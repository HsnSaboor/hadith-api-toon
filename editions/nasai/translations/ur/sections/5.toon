{"hadithnumber": "448", "text": "بسرہ بنت صفوان رضی اللہ عنہا کہتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جو اپنا ذکر  ( عضو"}
{"hadithnumber": "449", "text": "انس بن مالک، مالک بن صعصعہ رضی اللہ عنہما سے روایت کرتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمای"}
{"hadithnumber": "450", "text": "انس بن مالک اور ابن حزم رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ عز"}
{"hadithnumber": "451", "text": "یزید بن ابی مالک کہتے ہیں کہ  انس بن مالک رضی اللہ عنہ نے ہم سے بیان کیا کہ رسول اللہ صلی اللہ علیہ"}
{"hadithnumber": "452", "text": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  ۔ ( معراج کی شب )  جب رسول اللہ صلی اللہ علیہ وسلم کو لے"}
{"hadithnumber": "453", "text": "انس بن مالک رضی اللہ عنہ سے روایت ہے کہ  پنج وقتہ نمازیں مکہ میں فرض کی گئیں، دو فرشتے رسول اللہ صلی"}
{"hadithnumber": "454", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  ابتداء میں دو رکعت نماز فرض کی گئی، پھر سفر کی نماز  ("}
{"hadithnumber": "455", "text": "ولید کہتے ہیں کہ ابوعمرو اوزاعی نے مجھے خبر دی ہے کہ  انہوں نے زہری سے رسول اللہ صلی اللہ علیہ وسلم"}
{"hadithnumber": "456", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  نماز دو دو رکعت فرض کی گئی، پھر سفر کی نماز  ( دو ہی )"}
{"hadithnumber": "457", "text": "عبداللہ بن عباس رضی اللہ عنہم کہتے ہیں کہ  نماز بزبان نبی اکرم صلی اللہ علیہ وسلم حضر میں چار رکعت،"}
{"hadithnumber": "458", "text": "امیہ بن عبداللہ بن خالد بن اسید سے روایت ہے کہ  انہوں نے ابن عمر رضی اللہ عنہم سے پوچھا کہ آپ نماز"}
{"hadithnumber": "459", "text": "ابو سہیل اپنے باپ سے روایت کرتے ہیں کہ انہوں نے طلحہ بن عبیداللہ رضی اللہ عنہ کو کہتے سنا کہ  اہل نج"}
{"hadithnumber": "460", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم سے ایک آدمی نے دریافت کیا: اللہ کے رسول!"}
{"hadithnumber": "461", "text": "عوف بن مالک اشجعی رضی اللہ عنہ کہتے ہیں کہ  ہم لوگ رسول اللہ صلی اللہ علیہ وسلم کے پاس تھے، آپ صلی ا"}
{"hadithnumber": "462", "text": "ابن محریز سے روایت ہے کہ  بنی کنانہ کے ایک آدمی نے جسے مخدجی کہا جاتا تھا شام میں ایک آدمی کو جس کی"}
{"hadithnumber": "463", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم لوگوں کا کیا خیال"}
{"hadithnumber": "464", "text": "بریدہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ہمارے اور منافقوں کے درمیان"}
{"hadithnumber": "465", "text": "جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  بندے اور کفر کے درمیان سوائے"}
{"hadithnumber": "466", "text": "حریث بن قبیصہ کہتے ہیں کہ  میں مدینہ آیا، وہ کہتے ہیں: میں نے دعا کی، اے اللہ! مجھے کوئی نیک ہم نشیں"}
{"hadithnumber": "467", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  قیامت کے دن سب سے پہلے"}
{"hadithnumber": "468", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  سب سے پہلے بندہ سے نماز"}
{"hadithnumber": "469", "text": "ابوایوب رضی اللہ عنہ سے روایت ہے کہ  ایک شخص نے عرض کیا: اللہ کے رسول! مجھے کوئی ایسا عمل بتائیے جو"}
{"hadithnumber": "470", "text": "ابن منکدر اور ابراہیم بن میسرہ سے روایت ہے کہ  ان دونوں نے انس رضی اللہ عنہ کو کہتے سنا کہ میں نے نب"}
{"hadithnumber": "471", "text": "حکم بن عتیبہ کہتے ہیں کہ  میں نے ابوجحیفہ رضی اللہ عنہ کو کہتے سنا کہ رسول اللہ صلی اللہ علیہ وسلم د"}
{"hadithnumber": "472", "text": "عمارہ بن رویبہ ثقفی رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  جو"}
{"hadithnumber": "473", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کے آزاد کردہ غلام ابو یونس کہتے ہیں کہ  ام المؤمنین عائشہ رضی اللہ ع"}
{"hadithnumber": "474", "text": "علی رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے  ( جنگ خندق کے موقع پر )  فرمایا:  ان ل"}
{"hadithnumber": "475", "text": "ابوالملیح (ابوالملیح بن اسامہ) کہتے ہیں کہ  بدلی والے ایک دن میں ہم بریدہ رضی اللہ عنہ کے ساتھ تھے ت"}
{"hadithnumber": "476", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  ہم ظہر اور عصر میں رسول اللہ صلی اللہ علیہ وسلم کے قیام کا ا"}
{"hadithnumber": "477", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نماز ظہر میں قیام کرتے تھے تو ہ"}
{"hadithnumber": "478", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے مدینہ میں ظہر کی نماز چار رکعت،"}
{"hadithnumber": "479", "text": "نوفل بن معاویہ رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا کہ جس کی"}
{"hadithnumber": "480", "text": "نوفل بن معاویہ رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  نمازوں"}
{"hadithnumber": "481", "text": "نوفل بن معاویہ رضی اللہ عنہ کہتے ہیں کہ  ایک نماز ایسی ہے کہ جس کی وہ فوت ہو جائے گویا اس کا گھربار"}
{"hadithnumber": "482", "text": "سلمہ بن کہیل کہتے ہیں کہ  میں نے سعید بن جبیر کو مزدلفہ میں دیکھا، انہوں نے اقامت کہی، اور مغرب کی ن"}
{"hadithnumber": "483", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے عشاء کو مؤخر کیا یہاں"}
{"hadithnumber": "484", "text": "حکم کہتے ہیں کہ  ہمیں سعید بن جبیر نے مزدلفہ میں ایک اقامت سے مغرب کی تین رکعتیں پڑھائیں، پھر سلام پ"}
{"hadithnumber": "485", "text": "سعید بن جبیر کہتے ہیں کہ  میں نے عبداللہ بن عمر رضی اللہ عنہم کو مزدلفہ میں نماز پڑھتے دیکھا، انہوں"}
{"hadithnumber": "486", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تمہارے پاس رات اور دن"}
{"hadithnumber": "487", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جماعت کی نماز تمہاری"}
{"hadithnumber": "488", "text": "عمارہ بن رویبہ رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  وہ شخص"}
{"hadithnumber": "489", "text": "براء بن عازب رضی اللہ عنہ کہتے ہیں کہ  ہم نے رسول اللہ صلی اللہ علیہ وسلم کے ساتھ سولہ یا سترہ مہینہ"}
{"hadithnumber": "490", "text": "براء بن عازب رضی اللہ عنہم کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم مدینہ آئے تو آپ نے سولہ مہینہ ت"}
{"hadithnumber": "491", "text": "عبداللہ بن عمر رضی اللہ عنہم کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم سواری پر نفل پڑھتے تھے، وہ چا"}
{"hadithnumber": "492", "text": "عبداللہ بن عمر رضی اللہ عنہم کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم اپنی سواری پر  ( نفل )  نماز"}
{"hadithnumber": "493", "text": "عبداللہ بن عمر رضی اللہ عنہم کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم سفر میں اپنی سواری پر نماز پڑ"}
