2469,"ذعشحأدتثشأثىأؼثزتههۄأشعۏأتههۄأؼىۄوتأضەأشًتۏحأۄەأڬۄأشضًهأتههۄأ﷽أىەأؼشتۏتأًتهًڽأڬًأشرظحأزۏأحہۏأڬۄأًۄأځہهأڬتأتىزتصۄأڬشأڬەأتۏڬأًضمأ؏أزًأًضمأ؏أحۏىأتًشأډتشأًضمأڬەأثزهەأتځىتأځہهأثۏډأزۏڽأۗأتًشألشوتۏتأ=““أۄشأزضأًضمأڬہدًشۏڽأحًڔىەأځشأتۏڬأرًطۄأوضتڬۏىأڬەأهۏەأوضدزأوۏڽأشڬہتأدتةەأڲتأۗ‛‛أتوتوأتثًثڬشأشذوۄأتههۄألشوتحەأۄۏڽأ=أوۏڽأىەأزتشوۏأضەأضىتأۄەأ=أ®مىؼ¾أتًشأ®مٓىًٕ¾أڬتأوؼىۏأتۏڬأۄۏأۄەأ=““أرًطۄأ‛‛أۗ

[تخریج]: (2469) اسنادہ حسن : سنن ابی داؤد ، کتاب الزکاۃ ، باب فی حقوق المال ، حدیث : 1662 ۔ مسند احمد : 3 / 359 / 360 ۔ صحیح ابن حبان : 4987 ۔"
2470,"ذعشحأدتثشأشعۏأتههۄأؼىۄأىثۏأڬشۏوأ﷽أضەأشًتۏحأڬشحەأۄۏڽأڬۄأإځأىەألشوتۏتأ=““أدثأحوأىەأتځىەأوتهأڬۏأصڬًٳۆأتزتأڬشأزۏأحًأحوأىەأتضأوتهأڬۏأثشتةۏأتًشأوظۏثحأڬًأتځىەأضەأزًشأڬشأزۏتأۗ‛‛

[تخریج]: (2470) اسنادہ ضعیف : تقدم تخریجہ برقم : 2258 ۔"
2471,"ذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأشًتۏحأۄەأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أدثأحوأىەأتځىەأوتهأڬۏأصڬًٳۆأتزتأڬشأزۏأحًأحوأىەأتځىۏأسوۄأزتشۏأتًشألشعأتزتأڬشأزۏتأۗأتًشأدضأطرظأىەأذشتوأوتهأدوؼأڬۏتأځہشأتضأڬتأظزمۄأڬشأزۏتأحًأتضەأتضأظزمەأڬتأڬًةۏأتدشأىۄۏڽأوهەأڲتأتًشأتضأځشأتضأڬتأڲىتۄأۄًأڲتأۗ‛‛

[تخریج]: (2471) حسن : سنن ترمذی ، کتاب الزکاۃ ، باب ما جاء اذا ادیت الزکاۃ … ، حدیث : 618 ۔ الصحیحۃ : 3350 ۔ سنن ابن ماجہ : 1788 ۔ صحیح ابن حبان : 3216 ۔"
2472,"دىتثأتثىأثدۏزأتځىۏأزتزۏأضەأشًتۏحأڬشحەأۄۏڽأۗأًۄألشوتحۏأۄۏڽأ=أوۏڽأىەأؼشعأڬۏتأتەأتههۄأڬەأشضًهأ+أثؼعأتًمتحأ,أضتةهأوۏشەأځتضأإحتأۄەأدثڬۄأوۏشەأځتضأتضەأزۏىەأڬەأهۏەأڬډہأىۄۏڽأۄًحتأ+أحًأوۏڽأڬۏتأڬشًڽأ,أآأإځأىەألشوتۏتأ=““أضتةهأڬًأ+أرتهۏأۄتحہأ,أىۄأهًټتىتأ؏أتڲشأتۏڬأڬہشۏأۄًأحًأًۄۏأزەأزًأۗ‛‛أ
أدىتثأتطدأشتًۏأىەأ““أ®وّتأتْؼٕغٓۏٕۄٓ¾أ‛‛أڬەأتهلتػأثۏتىأىۄۏڽأڬۏەأۗأتوتوأتثًثڬشأشذوۄأتههۄألشوتحەأۄۏڽأ=أتثىأثدۏزأضەأوشتزأؼثزتهشذوتىأثىأثدۏزأثىأمثغۏأۄەأۗ

[تخریج]: (2472) اسنادہ صحیح : سنن نسائی ، کتاب الزکاۃ ، باب ردّ السائل ، حدیث : 2566 ۔ مسند احمد : 4 / 70 ۔ موطا امام مالک : 2 / 923 ۔"
2473,"دىتثأتثىأذتشخۄأڬەأثہتةۏأؼثزتهشذوىأثىأثدۏزأضەأشًتۏحأۄەأڬۄأتىہۏڽأتىأڬۏأزتزۏأىەأثۏتىأڬۏتأۗأ
أًۄأتوأثدۏزأۄۏڽأتًشأًۄأشضًهأتههۄأ﷽أڬۏأثۏؼحأڬشىەأًتهًڽأوۏڽأضەأحہۏڽأۗأتىہًڽأىەأشضًهأتههۄأ﷽أضەأؼشعأڬۏتأ=أتههۄأڬۏأمضوأ$أوضڬۏىأوۏشەأزشًتصەأځشأڬہڔتأۄًحتأۄەأتًشأوۏشەأځتضأتضەأزۏىەأڬەأهۏەأڬًةۏأډۏصأىۄۏڽأۄًحۏأحًأشضًهأتههۄأ﷽أىەأتىہۏڽأذڬوأزۏتأ=““أتڲشأحوہۏڽأتضەأزۏىەأڬەأهۏەأدهۏأۄًةۏأڬہشۏأڬەأضًتأڬډہأىۄأوهەأحًأًۄۏأتضأڬەأۄتحہأوۏڽأحہوتأزًأۗ‛‛

[تخریج]: (2473) اسنادہ صحیح : سنن ابی داؤد ، کتاب الزکاۃ ، باب حق السائل ، حدیث : 1667 ۔ سنن ترمذٖ : 665 ۔ سنن نسائی : 2575 ۔ مسند احمد : 6 / 382 ۔"
2474,"ذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄوتأثۏتىأڬشحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أدًأطرظأظزمۄأڬشأڬەأتځىتأظزمۄأًتځضأهەأهۏحتأۄەأتضأڬۏأوختهأتضأڬحەأدۏضۏأۄەأدًأمەأڬشحتأۄەأځہشأتځىۏأمەأڬًأډتټأهۏحتأۄەأۗ‛‛

[تخریج]: (2474) صحیح مسلم ، کتاب الہبات ، باب تحریم الرجوع فی الصدقۃ ، حدیث : 1622 ۔ سنن نسائی : 3723 ۔ سنن ابن ماجہ : 2391 ۔ مسند احمد : 1 / 349 ۔ صحیح بخاری ، کتاب الہبۃ ، باب لا یحل لاحد ان یرجع فی ہبۃ وصدقۃ ، حدیث : 2621 من طریق اٰخر عن سعید بن المسیب نحوہ ۔"
2475,ذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄوتأضەأشضًهأتههۄأ﷽أڬۏأوسڬًشۄأثتهتأڬۏأغشذأشًتۏحأوشًۏأۄەأۗ
2477,"ذعشحأدشۏشأثىأؼثزتههۄأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەأۄوۏڽأرغثۄأتشطتزألشوتحەأۄًةەأظزمۄأڬشىەأڬتأذڬوأزۏتأحًأهًڲًڽأىەأتضأذڬوأڬۏأحؼوۏهأوۏڽأحترۏشأڬشأزۏأذحۏأڬۄأإځأڬەأډۄشۄأوثتشڬأځشأؽظەأڬەأإختشأىوًزتشأۄًأڲةەأۗأځہشأتۏڬأتىظتشۏأظذتثۄأتۏڬأحہۏهۏأهتۏتأتًشأًۄأظزمۄأوۏڽأزەأزۏأۗأځہشأهًڲأځەأزشځەأظزمۄأهتىەأهڲەأذحۏأڬۄأشضًهأتههۄأ﷽أڬتأډۄشۄأوثتشڬأرًطۏأضەأڬہهأتټہتأۗأحًأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أدضأطرظأىەأڬًةۏأتډہتأغشۏمۄأشتةدأڬۏتأحًأتضەأتځىتأثہۏأتًشأتضأغشۏمەأځشأؼوهأڬشىەأًتهەأحوتوأهًڲًڽأڬتأثہۏأتدشأوهەأڲتأدثڬۄأتىأڬەأتځىەأتدشأوۏڽأثہۏأڬوۏأىۄۏڽأڬۏأدتةەأڲۏأۗأتًشأدضأطرظأىەأ+أتضهتوأوۏڽأ,أثشتأغشۏمۄأشتةدأڬۏتأحًأتضەأتضأڬتأتځىتأتًشأتضأغشۏمەأځشأؼوهأڬشىەأًتهەأحوتوأهًڲًڽأڬتأثہۏأڲىتۄأۄًأڲتأدثڬۄأزۏڲشأؼوهأڬشىەأًتهًڽأڬەأتځىەأڲىتۄأوۏڽأثہۏأڬًةۏأڬوۏأىۄۏڽأۄًأڲۏأ1‛‛

[تخریج]: (2477) صحیح مسلم ، کتاب الزکاۃ ، باب الحث علی الصدقۃ ولو بشق تمرۃ ، حدیث : 1017 ۔ مسند احمد : 4 / 361 ۔ سنن الدارمی : 514 ۔ صحیح ابن حبان : 3297 ۔"
2478,"ذعشحأؼمثۄأثىأؼتوشأدۄىۏأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أؽۏشحأزًأمضوأڬۏأۄەأۗأتۏڬأتههۄأحؼتهۏٳأڬًأځضىزأۄەأتًشأزًضشۏأىتأځضىزأۄەأۗأدىأڬتوًڽأوۏڽأحۄوحأهڲىەأتًشأثزڲوتىۏأځۏزتأۄًىەأڬتأرغشۄأۄًأتىأوۏڽأؽۏشحأڬًأتههۄأحؼتهۏٳأځضىزأڬشحەأۄۏڽأۗأتًشأدىأتوًشأوۏڽأطڬأًأطثۄأتًشأحۄوحأهڲىەأڬتأرزطۄأىۄأۄًأتىأوۏڽأؽۏشحأڬًأتههۄأحؼتهۏٳأىتځضىزأڬشحەأۄۏڽأۗأدثأإزوۏأظزمۄأرۏشتحأڬشأڬەأتحشتةەأحًأتههۄأحؼتهۏٳأتضأطًرۏأڬًأځضىزأڬشحەأۄۏڽأۗأتًشأدضألرشأًأؽشًشأڬتأضثثأحڬثشأۄًأتضەأتههۄأحؼتهۏٳأىتځضىزأڬشحەأۄۏڽأۗ‛‛أتًشأإځأىەألشوتۏتأ=““أحۏىأتلشتزأڬۏأزؼتأثۄحأمثًهأۄًحۏأۄەأ=أًتهزأڬۏأزؼتأ+أتًهتزأڬەأذمأوۏڽأ,أوضتلشأتًشأوػهًوأڬۏأزؼتأ‛‛أتًشأإځأىەألشوتۏتأ=““أثەأطڬأتههۄأحؼتهۏٳأتۏڬأحۏشأڬەأضثثأضەأحۏىأتلشتزأڬًأدىحأوۏڽأزترهأڬشحتأۄەأۗأحۏشأثىتىەأًتهەأڬًأ؏أحۏشأودتۄزأڬًألشتۄوأڬشىەأًتهەأڬًأتًشأتههۄأڬۏأشتۄأوۏڽأتضأحۏشأڬًأډهتىەأًتهەأودتۄزأڬًأۗ‛‛

[تخریج]: (2478) اسنادہ صحیح ، الصحیحۃ : 315 ۔ مسند احمد : 4 / 154 ۔"
2479,"ذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأىثۏأڬشۏوأ﷽أضەأشًتۏحأڬشحەأۄۏڽأڬۄأإځأىەألشوتۏتأ=““أتههۄأحؼتهۏٳألشوتحەأۄۏڽأ=أوۏڽأىەأتځىەأثىزەأضەأمشعأوتىڲتأحًأتضأىەأودہەأمشعأىۄۏڽأزۏتأۗأتًشأوۏشەأثىزەأىەأودہەأڲتهۏأزۏأدثڬۄأًۄأدتىحتأىۄۏڽأ؏أڬۄحتأۄەأۄتةەأصوتىەأڬۏأثشثتزۏأۗأۄتةەأصوتىەأڬۏأۄهتڬحأۗأذتهتىڬۄأصوتىۄأوۏڽأۄًڽأۗ‛‛أتوتوأتثًثڬشأشذوۄأتههۄألشوتحەأۄۏڽأڬۄأتشطتزأثتشۏأحؼتهۏٳأ=““أوۏڽأصوتىۄأۄًڽأ‛‛أڬتأوغهثأۄەأڬۄأوۏڽأۄۏأصوتىەأڬەأزىأشتحأحثزۏهأڬشحتأۄًڽأڬثہۏأرًطذتهۏأحًأڬثہۏأحىڲأزضحۏأځۏزتأڬشحتأۄًڽأدۏضەأوۏڽأډتۄحتأۄًڽأۗأدثڬۄأثؼعأڬتلشًڽأڬتأؼمۏزۄأۄەأڬۄأتىہۏڽأصوتىۄأۄهتڬأڬشحتأۄەأتههۄأحؼتهۏٳأىەأتىأڬتأمًهأثۏتىأڬشحەأۄًةەألشوتۏتأ=أ+أًۄأڬۄحەأۄۏڽأ,أ=““أتًشأۄوۏڽأحًأظشلأصوتىۄأۄۏأۄهتڬأڬشحتأۄەأۗ‛‛أتههۄأحؼتهۏٳأىەأثحتۏتأۄەأڬۄأتىہۏڽأتضأثتحأڬتأؼهوأۄۏأىۄۏڽأتًشأتىأڬتأۏۄأمًهألمغأتىأڬتأرۏتهأًأڲوتىأۄەأۗأتشطتزأثتشۏأحؼتهۏٳأۄەأ=““أتًشأتىہۏڽأتضأثتحأڬتأڬډہأؼهوأىۄۏڽأ؏أًۄأحًأثضأتټڬهأځډًأهڲتحەأۄۏڽأۗ‛‛أتًشأىثۏأڬشۏوأ﷽أىەأثحتأزۏتأۄەأڬۄأتىأ
أڬتأصوتىۄأڬًأڲتهۏتڽأزۏىتأتههۄأحؼتهۏٳأڬًأڲتهۏأزۏىتأۄەأڬۏًىڬۄأًۄأڲوتىأشڬہحەأۄۏڽأڬۄأتىۄۏڽأصوتىۄأۄهتڬأڬشحتأۄەأځضأًۄأۄهتڬأڬشىەأًتهەأڬًأڲتهۏأزۏحەأۄۏڽأذتهتىڬۄأتىہۏڽأۄهتڬأًأثشثتزأڬشىەأًتهۏأستحأتههۄأڬۏأۄەأ؏أصوتىۄأىۄۏڽأهۄٳستأۄشأڬتلشأدًأتځىەأۄهتڬأڬشىەأًتهەأڬًأڲتهۏأزۏحتأۄەأحًأتضأڬۏأڲتهۏأتىأڬەأرتهمأڬًأدتحۏأۄەأدضأىەأتىہۏڽأۄهتڬأڬۏتأۄەأۗأتىأڬۏأڲتهۏأصوتىەأڬًأىۄۏڽأوهحۏأڬۏًىڬۄأتىہۏڽأۄهتڬأڬشىەأوۏڽأتضأڬتأڬًةۏأؼوهأزرهأىۄۏڽأڬۏًىڬۄأصوتىەأڬتأرتهمأثہۏأتههۄأحؼتهۏٳأۄۏأۄۏڽأۗ

[تخریج]: (2479) اسنادہ حسن : الصحیحۃ : 3477 ۔ خلق افعال العباد للبخاری : 57 ۔ مسند احمد : 2 / 300 ۔ مسند ابی یعلی : 6466 ۔"
2480,"ذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أدًأطرظأتځىەأوتهأضەأزًأډۏصۏڽأ+أدًڔتأ,أتههۄأڬۏأشتۄأوۏڽأرشډأڬشەأحًأتضأڬًأدىحأڬەألشطحەأ+أزشًتصًڽأځشأ,أثهتةۏڽأڲەأۗأتًشأدىحأڬەأڬةۏأزشًتصەأۄۏڽأهۄٳستأدًأىوتصۏأۄًأڲتأتضەأثتثأتهظهتۆأضەأثهتۏتأدتةەأڲتأۗأتًشأدًأظزمۄأتًشأصڬًٳۆأتزتأڬشىەأًتهتأۄًأڲتأتضەأثتثأتهظزمۆأضەأثهتۏتأدتةەأڲتأۗأتًشأدًأدۄتزأڬشحتأشۄتأۄًأڲتأتضەأدۄتزأڬەأزشًتصەأضەأثهتۏتأدتةەأڲتأۗأتًشأدًأشًصەأزتشأۄًأتضەأثتثأتهشۏتىأضەأثهتۏتأدتةەأڲتأۗ‛‛أحًأذعشحأتثًثڬشأشعۏأتههۄأؼىۄأىەأإځأضەأؼشعأڬۏأ=أتههۄأڬۏأمضوأ$أتەأتههۄأڬەأشضًهأ﷽أ$أتڲشأڬًةۏأطرظأتىأزشًتصًڽأوۏڽأضەأڬضۏأتۏڬأزشًتصەأوۏڽأضەأثہۏأثهتۏتأدتةەأحًأثہۏأڬًةۏأذشدأىۄۏڽأهۏڬىأڬۏتأڬًةۏأتۏضتأثہۏأرًطأىظۏثأۄًأڲتأدًأتٓىأحوتوأزشًتصًڽأضەأثهتۏتأدتةەأڲتأآأإځأىەألشوتۏتأ=““أۄتڽأتۏضەأرًطأىظۏثأۄًڽأڲەأتًشأودہەأتوۏزأۄەأڬۄأحوأثہۏأتىأوۏڽأطتوهأۄًأڲەأۗ‛‛

[تخریج]: (2480) صحیح بخاری ، کتاب الصوم ، باب الریان للصائمین ، حدیث : 1897 ۔ صحیح مسلم ، کتاب الزکاۃ ، باب فضل من ضم الی الصدقۃ غیرہا … ، حدیث : 1027 ۔ سنن ترمذی : 3674 ۔ سنن نسائی : 2240 ۔ مسند احمد : 2 / 268 ۔ صحیح ابن حبان : 3419 ۔"
2481,"ذعشحأتثًضؼۏزأرزشۏأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأڬۄأدوؼەأًتهەأزىأتۏڬأطرظأثڔۏأرضحۄأذتهحأوۏڽأإۏتأدثڬۄأشضًهأتههۄأ﷽أرغثۄأتشطتزألشوتأشۄەأحہەأۗأحًأشضًهأتههۄأ﷽أىەأهًڲًڽأڬًأتضأځشأظزمۄأڬشىەأڬتأذڬوأزۏتأحًأهًڲًڽأىەأتځىەأڬډہأڬځڔەأظزمەأڬەأهۏەأشڬہأزۏەأإځأىەأتضەأزًأڬځڔەأزۏىەأڬتأذڬوأزۏتأتًشأإځأىەأتضەأذڬوأزۏتأحًأتضأىەأزًأشڬؼحأتزتأڬۏڽأدثڬۄأشضًهأتههۄأ﷽أرغثۄأتشطتزألشوتأشۄەأحہەأۗأځہشأثمۏۄأذزۏخأثۏتىأڬۏأۗأوۏڽأىەأۏۄأذزۏخأڬحتثأتهدوؼۄأوۏڽأثۏتىأڬشأزۏأۄەأۗ

[تخریج]: (2481) تقدم تخریجہ برقم : 1799 ۔"
2482,"دىتثأطلۏأتظثذۏأثۏتىأڬشحەأۄۏڽأڬۄأًۄأوزۏىۄأوىًشۄأوۏڽأزترهأۄًةەأحًأتىہًڽأىەأزۏڬہتأڬۄأتۏڬأطرظأڬەأځتضأڬتلۏأهًڲأدوؼأۄۏڽأۗأحًأتىہًڽأىەأځًډہتأ=أۏۄأڬًىأظتذثأۄۏڽأآأهًڲًڽأىەأثحتۏتأڬۄأ
أۏۄأذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأۄۏڽأۗأهۄٳستأوۏڽأ
أتىأڬەأمشۏثأدتأڬشأتىأڬەأضتوىەأثۏټہأڲۏتأ؏أدثڬۄأًۄأهًڲًڽأڬًأذزۏخأثۏتىأڬشأشۄەأحہەأۗأځہشأدثأًۄأرتوًطأۄًةەأتًشأتڬۏهەأشۄأڲةەأحًأوۏڽأىەأؼشعأڬۏأ=أوۏڽأإځأڬًأتههۄأحؼتهۏٳأڬۏأمضوأتًشأتضأڬەأذمأڬتأًتضغۄأزەأڬشأڲصتشطأڬشحتأۄًڽأڬۄأإځأودہەأًۄأذزۏخأثۏتىأڬشۏڽأدًأإځأىەأشضًهأتههۄأ﷽أضەأضىأڬشأۏتزأشڬہۏأۄًأتًشأإځأتضەأثرًثۏأدتىحەأۄًڽأۗأحًأذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأىەألشوتۏتأ=أوۏڽأحوہۏڽأتۏضۏأۄۏأذزۏخأضىتاڽأڲتأدًأوۏڽأىەأشضًهأتههۄأ﷽أضەأضىۏأتًشأۏتزأشڬہۏأۄەأۗأځہشأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضضڬۏتڽأهەأڬشأشًىەأهڲأڲةەأتًشأثەأۄًطأۄًأڲةەأځہشأحہًڔۏأزۏشأڬەأثؼزأۄًطأإۏتأحًألشوتىەأهڲەأ=أوۏڽأحوہۏڽأعشًشأتۏضۏأذزۏخأضىتاڽأڲتأدًأودہەأشضًهأتههۄأ﷽أىەأثۏتىأڬۏأحہۏأدثڬۄأوۏڽأتًشأإځأتضأڲہشأوۏڽأتڬۏهەأوًدًزأحہەأۗأځہشأزًضشۏأثتشأذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأىەأضضڬۏتڽأهەأڬشأشًىتأطشًؼأڬشأزۏتأتًشأثەأۄًطأۄًأڲةەأۗأځہشأۄًطأوۏڽأإةەأتًشأتځىەأډۄشەأڬًأظتلأڬۏتأۗأځہشألشوتۏتأ=أوۏڽأحوہۏڽأذزۏخأضىتحتأۄًڽأ؏أوۏڽأعشًشأحوہۏڽأتۏضۏأذزۏخأضىتاڽأڲتأدًأشضًهأتههۄأ﷽أىەأودہەأتضأًمحأضىتةۏأحہۏأدثأوۏڽأتًشأإځأتضأڲہشأوۏڽأتڬۏهەأۄۏأحہەأۄوتشەأؼهتًۄأڬًةۏأتًشأوًدًزأىۄأحہتأځہشأذعشحأتثًۄشۏشۄأطزۏزأضضڬۏتڽأهەأڬشأشًىەأهڲأڲةەأځہشأثەأۄًطأۄًأڬشأوىۄأڬەأثهأڲشأڲةەأتًشأوۏڽأزۏشأحڬأإځأڬًأضۄتشتأزەأڬشأثۏټہتأشۄتأۗأځہشأدثأۄًطأوۏڽأإةەأحًألشوتۏتأ=أشضًهأتههۄأ﷽أىەأودہەأثۏتىأڬۏتأ=““أدثأمۏتوحأڬتأزىأۄًأڲتأحًأتههۄأحؼتهۏٳأورهًمأڬەأزشوۏتىألۏظهەأڬەأهۏەأحطشۏلأهتةۏڽأڲەأدثڬۄأۄشأتوحأڲہټىًڽأڬەأثهأثۏټہۏأۄًأڲۏأۗأضثأضەأځۄهەأمتشۏأمشإىأڬًأثهتۏتأدتةەأڲتأتًشأتههۄأڬۏأشتۄأوۏڽأدۄتزأڬشىەأًتهەأودتۄزأڬًأدًأطۄۏزأۄًتأحہتأتًشأزًهحأوىزأطرظأڬًأثهتۏتأدتةەأڲتأتههۄأحؼتهۏٳأمتشۏأضەألشوتةۏڽأڲەأ=أڬۏتأوۏڽأىەأحوہۏڽأًۄأڬحتثأىۄۏڽأضڬہتةۏأحہۏأدًأوۏڽأىەأتځىەأشضًهأځشأىتصهأڬۏأحہۏأآأًۄأڬۄەأڲتأ=أڬۏًڽأىۄۏڽأتەأوۏشەأشثأ$أحًأتههۄأحؼتهۏٳألشوتةۏڽأڲەأ=أحًأحوأىەأؼهوأذتظهأڬشىەأڬەأثؼزأڬۏتأؼوهأڬۏتأآأًۄأدًتثأزەأڲتأ=أوۏڽأزىأشتحأىوتصأوۏڽأتضأڬۏأحهتًحأڬشحتأحہتأحًأتههۄأحؼتهۏٳألشوتةۏڽأڲەأ=أحوأىەأدہًټأثًهتأۄەأۗأتًشألشطحەأثہۏأڬۄۏڽأڲەأ=أحوأىەأدہًټأڬۄتأۄەأۗأتًشأتههۄأحؼتهۏٳألشوتةۏڽأڲەأ=أثهڬۄأحوأحًأۏۄأډتۄحەأحہەأڬۄأڬۄتأدتةەأ=ألهتڽأثۄحأثڔتأمتشۏأۄەأۗأحًأۏۄأثتحأحًأ+أزىۏتأوۏڽأ,أڬۄۄأزۏأڲةۏأحہۏأۗأتًشأوتهزتشأطرظأڬًأهتۏتأدتةەأڲتأحًأتههۄأحؼتهۏٳألشوتةۏڽأڲەأ=أڬۏتأوۏڽأىەأحوہۏڽأتحىتأوتهأًأزًهحأؼغتأىۄۏڽأڬۏتأحہتأڬۄأحوأڬضۏأطرظأڬەأوذحتدأىۄۏڽأشۄەأحہەأآأًۄأدًتثأزەأڲتأ=أعشًشأتۏضەأۄًتأحہتأۗأتههۄأحؼتهۏٳألشوتةۏڽأڲەأ=أحًأحوأىەأوۏشەأؼغتأڬۏەأۄًةەأوتهأوۏڽأڬۏتأؼوهأڬۏتأآأًۄأڬۄەأڲتأ=أوۏڽأتضأوتهأضەأظهۄأشذوۏأڬشحتأحہتأ؏أتًشأظزمۄأًأرۏشتحأڬشحتأحہتأۗأحًأتههۄأحؼتهۏٳأتًشأتضأڬەألشطحەأڬۄۏڽأڲەأ=أحوأىەأدہًټأثًهتأۄەأتههۄأحؼتهۏٳألشوتةۏڽأڲەأ=أثهڬۄأحوہتشتأتشتزۄأحًأۏۄأحہتأڬۄأهًڲأڬۄۏڽأ=ألهتڽأطرظأثڔتأضرۏأۄەأحًأًۄأڬۄۄأزۏتأڲۏتأحہتأۗأځہشأتههۄأڬۏأشتۄأوۏڽأمحهأۄًىەأًتهەأودتۄزأڬًأهتۏتأدتةەأڲتأحًأتضأضەأځًډہتأدتةەأڲتأ=أحوأىەأڬضأومظزأڬەأهۏەأدتىأزۏأآأحًأًۄأڬۄەأڲتأ=أتههۄأحوأىەأتځىەأشتضحەأوۏڽأدۄتزأڬشىەأڬتأذڬوأزۏتأحہتأحًأوۏڽأىەأدىڲأهڔۏأذحۏأڬۄأوۏڽأمحهأۄًأڲۏتأحًأتههۄأحؼتهۏألشوتةۏڽأڲەأ=أحوأىەأدہًټأثًهتأۄەأۗأتًشألشطحەأثہۏأڬۄۏڽأڲەأ=أحوأدہًټەأۄًأتًشأتههۄأحؼتهۏٳألشوتةۏڽأڲەأ=أثهڬۄأحوہتشتأتشتزۄأحًأۏۄأحہتأڬۄأڬۄتأدتةەأ=ألهتڽأطرظأثڔتأثۄتزشأۄەأحًأزىۏتأوۏڽأۏۄأڬۄۄأزۏتأڲۏتأحہتأځہشأشضًهأتههۄأ﷽أىەأوۏشەأڲہټىەأځشأۄتحہأوتشأڬشألشوتۏتأ=أتەأتثًۄشۏشۄأ$أۏۄأحۏىأتلشتزأًۄأځۄهۏأتههۄأڬۏأورهًمأۄًڽأڲەأدىأضەأمۏتوحأڬەأزىأدۄىوأڬۏأإڲأثہڔڬتةۏأدتةەأڲۏأۗ‛‛أدىتثأؼمثۄأڬۄحەأۄۏڽأ=أدىتثأطْلۏأىەأۄۏأۏۄأذزۏخأذعشحأوؼتًۏۄأشعۏأتههۄأؼىۄأڬۏأرزوحأوۏڽأذتعشأۄًأڬشأثۏتىأڬۏأحہۏأۗأدىتثأتهؼهتؤأثىأتثۏأذڬۏوأثۏتىأڬشحەأۄۏڽأڬۄأطْلۏأذعشحأوؼتًۏۄأڬەأدهتزأحہەأتًشأتۏڬأطرظأىەأذعشحأوؼتًۏۄأشعۏأتههۄأؼىۄأڬەأځتضأذتعشأۄًأڬشأۏۄأذزۏخأثۏتىأڬۏأحًأتىہًڽأىەألشوتۏتأ=أتههۄأتًشأتضأڬەأشضًهأىەأضډألشوتۏتأۄەأۗأځہشأۏۄأإۏحأځڔہۏأ=أدًأطرظأزىۏتأڬۏأصىزڲۏأتًشأتضأڬۏأصۏىحأډتۄحتأۄەأحًأۄوأتىأڬەأتؼوتهأڬتأثزهۄأتضۏأزىۏتأوۏڽأزەأزۏحەأۄۏڽأۗأتًشأتضأوۏڽأتىأڬۏأذمأحهلۏأىۄۏڽأڬۏأدتحۏأۗأۏۄۏأهًڲأۄۏڽأدىأڬەأهۏەأإرشحأوۏڽأإڲأڬەأضًتأڬډہأىۄۏڽأ؏أتًشأًۄأثشثتزأۄًأڲۏتأدًأڬډہأتىہًڽأىەأزىۏتأوۏڽأڬوتۏتأحہتأتًشأدًأًۄأؼوهأڬشحەأشۄەأ؏أعتةؼأۄًأڲةەأۗأ+أضًشۄأہًزأ=أ48أ؏أ49أ,أۗ

[تخریج]: (2482) اسنادہ صحیح : خلق افعال العباد للبخاری : 42 ۔ سنن ترمذی ، کتاب الزہد ، باب ما جاء فی الریاء والسمعۃ ، حدیث : 2382 ۔ سنن کبرٰی نسائی : 1824 ۔ صحیح ابن حبان : 408 ۔"
