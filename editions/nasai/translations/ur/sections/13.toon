{"hadithnumber": "1328", "text": "محمود بن ربیع رضی اللہ عنہ کہتے ہیں کہ  میں نے عتبان بن مالک رضی اللہ عنہ کو کہتے سنا کہ میں اپنی قو"}
{"hadithnumber": "1329", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم عشاء سے فجر تک کے بیچ میں"}
{"hadithnumber": "1330", "text": "عبداللہ بن مسعود رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے سلام پھیرا، پھر آپ نے گ"}
{"hadithnumber": "1331", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے سلام پھیرا، پھر سہو کے دو سجدے"}
{"hadithnumber": "1332", "text": "عمران بن حصین رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے تین رکعت نماز پڑھ کر سلا"}
{"hadithnumber": "1333", "text": "براء بن عازب رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کی نماز کو بغور دیکھا، تو"}
{"hadithnumber": "1334", "text": "ام المؤمنین ام سلمہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے زمانے میں عورتیں جب ن"}
{"hadithnumber": "1335", "text": "یزید بن اسود رضی اللہ عنہ روایت کرتے ہیں کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم کے ساتھ نماز فجر"}
{"hadithnumber": "1336", "text": "عبداللہ بن عباس رضی اللہ عنہم کہتے ہیں  میں رسول اللہ صلی اللہ علیہ وسلم کی نماز کے ختم ہونے کو تکبی"}
{"hadithnumber": "1337", "text": "عقبہ بن عامر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مجھے حکم دیا کہ میں ہر نماز ک"}
{"hadithnumber": "1338", "text": "ثوبان رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم جب نماز سے فارغ ہو کر پلٹتے تو تین بار"}
{"hadithnumber": "1339", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم جب سلام پھیرتے تو کہتے:"}
{"hadithnumber": "1340", "text": "ابوالزبیر کہتے ہیں کہ  میں نے عبداللہ بن زبیر رضی اللہ عنہم کو اس منبر پر بیان کرتے ہوئے سنا، وہ کہہ"}
{"hadithnumber": "1341", "text": "ابو الزبیر کہتے ہیں کہ  عبداللہ بن زبیر رضی اللہ عنہم نماز کے بعد تہلیل کرتے اور کہتے: «لا إله إلا ا"}
{"hadithnumber": "1342", "text": "مغیرہ بن شعبہ رضی اللہ عنہ کے منشی وراد کہتے ہیں کہ  معاویہ رضی اللہ عنہ نے مغیرہ بن شعبہ رضی اللہ ع"}
{"hadithnumber": "1343", "text": "وراد کہتے ہیں کہ  مغیرہ بن شعبہ رضی اللہ عنہ نے معاویہ رضی اللہ عنہ کو لکھا کہ رسول اللہ صلی اللہ عل"}
{"hadithnumber": "1344", "text": "مغیرہ رضی اللہ عنہ کے منشی وراد سے روایت ہے کہ  معاویہ رضی اللہ عنہ نے مغیرہ رضی اللہ عنہ کو لکھا: م"}
{"hadithnumber": "1345", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم جب کسی مجلس میں بیٹھتے"}
{"hadithnumber": "1346", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  ایک یہودی عورت میرے پاس آئی اور کہنے لگی: پیشاب سے نہ ب"}
{"hadithnumber": "1347", "text": "ابومروان روایت کرتے ہیں کہ  کعب رضی اللہ عنہ نے ان سے اس اللہ کی قسم کھا کر کہا جس نے موسیٰ کے لیے س"}
{"hadithnumber": "1348", "text": "ابوبکرہ رضی اللہ عنہ کہتے ہیں کہ  میرے والد  ( ابوبکرہ رضی اللہ عنہ )  نماز کے بعد یہ دعا پڑھتے: «ال"}
{"hadithnumber": "1349", "text": "عبداللہ بن عمرو رضی اللہ عنہم کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  دو ایسی خصلتیں ہ"}
{"hadithnumber": "1350", "text": "کعب بن عجرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  کچھ ایسے الفاظ ہیں جن"}
{"hadithnumber": "1351", "text": "زید بن ثابت رضی اللہ عنہ کہتے ہیں کہ  لوگوں کو حکم دیا گیا کہ وہ ہر نماز کے بعد تینتیس بار «سبحان ال"}
{"hadithnumber": "1352", "text": "عبداللہ بن عمر رضی اللہ عنہم سے روایت ہے کہ  ایک آدمی نے دیکھا جیسے سونے والا خواب دیکھتا ہے، اس سے"}
{"hadithnumber": "1353", "text": "ام المؤمنین جویریہ بنت حارث رضی اللہ عنہا سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم ان کے پاس سے گ"}
{"hadithnumber": "1354", "text": "عبداللہ بن عباس رضی اللہ عنہم کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے پاس کچھ فقراء نے آ کر عرض"}
{"hadithnumber": "1355", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص فجر کی نماز کے بع"}
{"hadithnumber": "1356", "text": "عبداللہ بن عمرو رضی اللہ عنہم کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو تسبیح گنتے ہوئے دی"}
{"hadithnumber": "1357", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم  ( رمضان کے )  مہینہ کے بیچ کے"}
{"hadithnumber": "1358", "text": "جابر بن سمرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم جب نماز فجر سے فارغ ہو جاتے تو آ"}
{"hadithnumber": "1359", "text": "سماک بن حرب کہتے ہیں کہ  میں نے جابر بن سمرہ رضی اللہ عنہ سے پوچھا: آپ رسول اللہ صلی اللہ علیہ وسلم"}
{"hadithnumber": "1360", "text": "سدی (اسماعیل بن عبدالرحمٰن) کہتے ہیں کہ  میں نے انس بن مالک رضی اللہ عنہ سے پوچھا کہ میں اپنے داہنے"}
{"hadithnumber": "1361", "text": "اسود کہتے ہیں کہ  عبداللہ بن مسعود رضی اللہ عنہ نے کہا: تم میں سے کوئی خود سے شیطان کا کوئی حصہ نہ ک"}
{"hadithnumber": "1362", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو کھڑے ہو کر اور ب"}
{"hadithnumber": "1363", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  عورتیں رسول اللہ صلی اللہ علیہ وسلم کے ساتھ نماز فجر اد"}
{"hadithnumber": "1364", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  ایک دن رسول اللہ صلی اللہ علیہ وسلم نے ہمیں نماز پڑھائی، پھر ہ"}
{"hadithnumber": "1365", "text": "ابوذر رضی اللہ عنہ کہتے ہیں کہ  ہم نے رمضان میں رسول اللہ صلی اللہ علیہ وسلم کے ساتھ روزے رکھے، لیکن"}
{"hadithnumber": "1366", "text": "عقبہ بن حارث رضی اللہ عنہ کہتے ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم کے ساتھ مدینہ میں نماز عصر"}
