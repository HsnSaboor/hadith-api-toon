metadata:
  section_id: 4
  section_name: Chapter 4
  hadith_first: 31
  hadith_last: 35

hadiths[5]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
31,“I used to comb the hair of Allah’s Messenger (Allah bless him and give him peace) while I was menstruating.”,,,48746,"A’isha said:",Chapter 4
32,"“Allah’s Messenger (Allah bless him and give him peace) made a frequent practice of oiling his head and combing his beard, and he often wore the head veil, so it was as if his\nrobe was the robe of an oil dealer.”",,,48747,"Anas ibn Malik said:",Chapter 4
33,"“Allah’s Messenger (Allah bless him and give him peace) used to love tayammun  in his ritual purification when\nhe purified himself, in his combing when he combed his hair, and putting on his shoes when he donned them.”",,,48748,"'A’isha said:",Chapter 4
34,"""Allah’s Messenger (Allah bless him and give him peace) forbade combing except at intervals.”",,,48749,"'Abdullah ibn Mughaffal said:",Chapter 4
35,"""The Prophet (Allah bless him and give him peace) used to comb his hair at intervals.”",,,48750,"Humaid ibn 'Abd ar-Rahman relates on the authority of a man from among the Companions of the Prophet (Allah bless him and give him peace):",Chapter 4
