{"hadithnumber": "3571", "text": "ابوہریرہ رضی اللہ عنہ کا ارشاد ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو قاضی بنا دیا گیا"}
{"hadithnumber": "3572", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جو شخص لوگوں کے درمیان قا"}
{"hadithnumber": "3573", "text": "بریدہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  قاضی تین طرح کے ہوتے ہیں:"}
{"hadithnumber": "3574", "text": "عمرو بن العاص رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب حاکم  ( قاضی )"}
{"hadithnumber": "3575", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جو شخص مسلمانوں کے منصب ق"}
{"hadithnumber": "3576", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں  آیت کریمہ «ومن لم يحكم بما أنزل الله فأولئك هم الكافرون»  ج"}
{"hadithnumber": "3577", "text": "عبدالرحمٰن بن بشر انصاری ازرق کہتے ہیں کہ  کندہ کے دروازوں سے دو شخص جھگڑتے ہوئے آئے اور ابومسعود ان"}
{"hadithnumber": "3578", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو کہتے سنا:  جو شخص منصب"}
{"hadithnumber": "3579", "text": "نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:   ہم ہرگز کسی ایسے شخص کو عامل مقرر نہیں کریں گے جو عامل بننا"}
{"hadithnumber": "3580", "text": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے رشوت دینے، اور رشوت لینے"}
{"hadithnumber": "3581", "text": "عدی بن عمیرہ کندی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  لوگو! تم میں سے"}
{"hadithnumber": "3582", "text": "علی رضی اللہ عنہ کہتے ہیں کہ  مجھے رسول اللہ صلی اللہ علیہ وسلم نے یمن کا قاضی بنا کر بھیجا تو میں ن"}
{"hadithnumber": "3583", "text": "ام المؤمنین ام سلمہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  میں انسان ہی"}
{"hadithnumber": "3584", "text": "ام المؤمنین ام سلمہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے پاس دو شخص اپنے میراث"}
{"hadithnumber": "3585", "text": "اس سند سے بھی ام المؤمنین ام سلمہ رضی اللہ عنہا سے یہی حدیث مروی ہے، اس میں اتنا اضافہ ہے کہ  وہ دون"}
{"hadithnumber": "3586", "text": "ابن شہاب کہتے ہیں کہ  عمر بن خطاب رضی اللہ عنہ نے منبر پر فرمایا:  لوگو! رائے تو صرف رسول اللہ صلی ا"}
{"hadithnumber": "3587", "text": "معاذ بن معاذ کہتے ہیں  ابوعثمان شامی نے مجھے خبر دی اور میری نظر میں ان سے  ( یعنی حریز بن عثمان سے"}
{"hadithnumber": "3588", "text": "عبداللہ بن زبیر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے حکم دیا کہ مدعی اور مدعا"}
{"hadithnumber": "3589", "text": "ابوبکرہ رضی اللہ عنہ سے روایت ہے  انہوں نے اپنے بیٹے کے پاس لکھا کہ رسول اللہ صلی اللہ علیہ وسلم نے"}
{"hadithnumber": "3590", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں  آیت کریمہ «فإن جاءوك فاحكم بينهم أو أعرض عنهم»  جب کافر آپ"}
{"hadithnumber": "3591", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں  جب یہ آیت «فإن جاءوك فاحكم بينهم أو أعرض عنهم»  جب کافر آپ"}
{"hadithnumber": "3592", "text": "معاذ بن جبل رضی اللہ عنہ کے اصحاب میں سے حمص کے کچھ لوگ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے"}
{"hadithnumber": "3593", "text": "معاذ بن جبل رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے جب انہیں یمن کی طرف بھیجا۔ ۔ ۔"}
{"hadithnumber": "3594", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مسلمانوں کے درمیان مصالح"}
{"hadithnumber": "3595", "text": "کعب بن مالک رضی اللہ عنہ کہتے ہیں کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم کے عہد میں ابن ابی حدرد"}
{"hadithnumber": "3596", "text": "زید بن خالد جہنی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  کیا میں تمہیں سب"}
{"hadithnumber": "3597", "text": "یحییٰ بن راشد کہتے ہیں کہ  ہم عبداللہ بن عمر رضی اللہ عنہما کے انتظار میں بیٹھے تھے، وہ ہمارے پاس آ"}
{"hadithnumber": "3598", "text": "اس سند سے بھی ابن عمر رضی اللہ عنہما نے نبی اکرم صلی اللہ علیہ وسلم سے اسی مفہوم کی حدیث روایت کی ہے"}
{"hadithnumber": "3599", "text": "خریم بن فاتک رضی اللہ عنہ کہتے ہیں  رسول اللہ صلی اللہ علیہ وسلم نے فجر پڑھائی، جب نماز سے فارغ ہوئے"}
{"hadithnumber": "3600", "text": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے خیانت کرنے والے مرد، خیا"}
{"hadithnumber": "3601", "text": "اس سند سے بھی عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  خ"}
{"hadithnumber": "3602", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  دیہاتی کی گ"}
{"hadithnumber": "3603", "text": "ابن ابی ملیکہ کہتے ہیں کہ  مجھ سے عقبہ بن حارث نے اور میرے ایک دوست نے انہیں کے واسطہ سے بیان کیا او"}
{"hadithnumber": "3604", "text": "اس سند سے بھی ابن ابی ملیکہ سے روایت ہے، وہ عبید بن ابی مریم سے روایت کرتے ہیں اور وہ عقبہ بن حارث س"}
{"hadithnumber": "3605", "text": "شعبی کہتے ہیں کہ  ایک مسلمان شخص مقام  دقوقاء  میں مرنے کے قریب ہو گیا اور اسے کوئی مسلمان نہیں مل س"}
{"hadithnumber": "3606", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  بنو سہم کا ایک شخص تمیم داری اور عدی بن بداء کے ساتھ نکل"}
{"hadithnumber": "3607", "text": "عمارہ بن خزیمہ کہتے ہیں: ان کے چچا نے ان سے بیان کیا اور وہ نبی اکرم صلی اللہ علیہ وسلم کے اصحاب میں"}
{"hadithnumber": "3608", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک حلف اور ایک گواہ پر"}
{"hadithnumber": "3609", "text": "اس سند سے بھی ابن عباس رضی اللہ عنہما سے اسی مفہوم کی حدیث مروی ہے  سلمہ نے اپنی حدیث میں یوں کہا کہ"}
{"hadithnumber": "3610", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں  نبی اکرم صلی اللہ علیہ وسلم نے گواہ کے ساتھ قسم پر فیصلہ کیا۔ ابوداؤ"}
{"hadithnumber": "3611", "text": "ابومصعب ہی کی سند سے ربیعہ سے اسی مفہوم کی حدیث مروی ہے۔ سلیمان کہتے ہیں  میں نے سہیل سے ملاقات کی ا"}
{"hadithnumber": "3612", "text": "زبیب عنبری کہتے ہیں کہ  اللہ کے نبی کریم صلی اللہ علیہ وسلم نے بنی عنبر کی طرف ایک لشکر بھیجا، تو لش"}
{"hadithnumber": "3613", "text": "ابوموسیٰ اشعری رضی اللہ عنہ کہتے ہیں کہ  دو شخصوں نے ایک اونٹ یا چوپائے کا رسول اللہ صلی اللہ علیہ و"}
{"hadithnumber": "3614", "text": "اس سند سے بھی سعید (ابن ابی عروبۃ) سے  اسی طریق سے اسی مفہوم کی حدیث مروی ہے۔"}
{"hadithnumber": "3615", "text": "اس سند سے بھی قتادہ سے اسی طریق سے اسی مفہوم کی حدیث مروی ہے اس میں ہے کہ  نبی اکرم صلی اللہ علیہ وس"}
{"hadithnumber": "3616", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  دو آدمی ایک سامان کے متعلق نبی اکرم صلی اللہ علیہ وسلم کے پاس جھگ"}
{"hadithnumber": "3617", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جب دونوں آدمی قسم کھان"}
{"hadithnumber": "3618", "text": "سعید بن ابی عروبہ سے ابن منہال کی سند سے اسی کے مثل مروی ہے  اس میں «في متاع» کے بجائے «في دابة» کے"}
{"hadithnumber": "3619", "text": "ابن ابی ملیکہ کہتے ہیں کہ  ابن عباس رضی اللہ عنہما نے میرے پاس لکھا کہ رسول اللہ صلی اللہ علیہ وسلم"}
{"hadithnumber": "3620", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے ایک شخص سے قسم کھلائی تو"}
{"hadithnumber": "3621", "text": "اشعث رضی اللہ عنہ کہتے ہیں کہ  میرے اور ایک یہودی کے درمیان کچھ  ( مشترک )  زمین تھی، یہودی نے میرے"}
{"hadithnumber": "3622", "text": "اشعث بن قیس رضی اللہ عنہ کہتے ہیں  ایک کندی اور ایک حضرمی یمن کی ایک زمین کے سلسلے میں جھگڑتے ہوئے ن"}
{"hadithnumber": "3623", "text": "وائل بن حجر حضرمی رضی اللہ عنہ کہتے ہیں  ایک حضرمی اور ایک کندی رسول اللہ صلی اللہ علیہ وسلم کے پاس"}
{"hadithnumber": "3624", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے یہودیوں سے فرمایا:  میں تمہیں اس ا"}
{"hadithnumber": "3625", "text": "اس سند سے بھی زہری سے یہی حدیث اسی طریق سے مروی ہے  اس میں ہے کہ مجھ سے مزینہ کے ایک آدمی نے جو علم"}
{"hadithnumber": "3626", "text": "عکرمہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے اس سے یعنی ابن صوریا ۱؎ سے فرمایا:  میں تمہیں اس ا"}
{"hadithnumber": "3627", "text": "عوف بن مالک رضی اللہ عنہ کہتے ہیں  نبی اکرم صلی اللہ علیہ وسلم نے دو شخصوں کے درمیان فیصلہ کیا، تو ج"}
{"hadithnumber": "3628", "text": "شرید رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مالدار آدمی کا ٹال مٹول کرنا"}
{"hadithnumber": "3629", "text": "حبیب تمیمی عنبری سے روایت ہے کہ  ان کے والد نے کہا: میں رسول اللہ صلی اللہ علیہ وسلم کے پاس اپنے ایک"}
{"hadithnumber": "3630", "text": "معاویہ بن حیدہ قشیری رضی اللہ عنہ کہتے ہیں  نبی اکرم صلی اللہ علیہ وسلم نے ایک الزام میں ایک شخص کو"}
{"hadithnumber": "3631", "text": "معاویہ بن حیدہ رضی اللہ عنہ روایت کرتے ہیں  ابن قدامہ کی روایت میں ہے کہ ان کے بھائی یا ان کے چچا او"}
{"hadithnumber": "3632", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  میں نے خیبر کی جانب نکلنے کا ارادہ کیا تو رسول اللہ صلی"}
{"hadithnumber": "3633", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جب تم کسی راستہ کے متع"}
{"hadithnumber": "3634", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں سے کوئی اپنے ب"}
{"hadithnumber": "3635", "text": "ابوصرمہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جس نے کسی کو تکلیف پہنچ"}
{"hadithnumber": "3636", "text": "سمرہ بن جندب رضی اللہ عنہ کہتے ہیں کہ  ایک انصاری کے باغ میں ان کے کھجور کے کچھ چھوٹے چھوٹے درخت تھے"}
{"hadithnumber": "3637", "text": "عبداللہ بن زبیر رضی اللہ عنہما کہتے ہیں کہ  ایک شخص نے زبیر رضی اللہ عنہ سے حرۃ کی نالیوں کے سلسلہ م"}
{"hadithnumber": "3638", "text": "ثعلبہ بن ابی مالک قرظی کہتے ہیں  انہوں نے اپنے بزرگوں سے بیان کرتے ہوئے سنا کہ قریش کے ایک آدمی نے ج"}
{"hadithnumber": "3639", "text": "عبداللہ بن عمر و رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مہزور کے نالے کے متعلق"}
{"hadithnumber": "3640", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  دو شخص ایک کھجور کے درخت کی حد کے سلسلے میں جھگڑا لے کر رسول"}
