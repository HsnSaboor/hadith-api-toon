2125,"أذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأدىتثأشضًهأتههۄأ﷽أىەأتشطتزألشوتۏتأودہەأوضًتڬأڬتأذڬوأتضأحتڬۏزأڬەأضتحہأزۏتأڲۏتأڬۄأودہەأتىزۏطۄأۄًىەأهڲتأڬۄأڬۄۏڽأتضأثتشەأوۏڽأودہأځشأمشإىأڬۏأڬًةۏأإۏحأىتصهأىۄأۄًأدتةەأ+أتًشأوۏشۏأتوحأتضأذڬوأڬًأځًشتأىۄأڬشأضڬەأ,أ"
2126,أذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأدىتثأشضًهأتههۄأ﷽أرتىۄأڬؼثۄأوۏڽأزترهأۄًةەأ؏أرتىۄأڬؼثۄأوۏڽأتضأًمحأډہأضحًىأحہەأ؏أىثۏأ﷽أۄشأضحًىأڬەأځتضأڬہڔەأۄًةەأ؏أهۏڬىأىوتصأىۄۏڽأځڔہۏأۗأ
2127,"أذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأدثأذعشحأؼخوتىأثىأوػؼًىأشعۏأتههۄأؼىۄأڬتأتىحمتهأۄًتأحًأتۏڬأرتحًىأڬۄىەأهڲۏأڬۄأؼخوتىأ$أحوۄۏڽأدىحأوثتشڬأۄًأ$أىثۏأ﷽أىەأتضأرتحًىأڬۏأغشلأؽظەأثہشۏأىڲتۄًڽأضەأزۏڬہتأتًشألشوتۏتأحوۄۏڽأڬۏضەأځحۄأډهتأآأتضأىەأؼشعأڬۏتأۏتأشضًهأتههۄأ$أۏۄأإځأڬەأطۄضًتشأتًشأضتحہۏأحہەأ؏أ+أتضأهةەأوشىەأڬەأثؼزأدىحأۄۏأوۏڽأدتةۏڽأڲەأ,أىثۏأ﷽أىەألشوتۏتأثرزتأ$أودہەأتههۄأڬتأځۏؽوثشأۄًىەأڬەأثتًدًزأوؼهًوأىۄۏڽأۄەأڬۄأوۏشەأضتحہأڬۏتأۄًأڲتأ؏أۏۄأضىأڬشأهًڲأذعشحأؼخوتىأثىأوػؼًىأشعۏأتههۄأؼىۄأڬەأثتشەأڋشأڲةەأهۏڬىأدثأىثۏأ﷽أڬۏأثڔۏأظتذثصتزۏأذعشحأصۏىثأشعۏأتههۄأؼىۄتأڬتأتىحمتهأۄًتأحًأىثۏأ﷽أىەألشوتۏتأۄوتشەأإڲەأدتىەأًتهەأثۄحشۏىأضتحہۏأؼخوتىأثىأوػؼًىأضەأدتأوهًأ+أدضأضەأتىأڬتأدىحۏأۄًىتأختثحأۄًأڲۏتأ,أتضأځشأؼًشحۏڽأشًىەأهڲۏڽأ؏أذعشحأؼوشأشعۏأتههۄأؼىۄأتىۄۏڽأڬًڔًڽأضەأوتشىەأهڲەأ؏أىثۏأ﷽أىەأتىأڬتأۄتحہأځڬڔأهۏتأتًشألشوتۏتأؼوشأ$أشڬأدتاأ؏أځہشأرًتحۏىأضەألشوتۏتأڬۄأحوۄۏڽأشًىەأڬۏأتدتصحأۄەأهۏڬىأطۏغتىأڬۏأډۏرأًأځڬتشأضەأتځىەأإځأڬًأثډتاأ؏أځہشألشوتۏتأڬۄأدثأحڬأۏۄأإىڬہأتًشأزهأڬتأوؼتوهۄأشۄەأحًأتههۄأڬۏأغشلأضەأۄًحتأۄەأتًشأثتؼخأشذوحأۄًحتأۄەأتًشأدثأۄتحہأتًشأصثتىأحڬأىًثحأځۄىډأدتةەأحًأۏۄأطۏغتىأڬۏأغشلأضەأۄًحتأۄەأۗأ"
2128,أذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأىثۏأ﷽أىەأتۄهأوزۏىۄأڬەأهةەأسًتهذهۏلۄأ؏أتۄهأطتوأڬەأهةەأدذلۄأ؏أتۄهأۏوىأڬەأهةەأۏهوهوأتًشأتۄهأىدزأڬەأهةەأمشىأڬًأوۏمتحأومششأڬشحەأۄًةەألشوتۏتأڬۄأۏۄأدڲۄۏڽأۏۄتڽأشۄىەأًتهًڽأڬەأهةەأثہۏأوۏمتحأۄۏڽأتًشأۏۄتڽأضەأڲصشىەأًتهًڽأڬەأهةەأثہۏأدًأذدأتًشأؼوشۄأڬتأتشتزۄأشڬہحەأۄًڽأتًشأدضأڬتأڲہشأوۏمتحأضەأځۏډہەأۄًأحًأًۄأدۄتڽأضەأتثحزتأڬشەأ؏أًۄۏڽأضەأتذشتوأثتىزہأهەأ؏أذحۏأڬۄأتۄهأوڬۄأڬتأتذشتوأًۄتڽأضەأۄًأڲتأدۄتڽأضەأًۄأتثحزتأڬشۏڽأڲەأۗأ
2129,أذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأدثأذعشحأوتؼصأثىأوتهڬأشعۏأتههۄأؼىۄأىثۏأ﷽أڬۏأرزوحأوۏڽأتؼحشتلأدشوأڬەأهةەأذتعشأۄًةەأحًأىثۏأ﷽أىەأتىأضەألشوتۏتأطتۏزأحوأىەأتضەأثًضۄأزۏتأۄًأڲتأآأۏتأحوأىەأتضەأظشلأډہًتأۄًأڲتأآأتىۄًڽأىەأڬۄتأڬۄأىۄۏڽأ؏أىثۏأ﷽أىەألشوتۏتأڬۏتأحوأىەأتضأضەأدوتؼأڬۏتأۄەأآأتىۄًڽأىەأڬۄتأدۏأۄتڽأ$أحثأىثۏأ﷽أڬەأذڬوأځشأتىۄۏڽأضىڲضتشأڬشأزۏتأڲۏتأۗأ
2130,أذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأتۏڬأوشحثۄألدشأڬۏأىوتصأڬەأهةەأتمتوحأۄًةۏأحًأتۏڬأإزوۏأزًأشڬؼحۏڽأځڔہىەأڬەأهةەأڬہڔتأۄًأڲۏتأ؏أىثۏأ﷽أىەأتضەأڬځڔەأضەأځڬڔأڬشأڬہۏىډتأتًشألشوتۏتأڬۏتأحوألدشأڬۏأډتشأشڬؼحۏڽأځڔہًأڲەأآأ
2131,"أذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأدثأۏۄأإۏحأىتصهأۄًةۏأڬۄأدًأهًڲأځتڬزتوىأؼًشحًڽأځشأحۄوحأهڲتةۏڽأتًشأتضأځشأډتشأڲًتۄأځۏطأىۄأڬشأضڬۏڽأحًأتىۄۏڽأتضۏأڬًڔەأوتشًأتًشأتىأڬۏأڲًتۄۏأڬثہۏأمثًهأىۄأڬشًأ؏أحًأذعشحأضؼزأثىأؼثتزۄأشعۏأتههۄأؼىۄأدًأتىظتشأڬەأضشزتشأحہەأڬۄىەأهڲەأڬۄأۏتأشضًهأتههۄأ$أڬۏتأۏۄأذڬوأإځأځشأتضۏأغشذأىتصهأۄًتأۄەأآأىثۏأ﷽أىەألشوتۏتأتەأڲشًۄأتىظتشأ$أضىحەأۄًأڬۄأحوۄتشەأضشزتشأڬۏتأڬۄۄأشۄەأۄۏڽأآأهًڲًڽأىەأؼشعأڬۏتأۏتأشضًهأتههۄأ$أتىأڬۏأثتحأڬتأثشتأىۄأوىتةۏەأڬۏًىڬۄأۏۄأثۄحأثتؽۏشحأإزوۏأۄۏڽأ؏أثرزتأتىۄًڽأىەأۄوۏطۄأظشلأڬىًتشۏأؼًشحأضەأۄۏأطتزۏأڬۏأۄەأتًشأدثأڬثہۏأتىۄًڽأىەأتځىۏأڬضۏأثۏًۏأڬًأغهتمأزۏأۄەأحًأڬضۏأزًضشەأإزوۏأڬًأتىأڬۏأتضأوغهمۄأثۏًۏأضەأثہۏأتىأڬۏأطزحأؽۏشحأڬۏأًدۄأضەأطتزۏأڬشىەأڬۏأدشتحأىۄۏڽأۄًةۏأۗأذعشحأضؼزأشعۏأتههۄأؼىۄأڬۄىەأهڲەأۏتأشضًهأتههۄأ$أودہەأتضأثتحأڬتأۏمۏىأۄەأڬۄأۏۄأذڬوأثشذمأۄەأتًشأتههۄأۄۏأڬۏأغشلأضەأإۏتأۄەأ؏أهۏڬىأودہەأتضأثتحأځشأحؼدثأۄًأشۄتأۄەأڬۄأتڲشأوۏڽأڬضۏأڬوۏىۏأؼًشحأڬًأتضأذتهأوۏڽأزۏڬہًڽأڬۄأتضەأڬضۏأإزوۏأىەأتځىۏأشتىًڽأڬەأزشوۏتىأزثًډأشڬہتأۄًأتًشأوۏڽأتضأځشأؽظۄأوۏڽأثہۏأىۄأإاڽأتًشأتضەأډہۏڔًڽأثہۏأىۄۏڽأ؏أځۄهەأدتأڬشأډتشأڲًتۄأهەأڬشأإاڽأ؏أثرزتأ$أوۏڽأحًأدثأحڬأڲًتۄأهەأڬشأإاڽأڲتأتضأًمحأحڬأًۄأتځىتأڬتوأځًشتأڬشأډڬتأۄًأڲتأۗأتثہۏأۏۄأثتحۏڽأۄًأۄۏأشۄۏأحہۏڽأڬۄأحہًڔۏأزۏشأثؼزأۄهتهأثىأتوۏۄأشعۏأتههۄأؼىۄأإأڲةەأ؏أۏۄأۄهتهأتىأحۏىأوۏڽأضەأتۏڬأۄۏڽأدًأؽصًۄأحثًڬأضەأځۏډہەأشۄأڲةەأحہەأتًشأثؼزأوۏڽأتىأڬۏأحًثۄأمثًهأۄًأڲةۏأحہۏأ؏أۏۄأؼطتؤأڬەأًمحأتځىۏأصوۏىأضەأًتځضأإةەأ؏أحًأتځىۏأثۏًۏأڬەأځتضأتۏڬأتدىثۏأإزوۏأڬًأزۏڬہتأ؏أتىۄًڽأىەأتىۄۏڽأتځىۏأإىڬہًڽأضەأزۏڬہتأتًشأتځىەأڬتىًڽأضەأتىأڬۏأثتحۏڽأضىۏڽأهۏڬىأحذوهأڬتأوػتۄشأڬۏتأ؏أظثذأۄًةۏأحًأىثۏأ﷽أڬۏأرزوحأوۏڽأذتعشأۄًأڬشأؼشعأڬۏتأۏتأشضًهأتههۄأ$أوۏڽأشتحأڬًأتځىۏأثۏًۏأڬەأځتضأإۏتأحًأتضأڬەأځتضأتۏڬأتدىثۏأإزوۏأڬًأځتۏتأ؏أوۏڽأىەأتىۄۏڽأتځىۏأإىڬہًڽأضەأزۏڬہتأتًشأتځىەأڬتىًڽأضەأضىتأۗأىثۏأ﷽أځشأۏۄأثتحأثڔۏأطتمأڲصشۏأتًشأتضأځشأإځأ﷽أىەأىتڲًتشۏأڬتأتػۄتشألشوتۏتأ؏أتىظتشأثہۏأتڬټہەأۄًأڲةەأتًشأڬۄىەأهڲەأڬۄأضؼزأثىأؼثتزۄأشعۏأتههۄأؼىۄأىەأدًأڬۄتأحہتأ؏أۄوأتضۏأوۏڽأوثحهتأۄًأڲةەأ؏أتثأىثۏأ﷽أۄهتهأثىأتوۏۄأڬًأضصتأزۏڽأڲەأتًشأوضهوتىًڽأوۏڽأتىأڬۏأڲًتۄۏأڬًأىتمتثهأتؼحثتشأمشتشأزەأزۏڽأڲەأ؏أهۏڬىأۄهتهأڬۄىەأهڲەأڬۄأثرزتأ$أودہەأتوۏزأۄەأڬۄأتههۄأوۏشەأهةەأتضأضەأىڬهىەأڬتأڬًةۏأشتضحۄأعشًشأثىتةەأڲتأ؏أځہشأۄهتهأڬۄىەأهڲەأڬۄأۏتأشضًهأتههۄأ$أودہەأوذضًضأۄًأشۄتأۄەأڬۄأوۏڽأىەأدًأوضةهۄأإځأڬۏأرزوحأوۏڽأځۏطأڬۏتأۄەأ؏أًۄأإځأځشأطتمأڲصشتأۄەأ؏أتههۄأدتىحتأۄەأڬۄأوۏڽأتځىۏأثتحأوۏڽأضډتأۄًڽأۗأىثۏأ﷽أثہۏأتىأځشأضصتأدتشۏأڬشىەأڬتأذڬوأزۏىەأًتهەأۄۏأحہەأڬۄأىثۏأ﷽أځشأًذۏأڬتأىصًهأطشًؼأۄًأڲۏتأتًشأدثأىثۏأ﷽أځشأًذۏأىتصهأۄًأشۄۏأۄًحۏأحًأظذتثۄأڬشتوأشعۏأتههۄأؼىۄوأىثۏأ﷽أڬەأشًةەأتىًشأڬتأشىڲأوحؽۏشأۄًىەأضەأتضەأځۄډتىأهۏحەأحہەأتًشأتځىەأإځأڬًأشًڬأهۏحەأحہەأ؏أحتإىڬۄأإځأ﷽أڬًأًذۏأضەألشتؽحأۄًأدتحۏأ؏أډىتىډۄأتضأوًمؼأځشأۏۄأإۏحأهؼتىأىتصهأۄًةۏأڬۄأدًأهًڲأتځىۏأثۏًۏًڽأځشأثزڬتشۏأڬتأتهصتوأهڲتةۏڽأتًشأتىأڬەأځتضأضًتةەأتىأڬۏأتځىۏأستحأڬەأڬًةۏأتًشأڲًتۄأىۄأۄًأحًأۗأدثأىثۏأ﷽أځشأضەأىصًهأًذۏأڬۏأڬۏلۏحأرحوأۄًةۏأحًألشوتۏتأۄهتهأ$أحوۄۏڽأرًطرثشۏأۄًأڬۄأتههۄأىەأحوۄتشەأهةەأڬطتزڲۏأتًشأىڬهىەأڬتأشتضحۄأځۏزتألشوتأزۏتأ؏أتىۄًڽأىەأؼشعأڬۏتأڬۄأودہەأتځىەأځشًشزڲتشأضەأۏۄۏأتوۏزأحہۏأ؏أىثۏأ﷽أىەألشوتۏتأتضأڬۏأثۏًۏأڬًأثهتاأ؏أډىتىډۄأهًڲأتضەأثهتأهتةەأ؏أدثأًۄأإأڲةۏأحًأىثۏأ﷽أىەأتىأزًىًڽأڬەأضتوىەأوسڬًشۄأإۏتحأڬۏأحهتًحألشوتةۏأتًشأتىۄۏڽأىظۏذحأڬشحەأۄًةەألشوتۏتأڬۄأإرشحأڬتأؼستثأزىۏتأڬۏأضصتأضەأصۏتزۄأضرحأۄەأۗأۄهتهأڬۄىەأهڲەأڬۄأۏتأشضًهأتههۄأ$أثرزتأوۏڽأتضأځشأتهصتوأهڲتىەأوۏڽأضډتأۄًڽأ؏أدثڬۄأتىأڬۏأثۏًۏأىەأحڬسۏثأڬۏأ؏أىثۏأ﷽أىەألشوتۏتأتىأزًىًڽأڬەأزشوۏتىأهؼتىأڬشتأزًأ+أدضأڬتأغشۏمۄأۏۄأۄەأڬۄأ,أۄهتهأضەأڬۄتأڲۏتأڬۄأإځأڲًتۄۏأزۏدةەأ؏أتىۄًڽأىەأډتشأوشحثۄأتههۄأڬۏأمضوأڬہتأڬشأۏۄأڲًتۄۏأزۏأڬۄأًۄأتځىەأزؼًۏأوۏڽأضډەأۄۏڽأ؏أدثأځتىډًۏڽأوشحثۄأڬۄىەأڬۏأثتشۏأإةۏأحًأتىأضەأڬۄتأڲۏتأڬۄأۄهتهأ$أتههۄأضەأڋشًأ؏أزىۏتأڬۏأضصتأإرشحأڬۏأضصتأضەأۄهڬۏأۄەأتًشأۏۄأځتىډًۏڽأوشحثۄأڬۏأمضوأحوأځشأضصتأڬًأختثحأڬشأضڬحۏأۄەأ؏أتىۄًڽأىەأڬۄتأڬۄأتههۄأىەأدضأغشذأودہەأڬًڔەأىۄۏڽأځڔىەأزۏةەأ؏أًۄأودہەأضصتأثہۏأىۄۏڽأزەأڲتأتًشأتىۄًڽأىەأځتىډًۏڽأوشحثۄأۏۄأمضوأڬہتأهۏأڬۄأتڲشأًۄأدہًټەأۄًڽأحًأتىأځشأتههۄأڬۏأهؼىحأۄًأۗأځہشأتىأڬۏأثۏًۏأضەأتضۏأغشذأډتشأوشحثۄأتههۄأڬۏأمضوأڬہتأڬشأتضأثتحأځشأڲًتۄۏأزۏىەأڬەأهةەأڬۄتأڲۏتأڬۄأتىأڬتأطًۄشأتځىەأتهصتوأوۏڽأدہًټتأۄەأ؏أدثأځتىډًۏڽأمضوأڬۏأثتشۏأإةۏأحًأتضأضەأڬۄتأڲۏتأڬۄأتههۄأضەأڋشأ؏أزىۏتأڬۏأضصتأإرشحأڬەأؼستثأڬەأومتثهەأوۏڽأثۄحأۄهڬۏأۄەأتًشأۏۄأځتىډًۏڽأوشحثۄأڬۏأمضوأحدہأځشأضصتأثہۏأختثحأڬشأضڬحۏأۄەأ؏أۏۄأضىأڬشأًۄأتۏڬأهوذەأڬەأهةەأۄډڬډتةۏأ؏أځہشأڬۄىەأهڲۏأًتههۄأ$أوۏڽأتځىۏأمًوأڬًأشضًتأىۄۏڽأڬشًڽأڲۏأتًشأځتىډًۏڽأوشحثۄأۏۄأمضوأڬہتأهۏأڬۄأتڲشأتضأڬتأطًۄشأضډتأۄًأحًأثۏًۏأځشأتههۄأڬتأؽعثأىتصهأۄًأ؏أتضأڬەأثؼزأىثۏأ﷽أىەأتىأزًىًڽأڬەأزشوۏتىأحلشۏمأڬشتأزۏأتًشأۏۄألۏظهۄألشوتأزۏتأڬۄأتضأؼًشحأڬۏأتًهتزأڬًأثتځأڬۏأغشلأوىضًثأىۄأڬۏتأدتةەأ؏أىۄأتضأؼًشحأڬًأتضأڬەأطًۄشأڬۏأغشلأوىضًثأڬۏتأدتةەأتًشأىۄأتضأڬۏأتًهتزأځشأڬًةۏأحۄوحأهڲتةۏأدتةەأ؏أدًأطرظأتضأځشأۏتأتضأڬۏأتًهتزأځشأڬًةۏأحۄوحأهڲتةەأڲتأ؏أتضەأضصتأزۏأدتةەأڲۏأ؏أىۏصأإځأ﷽أىەأۏۄألۏظهۄأثہۏألشوتۏتأڬۄأتضأؼًشحأڬۏأشۄتةطأثہۏأتضأڬەأطًۄشأڬەأسوەأىۄۏڽأۄەأتًشأىتىأىلمۄأثہۏأ؏أڬۏًىڬۄأتىأزًىًڽأڬەأزشوۏتىأغهتمأۏتأًلتحأڬەأثؽۏشأدزتةۏأۄًةۏأحہۏأۗأتًشألشوتۏتأڬۄأتڲشأتضأؼًشحأڬەأۏۄتڽأځۏزتأۄًىەأًتهتأثډۄأضشرأًضلۏزأشىڲأڬتأۄًأ؏أۄهڬەأضشۏىأتًشأځحهۏأځىڋهۏًڽأًتهتأۄًأحًأًۄأۄهتهأڬتأۄًأڲتأتًشأتڲشأڲىزوۏأشىڲأڬتأۄًأ؏أڲہىڲہشۏتهەأثتهًڽأًتهتأ؏أثہشۏأۄًةۏأځىڋهۏًڽأتًشأثہشەأۄًةەأضشۏىأًتهتأۄًأحًأۏۄأتضأطرظأڬتأۄًأڲتأدضأڬۏأغشلأتضأؼًشحأڬًأوحۄوأڬۏتأڲۏتأۄەأ؏أډىتىډۄأتضأؼًشحأڬەأۏۄتڽأدًأثډۄأځۏزتأۄًتأتضأڬتأشىڲأڲىزوۏأ؏أثتهأڲہىڲہشۏتهەأثہشۏأۄًةۏأځىڋهۏتڽأتًشأثہشەأۄًةەأضشۏىأحہەأ؏أىثۏأ﷽أڬًأدثأوؼهًوأۄًتأحًألشوتۏتأڬۄأتڲشأتضأمضوأڬتأځتضأهذتػأىۄأۄًحتأحًأوۏشتأتًشأتضأؼًشحأڬتأوؼتوهۄأۄۏأزًضشتأۄًحتأ؏أؼڬشوۄأڬۄحەأۄۏڽأڬۄأثؼزأوۏڽأثڔتأۄًأڬشأًۄأثډۄأوظشأڬتأڲًشىشأثىتأ؏أهۏڬىأتضەأتضأڬۏأوتڽأڬۏأغشلأۄۏأوىضًثأڬۏتأدتحتأحہتأ؏أثتځأڬۏأغشلأىۄۏڽأۗ"
2132,أذعشحأتثىأؼوشأتًشأذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄوتأضەأوشًۏأۄەأڬۄأدىتثأشضًهأتههۄأ﷽أىەأتشطتزألشوتۏتأدثڬۄأإځأ﷽أوىثشأځشأحطشۏلألشوتأحہەأ؏أهًڲأدوؼۄأډہًڔىەأضەأثتصأإأدتةۏڽأ؏أًشىۄأتههۄأحؼتهۏٳأتىأڬەأزهًڽأځشأوۄشأهڲتأزەأڲتأتًشأتىۄۏڽأؽتلهًڽأوۏڽأهڬہأزەأڲتأۗأ
2133,أذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأدىتثأشضًهأتههۄأ﷽أڬۏأرزوحأوۏڽأتۏڬأؼًشحأتځىتأثډۄأهەأڬشأذتعشأۄًةۏأتًشأڬۄىەأهڲۏأڬۄأۏتأشضًهأتههۄأ$أتضەأڬًةۏأحڬهۏلأۄەأ؏أڬہتىەأڬەأزًشتىأدثأتضەأًۄأحڬهۏلأۄًحۏأۄەأحًأۏۄأۄوتشتأضتشتأڬہتىتأرشتثأڬشأزۏحتأۄەأ؏أىثۏأ﷽أىەأتضأڬەأضۏىەأځشأۄتحہأځہۏشتأتًشأتضأڬەأهةەأزؼتألشوتةۏأ؏أتډتىڬأتضأثډەأڬًأمەأۄًةۏأتًشأتضأڬەأوىۄأضەأتۏڬأڬتهەأثهەأدۏضۏأڬًةۏأډۏصأىڬهۏأتًشأثہتڲأڲةۏأۗأ
