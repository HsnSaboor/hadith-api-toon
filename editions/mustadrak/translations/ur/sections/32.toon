5699,أوذوزأثىأؼثزتههۄأثىأىوۏشألشوتحەأۄۏڽأ=أظۄۏثأڬۏأڬىۏحأ““أتثًۏذۏۏأ‛‛أحہۏأۏۄأظۄۏثأثىأضىتىأىوشۏأۄۏڽأ؏أىوشأثىأمتضغأڬۏأتًهتزًڽأوۏڽأضەأۄۏڽأۗأۏۄأمۏزۏأۄًأڬشأوهڬأشًوأوۏڽأډهەأڲةەأحہەأ؏أتضۏأهةەأتىأڬًأظۄۏثأشًوۏأثہۏأڬۄتأدتحتأۄەأ؏أتىأڬۏأؼوشأ:3أثشضأحہۏأ؏أإځأزتڔہۏأطشۏلأڬًأوۄىزۏأهڲتۏتأڬشحەأحہەأ؏أإځأوتۄأطًتهأتهوڬشوأوۏڽأضىأ6;أۄدشۏأوۏڽأوزۏىۄأطشۏلأوۏڽألًحأۄًةەأتًشأتىأڬًأثمۏؼأوثتشڬأوۏڽأزلىأڬۏتأڲۏتأۗأ
5700,"%أؼڬشوۄأڬۄحەأۄۏڽأ=أدثأذعشحأظۄۏثأشعۏأتههۄأؼىۄأۄدشحأڬشأڬەأوڬۄأضەأىڬهەأ؏أحًأتۄهأوڬۄأىەأتىأڬتأځۏډہتأڬۏتأ؏أتىۄًڽأىەأتځىتأحشڬطأرتهۏأڬشأزۏتأ؏أتضأوۏڽأضەأډتهۏضأحۏشأىڬتهەأۗأځہشألشوتۏتأ=أحوأودہأحڬأځۄىډىەأڬۏأڬًططأڬشًأڲەأحًأوۏڽأحوأوۏڽأضەأۄشأتۏڬأڬەأضۏىەأوۏڽأتۏڬأتۏڬأحۏشأځۏًضحأڬشأزًڽأڲتأ؏أځہشأتضأڬەأثؼزأوۏڽأطوطۏشصىۏأڬشًڽأڲتأ؏أحثأحوأودہەأدتىًأڲەأڬۄأوۏڽأ+أڬۏضتأثۄتزشأتًشأزهۏشأ,أوشزأۄًڽأۗأوۏڽأىەأوڬۄأوۏڽأتځىەأځۏډہەأزًأهًىڋۏتڽأډہًڔۏأۄۏڽأ؏أًۄأحوۄتشەأهةەأۄۏڽأۗ أٰٰأذعشحأتىضأشعۏأتههۄأؼىۄأضەأثہۏأوسڬًشۄأذزۏخأدۏضۏأذزۏخأوشًۏأۄەأتًشأتضأوۏڽأۏۄأثہۏأۄەأڬۄأىثۏأتڬشوأ﷽أځشأۏۄأإۏحأوثتشڬۄأىتصهأۄًةۏ"
أ®ًّوّىٓأتهىّٔتضٓأوّىٕأٍّطٕشٍٓأىّلٕضّيْأتثٕحٓؽّتؤّأوّشٕعّتجٓأتههّٔيٓأ+أتهثمشۆأ=أ53:أ,"¾ أدثأىثۏأتڬشوأ﷽أىەأتىأڬًأزۏڬہتأحًألشوتۏتأ=أتثًۏذۏۏأڬًأثۏؼأىەأىلؼأزۏتأۄەأځہشأۏۄأإۏحأځڔہۏأۗ أٰٰأۏۄأذزۏخأتوتوأوضهوأشذوۆأتههۄأؼهۏۄأڬەأوؼۏتشأڬەأوغتثمأظذۏذأۄەأهۏڬىأزًىًڽأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗ%أ"""
