{"metadata":{"name":"Sunan an Nasai","section":{"51":"The Book of Drinks"},"section_detail":{"51":{"hadithnumber_first":5540,"hadithnumber_last":5758,"arabicnumber_first":5540,"arabicnumber_last":5758}}},"hadiths":[{"hadithnumber":5756,"arabicnumber":5756,"text":"Rapporté par 'Abidah : Les gens ont inventé des boissons et je ne sais pas ce que c'est. Je n'ai rien bu depuis 20 ans à part de l'eau, du lait et du miel","grades":[{"name":"Abu Ghuddah","grade":"Sahih Isnaad Maqtu"},{"name":"Al-Albani","grade":"Sahih Isnaad Maqtu"},{"name":"Zubair Ali Zai","grade":"Isnaad Sahih"}],"reference":{"book":51,"hadith":218}}]}