{"metadata":{"name":"Sunan Abu Dawud","section":{"29":"Medicine (Kitab Al-Tibb)"},"section_detail":{"29":{"hadithnumber_first":3855,"hadithnumber_last":3903,"arabicnumber_first":3855,"arabicnumber_last":3903}}},"hadiths":[{"hadithnumber":3868,"arabicnumber":3868,"text":"Rapporté par Jabir ibn Abdullah رضي الله عنه : On interrogea le Messager d’Allah ﷺ au sujet d’un charme pour celui qui est possédé (nashrah). Il répondit : « Cela fait partie des œuvres du diable. »","grades":[{"name":"Al-Albani","grade":"Sahih"},{"name":"Muhammad Muhyi Al-Din Abdul Hamid","grade":"Sahih"},{"name":"Shuaib Al Arnaut","grade":"Sahih"},{"name":"Zubair Ali Zai","grade":"Isnaad Hasan"}],"reference":{"book":29,"hadith":14}}]}