{"hadithnumber": "1841", "text": "حضرت ابوسعید خدری رضی اللہ عنہ سے روایت ہے کہ بلاشبہ انصار میں سے کچھ لوگوں نے رسول اللہ ﷺ سے سوال ک"}
{"hadithnumber": "1842", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ نے فرمایا : اس حال میں کہ وہ من"}
{"hadithnumber": "1843", "text": "عطاء بن یسار رحمہ اللہ سے روایت ہے کہ یقیناً رسول اللہ ﷺ نے حضرت عمر بن خطاب رضی اللہ عنہ کی طرف ان"}
{"hadithnumber": "1844", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا :’’ قسم اس ذات کی جس کے ہاتھ میں میر"}
{"hadithnumber": "1845", "text": "بنو اسد کے ایک شخص سے روایت ہے ، کہتے ہیں : میں اور میرے گھر والوں نے ( مسجد نبوی ﷺ کے بائیں جانب مد"}
{"hadithnumber": "1846", "text": "امام مالک رحمہ اللہ ، علاء بن عبدالرحمن رحمہ اللہ سے روایت کرتے ہیں ، انھوں نے ان کو یہ فرماتے ہوئے"}
{"hadithnumber": "1847", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ بلاشبہ رسول اللہ ﷺ نے فرمایا :’’ آل محمد ( ﷺ ) کے لیے صدقہ حل"}
{"hadithnumber": "1848", "text": "عبداللہ بن ابی بکر رحمہ اللہ اپنے والد ( ابوبکر بن محمد بن عمرو بن حزم رحمہ اللہ ) سے روایت کرتے ہیں"}
{"hadithnumber": "1849", "text": "زید بن اسلم رحمہ اللہ اپنے والد ( اسلم رحمہ اللہ مولیٰ عمر رضی اللہ عنہ ) سے روایت کرتے ہیں ، انھوں"}
{"hadithnumber": "1850", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ بیشک لقمان حکیم رحمہ اللہ نے اپنے بیٹے کو وصیت فرمائی ، چنانچ"}
{"hadithnumber": "1851", "text": "زید بن اسلم رحمہ اللہ اپنے والد ( اسلم رحمہ اللہ ) سے روایت کرتے ہیں کہ بیشک حضرت عمر بن خطاب رضی ال"}
{"hadithnumber": "1852", "text": "محمد بن جُبیر بن مُطعم رضی اللہ عنہ سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ نے فرمایا :’’ میرے پانچ نام ہی"}
