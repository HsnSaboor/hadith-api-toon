{"hadithnumber": "3984", "text": "ابی بن کعب رضی اللہ عنہ کہتے ہیں  رسول اللہ صلی اللہ علیہ وسلم جب دعا فرماتے تو پہلے اپنی ذات سے شرو"}
{"hadithnumber": "3985", "text": "ابی بن کعب رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے «قد بلغت من لدني»  ( نون کی ت"}
{"hadithnumber": "3986", "text": "مصدع ابویحییٰ کہتے ہیں کہ  میں نے ابن عباس رضی اللہ عنہما سے سنا وہ کہہ رہے تھے مجھے ابی ابن کعب رضی"}
{"hadithnumber": "3987", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  علیین والوں میں سے ا"}
{"hadithnumber": "3988", "text": "فروہ بن مسیک غطیفی رضی اللہ عنہ کہتے ہیں کہ  میں نبی اکرم صلی اللہ علیہ وسلم کے پاس آیا پھر انہوں نے"}
{"hadithnumber": "3989", "text": "اس سند سے ابوہریرہ رضی اللہ عنہ نے  نبی اکرم صلی اللہ علیہ وسلم سے وحی کی حدیث ۱؎ روایت کی اس کے بعد"}
{"hadithnumber": "3990", "text": "ام المؤمنین ام سلمہ رضی اللہ عنہا کہتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کی قرآت «بلى قد جاءتك آيا"}
{"hadithnumber": "3991", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم کو «فروح وريحان»  تو"}
{"hadithnumber": "3992", "text": "یعلیٰ بن امیہ۔ منیہ۔ رضی اللہ عنہ کہتے ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم کو منبر پر «ونادوا"}
{"hadithnumber": "3993", "text": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں  رسول اللہ صلی اللہ علیہ وسلم نے مجھے «إني أنا الرزاق ذو القو"}
{"hadithnumber": "3994", "text": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم «فهل من مدكر»  تو کیا ہے کوئی"}
{"hadithnumber": "3995", "text": "جابر رضی اللہ عنہ کہتے ہیں  میں نے نبی اکرم صلی اللہ علیہ وسلم کو «يحسب أن ماله أخلده» ۱؎ پڑھتے دیکھ"}
{"hadithnumber": "3996", "text": "ابوقلابہ ایک ایسے شخص سے جس کو رسول اللہ صلی اللہ علیہ وسلم نے پڑھایا ہے  روایت کرتے ہیں  ( کہ یہ آی"}
{"hadithnumber": "3997", "text": "ابوقلابہ کہتے ہیں: مجھے ایک ایسے شخص نے خبر دی ہے  جسے نبی اکرم صلی اللہ علیہ وسلم نے پڑھایا ہے یا ج"}
{"hadithnumber": "3998", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں  رسول اللہ صلی اللہ علیہ وسلم نے ایک حدیث بیان فرمائی جس میں جبر"}
{"hadithnumber": "3999", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں  رسول اللہ صلی اللہ علیہ وسلم نے اس فرشتہ کا ذکر کیا جو صور لیے"}
{"hadithnumber": "4000", "text": "عبدالرزاق کہتے ہیں ہمیں معمر نے زہری کے واسطہ سے خبر دی ہے اور معمر نے کبھی کبھی زہری کے بجائے ابن م"}
{"hadithnumber": "4001", "text": "ام المؤمنین ام سلمہ رضی اللہ عنہا سے روایت ہے کہ  انہوں نے ذکر کیا یا اس کے علاوہ راوی نے کوئی اور ک"}
{"hadithnumber": "4002", "text": "ابوذر رضی اللہ عنہ کہتے ہیں کہ  میں رسول اللہ صلی اللہ علیہ وسلم کا ردیف تھا آپ ایک گدھے پر سوار تھے"}
{"hadithnumber": "4003", "text": "واثلہ بن الاسقع بکری رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم ان کے پاس مہاجرین کے صفے"}
{"hadithnumber": "4004", "text": "عبداللہ بن مسعود رضی اللہ عنہ سے روایت ہے کہ  انہوں نے «هَيْتَ لَكَ» ۱؎ پڑھا تو ابووائل شقیق بن سلمہ"}
{"hadithnumber": "4005", "text": "ابووائل شقیق بن سلمہ کہتے ہیں  عبداللہ بن مسعود رضی اللہ عنہ سے کہا گیا کہ کچھ لوگ اس آیت کو «وَقَال"}
{"hadithnumber": "4006", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ عزوجل نے بنی ا"}
{"hadithnumber": "4007", "text": "اس سند سے بھی  ہشام بن سعد سے اسی کے مثل مروی ہے"}
{"hadithnumber": "4008", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم پر وحی اتری تو آپ نے ہمیں"}
