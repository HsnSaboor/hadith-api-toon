metadata:

hadiths[22]{hadithnumber,arabic,bengali,english,french,indonesian,russian,urdu,grades,reference,international_number,narrator_chain,chapter_intro}:
{"hadithnumber": "2664", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ مِهْرَانَ الرَّازِيُّ، حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِيلَ، عَنْ مُوسَى بْنِ عُقْبَةَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، رضى الله عنهما أَنَّ النَّبِيَّ صلى الله عليه وسلم كَانَ يَعْتَكِفُ فِي الْعَشْرِ الأَوَاخِرِ مِنْ رَمَضَانَ ‏.‏", "bengali": "", "english": "Ibn 'Umar (Allah be pleased with both of them) reported that the Messenger of Allah (ﷺ) used to observe i'tikaf in the last ten days of Ramadan.", "french": "", "indonesian": "", "russian": "", "urdu": "ابو بکر بن ابی شیبہ ، وکیع بن جراح ، حاجب ابن عمر ، حضرت حکم بن اعرج سے روایت ہے فرماتے ہیں کہ میں ح", "grades": "", "reference": "", "international_number": "2664", "narrator_chain": "", "chapter_intro": "The Book of I'tikaf"}
{"hadithnumber": "2665", "arabic": "وَحَدَّثَنِي أَبُو الطَّاهِرِ، أَخْبَرَنَا ابْنُ وَهْبٍ، أَخْبَرَنِي يُونُسُ بْنُ يَزِيدَ، أَنَّ نَافِعًا، حَدَّثَهُ عَنْ عَبْدِ اللَّهِ بْنِ عُمَرَ، - رضى الله عنهما - أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم كَانَ يَعْتَكِفُ الْعَشْرَ الأَوَاخِرَ مِنْ رَمَضَانَ ‏.‏ قَالَ نَافِعٌ وَقَدْ أَرَانِي عَبْدُ اللَّهِ - رضى الله عنه - الْمَكَانَ الَّذِي كَانَ يَعْتَكِفُ فِيهِ رَسُولُ اللَّهِ صلى الله عليه وسلم مِنَ الْمَسْجِدِ ‏.‏", "bengali": "", "english": "Abdullah (Allah be pleased with him) showed me the place in the mosque where the Messenger of Allah (ﷺ) used to observe i'tikaf.", "french": "", "indonesian": "", "russian": "", "urdu": "محمد بن حاتم ، یحییٰ بن سعید ، معاویہ بن عمرو ، حضرت حکم بن اعرج کہتے ہیں کہ میں نے حضرت ابن عباس  ر", "grades": "", "reference": "", "international_number": "2665", "narrator_chain": "Abdullah b. Umar (Allah be pleased with both of them) reported that the Messenger of Allah (ﷺ) used to observe i'tikaf in the last ten days of Ramadan. Nafi' said:", "chapter_intro": "The Book of I'tikaf"}
{"hadithnumber": "2666", "arabic": "وَحَدَّثَنَا سَهْلُ بْنُ عُثْمَانَ، حَدَّثَنَا عُقْبَةُ بْنُ خَالِدٍ السَّكُونِيُّ، عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، - رضى الله عنها - قَالَتْ كَانَ رَسُولُ اللَّهِ صلى الله عليه وسلم يَعْتَكِفُ الْعَشْرَ الأَوَاخِرَ مِنْ رَمَضَانَ ‏.‏", "bengali": "", "english": "'A'isha (Allah be pleased with her) reported that the Messenger of Allah (ﷺ) used to observe i'tikaf in the last ten days of Ramadan.", "french": "", "indonesian": "", "russian": "", "urdu": "حسن بن علی حلوانی ، ابن ابی مریم ، یحییٰ بن ایوب ، اسماعیل بن امیہ ، حضرت ابن عباس  رضی اللہ تعالیٰ", "grades": "", "reference": "", "international_number": "2666", "narrator_chain": "", "chapter_intro": "The Book of I'tikaf"}
{"hadithnumber": "2667", "arabic": "حَدَّثَنَا يَحْيَى بْنُ يَحْيَى، أَخْبَرَنَا أَبُو مُعَاوِيَةَ، ح وَحَدَّثَنَا سَهْلُ بْنُ عُثْمَانَ، أَخْبَرَنَا حَفْصُ بْنُ غِيَاثٍ، جَمِيعًا عَنْ هِشَامٍ، ح وَحَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَأَبُو كُرَيْبٍ - وَاللَّفْظُ لَهُمَا - قَالاَ حَدَّثَنَا ابْنُ نُمَيْرٍ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، - رضى الله عنها - قَالَتْ كَانَ رَسُولُ اللَّهِ صلى الله عليه وسلم يَعْتَكِفُ الْعَشْرَ الأَوَاخِرَ مِنْ رَمَضَانَ ‏.‏", "bengali": "", "english": "This hadith has been narrated by 'A'isha (Allah be pleased with her) through another chain of transmitters.", "french": "", "indonesian": "", "russian": "", "urdu": "ابو بکر بن ابی شیبہ ، ابو کریب ، وکیع ، ابن ابی ذئب ، قاسم بن عبداللہ ، عبداللہ بن عمیر ، حضرت ابن ع", "grades": "", "reference": "", "international_number": "2667", "narrator_chain": "", "chapter_intro": "The Book of I'tikaf"}
{"hadithnumber": "2668", "arabic": "وَحَدَّثَنَا قُتَيْبَةُ بْنُ سَعِيدٍ، حَدَّثَنَا لَيْثٌ، عَنْ عُقَيْلٍ، عَنِ الزُّهْرِيِّ، عَنْ عُرْوَةَ، عَنْ عَائِشَةَ، - رضى الله عنها - أَنَّ النَّبِيَّ صلى الله عليه وسلم كَانَ يَعْتَكِفُ الْعَشْرَ الأَوَاخِرَ مِنْ رَمَضَانَ حَتَّى تَوَفَّاهُ اللَّهُ عَزَّ وَجَلَّ ثُمَّ اعْتَكَفَ أَزْوَاجُهُ مِنْ بَعْدِهِ ‏.‏", "bengali": "", "english": "'A'isha (Allah be pleased with her) reported that the Messenger of Allah (may peace he upon him) used to observe i'tikif in the last ten days of Ramadan till Allah called him back (to his heavenly home). Then his wives observed i'tikaf after him.", "french": "", "indonesian": "", "russian": "", "urdu": "قتیبہ بن سعید ، حاتم یعنی ابن اسماعیل ، یزید بن ابی عبید ، حضرت سلمہ بن اکوع  رضی اللہ تعالیٰ عنہ  س", "grades": "", "reference": "", "international_number": "2668", "narrator_chain": "", "chapter_intro": "The Book of I'tikaf"}
{"hadithnumber": "2669", "arabic": "حَدَّثَنَا يَحْيَى بْنُ يَحْيَى، أَخْبَرَنَا أَبُو مُعَاوِيَةَ، عَنْ يَحْيَى بْنِ سَعِيدٍ، عَنْ عَمْرَةَ، عَنْ عَائِشَةَ، - رضى الله عنها - قَالَتْ كَانَ رَسُولُ اللَّهِ صلى الله عليه وسلم إِذَا أَرَادَ أَنْ يَعْتَكِفَ صَلَّى الْفَجْرَ ثُمَّ دَخَلَ مُعْتَكَفَهُ وَإِنَّهُ أَمَرَ بِخِبَائِهِ فَضُرِبَ أَرَادَ الاِعْتِكَافَ فِي الْعَشْرِ الأَوَاخِرِ مِنْ رَمَضَانَ فَأَمَرَتْ زَيْنَبُ بِخِبَائِهَا فَضُرِبَ وَأَمَرَ غَيْرُهَا مِنْ أَزْوَاجِ النَّبِيِّ صلى الله عليه وسلم بِخِبَائِهِ فَضُرِبَ فَلَمَّا صَلَّى رَسُولُ اللَّهِ صلى الله عليه وسلم الْفَجْرَ نَظَرَ فَإِذَا الأَخْبِيَةُ فَقَالَ ‏ ‏ آلْبِرَّ تُرِدْنَ ‏\"\"‏ ‏.‏ فَأَمَرَ بِخِبَائِهِ فَقُوِّضَ وَتَرَكَ الاِعْتِكَافَ فِي شَهْرِ رَمَضَانَ حَتَّى اعْتَكَفَ فِي الْعَشْرِ الأَوَّلِ مِنْ شَوَّالٍ ‏.‏\"", "bengali": "", "english": "What is this virtue that these (ladies) have decided to acquire? He commanded his tent to be struck and abandoned i'tikaf in the month of Ramadan and postponed it to the first ten days of Shawwal.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "'A'isha (Allah be pleased with her) reported that when the Messenger of Allah (ﷺ) decided to observe i'tikaf, he prayed in the morning and then went to the place of his i'tikaf, and he commanded that a tent should be pitched for him, and it was pitched. He (once) decided to observe i'tikaf in the last ten days of Ramadan. Zainab (the wife of the Holy Prophet) commanded that a tent should be pitched for her. It was pitched accordingly. And some other wives of Allah's Apostle (ﷺ) commanded that tents should be pitched for them too. And they were pitched. When the Messenger of Allah (may peace he upon him) offered the morning prayer, he looked and found (so many) tents. Thereupon he said:", "chapter_intro": "The Book of I'tikaf"}
{"hadithnumber": "2670", "arabic": "وَحَدَّثَنَاهُ ابْنُ أَبِي عُمَرَ، حَدَّثَنَا سُفْيَانُ، ح وَحَدَّثَنِي عَمْرُو بْنُ سَوَّادٍ، أَخْبَرَنَا ابْنُ، وَهْبٍ أَخْبَرَنَا عَمْرُو بْنُ الْحَارِثِ، ح وَحَدَّثَنِي مُحَمَّدُ بْنُ رَافِعٍ، حَدَّثَنَا أَبُو أَحْمَدَ، حَدَّثَنَا سُفْيَانُ، ح وَحَدَّثَنِي سَلَمَةُ بْنُ شَبِيبٍ، حَدَّثَنَا أَبُو الْمُغِيرَةِ، حَدَّثَنَا الأَوْزَاعِيُّ، ح وَحَدَّثَنِي زُهَيْرُ بْنُ حَرْبٍ، حَدَّثَنَا يَعْقُوبُ بْنُ إِبْرَاهِيمَ بْنِ سَعْدٍ، حَدَّثَنَا أَبِي، عَنِ ابْنِ إِسْحَاقَ، كُلُّ هَؤُلاَءِ عَنْ يَحْيَى بْنِ، سَعِيدٍ عَنْ عَمْرَةَ، عَنْ عَائِشَةَ، - رضى الله عنها - عَنِ النَّبِيِّ صلى الله عليه وسلم ‏.‏ بِمَعْنَى حَدِيثِ أَبِي مُعَاوِيَةَ ‏.‏ وَفِي حَدِيثِ ابْنِ عُيَيْنَةَ وَعَمْرِو بْنِ الْحَارِثِ وَابْنِ إِسْحَاقَ ذِكْرُ عَائِشَةَ وَحَفْصَةَ وَزَيْنَبَ - رضى الله عنهن - أَنَّهُنَّ ضَرَبْنَ الأَخْبِيَةَ لِلاِعْتِكَافِ ‏.‏", "bengali": "", "english": "This hadith has been reported through another chain of transmitters, and there it is mentioned that. 'A'isha, Hafsa and Zainab (Allah be pleased with them) pitched the tents for i'tikaf.", "french": "", "indonesian": "", "russian": "", "urdu": "یحییٰ بن یحییٰ ، ابو معشر ، عطار ، حضرت خالد بن ذکوان کہتے ہیں کہ میں نے ربیع بنت معوذ  رضی اللہ تعا", "grades": "", "reference": "", "international_number": "2670", "narrator_chain": "", "chapter_intro": "The Book of I'tikaf"}
{"hadithnumber": "2671", "arabic": "حَدَّثَنَا إِسْحَاقُ بْنُ إِبْرَاهِيمَ الْحَنْظَلِيُّ، وَابْنُ أَبِي عُمَرَ، جَمِيعًا عَنِ ابْنِ عُيَيْنَةَ، - قَالَ إِسْحَاقُ أَخْبَرَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، - عَنْ أَبِي يَعْفُورٍ، عَنْ مُسْلِمِ بْنِ صُبَيْحٍ، عَنْ مَسْرُوقٍ، عَنْ عَائِشَةَ، - رضى الله عنها - قَالَتْ كَانَ رَسُولُ اللَّهِ صلى الله عليه وسلم إِذَا دَخَلَ الْعَشْرُ أَحْيَا اللَّيْلَ وَأَيْقَظَ أَهْلَهُ وَجَدَّ وَشَدَّ الْمِئْزَرَ ‏.‏", "bengali": "", "english": "'A'isha (Allah be pleased with her) reported that when the last ten nights began Allah's Messenger (ﷺ) kept awake at night (for prayer and devotion), wakened his family, and prepared himself to observe prayer (with more vigour).", "french": "", "indonesian": "", "russian": "", "urdu": "یحییٰ بن یحییٰ  ، مالک ابن شہاب ، حضرت ابو عبید مولی بن ازہر سے روایت ہے انہوں نے کہاکہ میں عید کے د", "grades": "", "reference": "", "international_number": "2671", "narrator_chain": "", "chapter_intro": "The Book of I'tikaf"}
{"hadithnumber": "2672", "arabic": "حَدَّثَنَا قُتَيْبَةُ بْنُ سَعِيدٍ، وَأَبُو كَامِلٍ الْجَحْدَرِيُّ كِلاَهُمَا عَنْ عَبْدِ الْوَاحِدِ بْنِ زِيَادٍ، - قَالَ قُتَيْبَةُ حَدَّثَنَا عَبْدُ الْوَاحِدِ، - عَنِ الْحَسَنِ بْنِ عُبَيْدِ اللَّهِ، قَالَ سَمِعْتُ إِبْرَاهِيمَ، يَقُولُ سَمِعْتُ الأَسْوَدَ بْنَ يَزِيدَ، يَقُولُ قَالَتْ عَائِشَةُ رضى الله عنها كَانَ رَسُولُ اللَّهِ صلى الله عليه وسلم يَجْتَهِدُ فِي الْعَشْرِ الأَوَاخِرِ مَا لاَ يَجْتَهِدُ فِي غَيْرِهِ ‏.‏", "bengali": "", "english": "'A'isha (Allah be pleased with her) reported that Allah's Messenger (ﷺ) used to exert himself in devotion during the last ten nights to a greater extent than at any other time.", "french": "", "indonesian": "", "russian": "", "urdu": "یحییٰ بن یحییٰ ، مالک ، محمد بن یحییٰ ابن حبان ، اعرج ، حضرت ابو ہریرۃ  رضی اللہ تعالیٰ عنہ  سے روای", "grades": "", "reference": "", "international_number": "2672", "narrator_chain": "", "chapter_intro": "The Book of I'tikaf"}
{"hadithnumber": "2673", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَأَبُو كُرَيْبٍ وَإِسْحَاقُ قَالَ إِسْحَاقُ أَخْبَرَنَا وَقَالَ، الآخَرَانِ حَدَّثَنَا أَبُو مُعَاوِيَةَ، عَنِ الأَعْمَشِ، عَنْ إِبْرَاهِيمَ، عَنِ الأَسْوَدِ، عَنْ عَائِشَةَ، - رضى الله عنها - قَالَتْ مَا رَأَيْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم صَائِمًا فِي الْعَشْرِ قَطُّ ‏.‏", "bengali": "", "english": "I never saw the Messenger of Allah (ﷺ) fasting in the ten days of Dhu'I-Hijja.", "french": "", "indonesian": "", "russian": "", "urdu": "قتیبہ بن سعید ، جریر ، عبدالملک ، ابن عمیر ، قزعہ ، حضرت ابو سعید خدری  رضی اللہ تعالیٰ عنہ  سے روای", "grades": "", "reference": "", "international_number": "2673", "narrator_chain": "'A'isha (Allah be pleased with her) reported:", "chapter_intro": "The Book of I'tikaf"}
{"hadithnumber": "2674", "arabic": "وَحَدَّثَنِي أَبُو بَكْرِ بْنُ نَافِعٍ الْعَبْدِيُّ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ، حَدَّثَنَا سُفْيَانُ، عَنِ الأَعْمَشِ، عَنْ إِبْرَاهِيمَ، عَنِ الأَسْوَدِ، عَنْ عَائِشَةَ، - رضى الله عنها - أَنَّ النَّبِيَّ صلى الله عليه وسلم لَمْ يَصُمِ الْعَشْرَ ‏.‏", "bengali": "", "english": "The Apostle of Allah (ﷺ) did not observe fast in the ten days of Dhul-Hijja.", "french": "", "indonesian": "", "russian": "", "urdu": "ابو کامل جحدری ، عبدالعزیز بن مختار  ، عمرو بن یحییٰ ، حضرت ابو سعید خدری  رضی اللہ تعالیٰ عنہ  سے ر", "grades": "", "reference": "", "international_number": "2674", "narrator_chain": "'A'isha (Allah be pleased with her) reported:", "chapter_intro": "The Book of I'tikaf"}
{"hadithnumber": "2780", "arabic": "حَدَّثَنَا  مُحَمَّدُ بْنُ مِهْرَانَ الرَّازِيُّ ، حَدَّثَنَا  حَاتِمُ بْنُ إِسْمَاعِيل ، عَنْ  مُوس", "bengali": "", "english": "Ibn 'Umar (Allah be pleased with both of them) reported that the Messenger of Allah (ﷺ) used to observe i'tikaf in the last ten days of Ramadan", "french": "", "indonesian": "", "russian": "", "urdu": "موسیٰ بن عقبہ نے نافع سے اور انھوں نے حضرت ابن عمر  رضی اللہ تعالیٰ عنہ  سے روایت کی کہ نبی اکرم  صل", "grades": "", "reference": "Book 14, Hadith 1", "international_number": "2780", "narrator_chain": "", "chapter_intro": "The Book of I'tikaf"}
{"hadithnumber": "2781", "arabic": "وحَدَّثَنِي  أَبُو الطَّاهِرِ ، أَخْبَرَنَا  ابْنُ وَهْبٍ ، أَخْبَرَنِي  يُونُسُ بْنُ يَزِيدَ ، أَنّ", "bengali": "", "english": "Abdullah b. Umar (Allah be pleased with both of them) reported that the Messenger of Allah (ﷺ) used to observe i'tikaf in the last ten days of Ramadan. Nafi' said:Abdullah (Allah be pleased with him) showed me the place in the mosque where the Messenger of Allah (ﷺ) used to observe i'tikaf", "french": "", "indonesian": "", "russian": "", "urdu": "یونس بن یزید نے مجھے خبر دی کہ نافع نے انھیں حضرت عبداللہ بن عمر رضی اللہ تعالیٰ عنہ  کے واسطے سے حد", "grades": "", "reference": "Book 14, Hadith 2", "international_number": "2781", "narrator_chain": "", "chapter_intro": "The Book of I'tikaf"}
{"hadithnumber": "2782", "arabic": "وحَدَّثَنَا  سَهْلُ بْنُ عُثْمَانَ ، حَدَّثَنَا  عُقْبَةُ بْنُ خَالِدٍ السَّكُونِيُّ ، عَنْ  عُبَيْد", "bengali": "", "english": "A'isha (Allah be pleased with her) reported that the Messenger of Allah (ﷺ) used to observe i'tikaf in the last ten days of Ramadan", "french": "", "indonesian": "", "russian": "", "urdu": "عبدالرحمان بن قاسم نے اپنے والد سے ، انھوں نے حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے روایت کی ، انھوں", "grades": "", "reference": "Book 14, Hadith 3", "international_number": "2782", "narrator_chain": "", "chapter_intro": "The Book of I'tikaf"}
{"hadithnumber": "2783", "arabic": "حَدَّثَنَا  يَحْيَى بْنُ يَحْيَى ، أَخْبَرَنَا  أَبُو مُعَاوِيَةَ . ح وحَدَّثَنَا  سَهْلُ بْنُ عُثْم", "bengali": "", "english": "This hadith has been narrated by 'A'isha (Allah be pleased with her) through another chain of transmitters", "french": "", "indonesian": "", "russian": "", "urdu": "ہشام بن عروہ نے اپنے والد ( عروہ  )  سے ، انھوں نے حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے روایت کی ،", "grades": "", "reference": "Book 14, Hadith 4", "international_number": "2783", "narrator_chain": "", "chapter_intro": "The Book of I'tikaf"}
{"hadithnumber": "2784", "arabic": "وحَدَّثَنَا  قُتَيْبَةُ بْنُ سَعِيدٍ ، حَدَّثَنَا  لَيْثٌ ، عَنْ  عُقَيْلٍ ، عَنِ  الزُّهْرِيِّ ، عَ", "bengali": "", "english": "A'isha (Allah be pleased with her) reported that the Messenger of Allah (may peace he upon him) used to observe i'tikif in the last ten days of Ramadan till Allah called him back (to his heavenly home). Then his wives observed i'tikaf after him", "french": "", "indonesian": "", "russian": "", "urdu": "زہری نے عروہ کے واسطے سے حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے روایت کی کہ نبی کریم  صلی اللہ علیہ و", "grades": "", "reference": "Book 14, Hadith 5", "international_number": "2784", "narrator_chain": "", "chapter_intro": "The Book of I'tikaf"}
{"hadithnumber": "2785", "arabic": "حَدَّثَنَا  يَحْيَى بْنُ يَحْيَى ، أَخْبَرَنَا  أَبُو مُعَاوِيَةَ ، عَنْ  يَحْيَى بْنِ سَعِيدٍ ، عَن", "bengali": "", "english": "A'isha (Allah be pleased with her) reported that when the Messenger of Allah (ﷺ) decided to observe i'tikaf, he prayed in the morning and then went to the place of his i'tikaf, and he commanded that a tent should be pitched for him, and it was pitched. He (once) decided to observe i'tikaf in the last ten days of Ramadan. Zainab (the wife of the Holy Prophet) commanded that a tent should be pitched for her. It was pitched accordingly. And some other wives of Allah's Apostle (ﷺ) commanded that tents should be pitched for them too. And they were pitched. When the Messenger of Allah (may peace he upon him) offered the morning prayer, he looked and found (so many) tents. Thereupon he said:What is this virtue that these (ladies) have decided to acquire? He commanded his tent to be struck and abandoned i'tikaf in the month of Ramadan and postponed it to the first ten days of Shawwal", "french": "", "indonesian": "", "russian": "", "urdu": "ابو معاویہ نے ہمیں یحییٰ بن سعید سے خبر دی ، انھوں نے عمرہ سے ، انھوں نے حضرت عائشہ  رضی اللہ تعالیٰ", "grades": "", "reference": "Book 14, Hadith 6", "international_number": "2785", "narrator_chain": "", "chapter_intro": "The Book of I'tikaf"}
{"hadithnumber": "2786", "arabic": "وحَدَّثَنَاه  ابْنُ أَبِي عُمَرَ ، حَدَّثَنَا  سُفْيَانُ . ح وحَدَّثَنِي  عَمْرُو بْنُ سَوَّادٍ ، أَ", "bengali": "", "english": "This hadith has been reported through another chain of transmitters, and there it is mentioned that. 'A'isha, Hafsa and Zainab (Allah be pleased with them) pitched the tents for i'tikaf", "french": "", "indonesian": "", "russian": "", "urdu": "سفیان بن عینیہ ، عمرو بن حارث ، سفیان ثوری ، اوزاعی ، اور محمد بن اسحاق سب نے یحییٰ بن سعید سے ، انھ", "grades": "", "reference": "Book 14, Hadith 7", "international_number": "2786", "narrator_chain": "", "chapter_intro": "The Book of I'tikaf"}
{"hadithnumber": "2787", "arabic": "حَدَّثَنَا  إِسْحَاق بْنُ إِبْرَاهِيمَ الْحَنْظَلِيُّ ،  وَابْنُ أَبِي عُمَرَ جَمِيعًا، عَنِ  ابْنِ", "bengali": "", "english": "A'isha (Allah be pleased with her) reported that when the last ten nights began Allah's Messenger (ﷺ) kept awake at night (for prayer and devotion), wakened his family, and prepared himself to observe prayer (with more vigour)", "french": "", "indonesian": "", "russian": "", "urdu": "مسروق نے حضرت عائشہ سے روایت کی کہ ام المؤمنین عائشہ صدیقہ رضی اللہ عنہا کہتی ہیں  : کہ رسول اللہ صل", "grades": "", "reference": "Book 14, Hadith 8", "international_number": "2787", "narrator_chain": "", "chapter_intro": "The Book of I'tikaf"}
{"hadithnumber": "2788", "arabic": "حَدَّثَنَا  قُتَيْبَةُ بْنُ سَعِيدٍ ،  وَأَبُو كَامِلٍ الْجَحْدَرِيُّ كِلَاهُمَا، عَنْ  عَبْدِ الْوَ", "bengali": "", "english": "A'isha (Allah be pleased with her) reported that Allah's Messenger (ﷺ) used to exert himself in devotion during the last ten nights to a greater extent than at any other time", "french": "", "indonesian": "", "russian": "", "urdu": "حسن بن عبیداللہ سے روایت ہے   ، کہا : میں نے ابراہیم نخعی سےسنا ، کہہ رہے تھے : میں نے اسود بن یزید", "grades": "", "reference": "Book 14, Hadith 9", "international_number": "2788", "narrator_chain": "", "chapter_intro": "The Book of I'tikaf"}
{"hadithnumber": "2789", "arabic": "حَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ،  وَأَبُو كُرَيْبٍ ،  وَإِسْحَاق ، قَالَ إِسْحَاق: أَخ", "bengali": "", "english": "A'isha (Allah be pleased with her) reported:I never saw the Messenger of Allah (ﷺ) fasting in the ten days of Dhu'I-Hijja", "french": "", "indonesian": "", "russian": "", "urdu": "ابو معاویہ نے اعمش سے ، انھوں نےابراہیم سے ، انھوں نے اسود سے ، انھوں نے حضرت عائشہ  رضی اللہ تعالیٰ", "grades": "", "reference": "Book 14, Hadith 10", "international_number": "2789", "narrator_chain": "", "chapter_intro": "The Book of I'tikaf"}
{"hadithnumber": "2790", "arabic": "وحَدَّثَنِي  أَبُو بَكْرِ بْنُ نَافِعٍ الْعَبْدِيُّ ، حَدَّثَنَا  عَبْدُ الرَّحْمَنِ ، حَدَّثَنَا  س", "bengali": "", "english": "A'isha (Allah be pleased with her) reported:The Apostle of Allah (ﷺ) did not observe fast in the ten days of Dhul-Hijja", "french": "", "indonesian": "", "russian": "", "urdu": "سفیان نے اعمش سے باقی ماندہ سابقہ سند کے ساتھ حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے روایت کی کہ اللہ", "grades": "", "reference": "Book 14, Hadith 11", "international_number": "2790", "narrator_chain": "", "chapter_intro": "The Book of I'tikaf"}
