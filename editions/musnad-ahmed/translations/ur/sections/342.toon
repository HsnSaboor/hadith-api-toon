hadiths[1]{hadithnumber,text}:
16746,أذعشحأسۏأتهؽشۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأتۏڬأزۏۄتحۏأإزوۏأىثۏأ﷽أڬۏأرزوحأوۏڽأذتعشأۄًتأ؏أىثۏأ﷽أتضأًمحأډۄهأمزوۏألشوتأشۄەأحہەأ؏أتضأىەأځًډہتأۏتأشضًهأتههۄأ$أثؼعأتًمتحأتثہۏأۄوأهًڲأتًىټًڽأڬەأثتڔەأوۏڽأۄًحەأۄۏڽأڬۄأىوتصأڬتأًمحأۄًأدتحتأۄەأحًأڬۏتأۄوأًۄۏڽأځشأىوتصأځڔہأضڬحەأۄۏڽأآأىثۏأ﷽أىەألشوتۏتأىۄۏڽأ؏أتضأىەأځًډہتأڬۏتأتًىټأڬتأڲًطحأڬہتىەأڬەأثؼزأۄوأىۏتأًعًأڬشۏڽأآأىثۏأ﷽أىەألشوتۏتأۄتڽأ$أتضأىەأځًډہتأڬۏتأۄوأثڬشۏًڽأڬەأثتڔەأوۏڽأىوتصأځڔہأضڬحەأۄۏڽأآأىثۏأ﷽أىەألشوتۏتأۄتڽأ$أتضأىەأځًډہتأڬۏتأثڬشۏأڬتأڲًطحأڬہتىەأڬەأثؼزأۄوأىۏتأًعًأڬشۏڽأآأىثۏأ﷽أىەألشوتۏتأىۄۏڽأۗ
