{"hadithnumber": "3041", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے اہل نجران سے اس شرط پر ص"}
{"hadithnumber": "3042", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  جب اہل فارس کے نبی مر گئے تو ابلیس نے انہیں مجوسیت  ( یع"}
{"hadithnumber": "3043", "text": "عمرو بن دینار سے روایت ہے، انہوں نے بجالہ کو عمرو بن اوس اور ابوشعثاء سے بیان کرتے سنا کہ  میں احنف"}
{"hadithnumber": "3044", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  بحرین کے رہنے والے اسبذیوں ۱؎  ( ہجر کے مجوسیوں )  میں ک"}
{"hadithnumber": "3045", "text": "عروہ بن زبیر کہتے ہیں کہ  ہشام بن حکیم بن حزام رضی اللہ عنہما نے حمص کے ایک عامل  ( محصل )  کو دیکھا"}
{"hadithnumber": "3046", "text": "حرب بن عبیداللہ کے نانا (جو بنی تغلب سے ہیں) کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ع"}
{"hadithnumber": "3047", "text": "حرب بن عبیداللہ سے اسی مفہوم کی حدیث مرفوعاً مروی ہے  لیکن «عشور» کی جگہ «خراج» کا لفظ ہے۔"}
{"hadithnumber": "3048", "text": "عطا سے روایت ہے  انہوں نے  ( قبیلہ )  بکر بن وائل کے ایک شخص سے اس نے اپنے ماموں سے روایت کیا ہے وہ"}
{"hadithnumber": "3049", "text": "حرب بن عبیداللہ کے نانا جو بنی تغلب سے تعلق رکھتے تھے کہتے ہیں  میں نبی اکرم صلی اللہ علیہ وسلم کے پ"}
{"hadithnumber": "3050", "text": "عرباض بن ساریہ سلمی رضی اللہ عنہ کہتے ہیں  ہم نے نبی اکرم صلی اللہ علیہ وسلم کے ساتھ خیبر میں پڑاؤ ک"}
{"hadithnumber": "3051", "text": "جہینہ کے ایک شخص کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ایسا ہو سکتا ہے کہ تم ایک قوم"}
{"hadithnumber": "3052", "text": "ابوصخر مدینی کا بیان ہے کہ  صفوان بن سلیم نے رسول اللہ صلی اللہ علیہ وسلم کے اصحاب کے کچھ بیٹوں سے ا"}
{"hadithnumber": "3053", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مسلمان پر جزیہ"}
{"hadithnumber": "3054", "text": "محمد بن کثیر کہتے ہیں  سفیان سے اس حدیث کا مطلب ۱؎ پوچھا گیا تو انہوں نے کہا کہ جب ذمی اسلام قبول کر"}
{"hadithnumber": "3055", "text": "عبداللہ ہوزنی کہتے ہیں کہ  میں نے مؤذن رسول بلال رضی اللہ عنہ سے حلب ۱؎ میں ملاقات کی، اور کہا: بلال"}
{"hadithnumber": "3056", "text": "اس سند سے بھی ابوتوبہ کی حدیث کے ہم معنی حدیث مروی ہے، اس میں ہے کہ  جب میں نے کہا کہ نہ آپ کے پاس ا"}
{"hadithnumber": "3057", "text": "عیاض بن حمار رضی اللہ عنہ کہتے ہیں  میں نے نبی اکرم صلی اللہ علیہ وسلم کو ایک اونٹنی ہدیہ میں دی، تو"}
{"hadithnumber": "3058", "text": "وائل رضی اللہ عنہ ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے انہیں حضر موت ۱؎ میں زمین کا ٹکڑا جاگیر میں"}
{"hadithnumber": "3059", "text": "اس سند سے بھی علقمہ بن وائل سے  اسی کے مثل روایت مروی ہے۔"}
{"hadithnumber": "3060", "text": "عمرو بن حریث رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مدینہ میں مجھے گھر بنانے کے ل"}
{"hadithnumber": "3061", "text": "ربیعہ بن ابی عبدالرحمٰن نے کئی لوگوں سے روایت کی ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے بلال بن حارث"}
{"hadithnumber": "3062", "text": "عمرو بن عوف مزنی رضی اللہ عنہ ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے بلال بن حارث مزنی کو قبلیہ کی ن"}
{"hadithnumber": "3063", "text": "محمد بن نضر کہتے ہیں کہ  میں نے حنینی کو کہتے ہوئے سنا کہ میں نے اسے یعنی نبی اکرم صلی اللہ علیہ وسل"}
{"hadithnumber": "3064", "text": "ابیض بن حمال ماربی رضی اللہ عنہ سے روایت ہے کہ  وہ رسول اللہ صلی اللہ علیہ وسلم کے پاس آئے اور آپ سے"}
{"hadithnumber": "3065", "text": "ہارون بن عبداللہ کہتے ہیں کہ  محمد بن حسن مخزومی نے کہا: «ما لم تنله أخفاف الإبل» کا مطلب یہ ہے کہ ا"}
{"hadithnumber": "3066", "text": "ابیض بن حمال ماربی رضی اللہ عنہ سے روایت ہے کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم سے پیلو کی ایک"}
{"hadithnumber": "3067", "text": "صخر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ثقیف سے جہاد کیا  ( یعنی قلعہ طائف پر"}
{"hadithnumber": "3068", "text": "ربیع جہنی کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے اس جگہ جہاں اب مسجد ہے ایک بڑے درخت کے نیچے پڑ"}
{"hadithnumber": "3069", "text": "اسماء بنت ابوبکر رضی اللہ عنہما کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے زبیر رضی اللہ عنہ  ( اس"}
