{"hadithnumber": "4566", "text": "مسلم بن یسار اور عبداللہ بن عبید کہتے ہیں کہ  عبادہ بن صامت اور معاویہ رضی اللہ عنہما ایک جگہ اکٹھا"}
{"hadithnumber": "4567", "text": "عبادہ بن صامت رضی اللہ عنہ سے روایت ہے (وہ بدری صحابی ہیں، انہوں نے رسول اللہ صلی اللہ علیہ وسلم سے"}
{"hadithnumber": "4568", "text": "عبادہ بن صامت رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”سونا سونے کے بدلے،"}
{"hadithnumber": "4569", "text": "سلیمان بن علی سے روایت ہے کہ  بازار میں ان کے پاس سے ابوالمتوکل کا گزر ہوا، تو کچھ لوگ ان کے پاس گئے"}
{"hadithnumber": "4570", "text": "عبادہ بن صامت رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا: ”سون"}
{"hadithnumber": "4571", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”دینار کے بدلے دینار ا"}
{"hadithnumber": "4572", "text": "عمر رضی اللہ عنہ کہتے ہیں کہ  دینار کے بدلے دینار، درہم کے بدلے درہم کی بیع میں کمی زیادتی جائز نہیں"}
{"hadithnumber": "4573", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”سونے کے بدلے سونا، برابر"}
{"hadithnumber": "4574", "text": "ابو سعید خدری رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”سونا سونے کے بدل"}
{"hadithnumber": "4575", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  میری آنکھوں نے دیکھا اور میرے کانوں نے رسول اللہ صلی اللہ عل"}
{"hadithnumber": "4576", "text": "عطاء بن یسار سے روایت ہے کہ  معاویہ رضی اللہ عنہ نے پینے کا برتن جو سونے یا چاندی کا تھا اس سے زائد"}
{"hadithnumber": "4577", "text": "فضالہ بن عبید رضی اللہ عنہ کہتے ہیں کہ  خیبر کے دن میں نے ایک ہار جس میں سونا اور نگینے لگے ہوئے تھے"}
{"hadithnumber": "4578", "text": "فضالہ بن عبید رضی اللہ عنہ کہتے ہیں کہ  مجھے خیبر کے دن ایک ہار ملا جس میں سونا اور نگینے تھے، میں ن"}
{"hadithnumber": "4579", "text": "ابومنہال کہتے ہیں کہ  شریک نے کچھ چاندی ادھار بیچی، پھر میرے پاس کر مجھے بتایا تو میں نے کہا: یہ درس"}
