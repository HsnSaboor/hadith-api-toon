{"metadata":{"name":"Sunan an Nasai","section":{"1":"The Book of Purification"},"section_detail":{"1":{"hadithnumber_first":1,"hadithnumber_last":324,"arabicnumber_first":1,"arabicnumber_last":324}}},"hadiths":[{"hadithnumber":37,"arabicnumber":37,"text":"Rapporté par Ibn 'Umar : Un homme est passé devant le Prophète (ﷺ) alors qu’il urinait et l’a salué, mais il n’a pas répondu à son salut","grades":[{"name":"Abu Ghuddah","grade":"Hasan Sahih"},{"name":"Al-Albani","grade":"Hasan Sahih"},{"name":"Zubair Ali Zai","grade":"Sahih Muslim"}],"reference":{"book":1,"hadith":37}}]}