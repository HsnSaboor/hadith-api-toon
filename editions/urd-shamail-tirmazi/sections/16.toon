metadata:
  section_id: 16
  section_name: رسول اللہ صلی اللہ علیہ وسلم کی زرہ کا بیان
  hadith_first: 106
  hadith_last: 107

hadiths[2]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
106,"’’سیدنا زبیر بن عوام رضی اللہ عنہ سے مروی ہے وہ فرماتے ہیں جنگ اُحد کے دن رسول اللہ صلی اللہ علیہ وسلم نے دو زرہیں زیب تن فرمائی تھیں، پس آپ صلی اللہ علیہ وسلم نے ایک چٹان پر چڑھنے کا ارادہ فرمایا تو اس چٹان پر نہ چڑھ سکے، پس آ پ صلی اللہ علیہ وسلم نے طلحہ رضی اللہ عنہ کو نیچے بٹھایا اور ( ان پر کھڑے ہو کر) اس چٹان پر سیدھے چڑھ گئے۔ زبیر رضی اللہ عنہ فرماتے ہیں کہ میں نے نبی اکرم صلی اللہ علیہ وسلم سے سنا آپ صلی اللہ علیہ وسلم نے فرمایا : طلحہ نے (اپنے اوپر جنت) واجب کرلی۔ ‘‘",,,106,,رسول اللہ صلی اللہ علیہ وسلم کی زرہ کا بیان
107,’’سیدنا سائب بن یزید رضی اللہ عنہ فرماتے ہیں رسول اللہ صلی اللہ علیہ وسلم پر احد کے دن دو زرہیں تھیں، دونوں کو اوپر نیچے پہن رکھا تھا۔ ‘‘,,,107,,رسول اللہ صلی اللہ علیہ وسلم کی زرہ کا بیان
