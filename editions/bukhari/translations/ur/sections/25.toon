{"hadithnumber": "1752", "text": "ہم سے اسماعیل بن عبداللہ نے بیان کیا، انہوں نے کہا کہ مجھ سے میرے بھائی (عبدالحمید) نے بیان کیا، ان"}
{"hadithnumber": "1753", "text": "اور محمد بن بشار نے کہا کہ ہم سے عثمان بن عمر نے بیان کیا، انہیں یونس نے خبر دی اور انہیں زہری نے کہ"}
{"hadithnumber": "1754", "text": "ہم سے علی بن عبداللہ نے بیان کیا، کہا ہم سے سفیان بن عیینہ نے بیان کیا، ان سے عبدالرحمٰن بن قاسم نے"}
{"hadithnumber": "1755", "text": "ہم سے مسدد نے بیان کیا، کہا ہم سے سفیان بن عیینہ نے بیان کیا، ان سے ابن طاؤس نے، ان سے ان کے والد نے"}
{"hadithnumber": "1756", "text": "ہم سے اصبغ بن فرج نے بیان کیا، انہوں نے کہا کہ ہم کو ابن وہب نے خبر دی، انہیں عمرو بن حارث نے، انہیں"}
{"hadithnumber": "1757", "text": "ہم سے عبداللہ بن یوسف نے بیان کیا، کہا ہمیں امام مالک نے خبر دی، انہیں عبدالرحمٰن بن قاسم نے، انہیں"}
{"hadithnumber": "1759", "text": "ہم سے ابوالنعمان نے بیان کیا، ان سے ایوب نے، ان سے عکرمہ نے کہ  مدینہ کے لوگوں نے ابن عباس رضی اللہ"}
{"hadithnumber": "1761", "text": "کہا میں نے ابن عمر کو کہتے سنا کہ  اس عورت کے لیے واپسی نہیں۔ اس کے بعد میں نے ان سے سنا آپ فرماتے ت"}
{"hadithnumber": "1762", "text": "ہم سے ابوالنعمان نے بیان کیا، کہا کہ ہم سے ابوعوانہ نے بیان کیا، ان سے منصور نے، ان سے ابراہیم نخعی"}
{"hadithnumber": "1763", "text": "ہم سے محمد بن مثنی نے بیان کیا، کہا ہم سے اسحٰق بن یوسف نے بیان کیا، ان سے سفیان ثوری نے بیان کیا، ا"}
{"hadithnumber": "1764", "text": "ہم سے عبدالمتعال بن طالب نے بیان کیا، انہوں نے کہا کہ ہم سے ابن وہب نے بیان کیا، انہوں نے کہا کہ مجھ"}
{"hadithnumber": "1765", "text": "ہم سے ابونعیم نے بیان کیا، کہا کہ ہم سے سفیان نے بیان کیا، ان سے ہشام بن عروہ نے، ان سے ان کے والد ن"}
{"hadithnumber": "1766", "text": "ہم سے علی بن عبداللہ نے بیان کیا، کہا ہم سے سفیان بن عیینہ نے بیان کیا، ان سے عمرو بن عطاء بن ابی رب"}
{"hadithnumber": "1767", "text": "ہم سے ابراہیم بن المنذر نے بیان کیا، انہوں نے کہا کہ ہم سے ابوضمرہ انس بن عیاض نے بیان کیا، ان سے مو"}
{"hadithnumber": "1768", "text": "ہم سے عبداللہ بن عبدالوہاب نے بیان کیا، انہوں نے کہا کہ ہم سے خالد بن حارث نے بیان کیا، انہوں نے کہا"}
{"hadithnumber": "1769", "text": "اور محمد بن عیسیٰ نے کہا کہ ہم سے حماد بن سلمہ نے بیان کیا، انہوں نے کہا کہ ہم سے ایوب نے بیان کیا،"}
{"hadithnumber": "1770", "text": "ہم سے عثمان بن ہیثم نے بیان کیا، انہوں نے کہا کہ ہم کو ابن جریج نے خبر دی، ان سے عمرو بن دینار نے بی"}
{"hadithnumber": "1772", "text": "ابوعبداللہ (امام بخاری رحمہ اللہ) نے کہا، محمد بن سلام نے (اپنی روایت میں) یہ زیادتی کی ہے کہ ہم سے"}
