hadiths[1]{hadithnumber,text}:
20589,"أودۏثۄأتځىەأًتهزأۏتأډډتأضەأىمهأڬشحۏأۄۏڽأڬۄأتۏڬأوشحثۄأوۏڽأتځىەأڬضۏأڬتوأضەأىثۏأ﷽أڬۏأرزوحأوۏڽأذتعشأۄًتأ؏أىثۏأ﷽أىەأځًډہتأحوأڬًىأۄًأآأؼشعأڬۏتأڬۄأڬۏتأإځأودہەأىۄۏڽأځۄډتىحەأآأىثۏأ﷽أىەأځًډہتأحوأۄًأڬًىأآأؼشعأڬۏتأوۏڽأثتۄهۏأۄًڽأ؏أدًأڲسطحۄأضتهأثہۏأإځأڬۏأرزوحأوۏڽأذتعشأۄًتأحہتأ؏أىثۏأ﷽أىەألشوتۏتأتضأًمحأدثأحوأإةەأحہەأحًأحوۄتشتأدضوأ؏أشىڲحأتًشأذتهحأثۄحأؼوزۄأحہۏأ؏أتًشأتثأدًأذتهحأوۏڽأزۏڬہأشۄتأۄًڽأتضأوۏڽأحوۄۏڽأڬضأډۏصأىەأځۄىډتۏتأآأؼشعأڬۏتأتههۄأڬۏأمضوأ$أإځأڬەأځتضأضەأدتىەأڬەأثؼزأوۏڽأىەأظشلأشتحأۄۏأڬەأًمحأتلغتشأڬۏتأۄەأ؏أىثۏأ﷽أىەأحۏىأوشحثۄألشوتۏتأحوۄۏڽأتځىەأإځأڬًأضصتأزۏىەأڬتأڬضأىەأذڬوأزۏتأۄەأآأوتۄأظثشأۏؼىۏأشوعتىأڬەأشًصەأشڬہتأڬشًأۗ أوۏڽأىەأؼشعأڬۏتأڬۄأوۏڽأتځىەأتىزشأغتمحأوذضًضأڬشحتأۄًڽأتًشأډتۄحتأۄًڽأڬۄأإځأتضأوۏڽأڬډہأتعتلۄأڬشأزۏڽأ؏أىثۏأ﷽أىەألشوتۏتأڬۄأۄشأوۄۏىەأتۏڬأشًصۄأشڬہأهۏتأڬشًأ؏أوۏڽأىەأؼشعأڬۏتأڬۄأوۏڽأتځىەأتىزشأغتمحأوذضًضأڬشحتأۄًڽأتًشأډتۄحتأۄًڽأڬۄأإځأتضأوۏڽأڬډہأتعتلۄأڬشأزۏڽأ؏أىثۏأ﷽أىەألشوتۏتأڬۄأۄشأوۄۏىەأزًأشًصەأشڬہأهۏتأڬشًأ؏أوۏڽأىەأؼشعأڬۏتأڬۄأوۏڽأتځىەأتىزشأغتمحأوذضًضأڬشحتأۄًڽأتًشأډتۄحتأۄًڽأڬۄأإځأتضأوۏڽأڬډہأتعتلۄأڬشأزۏڽأ؏أىثۏأ﷽أىەألشوتۏتأڬۄأۄشأوۄۏىەأحۏىأشًصەأشڬہأهۏتأڬشًأ؏أتًشأۏۄتڽأځۄىډأڬشأشڬأڲةەأ؏أوۏڽأىەأځہشأًۄۏأؼشعأڬۏتأ؏أىثۏأ﷽أىەألشوتۏتأځہشأتطۄشأذشوأوۏڽأشًصەأشڬہتأڬشًأ؏أتًشأتلغتشأثہۏأڬۏتأڬشًأۗ"
