{"hadithnumber": "4870", "text": "سالم بن ابی الجعد کہتے ہیں کہ  ابن عباس رضی اللہ عنہما سے اس شخص کے بارے میں پوچھا گیا جس نے کسی موم"}
{"hadithnumber": "4871", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”کبیرہ گناہ یہ ہیں: اللہ تعالی"}
{"hadithnumber": "4872", "text": "عبداللہ بن عمرو رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”کبیرہ گناہ یہ"}
{"hadithnumber": "4873", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”کوئی بندہ مومن"}
{"hadithnumber": "4874", "text": "ابوہریرہ رضی اللہ عنہ روایت کرتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”کوئی شخص ایمان رکھ"}
{"hadithnumber": "4875", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جب زنا کرنے والا زنا کرت"}
{"hadithnumber": "4876", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  جب کوئی زنا کرتا ہے تو زنا کے وقت وہ مومن نہیں رہتا، چوری کرتا ہے"}
{"hadithnumber": "4877", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اللہ تعالیٰ کی لعنت نازل"}
{"hadithnumber": "4878", "text": "نعمان بن بشیر رضی اللہ عنہما سے روایت ہے کہ  ان کے پاس قبیلہ کلاع کے کچھ لوگ مقدمہ لائے کہ کچھ بنکرو"}
{"hadithnumber": "4879", "text": "بہز بن حکیم کے دادا معاویہ بن حیدہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے کچھ لوگ"}
{"hadithnumber": "4880", "text": "بہز بن حکیم کے دادا معاویہ بن حیدہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک شخص"}
{"hadithnumber": "4881", "text": "ابوامیہ مخزومی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے پاس ایک چور پکڑ کر لایا گیا"}
{"hadithnumber": "4882", "text": "صفوان بن امیہ رضی اللہ عنہ کہتے ہیں کہ  ایک شخص نے ان کی چادر چرا لی، وہ اسے لے کر رسول اللہ صلی الل"}
{"hadithnumber": "4883", "text": "صفوان بن امیہ رضی اللہ عنہ کہتے ہیں کہ  ایک شخص نے ایک چادر چرائی، وہ اسے لے کر نبی اکرم صلی اللہ عل"}
{"hadithnumber": "4884", "text": "عطا بن ابی رباح کہتے ہیں کہ  ایک شخص نے ایک کپڑا چرایا، اسے رسول اللہ صلی اللہ علیہ وسلم کے پاس لایا"}
{"hadithnumber": "4885", "text": "صفوان بن امیہ رضی اللہ عنہ کہتے ہیں کہ  انہوں نے بیت اللہ کا طواف کیا، پھر نماز پڑھی، پھر اپنی چادر"}
{"hadithnumber": "4886", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  صفوان رضی اللہ عنہ مسجد میں سو رہے تھے، ان کی چادر ان کے"}
{"hadithnumber": "4887", "text": "صفوان بن امیہ رضی اللہ عنہ کہتے ہیں کہ  میں مسجد میں اپنی ایک چادر پر سو رہا تھا، جس کی قیمت تیس درہ"}
{"hadithnumber": "4888", "text": "صفوان بن امیہ رضی اللہ عنہ کہتے ہیں کہ  ایک چادر ان کے سر کے نیچے سے چوری ہو گئی اور وہ مسجد نبوی می"}
{"hadithnumber": "4889", "text": "عبداللہ بن عمرو رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”حدود کو میرے"}
{"hadithnumber": "4890", "text": "عبداللہ بن عمرو بن عاص رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”حدود"}
