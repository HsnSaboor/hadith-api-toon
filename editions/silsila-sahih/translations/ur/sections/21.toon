2565,"تثًأۄشۏشۄ‏شعۏأتههۄأؼىۄأضەأوشلًؼتأوشًۏأۄەأڬۄ=أۏتأدًدأتًشأوتدًأدأۄشأزىأزۏًتشأڬہشډحەأۄۏڽ؏أۏۄتڽأحڬأڬۄأدثأتضأذزأحڬأځۄىډأدتحەأۄۏڽأڬۄأضًشدأڬۏأطؼتؼأزۏڬہأضڬۏڽأحًأتىأڬتأىڲشتىأڬۄحتأۄە=أًتځضأډهً؏أثتمۏأڬهأڬہشډۏڽأڲەۗأتههۄأحؼتهۏٳأتضأزۏًتشأڬًأتضأضەأأصۏتزۄأوًټتأڬشأزۏحتأۄە؏أذحۏأڬۄأدثأتىأڬەأىڬهىەأڬتأًمحأإدتةەأڲتأتًشأتههۄأحؼتهۏٳأتىۄۏڽأهًڲًڽأوۏڽأثہۏدىتأډتۄەڲتأحًأزۏًتشأڬہشډۏڽأڲەأذحۏأڬۄأضًشدأڬۏأڬشىأزۏڬہىەأڬەأمشۏثأځۄىډأدتةۏڽأڲەأحًأتىأڬتأىڲشتىأڬۄەأڲت=أًتځضأډهًأثتمۏأتىأطتؤأتههۄأڬهأڬہشډۏڽأڲەأ؏أدثأًۄأتضأغشذأڬۄۏڽأڲەأتًشأزًضشەأزىأًتځضأإةۏڽأڲەأحًأزۏًتشأتضۏأغشذأۄًڲۏأدضأغشذأډہًڔأڬشأڲةەأۄًڽأڲەۗأًۄأتضەأڬہشډأڬشأهًڲًڽأوۏڽأإدتةۏڽأڲە؏ځتىۏأرحوأڬشزۏڽأڲەتًشهًڲأمهؼًڽ+أڲہشًڽ,أوۏڽأثىزأۄًأدتةۏڽأڲەۗأًۄأتځىەأحۏشأإضوتىأڬۏأغشلأځہۏىڬۏڽأڲە؏أدثأًتځضأإةۏڽأڲەأحًأتىأځشأرًىأهڲتأۄًتأۄًڲتۗأًۄأڬۄۏڽأڲە=ۄوأصوۏىأتًشأإضوتىأًتهًڽأځشأؽتهثأۄًڲةە؏أحثأتههۄأحؼتهۏٳأتىأڬۏأڲشزىًڽأوۏڽأڬۏڔتأځۏزتأڬشأزەأڲتأدضأڬۏأًدۄأضەأًۄأوشأدتةۏڽأڲە؏شضًهأتههۄأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ىەألشوتۏت=أتضأستحأڬۏأمضوأدضأڬەأۄتحہأوۏڽأوۏشۏأدتىأۄە؏صوۏىأڬەأڬۏڔەأوڬًڔەأتىأڬتأڲًطحأڬہتأڬشأوًټەأۄًأدتةۏڽأڲەأتًشأرًثأطڬشأتزتأڬشۏڽأڲە

[تخریج]: الصحيحة رقم (1735)  سنن الترمذي كِتَاب تَفْسِيرِ الْقُرْآنِ بَاب وَمِنْ سُورَةِ الْكَهْفِ رقم (3078)"
2566,"تىضأثىأوتهڬ‏شعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأتۏڬأإزوۏأىەأشضًهأتههۄأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ضەأضًتهأڬۏت=أمۏتوحأڬثأإةەأڲۏآأإځأڬەأځتضأتىظتشأڬتأتۏڬأوذوزأىتوۏأثډۄأثۏټہتأۄًتأحہت؏أشضًهأتههۄأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ىەأتضأضەأڬۄت=أتڲشأۏۄأثډۄأصىزۄأشۄتأحًأووڬىأۄەأۏۄأثًڔہتأثہۏأىۄأۄًأتًشأمۏتوحأإدتةە

[تخریج]: الصحيحة رقم (3497)  صحيح مسلم كِتَاب الْفِتَنِ وَأَشْرَاطِ السَّاعَةِ بَاب قُرْبِ السَّاعَةِ رقم (5249) ."
2567,"دىتزۄأثىأتثۏأتوۏۄأزًضۏأأشذوۆأتههۄأؼهۏۄأضەأوشًۏأۄەأڬۄحەأۄۏڽأڬۄأوۏڽأتًشأوۏشتأتۏڬأزًضحأشضًهأتههۄأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ڬەأتۏڬأظذتثۏأڬەأځتضأإةە؏ۄوأىەأڬۄت=إځأىەأشضًهأتههۄأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ضەأدًأضىتأۄەأًۄأۄوۏڽأثۏتىأڬۏدةە؏تضأڬەأؼهتًۄأڬضۏأتًشأضەأثۏتىأىۄأڬۏدةەأتڲشډۄأًۄأضډتأۄۏأڬۏًڽأىۄأۄً؏أتىۄًڽأىەأڬۄتأټہۏڬأۄە؏تۏڬأزىأشضًهأتههۄأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ۄوأوۏڽأڬہڔەأۄًةەأتًشألشوتىەأهڲە=وۏڽأحوۄۏڽأزدتهأضەأڋشتحتأۄًڽ؏أوۏڽأحوۄۏڽأزدتهأضەأڋشتحتأۄًڽ؏أوۏڽأحوۄۏڽأزدتهأضەأڋشتحتأۄًڽۗأأڬۏًڽأڬۄأدًأىثۏأثہۏأإۏتأۄەأتضأىەأزدتهأضەأتځىۏأتوحأڬًأڋشتۏتأۄەأتًشأتەأوۏشۏأتوح$أًۄأحوأوۏڽأػتۄشأۄًڲت؏أًۄأڲىزوۏأشىڲأڬتأضرحأڲہىڲشۏتهەأثتهًڽأًتهتأۄًڲت؏أثتةۏڽأإىڬہأضەأڬتىتأۄًڲتۗتضأڬەأضتحہأدىحأتًشأدۄىوأۄًڲۏ؏أتضأڬۏأدۄىوأدىحأۄەأتًشأتضأڬۏأدىحأدۄىوأۄەأتًشأتضأڬەأضتحہأځتىۏأڬۏأتۏڬأىۄشأتًشأشًټۏأڬتأځۄتڔأۄًڲتۗأًۄأتۏڬأطرظأځشأؽهثۄأځتةەأڲتأحًأتضەأمحهأڬشأڬەأصىزۄأڬشأزەأڲتۗأتضأڬەأؼهتًۄأڬضۏأتًشأځشأؽهثۄأىۄۏڽأځتأضڬەأڲتۗأًۄأإضوتىأضەأثتشطأثشضتةەأڲتأهۏڬىأصوۏىأوۏڽأڬہۏحۏأىۄۏڽأتڲەأڲۏ؏أًۄأصوۏىأوۏڽأډتهۏضأزىأشۄەأڲت؏أتًشأصوۏىأڬەأڬًىەأڬًىەأحڬأدتةەأڲت؏أًۄأډتشأوضدزًڽأڬەأمشۏثأىۄۏڽأدتضڬەڲتۗوضدزذشتو؏وضدزىثًۏ؏وضدزتمظۏأتًشأغًشۗحوأتضأڬەثتشەوۏڽأطثۄأوۏڽأىۄأځڔدتىتڬۏًڽأڬۄأحوۄتشتشثأڬتىتأىۄۏڽ+زًوشحثۄألشوتۏت,ۗأ

[تخریج]: الصحيحة رقم (2934)  مصنف ابن أبي شيبة رقم (52)"
2568,"وًضۏٳأثىأؼمثۄأأشذوۆأتههۄأؼهۏۄأضەأوشًۏأۄە؏أڬۄحەأۄۏڽأڬۄأودہەأوۏشەأىتىتأتثًأذثۏثۄأىەأثۏتىأڬۏتأڬۄأًۄأتضأڲہشأوۏڽأزترهأۄًةەأدضأوۏڽأؼخوتى‏شعۏأتههۄأؼىۄأأوذظًشأحہە؏تىۄًڽأىەأتثًأۄشۏشۄأشعۏأتههۄأؼىۄأأضەأضىتأًۄأثتحأډۏحأڬشىەأڬەأهةەأؼخوتى‏شعۏأتههۄأؼىۄأأضەأتدتصحأهەأشۄەأحہەۗأؼخوتى‏شعۏأتههۄأؼىۄأىەأتىۄۏڽأتدتصحأزەأزۏ؏أًۄأڬہڔەأۄًةەأتًشأتههۄأڬۏأذوزًأخىتأثۏتىأڬۏ؏أځہشأڬۄىەأهڲە=أوۏڽأىەأشضًهأتههۄأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ضەأضىتألشوتأشۄەأحہە=حوأوۏشەأثؼزألحىەأتًشأترحهتلأوۏڽأځڔأدتًٗأڲەۗأتۏڬأطرظأىەأإځأظهۏأتههۄأؼهۏۄأًضهوأضەأڬۄت=تەأتههۄأڬەأشضًه$ۄوتشۏأشۄىوتةۏأڬشىەأًتهتأڬًىأۄًڲتآأإځأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ىەألشوتۏت=أحوأتضأتوۏى+توتىحزتش,تًشأتضأڬەأضتحہۏًڽأڬەأضتحہأوهأدتىت؏أإځأظهۏأتههۄأؼهۏۄأًضهوأ‏ؼخوتىأشعۏأتههۄأؼىۄأأڬۏأغشلأتطتشۄأڬشأشۄەأحہە

[تخریج]: الصحيحة رقم (3188) مسند أحمد رقم (8185) ."
2569,"ثۄصأثىأذڬۏوأثىأوؼتًۏۄأتځىەأًتهزأضەأًۄأتځىەأزتزتأ+وؼتًۏۄأثىأذۏزۄأشعۏأتههۄأؼىۄأ,ضەأوشلًؼتأثۏتىأڬشحەأۄۏڽأڬۄأحوأمۏتوحأڬەأزىأثهتةەأدتًٗأڲەأحوۄتشەأوىۄأثىزأۄًڽأڲە؏أځہشأضثأضەأځۄهەأدًأؼعًأثتحأڬشەڲتأًۄأحوۄتشۏأشتىأتًشأۄحہۏهۏأۄًأڲۏأ

[تخریج]: الصحيحة رقم (2713) مسند أحمد رقم (19188) ."
2570,"تثًأسش‏شعۏأتههۄأؼىۄأضەأوشلًؼتأوشًۏأۄەڬۄ=أحوأإدأتضأزًشأوۏڽأۄًأدضأوۏڽأؼهوتأؤأصۏتزۄأۄۏڽأتًشأرغثتؤڬو؏دضأطرظأىەأتځىەأؼهوأڬەأوغتثمأزضًتڽأذظۄأثہۏأؼوهأډہًڔأزۏتأًۄأڲوشتۄأۄًڲت؏أتًشأتضأڬەأثؼزأتۏضتأزًشأإةەأڲتأدضأوۏڽأرغثتؤأصۏتزۄأۄًڽأڲەأتًشأؼهوتأؤڬو؏دضأطرظأىەأتځىەأؼهوأڬەأوغتثمأزضًتڽأذظۄأثہۏأؼوهأڬۏتأًۄأىدتحأځتأدتةەأڲت

[تخریج]: الصحيحة رقم (2510) مسند أحمد رقم (20408) ."
2571,"تثًأۄشۏشۄ‏شعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأىثۏأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ىەألشوتۏت=أمۏتوحأڬەأزىأتۏڬأوًټتأحتصۄأثہتشۏأثہشڬوأإزوۏأإةەأڲتأهۏڬىأتههۄأڬەأۄتڽأتۏڬأوډہشأڬەأځشأڬەأثشتثشأثہۏأًصىأىۄۏڽأشڬہەأڲتۗأتًشألشوتۏت=أۏۄأإۏحأځڔہً=+تهنيل=۴۳۸,ۗ““ځضأۄوأتىأڬەأ+تؼوتهأڬەأًصىأڬە,أهۏەأمۏتوحأڬەأزىأحشتصًأمتةوأڬشۏڽأڲەأ‛‛ۗأ

[تخریج]: الصحيحة رقم (3581) صحيح البخاري كِتَاب تَفْسِيرِ الْقُرْآنِ بَاب { أُولَئِكَ الَّذِينَ كَفَرُوا بِآيَاتِ رَبِّهِمْ ...} رقم (4360) ."
2572,"ؼثزتههۄأثىأشتلؼأأتوأضهوۄأصًدۄأىثۏأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ڬەأإصتزڬشزۄأؽهتوأضەأوشًۏأۄەأڬۄأتوأضهوۄأشعۏأتههۄأؼىۄتأىەأڬۄت=أوۏڽأهًڲًڽأضەأذًعأ+ڬًخش,ڬتأسڬشأضىتأڬشحۏأحہۏأهۏڬىأشضًهأتههۄأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ضەأىۄۏڽأضىتأحہت؏أتۏڬأزىأتۏضتأۄًتأڬۄأهًىڋۏأوۏشۏأڬىڲہۏأڬشأشۄۏأحہۏ؏وۏڽأىەأشضًهأتههۄأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ضەأضىت؏ألشوتأشۄەأحہە=هًڲً$وۏڽأىەأهًىڋۏأضەأڬۄت=أځۏډہەأۄټً؏أًۄأڬۄىەأهڲۏ=أإځأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ىەأحًأوشزًڽأڬًأثهتۏتأۄە؏ؼًشحًڽأڬًأىۄۏڽ؏وۏڽأىەأڬۄت=أوۏڽأثہۏأهًڲًڽأوۏڽأضەأۄًڽۗأشضًهأتههۄأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ىەألشوتۏت=أوۏڽأذًعأځشأحوۄتشتأوىحػشأۄًڽأڲتۗأتضأثتحأضەأثډىتأڬۄأڬًةۏأطرظأوۏشەأځتضأإةەأتًشأودہأضەأتضأغشذأزًشأڬشأزۏتأدتةەأدضأغشذأڲوشتۄ+ثہټڬتأۄًت,أتًىټأزًشأثہڲتأزۏتأدتحتأۄە؏أتًشأوۏڽأڬۄًڽ؏أۏۄأڬضأًدۄأضەأآأحًأودہەأثحتۏتأدتةەأڬۄ=إځأىۄۏڽأدتىحەأإځأڬەأثؼزأتىۄًڽأىەأڬۏتأڬۏتأىةەأڬتوأتۏدتزأڬشأهةەأحہەأآتًشأوۏڽأڬۄًڽأتىۄۏڽأزًشأڬشزً

[تخریج]: الصحيحة رقم (3944) صحيح مسلم كِتَاب الْفَضَائِلِ بَاب إِثْبَاتِ حَوْضِ نَبِيِّنَا ﷺ وَصِفَاتِهِ رقم (4247)"
2573,"ؼثزتههۄأثىأؼثتضأأشعۏأتههۄأؼىۄوتأ؏ؼوشأثىأرغتثأشعۏأتههۄأؼىۄأأضەأثۏتىأڬشحەأۄۏڽأڬۄأشضًهأتههۄأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ىەألشوتۏت=أوۏڽأحوۄۏڽأځۏډہەأضەأځڬڔأڬشأإڲأضەأثډتأشۄتأۄًڽأتًشأحوأڬۏڔەأوڬًڔًڽأ+ځشًتىًڽ,أتًشأټڋۏًڽأڬۏأغشذأتضأوۏڽأزترهأۄًىەأڬۏأڬًططأڬشأشۄەأۄًۗأمشۏثأۄەأڬۄأوۏڽأحوۄۏڽأځۏډہەأضەأډہًڔأزًڽ؏تًشأوۏڽأذًعأځشأحوۄتشتأوىحػشأشۄًڽأڲت؏حوأټًهۏًڽأڬۏأظًشحأوۏڽأتًشأتهڲأتهڲأأوۏشەأځتضأإًٗأڲە؏وۏڽأحوۄۏڽأحوۄتشەأىتوًڽأتًشأحوۄتشەأىطتىًڽأڬەأضتحہأتضأغشذأځۄډتىًڽأڲتأدضأغشذأڬًةۏأطرظأتځىەأتًىټًڽأوۏڽأتدىثۏأتًىټأځۄډتىحتأۄەأۗځہشأحوأوۏڽأضەأ+ثؼعأڬً,أثتةۏڽأغشلأهەأدتۏتأدتةەأڲت؏أوۏڽأشثأتهؼتهوۏىأضەأحوۄتشەأثتشەأوۏڽأتهحدتأڬشًڽأڲتأتًشأڬۄًڽأڲت=أتەأوۏشەأشث$أۏۄأوۏشۏأتوحأۄە؏ودہەأڬۄتأدتةەأڲت=أإځأىۄۏڽأدتىحەأڬۄأإځأڬەأثؼزأتىۄًڽأىەأڬۏتأڬۏتأىةەأڬتوأتۏدتزأڬشأهةە؏أۏۄأإځأڬەأثؼزأتهټەأمزوًڽأځہشأڲةەۗوۏڽأحوأوۏڽأضەأڬضۏأطرظأڬًأتضأذتهأوۏڽأىۄأځتًٗڽأڬۄأتضأڬەأڬتىزہًڽأځشأڬًةۏأثڬشۏأۄًأدًأوىوىتشۄۏأۄًأتًشأًۄأطرظأځڬتشأشۄتأۄً=أۏتأوذوز$أۏتأوذوز$أ+وۏشۏأوززأڬشً,أتًشأوۏڽأڬۄًڽأوۏڽأتههۄأضەأحوۄۏڽأىۄۏڽأډہڔتأضڬحتأوۏڽأىەأحًأځۏؽتوأځۄىډتأزۏتأحہتۗأتًشأحوأوۏڽأضەأڬضۏأطرظأڬًأتضأذتهأوۏڽأىۄأځتًٗڽأڬۄأًۄأمۏتوحأڬەأزىأإةەأتًشأتضأڬەأڬتىزہًڽأځشأڬًةۏأتًىټأۄًأدًأثهثهتأشۄتأۄً؏أًۄأطرظأ+وززأڬەأهةە,أځڬتشأشۄتأۄًأۏتأوذوز$أۏتأوذوز$أتًشأوۏڽأڬۄًڽ=أوۏڽأتههۄأضەأحوۄۏڽأىۄۏڽأډہڔتأضڬحت؏أوۏڽأىەأحًأځۏؽتوأځۄىډتأزۏتأحہتۗتًشأڬضۏأطرظأڬًأتضأذتهأوۏڽأىۄأځتًٗڽأڬۄأًۄأمۏتوحأڬەأزىأتځىەأڬتىزہًڽأځشأڲہًڔتأتټہتةەأۄًةەأإةەأدًأۄىۄىتأشۄتأۄًأتًشأًۄأطرظأځڬتشأشۄتأۄًأۏتأوذوز$أۏتأوذوز$أتًشأوۏڽأڬۄًڽأوۏڽأتههۄأضەأحوۄۏڽأىۄۏڽأډہڔتأضڬحت؏أوۏڽأىەأحًأځۏؽتوأځۄىډتأزۏتأحہتۗتًشأىۄأڬضۏأطرظأڬًأتضأذتهأوۏڽأځتًٗڽأڬۄأتضأىەأډوڔەأڬتأتۏڬأټڬڔتأتټہتأشڬہتأۄًأتًشأًۄأځڬتشأشۄتأۄًأۏتأوذوز$أۏتأوذوز$أتًشأوۏڽأڬۄًڽأوۏڽأتههۄأضەأحوۄۏڽأىۄۏڽأثډتأضڬحت؏أوۏڽأىەأحًأځۏؽتوأځۄىډتأزۏتأحہت

