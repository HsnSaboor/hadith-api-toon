{"hadithnumber": "690", "arabic": "[690] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ نَافِعٍ، عَنْ أَسْلَمَ مَوْلَی عُمَرَ بْنِ الْخَطَّابِ : أَن", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 19, Hadith 1", "international_number": "690", "narrator_chain": ""}
{"hadithnumber": "691", "arabic": "[691] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ زَیْدِ بْنِ أَسْلَمَ، عَنْ أَبِیہِ، أَ نَّہُ قَالَ لِعُمَرَ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Mauquf Sahih'}", "reference": "Book 19, Hadith 2", "international_number": "691", "narrator_chain": ""}
{"hadithnumber": "692", "arabic": "[692] وَحَدَّثَنِی عَنْ مَالِکٍ، أَ نَّہُ بَلَغَہُ : أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ کَتَبَ إِ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Maqtu Sahih'}", "reference": "Book 19, Hadith 3", "international_number": "692", "narrator_chain": ""}
{"hadithnumber": "693", "arabic": "[693] حَدَّثَنِی یَحْیَی، عَنْ مَالِکٍ، عَنِ ابْنِ شِہَابٍ، عَنْ سَالِمِ بْنِ عَبْدِ اللّٰہِ، عَنْ ا", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Maqtu Daif'}", "reference": "Book 19, Hadith 4", "international_number": "693", "narrator_chain": ""}
{"hadithnumber": "694", "arabic": "[694] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنِ ابْنِ شِہَابٍ، عَنِ السَّائِبِ بْنِ یَزِیدَ، أَ نَّہُ قَالَ:", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Maqtu Sahih'}", "reference": "Book 19, Hadith 5", "international_number": "694", "narrator_chain": ""}
{"hadithnumber": "695", "arabic": "[695] وَحَدَّثَنِی عَنْ مَالِکٍ، أَ نَّہُ سَأَلَ ابْنَ شِہَابٍ، عَلَی أَیِّ وَجْہٍ کَانَ یَأْخُذ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Shadh, Sahih'}", "reference": "Book 19, Hadith 6", "international_number": "695", "narrator_chain": ""}
{"hadithnumber": "696", "arabic": "[696] حَدَّثَنِی یَحْیَی، عَنْ مَالِکٍ، عَنْ زَیْدِ بْنِ أَسْلَمَ، عَنْ أَبِیہِ، أَ نَّہُ قَالَ :", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 19, Hadith 7", "international_number": "696", "narrator_chain": ""}
{"hadithnumber": "697", "arabic": "[697] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ نَافِعٍ، عَنْ عَبْدِ اللّٰہِ بْنِ عُمَرَ، أَنَّ عُمَرَ بْنَ ا", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 19, Hadith 8", "international_number": "697", "narrator_chain": ""}
{"hadithnumber": "698", "arabic": "[698] حَدَّثَنِی یَحْیَی، عَنْ مَالِکٍ، عَنْ نَافِعٍ: أَنَّ عَبْدَ اللّٰہِ بْنَ عُمَرَ کَانَ یُخْرِ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 19, Hadith 9", "international_number": "698", "narrator_chain": ""}
{"hadithnumber": "699", "arabic": "[699] حَدَّثَنِی یَحْیَی، عَنْ مَالِکٍ، عَنْ نَافِعٍ، عَنْ عَبْدِ اللّٰہِ بْنِ عُمَرَ، أَنَّ رَسُول", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 19, Hadith 10", "international_number": "699", "narrator_chain": ""}
{"hadithnumber": "700", "arabic": "[700] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ زَیْدِ بْنِ أَسْلَمَ، عَنْ عِیَاضِ بْنِ عَبْدِ اللّٰہِ بْنِ س", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 19, Hadith 11", "international_number": "700", "narrator_chain": ""}
{"hadithnumber": "701", "arabic": "[701] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ نَافِعٍ : أَنَّ عَبْدَ اللّٰہِ بْنَ عُمَرَ کَانَ لَا یُخْرِجُ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 19, Hadith 12", "international_number": "701", "narrator_chain": ""}
{"hadithnumber": "702", "arabic": "[702] حَدَّثَنِی یَحْیَی، عَنْ مَالِکٍ، عَنْ نَافِعٍ : أَنَّ عَبْدَ اللَّہِ بْنَ عُمَرَ کَانَ یَبْع", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 19, Hadith 13", "international_number": "702", "narrator_chain": ""}
{"hadithnumber": "703", "arabic": "[703] حَدَّثَنِی یَحْیَی، عَنْ مَالِکٍ : لَیْسَ عَلَی الرَّجُلِ فِی عَبِیدِ عَبِیدِہِ، وَلَا فِی أَ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Daif'}", "reference": "Book 19, Hadith 14", "international_number": "703", "narrator_chain": ""}
{"hadithnumber": "704", "arabic": "[704] حَدَّثَنِی یَحْیَی، عَنْ مَالِکٍ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ، عَنْ أَبِیہِ، عَنْ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Maqtu Daif'}", "reference": "Book 19, Hadith 15", "international_number": "704", "narrator_chain": ""}
{"hadithnumber": "717", "arabic": "حَدَّثَنِي يَحْيَى، عَنْ مَالِكٍ، عَنِ ابْنِ شِهَابٍ، عَنْ عُرْوَةَ بْنِ الزُّبَيْرِ، عَنْ عَمْرَةَ بِنْتِ عَبْدِ الرَّحْمَنِ، عَنْ عَائِشَةَ، زَوْجِ النَّبِيِّ صلى الله عليه وسلم أَنَّهَا قَالَتْ كَانَ رَسُولُ اللَّهِ صلى الله عليه وسلم إِذَا اعْتَكَفَ يُدْنِي إِلَىَّ رَأْسَهُ فَأُرَجِّلُهُ وَكَانَ لاَ يَدْخُلُ الْبَيْتَ إِلاَّ لِحَاجَةِ الإِنْسَانِ ‏.‏", "grades": "", "reference": "", "international_number": "717", "narrator_chain": ""}
{"hadithnumber": "718", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنِ ابْنِ شِهَابٍ، عَنْ عَمْرَةَ بِنْتِ عَبْدِ الرَّحْمَنِ، أَنَّ عَائِشَةَ، كَانَتْ إِذَا اعْتَكَفَتْ لاَ تَسْأَلُ عَنِ الْمَرِيضِ إِلاَّ وَهِيَ تَمْشِي لاَ تَقِفُ ‏.‏", "grades": "", "reference": "", "international_number": "718", "narrator_chain": ""}
{"hadithnumber": "719", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، أَنَّهُ سَأَلَ ابْنَ شِهَابٍ عَنِ الرَّجُلِ، يَعْتَكِفُ هَلْ يَدْخُلُ لِحَاجَتِهِ تَحْتَ سَقْفٍ فَقَالَ نَعَمْ لاَ بَأْسَ بِذَلِكَ ‏.‏ قَالَ مَالِكٌ الأَمْرُ عِنْدَنَا الَّذِي لاَ اخْتِلاَفَ فِيهِ أَنَّهُ لاَ يُكْرَهُ الاِعْتِكَافُ فِي كُلِّ مَسْجِدٍ يُجَمَّعُ فِيهِ وَلاَ أُرَاهُ كُرِهَ الاِعْتِكَافُ فِي الْمَسَاجِدِ الَّتِي لاَ يُجَمَّعُ فِيهَا إِلاَّ كَرَاهِيَةَ أَنْ يَخْرُجَ الْمُعْتَكِفُ مِنْ مَسْجِدِهِ الَّذِي اعْتَكَفَ فِيهِ إِلَى الْجُمُعَةِ أَوْ يَدَعَهَا فَإِنْ كَانَ مَسْجِدًا لاَ يُجَمَّعُ فِيهِ الْجُمُعَةُ وَلاَ يَجِبُ عَلَى صَاحِبِهِ إِتْيَانُ الْجُمُعَةِ فِي مَسْجِدٍ سِوَاهُ فَإِنِّي لاَ أَرَى بَأْسًا بِالاِعْتِكَافِ فِيهِ لأَنَّ اللَّهَ تَبَارَكَ وَتَعَالَى قَالَ ‏{‏وَأَنْتُمْ عَاكِفُونَ فِي الْمَسَاجِدِ‏}‏ فَعَمَّ اللَّهُ الْمَسَاجِدَ كُلَّهَا وَلَمْ يَخُصَّ شَيْئًا مِنْهَا ‏.‏ قَالَ مَالِكٌ فَمِنْ هُنَالِكَ جَازَ لَهُ أَنْ يَعْتَكِفَ فِي الْمَسَاجِدِ الَّتِي لاَ يُجَمَّعُ فِيهَا الْجُمُعَةُ إِذَا كَانَ لاَ يَجِبُ عَلَيْهِ أَنْ يَخْرُجَ مِنْهُ إِلَى الْمَسْجِدِ الَّذِي تُجَمَّعُ فِيهِ الْجُمُعَةُ ‏.‏ قَالَ مَالِكٌ وَلاَ يَبِيتُ الْمُعْتَكِفُ إِلاَّ فِي الْمَسْجِدِ الَّذِي اعْتَكَفَ فِيهِ إِلاَّ أَنْ يَكُونَ خِبَاؤُهُ فِي رَحَبَةٍ مِنْ رِحَابِ الْمَسْجِدِ وَلَمْ أَسْمَعْ أَنَّ الْمُعْتَكِفَ يَضْرِبُ بِنَاءً يَبِيتُ فِيهِ إِلاَّ فِي الْمَسْجِدِ أَوْ فِي رَحَبَةٍ مِنْ رِحَابِ الْمَسْجِدِ وَمِمَّا يَدُلُّ عَلَى أَنَّهُ لاَ يَبِيتُ إِلاَّ فِي الْمَسْجِدِ قَوْلُ عَائِشَةَ كَانَ رَسُولُ اللَّهِ صلى الله عليه وسلم إِذَا اعْتَكَفَ لاَ يَدْخُلُ الْبَيْتَ إِلاَّ لِحَاجَةِ الإِنْسَانِ ‏.‏ وَلاَ يَعْتَكِفُ فَوْقَ ظَهْرِ الْمَسْجِدِ وَلاَ فِي الْمَنَارِ يَعْنِي الصَّوْمَعَةَ ‏.‏ وَقَالَ مَالِكٌ يَدْخُلُ الْمُعْتَكِفُ الْمَكَانَ الَّذِي يُرِيدُ أَنْ يَعْتَكِفَ فِيهِ قَبْلَ غُرُوبِ الشَّمْسِ مِنَ اللَّيْلَةِ الَّتِي يُرِيدُ أَنْ يَعْتَكِفَ فِيهَا حَتَّى يَسْتَقْبِلَ بِاعْتِكَافِهِ أَوَّلَ اللَّيْلَةِ الَّتِي يُرِيدُ أَنْ يَعْتَكِفَ فِيهَا وَالْمُعْتَكِفُ مُشْتَغِلٌ بِاعْتِكَافِهِ لاَ يَعْرِضُ لِغَيْرِهِ مِمَّا يَشْتَغِلُ بِهِ مِنَ التِّجَارَاتِ أَوْ غَيْرِهَا وَلاَ بَأْسَ بِأَنْ يَأْمُرَ الْمُعْتَكِفُ بِبَعْضِ حَاجَتِهِ بِضَيْعَتِهِ وَمَصْلَحَةِ أَهْلِهِ وَأَنْ يَأْمُرَ بِبَيْعِ مَالِهِ أَوْ بِشَىْءٍ لاَ يَشْغَلُهُ فِي نَفْسِهِ فَلاَ بَأْسَ بِذَلِكَ إِذَا كَانَ خَفِيفًا أَنْ يَأْمُرَ بِذَلِكَ مَنْ يَكْفِيهِ إِيَّاهُ ‏.‏ قَالَ مَالِكٌ لَمْ أَسْمَعْ أَحَدًا مِنْ أَهْلِ الْعِلْمِ يَذْكُرُ فِي الاِعْتِكَافِ شَرْطًا وَإِنَّمَا الاِعْتِكَافُ عَمَلٌ مِنَ الأَعْمَالِ مِثْلُ الصَّلاَةِ وَالصِّيَامِ وَالْحَجِّ وَمَا أَشْبَهَ ذَلِكَ مِنَ الأَعْمَالِ مَا كَانَ مِنْ ذَلِكَ فَرِيضَةً أَوْ نَافِلَةً فَمَنْ دَخَلَ فِي شَىْءٍ مِنْ ذَلِكَ فَإِنَّمَا يَعْمَلُ بِمَا مَضَى مِنَ السُّنَّةِ وَلَيْسَ لَهُ أَنْ يُحْدِثَ فِي ذَلِكَ غَيْرَ مَا مَضَى عَلَيْهِ الْمُسْلِمُونَ لاَ مِنْ شَرْطٍ يَشْتَرِطُهُ وَلاَ يَبْتَدِعُهُ وَقَدِ اعْتَكَفَ رَسُولُ اللَّهِ صلى الله عليه وسلم وَعَرَفَ الْمُسْلِمُونَ سُنَّةَ الاِعْتِكَافِ ‏.‏ قَالَ مَالِكٌ وَالاِعْتِكَافَ وَالْجِوَارُ سَوَاءٌ وَالاِعْتِكَافُ لِلْقَرَوِيِّ وَالْبَدَوِيِّ سَوَاءٌ ‏.‏", "grades": "", "reference": "", "international_number": "719", "narrator_chain": ""}
{"hadithnumber": "720", "arabic": "حَدَّثَنِي يَحْيَى، عَنْ مَالِكٍ، أَنَّهُ بَلَغَهُ أَنَّ الْقَاسِمَ بْنَ مُحَمَّدٍ، وَنَافِعًا، مَوْلَى عَبْدِ اللَّهِ بْنِ عُمَرَ قَالاَ لاَ اعْتِكَافَ إِلاَّ بِصِيَامٍ بِقَوْلِ اللَّهِ تَبَارَكَ وَتَعَالَى فِي كِتَابِهِ ‏{‏وَكُلُوا وَاشْرَبُوا حَتَّى يَتَبَيَّنَ لَكُمُ الْخَيْطُ الأَبْيَضُ مِنَ الْخَيْطِ الأَسْوَدِ مِنَ الْفَجْرِ ثُمَّ أَتِمُّوا الصِّيَامَ إِلَى اللَّيْلِ وَلاَ تُبَاشِرُوهُنَّ وَأَنْتُمْ عَاكِفُونَ فِي الْمَسَاجِدِ‏}‏ فَإِنَّمَا ذَكَرَ اللَّهُ الاِعْتِكَافَ مَعَ الصِّيَامِ ‏.‏ قَالَ مَالِكٌ وَعَلَى  ذَلِكَ الأَمْرُ عِنْدَنَا أَنَّهُ لاَ اعْتِكَافَ إِلاَّ بِصِيَامٍ ‏.‏", "grades": "", "reference": "", "international_number": "720", "narrator_chain": ""}
{"hadithnumber": "721", "arabic": "حَدَّثَنِي يَحْيَى، عَنْ زِيَادِ بْنِ عَبْدِ الرَّحْمَنِ، قَالَ حَدَّثَنَا مَالِكٌ، عَنْ سُمَىٍّ، مَوْلَى أَبِي بَكْرِ بْنِ عَبْدِ الرَّحْمَنِ أَنَّ أَبَا بَكْرِ بْنَ عَبْدِ الرَّحْمَنِ، اعْتَكَفَ فَكَانَ يَذْهَبُ لِحَاجَتِهِ تَحْتَ سَقِيفَةٍ فِي حُجْرَةٍ مُغْلَقَةٍ فِي دَارِ خَالِدِ بْنِ الْوَلِيدِ ثُمَّ لاَ يَرْجِعُ حَتَّى يَشْهَدَ الْعِيدَ مَعَ الْمُسْلِمِينَ ‏.", "grades": "", "reference": "", "international_number": "721", "narrator_chain": ""}
{"hadithnumber": "722", "arabic": "حَدَّثَنِي يَحْيَى عَنْ زِيَادٍ عَنْ مَالِكٍ أَنَّهُ رَأَى بَعْضَ أَهْلِ الْعِلْمِ إِذَا اعْتَكَفُوا الْعَشْرَ الأَوَاخِرَ مِنْ رَمَضَانَ لاَ يَرْجِعُونَ إِلَى أَهَالِيهِمْ حَتَّى يَشْهَدُوا الْفِطْرَ مَعَ النَّاسِ ‏.‏ قَالَ زِيَادٌ قَالَ مَالِكٌ وَبَلَغَنِي ذَلِكَ عَنْ أَهْلِ الْفَضْلِ الَّذِينَ مَضَوْا وَهَذَا أَحَبُّ مَا سَمِعْتُ إِلَىَّ فِي ذَلِكَ ‏.", "grades": "", "reference": "", "international_number": "722", "narrator_chain": ""}
{"hadithnumber": "723", "arabic": "حَدَّثَنِي زِيَادٌ، عَنْ مَالِكٍ، عَنِ ابْنِ شِهَابٍ، عَنْ عَمْرَةَ بِنْتِ عَبْدِ الرَّحْمَنِ، عَنْ عَائِشَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم أَرَادَ أَنْ يَعْتَكِفَ فَلَمَّا انْصَرَفَ إِلَى الْمَكَانِ الَّذِي أَرَادَ أَنْ يَعْتَكِفَ فِيهِ وَجَدَ أَخْبِيَةً خِبَاءَ عَائِشَةَ وَخِبَاءَ حَفْصَةَ وَخِبَاءَ زَيْنَبَ فَلَمَّا رَآهَا سَأَلَ عَنْهَا فَقِيلَ لَهُ هَذَا خِبَاءُ عَائِشَةَ وَحَفْصَةَ وَزَيْنَبَ ‏.‏ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ آلْبِرَّ تَقُولُونَ بِهِنَّ ‏\"\"‏ ‏.‏ ثُمَّ انْصَرَفَ فَلَمْ يَعْتَكِفْ حَتَّى اعْتَكَفَ عَشْرًا مِنْ شَوَّالٍ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "724", "arabic": "[724] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ نَافِعٍ، عَنْ أَسْلَمَ مَوْلَی عُمَرَ بْنِ الْخَطَّابِ : أَن", "grades": "", "reference": "", "international_number": "724", "narrator_chain": ""}
{"hadithnumber": "725", "arabic": "وَحَدَّثَنِي زِيَادٌ، عَنْ مَالِكٍ، عَنِ ابْنِ شِهَابٍ، ‏.‏ أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم كَانَ يَذْهَبُ لِحَاجَةِ الإِنْسَانِ فِي الْبُيُوتِ ‏.‏ قَالَ مَالِكٌ لاَ يَخْرُجُ الْمُعْتَكِفُ مَعَ جَنَازَةِ أَبَوَيْهِ وَلاَ مَعَ غَيْرِهَا ‏.‏", "grades": "", "reference": "", "international_number": "725", "narrator_chain": ""}
{"hadithnumber": "726", "arabic": "[726] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ یَحْیَی بْنِ سَعِیدٍ، وَعَبْدِ اللّٰہِ بْنِ أبِی بَکْرٍ، وَرَ", "grades": "", "reference": "", "international_number": "726", "narrator_chain": ""}
{"hadithnumber": "727", "arabic": "حَدَّثَنِي زِيَادٌ، عَنْ مَالِكٍ، عَنْ يَزِيدَ بْنِ عَبْدِ اللَّهِ بْنِ الْهَادِ، عَنْ مُحَمَّدِ بْنِ إِبْرَاهِيمَ بْنِ الْحَارِثِ التَّيْمِيِّ، عَنْ أَبِي سَلَمَةَ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ أَبِي سَعِيدٍ الْخُدْرِيِّ، أَنَّهُ قَالَ كَانَ رَسُولُ اللَّهِ صلى الله عليه وسلم يَعْتَكِفُ الْعَشْرَ الْوُسُطَ مِنْ رَمَضَانَ فَاعْتَكَفَ عَامًا حَتَّى إِذَا كَانَ لَيْلَةَ إِحْدَى وَعِشْرِينَ وَهِيَ اللَّيْلَةُ الَّتِي يَخْرُجُ فِيهَا مِنْ صُبْحِهَا مِنَ اعْتِكَافِهِ قَالَ ‏ ‏ مَنِ اعْتَكَفَ مَعِي فَلْيَعْتَكِفِ الْعَشْرَ الأَوَاخِرَ وَقَدْ رَأَيْتُ هَذِهِ اللَّيْلَةَ ثُمَّ أُنْسِيتُهَا وَقَدْ رَأَيْتُنِي أَسْجُدُ مِنْ صُبْحِهَا فِي مَاءٍ وَطِينٍ فَالْتَمِسُوهَا فِي الْعَشْرِ الأَوَاخِرِ وَالْتَمِسُوهَا فِي كُلِّ وِتْرٍ ‏\"\"‏ ‏.‏ قَالَ أَبُو سَعِيدٍ فَأُمْطِرَتِ السَّمَاءُ تِلْكَ اللَّيْلَةَ وَكَانَ الْمَسْجِدُ عَلَى عَرِيشٍ فَوَكَفَ الْمَسْجِدُ - قَالَ أَبُو سَعِيدٍ - فَأَبْصَرَتْ عَيْنَاىَ رَسُولَ اللَّهِ صلى الله عليه وسلم انْصَرَفَ وَعَلَى جَبْهَتِهِ وَأَنْفِهِ أَثَرُ الْمَاءِ وَالطِّينِ مِنْ صُبْحِ لَيْلَةِ إِحْدَى وَعِشْرِينَ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "728", "arabic": "وَحَدَّثَنِي زِيَادٌ، عَنْ مَالِكٍ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ أَبِيهِ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ تَحَرَّوْا لَيْلَةَ الْقَدْرِ فِي الْعَشْرِ الأَوَاخِرِ مِنْ رَمَضَانَ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "729", "arabic": "وَحَدَّثَنِي زِيَادٌ، عَنْ مَالِكٍ، عَنْ عَبْدِ اللَّهِ بْنِ دِينَارٍ، عَنْ عَبْدِ اللَّهِ بْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ تَحَرَّوْا لَيْلَةَ الْقَدْرِ فِي السَّبْعِ الأَوَاخِرِ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "730", "arabic": "وَحَدَّثَنِي زِيَادٌ، عَنْ مَالِكٍ، عَنْ أَبِي النَّضْرِ، مَوْلَى عُمَرَ بْنِ عُبَيْدِ اللَّهِ أَنَّ عَبْدَ اللَّهِ بْنَ أُنَيْسٍ الْجُهَنِيَّ، قَالَ لِرَسُولِ اللَّهِ صلى الله عليه وسلم يَا رَسُولَ اللَّهِ إِنِّي رَجُلٌ شَاسِعُ الدَّارِ فَمُرْنِي لَيْلَةً أَنْزِلُ لَهَا ‏.‏ فَقَالَ لَهُ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ انْزِلْ لَيْلَةَ ثَلاَثٍ وَعِشْرِينَ مِنْ رَمَضَانَ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "731", "arabic": "وَحَدَّثَنِي زِيَادٌ، عَنْ مَالِكٍ، عَنْ حُمَيْدٍ الطَّوِيلِ، عَنْ أَنَسِ بْنِ مَالِكٍ، أَنَّهُ قَالَ خَرَجَ عَلَيْنَا رَسُولُ اللَّهِ صلى الله عليه وسلم فِي رَمَضَانَ فَقَالَ ‏ ‏ إِنِّي أُرِيتُ هَذِهِ اللَّيْلَةَ فِي رَمَضَانَ حَتَّى تَلاَحَى رَجُلاَنِ فَرُفِعَتْ فَالْتَمِسُوهَا فِي التَّاسِعَةِ وَالسَّابِعَةِ وَالْخَامِسَةِ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "732", "arabic": "وَحَدَّثَنِي زِيَادٌ، عَنْ مَالِكٍ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ رِجَالاً، مِنْ أَصْحَابِ رَسُولِ اللَّهِ صلى الله عليه وسلم أُرُوا لَيْلَةَ الْقَدْرِ فِي الْمَنَامِ فِي السَّبْعِ الأَوَاخِرِ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ إِنِّي أَرَى رُؤْيَاكُمْ قَدْ تَوَاطَأَتْ فِي السَّبْعِ الأَوَاخِرِ فَمَنْ كَانَ مُتَحَرِّيَهَا فَلْيَتَحَرَّهَا فِي السَّبْعِ الأَوَاخِرِ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "733", "arabic": "وَحَدَّثَنِي زِيَادٌ، عَنْ مَالِكٍ، أَنَّهُ سَمِعَ مَنْ، يَثِقُ بِهِ مِنْ أَهْلِ الْعِلْمِ يَقُولُ إِنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم أُرِيَ أَعْمَارَ النَّاسِ قَبْلَهُ أَوْ مَا شَاءَ اللَّهُ مِنْ ذَلِكَ فَكَأَنَّهُ تَقَاصَرَ أَعْمَارَ أُمَّتِهِ أَنْ لاَ يَبْلُغُوا مِنَ الْعَمَلِ مِثْلَ الَّذِي بَلَغَ غَيْرُهُمْ فِي طُولِ الْعُمْرِ فَأَعْطَاهُ اللَّهُ لَيْلَةَ الْقَدْرِ خَيْرٌ مِنْ أَلْفِ شَهْرٍ ‏.‏", "grades": "", "reference": "", "international_number": "733", "narrator_chain": ""}
{"hadithnumber": "734", "arabic": "وَحَدَّثَنِي زِيَادٌ، عَنْ مَالِكٍ، أَنَّهُ بَلَغَهُ أَنَّ سَعِيدَ بْنَ الْمُسَيَّبِ، كَانَ يَقُولُ مَنْ شَهِدَ الْعِشَاءَ مِنْ لَيْلَةِ الْقَدْرِ فَقَدْ أَخَذَ بِحَظِّهِ مِنْهَا ‏.‏", "grades": "", "reference": "", "international_number": "734", "narrator_chain": ""}
