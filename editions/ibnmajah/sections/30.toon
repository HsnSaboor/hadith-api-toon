{"hadithnumber": "3415", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا غُنْدَرٌ،‏‏‏‏ عَنْ شُعْبَةَ،‏‏‏‏ عَنْ سَ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 30, Hadith 45", "international_number": "3415", "narrator_chain": ""}
{"hadithnumber": "3416", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا ابْنُ مَهْدِيٍّ،‏‏‏‏ حَدَّثَنَا عَزْرَةُ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 30, Hadith 46", "international_number": "3416", "narrator_chain": ""}
{"hadithnumber": "3417", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ،‏‏‏‏ وَمُحَمَّدُ بْنُ الصَّبَّاحِ،‏‏‏‏ قَالَا:‏‏‏‏ حَدَّثَنَا مَرْو", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 30, Hadith 47", "international_number": "3417", "narrator_chain": ""}
{"hadithnumber": "3418", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ عَمْرِو بْنِ السَّرْحِ،‏‏‏‏ حَدَّثَنَا ابْنُ وَهْبٍ،‏‏‏‏ عَنْ يُونُسَ،‏‏‏‏", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 30, Hadith 48", "international_number": "3418", "narrator_chain": ""}
{"hadithnumber": "3419", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ،‏‏‏‏ حَدَّثَنَا أَبُو عَامِرٍ،‏‏‏‏ حَدَّثَنَا زَمْعَةُ بْنُ صَالِ", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 30, Hadith 49", "international_number": "3419", "narrator_chain": ""}
{"hadithnumber": "3420", "arabic": "حَدَّثَنَا بِشْرُ بْنُ هِلَالٍ الصَّوَّافُ،‏‏‏‏ حَدَّثَنَا عَبْدُ الْوَارِثِ بْنُ سَعِيدٍ،‏‏‏‏ عَنْ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Bukhari'}", "reference": "Book 30, Hadith 50", "international_number": "3420", "narrator_chain": ""}
