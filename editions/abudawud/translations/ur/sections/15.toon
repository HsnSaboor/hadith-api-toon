{"hadithnumber": "2529", "text": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  ایک آدمی نبی اکرم صلی اللہ علیہ وسلم کے پاس آیا اور کہنے"}
{"hadithnumber": "2530", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  ایک آدمی رسول اللہ صلی اللہ علیہ وسلم کے پاس یمن سے ہجرت کر"}
{"hadithnumber": "2531", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ام سلیم رضی اللہ عنہا کو اور انصار کی کچھ"}
{"hadithnumber": "2532", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تین باتیں ایمان کی اص"}
{"hadithnumber": "2533", "text": "ابوہریرہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جہاد تم پر ہر امیر کے"}
{"hadithnumber": "2534", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے جہاد کا ارادہ کیا تو فرم"}
{"hadithnumber": "2535", "text": "ضمرہ کا بیان ہے کہ ابن زغب ایادی نے ان سے بیان کیا کہ  عبداللہ بن حوالہ ازدی رضی اللہ عنہ میرے پاس ا"}
{"hadithnumber": "2536", "text": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ہمارا رب اس شخص"}
{"hadithnumber": "2537", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  عمرو بن اقیش رضی اللہ عنہ کا جاہلیت میں کچھ سود  ( وصول کرنا )"}
{"hadithnumber": "2538", "text": "سلمہ بن الاکوع رضی اللہ عنہ کہتے ہیں کہ  جب جنگ خیبر ہوئی تو میرے بھائی بڑی شدت سے لڑے، ان کی تلوار"}
{"hadithnumber": "2539", "text": "ابو سلام ایک صحابی سے روایت کرتے ہوئے کہتے ہیں کہ  ہم نے جہینہ کے ایک قبیلہ پر شب خون مارا تو ایک مس"}
{"hadithnumber": "2540", "text": "سہل بن سعد رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  دو  ( وقت کی )  دعائیں"}
{"hadithnumber": "2541", "text": "معاذ بن جبل رضی اللہ عنہ کہتے ہیں کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا:  جس"}
{"hadithnumber": "2542", "text": "عتبہ بن عبدسلمی رضی اللہ عنہ کہتے ہیں کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا:"}
{"hadithnumber": "2543", "text": "ابو وہب جشمی سے روایت ہے  اور انہیں اللہ کے رسول صلی اللہ علیہ وسلم کی صحبت حاصل تھی، وہ کہتے ہیں کہ"}
{"hadithnumber": "2544", "text": "ابو وہب رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم اپنے اوپر ہر سرخ سفید"}
{"hadithnumber": "2545", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  گھوڑے کی برکت س"}
{"hadithnumber": "2546", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم گھوڑے کی مادہ کو بھی «فرس» کا نام"}
{"hadithnumber": "2547", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم گھوڑے میں «شکال» کو ناپسند فرماتے تھے"}
{"hadithnumber": "2548", "text": "سہل بن حنظلیہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ایک ایسے اونٹ کے پاس سے گزرے جس"}
{"hadithnumber": "2549", "text": "عبداللہ بن جعفر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مجھے ایک دن اپنے پیچھے س"}
{"hadithnumber": "2550", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ایک آدمی کسی راستہ پہ"}
{"hadithnumber": "2551", "text": "حمزہ ضبی کہتے ہیں کہ  میں نے انس بن مالک رضی اللہ عنہ کو کہتے سنا کہ ہم کسی جگہ اترتے تو نماز نہ پڑھ"}
{"hadithnumber": "2552", "text": "ابوبشیر انصاری رضی اللہ عنہ کہتے ہیں کہ  وہ رسول اللہ صلی اللہ علیہ وسلم کے ساتھ ایک سفر میں تھے تو"}
{"hadithnumber": "2553", "text": "ابو وہب جشمی رضی اللہ عنہ سے روایت ہے  انہیں  ( اللہ کے رسول صلی اللہ علیہ وسلم کی )  صحبت حاصل تھی"}
{"hadithnumber": "2554", "text": "ام المؤمنین ام حبیبہ رضی اللہ عنہا نبی اکرم صلی اللہ علیہ وسلم سے روایت کرتی ہیں کہ  آپ نے فرمایا:"}
{"hadithnumber": "2555", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:   ( رحمت کے فرشتے )  اس ج"}
{"hadithnumber": "2556", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے گھنٹی کے بارے میں فرمایا:  وہ شیطا"}
{"hadithnumber": "2557", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  گندگی کھانے والے جانور کی سواری سے منع کیا گیا ہے۔"}
{"hadithnumber": "2558", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے گندگی کھانے والے اونٹوں ک"}
{"hadithnumber": "2559", "text": "معاذ رضی اللہ عنہ کہتے ہیں کہ  میں ایک گدھے پر رسول اللہ صلی اللہ علیہ وسلم کے پیچھے سوار تھا جس کو"}
{"hadithnumber": "2560", "text": "سمرہ بن جندب رضی اللہ عنہ سے روایت ہے  وہ حمد و صلاۃ کے بعد کہتے ہیں کہ نبی اکرم صلی اللہ علیہ وسلم"}
{"hadithnumber": "2561", "text": "عمران بن حصین رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم ایک سفر میں تھے، آپ نے لعنت"}
{"hadithnumber": "2562", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے جانوروں کو باہم لڑانے سے"}
{"hadithnumber": "2563", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  میں اپنے بھائی کی پیدائش پر اس کو نبی اکرم صلی اللہ علیہ وسلم"}
{"hadithnumber": "2564", "text": "جابر رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم کے پاس سے ایک گدھا گزرا جس کے چہرہ کو"}
{"hadithnumber": "2565", "text": "علی بن ابی طالب رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کو ایک خچر ہدیہ میں دیا گیا ت"}
{"hadithnumber": "2566", "text": "عبداللہ بن جعفر رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم جب سفر سے آتے تو ہم لوگ آپ ک"}
{"hadithnumber": "2567", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  اپنے جانوروں کی پیٹھ ک"}
{"hadithnumber": "2568", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  کچھ اونٹ ۱؎ شیطانوں کے ہ"}
{"hadithnumber": "2569", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  سرسبز علاقوں میں سفر کرو"}
{"hadithnumber": "2570", "text": "جابر بن عبداللہ رضی اللہ عنہما نے بھی  نبی اکرم صلی اللہ علیہ وسلم سے ایسی ہی روایت کی ہے، مگر اس می"}
{"hadithnumber": "2571", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  رات کے آخری حصہ میں سفر کرنے"}
{"hadithnumber": "2572", "text": "بریدہ رضی اللہ عنہ کہتے ہیں  رسول اللہ صلی اللہ علیہ وسلم چل رہے تھے کہ اسی دوران ایک آدمی آیا اور ا"}
{"hadithnumber": "2573", "text": "عباد بن عبداللہ بن زبیر کہتے ہیں کہ  میرے رضاعی والد نے جو بنی مرہ بن عوف میں سے تھے مجھ سے بیان کیا"}
{"hadithnumber": "2574", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مقابلہ میں بازی رکھنا جا"}
{"hadithnumber": "2575", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے پھرتیلے چھریرے بدن وال"}
{"hadithnumber": "2576", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  اللہ کے نبی اکرم صلی اللہ علیہ وسلم گھوڑ دوڑ کے لیے گھ"}
{"hadithnumber": "2577", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے گھوڑ دوڑ کا مقابلہ کرا"}
{"hadithnumber": "2578", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  وہ نبی اکرم صلی اللہ علیہ وسلم کے ساتھ ایک سفر میں ت"}
{"hadithnumber": "2579", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جو شخص دو گھوڑوں کے در"}
{"hadithnumber": "2580", "text": "اس سند سے بھی زہری سے عباد والے طریق ہی سے اسی مفہوم کی حدیث مروی ہے  ابوداؤد کہتے ہیں: اسے معمر، شع"}
{"hadithnumber": "2581", "text": "عمران بن حصین رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:   «جلب» اور «جنب"}
{"hadithnumber": "2582", "text": "قتادہ رضی اللہ عنہ سے روایت ہے، انہوں نے کہا  «جلب» اور «جنب» ۱؎ گھوڑ دوڑ کے مقابلہ میں ہوتا ہے۔"}
{"hadithnumber": "2583", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کی تلوار کے قبضہ کی خول چاندی کی تھی۔"}
{"hadithnumber": "2584", "text": "(حسن بصری کے بھائی) سعید بن ابوالحسن کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کی تلوار کے دستہ کی خ"}
{"hadithnumber": "2585", "text": "اس سند سے انس بن مالک رضی اللہ عنہ سے سابقہ حدیث مروی ہے  ابوداؤد کہتے ہیں: ان احادیث میں سب سے زیاد"}
{"hadithnumber": "2586", "text": "جابر رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک شخص کو حکم دیا جو مسجد میں تیر"}
{"hadithnumber": "2587", "text": "ابوموسیٰ اشعری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب کوئی شخص ہماری"}
{"hadithnumber": "2588", "text": "جابر رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے ننگی تلوار  ( کسی کو )  تھمانے سے م"}
{"hadithnumber": "2589", "text": "سمرہ بن جندب رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے چمڑے کو دو انگلیوں کے درمی"}
{"hadithnumber": "2590", "text": "سائب بن یزید رضی اللہ عنہ ایک ایسے آدمی سے روایت کرتے ہیں  جس کا انہوں نے نام لیا تھا کہ رسول اللہ ص"}
{"hadithnumber": "2591", "text": "محمد بن قاسم کے غلام یونس بن عبید کہتے ہیں کہ  محمد بن قاسم نے مجھے براء بن عازب رضی اللہ عنہ کے پاس"}
{"hadithnumber": "2592", "text": "جابر رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم جس دن مکہ میں داخل ہوئے آپ کا پرچم سفی"}
{"hadithnumber": "2593", "text": "سماک اپنی قوم کے ایک آدمی سے روایت کرتے ہیں اور اس نے انہیں میں سے ایک دوسرے شخص سے روایت کیا، وہ کہ"}
{"hadithnumber": "2594", "text": "ابوالدرداء رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا:  میرے ل"}
{"hadithnumber": "2595", "text": "سمرہ بن جندب رضی اللہ عنہ کہتے ہیں کہ  مہاجرین کا شعار  ( کوڈ )  ۱؎  عبداللہ  اور انصار کا شعار  عبد"}
{"hadithnumber": "2596", "text": "سلمہ بن الاکوع رضی اللہ عنہ کہتے ہیں کہ  ہم نے ابوبکر رضی اللہ عنہ کے ساتھ نبی اکرم صلی اللہ علیہ وس"}
{"hadithnumber": "2597", "text": "مہلب بن ابی صفرہ کہتے ہیں کہ  مجھے اس شخص نے خبر دی ہے جس نے نبی اکرم صلی اللہ علیہ وسلم کو فرماتے ہ"}
{"hadithnumber": "2598", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  اللہ کے رسول صلی اللہ علیہ وسلم جب سفر کرتے تو یہ دعا پڑھتے: «الل"}
{"hadithnumber": "2599", "text": "علی ازدی کہتے ہیں کہ ابن عمر رضی اللہ عنہما نے انہیں سکھایا کہ  رسول اللہ صلی اللہ علیہ وسلم سفر میں"}
{"hadithnumber": "2600", "text": "قزعہ کہتے ہیں کہ  مجھ سے ابن عمر رضی اللہ عنہما نے کہا: آؤ میں تمہیں اسی طرح رخصت کروں جیسا کہ رسول"}
{"hadithnumber": "2601", "text": "عبداللہ خطمی رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم جب لشکر کو رخصت کرنے کا ارادہ کرت"}
{"hadithnumber": "2602", "text": "علی بن ربیعہ رضی اللہ عنہ کہتے ہیں کہ  میں علی رضی اللہ عنہ کے پاس حاضر ہوا، آپ کے لیے ایک سواری لائ"}
{"hadithnumber": "2603", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم جب سفر کرتے اور رات ہو جاتی"}
{"hadithnumber": "2604", "text": "جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب سورج ڈوب جائے تو اپنے جان"}
{"hadithnumber": "2605", "text": "کعب بن مالک رضی اللہ عنہ کہتے ہیں کہ  بہت کم ایسا ہوتا کہ رسول اللہ صلی اللہ علیہ وسلم جمعرات کے علا"}
{"hadithnumber": "2606", "text": "صخر غامدی رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: «اللهم بارك لأمتي في بكور"}
{"hadithnumber": "2607", "text": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ایک سوار شیطان"}
{"hadithnumber": "2608", "text": "ابو سعید خدری رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تین افراد کسی"}
{"hadithnumber": "2609", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تین افراد کسی سفر"}
