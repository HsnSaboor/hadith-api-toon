{"metadata":{"name":"Sunan Ibn Majah","section":{"7":"Fasting"},"section_detail":{"7":{"hadithnumber_first":1638,"hadithnumber_last":1782,"arabicnumber_first":1638,"arabicnumber_last":1782}}},"hadiths":[{"hadithnumber":1684,"arabicnumber":1684,"text":"Rapporté par ‘Aishah : Le Messager d’Allah (ﷺ) embrassait alors qu’il jeûnait, et qui parmi vous peut contrôler son désir comme le Messager d’Allah (ﷺ) le faisait ?","grades":[{"name":"Al-Albani","grade":"Sahih"},{"name":"Muhammad Fouad Abd al-Baqi","grade":"Sahih"},{"name":"Shuaib Al Arnaut","grade":"Sahih"},{"name":"Zubair Ali Zai","grade":"Sahih Muslim"}],"reference":{"book":7,"hadith":47}}]}