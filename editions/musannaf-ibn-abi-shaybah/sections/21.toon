hadiths[1395]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}:
27261,"حَدَّثَنَا أَبُو عَبْدِ الرَّحْمَنِ بَقِیُّ بْنُ مَخْلَدٍ قَالَ : حدَّثَنَا أَبُو بَکْرٍ عَبْدُ اللہِ بْنُ مُحَمَّدِ بْنِ أَبِی شَیْبَۃَ الْعَبْسِیُّ قَالَ:\n\n حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَن عِکْرِمَۃَ قَالَ : قَضَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لِرَجُلٍ مِنَ الأَنْصَارِ قَتَلَہُ مَوْلَی بَنِی عَدِیٍّ بِالدِّیَۃِ اثْنَیْ عَشَرَ أَلْفًا ، وَفِیہِمْ نَزَلَتْ : {وَمَا نَقَمُوا إِلاَّ أَنْ أَغْنَاہُمُ اللَّہُ وَرَسُولُہُ مِنْ فَضْلِہِ}۔ (ابوداؤد 4534۔ ترمذی 1388)",,,27261,,
27262,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَیُّوبَ بْنِ مُوسَی ، عَنْ مَکْحُولٍ قَالَ : تُوُفِّیَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَالدِّیَۃُ ثَمَانُ مِئَۃِ دِینَارٍ ، فَخَشِیَ عُمَرُ مِنْ بَعْدِہِ ، فَجَعَلَہَا اثْنَیْ عَشَرَ أَلْفَ دِرْہَمٍ ، أَوْ أَلْفَ دِینَارٍ۔",,,27262,,
27263,"حَدَّثَنَا وَکِیعٌ ، قَالَ: حَدَّثَنَا ابْنُ أَبِی لَیْلَی ، عَنِ الشَّعْبِیِّ ، عَنْ عَبِیدَۃَ السَّلْمَانِیِّ قَالَ: وَضَعَ عُمَرُ الدِّیَاتِ، فَوَضَعَ عَلَی أَہْلِ الذَّہَبِ أَلْفَ دِینَارٍ ، وَعَلَی أَہْلِ الْوَرِقِ عَشَرَۃَ آلاَفٍ ، وَعَلَی أَہْلِ الإِبِلِ مِئَۃ مِنَ الإِبِلِ ، وَعَلَی أَہْلِ الْبَقَرِ مِئَتَیْ بَقَرَۃٍ مُسِنَّۃٍ ، وَعَلَی أَہْلِ الشَّاۃِ أَلْفَیْ شَاۃٍ ، وَعَلَی أَہْلِ الْحُلَلِ مِئَتَیْ حُلَّۃٍ۔",,,27263,,
27264,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ عَطَائٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَضَعَ الدِّیَۃَ عَلَی النَّاسِ فِی أَمْوَالِہِمْ مَا کَانَتْ : عَلَی أَہْلِ الإِبِلِ مِئَۃ بَعِیرٍ ، وَعَلَی أَہْلِ الشَّاۃِ أَلْفَیْ شَاۃٍ ، وَعَلَی أَہْلِ الْبَقَرِ مِئَتَیْ بَقَرَۃٍ ، وَعَلَی أَہْلِ الْبُرُودِ مِئَتَیْ حُلَّۃٍ ، قَالَ : وَقَدْ جَعَلَ عَلَی أَہْلِ الطَّعَامِ شَیْئًا لاَ أَحْفَظُہُ۔ (ابوداؤد 4531)",,,27264,,
27265,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو قَالَ : کَتَبَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ إِلَی أُمَرَائِ الأَجْنَادِ : إِنَّ الدِّیَۃَ کَانَتْ عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِئَۃَ بَعِیرٍ۔",,,27265,,
27266,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : دِیَۃُ الْخَطَأِ مِئَۃ بَعِیرٍ ، فَمَنْ زَادَ بَعِیرًا فَہُوَ مِنْ أَمْرِ الْجَاہِلِیَّۃِ۔",,,27266,,
27267,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ؛ أَنَّہُ جَعَلَ الدِّیَۃَ مِئَۃَ بَعِیرٍ ، وَقَوَّمَ کُلَّ بَعِیرٍ مِئَۃ ، غَلَتْ ، أَوْ رَخُصَتْ ، فَأَخَذَ النَّاسُ بِہَا۔,,,27267,,
27268,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ أَبِی خَالِدٍ ، عَنْ عَامِرٍ ، عَنْ عَلِیٍّ ، وَعَبْدِ اللہِ ، وَزَیْدٍ ؛ أَنَّہُمْ قَالُوا : الدِّیَۃُ مِئَۃ بَعِیرٍ۔",,,27268,,
27269,"حَدَّثَنَا إِسْمَاعِیلُ بْنُ إِبْرَاہِیمَ ، عَن خَالِدٍ ، عَن عِکْرِمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : إِنِّی لأُسَبِّحُ کُلَّ یَوْمٍ ثِنْتَیْ عَشْرَۃَ أَلْفِ تَسْبِیحَۃٍ ، قَدْرَ دِیَتِی ، أَوْ قَالَ : قَدْرَ دِیَتِہِ۔",,,27269,,
27270,"حَدَّثَنَا عَبْدُ اللہِ بْنُ مُبَارَکٍ ، عَنْ مَعْمَرٍ ، عَنْ عَمْرِو بْنِ عَبْدِ اللہِ ، عَنْ عِکْرِمَۃَ ؛ أَنَّ عُمَرَ بْنَ الْخَطَّابِ قَضَی بِالدِّیَۃِ عَلَی أَہْلِ الْقُرَی اثْنَیْ عَشَرَ أَلْفًا ، وَقَالَ : إِنَّ الزَّمَانَ یَخْتَلِفُ ، وَأَخَافُ عَلَیْکُمُ الْحُکَّامَ مِنْ بَعْدِی، فَلَیْسَ عَلَی أَہْلِ الْقُرَی زِیَادَۃٌ فِی تَغْلِیظِ عَقْلٍ، وَلاَ الشَّہْرِ الْحَرَامِ، وَلاَ الْحُرْمَۃِ، وَعَقْلُ أَہْلِ الْقُرَی فِیہِ تَغْلِیظٌ ، لاَ زِیَادَۃَ فِیہِ۔",,,27270,,
27271,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ؛ أَنَّ قَتَادَۃَ رَجُلاً مِنْ بَنِی مُدْلِجٍ قَتَلَ ابْنَہُ ، فَأَخَذَ مِنْہُ عُمَرُ مِئَۃً مِنَ الإِبِلِ : ثَلاَثِینَ حِقَّۃً ، وَثَلاَثِینَ جَذَعَۃً ، وَأَرْبَعِینَ خَلِفَۃً۔",,,27271,,
27272,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ قَالَ: حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ، عَنْ عَلِیِّ بْنِ زَیْدِ بْنِ جُدْعَانَ، عَنِ الْقَاسِمِ بْنِ رَبِیعَۃَ، عَنِ ابْنِ عُمَرَ ، قَالَ: خَطَبَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَوْمَ فَتْحِ مَکَّۃَ ، فَقَامَ عَلَی دَرَجِ الْکَعْبَۃِ ، فَقَالَ: الْحَمْدُ لِلَّہِ الَّذِی صَدَقَ وَعْدَہُ ، وَنَصَرَ عَبْدَہُ ، وَہَزَمَ الأَحْزَابَ وَحْدَہُ ، أَلاَ إِنَّ قَتِیلَ الْعَمْدِ الْخَطَأِ بِالسَّوْطِ ، أَوِ الْعَصَا فِیہِ الدِّیَۃُ مُغَلَّظَۃٌ : مِئَۃٌ مِنَ الإِبِلِ ، أَرْبَعُونَ خَلِفَۃً فِی بُطُونِہَا أَوْلاَدُہَا۔ (ابوداؤد 4536۔ احمد 11)",,,27272,,
27273,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَن یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی أَسْنَانِ الإِبِلِ فِی الدِّیَۃِ ، قَالَ : ثَلاَثُونَ خَلِفَۃً ، وَثَلاَثُونَ جَذَعَۃً ، وَعِشْرُونَ ابْنَۃَ مَخَاضٍ ، وَعِشْرُونَ ابْنَۃَ لَبُونٍ۔",,,27273,,
27274,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ قَالَ : کَانَ الزُّہْرِیُّ یَقُولُ : مِئَتَیْ بَقَرَۃٍ ، أَوْ أَلْفَیْ شَاۃٍ۔",,,27274,,
27275,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ قَالَ : حدَّثَنَا سَعِیدُ بْنُ عُبَیْدٍ ، عَن بُشَیْرِ بْنِ یَسَارٍ ، عَن سَہْلِ بْنِ أَبِی حَثْمَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَدَی رَجُلاً بِمِئَۃٍ مِنَ الإِبِلِ۔ (بخاری 6898۔ مسلم 1291)",,,27275,,
27276,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، قَالَ: مِئَۃٌ مِنَ الإِبِلِ، أَوْ قِیمَتُہَا مِنْ غَیْرِہِ۔",,,27276,,
27277,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ إِسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ ، قَالَ : یُعْطِی أَہْلُ الإِبِلِ الإِبِلَ ، وَأَہْلُ الْبَقَرِ الْبَقَرَ ، وَأَہْلُ الشَّائِ الشَّائَ ، وَأَہْلُ الْوَرِقِ الْوَرِقَ۔",,,27277,,
27278,حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ أَنَّ عُمَرَ ، وَعُثْمَانَ قَوَّمَا الدِّیَۃَ ، وَجَعَلاَ ذَلِکَ إِلَی الْمُعْطِی ، إِنْ شَائَ فَالإِبِلُ ، وَإِنْ شَائَ فَالْقِیمَۃُ۔,,,27278,,
27279,"حَدَّثَنَا أَبُو أُسَامَۃَ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو، أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ قَالَ: إِنْ کَانَ الَّذِی أَصَابَہُ مِنَ الأَعْرَابِ، فَدِیَتُہُ مِئَۃٌ مِنَ الإِبِلِ، لاَ یُکَلَّفُ الأَعْرَابِیُّ الذَّہَبَ، وَلاَ الْوَرِقَ، وَدِیَۃُ الأَعْرَابِیِّ إِذَا أَصَابَہُ الأَعْرَابِیُّ مِئَۃٌ مِنَ الإِبِلِ ، فَإِنْ لَمْ تَجِدِ الْعَاقِلَۃُ إِبِلاً ، فَعَدْلُہَا مِنَ الشَّائِ أَلْفَیْ شَاۃٍ۔",,,27279,,
27280,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ طَاوُوس قَالَ : قَالَ أَبِی : یُعْطُونَ مِنْ أَیِّ صِنْفٍ کَانَ ، بِقِیمَۃِ الإِبِلِ یَوْمئِذٍ مَا کَانَتْ ، إِنِ ارْتَفَعَتْ ، وَإِنِ انْخَفَضَتْ فَقِیمَتُہَا۔",,,27280,,
27281,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ قَالَ : قُلْتُ لِعَطَائٍ : إِنْ شَائَ الْقرَوِیُّ أَعْطَی مِئَۃَ نَاقَۃٍ ، أَوْ مِئَتَیْ بَقَرَۃٍ ، أَوْ أَلْفَیْ شَاۃٍ وَلَمْ یُعْطِ ذَہَبًا ؟ قَالَ : إِنْ شَائَ أَعْطَی إِبِلاً وَلَمْ یُعْطِ ذَہَبًا۔\n\nقَالَ: وَقَالَ عَطَائٌ : کَانَ یُقَالُ : عَلَی أَہْلِ الإِبِلِ إِبِلٌ ، وَعَلَی أَہْلِ الْبَقَرِ بَقَرٌ ، وَعَلَی أَہْلِ الشَّائِ شَائٌ۔",,,27281,,
27282,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ قَالَ : أَخْبَرَنَا عَبْدُ الْکَرِیمِ بْنُ أَبِی الْمُخَارِقِ ، عَنِ الْحَسَنِ ، قَالَ : إِنْ شَائَ صَاحِبُ الْبَقَرِ وَالشَّائِ أَعْطَی الإِبِلَ۔",,,27282,,
27283,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ قَالَ : قَالَ أَبُو بَکْرٍ : مَنْ کَانَ عَقْلُہُ فِی الشَّائِ ، فَکُلُّ بَعِیرٍ بِعِشْرِینَ شَاۃً ، وَمَنْ کَانَ عَقْلُہُ الْبَقَر ، فَکُلُّ بَعِیرٍ بِبَقَرَتَیْنِ۔",,,27283,,
27284,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، وَأَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَن زَیْدِ بْنِ جُبَیْرٍ ، عَن خِشْفٍ ، عَنْ عَبْدِ اللہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أَنَّہُ قَالَ : دِیَۃُ الْخَطَأِ أَخْمَاسًا : عِشْرُونَ حِقَّۃً ، وَعِشْرُونَ جَذَعَۃً ، وَعِشْرُونَ بَنَاتِ لَبُونٍ ، وَعِشْرُونَ بَنُو لَبُونٍ ، وَعِشْرُونَ بَنَاتِ مَخَاضٍ۔ (ترمذی 1386۔ دارقطنی 175)",,,27284,,
27285,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَلْقَمَۃَ بْنِ قَیْسٍ ، عَنْ عَبْدِ اللہِ أَنَّہُ قَالَ : فِی الْخَطَأِ أَخْمَاسًا : عِشْرُونَ حِقَّۃً ، وَعِشْرُونَ جَذَعَۃً ، وَعِشْرُونَ بَنَاتِ مَخَاضٍ ، وَعِشْرُونَ بَنُو مَخَاضٍ ، وَعِشْرُونَ بَنَاتِ لَبُونٍ۔",,,27285,,
27286,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَن مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَبْدِ اللہِ ، مِثْلُہُ۔",,,27286,,
27287,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ ، عَنْ عَلِیٍّ (ح) وَعَنْ سُفْیَانَ ، عَن مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَلِیٍّ ، قَالَ : کَانَ یَقُولُ فِی الْخَطَأِ أَرْبَاعًا : خَمْسٌ وَعِشْرُونَ حِقَّۃً ، وَخَمْسٌ وَعِشْرُونَ جَذَعَۃً ، وَخَمْسٌ وَعِشْرُونَ ابْنَۃَ لَبُونٍ ، وَخَمْسٌ وَعِشْرُونَ بَنَاتِ مَخَاضٍ۔",,,27287,,
27288,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ، عَن عُبَیْدَۃَ، عَنْ إِبْرَاہِیمَ، عَنْ عُمَرَ، وَعَبْدِاللہِ، أَنَّہُمَا قَالاَ: دِیَۃُ الْخَطَأِ أَخْمَاسًا۔",,,27288,,
27289,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ (ح) وَعَنْ عَبْدِ رَبِّہِ ، عَنْ أَبِی عِیَاضٍ ، عَنْ عُثْمَانَ ، وَزَیْدٍ ، قَالاَ : فِی الْخَطَأِ ثَلاَثُونَ جَذَعَۃً ، وَثَلاَثُونَ بَنَاتُ لَبُونٍ ، وَعِشْرُونَ بَنُو لَبُونٍ ، وَعِشْرُونَ بَنْتُ مَخَاضٍ۔",,,27289,,
27290,"حَدَّثَنَا وَکِیعٌ ، عَنْ الْحَسَنِ بْنِ صَالِحٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الشَّعْبِیِّ ، عَنْ زَیْدٍ ؛ فِی دِیَۃِ الْخَطَأِ : ثَلاَثُونَ جَذَعَۃً ، وَثَلاَثُونَ حِقَّۃً ، وَعِشْرُونَ بَنُو لَبُونٍ ، وَعِشْرُونَ بَنَاتِ مَخَاضٍ۔",,,27290,,
27291,"حَدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ ، عَنِ الْحَسَنِ ، قَالَ : دِیَۃُ الْخَطَأِ أَخْمَاسًا۔",,,27291,,
27292,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَلْقَمَۃَ ، وَالأَسْوَدِ ، عَنْ عَبْدِ اللہِ ، قَالَ: شِبْہُ الْعَمْدِ أَرْبَاعًا: خَمْسٌ وَعِشْرُونَ حِقَّۃً، وَخَمْسٌ وَعِشْرُونَ جَذَعَۃً، وَخَمْسٌ وَعِشْرُونَ بَنَاتُ مَخَاضٍ، وَخَمْسٌ وَعِشْرُونَ بَنَاتُ لَبُونٍ۔",,,27292,,
27293,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا ابْنُ أَبِی خَالِدٍ ، عَنْ عَامِرٍ ، قَالَ : کَانَ ابْنُ مَسْعُودٍ یَقُولُ : فِی شِبْہِ الْعَمْدِ أَرْبَاعًا : خَمْسٌ وَعِشْرُونَ جَذَعَۃً ، وَخَمْسٌ وَعِشْرُونَ حِقَّۃً ، وَخَمْسٌ وَعِشْرُونَ بَنَاتُ لَبُونٍ ، وَخَمْسٌ وَعِشْرُونَ بَنَاتُ مَخَاضٍ۔",,,27293,,
27294,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَن مُجَاہِدٍ ، عَنْ عُمَرَ ؛ أَنَّہُ قَالَ : فِی شِبْہِ الْعَمْدِ ثَلاَثُونَ جَذَعَۃً ، وَثَلاَثُونَ حِقَّۃً ، وَأَرْبَعُونَ مَا بَیْنَ ثَنِیَّۃٍ إِلَی بَازِلِ عَامِہَا کُلُّہَا خَلِفَۃً۔",,,27294,,
27295,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمٍ ، عَنْ عَلِیٍّ ، قَالَ : فِی شِبْہِ الْعَمْدِ ثَلاَثٌ وَثَلاَثُونَ حِقَّۃً ، وَثَلاَثٌ وَثَلاَثُونَ جَذَعَۃً ، وَأَرْبَعٌ وَثَلاَثُونَ ثَنِیَّۃً إِلَی بَازِلِ عَامِہَا کُلُّہَا خَلِفَۃً۔",,,27295,,
27296,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ (ح) وَعَنْ عَبْدِ رَبِّہِ ، عَنْ أَبِی عِیَاضٍ ؛ أَنَّ عُثْمَانَ ، وَزَیْدَ بْنَ ثَابِتٍ ، قَالاَ : فِی الْمُغَلَّظَۃِ أَرْبَعُونَ جَذَعَۃً خَلِفَۃً ، وَثَلاَثُونَ حِقَّۃً ، وَثَلاَثُونَ بَنَاتِ لَبُونٍ۔",,,27296,,
27297,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنِ الشَّعْبِیِّ ، قَالَ : کَانَ أَبُو مُوسَی ، وَالْمُغِیرَۃُ بْنُ شُعْبَۃَ ،یَقُولاَنِ : فِی الْمُغَلَّظَۃِ مِنَ الدِّیَۃِ ثَلاَثُونَ حِقَّۃً ، وَثَلاَثُونَ جَذَعَۃً ، وَأَرْبَعُونَ ثَنِیَّۃً إِلَی بَازِلِ عَامِہَا کُلُّہَا خَلِفَۃً۔",,,27297,,
27298,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا ابْنُ أَبِی خَالِدٍ ، عَنْ عَامِرٍ ، قَالَ : کَانَ زَیْدُ بْنُ ثَابِتٍ یَقُولُ : فِی شِبْہِ الْعَمْدِ : ثَلاَثُونَ حِقَّۃً ، وَثَلاَثُونَ جَذَعَۃً ، وَأَرْبَعُونَ مَا بَیْنَ ثَنِیَّۃٍ إِلَی بَازِلِ عَامِہَا کُلُّہَا خَلِفَۃً ،\n\nوَکَانَ عَلِیٌّ یَقُولُ : فِی شِبْہِ الْعَمْدِ : ثَلاَثٌ وَثَلاَثُونَ حِقَّۃً ، وَثَلاَثٌ وَثَلاَثُونَ جَذَعَۃً ، وَأَرْبَعٌ وَثَلاَثُونَ مَا بَیْنَ ثَنِیَّۃٍ إِلَی بَازِلِ عَامِہَا کُلُّہَا خَلِفَۃً۔",,,27298,,
27299,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ أَشْعَثَ ، عَنْ عَامِرٍ ، وَالْحَسَنِ ، وَابْنِ سِیرِینَ ، وَعَمْرِو بْنِ دِینَارٍ، قَالُوا : شِبْہُ الْعَمْدِ تُغْلِظُ عَلَیْہِمُ الدِّیَۃَ فِی أَسْنَانِ الإِبِلِ۔",,,27299,,
27300,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ ، عَنْ عَلِیٍّ ، قَالَ : شِبْہُ الْعَمْدِ ؛ الضَّرْبَۃُ بِالْخَشَبَۃِ ، أَوِ الْقَذْفَۃُ بِالْحَجَرِ الْعَظِیمِ ، وَالدِّیَۃُ أَثْلاَثٌ : ثُلُثٌ حِقَاقٌ ، وَثُلُثٌ جِذَاعٌ ، وَثُلُثٌ مَا بَیْنَ ثَنِیَّۃٍ إِلَی بَازِلِ عَامِہَا کُلُّہَا خَلِفَۃً۔",,,27300,,
27301,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قَالَ عَطَائٌ : تُغَلَّظُ الدِّیَۃُ فِی شِبْہِ الْعَمْدِ ، وَلاَ یُقْتَلُ بِہِ۔",,,27301,,
27302,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : مَا تَغْلِیظُ الإِبِلِ ؟ قَالَ : أَرْبَعُونَ خَلِفَۃً ، وَثَلاَثُونَ حِقَّۃً ، وَثَلاَثُونَ جَذَعَۃً۔",,,27302,,
27303,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَن یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی التَّغْلِیظِ : أَرْبَعُونَ ثَنِیَّۃً إِلَی بَازِلِ عَامہَا کُلَّہَا خَلِفَۃً ، وَثَلاَثُونَ حِقَّۃً وَثَلاَثُونَ بِنْتُ مَخَاضٍ۔",,,27303,,
27304,"حَدَّثَنَا أبو خالد ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ قَالَ : إِنَّمَا التَّغْلِیظُ فِی شِبْہِ الْعَمْدِ فِی أَسْنَانِ الإِبِلِ۔",,,27304,,
27305,"حَدَّثَنَا أَبُو الأَحْوَصِ، عَنْ أَبِی إِسْحَاقَ، عَنْ عَاصِمٍ، عَنْ عَلِیٍّ، قَالَ: شِبْہُ الْعَمْدِ بِالْحَجَرِ الْعَظِیمِ وَالْعَصَا۔",,,27305,,
27306,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: قَتِیلُ السَّوْطِ وَالْعَصَا شِبْہُ عَمْدٍ۔ (ابوداؤد 4535۔ احمد 164)",,,27306,,
27307,"حَدَّثَنَا حَفْصٌ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ، وَحَکَمٍ ، وَحَمَّادٍ ، قَالُوا : مَا أُصِیبَ بِہِ مِنْ حَجَرٍ ، أَوْ سَوْطٍ ، أَوْ عَصًا فَأَتَی عَلَی النَّفْسِ ، فَہُوَ شِبْہُ الْعَمْدِ ، وَفِیہِ الدِّیَۃُ مُغَلَّظَۃٌ۔",,,27307,,
27308,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : شِبْہُ الْعَمْدِ کُلُّ شَیْئٍ یُعْمدُ بِہِ بِغَیْرِ حَدِیدٍ ، وَلاَ یَکُونُ شِبْہُ الْعَمْدِ إِلاَّ فِی النَّفْسِ ، وَلاَ یَکُونُ دُونَ النَّفْسِ۔",,,27308,,
27309,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : مَا کَانَ مِنْ قَتْلٍ بِغَیْرِ سِلاَحٍ ، فَہُوَ شِبْہُ الْعَمْدِ ، وَفِیہِ الدِّیَۃُ عَلَی الْعَاقِلَۃِ۔",,,27309,,
27310,"حَدَّثَنَا مُحَمَّدُ بْنُ مُصْعَبٍ ، عَنِ الأَوْزَاعِیِّ ، عَنِ الزُّہْرِیِّ ، قَالَ : شِبْہُ الْعَمْدِ أَنْ یَضْرِبَ الرَّجُلُ الرَّجُلَ فِی الثَّاْرِ یَکُونُ بَیْنَہُمَا ، وَلاَ یُرِیدُ قَتْلَہُ ، فَیَمْرَضُ مِنْ ذَلِکَ فَیَمُوتُ۔",,,27310,,
27311,"حَدَّثَنَا أَبُو الأَحْوَصِ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ جَابِرٍ ، عَنْ أَبِی عَازِبٍ ، عَنِ النُّعْمَانِ بْنِ بَشِیرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : کُلُّ شَیْئٍ خَطَأٌ إِلاَّ السَّیْفَ ، وَلِکُلِّ خَطَأٍ أَرْشٌ۔\n\n(احمد 275۔ بزار 3244)",,,27311,,
27312,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : الْخَطَأُ أَنْ تُرِیدَ الشَّیئَ ، فَتُصِیبُ غَیْرَہُ۔",,,27312,,
27313,"حَدَّثَنَا جَرِیرٌ، عَنْ مُغِیرَۃَ، عَنْ إِبْرَاہِیمَ، قَالَ: الْخَطَأُ أَنْ تُصِیبَ الإِنْسَانَ، وَلاَ تُرِیدُہُ، فَذَلِکَ عَلَی الْعَاقِلَۃِ۔",,,27313,,
27314,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی حَمْزَۃَ الأَسَدِیِّ ، قَالَ : شَہِدْت شُرَیْحًا قَضَی فِی مُوضِحَۃٍ بِخَمْسِ مِئَۃِ دِرْہَمٍ۔",,,27314,,
27315,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سُفْیَانَ ، عَنْ حَکِیمِ بْنِ الدَّیْلَمِ ، قَالَ : أَتَیْتُ شُرَیْحًا فِی مُوضِحَۃٍ ، فَقَضَی فِیہَا بِخَمْسِ قَلاَئِصَ۔",,,27315,,
27316,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ سُفْیَانَ بْنِ حُسَیْنٍ ، عَنْ شَیْبَۃَ بْنِ مُسَاوِرٍ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَضَی فِی الْمُوضِحَۃِ بِخَمْسٍ مِنَ الإِبِلِ ، وَلَمْ یَقْضِ فِیمَا سِوَی ذَلِکَ۔\n\n(عبدالرزاق 17316)",,,27316,,
27317,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا سَعِیدٌ ، عَنْ مَطَرٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَضَی فِی الْمُوضِحَۃِ خَمْسًا خَمْسًا۔ (ابوداؤد 4555۔ ترمذی 1390)",,,27317,,
27318,حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ مَکْحُولٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَضَی فِی الْمُوضِحَۃِ بِخَمْسٍ مِنَ الإِبِلِ ، وَلَمْ یَقْضِ فِیمَا سِوَی ذَلِکَ۔۔,,,27318,,
27319,حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ مَکْحُولٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَضَی فِی الْمُوضِحَۃِ فَصَاعِدًا ، فَجَعَلَ فِی الْمُوضِحَۃِ خَمْسًا مِنَ الإِبِلِ۔,,,27319,,
27320,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، عَنْ عَلِیٍّ ، وَعَبْدِ اللہِ ، قَالاَ : فِی الْمُوضِحَۃِ خَمْسٌ مِنَ الإِبِلِ۔",,,27320,,
27321,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ ، عَنْ عَلِیٍّ ، قَالَ : فِی الْمُوضِحَۃِ خَمْسٌ مِنَ الإِبِلِ۔",,,27321,,
27322,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ عَمْرِو بْنِ مَیْمُونٍ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ قَالَ : فِیہَا خَمْسٌ مِنَ الإِبِلِ۔",,,27322,,
27323,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : فِی الْمُوضِحَۃِ خَمْسُ فَرَائِضَ۔",,,27323,,
27324,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : فِی الْمُوضِحَۃِ خَمْسٌ مِنَ الإِبِلِ ، أَوْ عَدْلُ ذَلِکَ مِنَ الذَّہَبِ أَوِ الْوَرِقِ۔",,,27324,,
27325,"حَدَّثَنَا یحیی بْنُ عَبْدِ الْمَلِکِ بْنِ أَبِی غَنِیَّۃ ، عَنْ أَبِیہِ ، عَنِ الْحَکَمِ ، وَحَمَّادٍ ، قَالاَ : فِی الْمُوضِحَۃِ خَمْسٌ مِنَ الإِبِلِ۔",,,27325,,
27326,"حَدَّثَنَا أَبُو دَاوُدَ ، عَن زَمْعَۃَ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ قَالَ : فِی الْمُوضِحَۃِ خَمْسٌ مِنَ الإِبِلِ۔",,,27326,,
27327,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا حُسَیْنُ الْمُعَلِّمُ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : فِی الْمُوضِحَۃِ خَمْسٌ۔ (ابوداؤد 455۔ ترمذی 1390)",,,27327,,
27328,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَن عِکْرِمَۃَ بْنِ خَالِدٍ ، عَنْ رَجُلٍ مِنْ آلِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : فِی الْمُوضِحَۃِ خَمْسٌ۔",,,27328,,
27329,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَن خَالِدٍ ، قَالَ : کَتَبَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ : أَنْ لاَ یُزَادَ فِی الْمُوضِحَۃِ عَلَی خَمْسِینَ دِینَارًا ، قَالَ خَالِدٌ : یُرِیدُ الْمُوضِحَۃَ فِی الْوَجْہِ۔",,,27329,,
27330,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : فِی الْمُوضِحَۃِ خَمْسٌ مِنَ الإِبِلِ۔",,,27330,,
27331,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، عَنْ عَلِیٍّ ، قَالَ : فِی الْمُوضِحَۃِ خَمْسٌ مِنَ الإِبِلِ أَرْبَاعًا : رُبْعٌ جِذَاعٌ ، وَرُبْعٌ حِقَاقٌ ، وَرُبْعٌ بَنَاتُ لَبُونٍ ، وَرُبْعٌ بَنَاتُ مَخَاضٍ۔",,,27331,,
27332,"حَدَّثَنَا ابْنُ فُضَیْلٍ، عَنْ أَشْعَثَ، عَنْ عَامِرٍ، عَنْ عَبْدِاللہِ، قَالَ: فِی الْمُوضِحَۃِ خَمْسٌ مِنَ الإِبِلِ أَخْمَاسًا۔",,,27332,,
27333,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، عَن مَسْرُوقٍ ، وَشُرَیْحٍ ؛ أَنَّہُمَا قَالاَ : فِی الْمُوضِحَۃِ خَمْسٌ مِنَ الإِبِلِ : حِقَّۃٌ ، وَجَذَعَۃٌ ، وَبِنْتُ مَخَاضٍ ، وَبِنْتُ لَبُونٍ ، وَابْنُ لَبُونٍ۔",,,27333,,
27334,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ؛ فِی السِّنِّ وَالْمُوضِحَۃِ خَمْسٌ مِنَ الإِبِلِ : ابْنَا مَخَاضٍ ؛ أُنْثَی وَذَکَرٍ ، وَابْنَۃُ لَبُونٍ ، وَجَذَعَۃٌ ، وَحِقَّۃٌ۔",,,27334,,
27335,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَن یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی دِیَۃِ الْمُوضِحَۃِ : بِنْتُ مَخَاضٍ ، وَابْنُ لَبُونٍ ، وَابْنَۃُ لَبُونٍ ، وَحِقَّۃٌ ، وَجَذَعَۃٌ۔",,,27335,,
27336,حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ مَکْحُولٍ (ح) وَعَنْ أَشْعَثَ ، عَنِ الزُّہْرِیِّ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَضَی فِی الآمَّۃِ ثُلُثَ الدِّیَۃِ۔ (ابوداؤد 257۔ نسائی 7060),,,27336,,
27337,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمٍ ، عَنْ عَلِیٍّ قَالَ : فِی الآمَّۃِ ثُلُثُ الدِّیَۃِ۔",,,27337,,
27338,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ، عَنْ أَشْعَثَ، عَنِ الشَّعْبِیِّ، عَنْ عَبْدِ اللہِ ، قَالَ: فِی الآمَّۃِ ثُلُثُ الدِّیَۃِ أَخْمَاسًا۔",,,27338,,
27339,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَن مُجَاہِدٍ ، قَالَ : فِی الآمَّۃِ ثُلُثُ الدِّیَۃِ۔",,,27339,,
27340,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : فِی الآمَّۃِ ثُلُثُ الدِّیَۃِ۔",,,27340,,
27341,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُحَمَّدِ بْنِ عمرو ، عن عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : فِی الآمَّۃِ ثُلُثُ الدِّیَۃِ۔",,,27341,,
27342,"حَدَّثَنَا عَبْدُ الْوَہَّابِ ، عَن جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ ، قَالَ : فِی الآمَّۃِ ثُلُثُ الدِّیَۃِ۔",,,27342,,
27343,حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ فِی الْمَأْمُومَۃِ الثُّلُثُ۔,,,27343,,
27344,حَدَّثَنَا شَرِیکٌ ، عَنْ أَبِی إِسْحَاقَ ؛ أَنَّ شُرَیْحًا قَضَی فِی الآمَّۃِ بِأَرْبَعَۃِ آلاَفٍ۔,,,27344,,
27345,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ عَنْ عَاصِمٍ ، عَنْ عَلِیٍّ ، قَالَ : فِی الْمُنَقِّلَۃُ خَمْسَ عَشْرَۃَ۔",,,27345,,
27346,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَن عِکْرِمَۃَ بْنِ خَالِدٍ ، عَنْ رَجُلٍ مِنْ آلِ عُمَرَ ، رَفَعَہُ ، قَالَ : فِی الْمُنَقِّلَۃِ خَمْسَ عَشْرَۃَ۔",,,27346,,
27347,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُحَمَّدِ بْنِ عمرو ، عن عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : فِی الْمُنَقِّلَۃِ خَمْسَ عَشْرَۃَ مِنَ الإِبِلِ ، أَوْ عَدْلُ ذَلِکَ مِنَ الذَّہَبِ ، أَوِ الْوَرِقِ۔",,,27347,,
27348,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ قَالَ : فِی الْمُنَقِّلَۃِ خَمْسَ عَشْرَۃَ۔",,,27348,,
27349,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : فِی الْمُنَقِّلَۃِ خَمْسَ عَشْرَۃَ۔",,,27349,,
27350,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، قَالَ : فِیہَا خَمْسَ عَشْرَۃَ۔",,,27350,,
27351,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، عَنْ عَبْدِ اللہِ قَالَ : فِی الْمُنَقِّلَۃِ خَمْسَ عَشْرَۃَ أَخْمَاسًا۔",,,27351,,
27352,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَشْعَثَ ، عَنْ عَامِرٍ ، عَنْ عَلِیٍّ ، قَالَ : فِی الْمُنَقِّلَۃِ خَمْسَ عَشْرَۃَ مِنَ الإِبِلِ أَرْبَاعًا : رُبْعٌ جِذَاعٌ ، وَرُبْعٌ حِقَاقٌ ، وَرُبْعٌ بَنَاتُ لَبُونٍ ، وَرُبْعٌ بَنَاتُ مَخَاضٍ۔",,,27352,,
27353,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ مَکْحُولٍ ، قَالَ : قضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی الْمُنَقِّلَۃِ خَمْسَ عَشْرَۃَ۔",,,27353,,
27354,"حَدَّثَنَا جَرِیرٌ ، عَن مَنْصُورٍ ، عَنِ الْحَکَمِ ، قَالَ : کَانَ عَلِیٌّ یَجْعَلُ فِی الَّتِی لَمْ تُوضِحْ وَقَدْ کَادَتْ أَرْبَعًا مِنَ الإِبِلِ۔",,,27354,,
27355,"حَدَّثَنَا وَکِیعٌ ، عن سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنِ الْحَکَمِ ، عَنْ عَلِیِّ ؛ فی السِّمْحاق : أَرْبَعٌ مِنَ الإِبِلِ ، وَذُکِرَ عَنِ الْحَکَمِ ، عَنْ عَلِیٍّ ، مِثْلُ ذَلِکَ۔",,,27355,,
27356,حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ سُفْیَانَ ، عَن مَالِکِ بْنِ أَنَسٍ ، عَنْ یَزِیدَ بْنِ عَبْدِ اللہِ بْنِ قُسَیْطٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، أَنَّ عُمَرَ ، وَعُثْمَانَ قَضَیَا فِی الْمِلْطَاۃِ ، وَہِیَ السِّمْحَاقُ نِصْفَ دِیَۃِ الْمُوضِحَۃِ۔,,,27356,,
27357,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : مَا دُونَ الْمُوضِحَۃِ فَفِیہِ الصُّلْحُ۔",,,27357,,
27358,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَن فِرَاسٍ ، عَنْ عَامِرٍ ، قَالَ : قَالَ : مَا دُونَ الْمُوضِحَۃِ أَجْرُ الطَّبِیبِ۔",,,27358,,
27359,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ عَمْرِو بْنِ مَیْمُونٍ ، قَالَ : کَتَبَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ : لَیْسَ فِیمَا دُونَ الْمُوضِحَۃِ عَقْلٌ إِلاَّ أَجْرَ الطَّبِیبِ۔",,,27359,,
27360,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَن حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : فِیمَا دُونَ الْمُوضِحَۃِ حُکْمٌ۔",,,27360,,
27361,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، عَن مَسْرُوقٍ ، قَالَ : لَیْسَ فِیمَا دُونَ الْمُوضِحَۃِ إِلاَّ أَجْرَ الطَّبِیبِ۔",,,27361,,
27362,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنِ الأَعْمَشِ ، قَالَ : سَأَلْتُ إِبْرَاہِیمَ عَنِ الْخَدْشِ ، أَوِ الشَّیئِ ؟ قَالَ : صُلْحٌ ، مَا لَمْ یَبْلُغْ فَرِیضَۃً۔",,,27362,,
27363,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، قَالَ : کَانَ الْحَسَنُ لاَ یُوَقِّتُ فِیمَا دُونَ الْمُوضِحَۃِ شَیْئًا۔",,,27363,,
27364,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللہِ الأَسَدِیُّ ، عَنِ ابْنِ عُلاَثَۃَ ، عَنْ إِبْرَاہِیمَ بْنِ أَبِی عَبْلَۃَ ؛ أَنَّ مُعَاذًا ، وَعُمَرَ جَعَلاَ فِیما دون الْمُوضِحَۃِ أَجْرَ الطَّبِیبِ۔,,,27364,,
27365,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ عُمَرَ بْنِ عَامِرٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ؛ أَنَّ أَبَا بَکْرٍ ، وَعُمَرَ ، قَالاَ : الْمُوضِحَۃُ فِی الْوَجْہِ وَالرَّأْسِ سَوَائٌ۔",,,27365,,
27366,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ عَمْرِو بْنِ مَیْمُونٍ ، أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ کَتَبَ : أَنَّ الْمُوضِحَۃَ فِی الْوَجْہِ وَالرَّأْسِ سَوَائٌ ، فِیہَا خَمْسٌ مِنَ الإِبِلِ۔",,,27366,,
27367,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ الْقَطَّانُ، عَنْ یَحْیَی بْنِ سَعِیدٍ، عَن سُلَیْمَانَ بْنِ یَسَارٍ، قَالَ: الْمُوضِحَۃُ فِی الْوَجْہِ کَالْمُوضِحَۃِ فِی الرَّأْسِ، إِلاَّ أَنْ یَکُونَ فِی الْوَجْہِ شَیْنٌ، فَعَلَی قَدْرِ ذَلِکَ إِلَی أَنْ یَبْلُغَ نِصْفَ عَقْلِ الْمُوضِحَۃِ۔",,,27367,,
27368,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إِدْرِیسَ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ، قَالَ : الْمُوضِحَۃُ فِی الْوَجْہِ وَالرَّأْسِ۔",,,27368,,
27369,"حَدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ، قَالَ : الْمُوضِحَۃُ فِی الْوَجْہِ وَالرَّأْسِ سَوَائٌ ، إِلاَّ أَنْ یَکُونَ فِی الْوَجْہِ شَیْنٌ ، فَیَزِیدُ عَلَی قَدْرِ الشَّیْنِ۔",,,27369,,
27370,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ، عَنْ حَجَّاجٍ، عَنْ مَکْحُولٍ، عَنْ زَیْدٍ، قَالَ: الْمُوضِحَۃُ فِی الْوَجْہِ وَالرَّأْسِ وَالأَنْفِ سَوَائٌ۔",,,27370,,
27371,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : الْمُوضِحَۃُ فِی الرَّأْسِ وَالْوَجْہِ سَوَائٌ۔",,,27371,,
27372,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : الْمُوضِحَۃُ فِی الْوَجْہِ مِثْلُ الْمُوضِحَۃِ فِی الرَّأْسِ۔",,,27372,,
27373,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ شُرَیْحٍ ، وَالْحَسَنِ ، قَالاَ : الْمُوضِحَۃُ فِی الْوَجْہِ مِثْلُ الْمُوضِحَۃِ فِی الرَّأْسِ۔",,,27373,,
27374,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَن حُمْرَانَ ، عَنْ إِیَاسِ بْنِ مُعَاوِیَۃَ ، قَالَ : الْمُوضِحَۃُ ہوْنا وہوْنا سَوَائٌ ، وَأَشَارَ مُعْتَمِرٌ بِیَدِہِ إِلَی رَأْسِہِ وَوَجْہِہِ۔",,,27374,,
27375,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ؛ أَنَّ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : خَمْسٌ خَمْسٌ۔",,,27375,,
27376,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ، قَالَ: الْمُوضِحَۃُ فِی الرَّأْسِ خَمْسٌ، وَفِی الْوَجْہِ عَشْرٌ۔",,,27376,,
27377,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَن دَاوُد ، عَنْ عَامِرٍ ، قَالَ : الْمُوضِحَۃُ فِی الْوَجْہِ لَہَا دِیَتَانِ۔",,,27377,,
27378,"حَدَّثَنَا أَبُو الأَحْوَصِ، عَنْ أَبِی إِسْحَاقَ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ، عَنْ عَلِیٍّ، قَالَ: فِی الأُذُنِ نِصْفُ الدِّیَۃِ۔",,,27378,,
27379,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ، عَنْ حَجَّاجٍ ، عَنْ مَکْحُولٍ ، عَنْ زَیْدٍ ، قَالَ : إِذَا اصْطَلَمَتِ الأُذُنُ فَفِیہَا دِیَتُہَا۔",,,27379,,
27380,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، قَالَ : قَالَ أَبُو بَکْرٍ : فِی الأُذُنِ خَمْسَ عَشَرَۃَ مِنْ أَجْلِ أَنَّہُ لیس یَضُرُّ سَمْعُہَا ، وَیُغَشِّیہَا الشَّعْرُ وَالْعِمَامَۃُ۔",,,27380,,
27381,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنَی ابْنُ أَبِی نَجِیحٍ ، عَن مُجَاہِدٍ ؛ أَنَّہُ کَانَ یَقُولُ : فِی الأُذُنِ إِذَا اسْتُؤْصِلَتْ خَمْسُونَ مِنَ الإِبِلِ۔",,,27381,,
27382,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ، عَنِ ابْنِ جُرَیْجٍ، عَنْ عَطَائٍ، قَالَ: فِی الأُذُنِ إِذَا اسْتُؤْصِلَتْ خَمْسُونَ مِنَ الإِبِلِ۔",,,27382,,
27383,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی عَبْدُ الْعَزِیزِ بْنُ عُمَرَ ، أَنَّ فِی کِتَابٍ لِعُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، عَنْ عُمَرَ بْنِ الْخَطَّابِ ، قَالَ : فِی الأُذُنِ نِصْفُ الدِّیَۃِ ، أَوْ عَدْلُ ذَلِکَ مِنَ الذَّہَبِ۔",,,27383,,
27384,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی بَکْرٍ ، عَنِ الشَّعْبِیِّ ، عَنْ شُرَیْحٍ قَالَ : فِی الأُذُنِ نِصْفُ الدِّیَۃِ۔",,,27384,,
27385,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، عَنْ عَبْدِ اللہِ ، قَالَ : فِی الأُذُنِ إِذَا اسْتُؤْصِلَتْ نِصْفُ الدِّیَۃِ أَخْمَاسًا ، فَمَا نَقَصَ مِنْہَا فَبِحِسَابٍ۔",,,27385,,
27386,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ أَبِی لَیْلَی ، عَن عِکْرِمَۃَ بْنِ خَالِدٍ ، عَنْ رَجُلٍ مِنْ آلِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : فِی الأَنْفِ إِذَا اسْتُؤْصِلَ مَارِنُہُ الدِّیَۃُ۔",,,27386,,
27387,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ ، عَنْ عَلِیٍّ ، قَالَ : فِی الأَنْفِ الدِّیَۃُ۔",,,27387,,
27388,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ، عَنْ أَشْعَثَ، عَنْ عَلِیٍّ ، قَالَ: فِی الأَنْفِ الدِّیَۃُ، وَمَا قُطِعَ مِنَ الأَنْفِ فَبِحِسَابٍ۔",,,27388,,
27389,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ مُحَمَّدِ بْنِ عُمَارَۃَ ، عَنْ أَبِی بَکْرٍ بْنِ عَمْرِو بْنِ حَزْمٍ ، قَالَ : کَانَ فِی کِتَابِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لِعَمْرِو بْنِ حَزْمٍ : فِی الأَنْفِ إِذَا اسْتُوْعِبَ مَارِنُہُ الدِّیَۃُ۔",,,27389,,
27390,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : فِی الأَنْفِ الدِّیَۃُ ، وَمَا نَقَصَ مِنَ الأَنْفِ فَبِحِسَابِہِ۔",,,27390,,
27391,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : الأَنْفُ وَالأُذُنُ بِمَنْزِلَۃِ السِّنِّ ، مَا نَقَصَ مِنْہُ فَبِحِسَابٍ۔",,,27391,,
27392,حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، عَنْ عَبْدِ اللہِ ؛ فِی الأَنْفِ إِذَا أُوْعِبَ جَدْعُہُ ، أَوْ قُطِعَ الْمَارِنُ ، الدِّیَۃُ أَخْمَاسًا ، فَمَا نَقَصَ مِنْہُ فَبِالْحِسَابِ۔,,,27392,,
27393,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَن مُجَاہِدٍ، قَالَ: فِی الرَّوْثَۃِ ثُلُثُ الدِّیَۃِ، فَإِذَا بَلَغَ الْمَارِنُ الْعَظْمَ فَالدِّیَۃُ وَافِیَۃٌ ، فَإِنْ أُصِیبَ مِنَ الرَّوْثَۃِ الأَرْنَبَۃُ ، أَوْ غَیْرُہَا مَا لَمْ یَبْلُغَ الْعَظْمَ فَبِحِسَابِ الرَّوْثَۃِ۔",,,27393,,
27394,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قَالَ سُلَیْمَانُ بْنُ مُوسَی : کَتَبَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ إِلَی أُمَرَائِ الأَجْنَادِ : فِی الأَنْفِ إِذَا أُوْعِبَ جَدْعُہُ الدِّیَۃُ کَامِلَۃٌ ، فَمَا أُصِیبَ مِنَ الأَنْفِ فَبِحِسَابٍِ۔",,,27394,,
27395,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : فِی الْعِرْنِینِ الدِّیَۃُ۔",,,27395,,
27396,"حَدَّثَنَا وَکِیعٌ ، عَن سَلاَّمٍ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : فِی الْمَارِنِ الدِّیَۃُ۔",,,27396,,
27397,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَن عُبَیْدَۃَ ، عَنْ إِبْرَاہِیمَ ، عَنْ عُمَرَ ، قَالَ : فِی الأَنْفِ الدِّیَۃُ۔",,,27397,,
27398,"حَدَّثَنَا یَزِیدُ ، عَنْ حَجَّاجٍ ، عَنْ مَکْحُولٍ ، عَن زَیْدِ بْنِ أَسْلَمَ ، قَالَ : فِی الأَرْنَبَۃِ ثُلُثُ دِیَۃِ الأَنْفِ ، وَفِی الْوَتَرَۃِ ثُلُثُ دِیَۃِ الأَنْفِ۔",,,27398,,
27399,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ حَجَّاجٍ ، وَعُمَرَ بْنِ عَامِرٍ ، عَنْ مَکْحُولٍ ، عَن زَیْدِ بْنِ ثَابِتٍ ، قَالَ : فِی الْخَرَمَاتِ الثَّلاَثِ فِی الأَنْفِ الدِّیَۃُ ، وَفِی کُلِّ وَاحِدَۃٍ ثُلُثُ الدِّیَۃِ۔",,,27399,,
27400,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَن مُجَاہِدٍ ، قَالَ : فِی الرَّوْثَۃِ ثُلُثُ الدِّیَۃِ ، وَإِنْ أُصِیبَ مِنَ الرَّوْثَۃِ الأَرْنَبَۃُ ، أَوْ غَیْرُہَا مَا لَمْ یَبْلُغِ الْعَظْمَ فَبِحِسَابٍ۔",,,27400,,
27401,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : فِی الأَنْفِ جَائِفَۃٌ ؟ قَالَ : نَعَمْ۔",,,27401,,
27402,حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَن مُجَاہِدٍ ؛ أَنَّہُ کَانَ یَقُولُ فِی جَائِفَۃِ الأَنْفِ ثُلُثُ الدِّیَۃِ ، فَإِنْ أَنْفَذَ فَالثُّلُثَانِ۔,,,27402,,
27403,"حَدَّثَنَا شَرِیکٌ ، عَنْ سَعِیدِ بْنِ مَسْرُوقٍ ، عَنِ الشَّعْبِیِّ ؛ سُئِلَ عَنْ رَجُلٍ کَسَرَ أَنْفَ رَجُلٍ ، فَبَرِئَ عَلَی عَثَمٍ ؟ قَالَ : فِیہِ حُکْمٌ۔",,,27403,,
27404,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی عُثْمَانُ بْنُ أَبِی سُلَیْمَانَ ؛ أَنَّ مَمْلُوکًا لِجُبَیْرِ بْنِ أَبِی سُلَیْمَانَ کَسَرَ إِحْدَی قَصَبَتَیْ أَنْفِ مَوْلًی لِعَطَائِ بْنِ بُخْتٍ ، وَإِنَّ ابْنَ سُرَاقَۃَ سَأَلَ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ عَن ذَلِکَ ؟ فَقَالَ عُمَرُ : وَجَدْنَا فِی کِتَابٍ لِعُمَرَ بْنِ الْخَطَّابِ : أَیُّمَا عَظْمٍ کُسِرَ ، ثُمَّ جُبِرَ کَمَا کَانَ فَفِیہِ حِقَّتَانِ ، فَرَاجَعَ ابْنُ سُرَاقَۃَ عُمَرَ ، فَقَالَ : إِنَّمَا کُسِرَتْ إِحْدَی الْقَصَبَتَیْنِ ، فَأَبَی عُمَرُ إِلاَّ أَنْ یَجْعَلَ فِیہَا الْحِقَّتَیْنِ وَافِیَتَیْنِ۔",,,27404,,
27405,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إِدْرِیسَ ، عَنْ مُحَمَّدِ بْنِ عُمَارَۃَ ، عَنْ أَبِی بَکْرِ بْنِ عَمْرِو بْنِ حَزْمٍ ، قَالَ : فِی کِتَابِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لِعَمْرِو بْنِ حَزْمٍ : وَفِی الْعَیْنِ خَمْسُونَ۔",,,27405,,
27406,"حَدَّثَنَا أَبُو الأَحْوَصِ، عَنْ أَبِی إِسْحَاقَ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ ، عَنْ عَلِیٍّ ، قَالَ: فِی الْعَیْنِ نِصْفُ الدِّیَۃِ۔",,,27406,,
27407,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ أَبِی لَیْلَی ، عَن عِکْرِمَۃَ بْنِ خَالِدٍ ، عَنْ رَجُلٍ مِنْ آلِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : فِی الْعَیْنِ خَمْسُونَ۔",,,27407,,
27408,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قَالَ عَطَائٌ : الْعَیْنُ خَمْسُونَ۔",,,27408,,
27409,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ، عَنْ أَشْعَثَ، عَنِ الشَّعْبِیِّ، عَنْ عَبْدِاللہِ، قَالَ: فِی الْعَیْنِ نِصْفُ الدِّیَۃِ، أَخْمَاسًا۔",,,27409,,
27410,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : فِی الْعَیْنِ نِصْفُ الدِّیَۃِ۔",,,27410,,
27411,حَدَّثَنَا عَبْدُ اللہِ بْنُ مُبَارَکٍ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ فِی الْحَاجِبَیْنِ إِذَا اجْتِیحَا الدِّیَۃُ ، وَفِی أَحَدِہِمَا نِصْفُ الدِّیَۃِ۔,,,27411,,
27412,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، وَابْنُ إِدْرِیسَ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ، قَالَ : فِی الْحَاجِبَیْنِ الدِّیَۃُ۔",,,27412,,
27413,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : فِی الْحَاجِبَیْنِ الدِّیَۃُ ، وَفِی أَحَدِہِمَا نِصْفُ الدِّیَۃِ۔",,,27413,,
27414,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، قَالَ : قضَی أَبُو بَکْرٍ فِی الْحَاجِبِ إِذَا أُصِیبَ حَتَّی یَذْہَبَ شَعْرُہُ بِمُوضِحَتَیْنِ ؛ عَشْرٌ مِنَ الإِبِلِ۔",,,27414,,
27415,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَجَّاجٍ ، عَنْ مَکْحُولٍ ، عَن زَیْدِ بْنِ ثَابِتٍ ، قَالَ : فِی الْحَاجِبَیْنِ ثُلُثَا الدِّیَۃِ۔",,,27415,,
27416,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنِ الْحَجَّاجِ ، عَنِ الْحَکَمِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : فِی کُلِّ اثْنَیْنِ مِنَ الرَّجُلِ وَالْمَرْأَۃِ الدِّیَۃُ ؛ الْیَدَیْنِ وَالْحَاجِبَیْنِ ، وَقَالَ الشَّعْبِیُّ : فِی کُلِّ شَیْئٍ مِنَ الإِنْسَانِ اثْنَیْنِ الدِّیَۃُ۔",,,27416,,
27417,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی عَبْدُ الْکَرِیمِ بْنُ أَبِی الْمُخَارِقِ ؛ أَنَّہُ بَلَغَہُ عَنْ بَعْضِ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ أَنَّ فِی الْحَاجِبِ یَتَحَصْحَصُ شَعْرُہُ ؛ أَنَّ فِیہِ کُلَّہُ الرُّبْعُ ، وَفِیمَا ذَہَبَ مِنْہُ فَبِحِسَابٍ۔",,,27417,,
27418,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَن مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانَ یُقَالُ : مَا کَانَ مِنَ اثْنَیْنِ مِنَ الإِنْسَان الدِّیَۃُ ، وَفِی کُلِّ وَاحِدٍ مِنْہُمَا نِصْفُ الدِّیَۃِ ، وَمَا کَانَ مِنْ وَاحِدٍ فَفِیہِ الدِّیَۃُ۔",,,27418,,
27419,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا الْمِنْہَالُ بْنُ خَلِیفَۃَ الْعِجْلِیُّ، عَن سَلَمَۃَ بْنِ تَمَّامٍ الشَّقَرِیِّ، قَالَ: مَرَّ رَجُلٌ بِقِدْرٍ، فَوَقَعَتْ عَلَی رَأْسِ رَجُلٍ فَأَحْرَقَتْ شَعْرَہُ ، فَرُفِعَ إِلَی عَلِیٍّ فَأَجَّلَہُ سَنَۃً ، فَلَمْ یَنْبُتْ ، فَقَضَی فِیہِ عَلِیٌّ بِالدِّیَۃِ۔",,,27419,,
27420,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ مَکْحُولٍ ، عَن زَیْدِ بْنِ ثَابِتٍ ؛ فِی الشَّعْرِ إِذَا لَمْ یَنْبُتْ فَالدِّیَۃُ۔,,,27420,,
27421,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَن صَاعِدِ بْنِ مُسْلِمٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : فِیہِ الدِّیَۃُ۔",,,27421,,
27422,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ، عَنِ ابْنِ جُرَیْجٍ، قَالَ: قُلْتُ لِعَطَائٍ: حَلْقُ الرَّأْسِ لَہُ نَذْرٌ؟ یَعْنِی أَرْشًا، قَالَ: لَمْ أَعْلَمْ۔",,,27422,,
27423,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ حَجَّاجٍ ، عَنْ مَکْحُولٍ ، عَنْ زَیْدٍ ، قَالَ : فِی الشَّفْرِ الأَعْلَی نِصْفُ الدِّیَۃِ، وَفِی الشَّفْرِ الأَسْفَلِ ثُلُثُ الدِّیَۃِ۔",,,27423,,
27424,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَن بَیَانٍ أَبِی بِشْرٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : کَانُوا لاَ یُوقِّتُونَ فِی الأَشْفَارِ شَیْئًا۔",,,27424,,
27425,"حَدَّثَنَا أَبُو أُسَامَۃَ، عَنْ ہِشَامٍ، عَنِ الْحَسَنِ، قَالَ: فِی الأَشْفَارِ الدِّیَۃُ ، وَفِی کُلِّ وَاحِدٍ مِنْہُمَا رُبْعُ الدِّیَۃِ۔",,,27425,,
27426,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَن صَاعِدٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : فِی کُلِّ شَفْرٍ رُبْعُ الدِّیَۃِ۔",,,27426,,
27427,"حَدَّثَنَا شَبَابَۃُ، عَنْ شُعْبَۃَ، عَنْ عَبْدِ اللہِ بْنِ شُبْرُمَۃَ، قَالَ: کَانَ إِبْرَاہِیمُ یَقُولُ: فِی الأَشْفَارِ حُکْمُ ذَوِی عَدْلٍ۔",,,27427,,
27428,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ، عَنِ ابْنِ جُرَیْجٍ، قَالَ: أَخْبَرَنِی عَبْدُ الْعَزِیزِ بْنُ عُمَرَ؛ أَنَّ عُمَرَ بْنَ عَبْدِالْعَزِیزِ کَتَبَ إِلَی أُمَرَائِ الأَجْنَادِ فِی شَفْرِ الْعَیْنِ الأَعْلَی : إِذَا نُتِفَ نِصْفُ الدِّیَۃِ ، وَفِی الشَّفْرِ الأَسْفَلِ ثُلُثُ دِیَۃِ الْعَیْنِ۔",,,27428,,
27429,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَن دَاوُد ، عَنِ الشَّعْبِیِّ ، قَالَ : فِی الْجَفْنِ الأَسْفَلِ الثُّلُثَانِ ، وَفِی الأَعْلَی الثُّلُثُ۔",,,27429,,
27430,"حَدَّثَنَا حَفْصٌ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ، قَالَ : فِی الأَجْفَانِ ، فِی کُلِّ جَفْنٍ رُبْعُ الدِّیَۃِ۔",,,27430,,
27431,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ مَکْحُولٍ ، قَالَ : کَانُوا یَجْعَلُونَ فِی جَفْنَیِ الْعَیْنِ إِذَا نَدَرَا عَنِ الْعَیْنِ الدِّیَۃُ ، وَذَلِکَ أَنَّہُ لاَ بَقَائَ لِلْعَیْنِ بَعْدَہُمَا ، فَإِنْ تَفَرَّقَا جَعَلُوا فِی الأَسْفَلِ الثُّلُثُ ، وَفِی الأَعْلَی الثُّلُثَیْنِ ، وَذَلِکَ أَنَّہُ أَجْزَأُ عَنِ الْعَیْنِ مِنَ الأَسْفَلِ ، یَسْترُ وَیَکُفُّ عَنْہَا۔",,,27431,,
27432,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ عُمَرَ ؛ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ کَتَبَ إِلَی أُمَرَائِ الأَجْنَادِ : أَنْ یَکْتُبُوا إِلَیْہِ بِعِلْمِ عُلَمَائِہِمْ ، فَکَانَ مِمَّا اجْتَمَعَ عَلَیْہِ أُمَرَائُ الأَجْنَادِ : وَإِنْ مُرِطَ الشَّارِبُ فَفِیہِ سِتُّونَ دِینَارًا ، وَإِنْ مُرِطَا جَمِیعًا فَفِیہِمَا مِئَۃٌ وَعِشْرُونَ دِینَارًا۔",,,27432,,
27433,"حَدَّثَنَا ابْنُ نُمَیْرٍ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ، عَنْ مَکْحُولٍ، قَالَ: کَانُوا یَجْعَلُونَ فِی الْفَمِ إِذَا انْشَقَّ الدِّیَۃَ۔",,,27433,,
27434,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنْ مَکْحُولٍ ، عَن زَیْدِ بْنِ ثَابِتٍ ، قَالَ : إِذَا ضُرِبَ الرَّجُلُ حَتَّی یَذْہَبَ سَمْعُہُ فَفِیہِ الدِّیَۃُ۔",,,27434,,
27435,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَن یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ ضُرِبَ ، فَذَہَبَ سَمْعُہُ وَبَصَرُہُ وَکَلاَمُہُ ، قَالَ لَہُ : ثَلاَثُ دِیَاتٍ۔",,,27435,,
27436,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ عَوْفٍ ، قَالَ : سَمِعْتُ شَیْخًا قَبْلَ فِتْنَۃِ ابْنِ الأَشْعَثِ ، فَنَعَتَ نَعْتَہُ ، قَالُوا : ذَاکَ أَبُو الْمُہَلَّبِ عَمُّ أَبِی قِلاَبَۃَ ، قَالَ : رُمِیَ رَجُل بِحَجَرٍ فِی رَأْسِہِ ، فَذَہَبَ سَمْعُہُ وَلِسَانُہُ وَعَقْلُہُ وَذَکَرُہُ ، فَلَمْ یَقْرَبِ النِّسَائَ ، فَقَضَی فِیہِ عُمَرُ بِأَرْبَعِ دِیَاتٍ۔",,,27436,,
27437,"حَدَّثَنَا عُمَرُ بْنُ یُونُسَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : فِی السَّمْعِ الدِّیَۃُ۔",,,27437,,
27438,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی ابْنُ أَبِی نَجِیحٍ ، عَن مُجَاہِدٍ ، قَالَ : فِی ذَہَابِ السَّمْعِ خَمْسُونَ۔",,,27438,,
27439,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ: سَأَلْتُ عَطَائً عَنْ رَجُلٍ أُصِیبَ مِنْ أَطْرَافِہِ ، مَا قَدْرُہُ أَکْثَرُ مِنْ دِیَتِہِ ؟ فَقَالَ : مَا سَمِعْتُ فِیہِ بِشَیْئٍ ، وَإِنِّی لأَظُنُّہُ سَیُعْطَی بِکُلِّ مَا أُصِیبَ مِنْہُ ، وَإِنْ کَانَ أَکْثَرَ مِنْ دِیَتِہِ۔",,,27439,,
27440,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قَالَ ابْنُ شِہَابٍ فِی رَجُلٍ فَقَأَ عَیْنَ صَاحِبِہِ ، وَقَطَعَ أَنْفَہُ وَأُذُنَہُ ، قَالَ : یُحْسَبُ ذَلِکَ کُلُّہُ۔",,,27440,,
27441,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا سَعِیدٌ ، عَنْ قَتَادَۃَ ؛ أَنَّ الْحَسَنَ سُئِلَ عَنْ رَجُلٍ رُمِیَ بِحَجَرٍ ، أَوْ ضُرِبَ عَلَی رَأْسِہِ ، فَذَہَبَ سَمْعُہُ وَبَصَرُہُ ، وَانْقَطَعَ کَلأَمُہُ ؟ فَقَالَ : دِیَاتٌ ؛ فِی سَمْعِہِ دِیَۃٌ ، وَفِی بَصَرِہِ دِیَۃٌ ، وَفِی لِسَانِہِ دِیَۃٌ ، فَقِیلَ لِلْحَسَنِ : رَبِحَ ، فَقَالَ : وَاللَّہِ مَا رَبِحَ ، وَلاَ أَفْلَحَ۔",,,27441,,
27442,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : بَلَغَنِی أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ جَائَ إِلَیْہِ رَجُلٌ ، فَقَالَ : ضَرَبَنِی فُلاَنٌ حَتَّی صُمَّتْ إِحْدَی أُذُنَیْ ، فَقَالَ : کَیْفَ نَعْلَمُ ؟ فَقَالَ : ادْعُوا الأَطِبَّائَ ، فَدَعوہُمْ فَشَمُّوہَا ، فَقَالُوا : ہَذِہِ الصَّمَّائُ۔",,,27442,,
27443,"حَدَّثَنَا عُمَرُ بْنُ عَلِیِّ بْنِ عَطَائِ بْنِ مُقَدَّمٍ ، عَنْ حَجَّاجٍ ، عَنْ مَکْحُولٍ ، عَن زَیْدِ بْنِ ثَابِتٍ ؛ فِی الرَّجُلِ یَدَّعِی أَنَّہُ قَدْ ذَہَبَ سَمْعُہُ ، قَالَ : یُحَلَّفُ عَلَیْہِ۔",,,27443,,
27444,حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنْ بَعْضِ أَصْحَابِہِ ، عَنْ شُرَیْحٍ ؛ أَنَّ رَجُلاً ادَّعَی ذِہَابَ سَمْعِہِ ؛ فَأَمَرَ أَنْ یُحَلَّفَ عَلَیْہِ۔,,,27444,,
27445,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ؛ فِی رَجُلٍ ادَّعَی أَنَّ سَمْعَہُ قَدْ ذَہَبَ ؟ قَالَ : یَنْظُرُ إِلَیْہِ الدَّارُونَ ، یَعْنِی الأَطِبَّائَ۔",,,27445,,
27446,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنِ ابْنِ أَبِی نَجِیحٍ، عَن مُجَاہِدٍ، قَالَ: إِذَا سَمِعَ الرَّعْدَ فَغُشِیَ عَلَیْہِ فَفِیہِ الدِّیَۃُ۔",,,27446,,
27447,"حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : یُغْتَفَلُ فَیُصَاحُ بِہِ۔",,,27447,,
27448,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ قَالَ : حدَّثَنَا الزُّبَیْرُ بْنُ جُنَادَۃَ ، قَالَ : سَأَلْتُ عَطَائً عَنْ رَجُلٍ ضَرَبَ رَجُلاً فَذَہَبَ سَمْعُہُ ، وَقَدْ کَانَ سَمِیعًا ؟ قَالَ : یُتْرَکُ ، فَإِذَا اسْتَثْقَلَ نَوْمًا أُجْلِبَ حَوْلَہُ ، فَإِنْ لَمْ یَسْتَنْبِہْ کَانَتِ الدِّیَۃُ، وَإِنِ اسْتَنْبَہَ کَانَتْ حُکُومَۃٌ۔",,,27448,,
27449,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَمَّنْ سَمِعَ الْقَاسِمَ بْنَ مُحَمَّدٍ ، وَسُئِلَ عَنْ رَجُلٍ ضَرَبَ حَنْجَرَۃَ رَجُلٍ ، فَذَہَبَ صَوْتُہُ ؟ فَقَالَ : فِیہَا الدِّیَۃُ۔",,,27449,,
27450,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ مَکْحُولٍ ، عَنْ زَیْدٍ ، قَالَ : إِذَا ضُرِبَ الرَّجُلُ فَحَدِبَ ، أَوْ غُنَّ ، أَوْ بُحَّ ، فَفِی کُلِّ وَاحِدۃٍ الدِّیَۃُ۔",,,27450,,
27451,حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ عُمَرَ ؛ أَنَّ أُمَرَائَ الأَجْنَادِ اجْتَمَعُوا لِعُمَرَ بْنِ عَبْدِ الْعَزِیزِ فِی الْحَنْجَرَۃِ ، إِذَا انْکَسَرَتْ فَانْقَطَعَ الصَّوْتُ مِنَ الرَّجُلِ ، الدِّیَۃُ کَامِلَۃً۔,,,27451,,
27452,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَن یُونُسَ ، عَنِ الْحَسَنِ : إِذَا ذَہَبَ کَلاَمُہُ فَالدِّیَۃُ۔",,,27452,,
27453,حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ حَجَّاجٍ ، عَنْ مَکْحُولٍ ، عَنْ زَیْدٍ ؛ فِی الصَّعَرِ الدِّیَۃُ۔,,,27453,,
27454,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ قَالَ : أَخْبَرَنِی عَبْدُ الْعَزِیزِ بْنُ عُمَرَ : أَنَّ أُمَرَائَ الأَجْنَادِ اجْتَمَعُوا لِعُمَرَ بْنِ عَبْدِ الْعَزِیزِ فِی الصَّعَرِ ، إِذَا لَمْ یَلْتَفِتِ الرَّجُلُ إِلاَّ مَا انْحَرَفَ : خَمْسُونَ دِینَارًا۔",,,27454,,
27455,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ عُمَرَ بْنِ عَامِرٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّ رَجُلاً أَصَابَ عَیْنَ رَجُلٍ ، فَذَہَبَ بَعْضُ بَصَرِہِ وَبَقِیَ بَعْضٌ ، فَرُفِعَ ذَلِکَ إِلَی عَلِیٍّ ، فَأَمَرَ بِعَیْنِہِ الصَّحِیحَۃِ فَعُصِبَتْ ، وَأَمَرَ رَجُلاً بِبَیْضَۃٍ فَانْطَلَقَ بِہَا وَہُوَ یَنْظُرُ حَتَّی انْتَہَی بَصَرُہُ ، ثُمَّ خَطَّ عَندَ ذَلِکَ عَلَمًا ، قَالَ : ثُمَّ نَظَرَ فِی ذَلِکَ فَوَجَدُوہُ سَوَائً ، فَقَالَ : فَأَعْطوہُ بِقَدْرِ مَا نَقَصَ مِنْ بَصَرِہِ مِنْ مَالِ الآخَرِ۔",,,27455,,
27456,"حدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنْ الْحَسَنِ ؛ فِی رَجُلٍ فَقَأَ عَیْنَ رَجُلٍ ، وَہُوَ یُبْصِرُ بِہَا ، قَالَ : یَغْرَمُ بِقَدْرِ مَا نَقَصَ مِنْہَا۔",,,27456,,
27457,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قَالَ عَطَائٌ : فِی الْعَیْنِ خَمْسُونَ ، قَالَ : فَذَہَبَ بَعْضُ بَصَرِہَا وَبَقِیَ بَعْضٌ ، قَالَ : بِحِسَابِ مَا ذَہَبَ ، قَالَ : یَمْسِکُ عَلَی الصَّحِیحَۃِ ، فَیَنْظُرُ بِالأُخْرَی ، ثُمَّ یَمْسِکُ عَلَی الأُخْرَی ، فَیَنْظُرُ بِالصَّحِیحَۃِ ، فَیُحْسَبُ مَا ذَہَبَ مِنْہَا۔\n\nقُلْتُ : ضَعُفَتْ عَیْنُہُ مِنْ کِبَرٍ فَأُصِیبَتْ ، قَالَ : نَذْرُہَا وَافِیًا۔",,,27457,,
27458,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَن حَسَنٍ ، عَن بَیَانٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : ذُکِرَ قَوْلُ عَلِیٍّ فِی الَّذِی أُصِیبَتْ عَیْنُہُ حَیْثُ أَرَاہُ الْبَیْضَۃَ ، فَقَالَ الشَّعْبِیُّ : إِنَّہُ إِنْ شَائَ زَادَ فِی عَیْنِہِ الَّتِی یُبْصِرُ بِہَا ، فَقَالَ : إِنَّہُ یُبْصِرُ بِہَا أَکْثَرَ مِمَّا یُبْصِرُ بِہَا ، وَإِنْ شَائَ نَقَصَ مِنْ عَیْنِہِ الَّتِی أُصِیبَتْ ، فَقَالَ : إِنَّہُ لاَ یُبْصِرُ بِہَا وَہُوَ یُبْصِرُ بِہَا ، وَلَکِنَّ أَمْثَلَ مِنْ ذَلِکَ أَنْ یَنْظُرَ طَبِیبٌ مَا یَرَی ، فَیَنْظُرُ مَا نَقَصَ مِنْہَا۔",,,27458,,
27459,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَجَّاجٍ ، عَنْ مَکْحُولٍ ، عَنْ زَیْدٍ ؛ فِی الشَّفَۃِ السُّفْلَی ثُلُثَا الدِّیَۃِ ، لأَنَّہَا تَحْبِسُ الطَّعَامَ وَالشَّرَابَ ، وَفِی الْعُلْیَا ثُلُثُ الدِّیَۃِ۔,,,27459,,
27460,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ فِی السُّفْلَی ثُلُثَا الدِّیَۃِ ، وَفِی الْعُلْیَا ثُلُثُ الدِّیَۃِ۔,,,27460,,
27461,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، أَنَّہُ قَالَ : فِی الشَّفَتَیْنِ الدِّیَۃُ ؛ فِی السُّفْلَی ثُلُثَا الدِّیَۃِ ، وَفِی الْعُلْیَا ثُلُثُ الدِّیَۃِ۔",,,27461,,
27462,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : فِی الشَّفَتَیْنِ الدِّیَۃُ ، وَفِی إِحْدَاہُمَا نِصْفُ الدِّیَۃِ۔",,,27462,,
27463,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنْ شُرَیْحٍ ؛ فِی الشَّفَتَیْنِ الدِّیَۃُ۔,,,27463,,
27464,"حَدَّثَنَا وَکِیعٌ ، عَن زَکَرِیَّا ، عَنْ عَامِرٍ ، قَالَ : فِی الشَّفَتَیْنِ الدِّیَۃُ ، وَفِی کُلِّ وَاحِدَۃٍ مِنْہُمَا نِصْفٌ۔",,,27464,,
27465,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَن مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانَ یُقَالُ : مَا کَانَ مِنَ اثْنَیْنِ فِی الإِنْسَان فَفِیہِمَا الدِّیَۃُ ، وَفِی کُلِّ وَاحِدَۃٍ مِنْہُمَا نِصْفُ الدِّیَۃِ ، وَمَا کَانَ مِنْ وَاحِدٍ فَفِیہِ الدِّیَۃُ۔",,,27465,,
27466,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، قَالَ : قضَی أَبُو بَکْرٍ فِی الشَّفَتَیْنِ بِالدِّیَۃِ ، مِئَۃٌ مِنَ الإِبِلِ۔",,,27466,,
27467,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : الشَّفَتَانِ مَا فِیہِمَا ؟ قَالَ : خَمْسُونَ خَمْسُونَ مِنَ الإِبِلِ فِی کُلِّ وَاحِدَۃٍ ، قُلْتُ : أَیُفَضَّلُ بَیْنَہُمَا ؟ قَالَ : السُّفْلَی تُفَضَّلُ ، زَعَمُوا ، قُلْتُ : بِکَمْ ؟ قَالَ : لاَ أَدْرِی۔",,,27467,,
27468,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی ابْنُ أَبِی نَجِیحٍ ، عَن مُجَاہِدَ ، أَنَّہُ قَالَ : فِی الشَّفَتَیْنِ خَمْسُونَ خَمْسُونَ ، وَتُفَضَّلُ السُّفْلَی عَلَی الْعُلْیَا مِنَ الرَّجُلِ وَالْمَرْأَۃِ بِالتَّغْلِیظِ ، وَلاَ تُفَضَّلُ بِالزِّیَادَۃِ فِی عَدَدٍ ، وَلَکِنَّ الْخَمْسِینَ فِیہَا تَغْلِیظٌ فِی أَسْنَانِ الإِبِلِ۔",,,27468,,
27469,"حَدَّثَنَا صَفْوَانُ بْنُ عِیسَی ، عَنْ مَعْمَرٍ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَن مُجَاہِدٍ ، قَالَ : الشَّفَتَانِ سَوَائٌ ؛ النِّصْفُ وَالنِّصْفُ۔",,,27469,,
27470,"حَدَّثَنَا حَفْصٌ، عَنِ الشَّیْبَانِیِّ، عَنِ الشَّعْبِیِّ، قَالَ: فِی الشَّفَتَیْنِ الدِّیَۃُ، فِی السُّفْلَی الثُّلُثَانِ، وَفِی الْعُلْیَا الثُّلُثُ۔",,,27470,,
27471,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ أَبِی لَیْلَی ، عَن عِکْرِمَۃَ بْنِ خَالِدٍ ، عَنْ رَجُلٍ مِنْ آلِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : فِی اللِّسَانِ الدِّیَۃُ کَامِلَۃً۔",,,27471,,
27472,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ أَشْعَثَ ، عَنِ الزُّہْرِیِّ ، رَفَعَہُ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : فِی اللِّسَانِ إِذَا اسْتُؤْصِلَ الدِّیَۃُ کَامِلَۃً۔",,,27472,,
27473,حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ مَکْحُولٍ ، رَفَعَہُ ، مِثْلَہُ۔,,,27473,,
27474,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ ، عَنْ عَلِیٍّ ، قَالَ : فِی اللِّسَانِ الدِّیَۃُ۔",,,27474,,
27475,حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، عَنْ عَبْدِ اللہِ ؛ فِی اللِّسَانِ إِذَا اسْتُؤْصِلَ الدِّیَۃُ أَخْمَاسًا ، فَمَا نَقَصَ فَبِالْحِسَابِ۔,,,27475,,
27476,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : فِی اللِّسَانِ الدِّیَۃُ کَامِلَۃً ، وَمَا أُصِیبَ مِنَ اللِّسَانِ ، فَبَلَغَ أَنْ یَمْنَعَ الْکَلاَمَ فَفِیہِ الدِّیَۃُ کَامِلَۃً۔",,,27476,,
27477,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : فِی عُکَدَۃِ اللِّسَانِ۔",,,27477,,
27478,حَدَّثَنَا ہُشَیْمٌ ، عَن یُونُسَ ، عَنِ الْحَسَنِ ، مِثْلَہُ۔,,,27478,,
27479,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ عُمَرَ بْنِ عَامِرٍ ، عَنْ مَکْحُولٍ ، عَن زَیْدِ بْنِ ثَابِتٍ ، قَالَ : فِی اللِّسَانِ إِذَا انْشَقَّ ، ثُمَّ الْتَأَمَ عِشْرُونَ بَعِیرًا۔",,,27479,,
27480,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : اللِّسَانُ یُقْطَعُ کُلُّہُ ؟ قَالَ : الدِّیَۃُ۔",,,27480,,
27481,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، قَالَ : قضَی أَبُو بَکْرٍ الصِّدِّیقُ فِی اللِّسَانِ إِذَا قُطِعَ بِالدِّیَۃِ ، إِذَا أُوْعِبَ مِنْ أَصْلِہِ ، وَإِذَا قُطِعَتْ أَسَلَتُہُ فَتَکَلَّمَ صَاحِبُہُ ، فَفِیہِ نِصْفُ الدِّیَۃِ۔\n\n(بیہقی 89)",,,27481,,
27482,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قَالَ سُلَیْمَانُ بْنُ مُوسَی : فِی کِتَابِ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ : مَا قُطِعَ مِنَ اللِّسَانِ فَبَلَغَ أَنْ یَمْنَعَ الْکَلاَمَ کُلَّہُ فَفِیہِ الدِّیَۃُ ، وَمَا نَقَصَ دُونَ ذَلِکَ فَبِحِسَابِہِ۔",,,27482,,
27483,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی عَبْدُ الْعَزِیزِ بْنُ عُمَرَ ، أَنَّ فِی کِتَابٍ لِعُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، عَنْ عُمَرَ بْنِ الْخَطَّابِ ؛ فِی اللِّسَانِ إِذَا اسْتُؤْصِلَ الدِّیَۃُ کَامِلَۃً ، وَمَا أُصِیبَ مِنَ اللِّسَانِ فَبَلَغَ أَنْ یَمْنَعَ الْکَلاَمَ فَفِیہِ الدِّیَۃُ کَامِلَۃً ، وَفِی لِسَانِ الْمَرْأَۃِ الدِّیَۃُ کَامِلَۃً ، وَمَا أُصِیبَ مِنْ لِسَانِہَا فَبَلَغَ أَنْ یَمْنَعَ الْکَلاَمَ فَفِیْہِ الدِّیَۃُ کَامِلَۃً ، وَمَا کَانَ دُونَ ذَلِکَ فَبِحِسَابِہِ۔ (ابوداؤد 261)",,,27483,,
27484,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ عَاصِمٍ ، عَنْ عَلِیٍّ ، قَالَ : فِی اللِّسَانِ الدِّیَۃُ۔",,,27484,,
27485,"حَدَّثَنَا وَکِیعٌ ، عَن سَلاَّمٍ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : فِیہِ الدِّیَۃُ۔",,,27485,,
27486,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی عَبْدُ الْعَزِیزِ بْنُ عُمَرَ ؛ أَنَّ أُمَرَائَ الأَجْنَادِ اجْتَمَعُوا لِعُمَرَ بْنِ عَبْدِ الْعَزِیزِ فِی الذَّقَنِ ثُلُثُ الدِّیَۃِ۔",,,27486,,
27487,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : بَلَغَنِی عَنِ الشَّعْبِیِّ ، أَنَّہُ قَالَ : فِی اللَّحْی إِذَا کُسِرَ أَرْبَعُونَ دِینَارًا۔",,,27487,,
27488,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : حُدِّثْتُ عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، أَنَّہُ قَالَ : فِی فَقَمِی الإِنْسَانِ أَنْ یَثْنِیَ إِبْہَامَہُ ، ثُمَّ یَجْعَلَ قَصَبَتَہُ السُّفْلَی ، وَیَفْتَحَ فَاہُ فَیَجْعَلَہَا بَیْنَ لَحْیَیْہِ ، فَمَا نَقَصَ مِنْ فَتْحِہِ فَاہُ مِنْ قَصَبَۃِ إِبْہَامِہِ السُّفْلَی کَانَ بِحِسَابِہِ۔",,,27488,,
27489,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا ابْنُ أَبِی لَیْلَی ، عَن عِکْرِمَۃَ بْنِ خَالِدٍ ، عَنْ رَجُلٍ مِنْ آلِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : فِی الْیَدِ خَمْسُونَ۔ (ابوداؤد 4553۔ احمد 217)",,,27489,,
27490,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ مُحَمَّدِ بْنِ عُمَارَۃَ ، عَنْ أَبِی بَکْرِ بْنِ عَمْرِو بْنِ حَزْمٍ ، قَالَ : کَانَ فِی کِتَابِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لِعَمْرِو بْنِ حَزْمٍ : فِی الْیَدِ خَمْسُونَ۔ (نسائی 7059)",,,27490,,
27491,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ ، عَنْ عَلِیٍّ ، قَالَ : فِی الْیَدِ نِصْفُ الدِّیَۃِ۔",,,27491,,
27492,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، عَنْ عَلِیٍّ ، قَالَ : فِی الْیَدِ نِصْفُ الدِّیَۃِ ، خَمْسُونَ مِنَ الإِبِلِ أَرْبَاعًا ، رُبْعٌ جِذَاعٌ ، وَرُبْعٌ حِقَاقٌ ، وَرُبْعٌ بَنَاتُ لَبُونٍ ، وَرُبْعٌ بَنَاتُ مَخَاضٍ۔",,,27492,,
27493,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمٍ ، عَنْ عَلِیِّ ، قَالَ : فِی الْیَدِ نِصْفُ الدِّیَۃِ۔",,,27493,,
27494,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَشْعَثَ ، عَنْ عَامِرٍ ، عَنْ عَبْدِ اللہِ ، قَالَ : فِی الْیَدِ نِصْفُ الدِّیَۃِ أَخْمَاسًا۔",,,27494,,
27495,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَن حَکِیمِ بْنِ حَکِیمٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، قَالَ : کَانَ فِیمَا وَضَعَ أَبُو بَکْرٍ ، وَعُمَرُ مِنَ الْقَضِیَّۃِ فِی الْجِرَاحَۃِ : الْیَدُ إِذَا لَمْ یَأْکُلْ بِہَا صَاحِبُہَا ، وَلَمْ یَأْتَزِرْ ، وَلَمْ یَسْتَطِبْ بِہَا ، فَقَدْ تَمَّ عَقْلُہَا ، فَمَا نَقَصَ فَبِحِسَابٍ۔",,,27495,,
27496,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قَالَ عَطَائٌ : فِی الْیَدِ تُسْتَأْصَلُ خَمْسُونَ ، قُلْتُ : أَمِنَ الْمَنْکِبِ ، أَوْ مِنَ الْکَتِفِ ؟ قَالَ : لاَ ، بَلْ مِنَ الْمَنْکِبِ۔",,,27496,,
27497,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَن مُجَاہِدٍ ، قَالَ : إِنْ قُطِعَتِ الأَصَابِعُ فَالدِّیَۃُ ، وَإِنْ قُطِعَتِ الْکَفُّ فَخَمْسُونَ مِنَ الإِبِلِ۔",,,27497,,
27498,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : إِذَا قُطِعَتِ الْیَدُ مِنَ الْمِفْصَلِ فَفِیہَا نِصْفُ الدِّیَۃِ ، وَإِذَا قُطِعَتْ مِنَ الْعَضُدِ فَفِیہَا نِصْفُ الدِّیَۃِ۔",,,27498,,
27499,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، عَن مَسْرُوقٍ ، عَنْ عَبْدِ اللہِ ، قَالَ : الْیَدَانِ سَوَائٌ۔",,,27499,,
27500,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا قُطِعَتِ الْکَفُّ مِنَ الْمِفْصَلِ ، فَإِنَّ فِیہَا دِیَتُہَا ، فَإِنْ قُطِعَ مِنْہُمَا شَیْئٌ بَعْدَ ذَلِکَ فَفِیہَا حُکُومَۃُ عَدْلٍ ، وَإِذَا قُطِعَتْ مِنَ الْعَضُدِ ، أَوْ أَسْفَلَ مِنَ الْعَضُدِ شَیْئًا ، فَإِنَّ فِیہَا دِیَتُہَا۔",,,27500,,
27501,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : أَرَأَیْتَ إِنْ قُطِعَتِ الْیَدُ مِنْ شَطْرِ الذِّرَاعِ ؟ قَالَ : خَمْسُونَ ، قُلْتُ : فَقُطِعَ شَیْئٌ مِمَّا بَقِیَ بَعْدُ ؟ قَالَ : جُرْحٌ ، لاَ أَحْسِبُ إِلاَّ ذَلِکَ ، إِلاَّ أَنْ یَکُونَ فِی ذَلِکَ سُنَّۃٌ۔",,,27501,,
27502,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی ابْنُ أَبِی نَجِیحٍ ، عَن مُجَاہِدٍ ، قَالَ : إِنْ قُطِعَتِ الْکَفُّ فَخَمْسُونَ مِنَ الإِبِلِ ، فَإِنْ قُطِعَ مَا بَقِیَ مِنَ الْیَدِ کُلِّہَا ، أَوِ الذِّرَاعِ ، أَوْ قُطِعَ نِصْفُ الذِّرَاعِ : فَنِصْفُ نَذْرِ الْیَدِ أَیْضًا ، خَمْسَۃٌ وَعِشْرُونَ ، فَإِنْ کَانَتْ إِنَّمَا قُطِعَتْ مِنْ شَطْرِ ذِرَاعِہَا ، أَوِ الذِّرَاعِ بَعْدَ الْکَفِّ ، قَالَ مُجَاہِدٌ : یَقُولُ ذَلِکَ ، فَنِصْفُ نَذْرِ الْیَدِ ، فَإِنْ قُطِعَ مَا بَقِیَ کُلُّہُ فَجُرْحٌ یُرَی فِیْہِ۔ (عبدالرزاق 17689)",,,27502,,
27503,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَن زَیْدِ بْنِ أَسْلَمَ ، عَن مُسْلِمِ بْنِ جُنْدُبٍ ، عَنْ أَسْلَمَ مَوْلَی عُمَرَ ، قَالَ : سَمِعْتُ عُمَرَ یَقُولُ عَلَی الْمِنْبَرِ : فِی التَّرْقُوَۃِ جَمَلٌ۔",,,27503,,
27504,حَدَّثَنَا عَبْدُالرَّحِیمِ، عَنْ حَجَّاجٍ، عَن جُنْدُبٍ الْقَاصِّ، عَنْ أَسْلَمَ مَوْلَی عُمَرَ؛ أَنَّہُ قَضَی فِی التَّرْقُوَۃِ بِبَعِیر۔,,,27504,,
27505,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَجَّاجٍ ، عَن دَاوُد بْنِ أَبِی عَاصِمٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : فِی التَّرْقُوَۃِ بَعِیرٌ۔",,,27505,,
27506,"حَدَّثَنَا وَکِیعٌ ، وَأَبُو خَالِدٍ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی بِشْرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : فِی التَّرْقُوَۃِ بَعِیرَانِ۔",,,27506,,
27507,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ جَابِرٍ ، عَنِ الشَّعْبِیِّ ، عَن مَسْرُوقٍ ، قَالَ : فِی التَّرْقُوَۃِ حُکْمٌ۔",,,27507,,
27508,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَبْدِ الْکَرِیمِ ، عَن مُجَاہِدٍ ، وَالشُّعَبِیِّ ؛ قَالاَ : إِنْ کُسِرَتْ فَأَرْبَعُونَ دِینَارًا۔",,,27508,,
27509,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی عَبْدُ الْکَرِیمِ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، قَالَ : إِنْ قُطِعَتِ التَّرْقُوَۃُ فَلَمْ یَعِشْ فَلَہُ الدِّیَۃُ کَامِلَۃً ، فَإِنْ عَاشَ فَفِیہَا خَمْسُونَ مِنَ الإِبِلِ۔",,,27509,,
27510,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، عَنْ قَتَادَۃَ ، قَالَ : إِذَا انْجَبَرَتِ التَّرْقُوَۃُ فَفِیہَا أَرْبَعَۃُ أَبْعِرَۃٍ ، یَعْنِی مَثَلَ بِالوَجُور۔",,,27510,,
27511,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، قَالَ : قضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی السِّنِّ بِخَمْسٍ مِنَ الإِبِلِ۔\n\nقَالَ: وَقَالَ أَبِی: یُفَضَّلُ بَعْضُہَا عَلَی بَعْضٍ، بِمَا یَرَی أَہْلُ الرَّأْیِ وَالْمَشْورَۃِ۔(ابوداؤد 261۔ عبدالرزاق 17490)",,,27511,,
27512,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا سَعِیدُ بْنُ أَبِی عَرُوبَۃَ ، عَنْ مَطَرٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : فِی الأَسْنَانِ خَمْسٌ خَمْسٌ۔ \n\n(ابوداؤد 4553۔ احمد 182)",,,27512,,
27513,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَن حُسَیْنِ الْمُعَلِّمِ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : فِی السِّنِّ خَمْسٌ۔ (ابوداؤد 4552۔ نسائی 7045)",,,27513,,
27514,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : فِی السِّنِّ خَمْسٌ مِنَ الإِبِلِ ، أَوْ عَدْلُ ذَلِکَ مِنَ الذَّہَبِ ، أَوِ الْوَرِقِ۔",,,27514,,
27515,"حَدَّثَنَا وَکِیعٌ ، عن مَالِکِ بْنِ أَنَسٍ ، عَنْ دَاوُدَ بْنُ حُصَیْنٍ ، عَنْ أَبِی غَطَفَانَ الْمُرِّیِّ ، عَنِ ابْنِ عَبَّاسٍ قَالَ: الأَسْنَانُ سَوَائٌ ؛ اعْتَبرہَا بِالأَصَابِعِ۔",,,27515,,
27516,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَن سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنْ شُرَیْحٍ ، قَالَ : الأَسْنَانُ سَوَائٌ۔",,,27516,,
27517,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، عَنْ شُرَیْحٍ ، قَالَ : أَتَانِی عُرْوَۃُ الْبَارِقِیُّ مِنْ عَندِ عُمَرَ : أَنَّ الأَصَابِعَ وَالأَسْنَانَ فِی الدِّیَۃِ سَوَائٌ۔",,,27517,,
27518,"حَدَّثَنَا وَکِیعٌ، عَنْ ہِشَامٍ، عَنْ أَبِیہِ، قَالَ: الأَسْنَانُ سَوَائٌ، وَقَالَ: إِنْ کَانَ لِلثَّنِیَّۃِ جَمَالٌ فَإِنَّ لِلضِّرْسِ مَنْفَعَۃً۔",,,27518,,
27519,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، قَالَ : ہِیَ سَوَائٌ۔",,,27519,,
27520,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَن مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : ہی فِی الدِّیَۃِ سَوَائٌ۔",,,27520,,
27521,"حَدَّثَنَا حَفْصٌ ، وَأَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : أَشْہَدُ عَلَی شُرَیْحٍ ،وَمَسْرُوقٍ أَنَّہُمَا جَعَلاَ الأَصَابِعَ وَالأَسْنَانَ فِی الدِّیَۃِ سَوَائً۔",,,27521,,
27522,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ ، قَالَ : فِی السِّنِّ خَمْسٌ مِنَ الإِبِلِ۔",,,27522,,
27523,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، قَالَ : حدَّثَنَا عِکْرِمَۃُ بْنُ خَالِدٍ ، عَنْ رَجُلٍ مِنْ آلِ عُمَرَ ؛ قَضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی السِّنِّ خَمْسٌ مِنَ الإِبِلِ۔",,,27523,,
27524,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنَی سُلَیْمَانُ بْنُ مُوسَی ؛ أَنَّ فِی کِتَابِ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ إِلَی أُمَرَائِ الأَجْنَادِ : وَفِی الأَسْنَانِ خَمْسٌ مِنَ الإِبِلِ۔",,,27524,,
27525,"حَدَّثَنَا ابْنُ فُضَیْلٍ، عَنْ أَشْعَثَ، عَنِ الشَّعْبِیِّ ، عَنْ عَبْدِ اللہِ ، قَالَ : فِی السِّنِّ خَمْسٌ مِنَ الإِبِلِ أَخْمَاسًا۔",,,27525,,
27526,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، عَن مَسْرُوقٍ ، عَنْ عَبْدِ اللہِ ، قَالَ : الأَسْنَانُ سَوَائٌ۔",,,27526,,
27527,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَن یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : فِی الأَسْنَانِ خَمْسٌ خَمْسٌ۔",,,27527,,
27528,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قَالَ لِی عَطَائٌ : فِی الأَسْنَانِ الثَّنِیَّتَیْنِ ، والرَّباعِیَّتیْن ، وَالنَّابَیْنِ خَمْسٌ خَمْسٌ ، وَفِیمَا بَقِیَ بَعِیرَانِ بَعِیرَانِ ، أَعْلَی الْفَمِ مِنْ ذَلِکَ وَأَسْفَلہُ سَوَائٌ ، ثَنِیَّتَا ، وَرَبَاعِیَتَا ، وَنَابَا أَعْلَی الْفَمِ وَأَسْفَلِہِ سَوَائٌ ، وَأَضْرَاسُ أَعْلَی الْفَمِ ، وَأَضْرَاسُ أَسْفَلِ الْفَمِ سَوَائٌ۔",,,27528,,
27529,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخَبَرَنِی ابْنُ أَبِی نُجَیٍحٍ ، عَنْ مُجَاہِدٍ ؛ مِثْلَ قَوْلِ عَطَائٍ ، قَالَ : الأَسْنَانُ مِنْ أَعْلَی الْفَمِ وَأَسْفَلِہِ ، وَالأَضْرَاسُ مِنْ أَعْلَی الْفَمِ وَأَسْفَلِہِ ، سَوَائٌ۔",,,27529,,
27530,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ، عَنِ ابْنِ طَاوُوسٍ، قَالَ: قَالَ أَبِی: یُفَضَّلُ بَعْضُہَا عَلَی بَعْضٍ، بِمَا یَرَی أَہْلُ الرَّأْیِ وَالْمَشْورَۃِ۔",,,27530,,
27531,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی عَمْرُو بْنُ مُسْلِمٍ ؛ أَنَّہُ سَمِعَ طَاوُوسًا ، یَقُولُ : تُفَضَّلُ السِّتُّ فِی أَعْلَی الْفَمِ وَأَسْفَلِہِ عَلَی الأَضْرَاسِ ، وَأَنَّہُ قَالَ : فِی الأَضْرَاسِ صِغَارُ الإِبِلِ۔",,,27531,,
27532,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّ عُمَرَ بْنَ الْخَطَّابِ قَضَی فِیمَا أَقْبَلَ مِنَ الْفَمِ بِخَمْسِ فَرَائِضَ خَمْسٍ ، وَذَلِکَ خَمْسُونَ دِینَارًا ، قِیمَۃُ کُلِّ فَرِیضَۃٍ عَشَرَۃُ دَنَانِیرَ ، وَفِی الأَضْرَاسِ بَعِیرٌ بَعِیرٌ۔\n\nوَذَکَرَ یَحْیَی : أَنَّ مَا أَقْبَلَ مِنَ الْفَمِ ؛ الثَّنَایَا ، وَالرَّبَاعِیَاتُ ، وَالأَنْیَابُ۔\n\nقَالَ سَعِیدٌ : حتَّی إِذَا کَانَ مُعَاوِیَۃُ فَأُصِیبَتْ أَضْرَاسُہُ ، قَالَ : أَنَا أَعْلَمُ بِالأَضْرَاسِ مِنْ عُمَرَ ، فَقَضَی فِیہِ خَمْسَ فَرَائِضَ ۔ قَالَ سَعِیدٌ : لَوْ أُصِیبَ الْفَمُ کُلُّہُ فِی قَضَائِ عُمَرَ لَنَقَصَتِ الدِّیَۃُ ، وَلَوْ أُصِیبَ فِی قَضَائِ مُعَاوِیَۃَ لَزَادَتِ الدِّیَۃُ ، وَلَوْ کُنْتُ أَنَا لَجَعَلْتُ فِی الأَضْرَاسِ بَعِیرَیْنِ بَعِیرَیْنِ۔",,,27532,,
27533,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ قَتَادَۃَ ، عَن عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : ہَذِہِ وَہَذِہِ سَوَائٌ ، یَعْنِی الْخِنْصَرَ وَالإِبْہَامَ۔ (بخاری 6895۔ ابوداؤد 4546)",,,27533,,
27534,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : قَالَ شُرَیْحٌ : أَتَانِی عُرْوَۃُ الْبَارِقِیُّ مِنْ عِندَ عُمَرَ : أَنَّ الأَصَابِعَ فِی الدِّیَۃِ سَوَائٌ۔",,,27534,,
27535,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ حَجَّاجٍ ، عَنْ مَکْحُولٍ ، عَنْ زَیْدٍ بْنِ ثَابِتٍ ، قَالَ : الأَصَابِعُ سَوَائٌ۔",,,27535,,
27536,"حَدَّثَنَا أَبُو خَالِدٍ ، وَوَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ؛ أَنَّہُ قَالَ : ہِیَ سَوَائٌ۔",,,27536,,
27537,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَن مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : الدِّیَۃُ فِی الأَصَابِعِ سَوَائٌ۔",,,27537,,
27538,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، قَالَ : وَجَدْتُ فِی کِتَابِی عَن حُمَیْدٍ ، عَن بَکْرٍ ، عَنْ ہِشَامِ بْنِ ہُبَیْرَۃَ ؛ أَنَّ ابْنَ عُمَرَ ، وَابْنَ عَبَّاسٍ ، قَالاَ : الأَصَابِعُ سَوَائٌ ، أَوْ ہَذِہِ وَہَذِہِ سَوَائٌ۔",,,27538,,
27539,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، وَأَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : أَشْہَدُ عَلَی شُرَیْحٍ ، وَمَسْرُوقٍ ، أَنَّہُمَا جَعَلاَ الأَصَابِعَ وَالأَسْنَانَ سَوَائً۔",,,27539,,
27540,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، وَمُحَمَّدٍ ، قَالاَ : الأَصَابِعُ سَوَائٌ ، عَشْرٌ عَشْرٌ۔",,,27540,,
27541,"حَدَّثَنَا إِسْمَاعِیلُ بْنُ إِبْرَاہِیمَ ، عَن غَالِبٍ التَّمَّارِ ، عَن مَسْرُوقِ بْنِ أَوْسٍ ، عَنْ أَبِی مُوسَی ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أَنَّہُ قَالَ : فِی الأَصَابِعِ عَشْرٌ عَشْرٌ۔ (ابوداؤد 4545۔ احمد 397)",,,27541,,
27542,حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، وَأَبُو أُسَامَۃَ ، عَنْ سَعِیدٍ ، عَن غَالِبِ التَّمَّارِ ، عنْ حُمَیْدِ بْنِ ہِلاَلٍ ، عَن مَسْرُوقِ بْنِ أَوْسٍ ، عَنْ أَبِی مُوسَی ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَضَی فِی الأَصَابِعِ بِعَشْرٍ مِنَ الإِبِلِ۔ (ابوداؤد 4544۔ ابن ماجہ 2654),,,27542,,
27543,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، عَنْ سَعِیدِ ، عَنْ مَطَرٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَضَی فِی الأَصَابِعِ : عَشْرٌ عَشْرٌ۔ (ابوداؤد 4551۔ احمد 215)",,,27543,,
27544,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَن عِکْرِمَۃَ بْنِ خَالِدٍ ، عَنْ رَجُلٍ مِنْ آلِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : فِی کُلِّ إِصْبَعٍ مِمَّا ہُنَالِکَ عَشْرٌ مِنَ الإِبِلِ۔",,,27544,,
27545,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، عَنْ عَلِیٍّ ، وَعَبْدِ اللہِ ، قَالاَ : فِی الأَصَابِعِ ، فِی کُلِّ إِصْبَعٍ عُشْرُ الدِّیَۃِ۔",,,27545,,
27546,"حَدَّثَنَا أَبُو الأَحْوَصِ، عَنْ أَبِی إِسْحَاقَ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ، عَنْ عَلِیٍّ، قَالَ: فِی الإِصْبَعِ عُشْرُ الدِّیَۃِ۔",,,27546,,
27547,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ؛ فِی کُلِّ إِصْبَعٍ عَشْرٌ مِنَ الإِبِلِ ، أَوْ عَدْلُ ذَلِکَ مِنْ ذَہَبٍ ، أَوْ وَرِقٍ۔,,,27547,,
27548,حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃٍ ، عَنْ إِبْرَاہِیمَ ؛ فِی کُلِّ إِصْبَعٍ خُمْسُ الدِّیَۃِ أَخْمَاسًا۔,,,27548,,
27549,"حَدَّثَنَا عَبْدُاللہِ بْنُ نُمَیْرٍ، عَنْ إِسْمَاعِیلَ بْنِ أَبِی خَالِدٍ، عَنِ الشَّعْبِیِّ، قَالَ: الأَصَابِعُ کُلُّہَا سَوَائٌ، فِیہَا الْعُشْرُ۔",,,27549,,
27550,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : فِی کُلِّ إِصْبَعٍ عَشْرِ فَرَائِضَ۔",,,27550,,
27551,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الزُّہْرِیِّ ، قَالَ : قضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی کُلِّ إِصْبَعٍ مِمَّا ہُنَالِکَ عُشْرُ الدِّیَۃِ۔",,,27551,,
27552,حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّ عُمَرَ قَضَی فِی الإِبْہَامِ وَالَّتِی تَلِیہَا بِکَفِکَ نِصْفُ الْکَفِّ، وَفِی الْوُسْطَی بِعَشْرِ فَرَائِضَ، وَالَّتِی تَلِیہَا بِتِسْعِ فَرَائِضَ، وَفِی الْخِنْصَرِ بِسِتِّ فَرَائِضَ۔,,,27552,,
27553,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، وَمُحَمَّدٍ ، قَالاَ : الأَصَابِعُ عَشْرٌ عَشْرٌ۔",,,27553,,
27554,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ عَلِیٍّ ، وَابْنِ مَسْعُودٍ ، وَابْنِ عَبَّاسٍ ، وَالْحَسَنِ ، کَانُوا یَقُولُونَ : فِی الأَصَابِعِ کُلِّہَا عَشْرٌ عَشْرٌ۔",,,27554,,
27555,"حَدَّثَنَا إِسْمَاعِیلُ بْنُ إِبْرَاہِیمَ ، عَن خَالِدِ الْحَذَّائِ ، عَنْ أَبِی قِلاَبَۃَ ، عَنْ عَمْرِو بْنِ سَلِمَۃَ قَالَ : کَتَبَ إِلَیْنَا عَبْدُ الْمَلِکِ بْنُ مَرْوَانَ ، وَنَحْنُ مَعَ خَالِدِ بْنِ عَبْدِ اللہِ : أَنَّ الأَصَابِعَ أَثْلاَثًا ، وَقَرَنَ خَالِدٌ بَیْنَ الْخِنْصَرِ وَالْبِنْصَرِ ، وَبَیْنَ الْوُسْطَی وَالَّتِی تَلِیہَا ، وَالإِبْہَامُ عَلَی حِدَۃٍ۔",,,27555,,
27556,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَن مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : فِی کُلِّ مِفْصَلٍ مِنَ الأَصَابِعِ ثُلُثُ دِیَۃِ الإِصْبَعِ ، إِلاَّ الإِبْہَامَ فَإِنَّ فِی کُلِّ مِفْصَلٍ نِصْفَ دِیَتِہَا۔",,,27556,,
27557,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَن مُجَاہِدٍ ، قَالَ : فِی الإِبْہَامِ خَمْسَ عَشْرَۃَ ، وَفِی الَّتِی تَلِیہَا عَشْرٌ ، وَفِی الَّتِی تَلِیہَا عَشْرٌ ، وَفِی الَّتِی تَلِیہَا ثَمَانٌ ، وَفِی الَّتِی تَلِیہَا سَبْعٌ۔",,,27557,,
27558,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ حَجَّاجٍ ، عَنْ زَیْدٍ ؛ أَنَّہُ قَالَ : فِی الأَصَابِعِ فِی کُلِّ مِفْصَلٍ ثُلُثُ دِیَۃِ الإِصْبَعِ ، إِلاَّ الإِبْہَامَ ، فَإِنَّ فِیہَا نِصْفَ دِیَتِہَا إِذَا قُطِعَتْ مِنَ الْمِفْصَلِ ، لأَنَّ فِیہَا مِفْصَلَیْنِ۔",,,27558,,
27559,حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّ الْقَضَائَ فِی الأَصَابِعِ فِی الْیَدَیْنِ وَالرِّجْلَیْنِ صَارَ إِلَی عَشْرٍ مِنَ الإِبِلِ۔,,,27559,,
27560,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ؛ أَنَّ ہِشَامَ بْنَ ہُبَیْرَۃَ کَتَبَ إِلَی شُرَیْحٍ یَسْأَلُہُ ، فَکَتَبَ إِلَیْہِ : إِنَّ أَصَابِعَ الرِّجْلَیْنِ وَالْیَدَیْنِ سَوَائٌ۔",,,27560,,
27561,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ ، قَالَ : أَصَابِعُ الْیَدَیْنِ وَالرِّجْلَیْنِ سَوَائٌ۔",,,27561,,
27562,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ أَبِی حَنِیفَۃَ ، عَن حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : أَصَابِعُ الْیَدَیْنِ وَالرِّجْلَیْنِ سَوَائٌ۔",,,27562,,
27563,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ قَتَادَۃَ ، عَنْ أَبِی مِجْلَزٍ ؛ أَنَّ رَجُلاً سَأَلَ ابْنَ عُمَرَ عَنِ الأَعْوَرِ تُفْقَأُ عَیْنُہُ ؟ فَقَالَ عَبْدُ اللہِ بْنُ صَفْوَانَ : قَضَی فِیہَا عُمَرُ بِالدِّیَۃِ۔",,,27563,,
27564,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ عَبْدِ رَبِّہِ ، عَنْ أَبِی عِیَاضٍ ؛ أَنَّ عُثْمَانَ قَضَی فِی أَعْوَرَ أُصِیبَتْ عَیْنُہُ الصَّحِیحَۃُ الدِّیَۃَ کَامِلَۃً۔,,,27564,,
27565,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَن خِلاَسٍ ، عَنْ عَلِیٍّ ؛ فِی الرَّجُلِ الأَعْوَرِ إِذَا أُصِیبَتْ عَیْنُہُ الصَّحِیحَۃُ ، قَالَ : إِنْ شَائَ تُفْقَأُ عَیْنٌ مَکَانَ عَیْنٍ ، وَیَأْخُذُ النِّصْفَ ، وَإِنْ شَائَ أَخَذَ الدِّیَۃَ کَامِلَۃً۔",,,27565,,
27566,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَن سَالِمٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : إِذَا فُقِئَتْ عَیْنُ الأَعْوَرِ فَفِیہَا دِیَۃٌ کَامِلَۃً۔",,,27566,,
27567,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَن لاَحِقِ بْنِ حُمَیْدٍ ؛ أَنَّہُ سَأَلَ ابْنُ عُمَرَ ، أَوْ سَأَلَہُ رَجُلٌ عَنِ الأَعْوَرِ تُفْقَأُ عَیْنُہُ الصَّحِیحَۃُ ؟ فَقَالَ ابْنُ صَفْوَانَ ، وَہُوَ عَندَ ابْنِ عُمَرَ : قَضَی فِیہَا عُمَرُ بِالدِّیَۃِ کَامِلَۃً ، فَقَالَ: إِنَّمَا أَسْأَلُک یَا ابْنَ عُمَرَ ، فَقَالَ : تَسْأَلُنِی ؟ ہَذَا یُحَدِّثُکَ أَنَّ عُمَرَ قَضَی فِیہَا بِالدِّیَۃِ کَامِلَۃً۔ (بیہقی 94)",,,27567,,
27568,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَن حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّہُ ذَکَرَ مَا یَقُولُونَ فِی الأَعْوَرِ إِذَا فُقِئَتْ عَیْنُہُ الصَّحِیحَۃُ ، وَلَمْ یَکُنْ أَخَذَ لِلأُخْرَی أَرْشًا ، فَقَالُوا : الدِّیَۃُ کَامِلَۃً ، فَقَالَ إِبْرَاہِیمُ : زَعَمَ أُنَاسٌ مِنْ بَنِی کَاہِلٍ أَنَّ ذَلِکَ کَانَ فِیہِمْ ، فَقَضَی فِیہَا عُثْمَانُ دِیَۃَ الْعَیْنَیْنِ کِلْتَیْہِمَا ، فَسَأَلْنَا عَنْ غَوْر ذَلِکَ ، فَطَلَبْنَاہُ فَلَمْ نَجِدْ لَہُ نَفَاذًا ، فَبَردَ۔",,,27568,,
27569,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : فِی الْعَیْنِ إِذَا لَمْ یَبْقَ مِنْ بَصَرِہِ غَیْرُہَا ، ثُمَّ أُصِیبَتْ ، الدِّیَۃُ کَامِلَۃً۔",,,27569,,
27570,"حَدَّثَنَا یَزِیدُ، عَنْ سَعِیدٍ، عَنْ قَتَادَۃَ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ؛ فِی أَعْوَرٍ فُقِئَتْ عَیْنُہُ، قَالَ: فِیہَا الدِّیَۃُ کَامِلَۃً۔",,,27570,,
27571,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ، عَنْ شُرَیْحٍ ؛ أَنَّہُ قَالَ : فِی الرَّجُلِ تُفْقَأُ عَیْنُہُ ، وَلَیْسَ لَہُ عَیْنٌ غَیْرُہَا ، قَالَ : الْقِصَاصُ ، وَإِنْ فُقِئَتْ خَطَأً فَنِصْفُ الدِّیَۃِ۔",,,27571,,
27572,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَن فِرَاسٍ ، عَنِ الشَّعْبِیِّ ، عَن مَسْرُوقٍ ؛ فِی الأَعْوَرِ تُفْقَأُ عَیْنُہُ الصَّحِیحَۃُ ، قَالَ : فِیہَا نِصْفٌ ، أَنَا أُدِیَ قَتِیلَ اللہِ؟۔",,,27572,,
27573,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، وَوَکِیعٌ ، عَنْ إِسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنِ الشَّعْبِیِّ ؛ فِی الأَعْوَرِ تُفْقَأُ عَیْنُہُ الصَّحِیحَۃُ عَمْدًا ، قَالَ : الْعَیْنُ بِالْعَیْنِ۔",,,27573,,
27574,"حَدَّثَنَا وَکِیعٌ ، وَعَبْدُ الرَّحِیمِ ، عَنْ إِسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنْ أَبِی الضُّحَی ، عَنْ عَبْدِ اللہِ بْنِ مُغَفَّلٍ ؛ فِی الأَعْوَرِ تُفْقَأُ عَیْنُہُ الصَّحِیحَۃُ عَمْدًا ، قَالَ : الْعَیْنُ بِالْعَیْنِ ، مَا أَنَا فَقَأْتُ عَیْنَہُ الأُوْلَی۔",,,27574,,
27575,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إِسْرَائِیلُ ، عَنْ جَابِرٍ ، عَنْ عَطَائِ بْنِ أَبِی رَبَاحٍ ، قَالَ : فِیہَا نِصْفُ الدِّیَۃِ۔",,,27575,,
27576,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ سُفْیَانَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : فِیہَا نِصْفُ الدِّیَۃِ۔",,,27576,,
27577,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَن زَکَرِیَّا ، عَن فِرَاسٍ ، عَنْ عَامِرٍ ، عَن مَسْرُوقٍ ؛ أَنَّہُ سُئِلَ عَنْ أَعْوَرَ فُقِئَتْ عَیْنُہُ ؟ فَقَالَ : لاَ أُدِیَ قَتِیلَ اللہِ ، إِنَّمَا عَلَی الَّذِی أَصَابَہَا دِیَۃُ عَیْنٍ وَاحِدَۃٍ۔",,,27577,,
27578,"حَدَّثَنَا حَفْصٌ ، عَن دَاوُد ، عَنْ عَامِرٍ ؛ فِی أَعْوَرَ فَقَأَ عَیْنَ رَجُلٍ ، فَقَالَ : الْعَیْنُ بِالْعَیْنِ۔",,,27578,,
27579,حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ؛ فِی الأَعْوَرِ إِذَا فَقَأَ عَیْنَ إِنْسَانٍ ، فُقِئَتْ عَیْنُہُ۔,,,27579,,
27580,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنْ مُحَمَّدٍ ، قَالَ : الْعَیْنُ بِالْعَیْنِ۔",,,27580,,
27581,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ حَجَّاجٍ ، عَنْ مَکْحُولٍ ، عَن زَیْدٍ ، (ح) وَعَنْ حَجَّاجٍ ، عَنْ حُصَیْنٍ ، عَنِ الشَّعْبِیِّ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ (ح) وَعَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا اسْوَدَّتِ السِّنُّ تَمَّ عَقْلُہَا۔",,,27581,,
27582,حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ حَجَّاجٍ ، عَنْ مَکْحُولٍ ، عَن زَیْدٍ ، (ح) وَعَنْ حَجَّاجٍ ، عَنْ حُصَیْنٍ الْحَارِثِیِّ ، عَنِ الشَّعْبِیِّ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ (ح) وَعَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنْ إِبْرَاہِیمَ ؛ مِثْلَہُ۔,,,27582,,
27583,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : إِذَا اسْوَدَّتِ السِّنُّ فَعَقْلُہَا تَامٌّ۔",,,27583,,
27584,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : إِذَا اسْوَدَّتْ فَعَقْلُہَا تَامٌّ۔",,,27584,,
27585,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنْ مُحَمَّدٍ ، عَنْ شُرَیْحٍ ؛ أَنَّہُ کَانَ إِذَا اسْوَدَّتِ السِّنُّ قَضَی فِیہَا بِدِیَتِہَا۔,,,27585,,
27586,"حَدَّثَنَا أَبُو عَاصِمٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ أَنَّہُ قَالَ : فِی السِّنِّ إِذَا اسْوَدَّتْ ، أَوْ تَحَرَّکَتْ ، أَوْ رَجَفَتْ ، فَہُوَ سَوَائٌ۔",,,27586,,
27587,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَن حَنْظَلَۃَ ، عَنِ الْقَاسِمِ ؛ فِی السِّنِّ تَرْجُفُ ، قَالَ : عَقْلُہَا تَامٌّ۔",,,27587,,
27588,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ جَابِرٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : إِذَا اسْوَدَّتِ السِّنُّ ، أَوِ اصْفَرَّتْ فَفِیہَا دِیَتُہَا۔",,,27588,,
27589,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ لَیْثٍ ، عَنِ الزُّہْرِیِّ قَالَ : إِذَا اسْوَدَّتِ السِّنُّ ، فَقَدْ تَمَّ عَقْلُہَا۔",,,27589,,
27590,حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَن مَنْصُورٍ، عَنْ إِبْرَاہِیمَ؛ فِی السِّنِّ یُسْتَأْنَی بِہَا، فَإِنَ اسْوَدَّتْ فَالْعَقْلُ تَامٌّ۔,,,27590,,
27591,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ حَجَّاجٍ ، عَنْ حُصَیْنٍ ، عَنِ الشَّعْبِیِّ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : یُتَرَبَّصُ بِہَا حَوْلاً۔",,,27591,,
27592,حَدَّثَنَا عَبَّادٌ ، عَنْ حَجَّاجٍ ، عَنْ مَکْحُولٍ ، عَنْ زَیْدٍ ؛ مِثْلَہُ۔,,,27592,,
27593,حَدَّثَنَا عَبَّادٌ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنْ إِبْرَاہِیمَ ؛ مِثْلَہُ۔,,,27593,,
27594,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَن مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : فِی السِّنُّ یُسْتَأْنَی بِہَا سَنَۃً۔",,,27594,,
27595,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ، عَن حَسَنٍ، عَن فِرَاسٍ، عَنِ الشَّعْبِیِّ؛ فِی السِّنِّ، قَالَ: یُتَرَبَّصُ بِہَا سَنَۃً۔",,,27595,,
27596,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ ہِشَامٍ ، عَنْ مُحَمَّدٍ ، عَنْ شُرَیْحٍ ، قَالَ : إِذَا کُسِرَتِ السِّنُّ أَجَّلَہُ سَنَۃً۔",,,27596,,
27597,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : یُنْتَظَرُ بِہَا سَنَۃً ، فَإِنِ اسْوَدَّتْ ، أَوِ اصْفَرَّتْ فَفِیہَا الْعَقْلُ۔",,,27597,,
27598,حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ حَجَّاجٍ ، عَنْ حُصَیْنٍ ، عَنِ الشَّعْبِیِّ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ؛ فِی السِّنِّ إِذَا کُسِرَ بَعْضُہَا ، أُعْطَی صَاحِبُہَا بِحِسَابِ مَا نَقَصَ مِنْہَا۔,,,27598,,
27599,حَدَّثَنَا عَبَّادٌ، عَنْ حَجَّاجٍ، عَنْ مَکْحُولٍ، عَن زَیْدٍ (ح) وَعَنْ حَجَّاجٍ، عَنِ الْحَکَمِ، عَنْ إِبْرَاہِیمَ ؛ مِثْلَہُ۔,,,27599,,
27600,حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ حَجَّاجٍ ، عَنْ حُصَیْنٍ ، عَنِ الشَّعْبِیِّ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، (ح) وَعَنْ حَجَّاجٍ ، عَنْ مَکْحُولٍ ، عَنْ زَیْدٍ ، (ح) وَعَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنْ إِبْرَاہِیمَ ؛ مِثْلَہُ۔,,,27600,,
27601,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : الأَنْفُ وَالأُذُنُ بِمَنْزِلَۃِ السِّنِّ ، مَا نَقَصَ مِنْہُ فَبِحِسَابٍ۔",,,27601,,
27602,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ؛ فِی السِّنِّ خَمْسٌ مِنَ الإِبِلِ ، فَمَا کُسِرَ مِنْہَا إِذَا لَمْ یَسْوَدَّ فَبِحِسَابٍ۔,,,27602,,
27603,حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، وَأَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنْ مُحَمَّدٍ ، عَنْ شُرَیْحٍ ؛ أَنَّہُ کَانَ یَجْعَلُ فِیہَا قَدْرَ مَا نَقَصَ مِنْہَا۔,,,27603,,
27604,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : مَا کُسِرَ مِنْہَا إِذَا لَمْ یَسْوَدَّ فَبِحِسَابِ ذَلِکَ۔",,,27604,,
27605,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ یَعْلَی بْنِ عَطَائٍ ، عَنْ عَبْدِ اللہِ بْنِ مُسْلِمٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ فِی السِّنِّ إِذَا اسْوَدَّ بَعْضُہَا فَبِحِسَابِ مَنْزِلَۃِ الْکَسْرِ۔,,,27605,,
27606,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : إِنْ کُسرَ مِنْہَا نِصْفٌ ، أَوْ ثُلُثٌ وَہِیَ بَیْضَائُ، فَبِحِسَابِ مَا کُسرَ مِنْہَا۔",,,27606,,
27607,حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، وَالشَّعْبِیِّ ، وَالْحَکَمِ ، وَحَمَّادٍ ، عَنْ إِبْرَاہِیمَ ؛ فِی السِّنِّ السَّوْدَائِ إِذَا أُصِیبَتْ فَفِیہَا حُکُومَۃُ ذَوِیْ عَدْلٍ۔,,,27607,,
27608,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : فِی السِّنِّ السَّوْدَائِ حُکُومَۃٌ۔",,,27608,,
27609,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : فِیہَا ثُلُثُ الدِّیَۃِ۔",,,27609,,
27610,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : فِیہَا ثُلُثُ دِیَتِہَا۔",,,27610,,
27611,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی ہِلاَلٍ ، عَنْ قَتَادَۃَ ، عَنِ ابْنِ بُرَیْدَۃَ ، عَنْ یَحْیَی بْنِ یَعْمُرَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : فِیہَا ثُلُثُ الدِّیَۃِ۔",,,27611,,
27612,حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ قَتَادَۃَ ، عَنْ رَجُلٍ ، عَنِ ابْنِ عَبَّاسٍ ، عَنْ عُمَرَ ؛ فِی السِّنِّ السَّوْدَائِ ثُلُثُ دِیَتِہَا۔,,,27612,,
27613,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ سَعِیدِ بْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ عَبْدِ اللہِ بْنِ بُرَیْدَۃَ ، عَنْ یَحْیَی بْنِ یَعْمُرَ، عَنِ ابْنِ عَبَّاسٍ، عَنْ عُمَرَ بْنِ الْخَطَّابِ، قَالَ: فِی السِّنِّ السَّوْدَائِ إِذَا نُزِعَتْ وَکَانَتْ ثَابِتَۃً ثُلُثُ دِیَتِہَا۔",,,27613,,
27614,"حَدَّثَنَا حَفْصٌ ، وَعَبْدُ الرَّحِیمِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَن بُکَیْر بْنِ عَبْدِ اللہِ بْنِ الأَشَجِّ ، عَن سُلَیْمَانَ بْنِ یَسَارٍ ، عَن زَیْدِ بْنِ ثَابِتٍ ؛ أَنَّہُ قضَی فِی الْعَیْنِ الْقَائِمَۃِ إِذَا طُفِئَتْ : مِئَۃَ دِینَارٍ۔",,,27614,,
27615,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : فِیہَا ثُلُثُ الدِّیَۃِ۔",,,27615,,
27616,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : فِیہَا ثُلُثُ دِیَتِہَا۔",,,27616,,
27617,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ یَزِیدَ بْنِ عَبْدِ اللہِ بْنِ قُسَیْطً ؛ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ قَضَی فِی عَیْنٍ قَائِمَۃٍ بُخِصَتْ بِمِئَۃِ دِینَارٍ۔,,,27617,,
27618,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، وَالشَّعْبِیِّ (ح) وَعَنِ الْحَکَمِ ، وَحَمَّادٍ ، عَنْ إِبْرَاہِیمَ ؛ قَالُوا: فِی الْعَیْنِ الْقَائِمَۃِ حُکْمُ ذَوِی عَدْلٍ۔",,,27618,,
27619,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی ہِلاَلٍ ، عَن قَتَادَۃَ ، عَنِ ابْنِ بُرَیْدَۃَ ، عَنْ یَحْیَی بْنِ یَعْمُرَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : فِی الْعَیْنِ الْقَائِمَۃِ إِذَا بُخِصَتْ ثُلُثُ دِیَتِہَا۔",,,27619,,
27620,"حَدَّثَنَا وَکِیعٌ ، عَن سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، عَن مَسْرُوقٍ ، قَالَ : فِی الْعَیْنِ الْعَوْرَائِ حُکْمٌ۔",,,27620,,
27621,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ عَبْدِ اللہِ بْنِ بُرَیْدَۃَ ، عَنْ یَحْیَی بْنِ یَعْمُرَ ، عَنِ ابْنِ عَبَّاسٍ ، عَنْ عُمَرَ ؛ فِی الْعَیْنِ الْعَوْرَائِ إِذَا بُخِصَتْ وَکَانَتْ قَائِمَۃً : ثُلُثُ دِیَتِہَا۔",,,27621,,
27622,"حَدَّثَنَا عَبْدُ الأَعْلَی بْنُ عَبْدِ الأَعْلَی ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَن حَکِیمِ بْنِ حَکِیمٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، قَالَ : کَانَ فِیمَا وَضَعَ أَبُو بَکْرٍ ، وَعُمَرُ مِنَ الْقَضِیَّۃِ : أَنَّ الرَّجُلَ إِذَا بَسَطَہَا صَاحِبُہَا فَلَمْ یَقْبِضْہَا ، أَوْ قَبَضَہَا فَلَمْ یَبْسُطْہَا ، أَوْ قُلِّصَتْ عَنِ الأَرْضِ فَلَمْ تَبْلُغْہَا ، فَمَا نَقَصَ فَبِحِسَابٍ۔",,,27622,,
27623,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمٍ ، عَنْ عَلِیٍّ ، قَالَ : فِی الرِّجْلِ نِصْفُ الدِّیَۃِ۔",,,27623,,
27624,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : فِی الرِّجْلِ نِصْفُ الدِّیَۃِ۔",,,27624,,
27625,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، (ح) وَعَنِ الْحَکَمِ ، وَحَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالاَ : فِی الْیَدِ تُصَابُ فَتُشَلُّ ، أَوِ الرِّجْلِ ، أَوِ الْعَیْنِ إِذَا ذَہَبَ بَصَرُہَا وَہِیَ قَائِمَۃٌ ، فَقَدْ تَمَّ عَقْلُہَا۔",,,27625,,
27626,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ أَبِی لَیْلَی ، عَن عِکْرِمَۃَ بْنِ خَالِدٍ ، عَنْ رَجُلٍ مِنْ آلِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : فِی الرِّجْلِ خَمْسُونَ۔",,,27626,,
27627,"حَدَّثَنَا ابْنُ فُضَیْلٍ، عَنْ أَشْعَثَ، عَنِ الشَّعْبِیِّ، عَنْ عَبْدِ اللہِ، قَالَ: فِی الرِّجْلِ خَمْسُونَ مِنَ الإِبِلِ أَخْمَاسًا۔",,,27627,,
27628,"حَدَّثَنَا وَکِیعٌ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، عنْ حُمَیْدِ بْنِ ہِلاَلٍ ، قَالَ : فِی کِتَابٍ کَتَبَہُ مَرْوَانُ ، عَن زَیْدِ بْنِ ثَابِتٍ : إِذَا قَزَلَتِ الرِّجْلُ ، فَفِیہَا نِصْفُ الدِّیَۃِ۔",,,27628,,
27629,"حَدَّثَنَا أَبُو الأَحْوَصِ، عَنْ أَبِی إِسْحَاقَ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ، عَنْ عَلِیٍّ ، قَالَ: فِی الْجَائِفَۃِ ثُلُثُ الدِّیَۃِ۔",,,27629,,
27630,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : فِی الْجَائِفَۃِ ثُلُثُ الدِّیَۃِ۔",,,27630,,
27631,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، عَنْ عَبْدِ اللہِ ، قَالَ : فِی الْجَائِفَۃِ ثُلُثُ الدِّیَۃِ أَخْمَاسًا۔",,,27631,,
27632,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : فِی الْجَائِفَۃِ ثُلُثُ الدِّیَۃِ۔",,,27632,,
27633,حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَن مَکْحُولٍ ، (ح) وَعَنْ أَشْعَثَ ، عَنِ الزُّہْرِیِّ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَضَی فِی الْجَائِفَۃِ بِثُلُث الدِّیَۃِ۔,,,27633,,
27634,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : الْجَائِفَۃُ فِی الْبَطْنِ وَالْفَخْذِ ، دِیَتُہَا ثُلُثُ الدِّیَۃِ۔",,,27634,,
27635,حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَان ، عَنْ حَجَّاجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّ قَوْمًا کَانُوا یَرْمُونَ ، فَرَمَی رَجُلٌ مِنْہُمْ بِسَہْمٍ خَطَأً ، فَأَصَابَ بَطْنَ رَجُلٍ ، فَأَنْفَذَہُ إِلَی ظَہْرِہِ ، فَدُووِیَ فَبَرَأَ ، فَرُفِعَ إِلَی أَبِی بَکْرٍ فَقَضَی فِیہِ بِجَائِفَتَیْنِ۔,,,27635,,
27636,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَجَّاجٍ ، عَنْ مَکْحُولٍ ، عَنْ زَیْدٍ ؛ فِی النَّافِذَۃِ فِی الْجَوْفِ ثُلُثُ الدِّیَۃِ ، وَفِی الأُخْرَی مِئَۃُ دِینَارٍ۔,,,27636,,
27637,"حَدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَن بُرْدٍ ، عَنْ مَکْحُولٍ ، قَالَ : الْجَائِفَۃُ فِی الْجَوْفِ حَتَّی یَخْرُجَ مِنَ الْجَانِبِ الآخَرِ جَائِفَتَانِ۔",,,27637,,
27638,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ، عَنْ عَمْرٍو، عَنِ الْحَسَنِ؛ فِی رَجُلٍ رَمَی رَجُلاً فَأَنْفَذَہُ قَالَ : فِیہِ جَائِفَتَانِ۔",,,27638,,
27639,"حَدَّثَنَا أَبُو خَالِدٍ ، عَن عُبَیْدَۃَ ، عَنْ إِبْرَاہِیمَ ، عَنْ عُمَرَ ، قَالَ : فِی الْجَائِفَۃِ ثُلُثُ الدِّیَۃِ۔",,,27639,,
27640,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَجَّاجٍ ، عَنْ مَکْحُولٍ ، عَن زَیْدِ بْنِ ثَابِتٍ ، قَالَ : فِی کُلِّ نَافِذَۃٍ فِی عُضْوٍ مِنَ الْیَدِ وَالرِّجْلِ ، مِئَۃ دِینَارٍ۔",,,27640,,
27641,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : الْجَائِفَۃُ فِی الْفَخْذِ دِیَتُہَا ثُلُثُ الدِّیَۃِ۔",,,27641,,
27642,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : کُلُّ نَافِذَۃٍ فِی عُضْوٍ فَدِیَتُہَا ثُلُثُ دِیَۃِ ذَلِکَ الْعُضْوِ۔",,,27642,,
27643,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، قَالَ : لِکُلِّ عَظْمٍ جَائِفَۃٌ ، فَکُلُّ عَظْمٍ أُجِیفَ فَجَائِفَتُہُ مِنْ حِسَابِ ذَلِکَ الْعَظْمِ۔",,,27643,,
27644,"حَدَّثَنَا إِسْمَاعِیلُ بْنُ إِبْرَاہِیمَ ، عَنِ الْوَلِیدِ بْنِ أَبِی ہِشَامٍ ، عَنْ أَبِی بَکْرِ بْنِ مُحَمَّدِ بْنِ عَمْرِو بْنِ حَزْمٍ ، قَالَ : قَالَ عُمَرُ : کُلُّ رَمْیَۃٍ نَافِذَۃٍ فِی عُضْوٍ ، فَفِیہَا ثُلُثُ دِیَۃِ ذَلِکَ الْعُضْوِ۔",,,27644,,
27645,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ أَبِی لَیْلَی ، عَن عِکْرِمَۃَ بْنِ خَالِدٍ ، عَنْ رَجُلٍ مِنْ آلِ عُمَرَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : فِی الذَّکَرِ الدِّیَۃُ۔ (عبدالرزاق 17636)",,,27645,,
27646,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ ، عَنْ عَلِیٍّ ، قَالَ : فِی الذَّکَرِ الدِّیَۃُ۔",,,27646,,
27647,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، عَنْ عَبْدِ اللہِ ، قَالَ : فِی الذَّکَرِ الدِّیَۃُ أَخْمَاسًا۔",,,27647,,
27648,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : فِی الذَّکَرِ الدِّیَۃُ۔",,,27648,,
27649,"حَدَّثَنَا أَبُو خَالِدٍ ، عَن عُبَیْدَۃَ ، عَنْ إِبْرَاہِیمَ ، عَنْ عُمَرَ ، قَالَ : فِی الذَّکَرِ الدِّیَۃُ۔",,,27649,,
27650,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : فِی الذَّکَرِ الدِّیَۃُ۔",,,27650,,
27651,حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ أَشْعَثَ ، عَنِ الزُّہْرِیِّ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَضَی فِی الذَّکَرِ الدِّیَۃَ۔ (ابوداؤد 265),,,27651,,
27652,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : قُلْتُ لَہُ : اسْتُؤْصِلَ الذَّکَرُ ؟ قَالَ : الدِّیَۃُ ، قُلْتُ : أَرَأَیْتَ إِنْ أُصِیبَتِ الْحَشَفَۃُ ، ثُمَّ أُصِیبَ شَیْئٌ مِمَّا بَقِیَ ؟ قَالَ : جُرْحٌ۔",,,27652,,
27653,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ، عَنِ ابْنِ جُرَیْجٍ، قَالَ: أَخْبَرَنِی ابْنُ أَبِی نَجِیحٍ، عَن مُجَاہِدٍ، قَالَ: فِی الذَّکَرِ الدِّیَۃُ۔",,,27653,,
27654,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، قَالَ : قضَی أَبُو بَکْرٍ فِی ذَکَرِ الرَّجُلِ بِدِیَتِہِ ، مِئَۃٍ مِنَ الإِبِلِ۔",,,27654,,
27655,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَان ، عَنْ أَشْعَثَ ، عَنِ الزُّہْرِیِّ ، قَالَ : قضَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی الذَّکَرِ إِذَا اسْتُؤْصِلَ ، أَوْ قُطِعَتْ حَشَفَتُہُ : الدِّیَۃُ کَامِلَۃٌ مِئَۃٌ مِنَ الإِبِلِ۔",,,27655,,
27656,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنْ أَشْعَثَ ، عَنْ عَامِرٍ ، عَنْ عَلِیٍّ ، وَعَبْدِ اللہِ ، قَالاَ : فِی الْحَشَفَۃِ إِذَا قُطِعَتِ الدِّیَۃُ ، فَمَا نَقَصَ مِنْہَا فَبِحِسَابٍ۔",,,27656,,
27657,"حَدَّثَنَا وَکِیعٌ ، عَن زَکَرِیَّا ، أَوْ إِسْرَائِیلَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ ، عَنْ عَلِیٍّ ، قَالَ : فِی الْحَشَفَۃِ الدِّیَۃُ۔",,,27657,,
27658,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : فِی الْحَشَفَۃِ الدِّیَۃُ۔",,,27658,,
27659,"حَدَّثَنَا وَکِیعٌ ، عَن سَلاَّمٍ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : فِی الْحَشَفَۃِ الدِّیَۃُ۔",,,27659,,
27660,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ قَالَ : فِی الْحَشَفَۃِ الدِّیَۃُ۔",,,27660,,
27661,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی ابْنُ أَبِی نَجِیحٍ ، عَن مُجَاہِدٍ ، قَالَ : فِی الْحَشَفَۃِ وَحْدَہَا الدِّیَۃُ۔",,,27661,,
27662,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : أَرَأَیْتَ إِنْ أُصِیبَتِ الْحَشَفَۃُ ؟ قَالَ : الدِّیَۃُ ، قَالَ : قُلْتُ لِعَطَائٍ : أَثَبْتٌ ؟ قَالَ : قَدْ قَالُوا ذَلِکَ۔",,,27662,,
27663,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا زُہَیْرٌ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ ، عَنْ عَلِیٍّ ، قَالَ : فِی الْحَشَفَۃِ الدِّیَۃُ۔",,,27663,,
27664,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، عَن مَسْرُوقٍ ؛ فِی الْیَدِ الشَّلاَّئِ إِذَا قُطِعَتْ حُکْمٌ ، وَفِی الضِّرْسِ حُکْمٌ ، یَعْنِی الْمَأْکُولَ۔,,,27664,,
27665,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا ہِشَامُ الدَّسْتَوَائِیُّ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : فِی الْیَدِ الشَّلاَّئِ إِذَا قُطِعَتْ ثُلُثُ الدِّیَۃِ۔",,,27665,,
27666,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی حَنِیفَۃَ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : فِی الْیَدِ الشَّلاَّئِ إِذَا قُطِعَتْ ثُلُثُ الدِّیَۃِ۔",,,27666,,
27667,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ سَعِیدِ بْنِ أَبِی عُرْوَۃَ ، عَنْ قَتَادَۃَ ، عَنِ ابْنِ بُرَیْدَۃَ ، عَنْ یَحْیَی بْنِ یَعْمُرَ ، عَنِ ابْنِ عَبَّاسٍ ، عَنْ عُمَرَ بْنِ الْخَطَّابِ ؛ فِی الْیَدِ الشَّلاَّئِ إِذَا قُطِعَتْ ثُلُثُ الدِّیَۃِ۔,,,27667,,
27668,حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی ہِلاَلٍ ، عَنْ قَتَادَۃَ ، عَنِ ابْنِ بُرَیْدَۃَ ، عَنْ یَحْیَی بْنِ یَعْمُرَ ، عَنِ ابْنِ عَبَّاسٍ ؛ فِی الْیَدِ الشَّلاَّئِ إِذَا قُطِعَتْ ثُلُثُ الدِّیَۃِ۔,,,27668,,
27669,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، وَالشَّعْبِیِّ ، وَالْحَکَمِ ، وَحَمَّادٍ ، عَنْ إِبْرَاہِیمَ ؛ فِی الْیَدِ الشَّلاَّئِ ، قَالُوا : فِیہَا حُکْمُ ذَوِی عَدْلٍ۔",,,27669,,
27670,"حَدَّثَنَا جَرِیرٌ ، عَن مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانَ یُقَالُ : إِذَا کُسِرَتِ الْیَدُ ، أَوِ الرِّجْلُ ، ثُمَّ بَرَأَتْ وَلَمْ یَنْقُصْ مِنْہَا شَیْئٌ : أَرْشُہَا مِئَۃٌ وَثَمَانُونَ دِرْہَمًا۔",,,27670,,
27671,حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنِ الْقَعْقَاعِ بْنِ یَزِیدَ، عَنْ إِبْرَاہِیمَ؛ فِی الْیَدِ، أَوِ الرِّجْلِ إِذَا کُسِرَتْ صُلْح۔,,,27671,,
27672,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ أَشْعَثَ ، عَنْ عَبْدِ اللہِ بْنِ ذَکْوَانَ ؛ أَنَّ عُمَرَ قَضَی فِی رَجُلٍ کُسِرَتْ سَاقُہُ فَجُبِرَتْ وَاسْتَقَامَتْ ، فَقَضَی فِیہَا بِعِشْرِینَ دِینَارًا۔\n\nقَالَ: قیلَ لَہُ : إِنَّہَا وَہَنَتْ۔",,,27672,,
27673,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سَعِیدُ بْنُ عَبْدِ الرَّحْمَنِ ، عن ابن سیرین ، عَنْ شُرَیْحٍ ؛فِی رَجُلٍ کَسَرَ یَدَ رَجُلٍ فَجُبِرَتْ ، فَقَالَ شُرَیْحٌ : عَلَی الْکَاسِرِ أَجْرُ الْجَابِرِ ، أَمَا یَحْمَدُ اللَّہَ حَیْثُ رَدَّ عَلَیْہِ یَدَہُ۔",,,27673,,
27674,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا شُعْبَۃُ، عَنْ أَبِی بِشْرٍ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ، قَالَ: فِی الأَعْضَائِ کُلِّہَا حُکُومَۃٌ۔",,,27674,,
27675,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ ابْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ، عَن زَیْدِ بْنِ ثَابِتٍ ؛ فِی السَّاقِ تُکْسَرُ خَمْسُونَ دِینَارًا ، وَإِذَا بَرَأَتْ عَلَی عَثْمٍ فَفِیہَا خَمْسُونَ دِینَارًا ، وَفِی الْعَثْمِ مَا فِیہِ۔,,,27675,,
27676,"حَدَّثَنَا عَبْدُ الْوَہَّابِ ، عَنْ عَطَائٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَن سُلَیْمَانَ بْنِ یَسَارٍ ، قَالَ : فِی الذِّرَاعِ ، وَالسَّاقِ ، وَالْعَضُدِ ، وَالْفَخْذِ إِذَا کُسِرَتْ ، ثُمَّ جُبِرَتْ : قَلُوصَانِ ، قَلُوصَانِ۔",,,27676,,
27677,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قُلْتُ لَہُ : کُسرَتِ الْیَدُ ، أَوِ الرِّجْلُ ، أَوِ التَّرْقُوَۃُ فَجُبِرَتْ فَاسْتَوَتْ ، قَالَ : فِی ذَلِکَ شَیْئٌ ، وَمَا بَلَغَنِی مَا ہُوَ۔",,,27677,,
27678,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ أَبِی حُرَّۃَ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ کُسِرَتْ یَدُہُ ، قَالَ : یُعَوَّضُ مِنْ یَدِہِ ۔ قَالَ : وَقَالَ مُحَمَّدٌ : قَالَ شُرَیْحٌ : یُعْطَی أَجْرَ الطَّبِیبِ۔",,,27678,,
27679,"حَدَّثَنَا أَبُو أُسَامَۃَ، عَنْ أَشْعَثَ، عَنِ الْحَسَنِ؛ فِی الَّذِی یُکْسَرُ ذِرَاعُہُ ، ثُمَّ یُجْبَرُ، قَالَ: یُرْضَخُ لَہُ شَیْئٌ۔",,,27679,,
27680,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ حَجَّاجٍ ، عَنْ مَکْحُولٍ ، عَن زَیْدِ بْنِ ثَابِتٍ ؛ أَنَّہُ قَضَی فِی الظُّفْرِ إِذَا سَقَطَ فَلَمْ یَنْبُتْ ، أَوْ نَبَتَ مُتَغَیِّرًا : عَشَرَۃَ دَنَانِیرَ ، وَإِنْ خَرَجَ أَبْیَضَ فَفِیہِ خَمْسَ دَنَانِیرَ۔",,,27680,,
27681,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَن خَالِدِ الْحَذَّائِ ، عَنْ عَمْرِو بْنِ ہَرِم ، عَنْ جَابِرِ بْنِ زَیْدٍ ، عَنِ ابْنِ عَبَّاسٍ؛ فِی الظُّفْرِ إِذَا أَعْوَرَ خُمْسُ دِیَۃِ الإِصْبَعِ۔,,,27681,,
27682,حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ أَشْعَثَ بْنِ سَوَّارٍ ، عَنْ عَبْدِ اللہِ بْنِ ذَکْوَانَ ، عَنِ ابْنِ عَبَّاسٍ ؛ قَضَی فِی ظُفْرِ رَجُلٍ أَصَابَہُ رَجُلٌ فَأَعْوَرَ ، بِعُشْرِ دِیَۃِ الإِصْبَعِ۔,,,27682,,
27683,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ قَالَ : فِی الظُّفْرِ إِذَا نَبَتَ ، فَإِنْ کَانَ فِیہِ عَیْبٌ فَبَعِیرٌ۔",,,27683,,
27684,حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ؛ أَنَّ عُمَرَ بْنَ الْخَطَّابِ قَضَی فِی الظُّفْرِ إِذَا اعْرَنْجَمَ وَفَسَدَ بِقُلُوصٍ۔,,,27684,,
27685,حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَبْدِ الکَرِیمِ ؛ فِی الظُّفْرِ إِذَا لَمْ یَنْبُتْ فَفِیہِ نَاقَتَانِ ، فَإِنْ نَبَتَتْ عَمْیَائَ لَیْسَ لَہَا وَبِیصٌ ، فَفِیہَا نَاقَۃٌ۔,,,27685,,
27686,حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَن مُجَاہِدٍ ؛ فِی الظُّفْرِ إِذَا لَمْ یَنْبُتْ، فَفِیہِ بِنْتُ مَخَاضٍ ، فَإِنْ لَمْ تُوجَدْ فَفِیہِ بِنْتُ لَبُونٍ۔,,,27686,,
27687,"حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : سَأَلْتُ عَطَائً عَنِ الظُّفْرِ إِذَا لَمْ یَنْبُتْ ؟ فَقَالَ : قَدْ سَمِعْت فِیہِ بِشَیْئٍ ، وَلاَ أَدْرِی مَا ہُوَ۔",,,27687,,
27688,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی عَبْدُ الْعَزِیزِ بْنُ عُمَرَ ؛ أَنَّ أُمَرَائَ الأَجْنَادِ ، وَأَہْلَ الرَّأْیِ اجْتَمَعُوا لِعُمَرَ بْنِ عَبْدِ الْعَزِیزِ فِی الظُّفْرِ إِذَا نُزِعَ فَعَنِتَ ، أَوْ سَقَطَ، أَوِ اسْوَدَّ: الْعُشْرُ مِنْ دِیَۃِ الإِصْبَعِ، عَشَرَۃُ دَنَانِیرَ۔",,,27688,,
27689,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَن خَالِدٍ ، عَنْ عَمْرِو بْنِ ہَرِمٍ ، عَنْ جَابِرِ بْنِ زَیْدٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ فِی الظُّفْرِ إِذَا أَعْوَرَ خُمْسُ دِیَۃِ الإِصْبَعِ۔,,,27689,,
27690,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَن حُمَیْدٍ ، عَنْ أَنَسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَمَرَ بِالْقِصَاصِ فِی سِنٍّ ، وَقَالَ : کِتَابَ اللہِ الْقِصَاصَ۔ (بخاری 6894۔ ابوداؤد 4585)",,,27690,,
27691,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَزْہَرَ ، عَن مُحَارِبِ بْنِ دِثار ، قَالَ : جَائَ رَجُلاَنِ إِلَی شُرَیْحٍ قَدْ کَسَرَ ہَذَا ضِرْسَ ہَذَا ، وَہَذَا ضِرْسَ ہَذَا ، قَالَ : ہَذِہِ ثَنِیَّۃٌ بِضِرْسٍ ، قُومَا۔",,,27691,,
27692,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، وَالْحَسَنِ ، قَالاَ : لَیْسَ فِی الْعِظَامِ قِصَاصٌ مَا خَلاَ السِّنِّ ، أَوِ الرَّأْسِ۔",,,27692,,
27693,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : یُقَادُ مِنَ السِّنِّ۔",,,27693,,
27694,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : الْعَیْنُ یُقَادُ مِنْہَا ؟ قَالَ : نَعَمْ ، وَالسِّنُّ۔",,,27694,,
27695,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَن زَیْدِ بْنِ أَسْلَمَ ، عَن مُسْلِمِ بْنِ جُنْدُبٍ ، عَنْ أَسْلَمَ مَوْلَی عُمَرَ ، قَالَ : سَمِعْتُ عُمَرَ عَلَی الْمِنْبَرِ یَقُولُ : فِی الضِّلَعِ جَمَلٌ۔",,,27695,,
27696,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ فِی الضِّلَعِ إِذَا کُسِرَتْ بَعِیرَانِ ، فَإِذَا انْجَبَرَتْ فَبَعِیرٌ۔,,,27696,,
27697,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ، عَنْ حَجَّاجٍ، عَن دَاوُد بْنِ أَبِی عَاصِمٍ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ؛ فِی الضِّلَعِ بَعِیرٌ۔,,,27697,,
27698,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ جَابِرٍ ، عَنِ الشَّعْبِیِّ ، عَنْ شُرَیْحٍ ، وَمَسْرُوقٍ ؛ أَنَّہُمَا قَالاَ : فِی الضِّلَعِ وَنَحْوِہَا إِذَا کُسِرَتْ فَجُبِرَتْ عَلَی غَیْرِ عَثْمٍ ، قَالاَ : فِیہِ أَجْرُ الطَّبِیبِ۔",,,27698,,
27699,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ ابْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ، عَن زَیْدِ بْنِ ثَابِتٍ ، قَالَ : فِیہِ عَشَرَۃُ دَنَانِیرَ۔",,,27699,,
27700,"حَدَّثَنَا وَکِیعٌ، عَنْ أَبِیہِ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ، عَنِ الْحَکَمِ، قَالَ: فِی الضِّلَعِ بَعِیرٌ، وَفِی الضِّرْسِ بَعِیرٌ۔",,,27700,,
27701,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ ، عَنْ عَلِیٍّ ، قَالَ : فِی إِحْدَی الْبَیْضَتَیْنِ نِصْفُ الدِّیَۃِ۔",,,27701,,
27702,"حَدَّثَنَا وَکِیعٌ ، قَالَ :حَدَّثَنَا سُفْیَان ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِم ، عَنْ عَلِیٍّ ؛ مِثْلَہُ۔",,,27702,,
27703,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَجَّاجٍ ، عَنْ مَکْحُولٍ ، عَن زَیْدِ بْنِ ثَابِتٍ (ح) وَعَنْ حَجَّاجٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِم ، عَنْ عَلِیٍّ (ح) وَعَنْ حَجَّاجٍ ، عَنِ الزُّہْرِیِّ ، عَنْ عُرْوَۃَ بْنِ الزُّبَیْرِ (ح) وَعَنْ حَجَّاجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ؛ أَنَّہُمْ قَالُوا : الْبَیْضَتَانِ سَوَائٌ۔",,,27703,,
27704,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی ابْنُ أَبِی نَجِیحٍ ، عَن مُجَاہِدٍ ، قَالَ : فِی الْبَیْضَتَیْنِ الدِّیَۃُ وَافِیَۃً ، خَمْسُونَ خَمْسُونَ۔",,,27704,,
27705,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی ابْنُ أَبِی نَجِیحٍ ، عَن مُجَاہِدٍ ؛ الْبَیْضَتَانِ سَوَائٌ ، خَمْسُونَ خَمْسُونَ ، وَلَمْ أَسْمَعْہُ مِنْ ثَبْتٍ۔",,,27705,,
27706,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : قُلْتُ لَہُ : الْبَیْضَتَانِ ؟ قَالَ : خَمْسُونَ خَمْسُونَ ، وَلَمْ أَسْمَعْہُ مِنْ ثَبْتٍ۔",,,27706,,
27707,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، عَن مَسْرُوقٍ ، عَنْ عَبْدِ اللہِ ، قَالَ : الْبَیْضَتَانِ سَوَائٌ۔",,,27707,,
27708,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، عَن مَسْرُوقٍ ، عَنْ عَبْدِ اللہِ ، قَالَ : الأُنْثَیَانِ سَوَائٌ۔",,,27708,,
27709,"حَدَّثَنَا إِسْمَاعِیلُ بْنُ إِبْرَاہِیمَ ، عَن دَاوُد ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ: فِی الْبَیْضَۃِ الْیُسْرَی ثُلُثَا الدِّیَۃِ، وَفِی الْیُمْنَی الثُّلُثُ ، قُلْتُ : لِمَہْ ؟ قَالَ : لأَنَّ الْیُسْرَی إِذَا ذَہَبَتْ لَمْ یُولَدْ لَہُ ، وَإِذَا ذَہَبَتِ الْیُمْنَی وُلِدَ لَہُ۔",,,27709,,
27710,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَن مَنْصُورٍ ، قَالَ : ذَکَرْتُ ذَلِکَ لإِبْرَاہِیمَ ، فَقَالَ : ہُمَا سَوَائٌ۔",,,27710,,
27711,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا سُفْیَانُ، عَنْ جَابِرٍ، عَنِ الشَّعْبِیِّ، عَن مَسْرُوقٍ، قَالَ: فِی لِسَانِ الأَخْرَسِ حُکْمٌ۔",,,27711,,
27712,حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ، عَن حَمَّادٍ، عَنْ إِبْرَاہِیمَ؛ فِی لِسَانِ الأَخْرَسِ الدِّیَۃُ کَامِلَۃً۔,,,27712,,
27713,حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی حَنِیفَۃَ ، عَن حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ؛ فِی لِسَانِ الأَخْرَسِ حُکْمٌ ، وَفِی ذَکَرِ الْخَصِیِّ حُکْمٌ۔,,,27713,,
27714,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ، عَنِ ابْنِ جُرَیْجٍ، عَنْ قَتَادَۃَ، قَالَ: فِی لِسَانِ الأَخْرَسِ الثُّلُثُ مِمَّا فِی لِسَانِ الصَّحِیحِ۔",,,27714,,
27715,"حَدَّثَنَا عَبْدُ الْوَہَّابِ بْنُ عَطَائٍ ، عَنْ عَمْرو ، عَنِ الْحَسَن ، قَالَ : فِی لِسَانِ الأَخْرَسِ الدِّیَۃُ کَامِلَۃً۔",,,27715,,
27716,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : فِی ذَکَرِ الَّذِی لاَ یَأْتِی النِّسَائَ ، مِثْلُ مَا فِی ذَکَرِ الَّذِی یَأْتِی النِّسَائَ ؟ قَالَ : نَعَمْ ، وَقَالَ لِی : أَرَأَیْتَ الَّذِی قَدْ ذَہَبَ ذَلِکَ مِنْہُ ، أَلَیْسَ یُوفَی نَذْرُہُ۔",,,27716,,
27717,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی عَبْدُ الْعَزِیزِ بْنُ عُمَرَ ؛ أَنَّ أُمَرَائَ الأَجْنَادِ ، وَأَہْلَ الرَّأْیِ مِنْہُمُ اجْتَمَعُوا لِعُمَرَ بْنِ عَبْدِالْعَزِیزِ فِی الْمَنْکِبِ إِذَا کُسِرَ ، ثُمَّ جُبِرَ فِی غَیْرِ عَثْمٍ فَفِیہِ أَرْبَعُونَ دِینَارًا۔",,,27717,,
27718,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ، عَنِ ابْنِ جُرَیْجٍ، قَالَ: بَلَغَنِی عَنِ الشَّعْبِیِّ؛ فِی الْمَنْکِبِ إِذَا کُسِرَ أَرْبَعُونَ دِینَارًا۔",,,27718,,
27719,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَزْہَرِ الْعَطَّارِ ، عَنْ أَبِی عَوْنٍ الثَّقَفِیِّ ، عَنْ شُرَیْحٍ ، قَالَ : فِی الْفَتْقِ ثُلُثُ الدِّیَۃِ۔",,,27719,,
27720,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ، عَنْ قَتَادَۃَ، عَنْ أَبِی مِجْلَزٍ، قَالَ: فِی فَتْقِ الْمَثَانَۃِ ثُلُثُ الدِّیَۃِ۔",,,27720,,
27721,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : بَلَغَنِی عَنِ الشَّعْبِیِّ ، قَالَ : فِی الْمَثَانَۃِ إِذَا خُرِقَتْ ، فَلَمْ یَسْتَمْسِکِ الْبَوْل ثُلُثُ الدِّیَۃِ۔",,,27721,,
27722,"حَدَّثَنَا أَبُو أُسَامَۃَ، قَالَ: حدَّثَنَا عَبْدُ الْوَاحِدِ بْنُ زِیَادٍ، عَنْ حَجَّاجٍ، عَنْ مَکْحُولٍ، عَنْ زَیْدٍ؛ فِی الْفَتْقِ الدِّیَۃُ۔",,,27722,,
27723,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ أَشْعَثَ ، عَنِ الزُّہْرِیِّ ، قَالَ : قضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی الصُّلْبِ الدِّیَۃَ۔ (ابوداؤد 263۔ بیہقی 95)",,,27723,,
27724,"حَدَّثَنَا أَبُو خَالِدٍ ، وَأَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ مَکْحُولٍ ، عَنْ زَیْدٍ ، قَالَ : فِی الصُّلْبِ الدِّیَۃُ۔",,,27724,,
27725,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : فِی الصُّلْبِ الدِّیَۃُ۔",,,27725,,
27726,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : اتَّفَقَ أَہْلُ الْعِلْمِ أَنَّ فِی الصُّلْبِ الدِّیَۃَ۔",,,27726,,
27727,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ یَعْلَی بْنِ عَطَائٍ ، عَنْ عَبْدِ اللہِ بْنِ مُسْلِمٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : فِی الصُّلْبِ الدِّیَۃُ۔",,,27727,,
27728,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، قَالَ : قضَی أَبُو بَکْرٍ فِی صُلْبِ الرَّجُلِ إِذَا کُسِرَ ثُمَّ جُبِرَ بِالدِّیَۃِ کَامِلَۃً ، إِذَا کَانَ لاَ یُحْمَلُ لَہُ ، وَبِنِصْفِ الدِّیَۃِ إِذَا کَانَ یُحْمَلُ لَہُ۔",,,27728,,
27729,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ، عَنِ ابْنِ جُرَیْجٍ، قَالَ: أَخْبَرَنِی ابْنُ أَبِی نَجِیحٍ، عَن مُجَاہِدٍ قَالَ: إِنْ أُصِیبَ الصُّلْبُ، أَوْ کُسِرَ فَجُبِرَ وَانْقَطَعَ مَنِیُّہُ ، فَالدِّیَۃُ وَافِیَۃٌ ، فَإِنْ لَمْ یَنْقَطِعْ الْمَنِیُّ وَکَانَ فِی الظَّہْرِ مَیْلٌ ، فَإِنَّہُ یُرَی فِیہِ۔",,,27729,,
27730,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : سَأَلْتُ عَطَائً عَنِ الصُّلْبِ یُکْسَرُ ؟ قَالَ : الدِّیَۃُ۔",,,27730,,
27731,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی مُحَمَّدُ بْنُ الْحَارِثِ بْنِ سُفْیَانَ ؛ أَنَّ مُحَمَّدَ بْنَ عَبْدِ اللہِ بْنِ أَبِی رَبِیعَۃَ أَخْبَرَہُ ؛ أَنَّہُ قَالَ : حَضَرْتُ ابْنَ الزُّبَیْرِ فِی رَجُلٍ کُسِرَ صُلْبُہُ ، فَاحْدَوْدَبَ ، وَلَمْ یَقْعُدْ وَہُوَ یَمْشِی وَہُوَ مُحْدَوْدِبٌ ، فَقَالَ : امْشِ ، فَمَشَی ، فَقَضَی لَہُ بِثُلُثَیِ الدِّیَۃِ۔",,,27731,,
27732,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَن حَسَنِ بْنِ صَالِحٍ ، عَنْ عَبِیدَۃَ ، عَنْ یَزِیدَ الضَّخْمِ ، عَنْ عَلِیٍّ ، قَالَ : إِذَا کُسِرَ الصُّلْبُ ، وَمَنَعَ الْجِمَاعَ فَفِیہِ الدِّیَۃُ۔",,,27732,,
27733,حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ حَجَّاجٍ ، عَنْ مَکْحُولٍ ، عَن زَیْدِ بْنِ ثَابِتٍ ؛ أَنَّہُ قَضَی فِی حَلَمَۃِ ثَدْیِ الْمَرْأَۃِ رُبُعَ دِیَتِہَا ، وَفِی حَلَمَۃِ ثَدْیِ الرَّجُلِ ثُمْنَ دِیَتِہِ۔,,,27733,,
27734,"حَدَّثَنَا أَبُو بَکْرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ، قَالَ : فِی الثَّدْیَیْنِ الدِّیَۃُ۔",,,27734,,
27735,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ، قَالَ : فی ثَدْیِ الْمَرْأَۃِ فَمَا فَوْقَہُ الدِّیَۃُ کَامِلَۃً ، وَفِی أَحَدِہِمَا نِصْفُ الدِّیَۃِ۔",,,27735,,
27736,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : فِی الثَّدْیَیْنِ الدِّیَۃُ ، وَفِی أَحَدِہِمَا نِصْفُ الدِّیَۃِ۔",,,27736,,
27737,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : سُئِلَ عَن ثَدْیِ الْمَرْأَۃِ ؟ فَقَالَ : فِیہِ نِصْفُ الدِّیَۃِ ، وَإِذَا أُصِیبَ بَعْضُہُ فَفِیہِ حُکُومَۃُ الْعَدْلِ الْمُجْتَہِدِ۔",,,27737,,
27738,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قَالَ عَمْرُو بْنُ شُعَیْبٍ : قَضَی أَبُو بَکْرٍ فِی ثَدْیِ الرَّجُلِ إِذَا ذَہَبَتْ حَلَمَتُہُ بِخَمْسٍ مِنَ الإِبِلِ ، وَقَضَی فِی ثَدْیِ الْمَرْأَۃِ بِعَشْرٍ مِنَ الإِبِلِ إِذَا لَمْ یُصِبْ إِلاَّ حَلَمَۃَ ثَدْیِہَا، فَإِذَا قُطِعَ مِنْ أَصْلِہِ فَخَمْسَۃُ عَشْرٍ مِنَ الإِبِلِ۔",,,27738,,
27739,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی مَعْمَرٌ ، عَمَّنْ أَخْبَرَہُ ، عَن عِکْرِمَۃَ ؛ أَنَّ أَبَا بَکْرٍ جَعَلَ فِی حَلَمَۃِ ثَدْیِ الْمَرْأَۃِ مِئَۃَ دِینَارٍ ، وَجَعَلَ فِی حَلَمَۃِ ثَدْیِ الرَّجُلِ خَمْسِینَ دِینَارًا۔",,,27739,,
27740,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنَی دَاوُد بْنُ أَبِی عَاصِمٍ ؛ أَنَّ عَبْدَ الْمَلِکِ بْنَ مَرْوَانَ قَضَی فِی قِتَالِ غَسَّانَ وَأَصَابُوا النِّسَائَ ، فِی الثَّدْیِ بِخَمْسِینَ دِینَارًا۔",,,27740,,
27741,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، قَالَ : بَلَغَنِی عَنْ إِبْرَاہِیمَ ، قَالَ : فِی ثَدْیِ الْمَرْأَۃِ نِصْفُ الدِّیَۃِ ، وَفِی ثَدْیِ الرَّجُلِ حُکُومَۃٌ۔",,,27741,,
27742,"حَدَّثَنَا ابْنُ مَہْدِیٍّ، عَنْ مُحَمَّدِ بْنِ رَاشِدٍ، عَنْ مَکْحُولٍ، قَالَ: ثَدْیُ الْمَرْأَۃِ نِصْفُ عَقْلِہَا، وَإِنْ کَانَتْ عَاقِرًا۔",,,27742,,
27743,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ حُصَیْنٍ الْحَارِثِیِّ ، عَنِ الشَّعْبِیِّ ، عنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : مَا جَنَی الْعَبْدُ : فَفِی رَقَبَتِہِ ، وَیُخَیَّرُ مَوْلاَہُ ، إِنْ شَائَ فَدَاہُ ، وَإِنْ شَائَ دَفَعَہُ۔",,,27743,,
27744,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ طَاوُوسٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : جِنَایَۃُ الْعَبْدِ فِی رَقَبَتِہِ ، وَیُخَیَّرُ مَوْلاَہُ ، إِنْ شَائَ فَدَاہُ ، وَإِنْ شَائَ دَفَعَہُ۔",,,27744,,
27745,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : لاَ یَجْنِی الْمَمْلُوکُ عَلَی سَیِّدِہِ أَکْثَرَ مِنْ ثَمَنِ رَقَبَتِہِ۔",,,27745,,
27746,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ ، عَنْ شُرَیْحٍ ، قَالَ : مَا جَنَی الْعَبْدُ فَفِی رَقَبَتِہِ ، أَوْ یُؤَدِّی عَنْہُ سَیِّدُہُ۔",,,27746,,
27747,"حَدَّثَنَا عَبَّادٌ ، عَنْ أَشْعَثَ ، عَنْ مُحَمَّدٍ ، قَالَ : قُلْتُ لَہُ : عَبْدٌ جَنَی جِنَایَۃً ، قَالَ : فِی رَقَبَتِہِ۔",,,27747,,
27748,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : خُبِّرْتُ عَنْ سَالِمِ بْنِ عَبْدِ اللہِ ، قَالَ : إِنْ شَائَ أَہْلُ الْمَمْلُوکِ فَدَوْہُ بِعَقْلِ جُرْحِ الْجارِحِ ، وَإِنْ شَاؤُوا أَسْلَمُوہُ۔",,,27748,,
27749,"حَدَّثَنَا عَبْدُالأَعْلَی، عَنْ مَعْمَرٍ، عَنِ الزُّہْرِیِّ، قَالَ: إِنْ قَتَلَ خَطَأً: إِنْ شَائَ سَیِّدُہُ فَدَاہُ، وَإِنْ شَائَ دَفَعَہُ بِرُمَّتِہِ۔",,,27749,,
27750,"حَدَّثَنَا سُلَیْمَانُ بْنُ حَرْبٍ، عَنْ حَمَّادِ بْنِ زَیْدٍ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ، عَنْ أَبِیہِ؛ أَنَّہُ کَانَ یَقُولُ فِی الْعَبْدِ یَجْنِی الْجِنَایَۃَ ، قَالَ : مَوْلاَہُ بِالْخِیَارِ ؛ إِنْ شَائَ أَنْ یَدْفَعَ الْعَبْدَ بِالْجِنَایَۃِ ، وَإِنْ شَائَ أَعْطَی الْجِنَایَۃَ ، وَأَمْسَکَ الْعَبْدَ۔",,,27750,,
27751,"حَدَّثَنَا شَرِیکٌ، عَنْ مُغِیْرَۃ، عَنْ إِبْرَاہِیمَ، قَالَ: إِذَا جَنَی جِنَایَۃً فَعَلِمَ بِجِنَایَتِہ، فَأَعْتَقَہُ؛ فَہُوَ ضَامِن لِجِنَایَتِہِ۔",,,27751,,
27752,حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، مِثْلَہُ۔,,,27752,,
27753,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ؛ فِی الْعَبْدِ یَجُرُّ الْجَرِیرَۃَ فَیُعْتِقُہُ سَیِّدُہُ ، أَنَّہُ یَجُوزُ عِتْقُہُ ، وَیَضْمَنُ سَیِّدُہُ ثَمَنَہُ۔,,,27753,,
27754,"حَدَّثَنَا عَبَّادٌ ، عَنْ أَشْعَثَ ، عن مُحَمَّدٍ ؛ فِی الْعَبْدِ یَجْنِی الْجِنَایَۃَ ، قَالَ : فِی رَقَبَتِہِ ، قُلْتُ : فَإِنْ أَعْتَقَہُ مَوْلاَہُ ؟ قَالَ : عَلَیْہِ قِیْمَتُہُ۔",,,27754,,
27755,"حَدَّثَنَا ابْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ فِی عَبْدٍ جَنَی جِنَایَۃً ، فَعَلِمَ مَوْلاَہُ فَأَعْتَقَہُ ، قَالَ : یَسْعَی الْعَبْدُ فِی جِنَایَتِہِ۔",,,27755,,
27756,"حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الوارث ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، عَن حَمَّادٍ؛ سُئِلَ عَنِ الْعَبْدِ یُصِیبُ الْجِنَایَۃَ؟ قَالَ : سَیِّدُہُ بِالْخِیَارِ ، إِنْ شَائَ دَفَعَہُ ، وَإِنْ شَائَ أَسْلَمَہُ ، فَإِنْ أَعْتَقَہُ فَعَلَیْہِ ثَمَنُ الْعَبْدِ ، وَلَیْسَ عَلَی الْعَبْدِ شَیْئٌ إِذَا أُعْتِقَ۔",,,27756,,
27757,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا إِسْمَاعِیلُ بْنُ أَبِی خَالِدٍ ، عَن طَارِقٍ ، عَنِ الشَّعْبِیِّ ؛ فِی عَبْدٍ قَتَلَ رَجُلاً حُرًّا، فَبَلَغَ مَوْلاَہُ فَأَعْتَقَہُ ، قَالَ : عِتْقُہُ جَائِزٌ ، وَعَلَی مَوْلاَہُ الدِّیَۃُ۔",,,27757,,
27758,"حَدَّثَنَا وَکِیعٌ ، قَالَ : سَمِعْتُ سُفْیَانَ ، یَقُولُ : إِنْ کَانَ مَوْلاَہُ أَعْتَقَہُ وَقَدْ عَلِمَ بِالْجِنَایَۃِ ، فَہُوَ ضَامِنٌ لِلْجِنَایَۃِ ، وَإِنْ لَمْ یَکُنْ عَلِمَ بِالْجِنَایَۃِ فَعَلَیْہِ قِیمَۃُ الْعَبْدِ۔",,,27758,,
27759,"حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ عَلِیٍّ قَالَ : إِذَا قَتَلَ الْعَبْدُ الْحُرَّ دُفِعَ إِلَی أَوْلِیَائِ الْمَقْتُولِ ، فَإِنْ شَاؤُوا قَتَلُوہُ ، وَإِنْ شَاؤُوا اسْتَحْیَوْہُ۔",,,27759,,
27760,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : لاَ أَعْلَمُ الدَّمَ إِلاَّ لأَہْلِہِ ، إِنْ شَاؤُوا بَاعُوا ، وَإِنْ شَاؤُوا وَہَبُوا ، وَإِنْ شَاؤُوا اسْتَقَادُوا۔",,,27760,,
27761,"حَدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَن یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی عَبْدٍ قَتَلَ حُرًّا فَأُعْطِی وَرَثَتُہُ أَنْ یَقْتُلُوہُ ، قَالَ : إِنْ شَائَ اسْتَرَقُّوہُ۔",,,27761,,
27762,"حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : یُدْفَعُ إِلَی أَوْلِیَائِ الْمَقْتُولِ ، فَإِنْ شَاؤُوا قَتَلُوا ، وَإِنْ شَاؤُوا اسْتَرَقُّوا۔",,,27762,,
27763,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ (ح) وَعَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ قَالاَ : إِنْ شَاؤُوا قَتَلُوا ، وَإِنْ شَاؤُوا اسْتَرَقُّوا۔",,,27763,,
27764,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ مُحَمَّدِ بْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ؛ فِی عَبْدٍ قَتَلَ حُرًّا مُتَعَمِّدًا ، قَالَ : یُعْطَی ہَؤُلاَئِ : أَہْلُ الْمَقْتُولِ ، إِنْ شَاؤُوا قَتَلُوہُ ، وَإِنْ شَاؤُوا اسْتَرَقُّوہُ۔",,,27764,,
27765,"حَدَّثَنَا عَبَّادٌ ، عَنْ عُمَرَ بْنِ عَامِرٍ ، عَن حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ؛ فِی الْعَبْدِ یَقْتُلُ الْحُرَّ عَمْدًا ، قَالَ : لَیْسَ لَہُمْ أَنْ یَسْتَخْدِمُوہُ ، إِنَّمَا لَہُمْ دَمُہُ ، إِنْ شَاؤُوا قَتَلُوہُ ، وَإِنْ شَاؤُوا عَفَوْا عَنْہُ۔",,,27765,,
27766,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إِبْرَاہِیمَ ؛ فِی الْعَبْدِ یَقْتُلُ الْحُرَّ مُتَعَمِّدًا ، ثُمَّ یَعْفُو وَلِیُّ الدَّمِ عَنِ الدَّمِ ، قَالَ : یَرْجِعُ إِلَی مَوْلاَہُ۔",,,27766,,
27767,"حَدَّثَنَا مُعَاذٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : إِنْ عَفَوْا عَنْہُ رَجَعَ عبدًا إِلَی سَیِّدِہِ۔",,,27767,,
27768,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حَمَّادٍ ؛ فِی عَبْدٍ قَتَلَ حُرًّا فَدُفِعَ إِلَی أَوْلِیَائِہِ ، قَالَ : إِنْ عَفَوْا عَنْہُ رَجَعَ إِلَی سَیِّدِہِ ، وَلَیْسَ لَہُمْ أَنْ یَسْتَخْدِمُوہُ۔\n\nقَالَ وَکِیعٌ : وَہُوَ قَوْلُ سُفْیَانَ۔",,,27768,,
27769,"حَدَّثَنَا حَفْصٌ ، وَعَلِیٌّ ، وَعَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : قیمَتُہُ بَالِغَۃٌ مَا بَلَغَتْ۔",,,27769,,
27770,"حَدَّثَنَا إِسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ عَمْرِو بْنِ مُہَاجِرٍ ، وَسِوَادَۃَ بْنِ زِیَادٍ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : قیمَتُہُ یَوْمَ یُصَابُ۔",,,27770,,
27771,"حَدَّثَنَا إِسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَن عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ أَیُّوبَ بْنِ مُوسَی ، عَنْ عَطَائٍ وَمَکْحُولٍ ، وَابْنِ شِہَابٍ ، قَالُوا : قیمَتُہُ یَوْمَ یُصَابُ۔",,,27771,,
27772,"حَدَّثَنَا حَفْصٌ، عَنْ أَشْعَثَ، عَنِ الْحَسَنِ، وَابْنِ سِیرِینَ، أَنَّہُمَا قَالاَ: قیمَتُہُ یَوْمَ یُصَابُ ، بَالِغَۃً مَا بَلَغَتْ۔",,,27772,,
27773,"حَدَّثَنَا مَعْمَرٌ ، عَنْ حَجَّاجٍ ، عَنْ مَکْحُولٍ ، قَالَ : قیمَتُہُ یَوْمَ یُصَابُ۔",,,27773,,
27774,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ سَعِیدِ بْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، وَالْحَسَنِ ، قَالاَ : قیمَتُہُ یَوْمَ یُصَابُ ، بَالِغَۃً مَا بَلَغَتْ۔",,,27774,,
27775,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ عَلِیٍّ ، وَعَبْدِ اللہِ وَشُرَیْحٍ ، قَالُوا : ثَمَنُہُ، وَإِنْ خَلَفَ دِیَۃَ الْحُرِّ۔",,,27775,,
27776,"حَدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : ہُوَ مَالٌ مَا بَلَغَ۔",,,27776,,
27777,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ سُفْیَانَ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، قَالَ : یَبْلُغُ مَا بَلَغَ۔",,,27777,,
27778,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَن دَاوُد ، عَنِ الشَّعْبِیِّ ؛ أَنَّ سَعِیدَ بْنَ الْعَاصِ جَعَلَ دِیَۃَ عَبْدٍ قُتِلَ خَطَأً أَرْبَعَۃَ آلاَفٍ ، وَکَانَ ثَمَنُہُ أَکْثَرَ مِنْ ذَلِکَ ، وَقَالَ : أَکْرَہُ أَنْ أَجْعَلَ دِیَتَہُ أَکْثَرَ مِنْ دِیَۃِ الْحُرِّ۔",,,27778,,
27779,"حَدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لاَ یُبْلَغُ بِہِ دِیَۃُ الْحُرِّ۔",,,27779,,
27780,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ، عَنِ ابْنِ جُرَیْجٍ، عَنْ عَطَائٍ، قَالَ: لاَ یُزَادُ السَّیْدُ عَلَی دِیَۃِ الْحُرِّ۔(عبدالرزاق 18169)",,,27780,,
27781,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، وَالشَّعْبِیِّ ، قَالاَ : لاَ یُبْلَغُ بِدِیَۃِ الْعَبْدِ دِیَۃَ الْحُرِّ فِی الْخَطَأِ۔",,,27781,,
27782,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : دِیَۃُ الْمَمْلُوکِ أَنْقَصُ مِنْ دِیَۃِ الْحُرِّ۔",,,27782,,
27783,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا أُصِیبَتْ أُذُنُ الْعَبْدِ ، أَوْ عَیْنُہُ فَفِیہَا نِصْفُ ثَمَنِہِ ، وَإِذَا أُصِیبَتْ أُذُنَاہُ ، أَوْ عَیْنَاہُ فَفِیہَا ثَمَنُہُ کُلُّہُ ، وَیَدْفَعُہُ إِلَی الَّذِی أَصَابَہُ۔",,,27783,,
27784,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : إِذَا فُقِئَتْ عَیْنُ الْعَبْدِ ، أَوْ قُطِعَتْ یَدُہُ ، أَوْ رِجْلُہُ ؛ فَعَلَیْہِ نِصْفُ قِیمَتِہِ ، وَإِذَا فُقِئَتْ عَیْنَاہُ ، أَوْ قُطِعَتْ یَدَاہُ ، أَوْ رِجْلاَہُ ؛دَفَعَہُ وَعَلَیْہِ قِیمَتُہُ۔",,,27784,,
27785,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَن یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی الْمَمْلُوکِ إِذَا فُقِئَتْ عَیْنُہُ ، فَفِیہَا نِصْفُ ثَمَنِہِ۔,,,27785,,
27786,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ إِیَاسِ بْنِ مُعَاوِیَۃَ ؛ فِی رَجُلٍ قَطَعَ یَدَ عَبْدٍ عَمْدًا ، أَوْ فَقَأَ عَیْنَہُ ، قَالَ : ہُوَ لَہُ ، وَعَلَیْہِ ثَمَنُہُ۔",,,27786,,
27787,"حَدَّثَنَا عَبْدُالأَعْلَی، عَنْ مَعْمَرٍ، عَنِ الزُّہْرِیِّ، فِی الْحُرِّ یَجْرَحُ الْعَبْدَ، قَالَ: إِنْ فَقَأَ عَیْنَہُ فَفِیہَا نِصْفُ ثَمَنِہِ۔",,,27787,,
27788,حَدَّثَنَا وَکِیعٌ ، عَنِ النَّہَّاسِ بْنِ قَہْمٍ ، عَنْ عَطَائٍ ؛ فِی مُوضِحَۃِ الْعَبْدِ ، نِصْفُ عُشْرِ ثَمَنِہِ۔,,,27788,,
27789,حَدَّثَنَا وَکِیعٌ ، عَن زَکَرِیَّا ، عَنِ الشَّعْبِیِّ ؛ فِی مُوضِحَۃِ الْعَبْدِ ، نِصْفُ عُشْرِ ثَمَنِہِ۔,,,27789,,
27790,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، عَنْ شُرَیْحٍ ، قَالَ : قضَی فِی سِنِّ الْعَبْدِ وَمُوضِحَتِہِ عَلَی قَدْرِ قِیمَتِہِ مِنْ ثَمَنِہِ ؛ نِصْفُ عُشْرِ قِیمَتِہِ ، کَنَحْوٍ مِنْ دِیَۃِ الْحُرِّ فِی السِّنِّ وَالْمُوضِحَۃِ۔",,,27790,,
27791,حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، عن شُرَیْحٍ ؛ بِنَحْوِ ذَلِکَ۔,,,27791,,
27792,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، وَحَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : جِرَاحَۃُ الْعَبْدِ مِنْ ثَمَنِہِ ، کَجِرَاحَۃِ الْحُرِّ مِنْ دِیَتِہِ ، الْعُشْرُ وَنِصْفُ الْعُشْرِ۔",,,27792,,
27793,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : عَقْلُ الْعَبْدِ فِی ثَمَنِہِ۔",,,27793,,
27794,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : جِرَاحَۃُ الْعَبْدِ فِی ثَمَنِہِ مِثْلُ جِرَاحَۃِ الْحُرِّ فِی دِیَتِہِ ، وَقَالَ الزُّہْرِیُّ : قَالَ أُنَاسٌ : إِنَّمَا ہُوَ مَالٌ ، فَعَلَی قَدْرِ مَا انْتَقَصَ مِنْ ثَمَنِہِ۔",,,27794,,
27795,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ أَیُّوبَ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : تَجْرِی جِرَاحَاتُ الْعَبِیدِ عَلَی مَا تَجْرِی عَلَیْہِ جِرَاحَاتُ الأَحْرَارِ۔",,,27795,,
27796,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ أَبِی حُرَّۃَ ، عَنِ الْحَسَنِ ؛ فِی حُرٍّ أَصَابَ مِنْ عَبْدٍ شَیْئًا ، قَالَ : یُردّ عَلَی مَوْلاَہُ مَا نَقَصَ مِنْ ثَمَنِہِ۔",,,27796,,
27797,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : عَقْلُ الْعَبْدِ فِی ثَمَنِہِ ، مِثْلُ عَقْلِ الرَّجُلِ الْحُرِّ فِی دِیَتِہِ۔",,,27797,,
27798,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حَجَّاجٍ ، عَنْ حُصَیْنٍ الْحَارِثِیِّ ، عَنِ الشَّعْبِیِّ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : تَجْرِی جِرَاحَاتُ الْعَبِیدِ عَلَی مَا تَجْرِی عَلَیْہِ جِرَاحَاتُ الأَحْرَارِ۔",,,27798,,
27799,"حَدَّثَنَا ہُشَیْمٌ ، وَابْنُ عُلَیَّۃَ ، عَن خَالِدٍ ، عَنِ ابْنِ سِیرِینَ ، عَنْ شُرَیْحٍ ؛ فِی عَبْدٍ جَرَحَ حُرًّا ، قَالَ : إِنْ شَائَ اقْتَصَّ مِنْہُ ، وَإِنْ شَائَ أَخَذَ بِخُمَاشتہِ أَرْشًا۔",,,27799,,
27800,"حَدَّثَنَا جَرِیرٌ، عَنْ مُغِیرَۃَ، عَنْ إِبْرَاہِیمَ، قَالَ: إِذَا شَجَّ الْحُرُّ الْعَبْدَ مُتَعَمِّدًا، فَإِنَّمَا ہِیَ دِیَۃٌ لَیْسَ لَہُ عَلَیْہِ قَود۔",,,27800,,
27801,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : لاَ یُقَادُ الْحُرُّ مِنَ الْعَبْدِ۔",,,27801,,
27802,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، وَالْحَسَنِ (ح) وَعَنِ الْحَکَمِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لَیْسَ بَیْنَ الْمَمْلُوکِینَ وَالأَحْرَارِ قِصَاصٌ فِیمَا دُونَ النَّفْسِ۔",,,27802,,
27803,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : الْعَبْدُ یَشُجُّ الْحُرَّ ، أَوْ یَفْقَأُ عَیْنَہُ ، فَیُرِیدُ الْحُرُّ أَنْ یَسْتَقِیدَ مِنَ الْعَبْدِ ، قَالَ : لاَ یَسْتَقِیدُ حُرٌّ مِنْ عَبْدٍ ، وَقَالَ مِثْلَ ذَلِکَ مُجَاہِدٌ ، وَسُلَیْمَانُ بْنُ مُوسَی۔",,,27803,,
27804,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أُخْبِرْتُ عَن سَالِمٍ ، قَالَ : لاَ یَسْتَقِیدُ الْعَبْدُ مِنَ الْحُرِّ۔",,,27804,,
27805,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : لاَ قَوَدَ بَیْنَ الْحُرِّ وَالْعَبْدِ ، إِلاَّ أَنَّ الْعَبْدَ إِذَا قَتَلَ الْحُرَّ قُتِلَ بِہِ۔",,,27805,,
27806,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، وَحَمَّادٍ ، قَالاَ : لَیْسَ بَیْنَ الْمَمْلُوکِینَ قِصَاصٌ۔",,,27806,,
27807,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، وَالْحَسَنِ (ح) وَعَنِ الْحَکَمِ ، وَحَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالُوا : لَیْسَ بَیْنَ الْمَمْلُوکِینَ قِصَاصٌ فِیمَا دُونَ النَّفْسِ۔",,,27807,,
27808,"حَدَّثَنَا عَبَّادٌ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنْ إِبْرَاہِیمَ ، وَالشَّعْبِیِّ ؛ أَنَّہُمَا قَالاَ : لَیْسَ بَیْنَ الْمَمْلُوکِینَ قِصَاصٌ ، وَلَیْسَ بَیْنَ الصِّبْیَانِ قِصَاصٌ۔",,,27808,,
27809,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أُخْبِرْتُ عَن سَالِمٍ ، أَنَّہُ قَالَ : إِذَا عَمَدَ الْمَمْلُوکُ فَقَتَلَ الْمَمْلُوکَ ، أَوْ جَرَحَہُ ، فَہُوَ بِہِ قَوَدٌ۔",,,27809,,
27810,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : یُقَادُ الْمَمْلُوکُ مِنَ الْمَمْلُوکِ فِی کُلِّ عَمْدٍ یَبْلُغُ قِیمَۃَ نَفْسِہِ ، فَمَا دُونَ ذَلِکَ مِنَ الْجِرَاحَاتِ۔",,,27810,,
27811,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ عُمَرَ ؛ أَنَّ فِی کِتَابٍ لِعُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، عَنْ عُمَرَ بْنِ الْخَطَّابِ : یُقَادُ الْمَمْلُوکُ مِنَ الْمَمْلُوکِ فِی عَمْدٍ یَبْلُغُ نَفْسَہُ فَمَا دُونَ ذَلِکَ۔",,,27811,,
27812,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَن زُہَیْرٍ ، عَنِ الْحَسَنِ بْنِ الْحُرِّ ، عَنِ الْحَکَمِ ، عَنْ إِبْرَاہِیمَ ، وَالشَّعْبِیِّ ، عَنْ عَبْدِ اللہِ بْنِ مَسْعُودٍ ، قَالَ : إِنَّ الْعَبْدَ لاَ یُقَادُ مِنَ الْعَبْدِ فِی جِرَاحَۃِ عَمْدٍ ، وَلاَ خَطَأٍ ، إِلاَّ فِی قَتْلِ عَمْدٍ۔",,,27812,,
27813,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَن یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَرَی الْقِصَاصَ بَیْنَ الْعَبِیدِ۔,,,27813,,
27814,"حَدَّثَنَا شَبَابَۃُ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الْحَارِثِ ، قَالَ : قَالَ : رَأَیْتُ نَوْفَلَ بْنَ مُسَاحِقٍ یقتصّ لِلْعَبِید بَعْضِہمْ مِنْ بَعْضٍ۔",,,27814,,
27815,"حَدَّثَنَا إِسْمَاعِیلُ بْنُ إِبْرَاہِیمَ ، عَن خَالِدٍ الْحَذَّائِ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : کَانَ لاَ یَرَی بَأْسًا فِی الرَّجُلِ یَقْتُلُہُ الرَّجُلاَنِ أَنْ یُقْتَلَ أَحَدُہُمَا ، وَتُؤْخَذ الدِّیَۃُ مِنَ الآخَرِ۔",,,27815,,
27816,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ؛ فِی الرَّجُلِ یَقْتُلُہُ النَّفَرُ ، قَالَ : یُدْفَعُونَ إِلَی أَوْلِیَائِ الْمَقْتُولِ ، فَیَقْتُلُونَ مَنْ شَاؤُوا ، وَیَعْفُونَ عَمَّنْ شَاؤُوا۔",,,27816,,
27817,"حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ، عَنِ ابْنِ جُرَیْجٍ، عَنْ عَطَائٍ، قَالَ: إِذَا عَفَا عَنْ أَحَدِہِمْ، فَلْیَعْفُ عَنہُمْ جَمِیعًا۔",,,27817,,
27818,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُ قَالَ فِی رَجُلٍ قَتَلَہُ ثَلاَثَۃُ نَفَرٍ ، فَأَرَادَ وَلِیُّہُ أَنْ یَعْفُوَ عَن بَعْضٍ وَیَقْتُلَ بَعْضًا ، وَیَأْخُذَ مِنْ بَعْضٍ الدِّیَۃَ ، قَالَ : لَیْسَ لَہُ ذَلِکَ۔",,,27818,,
27819,"حَدَّثَنَا بَہْزُ بْنُ أَسَدٍ ، عَنْ أَبَانَ الْعَطَّارِ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ فِی الرَّجُلِ یَقْتُلُہُ النَّفَرُ ، قَالَ : یَعْفُوَ عَمَّنْ شَائَ ، وَیَقْتُلُ مَنْ شَائَ ، وَیَأْخُذُ الدِّیَۃَ مِمَّنْ شَائَ۔",,,27819,,
27820,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنِ الْحَکَمِ ، عَنْ إِبْرَاہِیمَ ؛ فِی الرَّجُلِ یَقْتُلُہُ النَّفَرُ ، قَالَ : یَقْتُلُ مَنْ شَائَ ، وَیَعْفُوَ عَمَّنْ شَائَ ، وَیَأْخُذَ الدِّیَۃَ مِمَّنْ شَائَ۔",,,27820,,
27821,"حَدَّثَنَا إِسْمَاعِیلُ بْنُ عُلَیَّۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ إِسْحَاقَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : جَنِینُ الأَمَۃِ عَشَرَۃُ دَنَانِیرَ۔",,,27821,,
27822,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَبْدِ الْخَالِقِ ، عَن حَمَّادٍ ، قَالَ : فِی جَنِینِ الأَمَۃِ حُکْمٌ۔",,,27822,,
27823,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ، عَنْ أَشْعَثَ، عَنِ الْحَسَنِ، قَالَ: جَنِینُ الأَمَۃِ إِذَا اسْتَہَلَّ، فَقِیمَتُہُ یَوْمَ اسْتَہَلَّ۔",,,27823,,
27824,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، قَالَ : کَانُوا یَأْخُذُونَ جَنِینَ الأَمَۃِ مِنْ جَنِینِ الْحُرَّۃِ۔",,,27824,,
27825,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، وَحَمَّادٍ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّہُ قَالَ : فِی جَنِینِ الأَمَۃِ مِنْ ثَمَنِہَا ، کَنَحْوٍ مِنْ جَنِینِ الْحُرَّۃِ مِنْ دِیَتِہَا ؛ الْعُشْرُ ، وَنِصْفُ الْعُشْرِ۔",,,27825,,
27826,"حَدَّثَنَا مُحَمَّدُ بْنُ یَزِیدَ ، عَنْ أَبِی الْعَلاَئِ ، عَنْ قَتَادَۃَ ، قَالَ : إِنْ وَقَعَ حَیًّا فَعَلَیْہِ ثَمَنُہُ ، وَإِنْ وَقَعَ مَیِّتًا فَعَلَیْہِ عُشْرُ ثَمَنِ أُمِّہِ۔",,,27826,,
27827,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَن یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی جَنِینِ الأَمَۃِ عُشْرُ ثَمَنِہَا۔,,,27827,,
27828,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : عُشْرُ ثَمَنِہَا۔",,,27828,,
27829,"حَدَّثَنَا أَبُو بَکْرٍ ، قَالَ : سَمِعْتُ وَکِیعًا ، یَقُولُ : قَالَ سُفْیَانُ : وَنَحْنُ نَقُولُ : إِنْ کَانَ غُلاَمًا فَنِصْفُ عُشْرِ قِیمَتِہِ ، وَإِنْ کَانَتْ جَارِیَۃً فَعُشْرُ قِیمَتِہَا لَوْ کَانَتْ حَیَّۃً۔",,,27829,,
27830,حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَن حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ؛ فِی جَنِینِ الدَّابَّۃِ قِیمَتُہُ۔,,,27830,,
27831,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، قَالَ : کَانُوا یَأْخُذُونَ جَنِینِ الدَّابَّۃِ مِنْ جَنِینِ الأَمَۃِ۔",,,27831,,
27832,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ فِی جَنِینِ الدَّابَّۃِ عُشْرُ ثَمَنِ أُمِّہِ۔,,,27832,,
27833,"حَدَّثَنَا عُمَرُ ، عَن یُونُسَ ، عَنِ الزُّہْرِیِّ ؛ فِی جَنِینِ الْبَہِیمَۃِ ، قَالَ : نَرَی الْبَہِیمَۃِ سِلْعَۃٌ ، یُقَیِّمُ جَنِینَہَا الْحَاکِمُ ، مَا رَأَی بِرَأْیِہِ۔",,,27833,,
27834,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إِسْرَائِیلُ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ؛ فِی وَلَدِ الْبَہِیمَۃِ حُکُومَۃٌ۔",,,27834,,
27835,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَضَی فِی الْجَنِینِ ؛ عَبْدًا ، أَوْ أَمَۃً ، فَقَالَ : الَّذِی قَضَی عَلَیْہِ : أَیُعْقَل مَنْ لاَ شَرِبَ، وَلاَ أَکَلَ ، وَلاَ صَاحَ ، فَاسْتَہَلَّ ، وَمِثْلُ ذَلِکَ یُطَلُّ ؟ فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنَّ ہَذَا لَیَقُولُ بِقَوْلِ شَاعِرٍ ، فِیہِ غُرَّۃٌ عَبْدٌ ، أَوْ أَمَۃٌ۔ (ابوداؤد 4568۔ ترمذی 1410)",,,27835,,
27836,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنِ الْمِسْوَرِ بْنِ مَخْرَمَۃَ ، قَالَ : اسْتَشَارَ عُمَرُ بْنُ الْخَطَّابِ فِی إِمْلاَصِ الْمَرْأَۃِ ، فَقَالَ : الْمُغِیرَۃُ بْنُ شُعْبَۃَ : شَہِدْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَضَی فِیہِ بِغُرَّۃٍ؛ عَبْدٍ ، أَوْ أَمَۃٍ ، قَالَ : فَقَالَ لَہُ عُمَرُ : ائْتِنِی بِمَنْ شَہِدَ مَعَکَ ، فَشَہِدَ لَہُ مُحَمَّدُ بْنُ مَسْلَمَۃَ۔\n\n(بخاری 6907۔ ابوداؤد 4559)",,,27836,,
27837,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : فِی الْجَنِینِ غُرَّۃٌ ؛ عَبْدٌ ، أَوْ أَمَۃٌ ، أَوْ بَغْلٌ۔ (ابوداؤد 4568)",,,27837,,
27838,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، قَالَ : فِیہِ عَبْدٌ ، أَوْ أَمَۃٌ ، أَوْ فَرَسٌ۔",,,27838,,
27839,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، قَالَ : غُرَّۃٌ ؛ عَبْدٌ ، أَوْ أَمَۃٌ لأُِمِّہِ ، أَوْ لأَقْرَبِ النَّاسِ مِنْہُ۔",,,27839,,
27840,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ ، وَالْحَکَمِ ؛ قَالاَ : جَنِینُ الْحُرَّۃِ عَبْدٌ ، أَوْ أَمَۃٌ۔",,,27840,,
27841,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُحَمَّدِ بْنِ قَیْسٍ ، عَنِ الشَّعْبِیِّ ؛ فِی رَجُلٍ ضَرَبَ بَطْنَ امْرَأَتِہِ فَأَسْقَطَتْ ، قَالَ : عَلَیْہِ غُرَّۃٌ یَرِثُہَا وَتَرِثَہُ۔",,,27841,,
27842,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ لَیْثٍ ، عَن طَاوُوسٍ ، وَمُجَاہِدٍ ؛ قَالاَ : فِی الْغُرَّۃِ عَبْدٌ ، أَوْ أَمَۃٌ ، أَوْ فَرَسٌ۔",,,27842,,
27843,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ لَیْثٍ ، عَن مُجَاہِدٍ ، قَالَ : عَبْدٌ ، أَوْ أَمَۃٌ ، أَوْ فَرَسٌ۔",,,27843,,
27844,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : فِی امْرَأَۃٍ شَرِبَتْ دَوَائً فَأَسْقَطَتْ ، قَالَ : تُعْتِقُ رَقَبَۃً ، وَتُعْطِی أَبَاہُ غُرَّۃً۔",,,27844,,
27845,"حَدَّثَنَا یُونُسُ بْنُ مُحَمَّدٍ ، قَالَ : حدَّثَنَا عَبْدُ الْوَاحِدِ بْنُ زِیَادٍ ، عَن مُجَالِدٍ ، عَنِ الشَّعْبِیِّ ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ أَنَّہُ قَالَ : فِی الْغُرَّۃِ عَبْدٌ ، أَوْ أَمَۃٌ۔ (مسند 1901)",,,27845,,
27846,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : فِی أَصْلِ کُلِّ حَبَلٍ غُرَّۃٌ ، قَالَ : وَقَالَ الْحَکَمُ : فِیہِ صُلْحٌ حَتَّی یَسْتَبِینَ خَلْقُہُ۔\n\nقَالَ وَکِیعٌ : وَقَوْلُ الْحَکَمِ أَحْسَنُ مِنْ قَوْلِ الشَّعْبِیِّ۔",,,27846,,
27847,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ (ح) وَعَن یُونُسَ ، عَنِ الْحَسَنِ (ح) وَحَجَّاجٍ ، عَنْ عَطَائٍ ؛ قَالُوا فِیمَنْ أَصَابَ جَنِینًا : إِنَّ عَلَیْہِ عِتْقَ رَقَبَۃٍ مَعَ الْغُرَّۃِ۔",,,27847,,
27848,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، قَالَ : سَمِعْتُہ یَقُولُ : إِذَا ضُرِبَتِ الْمَرْأَۃُ فَأَلْقَتْ جَنِینًا ، فَإِنَّ صَاحِبَہُ یُعْتِقُ۔",,,27848,,
27849,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، وَوَکِیعٌ ، قَالاَ : حدَّثَنَا عُمَرُ بْنُ ذَرٍّ ، عَن مُجَاہِدٍ ؛ أَنَّ امْرَأَۃً مَسَحَتْ بَطْنَ امْرَأَۃٍ فَأَسْقَطَتْ ، فَأَمَرَہَا عُمَرُ بْنُ الْخَطَّابِ أَنْ تُعْتِقَ۔",,,27849,,
27850,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَن طَارِقٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : الْغُرَّۃُ خَمْسُ مِئَۃٍ۔",,,27850,,
27851,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ لَیْثٍ ، عَن حَبِیبِ بْنِ أَبِی ثَابِتٍ ، قَالَ : قیمَۃُ الْغُرَّۃِ أَرْبَعُ مِئَۃِ دِرْہَمٍ۔",,,27851,,
27852,حَدَّثَنَا إِسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَن زَیْدِ بْنِ أَسْلَمَ ؛ أَنَّ عُمَرَ بْنَ الْخَطَّابِ قَوَّمَ الْغُرَّۃَ خَمْسِینَ دِینَارًا۔,,,27852,,
27853,حَدَّثَنَا حَفْصٌ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ جَعَلَ الْغُرَّۃَ عَلَی الْعَاقِلَۃِ۔,,,27853,,
27854,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ، وَابْنُ مَہْدِیٍّ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : الْغُرَّۃُ عَلَی الْعَاقِلَۃِ۔",,,27854,,
27855,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : فی مَالِہِ۔",,,27855,,
27856,"حَدَّثَنَا یُونُسُ بْنُ مُحَمَّدٍ ، قَالَ : حدَّثَنَا عَبْدُ الْوَاحِدِ بْنُ زِیَادٍ ، عَنِ الْمُجَالِدِ ، عَنِ الشَّعْبِیِّ ، عَنْ جَابِرٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ جَعَلَ فِی الْجَنِینِ غُرَّۃً عَلَی عَاقِلَۃِ الْقَاتِلَۃِ ، وَبَرَّأَ زَوْجَہَا وَوَلَدَہَا۔\n\n(بخاری 6740۔ مسلم 1309)",,,27856,,
27857,"حَدَّثَنَا یَحْیَی بْنُ یَعْلَی التَّیْمِیُّ ، عَن مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَن عُبَیْدِ بْنِ نُضِیلَۃَ ، عَنِ الْمُغِیرَۃِ بْنِ شُعْبَۃَ، قَالَ : قضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَلَی عَاقِلَتِہَا بِالدِّیَۃِ ، وَفِی الْحَمْلِ غُرَّۃٌ۔\n\n(مسلم 1310۔ ابوداؤد 4557)",,,27857,,
27858,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ أَبِی إِسْحَاقَ ، عَنْ یَزِیدَ بْنِ عَبْدِ اللہِ بْنِ قُسَیْطٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّ عُمَرَ جَعَلَ الْغُرَّۃَ عَلَی أَہْلِ الْقَرْیَۃِ ، وَالْفَرَائِضَ عَلَی أَہْلِ الْبَادِیَۃِ۔,,,27858,,
27859,"حَدَّثَنَا عَبْدُ الْوَہَّابِ بْنُ عَطَائٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، قَالَ : دِیَۃُ الْجَنِینِ عَلَی الَّذِی أَصَابَہُ فِی مَالِہِ ، وَلَیْسَ عَلَی قَوْمِہِ شَیْئٌ۔",,,27859,,
27860,"حَدَّثَنَا إِسْمَاعِیلُ بْنُ عُلَیَّۃَ ، عَنْ عَلِیِّ بْنِ الْحَکَمِ ، عَنْ إِسْحَاقَ ، عَنِ الضَّحَّاکِ ، عَنْ عَلِیٍّ ؛ أَنَّہُ قَالَ : لَیْسَ فِی الْجَائِفَۃِ ، وَلاَ الْمَأْمُومَۃِ ، وَلاَ الْمُنَقِّلَۃِ قِصَاصٌ۔",,,27860,,
27861,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لَیْسَ فِی الآمَّۃِ ، وَالْمُنَقِّلَۃِ ، وَالْجَائِفَۃِ قَوَدٌ ، إِنَّمَا عَمْدُہَا الدِّیَۃُ فِی مَالِ الرَّجُلِ۔",,,27861,,
27862,"حَدَّثَنَا إِسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ یُقَادُ مِنَ الْجَائِفَۃِ ، وَلاَ مِنَ الْمَأْمُومَۃِ ، وَلاَ مِنَ الْمُنَقِّلَۃِ ، وَلاَ مِنْ شَیْئٍ یُخَافُ فِیہِ عَلَی النَّفْسِ ، وَلاَ مِنْ شَیْئٍ لاَ یَأْتِی کَمَا أَصَابَ صَاحِبہُ۔",,,27862,,
27863,"حَدَّثَنَا إِسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَن عُبَیْدِ اللہِ بْنِ عُبَیْدٍ الْکَلاَعِیِّ ، عَنْ مَکْحُولٍ ، قَالَ : لاَ یُقَادُ مِنَ الْجَائِفَۃِ ، وَالْمَأْمُومَۃِ ، وَالْمُنَقِّلَۃِ ، وَالنَّاخِرَۃِ۔",,,27863,,
27864,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : لَیْسَ فِی الآمَّۃِ ، وَلاَ فِی الْجَائِفَۃِ ، وَلاَ فِی کَسْرِ الْعِظَامِ قِصَاصٌ۔",,,27864,,
27865,"حَدَّثَنَا أَبُو خَالِدٍ ، عَن عِیسَی ، عَنِ الشَّعْبِیِّ ، قَالَ : لَیْسَ فِی جَائِفَۃٍ ، وَلاَ مَأْمُومَۃٍ ، وَلاَ مُنَقِّلَۃٍ قِصَاصٌ ، وَلاَ فِی الْفَخِذِ إِذَا کُسِرَتْ۔",,,27865,,
27866,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنْ أَبِی بَکْرِ بْنِ حَفْصٍ ، قَالَ : رَأَیْتُ ابْنَ الزُّبَیْرِ أَقَادَ مِنْ مَأْمُومَۃٍ ۔ قَالَ : فَرَأَیْتُہُمَا یَمْشِیَانِ مَأْمُومَیْنِ جَمِیعًا۔",,,27866,,
27867,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ؛ أَنَّ ابْنَ الزُّبَیْرِ أَقَادَ مِنْ مُنَقِّلَۃٍ۔,,,27867,,
27868,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عَمْرِو بْنِ دِینَارٍ ؛ أَنَّ ابْنَ الزُّبَیْرِ أَقَادَ مِنْ مُنَقِّلَۃٍ ، قَالَ : فَأُعْجِبَ النَّاسُ ، أَوْ جَعَلَ النَّاسَ یَعجَبُونَ۔",,,27868,,
27869,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، عَنْ عُمَرَ ، قَالَ : إِنَّا لاَ نُقِیدُ مِنَ الْعِظَامِ۔",,,27869,,
27870,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لَیْسَ فِی الْعِظَامِ قِصَاصٌ۔",,,27870,,
27871,"حَدَّثَنَا جَرِیرٌ، عَنْ حُصَیْنٍ، قَالَ: کَتَبَ عُمَرُ بْنُ عَبْدِالْعَزِیزِ: مَا کَانَ مِنْ کَسْرٍ فِی عَظْمٍ فَلاَ قِصَاصَ فِیہِ۔",,,27871,,
27872,"حَدَّثَنَا شَرِیکٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ (ح) وَعَنْ جَابِرٍ ، عَنْ عَامِرٍ ؛ قَالاَ : لاَ قِصَاصَ فِی عَظْمٍ۔",,,27872,,
27873,"حَدَّثَنَا ابْنُ إِدْرِیسَ، عَنِ الشَّیْبَانِیِّ، عَنِ الشَّعْبِیِّ، قَالَ: لَیْسَ فِی شَیْئٍ مِنَ الْعِظَامِ قِصَاصٌ، إِلاَّ الْوَجْہَ وَالرَّأْسَ۔",,,27873,,
27874,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : لَیْسَ فِی کَسْرِ الْعِظَامِ قِصَاصٌ۔",,,27874,,
27875,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، وَالْحَسَنِ ، قَالاَ : لَیْسَ فِی عَظْمٍ قِصَاصٌ۔",,,27875,,
27876,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : إِذَا کُسِرَتِ الْیَدُ وَالسَّاقُ فَلَیْسَ عَلَی کَاسِرِہَا قَوَدٌ ، وَلَکِنْ عَلَیْہِ الدِّیَۃُ۔",,,27876,,
27877,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ قَتَادَۃَ ، عَن خِلاَسٍ ، عَنْ عَلِیٍّ؛ أَنَّہُ کَانَ یضَمِّنُ الْقَائِدَ، وَالسَّائِقَ، وَالرَّاکِبَ۔,,,27877,,
27878,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی حَصَیْنٍ ، عَنْ شُرَیْحٍ (ح) وَعَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، (ح) وَعَنْ طَارِقٍ ، عَنِ الشَّعْبِیِّ ، قَالُوا : یضَمِّنُ الْقَائِدَ ، وَالسَّائِقَ ، وَالرَّاکِبَ۔",,,27878,,
27879,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ إِسْمَاعِیلَ بْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : سَمِعْتُُُہ یَقُولُ : إِذَا سَاقَ الرَّجُلُ دَابَّتَہُ سَوْقًا رَفِیقًا فَلاَ ضَمَانَ عَلَیْہِ ، وَإِذَا أَعَنْفَ فِی سَوْقِہَا فَأَصَابَتْ ، فَہُوَ ضَامِنٌ۔",,,27879,,
27880,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : یَضْمَنُ السَّائِقُ وَالْقَائِدُ۔",,,27880,,
27881,"حَدَّثَنَا عَبَّادٌ ، عَنْ عُمَرَ بْنِ عَامِرٍ ، عَنْ قَتَادَۃَ ، عَن خِلاَسٍ ، عَنْ عَلِیٍّ ، قَالَ : إِذَا کَانَ الطَّرِیقُ وَاسِعًا فَلاَ ضَمَانَ عَلَیْہِ۔",,,27881,,
27882,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ قَالَ : یَغْرَمُ الْقَائِدُ ، قُلْتُ : وَالسَّائِقُ یَغْرَمُ عَنِ الْیَدِ وَالرِّجْلِ ؟ قَالَ : زَعَمُوا أَنَّہُ یَغْرَمُ عَنِ الْیَدِ ، فَرَادَدْتُہُ ، فَقَالَ : یَقُولُ : الطَّرِیقَ الطَّرِیقَ۔",,,27882,,
27883,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَن زُہَیْرٍ ، عَنِ الْحَسَنِ بْنِ الْحُرِّ ، عَنِ الْحَکَمِ ، قَالَ : إِنَّ السَّائِقَ ، وَالْقَائِدَ ، وَالرَّاکِبَ یَغْرَمُ مَا أَصَابَتْ دَابَّتُہُ بِیَدٍ ، أَوْ رِجْلٍ ، وَطِئَتْ ، أَوْ ضَرَبَتْ۔",,,27883,,
27884,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَن زُہَیْرٍ ، عَنْ لَیْثٍ ، عَن طَاوُوسٍ ، قَالَ : یَضْمَنُ الْقَائِدُ ، وَالسَّائِقُ ، وَالرَّاکِبُ مَا أَصَابَتْ بِمُقَدَّمِہَا۔",,,27884,,
27885,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ قَتَادَۃَ ، عَن خِلاَسٍ ، عَنْ عَلِیٍّ ، قَالَ : یُضَمِّنُ الرَّدِیفَان۔",,,27885,,
27886,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَن مُجَالِدٍ ، عَنِ الشَّعْبِیِّ ، عَنْ شُرَیْحٍ ، قَالَ : لَیْسَ عَلَی الرِّدْفِ ضَمَانٌ۔",,,27886,,
27887,"حَدَّثَنَا وَکِیعٌ ، عَن حَسَنٍ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ؛ فِی الرِّدْفِ ، قَالَ : ہُمَا شَرِیکَانِ۔",,,27887,,
27888,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : الرَّاکِبُ وَالرِّدْفُ سَوَائٌ ، مَا أَوْطَأا ، فَہُوَ بَیْنَہُمَا نِصْفَانِ۔",,,27888,,
27889,"حَدَّثَنَا مُحَمَّدُ بْنُ یَزِیدَ، عَنْ أَبِی الْعَلاَئِ، عَنْ قَتَادَۃَ، وَأَبِی ہَاشِمٍ، قَالاَ: یَضْمَنُ الرِّدْفُ مَا یَضْمَنُ الْمُقَدَّمُ۔",,,27889,,
27890,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ، قَالَ : یَضْمَنُ الرِّدْفُ۔",,,27890,,
27891,"حَدَّثَنَا أَبُو بَکْرٍ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : الْعَقْلُ عَلَی أَہْلِ الدِّیوَانِ۔",,,27891,,
27892,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی حُرَّۃَ ، عَنِ الْحَسَنِ ، قَالَ : الْعَقْلُ عَلَی أَہْلِ الدِّیوَانِ۔",,,27892,,
27893,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَن حَسَنٍ ، عَنْ مُطَرِّفٍ ، عَنِ الْحَکَمِ ، قَالَ : عُمَرُ أَوَّلُ مَنْ جَعَلَ الدِّیَۃَ عَشَرَۃً عَشَرَۃً فِی أَعْطِیَاتِ الْمُقَاتَلَۃِ دُونَ النَّاسِ۔",,,27893,,
27894,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ ابْنٍ لِمُحَمَّدِ بْنِ إِبْرَاہِیمَ التَّیْمِیِّ ، عَنْ أَبِیہِ ، عَنِ السَّلُولِیِّ ، عَن مُعَاذِ بْنِ جَبَلٍ ، عَنْ أَبِی عُبَیْدَۃَ بْنِ الْجَرَّاحِ ، قَالَ : جِنَایَۃُ الْمُدَبَّرِ عَلَی مَوْلاَہُ۔",,,27894,,
27895,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : جِنَایَۃُ الْمُدَبَّرِ عَلَی مَوْلاَہُ۔",,,27895,,
27896,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی ذِئْبٍ قَالَ : حدَّثَنِی یُسَیْرٌ الْمُکْتِبُ ، أَنَّ امْرَأَۃً دَبَّرَتْ جَارِیَۃً لَہَا فَجَنَتْ جِنَایَۃً ، فَقَضَی عُمَرُ بْنُ عَبْدِ الْعَزِیزِ بِجِنَایَتِہَا عَلَی مَوْلاَتِہَا فِی قِیمَۃِ الْجَارِیَۃِ۔",,,27896,,
27897,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَن یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی جِنَایَۃِ الْمُدَبَّرِ ، قَالَ : ہُوَ عَبْدٌ ، إِنْ شَائَ مَوْلاَہُ أَسْلَمَہُ ، وَإِنْ شَائَ فَدَاہُ۔",,,27897,,
27898,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، وَحَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا قَتَلَ الْمُدَبَّرُ قَتِیلاً ، أَوْ فَقَأَ عَیْنًا ، قِیلَ لِمَوْلاَہُ : ادْفَعْہُ ، أَوِ افْدِہِ۔",,,27898,,
27899,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ، عَنْ مُحَمَّدِ بْنِ سَالِمٍ، عَنْ عَامِرٍ، قَالَ: جِنَایَۃُ الْمُدَبَّرِ، وَأُمِّ الْوَلَدِ عَلَی عَاقِلَۃِ مَوَالِیہَا۔",,,27899,,
27900,"حَدَّثَنَا غُنْدَرٌ، عَنْ شُعْبَۃَ، عَن حَمَّادٍ، قَالَ: عَلَی مَوَالِیہِمُ الدِّیَۃُ إِذَا قَتَلُوا، وَإِنْ قتلوا فَدِیَتُہُمْ دِیَۃُ الْمَمْلُوکِ۔",,,27900,,
27901,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَن خَالِدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : جِنَایَۃُ الْمُدَبَّرِ عَلَی سَیِّدِہِ۔",,,27901,,
27902,"حَدَّثَنَا وَکِیعٌ ، قَالَ : سَمِعْتُ سُفْیَانَ یَقُولُ : جِنَایَۃُ الْمُدَبَّرِ عَلَی مَوْلاَہُ ، یَضْمَنُ قِیمَتَہُ ۔ قَالَ ابْنُ أَبِی لَیْلَی فِی الْمُدَبَّرِ : عَلَیْہِ جَمِیعُ الْجِنَایَۃِ۔",,,27902,,
27903,"حَدَّثَنَا ہُشَیْمٌ ، عَن یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : جِنَایَۃُ الْمُکَاتَبِ فِی رَقَبَتِہِ ، یَبْدَأُ بِہَا۔",,,27903,,
27904,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ الشَّیْبَانِیِّ ، عَن حَمَّادٍ ، قَالَ : یَسْعَی فِیہَا وَفِی الْمُکَاتَبَۃِ بِالْحِصَصِ۔",,,27904,,
27905,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : جِنَایَۃُ الْمُکَاتَبِ فِی رَقَبَتِہِ۔",,,27905,,
27906,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَن خَالِدٍ، عَنْ أَبِی مَعْشَرٍ، عَنْ إِبْرَاہِیمَ ، قَالَ: جِنَایَۃُ الْمُکَاتَبِ عَلَی سَیِّدِہِ۔",,,27906,,
27907,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ أَصْحَابِہِ ، أَوْ عَنْ إِبْرَاہِیمَ ، قَالَ : مَا جَنَی الْمُکَاتَبُ فَہُوَ فِی رَقَبَتِہِ ، یُؤَدِّی جِنَایَتَہُ وَمُکَاتَبَتَہُ جَمِیعًا۔",,,27907,,
27908,"حَدَّثَنَا وَکِیعٌ ، سَمِعْت سُفْیَانَ یَقُولُ : جِنَایَۃُ الْمُکَاتَبِ فِی رَقَبَتِہِ۔",,,27908,,
27909,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : مَا جُنِیَ عَلَی الْمُکَاتَبِ فَہُوَ لَہُ ، یَسْتَعِینُ بِہِ فِی کِتَابَتِہِ ، کَذَا کَانَ یَقُولُ مَنْ کَانَ قَبْلَکُمْ۔",,,27909,,
27910,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : مَا جُنِیَ عَلَی الْمُکَاتَبِ ، فَہُوَ لَہُ۔",,,27910,,
27911,"حَدَّثَنَا وَکِیعٌ ، قَالَ : سَمِعْتُ سُفْیَانَ ، یَقُولُ : إِذَا جُنِیَ عَلَیْہِ کَانَ لَہُ ، دُونَ مَوْلاَہُ۔",,,27911,,
27912,"حَدَّثَنَا إِبْرَاہِیمُ بْنُ صَدَقَۃَ ، عَنْ سُفْیَانَ بْنِ حُسَیْنٍ ، عَنِ الْحَکَمِ ؛ أَنَّہُ کَانَ یَقُولُ فِی جِنَایَۃِ أُمِّ الْوَلَدِ : لاَ تَعْدُو قِیمَتَہَا ۔ وَقَالَ حَمَّادٌ : دِیَۃُ مَا جَنَتْ۔",,,27912,,
27913,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَن خَالِدٍ، عَنْ أَبِی مَعْشَرٍ، عَنْ إِبْرَاہِیمَ ، قَالَ : جِنَایَۃُ أُمِّ الْوَلَدِ عَلَی سَیِّدِہَا۔",,,27913,,
27914,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ؛ فِی أُمِّ الْوَلَدِ إِذَا جَنَتْ جِنَایَۃً ، فَعَلَی سَیِّدِہَا جِنَایَتُہَا۔,,,27914,,
27915,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَن یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی أُمِّ الْوَلَدِ تَجْنِی ، قَالَ : تُقَوَّمُ عَلَی سَیِّدِہَا۔",,,27915,,
27916,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَن زَکَرِیَّا ، قَالَ : سُئِلَ عَامِرٌ عَن سُرِّیَّۃٍ قَتَلَتِ امْرَأَۃً ، وَمَوْلاَہَا حَیٌّ لَمْ یُعْتِقْہَا ، وَقَدْ وَلَدَتْ لَہُ ؟ قَالَ : ہِیَ أَمَۃٌ ، إِنْ شَائَ مَوْلاَہَا أَدَّی عَنْہَا ، وَإِنْ شَائَ أَسْلَمَہَا بِرُمَّتِہَا۔",,,27916,,
27917,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ حَجَّاجٍ ، عَنْ مَکْحُولٍ ، عَنْ زَیْدٍ ، قَالَ : فِی الْعَقْلِ الدِّیَۃُ۔",,,27917,,
27918,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَن مُجَاہِدٍ ، قَالَ : فِی الْعَقْلِ الدِّیَۃُ۔",,,27918,,
27919,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنِ الأَشْعَثِ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ أَفْزَعَ رَجُلاً فَذَہَبَ عَقْلُہُ ، قَالَ : لَوْ أَدْرَکَہُ عُمَرُ لَضَمَّنَہُ۔",,,27919,,
27920,"حَدَّثَنَا سُلَیْمَانُ بْنُ حَیَّانَ ، عَنْ عَوْفٍ ، قَالَ : سَمِعْتُ شَیْخًا قَبْلَ فِتْنَۃِ ابْنِ الأَشْعَثِ فَنَعَتَ نَعْتَہُ ، قَالُوا ذَلِکَ أَبُو الْمُہَلَّبِ عَمُّ أَبِی قِلاَبَۃَ ، قَالَ : رَمَی رَجُلٌ رَجُلاً فِی رَأْسِہِ بِحَجَرٍ ، فَذَہَبَ سَمْعُہُ وَلِسَانُہُ وَعَقْلُہُ وَذَکَرُہُ ، فَلَمْ یَقْرَبِ النِّسَائَ ، فَقَضَی فِیہِ عُمَرُ بِأَرْبَعِ دِیَاتٍ۔",,,27920,,
27921,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ حَجَّاجٍ ، عَنْ حُصَیْنٍ ، عَنِ الشَّعْبِیِّ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : مَنْ أَخْرَجَ حَجَرًا ، أَوْ مِرْزَابًا ، أَوْ زَادَ فِی سَاحَتِہِ مَا لَیْسَ لَہُ ، فَہُوَ ضَامِنٌ۔",,,27921,,
27922,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : مَنْ بَنَی فِی غَیْرِ سَمَائِہِ ، فَہُوَ ضَامِنٌ۔",,,27922,,
27923,"حَدَّثَنَا جَرِیرٌ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ شُرَیْحٍ ، قَالَ : کَانَ یُضَمِّنُ أَصْحَابَ الْبَلاَلِیعِ الَّتِی یَتَّخِذُونَہَا فِی الطَّرِیقِ ، وبواری الْبِغَالِ ، وَالْخَشَبِ الَّذِی یُجْعَلُ فِی الْحِیطَانِ ، وَکَانَ لاَ یُضَمِّنُ الآبَارَ الْخَارِجَۃَ الَّتِی أَمَامَ الْکُوفَۃِ فِی الْجَبَّانَۃِ ، وَالَّتِی فِی الْمَقَابِرِ ، وَمَا جُعِلَ مَنْفَعَۃً لِلْمُسْلِمِینَ۔",,,27923,,
27924,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ لَیْثٍ ، عَن طَاوُوسٍ ، قَالَ : مَنْ أَوْتَد وَتِدًا فِی غَیْرِ أَرْضِہِ ، وَلاَ سَمَائِہِ ضَمِنَ مَا أَصَابَ ، وَمَنَ احْتَفَرَ بِئْرًا فِی غَیْرِ أَرْضِہِ ، وَلاَ سَمَائِہِ ، فَہُوَ ضَامِنٌ مَا وَقَعَ فِیہَا۔",,,27924,,
27925,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَن مُجَالِدٍ ، عَنِ الشَّعْبِیِّ ، عَنْ شُرَیْحٍ ، قَالَ : مَنْ أَخْرَجَ مِنْ دَارِہِ شَیْئًا إِلَی طَرِیقٍ فَأَصَابَ شَیْئًا ، فَہُوَ لَہُ ضَامِنٌ ؛ مِنْ حَجَرٍ ، أَوْ عُودٍ ، أَوْ حَفَرَ بِئْرًا فِی طَرِیقِ الْمُسْلِمِینَ ، تُؤْخَذُ دِیَتُہُ ، وَلاَ یُقَادُ مِنْہُ۔",,,27925,,
27926,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ، عَنْ ہِشَامٍ، عَنِ الْحَسَنِ، قَالَ: مَنْ أَحْدَثَ شَیْئًا فِی طَرِیقِ الْمُسْلِمِینَ، فَہُوَ ضَامِنٌ۔",,,27926,,
27927,"حَدَّثَنَا أَبُو خَالِدٍ، عَنْ عَمْرٍو، عَنِ الْحَسَنِ، رَفَعَہُ، قَالَ: مَنْ أَخْرَجَ مِنْ حَدِّہِ شَیْئًا فَأَصَابَ شَیْئًا، فَہُوَ ضَامِنٌ۔ (بزار 3664)",,,27927,,
27928,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَن مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا أَخْرَجَ الرَّجُلُ الصَّلاَیَۃَ أَوِ الْخَشَبَۃَ فِی حَائِطِہِ ضَمِنَ۔",,,27928,,
27929,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مِسْعَرٌ ، عَن وَاصِلٍ الأَحْدَبِ الأَسَدِیِّ ، عَنِ الشَّعْبِیِّ ، عَنْ عَلِیٍّ ؛ أَنَّہُ کَانَ یَقْطَعُ الْکُنُفَ ، أَوْ یَأْمُرُ بِقَطْعِہَا۔",,,27929,,
27930,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ شُرَیْحٍ ؛ أَنَّہُ کَانَ یُضَمِّنُ باریَّ السُّوقِیِّ وَعَمُودَہُ ، وَیَقُولُ : أَخْرَجَہُ فِی غَیْرِ مِلْکِہِ۔",,,27930,,
27931,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّ عَمْرَو بْنَ الْحَارِثِ بْنِ الْمُصْطَلِقِ حَفَرَ بِئْرًا فِی طَرِیقِ الْمُسْلِمِینَ ، فَوَقَعَ فِیہَا بَغْلٌ فَانْکَسَرَ ، فَضَمَّنَہُ شُرَیْحٌ۔",,,27931,,
27932,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عِیسَی بْنُ دِینَارٍ ، عَنْ أَبِیہِ ، أَنَّ عَمْرَو بْنَ الْحَارِثِ حَفَرَ بِئْرًا فِی طَرِیقِ الْمُسْلِمِینَ ، فَمَرَّ بَغْلٌ ، فَوَقَعَ فِیہَا ، فَانْکَسَرَ ؛ فَضَمَّنَہُ شُرَیْحٌ قِیمَۃَ الْبَغْلِ ، مِئَتَیْ دِرْہَمٍ ، وَأَعْطَاہُ الْبَغْلَ۔",,,27932,,
27933,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شَرِیکٌ ، عَنِ الْحَسَنِ أَبِی مُسَافِرٍ ؛ أَنَّ کَنِیفًا لِجَارٍ لَہُ وَقَعَ عَلَی صَبِیٍّ فَقَتَلَہُ، أَوْ جَرَحَہُ ، فَقَالَ شُرَیْحٌ : لَوْ أُتِیتُ بِہِ لَضَمَّنْتہ۔",,,27933,,
27934,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ إِسْمَاعِیلَ ، عَنِ الْحَارِثِ ، عَنْ شُرَیْحٍ ؛ أَنَّہُ کَانَ لاَ یَدَعُ ظُلَّۃً لاَ یَمُرُّ فِیہَا الْفَارِسُ بِرُمْحِہِ ، وَیَقُولُ : بَنَیْتُمْ عَلَی رُمْحِ الْفَارِسِ۔",,,27934,,
27935,"حَدَّثَنَا أَبُو أُسَامَۃَ، عَنِ ابْنِ عَوْنٍ، عَنِ ابْنِ سِیرِینَ، قَالَ: کَانُوا یُغَرِّمُونَ مِنَ الْوَطْئِ، وَلاَ یَغْرَمُونَ مِنَ النَّفْحَۃِ۔",,,27935,,
27936,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا سُفْیَانُ، عَن مَنْصُورٍ، عَنْ إِبْرَاہِیمَ، قَالَ: لاَ یُضْمَنُ صَاحِبُ الدَّابَّۃِ مِنَ النَّفْحَۃِ۔",,,27936,,
27937,حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ ، عَنْ شُرَیْحٍ ؛ أَنَّہُ بَرَّأَ مِنَ النَّفْحَۃِ۔,,,27937,,
27938,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی قَیْسٍ ، عَن ہُزَیْلٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الرِّجْلُ جُبَارٌ ، یَعْنِی ہَدَرًا۔ (عبدالرزاق 18376۔ دارقطنی 213)",,,27938,,
27939,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، قَالَ : صَاحِبُ الدَّابَّۃِ ضَامِنٌ لِمَا أَصَابَتِ الدَّابَّۃُ بِیَدِہَا ، أَوْ بِرِجْلِہَا ، حَتَّی یَنْزِلَ عَنہَا۔",,,27939,,
27940,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ ، وَحَمَّادًا عَنْ رَجُلٍ وَاقِفٍ عَلَی دَابَّتِہِ ، فَضَرَبَتْ بِرِجْلِہَا ؟ قَالَ حَمَّادٌ : لاَ یَضْمَنُ ، وَقَالَ الْحَکَمُ : یَضْمَنُ۔",,,27940,,
27941,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَاصِمٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : مَا کَانُوا یُضَمِّنُونَ مِنَ الرِّجْلِ إِلاَّ مَا رَدَّ الْعِنَانَ۔",,,27941,,
27942,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنِ الْحَارِثِ ، قَالَ : إِذَا ضَرَبَتِ الدَّابَّۃُ أَوْ کَبَحْتہَا ، فَأَنْتَ ضَامِنٌ۔",,,27942,,
27943,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ أَبِی سَلَمَۃَ ، وَسَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ أَبِی ہُرَیْرَۃَ ، یَبْلُغُ بِہِ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : الْعَجْمَائُ جَرْحُہَا جُبَارٌ ، وَالْبِئْرُ جُبَارٌ ، وَالْمَعْدِنُ جُبَارٌ ، وَفِی الرِّکَازِ الْخُمُسُ۔ (بخاری 1499۔ مسلم 6912)",,,27943,,
27944,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ مُحَمَّدِ بْنِ زِیَادٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، مِثْلَہُ ، إِلاَّ أَنَّہُ لَمْ یَذْکُرْ جَرْحَہَا۔ (بخاری 6913۔ مسلم 1335)",,,27944,,
27945,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا ابْنُ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : الْبَہِیمَۃُ عَقْلُہَا جُبَارٌ ، وَالْمَعْدِنُ عَقْلُہُ جُبَارٌ ، وَالْبِئْرُ عَقْلُہَا جُبَارٌ ، وَفِی الرِّکَازِ الْخُمُسُ۔ (احمد 228۔ طحاوی 204)",,,27945,,
27946,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مُغِیرَۃُ بْنُ أَبِی الْحُرِّ ؛ أَنَّ بَعِیرًا افْتَرَسَ رَجُلاً فَقَتَلَہُ ، فَجَائَ رَجُلٌ فَقَتَلَ الْبَعِیرَ ، فَأَبْطَلَ شُرَیْحٌ دِیَۃَ الرَّجُلِ ، وَضَمَّنَ الرَّجُلَ ثَمَنَ الْبَعِیرِ۔",,,27946,,
27947,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّ بَعِیرًا افْتَرَسَ رَجُلاً فَقَتَلَہُ ، فَجَائَ رَجُلٌ فَقَتَلَ الْبَعِیرَ ، فَأَبْطَلَ شُرَیْحٌ دِیَۃَ الرَّجُلِ ، وَضَمَّنَ الرَّجُلَ قِیمَۃَ الْبَعِیرِ۔",,,27947,,
27948,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : یَغْرَمُ قَاتِلُ الْبَہِیمَۃِ ، وَلاَ یَغْرَمُ أَہْلُہَا مَا قَتَلَتْ۔",,,27948,,
27949,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَن زَمْعَۃَ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ ، قَالَ : اقْتُلُوا الْفَحْلَ إِذَا عَدَا عَلَیْکُمْ ، وَلاَ غُرْمَ عَلَیْکُمْ۔",,,27949,,
27950,"حَدَّثَنَا مُحَمَّدُ بْنُ میسَّرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَبْدِ الْکَرِیمِ ؛ أَنَّ فَحْلاً عَدَا عَلَی رَجُلٍ فَقَتَلَہُ ، فَرُفِعَ إِلَی أَبِی بَکْرٍ فَأَغْرَمَہُ ، وَقَالَ : بَہِیمَۃٌ لاَ تُعْقَلُ۔",,,27950,,
27951,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الأَسْوَدِ بْنِ قَیْسٍ ، عَنِ الْحَیِّ ؛ أَنَّ غُلاَمًا مِنْ قَوْمِہِ دَخَلَ عَلَی نَجِیبَۃٍ لِزَیْدِ بْنِ صُوحَانَ فِی دَارِہِ ، فَخَبَطَتْہُ فَقَتَلَتْہُ ، فَجَائَ أَبُوہُ بِالسَّیْفِ فَعَقَرَہَا ، فَرُفِعَ ذَلِکَ إِلَی عُمَرَ ، فَأَہْدَرَ دَمَ الْغُلاَمِ ، وَضَمَّنَ أَبَاہُ ثَمَنَ النَّجِیبَۃِ۔,,,27951,,
27952,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یَلْقَی الْبَہِیمَۃَ فَیَخَافُہَا عَلَی نَفْسِہِ ، قَالَ : یَقْتُلُہَا ، وَثَمَنُہَا عَلَیْہِ۔",,,27952,,
27953,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، وَیَعْلَی بْنُ عُبَیْدٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ فِی رَجُلٍ عَدَا عَلَیْہِ فَحْلٌ فَضَرَبَہُ بِالسَّیْفِ ، أَیُضَمَّنُ ؟ قَالَ : نَعَمْ ، إِلاَّ أَنَّ ابْنَ نُمَیْرٍ قَالَ : یُضَمَّنُ۔",,,27953,,
27954,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، وَحَمَّادٍ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّہُ سُئِلَ عَنِ الْمُہْرِ یَتْبَعُ أُمَّہُ ؟ قَالَ : ہُوَ ضَامِنٌ ، لأَنَّہُ أَرْسَلَہُ۔",,,27954,,
27955,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، عَنْ إِبْرَاہِیمَ ؛ فِی الْمُہْرِ یَتْبَعُ أُمَّہُ ، قَالَ : یَضْمَنُ۔",,,27955,,
27956,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، وَحَمَّادٍ ؛ سَأَلْتہمَا عَنِ الْمُہْرِ یَتْبَعُ أُمَّہُ فَیُصِیبُ ؟ قَالاَ : یَضْمَنُ۔",,,27956,,
27957,"حَدَّثَنَا الْبَکْرَاوِیُّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : لاَ یَضْمَنُ۔",,,27957,,
27958,"حَدَّثَنَا حَفْصٌ ، عَنِ الْحَجَّاجِ ، عَنِ الْقَاسِمِ بْنِ نَافِعٍ ، قَالَ : قَالَ عُمَرُ : مَا أَصَابَ الْمُنْفَلِتُ فَلاَ ضَمَانَ عَلَی صَاحِبِہِ ، وَمَنْ أَصَابَ الْمُنْفَلِتَ ضَمِنَ۔",,,27958,,
27959,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ، وَابْنِ سِیرِینَ ؛ فِی الدَّابَّۃِ الْمُرْسَلَۃِ تُصِیبُ ؟ قَالاَ : لَیْسَ عَلَیْہِ ضَمَانٌ۔",,,27959,,
27960,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، قَالَ : کُلُّ مُرْسَلَۃٍ فَصَاحِبُہَا ضَامِنٌ۔",,,27960,,
27961,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَن حَمَّادٍ ؛ فِی رَجُلٍ انْفَلَتَتْ دَابَّتُہُ وَہُوَ فِی أَثَرِہَا ، فَأَصَابَتْ إِنْسَانًا ، قَالَ : لَیْسَ عَلَیْہِ شَیْئٌ ، وَقَالَ الْحَکَمُ مِثْلَ ذَلِکَ۔",,,27961,,
27962,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ، عَنْ أَبِی الْمُہَلِّبِ ، عَنْ عُمَرَ ، قَالَ : فِی عَیْنِ الدَّابَّۃِ رُبُعُ ثَمَنِہَا۔",,,27962,,
27963,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، قَالَ : فِی عَیْنِ الدَّابَّۃِ رُبُعُ ثَمَنِہَا۔",,,27963,,
27964,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ قَالَ : قضَی عُمَرُ فِی عَیْنِ الدَّابَّۃِ رُبُعَ ثَمَنِہَا۔",,,27964,,
27965,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ، قَالَ : کَتَبَ ہِشَامُ بْنُ ہُبَیْرَۃَ قَاضِی الْبَصْرَۃِ إِلَی شُرَیْحٍ یَسْأَلُہُ عَنْ عَیْنِ الدَّابَّۃِ ؟ فَکَتَبَ إِلَیْہِ : إِنَّ فِی عَیْنِ الدَّابَّۃِ رُبُعَ ثَمَنِہَا۔",,,27965,,
27966,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إِسْمَاعِیلُ بْنُ أَبِی خَالِدٍ ، عَنْ رَجُلٍ یُقَالُ لَہُ : حَبِیبٌ ، عَنْ شُرَیْحٍ ؛ أَنَّہُ قَالَ : فِی عَیْنِ الدَّابَّۃِ رُبُعُ ثَمَنِہَا۔",,,27966,,
27967,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَن حَمَّادٍ ، أَوْ عَن یَزِیدَ بْنِ الْوَلِیدِ ، عَن حَمَّادٍ ؛ فِی الرَّجُلِ یَفْقَأُ عَیْنَ الدَّابَّۃِ الْعَوْرَائِ ، قَالَ : یُؤَدِّی قِیمَتَہَا عَوْرَائَ ، وَیَأْخُذُ الدَّابَّۃَ۔",,,27967,,
27968,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، عَنْ شُرَیْحٍ ؛ قَالَ : أَتَانِی عُرْوَۃُ الْبَارِقِیُّ مِنْ عَندِ عُمَرَ : أَنَّ فِی عَیْنِ الدَّابَّۃِ رُبُعَ ثَمَنِہَا۔",,,27968,,
27969,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنْ مُحَمَّدٍ ، عَنْ شُرَیْحٍ ، قَالَ: فِی ذَنَبِ الدَّابَّۃِ إِذَا اسْتُؤْصِلَ رُبُعُ ثَمَنِہَا۔",,,27969,,
27970,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ؛ أَنَّہُ سُئِلَ عَنِ الدَّابَّۃِ یُقْطَعُ ذَنَبُہَا ، أَوْ أُذُنُہَا ؟ قَالَ : مَا نَقَصَہَا، فَإِذَا قُطِعَتْ یَدُہَا ، أَوْ رِجْلُہَا فَالْقِیمَۃُ۔",,,27970,,
27971,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا سَعِیدٌ ، عَنْ قَتَادَۃَ ؛ فِی رَجُلٍ قَطَعَ ذَنَبَ دَابَّۃٍ ، قَالَ : عَلَیْہِ ، ثَمَنُہَا ، وَتُدْفَعُ إِلَیْہِ الدَّابَّۃُ۔",,,27971,,
27972,"حَدَّثَنَا حَفْصٌ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، قَالَ: قَالَ عَلِیٌّ: مَنِ اسْتَعْمَلَ مَمْلُوکَ قَوْمٍ صَغِیرًا ، أَوْ کَبِیرًا، فَہُوَ ضَامِنٌ۔",,,27972,,
27973,"حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، عَنْ عَلِیٍّ ، قَالَ : مَنِ اسْتَعَانَ صَغِیرًا حُرًّا ، أَوْ عَبْدًا فَعَنِتَ ، فَہُوَ ضَامِنٌ ، وَمَنِ اسْتَعَانَ کَبِیرًا لَمْ یَضْمَنْ۔",,,27973,,
27974,"حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، وَحَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا اسْتَعَنْتَ مَمْلُوکَ قَوْمٍ ، فَأَنْتَ ضَامِنٌ لِمَا أَصَابَہُ۔",,,27974,,
27975,"( حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یَأْمُرُ الصَّبِیَّ بِالشَّیْئِ یَعْمَلُہُ بِغَیْرِ إِذْنِ أَہْلِہِ ، فَیَہْلِکُ الصَّبِیُّ ، قَالَ : عَلَیْہِ الضَّمَانُ ، فَإِنْ کَانَ اسْتَأْمَرَ أَہْلَہُ فَلاَ ضَمَانَ عَلَیْہِ ، وَفِی الْعَبْدِ مِثْلُ ذَلِکَ۔",,,27975,,
27976,"حَدَّثَنَا ہُشَیمٌ ، عَنْ إِسْمَاعِیلَ بْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : سَمِعْتُہ یَقُولُ : إِذَا حَمَلَ الرَّجُلُ عَلَی دَابَّتِہِ غُلاَمًا لَمْ یَحْتَلِمْ ، فَأَصَابَ شَیْئًا ، فَہُوَ عَلَی الَّذِی حَمَلَہُ ، وَإِنْ کَانَ قَدْ بَلَغَ فَأَصَابَ شَیْئًا ، فَہُوَ ضَامِنٌ ، وَفِی الْعَبْدِ مِثْلُ ذَلِکَ۔",,,27976,,
27977,"حَدَّثَنَا أَبُو عَاصِمٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : إِنِ اسْتَأْجَرَہُ بِغَیْرِ إِذْنِہِمْ فَمَاتَ غَرِمَ۔",,,27977,,
27978,"حَدَّثَنَا عَبْدُ اللہِ بْنُ الْمُبَارَکِ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : قَالَ الْمُغِیرَۃُ بْنُ شُعْبَۃَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْمَرْأَۃُ تَعْقِلُ عَنہَا عَصَبَتُہَا ، وَیَرِثُہَا بَنُوہَا۔",,,27978,,
27979,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ إِسْمَاعِیلَ بْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ، سَمِعْتہ یَقُولُ : وَلَدُ الْمَرْأَۃِ الذَّکَرُ أَحَقُّ بِمِیرَاثِ مَوَالِیہَا مِنْ عَصَبَتِہَا ، وَإِنْ کَانَتْ جِنَایَۃُ عَقَلَ عَصَبَتُہَا۔",,,27979,,
27980,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَن حَسَنِ بْنِ صَالِحٍ ، عَنْ فِرَاسٍ ، عَنِ الشَّعْبِیِّ ، عَنْ شُرَیْحٍ ؛ فِی امْرَأَۃٍ أَعْتَقَتْ رَجُلاً ، ثُمَّ مَاتَتْ ، قَالَ : الْوَلاَئُ لِوَلَدِہَا وَالْعَقْلُ عَلَیْہِمْ۔ قَالَ : وَکَانَ عَامِرٌ یَقُولُ : الْوَلاَئُ لِوَلَدِہَا، وَالْعَقْلُ عَلَیْہِمْ۔",,,27980,,
27981,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ الْبُرْسَانِیُّ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : یَعْقِلُ عَنِ الْمَرْأَۃِ عَصَبَتُہَا ، وَإِنْ کَانَ لَہَا وَلَدٌ ذُکُورٌ۔",,,27981,,
27982,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : مَا کَانَ مِنْ جُرْحٍ مِنَ الْعَمْدِ لاَ یُسْتَطَاعُ فِیہِ الْقِصَاصُ ، فَہُوَ عَلَی الْجَارِحِ فِی مَالِہِ دُونَ عَاقِلَتِہِ۔",,,27982,,
27983,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ عَنِ الْعَمْدِ الَّذِی لاَ یُسْتَطَاعُ أَنْ یُسْتَقَادَ مِنْہُ ؟ فَقَالَ : عَلَی الْعَاقِلَۃِ ، وَسَأَلْتُ حَمَّادًا ؟ فَقَالَ : فِی مَالِہِ۔",,,27983,,
27984,"حَدَّثَنَا مُحَمَّدُ بْنُ یَزِیدَ، عَنْ أَیُّوبَ أَبِی الْعَلاَئِ، عَنْ قَتَادَۃَ، قَالَ: کُلُّ شَیْئٍ لاَ یُقَادُ مِنْہُ، فَہُوَ عَلَی الْعَاقِلَۃِ۔",,,27984,,
27985,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی ہِشَامٌ ، عَنْ أَبِیہِ ، قَالَ : کُلُّ عَمْدٍ لَیْسَ فِیہِ قَوَدٌ فَعَقْلُہُ فِی مَالِ الْمُصِیبِ ، وَإِنْ لَمْ یَکُنْ لَہُ مَالٌ فَعَلَی عَاقِلَۃِ الْمُصِیبِ ، إِنْ قَطَعَ یَمِینًا عَمْدًا ، وَکَانَتْ یَمِینُ الْقَاطِعِ قَدْ قُطِعَتْ قَبْلَ ذَلِکَ ، فَعَقْلُہَا فِی مَالِ الْقَاطِعِ ، فَإِنْ لَمْ یَکُنْ لَہُ مَالٌ فَعَلَی عَاقِلَتِہِ ، فَإِنْ کَانَتْ لَہُ یَدٌ یُسْرَی لَمْ یُقَدْ مِنْہَا ، وَالْعَقْلُ کَذَلِکَ ، وَالأَعْضَائِ کُلِّہَا کَذَلِکَ۔",,,27985,,
27986,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : مَا کَانَ مِنْ قَتْلٍ بِغَیْرِ سِلاَحٍ فَہُوَ شِبْہُ الْعَمْدِ ، وَفِیہِ الدِّیَۃُ عَلَی الْعَاقِلَۃِ۔",,,27986,,
27987,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ حَمَّادًا عَن قَتْلِ الْخَطَأِ شِبْہِ الْعَمْدِ ؟ فَقَالَ : فِی مَالِ الْقَاتِلِ ، وَقَالَ الْحَکَمُ : ہُوَ عَلَی الْعَاقِلَۃِ۔",,,27987,,
27988,"حَدَّثَنَا عَبْدُ الْوَہَّابِ بْنُ عَطَائٍ ، عَنْ إِسْمَاعِیلَ ، عَنِ الْحَارِثِ ، وَابْنِ شُبْرُمَۃَ ، قَالاَ : ہُوَ عَلَیْہِ فِی مَالِہِ۔",,,27988,,
27989,حَدَّثَنَا عَبْدُ الْوَہَّابِ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، مِثْلَہُ۔,,,27989,,
27990,"حَدَّثَنَا حَفْصٌ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ، وَالْحَکَمِ ، وَحَمَّادًا ، قَالُوا : مَا أُصِیبَ بِہِ مِنْ سَوْطٍ ، أَوْ حَجَرٍ ، أَوْ عَصًا فَأَتَی عَلَی النَّفْسِ فَہُوَ شِبْہُ الْعَمْدِ ، وَفِیہِ الدِّیَۃُ مُغَلَّظَۃً عَلَی الْعَاقِلَۃِ۔",,,27990,,
27991,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: قَتِیلُ السَّوْطِ وَالْعَصَی شِبْہُ الْعَمْدِ ، فِیہَا مِئَۃٌ مِنَ الإِبِلِ ، أَرْبَعُونَ مِنْہَا فِی بُطُونِہَا أَوْلاَدُہَا۔",,,27991,,
27992,"حَدَّثَنَا شَرِیکٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لاَ یَعْقِلُ الْعَبْدُ ، وَلاَ یُعْقَلُ عَنْہُ۔",,,27992,,
27993,"حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : قُلْتُ لَہُ : الرَّجُلُ یَقْتُلُ الْعَبْدَ ، مَنْ یَعْقِلُہُ؟ یَعْقِلُہُ ہُوَ ، أَمْ قَوْمُہُ ؟ قَالَ : قَوْمُہُ۔",,,27993,,
27994,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَن حَمَّادٍ ، وَالْحَکَمِ ؛ أَنَّہُمَا قَالاَ فِی رَجُلٍ قَتَلَ دَابَّۃً خَطَأً ، قَالاَ : فِی مَالِہِ ، وَإِنْ قَتَلَ عَبْدًا فَہُوَ عَلَی الْعَاقِلَۃِ۔",,,27994,,
27995,"حَدَّثَنَا عُمَرُ ، عَن یُونُسَ ، عَنِ الزُّہْرِیِّ ؛ فِی حُرٍّ قَتَلَ عَبْدًا خَطَأً ، قَالَ : قیمَتُہُ عَلَی الْعَاقِلَۃِ۔",,,27995,,
27996,"حَدَّثَنَا وَکِیعٌ ، وَیَزِیدُ بْنُ ہَارُونَ ، عَن زَیْدِ بْنِ إِبْرَاہِیمَ ، عَنِ الْحَسَنِ ، قَالَ : إِذَا قَتَلَ الْحُرُّ الْعَبْدَ خَطَأً ، یُعْتِقُ رَقَبَۃً وَعَلَیْہِ الدِّیَۃُ۔",,,27996,,
27997,"حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ ، عَنْ مُحَمَّدِ بْنِ رَاشِدٍ ، عَنْ مَکْحُولٍ ، قَالَ : لَیْسَ عَلَی أَہْلِ الْقَبِیلَۃِ مِنْ دِیَۃِ الْعَبْدِ شَیْئٌ۔",,,27997,,
27998,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ مُطَرِّفٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : لاَ تَعْقِلُ الْعَاقِلَۃُ صُلْحًا ، وَلاَ عَمْدًا ، وَلاَ عَبْدًا ، وَلاَ اعْتِرَافًا۔",,,27998,,
27999,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ عُبَیْدَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لاَ تَعْقِلُ الْعَاقِلَۃُ صُلْحًا ، وَلاَ عَمْدًا ، وَلاَ اعْتِرَافًا ، وَلاَ عَبْدًا۔",,,27999,,
28000,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، وَالشَّعْبِیِّ ، قَالاَ : الْخَطَأُ عَلَی الْعَاقِلَۃِ ، وَالْعَمْدُ وَالصُّلْحُ عَلَی الَّذِی أَصَابَہُ فِی مَالِہِ۔",,,28000,,
28001,"حَدَّثَنَا عَبْدَۃُ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یَقُولُ : لاَ تَعْقِلُ الْعَاقِلَۃُ فِی الْعَمْدِ إِلاَّ أَنْ تَشَائَ ، وَإِنَّمَا تَعْقِلُ الْعَشِیرَۃُ الْخَطَأَ۔",,,28001,,
28002,"حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : اصْطَلَحَ الْمُسْلِمُونَ عَلَی أَنْ لاَ تَعْقِلَ الْعَاقِلَۃُ صُلْحًا ، وَلاَ عَمْدًا ، وَلاَ اعْتِرَافًا۔",,,28002,,
28003,"حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَن مَالِکِ بْنِ أَنَسٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : مَضَتِ السُّنَّۃُ أَنَّ الْعَاقِلَۃَ لاَ تَعْقِلُ دِیَۃَ عَمْدٍ ، إِلاَّ عَن طِیبِ نَفْسٍ۔",,,28003,,
28004,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنِ الْقَاسِمِ بْنِ نَافِعٍ ، عَنْ عَلِیِّ بْنِ مَاجِدَۃَ ، قَالَ : قاتَلْتُ غُلاَمًا فَجَدَعْتُ أَنْفَہُ ، فَأُتِیَ بِی أَبُو بَکْرٍ فَقَاسَنِی ، فَلَمْ یَجِدْ فِی قِصَاصًا ، فَجَعَلَ عَلَی عَاقِلَتِی الدِّیَۃَ۔",,,28004,,
28005,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُ قَالَ : فِی الصَّبِیِّ وَالْمَجْنُونِ خَطَؤُہُمَا وَعَمْدُہُمَا سَوَائٌ عَلَی عَاقِلَتِہِمَا۔",,,28005,,
28006,"حَدَّثَنَا عَبَّادٌ ، عن عُبَیْدَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : عَمْدُ الصَّبِیِّ وَخَطَؤُہُ عَلَی الْعَاقِلَۃِ۔",,,28006,,
28007,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، وَالْحَکَمِ ، وَحَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : عَمْدُ الصَّبِیِّ وَخَطَؤُہُ سَوَائٌ۔",,,28007,,
28008,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ (ح) وَعَنِ الْحَکَمِ ، عَنْ إِبْرَاہِیمَ ، قَالاَ : أَوَّلُ مَنْ فَرَضَ الْعَطَائَ عُمَرُ بْنُ الْخَطَّابِ ، وَفَرَضَ فِیہِ الدِّیَۃَ کَامِلَۃً فِی ثَلاَثِ سِنِینَ ، ثُلُثَا الدِّیَۃِ فِی سَنَتَیْنِ ، وَالنِّصْفَ فِی سَنَتَیْنِ ، وَالثُّلُث فِی سَنَۃٍ ، وَمَا دُونَ ذَلِکَ فِی عَامِہ۔",,,28008,,
28009,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : الدِّیَۃُ فِی ثَلاَثِ سِنِینَ ، أَوَّلُہَا فِی السَّنَۃِ الَّتِی یُصَابُ فِیہَا ، وَالثُّلُثَان فِی السَّنَتَیْنِ ، وَالثُّلُث فِی سَنَۃٍ۔",,,28009,,
28010,"حَدَّثَنَا مُحَمَّدُ بْنُ یزید ، عَنْ أَیُّوبَ أَبِی الْعَلاَئِ ، عَنْ قَتَادَۃَ ، وَأَبِی ہَاشِمٍ ، قَالاَ : الدِّیَۃُ فِی ثَلاَثِ سِنِینَ : ثُلُثَاہَا وَنِصْفُہَا فِی سَنَتَیْنِ ، وَالثُّلُثُ فِی سَنَۃٍ۔",,,28010,,
28011,"حَدَّثَنَا وَکِیعٌ ، عَن حُرَیْثٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : الدِّیَۃُ فِی ثَلاَثِ سِنِینَ ، فِی کُلٍّ ثُلُثٌ۔",,,28011,,
28012,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ عُبَیدَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لاَ یَجُوزُ اعْتِرَافُ الصَّبِیِّ ، فَإِنْ قَامَتْ عَلَیْہِ الْبَیِّنَۃُ بِقَتْلٍ فَہُوَ عَلَی الْعَاقِلَۃِ۔",,,28012,,
28013,حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ سُفْیَانَ ، عَن عِیسَی بْنِ أَبِی عَزَّۃَ ، عَنِ الشَّعْبِیِّ ؛ أَنَّہُ کَانَ لاَ یُجِیزُ إِقْرَارَ الصَّبِیِّ وَالْعَبْدِ فِی الْجِرَاحَاتِ۔,,,28013,,
28014,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ أَبَانَ بْنِ صَالِحٍ ، عَن مُجَاہِدٍ ، عَنِ ابْنِ مَسْعُودٍ ، قَالَ : کَانَ یَقُولُ : دِیَۃُ أَہْلِ الْکِتَابِ مِثْلُ دِیَۃِ الْمُسْلِمِ۔",,,28014,,
28015,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَلِیِّ بْنِ أَبِی طَلْحَۃَ ، عَنِ الْقَاسِمِ بْنِ عَبْدِ الرَّحْمَنِ ، قَالَ : قَالَ عَبْدُ اللہِ : مَنْ کَانَ لَہُ عَہْدٌ ، أَوْ ذِمَّۃٌ فَدِیَتُہُ دِیَۃُ الْحُرِّ الْمُسْلِمِ۔\n\nقَالَ سُفْیَانُ : ثُمَّ قَالَ عَلِیٌّ بَعْدُ ذَلِکَ : لاَ أَعْلَمُ إِلاَّ ذَلِکَ۔",,,28015,,
28016,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا الْحَسَنُ بْنُ صَالِحٍ ، عَنْ عَلِیِّ بْنِ أَبِی طَلْحَۃَ ، عَنِ الْقَاسِمِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ عَبْدِ اللہِ ، قَالَ : مَنْ کَانَ لَہُ عَہْدٌ ، أَوْ ذِمَّۃٌ فَدِیَتُہُ دِیَۃُ الْحُرِّ الْمُسْلِمِ۔",,,28016,,
28017,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ أَبِی الْعُمَیْسِ ، عَن حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، قَالَ : دِیَۃُ الْمُعَاہَدِ مِثْلُ دِیَۃِ الْمُسْلِمِ۔",,,28017,,
28018,"حَدَّثَنَا إِسْمَاعِیلُ بْنُ إِبْرَاہِیمَ، عَنِ ابْنِ أَبِی نَجِیحٍ، عَن مُجَاہِدٍ، وَعَطَائٍ، قَالاَ: دِیَۃُ الْمُعَاہَدِ مِثْلُ دِیَۃِ الْمُسْلِمِ۔",,,28018,,
28019,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ (ح) وَعَنِ الْحَکَمِ ، وَحَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالاَ : دِیَۃُ الْیَہُودِیِّ وَالنَّصْرَانِیِّ وَالْمَجُوسِیِّ وَالْمُعَاہَدِ مِثْلُ دِیَۃِ الْمُسْلِمِ ، وَنِسَاؤُہُمْ عَلَی النِّصْفِ مِنْ دِیَۃِ الرِّجَالِ ، وَکَانَ عَامِرٌ یَتْلُو ہَذِہِ الآیَۃَ : {وَإِنْ کَانَ مِنْ قَوْمٍ بَیْنَکُمْ وَبَیْنَہُمْ مِیثَاقٌ فَدِیَۃٌ مُسَلَّمَۃٌ إِلَی أَہْلِہِ}۔",,,28019,,
28020,"حَدَّثَنَا إِسْمَاعِیلُ بْنُ إِبْرَاہِیمَ ، عَن أَیُّوبَ ، عَنِ الزُّہْرِیِّ ، قَالَ: سَمِعْتُہ یَقُولُ: دِیَۃُ الْمُعَاہَدِ دِیَۃُ الْمُسْلِمِ، وَتَلاَ ہَذِہِ الآیَۃَ : {وَإِنْ کَانَ مِنْ قَوْمٍ بَیْنَکُمْ وَبَیْنَہُمْ مِیثَاقٌ}۔",,,28020,,
28021,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَن مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : دِیَۃُ أَہْلِ الْعَہْدِ مِنَ الْمُشْرِکِینَ مِثْلُ دِیَۃِ الْمُسْلِمِینَ۔",,,28021,,
28022,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : دِیَۃُ الْکَافِرِ نِصْفُ دِیَۃِ الْمُؤْمِنِ۔ (ابوداؤد 4573۔ ترمذی 1413)",,,28022,,
28023,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَبْدِ اللہِ بْنِ ذَکْوَانَ أَبِی الزِّنَادِ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : دِیَۃُ الْمُعَاہَدِ عَلَی النِّصْفِ مِنْ دِیَۃِ الْمُسْلِمِ۔",,,28023,,
28024,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، قَالَ : قرَأْتُ کِتَابَ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ : أَنَّ دِیَۃَ الْیَہُودِیِّ وَالنَّصْرَانِیِّ عَلَی الثُّلُثِ مِنْ دِیَۃِ الْمُسْلِمِ۔",,,28024,,
28025,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی الْمِقْدَامِ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ عُمَرَ بْنِ الْخَطَّابِ، قَالَ : دِیَۃُ الْیَہُودِیِّ وَالنَّصْرَانِیِّ أَرْبَعَۃُ آلاَفٍ ، وَدِیَۃُ الْمَجُوسِیِّ ثَمَانُ مِئَۃٍ۔",,,28025,,
28026,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عُثْمَانَ بْنِ غِیَاثٍ ، عَن عِکْرِمَۃَ ، وَالْحَسَنِ ، قَالاَ : دِیَۃُ الْیَہُودِیِّ وَالنَّصْرَانِیِّ أَرْبَعَۃُ آلاَفٍ ، وَدِیَۃُ الْمَجُوسِیِّ ثَمَانُ مِئَۃٍ۔",,,28026,,
28027,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَن سُلَیْمَانَ بْنِ یَسَارٍ ، قَالَ : کَانَ النَّاسُ یَقْضُونَ فِی الزَّمَانِ الأَوَّلِ فِی دِیَۃِ الْمَجُوسِیِّ بِثَمَانِ مِئَۃٍ ، وَیَقْضُونَ فِی دِیَۃِ الْیَہُودِیِّ وَالنَّصْرَانِیِّ بِالَّذِی کَانُوا یَتَعَاقَلُونَ بِہِ فِیمَا بَیْنَہُمْ ، ثُمَّ رَجَعَتِ الدِّیَۃُ إِلَی سِتَّۃِ آلاَفِ دِرْہَمٍ۔",,,28027,,
28028,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : دِیَۃُ الْیَہُودِیِّ وَالنَّصْرَانِیِّ أَرْبَعَۃُ آلاَفٍ ، وَدِیَۃُ الْمَجُوسِیِّ ثَمَانُ مِئَۃٍ۔",,,28028,,
28029,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ أَشْعَثَ ، عَن نَافِعٍ ، وَعَمْرِو بْنِ دِینَارٍ ؛ أَنَّہُمَا کَانَا یَقُولاَنِ : دِیَۃُ الْیَہُودِیِّ وَالنَّصْرَانِیِّ أَرْبَعَۃُ آلاَفٍ۔",,,28029,,
28030,حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ صَدَقَۃ بْنِ یَسَارٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّ عُثْمَانَ قَضَی فِی دِیَۃِ الْیَہُودِیِّ وَالنَّصْرَانِیِّ أَرْبَعَۃَ آلاَفٍ۔,,,28030,,
28031,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ حَجَّاجٍ ، عَن رَبِیعَۃَ بْنِ أَبِی عَبْدِ الرَّحْمَنِ ، عن عبد الرحمن بْنِ الْبَیْلَمَانِیِّ ، قَالَ : قتَلَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجُلاً مِنْ أَہْلِ الْقِبْلَۃِ قَتَلَ رَجُلاً مِنْ أَہْلِ الذِّمَّۃِ ، وَقَالَ : أَنَا أَحَقُّ مَنْ وَفَّی بِذِمَّتِہِ۔ (دارقطنی 135)",,,28031,,
28032,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ لَیْثٍ ، عَنِ الْحَکَمِ ، عَنْ عَلِیٍّ ، وَعَبْدِ اللہِ ؛ أَنَّہُمَا قَالاَ : إِذَا قَتَلَ یَہُودِیًّا ، أَوْ نَصْرَانِیًّا قُتِلَ بِہِ۔",,,28032,,
28033,"حَدَّثَنَا مُعْتَمِرٌ ، عَن حُمَیْدٍ ، عَنْ مَیْمُونِ بْنِ مِہْرَانَ ؛ أّنَّہُ أَخْبَرَہُ ، قَالَ : مَرَّ رَجُلٌ مِنَ الْمُسْلِمِینَ بِرَجُلٍ مِنَ الْیَہُودِ، فَأَعْجَبَتْہُ امْرَأَتُہُ فَقَتَلَہُ وَغَلَبَہُ عَلَیْہَا، فَکَتَبَ إِلَی عُمَرَ بْنِ عَبْدِالْعَزِیزِ، فَکَتَبَ عُمَرُ: أَنِ ادْفَعُوہُ إِلَی وَلِیِّہِ، قَالَ: فَدَفَعْناہُ إِلَی أُمِّہِ ، فَشَدَخَتْ رَأْسَہُ بِصَخْرَۃٍ ، أَوْ بِصَلاَیَۃٍ، لاَ أَدْرِی قَامَتْ عَلَیْہِ بَیِّنَۃٌ، أَوِ اعْتَرَفَ۔",,,28033,,
28034,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ عَبْدِ الْمَلِکِ بْنِ مَیْسَرَۃَ ، عَنِ النَّزَّالِ بْنِ سَبْرَۃَ ، قَالَ : قتَلَ رَجُلٌ مِنْ فُرْسَانِ أَہْلِ الْکُوفَۃِ عِبَادِیًا مِنْ أَہْلِ الْحِیرَۃِ ، فَکَتَبَ عُمَرُ : أَنْ أَقِیدوا أَخَاہُ مِنْہُ ، فَدَفَعُوا الرَّجُلَ إِلَی أَخِی الْعِبادِیِّ فَقَتَلَہُ ، ثُمَّ جَائَ کِتَابُ عُمَرَ : أَنْ لاَ تَقْتُلُوہُ وَقَدْ قَتَلَہُ۔",,,28034,,
28035,"حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : یُقْتُلُ الْمُسْلِمُ بِالْمُعَاہَدِ۔",,,28035,,
28036,"حَدَّثَنَا سُفْیَانُ ، عَن مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ؛ فِی الْمُسْلِمِ یَقتَلَ الذِّمِّیَّ عَمْدًا ، قَالَ : یُقْتَلُ بِہِ۔",,,28036,,
28037,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا أَبُو الأَشْہَبِ ، عَنْ أَبِی نَضِرَۃَ ، قَالَ : حُدِّثْنَا أَنَّ عُمَرَ بْنَ الْخَطَّابِ أَقَادَ رَجُلاً مِنَ الْمُسْلِمِینَ بِرَجُلٍ مِنْ أَہْلِ الذِّمَّۃِ۔",,,28037,,
28038,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَن حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، عَنْ عُمَرَ بْنِ الْخَطَّابِ ؛ أَنَّہُ أَقَادَ رَجُلاً مِنَ الْمُسْلِمِینَ بِرَجُلٍ مِنْ أَہْلِ الْحِیرَۃِ۔",,,28038,,
28039,"حَدَّثَنَا حَفْصٌ ، عَنِ الْمُسَاوِرِ ، قَالَ : سَمِعْتُہُ یَقُولُ : مَنِ اعْتَرَضَ ذِمَّۃَ مُحَمَّدٍ بِقَتْلِہِمْ ، فَاقْتُلُوہُ۔",,,28039,,
28040,حَدَّثَنَا مَعْن ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الْحَارِثِ بْنِ عَبْدِ الرَّحْمَنِ ؛ أَنَّ رَجُلاً مِنَ النَّبَطِ عَدَا عَلَیْہِ رَجُلٌ مِنْ أَہْلِ الْمَدِینَۃِ فَقَتَلَہُ قَتْلَ غِیلَۃٍ ، فَأُتِیَ بِہِ أَبَانُ بْنَ عُثْمَانَ ، وَہُوَ إِذْ ذَاکَ عَلَی الْمَدِینَۃِ ، فَأَمَرَ بِالْمُسْلِمِ الَّذِی قَتَلَ الذِّمِّیَّ أَنْ یُقْتَلَ۔,,,28040,,
28041,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ قَیْسٍ الأَسَدِیُّ ، عَنْ عَبْدِ الْمَلِکِ بْنِ مَیْسَرَۃَ ، عَنِ النَّزَّالِ بْنِ سَبْرَۃَ ؛ أَنَّ رَجُلاً مِنَ الْمُسْلِمِینَ قَتَلَ رَجُلاً مِنْ أَہْلِ الْحِیرَۃِ ، فَکَتَبَ فِیہِ إِلَی عُمَرَ بْنِ الْخَطَّابِ ، فَکَتَبَ عُمَرُ : أَنِ اقْتُلُوہُ بِہِ ، فَقِیلَ لأَخِیہِ حُنَیْنٍ : اقْتُلْہُ ، قَالَ : حَتَّی یَجِیئَ الْغَضَبُ ، قَالَ : فَبَلَغَ عُمَرَ أَنَّہُ مِنْ فُرْسَانِ الْمُسْلِمِینَ ، قَالَ : فَکَتَبَ عُمَرُ : أَنْ لاَ تُقِیدُوہُ بِہِ ، قَالَ : فَجَائَہُ الْکِتَابُ وَقَدْ قُتِلَ۔ (طحاوی 196)",,,28041,,
28042,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ مُطَرِّفٍ ، عَنِ الشَّعْبِیِّ ، عَنْ أَبِی جُحَیْفَۃَ ، قَالَ : قُلْنَا لِعَلِیٍّ : ہَلْ عِنْدَکُمْ مِنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ شَیْئٌ سِوَی الْقُرْآنِ ؟ فَقَالَ : لاَ ، وَالَّذِی فَلَقَ الْحَبَّۃَ وَبَرَأَ النَّسَمَۃَ ، إِلاَّ أَنْ یُعْطِیَ اللَّہُ رَجُلاً فَہْمًا فِی کِتَابِ اللہِ ، وَمَا فِی ہَذِہِ الصَّحِیفَۃِ ؟ قَالَ : قُلْتُ : وَمَا فِی ہَذِہِ الصَّحِیفَۃِ ؟ قَالَ : الْعَقْلُ ، وَفِکَاکُ الأَسِیرِ ، وَلاَ یُقْتَلُ مُسْلِمٌ بِکَافِرٍ۔ (بخاری 111۔ ترمذی 1412)",,,28042,,
28043,"حَدَّثَنَا ابْنُ أَبِی زَائِدَۃ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لاَ یُقْتَلُ مُؤْمِنٌ بِکَافِرٍ۔ (ابوداؤد 2745۔ ترمذی 1413)",,,28043,,
28044,"حَدَّثَنَا وَکِیعٌ ، عَن مَعْقِلٍ ، عَنْ عَطَائٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یُقْتَلُ مُسْلِمٌ بِکَافِرٍ ، وَلاَ ذُو عَہْدٍ فِی عَہْدِہِ۔ (ابوداؤد 4519۔ نسائی 6936)",,,28044,,
28045,حَدَّثَنَا ابْنُ مُسْہِرٍ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ أَبِی الْمَلِیحِ ؛ أَنَّ رَجُلاً مِنْ قَوْمِہِ رَمَی رَجُلاً یَہُودِیًّا بِسَہْمٍ فَقَتَلَہُ ، فَرُفِعَ إِلَی عُمَرَ بْنِ الْخَطَّابِ ، فَأَغْرَمہُ أَرْبَعَۃَ آلاَفٍ ، وَلَمْ یُقِدْ مِنْہُ۔,,,28045,,
28046,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : سُئِلَ عَمَّنْ یَقْتُلُ یَہُودِیًّا ، أَوْ نَصْرَانِیًّا ؟ قَالَ : لاَ یُقْتَلُ مُسْلِمٌ بِکَافِرٍ ، وَإِنْ قَتَلَہُ عَمْدًا۔",,,28046,,
28047,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : لاَ یُقْتَلُ الرَّجُلُ الْمُسْلِمُ بِالْیَہُودِیِّ ، وَلاَ بِالنَّصْرَانِیِّ ، وَلَکِنْ یُغْرَمُ الدِّیَۃَ۔",,,28047,,
28048,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : قَالَ عَلِیٌّ : مِنَ السُّنَّۃِ أَنْ لاَ یُقْتَلَ مُؤْمِنٌ بِکَافِرٍ، وَلاَ حُرٌّ بِعَبْدٍ۔",,,28048,,
28049,"حدَّثَنَا أَبُو عَبْدِ الرَّحْمَنِ بَقِیُّ بْنُ مَخْلَدٍ ، حدَّثَنَا أَبُو بَکْرٍ عَبْدُ اللہِ بْنُ مُحَمَّدِ بْنِ أَبِی شَیْبَۃَ الْعَبْسِیُّ ، قَالَ :\n\n حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسٍ ؛ أَنَّ یَہُودِیًّا رَضَخَ رَأْسَ امْرَأَۃٍ بِحَجَرٍ فَقَتَلَہَا ، فَرَضَخَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَأْسَہُ بَیْنَ حَجَرَیْنِ۔ (بخاری 6885۔ احمد 170)",,,28049,,
28050,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ہِشَامٌ الدَّسْتَوَائِیُّ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛أَنَّ عُمَرَ قَتَلَ ثَلاَثَۃَ نَفَرٍ مِنْ أَہْلِ صَنْعَائَ بِامْرَأَۃٍ۔ (عبدالرزاق 18073)",,,28050,,
28051,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ (ح) وَعَنْ جَابِرٍ ، عَنِ الشَّعْبِیِّ ، قَالاَ : یُقْتَلُ الرَّجُلُ بِالْمَرْأَۃِ إِذَا قَتَلَہَا عَمْدًا۔",,,28051,,
28052,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ لَیْثٍ ، عَنِ الْحَکَمِ ، عَنْ عَلِیٍّ ، وَعَبْدِ اللہِ ، قَالاَ : إِذَا قَتَلَ الرَّجُلُ الْمَرْأَۃَ مُتَعَمِّدًا ، فَہُوَ بِہَا قَوَدٌ۔",,,28052,,
28053,"حَدَّثَنَا عُمَرُ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : یُقْتَلُ وَلَیْسَ بَیْنَہُمَا فَصْلٌ۔",,,28053,,
28054,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَن سِمَاکٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : رُفِعَ إِلَی علِیٍّ رَجُلٌ قَتَلَ امْرَأَۃً ، فَقَالَ عَلِیٌّ لأَوْلِیَائِہَا : إِنْ شِئْتُمْ فَأَدُّوا نِصْفَ الدِّیَۃِ وَاقْتُلُوہُ۔",,,28054,,
28055,"حَدَّثَنَا غُنْدَرٌ، عَنْ عَوْفٍ، عَنِ الْحَسَنِ، قَالَ: لاَ یُقْتَلُ الذَّکَرُ بِالأُنْثَی حَتَّی یُؤَدِّی نِصْفَ الدِّیَۃِ إِلَی أَہْلِہِ۔",,,28055,,
28056,"حَدَّثَنَا یَعْلَی ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ فِی الرَّجُلِ یَقْتُلُ الْمَرْأَۃَ ، قَالَ : إِنْ قَتَلُوہُ أَدَّوْا نِصْفَ الدِّیَۃَ ، وَإِنْ شَاؤُوا قَبِلُوا الدِّیَۃَ۔",,,28056,,
28057,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : الْقِصَاصُ فِیْمَا بَیْنَ الرَّجُلِ وَالْمَرْأَۃِ فِی الْعَمْدِ ، فِیمَا بَیْنَہُ وَبَیْنَ النَّفْسِ۔",,,28057,,
28058,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ (ح) وَعَنْ جَابِرٍ ، عَنِ الشَّعْبِیِّ ، قَالاَ : الْقِصَاصُ فِیمَا بَیْنَ الرَّجُلِ وَالْمَرْأَۃِ فِی الْعَمْدِ ، فِی کُلِّ شَیْئٍ۔",,,28058,,
28059,"حَدَّثَنَا حَفْصٌ، عَنِ الشَّیْبَانِیِّ، عَن حَمَّادٍ؛ أَنَّہُ کَانَ لاَ یَرَی بَیْنَ الرِّجَالِ وَالنِّسَائِ قِصَاصًا فِیمَا دُونَ النَّفْسِ۔\n\nوَقَالَ الْحَکَمُ : مَا سَمِعْنَا فِیہِمَا بِشَیْئٍ ، وَإِنَّ الْقِصَاصَ بَیْنَہُمَا لَحَسَنٌ۔",,,28059,,
28060,"حَدَّثَنَا عِیسَی ، عَنِ الأَوْزَاعِیِّ ، عَنِ الزُّہْرِیِّ ، قَالَ : مَضَتِ السُّنَّۃُ فِی الرَّجُلِ یَضْرِبُ امْرَأَتَہُ فَیَجْرَحُہَا أَنْ لاَ تَقْتَصَّ مِنْہُ ، وَیَعْقِلَ لَہَا۔",,,28060,,
28061,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا سُفْیَانُ، عَنْ إِسْمَاعِیلَ بْنِ أُمَیَّۃَ، عَنِ الزُّہْرِیِّ، قَالَ: لاَ یُقَصُّ لِلْمَرْأَۃِ مِنْ زَوْجِہَا۔",,,28061,,
28062,"حَدَّثَنَا وکیع ، قَالَ : حَدَّثَنَا سُفْیَانُ ، عَن عِیسَی بْنِ أَبِی عَزَّۃَ ، عَنِ الشَّعْبِیِّ ؛ فِی رَجُلٍ أَبْرَکَ امْرَأَتَہُ أَنْ یُجَامِعَہَا فَدَقَّ سِنَّہَا ، قَالَ : یَضْمَنُ۔",,,28062,,
28063,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَن حَمَّادٍ ، قَالَ : لَیْسَ بَیْنَ الرَّجُلِ وَالْمَرْأَۃِ قِصَاصٌ فِیمَا دُونَ النَّفْسِ فِی الْعَمْدِ۔",,,28063,,
28064,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا جَرِیرُ بْنُ حَازِمٍ، عَنِ الْحَسَنِ؛ فِی رَجُلٍ لَطَمَ امْرَأَتَہُ، فَأَتَتْ تَطْلُبُ الْقِصَاصَ، فَجَعَلَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَیْنَہُمَا الْقِصَاصَ ، فَأَنْزَلَ اللَّہُ تَعَالَی : {وَلاَ تَعْجَلْ بِالْقُرْآنِ مِنْ قَبْلِ أَنْ یُقْضَی إِلَیْک وَحْیُہُ} وَنَزَلَتْ : {الرِّجَالُ قَوَّامُونَ عَلَی النِّسَائِ بِمَا فَضَّلَ اللَّہُ بَعْضَہُمْ عَلَی بَعْضٍ}۔",,,28064,,
28065,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الْقَاسِمُ بْنُ الْفَضْلِ الْحُدَّانِیُّ ، عَنْ مُحَمَّدِ بْنِ زِیَادٍ ، قَالَ : کَانَتْ جَدَّتِی أُمَّ وَلَدٍ لِعُثْمَانَ بْنِ مَظْعُونٍ ، فَلَمَّا مَاتَ عُثْمَانُ جَرَحَہَا ابْنُ عُثْمَانَ جُرْحًا ، فَذَکَرَتْ ذَلِکَ لِعُمَرَ بْنِ الْخَطَّابِ ، فَقَالَ لَہُ عُمَر : أَعْطِہَا أَرْشًا مِمَّا صَنَعْتَ بِہَا۔",,,28065,,
28066,"حَدَّثَنَا جَرِیرٌ ، عَن مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَبْدِ اللہِ ، قَالَ : تَسْتَوِی جِرَاحَاتُ الرِّجَالِ وَالنِّسَائِ فِی السِّنِّ وَالْمُوضِحَۃِ۔",,,28066,,
28067,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، عَنْ شُرَیْحٍ ، قَالَ : أَتَانِی عُرْوَۃُ الْبَارِقِیُّ مِنْ عِندِ عُمَرَ ؛ أَنَّ جِرَاحَاتِ الرِّجَالِ وَالنِّسَائِ تَسْتَوِی فِی السِّنِّ وَالْمُوضِحَۃِ ، وَمَا فَوْقَ ذَلِکَ فَدِیَۃُ الْمَرْأَۃِ عَلَی النِّصْفِ مِنْ دِیَۃِ الرَّجُلِ۔",,,28067,,
28068,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ، عَنْ شُرَیْحٍ ؛ أَنَّ ہِشَامَ بْنَ ہُبَیْرَۃَ کَتَبَ إِلَیْہِ یَسْأَلُہُ، فَکَتَبَ إِلَیْہِ : إِنَّ دِیَۃَ الْمَرْأَۃِ عَلَی النِّصْفِ مِنْ دِیَۃِ الرَّجُلِ ، إِلا فِی السِّنِّ وَالْمُوضِحَۃِ۔",,,28068,,
28069,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا زَکَرِیَا ، وَابْنُ أَبِی لَیْلَی ، عَنِ الشَّعْبِیِّ ، قَالَ : کَانَ عَلِیٌّ یَقُولُ : دِیَۃُ الْمَرْأَۃِ فِی الْخَطَأِ عَلَی النِّصْفِ مِنْ دِیَۃِ الرَّجُلِ ، فِیمَا دَقَّ وَجَلَّ۔\n\nوَکَانَ ابْنُ مَسْعُودٍ یَقُولُ : دِیَۃُ الْمَرْأَۃِ فِی الْخَطَأِ عَلَی النِّصْفِ مِنْ دِیَۃِ الرَّجُلِ ، إِلاَّ السِّنَّ وَالْمُوضِحَۃَ فَہُمَا فِیہِ سَوَائٌ۔\n\nوَکَانَ زَیْدُ بْنُ ثَابِتٍ یَقُولُ : دِیَۃُ الْمَرْأَۃِ فِی الْخَطَأِ مِثْلُ دِیَۃِ الرَّجُلِ ، حَتَّی تَبْلُغَ ثُلُثَ الدِّیَۃِ ، فَمَا زَادَ فَہِیَ عَلَی النِّصْفِ۔",,,28069,,
28070,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَن خَالِدٍ ، عَنْ أَبِی قِلاَبَۃَ ، عَن زَیْدِ بْنِ ثَابِتٍ ، أَنَّہُ قَالَ : یَسْتَوُونَ إِلَی الثُّلُثِ۔",,,28070,,
28071,"حَدَّثَنَا مُعْتَمِرٌ ، عَنِ ابْنِ عَوْنٍ ، عَنِ الْحَسَنِ ، قَالَ : تَسْتَوِی جِرَاحَاتُ الرِّجَالِ وَالنِّسَائِ عَلَی النِّصْفِ ، فَإِذَا بَلَغَتِ النِّصْفَ فَہِیَ عَلَی النِّصْفِ۔",,,28071,,
28072,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : تُعَاقِلُ الْمَرْأَۃُ الرَّجُلَ إِلَی الثُّلُثِ ، إِصْبَعُہَا کَإِصْبَعِہِ ، وَسِنُّہَا کَسِنِّہِ ، وَمُوضِحَتُہَا کَمُوضِحَتِہِ ، وَمُنَقِّلَتُہَا کَمُنَقِّلَتِہِ۔",,,28072,,
28073,"حَدَّثَنَا حَفْصٌ ، عَنِ الشَّیْبَانِیِّ ، وَإِسْمَاعِیلُ ، عَنِ الشَّعْبِیِّ ، عَنْ عَلِیٍّ ، قَالَ : تَسْتَوِی جِرَاحَاتُ النِّسَائِ وَالرِّجَالِ فِی کُلِّ شَیْئٍ۔",,,28073,,
28074,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَبْدِ اللہِ بْنِ ذَکْوَانَ أَبِی الزِّنَادِ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : فِی مُوضِحَۃِ الْمَرْأَۃِ ، وَمُنَقِّلَتِہَا ، وَسِنِّہَا مِثْلُ الرَّجُلِ فِی الدِّیَۃِ۔",,,28074,,
28075,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ رَجُلٍ ، عَنْ عُرْوَۃَ بْنِ الزُّبَیْرِ ، قَالَ : مُنَقِّلَتُہَا ، وَمُوَضِحَتُہَا ، وَسِنُّہَا مِثْلُ الرَّجُلِ فِی الدِّیَۃِ۔",,,28075,,
28076,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَن رَبِیعَۃَ بْنِ أَبِی عَبْدِ الرَّحْمَنِ ، قَالَ : قُلْتُ لِسَعِیدِ بْنِ الْمُسَیَّبِ: کَمْ فِی ہَذِہِ مِنَ الْمَرْأَۃِ ؟ یَعْنِی الْخِنْصَرِ ، فَقَالَ : عَشْرٌ مِنَ الإِبِلِ ، قَالَ : قُلْتُ : فِی ہَذَیْنِ ؟ یَعْنِی الْخِنْصَرَ وَالَّتِی تَلِیہَا ، قَالَ : عِشْرُونَ ، قَالَ : قُلْتُ : فَہَؤُلاَئِ ؟ یَعْنِی الثَّلاَثَۃَ ، قَالَ : ثَلاَثُونَ ، قَالَ : قُلْتُ : فَفِی ہَؤُلاَئِ ؟ وَأَوْمَأَ إِلَی الأَرْبَعِ ، قَالَ : عِشْرُونَ ، قَالَ : قُلْتُ : حِینَ آلَمَتْ جِرَاحُہَا وَعَظُمَتْ مُصِیبَتُہَا کَانَ الأَقَلَّ لأَِرْشِہَا ؟ قَالَ : أَعِرَاقِیٌّ أَنْتَ ؟ قَالَ : قُلْتُ : عَالِمٌ مُتَثَبِّتٌ ، أَوْ جَاہِلٌ مُتَعَلِّمٌ ، قَالَ : یَا ابْنَ أَخِی ، السُّنَّۃُ۔\n\n(مالک860۔ عبدالرزاق 17749)",,,28076,,
28077,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الْمَسْعُودِیُّ ، عَنِ الْحَکَمِ بْنِ عُتَیْبَۃَ ، قَالَ : کَتَبَ شُرَیْحٌ إِلَی ہِشَامِ بْنِ ہُبَیْرَۃَ: أَنَّ دِیَۃَ الْمَرْأَۃِ عَلَی النِّصْفِ مِنْ دِیَۃِ الرَّجُلِ ، إِلاَّ السِّنَّ وَالْمُوضِحَۃَ۔",,,28077,,
28078,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ (ح) وَعَنْ مَکْحُولٍ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ؛ أَنَّہُمَا قَالاَ : یُعَاقِلُ الرَّجُلُ الْمَرْأَۃَ فِی ثُلُثِ دِیَتِہَا ، ثُمَّ یَخْتَلِفَانِ۔",,,28078,,
28079,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، حَدَّثَنَا ابن أَبِی عَرُوبَۃ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، عَن سَمُرَۃَ بْنِ جُنْدُبٍ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : مَنْ قَتَلَ عَبْدَہُ قَتَلْنَاہُ ، وَمَنْ جَدَعَ عَبْدَہُ جَدَعْناہُ۔\n\n(ابوداؤد 4504۔ ترمذی 1414)",,,28079,,
28080,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی ہَاشِمٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إِذَا قَتَلَ عَبْدَہُ عَمْدًا قُتِلَ بِہِ۔",,,28080,,
28081,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : یُقْتَلُ بِہِ۔",,,28081,,
28082,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ عَنِ الرَّجُلِ یَقْتُلُ عَبْدَہُ عَمْدًا ؟ قَالَ : أَرَاہُ یُقْتَلُ بِہِ۔",,,28082,,
28083,"حَدَّثَنَا إِسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ إِسْحَاقَ بْنِ أَبِی فَرْوَۃَ ، عَنْ إِبْرَاہِیمَ بْنِ عَبْدِ اللہِ بْنِ حُنَیْنٍ ، عَنْ أَبِیہِ ، عَنْ عَلِیٍّ ، قَالَ : أُتِیَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِرَجُلٍ قَتَلَ عَبْدَہُ مُتَعَمِّدًا ،فَجَلَدَہُ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِئَۃَ جَلْدَۃٍ ، وَنَفَاہُ سَنَۃً ، وَمَحَا سَہْمَہُ مِنَ الْمُسْلِمِینَ ، وَلَمْ یُقِدْہ مِنْہُ۔\n\n(ابن ماجہ 2664۔ دارقطنی 143)",,,28083,,
28084,حَدَّثَنَا إِسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ إِسْحَاقَ بْنِ أَبِی فَرْوَۃَ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ مِثْلَہُ۔ (بیہقی 37),,,28084,,
28085,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا شُعْبَۃُ ، عَنْ مُغِیرَۃَ ، عَنْ عَامِرٍ ، قَالَ : إِذَا قَتَلَ الرَّجُلُ عَبْدَہُ عَمْدًا لَمْ یُقْتَلْ بِہِ۔",,,28085,,
28086,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنِ ابْنِ لَہِیعَۃَ ، عَن خَالِدِ بْنِ أَبِی عِمْرَانَ ، قَالَ : سَأَلْتُ سَالِمًا ، وَالْقَاسِمَ عَنْ رَجُلٍ قَتَلَ عَبْدَہُ ؟ قَالاَ : عُقُوبَتُہُ أَنْ یُقْتَلَ ، وَلَکِنْ لاَ یُقْتَلُ بِہِ۔",,,28086,,
28087,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ؛ أَنَّ أَبَا بَکْرٍ ، وَعُمَرَ کَانَا یَقُولاَنِ : لاَ یُقْتَلُ الْمَوْلَی بِعَبْدِہِ ، وَلَکِنْ یُضْرَبُ ، وَیُطَالُ حَبْسُہُ ، وَیُحْرَمُ سَہْمُہُ۔",,,28087,,
28088,حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ حَجَّاجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ؛ أَنَّ أَبَا بَکْرٍ ، وَعُمَرَ کَانَا لاَ یَقْتُلاَنِ الْحُرَّ بِقَتلِ الْعَبْد۔,,,28088,,
28089,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ لَیْثٍ ، عَنِ الْحَکَمِ ، عَنْ عَلِیٍّ ، وَعَبْدِ اللہِ ، أَنَّہُمَا قَالاَ : إِذَا قَتَلَ الْحُرُّ الْعَبْدَ ، فَہُوَ بِہِ قَود۔",,,28089,,
28090,"حَدَّثَنَا ہُشَیمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : یُقْتَلُ الْعَبْدُ بِالْحُرِّ ، وَالْحُرُّ بِالْعَبْدِ۔",,,28090,,
28091,"حَدَّثَنَا عَبِیدَۃُ بْنُ حُمَیْدٍ ، عَن سُہَیْلِ بْنِ أَبِی صَالِحٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : سَأَلْتُہُ عَنْ رَجُلٍ حُرٍّ قَتَلَ مَمْلُوکًا ؟ قَالَ : یُقْتَلُ بِہِ ، ثُمَّ رَجَعْتُ إِلَیْہِ ، فَقَالَ : یُقْتَلُ بِہِ ، ثُمَّ قَالَ : وَاللَّہِ لَوِ اجْتَمَعَ عَلَیْہِ أَہْلُ الْیَمَنِ لَقَتَلْتہمْ بِہِ۔",,,28091,,
28092,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَن سُہَیْلِ بْنِ أَبِی صَالِحٍ ، قَالَ : سَأَلْتُ سَعِیدَ بْنَ الْمُسَیَّبِ عَنِ الْحُرِّ یَقْتُلُ الْعَبْدَ عَمْدًا ؟ قَالَ : اقْتُلْہُ ، وَلَوِ اجْتَمَعَ عَلَیْہِ أَہْلُ الْیَمَنِ۔",,,28092,,
28093,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عَلِیُّ بْنُ صَالِحٍ ، عَنْ أَبِی الْوَضِینِ ، قَالَ : سَأَلْتُ الشَّعْبِیَّ عَنِ الْحُرِّ یَقْتُلُ الْعَبْدَ عَمْدًا ؟ قَالَ : اقْتُلْہُ بِہِ صَاغِرًا لَئِیمًا۔",,,28093,,
28094,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : لاَ یُقَادُ الْحُرُّ مِنَ الْعَبْدِ۔",,,28094,,
28095,"حَدَّثَنَا وَکِیعٌ ، قَالَ : سَمِعْتُ سُفْیَانَ ، یَقُولُ : یُقْتَلُ الرَّجُلُ بِعَبْدِ غَیْرِہِ ، وَلاَ یُقْتَلُ بِعَبْدِہِ ، کَمَا لَوْ قَتَلَ ابْنَہُ لَمْ یُقْتَلْ بِہِ۔",,,28095,,
28096,"حَدَّثَنَا وَکِیعٌ ، قَالَ : وَسَمِعْت سُفْیَانَ ، یَقُولُ : لاَ یُقْتَلُ الرَّجُلُ بِعَبْدِہِ ، وَیُعَزَّرُ۔",,,28096,,
28097,"حَدَّثَنَا عَبَّادٌ ، عَنْ حَجَّاجٍ ، عَنْ مَکْحُولٍ ، عَنْ زَیْدٍ ؛ فِی السِّقْطِ یَقَعُ فَیَتَحَرَّکُ ، قَالَ : کَمُلَتْ دِیَتُہُ ؛ اسْتَہَلَّ ، أَوْ لَمْ یَسْتَہِلَّ۔",,,28097,,
28098,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، قَالَ : فِی الْجَنِینِ إِذَا سَقَطَ حَیًّا فَفِیہِ الدِّیَۃُ ، وَإِنْ سَقَطَ مَیِّتًا فَفِیہِ غُرَّۃٌ۔",,,28098,,
28099,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنِ ابْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : إِذَا ضَرَبَ الرَّجُلُ بَطْنَ الْحَامِلِ فَأَسْقَطَتْ مَیِّتًا فَفِیہِ غُرَّۃُ عَبْدٍ ، أَوْ أَمَۃٍ فِی مَالِہِ ، وَإِنْ کَانَ حَیًّا فَالدِّیَۃُ۔",,,28099,,
28100,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، قَالَ: إِذَا اسْتَہَلَّ الْجَنِینُ ، ثُمَّ مَاتَ فَفِیہِ الدِّیَۃُ۔",,,28100,,
28101,"حَدَّثَنَا جَرِیرٌ، عَن مَنْصُورٍ، عَنْ إِبْرَاہِیمَ، قَالَ: وَلَدَتِ امْرَأَۃٌ وَلَدًا، فَشَہِدَ نِسْوَۃٌ أَنَّہُ اخْتَلَجَ وَوُلِدَ حَیًّا، وَلَمْ یَشْہَدْنَ عَلَی الاِسْتِہْلاَلِ، قَالَ شُرَیْحٌ: الْحَیُّ یَرِثُ الْمَیِّتَ ، ثُمَّ أَبْطَلَ مِیرَاثَہُ لأَنَّہُ لَمْ یَشْہَدْنَ عَلَی اسْتِہْلاَلِہِ۔",,,28101,,
28102,حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ حَجَّاجٍ ، عَن جُنْدُبٍ الْقَاص ، عَنْ أَسْلَمَ مَوْلَی عُمَرَ ، عَنْ عُمَرَ ؛ أَنَّہُ قَضَی فِی سِنِّ الصَّبِیِّ إِذَا سَقَطَتْ قَبْلَ أَنْ یُثْغِرَ بَعِیرًا۔,,,28102,,
28103,"حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : لَیْسَ فِی سِنِّ الصَّبِیِّ إِذَا لَمْ یُثْغِرْ إِلاَّ الأَلَمُ۔",,,28103,,
28104,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنِ ابْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : إِذَا أَصَابَ سِنَّہُ وَلَمْ یُثْغِرْ فَفِیہِ حُکْمٌ۔",,,28104,,
28105,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قَالَ ابْنُ شِہَابٍ فِی غُلاَمٍ صَغِیرٍ لَمْ یُثْغِرْ کَسَرَ سِنَّ غُلاَمٍ آخَرَ ، قَالَ : عَلَیْہِ الْغُرْمُ بِقَدْرِ مَا یَرَی الْحَکَمُ۔",,,28105,,
28106,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ، قَالَ : فِی سِنِّ الصَّبِیِّ إِذَا لَمْ یُثْغِرْ ، قَالَ : یَنْظُرُ فِیہِ ذَوَا عَدْلٍ ، فَإِنْ نَبَتَتْ جُعِلَ لَہُ شَیْئٌ ، وَإِنْ لَمْ تَنْبُتْ کَانَ کَسِنِّ الرَّجُلِ۔",,,28106,,
28107,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، قَالَ : مَا أَصَابَ الْمَجْنُونُ فِی حَالِ جُنُونِہِ فَعَلَی عَاقِلَتِہِ ، وَمَا أَصَابَ فِی حَالِ إِفَاقَتِہِ أُقِیدَ مِنْہُ۔",,,28107,,
28108,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُ قَالَ فِی الْمَجْنُونِ وَالْمَغْلُوبِ عَلَی عَقْلِہِ ، وَالْمَعْتُوہِ ، وَالَّذِی یُصِیبُہُ فِی الشَّہْرِ الْمَرَّۃَ وَالْمَرَّتَیْنِ ، قَالَ : إِذَا ذَہَبَ عَنْہُ ذَاکَ ، فَصَامَ وَصَلَّی وَعَقَلَ وَأَصَابَ شَیْئًا ، فَہُوَ عَلَیْہِ۔",,,28108,,
28109,حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ؛ أَنَّہُ جَعَلَ جِنَایَۃَ الْمَجْنُونِ عَلَی الْعَاقِلَۃِ۔,,,28109,,
28110,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا صَخْرُ بْنُ جُوَیْرِیَۃَ ، عَن نَافِعٍ ؛ أَنَّ رَجُلاً مَجْنُونًا فِی عَہْدِ ابْنِ الزُّبَیْرِ کَانَ یُفِیقُ أَحْیَانًا ، فَلاَ یُرَی بِہِ بَأْسًا ، وَیَعُودُ بِہِ وَجَعُہُ ، فَبَیْنَمَا ہُوَ نَائِمٌ مَعَ ابْنِ عَمِّہِ إِذْ دَخَلَ الْبَیْتَ بِخْنْجَرٍ فَطَعَنَ ابْنَ عَمِّہِ فَقَتَلَہُ ، فَقَضَی عَبْدُ اللہِ بْنُ الزُّبَیْرِ أَنْ یُخْلَعَ مِنْ مَالِہِ ، وَیُدْفَعَ إِلَی أَہْلِ الْمَقْتُولِ۔",,,28110,,
28111,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : إِذَا قَتَلَ الْمُسْلِمُ الذِّمِّیَّ فَلَیْسَ عَلَیْہِ کَفَّارَۃٌ۔",,,28111,,
28112,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانُ ، عَنْ قَیْسِ بْنِ مُسْلِمٍ ، عَنِ الشَّعْبِیِّ ؛ فِی الْمُسْلِمِ یَقْتُلُ الذِّمِّیَّ خَطَأً ، قَالَ : کَفَّارَتُہُمَا سَوَائٌ۔",,,28112,,
28113,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَفَّارَتُہُمَا سَوَائٌ۔",,,28113,,
28114,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنْ یَزِیدَ الْجُعفی ، عَنِ الشَّعْبِیِّ ؛ فِی الرَّجُلِ یقْتُلُ فَتَعْفُو الْمَرْأَۃُ ، قَالَ : یُؤَدِّی الْقَاتِلُ سَبْعَۃَ أَثْمَانِ الدِّیَۃِ۔",,,28114,,
28115,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ؛ أَنَّ امْرَأَۃً عَفَتْ عَن دَمِ زَوْجِہَا ، قَالَ : صَارَتْ دِیَۃً ، وَیُرْفَعُ عَنْہُ الثُّمُنَ۔",,,28115,,
28116,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابن صَالِحٍ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ؛ فِی امْرَأَۃٍ قُتِلَ زَوْجُہَا فَعَفَتْ ، قَالَ : عَفْوُہَا جَائِزٌ ، وَیُرْفَعُ نَصِیبُہَا مِنَ الدِّیَۃِ۔",,,28116,,
28117,"حَدَّثَنَا حَفْصٌ ، عَنِ الشَّیْبَانِیِّ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لِکُلِّ ذِی سَہْمٍ عَفْوٌ۔",,,28117,,
28118,"حَدَّثَنَا شَبَابَۃُ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، وَحَمَّادٍ ؛ أَنَّہُمَا قَالاَ فِی الرَّجُلِ یَقْتُلُ الرَّجُلَ فَتَعْفُو الْمَرْأَۃُ ، قَالاَ: مَنْ عَفَا مِنْ رَجُلٍ ، أَوِ امْرَأَۃٍ فَإِنَّہُ یَدْرَأَ عَنْہُ الْقَتْل۔",,,28118,,
28119,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ مُحَمَّدِ بْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ، عَنْ عُمَرَ ، قَالَ : الزَّوْجُ وَالْمَرْأَۃُ لاَ عَفْوَ لَہُمَا۔",,,28119,,
28120,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ إِسْمَاعِیلَ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لَیْسَ لِلزَّوْجِ ، وَلاَ لِلْمَرْأَۃِ عَفْوٌ فِی الدَّمِ ، إِنَّمَا الْعَفْوُ إِلَی أَوْلِیَائِ الْمَقْتُولِ۔",,,28120,,
28121,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ إِسْمَاعِیلَ ، عَنِ الْحَسَنِ ، قَالَ : لَیْسَ لِلزَّوْجِ ، وَلاَ لِلْمَرْأَۃِ عَفْوٌ فِی الدَّمِ ، وَإِنْ عَفَا أَحَدٌ مِنَ الْوَرَثَۃِ جَازَ عَفْوُہُ وَصَارَتِ الدِّیَۃُ۔",,,28121,,
28122,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ، عَن صَاعِدِ بْنِ مُسْلِمٍ، عَنِ الشَّعْبِیِّ؛ فِی رَجُلٍ قُتِلَ وَتَرَکَ ابْنَتَہُ وَأُخْتَہُ وَامْرَأَتَیْہِ، فَعَفَتْ إِحْدَی الْمَرْأَتَیْنِ ، قَالَ الشَّعْبِیُّ : لَیْسَ لِلْمَرْأَۃِ عَفْوٌ ، إِلاَّ امْرَأَۃٌ لَہَا رَحِمٌ مَاسَّۃٌ ، وَسَہْمٌ فِی الْمِیرَاثِ۔",,,28122,,
28123,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدٍ ؛ أَنَّ عُمَرَ کَانَ یَقُولُ : الدِّیَۃُ لِلْعَاقِلَۃِ ، وَلاَ تَرِثُ الْمَرْأَۃُ مِنْ دِیَۃِ زَوْجِہَا شَیْئًا ، حَتَّی کَتَبَ إِلَیْہِ الضَّحَّاکُ بْنُ سُفْیَانَ الْکِلاَبِیُّ : أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَرَّثَ امْرَأَۃَ أَشْیَمَ الضَّبَابِیِّ مِنْ دِیَۃِ زَوْجِہَا۔ (ابوداؤد 2919۔ ترمذی 1415)",,,28123,,
28124,"حَدَّثَنَا یَحْیَی بْنُ زَکَرِیَّا بْنِ أَبِی زَائِدَۃَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : قامَ عُمَرُ بِمِنًی ، فَسَأَلَ النَّاسَ ، فَقَالَ : مَنْ عِندَہُ عِلْمٌ مِنْ مِیرَاثِ الْمَرْأَۃِ مِنْ عَقْلِ زَوْجِہَا ؟ فَقَامَ الضَّحَّاکُ بْنُ سُفْیَانَ الْکِلاَبِیُّ ، فَقَالَ : ادْخُلْ قُبَّتَکَ حَتَّی أُخْبِرَک ، فدخل فَأَتَاہُ ، فَقَالَ : کَتَبَ إِلَیَّ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ أُوَرِّثَ امْرَأَۃَ أَشْیَمَ الضَّبَابِیِّ مِنْ عَقْلِ زَوْجِہَا۔ (نسائی 6365)",,,28124,,
28125,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ؛ فِی الرَّجُلِ یقْتُلُ عَمْدًا فَیَعْفُو بَعْضُ الْوَرَثَۃِ ، قَالَ : لامْرَأَتِہِ مِیرَاثُہَا مِنَ الدِّیَۃِ۔",,,28125,,
28126,"حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : تَرِثُ الْمَرْأَۃُ مِنْ دَمِ زَوْجِہَا۔",,,28126,,
28127,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : إِذَا قَبِلَ الْعَقْلَ فِی الْعَمْدِ ، کَانَ مِیرَاثًا تَرِثُہُ الزَّوْجَۃُ وَغَیْرُہَا۔",,,28127,,
28128,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ مُحَمَّدِ بْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ، عَنْ عُمَرَ ؛ أَنَّہُ قَالَ : یَرِثُ مِنَ الدِّیَۃِ کُلُّ وَارِثٍ ، وَالزَّوْجُ وَالْمَرْأَۃُ فِی الْخَطَأِ وَالْعَمْدِ۔",,,28128,,
28129,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ أَبِی عَمْرٍو الْعَبْدِیِّ ، عَنْ عَلِیٍّ ، قَالَ : تُقْسَمُ الدِّیَۃُ لِمَنْ أَحْرَزَ الْمِیرَاثَ۔",,,28129,,
28130,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الدِّیَۃُ لِلْمِیرَاثِ ، وَالْعَقْلُ عَلَی الْعَصَبَۃِ۔ (عبدالرزاق 17768)",,,28130,,
28131,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ؛ أَنَّہُ کَانَ یَتَحَدَّثُ : أَنَّ الدِّیَۃَ سَبِیلُہَا سَبِیلُ الْمِیرَاثِ۔",,,28131,,
28132,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ (ح) وَجَہْم ، عَنْ إِبْرَاہِیمَ ، قَالاَ : الدِّیَۃُ لِلْمِیرَاثِ۔",,,28132,,
28133,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : عَلَی کِتَابِ اللہِ کَسَائِرِ مَالِہِ۔",,,28133,,
28134,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ طَاوُوسٍ ؛ أَنَّ أَبَاہُ کَانَ یَقُولُ وَیَقْضِی : بِأَنَّ الْوُرَّاثَ أَجْمَعِینَ یَرِثُونَ مِنَ الْعَقْلِ مِثْلَ الْمِیرَاثِ۔",,,28134,,
28135,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : الْعَقْلُ کَہَیْئَۃِ الْمِیرَاثِ ؟ قَالَ : نَعَمْ ، قُلْتُ : وَیَرِثُ الإِخْوَۃُ مِنَ الأُمِّ فِیْہِ ؟ قَالَ : نَعَمْ۔",,,28135,,
28136,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ عَبْدِ اللہِ بْنِ مُحَمَّدِ بْنِ عَلِیٍّ ، قَالَ : قَالَ عَلِیٌّ : قَدْ ظَلَمَ مَنْ لَمْ یُوَرِّثِ الإِخْوَۃَ مِنَ الأُمِّ مِنَ الدِّیَۃِ۔",,,28136,,
28137,حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ عُمَرَ ؛ أَنَّہُ کَانَ یُوَرِّثُ الإِخْوَۃَ مِنَ الأُمِّ مِنَ الدِّیَۃِ۔,,,28137,,
28138,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، وَابْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ، قَالَ : الإِخْوَۃُ مِنَ الأُمِّ یَرِثُونَ مِنَ الدِّیَۃِ، وَکُلُّ وَارِثٍ۔",,,28138,,
28139,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَن حُمَیْدٍ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : کَتَبَ فِی الإِخْوَۃِ مِنَ الأُمِّ : یَرِثُونَ مِنَ الدِّیَۃِ۔",,,28139,,
28140,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : یَرِثُ الإِخْوَۃُ مِنَ الأُمِّ ؟ یَعْنِی مِنَ الْعَقْلِ ، قَالَ : نَعَمْ۔",,,28140,,
28141,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الأَعْمَشِ ، قَالَ : سَأَلْتُ إِبْرَاہِیمَ : أَیَرِثُ الإِخْوَۃُ مِنَ الأُمِّ مِنَ الدِّیَۃِ ؟ قَالَ: نَعَمْ۔",,,28141,,
28142,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَن ہَمَّامٍ ، عَنْ عَاصِمٍ الأَحْوَلِ ، قَالَ : سَأَلْتُ الْحَسَنَ ؟ فَقَالَ : لَہُمْ کِتَابُ اللہِ۔",,,28142,,
28143,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، عَنْ مُحَمَّدِ بْنِ عَلِیٍّ ، قَالَ : لَقَدْ ظَلَمَ مَنْ لَمْ یُوَرِّثِ الإِخْوَۃَ مِنَ الأُمِّ مِنَ الدِّیَۃِ۔",,,28143,,
28144,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَن زَیْدِ بْنِ وَہْبٍ ، قَالَ : رَأَی رَجُلٌ مَعَ امْرَأَتِہِ رَجُلاً فَقَتَلَہَا ، فَرُفِعَ إِلَی عُمَرَ فَوَہَبَ بَعْضُ إِخْوَتِہَا نَصِیبَہُ لَہُ ، فَأَمَرَ عُمَرُ سَائِرَہُمْ أَنْ یَأْخُذُوا الدِّیَۃَ۔",,,28144,,
28145,"حَدَّثَنَا عَبْدَۃُ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إِبْرَاہِیمَ ؛ فِی رَجُلٍ قَتَلَ رَجُلاً مُتَعَمِّدًا ، فَعَفَا بَعْضُ الأَوْلِیَائِ ، فَرُفِعَ ذَلِکَ إِلَی عُمَرَ ، فَقَالَ لِعَبْدِ اللہِ : قُلْ فِیہَا ، فَقَالَ : أَنْتَ أَحَقُّ أَنْ تَقُولَ یَا أَمِیرَ الْمُؤْمِنِینَ ، فَقَالَ عَبْدُ اللہِ : إِذَا عَفَا بَعْضُ الأَوْلِیَائِ فَلاَ قَوَدَ ، یُحَطُّ عَنْہُ حِصَّۃِ الَّذِی عَفَا ، وَلَہُمْ بَقِیَّۃُ الدِّیَۃِ ، فَقَالَ عُمَرُ : ذَاکَ الرَّأْیُ ، وَوَافَقْتَ مَا فِی نَفْسِی۔",,,28145,,
28146,"حَدَّثَنَا وَکِیعٌ ، عَن عِیسَی ، عَنِ الشَّعْبِیِّ ، قَالَ : إِذَا عَفَا بَعْضُ الْوَرَثَۃِ یُتْبَعُ الْعَفْوُ مِنْ ذَلِکَ۔",,,28146,,
28147,"حَدَّثَنَا عَبْدُ الْوَہَّابِ بْنُ عَطَائٍ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ؛ أَنَّہُ قَالَ : مَنْ عَفَا فَلاَ نَصِیبَ لَہُ۔",,,28147,,
28148,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَن زَمْعَۃَ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ ، قَالَ : إِذَا عَفَا بَعْضُ أَوْلِیَائِ الدَّمِ فَہِیَ الدِّیَۃُ۔",,,28148,,
28149,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ أَشْعَثَ ، عَنِ الزُّہْرِیِّ ، قَالَ : صَاحِبُ الْعَفْوِ أَوْلَی بِالدَّمِ۔",,,28149,,
28150,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَن مِقْسَمٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : کَتَبَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کِتَابًا بَیْنَ الْمُہَاجِرِینَ وَالأَنْصَارِ : أَنْ یَعْقِلُوا مَعَاقِلَہُمْ ، وَأَنْ یَفْدُوا عَانِیہمْ بِالْمَعْرُوفِ ، وَالإِصْلاَحِ بَیْنَ الْمُسْلِمِینَ۔ (احمد 271۔ ابویعلی 2479)",,,28150,,
28151,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ أَبِی لَیْلَی ، عَنِ الشَّعْبِیِّ ، قَالَ : جَعَلَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَقْلَ قُرَیْشٍ عَلَی قُرَیْشٍ ، وَعَقْلَ الأَنْصَارِ عَلَی الأَنْصَارِ۔ (ابن حزم 2140)",,,28151,,
28152,حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ جَعَلَ الْعَقْلَ عَلَی الْعَصَبَۃِ۔,,,28152,,
28153,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَن حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : اخْتَصَمَ عَلِیٌّ ، وَالزُّبَیْرُ فِی وَلاَئِ مَوَالِی صَفِیَّۃَ إِلَی عُمَرَ ، فَقَضَی عُمَرُ بِالْمِیرَاثِ لِلزُّبَیْرِ ، وَبِالْعَقْلِ عَلَی عَلِیٍّ۔",,,28153,,
28154,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ، قَالَ: حدَّثَنَی عَبْدُ الْعَزِیزِ بْنُ عُمَرَ، قَالَ: کُتِبَ إِلَی عُمَرَ بْنِ عَبْدِ الْعَزِیزِ فِی رَجُلٍ قَالَ مَوَالِیہِ : لاَ نَعْقِلُ عَنْہُ ، فَکَتَبَ إِلَی الْقَاضِی: أَنْ أَلْزِمْہُمُ الْعَقْلَ ، فَمَا أَشُکُّ أَنَّہُمْ کَانُوا آخذی مِیرَاثِہِ۔",,,28154,,
28155,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ؛ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ کَتَبَ : لَوْ لَمْ یَدَعْ قَرَابَۃً إِلاَّ مَوَالِیہِ ، کَانُوا أَحَقَّ النَّاسِ بِمِیرَاثِہِ ، فَاحْمِلْ عَلَیْہِمْ عَقْلَہُ کَمَا یَرِثُونَہُ۔",,,28155,,
28156,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : الْمِیرَاثُ لِلرَّحِمِ ، وَالْجَرَائِرُ عَلَی مَنْ أَعْتَقَ۔",,,28156,,
28157,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ؛ فِی رَجُلٍ أَعْتَقَہُ قَوْمٌ ، وَأَعْتَقَ أبَاہُ آخَرُونَ ، قَالَ : یَتَوَارَثَانِ بِالأَرْحَامِ ، وَجِنَایَتُہُمَا عَلَی عَاقِلَۃِ مَوَالِیہِمَا۔",,,28157,,
28158,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَن حَمَّادٍ ، قَالَ : جِنَایَۃُ الْمَوْلَی عَلَی عَاقِلَۃِ مَوَالِیہِ۔",,,28158,,
28159,"حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَن خُصَیْفٍ ، عَن مُجَاہِدٍ ؛ أَنَّ رَجُلاً أَتَی عُمَرَ ، فَقَالَ : إِنَّ رَجُلاً أَسْلَمَ عَلَی یَدَیَّ ، فَمَاتَ وَتَرَکَ أَلْفَ دِرْہَمٍ ، فَتَحَرَّجْتُ مِنْہَا وَرَفَعْتہَا إِلَیْک ، فَقَالَ : أَرَأَیْتَ لَوْ جَنَی جِنَایَۃً ، عَلَی مَنْ کَانَتْ تَکُونُ ؟ قَالَ : عَلَیَّ ، قَالَ : فَمِیرَاثُہُ لَکَ۔",,,28159,,
28160,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : الْعَقْلُ عَلَی مَنْ لَہُ الْمِیرَاثُ۔",,,28160,,
28161,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : أَبَی الْقَوْمُ أَنْ یَعْقِلُوا عَن مَوْلاَہُمْ ؟ قَالَ عَطَائٌ : إِنْ أَبَی أَہْلُہُ وَالنَّاسُ أَنْ یَعْقِلُوا عَنْہُ ، فَہُوَ مَوْلَی الْمُصَابِ۔",,,28161,,
28162,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : قَالَ عُمَرُ فِیہِ : إِذَا وَالَی الرَّجُلُ رَجُلاً فَلَہُ مِیرَاثُہُ، وَعَلَی عَاقِلَتِہِ عَقْلُہُ۔",,,28162,,
28163,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ؛ فِی رَجُلٍ تَوَلَّی قَوْمًا ، قَالَ : إِذَا عَقَلَ عَنہُمْ ، فَہُوَ مِنْہُمْ۔",,,28163,,
28164,"حَدَّثَنَا حَفْصٌ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ عُمَرَ ، قَالَ : حدَّثَنِی بَعْضُ الَّذِینَ قَدِمُوا عَلَی أَبِی ، قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَیُّمَا طَبِیبٍ تَطَبَّبَ عَلَی قَوْمٍ ، وَلَمْ یُعْرَفْ بِالطِّبِّ قَبْلَ ذَلِکَ ، فَأَعْنتَ فَہُوَ ضَامِنٌ ، قَالَ عَبْدُ الْعَزِیزِ : أَمَّا إِنَّہُ لَیْسَ بِالنَّعْتِ ، وَلَکِنَّہُ قَطْعُ الْعُرُوقِ وَالْبَطُّ۔ (ابوداؤد 4577۔ مسند 983)",,,28164,,
28165,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : إِذَا جَاوَزَ الطَّبِیبُ مَا أُمِرَ بِہِ ، فَہُوَ ضَامِنٌ۔",,,28165,,
28166,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، وَعُمَرُ بْنُ ہَارُونَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ فِی الطَّبِیبِ یَبُطُّ فَیَمُوتُ ، قَالَ: لَیْسَ عَلَیْہِ عَقْلٌ۔",,,28166,,
28167,حَدَّثَنَا إِسْمَاعِیلُ ، عَنْ ہِشَامٍ بْنِ الْغَازِ الْجُرَشِیِّ ، عَنْ أَبِی قُرَّۃَ ؛ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ ضَمَّنَ الْخَاتِنَ۔,,,28167,,
28168,حَدَّثَنَا إِسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ سَعِیدِ بْنِ یُوسُفَ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ؛ أَنَّ امْرَأَۃً خَفَضَتْ جَارِیَۃً فَأَعَنتْتہَا فَمَاتَتْ ، فَضَمَّنَہَا عَلِیٌّ الدِّیَۃَ۔,,,28168,,
28169,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شَرِیکٌ ، عَن غَیْلاَنَ بْنِ جَامِعٍ الْمُحَارِبِیِّ ، عَنْ أَبِی عَوْنٍ الثَّقَفِیِّ ، عَنْ شُرَیْحٍ ، قَالَ : لَیْسَ عَلَی الْمُدَاوِی ضَمَانٌ۔",,,28169,,
28170,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا یُونُسُ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : لَیْسَ عَلَی مُدَاوٍ ضَمَانٌ۔",,,28170,,
28171,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا یُونُسُ بن أَبِی إِسْحَاقَ ، قَالَ : سَمِعْتُ الشَّعْبِیَّ یَقُولُ : لَیْسَ عَلَی حَجَّامٍ ، وَلاَ بَیْطَارٍ ، وَلاَ مُدَاوٍ ضَمَانٌ۔",,,28171,,
28172,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إِسْرَائِیلُ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ؛ فِی بَیْطَارٍ نَزَعَ ظُفْرَۃً مِنْ عَیْنِ فَرَسٍ فَنَفَقَ الْفَرَسُ ، قَالَ : یَضْمَنُ۔",,,28172,,
28173,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ، عَنْ أَبِی الْمَلِیحِ ؛ أَنَّ خَتَّانَۃً بِالْمَدِینَۃِ خَتَنَتْ جَارِیَۃً فَمَاتَتْ، فَقَالَ لَہَا عُمَرُ : أَلاَ أَبْقَیْتِ کَذَا ، وَجَعَلَ دِیَتَہَا عَلَی عَاقِلَتِہَا۔",,,28173,,
28174,"حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ؛ أَنَّ امْرَأَۃً کَانَتْ تَخْفِضُ جَوَارٍ فَأَعَنتَتْ ، فَضَمَّنَہَا عُمَرُ ، وَقَالَ : أَلاَ أَبْقَیْتِ کَذَا۔",,,28174,,
28175,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ طَاوُوسٍ ، قَالَ : قُلْتُ لأَبِی : الرَّجُلُ یُقْتَلُ فَیَعْفُو عَن دَمِہِ ، قَالَ : جَائِزٌ ، قَالَ : قُلْتُ : خَطَأً ، أَمْ عَمْدًا ؟ قَالَ : نَعَمْ۔",,,28175,,
28176,"حَدَّثَنَا ہُشَیْمٌ ، عَن یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَقُولُ : إِذَا عَفَا الرَّجُلُ عَن قَاتِلِہِ فِی الْعَمْدِ قَبْلَ أَنْ یَمُوتَ ، فَہُوَ جَائِزٌ۔",,,28176,,
28177,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا سَعِیدٌ ، عَنْ قَتَادَۃَ ؛ أَنَّ عُرْوَۃَ بْنَ مَسْعُودٍ الثَّقَفِیَّ دَعَا قَوْمَہُ إِلَی اللہِ وَإِلَی رَسُولِہِ ، فَرَمَاہُ رَجُلٌ مِنْہُمْ بِسَہْمٍ فَمَاتَ فَعَفَا ، فَرُفِعَ ذَلِکَ إِلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَأَجَازَ عَفْوَہُ ، وَقَالَ : ہُوَ کَصَاحِبِ یَاسِینَ۔ (طبرانی 12156)",,,28177,,
28178,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : سَمِعْتُ عَطَائً یَقُولُ : إِنْ وَہَبَ الَّذِی یُقْتَلُ خَطَأً دِیَتَہُ لِمَنْ قَتَلَہُ ، فَإِنَّمَا لَہُ مِنْہَا الثُّلُثُ ، إِنَّمَا ہُوَ مَالٌ یُوصِی بِہِ۔",,,28178,,
28179,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنِ ابْنِ مُبَارَکٍ ، عَنْ مَعْمَرٍ ، عَنْ سِمَاکِ بْنِ الْفَضْلِ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : مِنَ الثُّلُثِ۔",,,28179,,
28180,"حَدَّثَنَا إِسْمَاعِیلُ بْنُ إِبْرَاہِیمَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، قَالَ : حدَّثَنَی عَبْدُ الرَّحْمَنِ بْنُ أَبِی زَیْد ، عَن نَافِعِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : یُزَادُ فِی دِیَۃِ الْمَقْتُولِ فِی أَشْہُرِ الْحُرُمِ أَرْبَعَۃُ آلاَفٍ ، وَالْمَقْتُولُ فِی الْحَرَمِ یُزَادُ فِی دِیَتِہِ أَرْبَعَۃُ آلاَفٍ ، قِیمَۃُ دِیَۃِ الْحرمِیِّ عِشْرِینَ أَلْفًا۔",,,28180,,
28181,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ مَعْمَرٍ ، عَنْ عَمْرِو بْنِ عَبْدِ اللہِ ، عَن عِکْرِمَۃَ ، عن عُمَرَ بْنِ الْخَطَّابِ ؛ قَضَی بِالدِّیَۃِ عَلَی أَہْلِ الْقُرَی اثْنَیْ عَشَرَ أَلْفًا ، وَقَالَ : إِنَّ الزَّمَانَ یَخْتَلِفُ ، وَأَخَافُ عَلَیْکُمُ الْحُکَّامَ بَعْدِی ، فَلَیْسَ عَلَی أَہْلِ الْقُرَی زِیَادَۃٌ فِی تَغْلِیظِ عَقْلٍ ، وَلاَ فِی الشَّہْرِ الْحَرَامِ ، وَلاَ الْحُرْمَۃِ ، وَعَقْلِ أَہْلِ الْقُرَی فِیہِ تَغْلِیظٌ لاَ زِیَادَۃَ فِیہِ۔",,,28181,,
28182,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ أَبِیہِ ؛ أَنَّ عُثْمَانَ قَضَی فِی امْرَأَۃٍ قُتِلَتْ فِی الْحَرَمِ بِدِیَۃٍ وَثُلُثِ دِیَۃٍ۔,,,28182,,
28183,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، وَأَبُو أُسَامَۃَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، وَسُلَیْمَانَ بْنِ یَسَارٍ ، وَعَطَائٍ ، قَالُوا : إِذَا قُتِلَ فِی الْبَلَدِ الْحَرَامِ فَدِیَۃٌ وَثُلُثُ دِیَۃٍ ، وَإِذَا قُتِلَ فِی الشَّہْرِ الْحَرَامِ وَہُوَ مُحْرِمٌ فَدِیَۃٌ مُغَلَّظَۃٌ۔",,,28183,,
28184,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَن قَیْسِ بْنِ سَعْدٍ ، عَنْ عَطَائٍ ، وَسَعِیدِ بْنِ جُبَیْرٍ ، وَمُجَاہِدٍ؛ أَنَّہُمْ قَالُوا: فِی الَّذِی یَقْتُلُ فِی الْحرمِ دِیَۃٌ وَثُلُثُ دِیَۃٍ۔ وَقَالَ أَحَدُہُمْ ، أَحْسِبُہُ قَالَ : سَعِیدَ بْنَ جُبَیْرٍ : وَالَّذِی یَقْتُلُ فِی الْحرمِ دِیَۃٌ وَثُلُثُ دِیَۃٍ۔",,,28184,,
28185,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ؛ أَنَّہُ قَالَ : فِی الرَّجُلِ یُقْتَلُ فِی الْحَرَمِ ، أَوْ فِی أَشْہُرِ الْحُرُمِ ، دِیَۃٌ وَثُلُثُ دِیَۃٍ۔",,,28185,,
28186,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ: دِیَۃُ الَّذِی یَقْتُلُ فِی الْحَرَمِ وَغَیْرِ الْحَرَمِ سَوَائٌ۔",,,28186,,
28187,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إِسْرَائِیلُ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : دِیَتُہُمَا سَوَائٌ۔",,,28187,,
28188,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا سَعِید بن أَبِی مَعْشَرٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا قُتِلَ فِی الْبَلَدِ الْحَرَامِ وَفِی غَیْرِ الْبَلَدِ الْحَرَامِ فَالدِّیَۃُ وَاحِدَۃٌ۔",,,28188,,
28189,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا سَعِیدٌ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، قَالَ : لاَ یُزَادُ عَلَی دِیَۃٍ وَاحِدَۃٍ ، مِثْلَ قَوْلِ إِبْرَاہِیمَ۔",,,28189,,
28190,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ ، قَالَ : تُغَلَّظُ الدِّیَۃُ فِی الشَّہْرِ الْحَرَامِ ، وَالْحُرْمَۃِ ، وَالْمُحْرِمِ ، وَفِی الْجَارِ۔",,,28190,,
28191,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : فِی الْجَارِ وَفِی الشَّہْرِ الْحَرَامِ تَغْلِیظٌ۔",,,28191,,
28192,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی عَمْرُو بْنُ دِینَارٍ ، وَسُلَیْمَانُ الأَحْوَلُ ؛ أَنَّہُمَا سَمِعَا طَاوُوسًا یَقُولُ : فِی الْحَرَمِ ، وَالشَّہْرِ الْحَرَامِ ، وَالْجَارِ تَغْلِیظٌ۔",,,28192,,
28193,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : لاَ یُزَادُ الَّذِی یُقْتَلُ فِی الْحَرَمِ عَلَی دِیَۃِ الَّذِی یُقْتَلُ فِی الْحِلِّ۔",,,28193,,
28194,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ مَعْمَرٍ ، عَنْ سِمَاکِ بْنِ الْفَضْلِ ؛ أَنَّ رَجُلاً خَنَقَ صَبِیًّا عَلَی أَوْضَاحٍ لَہُ ، قَالَ : فَکَتَبَ فِیہِ إِلَی عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، فَکَتَبَ أَنْ یُقْتَلَ۔",,,28194,,
28195,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا سُفْیَانُ ، عَنْ أَبِی ہَاشِمٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا خَنَقَہُ حَتَّی یَقْتُلَہُ قُتِلَ بِہِ۔",,,28195,,
28196,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا إِسْرَائِیلُ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : إِذَا خَنَقَ الرَّجُلُ الرَّجُلَ فَلَمْ یَرْفَعْ عَنْہُ حَتَّی یَقْتُلَہُ فَہُوَ قَودٌ ، وَإِذَا رَفَعَ عَنْہُ ثُمَّ مَاتَ فَدِیَۃٌ مُغَلَّظَۃٌ۔",,,28196,,
28197,حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ؛ أَنَّ رَجُلاً خَنَقَ رَجُلاً فَقَتَلَہُ ، فَجُعِلَتْ عَلَیْہِ الدِّیَۃُ مُغَلَّظَۃً۔,,,28197,,
28198,"حَدَّثَنَا أَبُو قُتَیْبَۃَ ، وَأَبُو دَاوُد الطَّیَالِسِیُّ ، عَنْ شُعْبَۃَ ، عَن حَمَّادٍ ، قَالَ : ہُوَ خَطَأٌ۔",,,28198,,
28199,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنِ الْحَارِثِ ؛ فِی الرَّجُلِ یَضْرِبُ الرَّجُلَ ، قَالَ : إِذَا شَہِدَتِ الشُّہُودُ أَنَّہُ ضَرَبَہُ فَلَمْ یَزَلْ مَرِیضًا مِنْ ضَرْبِہِ حَتَّی مَاتَ أَلْزَمْتُہُ الدِّیَۃَ ، فَإِنْ کَانَ عَامِدًا فَالْقَودُ ، وَإِنْ کَانَ خَطَأً فَالدِّیَۃُ عَلَی الْعَاقِلَۃِ۔",,,28199,,
28200,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یَضْرِبُ الرَّجُلَ ، فَلاَ یَزَالُ مُضْنًی عَلَی فِرَاشِہِ حَتَّی یَمُوتَ ، قَالَ : فِیہِ الْقَودُ۔",,,28200,,
28201,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَن تَمِیمِ بْنِ سَلَمَۃَ ، قَالَ : شَہِدَ رَجُلاَنِ عَندَ شُرَیْحٍ عَلَی رَجُلٍ ، فَقَالاَ : نَشْہَدُ أَنَّ ہَذَا صَرَعَ ہَذَا ، فَلَمْ یَزَلْ یَعْصِرُہُ بِمِرْفَقِہِ حَتَّی مَاتَ ، فَقَالَ شُرَیْحٌ : تَشْہَدَان أَنَّہُ قَتَلَہُ ؟ فَقَالاَ : نَشْہَدُ أَنَّہُ صَرَعَہُ ، فَلَمْ یَزَلْ یَعْصِرُہُ بِمِرْفَقِہِ حَتَّی مَاتَ ، فَقَالَ : تَشْہَدَان أَنَّہُ قَتَلَہُ؟۔\n\n(عبدالرزاق 18300۔ بیہقی 134)",,,28201,,
28202,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی ابْنُ شِہَابٍ ؛ أَنَّ عُمَرَ بْنَ الْخَطَّابِ أَوْطَأَ فِی زَمَانِہِ رَجُلٌ مِنْ جُہَیْنَۃَ رَجُلاً مِنْ بَنِی غِفَارٍ ، أَوْ رَجُلٌ مِنْ بَنِی غِفَارٍ رَجُلاً مِنْ جُہَیْنَۃَ ، فَادَّعَی أَہْلُہُ أَنَّہُ مَاتَ مِنْ ذَلِکَ ۔ فَأَحْلَفَہُمْ عُمَرُ خَمْسِینَ رَجُلاً مِنْہُمْ مِنَ الْمُدَّعِینَ فَأَبَوْا أَنْ یَحْلِفُوا ، وَأَبَی الْمُدَّعَی عَلَیْہِمْ أَنْ یَحْلِفُوا ، فَقَضَی عُمَرُ فِیہَا بِشَطْرِ الدِّیَۃِ۔ (عبدالرزاق 18297۔ مالک 3)",,,28202,,
28203,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی حَسَنُ بْنُ مُسْلِمٍ ؛ أَنَّ أَمَۃً عَضَّتْ إِصْبَعًا لِمَوْلَی لِبَنِی زَیْدٍ ، فَطُمِرَ فِیہَا فَمَاتَ ، فَاعْتَرَفَتِ الْجَارِیَۃُ بِعَضَّتِہَا إِیَّاہُ ، فَقَضَی فِیہَا عُمَرُ بْنُ عَبْدِ الْعَزِیزِ بِأَنْ یُحَلِّفَ بَنُو زَیْدٍ خَمْسِینَ یَمِینًا ، تُرَدَّدُ عَلَیْہِمُ الأَیْمَانُ ، لَمَاتَ مِنْ عَضَّتِہَا ، ثُمَّ الأَمَۃُ لَہُمْ ، وَإِلاَّ فَلاَ حَقَّ لَہُمْ ، فَأَبَوْا أَنْ یَحْلِفُوا۔",,,28203,,
28204,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی عَوْنٍ ، عَنْ شُرَیْحٍ ؛ أَنَّ رَجُلاً لَقِیَ رَجُلاً بِکُرْسِیٍّ فَصَدَمَہُ فَقَتَلَہُ ، فَقَالَ شُرَیْحٌ : ضَمِنَ الصَّادِمُ لِلْمَصْدُومِ۔",,,28204,,
28205,حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ أَشْعَثَ ، عَن حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَلِیٍّ ؛ فِی فَارِسَیْنِ اصْطَدَمَا فَمَاتَ أَحَدُہُمَا ، فَضَمِنَ الْحَیُّ الْمَیِّتَ۔,,,28205,,
28206,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ إِسْمَاعِیلَ بْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ؛ أَنَّہُ سُئِلَ عَن سَفِینَتَیْنِ اصْطَدَمَتَا ، فَغَرِقَتْ إِحْدَاہُمَا ؟ فَقَالَ : لَیْسَ عَلَی الآخِرین ضَمَان ، وَلَکِنْ أَیُّمَا رَجُلٍ أَوْثَقَ سَفِینَۃً عَلَی طَرِیقِ الْمُسْلِمِینَ فَأَصَابَتْ ، فَہُوَ ضَامِنٌ۔",,,28206,,
28207,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، عَنْ عَلِیٍّ ؛ فِی الْفَارِسَیْنِ یَصْطَدِمَانِ ، قَالَ : یَضْمَنُ الْحَیُّ دِیَۃَ الْمَیِّتِ۔",,,28207,,
28208,حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ حَجَّاجٍ ، عَنْ قَتَادَۃَ ، عَن کَعْبِ بْنِ سُورٍ ؛ أَنَّ رَجُلاً کَانَ عَلَی حِمَارٍ ، فَاسْتَقْبَلَہُ رَجُلٌ عَلَی بَعِیرٍ فِی زُقَاقٍ ، فَنَفَرَ الْحِمَارُ ، فَصُرعَ الرَّجُلُ فَأَصَابَہُ شَیْئٌ ، فَلَمْ یضَمِّنْ کَعْبُ بْنُ سُورٍ صَاحِبَ الْبَعِیرِ شَیْئًا۔,,,28208,,
28209,حَدَّثَنَا شَبَابَۃُ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الْمُطَّلِبِ بْنِ السَّائِبِ السَّہْمِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّ عُثْمَانَ قَضَی أَنَّ کُلَّ مُقْتَتِلَیْنِ اقْتَتَلاَ ضَمِنَا مَا بَیْنَہُمَا۔,,,28209,,
28210,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : إِذَا أُشْہِدَ عَلَی صَاحِبِ الْحَائِطِ الْمَائِلِ فَوَقَعَ فَأَصَابَ ، فَہُوَ ضَامِنٌ۔",,,28210,,
28211,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، عَنْ شُرَیْحٍ ، قَالَ : إِذَا کَانَ حَائِطُ الرَّجُلِ مَائِلاً فَأَشْہَدَ عَلَیْہِ ، ضَمِنَ۔",,,28211,,
28212,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ؛ مِثْلَہُ۔",,,28212,,
28213,حَدَّثَنَا عَبْدُ الْوَہَّابِ بْنُ عَطَائٍ الْخَفَّافُ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ؛ أَنَّہُ کَانَ یَقُولُ فِی الْحَائِطِ الْمَائِلِ إِذَا شَہِدُوا عَلَی صَاحِبِہِ فَقَتَلَ إِنْسَانًا ، فَہُوَ ضَامِنٌ۔,,,28213,,
28214,حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی عَوْنٍ ، عَنْ شُرَیْحٍ ؛ أَنَّ غُلاَمًا وَثَبَ عَلَی آخَرَ ، فَتَنَحَّی الأَسْفَلُ وَانْکَسَرَتْ ثَنِیَّۃُ الأَعْلَی ، فَضَمَّنَ الأَعْلَی ، وَلَمْ یُضَمِّنِ الأَسْفَلَ۔,,,28214,,
28215,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عِمْرَانُ بْنُ حُدَیْرٍ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ : لَوْ صَرَعَ رَجُلٌ عَلَی رَجُلٍ فَمَاتَ أَحَدُہُمَا ضمن الْبَاقِی ، قَالَ : قُلْتُ : لِمَ ؟ قَالَ : لأَنَّہُ لاَ یُطَلُّ دَمُ مُسْلِمٍ۔",,,28215,,
28216,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا سُفْیَانُ ، عَن مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّ غُلاَمَیْنِ کَانَا یَلْعَبَانِ التَّحِیَۃَ ، فَصَرَعَ أَحَدُہُمَا الآخَرَ ، فَشُجَّ أَحَدُہُمَا وَانْکَسَرَتْ ثَنِیَّۃُ الآخَرِ ، فَضَمَّنَ الأَعْلَی الأَسْفَلَ ، وَلَمْ یُضَمنْ الأَسْفَلُ الأَعْلَی۔",,,28216,,
28217,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی حَصیْنٍ ، عَنْ شُرَیْحٍ ؛ فِی رَجُلٍ وَقَعَ عَلَی رَجُلٍ مِنْ فَوْقِ بَیْتٍ ، فَمَاتَ الأَعْلَی ، قَالَ شُرَیْحٌ : أُضَمِّنُ الأَرْضَ۔",,,28217,,
28218,"حَدَّثَنَا شَرِیکٌ ، قَالَ : حدَّثَنَا إِسْرَائِیلُ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : إِنْ مَاتَ الأَسْفَلُ ضَمِنَ الأَعْلَی۔",,,28218,,
28219,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلِیِّ بْنِ أَبِی طَالِبٍ ، قَالَ : کَانَ غُلاَمَانِ یَلْعَبَانِ ، فَوَثَبَ أَحَدُہُمَا عَلَی ظَہْرِ صَاحِبِہِ ، فَانْکَسَرَتْ ثَنِیَّۃُ الأَعْلَی ، وَشُجَّ الأَسْفَلُ ، فَضَمَّنَ بَعْضُہُمْ بَعْضًا۔",,,28219,,
28220,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ؛ فِی رَجُلٍ وَقَعَ عَلَی رَجُلٍ مِن فَوْق بَیْتٍ ، فَمَاتَ أَحَدُہُمَا ، قَالَ: یَضْمَنُ الْحَیُّ مِنْہُمَا۔",,,28220,,
28221,حَدَّثَنَا أَبُو بَکْرٍ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ؛ فِی رَجُلٍ وَثَبَ عَلَی رَجُلٍ ، فَانْکَسَرَتْ ثَنِیَّۃُ الْوَاثِبِ وَشُجَّ الْمَوْثُوبُ عَلَیْہِ ، فَأَبْطَلَ ثَنِیَّۃَ الْوَاثِبِ ، وَضَمَّنَہُ شَجَّۃَ الْمَوْثُوبِ عَلَیْہِ۔,,,28221,,
28222,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی عَطَائٌ ، قَالَ : أَخْبَرَنِی صَفْوَانُ بْنُ یَعْلَی بْنِ أُمَیَّۃَ ، عَنْ أَبِیہِ ، قَالَ : کَانَ لِی أَجِیرٌ ، فَقَاتَلَ إِنْسَانًا ، فَعَضَّ أَحَدُہُمَا یَدَ الآخَرِ ، قَالَ عَطَائٌ : لَقَدْ أَخْبَرَنِی صَفْوَانُ أَیُّہُمَا عَضَّ الآخَرَ ، فَانْتَزَعَ الْمَعْضُوضُ یَدَہُ مِنْ فِی الْعَاضِّ ، فَانْتَزَعَ إِحْدَی ثَنِیَّتِہِ ، فَأَتَیَا إِلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَأَہْدَرَ ثَنِیَّتَہُ۔ (بخاری 6893۔ مسلم 1301)",,,28222,,
28223,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَن زُرَارَۃَ ، عَن عِمْرَانَ بْنِ حُصَیْنٍ ، قَالَ : فَأَطَلَّہَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔ (بخاری 6892۔ طبرانی 533)",,,28223,,
28224,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ عَطَائٍ ؛ أَنَّ رَجُلاً عَضَّ یَدَ آخَرَ عَلَی عَہْدِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَانْتَزَعَ ثَنِیَّتَہُ ، فَأَہْدَرَہَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔,,,28224,,
28225,"حَدَّثَنَا إِسْمَاعِیلُ بْنُ إِبْرَاہِیمَ ، عَن أَیُّوبَ ، عَنِ ابْنِ سِیرِینَ ؛ قَالَ : نُبِّئْتُ أَنَّ رَجُلاً عَضَّ یَدَ رَجُلٍ ، فَانْتَزَعَ یَدَہُ مِنْ فِیہِ فَأَسْقَطَ ثَنِیَّۃً ، أَوْ ثَنِیَّتَیْنِ مِنْ فِیہِ ، فَأَتَی إِلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَسْتَقِیدُ ، فَقَالَ لَہُ: أَفَیَدَعُ یَدَہُ فِی فِیکَ تَأْکُلُہَا ؟ إِنْ شِئْتَ دَفَعْتَ یَدَک إِلَیْہِ یَعَضُّہَا ، ثُمَّ انْتَزَعْہَا۔ (مسلم 1301۔ احمد 435)",,,28225,,
28226,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنَی ابْنُ أَبِی مُلَیْکَۃَ ، عَنْ جَدِّہِ ؛ أَنَّ إِنْسَانًا أَتَی أَبَا بَکْرٍ ، وَعَضَّہُ إِنْسَانٌ فَنَزَعَ یَدَہُ مِنْہُ فَنَدَرَتْ ثَنِیَّتُہُ ، فَقَالَ أَبُو بَکْرٍ : بَعِدتْ ثَنِیَّتَہُ۔",,,28226,,
28227,حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ؛ أَنَّ أَبَا بَکْرٍ ، وَعُمَرَ أَبْطَلاَہَا۔,,,28227,,
28228,حَدَّثَنَا حَفْصٌ ، عَنِ الشَّیْبَانِیِّ ، عَنْ مُحَمَّدِ بْنِ عُبَیْدِ اللہِ ، عَنْ شُرَیْحٍ ؛ فِی رَجُلٍ عَضَّ رَجُلاً فَنَزَعَ یَدَہُ، فَانْتُزِعَتْ ثَنِیَّتُہُ ، فَأَبْطَلَہَا شُرَیْحٌ۔,,,28228,,
28229,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ؛ أَنَّ رَجُلَیْنِ مِنَ الأَعْرَابِ اخْتَصَمَا بِالْمَدِینَۃِ فِی زَمَانِ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، فَقَالَ أَحَدُہُمَا لِصَاحِبِہِ : ضَرَبْتُہُ وَاللَّہِ حَتَّی سَلَحَ ، فَقَالَ : اشْہَدُوا ، فَقَدْ وَاللَّہِ صَدَقَ ، فَأَرْسَلَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ إِلَی سَعِیدِ بْنِ الْمُسَیَّبِ یَسْأَلُہُ عَنْ رَجُلٍ ضَرَبَ رَجُلاً حَتَّی سَلَحَ ، ہَلْ فِی ذَلِکَ أَمْر مَضَی ، أَوْ سُنَّۃٌ ؟ قَالَ سَعِیدٌ : قَضَی فِیہَا عُثْمَانُ بِثُلُثِ الدِّیَۃِ۔",,,28229,,
28230,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ، عَنِ الشَّیْبَانِیِّ، عَنِ الشَّعْبِیِّ؛ فِی الرَّجُلِ إِذَا أَصَابَ بِجِرَاحَۃٍ فَاقْتُصَّ مِنْہُ فَمَاتَ، قَالَ : یُدْفَع مِنْ دِیَۃِ الْمَیِّتِ جِرَاحَۃَ الأَوَّلِ۔ قَالَ عَبْدُ اللہِ بْنُ ذَکْوَانَ : لَیْسَ لَہُ مِنْ دِیَۃِ الْمَیِّتِ شَیْئٌ۔",,,28230,,
28231,"حَدَّثَنَا أَبُو بَکْرٍ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : یُرْفَعُ عَنْہُ بِقَدْرِ الْجِرَاحَۃِ۔",,,28231,,
28232,"حَدَّثَنَا عَبْدَہُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَبْدِ اللہِ ، قَالَ : یُرْفَعُ عَنْہُ بِقَدْرِ الْجِرَاحَۃِ ، وَیَکُونُ ضَامِنًا لِبَقِیَّۃِ الدِّیَۃِ۔",,,28232,,
28233,"حَدَّثَنَا عَبْدُ الأَعْلَی، عَنْ مَعْمَرٍ، عَنِ الزُّہْرِیِّ، قَالَ: إِذَا مَاتَ الَّذِی یُقْتَصُّ مِنْہُ ،فَالْمُقْتَصُّ ضَامِنٌ لِلدِّیَۃِ۔",,,28233,,
28234,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ؛ فِی الْمُقْتَصِّ مِنْہُ : أَیُّہُمَا مَاتَ وُدِیَ۔",,,28234,,
28235,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، قَالَ : اسْتَأْذَنْتُ زِیَادَ بْنَ جُبَیْرٍ فِی الْحَجِّ ، فَسَأَلَنِی عَنْ رَجُلٍ شَجَّ رَجُلاً فَاقْتَصَّ لَہُ مِنْہُ ، فَمَاتَ الْمُقْتَصُّ مِنْہُ ؟ فَقُلْتُ : عَلَیْہِ الدِّیَۃُ ، وَیُرْفَعُ عَنْہُ بِقَدْرِ الشَّجَّۃِ ، ثُمَّ ہِبْتُ ذَلِکَ فَجَائَ إِبْرَاہِیمُ فَسَأَلْتُہُ ؟ فَقَالَ : عَلَیْہِ الدِّیَۃُ۔",,,28235,,
28236,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ ، وَحَمَّادًا عَن ذَلِکَ ؟ فَقَالاَ : عَلَیْہِ الدِّیَۃُ ، وَقَالَ حَمَّادٌ : یُرْفَعُ عَنْہُ بِقَدْرِ الشَّجَّۃِ۔",,,28236,,
28237,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شَرِیکٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، وَالشَّعْبِیِّ ، قَالاَ : عَلَیْہِ الدِّیَۃُ ، وَیُرْفَعُ عَنْہُ بِقَدْرِ الشَّجَّۃِ۔",,,28237,,
28238,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ مَعْمَرٍ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ (ح) وَعَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالاَ : عَلَیْہِ الدِّیَۃُ ، وَلاَ یُرْفَعُ عَنْہُ شَیْئٌ۔",,,28238,,
28239,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ أَشْعَثَ ، عَنْ عَامِرٍ (ح) وَعَنْ حَجَّاجٍ ، عَنْ عُمَیْرِ بْنِ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَن خِلاَسٍ ، عَنْ عَلِیٍّ ؛ أَنَّہُ قَالَ : مَنْ مَاتَ فِی قِصَاصٍ بِکِتَابِ اللہِ فَلاَ دِیَۃَ لَہُ۔",,,28239,,
28240,حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ سَعِید ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدٍ ، عَنْ عُمَرَ ؛ مِثْلَہُ۔,,,28240,,
28241,"حَدَّثَنَا أَبُو أُسَامَۃَ، عَنْ ہِشَامٍ، عَنِ الْحَسَنِ؛ فِی الرَّجُلِ یُقْتَصُّ مِنْہُ فَیَمُوتُ: لاَ دِیَۃَ لَہُ ، قَتَلَہُ کِتَابُ اللہِ۔",,,28241,,
28242,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ، عَن یُونُسَ، عَنِ الْحَسَنِ؛ فِی الرَّجُلِ یَمُوتُ فِی الْقِصَاصِ ، قَالَ : لاَ دِیَۃَ لَہُ۔",,,28242,,
28243,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَن شَیْخٍ مِنْ أَہْلِ الْبَصْرَۃِ ، عَنْ أَبِی نَضْرَۃَ ، عَنْ أَبِی سَعِیدٍ ؛ أَنَّ أَبَا بَکْرٍ ، وَعُمَرَ ، قَالاَ : مَنْ قَتَلَہُ حَدٌّ فَلاَ عَقْلَ لَہُ۔",,,28243,,
28244,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَمُحَمَّدٍ ؛ فِی الرَّجُلِ یُقَامُ عَلَیْہِ الْحَدُّ فَیَمُوتُ ، قَالاَ : لاَ دِیَۃَ لَہُ۔",,,28244,,
28245,"حَدَّثَنَا عَبَّادٌ ، عَنْ حَجَّاجٍ ، عَنْ عُمَیْرِ بْنِ سَعِیدٍ ، قَالَ : قَالَ عَلِیٌّ : إِذَا أُقِیمَ عَلَی الرَّجُلِ الْحَدُّ فِی الزنَی، أَوْ سَرِقَۃٍ ، أَوْ قَذْفٍ فَمَاتَ ، فَلاَ دِیَۃَ لَہُ۔",,,28245,,
28246,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مِسْعَرٌ ، وَسُفْیَانُ ، عَنْ أَبِی حَصِینٍ ، عَنْ عُمَیْرِ بْنِ سَعِید النَّخَعِیِّ ، قَالَ : قَالَ عَلِیٌّ : مَا کُنْتُ لأُِقِیمَ عَلَی رَجُلٍ حَدًّا فَیَمُوت فَأَجِد فِی نَفْسِی مِنْہُ شَیْئًا إِلاَّ صَاحِبَ الْخَمْرِ لَوْ مَاتَ وَدَیْتُہُ۔ وَزَادَ سُفْیَانُ : وَذَلِکَ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لَمْ یَسُنَّہُ۔",,,28246,,
28247,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ، قَالَ: حدَّثَنَا سَعِیدٌ، عَنْ مَطَرٍ، عَنْ عَطَائٍ، عَن عُبَیْدِ بْنِ عُمَیْرٍ؛ أَنَّ عَلِیًّا وَ عُمَرَ، قَالاَ : مَنْ قَتَلَہُ قِصَاصٌ فَلاَ دِیَۃَ لَہُ۔",,,28247,,
28248,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ عَلِیٍّ ، وَعَبْدِ اللہِ ، قَالاَ : الْعَمْدُ السِّلاَحُ۔",,,28248,,
28249,حَدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، مِثْلَہُ۔,,,28249,,
28250,"حَدَّثَنَا أَبُو خَالِدٍ، عَنِ ابْنِ جُرَیْجٍ، عَمَّنْ حَدَّثَہُ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ، قَالَ: الْعَمْدُ بِالإِبْرَۃِ فَمَا فَوْقَہَا۔",,,28250,,
28251,"حَدَّثَنَا عَبَّادٌ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، عَن مَسْرُوقٍ ، قَالَ : الْعَمْدُ بِالْحَدِیدَۃِ۔",,,28251,,
28252,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : کُلُّ شَیْئٍ بِحَدِیدَۃٍ ، فَہُوَ عَمْدٌ۔",,,28252,,
28253,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : لاَ یُقَادُ مِنْ ضَارِبٍ ، إِلاَّ أَنْ یَضْرِبَ بِحَدِیدَۃٍ۔",,,28253,,
28254,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ أَبِی عَازِبٍ ، عَنِ النُّعْمَانِ بْنِ بَشِیرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : کُلُّ شَیْئٍ خَطَأٌ إِلاَّ السَّیْفَ ، وَلِکُلِّ خَطَأٍ أَرْشٌ۔",,,28254,,
28255,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : الْعَمْدُ بِالسِّلاَحِ۔",,,28255,,
28256,حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنِ الشَّیْبَانِیِّ ، عَن زِیَادِ بْنِ عِلاَقَۃَ ، عَنْ رَجُلٍ ؛ أَنَّ رَجُلاً رَمَی رَجُلاً بِجُلْمُودٍ فَقَتَلَہُ ، فَأَقَادَہُ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔ (بخاری 1903۔ بیہقی 43),,,28256,,
28257,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : الضَّرْبُ بِالصَّخْرَۃِ عَمْدٌ ، وَفِیہَا الْقَوَدُ۔",,,28257,,
28258,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَن عُبَیْدِ بْنِ عُمَیْرٍ ، قَالَ : یَعْمِدُ الرَّجُلُ الأَیْدُ ، یَعْنِی الشَّدِیدَ ، إِلَی الصَّخْرَۃِ ، أَوْ إِلَی الْخَشَبَۃِ فَیَشْدَخُ بِہَا رَأْسَ الرَّجُلِ ، وَأَیُّ عَمْدٍ أَعْمَدُ مِنْ ہَذَا ؟۔",,,28258,,
28259,"حَدَّثَنَا شَرِیکٌ ، عَن زَیْدِ بْنِ جُبَیْرٍ ، عَنْ جَرْوَۃَ بْنِ حُمیلٍ ، عَنْ أَبِیہِ ، قَالَ : قَالَ عُمَرُ : یَعْمِدُ أَحَدُکُمْ إِلَی أَخِیہِ فَیَضْرِبُہُ بِمِثْلِ آکِلَۃِ اللَّحْمِ ، لاَ أُوتَی بِرَجُلٍ فَعَلَ ذَلِکَ فَقَتَلَ ، إِلاَّ أَقَدْتُہُ مِنْہُ۔",,,28259,,
28260,"حَدَّثَنَا عَبْدُالأَعْلَی، عَنْ مَعْمَرٍ، عَنِ الزُّہْرِیِّ، قَالَ: أَیَضْرِبُہُ بِالْعَصَا عمْدًا؟ إِذَا قَتَلَتْ صَاحِبَہَا قُتِلَ الضَّارِبُ۔",,,28260,,
28261,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ ، عَنْ عَلِیٍّ ، قَالَ : شِبْہُ الْعَمْدِ ؛ بِالْعَصَا ، وَالْحَجَرِ الْعَظِیمِ۔",,,28261,,
28262,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ قَیْسٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : إِذَا ضَرَبَ بِالْعَصَا فَأَعَادَ وَأَبْدَأَ ، قُتِلَ۔",,,28262,,
28263,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، قَالَ : سَأَلْتُ الْحَکَمَ ، وَحَمَّادًا عَنِ الرَّجُلِ یَضْرِبُ الرَّجُلَ بِالْعَصَا فَیَقْتُلُ ؟ قَالَ الْحَکَمُ : لَیْسَ عَلَیْہِ قَوَدٌ ، وَقَالَ حَمَّادٌ : یُقْتَلُ۔",,,28263,,
28264,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : إِذَا عَلاَ بِالْعَصَا ، فَہُوَ قَوَدٌ۔",,,28264,,
28265,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ہِشَامٌ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسٍ ؛ أَنَّ یَہُودِیًّا رَضَخَ رَأْسَ امْرَأَۃٍ بِحَجَرٍ ، فَرَضَخَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَأْسَہُ بَیْنَ حَجَرَیْنِ۔",,,28265,,
28266,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّ إِنْسَانًا قُتِلَ بِصَنْعَائَ ، وَأَنَّ عُمَرَ قَتَلَ بِہِ سَبْعَۃَ نَفَرٍ ، وَقَالَ : لَوْ تَمَالاَ عَلَیْہِ أَہْلُ صَنْعَائَ لَقَتَلْتُہُمْ بِہِ جَمِیعًا۔ (مالک 871)",,,28266,,
28267,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ہِشَامٌ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : قَالَ عُمَرُ : لَوِ اشْتَرَکَ فِیہِ أَہْلُ صَنْعَائَ لَقَتَلْتُہُمْ۔",,,28267,,
28268,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الْعُمَرِیُّ ، عَن نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ عُمَرَ بْنَ الْخَطَّابِ قَتَلَ سَبْعَۃً مِنْ أَہْلِ صَنْعَائَ بِرَجُلٍ ، وَقَالَ : لَوِ اشْتَرَکَ فِیہِ أَہْلُ صَنْعَائَ لَقَتَلْتُہُمْ۔",,,28268,,
28269,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إِسْرَائِیلُ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ سَعِیدِ بْنِ وَہْبٍ ، قَالَ : خَرَجَ رِجَالٌ سَفَرٌ فَصَحِبَہُمْ رَجُلٌ ، فَقَدِمُوا وَلَیْسَ مَعَہُمْ ، قَالَ: فَاتَّہَمَہُمْ أَہْلُہُ ، فَقَالَ شُرَیْحٌ : شُہُودُکُمْ أَنَّہُمْ قَتَلُوا صَاحِبَکُمْ، وَإِلاَّ حَلَفُوا بِاللَّہِ مَا قَتَلُوہُ ، فَأَتَوْا بِہِمْ عَلِیًّا وَأَنَا عِنْدَہُ ، فَفَرَّقَ بَیْنَہُمْ فَاعْتَرَفُوا ، فَسَمِعْتُ عَلِیًّا یَقُولُ : أَنَا أَبُو الْحَسَنِ الْقرْم ، فَأَمَرَ بِہِمْ فَقُتِلُوا۔",,,28269,,
28270,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : سَمِعْتُ سُلَیْمَانَ بْنَ مُوسَی ، قَالَ : فِی الْقَوْمِ یُدْلُونَ جَمِیعًا فِی الرَّجُلِ ، یَقْتُلُہُمْ جَمِیعًا بِہِ۔",,,28270,,
28271,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : رَجُلٌ قَتَلَ رَجُلَیْنِ حُرَّیْنِ عَمْدًا ؟ قَالَ : ہُوَ بِہِمَا قَوَدٌ۔ (عبدالرزاق 18087)",,,28271,,
28272,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَن مُجَالِدٍ ، عَنِ الشَّعْبِیِّ ، عَنِ الْمُغِیرَۃَ بْنِ شُعْبَۃَ ؛ أَنَّہُ قَتَلَ سَبْعَۃً بِرَجُلٍ۔,,,28272,,
28273,حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ إِسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَن حَبِیبِ بْنِ أَبِی ثَابِتٍ ، قَالَ ، لاَ یُقْتَلُ رَجُلاَنِ بِرَجُلٍ۔,,,28273,,
28274,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، قَالَ : کَانَ عَبْدُ الْمَلِکِ ، وَابْنُ الزُّبَیْرِ لاَ یَقْتُلاَنِ مِنْہُمْ إِلاَّ وَاحِدًا۔",,,28274,,
28275,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنْ مُحَمَّدٍ ، قَالَ : لاَ یُقْتَلُ مِنْہُمْ إِلاَّ وَاحِد۔",,,28275,,
28276,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَن حَسَنِ بْنِ صَالِحٍ ، عَن سِمَاکٍ ، عَن ذُہْلِ بْنِ کَعْبٍ ؛ أَنَّ مُعَاذًا قَالَ لِعُمَرَ : لَیْسَ لَکَ أَنْ تَقْتُلَ نَفْسَیْنِ بِنَفْسٍ۔",,,28276,,
28277,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ عَبْدِ اللہِ بْنِ عَمْرٍو ، قَالَ : کَانَ رَجُلٌ یَسُوقُ حِمَارًا وَکَانَ رَاکِبًا عَلَیْہِ، فَضَرَبَہُ بِعَصًا مَعَہُ ، فَطَارَتْ مِنْہَا شَظِیَّۃٌ فَأَصَابَتْ عَیْنَہُ فَفَقَأَتْہَا، فَرُفِعَ ذَلِکَ إِلَی عُمَرَ بْنِ الْخَطَّابِ ، فَقَالَ: ہِیَ یَدٌ مِنْ أَیْدِی الْمُسْلِمِینَ، لَمْ یُصِبْہَا اعْتِدَائٌ عَلَی أَحَدٍ، فَجَعَلَ دِیَۃَ عَیْنِہِ عَلَی عَاقِلَتِہِ۔",,,28277,,
28278,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : الرَّجُلُ یُصِیبُ نَفْسَہُ بِالْجُرْحِ خَطَأً ، عَلَیْہِ بَیِّنَۃٌ ؟ قَالَ : تَعْقِلُہُ عَاقِلَتُہُ۔",,,28278,,
28279,"حَدَّثَنَا حَرَمِیُّ بْنُ عُمَارَۃَ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ ، وَحَمَّادًا عَن رَجُلَیْنِ شَہِدَا عَلَی رَجُلٍ فَقُطِعَتْ یَدُہُ ، فَنَظَرُوا فَإِذَا أَحَدُ الشَّاہِدَیْنِ عَبْدٌ ؟ قَالاَ : یَضْمَنُ الإِمَامُ۔",,,28279,,
28280,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : حَملَ رَجُلٌ ابْنَہُ عَلَی فَرَسٍ لِیَشُورَہُ ، فَنَخَسَ بِہِ وَصَوَّتَ بِہِ فَقَتَلَہُ ، فَجَعَلَ دِیَتَہُ عَلَی عَاقِلَتِہِ ، وَلَمْ یُوَرِّثِ الأَبَ شَیْئًا۔",,,28280,,
28281,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : الرَّجُلُ یَقْتُلُ ابْنَہُ خَطَأً ؟ قَالَ : تَعْقِلُہُ عَاقِلَتُہُ۔",,,28281,,
28282,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی عَمْرُو بْنُ دِینَارٍ ؛ أَنَّ عَبْدَ الْمَلِکِ بْنَ مَرْوَانَ جَائَہُ رَجُلٌ قَتَلَ أَبَاہُ وَأَخَاہُ ، فَقَالَ : فِی مَالِکَ خَاصَّۃً۔",,,28282,,
28283,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَن سِمَاکٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَعْقَاعِ ، قَالَ : دَعَوْتُ إِلَی بَیْتِی قَوْمًا فَطَعِمُوا وَشَرِبُوا، فَسَکِرُوا وَقَامُوا إِلَی سَکَاکِینَ الْبَیْتِ، فَاضْطَرَبُوا بِہَا، فَجَرَحَ بَعْضُہُمْ بَعْضًا وَہُمْ أَرْبَعَۃٌ ، فَمَاتَ اثْنَان وَبَقِیَ اثْنَان، فَجَعَلَ عَلِیٌّ الدِّیَۃَ عَلَی الأَرْبَعَۃِ جَمِیعًا، وَقَصَّ لِلْمَجْرُوحِینَ مَا أَصَابَہُمَا مِنْ جِرَاحَاتِہِمَا۔",,,28283,,
28284,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا زَکَرِیَّا ، عَنْ عَامِرٍ ؛ أَنَّ الْحَسَنَ بْنَ عَلِیٍّ أُتِیَ بِرَجُلَیْنِ قَتَلاَ ثَلاَثَۃً ، وَقَدْ جُرِحَ الرَّجُلاَنِ ، فَقَالَ الْحَسَنُ بْنُ عَلِیٍّ : عَلَی الرَّجُلَیْنِ دِیَۃُ الثَّلاَثَۃِ ، وَیُرْفَعُ عَنہُمَا جِرَاحَۃُ الرَّجُلَیْنِ۔",,,28284,,
28285,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، وَابْنِ أَبِی مُلَیْکَۃَ ، قَالاَ : لَوْ أَنَّ رَجُلاً قَتَلَ رَجُلاً ، وَجَرَحَ الْمَقْتُولُ الْقَاتِلَ جُرْحًا ، قُتِلَ الْقَاتِلُ ، وَوَدَی أَہْلُ الْمَقْتُولِ جُرْحَ الْقَاتِلِ۔",,,28285,,
28286,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : وُجِدَ فِی بَیْتٍ قَتْلَی وَشِجَاجٌ ، فَجُعِلَ بَعْضَہُمْ بِبَعْضٍ۔",,,28286,,
28287,"حَدَّثَنَا حَفْصٌ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ، قَالَ : خَرَجَ قَوْمٌ مِنْ زُرَارَۃَ فَاقْتَتَلُوا ، فَقَتَلَ بَعْضُہُمْ بَعْضًا، فَضَمَّنَ عَلِیٌّ دِیَۃَ الْمَقْتُولِینَ ، وَرَفَعَ عَنِ الْمَجْرُوحِینَ بِقَدْرِ جِرَاحَتِہِمْ۔",,,28287,,
28288,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : إِذَا کَانَ الْکَلْبُ فِی الدَّارِ ، فَأَذِنَ أَہْلُ الدَّارِ لِلرَّجُلِ فَدَخَلَ فَعَقَرَہُ ضَمِنُوا ، وَإِنْ دَخَلَ بِغَیْرِ إِذْنٍ ، فَعَقَرَہُ لَمْ یَضْمَنُوا۔",,,28288,,
28289,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا زَکَرِیَّا، عَنْ عَامِرٍ، قَالَ: إِنْ عَقَرَ کَلْبُہُمْ خَارِجًا مِنْ دَارِہِمْ شِبْرًا فَمَا فَوْقَہُ ضَمِنُوا۔",,,28289,,
28290,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مُحَمَّد بْن قَیْسٍ ، سَمِعَہُ مِنَ الشَّعْبِیِّ ، قَالَ ، إِذَا أَدْخَلَ الرَّجُلُ الرَّجُلَ دَارَہُ، فَہُوَ ضَامِنٌ لَہُ حَتَّی یُخْرِجَہُ کَمَا أَدْخَلَہُ۔",,,28290,,
28291,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا دَخَلَ بِإِذْنِہِمْ فَعَقَرَہُ ضَمِنُوا ، وَإِنْ دَخَلَ بِغَیْرِ إِذْنِہِمْ ، فَعَقَرَہُ لَمْ یَضْمَنُوا۔",,,28291,,
28292,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَن طَارِقِ بْنِ عَبْدِ الرَّحْمَنِ ، قَالَ : کُنْتُ عندَ شُرَیْحٍ ، فَجَائَہُ سَائِلٌ قَدْ خُرِقَ جِرَابُہُ وَخُمِشَتْ سَاقُہُ ، فَقَالَ : إِنِّی دَخَلْتُ دَارَ قَوْمٍ فَعَقَرَنِی کَلْبُہُمْ ، فَقَالَ شُرَیْحٌ : إِنْ کَانَ أَذِنُوا لَکَ فَہُمْ ضَامِنُونَ ، وَإِلاَّ فَلاَ ضَمَانَ عَلَیْہِمْ۔",,,28292,,
28293,"حَدَّثَنَا عُبَیْدُ اللہِ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ؛ فِی الْکَلْبِ الْعَقُورِ ، قَالَ : لاَ یُضْمَنُ۔",,,28293,,
28294,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنْ عَامِرٍ ، قَالَ : کَانَ یَقُولُ فِی الْکِلاَبِ إِذَا غَشِیَہَا الرَّجُلُ وَہِیَ مَعَ الْغَنَمِ فَعَقَرَتْہُ ، فَلَیْسَ عَلَیْہِ ضَمَانٌ ، وَإِنْ تَعَرَّضَتْ لِلنَّاسِ فِی الطَّرِیقِ فَأَصَابَتْ أَحَدًا ، فَعَلَیْہِ الضَّمَانُ۔",,,28294,,
28295,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ أَشْعَثَ ، وَعَمْرٌو ، عَنِ الْحَسَنِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ قَوَدَ إِلاَّ بِالسَّیْفِ۔",,,28295,,
28296,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ؛ فِی الرَّجُلِ یَقْتُلُ الرَّجُلَ بِالْحَصَی ، أَوْ یُمَثِّلُ بِہِ ، قَالَ : إِنَّمَا الْقَوَدُ بِالسَّیْفِ ، لَمْ یَکُنْ مِنْ أَمْرِہِمُ الْمُثْلَۃُ۔",,,28296,,
28297,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُحَمَّدِ بْنِ قَیْسٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : لاَ قَوَدَ إِلاَّ بِحَدِیدَۃٍ۔",,,28297,,
28298,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ، عَنِ ابْنِ أَبِی عَرُوبَۃَ، عَنْ أَبِی مَعْشَرٍ، عَنْ إِبْرَاہِیمَ، قَالَ: لاَ قَوَدَ إِلاَّ بِحَدِیدَۃٍ۔",,,28298,,
28299,حَدَّثَنَا عَبْدَۃُ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ؛ مِثْلَہُ۔,,,28299,,
28300,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ فِی الْعَبْدِ یَجْنِی الْجِنَایَاتِ ، قَالَ : یُدْفَعُ إِلَیْہِمْ ، فَیَقْتَسِمُونَہُ عَلَی قَدْرِ الْجِنَایَاتِ۔",,,28300,,
28301,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ، عَنْ سُفْیَانَ ، عَنْ عَبْدِالْمَلِکِ ، عَنِ الشَّعْبِیِّ ؛ فِی عَبْدٍ شَجَّ رَجُلاً ، ثُمَّ شَجَّ آخَرَ، ثُمَّ شَجَّ آخَرَ ، فَقَضَی بِہِ لِلآخَرِ۔,,,28301,,
28302,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَن حَمَّادٍ ، وَرَبِیعَۃَ ، قَالاَ : یَقْتَسِمُونَہُ بِالْحِصَصِ۔",,,28302,,
28303,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَن کَرَدْمِ ؛ أَنَّ رَجُلاً سَأَلَ ابْنَ عَبَّاسٍ ، وَأَبَا ہُرَیْرَۃَ ، وَابْنَ عُمَرَ عَنْ رَجُلٍ قَتَلَ مُؤْمِنًا ، فَہَلْ لَہُ مِنْ تَوْبَۃٍ ؟ فَکُلُّہُمْ قَالَ : یَسْتَطِیعُ أَنْ یُحْیِیَہُ ؟ یَسْتَطِیعُ أَنْ یَبْتَغِیَ نَفَقًا فِی الأَرْضِ ، أَوْ سُلَّمًا فِی السَّمَائِ ؟ یَسْتَطِیعُ أَنْ لاَ یَمُوتَ ؟۔",,,28303,,
28304,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَبِی نَصْرٍ ، وَیَحْیَی الْجَابِرِ ، عَنْ سَالِمِ بْنِ أَبِی الْجَعْدِ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : أَتَاہُ رَجُلٌ ، فَقَالَ : یَا أَبَا عَبَّاسٍ ، أَرَأَیْتَ رَجُلاً قَتَلَ مُتَعَمِّدًا ، مَا جَزَاؤُہُ ؟ قَالَ : {جَزَاؤُہُ جَہَنَّمُ خَالِدًا فِیہَا وَغَضِبَ اللَّہُ عَلَیْہِ} الآیَۃَ ، قَالَ : أَرَأَیْتَ إِنْ تَابَ ، وَآمَنَ ، وَعَمِلَ عَمَلاً صَالِحًا ، ثُمَّ اہْتَدَی ؟ فَقَالَ : وَأَنَّی لَہُ التَّوْبَۃُ ، ثَکِلَتْک أُمُّک ؟ إِنَّہُ یَجِیئُ یَوْمَ الْقِیَامَۃِ آخِذًا بِرَأْسِہِ ، تَشْخَبُ أَوْدَاجُہُ حَتَّی یَقِفَ بِہِ عَندَ الْعَرْشِ ، فَیَقُولُ : یَا رَبِّ ، سَلْ ہَذَا فِیمَ قَتَلَنِی۔ (ترمذی 3029۔ احمد 222)",,,28304,,
28305,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مُطَرِّفٍ ، عَنْ أَبِی السَّفَرِ ، عَن نَاجِیَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : ہُمَا الْمُبْہَمَتَانِ : الشِّرْکُ ، وَالْقَتْلُ۔",,,28305,,
28306,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا حُریثُ بْنُ السَّائِبِ ، عَنِ الْحَسَنِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَا نَازَلْتُ رَبِّی فِی شَیْئٍ ، مَا نَازَلْتُہُ فِی قَاتِلِ الْمُؤْمِنِ ، فَلَمْ یُجِبْنِی۔",,,28306,,
28307,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَن ہَارُونَ بْنِ سَعْدٍ ، عَنْ أَبِی الضُّحَی ، قَالَ : کُنْتُ مَعَ ابْنِ عُمَرَ فِی فُسْطَاطِہِ ، فَسَأَلَہُ رَجُلٌ عَنْ رَجُلٍ قَتَلَ مُؤْمِنًا مُتَعَمِّدًا ؟ قَالَ : فَقَرَأَ عَلَیْہِ ابْنُ عُمَرَ : {وَمَنْ یَقْتُلْ مُؤْمِنًا مُتَعَمِّدًا فَجَزَاؤُہُ جَہَنَّمُ خَالِدًا فِیہَا} الآیَۃِ ، فَانْظُرْ مَنْ قَتَلْتَ۔",,,28307,,
28308,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سَلَمَۃُ بْنُ نُبَیْطٍ ، عَنِ الضَّحَّاکِ ، قَالَ : لَیْسَ لِقَاتِلِ الْمُؤْمِنِ تَوْبَۃٌ۔",,,28308,,
28309,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَن یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : قَالَ أَبُو مُوسَی : مَا مِنْ خَصْمٍ یَوْمَ الْقِیَامَۃِ أَبْغَضُ إِلَیَّ مِنْ رَجُلٍ قَتَلْتُہُ ، تَشْخبُ أَوْدَاجُہُ دَمًا ، یَقُولُ : یَا رَبِّ ، سَلْ ہَذَا عَلاَمَ قَتَلَنِی ؟۔",,,28309,,
28310,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سَلَمَۃُ بْنُ نُبَیْطٍ ، عَنِ الضَّحَّاکِ بْنِ مُزَاحِمٍ ، قَالَ : لأَنْ أَتُوبَ مِنَ الشِّرْکِ ، أَحَبَّ إِلَیَّ مِنْ أَنْ أَتُوبَ مِنْ قَتْلِ مُؤْمِنٍ۔",,,28310,,
28311,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سَلَمَۃُ بْنُ نُبَیْطٍ ، عَنِ الضَّحَّاکِ ؛ (وَمَنْ یَقْتُلْ مُؤْمِنًا مُتَعَمِّدًا فَجَزَاؤُہُ جَہَنَّمُ خَالِدًا فِیہَا) قَالَ : مَا نَسَخَہَا شَیْئٌ مُنْذُ نَزَلَتْ۔",,,28311,,
28312,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إِسْمَاعِیلُ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَائِذٍ ، عَن عُقْبَۃَ بْنِ عَامِرٍ الْجُہَنِیِّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ لَقِیَ اللَّہَ لاَ یُشْرِکُ بِہِ شَیْئًا ، لَمْ یَتَنَدَّ بِدَمٍ حَرَامٍ دَخَلَ الْجَنَّۃَ۔\n\n(ابن ماجہ 2618۔ حاکم 351)",,,28312,,
28313,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ إِبْرَاہِیمَ ، قَالَ : قَالَ عَبْدُ اللہِ : لاَ یَزَالُ الرَّجُلُ فِی فُسْحَۃٍ مِنْ دِینِہِ مَا نَقِیَتْ کَفُّہُ مِنَ الدَّمِ ، فَإِذَا غَمَسَ یَدَہُ فِی دَمٍ حَرَامٍ نُزِعَ حَیَاؤُہُ۔",,,28313,,
28314,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَن شِمْرٍ ، عَن شَہْرِ بْنِ حَوْشَبٍ ، عنْ أَبِی الدَّرْدَائِ ، قَالَ : یَجِیئُ الْمَقْتُولُ یَوْمَ الْقِیَامَۃِ ، فَیُجْلِسُ عَلَی الْجَادَّۃِ ، فَإِذَا مَرَّ بِہِ الْقَاتِلُ قَامَ إِلَیْہِ فَأَخَذَ بِتَلْبِیبِہِ ، فَیَقُولُ : یَا رَبِّ ، سَلْ ہَذَا فِیمَ قَتَلَنِی ؟ قَالَ : فَیَقُولُ : أَمَرَنِی فُلاَن ، قَالَ : فَیُؤْخَذُ الْقَاتِلُ وَالآمِرُ فَیُلْقَیَانِ فِی النَّارِ۔",,,28314,,
28315,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا أَبُو الأَشْہَبِ ، قَالَ : سَمِعْتُ مُزَاحِمًا الضَّبِّیَّ یُحَدِّثُ الْحَسَنَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : بَیْنَمَا رَجُلٌ قَدْ سَقَی فِی حَوْضٍ لَہُ ، یَنْتَظِرُ ذَوْدًا تَرِدُ عَلَیْہِ ، إِذْ جَائَہُ رَجُلٌ رَاکِبٌ ظَمْآنُ مُطْمَئِنٌّ ، قَالَ : أَرِدْ ؟ قَالَ : لاَ ، قَالَ : فَتَنَحَّی ، فَعَقَلَ رَاحِلَتَہُ ، فَلَمَّا رَأَتِ الْمَائَ دَنَتْ مِنَ الْحَوْضِ ، فَفَجَّرَتِ الْحَوْضَ ، قَالَ : فَقَامَ صَاحِبُ الْحَوْضِ فَأَخَذَ سَیْفًا مِنْ عنقِہِ ، ثُمَّ ضَرَبَہ بِہِ حَتَّی قَتَلَہُ، قَالَ: فَخَرَجَ یَسْتَفْتِی، فَسَأَلَ رِجَالاً مِنْ أَصْحَابِ مُحَمَّدٍ ، لَسْتُ أُسَمِّیہِمْ ، وَکُلُّہُمْ یُؤَیِّسُہُ ، حَتَّی أَتَی رَجُلاً مِنْہُمْ ، فَقَالَ : ہَلْ تَسْتَطِیعُ أَنْ تُصْدِرَہُ کَمَا أَوْرَدْتَہُ ؟ قَالَ : لاَ ، قَالَ : فَہَلَ تَسْتَطِیعُ أَنْ تَبْتَغِیَ نَفَقًا فِی الأَرْضِ ، أَوْ سُلَّمًا فِی السَّمَائِ ؟ فَقَالَ : لاَ ، قَالَ : فَقَامَ الرَّجُلُ ، فَذَہَبَ غَیْرَ بَعِیدٍ ، فَدَعَاہُ فَرَدَّہُ ، فَقَالَ : ہَلْ لَکَ مِنْ وَالِدَیْنِ ؟ قَالَ : نَعَمْ ، أُمِّی حَیَّۃٌ ، قَالَ : احْمِلْہَا وَبِرَّہَا ، فَإِنْ دَخَلَ الاٰخَرُ النَّارَ ، فَأَبْعَدَ اللَّہُ مَنْ أَبْعَدَہُ۔",,,28315,,
28316,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا سَلاَّمُ بْنُ مِسْکِینٍ ، قَالَ ، حَدَّثَنِی سُلَیْمَانُ بْنُ عَلِیٍّ ، عَنْ أَبِی سَعِیدٍ الخدری ، قَالَ : قِیلَ لَہُ فِی ہَذِہِ الآیَۃِ : {مَنْ قَتَلَ نَفْسًا بِغَیْرِ نَفْسٍ ، أَوْ فَسَادٍ فِی الأَرْضِ فَکَأَنَّمَا قَتَلَ النَّاسَ جَمِیعًا} ، أَہِیَ لنا کَمَا کَانَتْ لِبَنِی إِسْرَائِیلَ ؟ قَالَ : فَقَالَ : إِی ، وَالَّذِی لاَ إِلَہَ إِلاَّ ہُوَ۔",,,28316,,
28317,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَن مُجَاہِدٍ ، قَالَ : لِقَاتِلِ الْمُؤْمِنِ تَوْبَۃٌ۔",,,28317,,
28318,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَن مَنْصُورٍ ، عَن مُجَاہِدٍ ، قَالَ : کَانَ یُقَالُ : تَوْبَۃُ الْقَاتِلِ إِذَا نَدِمَ۔",,,28318,,
28319,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی حَصِینٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : لاَ أَعْلَمُ لِقَاتِلِ الْمُؤْمِنِ تَوْبَۃً ، إِلاَّ الاِسْتِغْفَارُ۔",,,28319,,
28320,"حَدَّثَنَا الْفَضْلُ ، عَنِ الصَّبَّاحِ بْنِ ثَابِتٍ ، عَن عِکْرِمَۃَ ، قَالَ : لِلْقَاتِلِ تَوْبَۃٌ۔",,,28320,,
28321,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : جَائَ رَجُلٌ إِلَی عُمَرَ ، فَقَالَ : إِنِّی قَتَلْتُ ، فَہَلْ لِی مِنْ تَوْبَۃٍ ؟ قَالَ : نَعَمْ ، فَلاَ تَیْأَسْ ، وَقَرَأَ عَلَیْہِ مِنْ حم الْمُؤْمِنِ : {غَافِرِ الذَّنْبِ وَقَابِلِ التَّوْبِ شَدِیدِ الْعِقَابِ}۔",,,28321,,
28322,"حَدَّثَنَا ابْنُ سَعِیدٍ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی مِجْلَزٍ ؛ {فَجَزَاؤُہُ جَہَنَّمُ}، قَالَ : ہِیَ جَزَاؤُہُ ، فَإِنْ شَائَ أَنْ یَتَجَاوَزَ عَنْ جَزَائِہِ فَعَلَ۔",,,28322,,
28323,حَدَّثَنَا عَمْرُو بْنُ مُحَمَّدٍ ، عَنْ شُعْبَۃَ ، عَنْ سَیَّارٍ ، عَنْ أَبِی صَالِحٍ ؛ نَحْوَہُ۔,,,28323,,
28324,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَن زِیَادِ بْنِ أَبِی مَرْیَمَ ، عَنِ ابْنِ مَعْقِلٍ ، قَالَ لَہُ : أَسَمِعْتَ أَبَاک یَقُولُ : سَمِعْتُ عَبْدَ اللہِ یَقُولُ : سَمِعْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : التَّوْبَۃُ نَدَمٌ ؟ قَالَ : نَعَمْ۔\n\n(ابن ماجہ 4252۔ احمد 376)",,,28324,,
28325,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا سُفْیَانُ الثَّوْرِیُّ ، عَنْ عَبْدِ الْکَرِیمِ ، عَن زِیَادِ بْنِ أَبِی مَرْیَمَ ، عْن عَبْدِ اللہِ بْنِ مَعْقِلٍ ؛ أَنَّ أَبَاہُ مَعْقِلَ بْنَ مُقَرِّنٍ الْمُزَنِیَّ قَالَ لابْنِ مَسْعُودٍ : أَسَمِعْتَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : التَّوْبَۃُ نَدَمٌ ؟ قَالَ : نَعَمْ۔ (احمد 433)",,,28325,,
28326,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : أَخْبَرَنَا أَبُو مَالِکٍ الأَشْجَعِیُّ ، عَنْ سَعْدِ بْنِ عُبَیْدَۃَ ، قَالَ : جَائَ رَجُلٌ إِلَی ابْنِ عَبَّاسٍ فَقَالَ : لِمَنْ قَتَلَ مُؤْمِنًا تَوْبَۃٌ ؟ قَالَ : لاَ ، إِلاَّ النَّارُ ، فَلَمَّا ذَہَبَ قَالَ لَہُ جُلَسَاؤُہُ : مَا ہَکَذَا کُنْتَ تُفْتِینَا ، کُنْتَ تُفْتِینَا أَنَّ لِمَنْ قَتَلَ مُؤْمِنًا تَوْبَۃٌ مَقْبُولَۃٌ ، فَمَا بَالُ الْیَوْمِ ؟ قَالَ : إِنِّی أَحْسِبُہُ رَجُلاً مُغْضَبًا یُرِیدُ أَنْ یَقْتُلَ مُؤْمِنًا ، قَالَ : فَبَعَثُوا فِی أَثَرِہِ فَوَجَدُوہُ کَذَلِکَ۔",,,28326,,
28327,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَن مُجَالِدٍ ، عَنِ الشَّعْبِیِّ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ نَظَرَ إِلَی الْکَعْبَۃِ ، فَقَالَ : مَا أَعْظَمَ حُرْمَتَکَ ، وَمَا أَعْظَمَ حَقَّک ، وَلَلْمُسْلِمُ أَعْظَمُ حُرْمَۃً مِنْکِ ، حَرَّمَ اللَّہُ مَالَہُ ، وَحَرَّمَ دَمَہُ ، وَحَرَّمَ عِرْضَہُ وَأَذَاہُ ، وَأَنْ یُظَنَّ بِہِ ظَنَّ سوئٍ۔",,,28327,,
28328,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ یَعْلَی بْنِ عَطَائٍ ، عَنْ أَبِیہِ ، عَنْ عَبْدِ اللہِ بِنْ عَمْرٍو ، قَالَ : قَتْلُ الْمُؤْمِنِ أَعْظَمُ عِنْدَ اللہِ مِنْ زَوَالِ الدُّنْیَا۔ (ترمذی 1395۔ نسائی 3449)",,,28328,,
28329,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَن خُصَیْفٍ ، عَن مُجَاہِدٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ {فَکَأَنَّمَا قَتَلَ النَّاسَ جَمِیعًا} ، قَالَ : مَنْ أَوْبَقَہَا ، {وَمَنْ أَحْیَاہَا فَکَأَنَّمَا أَحْیَا النَّاسَ جَمِیعًا} ، قَالَ : مَنْ کَفَّ عَن قَتْلِہَا۔",,,28329,,
28330,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَن مَنْصُورٍ ، عَن مُجَاہِدٍ ؛ {وَمَنْ أَحْیَاہَا} ، قَالَ : مَنْ أَنْجَاہَا مِنْ غَرَقٍ ، أَوْ حَرْقٍ فَقَدْ أَحْیَاہَا۔",,,28330,,
28331,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الْعَلاَئُ بْنُ عَبْدِ الْکَرِیمِ ، قَالَ : سَمِعْتُ مُجَاہِدًا ، یَقُولُ : {وَمَنْ أَحْیَاہَا فَکَأَنَّمَا أَحْیَا النَّاسَ جَمِیعًا} ، قَالَ : مَنْ کَفَّ عَن قَتْلِہَا فَقَدْ أَحْیَاہَا۔",,,28331,,
28332,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی الْمِقْدَامِ ، عَن حَبَّۃَ بْنِ جُوَیْنٍ الْحَضْرَمِیِّ ، عَنْ عَلِیٍّ ؛ {رَبَّنَا أَرِنَا اللَّذَیْنِ أَضَلاَّنَا مِنَ الْجِنِّ وَالإِنْسِ} ، ابْنَ آدَمَ الَّذِی قَتَلَ أَخَاہُ ، وَإِبْلِیسَ الأَبَالِسِ۔",,,28332,,
28333,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنْ مَالِکِ بْنِ حُصَیْنٍ ، عَنْ أَبِیہِ ، عَنْ عَلِیٍّ ، قَالَ : ابْنُ آدَمَ الَّذِی قَتَلَ أَخَاہُ وَإِبْلِیسُ۔",,,28333,,
28334,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ عَبْدِ اللہِ بْنِ مُرَّۃَ ، عَن مَسْرُوقٍ ، عَنْ عَبْدِ اللہِ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تُقْتَلُ نَفْسٌ ظُلْمًا ، إِلاَّ کَانَ عَلَی ابْنِ آدَمَ الأَوَّلِ کِفْلٌ مِنْ دَمِہَا ، لأَنَّہُ أَوَّلُ مَنْ سَنَّ الْقَتْلَ۔ (بخاری 6867۔ مسلم 27)",,,28334,,
28335,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الْحَسَنُ بْنُ صَالِحٍ ، عَنْ إِبْرَاہِیمَ بْنِ الْمُہَاجِرِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : مَا مِنْ نَفْسٍ تُقْتَلُ ظُلْمًا ، إِلاَّ کَانَ عَلَی ابْنِ آدَمَ الأَوَّلِ وَالشَّیْطَانِ کِفْلٌ مِنْہَا۔",,,28335,,
28336,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ لَیْثٍ ، عَن مُجَاہِدٍ ؛ {ظَہَرَ الْفَسَادُ فِی الْبَرِّ وَالْبَحْرِ بِمَا کَسَبَتْ أَیْدِی النَّاسِ}، قَالَ: فِی الْبَرِّ ابْنُ آدَمَ الَّذِی قَتَلَ أَخَاہُ، وَفِی الْبَحْرِ الَّذِی کَانَ یَأْخُذُ کُلَّ سَفِینَۃٍ غَصْبًا۔",,,28336,,
28337,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا ہُشَیْمٌ ، عَنْ إِسْمَاعِیلَ بْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : مَنْ قَتَلَ رَجُلَیْنِ فَہُوَ جَبَّارٌ ، وَتَلاَ: {أَتُرِیدُ أَنْ تَقْتُلَنِی کَمَا قَتَلْت نَفْسًا بِالأَمْسِ، إِنْ تُرِیدُ إِلاَّ أَنْ تَکُونَ جَبَّارًا} الآیۃ۔",,,28337,,
28338,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : مَا کَانَ مِنْ قَتْلٍ بِسِلاَحٍ عَمْدٍ ، فَفِیہِ الْقَوَدُ۔",,,28338,,
28339,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، قَالَ : قَالَ عَلِیٌّ : الْعَمْدُ کُلُّہُ قَوَدٌ۔",,,28339,,
28340,"حَدَّثَنَا عَبْدُالرَّحِیمِ، عَنْ أَشْعَثَ، عَنْ عَامِرٍ، وَالْحَسَنِ، وَابْنِ سِیرِینَ، وَعَمْرِو بْنِ دِینَارٍ، قَالُوا: الْعَمْدُ قَوَدٌ۔",,,28340,,
28341,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ إِسْمَاعِیلَ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، عَن طَاوُوسٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْعَمْدُ قَوَدٌ ، إِلاَّ أَنْ یَعْفُوَ وَلِیُّ الْمَقْتُولِ۔ (ابوداؤد 4527۔ نسائی 6992)",,,28341,,
28342,"حَدَّثَنَا حَفْصٌ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ، وَالْحَکَمِ ، وَحَمَّادٍ ، قَالُوا : مَا کَانَ مِنْ ضَرْبَۃٍ بِسَوْطٍ ، أَوْ عَصًا ، أَوْ حَجَرٍ ، فَکَانَ دُونَ النَّفْسِ ، فَہُوَ عَمْدٌ ، وَفِیہِ الْقَوَدُ۔",,,28342,,
28343,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : إِذَا اجْتَمَعَ رَجُلٌ وَغُلاَمٌ عَلَی قَتْلِ رَجُلٍ ، قُتِلَ الرَّجُلُ ، وَعَلَی عَاقِلَۃِ الْغُلاَمِ الدِّیَۃُ کَامِلَۃً۔",,,28343,,
28344,"حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، قَالَ ، سُئِلَ حَمَّادٌ عَنْ رَجُلٍ وَصَبِیٍّ قَتَلاَ رَجُلاً عَمْدًا ؟ قَالَ : أَمَّا الرَّجُلُ یُقْتَلُ ، وَأَمَّا الصَّبِیُّ فَعَلَی أَوْلِیَائِہِ حِصَّتَۃُ مِنَ الدِّیَۃِ۔",,,28344,,
28345,"حَدَّثَنَا مُحَمَّدُ بْنُ سَوَائٍ ، عَنْ سَعِیدٍ ، عَن حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا أَعَانَہُ مَنْ لاَ یُقَادُ بِہِ ، فَإِنَّمَا ہِیَ دِیَۃٌ۔",,,28345,,
28346,"حَدَّثَنَا حَفْصٌ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ، قَالَ : إِذَا اجْتَمَعَ صَبِیٌّ وَعَبْدٌ عَلَی قَتْلٍ فَہِیَ دِیَۃٌ ، فَإِذَا اجْتَمَعَا ، فَضَرَبَ ہَذَا بِسَیْفٍ وَہَذَا بِعَصًا ، فَہِیَ دِیَۃٌ۔",,,28346,,
28347,"حَدَّثَنَا یَزِیدُ ، قَالَ : أَخبَرَنَا ہِشَامٌ ، عَنِ الْحَسَنِ ؛ فِی الْقَوْمِ یَقْتُلُونَ عَمْدًا ، وَفِیہِمُ الصَّبِیُّ وَالْمَعْتُوہُ ، قَالَ ، ہِیَ دِیَۃُ خَطَأٍ عَلَی الْعَاقِلَۃِ۔",,,28347,,
28348,"حَدَّثَنَا مُحَمَّدُ بْنُ یَزِیدَ ، عَنْ أَبِی الْعَلاَئِ ، عَنْ أَبِی ہَاشِمٍ ، عَنْ إِبْرَاہِیمَ (ح) وَعَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، قَالا فِی رَجُلٍ قُتِلَ عَمْدًا ، فَحُبِسَ الْقَاتِلُ لِیُقَادَ بِالْمَقْتُولِ ، فَجَائَ رَجُلٌ فَقَتَلَ الْقَاتِلَ خَطَأً ، فقَالا : دِیَتُہُ لأَہْلِ الْمَحْبُوسِ ، وَقَالَ عَطَائٌ : لأَہْلِ الْمَقْتُولِ الأَوَّلِ۔",,,28348,,
28349,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ قَتَادَۃَ ، عَنْ الْحَسَنِ ، قَالَ : الدِّیَۃُ لأَہْلِ الْمَقْتُولِ۔",,,28349,,
28350,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حَمَّادٍ ، مِثْلَ قَوْلِ الْحَسَنِ۔,,,28350,,
28351,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ قُتِلَ وَلَہُ وَلَدٌ صِغَارٌ ، قَالَ : ذَاکَ إِلَی أَوْلِیَائِہِ۔",,,28351,,
28352,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، قَالَ : سَمِعْتُ حَمَّادًا یَقُولُ فِی رَجُلٍ قُتِلَ ، وَبَعْضُ أَوْلِیَائِہِ صِغَارٌ ، قَالَ : یَقْتُلُ أَوْلِیَاؤُہُ الْکِبَارُ إِنْ شَاؤُوا ، وَلاَ یَنْتَظِرُوا۔",,,28352,,
28353,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حُسَیْنٍ ، عَنْ زَیْدٍ ، عَنْ بَعْضِ أَہْلِہِ ؛ أَنَّ الْحَسَنَ بْنَ عَلِیٍّ قَتَلَ ابْنَ مُلْجِمٍ الَّذِی قَتَلَ عَلِیًّا ، وَلَہُ وَلَدٌ صِغَارٌ۔,,,28353,,
28354,"حَدَّثَنَا قَبِیصَۃُ ، عَنْ سُفْیَانَ ، عَن خَالِدٍ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : یُسْتَأْنَی بِہِ حَتَّی یَکْبُرُوا۔",,,28354,,
28355,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ حَجَّاجٍ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، عَن نَافِعِ بْنِ عَبْدِ الْحَارِثِ ، قَالَ : کَتَبْتُ إِلَی عُمَرَ أَسْأَلُہُ عَنْ رَجُلٍ کُسِرَ أَحَدُ زَنْدَیْہِ ؟ فَکَتَبَ إِلَیَّ عُمَرُ : أَنَّ فِیہِ حِقَّتَیْنِ بَکْرَتَیْنِ۔",,,28355,,
28356,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ ابْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ، عَن زَیْدِ بْنِ ثَابِتٍ ، قَالَ : فِی السَّاعِدَیْنِ ، وَہُمَا الزَّنْدَانِ خَمْسُونَ دِینَارًا۔",,,28356,,
28357,"حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : لاَ یُقْتَصُّ لِمَجْرُوحٍ حَتَّی تَبْرَأَ جِرَاحُہُ۔",,,28357,,
28358,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : لاَ یُقْتَصُّ مِنَ الْجَارِحِ حَتَّی یَبْرَأَ صَاحِبُ الْجُرْحِ۔",,,28358,,
28359,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : یُنْتَظَرُ بِالْقَوَدِ أَنْ یَبْرَأَ صَاحِبُہُ۔",,,28359,,
28360,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، عَنْ جَابِرٍ ؛ أَنَّ رَجُلاً طَعَنَ رَجُلاً بِقَرْنٍ فِی رُکْبَتِہِ ، فَأَتَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَسْتَقِیدُ ، فَقِیلَ لَہُ : حتَّی تَبْرَأَ ، فَأَبَی وَعَجَّلَ وَاسْتَقَادَ ، قَالَ : فَعَنِتَتْ رِجْلُہُ وَبَرِئَتْ رِجْلُ الْمُسْتَقَادِ مِنْہُ ، فَأَتَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : لَیْسَ لَکَ شَیْئٌ ، أَبَیْتَ۔\n\n(دارقطنی 89۔ احمد 217)",,,28360,,
28361,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، قَالَ: سَأَلْتُ الْحَکَمَ، وَحَمَّادًا عَنِ الرَّجُلِ یَأْمُرُ الرَّجُلَ یَقْتُلُ الرَّجُلَ؟ قَالاَ : یُقْتَلُ الْقَاتِلُ ، وَلَیْسَ عَلَی الآمِرِ قَوَدٌ۔",,,28361,,
28362,"حَدَّثَنَا وَکِیعٌ ، قَالَ: حدَّثَنَا سُفْیَانُ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ؛ فِی رَجُلٍ أَمَرَ عَبْدَہُ فَقَتَلَ رَجُلاً عَمْدًا؟ قَالَ: یُقْتَلُ الْعَبْدُ۔",,,28362,,
28363,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ صَالِحٍ ، عَن مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ؛ فِی الرَّجُلِ یَأْمُرُ الرَّجُلَ فَیَقْتُلُ ، قَالَ : ہُمَا شَرِیکَانِ۔\n\nقَالَ وَکِیعٌ : ہَذَا عَندَنَا فِی الإِثْمِ ، فَأَمَّا الْقَوَدُ فَإِنَّمَا ہُوَ عَلَی الْقَاتِلِ۔",,,28363,,
28364,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سُفْیَانَ ، عَن مَنْصُورٍ ، قَالَ : سَأَلْتُ إِبْرَاہِیمَ عَن أَمِیرٍ أَمَرَ رَجُلاً فَقَتَلَ رَجُلاً ؟ قَالَ : ہُمَا شَرِیکَانِ فِی الإِثْمِ۔",,,28364,,
28365,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سَلَمَۃُ بْنُ نُبَیْطٍ ، عَنِ الضَّحَّاکِ بْنِ مُزَاحِمٍ ؛ فِی السُّلْطَانِ یَأْمُرُ الرَّجُلَ یَقْتُلُ الرَّجُلَ ؟ فَقَالَ الضَّحَّاکُ : کُنْ أَنْتَ الْمَقْتُولُ۔",,,28365,,
28366,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ، عَنْ أَشْعَثَ، عَنِ الْحَسَنِ؛ فِی الرَّجُلِ یَأْمُرُ عَبْدَہُ یَقْتُلُ الرَّجُلَ؟ قَالَ: یُقْتَلُ الرَّجُلُ۔",,,28366,,
28367,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ قَتَادَۃَ ، عَن خِلاَسٍ ، عَنْ عَلِیٍّ ؛ فِی رَجُلٍ أَمَرَ عَبْدَہُ أَنْ یَقْتُلَ رَجُلاً ؟ قَالَ : إِنَّمَا ہُوَ بِمَنْزِلَۃِ سَوْطِہِ ، أَوْ سَیْفِہِ۔",,,28367,,
28368,"حَدَّثَنَا عُمَرُ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، عَنْ أَبِی ہُرَیْرَۃَ ؛ فِی الرَّجُلِ یَأْمُرُ عَبْدَہُ فَیَقْتُلُ رَجُلاً ، قَالَ : یُقْتَلُ الْمَوْلَی۔",,,28368,,
28369,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنِ الْقَاسِمِ ، عَن عُبَیْدِ بْنِ عُمَیْرٍ ؛ أَنَّ رَجُلاً أَضَافَ إِنْسَانًا مِنْ ہُذَیْلٍ ، فَذَہَبَتْ جَارِیَۃٌ مِنْہُمْ تَحْتَطِبُ ، فَأَرَادَہَا عَلَی نَفْسِہَا ، فَرَمَتْہُ بِفِہْرٍ فَقَتَلَتْہُ ، فَرُفِعَ إِلَی عُمَرَ بْنِ الْخَطَّابِ ، قَالَ : ذَلِکَ قَتِیلُ اللہِ ، لاَ یُودَی أَبَدًا۔",,,28369,,
28370,"حَدَّثَنَا حَفْصٌ ، عَنْ مُحَمَّدِ بْنِ یُوسُفَ ، عَنِ السَّائِبِ بْنِ یَزِیدَ ؛ أَنَّ رَجُلاً أَرَادَ امْرَأَۃً عَلَی نَفْسِہَا ، فَرَفَعَتْ حَجَرًا فَقَتَلَتْہُ ، فَرُفِعَ ذَلِکَ إِلَی عُمَرَ ، فَقَالَ : ذَاکَ قَتِیلُ اللہِ۔",,,28370,,
28371,حَدَّثَنَا عَائِذُ بْنُ حَبِیبٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَن سُلَیْمَانَ بْنِ یَسَارٍ ؛ أَنَّ امْرَأَۃً بِالشَّامِ أَتَتِ الضَّحَّاکَ بْنَ قَیْسٍ ، فَذَکَرَتْ لَہُ أَنَّ إِنْسَانًا اسْتَفْتَحَ عَلَیْہَا بَابَہَا ، وَأَنَّہَا اسْتَغَاثَتْ فَلَمْ یُغِثْہَا أَحَدٌ ، وَکَانَ الشِّتَائُ ، فَفَتَحَتْ لَہُ الْبَابَ ، وَأَخَذَتْ رَحًی فَرَمَتْہُ بِہَا فَقَتَلَتْہُ ، فَبَعَثَ مَعَہَا ، وَإِذَا لِصٌّ مِنَ اللُّصُوصِ ، وَإِذَا مَعَہُ مَتَاعٌ فَأَبْطَلَ دَمَہُ۔,,,28371,,
28372,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ إِسْمَاعِیلَ بْنِ أُمَیَّۃَ ، قَالَ : قَضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی رَجُلٍ أَمْسَکَ رَجُلاً وَقَتَلَہُ آخَرُ ، أَنْ یُقْتَلَ الْقَاتِلُ ، وَیُحْبَسَ الْمُمْسِکُ۔ (دارقطنی 140۔ بیہقی 50)",,,28372,,
28373,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا سُفْیَانُ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، عَنْ عَلِیٍّ ؛ أَنَّہُ قَضَی بِقَتْلِ الْقَاتِلِ ، وَبِحَبْسِ الْمُمْسِکِ۔ (عبدالرزاق 18089)",,,28373,,
28374,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، قَالَ : سَأَلْتُ الْحَکَمَ ، وَحَمَّادًا عَنِ الرَّجُلِ یُمْسِکُ الرَّجُلَ ، وَیَقْتُلُہُ آخَرُ ؟ قَالاَ : یُقْتَلُ الْقَاتِلُ۔",,,28374,,
28375,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : سَمِعْتُ سُلَیْمَانَ بْنَ مُوسَی یَقُولُ : الاِجْتِمَاعُ فِینَا عَلَی الْمَقْتُولِ أَنْ یُمْسِکَ الرَّجُلَ ، وَیَضْرِبَہُ الآخَرُ ، فَہُمَا شَرِیکَانِ عَندَنَا فِی دَمِہِ ، یُقْتَلاَنِ جَمِیعًا۔",,,28375,,
28376,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ؛ أَنَّ عَلِیًّا أُتِیَ بِرَجُلَیْنِ قَتَلَ أَحَدُہُمَا، وَأَمْسَکَ الآخَرُ ، فَقَتَلَ الَّذِی قَتَلَ ، وَقَالَ لِلَّذِی أَمْسَکَ : أَمْسَکْتَہُ لِلْمَوْتِ ، فَأَنَا أَحْبِسُکَ فِی السِّجْنِ حَتَّی تَمُوتَ۔",,,28376,,
28377,حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی ذِئْبٍ ؛ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ أَمَرَ أَنْ تُعْقَلَ الْمُوضِحَۃَ۔,,,28377,,
28378,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عن رَجُلٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : لاَ تَعْقِلُ الْعَاقِلَۃُ ، إِلاَّ الثُّلُثُ فَمَا زَادَ۔",,,28378,,
28379,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ عُمَرَ بْنِ عَبْدِ الرَّحْمَنِ السَّہْمِیِّ ، عَنْ رَجُلٍ ؛ أَنَّ رَجُلاً أَتَی عُمَرَ بْنَ الْخَطَّابِ فِی مُوضِحَۃٍ ؟ فَقَالَ : إِنَّا لاَ نَتَعَاقَلُ الْمُضَغَ بَیْنَنَا۔",,,28379,,
28380,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عِیسَی ، عَنِ الشَّعْبِیِّ ، قَالَ : لَیْسَ فِیمَا دُونَ الْمُوضِحَۃِ عَقْلٌ۔",,,28380,,
28381,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : مَتَی یَبْلُغُ الْعَقْلُ أَنْ تَعْقِلَہُ الْعَاقِلَۃُ عَامَّۃً أَجْمَعُونَ، إِذَا بَلَغَ الثُّلُثَ؟ قَالَ: نَعَمْ، إِخَالُ، وَلاَ أَشُکَّ أَنَّہُ قَالَ: وَمَا لَمْ یَبْلُغِ الثُّلُثَ فَعَلَی قَوْمِ الرَّجُلِ خَاصَّۃً۔",,,28381,,
28382,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ عَبْدِ اللہِ بْنِ مُؤَمِّلٍ ، قَالَ : حدَّثَنِی عُمَرُ بْنُ عَبْدِ الرَّحْمَنِ السَّہْمِیُّ ، عَنْ عَطَائِ بْنِ أَبِی رَبَاحٍ ، عَنْ أَبِی أُمَیَّۃَ الأَخْنَسِ ، قَالَ : کُنْتُ عِندَ عُمَرَ بْنِ الْخَطَّابِ جَالِسًا ، فَجَائَ رَجُلٌ مِنْ بَنِی غِفَارٍ ، فَقَالَ : إِنَّ ابْنِی شُجَّ ، فَقَالَ : إِنَّ ہَذِہِ الْمُضَغ لاَ یَتَعَاقَلُہَا أَہْلُ الْقُرَی۔",,,28382,,
28383,"حَدَّثَنَا أَبُو مُحَمَّدٍ عَبْدُاللہِ بْنُ یُونُسَ، قَالَ: حدَّثَنَا أَبُو عَبْدِالرَّحْمَنِ بَقِیُّ بْنُ مَخْلَدٍ، قَالَ: حدَّثَنَا أَبُو بَکْرٍ، قَالَ:\n\n حَدَّثَنَا عَبْدُ الأَعْلَی بْنِ عَبْدِ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّ الْقَسَامَۃَ کَانَتْ فِی الْجَاہِلِیَّۃِ ، فَأَقَرَّہَا النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی قَتِیلٍ مِنَ الأَنْصَارِ وُجِدَ فِی جُبٍّ لِلْیَہُودِ ، قَالَ: فَبَدَأَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِالْیَہُودِ ، فَکَلَّفَہُمْ قَسَامَۃً خَمْسِینَ ، فَقَالَتِ الْیَہُودُ : لَنْ نَحْلِفَ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لِلأَنْصَارِ : أَفَتَحْلِفُونَ ؟ فَأَبَتِ الأَنْصَارُ أَنْ تَحْلِفَ ، فَأَغْرَمَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْیَہُودَ دِیَتَہُ ، لأَنَّہُ قُتِلَ بَیْنَ أَظْہُرِہِمْ۔ (مسلم 1295۔ نسائی 6911)",,,28383,,
28384,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : دَعَانِی عُمَرُ بْنُ عَبْدِ الْعَزِیزِ فَسَأَلَنِی عَنِ الْقَسَامَۃِ؟ فَقَالَ: قَدْ بَدَا لِی أَنْ أَرُدَّہَا ، إِنَّ الأَعْرَابِیَّ یَشْہَدُ ، وَالرَّجُلُ الْغَائِبُ یَجِیئُ فَیَشْہَدُ، فَقُلْتُ: یَا أَمِیرَ الْمُؤْمِنِینَ، إِنَّک لَنْ تَسْتَطِیعَ رَدَّہَا ، قَضَی بِہَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَالْخُلَفَائُ بَعْدَہُ۔",,,28384,,
28385,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ، قَالَ: حدَّثَنَا سَعِیدٌ، عَنْ قَتَادَۃَ؛ أَنَّ سُلَیْمَانَ بْنَ یَسَارٍ حَدَّث؛ أَنَّ عُمَرَ بْنَ عَبْدِالْعَزِیزِ، قَالَ: مَا رَأَیْتُ مِثْلَ الْقَسَامَۃِ قَطُّ أُقَیِّدُ بِہَا ، وَاللَّہُ یَقُولُ : {وَأَشْہِدُوا ذَوَیْ عَدْلٍ مِنْکُمْ} ، وَقَالَتِ الأَسْبَاطُ: {وَمَا شَہِدْنَا إِلاَّ بِمَا عَلِمْنَا وَمَا کُنَّا لِلْغَیْبِ حَافِظِینَ} ، وَقَالَ اللَّہُ : {إِلاَّ مَنْ شَہِدَ بِالْحَقِّ وَہُمْ یَعْلَمُونَ}۔\n\nوَقَالَ سُلَیْمَانُ بْنُ یَسَارٍ : الْقَسَامَۃُ حَقٌّ ، قَضَی بِہَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، بَیْنَمَا الأَنْصَارُ عِندَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إِذْ خَرَجَ رَجُلٌ مِنْہُمْ ، ثُمَّ خَرَجُوا مِنْ عِندِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَإِذَا ہُمْ بِصَاحِبِہِمْ یَتَشَحَّطُ فِی دَمِہِ ، فَرَجَعُوا إِلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالُوا : قَتَلَتْنَا الْیَہُودُ ، وَسَمَّوْا رَجُلاً مِنْہُمْ ، وَلَمْ تَکُنْ لَہُمْ بَیِّنَۃٌ ، فَقَالَ لَہُمْ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : شَاہِدَانِ مِنْ غَیْرِکُمْ حَتَّی أَدْفَعَہُ إِلَیْکُمْ بِرُمَّتِہِ ، فَلَمْ تَکُنْ لَہُمْ بَیِّنَۃٌ ، فَقَالَ : اسْتَحِقُّوا بِخَمْسینَ قَسَامَۃٍ أَدْفَعَہُ إِلَیْکُمْ بِرُمَّتِہِ ، فَقَالُوا : یَا رَسُولَ اللہِ ، إِنَّا نَکْرَہُ أَنْ نَحْلِفَ عَلَی غَیْبٍ ، فَأَرَادَ نَبِیُّ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یَأْخُذَ قَسَامَۃَ الْیَہُودِ بِخَمْسِینَ مِنْہُمْ، فَقَالَتِ الأَنْصَارُ: یَا رَسُولَ اللہِ ، إِنَّ الْیَہُودَ لاَ یُبَالُونَ الْحَلِفَ، مَتَی مَا نَقْبَلُ ہَذَا مِنْہُمْ یَأْتُونَا عَلَی آخِرِنَا، فَوَدَاہُ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِنْ عِندِہِ۔ (بیہقی 16371)",,,28385,,
28386,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ؛ أَنَّ حُوَیِّصَۃَ ، وَمُحَیِّصَۃَ ابْنَیْ مَسْعُودٍ، وَعَبْدَ اللہِ ، وَعَبْدَ الرَّحْمَن ابْنَیْ فُلاَنٍ خَرَجُوا یَمْتَارُونَ بِخَیْبَرَ ، فَعُدِیَ عَلَی عَبْدِاللہِ ، فَقُتِلَ، قَالَ : فَذُکِر ذَلِکَ لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : تُقْسِمُونَ بِخَمْسِین فَتَسْتَحِقُّونَ ، قَالُوا : یَا رَسُولَ اللہِ ، کَیْفَ نُقْسِمُ وَلَمْ نَشْہَدْ ؟ قَالَ : فَتُبَرِّئُکُمْ یَہُودُ ، یَعْنِی یَحْلِفُونَ ، قَالَ : فَقَالُوا : یَا رَسُولَ اللہِ ، إِذًا تَقْتُلُنَا الْیَہُودُ ، قَالَ : فَوَدَاہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِنْ عِندِہِ۔\n\n(ابن ماجہ 2678۔ نسائی 6922)",,,28386,,
28386,"قَالَ أبو خالد : أَخْبَرَنِی یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ یَسَارٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ نَحْوَ ہَذَا ، إِلاَّ أَنَّہُ قَالَ : ذَہَبَ عَبْدُ الرَّحْمَنِ أَخُو الْمَقْتُولِ یَتَکَلَّمُ ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْکُبْرَ الْکُبْرَ ، قَالَ: فَتَکَلَّمَ الْکُبْر ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : تُقْسِمُونَ بِخَمْسِینَ یَمِینًا فَتَسْتَحِقُّونَ، أَوْ تُقْسِمُ لَکُمْ بِخَمْسِینَ ؟ قَالَ : فَقَالُوا : یَا رَسُولَ اللہِ ، کَیْفَ نَقْبَلُ أَیْمَانَ قَوْمٍ کُفَّارٍ ؟ قَالَ : فَوَدَاہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِنْ عِندِہِ۔",,,28386,,
28387,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الْمَسْعُودِیُّ ، عَنِ الْقَاسِمِ بْنِ عَبْدِ الرَّحْمَنِ ، قَالَ : انْطَلَقَ رَجُلاَنِ مِنْ أَہْلِ الْکُوفَۃِ إِلَی عُمَرَ بْنِ الْخَطَّابِ ، فَوَجَدَاہُ قَدْ صَدَرَ عَنِ الْبَیْتِ عَامِدًا إِلَی مِنًی ، فَطَافَا بِالْبَیْتِ ، ثُمَّ أَدْرَکَاہُ فَقَصَّا عَلَیْہِ قِصَّتَہُمَا ، فَقَالاَ : یَا أَمِیرَ الْمُؤْمِنِینَ ، إِنَّ ابْنَ عَمٍّ لَنَا قُتِلَ ، نَحْنُ إِلَیْہِ شَرَعٌ سَوَائٌ فِی الدَّمِ ، وَہُوَ سَاکِتٌ عَنہُمَا لاَ یَرْجِعُ إِلَیْہِمَا شَیْئًا ، حَتَّی نَاشَدَاہُ اللَّہَ فَحَمَلَ عَلَیْہِمَا ، ثُمَّ ذَکَّرَاہُ اللَّہَ فَکَفَّ عَنہُمَا ، ثُمَّ قَالَ عُمَرُ : وَیْلٌ لَنَا إِذَا لَمْ نُذَکَّرْ بِاللَّہِ ، وَوَیْلٌ لَنَا إِذَا لَمْ نَذْکُرِ اللَّہَ ، فِیکُمْ شَاہِدَانِ ذَوَا عَدْلٍ تَجِیئَانِ بِہِمَا عَلَی مَنْ قَتَلَہُ فَنُقِیدُکُمْ مِنْہُ ، وَإِلاَّ حَلَفَ مَنْ یَدْرَؤکُمْ بِاللَّہِ : مَا قَتَلْنَا ، وَلاَ عَلِمْنَا قَاتِلاً ، فَإِنْ نَکَلُوا حَلَفَ مِنْکُمْ خَمْسُونَ ، ثُمَّ کَانَتْ لَکُمُ الدِّیَۃُ۔",,,28387,,
28388,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی إِسْحَاقَ ؛ أَنَّ قَتِیلاً وُجِدَ فِی بَنِی سَلُولَ ، فَجَائَ الأَوْلِیَائُ فَأَبْرَؤُوا بَنِی سَلُولَ، وَادَّعُوا عَلَی حَیٍّ آخَرَ، وَأَتَوْا شُرَیْحًا بِبَنِی سَلُولَ، فَسَأَلَہُمُ الْبَیِّنَۃَ عَلَی الْمُدَّعَی عَلَیْہِمْ۔",,,28388,,
28389,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا وُجِدَ قَتِیلٌ فِی حَیٍّ ، أُخِذَ مِنْہُم خَمْسُونَ رَجُلاً فِیہِمُ الْمُدَّعَی عَلَیْہِ، وَإِنْ کَانُوا أَقَلَّ مِنْ خَمْسِینَ رُدَّتْ عَلَیْہِمُ الأَیْمَانُ، الأَوَّلُ فَالأَوَّلُ۔",,,28389,,
28390,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إِسْرَائِیلُ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ بْنِ الأَزْمَعِ ، قَالَ : وُجِدَ قَتِیلٌ بِالْیَمَنِ بَیْنَ وَادِعَۃَ وَأَرْحَبَ ، فَکَتَبَ عَامِلُ عُمَرَ بْنِ الْخَطَّابِ إِلَیْہِ ، فَکَتَبَ إِلَیْہِ عُمَرُ : أَنْ قِسْ مَا بَیْنَ الْحَیَّیْنِ، فَإِلَی أَیِّہِمَا کَانَ أَقْرَبَ فَخُذْہُمْ بِہِ ، قَالَ : فَقَاسُوا ، فَوَجَدُوہُ أَقْرَبَ إِلَی وَادِعَۃَ ، قَالَ : فَأَخَذْنَا، وَأَغْرَمْنَا ، وَأَحْلَفْنَا ، فَقُلْنَا : یَا أَمِیرَ الْمُؤْمِنِینَ ، أَتُحَلِّفُنَا وَتُغَرِّمُنَا ؟ قَالَ : نَعَمْ ، قَالَ : فَأَحْلَفَ مِنَّا خَمْسِینَ رَجُلاً بِاللَّہِ مَا فَعَلْتُ ، وَلاَ عَلِمْتُ قَاتِلاً۔",,,28390,,
28391,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ أَبِی لَیْلَی ، عَنِ الشَّعْبِیِّ ؛ أَنَّ قَتِیلاً وُجِدَ بِالْیَمَنِ بَیْنَ حَیَّیْنِ ، قَالَ : فَقَالَ عُمَرُ : انْظُرُوا أَقْرَبَ الْحَیَّیْنِ إِلَیْہِ ، فَأَحْلِفُوا مِنْہُمْ خَمْسِینَ رَجُلاً بِاللَّہِ مَا قَتَلْنَا ، وَلاَ عَلِمْنَا قَاتِلاً ، ثُمَّ یَکُونُ عَلَیْہِمُ الدِّیَۃُ۔",,,28391,,
28392,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ؛ أَنَّ الزُّہْرِیِّ سُئِلَ عَن قَتِیلٍ وُجِدَ فِی دَارِ رَجُلٍ ، فَقَالَ رَبُّ الدَّارِ : إِنَّہُ طَرَقَنِی لِیَسْرِقَنِی فَقَتَلْتہ ، وَقَالَ أَہْلُ الْقَتِیلِ : إِنَّہُ دَعَاہُ إِلَی بَیْتِہِ فَقَتَلَہُ ، فَقَالَ : إِنْ أَقْسَمَ مِنْ أَہْلِ الْقَتِیلِ خَمْسُونَ أَنَّہُ دَعَاہُ فَقَتَلَہُ ، أُقِیدَ بِہِ ، وَإِنْ نَکَلُوا غَرِمُوا الدِّیَۃَ ، قَالَ الزُّہْرِیُّ : فَقَضَی ابْنُ عَفَّانَ فِی قَتِیلٍ مِنْ بَنِی بَاقِرِۃِ أَبَی أَوْلِیَاؤُہُ أَنْ یَحْلِفُوا ، فَأَغْرَمَہُم عُثْمَانُ الدِّیَۃَ۔",,,28392,,
28393,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَن یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی الْقَتِیلِ یُؤْخَذُ غِیلَۃً ، قَالَ : یُقْسِمُ مِنَ الْمُدَّعَی عَلَیْہِمْ خَمْسُونَ خَمْسِینَ یَمِینًا : مَا قَتَلْنَا ، وَلاَ عَلِمْنَا قَاتِلاً ، فَإِنْ حَلَفُوا فَقَدْ بَرِئُوا ، وَإِنْ نَکَلُوا أَقْسَمَ مِنَ الْمُدَّعِینَ خَمْسُونَ : أَنَّ دَمَنَا قِبَلَکُمْ ، ثُمَّ یُودَی۔",,,28393,,
28394,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ؛ فِی الْقَسَامَۃِ : لَمْ یَزَلْ یُعْمَلُ بِہَا فِی الْجَاہِلِیَّۃِ وَالإِسْلاَمِ۔",,,28394,,
28395,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ سَعِیدِ بْنِ عُبَیْدٍ ، عَن بُشَیْرِ بْنِ یَسَارٍ ؛ زَعَمَ أَنَّ رَجُلاً مِنَ الأَنْصَارِ یُقَالُ لَہُ: سَہْلُ بْنُ أَبِی حَثْمَۃَ أَخْبَرَہُ ؛ أَنَّ نَفَرًا مِنْ قَوْمِہِ انْطَلَقُوا إِلَی خَیْبَرَ ، فَتَفَرَّقُوا فِیہَا ، فَوَجَدُوا أَحَدَہُمْ قَتِیلاً ، فَقَالُوا لِلَّذِینَ وَجَدُوہُ عِنْدَہُمْ : قَتَلْتُمْ صَاحِبَنَا ، قَالُوا : مَا قَتَلْنَا ، وَلاَ عَلِمْنَا ، فَانْطَلَقُوا إِلَی نَبِیِّ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالُوا : یَا نَبِیَّ اللہِ ، انْطَلَقْنَا إِلَی خَیْبَرَ فَوَجَدْنَا أَحَدَنَا قَتِیلاً ، قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: الْکُبْرَ الْکُبْرَ، فَقَالَ لَہُمْ: تَأْتُونَ بِالْبَیِّنَۃِ عَلَی مَنْ قَتَلَ ، فَقَالُوا : مَا لَنَا بَیِّنَۃٌ ، قَالَ : فَیَحْلِفُونَ لَکُمْ ، قَالُوا: لاَ نَرْضَی بِأَیْمَانِ الْیَہُودِ ، فَکَرِہَ نَبِیُّ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یُبْطِلَ دَمَہُ ، فَوَدَاہُ بِمِئَۃٍ مِنْ إِبِلِ الصَّدَقَۃِ۔",,,28395,,
28396,حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَضَی فِی الْقَسَامَۃِ أَنَّ الْیَمِینَ عَلَی الْمُدَّعَی عَلَیْہِمْ۔ (بخاری 6898),,,28396,,
28397,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی عُبَیْدُ اللہِ بْنُ عُمَرَ ، أَنَّہُ سَمِعَ أَصْحَابًا لَہُمْ یُحَدِّثُونَ ؛ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ بَدَّأَ الْمُدَّعَی عَلَیْہِمْ بِالْیَمِینِ ، ثُمَّ ضَمَّنَہُمُ الْعَقْلَ۔",,,28397,,
28398,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَن مُطِیعٍ ، عَن فُضَیْلِ بْنِ عَمْرٍو ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ قَضَی بِالْقَسَامَۃِ عَلَی الْمُدَّعَی عَلَیْہِمْ۔,,,28398,,
28399,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّہُ کَانَ یَرَی الْقَسَامَۃَ عَلَی الْمُدَّعَی عَلَیْہِمْ۔,,,28399,,
28400,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ؛ قضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِالْقَسَامَۃِ عَلَی الْمُدَّعَی عَلَیْہِمْ۔,,,28400,,
28401,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لابْنِ شِہَابٍ : الْقَسَامَۃُ فِی الدَّمِ عَلَی الْعِلْمِ ، أَمْ عَلَی الْبَتَّۃِ ؟ قَالَ : عَلَی الْبَتَّۃِ۔",,,28401,,
28402,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ، عَنْ شُرَیْحٍ ؛ أَنَّہُ قَالَ فِی الْقَسَامَۃِ : أُؤَثّمہُمْ وَأَنَا أَعْلَمُ ، یَعْنِی أَسْتَحْلِفُہُمْ : مَا قَتَلْنَا ، وَلاَ عَلِمْنَا قَاتِلاً۔",,,28402,,
28403,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہ ، عَنْ إِبْرَاہِیمَ ، قَالَ : یُسْتَحْلفُ کُلُّ رَجُلٍ مِنْہُمْ بِاللَّہِ: مَا قَتَلْتُ ، وَلاَ عَلِمْتُ قَاتِلاً ، ثُمَّ یَدِیہِ۔",,,28403,,
28404,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ، قَالَ : وُجِدَ قَتِیلٌ بِالْیَمَنِ فِی وَادِعَۃَ ، فَرُفِعَ إِلَی عُمَرَ فَأَحْلَفَہُمْ بِخَمْسِینَ : مَا قَتَلْنَا ، وَلاَ عَلِمْنَا قَاتِلاً ، ثُمَّ وَدَاہُ۔",,,28404,,
28405,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ، عَنْ ہِشَامٍ، عَنِ الْحَسَنِ، قَالَ: یُسْتَحْلفُ عَنِ الْقَسَامَۃِ بِاللَّہِ: مَا قَتَلْنَا، وَلاَ عَلِمْنَا قَاتِلاً۔",,,28405,,
28406,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَمُحَمَّدٍ ؛ أَنَّ شُرَیْحًا اسْتَحْلَفَہُمْ بِاللَّہِ : مَا قَتَلْنَا ، وَلاَ عَلِمْنَا قَاتِلاً۔",,,28406,,
28407,حَدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ؛ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ ، وَابْنَ الزُّبَیْرِ أَقَادَا بِالْقَسَامَۃِ۔,,,28407,,
28408,"حَدَّثَنَا عَبْد الأَعَلَی ، عَنْ مَعْمَر ، عَنِ الزہری ؛ أَنَّہُ کَانَ یَقُولُ : إِنَّ الْقَسَامَۃ یُقَادُ بِہَا۔",,,28408,,
28409,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الْمَسْعُودِیُّ ، عَنِ الْقَاسِمِ ، قَالَ : قَالَ عُمَرُ : إِنَّ الْقَسَامَۃَ إِنَّمَا تُوجِبُ الْعَقْلَ، وَلاَ تُشِیطُ الدَّمَ۔",,,28409,,
28410,حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ؛ أَنَّ أَبَا بَکْرٍ ، وَعُمَرَ ، وَالْجَمَاعَۃَ الأُولَی لَمْ یَکُونُوا یَقْتُلُونَ بِالْقَسَامَۃِ۔,,,28410,,
28411,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنِ الْحَسَنِ بْنِ عَمْرٍو ، عَنْ فُضَیْلٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : الْقَوَدُ بِالْقَسَامَۃِ جَوْرٌ۔",,,28411,,
28412,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ، قَالَ: حدَّثَنَا سَعِیدٌ، عَنْ قَتَادَۃَ، قَالَ: الْقَسَامَۃُ یَسْتَحِقُّونَ بِہَا الدِّیَۃَ، وَلاَ یُقَادُ بِہَا۔",,,28412,,
28413,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا سَعِیدٌ ، قَالَ : حَدَّثَنَا أَبُو مَعْشَرٍ ، عَنِ النَّخَعِیّ ،ِ قَالَ : الْقَسَامَۃُ یُسْتَحَقُّ بِہَا الدِّیَۃُ ، وَلاَ یُقَادُ بِہَا۔",,,28413,,
28414,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : لاَ یُقْتَلُ بِالْقَسَامَۃِ إِلاَّ وَاحِدٌ۔",,,28414,,
28415,"حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنْ حَجَّاجِ بْنِ أَبِی عُثْمَانَ، قَالَ: حدَّثَنِی أَبُو رَجَاء مَوْلَی أَبِی قِلاَبَۃَ، عَنْ أَبِی قِلاَبَۃَ؛ أَنَّ عُمَرَ بْنَ عَبْدِالْعَزِیزِ أَبْرَزَ سَرِیرَہُ یَوْمًا لِلنَّاسِ، ثُمَّ أَذِنَ لَہُمْ فَدَخَلُوا عَلَیْہِ، فَقَالَ: مَا تَقُولُونَ فِی الْقَسَامَۃِ؟ فَأَضَبَّ النَّاسُ، فَقَالُوا: نَقُولُ الْقَسَامَۃُ الْقَوَدُ بِہَا حَقٌّ، وَقَدْ أَقَادَتْ بِہَا الْخُلَفَائُ۔ (بخاری 6899۔ ابوداؤد 273)",,,28415,,
28416,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا سَعِیدٌ ، عَنْ قَتَادَۃَ ، عَن سُلَیْمَانَ بْنِ یَسَارٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : شَاہِدَانِ مِنْ غَیْرِکُمْ۔ (ابوداؤد 4513)",,,28416,,
28417,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الْمَسْعُودِیُّ ، عَنِ الْقَاسِمِ ، قَالَ : انْطَلَقَ رَجُلاَنِ مِنْ أَہْلِ الْکُوفَۃِ إِلَی عُمَرَ بْنِ الْخَطَّابِ ، فَوَجَدَاہُ قَدْ صَدَرَ عَنِ الْبَیْتِ ، فَقَالاَ : یَا أَمِیرَ الْمُؤْمِنِینَ ، إِنَّ ابْنَ عَمٍّ لَنَا قُتِلَ وَنَحْنُ إِلَیْہِ شَرَعٌ سَوَائٌ فِی الدَّمِ ، وَہُوَ سَاکِتٌ عَنہُمَا ، قَالَ : شَاہِدَانِ ذَوَا عَدْلٍ تَجِیئَانِ بِہِ عَلَی مَنْ قَتَلَہُ ، فَنُقِیدُکُمْ مِنْہُ۔",,,28417,,
28418,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنِ الْحَسَنِ بْنِ عَمْرٍو ، عَنْ فُضَیْلٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : شَاہِدَانِ عَلَی الدَّمِ۔",,,28418,,
28419,"حَدَّثَنَا ابْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : لاَ یَجُوزُ فِی الْقَوَدِ إِلاَّ شَہَادَۃُ أَرْبَعَۃٍ۔",,,28419,,
28420,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُطَرِّفٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : شَاہِدَانِ۔",,,28420,,
28421,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الشَّیْبَانِیِّ ، عَن حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا لَمْ تَبْلُغِ الْقَسَامَۃُ ، کَرَّرُوا حَتَّی یَحْلِفُوا خَمْسِینَ یَمِینًا۔",,,28421,,
28422,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ ، عَنْ شُرَیْحٍ ، قَالَ : جَائَتْ قَسَامَۃٌ فَلَمْ یُوفُوا خَمْسِینَ ، فَرَدَّدَ عَلَیْہِم الْقَسَامَۃَ حَتَّی أَوْفَوْا۔",,,28422,,
28423,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ، عَنْ شُرَیْحٍ ، قَالَ : إِذَا کَانُوا أَقَلَّ مِنْ خَمْسِینَ ، رُدِّدَتْ عَلَیْہِم الأَیْمَانُ۔",,,28423,,
28424,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا سُفْیَانُ ، عَنْ عَبْدِ اللہِ بْنِ یَزِیدَ الْہُذَلِیِّ، عَنْ أَبِی مَلِیحٍ؛ أَنَّ عُمَرَ بْنَ الْخَطَّابِ رَدَّدَ عَلَیْہِم الأَیْمَانُ۔",,,28424,,
28425,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا کَانُوا أَقَلَّ مِنْ خَمْسِینَ رُدِّدَتْ عَلَیْہِم الأَیْمَانُ ، الأَوَّلُ فَالأَوَّلُ۔",,,28425,,
28426,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ أَبِی الزِّنَادِ ، عَنْ أَبِیہِ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ؛ أَنَّہُ رَدَّدَ الأَیْمَانَ عَلَی سَبْعَۃِ نَفَرٍ فِی الْقَسَامَۃِ ، أَحَدُہُمْ خَالِی۔",,,28426,,
28427,"حَدَّثَنَا عَبْدُ الأَعْلَی، عَنْ مَعْمَرٍ، عَنِ الزُّہْرِیِّ، قَالَ: إِذَا نَقَصَ مِنَ الْخَمْسِینَ فِی الْقَسَامَۃِ رَجُلٌ، لَمْ نُجِزْہَا۔",,,28427,,
28428,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ، عَنِ ابْنِ جُرَیْجٍ، عَنِ ابْنِ شِہَابٍ، قَالَ: أَمَّا الَّذِی عَلَیْہِ النَّاسُ الْیَوْمَ فَتَرْدِیدُ الأَیْمَانِ۔",,,28428,,
28429,حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ أَبِی جَعْفَرٍ ؛ أَنَّ عَلِیًّا کَانَ إِذَا وُجِدَ الْقَتِیل بَیْنَ الْقَرْیَتَیْنِ ، قَاسَ مَا بَیْنَہُمَا۔,,,28429,,
28430,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، قَالَ : قُتِلَ قَتِیلٌ بَیْنَ حَیَّیْنِ مِنْ ہَمْدَانَ ، بَیْنَ وَادِعَۃَ وَخَیْوَانَ ، فَبَعَثَ مَعَہُمْ عُمَرُ الْمُغِیرَۃَ بْنَ شُعْبَۃَ ، فَقَالَ : انْطَلِقْ مَعَہُمْ فَقِسْ مَا بَیْنَ الْقَرْیَتَیْنِ ، فَأَیَّتُہُمَا کَانَتْ أَقْرَبَ فَأَلْحِقْ بِہِمُ الْقَتِیلَ۔",,,28430,,
28431,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إِسْرَائِیلُ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ بْنِ الأَزْمَعِ ، قَالَ : وُجِدَ قَتِیلٌ بِالْیَمَنِ بَیْنَ وَادِعَۃَ وَأَرْحَبَ ، فَکَتَبَ عَامِلُ عُمَرَ إِلَیْہِ ، فَکَتَبَ إِلَیْہِ عُمَرُ : أَنْ قِسْ مَا بَیْنَ الْحَیَّیْنِ ، فَإِلَی أَیِّہِمَا کَانَ أَقْرَبَ فَخُذْہُمْ بِہِ۔",,,28431,,
28432,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یَحْیَی بْنِ أَبِی إِسْحَاقَ ، قَالَ : سَمِعْتُ سَالِمَ بْنَ عَبْدِ اللہِ ، یَقُولُ : وَقَدْ تَیَسَّرَ قَوْمٌ مِنْ بَنِی لَیْثٍ لِیَحْلِفُوا الْغَدَ فِی الْقَسَامَۃِ ، فَقَالَ : یَالِعِبَادَ اللہِ ، لَقَوْمٌ یَحْلِفُونَ عَلَی مَا لَمْ یَرَوْہُ ، وَلَمْ یَحْضُرُوہُ ، وَلَمْ یَشْہَدُوہُ ، وَلَوْ کَانَ لِی ، أَوْ إِلَیَّ مِنَ الأَمْرِ شَیْئٌ لَعَاقَبْتُہُمْ ، أَوْ لَنَکَلْتُہُمْ ، أَوْ لَجَعَلْتُہُمْ نَکَالاً، وَمَا قَبِلْتُ لَہُمْ شَہَادَۃً۔",,,28432,,
28433,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ حَجَّاجِ بْنِ أَبِی عُثْمَانَ، قَالَ: حدَّثَنَی أَبُو رَجَائٍ ، مَوْلَی أَبِی قِلاَبَۃَ ، عَنْ أَبِی قِلاَبَۃَ؛ أَنَّ عُمَرَ بْنَ عَبْدِالْعَزِیزِ أَبْرَزَ سَرِیرَہُ یَوْمًا لِلنَّاسِ ، ثُمَّ أَذِنَ لَہُمْ فَدَخَلُوا عَلَیْہِ ، فَقَالَ : مَا تَقُولُونَ فِی الْقَسَامَۃِ؟ فَأَضَبَّ النَّاسُ ، فَقَالُوا : نَقُولُ : الْقَسَامَۃُ الْقَوَدُ بِہَا حَقٌّ ، وَقَدْ أَقَادَتْ بِہَا الْخُلَفَائُ ، فَقَالَ : مَا تَقُولُ یَا أَبَا قِلاَبَۃَ ؟ وَنَصَبَنِی لِلنَّاسِ ، قُلْتُ : یَا أَمِیرَ الْمُؤْمِنِینَ ، عِنْدَکَ أَشْرَافُ الْعَرَبِ وَرُؤُوسُ الأَجْنَادِ ، أَرَأَیْتَ لَوْ أَنَّ خَمْسِینَ مِنْہُمْ شَہِدُوا عَلَی رَجُلٍ بِحِمْصٍ أَنَّہُ قَدْ سَرَقَ وَلَمْ یَرَوْہُ ، أَکُنْت تَقْطَعُہُ ؟ قَالَ : لاَ ، قُلْتُ : وَمَا قَتَلَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَحَدًا قَطُّ ، إِلاَّ فِی إِحْدَی ثَلاَثِ خِصَالٍ : رَجُلٍ یُقْتَلُ بِجَرِیرَۃِ نَفْسِہِ ، أَوْ رَجُلٍ زَنَی بَعْدَ إِحْصَانِہِ ، أَوْ رَجُلٍ حَارَبَ اللَّہَ وَرَسُولَہُ وَارْتَدَّ عَنِ الإِسْلاَمِ۔",,,28433,,
28434,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ أَبِی لَیْلَی ، عَنْ عَطَائٍ ؛ أَنَّ النَّاسَ أُجْلُوا عَن قَتِیلٍ فِی الطَّوَافِ ، فَوَدَاہُ مِنْ بَیْتِ الْمَالِ۔",,,28434,,
28435,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا وَہْبُ بْنُ عُقْبَۃَ ، وَمُسْلِمُ بْنُ یَزِیدَ بْنِ مَذْکُورٍ ، سَمِعَاہُ مِنْ یَزِیدَ بْنِ مَذْکُورٍ؛ أَنَّ النَّاسَ ازْدَحَمُوا فِی الْمَسْجِدِ الْجَامِعِ بِالْکُوفَۃِ یَوْمَ الْجُمُعَۃِ ، فَأَفْرَجُوا عَن قَتِیلٍ ، فَوَدَاہُ عَلِیُّ بْنُ أَبِی طَالِبٍ مِنْ بَیْتِ الْمَالِ۔",,,28435,,
28436,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنِ الْحَکَمِ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّ رَجُلاً قُتِلَ فِی الطَّوَافِ ، فَاسْتَشَارَ عُمَرُ النَّاسَ ، فَقَالَ عَلِیٌّ : دِیَتُہُ عَلَی الْمُسْلِمِینَ ، أَوْ فِی بَیْتِ الْمَالِ۔",,,28436,,
28437,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ، عَنِ ابْنِ جُرَیْجٍ، عَنْ عَطَائٍ، قَالَ: أَتَی حَجَرٌ عَائِرٌ فِی إِمْرَۃِ مَرْوَانَ ، فَأَصَابَ ابْنَ نِسْطَاسٍ بن عَامِرِ بْنِ عَبْدِ اللہِ بْنِ نِسْطَاسٍ ، لاَ یُعْلَمُ مَنْ صَاحِبُہُ فَقَتَلَہُ ، فَضَرَبَ مَرْوَانُ دِیَتَہُ عَلَی النَّاسِ۔",,,28437,,
28438,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ فِی قَوْمٍ تَنَاضَلُوا ، فَأَصَابُوا إِنْسَانًا لاَ یُدْرَی أَیُّہُمْ أَصَابَہُ ، قَالَ : الدِّیَۃُ عَلَیْہِمْ کُلِّہِمْ۔",,,28438,,
28439,"حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ، عَن عِکْرِمَۃَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: یُودَی الْمُکَاتَبُ بِقَدْرِ مَا عَتَقَ مِنْہُ دِیَۃَ الْحُرِّ، وَبِقَدْرِ مَا رُقَّ مِنْہُ دِیَۃَ الْعَبْدِ۔\n\n(ابوداؤد 457۔ احمد 260)",,,28439,,
28440,"حَدَّثَنَا إِسْمَاعِیلُ بْنُ إِبْرَاہِیمَ، عَن أَیُّوبَ، عَن عِکْرِمَۃَ، قَالَ: قَالَ عَلِیٌّ: یُودَی مِنَ الْمُکَاتَبِ بِقَدْرِ مَا أَدَّاہُ۔",,,28440,,
28441,"حَدَّثَنَا غُنْدَرٌ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ؛ أَنَّ عَلِیًّا ، وَمَرْوَانَ کَانَا یَقُولاَنِ فِی الْمُکَاتَبِ : یُودَی مِنْہُ دِیَۃَ الْحُرِّ بِقَدْرِ مَا أَدَّی ، وَمَا رَقَّ مِنْہُ دِیَۃَ الْعَبْدِ۔",,,28441,,
28442,"حَدَّثَنَا مُحَمَّدُ بْنُ سَوَائٍ ، عَنْ سَعِیدِ بْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : جِرَاحَۃُ الْمُکَاتَبِ جِرَاحَۃُ عَبْدٍ۔",,,28442,,
28443,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : تُودَی جِرَاحَتُہُ بِحِسَابِ مَا أَدَّی۔",,,28443,,
28444,"حَدَّثَنَا مُحَمَّدُ بْنُ سَوَائٍ ، عَنْ عَبَّادِ بْنِ مَنْصُورٍ ، عَن حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، عَنْ شُرَیْحٍ ، قَالَ : جِرَاحَۃُ الْمُکَاتَبِ جِرَاحَۃُ عَبْدٍ۔",,,28444,,
28445,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ ، وَحَمَّادًا عَنْ رَجُلٍ رَمَی بِنَارٍ فِی دَارِ قَوْمٍ فَاحْتَرَقُوا ؟ قَالاَ : لَیْسَ عَلَیْہِ قَوَدٌ ، لاَ یُقْتَلُ۔",,,28445,,
28446,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ حُصَیْنٍ ، عَنْ یَحْیَی بْنِ یَحْیَی الْغَسَّانِیِّ ، قَالَ : أَحْرَقَ رَجُلٌ تِبْنًا فِی قَرَاحٍ لَہُ ، فَخَرَجَتْ شَرَارَۃٌ مِنْ نَارٍ ، حَتَّی أَحْرَقَتْ شَیْئًا لِجَارِہِ ، قَالَ : فَکَتَبْتُ فِیہِ إِلَی عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، فَکَتَبَ إِلَیَّ : إِنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : الْعَجْمَائُ جُبَارٌ ، وَأَرَی أَنَّ النَّارَ جُبَارٌ۔\n\n(ابوداؤد 4582۔ ابن ماجہ 2676)",,,28446,,
28447,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ ، وَحَمَّادًا عَنْ رَجُلٍ أَحْرَقَ دَارًا ، فَأَحْرَقَ فِیہَا قَوْمًا؟ قَالاَ : لاَ یُقْتَلُ۔",,,28447,,
28448,"حَدَّثَنَا مُحَمَّدُ بْنُ عُبَیْدٍ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، قَالَ : حدَّثَنِی مَکْحُولٌ ، قَالَ : لَمَّا قَدِمَ عَلَیْنَا عُمَرُ بَیْتَ الْمَقْدِسِ أَعْطَی عُبَادَۃُ بْنُ الصَّامِتِ رَجُلاً مِنْ أَہْلِ الذِّمَّۃِ دَابَّتَہُ یُمْسِکُہَا ، فَأَبَی عَلَیْہِ فَشَجَّہُ مُوضِحَۃً ، ثُمَّ دَخَلَ الْمَسْجِدَ ، فَلَمَّا خَرَجَ عُمَرُ صَاحَ النَّبَطِیُّ إِلَی عُمَرَ ، فَقَالَ عُمَرُ : مَنْ صَاحِبُ ہَذَا ؟ قَالَ عُبَادَۃُ : أَنَا صَاحِبُ ہَذَا ، قَالَ : مَا أَرَدْتَ إِلَی ہَذَا ؟ قَالَ : أَعْطَیُْتہُ دَابَّتِی یُمْسِکُہَا فَأَبَی ، وَکُنْتُ امْرَئًا فِی حَدٍّ ، قَالَ : إِمَّا لاَ ، فَاقْعُدْ لِلْقَوَدِ ، فَقَالَ لَہُ زَیْدُ بْنُ ثَابِتٍ : مَا کُنْتَ لِتَقِیدَ عَبْدَک مِنْ أَخِیک ، قَالَ : أَمَا وَاللَّہِ لَئِنْ تَجَافَیْتُ لَکَ عَنِ الْقَوَدِ لأُعْنِتَنَّکَ فِی الدِّیَۃِ ، أَعْطِہِ عَقْلَہَا مَرَّتَیْنِ۔",,,28448,,
28449,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : لاَ قَوَدَ بَیْنَ النَّصْرَانِیِّ وَالْحُرِّ الْمُسْلِمِ ، وَلاَ بَیْنَ النَّصْرَانِیِّ وَالْعَبْدِ الْمُسْلِمِ۔",,,28449,,
28450,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ سُفْیَانَ ، عَن خَالِدٍ النِّیلِیِّ ، عَنِ الْحَکَمِ ، وَحَمَّادٍ ؛ أَنَّہُمَا قَالاَ فِی رَجُلٍ شَجَّ رَجُلاً فَذَہَبَتْ عَیْنُہُ ، فَقَالَ الْحَکَمُ : إِنْ شَہِدُوا أَنَّہَا ذَہَبَتْ مِنَ الضَّرْبَۃِ ، فَہُوَ جَائِزٌ ، وَقَالَ حَمَّادٌ : إِنْ شَہِدُوا أَنَّہُ ضَرَبَہُ یَوْمَ ضَرَبَہُ وَہِیَ صَحِیحَۃٌ ، فَہُوَ جَائِزٌ۔",,,28450,,
28451,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَن سِمَاکٍ ، عَن حَنَشِ بْنِ الْمُعْتَمِرِ ، قَالَ : حُفِرَتْ زُبْیَۃٌ بِالْیَمَنِ لِلأَسَدِ فَوَقَعَ فِیہَا الأَسَدُ ، فَأَصْبَحَ النَّاسُ یَتَدَافَعُونَ عَلَی رَأْسِ الْبِئْرِ ، فَوَقَعَ فِیہَا رَجُلٌ ، فَتَعَلَّقَ بِآخَرَ ، وَتَعَلَّقَ الآخَرُ بِآخَرَ ، فَہَوَی فِیہَا أَرْبَعَۃٌ فَہَلَکُوا فِیہَا جَمِیعًا ، فَلَمْ یَدْرِ النَّاسُ کَیْفَ یَصْنَعُونَ ، فَجَائَ عَلِیٌّ ، فَقَالَ : إِنْ شِئْتُمْ قَضَیْتُ بَیْنَکُمْ بِقَضَائٍ یَکُونُ جَائِزًا بَیْنَکُمْ ، حَتَّی تَأْتُوا النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : فَإِنِّی أَجْعَلُ الدِّیَۃَ عَلَی مَنْ حَضَرَ رَأْسَ الْبِئْرِ ، فَجَعَلَ لِلأَوَّلِ الَّذِی ہَوَی فِی الْبِئْرِ رُبُعَ الدِّیَۃِ ، وَلِلثَّانِی ثُلُثَ الدِّیَۃِ ، وَالثَّالِثِ نِصْفَ الدِّیَۃِ ، وَالرَّابِعِ کَامِلَۃً ، قَالَ : فَتَرَاضَوْا عَلَی ذَلِکَ حَتَّی أَتَوُا النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَأَخْبَرُوہُ بِقَضَائِ عَلِیٍّ ، فَأَجَازَ الْقَضَائَ۔ (احمد 77۔ طیالسی 114)",,,28451,,
28452,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عَبْدُ اللہِ بْنُ حَبِیبِ بْنِ أَبِی ثَابِتٍ ، عَنْ عَامِرٍ ، عَن مَسْرُوقٍ ؛ أَنَّ سِتَّۃَ غِلْمَۃٍ ذَہَبُوا یَسْبَحُونَ ، فَغَرِقَ أَحَدُہُمْ ، فَشَہِدَ ثَلاَثَۃٌ عَلَی اثْنَیْنِ أَنَّہُمَا أَغْرَقَاہُ ، وَشَہِدَ اثْنَانِ عَلَی ثَلاَثَۃٍ أَنَّہُمْ أَغَرقُوہُ ، فَقَضَی عَلِیٌّ أَنَّ عَلَی الثَّلاَثَۃِ خُمُسَیِ الدِّیَۃِ ، وَعَلَی الاِثْنَیْنِ ثَلاَثَۃُ أَخْمَاسِ الدِّیَۃِ۔",,,28452,,
28453,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سُفْیَانَ ، عَن فِرَاسٍ ، عَنِ الشَّعْبِیِّ ، عَن مَسْرُوقٍ ؛ أَنَّہُ جَعَلَ الدِّیَۃَ أَسْبَاعًا : أَرْبَعَۃً عَلَی ثَلاَثَۃٍ ، وَثَلاَثَۃً عَلَی أَرْبَعَۃٍ۔",,,28453,,
28454,"حَدَّثَنَا ابْنُ مُسْہِرٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَن خِلاَسٍ ، قَالَ : اسْتَأْجَرَ رَجُلٌ أَرْبَعَۃَ رِجَالٍ لِیَحْفِرُوا لَہُ بِئْرًا ، فَحَفَرُوہَا فَانْخَسَفَتْ بِہِمُ الْبِئْرُ ، فَمَاتَ أَحَدُہُمْ ، فَرُفِعَ ذَلِکَ إِلَی عَلِیٍّ ، فَضَمَّنَ الثَّلاَثَۃَ ثَلاَثَۃَ أَرْبَاعِ الدِّیَۃِ ، وَطَرَحَ عَنہُمْ رُبُعَ الدِّیَۃِ۔",,,28454,,
28455,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا أَبُو مَالِکٍ ، عَنْ عَلِیِّ بْنِ الأَقْمَرِ؛ أَنَّ رَجُلاً اسْتَأْجَرَ ثَلاَثَۃً یَحْفِرُونَ لَہُ حَائِطًا، فَضَرَبُوا فِی أَصْلِہِ جَمِیعًا ، فَوَقَعَ عَلَیْہِمْ فَمَاتَ أَحَدُہُمْ ، فَاخْتَصَمُوا إِلَی شُرَیْحٍ ، فَقَضَی عَلَی الْبَاقِیَیْنِ بِثُلُثَیِ الدِّیَۃِ۔",,,28455,,
28456,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ؛ أَنَّہُ سُئِلَ عَن أُجَرَائَ اسْتُؤْجِرُوا یَہْدِمُونَ حَائِطًا ، فَخَرَّ عَلَیْہِمْ ، فَمَاتَ بَعْضُہُمْ ؟ أَنَّہُ یَغْرَمُ بَعْضٌ لِبَعْضٍ ، وَالدِّیَۃَ عَلَی مَنْ بَقِیَ۔,,,28456,,
28457,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا مُوسَی بْنُ عُلَیٍّ، عَنْ أَبِیہِ، قَالَ: جَائَ أَعْمَی یَنْشُدُ النَّاسَ فِی زَمَانِ عُمَرَ یَقُولُ:\n\nیَا أَیُّہَا النَّاسُ لَقِیت مُنْکَرًا ہَلْ یَعْقِلُ الأَعْمَی الصَّحِیحَ الْمُبْصِرَا۔\n\nخَرَّا مَعًا کِلاَہُمَا تَکَسَّرَا ؟\n\nقالَ وَکِیعٌ : کَانُوا یَرَوْنَ أَنَّ رَجُلاً صَحِیحًا کَانَ یَقُودُ أَعْمَی ، فَوَقَعَا فِی بِئْرٍ ، فَوَقَعَ عَلَیْہِ ، فَإِمَّا قَتَلَہُ ، وَإِمَّا جَرَحَہُ ، فَضَمَّنَ الأَعْمَی۔",,,28457,,
28458,"حَدَّثَنَا عَبْدَۃُ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّ رَجُلاً مِنْ أَہْلِ الشَّامِ یُقَالُ لَہُ : ابْنُ خَیْبَرِیٍّ وَجَدَ مَعَ امْرَأَتِہِ رَجُلاً فَقَتَلَہَا ، أَوْ قَتَلَہُمَا ، فَرُفِعَ إِلَی مُعَاوِیَۃَ ، فَأَشْکَلَ عَلَیْہِ الْقَضَائُ فِی ذَلِکَ ، فَکَتَبَ إِلَی أَبِی مُوسَی : أَنْ سَلْ عَلِیًّا عَنْ ذَلِکَ ، فَسَأَلَ أَبُو مُوسَی عَلِیًّا ؟ فَقَالَ : إِنَّ ہَذَا لَشَیْئٌ مَا ہُوَ بِأَرْضِنَا، عَزَمْتُ عَلَیْک لِتُخْبِرَنِی ، فَأَخْبَرَہُ ، فَقَالَ عَلِیٌّ : أَنَا أَبُو حَسَنٍ ، إِنْ لَمْ یَجِئْ بِأَرْبَعَۃِ شُہَدَائَ ، فَلِیَدْفَعُوہُ بِرُمَّتِہِ۔ (عبدالرزاق 17915)",,,28458,,
28459,"حَدَّثَنَا أَسْبَاطٌ ، عَنِ الشَّیْبَانِیِّ ، عَن سَلَمَۃَ ، قَالَ : رُفِعَ إِلَی مُصْعَبٍ رَجُلٌ وَجَدَ مَعَ امْرَأَتِہِ رَجُلاً فَقَتَلَہُ ، فَأَبْطَلَ دَمَہُ۔",,,28459,,
28460,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی عَاصِمٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : کَانَ رَجُلاَنِ أَخَوَانِ مِنَ الأَنْصَارِ ، یُقَالُ لأَحَدِہِمَا : أَشْعَث ، فَغَزَا فِی جَیْشٍ مِنْ جُیُوشِ الْمُسْلِمِینَ ، قَالَ : فَقَالَتِ امْرَأَۃُ أَخِیہِ لأَخِیہِ : ہَلْ لَکَ فِی امْرَأَۃِ أَخِیک مَعَہَا رَجُلٌ یُحَدِّثُہَا ؟ فَصَعِدَ فَأَشْرَفَ عَلَیْہِ وَہُوَ مَعَہَا عَلَی فِرَاشِہَا ، وَہِیَ تَنْتِفُ لَہُ دَجَاجَۃً ، وَہُوَ یَقُولُ :\n\nوَأَشْعَثُ غَرَّہُ الإِسْلاَمُ مِنِّی\n\nأَبِیتُ عَلَی حَشَایَاہَا وَیُمْسِی\n\nکَأَنَّ مَوَاضِعَ الرَّبَلاَتِ مِنْہَا\n\nخَلَوْتُ بِعُرْسِہِ لَیْلَ التمَامِ\n\nعَلَی دَہْمَائَ لاَحِقَۃِ الْحِزَامِ\n\nفِئَامٌ قَدْ جُمِعنْ إِلَی فِئَامِ\n\nقالَ : فَوَثَبَ إِلَیْہِ الرَّجُلُ فَضَرَبَہُ بِالسَّیْفِ حَتَّی قَتَلَہُ ، ثُمَّ أَلْقَاہُ فَأَصْبَحَ قَتِیلاً بِالْمَدِینَۃِ ، فَقَالَ عُمَرُ : أُنْشِدُ اللَّہَ رَجُلاً کَانَ عِندَہُ مِنْ ہَذَا عِلْمٌ إِلاَّ قَامَ بِہِ ، فَقَامَ الرَّجُلُ فَأَخْبَرَہُ بِالْقِصَّۃِ ، فَقَالَ : سَحِقَ وَبَعُدَ۔",,,28460,,
28461,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : الرَّجُلُ یَجِدُ عَلَی امْرَأَتِہِ رَجُلاً فَیَقْتُلُہُ ، أَیُہْدَرُ دَمُہُ ؟ قَالَ : مَا مِنْ أَمْرٍ إِلاَّ بِالْبَیِّنَۃِ ، قُلْتُ : إِنْ شُہِدَ عَلَیْہِ أَنَّہُ زَانِی فِی أَہْلِی ، قَالَ : وَإِنْ شُہِدَ ، لاَ أَمْرَ إِلاَّ بِالْبَیِّنَۃِ ، لاَ أَمْرَ إِلاَّ فِی بَیِّنَۃٍ۔",,,28461,,
28462,"حَدَّثَنَا عَبْدَۃُ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، عَنْ عَبْدِ اللہِ ، قَالَ : بَیْنَا نَحْنُ لَیْلَۃ فِی الْمَسْجِدِ ، إِذْ جَائَ رَجُلٌ فَقَالَ : لَوْ أَنَّ رَجُلاً وَجَدَ مَعَ امْرَأَتِہِ رَجُلاً فَقَتَلَہُ ، قَتَلْتُمُوہُ ؟ ، أَوْ تَکَلَّمَ جَلَدْتُمُوہُ ؟ لأَذْکُرَنَّ ذَلِکَ لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَأَتَاہُ ، فَذَکَرَ ذَلِکَ لَہُ ، فَسَکَتَ عَنْہُ ، فَنَزَلَتْ آیَۃُ اللِّعَانِ ، فَدَعَاہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَرَأَہَا عَلَیْہِ ، فَجَائَ الرَّجُلُ بَعْدُ یَقْذِفُ امْرَأَتَہُ ، فَلاَعَنَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَیْنَہُمَا ، وَقَالَ : عَسَی أَنْ تَجِیئَ بِہِ أَسْوَدَ جَعْدًا ، فَجَائَتْ بِہِ أَسْوَدَ جَعْدًا۔ (مسلم 10۔ ابوداؤد 2247)",,,28462,,
28463,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَن زَائِدَۃَ ، عَنْ عَبْدِ الْمَلِکِ ، عَن وَرَّادٍ ، عَنِ الْمُغِیرَۃِ ، قَالَ : بَلَغَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنَّ سَعْدَ بْنَ عُبَادَۃَ یَقُولُ : لَوْ وَجَدْت مَعَہَا رَجُلاً لَضَرَبْتُہُ بِالسَّیْفِ غَیْرَ مُصْفَحٍ ، قَالَ : فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَتَعْجَبُونَ مِنْ غَیْرَۃِ سَعْدٍ ؟ فَوَاللَّہِ لأَنَا أَغْیَرُ مِنْ سَعْدٍ ، وَاللَّہُ أَغْیَرُ مِنِّی ، وَمِنْ أَجْلِ غَیْرَۃِ اللہِ حَرَّمَ اللَّہُ الْفَوَاحِشَ ، مَا ظَہَرَ مِنْہَا وَمَا بَطَنَ۔",,,28463,,
28464,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الْمُغِیرَۃِ بْنِ النُّعْمَانِ ، عَن ہَانِئِ بْنِ حِزَامٍ ، زَادَ فِیہِ یَحْیَی بْنُ آدَمَ : عَن مَالِکِ بْنِ أَنَسٍ ، عَن ہَانِئِ بْنِ حِزَامٍ ؛ أَنَّ رَجُلاً وَجَدَ مَعَ امْرَأَتِہِ رَجُلاً فَقَتَلَہَا ، فَکَتَبَ فِیہِ إِلَی عُمَرَ ، فَکَتَبَ فِیہِ عُمَرُ کِتَابَیْنِ : کِتَابٌ فِی الْعَلاَنِیَۃِ : یُقْتَلُ ، وَکِتَابٌ فِی السِّرِّ : تُؤْخَذُ الدِّیَۃُ۔",,,28464,,
28465,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ، عَنِ الرَّبِیعِ بْنِ النُّعْمَانِ، عَن أُمِّہِ؛ أَنَّ امْرَأَۃً مِنْ بَنِی لَیْثٍ، یُقَالُ لَہَا: أُمُّ ہَارُونَ، بَیْنَمَا ہِیَ جَالِسَۃٌ تَقْطَعُ مِنْ لَحْمِ أُضْحِیَّتِہَا، إِذْ شَدَّ کَلْبٌ فِی الدَّارِ عَلَی ذَلِکَ اللَّحْمِ، فَرَمَتْہُ بِالسِّکِّینِ فَأَخْطَأَتْہُ ، وَاعْتَرَضَ ابْنٌ لَہَا فَوَقَعَتِ السِّکِّینُ فِی بَطْنِہِ مُرْتَزَّۃ ، فَمَاتَ ، فَوَدَاہُ عَلِیٌّ مِنْ بَیْتِ الْمَالِ۔",,,28465,,
28466,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ، عَن خِلاَسٍ، قَالَ: رَمَی رَجُلٌ أُمَّہُ بِحَجَرٍ فَقَتَلَہَا، فَطَلَبَ مِیرَاثَہَا مِنْ إِخْوَتِہِ ، فَقَالَ إِخْوَتُہُ : لاَ مِیرَاثَ لَکَ ، فَارْتَفَعُوا إِلَی عَلِیٍّ ، فَأَخْرَجَہُ مِنَ الْمِیرَاثِ ، وَقَضَی عَلَیْہِ بِالدِّیَۃِ ، وَقَالَ : حَظَّک مِنْہَا ذَلِکَ الْحَجَرُ۔",,,28466,,
28467,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَن مُجَاہِدٍ (ح) وَعَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ، عَنْ جَدِّہِ (ح) وَعَنْ قَتَادَۃَ ، عَنْ أَبِی الْمَلِیحِ (ح) وَعَنْ عَطَائٍ ؛ أَنَّ قَتَادَۃَ کَانَتْ لَہُ أُمُّ وَلَدٍ تَرْعَی غَنَمَہُ ، فَقَالَ لَہُ ابْنُہُ مِنْہَا : حَتَّی مَتَی تَسْتَأْمِی أُمِّی ، واللہِ لاَ تَسْتَأْمِیہَا أَکْثَرَ مِمَّا اسْتَأْمَیْتہَا ، قَالَ : إِنَّکَ لَہَا ہُنَا ؟ فَخَذَفَہُ بِالسَّیْفِ فَقَتَلَہُ ، فَکَتَبَ فِی ذَلِکَ سُرَاقَۃُ بْنُ جُعْشُمٍ إِلَی عُمَرَ ، فَکَتَبَ إِلَیْہِ : وَافِنِی بِہِ ، وَبِعِشْرِینَ وَمِئَۃٍ ، قَالَ حَجَّاجٌ : وَقَالَ بَعْضُہُمْ : وَبِأَرْبَعِینَ وَمِئَۃٍ ، فَأَخَذَ مِنْہَا ثَلاَثِینَ حِقَّۃً ، وَثَلاَثِینَ جَذَعَۃً ، وَأَرْبَعِینَ مَا بَیْنَ ثَنِیَّۃٍ إِلَی بَازِلٍ عَامُہَا کُلُّہَا خِلْفَۃٌ ، فَقَسَمَہَا بَیْنَ إِخْوَتِہِ ، وَلَمْ یُوَرِّثْہُ شَیْئًا۔",,,28467,,
28468,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَوْفٍ ، قَالَ : کَانَ عُمَرُ بْنُ حَیَّانَ الْحِمَّانِیُّ یَصْنَعُ الْخَیْلَ ، وَإِنَّہُ حَمَلَ ابْنَہُ عَلَی فَرَسٍ ، فَخَرَّ فَتَقَطَّرَ مِنَ الْفَرَسِ فَمَاتَ ، فَجُعِلَتْ دِیَتُہُ عَلَی عَاقِلَتِہِ ، زَمَانَ زِیَادٍ عَلَی الْبَصْرَۃِ۔",,,28468,,
28469,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : حمَِلَ رَجُلٌ ابْنَہُ عَلَی فَرَسٍ لِیَشُوِّرہُ ، فَنَخَسَ بِہِ ، وَصَوَّتَ بِہِ فَقَتَلَہُ ، فَجُعِلَتْ دِیَتَہُ عَلَی عَاقِلَتِہِ ، وَلَمْ یُوَرِّثِ الأَبَ شَیْئًا۔",,,28469,,
28470,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ عَن خِلاَسٍ ، عَنْ عَلِیٍّ ؛ أَنَّ رَجُلَیْنِ أَتَیَا عَلِیًّا ، فَشَہِدَا عَلَی رَجُلٍ أَنَّہُ سَرَقَ ، فَقَطَعَ یَدَہُ ، ثُمَّ جَائَا بِآخَرَ ، فَقَالاَ : ہُوَ ہَذَا ، قَالَ : فَاتَّہَمَہُمَا عَلَی ہَذَا ، وَضَمَّنَہُمَا دِیَۃَ الأَوَّلِ۔",,,28470,,
28471,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : أَخْبَرَنَا ابْنُ جُرَیْجٍ ، قَالَ : أَخْبَرَنَی عَمَرَّد ؛ أَنَّ حُیَیَّ بْنَ یَعْلَی أَخْبَرَہُ ، أَنَّہُ سَمِعَ یَعْلَی یُخْبِرُ ؛ أَنَّ رَجُلاً أَتَی یَعْلَی ، فَقَالَ لَہُ : قَاتِلِی ہَذَا ، فَدَفَعَہُ إِلَیْہِ یَعْلَی ،فَجَدَعُوہُ بِسُیُوفِہِمْ ، حَتَّی رُؤُوا أَنَّہُمْ قَتَلُوہُ وَبِہِ رَمَقٌ ، فَأَخَذَہُ أَہْلُہُ فَدَاوُوہُ حَتَّی بَرِأَ ، فَجَائَ یَعْلَی ،فَقَالَ : أَوَلَسْتُ قَدْ دَفَعْتُہُ إِلَیْک ؟ فَأَخْبَرَہُ خَبَرَہُ ، فَدَعَاہُ یَعْلَی ، فَوَجَدَہُ قَدْ شُلِّلَ ، فَحُسِبَتْ جُرُوحُہُ فَوَجَدُوا فِیہِ الدِّیَۃَ ، فَقَالَ لَہُ یَعْلَی : إِنْ شِئْتَ فَادْفَعْ إِلَیْہِ دِیَتَہُ وَاقْتُلْہُ ، وَإِلاَّ فَدَعْہُ ، فَلَحِقَ بِعُمَرَ فَاسْتَأْدَی عَلَی یَعْلَی ، فَاتَّفَقَ عُمَرُ وَعَلِیٌّ عَلَی قَضَائِ یَعْلَی، أَنْ یَدْفَعَ إِلَیْہِ الدِّیَۃَ وَیَقْتُلَہُ ، أَوْ یَدَعَہُ فَلاَ یَقْتُلُہُ ، وَقَالَ عُمَرُ لِیَعْلَی : إِنَّک لَقَاضٍ ، ثُمَّ رَدَّہُ إِلَی عَمَلِہِ۔",,,28471,,
28472,"حَدَّثَنَا عَبَّادٌ ، وَأَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، عَنْ عُمَرَ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : لاَ یُقْتَلُ الْوَالِدُ بِالْوَلَدِ۔ (ابن ماجہ 2662۔ دارقطنی 181)",,,28472,,
28473,"حَدَّثَنَا ابْنُ فُضَیْلٍ، عَنْ لَیْثٍ، عَن مُجَاہِدٍ، وَعَطَائٍ، قَالاَ: لاَ یُقَادُ الرَّجُلُ مِنْ وَالِدَیْہِ، وَإِنْ قَتَلاَہُ صَبْرًا۔",,,28473,,
28474,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، قَالَ : کُتِبَ إِلَی عُمَرَ فِی امْرَأَۃٍ أَخَذَتْ بِأُنْثَیَیْ رَجُلٍ ، فَخَرَقَتِ الْجِلْدَ وَلَمْ تَخْرِقِ الصِّفَاقَ ، قَالَ عُمَرُ لأَصْحَابِہِ : مَا تَرَوْنَ فِی ہَذَا ؟ قَالُوا : اجْعَلْہَا بِمَنْزِلَۃِ الْجَائِفَۃِ ، فَقَالَ عُمَرُ : لَکِنِّی أَرَی غَیْرَ ذَلِکَ ، أَرَی أَنَّ فِیہَا نِصْفَ مَا فِی الْجَائِفَۃِ۔",,,28474,,
28475,حَدَّثَنَا ہُشَیْمٌ ، عَن دَاوُد ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ؛ أَنَّ رَجُلاً اسْتَکْرَہَ امْرَأَۃً فَأَفْضَاہَا ، فَضَرَبَہُ عُمَرُ الْحَدَّ ، وَغَرَّمَہُ ثُلُثَ دِیَتِہَا۔,,,28475,,
28476,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَن خَالِدِ بْنِ عَبْدِ اللہِ ، عَن خَالِدٍ الْحَذَّائِ ، عَنْ أَبَانَ بْنِ عُثْمَانَ ؛ أَنَّہُ رُفِعَ إِلَیْہِ رَجُلٌ تَزَوَّجَ جَارِیَۃً فَأَفْضَاہَا ، فَقَالَ فِیہَا ہُوَ وَعُمَرُ بْنُ عَبْدِ الْعَزِیزِ : إِنْ کَانَتْ مِمَّنْ یُجَامَعُ مِثْلُہَا فَلاَ شَیْئَ عَلَیْہِ ، وَإِنْ کَانَتْ مِمَّنْ لاَ یُجَامَعُ مِثْلُہَا ، فَعَلَیْہِ ثُلُثُ الدِّیَۃِ۔",,,28476,,
28477,"حَدَّثَنَا وَکِیعٌ ، عَن شَیْخٍ ، عَنْ قَتَادَۃَ ، عَن زَیْدِ بْنِ ثَابِتٍ ؛ فِی الرَّجُلِ یُفضِی الْمَرْأَۃَ ، قَالَ : إِذَا أَمْسَکَ أَحَدُہُمَا عَنِ الآخَرِ فَالثُّلُثُ ، وَإِنْ لَمْ یُمْسِکْ فَالدِّیَۃُ۔",,,28477,,
28478,حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ أَنَّ رَجُلاً اسْتَسْقَی عَلَی بَابِ قَوْمٍ فَأَبَوْا أَنْ یُسْقُوہُ ، فَأَدْرَکَہُ الْعَطَشُ فَمَاتَ ، فَضَمَّنَہُمْ عُمَرُ دِیَتَہُ۔,,,28478,,
28479,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ، قَالَ : مَا قُتِلَ عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَلاَ أَبِی بَکْرٍ ، وَلاَ عُمَرَ رَجُلٌ مِنَ الْمُسْلِمِینَ إِلاَّ فِی زِنَی ، أَوْ قَتْلٍ ، أَوْ حَارَبَ اللَّہَ وَرَسُولَہُ۔",,,28479,,
28480,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ عَبْدِ اللہِ بْنِ مُرَّۃَ ، عَن مَسْرُوقٍ ، عَنْ عَبْدِ اللہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: لاَ یَحِلُّ دَمُ امْرِئٍ یَشْہَدُ أَنْ لاَ إِلَہَ إِلاَّ اللَّہُ، وَأَنِّی رَسُولُ اللہِ، إِلاَّ أَحَدُ ثَلاَثَۃِ نَفَرٍ ؛ النَّفْسِ بِالنَّفْسِ ، وَالثَّیِّبِ الزَّانِی ، وَالتَّارِکِ لِدِینِہِ ، الْمُفَارِقِ لِلْجَمَاعَۃِ۔(بخاری 6878۔ مسلم 1302)",,,28480,,
28481,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَمْرِو بْنِ غَالِبٍ ، عَنْ عَائِشَۃَ ، قَالَتْ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَحِلُّ دَمُ امْرِئٍ مُسْلِمٍ ، إِلاَّ رَجُلٌ قَتَلَ فَقُتِلَ ، أَوْ رَجُلٌ زَنَی بَعْدَ مَا أُحْصِنَ ، أَوْ رَجُلٌ ارْتَدَّ بَعْدَ إِسْلاَمِہِ۔ (احمد 205۔ طیالسی 1543)",,,28481,,
28482,حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَمْرِو بْنِ غَالِبٍ ، عَنْ عَائِشَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ مِثْلَہُ۔,,,28482,,
28483,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَن مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَنْ أَبِی مَعْشَرٍ، عَن مَسْرُوقٍ، عَنْ عَائِشَۃَ، قَالَتْ : مَا حَلَّ دَمُ أَحَدٍ مِنْ أَہْلِ ہَذِہِ الْقِبْلَۃِ ، إِلاَّ مَنِ اسْتَحَلَّ ثَلاَثَۃَ أَشْیَائَ ؛ قَتْلَ النَّفْسِ بِالنَّفْسِ ، وَالثَّیِّبَ الزَّانِی ، وَالْمُفَارِقَ جَمَاعَۃَ الْمُسْلِمِینَ ، أَوِ الْخَارِجَ مِنْ جَمَاعَۃِ الْمُسْلِمِینَ۔ (حاکم 354)",,,28483,,
28484,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ قَیْسٍ ، عَنْ أَبِی حَصِیْنٍ ؛ أَنَّ عُثْمَانَ أَشْرَفَ عَلَی النَّاسِ یَوْمَ الدَّارِ ، فَقَالَ : أَمَا عَلِمْتُمْ أَنَّہُ لاَ یَحِلُّ دَمُ امْرِئٍ مُسْلِمٍ إِلاَّ أَرْبَعَۃٌ ؛ رَجُلٌ قَتَلَ فَقُتِلَ ، أَوْ رَجُلٌ زَنَی بَعْدَ مَا أُحْصِنَ ، أَوْ رَجُلٌ ارْتَدَّ بَعْدَ إِسْلاَمِہِ ، أَوْ رَجُلٌ عَمِلَ عَمَلَ قَوْمِ لُوطٍ۔ (نسائی 3520۔ احمد 63)",,,28484,,
28485,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ عَلِیِّ بْنِ الأَقْمَرِ ، قَالَ : وَجَدْت مَمْلُوکًا لَنَا کَانَ یَعْمَلُ فِی بِئْرٍ فِی دَارِ عُتْبَۃَ ، فَخَاصَمْتُہُ إِلَی شُرَیْحٍ ، فَقَالَ : بَیِّنَتُکَ أَنَّہُمْ أَکْرَہُوہُ ، وَإِلاَّ أَقْسَمَ لَکَ مِنْ أَہْلِ الدَّارِ مَنْ شِئْتَ۔",,,28485,,
28486,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قَالَ لِی ابْنُ شِہَابٍ : لَیْسَ فِی الْعَبْدِ قَسَامَۃٌ ، وَلاَ تُرَدَّ بِہِ الْقَسَامَۃَ ، إِنَّمَا ہِیَ الأَثْمَانُ کَہَیْئَۃِ الْحَقِّ یُدَّعَی۔",,,28486,,
28487,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قضَی ہِشَامُ بْنُ عَبْدِ الْمَلِکِ فِی عَبْدِ أَیُّوبَ مَوْلَی ابْنِ نَافِعٍ بِخَمْسِینَ یَمِینًا عَلَی أَیُّوبَ ، فَحَلَفَ فَأَخَذَ ثَمَنَہُ۔",,,28487,,
28488,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَن عُمَارَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزید ، قَالَ : قَالَ سَلْمَانُ : أَمَّا الدَّمُ فَیَقْضِی فِیہِ عُمَرُ۔",,,28488,,
28489,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا مِسْعَرٌ ، عَنْ عَبْدِ الْمَلِکِ بْنِ مَیْسَرَۃَ ، عَنِ النَّزَّالِ بْنِ سَبْرَۃَ ، قَالَ : کَتَبَ عُمَرُ إِلَی أُمَرَائِ الأَجْنَادِ : أَنْ لاَ تُقْتَلَ نَفْسٌ دُونِی۔",,,28489,,
28490,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : کَانَ لاَ یُقْضَی فِی دَمٍ دُونَ أَمِیرِ الْمُؤْمِنِینَ۔",,,28490,,
28491,حَدَّثَنَا عَبْدَۃُ، عَن عُبَیْدِاللہِ بْنِ عُمَرَ، عَن نَافِعٍ، عَنِ ابْنِ عُمَرَ؛ أَنَّ جَارِیَۃً لِحَفْصَۃَ سَحَرَتْہَا، وَوَجَدُوا سِحْرَہَا وَاعْتَرَفَتْ بِہِ ، فَأَمَرْت عَبْدَ الرَّحْمَن بْنَ زَیْدٍ فَقَتَلَہَا ، فَبَلَغَ ذَلِکَ عُثْمَانَ فَأَنْکَرَہُ وَاشْتَدَّ عَلَیْہِ ، فَأَتَاہُ ابْنُ عُمَرَ فَأَخْبَرَہُ أَنَّہَا سَحَرَتْہَا وَاعْتَرَفَتْ بِہِ، وَوَجَدُوا سِحْرَہَا، فَکَأَنَّ عُثْمَانَ إِنَّمَا أَنْکَرَ ذَلِکَ لأَنَّہَا قُتِلَتْ بِغَیْرِ إِذْنِہِ۔,,,28491,,
28492,"حَدَّثَنَا حَفْصٌ ، قَالَ : سَأَلْتُ عُمَرًا : مَا کَانَ الْحَسَنُ یَقُولُ فِی الْمُعَاہَدِ یُقْتَلُ ؟ قَالَ : إِنْ کَانُوا یَتَعَاقَلُونَ فَعَلَی الْعَوَاقِلِ ، وَإِنْ کَانُوا لاَ یَتَعَاقَلُونَ فَدَیْنٌ عَلَیْہِ فِی مَالِہِ۔",,,28492,,
28493,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ؛ فِی الْمُعَاہَدِ یَقْتُلُ ، قَالَ : دِیَتُہُ لِلْمُسْلِمِینَ وَعَقْلُہُ عَلَیْہِمْ۔",,,28493,,
28494,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ؛ فِی رَجُلٍ مِنْ أَہْلِ الذِّمَّۃِ فَقَأَ عَیْنَ رَجُلٍ مُسْلِمٍ ، قَالَ : دِیَتُہُ عَلَی أَہْلِ طَسَّوجہ۔",,,28494,,
28495,"حَدَّثَنَا حَفْصٌ ، عَنِ الشَّیْبَانِیِّ ، عَن حَمَّادٍ ؛ فِی أَرْبَعَۃٍ شَہِدُوا عَلَی رَجُلٍ بِالزِّنَی فَرُجِمَ ، ثُمَّ رَجَعَ أَحَدُہُمْ ، قَالَ : عَلَیْہِ رُبُعُ الدِّیَۃِ۔",,,28495,,
28496,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ سَعِیدٍ ، عَنْ مَطَرٍ ، عَن عِکْرِمَۃَ ؛ فِی أَرْبَعَۃٍ شَہِدُوا عَلَی رَجُلٍ بِحَدٍّ ، ثُمَّ أَکْذَبَ أَحَدُہُمْ نَفْسَہُ ، قَالَ : یَغْرَمُ رُبُعَ الدِّیَۃِ۔",,,28496,,
28497,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، قَالَ : یُقْتَلُ ، وَعَلَی الآخَرِینَ الدِّیَۃُ۔",,,28497,,
28498,"حَدَّثَنَا مُحَمَّدُ بْنُ یَزِیدَ ، عَنْ أَیُّوبَ أَبِی الْعَلاَئِ ، قَالَ : قَالَ أَبُو ہَاشِمٍ ؛ فِی أَرْبَعَۃٍ شَہِدُوا عَلَی رَجُلٍ بِالزِّنَی ، ثُمَّ رَجَعَ أَحَدُہُمْ : عَلَیْہِ رُبُعُ الدِّیَۃِ ، وَقَالَ ابْنُ سِیرِینَ : إِذَا قَالَ أَخْطَأْتُ وَأَرَدْتُ غَیْرَہُ ، فَعَلَیْہِ الدِّیَۃُ کَامِلَۃً ، وَإِنْ قَالَ تَعَمَّدْتُ قَتْلَہُ ، قُتِلَ بِہِ۔",,,28498,,
28499,"حَدَّثَنَا حَفْصٌ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ، قَالَ : إِذَا وَہَبَ الأَبُ الشَّجَّۃَ الصَّغِیرَۃَ الَّتِی تُصِیبُ ابْنَہُ ، جَازَتْ عَلَیْہِ۔",,,28499,,
28500,"حَدَّثَنَا عَبْدَۃُ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ جَابِرِ بْنِ زَیْدٍ ؛ فِی رَجُلٍ قُطِعَتْ یَدُہُ فِی السَّرِقَۃِ ، ثُمَّ قَطَعَ رَجُلٌ یَدَہُ الأُخْرَی بَعْدُ ، قَالَ : فِیہَا نِصْفُ الدِّیَۃِ۔",,,28500,,
28501,"حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ ، وَحَمَّادًا عَنْ رَجُلٍ تَوَضَّأَ فَصَبَّ مَائً فِی الطَّرِیقِ ؟ قَالَ حَمَّادٌ : یُضَمَّنُ ، وَقَالَ الْحَکَمُ : لاَ یُضَمَّنُ۔",,,28501,,
28502,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا سُفْیَانُ، عَنْ جَابِرٍ، عَنْ عَامِرٍ؛ فِی الْقَصَّابِ، وَالْقَصَّارِ یَنْضَحُ بَابَہُ، قَالَ: یُضْمَنُ۔",,,28502,,
28503,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، وَحَمَّادٍ ؛ فِی الرَّجُلِ السّوقِیِّ یَنْضَحُ بَیْنَ یَدَیْ بَابِہِ ، فَیَمُرُّ بِہِ إِنْسَانٌ فَیَزْلَقُ فَیَعْنَتُ ، قَالَ حَمَّادٌ : یَضْمَنُ ، وَقَالَ الْحَکَمُ : لاَ یَضْمَنُ۔",,,28503,,
28504,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ عَوْفٍ ، قَالَ : شَہِدْتُ عَبْدَ الرَّحْمَن بْنَ أُذَیْنَۃَ أَقَصَّ رَجُلاً حَارِصَتَیْنِ فِی رَأْسِہِ ، ثُمَّ حَبَسَ الْمُقْتَصَّ لَہُ حَتَّی یَنْظُرَ الْمُقْتَصَّ مِنْہُ۔ قَالَ : وَکَانَ ابْنُ سِیرِینَ یُنْکِرُ ہَذَا الْحَبْسَ۔",,,28504,,
28505,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قَالَ عَطَائٌ : لِلْجُرُوحِ قِصَاصٌ ، وَلَیْسَ لِلإِمَامِ أَنْ یَضْرِبَہُ، وَلاَ أَنْ یَحْبِسَہُ ، إِنَّمَا ہُوَ الْقِصَاصُ ، مَا کَانَ اللَّہُ نَسِیًّا ، لَوْ شَائَ لأَمَرَ بِالسِّجْنِ وَالضَّرْبِ۔",,,28505,,
28506,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مُغِیرَۃَ ، عَن شِبَاکٍ ، عَنْ إِبْرَاہِیمَ ، عَن ہُنَیِّ بْن نُوَیْرَۃَ ، عَنْ عَلْقَمَۃَ ، عَنْ عَبْدِ اللہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَعَفَّ النَّاسِ قِتْلَۃً أَہْلُ الإِیمَانِ۔\n\n(ابوداؤد 2659۔ ابن حبان 5994)",,,28506,,
28507,"حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَنْ عَلْقَمَۃَ ؛ أَنَّہُ مَرَّ عَلَی ابْنِ مُکَعْبَرٍ ، وَقَدْ قَطَعَ زِیَادٌ یَدَیْہِ وَرِجْلَیْہِ ، فَقَالَ : سَمِعْتُ عَبْدَ اللہِ یَقُولُ : إِنَّ أَعَفَّ النَّاسِ قِتْلَۃً أَہْلُ الإِیِمَانِ۔",,,28507,,
28508,"حَدَّثَنَا حَفْصٌ ، عَن خَالِدٍ ، عَنْ أَبِی قِلاَبَۃَ ، عَنْ أَبِی الأَشْعَثِ ، عَن شَدَّادِ بْنِ أَوْسٍ ، رَفَعَہُ ، قَالَ : إِنَّ اللَّہَ کَتَبَ الإِحْسَانَ عَلَی کُلِّ شَیْئٍ ، فَإِذَا قَتَلْتُمْ فَأَحْسِنُوا الْقَتْلَ۔ (مسلم 1549۔ ابوداؤد 2807)",,,28508,,
28509,"حَدَّثَنَا وَکِیعٌ ، عَن مَسْلَمَۃَ بْنِ نَوْفَلٍ ، عَن صَفِیَّۃَ بِنْتِ الْمُغِیرَۃِ بْنِ شُعْبَۃَ ، قَالَتْ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الْمُثْلَۃِ۔ (احمد 246)",,,28509,,
28510,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَن خَالِدٍ ، عَنْ أَبِی قِلاَبَۃَ ، عَنْ أَبِی الأَشْعَثِ ، عَن شَدَّادِ بْنِ أَوْسٍ ، رَفَعَہُ ، قَالَ : إِنَّ اللَّہَ کَتَبَ عَلَیْکُم الإِحْسَانَ فِی کُلِّ شَیْئٍ ، فَإِذَا قَتَلْتُمْ فَأَحْسِنُوا الْقِتْلَۃَ ، وَإِذَا ذَبَحْتُمْ فَأَحْسِنُوا الذَّبْحَ۔\n\n(مسلم 1548۔ بیہقی 68)",,,28510,,
28511,"حَدَّثَنَا وَکِیعٌ ، قَالَ: حدَّثَنَا الْمَسْعُودِیُّ ، عَن سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنْ إِبْرَاہِیمَ ، عَنْ عَلْقَمَۃَ ، عَنْ عَبْدِ اللہِ، قَالَ : أَعَفَّ النَّاسِ قِتْلَۃً أَہْلُ الإِِِیِمَانِ۔",,,28511,,
28512,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَن بُکَیْر بْنِ عَبْدِ اللہِ بْنِ الأَشَجِّ ، عَنْ عُبَیْدِ بن تِعْلَی ، قَالَ : غَزَوْنَا أَرْضَ الرُّومِ وَمَعَنا أَبُو أَیُّوبَ الأَنْصَارِیُّ صَاحِبُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَعَلَی النَّاسِ عَبْدُ الرَّحْمَنِ بْنُ خَالِدِ بْنِ الْوَلِیدِ فِی زَمَانِ مُعَاوِیَۃَ ، فَبَیْنَا نَحْنُ عَندَہُ إِذْ أَتَاہُ رَجُلٌ ، فَقَالَ : أُتِیَ الأَمِیرُ آنفًا بِأَعْلاَجٍ أَرْبَعَۃٍ ، فَأَمَرَ بِہِم فَصُبِرُوا ، یُرْمَوْنَ بِالنَّبْلِ حَتَّی قُتِلُوا ، قَالَ : فَقَامَ أَبُو أَیُّوبَ فَزِعًا حَتَّی أَتَی عَبْدَ الرَّحْمَن ، فَقَالَ : أَصَبَرْتَہمْ ؟ لَقَدْ سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَنْہَی عَن صَبْرِ الْبَہِیمَۃِ ، وَمَا أَحَبُّ أَنـِّی صَبْرَتُ دَجَاجَۃً وَأَنَّ لِی کَذَا وَکَذَا ، قَالَ : فَأَعْظَمَ ذَلِکَ ، فَدَعَا عَبْدُ الرَّحْمَنِ بِغِلْمَانٍ لَہُ أَرْبَعَۃٍ فَأَعْتَقَہُمْ مَکَانَ الَّذِی صَنَعَ۔",,,28512,,
28513,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃ ، عَنْ عَدِیِّ بْنِ ثَابِتٍ ، عَنْ عَبْدِ اللہِ بْنِ یَزِیدَ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الْمُثْلَۃِ۔",,,28513,,
28514,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا ہَمَّامٌ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، عَن ہَیَّاجِ بْنِ عِمْرَانَ الْبُرْجُمِیِّ ، عَنْ عِمْرَانَ بْنَ حُصَیْنٍ ، وَسَمُرَۃَ بْنَ جُنْدُبٍ ، قَالاَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الْمُثْلَۃِ۔\n\n(ابوداؤد 2660۔ احمد 429)",,,28514,,
28515,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَطَائٍ ، عَنْ عَبْدِ اللہِ بْنِ حَفْصٍ ، عَنْ یَعْلَی بْنِ مُرَّۃَ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : قَالَ اللَّہُ : لاَ تُمَثِّلُوا بِعِبَادِی۔ (احمد 173۔ طبرانی 698)",,,28515,,
28516,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَن مَنْصُورٍ ، عَن طَلْقِ بْنِ حَبِیبٍ ؛ فِی قَوْلِہِ : {فَلاَ یُسْرِفْ فِی الْقَتْلِ} ، قَالَ : أَنْ تَقْتُلَ غَیْرَ قَاتِلِکَ ، أَوْ تُمَثِّلَ بِقَاتِلِک۔",,,28516,,
28517,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَن خُصَیْفٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ {فَلاَ یُسْرِفْ فِی الْقَتْلِ} ، قَالَ : أَنْ یَقْتُلَ اثْنَیْنِ بِوَاحِدٍ۔",,,28517,,
28518,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَلْقَمَۃَ بْنِ مَرْثَدٍ ، عَن سُلَیْمَانَ بْنِ بُرَیْدَۃَ ، عَنْ أَبِیہِ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إِذَا بَعَثَ سَرِیَّۃً ، قَالَ : لاَ تُمَثِّلُوا۔ (مسلم 1356۔ ابوداؤد 2605)",,,28518,,
28519,"حَدَّثَنَا عُقْبَۃُ بْنُ خَالِدٍ السَّکُونِیُّ ، عَن مُوسَی بْنِ مُحَمَّدِ بْنِ إِبْرَاہِیمَ ، قَالَ : حدَّثَنَی أَبِی ، عَنْ أَبِی سَعِیدٍ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یُمَثَّلَ بِالْبَہَائِمِ۔",,,28519,,
28520,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا رَبِیعَۃُ بْنُ عُثْمَانَ التَّیْمِیُّ ، عَنْ سَعْدِ بْنِ إِبْرَاہِیمَ ؛ أَنَّ أَبَا مُوسَی کَتَبَ إِلَی عُمَرَ : إِنَّ الرَّجُل یَمُوتُ قِبَلَنَا وَلَیْسَ لَہُ رَحِمٌ ، وَلاَ وَلِیٌّ ، قَالَ : فَکَتَبَ إِلَیْہِ عُمَرُ : إِنْ تَرَکَ ذَا رَحِمٍ فَالرَّحِمُ ، وَإِلاَّ فَالْوَلاَئُ ، وَإِلاَّ فَبَیْتُ الْمَالِ یَرِثُونَہُ ، وَیَعْقِلُونَ عَنْہُ۔",,,28520,,
28521,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مُطَرِّفٍ ، عَنِ الشَّعْبِیِّ (ح) وَعَن یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یُسْلِمُ وَلَیْسَ لَہُ مَوْلًی ، قَالاَ : مِیرَاثُہُ لِلْمُسْلِمِینَ ، وَعَقْلُہُ عَلَیْہِمْ۔",,,28521,,
28522,"حَدَّثَنَا جَرِیرٌ، عَن مَنْصُورٍ، عَنْ إِبْرَاہِیمَ، قَالَ: إِذَا أَسْلَمَ الرَّجُلُ عَلَی یَدِ الرَّجُلِ فَلَہُ مِیرَاثُہُ، وَیَعْقِل عَنْہُ۔",,,28522,,
28523,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَن یُونُسَ ، عَنِ الْحَکَمِ بْنِ الأَعْرَجِ ، عَنِ الأَشْعَثِ بْنِ ثُرْمُلَۃَ ، عنْ أَبِی بَکْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ قَتَلَ نَفْسًا مُعَاہَدَۃً بِغَیْرِ حِلِّہَا ، حَرَّمَ اللَّہُ عَلَیْہِ الْجَنَّۃَ أَنْ یَشُمَّ رِیحَہَا۔ (حاکم 8743۔ احمد 38)",,,28523,,
28524,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا سُفْیَانُ، عَن یُونُسَ، عَنِ الْحَکَمِ، عَنْ أَشْعَثَ، عنْ أَبِی بَکْرَۃَ، عَنِ النَّبِیِّ؛ مِثْلَہُ۔ (احمد 52)",,,28524,,
28525,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا عُیَیْنَۃُ بْنُ عَبْدِالرَّحْمَنِ، عَنْ أبیہ ، عَنْ أَبِی بَکْرَۃَ ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ قَتَلَ نَفْسًا مُعَاہَدَۃً فِی غَیْرِ کُنْہِہِ ، حَرَّمَ اللَّہُ عَلَیْہِ الْجَنَّۃَ۔ (ابوداؤد 2754۔ احمد 38)",,,28525,,
28526,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، قَالَ : حدَّثَنَا الْحَسَنُ بْنُ عَمْرٍو ، عَن مُجَاہِدٍ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ قَتَلَ مُعَاہَدًا بِغَیْرِ حَقٍّ ، لَمْ یَرَحْ رَائِحَۃَ الْجَنَّۃِ ، وَإِنَّہُ لَیُوجَدُ رِیحُہَا مِنْ مَسِیرَۃِ أَرْبَعِینَ عَامًا۔ (بخاری 3166۔ ابن ماجہ 2686)",,,28526,,
28527,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ أَبِی وَائِلٍ ، عَنْ عَبْدِ اللہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَوَّلُ مَا یُقْضَی بَیْنَ النَّاسِ یَوْمَ الْقِیَامَۃِ فِی الدِّمَائِ۔ (مسلم 1304۔ ترمذی 1397)",,,28527,,
28528,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ أَبِی وَائِلٍ ، عَنْ عَمْرِو بْنِ شُرَحْبِیلِ ، قَالَ : أوَّلُ مَا یُقْضَی بَیْنَ النَّاسِ یَوْمَ الْقِیَامَۃِ فِی الدِّمَائِ ، یَجِیئُ الرَّجُلُ آخِذًا بِیَدِ الرَّجُلِ ، قَالَ : فَیَقُولُ : یَا رَبِّ ، ہَذَا قَتَلَنِی ، فَیَقُولُ : فِیمَ قَتَلْتَہُ ؟ فَیَقُولُ : قَتَلَتُہُ لِتَکُونَ الْعِزَّۃُ لِفُلاَنٍ ، فَیُقَالُ : إِنَّہَا لَیْستَْ لَہُ ، بُؤْ بِعَمَلِکَ ، وَیَجِیئُ الرَّجُلُ آخِذًا بِیَدِ الرَّجُلِ ، فَیَقُولُ : یَا رَبِّ ، ہَذَا قَتَلَنِی ، فَیَقُولُ : فِیمَ قَتَلْتَہُ ؟ فَیَقُولُ : قَتَلَتُہُ لِتَکُونَ الْعِزَّۃُ لَک۔ قَالَ : فَیَقُولُ : إِنَّ الْعِزَّۃَ لِی۔ (نسائی 3460۔ طبرانی 10075)",,,28528,,
28529,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی مِجْلَزٍ ، عَن قَیْسِ بْنِ عُبَادٍ ، قَالَ : قَالَ عَلِیٌّ : أَنَا أَوَّلُ مَنْ یَجْثُو لِلْخَصْمِ بَیْنَ یَدِی اللہِ یَوْمَ الْقِیَامَۃِ۔ (بخاری 4744)",,,28529,,
28530,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا فُضَیْلُ بْنُ مَرْزُوقٍ ، عَنْ عَطِیَّۃَ بْنِ سَعْدٍ الْعَوْفِیِّ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ جُنْدَبٍ ، عَنْ عَلِیٍّ ؛ أَنَّہُ سُئِلَ عَن قَتْلاَہُ ، وَقَتْلَی مُعَاوِیَۃَ ؟ فَقَالَ : أَجِیئُ أَنَا وَمُعَاوِیَۃُ فَنَخْتَصِمُ عَندَ ذِی الْعَرْشِ ، فَأَیُّنَا فَلَجَ ، فَلَجَ أَصْحَابُہُ۔",,,28530,,
28531,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ إِبْرَاہِیمِ بْنِ الْمُہَاجِرِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : أَوَّلُ مَا یُقْضَی بَیْنَ النَّاسِ یَوْمَ الْقِیَامَۃِ فِی الدِّمَائِ۔",,,28531,,
28532,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ، قَالَ : إِذَا أُصِیبَ الرَّجُلُ بِجِرَاحَۃٍ فَاقْتُصُّ مِنْ صَاحِبِہِ ، کَانَتْ دِیَۃُ الْمُقْتَصِّ مِنْہُ عَلَی عَاقِلَۃِ الْقَاصِّ۔",,,28532,,
28533,حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، عَنْ إِبْرَاہِیمَ ؛ فِی الَّذِی یُقْتَصُّ مِنْہُ فَیَمُوتُ ، یُرْفَعُ عَنِ الَّذِی اقْتَصَّ مِنْہُ دِیَۃُ جِرَاحَتِہِ ، وَعَلَیْہِ دِیَتُہُ عَلَی عَاقِلَتِہِ۔,,,28533,,
28534,"حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ سُفْیَانَ ، عَنِ ابْن أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ؛ فِی الَّذِی یُقْتَصُّ مِنْہُ فَیَمُوتُ ، قَالَ : الدِّیَۃُ عَلَی عَاقِلَتِہِ۔",,,28534,,
28535,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ؛ فِی السِّنِّ الزَّائِدَۃِ ، قَالَ : حکُومَۃٌ۔",,,28535,,
28536,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : حدِّثْتُ عَنْ مَکْحُولٍ ، عن زَیْدِ بْنِ ثَابِتٍ ؛ أَنَّہُ قَالَ : فِی السِّنِّ الزَّائِدَۃِ ثُلُثُ السِنِّ۔",,,28536,,
28537,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الْمَسْعُودِیُّ ، عَنِ الْقَاسِمِ بْنِ عَبْدِ الرَّحْمَنِ ، قَالَ : أَقْبَلَ رَجُلٌ بِجَارِیَۃٍ مِنَ الْقَادِسِیَّۃِ ، فَمَرَّ عَلَی رَجُلٍ وَاقِفٍ عَلَی دَابَّۃٍ ، فَنَخَسَ الرَّجُلُ الدَّابَّۃَ ، فَرَفَعَتِ الدَّابَّۃُ رِجْلَہَا ، فَلَمْ تُخْطِئْ عَیْنَ الْجَارِیَۃِ ، فَرُفِعَ إِلَی سَلْمَانَ بْنِ رَبِیعَۃَ الْبَاہِلِیِّ ، فَضَمَّنَ الرَّاکِبَ ، فَبَلَغَ ذَلِکَ ابْنَ مَسْعُودٍ ، فَقَالَ : عَلَیّ الرَّجُل ، إِنَّمَا یُضَمَّنُ النَّاخِسُ۔",,,28537,,
28538,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إِسْرَائِیلُ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : سَأَلْتُہُ عَنْ رَجُلٍ نَخَسَ دَابَّۃَ رَجُلٍ؟ فَقَالَ : یُضَمَّنُ النَّاخِسُ۔",,,28538,,
28539,"حَدَّثَنَا أَبُو أُسَامَۃَ، عَن مُجَالِدٍ، عَنِ الشَّعْبِیِّ، عَنْ شُرَیْحٍ، قَالَ: إِلاَّ أَنْ یَنْخُسَہَا إِنْسَانٌ فَیُضَمَّن النَّاخِسُ۔",,,28539,,
28540,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ (ح) وَحَمَّادٍ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّہُمَا قَالاَ فِی رَجُلٍ جَدَعَ أَنْفَ عَبْدٍ کُلَّہُ ، قَالَ : یَغْرَمُ ثَمَنَہُ۔",,,28540,,
28541,"حَدَّثَنَا قَبِیصَۃُ بْنُ عُقْبَۃَ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی عُبَیْدِ اللہِ ، عَنِ ابْنِ عَبَّاسٍ ؛ فِی رَجُلٍ قُطِعَتْ یَدُہُ ، فَصَالَحَ عَلَیْہَا ، ثُمَّ انْتَقَضَتْ یَدُہُ فَمَاتَ ، قَالَ : الصُّلْحُ مَرْدُودٌ ، وَیُؤْخَذُ بِالدِّیَۃُ۔",,,28541,,
28542,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : ہَاجَتِ الْفِتْنَۃُ وَأَصْحَابُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مُتَوَافِرُونَ ، فَأَجْمَعَ رَأْیُہُمْ عَلَی أَنَّہُ لاَ یُقَادُ ، وَلاَ یُودَی مَا أُصِیبَ عَلَی تَأْوِیلِ الْقُرْآنِ ، وَلاَ یُرَدُّ مَا أُصِیبَ عَلَی تَأْوِیلِ الْقُرْآنِ ، إِلاَّ مَا یُوجَدُ بِعَیْنِہِ۔",,,28542,,
28543,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : سَأَلْتُہُ عَن غُلاَمٍ کَانَ یُطَیِّرُ حَمَامًا فَوْقَ بَیْتٍ ، وَرَجُلٌ فَوْقَ بَیْتٍ ، فَوَقَعَ الْغُلاَمُ ، فَقَالَ إِبْرَاہِیمُ : لَعَلَّہُمْ یَقُولُونَ لَعَلَّہُ أَمَرَہُ بِشَیْئٍ۔",,,28543,,
28544,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عِمْرَانُ بْنُ حُدَیْرٍ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ : لو قُلْتَ لِرَجُلٍ وَہُوَ عَلَی مَقْتَلِہِ ، یَعْنِی مَہْلِکَہُ : جِسْرًا ، أَوْ حَائِطًا ، بَاعِد اتَّقِہِ ، فَصُرِعَ غَرِمْتَہُ۔",,,28544,,
28545,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : رَجُلٌ نَادَی صَبِیًّا اسْتَأْخِرْ ، فَخَرَّ فَمَاتَ ؟ قَالَ : یَرْوُونَ عَنْ عَلِیٍّ أَنَّہُ یُغَرِّمُہُ ، یَقُولُونَ : أَفْزَعَہُ ، قُلْتُ : فَنَادَی کَبِیرًا ؟ قَالَ : مَا أَرَاہُ إِلاَّ مِثْلَہُ ، فَرَادَدْتُہُ ، فَکَانَ یَرَی أَنْ یُغَرَّمَ۔",,,28545,,
28546,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ فِی رَجُلَیْنِ شَجَّا رَجُلاً ، فَشَجَّہُ أَحَدُہُمَا آمَّۃً ، وَشَجَّہُ الآخَرُ مُوضِحَۃً ، لاَ یُعْلَمُ ، وَلاَ یُدْرَی أَیُّہُمَا شَجَّ الْمُوضِحَۃَ ، وَلاَ أَیُّہُمَا شَجَّ الآمَّۃَ ، فَقَالَ : عَلَی کُلِّ وَاحِدٍ مِنْہُمَا نِصْفُ الآمَّۃِ ، وَنِصْفُ الْمُوضِحَۃِ۔",,,28546,,
28547,"حَدَّثَنَا وَکِیعٌ ، عَن خَلِیفَۃَ بْنِ خَیَّاطٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ أَنَّہُ قَالَ فِی خُطْبَتِہِ ، وَہُوَ مُسْنِدٌ ظَہْرَہُ إِلَی الْکَعْبَۃِ ، قَالَ : الْمُسْلِمُونَ تَتَکَافَأُ دِمَاؤُہُمْ ، یَسْعَی بِذِمَّتِہِمْ أَدْنَاہُمْ ، وَہُمْ یَدٌ عَلَی مَنْ سِوَاہُمْ۔ (ابوداؤد 2745۔ ابن ماجہ 2685)",,,28547,,
28548,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا أَبُو الأَشْہَبِ ، عَنِ الْحَسَنِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْمُسْلِمُونَ تَتَکَافَأُ دِمَاؤُہُمْ ، یَسْعَی بِذِمَّتِہِمْ أَدْنَاہُمْ ، وَہُمْ یَدٌ عَلَی مَنْ سِوَاہُمْ۔\n\n(ابوداؤد 4519۔ ابن ماجہ 2684)",,,28548,,
28549,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ عَلِیِّ بْنِ صَالِحٍ ، عَن سِمَاکٍ ، عَن عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : کَانَت قُرَیْظَۃُ وَالنَّضِیرُ ، وَکَانَتِ النَّضِیرُ أَشْرَفَ مِنْ قُرَیْظَۃَ ، فَکَانَ إِذَا قَتَلَ رَجُلٌ مِنْ قُرَیْظَۃَ رَجُلاً مِنَ النَّضِیرِ قُتِلَ بِہِ ، وَإِنْ قَتَلَ رَجُلٌ مِنَ النَّضِیرِ رَجُلاً مِنْ قُرَیْظَۃَ وَدَاہ مِئَۃَ وَسْقٍ مِنْ تَمْرٍ ، فَلَمَّا بُعِثَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَتَلَ رَجُلٌ مِنَ النَّضِیرِ رَجُلاً مِنْ قُرَیْظَۃَ ، قَالُوا : ادْفَعُوہُ إِلَیْنَا نَقْتُلُہُ ، فَقَالُوا : بَیْنَنَا وَبَیْنَکُمَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَأَتَوْہُ ، فَنَزَلَتْ : {وَإِنْ حَکَمْتَ فَاحْکُمْ بَیْنَہُمْ بِالْقِسْطِ} فَالْقِسْطُ : النَّفْسُ بِالنَّفْسِ ، ثُمَّ نَزَلَتْ : {أَفَحُکْمَ الْجَاہِلِیَّۃِ یَبْغُونَ}۔ (ابوداؤد 4488۔ نسائی 6934)",,,28549,,
28550,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَن مُجَاہِدٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : کَانَ فِی بَنِی إِسْرَائِیلَ الْقِصَاصُ ، وَلَمْ تَکُنْ فِیہِم الدِّیَۃُ ، فَقَالَ اللَّہُ لِہَذِہِ الأُمَّۃِ : {کُتِبَ عَلَیْکُمَ الْقِصَاصُ فِی الْقَتْلَی الْحُرُّ بِالْحُرِّ ، وَالْعَبْدُ بِالْعَبْدِ ، وَالأُنْثَی بِالأُنْثَی ، فَمَنْ عُفِیَ لَہُ مِنْ أَخِیہِ شَیْئٌ ، فَاتِّبَاعٌ بِالْمَعْرُوفِ وَأَدَائٌ إِلَیْہِ بِإِحْسَانٍ} فَالْعَفْوُ : أَنْ تُقْبَلَ الدِّیَۃُ فِی الْعَمْدِ : {ذَلِکَ تَخْفِیفٌ مِنْ رَبِّکُمْ وَرَحْمَۃٌ} قَالَ : فَعَلَی ہَذَا : أَنْ یَتَّبِعَ بِالْمَعْرُوفِ ، وَعَلَی ذَاکَ أَنْ یُؤَدِّیَ إِلَیْہِ بِإِحْسَانٍ، {فَمَنَ اعْتَدَی بَعْدَ ذَلِکَ فَلَہُ عَذَابٌ أَلِیمٌ}۔(بخاری4498۔ ابن الجارود 775)",,,28550,,
28551,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : مَا قَوْلُہُ : {الْحُرُّ بِالْحُرِّ وَالْعَبْدُ بِالْعَبْدِ}؟ قَالَ : الْعَبْدُ یَقْتُلُ عَبْدًا ، مِثْلَہُ ، فَہُوَ بِہِ قَوَدٌ ، وَإِنْ کَانَ الْقَاتِلُ أَفْضَلَ لَمْ یَکُنْ لَہُم إِلاَّ قِیمَۃُ الْمَقْتُولِ۔",,,28551,,
28552,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ سُفْیَانَ بْنِ حُسَیْنٍ ، عَنِ ابْنِ أَشْوَعَ ، عَنِ الشَّعْبِیِّ ، قَالَ : کَانَ بَیْنَ حَیَّیْنِ مِنَ الْعَرَبِ قِتَالٌ ، فَقُتِلَ مِنْ ہَؤُلاَئِ وَمِنْ ہَؤُلاَئِ ، فَقَالَ أَحَدُ الْحَیَّیْنِ : لاَ نَرْضَی حَتَّی نَقْتُلَ بِالْمَرْأَۃِ الرَّجُلَ ، وَبِالرَّجُلِ الرَّجُلَیْنِ ، قَالَ : فَأَبَی عَلَیْہِم الآخَرُونَ ، فَارْتَفَعُوا إِلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْقَتْلُ بَوَائٌ ، أَیْ سَوَائٌ ، قَالَ : فَاصْطَلَحَ الْقَوْمُ بَیْنَہُمْ عَلَی الدِّیَاتِ۔ قَالَ : فَحَسَبُوا لِلرَّجُلِ دِیَۃَ الرَّجُلِ ، وَلِلْمَرْأَۃِ دِیَۃَ الْمَرْأَۃِ ، وَلِلْعَبْدِ دِیَۃَ الْعَبْدِ ، فَقََضَی لأَحَدِ الْحَیَّیْنِ عَلَی الآخَرِ ، قَالَ : فَہُوَ قَوْلُہُ : {یَا أَیُّہَا الَّذِینَ آمَنُوا کُتِبَ عَلَیْکُمُ الْقِصَاصُ فِی الْقَتْلَی الْحُرُّ بِالْحُرِّ ، وَالْعَبْدُ بِالْعَبْدِ ، وَالأُنْثَی بِالأُنْثَی}۔\n\nقَالَ سُفْیَانُ : {فَمَنْ عُفِیَ لَہُ مِنْ أَخِیہِ شَیْئٌ} ، قَالَ : فَمَنْ فَضَلَ لَہُ عَلَی أَخِیہِ شَیْئٌ فَلْیُؤَدِّہِ بِالْمَعْرُوفِ ، وَلِیَتْبَعہُ الطَّالِبُ بِإِحْسَانٍ ، إِلَی قَولِہِ : {عَذَابٌ أَلِیمٌ}۔",,,28552,,
28553,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ ، وَحَمَّادًا عَن غَنَمٍ سَقَطَتْ فِی زَرْعِ قَوْمٍ ؟ قَالَ حَمَّادٌ : لاَ یُضَمَّنُ ، وَقَالَ الْحَکَمُ : یُضَمَّنُ۔",,,28553,,
28554,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَن طَارِقٍ ، عَنِ الشَّعْبِیِّ ؛ أَنَّ شَاۃً دَخَلَتْ عَلَی نَسَّاجٍ فَأَفْسَدَتْ غَزْلَہُ، فَلَمْ یُضَمِّنِ الشَّعْبِیُّ صَاحِبَ الشَّاۃِ بِالنَّہَارِ۔,,,28554,,
28555,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدٍ ، وَحَرَامِ بْنِ سَعْدٍ ؛ أَنَّ نَاقَۃً لِلْبَرَائِ بْنِ عَازِبٍ دَخَلَتْ حَائِطَ قَوْمٍ فَأَفْسَدَتْ عَلَیْہِمْ ، فَقَضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنَّ حِفْظَ الأَمْوَالِ عَلَی أَہْلِہَا بِالنَّہَارِ ، وَأَنَّ عَلَی أَہْلِ الْمَاشِیَۃِ مَا أَصَابَتِ الْمَاشِیَۃُ بِاللَّیْلِ۔ (ابوداؤد 3565۔ احمد 295),,,28555,,
28556,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ (ح) وَإِسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنِ الشَّعْبِیِّ ؛ أَنَّ شَاۃً أَکَلَتْ عَجِینًا ، وَقَالَ الآخَرُ : غَزْلاً نَہَارًا ، فَأَبْطَلَہُ شُرَیْحٌ ، وَقَرَأَ : {إِذْ نَفَشَتْ فِیہِ غَنَمُ الْقَوْمِ}، فَقَالَ فِی حَدِیثِ إِسْمَاعِیلَ : إِنَّمَا کَانَ النَّفْشُ بِاللَّیْلِ۔",,,28556,,
28557,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ أَبِی خَالِدٍ ، عَنْ عَامِرٍ ، قَالَ : جَائَ رَجُلٌ إِلَی شُرَیْحٍ ، فَقَالَ : إِنَّ شَاۃَ ہَذَا قَطَعَتْ غَزْلِی ، فَقَالَ : لَیْلاً ، أَوْ نَہَارًا ؟ فَإِنْ کَانَ نَہَارًا ، فَقَدْ بَرِئَ ، وَإِنْ کَانَ لَیْلاً ، فَقَدْ ضَمِنَ ، وَقَرَأَ : {إِذْ نَفَشَتْ فِیہِ غَنَمُ الْقَوْمِ} ، وَقَالَ : إِنَّمَا کَانَ النَّفْشُ بِاللَّیْلِ۔",,,28557,,
28558,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إِسْرَائِیلُ ، عَنْ أَبِی إِسْحَاقَ ، عَن مُرَّۃَ بْنِ شَرَاحِیلَ ، عَن مَسْرُوقٍ ؛ {إِذْ نَفَشَتْ فِیہِ غَنَمُ الْقَوْمِ} ، قَالَ : کَانَ کَرمًا ، فَدَخَلَتْ فِیہِ لَیْلاً ، فَمَا أَبْقَتْ فِیہِ خَضِرًا۔",,,28558,,
28559,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ مُحَمَّدِ بْنِ عَلِیٍّ ، قَالَ : قَالَ عُثْمَانُ : مَنْ جَالَسَ أَعْمَی ، فَأَصَابَہُ الأَعْمَی بِشَیْئٍ ، فَہُوَ ہَدَرٌ۔",,,28559,,
28560,"حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنِ الْحَارِثِ بْنِ حَصیرۃ ، عَن زَیْدِ بْنِ وَہْبٍ ؛ أَنَّ عَلِیًّا لَمَّا رَجَمَ الْمَرْأَۃَ قَالَ لأَوْلِیَائِہَا : ہَذَا ابْنُکُمْ تَرِثُونَہُ وَیَرِثُکُمْ ، وَإِنْ جَنَی جِنَایَۃً فَعَلَیْکُمْ۔",,,28560,,
28561,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا لاَعَنِ الرَّجُلُ امْرَأَتَہُ فُرِّقَ بَیْنَہُمَا ، وَلاَ یَجْتَمِعَانِ أَبَدًا، وَأُلْحِقَ الْوَلَدُ بِعَصَبَۃِ أُمِّہِ ، یَرِثُونَہُ وَیَعْقِلُونَ عَنْہُ۔",,,28561,,
28562,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ عُمَرَ ، عَن حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : مِیرَاثُہُ کُلُّہُ لأُِمِّہِ ، وَیَعْقِلُ عَنْہُ عَصَبَتُہَا ، کَذَلِکَ وَلَدُ الزِّنَی ، وَوَلَدُ النَّصْرَانِیِّ وَأُمّہُ مُسْلِمَۃٌ۔",,,28562,,
28563,"حَدَّثَنَا مُحَمَّدُ بْنُ یَزِیدَ ، عَنْ أَبِی الْعَلاَئِ ، عَنْ قَتَادَۃَ ، وَأَبِی ہَاشِمٍ ، قَالاَ فِی رَجُلٍ قَتَلَ رَجُلاً عَمْدًا ، فَحُبِسَ لِیُقَادَ بِہِ ، فَجَائَ رَجُلٌ فَقَتَلَہُ عَمْدًا ، قَالاَ : لاَ یُقَادُ بِہِ۔",,,28563,,
28564,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : إِذَا قَتَلَ الرَّجُلُ مُتَعَمِّدًا ، ثُمَّ قَتَلَ الْقَاتِلَ رَجُلٌ مُتَعَمِّدًا ، قُتِلَ الأَوْسَطُ۔",,,28564,,
28565,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَن قَیْسِ بْنِ مُسْلِمٍ ، عَن طَارِقِ بْنِ شِہَابٍ ، عَنِ الْہَیْثَمِ بْنِ الأَسْوَدِ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ؛ {فَمَنْ تَصَدَّقَ بِہِ فَہُوَ کَفَّارَۃٌ لَہُ} ، قَالَ : ہُدِمَ عَنْہُ مِنْ ذُنُوبِہِ مِثْلُ ذَلِکَ۔",,,28565,,
28566,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ؛ {فَمَنْ تَصَدَّقَ بِہِ فَہُوَ کَفَّارَۃٌ لَہُ} قَالَ : لِلْمَجْرُوحِ ، وَقَالَ مُجَاہِدٌ : لِلْجَارِحِ۔",,,28566,,
28567,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَن مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، وَمُجَاہِدٍ ، قَالاَ : کَفَّارَۃٌ لِلْجَارِحِ ، وَأَجْرُ الَّذِی أُصِیبَ عَلَی اللہِ۔",,,28567,,
28568,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ سُفْیَانَ بْنِ حُسَیْنٍ ، عَنِ الْحَسَنِ ؛ {فَمَنْ تَصَدَّقَ بِہِ فَہُوَ کَفَّارَۃٌ لَہُ} قَالَ: لِلْمَجْرُوحِ۔",,,28568,,
28569,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَن زَیْدِ بْنِ أَسْلَمَ ، قَالَ : سَمِعْتُہ یَقُولُ : إِنْ عَفَی عَنْہُ ، أَوِ اقْتَصَّ مِنْہُ ، أَوْ قَبِلَ مِنْہُ الدِّیَۃَ فَہُوَ کَفَّارَۃٌ۔",,,28569,,
28570,"حَدَّثَنَا جَرِیرٌ ، عَن مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، وَمُجَاہِدٍ ، قَالاَ : کَفَّارَۃٌ لِلَّذِی تَصَدَّقَ عَلَیْہِ ، وَأَجْرُ الَّذِی أُصِیبَ عَلَی اللہِ۔",,,28570,,
28571,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، وَیَحْیَی بْنُ آدَمَ ، عَنْ سُفْیَانَ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ {فَمَنْ تَصَدَّقَ بِہِ فَہُوَ کَفَّارَۃٌ لَہُ} ، قَالَ : لِلْجَارِحِ ، وَأَجرُ الْمُتَصَدِق عَلَی اللہِ۔",,,28571,,
28572,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَن عُمَارَۃَ ، عَنْ أَبِی عُقْبَۃَ ، عَنْ جَابِرِ بْنِ زَیْدٍ ؛ {فَمَنْ تَصَدَّقَ بِہِ فَہُوَ کَفَّارَۃٌ لَہُ} ، قَالَ : لِلجَارِحِ۔",,,28572,,
28573,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ أَبِی إِدْرِیسَ ، عَن عُبَادَۃَ بْنِ الصَّامِتِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ أَنَّہُ قَالَ : تُبَایِعُونِی عَلَی أَنْ لاَ تُشْرِکُوا بِاَللَّہِ شَیْئًا ، وَلاَ تَزْنُوا ، وَلاَ تَسْرِقُوا ، فَمَنْ أَصَابَ مِنْ ذَلِکَ شَیْئًا فَعُوقِبَ بِہِ ، فَہُوَ کَفَّارَتُہُ۔ (بخاری 4894۔ مسلم 1333)",,,28573,,
28574,"حَدَّثَنَا وَکِیعٌ ، عَن زَکَرِیَّا ، عَنِ الشَّعْبِیِّ ، قَالَ : لِلَّذِی تَصَدَّقَ بِہِ۔",,,28574,,
28575,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنِ الْحَارِثِ بْنِ فُضَیْلٍ ، عَنِ ابْنِ أَبِی الْعَوْجَائِ ، عَنْ أَبِی شُرَیْحٍ الْخُزَاعِیِّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: مَنْ أُصِیبَ بِدَمٍ ، أَوْ خَبْلٍ ، وَالْخَبْلُ: الْجُرْحُ ، فَہُوَ بِالْخِیَارِ بَیْنَ إِحْدَی ثَلاَثٍ ، فَإِنْ أَرَادَ الرَّابِعَۃَ فَخُذُوا عَلَی یَدَیْہِ ؛ أَنْ یَقْتُلَ ، أَوْ یَعْفُوَ ، أَوْ یَأْخُذَ الدِّیَۃَ ، فَمَنْ فَعَلَ شَیْئًا مِنْ ذَلِکَ فَعَادَ ، فَلَہُ نَارُ جَہَنَّمَ خَالِدًا مُخَلَّدًا فِیہَا أَبَدًا۔ (ابوداؤد 4490۔ احمد 31)",,,28575,,
28576,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَوْفٍ ، عَن حَمْزَۃَ أَبِی عُمَرَ ، عَنْ عَلْقَمَۃَ بْنِ وَائِلٍ ، عَنْ أَبِیہِ ، قَالَ : شَہِدْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حِینَ أُتِیَ بِالْقَاتِلِ یُجَرُّ فِی نِسْعَتِہِ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لِوَلِیِّ الْمَقْتُولِ ، أَتَعْفُو عَنْہُ ؟ قَالَ : لاَ ، قَالَ : فَتَأْخُذُ الدِّیَۃَ ؟ قَالَ : لاَ ، قَالَ : فَتَقْتُلُہُ ؟ قَالَ : نَعَمْ ، فَأَعَادَ عَلَیْہِ ثَلاَثًا ، فَقَالَ لَہُ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنْ عَفَوْتَ عَنْہُ فَإِنَّہُ یَبُوئُ بِإِثْمِہِ ، قَالَ : فَعَفَا ، فَرَأَیْتُہُ یَجُرُّ نِسْعَتَہُ ، قَدْ عُفِیَ عَنْہُ۔",,,28576,,
28577,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قُتِلَ رَجُلٌ عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَرُفِعَ ذَلِکَ إِلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَدَفَعَہُ إِلَی وَلِیِّ الْمَقْتُولِ ، فَقَالَ الْقَاتِلُ : یَا رَسُولَ اللہِ ، مَا أَرَدْتُ قَتْلَہُ ، قَالَ : فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لِلْوَلِیِّ : أَمَا إِنْ کَانَ صَادِقًا ، ثُمَّ قَتَلْتَہُ دَخَلْتَ النَّارَ ، قَالَ : فَخَلَّی سَبِیلَہُ۔ قَالَ : وَکَانَ مَکْتُوفًا بِنِسْعَۃٍ ، قَالَ : فَخَرَجَ یَجُرُّ نِسْعَتَہُ ، قَالَ : فَسُمِّیَ ذَا النِّسْعَۃِ۔ (ابوداؤد 4492۔ ترمذی 1407)",,,28577,,
28578,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ ، وَحَمَّادًا عَن حُرٍّ وَعَبْدٍ اصْطَدَمَا فَمَاتَا ؟ قَالاَ : أَمَّا دِیَۃُ الْحُرِّ فَلَیْسَتْ عَلَی الْمَمْلُوکِ ، وَأَمَّا دِیَۃُ الْمَمْلُوکِ فَعَلَی الْعَاقِلَۃِ۔",,,28578,,
28579,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ الْقَطَّانُ ، عَنْ سُفْیَانَ ، عَن سِمَاکٍ ، عَن عِکْرِمَۃَ (ح) وَعن مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ؛ {وَإِنْ کَانَ مِنْ قَوْمٍ بَیْنَکُمْ وَبَیْنَہُمْ مِیثَاقٌ} ، قَالاَ : الرَّجُلُ یُسْلِمُ فِی دَارِ الْحَرْبِ فَیَقْتُلُہُ الرَّجُلُ ، لَیْسَ عَلَیْہِ الدِّیَۃُ ، وَعَلَیْہِ الْکَفَّارَۃُ۔",,,28579,,
28580,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ؛ فِی قَوْلِہِ تَعَالَی : {وَمَنْ قَتَلَ مُؤْمِنًا خَطَأً فَتَحْرِیرُ رَقَبَۃٍ مُؤْمِنَۃٍ وَدِیَۃٌ مُسَلَّمَۃٌ إِلَی أَہْلِہِ} ، إِذَا قُتِلَ الْمُسْلِمُ فَہَذَا لَہُ وَلِوَرَثَتِہِ الْمُسْلِمِینَ ، {فَإِنْ کَانَ مِنْ قَوْمٍ عَدُوٍّ لَکُمْ وَہُوَ مُؤْمِنٌ}، الرَّجُلُ الْمُسْلِمُ یقْتَلُ وَقَوْمُہُ مُشْرِکُونَ، لَیْسَ بَیْنَہُمْ وَبَیْنَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَہْدٌ، فَعَلَیْہِ تَحْرِیرُ رَقَبَۃٍ مُؤْمِنَۃٍ ، وَإِنْ قَتَلَ مُسْلِمًا مِنْ قَوْمٍ مُشْرِکِینَ وَبَیْنَہُمْ وَبَیْنَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَہْدٌ ، فَعَلَیْہِ تَحْرِیرُ رَقَبَۃٍ مُؤْمِنَۃٍ ، وَتُؤَدَی دِیَتُہُ إِلَی قَوْمِہِ الَّذِینَ بَیْنَہُمْ وَبَیْنَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَہْدٌ ، فَیَکُونُ مِیرَاثُہُ لِلْمُسْلِمِینَ ، وَیَکُونُ عَقْلُہُ لِقَوْمِہِ الْمُشْرِکِینَ الَّذِینَ بَیْنَہُمْ وَبَیْنَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَہْدٌ ، فَیَرِثُ الْمُسْلِمُونَ مِیرَاثَہُ ، وَیَکُونُ عَقْلُہُ لِقَوْمِہِ لأَنَّہُمْ یَعْقِلُونَ عَنْہُ۔",,,28580,,
28581,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَن عِیسَی بْنِ مُغِیرَۃَ ، عَنِ الشَّعْبِیِّ ؛ فِی قَوْلِہِ : {وَإِنْ کَانَ مِنْ قَوْمٍ بَیْنَکُمْ وَبَیْنَہُمْ مِیثَاقٌ} ، قَالَ : مِنْ أَہْلِ الْعَہْدِ وَلَیْسَ بِمُؤْمِنٍ۔",,,28581,,
28582,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، قَالَ : حدَّثَنَا عَمَّارُ بْنُ رُزَیْقٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ أَبِی یَحْیَی ، عَنِ ابْنِ عَبَّاسٍ ؛ {فَإِنْ کَانَ مِنْ قَوْمٍ عَدُوٍّ لَکُمْ وَہُوَ مُؤْمِنٌ فَتَحْرِیرُ رَقَبَۃٍ مُؤْمِنَۃٍ} قَالَ : کَانَ الرَّجُلُ یَأْتِی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَیُسْلِمُ ، ثُمَّ یَرْجِعُ إِلَی قَوْمِہِ فَیَکُونُ فِیہِمْ وَہُمْ مُشْرِکُونَ ، فَیُصِیبُہُ الْمُسْلِمُونَ خَطَأً فِی سَرِیَّۃٍ ، أَوْ غَزَاۃٍ ، فَیُعْتِقُ الَّذِی یُصِیبُہُ رَقَبَۃً ، {وَإِنْ کَانَ مِنْ قَوْمٍ بَیْنَکُمْ وَبَیْنَہُمْ مِیثَاقٌ} ، قَالَ : ہُوَ الرَّجُلُ یَکُونُ مُعَاہَدًا ، وَیَکُونُ قَوْمُہُ أَہْلَ عَہْدٍ ، فَیُسْلَمُ إِلَیْہِم الدِّیَۃُ ، وَیُعْتِقُ الَّذِی أَصَابَہُ رَقَبَۃً۔",,,28582,,
28583,حَدَّثَنَا یَحْیَی بْنُ عَبْدِ الْمَلِکِ بْنِ أَبِی غَنِیَّۃَ ، عَنْ أَبِیہِ ، عَنِ الْحَکَمِ ؛ أَنَّ الْعَبَّاسَ بْنَ عَبْدِ الْمُطَّلِبِ لَطَمَ رَجُلاً ، فَأَقَادَہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِنَ الْعَبَّاسِ ، فَعَفَا عَنْہُ۔ (نسائی 6977),,,28583,,
28584,"حَدَّثَنَا أَبُو عَبْدِ الرَّحْمَنِ الْمَسْعُودِیُّ : عَبْدِ اللہِ بْنِ عَبْدِ الْمَلِکِ بْنِ أَبِی عُبَیْدَۃَ ، عَن نَاجِیَۃَ أَبِی الْحَسَنِ ، عَنْ أَبِیہِ ؛ أَنَّ عَلِیًّا قَالَ فِی رَجُلٍ لَطَمَ رَجُلاً ، فَقَالَ لِلْمَلْطُومِ : اقْتَصَّ۔",,,28584,,
28585,حَدَّثَنَا وَکِیعٌ ، عَنِ الْحَسَنِ بْنِ صَالِحٍ ، عَن مُخَارِقٍ ، عَن طَارِقِ بْنِ شِہَابِ ؛ أَنَّ خَالِدَ بْنَ الْوَلِیدِ أَقَادَ رَجُلاً مِنْ مُرَادٍ مِنْ لَطْمَۃٍ لَطَمَ ابْنَ أَخِیہِ۔,,,28585,,
28586,حَدَّثَنَا شَرِیکٌ ، عَن مُخَارِقٍ ، عَن طَارِقٍ ؛ أَنَّ خَالِدَ بْنَ الْوَلِیدِ أَقَادَ مِنْ لَطْمَۃ۔,,,28586,,
28587,حَدَّثَنَا شَرِیکٌ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ شُرَیْحٍ ؛ أَنَّہُ أَقَادَ مِنْ لَطْمَۃٍ وَخُمَاشٍ۔,,,28587,,
28588,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ شُرَیْحٍ ؛ أَنَّہُ أَقَادَ مِنْ لَطْمَۃٍ۔",,,28588,,
28589,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنِ ابْنِ الزُّبَیْرِ ؛ أَنَّہُ أَقَادَ مِنْ لَطْمَۃٍ۔,,,28589,,
28590,حَدَّثَنَا أَبُو عَبْدِالرَّحْمَنِ الْمَسْعُودِیُّ، عَن زُرَارَۃَ بْنِ یَحْیَی، عَنْ أَبِیہِ؛ أَنَّ الْمُغِیرَۃَ بْنَ عَبْدِاللہِ أَقَادَ مِنْ لَطْمَۃٍ۔,,,28590,,
28591,"حَدَّثَنَا شَبَابَۃُ، عَنْ شُعْبَۃَ، عَنْ یَحْیَی بْنِ الْحُصَیْنِ، قَالَ: سَمِعْتُ طَارِقَ بْنَ شِہَابٍ ، یَقُولُ : لَطَمَ أَبُوبَکْرٍ یَوْمًا رَجُلاً لَطْمَۃً، فَقِیلَ: مَا رَأَیْنَا کَالْیَوْمِ قَطُّ، مَنْعَہُ وَلَطْمَہُ، فَقَالَ أَبُوبَکْرٍ: إِنَّ ہَذَا أَتَانِی لِیَسْتَحْمِلُنِی، فَحَمَلْتُہُ فَإِذَا ہُوَ یَبیعُہُمْ ، فَحَلَفْت أَنْ لاَ أَحْمِلَہُ : وَاللَّہِ لاَ حَمَلْتُہُ ، ثَلاَثَ مَرَّاتٍ ، ثُمَّ قَالَ لَہُ : اقْتَصَّ ، فَعَفَا الرَّجُلُ۔",,,28591,,
28592,"حَدَّثَنَا وَکِیعٌ ، عَن حَسَنِ بْنِ صَالِحٍ ، قَالَ : قُلْتُ لاِبْنِ أَبِی لَیْلَی : أقَدْتَ مِنْ لَطْمَۃٍ ؟ قَالَ : نَعَمْ ، وَمِنْ لَطَمَاتٍ۔",,,28592,,
28593,حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنِ الشَّعْبِیِّ ، عَن مَسْرُوقٍ ؛ أَنَّہُ أَقَادَ مِنْ لَطْمَۃٍ۔,,,28593,,
28594,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّ جِلْوَازًا قَنَعَ رَجُلاً بِسَوْطٍ ، فَأَقَادَہُ مِنْہُ شُرَیْحٌ۔",,,28594,,
28595,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ أَشْعَثَ ، عَنْ فُضَیْلٍ ، عَنْ عَبْدِاللہِ بْنِ مغفلٍ، قَالَ: کُنْتُ جَالِسًا عَندَ عَلِیٍّ، فَجَائَہُ رَجُلٌ فَسَارَّہُ ، فَقَالَ عَلِیٌّ : یَا قَنْبَرُ ، فَقَالَ النَّاسُ : یَا قَنْبَرُ ، قَالَ : أَخْرِجْ ہَذَا فَاجْلِدْہُ ، ثُمَّ جَائَ الْمَجْلُودُ، فَقَالَ : إِنَّہُ قَدْ زَادَ عَلَیَّ ثَلاَثَۃَ أَسْوَاطٍ ، فَقَالَ لَہُ عَلِیٌّ : مَا یَقُولُ ؟ قَالَ : صَدَقَ یَا أَمِیرَ الْمُؤْمِنِینَ ، قَالَ : خُذِ السَّوْطَ فَاجْلِدْہُ ثَلاَثَۃَ أَسْوَاطٍ ، ثُمَّ قَالَ : یَا قَنْبَرُ ، إِذَا جَلَدْتَ فَلاَ تَعْد الْحُدُودَ۔",,,28595,,
28596,"حَدَّثَنَا حَفْصٌ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ، وَالْحَکَمِ ، وَحَمَّادٍ ، قَالُوا : مَا أُصِیبَ بِہِ سَوْطٍ ، أَوْ عَصًا، أَوْ حَجَرٍ ، فَکَانَ دُونَ النَّفْسِ فَہُوَ عَمْدٌ ، دِیَتُہُ الْقَوَدُ۔",,,28596,,
28597,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ؛ فِی رَجُلٍ اسْتَعَارَ مِنْ رَجُلٍ فَرَسًا ، فَرَکضَہُ حَتَّی مَاتَ ، قَالَ : لَیْسَ عَلَیْہِ ضَمَانٌ لأَنَّ الرَّجُلَ یُرْکِضُ فَرَسَہُ۔",,,28597,,
28598,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ؛ فِی رَجُلٍ أَعْطَی رَجُلاً فَرَسًا فَقَتَلَہُ ، قَالَ : لاَ یَضْمَنُ ، إِلاَّ أَنْ یَکُونَ عَبْدًا ، أَوْ صَبِیًّا۔",,,28598,,
28599,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا زُہَیْرٌ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ؛ فِی رَجُلٍ قَتَلَ رَجُلاً قَدْ ذَہَبَتِ الرُّوحُ مِنْ نِصْفِ جَسَدِہِ ، قَالَ : یُضَمَّنُہُ۔",,,28599,,
28600,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، قَالَ : مَنْ أَوْقَفَ دَابَّتَہُ فِی طَرِیقِ الْمُسْلِمِینَ ، أَوْ وَضَعَ شَیْئًا ، فَہُوَ ضَامِنٌ لِجِنَایَتِہِ۔",,,28600,,
28601,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ أَشْعَثَ ؛ عَنِ الشَّعْبِیِّ (ح) وَعَن حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالاَ : مَنْ رَبَطَ دَابَّۃً فِی طَرِیقٍ فَہُوَ ضَامِنٌ۔",,,28601,,
28602,حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ لاَ یُوَقِّتُ فِی الْہَاشِمَۃِ شَیْئًا۔,,,28602,,
28603,حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ قَتَادَۃَ ؛ أَنَّ عَبْدَ الْمَلِکِ بْنَ مَرْوَانَ قَضَی فِی الدَّامِیَۃِ بِبَعِیرٍ ، وَفِی الْبَاضِعَۃِ بِبَعِیرَیْنِ ، وَقَضَی فِی الْمُتَلاَحِمَۃِ بِثَلاَثَۃِ أَبْعِرَۃٍ۔,,,28603,,
28604,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ (ح) وَعَن حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ؛ فِی الْعَبْدَیْنِ یَفْقَأُ أَحَدُہُمَا عَیْنَ صَاحِبِہِ ، قَالَ : إِنْ کَانَتْ قِیمَتُہُمَا سَوَائً ، فَالْعَیْنُ بِالْعَیْنِ ، وَإِنْ کَانَتْ قِیمَۃُ أَحَدِہِمَا أَکْثَرَ مِنَ الآخَرِ ، رُدَّ الأَکْثَرُ عَلَی الأَقَلِّ۔",,,28604,,
28605,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : الْعَبْدُ یَقْتُلُ الْعَبْدَ عَمْدًا ، وَالْمَقْتُولُ خَیْرٌ مِنَ الْقَاتِلِ ؟ قَالَ : لَیْسَ لِسَادَۃِ الْمَقْتُولِ إِلاَّ قَاتِلُ عَبْدِہِمْ ، لَیْسَ لَہُمْ غَیْرَہُ۔ وَقَالَہَا عَمْرُو بْنُ دِیِنَارٍ : لَیْسَ لَہُمْ إِلاَّ قَاتِلُ عَبْدِہِم ، إِنْ شَاؤُوا قَتَلُوہُ ، وَإِنْ شَاؤُوا اسْتَرَقوہُ۔",,,28605,,
28606,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ مَعْمَرٍ ، عَنْ زِیَادِ بْنِ مُسْلِمٍ ؛ أَنَّ رَجُلاً مِنْ أَہْلِ الْہِنْدِ قَدِمَ بِأَمَانٍ عَدَنَ ، فَقَتَلَہُ رَجُلٌ مِنَ الْمُسْلِمِینَ بِأَخِیہِ ، فَکَتَبَ فِی ذَلِکَ إِلَی عُمَرَ بْنِ عَبْدِ الْعَزِیزِ فَکَتَبَ : أَنْ لاَ تَقْتُلْہُ وَخُذْ مِنْہُ الدِّیَۃَ ، فَابْعَثْ بِہَا إِلَی وَرَثَتِہِ ، وَأَمَرَ بِہِ فَسُجِنَ۔",,,28606,,
28607,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَن یُوسُفَ بْنِ یَعْقُوبَ ؛ أَنَّ رَجُلاً مِنَ الْمُشْرِکِینَ قَتَلَ رَجُلاً مِنَ الْمُسْلِمِینَ ، ثُمَّ دَخَلَ بِأَمَانٍ فَقَتَلَہُ أَخُوہُ ، فَقَضَی عَلَیْہِ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ بِالدِّیَۃِ ،وَجَعَلَہَا عَلَیْہِ فِی مَالِہِ ، وَحَبَسَہُ فِی السِّجْنِ ، وَبَعَثَ بِدِیَتِہِ إِلَی وَرَثَتِہِ مِنْ أَہْلِ الْحَرْبِ۔,,,28607,,
28608,حَدَّثَنَا الثَّقَفِیُّ ، عَن حَبِیبٍ الْمُعَلِّمِ ، عَنِ الْحَسَنِ ؛ أَنَّ رَجُلاً مِنَ الْمُشْرِکِینَ حَجَّ ، فَلَمَّا رَجَعَ صَادِرًا لَقِیَہُ رَجُلٌ مِنَ الْمُسْلِمِینَ فَقَتَلَہُ ، فَأَمَرَہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یُؤَدِّی دِیَتَہُ إِلَی أَہْلِہِ۔ (ابوداؤد 367),,,28608,,
28609,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ أَبِی حُرَّۃَ ، عَنِ الْحَسَنِ ؛ فِی قَوْمٍ لَقُوا العَدُو فَاسْتَأْجَلُوہُمْ خَمْسَۃَ أَیَّامٍ ، فَقُتِلَ بَیْنَہُمْ قَتِیلٌ ، قَالَ : عَلَی الْمُسْلِمِینَ دِیَتُہُ۔",,,28609,,
28610,"حَدَّثَنَا حَفْصٌ ، عَنْ أَبِی طَلْقٍ ، عَنْ أُخْتِہِ ہِنْدِ بِنْتِ طَلْقٍ ، قَالَتْ : کُنْتُ فِی نِسْوَۃٍ وَصَبِیٌّ مُسَجًّی ، قَالَتْ : فَمَرَّتِ امْرَأَۃٌ فَوَطَئَتْہُ ، قُلْتُ : الصَّبِیَّ قَتَلَتْہُ وَاللَّہِ ، قَالَتْ : فَشَہِدْنَ عِندَ عَلِیٍّ عَشْرُ نِسْوَۃٍ ، أَنَا عَاشِرَتُہُنَّ ، فَقَضَی عَلَیْہَا بِالدِّیَۃِ ، وَأَعَانَہَا بِأَلْفَیْنِ۔",,,28610,,
28611,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ أَبِی حَنِیفَۃَ ، عَن حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لاَ یَکُونُ التَّغْلِیظُ فِی شَیْئٍ مِنَ الدِّیَۃِ ، إِلاَّ فِی الإِبِلِ ، وَالتَّغْلِیظُ فِی إِنَاثِ الإِبِلِ۔",,,28611,,
28612,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ؛ فِی امْرَأَۃٍ ضُرِبَتْ فَأَسْقَطَتْ ثَلاَثَۃَ أَسْقَاطٍ ، قَالَ : أَرَی أَنَّ فِی کُلِّ وَاحِدٍ مِنْہُمْ غُرَّۃً ، کَمَا أَنَّ فِی کُلِّ وَاحِدٍ مِنْہُم الدِّیَۃَ۔",,,28612,,
28613,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : أَرَی الْعُطَاسَ اسْتِہْلاَلاً۔",,,28613,,
28614,"حَدَّثَنَا وَکِیعٌ ، قَالَ: حدَّثَنَا إِسْرَائِیلُ ، عَن سِمَاکٍ، عَن عِکْرِمَۃَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: اسْتِہْلاَلُہُ صِیَاحُہُ۔",,,28614,,
28615,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَن سُلَیْمَانَ بْنِ بِلاَلٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنِ الْقَاسِمِ بْنِ مُحَمَّدٍ ، قَالَ : الاِسْتِہْلاَلُ النِّدَائُ ، أَوِ الْعُطَاسُ۔",,,28615,,
28616,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَن زَائِدَۃَ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : الاِسْتِہْلاَلُ الصِّیَاحُ۔",,,28616,,
28617,حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَن صَاعِدِ بْنِ مُسْلِمٍ ، عَنِ الشَّعْبِیِّ ؛ فِی اللِّحْیَۃِ الدِّیَۃُ ، إِذَا نُتِفَتْ فَلَمْ تَنْبُتْ۔,,,28617,,
28618,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَاصِمٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ ، کَانَ عُمَرُ بْنُ الْخَطَّابِ یُعَدِّی الْمَمْلُوکَ عَلَی سَیِّدِہِ إِذَا اسْتَعْدَاہُ ، قَالَ مُحَمَّدٌ : اسْتَعْدَی أَبِی عَلَی أَنَسٍ عُمَرَ۔",,,28618,,
28619,حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ مُطَرِّفٍ ، عَنِ الْحَارِثِ ؛ أَنَّ عَبْدًا أَتَی عَلِیًّا قَدْ وَسَمَہُ أَہْلُہُ ، فَأَعْتَقَہُ۔,,,28619,,
28620,"حَدَّثَنَا جَرِیرٌ، عَنْ مُغِیرَۃَ، عَن حَمَّادٍ، عَنْ إِبْرَاہِیمَ، قَالَ: إِذَا دَخَلَ اللِّصُّ دَارَ الرَّجُلِ فَقَتَلَہُ فَلاَ ضِرَارَ عَلَیْہِ۔",,,28620,,
28621,"حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : اقْتُلِ اللِّصَّ وَأَنَا ضَامِنٌ أَنْ لاَ تَتْبَعَک مِنْہُ تَبِعَۃٌ۔",,,28621,,
28622,حَدَّثَنَا عَبْدَۃُ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمِ بْنِ عَبْدِ اللہِ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ وَجَدَ سَارِقًا فِی بَیْتِہِ ، فَأَصْلَتَ عَلَیْہِ بِالسَّیْفِ ، وَلَوْ تَرَکْنَاہُ لَقَتَلَہُ۔,,,28622,,
28623,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عنْ حُمَیْدِ بْنِ ہِلاَلٍ ، عَن حُجَیْرِ بْنِ الرَّبِیعِ ، قَالَ : قُلْتُ لِعِمْرَانَ بْنِ حُصَیْنٍ : أَرَأَیْتَ إِنْ دَخَلَ عَلَیَّ دَاخِلٌ ، یُرِیدُ نَفْسِی وَمَالِی ؟ فَقَالَ : لَوْ دَخَلَ عَلَیَّ دَاخِلٌ یُرِیدُ نَفْسِی وَمَالِی، لَرَأَیْتُ أَنْ قَدْ حَلَّ لِی قَتْلُہُ۔",,,28623,,
28624,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَن سِمَاکٍ ، عَن قَابُوسَ بْنِ الْمُخَارِقِ ، عَنْ أَبِیہِ ، قَالَ : أَتَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجُلٌ ، فَقَالَ : یَا رَسُولَ اللہِ ، الرَّجُلُ یَأْتِینِی یُرِیدُ مَالِی ؟ قَالَ : ذَکِّرْہُ اللَّہَ ، قَالَ : فَإِنْ لَمْ یَذْکُرْ ؟ قَالَ : فَاسْتَعِنْ عَلَیْہِ بِمَنْ حَوْلَک مِنَ الْمُسْلِمِینَ ، قَالَ : فَإِنْ لَمْ یَکُنْ أَحَدٌ حَوْلِی مِنَ الْمُسْلِمِینَ ؟ قَالَ : فَاسْتَعِنْ عَلَیْہِ بِالسُّلْطَانِ ، قَالَ : فَإِنْ نَأَی عَنِّی السُّلْطَانُ ؟ قَالَ : فَقَاتِلْ دُونَ مَالِکَ حَتَّی تَمْنَعَ مَالَک ، وَتَکُونَ فِی شُہَدَائِ الآخِرَۃِ۔ (احمد 294۔ طبرانی 747)",,,28624,,
28625,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : سَمِعْتُہ یَقُولُ : مَا عَلِمْت أَنَّ أَحَدًا مِنَ الْمُسْلِمِینَ تَرَکَ قِتَالَ رَجُلٍ یَقْطَعُ عَلَیْہِ الطَّرِیقَ ، أَوْ یَطْرُقُہُ فِی بَیْتِہِ تَأَثُّمًا مِنْ ذَلِکَ۔",,,28625,,
28626,"حَدَّثَنَا عَبَّادٌ ، عَنْ عَوْفٍ ، عَنِ الْحَسَنِ ، قَالَ : اقْتُلِ اللِّصَّ ، وَالْحَرُورِیَّ ، وَالْمُسْتَعْرِضَ۔",,,28626,,
28627,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَن عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَن نَافِعٍ ، قَالَ : أَصْلَتَ ابْنُ عُمَرَ عَلَی لِصٍّ بِالسَّیْفِ ، فَلَوْ تَرَکْنَاہُ لَقَتَلَہُ۔",,,28627,,
28628,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَن طَلْحَۃَ بْنِ عَبْدِ اللہِ ، عَنْ سَعِیدِ بْنِ زَیْدٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ قُتِلَ دُونَ مَالِہِ فَہُوَ شَہِیدٌ۔ (ابوداؤد 4739۔ ترمذی 1421)",,,28628,,
28629,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : مَنْ قُتِلَ دُونَ مَالِہِ فَہُوَ شَہِیدٌ۔ (بخاری 2480۔ ابوداؤد 4738)",,,28629,,
28630,"حَدَّثَنَا ہشیم ، عن جریر ، عن الضحاک ، عن ابن عباس، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: مَنْ قُتِلَ دُونَ مَالِہِ فَہُوَ شَہِیدٌ۔ (احمد 305۔ طبرانی 12642)",,,28630,,
28631,"حَدَّثَنَا مَرْوَانُ ، عَنْ یَزِیدَ بْنِ سِنَانٍ ، عَنْ مَیْمُونِ بْنِ مِہْرَانَ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ قُتِلَ دُونَ مَالِہِ فَہُوَ شَہِیدٌ۔ (ابن ماجہ 2581)",,,28631,,
28632,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ جَابِرٍ، عَنْ عَامِرٍ، قَالَ: سَأَلَہُ ابْنُ ہُبَیْرَۃَ عَنِ الْعَقْلِ عَلَی رُؤُوسِ الرِّجَالِ، أَوْ عَلَی الأَعْطِیَۃِ ؟ قَالَ : لاَ ، بَلْ عَلَی رُؤُوسِ الرِّجَالِ۔",,,28632,,
28633,"حَدَّثَنَا وَکِیعٌ ، قَالَ : سَمِعْتُ سُفْیَانَ یَقُولُ : الْعَقْلُ ، وَالْقَسَامَۃُ ، وَالشُّفْعَۃُ عَلَی رُؤُوسِ الرِّجَالِ۔",,,28633,,
28634,"حَدَّثَنَا جَرِیرٌ ، عَن رَقَبَۃَ ، عَن حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ؛ فِی الْجَرَّۃِ تُوضَعُ عَلَی الْجِدَارِ فَتُصِیبُ إِنْسَانًا، قَالَ: إِنْ کَانَ أَصْلُ الْجِدَارِ لِصَاحِبِ الْجَرَّۃِ لَمْ یَضْمَنْ مَا أَصَابَتْ، وَفِی الشَّیْئِ یُوضَعُ عَلَیْہِ الشَّیْئِ مِنْ مِلْکِہِ۔",,,28634,,
28635,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، قَالَ : أَخْبَرَنَی أَشْعَثُ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ لاَ یَرَی أَنْ یَقْتَصَّ الرَّجُلُ مِنَ الرَّجُلَیْنِ فِیمَا دُونَ النَّفْسِ۔",,,28635,,
28636,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، کَانَ یَقُولُ : إِذَا قُتِلَتِ الْمَرْأَۃُ وَہِیَ حَامِلٌ فِدْیَۃٌ وَغُرَّۃٌ ، وَإِنْ لَمْ تُلْقِہِ۔",,,28636,,
28637,"حَدَّثَنَا مُحَمَّدُ بْنُ سَوَائٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ؛ فِی الْمَرْأَۃِ تُقْتَلُ وَہِیَ حَامِلٌ ، فِی جَنِینِہَا شَیْئٌ ؟ قَالَ: کَانَ یَقُولُ : لَیْسَ فِیہَا شَیْئٌ حَتَّی تَقْذِفَہُ۔",,,28637,,
28638,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَن مُوسَی بْنِ أَبِی الْفُرَاتِ ؛ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ قَالَ : أَیُّمَا عَبْدٍ قَتَلَ عَبْدًا عَمْدًا فَاقْتُلْہُ بِہِ ، وَثَمَنُ الأَوَّلِ فَأَخْرِجْہُ مِنْ بَیْتِ الْمَالِ ، فَأَعْطِہِ مَوَالِیَہُ۔",,,28638,,
28639,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ عَاصِمٍ ، قَالَ : کَتَبَ عَدِیُّ بْنُ أَرْطَاۃَ قَاضِی الْبَصْرَۃِ إِلَی عُمَرَ بْنِ عَبْدِ الْعَزِیزِ : إِنِّی وَجَدْتُ قَتِیلاً فِی سُوقِ الْجَزَّارِینَ ؟ فَقَالَ : أَمَّا الْقَتِیلُ فَدِیَتُہُ مِنْ بَیْتِ الْمَالِ۔",,,28639,,
28640,"حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ قَالَ : سَأَلْتُ الْحَکَمَ ، وَحَمَّادًا عَنِ الْمُکَارِی یَسُوقُ بِالْمَرْأَۃِ ؟ فَأَکْثَرُ عِلْمِی أَنَّہُمَا قَالاَ : لَیْسَ عَلَیْہِ ضَمَانٌ۔",,,28640,,
28641,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ الْمُجَالِدِ ، قَالَ : حدَّثَنَی عَرِیفٌ لِجُہَیْنَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أُوتِیَ بِأَسِیرٍ فِی الشِّتَائِ ، فَقَالَ لأُِنَاسٍ مِنْ جُہَیْنَۃَ : اذْہَبُوا بِہِ فَأَدْفُوہُ ، قَالَ : وَکَانَ الدَّفْئُ بِلِسَانِہِمْ عِنْدَہُمُ الْقَتْلَ ، فَذَہَبُوا بِہِ فَقَتَلُوہُ ، فَسَأَلَہُمُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَعْدُ ؟ فَقَالُوا : یَا رَسُولَ اللہِ ، أَلَمْ تَأْمُرْنَا أَنْ نَقْتُلَہُ ، قَالَ: وَکَیْفَ قُلْتُ لَکُمْ؟ قَالَ : قُلْتَ لَنَا: اذْہَبُوا بِہِ فَأَدْفُوہُ، قَالَ: فَقَالَ: قَدْ شَرِکْتُکُمْ إِذًا، اعْقِلُوہُ وَأَنَا شَرِیکُکُمْ۔\n\nقَالَ : فَحَدَّثْتُ ہَذَا الْحَدِیثَ عَامِرًا ، قَالَ : صَدَقَ ، وَعَرَفَ الْحَدِیثَ۔",,,28641,,
28642,"حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، قَالَ : نَذَرَتِ امْرَأَۃٌ أَنْ تُقَادَ مَزْمُومَۃً بِزِمَامٍ فِی أَنْفِہَا ، فَوَقَعَ بَعِیرُہَا ، فَانْقَطَعَ زِمَامُہَا ، فَخُرِمَ أَنْفُہَا ، فَأَتَتْ عَلِیًّا تَطْلُبُ عَقْلَہَا ، فَأَبْطَلَہُ وَقَالَ : إِنَّمَا نَذَرْتِیہِ لِلَّہِ۔",,,28642,,
28643,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قَالَ عَطَائٌ : إِنْ قَتَلَ رَجُلٌ رَجُلاً خَطَأً ثُمَّ آخَرَ عَمْدًا ، قَالَ: فَلْیُؤَدِّ الْخَطَأَ مِنْ أَجْلِ أَنَّہُ قَدْ ثَبَتَ عَقْلُہُ قَبْلَ الْعَمْدِ ، قَالَ لَہُ إِنْسَانٌ : وَقَتَلَ عَمْدًا ، ثُمَّ قَتَلَ خَطَأً ؟ قَالَ : فَلاَ یُؤَدِّ ، مِنْ أَجْلِ إِنَّہُ قَدْ غُلِقَ دَمہُ۔",,,28643,,
28644,"حَدَّثَنَا مُحَمَّدٌ بْنُ بَکْرِ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : رَجُلٌ قَتَلَ رَجُلاً عَمْدًا ، فَفَرَّ فَلَمْ یُقْدَرْ عَلَیْہِ حَتَّی مَاتَ ، وَتَرَکَ مَالاً ، فَدِیَتُہُ فِی مَالِہِ دِیَۃُ الْمَقْتُولِ ، قِیلَ لَہُ : سُجِنَ الْقَاتِلُ حَتَّی مَاتَ ؟ قَالَ : قَدْ قَتَلُوہُ ، حَبَسُوہُ حَتَّی مَاتَ فِی السِّجْنِ۔",,,28644,,
28645,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَن صَاعِدِ بْنِ مُسْلِمٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : سُئِلَ عَن قَتِیلٍ وُجِدَ فِی ثَلاَثَۃِ أَحْیَائٍ ؛ رَأْسُہُ فِی حَیٍّ ، وَرِجْلاَہُ فِی حَیٍّ ، وَوَسَطُہُ فِی حَیٍّ ، قَالَ الشَّعْبِیُّ : یُصَلَّی عَلَی الْوَسَطِ ، وَعَلَی أَہْلِ الْوَسَطِ الدِّیَۃُ ، وَقَسَامَۃٌ : مَا قَتَلْنَا ، وَلاَ عَلِمْنَا قَاتِلاً۔",,,28645,,
28646,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مَعْمَرٍ ، عَنْ رَجُلٍ ، عَن عِکْرِمَۃَ قَالَ : لَیْسَ فِی دِیَۃِ الدَّنَانِیرِ وَالدَّرَاہِمِ مُغَلَّظَۃٌ ، إِنَّمَا الْمُغَلَّظَۃُ فِی الإِبِلِ۔",,,28646,,
28647,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنِ الْقَاسِمِ بْنِ الْفَضْلِ ، عَن ہَارُونَ ، عَن عِکْرِمَۃَ ؛ فِی رَجُلٍ قَتَلَ بَعْدَ أَخْذِہِ الدِّیَۃَ، قَالَ : یُقْتَلُ ، أَمَا سَمِعْتَ اللَّہَ یَقُولُ : (فَلَہُ عَذَابٌ أَلِیمٌ)؟ ۔",,,28647,,
28648,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَن یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : یُؤْخَذُ مِنْہُ الدِّیَۃُ وَلاَ یُقْتَلُ۔",,,28648,,
28649,"حَدَّثَنَا أَبُو دَاوُدَ ، عَن وَہْبٍ ، عَن یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ قُتِلَ لَہُ قَتِیلٌ ، فَعَفَا عَنْہُ ، ثُمَّ رَاحَ فَقَتَلَہُ ، قَالَ الْحَسَنُ : لاَ یُقْتَلُ۔",,,28649,,
28650,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَن زُہَیْرٍ ، عَنْ جَابِرٍ ؛ فِی امْرَأَۃٍ حَمَلَتْ مِنَ الزِّنَی ، فَحُبِسَتْ لِتَضَعَ مَا فِی بَطْنِہَا ثُمَّ تُرْجَمُ ، فَدَخَلَ عَلَیْہَا رَجُلٌ فَقَتَلَہَا ، قَالَ : قَالَ عَامِرٌ : لاَ أَعْلَمُ فِیہَا شَیْئًا ، غَیْرَ أَنَّ الْوَلَدَ لِلسُّلْطَانِ ، یَحْکُمُ فِیہِ مَا شَائَ\n\nقَالَ : وَحَدَّثَنِی حَمَّادٌ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لَیْسَ أَحَدٌ مِنَ الْمُسْلِمِینَ بِأَحَقَّ بِہَا ، بَعْضُہُمْ مِنْ بَعْضٍ ، وَقَالَ حَمَّادٌ : فِی الْوَلَدِ غُرَّۃٌ۔",,,28650,,
28651,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَن حَسَنٍ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، فِی صَاحِبِ الْمَعْبَرِ یَعْبُرُ بِدَوَابَّ فَغَرِقَتْ ، قَالَ : لاَ ضَمَانَ عَلَیْہِ۔",,,28651,,
28652,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، وَابْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنْ مَکْحُولٍ ، عَن زَیْدِ بْنِ ثَابِتٍ ، قَالَ : فِی شَحْمَۃِ الأُذُنِ ثُلُثُ دِیَۃِ الأُذُنِ۔",,,28652,,
28653,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إِدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنْ عَامِرٍ ، قَالَ : اخْتُصِمَ إِلَی عَلِیٍّ فِی ثَوْرٍ نَطَحَ حِمَارًا فَقَتَلَہُ ، فَقَالَ عَلِیٌّ : إِنْ کَانَ الثَّوْرُ دَخَلَ عَلَی الْحِمَارِ فَقَتَلَہُ ، فَقَدْ ضَمِنَ ، وَإِنْ کَانَ الْحِمَارُ دَخَلَ عَلَی الثَّوْرِ فَقَتَلَہُ ، فَلاَ ضَمَانَ عَلَیْہِ۔",,,28653,,
28654,"حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : یُقْتَصُّ لِبَعْضِہِمْ مِنْ بَعْضٍ ، ثُمَّ تُقَامُ الْحُدُودُ ، یَعْنِی فِی الْقَوْمِ یَجْرَحُ بَعْضُہُمْ بَعْضًا۔",,,28654,,
