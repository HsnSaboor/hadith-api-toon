{"hadithnumber": "4204", "text": "یحییٰ بن سعید قطان نے ہمیں عبیداللہ سے حدیث بیان کی کہا :  مجھے نافع نے حضرت ابن عمر رضی اللہ عنہ سے"}
{"hadithnumber": "4205", "text": "عبدہ بن سلیمان اور عبداللہ بن نمیر دونوں نے عبیداللہ سے اسی سند کے ساتھ روایت کی ،  البتہ ان دونوں ن"}
{"hadithnumber": "4206", "text": "ایوب ،  یونس ،  اسامہ بن زید لیثی اور ہشام بن سعد سب نے نافع سے ،  انہوں نے حضرت ابن عمر رضی اللہ عن"}
{"hadithnumber": "4207", "text": "عمرو بن حارث نے مجھے ابن شہاب سے خبر دی ،  انہوں نے سالم سے اور انہوں نے اپنے والد سے روایت کی کہ ان"}
{"hadithnumber": "4208", "text": "یونس ،  عقیل اور معمر سب نے زہری سے اسی سند کے ساتھ عمرو بن حارث کی حدیث کی طرح حدیث بیان کی"}
{"hadithnumber": "4209", "text": "ابراہیم بن سعد  ( بن ابراہیم بن عبدالرحمان بن عوف )  نے ہمیں ابن شہاب سے خبر دی ،  انہوں نے عامر بن"}
{"hadithnumber": "4210", "text": "سفیان بن عیینہ ،  یونس اور معمر سب نے ابن شہاب سے اسی سند کے ساتھ اسی طرح حدیث بیان کی"}
{"hadithnumber": "4211", "text": "سعد بن ابراہیم نے عامر بن سعد سے اور انہوں نے حضرت سعد رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  ن"}
{"hadithnumber": "4212", "text": "زہیر نے ہمیں حدیث بیان کی ،  کہا :  ہمیں سماک بن حرب نے حدیث بیان کی ،  کہا :  مجھے مصعب بن سعد  ( ب"}
{"hadithnumber": "4213", "text": "شعبہ نے سماک سے اسی سند کے ساتھ اسی کے ہم معنی حدیث بیان کی اور انہوں نے یہ بیان نہیں کیا :   \" اس ک"}
{"hadithnumber": "4214", "text": "عبدالملک بن عُمَیر نے مُصعب بن سعد سے اور انہوں نے اپنے والد سے روایت کی ،  انہوں نے کہا :  نبی صلی"}
{"hadithnumber": "4215", "text": "عبدالوہاب )  ثقفی نے ہمیں ایوب سختیانی سے حدیث بیان کی ،  انہوں نے عمرو بن سعید سے ،  انہوں نے حُمید"}
{"hadithnumber": "4216", "text": "ہمیں حماد نے حدیث بیان کی ،  انہوں نے کہا :  ہمیں ایوب نے عمرو بن سعید سے حدیث بیان کی ،  انہوں نے ح"}
{"hadithnumber": "4217", "text": "محمد نے حمید بن عبدالرحمان سے روایت کی ،  انہوں نے کہا :  مجھے حضرت سعد بن مالک رضی اللہ عنہ کے تین"}
{"hadithnumber": "4218", "text": "عیسیٰ بن یونس ،  وکیع اور ابن نمیر سب نے ہشام بن عروہ سے حدیث بیان کی ،  انہوں نے اپنے والد سے اور ا"}
{"hadithnumber": "4219", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ ایک آدمی نے نبی صلی اللہ علیہ وسلم سے عرض کی :  میرے والد"}
{"hadithnumber": "4220", "text": "یحییٰ بن سعید نے ہمیں ہشام بن عروہ سے حدیث بیان کی ،  کہا :  مجھے میرے والد نے حضرت عائشہ سے خبر دی"}
{"hadithnumber": "4221", "text": "محمد بن بشر نے ہمیں حدیث بیان کی ،  کہا :  ہمیں ہشام نے اپنے والد سے ،  انہوں نے حضرت عائشہ رضی اللہ"}
{"hadithnumber": "4222", "text": "ابواسامہ ،  شعیب بن اسحاق ،  روح بن قاسم اور جعفر بن عون ،  سب نے ہشام بن عروہ سے اسی سند کے ساتھ حد"}
{"hadithnumber": "4223", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   \" جب انسان فوت"}
{"hadithnumber": "4224", "text": "سُلیم بن اخضر نے ہمیں ابن عون سے خبر دی ،  انہوں نے نافع سے اور انہوں نے حضرت ابن عمر رضی اللہ عنہ س"}
{"hadithnumber": "4225", "text": "ابن ابی زائدہ ،  ازہر سمان اور ابن ابی عدی سب نے ابن عون سے اسی سند کے ساتھ اسی کے ہم معنی حدیث بیان"}
{"hadithnumber": "4226", "text": "سفیان نے ابن عون سے ،  انہوں نے نافع سے ،  انہوں نے حضرت ابن عمر رضی اللہ عنہ سے اور انہوں نے حضرت ع"}
{"hadithnumber": "4227", "text": "عبدالرحمان بن مہدی نے ہمیں مالک بن مغول سے خبر دی اور انہوں نے طلحہ بن مصرف سے روایت کی ،  انہوں نے"}
{"hadithnumber": "4228", "text": "وکیع اور ابن نمیر دونوں نے مالک بن مغول سے اسی سند کے ساتھ اسی طرح حدیث بیان کی ،  البتہ وکیع کی حدی"}
{"hadithnumber": "4229", "text": "عبداللہ بن نمیر اور ابومعاویہ دونوں نے کہا :  ہمیں اعمش نے ابووائل سے حدیث بیان کی ،  انہوں نے مسروق"}
{"hadithnumber": "4230", "text": "جریر اور عیسیٰ بن یونس نے اعمش سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی"}
{"hadithnumber": "4231", "text": "اسود بن یزید سے روایت ہے ،  انہوں نے کہا :  لوگوں نے حضرت عائشہ رضی اللہ عنہا کے پاس ذکر کیا کہ حضرت"}
{"hadithnumber": "4232", "text": "ہمیں سعید بن منصور ، قتیبہ بن سعید ،  ابوبکر بن ابی شیبہ اور عمرو ناقد نے حدیث بیان کی  ۔  ۔  الفاظ"}
{"hadithnumber": "4233", "text": "طلحہ بن مُصرف نے سعید بن جبیر سے اور انہوں نے حضرت ابن عباس رضی اللہ عنہ سے روایت کی کہ انہوں نے کہا"}
{"hadithnumber": "4234", "text": "عبیداللہ بن عبداللہ بن عتبہ نے حضرت ابن عباس رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  جب رسول الل"}
