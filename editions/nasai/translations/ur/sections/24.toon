{"hadithnumber": "3072", "text": "عبدالرحمٰن بن یزید کہتے ہیں کہ عبداللہ بن مسعود رضی الله عنہ سے کہا گیا کہ  کچھ لوگ جمرہ کو گھاٹی کے"}
{"hadithnumber": "3073", "text": "عبدالرحمٰن بن یزید کہتے ہیں کہ  عبداللہ بن مسعود رضی اللہ عنہ نے خانہ کعبہ کو اپنے بائیں جانب کیا او"}
{"hadithnumber": "3074", "text": "عبدالرحمٰن بن یزید کہتے ہیں کہ  میں نے ابن مسعود رضی اللہ عنہ کو دیکھا کہ انہوں نے جمرہ عقبہ کو وادی"}
{"hadithnumber": "3075", "text": "اعمش کہتے ہیں کہ  میں نے حجاج کو کہتے سنا کہ ”سورۃ البقرہ“ نہ کہو، بلکہ کہو ”وہ سورۃ جس میں بقرہ کا"}
{"hadithnumber": "3076", "text": "جابر رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے جمرہ عقبہ کی رمی چٹکی میں آنے والی جی"}
{"hadithnumber": "3077", "text": "جابر رضی الله عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو دیکھا کہ آپ چٹکی میں آنے والی"}
{"hadithnumber": "3078", "text": "ابو جعفر محمد بن علی بن حسین باقر کہتے ہیں کہ  ہم جابر بن عبداللہ کے پاس گئے تو میں نے ان سے کہا: آپ"}
{"hadithnumber": "3079", "text": "سعد رضی الله عنہ کہتے ہیں کہ  ہم نبی اکرم صلی اللہ علیہ وسلم کے ساتھ حج میں لوٹے۔ تو ہم میں سے کوئی"}
{"hadithnumber": "3080", "text": "ابومجلز کہتے ہیں کہ  میں نے ابن عباس رضی اللہ عنہما سے کنکریوں کے متعلق پوچھا تو انہوں نے کہا: مجھے"}
{"hadithnumber": "3081", "text": "عبداللہ بن عباس اپنے بھائی فضل بن عباس (رضی الله عنہم) سے روایت کرتے ہیں، فضل رضی الله عنہ کہتے ہیں"}
{"hadithnumber": "3082", "text": "عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  فضل بن عباس رضی اللہ عنہما نے کہا کہ میں رسول اللہ صلی ا"}
{"hadithnumber": "3083", "text": "عبداللہ بن عباس رضی الله عنہما سے روایت ہے کہ  فضل  ( فضل بن عباس رضی اللہ عنہما )  نے انہیں خبر دی"}
{"hadithnumber": "3084", "text": "فضل بن عباس رضی الله عنہما سے روایت ہے کہ  وہ رسول اللہ صلی اللہ علیہ وسلم کے پیچھے سوار تھے، اور آپ"}
