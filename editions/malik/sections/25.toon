{"hadithnumber": "1052", "arabic": "[1052] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ یَزِیدَ بْنِ عَبْدِ اللّٰہِ بْنِ قُسَیْطٍ، عَنْ مُحَمَّدِ بْن", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Mauquf Sahih'}", "reference": "Book 25, Hadith 1", "international_number": "1052", "narrator_chain": ""}
{"hadithnumber": "1053", "arabic": "[1053] حَدَّثَنِی یَحْیَی، عَنْ مَالِکٍ، عَنْ زَیْدِ بْنِ أَسْلَمَ، عَنْ رَجُلٍ مِنْ بَنِی ضَمْرَۃَ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Maqtu Daif'}", "reference": "Book 25, Hadith 2", "international_number": "1053", "narrator_chain": ""}
{"hadithnumber": "1054", "arabic": "[1054] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ جَعْفَرِ بْنِ مُحَمَّدٍ، عَنْ أَبِیہِ أَ نَّہُ قَالَ : وَزَ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Maqtu Daif'}", "reference": "Book 25, Hadith 3", "international_number": "1054", "narrator_chain": ""}
{"hadithnumber": "1055", "arabic": "[1055] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ رَبِیعَۃَ بْنِ أبِی عَبْدِ الرَّحْمَنِ، عَنْ مُحَمَّدِ بْنِ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Mauquf Sahih'}", "reference": "Book 25, Hadith 4", "international_number": "1055", "narrator_chain": ""}
{"hadithnumber": "1056", "arabic": "[1056] حَدَّثَنِی یَحْیَی، عَنْ مَالِکٍ، عَنْ نَافِعٍ : أَنَّ عَبْدَ اللّٰہِ بْنَ عُمَرَ لَمْ یَکُن", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Mauquf Sahih'}", "reference": "Book 25, Hadith 5", "international_number": "1056", "narrator_chain": ""}
{"hadithnumber": "1057", "arabic": "[1057] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ رَبِیعَۃَ بْنِ أبِی عَبْدِ الرَّحْمَنِ، عَنْ مُحَمَّدِ بْنِ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Mauquf Hasan'}", "reference": "Book 25, Hadith 6", "international_number": "1057", "narrator_chain": ""}
{"hadithnumber": "1058", "arabic": "[1058] وَحَدَّثَنِی عَنْ مَالِکٍ، أَ نَّہُ بَلَغَہُ : أَ نَّہُ عُقَّ عَنْ حَسَنٍ وَحُسَیْنٍ ابْنَی", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Mauquf Sahih'}", "reference": "Book 25, Hadith 7", "international_number": "1058", "narrator_chain": ""}
{"hadithnumber": "1059", "arabic": "[1059] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ : أَنَّ أَبَاہُ عُرْوَۃَ بْنَ الزُّبَ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Mauquf Hasan'}", "reference": "Book 25, Hadith 8", "international_number": "1059", "narrator_chain": ""}
{"hadithnumber": "1060", "arabic": "[1060] حَدَّثَنِی یَحْیَی، عَنْ مَالِکٍ، عَنْ عَمْرِو بْنِ الْحَارِثِ، عَنْ عُبَیْدِ بْنِ فَیْرُوزٍ،", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Mauquf Sahih'}", "reference": "Book 25, Hadith 9", "international_number": "1060", "narrator_chain": ""}
{"hadithnumber": "1061", "arabic": "[1061] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ نَافِعٍ : أَنَّ عَبْدَ اللّٰہِ بْنَ عُمَرَ کَانَ یَتَّقِی مِ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Mauquf Sahih'}", "reference": "Book 25, Hadith 10", "international_number": "1061", "narrator_chain": ""}
{"hadithnumber": "1062", "arabic": "[1062] حَدَّثَنِی یَحْیَی، عَنْ مَالِکٍ، عَنْ یَحْیَی بْنِ سَعِیدٍ، عَنْ بُشَیْرِ بْنِ یَسَارٍ : أَ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Shadh'}", "reference": "Book 25, Hadith 11", "international_number": "1062", "narrator_chain": ""}
{"hadithnumber": "1063", "arabic": "[1063] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ یَحْیَی بْنِ سَعِیدٍ، عَنْ عَبَّادِ بْنِ تَمِیمٍ، أَنَّ عُوَ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 25, Hadith 12", "international_number": "1063", "narrator_chain": ""}
{"hadithnumber": "1064", "arabic": "[1064] حَدَّثَنِی یَحْیَی، عَنْ مَالِکٍ، عَنْ نَافِعٍ : أَنَّ عَبْدَ اللّٰہِ بْنَ عُمَرَ ضَحَّی مَر", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 25, Hadith 13", "international_number": "1064", "narrator_chain": ""}
{"hadithnumber": "1065", "arabic": "[1065] حَدَّثَنِی یَحْیَی، عَنْ مَالِکٍ، عَنْ أبِی الزُّبَیْرِ الْمَکِّیِّ عَنْ جَابِرِ بْنِ عَبْدِ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 25, Hadith 14", "international_number": "1065", "narrator_chain": ""}
{"hadithnumber": "1066", "arabic": "[1066] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ عَبْدِ اللّٰہِ بْنِ أبِی بَکْرٍ، عَنْ عَبْدِ اللّٰہِ بْنِ وَ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Daif'}", "reference": "Book 25, Hadith 15", "international_number": "1066", "narrator_chain": ""}
{"hadithnumber": "1098", "arabic": "حَدَّثَنِي يَحْيَى، عَنْ مَالِكٍ، عَنْ نَافِعٍ، أَنَّهُ قَالَ رَمَيْتُ طَائِرَيْنِ بِحَجَرٍ وَأَنَا بِالْجُرْفِ، فَأَصَبْتُهُمَا فَأَمَّا أَحَدُهُمَا فَمَاتَ فَطَرَحَهُ عَبْدُ اللَّهِ بْنُ عُمَرَ وَأَمَّا الآخَرُ فَذَهَبَ عَبْدُ اللَّهِ بْنُ عُمَرَ يُذَكِّيهِ بِقَدُومٍ فَمَاتَ قَبْلَ أَنْ يُذَكِّيَهُ فَطَرَحَهُ عَبْدُ اللَّهِ أَيْضًا ‏.‏", "grades": "", "reference": "", "international_number": "1098", "narrator_chain": ""}
{"hadithnumber": "1099", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، أَنَّهُ بَلَغَهُ أَنَّ الْقَاسِمَ بْنَ مُحَمَّدٍ، كَانَ يَكْرَهُ مَا قَتَلَ الْمِعْرَاضُ وَالْبُنْدُقَةُ ‏.‏", "grades": "", "reference": "", "international_number": "1099", "narrator_chain": ""}
{"hadithnumber": "1100", "arabic": "سَعِيدَ بْنَ الْمُسَيَّبِ، كَانَ يَكْرَهُ أَنْ تُقْتَلَ الإِنْسِيَّةُ، بِمَا يُقْتَلُ بِهِ الصَّيْدُ مِنَ الرَّمْىِ وَأَشْبَاهِهِ ‏.‏ قَالَ مَالِكٌ وَلاَ أَرَى بَأْسًا بِمَا أَصَابَ الْمِعْرَاضُ إِذَا خَسَقَ وَبَلَغَ الْمَقَاتِلَ أَنْ يُؤْكَلَ قَالَ اللَّهُ تَبَارَكَ وَتَعَالَى ‏{‏يَا أَيُّهَا الَّذِينَ آمَنُوا لَيَبْلُوَنَّكُمُ اللَّهُ بِشَىْءٍ مِنَ الصَّيْدِ تَنَالُهُ أَيْدِيكُمْ وَرِمَاحُكُمْ ‏}‏ قَالَ فَكُلُّ شَىْءٍ نَالَهُ الإِنْسَانُ بِيَدِهِ أَوْ رُمْحِهِ أَوْ بِشَىْءٍ مِنْ سِلاَحِهِ فَأَنْفَذَهُ وَبَلَغَ مَقَاتِلَهُ فَهُوَ صَيْدٌ كَمَا قَالَ اللَّهُ تَعَالَى", "grades": "", "reference": "", "international_number": "1100", "narrator_chain": ""}
{"hadithnumber": "1101", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ أَنَّهُ سَمِعَ أَهْلَ الْعِلْمِ يَقُولُونَ إِذَا أَصَابَ الرَّجُلُ الصَّيْدَ فَأَعَانَهُ عَلَيْهِ غَيْرُهُ مِنْ مَاءٍ أَوْ كَلْبٍ غَيْرِ مُعَلَّمٍ لَمْ يُؤْكَلْ ذَلِكَ الصَّيْدُ إِلاَّ أَنْ يَكُونَ سَهْمُ الرَّامِي قَدْ قَتَلَهُ أَوْ بَلَغَ مَقَاتِلَ الصَّيْدِ حَتَّى لاَ يَشُكَّ أَحَدٌ فِي أَنَّهُ هُوَ قَتَلَهُ وَأَنَّهُ لاَ يَكُونُ لِلصَّيْدِ حَيَاةٌ بَعْدَهُ ‏.‏ قَالَ وَسَمِعْتُ مَالِكًا يَقُولُ لاَ بَأْسَ بِأَكْلِ الصَّيْدِ - وَإِنْ غَابَ عَنْكَ مَصْرَعُهُ - إِذَا وَجَدْتَ بِهِ أَثَرًا مِنْ كَلْبِكَ أَوْ كَانَ بِهِ سَهْمُكَ مَا لَمْ يَبِتْ فَإِذَا بَاتَ فَإِنَّهُ يُكْرَهُ أَكْلُهُ ‏.", "grades": "", "reference": "", "international_number": "1101", "narrator_chain": ""}
{"hadithnumber": "1102", "arabic": "وَحَدَّثَنِي يَحْيَى، عَنْ مَالِكٍ، عَنْ نَافِعٍ، عَنْ عَبْدِ اللَّهِ بْنِ عُمَرَ، أَنَّهُ كَانَ يَقُولُ فِي الْكَلْبِ الْمُعَلَّمِ كُلْ مَا أَمْسَكَ عَلَيْكَ إِنْ قَتَلَ وَإِنْ لَمْ يَقْتُلْ ‏.‏", "grades": "", "reference": "", "international_number": "1102", "narrator_chain": ""}
{"hadithnumber": "1103", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَمَّنْ سَمِعَ نَافِعًا، يَقُولُ قَالَ عَبْدُ اللَّهِ بْنُ عُمَرَ وَإِنْ أَكَلَ وَإِنْ لَمْ يَأْكُلْ ‏.‏", "grades": "", "reference": "", "international_number": "1103", "narrator_chain": ""}
{"hadithnumber": "1104", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، أَنَّهُ بَلَغَهُ عَنْ سَعْدِ بْنِ أَبِي وَقَّاصٍ، أَنَّهُ سُئِلَ عَنِ الْكَلْبِ الْمُعَلَّمِ، إِذَا قَتَلَ الصَّيْدَ فَقَالَ سَعْدٌ كُلْ وَإِنْ لَمْ تَبْقَ إِلاَّ بِضْعَةٌ وَاحِدَةٌ ‏.‏ وَحَدَّثَنِي عَنْ مَالِكٍ، أَنَّهُ بَلَغَهُ عَنْ سَعْدِ بْنِ أَبِي وَقَّاصٍ، أَنَّهُ سُئِلَ عَنِ الْكَلْبِ الْمُعَلَّمِ، إِذَا قَتَلَ الصَّيْدَ فَقَالَ سَعْدٌ كُلْ وَإِنْ لَمْ تَبْقَ إِلاَّ بِضْعَةٌ وَاحِدَةٌ ‏.", "grades": "", "reference": "", "international_number": "1104", "narrator_chain": ""}
{"hadithnumber": "1105", "arabic": ".‏ وَحَدَّثَنِي عَنْ مَالِكٍ أَنَّهُ سَمِعَ بَعْضَ أَهْلِ الْعِلْمِ يَقُولُونَ فِي الْبَازِي وَالْعُقَابِ وَالصَّقْرِ وَمَا أَشْبَهَ ذَلِكَ أَنَّهُ إِذَا كَانَ يَفْقَهُ كَمَا تَفْقَهُ الْكِلاَبُ الْمُعَلَّمَةُ فَلاَ بَأْسَ بِأَكْلِ مَا قَتَلَتْ مِمَّا صَادَتْ إِذَا ذُكِرَ اسْمُ اللَّهِ عَلَى إِرْسَالِهَا ‏.‏ قَالَ مَالِكٌ وَأَحْسَنُ مَا سَمِعْتُ فِي الَّذِي يَتَخَلَّصُ الصَّيْدَ مِنْ مَخَالِبِ الْبَازِي أَوْ مِنَ الْكَلْبِ ثُمَّ يَتَرَبَّصُ بِهِ فَيَمُوتُ أَنَّهُ لاَ يَحِلُّ أَكْلُهُ ‏.‏ قَالَ مَالِكٌ وَكَذَلِكَ كُلُّ مَا قُدِرَ عَلَى ذَبْحِهِ وَهُوَ فِي مَخَالِبِ الْبَازِي أَوْ فِي الْكَلْبِ فَيَتْرُكُهُ صَاحِبُهُ وَهُوَ قَادِرٌ عَلَى ذَبْحِهِ حَتَّى يَقْتُلَهُ الْبَازِي أَوِ الْكَلْبُ فَإِنَّهُ لاَ يَحِلُّ أَكْلُهُ ‏.‏ قَالَ مَالِكٌ وَكَذَلِكَ الَّذِي يَرْمِي الصَّيْدَ فَيَنَالُهُ وَهُوَ حَىٌّ فَيُفَرِّطُ فِي ذَبْحِهِ حَتَّى يَمُوتَ فَإِنَّهُ لاَ يَحِلُّ أَكْلُهُ ‏.‏ قَالَ مَالِكٌ الأَمْرُ الْمُجْتَمَعُ عَلَيْهِ عِنْدَنَا أَنَّ الْمُسْلِمَ إِذَا أَرْسَلَ كَلْبَ الْمَجُوسِيِّ الضَّارِيَ فَصَادَ أَوْ قَتَلَ إِنَّهُ إِذَا كَانَ مُعَلَّمًا فَأَكْلُ ذَلِكَ الصَّيْدِ حَلاَلٌ لاَ بَأْسَ بِهِ وَإِنْ لَمْ يُذَكِّهِ الْمُسْلِمُ وَإِنَّمَا مَثَلُ ذَلِكَ مَثَلُ الْمُسْلِمِ يَذْبَحُ بِشَفْرَةِ الْمَجُوسِيِّ أَوْ يَرْمِي بِقَوْسِهِ أَوْ بِنَبْلِهِ فَيَقْتُلُ بِهَا فَصَيْدُهُ ذَلِكَ وَذَبِيحَتُهُ حَلاَلٌ لاَ بَأْسَ بِأَكْلِهِ وَإِذَا أَرْسَلَ الْمَجُوسِيُّ كَلْبَ الْمُسْلِمِ الضَّارِيَ عَلَى صَيْدٍ فَأَخَذَهُ فَإِنَّهُ لاَ يُؤْكَلُ ذَلِكَ الصَّيْدُ إِلاَّ أَنْ يُذَكَّى  وَإِنَّمَا مَثَلُ ذَلِكَ مَثَلُ قَوْسِ الْمُسْلِمِ وَنَبْلِهِ يَأْخُذُهَا الْمَجُوسِيُّ فَيَرْمِي بِهَا الصَّيْدَ فَيَقْتُلُهُ وَبِمَنْزِلَةِ شَفْرَةِ الْمُسْلِمِ يَذْبَحُ بِهَا الْمَجُوسِيُّ فَلاَ يَحِلُّ أَكْلُ شَىْءٍ مِنْ ذَلِكَ ‏.", "grades": "", "reference": "", "international_number": "1105", "narrator_chain": ""}
{"hadithnumber": "1106", "arabic": "وَحَدَّثَنِي يَحْيَى، عَنْ مَالِكٍ، عَنْ نَافِعٍ، أَنَّ عَبْدَ الرَّحْمَنِ بْنَ أَبِي هُرَيْرَةَ، سَأَلَ عَبْدَ اللَّهِ بْنَ عُمَرَ عَمَّا لَفَظَ الْبَحْرُ فَنَهَاهُ عَنْ أَكْلِهِ، ‏.‏ قَالَ نَافِعٌ ثُمَّ انْقَلَبَ عَبْدُ اللَّهِ فَدَعَا بِالْمُصْحَفِ فَقَرَأَ ‏{‏أُحِلَّ لَكُمْ صَيْدُ الْبَحْرِ وَطَعَامُهُ‏}‏ قَالَ نَافِعٌ فَأَرْسَلَنِي عَبْدُ اللَّهِ بْنُ عُمَرَ إِلَى عَبْدِ الرَّحْمَنِ بْنِ أَبِي هُرَيْرَةَ إِنَّهُ لاَ بَأْسَ بِأَكْلِهِ ‏.‏", "grades": "", "reference": "", "international_number": "1106", "narrator_chain": ""}
{"hadithnumber": "1107", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ زَيْدِ بْنِ أَسْلَمَ، عَنْ سَعْدٍ الْجَارِيِّ، مَوْلَى عُمَرَ بْنِ الْخَطَّابِ أَنَّهُ قَالَ سَأَلْتُ عَبْدَ اللَّهِ بْنَ عُمَرَ عَنِ الْحِيتَانِ، يَقْتُلُ بَعْضُهَا بَعْضًا أَوْ تَمُوتُ صَرَدًا فَقَالَ لَيْسَ بِهَا بَأْسٌ ‏.‏ قَالَ سَعْدٌ ثُمَّ سَأَلْتُ عَبْدَ اللَّهِ بْنَ عَمْرِو بْنِ الْعَاصِ فَقَالَ مِثْلَ ذَلِكَ ‏.‏", "grades": "", "reference": "", "international_number": "1107", "narrator_chain": ""}
{"hadithnumber": "1108", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ أَبِي الزِّنَادِ، عَنْ أَبِي سَلَمَةَ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ أَبِي هُرَيْرَةَ، وَزَيْدِ بْنِ ثَابِتٍ، أَنَّهُمَا كَانَا لاَ يَرَيَانِ بِمَا لَفَظَ الْبَحْرُ بَأْسًا ‏.‏", "grades": "", "reference": "", "international_number": "1108", "narrator_chain": ""}
{"hadithnumber": "1109", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ أَبِي الزِّنَادِ، عَنْ أَبِي سَلَمَةَ بْنِ عَبْدِ الرَّحْمَنِ، أَنَّ نَاسًا، مِنْ أَهْلِ الْجَارِ قَدِمُوا فَسَأَلُوا مَرْوَانَ بْنَ الْحَكَمِ عَمَّا لَفَظَ الْبَحْرُ فَقَالَ لَيْسَ بِهِ بَأْسٌ وَقَالَ اذْهَبُوا إِلَى زَيْدِ بْنِ ثَابِتٍ وَأَبِي هُرَيْرَةَ فَاسْأَلُوهُمَا عَنْ ذَلِكَ ثُمَّ ائْتُونِي فَأَخْبِرُونِي مَاذَا يَقُولاَنِ فَأَتَوْهُمَا فَسَأَلُوهُمَا فَقَالاَ لاَ بَأْسَ بِهِ ‏.‏ فَأَتَوْا مَرْوَانَ فَأَخْبَرُوهُ ‏.‏ فَقَالَ مَرْوَانُ قَدْ قُلْتُ لَكُمْ ‏.‏ قَالَ مَالِكٌ لاَ بَأْسَ بِأَكْلِ الْحِيتَانِ يَصِيدُهَا الْمَجُوسِيُّ لأَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ فِي الْبَحْرِ ‏ ‏ هُوَ الطَّهُورُ مَاؤُهُ الْحِلُّ مَيْتَتُهُ ‏\"\"‏ ‏.‏ قَالَ مَالِكٌ وَإِذَا أُكِلَ ذَلِكَ مَيْتًا فَلاَ يَضُرُّهُ مَنْ صَادَهُ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1110", "arabic": "حَدَّثَنِي يَحْيَى، عَنْ مَالِكٍ، عَنِ ابْنِ شِهَابٍ، عَنِ أَبِي إِدْرِيسَ الْخَوْلاَنِيِّ، عَنْ أَبِي ثَعْلَبَةَ الْخُشَنِيِّ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ أَكْلُ كُلِّ ذِي نَابٍ مِنَ السِّبَاعِ حَرَامٌ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1111", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ إِسْمَاعِيلَ بْنِ أَبِي حَكِيمٍ، عَنْ عَبِيدَةَ بْنِ سُفْيَانَ الْحَضْرَمِيِّ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ أَكْلُ كُلِّ ذِي نَابٍ مِنَ السِّبَاعِ حَرَامٌ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1112", "arabic": "[1112] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ إِبْرَاہِیمَ بْنِ أبِی عَبْلَۃَ، عَنْ عَبْدِ الْمَلِکِ بْنِ", "grades": "", "reference": "", "international_number": "1112", "narrator_chain": ""}
{"hadithnumber": "1114", "arabic": "وَحَدَّثَنِي مَالِكٌ، عَنْ زَيْدِ بْنِ أَسْلَمَ، عَنِ ابْنِ وَعْلَةَ الْمِصْرِيِّ، عَنْ عَبْدِ اللَّهِ بْنِ عَبَّاسٍ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ إِذَا دُبِغَ الإِهَابُ فَقَدْ طَهُرَ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1115", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ يَزِيدَ بْنِ عَبْدِ اللَّهِ بْنِ قُسَيْطٍ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ ثَوْبَانَ، عَنْ أُمِّهِ، عَنْ عَائِشَةَ، زَوْجِ النَّبِيِّ صلى الله عليه وسلم أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم أَمَرَ أَنْ يُسْتَمْتَعَ بِجُلُودِ الْمَيْتَةِ إِذَا دُبِغَتْ ‏.‏", "grades": "", "reference": "", "international_number": "1115", "narrator_chain": ""}
{"hadithnumber": "1116", "arabic": "[1116] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنِ ابْنِ شِہَابٍ، عَنْ عُرْوَۃَ بْنِ الزُّبَیْرِ : أَنَّ خَوْلَ", "grades": "", "reference": "", "international_number": "1116", "narrator_chain": ""}
