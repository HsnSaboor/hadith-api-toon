{"hadithnumber": "5053", "text": "ہم سے سعد بن حفص نے بیان کیا، کہا ہم سے شیبان نے بیان کیا، ان سے یحییٰ بن ابی کثیر نے، ان سے محمد بن"}
{"hadithnumber": "5054", "text": "مجھ سے اسحاق بن منصور نے بیان کیا، کہا ہم کو عبیداللہ بن موسیٰ نے خبر دی، انہیں شیبان نے، انہیں یحیی"}
{"hadithnumber": "5055", "text": "ہم سے صدقہ بن فضل نے بیان کیا، کہا ہم کو یحییٰ بن سعید نے خبر دی، انہیں سفیان ثوری نے، انہیں سلیمان"}
{"hadithnumber": "5056", "text": "ہم سے قیس بن حفص نے بیان کیا، کہا ہم سے عبدالواحد نے بیان کیا، کہا ہم سے اعمش نے بیان کیا، ان سے ابر"}
{"hadithnumber": "5057", "text": "ہم سے محمد بن کثیر نے بیان کیا، کہا ہم کو سفیان ثوری نے خبر دی، کہا ہم سے اعمش نے بیان کیا، ان سے خی"}
{"hadithnumber": "5058", "text": "ہم سے عبداللہ بن یوسف تنیسی نے بیان کیا، کہا ہم کو امام مالک نے خبر دی، انہیں یحییٰ بن سعید انصاری ن"}
{"hadithnumber": "5059", "text": "ہم سے مسدد بن مسرہد نے بیان کیا، کہا ہم سے یحییٰ قطان نے بیان کیا، ان سے قتادہ نے، ان سے انس بن مالک"}
{"hadithnumber": "5060", "text": "ہم سے ابوالنعمان نے بیان کیا، کہا ہم سے حماد نے بیان کیا، ان سے ابوعمران جونی نے اور ان سے جندب بن ع"}
{"hadithnumber": "5061", "text": "ہم سے عمرو بن علی فلاس نے بیان کیا، کہا ہم سے عبدالرحمٰن بن مہدی نے بیان کیا، ان سے سلام بن ابی مطیع"}
{"hadithnumber": "5062", "text": "ہم سے سلیمان بن حرب نے بیان کیا، کہا ہم سے شعبہ نے، ان سے عبدالملک بن میسرہ نے، ان سے نزال بن سبرہ ن"}
