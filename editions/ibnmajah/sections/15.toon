hadiths[count]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}:
2124,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا هِشَامُ بْنُ سَعْدٍ، عَنْ زَيْدِ بْنِ أَسْلَمَ، عَنْ أَبِيهِ، عَنْ عُمَرَ بْنِ الْخَطَّابِ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ لاَ تَعُدْ فِي صَدَقَتِكَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: صحیح مسلم/النذر ۳ (۱۶۴۱)، سنن ابی داود/الأیمان ۲۸ (۳۳۱۶)، سنن النسائی/الأیمان ۳۰ (۳۸۴۳)،۴۱ (۳۸۸۰)،(تحفة الأشرف:۱۰۸۸۴،۱۰۸۸۸)، وقد أخرجہ: مسند احمد (۴/۴۲۹،۴۳۴),,It was narrated from 'Umar bin Khattab that:,The Chapters on Charity
2125,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ الدِّمَشْقِيُّ، حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، حَدَّثَنَا الأَوْزَاعِيُّ، حَدَّثَنِي أَبُو جَعْفَرٍ، مُحَمَّدُ بْنُ عَلِيٍّ حَدَّثَنِي سَعِيدُ بْنُ الْمُسَيَّبِ، حَدَّثَنِي عَبْدُ اللَّهِ بْنُ الْعَبَّاسِ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَثَلُ الَّذِي يَتَصَدَّقُ ثُمَّ يَرْجِعُ فِي صَدَقَتِهِ مَثَلُ الْكَلْبِ يَقِيءُ ثُمَّ يَرْجِعُ فَيَأْكُلُ قَيْئَهُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: سنن ابی داود/الأیمان ۲۲ (۳۲۹۰،۳۲۹۱)، سنن الترمذی/الایمان ۲ (۱۵۲۴)، سنن النسائی/الأیمان ۴۰ (۳۸۶۵)،(تحفة الأشراف:۱۷۷۷۰)، وقد أخرجہ: صحیح البخاری/الأیمان ۲۸ (۶۶۹۶)،۳۱ (۶۷۰۰)، موطا امام مالک/النذور۴ (۸)، مسند احمد (۶/۳۶،۴۱،۲۲۴)، سنن الدارمی/النذور ۳ (۲۳۸۳),,'Abdullah bin 'Abbas narrated that the Messenger of Allah (ﷺ) said:,The Chapters on Charity
2126,"حَدَّثَنَا تَمِيمُ بْنُ الْمُنْتَصِرِ الْوَاسِطِيُّ، حَدَّثَنَا إِسْحَاقُ بْنُ يُوسُفَ، عَنْ شَرِيكٍ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ عُمَرَ بْنِ عَبْدِ اللَّهِ بْنِ عُمَرَ يَعْنِي، عَنْ أَبِيهِ، عَنْ جَدِّهِ، عُمَرَ أَنَّهُ تَصَدَّقَ بِفَرَسٍ عَلَى عَهْدِ رَسُولِ اللَّهِ صلى الله عليه وسلم فَأَبْصَرَ صَاحِبَهَا يَبِيعُهَا بِكَسْرٍ فَأَتَى النَّبِيَّ صلى الله عليه وسلم فَسَأَلَهُ عَنْ ذَلِكَ فَقَالَ ‏ ‏ لاَ تَبْتَعْ صَدَقَتَكَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: صحیح البخاری/الإیمان والنذور ۲۸ (۶۶۹۶)،۳۱ (۶۷۰۰)، سنن ابی داود/الإیمان والنذور ۲۲ (۳۲۸۹)، سنن الترمذی/النذور الإیمان ۲ (۱۵۲۶)، سنن النسائی/الإیمان والنذور ۲۶ (۳۸۳۷)،۲۷ (۳۸۳۸،۳۸۳۹)،(تحفة الأشراف:۱۷۴۵۸)، وقد أخرجہ: موطا امام مالک/النذور (۸)، مسند احمد (۶/۳۶،۴۱،۲۲۴، سنن الدارمی/النذور ۳ (۲۳۸۳),,"It was narrated from 'Umar, meaning, from his father, his grandfather 'Umar, that :",The Chapters on Charity
2127,حَدَّثَنَا يَحْيَى بْنُ حَكِيمٍ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، حَدَّثَنَا سُلَيْمَانُ التَّيْمِيُّ، عَنْ أَبِي عُثْمَانَ النَّهْدِيِّ، عَنْ عَبْدِ اللَّهِ بْنِ عَامِرٍ، عَنِ الزُّبَيْرِ بْنِ الْعَوَّامِ، أَنَّهُ حَمَلَ عَلَى فَرَسٍ يُقَالُ لَهُ غَمْرٌ أَوْ غَمْرَةٌ فَرَأَى مُهْرًا أَوْ مُهْرَةً مِنْ أَفْلاَئِهَا يُبَاعُ يُنْسَبُ إِلَى فَرَسِهِ فَنَهَى عَنْهَا ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۹۲۳)، وقد أخرجہ: صحیح مسلم/النذر ۵ (۱۶۴۵)، سنن ابی داود/الأیمان ۳۱ (۳۳۲۳)، سنن الترمذی/الأیمان ۴ (۱۵۲۸)، سنن النسائی/الأیمان ۴۰ (۳۸۶۳)، مسند احمد (۴/۱۴۴،۱۴۶،۱۴۷),2127,It was narrated from Zubair bin 'Awwam that :,The Chapters on Charity
2128,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، عَنْ سُفْيَانَ، عَنْ عَبْدِ اللَّهِ بْنِ عَطَاءٍ، عَنْ عَبْدِ اللَّهِ بْنِ بُرَيْدَةَ، عَنْ أَبِيهِ، قَالَ جَاءَتِ امْرَأَةٌ إِلَى النَّبِيِّ صلى الله عليه وسلم فَقَالَتْ يَا رَسُولَ اللَّهِ إِنِّي تَصَدَّقْتُ عَلَى أُمِّي بِجَارِيَةٍ وَإِنَّهَا مَاتَتْ ‏.‏ فَقَالَ ‏ ‏ آجَرَكِ اللَّهُ وَرَدَّ عَلَيْكِ الْمِيرَاثَ ‏""""‏ ‏.‏""",Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Hasan,takhreej: سنن ابی داود/الأیمان والنذور ۳۰ (۳۳۲۲)،(تحفة الأشراف:۶۳۴۱),,It was narrated from 'Abdullah bin Buraidah that his father said:,The Chapters on Charity
2129,"حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ جَعْفَرٍ الرَّقِّيُّ، حَدَّثَنَا عُبَيْدُ اللَّهِ، عَنْ عَبْدِ الْكَرِيمِ، عَنْ عَمْرِو بْنِ شُعَيْبٍ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، قَالَ جَاءَ رَجُلٌ إِلَى النَّبِيِّ صلى الله عليه وسلم فَقَالَ إِنِّي أَعْطَيْتُ أُمِّي حَدِيقَةً لِي وَإِنَّهَا مَاتَتْ وَلَمْ تَتْرُكْ وَارِثًا غَيْرِي فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ وَجَبَتْ صَدَقَتُكَ وَرَجَعَتْ إِلَيْكَ حَدِيقَتُكَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: صحیح البخاری/الاعتکاف ۵ (۲۰۳۲)،۱۵ (۲۰۴۲)،۱۶ (۲۰۴۳)، صحیح مسلم/الأیمان ۶ (۱۶۵۶)، سنن ابی داود/الصوم۸۰ (۲۴۷۴)، الأیمان ۳۲ (۳۳۲۵)، سنن الترمذی/الأیمان ۱۱ (۱۵۳۹)، سنن النسائی/الأیمان ۳۵ (۳۸۵۱)،(تحفة الأشراف:۱۰۵۵۰)، وقد أخرجہ: مسند احمد (۱/۳۷،۲/۲۰،۸۲،۱۵۳)، سنن الدارمی/النذور ۱ (۲۳۷۸),,"It was narrated from 'Amr  bin Shu'aib, from his father, that his grandfather said:",The Chapters on Charity
2130,"حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ، حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَيْمَانَ، عَنِ ابْنِ عَوْنٍ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ أَصَابَ عُمَرُ بْنُ الْخَطَّابِ أَرْضًا بِخَيْبَرَ فَأَتَى النَّبِيَّ صلى الله عليه وسلم فَاسْتَأْمَرَهُ فَقَالَ يَا رَسُولَ اللَّهِ إِنِّي أَصَبْتُ مَالاً بِخَيْبَرَ لَمْ أُصِبْ مَالاً قَطُّ هُوَ أَنْفَسُ عِنْدِي مِنْهُ فَمَا تَأْمُرُنِي بِهِ فَقَالَ ‏ ‏ إِنْ شِئْتَ حَبَسْتَ أَصْلَهَا وَتَصَدَّقْتَ بِهَا ‏""""‏ ‏.‏ قَالَ فَعَمِلَ بِهَا عُمَرُ عَلَى أَنْ لاَ يُبَاعَ أَصْلُهَا وَلاَ يُوهَبَ وَلاَ يُورَثَ تَصَدَّقَ بِهَا لِلْفُقَرَاءِ وَفِي الْقُرْبَى وَفِي الرِّقَابِ وَفِي سَبِيلِ اللَّهِ وَابْنِ السَّبِيلِ وَالضَّيْفِ لاَ جُنَاحَ عَلَى مَنْ وَلِيَهَا أَنْ يَأْكُلَ مِنْهَا بِالْمَعْرُوفِ أَوْ يُطْعِمَ صَدِيقًا غَيْرَ مُتَمَوِّلٍ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۴۸۶، ومصباح الزجاجة:۷۵۰),,It was narrated that Ibn 'Umar said:,The Chapters on Charity
2131,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِي عُمَرَ الْعَدَنِيُّ، حَدَّثَنَا سُفْيَانُ، عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ قَالَ عُمَرُ بْنُ الْخَطَّابِ يَا رَسُولَ اللَّهِ إِنَّ الْمِائَةَ سَهْمٍ الَّتِي بِخَيْبَرَ لَمْ أُصِبْ مَالاً قَطُّ هُوَ أَحَبُّ إِلَىَّ مِنْهَا وَقَدْ أَرَدْتُ أَنْ أَتَصَدَّقَ بِهَا فَقَالَ النَّبِيُّ صلى الله عليه وسلم ‏ ‏ احْبِسْ أَصْلَهَا وَسَبِّلْ ثَمَرَتَهَا ‏""""‏ ‏.‏ قَالَ ابْنُ أَبِي عُمَرَ فَوَجَدْتُ هَذَا الْحَدِيثَ فِي مَوْضِعٍ آخَرَ فِي كِتَابِي عَنْ سُفْيَانَ عَنْ عَبْدِ اللَّهِ عَنْ نَافِعٍ عَنِ ابْنِ عُمَرَ قَالَ قَالَ عُمَرُ فَذَكَرَ نَحْوَهُ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۸۰۹۲، ومصباح الزجاجة:۷۵۱)، وقد أخرجہ: سنن ابی داود/الأیمان ۲۷ (۳۳۱۴)، مسند احمد (۶/۳۶۶),,It was narrated that Ibn 'Umar said:,The Chapters on Charity
2132,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ عَيَّاشٍ، حَدَّثَنَا شُرَحْبِيلُ بْنُ مُسْلِمٍ، قَالَ سَمِعْتُ أَبَا أُمَامَةَ، يَقُولُ سَمِعْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم يَقُولُ ‏ ‏ الْعَارِيَةُ مُؤَدَّاةٌ وَالْمِنْحَةُ مَرْدُودَةٌ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: صحیح البخاری/الوصایا ۱۹ (۲۷۶۱)، الأیمان والنذور۳۰ (۶۶۹۸)، الحیل ۳ (۶۹۵۹)، صحیح مسلم/النذور۱ (۱۶۳۸)، سنن ابی داود/الأیمان ۲۵ (۳۳۰۷)، سنن الترمذی/الأیمان ۱۹ (۱۵۴۶)، سنن النسائی/الوصایا ۸ (۳۶۸۶)، الأیمان ۳۴ (۳۸۴۸،۳۸۴۹،۳۸۵۰)،(تحفة الأشراف:۵۸۳۵)، وقد أخرجہ: موطا امام مالک/النذور۱ (۱)، مسند احمد (۱/۲۱۹،۳۲۹),,Shurahbil Muslim said:,The Chapters on Charity
2133,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، وَعَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ الدِّمَشْقِيَّانِ، قَالاَ حَدَّثَنَا مُحَمَّدُ بْنُ شُعَيْبٍ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ يَزِيدَ، عَنْ سَعِيدِ بْنِ أَبِي سَعِيدٍ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ سَمِعْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم يَقُولُ ‏ ‏ الْعَارِيَةُ مُؤَدَّاةٌ وَالْمِنْحَةُ مَرْدُودَةٌ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۵۵۴),,It was narrated that Anas bin Malik said:,The Chapters on Charity
2134,"حَدَّثَنَا إِبْرَاهِيمُ بْنُ الْمُسْتَمِرِّ، حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ، ح وَحَدَّثَنَا يَحْيَى بْنُ حَكِيمٍ، حَدَّثَنَا ابْنُ أَبِي عَدِيٍّ، جَمِيعًا عَنْ سَعِيدٍ، عَنْ قَتَادَةَ، عَنِ الْحَسَنِ، عَنْ سَمُرَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ عَلَى الْيَدِ مَا أَخَذَتْ حَتَّى تُؤَدِّيَهُ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الأیمان ۲۳ (۳۲۹۳،۳۲۹۴)، سنن الترمذی/الأیمان ۱۶ (۱۵۴۴)، سنن النسائی/الأیمان ۳۲ (۳۸۴۶)،(تحفة الأشراف:۹۹۳۰)، وقد أخرجہ: مسند احمد (۳/۱۴۳،۴/ ۱۴۵،۱۴۹،۱۵۱)، سنن الدارمی/النذور ۲ (۲۳۷۹),,It was narrated from Samurah that the Messenger of Allah (ﷺ) said:,The Chapters on Charity
2135,"حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ الْجَهْمِ الأَنْمَاطِيُّ، حَدَّثَنَا أَيُّوبُ بْنُ سُوَيْدٍ، عَنِ الْمُثَنَّى، عَنْ عَمْرِو بْنِ شُعَيْبٍ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنْ أُودِعَ وَدِيعَةً فَلاَ ضَمَانَ عَلَيْهِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/النذ ر ۴ (۱۶۴۳)،(تحفة الأشراف:۱۳۹۴۸)، وقد أخرجہ: مسند احمد (۲/۳۷۳)، سنن الدارمی/النذور ۲ (۲۳۸۱),,"It was narrated from 'Amr  bin Shu'aib, from his father, that his grandfather said:",The Chapters on Charity
2136,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ شَبِيبِ بْنِ غَرْقَدَةَ، عَنْ عُرْوَةَ الْبَارِقِيِّ، أَنَّ النَّبِيَّ صلى الله عليه وسلم أَعْطَاهُ دِينَارًا يَشْتَرِي لَهُ شَاةً فَاشْتَرَى لَهُ شَاتَيْنِ فَبَاعَ إِحْدَاهُمَا بِدِينَارٍ فَأَتَى النَّبِيَّ صلى الله عليه وسلم بِدِينَارٍ وَشَاةٍ فَدَعَا لَهُ رَسُولُ اللَّهِ صلى الله عليه وسلم بِالْبَرَكَةِ ‏.‏ قَالَ فَكَانَ لَوِ اشْتَرَى التُّرَابَ لَرَبِحَ فِيهِ ‏.‏ حَدَّثَنَا أَحْمَدُ بْنُ سَعِيدٍ الدَّارِمِيُّ، حَدَّثَنَا حَبَّانُ بْنُ هِلاَلٍ، حَدَّثَنَا سَعِيدُ بْنُ زَيْدٍ، عَنِ الزُّبَيْرِ بْنِ الْخِرِّيتِ، عَنْ أَبِي لَبِيدٍ، لِمَازَةَ بْنِ زَبَّارٍ عَنْ عُرْوَةَ بْنِ أَبِي الْجَعْدِ الْبَارِقِيِّ، قَالَ قَدِمَ جَلَبٌ فَأَعْطَانِي النَّبِيُّ صلى الله عليه وسلم دِينَارًا فَذَكَرَ نَحْوَهُ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۹۳۴),,It was narrated from 'Urwah  Al-Bariqi that :,The Chapters on Charity
2137,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ أَبِي الزِّنَادِ، عَنِ الأَعْرَجِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ الظُّلْمُ مَطْلُ الْغَنِيِّ وَإِذَا أُتْبِعَ أَحَدُكُمْ عَلَى مَلِيءٍ فَلْيَتْبَعْ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: سنن النسائی/البیوع ۱ (۴۴۵۴)،(تحفة الأشراف:۱۵۹۶۱)، وقد أخرجہ: سنن ابی داود/البیوع ۷۹ (۳۵۲۸)، سنن الترمذی/الأحکام ۲۲ (۱۳۵۸)، مسند احمد (۶/۳۱،۴۲،۱۲۷،۱۶۲،۱۹۳،۲۲۰)، سنن الدارمی/البیوع ۶ (۲۵۷۹),,It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said:,The Chapters on Charity
2138,"حَدَّثَنَا إِسْمَاعِيلُ بْنُ تَوْبَةَ، حَدَّثَنَا هُشَيْمٌ، عَنْ يُونُسَ بْنِ عُبَيْدٍ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَطْلُ الْغَنِيِّ ظُلْمٌ وَإِذَا أُحِلْتَ عَلَى مَلِيءٍ فَاتْبَعْهُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۵۶۱)، وقد أخرجہ: صحیح البخاری/البیوع ۱۵ (۲۰۷۲)، مسند احمد (۴/۱۳۱،۱۳۲),,It was narrated from Ibn 'Umar that the Messenger of Allah (ﷺ) said:,The Chapters on Charity
2139,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، وَالْحَسَنُ بْنُ عَرَفَةَ، قَالاَ حَدَّثَنَا إِسْمَاعِيلُ بْنُ عَيَّاشٍ، حَدَّثَنِي شُرَحْبِيلُ بْنُ مُسْلِمٍ الْخَوْلاَنِيُّ، قَالَ سَمِعْتُ أَبَا أُمَامَةَ الْبَاهِلِيَّ، يَقُولُ سَمِعْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم يَقُولُ ‏ ‏ الزَّعِيمُ غَارِمٌ وَالدَّيْنُ مَقْضِيٌّ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۵۹۸، ومصباح الزجاجة:۷۵۵),,Shurahbil bin Muslim Al-Khawlani said:,The Chapters on Charity
2140,"حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ الدَّرَاوَرْدِيُّ، عَنْ عَمْرِو بْنِ أَبِي عَمْرٍو، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ رَجُلاً، لَزِمَ غَرِيمًا لَهُ بِعَشَرَةِ دَنَانِيرَ عَلَى عَهْدِ رَسُولِ اللَّهِ صلى الله عليه وسلم فَقَالَ مَا عِنْدِي شَىْءٌ أُعْطِيكَهُ فَقَالَ لاَ وَاللَّهِ لاَ أُفَارِقُكَ حَتَّى تَقْضِيَنِي أَوْ تَأْتِيَنِي بِحَمِيلٍ فَجَرَّهُ إِلَى النَّبِيِّ صلى الله عليه وسلم فَقَالَ لَهُ النَّبِيُّ صلى الله عليه وسلم ‏""‏ كَمْ تَسْتَنْظِرُهُ ‏""‏ ‏.‏ فَقَالَ شَهْرًا فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏""‏ فَأَنَا أَحْمِلُ لَهُ ‏""‏ ‏.‏ فَجَاءَهُ فِي الْوَقْتِ الَّذِي قَالَ النَّبِيُّ صلى الله عليه وسلم فَقَالَ لَهُ النَّبِيُّ صلى الله عليه وسلم ‏""‏ مِنْ أَيْنَ أَصَبْتَ هَذَا ‏""‏ ‏.‏ قَالَ مِنْ مَعْدِنٍ قَالَ ‏""‏ لاَ خَيْرَ فِيهَا ‏""‏ ‏.‏ وَقَضَاهَا عَنْهُ ‏.‏",Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: صحیح البخاری/النفقات ۱ (۵۳۵۳)، صحیح مسلم/الزہد والرقائق ۲ (۲۹۸۲)، سنن الترمذی/البروالصلة ۴۴ (۱۹۶۹)، سنن النسائی/الزکاة ۷۸ (۲۵۷۸)،(تحفة الأشراف:۱۲۹۱۴)، وقد أخرجہ: مسند احمد (۲/۳۶۱),2140,It was narrated from Ibn 'Abbas:,The Chapters on Charity
2141,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا أَبُو عَامِرٍ، حَدَّثَنَا شُعْبَةُ، عَنْ عُثْمَانَ بْنِ عَبْدِ اللَّهِ بْنِ مَوْهَبٍ، قَالَ سَمِعْتُ عَبْدَ اللَّهِ بْنَ أَبِي قَتَادَةَ، عَنْ أَبِيهِ، أَنَّ النَّبِيَّ صلى الله عليه وسلم أُتِيَ بِجِنَازَةٍ لِيُصَلِّيَ عَلَيْهَا فَقَالَ ‏""‏ صَلُّوا عَلَى صَاحِبِكُمْ فَإِنَّ عَلَيْهِ دَيْنًا ‏""‏ ‏.‏ فَقَالَ أَبُو قَتَادَةَ أَنَا أَتَكَفَّلُ بِهِ ‏.‏ قَالَ النَّبِيُّ صلى الله عليه وسلم ‏""‏ بِالْوَفَاءِ ‏""‏ ‏.‏ قَالَ بِالْوَفَاءِ ‏.‏ وَكَانَ الَّذِي عَلَيْهِ ثَمَانِيَةَ عَشَرَ أَوْ تِسْعَةَ عَشَرَ دِرْهَمًا ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۵۶۰۶، ومصباح الزجاجة:۷۵۶)، وقد أخرجہ: مسند احمد (۵/۳۷۲،۳۸۱),2141,It was narrated that 'Uthman bin 'Abdullah bin Mawhab said:,The Chapters on Charity
2142,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبِيدَةُ بْنُ حُمَيْدٍ، عَنْ مَنْصُورٍ، عَنْ زِيَادِ بْنِ عَمْرِو بْنِ هِنْدٍ، عَنِ ابْنِ حُذَيْفَةَ، - هُوَ عِمْرَانُ - عَنْ أُمِّ الْمُؤْمِنِينَ، مَيْمُونَةَ قَالَ كَانَتْ تَدَّانُ دَيْنًا فَقَالَ لَهَا بَعْضُ أَهْلِهَا لاَ تَفْعَلِي وَأَنْكَرَ ذَلِكَ عَلَيْهَا قَالَتْ بَلَى إِنِّي سَمِعْتُ نَبِيِّي وَخَلِيلِي صلى الله عليه وسلم يَقُولُ ‏ ‏ مَا مِنْ مُسْلِمٍ يَدَّانُ دَيْنًا يَعْلَمُ اللَّهُ مِنْهُ أَنَّهُ يُرِيدُ أَدَاءَهُ إِلاَّ أَدَّاهُ اللَّهُ عَنْهُ فِي الدُّنْيَا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۸۹۴، ومصباح الزجاجة:۷۵۷),,It was narrated that :,The Chapters on Charity
2143,"حَدَّثَنَا إِبْرَاهِيمُ بْنُ الْمُنْذِرِ، حَدَّثَنَا ابْنُ أَبِي فُدَيْكٍ، حَدَّثَنَا سَعِيدُ بْنُ سُفْيَانَ، - مَوْلَى الأَسْلَمِيِّينَ - عَنْ جَعْفَرِ بْنِ مُحَمَّدٍ، عَنْ أَبِيهِ، عَنْ عَبْدِ اللَّهِ بْنِ جَعْفَرٍ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ إِنَّ اللَّهَ مَعَ الدَّائِنِ حَتَّى يَقْضِيَ دَيْنَهُ مَا لَمْ يَكُنْ فِيمَا يَكْرَهُ اللَّهُ ‏""""‏ ‏.‏ قَالَ فَكَانَ عَبْدُ اللَّهِ بْنُ جَعْفَرٍ يَقُولُ لِخَازِنِهِ اذْهَبْ فَخُذْ لِي بِدَيْنٍ فَإِنِّي أَكْرَهُ أَنْ أَبِيتَ لَيْلَةً إِلاَّ وَاللَّهُ مَعِي بَعْدَ الَّذِي سَمِعْتُ مِنْ رَسُولِ اللَّهِ صلى الله عليه وسلم ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۶۸۴، ومصباح الزجاجة:۷۵۸),,It was narrated from 'Abdullah bin Ja'far that the Messenger of Allah (ﷺ) said:,The Chapters on Charity
2144,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا يُوسُفُ بْنُ مُحَمَّدِ بْنِ صَيْفِيِّ بْنِ صُهَيْبِ الْخَيْرِ، حَدَّثَنِي عَبْدُ الْحَمِيدِ بْنُ زِيَادِ بْنِ صَيْفِيِّ بْنِ صُهَيْبٍ، عَنْ شُعَيْبِ بْنِ عَمْرٍو، حَدَّثَنَا صُهَيْبُ الْخَيْرِ، عَنْ رَسُولِ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ أَيُّمَا رَجُلٍ يَدَيَّنُ دَيْنًا وَهُوَ مُجْمِعٌ أَنْ لاَ يُوَفِّيَهُ إِيَّاهُ لَقِيَ اللَّهَ سَارِقًا ‏""""‏ ‏.‏ حَدَّثَنَا إِبْرَاهِيمُ بْنُ الْمُنْذِرِ الْحِزَامِيُّ، حَدَّثَنَا يُوسُفُ بْنُ مُحَمَّدِ بْنِ صَيْفِيٍّ، عَنْ عَبْدِ الْحَمِيدِ بْنِ زِيَادٍ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، صُهَيْبٍ عَنِ النَّبِيِّ صلى الله عليه وسلم نَحْوَهُ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۸۸۰، ومصباح الزجاجة:۷۵۹),,Suhaib Al-Khair narrated that the Messenger of Allah (ﷺ) said:,The Chapters on Charity
2145,"حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ، عَنْ ثَوْرِ بْنِ زَيْدٍ الدِّيلِيِّ، عَنْ أَبِي الْغَيْثِ، - مَوْلَى ابْنِ مُطِيعٍ - عَنْ أَبِي هُرَيْرَةَ، أَنَّ النَّبِيَّ صلى الله عليه وسلم قَالَ ‏ ‏ مَنْ أَخَذَ أَمْوَالَ النَّاسِ يُرِيدُ إِتْلاَفَهَا أَتْلَفَهُ اللَّهُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: سنن ابی داود/البیوع ۱ (۳۳۲۶،۳۳۲۷)، سنن الترمذی/البیوع ۴ (۱۲۰۸)، سنن النسائی/الأیمان ۲۱ (۳۸۲۸)، البیوع ۷ (۴۴۶۸)،(تحفة الأشراف:۱۱۱۰۳)، وقد أخرجہ: مسند احمد (۴/۶،۲۸۰),,It was narrated from Abu Hurairah that the Prophet (ﷺ) said:,The Chapters on Charity
2146,"حَدَّثَنَا حُمَيْدُ بْنُ مَسْعَدَةَ، حَدَّثَنَا خَالِدُ بْنُ الْحَارِثِ، حَدَّثَنَا سَعِيدٌ، عَنْ قَتَادَةَ، عَنْ سَالِمِ بْنِ أَبِي الْجَعْدِ، عَنْ مَعْدَانَ بْنِ أَبِي طَلْحَةَ، عَنْ ثَوْبَانَ، - مَوْلَى رَسُولِ اللَّهِ صلى الله عليه وسلم - عَنْ رَسُولِ اللَّهِ صلى الله عليه وسلم أَنَّهُ قَالَ ‏ ‏ مَنْ فَارَقَ الرُّوحُ الْجَسَدَ وَهُوَ بَرِيءٌ مِنْ ثَلاَثٍ دَخَلَ الْجَنَّةَ مِنَ الْكِبْرِ وَالْغُلُولِ وَالدَّيْنِ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Hasan Lighairihi; Zubair Ali Zai: Isnaad Hasan,takhreej: سنن الترمذی/البیوع ۴ (۱۲۱۰)،(تحفة الأشراف:۳۶۰۷)، وقد أخرجہ: سنن الدارمی/البیوع ۷ (۲۵۸۰),,"It was narrated from Thawban, the freed slave of the Messenger of Allah (ﷺ), that the Messenger of Allah (ﷺ) said:",The Chapters on Charity
2147,"حَدَّثَنَا أَبُو مَرْوَانَ الْعُثْمَانِيُّ، حَدَّثَنَا إِبْرَاهِيمُ بْنُ سَعْدٍ، عَنْ أَبِيهِ، عَنْ عُمَرَ بْنِ أَبِي سَلَمَةَ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ نَفْسُ الْمُؤْمِنِ مُعَلَّقَةٌ بِدَيْنِهِ حَتَّى يُقْضَى عَنْهُ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۶۴۲، ومصباح الزجاجة:۷۶۰),,It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) that the Messenger of Allah (ﷺ) said:,The Chapters on Charity
2148,"حَدَّثَنَا مُحَمَّدُ بْنُ ثَعْلَبَةَ بْنِ سَوَاءٍ، حَدَّثَنَا عَمِّي، مُحَمَّدُ بْنُ سَوَاءٍ عَنْ حُسَيْنٍ الْمُعَلِّمِ، عَنْ مَطَرٍ الْوَرَّاقِ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنْ مَاتَ وَعَلَيْهِ دِينَارٌ أَوْ دِرْهَمٌ قُضِيَ مِنْ حَسَنَاتِهِ لَيْسَ ثَمَّ دِينَارٌ وَلاَ دِرْهَمٌ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۷۶۷۴، ومصباح الزجاجة:۷۶۱)، وقد أخرجہ: مسند احمد (۶/۲۴۶),,It was narrated from Ibn 'Umar that the Messenger of Allah (ﷺ) said:,The Chapters on Charity
2149,"حَدَّثَنَا أَحْمَدُ بْنُ عَمْرِو بْنِ السَّرْحِ الْمِصْرِيُّ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، أَخْبَرَنِي يُونُسُ، عَنِ ابْنِ شِهَابٍ، عَنْ أَبِي سَلَمَةَ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم كَانَ يَقُولُ إِذَا تُوُفِّيَ الْمُؤْمِنُ فِي عَهْدِ رَسُولِ اللَّهِ صلى الله عليه وسلم وَعَلَيْهِ الدَّيْنُ فَيَسْأَلُ ‏""‏ هَلْ تَرَكَ لِدَيْنِهِ مِنْ قَضَاءٍ ‏""‏ ‏.‏ فَإِنْ قَالُوا نَعَمْ ‏.‏ صَلَّى عَلَيْهِ وَإِنْ قَالُوا لاَ ‏.‏ قَالَ ‏""‏ صَلُّوا عَلَى صَاحِبِكُمْ ‏""‏ ‏.‏ فَلَمَّا فَتَحَ اللَّهُ عَلَى رَسُولِهِ الْفُتُوحَ قَالَ ‏""‏ أَنَا أَوْلَى بِالْمُؤْمِنِينَ مِنْ أَنْفُسِهِمْ فَمَنْ تُوُفِّيَ وَعَلَيْهِ دَيْنٌ فَعَلَىَّ قَضَاؤُهُ وَمَنْ تَرَكَ مَالاً فَهُوَ لِوَرَثَتِهِ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: صحیح البخاری/الإجارة ۲ (۲۲۶۲)،(تحفة الأشراف:۱۳۰۸۳),2149,It was narrated from Abu Hurairah that:,The Chapters on Charity
2150,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا سُفْيَانُ، عَنْ جَعْفَرِ بْنِ مُحَمَّدٍ، عَنْ أَبِيهِ، عَنْ جَابِرٍ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنْ تَرَكَ مَالاً فَلِوَرَثَتِهِ وَمَنْ تَرَكَ دَيْنًا أَوْ ضَيَاعًا فَعَلَىَّ وَإِلَىَّ وَأَنَا أَوْلَى بِالْمُؤْمِنِينَ ‏""""‏ ‏.‏""",Al-Albani: Sahih Hadith; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الفضائل ۴۵ (۲۳۷۹)،(تحفة الأشراف:۱۴۶۵۲)، وقد أخرجہ: مسند احمد (۲/۲۹۶،۴۰۵،۴۸۵),,It was narrated from Jabir that the Messenger of Allah (ﷺ) said:,The Chapters on Charity
2151,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، عَنِ الأَعْمَشِ، عَنْ أَبِي صَالِحٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنْ يَسَّرَ عَلَى مُعْسِرٍ يَسَّرَ اللَّهُ عَلَيْهِ فِي الدُّنْيَا وَالآخِرَةِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/التوحید ۶۵ (۷۵۵۷)، سنن النسائی/الزینة من المجتبیٰ ۵۹ (۵۳۶۴)،(تحفة الأشراف:۱۷۵۵۷)، وقد أخرجہ:۶/۷۰،۸۰،۲۲۳،۲۴۶),,It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said:,The Chapters on Charity
2152,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا أَبِي، حَدَّثَنَا الأَعْمَشُ، عَنْ نُفَيْعٍ أَبِي دَاوُدَ، عَنْ بُرَيْدَةَ الأَسْلَمِيِّ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ مَنْ أَنْظَرَ مُعْسِرًا كَانَ لَهُ بِكُلِّ يَوْمٍ صَدَقَةٌ وَمَنْ أَنْظَرَهُ بَعْدَ حِلِّهِ كَانَ لَهُ مِثْلُهُ فِي كُلِّ يَوْمٍ صَدَقَةٌ ‏""""‏ ‏.‏""",Al-Albani: Mawdu; Muhammad Fouad Abd al-Baqi: Mawdu; Shuaib Al Arnaut: Mawdu; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۴۸۳۸، ومصباح الزجاجة:۷۶۲)، وقد أخرجہ: مسند احمد (۲/۲۹۲،۳۲۴،۳۴۵),,It was narrated from Buraidah Al-Aslami that the Prophet (ﷺ) said:,The Chapters on Charity
2153,"حَدَّثَنَا يَعْقُوبُ بْنُ إِبْرَاهِيمَ الدَّوْرَقِيُّ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ إِبْرَاهِيمَ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ إِسْحَاقَ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ مُعَاوِيَةَ، عَنْ حَنْظَلَةَ بْنِ قَيْسٍ، عَنْ أَبِي الْيَسَرِ، صَاحِبِ النَّبِيِّ صلى الله عليه وسلم قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنْ أَحَبَّ أَنْ يُظِلَّهُ اللَّهُ فِي ظِلِّهِ - فَلْيُنْظِرْ مُعْسِرًا أَوْ لِيَضَعْ لَهُ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشرا:۱۰۴۵۵، ومصباح الزجاجة:۷۶۳)، وقد أخرجہ: سنن الدارمی/البیوع ۱۲ (۲۵۸۶),,"It was narrated from Abu Yasar, the Companion of the Prophet (ﷺ) that :",The Chapters on Charity
2154,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا أَبُو عَامِرٍ، حَدَّثَنَا شُعْبَةُ، عَنْ عَبْدِ الْمَلِكِ بْنِ عُمَيْرٍ، قَالَ سَمِعْتُ رِبْعِيَّ بْنَ حِرَاشٍ، يُحَدِّثُ عَنْ حُذَيْفَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم ‏ ‏ أَنَّ رَجُلاً مَاتَ فَقِيلَ لَهُ مَا عَمِلْتَ - فَإِمَّا ذَكَرَ أَوْ ذُكِّرَ - قَالَ إِنِّي كُنْتُ أَتَجَوَّزُ فِي السِّكَّةِ وَالنَّقْدِ وَأُنْظِرُ الْمُعْسِرَ ‏.‏ فَغَفَرَ اللَّهُ لَهُ ‏""""‏ ‏.‏ قَالَ أَبُو مُسْعُودٍ أَنَا قَدْ، سَمِعْتُ هَذَا، مِنْ رَسُولِ اللَّهِ صلى الله عليه وسلم ‏.‏""",Al-Albani: Sahih Hadith; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: صحیح مسلم/المساقاة ۲۶ (۱۶۰۵)، سنن ابی داود/البیوع ۴۹ (۳۴۴۷)، سنن الترمذی/البیوع ۴۰ (۱۲۶۷)،(تحفة الأشراف:۱۱۴۸۱)، وقد أخرجہ: مسند احمد (۳/۴۵۳،۴۵۴،۶/۴۰۰،)، سنن الدارمی/البیوع ۱۲ (۲۵۸۵),,It was narrated from Hudhaifah that the Prophet (ﷺ) said:,The Chapters on Charity
2155,"حَدَّثَنَا مُحَمَّدُ بْنُ خَلَفٍ الْعَسْقَلاَنِيُّ، وَمُحَمَّدُ بْنُ يَحْيَى، قَالاَ حَدَّثَنَا ابْنُ أَبِي مَرْيَمَ، حَدَّثَنَا يَحْيَى بْنُ أَيُّوبَ، عَنْ عُبَيْدِ اللَّهِ بْنِ أَبِي جَعْفَرٍ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، وَعَائِشَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ مَنْ طَلَبَ حَقًّا فَلْيَطْلُبْهُ فِي عَفَافٍ وَافٍ أَوْ غَيْرِ وَافٍ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Isnaad Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۶۲۲، ومصباح الزجاجة:۷۶۴)، وقد أخرجہ: مسند احمد (۱/۲۱),,It was narrated from Ibn 'Umar and 'Aishah that the Messenger of Allah (ﷺ) said:,The Chapters on Charity
2156,"حَدَّثَنَا مُحَمَّدُ بْنُ الْمُؤَمَّلِ بْنِ الصَّبَّاحِ الْقَيْسِيُّ، حَدَّثَنَا مُحَمَّدُ بْنُ مُحَبَّبٍ الْقُرَشِيُّ، حَدَّثَنَا سَعِيدُ بْنُ السَّائِبِ الطَّائِفِيُّ، عَنْ عَبْدِ اللَّهِ بْنِ يَامِينَ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ لِصَاحِبِ الْحَقِّ ‏ ‏ خُذْ حَقَّكَ فِي عَفَافٍ وَافٍ أَوْ غَيْرِ وَافٍ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «صحیح البخاری/الإجارة ۱۶ (۲۲۷۶)، صحیح مسلم/السلام ۲۳ (۲۲۰۱)، سنن ابی داود/الطب ۱۹ (۳۹۰۰)، سنن الترمذی/الطب ۲۰ (۲۰۶۳،۲۰۶۴)،(تحفة الأشراف:۴۲۴۹،۴۳۰۷)، وقد أخرجہ: مسند احمد (۳/۴۴),,It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said to the one who was entitled to something:,The Chapters on Charity
2157,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا شَبَابَةُ، ح وَحَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، قَالاَ حَدَّثَنَا شُعْبَةُ، عَنْ سَلَمَةَ بْنِ كُهَيْلٍ، سَمِعْتُ أَبَا سَلَمَةَ بْنَ عَبْدِ الرَّحْمَنِ، يُحَدِّثُ عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ إِنَّ خَيْرَكُمْ - أَوْ مِنْ خَيْرِكُمْ - أَحَاسِنُكُمْ قَضَاءً ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: سنن ابی داود/البیوع ۳۷ (۳۴۱۶)،(تحفة الأشراف:۵۰۶۸)، وقدأخرجہ: مسند احمد (۵/۳۱۵),,It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said:,The Chapters on Charity
2158,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ إِبْرَاهِيمَ بْنِ عَبْدِ اللَّهِ بْنِ أَبِي رَبِيعَةَ الْمَخْزُومِيُّ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، أَنَّ النَّبِيَّ صلى الله عليه وسلم اسْتَسْلَفَ مِنْهُ حِينَ غَزَا حُنَيْنًا ثَلاَثِينَ أَوْ أَرْبَعِينَ أَلْفًا فَلَمَّا قَدِمَ قَضَاهَا إِيَّاهُ ثُمَّ قَالَ لَهُ النَّبِيُّ صلى الله عليه وسلم ‏ ‏ بَارَكَ اللَّهُ لَكَ فِي أَهْلِكَ وَمَالِكَ إِنَّمَا جَزَاءُ السَّلَفِ الْوَفَاءُ وَالْحَمْدُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۹، ومصباح الزجاجة:۷۵۸),,"Isma'il bin Abi Rabi'ah Al-Makhzumi narrated from his father, from his grandfather, that :",The Chapters on Charity
2159,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الأَعْلَى الصَّنْعَانِيُّ، حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَيْمَانَ، عَنْ أَبِيهِ، عَنْ حَنَشٍ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ جَاءَ رَجُلٌ يَطْلُبُ نَبِيَّ اللَّهِ صلى الله عليه وسلم بِدَيْنٍ أَوْ بِحَقٍّ فَتَكَلَّمَ بِبَعْضِ الْكَلاَمِ فَهَمَّ صَحَابَةُ رَسُولِ اللَّهِ صلى الله عليه وسلم بِهِ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَهْ إِنَّ صَاحِبَ الدَّيْنِ لَهُ سُلْطَانٌ عَلَى صَاحِبِهِ حَتَّى يَقْضِيَهُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: صحیح البخاری/البیوع ۱۱۳ (۲۲۳۷)، الإجارة ۲۰ (۲۲۸۲)، الطلاق ۵۱ (۵۳۴۶)، الطب ۴۶ (۵۷۶۱)، صحیح مسلم/المساقاة ۹ (۱۵۶۷)، سنن ابی داود/البیوع ۴۱ (۳۴۲۸)،۶۵ (۳۴۸۱)، سنن الترمذی/البیوع ۴۶ (۱۲۷۶)، النکاح ۳۷ (۱۱۳۳)، الطب ۲۳ (۲۰۷۱)، سنن النسائی/الصید والذبائح ۱۵ (۴۲۹۷)،(تحفة الأشراف:۱۰۰۱۰)، وقد أخرجہ: موطا امام مالک/البیوع ۲۹ (۶۸)، مسند احمد (۱/۱۱۸،۱۲۰،۱۴۰،۱۴۱)، سنن الدارمی/البیوع ۳۴ (۲۶۱۰),,It was narrated that Ibn 'Abbas said:,The Chapters on Charity
2160,"حَدَّثَنَا إِبْرَاهِيمُ بْنُ عَبْدِ اللَّهِ بْنِ مُحَمَّدِ بْنِ عُثْمَانَ أَبُو شَيْبَةَ، حَدَّثَنَا ابْنُ أَبِي عُبَيْدَةَ، - أَظُنُّهُ قَالَ - حَدَّثَنَا أَبِي، عَنِ الأَعْمَشِ، عَنْ أَبِي صَالِحٍ، عَنْ أَبِي سَعِيدٍ الْخُدْرِيِّ، قَالَ جَاءَ أَعْرَابِيٌّ إِلَى النَّبِيِّ صلى الله عليه وسلم يَتَقَاضَاهُ دَيْنًا كَانَ عَلَيْهِ فَاشْتَدَّ عَلَيْهِ حَتَّى قَالَ لَهُ أُحَرِّجُ عَلَيْكَ إِلاَّ قَضَيْتَنِي ‏.‏ فَانْتَهَرَهُ أَصْحَابُهُ وَقَالُوا وَيْحَكَ تَدْرِي مَنْ تُكَلِّمُ قَالَ إِنِّي أَطْلُبُ حَقِّي ‏.‏ فَقَالَ النَّبِيُّ صلى الله عليه وسلم ‏""‏ هَلاَّ مَعَ صَاحِبِ الْحَقِّ كُنْتُمْ ‏""‏ ‏.‏ ثُمَّ أَرْسَلَ إِلَى خَوْلَةَ بِنْتِ قَيْسٍ فَقَالَ لَهَا ‏""‏ إِنْ كَانَ عِنْدَكِ تَمْرٌ فَأَقْرِضِينَا حَتَّى يَأْتِيَنَا تَمْرٌ فَنَقْضِيَكِ ‏""‏ ‏.‏ فَقَالَتْ نَعَمْ بِأَبِي أَنْتَ يَا رَسُولَ اللَّهِ ‏.‏ قَالَ فَأَقْرَضَتْهُ فَقَضَى الأَعْرَابِيَّ وَأَطْعَمَهُ فَقَالَ أَوْفَيْتَ أَوْفَى اللَّهُ لَكَ ‏.‏ فَقَالَ ‏""‏ أُولَئِكَ خِيَارُ النَّاسِ إِنَّهُ لاَ قُدِّسَتْ أُمَّةٌ لاَ يَأْخُذُ الضَّعِيفُ فِيهَا حَقَّهُ غَيْرَ مُتَعْتَعٍ ‏""‏ ‏.‏",Al-Albani: Sahih Hadith; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۳۴۰۷)، وقہ أخرجہ: سنن ابی داود/البیوع ۶۵ (۳۴۸۱)، سنن النسائی/الصید والذبائح ۱۵ (۴۲۹۷),2160,It was narrated that Abu Sa'eed Al-Khudri said:,The Chapters on Charity
2161,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا وَبْرُ بْنُ أَبِي دُلَيْلَةَ الطَّائِفِيُّ، حَدَّثَنِي مُحَمَّدُ بْنُ مَيْمُونِ بْنِ مُسَيْكَةَ، - قَالَ وَكِيعٌ وَأَثْنَى عَلَيْهِ خَيْرًا - عَنْ عَمْرِو بْنِ الشَّرِيدِ، عَنْ أَبِيهِ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ لَىُّ الْوَاجِدِ يُحِلُّ عِرْضَهُ وَعُقُوبَتَهُ ‏""""‏ ‏.‏ قَالَ عَلِيٌّ الطَّنَافِسِيُّ يَعْنِي عِرْضَهُ شِكَايَتَهُ وَعُقُوبَتَهُ سِجْنَهُ ‏.‏""",Al-Albani: Sahih Hadith; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: تفرد بہ ابن ماجہ:(تحفة الأشراف:۲۷۸۳)، وقد أخرجہ: سنن الترمذی/البیوع ۴۹ (۱۲۷۹)، سنن النسائی/الصید ۱۶ (۴۳۰۰)، البیوع ۹۰ (۴۶۷۲)، سنن ابی داود/البیوع ۶۴ (۳۴۷۹)، مسند احمد (۳/۳۳۹،۳۴۹),,It was narrated from 'Amr bin Sharid that his father said that the Messenger of Allah (ﷺ)  said:,The Chapters on Charity
2162,"حَدَّثَنَا هَدِيَّةُ بْنُ عَبْدِ الْوَهَّابِ، حَدَّثَنَا النَّضْرُ بْنُ شُمَيْلٍ، حَدَّثَنَا الْهِرْمَاسُ بْنُ حَبِيبٍ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، قَالَ أَتَيْتُ النَّبِيَّ صلى الله عليه وسلم بِغَرِيمٍ لِي فَقَالَ لِي ‏""‏ الْزَمْهُ ‏""‏ ‏.‏ ثُمَّ مَرَّ بِي آخِرَ النَّهَارِ فَقَالَ ‏""‏ مَا فَعَلَ أَسِيرُكَ يَا أَخَا بَنِي تَمِيمٍ ‏""‏ ‏.‏",Al-Albani: Sahih Hadith; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: صحیح البخاری/جزاء الصید ۱۱ (۱۸۳۵)، الصوم ۳۲ (۱۹۳۸)، الإجارة ۱۸ (۲۲۷۸)، الطب ۹ (۵۶۹۱)، صحیح مسلم/الحج ۱۱ (۱۲۰۲)،(تحفة الأشراف:۵۷۰۹)، وقد أخرجہ: سنن ابی داود/الحج ۳۶ (۱۸۳۵)، سنن الترمذی/الحج ۲۲ (۸۳۹)، سنن النسائی/الحج ۹۲ (۲۸۴۹)، مسند احمد (۱/۲۱۵،۲۲۱،۲۲۲،۲۳۶،۲۴۸،۲۴۹،۲۶۰،۲۸۳،۲۸۶،۲۹۲،۳۰۶،۳۱۵،۳۳۳،۳۴۶،۳۵۱،۳۷۲،۳۷۴)، سنن الدارمی/البیوع ۷۹ (۲۶۶۴),2162,Hirmas bin Habib narrated from his father that his grandfather said:,The Chapters on Charity
2163,"حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، وَيَحْيَى بْنُ حَكِيمٍ، قَالاَ حَدَّثَنَا عُثْمَانُ بْنُ عُمَرَ، أَنْبَأَنَا يُونُسُ بْنُ يَزِيدَ، عَنِ الزُّهْرِيِّ، عَنْ عَبْدِ اللَّهِ بْنِ كَعْبِ بْنِ مَالِكٍ، عَنْ أَبِيهِ، أَنَّهُ تَقَاضَى ابْنَ أَبِي حَدْرَدٍ دَيْنًا لَهُ عَلَيْهِ فِي الْمَسْجِدِ حَتَّى ارْتَفَعَتْ أَصْوَاتُهُمَا حَتَّى سَمِعَهُمَا رَسُولُ اللَّهِ صلى الله عليه وسلم وَهُوَ فِي بَيْتِهِ فَخَرَجَ إِلَيْهِمَا فَنَادَى كَعْبًا فَقَالَ لَبَّيْكَ يَا رَسُولَ اللَّهِ قَالَ ‏""‏ دَعْ مِنْ دَيْنِكَ هَذَا ‏""‏ ‏.‏ وَأَوْمَأَ بِيَدِهِ إِلَى الشَّطْرِ فَقَالَ قَدْ فَعَلْتُ ‏.‏ قَالَ ‏""‏ قُمْ فَاقْضِهِ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih Lighairihi; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۲۸۴، ومصباح الزجاجة:۷۶۶)، وقد أخرجہ: مسند احمد (۱/۹۰،۱۳۴،۱۳۵),2163,It was narrated from 'Abdullah bin Ka'b bin Malik from his father that :,The Chapters on Charity
2164,"حَدَّثَنَا مُحَمَّدُ بْنُ خَلَفٍ الْعَسْقَلاَنِيُّ، حَدَّثَنَا يَعْلَى، حَدَّثَنَا سُلَيْمَانُ بْنُ يُسَيْرٍ، عَنْ قَيْسِ بْنِ رُومِيٍّ، قَالَ كَانَ سُلَيْمَانُ بْنُ أُذُنَانٍ يُقْرِضُ عَلْقَمَةَ أَلْفَ دِرْهَمٍ إِلَى عَطَائِهِ فَلَمَّا خَرَجَ عَطَاؤُهُ تَقَاضَاهَا مِنْهُ وَاشْتَدَّ عَلَيْهِ فَقَضَاهُ فَكَأَنَّ عَلْقَمَةَ غَضِبَ فَمَكَثَ أَشْهُرًا ثُمَّ أَتَاهُ فَقَالَ أَقْرِضْنِي أَلْفَ دِرْهَمٍ إِلَى عَطَائِي قَالَ نَعَمْ وَكَرَامَةً يَا أُمَّ عُتْبَةَ هَلُمِّي تِلْكَ الْخَرِيطَةَ الْمَخْتُومَةَ الَّتِي عِنْدَكِ ‏.‏ فَجَاءَتْ بِهَا فَقَالَ أَمَا وَاللَّهِ إِنَّهَا لَدَرَاهِمُكَ الَّتِي قَضَيْتَنِي مَا حَرَّكْتُ مِنْهَا دِرْهَمًا وَاحِدًا ‏.‏ قَالَ فَلِلَّهِ أَبُوكَ مَا حَمَلَكَ عَلَى مَا فَعَلْتَ بِي ‏.‏ قَالَ مَا سَمِعْتُ مِنْكَ ‏.‏ قَالَ مَا سَمِعْتَ مِنِّي قَالَ سَمِعْتُكَ تَذْكُرُ عَنِ ابْنِ مَسْعُودٍ أَنَّ النَّبِيَّ صلى الله عليه وسلم قَالَ ‏ ‏ مَا مِنْ مُسْلِمٍ يُقْرِضُ مُسْلِمًا قَرْضًا مَرَّتَيْنِ إِلاَّ كَانَ كَصَدَقَتِهَا مَرَّةً ‏""""‏ ‏.‏ قَالَ كَذَلِكَ أَنْبَأَنِي ابْنُ مَسْعُودٍ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۴۷۱)، وقد أخرجہ: صحیح البخاری/الطب ۱۳ (۵۶۹۶)، صحیح مسلم/المسا قاة ۱۱ (۱۵۷۷)، سنن ابی داود/البیوع ۳۹ (۳۴۲۴)، سنن الترمذی/البیوع ۴۸ (۱۲۷۸)، موطا امام مالک/الإستئذان ۱۰ (۲۶),,It was narrated that Qais bin Rumi said:,The Chapters on Charity
2165,"حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ عَبْدِ الْكَرِيمِ، حَدَّثَنَا هِشَامُ بْنُ خَالِدٍ، حَدَّثَنَا خَالِدُ بْنُ يَزِيدَ بْنِ أَبِي مَالِكٍ، وَحَدَّثَنَا أَبُو حَاتِمٍ، حَدَّثَنَا هِشَامُ بْنُ خَالِدٍ، حَدَّثَنَا خَالِدُ بْنُ يَزِيدَ بْنِ أَبِي مَالِكٍ، عَنْ أَبِيهِ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ رَأَيْتُ لَيْلَةَ أُسْرِيَ بِي عَلَى بَابِ الْجَنَّةِ مَكْتُوبًا الصَّدَقَةُ بِعَشْرِ أَمْثَالِهَا وَالْقَرْضُ بِثَمَانِيَةَ عَشَرَ ‏.‏ فَقُلْتُ يَا جِبْرِيلُ مَا بَالُ الْقَرْضِ أَفْضَلُ مِنَ الصَّدَقَةِ ‏.‏ قَالَ لأَنَّ السَّائِلَ يَسْأَلُ وَعِنْدَهُ وَالْمُسْتَقْرِضُ لاَ يَسْتَقْرِضُ إِلاَّ مِنْ حَاجَةٍ ‏""""‏ ‏.‏""",Al-Albani: Sahih Hadith; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۰۱۱، ومصباح الزجاجة:۷۶۷),,It was narrated from Anas bin Malik that the Messenger of Allah (ﷺ) said:,The Chapters on Charity
2166,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ عَيَّاشٍ، حَدَّثَنِي عُتْبَةُ بْنُ حُمَيْدٍ الضَّبِّيُّ، عَنْ يَحْيَى بْنِ أَبِي إِسْحَاقَ الْهُنَائِيِّ، قَالَ سَأَلْتُ أَنَسَ بْنَ مَالِكٍ الرَّجُلُ مِنَّا يُقْرِضُ أَخَاهُ الْمَالَ فَيُهْدِي لَهُ قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ إِذَا أَقْرَضَ أَحَدُكُمْ قَرْضًا فَأَهْدَى لَهُ أَوْ حَمَلَهُ عَلَى الدَّابَّةِ فَلاَ يَرْكَبْهَا وَلاَ يَقْبَلْهُ إِلاَّ أَنْ يَكُونَ جَرَى بَيْنَهُ وَبَيْنَهُ قَبْلَ ذَلِكَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «سنن ابی داود/البیوع ۳۹ (۳۴۲۲)، سنن الترمذی/البیوع ۴۷ (۱۲۷۶،۱۲۷۷)،(تحفة الأشراف:۱۱۲۳۸)، وقد أخرجہ: موطا امام مالک/الإستئذان ۱۰ (۲۸)، مسند احمد (۵/۴۳۵،۴۳۶),,It was narrated that Yahya bin Abu Ishaq Al-Huna'i said:,The Chapters on Charity
2167,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَفَّانُ، حَدَّثَنَا حَمَّادُ بْنُ سَلَمَةَ، أَخْبَرَنِي عَبْدُ الْمَلِكِ أَبُو جَعْفَرٍ، عَنْ أَبِي نَضْرَةَ، عَنْ سَعْدِ بْنِ الأَطْوَلِ، أَنَّ أَخَاهُ، مَاتَ وَتَرَكَ ثَلاَثَمِائَةِ دِرْهَمٍ وَتَرَكَ عِيَالاً فَأَرَدْتُ أَنْ أُنْفِقَهَا عَلَى عِيَالِهِ فَقَالَ النَّبِيُّ صلى الله عليه وسلم ‏""‏ إِنَّ أَخَاكَ مُحْتَبَسٌ بِدَيْنِهِ فَاقْضِ عَنْهُ ‏""‏ ‏.‏ فَقَالَ يَا رَسُولَ اللَّهِ قَدْ أَدَّيْتُ عَنْهُ إِلاَّ دِينَارَيْنِ ادَّعَتْهُمَا امْرَأَةٌ وَلَيْسَ لَهَا بَيِّنَةٌ ‏.‏ قَالَ ‏""‏ فَأَعْطِهَا فَإِنَّهَا مُحِقَّةٌ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: صحیح البخاری/البیوع ۱۱۲ (۲۲۳۶)، المغازي ۵۱ (۴۲۹۶)، سورة الأنعام ۶ (۴۶۳۳)، صحیح مسلم/المساقاة ۱۳ (۱۵۸۱)، سنن ابی داود/البیوع ۶۶ (۳۴۸۶،۳۴۸۷)، سنن الترمذی/البیوع ۶۱ (۱۲۹۷)، سنن النسائی/الفرع والعتیرة ۷ (۴۲۶۱)، البیوع ۹۱ (۴۶۷۳)،(تحفة الأشراف:۲۴۹۴)، وقد أخرجہ: مسند احمد (۳/۳۳۴،۳۷۰),2167,It was narrated from Sa'd bin Atwal that :,The Chapters on Charity
2168,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ الدِّمَشْقِيُّ، حَدَّثَنَا شُعَيْبُ بْنُ إِسْحَاقَ، حَدَّثَنَا هِشَامُ بْنُ عُرْوَةَ، عَنْ وَهْبِ بْنِ كَيْسَانَ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، أَنَّ أَبَاهُ، تُوُفِّيَ وَتَرَكَ عَلَيْهِ ثَلاَثِينَ وَسْقًا لِرَجُلٍ مِنَ الْيَهُودِ فَاسْتَنْظَرَهُ جَابِرُ بْنُ عَبْدِ اللَّهِ فَأَبَى أَنْ يُنْظِرَهُ فَكَلَّمَ جَابِرٌ رَسُولَ اللَّهِ صلى الله عليه وسلم لِيَشْفَعَ لَهُ إِلَيْهِ فَجَاءَهُ رَسُولُ اللَّهِ صلى الله عليه وسلم فَكَلَّمَ الْيَهُودِيَّ لِيَأْخُذَ ثَمَرَ نَخْلِهِ بِالَّذِي لَهُ عَلَيْهِ فَأَبَى عَلَيْهِ فَكَلَّمَهُ رَسُولُ اللَّهِ صلى الله عليه وسلم فَأَبَى أَنْ يُنْظِرَهُ فَدَخَلَ رَسُولُ اللَّهِ صلى الله عليه وسلم النَّخْلَ فَمَشَى فِيهَا ثُمَّ قَالَ لِجَابِرٍ ‏""‏ جُدَّ لَهُ فَأَوْفِهِ الَّذِي لَهُ ‏""‏ ‏.‏ فَجَدَّ لَهُ بَعْدَ مَا رَجَعَ رَسُولُ اللَّهِ صلى الله عليه وسلم ثَلاَثِينَ وَسْقًا وَفَضَلَ لَهُ اثْنَا عَشَرَ وَسْقًا فَجَاءَ جَابِرٌ رَسُولَ اللَّهِ صلى الله عليه وسلم لِيُخْبِرَهُ بِالَّذِي كَانَ فَوَجَدَ رَسُولَ اللَّهِ صلى الله عليه وسلم غَائِبًا فَلَمَّا انْصَرَفَ رَسُولُ اللَّهِ صلى الله عليه وسلم جَاءَهُ فَأَخْبَرَهُ أَنَّهُ قَدْ أَوْفَاهُ وَأَخْبَرَهُ بِالْفَضْلِ الَّذِي فَضَلَ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏""‏ أَخْبِرْ بِذَلِكَ عُمَرَ بْنَ الْخَطَّابِ ‏""‏ ‏.‏ فَذَهَبَ جَابِرٌ إِلَى عُمَرَ فَأَخْبَرَهُ فَقَالَ لَهُ عُمَرُ لَقَدْ عَلِمْتُ حِينَ مَشَى فِيهِ رَسُولُ اللَّهِ صلى الله عليه وسلم لَيُبَارِكَنَّ اللَّهُ فِيهَا ‏.‏",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: سنن الترمذی/البیوع ۱۵ (۱۲۸۲)،(تحفة الأشراف:۴۸۹۸),2168,It was narrated from Jabir bin 'Abdullah that :,The Chapters on Charity
2169,"حَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا رِشْدِينُ بْنُ سَعْدٍ، وَعَبْدُ الرَّحْمَنِ الْمُحَارِبِيُّ، وَأَبُو أُسَامَةَ وَجَعْفَرُ بْنُ عَوْنٍ عَنِ ابْنِ أَنْعُمٍ، قَالَ أَبُو كُرَيْبٍ وَحَدَّثَنَا وَكِيعٌ، عَنْ سُفْيَانَ، عَنِ ابْنِ أَنْعُمٍ، عَنِ عِمْرَانَ بْنِ عَبْدٍ الْمَعَافِرِيِّ، عَنْ عَبْدِ اللَّهِ بْنِ عَمْرٍو، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ إِنَّ الدَّيْنَ يُقْضَى مِنْ صَاحِبِهِ يَوْمَ الْقِيَامَةِ إِذَا مَاتَ إِلاَّ مَنْ يَدَيَّنُ فِي ثَلاَثِ خِلاَلٍ الرَّجُلُ تَضْعُفُ قُوَّتُهُ فِي سَبِيلِ اللَّهِ فَيَسْتَدِينُ يَتَقَوَّى بِهِ لِعَدُوِّ اللَّهِ وَعَدُوِّهِ وَرَجُلٌ يَمُوتُ عِنْدَهُ مُسْلِمٌ لاَ يَجِدُ مَا يُكَفِّنُهُ وَيُوَارِيهِ إِلاَّ بِدَيْنٍ وَرَجُلٌ خَافَ اللَّهَ عَلَى نَفْسِهِ الْعُزْبَةَ فَيَنْكِحُ خَشْيَةً عَلَى دِينِهِ فَإِنَّ اللَّهَ يَقْضِي عَنْ هَؤُلاَءِ يَوْمَ الْقِيَامَةِ ‏""""‏ ‏.‏""",Al-Albani: Sahih Hadith; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: صحیح البخاری/الصلاة ۱۰ (۳۶۸)، المواقیت ۳۰ (۵۸۴)، الصوم ۶۷ (۱۹۹۳)، البیوع ۶۳ (۲۱۴۶)، اللباس ۲۰ (۵۸۱۹)،۲۱ (۵۸۲۱)، صحیح مسلم/البیوع ۱ (۱۵۱۱)، سنن النسائی/البیوع ۲۴ (۴۵۲۱)،(تحفة الأشراف:۱۲۲۶۵)، وقد أخرجہ: سنن الترمذی/البیوع ۶۹ (۱۳۱۰)، موطا امام مالک/البیوع ۳۵ (۷۶)، مسند احمد (۲/۲۷۹،۳۱۹،۴۱۹،۴۶۴),,It was narrated from 'Abdullah bin 'Amr that the Messenger of Allah (ﷺ) said:,The Chapters on Charity
2390,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏حَدَّثَنَا هِشَامُ بْنُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الزکاة ۵۹ (۱۴۹۰)، الھبة ۳۰ (۲۶۲۳)،۳۷ (۲۶۳۶)، الوصایا ۳۱ (۲۷۷۵)، الجہاد ۱۱۹ (۲۹۷۰)،۱۳۷ (۳۰۰۲)، صحیح مسلم/الھبات ۱ (۱۶۲۰)، سنن النسائی/الزکاة ۱۰۰ (۲۶۱۶)،(تحفة الأشراف:۱۰۳۸۵)، وقد أخرجہ: سنن الترمذی/الزکاة ۳۲ (۶۶۸)، موطا امام مالک/الزکاة ۲۶ (۴۹)، مسند احمد (۱/۲۵،۳۷،۴۰،۵۴),2390,,The Chapters on Charity
2391,حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ الدِّمَشْقِيُّ، ‏‏‏‏‏‏حَدَّثَنَا الْوَلِيدُ بْنُ مُس,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «انظر حدیث رقم (۲۳۸۵)،(تحفة الأشراف:۵۶۶۲),2391,,The Chapters on Charity
2392,حَدَّثَنَا تَمِيمُ بْنُ الْمُنْتَصِرِ الْوَاسِطِيُّ، ‏‏‏‏‏‏حَدَّثَنَا إِسْحَاق بْنُ يُوسُفَ، ‏‏‏‏‏‏ع,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۵۴۶),2392,,The Chapters on Charity
2393,حَدَّثَنَا يَحْيَى بْنُ حَكِيمٍ، ‏‏‏‏‏‏حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، ‏‏‏‏‏‏حَدَّثَنَا سُلَيْمَان,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۶۳۲، ومصباح الزجاجة:۸۴۸)، وقد أخرجہ: مسند احمد (۱/۱۶۴),2393,,The Chapters on Charity
2394,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏عَنْ سُفْيَانَ، ‏‏‏‏‏‏عَنْ عَبْدِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: انظر حدیث رقم:(۱۷۵۹)،(تحفة الأشراف:۱۹۸۰),2394,,The Chapters on Charity
2395,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ جَعْفَرٍ الرَّقِّيُّ، ‏‏‏‏‏‏,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۷۴۴، ومصباح الزجاجة:۸۳۹)، وقد أخرجہ: مسند احمد (۲/۱۸۵),2395,,The Chapters on Charity
2396,حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ، ‏‏‏‏‏‏حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَيْمَانَ، ‏‏‏‏‏‏ع,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: صحیح البخاری/الشروط ۱۹ (۲۷۳۷)، الوصایا ۲۲ (۶۷۶۴)،۲۸ (۲۷۷۲)،۳۲ (۲۷۷۷)، صحیح مسلم/الوصایا ۴ (۱۶۳۲)، سنن ابی داود/الوصایا ۱۳ (۲۸۷۸)، سنن الترمذی/الأحکام ۳۶ (۱۳۷۵)، سنن النسائی/الإحباس ۱ (۳۶۲۹)،(تحفة الأشراف:۷۷۴۲)، وقد أخرجہ: مسند احمد (۲/۵۵،۱۲۵),2396,,The Chapters on Charity
2397,حَدَّثَنَا مُحَمَّدُ بْنُ أَبِي عُمَرَ الْعَدَنِيُّ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ، ‏‏‏‏‏‏عَنْ عُبَيْدِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: سنن النسائی/الإحباس ۲ (۳۶۳۳)،(تحفة الأشراف:۷۹۰۲),2397,,The Chapters on Charity
2398,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا إِسْمَاعِيل بْنُ عَيَّاشٍ، ‏‏‏‏‏‏حَدَّثَنَا شُرَح,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۸۸۴، ومصباح الزجاجة:۸۴۰)، وقد أخرجہ: سنن ابی داود/البیوع ۹۰ (۳۵۶۵)، سنن الترمذی/البیوع ۳۴ (۱۲۶۵)،(الشطر الأول فقط),2398,,The Chapters on Charity
2399,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏ وَعَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ، ‏‏‏‏‏‏الدِّمَشْقِيّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۶۲، ومصباح الزجاجة:۸۴۱),2399,,The Chapters on Charity
2400,حَدَّثَنَا إِبْرَاهِيمُ بْنُ الْمُسْتَمِرِّ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ، ‏‏‏‏‏‏ح,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: سنن ابی داود/البیوع ۹۰ (۳۵۶۱)، سنن الترمذی/البیوع ۳۹ (۱۲۶۶)،(تحفة الأشراف:۴۵۸۴)، وقد أخرجہ: مسند احمد (۵/۱۲،۱۳)، سنن الدارمی/البیوع ۵۶ (۲۶۳۸),2400,,The Chapters on Charity
2401,حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ الْجَهْمِ الْأَنْمَاطِيُّ، ‏‏‏‏‏‏حَدَّثَنَا أَيُّوبُ بْنُ سُوَيْدٍ،,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۷۸۰، ومصباح الزجاجة:۸۴۲),2401,,The Chapters on Charity
2402,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏عَنْ,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Sahih Bukhari,takhreej: صحیح البخاری/المناقب ۲۸ (۳۶۴۰،۳۶۴۱،۳۶۴۲)، سنن ابی داود/البیوع ۲۸ (۳۳۸۴،۳۳۸۵)، سنن الترمذی/البیوع ۳۴ (۱۲۵۸)،(تحفة الأشراف:۹۸۹۸)، وقد أخرجہ: مسند احمد (۴/۳۷۵،۳۷۶),2402,,The Chapters on Charity
2403,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏عَنْ أَبِي الزِّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: سنن النسائی/البیوع ۹۹ (۴۶۹۵)،۱۰۱ (۴۷۰۵)،(تحفة الأشراف:۱۳۶۹۳)، وقد أخرجہ: صحیح البخاری/الحوالہ ۱ (۲۲۸۸)،۲ (۲۲۸۹)، الإستقراض ۱۲ (۲۴۰۰)، صحیح مسلم/المساقاة ۷ (۱۵۶۴)، سنن ابی داود/البیوع ۱۰ (۳۳۴۵)، سنن الترمذی/البیوع ۶۸ (۱۳۰۸)، موطا امام مالک/البیوع ۴۰ (۸۴)، مسند احمد (۲/۲۴۵،۲۵۴،۲۶۰،۳۱۵،۳۷۷،۳۸۰،۴۶۳،۴۶۴،۴۶۵)، سنن الدارمی/البیوع ۴۸ (۲۶۲۸),2403,,The Chapters on Charity
2404,حَدَّثَنَا إِسْمَاعِيل بْنُ تَوْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا هُشَيْمٌ، ‏‏‏‏‏‏عَنْ يُونُسَ بْنِ عُبَيْدٍ، ‏,Al-Albani: Sahih Hadith; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۵۳۵، ومصباح الزجاجة:۸۴۳)، وقد أخرجہ: مسند احمد (۲/۷۱),2404,,The Chapters on Charity
2405,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏ وَالْحَسَنُ بْنُ عَرَفَةَ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَا إِس,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Hasan,takhreej: سنن ابی داود/البیوع ۹۰ (۳۵۶۵)، سنن الترمذی/البیوع ۳۹ (۱۲۶۵)،(تحفة الأشراف:۴۸۸۴),2405,,The Chapters on Charity
2406,حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ الدَّارَوَر,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: سنن ابی داود/البیوع ۲ (۳۳۲۸)،(تحفة الأشراف:۶۱۷۸),2406,,The Chapters on Charity
2407,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو عَامِرٍ، ‏‏‏‏‏‏حَدَّثَنَا شُعْبَةُ، ‏‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: سنن الترمذی/الجنائز ۶۹ (۱۰۶۹)، سنن النسائی/الجنائز ۶۷ (۱۹۶۲)، البیوع ۱۰۰ (۴۶۹۶)،(تحفة الأشراف:۱۲۱۰۳)، وقد أخرجہ: مسند احمد (۵/۳۰۲،۳۱۱)، سنن الدارمی/البیوع ۵۳ (۲۶۳۵),2407,,The Chapters on Charity
