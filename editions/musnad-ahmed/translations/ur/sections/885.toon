hadiths[2]{hadithnumber,text}:
22834,"أذعشحأتثًؼثزتهشذوىألۄشۏأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأوۏڽأؽصًۄأذىۏىأوۏڽأىثۏأ﷽أڬەأۄوشتۄأحہتأ؏أۄوأطزۏزأڲشوۏأڬەأتۏڬأڲشوأحشۏىأزىأوۏڽأشًتىۄأۄًةەأ؏أشتضحەأوۏڽأتۏڬأدڲۄأضتۏۄأزتشأزشرحًڽأڬەأىۏډەأځڔتاأڬۏتأ؏أدثأضًشدأڋہهأڲۏتأحًأوۏڽأىەأتځىتأتضهذۄأصۏثأحىأڬۏتأ؏أتځىەأڲہًڔەأځشأضًتشأۄًتأتًشأىثۏأ﷽أڬۏأرزوحأوۏڽأذتعشأۄًأڲۏتأ؏أتضأًمحأىثۏأ﷽أتځىەأرۏوەأوۏڽأحہەأ؏أوۏڽأىەأ““أ®تهضهتوأؼهۏڬأۏتأشضًهأتههۄأًشذوۆأتههۄ¾أ‛‛أڬۄۄأڬشأځًډہتأڬۄأڬًډأڬتأًمحأۄًأڲۏتأۄەأآأىثۏأ﷽أىەألشوتۏتأۄتڽأ$أځہشأذعشحأثهتهأشعۏأتههۄأؼىۄأڬًأإًتصأزۏأ؏أًۄأثثًهأڬەأىۏډەأضەأتضأغشذأڬًزەأدۏضەأڬضۏأځشىزەأڬتأضتۏۄأۄًأتًشأؼشعأڬۏتأ®هثۏنأًضؼزۏن¾أ؏أوۏڽأإځأځشأمشثتىأ؏أىثۏأ﷽أىەألشوتۏتأوۏشەأڲہًڔەأځشأصۏىأڬضأزًأ؏أډىتىډۄأتىۄًڽأىەأتۏڬأصۏىأىڬتهۏأدضأڬەأزًىًڽأڬىتشەأڬہدًشأڬۏأډہتهأضەأثہشەأۄًةەأحہەأتًشأدضأوۏڽأڬًةۏأؽشًشأًأحڬثشأىۄأحہتأتًشأتضەأڬضأزۏتأۗ
أځہشأىثۏأ﷽أضًتشأۄًةەأتًشأۄوأثہۏأضًتشأۄًأڲةەأ؏أوۏزتىأدىڲأوۏڽأؼطتؤأڬەأًمحأضەأضتشۏأشتحأۄوأهًڲأظلأثىزۏأڬشحەأشۄەأ؏أدثأزًىًڽأدوتؼحًڽأڬەأڲہًڔەأتۏڬأزًضشەأوۏڽأڲہضەأحًأوضهوتىأځۏټہأځہۏشأڬشأثہتڲأتټہەأدۏضتأڬۄأتههۄأحؼتهۏٳأىەألشوتۏتأۄەأ؏أځہشأىثۏأ﷽أىەألشوتۏتأتەأتههۄأڬەأثىزًأ$أوۏڽأرزتأڬتأثىزۄأتًشأشضًهأ+أحًأۏۄتڽأوًدًزأ,أۄًڽأ؏أځہشألشوتۏتأتەأڲشًۄأوۄتدشۏىأ$أوۏڽأرزتأڬتأثىزۄأتًشأشضًهأ+أحًأۏۄتڽأوًدًزأ,أۄًڽأ؏أتضأڬەأثؼزأىثۏأ﷽أتځىەأڲہًڔەأضەأڬًزەأتًشأوټہۏأثہشأوټۏأتټہتةۏأتًشأىثۏأ﷽أڬەأضثأضەأمشۏثۏأإزوۏأڬۏأتغهتؼأڬەأوغتثمأىثۏأ﷽أىەأًۄأوټۏأزطوىأڬەأډۄشًڽأځشأځہۏىڬأزۏأتًشألشوتۏتأۏۄأډۄشەأثڲڔأدتةۏڽأ؏أډىتىډۄأتههۄأىەأوطشڬۏىأڬًأطڬضحأضەأزًډتشأڬشأزۏتأۗ أوطشڬۏىأرًزأتځىەأثۏټًڽأضەأڬۄحەأۄۏڽأڬۄأۄوأوۏڽأضەأتۏڬأثہۏأإزوۏأتۏضتأىۄأثډتأدضأڬۏأإىڬہۏڽأتًشأوىۄأوټۏأضەأىۄأثہشأڲۏتأۄًأ؏أتًشأۄوأىەأصوۏىأًأإضوتىأڬەأزشوۏتىأتۏضۏأإًتصأضىۏأدۏضەأهًۄەأڬًأهًۄەأڬۏأځهۏټأځشأڲصتشىەأضەأځۏزتأۄًحۏأۄەأۗ"
22835,أڲسطحۄأذزۏخأتضأزًضشۏأضىزأضەأثہۏأوشًۏأۄەأۗأ
