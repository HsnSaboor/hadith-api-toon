9991,"أذعشحأطؼثۏأشذوۆأتههۄأؼهۏۄألشوتحەأۄۏڽأڬۄأذعًشأتمزضأ﷽أىەأۏوىأ+أڬەأمتعۏأڬًأ,أهڬہتأ=أځتىډأتًىټًڽأځشأتۏڬأثڬشۏأصڬًۆأۄەأ؏أتًشأزضأتًىټًڽأځشأزًأثڬشۏتڽأ؏أتًشأځىزشۄأتًىټًڽأځۄأحۏىأثڬشۏتڽأتًشأثۏضأتًىټًڽأځۄأډتشأتًشأځډۏضأتًىټًڽأځۄأځتىډأثڬشۏتڽأتًشأځډۏضأضەأتۏڬأتًىټأصتةزأۄًأدتةەأحًأتضأځشأثىحأورتعأۄەأځۏىحۏضأتًىټًڽأحڬأ؏أتًشأتڲشأصڬًۆأوۏڽأزۏىەأڬۏهةەأثىحأورتعأىۄأځتةەأحًأوسڬشأتثىأهثًىأزۏزەأۗأتًشأدثأځۏىحۏضأضەأتۏڬأتًىټأصتةزأۄًأدتةەأحًأځۏىحتهۏضأحڬأتۏڬأثىحأهثًىأۄەأ؏أدثأځۏىحتهۏضأضەأتۏڬأتًىټأصتةزأۄًأدتةەأحًأضتټہأحڬأتۏڬأذمۄأۄەأ؏أدثأضتټہأتًىټًڽأضەأتۏڬأتًىټأصتةزأۄًأدتةەأحًأځډہحشأتًىټًڽأحڬأتۏڬأدسؼۄأۄەأتًشأدثأځډہحشأضەأتۏڬأصتةزأۄًأدتةەأحًأتضأځشأزًأثىحأهثًىأۄۏڽأۗأىًەأحڬأتضۏأغشذأۄەأ؏أدثأىًەأضەأتۏڬأتًىټأصتةزأۄًأدتةەأحًأتۏڬأضًأثۏضأحڬأزًأذمەأۄۏڽأ؏أځہشأدثأتًىټأتۏڬأضەأثۏضأضەأثہۏأصتةزأۄًأدتةۏڽأحًأۄشأځډتضأځشأتۏڬأذمۄأتًشأۄشأډتهۏضأځشأتۏڬأثىحأهثًىأإةەأڲتأ؏أتًشأوحلشمأڬًأدوؼأتًشأدوؼأڬًأوحلشمأىۄۏڽأڬۏتأدتةەأڲتأتًشأصڬًۆأًظًهأڬشحەأًمحأثۄحأډہًټتأۏتأثۄحأثًڔہتأدتىًشأًظًهأىۄۏڽأڬۏتأدتةەأڲتأ+أثهڬۄأزشوۏتىۄأًظًهأڬۏتأدتةەأڲتأ,أتًشأىۄأڬتىتأتًشأثۄحأڬوصًشأدتىًشأًظًهأڬۏتأدتةەأڲتأۗأتدهذأشتًۏألشوتحەأۄۏڽأڬۄأوۏڽأىەأتوتوأطؼثۏأشذوۆأتههۄأؼهۏۄأضەأځًډہتأڬۄأ®هتّأۏْدٕوّؼْأثّۏٕىّأوْلٕحّشٓمِ¾أ؏أ®ًّهتّأۏْلّشّٔمْأثّۏٕىّأوْدٕحّوٓؼِ¾أڬتأڬۏتأوغهثأۄەأآأإځأشذوۆأتههۄأؼهۏۄأىەأتشطتزألشوتۏتأڬۄأتۏڬأإزوۏأڬەأځتضأډًځتةەأۄًڽأحًأًۄأتضأىۏحأضەأتىأڬًأوحلشمأىۄأڬشەأحتڬۄأوحلشمأ+أدثأىظتثأصڬًۆأىۄأځۄىډەأحًأتضأځشأ,أځشأصڬًۆأىۄأإةەأتًشأىۄأۄۏأوحلشمأڬًأدوؼأڬشەأۏؼىۏأڬضۏأمًوأڬەأځتضأډًځتةەأحًأۄًڽأهۏڬىأتىأځۄأصڬًۆأىۄأإأشۄۏأۄًأحًأوظزمأ+أصڬًۆأًظًهأڬشىەأًتهتأ,أتىأضثأڬًأتۏڬأضتحہأدوؼأڬشأڬەأصڬًۆأًظًهأىۄأڬشەأۗ"
9992,"أذعشحأؼهۏأتشطتزألشوتحەأۄۏڽأڬۄأدثأحوۄتشەأځتضأډتشأسًزأتًىټًڽأڬەأؼهتًۄأڬډہأىۄأۄًأ+أًۄأتًىټأدىأڬۏأؼوشأحۏىأضەأهۏڬشأزضأحڬأۄًأ,أحًأتىأځشأصڬًۆأىۄۏڽأۄەأۗ"
