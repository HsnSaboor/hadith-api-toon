metadata:
  section_id: 21
  section_name: Chapter 21
  hadith_first: 126
  hadith_last: 130

hadiths[5]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
126,"""I saw Allah’s Messenger (Allah bless him and give him peace) leaning on a cushion on his left side.”",,,48841,"Jabir ibn Samura said:",Chapter 21
127,"“Allah’s Messenger said (Allah bless him and give him peace): ‘Should I tell you about the greatest of the major sins?’ They said: ‘Yes indeed, O Messenger of Allah!’ He said: ‘Associating partners with Allah, and recalcitrance against parents.’ Allah’s Messenger (Allah bless him and give him peace) sat down, and he was leaning on a support. He added: '...and false testimony’ or: ‘false speech.’ Allah’s Messenger (Allah bless him and give him peace) went on speaking until we said: ‘If only he would keep silent!”",,,48842,"'Abd ar-Rahman ibn Abi Bakra reported that his father Abu Bakra said:",Chapter 21
128,"""Allah’s Messenger said (Allah bless him and give him peace):‘As for me, I do not eat while leaning on a support!’”",,,48843,"Abu Juhaifa said:",Chapter 21
129,"""Allah’s Messenger said (Allah bless him and give him peace): 'I do not eat while leaning on a support! I do not eat while leaning on a support'!”",,,48844,"Abu Juhaifa said:",Chapter 21
130,"""I saw Allah’s Messenger (Allah bless him and give him peace) leaning on a cushion.”",,,48845,"Jabir ibn Samura said:",Chapter 21
