{"hadithnumber": "1", "arabic": "وَاعْلَمْ- وَفَّقَكَ اللَّهُ تَعَالَى- أَنَّ الْوَاجِبَ عَلَى كُلِّ أَحَدٍ عَرَفَ التَّمْيِيزَ بَيْن", "grades": "", "reference": "Book 0, Hadith 1", "international_number": "1", "narrator_chain": ""}
{"hadithnumber": "2", "arabic": "وحَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، حَدَّثَنَا  غُنْدَرٌ ، عَنْ  شُعْبَةَ . ح وَحَدَّثَن", "grades": "", "reference": "Book 0, Hadith 2", "international_number": "2", "narrator_chain": ""}
{"hadithnumber": "3", "arabic": "وحَدَّثَنِي  زُهَيْرُ بْنُ حَرْبٍ ، حَدَّثَنَا  إِسْمَاعِيل يَعْنِي ابْنَ عُلَيَّةَ ، عَنْ  عَبْدِ ا", "grades": "", "reference": "Book 0, Hadith 3", "international_number": "3", "narrator_chain": ""}
{"hadithnumber": "4", "arabic": "وحَدَّثَنَا  مُحَمَّدُ بْنُ عُبَيْدٍ الْغُبَرِيُّ ، حَدَّثَنَا  أَبُو عَوَانَةَ ، عَنْ  أَبِي حَصِين", "grades": "", "reference": "Book 0, Hadith 4", "international_number": "4", "narrator_chain": ""}
{"hadithnumber": "5", "arabic": "وحَدَّثَنَا  مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ ، حَدَّثَنَا  أَبِي ، حَدَّثَنَا  سَعِيدُ ب", "grades": "", "reference": "Book 0, Hadith 5", "international_number": "5", "narrator_chain": ""}
{"hadithnumber": "6", "arabic": "وحَدَّثَنِي  عَلِيُّ بْنُ حُجْرٍ السَّعْدِيُّ ، حَدَّثَنَا  عَلِيُّ بْنُ مُسْهِرٍ ، أَخْبَرَنَا  مُح", "grades": "", "reference": "Book 0, Hadith 6", "international_number": "6", "narrator_chain": ""}
{"hadithnumber": "7", "arabic": "وحَدَّثَنَا  عُبَيْدُ اللَّهِ بْنُ مُعَاذٍ الْعَنْبَرِيُّ ، حَدَّثَنَا  أَبِي . ح وحَدَّثَنَا  مُحَم", "grades": "", "reference": "Book 0, Hadith 7", "international_number": "7", "narrator_chain": ""}
{"hadithnumber": "8", "arabic": "وحَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، حَدَّثَنَا  عَلِيُّ بْنُ حَفْصٍ ، حَدَّثَنَا  شُعْبَ", "grades": "", "reference": "Book 0, Hadith 8", "international_number": "8", "narrator_chain": ""}
{"hadithnumber": "9", "arabic": "وحَدَّثَنَا وحَدَّثَنَا  يَحْيَى بْنُ يَحْيَى ، أَخْبَرَنَا  هُشَيْمٌ ، عَنْ  سُلَيْمَانَ التَّيْمِي", "grades": "", "reference": "Book 0, Hadith 9", "international_number": "9", "narrator_chain": ""}
{"hadithnumber": "10", "arabic": "وحَدَّثَنِي أَبُو الطَّاهِرِ أَحْمَدُ بْنُ عَمْرِو بْنِ عَبْدِ اللَّهِ بْنِ عَمْرِو بْنِ سَرْحٍ، قَا", "grades": "", "reference": "Book 0, Hadith 10", "international_number": "10", "narrator_chain": ""}
{"hadithnumber": "11", "arabic": "حَدَّثَنَا حَدَّثَنَا  وَمُحَمَّدُ بْنُ الْمُثَنَّى ، قَالَ: حَدَّثَنَا  عَبْدُ الرَّحْمَنِ ، قَالَ:", "grades": "", "reference": "Book 0, Hadith 11", "international_number": "11", "narrator_chain": ""}
{"hadithnumber": "12", "arabic": "وحَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، قَالَ: سَمِعْتُ عَبْدَ الرَّحْمَنِ بْنَ مَهْدِيٍّ، يَقُولُ:", "grades": "", "reference": "Book 0, Hadith 12", "international_number": "12", "narrator_chain": ""}
{"hadithnumber": "13", "arabic": "وحَدَّثَنَا يَحْيَى بْنُ يَحْيَى، أَخْبَرَنَا عُمَرُ بْنُ عَلِيِّ بْنِ مُقَدَّمٍ، عَنْ سُفْيَانَ بْن", "grades": "", "reference": "Book 0, Hadith 13", "international_number": "13", "narrator_chain": ""}
{"hadithnumber": "14", "arabic": "وحَدَّثَنِي  أَبُو طَاهِرٍ ،  وَحَرْمَلَةُ بْنُ يَحْيَى ، قَالَا: أَخْبَرَنَا  ابْنُ وَهْبٍ ، قَالَ:", "grades": "", "reference": "Book 0, Hadith 14", "international_number": "14", "narrator_chain": ""}
{"hadithnumber": "15", "arabic": "وحَدَّثَنِي  مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ  وَزُهَيْرُ بْنُ حَرْبٍ ، قَالَا: حَدَّثَنَ", "grades": "", "reference": "Book 0, Hadith 15", "international_number": "15", "narrator_chain": ""}
{"hadithnumber": "16", "arabic": "وحَدَّثَنِي  حَرْمَلَةُ بْنُ يَحْيَى بْنِ عَبْدِ اللَّهِ بْنِ حَرْمَلَةَ بْنِ عِمْرَانَ التُّجِيبِيّ", "grades": "", "reference": "Book 0, Hadith 16", "international_number": "16", "narrator_chain": ""}
{"hadithnumber": "17", "arabic": "وحَدَّثَنِي أَبُو سَعِيدٍ الأَشَجُّ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا الأَعْمَشُ، عَنِ الْمُسَيَّبِ بْ", "grades": "", "reference": "Book 0, Hadith 17", "international_number": "17", "narrator_chain": ""}
{"hadithnumber": "18", "arabic": "وحَدَّثَنِي مُحَمَّدُ بْنُ رَافِعٍ، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَخْبَرَنَا مَعْمَرٌ، عَنْ ابْنِ", "grades": "", "reference": "Book 0, Hadith 18", "international_number": "18", "narrator_chain": ""}
{"hadithnumber": "19", "arabic": "وحَدَّثَنِي مُحَمَّدُ بْنُ عَبَّادٍ وَسَعِيدُ بْنُ عَمْرٍو الأَشْعَثِيُّ جَمِيعًا، عَنِ ابْنِ عُيَيْ", "grades": "", "reference": "Book 0, Hadith 19", "international_number": "19", "narrator_chain": ""}
{"hadithnumber": "20", "arabic": "وحَدَّثَنِي مُحَمَّدُ بْنُ رَافِعٍ، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَخْبَرَنَا مَعْمَرٌ، عَنِ ابْنِ", "grades": "", "reference": "Book 0, Hadith 20", "international_number": "20", "narrator_chain": ""}
{"hadithnumber": "21", "arabic": "وحَدَّثَنِي أَبُو أَيُّوبَ سُلَيْمَانُ بْنُ عُبَيْدِ اللَّهِ الْغَيْلَانِيُّ، حَدَّثَنَا أَبُو عَامِ", "grades": "", "reference": "Book 0, Hadith 21", "international_number": "21", "narrator_chain": ""}
{"hadithnumber": "22", "arabic": "حَدَّثَنَا دَاوُدُ بْنُ عَمْرٍو الضَّبِّيُّ، حَدَّثَنَا نَافِعُ بْنُ عُمَرَ، عَنِ ابْنِ أَبِى مُلَيْ", "grades": "", "reference": "Book 0, Hadith 22", "international_number": "22", "narrator_chain": ""}
{"hadithnumber": "23", "arabic": "حَدَّثَنَا عَمْرٌو النَّاقِدُ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ هِشَامِ بْنِ حُجَيْرٍ، عَن", "grades": "", "reference": "Book 0, Hadith 23", "international_number": "23", "narrator_chain": ""}
{"hadithnumber": "24", "arabic": "حَدَّثَنَا حَسَنُ بْنُ عَلِيٍّ الْحُلْوَانِيُّ، حَدَّثَنَا يَحْيَي بْنُ آدَمَ، حَدَّثَنَا ابْنُ إِدْ", "grades": "", "reference": "Book 0, Hadith 24", "international_number": "24", "narrator_chain": ""}
{"hadithnumber": "25", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ خَشْرَمٍ، أَخْبَرَنَا أَبُو بَكْرٍ يَعْنِى ابْنَ عَيَّاشٍ، قَالَ: سَمِعْتُ ا", "grades": "", "reference": "Book 0, Hadith 25", "international_number": "25", "narrator_chain": ""}
{"hadithnumber": "26", "arabic": "حَدَّثَنَا حَسَنُ بْنُ الرَّبِيعِ، حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ، عَنْ أَيُّوبَ وَهِشَامٍ، عَنْ مُ", "grades": "", "reference": "Book 0, Hadith 26", "international_number": "26", "narrator_chain": ""}
{"hadithnumber": "27", "arabic": "حَدَّثَنَا أَبُو جَعْفَرٍ مُحَمَّدُ بْنُ الصَّبَّاحِ، حَدَّثَنَا إِسْمَاعِيل بْنُ زَكَرِيَّاءَ، عَنْ", "grades": "", "reference": "Book 0, Hadith 27", "international_number": "27", "narrator_chain": ""}
{"hadithnumber": "28", "arabic": "حَدَّثَنَا إِسْحَاق بْنُ إِبْرَاهِيمَ الْحَنْظَلِيُّ، أَخْبَرَنَا عِيسَى وَهُوَ ابْنُ يُونُسَ، حَدَّ", "grades": "", "reference": "Book 0, Hadith 28", "international_number": "28", "narrator_chain": ""}
{"hadithnumber": "29", "arabic": "وحَدَّثَنَا عَبْدُ اللَّهِ بْنُ عَبْدِ الرَّحْمَنِ الدَّارِمِيُّ، أَخْبَرَنَا مَرْوَانُ يَعْنِى ابْن", "grades": "", "reference": "Book 0, Hadith 29", "international_number": "29", "narrator_chain": ""}
{"hadithnumber": "30", "arabic": "حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ، حَدَّثَنَا الأَصْمَعِيُّ، عَنِ ابْنِ أَبِي الزِّنَادِ", "grades": "", "reference": "Book 0, Hadith 30", "international_number": "30", "narrator_chain": ""}
{"hadithnumber": "31", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ أَبِي عُمَرَ الْمَكِّيُّ، حَدَّثَنَا سُفْيَانُ.ح وحَدَّثَنِي أَبُو بَكْرِ", "grades": "", "reference": "Book 0, Hadith 31", "international_number": "31", "narrator_chain": ""}
{"hadithnumber": "32", "arabic": "وحَدَّثَنِي مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ قُهْزَاذ َ مِنْ أَهْلِ مَرْوَ، قَالَ: سَمِعْتُ عَبْدَ", "grades": "", "reference": "Book 0, Hadith 32", "international_number": "32", "narrator_chain": ""}
{"hadithnumber": "33", "arabic": "وحَدَّثَنِي أَبُو بَكْرِ بْنُ النَّضْرِ بْنِ أَبِي النَّضْرِ، قَالَ: حَدَّثَنِي أَبُو النَّضْرِ هَاش", "grades": "", "reference": "Book 0, Hadith 33", "international_number": "33", "narrator_chain": ""}
{"hadithnumber": "34", "arabic": "وحَدَّثَنِي بِشْرُ بْنُ الْحَكَمِ الْعَبْدِيُّ، قَالَ: سَمِعْتُ سُفْيَانَ بْنَ عُيَيْنَةَ، يَقُولُ:", "grades": "", "reference": "Book 0, Hadith 34", "international_number": "34", "narrator_chain": ""}
{"hadithnumber": "35", "arabic": "وحَدَّثَنَا عَمْرُو بْنُ عَلِيٍّ أَبُو حَفْصٍ، قَالَ: سَمِعْتُ يَحْيَى بْنَ سَعِيدٍ، قَالَ: سَأَلْتُ", "grades": "", "reference": "Book 0, Hadith 35", "international_number": "35", "narrator_chain": ""}
{"hadithnumber": "36", "arabic": "وحَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ سَعِيدٍ، قَالَ: سَمِعْتُ النَّضْرَ، يَقُولُ: سُئِلَ ابْنُ عَوْنٍ،", "grades": "", "reference": "Book 0, Hadith 36", "international_number": "36", "narrator_chain": ""}
{"hadithnumber": "37", "arabic": "وحَدَّثَنِي حَجَّاجُ بْنُ الشَّاعِر، حَدَّثَنَا شَبَابَةُ، قَالَ: قَال شُعْبَةُ: وَقَدْ لَقِيتُ شَهْ", "grades": "", "reference": "Book 0, Hadith 37", "international_number": "37", "narrator_chain": ""}
{"hadithnumber": "38", "arabic": "وحَدَّثَنِي مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ قُهْزَاذَ مِنْ أَهْلِ مَرْوَ، قَالَ: أَخْبَرَنِي عَلِ", "grades": "", "reference": "Book 0, Hadith 38", "international_number": "38", "narrator_chain": ""}
{"hadithnumber": "39", "arabic": "وحَدَّثَنِي الْفَضْلُ بْنُ سَهْلٍ، قَالَ: سَأَلْتُ مُعَلًّى الرَّازِيَّ، عَنْ مُحَمَّدِ بْنِ سَعِيدٍ", "grades": "", "reference": "Book 0, Hadith 39", "international_number": "39", "narrator_chain": ""}
{"hadithnumber": "40", "arabic": "وحَدَّثَنِي مُحَمَّدُ بْنُ أَبِي عَتَّابٍ، قَالَ: حَدَّثَنِي عَفَّانُ، عَنْ مُحَمَّدِ بْنِ يَحْيَى ب", "grades": "", "reference": "Book 0, Hadith 40", "international_number": "40", "narrator_chain": ""}
{"hadithnumber": "41", "arabic": "حَدَّثَنِي الْفَضْلُ بْنُ سَهْلٍ، قَالَ: حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، قَالَ: أَخْبَرَنِي خَلِيف", "grades": "", "reference": "Book 0, Hadith 41", "international_number": "41", "narrator_chain": ""}
{"hadithnumber": "42", "arabic": "حَدَّثَنِي مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ قُهْزَاذَ، قَالَ: سَمِعْتُ عَبْدَ اللَّهِ بْنَ عُثْمَا", "grades": "", "reference": "Book 0, Hadith 42", "international_number": "42", "narrator_chain": ""}
{"hadithnumber": "43", "arabic": "حَدَّثَنِي ابْنُ قُهْزَاذَ، قَالَ: سَمِعْتُ وَهْبًا، يَقُولُ: عَنِ سُفْيَانَ، عَنِ ابْنِ الْمُبَارَك", "grades": "", "reference": "Book 0, Hadith 43", "international_number": "43", "narrator_chain": ""}
{"hadithnumber": "44", "arabic": "حَدَّثَنَا قُتَيْبَةُ بْنُ سَعِيدٍ، حَدَّثَنَا جَرِيرٌ، عَنْ مُغِيرَةَ، عَنِ الشَّعْبِيِّ، قَالَ: حَ", "grades": "", "reference": "Book 0, Hadith 44", "international_number": "44", "narrator_chain": ""}
{"hadithnumber": "45", "arabic": "حَدَّثَنَا أَبُو عَامِرٍ عَبْدُ اللَّهِ بْنُ بَرَّادٍ الأَشْعَرِيُّ، حَدَّثَنَا أَبُو أُسَامَةَ، عَن", "grades": "", "reference": "Book 0, Hadith 45", "international_number": "45", "narrator_chain": ""}
{"hadithnumber": "46", "arabic": "حَدَّثَنَا قُتَيْبَةُ بْنُ سَعِيدٍ، حَدَّثَنَا جَرِيرٌ، عَنْ مُغِيرَةَ، عَنْ إِبْرَاهِيمَ، قَالَ: قَ", "grades": "", "reference": "Book 0, Hadith 46", "international_number": "46", "narrator_chain": ""}
{"hadithnumber": "47", "arabic": "وحَدَّثَنِي حَجَّاجُ بْنُ الشَّاعِرِ، حَدَّثَنَا أَحْمَدُ يَعْنِي ابْنَ يُونُسَ، حَدَّثَنَا زَائِدَة", "grades": "", "reference": "Book 0, Hadith 47", "international_number": "47", "narrator_chain": ""}
{"hadithnumber": "48", "arabic": "وحَدَّثَنِي حَجَّاجٌ، قَالَ: حَدَّثَنِي أَحْمَدُ وَهُوَ ابْنُ يُونُسَ، حَدَّثَنَا زَائِدَةُ، عَنْ مَ", "grades": "", "reference": "Book 0, Hadith 48", "international_number": "48", "narrator_chain": ""}
{"hadithnumber": "49", "arabic": "وحَدَّثَنَا قُتَيْبَةُ بْنُ سَعِيدٍ، حَدَّثَنَا جَرِيرٌ، عَنْ حَمْزَةَ الزَّيَّاتِ، قَالَ: سَمِعَ مُ", "grades": "", "reference": "Book 0, Hadith 49", "international_number": "49", "narrator_chain": ""}
{"hadithnumber": "50", "arabic": "وحَدَّثَنِي عُبَيْدُ اللَّهِ بْنُ سَعِيد، حَدَّثَنَا عَبْدُ الرَّحْمَنِ يَعْنِي ابْنَ مَهْدِيٍّ، حَد", "grades": "", "reference": "Book 0, Hadith 50", "international_number": "50", "narrator_chain": ""}
{"hadithnumber": "51", "arabic": "حَدَّثَنَا أَبُو كَامِلٍ الْجَحْدَرِيُّ، حَدَّثَنَا حَمَّادٌ وَهُوَ ابْنُ زَيْدٍ، قَالَ: حَدَّثَنَا", "grades": "", "reference": "Book 0, Hadith 51", "international_number": "51", "narrator_chain": ""}
{"hadithnumber": "52", "arabic": "حَدَّثَنَا أَبُو غَسَّانَ مُحَمَّدُ بْنُ عَمْرٍو الرَّازِيُّ، قَالَ: سَمِعْتُ جَرِيرًا، يَقُولُ:\" لَ", "grades": "", "reference": "Book 0, Hadith 52", "international_number": "52", "narrator_chain": ""}
{"hadithnumber": "53", "arabic": "حَدَّثَنَا الْحَسَنُ الْحُلْوَانِيُّ، حَدَّثَنَا يَحْيَي بْنُ آدَمَ، حَدَّثَنَا مِسْعَرٌ، قَالَ: حَد", "grades": "", "reference": "Book 0, Hadith 53", "international_number": "53", "narrator_chain": ""}
{"hadithnumber": "54", "arabic": "وحَدَّثَنِي سَلَمَةُ بْنُ شَبِيبٍ، حَدَّثَنَا الْحُمَيْدِيُّ، حَدَّثَنَا سُفْيَانُ، قَالَ: كَانَ الن", "grades": "", "reference": "Book 0, Hadith 54", "international_number": "54", "narrator_chain": ""}
{"hadithnumber": "55", "arabic": "وحَدَّثَنَا حَسَنٌ الْحُلْوَانِيُّ، حَدَّثَنَا أَبُو يَحْيَى الْحِمَّانِيُّ، حَدَّثَنَا قَبِيصَةُ، و", "grades": "", "reference": "Book 0, Hadith 55", "international_number": "55", "narrator_chain": ""}
{"hadithnumber": "56", "arabic": "وحَدَّثَنِي حَجَّاجُ بْنُ الشَّاعِرِ، حَدَّثَنَا أَحْمَدُ بْنُ يُونُسَ، قَالَ: سَمِعْتُ زُهَيْرًا، ي", "grades": "", "reference": "Book 0, Hadith 56", "international_number": "56", "narrator_chain": ""}
{"hadithnumber": "57", "arabic": "وحَدَّثَنِي إِبْرَاهِيمُ بْنُ خَالِدٍ الْيَشْكُرِيُّ، قَالَ: سَمِعْتُ أَبَا الْوَلِيدِ، يَقُولُ: سَم", "grades": "", "reference": "Book 0, Hadith 57", "international_number": "57", "narrator_chain": ""}
{"hadithnumber": "58", "arabic": "وحَدَّثَنِي سَلَمَةُ بْنُ شَبِيبٍ، حَدَّثَنَا الْحُمَيْدِيُّ، حَدَّثَنَا سُفْيَانُ، قَالَ: سَمِعْتُ", "grades": "", "reference": "Book 0, Hadith 58", "international_number": "58", "narrator_chain": ""}
{"hadithnumber": "59", "arabic": "وحَدَّثَنِي سَلَمَةُ، حَدَّثَنَا الْحُمَيْدِيُّ، حَدَّثَنَا سُفْيَانُ، قَالَ: سَمِعْتُ جَابِرًا، يُح", "grades": "", "reference": "Book 0, Hadith 59", "international_number": "59", "narrator_chain": ""}
{"hadithnumber": "60", "arabic": "حَدَّثَنِي أَحْمَدُ بْنُ إِبْرَاهِيمَ الدَّوْرَقِيُّ، قَالَ: حَدَّثَنِي عَبْدُ الرَّحْمَنِ بْنُ مَهْ", "grades": "", "reference": "Book 0, Hadith 60", "international_number": "60", "narrator_chain": ""}
{"hadithnumber": "61", "arabic": "حَدَّثَنِي حَجَّاجُ بْنُ الشَّاعِرِ، حَدَّثَنَا سُلَيْمَانُ بْنُ حَرْبٍ، حَدَّثَنَا حَمَّادُ بْنُ زَ", "grades": "", "reference": "Book 0, Hadith 61", "international_number": "61", "narrator_chain": ""}
{"hadithnumber": "62", "arabic": "وحَدَّثَنِي مُحَمَّدُ بْنُ رَافِعٍ وَحَجَّاجُ بْنُ الشَّاعِرِ، قَالَا: حَدَّثَنَا عَبْدُ الرَّزَّاقِ", "grades": "", "reference": "Book 0, Hadith 62", "international_number": "62", "narrator_chain": ""}
{"hadithnumber": "63", "arabic": "حَدَّثَنِي الْفَضْلُ بْنُ سَهْلٍ، قَالَ: حَدَّثَنَا عَفَّانُ بْنُ مُسْلِمٍ، حَدَّثَنَا هَمَّامٌ، قَا", "grades": "", "reference": "Book 0, Hadith 63", "international_number": "63", "narrator_chain": ""}
{"hadithnumber": "64", "arabic": "وحَدَّثَنِي حَسَنُ بْنُ عَلِيٍّ الْحُلْوَانِيُّ، قَالَ: حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، أَخْبَرَنَ", "grades": "", "reference": "Book 0, Hadith 64", "international_number": "64", "narrator_chain": ""}
{"hadithnumber": "65", "arabic": "حَدَّثَنَا عُثْمَانُ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا جَرِيرٌ، عَنْ رَقَبَةَ، أَنَّ أَبَا جَعْفَرٍ ال", "grades": "", "reference": "Book 0, Hadith 65", "international_number": "65", "narrator_chain": ""}
{"hadithnumber": "66", "arabic": "حَدَّثَنَا الْحَسَنُ الْحُلْوَانِيُّ، قَالَ: حَدَّثَنَا نُعَيْمُ بْنُ حَمَّادٍ، قَالَ أَبُو إِسْحَاق", "grades": "", "reference": "Book 0, Hadith 66", "international_number": "66", "narrator_chain": ""}
{"hadithnumber": "67", "arabic": "حَدَّثَنِي عَمْرُو بْنُ عَلِيٍّ أَبُو حَفْصٍ، قَالَ: سَمِعْتُ مُعَاذَ بْنَ مُعَاذٍ، يَقُولُ: قُلْتُ", "grades": "", "reference": "Book 0, Hadith 67", "international_number": "67", "narrator_chain": ""}
{"hadithnumber": "68", "arabic": "وحَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ عُمَرَ الْقَوَارِيرِيُّ، حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ، قَالَ: ك", "grades": "", "reference": "Book 0, Hadith 68", "international_number": "68", "narrator_chain": ""}
{"hadithnumber": "69", "arabic": "وحَدَّثَنِي حَجَّاجُ بْنُ الشَّاعِرِ، حَدَّثَنَا سُلَيْمَانُ بْنُ حَرْبٍ، حَدَّثَنَا ابْنُ زَيْدٍ يَ", "grades": "", "reference": "Book 0, Hadith 69", "international_number": "69", "narrator_chain": ""}
{"hadithnumber": "70", "arabic": "وحَدَّثَنِي حَجَّاجٌ، حَدَّثَنَا سُلَيْمَانُ بْنُ حَرْبٍ، قَالَ: سَمِعْتُ سَلَّامَ بْنَ أَبِي مُطِيع", "grades": "", "reference": "Book 0, Hadith 70", "international_number": "70", "narrator_chain": ""}
{"hadithnumber": "71", "arabic": "وحَدَّثَنِي سَلَمَةُ بْنُ شَبِيبٍ، حَدَّثَنَا الْحُمَيْدِيُّ، حَدَّثَنَا سُفْيَانُ، قَالَ: سَمِعْتُ", "grades": "", "reference": "Book 0, Hadith 71", "international_number": "71", "narrator_chain": ""}
{"hadithnumber": "72", "arabic": "حَدَّثَنِي عُبَيْدُ اللَّهِ بْنُ مُعَاذٍ الْعَنْبَرِيُّ، حَدَّثَنَا أَبِي، قَالَ: كَتَبْتُ إِلَى شُع", "grades": "", "reference": "Book 0, Hadith 72", "international_number": "72", "narrator_chain": ""}
{"hadithnumber": "73", "arabic": "وحَدَّثَنَا الْحُلْوَانِيُّ، قَالَ: سَمِعْتُ عَفَّانَ، قَالَ: حَدَّثْتُ حَمَّادَ بْنَ سَلَمَةَ، عَنْ", "grades": "", "reference": "Book 0, Hadith 73", "international_number": "73", "narrator_chain": ""}
{"hadithnumber": "74", "arabic": "وحَدَّثَنِي مَحْمُودُ بْنُ غَيْلَانَ، حَدَّثَنَا أَبُو دَاوُدَ، قَالَ: قَالَ لِي شُعْبَةُ: ايتِ جَرِ", "grades": "", "reference": "Book 0, Hadith 74", "international_number": "74", "narrator_chain": ""}
{"hadithnumber": "75", "arabic": "وحَدَّثَنَا الْحَسَنُ الْحُلْوَانِيُّ، قَالَ: سَمِعْتُ يَزِيدَ بْنَ هَارُونَ، وَذَكَرَ زِيَادَ بْنَ", "grades": "", "reference": "Book 0, Hadith 75", "international_number": "75", "narrator_chain": ""}
{"hadithnumber": "76", "arabic": "وحَدَّثَنَا مَحْمُودُ بْنُ غَيْلَانَ، قَالَ: قُلْتُ لِأَبِي دَاوُدَ الطَّيَالِسِيِّ: قَدْ أَكْثَرْتَ", "grades": "", "reference": "Book 0, Hadith 76", "international_number": "76", "narrator_chain": ""}
{"hadithnumber": "77", "arabic": "حَدَّثَنَا حَسَنٌ الْحُلْوَانِي، قَالَ: سَمِعْتُ شَبَابَةَ، قَالَ: كَانَ عَبْدُ الْقُدُّوسِ يُحَدِّث", "grades": "", "reference": "Book 0, Hadith 77", "international_number": "77", "narrator_chain": ""}
{"hadithnumber": "78", "arabic": "وحَدَّثَنَا الْحَسَنُ الْحُلْوَانِيُّ، قَالَ: سَمِعْتُ عَفَّانَ، قَالَ: سَمِعْتُ أَبَا عَوَانَةَ، قَ", "grades": "", "reference": "Book 0, Hadith 78", "international_number": "78", "narrator_chain": ""}
{"hadithnumber": "79", "arabic": "وحَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ، قَالَ: سَمِعْتُ أَنَا وَحَمْزَة", "grades": "", "reference": "Book 0, Hadith 79", "international_number": "79", "narrator_chain": ""}
{"hadithnumber": "80", "arabic": "حَدَّثَنَا عَبْدُ اللَّهِ بْنُ عَبْدِ الرَّحْمَنِ الدَّارِمِيُّ، أَخْبَرَنَا زَكَرِيَّاءُ بْنُ عَدِي", "grades": "", "reference": "Book 0, Hadith 80", "international_number": "80", "narrator_chain": ""}
{"hadithnumber": "81", "arabic": "وحَدَّثَنَا إِسْحَاق بْنُ إِبْرَاهِيمَ الْحَنْظَلِيُّ، قَالَ: سَمِعْتُ بَعْضَ أَصْحَابِ عَبْدِ اللَّ", "grades": "", "reference": "Book 0, Hadith 81", "international_number": "81", "narrator_chain": ""}
{"hadithnumber": "82", "arabic": "وحَدَّثَنِي أَحْمَدُ بْنُ يُوسُفَ الأَزْدِيُّ، قَالَ: سَمِعْتُ عَبْدَ الرَّزَّاقِ، يَقُولُ: مَا رَأَ", "grades": "", "reference": "Book 0, Hadith 82", "international_number": "82", "narrator_chain": ""}
{"hadithnumber": "83", "arabic": "حَدَّثَنِي عَبْدُ اللَّهِ بْنُ عَبْدِ الرَّحْمَنِ الدَّارِمِيُّ، قَالَ: سَمِعْتُ أَبَا نُعَيْمٍ، وَذ", "grades": "", "reference": "Book 0, Hadith 83", "international_number": "83", "narrator_chain": ""}
{"hadithnumber": "84", "arabic": "حَدَّثَنِي عَمْرُو بْنُ عَلِيٍّ وَحَسَنٌ الْحُلْوَانِيُّ كِلَاهُمَا، عَنْ عَفَّانَ بْنِ مُسْلِمٍ، قَ", "grades": "", "reference": "Book 0, Hadith 84", "international_number": "84", "narrator_chain": ""}
{"hadithnumber": "85", "arabic": "وحَدَّثَنَا أَبُو جَعْفَرٍ الدَّارِمِيُّ، حَدَّثَنَا بِشْرُ بْنُ عُمَرَ، قَالَ: سَأَلْتُ مَالِكَ بْن", "grades": "", "reference": "Book 0, Hadith 85", "international_number": "85", "narrator_chain": ""}
{"hadithnumber": "86", "arabic": "وحَدَّثَنِي الْفَضْلُ بْنُ سَهْلٍ، قَالَ: حَدَّثَنِي يَحْيَى بْنُ مَعِينٍ، حَدَّثَنَا حَجَّاجٌ، حَدّ", "grades": "", "reference": "Book 0, Hadith 86", "international_number": "86", "narrator_chain": ""}
{"hadithnumber": "87", "arabic": "وحَدَّثَنِي مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ قُهْزَاذَ، قَالَ: سَمِعْتُ أَبَا إِسْحَاق الطَّالَقَا", "grades": "", "reference": "Book 0, Hadith 87", "international_number": "87", "narrator_chain": ""}
{"hadithnumber": "88", "arabic": "حَدَّثَنِي الْفَضْلُ بْنُ سَهْلٍ، حَدَّثَنَا وَلِيدُ بْنُ صَالِحٍ، قَالَ: قَالَ عُبَيْدُ اللَّهِ بْن", "grades": "", "reference": "Book 0, Hadith 88", "international_number": "88", "narrator_chain": ""}
{"hadithnumber": "89", "arabic": "حَدَّثَنِي أَحْمَدُ بْنُ إِبْرَاهِيمَ الدَّوْرَقِيُّ، قَالَ: حَدَّثَنِي عَبْدُ السَّلَامِ الْوَابِصِ", "grades": "", "reference": "Book 0, Hadith 89", "international_number": "89", "narrator_chain": ""}
{"hadithnumber": "90", "arabic": "حَدَّثَنِي أَحْمَدُ بْنُ إِبْرَاهِيمَ، قَالَ: حَدَّثَنِي سُلَيْمَانُ بْنُ حَرْبٍ، عَنْ حَمَّادِ بْنِ", "grades": "", "reference": "Book 0, Hadith 90", "international_number": "90", "narrator_chain": ""}
{"hadithnumber": "91", "arabic": "وحَدَّثَنِي عَبْدُ الرَّحْمَنِ بْنُ بِشْرٍ الْعَبْدِيُّ، قَالَ: سَمِعْتُ يَحْيَى بْنَ سَعِيدٍ الْقَط", "grades": "", "reference": "Book 0, Hadith 91", "international_number": "91", "narrator_chain": ""}
{"hadithnumber": "92", "arabic": "حَدَّثَنِي بِشْرُ بْنُ الْحَكَمِ، قَالَ: سَمِعْتُ يَحْيَى بْنَ سَعِيدٍ الْقَطَّانَ، ضَعَّفَ حَكِيمَ", "grades": "", "reference": "Book 0, Hadith 92", "international_number": "92", "narrator_chain": ""}
{"hadithnumber": "128", "arabic": "وحَدَّثَنِي  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، حَدَّثَنَا  وَكِيعٌ . ح وحَدَّثَنِي  مُحَمَّدُ بْنُ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "128", "narrator_chain": ""}
{"hadithnumber": "209", "arabic": "حَدَّثَنِي  مُحَمَّدُ بْنُ رَافِعٍ ، حَدَّثَنَا  عَبْدُ الرَّزَّاقِ ، أَخْبَرَنَا  سُفْيَانُ ، عَنِ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "209", "narrator_chain": ""}
{"hadithnumber": "248", "arabic": "وحَدَّثَنَا  مَنْصُورُ بْنُ أَبِي مُزَاحِمٍ ، حَدَّثَنَا  إِبْرَاهِيمُ بْنُ سَعْدٍ . ح وحَدَّثَنِي", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "248", "narrator_chain": ""}
{"hadithnumber": "637", "arabic": "وحَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ،  وَمُحَمَّدُ بْنُ الْعَلَاءِ ، قَالَا: حَدَّثَنَا  أ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "637", "narrator_chain": ""}
{"hadithnumber": "638", "arabic": "وحَدَّثَنِيهِ  سُوَيْدُ بْنُ سَعِيدٍ ، حَدَّثَنَا  عَلِيٌّ يَعْنِي ابْنَ مُسْهِرٍ ، عَنِ  الأَعْمَشِ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "638", "narrator_chain": ""}
{"hadithnumber": "794", "arabic": "قَالَ  ابْنُ شِهَابٍ : وَحَدَّثَنِي  عَلِيُّ بْنُ عَبْدِ اللَّهِ بْنِ عَبَّاسٍ ، عَنْ  أَبِيهِ ، عَن", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "794", "narrator_chain": ""}
{"hadithnumber": "852", "arabic": "حَدَّثَنَا  مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ ، حَدَّثَنَا  عَبْدَةُ ، عَنْ  طَلْحَةَ بْنِ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "852", "narrator_chain": ""}
{"hadithnumber": "853", "arabic": "وحَدَّثَنِيهِ  إِسْحَاق بْنُ مَنْصُورٍ ، أَخْبَرَنَا  أَبُو عَامِرٍ ، حَدَّثَنَا  سُفْيَانُ ، عَنْ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "853", "narrator_chain": ""}
{"hadithnumber": "881", "arabic": "حَدَّثَنِي  أَحْمَدُ بْنُ جَعْفَرٍ الْمَعْقِرِيُّ ، حَدَّثَنَا  النَّضْرُ بْنُ مُحَمَّدٍ ، حَدَّثَنَ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "881", "narrator_chain": ""}
{"hadithnumber": "1220", "arabic": "حَدَّثَنَا  مُحَمَّدُ بْنُ الْمُثَنَّى ، حَدَّثَنَا  يَحْيَى بْنُ سَعِيدٍ ، عَنْ  هِشَامٍ ، قَالَ: ح", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "1220", "narrator_chain": ""}
{"hadithnumber": "1221", "arabic": "وحَدَّثَنِيهِ  عُبَيْدُ اللَّهِ بْنُ عُمَرَ الْقَوَارِيرِيُّ ، حَدَّثَنَا  خَالِدٌ يَعْنِي ابْنَ الْ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "1221", "narrator_chain": ""}
{"hadithnumber": "1222", "arabic": "وحَدَّثَنَاه  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، حَدَّثَنَا  الْحَسَنُ بْنُ مُوسَى ، حَدَّثَنَا  شَي", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "1222", "narrator_chain": ""}
{"hadithnumber": "1251", "arabic": "وَحَدَّثَنِي  مُحَمَّدُ بْنُ رَافِعٍ ،  عَبْدُ بْنُ حميد ، قَالَ عَبْدُ: أَخْبَرَنَا، وَقَالَ ابْنُ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "1251", "narrator_chain": ""}
{"hadithnumber": "1332", "arabic": "حَدَّثَنَا  مُحَمَّدُ بْنُ الْمُثَنَّى ، حَدَّثَنَا  مُحَمَّدُ بْنُ جَعْفَرٍ ، حَدَّثَنَا  شُعْبَةُ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "1332", "narrator_chain": ""}
{"hadithnumber": "1350", "arabic": "حَدَّثَنَا  نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ ، حَدَّثَنَا  أَبُو أَحْمَدَ ، حَدَّثَنَا  حَمْزَةُ ا", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "1350", "narrator_chain": ""}
{"hadithnumber": "1351", "arabic": "حَدَّثَنِي  مُحَمَّدُ بْنُ حَاتِمٍ ، حَدَّثَنَا  أَسْبَاطُ بْنُ مُحَمَّدٍ ، حَدَّثَنَا  عَمْرُو بْنُ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "1351", "narrator_chain": ""}
{"hadithnumber": "1354", "arabic": "حَدَّثَنِي  زُهَيْرُ بْنُ حَرْبٍ ، حَدَّثَنَا  جَرِيرٌ ، عَنْ  عُمَارَةَ بْنِ الْقَعْقَاعِ ، عَنْ  أ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "1354", "narrator_chain": ""}
{"hadithnumber": "1355", "arabic": "حَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، وَابْنُ نُمَيْرٍ ، قَالَا: حَدَّثَنَا  ابْنُ فُضَيْلٍ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "1355", "narrator_chain": ""}
{"hadithnumber": "1365", "arabic": "وحَدَّثَنِي  مُحَمَّدُ بْنُ حَاتِمٍ ،  وَعُبَيْدُ اللَّهِ بْنُ سَعِيدٍ ، قَالَا: حَدَّثَنَا  يَحْيَى", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "1365", "narrator_chain": ""}
{"hadithnumber": "1366", "arabic": "وحَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، حَدَّثَنَا  سُفْيَانُ بْنُ عُيَيْنَةَ ، عَنْ  مَعْمَ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "1366", "narrator_chain": ""}
{"hadithnumber": "1428", "arabic": "حَدَّثَنَا حَدَّثَنَا  إِسْحَاق بْنُ إِبْرَاهِيمَ الْحَنْظَلِيُّ ، أَخْبَرَنَا  يَحْيَى ابْنُ آدَمَ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "1428", "narrator_chain": ""}
{"hadithnumber": "1429", "arabic": "قَالَ مُسْلِم وَرَوَاهُ  الأَشْجَعِيُّ : عَنْ  سُفْيَانَ الثَّوْرِيِّ ، عَنِ الأَسْوَدِ بْنِ قَيْسٍ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "1429", "narrator_chain": ""}
{"hadithnumber": "1648", "arabic": "وحَدَّثَنَا  حَسَنٌ الْحُلْوَانِيُّ ، حَدَّثَنَا  يَزِيدُ بْنُ هَارُونَ ، أَخْبَرَنَا  حَمَّادُ بْنُ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "1648", "narrator_chain": ""}
{"hadithnumber": "1718", "arabic": "وحَدَّثَنِي  حَرْمَلَةُ بْنُ يَحْيَى ، حَدَّثَنَا  ابْنُ وَهْبٍ ، أَخْبَرَنِي  عَمْرُو بْنُ الْحَارِ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "1718", "narrator_chain": ""}
{"hadithnumber": "1719", "arabic": "وحَدَّثَنِيهِ  حَرْمَلَةُ ، أَخْبَرَنَا  ابْنُ وَهْبٍ ، أَخْبَرَنِي  يُونُسُ ، عَنِ  ابْنِ شِهَابٍ ،", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "1719", "narrator_chain": ""}
{"hadithnumber": "1778", "arabic": "وحَدَّثَنَاه  مُحَمَّدُ بْنُ الْمُثَنَّى ،  وَابْنُ بَشَّارٍ ، قَالَا: حَدَّثَنَا مُحَمَّدُ بْنُ جَع", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "1778", "narrator_chain": ""}
{"hadithnumber": "2045", "arabic": "وحَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ،  وَابْنُ أَبِي عُمَرَ ، قَالَ أَبُو بَكْرٍ: حَدَّثَن", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "2045", "narrator_chain": ""}
{"hadithnumber": "2046", "arabic": "وحَدَّثَنِيهِ  أَبُو الرَّبِيعِ الزَّهْرَانِيُّ ، حَدَّثَنَا  حَمَّادٌ . ح وحَدَّثَنِي  يَعْقُوبُ ال", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "2046", "narrator_chain": ""}
{"hadithnumber": "2057", "arabic": "وحَدَّثَنَا  عُبَيْدُ اللَّهِ بْنُ مُعَاذٍ الْعَنْبَرِيُّ ، حَدَّثَنَا  أَبِي ، حَدَّثَنَا  شُعْبَةُ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "2057", "narrator_chain": ""}
{"hadithnumber": "2058", "arabic": "وحَدَّثَنِيهِ  عَمْرٌو النَّاقِدُ ، حَدَّثَنَا  ابْنُ إِدْرِيسَ . ح وحَدَّثَنِي  أَبُو بَكْرِ بْنُ ن", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "2058", "narrator_chain": ""}
{"hadithnumber": "2093", "arabic": "وحَدَّثَنَا  مُحَمَّدُ بْنُ مِهْرَانَ ، حَدَّثَنَا  الْوَلِيدُ بْنُ مُسْلِمٍ ، أَخْبَرَنَا  عَبْدُ ا", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "2093", "narrator_chain": ""}
{"hadithnumber": "2100", "arabic": "وحَدَّثَنِي  يَعْقُوبُ بْنُ إِبْرَاهِيمَ الدَّوْرَقِيُّ ، حَدَّثَنَا  إِسْمَاعِيلُ ابْنُ عُلَيَّةَ ،", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "2100", "narrator_chain": ""}
{"hadithnumber": "2101", "arabic": "وحَدَّثَنِيهِ  أَبُو غَسَّانَ الْمِسْمَعِيُّ ، حَدَّثَنَا  عَبْدُ الْمَلِكِ بْنُ الصَّبَّاحِ ، عَنْ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "2101", "narrator_chain": ""}
{"hadithnumber": "2104", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِى شَيْبَةَ وَأَبُو كُرَيْبٍ قَالاَ حَدَّثَنَا أَبُو أُسَامَةَ عَنْ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "2104", "narrator_chain": ""}
{"hadithnumber": "2105", "arabic": "حَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ،  وَأَبُو كُرَيْبٍ ، قَالَا: حَدَّثَنَا  أَبُو أُسَامَ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "2105", "narrator_chain": ""}
{"hadithnumber": "2149", "arabic": "حَدَّثَنَا  دَاوُدُ بْنُ رُشَيْدٍ ، حَدَّثَنَا  إِسْمَاعِيلُ ابْنُ عُلَيَّةَ ، حَدَّثَنَا  أَيُّوبُ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "2149", "narrator_chain": ""}
{"hadithnumber": "2150", "arabic": "حَدَّثَنَا  مُحَمَّدُ بْنُ رَافِعٍ ،  وَعَبْدُ بْنُ حميد ، قَالَ ابْنُ رَافِعٍ: حَدَّثَنَا  عَبْدُ ا", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "2150", "narrator_chain": ""}
{"hadithnumber": "2225", "arabic": "حَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، حَدَّثَنَا  غُنْدَرٌ ، عَنْ  شُعْبَةَ . ح وحَدَّثَنَا", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "2225", "narrator_chain": ""}
{"hadithnumber": "2232", "arabic": "وحَدَّثَنِي  هَارُونُ بْنُ سَعِيدٍ الْأَيْلِيُّ ، أَخْبَرَنَا  ابْنُ وَهْبٍ ، أَخْبَرَنِي  مُعَاوِيَ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "2232", "narrator_chain": ""}
{"hadithnumber": "2243", "arabic": "حَدَّثَنَا  يَحْيَى بْنُ يَحْيَى ،  وَأَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ،  وَزُهَيْرُ بْنُ حَرْبٍ ، ق", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "2243", "narrator_chain": ""}
{"hadithnumber": "2295", "arabic": "وحَدَّثَنِي  هَارُونُ بْنُ سَعِيدٍ الْأَيْلِيُّ ، حَدَّثَنَا  ابْنُ وَهْبٍ ، أَخْبَرَنِي  عَمْرُو بْ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "2295", "narrator_chain": ""}
{"hadithnumber": "2339", "arabic": "وحَدَّثَنَا  قُتَيْبَةُ بْنُ سَعِيدٍ ، حَدَّثَنَا  يَعْقُوبُ وَهُوَ ابْنُ عَبْدِ الرَّحْمَنِ الْقَار", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "2339", "narrator_chain": ""}
{"hadithnumber": "2381", "arabic": "وحَدَّثَنَا  يَحْيَى بْنُ يَحْيَى ، قَالَ: قَرَأْتُ عَلَى  مَالِكٍ ، عَنْ  خُبَيْبِ بْنِ عَبْدِ الرّ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "2381", "narrator_chain": ""}
{"hadithnumber": "2810", "arabic": "ح وحَدَّثَنِي مُحَمَّدُ بْنُ حَاتِمٍ ،  وَعَبْدُ بْنُ حُمَيْدٍ كِلَاهُمَا، عَنْ  مُحَمَّدِ بْنِ بَكْ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "2810", "narrator_chain": ""}
{"hadithnumber": "2892", "arabic": "وحَدَّثَنَا  أَبُو الرَّبِيعِ الزَّهْرَانِيُّ ، حَدَّثَنَا  حَمَّادٌ ، عَنْ  عَمْرِو بْنِ دِينَارٍ ،", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "2892", "narrator_chain": ""}
{"hadithnumber": "2893", "arabic": "وحَدَّثَنِيهِ  عَمْرٌو النَّاقِدُ ، حَدَّثَنَا  إِسْمَاعِيل بْنُ إِبْرَاهِيمَ ، عَنْ  أَيُّوبَ ، قَا", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "2893", "narrator_chain": ""}
{"hadithnumber": "2978", "arabic": "وحَدَّثَنَا  مُحَمَّدُ بْنُ الْمُثَنَّى ، حَدَّثَنِي  عَبْدُ الصَّمَدِ ، حَدَّثَنَا  هَمَّامٌ ، حَدّ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "2978", "narrator_chain": ""}
{"hadithnumber": "2979", "arabic": "وحَدَّثَنِيهِ حَجَّاجُ بْنُ الشَّاعِرِ ، حَدَّثَنَا  عُبَيْدُ اللَّهِ بْنُ عَبْدِ الْمَجِيدِ ، حَدَّ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "2979", "narrator_chain": ""}
{"hadithnumber": "3023", "arabic": "حَدَّثَنِي  عُبَيْدُ اللَّهِ بْنُ عُمَرَ الْقَوَارِيرِيُّ ، حَدَّثَنَا  عَبْدُ الْأَعْلَى بْنُ عَبْد", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "3023", "narrator_chain": ""}
{"hadithnumber": "3028", "arabic": "حَدَّثَنَا  يَحْيَى بْنُ يَحْيَى ، أَخْبَرَنَا  هُشَيْمٌ ، عَنْ  يَحْيَى بْنِ أَبِي إِسْحَاق ،  وَعَ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "3028", "narrator_chain": ""}
{"hadithnumber": "3029", "arabic": "وحَدَّثَنِيهِ  عَلِيُّ بْنُ حُجْرٍ ، أَخْبَرَنَا  إِسْمَاعِيل بْنُ إِبْرَاهِيمَ ، عَنْ  يَحْيَى بْنِ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "3029", "narrator_chain": ""}
{"hadithnumber": "3038", "arabic": "وَحَدَّثَنِي  مُحَمَّدُ بْنُ حَاتِمِ بْنِ مَيْمُونٍ ، حَدَّثَنَا  يَحْيَى بْنُ سَعِيدٍ ، عَنِ  ابْنِ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "3038", "narrator_chain": ""}
{"hadithnumber": "3039", "arabic": "وحَدَّثَنَا  أَحْمَدُ بْنُ عَبْدَةَ الضَّبِّيُّ ، حَدَّثَنَا  يَزِيدُ يَعْنِي ابْنَ زُرَيْعٍ ، حَدَّ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "3039", "narrator_chain": ""}
{"hadithnumber": "3087", "arabic": "حَدَّثَنَا  يَحْيَى بْنُ أَيُّوبَ ،  وَقُتَيْبَةُ بْنُ سَعِيدٍ ،  وَابْنُ حُجْرٍ ، قَالُوا: حَدَّثَن", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "3087", "narrator_chain": ""}
{"hadithnumber": "3092", "arabic": "وحَدَّثَنَا  سُرَيْجُ بْنُ يُونُسَ ، حَدَّثَنَا  هُشَيْمٌ ، أَخْبَرَنَا  حُصَيْنٌ ، عَنْ  كَثِيرِ بْ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "3092", "narrator_chain": ""}
{"hadithnumber": "3093", "arabic": "وَحَدَّثَنَاه  حَسَنٌ الْحُلْوَانِيُّ ، حَدَّثَنَا  يَحْيَى بْنُ آدَمَ ، حَدَّثَنَا  سُفْيَانُ ، عَن", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "3093", "narrator_chain": ""}
{"hadithnumber": "3108", "arabic": "حَدَّثَنَا  يَحْيَى بْنُ يَحْيَى ، أَخْبَرَنَا  سُلَيْمَانُ بْنُ بِلَالٍ ، عَنْ  يَحْيَى بْنِ سَعِيد", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "3108", "narrator_chain": ""}
{"hadithnumber": "3109", "arabic": "وحَدَّثَنَاه  قُتَيْبَةُ ،  وَابْنُ رُمْحٍ ، عَنِ  اللَّيْثِ بْنِ سَعْدٍ ، عَنْ  يَحْيَى بْنِ سَعِيد", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "3109", "narrator_chain": ""}
{"hadithnumber": "3222", "arabic": "حدثنا  قُتَيْبَةُ بْنُ سَعِيدٍ ، حدثنا  لَيْثٌ . ح وحدثنا  مُحَمَّدُ بْنُ رُمْح ، حدثنا  اللَّيْثُ ،", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "3222", "narrator_chain": ""}
{"hadithnumber": "3223", "arabic": "حَدَّثَنِي  أَبُو الطَّاهِرِ ،  وَحَرْمَلَةُ بْنُ يَحْيَى ،  وَأَحْمَدُ بْنُ عِيسَى ، قَالَ أَحْمَدُ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "3223", "narrator_chain": ""}
{"hadithnumber": "3224", "arabic": "وحدثنا  قُتَيْبَةُ يَعْنِي ابْنَ سَعِيدٍ ، حدثنا  لَيْثٌ . ح وحدثنا  زُهَيْرُ بْنُ حَرْبٍ ، حدثنا  س", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "3224", "narrator_chain": ""}
{"hadithnumber": "3225", "arabic": "وحدثنا  عَبْدُ اللَّهِ بْنُ مَسْلَمَةَ بْنِ قَعَنْبٍ ، حدثنا  أَفْلَح ، عَنِ  الْقَاسِمِ بْنِ مُحَمّ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "3225", "narrator_chain": ""}
{"hadithnumber": "3226", "arabic": "حدثنا  يَحْيَى بْنُ يَحْيَى ، قَالَ: قَرَأْتُ عَلَى  مَالِكٍ ، عَنْ  عَبْدِ اللَّهِ بْنِ أَبِي بَكْر", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "3226", "narrator_chain": ""}
{"hadithnumber": "3227", "arabic": "حَدَّثَنِي  الْحَكَمُ بْنُ مُوسَى ، حَدَّثَنِي  يَحْيَى بْنُ حَمْزَةَ ، عَنِ  الْأَوْزَاعِيِّ ، لَعَ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "3227", "narrator_chain": ""}
{"hadithnumber": "3228", "arabic": "حدثنا  مُحَمَّدُ بْنُ الْمُثَنَّى ،  وَابْنُ بَشَّارٍ ، قَالَا: حدثنا  مُحَمَّدُ بْنُ جَعْفَرٍ ، حدث", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "3228", "narrator_chain": ""}
{"hadithnumber": "3229", "arabic": "وحدثنا  يَحْيَى بْنُ يَحْيَى ،  وَأَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ،  وَأَبُو كُرَيْبٍ ، عَنْ  أَبِي", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "3229", "narrator_chain": ""}
{"hadithnumber": "3262", "arabic": "وحدثنا  مُحَمَّدُ بْنُ الْمُثَنَّى ، حدثنا  مُحَمَّدُ بْنُ جَعْفَرٍ ، حدثنا  شُعْبَةُ ، عَنْ  عَبْدِ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "3262", "narrator_chain": ""}
{"hadithnumber": "3463", "arabic": "ح وحدثناه  مُحَمَّدُ بْنُ الْمُثَنَّى ، حدثنا  عَبْدُ الصَّمَدِ ، حدثنا  شُعْبَةُ ، عَنِ  الْأَعْمَش", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "3463", "narrator_chain": ""}
{"hadithnumber": "3499", "arabic": "وحدثنا  يَحْيَى بْنُ يَحْيَى ، أَخْبَرَنا  خَالِدُ بْنُ عَبْدِ اللَّهِ ، عَنْ  مُطَرِّفٍ ، عَنْ  عَا", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "3499", "narrator_chain": ""}
{"hadithnumber": "3525", "arabic": "وحدثنا  ابْنُ أَبِي عُمَرَ ، حدثنا  سُفْيَانُ ، قَالَ: سَمِعْتُ  زِيَادَ بْنَ سَعْدٍ ، قَالَ: سَمِعْ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "3525", "narrator_chain": ""}
{"hadithnumber": "3695", "arabic": "وحدثنا  إِسْحَاقَ بْنُ إِبْرَاهِيمَ الْحَنْظَلِيُّ ،  وَمُحَمَّدُ بْنُ أَبِي عُمَرَ ، وَتَقَارَبَا ف", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "3695", "narrator_chain": ""}
{"hadithnumber": "3725", "arabic": "وحدثنا  يَحْيَى بْنُ يَحْيَى ، قَالَ: قَرَأْتُ عَلَى  مَالِكٍ ، عَنْ  عَبْدِ اللَّهِ بْنِ أَبِي بَكْ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "3725", "narrator_chain": ""}
{"hadithnumber": "3726", "arabic": "(حديث موقوف) قَالَت قَالَت  زَيْنَبُ : ثُمَّ دَخَلْتُ عَلَى  زَيْنَبَ بِنْتِ جَحْشٍ حِينَ تُوُفِّيَ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "3726", "narrator_chain": ""}
{"hadithnumber": "3727", "arabic": "(حديث موقوف) قَالَت قَالَت  زَيْنَبُ : سَمِعْتُ أُمِّي  أُمَّ سَلَمَةَ ، تَقُولُ: جَاءَتِ امْرَأَةٌ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "3727", "narrator_chain": ""}
{"hadithnumber": "3730", "arabic": "وَحَدَّثَتْهُ  زَيْنَبُ ، عَنْ  أُمِّهَا ، وَعَنْ  زَيْنَبَ زَوْجِ النَّبِيِّ صَلَّى اللَّهُ عَلَيْه", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "3730", "narrator_chain": ""}
{"hadithnumber": "3792", "arabic": "حَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، حَدَّثَنَا  حُسَيْنُ بْنُ عَلِيٍّ الْجُعْفِيُّ ، عَنْ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "3792", "narrator_chain": ""}
{"hadithnumber": "3836", "arabic": "حَدَّثَنَا  يَحْيَي بْنُ يَحْيَي ، حَدَّثَنَا  حَمَّادُ بْنُ زَيْدٍ . ح وحَدَّثَنَا  أَبُو الرَّبِيع", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "3836", "narrator_chain": ""}
{"hadithnumber": "3842", "arabic": "حَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، حَدَّثَنَا  عَلِيُّ بْنُ مُسْهِرٍ ، عَنْ  عُبَيْدِ ال", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "3842", "narrator_chain": ""}
{"hadithnumber": "3845", "arabic": "حَدَّثَنَا  يَحْيَي بْنُ يَحْيَي ،  وَعَلِيُّ بْنُ حُجْرٍ ، قَالَ يَحْيَي: أَخْبَرَنَا  إِسْمَاعِيلُ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "3845", "narrator_chain": ""}
{"hadithnumber": "4251", "arabic": "وحَدَّثَنِي  مُحَمَّدُ بْنُ رَافِعٍ ، حَدَّثَنَا  عَبْدُ الرَّزَّاقِ ، أَخْبَرَنَا  ابْنُ جُرَيْجٍ ،", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "4251", "narrator_chain": ""}
{"hadithnumber": "4252", "arabic": "وحَدَّثَنِيهِ  مُحَمَّدُ بْنُ حَاتِمٍ ،  وَابْنُ أَبِي خَلَفٍ ، قَالَا: حَدَّثَنَا  رَوْحُ بْنُ عُبَ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "4252", "narrator_chain": ""}
{"hadithnumber": "4435", "arabic": "حَدَّثَنَا  قُتَيْبَةُ بْنُ سَعِيدٍ ، حَدَّثَنَا  لَيْثٌ . ح وحَدَّثَنَاه  مُحَمَّدُ بْنُ رُمْحٍ ، أ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "4435", "narrator_chain": ""}
{"hadithnumber": "4436", "arabic": "وحَدَّثَنَا  أَبُو الطَّاهِرِ ،  وَحَرْمَلَةُ ، قَالَا: أَخْبَرَنَا  ابْنُ وَهْبٍ ، أَخْبَرَنِي  يُو", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "4436", "narrator_chain": ""}
{"hadithnumber": "4504", "arabic": "وحَدَّثَنِي  أَبُو الطَّاهِرِ أَحْمَدُ بْنُ عَمْرِو بْنِ سَرْحٍ ، أَخْبَرَنَا  عَبْدُ اللَّهِ بْنُ و", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "4504", "narrator_chain": ""}
{"hadithnumber": "4505", "arabic": "وحَدَّثَنِيهِ  إِسْحَاقُ بْنُ مَنْصُورٍ ، أَخْبَرَنَا  أَبُو بَكْرٍ الْحَنَفِيُّ ، حَدَّثَنَا  الضَّ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "4505", "narrator_chain": ""}
{"hadithnumber": "4521", "arabic": "حَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، حَدَّثَنَا  وَكِيعُ بْنُ الْجَرَّاحِ ، عَنْ  سُفْيَان", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "4521", "narrator_chain": ""}
{"hadithnumber": "4522", "arabic": "ح وحَدَّثَنِي  عَبْدُ اللَّهِ بْنُ هَاشِمٍ وَاللَّفْظُ لَهُ، حَدَّثَنِي  عَبْدُ الرَّحْمَنِ يَعْنِي", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "4522", "narrator_chain": ""}
{"hadithnumber": "4680", "arabic": "حَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، حَدَّثَنَا  يَزِيدُ بْنُ هَارُونَ ، أَخْبَرَنَا  حَمّ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "4680", "narrator_chain": ""}
{"hadithnumber": "4681", "arabic": "وحَدَّثَنِيهِ  مُحَمَّدُ بْنُ حَاتِمٍ ، حَدَّثَنَا  بَهْزٌ ، حَدَّثَنَا  حَمَّادُ بْنُ سَلَمَةَ ، أَ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "4681", "narrator_chain": ""}
{"hadithnumber": "4725", "arabic": "وحَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، حَدَّثَنَا  مُحَمَّدُ بْنُ بِشْرٍ . ح وحَدَّثَنَا  ا", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "4725", "narrator_chain": ""}
{"hadithnumber": "4726", "arabic": "قَالَ أَبُو إِسْحَاقَ وَحَدَّثَنَا الْحَسَنُ بْنُ بِشْرٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، ع", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "4726", "narrator_chain": ""}
{"hadithnumber": "4747", "arabic": "حَدَّثَنَا  يَحْيَي بْنُ يَحْيَي ، أَخْبَرَنَا  الْمُغِيرَةُ بْنُ عَبْدِ الرَّحْمَنِ الْحِزَامِيُّ ،", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "4747", "narrator_chain": ""}
{"hadithnumber": "4748", "arabic": "وحَدَّثَنِيهِ  زُهَيْرُ بْنُ حَرْبٍ ، حَدَّثَنَا  ابْنُ عُيَيْنَةَ ، عَنْ  أَبِي الزِّنَادِ بِهَذَا", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "4748", "narrator_chain": ""}
{"hadithnumber": "4780", "arabic": "وحَدَّثَنِي  يَحْيَي بْنُ حَبِيبٍ الْحَارِثِيُّ ، حَدَّثَنَا  خَالِدٌ يَعْنِي ابْنَ الْحَارِثِ ، حَد", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "4780", "narrator_chain": ""}
{"hadithnumber": "4781", "arabic": "وحَدَّثَنِيهِ  عُبَيْدُ اللَّهِ بْنُ مُعَاذٍ ، حَدَّثَنَا  أَبِي ، حَدَّثَنَا  شُعْبَةُ بِهَذَا الْإ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "4781", "narrator_chain": ""}
{"hadithnumber": "4819", "arabic": "وحَدَّثَنَاه  حَامِدُ بْنُ عُمَرَ ، حَدَّثَنَا  أَبُو عَوَانَةَ ، عَنْ  طَارِقٍ ، عَنْ  سَعِيدِ بْنِ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "4819", "narrator_chain": ""}
{"hadithnumber": "4820", "arabic": "وحَدَّثَنِيهِ  مُحَمَّدُ بْنُ رَافِعٍ ، حَدَّثَنَا  أَبُو أَحْمَدَ ، قَالَ: وَقَرَأْتُهُ عَلَى  نَصْ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "4820", "narrator_chain": ""}
{"hadithnumber": "4905", "arabic": "وحَدَّثَنِيهِ  إِسْحَاقُ بْنُ مَنْصُورٍ ، أَخْبَرَنَا  عَبْدُ الصَّمَدِ يَعْنِي ابْنَ عَبْدِ الْوَار", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "4905", "narrator_chain": ""}
{"hadithnumber": "4906", "arabic": "وحَدَّثَنِي  إِسْحَاقُ بْنُ مَنْصُورٍ ، أَخْبَرَنَا  عُبَيْدُ اللَّهِ يَعْنِي ابْنَ مُوسَى ، عَنْ  ش", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "4906", "narrator_chain": ""}
{"hadithnumber": "4968", "arabic": "وحَدَّثَنِيهِ  يَحْيَي بْنُ حَبِيبٍ، حَدَّثَنَا  رَوْحٌ ، حَدَّثَنَا  شُعْبَةُ بِهَذَا الْإِسْنَادِ.", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "4968", "narrator_chain": ""}
{"hadithnumber": "4969", "arabic": "وحَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، حَدَّثَنَا  وَكِيعٌ ، عَنْ  سُفْيَانَ ، عَنْ  مُحَار", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "4969", "narrator_chain": ""}
{"hadithnumber": "4970", "arabic": "وحَدَّثَنِيهِ  مُحَمَّدُ بْنُ الْمُثَنَّى ، حَدَّثَنَا  عَبْدُ الرَّحْمَنِ ، حَدَّثَنَا  سُفْيَانُ ب", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "4970", "narrator_chain": ""}
{"hadithnumber": "4971", "arabic": "وحَدَّثَنَا  مُحَمَّدُ بْنُ الْمُثَنَّى ، حَدَّثَنَا  مُحَمَّدُ بْنُ جَعْفَرٍ . ح وحَدَّثَنَا  عُبَي", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "4971", "narrator_chain": ""}
{"hadithnumber": "5112", "arabic": "وحَدَّثَنِي  إِسْحاقُ بْنُ مَنْصُورٍ ، أَخْبَرَنَا  أَبُو مُسْهِرٍ ، حَدَّثَنَا  يَحْيَي بْنُ حَمْزَ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5112", "narrator_chain": ""}
{"hadithnumber": "5113", "arabic": "وحَدَّثَنِيهِ  عَبْدُ اللَّهِ بْنُ عَبْدِ الرَّحْمَنِ الدَّارِمِيُّ ، أَخْبَرَنَا  مُحَمَّدُ بْنُ ال", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5113", "narrator_chain": ""}
{"hadithnumber": "5204", "arabic": "(حديث موقوف) قَالَ قَالَ  أَبُو الزُّبَيْرِ ، وَسَمِعْتُ  جَابِرَ بْنَ عَبْدِ اللَّهِ ، يَقُولُ: \" ن", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5204", "narrator_chain": ""}
{"hadithnumber": "5207", "arabic": "حَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ،  وَمُحَمَّدُ بْنُ الْمُثَنَّى قَالَا: حَدَّثَنَا  مُح", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5207", "narrator_chain": ""}
{"hadithnumber": "5208", "arabic": "وحَدَّثَنَا  حَجَّاجُ بْنُ الشَّاعِرِ ، حَدَّثَنَا  ضَحَّاكُ بْنُ مَخْلَدٍ ، عَنْ  سُفْيَانَ ، عَنْ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5208", "narrator_chain": ""}
{"hadithnumber": "5214", "arabic": "وحَدَّثَنَا  قُتَيْبَةُ بْنُ سَعِيدٍ ،  وَإِسْحَاقُ بْنُ إِبْرَاهِيمَ ، وَاللَّفْظُ لِقُتَيْبَةَ، قَ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5214", "narrator_chain": ""}
{"hadithnumber": "5384", "arabic": "وحَدَّثَنَاه  أَبُو كُرَيْبٍ ،  وَمُحَمَّدُ بْنُ الْمُثَنَّى ، قَالَا: حَدَّثَنَا  أَبُو مُعَاوِيَةَ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5384", "narrator_chain": ""}
{"hadithnumber": "5393", "arabic": "وحَدَّثَنَا  إِسْحَاقُ بْنُ إِبْرَاهِيمَ ، حَدَّثَنَا  يَحْيَي بْنُ آدَمَ ،  وَعَمْرُو بْنُ مُحَمَّد", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5393", "narrator_chain": ""}
{"hadithnumber": "5519", "arabic": "حَدَّثَنَا  إِسْحَاقُ بْنُ إِبْرَاهِيمَ ، أَخْبَرَنَا  جَرِيرٌ ، عَنْ  سُهَيْلِ بْنِ أَبِي صَالِح ،", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5519", "narrator_chain": ""}
{"hadithnumber": "5521", "arabic": "حَدَّثَنِي  زُهَيْرُ بْنُ حَرْبٍ ، حَدَّثَنَا  إِسْمَاعِيلُ بْنُ إِبْرَاهِيمَ ، عَنْ  دَاوُدَ ، عَنْ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5521", "narrator_chain": ""}
{"hadithnumber": "5522", "arabic": "وحدثينيه  مُحَمَّدُ بْنُ الْمُثَنَّى ، حَدَّثَنَا  ابْنُ أَبِي عَدِيٍّ ،  وَعَبْدُ الْأَعْلَى ، بِهَ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5522", "narrator_chain": ""}
{"hadithnumber": "5539", "arabic": "وحَدَّثَنَا  نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ ، حَدَّثَنَا  عَبْدُ الْعَزِيزِ بْنُ عَبْدِ الصَّمَد", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5539", "narrator_chain": ""}
{"hadithnumber": "5540", "arabic": "قَالَ مُسْلِم: قَرَأْتُ عَلَى  نَصْرِ بْنِ عَلِيٍّ الْجَهْضَمِيِّ ، عَنْ  عَبْدِ الْأَعْلَى بْنِ عَب", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5540", "narrator_chain": ""}
{"hadithnumber": "5541", "arabic": "وحَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، حَدَّثَنَا  عَلِيُّ بْنُ مُسْهِرٍ ، عَنْ  سَعِيدِ بْ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5541", "narrator_chain": ""}
{"hadithnumber": "5542", "arabic": "حَدَّثَنَا  أَبُو غَسَّانَ الْمِسْمَعِيُّ ،  وَمُحَمَّدُ بْنُ الْمُثَنَّى ، قالا: حَدَّثَنَا مُعَاذُ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5542", "narrator_chain": ""}
{"hadithnumber": "5543", "arabic": "حَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ،  وَمُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ ،  وَأ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5543", "narrator_chain": ""}
{"hadithnumber": "5544", "arabic": "وحدثينيه  زُهَيْرُ بْنُ حَرْبٍ ، حَدَّثَنَا  جَرِيرٌ ، عَنْ  عُمَارَةَ ، عَنْ  أَبِي زُرْعَةَ ، قال:", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5544", "narrator_chain": ""}
{"hadithnumber": "5545", "arabic": "حَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، حَدَّثَنَا  خَالِدُ بْنُ مَخْلَدٍ ، عَنْ  سُلَيْمَانَ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5545", "narrator_chain": ""}
{"hadithnumber": "5556", "arabic": "وحَدَّثَنِي  زُهَيْرُ بْنُ حَرْبٍ ، حَدَّثَنَا  يَحْيَي بْنُ سَعِيدٍ ، عَنْ  شُعْبَةَ ، حَدَّثَنِي", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5556", "narrator_chain": ""}
{"hadithnumber": "5557", "arabic": "وحدثينيه  يَحْيَي بْنُ حَبِيبٍ ، حَدَّثَنَا  خَالِدُ بْنُ الْحَارِثِ . ح وحدثنا  مُحَمَّدُ بْنُ بَشّ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5557", "narrator_chain": ""}
{"hadithnumber": "5569", "arabic": "حَدَّثَنِي  زُهَيْرُ بْنُ حَرْبٍ ، حَدَّثَنَا  زَيْدُ بْنُ الْحُبَابِ ، عَنْ  إِبْرَاهِيمَ بْنِ نَاف", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5569", "narrator_chain": ""}
{"hadithnumber": "5570", "arabic": "وحدثينيه  مُحَمَّدُ بْنُ حَاتِمٍ ، حَدَّثَنَا  عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ ، عَنْ  إِبْرَاهِيم", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5570", "narrator_chain": ""}
{"hadithnumber": "5571", "arabic": "حَدَّثَنَا  مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ ، حَدَّثَنَا  أَبِي . ح وحَدَّثَنَا  زُهَيْر", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5571", "narrator_chain": ""}
{"hadithnumber": "5572", "arabic": "وحدثينيه  مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ بَزِيعٍ ، حَدَّثَنَا  بِشْرُ بْنُ الْمُفَضَّلِ ، حَدَّث", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5572", "narrator_chain": ""}
{"hadithnumber": "5637", "arabic": "وحدثنا  إِسْحَاقُ بْنُ إِبْرَاهِيمَ ، حَدَّثَنَا  النَّضْرُ بْنُ شُمَيْلٍ ،  وَأَبُو عَامِرٍ الْعَقَ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5637", "narrator_chain": ""}
{"hadithnumber": "5669", "arabic": "وحدثنا  أَبُو كُرَيْبٍ ، حَدَّثَنَا  ابْنُ نُمَيْرٍ ، حَدَّثَنَا  هِشَامٌ بِهَذَا الْإِسْنَادِ، وَقَ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5669", "narrator_chain": ""}
{"hadithnumber": "5670", "arabic": "وحَدَّثَنِيهِ  سُوَيْدُ بْنُ سَعِيدٍ ، حَدَّثَنَا  عَلِيُّ بْنُ مُسْهِرٍ ، عَنْ  هِشَامٍ بِهَذَا الْ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5670", "narrator_chain": ""}
{"hadithnumber": "5762", "arabic": "حَدَّثَنَا  يَحْيَي بْنُ يَحْيَي التَّمِيمِيُّ ،  وَأَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ،  وَعَمْرٌو ال", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5762", "narrator_chain": ""}
{"hadithnumber": "5764", "arabic": "وحَدَّثَنِي  حَرْمَلَةُ بْنُ يَحْيَي ، أَخْبَرَنَا  ابْنُ وَهْبٍ ، أَخْبَرَنِي  يُونُسُ بْنُ يَزِيدَ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5764", "narrator_chain": ""}
{"hadithnumber": "5826", "arabic": "وحَدَّثَنَا  حَاجِبُ بْنُ الْوَلِيدِ ، حَدَّثَنَا  مُحَمَّدُ بْنُ حَرْبٍ ، عَنْ  الزُّبَيْدِيِّ ، عَ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5826", "narrator_chain": ""}
{"hadithnumber": "5827", "arabic": "وحدثينيه  حَرْمَلَةُ بْنُ يَحْيَي ، أَخْبَرَنَا  ابْنُ وَهْبٍ ، أَخْبَرَنِي  يُونُسُ . ح وحَدَّثَنَا", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5827", "narrator_chain": ""}
{"hadithnumber": "5885", "arabic": "حَدَّثَنَا  عَمْرٌو النَّاقِدُ ،  وَابْنُ أَبِي عُمَرَ كِلَاهُمَا، عَنْ  ابْنِ عُيَيْنَةَ ، قَالَ اب", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5885", "narrator_chain": ""}
{"hadithnumber": "5886", "arabic": "وحَدَّثَنِيهِ  زُهَيْرُ بْنُ حَرْبٍ ،  وَأَحْمَدُ بْنُ عَبْدَةَ ، جَمِيعًا، عَنْ  ابْنِ عُيَيْنَةَ ،", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5886", "narrator_chain": ""}
{"hadithnumber": "5935", "arabic": "حَدَّثَنِي  مُحَمَّدُ بْنُ سَهْلٍ التَّمِيمِيُّ ، حَدَّثَنَا  أَبُو الْيَمَانِ ، أَخْبَرَنَا  شُعَيْ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5935", "narrator_chain": ""}
{"hadithnumber": "5968", "arabic": "حَدَّثَنَا  قُتَيْبَةُ بْنُ سَعِيدٍ ، حَدَّثَنَا  يَعْقُوبُ يَعْنِي ابْنَ عَبْدِ الرَّحْمَنِ الْقَار", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5968", "narrator_chain": ""}
{"hadithnumber": "5971", "arabic": "وحَدَّثَنَا  دَاوُدُ بْنُ عَمْرٍو الضَّبِّيُّ ، حَدَّثَنَا  نَافِعُ بْنُ عُمَرَ الْجُمَحِيُّ ، عَنْ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5971", "narrator_chain": ""}
{"hadithnumber": "5990", "arabic": "حَدَّثَنَا  أَبُو غَسَّانَ الْمِسْمَعِيُّ ،  وَمُحَمَّدُ بْنُ الْمُثَنَّى ،  وَابْنُ بَشَّارٍ ، وَأَ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5990", "narrator_chain": ""}
{"hadithnumber": "5991", "arabic": "وحَدَّثَنِيهِ  زُهَيْرُ بْنُ حَرْبٍ ، حَدَّثَنَا  الْحَسَنُ بْنُ مُوسَى ، حَدَّثَنَا  شَيْبَانُ ، عَ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5991", "narrator_chain": ""}
{"hadithnumber": "5995", "arabic": "وحَدَّثَنِي  حَرْمَلَةُ بْنُ يَحْيَي ، أَخْبَرَنَا  ابْنُ وَهْبٍ ، أَخْبَرَنِي  يُونُسُ ، عَنْ  ابْن", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5995", "narrator_chain": ""}
{"hadithnumber": "5996", "arabic": "وحَدَّثَنِي  مُحَمَّدُ بْنُ حَاتِمٍ ، حَدَّثَنَا  عَفَّانُ بْنُ مُسْلِمٍ الصَّفَّارُ ، حَدَّثَنَا  و", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5996", "narrator_chain": ""}
{"hadithnumber": "5997", "arabic": "وحَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ،  وَعَلِيُّ بْنُ حُجْرٍ ، قَالَا: حَدَّثَنَا  عَلِيُّ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5997", "narrator_chain": ""}
{"hadithnumber": "5998", "arabic": "وحَدَّثَنَا  عَاصِمُ بْنُ النَّضْرِ التَّيْمِيُّ ،  وَهُرَيْمُ بْنُ عَبْدِ الْأَعْلَى وَاللَّفْظُ لِ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5998", "narrator_chain": ""}
{"hadithnumber": "5999", "arabic": "وحَدَّثَنَا  هَارُونُ بْنُ عَبْدِ اللَّهِ ، حَدَّثَنَا  عَبْدُ الصَّمَدِ ، حَدَّثَنَا  هِشَامٌ . ح و", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "5999", "narrator_chain": ""}
{"hadithnumber": "6000", "arabic": "وحَدَّثَنِي  يَحْيَي بْنُ حَبِيبٍ الْحَارِثِيُّ ،  وَمُحَمَّدُ بْنُ عَبْدِ اللَّهِ الرُّزِّيُّ ، قَا", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "6000", "narrator_chain": ""}
{"hadithnumber": "6001", "arabic": "وحَدَّثَنِيهِ زُهَيْرُ بْنُ حَرْبٍ ، حَدَّثَنَا  الْحَسَنُ بْنُ مُوسَى ، حَدَّثَنَا  شَيْبَانُ ، عَن", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "6001", "narrator_chain": ""}
{"hadithnumber": "6002", "arabic": "حَدَّثَنِي  الْوَلِيدُ بْنُ شُجَاعِ بْنِ الْوَلِيدِ السَّكُونِيُّ ، حَدَّثَنِي  أَبِي رَحِمَهُ اللَّ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "6002", "narrator_chain": ""}
{"hadithnumber": "6003", "arabic": "حَدَّثَنَا  قُتَيْبَةُ بْنُ سَعِيدٍ ،  وَأَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، قَالَا: حَدَّثَنَا  حَات", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "6003", "narrator_chain": ""}
{"hadithnumber": "6015", "arabic": "حَدَّثَنِي  أَبُو مَعْنٍ الرَّقَاشِيُّ زَيْدُ بْنُ يَزِيدَ ، أَخْبَرَنَا  عُمَرُ بْنُ يُونُسَ ، حَدّ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "6015", "narrator_chain": ""}
{"hadithnumber": "6144", "arabic": "وحَدَّثَنِي  زُهَيْرُ بْنُ حَرْبٍ ، حَدَّثَنَا  شَبَابَةُ ، حَدَّثَنَا  وَرْقَاءُ ، عَنْ  أَبِي الزّ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "6144", "narrator_chain": ""}
{"hadithnumber": "6179", "arabic": "حَدَّثَنِي  عَبَّادُ بْنُ مُوسَى ، حَدَّثَنَا  إِبْرَاهِيمُ بْنُ سَعْدٍ ، أَخْبَرَنِي  أَبِي ، عَنْ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "6179", "narrator_chain": ""}
{"hadithnumber": "6180", "arabic": "وحَدَّثَنِيهِ  حَجَّاجُ بْنُ الشَّاعِرِ ، حَدَّثَنَا  يَعْقُوبُ بْنُ إِبْرَاهِيمَ ، حَدَّثَنَا  أَبِ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "6180", "narrator_chain": ""}
{"hadithnumber": "6200", "arabic": "حَدَّثَنِي  حَرْمَلَةُ بْنُ يَحْيَي ، أَخْبَرَنَا  ابْنُ وَهْبٍ ، أَخْبَرَنِي  يُونُسُ ، أَنَّ  ابْن", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "6200", "narrator_chain": ""}
{"hadithnumber": "6201", "arabic": "وحَدَّثَنِيهِ  عَمْرٌو النَّاقِدُ ،  وَحَسَنٌ الْحُلْوَانِيُّ ،  وَعَبْدُ بْنُ حُمَيْدٍ ، قَالُوا: ح", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "6201", "narrator_chain": ""}
{"hadithnumber": "6410", "arabic": "حَدَّثَنَا  عَبْدُ اللَّهِ بْنُ بَرَّادٍ الْأَشْعَرِيُّ ،  وَمُحَمَّدُ بْنُ الْعَلَاءِ الْهَمْدَانِي", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "6410", "narrator_chain": ""}
{"hadithnumber": "6414", "arabic": "حَدَّثَنَا  مُحَمَّدُ بْنُ الْمُثَنَّى ، حَدَّثَنَا  مُحَمَّدُ بْنُ جَعْفَرٍ ،  وَعَبْدُ الرَّحْمَنِ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "6414", "narrator_chain": ""}
{"hadithnumber": "6415", "arabic": "وحَدَّثَنِيهِ  يَحْيَي بْنُ حَبِيبٍ ، حَدَّثَنَا  خَالِدٌ يَعْنِي ابْنَ الْحَارِثِ ، حَدَّثَنَا  شُع", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "6415", "narrator_chain": ""}
{"hadithnumber": "6505", "arabic": "حَدَّثَنَا  عُبَيْدُ اللَّهِ بْنُ مُعَاذٍ ، حَدَّثَنَا  أَبِي ، حَدَّثَنَا  شُعْبَةُ ، عَنْ  حَبِيبٍ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "6505", "narrator_chain": ""}
{"hadithnumber": "6506", "arabic": "حَدَّثَنَا  أَبُو كُرَيْبٍ ، أَخْبَرَنَا  ابْنُ بِشْرٍ ، عَنْ  مِسْعَرٍ . ح وحَدَّثَنِي  مُحَمَّدُ ب", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "6506", "narrator_chain": ""}
{"hadithnumber": "6527", "arabic": "حَدَّثَنَا  حَاجِبُ بْنُ الْوَلِيدِ ، حَدَّثَنَا  مُحَمَّدُ بْنُ حَرْبٍ ، حَدَّثَنَا  مُحَمَّدُ بْنُ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "6527", "narrator_chain": ""}
{"hadithnumber": "6528", "arabic": "حَدَّثَنَا  زُهَيْرُ بْنُ حَرْبٍ ،  وَابْنُ أَبِي عُمَرَ ،  وَعَمْرٌو النَّاقِدُ جميعا، عَنْ  ابْنِ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "6528", "narrator_chain": ""}
{"hadithnumber": "6529", "arabic": "حَدَّثَنَا  أَبُو كَامِلٍ ، حَدَّثَنَا  يَزِيدُ يَعْنِي ابْنَ زُرَيْعٍ . ح وحَدَّثَنَا  مُحَمَّدُ بْ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "6529", "narrator_chain": ""}
{"hadithnumber": "6544", "arabic": "حَدَّثَنَا  قُتَيْبَةُ بْنُ سَعِيدٍ ، عَنْ  مَالِكِ بْنِ أَنَسٍ فِيمَا قُرِئَ عَلَيْهِ، عَنْ  سُهَيْ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "6544", "narrator_chain": ""}
{"hadithnumber": "6545", "arabic": "حَدَّثَنِيهِ  زُهَيْرُ بْنُ حَرْبٍ ، حَدَّثَنَا  جَرِيرٌ . ح وحَدَّثَنَا  قُتَيْبَةُ بْنُ سَعِيدٍ ،", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "6545", "narrator_chain": ""}
{"hadithnumber": "6625", "arabic": "حَدَّثَنِي  هَارُونُ بْنُ عَبْدِ اللَّهِ ،  وَحَجَّاجُ بْنُ الشَّاعِرِ ، قَالَا: حَدَّثَنَا  حَجَّاج", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "6625", "narrator_chain": ""}
{"hadithnumber": "6626", "arabic": "حَدَّثَنِيهِ  ابْنُ أَبِي خَلَفٍ ، حَدَّثَنَا  رَوْحٌ . ح وحَدَّثَنَاه  عَبْدُ بْنُ حُمَيْدٍ ، حَدَّ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "6626", "narrator_chain": ""}
{"hadithnumber": "6701", "arabic": "حَدَّثَنَا  سُوَيْدُ بْنُ سَعِيدٍ ،  وَمُحَمَّدُ بْنُ عَبْدِ الْأَعْلَى وَتَقَارَبَا فِي اللَّفْظِ،", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "6701", "narrator_chain": ""}
{"hadithnumber": "6702", "arabic": "وحَدَّثَنِيهِ  عُبَيْدُ اللَّهِ بْنُ سَعِيدٍ ، حَدَّثَنَا  يَحْيَي يَعْنِي ابْنَ سَعِيدٍ ، عَنْ  الت", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "6702", "narrator_chain": ""}
{"hadithnumber": "6711", "arabic": "حَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ،  وَعَمْرٌو النَّاقِدُ ،  وَزُهَيْرُ بْنُ حَرْبٍ ،  وَ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "6711", "narrator_chain": ""}
{"hadithnumber": "6712", "arabic": "حَدَّثَنِيهِ  مُحَمَّدُ بْنُ رَافِعٍ ،  وَعَبْدُ بْنُ حُمَيْدٍ ، قَالَ عَبْدٌ: أَخْبَرَنَا، وَقَالَ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "6712", "narrator_chain": ""}
{"hadithnumber": "6792", "arabic": "حَدَّثَنِي  حَرْمَلَةُ بْنُ يَحْيَي ، أَخْبَرَنَا  ابْنُ وَهْبٍ ، أَخْبَرَنِي  يُونُسُ ، عَنْ  ابْنِ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "6792", "narrator_chain": ""}
{"hadithnumber": "6844", "arabic": "حَدَّثَنَا  سُلَيْمَانُ بْنُ عُبَيْدِ اللَّهِ أَبُو أَيُّوبَ الْغَيْلَانِيُّ ، حَدَّثَنَا  أَبُو عَا", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "6844", "narrator_chain": ""}
{"hadithnumber": "6845", "arabic": "وقَالَ  سُلَيْمَانُ : حَدَّثَنَا  أَبُو عَامِرٍ ، حَدَّثَنَا  عُمَرُ ، حَدَّثَنَا  عَبْدُ اللَّهِ بْ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "6845", "narrator_chain": ""}
{"hadithnumber": "6855", "arabic": "حَدَّثَنَا  مُحَمَّدُ بْنُ الْمُثَنَّى ،  وَابْنُ بَشَّارٍ ، قَالَا: حَدَّثَنَا  مُحَمَّدُ بْنُ جَعْ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "6855", "narrator_chain": ""}
{"hadithnumber": "6856", "arabic": "وحَدَّثَنِيهِ  زُهَيْرُ بْنُ حَرْبٍ ، حَدَّثَنَا  عَبْدُ الرَّحْمَنِ ، حَدَّثَنَا  شُعْبَةُ فِي هَذَ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "6856", "narrator_chain": ""}
{"hadithnumber": "6879", "arabic": "وحَدَّثَنَا  هَارُونُ بْنُ مَعْرُوفٍ ،  وَأَبُو الطَّاهِرِ كِلَاهُمَا، عَنْ  ابْنِ وَهْبٍ وَاللَّفْظ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "6879", "narrator_chain": ""}
{"hadithnumber": "6918", "arabic": "حَدَّثَنِي  أُمَيَّةُ بْنُ بِسْطَامَ الْعَيْشِيُّ ، حَدَّثَنَا  يَزِيدُ يَعْنِي ابْنَ زُرَيْعٍ ، حَد", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "6918", "narrator_chain": ""}
{"hadithnumber": "6919", "arabic": "وحَدَّثَنِيهِ  أَحْمَدُ بْنُ سَعِيدٍ الدَّارِمِيُّ ، حَدَّثَنَا  حَبَّانُ ، حَدَّثَنَا  وُهَيْبٌ ، ح", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "6919", "narrator_chain": ""}
{"hadithnumber": "6929", "arabic": "حَدَّثَنَا  إِسْحَاقُ بْنُ إِبْرَاهِيمَ ، أَخْبَرَنَا  عِيسَى بْنُ يُونُسَ ، حَدَّثَنَا  عَبْدُ الْم", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "6929", "narrator_chain": ""}
{"hadithnumber": "6961", "arabic": "حَدَّثَنَا  هَدَّابُ بْنُ خَالِدٍ ، حَدَّثَنَا  هَمَّامٌ ، حَدَّثَنَا  قَتَادَةُ ، عَنْ  أَنَسِ بْنِ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "6961", "narrator_chain": ""}
{"hadithnumber": "6962", "arabic": "وحَدَّثَنِيهِ  أَحْمَدُ الدَّارِمِيُّ ، حَدَّثَنَا  حَبَّانُ ، حَدَّثَنَا  هَمَّامٌ ، حَدَّثَنَا  قَ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "6962", "narrator_chain": ""}
{"hadithnumber": "6981", "arabic": "حَدَّثَنَا  مُحَمَّدُ بْنُ رَافِعٍ ،  وَعَبْدُ بْنُ حميد ، قَالَ عَبد: أَخْبَرَنَا، وقَالَ ابْنُ رَا", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "6981", "narrator_chain": ""}
{"hadithnumber": "6989", "arabic": "حَدَّثَنَا  مُحَمَّدُ بْنُ الْمُثَنَّى ، حَدَّثَنَا  مُحَمَّدُ بْنُ جَعْفَرٍ ، حَدَّثَنَا  شُعْبَةُ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "6989", "narrator_chain": ""}
{"hadithnumber": "6990", "arabic": "وحَدَّثَنَا  مُحَمَّدُ بْنُ بَشَّارٍ ، حَدَّثَنَا  أَبُو دَاوُدَ ، حَدَّثَنَا  شُعْبَةُ بِهَذَا الْإ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "6990", "narrator_chain": ""}
{"hadithnumber": "7016", "arabic": "حَدَّثَنِي  أَبُو الطَّاهِرِ أَحْمَدُ بْنُ عَمْرِو بْنِ عَبْدِ اللَّهِ بْنِ عَمْرِو بْنِ سَرْحٍ مَوْ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7016", "narrator_chain": ""}
{"hadithnumber": "7017", "arabic": "وحَدَّثَنِيهِ  مُحَمَّدُ بْنُ رَافِعٍ ، حَدَّثَنَا  حُجَيْنُ بْنُ الْمُثَنَّى ، حَدَّثَنَا  اللَّيْث", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7017", "narrator_chain": ""}
{"hadithnumber": "7018", "arabic": "وحَدَّثَنِي  عَبْدُ بْنُ حُمَيْدٍ ، حَدَّثَنِي  يَعْقُوبُ بْنُ إِبْرَاهِيمَ بْنِ سَعْدٍ ، حَدَّثَنَا", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7018", "narrator_chain": ""}
{"hadithnumber": "7020", "arabic": "حَدَّثَنَا  حِبَّانُ بْنُ مُوسَى ، أَخْبَرَنَا  عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ ، أَخْبَرَنَا  يُون", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7020", "narrator_chain": ""}
{"hadithnumber": "7076", "arabic": "حَدَّثَنِي  زُهَيْرُ بْنُ حَرْبٍ ،  وَعَبْدُ بْنُ حميد ، قَالَا: حَدَّثَنَا  يُونُسُ بْنُ مُحَمَّدٍ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7076", "narrator_chain": ""}
{"hadithnumber": "7077", "arabic": "وحَدَّثَنِيهِ  مُحَمَّدُ بْنُ رَافِعٍ ، حَدَّثَنَا  عَبْدُ الرَّزَّاقِ ، أَخْبَرَنَا  مَعْمَرٌ ، عَن", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7077", "narrator_chain": ""}
{"hadithnumber": "7080", "arabic": "حَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا  أَبُو مُعَاوِيَةَ ،  وَأَبُو أُسَامَةَ ، ع", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7080", "narrator_chain": ""}
{"hadithnumber": "7081", "arabic": "حَدَّثَنَا  مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ   وَأَبُو سَعِيدٍ الْأَشَجُّ ، قَالَا: حَدَّ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7081", "narrator_chain": ""}
{"hadithnumber": "7111", "arabic": "حَدَّثَنَا  قُتَيْبَةُ بْنُ سَعِيدٍ ، حَدَّثَنَا  لَيْثٌ ، عَنْ  بُكَيْرٍ ، عَنْ  بُسْرِ بْنِ سَعِيد", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7111", "narrator_chain": ""}
{"hadithnumber": "7112", "arabic": "وحَدَّثَنِيهِ  يُونُسُ بْنُ عَبْدِ الْأَعْلَى الصَّدَفِيُّ ، أَخْبَرَنَا  عَبْدُ اللَّهِ بْنُ وَهْبٍ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7112", "narrator_chain": ""}
{"hadithnumber": "7138", "arabic": "حَدَّثَنَا  إِسْحَاقُ بْنُ إِبْرَاهِيمَ الْحَنْظَلِيُّ ، أَخْبَرَنَا  الْمَخْزُومِيُّ ، حَدَّثَنَا", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7138", "narrator_chain": ""}
{"hadithnumber": "7141", "arabic": "حَدَّثَنَا  قُتَيْبَةُ بْنُ سَعِيدٍ ، حَدَّثَنَا  يَعْقُوبُ يَعْنِي ابْنَ عَبْدِ الرَّحْمَنِ الْقَار", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7141", "narrator_chain": ""}
{"hadithnumber": "7144", "arabic": "حَدَّثَنِي  عَبْدُ اللَّهِ بْنُ جَعْفَرِ بْنِ يَحْيَى بْنِ خَالِدٍ ، حَدَّثَنَا  مَعْنٌ ، حَدَّثَنَا", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7144", "narrator_chain": ""}
{"hadithnumber": "7256", "arabic": "وحَدَّثَنَا  مُحَمَّدُ بْنُ رَافِعٍ ، حَدَّثَنَا  عَبْدُ الرَّزَّاقِ ، حَدَّثَنَا  مَعْمَرٌ ، عَنْ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7256", "narrator_chain": ""}
{"hadithnumber": "7301", "arabic": "حَدَّثَنَا  قُتَيْبَةُ بْنُ سَعِيدٍ ، عَنْ  مَالِكِ بْنِ أَنَسٍ فِيمَا قُرِئَ عَلَيْهِ، عَنْ  أَبِي", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7301", "narrator_chain": ""}
{"hadithnumber": "7302", "arabic": "حَدَّثَنَا  عَبْدُ اللَّهِ بْنُ عُمَرَ بْنِ مُحَمَّدِ بْنِ أَبَانَ بْنِ صَالِحٍ ،  وَمُحَمَّدُ بْنُ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7302", "narrator_chain": ""}
{"hadithnumber": "7319", "arabic": "وحَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، حَدَّثَنَا  أَبُو مُعَاوِيَةَ ، عَنْ  دَاوُدَ بْنِ أ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7319", "narrator_chain": ""}
{"hadithnumber": "7325", "arabic": "حَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، حَدَّثَنَا  أَبُو أُسَامَةَ ، حَدَّثَنَا  شُعْبَةُ ،", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7325", "narrator_chain": ""}
{"hadithnumber": "7329", "arabic": "حَدَّثَنَا  مُحَمَّدُ بْنُ رَافِعٍ ، حَدَّثَنَا  عَبْدُ الرَّزَّاقِ ، حَدَّثَنَا  مَعْمَرٌ ، عَنْ  ه", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7329", "narrator_chain": ""}
{"hadithnumber": "7330", "arabic": "حَدَّثَنَا  قُتَيْبَةُ بْنُ سَعِيدٍ ، حَدَّثَنَا  جَرِيرٌ ، عَنْ  عَبْدِ الْمَلِكِ بْنِ عُمَيْرٍ ، ع", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7330", "narrator_chain": ""}
{"hadithnumber": "7331", "arabic": "حَدَّثَنَا  قُتَيْبَةُ بْنُ سَعِيدٍ ،  وَأَبُو كَامِلٍ الْجَحْدَرِيُّ ، قَالَا: حَدَّثَنَا  أَبُو عَ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7331", "narrator_chain": ""}
{"hadithnumber": "7332", "arabic": "حَدَّثَنَا  مُحَمَّدُ بْنُ الْمُثَنَّى ،  وَابْنُ بَشَّارٍ ، قَالَا: حَدَّثَنَا  مُحَمَّدُ بْنُ جَعْ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7332", "narrator_chain": ""}
{"hadithnumber": "7333", "arabic": "حَدَّثَنَا  قُتَيْبَةُ بْنُ سَعِيدٍ ، حَدَّثَنَا  عَبْدُ الْعَزِيزِ يَعْنِي ابْنَ مُحَمَّدٍ ، عَنْ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7333", "narrator_chain": ""}
{"hadithnumber": "7334", "arabic": "حَدَّثَنِي  مُحَمَّدُ بْنُ مَرْزُوقٍ ، حَدَّثَنَا  بِشْرُ بْنُ عُمَرَ الزَّهْرَانِيُّ ، حَدَّثَنِي", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7334", "narrator_chain": ""}
{"hadithnumber": "7335", "arabic": "حَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، حَدَّثَنَا  مُحَمَّدُ بْنُ بِشْرٍ ، حَدَّثَنَا  عُبَي", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7335", "narrator_chain": ""}
{"hadithnumber": "7336", "arabic": "وحَدَّثَنَاه  مُحَمَّدُ بْنُ الْمُثَنَّى ،  وَعُبَيْدُ اللَّهِ بْنُ سَعِيدٍ ، قَالَا: حَدَّثَنَا  يَ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7336", "narrator_chain": ""}
{"hadithnumber": "7337", "arabic": "حَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ حَدَّثَنَا  أَبُو أُسَامَةَ ، أَخْبَرَنِي  عُمَرُ بْنُ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7337", "narrator_chain": ""}
{"hadithnumber": "7338", "arabic": "حَدَّثَنَا  حَرْمَلَةُ بْنُ يَحْيَى ، أَخْبَرَنَا  ابْنُ وَهْبٍ ، أَخْبَرَنِي  يُونُسُ ، عَنْ  ابْنِ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7338", "narrator_chain": ""}
{"hadithnumber": "7339", "arabic": "حَدَّثَنَا  قُتَيْبَةُ بْنُ سَعِيدٍ ، حَدَّثَنَا  يَعْقُوبُ يَعْنِي ابْنَ عَبْدِ الرَّحْمَنِ ، عَنْ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7339", "narrator_chain": ""}
{"hadithnumber": "7340", "arabic": "حَدَّثَنَا  يَحْيَى بْنُ يَحْيَى ،  وَأَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، قَالَ يَحْيَى أَخْبَرَنَا،", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7340", "narrator_chain": ""}
{"hadithnumber": "7341", "arabic": "وحَدَّثَنِي  ابْنُ الْمُثَنَّى ،  وَابْنُ بَشَّارٍ ، قَالَا: حَدَّثَنَا  مُحَمَّدُ بْنُ جَعْفَرٍ ، ح", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7341", "narrator_chain": ""}
{"hadithnumber": "7342", "arabic": "حَدَّثَنِي  زُهَيْرُ بْنُ حَرْبٍ ،  وَإِسْحَاقُ بْنُ مَنْصُورٍ ، قَالَ إِسْحَاقُ أَخْبَرَنَا، وقَالَ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7342", "narrator_chain": ""}
{"hadithnumber": "7343", "arabic": "حَدَّثَنَا  مُحَمَّدُ بْنُ رَافِعٍ ، حَدَّثَنَا  عَبْدُ الرَّزَّاقِ ، أَخْبَرَنَا  مَعْمَرٌ ، عَنْ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7343", "narrator_chain": ""}
{"hadithnumber": "7354", "arabic": "حَدَّثَنِي  حَرْمَلَةُ بْنُ يَحْيَى بْنِ عَبْدِ اللَّهِ بْنِ حَرْمَلَةَ بْنِ عِمْرَانَ التُّجِيبِيُّ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7354", "narrator_chain": ""}
{"hadithnumber": "7355", "arabic": "وَقَالَ سَالِمُ بْنُ عَبْدِ اللَّهِ: سَمِعْتُ عَبْدَ اللَّهِ بْنَ عُمَرَ، يَقُولُ: انْطَلَقَ بَعْدَ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7355", "narrator_chain": ""}
{"hadithnumber": "7368", "arabic": "حَدَّثَنَا  عُبَيْدُ اللَّهِ بْنُ مُعَاذٍ ، حَدَّثَنَا  أَبِي ، حَدَّثَنَا  شُعْبَةُ . ح وحَدَّثَنَا", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7368", "narrator_chain": ""}
{"hadithnumber": "7369", "arabic": "وَحَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا غُنْدَرٌ، عَنْ شُعْبَةَ، ح وَحَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، وَابْنُ، بَشَّارٍ قَالاَ حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، حَدَّثَنَا شُعْبَةُ، عَنْ مَنْصُورٍ، عَنْ رِبْعِيِّ بْنِ حِرَاشٍ، أَنَّهُ سَمِعَ عَلِيًّا، - رضى الله عنه - يَخْطُبُ قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ لاَ تَكْذِبُوا عَلَىَّ فَإِنَّهُ مَنْ يَكْذِبْ عَلَىَّ يَلِجِ النَّارَ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abū Bakr ibn Abī Shaybah narrated to us that Ghundar narrated to us, on authority of Shu’bah; and Muhammad bin ul-Muthannā and Ibn Bashār both narrated to us, they said:"}
{"hadithnumber": "7370", "arabic": "وَحَدَّثَنِي زُهَيْرُ بْنُ حَرْبٍ، حَدَّثَنَا إِسْمَاعِيلُ، - يَعْنِي ابْنَ عُلَيَّةَ - عَنْ عَبْدِ الْعَزِيزِ بْنِ صُهَيْبٍ، عَنْ أَنَسِ بْنِ مَالِكٍ، أَنَّهُ قَالَ إِنَّهُ لَيَمْنَعُنِي أَنْ أُحَدِّثَكُمْ حَدِيثًا كَثِيرًا أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ مَنْ تَعَمَّدَ عَلَىَّ كَذِبًا فَلْيَتَبَوَّأْ مَقْعَدَهُ مِنَ النَّارِ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Zuhayr bin Harb narrated to me, Ismā’īl, rather, Ibn Ulayyah narrated to us, on authority of Abd il-Azīz ibn Suhayb, on authority of Anas bin Mālik, that he said:"}
{"hadithnumber": "7371", "arabic": "وَحَدَّثَنَا مُحَمَّدُ بْنُ عُبَيْدٍ الْغُبَرِيُّ، حَدَّثَنَا أَبُو عَوَانَةَ، عَنْ أَبِي حَصِينٍ، عَنْ أَبِي صَالِحٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنْ كَذَبَ عَلَىَّ مُتَعَمِّدًا فَلْيَتَبَوَّأْ مَقْعَدَهُ مِنَ النَّارِ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Muhammad bin Ubayd il-Ghubarī narrated to us, Abū Awānah narrated to us, on authority of Abī Hasīn, on authority of Abī Sālih, on authority of Abū Hurayrah, he said, the Messenger of Allah, peace and blessings of Allah upon him, said:"}
{"hadithnumber": "7372", "arabic": "وَحَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا أَبِي، حَدَّثَنَا سَعِيدُ بْنُ عُبَيْدٍ، حَدَّثَنَا عَلِيُّ بْنُ رَبِيعَةَ، قَالَ أَتَيْتُ الْمَسْجِدَ وَالْمُغِيرَةُ أَمِيرُ الْكُوفَةِ قَالَ فَقَالَ الْمُغِيرَةُ سَمِعْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم يَقُولُ ‏ ‏ إِنَّ كَذِبًا عَلَىَّ لَيْسَ كَكَذِبٍ عَلَى أَحَدٍ فَمَنْ كَذَبَ عَلَىَّ مُتَعَمِّدًا فَلْيَتَبَوَّأْ مَقْعَدَهُ مِنَ النَّارِ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Muhammad bin Abd Allah ibn Numayr narrated to us, my father narrated to us, Sa’īd bin Ubayd narrated to us, Alī bin Rabī’ah narrated to us, he said:"}
{"hadithnumber": "7373", "arabic": "وَحَدَّثَنِي عَلِيُّ بْنُ حُجْرٍ السَّعْدِيُّ، حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ، أَخْبَرَنَا مُحَمَّدُ بْنُ قَيْسٍ الأَسَدِيُّ، عَنْ عَلِيِّ بْنِ رَبِيعَةَ الأَسَدِيِّ، عَنِ الْمُغِيرَةِ بْنِ شُعْبَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم بِمِثْلِهِ وَلَمْ يَذْكُرْ ‏ ‏ إِنَّ كَذِبًا عَلَىَّ لَيْسَ كَكَذِبٍ عَلَى أَحَدٍ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "7374", "arabic": "وَحَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ مُعَاذٍ الْعَنْبَرِيُّ، حَدَّثَنَا أَبِي ح، وَحَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، قَالاَ حَدَّثَنَا شُعْبَةُ، عَنْ خُبَيْبِ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ حَفْصِ بْنِ عَاصِمٍ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ كَفَى بِالْمَرْءِ كَذِبًا أَنْ يُحَدِّثَ بِكُلِّ مَا سَمِعَ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Ubayd Allah bin Mu’ādh al-Anbarī narrated to us, my father narrated to us; and Muhammad bin ul-Muthannā narrated to us, Abd ur-Rahman bin Mahdī both narrated to us:"}
{"hadithnumber": "7375", "arabic": "وَحَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَلِيُّ بْنُ حَفْصٍ، حَدَّثَنَا شُعْبَةُ، عَنْ خُبَيْبِ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ حَفْصِ بْنِ عَاصِمٍ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم بِمِثْلِ ذَلِكَ ‏.‏", "grades": "", "reference": "", "international_number": "7375", "narrator_chain": ""}
{"hadithnumber": "7376", "arabic": "وَحَدَّثَنَا يَحْيَى بْنُ يَحْيَى، أَخْبَرَنَا هُشَيْمٌ، عَنْ سُلَيْمَانَ التَّيْمِيِّ، عَنْ أَبِي عُثْمَانَ النَّهْدِيِّ، قَالَ قَالَ عُمَرُ بْنُ الْخَطَّابِ رضى الله تعالى عنه بِحَسْبِ الْمَرْءِ مِنَ الْكَذِبِ أَنْ يُحَدِّثَ بِكُلِّ مَا سَمِعَ ‏.‏", "grades": "", "reference": "", "international_number": "7376", "narrator_chain": "Yahyā bin Yahyā narrated to us, Hushaym informed us, on authority of Sulaymān at-Taymī, on authority of Abī Uthmān an-Nahdī, he said, Umar bin ul-Khattāb, may Allah be pleased with him, said:"}
{"hadithnumber": "7377", "arabic": "وَحَدَّثَنِي أَبُو الطَّاهِرِ، أَحْمَدُ بْنُ عَمْرِو بْنِ عَبْدِ اللَّهِ بْنِ عَمْرِو بْنِ سَرْحٍ قَالَ أَخْبَرَنَا ابْنُ وَهْبٍ، قَالَ قَالَ لِي مَالِكٌ اعْلَمْ أَنَّهُ لَيْسَ يَسْلَمُ رَجُلٌ حَدَّثَ بِكُلِّ مَا سَمِعَ وَلاَ يَكُونُ إِمَامًا أَبَدًا وَهُوَ يُحَدِّثُ بِكُلِّ مَا سَمِعَ ‏.‏", "grades": "", "reference": "", "international_number": "7377", "narrator_chain": "Abūt-Tāhir Ahmad bin Amr bin Sarh narrated to me, he said, Ibn Wahb narrated to us, he said, Mālik said to me:"}
{"hadithnumber": "7378", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، قَالَ حَدَّثَنَا عَبْدُ الرَّحْمَنِ، قَالَ حَدَّثَنَا سُفْيَانُ، عَنْ أَبِي إِسْحَاقَ، عَنْ أَبِي الأَحْوَصِ، عَنْ عَبْدِ اللَّهِ، قَالَ بِحَسْبِ الْمَرْءِ مِنَ الْكَذِبِ أَنْ يُحَدِّثَ بِكُلِّ مَا سَمِعَ ‏.‏", "grades": "", "reference": "", "international_number": "7378", "narrator_chain": "Muhammad bin ul-Muthannā narrated to us, he said Abd ur-Rahman narrated to us, he said Sufyān narrated to us, on authority of Abī Ishāq, on authority of Abīl-Ahwas, on authority of Abd Illah, he said:"}
{"hadithnumber": "7379", "arabic": "وَحَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، قَالَ سَمِعْتُ عَبْدَ الرَّحْمَنِ بْنَ مَهْدِيٍّ، يَقُولُ لاَ يَكُونُ الرَّجُلُ إِمَامًا يُقْتَدَى بِهِ حَتَّى يُمْسِكَ عَنْ بَعْضِ مَا سَمِعَ ‏.‏", "grades": "", "reference": "", "international_number": "7379", "narrator_chain": "Muhammad bin ul-Muthannā narrated to us, he said I heard Abd ar-Rahman bin Mahdī saying:"}
{"hadithnumber": "7380", "arabic": "وَحَدَّثَنَا يَحْيَى بْنُ يَحْيَى، أَخْبَرَنَا عُمَرُ بْنُ عَلِيِّ بْنِ مُقَدَّمٍ، عَنْ سُفْيَانَ بْنِ حُسَيْنٍ، قَالَ سَأَلَنِي إِيَاسُ بْنُ مُعَاوِيَةَ فَقَالَ إِنِّي أَرَاكَ قَدْ كَلِفْتَ بِعِلْمِ الْقُرْآنِ فَاقْرَأْ عَلَىَّ سُورَةً وَفَسِّرْ حَتَّى أَنْظُرَ فِيمَا عَلِمْتَ ‏.‏ قَالَ فَفَعَلْتُ ‏.‏ فَقَالَ لِيَ احْفَظْ عَلَىَّ مَا أَقُولُ لَكَ إِيَّاكَ وَالشَّنَاعَةَ فِي الْحَدِيثِ فَإِنَّهُ قَلَّمَا حَمَلَهَا أَحَدٌ إِلاَّ ذَلَّ فِي نَفْسِهِ وَكُذِّبَ فِي حَدِيثِهِ ‏.‏", "grades": "", "reference": "", "international_number": "7380", "narrator_chain": "Yahyā bin Yahyā narrated to us, Umar bin Alī bin Muqaddam informed us, on authority of Sufyān bin Husayn, he said:"}
{"hadithnumber": "7381", "arabic": "وَحَدَّثَنِي أَبُو الطَّاهِرِ، وَحَرْمَلَةُ بْنُ يَحْيَى، قَالاَ أَخْبَرَنَا ابْنُ وَهْبٍ، قَالَ أَخْبَرَنِي يُونُسُ، عَنِ ابْنِ شِهَابٍ، عَنْ عُبَيْدِ اللَّهِ بْنِ عَبْدِ اللَّهِ بْنِ عُتْبَةَ، أَنَّ عَبْدَ اللَّهِ بْنَ مَسْعُودٍ، قَالَ مَا أَنْتَ بِمُحَدِّثٍ قَوْمًا حَدِيثًا لاَ تَبْلُغُهُ عُقُولُهُمْ إِلاَّ كَانَ لِبَعْضِهِمْ فِتْنَةً ‏.‏", "grades": "", "reference": "", "international_number": "7381", "narrator_chain": "Abūt-Tāhir and Harmalah bin Yahyā narrated to me, they said Ibn Wahb narrated to us, he said Yūnus informed me, on authority of Ibn Shihāb, on authority of Ubayd Allah bin Abd Allah bin Utbah, that Abd Allah bin Mas’ūd said:"}
{"hadithnumber": "7382", "arabic": "وَحَدَّثَنِي مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، وَزُهَيْرُ بْنُ حَرْبٍ، قَالاَ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ يَزِيدَ، قَالَ حَدَّثَنِي سَعِيدُ بْنُ أَبِي أَيُّوبَ، قَالَ حَدَّثَنِي أَبُو هَانِئٍ، عَنْ أَبِي عُثْمَانَ، مُسْلِمِ بْنِ يَسَارٍ عَنْ أَبِي هُرَيْرَةَ، عَنْ رَسُولِ اللَّهِ صلى الله عليه وسلم أَنَّهُ قَالَ ‏ ‏ سَيَكُونُ فِي آخِرِ أُمَّتِي أُنَاسٌ يُحَدِّثُونَكُمْ مَا لَمْ تَسْمَعُوا أَنْتُمْ وَلاَ آبَاؤُكُمْ فَإِيَّاكُمْ وَإِيَّاهُمْ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Muhammad bin Abd Allah bin Numayr and Zuhayr bin Harb narrated to me, they said Abd Allah bin Yazīd narrated to us, he said Sa’īd bin Abī Ayyūb narrated to me, he said Abū Hāni’ narrated to me, on authority of Uthmān Muslim bin Yasār, on authority of Abī Hurayrah, on authority of the Messenger of Allah, peace and blessings of Allah upon him, he said:"}
{"hadithnumber": "7383", "arabic": "وَحَدَّثَنِي حَرْمَلَةُ بْنُ يَحْيَى بْنِ عَبْدِ اللَّهِ بْنِ حَرْمَلَةَ بْنِ عِمْرَانَ التُّجِيبِيُّ، قَالَ حَدَّثَنَا ابْنُ وَهْبٍ، قَالَ حَدَّثَنِي أَبُو شُرَيْحٍ، أَنَّهُ سَمِعَ شَرَاحِيلَ بْنَ يَزِيدَ، يَقُولُ أَخْبَرَنِي مُسْلِمُ بْنُ يَسَارٍ، أَنَّهُ سَمِعَ أَبَا هُرَيْرَةَ، يَقُولُ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ يَكُونُ فِي آخِرِ الزَّمَانِ دَجَّالُونَ كَذَّابُونَ يَأْتُونَكُمْ مِنَ الأَحَادِيثِ بِمَا لَمْ تَسْمَعُوا أَنْتُمْ وَلاَ آبَاؤُكُمْ فَإِيَّاكُمْ وَإِيَّاهُمْ لاَ يُضِلُّونَكُمْ وَلاَ يَفْتِنُونَكُمْ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Harmalah bin Yahyā bin Abd Allah bin Harmalah bin Imrān at-Tujībī narrated to me, he said Ibn Wahb narrated to us, he said Abū Shurayh narrated to me that he heard Sharāhīl bin Yazīd saying ‘Muslim bin Yasār informed me that he heard Abā Hurayrah saying, the Messenger of Allah, peace and blessings of Allah upon him, said:"}
{"hadithnumber": "7384", "arabic": "وَحَدَّثَنِي أَبُو سَعِيدٍ الأَشَجُّ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا الأَعْمَشُ، عَنِ الْمُسَيَّبِ بْنِ رَافِعٍ، عَنْ عَامِرِ بْنِ عَبَدَةَ، قَالَ قَالَ عَبْدُ اللَّهِ إِنَّ الشَّيْطَانَ لَيَتَمَثَّلُ فِي صُورَةِ الرَّجُلِ فَيَأْتِي الْقَوْمَ فَيُحَدِّثُهُمْ بِالْحَدِيثِ مِنَ الْكَذِبِ فَيَتَفَرَّقُونَ فَيَقُولُ الرَّجُلُ مِنْهُمْ سَمِعْتُ رَجُلاً أَعْرِفُ وَجْهَهُ وَلاَ أَدْرِي مَا اسْمُهُ يُحَدِّثُ ‏.‏", "grades": "", "reference": "", "international_number": "7384", "narrator_chain": "Abū Sa’īd al-Ashajj narrated to me, Wakī’ narrated to us, al-A’mash narrated to us, on authority of al-Musayyab bin Rāfi’, on authority of Āmir bin Abdah, he said, Abd Allah  said:"}
{"hadithnumber": "7385", "arabic": "وَحَدَّثَنِي مُحَمَّدُ بْنُ رَافِعٍ، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَخْبَرَنَا مَعْمَرٌ، عَنِ ابْنِ طَاوُسٍ، عَنْ أَبِيهِ، عَنْ عَبْدِ اللَّهِ بْنِ عَمْرِو بْنِ الْعَاصِ، قَالَ إِنَّ فِي الْبَحْرِ شَيَاطِينَ مَسْجُونَةً أَوْثَقَهَا سُلَيْمَانُ يُوشِكُ أَنْ تَخْرُجَ فَتَقْرَأَ عَلَى النَّاسِ قُرْآنًا ‏.‏", "grades": "", "reference": "", "international_number": "7385", "narrator_chain": "Muhammad bin Rāfi’ narrated to me, Abd ur-Razzāq narrated to us, Ma’mar informed us, on authority of Ibn Tāwus, on authority of his father, on authority Abd Allah bin Amr bin al-Ās, he said:"}
{"hadithnumber": "7386", "arabic": "وَحَدَّثَنِي مُحَمَّدُ بْنُ عَبَّادٍ، وَسَعِيدُ بْنُ عَمْرٍو الأَشْعَثِيُّ، جَمِيعًا عَنِ ابْنِ عُيَيْنَةَ، - قَالَ سَعِيدٌ أَخْبَرَنَا سُفْيَانُ، - عَنْ هِشَامِ بْنِ حُجَيْرٍ، عَنْ طَاوُسٍ، قَالَ جَاءَ هَذَا إِلَى ابْنِ عَبَّاسٍ - يَعْنِي بُشَيْرَ بْنَ كَعْبٍ - فَجَعَلَ يُحَدِّثُهُ فَقَالَ لَهُ ابْنُ عَبَّاسٍ عُدْ لِحَدِيثِ كَذَا وَكَذَا ‏.‏ فَعَادَ لَهُ ثُمَّ حَدَّثَهُ فَقَالَ لَهُ عُدْ لِحَدِيثِ كَذَا وَكَذَا ‏.‏ فَعَادَ لَهُ فَقَالَ لَهُ مَا أَدْرِي أَعَرَفْتَ حَدِيثِي كُلَّهُ وَأَنْكَرْتَ هَذَا أَمْ أَنْكَرْتَ حَدِيثِي كُلَّهُ وَعَرَفْتَ هَذَا فَقَالَ لَهُ ابْنُ عَبَّاسٍ إِنَّا كُنَّا نُحَدِّثُ عَنْ رَسُولِ اللَّهِ صلى الله عليه وسلم إِذْ لَمْ يَكُنْ يُكْذَبُ عَلَيْهِ فَلَمَّا رَكِبَ النَّاسُ الصَّعْبَ وَالذَّلُولَ تَرَكْنَا الْحَدِيثَ عَنْهُ ‏.‏", "grades": "", "reference": "", "international_number": "7386", "narrator_chain": "Muhammad bin Abbād and Sa’īd bin Amr al-Ash’athī narrated to me on authority of Ibn Uyaynah; Sa’īd said Sufyān informed us on authority of Hishām bin Hujayr, on authority of Tāwus, he said (Bushayr bin Ka’b) came to Ibn Abbās so he set about narrating to him. Ibn Abbās said to him:"}
{"hadithnumber": "7387", "arabic": "وَحَدَّثَنِي مُحَمَّدُ بْنُ رَافِعٍ، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَخْبَرَنَا مَعْمَرٌ، عَنِ ابْنِ طَاوُسٍ، عَنْ أَبِيهِ، عَنِ ابْنِ عَبَّاسٍ، قَالَ إِنَّمَا كُنَّا نَحْفَظُ الْحَدِيثَ وَالْحَدِيثُ يُحْفَظُ عَنْ رَسُولِ اللَّهِ صلى الله عليه وسلم فَأَمَّا إِذْ رَكِبْتُمْ كُلَّ صَعْبٍ وَذَلُولٍ فَهَيْهَاتَ ‏.‏", "grades": "", "reference": "", "international_number": "7387", "narrator_chain": "Muhammad bin Rāfi’ narrated to me, Abd ur-Razzāq narrated to us, Ma’mar informed us, on authority of Ibn Tāwus, on authority of his father, on authority of Ibn Abbās, he said:"}
{"hadithnumber": "7388", "arabic": "وَحَدَّثَنِي أَبُو أَيُّوبَ، سُلَيْمَانُ بْنُ عُبَيْدِ اللَّهِ الْغَيْلاَنِيُّ حَدَّثَنَا أَبُو عَامِرٍ، - يَعْنِي الْعَقَدِيَّ - حَدَّثَنَا رَبَاحٌ، عَنْ قَيْسِ بْنِ سَعْدٍ، عَنْ مُجَاهِدٍ، قَالَ جَاءَ بُشَيْرٌ الْعَدَوِيُّ إِلَى ابْنِ عَبَّاسٍ فَجَعَلَ يُحَدِّثُ وَيَقُولُ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم فَجَعَلَ ابْنُ عَبَّاسٍ لاَ يَأْذَنُ لِحَدِيثِهِ وَلاَ يَنْظُرُ إِلَيْهِ فَقَالَ يَا ابْنَ عَبَّاسٍ مَا لِي لاَ أَرَاكَ تَسْمَعُ لِحَدِيثِي أُحَدِّثُكَ عَنْ رَسُولِ اللَّهِ صلى الله عليه وسلم وَلاَ تَسْمَعُ ‏.‏ فَقَالَ ابْنُ عَبَّاسٍ إِنَّا كُنَّا مَرَّةً إِذَا سَمِعْنَا رَجُلاً يَقُولُ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ابْتَدَرَتْهُ أَبْصَارُنَا وَأَصْغَيْنَا إِلَيْهِ بِآذَانِنَا فَلَمَّا رَكِبَ النَّاسُ الصَّعْبَ وَالذَّلُولَ لَمْ نَأْخُذْ مِنَ النَّاسِ إِلاَّ مَا نَعْرِفُ ‏.‏", "grades": "", "reference": "", "international_number": "7388", "narrator_chain": "Abū Ayyūb Sulaymān bin Ubayd Allah al-Ghaylānī narrated to us, Abū Āmir, meaning al-Aqadī, narrated to us, Rabāh narrated to us, on authority of Qays bin Sa’d, on authority of Mujāhid, he said Bushayr ul-Adawī came to Ibn Abbās then he set about narrating to him, saying:"}
{"hadithnumber": "7389", "arabic": "حَدَّثَنَا دَاوُدُ بْنُ عَمْرٍو الضَّبِّيُّ، حَدَّثَنَا نَافِعُ بْنُ عُمَرَ، عَنِ ابْنِ أَبِي مُلَيْكَةَ، قَالَ كَتَبْتُ إِلَى ابْنِ عَبَّاسٍ أَسْأَلُهُ أَنْ يَكْتُبَ، لِي كِتَابًا وَيُخْفِي عَنِّي ‏.‏ فَقَالَ وَلَدٌ نَاصِحٌ أَنَا أَخْتَارُ لَهُ الأُمُورَ اخْتِيَارًا وَأُخْفِي عَنْهُ ‏.‏ قَالَ فَدَعَا بِقَضَاءِ عَلِيٍّ فَجَعَلَ يَكْتُبُ مِنْهُ أَشْيَاءَ وَيَمُرُّ بِهِ الشَّىْءُ فَيَقُولُ وَاللَّهِ مَا قَضَى بِهَذَا عَلِيٌّ إِلاَّ أَنْ يَكُونَ ضَلَّ ‏.‏", "grades": "", "reference": "", "international_number": "7389", "narrator_chain": "Dāwud bin Amr aḍ-Ḍabbī narrated to us, Nāfi’ bin Umar narrated to us, on authority of Ibn Abī Mulaykah, he said:"}
{"hadithnumber": "7390", "arabic": "حَدَّثَنَا عَمْرٌو النَّاقِدُ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ هِشَامِ بْنِ حُجَيْرٍ، عَنْ طَاوُسٍ، قَالَ أُتِيَ ابْنُ عَبَّاسٍ بِكِتَابٍ فِيهِ قَضَاءُ عَلِيٍّ - رضى الله عنه - فَمَحَاهُ إِلاَّ قَدْرَ ‏.‏ وَأَشَارَ سُفْيَانُ بْنُ عُيَيْنَةَ بِذِرَاعِهِ ‏.‏", "grades": "", "reference": "", "international_number": "7390", "narrator_chain": "Amr an-Nāqid narrated to us, Sufyān bin Uyaynah narrated to us, on authority of Hishām bin Hujayr, on authority of Tāwus, he said:"}
{"hadithnumber": "7391", "arabic": "حَدَّثَنَا حَسَنُ بْنُ عَلِيٍّ الْحُلْوَانِيُّ، حَدَّثَنَا يَحْيَى بْنُ آدَمَ، حَدَّثَنَا ابْنُ إِدْرِيسَ، عَنِ الأَعْمَشِ، عَنْ أَبِي إِسْحَاقَ، قَالَ لَمَّا أَحْدَثُوا تِلْكَ الأَشْيَاءَ بَعْدَ عَلِيٍّ - رضى الله عنه - قَالَ رَجُلٌ مِنْ أَصْحَابِ عَلِيٍّ قَاتَلَهُمُ اللَّهُ أَىَّ عِلْمٍ أَفْسَدُوا ‏.‏", "grades": "", "reference": "", "international_number": "7391", "narrator_chain": "Hasan bin Alī al-Hulwānī narrated to us, Yahyā bin Ādam narrated to us, Ibn Idrīs narrated to us, on authority of al-A’mash, on authority of Abī Ishāq who said:"}
{"hadithnumber": "7392", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ خَشْرَمٍ، أَخْبَرَنَا أَبُو بَكْرٍ، - يَعْنِي ابْنَ عَيَّاشٍ - قَالَ سَمِعْتُ الْمُغِيرَةَ، يَقُولُ لَمْ يَكُنْ يَصْدُقُ عَلَى عَلِيٍّ - رضى الله عنه - فِي الْحَدِيثِ عَنْهُ إِلاَّ مِنْ أَصْحَابِ عَبْدِ اللَّهِ بْنِ مَسْعُودٍ ‏.‏", "grades": "", "reference": "", "international_number": "7392", "narrator_chain": "Alī bin Khashram narrated to us, Abū Bakr, meaning Ibn Ayyāsh, informed us, he said ‘I heard al-Mughīrah saying:"}
{"hadithnumber": "7393", "arabic": "حَدَّثَنَا حَسَنُ بْنُ الرَّبِيعِ، حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ، عَنْ أَيُّوبَ، وَهِشَامٍ، عَنْ مُحَمَّدٍ، وَحَدَّثَنَا فُضَيْلٌ، عَنْ هِشَامٍ، قَالَ وَحَدَّثَنَا مَخْلَدُ بْنُ حُسَيْنٍ، عَنْ هِشَامٍ، عَنْ مُحَمَّدِ بْنِ سِيرِينَ، قَالَ إِنَّ هَذَا الْعِلْمَ دِينٌ فَانْظُرُوا عَمَّنْ تَأْخُذُونَ دِينَكُمْ ‏.‏", "grades": "", "reference": "", "international_number": "7393", "narrator_chain": "Hasan bin ur-Rabī’ narrated to us, Hammād bin Zayd narrated to us, on authority of Ayyūb and Hishām , on authority of Muhammad bin Sīrīn , that he said:"}
{"hadithnumber": "7394", "arabic": "حَدَّثَنَا أَبُو جَعْفَرٍ، مُحَمَّدُ بْنُ الصَّبَّاحِ حَدَّثَنَا إِسْمَاعِيلُ بْنُ زَكَرِيَّاءَ، عَنْ عَاصِمٍ الأَحْوَلِ، عَنِ ابْنِ سِيرِينَ، قَالَ لَمْ يَكُونُوا يَسْأَلُونَ عَنِ الإِسْنَادِ، فَلَمَّا وَقَعَتِ الْفِتْنَةُ قَالُوا سَمُّوا لَنَا رِجَالَكُمْ فَيُنْظَرُ إِلَى أَهْلِ السُّنَّةِ فَيُؤْخَذُ حَدِيثُهُمْ وَيُنْظَرُ إِلَى أَهْلِ الْبِدَعِ فَلاَ يُؤْخَذُ حَدِيثُهُمْ ‏.‏", "grades": "", "reference": "", "international_number": "7394", "narrator_chain": "Abū Ja’far Muhammad bin us-Sabbāh narrated to us, Ismā’īl bin Zakariyyā’ narrated to us, on authority of Āsim il-Ahwal, on authority of Ibn Sīrīn that he said:"}
{"hadithnumber": "7395", "arabic": "حَدَّثَنَا إِسْحَاقُ بْنُ إِبْرَاهِيمَ الْحَنْظَلِيُّ، أَخْبَرَنَا عِيسَى، - وَهُوَ ابْنُ يُونُسَ - حَدَّثَنَا الأَوْزَاعِيُّ، عَنْ سُلَيْمَانَ بْنِ مُوسَى، قَالَ لَقِيتُ طَاوُسًا فَقُلْتُ حَدَّثَنِي فُلاَنٌ، كَيْتَ وَكَيْتَ ‏.‏ قَالَ إِنْ كَانَ صَاحِبُكَ مَلِيًّا فَخُذْ عَنْهُ ‏.‏", "grades": "", "reference": "", "international_number": "7395", "narrator_chain": "Ishāq bin Ibrāhīm al-Hanthalī narrated to us, Īsā, and he is Ibn Yūnus, informed us, al-Awzā’ī narrated to us, on authority of Sulyamān bin Mūsā, he said:"}
{"hadithnumber": "7396", "arabic": "وَحَدَّثَنَا عَبْدُ اللَّهِ بْنُ عَبْدِ الرَّحْمَنِ الدَّارِمِيُّ، أَخْبَرَنَا مَرْوَانُ، - يَعْنِي ابْنَ مُحَمَّدٍ الدِّمَشْقِيَّ - حَدَّثَنَا سَعِيدُ بْنُ عَبْدِ الْعَزِيزِ، عَنْ سُلَيْمَانَ بْنِ مُوسَى، قَالَ قُلْتُ لِطَاوُسٍ إِنَّ فُلاَنًا حَدَّثَنِي بِكَذَا، وَكَذَا، ‏.‏ قَالَ إِنْ كَانَ صَاحِبُكَ مَلِيًّا فَخُذْ عَنْهُ ‏.‏", "grades": "", "reference": "", "international_number": "7396", "narrator_chain": "Abd Allah bin Abd ir-Rahman ad-Dārimī narrated to us, Marwān, meaning Ibn Muhammad ad-Dimashqī informed us, Sa’īd bin Abd il-Azīz narrated to us, on authority of Sulaymān bin Mūsā, he said, I said to Tāwus:"}
{"hadithnumber": "7397", "arabic": "حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ، حَدَّثَنَا الأَصْمَعِيُّ، عَنِ ابْنِ أَبِي الزِّنَادِ، عَنْ أَبِيهِ، قَالَ أَدْرَكْتُ بِالْمَدِينَةِ مِائَةً كُلُّهُمْ مَأْمُونٌ ‏.‏ مَا يُؤْخَذُ عَنْهُمُ الْحَدِيثُ يُقَالُ لَيْسَ مِنْ أَهْلِهِ ‏.‏", "grades": "", "reference": "", "international_number": "7397", "narrator_chain": "Nasr bin Alī al-Jahdhamī narrated to us, al-Asma’ī narrated to us, on authority of Ibn Abī-Zinād, on authority of his father, he said:"}
{"hadithnumber": "7398", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ أَبِي عُمَرَ الْمَكِّيُّ، حَدَّثَنَا سُفْيَانُ، ح وَحَدَّثَنِي أَبُو بَكْرِ بْنُ خَلاَّدٍ الْبَاهِلِيُّ، - وَاللَّفْظُ لَهُ - قَالَ سَمِعْتُ سُفْيَانَ بْنَ عُيَيْنَةَ، عَنْ مِسْعَرٍ، قَالَ سَمِعْتُ سَعْدَ بْنَ إِبْرَاهِيمَ، يَقُولُ لاَ يُحَدِّثُ عَنْ رَسُولِ اللَّهِ صلى الله عليه وسلم إِلاَّ الثِّقَاتُ ‏.‏", "grades": "", "reference": "", "international_number": "7398", "narrator_chain": "Muhammad bin Abī Umar al-Makkī narrated to us, Sufyān narrated to us; and Abū Bakr bin Khallād al-Bāhilī narrated to us – and the wording is his, he said, I heard Sufyān bin Uyaynah, on authority of Mis’ar, he said, I heard Sa’d bin Ibrāhīm saying:"}
{"hadithnumber": "7399", "arabic": "وَحَدَّثَنِي مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ قُهْزَاذَ، - مِنْ أَهْلِ مَرْوَ - قَالَ سَمِعْتُ عَبْدَانَ بْنَ عُثْمَانَ، يَقُولُ سَمِعْتُ عَبْدَ اللَّهِ بْنَ الْمُبَارَكِ، يَقُولُ الإِسْنَادُ مِنَ الدِّينِ وَلَوْلاَ الإِسْنَادُ لَقَالَ مَنْ شَاءَ مَا شَاءَ ‏.‏ وَقَالَ مُحَمَّدُ بْنُ عَبْدِ اللَّهِ حَدَّثَنِي الْعَبَّاسُ بْنُ أَبِي رِزْمَةَ، قَالَ سَمِعْتُ عَبْدَ اللَّهِ، يَقُولُ بَيْنَنَا وَبَيْنَ الْقَوْمِ الْقَوَائِمُ ‏.‏ يَعْنِي الإِسْنَادَ ‏.‏ وَقَالَ مُحَمَّدٌ سَمِعْتُ أَبَا إِسْحَاقَ، إِبْرَاهِيمَ بْنَ عِيسَى الطَّالَقَانِيَّ قَالَ قُلْتُ لِعَبْدِ اللَّهِ بْنِ الْمُبَارَكِ يَا أَبَا عَبْدِ الرَّحْمَنِ الْحَدِيثُ الَّذِي جَاءَ ‏ ‏ إِنَّ مِنَ الْبِرِّ بَعْدَ الْبِرِّ أَنْ تُصَلِّيَ لأَبَوَيْكَ مَعَ صَلاَتِكَ وَتَصُومَ لَهُمَا مَعَ صَوْمِكَ ‏\"\"‏ ‏.‏ قَالَ فَقَالَ عَبْدُ اللَّهِ يَا أَبَا إِسْحَاقَ عَمَّنْ هَذَا قَالَ قُلْتُ لَهُ هَذَا مِنْ حَدِيثِ شِهَابِ بْنِ خِرَاشٍ ‏.‏ فَقَالَ ثِقَةٌ عَمَّنْ قَالَ قُلْتُ عَنِ الْحَجَّاجِ بْنِ دِينَارٍ ‏.‏ قَالَ ثِقَةٌ عَمَّنْ قَالَ قُلْتُ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏.‏ قَالَ يَا أَبَا إِسْحَاقَ إِنَّ بَيْنَ الْحَجَّاجِ بْنِ دِينَارٍ وَبَيْنَ النَّبِيِّ صلى الله عليه وسلم مَفَاوِزَ تَنْقَطِعُ فِيهَا أَعْنَاقُ الْمَطِيِّ وَلَكِنْ لَيْسَ فِي الصَّدَقَةِ اخْتِلاَفٌ ‏.‏ وَقَالَ مُحَمَّدٌ سَمِعْتُ عَلِيَّ بْنَ شَقِيقٍ، يَقُولُ سَمِعْتُ عَبْدَ اللَّهِ بْنَ الْمُبَارَكِ، يَقُولُ عَلَى رُءُوسِ النَّاسِ دَعُوا حَدِيثَ عَمْرِو بْنِ ثَابِتٍ فَإِنَّهُ كَانَ يَسُبُّ السَّلَفَ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Muhammad bin Abd Allah bin Quhzādh from the people of Marw narrated to us, he said I heard Abdān bin Uthmān saying, I heard Abd Allah bin al-Mubārak saying:"}
{"hadithnumber": "7400", "arabic": "وَحَدَّثَنِي أَبُو بَكْرِ بْنُ النَّضْرِ بْنِ أَبِي النَّضْرِ، قَالَ حَدَّثَنِي أَبُو النَّضْرِ، هَاشِمُ بْنُ الْقَاسِمِ حَدَّثَنَا أَبُو عَقِيلٍ، صَاحِبُ بُهَيَّةَ قَالَ كُنْتُ جَالِسًا عِنْدَ الْقَاسِمِ بْنِ عُبَيْدِ اللَّهِ وَيَحْيَى بْنِ سَعِيدٍ فَقَالَ يَحْيَى لِلْقَاسِمِ يَا أَبَا مُحَمَّدٍ إِنَّهُ قَبِيحٌ عَلَى مِثْلِكَ عَظِيمٌ أَنْ تُسْأَلَ عَنْ شَىْءٍ مِنْ أَمْرِ هَذَا الدِّينِ فَلاَ يُوجَدَ عِنْدَكَ مِنْهُ عِلْمٌ وَلاَ فَرَجٌ - أَوْ عِلْمٌ وَلاَ مَخْرَجٌ - فَقَالَ لَهُ الْقَاسِمُ وَعَمَّ ذَاكَ قَالَ لأَنَّكَ ابْنُ إِمَامَىْ هُدًى ابْنُ أَبِي بَكْرٍ وَعُمَرَ ‏.‏ قَالَ يَقُولُ لَهُ الْقَاسِمُ أَقْبَحُ مِنْ ذَاكَ عِنْدَ مَنْ عَقَلَ عَنِ اللَّهِ أَنْ أَقُولَ بِغَيْرِ عِلْمٍ أَوْ آخُذَ عَنْ غَيْرِ ثِقَةٍ ‏.‏ قَالَ فَسَكَتَ فَمَا أَجَابَهُ ‏.‏", "grades": "", "reference": "", "international_number": "7400", "narrator_chain": "Abū Bakr ibn in-Naḍr bin Abīn-Naḍr narrated to me, he said Abūn-Naḍr Hāshim bin ul-Qāsim narrated to me, Abū Aqīl, companion of Buhayyah, narrated to us, he said:"}
{"hadithnumber": "7401", "arabic": "وَحَدَّثَنِي بِشْرُ بْنُ الْحَكَمِ الْعَبْدِيُّ، قَالَ سَمِعْتُ سُفْيَانَ بْنَ عُيَيْنَةَ، يَقُولُ أَخْبَرُونِي عَنْ أَبِي عَقِيلٍ، صَاحِبِ بُهَيَّةَ أَنَّ أَبْنَاءً، لِعَبْدِ اللَّهِ بْنِ عُمَرَ سَأَلُوهُ عَنْ شَىْءٍ لَمْ يَكُنْ عِنْدَهُ فِيهِ عِلْمٌ فَقَالَ لَهُ يَحْيَى بْنُ سَعِيدٍ وَاللَّهِ إِنِّي لأُعْظِمُ أَنْ يَكُونَ مِثْلُكَ وَأَنْتَ ابْنُ إِمَامَىِ الْهُدَى - يَعْنِي عُمَرَ وَابْنَ عُمَرَ - تُسْأَلُ عَنْ أَمْرٍ لَيْسَ عِنْدَكَ فِيهِ عِلْمٌ ‏.‏ فَقَالَ أَعْظَمُ مِنْ ذَلِكَ وَاللَّهِ عِنْدَ اللَّهِ وَعِنْدَ مَنْ عَقَلَ عَنِ اللَّهِ أَنْ أَقُولَ بِغَيْرِ عِلْمٍ أَوْ أُخْبِرَ عَنْ غَيْرِ ثِقَةٍ ‏.‏ قَالَ وَشَهِدَهُمَا أَبُو عَقِيلٍ يَحْيَى بْنُ الْمُتَوَكِّلِ حِينَ قَالاَ ذَلِكَ ‏.‏", "grades": "", "reference": "", "international_number": "7401", "narrator_chain": "Bishr bin ul-Hakam al-Abdī narrated to me, he said, I heard Sufyān bin Uyaynah saying, they informed me on authority of Abī Aqīl, companion of Buhayyah, that a descendent of Abd Allah bin Umar was asked about something that he did not have knowledge about, so Yahyā bin Sa’īd said to him:"}
{"hadithnumber": "7402", "arabic": "وَحَدَّثَنَا عَمْرُو بْنُ عَلِيٍّ أَبُو حَفْصٍ، قَالَ سَمِعْتُ يَحْيَى بْنَ سَعِيدٍ، قَالَ سَأَلْتُ سُفْيَانَ الثَّوْرِيَّ وَشُعْبَةَ وَمَالِكًا وَابْنَ عُيَيْنَةَ عَنِ الرَّجُلِ لاَ يَكُونُ ثَبْتًا فِي الْحَدِيثِ فَيَأْتِينِي الرَّجُلُ فَيَسْأَلُنِي عَنْهُ ‏.‏ قَالُوا أَخْبِرْ عَنْهُ أَنَّهُ لَيْسَ بِثَبْتٍ ‏.‏", "grades": "", "reference": "", "international_number": "7402", "narrator_chain": "Amr bin Alī Abū Hafs narrated to us, he said I heard Yahyā bin Sa’īd, he said:"}
{"hadithnumber": "7403", "arabic": "وَحَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ سَعِيدٍ، قَالَ سَمِعْتُ النَّضْرَ، يَقُولُ سُئِلَ ابْنُ عَوْنٍ عَنْ حَدِيثٍ، لِشَهْرٍ وَهُوَ قَائِمٌ عَلَى أُسْكُفَّةِ الْبَابِ فَقَالَ إِنَّ شَهْرًا نَزَكُوهُ إِنَّ شَهْرًا نَزَكُوهُ ‏.‏ قَالَ مُسْلِمٌ رَحِمَهُ اللَّهُ يَقُولُ أَخَذَتْهُ أَلْسِنَةُ النَّاسِ تَكَلَّمُوا فِيهِ ‏.‏", "grades": "", "reference": "", "international_number": "7403", "narrator_chain": "Ubayd Allah bin Sa’īd narrated to us, he said, I heard an-Naḍr saying:"}
{"hadithnumber": "7404", "arabic": "وَحَدَّثَنِي حَجَّاجُ بْنُ الشَّاعِرِ، حَدَّثَنَا شَبَابَةُ، قَالَ قَالَ شُعْبَةُ وَقَدْ لَقِيتُ شَهْرًا فَلَمْ أَعْتَدَّ بِهِ ‏.‏", "grades": "", "reference": "", "international_number": "7404", "narrator_chain": "Hajjāj bin ush-Shā’ir narrated to me, Shabābah narrated to us, he said, Shu’bah said:"}
{"hadithnumber": "7405", "arabic": "وَحَدَّثَنِي مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ قُهْزَاذَ، - مِنْ أَهْلِ مَرْوَ - قَالَ أَخْبَرَنِي عَلِيُّ بْنُ حُسَيْنِ بْنِ وَاقِدٍ، قَالَ قَالَ عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ قُلْتُ لِسُفْيَانَ الثَّوْرِيِّ إِنَّ عَبَّادَ بْنَ كَثِيرٍ مَنْ تَعْرِفُ حَالَهُ ‏.‏ وَإِذَا حَدَّثَ جَاءَ، بِأَمْرٍ عَظِيمٍ فَتَرَى أَنْ أَقُولَ، لِلنَّاسِ لاَ تَأْخُذُوا عَنْهُ قَالَ سُفْيَانُ بَلَى ‏.‏ قَالَ عَبْدُ اللَّهِ فَكُنْتُ إِذَا كُنْتُ فِي مَجْلِسٍ ذُكِرَ فِيهِ عَبَّادٌ أَثْنَيْتُ عَلَيْهِ فِي دِينِهِ وَأَقُولُ لاَ تَأْخُذُوا عَنْهُ ‏.‏ وَقَالَ مُحَمَّدٌ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ عُثْمَانَ، قَالَ قَالَ أَبِي قَالَ عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ انْتَهَيْتُ إِلَى شُعْبَةَ فَقَالَ هَذَا عَبَّادُ بْنُ كَثِيرٍ فَاحْذَرُوهُ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Muhammad bin Abd Allah bin Quhzādh, from the people of Marw, narrated to me, he said Alī bin Husayn bin Wāqid informed me, he said Abd Allah bin al-Mubārak said, I said to Sufyān ath-Thawrī:"}
{"hadithnumber": "7406", "arabic": "وَحَدَّثَنِي الْفَضْلُ بْنُ سَهْلٍ، قَالَ سَأَلْتُ مُعَلًّى الرَّازِيَّ عَنْ مُحَمَّدِ بْنِ سَعِيدٍ الَّذِي، رَوَى عَنْهُ، عَبَّادٌ فَأَخْبَرَنِي عَنْ عِيسَى بْنِ يُونُسَ، قَالَ كُنْتُ عَلَى بَابِهِ وَسُفْيَانُ عِنْدَهُ فَلَمَّا خَرَجَ سَأَلْتُهُ عَنْهُ فَأَخْبَرَنِي أَنَّهُ كَذَّابٌ ‏.‏", "grades": "", "reference": "", "international_number": "7406", "narrator_chain": "Al-Faḍl bin Sahl narrated to me, he said, I asked Mu’allā ar-Rāzī about Muhammad bin Sa’īd whom Abbād transmitted from, so he informed me about what Īsā bin Yūnus said:"}
{"hadithnumber": "7407", "arabic": "وَحَدَّثَنِي مُحَمَّدُ بْنُ أَبِي عَتَّابٍ، قَالَ حَدَّثَنِي عَفَّانُ، عَنْ مُحَمَّدِ بْنِ يَحْيَى بْنِ سَعِيدٍ الْقَطَّانِ، عَنْ أَبِيهِ، قَالَ لَمْ نَرَ الصَّالِحِينَ فِي شَىْءٍ أَكْذَبَ مِنْهُمْ فِي الْحَدِيثِ ‏.‏ قَالَ ابْنُ أَبِي عَتَّابٍ فَلَقِيتُ أَنَا مُحَمَّدَ بْنَ يَحْيَى بْنِ سَعِيدٍ الْقَطَّانِ، فَسَأَلْتُهُ عَنْهُ فَقَالَ عَنْ أَبِيهِ، لَمْ تَرَ أَهْلَ الْخَيْرِ فِي شَىْءٍ أَكْذَبَ مِنْهُمْ فِي الْحَدِيثِ ‏.‏ قَالَ مُسْلِمٌ يَقُولُ يَجْرِي الْكَذِبُ عَلَى لِسَانِهِمْ وَلاَ يَتَعَمَّدُونَ الْكَذِبَ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Muhammad bin Abī Attāb narrated to me, he said Affān narrated to me, on authority of Muhammad bin Yahyā bin Sa’īd al-Qattān, on authority of his father, he said:"}
{"hadithnumber": "7408", "arabic": "حَدَّثَنِي الْفَضْلُ بْنُ سَهْلٍ، قَالَ حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، قَالَ أَخْبَرَنِي خَلِيفَةُ بْنُ مُوسَى، قَالَ دَخَلْتُ عَلَى غَالِبِ بْنِ عُبَيْدِ اللَّهِ فَجَعَلَ يُمْلِي عَلَىَّ حَدَّثَنِي مَكْحُولٌ، حَدَّثَنِي مَكْحُولٌ، فَأَخَذَهُ الْبَوْلُ فَقَامَ فَنَظَرْتُ فِي الْكُرَّاسَةِ فَإِذَا فِيهَا حَدَّثَنِي أَبَانٌ عَنْ أَنَسٍ وَأَبَانٌ عَنْ فُلاَنٍ فَتَرَكْتُهُ وَقُمْتُ ‏.‏ قَالَ وَسَمِعْتُ الْحَسَنَ بْنَ عَلِيٍّ الْحُلْوَانِيَّ، يَقُولُ رَأَيْتُ فِي كِتَابِ عَفَّانَ حَدِيثَ هِشَامٍ أَبِي الْمِقْدَامِ حَدِيثُ عُمَرَ بْنِ عَبْدِ الْعَزِيزِ قَالَ هِشَامٌ حَدَّثَنِي رَجُلٌ يُقَالُ لَهُ يَحْيَى بْنُ فُلاَنٍ عَنْ مُحَمَّدِ بْنِ كَعْبٍ قَالَ قُلْتُ لِعَفَّانَ إِنَّهُمْ يَقُولُونَ هِشَامٌ سَمِعَهُ مِنْ مُحَمَّدِ بْنِ كَعْبٍ ‏.‏ فَقَالَ إِنَّمَا ابْتُلِيَ مِنْ قِبَلِ هَذَا الْحَدِيثِ كَانَ يَقُولُ حَدَّثَنِي يَحْيَى عَنْ مُحَمَّدٍ ثُمَّ ادَّعَى بَعْدُ أَنَّهُ سَمِعَهُ مِنْ مُحَمَّدٍ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Al-Faḍl bin Sahl narrated to me, he said Yazīd bin Hārūn narrated to us, he said Khalīfah bin Mūsā informed me, he said:"}
{"hadithnumber": "7409", "arabic": "حَدَّثَنِي مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ قُهْزَاذَ، قَالَ سَمِعْتُ عَبْدَ اللَّهِ بْنَ عُثْمَانَ بْنِ جَبَلَةَ، يَقُولُ قُلْتُ لِعَبْدِ اللَّهِ بْنِ الْمُبَارَكِ مَنْ هَذَا الرَّجُلُ الَّذِي رَوَيْتَ عَنْهُ، حَدِيثَ عَبْدِ اللَّهِ بْنِ عَمْرٍو ‏\"‏ يَوْمُ الْفِطْرِ يَوْمُ الْجَوَائِزِ ‏\"‏ ‏.‏ قَالَ سُلَيْمَانُ بْنُ الْحَجَّاجِ ‏.‏ انْظُرْ مَا وَضَعْتَ فِي يَدِكَ مِنْهُ ‏.‏ قَالَ ابْنُ قُهْزَاذَ وَسَمِعْتُ وَهْبَ بْنَ زَمْعَةَ، يَذْكُرُ عَنْ سُفْيَانَ بْنِ عَبْدِ الْمَلِكِ، قَالَ قَالَ عَبْدُ اللَّهِ يَعْنِي ابْنَ الْمُبَارَكِ رَأَيْتُ رَوْحَ بْنَ غُطَيْفٍ صَاحِبَ ‏\"\"‏ الدَّمِ قَدْرِ الدِّرْهَمِ ‏\"\"‏ وَجَلَسْتُ إِلَيْهِ مَجْلِسًا فَجَعَلْتُ أَسْتَحْيِي مِنْ أَصْحَابِي أَنْ يَرَوْنِي جَالِسًا مَعَهُ كُرْهَ حَدِيثِهِ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Muhammad bin Abd Allah bin Quhzādh narrated to me, he said I heard Abd Allah bin Uthmān bin Jabalah saying, I said to Abd Allah bin al-Mubārak:"}
{"hadithnumber": "7410", "arabic": "حَدَّثَنِي ابْنُ قُهْزَاذَ، قَالَ سَمِعْتُ وَهْبًا، يَقُولُ عَنْ سُفْيَانَ، عَنِ ابْنِ الْمُبَارَكِ، قَالَ بَقِيَّةُ صَدُوقُ اللِّسَانِ وَلَكِنَّهُ يَأْخُذُ عَمَّنْ أَقْبَلَ وَأَدْبَرَ ‏.‏", "grades": "", "reference": "", "international_number": "7410", "narrator_chain": "Ibn Quhzādh narrated to me, he said, I heard Wahb , on authority of Ibn al-Mubārak, he said:"}
{"hadithnumber": "7411", "arabic": "حَدَّثَنَا قُتَيْبَةُ بْنُ سَعِيدٍ، حَدَّثَنَا جَرِيرٌ، عَنْ مُغِيرَةَ، عَنِ الشَّعْبِيِّ، قَالَ حَدَّثَنِي الْحَارِثُ الأَعْوَرُ الْهَمْدَانِيُّ، وَكَانَ، كَذَّابًا ‏.‏", "grades": "", "reference": "", "international_number": "7411", "narrator_chain": "Qutaybah bin Sa’īd narrated to us, Jarīr narrated to us, on authority of Mughīrah, on authority of ash-Sha’bī, he said:"}
{"hadithnumber": "7412", "arabic": "حَدَّثَنَا أَبُو عَامِرٍ عَبْدُ اللَّهِ بْنُ بَرَّادٍ الأَشْعَرِيُّ، حَدَّثَنَا أَبُو أُسَامَةَ، عَنْ مُفَضَّلٍ، عَنْ مُغِيرَةَ، قَالَ سَمِعْتُ الشَّعْبِيَّ، يَقُولُ حَدَّثَنِي الْحَارِثُ الأَعْوَرُ، وَهُوَ يَشْهَدُ أَنَّهُ أَحَدُ الْكَاذِبِينَ ‏.‏", "grades": "", "reference": "", "international_number": "7412", "narrator_chain": "Abū Āmir Abd Allah bin Barrād al-Ash’arī narrated to us, Abū Usāmah narrated to us, on authority of Mufaḍḍal, on authority of Mughīrah, he said I heard ash-Sha’bī saying:"}
{"hadithnumber": "7413", "arabic": "حَدَّثَنَا قُتَيْبَةُ بْنُ سَعِيدٍ، حَدَّثَنَا جَرِيرٌ، عَنْ مُغِيرَةَ، عَنْ إِبْرَاهِيمَ، قَالَ قَالَ عَلْقَمَةُ قَرَأْتُ الْقُرْآنَ فِي سَنَتَيْنِ ‏.‏ فَقَالَ الْحَارِثُ الْقُرْآنُ هَيِّنٌ الْوَحْىُ أَشَدُّ ‏.‏", "grades": "", "reference": "", "international_number": "7413", "narrator_chain": "Qutaybah bin Sa’īd narrated to us, Jarīr narrated to us, on authority of Mughīrah, on authority of Ibrāhīm , he said, Alqamah said:"}
{"hadithnumber": "7414", "arabic": "وَحَدَّثَنِي حَجَّاجُ بْنُ الشَّاعِرِ، حَدَّثَنَا أَحْمَدُ، - يَعْنِي ابْنَ يُونُسَ - حَدَّثَنَا زَائِدَةُ، عَنِ الأَعْمَشِ، عَنْ إِبْرَاهِيمَ، أَنَّ الْحَارِثَ، قَالَ تَعَلَّمْتُ الْقُرْآنَ فِي ثَلاَثِ سِنِينَ وَالْوَحْىَ فِي سَنَتَيْنِ - أَوْ قَالَ الْوَحْىَ فِي ثَلاَثِ سِنِينَ وَالْقُرْآنَ فِي سَنَتَيْنِ ‏.‏", "grades": "", "reference": "", "international_number": "7414", "narrator_chain": "Hajjāj bin ash-Shā’ir narrated to me, Ahmad- meaning Ibn Yūnus- narrated to us, Zā’idah narrated to us, on authority of al-A’mash, on authority of Ibrāhīm that al-Hārith said:"}
{"hadithnumber": "7415", "arabic": "وَحَدَّثَنِي حَجَّاجٌ، قَالَ حَدَّثَنِي أَحْمَدُ، - وَهُوَ ابْنُ يُونُسَ - حَدَّثَنَا زَائِدَةُ، عَنْ مَنْصُورٍ، وَالْمُغِيرَةِ، عَنْ إِبْرَاهِيمَ، أَنَّ الْحَارِثَ، اتُّهِمَ ‏.‏", "grades": "", "reference": "", "international_number": "7415", "narrator_chain": ""}
{"hadithnumber": "7416", "arabic": "وَحَدَّثَنَا قُتَيْبَةُ بْنُ سَعِيدٍ، حَدَّثَنَا جَرِيرٌ، عَنْ حَمْزَةَ الزَّيَّاتِ، قَالَ سَمِعَ مُرَّةُ الْهَمْدَانِيُّ، مِنَ الْحَارِثِ شَيْئًا فَقَالَ لَهُ اقْعُدْ بِالْبَابِ ‏.‏ قَالَ فَدَخَلَ مُرَّةُ وَأَخَذَ سَيْفَهُ - قَالَ - وَأَحَسَّ الْحَارِثُ بِالشَّرِّ فَذَهَبَ ‏.‏", "grades": "", "reference": "", "international_number": "7416", "narrator_chain": "Qutaybah bin Sa’īd narrated to us, Jarīr narrated to us, on authority of Hamzah az-Zayyāt, he said:"}
{"hadithnumber": "7417", "arabic": "وَحَدَّثَنِي عُبَيْدُ اللَّهِ بْنُ سَعِيدٍ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ، - يَعْنِي ابْنَ مَهْدِيٍّ - حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ، عَنِ ابْنِ عَوْنٍ، قَالَ قَالَ لَنَا إِبْرَاهِيمُ إِيَّاكُمْ وَالْمُغِيرَةَ بْنَ سَعِيدٍ وَأَبَا عَبْدِ الرَّحِيمِ فَإِنَّهُمَا كَذَّابَانِ ‏.‏", "grades": "", "reference": "", "international_number": "7417", "narrator_chain": "Ubayd Allah bin Sa’īd narrated to me, Abd ur-Rahman- meaning Ibn Mahdī- narrated to us, Hammād bin Zayd narrated to us, on authority of Ibn Awn, he said, Ibrāhīm said to us:"}
{"hadithnumber": "7418", "arabic": "حَدَّثَنَا أَبُو كَامِلٍ الْجَحْدَرِيُّ، حَدَّثَنَا حَمَّادٌ، - وَهُوَ ابْنُ زَيْدٍ - قَالَ حَدَّثَنَا عَاصِمٌ، قَالَ كُنَّا نَأْتِي أَبَا عَبْدِ الرَّحْمَنِ السُّلَمِيَّ وَنَحْنُ غِلْمَةٌ أَيْفَاعٌ فَكَانَ يَقُولُ لَنَا لاَ تُجَالِسُوا الْقُصَّاصَ غَيْرَ أَبِي الأَحْوَصِ وَإِيَّاكُمْ وَشَقِيقًا ‏.‏ قَالَ وَكَانَ شَقِيقٌ هَذَا يَرَى رَأْىَ الْخَوَارِجِ وَلَيْسَ بِأَبِي وَائِلٍ ‏.‏", "grades": "", "reference": "", "international_number": "7418", "narrator_chain": "Abū Kāmil al-Jahdarī narrated to us, Hammād- and he is Ibn Zayd- narrated to us, he said Āsim  narrated to us, he said:"}
{"hadithnumber": "7419", "arabic": "حَدَّثَنَا أَبُو غَسَّانَ، مُحَمَّدُ بْنُ عَمْرٍو الرَّازِيُّ قَالَ سَمِعْتُ جَرِيرًا، يَقُولُ لَقِيتُ جَابِرَ بْنَ يَزِيدَ الْجُعْفِيَّ فَلَمْ أَكْتُبْ عَنْهُ كَانَ يُؤْمِنُ بِالرَّجْعَةِ ‏.‏", "grades": "", "reference": "", "international_number": "7419", "narrator_chain": "Abū Ghassān Muhammad bin Amr ar-Rāzī narrated to us, he said, I heard Jarīr  saying:"}
{"hadithnumber": "7420", "arabic": "حَدَّثَنَا الْحَسَنُ الْحُلْوَانِيُّ، حَدَّثَنَا يَحْيَى بْنُ آدَمَ، حَدَّثَنَا مِسْعَرٌ، قَالَ حَدَّثَنَا جَابِرُ بْنُ يَزِيدَ، قَبْلَ أَنْ يُحْدِثَ، مَا أَحْدَثَ ‏.‏", "grades": "", "reference": "", "international_number": "7420", "narrator_chain": "Al-Hasan al-Hulwānī narrated to us, Yahyā bin Ādam narrated to us, Mis’ar narrated to us, he said:"}
{"hadithnumber": "7421", "arabic": "وَحَدَّثَنِي سَلَمَةُ بْنُ شَبِيبٍ، حَدَّثَنَا الْحُمَيْدِيُّ، حَدَّثَنَا سُفْيَانُ، قَالَ كَانَ النَّاسُ يَحْمِلُونَ عَنْ جَابِرٍ، قَبْلَ أَنْ يُظْهِرَ، مَا أَظْهَرَ فَلَمَّا أَظْهَرَ مَا أَظْهَرَ اتَّهَمَهُ النَّاسُ فِي حَدِيثِهِ وَتَرَكَهُ بَعْضُ النَّاسِ فَقِيلَ لَهُ وَمَا أَظْهَرَ قَالَ الإِيمَانَ بِالرَّجْعَةِ ‏.‏", "grades": "", "reference": "", "international_number": "7421", "narrator_chain": "Salamah bin Shabīb narrated to me, al-Humaydī narrated to us, Sufyān narrated to us, he said:"}
{"hadithnumber": "7422", "arabic": "وَحَدَّثَنَا حَسَنٌ الْحُلْوَانِيُّ، حَدَّثَنَا أَبُو يَحْيَى الْحِمَّانِيُّ، حَدَّثَنَا قَبِيصَةُ، وَأَخُوهُ، أَنَّهُمَا سَمِعَا الْجَرَّاحَ بْنَ مَلِيحٍ، يَقُولُ سَمِعْتُ جَابِرًا، يَقُولُ عِنْدِي سَبْعُونَ أَلْفَ حَدِيثٍ عَنْ أَبِي جَعْفَرٍ، عَنِ النَّبِيِّ صلى الله عليه وسلم كُلُّهَا ‏.‏", "grades": "", "reference": "", "international_number": "7422", "narrator_chain": "Hasan al-Hulwānī narrated to us, Abū Yahyā al-Himmānī narrated to us, Qabīsah and his brother  narrated to us, that they heard al-Jarrāh bin Malīh saying, I heard Jābir say:"}
{"hadithnumber": "7423", "arabic": "وَحَدَّثَنِي حَجَّاجُ بْنُ الشَّاعِرِ، حَدَّثَنَا أَحْمَدُ بْنُ يُونُسَ، قَالَ سَمِعْتُ زُهَيْرًا، يَقُولُ قَالَ جَابِرٌ - أَوْ سَمِعْتُ جَابِرًا، يَقُولُ - إِنَّ عِنْدِي لَخَمْسِينَ أَلْفَ حَدِيثٍ مَا حَدَّثْتُ مِنْهَا بِشَىْءٍ ‏.‏ قَالَ ثُمَّ حَدَّثَ يَوْمًا بِحَدِيثٍ فَقَالَ هَذَا مِنَ الْخَمْسِينَ أَلْفًا ‏.‏", "grades": "", "reference": "", "international_number": "7423", "narrator_chain": "Hajjāj bin ash-Shā’ir narrated to me, Ahmad bin Yūnus narrated to us, he said, I heard Zuhayr saying, Jābir said, or, I heard Jābir saying:"}
{"hadithnumber": "7424", "arabic": "وَحَدَّثَنِي إِبْرَاهِيمُ بْنُ خَالِدٍ الْيَشْكُرِيُّ، قَالَ سَمِعْتُ أَبَا الْوَلِيدِ، يَقُولُ سَمِعْتُ سَلاَّمَ بْنَ أَبِي مُطِيعٍ، يَقُولُ سَمِعْتُ جَابِرًا الْجُعْفِيَّ، يَقُولُ عِنْدِي خَمْسُونَ أَلْفَ حَدِيثٍ عَنِ النَّبِيِّ صلى الله عليه وسلم ‏.‏", "grades": "", "reference": "", "international_number": "7424", "narrator_chain": "Ibrāhīm bin Khālid al-Yashkurī narrated to me, he said, I heard Abūl-Walīd saying, I heard Sallām bin Abī Mutī’ saying, I heard Jābir al-Ju’fī saying:"}
{"hadithnumber": "7425", "arabic": "وَحَدَّثَنِي سَلَمَةُ بْنُ شَبِيبٍ، حَدَّثَنَا الْحُمَيْدِيُّ، حَدَّثَنَا سُفْيَانُ، قَالَ سَمِعْتُ رَجُلاً، سَأَلَ جَابِرًا عَنْ قَوْلِهِ عَزَّ وَجَلَّ ‏{‏ فَلَنْ أَبْرَحَ الأَرْضَ حَتَّى يَأْذَنَ لِي أَبِي أَوْ يَحْكُمَ اللَّهُ لِي وَهُوَ خَيْرُ الْحَاكِمِينَ‏}‏ فَقَالَ جَابِرٌ لَمْ يَجِئْ تَأْوِيلُ هَذِهِ ‏.‏ قَالَ سُفْيَانُ وَكَذَبَ ‏.‏ فَقُلْنَا لِسُفْيَانَ وَمَا أَرَادَ بِهَذَا فَقَالَ إِنَّ الرَّافِضَةَ تَقُولُ إِنَّ عَلِيًّا فِي السَّحَابِ فَلاَ نَخْرُجُ مَعَ مَنْ خَرَجَ مِنْ وَلَدِهِ حَتَّى يُنَادِيَ مُنَادٍ مِنَ السَّمَاءِ ‏.‏ يُرِيدُ عَلِيًّا أَنَّهُ يُنَادِي اخْرُجُوا مَعَ فُلاَنٍ ‏.‏ يَقُولُ جَابِرٌ فَذَا تَأْوِيلُ هَذِهِ الآيَةِ وَكَذَبَ كَانَتْ فِي إِخْوَةِ يُوسُفَ صلى الله عليه وسلم ‏.‏", "grades": "", "reference": "", "international_number": "7425", "narrator_chain": "Salamah bin Shabīb narrated to me, al-Humaydī narrated to us, Sufyān narrated to us, he said, I heard a man ask Jābir about the verse:"}
{"hadithnumber": "7426", "arabic": "وَحَدَّثَنِي سَلَمَةُ، حَدَّثَنَا الْحُمَيْدِيُّ، حَدَّثَنَا سُفْيَانُ، قَالَ سَمِعْتُ جَابِرًا، يُحَدِّثُ بِنَحْوٍ مِنْ ثَلاَثِينَ أَلْفَ حَدِيثٍ مَا أَسْتَحِلُّ أَنْ أَذْكُرَ مِنْهَا شَيْئًا وَأَنَّ لِي كَذَا وَكَذَا ‏.‏ قَالَ مُسْلِمٌ وَسَمِعْتُ أَبَا غَسَّانَ، مُحَمَّدَ بْنَ عَمْرٍو الرَّازِيَّ قَالَ سَأَلْتُ جَرِيرَ بْنَ عَبْدِ الْحَمِيدِ فَقُلْتُ الْحَارِثُ بْنُ حَصِيرَةَ لَقِيتَهُ قَالَ نَعَمْ ‏.‏ شَيْخٌ طَوِيلُ السُّكُوتِ يُصِرُّ عَلَى أَمْرٍ عَظِيمٍ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Salamah narrated to me, al-Humaydī narrated to us, Sufyān narrated to us, he said:"}
{"hadithnumber": "7427", "arabic": "حَدَّثَنِي أَحْمَدُ بْنُ إِبْرَاهِيمَ الدَّوْرَقِيُّ، قَالَ حَدَّثَنِي عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، عَنْ حَمَّادِ بْنِ زَيْدٍ، قَالَ ذَكَرَ أَيُّوبُ رَجُلاً يَوْمًا فَقَالَ لَمْ يَكُنْ بِمُسْتَقِيمِ اللِّسَانِ وَذَكَرَ آخَرَ فَقَالَ هُوَ يَزِيدُ فِي الرَّقْمِ ‏.‏", "grades": "", "reference": "", "international_number": "7427", "narrator_chain": "Ahmad bin Ibrāhīm ad-Dawraqī narrated to me, he said Abd ur-Rahman bin Mahdī narrated to me, on authority Hammād bin Zayd, he said, Ayyūb mentioned a man one day and said :"}
{"hadithnumber": "7428", "arabic": "حَدَّثَنِي حَجَّاجُ بْنُ الشَّاعِرِ، حَدَّثَنَا سُلَيْمَانُ بْنُ حَرْبٍ، حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ، قَالَ قَالَ أَيُّوبُ إِنَّ لِي جَارًا - ثُمَّ ذَكَرَ مِنْ فَضْلِهِ - وَلَوْ شَهِدَ عِنْدِي عَلَى تَمْرَتَيْنِ مَا رَأَيْتُ شَهَادَتَهُ جَائِزَةً ‏.‏", "grades": "", "reference": "", "international_number": "7428", "narrator_chain": "Hajjāj bin ash-Shā’ir narrated to me, Sulaymān bin Harb narrated to us, Hammād bin Zayd narrated to us, he said, Ayyūb said:"}
{"hadithnumber": "7429", "arabic": "وَحَدَّثَنِي مُحَمَّدُ بْنُ رَافِعٍ، وَحَجَّاجُ بْنُ الشَّاعِرِ، قَالاَ حَدَّثَنَا عَبْدُ الرَّزَّاقِ، قَالَ قَالَ مَعْمَرٌ مَا رَأَيْتُ أَيُّوبَ اغْتَابَ أَحَدًا قَطُّ إِلاَّ عَبْدَ الْكَرِيمِ - يَعْنِي أَبَا أُمَيَّةَ - فَإِنَّهُ ذَكَرَهُ فَقَالَ رَحِمَهُ اللَّهُ كَانَ غَيْرَ ثِقَةٍ لَقَدْ سَأَلَنِي عَنْ حَدِيثٍ لِعِكْرِمَةَ ثُمَّ قَالَ سَمِعْتُ عِكْرِمَةَ ‏.‏", "grades": "", "reference": "", "international_number": "7429", "narrator_chain": "Muhammad bin Rāfi’ and Hajjāj bin ash-Shā’ir narrated to me, they said Abd ur-Razzāq narrated to us, he said Ma’mar said:"}
{"hadithnumber": "7430", "arabic": "حَدَّثَنِي الْفَضْلُ بْنُ سَهْلٍ، قَالَ حَدَّثَنَا عَفَّانُ بْنُ مُسْلِمٍ، حَدَّثَنَا هَمَّامٌ، قَالَ قَدِمَ عَلَيْنَا أَبُو دَاوُدَ الأَعْمَى فَجَعَلَ يَقُولُ حَدَّثَنَا الْبَرَاءُ، قَالَ وَحَدَّثَنَا زَيْدُ بْنُ أَرْقَمَ، ‏.‏ فَذَكَرْنَا ذَلِكَ لِقَتَادَةَ فَقَالَ كَذَبَ مَا سَمِعَ مِنْهُمْ إِنَّمَا كَانَ ذَلِكَ سَائِلاً يَتَكَفَّفُ النَّاسَ زَمَنَ طَاعُونِ الْجَارِفِ ‏.‏", "grades": "", "reference": "", "international_number": "7430", "narrator_chain": "Al-Faḍl bin Sahl narrated to me, he said Affān bin Muslim narrated to us, Hammām narrated to us, he said, Abū Dāwud al-A’mā came to us and began saying:"}
{"hadithnumber": "7431", "arabic": "وَحَدَّثَنِي حَسَنُ بْنُ عَلِيٍّ الْحُلْوَانِيُّ، قَالَ حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، أَخْبَرَنَا هَمَّامٌ، قَالَ دَخَلَ أَبُو دَاوُدَ الأَعْمَى عَلَى قَتَادَةَ فَلَمَّا قَامَ قَالُوا إِنَّ هَذَا يَزْعُمُ أَنَّهُ لَقِيَ ثَمَانِيَةَ عَشَرَ بَدْرِيًّا ‏.‏ فَقَالَ قَتَادَةُ هَذَا كَانَ سَائِلاً قَبْلَ الْجَارِفِ لاَ يَعْرِضُ فِي شَىْءٍ مِنْ هَذَا وَلاَ يَتَكَلَّمُ فِيهِ ‏.‏ فَوَاللَّهِ مَا حَدَّثَنَا الْحَسَنُ عَنْ بَدْرِيٍّ مُشَافَهَةً ‏.‏ وَلاَ حَدَّثَنَا سَعِيدُ بْنُ الْمُسَيَّبِ عَنْ بَدْرِيٍّ مُشَافَهَةً إِلاَّ عَنْ سَعْدِ بْنِ مَالِكٍ ‏.‏", "grades": "", "reference": "", "international_number": "7431", "narrator_chain": "Hasan bin Alī al-Hulwānī narrated to me, he said Yazīd bin Hārūn narrated to us, Hammām informed us, he said ‘Abū Dāwud al-A’mā entered upon Qatādah and when he stood, they said:"}
{"hadithnumber": "7432", "arabic": "حَدَّثَنَا عُثْمَانُ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا جَرِيرٌ، عَنْ رَقَبَةَ، أَنَّ أَبَا جَعْفَرٍ الْهَاشِمِيَّ الْمَدَنِيَّ، كَانَ يَضَعُ أَحَادِيثَ كَلاَمَ حَقٍّ وَلَيْسَتْ مِنْ أَحَادِيثِ النَّبِيِّ صلى الله عليه وسلم وَكَانَ يَرْوِيهَا عَنِ النَّبِيِّ صلى الله عليه وسلم ‏.‏", "grades": "", "reference": "", "international_number": "7432", "narrator_chain": ""}
{"hadithnumber": "7433", "arabic": "حَدَّثَنَا الْحَسَنُ الْحُلْوَانِيُّ، قَالَ حَدَّثَنَا نُعَيْمُ بْنُ حَمَّادٍ، قَالَ أَبُو إِسْحَاقَ إِبْرَاهِيمُ بْنُ مُحَمَّدِ بْنِ سُفْيَانَ وَحَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، قَالَ حَدَّثَنَا نُعَيْمُ بْنُ حَمَّادٍ، حَدَّثَنَا أَبُو دَاوُدَ الطَّيَالِسِيُّ، عَنْ شُعْبَةَ، عَنْ يُونُسَ بْنِ عُبَيْدٍ، قَالَ كَانَ عَمْرُو بْنُ عُبَيْدٍ يَكْذِبُ فِي الْحَدِيثِ ‏.‏", "grades": "", "reference": "", "international_number": "7433", "narrator_chain": "Al-Hasan al-Hulwānī narrated to us, he said Nu’aym bin Hammād narrated to us, he said Abū Ishāq Ibrāhīm bin Muhammad bin Sufyān said; and Muhammad bin Yahyā narrated to us, he said, Nu’aym bin Hammād narrated to us, Abū Dāwud at-Tayālisī narrated to us, on authority of Shu’bah, on authority of Yūnus bin Ubayd, he said:"}
{"hadithnumber": "7434", "arabic": "حَدَّثَنِي عَمْرُو بْنُ عَلِيٍّ أَبُو حَفْصٍ، قَالَ سَمِعْتُ مُعَاذَ بْنَ مُعَاذٍ، يَقُولُ قُلْتُ لِعَوْفِ بْنِ أَبِي جَمِيلَةَ إِنَّ عَمْرَو بْنَ عُبَيْدٍ حَدَّثَنَا عَنِ الْحَسَنِ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ مَنْ حَمَلَ عَلَيْنَا السِّلاَحَ فَلَيْسَ مِنَّا ‏\"\"‏ قَالَ كَذَبَ وَاللَّهِ عَمْرٌو وَلَكِنَّهُ أَرَادَ أَنْ يَحُوزَهَا إِلَى قَوْلِهِ الْخَبِيثِ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Amr bin Alī Abū Hafs narrated to me, he said I heard Mu’ādh bin Mu’ādh saying, I said to Awf bin Abī Jamīlah ‘Indeed Amr bin Ubayd narrated to us on authority of al-Hasan that the Messenger of Allah, peace and blessings of Allah upon him, said:"}
{"hadithnumber": "7435", "arabic": "وَحَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ عُمَرَ الْقَوَارِيرِيُّ، حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ، قَالَ كَانَ رَجُلٌ قَدْ لَزِمَ أَيُّوبَ وَسَمِعَ مِنْهُ فَفَقَدَهُ أَيُّوبُ فَقَالُوا يَا أَبَا بَكْرٍ إِنَّهُ قَدْ لَزِمَ عَمْرَو بْنَ عُبَيْدٍ ‏.‏ قَالَ حَمَّادٌ فَبَيْنَا أَنَا يَوْمًا مَعَ أَيُّوبَ وَقَدْ بَكَّرْنَا إِلَى السُّوقِ فَاسْتَقْبَلَهُ الرَّجُلُ فَسَلَّمَ عَلَيْهِ أَيُّوبُ وَسَأَلَهُ ثُمَّ قَالَ لَهُ أَيُّوبُ بَلَغَنِي أَنَّكَ لَزِمْتَ ذَاكَ الرَّجُلَ ‏.‏ قَالَ حَمَّادٌ سَمَّاهُ ‏.‏ يَعْنِي عَمْرًا ‏.‏ قَالَ نَعَمْ يَا أَبَا بَكْرٍ إِنَّهُ يَجِيئُنَا بِأَشْيَاءَ غَرَائِبَ ‏.‏ قَالَ يَقُولُ لَهُ أَيُّوبُ إِنَّمَا نَفِرُّ أَوْ نَفْرَقُ مِنْ تِلْكَ الْغَرَائِبِ ‏.‏", "grades": "", "reference": "", "international_number": "7435", "narrator_chain": "Ubayd Allah bin Umar al-Qawārīrī narrated to us, Hammād bin Zayd narrated to us, he said:"}
{"hadithnumber": "7436", "arabic": "وَحَدَّثَنِي حَجَّاجُ بْنُ الشَّاعِرِ، حَدَّثَنَا سُلَيْمَانُ بْنُ حَرْبٍ، حَدَّثَنَا ابْنُ زَيْدٍ، - يَعْنِي حَمَّادًا - قَالَ قِيلَ لأَيُّوبَ إِنَّ عَمْرَو بْنَ عُبَيْدٍ رَوَى عَنِ الْحَسَنِ قَالَ لاَ يُجْلَدُ السَّكْرَانُ مِنَ النَّبِيذِ ‏.‏ فَقَالَ كَذَبَ أَنَا سَمِعْتُ الْحَسَنَ يَقُولُ يُجْلَدُ السَّكْرَانُ مِنَ النَّبِيذِ ‏.‏", "grades": "", "reference": "", "international_number": "7436", "narrator_chain": "Hajjāj bin ash-Shā’ir narrated to me, Sulaymān bin Harb narrated to us, Ibn Zayd, rather Hammād, narrated to us, he said, it was said to Ayyūb, ‘Indeed Amr bin Ubayd transmitted on authority of al-Hasan that he said:"}
{"hadithnumber": "7437", "arabic": "وَحَدَّثَنِي حَجَّاجٌ، حَدَّثَنَا سُلَيْمَانُ بْنُ حَرْبٍ، قَالَ سَمِعْتُ سَلاَّمَ بْنَ أَبِي مُطِيعٍ، يَقُولُ بَلَغَ أَيُّوبَ أَنِّي آتِي عَمْرًا فَأَقْبَلَ عَلَىَّ يَوْمًا فَقَالَ أَرَأَيْتَ رَجُلاً لاَ تَأْمَنُهُ عَلَى دِينِهِ كَيْفَ تَأْمَنُهُ عَلَى الْحَدِيثِ", "grades": "", "reference": "", "international_number": "7437", "narrator_chain": "Hajjāj narrated to me, Sulaymān bin Harb narrated to us, he said, I heard Sallām bin Abī Mutī’ saying, it reached Ayyūb that I would go to Amr so he turned to me and said:"}
{"hadithnumber": "7438", "arabic": "وَحَدَّثَنِي سَلَمَةُ بْنُ شَبِيبٍ، حَدَّثَنَا الْحُمَيْدِيُّ، حَدَّثَنَا سُفْيَانُ، قَالَ سَمِعْتُ أَبَا مُوسَى، يَقُولُ حَدَّثَنَا عَمْرُو بْنُ عُبَيْدٍ، قَبْلَ أَنْ يُحْدِثَ، ‏.‏", "grades": "", "reference": "", "international_number": "7438", "narrator_chain": "Salamah bin Shabīb narrated to me, al-Humaydī narrated to us, Sufyān narrated to us, he said I heard Abū Mūsā  saying:"}
{"hadithnumber": "7439", "arabic": "حَدَّثَنِي عُبَيْدُ اللَّهِ بْنُ مُعَاذٍ الْعَنْبَرِيُّ، حَدَّثَنَا أَبِي قَالَ، كَتَبْتُ إِلَى شُعْبَةَ أَسْأَلُهُ عَنْ أَبِي شَيْبَةَ، قَاضِي وَاسِطٍ فَكَتَبَ إِلَىَّ لاَ تَكْتُبْ عَنْهُ شَيْئًا وَمَزِّقْ كِتَابِي ‏.‏", "grades": "", "reference": "", "international_number": "7439", "narrator_chain": "Ubayd Allah bin Mu’ādh al-Anbarī narrated to me, my father narrated to us, he said:"}
{"hadithnumber": "7440", "arabic": "وَحَدَّثَنَا الْحُلْوَانِيُّ، قَالَ سَمِعْتُ عَفَّانَ، قَالَ حَدَّثْتُ حَمَّادَ بْنَ سَلَمَةَ، عَنْ صَالِحٍ الْمُرِّيِّ، بِحَدِيثٍ عَنْ ثَابِتٍ، فَقَالَ كَذَبَ ‏.‏ وَحَدَّثْتُ هَمَّامًا، عَنْ صَالِحٍ الْمُرِّيِّ، بِحَدِيثٍ فَقَالَ كَذَبَ ‏.‏", "grades": "", "reference": "", "international_number": "7440", "narrator_chain": "Al-Hulwānī narrated to us, he said, I heard Affān  say:"}
{"hadithnumber": "7441", "arabic": "وَحَدَّثَنَا مَحْمُودُ بْنُ غَيْلاَنَ، حَدَّثَنَا أَبُو دَاوُدَ، قَالَ قَالَ لِي شُعْبَةُ ايتِ جَرِيرَ بْنَ حَازِمٍ فَقُلْ لَهُ لاَ يَحِلُّ لَكَ أَنْ تَرْوِيَ عَنِ الْحَسَنِ بْنِ عُمَارَةَ فَإِنَّهُ يَكْذِبُ ‏.‏ قَالَ أَبُو دَاوُدَ قُلْتُ لِشُعْبَةَ وَكَيْفَ ذَاكَ فَقَالَ حَدَّثَنَا عَنِ الْحَكَمِ بِأَشْيَاءَ لَمْ أَجِدْ لَهَا أَصْلاً ‏.‏ قَالَ قُلْتُ لَهُ بِأَىِّ شَىْءٍ قَالَ قُلْتُ لِلْحَكَمِ أَصَلَّى النَّبِيُّ صلى الله عليه وسلم عَلَى قَتْلَى أُحُدٍ فَقَالَ لَمْ يُصَلِّ عَلَيْهِمْ ‏.‏ فَقَالَ الْحَسَنُ بْنُ عُمَارَةَ عَنِ الْحَكَمِ عَنْ مِقْسَمٍ عَنِ ابْنِ عَبَّاسٍ إِنَّ النَّبِيَّ صلى الله عليه وسلم صَلَّى عَلَيْهِمْ وَدَفَنَهُمْ ‏.‏ قُلْتُ لِلْحَكَمِ مَا تَقُولُ فِي أَوْلاَدِ الزِّنَا قَالَ يُصَلَّى عَلَيْهِمْ ‏.‏ قُلْتُ مِنْ حَدِيثِ مَنْ يُرْوَى قَالَ يُرْوَى عَنِ الْحَسَنِ الْبَصْرِيِّ ‏.‏ فَقَالَ الْحَسَنُ بْنُ عُمَارَةَ حَدَّثَنَا الْحَكَمُ عَنْ يَحْيَى بْنِ الْجَزَّارِ عَنْ عَلِيٍّ ‏.‏", "grades": "", "reference": "", "international_number": "7441", "narrator_chain": "Mahmūd bin Ghaylān narrated to us, Abū Dāwud narrated to us, he said, Shu’bah said to me:"}
{"hadithnumber": "7442", "arabic": "وَحَدَّثَنَا الْحَسَنُ الْحُلْوَانِيُّ، قَالَ سَمِعْتُ يَزِيدَ بْنَ هَارُونَ، ‏.‏ وَذَكَرَ زِيَادَ بْنَ مَيْمُونٍ فَقَالَ حَلَفْتُ أَلاَّ أَرْوِيَ عَنْهُ شَيْئًا وَلاَ عَنْ خَالِدِ بْنِ مَحْدُوجٍ ‏.‏ وَقَالَ لَقِيتُ زِيَادَ بْنَ مَيْمُونٍ فَسَأَلْتُهُ عَنْ حَدِيثٍ فَحَدَّثَنِي بِهِ عَنْ بَكْرٍ الْمُزَنِيِّ ثُمَّ عُدْتُ إِلَيْهِ فَحَدَّثَنِي بِهِ عَنْ مُوَرِّقٍ ثُمَّ عُدْتُ إِلَيْهِ فَحَدَّثَنِي بِهِ عَنِ الْحَسَنِ ‏.‏ وَكَانَ يَنْسُبُهُمَا إِلَى الْكَذِبِ ‏.‏ قَالَ الْحُلْوَانِيُّ سَمِعْتُ عَبْدَ الصَّمَدِ وَذَكَرْتُ عِنْدَهُ زِيَادَ بْنَ مَيْمُونٍ فَنَسَبَهُ إِلَى الْكَذِبِ ‏.‏", "grades": "", "reference": "", "international_number": "7442", "narrator_chain": "Al-Hasan al-Hulwānī narrated to us, he said, I heard Yazīd bin Hārūn mention Ziyād bin Maymūn, and he said:"}
{"hadithnumber": "7443", "arabic": "وَحَدَّثَنَا مَحْمُودُ بْنُ غَيْلاَنَ، قَالَ قُلْتُ لأَبِي دَاوُدَ الطَّيَالِسِيِّ قَدْ أَكْثَرْتَ عَنْ عَبَّادِ بْنِ مَنْصُورٍ فَمَا لَكَ لَمْ تَسْمَعْ مِنْهُ حَدِيثَ الْعَطَّارَةِ الَّذِي رَوَى لَنَا النَّضْرُ بْنُ شُمَيْلٍ قَالَ لِيَ اسْكُتْ فَأَنَا لَقِيتُ زِيَادَ بْنَ مَيْمُونٍ وَعَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ فَسَأَلْنَاهُ فَقُلْنَا لَهُ هَذِهِ الأَحَادِيثُ الَّتِي تَرْوِيهَا عَنْ أَنَسٍ فَقَالَ أَرَأَيْتُمَا رَجُلاً يُذْنِبُ فَيَتُوبُ أَلَيْسَ يَتُوبُ اللَّهُ عَلَيْهِ قَالَ قُلْنَا نَعَمْ ‏.‏ قَالَ مَا سَمِعْتُ مِنْ أَنَسٍ مِنْ ذَا قَلِيلاً وَلاَ كَثِيرًا إِنْ كَانَ لاَ يَعْلَمُ النَّاسُ فَأَنْتُمَا لاَ تَعْلَمَانِ أَنِّي لَمْ أَلْقَ أَنَسًا ‏.‏ قَالَ أَبُو دَاوُدَ فَبَلَغَنَا بَعْدُ أَنَّهُ يَرْوِي فَأَتَيْنَاهُ أَنَا وَعَبْدُ الرَّحْمَنِ فَقَالَ أَتُوبُ ‏.‏ ثُمَّ كَانَ بَعْدُ يُحَدِّثُ ‏.‏ فَتَرَكْنَاهُ ‏.‏", "grades": "", "reference": "", "international_number": "7443", "narrator_chain": "Mahmūd bin Ghaylān narrated to us, he said, I said to Abū Dāwud at-Tayālisī:"}
{"hadithnumber": "7444", "arabic": "حَدَّثَنَا حَسَنٌ الْحُلْوَانِيُّ، قَالَ سَمِعْتُ شَبَابَةَ، قَالَ كَانَ عَبْدُ الْقُدُّوسِ يُحَدِّثُنَا فَيَقُولُ سُوَيْدُ بْنُ عَقَلَةَ ‏.‏ قَالَ شَبَابَةُ وَسَمِعْتُ عَبْدَ الْقُدُّوسِ يَقُولُ نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم أَنَّ يُتَّخَذَ الرَّوْحُ عَرْضًا ‏.‏ قَالَ فَقِيلَ لَهُ أَىُّ شَىْءٍ هَذَا قَالَ يَعْنِي تُتَّخَذُ كُوَّةٌ فِي حَائِطٍ لِيَدْخُلَ عَلَيْهِ الرَّوْحُ ‏.‏ قَالَ مُسْلِمٌ وَسَمِعْتُ عُبَيْدَ اللَّهِ بْنَ عُمَرَ الْقَوَارِيرِيَّ، يَقُولُ سَمِعْتُ حَمَّادَ بْنَ زَيْدٍ، يَقُولُ لِرَجُلٍ بَعْدَ مَا جَلَسَ مَهْدِيُّ بْنُ هِلاَلٍ بِأَيَّامٍ مَا هَذِهِ الْعَيْنُ الْمَالِحَةُ الَّتِي نَبَعَتْ قِبَلَكُمْ قَالَ نَعَمْ يَا أَبَا إِسْمَاعِيلَ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Hasan al-Hulwānī narrated to us, he said, I heard Shabābah say:"}
{"hadithnumber": "7445", "arabic": "وَحَدَّثَنَا الْحَسَنُ الْحُلْوَانِيُّ، قَالَ سَمِعْتُ عَفَّانَ، قَالَ سَمِعْتُ أَبَا عَوَانَةَ، قَالَ مَا بَلَغَنِي عَنِ الْحَسَنِ، حَدِيثٌ إِلاَّ أَتَيْتُ بِهِ أَبَانَ بْنَ أَبِي عَيَّاشٍ فَقَرَأَهُ عَلَىَّ ‏.‏", "grades": "", "reference": "", "international_number": "7445", "narrator_chain": "Al-Hasan al-Hulwānī narrated to us, he said, I heard Affān say, I heard Abū Awānah say:"}
{"hadithnumber": "7446", "arabic": "وَحَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ، قَالَ سَمِعْتُ أَنَا وَحَمْزَةُ الزَّيَّاتُ، مِنْ أَبَانَ بْنِ أَبِي عَيَّاشٍ نَحْوًا مِنْ أَلْفِ حَدِيثٍ ‏.‏ قَالَ عَلِيٌّ فَلَقِيتُ حَمْزَةَ فَأَخْبَرَنِي أَنَّهُ رَأَى النَّبِيَّ صلى الله عليه وسلم فِي الْمَنَامِ فَعَرَضَ عَلَيْهِ مَا سَمِعَ مِنْ أَبَانَ فَمَا عَرَفَ مِنْهَا إِلاَّ شَيْئًا يَسِيرًا خَمْسَةً أَوْ سِتَّةً ‏.‏", "grades": "", "reference": "", "international_number": "7446", "narrator_chain": "Suwayd bin Sa’īd narrated to us, Alī bin Mus’hir narrated to us, he said:"}
{"hadithnumber": "7447", "arabic": "حَدَّثَنَا عَبْدُ اللَّهِ بْنُ عَبْدِ الرَّحْمَنِ الدَّارِمِيُّ، أَخْبَرَنَا زَكَرِيَّاءُ بْنُ عَدِيٍّ، قَالَ قَالَ لِي أَبُو إِسْحَاقَ الْفَزَارِيُّ اكْتُبْ عَنْ بَقِيَّةَ، مَا رَوَى عَنِ الْمَعْرُوفِينَ، وَلاَ تَكْتُبْ عَنْهُ مَا رَوَى عَنْ غَيْرِ الْمَعْرُوفِينَ، وَلاَ تَكْتُبْ عَنْ إِسْمَاعِيلَ بْنِ عَيَّاشٍ، مَا رَوَى عَنِ الْمَعْرُوفِينَ، وَلاَ عَنْ غَيْرِهِمْ، ‏.‏", "grades": "", "reference": "", "international_number": "7447", "narrator_chain": "Abd Allah bin Abd ar-Rahman ad-Dārimī narrated to us, Zakariyyā’ bin Adī informed us, he said, Abū Ishāq al-Fazarī said to me:"}
{"hadithnumber": "7448", "arabic": "وَحَدَّثَنَا إِسْحَاقُ بْنُ إِبْرَاهِيمَ الْحَنْظَلِيُّ، قَالَ سَمِعْتُ بَعْضَ، أَصْحَابِ عَبْدِ اللَّهِ قَالَ قَالَ ابْنُ الْمُبَارَكِ نِعْمَ الرَّجُلُ بَقِيَّةُ لَوْلاَ أَنَّهُ كَانَ يَكْنِي الأَسَامِيَ وَيُسَمِّي الْكُنَى كَانَ دَهْرًا يُحَدِّثُنَا عَنْ أَبِي سَعِيدٍ الْوُحَاظِيِّ فَنَظَرْنَا فَإِذَا هُوَ عَبْدُ الْقُدُّوسِ ‏.‏", "grades": "", "reference": "", "international_number": "7448", "narrator_chain": "Ishāq bin Ibrāhīm al-Hanthalī  say, Ibn al-Mubārak said:"}
{"hadithnumber": "7449", "arabic": "وَحَدَّثَنِي أَحْمَدُ بْنُ يُوسُفَ الأَزْدِيُّ، قَالَ سَمِعْتُ عَبْدَ الرَّزَّاقِ، يَقُولُ مَا رَأَيْتُ ابْنَ الْمُبَارَكِ يُفْصِحُ بِقَوْلِهِ كَذَّابٌ إِلاَّ لِعَبْدِ الْقُدُّوسِ فَإِنِّي سَمِعْتُهُ يَقُولُ لَهُ كَذَّابٌ ‏.‏", "grades": "", "reference": "", "international_number": "7449", "narrator_chain": "Ahmad bin Yūsuf al-Azdī narrated to me, he said, I heard Abd ar-Razzāq saying:"}
{"hadithnumber": "7450", "arabic": "وَحَدَّثَنِي عَبْدُ اللَّهِ بْنُ عَبْدِ الرَّحْمَنِ الدَّارِمِيُّ، قَالَ سَمِعْتُ أَبَا نُعَيْمٍ، ‏.‏ وَذَكَرَ الْمُعَلَّى بْنَ عُرْفَانَ فَقَالَ قَالَ حَدَّثَنَا أَبُو وَائِلٍ، قَالَ خَرَجَ عَلَيْنَا ابْنُ مَسْعُودٍ بِصِفِّينَ ‏.‏ فَقَالَ أَبُو نُعَيْمٍ أَتُرَاهُ بُعِثَ بَعْدَ الْمَوْتِ", "grades": "", "reference": "", "international_number": "7450", "narrator_chain": "Abd Allah bin Abd ar-Rahman ad-Dārimī narrated to me, he said:"}
{"hadithnumber": "7451", "arabic": "حَدَّثَنِي عَمْرُو بْنُ عَلِيٍّ، وَحَسَنٌ الْحُلْوَانِيُّ، كِلاَهُمَا عَنْ عَفَّانَ بْنِ مُسْلِمٍ، قَالَ كُنَّا عِنْدَ إِسْمَاعِيلَ ابْنِ عُلَيَّةَ فَحَدَّثَ رَجُلٌ، عَنْ رَجُلٍ، فَقُلْتُ إِنَّ هَذَا لَيْسَ بِثَبْتٍ ‏.‏ قَالَ فَقَالَ الرَّجُلُ اغْتَبْتَهُ ‏.‏ قَالَ إِسْمَاعِيلُ مَا اغْتَابَهُ ‏.‏ وَلَكِنَّهُ حَكَمَ أَنَّهُ لَيْسَ بِثَبْتٍ ‏.‏", "grades": "", "reference": "", "international_number": "7451", "narrator_chain": "Amr bin Alī and Hasan al-Hulwānī narrated to me, both of them on authority of Affān bin Muslim, he said:"}
{"hadithnumber": "7452", "arabic": "وَحَدَّثَنَا أَبُو جَعْفَرٍ الدَّارِمِيُّ، حَدَّثَنَا بِشْرُ بْنُ عُمَرَ، قَالَ سَأَلْتُ مَالِكَ بْنَ أَنَسٍ عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ الَّذِي، يَرْوِي عَنْ سَعِيدِ بْنِ الْمُسَيَّبِ، فَقَالَ لَيْسَ بِثِقَةٍ ‏.‏ وَسَأَلْتُهُ عَنْ صَالِحٍ، مَوْلَى التَّوْأَمَةِ فَقَالَ لَيْسَ بِثِقَةٍ ‏.‏ وَسَأَلْتُهُ عَنْ أَبِي الْحُوَيْرِثِ فَقَالَ لَيْسَ بِثِقَةٍ ‏.‏ وَسَأَلْتُهُ عَنْ شُعْبَةَ الَّذِي رَوَى عَنْهُ ابْنُ أَبِي ذِئْبٍ فَقَالَ لَيْسَ بِثِقَةٍ ‏.‏ وَسَأَلْتُهُ عَنْ حَرَامِ بْنِ عُثْمَانَ فَقَالَ لَيْسَ بِثِقَةٍ ‏.‏ وَسَأَلْتُ مَالِكًا عَنْ هَؤُلاَءِ الْخَمْسَةِ فَقَالَ لَيْسُوا بِثِقَةٍ فِي حَدِيثِهِمْ ‏.‏ وَسَأَلْتُهُ عَنْ رَجُلٍ آخَرَ نَسِيتُ اسْمَهُ فَقَالَ هَلْ رَأَيْتَهُ فِي كُتُبِي قُلْتُ لاَ ‏.‏ قَالَ لَوْ كَانَ ثِقَةً لَرَأَيْتَهُ فِي كُتُبِي ‏.‏", "grades": "", "reference": "", "international_number": "7452", "narrator_chain": "Abū Ja’far ad-Dārimī narrated to us, Bishr bin Umar narrated to us, he said:"}
{"hadithnumber": "7453", "arabic": "وَحَدَّثَنِي الْفَضْلُ بْنُ سَهْلٍ، قَالَ حَدَّثَنِي يَحْيَى بْنُ مَعِينٍ، حَدَّثَنَا حَجَّاجٌ، حَدَّثَنَا ابْنُ أَبِي ذِئْبٍ، عَنْ شُرَحْبِيلَ بْنِ سَعْدٍ، وَكَانَ، مُتَّهَمًا ‏.‏", "grades": "", "reference": "", "international_number": "7453", "narrator_chain": "Al-Faḍl bin Sahl narrated to me, he said:"}
{"hadithnumber": "7454", "arabic": "وَحَدَّثَنِي مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ قُهْزَاذَ، قَالَ سَمِعْتُ أَبَا إِسْحَاقَ الطَّالَقَانِيَّ، يَقُولُ سَمِعْتُ ابْنَ الْمُبَارَكِ، يَقُولُ لَوْ خُيِّرْتُ بَيْنَ أَنْ أَدْخُلَ الْجَنَّةَ وَبَيْنَ أَنْ أَلْقَى عَبْدَ اللَّهِ بْنَ مُحَرَّرٍ لاَخْتَرْتُ أَنْ أَلْقَاهُ ثُمَّ أَدْخُلَ الْجَنَّةَ فَلَمَّا رَأَيْتُهُ كَانَتْ بَعْرَةٌ أَحَبَّ إِلَىَّ مِنْهُ ‏.‏", "grades": "", "reference": "", "international_number": "7454", "narrator_chain": "Muhammad bin Abd Allah bin Quhzādh narrated to me, he said, I heard Abū Ishāq at-Tālqānī saying, I heard Ibn al-Mubārak saying:"}
{"hadithnumber": "7455", "arabic": "وَحَدَّثَنِي الْفَضْلُ بْنُ سَهْلٍ، حَدَّثَنَا وَلِيدُ بْنُ صَالِحٍ، قَالَ قَالَ عُبَيْدُ اللَّهِ بْنُ عَمْرٍو قَالَ زَيْدٌ يَعْنِي ابْنَ أَبِي أُنَيْسَةَ لاَ تَأْخُذُوا عَنْ أَخِي، ‏.‏", "grades": "", "reference": "", "international_number": "7455", "narrator_chain": "Al-Faḍl bin Sahl narrated to me, Walīd bin Sālih narrated to us, he said, Ubayd Allah bin Amr said, Zayd- meaning Ibn Abī Unaysah – said:"}
{"hadithnumber": "7456", "arabic": "حَدَّثَنِي أَحْمَدُ بْنُ إِبْرَاهِيمَ الدَّوْرَقِيُّ، قَالَ حَدَّثَنِي عَبْدُ السَّلاَمِ الْوَابِصِيُّ، قَالَ حَدَّثَنِي عَبْدُ اللَّهِ بْنُ جَعْفَرٍ الرَّقِّيُّ، عَنْ عُبَيْدِ اللَّهِ بْنِ عَمْرٍو، قَالَ كَانَ يَحْيَى بْنُ أَبِي أُنَيْسَةَ كَذَّابًا ‏.‏", "grades": "", "reference": "", "international_number": "7456", "narrator_chain": "Ahmad bin Ibrāhīm ad-Dawraqī narrated to me, he said, Abd us-Salām al-Wābisī narrated to me, he said, Abd Allah bin Ja’far ar-Raqqī narrated to me, on authority of Ubayd Allah bin Amr, he said:"}
{"hadithnumber": "7457", "arabic": "حَدَّثَنِي أَحْمَدُ بْنُ إِبْرَاهِيمَ، قَالَ حَدَّثَنِي سُلَيْمَانُ بْنُ حَرْبٍ، عَنْ حَمَّادِ بْنِ زَيْدٍ، قَالَ ذُكِرَ فَرْقَدٌ عِنْدَ أَيُّوبَ فَقَالَ إِنَّ فَرْقَدًا لَيْسَ صَاحِبَ حَدِيثٍ ‏.‏", "grades": "", "reference": "", "international_number": "7457", "narrator_chain": "Ahmad bin Ibrāhīm narrated to me, he said, Sulaymān bin Harb narrated to me, on authority of Hammād bin Zayd, he said, Farqad was mentioned near Ayyūb, so he said:"}
{"hadithnumber": "7458", "arabic": "وَحَدَّثَنِي عَبْدُ الرَّحْمَنِ بْنُ بِشْرٍ الْعَبْدِيُّ، قَالَ سَمِعْتُ يَحْيَى بْنَ سَعِيدٍ الْقَطَّانَ، ذُكِرَ عِنْدَهُ مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ عُبَيْدِ بْنِ عُمَيْرٍ اللَّيْثِيُّ فَضَعَّفَهُ جِدًّا ‏.‏ فَقِيلَ لِيَحْيَى أَضْعَفُ مِنْ يَعْقُوبَ بْنِ عَطَاءٍ قَالَ نَعَمْ ‏.‏ ثُمَّ قَالَ مَا كُنْتُ أُرَى أَنَّ أَحَدًا يَرْوِي عَنْ مُحَمَّدِ بْنِ عَبْدِ اللَّهِ بْنِ عُبَيْدِ بْنِ عُمَيْرٍ ‏.‏", "grades": "", "reference": "", "international_number": "7458", "narrator_chain": "Abd ur-Rahman bin Bishr al-Abdī narrated to me, he said, I heard Muhammad bin Abd Allah bin Ubayd bin Umayr al-Laythī was mentioned near Yahyā bin Sa’īd al-Qattān, so he weakened him severely. Then it was said to Yahyā:"}
{"hadithnumber": "7459", "arabic": "حَدَّثَنِي بِشْرُ بْنُ الْحَكَمِ، قَالَ سَمِعْتُ يَحْيَى بْنَ سَعِيدٍ الْقَطَّانَ، ضَعَّفَ حَكِيمَ بْنَ جُبَيْرٍ وَعَبْدَ الأَعْلَى وَضَعَّفَ يَحْيَى مُوسَى بْنَ دِينَارٍ قَالَ حَدِيثُهُ رِيحٌ ‏.‏ وَضَعَّفَ مُوسَى بْنَ دِهْقَانَ وَعِيسَى بْنَ أَبِي عِيسَى الْمَدَنِيَّ ‏.‏ قَالَ وَسَمِعْتُ الْحَسَنَ بْنَ عِيسَى، يَقُولُ قَالَ لِيَ ابْنُ الْمُبَارَكِ إِذَا قَدِمْتَ عَلَى جَرِيرٍ فَاكْتُبْ عِلْمَهُ كُلَّهُ إِلاَّ حَدِيثَ ثَلاَثَةٍ لاَ تَكْتُبْ حَدِيثَ عُبَيْدَةَ بْنِ مُعَتِّبٍ وَالسَّرِيِّ بْنِ إِسْمَاعِيلَ وَمُحَمَّدِ بْنِ سَالِمٍ ‏.‏", "grades": "", "reference": "", "international_number": "7459", "narrator_chain": "Bishr bin al-Hakam narrated to me, he said, I heard Yahyā bin Sa’īd al-Qattān weaken Hakīm bin Jubayr and Abd al-A’lā; and he weakened Yahyā Mūsā bin Dīnār  said:"}
{"hadithnumber": "7460", "arabic": "حَدَّثَنَا  مُحَمَّدُ بْنُ رَافِعٍ ، حَدَّثَنَا  يَحْيَى بْنُ آدَمَ ، حَدَّثَنَا  زُهَيْرٌ . ح حَدَّ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7460", "narrator_chain": ""}
{"hadithnumber": "7461", "arabic": "وحَدَّثَنَا  مُحَمَّدُ بْنُ الْمُثَنَّى ،  وَابْنُ بَشَّارٍ وَاللَّفْظُ لِابْنِ الْمُثَنَّى، قَالَا:", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7461", "narrator_chain": ""}
{"hadithnumber": "7462", "arabic": "حَدَّثَنِي حَدَّثَنِي  أَبُو الطَّاهِرِ أَحْمَدُ بْنُ عَمْرِو بْنِ سَرْحٍ ، أَخْبَرَنَا  ابْنُ وَهْب", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7462", "narrator_chain": ""}
{"hadithnumber": "7463", "arabic": "(حديث موقوف) قَالَ  أَبُو عَبْدِ الرَّحْمَنِ : وَجَاءَ ثَلَاثَةُ نَفَرٍ إِلَى  عَبْدِ اللَّهِ بْنِ ع", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7463", "narrator_chain": ""}
{"hadithnumber": "7498", "arabic": "حَدَّثَنَا  قُتَيْبَةُ بْنُ سَعِيدٍ ، حَدَّثَنَا  لَيْثٌ ، عَنْ  عُقَيْلٍ ، عَنْ  الزُّهْرِيِّ ، عَن", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7498", "narrator_chain": ""}
{"hadithnumber": "7499", "arabic": "وحَدَّثَنِيهِ  أَبُو الطَّاهِرِ ،  وَحَرْمَلَةُ بْنُ يَحْيَى ، قَالَا: أَخْبَرَنَا ابْنُ وَهْبٍ ، عَ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7499", "narrator_chain": ""}
{"hadithnumber": "7512", "arabic": "حَدَّثَنَا  هَارُونُ بْنُ مَعْرُوفٍ ،  وَمُحَمَّدُ بْنُ عَبَّادٍ ، وَتَقَارَبَا فِي لَفْظِ الْحَدِيث", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7512", "narrator_chain": ""}
{"hadithnumber": "7513", "arabic": "قَالَ: فَقُلْتُ لَهُ: أَنَا يَا عَمِّ لَوْ أَنَّكَ أَخَذْتَ بُرْدَةَ غُلَامِكَ وَأَعْطَيْتَهُ مَعَاف", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7513", "narrator_chain": ""}
{"hadithnumber": "7514", "arabic": "(حديث موقوف) ثُمَّ مَضَيْنَا حَتَّى أَتَيْنَا  جَابِرَ بْنَ عَبْدِ اللَّهِ فِي مَسْجِدِهِ وَهُوَ يُص", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7514", "narrator_chain": ""}
{"hadithnumber": "7515", "arabic": "سِرْنَا مَعَ رَسُولِ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ فِي غَزْوَةِ بَطْنِ بُوَاطٍ وَهُوَ يَ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7515", "narrator_chain": ""}
{"hadithnumber": "7516", "arabic": "سِرْنَا مَعَ رَسُولِ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ حَتَّى إِذَا كَانَتْ عُشَيْشِيَةٌ، وَ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7516", "narrator_chain": ""}
{"hadithnumber": "7517", "arabic": "سِرْنَا مَعَ رَسُولِ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ، وَكَانَ قُوتُ كُلِّ رَجُلٍ مِنَّا فِ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7517", "narrator_chain": ""}
{"hadithnumber": "7518", "arabic": "سِرْنَا مَعَ رَسُولِ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ حَتَّى نَزَلْنَا وَادِيًا أَفْيَحَ، ف", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7518", "narrator_chain": ""}
{"hadithnumber": "7519", "arabic": "قَالَ: فَأَتَيْنَا الْعَسْكَرَ، فَقَالَ رَسُولُ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ: يَا جَابِ", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7519", "narrator_chain": ""}
{"hadithnumber": "7555", "arabic": "حَدَّثَنِي حَدَّثَنِي  أَبُو بَكْرِ بْنُ نَافِعٍ الْعَبْدِيُّ ، حَدَّثَنَا  عَبْدُ الرَّحْمَنِ ، حَد", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7555", "narrator_chain": ""}
{"hadithnumber": "7557", "arabic": "وحَدَّثَنِي وحَدَّثَنِي  حَجَّاجُ بْنُ الشَّاعِرِ ، حَدَّثَنَا  عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَار", "grades": "", "reference": "Book 0, Hadith 0", "international_number": "7557", "narrator_chain": ""}
