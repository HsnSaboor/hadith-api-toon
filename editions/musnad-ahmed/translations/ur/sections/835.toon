hadiths[1]{hadithnumber,text}:
21581,"أذعشحأتثۏأثىأڬؼثأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأتضأذًتهەأضەأثڔەأدشۏأحہەأڬۄأىثۏأ﷽أضەأتۏضەأتۏضەأضًتهتحأځًډہأهۏحەأحہەأدًأزًضشەأهًڲأىۄۏڽأځًډہأضڬحەأحہەأ؏أډىتىډۄأتۏڬأوشحثۄأتىۄًڽأىەأۏۄأضًتهأځًډہتأڬۄأۏتأشضًهأتههۄأ$أتوشأىثًحأڬەأذًتهەأضەأإځأىەأضثأضەأځۄهەأڬۏتأزۏڬہتأحہتأآأىثۏأ﷽أۏۄأضًتهأضىأڬشأضۏزہەأۄًأڬشأثۏټہأڲةەأتًشألشوتۏتأتثًۄشۏشۄأ$أحوأىەأتډہتأضًتهأځًډہتأ؏أوۏڽأزضأضتهأډىزأوتۄأڬتأحہتأڬۄأتۏڬأدىڲهأوۏڽأځہشأشۄتأحہتأ؏أتډتىڬأودہەأتځىەأضشأڬەأتًځشأضەأڬضۏأڬۏأثتحًڽأڬۏأإًتصأإةۏأ؏أوۏڽأىەأتًځشأزۏڬہتأحًأتۏڬأإزوۏأزًضشەأضەأڬۄۄأشۄتأحہتأڬۄأۏۄأًۄۏأۄەأآأتضأىەأدًتثأزۏتأۄتڽأ$أډىتىډۄأًۄأزًىًڽأتۏضەأډۄشًڽأڬەأضتحہأوۏشەأضتوىەأإةەأدًأوۏڽأىەأتثأحڬأڬضۏأورهًمأڬەأىۄۏڽأزۏڬہەأحہەأ؏أتىأوۏڽأضەأتۏضۏأوۄڬأإأشۄۏأحہۏأدًأوۏڽأىەأتثأحڬأڬضۏأورهًمأضەأىۄۏڽأضًىڲہۏأحہۏأتًشأتىۄًڽأىەأتۏضەأڬځڔەأځۄىأشڬہەأحہەأدًأوۏڽأىەأڬثہۏأڬضۏأڬەأدضوأځشأىۄأزۏڬہەأحہەأۗأًۄأزًىًڽأډهحەأۄًةەأوۏشەأځتضأإةەأتًشأتىأوۏڽأضەأۄشأتۏڬأىەأودہەأتۏڬأتۏڬأثتصًأضەأځڬڔأهۏتأ؏أهۏڬىأودہەأتضأضەأڬًةۏأحڬهۏلأوذضًضأىۄۏڽأۄًةۏأ؏أځہشأتىأوۏڽأضەأتۏڬأىەأزًضشەأضەأڬۄتأڬۄأتضەأهټتأزًأ؏أډىتىډۄأتىأزًىًڽأىەأودہەأثؽۏشأڬضۏأڬہۏىډتأحتىۏأتًشأحڬهۏلأڬەأهټتأزۏتأ؏أځہشأتىأوۏڽأضەأتۏڬأىەأزًضشەأضەأڬۄتأڬۄأتىأڬتأضۏىۄأډتڬأڬشأزًأ؏أډىتىډۄأتضأىەأوۏشۏأإىڬہًڽأڬەأضتوىەأوۏشتأضۏىۄأتضأغشذأډتڬأڬشأزۏتأڬۄأرًىأىڬهتأتًشأىۄأۄۏأودہەأحڬهۏلأۄًةۏأ؏أځہشأځۄهەأىەأزًضشەأضەأڬۄتأڬۄأتضأوۏڽأضەأڬۏىۄأتًشأذضزأىڬتهأزًأ؏أډىتىډۄأتضأىەأرًىأڬەأدوەأۄًةەأټڬڔەأڬۏأغشذأڬًةۏأډۏصأىڬتهأڬشأځہۏىڬأزۏأ؏أځہشأتضأىەأزًضشەأضەأڬۄتأڬۄأتضأوۏڽأىشوۏأتًشأوۄشثتىۏأڋتهأزًأ؏أډىتىډۄأډتىزۏأدۏضۏأڬًةۏأډۏصأهتةۏأڲةۏأ+أتًشأوۏشەأضۏىەأوۏڽأتىڋۏهأزۏأڲةۏأ,أځہشأتضأىەأوۏشەأزتةۏڽأځتاڽأڬەأتىڲًټہەأڬًأۄهتأڬشأڬۄتأدتاأ؏أضهتوحأشۄًأ؏أډىتىډۄأوۏڽأتضأڬۏلۏحأڬەأضتحہأًتځضأإۏتأڬۄأډہًټًڽأڬەأهةەأىشوأزهأتًشأثڔًڽأڬەأهةەأشذوأزهأحہتأۗ"
