2191,"أتثىأثشۏزۄأتځىەأًتهزأضەأثۏتىأڬشحەأۄۏڽأڬۄأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أدثأۄوأثۏحأتهومزضأځۄىډەأحًأدثشۏهأؼهۏۄأتهضهتوأىەأتځىۏأتىڲهۏأضەأځحہشأوۏڽأضًشترأڬۏتأتًشأثشتمأڬًأتضأڬەأضتحہأثتىزہأزۏتۗ

[تخریج]: الصحيحة رقم (3487) سنن الترمذي بَاب وَمِنْ سُورَةِ بَنِي إِسْرَائِيلَ كِتَاب تَفْسِيرِ الْقُرْآنِ رقم (3057) المستدرك للحاكم رقم (3327) ."
2192,"ؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأضەأوشًۏأۄەأڬۄأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=دضأشتحأودہەأوؼشتدأڬشًتةۏأڲةۏ؏أتًشأظثذأوڬەأوۏڽأڬۏأحًأوۏڽأتځىەأوؼتوهەأضەأځشۏطتىأۄًأڲۏتأتًشأودہەأوؼهًوأۄًأڲۏتأڬۄأهًڲأودہەأدہټهتةۏڽأڲە؏أإځأؽوڲۏىأۄًأڬشأؼهۏذزۄأثۏټہأڲةەۗأتههۄأڬتأزطوىأتثًأدۄهأڲصشتأتًشأإڬشأإځأڬەأځتضأثۏټہأڲۏت؏أتًشأتضحۄصتؤأڬشحەأۄًةەأإځأضەأڬۄىەأهڲت=أڬۏتأڬًةۏأىةۏأثتحأۄًأڲةۏأۄەآأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أۄتڽۗأتثًأدۄهأىەأڬۄت=أًۄأڬۏتآأإځأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أإدأشتحأودہەأضۏشأڬشًتةۏأڲةۏۗأتثًأدۄهأىەأڬۄتأ=ڬضأغشلآأإځأىەألشوتۏت=أثۏحأتهومزضأڬۏأغشلأتثًأدۄهأڬۄىەأهڲت=أځہشأإځأىەأظثذأۏۄتڽأۄوتشەأزشوۏتىأڬۏآأإځأىەألشوتۏت=أۄتڽۗأتثًأدۄهأىەأإځأڬۏأحڬسۏثأتضأڋشأضەأوىتضثأىۄأضودہۏأڬۄأدثأًۄأتځىۏأمًوأڬًأثهتةەأڲتأحًأڬۄۏڽأإځأتضأثتحأڬتأتىڬتشأىۄأڬشأزۏڽۗأڬۄىەأهڲتأ=إځأڬەأرۏتهأوۏڽأتڲشأوۏڽأإځأڬۏأمًوأڬًأثهتًٗڽأحًأڬۏتأإځأتىۄۏڽأثہۏأًۄۏأثتحأثحتةۏڽأڲەأدًأودہەأثحتةۏأۄەآأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أۄتڽۗأتثًأدۄهأځڬتشىەأهڲت=أثىۏأڬؼثأثىأهًةۏأڬەأهًڲً$أإًٗ؏أهًڲأإځأڬۏأغشلأإىەأهڲەأتًشأإڬشأتىأزًىًڽأڬەأځتضأثۏټہأڲةەۗأتثًأدۄهأڬۄىەأهڲت=أتځىۏأمًوأڬًأثہۏأًۄۏأثۏتىأڬۏدةەأدًأودہەأثحتۏتأۄەأۗشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=إدأشتحأودہەأضۏشأڬشًتةۏأڲةۏأۄەأۗأهًڲًڽأىەأڬۄت=ڬضأغشلآإځأىەألشوتۏت=أثۏحأتهومزضأڬۏأغشلۗأهًڲأڬۄىەأهڲە=أځہشأإځأۄوتشەأزشوۏتىأأڬہڔەأۄۏڽآأإځأىەألشوتۏت=أۄتڽ؏أڬډہأهًڲأحتهۏتڽأثدتىەأهڲە؏تًشأڬډہأهًڲًڽأىەأإځأڬەأڲوتىأڬەأوغتثمأدہًټأځشأحؼدثأڬشحەأۄًةەأتځىەأۄتحہأضشًڽأځشأشڬہأهةەۗأهًڲًڽأىەأڬۄت=أڬۏتأإځأۄوۏڽأتضأوضدزأڬۏأظلتحأثۏتىأڬشأۏڽأڲەآأڬډہأهًڲأتۏضەأثہۏأحہەدىۄًڽأىەأتضأؼهتمەأڬتأضلشأڬۏتأحہتأتًشأوضدزأزۏڬہۏأحہۏۗأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أوۏڽأتىۄۏڽأثحتىەأهڲتۗأوۏڽأتىۄۏڽأثحتشۄتأحہتأڬۄأڬًةۏأًظلأودہأځشأرهغأوهغأۄًڲۏتۗأإځأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أځہشأوضدزأڬًأ+وۏشەأضتوىە,هتۏتأڲۏت؏أوۏڽأزۏڬہأشۄتأحہتأذحۏأڬۄأؼمتهأۏتأؼمۏهأڬەأزشًتصەأڬەأځتضأشڬہأزۏأڲةۏأوۏڽأتضأڬتأًظلأثۏتىأڬشىەأهڲتأتًشأوۏڽأتضأڬۏأغشلأزۏڬہأشۄتأحہتۗأؼثزتههۄأثىأؼثتضأىەأڬۄتأڬۄ=أتضأذزۏخأوۏڽأشضًهأتههۄأڬتأثۏتىأڬشزۄأثۏحأتهومزضأڬتأًظلأثہۏأحہتأهۏڬىأًۄأودہەأۏتزأىۄۏڽأشۄتۗأهًڲًڽأىەأڬۄت=أۏۄأًظلأًتههۄأزشضحأثحتۏتۗ

[تخریج]: الصحيحة رقم (3021) مسند أحمد رقم (2680) دلائل النبوة للبيهقي (برقم  : 656) ."
2193,"ؼثزتههۄأثىأوضؼًز‏شعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄحەأۄۏڽأڬۄأۄوأؽصًۄأثزشأوۏڽأحہە؏أۄوأوۏڽأضەأحۏىأحۏىأإزوۏأتۏڬأتۏڬأتًىټأځشأ+ثتشۏأثتشأضًتشأۄًحە,حہە؏أؼهۏأتًشأتثًأهثتثۄأأأشعۏأتههۄأؼىۄوتأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأڬەضتحہۏأحہەۗأدثأىثۏأظهۏأتههۄأؼهۏۄأًضهوأڬۏأثتشۏأإةۏأحًأزًىًڽأىەأڬۄت=أتەأتههۄأڬەأشضًهأضًتشأۄًأدتةۏە؏أۄوأځۏزهأډهحەأۄۏڽۗأإځأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أحوأزًىًڽأودہأضەأصۏتزۄأځۏزهأډهىەأځشأمتزشأىۄۏڽأۄً؏أتًشأىۄأوۏڽأخًتثأوۏڽأحوأضەأڬوأوذحتدأۄًڽۗ

[تخریج]: الصحيحة رقم (2257) مسند أحمد رقم (3807) بغية الحارث ."
2194,"تثًأۄشۏشۄ‏شعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=ىۄأوۏڽأحوۄۏڽأڬًةۏأډۏصأزۏحتأۄًڽ؏أىۄأڬًةۏأډۏصأشًڬحتأۄًڽۗأوۏڽأحًأتههۄأڬۏأغشلأوتوًشأرتصىأۄًڽ؏أدۏضتذڬوأزۏتأدتحتأۄەأًۏضتأۄۏأڬشحتأۄًڽۗأ

[تخریج]: الصحيحة رقم (2221) سنن أبي داؤد كِتَاب الْخَرَاجِ وَالْإِمَارَةِ وَالْفَيْءِ بَاب فِيمَا يَلْزَمُ الْإِمَامُ ...رقم (2560) مسند أحمد رقم (7808)"
2195,"تثىأثشۏزۄأتځىەأًتهزأضەأوشلًؼتَأثۏتىأڬشحەأۄۏڽأڬۄأ=أتههۄأڬەأهةەأدحىۏأحڬهۏلأودہەزۏأڲةۏأڬضۏأتًشأطرظأڬًأىۄۏڽأزۏأڲةۏ

[تخریج]: الصحيحة رقم (2222) الديلمي (4/51)."
2196,"ؼتةطۄأشعۏأتههۄأؼىۄتأڬۄحۏأۄۏڽأڬۄأ=إځأظهۏأتههۄأؼهۏۄأًضهوأتضأًمحأحڬألًحأىۄۏڽأۄًةەأدثأحڬأتههۄأحؼتهۏٳأىەأإځأڬەأهةەأذهتهأىۄۏڽأڬشأزۏتأڬۄأدضأؼًشحأضەأډتۄۏڽأطتزۏأڬشأهۏڽۗ

[تخریج]: الصحيحة رقم (3224) سنن الدارمي رقم (2296)."
2197,"ؼتةطۄأشعۏأتههۄأؼىۄتأضەوشًۏأۄەڬۄحۏأۄۏڽأڬۄأإځأظهۏأتههۄأؼهۏۄأًضهوأىەأتځىەأۄتحہأضەأڬثہۏأڬضۏأرتزوأۏتأؼًشحأڬًأىۄۏڽأوتشت؏أىۄأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأىەأڬضۏأأڬًأڬثہۏأوتشت؏أظشلأتضأًمحأدثأإځأتههۄأڬەأشتضحەأوۏڽأدتتزأڬشأشۄەأۄًحە؏أتًشأدثأثہۏأإځأڬًأزًأوؼتوهًڽأڬەأزشوۏتىأترحۏتشأزۏتأڲۏتأإځأىەأإضتىأوؼتوهۄأڬًأځضىزأڬۏتۗأدثأحڬأڬۄأًۄأڲىتۄأىۄأۄًأدثأڬًةۏأڲىتۄأڬتأڬتوأۄًحتأحًأإځأضثأضەأصۏتزۄأزًشأۄًحەۗأإځأىەأتځىەأهةەأڬضۏأضەأتىحمتوأىۄۏڽأهۏتأضًتةەأتضأڬەأڬۄأتههۄأڬۏأذشوتحأڬۏأىتألشوتىۏأڬۏأدتحۏۗأتضأظًشحأوۏڽأإځأتههۄأؼصًدهأڬەأهةەأتىحمتوأهۏحەۗ

[تخریج]: الصحيحة رقم (507) مسند أحمد رقم (24765) ."
2198,"ؼثزتههۄأثىأوضؼًز‏شعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄحەأۄۏڽأڬۄأمشۏطأڬەأڬډہأضشزتشأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأڬەأځتضأضەأڲصشە؏أإځأڬەأځتضأظۄۏث؏أثهته؏أؼوتش؏أرثتثأشعۏأتههۄأؼىۄوأتًشأتىأدۏضەأڬوصًشأوضهوتىأثۏټہەأحہەۗأڬۄىەأهڲە=تەأوذوز+أظهۏأتههۄأؼهۏۄأًضهوأ,$تىۄۏڽأزہحڬتشأزۏدةە؏أڬۏتأإځأىەأتځىۏأمًوأوۏڽأضەأتىۄۏڽأځضىزأڬۏتأۄەآأڬۏتأۄوأتىأڬەأځۏډہەأهڲۏڽآأڬۏتأۏۄۏأهًڲأۄۏڽأدىأځشأتههۄأحؼتهۏٳأىەأتذضتىألشوتۏتآأووڬىأۄەأتڲشأإځأتىۄۏڽأزہحڬتشأزۏڽأحًأۄوأإځأڬەأځتضأإدتةۏڽۗحثأۏۄأإۏحأىتصهأۄًةۏ=+تهتىؼتو=۸۵,حشدوۄ=تًشأتۏضەأهًڲًڽأڬًأڋشتةۏەأدًأتضأثتحأضەأتىزۏطۄأشڬہحەأۄۏڽأڬۄأتځىەأشثأڬەأځتضأتۏضۏأذتهحأوۏڽأدوؼأڬةەأدتةۏڽأڲەأڬۄأدحىەأؽۏشأتههۄأۄۏڽأىۄأڬًةۏأتىأڬتأوززڲتشأۄًڲتأتًشأىۄأڬًةۏأطلۏؼأۄًڲت؏أتضأتوۏزأځشأڬۄأًۄأڋشأدتةۏڽۗأأتًشأتىأهًڲًڽأڬًأىۄأىڬتهۏەأدًأظثذأًطتوأتځىەأځشًشزڲتشأڬۏأؼثتزحأڬشحەأۄۏڽ؏أرتظأتضۏأڬۏأشعتوىزۏأڬتأمظزأشڬہحەأۄۏڽۗتىأڬتأذضتثأسشتأثہۏأإځأڬەأوحؼهمأىۄۏڽأتًشأإځأڬتأذضتثأسشتأثہۏأتىأڬەأوحؼهمأىۄۏڽأڬۄأإځأتىأڬًأىڬتهأزۏڽًۗشىۄأإځأػهوأڬشىەأًتهًڽأوۏڽأضەأۄًدتةۏڽأڲەۗ

[تخریج]: الصحيحة رقم (3297) مسند الزخار رقم (1802) ."
2199,"ؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأڬۄحەأۄۏڽأڬۄأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأ+وڬەأڬۏأغشلأ,ډهەأحًأوزۏىەأځشأتثًأشۄوأڬهخًوأثىأذضۏىأؽلتشۏأشعۏأتههۄأؼىۄأأڬًأىڲشتىأومششأڬۏتۗأزضأشوعتىأڬًأضلشأځشأىڬهە؏أشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأتًشأظذتثۄأىەأشًصۄأشڬہتأۄًتأحہتۗأدثأ+ڬزۏزأ,وۏڽأځۄىډەأدًأؼضلتىأتًش+أتود,أڬەأزشوۏتىأۄەۗحًأإځأىەتلغتشأڬشأهۏت؏أځہشأډهأځڔەأدثأزضأۄصتشأڬەأهطڬشأڬەأضتحہأدضأوۏڽأأوصۏىۄأضهۏوأتًشأۄشأمثۏهەأضەأوضهوتىًڽأڬۏأتډہۏأرتظۏأحؼزتزأوًدًزأحہۏۗأ+وشتهػۄشتى,أوۏڽأځڔتًٗأڋتهت؏أوۄتدشۏىأًأتىظتشأضثأڬەأضثأإځأظهۏأتههۄأؼهۏۄأًضهوأڬەأضتحہأىڬهە؏أڬًةۏأثہۏأطرظأإځأضەأځۏډہەأىۄۏڽأشۄت؏أدثأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأىەأ+وشتهػۄشتى,أوۏڽأځڔتًٗأڋتهت؏أمشۏطأضەأرثشًڽأڬتأضهضهۄأوىمغؼأۄًڲۏتأحہت؏أتًشأتىۄۏڽأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأڬۏأڬًةۏأتغهتؼأىۄۏڽأحہۏۗأىۄأۏۄأدتىحەأحہەأڬۄأإځأڬۏتأڬشىەأًتهەأۄۏڽآأتضأشتحأتثًأضلۏتىأثىأذشث؏أذڬۏوأثىأذصتوأتًشأثزۏهأثىأًشمتؤأۏۄأزۏڬہىەأڬەأهةەثتۄشأىڬهەأڬۄأڬۏتأتىۄۏڽأڬًةۏأرثشأۏتأڬًةۏأضىأڲىأوهحۏأۄەآأؼثتضأثىأؼثزتهوغهثأأشعۏأتههۄأؼىۄأأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأضەأشتضحەأوۏڽأإوهەأحہەۗأتًشأتثًضلۏتىأثىأذتشخأثىأؼثزتهوغهثأتًشأؼثزتههۄأثىأتوۏۄأثىأوؽۏشۄأثہۏأوڬۄأتًشأوزۏىۄأڬەأزشوۏتىأإةەأتًشأإځأضەأوهىەأڬۏأرًتۄطأڬۏۗأتوأضهوۄأشعۏأتههۄأؼىۄتأىەأتىأزًىًڽأڬەأثتشەأوۏڽأثتحأډۏحأڬۏأۗڬۄىەأهڲۏڽ=أتەأتههۄأڬەأشضًه$أإځأڬەأډډتأڬتأثۏټتأتًشأځہًځہۏأڬتأثۏټتأتًشأزتوتزۗإځأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أودہەأتىأزًىًڽأضەأڬًةۏأؽشعأىۄۏڽۗأوۏشەأډډتأڬەأثۏټەأىەأوۏشۏأؼصحأرشتثأڬۏأۄە؏أتًشأوۏشۏأځہًځہۏأڬەتضأثۏټەأىەأوڬەأوۏڽأڬۏتأڬډہأىۄۏڽأأڬۄتۗأدثأتىأڬۏأغشلأۏۄأځۏؽتوأځۄىډتأحًأتثًأضلۏتىأڬەأضتحہأتضأڬتأډہًټتأثۏټتأثہۏأحہت؏أڬۄىەأهڲت=ًتههۄأۏتأحًإځأودہەأتدتصحأزەأزۏڽأۏتأوۏڽأتځىەأتضأثۏټەأڬتأۄتحہأځڬڔأڬشأثۏتثتىأوۏڽأىڬهأدتًٗڽأڲتۗأۏۄتڽأحڬأڬۄأۄوأثہًڬأتًشأځۏتضأضەأوشأدتةۏڽأۗأدثأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأحڬأۏۄأثتحأځۄىډۏأحًأإځأڬتأزهأىشوأۄًڲۏتۗأځہشأتىأزًىًڽأڬًأتدتصحأزەأزۏ؏أًۄأزًىًڽأإځأڬۏأرزوحأوۏڽأذتعشأۄًةەأتًشأتضهتوأمثًهأڬشأهۏتۗأدثأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأىەأوشتهػۄشتىأوۏڽأځڔتًٗأڋتهتأحًأؼثتضأشعۏأتههۄأؼىۄأأأڬۄىەأهڲەأمشۏطأڬۏأظثذأثشۏأذتهحأۄًڲۏۗأًتههۄ$أتڲشأشضًهأتههۄأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏مشۏطأڬەأتوتىأغهثأڬشىەأضەأځۄهەأدىڲأڬشحەأۄًةەأأوڬەأوۏڽأزترهأۄًڲةەأحًأۏۄأۄوۏطۄأڬەأهةەأمشۏطأڬۏأۄهتڬحأۄەۗأځہشأوۏڽأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأڬەأضلۏزأرډشأځشأثۏټہتأتًشأتضأځشأثۏټہأڬشأتشتڬأحڬأإڲۏتۗأوۏڽأىەضًډت=أطتۏزأوۏڽأڬضۏأهڬڔۄتشە؏أزًزہأًتهەأۏتأڬضۏأعشًشحوىزأضەأوهًڽأحتڬۄأًۄأوڬۄأًتهًڽأڬًأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأڬەأځڔتًٗأڬۏأرثشأزەأتًشأوڬەأًتهەأوڬەأوۏڽأدىڲۏأذتهحأوۏڽأزترهأۄًىەأضەأځۄهەأإځأظهۏأتههۄأؼهۏۄأًضهوأڬەأځتضأإڬشأإځأضەأتوتىأغهثأڬشۏڽأۗأًتههۄ$أوۏڽأتضأځشأضًتشأڬضۏأطرظأڬًأحهتطأڬشحتأشۄتأڬۄأوۏڽأىەأتثًأضلۏتىأتًشأثزۏهأثىأًشمتؤأڬۏأثتحأضىۏأًۄأزًىًڽأإځضأوۏڽأثتحأډۏحأڬشأشۄەأحہەۗتثًأضلۏتىأڬۄۄأشۄتأحہت=أإدأڬەأزىأدۏضۏأإڲأتًشأهطڬشأوۏڽأىەأىۄۏڽأزۏڬہتۗأثزۏهأڬۄۄأشۄتأحہت=أۏۄأًتههۄأرصتؼۄأڬۏأإڲأۄەأدىۄۏڽأدىڲأىەأثشتىڲۏرحۄأڬشزۏتأۄەۗأتثًأضلۏتىأڬۄۄأشۄتأحہت=أرصتؼۄأڬۏأًتههۄأتحىۏأذۏخۏحأڬۄتڽأڬۄأًۄأتحىۏأإڲأدهتةەأتًشأتحىتأثڔتأهطڬشأهتةەۗأوۏڽأىەأتضأڬۏأإًتصأځۄډتىأهۏۗأوۏڽأىەأڬۄت=أتثًأذىػهۄآأتىۄًڽأىەأوۏشۏأإًتصأځۄډتىأهۏأتًشأڬۄىەأهڲە=أتثًأتهلعهأۄًآأوۏڽأىەأڬۄت=أۄتڽ؏أڬۄىەأهڲە=أوۏشەأوتڽأثتځأإځأځشأمشثتىأۄًڽأإځأڬًأڬۏتأۄًتآأوۏڽأىەأڬۄت=أتثًأضلۏتى$أتلضًضأۏۄأشضًهأتههۄأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏هًڲًڽأڬەأضتحہأۄۏڽأتًشأمشۏطأڬۏأثتشۏأإڲةۏأًتههۄۗأڬۄىەأهڲە=أوۏشەأوتڽأثتځأإځأځشأمشثتىأۄًڽ$أتضأضەأثډىەأڬتأڬۏتأغشۏمۄأۄەآأوۏڽأىەأڬۄت=أًتههۄأتڲشأًۄأحوأځشأذتًۏأۄًڲةەأحًأحوۄتشۏأڲشزىأتڔتزۏڽأڲەۗأوۏشەأضتحہأتضأرډشأځشأضًتشأۄًأدتًٗأحتڬۄأوۏڽأحوۄۏڽأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأڬەأځتضأهەأدتأڬشأإځأظهۏأتههۄأؼهۏۄأًضهوأضەأحوۄتشەأهةەأتوتىأغهثأڬشًڽۗأًۄأوۏشەأځۏډہەأضًتشأۄًڲةە؏أتًشأتىأڬەأزًىًڽأضتحہۏأًتځضأهًټأڲةەۗأوۏڽأىەأضًتشۏأډهتةۏ؏أوۏڽأدثأثہۏأوضهوتىًڽأڬۏأڬضۏأإڲأڬەأځتضأضەأڲصشحتأحًأڬۄحە=أۏۄأڬًىأۄەآأځہشأدثأًۄأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأڬتأرډشأزۏڬہحەأحًأڬۄحە=شضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأڬەأډډتأإځأڬەأرډشأځشأضًتشأۄۏڽۗأدثأوۏڽأؼوشأثىأرغتث‏شعۏأتههۄأؼىۄأڬۏأإڲأڬەأځتضأضەأڲصشتأحًأتىۄًڽأىەأڬۄت=أۏۄأڬًىأۄەآأتًشأوۏشۏأغشلأإىەأهڲە=أدثأتىۄًڽأىەأتثًأضلۏتىأڬًأرډشأڬەأځۏډہەأزۏڬہتأحًأڬۄىەأهڲە=أتثًأضلۏتى$أتههۄأڬتأزطوىآأتهذوزههۄ$أدضأىەأثؽۏشأڬضۏأؼۄزًأځۏوتڽأڬەأحوأځشأؽتهثأڬشأزۏتۗأځہشأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأڬۏأغشلأزًڔىەأهڲەۗأوۏڽأىەأثہۏأرډشأڬًأتۏڔأهڲتةۏأحًأوۏڽأتىأضەأځۄهەأځۄىډأڲۏتأدۏضتأڬۄأضضحأدتىًشأثہۏأضضحأإزوۏأضەأضثمحأهەأدتحتأۄەۗأوۏڽأىەأرډشأضەأډہهتىڲأهڲتأزۏۗأوۏڽأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأڬەأځتضأځۄىډتأحًأتًځشأضەأؼوش‏شعۏأتههۄأؼىۄأځۄىډأڲةەأتًشأڬۄىەأهڲە=أتەأتههۄأڬەأشضًه$أۏۄأتثًأضلۏتىأۄەۗأتههۄأحؼتهۏٳأىەأثؽۏشأڬضۏأؼۄزًأځۏوتىأڬەأتضأځشأؽهثۄأزەأزۏتأۄەۗودہەأتدتصحأزۏدةەأوۏڽأتضأڬۏأڲشزىأتڔتًٗڽ؏أوۏڽأىەأڬۄت=أتەأتههۄأڬەأشضًهأ$أوۏڽأىەأتضەأځىتۄأزۏأۄەۗأځہشأوۏڽأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأڬەأځتضأثۏټہأڲۏتأتًشأإځأڬتأضشأځڬڔأهۏتأوۏڽأىەأڬۄت=أىۄۏڽأًتههۄ$أإدأڬۏأشتحأوۏشەأؼهتًۄأڬًةۏأطرظأإځأظهۏأتههۄأؼهۏۄأًضهوأضەأثتحأىۄۏڽأڬشۏڲتأۗأدثأؼوش‏شعۏأتههۄأؼىۄأىەأتىأڬەأثتشەأوۏڽأصۏتزۄأڬۄتأحًأوۏڽأىەأڬۄت=أؼوش$أثضأڬشً؏أًتههۄأتڲشأۏۄأثىۏأؼزۏأثىأڬؼثأڬتأإزوۏأۄًحتأحًأحوأتضأڬەأثتشەأوۏڽأتحىتأىۄأڬۄحە؏أهۏڬىأحوۄۏڽأوؼهًوأۄەأڬۄأۏۄأثىۏأؼثزأوىتلأڬتأتۏڬأطرظأۄەۗأؼوش‏شعۏأتههۄأؼىۄأڬۄىەأهڲە=أؼثتضأډہًڔً؏أًتههۄأدضأزىأحوأتضهتوأهتةەأحوۄتشتأتضهتوأهتىتأودہەأ+وۏشەأثتځ,أرغتثأڬەأتضهتوأهتىەأضەأصۏتزۄأوذثًثأۄەأتڲشأًۄأۏۄأتضأهةەأڬۄأودہەأوؼهًوأۄەأڬۄأإځأڬتأتضهتوأهتىتأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأڬًأ+وۏشەأثتځ,أرغتثأڬەأتضهتوأهتىەأضەأصۏتزۄأوذثًثأۄەۗأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أؼثتضأتضەأرۏوەأوۏڽأهەأدتًٗ؏أدثأظثذأۄًدتةەأحًأتضەأوۏشەأځتضأهەأإىتۗأوۏڽأتثًأضلۏتىأڬًأتځىەأرۏوەأوۏڽأهەأڲۏتۗأتىۄًڽأىەأشتحأوۏشەأرۏوەأوۏڽأڲصتشۏ؏أدثأظثذأۄًةۏأحًأوۏڽأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأڬەأځتضأهەأڬشأإۏتۗأدثأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأىەأتضەأزۏڬہتأحًألشوتۏت=أتثًأضلۏتى$أتلضًضأۄە؏أڬۏتأحوۄۏڽأتثہۏأثہۏأوؼهًوأىۄۏڽأۄًتأڬۄأتههۄأڬەأؼهتًۄأڬًةۏأضډتأوؼثًزأىۄۏڽآأتثًأضلۏتىأىەأڬۄت=أوۏشەأوتڽأثتځأإځأځشأمشثتى؏أإځأڬحىەأوؼصص+ثشزثتش,أتًشأحؼهمأزتشۏأًتهەأۄۏڽ؏أًتههۄأتڲشأتههۄأڬەأضتحہأڬًةۏأتًشأۄًحتأ+تضأظًشحذتهأڬەأثؼزأ,عشًشأوۏشۏأوززأڬشحتۗأإځأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أتثًأضلۏتىأ$تلضًض$أڬۏتأتثہۏأًمحأىۄۏڽأإۏتأڬۄأحوۄۏڽأوؼهًوأۄًأڬۄأوۏڽأتههۄأڬتأشضًهأۄًڽآأتثًأضلۏتىأىەأڬۄت=أوۏشەأوتڽأثتځأإځأځشأمشثتىأإځأڬحىەأ=ثشزثتشأوؼصصأتًشأحؼهمأزتشۏأًتهەأۄۏڽ؏أتضأثتشەأوۏڽأوۏشەأزهأوۏڽأتثہۏأڬډہأطڬأطثۄۄأۄەۗأؼثتض‏شعۏأتههۄأؼىۄأىەأڬۄت=أتثًأضلۏتىأتلضًض$أتضأضەأځۄهەأڬۄأحوۄتشۏأڲشزىأوتشزۏأدتةەتضهتوأهەأإًٗأتًشأهتأتهيأتهتأتههۄأوذوزأشضًهأتههۄأڬۏأڲًتۄۏأزًۗأحثأتثًأضلۏتىأىەأذمأڬۏأڲًتۄۏأزۏأتًشأوضهوتىأۄًڲةەۗأوۏڽأىەأڬۄت=أتەأتههۄأڬەأشضًه$أتثًأضلۏتىأتۏضتأطرظأۄەأدًألرشأڬًأځضىزأڬشحتأۄە؏أتضأڬەأهةەأڬًةۏأرتظأثتحألشوتأزۏدةەۗأإځأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أټہۏڬأۄەأدًأطرظأتثًأضلۏتىأڬەأڲہشأوۏڽأزترهأۄًتأًۄأتوىأوۏڽأۄەۗأدضأطرظأىەأتځىتأزشًتصۄأثىزأڬشأهۏت؏أًۄأتوىأوۏڽأۄەأتًشأدًأوضدزأوۏڽأزترهأۄًأڲۏتأًۄأتوىأوۏڽأۄەۗدثأًۄأدتىەأڬەأهةەأوڔەأحًأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أؼثتضأ$ځۄتڔأڬەأضشەأأڬەأځتضأحىڲأڲہتټۏأوۏڽأتضەأشًڬأهً؏أحتڬۄأتههۄأڬەأهطڬشأڲصشۏڽأحًأۏۄأزۏڬہأضڬەۗأڬۄت=أوۏڽأتثًأضلۏتىأڬًأهەأڬشأثتۄشأىڬهتأتًشأدۄتڽأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأىەأودہەأتثًأضلۏتىأڬًأشًڬىەأڬتأذڬوأزۏتأحہتأوۏڽأىەأتضەأشًڬأهۏتۗأمثتةهأتځىەأدہىڋًڽأڬەأضتحہأڲصشىەأهڲەۗأدثأڬثہۏأڬًةۏأمثۏهۄأڲصشحتأحًأتثًأضلۏتىأڬۄحە=أۏۄأڬًىأۄۏڽآأوۏڽأڬۄحتأ+ضهۏو,أًۄأڬۄحەأودہە+أضهۏو,أضەأڬۏتأًتضغۄآأځہشأتۏڬأمثۏهۄأڲصشتأحًأتىۄًڽأىەأڬۄت=أۏۄأڬًىأۄۏڽآأوۏڽأىەأ=أأ+وصۏىۄ,أًۄأڬۄىەأڲهە=+وصۏىۄ,أضەأوۏشتأڬۏتأحؼهمۗأذحۏأڬۄأڬةۏأمثتةهأڲصشأڲةە؏أدثأڬًةۏأمثۏهۄأڲصشحتأحًأڬۄحەأۏۄأڬًىأۄۏڽآأوۏڽأڬۄحت=ألهتڽأًۄأڬۄحە=أودہەألهتڽأضەأڬۏتأًتضغۄآأذحۏأڬۄأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأتۏڬأثڔەأأهطڬشأڬەأضتحہأڲصشەأدضأوۏڽأوۄتدشۏىأتًشأتىظتشأحہەأۗدىأځشأهًۄەأڬۏأصشأۄۏڽأحہۏأتًشأظشلأتىأڬۏأإىڬہۏڽأزڬہتةۏأزەأشۄۏأحہۏڽۗأتثًأضلۏتىأىەأڬۄت=أضثذتىأتههۄأ$ؼثتض$أۏۄأڬًىأهًڲأۄۏڽآأوۏڽأىەأڬۄت=أۏۄأتههۄأڬەأشضًهأظهۏأتههۄأؼهۏۄأًضهوأوۄتدشۏىأًأتىظتشأڬەأضتحہأۄۏڽۗأتىۄًڽأىەأڬۄت=أتىأڬەأومتثهەأوۏڽأحًأڬضۏأڬۏأمًحأًأغتمحأىۄۏڽۗأتثًأتهلعه$أًتههۄ$أحوۄتشەأثہحۏدەأڬۏأثتزطتۄحأؼػۏوأۄًڲةۏۗأوۏڽأىەأڬۄت=أتثًأضلۏتىأۏۄأىثًحأۄە+ثتزطتۄحأىۄۏڽ,أتثًأضلۏتىأىەأڬۄت=أحثأحًأۏۄأثۄحأتډہۏأۄەۗأوۏڽأىەأڬۄت=أتځىۏأمًوأڬۏأىدتحأڬتأتؼهتىأڬشًۗأًۄأًۄتڽأضەأډهأڬشأتځىۏأمًوأڬەأځتضأإةەأتًشأثهىزأإًتصضەأڬۄىەأهڲە=أتەأمشۏطأڬۏأدوتؼح$أۏۄأوذوزأظهۏأتههۄأؼهۏۄأًضهوأۄۏڽ؏أحوۄتشەأځتضأتۏضتأهطڬشأهتةەۄۏڽأدضأڬتأڬًةۏأوزومتثهأىۄۏڽ؏أدًأطرظأتثًأضلۏتىأڬەأڲہشأوۏڽأزترهأۄًتأًۄأتوىأوۏڽأۄەۗأتضأڬۏأثۏًۏأۄىزأثىحأؼحثۄأتضأڬەأځتضأإةۏأتًشأتضأڬۏأوًىډہًڽأضەأځڬڔأڬشأڬۄت=أتضؼأډشثۏأضەأثہشەأۄًةەأځحهۏأځىڋهۏًڽأًتهەأڬًأمحهأڬشزً؏أۏۄأمًوأڬتأثشۏأرثشأڬتأتغهتؼأزۄىزۄأۄەۗأتثًأضلۏتىأڬۄىەأهڲە=أحوأځشأتلضًض$أۏۄأؼًشحأحوۄۏڽأزہًڬەأوۏڽأىۄأڋتهأزە؏أڬۏًڽأڬۄأإځأظهۏأتههۄأؼهۏۄأًضهوأتۏضتأهطڬشأهتةەأۄۏڽأدضأڬتأڬًةۏأومتثهأىۄۏڽ؏أدًأطرظأتثًأضلۏتىأڬەأڲہشأوۏڽأزترهأۄًڲۏتأًۄأتوىأوۏڽأۄەأۗهًڲأڬۄىەأهڲە=أحًأثشثتزأۄً؏أحۏشتأڲہشأڬحىەأهًڲًڽأڬًأڬتلۏأۄًڲتآأتثًأضلۏتىأىەأڬۄت=أدضأطرظأىەأتځىتأزشًتصۄأثىزأڬشأهۏتأًۄأتوىأوۏڽأۄەۗأدًأوضدزأوۏڽأزترهأۄًأڲۏتأًۄأتوىأوۏڽأۄەۗأحثأهًڲأتځىەأڲہشًڽأتًشأوضدزأڬۏأغشلأډهەأڲةەۗ

[تخریج]: الصحيحة رقم (3341) المعجم الكبير للطبراني (برقم  : 7115) ."
2200,"تثًأضؼۏزأرزشۏ‏شعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأتۏڬأزىأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأوتهأحمضۏوألشوتأشۄەأحہەأڬۄأإځأڬەأځتضأسًتهرًۏظشۄۗثىۏأحوۏوأڬتأتۏڬألشزۗأإۏتأتًشأڬۄىەأهڲت=أتەأوذوز+أظهۏأتههۄأؼهۏۄأًضهوأ,تىظتلأڬۏدةەۗأتههۄأڬۏأمضو$أإدأڬەأزىأإځأىەأتىظتلأىۄۏڽأڬۏتۗأىثۏأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أحوأوۏشەأثؼزأڬًةۏأتۏضتأطرظأىۄۏڽأزۏڬہًأڲەأدًأودہأضەأصۏتزۄأؼزهأڬشىەأًتهتأۄًۗأإځأىەأحۏىأوشحثۄألشوتۏت=أؼوش‏شعۏأتههۄأؼىۄأڬۄىەأهڲە=أتەأتههۄأڬەأشضًه$أڬۏتأإځأودہەأتدتصحأزۏحەأۄۏڽأڬۄأوۏڽأتضأڬۏأڲشزىأتڔتزًڽآأإځأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أىۄۏڽأتضأڬەأتۏضەأضتحہۏأۄۏڽأڬۄأحوأوۏڽأضەأڬًةۏأطرظأتځىۏأىوتصأتىأڬەأومتثهەأوۏڽأذمۏشأضودہەأڲتۗۗۗ

[تخریج]: الصحيحة رقم (2306) مسند أحمد رقم (11195) والفظ له صحيح البخاري كِتَاب الْمَنَاقِبِ بَاب عَلَامَاتِ النُّبُوَّةِ فِي الْإِسْلَامِ رقم (3341) ."
2201,"ىثۏأظهۏأتههۄأؼهۏۄأًضهوأؼتوأتهلۏهأوۏڽأځۏزتأۄًةەۗۏۄأذزۏخأؼثزتههۄأثىأؼثتضأتًشأمۏضأثىأوذصوۄأشعۏأتههۄأؼىۄوأضەأوشًۏأۄەۗأ

[تخریج]: الصحيحة رقم (3152) مسند أحمد رقم (17218) المستدرك على الصحيحين للحاكم (برقم 4145) المعجم الكبير للطبراني (برقم: 12262)"
2202,"توأۄتىۏأثىحأتثۏأغتهثأأشعۏأتههۄأؼىۄتأڬۄحۏأۄۏڽأڬۄألحذأوڬۄأڬەأوًمؼأځشأوۏڽأىەأتځىەأزًأزۏًشًڽأڬًأځىتأۄأزۏ؏أتًشأتىأزًىًڽأڬًأڲہشأوۏڽأهتأڬشأزشًتصۄأثىزأڬشأزۏتۗأوۏشتأوتڽأصتز+ترۏتلۏ,أثہتةۏأؼهۏأثىأتثۏأغتهثأشعۏأتههۄأؼىۄأأإةەأتًشأتىأزًىًڽأځشأحهًتشأضًىحأهۏۗأڬۄحۏأۄۏڽأوۏڽأىثۏأظهۏأتههۄأؼهۏۄأًضهوأڬەأځتضأإةۏأحًأإځأأودہەأىۄۏڽأوهەۗأألتغوۄأشعۏأتههۄأؼىۄتأوهأڲةۏأًۄأتځىەأطًۄشأضەأثہۏأصۏتزۄأودہأځشأزثتًٗأڋتهىەأهڲۏڽۗأڬۄحۏأۄۏڽأځہشأىثۏأظهۏأتههۄأؼهۏۄأًضهوأإةەأإځأځشأڲشزًأؽثتشأځڔتأۄًتأحہتأوۏڽأىەأإځأڬًأثحتۏتأحًأإځأظهۏأتههۄأؼهۏۄأًضهوألشوتىەأهڲە=أتوأۄتىۏ$أدضەأحوأىەأځىتۄأزۏأۄوأىەأثہۏأتضەأځىتۄأزۏ؏أتًشأدضەأحوأىەأتوتىأزۏأۄوأىەأثہۏأتضەأتوتىأزۏ

[تخریج]: الصحيحة رقم (2049) مسند أحمد رقم (25671) ."
2203,"شثۏؼۄأتضهوۏأأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄحەأۄۏڽأڬۄأوۏڽأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأڬۏأرزوحأڬۏتأڬشحتأحہتۗأإځأىەودہەأصوۏىأڬتأتۏڬأټڬڔتأزۏت؏أتًشأتثًأثڬش‏شعۏأتههۄأؼىۄأأڬًأثہۏأصوۏىأڬتأتۏڬأټڬڔتأزۏتۗأزىۏتأڬۏأهتهډأإأڲةۏأڬۄأۄوأڬہدًشأڬەأتۏڬأزشرحأوۏڽأدہڲڔىەأهڲەۗأتثًأثڬش‏شعۏأتههۄأؼىۄأىەأڬۄت=أۏۄأوۏشۏأصوۏىأڬۏأذزأوۏڽأۄەأتًشأوۏڽأىەأڬۄت=أۏۄأوۏشۏأصوۏىأڬۏأذزأوۏڽأۄەۗأوۏشەأتًشأتثًأثڬش‏شعۏأتههۄأؼىۄأڬەأزشوۏتىأحهرأڬهتوۏأۄًىەأهڲۏۗأتثًأثڬشأأشعۏأتههۄأؼىۄأىەأودہەأتۏضۏأثتحأڬۄۏأدًأودہەأىتأځضىزأهڲۏۗأًۄأطشوىزۄأۄًڲةەأۗتًشأودہأضەأڬۄىەأهڲە=أشثۏؼۄ$أودہەأثہۏأتۏضۏأثتحأڬۄًأحتڬۄأثزهۄأۄًأدتةەۗأوۏڽأىەأڬۄت=أوۏڽأتۏضتأڬتوأىۄۏڽأڬشًڽأڲتۗأتثًأثڬش‏شعۏأتههۄأؼىۄأىەأڬۄت=أحوأتۏضتأعشًشأڬۄًأڲەأًڲشىۄأوۏڽأحوۄتشەأرهتلأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأضەوززأغهثأڬشًڽأڲت؏أوۏڽأىەأڬۄتأ=وۏڽأتۏضتأىۄۏڽأڬشًڽأڲتۗأتًشأصوۏىأډہًڔأزۏ؏أتثًأثڬش‏شعۏأتههۄأؼىۄأىثۏأظهۏأتههۄأؼهۏۄأًضهوأڬەأځتضأډهە؏أوۏڽأثہۏأتىأڬەأځۏډہەأځۏډہەأډهتأثىًأتضهوأڬەأڬډہأإزوۏأإةەأتًشأڬۄىەأهڲە=أتههۄأحؼتهۏٳأتثًأثڬشأأشعۏأتههۄأؼىۄأځشأشذوأڬشە$أڬضأثتشەأوۏڽأۏۄأحوۄتشەأرهتلأشضًهأتههۄأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ضەوززأوتىڲأشۄەأۄۏڽأذتهتىڬۄأتضأىەأحوأضەأتۏضۏأثتحأڬۄۏأۄەآأوۏڽأىەأڬۄت=أڬۏتأحوأدتىحەأۄًآأۏۄأڬًىأۄەآۏۄأتثًأثڬشأظزۏمأشعۏأتههۄأؼىۄأأۄۏڽۗأختىۏأتخىۏىأ+زًىًڽأوۏڽأضەأزًضشە,أوضهوتىًڽأوۏڽأثصشڲۏأًتهە؏أحوأتضأثتحأضەأثډًأڬۄأًۄأحوۄۏڽأزۏڬہأهەأڬۄأحوأتضأڬەأرهتلأوۏشۏأوززأڬشأشۄەأۄًۗأًۄأؽظەأۄًأدتةۏڽۗأًۄأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأڬەأځتضأإةۏڽأتًشأإځأتىأڬەأؽظەأڬۏأًدۄأضەأؽظەأۄًأدتةۏڽأتًأتههۄأحؼتهۏٳأتىأزًىًڽأڬەأؽظەأڬۏأًدۄأضەأؽظەأۄًأدتةۏڽأتًشأشثۏؼۄأۄهتڬأۄًأدتةەۗأًۄأڬۄىەأهڲە=أځہشأتثأحوأۄوۏڽأڬۏتأڬۄحەأۄًآأحوأًتځضأډهەأدتًٗ؏أتثًأثڬش‏شعۏأتههۄأؼىۄأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأڬەأځتضأڲةەۗأوۏڽأتڬۏهتأتىأڬەأځۏډہەأڲۏتأتًشأتىأڬەأځۏډہەأځۏډہەأشۄتأذحۏأڬۄأًۄأىثۏأظهۏأتههۄأؼهۏۄأًضهوأڬەأځتضأځۄىډأڲةەأتًشأدضأغشذأثتحأۄًةۏأثۏتىأڬشأزۏۗأإځأظهۏأتههۄأؼهۏۄأًضهوأىەأوۏشۏأغشلأضشأتټہتأڬشأڬۄت=أشثۏؼۄأحوۄتشتأتًشأظزۏمأڬتأڬۏتأوؼتوهۄأۄەآأوۏڽأىەأڬۄت=أتەأتههۄأڬەأشضًه$أتضأغشذأثتحأۄًةۏأحہۏ؏أځہشأتىۄًڽأىەأودہأضەأتۏڬأثتحأڬۄۏأدًأودہەأىتأځضىزأهڲۏأحًأتىۄًڽأىەأودہأضەأڬۄت=أدضأغشذأوۏڽأىەأحوأضەأڬۄتأۄەأتضأغشذأحوأثہۏأڬۄًأحتڬۄأثزهۄأۄًأدتةەأ+هۏڬىأوۏڽأىەأتىڬتشأڬشأزۏت,أشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أۄتڽ؏أحوأتضأڬۏأثتحأڬتأدًتثأىۄأزً؏أهۏڬىأحوأڬۄً=أتثًأثڬش$أتههۄأحوۄۏڽأوؼتلألشوتةەۗأتثًأثڬش$أتههۄأحؼتهۏٳأحوۄۏڽأوؼتلألشوتةەأځضأوۏڽأىەأڬۄتأتثًثڬشأتههۄأحؼتهۏٳأحوۄۏڽأوؼتلألشوتةە؏أڬۄحەأۄۏڽأځہشأحًأتثًأثڬشأشعۏأتههۄأؼىۄأأتههۄأتىأځشأشذوأڬشەۗأشًحەأۄًةەأًتځضأډهەأڲةەۗ

[تخریج]: الصحيحة رقم (3145) مسند أحمد رقم (15982) المعجم الكبير للطبراني رقم (4443) ."
2204,"ؼتظوأثىأذوۏزأضڬًىۏأضەأوشًۏأۄەأڬۄحەأۄۏڽأڬۄأوؼتس‏شعۏأتههۄأؼىۄأڬًأدثأىثۏأظهۏأتههۄأؼهۏۄأًضهوأىەأثہۏدتأحًأىثۏأظهۏأتههۄأؼهۏۄأًضهوأتىۄۏڽأًظۏحأڬشىەأثتۄشأحڬأإةەأوؼتسأشعۏأتههۄأؼىۄأأضًتشأحہەأتًشأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأتضأڬۏأضًتشۏأڬەأضتحہأځۏزهأډهأشۄەأحہەۗأدثألتشؽأۄًڲةەأحًأڬۄىەأهڲەأ=وؼتس$أووڬىأۄەأحوأودہأضەأتضأضتهأڬەأثؼزأوهتمتحأىۄأڬشأضڬً؏أتًشأووڬىأۄەأحوأوۏشۏأ+تض,وضدزأتًشأوۏشۏأمثشأڬەأځتضأضەأڲصشً؏أوؼتسأثىأدثه‏شعۏأتههۄأؼىۄأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأڬۏأدزتةۏأوۏڽأځہًټأځہًټأڬشأشًىەأهڲەأۗىثۏأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أوؼتس$أشًأوح؏أۏمۏىتَشًىتأطۏغتىأڬۏأغشلأضەأۄەۗ

[تخریج]: الصحيحة رقم (2497) مسند أحمد رقم (21042)"
