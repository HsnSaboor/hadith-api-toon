{"metadata":{"name":"Sunan Abu Dawud","section":{"9":"Zakat (Kitab Al-Zakat)"},"section_detail":{"9":{"hadithnumber_first":1556,"hadithnumber_last":1700,"arabicnumber_first":1556,"arabicnumber_last":1700}}},"hadiths":[{"hadithnumber":1562,"arabicnumber":1562,"text":"Rapporté par Samurah ibn Jundub : Le Messager d’Allah ﷺ nous ordonnait de payer la sadaqa (zakat) sur ce que nous préparions pour le commerce","grades":[{"name":"Al-Albani","grade":"Daif"},{"name":"Muhammad Muhyi Al-Din Abdul Hamid","grade":"Daif"},{"name":"Zubair Ali Zai","grade":"Daif"}],"reference":{"book":9,"hadith":7}}]}