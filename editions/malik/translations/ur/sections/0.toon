{"hadithnumber": "167", "text": "ابونعیم وہب بن کیسان رحمہ اللہ سے روایت ہے کہ حضرت جابر بن عبداللہ رضی اللہ عنہما ان کو نماز میں الل"}
{"hadithnumber": "684", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ نے فرمایا :’’ مسلمان پر اس کے غلام اور"}
{"hadithnumber": "927", "text": "سیدہ عائشہ رضی اللہ عنہا زوجہ پیغمبر ﷺ سے روایت ہے ، کہتی ہیں کہ میں مکہ میں اس حال میں آئی کہ میں ح"}
{"hadithnumber": "951", "text": "ابن شہاب رحمہ اللہ سے بھی اسی کی مثل مروی ہے ۔"}
{"hadithnumber": "958", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ وہ بھی اس مسئلے میں سیدہ عائشہ رضی اللہ عنہا کے قو"}
{"hadithnumber": "1013", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ بے شک سعید بن مسیب رحمہ اللہ اور ابوسلمہ بن عبدالرحمن بھی حضر"}
{"hadithnumber": "1040", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ بے شک سعید بن مسیب رحمہ اللہ یہ ناپسند کرتے تھے کہ انسانوں سے"}
{"hadithnumber": "1090", "text": "زُبیر بن عبدالرحمن بن زبیر رحمہ اللہ سے روایت ہے کہ حضرت رفاعہ بن سموال رضی اللہ عنہ نے اپنی بیوی حض"}
{"hadithnumber": "1171", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ عروہ بن زبیر لعان کرنے والے کے بچے یعنی ولد زنا کے متعلق فرما"}
{"hadithnumber": "1176", "text": "طلحہ بن عبداللہ بن عوف رحمہ اللہ جو کہ اس حدیث کا سب سے زیادہ علم رکھنے والے تھے ، اور ابوسلمہ بن عب"}
{"hadithnumber": "1191", "text": "نافع رحمہ اللہ سے روایت ہے کہ بے شک سیدنا عبداللہ بن عمر رضی اللہ عنہما نے رسول اللہ ﷺ کے دور میں اپ"}
{"hadithnumber": "1203", "text": "نافع سے روایت ہے کہ سیدنا عبداللہ بن عمر رضی اللہ عنہما نے اپنی ایک بیوی کو ( اپنی ہمشیرہ ) سیدہ حفص"}
{"hadithnumber": "1338", "text": "ابوزناد سے روایت ہے کہ انھوں نے سعید بن مسیب رحمہ اللہ کو یہ فرماتے ہوئے سنا : ( کمی بیشی اور ادھار"}
{"hadithnumber": "1492", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ بے شک عروہ بن زبیر رحمہ اللہ لعان والی عورت کے بچے اور زنا کے"}
{"hadithnumber": "1519", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ بے شک سعید بن مسیب رحمہ اللہ اور سلیمان بن یسار رحمہ اللہ کہا"}
{"hadithnumber": "1528", "text": "عمرو بن شعیب رحمہ اللہ سے روایت ہے کہ بیشک بنومدلج قبیلے کے ایک شخص جسے قتادہ رحمہ اللہ کہا جاتا تھا"}
{"hadithnumber": "1583", "text": "حضرت ابوقتادہ انصاری رضی اللہ عنہ سے روایت ہے کہ بے شک رسول اللہ ﷺ نے اس سے منع فرمایا کہ کھجور اور"}
{"hadithnumber": "1748", "text": "سیدہ عائشہ رضی اللہ عنہا زوجہ پیغمبر ﷺ سے روایت ہے ، انھیں یہ خبر پہنچی کہ ان کے محلے میں ایک گھر وا"}
