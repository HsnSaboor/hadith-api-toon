{"hadithnumber": "4212", "arabic": "أَخْبَرَنَا عَمْرُو بْنُ عَلِيٍّ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا يَحْيَى، ‏‏‏‏‏‏عَنْ سُفْيَانَ، ‏‏‏‏‏‏ع", "grades": "{'name': 'Abu Ghuddah', 'grade': 'Hasan Sahih'},{'name': 'Al-Albani', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 40, Hadith 1", "international_number": "4212", "narrator_chain": ""}
{"hadithnumber": "4213", "arabic": "أَخْبَرَنَا هَارُونُ بْنُ إِسْحَاق، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا مُحَمَّدٌ يَعْنِي ابْنَ عَبْدِ الْوَ", "grades": "{'name': 'Abu Ghuddah', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 40, Hadith 2", "international_number": "4213", "narrator_chain": ""}
{"hadithnumber": "4214", "arabic": "أَخْبَرَنَا إِسْحَاق بْنُ مَنْصُورٍ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا عَبْدُ الرَّحْمَنِ، ‏‏‏‏‏‏عَنْ سُفْ", "grades": "{'name': 'Abu Ghuddah', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 40, Hadith 3", "international_number": "4214", "narrator_chain": ""}
{"hadithnumber": "4215", "arabic": "أخْبَرَنَا قُتَيْبَةُ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا سُفْيَانُ، ‏‏‏‏‏‏عَنِ الزُّهْرِيِّ، ‏‏‏‏‏‏عَنْ أَ", "grades": "{'name': 'Abu Ghuddah', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 40, Hadith 4", "international_number": "4215", "narrator_chain": ""}
{"hadithnumber": "4216", "arabic": "أَخْبَرَنَا مُحَمَّدُ بْنُ آَدَمَ بْنِ سُلَيْمَانِ،‏‏‏‏ عَنِ ابْنِ الْمُبَارَكِ،‏‏‏‏ عَنِ ابْنِ أَبِ", "grades": "{'name': 'Abu Ghuddah', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 40, Hadith 5", "international_number": "4216", "narrator_chain": ""}
{"hadithnumber": "4217", "arabic": "أَخْبَرَنَا أَحْمَدُ بْنُ سُلَيْمَانَ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا أَبُو نُعَيْمٍ، ‏‏‏‏‏‏قَالَ:‏‏‏‏", "grades": "{'name': 'Abu Ghuddah', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 40, Hadith 6", "international_number": "4217", "narrator_chain": ""}
{"hadithnumber": "4218", "arabic": "أَخْبَرَنَا الْحُسَيْنُ بْنُ حُرَيْثٍ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا الْفَضْلُ، ‏‏‏‏‏‏عَنْ الْحُسَيْنِ", "grades": "{'name': 'Abu Ghuddah', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 40, Hadith 7", "international_number": "4218", "narrator_chain": ""}
{"hadithnumber": "4219", "arabic": "أَخْبَرَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا عَفَّانُ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّ", "grades": "{'name': 'Abu Ghuddah', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 40, Hadith 8", "international_number": "4219", "narrator_chain": ""}
{"hadithnumber": "4220", "arabic": "أَخْبَرَنَا أَحْمَدُ بْنُ سُلَيْمَانَ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا عَفَّانُ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّث", "grades": "{'name': 'Abu Ghuddah', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Bukhari'}", "reference": "Book 40, Hadith 9", "international_number": "4220", "narrator_chain": ""}
{"hadithnumber": "4221", "arabic": "أَخْبَرَنَا عُبَيْدُ اللَّهِ بْنُ سَعِيدٍ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا سُفْيَانُ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ ق", "grades": "{'name': 'Abu Ghuddah', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Bukhari'}", "reference": "Book 40, Hadith 10", "international_number": "4221", "narrator_chain": ""}
{"hadithnumber": "4222", "arabic": "أَخْبَرَنَا أَحْمَدُ بْنُ سُلَيْمَانَ، قَالَ حَدَّثَنَا أَبُو نُعَيْمٍ، قَالَ حَدَّثَنَا دَاوُدُ بْنُ قَيْسٍ، عَنْ عَمْرِو بْنِ شُعَيْبٍ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، قَالَ سُئِلَ رَسُولُ اللَّهِ صلى الله عليه وسلم عَنِ الْعَقِيقَةِ فَقَالَ ‏\"‏ لاَ يُحِبُّ اللَّهُ عَزَّ وَجَلَّ الْعُقُوقَ ‏\"‏ ‏.‏ وَكَأَنَّهُ كَرِهَ الاِسْمَ قَالَ لِرَسُولِ اللَّهِ صلى الله عليه وسلم إِنَّمَا نَسْأَلُكَ أَحَدُنَا يُولَدُ لَهُ ‏.‏ قَالَ ‏\"‏ مَنْ أَحَبَّ أَنْ يَنْسُكَ عَنْ وَلَدِهِ فَلْيَنْسُكْ عَنْهُ عَنِ الْغُلاَمِ شَاتَانِ مُكَافَأَتَانِ وَعَنِ الْجَارِيَةِ شَاةٌ ‏\"‏ ‏.‏ قَالَ دَاوُدُ سَأَلْتُ زَيْدَ بْنَ أَسْلَمَ عَنِ الْمُكَافَأَتَانِ قَالَ الشَّاتَانِ الْمُشَبَّهَتَانِ تُذْبَحَانِ جَمِيعًا ‏.‏", "grades": "", "reference": "", "international_number": "4222", "narrator_chain": "It was narrated from 'Amr bin Shuaib, from his fahther, that his grandfather said:"}
{"hadithnumber": "4223", "arabic": "أَخْبَرَنَا الْحُسَيْنُ بْنُ حُرَيْثٍ، قَالَ حَدَّثَنَا الْفَضْلُ، عَنِ الْحُسَيْنِ بْنِ وَاقِدٍ، عَنْ عَبْدِ اللَّهِ بْنِ بُرَيْدَةَ، عَنْ أَبِيهِ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم عَقَّ عَنِ الْحَسَنِ وَالْحُسَيْنِ ‏.‏", "grades": "", "reference": "", "international_number": "4223", "narrator_chain": "It was narrated from 'Abdullah bin Buraidah, from his father, that:"}
{"hadithnumber": "4224", "arabic": "أَخْبَرَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، قَالَ حَدَّثَنَا عَفَّانُ، قَالَ حَدَّثَنَا حَمَّادُ بْنُ سَلَمَةَ، قَالَ حَدَّثَنَا أَيُّوبُ، وَحَبِيبٌ، وَيُونُسُ، وَقَتَادَةُ، عَنْ مُحَمَّدِ بْنِ سِيرِينَ، عَنْ سَلْمَانَ بْنِ عَامِرٍ الضَّبِّيِّ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ فِي الْغُلاَمِ عَقِيقَةٌ فَأَهْرِيقُوا عَنْهُ دَمًا وَأَمِيطُوا عَنْهُ الأَذَى ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Salman bin 'Amir Ad-Dabbi that the Messenger of Allah said:"}
{"hadithnumber": "4225", "arabic": "أَخْبَرَنَا أَحْمَدُ بْنُ سُلَيْمَانَ، قَالَ حَدَّثَنَا عَفَّانُ، قَالَ حَدَّثَنَا حَمَّادٌ، عَنْ قَيْسِ بْنِ سَعْدٍ، عَنْ عَطَاءٍ، وَطَاوُسٍ، وَمُجَاهِدٍ، عَنْ أُمِّ كُرْزٍ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ فِي الْغُلاَمِ شَاتَانِ مُكَافَأَتَانِ وَفِي الْجَارِيَةِ شَاةٌ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "it was narrated from Um Kurz that the Messenger of Allah said:"}
{"hadithnumber": "4226", "arabic": "أَخْبَرَنَا عُبَيْدُ اللَّهِ بْنُ سَعِيدٍ، قَالَ حَدَّثَنَا سُفْيَانُ، قَالَ قَالَ عَمْرٌو عَنْ عَطَاءٍ، عَنْ حَبِيبَةَ بِنْتِ مَيْسَرَةَ، عَنْ أُمِّ كُرْزٍ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ عَنِ الْغُلاَمِ شَاتَانِ مُكَافَأَتَانِ وَعَنِ الْجَارِيَةِ شَاةٌ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Umm Kurz that the Messenger of Allah said:"}
{"hadithnumber": "4227", "arabic": "أَخْبَرَنَا قُتَيْبَةُ، قَالَ حَدَّثَنَا سُفْيَانُ، عَنْ عُبَيْدِ اللَّهِ، - وَهُوَ ابْنُ أَبِي يَزِيدَ - عَنْ سِبَاعِ بْنِ ثَابِتٍ، عَنْ أُمِّ كُرْزٍ، قَالَتْ أَتَيْتُ النَّبِيَّ صلى الله عليه وسلم بِالْحُدَيْبِيَةِ أَسْأَلُهُ عَنْ لُحُومِ الْهَدْىِ فَسَمِعْتُهُ يَقُولُ ‏ ‏ عَلَى الْغُلاَمِ شَاتَانِ وَعَلَى الْجَارِيَةِ شَاةٌ لاَ يَضُرُّكُمْ ذُكْرَانًا كُنَّ أَمْ إِنَاثًا ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that umm Kurz said:"}
{"hadithnumber": "4228", "arabic": "أَخْبَرَنَا عَمْرُو بْنُ عَلِيٍّ، قَالَ حَدَّثَنَا يَحْيَى، قَالَ حَدَّثَنَا ابْنُ جُرَيْجٍ، قَالَ حَدَّثَنِي عُبَيْدُ اللَّهِ بْنُ أَبِي يَزِيدَ، عَنْ سِبَاعِ بْنِ ثَابِتٍ، عَنْ أُمِّ كُرْزٍ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ عَنِ الْغُلاَمِ شَاتَانِ وَعَنِ الْجَارِيَةِ شَاةٌ لاَ يَضُرُّكُمْ ذُكْرَانًا كُنَّ أَمْ إِنَاثًا ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Umma Kurz that the Messenger of Allah said:"}
{"hadithnumber": "4229", "arabic": "أَخْبَرَنَا أَحْمَدُ بْنُ حَفْصِ بْنِ عَبْدِ اللَّهِ، قَالَ حَدَّثَنِي أَبِي قَالَ، حَدَّثَنِي إِبْرَاهِيمُ، - هُوَ ابْنُ طَهْمَانَ - عَنِ الْحَجَّاجِ بْنِ الْحَجَّاجِ، عَنْ قَتَادَةَ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ عَقَّ رَسُولُ اللَّهِ صلى الله عليه وسلم عَنِ الْحَسَنِ وَالْحُسَيْنِ رضى الله عنهما بِكَبْشَيْنِ كَبْشَيْنِ ‏.‏", "grades": "", "reference": "", "international_number": "4229", "narrator_chain": "It was narrated that Ibn 'Abbas said:"}
{"hadithnumber": "4230", "arabic": "أَخْبَرَنَا عَمْرُو بْنُ عَلِيٍّ، وَمُحَمَّدُ بْنُ عَبْدِ الأَعْلَى، قَالاَ حَدَّثَنَا يَزِيدُ، - وَهُوَ ابْنُ زُرَيْعٍ - عَنْ سَعِيدٍ، أَنْبَأَنَا قَتَادَةُ، عَنِ الْحَسَنِ، عَنْ سَمُرَةَ بْنِ جُنْدُبٍ، عَنْ رَسُولِ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ كُلُّ غُلاَمٍ رَهِينٌ بِعَقِيقَتِهِ تُذْبَحُ عَنْهُ يَوْمَ سَابِعِهِ وَيُحْلَقُ رَأْسُهُ وَيُسَمَّى ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Qatadah, from Al-Hasan, from Samurh bin Jundab that the Messenger of Allah said:"}
{"hadithnumber": "4231", "arabic": "أَخْبَرَنَا هَارُونُ بْنُ عَبْدِ اللَّهِ، قَالَ حَدَّثَنَا قُرَيْشُ بْنُ أَنَسٍ، عَنْ حَبِيبِ بْنِ الشَّهِيدِ، قَالَ لِي مُحَمَّدُ بْنُ سِيرِينَ سَلِ الْحَسَنَ مِمَّنْ سَمِعَ حَدِيثَهُ، فِي الْعَقِيقَةِ ‏.‏ فَسَأَلْتُهُ عَنْ ذَلِكَ، فَقَالَ سَمِعْتُهُ مِنْ، سَمُرَةَ ‏.‏", "grades": "", "reference": "", "international_number": "4231", "narrator_chain": "It was narrated from Habib bin Ash-Shahid:"}
