hadiths[1869]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}: 16152,"حدَّثَنَا أَبُو عَبْدِ الرَّحْمَنِ بَقِیُّ بْنُ مَخْلَدٍ ، قَالَ : حدَّثَنَا أَبُو بَکْرٍ عَبْدُ اللہِ بْنُ مُحَمَّدِ بْنِ أَبِی شَیْبَۃَ ، قَالَ : حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ مَیْمُونٍ أَبِی المُغَلِّسِ ، عَنْ أَبِی نَجِیحٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ کَانَ مُوسِرًا لأَنْ یَنْکِحَ فَلَمْ یَنْکِحْ فَلَیْسَ مِنَّا۔ (ابوداؤد 202۔ عبدالرزاق 10376)",,,16152 16153,"حَدَّثَنَا ابْنُ الْمُبَارَکِ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ : عَنْ سَعْدٍ ، أَنَّ رَسُولَ اللّٰہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَدَّ عَلَی عُثْمَانَ بْنِ مَظْعُونٍ التَّبَتُّلَ ، وَلَوْ أَذِنَ لَہُ لاَخْتَصَیْنَا۔ (مسلم 1020۔ احمد 1/176)",,,16153 16154,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ ، عَنْ عَلْقَمَۃَ قَالَ : کُنْتُ أَمْشِی مَعَ عَبْدِ اللہِ بِمِنًی ، فَلَقِیَہُ عُثْمَانُ فَقَامَ مَعَہُ یُحَدِّثُہُ ، فَقَالَ لہ عُثْمَانُ : یَا أَبَا عَبْدِ الرَّحْمَنِ ، أَلاَ أُزَوِّجُک جَارِیَۃً شَابَّۃً لَعَلَّہَا تُذَکِّرُک بَعْضَ مَا مَضَی مِنْ زَمَانِکَ ؟ فَقَالَ عَبْدُ اللہِ أَمَا لَئِنْ قُلْتُ ذَلِکَ لَقَدْ قَالَ لَنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: یَا مَعْشَرَ الشَّبَابِ ، مَنِ اسْتَطَاعَ مِنْکُمُ الْبَائَۃَ فَلْیَتَزَوَّجْ ، فَإِنَّہُ أَغَضُّ لِلْبَصَرِ ، وَمَنْ لَمْ یَسْتَطِعْ فَعَلَیْہِ بِالصَّوْمِ ، فَإِنَّہُ لَہُ وِجَائٌ۔ (بخاری 5065۔ مسلم 1018)",,,16154 16155,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِِ ، عَنْ عُمَارَۃَ بْنِ عُمَیْرٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، عَنْ عَبْدِ اللہِ قَالَ: قَالَ لَنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : یَا مَعْشَرَ الشَّبَابِ ، مَنِ اسْتَطَاعَ مِنْکُمُ الْبَائَۃَ فَلْیَتَزَوَّجْ ، فَإِنَّہُ أَغَضُّ لِلْبَصَرِ وَأَحْصَنُ لِلْفَرْجِ ، وَمَنْ لَمْ یَسْتَطِعْ فَعَلَیْہِ بِالصَّوْمِ ، فَإِنَّہُ لَہُ وِجَائٌ۔ (بخاری 5066۔ مسلم 1019)",,,16155 16156,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، عَنْ أَبِی رَجَائٍ ، عَنْ عُثْمَانَ بْنِ خَالِدٍ ، عَنِ الزُّہْرِیِّ : عَنْ شَدَّادِ بْنِ أَوْسٍ ، وَکَانَ قَدْ ذَہَبَ بَصَرُہُ قَالَ : زَوِّجُونِی فَإِنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَوْصَانِی أَنْ لاَ أَلْقَی اللَّہَ أَعْزَبًا۔",,,16156 16157,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، عَنْ أَبِی رَجَائٍ ، عَنِ الْحَکَمِ بْنِ زَیْدٍ ، عَنِ الْحَسَنِ ، قَالَ : قَالَ مُعَاذُ فِی مَرَضِہِ الَّذِی مَاتَ فِیہِ : زَوِّجُونِی إنِّی أَکْرَہُ أَنْ أَلْقَی اللَّہَ أَعْزَبًا۔",,,16157 16158,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ إبْرَاہِیمَ بْنِ مَیْسَرَۃَ ، قَالَ : قَالَ لِی طَاوُوسٌ : لَتَنْکِحَنَّ ، أَوْ لأَقُولَنَّ لَکَ مَا قَالَ عُمَرُ لأَبِی الزَّوَائِد : مَا یَمْنَعُک مِنَ النِّکَاحِ إلاَّ عَجْزٌ ، أَوْ فُجُورٌ۔",,,16158 16159,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ ہِشَامِ بْنِ حُجَیرٍ ، عَنْ طَاوُوسٍ قَالَ : لاَ یَتِمُّ نُسُکُ الشَّابِّ حَتَّی یَتَزَوَّجَ۔",,,16159 16160,"حَدَّثَنَا عَبَّادُ بْنُ عَوَّامٍ ، عَنْ سُفْیَانَ بْنِ حُسَیْنٍ ، عَنْ أَبِی الْحَکَمِ سَیَّارٍ ، عَنْ أَبِی وَائِلٍ ، عَنِ ابْنِ مَسْعُودٍ قَالَ : لَوْ لَمْ أَعِشْ أَوَ لو لَمْ أَکُنْ فِی الدُّنْیَا إلاَّ عَشْرًا لأَحْبَبْت أَنْ یَکُونَ عِنْدِی فِیہِنَّ امْرَأَۃً۔",,,16160 16161,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : تَزَوَّجُوا النِّسَائَ فَإِنَّہُنَّ یَأْتِینَکُمْ بِالْمَالِ۔",,,16161 16162,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ إبْرَاہِیمَ بْنِ مُحَمَّدِ بْنِ الْمُنْتَشِرِ ، قَالَ : قَالَ عُمَرُ ابْتَغُوا الْغِنَی فِی الْبَائَۃ۔",,,16162 16163,"حَدَّثَنَا مُعَاذٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ إبْرَاہِیمَ بْنِ مَیْسَرَۃَ ، عَنْ طَاوُوسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَمْ یُرَ لِلْمُتَحَابَّیْنِ مِثْلَ النِّکَاحِ۔ (بیہقی 78)",,,16163 16164,"حَدَّثَنَا عَبْد اللہِ قَالَ : حدَّثَنَا إسْرَائِیلُ عن أبی إسحاق ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، عَنْ عَبْدِ اللہِ قَالَ : لَوْ لَمْ یَبْقَ مِنَ الدَّہْرِ إلاَّ لَیْلَۃً لأَحْبَبْت أَنْ یَکُونَ لِی فِی تِلْکَ اللَّیْلَۃِ امْرَأَۃً۔",,,16164 16165,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنْ قَیْسٍ ، عَنْ عَبْدِ اللہِ قَالَ : کُنَّا مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَنَحْنُ شَبَابٌ ، فَقُلْنَا یَا رَسُولَ اللہِ أَلاَ نَسْتَخْصِی ؟ قَالَ : لاَ ، ثُمَّ رَخَّصَ لَنَا أَنْ نَنْکِحَ الْمَرْأَۃَ بِالثَّوْبِ إلَی الأَجَلِ ، ثُمَّ قَرَأَ عَبْدُ اللہِ {یَا أَیُّہَا الَّذِینَ آمَنُوا لاَ تُحَرِّمُوا طَیِّبَاتِ مَا أَحَلَّ اللَّہُ لَکُمْ}۔\n\n(بخاری 4615۔ مسلم 11)",,,16165 16166,"حَدَّثَنَا صَاحِبٌ لَنَا یُکَنَّی بِأَبِی بَکْرٍ قَالَ : حدَّثَنَا ابْنُ ہِشَامٍ الدَّسْتَوَائِیُّ ، عَنْ أَبِیہِ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، عَنْ سَمُرَۃَ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی ، عَنِ التَّبَتُّلِ۔ (ترمذی 1082۔ احمد 5/17)",,,16166 16167,"حدَّثَنَا مُعَاذٌ قَالَ : أَخْبَرَنَا ابْنُ جُرَیْجٍ ، عَنْ سُلَیْمَانَ بْنِ مُوسَی ، عَنِ الزُّہْرِیِّ ، عَنْ عُرْوَۃَ ، عَنْ عَائِشَۃَ قَالَتْ قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَیُّمَا امْرَأَۃٍ لَمْ یُنْکِحْہَا الْوَلِیُّ ، أَوِ الْوُلاَۃُ فَنِکَاحُہَا بَاطِلٌ فَنِکَاحُہَا بَاطِلٌ ، قَالَہَا ثَلاَثًا ، فَإِنْ أَصَابَہَا فَلَہَا مَہْرُہَا بِمَا أصاب مِنْہَا ، فَإِنَ اشْتَجَرُوا فَالسُّلْطَانُ وَلِیُّ مَنْ لاَ وَلِیَّ لَہُ۔ (ابوداؤد 2076۔ احمد 6/165)",,,16167 16168,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنِ ابْنِ أَخٍ لِعُبَیْدِ بْنِ عُمَیْرٍ ، عنْ عَبْدِ الرَّحْمَنِ بْنِ مَعْبَد أَنَّ عُمَر رَدَّ نِکَاحَ امْرَأَۃٍ نُکِحَتْ بِغَیْرِ إذْنِ وَلِیِّہَا۔,,,16168 16169,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، عَنْ عُمَرَ ، قَالَ : لاَ نِکَاحَ إلاَّ بِوَلِیٍّ۔",,,16169 16170,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ مُجَالِدٍ ، عَنِ الشَّعْبِیِّ قَالَ : مَا کَانَ أَحَدٌ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَشَدَّ فِی النِّکَاحِ بِغَیْرِ وَلِیٍّ مِنْ عَلِیٍّ حَتَّی کَانَ یَضْرِبُ فِیہِ۔",,,16170 16171,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ خُثَیْمٍ ، عَنْ سَعِیدٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ نِکَاحَ إلاَّ بِوَلِیٍّ ، أَوْ سُلْطَانٍ مُرْشِدٍ",,,16171 16172,"حَدَّثَنَا غُنْدَرٌ، عَنْ شُعْبَۃَ، قَالَ: سَمِعْتُ الْوَضَّاحَ، قَالَ: سَمِعْتُ جَابِرَ بْنَ زَیْدٍ یَقُولُ: لاَ نِکَاحَ إلاَّ بِوَلِیٍّ وَشَاہِدَیْنِ",,,16172 16173,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : لاَ نِکَاحَ إلاَّ بِوَلِیٍّ",,,16173 16174,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ أَنَّہُ کَانَ یَقُولُ : لاَ نِکَاحَ إلاَّ بِوَلِیٍّ ، أَوْ سُلْطَانٍ",,,16174 16175,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ قَالَ : لاَ تُنْکَحُ الْمَرْأَۃُ إلاَّ بِإِذْنِ وَلِیِّہَا ، فَإِنْ لَمْ یَکُنْ لَہَا وَلِیٌّ فَالسُّلْطَانُ۔",,,16175 16176,حَدَّثَنَا یَزِیدُ ، عَنْ أَشْعَثَ ، عَنْ أَصْحَابِہِ ، عَنْ إبْرَاہِیمَ مِثْلَہُ۔,,,16176 16177,"حَدَّثَنَا عُبَیْدُ اللہ بْنُ مُوسَی ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنْ عَمْرِو بْنِ أَبِی سُفْیَانَ ، قَالَ : قَالَ عُمَرُ : لاَ تُنْکَحُ الْمَرْأَۃُ إلاَّ بِإِذْنِ وَلِیِّہَا ، وَإِنْ نَکَحَتْ عَشَرَۃً ، أَوْ بِإِذْنِ سُلْطَانٍ۔",,,16177 16178,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَیُّوبَ ، عَنِ الْحَسَنِ ، وَابْنِ سِیرِینَ فِی الْمَرْأَۃِ مِنْ أَہْلِ السَّوَادِ لَیْسَ لَہَا وَلِیٌّ ، قَالَ : الْحَسَنُ السُّلْطَانُ ، وَقَالَ ابْنُ سِیرِینَ : رَجُلٌ مِنَ الْمُسْلِمِینَ۔",,,16178 16179,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ عُبَیْدَۃَ ، عَنْ إبْرَاہِیمَ وَالشُّعَبِیِّ قَالاَ : لاَ تُنْکَحُ الْمَرْأَۃُ إلاَّ بِإِذْنٍ وَلِیہَا ، وَلاَ یُنْکِحُہَا وَلِیُّہَا إلاَّ بِإِذْنِہَا۔",,,16179 16180,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ قَالَ : أُتِیَ عُمَرُ بِامْرَأَۃٍ قَدْ حَمَلَتْ ، فَقَالَتْ : تَزَوَّجَنِی بِشَہَادَۃٍ مِنْ أُمِّی وَأُخْتِی ، فَفَرَّقَ بَیْنَہُمَا وَدَرَأَ عَنْہُمَا الْحَدَّ ، وَقَالَ : لاَ نِکَاحَ إلاَّ بِوَلِیٍّ۔",,,16180 16181,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ حَجَّاجٍ ، عَنْ حُصَیْنٍ ، عَنِ الشَّعْبِیِّ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ قَالَ : لاَ نِکَاحَ إلاَّ بِوَلِیٍّ وَلاَ نِکَاحَ إلاَّ بِشُہُودٍ۔",,,16181 16182,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ حَجَّاجٍ ، عَنِ الزُّہْرِیِّ ، عَنْ عُرْوَۃَ ، عَنْ عَائِشَۃَ قَالَتْ قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ نِکَاحَ إلاَّ بِوَلِیٍّ وَالسُّلْطَانُ وَلِیُّ مَنْ لاَ وَلِیَّ لَہُ۔ (احمد 1/250۔ ابن ماجہ 1880",,,16182 16183,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ یَزِیدَ ، قَالَ : سَمِعْتُ الْحَسَنَ یَقُولُ : لاَ نِکَاحَ إلاَّ بِوَلِیٍّ وَشَاہِدَی عَدْلٍ وَبِصَدُقَۃٍ مَعْلُومَۃٍ وَشُہُودٍ وعَلاَنِیَۃٍ۔",,,16183 16184,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ أَبِیہِ قَالَ : قُلْتُ لِلْحَسَنِ جَارِیَۃٌ مِنْ أَہْلِ الأَرْضِ یَعْنِی لَیْسَ لَہَا مَوْلًی ، خَطَبَہَا رَجُلٌ، أَیُزَوِّجُہَا رَجُلٌ مِنْ جِیرَانِہَا ، قَالَ : تَأْتِی الأَمِیرَ قَالَ : فَإِنَّہَا أَضْعَفُ مِنْ ذَلِکَ ، قَالَ : فَتُکَلِّمُ رَجُلاً یُکَلِّمُ لَہَا الأَمِیرُ ، قَالَ : فَإِنَّہَا أَضْعَفُ مِنْ ذَلِکَ ؟ قَالَ : لاَ أَعْلَمُ إلاَّ ذَلِکَ ، قَالَ : قُلْتُ لَہُ : فَالْقَاضِی ؟ قَالَ : فَالْقَاضِی إذًا، إلاَّ أَنَّہُ یَجْعَلُ الْقَاضِی رُخْصَۃً۔",,,16184 16185,"حَدَّثَنَا عَفَّانُ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، عَنْ زِیَادٍ قَالَ : إذَا اتَّفَقَ الْوَلِیُّ وَالأُمُّ تَزَوَّجَا ، وَإِنِ اخْتَلَفَا فَالْوَلِیُّ",,,16185 16186,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ إسْرَائِیلَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی بُرْدَۃَ ، عَنْ أَبِیہِ ، قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ نِکَاحَ إلاَّ بِوَلِیٍّ۔ (ابوداؤد 2078۔ احمد 394)",,,16186 16187,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، عَنْ سُفْیَانَ ، عَنْ أَبِی یَحْیَی ، عَنْ رَجُلٍ یُقَالُ لَہُ الْحَکَمُ بْنُ مِینَائَ ، عَنِ ابْنِ عَبَّاسٍ : أَدْنَی مَا یَکُونُ فِی النِّکَاحِ أَرْبَعَۃٌ : الَّذِی یُزَوِّجُ وَالَّذِی یَتَزَوَّجُ وَشَاہِدَانِ۔",,,16187 16188,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ إِسْحَاقَ ، عَنْ أَبِی بُرْدَۃ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ نِکَاحَ إلاَّ بِوَلِیٍّ۔",,,16188 16189,حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مُحَمَّدٍ الْمُحَارِبِیُّ ، عَنْ لَیْثٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ أَنَّہُ أَرَادَ أَنْ یَتَزَوَّجَ فَذَہَبَ ہُوَ وَرَجُلٌ وَجَائَ الْوَلِیُّ وَرَجُلٌ۔,,,16189 16190,"حَدَّثَنَا وَکِیعٌ ، أَوْ غَیْرُہُ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ قَالَ : أَدْنَی مَا یَکُونُ فِی النِّکَاحِ أَرْبَعَۃٌ : الَّذِی یَتَزَوَّجُ وَالَّذِی یُزَوِّجُ وَشَاہِدَانِ۔",,,16190 16191,"حدَّثَنَا إسماعیل ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عِکْرِمَۃَ بْنِ خَالِدٍ قَالَ : جَمَعَتِ الطَّرِیقُ رَکْبًا ، فَجَعَلَتِ امْرَأَۃٌ مِنْہُمْ ثَیِّبٌ أَمْرَہَا إلَی رَجُلٍ مِنَ الْقَوم غَیْرِ وَلِیِّہَا ، فَأَنْکَحَہَا رَجُلاً ، قَالَ : فَجَلَدَ عُمَرُ النَّاکِحَ وَالْمُنْکِحَ وَفَرَّقَ بَیْنَہُمَا۔",,,16191 16192,"حَدَّثَنَا أَبُودَاوُدَ الطَّیَالِسِیُّ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ، عَنْ قَتَادَۃَ، عَنِ سعید بْنِ الْمُسَیَّبِ، وَالْحَسَنِ فِی امْرَأَۃٍ تَزَوَّجَتْ بِغَیْرِ إذْنِ وَلِیِّہَا ، قَالَ : یُفَرَّقُ بَیْنَہُمَا ، وَقَالَ الْقَاسِمُ بْنُ مُحَمَّدٍ : إِنْ أَجَازَہُ الأَوْلِیَائُ فَہُوَ جَائِزٌ۔",,,16192 16193,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ شُعْبَۃَ ، عَنْ مُصْعَبٍ قَالَ : سَأَلْتُ إبْرَاہِیمَ ، عَنِ امْرَأَۃٍ تَزَوَّجَتْ بِغَیْرِ وَلِیٍّ فَسَکَتَ، وَسَأَلْت سَالِمَ بْنَ أَبِی الْجَعْدِ ، فَقَالَ : لاَ یَجُوزُ۔",,,16193 16194,"حَدَّثَنَا وَکِیعٌ ، عَنْ سفیان عن ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ قَالَ : إذَا نُکِحَتِ الْمَرْأَۃُ بِغَیْرِ وَلِیٍّ ، ثُمَّ أَجَازَ الْوَلِیُّ جَازَ",,,16194 16195,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنْ بَکْرٍ قَالَ : تَزَوَّجَتِ امْرَأَۃٌ بِغَیْرِ وَلِیٍّ وَلاَ بَیِّنَۃٍ فَکَتَبَ إِلی عُمَرَ فَکَتَبَ أَنْ تُجْلَدَ مِئَۃً ، وَکَتَبَ إلَی الأَمْصَارِ ، أَیُّمَا امْرَأَۃٍ تَزَوَّجَتْ بِغَیْرِ وَلِیٍّ فَہِیَ بِمَنْزِلَۃِ الزَّانِیَۃِ۔",,,16195 16196,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ رَجُلٍ مِنْ أَہْلِ الْجَزِیرَۃِ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ أَنَّ رَجُلاً زَوَّجَ امْرَأَۃً وَلَہَا وَلِیٌّ ہُوَ أَوْلَی مِنْہُ بِدُرُوبِ الرُّومِ ، فَرَدَّ عُمَرُ النِّکَاحَ وَقَالَ : الْوَلِیُّ وَإِلاَّ فَالسُّلْطَانُ۔",,,16196 16197,"حدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ الشَّیْبَانِیِّ ، عَنْ أُمِّہِ ، عَنْ بَحَرِیَّۃَ بِنْتِ ہَانِیئٍ قَالَتْ : تَزَوَّجْت الْقَعْقَاعَ بْنَ شَوْرٍ فَسَأَلَنِی وَجَعَلَ لِی مُذْہَبًا مِنْ جَوْہَرٍ عَلَی أَنْ یَبِیتَ عِنْدِی لَیْلَۃً فَبَاتَ ، فَوَضَعْت لَہُ تَوْرًا فِیہِ خَلُوقٌ فَأَصْبَحَ وَہُوَ مُتَضَمِّخٌ بِالْخَلُوقِ ، فَقَالَ لِی : فَضَحْتِنِی ، فَقُلْتُ لَہُ : مِثْلِی یَکُونُ سِرًّا ؟ فَجَائَ أَبِی مِنَ الأَعْرَابِ ، فَاسْتَعْدَی عَلَیْہِ عَلِیًّا ، فَقَالَ عَلِیٌّ لِلْقَعْقَاعِ : أَدَخَلْتَ ؟ فَقَالَ : نَعَمْ ، فَأَجَازَ النِّکَاحَ۔",,,16197 16198,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ شُعْبَۃَ ، عَنْ مُصْعَبٍ قَالَ : سَأَلْتُ مُوسی بْنَ عَبْدِ اللہِ بْنِ یَزِیدَ ، فَقَالَ : یَجُوزُ فِی الْمَرْأَۃِ تَزْوِیجٌ بِغَیْرِ وَلِیٍّ۔",,,16198 16199,"حَدَّثَنَا عَبْدُالأَعْلَی، عَنْ مَعْمَرٍ قَالَ: سَأَلْتُ الزُّہْرِیَّ، عَنِ امْرَأَۃٍ تُزَوَّجُ بِغَیْرِ وَلِیٍّ، فَقَالَ: إِنْ کَانَ کُفُؤًا جَازَ۔",,,16199 16200,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ إسْمَاعِیلَ بْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ قَالَ : إذَا کَانَ کُفُؤًا جَازَ۔",,,16200 16201,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الشَّیْبَانِیِّ ، عَنْ أَبِی قَیْسٍ الأَوْدِیِّ ، عَمَّنْ حَدَّثَہُ عَنْ عَلِیٍّ أَنَّہُ أَجَازَ نِکَاحَ امْرَأَۃٍ بِغَیْرِ وَلِیٍّ أَنْکَحَتْہَا أُمُّہَا بِرِضَاہَا۔,,,16201 16202,"حَدَّثَنَا سَلاَّمٌ وَجَرِیرٌ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ رُفَیْعٍ ، عَنْ أَبِی سَلَمَۃَ بْنِ عَبْدِ الرَّحْمَنِ قَالَ : جَائَتِ امْرَأَۃٌ إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَتْ : یَا رَسُولَ اللہِ ، إنَّ عَمَّ وَلَدِی خَطَبَنِی فَرَدَّہُ أَبِی وَزَوَّجَنِی وَأَنَا کَارِہَۃٌ، قَالَ : فَدَعَا أَبَاہَا ، فَسَأَلَہُ ، عَنْ ذَلِکَ ، فَقَالَ : إنِّی أَنْکَحْتُہَا وَلَمْ آلُوہَا خَیْرًا ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ نِکَاحَ لَکِ ، اذْہَبِی فَانْکِحِی مَنْ شِئْتِ۔ (عبدالرزاق 10303)",,,16202 16203,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ أَنَّ الْقَاسِمَ بْنَ مُحَمَّدٍ أَخْبَرَہُ أَنَّ عَبْدَ الرَّحْمَنِ بْنَ یَزِیدَ وَمُجَمِّع بْنَ یَزِیدَ الأَنْصَارِیَّیْنِ أَخْبَرَاہُ أَنَّ رَجُلاً مِنْہُمْ یُدْعَی خِذَامًا أَنْکَحَ ابْنَۃً لَہُ ، فَکَرِہَتْ نِکَاحَ أَبِیہَا فَأَتَتْ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَذَکَرَتْ ذَلِکَ لَہُ فَرَدَّ عَنْہَا نِکَاحَ أَبِیہَا ، فَخُطِبَتْ فَنَکَحَتْ أَبَا لُبَابَۃَ بْنَ عَبْدِ الْمُنْذِرِ ، وَذَکَرَ یَحْیَی أَنَّہُ بَلَغَہُ أَنَّہَا کَانَتْ ثَیِّبًا۔ (بخاری 5139۔ ابوداؤد 2094,,,16203 16204,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ الْقَاسِمِ بْنِ مُحَمَّدٍ أَنَّ عَائِشَۃَ أَنْکَحَتْ حَفْصَۃَ ابْنَۃَ عَبْدِ الرَّحْمَنِ بْنِ أَبِی بَکْرٍ الْمُنْذِرَ بْنَ الزُّبَیْرِ وَعَبْدُ الرَّحْمَنِ غَائِبٌ فَلَمَّا قَدِمَ عَبْدُ الرَّحْمَنِ غَضِبَ وَقَالَ : أَی عِبَادَ اللہِ ، أَمِثْلِی یُفْتَاتُ عَلَیْہِ فِی بَنَاتِہِ ؟ فَغَضِبَتْ عَائِشَۃُ وَقَالَتْ : أَیُرْغَبُ ، عَنِ الْمُنْذِرِ۔",,,16204 16205,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی قَیْسٍ ، عَنْ ہُزَیْلٍ قَالَ : رُفِعَتْ إلَی عَلِیٍّ امْرَأَۃٌ زَوَّجَہَا خَالُہَا وأمہا ، قَالَ : فَأَجَازَ عَلِیٌّ النِّکَاحَ ، قَالَ : وَقَالَ سُفْیَانُ : لاَ یَجُوزُ لأَنَّہُ غَیْرُ وَلِیٍّ ، وَقَالَ عَلِیُّ بْنُ صَالِحٍ : ہُوَ جَائِزٌ لأَنَّ عَلِیًّا حِینَ أَجَازَہُ کَانَ بِمَنْزِلَۃِ الْوَلِیِّ۔",,,16205 16206,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَبِیہِ ، عَنِ الْحَکَمِ قَالَ : کَانَ عَلِیٌّ إذَا رُفِعَ إلَیْہِ رَجُلٌ تَزَوَّجَ امْرَأَۃً بِغَیْرِ وَلِیٍّ فَدَخَلَ بِہَا أَمْضَاہُ۔",,,16206 16207,"حدَّثَنَا محمد بْنُ فُضَیْلٍ، عَنْ مُغِیرَۃَ، عَنْ إبْرَاہِیمَ قَالَ: لَیْسَ الْعَقْدُ بِیَدِ النِّسَائِ، إِنَّمَا الْعَقْدُ بِیَدِ الرِّجَالِ۔",,,16207 16208,"حَدَّثَنَا ابن إدْرِیس ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ قَالَ : لاَ أَعْلَمُہُ إلاَّ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، قَالَتْ : کَانَ الْفَتَی مِنْ بَنِی أَخِیہَا إذَا ہَوَی الْفَتَاۃَ مِنْ بنات أَخِیہَا ضَرَبَتْ بَیْنَہُمَا سِتْرًا وَتَکَلَّمَتْ ، فَإِذَا لَمْ یَبْقَ إلاَّ النِّکَاحَ قَالَتْ : یَا فُلاَنُ ، أَنْکِحْ ، فَإِنَّ النِّسَائَ لاَ یَنْکِحْنَ۔",,,16208 16209,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنْ مُحَمَّدٍ ، عَنْ أَبِی ہُرَیْرَۃَ قَالَ : لاَ تُزَوِّجُ الْمَرْأَۃُ الْمَرْأَۃَ۔",,,16209 16210,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ قَالَ : لاَ تُنْکِحُ الْمَرْأَۃُ الْمَرْأَۃَ۔",,,16210 16211,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ قَالَ : تُزَوِّجُ الْمَرْأَۃُ أَمَتَہَا ، فَإِذَا أَعْتَقَتْہَا لَمْ تُزَوِّجْہَا۔",,,16211 16212,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : أَخْبَرَنِی ابْنُ أَبِی ذِئْبٍ ، عَنْ مَوْلَی بَنِی ہَاشِمٍ ، عَنْ عَلِیٍّ قَالَ : لاَ تَشْہَدُ الْمَرْأَۃُ ، یَعْنِی الْخِطْبَۃَ وَلاَ تُنْکِحُ۔",,,16212 16213,"حدَّثَنَا غَسَّانُ بْنُ مُضَرَ ، عَنْ سَعِیدِ بْنِ یَزِیدَ قَالَ : جَائَتِ امْرَأَۃٌ إلَی جَابِرِ بْنِ زَیْدٍ ، فَقَالَتْ : إنِّی زَوَّجْت نَفْسِی ، فَقَالَ : إنَّک لِتُحَدِّثِینِی أَنَّک زَنَیْت ؟ فَسَفَعَتْ برنَّۃ ثُمَّ انْطَلَقَتْ۔",,,16213 16214,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ قَالَ : لاَ تُنْکِحُ الْمَرْأَۃُ نَفْسَہَا ، وَکَانُوا یَقُولُونَ : إنَّ الزَّانِیَۃَ ہِیَ الَّتِی تُنْکِحُ نَفْسَہَا۔",,,16214 16215,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنْ مُحَمَّدِ بْنِ سِیرِینَ ، عَنْ أَبِی ہُرَیْرَۃَ بِمِثْلِہِ۔,,,16215 16216,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : أَخْبَرَنَا سَعِیدٌ ، عَنْ قَتَادَۃَ ، عَنْ جَابِرِ بْنِ زَیْدٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إنَّ الْبَغَایَا اللاَّئی یُنْکِحْنَ أَنْفُسَہُنَّ بِغَیْرِ بَیِّنَۃٍ۔",,,16216 16217,"حدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، عَنْ أَبِی عَمْرٍو مَوْلَی عَائِشَۃَ ، عَنْ عَائِشَۃَ قَالَتْ قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : تُسْتَأْمَرُ النِّسَائُ فِی أَبْضُعِہِنَّ ، قَالَتْ قُلْتُ : یَا رَسُولَ اللہِ ، إنَّہُنَّ یَسْتَحْیِینَ ، قَالَ : الأَیِّمُ أَحَقُّ بِنَفْسِہَا ، وَالْبِکْرُ تُسْتَأْمَرُ فَسُکاتُہَا إقْرَارُہَا۔(بخاری 6946۔ مسلم 65)",,,16217 16218,"حَدَّثَنَا ابْنُ إدْرِیسَ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ وَمَالِکِ بْنِ أَنَسٍ، عَنْ عَبْدِ اللہِ بْنِ الْفَضْلِ، عَنْ نَافِعِ بْنِ جُبَیْرٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الأَیِّمُ أَحَقُّ بِنَفْسِہَا مِنْ وَلِیِّہَا ، وَالْبِکْرُ تُسْتَأْمَرُ وَصَمْتُہَا إقْرَارُہَا۔ (ترمذی 1108۔ ابوداؤد 2091)",,,16218 16219,"حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا خُطِبَ أَحَدٌ مِنْ بَنَاتِہِ جَلَسَ إلَی جَنْبِ خِدْرِہَا ، فَقَالَ : إنَّ فُلاَنًا یَخْطُبُ فُلاَنَۃً فَإِنْ سَکَتَتْ بِہِ زَوَّجَہَا ، وَإِنْ طَعَنَتْ بِیَدِہَا وَأَشَارَ حَفْصٌ بِیَدِہِ السَّبَّابَۃِ أَی یَطْعَنُ فِی فَخِذِہ لَمْ یُزَوِّجْہَا۔ (عبدالرزاق 10279۔ بزار 1421)",,,16219 16220,"حَدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنِ الْحَکَمِ ، قَالَ : قَالَ عَلِیٌّ لاَ یُزَوِّجُ الرَّجُلُ ابنتہ حَتَّی یَسْتَأْمِرَہَا۔",,,16220 16221,"حَدَّثَنَا فُضَیْلُ بْنُ عِیَاضٍ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ قَالَ: إذَا کَانَتِ الْمَرْأَۃُ فِی عِیَالِ أَبِیہَا لَمْ یَسْتَأْمِرْہَا، وَإِنْ کَانَتْ فِی غَیْرِ عِیَالِہِ اسْتَأْمَرَہَا إذَا أَرَادَ أَنْ یُنْکِحَہَا۔",,,16221 16222,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ، عَنْ عاصم، عَنِ الشَّعْبِیِّ قَالَ: یَسْتَأْمِرُ الرَّجُلُ ابْنَتَہُ فِی النِّکَاحِ الْبِکْرَ وَالثَّیِّبَ۔",,,16222 16223,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ أَنَّہُ کَانَ یَقُولُ : نِکَاحُ الأَبِ جَائِزٌ عَلَی ابْنَتِہِ ، بِکْرًا کَانَ ، أَوْ ثَیِّبًا ، کَرِہَتْ ، أَوْ لَمْ تَکْرَہْ۔",,,16223 16224,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ قَالَ : لاَ یُکْرِہُ الرَّجُلُ ابْنَتَہُ الثَّیِّبَ عَلَی نِکَاحٍ ہِیَ تَکْرَہُہُ۔",,,16224 16225,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ مَالِکِ بْنِ أَنَسٍ قَالَ : کَانَ الْقَاسِمُ وَسَالِمٌ یَقُولاَنِ : إذَا زَوَّجَ أَبُو الْبِکْرِ الْبِکْرَ فَہُوَ لاَزِمٌ لَہَا ، وَإِنْ کَرِہَتْ۔",,,16225 16226,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ قَالَ : إِنَّ أَبُو الْبِکْرِ دَعَاہَا إلَی رَجُلٍ وَدَعَتْ ہِیَ إلَی آخَرَ ، قَالَ : یَتْبَعُ ہَوَاہَا إذَا لَمْ یَکُنْ بِہِ بَأْسٌ ، وَإِنْ کَانَ الَّذِی دَعَاہَا إلَیْہِ أَبُوہَا أَسْنی فِی الصَّدَاقِ أَخْشَی أَنْ یَقَعَ فِی نَفْسِہَا ، وَإِنْ أَکْرَہَہَا أَبُوہَا فَہُوَ أَحَقُّ۔",,,16226 16227,"حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ قَالَ : لاَ یُجْبِرُ عَلَی النِّکَاحِ إلاَّ الأَبُ۔",,,16227 16228,حَدَّثَنَا عَفَّانُ حَدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ أَیُّوبَ ، عَنْ عِکْرِمَۃَ ؛ أَنَّ عُثْمَانَ بْنَ عَفَّانَ کَانَ إذَا أَرَادَ أَنْ یُزَوِّجَ أَحَدًا مِنْ بَنَاتِہِ قَعَدَ إلَی خِدْرِہَا ، فَقَالَ إنَّ فُلاَنًا یَذْکُرُک۔,,,16228 16229,"حَدَّثَنَا عَمْرُو بْنُ مُحَمَّدٍ ، عَنْ إبْرَاہِیمَ بْنِ نَافِعٍ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ قَالَ : تُسْتَأْمَرُ الْبِکْرُ ، وَإِنْ کَانَتْ بَیْنَ أَبَوَیْہَا۔",,,16229 16230,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إِدْرِیسَ ، عَنْ کَہْمَسٍ ، عَنِ ابْنِ بُرَیْدَۃَ قَالَ : جَائَتْ فَتَاۃٌ إلَی عَائِشَۃَ ، فَقَالَتْ : إنَّ أَبِی زَوَّجَنِی من ابْنِ أَخِیہِ لِیَرْفَعَ بی خَسِیسَتَہُ وَإِنِّی کَرِہْت ذَلِکَ ، فَقَالَتْ لَہَا عَائِشَۃُ : انْتَظِرِی حَتَّی یَأْتِیَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَلَمَّا جَائَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَرْسَلَ إلَی أَبِیہَا ، فَجَعَلَ الأَمْرَ إلَیْہَا ، فَقَالَتْ : أَمَّا إذَا کَانَ الأَمْرُ إلَیَّ فَقَدْ أَجَزْت مَا صَنَعَ أَبِی ، إنَّمَا أَرَدْت أَنْ أَعْلَمَ ہَلْ لِلنِّسَائِ مِنَ الأَمْرِ شَیْئ؟۔ (احمد 6/136۔ دارقطنی 45)",,,16230 16231,"حدَّثَنَا سُفیَان بْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ : عَنْ سَعِیدٍ یَبْلُغُ بِہِ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : تُسْتَأْمَرُ الْیَتِیمَۃُ فِی نَفْسِہَا وَصَمْتُہَا إقْرَارُہَا۔ (عبدالرزاق 10295)",,,16231 16232,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْیَتِیمَۃُ تُسْتَأْمَرُ فِی نَفْسِہَا ، فَإِنْ قَبِلَتْ فَہُوَ إذْنُہَا ، وَإِنْ أَبَتْ فَلاَ جَوَازَ عَلَیْہَا۔\n\n(ابوداؤد 2086۔ احمد 2/259)",,,16232 16233,"حَدَّثَنَا سَلاَّمٌ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی بُرْدَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَیُّمَا یَتِیمَۃٍ خُطِبَتْ فَلاَ تُنْکَحُ حَتَّی تُسْتَأْمَرَ ، فَإِنْ ہِیَ أَقَرَّتْ فَلْتَنْکِحْ وَإِقْرَارُہَا سُکُوتُہَا ، وَإِنْ أَنْکَرَتْ فَلاَ تُنْکَحُ۔ (احمد 4/408۔ دارقطنی 77)",,,16233 16234,"حَدَّثَنَا جَرِیرٌ، عَنْ مَنْصُورٍ، عَنْ إبْرَاہِیمَ، قَالَ: قَالَ عُمَرُ: تُسْتَأْمَرُ الْیَتِیمَۃُ فِی نَفْسِہَا، فَرِضَاہَا أَنْ تَسْکُتَ۔",,,16234 16235,حَدَّثَنَا فُضَیْلُ بْنُ عِیَاضٍ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، عَنْ عُمَرَ مِثْلَہُ۔,,,16235 16236,"حدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ مُجَالِدٍ ، عَنِ الشَّعْبِیِّ ، عَنْ عَلِیٍّ وَعُمَرَ وَشُرَیْحٍ قَالُوا : تُسْتَأْمَرُ الْیَتِیمَۃُ فِی نَفْسِہَا ، وَرِضَاہَا أَنْ تَسْکُتَ۔",,,16236 16237,حدَّثَنَا ہُشَیْمٌ ، عَنْ مُجَالِدٍ ، عَنِ الشَّعْبِیِّ ، عَنْ عَلِیٍّ أَنَّہُ کَانَ یَقُولُ إذَا زُوّجَت الْیَتِیمَۃُ فَإِنْ سَکَتَتْ فَہُوَ رِضَاہَا ، وَإِنْ کَرِہَتْ لَمْ تُزَوَّجْ۔,,,16237 16238,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ عن شریح قَالَ : إِنْ سَکَتَتْ وَرَضِیَتْ فَقَدْ سَلَّمَتْ ، وَإِنْ کَرِہَتْ ومعضت لَمْ تُنْکَحْ۔",,,16238 16239,"حَدَّثَنَا ہُشَیْمٌ وَجَرِیرٌ کِلاَہُمَا ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ فِی الْیَتِیمَۃِ إذَا زُوِّجَتْ قَالَ : فَإِنْ سَکَتَتْ ، أَوْ بَکَتْ فَہُوَ رِضَاہَا ، وَإِنْ کَرِہَتْ لَمْ تَزَوَّجْ ، وَلَمْ یَذْکُرْ جَرِیرٌ کَرِہَتْ۔ (احمد 4/394۔ ابن حبان 4085)",,,16239 16240,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ خَالِدِ بْنِ دِینَارٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : سَمِعْتُہُ یَقُولُ فِی الْیَتِیمَۃِ : إذَا زُوِّجَتْ فَضَحِکَتْ ، أَوْ بَکَتْ ، أَوْ سَکَتَتْ فَہُوَ رِضَاہَا۔",,,16240 16241,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ قَالَ : حدَّثَنَا یُونُسُ بْنُ أَبِی إِسْحَاقَ قَالَ : حدَّثَنَا أَبُو بُرْدَۃَ ، قَالَ : قَالَ أَبُو مُوسَی : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : تُسْتَأْمَرُ الْیَتِیمَۃُ فِی نَفْسِہَا ، فَإِنْ سَکَتَتْ فَقَدْ أَذِنَتْ ، وَإِنْ أَنْکَرَتْ لَمْ تُنْکَحْ۔",,,16241 16242,"حَدَّثَنَا حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، عَنْ عُقْبَۃَ بْنِ عَامِرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا أَنْکَحَ الْوَلِیَّانِ فَہِیَ لِلأَوَّلِ۔ (مسلم 7۔ ابن ماجہ 2190)",,,16242 16243,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، عَنْ سَمُرَۃَ : ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : إذَا أَنْکَحَ الْوَلِیَّانِ فَہِیَ لِلأَوَّلِ۔ (ابوداؤد 2081۔ ابن ماجہ 2191)",,,16243 16244,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ أَنَّ امْرَأَۃً زَوَّجَہَا وَلِیٌّ لَہَا بِالْکُوفَۃِ عُبَیْدُ اللہِ ، وَتَزَوَّجَہَا بِالشَّامِ رَجُلٌ آخَرُ قَبْلَ عُبَیْدِ اللہِ ، قَالَ : فَقَدِمَ الرَّجُلُ ، فَخَاصَمَ عُبَیْدَ اللہِ إلَی عَلِیٍّ فَقَضَی بِہَا علی لِلأَوَّلِ بَعْدَ مَا ولدت للآخَرِ۔",,,16244 16245,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : اِلأَوَّلِ عُبَیْدِ اللہِ",,,16245 16246,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ ہِشَامٍ وَأَشْعَثَ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ، عَنْ شُرَیْحٍ قَالَ : إذَا أَنْکَحَ الْوَلِیَّانِ فَالنِّکَاحُ لِلأَوَّلِ۔",,,16246 16247,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ ہَارُونَ بْنِ إبْرَاہِیمَ ، عَنِ ابْنِ سِیرِینَ ، عَنْ شُرَیْحٍ فِی الْوَلِیَّیْنِ یُزَوِّجَانِ ، قَالَ: تُخَیَّرُ۔",,,16247 16248,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ قَالَ : إذَا أَنْکَحَ مُجِیزَانِ فَہِیَ لِلأَوَّلِ۔",,,16248 16249,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ ثَابِتِ بْنِ قَیْسٍ الْغِفَارِیِّ قَالَ : کَتَبْت إلَی عُمَرَ بْنِ عَبْدِ الْعَزِیزِ فِی جَارِیَۃٍ مِنْ جُہَیْنَۃَ زَوَّجَہَا وَلِیُّہَا رَجُلاً مِنْ قَیْسٍ ، وَزَوَّجَہَا أخوہا رَجُلاً مِنْ جُہَیْنَۃَ ، فَکَتَبَ عُمَرُ بْنُ عَبْدَ الْعَزِیزِ أَنْ أَدْخِلْ عَلَیْہَا شُہُودًا عُدُولاً ثم خَیِّرْہَا ، فَأَیَّہُمَا اخْتَارَتْ فَہُوَ زَوْجُہَا",,,16249 16250,حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عن سفیان ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ فِی أَخَوَیْنِ زَوَّجَا أُخْتًا لَہُمَا قَالَ تُخَیَّرَ۔,,,16250 16251,حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حَمَّادٍ فِی الْوَلِیَّیْنِ إِذَا زَوَّجَا قَالَ أَیّہُمَا رَضِیَتْ فَہُوَ زَوْجُہَا۔,,,16251 16252,"حدَّثَنَا مُعْتَمِرٌ عن سلیمان ، عَنْ سَلْمِ بْنِ أَبِی الذَّیَّالِ قَالَ : کَتَبَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ فِی الْیَتِیمَیْنِ : إذَا زُوِّجَا وَہُمَا صَغِیرَانِ أَنَّہُمَا بِالْخِیَارِ۔",,,16252 16253,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ قَالَ : لَہَا الْخِیَارُ۔",,,16253 16254,"حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ قَالَ : ہِیَ بِالْخِیَارِ۔",,,16254 16255,"حَدَّثَنَا ابْنُ مَہْدِیٍّ، عَنْ زَمْعَۃَ، عَنِ ابْنِ طَاوُوسٍ، عَنْ أَبِیہِ قَالَ: فِی الصَّغِیرَتَیْنِ، قَالَ: ہُمَا بِالْخِیَارِ إذَا شَبَّا۔",,,16255 16256,"حَدَّثَنَا عَبَّادُ بْنُ عَوَّامٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ فِی وَلِیِّ الْیَتِیمَۃِ إذَا زَوَّجَہَا وَہِیَ صَغِیرَۃٌ قَالَ : النِّکَاحُ جَائِزٌ ، وَلَہَا الْخِیَارُ۔",,,16256 16257,"حَدَّثَنَا عَبَّادٌ ، عَنْ أَبِی حَنِیفَۃَ ، عَنْ حَمَّادٍ قَالَ : النِّکَاحُ جَائِزٌ وَلاَ خِیَارَ لَہَا۔",,,16257 16258,"حدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ شُعْبَۃَ ، عَنْ زِیَادِ بْنِ عِلاَقَۃَ قَالَ : خَطَبَ رَجُلٌ سَیِّدَۃً مِنْ بَنِی لَیْثٍ ثَیِّبًا ، فَأَبَی أَبُوہَا أَنْ یُزَوِّجَہَا ، فَکَتَبْت إلَی عُثْمَانَ ، فَکَتَبَ عُثْمَانُ : إِنْ کُفُؤًا فَقُولُوا لأَبِیہَا أَنْ یُزَوِّجَہَا ، فَإِنْ أَبَی أَبُوہَا فَزَوِّجُوہَا۔",,,16258 16259,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ قَالَ : إذَا اخْتَلَفَ الْوَلِیُّ وَالْمَرْأَۃُ نَظَرَ السُّلْطَانُ ، فَإِنْ کَانَ الْوَلِیُّ مُضَارًّا زَوَّجَہَا وَإِلاَّ رُدَّ أَمْرُہَا إلَی وَلِیِّہَا۔",,,16259 16260,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ سُلَیْمَانَ التَّیْمِیِّ ، عَنْ أَبِی جَعْفَرٍ الأَشْجَعِیِّ أَنَّ امْرَأَۃً أَتَتْ شُرَیْحًا مَعَہَا أُمُّہَا وَعَمُّہَا ، فَأَرَادَتِ الأُمُّ رَجُلاً وَأَرَادَ الْعَمُّ رَجُلاً ، فَخَیَّرَہَا شُرَیْحٌ ، فَاخْتَارَتِ الَّذِی اخْتَارَتْ أُمُّہَا ، فَقَالَ شُرَیْحٌ لِلْعَمِّ : تَأْذَنْ ؟ قَالَ : لاَ وَاللَّہِ لاَ آذَنُ قَالَ : أَتَأْذَنُ قَبْلَ أَنْ لاَ یَکُونَ لَکَ إذْنٌ ؟ قَالَ : لاَ وَاللَّہِ لاَ آذَنُ ، قَالَ شُرَیْحٌ : اذْہَبِی فأَنْکِحِی ابْنَتَکَ مَنْ شِئْت۔",,,16260 16261,"حدَّثَنَا ابْنُ عَیَّاشٍ ، عَنْ عَبْدِ اللہِ بْنِ دِینَارٍ ، عَمَّنْ حَدَّثَہُ ، عَنِ الْحَسَنِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا أَنْکَحَ الرَّجُلُ ابْنَہُ وَہُوَ کَارِہٌ فَلَیْسَ بِنِکَاحٍ ، وَإِذَا زَوَّجَہُ وَہُوَ صَغِیرٌ جَازَ نِکَاحُہُ۔",,,16261 16262,"حدَّثَنَا مُطَرِّفٌ ، عَنِ الْحَکَمِ ، عَنْ شُرَیْحٍ قَالَ : إذَا زَوَّجَ الرَّجُلُ ابْنَہُ ، أَوِ ابْنَتَہُ فَالْخِیَارُ لَہُمَا إذَا شَبَّا۔",,,16262 16263,"حَدَّثَنَا عَبْدُ اللہِ بْنُ مُبَارَکٍ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، وَالْحَسَنِ وَقَتَادَۃَ قَالُوا : إذَا أَنْکَحَ الصِّغَارَ آبَاؤُہُمْ جَازَ نِکَاحُہُمْ۔",,,16263 16264,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ قَالَ : إذَا زَوَّجَ الرَّجُلُ ابْنَہُ وَہُوَ صَغِیرٌ فَتَزْوِیجُہُ جَائِزٌ عَلَیْہِ ، وَالصَّدَاقُ عَلَی الابْنِ۔",,,16264 16265,"حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ قَالَ : لاَ یُجْبِرُ عَلَی النِّکَاحِ إلاَّ الأَبُ۔",,,16265 16266,"حَدَّثَنَا عُبَیْدِ اللہِ بْنُ مُوسَی ، عَنِ الْحَسَنِ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ قَالَ : إذَا أَنْکَحَ الرَّجُلُ ابْنَہُ وَہُوَ صَغِیرٌ فَنِکَاحُہُ جَائِزٌ وَلاَ طَلاَقَ لَہُ۔",,,16266 16267,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ مُطَرِّفٍ ، عَنِ الْحَکَمِ ، قَالَ : قَالَ شُرَیْحٌ : إذَا أَنْکَحَ الرَّجُلُ ابْنَہُ وَہُوَ صَغِیرٌ جَازَ عَلَیْہِ فَإِذَا بَلَغَ فَإِنْ طَلَّقَ فَنِصْفُ الْمَہْرِ عَلَی الَّذِی کَفَلَ بِہِ۔",,,16267 16268,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ قَالَ : الصَّدَاقُ عَلَی الابْنِ۔",,,16268 16269,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ قَالَ : سَأَلْتُ الْحَکَمَ وَحَمَّادًا ، عَنِ الرَّجُلِ یُزَوِّجُ ابْنَہُ وَہُوَ صَغِیرٌ ، قَالَ الْحَکَمُ: ہو عَلَی اِلابْنِ، وَقَالَ حَمَّادٌ: ہُوَ عَلَی الأَبِ ، وَقَالَ قَتَادَۃُ : قَالَ ابْنُ عُمَرَ ہُوَ عَلَی الَّذِی أَنْکَحْتُمُوہُ، یَعْنِی : الصَّدَاقَ عَلَی اِلابْنِ۔",,,16269 16270,"حَدَّثَنَا حُمَیْدٌ ، عَنِ الْحَسَنِ ، عَنْ مُجَالِدٍ ، عَنِ الشَّعْبِیِّ قَالَ : ہُوَ عَلَی الأَبِ۔",,,16270 16271,"حدَّثَنَا ہُشَیْمٌ ، عَنْ عَوْفٍ ، عَنْ أَنَسٍ قَالَ : کَانَ إذَا زَوَّجَ امْرَأَۃً مِنْ بَنَاتِہِ ، أَوِ امْرَأَۃً مِنْ بَعْضِ أَہْلِہِ قَالَ لِزَوْجِہَا : أُزَوِّجُک تُمْسِکُ بِمَعْرُوفٍ ، أَوْ تُسَرِّحُ بِإِحْسَانٍ۔",,,16271 16272,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سُفْیَانَ ، عَنْ حَبِیبِ بْنِ أَبِی ثَابِتٍ أَنَّ ابْنَ عَبَّاسٍ کَانَ إذَا زَوَّجَ اشْتَرَطَ : {إمْسَاکٌ بِمَعْرُوفٍ ، أَوْ تَسْرِیحٌ بإحسان}۔",,,16272 16273,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ أَنَّ ابْنَ عُمَرَ کَانَ إذَا أَنْکَحَ قَالَ : أُنْکِحُک عَلَی مَا قَالَ اللَّہُ : {إمْسَاکٌ بِمَعْرُوفٍ ، أَوْ تَسْرِیحٌ بِإِحْسَانٍ}۔",,,16273 16274,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنَ قَالَ : أَخْبَرَنِی سُلَیْمَانُ أَنَّہُ خَطَبَ إلَی ابْنِ عُمَرَ مَوْلاَۃً لَہُ ، فَقَالَ لَہُ مِثْلَ ذَلِکَ",,,16274 16275,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : سَأَلْتُہ ، فَقُلْتُ : أَکَانُوا یَشْتَرِطُونَ عِنْدَ عُقْدَۃِ النِّکَاحِ : {إمْسَاکٌ بِمَعْرُوفٍ ، أَوْ تَسْرِیحٌ بِإِحْسَانٍ} ؟ قَالَ ، فَقَالَ : ذَلِکَ لَہُمْ ، وَإِنْ لَمْ یَشْتَرِطُوا مَا کَانَ أَصْحَابُنَا یَشْتَرِطُونَ۔",,,16275 16276,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ جُوَیْبر ، عَنِ الضَّحَّاکِ {وَأَخَذْنَ مِنْکُمْ مِیثَاقًا غَلِیظًا} قَالَ : {إمْسَاکٌ بِمَعْرُوفٍ، أَوْ تَسْرِیحٌ بِإِحْسَانٍ}۔",,,16276 16277,"حدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ {وَأَخَذْنَ مِنْکُمْ مِیثَاقًا غَلِیظًا} قَالَ: {إمْسَاکٌ بِمَعْرُوفٍ ، أَوْ تَسْرِیحٌ بِإِحْسَانٍ}۔",,,16277 16278,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ، عَنْ سَالِمٍ ، عَنْ مُجَاہِدٍ {وَأَخَذْنَ مِنْکُمْ مِیثَاقًا غَلِیظًا} قَالَ: عُقْدَۃُ النِّکَاحِ، قَالَ : قَوْلُہُ : قَدْ نکحت۔",,,16278 16279,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عِکْرِمَۃَ ، وَمُجَاہِدٍ {وَأَخَذْنَ مِنْکُمْ مِیثَاقًا غَلِیظًا} قَالَ : أَخَذْتُمُوہُنَّ بِأَمَانَۃِ اللہِ وَاسْتَحْلَلْتُمْ فُرُوجَہُنَّ بِکَلِمَۃِ اللہِ۔",,,16279 16280,"حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ سُفْیَانَ ، عَنْ حَبِیبٍ ، عَنِ ابْنِ عَبَّاسٍ {وَأَخَذْنَ مِنْکُمْ مِیثَاقًا غَلِیظًا} قَالَ : {إمْسَاکٌ بِمَعْرُوفٍ ، أَوْ تَسْرِیحٌ بِإِحْسَانٍ}۔",,,16280 16281,"حدَّثَنَا ہُشَیْمٌ، عَنْ مَنْصُورٍ، عَنِ الْحَسَنِ قَالَ: کَانَ لاَ یَرَی بَأْسًا أنْ یُزَوِّجَ الرَّجُلُ عَبْدَہُ أَمَتَہُ بِغَیْرِ مَہْرٍ وَلاَ بَیِّنَۃٍ۔",,,16281 16282,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مُحَمَّدٍ الْمُحَارِبِیُّ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ فِی الرَّجُلِ یُزَوِّجُ عَبْدَہُ أَمَتَہُ بِغَیْرِ شُہُودٍ قَالَ : یُشْہِد أَحَبُّ إلَیَّ ، وَإِنْ لَمْ یَفْعَلْ فَہُوَ جَائِزٌ۔",,,16282 16283,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ قَالَ : کَانُوا یُکْرِہُونَ الْمَمْلُوکَیْنِ عَلَی النِّکَاحِ وَیُغْلِقُونَ عَلَیْہِمَا الْبَابَ۔",,,16283 16284,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ بَأْسَ أَنْ یُزَوِّجَ الرَّجُلُ أَمَتَہُ عَبْدَہُ بِغَیْرِ مَہْرٍ۔",,,16284 16285,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ أَبِی فَاطِمَۃَ قَالَ : سَأَلْتُ ابْنَ سِیرِینَ قَالَ : قُلْتُ : رَجُلٌ قَالَ لِمَمْلُوکِہِ : دُونَک جَارِیَتِی ہَذِہِ فُلاَنَۃُ ، فَإِنْ أَحْبَبْت أَنْ تَتَّخِذَہَا لِنَفْسِکَ وَإِلاَّ فَبِعْہَا وَرُدَّ عَلَیَّ ثَمَنَہَا ، قَالَ : اکْسُہَا ثَوْبًا۔",,,16285 16286,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ أَنَّ عَلِیًّا کَانَ یَقُولُ : لاَ یَنْکِحُ الْعَبْدُ فَوْقَ اثْنَتَیْنِ۔",,,16286 16287,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ فِی الْعَبْدِ قَالَ : یَتَزَوَّجُ أَرْبَعًا ، وَقَالَ عَطَائٌ : اثْنَتَیْنِ۔",,,16287 16288,"حَدَّثَنَا جَرِیرٌ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ قَالَ : لاَ یَتَزَوَّجُ الْمَمْلُوکُ إلاَّ امْرَأَتَیْنِ۔",,,16288 16289,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ قَالَ : یَتَزَوَّجُ اثْنَتَیْنِ۔",,,16289 16290,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ یُونُسَ ، عَنْ مُحَمَّدٍ فِی الرَّجُلِ الْمَمْلُوکِ : یُکْرَہُ لَہُ أَنْ یَجْمَعَ أَکْثَرَ مِنَ اثْنَتَیْنِ ، وَلاَ یُذْکَرُ إمَائً کُنَّ ، أَوْ حَرَائِرَ ، إِنَّمَا مَالُہُ مَالُ مَوْلاَہُ۔",,,16290 16291,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ قَالَ : یَتَزَوَّجُ اثْنَتَیْنِ۔",,,16291 16292,"حَدَّثَنَا یَحْیَی بْنُ عَبْدِ الْمَلِکِ بْنِ أَبِی غَنِیَّۃَ ، عَنْ أَبِیہِ ، عَنِ الْحَکَمِ قَالَ : إذَا أَذِنَ الرَّجُلُ لِعَبْدِہِ فِی الْجَارِیَۃِ یَشْتَرِیہَا أَنْ یَطَأَہَا فَہُوَ نِکَاحٌ مِنَ السَّیِّدِ ، وَلاَ یَطَأُ فَوْقَ اثْنَتَیْنِ۔",,,16292 16293,"حَدَّثَنَا ابْنُ أَبِی زَائِدَۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : قَالَ عُمَرُ : مَنْ یَعْلَمُ مَا یَحِلُّ لِلْمَمْلُوکِ مِنَ النِّسَائِ ؟ قَالَ رَجُلٌ : أَنَا ، قَالَ : کَمْ ؟ قَالَ : امْرَأَتَیْنِ ، فَسَکَتَ۔",,,16293 16294,"حَدَّثَنَا زیدُ بْنُ حُبَابٍ ، عَنِ ابْنِ لَہِیعَۃَ ، عَنْ خَالِدِ بْنِ أَبِی عِمْرَانَ قَالَ : سَأَلْتُ سالِمًا وَالْقَاسِمَ ، عَنِ الْعَبْدِ ، کَمْ یَتَزَوَّجُ ؟ فَقَالاَ : أَرْبَعًا۔",,,16294 16295,"حَدَّثَنَا الْمُحَارِبِیُّ ، عَنْ لَیْثٍ ، عَنِ الْحَکَمِ قَالَ : أَجْمَعَ أَصْحَابُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَلَی أَنَّ الْمَمْلُوکَ لاَ یَجْمَعُ مِنَ النِّسَائَ فَوْقَ اثْنَتَیْنِ۔",,,16295 16296,"حَدَّثَنَا وَکِیعٌ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ قَالَ : یَتَزَوَّجُ الْمَمْلُوکُ فَوْقَ اثْنَتَیْنِ۔",,,16296 16297,"حدَّثَنَا وَکِیعُ بن الجرَّاح ، عَنْ سُفیَان ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ وَعَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالاَ : إذَا تَزَوَّجَ الْعَبْدُ بِغَیْرِ إذْنِ مَوْلاَہُ ثُمَّ أَذِنَ الْمَوْلَی فَہُوَ جَائِزٌ۔",,,16297 16298,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ شُعْبَۃَ ، عَنْ مَنْصُورٍ ، عَنِ الْحَسَنِ قَالَ : إذَا أَجَازَہُ الْمَوْلَی فَہُوَ جَائِزٌ۔",,,16298 16299,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، وَالْحَسَنِ فِی الْعَبْدِ یَتَزَوَّجُ بِغَیْرِ إذْنِ سَیِّدِہِ ، قَالاَ : إِنْ شَائَ أَجَازَ النِّکَاحَ سَیِّدُہُ ، وَإِنْ شَائَ رَدَّہُ۔",,,16299 16300,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ قَالَ : قَالَ : إِنْ أَجَازَہُ المولی جَازَ ، وَقَالَ حَمَّادُ : یَسْتَأْنِفُ النِّکَاحَ۔",,,16300 16301,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مَنْصُورٍ ، عَنِ الْحَسَنِ قَالَ : إذَا طَلَّقَ الرَّجُلُ امْرَأَتَہُ ثُمَّ تَزَوَّجَہَا عَبْدٌ بِغَیْرِ إذْنِ مَوَالِیہِ فَدَخَلَ بِہَا ، قَالَ الْحَسَنُ : لَیْسَ بِزَوْجٍ۔",,,16301 16302,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُحَمَّدِ بْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ مِثْلَ قَوْلِ الْحَسَنِ ، وَقَالَ الْحَکَمُ : ہُوَ زَوْجٌ وَلَہُ أَنْ یُرَاجِعَہَا۔",,,16302 16303,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ فِی الْمَرْأَۃِ تُطْلَقُ ثَلاَثًا فَیَتَزَوَّجُہَا عَبْدٌ بِغَیْرِ إذْنِ مَوَالِیہِ ، قَالَ : قَالَ عَطَائٌ : کُلُّ نِکَاحٍ عَلَی غَیْرِ وَجْہِ نِکَاحٍ فَإِنَّہَا لاَ تَرْجِعُ إلَی زَوْجِہَا الأَوَّلِ۔",,,16303 16304,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنِ عَبْدِ الْعَزِیزِ بْنِ عُبَیْدِ اللہِ ، عَنِ الْحَارِثِ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ تَرْجِعُ إلَیْہِ ، لأَنَّہُ نِکَاحٌ لَیْسَ رِشْدَۃً۔",,,16304 16305,"حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ ، عَنْ جَریر ، عَنْ حَمَّادٍ قَالَ : لاَ یَحِلُّ لَہَا أنْ تَرْجِعَ بِہِ إلَی زَوْجِہَا الأَوَّلِ حَتَّی تُنْکَحَ نِکَاحَ الْمُسْلِمِینَ الَّذِی یَجُوزُ۔",,,16305 16306,"حَدَّثَنَا عَفَّانَ قَالَ : حدَّثَنَا سَعِیدُ بْنُ زَیْدٍ قَالَ : حدَّثَنَا لَیْثٌ ، عَنْ طَاوُوسٍ قَالَ : کُلُّ نِکَاحٍ کَانَ بِغَیْرِ سُنَّۃٍ فَإِنَّ الْمَرْأَۃَ لاَ تَحِلُّ لِزَوْجِہَا الأَوَّلِ۔",,,16306 16307,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ فِی الْعَبْدِ وَالْخَصِیِّ قَالَ : ہُوَ زَوْجٌ۔",,,16307 16308,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی بِشْرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ فِی الْحُرِّ یَتَزَوَّجُ الأَمَۃَ قَالَ : مَا ازْلَحَفَّ ، عَنِ الزِّنَا إلاَّ قَلِیلاً لِقَوْلِہِ : {وَأَنْ تَصْبِرُوا خَیْرٌ لَکُمْ} قَالَ : یَقُول ، عَنْ نِکَاحِ الأَمَۃِ۔",,,16308 16309,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ الْعَوَّامِ ، عَمَّنْ حَدَّثَہُ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : مَا تَزَحَّفَ ، عَنِ الزِّنَا إلاَّ قَلِیلاً۔",,,16309 16310,حَدَّثَنَا إِسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ أَنَّہُ کَانَ یَکْرَہُ تَزْوِیج الأَمَۃِ مَا قَدَرَ عَلَی الْحُرَّۃِ إلاَّ أَنْ یَخْشَی الْعَنَتَ۔,,,16310 16311,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو قَالَ : سَأَلَ عَطَائٌ جَابِرًا ، عَنِ نِکَاحِ الأَمَۃِ ، فَقَالَ : لاَ یَصْلُحُ الْیَوْمَ۔",,,16311 16312,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ قَالَ : لاَ یَصْلُحُ لِلْحُرِّ أَنْ یَتَزَوَّجَ الأَمَۃَ إلاَّ أَنْ لاَ یَجِدَ طَوْلاً۔",,,16312 16313,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ أَبِی عُبَیْدَۃَ ، عَنْ عُمَارَۃَ بْنَ حَیَّانَ أَنَّ امْرَأَۃً أَتَتْ جَابِرَ بْنَ زَیْدٍ ، فَقَالَتْ : إنَّ رَجُلاً یَخْطُبُ عَلَیَّ أَمَتِی ، قَالَ : لاَ تُزَوِّجِیہِ قَالَتْ : فَإِنَّہُ یَخْشَی عَلَی نَفْسِہِ ، قَالَ : لاَ تُزَوِّجِیہِ ، قَالَتْ : فَإِنَّہُ یَخْشَی أَنْ یَزْنِیَ بِہَا ، قَالَ : فَزَوِّجِیہِ۔",,,16313 16314,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمَ وَحَمَّادٍ سُئِلاَ ، عَنْ نِکَاحِ الأَمَۃِ فَقَالاَ : {لِمَنْ خَشِیَ الْعَنَتَ مِنْکُمْ}۔",,,16314 16315,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ قَالَ : إنَّہُ مِمَّا وُسِّعَ بِہِ عَلَی ہَذِہِ الأُمَّۃِ ، نِکَاحُ الأَمَۃِ وَالنَّصْرَانِیَّۃ۔",,,16315 16316,"حَدَّثَنَا عبد اللہ بْنُ إدْرِیسَ ، عَنْ یحیی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : قَالَ عُمَرُ : أَیُّمَا عَبْدٍ نَکَحَ حُرَّۃً فَقَدْ أُعْتِقَ نِصْفُہُ ، وَأَیُّمَا حُرٍّ نَکَحَ أَمَۃً فَقَدْ أَرِقَ نِصْفَہُ۔",,,16316 16317,"حَدَّثَنَا الْفَضْلُ ، عَنْ شَرِیکٍ ، عَنْ خُصَیفِ ، عَنْ عَامِرٍ قَالَ : نِکَاحُ الأَمَۃِ کَالْمَیْتَۃِ وَالدَّمِ وَلَحْمِ الْخِنْزِیرِ، لاَ یَحِلُّ إلاَّ لِلْمُضْطَرِّ۔",,,16317 16318,"حدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ عَطَائٍ وَخُصَیْفٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ یَتَزَوَّجُ الْحُرُّ مِنَ الإِمَائِ إلاَّ وَاحِدَۃً",,,16318 16319,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی ہَاشِمٍ ، عَنِ الْحَارِثِ قَالَ : قَالَ : یَتَزَوَّجُ الْحُرُّ مِنَ الإِمَائِ أَرْبَعَۃً ، وَقَالَ حَمَّادٌ : ثِنْتَیْنِ۔",,,16319 16320,"حَدَّثَنَا رُوحُ بْنُ عُبَادَۃَ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ قَالَ: یَتَزَوَّجُ الْحُرُّ أَرْبَعَ إمَائٍ وَأَرْبَعَ نَصْرَانِیَّاتٍ، وَالْعَبْدُ کَذَلِکَ۔",,,16320 16321,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ قَالَ : إنَّمَا أَحَلَّ اللَّہُ وَاحِدَۃً لِمَنْ خَشِیَ الْعَنَتَ عَلَی نَفْسِہِ وَلَمْ یَجِدُ طَوْلاً۔",,,16321 16322,حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ ہِشَامِ الدَّسْتَوَائِیِّ ، عَنْ رَجُلٍ ، عَنِ الْحَسَنِ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی أَنْ تُنْکَحَ الأَمَۃ عَلَی الْحُرَّۃِ۔ (عبدالرزاق 13099۔ طبرانی 17),,,16322 16323,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ قَالَ : لاَ یَنْکِحُ الأَمَۃَ عَلَی الْحُرَّۃِ فَإِنْ فَعَلَ ذَلِکَ لَمْ یُتْرَکْ۔",,,16323 16324,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ قَالَ : لاَ یَتَزَوَّجُ الرَّجُلُ الأَمَۃَ عَلَی الْحُرَّۃِ ، وَیَتَزَوَّجُ الْحُرَّۃَ عَلَی الأَمَۃِ۔",,,16324 16325,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْمِنْہَالِ ، عَنْ زِرٍّ أَو عَبَّادِ بْنِ عَبْدِ اللہِ ، عَنْ عَلِیٍّ قَالَ : لاَ تُنْکَحُ الأَمَۃُ عَلَی الْحُرَّۃِ ، وَتُنْکَحُ الْحُرَّۃُ عَلَی الأَمَۃِ۔",,,16325 16326,"حَدَّثَنَا وَکِیعٌ، عَنْ إسْمَاعِیلَ، عَنِ الشَّعْبِیِّ، عَنْ مَسْرُوقٍ قَالَ: لاَ یَنْکِحُ الأَمَۃَ عَلَی الْحُرَّۃِ إلاَّ الْمَمْلُوکُ۔",,,16326 16327,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، عَنْ مَسْرُوقٍ ، عَنْ عَبْدِ اللہِ قَالَ : إلاَّ الْمَمْلُوکَ۔",,,16327 16328,"حَدَّثَنَا عَبْدَۃُ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنِ ابْنِ الْمُسَیَّبِ قَالَ : یَتَزَوَّجُ الْحُرَّۃَ عَلَی الأَمَۃِ ، وَلاَ یَتَزَوَّجُ الأَمَۃَ عَلَی الْحُرَّۃِ۔",,,16328 16329,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ الملک ، عَنْ عَطَائٍ فِی الرَّجُلِ یَنْکِحُ الْحُرَّۃَ عَلَی الأَمَۃِ قَالَ : حسَنٌ۔",,,16329 16330,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ زَمْعَۃَ ، عَنِ ابْنِ طَاوُوسٍ قَالَ : قُلْتُ لأَبِی : رَجُلٌ نَکَحَ أَمَۃً عَلَی حُرَّۃٍ وَإِنَّہُ یُزْعَمُ إِنَّہُ قَدْ حَرُمَتْ عَلَیْہِ ؟ قَالَ : صَدَقُوا۔",,,16330 16331,"حَدَّثَنَا عَبدَۃ بن سلیمان ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ سَعِیدِ بْنِ الْمُسَیَّبِ ، وَالْحَسَنِ فِی الرَّجُلِ یَتَزَوَّجُ الأَمَۃَ عَلَی الْحُرَّۃِ قَالاَ : یُفَرَّقُ بَیْنَہُ وَبَیْنَ الأَمَۃِ۔",,,16331 16332,"حَدَّثَنَا حَکَّامٌ الرَّازِیّ ، عَنْ مُثَنَّی ، عَنِ الزُّہْرِیِّ فِی رَجُلٍ تَزَوَّجَ أَمَۃً عَلَی حُرَّۃٍ قَالَ : یُوجَعُ ظَہْرُہُ وَتُنْزَعُ مِنْہُ۔",,,16332 16333,"حدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ قَالَ : إذَا تَزَوَّجَ الرَّجُلُ الْحُرَّۃَ عَلَی الأَمَۃِ فُرِّقَ بَیْنَہُ وَبَیْنَہَا إلاَّ أَنْ یَکُونَ لَہَا مِنْہُ وَلَدٌ۔",,,16333 16334,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : نِکَاحُ الْحُرَّۃِ عَلَی الأَمَۃِ طَلاَقُ الأَمَۃِ۔",,,16334 16335,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ إسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ ، عَنْ مَسْرُوقٍ مِثْلَہُ إلاَّ أَنَّہُ قَالَ : ہِیَ کَالْمَیْتَۃِ یُضْطَرُّ إلَیْہَا ، فَإِذَا أَغْنَاک اللَّہُ فَاسْتَغْنِ۔",,,16335 16336,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ ، عَنْ مَسْرُوقٍ قَالَ : نِکَاحُ الْحُرَّۃِ عَلَی الأَمَۃِ طَلاَقُ الأَمَۃِ۔",,,16336 16337,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ جَابِرِ بْنِ زَیْدٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إذَا تَزَوَّجَ الْحُرَّۃَ عَلَی الأَمَۃِ فَہُوَ لِلْمَمْلُوکَۃِ طَلاَقٌ۔",,,16337 16338,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ ابْنِ الْمُسَیَّبِ ، وَالْحَسَنِ فِی الرَّجُلِ یَتَزَوَّجُ الْمَمْلُوکَۃَ عَلَی الْیَہُودِیَّۃِ وَالنَّصْرَانِیَّۃ قَالاَ : یُفَرَّقُ بَیْنَہُ وَبَیْنَ الْمَمْلُوکَۃِ۔",,,16338 16339,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ فِی الرَّجُلِ تَکُونُ تَحْتَہُ الْمَرْأَۃُ النَّصْرَانِیَّۃُ : لاَ یَتَزَوَّجُ عَلَیْہَا أَمَۃً مُسْلِمَۃً۔",,,16339 16340,"حدَّثَنَا یَحْیَی بْنُ آدَمَ قَالَ : حدَّثَنَا شَرِیکٌ ، عَنْ سَالِمٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ یَتَزَوَّجُ الْیَہُودِیَّۃَ وَالنَّصْرَانِیَّۃ عَلَی الْمُسْلِمَۃِ یَعْنِی الْمُسْلِمَ۔",,,16340 16341,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ حَجَّاجٍ ، عَنِ الْمِنْہَالِ ، عَنْ زِرٍّ ، عَنْ عَلِیٍّ قَالَ : إذَا تَزَوَّجَ الْحُرَّۃَ عَلَی الأَمَۃِ قَسَمَ لِذِہِ یَوْمًا وَلِذِہِ یَوْمَیْنِ۔",,,16341 16342,"حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْمِنْہَالِ ، عَنْ زِرٍّ ، عَنْ عَلِیٍّ قَالَ : إذَا تَزَوَّجَ الْحُرَّۃَ عَلَی الأَمَۃِ قَسَمَ لِلأَمَۃِ یَوْمًا وَلِلْحُرَّۃِ یَوْمَیْنِ۔",,,16342 16343,حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنْ إبْرَاہِیمَ مِثْلَہُ۔,,,16343 16344,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : لِلْحُرَّۃِ یَوْمَانِ وَلَیْلَتَانِ ، وَلِلأَمَۃِ یَوْمٌ وَلَیْلَۃٌ۔",,,16344 16345,"حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ مُطَرِّفٍ ، عَنِ الشَّعْبِیِّ ، عَنْ مَسْرُوقٍ قَالَ : إذَا اجْتَمَعَتَا قَسَمَ لِلْحُرَّۃِ الثُّلُثَیْنِ مِنْ نَفْسِہِ وَمَالِہِ۔",,,16345 16346,"حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ وَعَنْ فِرَاسٍ ، عَنْ عَامِرٍ قَالاَ : یَتَزَوَّجُ الْحُرَّۃَ عَلَی الأَمَۃِ وَیُقَسِّمُ یَوْمًا ویومین۔",,,16346 16347,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ قَالَ : إذَا نُکِحَتِ الْحُرَّۃُ عَلَی الأَمَۃِ فُضِّلَتِ الْحُرَّۃُ ، فی الْقَسَمِ ، لِلْحُرَّۃِ لَیْلَتَانِ وَلِلأَمَۃِ لَیْلَۃٌ۔",,,16347 16348,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ أَبِیہِ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ قَالَ : إذَا نَکَحَ الأَمَۃَ ثُمَّ وَجَدَ مَا یَنْکِحُ الْحُرَّۃَ إِنْ شَائَ أَمْسَکَہَا وَیَقْسِمُ لَیْلَتَیْنِ وَلَیْلَۃً۔",,,16348 16349,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ قَالَ : یَقْسِمُ لِلْحُرَّۃِ یَوْمَیْنِ وَلِلأَمَۃِ یَوْمًا۔",,,16349 16350,"حَدَّثَنَا یَحْیَی بْنُ یَعْلَی التَّیْمِیُّ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ قَالَ : لِلْحُرَّۃِ یَوْمَانِ وَلِلأَمَۃِ یَوْمٌ۔",,,16350 16351,"حَدَّثَنَا یُونُسُ بْنُ مُحَمَّدٍ قَالَ : حدَّثَنَا شَرِیکٌ ، عَنْ عَطَائٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ قَالَ : لِلْحُرَّۃِ یَوْمَانِ وَلِلأَمَۃِ یَوْمٌ۔",,,16351 16352,"حَدَّثَنَا عَبدَۃ بن سلیمان ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ ابْنِ الْمُسَیَّبِ ، وَالْحَسَنِ فِیمَنْ یَتَزَوَّجُ الْیَہُودِیَّۃَ وَالنَّصْرَانِیَّۃ عَلَی الْمُسْلِمَۃِ قَالاَ : یَقْسِمُ بَیْنَہُمَا سَوَائً۔",,,16352 16353,"حَدَّثَنَا مَعْنُ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ قَالَ : قسْمَتُہُمَا سَوَائٌ۔",,,16353 16354,حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عُبَیْدَۃَ ، عَنْ إبْرَاہِیمَ قَالَ یَقْسِمُ لَہَا کَمَا یَقْسِمُ لِلْحُرَّۃِ۔,,,16354 16355,"حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ مُطَرِّفٍ ، عَنِ الشَّعْبِیِّ فِی الرَّجُلِ یَتَزَوَّجُ الْمُسْلِمَۃَ وَالْیَہُودِیَّۃَ ، أَوِ النَّصْرَانِیَّۃَ قَالَ : یُسَوِّی بَیْنَہُمَا فِی الْقِسْمَۃِ مِنْ مَالِہِ وَنَفْسِہِ۔",,,16355 16356,"حَدَّثَنَا أَبُو خَالِدٍ وَلَیْسَ بِالأَحْمَرِ، عَنْ سَعِیدٍ قَالَ: سَأَلْتُ الْحَکَمَ وَحَمَّادًا عَنہُ فَقَالاَ: ہُمَا فِی الْقِسْمَۃِ سَوَائٌ۔",,,16356 16357,"حَدَّثَنَا ہُشَیْمٌ قَالَ : حدَّثَنَا یُونُسُ ، عَنِ الْحَسَنِ أَنَّہُ قَالَ : فِی صَدَاقِ السِّرِّ : إذَا أَعْلَنَ أَکْثَرَ مِنْہُ یُؤْخَذُ بِالسِّرِّ وَتَبْطُلُ الْعَلاَنِیَۃُ۔",,,16357 16358,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ خَالِدٍ ، عَنِ ابْنِ سِیرِینَ ، عَنْ شُرَیْحٍ قَالَ : یُؤْخَذُ بِالسِّرِّ وَتَبْطُلُ الْعَلاَنِیَۃُ۔",,,16358 16359,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ قَالَ : الأَمْرُ عَلَی السِّرِّ۔",,,16359 16360,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ مَنْصُورٍ قَالَ : سَأَلْتُ الْحَکَمَ بْنَ عُتَیبَۃَ ، عَنِ الرَّجُلِ أَصْدَقَ أَلْفًا فِی السِّرِّ وَأَعْلَنَ أَلْفَیْنِ قَالَ : یُؤْخَذُ بِالسِّرِّ لأَنَّہُ الْحَقُّ ، وَتُبْطَلُ الْعَلاَنِیَۃُ۔",,,16360 16361,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی عَوْنٍ ، عَنْ شُرَیْحٍ قَالَ : یُؤْخَذُ بِالأَوَّلِ مِنہُمَا۔",,,16361 16362,"حدَّثَنَا ہُشَیْمٌ ، عَنْ حُصَیْنٍ ، عَنِ الشَّعْبِیِّ قَالَ : یُؤْخَذُ بِالْعَلاَنِیَۃِ۔",,,16362 16363,"حَدَّثَنَا ابْنُ مُسْہِرٍ ، وَأَبُو مُعَاوِیَۃَ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ قَالَ : یُؤْخَذُ بِالْعَلاَنِیَۃِ۔",,,16363 16364,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ مَنْصُورِ بْنِ عَبْدِ الرَّحْمَنِ قَالَ : لَقِیتُ الشَّعْبِیَّ فَسَأَلْتُہُ ، عَنْ ذَلِکَ ، فَقَالَ قَالَ : شُرَیْحٌ ، ہَدَمَ الْعَلاَنِیَۃُ السِّرَّ۔",,,16364 16365,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ زَیْدٍ ، عَنْ شُعَیب ، عَنْ أَبِی قِلاَبَۃَ قَالَ : یُؤْخَذُ بِالْعَلاَنِیَۃِ۔",,,16365 16366,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ والشَّعْبِیِّ قَالاَ : إذَا کَانَتِ الأَمَۃُ تَحْتَ الْحُرِّ فَاشْتَرَاہَا قَالاَ : النِّکَاحُ مُنْہَدِم ، وَتَکُونُ جَارِیَۃً لَہُ یَطَؤُہَا إِنْ شَائَ۔",,,16366 16367,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ تکون تحتہ الأَمَۃَ ثُمَّ یَشْتَرِیہَا قَالَ : أَذْہَبَ الرِّقُّ عُقْدَتَہَا",,,16367 16368,"حَدَّثَنَا وَکِیعٌ بن الجراح ، عَنِ عَلِی بْنِ مُبَارَکٍ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ مَکْحُولٍ فِی الرَّجُلِ یَتَزَوَّجُ الأَمَۃَ ثُمَّ یَشْتَرِیہَا قَالَ : یَطَؤُہَا بِالْمِلْکِ",,,16368 16369,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ قَالَ : یَطَؤُہَا بِالْمِلْکِ۔",,,16369 16370,"حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنِ ابْنِ أَبِی ذِئْبٍ قَالَ : سَأَلْتُ عَطَائً ، عَنِ الرَّجُلِ تَکُونُ تَحْتَہُ الأَمَۃُ فَیَشْتَرِیہَا قَالَ : ہِیَ أَمَتُہُ یَصْنَعُ بِہَا مَا شَائَ ، قَالَ : وَسَأَلْت الزُّہْرِیَّ ، فَقَالَ مِثْلِ ذَلِکَ۔",,,16370 16371,"حَدَّثَنَا خَالِدُ بْنُ حَیَّانَ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ قَالَ : سَأَلْتُ الزُّہْرِیَّ ، عَنْ رَجُلٍ کَانَتْ تَحْتَہُ أَمَۃٌ فَاشْتَرَاہَا، قَالَ : ہَدَمَ الشِّرَائُ النِّکَاحَ ، قَالَ جَعْفَرٌ : وَسَأَلْت مَیْمُونَ بْنَ مِہْرَانَ ، عَنْ ذَلِکَ قَالَ : تَحِلُّ لَہُ مِنْ قِبَلِ بابین ، مِنْ قِبَلِ التَّزْوِیجِ وَمِنْ قِبَلِ الشِّرَائِ۔",,,16371 16372,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَبِیبٍ ، عَنْ عَمْرٍو قَالَ : سُئِلَ جَابِرُ بْنُ زَیْدٍ ، عَنْ رَجُلٍ کَانَتْ تَحْتَہُ أَمَۃٌ فَطَلَّقَہَا تَطْلِیقَۃً ثُمَّ أَعْتَقَ الْعَبْدَ فَاشْتَرَی امْرَأَتَہُ ، مَا مَنْزِلتُہَا ؟ قَالَ : إذَا اشْتَرَاہَا فَہِیَ بِمَنْزِلَۃِ السُّرِّیۃِ ، وَقَدْ أَفْتَی بِذَلِکَ عِکْرِمَۃُ وَالْحَسَنُ بن أبی الحسن۔",,,16372 16373,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَمَّنْ حَدَّثَہُ عَنْ عُثْمَانَ بْنِ عَفَّانَ وَزَیْدِ بْنِ ثَابِتٍ أَنَّہُمَا قَالاَ : لاَ تَحِلُّ لَہُ حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ۔",,,16373 16374,"حَدَّثَنَا عَبَّاد بْنُ الْعَوَّامِ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ قَالَ : قرَأْت کِتَابَ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ : إنَّہَا لاَ تَحِلُّ لَہُ حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ۔",,,16374 16375,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ ، عَنْ عَلْقَمَۃَ قَالَ : لاَ تَحِلُّ لَہُ حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ۔",,,16375 16376,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، وَابْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِِ ، عَنْ أَبِی الضُّحَی ، عَنْ مَسْرُوقٍ قَالَ : لاَ تَحِلُّ لَہُ حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ۔",,,16376 16377,حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی عَوْنٍ ، عَنْ أَبِی صَالِحٍ الْحَنَفِیِّ ، عَنْ عَلِیٍّ قَالَ لاَ یَطَؤُہَا۔,,,16377 16378,حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ لاَ تَحِلُّ لَہُ حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ۔,,,16378 16379,"حَدَّثَنَا جَرِیرٌ ، عَنِ الشَّیْبَانِیِّ ، عَنْ أَبِی الضُّحَی وَالشَّعْبِیِّ قَالاَ : لاَ تَحِلُّ لَہُ إلاَّ مِنْ حَیْثُ حُرِّمَتْ عَلَیْہِ ، حَتَّی تزوج زَوْجًا غَیْرَہُ وَیَدْخُلَ بِہَا۔",,,16379 16380,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ قَالَ : لاَ تَحِلُّ لَہُ إلاَّ مِنْ حَیْثُ حُرِّمَتْ عَلَیْہِ۔",,,16380 16381,"حَدَّثَنَا عَبَّادُ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ قَالَ : لاَ تَحِلُّ لَہُ حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ۔",,,16381 16382,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ قَالَ : لاَ تَحِلُّ لَہُ حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ۔",,,16382 16383,"حَدَّثَنَا عبد اللہ بْنُ إدْرِیسَ ، عَنْ مَالِکٍ ، عَنِ الزُّہْرِیِّ ؛ أَنَّ أَبَا عَبْدِ الرَّحْمَنِ سَأَلَ زَیْدَ بْنَ ثَابِتٍ عن مَمْلُوکَۃٍ کَانَتْ تَحْتَ رَجُلٍ فَطَلَّقَہَا فَبَتَّہَا ثُمَّ اشْتَرَاہَا ؟ قَالَ : لاَ تَحِلُّ لَہُ إلاَّ مِنْ حَیْثُ حُرِّمَتْ عَلَیْہِ۔",,,16383 16384,"حدَّثَنَا ابْنُ إدْرِیسُ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ قَالَ : لاَ تَحِلُّ لَہُ إلاَّ مِنْ حَیْثُ حُرِّمَتْ عَلَیْہِ۔",,,16384 16385,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ، عَنْ حَبِیبٍ، عَنْ عَمْرٍو، عَنْ جَابِرِ بْنِ زَیْدٍ قَالَ: لاَ تَحِلُّ لَہُ حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ۔",,,16385 16386,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمَ ، عَنْ إبْرَاہِیمَ قَالَ : سَأَلْتُ عَنْہُ عَبِیْدَۃَ ، فَأَبَی ذَلِکَ عَلَیَّ۔",,,16386 16387,"حدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ قَالَ : ہِیَ مَا مَلَکَتْ یَمِینُہُ۔",,,16387 16388,"حَدَّثَنَا عَبَّادُ بْنُ عَوَّامٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ قَالَ : یَطَؤُہَا بِمِلْکِ الْیَمِینِ۔",,,16388 16389,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنْ مُحَمَّدٍ ، عَنْ حُمَیْدِ بْنِ عَبْدِ الرَّحْمَنِ قَالَ : أَحَلَّتْہَا آیَۃٌ وَحَرَّمَتْہَا آیَۃٌ أُخْرَی ، وَلاَ آمُرُک وَلاَ أَنْہَاک۔",,,16389 16390,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : لَیسَ لَہُ أَنْ یَغْشَاہَا بِمِلْکِ الْیَمِینِ ، وَإِنْ شَائَ أَعْتَقَہَا وَزَوَّجَہَا ، وَکَانَتْ عِنْدَہُ عَلَی وَاحِدَۃٍ ، وَکَانَ قَتَادَۃُ یَأْخُذُ بِہِ۔",,,16390 16391,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ جَابِرٍ وَأَبِی سَلَمَۃَ مِثْلَہُ۔,,,16391 16392,") حَدَّثَنَا عَبْدُ الْعَزِیزِ بْنُ عَبْدِ الصَّمَدِ الْعَمِّیُّ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ إبْرَاہِیمَ أَنَّ ابْنَ مَسْعُودٍ قَالَ : فِی رَجُلٍ یَعْنِی عَبْدٍ طَلَّقَ امْرَأَتَہُ تَطْلِیقَتَیْنِ وَہِیَ مَمْلُوکَۃٌ فَأُعْتِقَا ، فَقَالَ ابْنُ مَسْعُودٍ : لاَ یَتَزَوَّجُہَا حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ۔",,,16392 16393,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ وَعَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ فِی الأَمَۃِ تَکُونُ تَحْتَ الْعَبْدِ فَیُطَلِّقُہَا تَطْلِیقَتَیْنِ فَیُعْتَقَانِ جَمِیعًا قَالاَ : لاَ تَحِلُّ لَہُ حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ۔",,,16393 16394,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ دَاوُدَ ، عَنْ عَامِرٍ فِی الْعَبْدِ یُطَلِّقُ الأَمَۃَ تَطْلِیقَتَیْنِ فَیُعْتَقَانِ جَمِیعًا قَالَ : لاَ تَحِلُّ لَہُ حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ",,,16394 16395,"حَدَّثَنَا عَبْدَۃُ بن سلیمان ، عَنْ سَعِیدِ بْنِ أَبِی عَرُوبَۃَ ، عَمَّنْ حَدَّثَہُ عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ أَبِی الْحَسَنِ مَوْلًی لِبَنِی نَوْفَلٍ قَالَ : کُنْتُ أَنَا وَامْرَأَتِی مَمْلُوکَیْنِ فَطَلَّقْتُہَا تَطْلِیقَتَیْنِ ثُمَّ أُعْتِقْنَا بَعْدَ ذَلِکَ فَأَرَدْت مُرَاجَعَتَہَا فَسَأَلْت ابْنَ عَبَّاسٍ ، فَقَالَ : إِنْ رَاجَعْتہَا فَہِیَ عِنْدَکَ عَلَی وَاحِدَۃٍ وَمَضَتِ اثْنَتَانِ ، قَضَی بِذَلِکَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,16395 16396,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ قَالَ : حدَّثَنَا شَیْبَانَ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ عُمَر بْنِ مُعَتِّبٍ ، عَنْ أَبِی الْحَسَنِ مَوْلًی لِبَنِی نَوْفَلٍ ، عَنِ ابْنِ عَبَّاسٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِمِثْلِہِ۔ \n\n(ابوداؤد 2181۔ احمد 1/229)",,,16396 16397,"حَدَّثَنَا عَبْدُ الْوَہَّابِ بْنُ عَطَائٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ أَبِی سَلَمَۃَ وَجَابِرِ بْنِ عَبْدِ اللہِ قَالاَ : إذَا أُعْتِقَتْ فِی عِدَّتِہَا ، فَإِنَّہُ یَتَزَوَّجُہَا إِنْ شَائَ وَتَکُونُ عِنْدَہُ عَلَی وَاحِدَۃٍ۔",,,16397 16398,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ تَزَوَّجَ أَمَۃً بَیْنَ رَجُلَیْنِ فَاشْتَرَی نَصِیبَ أَحَدِہِمَا قَالَ : یَکُفُّ عَنْہَا حَتَّی یَشْتَرِیَ نَصِیبَ الآخَرِ۔",,,16398 16399,حَدَّثَنَا ہُشَیْمٌ ، عَنْ صَاحِبٍ لَہُ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ مِثْلَہُ۔,,,16399 16400,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مَنْصُورٍ ، عَنْ قَتَادَۃَ قَالَ : لَمْ یَزِدْہُ مِلْکُہُ مِنہَا إلاَّ قُرْبًا۔",,,16400 16401,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ أَنَّہُ کَانَ یَقُولُ : إذَا اشْتَرَی الرَّجُل مِنَ امْرَأَتہِ نَصِیبًا فَلاَ یَقْرَبُہَا حَتَّی یَسْتَخْلِصَہَا۔",,,16401 16402,"حَدَّثَنَا ہُشَیْمُ بْنُ بَشِیرٍ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ صُہَیْبٍ ، عَنْ أَنَسٍ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ جَعَلَ عِتْقَ صَفِیَّۃَ صَدَاقَہَا۔ (بخاری 371۔ ابوداؤد 2991)",,,16402 16403,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ قَالَ : قَالَ عَلِیٌّ : إِن شَاء الرَّجُل أَعْتَقَ أُمَّ وَلَدِہِ وَجَعَلَ عِتْقَہَا مَہْرَہَا۔",,,16403 16404,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، قَالَ : قَالَ سَعِیدُ بْنُ الْمُسَیَّبِ : مَنْ أَعْتَقَ وَلِیدَتَہُ ، أَوْ أُمَّ وَلَدِہِ وَجَعَلَ عِتْقَہَا صَدَاقَہَا رَأَیْت ذَلِکَ جَائِزًا لَہُ۔",,,16404 16405,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ أَنَّہُ کَانَ یَقُولُ : إذَا أَعْتَقَ الرَّجُلُ أَمَتَہُ وَجَعَلَ عِتْقَہَا صَدَاقَہَا ، إنَّ ذَلِکَ جَائِزٌ لَہُ۔",,,16405 16406,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، عَنِ ابْنِ عُمَرَ فِی الرَّجُلِ یَعْتِقُ الأَمَۃَ وَیَجْعَلُ عِتْقَہَا صَدَاقَہَا قَالَ : ہُوَ کَالرَّاکِبِ بَدَنَتَہُ۔",,,16406 16407,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الْکَنُودِ ، عَنْ عَبْدِ اللہِ قَالَ : مَثَلُ الَّذِی یَعْتِقُ أَمَتَہُ وَیَتَزَوَّجُہَا مَثَلُ الرَّجُلِ یَرْکَبُ بَدَنَتَہُ۔",,,16407 16408,حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ ابْنِ سِیرِینَ أَنَّہُ کَانَ یَقُولُ إذَا جَعَلَ عِتْقَ أَمَتِہِ صَدَاقَہَا کَانَ یُحِبُّ أَنْ یَجْعَلَ لَہَا شَیْئًا مَعَ ذَلِکَ۔,,,16408 16409,"حَدَّثَنَا عَبَّادُ بْنُ عَوَّامٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ فِی رَجُلٍ قَالَ لأَمَتِہِ : قَدْ أَعْتَقْتُکِ وَتَزَوَّجْتُکِ ، قَالَ : ہِیَ حُرَّۃٌ إِنْ شَائَتْ تَزَوَّجْتہ ، وَإِنْ شَائَتْ لَمْ تَزَوَّجْہُ۔",,,16409 16410,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسِ بْنِ مَالِکٍ ، وَسَعِیدِ بْنِ الْمُسَیَّبِ أَنَّہُمَا قَالاَ : إذَا أَعْتَقَہَا لِلَّہِ تَعَالَی فَلاَ یَعُودُ فِیہَا ، وَلاَ یَرَیَانِ بَأْسًا أَنْ یَعْتِقَہَا لِیَتَزَوَّجَہَا۔",,,16410 16411,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ شُعْبَۃَ ، عَنْ سَعِیدٍ ، عَنِ النَّخَعِیِّ ، أَنَّہُ کَرِہَ إذَا أَعْتَقَہَا لِلَّہِ۔,,,16411 16412,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ کَرِہَ أَنْ یَعْتِقَہَا ثُمَّ یَتَزَوَّجَہَا۔,,,16412 16413,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ أَنَّہُ کَرِہَ أَنْ یَعْتِقَہَا لِوَجْہِ اللہِ تَعَالَی ثُمَّ یَتَزَوَّجَہَا۔,,,16413 16414,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ أَنَّ بُشَیْرَ بْنَ کَعْبٍ قَرَأَ ہَذِہِ الآیَۃَ : {فَامْشُوا فِی مَنَاکِبِہَا} ، فَقَالَ لِجَارِیَتِہِ: إِنْ دَرَیْت مَا مَنَاکِبُہَا فَأَنْتِ حُرَّۃٌ لِوَجْہِ اللہِ، قَالَتْ: فَإِنَّ مَنَاکِبَہَا جِبَالُہَا ، فَکأَنَّمَا سُفِعَ وَجْہَہُ، وَرَغِبَ فِی جَارِیَتِہِ فَجَعَلَ یَسْأَلُ ، عَنْ ذَلِکَ فَمِنْہُمْ مَنْ یَأْمُرُہُ وَمِنْہُمْ مَنْ یَنْہَاہُ حَتَّی لَقِیَ أَبَا الدَّرْدَائِ فَذَکَرَ ذَلِکَ لَہُ ، فَقَالَ : دَعْ مَا یَرِیبُک إلَی مَا لاَ یَرِیبُک فَإِنَّ الْخَیْرَ فِی طُمَأْنِینَۃٍ وَإِنَّ الشَّرَّ فِی رِیبَۃٍ ، فترَکَ ذَلِکَ۔",,,16414 16415,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ أَنَّ الْحَسَنَ ، وَعَطَائً کَانَا لاَ یَرَیَانِ بِذَلِکَ بَأْسًا ، وَإِنْ أَعْتَقَہَا لِلَّہِ وَیَقُولاَنِ : ہُوَ أَعْظَمُ لِلأَجْرِ۔",,,16415 16416,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ أَنَّہُ کَانَ إذَا سُئِلَ عَنِ الرَّجُلِ یَعْتِقُ جَارِیَتَہُ وَیَتَزَوَّجُہَا أنہ کَانَ لاَ یَرَی بِذَلِکَ بَأْسًا ، وَإِنْ أَعْتَقَہَا لِلَّہِ۔,,,16416 16417,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنِ الصَّلْتِ بْنِ بَہْرَامَ ، عَنْ شَقِیقٍ قَالَ : تَزَوَّجَ حُذَیْفَۃُ یَہُودِیَّۃً فَکَتَبَ إلَیْہِ عُمَرُ أَنْ خَلِّ سَبِیلَہَا ، فَکَتَبَ إلَیْہِ : إِنْ کَانَتْ حَرَامًا خَلَّیْت سَبِیلَہَا ، فَکَتَبَ إلَیْہِ : إنِّی لاَ أَزْعُمُ أَنَّہَا حَرَامٌ وَلَکِنِّی أَخَافُ أَنْ تَعَاطَوا الْمُومِسَاتِ مِنْہُنَّ۔",,,16417 16418,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ عَبْدِ الْمَلِکِ قَالَ : سَأَلْتُ عَطَائً ، عَنْ نِکَاحِ الْیَہُودِیَّاتِ وَالنَّصْرَانِیَّات فَکَرِہَہُ وَقَالَ : کَانَ ذَلِکَ وَالْمُسْلِمَاتُ قَلِیلٌ۔",,,16418 16419,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ أَنَّہُ کَانَ یَکْرَہُ نِکَاحَ نِسَائِ أَہْلِ الْکِتَابِ ، وَلاَ یَرَی بِطَعَامِہِنَّ بَأْسًا۔,,,16419 16420,"حَدَّثَنَا وَکِیعُ بْنُ الْجَرَّاحِ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنْ مَیْمُونِ بْنِ مِہْرَانَ ، عَنِ ابْنِ عُمَرَ أَنَّہُ کَرِہَ نِکَاحَ نِسَائِ أَہْلِ الْکِتَابِ وَقَرَأَ : {وَلاَ تَنْکِحُوا الْمُشْرِکَاتِ حَتَّی یُؤْمِنَّ}۔",,,16420 16421,"حدَّثَنَا وَکِیعُ بْنُ الْجَرَّاحِ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ ہُبَیْرَۃَ ، عَنْ عَلِیٍّ قَالَ : تَزَوَّجَ رَجُلٌ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَہُودِیَّۃً۔",,,16421 16422,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ ہُبَیْرَۃَ أَنَّ طَلْحَۃَ تَزَوَّجَ نَصْرَانِیَّۃً۔,,,16422 16423,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ، عَنْ أَشْعَثَ، عَنْ أَبِی الزُّبَیْرِ، عَنْ جَابِرٍ قَالَ: شَہِدْنَا الْقَادِسِیَّۃَ مَعَ سَعْدٍ وَنَحْنُ یَوْمَئِذٍ لاَ نَجِدُ سَبِیلاً إلَی الْمُسْلِمَاتِ فَتَزَوَّجْنَا الْیَہُودِیَّاتِ وَالنَّصْرَانِیَّات فَمِنَّا مَنْ طَلَّقَ وَمِنَّا مَنْ أَمْسَکَ۔",,,16423 16424,حَدَّثَنَا عبد اللہ بْنُ إدْرِیسَ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ جَارٍ لِحُذَیْفَۃَ ، عَنْ حُذَیْفَۃَ أَنَّہُ نَکَحَ یَہُودِیَّۃً وَعِنْدَہُ عَرَبِیَّتَانِ۔,,,16424 16425,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَمَّادٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ قَالَ : لاَ بَأْسَ بِنِکَاحِ النَّصْرَانِیَّۃِ۔",,,16425 16426,حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُطَرِّفٍ ، عَنِ الشَّعْبِیِّ ، أَنَّہُ کَانَ لاَ یَرَی بَأْسًا بِالنِّکَاحِ فِی أَہْلِ الْکِتَابِ۔,,,16426 16427,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنْ أَبِی عِیَاضٍ قَالَ : لاَ بَأْسَ بِنِکَاحِ الْیَہُودِیَّاتِ وَالنَّصْرَانِیَّات إلاَّ أَہْلَ الْحَرْبِ۔",,,16427 16428,"حدَّثَنَا عَبدَۃ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ ابْنِ الْمُسَیَّبِ ، وَالْحَسَنِ قَالاَ : لاَ بَأْسَ أَنْ یَتَزَوَّجَ الرَّجُلُ أَرْبَعًا مِنْ أَہْلِ الْکِتَابِ۔",,,16428 16429,"حدَّثَنَا وَکِیعٌ ، عَنْ أَبِی الرَّبِیعِ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ قَالَ : لاَ بَأْسَ أَنْ یَجْمَعَ الرَّجُلُ أَرْبَعًا مِنْ أَہْلِ الْکِتَابِ۔",,,16429 16430,"حَدَّثَنَا رَوْحُ بْنُ عُبَادَۃَ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزہری قَالَ : یَتَزَوَّجُ الْحُرُّ أرْبَعَ إمَائٍ وَأَرْبَعَ نَصْرَانِیَّاتٍ وَالْعَبْدُ کَذَلِکَ۔",,,16430 16431,"حَدَّثَنَا عَبَّادُ بْنُ عَوَّامٍ ، عَنْ سُفْیَانَ بْنِ حُسَیْنٍ ، عَنِ الْحَکَمِ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ یَحِلُّ نِکَاحُ نِسَائِ أَہْلِ الْکِتَابِ إذَا کَانُوا حَرْبًا ، قَالَ الْحَکَمُ : فَحَدَّثْت بِہِ إبْرَاہِیمَ فَأَعْجَبَہُ ذَلِکَ۔",,,16431 16432,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بن مُحَمَّد الْمُحَارِبِیُّ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنْ أَبِی عِیَاضٍ قَالَ : نِسَائُ أَہْلُ الْکِتَابِ لَنَا حَلاَلٌ إلاَّ أَہْلَ الْحَرْبِ فَإِنَّ نِسَائَہُمْ وَذَبَائِحَہُمْ عَلَیْکُمْ حَرَامٌ۔",,,16432 16433,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنِ ابْنِ أَبِی غَنِیَۃَ ، عَنِ الْحَکَمِ قَالَ : إنَّ مِنْ أَہْلِ الْکِتَابِ مَنْ لاَ یَحِلُّ لَنَا مُنَاکَحَتُہُ وَلاَ ذَبِیحَتُہُ ، أَہْلُ الْحَرْبِ۔",,,16433 16434,"حَدَّثَنَا مُحَمَّدُ بْنُ بُکر ، عَنِ ابْنِ جُرَیْجٍ قَالَ : أَخْبَرَنِی أَبُو بَکْرٍ بْنُ عَبْدِ اللہِ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو الْعتوَارِیِّ ، وَیَحْیَی بْنِ عَبْدِ الرَّحْمَنِ بْنِ حَاطِبٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عَبْدِ اللہِ بْنِ عُتْبَۃَ وَعَنْ عَمْرِو بْنِ سُلَیْمٍ الزُّرَقِیِّ ، عَنِ ابْنِ الْمُسَیَّبِ وَعَنْ أَبِی النَّضْرِ ، عَنْ عُرْوَۃَ بْنِ الزُّبَیْرِ أَنَّہُمْ قَالُوا فِی الْمَرْأَۃِ مِنْ أَہْلِ الْکِتَابِ ، إذَا دَخَلَتْ مِنْ أَرْضِ الْحَرْبِ تَدْخُلُ أَرْضَ الْعَرَبِ بِأَمَانٍ ، إِنْ أَظْہَرَتِ السُّکُونَ فِی أَرْضِ الْعَرَبِ فَلاَ بَأْسَ أَنْ یَنْکِحَہَا الْمُسْلِمُ ، وَإِنْ لَمْ تُظْہِرْ ذَلِکَ إلاَّ عِنْدَ الْخِطْبَۃِ لَمْ تُنْکَحْ۔",,,16434 16435,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ أَبِی مَیْسَرَۃَ قَالَ : إمَائُ أَہْلِ الْکِتَابِ بِمَنْزِلَۃِ حَرَائِرِہِمْ۔",,,16435 16436,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ أَنَّہُ قَالَ : إنَّمَا رُخِّصَ لِہَذِہِ الأَمَۃِ فِی نِسَائِ أَہْلِ الْکِتَابِ وَلَمْ یُرَخَّصْ فِی الإِمَائِ۔",,,16436 16437,حَدَّثَنَا عُثْمَانُ ، عَنْ ثَوْرٍ ، عَنْ مَکْحُولٍ أَنَّہُ کَرِہَ نِکَاحَ أَہْلِ الْکِتَابِ۔,,,16437 16438,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ : {مِنْ فَتَیَاتِکُمَ الْمُؤْمِنَاتِ} ، قَالَ : لاَ یَنْبَغِی لِلْحُرِّ الْمُسْلِمِ أَنْ یَنْکِحَ أَمَۃً مِنْ أَہْلِ الْکِتَابِ۔",,,16438 16439,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ عَن مسور أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ کَتَبَ : إذَا دَخَلَ الرَّجُلُ بِالْمَرْأَۃِ فَقَدْ وَجَبَ الْعَاجِلُ وَالآجِلُ إلاَّ أَنْ تَشْتَرِطَ فِی الآجِلِ۔",,,16439 16440,"حَدَّثَنَا شَرِیکٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ فِی الرَّجُلِ یَتَزّوَّجُ الْمَرْأَۃَ إلَی مَیْسَرَۃٍ ، قَالَ : کَانَ یَقُولُ : إلَی مَوْتٍ ، أَوْ فِرَاقٍ۔",,,16440 16441,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ أَنَّہُ کَانَ یَقُولُ فِی الآجِلِ مِنَ الْمَہْرِ : ہُوَ حَالٌّ إلاَّ أَنْ تَکُونَ لَہُ مُدَّۃٌ مَعْلُومَۃٌ",,,16441 16442,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ ، عَنْ شُرَیْحٍ قَالَ : تَزَوَّجَ رَجُلٌ امْرَأَۃً بِآجِلٍ وَعَاجِلٍ إلَی مَیْسَرَۃَ فَقَدَّمَتْہُ إلَی شُرَیْحٍ ، فَقَالَ ، دُلّیْنَا عَلَی مَیْسَرَۃٍ نَأْخُذُہُ لَکِ۔",,,16442 16443,"حَدَّثَنَا أَزْہَرُ السَّمَّانُ، عَنِ ابْنِ عَوْنٍ، عَنْ إیَاسِ بْنِ مُعَاوِیَۃَ قَالَ: إذَا دَخَلَ بِہَا فَلاَ دَعْوَی لَہَا فِی الآجِلِ۔",,,16443 16444,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ قَالَ : الْعَاجِلُ آجِلٌ إلَی مَوْتٍ ، أَوْ فُرْقَۃٍ۔",,,16444 16445,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، قَالَ : سَمِعْتُ حَمَّادًا یَقُولُ : ہُوَ حَالٌّ تَأْخُذْہُ إذَا شِئْتِ۔",,,16445 16446,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ وَالزُّہْرِیِّ قَالاَ : فِی رَجُلٍ تَزَوَّجَ امْرَأَۃً فَدَخَلَ بِہَا فَرَأَی بِہَا جُنُونًا ، أَوْ جُذَامًا ، أَوْ بَرَصًا ، أَوْ عَفَلاً إنَّہَا تُرَدُّ مِنْ ہَذَا وَلَہَا الصَّدَاقُ الَّذِی اسْتَحَلَّ بِہِ فَرْجَہَا الْعَاجِلُ وَالآجِلُ وَصَدَاقُہُ عَلَی مَنْ غَرَّہُ۔",,,16446 16447,"حَدَّثَنَا عَبدَۃ بن سلیمان ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ، عَنْ عَلِیٍّ أَنَّہُ کَانَ یَکْرَہُ ذَبَائِحَ نَصَارَی بَنِی تَغْلِبَ وَنِسَائَہُمْ وَیَقُولُ : ہُمْ مِنَ الْعَرَبِ۔",,,16447 16448,"حَدَّثَنَا عَبدَۃ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ أَنَّہُ کَانَ لاَ یَرَی بِذَلِکَ بَأْسًا وَیَقُولُ : انْتَحَلُوا دِینًا فَذَلِکَ دِینُہُمْ۔",,,16448 16449,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَبِیبٍ ، عَنْ عَمْرِو بْنِ ہَرِمٍ قَالَ : سُئِلَ جَابِرُ بْنُ زَیْدٍ ، عَنْ نَصَارَی الْعَرَبِ ہَلْ تَحِلُّ نِسَاؤُہُمْ لِلْمُسْلِمِینَ قَالَ : لَیْسُوا مِنْ أَہْلِ الْکِتَابِ وَلاَ تَحِلُّ نِسَاؤُہُمْ وَلاَ طَعَامُہُمْ لِلْمُسْلِمِینَ۔",,,16449 16450,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ عِمْرَانَ بْنِ حُدَیر ، قَالَ : قَالَ عِکْرِمَۃُ : {وَمَنْ یَتَوَلَّہُمْ مِنْکُمْ فَإِنَّہُ مِنْہُمْ} قَالَ : نصاری الْعَرَب فِی ذَبَائِحِہِمْ وَفِی نِسَائِہِمْ۔",,,16450 16451,"حَدَّثَنَا عَفَّانَ قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عبَّاسٍ قَالَ : کُلُوا ذَبَائِحَ بَنِی ثَعْلَبَۃَ وَتَزَوَّجُوا نِسَائَہُمْ فَإِنَّ اللَّہَ تَعَالَی یَقُولُ : {یَا أَیُّہَا الَّذِینَ آمَنُوا لاَ تَتَّخِذُوا الْیَہُودَ وَالنَّصَارَی أَوْلِیَائَ بَعْضُہُمْ أَوْلِیَائُ بَعْضٍ} فَلَوْ لَمْ یَکُونُوا مِنْہُمْ إلاَّ بِالْوِلاَیَۃِ لَکَانُوا مِنْہُمْ۔",,,16451 16452,حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مِعْشَرٍ ، عَنْ إبْرَاہِیمَ ، عَنْ عَلِیٍّ أَنَّہُ کَرِہَ ذَبَائِحَ نَصَارَی الْعَرَبِ وَنِسَائَہُمْ۔,,,16452 16453,حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مِعْشَرٍ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ کَرِہَ۔,,,16453 16454,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ قَالَ : لاَ بَأْسَ بِہِ۔",,,16454 16455,حَدَّثَنَا جَرِیرٌ، عَنْ عَبْدِ الحمید ، عَنْ مُغِیرَۃَ ، عَنْ سِمَاکِ بْنِ سَلَمَۃَ أَنَّ شُرَیْحًا أَجَازَ نِکَاحَ وَصِیِّ وَصِیٍّ۔,,,16455 16456,"حَدَّثَنَا جَرِیرٌ، عَنْ مُغِیرَۃَ، عَنِ الْحَارِثِ قَالَ: یُشَاوِر الْوَلِیُّ الْوَصِیَّ فِی النِّکَاحِ وَیلِیَ عُقْدَۃُ النِّکَاحِ الْوَلِیُّ۔",,,16456 16457,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ حَمَّادٍ فِی وَصِیٍّ زَوَّجَ یَتِیمَۃً صَغِیرَۃً فِی حِجْرِہِ قَالَ : جَائِزٌ۔",,,16457 16458,"حَدَّثَنَا غُنْدَرٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ فِی الْوَصِیِّ یُزَوِّجُ قَالَ : ہُوَ جَائِزٌ۔",,,16458 16459,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حَارِثٍ ، عَنِ الشَّعْبِیِّ وَعَنِ الْحَکَمِ وَحَمَّادٍ ، عَنْ إبْرَاہِیمَ قَالاَ : مَا صَنَعَ الْوَصِیُّ فَہُوَ جَائِزٌ إلاَّ النِّکَاحَ۔",,,16459 16460,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ أَنَّہُ کَانَ لاَ یَجْعَلُ لِلْوَصِیِّ من أَمْرِ النِّکَاحِ شَیْئًا إلاَّ أَنْ یَکُونَ قَالَ : أَنْتَ وَصِیِّی فِی نِکَاحِ أخواتی وبناتی فَإِنْ فَعَلَ فَالْوَصِیُّ أَحَقُّ مِنَ الْوَلِیِّ وَإِلاَّ فَالْوَلِیُّ أَحَقُّ مِنَ الْوَصِیِّ۔",,,16460 16461,"حدَّثَنَا وَکِیعٌ، عَنْ إسْمَاعِیلَ، عَنِ الشَّعْبِیِّ فِی امْرْأَۃٍ تَزَوَّجَتْ رَجُلاً عَلَی أَنَّہُ حُرٌّ فَوُجِدَ عَبْدًا قَالَ: تُخَیَّرُ۔",,,16461 16462,"حَدَّثَنَا غُنْدَرٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ أَنَّہُ سُئِلَ عَنْ رَجُلٍ دَلَّسَ نَفْسَہُ لأَمْرَأَۃٍ فَزَعَمَ أَنَّہُ حُرٌّ وَہوَ عَبْدٌ قَالَ : تُخَیَّرُ۔",,,16462 16463,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ فِی امْرَأَۃٍ غُرَّتْ بِعَبْدٍ وَکَانَتْ تَحْسَبُہُ حُرًّا قَالَ ابْنُ شِہَابٍ : تُخَیَّرُ۔",,,16463 16464,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَبِیبٍ ، عَنْ عَمْرٍو قَالَ : سُئِلَ جَابِرُ بْنُ زَیْدٍ ، عَنْ عَبْدٍ أَتَی قَوْمًا فَأَخْبَرَہُمْ أَنَّہُ حُرٌّ فَأَنْکَحُوہُ امْرَأَۃً حُرَّۃً ثُمَّ عَلِمُوا بَعْدَ ذَلِکَ أَنَّہُ عَبْدٌ غُرَّتْ بِہِ قَالَ : إذَا عَلِمَتْ بِہِ فَإِنْ شَائَتْ مَکَثَتْ بِہِ، وَإِنْ شَائَتْ فَارَقَتْہُ وَلاَ حَقَّ لَہُ عَلَیْہَا۔",,,16464 16465,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنِ الشَّعْبِیِّ قَالَ : أَیُّمَا عَبْدٍ جَائَ إلَی حُرَّۃٍ فَزَوَّجَتْہُ فَعَلِمَتْ بَعْدَ ذَلِکَ أَنَّہُ مَمْلُوکٌ فَإِنْ شَائَتِ اسْتَقَرَّتْ عِنْدَہُ ، وَإِنْ شَائَتْ فَارَقَتْہُ۔",,,16465 16466,"حَدَّثَنَا وَکِیعُ بْنُ الجَرَّاحِ عن سفیان ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ قَالَ : إذَا تَزَوَّجَ الابْنُ لَمْ تَحِلَّ لِلأَبِ دَخَلَ بِہَا ، أَوْ لَمْ یَدْخُلْ بہا وَإِذَا تزوج الأَبُ لَمْ تَحِلَّ لِلابْنِ دَخَلَ بِہَا ، أَوْ لَمْ یَدْخُلْ بِہَا۔",,,16466 16467,"حَدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَنْ بُرْدٍ ، عَنِ الزُّہْرِیِّ قَالَ : مَنْ مَلَکَ عُقْدَۃَ امْرَأَۃٍ فَقَدْ حُرِّمَتْ عَلَی ابْنِہِ وعلی أَبِیہِ وَأَیُّہُمَا جَرَّدَ فَنَظَرَ إلَی الْعَوْرَۃِ کَذَلِکَ۔",,,16467 16468,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ عن أبی بکر ، عَنْ مَکْحُولٍ قَالَ : أَیُّہُمَا مَلَکَ عُقْدَۃَ امْرَأَۃٍ حُرِّمَتْ عَلَی الآخَرِ۔",,,16468 16469,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ أَبِی حُرَّۃَ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ تَزَوَّجَ امْرَأَۃً فَطَلَّقَہَا قَبْلَ أَنْ یَدْخُلَ بِہَا أَیَتَزَوَّجُہَا أَبُوہُ فَکَرِہَ وَقَالَ اللَّہُ تَعَالَی : {وَحَلاَئِلُ أَبْنَائِکُمْ}۔",,,16469 16470,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ وَمُحَمَّدٍ قَالاَ : ثَلاَثُ آیَاتٍ مُبْہَمَاتٌ : {وَحَلاَئِلُ أَبْنَائِکُمْ} وَ{مَا نَکَحَ آبَاؤُکُمْ} وَ{وَأُمَّہَاتُ نِسَائِکُمْ} قَالَ : أَشْعَثُ : وَہَذِہِ الرَّابِعَۃُ لَیْسَتْ بِمُبْہَمَۃٍ {وَرَبَائِبُکُمَ اللاَّتِی فِی حُجُورِکُمْ مِنْ نِسَائِکُمْ} فَقَرَأَہَا مُعَاذٌ إلَی آخِرِہَا۔",,,16470 16471,"حَدَّثَنَا ابْنُ فُضَیْلٍ، عَنْ عُبَیْدَۃَ، عَنْ إبْرَاہِیمَ قَالَ: إذَا تَزَوَّجَ الرَّجُلُ الْمَرْأَۃَ فَلَمْ یَدْخُلْ بِہَا لَمْ تَحِلَّ لأَبِیہِ۔",,,16471 16472,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، عَنْ مَکْحُولٍ أَنَّ عُمَرَ جَرَّدَ جَارِیَتَہُ فَسَأَلَہُ إیَّاہَا بَعْضُ بَنِیہِ ، فَقَالَ : إنَّہَا لاَ تَحِلُّ لَک۔",,,16472 16473,"حَدَّثَنَا عَبْدُ اللہِ بْنُ مُبَارَکٍ ، عَنْ حَجَّاجٍ ، عَنْ مَکْحُولٍ أَنَّ عُمَرَ جَرَّدَ جَارِیَۃً لَہُ فَطَلَبَہَا إلَیْہِ بَعْضُ بَنِیہِ ، فَقَالَ : إنَّہَا لاَ تَحِلُّ لَک۔",,,16473 16474,حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ أَنَّہُ جَرَّدَ جَارِیَۃً لَہُ ثُمَّ سَأَلَہُ إیَّاہَا بَعْضُ وَلَدِہِ ، فَقَالَ إنَّہَا لاَ تَحِلُّ لَک۔,,,16474 16475,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، سُلَیْمَانَ بْنِ حَیَّانَ ، عَنِ یَحْیَی بْنِ سَعِیدٍ ، عَنِ الْقَاسِمِ بْنِ مُحَمَّدٍ ، عَنْ عَبْدِ اللہِ بْنِ عَامِرٍ أَنَّ أَبَاہُ حِینَ حَضَرَتْہُ الْوَفَاۃُ نَہَی بَنِیہِ ، عَنْ جَارِیَۃٍ لَہُ أَنْ یَطَأَہَا أَحَدٌ مِنْہُمْ قَالَ : وَمَا نَعْلَمُہُ وَطِئَہَا إلاَّ أَنْ یَکُونَ اطَّلَعَ مِنْہَا عَلَی أَمْرٍ کَرِہَ أَنْ یَطَّلِعَ وَلَدُہُ مُطَّلَعَہُ۔",,,16475 16476,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ حَجَّاجٍ ، عَنْ مَکْحُولٍ أَنَّ عُمَرَ جَرَّدَ جَارِیَۃً لَہُ وَنَظَرَ إلَیْہَا فَسَأَلَہُ إیَّاہَا بَعْضُ وَلَدِہِ ، فَقَالَ : إنَّہَا لاَ تَحِلُّ لَک۔",,,16476 16477,حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ بِمِثْلِ ہَذَا۔,,,16477 16478,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، قَالَ : قَالَ مَسْرُوقٌ حِینَ حَضَرَتْہُ الْوَفَاۃُ : إنِّی لَمْ أُصِبْ مِنْ جَارِیَتِی ہَذِہِ إلاَّ مَا یُحَرِّمُہَا عَلَی وَلَدِی الْمَسَّ وَالنَّظَرَ۔",,,16478 16479,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ قَالَ مُجَاہِدٌ : إذَا مَسَّ الرَّجُلُ فَرْجَ الأَمَۃِ ، أَوْ مَسَّ فَرْجُہُ فَرْجَہَا ، أَوْ بَاشَرَہَا فَإِنَّ ذَلِکَ یُحَرِّمُہَا عَلَی أَبِیہِ وَعَلَی ابْنِہِ۔",,,16479 16480,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ أَنَّہُ سَأَلَ عَنْ رَجُلٍ جَرَّدَ جَارِیَتَہُ ہَلْ تَحِلُّ لابْنِہِ ، أَوْ لأَبِیہِ أَنَّہُ کَانَ یَکْرَہُ ذَلِکَ إذَا قَبَّلَہَا ، أَوْ جَرَّدَہَا لِشَہْوَۃٍ۔,,,16480 16481,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ مُثَنًّی ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ سَالِمٍ ، عَنِ ابْنِ عُمَرَ قَالَ : أَیُّمَا رَجُلٍ جَرَّدَ جَارِیَۃً فَنَظَرَ مِنْہَا إلَی ذَلِکَ الأَمْرِ فَإِنَّہَا لاَ تَحِلُّ لابْنِہِ۔",,,16481 16482,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ سَأَلَ عَنْہُ الشَّعْبِیَّ ، فَقَالَ : قدْ زَعَمُوا أَنَّ رَجُلاً اشْتَرَی جَارِیَۃً فَخَشِیَتِ امْرَأَتُہُ أَنْ یَتَّخِذَہَا فَأَمَرَتِ ابْنًا لَہَا غُلاَمًا أَنْ یَضْطَجِعَ عَلَیْہَا لِیُحَرِّمَہَا عَلَی زَوْجِہَا۔",,,16482 16483,حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ کَرِہَ أَنْ یَطَأَ الرَّجُلُ امْرَأَۃً قَبَّلَہَا أَبُوہُ ، أَوْ نَظَرَ إلَی مَحَاسِرِہَا۔,,,16483 16484,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ أَبِی بَکْرٍ ، عَنْ مَکْحُولٍ قَالَ : أَیُّمَا رَجُلٍ جَرَّدَ جَارِیَۃً حُرِّمَتْ عَلَی ابْنِہِ وَعَلَی أَبِیہِ۔",,,16484 16485,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَبِیبٍ ، عَنْ عَمْرِو بْنِ ہَرِمٍ قَالَ : سُئِلَ جَابِرُ بْنُ زَیْدٍ ، عَنْ جَارِیَۃٍ کَانَتْ لِرَجُلٍ فَمَسَّ قُبُلَہَا بِیَدِہِ ، أَوْ أَبْصَرَ عَوْرَتَہَا ثُمَّ وَہَبَہَا لاِبْنٍ لَہُ أَیُصْلِحُّ لہ أَنْ یَتَّطِئَہَا قَالَ : لاَ۔",,,16485 16486,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الْحَسَنِ بْنِ عَمْرٍو ، عَنِ الشَّعْبِیِّ قَالَ : کَتَبَ مَسْرُوقٌ إلَی أَہْلِہِ : اُنْظُرُوا جَارِیَتِی فَلاَ تَبِیعُوہَا فَإِنِّی لَمْ أُصِبْ مِنْہَا إلاَّ مَا یُحَرِّمُہَا عَلَی وَلَدِی اللَّمْسَ وَالنَّظَرَ۔",,,16486 16487,"حدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، عَنْ عِمْرَانَ بْنِ الْحُصَیْنِ فِی الرَّجُلِ یَقَعُ عَلَی أُمِّ امْرَأَتِہِ قَالَ : تَحْرُمُ عَلَیْہِ امْرَأَتُہُ۔",,,16487 16488,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ یَحْیَی بْنِ یَعْمَُرَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : حرْمَتَانِ أَنْ تَخْطّاہُمَا وَلاَ یُحَرِّمْہَا ذَلِکَ عَلَیْہِ۔",,,16488 16489,"حَدَّثَنَا حَفْص بن غِیَاثٍ ، عَنْ لَیْثٍ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، عَنْ عَلْقَمَۃَ ، عَنْ عَبْدِ اللہِ قَالَ : لاَ یَنْظُرُ اللَّہُ إلَی رَجُلٍ نَظَرَ إلَی فَرْجِ امْرَأَۃٍ وَابْنَتَہَا۔ (دارقطنی 92)",,,16489 16490,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی ہَانِیئٍ قَالَ قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ نَظَرَ إلَی فَرْجِ امْرَأَۃٍ لَمْ تَحِلَّ لَہُ أُمُّہَا وَلاَ ابْنَتُہَا۔ (بیہقی 170)",,,16490 16491,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ وَعَامِرٍ فِی رَجُلٍ وَقَعَ عَلَی ابْنَۃِ امْرَأَتِہِ قَالاَ : حرِّمَتَا عَلَیْہِ کِلاَہُمَا، وَقَالَ إبْرَاہِیمُ ، وَکَانُوا یَقُولُونَ إذَا اطَّلَعَ الرَّجُلُ عَلَی الْمَرْأَۃِ عَلَی مَا لاَ یَحِلُّ لَہُ ، أَوْ لَمَسَہَا لِشَہْوَۃٍ فَقَدْ حُرِّمَتَا عَلَیْہِ جَمِیعًا۔",,,16491 16492,"حَدَّثَنَا شَرِیکٌ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ عَطَائٍ قَالَ : إذَا أَتَی الرَّجُلُ الْمَرْأَۃَ حَرَامًا حُرِّمَتْ عَلَیْہِ ابْنَتُہَا ، وَإِنْ أَتَی ابْنَتَہَا حُرِّمَتْ عَلَیْہِ أُمُّہَا۔",,,16492 16493,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ اللہِ بْنِ مسبحٍ قَالَ : سَأَلْتُ إبْرَاہِیمَ ، عَنْ رَجُلٍ فَجَرَ بِأَمَۃٍ ثم أَرَادَ أَنْ یَتَزَوَّجَ أُمَّہَا قَالَ : لاَ یَتَزَوَّجُہَا۔",,,16493 16494,"حَدَّثَنَا عُبَیْدُ اللہِ ، عَنْ شُعْبَۃَ قَالَ : سَأَلْتُ الْحَکَمَ وَحَمَّادًا ، عَنْ رَجُلٍ زَنَی بِأُمِّ امْرَأَتِہِ ، قَالاَ : أَحَبُّ إِلَیْنَا أَنْ یُفَارِقَہَا۔",,,16494 16495,"حَدَّثَنَا حَفْص بن غِیَاثٍ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ قَالَ : إذَا غَمَزَ الرَّجُلُ الْجَارِیَۃَ بِشَہْوَۃٍ لَمْ یَتَزَوَّجْ أُمَّہَا وَلاَ ابْنَتَہَا۔",,,16495 16496,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنْ مُجَاہِدٍ ، وَعَطَائٍ قَالاَ : إذَا فَجَرَ الرَّجُلُ بِالْمَرْأَۃِ فَإِنَّہَا تَحِلُّ لَہُ وَلاَ یَحِلُّ لَہُ شَیْئٌ مِنْ بَنَاتِہَا۔",,,16496 16497,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنْ قَتَادَۃَ قَالَ : کَانَ جَابِرُ بْنُ زَیْدٍ وَالْحَسَنُ یَکْرَہَانِ أَنْ یَمَسَّ الرَّجُلُ امْرَأَتَہُ یَعْنِی فِی الرَّجُلِ یَقَعُ عَلَی أُمِّ امْرَأَتِہِ۔",,,16497 16498,"حَدَّثَنَا إِسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ یَزِیدَ الرِّشْکِ قَالَ : سَأَلْتُ سَعِیدَ بْنَ الْمُسَیَّبِ ، عَنْ رَجُلٍ یَفْجُرُ بِأُمِّ امْرَأَتِہِ ، فَقَالَ : أَمَّا الأُمُّ فَحَرَامٌ ، وَأَمَّا الْبِنْتُ فَحَلاَلٌ۔",,,16498 16499,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عُبَیْدِ اللہِ ، عَنْ أَبِیہِ قَالَ : سُئِلَ عُمَرُ ، عَنْ جَمْعِ الأُمِّ وَابْنَتِہَا مِنْ مِلْکِ الْیَمِینِ ، فَقَالَ : لاَ أُحِبُّ أَنْ یخبرہما جَمِیعًا۔",,,16499 16500,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ طَارِقٍ ، عَنْ قَیْسٍ بن أبی حازم قَالَ : قُلْتُ لاِبْنِ عَبَّاسٍ الرَّجُلُ یَقَعُ عَلَی الْجَارِیَۃِ وَابْنَتِہَا تَکُونَانِ عِنْدَہُ مَمْلُوکَتَیْنِ ، فَقَالَ : حَرَّمَتْہُمَا آیَۃٌ وَأَحَلَّتْہُمَا آیَۃٌ أُخْرَی وَلَمْ أَکُنْ لأَفْعَلَہُ۔",,,16500 16501,"حَدَّثَنَا عَبْدُ الأَعْلَی بْنُ عَبْدِ الأَعْلَی ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ أَبِی الزِّنَادِ ، عَنْ عَبْدِ اللہِ بْنِ نِیَار الأَسْلَمِیِّ قَالَ : کَانَتْ عِنْدِی جَارِیَۃٌ کُنْت أتَّطِئُہَا وَکَانَتْ مَعَہَا ابْنَۃٌ لَہَا فَأَدْرَکَتِ ابْنَتُہَا فَأَرَدْت أَنْ أمسک عَنْہَا وأتطی ابْنَتَہَا فَقَلتُ : لاَ أَفْعَلُ ذَلِکَ حَتَّی أَسْأَلَ عُثْمَانَ بْنَ عَفَّانَ ، فَسَأَلَتْہُ عَنْ ذَلِکَ ، فَقَالَ : أَمَّا أَنَا فَلَمْ أَکُنْ لنطلع مِنْہُما مُطَّلَعًا وَاحِدًا۔",,,16501 16502,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ أَنَّ مُعَاذَ بْنَ عُبَیْدِ اللہِ بْنِ مَعْمَرٍ سَأَلَ عَائِشَۃَ ، فَقَالَ : إنَّ عِنْدِی جَارِیَۃً أَصِیب مِنْہَا وَلَہَا ابْنَۃٌ قَدْ أَدْرَکَتْ فأصیب مِنْہَا ؟ فَنَہَتْہُ ، فَقَالَ : لاَ حَتَّی تَقُولِی ہِیَ حَرَامٌ ، فَقَالَتْ : لاَ یَفْعَلُہُ أَحَدٌ مِنْ أَہْلِی وَلاَ مِمَّنْ أَطَاعَنِی وَسَأَلْت ابْنَ عُمَرَ فَنَہَانِی عَنْہُ۔",,,16502 16503,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُجَالِدٍ ، عَنْ عَامِرٍ قَالَ : کَانَتْ لِرَجُلٍ مِنْ ہَمْدَانَ وَلِیدَۃٌ وَابْنَتُہَا ، فَکَانَ یَقَعُ عَلَیْہِمَا فَأُخْبِرَ بِذَلِکَ عَلِیٌّ فَسَأَلَہُ ، فَقَالَ : نَعَمْ ، فَقَالَ لَہُ عَلِیٌّ : إذَا أَحَلَّتْ لک آیَۃٌ وَحَرَّمَتْ عَلَیْک أُخْرَی فَإِنَّ أَمْلَکَہُمَا آیَۃُ الْحَرَامِ۔",,,16503 16504,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ رُفَیْعٍ ، عَنِ ابْنِ مُنَبِّہٍ قَالَ : فِی التَّوْرَاۃِ الَّتِی أَنْزَلَ اللَّہُ عَلَی مُوسَی إِنَّہُ لاَ یَکْشِفُ رَجُلٌ فَرْجَ امْرَأَۃٍ وَابْنَتِہَا إلاَّ مَلْعُونٌ ، مَا فَصَّلَ لَنَا حُرَّۃً وَلاَ مَمْلُوکَۃً۔",,,16504 16505,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنِ الْجُرَیْرِیِّ ، عَنْ أَبِی نَضْرَۃَ قَالَ : جَاء َ رَجُلٌ إلَی عُمَرَ قَالَ : إنَّ لِی وَلِیدَۃً وَابْنَتَہَا وَإِنَّہُمَا قَدْ أَعْجَبَتانِی أَفَأَطَؤُہُمَا ؟ قَالَ : آیَۃٌ أَحَلَّتْ وَآیَۃٌ حَرَّمَتْ ، أَمَّا أَنَا فَلَمْ أَکُنْ أَقْرَبُ ہَذَا۔",,,16505 16506,"حَدَّثَنَا شَرِیکٌ ، عَنْ سَالِمٍ ، عَنْ سَعِیدٍ قَالَ : لاَ یَجْمَعُ الرَّجُلُ بَیْنَ الْمَرْأَۃِ وَابْنَتِہَا وَلاَ بَیْنَ الْمَرْأَۃِ وَأُخْتِہَا۔",,,16506 16507,"حَدَّثَنَا عَبْدُ اللہِ بْنُ مُبَارَکٍ ، عَنْ مُوسَی بْنِ أَیُّوبَ ، عَنْ عَمِّہِ ، عَنْ عَلِیٍّ قَالَ : سَأَلْتُہ ، عَنْ رَجُلٍ لَہُ أَمَتَانِ أُخْتَانِ وَطِئَ إحْدَاہُمَا ثُمَّ أَرَادَ أَنْ یَطَأَ الأُخْرَی قَالَ : لاَ حَتَّی یُخْرِجَہَا مِنْ مِلْکِہِ ، قَالَ : قُلْتُ : فَإِنَّہ زَوَّجَہَا عَبْدَہُ ؟ قَالَ : لاَ حَتَّی یُخْرِجَہَا من مِلْکِہِ۔",,,16507 16508,"حَدَّثَنَا عَبْدُ اللہِ بْنِ إدْرِیسَ ، وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی عَوْنٍ ، عَنْ أَبِی صَالِحٍ الْحَنَفِیِّ أَنَّ ابْنَ الْکَوَّائِ سَأَلَ عَلِیًّا ، عَنِ الْجَمْعِ بَیْنَ الأُخْتَیْنِ ، فَقَالَ : حرَّمَتْہُمَا آیَۃٌ وَأَحَلَّتْہُمَا أُخْرَی وَلَسْت أَفْعَلُ أَنَا وَلاَ أَہْلِی۔",,,16508 16509,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ قَالَ : أَغْضَبُوا ابْنَ مَسْعُودٍ فِی الأُخْتَیْنِ الْمَمْلُوکَتَیْنِ ، فَغَضِبَ وَقَالَ : جَمَلَ أَحَدُکُمْ مِمَّا مَلَکَتْ یَمِینُہُ۔",,,16509 16510,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ فِی رَجُلٍ تَکُونُ لَہُ الأَمَتَانِ الأُخْتَانِ فَیَطَأُ إحْدَاہُمَا قَالَ : لاَ یَطَأُ الأُخْرَی حَتَّی یُخْرِجَہَا من مِلْکِہِ۔",,,16510 16511,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ مُطَرِّفٍ ، عَنْ أَبِی الْجَہْمِ ، عَنْ أَبِی الأَخْضَرِ ، عَنْ عَمَّارٍ قَالَ : مَا حَرَّمَ اللَّہُ مِنَ الْحَرَائِرِ شَیْئًا إلاَّ وَقَدْ حَرَّمَہُ مِنَ الإِمَائِ إلاَّ أَنَّ الرَّجُلَ قَدْ یَجْمَعُ مَا شَاء َ مِنَ الإِمَائِ۔",,,16511 16512,"حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ ، عَنْ مَالِکِ بْنِ أَنَسَ ، عَنِ الزُّہْرِیِّ ، عَنْ قَبِیصَۃَ بْنِ ذُؤَیْبٍ قَالَ : سُئِلَ عُثْمَانُ بْنُ عَفَّانَ ، عَنِ الأُخْتَیْنِ من مِلْکِ الْیَمِینِ یَجْمَعُ بَیْنَہُمَا ، فَقَالَ : أَحَلَّتْہُمَا آیَۃٌ مِنْ کِتَابِ اللہِ وَحَرَّمَتْہَا آیَۃٌ ، وَأَمَّا أَنَا فَمَا أُحِبُّ أَنْ أَفْعَلَ ذَلِکَ۔",,,16512 16513,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ مَیْمُونٍ ، عَنِ ابْنِ عُمَرَ أَنَّہُ سُئِلَ عَنْ رَجُلٍ لَہُ أَمَتَانِ أُخْتَانِ وَقَعَ عَلَی إحْدَاہُمَا أَیَقَعُ عَلَی الأُخْرَی؟ قَالَ: فَقَالَ ابْنُ عُمَرَ: لاَ یَقَعُ عَلَی الأُخْرَی مَا دَامَتِ الَّتِی وَقَعَ عَلَیْہَا فِی مِلْکِہِ۔",,,16513 16514,"حَدَّثَنَا أَبُو بَکْرٍ بْنُ عَیَّاشٍ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ رُفَیْعٍ قَالَ : سَأَلْتُ ابْنَ الْحَنَفِیَّۃِ ، عَنْ رَجُلٍ عِنْدَہُ أَمَتَانِ أختان أَیَطَؤُہُمَا ؟ فَقَالَ : أَحَلَّتْہُمَا آیَۃٌ وَحَرَّمَتْہُمَا آیَۃٌ ، ثُمَّ أَتَیْتُ ابْنَ الْمُسَیَّبِ ، فَقَالَ مِثْلَ قَوْلِ مُحَمَّدٍ ، ثُمَّ سَأَلْت ابْنَ مُنَبِّہٍ ، فَقَالَ : أَشْہَدُ أَنَّہُ فِیمَا أَنْزَلَ اللَّہُ عَلَی مُوسَی أَنَّہُ مَلْعُونٌ مَنْ جَمَعَ بَیْنَ الأُخْتَیْنِ قَالَ : فَمَا فَصَّلَ لَنَا حُرَّتَیْنِ وَلاَ مَمْلُوکَتَیْنِ قَالَ : فَرَجَعْت إلَی ابْنِ الْمُسَیَّبِ فَأَخْبَرْتہ ، فَقَالَ : اللَّہُ أَکْبَرُ۔",,,16514 16515,حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ مُبَارَکٍ ، عَنِ ابْنِ ثَوْبَانَ ، عَنْ عَائِشَۃَ أَنَّہَا کَرِہَتْہُ۔,,,16515 16516,"حَدَّثَنَا عَبْدُ الأَعْلَی، عَنْ یُونُسَ، عَنِ الْحَسَنِ؛ فِی رَجُلٍ لَہُ أَمَتَانِ أُخْتَانِ فَغَشِیَ إحْدَاہُمَا ثُمَّ أَمْسَکَ عَنْہَا ہَلْ لَہُ أَنْ یَغْشَی الأُخْرَی ، قَالَ : کَانَ یُعْجِبُہُ أَنْ لاَ یَغْشَاہَا حَتَّی یُخْرِجَ عَنْہُ ہَذِہِ الَّتِی غَشِیَ مِنْ مِلْکِہِ۔",,,16516 16517,"حَدَّثَنَا غُنْدَرٌ، عَنْ شُعْبَۃَ، عَنِ الْحَکَمِ وَحَمَّادٍ قَالاَ: إذَا کَانَتْ عِنْدَ الرَّجُلِ أُخْتَانِ فَلاَ یَقْرَبَنَّ وَاحِدَۃً مِنْہُمَا۔",,,16517 16518,"حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، وَابْنِ سِیرِینَ قَالاَ : یَحْرُمُ مِنْ جَمْعِ الإِمَائِ مَا یَحْرُمُ مِنْ جَمْعِ الْحَرَائِرِ إلاَّ الْعَدَدَ۔",,,16518 16519,"حَدَّثَنَا غُنْدَرٌ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ عُبَیْدِ اللہِ بْنِ عَبْدِ اللہِ بْنِ عُتْبَۃَ قَالَ : سَأَلَ رَجُلٌ عُثْمَانَ ، عَنِ الأُخْتَیْنِ یَجْمَعُ بَیْنَہُمَا ، فَقَالَ : أَحَلَّتْہُمَا آیَۃٌ وَحَرَّمَتْہُمَا آیَۃٌ وَلاَ آمُرُک وَلاَ أَنْہَاک فَلَقِیَ عَلِیًّا بِالْبَابِ ، فَقَالَ : عَمَّ سَأَلْتَہُ ؟فَأَخْبَرَہُ ، فَقَالَ : لَکِنِّی أَنْہَاک وَلَوْ کَانَ لِی عَلَیْک سَبِیلٌ ثُمَّ فَعَلْت ذَلِکَ لأَوْجَعْتُک۔",,,16519 16520,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنِ ابْنِ إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ عُمَرَ ، عَنْ قَتَادَۃَ ، عَنِ الْقَاسِمِ بْنِ مُحَمَّدٍ أَنَّ حَیًّا مِنْ أَحْیَائِ الْعَرَبِ سَأَلُوا مُعَاوِیَۃَ ، عَنْ الأُخْتَیْنِ مِمَّا مَلَکَتِ الْیَمِینُ ، یَکُونَانِ عِنْدَ الرَّجُلِ فَیَطَؤُہُمَا قَالَ : لَیْسَ بِذَلِکَ بَأْسٌ ، فَسَمِعَ بِذَلِکَ النُّعْمَانُ بْنُ بَشِیرٍ ، فَقَالَ أَفْتَیْت بِکَذَا وَکَذَا قَالَ : نَعَمْ ، قَالَ : أَرَأَیْت لَوْ کَانَتْ عِنْدَ رَجُلٍ أُخْتُہُ مَمْلُوکَۃً کَانَ یَجُوزُ لَہُ أَنْ یَطَأَہَُا ؟ فَقَالَ : أَمَا وَاللَّہِ إنَّمَا رَدَدْتنِی أَدْرِکْ فَقُلْ لَہُمَ اجْتَنِبُوا ذَلِکَ ، فَإِنَّہُ لاَ یَنْبَغِی لَہُمْ ، قَالَ : قُلْتُ : إنَّمَا ہِیَ الرَّحِمُ مِنَ الْعَتَاقَۃِ وَغَیْرِہَا۔",,,16520 16521,"حدَّثَنَا إِسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ فِی الرَّجُلِ یَتَزَوَّجُ الْمَرْأَۃَ ثُمَّ یُطَلِّقُہَا قَبْلَ أَنْ یَدْخُلَ بِہَا ، أَیَتَزَوَّجُ أُمَّہَا ؟ قَالَ : قَالَ عَلِیٌّ : ہِیَ بِمَنْزِلَۃِ الرَّبِیبَۃِ۔",,,16521 16522,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ خِلاَسٍ ، عَنْ عَلِیٍّ مِثْلَہُ,,,16522 16523,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ زَیْدِ بْنِ ثَابِتٍ أَنَّہُ کَانَ لاَ یَرَی بِہِ بَأْسًا إذَا طَلَّقَہَا وَیَکْرَہُہَا إذَا مَاتَتْ عِنْدَہُ۔,,,16523 16524,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ أَبِی بَکْرٍ بْنِ حَفْصِ بْنِ عُمَرَ بْنِ سَعْدٍ أَنَّ مُسْلِمَ بْنَ عُوَیْمِرِ بْنِ الأَجْدَعِ مِنْ بَنِی بَکْرِ بْنِ کِنَانَۃَ أَخْبَرَہُ أَنَّ أَبَاہُ أَنْکَحَہُ امْرَأَۃً بِالطَّائِفِ ، قَالَ : فَلَمْ أُجَامِعْہَا حَتَّی تُوُفِّیَ عَمِی ، عَنْ أُمِّہَا ، وَأُمُّہَا ذَاتُ مَالٍ کَثِیرٍ ، فَقَالَ لِی أبی ہَلْ لَکَ فِی أُمِّہَا ؟ فَقُلْتُ : وَدِدْت وَکَیْفَ وَقَدْ نَکَحَتِ ابْنَتَہَا، قَالَ : فَسَأَلْت ابْنَ عَبَّاسٍ ، فَقَالَ انْکِحْہَا ، وَسَأَلْت ابْنَ عُمَرَ ، فَقَالَ : لاَ تَنْکِحْہَا : قَالَ : فَکَتَبَ أَبِی عُوَیْمِرٍ فِی ذَلِکَ إلَی مُعَاوِیَۃَ وَأَخْبَرَہُ فِی کِتَابِہِ بِمَا قَالَ ابْنُ عَبَّاسٍ وَبِمَا قَالَ ابْنُ عُمَرَ فَکَتَبَ إلَیْہِ مُعَاوِیَۃُ : لاَ أُحِلُّ مَا حَرَّمَ اللَّہُ وَلاَ أُحَرِّمُ مَا أَحَلَّ اللَّہُ وَأَنْتَ وَذَاکَ وَالنِّسَائُ کَثِیرٌ قَالَ : فَلَمْ یَنْہَنِی وَلَمْ یَأْذَنْ وَانْصَرَفَ أَبِی عَنْہَا فَلَمْ نُنْکِحْہَا",,,16524 16525,"حَدَّثَنَا وَکِیع بن الجراح ، عَنْ سُفْیَانَ ، عَنْ أَبِی فَرْوَۃَ ، عَنْ أَبِی عَمْرٍو الشَّیْبَانِیِّ ، عَنْ عَبْدِ اللہِ بْنِ مَسْعُودٍ أَنَّہُ أَفْتَی فِی رَجُلٍ تَزَوَّجَ امْرَأَۃً فَطَلَّقَہَا قَبْلَ أَنْ یَدْخُلَ بِہَا ، أَوْ مَاتَتْ عِنْدَہُ ، فَقَالَ : لاَ بَأْسَ أَنْ یَتَزَوَّجَ أُمَّہَا ثُمَّ أَتَی الْمَدِینَۃَ فَرَجَعَ فَأَتَاہُمْ فَنَہَاہُمْ وَقَدْ وَلَدَتْ أَوْلاَدًا۔",,,16525 16526,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ ابن جریج قَالَ : أخبرنی دَاوُدَ ، عَنِ الشَّعْبِیِّ ، عَنْ مَسْرُوقٍ فِی {أُمَّہَاتِ نِسَائِکُمْ} قَالَ : مَا أَرْسَلَ اللَّہُ فَأَرْسِلُوا ، وَمَا بَیَّنَ فَاتَّبِعُوا۔",,,16526 16527,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ جُرَیْجٍ قَالَ : أَخْبَرَنِی عِکْرِمَۃُ ، عَنْ مُجَاہِدٍ أَنَّہُ قَالَ فِی {وَأُمَّہَاتُ نِسَائِکُمْ وَرَبَائِبُکُمَ اللاَّتِی فِی حُجُورِکُمْ} : أُرِیدَ بِہِمَا جَمْعُہُمَا۔",,,16527 16528,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ جُرَیْجٍ قَالَ : قُلْتُ لِعَطَائٍ : الرَّجُلُ یَتَزَوَّجُ الْمَرْأَۃَ ثُمَّ لاَ یَرَاہَا وَلاَ یُجَامِعُہَا حَتَّی یُطَلِّقَہَا أَیَتَزَوَّجُ أُمَّہَا ؟ قَالَ : لاَ ہِیَ مُرْسَلَۃٌ۔",,,16528 16529,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ أَنَّہُ کَانَ یَکْرَہُ إذَا مَلَکَ الرَّجُلُ عُقْدَۃَ امْرَأَۃٍ أَنْ یَتَزَوَّجَہَا۔,,,16529 16530,"حَدَّثَنَا عَفَّانَ قَالَ : حدَّثَنَا ہَمَّامٌ ، عَنْ قَتَادَۃَ قَالَ : أَخْبَرَنِی عَاصِمُ بْنُ سَعِیدٍ الْہُذَلِیُّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ أَنَّ زَیْدَ بْنَ ثَابِتٍ کَانَ یَکْرَہُ أَنْ یَتَزَوَّجَ بِنْتَ امْرَأَۃٍ مَاتَتْ أُمُّہَا عِنْدَہُ قَبْلَ أَنْ یَدْخُلَ بِہَا۔",,,16530 16531,"حَدَّثَنَا ابْنُ عُلَیَّۃَ قَالَ : قُلْتُ لاِبْنِ أَبِی نَجِیحٍ : الرَّجُلُ یَتَزَوَّجُ الْمَرْأَۃَ ثُمَّ یُطَلِّقُہَا قَبْلَ أَنْ یَدْخُلَ بِہَا أَیَتَزَوَّجُ أُمَّہَا ؟ فَقَالَ : سَمِعْتُ عِکْرِمَۃَ یَنْہَی عَنْہَا وَعَطَائً۔",,,16531 16532,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، عَنْ عِمْرَانَ بْنِ الْحُصَیْنِ فِی {أُمَّہَاتِ نِسَائِکُمْ} قَالَ : ہِیَ مُبْہَمَۃٌ۔",,,16532 16533,حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ زمعۃ عن ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ ، أَنَّہُ کَرِہَہَا ، وَقَالَ ہِیَ مُبْہَمَۃٌ۔,,,16533 16534,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : ہِیَ مُبْہَمَۃٌ۔",,,16534 16535,"حدَّثَنَا إِسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ قَالَ : کَانَ ابْنُ عُمَرَ یَرَی عَبْدَہُ یَتَسَرَّی فِی مَالِہِ فَلاَ یَعِیبُ ذَلِکَ عَلَیْہِ۔",,,16535 16536,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ قَالَ : کَتَبَ إلَیَّ نَافِعٌ إِنَّ الْعَبْدَ یَتَسَرَّی فِی مَالِہِ وَلاَ یَتَسَرَّی فِی مَالِ سَیِّدِہِ۔",,,16536 16537,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ قَالَ : کَانَ لاَ یَرَی بَأْسًا أَنْ یَتَسَرَّی الْعَبْدُ بِإِذْنِ سَیِّدِہِ۔",,,16537 16538,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ سَعْدِ بْنِ إبْرَاہِیمَ، عَنْ عُمَرَ بْنِ عَبْدِالْعَزِیزِ قَالَ: لاَ بَأْسَ أَنْ یَتَسَرَّی الْعَبْدُ۔",,,16538 16539,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَسَنٍ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ قَالَ : لاَ بَأْسَ بِہِ۔",,,16539 16540,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ قَیْسِ بْنِ مُسْلِمٍ ، عَنِ الشَّعْبِیِّ قَالَ : لاَ بَأْسَ بِہِ۔",,,16540 16541,"حَدَّثَنَا وَکِیعٌ ، عَنْ زَکَرِیَّا، عَنِ الشَّعْبِیِّ قَالَ: إذَا أَذِنَ الْمَوْلَی لِعَبْدِہِ فِی التَّسَرِّی ، فَلْیَتَّخِذْ مِنْہُنَّ مَا شَائَ",,,16541 16542,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ، عَنِ ابْنِ جُرَیْجٍ، عَنْ عَطَائٍ قَالَ: لَمْ نَکُنْ نَرَی بِتَسَرِّی الْعَبْدِ فِی مَالِ سَیِّدِہِ بَأْسًا۔",,,16542 16543,"حَدَّثَنَا عَبْدَۃُ بن سلیمان ، عَنْ إسْمَاعِیلَ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ بَأْسَ بِہِ۔",,,16543 16544,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنِ الْعَبَّاسِ بْنِ عبد اللہِ بْنِ مَعْبَدٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ کَانَ لَہُ غُلاَمٌ تَاجِرٌ ، وَکَانَ یَأْذَنُ لَہُ فَیَتَسَرَّی السِّتَّ وَالسَّبْعَ۔,,,16544 16545,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سَلَمَۃَ بْنَ کُہَیْلٍ ، عَنِ الْحَکَمِ قَالَ : یَتَزَوَّجُ وَلاَ یَتَسَرَّی۔",,,16545 16546,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ أَنَّہُ کَانَ یُحِبُّ أَنْ یُزَوِّجَہُ۔,,,16546 16547,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ قَالَ : سَأَلْتُ حَمَّادًا ، عَنْ ذَلِکَ ، فَقَالَ : أَلَمْ تَسْمَعِ وَلَکِنَّ اللَّہَ یَقُولُ : {إلاَّ عَلَی أَزْوَاجِہِمْ أَوْ مَا مَلَکَتْ أَیْمَانُہُمْ}۔",,,16547 16548,حَدَّثَنَا حَفْص بن غیاث، عَنْ أَشْعَثَ، عَنِ الْحَکَمِ، وَابْنِ سِیرِینَ أَنَّہُمَا کَرِہَا أَنْ یَتَسَرَّی، وَإِنْ أَذِنَ لَہُ مَوْلاَہُ۔,,,16548 16549,حَدَّثَنَا عَبْدَۃُ بن سلیمان ، عَنْ إسْمَاعِیلَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ کَانَ یَکْرَہُ أَنْ یَتَسَرَّی الْعَبْدُ۔,,,16549 16550,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ، عَنْ یَحْیَی بْنِ سَعِیدٍ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ، عَنْ عُمَرَ، قَالَ: مَنْ تَزَوَّجَ امْرَأَۃً وَبِہَا بَرَصٌ ، أَوْ جُذَامٌ ، أَوْ جُنُونٌ فَدَخَلَ بِہَا فَلَہَا الصَّدَاقُ بِمَا اسْتَحَلَّ مِنْ فَرْجِہَا وَذَلِکَ غُرْمٌ عَلَی وَلِیِّہَا۔",,,16550 16551,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ أَبِیہِ ، عَنِ الْحَکَمِ قَالَ : کَانَ عَلِیٌّ یَقُولُ فِی الْمَجْنُونَۃِ وَالْبَرْصَائِ : إِنْ دَخَلَ فَہِیَ امْرَأَتُہُ ، وَإِنْ لَمْ یَدْخُلْ فُرِّقَ بَیْنَہُمَا۔",,,16551 16552,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، عَنْ جَابِرِ بْنِ زَیْدٍ قَالَ : أَرْبَعٌ لاَ یَجُوزُنَ فِی بَیْعٍ وَلاَ نِکَاحٍ : الْبَرْصَائُ وَالْمَجْنُونَۃُ وَالْمَجْذُومَۃُ وَذَاتُ الْقَرَنِ۔",,,16552 16553,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ أَنَّ رَجُلاً تَزَوَّجَ امْرَأَۃً فَدَخَلَ بِہَا ثُمَّ وَجَدَ بِہَا عَیْبًا فَکَتَبَ إلَی عُمَرَ بْنِ عَبْدِ الْعَزِیزِ فِی ذَلِکَ ، فَکَتَبَ أَنَّہُ قَدْ اتَّمَنَہُمْ عَلَی مَا ہُوَ أَعْظَمُ مِنْ ذَلِکَ فَأَجَازَہَا عَلَیْہِ۔,,,16553 16554,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ سُئِلَ عَنِ الرَّجُلِ یَتَزَوَّجُ الْمَرْأَۃَ فَیَدْخُلُ بِہَا فَیَظْہَرُ عَلَیْہَا دَائٌ أَنَّہُ کَانَ یُوجِبُہَا عَلَیْہِ۔,,,16554 16555,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ عَمْرِو بْنِ مَیْمُونٍ، عَنْ عُمَرَ بْنِ عَبْدِالْعَزِیزِ قَالَ: لَیْسَ لَہُ إلاَّ أَمَانَۃُ أَصْہَارِہِ۔",,,16555 16556,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ قَالَ : الْحُرَّۃُ لاَ تُرَدُّ مِنْ عَیْبٍ۔",,,16556 16557,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ إسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ ، عَنْ شُرَیْحٍ أَنَّہُ کَانَ یُعَوِّضُ الْبَرْصَاء َ۔,,,16557 16558,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ وَالزُّہْرِیِّ قَالاَ : فِی رَجُلٍ تَزَوَّجَ امْرَأَۃً فَدَخَلَ فَرَأَی بِہَا جُنُونًا ، أَوْ جُذَامًا ، أَوْ بَرَصًا ، أَوْ عَفَلاً : إنَّہَا تُرَدُّ مِنْ ہَذَا وَلَہَا الصَّدَاقُ الَّذِی اسْتَحَلَّ بِہِ فَرْجَہَا الْعَاجِلُ وَالآجِلُ وَصَدَاقُہَ عَلَی مَنْ غَرَّہُ۔",,,16558 16559,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ جَمِیلٍ ، عَنْ عَبْدِ اللہِ بْنِ کَعْبٍ ، أَوْ کَعْبِ بْنِ عَبْدِ اللہِ قَالَ : تَزَوَّجَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ امْرَأَۃً مِنْ غِفَارٍ فَقَعَدَ مِنْہَا مَقْعَدَ الرَّجُلِ مِنَ الْمَرْأَۃِ فَأَبْصَرَ بِکَشْحِہَا بَرَصًا فَقَامَ عَنْہَا ، فَقَالَ : سَوِّی عَلَیْک ثِیَابَک وَارْجِعِی إلَی بَیْتِک۔",,,16559 16560,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ زُہَیْرٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، عَن عَبْدِ اللہِ قَالَ : لاَ تُرَدُّ الْحُرَّۃُ مِنْ عَیْبٍ۔",,,16560 16561,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ أَنَّہُ قَالَ : إذَا تَزَوَّجَ الرَّجُلُ الْمَرْأَۃَ وَبِالرَّجُلِ عَیْبٌ لَمْ تَعْلَمْ بِہِ ، جُنُونٌ ، أَوْ جُذَامٌ ، أَوْ بَرَصٌ خُیِّرَتْ۔",,,16561 16562,"حَدَّثَنَا غُنْدَرٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ أَنَّہُ قَالَ فِی الرَّجُلِ یَتَزَوَّجُ الْمَرْأَۃَ وَبِہِ الْبَرَصُ قَالَ : کَانَ لاَ یَرَاہُ مِنَ الرَّجُلِ شَیْئًا ، وَأَمَّا الْجُذَامُ فَإِنْ شَاء َتْ أَقَرَّتْ مَعَہُ ، وَإِنْ شَاء َتْ فَارَقَتْہُ۔",,,16562 16563,"حَدَّثَنَا مُحَمَّدُ بْنُ یَزِیدَ ، عَنْ أَبِی الْعَلاَئِ وَہُوَ أَیُّوبُ ، عَنْ قَتَادَۃَ فِی رَجُلٍ تَزَوَّجَ امْرَأَۃً وَبِہِ جُنُونٌ ، أَوْ دَائٌ عُضَالٌ لاَ تعْلَمُ بِہِ قَالَ : ہِیَ بِالْخِیَارِ إذَا عَلِمَتْ وَقَالَ أَبُو ہَاشِمٍ : ہِیَ امْرَأَتُہُ إِنْ شَاء َ أَمْسَکَ ، وَإِنْ شَاء َ طَلَّقَ۔",,,16563 16564,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مُوسَی بْنِ أَبِی عَائِشَۃَ قَالَ : سَأَلْتُ مُرَّۃَ ، عَنِ الرَّجُلِ یَشْتَرِی ، أَوْ یَسْبِی الْجَارِیَۃَ الْمَجُوسِیَّۃَ ثُمَّ یَقَعُ عَلَیْہَا قَبْلَ أَنْ تَعْلَمَ الإِسْلاَمَ قَالَ لاَ یَصْلُحُ ، وَسَأَلْت سَعِیدَ بْنَ جُبَیْرٍ ، فَقَالَ : مَا ہُوَ بِأَخْیَرَ مِنْہَا إذَا فَعَلَ ذَلِکَ۔",,,16564 16565,"حَدَّثَنَا عَبْدُ الأَعْلَی، عَنْ بُرْدٍ، عَنْ مَکْحُولٍ قَالَ: إذَا کَانَتْ وَلِیدَۃً مَجُوسِیَّۃً، فَإِنَّہُ لاَ یَنْکِحُہَا حَتَّی تُسْلِمَ۔",,,16565 16566,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، عَنِ الزُّہْرِیِّ قَالَ سَمِعْتُہُ یَقُولُ : لاَ تَقْرَبِ الْمَجُوسِیَّۃَ حَتَّی تَقُولَ لاَ إلَہَ إلاَّ اللَّہُ ، فَإِذَا قَالَتْ ذَلِکَ فَہُوَ مِنْہَا إسْلاَمٌ۔",,,16566 16567,"حَدَّثَنَا وَکِیعٌ ، عَنْ شَرِیکٍ ، عَنْ سِمَاکٍ ، عَنْ أَبِی سَلَمَۃَ فِی الْمَجُوسِیَّۃِ قَالَ : لاَ تَقْرَبْہَا مَتَی تُسْلِمُ۔",,,16567 16568,"حَدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی الْمَجُوسِیَّۃِ تَکُونُ عِنْدَ الرَّجُلِ قَالَ : لاَ یَطَؤُہَا۔",,,16568 16569,"حَدَّثَنَا جَرِیر بن عبد لحمید ، عَنْ مُغِیرَۃَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ قَالَ : إذَا سُبِیَتِ الْمَجُوسِیَّاتُ وَعَبَدَۃُ الأَوْثَانِ عُرِضَ عَلَیْہِنَّ الإِسْلاَمُ وجبرن فَإِنْ أَسْلَمْنَ وُطِئْنَ وَاسْتُخْدِمْنَ ، وَإِنْ أَبَیْنَ أَنْ یُسْلِمْنَ اسْتُخْدِمْنَ وَلَمْ یُوطَئْنَ۔",,,16569 16570,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ مُثَنَّی ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : لاَ بَأْسَ أَنْ یَشْتَرِیَ الرَّجُلُ الْجَارِیَۃَ الْمَجُوسِیَّۃَ فَیَتَسَرَّاہَا۔",,,16570 16571,"حَدَّثَنَا عُبَیْدُ اللہِ ، عَنْ مُثَنَّی قَالَ : کَانَ عَطَائٌ وَطَاوُسٌ وَعَمْرُو بْنُ دِینَارٍ لاَ یَرَوْنَ بَأْسًا أَنْ یَتَسَرَّی الرَّجُلُ الْمَجُوسِیَّۃَ وَکَرِہَہُ سَعِیدُ بْنُ الْمُسَیِّبِ۔",,,16571 16572,"حَدَّثَنَا شَاذَانُ قَالَ : حدَّثَنَا شَرِیکٌ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ بَکْرِ بْنِ مَاعِزٍ ، عَنْ رَبِیعِ بْنِ خُثَیْمٍ قَالَ : إذَا أَصَبْت الأَمَۃَ الْمُشْرِکَۃَ فَلاَ تَأْتِیہَا حَتَّی تُسْلِمَ وَتَغْتَسِلَ۔",,,16572 16573,"حَدَّثَنَا جَرِیر بن عبد لحمید ، عَنْ مُغِیرَۃَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ قَالَ : إذَا سُبِیَتِ الْیَہُودِیَّاتُ وَالنَّصْرَانِیَّات عُرِضَ عَلَیْہِنَّ الإِسْلاَمُ وَجُبِرْنَ عَلَیْہِ فَإِنْ أَسْلَمْنَ ، أَوْ لَمْ یُسْلِمْنَ وطِئْنَ وَاسْتُخْدِمْنَ۔",,,16573 16574,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ فِی الرَّجُلِ إذَا کَانَتْ لَہُ وَلِیدَۃٌ یَہُودِیَّۃٌ ، أَوْ نَصْرَانِیَّۃٌ ، فَإِنَّہُ یَتَّطِؤُہَا۔,,,16574 16575,حَدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ قَالَ الْیَہُودِیَّۃُ وَالنَّصْرَانِیَّۃُ یَتَّطئہما۔,,,16575 16576,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ قَالَ : إذَا أَصَابَ الرَّجُلُ الْجَارِیَۃَ الْمُشْرِکَۃَ فَلْیُقْرِرْہَا بِشَہَادَۃِ لاَ إلَہَ إلاَّ اللَّہُ فَإِنْ أَبَتْ أن تُقِرَّ لَمْ یَمْنَعْہُ ذَلِکَ أَنْ یَقَعَ عَلَیْہَا۔",,,16576 16577,حَدَّثَنَا عَبدَۃ بن سلیمان، عَنْ سَعِیدٍ، عَنْ قَتَادَۃَ، عَنْ مُعَاوِیَۃَ بْنِ قُرَّۃَ قَالَ، کَانَ عَبْدُاللہِ یَکْرَہُ أَمَتَہُ مُشْرِکَۃ۔,,,16577 16578,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ قَالَ : إذَا کَانَتْ لَہُ أَمَۃٌ مِنْ أَہْلِ الْکِتَابِ فَلَہُ أَنْ یَغْشَاہَا إِنْ شَاء َ وَیُکْرِہَہَا عَلَی الْغُسْلِ۔",,,16578 16579,"حَدَّثَنَا مُعْتَمِر بن سلیمان ، عَنْ نَاجِیَۃَ ، عَنْ قَتَادَۃَ ، عَنِ ابْنِ مَسْعُودٍ فِی الْمَسْبِیَّۃِ : لاَ یَطَؤُہَا حَتَّی تُہَلِّلَ وَتُسْلِمَ۔",,,16579 16580,"حَدَّثَنَا یَزِیدُ ، عَنْ حَبِیبٍ ، عَنْ عَمْرِو بْنِ ہَرِمٍ قَالَ : سُئِلَ جَابِرُ بْنُ زَیْدٍ ، عَنِ الرَّجُلِ یَشْتَرِی الْجَارِیَۃَ مِنَ السَّبْیِ فَیَقَعُ عَلَیْہَا قَالَ : لاَ حَتَّی یُعَلِّمَہَا الصَّلاَۃَ وَالْغُسْلَ مِنَ الْجَنَابَۃِ وَحَلْقَ الْعَانَۃِ۔",,,16580 16581,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ قَیْسِ بْنِ مُسْلِمٍ ، عَنِ الْحَسَنِ بْنِ مُحَمَّدٍ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَتَبَ إلَی مَجُوسِ أَہْلِ ہَجَرَ یَعْرِضُ عَلَیْہِمَ الإِسْلاَمَ فَمَنْ أَسْلَمَ قَبِلَ مِنْہُ وَمَنْ لَمْ یُسْلِمْ ضَرَبَ عَلَیْہِ الْجِزْیَۃَ غَیْرَ نَاکِحِی نِسَائِہِمْ وَلاَ آکِلِی ذَبَائِحِہِمْ۔ (عبدالرزاق 10028۔ بیہقی 285),,,16581 16582,حَدَّثَنَا ہُشَیْمٌ ، عَنِ الْعَوَّامِ قَالَ ، أَخْبَرَنِی مَنْ سَمِعَ سَعِیدَ بْنَ الْمُسَیَّبِ یُکْرَہُ أَنْ یَطْلُبَ الرَّجُلُ الْوَلَدَ مِنَ الأَمَۃِ إذَا کَانَتْ وَلَدَ الزِّنَا۔,,,16582 16583,"حَدَّثَنَا وَکِیعٌ ، عَنْ مَعْمَرٍ ، عَنْ أَبِی جَعْفَرٍ قَالَ : یَتَسَرَّی وَلَدَ الزِّنَا وَلاَ یَطْلُبُ وَلَدَہَا۔",,,16583 16584,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عُثْمَانَ بْنِ الْحَارِثِ ، عَنْ أَبِی الرُّوَاعِ ، قَالَ : سَأَلْتُ ابْنَ عُمَرَ ، عَنْ وَلَدِ الزِّنَا ، فَقَالَ : النِّسَائُ کَثِیرٌ۔",,,16584 16585,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ إبْرَاہِیمَ بْنِ الْمُہَاجِرِ ، عَنْ إبْرَاہِیمَ قَالَ لاَ بَأْسَ أَنْ یَتَسَرَّاہَا۔,,,16585 16586,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یَکُونُ تَحْتَہُ الأَمَۃُ لِزِنْیَۃ قَالَ : ہِیَ کَعَرَضِ مَالِہِ یَتَّطِؤُہَا۔",,,16586 16587,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ قَالَ : لاَ بَأْسَ أَنْ یَشْتَرِیَ الرَّجُلُ وَلَدَ الزِّنْیَۃِ یَتَسَرَّاہَا",,,16587 16588,"حَدَّثَنَا مُعْتَمِر بن سلیمان ، عَنْ أَبِیہِ ، عَنْ سَیّار مَوْلًی لِمُعَاوِیَۃَ قَالَ : أَرَادَ رَجُل أَنْ یَتَزَوَّجَ بِنْتَ زِنْیَۃٍ فَسَأَلَ عَنْ ذَلِکَ رَجُلاً مِنْ أَصْحَابِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : لاَ ، إذا أَتَزَوَّجَ أُمَّہَا أَحَبُّ إلَیَّ مِنْ أَنْ أَتَزَوَّجَہَا۔",,,16588 16589,"حَدَّثَنَا حُمَیْدٌ ، عَنْ حَسَنٍ ، عَنْ أَشْعَثَ ، عَنْ مُحَمَّدِ بْنِ سِیرِینَ فِی الرَّجُلِ یَتَسَرَّی وَلَدَ الزِّنَا قَالَ : وَمَا ذَنْبُہُ فِیمَا عَمِلَ أَبَوَاہُ۔",,,16589 16590,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ عَبْدِ اللہِ بْنِ حَبِیبٍ ، قَالَ : سَمِعْتُ الْحَکَمَ یَقُولُ : لَوْ کَانَتْ لِی جَارِیَۃُ وَلَدِ الزِّنَا لَمْ أُبَالِی أَنْ أَطَأَہَا۔",,,16590 16591,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمرو ، عَنْ أَبِی مَعْبَدٍ ؛ أَنَّ ابْنَ عَبَّاسٍ وَطِیئَ جَارِیَۃً بَعْدَ مَا أَنْکَرَ وَلَدَہَا۔,,,16591 16592,حَدَّثَنَا حَفْص بن غیاث ، عَنْ لَیْثٍ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی لبابۃ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ یَطَأَ الرَّجُلُ أَمَتہ إذَا فَجَرَتْ ، وَیَرَی أَنَّ ذَلِکَ تَحْصِینٌ لَہَا۔,,,16592 16593,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ مُحَمَّدِ بْنِ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ أَبِیہِ أَنَّہُ وَطِیئَ جَارِیَۃً لَہُ بَعْدَ مَا فَجَرَتْ۔,,,16593 16594,"حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الشَّعْبِیِّ فِی الرَّجُلِ یَطَأُ أَمَتَہُ وَقَدْ زَنَتْ قَالَ : ہُوَ بِالْخِیَارِ إِنْ شَاء َ وَطِئَہَا ، وَإِنْ شَاء َ أَمْسَکَ۔",,,16594 16595,"حَدَّثَنَا عَبدَۃ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ مُعَاوِیَۃَ بْنِ قُرَّۃَ قَالَ : کَانَ عَبْدُ اللہِ یَکْرَہُ أَمَتہ قَدْ زَنَتْ۔",,,16595 16596,"حَدَّثَنَا الْفَضْلُ ، عَنْ مُبَارَکٍ ، عَنِ الْحَسَنِ ، قَالَ : سَمِعْتُہُ وَسُئِلَ عَنِ الرَّجُلِ یَرَی أَمَتَہُ تَفْجُرُ أَیَطَؤُہَا ؟ قَالَ : لاَ وَلاَ کَرَامَۃَ۔",,,16596 16597,"حَدَّثَنَا حَفْص بن غیاث ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ وَعَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ قَالاَ : إذَا رَأَی الرَّجُلُ امْرَأَتَہُ تَفْجُرُ لَمْ یُحَرِّمْہَا ذَلِکَ عَلَیْہِ۔",,,16597 16598,"حَدَّثَنَا أَبُو أُسَامَۃَ قَالَ : حدَّثَنَا جَرِیرُ بْنُ حَازِمٍ ، عَنْ قَیْسِ بْنِ سَعْدٍ ، عَنْ عَطَائٍ فِی الرَّجُلِ یری تَزْنِی امْرَأَتُہُ قَالَ : لاَ یُحَرِّمُہَا ذَلِکَ عَلَیْہِ۔",,,16598 16599,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ حَمَّادِ بْنِ مَسْلَمَۃَ ، عَنْ عِمْرَانَ بْنِ عَبْدِ اللہِ ، عَنْ سَالِمٍ قَالَ لَہُ رَجُلٌ : إنِّی رَأَیْت مَعَ امْرَأَتِی رَجُلاً ، قَالَ : تَطِیبُ نَفْسُک ، أَوْ کَیْفَ تَطِیبُ نَفْسُک أَنْ تُمْسِکَہَا وَقَدْ رَأَیْت مَا رَأَیْت وَلَمْ تَحْرُمْ عَلَیْک۔",,,16599 16600,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یَرَی مِنِ امْرَأَتِہِ فَاحِشَۃً أَنَّہُ یَکْرَہُ أَنْ یُمْسِکَہَا۔,,,16600 16601,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیْدِ بْنِ جَابِرٍ ، عَنْ مَکْحُولٍ قَالَ : إذَا أطَّلَعَ الرَّجُلُ عَلَی امْرَأَتِہِ أَنَّہَا تَفْجُرُ لَمْ یَحِلَّ لَہُ أَنْ یُمْسِکَہَا ، وَإِذَا فَجَرَ ہُوَ ، لَمْ یَحِلَّ لَہَا أَنْ تُقِیمَ مَعَہُ۔",,,16601 16602,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ، عَنِ الشَّیْبَانِیِّ، عَنْ عَبْدِ اللہِ بْنِ شَدَّادٍ قَالَ: کُنْتُ جَالِسًا مَعَ ابْنِ عَبَّاسٍ فِی زَمْزَمَ فَأَتَاہُ رَجُلٌ فَذَکَر لہ أَنَّہُ تَسَقَّط امْرَأَتَہُ فَزَعَمَتْ أَنَّہَا فَجَرَتْ ، فَقَالَ لَہُ ابْنُ عَبَّاسٍ : فَبِئْسَ مَا صَنَعْت إِنْ کُنْت فَعَلْت مِثْلَ الَّذِی أَقَرَّتْ بِہِ عَلَی نَفْسِہَا ، فَأَمْسِکَ علیک امْرَأَتَکَ، وَإِنْ کَانَتْ لَمْ تَفْعَلْ فَخَلِّ سَبِیلَہَا۔",,,16602 16603,حَدَّثَنَا عَبدَۃ بن سلیمان ، عَنْ سَعِیدٍ ، عَنْ عَدِیِّ بْنِ ثَابِتٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ قَالَ ، إذَا رَأَی أَحَدُکُمَ امْرَأَتَہُ ، أَوْ أُمَّ وَلَدِہِ عَلَی فَاحِشَۃٍ فَلاَ یَقْرَبْہَا۔,,,16603 16604,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ زَمْعَۃَ ، عَنْ سَلَمَۃَ بْنِ وَہْرَام قَالَ: کُنْتُ جَالِسًا عِنْدَ طَاوُوسٍ ، فَقَالَ لَہُ رَجُلٌ: إنِّی وَجَدْت فِی مَجْلِسِی رَجُلاً ، فَقَالَ طَاوُوسٌ: إِنْ طَابَتْ نَفْسُک أَنْ تُمْسِکَہَا وَقَدْ رَأَیْت مَا رَأَیْت فَأَنْتَ أَعْلَمُ۔",,,16604 16605,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : أَخْبَرَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ عَبْدِ اللہِ بْنِ عُبَیْدِ بْنِ عُمَیْرٍ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : جَاء َ رَجُلٌ إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : إنَّ عِنْدِی امْرَأَۃً أَحَبُّ النَّاسِ إلَیَّ ، وَإِنَّہَا لاَ تَمْنَعُ یَدَ لاَمِسٍ ، قَالَ : طَلِّقْہَا قَالَ : لاَ أَصْبِرُ عَنْہَا ، قَالَ : فَاسْتَمْتِعْ بِہَا۔\n\n(ابوداؤد 2042۔ بیہقی 155)",,,16605 16606,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنْ قَیْسِ بْنِ سَعْدٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : جَاوَزَ حُرْمَتَیْنِ إلَی حُرْمَۃٍ وإن لَمْ تَحْرُمْ عَلَیْہِ امْرَأَتُہُ۔",,,16606 16607,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ قَالَ إذَا زَنَی الرَّجُلُ بِأُخْتِ امْرَأَتِہِ فَإِنَّہَا لاَ تَحْرُمُ عَلَیْہِ ، لاَ یُحَرِّمُ حَرَامٌ حَلاَلاً۔,,,16607 16608,حَدَّثَنَا عَبْدُ الْوَہَّابِ الثقفی ، عَنْ عُثْمَانَ الْبَتِّیِّ ، عَنِ ابْنِ أَشْوَعَ أَنَّہُ سُئِلَ عَنْہَا ، فَقَالَ لاَ یُحَرِّمُ الْحَرَامُ الْحَلاَلَ ، جَسَرْتُ عَلَیْہَا ، وَہَابَہَا إبْرَاہِیمُ وَالشَّعْبِیُّ۔,,,16608 16609,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ قَالَ حَرُمَتْ عَلَیْہِ امْرَأَتُہُ۔,,,16609 16610,"وَحَدَّثَنَا سَعِیدٌ قَالَ قَتَادَۃُ: لاَ یُحَرِّمُہَا ذَلِکَ عَلَیْہِ غَیْرَ أَنَّہُ لاَ یَغْشَی امْرَأَتَہُ حَتَّی تَنْقَضِیَ عِدَّۃُ الَّتِی بَنَی بِہَا۔",,,16610 16611,"حَدَّثَنَا عَبْدُ الأَعْلَی، عَنْ سَعِیدٍ، عَنْ قَتَادَۃَ، عَنْ جَابِرِ بْنِ زَیْدٍ، وَالْحَسَنِ أَنَّہُمَا قَالاَ: حرُمَتْ عَلَیْہِ امْرَأَتُہُ۔",,,16611 16612,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ بَعْضِ أَصْحَابِہِ ، عَنِ النَّخَعِیِّ : مِثْلَ قَوْلِ قَتادۃ ، وَإِنْ کَانَتْ حَامِلاً فَحَتی تَضَعَ حَمْلَہَا۔",,,16612 16613,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ صَاحِبٍ لَہُ ، عَنْ عَطَائٍ قَالَ : لاَ یُحَرِّمُہَا ذَلِکَ عَلَیْہِ۔",,,16613 16614,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ أَنَّہُ بَلَغَہُ عَنِ الشَّعْبِیِّ قَالَ : لاَ یُحَرِّمُہَا ذَلِکَ عَلَیْہِ۔",,,16614 16615,"حَدَّثَنَا أبو عَبْد الصَّمَدِ الْعَمِّیُّ، عَنْ سَعِیدٍ، عَنْ قَتَادَۃَ، عَنْ عِمْرَانَ بْنِ حُصَیْنٍ قَالَ: حرُمَتْ عَلَیْہِ امْرَأَتُہُ۔",,,16615 16616,"حَدَّثَنَا أبو عَبْد الصَّمَدِ الْعَمِّیُّ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ یَحْیَی بْنِ یَعْمَُرَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لَمْ تَحْرُمَ امْرَأَتُہُ عَلَیْہِ۔",,,16616 16617,"حَدَّثَنَا عَبْدُ الْعَزِیزِ بْنُ عَبْدِ الصَّمَدِ الْعَمِّیُّ ، عَنْ بُدَیْلِ بْنِ مَیْسَرَۃَ الْعُقَیْلِیِّ ، عَنِ أَبِی الْوَضِینِ أَنَّ رَجُلاً تَزَوَّجَ إلَی رَجُلٍ مِنْ أَہْلِ الشَّامِ بنتا لَہُ ابْنَۃَ مَہِیرَۃٍ فَزَوَّجَہُ وَزَفَّ إلَیْہِ ابْنَۃً لَہُ أُخْرَی بنت فَتَاۃ فَسَأَلَہَا الرَّجُلُ بَعْدَ مَا دَخَلَ بِہَا : ابْنَۃُ مَنْ أَنْتِ ؟ قَالَتْ : ابْنَۃُ الفَتَاۃِ تَعْنِی فُلاَنَۃً ، فَقَالَ : إنَّمَا تَزَوَّجْت إلَی أبیک ابنتہ ابْنَۃِ الْمَہِیرَۃِ فَارْتَفَعُوا إلَی مُعَاوِیَۃَ بْنِ أَبِی سُفْیَانَ ، فَقَالَ : امْرَأَۃٌ بِامْرَأَۃٍ وَسَأَلَ مَنْ حَوْلَہُ مِنْ أَہْلِ الشَّامِ ، فَقَالَ : امْرَأَۃٌ بِامْرَأَۃٍ ، فَقَالَ الرَّجُلُ : لمُعَاوِیَۃُ ، ارْفَعْنَا إلَی عَلِیِّ بْنِ أَبِی طَالِبٍ ، فَقَالَ : اذْہَبُوا إلَیْہِ فَأَتَوْا عَلِیًّا فَرَفَعَ عَلِیٌّ مِنَ الأَرْضِ شَیْئًا ، فَقَالَ : الْقَضَائُ فِی ہَذَا أَیْسَرُ مِنْ ہَذَا ، لِہَذِہِ مَا سُقْتَ إلَیْہَا بِمَا اسْتَحْلَلْتَ مِنْ فَرْجِہَا وَعَلَی أَبِیہَا أَنْ یجہز الأُخْرَی بِمَا سُقْتَ إلَی ہَذِہِ وَلاَ تَقْرَبْہَا حَتَّی تَنْقَضِیَ عِدَّۃُ ہَذِہِ الأُخْرَی ، قَالَ: وَأَحْسَبُ أَنَّہُ جَلَدَ أَبَاہَا ، أَوْ أَرَادَ أَنْ یَجْلِدَہُ۔",,,16617 16618,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، وَأَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ المُغِیرَۃَ الطَّائِفِیِّ ، عَنْ عَبْدِ الرَّحْمَنِ ابن البیلمَانِی مَوْلَی عُمَرَ قَالَ : خَطَبَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : أَنْکِحُوا الأَیَامَی مِنْکُمْ فَقَامَ إلَیْہِ رَجُلٌ ، فَقَالَ : یَا رَسُولَ اللہِ ، مَا الْعَلاَئِقُ بَیْنَہُمْ ؟ قَالَ : مَا تَرَاضَی عَلَیْہِ أَہْلُوہُمْ۔\n\n(بیہقی 239۔ ابن عدی 2188)",,,16618 16619,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَبِیبۃَ ، عَنْ جَدِّہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنِ اسْتَحَلَّ بِدِرْہَمٍ فَقَدِ اسْتَحَلَّ قَالَ : وَسَمِعْت وَکِیعًا یُفْتِی بِہِ یَقُولُ : یَتَزَوَّجُہَا بِدِرْہَمٍ۔ (ابویعلی 939)",,,16619 16620,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَاصِمِ بْنِ عُبَیْدِ اللہِ ، عَنْ عَبْدِ اللہِ بْنِ عَامِرِ بْنِ رَبِیعَۃَ ، عَنْ أَبِیہِ أَنَّ رَجُلاً تَزَوَّجَ عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَلَی نَعْلَیْنِ فَأَجَازَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نِکَاحَہُ۔ (ترمذی 1113۔ احمد 3/445),,,16620 16621,حَدَّثَنَا حُسَیْنِ بْنِ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ أَبِی حَازِمٍ ، عَنْ سَہْلِ بْنُ سعْدٍ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ زَوَّجَ رَجُلاً امْرَأَۃً عَلَی أَنْ یُعَلِّمَہَا سُورَۃً مِنَ الْقُرْآنِ۔ (بخاری 2310۔ مسلم 77),,,16621 16622,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ إسْمَاعِیلَ بْنِ أُمَیَّۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : لَوْ رَضِیَتْ بِسَوْطٍ کَانَ مَہْرَہَا۔",,,16622 16623,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسٍ قَالَ : تَزَوَّجَ عَبْدُ الرَّحْمَنِ بْنُ عَوْفٍ عَلَی وَزْنِ نَوَاۃٍ مِنْ ذَہَبٍ قُوِّمَتْ ثَلاَثَۃَ دَرَاہِمَ وَثُلُثًا۔",,,16623 16624,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ، عَنْ عَمْرٍو، عَنِ الْحَسَنِ قَالَ: مَا تَرَاضَی عَلَیْہِ الزَّوْجُ وَالْمَرْأَۃُ مِنْ شَیْئٍ فَہُوَ مَہْرٌ۔",,,16624 16625,"حَدَّثَنَا عبد اللہ بْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، فِی الرَّجُلِ یَتَزَوَّجُ عَلَی عَشَرَۃِ دَرَاہِمَ قَالَ : قدْ کَانَ الْمُسْلِمُونَ یَتَزَوَّجُونَ عَلَی أَقَلَّ مِنْ ذَلِکَ وَأَکْثَرَ۔",,,16625 16626,"حَدَّثَنَا إسماعیل ابْنُ عُلَیَّۃَ ، عَنْ صَالِحِ بْنِ مُسْلِمٍ قَالَ : قُلْتُ لِلشَّعْبِیِّ : رَجُلٌ تَزَوَّجَ امْرَأَۃً بِدِرْہَمٍ قَالَ : لاَ یَصْلُحُ إلاَّ بِثَوْبٍ ، أَوْ بِشَیْئٍ۔",,,16626 16627,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنِ ابْنِ عَوْنٍ قَالَ : سَأَلْتُ الْحَسَنَ مَا أَدْنَی مَا یَتَزَوَّجُ الرَّجُلُ عَلَیْہِ ؟ قَالَ : نَوَاۃٌ مِنْ ذَہَبٍ ، أَوْ وَزْنُ نَوَاۃٍ مِنْ ذَہَبٍ۔",,,16627 16628,"حَدَّثَنَا حَفْص بن غیاث ، عَنْ أَشْعَثَ وَہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ، عَنْ أَبِی الْعَجْفَائِ السُّلَمِیِّ ، عَنْ عُمَرَ ، قَالَ : لاَ تُغَالُوا فِی مُہُورِ النِّسَائِ فَإِنَّہَا لَوْ کَانَتْ مَکْرُمَۃً فِی الدُّنْیَا ، أَوْ تَقْوَی عِنْدَ اللہِ لَکَانَ أَحَقَّکُمْ بِہَا مُحَمَّدًا صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَأَوْلاَکُمْ ، مَا زَوَّجَ بِنْتًا مِنْ بَنَاتِہِ وَلاَ تَزَوَّجَ شَیْئًا مِنْ نِسَائِہِ إلاَّ عَلَی اثْنَتَی عَشْرَۃَ أُوقِیَّۃً۔ (ابوداؤد 2099۔ احمد 1/40)",,,16628 16629,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : أَخْبَرَنَا ابْنُ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ، عَنْ أَبِی الْعَجْفَائِ السُّلَمِی قَالَ قَالَ عُمَرُ : لاَ تُغَالُوا صُدُقَ النِّسَائِ ثُمَّ ذَکَرَ مِثْلَ حَدِیثِ حَفْصٍ۔ (ابن ماجہ 1887)",,,16629 16630,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، قَالَ : حَدَّثَنِی مُحَمَّدُ بْنُ إبْرَاہِیمَ قَالَ : کَانَ صَدَاقُ بَنَاتِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَصَدَاقُ نِسَائِہِ خَمْسَ مِئَۃِ دِرْہَمٍ۔ (ابوداؤد 2098۔ عبدالرزاق 10407)",,,16630 16631,"حَدَّثَنَا شَرِیک عَبْدِاللہِ، عَنْ دَاوُدَ الزعَافِری، عَنِ الشَّعْبِیِّ قَالَ: قَالَ عَلِیٌّ: لاَ مَہْرَ بِأَقَلَّ مِنْ عَشَرَۃِ دَرَاہِمَ۔",,,16631 16632,حَدَّثَنَا وَکِیع بن الجراح ، عَنِ ابن أَبِی رَوَّادٍ ، عَنْ نَافِعٍ ، أَنَّ عُمَرَ نَہَی أَنْ یُزَادَ النِّسَاء عَلَی أَرْبَعِ مِئَۃٍ۔,,,16632 16633,حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ کَرِہَ أَنْ یُتَزَوَّجَ عَلَی أَقَلَّ مِنْ أرْبَعِینَ ، وَکَانَ الْحَکَمُ لاَ یَرَی بِہِ بَأْسًا۔,,,16633 16634,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَبْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ قَالَ : تَزَوَّجَ ابْنُ عُمَرَ صَفِیَّۃَ عَلَی أَرْبَعِ مِئَۃِ دِرْہَمٍ فَأَرْسَلَتْ إلَیْہِ إِنَّ ہَذَا لاَ یَکْفِینَا فَزَادَہَا مِئَتَیْنِ سِرًّا مِنْ عُمَرَ۔",,,16634 16635,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : السُّنَّۃُ فِی النِّکَاحِ اثْنَا عَشَرَ أُوقِیَّۃً وَنِصْفَ فَذَلِکَ خَمْسُ مِئَۃِ دِرْہَمٍ۔",,,16635 16636,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنٍ ، عَنْ أَبِی ہَارُونَ ، عَنْ أَبِی سَعِیدٍ قَالَ : لَیْسَ عَلَی الرَّجُلِ جُنَاحٌ أَنْ یَتَزَوَّجَ بِقَلِیلٍ مِنْ مَالِہِ ، أَوْ کَثِیرٍ إذَا تَرَاضَوْا وَأَشْہَدُوا۔",,,16636 16637,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ أَیُّوبَ بن مُوسَی ، عَنِ ابْنِ قُسَیْطٍ أَنَّ سَعِیدَ بْنَ الْمُسَیَّبِ قَالَ : لَوْ أَصْدَقَہَا سَوْطًا لَحَلَّتْ لَہُ۔",,,16637 16638,"حَدَّثَنَا أَبُو أُسَامَۃَ قَالَ : حدَّثَنِی مُوسَی بْنُ عَبْدِ اللہِ قَالَ : حدَّثَنَا إِسْحَاقُ بْنُ عَبْدِ اللہِ بْنِ أَبِی طَلْحَۃَ الأَنْصَارِیُّ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ تَزَوَّجَ سَوْدَۃَ بِنْتَ زَمْعَۃَ عَلَی بَیْتٍ وَرِثَہُ مِنْ بَعْضِ نِسَائِہِ۔",,,16638 16639,"حَدَّثَنَا أَبُو خَالِد الأحمر ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ قَالَ : کَانُوا یَکْرَہُونَ أَنْ یَتَزَوَّجَ الرَّجُلُ عَلَی الدِّرْہَمِ وَالدِّرْہَمَین مِثْلِ مَہْرِ الْبَغِیِّ۔",,,16639 16640,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شعبۃ عن أَبِی سَلَمَۃَ ، عَنِ الشَّعْبِیِّ قَالَ : سَمِعَہُ یَقُولُ : کَانُوا یَکْرَہُونَ أَنْ یُتَزَوَّجَ عَلَی أَقَلَّ مِنْ ثَلاَثِ أَوَاقٍ۔",,,16640 16641,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنِ ابْنِ سَخْبَرَۃَ ، عَنِ الْقَاسِمِ ، عَنْ عَائِشَۃَ قَالَتْ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَعْظَمُ النِّسَائِ بَرَکَۃً أَیْسَرُہُنَّ مُؤْنَۃً۔ (احمد 6/145۔ حاکم 178)",,,16641 16642,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ مُحَمَّدِ بْنِ إبْرَاہِیمَ التَّیْمِیِّ أَنَّ أَبَا حَدْرَدٍ الأَسْلَمِیَّ اسْتَعَانَ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی مَہْرِ امْرَأَۃٍ نَکَحَہَا فَسَأَلَہُ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : کَمْ أَصْدَقْتہَا ؟ فَقَالَ : مِئَتَی دِرْہَمٍ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَوْ کُنْتُمْ تَغْرِفُونَ مِنْ بَطْحَانَ مَا زِدْتُمْ۔ (احمد 3/448۔ طبرانی 884)",,,16642 16643,حَدَّثَنَا عَبْدَۃ بن سلیمان ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ أَبِی جَعْفَرٍ أَنَّ النَّجَاشِیَّ زَوَّجَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أُمَّ حَبِیبَۃَ عَلَی أَرْبَعِ مِئَۃِ دِینَارٍ۔ (ابوداؤد 2100۔ ابن سعد 98),,,16643 16644,حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ سَعْدٍ ، عَنْ عَطَائٍ الْخُرَاسَانِیِّ أَنَّ عُمَرَ تَزَوَّجَ أُمَّ کُلْثُومٍ عَلَی أَرْبَعِینَ أَلْفِ دِرْہَمٍ۔,,,16644 16645,حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ یَزِیدَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی أَنَّ عَبْدَ الرَّحْمَنِ بْنَ عَوْفٍ تَزَوَّجَ امْرَأَۃً عَلَی ثَلاَثِینَ أَلْفًا۔,,,16645 16646,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ أَبِی الْعُمَیْسِ ، عَنِ الْمُغِیرَۃِ بْنِ حَکِیمٍ قَالَ : أَوَّلُ مَنْ سَنَّ الصَّدَاقَ أَرْبَعَ مِئَۃِ دِینَارٍ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ۔",,,16646 16647,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ تَزَوَّجَ شُمیلۃ السُّلمیۃ عَلَی عَشَرَۃِ آلاَفٍ۔,,,16647 16648,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ أَنَّ ابْنَ عُمَرَ کَانَ یُزَوِّجُ الْمَرْأَۃَ مِنْ بَنَاتِہِ عَلَی عَشَرَۃِ آلاَفٍ۔\n\n(ابویوسف 1021)",,,16648 16649,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مَہْدِیٍّ ، عَنْ غَیْلاَنَ ، عَنْ مُطَرِّفٍ أَنَّہُ أَصْدَقَ امْرَأَۃً تَزَوَّجَہَا مِنْ بَنِی عُقَیْلٍ عِشْرِینَ أَلْفًا۔,,,16649 16650,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ أَنَّ عُمَرَ رَخَّصَ أَنْ تُصْدَق الْمَرْأَۃَ أَلْفَیْنِ وَرَخَّصَ عُثْمَانُ فِی أَرْبَعَۃِ آلاَفٍ۔,,,16650 16651,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ کُرَیْبِ بْنِ ہِشَامٍ ، وَکَانَ مِنْ أَصْحَابِ عَبْدِ اللہِ أَنَّہُ تَزَوَّجَ امْرَأَۃً عَلَی أَرْبَعَۃِ آلاَفٍ۔,,,16651 16652,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی ہِلاَلٍ ، عَنِ ابْنِ سِیرِینَ قَالَ : خَطَبَ عَمْرُو بْنُ حُرَیْثٍ إلَی عَدِیِّ بْنِ حَاتِمٍ ابْنَتَہُ فَأَبَی إلاَّ عَلَی حُکْمِہِ فَحَکَّمَ عَدِیٌّ سُنَّۃَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ثَمَانِینَ وَأَرْبَعَ مِئَۃٍ فَبَعَثَ إلَیْہِ عَمْرٌو بِعَشَرَۃِ آلاَفٍ ، فَقَالَ : جَہِّزْہَا۔",,,16652 16653,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنْ مُحَمَّدٍ أَنَّ الْحَسَنَ بْنَ عَلِیٍّ تَزَوَّجَ امْرَأَۃً فَأَرْسَلَ إلَیْہَا مِئَۃَ جَارِیَۃٍ مَعَ کُلِّ جَارِیَۃٍ أَلْفُ دِرْہَمٍ۔,,,16653 16654,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ أَنَّ رَجُلاً تَزَوَّجَ امْرَأَۃً فَأَسَرَّ ذَلِکَ ، فَکَانَ یَخْتَلِفُ إلَیْہَا فِی مَنْزِلِہَا فَرَآہُ جَارٌ لَہَا یَدْخُلُ عَلَیْہَا فَقَذَفَہُ بِہَا فَخَاصَمَہُ إلَی عُمَرَ بْنِ الْخَطَّابِ ، فَقَالَ : یَا أَمِیرَ الْمُؤْمِنِینَ ، ہَذَا کَانَ یَدْخُلُ عَلَی جَارِیَۃٍ وَلاَ أَعْلَمُہُ تَزَوَّجَہَا ، فَقَالَ لَہُ : مَا تَقُولُ ؟ فَقَالَ : تَزَوَّجْت امْرَأَۃً عَلَی شَیْئٍ دُونٍ فَأَخْفَیْتُ ذَلِکَ ، قَالَ : فَمَنْ شَہِدَکُمْ ؟ قَالَ : أَشْہَدْت بَعْضَ أَہْلِہَا ، قَالَ : فَدَرَأَ الْحَدَّ ، عَنْ قَاذِفِہِ وَقَالَ: أَعْلِنُوا ہَذَا النِّکَاحَ وَحَصِّنُوا ہَذِہِ الْفُرُوجَ۔",,,16654 16655,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ حَمَّادِ بْنِ زَیْدٍ ، عَنْ ہِشَامٍ قَالَ کَانَ أَبِی یَقُولُ : لاَ یَصْلُحُ نِکَاحُ السِّرِّ۔",,,16655 16656,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ دَاوُدَ بْنِ قیس ، قَالَ : سَمِعْتُ نَافِعًا مَوْلَی ابْنِ عُمَرَ یَقُولُ : لَیْسَ فِی الإِسْلاَمِ نِکَاحُ السِّرِّ۔",,,16656 16657,حَدَّثَنَا أَبُو نُعَیْمٍ، عَنْ سُفْیَانَ، عَنْ زِیَادِ بْنِ فَیَّاضٍ، عَنْ عَبْدِ اللہِ بْنِ عُتْبَۃَ قَالَ، أَشَرُّ النِّکَاحِ نکاح السِّرُّ۔,,,16657 16658,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ قَالَ : مُرَّ عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِعَرُوسٍ ، فَقَالَ : لَوْ کَانَ مَعَ ہَذَا لَہْوٌ۔ (بخاری 5162۔ حاکم 184)",,,16658 16659,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنِ ابْنِ سِیرِینَ قَالَ : نُبِّئْت أَنَّ عُمَرَ کَانَ إذَا اسْتَمَعَ صَوْتًا أَنْکَرَہُ وَسَأَلَ عَنْہُ ، فَإِنْ قِیلَ عُرْسٌ ، أَوْ خِتَانٌ أَقَرَّہُ۔",,,16659 16660,"حَدَّثَنَا وَکِیع بن الجراح ، عَنْ أُسَامَۃَ بْنِ زَیْدٍ ، عَنْ شَیْخٍ مِنْ بَنِی سَلِمَۃَ ، عَنْ أبی قَتَادَۃَ أَنَّہُ قَالَ لِجَارِیَۃٍ فِی عُرْسٍ تَضْرِبُ بِالدُّفِّ : ارْعَفِی ارْعَفِی۔",,,16660 16661,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ عُبَیْدِ اللہِ ، عَنْ مُحَمَّدِ بْنِ عَمْرِو بْنِ عَطَائٍ ، عَنْ أَبِی سَلَمَۃَ بْنِ عَبْدِ الرَّحْمَنِ قَالَ : لَقَدْ ضُرِبَ لَیْلَۃَ الملک بِالدُّفِّ وَغُنِّیَ عَلَی رَأْسِ عَبْدِ الرَّحْمَنِ بْنِ عَوْفٍ۔",,,16661 16662,"حَدَّثَنَا شَرِیکٌ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَامِرِ بْنِ سَعْدٍ قَالَ : دَخَلْتُ عَلَی أَبِی مَسْعُود وَقَرَظَۃَ بْنِ کَعْبٍ وَعِنْدَہُمَا جَوَارٍ یُغَنِّینَ ، فَقُلْتُ : أَتَفْعَلُونَ ہَذَا وَأَنْتُمْ أَصْحَابُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ قَالَ ، فَقَالَ : إنَّہُ رُخِّصَ لَنَا فِی اللَّہْوِ عِنْدَ الْعُرْسِ۔ (بیہقی 289۔ طبرانی 690)",,,16662 16663,حَدَّثَنَا شَبَابَۃُ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی بَلْجٍ ، عَنْ مُحَمَّدِ بْنِ حَاطِبٍ قَالَ قَالَ رَسُولُ اللہ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَصْلُ مَا بَیْنَ الْحَلاَلِ وَالْحَرَامِ الصَّوْتُ یَعْنِی الضَّرْبَ بِالدُّفِّ۔ (ترمذی 1088۔ احمد 3/418),,,16663 16664,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَمِعْتُ أَبَا إِسْحَاقَ یُحَدِّثُ ، عَنْ عامر بن سعد أَنَّہُ قَالَ : کُنْتُ مَعَ ثَابِتِ بْنِ وَدِیعَۃَ وَقَرَظَۃَ بْنِ کَعْبٍ فِی عُرْسٍ فَسَمِعْت صَوْتَ غِنَائٍ ، فَقُلْتُ : أَلاَ تَسْمَعَانِ ؟ فَقَالاَ : إنَّہُ قَدْ رُخِّصَ لَنَا فِی الْغِنَائِ عِنْدَ الْعُرْسِ وَالْبُکَائِ عَلَی الْمَیِّتِ مِنْ غَیْرِ نِیَاحَۃٍ۔ (حاکم 184۔ طیالسی 1221)",,,16664 16665,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ قَالَ : حدَّثَنَا ابْنُ عَوْنٍ قَالَ : کَانَ فِی آلِ مُحَمَّدٍ مِلاَکٌ فَلَمَّا أَنْ فَرَغُوا وَرَجَعَ مُحَمَّدٌ إلَی مَنْزِلِہِ قَالَ لَہُنَّ : فَأَیْنَ صفاقتکن قَالَ ابْنُ عَوْنٍ : یَعْنِیَ الدُّفَّ۔",,,16665 16666,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ رَجُلٍ قَالَ : دَخَلَ ابْنُ مَسْعُودٍ عُرْسًا فِیہِ مَزَامِیرُ وَلَہْوٌ فَقَعَدَ وَلَمْ یَنْہَ عَنْہُ۔",,,16666 16667,"حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ حین خَتَنَ بَنِیہِ فَدَعَا اللاَّعِبِینَ فَأَعْطَاہُمْ أَرْبَعَۃَ دَرَاہِمَ ، أَوْ قَالَ : ثَلاَثَۃً۔",,,16667 16668,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، عَنْ مَغْرَاء َ العمی ، عَنْ شُرَیْحٍ أَنَّہُ سَمِعَ صَوْتَ دُفٍّ ، فَقَالَ : الْمَلاَئِکَۃُ لاَ یَدْخُلُونَ بَیْتًا فِیہِ دُفٌّ۔",,,16668 16669,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، وَابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ عِمْرَانَ بْنِ مُسلِم ، قَالَ : قَالَ لِی خَیْثَمَۃُ : أما سَمِعْت سُوَیْدًا یَقُولُ : لاَ تَدْخُلُ الْمَلاَئِکَۃُ بَیْتًا فِیہِ دُفٌّ۔",,,16669 16670,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ قَالَ : کَانَ أَصْحَابُ عَبْدِ اللہِ یَسْتَقْبِلُونَ الْجَوَارِیَ فِی الأَزِفَّۃِ مَعَہُنَّ الدُّفُّ فَیَشُقُّونَہَا۔",,,16670 16671,"حدثنا أبو عبد الرحمن بقی بن مخلد ، قَالَ : حدثنا أبو بکر قَالَ : حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ مُغِیرَۃَ ، عَنِ القاسم ، أَنَّ عَبْدَ اللہِ بْنَ جَعْفَرٍ جَمَعَ بَیْنَ ابْنَۃِ عَلِیٍّ وَامْرَأَتِہِ یَعْنِی مِنْ غَیْرِہَا۔",,,16671 16672,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ عِکْرِمَۃَ بْنِ خَالِدٍ أَنَّ عَبْدَ اللہِ بْنَ صَفْوَانَ تَزَوَّجَ امْرَأَۃَ رَجُلٍ مِنْ ثَقِیفٍ وَابْنَتَہُ یَعْنِی مِنْ غَیْرِہَا۔,,,16672 16673,"حَدَّثَنَا ابْنِ عُلَیَّۃَ ، عَنْ أَیُّوبَ : سُئِلَ عَنْ ذَلِکَ مُحَمَّدُ بْنُ سِیرِینَ فَلَمْ یَرَ بِہِ بَأْسًا وَقَالَ : نُبِّئْت أَنْ جبَلَۃ رَجُلٌ کَانَ یَکُونُ بِمِصْرٍ تَزَوَّجَ أُمَّ وَلَدِ رَجُلٍ وَابْنَتَہُ یَعْنِی مِنْ غَیْرِہَا۔",,,16673 16674,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ أَیُّوبَ قَالَ : نُبِّئْت ، عَنْ سَعْدِ بْنِ قَرْحَاء رَجُلٌ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ جَمَعَ بَیْنَ امْرَأَۃِ رَجُلٍ وَابْنَتِہِ مِنْ غَیْرِہَا۔",,,16674 16675,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ عَاصِمٍ ، عَنِ الشَّعْبِیِّ قَالَ : لاَ بَأْسَ أَنْ یَجْمَعَ الرَّجُلُ بَیْنَ أُمِّ وَلَدِ رَجُلٍ وَابْنَتِہِ یَعْنِی مِنْ غَیْرِہَا۔",,,16675 16676,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ قَالَ : لاَ بَأْسَ أَنْ یَجْمَعَ الرَّجُلُ بَیْنَ امْرَأَۃِ الرَّجُلِ وَابْنَتِہِ یَعْنِی مِنْ غَیْرِہَا۔",,,16676 16677,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ قَالَ : لاَ بَأْسَ أَنْ یَجْمَعَ الرَّجُلُ بَیْنَ ابْنَۃِ الرَّجُلِ وَامْرَأَۃِ أَبِیہَا ، وَإِنَّ الْحَسَنَ کَرِہَہُ۔",,,16677 16678,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ سَلَمَۃَ بْنِ عَلْقَمَۃَ قَالَ : سُئِلَ الْحَسَنُ ، عَنْ ذَلِکَ فَکَرِہَہُ ، فَقَالَ لَہُ بَعْضُہم : یَا أَبَا سَعِیدٍ ، ہَلْ تَرَی بَیْنَہُمَا شَیْئًا ؟ فنظر ، فَقَالَ : لاَ أَرَی بَیْنَہُمَا شَیْئًا",,,16678 16679,"حَدَّثَنَا شَبَابَۃُ ، عَنْ لَیْثٍ بن سَعْدٍ ، عَنْ یَزِیدَ بْنِ أَبِی حَبِیبٍ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ أَنَّہُ کَانَ یَقُولُ : لاَ بَأْسَ أَنْ یَجْمَعَ الرَّجُلُ بَیْنَ الْمَرْأَۃِ وَبَیْنِ امْرَأَۃِ أَبِیہَا۔",,,16679 16680,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنِ ابْنِ عَوْنٍ قَالَ : سَأَلْتُ مُحَمَّدًا ، فَقَالَ لاَ أَعْلَمُ بِہِ بَأْسًا۔",,,16680 16681,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ قَالَ : سُئِلَ الْحَسَنُ ، عَنِ الرَّجُلِ یَتَزَوَّجُ امْرَأَۃَ الرَّجُلِ وَابْنَتَہُ فَکَرِہَ ذَلِکَ یَعْنِی مِنْ غَیْرِہَا۔",,,16681 16682,حَدَّثَنَا شَبَابَۃُ ، عَنْ شُعْبَۃَ ، عَنْ فُضَیْلٍ ، عَنِ أَبِی حَرِیز ، عَنْ عِکْرِمَۃَ أَنَّہُ کَانَ یَکْرَہُ أَنْ یَجْمَعَ الرَّجُلُ بَیْنَ الْمَرْأَۃِ وَامْرَأَۃِ أَبِیہَا۔,,,16682 16683,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ مُحَمَّدِ بْنِ عُثَِیم ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ البیلَمَانِیِّ ، عَنْ أَبِیہِ ، عَنِ ابْنِ عُمَرَ قَالَ : سُئِلَ نَبِیُّ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَا یَجُوزُ فِی الرَّضَاعِ مِنَ الشُّہُودِ ؟ قَالَ رَجُلٌ وَامْرَأَۃٌ۔\n\n(احمد 2/109۔ بیہقی 464)",,,16683 16684,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ عُمَرَ بْنِ سَعِیدِ بْنِ أَبِی حُسَیْنٍ قَالَ : حدَّثَنِی عَبْدُ اللہِ بْنُ أَبِی مُلَیْکَۃَ ، قَالَ: حَدَّثَنِی عُقْبَۃُ بْنُ الْحَارِثِ قَالَ : تَزَوَّجْت ابْنَۃَ أَبِی إہَابٍ التّمَِیْمِیِّ فَلَمَّا کَانَتْ صَبِیحَۃُ مِلْکِہَا جَائَتْ مَوْلاَۃٌ لأَہْلِ مَکَّۃَ ، فَقَالَتْ : إنِّی أَرْضَعْتُکُمَا فَرَکِبَ عُقْبَۃُ إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ بِالْمَدِینَۃِ فَذَکَرَ ذَلِکَ لَہُ وَقَدْ سَأَلْت أَہْلَ الْجَارِیَۃِ فَأَنْکَرُوا ، فَقَالَ : کَیْفَ وَقَدْ قِیلَ فَفَارَقَہَا وَنَکَحَتْ غَیْرَہُ۔\n\n(بخاری 88۔ ابوداؤد 3598)",,,16684 16685,حَدَّثَنَا عَبدَۃ بن سلیمان ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ جَابِرِ بْنِ زَیْدٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ إذَا کَانَتِ الْمَرْأَۃُ مَرْضِیَّۃً جَازَتْ شَہَادَتُہَا فِی الرَّضَاعَۃِ وَیُؤْخَذُ بِیَمِینِہَا۔,,,16685 16686,حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عِکْرِمَۃَ بْنِ خَالِدٍ أَنَّ عُمَرَ رَدَّ شَہَادَۃَ امْرَأَۃٍ فِی رِضَاعٍ۔,,,16686 16687,"حَدَّثَنَا حَفْصٌ ، عَنْ حلام بْنِ صَالِحٍ ، عَنْ بُکَیرِ بْنِ فَائِدٍ أَنَّ امْرَأَۃً جَاء َتْ إلَی رَجُلٍ تَزَوَّجَ امْرَأَۃً فَزَعَمَتْ أَنَّہَا قَدْ أَرْضَعَتْہُمَا ، فَأَتَی عَلِیًّا فَسَأَلَہُ ، فَقَالَ : ہِیَ امْرَأَتُک لَیْسَ أَحَدٌ یُحَرِّمُہَا عَلَیْک ، وَإِنْ تَنَزَّہْتَ فَہُوَ أَفْضَلُ ، وَسَأَلَ ابْنَ عَبَّاسٍ ، فَقَالَ مِثْلَ ذَلِکَ۔",,,16687 16688,"، عَنْ مَعْنِ بْنِ عِیسَی ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ قَالَ : نُبِّئْت أَنَّ امْرَأَۃً فِی زَمَانِ عُثْمَانَ جَاء َتْ إلَی أَہْلِ بَیْتٍ ، فَقَالَتْ : قَدْ أَرْضَعْتُکُمْ فَفَرَّقَ بَیْنَہُمَا۔",,,16688 16689,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ قَالَ : کَانَتِ الْقُضَاۃُ یُفَرِّقُونَ بَیْنَ الرَّجُلِ وَامْرَأَتِہِ بِشَہَادَۃِ الْمَرْأَۃِ فِی الرَّضَاعِ۔",,,16689 16690,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی، عَنِ ابْنِ أَبِی ذِئْبٍ، عَنِ الزُّہْرِیِّ قَالَ: شَہَادَۃُ الْمَرْأَۃِ الْعَاقِلَۃِ تَجُوزُ فِی الرَّضَاعَۃِ۔",,,16690 16691,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مَنْصُورٍ ، عَنْ طَلْحَۃَ ، عَنْ خَیْثَمَۃَ قَالَ : زَوَّجَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجُلاً مِنَ الْمُسْلِمِینَ لَمْ یَکُنْ لَہُ شَیْئٌ فَأَمَرَ بِامْرَأَتِہِ أَنْ تَدْخُلَ عَلَیْہِ فَصَارَ ذَلِکَ الرَّجُلُ بَعْدُ مِنْ أَشْرَافِ الْمُسْلِمِینَ۔ (ابوداؤد 2121۔ ابن ماجہ 1992)",,,16691 16692,"حَدَّثَنَا أَبُو بَکْرٍ ، عَنْ أَبِی مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنِ الرُّکَیْنِ ، عَنْ أَبِیہِ قَالَ : تَزَوَّجَ فُلاَنُ بْنُ ہَرِمٍ لَیْلَی بِنْتَ الْعَجْمَائِ فِی زَمَنِ عُمَرَ فَدَخَلَ بِہَا وَلَمْ یُعْطِہَا شَیْئًا مِنْ صَدَاقِہَا۔",,,16692 16693,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ کُرَیْبِ بْنِ ہِشَامٍ ، وَکَانَ مِنْ أَصْحَابِ عَبْدِ اللہِ أَنَّہُ زَوَّجَ امْرَأَۃً عَلَی أَرْبَعَۃِ آلاَفٍ ثُمَّ دَخَلَ بِہَا قَبْلَ أَنْ یُعْطِیَہَا شَیْئًا مِنْ صَدَاقِہَا۔,,,16693 16694,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : اخْتَلَفَ فِیہِ أَہْلُ الْمَدِینَۃِ فَمِنْہُمْ مَنْ کَرِہَہُ وَمِنْہُمْ مَنْ رَخَّصَ فِیہِ وَأَیُّ ذَلِکَ فُعِلَ فَلاَ بَأْسَ۔",,,16694 16695,"حَدَّثَنَا عَبْدَۃُ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : إذَا کَانَتْ بِہِ رَاضِیَۃٌ لَمْ نَرَ بِذَلِکَ بَأْسًا۔",,,16695 16696,"حَدَّثَنَا حَفْصٌ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ قَالَ : لاَ بَأْسَ بِہِ۔",,,16696 16697,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ الْمُبَارَکِ ، عَنْ یَحْیَی ، عَنْ عِکْرِمَۃَ ؛ أَنَّ عَلِیًّا لَمَّا أَرَادَ أَنْ یَبْنِیَ بِفَاطِمَۃَ قَالَ لَہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : قدِّمْ شَیْئًا۔",,,16697 16698,"حَدَّثَنَا ہُشَیْمُ ، عَنْ أَبِی حَمْزَۃَ قَالَ : شَہِدْت ابْنَ عَبَّاسٍ وَسَأَلَہُ رَجُلٌ أَنَّہُ تَزَوَّجَ امْرَأَۃً فَعَسِرَ ، عَنْ صَدَاقِہَا ، فَقَالَ لَہُ ابْنُ عَبَّاسٍ : إن لَمْ تَجِدْ إلاَّ نَعْلَک فَأَعْطِہَا إیَّاہَا ثُمَّ ادْخُلْ بِہَا",,,16698 16699,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ خُصَیْفٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ قَالَ : یُعْطِیہَا وَلَوْ خِمَارًا۔",,,16699 16700,"حَدَّثَنَا حَفْصٌ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ قَالَ : کَانَ یَقُولُ : یُلْقِی عَلَیْہَا وَلَوْ ثَوْبًا ثُمَّ یَدْخُلُ بِہَا۔",,,16700 16701,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ وَعَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ أَنَّہُمَا کَرِہَا أَنْ یَدْخُلَ بِہَا وَلَمْ یُعْطِہَا مِنْ صَدَاقِہَا شَیْئًا۔,,,16701 16702,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنِ الضَّحَّاکِ بْنِ عُثْمَانَ قَالَ : سُئِلَ الزُّہْرِیُّ ، عَنْ رَجُلٍ تَزَوَّجَ امْرَأَۃً وَہُوَ مَلِیئٌ بِصَدَاقِہَا أَیَدْخُلُ بِہَا وَلَمْ یُعْطِہَا شَیْئًا ؟ قَالَ : مَضَتِ السُّنَّۃُ أَنْ لاَ یَدْخُلَ بِہَا حَتَّی یُعْطِیَہَا ولو شَیْئًا۔",,,16702 16703,"حَدَّثَنَا عَبدَۃ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ قَالَ : یُہْدِی شَیْئًا۔",,,16703 16704,"حَدَّثَنَا شبابۃ قَالَ : حدَّثَنَا ہِشَام بْنِ الغَاز ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ قَالَ : لاَ یَحِلُّ لِمُسْلِمٍ أَنْ یَدْخُلَ عَلَی امْرَأَۃٍ حَتَّی یَقْدُمَ إلیہا ما قَلَّ ، أَوْ کَثُرَ۔",,,16704 16705,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ عِکْرِمَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ لِعَلِیٍّ : أَعْطِہَا دِرْعَک الْحُطَمِیَّۃَ۔ (عبدالرزاق 10429۔ احمد 1/80)",,,16705 16706,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ یَزِیدَ بْنِ یَزِیدَ بْنِ جَابِرٍ ، عَنْ إسْمَاعِیلَ بْنِ عُبَیْدِ اللہِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ غَنْمٍ ، عَنْ عُمَرَ ، قَالَ : لَہَا شَرْطُہَا ، قَالَ رَجُلٌ : إذًا یُطَلِّقْنَنَا ، فَقَالَ عُمَرُ : إنَّ مَقَاطِعَ الْحُقُوقِ عِنْدَ الشَّرْطِ۔",,,16706 16707,"حَدَّثَنَا وَکِیعٌ ، عَنْ سَعِیدِ بْنِ عَبْدِ الْعَزِیزِ ، عَنْ إسْمَاعِیلَ بْنِ عُبَیْدِ اللہِ ، عَنِ ابْنِ غَنْمٍ عن عمر ، قَالَ : لَہَا شَرْطُہَا۔",,,16707 16708,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ الْحَمِیدِ بْنِ جَعْفَرٍ ، عَنْ یَزِیدَ بْنِ أَبِی حَبِیبٍ ، عَنْ أَبِی الْخَیْرِ ، عَنْ عُقْبَۃَ بْنِ عَامِرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ أَحَقَّ الشَّرْط أَنْ یُوَفَّی بِہِ مَا اسْتَحْلَلْتُمْ بِہِ الْفُرُوجَ۔\n\n(بخاری 5151۔ ابوداؤد 2132)",,,16708 16709,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ أَبِی عُبَیْدَۃَ أَنَّ مُعَاوِیَۃَ سَأَلَ عَنْہَا عَمْرَو بْنَ الْعَاصِ ، فَقَالَ : لَہَا شَرْطُہَا۔",,,16709 16710,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ، عَنْ عَمْرِو ، عَنْ أَبِی الشَّعْثَائِ ، قَالَ: إذَا شَرَطَ لَہَا دَارَہَا فَہُوَ بِمَا یَسْتَحِلُّ مِنْ فَرْجِہَا۔",,,16710 16711,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَبِی حَیَّانَ قَالَ : حدَّثَنَا أَبُو الزِّنَادِ أَنَّ امْرَأَۃً خَاصَمَتْ زَوْجَہَا إلَی عُمَرَ بْنِ عَبْدِ الْعَزِیزِ قَدْ شَرَطَ لَہَا دَارَہَا حِینَ تَزَوَّجَہَا فَأَرَادَ أَنْ یُخْرِجَہَا مِنْہَا فَقَضَی عُمَرُ أَنَّ لَہَا دَارَہَا ، لاَ یُخْرِجُہَا مِنْہَا وَقَالَ : وَالَّذِی نَفْسُ عُمَرَ بِیَدِہِ لَوِ اسْتَحْلَلْت فَرْجَہَا بِزِنَۃِ أُحُدٍ ذَہَبًا لأَخَذَتُ مَا بِہِ لَہَا۔",,,16711 16712,"حَدَّثَنَا وَکِیعٌ ، عَنْ شَرِیکٍ ، عَنْ عَاصِمٍ ، عَنْ عِیسَی بْنِ حِطَّانَ ، عَنْ مُجَاہِدٍ ، وَسَعِیدِ بْنِ جُبَیْرٍ قَالاَ : یُخْرِجُہَا ، فَقَالَ یَحْیَی بْنُ الْجَزَّارِ : فَبِأَیِّ شَیْئٍ یَسْتَحِلُّ الْفَرْجَ فَبِأَیِّ کَذَا وَکَذَا فَرَجَعَا ؟۔",,,16712 16713,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْمِنْہَالِ ، عَنْ عَبَّادِ بْنِ عَبْدِ اللہِ ، عَنْ عَلِیٍّ بن أبی طالب فِی الَّتِی شُرِطَ لَہَا دَارُہَا قَالَ : شَرْطُ اللہِ قَبْلَ شَرْطِہَا۔",,,16713 16714,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنِ الْحَارِثِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ أَبِی ذُبَابٍ ، عَنْ مُسْلِمِ بْنِ یَسَارٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ فِی الرَّجُلِ یَتَزَوَّجُ الْمَرْأَۃَ وَیَشْتَرِطُ لَہَا دَارَہَا قَالَ : یُخْرِجُہَا إِنْ شَاء َ۔",,,16714 16715,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ أَشْعَثَ ، عَنْ مُحَمَّدِ بْنِ سِیرِینَ ، عَنْ شُرَیْحٍ أَنَّ امْرَأَۃً جَاء َتْ ، فَقَالَتْ : شَرَطَ لَہَا دَارَہَا ، فَقَالَ : شَرْطُ اللہِ قَبْلَ شَرْطِہَا",,,16715 16716,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ وَعَنْ یُونُسَ ، عَنِ الْحَسَنِ قَالاَ : یُخْرِجُہَا إِنْ شَاء َ۔",,,16716 16717,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ قَالَ : یَذْہَبُ بِہَا حَیْثُ شَاء َ وَالشَّرْطُ بَاطِلٌ۔",,,16717 16718,"حَدَّثَنَا مُعَاذٌ ، عَنْ أَشْعَثَ ، عَنْ مُحَمَّدٍ فِی رَجُلٍ تَزَوَّجَ امْرَأَۃً وَشَرَطَ لَہَا دَارَہَا قَالَ : لاَ شَرْطَ لَہَا۔",,,16718 16719,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ حَبِیبِ بْنِ جَُرَیٍّ ، قَالَ : سَمِعْتُ طَاوُوسًا وَسُئِلَ عَنِ الرَّجُلِ یَخْطُبُ الْمَرْأَۃَ فَتَشْرُطُ عَلَیْہِ أَشْیَاء َ ، قَالَ : لَیْسَ الشَّرْطُ بِشَیْئٍ۔",,,16719 16720,حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ أَنَّ رَجُلاً زَوَّجَ ابْنَتَہُ عَلَی أَلْفِ دِینَارٍ وَشَرَطَ لِنَفْسِہِ أَلْفَ دِینَارٍ فَقَضَی عُمَرُ بْنُ عَبْدِ الْعَزِیزِ لِلْمَرْأَۃِ بِأَلْفَیْنِ دُونَ الأَبِ۔,,,16720 16721,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ عِکْرِمَۃَ قَالَ : إِنْ کَانَ ہُوَ الَّذِی یُنْکَحُ فَہُوَ لَہُ۔",,,16721 16722,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ مُثَنَّی ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ عُرْوَۃَ وَسَعِیدٍ قَالاَ : أَیُّمَا امْرَأَۃٍ أُنْکِحَتْ عَلَی صَدَاقٍ ، أَوْ عِدَۃٍِ لأَہْلِہَا کَانَ قَبْلَ عِصْمَۃِ النِّکَاحِ فَہُوَ لَہَا ، وَمَا کَانَ مِنْ حِبَائٍِ لأَہْلِہَا فَہُوَ لَہُمْ۔",,,16722 16723,حَدَّثَنَا شَرِیکٌ، عَنْ أَبِی إِسحاق أَنَّ مَسْرُوقًا زَوَّجَ ابْنَتَہُ فَاشْتَرَطَ عَلَی زَوْجِہَا عَشَرَۃَ آلاَفٍ سِوَی الْمَہْرِ۔,,,16723 16724,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، قَالَ : سَمِعْتُ الزُّہْرِیَّ یَقُولُ : لِلْمَرْأَۃِ مَا اسْتُحِلَّ بِہِ فَرْجُہَا۔",,,16724 16725,"، عَنِ الضَّحَّاکِ بْنِ الْمَخْلَدِ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ قَالَ : مَا اشْتَرَطَ من حِبَائٍِ لأَخِیہَا ، أَوْ أَبِیہَا فَہِی أَحَقُّ بِہِ إِنْ تَکَلَّمَتْ فِیہِ۔",,,16725 16726,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ أَنَّ رَافِعَ بْنَ خَدِیجٍ کَانَتْ تَحْتَہُ بِنْتُ مُحَمَّدِ بْنِ مَسْلَمَۃَ فَکَرِہَ مِنْ أَمْرِہَا إمَّا کِبَرًا ، أَوْ غَیْرَہُ فَأَرَادَ أَنْ یُطَلِّقَہَا ، فَقَالَتْ : لاَ تُطَلِّقْنِی وَاقْسِمْ لِی مَا شِئْت فَجَرَتِ السُّنَّۃُ بِذَلِکَ فَنَزَلَتْ : {وَإِنِ امْرَأَۃٌ خَافَتْ مِنْ بَعْلِہَا نُشُوزًا أَوْ إعْرَاضًا}۔(طبرانی 309۔ حاکم 308)",,,16726 16727,"حَدَّثَنَا عَبْدَۃُ ، عَنْ ہِشَامٍ عن أبیہ ، عَنْ عَائِشَۃَ {وَإِنِ امْرَأَۃٌ خَافَتْ مِنْ بَعْلِہَا نُشُوزًا أَوْ إعْرَاضًا} الآیَۃَ قَالَتْ : نَزَلَتْ فِی الْمَرْأَۃِ تَکُونُ عِنْدَ الرَّجُلِ فَتَطُولُ صُحْبَتُہَا فَیُرِیدُ أَنْ یُطَلِّقَہَا فَتَقُولُ : لاَ تُطَلِّقْنِی وَأَمْسِکْنِی وَأَنْتَ فِی حِلٍّ مِنِّی فَنَزَلَتْ ہَذِہِ الآیَۃُ فِیہِمَا۔ (بخاری 2450۔ مسلم 2316)",,,16727 16728,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَرْبِ بْنِ شَدَّادٍ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ قَالَ : حدَّثَنَا أَبُو النَّجَاشِیِّ مَوْلَی رَافِعِ بْنِ خَدِیجٍ : أَنَّ رَافِعَ بْنِ خَدِیجٍ تَزَوَّجَ امْرَأَۃً عَلَی امْرَأَتِہِ ، فَقَالَ لاِمْرَأَتِہِ الأُولَی : إِنْ شِئْتِ أَنْ أُمْسِکَکِ وَلاَ أَقْسِمُ لَکَ ، وَإِنْ شِئْتِ طَلَّقْتُکِ ، فَاخْتَارَتْ أَنْ یُمْسِکَہَا وَلاَ یُطَلِّقَہَا۔",,,16728 16729,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَرْبِ بْنِ شَدَّادٍ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ مُحَمَّدِ بْنِ إبْرَاہِیمَ بْنِ الْحَارِثِ أَنَّ بِنْتَ عَبْدِ اللہِ بْنِ جَعْفَرٍ کَانَتْ تَحْتَ رَجُلٍ مِنْ قُرَیْشٍ فَخَیَّرَہَا بَیْنَ أَنْ یُمْسِکَہَا وَلاَ یَقْسِمُ لَہَا وَبَیْنَ أَنْ یُطَلِّقَہَا فَاخْتَارَتْ أَنْ یُمْسِکَہَا وَلاَ یُطَلِّقَہَا۔,,,16729 16730,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثقفی ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ ، عَنْ عبیدۃ قَالَ : سَأَلْتُہ ، عَنْ ہَذِہِ الآیَۃِ : {وَإِنِ امْرَأَۃ خَافَتْ مِنْ بَعْلِہَا نُشُوزًا أَوْ إعْرَاضًا} قَالَ : ہُوَ رَجُلٌ تَکُونُ لَہُ الْمَرْأَۃُ قَدْ خَلاَ مِنْ سَہْمِہَا فَیُصَالِحُہَا مِنْ حَقِّہَا عَلَی شَیْئٍ فَہُوَ لَہُ مَا رَضِیَتْ فَإِذَا کَرِہَتْ فَلَہُ أَنْ یَعْدِلَ عَلَیْہَا ، أَوْ یُرْضِیَہَا من حَقِّہَا ، أَوْ یُطَلِّقَہَا۔",,,16730 16731,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ سِمَاکٍ ، عَنْ خَالِدِ بْنِ عَرْعَرَۃَ ، عَنْ عَلِیٍّ قَالَ : أَتَاہُ رَجُلٌ یَسْتَفْتِیہِ فِی {امْرَأَۃ خَافَتْ مِنْ بَعْلِہَا نُشُوزًا أَوْ إعْرَاضًا} ، فَقَالَ : ہِیَ الْمَرْأَۃُ تَکُونُ عِنْدَ الرَّجُلِ فَتَنبو عَیْنَاہُ مِنْ دَمَامَتہَا ، أَوْ فَقْرِہَا ، أَوْ سُوئِ خُلُقِہَا فَتَکْرَہُ فِرَاقَہُ فَإِنْ وَضَعَتْ لَہُ مِنْ مہرہا شَیْئًا حَلَّتْ لَہُ ، وَإِنْ جَعَلَتْ مِنْ أَیَّامِہَا شَیْئًا فَلاَ حَرَجَ۔",,,16731 16732,حَدَّثَنَا ابْنُ نُمَیْرٍ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ، عَنْ أَبِیہِ أَنَّ سَوْدَۃَ لَمَّا أَسَنَّتْ وَہَبَتْ یَوْمَہَا لِعَائِشَۃَ حَتَّی لَقِیَتِ اللَّہَ۔,,,16732 16733,حَدَّثَنَا عُقْبَۃُ بْنُ خَالِدٍ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ بِمِثْلِہِ۔,,,16733 16734,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنِ أَبِی رَزِینٍ فِی قولہ تعالی : {تُرْجِی مَنْ تَشَائُ مِنْہُنَّ وَتُؤْوِی إلَیْک مَنْ تَشَائُ} فَکَانَ مِمَّنْ آوَی عَائِشَۃُ وَأُمُّ سَلَمَۃَ وَزَیْنَبُ وَحَفْصَۃُ ، فَکَانَ قسمتہن مِنْ نَفْسِہِ وَمَالِہِ فیہن سَوَائً ، وَکَانَ مِمَّنْ أَرْجَی سَوْدَۃُ وَجُوَیْرِیَۃُ وَأُمُّ حَبِیبَۃَ وَمَیْمُونَۃُ وَصْفِیَّۃُ ، فَکَانَ یَقْسِمُ لَہُنَّ مَا شَاء َ ، وَکَانَ أَرَادَ أَنْ یُفَارِقَہُنَّ فَقُلْنَ لَہُ : اقْسِمْ لَنَا مِنْ نَفْسِکَ مَا شِئْت وَدَعْنَا نَکُونُ عَلَی حَالِنَا۔ (ابن جریر 25)",,,16734 16735,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ عَطَائِ بْنِ السَّائِبِ أَنَّ امْرَأَۃً مَلَکَتْ مِنْ زَوْجِہَا قِیمَۃَ سَبْعَۃ دَرَاہِمِ فَسُئِلَ مَیْسَرَۃُ ، عَنْ ذَلِکَ ، فَقَالَ : حرُمَتْ عَلَیْہِ وَلاَ أَدْرِی مِنْ أَیْنَ تَحِلُّ لَہُ ؟ فَلَقِیت الشَّعْبِیَّ فَسَأَلْتُہُ ، فَقَالَ : الْقَ أَبَا بَکْرِ بْنَ أَبِی مُوسَی فَاسْأَلْہُ وَہُوَ یَوْمَئِذٍ قَاضٍ فَأَتَیْتہ فَسَأَلْتُہُ ، فَقَالَ : إذَا لَمْ تَسْتَطِعْ شَیْئًا فَدَعْہُ إلَی مَا تَسْتَطِیعُ فَأَتَیْت الشَّعْبِیَّ فَذَکَرْت ذَلِکَ لَہُ فَضَحِکَ وَقَالَ : اذْہَبْ إلَی عُبَیْدِ اللہِ بْنِ عَبْدِ اللہِ بْنِ عُتْبَۃَ فَأَتَیْتہ فَسَأَلْتُہُ ، فَقَالَ ، حَرُمَتْ عَلَیْہِ ، فَقُلْتُ ، مِنْ أَیْنَ تَحِلُّ لَہُ ؟ فقَالَ : تَہَبُ ، أَوْ تُعْتِقُ ، أَوْ تَبِیعُ فَرَجَعْت إلَی الشَّعْبِیِّ فَسَأَلْتُہُ ، فَقَالَ : ارْجِعْ إلَیْہِ فَاسْأَلْہُ أَتَعْتَدُّ مِنْہُ ؟ فَأَتَیْتہ ، فَقَالَ : لاَ ، إنَّمَا ہُوَ مَاؤُہُ فَرَجَعْت إلَی الشَّعْبِیِّ فَأَخْبَرْتہ ، فَقَالَ : طَابَقَ الْفَتْوَی فَأَتَیْت ابْنَ مَعقِلٍ فَسَأَلْتُہُ ، فَقَالَ عَبْدُ السَّلاَمِ : فَلَمْ أَحْفَظْ مَا قَالَ فَأَخْبَرَنِی عَمَّارُ بْنُ رُزَیْقٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنِ ابْنِ مَعْقِلٍ قَالَ : یَسْتَقْبِلاَنِ لِلنِّکَاحِ۔",,,16735 16736,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ قَالَ سَأَلْتُ مَیْسَرَۃَ ، عَنِ امْرَأَۃٍ وَرِثَتْ مِنْ زَوْجِہَا شَیْئًا قَالَ : حَرُمَتْ عَلَیْہِ۔",,,16736 16737,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ فِی امْرَأَۃٍ مَلَکَتْ مِنْ زَوْجِہَا شَیْئًا فقَالَ : حرُمَتْ عَلَیْہِ إلاَّ أَنْ تُعْتِقَہُ سَاعَۃَ تَمْلِکُہُ۔",,,16737 16738,حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ أَنَّ عُبَیْدَ اللہِ بْنَ عَبْدِ اللہِ بْنِ عُتْبَۃَ قَالَہُ۔,,,16738 16739,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ أَنَّہُ قَالَ : حَرُمَتْ عَلَیْہِ۔",,,16739 16740,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یونس ، عَنِ الْحَسَنِ قَالَ : قد حرُمَتْ عَلَیْہِ فَلْیَسْتَأْنِفْ نِکَاحَہَا إِنْ أَرَادَہَا۔",,,16740 16741,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ حَجَّاجٍ قَالَ : وَقَالَ ذَلِکَ الشَّعْبِیُّ۔",,,16741 16742,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنْ عَبْدِ رَبِّہِ ، عَنْ طَاوُوسٍ أَنَّہُ سُئِلَ عَنِ امْرَأَۃٍ وَقَعَ لَہَا فِی زَوْجِہَا شِرْکٌ فَأَعْتَقَتْہُ سَاعَۃَ مَلَکَتْہُ ، فَقَالَ : لَوْ کَانَ قَدر ذُبَابٍ فَرِّقَ بَیْنَہُمَا۔",,,16742 16743,"حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ قَالَ : حرُمَتْ عَلَیْہِ۔",,,16743 16744,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ وَحَمَّادًا ، عَنِ الْمَرْأَۃِ تَرِثُ مِنْ زَوْجِہَا سَہْمًا قَالاَ : حرُمَتْ عَلَیْہِ ، وَإِنْ تَزَوَّجَہَا فَإِنَّہَا عِنْدَہُ عَلَی ثَلاَثِ تَطْلِیقَاتٍ۔",,,16744 16745,حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ قَالَ إِنْ أُعْتِقَ بعد تَزَوَّجَہَا فَإِنَّہَا عِنْدَہُ عَلَی ثَلاَثِ تَطْلِیقَاتٍ لَمْ تَکُنْ فرقتہما طَلاَقًا۔,,,16745 16746,"حَدَّثَنَا إِسْحَاقَ بْنِ مَنْصُورٍ، عَنْ شَرِیکٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ، عَنْ مَیْسَرَۃَ، عَنْ عَلِیٍّ قَالَ: حرُمَتْ عَلَیْہِ۔",,,16746 16747,"حَدَّثَنَا الثَّقَفِیُّ، عَنْ خَالِدٍ، عَنْ مُحَمَّدٍ فِی الْمَرْأَۃِ تَمْلِکُ زَوْجَہَا قَالَ: إِنْ أَعْتَقَتْہُ مَکَانَہَا فَہُمَا عَلَی نِکَاحِہِمَا۔",,,16747 16748,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ قَالَ : إذَا کَانَ لِلْمَمْلُوکِ امْرَأَۃٌ حرۃ فَمَاتَ مَوْلَی الْمَمْلُوکِ فَوَرِثَتِ امْرَأَتُہُ نَصِیبًا مِنْہُ فَإِنْ أَعْتَقَتْہُ مَکَانَہَا فَہُمَا عَلَی نِکَاحِہِمَا الأَوَّلِ ، وَإِنْ لَمْ تُعْتِقْہُ حَرُمَتْ عَلَیْہِ۔",,,16748 16749,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ خَالِدِ بْنِ کَثِیرٍ ، عَنِ الضَّحَّاکِ ، عَنْ عَلِیٍّ قَالَ : یُؤَجَّلُ سَنَۃً فَإِنْ وَصَلَ ، وَإِلاَّ فُرِّقَ بَیْنَہُمَا فَالْتَمَسَا مِنْ فَضْلِ اللہِ یَعْنِی الْعِنِّینَ۔",,,16749 16750,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الرُّکَیْنِ ، عَنْ أَبِیہِ وَحُصَیْنُ بْنُ قَبِیصَۃَ ، عَنْ عَبْدِ اللہِ أَنَّہُ قَالَ : یُؤَجَّلُ الْعِنِّینُ سَنَۃً فَإِنْ جَامَعَ ، وَإِلاَّ فُرِّقَ بَیْنَہُمَا۔",,,16750 16751,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الرُّکَیْنِ ، عَنْ أَبِی حَنْظَلَۃَ النعمان ، عَنِ الْمُغِیرَۃِ بْنِ شُعْبَۃَ أَنَّہُ أَجَّلَ الْعِنِّینَ سَنَۃً۔,,,16751 16752,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، عَنْ عُمَرَ ، قَالَ : یُؤَجَّلُ الْعِنِّینُ سَنَۃً ، فَإِنْ وَصَلَ إلَیْہَا ، وَإِلاَّ فُرِّقَ بَیْنَہُمَا۔",,,16752 16753,حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُحَمَّدِ بْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ أَنَّ عُمَرَ بْنَ الْخَطَّابِ کَتَبَ إلَی شُرَیْحٍ أَنْ یُؤَجِّلَ الْعِنِّینِ سَنَۃً مِنْ یَوْمِ یُرْفَعُ إلیہ۔,,,16753 16754,حَدَّثَنَا ہُشَیْمٌ ، عَنِ الْمُغِیرَۃِ ، عَنِ الشَّعْبِیِّ أَنَّ الْحَارِثَ بْنَ عَبْدِ اللہِ بْنِ أَبِی رَبِیعَۃَ أَجَّلَ رَجُلاً عَشَرَۃَ أَشْہُرٍ لَمْ یَصِلْ إلَی أَہْلِہِ۔,,,16754 16755,"حَدَّثَنَا جَرِیرٌ عَنْ مَنْصُورٍ عَنْ إبْرَاہِیمَ قَالَ: إذَا لَمْ یَصِلَ الرَّجُلُ إلَی امْرَأَتِہِ أُجِّلَ سَنَۃً أَو عَشَرَۃَ أَشْہُرٍ۔",,,16755 16756,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ وَعَنْ الْمُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالاَ : یُؤَجَّلُ الْعِنِّینُ مِنْ یَوْمِ یُرْفَعُ إلَی السُّلْطَانِ قَالَ یُونُسُ ، عَنِ الْحَسَنِ : یُؤَجَّلُ سَنَۃً وَقَالَ مُغِیرَۃُ ، عَنْ إبْرَاہِیمَ : لاَ أَحْفَظُ الْوَقْتَ وَلَکِنَّہُ یُؤَجَّلُ مِنْ یَوْمِ یُرْفَعُ إلَی السُّلْطَانِ۔",,,16756 16757,"حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ الشعبی أَنَّہُ کَانَ یَقُولُ بِقَوْلِ أَصْحَابِ مُحَمَّدٍ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : یُؤَجَّلُ الْعِنِّینُ سَنَۃً۔",,,16757 16758,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ قَالَ : یُؤَجَّلُ الْعِنِّینُ سَنَۃً فَإِنْ وَصَلَ إلَیْہَا ، وَإِلاَّ فُرِّقَ بَیْنَہُمَا۔",,,16758 16759,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ قَالَ : یَسْتَقْبِلُ بِہَا مِنْ یَوْمِ تُخَاصِمُہُ سَنَۃً۔",,,16759 16760,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ قَتَادَۃَ ، عَنِ سعید بْنِ الْمُسَیَّبِ قَالَ : یُؤَجَّلُ الْعِنِّینُ وَالَّذِی یُؤْخَذُ ، عَنِ امْرَأَتِہِ سَنَۃً۔",,,16760 16761,"حَدَّثَنَا حَفْصٌ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ قَالَ : یُؤَجَّلُ الْعِنِّینُ سَنَۃً فَإِنْ وَصَلَ إلَیْہَا ، وَإِلاَّ فُرِّقَ بَیْنَہُمَا۔",,,16761 16762,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ بَعْضِ أَشْیَاخِہِمْ أَنَّ أَبَا حَلِیمَۃَ مُعَاذًا الْقَارِیَّ تَزَوَّجَ ابْنَۃَ حارثۃ بْنِ النُّعْمَانِ الأَنْصَارِیِّ فَلَمْ یَصِلْ إلَیْہَا فَأَجَّلَہُ عُمَرُ سَنَۃً ، قَالَ یَحْیَی : فَأَخْبَرَنِی عَبْدُ الرَّحْمَنِ الأَنْصَارِیُّ أَنَّہُ حَیْثُ حَالَ عَلَیْہِ الْحَوْلُ فُرِّقَ بَیْنَہُمَا وَقَالَ : الْحَمْدُ لِلَّہِ الَّذِی کَفَّ عَلَی حارثۃ ابْنَتِہِ۔",,,16762 16763,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ، عَنْ سَعِیدٍ، عَنْ قَتَادَۃَ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ، عَنْ عُمَرَ، أَنَّہُ أَجَّلَ الْعِنِّینَ سَنَۃً۔,,,16763 16764,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الشَّعْبِیِّ أَنَّ عُمَرَ بْنَ الْخَطَّابِ کَانَ یَقُولُ : یُؤَجَّلُ سَنَۃً لاَ أَعْلَمُہُ إلاَّ مِنْ یَوْمِ یُرْفَعُ إلَی السُّلْطَانِ۔",,,16764 16765,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ نُسَِیرٍ قَالَ : کُنْتُ عِنْدَ عَبْدِ الْمَلِکِ بْنِ مَرْوَانَ فَأُتِیَ بِعِنِّینٍ فَإِذَا إنْسَانٌ ضَرِیرٌ فَأَجَّلَہُ سَنَۃً۔",,,16765 16766,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ شِمْر ، عَنِ الشَّعْبِیِّ قَالَ : یُؤَجَّلُ الْعِنِّینُ سَنَۃً۔",,,16766 16767,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ ابْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ وَعُبَیدَۃَ ، عَنْ إبْرَاہِیمَ قَالاَ : تُخَیَّرُ فِی رَأْسِ الْحَوْلِ فَإِنْ شَائَتْ أَقَامَتْ ، وَإِنْ شَائَتْ فَارَقَتْہُ۔",,,16767 16768,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ مُحَمَّدِ بْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ، عَنْ شُرَیْحٍ قَالَ : کَتَبَ إلَیَّ عُمَرُ أَنْ أَجِّلْہُ سَنَۃً فَإِنَ اسْتَطَاعَہَا ، وَإِلاَّ خَیِّرْہَا فَإِنْ شَائَتْ أَقَامَتْ ، وَإِنْ شَائَتْ فَارَقَتْہُ۔",,,16768 16769,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : یُؤَجَّلُ الْعِنِّینُ أَجَلاً فَإِنْ وَصَلَ ، وَإِلاَّ خُیِّرَتْ فَإِنَ اخْتَارَتْہُ فَلَیْسَ لَہَا خِیَارٌ بَعْدَ ذَلِکَ۔",,,16769 16770,حَدَّثَنَا یَزِیدَ بْنِ ہَارُونَ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ عُمَرَ ، أَنَّہُ أَجَّلَ الْعِنِّینَ سَنَۃً فَإِنْ أَتَاہَا ، وَإِلاَّ فُرِّقَ بَیْنَہُمَا وَلَہَا الصَّدَاقُ کَامِلاً۔,,,16770 16771,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنِ الشَّعْبِیِّ ، عَنْ شُرَیْحٍ أَنَّہُ کَانَ یَقُولُ فِی الْعِنِّینِ إذَا لَمْ یَصِلْ إلَی امْرَأَتِہِ : إنَّ عَلَیْہِ نِصْفَ صَدَاقٍ۔",,,16771 16772,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : عَلَیْہِ الصَّدَاقَ۔",,,16772 16773,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ قَالَ : لَہَا الْمَہْرُ۔",,,16773 16774,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، وَالْحَسَنِ قَالاَ : أَجَّلَہُ عُمَرُ سَنَۃً فَإِنْ وَصَلَ ، وَإِلاَّ فُرِّقَ بَیْنَہُمَا وَلَہَا الصَّدَاقُ۔",,,16774 16775,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : لَہَا الصَّدَاقُ۔",,,16775 16776,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ قَالَ : لَہَا الصَّدَاقُ۔",,,16776 16777,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ زَمْعَۃَ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ قَالَ : لَہَا نِصْفُ صَدَاقٍ۔",,,16777 16778,حَدَّثَنَا عبد اللہ بْنِ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ قَالَ إذَا وَصَلَ إلَیْہَا مَرَّۃً لَمْ یُفَرَّقْ بَیْنَہُمَا۔,,,16778 16779,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ قَالَ : إذَا قَدَرَ عَلَیْہَا مَرَّۃً فَہِیَ امْرَأَتُہُ أَبَدًا۔",,,16779 16780,"حَدَّثَنَا عُمَرُ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ قَالَ : إذَا أَصَابَہَا مَرَّۃً فَلاَ کَلاَمَ لَہَا وَلاَ خُصُومَۃَ۔",,,16780 16781,"حَدَّثَنَا عُمَرُ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرِو بْنِ دِینَارٍ قَالَ : مَا زِلْنَا نَسْمَعُ أَنَّہُ إذَا أَصَابَہَا مَرَّۃً فَلاَ کَلاَمَ لَہَا وَلاَ خُصُومَۃَ۔",,,16781 16782,"حَدَّثَنَا عُمَرُ، عَنِ ابْنِ جُرَیْجٍ، عَنِ ابْنِ طَاوُوسٍ، عَنْ أَبِیہِ قَالَ: إذَا أَصَابَہَا مَرَّۃً فَلاَ کَلاَمَ لَہَا وَلاَ خُصُومَۃَ۔",,,16782 16783,"حَدَّثَنَا مُحَمَّدُ بْنُ یَزِیدَ ، عَنْ أَبِی الْعَلاَئِ ، عَنْ قَتَادَۃَ وَأَبِی ہَاشِمٍ قَالاَ : إِنْ تَزَوَّجَہَا ثُمَّ وَطِئَہَا مَرَّۃً ثُمَّ لَمْ یَسْتَطِعْ أَنْ یَغْشَاہَا ، فَإِنَّہُ لاَ خِیَارَ لَہَا بَعْدَ تِلْکَ الْمَرَّۃِ۔",,,16783 16784,"حَدَّثَنَا مُحَمَّدُ بْنُ یَزِیدَ ، عَنْ عُبَیْدَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : إذَا وَطِئَہَا مَرَّۃً فَلَیْسَ لَہَا خِیَارٌ۔",,,16784 16785,"حَدَّثَنَا حَکَّام الرَّازِیّ، عَنْ خَلِیلِ بْنِ زُرَارَۃَ، عَنْ مُطَرِّفٍ، عَنِ الشَّعْبِیِّ قَالَ: مَنْ زَوَّجَ فَاسِقًا فَقَدْ قَطَعَ رَحِمَہُ۔",,,16785 16786,"حَدَّثَنَا ابْنُ مُبَارَکٍ، عَنْ سَعِیدٍ، عَنْ قَتَادَۃَ، عَنِ ابْنِ الْمُسَیَّبِ وَسُلَیْمَان بْنِ یَسَارٍ ، وَالْحَسَنِ ، وَعِکْرِمَۃَ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ خِیَارَ لَہَا عَلَی الْحُرِّ۔",,,16786 16787,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ قَالَ : قُلْتُ لَہُ : لَہَا خِیَارٌ عَلَی الْحُرِّ ؟ قَالَ : لاَ۔",,,16787 16788,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ قَالَ : لَیْسَ لَہَا خِیَارٌ مِنَ الْحُرِّ وَلَہَا خِیَارٌ مِنَ الْعَبْدِ۔",,,16788 16789,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ أَنَّہُ کَانَ یَقُولُ : لاَ خِیَارَ لِلأَمَۃِ إذَا أُعْتِقَتْ وَزَوْجُہَا حُرٌّ۔",,,16789 16790,حَدَّثَنَا عبد اللہ بْنُ نُمَیْرٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ نَافِعٍ أَنَّ صَفِیَّۃَ بِنْتَ أَبِی عُبَیْدٍ کَانَ لَہَا عَبْدٌ فَزَوَّجَتْہُ جَارِیَۃً لہا بِکْرًا فَکَانَتْ تَکْرَہُ زَوْجَہَا وَکَانَتْ تُرِیدُ عِتْقَہَا فَخَافَت أَنْ تُعْتِقَ الْوَلِیدَۃَ فَتُفَارِقَ زَوْجَہَا فَأَعْتَقَتِ الْعَبْدَ حَتَّی إذَا أُثْبِتَ الْعَتِیقُ أَعْتَقَتِ الْوَلِیدَۃَ بَعْدَ ذَلِکَ۔,,,16790 16791,حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عَنْ عَائِشَۃَ أَنَّہَا اشْتَرَتْ بَرِیرَۃَ فَأَعْتَقَتْہَا فَخَیَّرَہَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَکَانَ لَہَا زَوْجٌ حُرٌّ۔ (بخاری 6751۔ ابوداؤد 2228),,,16791 16792,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ قَالَ : تُخَیَّرُ ، وَإِنْ کَانَتْ تَحْتَ رَجُلٍ مِنْ قُرَیْشٍ۔",,,16792 16793,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ قَالَ : لَہَا الْخِیَارُ حُرًّا کَانَ زَوْجُہَا ، أَوْ عَبْدًا۔",,,16793 16794,"حَدَّثَنَا حَفْصٌ ، عَنْ عَاصِمٍ ، عَنِ الشَّعْبِیِّ قَالَ : تُخَیَّرُ حُرًّا کَانَ زَوْجُہَا ، أَوْ عَبْدًا۔",,,16794 16795,"حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ ، عَنْ حَرْبِ بْنِ أَبِی الْعَالِیَۃِ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ قَالَ : لَہَا الْخِیَارُ ، وَإِنْ کَانَتْ تَحْتَ أَمِیرِ الْمُؤْمِنِینَ۔",,,16795 16796,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ وَعَنِ ابْنِ جُرَیْجٍ ، عَنِ الْحَسَنِ بْنِ مُسْلِمٍ ، عَنْ طَاوُوسٍ قَالَ : لَہَا الْخِیَارُ عَلَی الْحُرِّ وَالْعَبْدِ۔",,,16796 16797,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ فِی الْمَمْلُوکَۃِ تَکُونُ تَحْتَ الْعَبْدِ فَتُعْتَقُ قَالَ : لَہَا الْخِیَارُ مَا لَمْ یَمَسَّہَا۔",,,16797 16798,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ حَنْظَلَۃَ قَالَ سَمِعْت طَاوُوسًا وَسُئِلَ عَنِ الأَمَۃِ تُعْتَقُ وَلَہَا زَوْجٌ حُرٌّ تُخَیَّرُ ؟ فَقَالَ : لاَ عِلْمَ لِی ، وَلَکِنَّہَا إذَا کَانَتْ تَحْتَ عَبْدٍ خُیِّرَتْ۔",,,16798 16799,"حَدَّثَنَا عَبدَۃ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ قَالَ : تُخَیَّرُ حُرًّا کَانَ زَوْجُہَا ، أَوْ عَبْدًا۔",,,16799 16800,"حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنْ خَالِدٍ، عَنْ أَبِی قِلاَبَۃَ، عَنْ عُمَرَ، قَالَ: إذَا أُعْتِقَتِ الأَمَۃُ فَلَہَا الْخِیَارُ مَا لَمْ یَطَأْہَا زَوْجُہَا۔",,,16800 16801,"حَدَّثَنَا عَبْدَۃُ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ قَالَ : إذَا قَرَبَہَا فَلاَ خِیَارَ لَہَا قَدْ أَقَرَّتْ۔",,,16801 16802,"حَدَّثَنَا عَبدَۃ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ أَنَّ حَفْصَۃَ زَوْجَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَعْتَقَتْ جَارِیَۃً لَہَا ، فَقَالَتْ : إِنْ وَطِئَک زَوْجُک فَلاَ خِیَارَ لَک۔",,,16802 16803,"حَدَّثَنَا عَبدَۃ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ قَالَ : إذَا غَشِیَہَا زَوْجُہَا فَلاَ خِیَارَ لَہَا۔",,,16803 16804,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ، وَنَافِعٍ قَالاَ : لَہَا الْخِیَارُ مَا لَمْ یَغْشَہَا۔",,,16804 16805,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : إذَا أُعْتِقَتِ الأَمَۃُ فَلَہَا الْخِیَارُ مَا لَمْ یَطَأْہَا زَوْجُہَا۔",,,16805 16806,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حَمَّادٍ قَالَ : إذَا أُعْتِقَتِ الأَمَۃُ ثُمَّ وَطِئَہَا وَہِیَ لاَ تَعْلَمُ أَنَّ لَہَا الْخِیَارَ فَلَہَا الْخِیَارُ قَالَ : وَبَلَغَنِی ، عَنِ الْحَسَنِ أَنَّہُ کَانَ یَقُولُ ذَلِکَ۔",,,16806 16807,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنِ ابْنِ جُرَیْجٍ قَالَ : بَلَغَنِی ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ أَنَّہُ قَالَ : لَہَا الْخِیَارُ وَقَالَ : لَوْ کَانَ لِی عَلَیْہِ سُلْطَانٌ لَضَرَبْتہ۔",,,16807 16808,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنِ ابْنِ جُرَیْجٍ فِیمَا قُرِیئَ عَلَیْہِ قَالَ : وَقَالَ ابْنُ عُمَرَ : إِنْ أَصَابَہَا وَلاَ تَعْلَمُ فَلَہَا الْخِیَارُ إذَا عَلِمَتْ وَلَوْ أَصَابَہَا مِنْہَا مِئَۃَ مَرَّۃٍ۔",,,16808 16809,"حَدَّثَنَا ابْنِ الْمُبَارَکِ ، عَنِ ابْنِ جُرَیْجٍ قَالَ : قُلْتُ لِعَطَائٍ ، إذَا أُعْتِقَتِ الأَمَۃُ فَأَصَابَہَا مُبَادِرًا قَالَ : بِئْسَ مَا صَنَعَ ، قَالَ : قُلْتُ : لَہَا خِیَارٌ عَلَی الْحُرِّ ؟ قَالَ : لاَ۔",,,16809 16810,"حَدَّثَنَا وَکِیعٌ، عَنْ شعبۃ، عَنِ الْحَکَمِ قَالَ: إذَا وَطِئَہَا وَہِیَ لاَ تَعْلَمُ أَنَّ لَہَا الْخِیَارَ فَلَہَا الْخِیَارُ إذَا عَلِمَتْ۔",,,16810 16811,"حَدَّثَنَا حَفْصٌ ، عَنْ بَعْضِ أَصْحَابِ حَمَّادٍ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ قَالَ : إذَا وَقَعَ عَلَیْہَا وَلَمْ تَعْلَمْ أَنَّ لَہَا الْخِیَارَ فَلَہَا الْخِیَارُ إذَا عَلِمَتْ۔",,,16811 16812,حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ جُوَِیبرٍ ، عَنِ الضَّحَّاکِ قَالَ إذَا وَطِئَہَا وَہِیَ تَعْلَمُ أَنَّ لَہَا الْخِیَارَ فَذَاکَ مِنْہَا رِضًا۔,,,16812 16813,"حَدَّثَنَا حَفْصٌ، عَنْ عَمْرٍو، عَنِ الْحَسَنِ قَالَ: إذَا وَقَعَ عَلَیْہَا زَوْجُہَا وَقَدْ عَلِمَتْ أَنَّ لَہَا الْخِیَارَ فَلاَ خِیَارَ لَہَا۔",,,16813 16814,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ قَالَ : إذَا غَشِیَہَا قَبْلَ أَنْ تَخْتَارَ اُسْتُحْلِفَت أَنَّہَا لَمْ تَعْلَمْ أَنَّ لَہَا الْخِیَارَ ثُمَّ خُیِّرَتْ إذَا کَانَتْ تَحْتَ عَبْدٍ۔",,,16814 16815,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ ، عَنْ رَجُلٍ کَانَتْ عِنْدَہُ امْرَأَۃٌ فَأُعْتِقَتْ فَغَشِیَہَا بَعْدَ الْعِتْقِ ، فَقَالَتْ : لَمْ أَشْعُرْ أَنَّ لِی خِیَارًا ، قَالَ : تُسْتَحْلَفُ أَنَّہَا لَمْ تَعْلَمْ أَنَّ لَہَا الْخِیَارَ ثُمَّ تُخَیَّرُ وَسَأَلْت حَمَّادًا، فَقَالَ : ہِیَ امْرَأَتُہُ وَلاَ تُخَیَّرُ۔",,,16815 16816,"حَدَّثَنَا غُنْدَرٌ، عَنْ شُعْبَۃَ قَالَ: أَخْبَرَنِی الْہَیْثَمُ ، عَنْ حَمَّادٍ أَنَّہُ قَالَ: تُسْتَحْلَفُ أَنَّہَا لَمْ تَعْلَمْ أَنَّ لَہَا الْخِیَارَ۔",,,16816 16817,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ معمر عن رَجُلٍ ، عَنْ جَابِرٍ بْنِ زَیْدٍ قَالَ فِی الْمُکَاتَبَۃِ قَالَ : تُخَیَّرُ۔",,,16817 16818,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ سُفْیَانَ ، عَنْ فِرَاسٍ ، عَنْ عَامِرٍ قَالَ : تُخَیَّرُ الْمُکَاتَبَۃُ۔",,,16818 16819,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ مَنْصُورٍ وَمُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : إذَا کَاتَبت المْرَأَۃ أَعَانَہَا زَوْجُہَا عَلَی مُکَاتَبَتِہَا ثُمَّ أُعْتِقَتْ فَلاَ خِیَارَ لَہَا۔",,,16819 16820,"حَدَّثَنَا شَرِیکٌ، عَنْ جَابِرٍ، عَنْ عَامِرٍ فِی الْمُکَاتَبَۃِ: تَسْعَی وَمَعَہَا زَوْجُہَا قَالَ: لَہَا الْخِیَارُ، وَإِنْ سَعَی مَعَہَا۔",,,16820 16821,حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ وَمَنْصُورٍ ، عَنِ الْحَسَنِ ، وَعَطَائٍ أَنَّہُمَا کَانَا لاَ یَرَیَانِ بَأْسًا بِتَزْوِیجِ النَّہَارِیَّاتِ۔,,,16821 16822,حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ أَنَّہُ کَانَ یَکْرَہُ نِکَاحَ النَّہَارِیَّاتِ وَکَانَ الْحَسَنُ لاَ یَرَی بہ بَأْسًا۔,,,16822 16823,حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ حَمَّادٍ أَنَّہُ کَرِہَہُ۔,,,16823 16824,"حَدَّثَنَا جَرِیرٍ ، عَنْ مُطَرِّفٍ ، عَنِ الْحَکَمِ وَحَمَّادٍ فِی رَجُلٍ تَزَوَّجَ امْرَأَۃً وَشَرَطَ لَہَا : مَا قَسَمْتُ لَکَ مِنْ لَیْلٍ ، أَوْ نَہَارٍ رَضِیتِ بِہِ ، قالا : ہَذَا شَرْطٌ فَاسِدٌ۔",,,16824 16825,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ قَالَ : کَانَ یُسْأَلُ ، عَنِ الرَّجُلِ یَتَزَوَّجُ الْمَرْأَۃَ فَیَشْتَرِطُ عَلَیْہَا أَنْ لاَ یَأْتِیَہَا کَذَا وَکَذَا ، وَلاَ یُنْفِقُ عَلَیْہَا إلاَّ شَیْئًا مَعْلُومًا ، قَالَ : إنَّمَا الصُّلْحُ الَّذِی أَمَرَ اللَّہُ بِہِ بَعْدَ الدُّخُولِ ، فَکَانَ یَکْرَہُہُ۔",,,16825 16826,"حَدَّثَنَا ابْنُ عُلَیَّۃَ قَالَ : سُئِلَ یُونُسُ ، عَنِ الشَّرْطِ فِی النِّکَاحِ ، فَقَالَ : کَانَ الْحَسَنُ لاَ یَرَی بِہِ بَأْسًا إذَا کَانَتْ عَلاَنِیَۃً ، وَکَانَ ابْنُ سِیرِینَ یَکْرَہُ ابْتِدَائَہُ وَلاَ یَرَی بِہِ بَأْسًا بَعْدَ ذَلِکَ۔",,,16826 16827,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ قَالَ : سَأَلْتُہ عَنِ الرَّجُلِ تَکُونُ لَہُ امْرَأَۃٌ فَیَتَزَوَّجُ الْمَرْأَۃَ فَیَشْتَرِطُ لِہَذِہِ یَوْمًا وَلِہَذِہِ یَوْمَیْنِ ؟ قَالَ : لاَ بَأْسَ بِہِ۔",,,16827 16828,"حَدَّثَنَا إسْمَاعِیلَ بْنِ عَیَّاشٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ فِی رَجُلٍ تَزَوَّجَ امْرَأَۃً فَاشْتَرَطُوا عَلَیْہِ : إِنْ جِئْت بِمَہْرِہَا إلَی کَذَا وَکَذَا ، وَإِلاَّ فَلاَ نِکَاحَ بَیْنَنَا ، قَالَ ابْنُ عَبَّاسٍ : لاَ بَأْسَ بِذَلِکَ۔",,,16828 16829,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ قَالَ : ہُوَ جَائِزٌ وَکَأَنَّہُ جَعَلَہُ حَلِفًا ، وَکَانَ الْحَسَنُ یَقُولُ : قَدْ جَازَ النِّکَاحُ وَبَطَلَ الشَّرْطُ۔",,,16829 16830,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ قَالَ : کُلُّ شَرْطٍ فِی النِّکَاحِ فَالنِّکَاحُ یَہْدِمُہُ إلاَّ الطَّلاَقَ۔",,,16830 16831,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَمْرِو بْنِ قَیْسٍ ، عَنْ جَدَّتِہِ أَنَّ أَبَاہَا تَزَوَّجَ امْرَأَۃً بِخَادِمٍ لَہَا فَخَاصَمَتْ أَبَاہَا إلَی شُرَیْحٍ فَقَضَی لَہَا بِالْخَادِمٍ وَقَضَی لِلْمَرْأَۃِ بِقِیمَۃِ الْخَادِمِ۔,,,16831 16832,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ فِی رَجُلٍ تَزَوَّجَ امْرَأَۃً عَلَی أَنْ یُعْتِقَ أَبَاہَا فَلَمْ یَقْدِرْ عَلَیْہِ ، قَالَ : عَلَیْہِ قِیمَۃُ الأَبِ۔",,,16832 16833,حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ فِی الرَّجُلِ یَتَزَوَّجُ المرأۃ عَلَی أَنْ یُحِجَّہَا قَالَ ہُوَ جائز۔,,,16833 16834,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ إسْمَاعِیلَ ، عَنْ أَبِی خَالِدٍ ، عَنِ الشَّعْبِیِّ فِی الرَّجُلِ یَتَزَوَّجُ امْرَأَۃً عَلَی أَنَّ صَدَاقَہَا عِتْقُ أَبِیہَا فَلَمْ یُبَعْہُ قَالَ : لَہَا قِیمَۃُ الأَبِ۔",,,16834 16835,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ حَمَّادٍ فِی رَجُلٍ تَزَوَّجَ امْرَأَۃً عَلَی أَنْ یُحِجَّہَا ثُمَّ طَلَّقَہَا قَبْلَ أَنْ یَدْخُلَ بِہَا قَالَ : لَہَا نِصْفُ أَدْنَی مَا یَحُجُّ بِہِ إنْسَانٌ۔",,,16835 16836,"حَدَّثَنَا ، عَنْ عَبْدِ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ قَالَ : إذَا خَطَبَ الرَّجُلُ عَلَی الرَّجُلِ فَزَوَّجَہُ فَأَنْکَرَ عَلَیْہِ الآخَرُ فَحَقُّہَا ثَابِتٌ عَلَی ہَذَا نِصْفُ الصَّدَاقِ۔",,,16836 16837,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ فِی رَجُلٍ کَتَبَ إلَی أَبِیہِ ، أَوْ إلَی مَوْلاَہُ أَنْ یُزَوِّجَہُ فَزَوَّجَہُ فَجَائَ فَأَنْکَرَ عَلَیْہِ قَالَ الشَّعْبِیُّ : إِنْ أَجَازَ الزَّوْجُ النِّکَاحَ فَہُوَ جَائِزٌ ، وَإِنْ لَمْ یُجِزْہُ فَلَیْسَ بِشَیْئٍ وَلَیْسَ عَلَی وَاحِدٍ مِنْہُمَا صَدَاقٌ إِنْ لَمْ یَکُنْ دَخَلَ بِہَا۔",,,16837 16838,"حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ فِی رَجُلٍ زَوَّجَ أَبَاہُ وَہُوَ غَائِبٌ فَلَمْ یَرْضَ الأَبُ قَالَ : الصَّدَاقُ عَلَی الابْنِ فَإِنْ زَوَّجَ الأَبُ الابْنَ فَلَمْ یَرْضَ الابْنُ فَالصَّدَاقُ عَلَی الأَبِ",,,16838 16839,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ عَطَائٍ ، عَنْ جَابِرٍ قَالَ : کُنَّا نَعْزِلُ وَالْقُرْآنُ یَنْزِلُ۔(بخاری 5207۔ مسلم 137)",,,16839 16840,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ أَبِی الزِّنَادِ ، عَنْ خَارِجَۃَ بْنِ زَیْدٍ أَنَّ زَیْدًا کَانَ یَعْزِلُ عَنْ جَارِیَۃٍ لَہُ۔,,,16840 16841,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ عِکْرِمَۃَ ؛ أَنَّ زَیْدًا وَسَعْدًا کَانَا یَعْزِلاَنِ۔,,,16841 16842,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ إسْمَاعِیلَ الشَّیْبَانِیِّ أَنَّہُ خَلَفَ عَلَی امْرَأَۃِ رَافِعِ بْنِ خَدِیجٍ فَأَخْبَرَتْہُ أَنَّہُ کَانَ یَعْزِلُ ، أَوْ تَعْزِلُ مِنْ قُرُوحٍ بِہَا کَی لاَ تَغْتَسِلَ۔,,,16842 16843,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ زَائِدَۃَ بن عُمَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ فِی قَوْلِہِ : {نِسَاؤُکُمْ حَرْثٌ لَکُمْ} قَالَ : مَنْ شَائَ أَنْ یَعْزِلَ فَلْیَعْزِلْ وَمَنْ شَائَ أَنْ لاَ یَعْزِلَ فَلاَ یَعْزِلْ۔",,,16843 16844,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ التَّیْمِیِّ ، عَنْ یَحْیَی بْنِ عَبَّادٍ أَنَّ خَبَّابًا کَانَ یَعْزِلُ ، عَنْ سَرَارِیہِ۔,,,16844 16845,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یَحْیَی بْنِ أَبِی إِسْحَاقَ ، عَنِ ابْنِ سَعدٍ - یَعْنِی عَامِرًا - أَنَّ سَعْدًا کَانَ یَعْزِلُ۔,,,16845 16846,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی الْعَزْلِ : اخْتَلَفَ فِیہِ أَصْحَابُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : فَکَانَ زَیْدٌ وَأَنَسُ بْنُ مَالِکٍ یَعْزِلاَنِ۔",,,16846 16847,حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ مُبَارَکٍ ، عَنْ یَحْیَی ، عَنْ أَبِی سَلَمَۃَ أَنَّ زَیْدًا وَسَعْدًا کَانَا یَعْزِلاَنِ۔,,,16847 16848,"حَدَّثَنَا وَکِیعٌ ، عَنِ الضَّحَّاکِ بن عُثْمَانَ ، عَنْ سَالِمٍ أَبِی النَّضْرِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَفْلَحَ قَالَ : نَکَحْت أُمَّ وَلَدِ أَبِی أَیُّوبَ فَأَخْبَرَتْنِی أَنَّ أَبَا أَیُّوبَ کَانَ یَعْزِلُ وَأَخْبَرَتْنِی أُمُّ وَلَدِ زَیْدِ بْنِ ثَابِتٍ أَنَّہُ کَانَ یَعْزِلُ عَنْہَا وَقَالَ سَالِمٌ ، عَنْ عَائِشَۃَ ابْنَۃِ سَعْدٍ إِنَّ سَعْدًا کَانَ یَعْزِلُ ، عَنْ أُمَّہَاتِ أَوْلاَدِہِ۔",,,16848 16849,"حَدَّثَنَا عَبْدَۃ بن سلیمان ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : کَانَتِ الأَنْصَارُ لاَ یَرَوْنَ بَأْسًا بِالْعَزْلِ ، وَکَانَ مِمَّنْ یَقُولُ ذَلِکَ زَیْدٌ ، وَأَبُو أَیُّوبَ وَأُبَیُّ۔",,,16849 16850,حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ أَنَّ عَلْقَمَۃَ وَأَصْحَابَ عَبْدِ اللہِ کَانُوا یَعْزِلُونَ۔,,,16850 16851,"حَدَّثَنَا حَفْصٌ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ عَلِیِّ بْنِ حُسَیْنٍ أَنَّہُ کَانَ یَعْزِلُ وَیَتَأَوَّلُ ہَذِہِ الآیَۃَ : {وَإِذْ أَخَذَ رَبُّک مِنْ بَنِی آدَمَ مِنْ ظُہُورِہِمْ ذُرِّیَّاتِہِمْ}۔",,,16851 16852,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مِسْعَرٍ ، عَنْ أَبِی عِمْرَانَ ، قَالَ : سَمِعْتُ امْرَأَۃً تَقُولُ : کَانَ الْحَسَنُ بْنُ عَلِیٍّ یَعْزِلُ عَنِّی۔",,,16852 16853,"حَدَّثَنَا عَبْدَۃُ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدٍ سُئِلَ عَنِ الْعَزْلِ فَلَمْ یَرَ بِہِ بَأْسًا ، وَقَالَ : ہُوَ حَرْثُک إِنْ شِئْتَ أَعْطَشْتہ ، وَإِنْ شِئْتَ أَسْقَیْتہ۔",,,16853 16854,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ مَسْعُودِ بْنِ عَلِیٍّ قَالَ : قُلْتُ لِعِکْرِمَۃَ : أَعْزِلُ ، عَنْ جَارِیَۃٍ لِی ؟ قَالَ : ہُوَ حَرْثُک فَإِنْ شِئْتَ فَأَعْطِشْہُ ، وَإِنْ شِئْتَ فَأَرْوِہِ۔",,,16854 16855,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنِ الزِّبْرِقَانِ السَّرَّاجِ قَالَ : سَأَلْتُ ابْنَ مَعْقِلٍ ، عَنِ الْعَزْلِ ، فَقَالَ : قَدْ فَعَلَ ذَلِکَ مَنْ ہُوَ خَیْرٌ مِنِّی وَمِنْک سَعْدٌ۔",,,16855 16856,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ الْحَسَنِ بْنِ ذَکْوَانَ ، عَنِ الْحَسَنِ ، عَنْ جَابِرٍ قَالَ : کُنَّا نَعْزِلُ وَالْقُرْآنُ یَنْزِلُ فَلاَ نُنْہَی۔",,,16856 16857,حَدَّثَنَا مُحَمَّدُ بْنُ بشر ، عَنْ مِسْعَرٍ ، عَنْ عَوْنِ بْنِ عَبْدِ اللہِ ، عَنْ رَجُلٍ ، عَنْ أمہ ، عَنْ سُرِّیَّۃٍ لِعُمَرَ أَنَّہُ کَانَ یَعْزِلُ۔,,,16857 16858,"حَدَّثَنَا مُحَمَّدُ بْنُ بشر حَدَّثَنَا مِسْعَرٌ ، عَنِ الْوَلِیدِ بْنِ أَبِی مَالِکٍ ، عَنْ قَزَعَۃَ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ قَالَ : إن ابْنَتِی ہَذِہِ الَّتِی فِی الْخِدْرِ مِنَ الْعَزْلِ۔",,,16858 16859,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِِ ، عَنْ سَالِمٍ ، عَنْ جَابِرٍ قَالَ : أَتَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجُلٌ ، فَقَالَ : إنَّ لِی خَادِمًا تَسْتَقِی عَلَی نَاضِحٍ لِی وَأَنَا أَعْزِلُ عَنْہَا ، فَجَائَتْ بِوَلَدٍ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَا قَدَّرَ اللَّہُ مِنْ نَفْسٍ أَنْ یَخْلُقَہَا إلاَّ وَہِیَ کَائِنَۃٌ۔ (مسلم 64۔ ابن ماجہ 89)",,,16859 16860,"حَدَّثَنَا مُحَمَّدُ بْنُ بشر ، عَنْ مِسْعَرٍ قَالَ : أَخْبَرَنِی الْحَسَنُ بن سَعْدٍ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ أَنَّ ابْنَ عَبَّاسٍ سُئِلَ عَنِ الْعَزْلِ فَدَعَا جَارِیَۃً لَہُ ، فَقَالَ : عَزَلْتُ عَنْکِ أَمْسِ۔",,,16860 16861,"حَدَّثَنَا مُحَمَّدُ بْنُ بشر ، عَنْ مِسْعَرٍ قَالَ : حدَّثَنِی عَبْدُ الْمَلِکِ بْنُ عُمَیْرٍ ، عَنْ مُصْعَبِ بْنِ سَعْدٍ أَنَّ سَعْدًا کَانَ یَعْزِلُ ، عَنِ الأَمَۃِ إذَا خَشِیَ أَنْ تَحْمِلَ۔",,,16861 16862,حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ أَنَّ أَبَا بَکْرٍ وَعُمَرَ کَانَا یَکْرَہَانِ الْعَزْلَ وَیَأْمُرَانِ النَّاسَ بِالْغُسْلِ مِنْہُ۔,,,16862 16863,حَدَّثَنَا عَبْدَۃُ بن سلیمان ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ أَنَّ رِجَالاً مِنَ الْمُہَاجِرِینَ کَانُوا یَکْرَہُونَ الْعَزْلَ ، مِنْہُمْ فُلاَنٌ وَفُلاَنٌ وَعُثْمَانُ بْنُ عَفَّانَ۔,,,16863 16864,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ عَاصِمٍ ، عَنْ زِرٍّ ، عَنْ عَلِیٍّ قَالَ : الْعَزْلُ الْوَأْدُ الْخَفِیُّ۔",,,16864 16865,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ قَالَ : حدَّثَنَا مَیْمُونُ بْنُ مِہْرَانَ أَنَّ ابْنَ عُمَرَ اشْتَرَی جَارِیَۃً لِبَعْضِ بَنِیہِ ، فَقَالَ : مَا لِی لاَ أَرَاہَا تَحْمِلُ ، لَعَلَّک تَعْزِلُ عَنْہَا لَوْ أَعْلَمُ ذَلِکَ لأَوْجَعْت ظَہْرَک۔",,,16865 16866,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ یَزِیدَ بْنِ خُمَیْرٍ ، عَنْ سُلَیْمِ بْنِ عَامِرٍ ، عَنْ أَبِی أُمَامَۃَ فِی الْعَزْلِ قَالَ : مَا کُنْت أَرَی7أَنَّ مُسْلِمًا یصنعہ۔",,,16866 16867,"حَدَّثَنَا غُنْدَرٌ، عَنْ شُعْبَۃَ، عَنْ عَبْدِ الْوَاحِدِ الْمَالِکِیِّ ، عَنْ سَالِمٍ فِی الْعَزْلِ ، قَالَ: ہِیَ الْمَوْؤُودَۃُ الْخَفِیَّۃُ۔",,,16867 16868,حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ أَنَّہُ کَانَ یَکْرَہُ الْعَزْلَ۔,,,16868 16869,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ مِنْدلِ بْنِ عَلِیِّ ، عَنْ جَعْفَرِ بْنِ أَبِی مُغِیرَۃَ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی الْہُذَیْلِ ، عَنْ جَرِیرٍ قَالَ : جَائَ رَجُلٌ إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : یَا رَسُولَ اللہِ ، مَا خَلُصْت إلَیْک مِنَ الْمُشْرِکِینَ إلاَّ بِقَیْنَۃٍ ، وَأَنَا أَعْزِلُ عَنْہَا ، أُرِیدُ بِہَا السُّوقَ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : جَائَہَا مَا قُدِّرَ۔ (طبرانی 2370۔ مسند 1611)",,,16869 16870,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ مُحَمَّدِ بْنِ إبْرَاہِیمَ التَّیْمِیِّ ، عَنْ أَبِی سَلَمَۃَ بْنِ عَبْدِ الرَّحْمَنِ وَأَبِی أُمَامَۃَ بْنِ سَہْلٍ عَنْہُمَا جَمِیعًا ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ قَالَ : لَمَّا أَصَبْنَا سَبْیَ بَنِی الْمُصْطَلِقِ اسْتَمْتَعْنَا من النساء وَعَزَلْنَا عَنْہُنَّ قَالَ ثم : إنی وَقفْت عَلَی جَارِیَۃٍ فِی سُوقِ بَنِی قَیْنُقَاعَ قَالَ : فَمَرَّ بِی رَجُلٌ مِنْ یَہُودَ ، فَقَالَ : مَا ہَذِہِ الْجَارِیَۃُ یَا أَبَا سَعِیدٍ ، قُلْتُ : جَارِیَۃٌ لِی أَبِیعُہَا ، قَالَ : ہَلْ کُنْت تُصِیبُہَا ؟ قَالَ ، قُلْتُ : نَعَمْ ، قَالَ : فَلَعَلَّک تَبِیعُہَا وَفِی بَطْنِہَا مِنْک سَخْلَۃٌ ؟ قَالَ : قُلْتُ : کُنْت أَعْزِلُ عَنْہَا ، قَالَ تِلْکَ الْمَوْؤُودَۃُ الصُّغْرَی ، قَالَ : فَجِئْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَذَکَرْت ذَلِکَ لَہُ ، فَقَالَ : کَذَبَتْ یَہُودُ کَذَبَتْ یَہُودُ۔ (نسائی 9084۔ طحاوی 32)",,,16870 16871,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ مُحَمَّدِ بْنِ یَحْیَی بْنِ حَبَّانَ ، عَنْ عَبْدِ اللہِ بْنِ مُحَیْرِیزٍ قَالَ : دَخَلْت أَنَا ، وَأَبُو صرمۃ الْمَازِنِیُّ فَوَجَدْنَا أَبَا سَعِیدٍ یُحَدِّثُ کَمَا یُحَدِّثُ أَبُو سَلَمَۃَ ، وَأَبُو أُمَامَۃَ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : کَذَبَتْ یَہُودُ ، وَقَالَ فِی آخِرِ الْحَدِیثِ : وَمَا عَلَیْکُمْ أَنْ لاَ تَفْعَلُوا وَقَدْ قَدَّرَ اللَّہُ مَا ہُوَ خَالِقٌ مِنْ خَلْقِہِ إلَی یَوْمِ الْقِیَامَۃِ۔ (بخاری 4138۔ مسلم 127)",,,16871 16872,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ، عَنْ إبْرَاہِیمَ التَّیْمِیِّ وَعَمْرِو بْنِ مُرَّۃَ قَالاَ: یُعْزَلُ ، عَنِ الأَمَۃِ وَتُسْتَأْمَرُ الْحُرَّۃَ۔",,,16872 16873,حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ مِثْلَہُ۔,,,16873 16874,حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنْ مُحَمَّدٍ مِثْلَہُ۔,,,16874 16875,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ حُمَیْدٍ الأَعْرَجِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ قَالَ : لاَ یُعْزَلُ ، عَنِ الْحُرَّۃِ إلاَّ بِإِذْنِہَا۔",,,16875 16876,"حَدَّثَنَا عبد الرحمن بْنُ مَہْدِیٍّ وَیَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ سَوَّارٍ الْکُوفِیِّ ، عَنْ عَبْدِ اللہِ قَالَ : تُسْتَأْمَرُ الْحُرَّۃَ یُعْزَلُ ، عَنِ الأَمَۃِ۔",,,16876 16877,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ ہَمَّامٍ ، عَنْ قَتَادَۃَ ، عَنْ جَابِرِ بْنِ زَیْدٍ قَالَ : لاَ یُعْزَلُ ، عَنِ الْحُرَّۃِ إلاَّ بِإِذْنِہَا",,,16877 16878,"حَدَّثَنَا وَکِیعٌ ، عَنْ طَلْحَۃَ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ وَعَنِ الرَّبِیعِ ، عَنِ الْحَسَنِ وَعَنْ سُفْیَانَ ، عَنْ أَبِی سُعَادَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ قَالُوا : تُسْتَأْمَرُ الْحُرَّۃُ وَلاَ تُسْتَأْمَرُ الأَمَۃَ۔",,,16878 16879,"حَدَّثَنَا أَسْبَاطُ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ قَالَ : سُئِلَ عَنِ الأَمَۃِ یُعَزَلُ عَنْہَا ، قَالَ : نَعَمْ ، وَأَمَّا الْحُرَّۃُ فَیَسْتَأْمِرُہَا۔",,,16879 16880,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ زَمْعَۃَ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ أَنَّہُ کَانَ یَعْزِلُ ، عَنِ الأَمَۃِ وَلاَ یَقُولُ فِی الْحُرَّۃِ شَیْئًا۔,,,16880 16881,"حَدَّثَنَا عَبْدِ الْوَہَّابِ الثَّقَفِیِّ ، عَنْ أَیُّوبَ ، عَنِ ابْنِ سِیرِینَ فِی الرَّجُلِ یَشْتَرِی الأَمَۃَ الْعَذْرَائَ قَالَ : لاَ یَقْرَبَنَّ مَا دُونَ رَحِمِہَا حَتَّی یَسْتَبْرِئَہَا۔",,,16881 16882,"حَدَّثَنَا إبْرَاہِیمُ بْنُ صَدَقَۃَ، عَنْ یُونُسَ، عَنِ الْحَسَنِ؛ فِی رَجُلٍ اشْتَرَی جَارِیَۃً عَذْرَائَ قَالَ: یَسْتَبْرِئُ رَحِمَہَا۔",,,16882 16883,"حَدَّثَنَا وَکِیعٌ ، عَنْ رَبِیعٍ ، عَنِ الْحَسَنِ قَالَ : یَسْتَبْرِئُہَا ، وَإِنْ کَانَتْ بِکْرًا",,,16883 16884,حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ مُبَارَکٍ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ عِکْرِمَۃَ مِثْلَہُ۔,,,16884 16885,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ فِی رَجُلٍ اشْتَرَی جَارِیَۃً بَیْنَ أَبَوَیْہَا عَذْرَائَ قَالَ : یَسْتَبْرِئُہَا بِحَیْضَتَیْنِ ، وَإِنْ لاَ تَحِیضُ فَبِخَمْسَۃٍ وَأَرْبَعِینَ یَوْمًا۔",,,16885 16886,"حَدَّثَنَا عَبْدُ الْوَہَّابِ، عَنْ سَعِیدٍ، عَنْ أَیُّوبَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ قَالَ: إنِ اشْتَرَی أَمَۃً عَذْرَائَ فَلاَ یَسْتَبْرِئُہَا۔",,,16886 16887,"حَدَّثَنَا عَبَّادُ بْنِ الْعَوَّامِ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ مَکْحُولٍ قَالَ : قُلْتُ لِلزُّہْرِیِّ : أَمَا عَلِمْت أن عُمَرَ حتی انْقَضَاء أَجَلِہِ ، وَابْنَ مَسْعُودٍ بِالْعِرَاقِ حتی انْقَضَاء أَجَلِہِ وَعُثْمَانَ بْنَ عَفَّانَ کَانُوا یَسْتَبْرِئُونَ الأَمَۃ بِحَیْضَۃٍ حَتَّی کَانَ مُعَاوِیَۃُ ، فَکَانَ یَقُولُ : حَیْضَتَانِ ، فَقَالَ الزُّہْرِیُّ : وَأَنَا أَزِیدُک عُبَادَۃَ بْنَ الصَّامِتِ",,,16887 16888,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ فِرَاسٍ، عَنِ الشَّعْبِیِّ، عَنْ عَلْقَمَۃَ، عَنْ عَبْدِ اللہِ قَالَ: تسْتَبْرَأُ الأَمَۃَ بِحَیْضَۃٍ۔",,,16888 16889,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ صِلَۃَ وَقُثَمٍ وَنَاجِیَۃَ قَالوا : أَیُّمَا رَجُلٍ اشتری جَارِیَۃً فَلاَ یَقْرَبْہَا حَتَّی تَحِیضَ۔",,,16889 16890,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُبَبْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ فِی الأَمَۃِ الَّتِی تُوطَأُ قَالَ : إذَا بِیعَتْ ، أَوْ أُعْتِقَتْ فَلِتُسْتَبْرأ بِحَیْضَۃٍ۔",,,16890 16891,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : سَأَلْتُہ ، عَنْ رَجُلٍ اشْتَرَی جَارِیَۃً لَہَا زَوْجٌ ، قَالَ : یَسْتَبْرِئُ رَحِمَہَا بِحَیْضَۃٍ۔",,,16891 16892,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنْ عَطِیَّۃَ ، عَنِ ابْنِ عُمَرَ قَالَ : مَنِ اشْتَرَی جَارِیَۃً فَلاَ یَقْرَبْہَا حَتَّی یَسْتَبْرِئہَا بِحَیْضَۃٍ۔",,,16892 16893,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ قَالَ : بِحَیْضَۃٍ۔",,,16893 16894,"حَدَّثَنَا وَکِیعٌ ، عَنْ شَرِیکٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ قَالَ : تُسْتَبْرَأ الأَمَۃَ بِحَیْضَۃٍ۔",,,16894 16895,"حَدَّثَنَا حَاتِمٌ بن وردان، عَنْ بُرد، عَنْ مَکْحُولٍ قَالَ: إذا اشْتَرَیْت الأَمَۃَ قَالَ: یَسْتَبْرِئُہَا بِحَیْضَۃٍ وَاحِدَۃٍ۔",,,16895 16896,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ وَطَاوُسٍ قَالاَ : تُسْتَبْرَأ الأَمَۃَ بِحَیْضَۃٍ۔",,,16896 16897,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ عَطَائٍ ، قَالَ : قَالَ عُمَرُ : مَنِ اشْتَرَی جَارِیَۃً فَلِیَسْتَبْرِئہَا بِحَیْضَۃٍ۔",,,16897 16898,"حَدَّثَنَا ہُشَیْمٍ، عَنْ یُونُسَ، عَنِ الْحَسَنِ أَنَّہُ کَانَ یَقُولُ: إذَا اشْتَرَاہَا وَہِیَ حَائِضٌ فَلِیَسْتَبْرِئہَا بِحَیْضَۃٍ أُخْرَی۔",,,16898 16899,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : إِنْ شَائَ اجْتَزَأَ بِہَذِہِ الْحَیْضَۃِ۔",,,16899 16900,"حَدَّثَنَا ہِشَامٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : إذَا اشْتَرَاہَا مِنَ امْرَأَۃٍ فَلِیَسْتَبْرِئہَا بِحَیْضَۃٍ۔",,,16900 16901,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ قَالَ : إذَا اشْتَرَاہَا مِنَ امْرَأَۃٍ اسْتَبْرَأَہَا",,,16901 16902,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ ، عَنْ أَبِی قِلاَبَۃَ ، وَابْنِ سِیرِینَ فِی الرَّجُلِ یستبرء الأَمَۃَ الَّتِی لَمْ تَحِضْ قَال : کَانَا لاَ یَرَیَانِ أَنَّ ذَلِکَ یَتَبَیَّنُ فِی أَقَلَّ مِنْ ثَلاَثَۃِ أَشْہُرٍ۔",,,16902 16903,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ أَنَّہُ کَانَ یَقُولُ یَستَبرئہا بِثَلاَثَۃِ أَشْہُرٍ۔,,,16903 16904,"حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنْ لَیث، عَنْ عَطَائٍ وَطَاوُسٍ قَالاَ: تُسْتَبْرَأ بِحَیْضَۃٍ، وَإِنْ کَانَتْ لاَ تَحِیضُ فَثَلاَثَۃُ أَشْہُرٍ۔",,,16904 16905,حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ إبْرَاہِیمَ قَالَ ثَلاَثَۃُ أَشْہُرٍ۔,,,16905 16906,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ وَسُفْیَانَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ مُجَاہِدٍ قَالَ : بِثَلاَثَۃِ أَشْہُرٍ۔",,,16906 16907,"حَدَّثَنَا مُعْتَمِرٌ بن سلیمان ، عَنْ مَعْمَرٍ ، عَنْ صَدَقَۃَ بْنِ یَسَارٍ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ قَالَ: ثَلاَثَۃُ أَشْہُرٍ۔",,,16907 16908,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حُمَیْدٍ ، عَنْ أَبِی قِلاَبَۃَ أَنَّہُ کَانَ یَقُولُ فِی اسْتِبْرَائِ الأَمَۃِ الَّتِی لَمْ تَحِضْ : خَمْسَۃٌ وَأَرْبَعُونَ۔",,,16908 16909,حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ قَالَ شَہْرٌ وَنِصْفٌ۔,,,16909 16910,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ قَالَ شَہْرٌ وَنِصْف۔,,,16910 16911,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنِ النُّعْمَانِ ، عَنْ قَتَادَۃَ ، وَعَطَائٍ قَالاَ : تُسْتَبْرَأ الْجَارِیَۃَ الَّتِی لَمْ تَحِضْ بِخَمْسَۃٍ وَأَرْبَعِینَ یَوْمًا۔",,,16911 16912,"حَدَّثَنَا عبدالرحمن بن محمد الْمُحَارِبِیُّ، عَنِ الشَّیْبَانِیِّ، عَنْ حَمَّادٍ قَالَ: یَسْتَبْرِئُہَا بِخَمْسَۃٍ وَأَرْبَعِینَ یَوْمًا۔",,,16912 16913,"حَدَّثَنَا ابْنُ نُمَیْرٍ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ، عَنْ عَطَائٍ، قَالَ: قَالَ عُمَرُ: إِنْ کَانَتْ لاَ تَحِیضُ فَأَرْبَعُونَ یَوْمًا۔",,,16913 16914,"حَدَّثَنَا عَبدَۃ بن سلیمان ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ وَعَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ قَالاَ : شَہْرٌ وَنِصْفٌ۔",,,16914 16915,"حَدَّثَنَا عَبدَۃ بن سلیمان ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ عَن سعید بْنِ الْمُسَیَّبِ وَعَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ قَالاَ : تُسْتَبْرَأُ الأَمَۃ بِحَیْضَتَیْنِ إذَا کَانَتْ تَحِیضُ۔",,,16915 16916,"حَدَّثَنَا شَرِیکٌ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ قَالَ : وُضِعَت عِنْدِی أَمَۃً تُسْتَبْرَأ فَحَاضَتْ حَیْضَۃً ثُمَّ ظَہَرَ لَہَا حَمْلٌ ، فَکَانَ یَسْتَبْرِئُہَا بِحَیْضَتَیْنِ۔",,,16916 16917,"حَدَّثَنَا ابْنُ عُلَیَّۃَ قَالَ سئلَ یُونُسَ، عَنِ الرَّجُلِ یَشْتَرِی الأَمَۃَ فَیَسْتَبْرِئُہَا، یُصِیبُ مِنْہَا الْقُبْلَۃَ وَالْمُبَاشَرَۃَ؟ قَالَ ابْنُ سِیرِینَ : یُکْرَہُ أَنْ یُصِیبَ مِنْہَا مَا یَحْرُمُ عَلَیْہِ مِنْ غَیْرِہَا حَتَّی یَسْتَبْرِئَہَا ، وَیَذْکُرُ ، عَنِ الْحَسَنِ أَنَّہُ کَانَ لاَ یَرَی بِالْقُبْلَۃِ بَأْسًا۔",,,16917 16918,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ الْمُبَارَکِ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ عِکْرِمَۃَ فِی الرَّجُلِ یَشْتَرِی الْجَارِیَۃَ الصَّغِیرَۃَ وَہِیَ أَصْغَرُ مِنْ ذَلِکَ قَالَ : لاَ بَأْسَ أَنْ یَمَسَّہَا قَبْلَ أَنْ یَسْتَبْرِئَہَا۔",,,16918 16919,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ إیَاسِ بْنِ مُعَاوِیَۃَ فِی رَجُلٍ اشْتَرَی جَارِیَۃً صَغِیرَۃً لاَ یُجَامَعُ مِثْلُہَا ؟ قَالَ : لاَ بَأْسَ أَنْ یَطَأَہَا وَلاَ یَسْتَبْرِئُہَا۔",,,16919 16920,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ أَنَّہُ کَرِہَ أَنْ یُقَبِّلَہَا حَتَّی یَسْتَبْرِئَہَا۔,,,16920 16921,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عَلِیِّ بْنِ زَیْدٍ ، عَنْ أَیُّوبَ اللَّخْمِیِّ قَالَ : وَقَعَتْ لابْنِ عُمَرَ جَارِیَۃٌ یَوْمَ جَلُولاَئَ فِی سَہْمِہِ ، کَأَنَّ فِی عُنُقِہَا إبْرِیقَ فِضَّۃٍ قَالَ : فَمَا مَلَکَ نَفْسَہُ أَنْ جَعَلَ یُقَبِّلُہَا وَالنَّاسُ یَنْظُرُونَ۔",,,16921 16922,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ أَسْلَمَ الْمُنْقِرِیِّ ، عَنْ عُبَیْدِ اللہِ بْنِ عُبَیْدِ بْنِ عُمَیْرٍ قَالَ : بَاعَ عَبْدُ الرَّحْمَنِ بْنُ عَوْفٍ جَارِیَۃً لَہُ کَانَ یَقَعُ عَلَیْہَا قَبْلَ أَنْ یَسْتَبْرِئَہَا فَظَہَرَ بِہَا حَمْلٌ عِنْدَ الَّذِی اشْتَرَاہَا فَخَاصَمَہُ إلَی عُمَرَ ، فَقَالَ عُمَرُ : کُنْت تَقَعُ عَلَیْہَا ؟ قَالَ : نَعَمْ ، قَالَ : فَبِعْتہَا قَبْلَ أَنْ تَسْتَبْرِئَہَا ؟ قَالَ : نَعَمْ ، قَالَ : مَا کُنْت لِذَلِکَ بِخَلِیقٍ ، فَدَعَا الْقَافَۃَ فَنَظَرُوا إلَیْہِ فَأَلْحَقُوہُ بِہِ۔",,,16922 16923,حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ أَنَّہُ کَانَ یَقُولُ یَسْتَبْرِئُ الرَّجُلُ أَمَتَہُ إذَا بَاعَہَا بِحَیْضَۃٍ ، وَإِذَا اشْتَرَاہَا بِحَیْضَۃٍ۔,,,16923 16924,"حَدَّثَنَا مُعْتَمِر بن سلیمان ، عَنْ کَثِیرِ بْنِ نُبَاتَۃ ، عَنِ ابْنِ سِیرِینَ قَالَ : إذَا اشْتَرَی الرَّجُلُ الْوَصِیفَۃَ فَلَمْ تَبْلُغِ الْحَیْضَ اسْتَبْرَأَہَا بِثَلاَثَۃِ أَشْہُرٍ فَإِذَا غَشِیَہَا فَأَرَادَ بَیْعَہَا فَلِیَسْتَبْرِئہَا أَیْضًا بِثَلاَثَۃِ أَشْہُرٍ۔",,,16924 16925,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَنْ إسْرَائِیلَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ قَالَ : إذَا أَرَادَ أَنْ یَبِیعَہَا فَلِیَسْتَبْرِئہَا۔",,,16925 16926,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ فِی الأَمَۃِ الَّتِی تُوطَأُ : إذَا بِیعَتْ ، أَوْ وُہِبَتْ ، أَوْ أُعْتِقَتْ فَلْتُسْتَبْرَأْ بِحَیْضَۃٍ۔",,,16926 16927,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ الْمُنْکَدِرِ سَمِعَ جَابِرًا یَقُولُ : کَانَتِ الْیَہُودُ تَقُولُ : إذَا أَتَی الرَّجُلُ امْرَأَتَہُ فِی قُبُلِہَا مِنْ دُبُرِہَا کَانَ الْوَلَدُ أَحْوَلَ فَنَزَلَتْ { نِسَاؤُکُمْ حَرْثٌ لَکُمْ}۔ (بخاری 4528۔ 1058)",,,16927 16928,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ زَائِدَۃَ بْنِ عُمَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ فِی قَوْلِہِ : (نِسَاؤُکُمْ حَرْثٌ لَکُمْ) قَالَ : مَنْ شَائَ أَنْ یَعْزِلَ فَلْیَعْزِلْ وَمَنْ شَائَ أَنْ لاَ یَعْزِلَ فَلاَ یَعْزِلْ۔",,,16928 16929,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ خَالِدٍ ، عَنْ عِکْرِمَۃَ قَالَ : یَأْتِیہَا کَیْفَ شَائَ قَائِمٌ وَقَاعِدٌ وَعَلَی کُلِّ حَالٍ یَأْتِیہَا مَا لَمْ یَکُنْ فِی دُبُرِہَا۔",,,16929 16930,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ إسْمَاعِیلَ ، عَنْ أَبِی صَالِحٍ {نِسَاؤُکُمْ حَرْثٌ لَکُمْ فَأْتُوا حَرْثَکُمْ أَنَّی شِئْتُمْ} قَالَ : إِنْ شِئْتَ فَأْتِہَا مُسْتَلْقِیَۃً ، وَإِنْ شِئْتَ فَمُتَحَرِّکَۃً ، وَإِنْ شِئْتَ فَبَارِکَۃً۔",,,16930 16931,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنِ الزِّبْرِقَانِ ، عَنْ أَبِی رَزِینٍ ، قَالَ : سَمِعْتُہُ یَقُولُ : {فَأْتُوا حَرْثَکُمْ أَنَّی شِئْتُمْ} قَالَ : مِنْ قِبَلِ الطُّہْرِ وَلاَ تَأْتُوہُنَّ مِنْ قِبَلِ الْحَیْضِ۔",,,16931 16932,"حَدَّثَنَا وَکِیعٌ ، عَنْ سَلَمَۃَ بْنِ نُبَیْطٍ ، عَنِ الضَّحَّاکِ فِی قَوْلِہِ : (نِسَاؤُکُمْ حَرْثٌ لَکُمْ فَأْتُوا حَرْثَکُمْ أَنَّی شِئْتُمْ) قَالَ : طُہْرًا غَیْرَ حُیَّضٍ۔",,,16932 16933,"حَدَّثَنَا عبد الرحمن بن محمد الْمُحَارِبِیُّ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ فِی قَوْلِہِ : (نِسَاؤُکُمْ حَرْثٌ لَکُمْ فَأْتُوا حَرْثَکُمْ أَنَّی شِئْتُمْ) قَالَ : ظَہْرٌ بِبَطْنٍ کَیْفَ شِئْت إلاَّ فِی دُبُرٍ ، أَوْ مَحِیضٍ۔",,,16933 16934,"حَدَّثَنَا قَبِیصَۃُ قَالَ : أَخْبَرَنَا سُفْیَانُ ، عَنْ عَبْدِ اللہِ بْنِ عُثْمَانَ بْنِ خُثَیْمٍ ، عَنِ ابْنِ سَابِطٍ ، عَنْ حَفْصَۃَ ، عَنْ أُمِّ سَلَمَۃَ قَالَتْ : لَمَّا قَدِمَ الْمُہَاجِرُونَ الْمَدِینَۃَ تَزَوَّجُوا فِی الأَنْصَارِ فَکَانُوا یُجَبُّونَہُنَّ ، وَکَانَتِ الأَنْصَارُ لاَ تَفْعَلُ ذَلِکَ ، فَقَالَتِ امْرَأَۃٌ مِنْہُنَّ لِزَوْجِہَا : حَتَّی أَسْأَلَ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَاسْتَحْیَتْ أَنْ تَسْأَلَہُ فَسَأَلْتُہُ ؟ فَدَعَاہَا فَقَرَأَ عَلَیْہَا : {نِسَاؤُکُمْ حَرْثٌ لَکُمْ فَأْتُوا حَرْثَکُمْ أَنَّی شِئْتُمْ} صِمَامًا وَاحِدًا۔\n\n(ترمذی 2979۔ احمد 6/310)",,,16934 16935,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنِ الْحُصَیْنِ ، عَنْ مُرَّۃَ الْہَمْدَانِیِّ أَنَّ بَعْضَ الْیَہُودِ لقی بَعْضَ الْمُسْلِمِینَ قَالَ : تَأْتُونَ النِّسَائَ وَرَائَہُنَّ ؟ قَالَ : کَأَنَّہُ کَرِہَ الإِبْرَاکَ قَالَ : فَذَکَرُوا ذَلِکَ فَنَزَلَتْ ہَذِہِ الآیَۃُ : {نِسَاؤُکُمْ حَرْثٌ لَکُمْ فَأْتُوا حَرْثَکُمْ أَنَّی شِئْتُمْ} فَرَخَّصَ اللَّہُ لِلْمُسْلِمِینَ أَنْ یَأْتُوا النِّسَائَ فِی الْفُرُوجِ کَیْفَ شَاؤُوا وأنی شَاؤُوا مِنْ بَیْنِ أَیْدِیہِنَّ ، وَإِنْ شَاؤُوا مِنْ خَلْفِہِنَّ۔",,,16935 16936,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنْ مُرَّۃَ : {فَأْتُوا حَرْثَکُمْ أَنَّی شِئْتُمْ} قَالَ : کَانَتِ الْیَہُودُ یَسْخَرُونَ مِنَ الْمُسْلِمِینَ فِی إتْیَانِہِمَ النِّسَائَ فَأَنْزَلَ اللَّہُ تَبَارَکَ وَتَعَالَی : {نِسَاؤُکُمْ حَرْثٌ لَکُمْ فَأْتُوا حَرْثَکُمْ أَنَّی شِئْتُمْ} فِی الْفُرُوجِ أَنَّی شِئْتُمْ۔",,,16936 16937,"حَدَّثَنَا مُحَمَّدُ بْنُ الْحَسَنِ قَالَ : حدَّثَنَا شَرِیکٌ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ فِی قولہ تعالی : {نِسَاؤُکُمْ حَرْثٌ لَکُمْ فَأْتُوا حَرْثَکُمْ أَنَّی شِئْتُمْ} قَالَ : یَأْتِیہَا مِنْ بَیْنِ یَدَیْہَا وَمِنْ خَلْفِہَا مَا لَمْ یَکُنْ فِی الدُّبُرِ",,,16937 16938,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لیث عن عِیسَی بْنِ سِنَان ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ فِی قَوْلِہِ : {نِسَاؤُکُمْ حَرْثٌ لَکُمْ فَأْتُوا حَرْثَکُمْ أَنَّی شِئْتُمْ} قَالَ : إِنْ شِئْتَ فَاعْزِلْ ، وَإِنْ شِئْتَ فَلاَ تَعْزِلْ۔",,,16938 16939,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ عَلِیٍّ قَالَ سَمِعْت الْحَسَنَ یَقُولُ : کَانَ الْمُشْرِکُونَ لاَ یَأْلُونَ مَا شَدَّدُوا عَلی الْمُسْلِمِینَ وَیَقُولُونَ : لاَ یَحِلُّ لَکُمْ أَنْ تَأْتُوا النِّسَائَ إلاَّ مِنْ وَجْہٍ وَاحِدٍ فَأَنْزَلَ اللَّہُ تَعَالَی : { فَأْتُوا حَرْثَکُمْ أَنَّی شِئْتُمْ}۔",,,16939 16940,"حَدَّثَنَا وَکِیعٌ ، عَنْ خَالِدِ بْنِ رَبَاحٍ ، عَنْ عِکْرِمَۃَ قَالَ : مِنْ قِبَلِ الْفَرْجِ۔",,,16940 16941,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی حَنِیفَۃَ ، عَنْ کَثِیرٍ الرَّمَّاحِ ، عَنْ أَبِی ذِرَاعٍ قَالَ : سَأَلْتُ ابْنَ عُمَرَ ، عَنْ قَوْلِہِ : (فَأْتُوا حَرْثَکُمْ أَنَّی شِئْتُمْ) قَالَ : إِنْ شِئْتَ عَزْلاً ، وَإِنْ شِئْتَ غَیْرُ عَزْلٍ۔",,,16941 16942,"حَدَّثَنَا شَبَابَۃُ ، عَنْ وَرْقَائَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ فِی قولہ تعالی : (فَأْتُوا حَرْثَکُمْ أَنَّی شِئْتُمْ) قَالَ : آتُوا النِّسَائَ فِی أَقْبَالِہِنَّ عَلَی کُلِّ نَحْوٍ۔",,,16942 16943,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ ، عَنْ عِکْرِمَۃَ : {فَأْتُوہُنَّ مِنْ حَیْثُ أَمَرَکُمُ اللَّہُ} قَالَ : مِنْ حَیْثُ أَمَرَکُمْ أَنْ تَعْتَزِلُوا۔",,,16943 16944,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ أَبِیہِ ، عَنْ یَزِیدَ بْنِ الْوَلِیدِ ، عَنْ إبْرَاہِیمَ {فَأْتُوہُنَّ مِنْ حَیْثُ أَمَرَکُمُ اللَّہُ} قَالُوا: فِی الْفُرُوجِ۔",,,16944 16945,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنْ مُجَاہِدٍ قَالَ : مِنْ حَیْثُ أَمَرَکُمَ اللَّہُ أَنْ تَعْتَزِلُوہُنَّ فِی الْمَحِیضِ۔",,,16945 16946,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ الأَزْرَقِ ، عَنِ ابْنِ الْحَنَفِیَّۃِ : {فَأْتُوْھُنَّ مِنْ حَیْثُ أَمَرَکُمُ اللّٰہُ} قَالَ : مِنْ قِبَلِ التَّزْوِیجِ ، مِنْ قِبَلِ الْحَلاَلِ۔",,,16946 16947,"حَدَّثَنَا شَبَابَۃُ ، عَنْ وَرْقَائَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ : {فَأْتُوْھُنَّ مِنْ حَیْثُ أَمَرَکُمُ اللّٰہُ} قَالَ : أُمِرُوا بِاعْتِزَالِ النِّسَائِ فِی الْمَحِیضِ ، فَأْتُوہُنَّ مِنْ حَیْثُ أَمَرَکُمَ اللَّہُ إذَا تَطَہَّرْنَ مِنْ حَیْثُ نُہُوا عَنْہُنَّ فِی مَحِیضِہِنَّ۔",,,16947 16948,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ أَبِی رَزِینٍ : {فَأْتُوْھُنَّ مِنْ حَیْثُ أَمَرَکُمُ اللّٰہُ} قَالَ : مِنْ قِبَلِ الطُّہْرِ۔",,,16948 16949,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ رُفَیْعٍ ، عَنِ ابن أَبِی مُلَیْکَۃَ قَالَ : نَزَلَتْ ہَذِہِ الآیَۃُ : {وَلَنْ تَسْتَطِیعُوا أَنْ تَعْدِلُوا بَیْنَ النِّسَائِ وَلَوْ حَرَصْتُمْ} فِی عَائِشَۃَ۔",,,16949 16950,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنْ مُحَمَّدٍ ، عَنْ عَبِیْدَۃَ قَالَ : الْحُبُّ وَالْجِمَاعُ۔",,,16950 16951,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ عَمْرِو بْنِ الْحَسَنِ قَالَ : فِی الْحُبِّ {فَلاَ تَمِیلُوا کُلَّ الْمَیْلِ} قَالَ : فِی الْغَشَیَانِ {فَتَذَرُوہَا کَالْمُعَلَّقَۃِ} قَالَ : لاَ أَیِّمَ وَلاَ ذَاتَ زَوْجٍ۔",,,16951 16952,"حَدَّثَنَا عَلِیُّ بْنُ حَسَن بْنُ شَقِیقٍ قَالَ : أَخْبَرَنَا حُسَیْنُ بْنُ وَاقِدٍ قَالَ : حدَّثَنَا یَزِیدُ النَّحْوِیُّ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ فِی قَوْلِہِ : {فَتَذَرُوہَا کَالْمُعَلَّقَۃِ} قَالَ : لاَ مُطَلَّقَۃً وَلاَ ذَاتَ بَعْلٍ۔",,,16952 16953,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : قَالَ عُمَرُ : إذَا أَغْلَقُوا بَابًا وَأَرْخَوْا سِتْرًا ، أَوْ کَشَفُوا خِمَارًا فَقَدْ وَجَبَ الصَّدَاقُ۔",,,16953 16954,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، عَنْ عُمَرَ بِمِثْلِہِ ، زَادَ فِیہِ : وَخَلاَ بِہَا۔",,,16954 16955,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ مَنْصُورٍ ، عَنِ الْمِنْہَالِ بْنِ عَمْرٍو ، عَنْ عَبَّادِ بْنِ عَبْدِ اللہِ ، قَالَ : قَالَ عَلِیٌّ : إذَا أَرْخَی سِتْرًا عَلَی امْرَأَتِہِ وَأَغْلَقَ بَابًا وَجَبَ الصَّدَاقُ۔",,,16955 16956,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنِ الْمِنْہَالِ بْنِ عَمْرٍو ، عَنْ حَیَّانَ بْنِ مَرْثَدٍ ، عَنْ عَلِیٍّ مِثْلَہُ۔,,,16956 16957,"حَدَّثَنَا عَبدَۃ بن سلیمان ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، عَنِ الأَحْنَفِ أَنَّ عُمَرَ وَعَلِیًّا قَالاَ : إذَا أَغْلَقَ بَابًا ، أَوْ أَرْخَی سِتْرًا فَلَہَا الصَّدَاقُ وَعَلَیْہَا الْعِدَّۃُ۔",,,16957 16958,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی الزِّنَادِ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ أَنَّ رَجُلاً تَزَوَّجَ امْرَأَۃً ، فَقَالَ عِنْدَہَا فَأَرْسَلَ مَرْوَانُ إلَی زَیْدٍ ، فَقَالَ : لَہَا الصَّدَاقُ کَامِلاً ، فَقَالَ مَرْوَانُ : إنَّہُ مِمَّنْ لاَ یُتَّہَمُ ، فَقَالَ لَہُ زَیْدٌ : لَوْ أَنَّہَا جَائَتْ بِحَمْلٍ ، أَوْ بِوَلَدٍ أَکُنْت تُقِیمُ عَلَیْہَا الْحَدَّ ؟۔",,,16958 16959,"حَدَّثَنَا ابْنُ فُضَیْلٍ، عَنْ حَجَّاجٍ، عَنْ مَکْحُولٍ قَالَ: اجْتَمَعَ نَفَرٌ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عُمَرُ وَمُعَاذٌ : أَنَّہُ إذَا أَغْلَقَ الْبَابَ وَأَرْخَی السِّتْرَ فَقَدْ وَجَبَ الصَّدَاقُ۔",,,16959 16960,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَوْفٍ ، عَنْ زُرَارَۃَ بْنِ أَوْفَی ، قَالَ : سَمِعْتُہُ یَقُولُ : قضَی الْخُلَفَائُ الرَّاشِدُونَ الْمَہْدِیُّونَ أَنَّہُ مَنْ أَغْلَقَ بَابًا ، أَوْ أَرْخَی سِتْرًا فَقَدْ وَجَبَ الْمَہْرُ وَوَجَبَتِ الْعِدَّۃُ۔",,,16960 16961,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : قَالَ عُمَرُ : إذَا أُرْخِیَتِ السُّتُورُ فَقَدْ وَجَبَ الصَّدَاقُ۔",,,16961 16962,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ قَالَ : حدَّثَنِی نَافِعُ بْنُ جُبَیْرِ بْنِ مُطْعِمٍ ، عَنْ رَجُلٍ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : إذَا أَرْخَی سِتْرًا ، أَوْ أَغْلَقَ بَابًا فَقَدْ وَجَبَ الصَّدَاقُ۔",,,16962 16963,"حَدَّثَنَا وَکِیعٌ ، عَنْ جَعْفَرٍ الأَحْمَرِ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ أَبِی الْبَخْتَرِیِّ ، عَنْ عَلِیٍّ قَالَ : إذَا أَغْلَقَ بَابًا أو أَرْخَی سِتْرًا أو خَلَی فَلَہَا الصَّدَاقُ۔",,,16963 16964,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنِ ابن سَالِمٍ ، عَنِ الشَّعْبِیِّ ، عَنْ عُمَرَ وَعَلِیٍّ قَالاَ : إذَا أَرْخَی سِتْرًا ، أَوْ خَلَی وَجَبَ الْمَہْرُ وَعَلَیْہَا الْعِدَّۃُ۔",,,16964 16965,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ مَطَرٍ ، عَنْ حیان ، عَنْ جَابِرٍ أنہ قَالَ : إذَا نَظَرَ إلَی فَرْجِہَا ثُمَّ طَلَّقَہَا فَلَہَا الصَّدَاقُ وَعَلَیْہَا الْعِدَّۃُ۔",,,16965 16966,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ قَالَ : إذَا أُجِیفَت الأَبْوَابُ وَأُرْخِیَت السُّتُورُ وَجَبَ الصَّدَاقُ۔",,,16966 16967,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : إذَا اطَّلَعَ مِنْہَا عَلَی مَا لاَ یَحِلُّ لِغَیْرِہِ وَجَبَ لہا الصَّدَاقُ وَعَلَیْہَا الْعِدَّۃُ۔",,,16967 16968,حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ مُبَارَکٍ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ ثَوْبَانَ أَنَّ رَجُلاً اجْتَلَی امْرَأَتَہُ فِی طَرِیقٍ فَجَعَلَ لَہَا عُمَرُ الصَّدَاقَ کَامِلاً۔,,,16968 16969,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، عَنْ فِرَاسٍ ، عَنِ الشَّعْبِیِّ ، عَنِ ابْنِ مَسْعُودٍ قَالَ : لَہَا نِصْفُ الصَّدَاقِ ، وَإِنْ جَلَسَ بَیْنَ رِجْلَیْہَا۔",,,16969 16970,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إذَا طَلَّقَ قَبْلَ أَنْ یَدْخُلَ فَلَہَا نِصْفُ الصَّدَاقِ ، وَإِنْ کَانَ قَدْ خَلَی بِہَا۔",,,16970 16971,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لَہَا نِصْفُ الصَّدَاقِ۔",,,16971 16972,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنِ الشَّعْبِیِّ أَنَّ رَجُلاً قَالَ لِشُرَیْحٍ : إنِّی تَزَوَّجْت امْرَأَۃً فَمَکَثَتْ عِنْدِی ثَمَانَ سِنِینَ ثُمَّ طَلَّقْتُہَا وَہِیَ عَذْرَائُ قَالَ : لَہَا نِصْفُ الصَّدَاقِ۔",,,16972 16973,"حَدَّثَنَا وَکِیعٌ ، عَنْ زَکَرِیَّا ، عَنِ الشَّعْبِیِّ قَالَ : لَہَا نِصْفُ الصَّدَاقِ۔",,,16973 16974,"حَدَّثَنَا أَبُو بَکْرٍ ، عَنْ أَبِی بَکْرِ بْنِ عَیَّاشٍ ، عَنِ مَنصُور ، عَنِ الْحَکَمِ ، عَنْ عَلِیٍّ قَالَ : إذَا فَقَدَتْ زَوْجَہَا لَمْ تُزَوَّجْ حَتَّی یقبل أَو أن یَمُوتَ۔",,,16974 16975,"حَدَّثَنَا عَبْدُ الأَعْلَی، عَنْ سَعِیدٍ، عَنْ أَیُّوبَ، عَنْ أَبِی قِلاَبَۃَ قَالَ: لَیْسَ لَہَا أَنْ تُزَوَّجَ حَتَّی تَبَیَّنَ لَہَا مَوْتُہُ۔",,,16975 16976,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ فِی امْرَأَۃٍ تَفْقِدُ زَوْجَہَا ، أَوْ یَأْخُذُہُ الْعَدُوُّ ، قَالَ : تَصْبِرُ فَإِنَّمَا ہِیَ امْرَأَتُہُ ، یُصِیبُہَا مَا أَصَابَ النِّسَائَ حَتَّی یَجِیئَ زَوْجُہَا ، أَوْ یَبْلُغَہَا إِنَّہُ مَاتَ۔",,,16976 16977,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ جَابِرٍ، عَنِ الشَّعْبِیِّ قَالَ: لاَ تُزَوَّجُ امْرَأَۃُ الْمَفْقُودِ حَتَّی یَرْجِعَ، أَوْ یَمُوتَ۔",,,16977 16978,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَبِیبٍ ، عَنْ عَمْرِو بْنِ ہَانِئٍ قَالَ : سُئِلَ جَابِرُ بْنُ زَیْدٍ ، عَنِ امْرَأَۃٍ غَابَ زَوْجُہَا عَنْہَا زَمَانًا لاَ تَعْلَمُ لَہُ بِمَوْتٍ وَلاَ حَیَاۃٍ قَالَ : تَرَبَّصُ حَتَّی تَعْلَمَ حَیٌّ ہُوَ أَمْ مَیِّتٌ۔",,,16978 16979,"حَدَّثَنَا أَبُو أُسَامَۃَ، عَنْ ہِشَامٍ، عَنْ مُحَمَّدٍ قَالَ: لاَ تُزَوَّجُ امْرَأَۃُ الْمَفْقُودِ حَتَّی یَأْتِیَہَا یَقِینُ مَوْتِ زَوْجِہَا۔",,,16979 16980,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ وَحَمَّادٍ فِی امْرَأَۃِ الْمَفْقُودِ قَالاَ : لاَ تُزَوِّجُ أَبَدًا حَتَّی یَأْتِیَہَا الْخَبَرُ۔",,,16980 16981,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ مِثْلَہُ۔,,,16981 16982,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ أَنَّ عُمَرَ بْنَ الْخَطَّابِ وَعُثْمَانَ بْنَ عَفَّانَ قَالاَ : فِی امْرَأَۃِ الْمَفْقُودِ : تَرَبَّصُ أَرْبَعَ سِنِینَ وَتَعْتَدُّ أَرْبَعَۃَ أَشْہُرٍ وَعَشْرًا۔",,,16982 16983,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مَنْصُورٍ قَالَ : حدَّثَنَا مُجَاہِدٌ فِی غرقۃ الْمِنْہَالِ بْنِ عَمْرٍو ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عُمَرَ بْنِ الْخَطَّابِ أَنَّہُ قَالَ فِی امْرَأَۃِ الْمَفْقُودِ : تَرَبَّصُ أربع سِنِینَ ثُمَّ یُدْعَی وَلِیُّہُ فَیُطَلِّقُہَا فَتَعْتَدُّ بَعْدَ ذَلِکَ أَرْبَعَۃَ أَشْہُرٍ وَعَشْرًا۔",,,16983 16984,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ دَاوُدَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ فِی الْفَقِیدِ بَیْنَ الصَّفَّیْنِ قَالَ : تَعْتَدُّ امْرَأَتُہُ سَنَۃً۔",,,16984 16985,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ یَحْیَی بْنِ جَعْدَۃَ أَنَّ رَجُلاً انتَسَفَتْہُ الْجِنُّ عَلَی عَہْدِ عُمَرَ فَأَتَتِ امْرَأَتُہُ عُمَرَ فَأَمَرَہَا أَنْ تَرَبَّصَ أَرْبَعَ سِنِینَ ثُمَّ أَمَرَ وَلِیَّہُ بَعْدَ أَرْبَعِ سِنِینَ أَنْ یُطَلِّقَہَا ثُمَّ أَمَرَہَا أَنْ تَعْتَدَّ فَإِذَا انْقَضَتْ عِدَّتُہَا تَزَوَّجَتْ فَإِنْ جَائَ زَوْجُہَا خُیِّرَ بَیْنَ امْرَأَتِہِ وَالصَّدَاقِ۔,,,16985 16986,"حَدَّثَنَا حَفْصٌ ، عَنْ دَاوُدَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ فِی الْفَقِیدِ بَیْنَ الصَّفَّیْنِ : تَرَبَّصُ امْرَأَتُہُ سَنَۃً۔",,,16986 16987,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ خَالِدٍ ، عَنْ أَبِی نَضْرَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی قَالَ : شَہِدْت عُمَرَ خَیَّرَ مَفْقُودًا تَزَوَّجَتِ امْرَأَتُہُ بَیْنَہَا وَبَیْنَ الْمَہْرِ الَّذِی سَاقَہُ إلَیْہَا۔",,,16987 16988,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ أَنَّ عُمَرَ وَعُثْمَانَ بْنَ عَفَّانَ قَالاَ : إِنْ جَائَ زَوْجُہَا خُیِّرَ بَیْنَ امْرَأَتِہِ وَبَیْنَ الصَّدَاقِ الأَوَّلِ۔",,,16988 16989,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ سُئِلَ عُمَرُ ، عَنْ رَجُلٍ غَابَ ، عَنِ امْرَأَتِہِ فَبَلَغَہَا أَنَّہُ مَاتَ فَتَزَوَّجَتْ ثُمَّ جَائَ الزَّوْجُ الأَوَّلُ ، فَقَالَ عُمَرُ : یُخَیَّرُ الزَّوْجُ الأَوَّلُ بَیْنَ الصَّدَاقِ وَامْرَأَتِہِ فَإِنَ اخْتَارَ الصَّدَاقَ تَرَکَہَا مَعَ الزَّوْجِ الآخَرِ ، وَإِنْ شَائَ اخْتَارَ امْرَأَتَہُ وَقَالَ عَلِیٌّ : لَہَا الصَّدَاقُ بِمَا اسْتَحَلَّ الآخَرُ مِنْ فَرْجِہَا وَیُفَرَّقُ بَیْنَہُ وَبَیْنَہَا ثُمَّ تَعْتَدُّ ثَلاَثَ حِیَضٍ ثُمَّ تُرَدُّ عَلَی الأَوَّلِ۔",,,16989 16990,"حَدَّثَنَا جَرِیرٌ ، عَنْ عَطَائِ بْنِ السَّائِبِ قَالَ : جَائَ رَجُلٌ إلَی إبْرَاہِیمَ ، فَقَالَ : إنَّہُ تَزَوَّجَ امْرَأَۃً کَانَ نُعِیَ إلَیْہَا زَوْجُہَا ، إِنَّہُ جَائَ کِتَابٌ مِنْہُ أَنَّہُ حَیٌّ ، فَقَالَ لہ إبْرَاہِیمُ : اعْتَزِلْہَا فَإِذَا قَدِمَ فَإِنْ شَائَ اخْتَارَ الَّذِی أَصْدَقَہَا وکَانَت امْرَأَتَکَ عَلَی حَالِہَا ، وَإِنِ اخْتَارَ الْمَرْأَۃَ فَإِذا انْقَضَتْ عِدَّتُہَا مِنْک فَہِیَ أمْرَأَۃُ الأَوَّلِ وَلَہَا مَا أَصْدَقَہَا بِمَا اسْتَحَلَّ مِنْ فَرْجِہَا قَالَ : فَأُواکِلُہَا ؟ قَالَ : نَعَمْ وَلاَ تَدْخُلُ عَلَیْہَا حَتَّی تُؤْذِنَہَا۔",,,16990 16991,"حَدَّثَنَا ابْنُ نُمَیْرٍ قَالَ حَدَّثَنَا ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ أَبِی الْمَلِیحِ ، عَنْ سُہَیۃَ ابْنَۃِ عُمَیْرٍ الشَّیْبَانِیَّۃِ قَالَتْ : نُعِیَ إلَیَّ زَوْجِی مِنْ قَنْدَابِیلَ فَتَزَوَّجْت بَعْدَہُ الْعَبَّاسَ بْنَ طَرِیفٍ أَخَا بَنِی قَیْسٍ ، فَقَدِمَ زَوْجِی الأَوَّلُ فَانْطَلَقْنَا إلَی عُثْمَانَ وَہُوَ مَحْصُورٌ ، فَقَالَ : کَیْفَ أَقْضِی بَیْنَکُمْ وأنا عَلَی حَالِی ہَذِہِ ؟ قُلْنَا : قَدْ رَضِینَا بِقَضَائِکَ فَخَیَّرَ الزَّوْجَ بَیْنَ الصَّدَاقِ وَبَیْنَ الْمَرْأَۃِ فَلَمَّا أُصِیبَ عُثْمَانُ انْطَلَقْنَا إلَی عَلِیٍّ وَقَصَصْنَا عَلَیْہِ الْقِصَّۃَ فَخَیَّرَ الزَّوْجَ الأَوَّلَ بَیْنَ الصَّدَاقِ وَبَیْنَ الْمَرْأَۃِ فَاخْتَارَ الصَّدَاقَ فَأَخَذَ مِنِّی أَلْفَیْنِ وَمِنَ الآخَرِ أَلْفَیْنِ۔",,,16991 16992,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ سَیَّارٍ ، عَنِ الشَّعْبِیِّ قَالَ : امْرَأَۃُ الْمَفْقُودِ امْرَأَۃُ الأَوَّلِ۔",,,16992 16993,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُمَرَ بْنِ حَمْزَۃَ ، قَالَ : سَمِعْتُ الْقَاسِمَ بْنَ مُحَمَّدٍ یَقُولُ : قَضَی فِینَا ابْنُ الزُّبَیْرِ فِی مَوْلاَۃٍ لَہُمْ کَانَ زَوْجُہَا قَدْ نُعِیَ فَزُوِّجَتْ ثُمَّ جَائَ زَوْجُہَا ، فَقَضَی أَنَّ زَوْجَہَا الأَوَّلَ یُخَیَّرُ إِنْ شَائَ امْرَأَتَہُ، وَإِنْ شَائَ صَدَاقَہُ ، قَالَ عُمَرُ : وَکَانَ الْقَاسِمُ یَقُولُ ذَلِکَ۔",,,16993 16994,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ دَاوُدَ ، عَنِ الْعَبَّاسِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ حُمَید بْنِ عَبْدِ الرَّحْمَنِ أَنَّ عُمَرَ خَیَّرَ الْمَفْقُودَ وَقَدْ تَزَوَّجَتِ امْرَأَتُہُ ، فَاخْتَارَ الْمَالَ فَجَعَلَہُ عَلَی زَوْجِہَا الأَحْدَثِ قَالَ حُمَیْدٌ : فَدَخَلْتُ عَلَی الْمَرْأَۃِ الَّتِی قَضَی فِیہَا ہَذَا ، فَقَالَتْ : فَأَعَنْتُ زَوْجِی الآخَرَ بِوَلِیدَۃٍ۔",,,16994 16995,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ خَالِدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ أَنَّ عَلِیًّا قَالَ : لَیْسَ بِزَوْجٍ یَعْنِی السَّیِّدَ۔",,,16995 16996,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ إسْمَاعِیلَ بْنِ سَالِمٍ قَالَ سَمِعْت الشَّعْبِیَّ یَقُولُ : لَیْسَ بِزَوْجٍ۔",,,16996 16997,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ کَانَ یَقُولُ یَقُولُ : لَیْسَ بِزَوْجٍ۔",,,16997 16998,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، عَنْ زَیْدٍ قَالَ : ہُوَ زَوْجٌ إذَا لَمْ یُرِدِ الإِحْلاَلَ۔",,,16998 16999,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ خَالِدٍ ، عَنْ مَرْوَانَ الأَصْفَرِ ، عَنْ أَبِی رَافِعٍ أَنَّ عُثْمَانَ بْنَ عَفَّانَ سُئِلَ عَنْ ذَلِکَ وَعِنْدَہُ عَلِیٌّ وَزَیْدُ بْنُ ثَابِتٍ ، قَالَ : فَرَخَّصَ فِی ذَلِکَ عُثْمَانُ وَزَیْدٌ ، قَالاَ : ہُوَ زَوْجٌ ، فَقَامَ عَلِیٌّ مُغْضَبًا کَارِہًا لِمَا قَالاَ۔",,,16999 17000,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ قَالَ : ہُوَ زَوْجٌ یقول السَّیِّدَ۔",,,17000 17001,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ قَالَ : سَأَلْتُ حَمَّادًا ، عَنْ رَجُلٍ تَحْتَہُ أَمَۃٌ فَطَلَّقَہَا تَطْلِیقَتَیْنِ ثُمَّ یَغْشَاہَا سَیِّدُہَا ، ہَلْ تَرْجِعُ إلَی زَوْجِہَا ؟ فَکَرِہَ ذَلِکَ۔",,,17001 17002,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَبِیبٍ ، عَنْ عَمْرِو بْنِ ہَرِمٍ قَالَ : سُئِلَ جَابِرُ بْنُ زَیْدٍ ، عَنْ رَجُلٍ کَانَتْ لَہُ امْرَأَۃٌ مَمْلُوکَۃٌ فَطَلَّقَہَا ثُمَّ إنَّ سَیِّدَہَا تَسَرَّاہَا ثُمَّ تَرَکَہَا ، أَتَحِلُّ لِزَوْجِہَا الَّذِی طَلَّقَہَا أَن یراجعہا ؟ قَالَ : لاَ تَحِلُّ لَہُ حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ۔",,,17002 17003,حَدَّثَنَا عَبدَۃ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ أن زَیْدِ بْنِ ثَابِتٍ وَالزُّبَیْرِ بْنِ الْعَوَّامِ ، کَانَا لاَ یَرَیَانِ بَأْسًا إذَا طَلَّقَ الرَّجُلُ امْرَأَتَہُ وَہِیَ أَمَۃٌ تَطْلِیقَتَیْنِ ثُمَّ غَشِیَہَا سَیِّدُہَا غشیانا لاَ یُرِیدُ بِذَلِکَ مُخَادَعَۃً وَلاَ إحْلاَلاً أَنْ تَرْجِعَ إلَی زَوْجِہَا بخطبۃ۔,,,17003 17004,"حَدَّثَنَا عَبدَۃ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إِبرَاہِیمَ فِی الأَمَۃِ یُطَلِّقُہَا زَوْجُہَا تَطْلِیقَتَیْنِ ثُمَّ یَغْشَاہَا سَیِّدُہَا : إنَّہَا لاَ تَحِلُّ لِزَوْجِہَا حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ۔",,,17004 17005,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ قَالَ : إذَا طَلَّقَہَا تَطْلِیقَتَیْنِ ثُمَّ وَطِئَہَا السَّیِّدُ تَزَوَّجَہَا إِنْ شَائَ۔",,,17005 17006,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ سُفْیَانَ ، عَنْ أَبِی الزِّنَادِ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ ، عَنْ زَیْدِ بْنِ ثَابِتٍ أَنَّ مَرْوَانَ سَأَلَہُ عَنْہَا فَکَرِہَہَا۔,,,17006 17007,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ، عَنْ عَبْدِالْکَرِیمِ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ: لاَ یَتَزَوَّجُ حَتَّی تَنْقَضِیَ عِدَّۃُ الَّتِی طَلَّقَ۔",,,17007 17008,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ ، عَنْ عَبِیْدَۃَ ؛ فِی رَجُلٍ طَلَّقَ امْرَأَتَہُ وَلَہُ أَرْبَعُ نِسْوَۃٍ قَالَ : لاَ یَحِلُّ لَہُ أَنْ یَتَزَوَّجَ الْخَامِسَۃَ حَتَّی تَنْقَضِیَ عِدَّۃُ الَّتِی طَلَّقَ۔",,,17008 17009,"حَدَّثَنَا عَائِذُ بْنُ حَبِیبٍ ، عَنْ حَجَّاجٍ ، عَنِ الشَّعْبِیِّ ، عَنْ عَلِیٍّ قَالَ : لاَ یَتَزَوَّجُ خَامِسَۃً حَتَّی تَنْقَضِیَ عِدَّۃُ الَّتِی طَلَّقَ۔",,,17009 17010,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ قَالَ : لاَ یَتَزَوَّجُ حَتَّی تَنْقَضِیَ عِدَّۃُ الَّتِی طَلَّقَ ، قَالَ عَطَائٌ : إذَا لَمْ یَکُنْ بَیْنَہُمَا مِیرَاثٌ وَلَمْ یَکُنْ عَلَیْہَا رَجْعَۃٌ فَلاَ بَأْسَ أَنْ یَتَزَوَّجَ۔",,,17010 17011,"حَدَّثَنَا عَبَّادُ بْنُ عَوَّامٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ أَنَّہُ سُئِلَ عَنْ رَجُلٍ کَانَ لَہُ أَرْبَعُ نِسْوَۃٍ فَطَلَّقَ إحْدَاہُنَّ ثَلاَثًا ، أَیَتَزَوَّجُ خَامِسَۃً ؟ قَالَ : لاَ حَتَّی تَنْقَضِیَ عِدَّۃُ الَّتِی طَلَّقَ",,,17011 17012,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ قَالَ : لاَ یَتَزَوَّجُ حَتَّی تَنْقَضِیَ عِدَّۃُ الَّتِی طَلَّقَ ، وَقَالَ عَطَائٌ : إذَا لَمْ یَکُنْ بَیْنَہُمَا مِیرَاثٌ وَلَمْ یَکُنْ لَہُ عَلَیْہَا رَجْعَۃٌ فَلاَ بَأْسَ أَنْ یَتَزَوَّجَ۔",,,17012 17013,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ أَنَّہُ کَانَ یَکْرَہُ أَنْ یَتَزَوَّجَ حَتَّی تَنْقَضِیَ عِدَّۃُ الَّتِی طَلَّقَ۔,,,17013 17014,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ مُبَارَکٍ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ مُحَمَّدِ بْنِ إبْرَاہِیمَ التَّیْمِیِّ أَنَّ عُتْبَۃَ بْنَ أَبِی سُفْیَانَ کَانَتْ عِنْدَہُ أَرْبَعُ نِسْوَۃٍ فَطَلَّقَ إحْدَاہُنَّ ثُمَّ تَزَوَّجَ خَامِسَۃً قَبل أَن تَنْقَضِیَ عِدَّۃُ الَّتِی طَلَّقَ فَسَأَلَ مَرْوَانُ ابْنَ عَبَّاسٍ ، فَقَالَ : لاَ حَتَّی تَنْقَضِیَ عِدَّۃُ الَّتِی طَلَّقَ۔",,,17014 17015,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ أَبِی صَادِقٍ قَالَ : لاَ یَتَزَوَّجُ خَامِسَۃً حَتَّی تَنْقَضِیَ عِدَّۃُ الَّتِی طَلَّقَ۔",,,17015 17016,") حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : إذَا کَانَتْ تَحْتَ الرَّجُلِ أَرْبَعُ نِسْوَۃٍ فَطَلَّقَ إحْدَاہُنَّ فَلاَ یَتَزَوَّجُ خَامِسَۃً حَتَّی تَنْقَضِیَ عِدَّۃُ الَّتِی طَلَّقَ فَإِنْ مَاتَتْ فَإِنْ شَائَ فَلْیَتَزَوَّجْ مِنْ یَوْمِہِ ذَلِکَ۔",,,17016 17017,"حَدَّثَنَا حَمَّاد بن خالد ، عَنْ مَالِکِ بن أَنس ، عَنْ رَبِیعَۃَ ، عَنِ الْقَاسِمِ وَعُرْوَۃَ بْنِ الزُّبَیْرِ أَنَّہُمَا قَالاَ : فِی الَّذِی عِنْدَہُ أَرْبَعُ نِسْوَۃٍ فَطَلَّقَ إحْدَاہُنَّ : یَتَزَوَّجُ مَتَی ما شَائَ۔",,,17017 17018,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، عَنْ عَلِیٍّ أَنَّہُ سُئِلَ عَنْ رَجُلٍ طَلَّقَ امْرَأَتَہُ فَلَمْ تَنْقَضِ عِدَّتُہَا حَتَّی تَزَوَّجَ أُخْتَہَا ، فَفَرَّقَ عَلِیٌّ بَیْنَہُمَا وَجَعَلَ لَہَا الصَّدَاقَ بِمَا اسْتَحَلَّ مِنْ فَرْجِہَا وَقَالَ : تُکْمِلُ الأُخْرَی عِدَّتَہَا وَہُوَ خَاطِبٌ فإنْ کَانَ دَخَلَ بِہَا فَلَہَا الصَّدَاقُ کَامِلاً وَعَلَیْہَا الْعِدَّۃُ کَامِلَۃً وَتَعْتَدَّانِ مِنْہُ جَمِیعًا ، کُلُّ وَاحِدَۃٍ ثَلاَث قُرُوئٍ ، فَإِنْ کَانَتَا لاَ تَحِیضَانِ فَثَلاَثَۃَ أَشْہُرٍ۔",,,17018 17019,حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ قَالَ طَلَّقَ رَجُلٌ امْرَأَۃً ثُمَّ تَزَوَّجَ أُخْتَہَا قَالَ ابْنُ عَبَّاسٍ لِمَرْوَانَ فَرِّقْ بَیْنَہُ وَبَیْنَہَا حَتَّی تَنْقَضِیَ عِدَّۃُ الَّتِی طَلَّقَ۔,,,17019 17020,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ قَالَ : إذَا نَکَحَ الرَّجُلُ الْمَرْأَۃَ ثُمَّ طَلَّقَہَا ثُمَّ تَزَوَّجَ أُخْتَہَا فِی عِدَّتِہَا ، قَالَ : نِکَاحُہُما حَرَامٌ وَیُفَرَّقُ بَیْنَہُمَا وَلاَ صَدَاقَ لَہَا وَلاَ عِدَّۃَ عَلَیْہَا۔",,,17020 17021,"حَدَّثَنَا وَکِیعٌ ، عَنْ زَکَرِیَّا قَالَ : سُئِلَ عَامِرٌ ، عَنْ رَجُلٍ نَکَحَ امْرَأَۃً ثُمَّ طَلَّقَہَا ثُمَّ تَزَوَّجَ أُخْتَہَا فِی عِدَّتِہَا ، قَالَ : یُفَرَّقُ بَیْنَہُمَا۔",,,17021 17022,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ قَالَ : کَانَ یَکْرَہُ إذَا کَانَت لَہُ امْرَأَۃٌ فَطَلَّقَہَا ثَلاَثًا کَرِہَ أَنْ یَتَزَوَّجَ أُخْتَہَا حَتَّی تَنْقَضِیَ عِدَّۃُ الَّتِی طَلَّقَ۔",,,17022 17023,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : لاَ یَتَزَوَّجُ الْمَرْأَۃَ فِی عِدَّۃِ أُخْتِہَا مِنْہُ۔",,,17023 17024,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا إذَا طَلَّقَ الرَّجُلُ امْرَأَتَہُ ثَلاَثًا أَنْ یَتَزَوَّجَ أُخْتَہَا فِی عِدَّتِہَا۔,,,17024 17025,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، وَسَعِیدِ بْنِ الْمُسَیَّبِ وَخِلاَسٍ فِی رَجُلٍ طَلَّقَ امْرَأَتَہُ ثَلاَثًا وَہِیَ حَامِلٌ ، قَالُوا : لاَ بَأْسَ أَنْ یَتَزَوَّجَ أُخْتَہَا فِی عِدَّتِہَا ، قَالَ : وَکَانَ عُبَیْدُ بْنُ نُضَیلَۃَ یَکْرَہُہُ حَتَّی ذُکِرَ ذلک لِلْحَسَنِ فَکَأَنَّہُ نَزَعَ عَنْہُ۔",,,17025 17026,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ عَاصِمٍ ، عَنِ الشَّعْبِیِّ ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تُنْکَحُ الْمَرْأَۃُ عَلَی عَمَّتِہَا وَلاَ خَالَتِہَا۔ (بخاری 5108۔ احمد 3/338)",,,17026 17027,"حَدَّثَنَا عبد اللہ بْنُ نُمَیْرٍ ، عَنِ ابْنِ إِسْحَاقَ ، عَنْ یَعْقُوبَ بْنِ عُتْبَۃَ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : لاَ تُنْکَحُ الْمَرْأَۃُ عَلَی خَالَتِہَا وَلاَ عَلَی عَمَّتِہَا۔",,,17027 17028,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ أَبِی حَصِینٍ ، عَنْ یَحْیَی ، عَنْ مَسْرُوقٍ ، عَنْ عَبْدِ اللہِ قَالَ : لاَ تُنْکَحُ الْمَرْأَۃُ عَلَی عَمَّتِہَا وَلاَ عَلَی خَالَتِہَا۔",,,17028 17029,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ أَنَّہُ قَالَ : لاَ تُنْکَحُ الْمَرْأَۃُ عَلَی عَمَّتِہَا وَلاَ عَلَی خَالَتِہَا۔",,,17029 17030,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تُنْکَحُ الْمَرْأَۃُ عَلَی عَمَّتِہَا وَلاَ عَلَی خَالَتِہَا وَلاَ تُنْکَحُ الْعَمَّۃُ عَلَی بِنْتِ أخیہا وَلاَ الْخَالَۃُ عَلَی بِنْتِ أُخْتِہَا وَلاَ تُزَوَّجُ الصُّغْرَی عَلَی الْکُبْرَی وَلاَ الْکُبْرَی عَلَی الصُّغْرَی۔ (ترمذ ی1126۔ ابوداؤد 2058)",,,17030 17031,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تُنْکَحُ الْمَرْأَۃُ عَلَی عَمَّتِہَا وَلاَ عَلَی خَالَتِہَا۔",,,17031 17032,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، قَالَ : سَمِعْتُ سَعِیدَ بْنَ الْمُسَیَّبِ یَقُولُ نُہی أَنْ تُنْکَحَ الْمَرْأَۃُ عَلَی عَمَّتِہَا أو عَلَی خَالَتِہَا أو یَطَأُ الرجل امْرَأَۃً فِی بَطْنِہَا جَنِینٌ لِغَیْرِہِ۔ (مالک 21)",,,17032 17033,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ : لاَ یَتَزَوَّجُ الرَّجُلُ عَمَّۃَ امْرَأَتِہِ وَلاَ خَالَتَہَا فَإِنْ طَلَّقَہَا فَلاَ یَتَزَوَّجُ وَاحِدَۃً مِنْہُنَّ حَتَّی تَنْقَضِیَ عِدَّتُہَا۔",,,17033 17034,"حَدَّثَنَا وَکِیعٌ ، عَنْ زَکَرِیَّا ، عَنِ الشَّعْبِیِّ قَالَ : سَأَلْتُہُ ، عَنِ امْرَأَۃٍ نُکِحَتْ عَلَی خَالَتِہَا مِنَ الرَّضَاعَۃِ قَالَ: یُفَرَّقُ بَیْنَہُمَا۔",,,17034 17035,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ قَالَ : لاَ یَنْبَغِی لِلرَّجُلِ أَنْ یَجْمَعَ بَیْنَ امْرَأَۃٍ وَعَمَّتِہَا مِنَ الرَّضَاعَۃِ مِمَّا مَلَکَتِ الْیَمِینُ۔",,,17035 17036,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حُسَیْنٍ الْمُعَلِّمِ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ یَوْمَ فَتَحَ مَکَّۃَ : لاَ تُنْکَحُ الْمَرْأَۃُ عَلَی عَمَّتِہَا وَلاَ عَلَی خَالَتِہَا۔\n\n(احمد 2/207۔ عبدالرزاق 10751)",,,17036 17037,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ حَدَّثَنَا جَعْفَرِ بْنِ بُرْقَانَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ ، عَنْ أَبِیہِ قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ تُزَوَّجَ الْمَرْأَۃُ عَلَی عَمَّتِہَا وَلاَ عَلَی خَالَتِہَا۔",,,17037 17038,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ حُسَیْنٍ الْمُعَلِّمِ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ أَنَّ رَجُلاً تَزَوَّجَ امْرَأَۃً عَلَی خَالَتِہَا فَضَرَبَہُ عُمَرُ وَفَرَّقَ بَیْنَہُمَا۔,,,17038 17039,"حَدَّثَنَا وَکِیعٌ ، عَنْ مَعقِلٍ ، عَنْ عَطَائٍ وَیَزِیدُ بْنُ إِبراہِیم ، عَنِ الْحَسَنِ قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ تُنْکَحَ الْمَرْأَۃُ عَلَی عَمَّتِہَا ، أَوْ عَلَی خَالَتِہَا",,,17039 17040,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ عَطَائٍ قَالَ : یُکْرَہُ الْجَمْعُ بَیْنَ ابْنَتَیِ الْعَمِّ لِفَسَادٍ بَیْنَہُمَا۔",,,17040 17041,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو أَنَّ الْحَسَنَ بْنَ مُحَمَّدٍ أَخْبَرَہُ أَنَّ ابْنًا لِعَلِیٍّ جَمَعَ بَیْنَ ابْنَتَی عَمٍّ لَہُ قَالَ : فَأُدْخِلَتَا عَلَیْہِ فِی لَیْلَۃٍ۔",,,17041 17042,حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ، عَنْ عَمْرٍو، عَنِ الْحَسَنِ أَنَّہُ کَانَ یَکْرَہُ أَنْ یُجْمَعَ بَیْنَ الْقَرَابَۃِ مِنْ أَجْلِ الْقَطِیعَۃِ۔,,,17042 17043,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَبِیبٍ ، عَنْ عَمْرٍو ، عَنْ جَابِرِ بْنِ زَیْدٍ قَالَ : سُئِلَ : ہَلْ یَصْلُحُ لِلْمَرْأَۃِ أَنْ تُزَوَّجَ عَلَی ابْنَۃِ عَمِّہَا ؟ قَالَ : تِلْکَ الْقَطِیعَۃُ وَلاَ تَصْلُحُ الْقَطِیعَۃُ۔",,,17043 17044,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ سُفْیَانَ حَدَّثَنِی خَالِدٌ الْفَأْفَاء ، عَنْ عِیسَی بْنِ طَلْحَۃَ قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ تُنْکَحَ الْمَرْأَۃُ عَلَی قَرَابَتِہَا مَخَافَۃَ الْقَطِیعَۃِ۔ (ابوداؤد 208۔ عبدالرزاق 10767)",,,17044 17045,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ أَبِی یَزِیدَ ، عَنْ أَبِیہِ أَنَّ سِبَاعَ بْنَ ثَابِتٍ تَزَوَّجَ ابْنَۃَ رَبَاحِ بْنِ وَہْبٍ وَلَہُ ابْنٌ مِنْ غَیْرِہَا وَلَہَا ابْنَۃٌ مِنْ غَیْرِہِ فَفَجَرَ الْغُلاَمُ بِالْجَارِیَۃِ فَظَہَرَ بِالْجَارِیَۃِ حَمْلٌ فَرُفِعَا إلَی عُمَرَ بْنِ الْخَطَّابِ فَاعْتَرَفَا فَجَلَدَہُمَا وَحَرَص أَنْ یُجْمَعَ بَیْنَہُمَا فَأَبَی الْغُلاَمُ۔,,,17045 17046,"حَدَّثَنَا خَلَفُ بْنُ خَلِیفَۃَ ، عَنْ أَبِی ہَاشِمٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ فِی رَجُلٍ وَامْرَأَۃٍ أَصَابَ کُلُّ وَاحِدٍ مِنْہُمَا مِنَ الآخَرِ حَدًّا ثُمَّ أَرَادَ أَنْ یَتَزَوَّجَہَا ، قَالَ : لاَ بَأْسَ ، أَوَّلُہُ سِفَاحٌ وَآخِرُہُ نِکَاحٌ۔",,,17046 17047,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ قَالَ : أَوَّلُہُ سِفَاحٌ وَآخِرُہُ نِکَاحٌ۔",,,17047 17048,"حَدَّثَنَا وَکِیعٌ ، عَنِ أَبِی جُنَابٍ ، عَنْ بُکَیْرِ بْنِ الأَخْنَسِ ، عَنْ أَبِیہِ قَالَ : قرَأْت مِنَ اللَّیْلِ (حم عسق) فَمَرَرْت بِہَذِہِ الآیَۃِ : {وَہُوَ الَّذِی یَقْبَلُ التَّوْبَۃَ ، عَنْ عِبَادِہِ وَیَعْفُو ، عَنِ السَّیِّئَاتِ وَیَعْلَمُ مَا تَفْعَلُونَ} فَغَدَوْت إلَی عَبْدِ اللہِ أَسْأَلُہُ عَنْہَا فَأَتَاہُ رَجُلٌ فَسَأَلَہُ ، عَنِ الرَّجُلِ یَفْجُرُ بِالْمَرْأَۃِ ثُمَّ یَتَزَوَّجُہَا فَقَرَأَ عَبْدُ اللہِ : {وَہُوَ الَّذِی یَقْبَلُ التَّوْبَۃَ ، عَنْ عِبَادِہِ وَیَعْفُو ، عَنِ السَّیِّئَاتِ}۔",,,17048 17049,"حَدَّثَنَا وَکِیعٌ ، عَنْ شَرِیکٍ عن عُرْوَۃَ بن عَبْدِ اللہِ بْنِ قُشَیرٍ ، عَنْ أَبِی الأَشْعَثِ ، عَنِ ابْنِ عُمَرَ قَالَ : أَوَّلُہُ سِفَاحٌ وَآخِرُہُ نِکَاحٌ أوَ أَوَّلُہُ حَرَامٌ وَآخِرُہُ حَلاَلٌ۔",,,17049 17050,حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الزُّہْرِیِّ ؛ أَنَّ رَجُلاً فَجَرَ بِامْرَأَۃٍ وَہُمَا بِکْرَانِ فَجَلَدَہُمَا أَبُو بَکْرٍ وَنَفَاہُمَا ثُمَّ زَوَّجَہَا إیَّاہُ بَعْدَ الْحَوْلِ۔,,,17050 17051,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَام ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : لاَ بَأْسَ أَنْ یَتَزَوَّجَہَا۔",,,17051 17052,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ ، عَنْ عَلْقَمَۃَ قَالَ : سَأَلَہُ رَجُلٌ ، عَنْ رَجُلٍ فَجَرَ بِامْرَأَۃٍ ، أَیَتَزَوَّجُہَا ؟ قَالَ : نَعَمْ ، وَتَلاَ ہَذِہِ الآیَۃَ : {وَہُوَ الَّذِی یَقْبَلُ التَّوْبَۃَ ، عَنْ عِبَادِہِ وَیَعْفُو ، عَنِ السَّیِّئَاتِ}۔",,,17052 17053,"حَدَّثَنَا جَرِیرٌ ، عَنْ شَیْبَۃَ أَبِی نَعَامَۃَ قَالَ : سُئِلَ سَعِیدُ بْنُ جُبَیْرٍ وَأَنَا أَسْمَعُ ، عَنْ رَجُلٍ فَجَرَ بِامْرَأَۃٍ ، أَیَتَزَوَّجُہَا ؟ قَالَ : أَوَّلُہُ سِفَاحٌ وَآخِرُہُ نِکَاحٌ أَحَلَّہَا لَہُ مَالُہُ۔",,,17053 17054,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ جَابِرِ بْنِ زَیْدٍ قَالَ : سُئِلَ عَنِ الرَّجُلِ یَفْجُرُ بِالْمَرْأَۃِ ثُمَّ یَتَزَوَّجُہَا ، قَالَ : ہُوَ أَحَقُّ بِہَا ، ہُوَ أَفْسَدَہَا۔",,,17054 17055,"حَدَّثَنَا وَکِیعٌ، عَنْ عُمَرَ بْنِ الْوَلِیدِ، عَنْ عِکْرِمَۃَ قَالَ: لاَ بَأْسَ ، ہُوَ بِمَنْزِلَۃِ رَجُلٍ سَرَقَ نَخْلَۃً ثُمَّ اشْتَرَاہَا۔",,,17055 17056,"حَدَّثَنَا وَکِیعٌ ، عَنْ سَعِیدِ بْنِ حَسَّانَ ، قَالَ : سَمِعْتُ حَنْظَلَۃَ قَالَ : سَأَلْتُ سَالِمًا عَنْہُ ، فَقَالَ : لاَ بَأْسَ بِہِ۔",,,17056 17057,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ قَالَ : إذَا تَابَا وَأَصْلَحَا فَلاَ بَأْسَ بہ۔",,,17057 17058,"حَدَّثَنَا عَبَّادُ بْنُ عَوَّامٍ ، عَنْ دَاوُدَ ، عَنْ یَزِیدَ بْنِ أَبِی مَنْصُورٍ ، أَوِ ابْنِ مَنْصُورٍ ، عَنْ صِلَۃَ بْنِ أَشْیَمَ قَالَ : لاَ بَأْسَ إِنْ کَانَا تَائِبَیْنِ فَاللَّہُ أَوْلَی بِتَوْبَتِہِمَا ، وَإِنْ کَانَا زَانِیَیْنِ فَالْخَبِیثُ عَلَی الْخَبِیثِ۔",,,17058 17059,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ یَحْیَی بْنِ سَعِیدٍ قَالَ : بَلَغَنِی أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ سُئِلَ عَنِ امْرَأَۃٍ أَصَابَتْ خَطِیئَۃً ثُمَّ رُئِیَ مِنْہَا خَیْرًا ، أَیَنْکِحُہَا الرَّجُلُ ؟ فَقَالَ لَہُ عمر کَمَا بَلَغَنِی : أتظن أنی أنہاک ؟۔",,,17059 17060,"حَدَّثَنَا سفیان بْنُ عُیَیْنَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ أَبِی یَزِیدَ قَالَ : سُئِلَ ابْنُ عَبَّاسٍ ، عَنْ رَجُلٍ زَنَی بِامْرَأَۃٍ فَأَرَادَ أَنْ یَتَزَوَّجَہَا ، قَالَ : الآنَ أَصَابَ الْحَلاَلَ۔",,,17060 17061,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنْ مُجَاہِدٍ ، وَعَطَائٍ قَالاَ : إذَا فَجَرَ الرَّجُلُ بِالْمَرْأَۃِ فَإِنَّہَا تَحِلُّ لَہُ۔",,,17061 17062,"حَدَّثَنَا مُحَمَّدُ بْنُ بشر ، عَنْ سَعِیدٍ حَدَّثَنَا قَتَادَۃُ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ وَجَابِرِ بْنِ عَبْدِ اللہِ وسعید بْنِ جُبَیْرٍ فِی الرَّجُلِ یَفْجُرُ بِالْمَرْأَۃِ ثُمَّ یَتَزَوَّجُہَا قَالُوا : لاَ بَأْسَ بِذَلِکَ إذَا تَابَا وَأَصْلَحَا۔",,,17062 17063,"حَدَّثَنَا مُحَمَّدُ بْنُ بشر قَالَ حَدَّثَنَا : سَعِیدٌ ، عَنْ قَتَادَۃَ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ فِی الرَّجُلِ یَفْجُرُ بِالْمَرْأَۃِ ثُمَّ یَتَزَوَّجُہَا ، قَالَ : کَانَ أَوَّلَہُ سِفَاحٌ وَآخِرَہُ نِکَاحٌ ، أَوَّلُہُ حَرَامٌ وَآخِرُہُ حَلاَلٌ۔",,,17063 17064,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَمْرِو بْنِ مَرْوَانَ ، عَنْ عَبْدِ الرَّحْمَنِ الصُّدَائِیِّ ، عَنْ علِیٍّ قَالَ : جَائَ إلَیْہِ رَجُلٌ ، فَقَالَ : إنَّ لِی ابْنَۃَ عَمٍّ أَہْوَاہَا وَقَدْ کُنْت نِلْت مِنْہَا ، فَقَالَ : إِنْ کَانَ شَیْئًا بَاطِنًا یَعْنِی الْجِمَاعَ فَلاَ ، وَإِنْ کَانَ شَیْئًا ظَاہِرًا یَعْنِی الْقُبْلَۃَ فَلاَ بَأْسَ۔",,,17064 17065,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ عن الحکم ، عَنْ سَالِمِ بْنِ أَبِی الْجَعْدِ ، عَنْ أَبِیہِ ، عَنْ عَبْدِ اللہِ قَالَ : لاَ یَزَالاَنِ زَانِیَیْنِ۔",,,17065 17066,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ ، قَالَ : قالَتْ عَائِشَۃُ : لاَ یَزَالاَنِ زَانِیَیْنِ مَا اصْطَحَبَا۔",,,17066 17067,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ جَابِرِ بْنِ زَیْدٍ أَنَّہُ قَالَ : ہُمَا زَانِیَانِ ، لِیَجْعَلَ بَیْنَہُ وَبَیْنَہَا الْبَحْرُ۔",,,17067 17068,"حَدَّثَنَا أَسْبَاطٌ ، عَنْ مُطَرِّفٍ ، عَنْ أَبِی الْجَہْمِ ، عَنِ الْبَرَائِ فِی الرَّجُلِ یَفْجُرُ بِالْمَرْأَۃِ ثُمَّ یَتَزَوَّجُہَا ، قَالَ : لاَ یَزَالاَنِ زَانِیَیْنِ أَبَدًا۔",,,17068 17069,"حَدَّثَنَا حَفْصٌ ، عَنْ عَاصِمٍ ، عَنْ عِیسَی بن حِطَّان ، عَنْ مُسْلِمِ بْنِ سَلاَّمٍ ، عَنْ عَلِیِّ بْنِ طَلْقٍ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : إنَّ اللَّہَ لاَ یَسْتَحْیِی مِنَ الْحَقِّ ، لاَ تَأْتُوا النِّسَائَ فِی أَعْجَازِہِنَّ ، أَوْ قَالَ : فِی أَدْبَارِہِنَّ۔ (ترمذی 1166۔ دارمی 1141)",,,17069 17070,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنِ الضَّحَّاکِ بْنِ عُثْمَانَ ، عَنْ مَخْرَمَۃَ بْنِ سُلَیْمَانَ ، عَنْ کُرَیْبٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لاَ یَنْظُرُ اللَّہُ إلَی رَجُلٍ أَتَی رَجُلاً ، أَوِ امْرَأَۃً فِی دُبُرِہَا۔\n\n(ترمذی 1165۔ ابن حبان 4418)",,,17070 17071,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ تُؤْتَی النِّسَائُ فِی أَعْجَازِہِنَّ وَقَالَ : إنَّ اللَّہَ لاَ یَسْتَحْیِی مِنَ الْحَقِّ۔",,,17071 17072,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ أَبِی أَیُّوبَ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرو قَالَ : ہِیَ اللُّوطِیَّۃُ الصُّغْرَی۔ (نسائی 8997)",,,17072 17073,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ عُقْبَۃَ بْنِ وَسَّاجٍ ، قَالَ : قَالَ أَبُو الدَّرْدَائِ : وَہَلْ یَفْعَلُ ذَلِکَ إلاَّ کَافِرٌ۔",,,17073 17074,"حَدَّثَنَا وَکِیعٌ، عَنْ ہَمَّامِ، عَنْ قَتَادَۃَ، عَنْ عُقْبَۃَ بن وساج، عَنْ أَبِی الدَّرْدَائِ قَالَ: وَہَلْ یَفْعَلُ ذَلِکَ إلاَّ کَافِرٌ۔",,,17074 17075,"حَدَّثَنَا إسْمَاعِیلُ بْنُ إِبْرَاہِیمَ ، عَن أَبِی عَبْدِ اللہِ الشَّقَرِیِّ ، عَنْ أَبِی الْقَعْقَاعِ ، عَنِ ابْنِ مَسْعُودٍ قَالَ : مَحَاشُّ النِّسَائِ عَلَیْکُمْ حَرَامٌ۔",,,17075 17076,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، عَنْ أَبِی ہُرَیْرَۃَ قَالَ : مَنْ أَتَاہُ مِنَ الرِّجَالِ وَالنِّسَائِ فَقَدْ کَفَرَ۔",,,17076 17077,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حَکِیمٍ الأَثْرَمِ ، عَنْ أَبِی تَمِیمَۃَ الْہُجَیْمِیِّ ، عَنْ أَبِی ہُرَیْرَۃَ قَالَ : مَنْ أَتَی حَائِضًا ، أَوِ امْرَأَۃً فِی دُبُرِہَا فَقَدْ کَفَرَ بِمَا أُنْزِلَ عَلَی مُحَمَّدٍ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ۔\n\n(ابوداؤد 3899۔ دارمی 1136)",,,17077 17078,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ الْوَلِیدِ بْنِ کَثِیرٍ قَالَ : حدَّثَنَا عُبَیْدُ اللہِ بْنُ عَبْدِ اللہِ بْنِ الْحُصَیْنِ الْخَطْمِیِّ ، عَنْ عَبْدِ الْمَلِکِ بْنِ قَیْسٍ الْخَطْمِیِّ ، عَنْ ہَرَمِی بْنِ عَبْدِ اللہِ ، قَالَ : سَمِعْتُ خُزَیْمَۃَ بْنَ ثَابِتٍ یَقُولُ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : إنَّ اللَّہَ لاَ یَسْتَحْیِی مِنَ الْحَقِّ ، لاَ تَأْتُوا النِّسَائَ فِی أعجازہن۔\n\n(طبرانی 3740۔ بیہقی 196)",,,17078 17079,"حَدَّثَنَا أَحْمَدُ بْنُ إِسْحَاقَ ، عَنْ وُہَیب ، عَنْ سُہَیْلِ بْنِ أَبِی صَالِحٍ ، عَنِ الْحَارِثِ بْنِ مُخَلَّدٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَنْظُرُ اللَّہُ إلَی رَجُلٍ جَامَعَ امْرَأَۃً فِی دُبُرِہَا۔\n\n(ابوداؤد 2155۔ ابن ماجہ 1923)",,,17079 17080,"حَدَّثَنَا ابْنُ نُمَیْرٍ قَالَ : حَدَّثَنَا الصَّلْتُ بْنِ بَہْرَامَ ، قَالَ : حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنِ مَسْعُودٍ ، عَنْ أَبِی الْمُعْتَمِرِ ، أَوْ أَبِی الْجُوَیْرِیَۃِ قَالَ : نَادَی عَلِیٌّ عَلَی الْمِنْبَرِ ، فَقَالَ : سَلُونِی سَلُونِی ، فَقَالَ رَجُلٌ : أَتُؤْتَی النِّسَائُ فِی أَدْبَارِہِنَّ ؟ فَقَالَ : سَفَلْتَ سَفَّلَ اللَّہُ بِکَ ، أَلَمْ تَرَ أَنَّ اللَّہَ تَعَالَی یَقُولُ : {أَتَأْتُونَ الْفَاحِشَۃَ} الآیَۃَ۔",,,17080 17081,"حدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عَنْ عَائِشَۃَ قَالَتْ : کَانَتْ إحْدَانَا إذَا کَانَتْ حَائِضًا أَمَرَہَا النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ تَتَّزِرَ بِإِزَارٍ ثُمَّ یُبَاشِرُہَا۔ (بخاری 300۔ مسلم 242)",,,17081 17082,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ قَالَتْ : کَانَتْ إحْدَانَا إذَا کَانَتْ حَائِضًا أَمَرَہَا النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ تَأْتَزِرَ فِی فور حَیْضَتِہَا ثُمَّ یُبَاشِرُہَا ، وَأَیُّکُمْ یَمْلِکُ إرْبَہُ کَمَا کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَمْلِکُ إرْبَہُ۔ (بخاری 302۔ مسلم 2)",,,17082 17083,"حَدَّثَنَا عَبَّادُ بْنُ عَوَّامٍ ، وَعَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ عَبْدِ اللہِ بْنِ شَدَّادٍ قَالَ : أَخْبَرَتْنِی مَیْمُونَۃُ زَوْجُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، عَنِ النَّبِیِّ بِنَحْوٍ مِنْہُ۔ (بخاری 303۔ احمد 6/336)",,,17083 17084,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَوْزَاعِیِّ ، عَنْ عَبْدَۃَ أَنَّ أُمَّ سَلَمَۃَ قَالَتْ : نُفِسْتُ وَأَنَا مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ تَعْنِی حِضْتُ فِی فِرَاشِی فَذَہَبْتُ لأَتَأَخَّرَ ، فَقَالَ : مَکَانَکِ إِنَّما کَانَ یَکْفِیکِ أَنْ تَجْعَلِی عَلَیْکِ ثَوْبًا۔\n\n(طبرانی 11602)",,,17084 17085,"حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنْ خَالِدٍ، عَنْ عِکْرِمَۃَ، عَنْ أُمِّ سَلَمَۃَ فِی مُضَاجَعَۃِ الْحَائِضِ: إذَا کَانَ عَلَی فَرْجِہَا خِرْقَۃٌ۔",,,17085 17086,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ، عَنْ عَلِیٍّ قَالَ : مَا فَوْقَ الإِزَارِ۔",,,17086 17087,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : مَا فَوْقَ الإِزَارِ۔",,,17087 17088,"حَدَّثَنَا جریر، عَنْ یَزِید، قَالَ: سَمِعْتُ سَعِیدَ بْنَ جُبَیْرٍ یَقُولُ: لَکَ مَا فَوْقَ الإِزَارِ وَلاَ تَطَّلِعْ عَلَی مَا تَحْتَہُ۔",,,17088 17089,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَوْزَاعِیِّ ، عَنْ مَیْمُونِ بْنِ مِہْرَانَ ، عَنْ عَائِشَۃَ أَنَّہَا سُئِلَتْ : مَا لِلرَّجُلِ مِنِ امْرَأَتِہِ وَہِیَ حَائِضٌ ؟ قَالَتْ : مَا فَوْقَ الإِزَارِ۔",,,17089 17090,"حَدَّثَنَا حَفْصٌ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ قَالَ : إذَا ألقت عَلَی فَرْجِہَا خِرْقَۃً فَیُبَاشِرُہَا۔",,,17090 17091,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، عَنِ الشَّیْبَانِیِّ قَالَ : إذَا کَفَّتِ الْحَائِضَۃُ عَنْہَا الأَذَی فَاصْنَعْ بِہَا مَا شِئْتَ۔",,,17091 17092,"حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ قَالَ : یَأْتِیہَا مَا أخطأ الدَّمُ۔",,,17092 17093,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرِ بْنِ حَبِیبٍ الْجَرْمِیِّ قَالَ : سَأَلْتُ أَبَا قِلاَبَۃَ : مَا لِلرَّجُلِ مِنِ امْرَأَتِہِ وَہِیَ حَائِضٌ؟ قَالَ : یَذْکُرُونَ مَا فَوْقَ الإِزَارِ۔",,,17093 17094,"حَدَّثَنَا وَکِیعٌ ، عَنِ الصَّلْتِ بْنِ بَہْرَامَ ، عَنْ إبْرَاہِیمَ قَالَ : لَکَ مَا فَوْقَ الإِزَارِ۔",,,17094 17095,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی مَکِینٍ ، عَنْ عِکْرِمَۃَ قَالَ : مَا فَوْقَ الإِزَارِ۔",,,17095 17096,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ حَرْمَلَۃَ أَنَّہُ سَمِعَ رَجُلاً یَسْأَلُ سَعِیدَ بْنَ الْمُسَیَّبِ ، فَقَالَ : أُبَاشِرُ امْرَأَتِی وَہِیَ حَائِضٌ ؟ قَالَ : اجْعَلْ بَیْنَکَ وَبَیْنَ ذَلِکَ مِنْہَا ثَوْبًا ثُمَّ بَاشِرْہَا۔",,,17096 17097,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ غَیْلاَنَ ، عَنِ الْحَکَمِ قَالَ : لاَ بَأْسَ أَنْ یَضَعَہُ عَلَی الْفَرْجِ وَلاَ یدْخِلْہُ۔",,,17097 17098,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ أَبِی ہِلاَلٍ ، عَنْ شَیْبَۃَ بْنِ ہِشَامٍ الرَّاسِبِیِّ قَالَ : سَأَلْتُ سَالِمًا ، عَنِ الرَّجُلِ یُضَاجِعُ امْرَأَتَہُ وَہِیَ حَائِضٌ ، فَقَالَ : أَمَّا نَحْنُ آلَ عُمَرَ فَنَعْزِلُہُنَّ۔",,,17098 17099,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ قَالَ : مَا فَوْقَ الإِزَارِ۔",,,17099 17100,"حَدَّثَنَا أَسْبَاطٌ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ ، عَنْ عَبِیْدَۃَ ، فِی الْحَائِضِ : لَکَ مَا فَوْقَ الإِزَارِ۔",,,17100 17101,"حَدَّثَنَا شَبَابَۃُ ، عَنْ لَیْثِ بْنِ سَعْدٍ ، عَنِ ابْنِ شِہَابٍ ، عَنْ حَبِیبٍ مَوْلَی عُرْوَۃَ ، عَنْ نَدْبَۃَ مَوْلاَۃِ مَیْمُونَۃَ ، عَنْ مَیْمُونَۃَ زَوْجِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُبَاشِرُ الْمَرْأَۃَ مِنْ نِسَائِہِ وَہِیَ حَائِضٌ إذَا کَانَ عَلَیْہَا إزَارٌ یَبْلُغُ أَنْصَافَ الْفَخِذَیْنِ ، أَوِ الرُّکْبَتَیْنِ مُحْتَجِرَۃً بِہِ۔\n\n(ابوداؤد 271۔ احمد 6/336)",,,17101 17102,"حَدَّثَنَا وَکِیعٌ ، عَنِ الرَّبِیعِ ، عَنِ الْحَسَنِ قَالَ : لاَ بَأْسَ أنْ یَلعَب عَلَی بَطْنِہَا وَبَیْنَ فَخِذَیْہَا۔",,,17102 17103,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ طَارِقٍ ، عَنْ عَاصِمِ بْنِ عَمْرٍو الْبَجَلِیِّ قَالَ : خَرَجَ نَاسٌ مِنْ أَہْلِ الْعِرَاقِ فَلَمَّا قَدِمُوا عَلَی عُمَرَ قَالَ لَہُمْ : مِمَّنْ أَنْتُمْ ؟ قَالُوا : مِنْ أَہْلِ الْعِرَاقِ ، قَالَ : فَبِإِذْنٍ جِئْتُمْ ؟ قَالُوا ، نَعَمْ ، فَسَأَلُوہ عَمَّا یَحِلُّ لِلرَّجُلِ مِنِ امْرَأَتِہِ وَہِیَ حَائِضٌ ، فَقَالَ : سَأَلْتُمُونِی ، عَنْ خِصَالٍ مَا سَأَلَنِی عنہن أَحَدٌ بَعْدَ أَنْ سَأَلْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : أَمَّا مَا لِلرَّجُلِ مِنِ امْرَأَتِہِ وَہِیَ حَائِضٌ فَلَہُ مَا فَوْقَ الإِزَارِ۔",,,17103 17104,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : یَقُولُ : إنِّی فِیک لرَاغِبٌ وَإِنِّی أُرِیدُ امْرَأَۃً أَمْرُہَا کَذَا وَکَذَا وَیُعَرِّضُ لَہَا بِالْقَوْلِ۔",,,17104 17105,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ فِی قَوْلِہِ : {وَلاَ جُنَاحَ عَلَیْکُمْ فِیمَا عَرَّضْتُمْ بِہِ مِنْ خِطْبَۃِ النِّسَائِ} قَالَ یَقُولُ : إنَّک جَمِیلَۃٌ وَإِنَّک لَنَافِقَۃٌ إنَّک إلَی خَیْرٍ ، وَیُکْرَہُ أَنْ یَقُولَ : لاَ تَفُوتِینِی بِنَفْسِکِ وَإِنِّی عَلَیْکِ لَحَرِیصٌ۔",,,17105 17106,حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ کَانَ لاَ یَرَی بَأْسًا بِذَلِکَ کُلِّہِ۔,,,17106 17107,"حَدَّثَنَا حَفْصٌ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ قَالَ : کَانَ یُکْرَہُ أَنْ یَقُولَ : إذَا انْقَضَتْ عِدَّتُہَا تَزَوَّجْتُکِ وَیَقُولُ مَا شَائَ۔",,,17107 17108,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ قَالَ : یَقُولُ : إنِّی بِکِ لَمُعْجَبٌ وَإِنِّی فِیک لَرَاغِبٌ فَلاَ تَفُوتِینَا بِنَفْسِک۔",,,17108 17109,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ قَالَ : یَقُولُ : إنَّک لَجَمِیلَۃٌ وَإِنَّک لَنَافِقَۃٌ وَإِنَّک لإِلَی خَیْرٍ۔",,,17109 17110,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، عَنْ أَبِیہِ فِی الْمَرْأَۃِ یُتَوَفَّی عَنْہَا زَوْجُہَا فَیُرِیدُ الرَّجُلُ خِطْبَتَہَا وَکَلاَمَہَا قَالَ : یَقُولُ : إنِّی بِکِ لَمُعْجَبٌ وَإِنِّی فِیکِ لَرَاغِبٌ وَإِنِّی عَلَیْکِ لَحَرِیصٌ وَأَشْبَاہَ ذَلِکَ۔",,,17110 17111,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ، عَنْ عَبِیْدَۃَ فِی قَوْلِہِ : {وَلاَ جُنَاحَ عَلَیْکُمْ فِیمَا عَرَّضْتُمْ بِہِ مِنْ خِطْبَۃِ النِّسَائِ} قَالَ : یَذْکُرُہَا إلَی وَلِیِّہَا وَلاَ یُشْعِرنَہَا۔",,,17111 17112,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ أَبِی سَلَمَۃَ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ لِفَاطِمَۃَ بِنْتِ قَیْسٍ : انْتَقِلِی إلَی أُمِّ شَرِیکٍ وَلاَ تَفُوتِینَا بِنَفْسِکِ۔ (مسلم 39۔ ابوداؤد 2281)",,,17112 17113,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سَلَمَۃَ ، عَنْ مُسْلِمٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ {إلاَّ أَنْ تَقُولُوا قَوْلاً مَعْرُوفًا} قَالَ : یقول : إنِّی فِیک لَرَاغِبٌ وَإِنِّی لأَرْجُو أَنْ یَجْمَعَ اللَّہُ بَیْنَکِ وَبَیْنِی۔",,,17113 17114,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ قَالَ : یَقُولُ : إنَّک لَجَمِیلَۃٌ وَإِنَّک لَنَافِقَۃٌ ، وَإِنْ قَضَی اللَّہُ أَمْرًا کَانَ۔",,,17114 17115,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ حَمَّادٍ عن إبراہیم قَالَ : لاَ بَأْسَ بالہدیۃ فِی تَعْرِیضِ النِّکَاحِ",,,17115 17116,"حَدَّثَنَا مُحَمَّدُ بْنُ بشر ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ أَبِی سَلَمَۃَ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ لَفَاطِمَۃَ : لاَ تَفُوتِینَا بِنَفْسِکِ۔",,,17116 17117,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عَبَّاسٍ {وَلاَ جُنَاحَ عَلَیْکُمْ فِیمَا عَرَّضْتُمْ بِہِ مِنْ خِطْبَۃِ النِّسَائِ} قَالَ : یَعْرِضُ الرَّجُلُ فَیَقُولُ : إنِّی أُرِیدُ أَنْ أَتَزَوَّجَ ، وَلاَ یَنْصِبْ فِی الْخِطْبَۃِ۔",,,17117 17118,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، عَنْ عَمَّارِ بْنِ رُزَیْقٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ فِی قَوْلِہِ : {وَلاَ جُنَاحَ عَلَیْکُمْ فِیمَا عَرَّضْتُمْ بِہِ مِنْ خِطْبَۃِ النِّسَائِ} قَالَ : یَقُولُ ، إنِّی فِیکِ لَرَاغِبٌ وَلَوَدِدْتُ أَنِّی تَزَوَّجْتُکِ حَتَّی یُعْلِمَہَا إِنَّہُ یُرِیدُ تَزْوِیجَہَا مِنْ غَیْرِ أَنْ یُوجِبَ عُقْدَۃً ، أَوْ یُعَاہِدَہَا عَلَی عَہْدٍ۔",,,17118 17119,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، عَنْ أَبِیہِ قَالَ : تَلاَ ہَذِہِ الآیَۃَ {وَلاَ جُنَاحَ عَلَیْکُمْ فِیمَا عَرَّضْتُمْ بِہِ مِنْ خِطْبَۃِ النِّسَائِ} قَالَ : یَقُولُ فِی الْعِدَّۃِ : إنِّی عَلَیْکِ لَحَرِیصٌ وَإِنِّی فِیکِ لَرَاغِبٌ وَنَحْوَ ہَذَا۔",,,17119 17120,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ : { وَلاَ جُنَاحَ عَلَیْکُمْ فِیمَا عَرَّضْتُمْ بِہِ مِنْ خِطْبَۃِ النِّسَائِ} قَالَ : یَقُولُ : إنَّکِ لَجَمِیلَۃٌ وَإِنَّکِ لَنَافِقَۃٌ ، وَإِنْ قَضَی اللَّہُ شَیْئًا کَانَ۔",,,17120 17121,"حَدَّثَنَا شَبَابَۃُ ، عَنْ وَرْقَائَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ : {فِیمَا عَرَّضْتُمْ بِہِ مِنْ خِطْبَۃِ النِّسَائِ} قَالَ: قَوْلُ الرَّجُلِ لِلْمَرْأَۃِ : إنَّکِ لَجَمِیلَۃٌ وَإِنَّکِ لَنَافِقَۃٌ وَإِنَّکِ لإِلَی خَیْرٍ ، وَلْیَکُنْ ذِکْرُ خِطْبَتِہَا فِی نَفْسِہِ ، لاَ یُبْدِیہِ لَہَا ، ہَذَا کُلُّہُ حِلٌّ مَعْرُوفٌ۔",,,17121 17122,"حَدَّثَنَا شَرِیکٌ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، عَنْ أَبِی الضُّحَی فِی قَوْلِہِ : {إلاَّ أَنْ تَقُولُوا قَوْلاً مَعْرُوفًا} قَالَ : یَقُولُ : إنِّی لأَشْتَہِیکِ۔",,,17122 17123,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ دَاوُدَ ، عَنْ عَبْدِ اللہِ بْنِ قَیْسٍ أَنَّ غُلاَمًا لأَبِی مُوسَی ، وَکَانَ صَاحِبَ إبِلِہِ تَزَوَّجَ أَمَۃً لِبَنِی جَعْدَۃَ وَسَاقَ إلَیْہَا خَمْسَ ذَوْدٍ فَحُدِّثَ أَبُو مُوسَی فَأَرْسَلَ إلَیْہِمْ: أَرْسِلُوا إلَیَّ غُلاَمِی وَمَالِی، فَقَالُوا : أَمَّا الْغُلاَمُ فَغُلاَمُکَ ، وَأَمَّا الْمَالُ فَقَدِ اسْتَحَلَّ بِہِ فَرْجَ صَاحِبَتِنَا فَاخْتَصَمُوا إلَی عُثْمَانَ بْنِ عَفَّانَ فَقَضَی لَہُمْ عُثْمَانُ بِخُمُسَی مَا اسْتَحَلَّ بِہِ فَرْجَ صَاحِبَتِہِمْ وَرَدَّ عَلَی أَبِی مُوسَی ثَلاَثَۃَ أَخْمَاسِہِ۔",,,17123 17124,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ قَالَ : تَزَوَّجَ عَبْدٌ لأَبِی مُوسَی فِی إمْرَۃِ عُمَرَ عَلَی خَمْسِ قَلاَئِصَ فَرُفِعَ ذَلِکَ إلَی عُمَرَ فَجَعَلَ لِلْمَرْأَۃِ قَلُوصَیْنِ وَِلأَبِی مُوسَی ثَلاَثَ قَلاَئِصَ ، أَوْ أَعْطَاہَا ثَلاَثَ قَلاَئِصَ وَرَدَّ عَلَی أَبِی مُوسَی قَلُوصَیْنِ قَالَ : أُرَاہُ تَزَوَّجَ بِغَیْرِ إذْنِہِ۔",,,17124 17125,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سَلَمَۃَ بْنِ تَمَّامٍ ، عَنْ رَجُلٍ ، عَنِ ابْنِ عُمَرَ قَالَ : لاَ صَدَاقَ لَہَا ، ہِیَ أَبَاحَتْ فَرْجَہَا",,,17125 17126,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ فِرَاسٍ ، عَنْ عَامِرٍ قَالَ : یَأْخُذُ مِنْہَا مَا اسْتَہْلَکَتْ ، وَمَا لَمْ تَسْتَہْلِکْ۔",,,17126 17127,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : یُؤْخَذُ مِنْہَا مَا لَمْ تَسْتَہْلِکْ ، فَأَمَّا مَا اسْتَہْلَکَتْ فَلاَ شَیْئَ۔",,,17127 17128,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ قَالَ : سَأَلْتُ الْحَکَمَ وَحَمَّادًا ، عَنِ الْعَبْدِ یَتَزَوَّجُ الْمَرْأَۃَ بِغَیْرِ إذْنِ مَوَالِیہِ ، قَالَ: یُفَرَّقُ بَیْنَہُمَا وَلاَ صَدَاقَ لَہَا ، یُؤْخَذُ مِنْہَا مَا أَخَذَتْ۔",,,17128 17129,حَدَّثَنَا غُنْدَرٌ، عَنْ أَشْعَثَ، عَنِ الْحَسَنِ؛ فِی مَمْلُوکٍ تَزَوَّجَ بِغَیْرِ إذْنِ سَیِّدِہِ فَدَخَلَ بِہَا قَالَ لَہَا مَا أَخَذَتْ۔,,,17129 17130,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ فِی الْعَبْدِ إذَا تَزَوَّجَ بِغَیْرِ إذْنِ سَیِّدِہِ فَلَیْسَ بِنِکَاحٍ وَلَیْسَ لَہَا بِشَیْئٍ۔,,,17130 17131,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ؛ فِی عَبْدٍ تَزَوَّجَ بِغَیْرِ إذْنِ مَوْلاَہُ وَسَاقَ صَدَاقًا ، قَالَ: إِنْ کَانَ دَخَلَ بِہَا فَلَہَا الصَّدَاقُ ، وَإِنْ لَمْ یَدْخُلْ بِہَا أَخَذَ الْمَوْلَی الصَّدَاقَ۔",,,17131 17132,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، عَنْ عَبْدِ اللہِ بْنِ مُحَمَّدِ بْنِ عَقِیلٍ ، عَنْ جَابِرٍ ، قَالَ : سَمِعْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : أَیُّمَا عَبْدٍ تَزَوَّجَ بِغَیْرِ إذْنِ مَوْلاَہُ فَہُوَ عَاہِرٌ۔ (ابوداؤد 2080۔ احمد 377)",,,17132 17133,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : أَخْبَرَنَا ہَمَّامٌ قَالَ حَدَّثَنَا الْقَاسِمُ بْنُ عَبْدِ الْوَاحِدِ ، عَنْ عَبْدِ اللہِ بْنِ مُحَمَّدِ بْنِ عَقِیلٍ ، عَنْ جَابِرٍ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : أَیُّمَا عَبْدٍ تَزَوَّجَ أو قَالَ : نکح بِغَیْرِ إذْنِ أَہْلِہِ فَہُوَ عَاہِرٌ۔ (حاکم 194۔ احمد 3/382)",,,17133 17134,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ قَالَ : نِکَاحُ الْعَبْدِ بِغَیْرِ إذْنِ سَیِّدِہِ زِنًا ، وَیُعَاقَبُ الَّذِی زَوَّجَہُ۔",,,17134 17135,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : أَخْبَرَنَا سَعِیدُ بْنُ أَبِی عَرُوبَۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ أَنَّہُ کَانَ إذَا تَزَوَّجَ عَبْدُہُ بِغَیْرِ إذْنٍ ضَرَبَہُ الْحَدَّ۔",,,17135 17136,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ الْجَرِیرِیِّ قَالَ : سَأَلْتُ غُنَیْمَ بْنَ قَیْسٍ ، قُلْتُ : الْعَبْدُ یَتَزَوَّجُ بِغَیْرِ إذْنِ سَیِّدِہِ ، أَزَانٍ ہُوَ ؟ قَالَ : قَدْ عَصَی ، قُلْتُ : أَزَانٍ ہُوَ ؟ قَالَ : قَدْ عَصَی۔",,,17136 17137,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ فِی الْعَبْدِ یَتَزَوَّجُ بِغَیْرِ إذْنِ مَوْلاَہُ ، قَالَ : قدْ کَانَ فِی شَیْئٍ فَسَلُوا عَنْہُ۔",,,17137 17138,"حَدَّثَنَا غُنْدَرٌ ، عَنْ عُثْمَانَ بْنِ غِیَاثٍ قَالَ : لاَ یَتَزَوَّجُ الْعَبْدُ إلاَّ بِإِذْنِ مَوْلاَہُ۔",,,17138 17139,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنِ الشَّعْبِیِّ فِی قَوْلِہِ : {وَلَکِنْ لاَ تُوَاعِدُوہُنَّ سِرًّا} قَالَ : لاَ یَأْخُذُ عَلَیْہَا عَہْدًا وَلاَ مِیثَاقًا أَلاَّ تَزَوَّجَ غَیْرَہُ۔",,,17139 17140,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ فِی قَوْلِہِ : {وَلَکِنْ لاَ تُوَاعِدُوہُنَّ سِرًّا} یَخْطُبُہَا فِی عِدَّتِہَا۔",,,17140 17141,"حَدَّثَنَا عبد الوہاب الثَّقَفِیُّ ، عَنْ خَالِدٍ ، عَنْ مُحَمَّدٍ قَالَ : {وَلَکِنْ لاَ تُوَاعِدُوہُنَّ سِرًّا} قَالَ : یَلْقَی الْوَلِیَّ فَیَذْکُرُ رَغْبَۃً وَحِرْصًا۔",,,17141 17142,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنْ مُسْلِمٍ الْبَطِینِ ، عَنْ سَعِیدٍ قَالَ : لاَ یُقَاضِیہَا فی الْعِدَّۃِ أَنْ لاَ تَزَوَّجَ غَیْرَہُ۔",,,17142 17143,"حَدَّثَنَا شَبَابَۃُ ، عَنْ وَرْقَائَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ : (وَلَکِنْ لاَ تُوَاعِدُوہُنَّ سِرًّا) قَوْلُ الرَّجُلِ لِلْمَرْأَۃِ : لاَ تَفُوتِینِی بِنَفْسِکِ فَإِنِّی نَاکِحُکِ ، ہَذَا لاَ یَحِلُّ۔",,,17143 17144,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عِمْرَانَ بْنِ حُدَیْرٍ ، عَنْ أَبِی مَخْلَدٍ ، وَالْحَسَنِ : {وَلَکِنْ لاَ تُوَاعِدُوہُنَّ سِرًّا} قَالاَ : الزِّنَا۔",,,17144 17145,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ عِمْرَانَ ، عَنِ الْحَسَنِ : {وَلَکِنْ لاَ تُوَاعِدُوہُنَّ سِرًّا} قَالَ : الزِّنَا۔",,,17145 17146,"حَدَّثَنَا وَکِیعٌ ، عَنْ عِمْرَانَ بْنِ حُدَیْرٍ ، عَنِ الْحَسَنِ قَالَ سَمِعْتُہُ یَقول {وَلَکِنْ لاَ تُوَاعِدُوہُنَّ سِرًّا} قَالَ: الزِّنَا۔",,,17146 17147,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ السُّدِّی ، عَنْ إبْرَاہِیمَ قَالَ : الزِّنَا۔",,,17147 17148,"حَدَّثَنَا جَرِیرٌ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی مِجْلَزٍ قَالَ : الزِّنَا۔",,,17148 17149,"حدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ أَبی ہِلال عَن حَیَّانَ الأَعْرَجِ ، عَنْ جَابِرِ بْنِ زَیْدٍ قَالَ : الزِّنَا۔",,,17149 17150,"حدَّثَنَا یَحْیَی بْنُ یَمَانٍ، عَنْ سُفْیَانَ، عَنْ عَلْقَمَۃَ بْنِ مَرْثَدٍ، عَنِ الضَّحَّاکِ قَالَ: لاَ یُقَاضِیہَا أَنْ لاَ تَزَوَّجَ غَیْرَہُ۔",,,17150 17151,"حدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ سِمَاکٍ ، عَنْ حَنَش بْنِ الْمُعْتَمِرِ قَالَ : أُتِیَ عَلِیٌّ برَجُلٍ قَدْ أَقَرَّ عَلَی نَفْسِہِ بِالزِّنَا ، فَقَالَ لَہُ علی : أُحْصِنْتَ ؟ قَالَ : نَعَمْ قَالَ : إذًا تُرْجَمُ ، قَالَ فَرَفَعَہُ إلَی السِّجْنِ فَلَمَّا کَانَ الْعَشِیّ دَعَا بِہِ فَقَصَّ أَمْرَہُ عَلَی النَّاسِ ، فَقَالَ رَجُلٌ مِنَ النَّاسِ : إنَّہُ قَدْ تَزَوَّجَ امْرَأَۃً لَمْ یَدْخُلْ بِہَا ، فَفَرِحَ بِذَلِکَ عَلِیٌّ فَضَرَبَہُ الْحَدَّ وَفَرَّقَ بَیْنَہُ وَبَیْنَ امْرَأَتِہِ وَأَعْطَاہَا نِصْفَ الصَّدَاقِ فِیمَا یُرَی سِمَاک۔",,,17151 17152,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ أَشْعَثَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ وَعَنْ أَشْعَثَ ، عَنِ الْحَسَنِ أنَّ الْبِکْرَ إذَا زَنَتْ جُلِدَتْ وَفُرِّقَ بَیْنَہَا وَبَیْنَ زَوْجِہَا وَلَیْسَ لَہَا شَیْئٌ ثُمَّ تَأَوَّلَ الْحَسَنُ ہَذِہِ الآیَۃَ : {وَلاَ تَعْضُلُوہُنَّ لِتَذْہَبُوا بِبَعْضِ مَا آتَیْتُمُوہُنَّ إلاَّ أَنْ یَأْتِینَ بِفَاحِشَۃٍ مُبَیِّنَۃٍ}۔",,,17152 17153,حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ قَالَ ، یُفَرَّقُ بَیْنَہُمَا وَلاَ صَدَاقَ لَہَا۔,,,17153 17154,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یَتَزَوَّجُ الْمَرْأَۃَ ثُمَّ تَزْنِی قَبْلَ أَنْ یَدْخُلَ بِہَا ، قَالَ: یُفَرَّقُ بَیْنَہُمَا وَلاَ صَدَاقَ لَہَا وَجَلْدُ مِئَۃٍ وَنَفْیُ سَنَۃٍ ، وَإِنْ ہُوَ زَنَی فُرِّقَ بَیْنَہُمَا۔",,,17154 17155,"حَدَّثَنَا جَرِیرٌ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ قَالَ : ہِیَ امْرَأَتُہُ یُقَامُ عَلَیْہِ الْحَدُّ ، إِنْ شَائَ طَلَّقَ ، وَإِنْ شَائَ أَمْسَکَ کَمَا أَنَّہُ لَوْ فَجَرَ لَمْ تُنْزَعْ عَنْہُ امْرَأَتُہُ۔",,,17155 17156,حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ فِی رَجُلٍ زَنَی قَبْلَ أَنْ یَدْخُلَ بِامْرَأَتِہِ ، فَکَانَ مِنْ رَأْیِہِ أَنْ لاَ یُفَرَّقَ بَیْنَہُ وَبَیْنَ امْرَأَتِہِ,,,17156 17157,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ فِی رَجُلٍ تَزَوَّجَ امْرَأَۃً فَأَصَابَ أَحَدُہُمَا فَاحِشَۃً قَبْلَ أَنْ یَدْخُلَ بِہَا قَالَ : یُجْلَدُ وَلاَ یُفَرَّقُ بَیْنَہُمَا۔",,,17157 17158,"حدَّثَنَا ابن فُضَیل عَن ابْنِ أَبِی لَیْلَی ، عَنْ نَافِعٍ ، عَنْ صَفِیَّۃَ بِنْتِ أَبِی عُبَیْدٍ قَالَتْ : تَزَوَّجَ رَجُلٌ امْرَأَۃً ثُمَّ فَجَرَ بِأُخْرَی قَبْلَ أَنْ یَدْخُلَ بِامْرَأَتِہِ فَجَلَدَہُ أَبُو بَکْرٍ مِئَۃً وَنَفَاہُ سَنَۃً۔",,,17158 17159,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ أَبِی الْخَلِیلِ أَنَّ أَبَا عَلْقَمَۃَ الْہَاشِمِیَّ حدَّثَنَا أَنَّ أَبَا سَعِیدٍ الْخُدْرِیَّ حَدَّثَہُمْ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَعَثَ یَوْمَ حُنَیْنٍ سَرِیَّۃً فَأَصَابُوا حَیًّا مِنَ الْعَرَبِ یَوْمَ أَوْطَاسٍ فَہَزَمُوہُمْ وَقَتَلُوہُمْ وَأَصَابُوا نِسَائً لَہُنَّ أَزْوَاجٌ من زنی ، فَکَانَ أُنَاسٌ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ تأثموا مِنْ غِشْیَانِہِنَّ مِنْ أَجْلِ أَزْوَاجِہِنَّ فَأَنْزَلَ اللَّہُ : {وَالْمُحْصَنَاتُ مِنَ النِّسَائِ إلاَّ مَا مَلَکَتْ أَیْمَانُکُمْ} مِنْہُنَّ فحلال لَکُمْ۔ (مسلم 33۔ ابوداؤد 2148)",,,17159 17160,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ حَمَّادٍ ، عن إبْرَاہِیمَ قَالَ : قَالَ عَلِیٌّ ، فِی قولہ تعالی: {وَالْمُحْصَنَاتُ مِنَ النِّسَائِ} قَالَ : ذَوَاتُ الأَزْوَاجِ مِنَ الْمُشْرِکِینَ۔",,,17160 17161,"حَدَّثَنَا عبد الوہاب الثَّقَفِیُّ ، عَنْ خَالِدٍ ، عَنْ أَبِی قِلاَبَۃَ ، عَنِ ابْنِ مَسْعُودٍ قَالَ : سَبَایَا کَانَ لَہُنَّ أَزْوَاجٌ قَبْلَ أَنْ یُسْبَیْنَ۔",,,17161 17162,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی مِجْلَزٍ ، عَنْ أَنَسٍ : {وَالْمُحْصَنَاتُ مِنَ النِّسَائِ} قَالَ : ذَوَاتُ الأَزْوَاجِ۔",,,17162 17163,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ زمعۃ ، عَنِ الزُّہْرِیِّ ، عَنِ سعید بْنِ الْمُسَیَّبِ قَالَ : ذَوَاتُ الأَزْوَاجِ ، یَرْجِعُ ذَلِکَ إلَی أَنَّ اللَّہَ تَعَالَی حَرَّمَ الزِّنَا۔",,,17163 17164,"حَدَّثَنَا عبد اللہ بْنُ إدْرِیسَ ، عَنْ أَشْعَثَ وَہِشَامٍ ، عَنْ مُحَمَّدٍ ، عَنْ عَبِیدَۃَ : {وَالْمُحْصَنَاتُ مِنَ النِّسَائِ} قَالَ بِیَدِہِ ہَکَذَا وَأَشَارَ بِالأَرْبَعِ : إلاَّ مَا مَلَکَتْ أَیْمَانُکُمْ۔",,,17164 17165,"حَدَّثَنَا ابْنُ إدْرِیسَ، عَنِ الصَّلْتِ، عَنْ إبْرَاہِیمَ قَالَ: کُلُّ ذَاتِ زَوْجٍ عَلَیْک حَرَامٌ إلاَّ مَا أَصَبْتَ مِنَ السَّبَایَا۔",,,17165 17166,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ زَکَرِیَّا ، عَنِ الشَّعْبِیِّ قَالَ : نَزَلَتْ یَوْمَ أَوْطَاسٍ۔",,,17166 17167,"حَدَّثَنَا ابْنُ مُسْہِرٍ ، عَنْ أَشْعَثَ ، عَنْ حَسَنٍ قَالَ : کُلُّ ذَاتِ زَوْجٍ عَلَیْک حَرَامٌ إلاَّ مَا مَلَکَتْ یَمِینُک یَعْنِی مِنَ السَّبَایَا۔",,,17167 17168,حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ سُفْیَانَ ، عَنْ قَیْسِ بْنِ مُسْلِمٍ ، عَنِ الْحَسَنِ بْنِ مُحَمَّدٍ مِثْلَہُ,,,17168 17169,"حَدَّثَنَا غُنْدَرٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ قَالَ : ہُوَ الزِّنَا ، وَقَالَ مُجَاہِدٌ : ہُوَ الزِّنَا ، وَقَالَ عِکْرِمَۃُ : ہُوَ الزِّنَا {إلاَّ مَا مَلَکَتْ أَیْمَانُکُمْ} وَقَالَ ابْنُ عَبَّاسٍ : {إلاَّ مَا مَلَکَتْ أَیْمَانُکُمْ} یَنْزِعُ الرَّجُلُ وَلِیدَتہ امْرَأَۃَ عَبْدِہِ وَقَالَ غَیْرُہُ : سَبَایَا الْعَدُوِّ یُوطَأْنَ إذَا مَا سُبِیَتْ أَزْوَاجُہُنَّ۔",,,17169 17170,"حَدَّثَنَا ابْنُ یَمَانٍ ، عَنْ أَشْعَثَ ، عَنْ جَعْفَرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ قَالَ : أَرْبَعٌ۔",,,17170 17171,"حَدَّثَنَا ابْنُ یَمَانٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ مَکْحُولٍ قَالَ : أَرْبَعٌ۔",,,17171 17172,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، عَن عَبْدِ اللہِ : {وَالْمُحْصَنَاتُ مِنَ النِّسَائِ إلاَّ مَا مَلَکَتْ أَیْمَانُکُمْ} قَالَ : ذَوَاتُ الأَزْوَاجِ۔",,,17172 17173,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِِ ، عَنْ إِبْرَاہِیمَ ، عَن عَبْدِ اللہِ فِی قَوْلِہِ : {وَالْمُحْصَنَاتُ مِنَ النِّسَائِ} قَالَ : کُلُّ ذَاتِ زَوْجٍ عَلَیْکَ حَرَامٌ إلاَّ مَا مَلَکَتْ یَمِینُکَ ، أَوْ تَشْتَرِیہَا۔",,,17173 17174,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ قَالَ : کُلُّ ذَاتِ زَوْجٍ عَلَیْکَ حَرَامٌ إلاَّ مَا مَلَکَتْ یَمِینُکَ مِنَ السَّبَایَا یُرِیدُ حْصَنَاتُ مِنَ النِّسَائِ}",,,17174 17175,"حَدَّثَنَا عُبَیْدُ اللہِ قَالَ : أَخْبَرَنَا إسْرَائِیلُ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ مَکْحُولٍ : {وَالْمُحْصَنَاتُ مِنَ النِّسَائِ} قَالَ : ذَوَاتُ الأَزْوَاجِ۔",,,17175 17176,"حَدَّثَنَا وَکِیعٌ ، عَنْ مَالِکِ بْنِ مِغْوَلٍ ، عَنْ أَبِی السَّوْدَائِ قَالَ : سَأَلْتُ عِکْرِمَۃَ عَنْہَا ، فَقَالَ : لاَ أَدْرِی ، وَسَأَلْتُ الشَّعْبِیَّ ، فَقَالَ : ہِیَ کُلُّ ذَاتِ زَوْجٍ۔",,,17176 17177,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ قَالَ : حدَّثَنَا شَرِیکٌ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ : {وَالْمُحْصَنَاتُ مِنَ النِّسَائِ} قَالَ : من النساء کُلِّہِنَّ إلاَّ ذَوَاتِ الأَزْوَاجِ مِنَ السَّبَایَا۔",,,17177 17178,"حَدَّثَنَا غُنْدَرٌ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ فِی قَوْلِہِ : {وَالْمُحْصَنَاتُ مِنَ النِّسَائِ إلاَّ مَا مَلَکَتْ أَیْمَانُکُمْ} قَالَ : الزِّنَا ، وَقَالَ مُجَاہِدٌ : ہُوَ الزِّنَا ، وَقَالَ ابْنُ عَبَّاسٍ : ہُوَ الزِّنَا إلاَّ مَا مَلَکَتْ أَیْمَانُکُمْ یَنْزِعُ الرَّجُلُ وَلِیدَتہ امْرَأَۃَ عَبْدِہِ فَیَطَؤُہَا إِنْ شَائَ ، وَقَالَ غَیْرُہُ : سَبَایَا الْعَدُوِّ۔",,,17178 17179,"حَدَّثَنَا مُحَمَّدُ بْنُ الْحَسَنِ قَالَ : حدثنا شَرِیکٌ ، عَنْ سَالِمٍ ، عَنْ سَعِیدٍ فِی قَوْلِہِ : {وَالْمُحْصَنَاتُ مِنَ النِّسَائِ إلاَّ مَا مَلَکَتْ أَیْمَانُکُمْ} قَالَ : نَزَلَتْ فِی نِسَائِ أَہْلِ حُنَیْنٍ ، لَمَّا افْتَتَحَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حُنَیْنًا أَصَابَ الْمُسْلِمُونَ السَّبَایَا ، فَکَانَ الرَّجُلُ إذَا أَرَادَ أَنْ یَأْتِیَ الْمَرْأَۃَ مِنْہُنَّ قَالَتْ : إنَّ لِی زَوْجًا فَأَتَوُا النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَذَکَرُوا ذَلِکَ لَہُ فَأَنْزَلَ اللَّہُ تَعَالَی : {وَالْمُحْصَنَاتُ مِنَ النِّسَائِ إلاَّ مَا مَلَکَتْ أَیْمَانُکُمْ} قَالَ : السَّبَایَا مِنْ ذَوَاتِ الأَزْوَاجِ۔",,,17179 17180,"حَدَّثَنَا شَبَابَۃُ، عَنْ وَرْقَائَ، عَنِ ابْنِ أَبِی نَجِیحٍ، عَنْ مُجَاہِدٍ: {وَالْمُحْصَنَاتُ مِنَ النِّسَائِ} نہی، عَنِ الزِّنَا۔",,,17180 17181,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ یُونُسَ بْنِ أَبِی إِسْحَاقَ ، عَنْ طَارِقٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : لاَ تَغُرَّنَّکُمْ ہَذِہِ الآیَۃُ {إلاَّ مَا مَلَکَتْ أَیْمَانُکُمْ} إنَّمَا عَنَی بِہِ الإِمَائَ وَلَمْ یَعْنِ بِہا الْعَبِیدَ۔",,,17181 17182,"حَدَّثَنَا جَرِیرٍ ، عَنْ مَنْصُورٍ ، عَنْ أَبِی رَزِینٍ فِی قَوْلِہِ : {لاَ یَحِلُّ لَکَ النِّسَائُ مِنْ بَعْدُ} قَالَ : لاَ یَحِلُّ لَکَ مِنَ الْمُشْرِکَاتِ إلاَّ مَا سَبَیْتَ ، أَوْ مَا مَلَکَتْ یَمِینُکَ۔",,,17182 17183,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ قَالَ : مِنْ مُسْلِمَۃٍ وَلاَ نَصْرَانِیَّۃٍ وَلاَ کَافِرَۃٍ۔",,,17183 17184,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ قَالَ : {لاَ یَحِلُّ لَکَ النِّسَائُ مِنْ بَعْدُ} قَالَ: نِسَائُ الأُمَمِ مِنْ أَہْلِ الْکِتَابِ۔",,,17184 17185,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَلِیِّ بْنِ بَذِیْمَۃَ ، قَالَ : سَمِعْتُ مُجَاہِدًا یَقُولُ : {لاَ یَحِلُّ لَکَ النِّسَائُ مِنْ بَعْدُ} قَالَ : مِنْ بَعْدِ ہَذَا السَّبَبِ۔",,,17185 17186,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ دَاوُدَ بْنِ أَبِی ہِنْدٍ ، عَنْ مُحَمَّدِ بْنِ أَبِی مُوسَی ، عَنْ زِیَادٍ قَالَ : قیل لأُبَیٍّ : لَوْ ہَلَکَ أَزْوَاجُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَلَّ لَہُ أَنْ یَتَزَوَّجَ ؟ قَالَ : وَمَنْ یَمْنَعُہُ ؟ أَحَلَّ اللَّہُ لَہُ ضَرْبًا مِنَ النِّسَائِ ، فَکَانَ یَتَزَوَّجُ مِنْہُنَّ مَنْ شَائَ ، ثُمَّ تَلاَ ہَذِہِ الآیَۃَ : {یَا أَیُّہَا النَّبِیُّ إنَّا أَحْلَلْنَا لَکَ أَزْوَاجَک اللاَّتِی} حَتَّی خَتَمَ الآیَۃَ۔ (طبری 29۔ دارمی 2240)",,,17186 17187,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ عَطَائٍ ، عَنْ عَائِشَۃَ قَالَتْ : مَا مَاتَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَتَّی أُحِلَّ لَہُ النِّسَائَ۔ (ترمذی 3216۔ احمد 41)",,,17187 17188,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ : {وَلاَ أَنْ تَبَدَّلَ بِہِنَّ مِنْ أَزْوَاجٍ وَلَوْ أَعْجَبَک حُسْنُہُنَّ} قَالَ : لاَ تَبَدَّلُ بِہِنَّ یَہُودِیَّاتٍ وَلاَ نَصْرَانِیَّاتٍ۔",,,17188 17189,"حَدَّثَنَا یَحْیَی بْنُ عَبْدِ الْمَلِکِ بْنِ أَبِی غَنِیۃَ ، عَنْ أَبِیہِ ، عَنِ الْحَکَمِ قَالَ : مِنْ أَہْلِ الْکِتَابِ ، أَوْ أَعْرَابِیَّۃٍ۔",,,17189 17190,"حَدَّثَنَا عُبَیدُ اللہِ ، عَنْ إسْرَائِیلَ ، عَنِ السدِّی ، عَنْ عَبْدِ اللہِ بْنِ شَدَّادٍ فِی قَوْلِہِ : {وَلاَ أَنْ تَبَدَّلَ بِہِنَّ مِنْ أَزْوَاجٍ} قَالَ : ذَلِکَ لَوْ طَلَّقَہُنَّ لَمْ یَحِلَّ لَہُ أَنْ یَسْتَبْدِلَ ، قَالَ : وَقَدْ کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَنْکِحُ مَا شَائَ بَعْدَ مَا نَزَلَتْ ، وَنَزَلَتْ وَتَحْتَہُ تِسْعُ نِسْوَۃٍ وَتَزَوَّجَ أُمَّ حَبِیبَۃَ وَجُوَیْرِیَۃَ۔",,,17190 17191,"حَدَّثَنَا عَفَّانُ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عَلِیِّ بْنِ زَیْدٍ ، عَنِ الْحَسَنِ : {وَلاَ أَنْ تَبَدَّلَ بِہِنَّ مِنْ أَزْوَاجٍ} قَالَ: قَصَرَہُ اللَّہُ عَلَی نِسَائِہِ التِّسْعِ اللاَّتِی مَاتَ عَنْہُنَّ ، قَالَ : قَالَ عَلِیٌّ : فَأَخْبَرْت بِذَلِکَ عَلِیَّ بْنَ حُسَیْنٍ ، فَقَالَ : بل کَانَ لَہُ أَنْ یَتَزَوَّجَ۔",,,17191 17192,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ شُبْرُمَۃَ ، عَنْ عِکْرِمَۃَ : (الزَّانِی لاَ یَنْکِحُ إلاَّ زَانِیَۃً) لاَ یَزْنِی الزَّانِی إلاَّ بِزَانِیَۃٍ۔",,,17192 17193,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ : {الزَّانِی لاَ یَنْکِحُ إلاَّ زَانِیَۃً أَوْ مُشْرِکَۃً} قَالَ : کَانَ یُقَالُ نَسَخَتْہَا الَّتِی بَعْدَہَا {وَأَنْکِحُوا الأَیَامَی مِنْکُمْ} قَالَ : وَکَانَ یُقَالُ إنَّہَا مِنْ أَیَامَی الْمُسْلِمِینَ۔",,,17193 17194,"حَدَّثَنَا غُنْدَرٌ، عَنْ شُعْبَۃَ، عَنْ یَعْلَی بْنِ مُسْلِمٍ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ قَالَ: لاَ یَزْنِی إلاَّ بِزَانِیَۃٍ ، أَوْ مُشْرِکَۃٍ۔",,,17194 17195,"حَدَّثَنَا غُنْدَرٌ، عَنْ شُعْبَۃَ، عَنْ إبْرَاہِیمَ بْنِ الْمُہَاجِرِ، عَنْ مُجَاہِدٍ قَالَ سَمِعْتُہُ یَقُولُ: کُنَّ بَغَایَا فِی الْجَاہِلِیَّۃِ۔",,,17195 17196,"حَدَّثَنَا عَبْدَۃَ بْنُ سُلَیْمَانَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ عَاصِمِ بْنِ الْمُنْذِرِ قَالَ : سَأَلْتُ عُرْوَۃَ ، عَنْ قَوْلِہِ : {الزَّانِی لاَ یَنْکِحُ إلاَّ زَانِیَۃً أَوْ مُشْرِکَۃً} قَالَ : کُنَّ نِسَائً بَغَایَا فِی الْجَاہِلِیَّۃِ لَہُنَّ رَایَاتٌ یُعْرَفْنَ بِہَا۔",,,17196 17197,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، عَنِ الشعبی قَالَ : نِسَائٌ کُنَّ یَکْرِینَ أَنْفُسَہُنَّ فِی الْجَاہِلِیَّۃِ۔",,,17197 17198,"حَدَّثَنَا وَکِیعٌ ، عَنْ سَلَمَۃَ ، عَنِ الضَّحَّاکِ فِی قَوْلِہِ : (الزَّانِی لاَ یَنْکِحُ إلاَّ زَانِیَۃً أَوْ مُشْرِکَۃً وَالزَّانِیَۃُ لاَ یَنْکِحُہَا إلاَّ زَانٍ أَوْ مُشْرِکٌ) قَالَ : لاَ یَزْنِی حِینَ یَزْنِی إلاَّ بِزَانِیَۃٍ وَلاَ تَزْنِی حِینَ تَزْنِی إلاَّ بِزَانٍ مِثْلِہَا۔",,,17198 17199,حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ یَعْلَی بْنِ مُسْلِمٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ مِثْلَہُ۔,,,17199 17200,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنْ شُعْبَۃَ مَوْلَی ابْنِ عَبَّاسٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : بَغَایَا کُنَّ فِی الْجَاہِلِیَّۃِ یَجْعَلْنَ عَلَی أَبْوَابِہِنَّ رَایَاتٍ کَرَایَاتِ الْبَیَاطِرَۃِ ، یَأْتِیہِنَّ النَّاسُ ، یُعْرَفْنَ بِذَلِکَ۔",,,17200 17201,حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ عَاصِمِ بْنِ الْمُنْذِرِ ، عَنْ عُرْوَۃَ نَحْوَہُ۔,,,17201 17202,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَبِیبِ بْنِ أَبِی عَمْرَۃَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : {الزَّانِی لاَ یَنْکِحُ إلاَّ زَانِیَۃً أَوْ مُشْرِکَۃً} یَعْنِی بِالنِّکَاحِ : یُجَامِعُہَا۔",,,17202 17203,حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، عَنْ سُفْیَانَ ، عَنْ خَالِدِ بْنِ دِینَارٍ ، عَنِ الْحَارِثِ ، عَنْ إبْرَاہِیمَ قَالَ لاَ یُجَامِعُہَا إلاَّ زَانٍ أَوْ مُشْرِکٌ۔,,,17203 17204,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ سُفْیَانَ التَّمَّارُ العُصْفُریّ ، قَالَ : سَمِعْتُ سَعِیدَ بْنَ جُبَیْرٍ یَقُولُ : کُنَّ بَغَایَا بِمَکَّۃَ قَبْلَ الإِسْلاَمِ ، فَکَانَ رِجَالٌ یَتَزَوَّجُونَہُنَّ فَیُنْفِقْنَ عَلَیْہِمْ مَا أَصَبْنَ فَلَمَّا جَائَ الإِسْلاَمُ تَزَوَّجَہُنَّ رِجَالٌ مِنْ أَہْلِ الإِسْلاَمِ فَحَرَّمَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ذَلِکَ عَلَیْہِمْ۔",,,17204 17205,"حَدَّثَنَا عَفَّانُ قَالَ حَدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ حُمَیْدٍ ، عَنْ إِسْحَاقَ بْنِ عَبْدِ اللہِ بْنِ الْحَارِثِ ، عَنِ ابْنِ عَبَّاسٍ : (الزَّانِی لاَ یَنْکِحُ إلاَّ زَانِیَۃً أَوْ مُشْرِکَۃً) قَالَ : الزَّانِی لاَ یزنی إلاَّ بِزَانِیَۃٍ ، أَوْ مُشْرِکَۃٍ وَلَکِنَّ اللَّہَ کَنَّی۔",,,17205 17206,"حَدَّثَنَا شَبَابَۃُ ، عَنْ وَرْقَائَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ فِی قَوْلِہِ : (الزَّانِی لاَ یَنْکِحُ إلاَّ زَانِیَۃً) بَغَایَا مُتَعَالِنَاتٌ کُنَّ فِی الْجَاہِلِیَّۃِ فَقِیلَ لَہُنَّ : ہَذَا حَرَامٌ فَأَرَادُوا نِکَاحَہُنَّ فَحَرَّمَ اللَّہُ عَلَیْہِمْ نِکَاحَہُنَّ۔",,,17206 17207,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ عَاصِمٍ ، عَنِ الشَّعْبِیِّ قَالَ : أَحَلُّ النِّسَائِ للزَّانِی الزَّانِیَۃُ قَالَ : وَسَأَلْتُ الْحَسَنَ ، فَقَالَ : إنا لاَ نُفتِی فِی الْمَسْتُورِ وَلَکِنِ الْمَحْدُودُ لاَ یَتَزَوَّجُ إلاَّ مَحْدُودَۃً۔",,,17207 17208,حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ لَیْثٍ ، عَنِ ابْنِ سَابِطٍ أَنَّ عَلِیًّا أُتِیَ بِمَحْدُودٍ تَزَوَّجَ امْرَأَۃً غَیْرَ مَحْدُودَۃٍ فَفَرَّقَ بَیْنَہُمَا۔\,,,17208 17209,"حَدَّثَنَا بَکَّارُ بْنُ عَبْدِ اللہِ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ أَخِیہِ عَبْدِ اللہِ بْنِ عُبَیْدَۃَ أَنَّ مَوْلاَۃً لِبَنِی حَارِثَۃَ جُلِدَتْ حَدَّ الزِّنَا فَأَرَادَ رَجُلٌ أَنْ یَتَزَوَّجَہَا فَاسْتَشَارَ أَبَا ہُرَیْرَۃَ ، فَقَالَ: لاَ، إلاَّ أَنْ تَکُونَ عَمِلْتَ مِثْلَ عَمَلِہَا۔",,,17209 17210,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ قَیْسِ بْنِ مُسْلِمٍ ، عَنْ طَارِقِ بْنِ شِہَابٍ أَنَّ رَجُلاً أَرَادَ أَنْ یُزَوِّجَ ابْنَۃً ، فَقَالَتْ : إنِّی أَخْشَی أَنْ أَفْضَحَکَ ، إنِّی قَدْ بَغَیْتُ ، فَأَتَی عُمَرَ ، فَقَالَ : أَلَیْسَتْ قَدْ تَابَتْ ؟ قَالَ : نَعَمْ ، قَالَ : فَزَوِّجْہَا۔",,,17210 17211,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عُرْوَۃَ ، عَنْ عَائِشَۃَ أَنَّ امْرَأَۃَ رِفَاعَۃَ الْقُرَظِیِّ جَائَتْ إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَتْ : إنِّی کُنْتُ عِنْدَ رِفَاعَۃَ الْقُرَظِیِّ فَطَلَّقَنِی فَبَتَّ طَلاَقِی فَتَزَوَّجْتُ عَبْدَ الرَّحْمَنِ بْنَ الزَّبِیْرِ وَإِنَّمَا مَعَہُ مِثْلُ ہُدْبَۃِ الثَّوْبِ ، فَتَبَسَّمَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَقَالَ : تُرِیدِینَ أَنْ تَرْجِعِی إلَی رِفَاعَۃَ ؟ لاَ حَتَّی تَذُوقِی عُسَیْلَتَہُ وَیَذُوقَ عُسَیْلَتَکِ۔ (بخاری 2639۔ مسلم 111)",,,17211 17212,"حَدَّثَنَا أبو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عَنْ عَائِشَۃَ قَالَتْ : سُئِلَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْہُ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تحل لہ حَتَّی یَذُوقَ الآخر عُسَیْلَتَہَا وَتَذُوقَ عُسَیْلَتَہُ۔ (ابوداؤد 2303۔ احمد 6/42)",,,17212 17213,حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ عُبَیْدِ اللہِ ، عَنِ الْقَاسِمِ ، عَنْ عَائِشَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مثل حدیث الأعمش۔ (بخاری 5261۔ مسلم 115),,,17213 17214,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِنَحْوہ۔\n\n(بخاری 5265۔ مسلم 114)",,,17214 17215,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَلْقَمَۃَ بْنِ مَرْثَدٍ ، عَنْ سُلَیْمَانَ بْنِ رَزِینٍ ، عَنِ ابْنِ عُمَرَ قَالَ : سُئِلَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، عَنْ رَجُلٍ طَلَّقَ امْرَأَتَہُ ثَلاَثًا فَتَزَوَّجَتْ زَوْجًا غَیْرَہُ فَأَغْلَقَ الْبَابَ وَأَرْخَی السِّتْرَ ثُمَّ طَلَّقَہَا قَبْلَ أَنْ یَدْخُلَ بِہَا قَالَ : لاَ تَحِلُّ لَہُ حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ وَتَذُوقَ عُسَیْلَتَہُ۔\n\nقَالَ وَکِیعٌ بأخرۃ : رَزِینِ بْنِ سُلَیْمَانَ۔ (احمد 2/25۔ بیہقی 375)",,,17215 17216,"حَدَّثَنَا شَریک ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : قَالَ عَلِیٌّ : لاَ تَحِلُّ لَہُ حَتَّی یَہُزَّہَا بِہِ ہَزِیزَ الْبِکْرِ ، قَالَ : وَقَالَتْ عَائِشَۃُ : حَتَّی یَذُوقَ الآخَرُ عُسَیْلَتَہَا وَتَذُوقَ عُسَیْلَتَہُ۔",,,17216 17217,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ یَحْیَی بْنِ یَزِیدَ الْہُنَائی ، عَنْ أَنَسٍ قَالَ : لاَ تَحِلُّ لِلأَوَّلِ حَتَّی یُجَامِعَہَا الآخَرُ وَیَدْخُلَ بِہَا۔",,,17217 17218,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ مُبَارَکٍ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ أَبِی تِحْیَی ، قَالَ : قَالَ أَبُو ہُرَیْرَۃَ : لاَ تَحِلُّ لِلأَوَّلِ حَتَّی یُجَامِعَہَا الآخَرُ۔",,,17218 17219,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ مِسْعَرٍ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، عَن عَبْدِ اللہِ : لاَ تَحِلُّ لَہُ حَتَّی یُشَفْشِفَہَا بِہِ ، وَقَالَ علی: حَتَّی تَذُوقَ عُسَیْلَتَہُ۔",,,17219 17220,"حدَّثَنَا الأَشْیَبُ الْحَسَنُ بْنُ مُوسَی ، عَنْ شَیْبَانَ ، عَنْ یَحْیَی ، عَنْ أَبِی الْحَارِثِ الْغِفَارِیِّ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : حَتَّی تَذُوقَ عُسَیْلَتَہُ۔ (ابن جریر 477)",,,17220 17221,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خالد عن أَبِی قِلاَبَۃَ ، عَنْ أَنَسٍ قَالَ : إذَا تَزَوَّجَ الرَّجُلُ الْبِکْرَ عَلَی امْرَأَتِہِ أَقَامَ عِنْدَہَا سَبْعًا وَإِذَا تَزَوَّجَ الثَّیِّبَ أَقَامَ عِنْدَہَا ثَلاَثًا ، قَالَ خَالِدٌ : قَالَ أَبُو قِلاَبَۃَ : أَمَا لَوْ قُلْتُ : إنَّہُ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَلَکِنَّہَا سُنَّۃٌ قَالَ خَالِدٌ : فَحَدَّثْتُ بِہِ ابْنَ سِیرِینَ ، فَقَالَ : زِدْتُمْ ہَذِہِ أَرْبَعًا وَہَذِہِ لَیْلَۃً۔\n\n(بخاری 5213۔ مسلم 1084)",,,17221 17222,"حَدَّثَنَا عَبْدَۃُ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : لِلْبِکْرِ سَبْعًا وَلِلثَّیِّبِ ثَلاَثًا۔ (دارمی 2209۔ مسلم 1084)",,,17222 17223,حَدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنْ مُحَمَّدِ بْنِ إسحاق ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ، عَنْ أَنَسٍ ، عَنِ النبی صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بمثلہ۔ (دارمی 2209),,,17223 17224,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ عن سفیان ، عَنْ مُحَمَّدِ بْنِ أَبِی بَکْرٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ أَبِی بَکْرِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ الْحَارِثِ بْنِ ہِشَامٍ ، عَنْ أَبِیہِ ، عَنْ أُمِّ سَلَمَۃَ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لَمَّا تَزَوَّجَ أُمَّ سَلَمَۃَ أَقَامَ عِنْدَہَا ثَلاَثًا وَقَالَ لَہَا : إنَّہُ لَیْسَ بِکِ عَلَی أَہْلِکِ ہَوَانٌ ، إِنْ شِئْتِ سَبَّعْتُ لَکِ ، وَإِنْ سَبَّعْتُ لَکِ سَبَّعْتُ لِنِسَائِی۔ (مسلم 1083۔ ابوداؤد 2115)",,,17224 17225,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ قَالَ : لَمَّا تَزَوَّجَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أُمَّ سَلَمَۃَ أَقَامَ عِنْدَہَا ثَلاَثًا وَقَالَ : إِنْ شِئْتِ سَبَّعْتُ لَکِ ، وَإِنْ سَبَّعْتُ لَکِ سَبَّعْتُ لِغَیْرِکِ ، قِیلَ لِلْحَکَمِ : مَنْ حَدَّثَک ہَذَا الْحَدِیثَ ؟ فَقَالَ : ہَذَا الْحَدِیثُ عِنْدَ أَہْلِ الْحِجَازِ مَعْرُوفٌ۔",,,17225 17226,"حَدَّثَنَا عَبْدَۃ بن سلیمان ، عَنْ أَبِی سَعِیدٍ ، عَنْ إبْرَاہِیمَ وَالشَّعْبِیِّ قَالاَ : إذَا تَزَوَّجَ الْبِکْرَ عَلَی امْرَأَتِہِ أَقَامَ عِنْدَہَا سَبْعًا وَإِذَا تَزَوَّجَ الثَّیِّبَ عَلَی امْرَأَتِہِ ، أَقَامَ عِنْدَہَا ثَلاَثًا۔",,,17226 17227,حَدَّثَنَا عَبدَۃ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسِ بْنِ مَالِکٍ مِثْلَہُ۔,,,17227 17228,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ قَالَ : لِلْبِکْرِ ثَلاَثًا وَلِلثَّیِّبِ لَیلَتَین۔",,,17228 17229,حَدَّثَنَا عَبدَۃ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ قَالَ یُقِیمُ عِنْدَ الْبِکْرِ ثَلاَثًا ولِلثَّیِّبِ لَیْلَتَیْنِ۔,,,17229 17230,"حَدَّثَنَا عَبدَۃ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ قَالَ : یُقِیمُ عِنْدَ الْبِکْرِ ثَلاَثًا وَیَقْسِمُ وَإِذَا تَزَوَّجَ الثَّیِّبَ أَقَامَ لَیْلَتَیْنِ ثُمَّ یَقْسِمُ۔",,,17230 17231,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ إبْرَاہِیمَ بَلَغَہُ قَالَ : الْبِکْرُ ثَلاَثًا وَالثَّیِّبُ لَیْلَتَیْنِ۔",,,17231 17232,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ زَمْعَۃَ ، عَنْ سَلَمَۃَ بْنِ وَہْرَام ، عَنْ عِکْرِمَۃَ قَالَ : لِلْبِکْرِ سَبْعًا وَلِلثَّیِّبِ ثَلاَثًا۔",,,17232 17233,"حَدَّثَنَا أَبُو قَطَنٍ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ وَحَمَّادٍ قَالاَ : ہُمَا سَوَائٌ فِی الْقَسْمِ۔",,,17233 17234,"حَدَّثَنَا عَبْدُ الْوَہَّابِ بْنُ عَطَائٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، وَسَعِیدِ بْنِ الْمُسَیَّبِ وَخِلاَسٍ قَالُوا : إذَا تَزَوَّجَ الْبِکْرَ عَلَی امْرَأَتِہِ أَقَامَ عنْدَہَا ثَلاَثًا ثُمَّ یَقْسِمُ ، وَإِذَا تَزَوَّجَ الثَّیِّبَ أَقَامَ لَیْلَتَیْنِ ثُمَّ یَقْسِمُ۔",,,17234 17235,"حَدَّثَنَا یَزِیدُ ، عَنْ حُمَیْدٍ ، عَنْ أَنَسٍ قَالَ : مِنَ السُّنَّۃِ لِلْبِکْرِ سَبْعًا وَلِلثَّیِّبِ ثَلاَثًا ، قَالَ حُمَیْدٌ : وَقَالَ الْحَسَنُ : سَبْعًا وَلَیْلَتَیْنِ۔",,,17235 17236,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ غَیْلاَنَ بْنِ جَامِعٍ ، عَنْ عَبْدِ الْمَلِکِ الزرَّاد ، عَنِ الشَّعْبِیِّ ، عَنْ قَمِیر ، عَنْ عَائِشَۃَ قَالَتْ : الْمُسْتَحَاضَۃُ لاَ یَأْتِیہَا زَوْجُہَا۔",,,17236 17237,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ کَرِہَ أَنْ یُجَامِعَہَا زَوْجُہَا۔,,,17237 17238,حَدَّثَنَا عَبْدُ الوَہَّاب الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ أَنَّہُ کَانَ یَکْرَہُ أَنْ یَأْتِیَ الرَّجُلُ امْرَأَتَہُ وَہِیَ مُسْتَحَاضَۃٌ۔,,,17238 17239,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ قَالَ : لاَ یَغْشَاہَا وَلاَ تَصُومُ۔",,,17239 17240,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَبْدِ الْمَلِکِ بْنِ مَیْسَرَۃَ ، قَالَ: قَالَ الشَّعْبِیُّ: لاَ تَصُومُ وَلاَ یَغْشَاہَا زَوْجُہَا",,,17240 17241,"حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنْ أَیُّوبَ قَالَ: قُلْتُ لِسُلَیْمَانَ بْنِ یَسَارٍ: یَأْتِیہَا زَوْجُہَا؟ قَالَ: مَا نَقُولُ فِیہِ إلاَّ مَا سَمِعْنَا۔",,,17241 17242,"حَدَّثَنَا حَفْصٌ ، عَنِ الشَّیْبَانِیِّ ، عَنْ عِکْرِمَۃَ قَالَ : الْمُسْتَحَاضَۃُ یَأْتِیہَا زَوْجُہَا۔",,,17242 17243,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ حُمَیْدٍ ، عَنْ بَکْرِ بْنِ عَبْدِ اللہِ قَالَ : بَلَغَنِی أَنَّ الْحَجَّاجَ قَالَ : إذَا شَکَّتْ فِی الْحَیْضِ اغْتَسَلَتْ وَصَلَّتْ وَلاَ یَقْرَبُہَا حَتَّی تَطْہُرَ ، فَقَالَ : بِئْسَ مَا قَالَ ، الصَّلاَۃُ أَعْظَمُ حُرْمَۃً۔",,,17243 17244,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ مُحَمَّدِ بْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ، عَنْ عَلِیٍّ قَالَ : یَأْتِیہَا زَوْجُہَا",,,17244 17245,"حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ أَشْعَثَ ، عَنْ عَطَائٍ قَالَ : یَأْتِیہَا زَوْجُہَا۔",,,17245 17246,"حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ قَالَ : یَغْشَاہَا زَوْجُہَا إِنْ شَائَ۔",,,17246 17247,"حَدَّثَنَا غُنْدَرٌ ، عَنْ َشُعْبَۃَ ، عَنْ حَمَّادٍ فِی الْمُسْتَحَاضَۃِ : یَأْتِیہَا زَوْجُہَا وَتَصُومُ۔",,,17247 17248,"حَدَّثَنَا وَکِیعٌ ، عَنْ سفیان عن سَالِمٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ فی المستحاضۃ قَالَ : یَأْتِیہَا ، الصَّلاَۃُ أَعْظَمُ حُرْمَۃً۔",,,17248 17249,"حَدَّثَنَا غُنْدَرٌ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ سعید بْنِ الْمُسَیَّبِ ، وَالْحَسَنِ فِی الْمُسْتَحَاضَۃِ : تَصُومُ وَتُصَلِّی وَتَقْضِی الْمَنَاسِکَ وَیَغْشَاہَا زَوْجُہَا۔",,,17249 17250,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ وَحَمَّادٍ ، عَنْ إبْرَاہِیمَ قَالَ : الْمُسْتَحَاضَۃُ تَصُومُ وَتُصَلِّی وَیَأْتِیہَا زَوْجُہَا۔",,,17250 17251,"حَدَّثَنَا وَکِیعٌ ، عَنْ مَعْمَرِ بْنِ مُوسَی ، عَنْ أَبِی جَعْفَرٍ قَالَ : الْمُسْتَحَاضَۃُ یَأْتِیہَا زَوْجُہَا۔",,,17251 17252,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : قَالَ شُرَیْحٌ : ہُوَ الزَّوْجُ یَعنِِْی {الَّذِی بِیَدِہِ عُقْدَۃُ النِّکَاحِ}۔",,,17252 17253,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی مُلَیْکَۃَ ، قَالَ : قَالَ سَعِیدُ بْنُ جُبَیْرٍ : {الَّذِی بِیَدِہِ عُقْدَۃُ النِّکَاحِ} ہُوَ الزَّوْجُ۔",,,17253 17254,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قَالَ مُجَاہِدٌ : {الَّذِی بِیَدِہِ عُقْدَۃُ النِّکَاحِ} ہُوَ الزَّوْجُ ، {إلاَّ أَنْ یَعْفُونَ} ترد الْمَرْأَۃُ شَطْرَہَا {أَوْ یَعْفُوَا الَّذِی بِیَدِہِ عُقْدَۃُ النِّکَاحِ} إتْمَامُ الزَّوْجِ الصَّدَاقَ کُلَّہُ۔",,,17254 17255,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ ، عَنْ شُرَیْحٍ ، وَعن إِسماعیل ، عَنِ الشَّعبی ، عَنْ شُرَیْحٍ وَجُوَیْبِرٌ ، عَنِ الضَّحَّاکِ قَالُوا : ہُوَ الزَّوْجُ۔",,,17255 17256,"حَدَّثَنَا عَبْدَۃُ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنِ ابْنِ الْمُسَیَّبِ : {إلاَّ أَنْ یَعْفُونَ أَوْ یَعْفُوَا الَّذِی بِیَدِہِ عُقْدَۃُ النِّکَاحِ} قَالَ : الَّذِی بِیَدِہِ عُقْدَۃُ النِّکَاحِ الزَّوْجُ ، إِنْ شَائَتْ أَنْ تَعْفُوَ ہِیَ فَلاَ تَأْخُذْ مِنْ صَدَاقِہَا شَیْئًا ، وَإِنْ شَائَ فَہُوَ بَیْنَہُمَا نِصْفَیْنِ۔",,,17256 17257,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ مُحَمَّدِ بْنِ عَمرو أَنَّ نَافِعَ بْنَ جُبَیْرٍ طَلَّقَ امْرَأَتَہُ قَبْلَ أَنْ یَدْخُلَ بِہَا فَأَتَمَّ لَہَا الصَّدَاقَ وَقَالَ : أَنَا أَحَقُّ بِالْعَفْوِ۔",,,17257 17258,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ أَفْلَحَ بن سَعِیدٍ ، قَالَ : سَمِعْتُ مُحَمَّدَ بْنَ کَعْبٍ یَقُولُ : {الَّذِی بِیَدِہِ عُقْدَۃُ النِّکَاحِ} ہُوَ الزَّوْجُ ، یُعْطِی مَا عِنْدَہُ عَفْوًا۔",,,17258 17259,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ قَالَ : {الَّذِی بِیَدِہِ عُقْدَۃُ النِّکَاحِ} الزَّوْجُ ، وَأَمَّا قَوْلُہُ : {إلاَّ أَنْ یَعْفُونَ أَوْ یَعْفُوَا الَّذِی بِیَدِہِ عُقْدَۃُ النِّکَاحِ} فَہِیَ الْمَرْأَۃُ یُطَلِّقُہَا زَوْجُہَا قَبْلَ أَنْ یَدْخُلَ بِہَا فَإِمَّا أَنْ تَعْفُوَ ، عَنِ النِّصْفِ لِزَوْجِہَا وَإِمَّا أَنْ یَعْفُوَ زَوْجُہَا فَیُکْمِلَ لَہَا الصَّدَاقَ۔",,,17259 17260,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی مِجْلَزٍ ، عَنْ شُرَیْحٍ قَالَ : ہُوَ الزَّوْجُ۔",,,17260 17261,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ زُہَیْرٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الشَّعْبِیِّ قَالَ : ہُوَ الزَّوْجُ۔",,,17261 17262,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی بِشْرٍ ، عَنْ طَاوُوسٍ ، وَمُجَاہِدٍ قَالاَ: {الَّذِیْ بِیَدِہٖ عُقْدَۃُ النِّکَاحِ} ہُوَ الْوَلِیُّ وَقَالَ سَعِیدُ بْنُ جُبَیْرٍ : ہُوَ الزَّوْجُ ، فَکَلَّمَاہُ فِی ذَلِکَ فَمَا بَرِحَا حَتَّی تَابَعَا سَعِیدًا۔",,,17262 17263,"حَدَّثَنَا حُمَیْدٌ ، عَنِ الْحَسَنِ ، عَنْ سَالِمٍ ، عَنْ سَعِیدٍ قَالَ : ہُوَ الزَّوْجُ۔",,,17263 17264,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عَلِیِّ بْنِ زَیْدٍ، عَنْ عَمَّارِ بْنِ أَبِی عَمَّارٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ : {الَّذِیْ بِیَدِہٖ عُقْدَۃُ النِّکَاحِ} الزَّوْجُ۔",,,17264 17265,"حَدَّثَنَا ابْنُ الدَّرَاوَرْدِیِّ ، عَنْ عُمَرَ مَوْلَی غُفْرَۃَ أَنَّ مُحَمَّدَ بْنَ کَعْبٍ کَانَ یَقُولُ : {الَّذِیْ بِیَدِہٖ عُقْدَۃُ النِّکَاحِ} الزَّوْجُ",,,17265 17266,"حَدَّثَنَا ابْنُ عُلَیَّۃَ وَوَکِیعٌ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، عَنْ عِیسَی بْنِ عاصم ، عَنْ عَلِیٍّ قَالَ : الزَّوْجُ۔\n\n(بیہقی 251۔ طبری 237)",,,17266 17267,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ ، عَنْ شُرَیْحٍ قَالَ : ہُوَ الزَّوْجُ۔",,,17267 17268,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنْ شُرَیْحٍ قَالَ : ہُوَ الزَّوْجُ۔",,,17268 17269,"حَدَّثَنَا مَرْوَانُ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ قَالَ : ہُوَ الزَّوْجُ۔",,,17269 17270,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ لَیْثٍ، عَنْ مُجَاہِدٍ: {إلاَّ أَنْ یَعْفُونَ أَوْ یَعْفُوَا الَّذِی بِیَدِہِ عُقْدَۃُ النِّکَاحِ} قَالَ : الزَّوْجُ۔",,,17270 17271,"حَدَّثَنَا عُبَیْدُ اللہِ ، عَنْ إسْرَائِیلَ ، عَنْ خُصَیْفٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، وَمُجَاہِدٍ قَالاَ : {الَّذِیْ بِیَدِہٖ عُقْدَۃُ النِّکَاحِ} الزَّوْجُ۔",,,17271 17272,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ قَالَ : ہُوَ الْوَلِیُّ۔",,,17272 17273,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَبِی رَجَائٍ قَالَ: سُئِلَ الْحَسَنُ ، عَنِ {الَّذِیْ بِیَدِہٖ عُقْدَۃُ النِّکَاحِ} قَالَ: ہُوَ الْوَلِیُّ۔",,,17273 17274,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ ، عَنْ عَلْقَمَۃَ قَالَ : ہُوَ الْوَلِیُّ۔",,,17274 17275,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنْ رَجُلٍ ، عَنْ عِکْرِمَۃَ قَالَ ہُوَ الْوَلِیُّ۔,,,17275 17276,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ قَالَ ہُوَ الْوَلِیُّ۔,,,17276 17277,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ قَالَ : الَّذِی بِیَدِہِ عُقْدَۃُ النِّکَاحِ الأَبُ۔",,,17277 17278,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ قَالَ : ہُوَ الْوَلِیُّ۔",,,17278 17279,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ الزُّہْرِیِّ {إلاَّ أَنْ یَعْفُونَ} قَالَ : الثَّیِّبَاتُ {أَوْ یَعْفُوَا الَّذِی بِیَدِہِ عُقْدَۃُ النِّکَاحِ} وَلِیُّ الْبِکْرِ۔",,,17279 17280,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : رَضِیَ اللَّہُ بِالْعَفْوِ وَأَمَرَ بِہِ فَإِنْ عَفَتْ عَفَتْ ، وَإِنْ أَبَتْ وَعَفَا وَلِیُّہَا جَازَ ، وَإِنْ أَبَتْ۔",,,17280 17281,"حَدَّثَنَا زِیَادُ بْنُ الرَّبِیعِ ، عَنْ صَالِحٍ الدَّہَّانِ ، عَنْ جَابِرِ بْنِ زَیْدٍ ، عَنِ ابْنِ عَبَّاسٍ : {وَلاَ یُبْدِینَ زِینَتَہُنَّ} قَالَ : الْکَفُّ وَرُقْعَۃُ الْوَجْہِ۔",,,17281 17282,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الأَحْوَصِ ، عَنْ عَبْدِ اللہِ : {وَلاَ یُبْدِینَ زِینَتَہُنَّ إلاَّ مَا ظَہَرَ مِنْہَا} قَالَ : الثِّیَابُ۔",,,17282 17283,"حَدَّثَنَا حَفْصٌ ، عَنْ عِمرَان بْنِ سُلَیْمَانَ ، عَنْ أَبِی صَالِحٍ ، وَعِکْرِمَۃَ : {وَلاَ یُبْدِینَ زِینَتَہُنَّ} قَالاَ : الْکُحْلُ وَالْخَاتَمُ وَالثِّیَابُ۔",,,17283 17284,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ {وَلاَ یُبْدِینَ زِینَتَہُنَّ} قَالَ : مَا فَوْقَ الدِّرْعِ إلاَّ مَا ظَہَرَ مِنْہَا۔",,,17284 17285,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَلْقَمَۃَ بْنِ مَرْثَدٍ ، عَنْ إبْرَاہِیمَ قَالَ : الثِّیَابُ۔",,,17285 17286,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَاصِمٍ ، عَنِ الشَّعْبِیِّ قَالَ ، الْکُحْلُ وَالثِّیَابُ۔,,,17286 17287,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ أُمِّ شَبِیبٍ ، عَنْ عَائِشَۃَ قَالَتْ : الْقُلْبُ وَالْفَتْخَۃُ۔",,,17287 17288,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنْ مَاہَانَ : إلاَّ مَا ظَہَرَ مِنْہَا ، قَالَ : الثِّیَابُ۔",,,17288 17289,"حَدَّثَنَا مُعْتَمر ، عَنْ یُونُسَ ، عَنِ ابْنِ شِہَابٍ ، عَنِ الْحَسَنِ قَالَ : الْوَجْہُ وَالثِّیَابُ۔",,,17289 17290,"حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ قَالَ : حدَّثَنَا ہِشَامُ بْنُ الْغَازِ قَالَ : حدَّثَنَا نَافِعٌ عن ابْنِ عُمَرَ قَالَ : الزِّینَۃُ الظَّاہِرَۃُ: الْوَجْہُ وَالْکَفَّانِ۔",,,17290 17291,"حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ قَالَ : حدَّثَنَا ہِشَامُ بْنُ الْغَازِ ، قَالَ : سَمِعْتُ عَطَائً یَقُولُ : الزِّینَۃُ الظَّاہِرَۃُ : الْخِضَابُ وَالْکُحْلُ۔",,,17291 17292,"حَدَّثَنَا شَبَابَۃُ ، عَنْ ہِشَامٍ ، قَالَ : سَمِعْتُ مَکْحُولاً یَقُولُ : الزِّینَۃُ الظَّاہِرَۃُ : الْوَجْہُ وَالْکَفَّانِ۔",,,17292 17293,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الأَحْوَصِ قَالَ : الثِّیَابُ۔",,,17293 17294,"حَدَّثَنَا عَفَّانُ قَالَ : حدَّثَنَا سَعِیدُ بْنُ زَیْدٍ قَالَ : حدَّثَنَا عَطَائُ بْنُ السَّائِبِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ : {وَلاَ یُبْدِینَ زِینَتَہُنَّ إلاَّ مَا ظَہَرَ مِنْہَا} الْخَاتَمُ وَالْخِضَابُ وَالْکُحْلُ۔",,,17294 17295,"حَدَّثَنَا عَفَّانُ قَالَ : حدَّثَنَا سَعِیدُ بْنُ زَیْدٍ قَالَ : حدَّثَنَا لَیْثٌ ، عَنْ مُجَاہِدٍ قَالَ : الْخِضَابُ وَالْکُحْلُ۔",,,17295 17296,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الأَحْوَصِ ، عَنْ عَبْدِ اللہِ قَالَ: الزِّینَۃُ زِینَتَانِ : زِینَۃٌ ظَاہِرَۃٌ وَزِینَۃٌ بَاطِنَۃٌ لاَ یَرَاہَا إلاَّ الزَّوْجُ ، وَأَمَّا الزِّینَۃُ الظَّاہِرَۃُ فَالثِّیَابُ ، وَأَمَّا الزِّینَۃُ الْبَاطِنَۃُ فَالْکُحْلُ وَالسِّوَارُ وَالْخَاتَمُ۔",,,17296 17297,"حَدَّثَنَا حَفْصٌ ، عَنْ عَبْدِ اللہِ بْنِ مُسْلِمٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ : {وَلاَ یُبْدِینَ زِینَتَہُنَّ إلاَّ مَا ظَہَرَ مِنْہَا} قَالَ : وَجْہُہَا وَکَفُّہَا۔",,,17297 17298,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ مُسْلم ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ قَالَ : کَفُّہَا وَوَجْہُہَا۔",,,17298 17299,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ قَالَ : حدَّثَنَا سَلَمَۃُ بْنُ سَابُورَ ، عَنْ عَبْدِ الْوَارِثِ : {وَلاَ یُبْدِینَ زِینَتَہُنَّ إلاَّ مَا ظَہَرَ مِنْہَا} قَالَ : الْکَفُّ وَالْخَاتَمُ۔",,,17299 17300,"حَدَّثَنَا أَحْمَدُ بْنُ بَشِیرٍ ، عَنِ ابْنِ شُبْرُمَۃَ ، عَنْ عِکْرِمَۃَ قَالَ : {مَا ظَہَرَ مِنْہَا} قَالَ : الْوَجْہُ وَثُغْرَۃُ النَّحْرِ۔",,,17300 17301,"حَدَّثَنَا عَبْدَۃُ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ أَبِی الْخَلِیلِ ، عَنْ عَبْدِ اللہِ بْنِ الْحَارِثِ ، عَنْ أُمِّ الْفَضْلِ قَالَتْ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تُحَرِّمُ الرَّضْعَۃُ وَالرَّضْعَتَانِ وَالْمَصَّۃُ وَالْمَصَّتَانِ۔\n\n(مسلم 18۔ احمد 6/339)",,,17301 17302,"حَدَّثَنَا عَبْدَۃُ ، وَابْنُ نُمَیْرٍ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، عَنِ ابْنِ الزُّبَیْرِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تُحَرِّمُ الْمَصَّۃُ وَالْمَصَّتَانِ۔ (ابن حبان 4225۔ احمد 4/4)",,,17302 17303,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَشْعَثَ بْنِ أَبِی الشَّعْثَائِ ، عَنْ أَبِیہِ ، عَنْ مَسْرُوقٍ ، عَنْ عَائِشَۃَ قَالَتْ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّمَا الرَّضَاعَۃُ مِنَ الْمَجَاعَۃِ۔ (بخاری 5102۔ مسلم 32)",,,17303 17304,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، عَنْ قَیْسٍ ، عَنِ الْمُغِیرَۃِ بْنِ شُعْبَۃَ قَالَ : لاَ تُحَرِّمُ الغبقۃ وَلاَ الْغَبْقَتَانِ۔\n\n(بیہقی 457)",,,17304 17305,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی الزُّبَیْرِ قَالَ : سَأَلْتُ ابْنَ الزُّبَیْرِ ، عَنِ الرَّضَاعِ ، فَقَالَ : لاَ تُحَرِّمُ الرَّضْعَۃُ وَلاَ الرَّضْعَتَانِ وَلاَ الثَّلاَثُ۔",,,17305 17306,"حَدَّثَنَا إِسْحَاقُ بْنُ سُلَیْمَانَ ، عَنْ حَنْظَلَۃَ ، عَنْ سَالِمٍ ، عَنْ زَیْدٍ قَالَ : لاَ تُحَرِّمُ الرَّضْعَۃُ وَلاَ الرَّضْعَتَانِ۔",,,17306 17307,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرِ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ قَالَ : یُحَرِّمُ مِنْہُ مَا فَتَقَ الأَمْعَائَ۔",,,17307 17308,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ إسْمَاعِیلَ ، عَنْ أَبِی عَمْرٍو الشَّیْبَانِیِّ ، قَالَ : قَالَ عَبْدُ اللہِ : إنَّمَا یُحَرِّمُ مِنَ الرَّضَاعِ مَا أَنْبَتَ اللَّحْمَ وَأَنْشَزَ الْعَظْمَ۔",,,17308 17309,"حَدَّثَنَا ابْنُ فُضَیْلٍ، عَنْ لَیْثٍ، عَنْ مُجَاہِدٍ، قَالَ: قَالَ أَبُو مُوسَی: لاَ یُحَرِّمُ الرَّضَاعُ إلاَّ مَا أَنْبَتَ اللَّحْمَ وَالدَّمَ۔",,,17309 17310,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ قَالَ : کَانَتْ عَائِشَۃُ إذَا أَرَادَتْ أَنْ یَدْخُلَ عَلَیْہَا أَحَدٌ أَمَرَتْ بِہِ فَأُرْضِعَ فَأَمَرَتْ أُمَّ کُلْثُومٍ أَنْ تُرْضِعَ سَالِمًا عَشْرَ رَضَعَاتٍ فَأَرْضَعَتْہُ ثَلاَثًا فَمَرِضَتْ ، فَکَانَ لاَ یَدْخُلُ عَلَیْہَا وَأَمَرَتْ فَاطِمَۃَ بِنْتَ عُمَرَ أَنْ تُرْضِعَ عَاصِمَ بْنَ سَعْدٍ مَوْلًی لَہُمْ عَشْرَ رَضَعَاتٍ ، فَأَرْضَعَتْہُ فَکَانَ یَدْخُلُ عَلَیْہَا۔ (عبدالرزاق 13929)",,,17310 17311,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنْ قَتَادَۃَ قَالَ : کَتَبْتُ إلَی إبْرَاہِیمَ أَسْأَلُہُ ، عَنِ الرَّضَاعِ فَکَتَبَ إلَیَّ أَنَّ عَلِیًّا ، وَعَبْدَ اللہِ کَانَا یَقُولاَنِ : قَلِیلُہُ وَکَثِیرُہُ حَرَامٌ۔",,,17311 17312,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ قَالَ ابْنُ مَسْعُودٍ : یُحَرِّمُ قَلِیلُ الرَّضَاعِ کَمَا یُحَرِّمُ کَثِیرُہُ ، وَقَالَ مُجَاہِدٌ : قَوْلُ ابْنِ مَسْعُودٍ أَحَبُّ إلَیَّ۔",,,17312 17313,"حَدَّثَنَا وَکِیعٌ عن سفیان ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَابِسٍ ، قَالَ : سَمِعْتُ ابْنَ عَبَّاسٍ وسُئِلَ عَنِ المرأۃ تُرْضِعُ الصَّبِیَّ الرَّضْعَۃَ ، فَقَالَ : إذَا عقا الصَّبِیُّ حَرُمَتْ عَلَیْہِ ، وَمَا وَلَدَتْ۔",,,17313 17314,"حَدَّثَنَا إِسْحَاقُ بْنُ سُلَیْمَانَ ، عَنْ حَنْظَلَۃَ ، عَنْ طَاوُوسٍ قَالَ : اشْتَرَطَ عَشْرَ رَضَعَاتٍ ثُمَّ قِیلَ : إنَّ الرَّضْعَۃَ الْوَاحِدَۃَ تُحَرِّمُ۔",,,17314 17315,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ قَالَ : الْحَکَمُ وَحَمَّادٌ قَالاَ : الْمَصَّۃُ تُحَرِّمُ۔",,,17315 17316,"حَدَّثَنَا أَبُو خَالِدٍ الأحمر ، عَنْ حَجَّاجٍ ، عَنْ حَبِیبٍ ، عَنْ طَاوُوسٍ قَالَ : سَأَلْتُ ابْنَ عَبَّاسٍ ، فَقَالَ : الْمَرَّۃُ الْوَاحِدَۃُ تُحَرِّمُ۔",,,17316 17317,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی الزُّبَیْرِ قَالَ : سَأَلْتُ ابن عمر ، فَقَالَ الْمَصَّۃُ الْوَاحِدَۃُ تُحَرِّمُ۔",,,17317 17318,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ زَمْعَۃَ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ وَعن حُمَیْدٍ الأَعْرَجِ ، عَنْ مُجَاہِدٍ وعَمَّنْ سَمِعَ عَطَائً ، قَالَ زَمْعَۃُ : وَسَمِعْتُ عَمْرَو بْنَ دِینَارٍ یَقُولُ : قَالُوا : یُحَرِّمُ قَلِیلُ الرَّضَاعِ وَکَثِیرُہُ۔",,,17318 17319,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ جَابِرِ بْنِ زَیْدٍ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أُرِیدَ عَلَی ابْنَۃِ حَمْزَۃَ بْنِ عَبْدِ الْمُطَّلِبِ ، فَقَالَ : إنَّہَا ابْنَۃُ أَخِی مِنَ الرَّضَاعَۃِ وَإِنَّہُ یَحْرُمُ مِنَ الرَّضَاعَۃِ مَا یَحْرُمُ مِنَ النَّسَبِ۔ (بخاری 2645۔ مسلم 13 )",,,17319 17320,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِِ ، عَنْ سَعْدِ بْنِ عُبَیْدَۃَ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ، عَنْ عَلِیٍّ قَالَ : قُلْتُ : یَا رَسُولَ اللہِ مَا لَکَ تَنوَّقُ فِی قُرَیْشٍ وَتَدَعُنَا قَالَ : عِنْدَکُمْ شَیْئٌ ؟ قُلْتُ : نَعَمْ ، ابنْۃ حَمْزَۃَ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّہَا لاَ تَحِلُّ لِی ، إنَّہَا بِنْتُ أَخِی مِنَ الرَّضَاعَۃِ۔ (مسلم 11۔ احمد 1/82)",,,17320 17321,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عُرْوَۃَ ، عَنْ عَائِشَۃَ قَالَتْ : أَتَانِی عَمِّی مِنَ الرَّضَاعَۃِ أَفْلَحُ بن أَبِی الْقُعَیْسِ یَسْتَأْذِنُ عَلَیَّ بَعْدَ مَا ضُرِبَ الْحِجَابُ فَأَبَیْتُ أَنْ آذَنَ لَہُ حَتَّی دَخَلَ عَلَیَّ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : إنَّہُ عَمُّک فَأْذَنِی لَہُ قالت : إنَّمَا أَرْضَعْتنِی الْمَرْأَۃُ وَلَمْ یُرْضِعْنِی الرَّجُلُ قَالَ : تَرِبَتْ یَدَاک، أَوْ یَمِینُک۔ (مسلم 1069۔ ابن ماجہ 1948)",,,17321 17322,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ زَیْنَبَ بِنْتِ أُمِّ سَلَمَۃَ ، عَنْ أُمِّ سَلَمَۃَ أن أُمَّ حَبِیبَۃَ قَالَتْ : یَا رَسُولَ اللہِ ، ہَلْ لَکَ فِی أُخْتِی ابْنَۃِ أَبِی سُفْیَانَ ؟ قَالَ : إنَّہَا لاَ تَحِلُّ لِی قَالَتْ : فَإِنَّہُ قَدْ بَلَغَنِی أَنَّک تَخْطُبُ دُرَّۃَ بِنْتَ أَبِی سَلَمَۃَ قَالَ : بِنْتُ أَبِی سَلَمَۃَ ؟ قَالَتْ : نَعَمْ ، قَالَ : وَاللَّہِ إِنْ لَمْ تَکُنْ رَبِیبَتِی فِی حِجْرِی مَا حَلَّتْ لِی ، إنَّہَا ابْنَۃُ أَخِی مِنَ الرَّضَاعَۃِ ، أَرْضَعَتْنِی وَأَبَاہَا ثُوَیْبَۃُ فَلاَ تَعْرِضْنَ عَلَیَّ بَنَاتِکُنَّ وَلاَ أَخَوَاتِکُنَّ۔\n\n(بخاری 5106۔ مسلم 1072)",,,17322 17323,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ قَالَ : کَانَتْ عَائِشَۃُ تُحَرِّمُ مِنَ الرَّضَاعَۃِ مَا تُحَرِّمُ مِنَ الْوِلاَدَۃِ۔",,,17323 17324,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ مُوسَی بْنِ أَیُّوبَ قَالَ : حدَّثَنِی عَمِّی إیَاسُ بْنُ عَامِرٍ ، قَالَ : قَالَ عَلِیٌّ : لاَ تَنْکِحْ مَنْ أَرْضَعَتْہُ امْرَأَۃُ أَخِیک وَلاَ امْرَأَۃُ أَبِیک وَلاَ امْرَأَۃُ ابْنِک۔",,,17324 17325,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنٍ ، عَنْ عَبْدِ الأَعْلَی ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : یَحْرُمُ مِنَ الرَّضَاعَۃِ مَا یَحْرُمُ مِنَ النَّسَبِ۔",,,17325 17326,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ، عَنْ دَاوُدَ، عَنْ أَبِی مَعْشَرٍ، عَنْ إبْرَاہِیمَ قَالَ: یَحْرُمُ مِنَ الرَّضَاعَۃِ مَا یَحْرُمُ مِنَ النَّسَبِ۔",,,17326 17327,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ، عَنْ عَبْدِ اللہِ بْنِ عُتْبَۃَ قَالَ : أُرَاہُ ، عَنْ عَبْدِ اللہِ قَالَ : یَحْرُمُ مِنَ الرَّضَاعَۃِ مَا یَحْرُمُ مِنَ النَّسَبِ۔",,,17327 17328,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنْ عِرَاکِ بْنِ مَالِکٍ ، عَنْ عُرْوَۃَ ، عَنْ عَائِشَۃَ قَالَتْ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : یَحْرُمُ مِنَ الرَّضَاعَۃِ مَا یَحْرُمُ مِنَ النَّسَبِ۔ (مسلم 9۔ ابن ماجہ 1937)",,,17328 17329,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ إسْرَائِیلَ ، عَنْ إِبْرَاہِیمَ بن عَبْدِ الأَعْلَی ، قَالَ : سَمِعْتُ سُوَیْد بْنَ غَفَلَۃَ یَقُولُ : یَحْرُمُ مِنَ الرَّضَاعَۃِ مَا یَحْرُمُ مِنَ النَّسَبِ۔",,,17329 17330,"حَدَّثَنَا عُبَیْدُ اللہِ ، عَنْ إسْرَائِیلَ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْبَرَائِ أَنَّہُ قِیلَ لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : ہَلْ لَکَ فِی بِنْتِ حَمْزَۃَ ؟ فَقَالَ : إنَّہَا لاَ تَحِلُّ لِی ، إنَّہَا ابْنَۃُ أَخِی مِنَ الرَّضَاعَۃِ۔ (بخاری 4251)",,,17330 17331,"حَدَّثَنَا حَفْصٌ ، عَنِ الشَّیْبَانِیِّ ، عَنْ أَبِی الضُّحَی ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ، عَنِ ابْنِ مَسْعُودٍ قَالَ : لاَ رَضَاعَ إلاَّ مَا کَانَ فِی الْحَوْلَیْنِ۔",,,17331 17332,حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ قَالَ عَبْدُ اللہِ لاَ رَضَاعَ إلاَّ مَا کَانَ فِی الْحَوْلَیْنِ۔,,,17332 17333,"حَدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ زُبَیْدٍ قَالَ قَالَ عَلِیٌّ : لاَ یُحَرِّمُ مِنَ الرَّضَاعِ إلاَّ مَا کَانَ فِی الْحَوْلَیْنِ۔",,,17333 17334,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ رَضَاعَ إلاَّ مَا کَانَ فِی الْحَوْلَیْنِ۔",,,17334 17335,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَاصِمٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ رَضَاعَ بَعْدَ الْفِصَالِ۔",,,17335 17336,حَدَّثَنَا ابْنُ عُیَیْنَۃَ، عَنْ عَبْدِ اللہِ بْنِ دِینَارٍ، عَنِ ابْنِ عُمَرَ، عَنْ عُمَرَ، قَالَ لاَ رَضَاعَ إلاَّ مَا کَانَ فِی الصِّغَرِ۔,,,17336 17337,"حَدَّثَنَا وَکِیعٌ ، عَنْ یَزِیدَ بْنِ إبْرَاہِیمَ ، عَنِ الْحَسَنِ ، قَالَ : قَالَ عُمَرُ : لاَ رَضَاعَ بَعْدَ الْفِصَالِ۔",,,17337 17338,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی جَنَابٍ ، عَنْ إسْمَاعِیلَ بْنِ رَجَائٍ ، عَنِ النَّزَّالِ بْنِ سَبْرَۃَ ، عَنْ عَلِیٍّ قَالَ : لاَ رَضَاعَ بَعْدَ الْفِصَالِ۔",,,17338 17339,"حَدَّثَنَا عَبْدَۃُ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ یَحْیَی بْنِ عَبْدِ الرَّحْمَنِ بْنِ حَاطِبٍ ، عَنْ جَدِّہِ أَنَّہُ سَأَلَ أُمَّ سَلَمَۃَ ، عَنِ الرَّضَاعِ ، فَقَالَتْ : لاَ رَضَاعَ إلاَّ مَا کَانَ فِی الْمَہْدِ قَبْلَ الْفِطَامِ۔",,,17339 17340,"حَدَّثَنَا عَبْدَۃُ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ أَنَّ أَبَا ہُرَیْرَۃَ سُئِلَ عَنِ الرَّضَاعِ ، فَقَالَ : لاَ یُحَرِّمُ مِنَ الرَّضَاعِ إلاَّ مَا فَتَقَ الأَمْعَائَ ، وَکَانَ فِی الثَّدْیِ قَبْلَ الْفِطَامِ۔",,,17340 17341,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ حَجَّاج بْنِ حَجَّاج ، عَنْ أَبِی ہُرَیْرَۃَ بِمِثْلِہِ۔,,,17341 17342,"حَدَّثَنَا ابْنُ نُمَیْرٍ قَالَ : حدَّثَنَا ہِشَامُ بْنُ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ حَجَّاج بْنِ حَجَّاج ، عَنْ أَبِیہِ ، عَنْ أَبِی ہُرَیْرَۃَ بِمِثْلِہِ۔",,,17342 17343,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، وَأَبُو أُسَامَۃَ ، عَنْ سُفْیَانَ ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ أَنَّ عَلْقَمَۃَ مَرَّ بِامْرَأَۃٍ وَہِیَ تُرْضِعُ صَبِیًّا لَہَا بَعْدَ الْحَوْلَیْنِ ، فَقَالَ : لاَ تسقیہ داء ک۔",,,17343 17344,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ قَالَ : إذَا فُطِمَ الصَّبِیُّ فَلاَ رَضَاعَ بَعْدَ الْفِطَامِ۔",,,17344 17345,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ قَالَ : لاَ یُحَرِّمُ مِنَ الرَّضَاعِ إلاَّ مَا کَانَ فِی الصِّغَرِ۔",,,17345 17346,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : لاَ رَضَاعَ إلاَّ مَا کَانَ فِی الْمَہْدِ ، وَإِلاَّ مَا أَنْبَتَ اللَّحْمَ وَالدَّمَ۔",,,17346 17347,"حَدَّثَنَا حَفْصٌ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ قَالَ : مَا کَانَ مِنْ رضاع ، أَوْ سَعُوطٍ فِی السَّنَتَیْنِ فَہُوَ رَضَاعٌ ، وَمَا کَانَ بَعْدُ فَلَیْسَ بِرَضَاعٍ۔",,,17347 17348,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنِ عَبْدِ اللہِ وَحَسَنٍ ابْنَی مُحَمَّدٍ ، عَنْ أَبِیہِمَا أَنَّ عَلِیًّا قَالَ لابْنِ عَبَّاسٍ : أَمَا عَلِمْتَ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی ، عَنِ الْمُتْعَۃِ وَعَنْ لُحُومِ الْحُمُرِ الأَہْلِیَّۃِ ؟۔\n\n(بخاری 4216۔ مسلم 29)",,,17348 17349,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنِ الرَّبِیعِ بْنِ سَبْرَۃَ الْجُہَنِیِّ ، عَنْ أَبِیہِ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی یَوْمَ الْفَتْحِ ، عَنْ مُتْعَۃِ النِّسَائِ۔ (مسلم 26۔ ابوداؤد 2066),,,17349 17350,"حَدَّثَنَا عَبْدَۃُ، عَنْ عَبْدِ الْعَزِیزِ بْنِ عُمَرَ ، عَنِ الرَّبِیعِ بْنِ سَبْرَۃَ ، عَنْ أَبِیہِ قَالَ : رَأَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَائِمًا بَیْنَ الرُّکْنِ وَالْبَابِ وَہُوَ یَقُولُ : أَیُّہَا النَّاسُ ، إنِّی کُنْتُ قد أَذِنْتُ لَکُمْ فِی الاِسْتِمْتَاعِ، أَلاَ وَإِنَّ اللَّہَ حَرَّمَہَا إلَی یَوْمِ الْقِیَامَۃِ فَمَنْ کَانَ عِنْدَہُ مِنْہُنَّ شَیْئٌ فَلْیُخَلِّ سَبِیلَہُ وَلاَ تَأْخُذُوا مِمَّا آتَیْتُمُوہُنَّ شَیْئًا۔\n\n(مسلم 25۔ ابن ماجہ 1962)",,,17350 17351,"حَدَّثَنَا یُونُسُ بْنُ مُحَمَّدٍ ، عَنْ عَبْدِ الْوَاحِدِ بْنِ زِیَادٍ قَالَ : حدَّثَنَا أَبُو الْعُمَیْسِ ، عَنْ إیَاسِ بْنِ سَلَمَۃَ ، عَنْ أَبِیہِ قَالَ : رَخَّصَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَامَ أَوْطَاسٍ فِی الْمُتْعَۃِ ثَلاَثًا ثُمَّ نَہَی عَنْہَا۔\n\n(مسلم 18۔ احمد 4/55)",,,17351 17352,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ عُمَرُ : لَوْ تَقَدَّمْتُ فِیہَا لَرَجَمْتُ یَعْنِی الْمُتْعَۃَ۔",,,17352 17353,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ دَاوُدَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : نَہَی عُمَرَ ، عَنْ مُتْعَتَیْنِ مُتْعَۃِ النِّسَائِ وَمُتْعَۃِ الْحَجِّ۔",,,17353 17354,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ ، عَنْ أَبِیہِ قَالَ : سُئِلَ عَنْ مُتْعَۃِ النِّسَائِ ، فَقَالَ : لاَ نَعْلَمُہَا إلاَّ السِّفَاحَ۔",,,17354 17355,"حَدَّثَنَا عَبدَۃ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ سُئِلَ عَنِ الْمُتْعَۃِ ، فَقَالَ : حرَامٌ فَقِیلَ لَہُ : إنَّ ابْنَ عَبَّاسٍ یُفْتِی بِہَا ، فَقَالَ : فَہَلاَّ تَزَمْزَمَ بِہَا فِی زَمَانِ عُمَرَ۔",,,17355 17356,"حَدَّثَنَا عَبدَۃ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ أَنَّہُ قَالَ : رَحِمَ اللَّہُ عُمَرَ ، لَوْلاَ إِنَّہُ نَہَی ، عَنِ الْمُتْعَۃِ صَارَ الزِّنَا جِہَارًا۔",,,17356 17357,"حَدَّثَنَا عَبدَۃ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ قَالَ : وَاللَّہِ مَا کَانَتِ الْمُتْعَۃُ إلاَّ ثَلاَثَۃَ أَیَّامٍ أَذِنَ لَہُمْ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِیہَا ، مَا کَانَتْ قَبْلَ ذَلِکَ وَلاَ بَعْدُ۔ (عبدالرزاق 14040)",,,17357 17358,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حَدَّثَنِی عَبْدُ اللہِ بْنُ الْوَلِیدِ ، قَالَ : قَالَ لِی ابْنُ ذُؤَیبٍ : سَمِعْتُ ابْنَ الزُّبَیْرِ یَخْطُبُ وَہُوَ یَقُولُ : إنَّ الذِّئْبَ یُکَنَّی أَبَا جَعْدَۃَ ، أَلاَ وَإِنَّ الْمُتْعَۃَ ہِیَ الزِّنَا۔",,,17358 17359,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ عُمَرَ ، عَنِ الْحَسَنِ بْنِ مُسْلِمٍ ، عَنِ طَاوُوسٍ قَالَ : کَانَتْ سُنَّۃُ الْمُتْعَۃِ سُنَّۃَ النِّکَاحِ إلاَّ أَنَّ الأَجَلَ کَانَ فِی أَیْدِیہِنَّ۔",,,17359 17360,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنِ الْعَلاَئِ بْنِ الْمُسَیَّبِ ، عَنْ أَبِیہِ ، قَالَ : قَالَ عُمَرُ : لَوْ أُتِیتُ بِرَجُلٍ تَمَتَّعَ بِامْرَأَۃٍ لَرَجَمْتُہُ إِنْ کَانَ أُحْصِنَ فَإِنْ کَانَ لَمْ یَکُنْ أُحْصِنَ ضَرَبْتُہُ۔",,,17360 17361,"حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ ، عَنْ ہِشَامِ بْنِ الْغَازِ ، قَالَ : سَمِعْتُ مَکْحُولاً یَقُولُ فِی الرَّجُلِ یَتَزَوَّجُ الْمَرْأَۃَ إلَی أَجَلٍ قَالَ : ذَلِکَ الزِّنَا۔",,,17361 17362,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا إسْمَاعِیلُ ، عَنْ قَیْسٍ ، عَنْ عَبْدِ اللہِ قَالَ : کُنَّا مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَنَحْنُ شَبَابٌ قَالَ فَقُلْنَا : یَا رَسُولَ اللہِ ، أَلاَ نَسْتَخْصِی ؟ قَالَ : لاَ ثُمَّ رَخَّصَ لَنَا أَنْ نَنْکِحَ الْمَرْأَۃَ بِالثَّوْبِ إلَی الأَجَلِ ثُمَّ قَرَأَ عَبْدُ اللہِ : {یَا أَیُّہَا الَّذِینَ آمَنُوا لاَ تُحَرِّمُوا طَیِّبَاتِ مَا أَحَلَّ اللَّہُ لَکُمْ}۔",,,17362 17363,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِِ ، عَنِ الْمُسَیَّبِ بْنِ رَافِعٍ ، عَنْ قَبِیصَۃَ بْنِ جَابِرٍ ، عَنْ عُمَرَ ، قَالَ : لاَ أُوتَی بِمُحِلٍّ وَلاَ مُحَلَّلٍ لَہُ إلاَّ رَجَمْتُہُمَا۔",,,17363 17364,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ الْحَذَّائِ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ رَجُلٍ ، عَنِ ابْنِ عُمَرَ أَنَّہُ قَالَ : لَعَنَ اللَّہُ الْمُحِلَّ وَالْمُحَلَّلَ لَہُ وَالْمُحَلَّلَۃَ۔",,,17364 17365,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ سَعِیدِ بْنِ أَبِی عَرُوبَۃَ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ عَبْدِ الْمَلِکِ بْنِ الْمُغِیرَۃِ بْنِ نَوْفَلٍ أَنَّ ابْنَ عُمَرَ سُئِلَ عَنْ تَحْلِیلِ الْمَرْأَۃِ لِزَوْجِہَا قَالَ : ذَلِکَ السِّفَاحُ ، لَوْ أَدْرَکَکُمْ عُمَرُ لَنَکَّلَکُمْ۔",,,17365 17366,"حَدَّثَنَا وَکِیعٌ ، عَنِ أَبِی شِہَابٍ ، عَنْ جَبَلَۃَ بْنِ دَعْلَجٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ قَالَ : الْمُحَلِّلُ مَلْعُونٌ۔",,,17366 17367,"حَدَّثَنَا ہُشَیْمٌ، عَنْ مُغِیرَۃَ، عَنْ إبْرَاہِیمَ وَعَنْ یُونُسَ، عَنِ الْحَسَنِ قَالاَ: إذَا ہَمَّ أَحَدُ الثَّلاَثَۃِ فَسَدَ النِّکَاحُ۔",,,17367 17368,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ قَالَ : سَأَلْتُ الْحَکَمَ وَحَمَّادًا ، عَنْ رَجُلٍ تَزَوَّجَ امْرَأَۃً لِیُحِلَّہَا لِزَوْجِہَا ، فَقَالَ الْحَکَمُ : یُمْسِکُہَا وَقَالَ حَمَّادٌ : أَحَبُّ إلَیَّ أَنْ یُفَارِقَہَا۔",,,17368 17369,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ حَبِیبٍ ، عَنْ عَمْرٍو ، عَنْ جَابِرِ بْنِ زَیْدٍ فِی رَجُلٍ تَزَوَّجَ امْرَأَۃً لِیُحِلَّہَا لِزَوْجِہَا وَہُوَ لاَ یَعْلَمُ قَالَ : لاَ یَصْلُحُ ذَلِکَ إذَا کَانَ تَزَوَّجَہَا لَیُحِلَّہَا۔",,,17369 17370,"حَدَّثَنَا عَائِذُ بْنُ حَبِیبٍ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ قَالَ : لُعِنَ الْمُحِلُّ وَالْمُحَلَّلُ لَہُ۔",,,17370 17371,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ سُفْیَانَ ، عَنْ أَبِی قَیْسٍ ، عَنْ ہُزَیْلٍ ، عَنْ عَبْدِ اللہِ قَالَ : لَعَنَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْمُحِلَّ وَالْمُحَلَّلَ لَہُ۔ (ترمذی 1820۔ احمد 1/462)",,,17371 17372,حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ مُجَالِدٍ ، عَنْ عَامِرٍ ، عَنِ جابر بْنِ عَبْدِ اللہِ ، عَنْ عَلِیٍّ قَالَ لَعَنَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْمُحِلَّ وَالْمُحَلَّلَ لَہُ۔ (ابوداؤد 2070۔ احمد 1/83),,,17372 17373,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ مُوسَی بْنِ أَبِی الْفُرَاتِ ، عَنْ عَمْرِو بْنِ دِینَارٍ أنَّہُ سُئِلَ عَنْ رَجُلٍ طَلَّقَ امْرَأَتَہُ فَجَائَ رَجُلٌ مِنْ أَہْلِ الْقَرْیَۃِ بِغَیْرِ عِلْمِہِ وَلاَ عِلْمِہَا فَأَخْرَجَ شَیْئًا مِنْ مَالِہِ فَتَزَوَّجَہَا بہ لِیُحِلَّہَا لَہُ ، فَقَالَ : لاَ ، ثُمَّ ذَکَرَ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سُئِلَ عَنْ مِثْلِ ذَلِکَ ، فَقَالَ : لاَ حَتَّی یَنْکِحَہَا مُرْتَغِِبًا لِنَفْسِہِ ، حَتَّی یَتَزَوَّجَہَا مُرْتَغِِبًا لِنَفْسِہِ ، فَإِذَا فَعَلَ ذَلِکَ لَمْ تَحِلَّ لَہُ حَتَّی یذُوقَ الْعُسَیْلَۃَ۔",,,17373 17374,"حَدَّثَنَا مُعَاذٌ قَالَ : حدَّثَنَا عَبَّادُ بْنُ مَنْصُورٍ قَالَ : جَائَ رَجُلٌ إلَی الْحَسَنِ ، فَقَالَ : إنَّ رَجُلاً مِنْ قَوْمِی طَلَّقَ امْرَأَتَہُ ثَلاَثًا فَنَدِمَ وَنَدِمَتْ ، فَأَرَدْتُ أَنْ أَنْطَلِقَ فَأَتَزَوَّجَہَا وَأَصْدُقَہَا صَدَاقًا ثُمَّ أَدْخُلَ بِہَا کَمَا یَدْخُلُ الرَّجُلُ بِامْرَأَتِہِ ، ثُمَّ أُطَلِّقَہَا حَتَّی تَحِلَّ لِزَوْجِہَا ، قَالَ ، فَقَالَ لَہُ الْحَسَنُ : اتَّقِ اللَّہَ یَا فَتَی وَلاَ تَکُونَنَّ مِسْمَارَ نَارٍ لِحُدُودِ اللہِ۔",,,17374 17375,"حَدَّثَنَا الْمُعَلَّی بْنُ مَنْصُورٍ قَالَ : حدَّثَنَا عَبْدُ اللہِ بْنُ جَعْفَرٍ ، عَنْ عُثْمَانَ بْنِ مُحَمَّدٍ الأَخْنَسِیِّ ، عَنِ الْمَقْبُرِیِّ ، عَنْ أَبِی ہُرَیْرَۃَ قَالَ : لَعَنَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْمُحِلَّ وَالْمُحَلَّلَ لَہُ۔\n\n(ترمذی 437۔ احمد 2/323)",,,17375 17376,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عَنْ أَبِی السَّنَابِلِ قَالَ : وَضَعَتْ سُبَیْعَۃُ بِنْتُ الْحَارِثِ حَمْلَہَا بَعْدَ وَفَاۃِ زَوْجِہَا بِبِضْعٍ وَعِشْرِینَ لَیْلَۃً فَلَمَّا تَعَلَّتْ مِنْ نِفَاسِہَا تَشَوَّفَتْ فَعِیبَ ذَلِکَ عَلَیْہَا وَذُکِرَ أَمْرُہَا لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : إِنْ تَفْعَلْ فَقَدْ مَضَی أَجَلُہَا۔\n\n(طبرانی 896۔ دارمی 2281)",,,17376 17377,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ یحیی بْنِ سَعِیدٍ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ ، عَنْ أَبِی سَلَمَۃَ قَالَ : کُنْتُ أَنَا ، وَابْنُ عَبَّاسٍ ، وَأَبُو ہُرَیْرَۃَ فَتَذَاکَرْنَا : الرَّجُلُ یَمُوتُ ، عَنِ الْمَرْأَۃِ فَتَضَعُ بَعْدَ وَفَاتِہِ بِیَسِیرٍ فَقُلْتُ : إذَا وَضَعَتْ فَقَدْ حَلَّتْ وَقَالَ ابْنُ عَبَّاسٍ : أَجَلُہَا آخِرُ الأَجَلَیْنِ فَتَرَاجَعَا بِذَلِکَ ، فَقَالَ أَبُو ہُرَیْرَۃَ : أَنَا مَعَ ابْنِ أَخِی یَعْنِی أَبَا سَلَمَۃَ فَبَعَثُوا کُرَیْبًا مَوْلَی ابْنِ عَبَّاسٍ إلَی أُمِّ سَلَمَۃَ ، فَقَالَتْ : إنَّ سُبَیْعَۃَ الأَسْلَمِیَّۃَ وَضَعَتْ بَعْدَ وَفَاۃِ زَوْجِہَا بِأَرْبَعِینَ لَیْلَۃً ، وَإِنَّ رَجُلاً مِنْ بَنِی عَبْدِ الدَّارِ یُکَنَّی أَبَا السَّنَابِلِ خَطَبَہَا وَأَخْبَرَہَا أَنَّہَا قَدْ حَلَّتْ فَأَرَادَتْ أَنْ تَتَزَوَّجَ غَیْرَہُ ، فَقَالَ لَہَا أَبُو السَّنَابِلِ : إنَّک لَمْ تَحِلِّینَ فَذَکَرَتْ ذَلِکَ سُبَیْعَۃُ لِرَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَأَمَرَہَا أَنْ تَتَزَوَّجَ۔ (مسلم 122۔ ترمذی 1123)",,,17377 17378,حَدَّثَنَا عَبْدَۃُ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، عَنِ الْمِسْوَرِ أَنَّ سُبَیْعَۃَ وَضَعَتْ بَعْدَ وَفَاۃِ زَوْجِہَا بِشَہْرٍ فَأَتَتِ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَأَمَرَہَا النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ تَزَوَّجَ۔ (بخاری 5320۔ احمد 4/327),,,17378 17379,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ ، قَالَ : قَالَ : سَمِعْتُ رَجُلاً مِنَ الأَنْصَارِ یُحَدِّثُ ابْنَ عُمَرَ یَقُولُ : سَمِعْتُ أَبَاک یَقُولُ : لَوْ وَضَعَتِ الْمُتَوَفَّی عَنْہَا زَوْجُہَا ذَا بَطْنِہَا وَہُوَ عَلَی السَّرِیرِ فَقَدْ حَلَّتْ۔",,,17379 17380,"حَدَّثَنَا وَکِیعٌ ، عَنْ عُبَیْدِ اللہِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ مَوْہَبٍ ، عَنْ صَالِحِ بْنِ کَیْسَانَ ، عَنْ عُمَرَ وَعُثْمَانَ قَالاَ : إذَا وَضَعَتْ وَہُوَ فِی جَانِبِ الْبَیْتِ فِی أَکْفَانِہِ فَقَدْ حَلَّتْ۔",,,17380 17381,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ أَنَّ عُمَرَ اسْتَشَارَ عَلِیَّ بْنَ أَبِی طَالِبٍ رضی اللہ عنہ وَزَیْدَ بْنَ ثَابِتٍ قَالَ زَیْدٌ : قدْ حَلَّتْ وَقَالَ عَلِیٌّ : أَرْبَعَۃَ أَشْہُرٍ وَعَشْرًا قَالَ زَیْدٌ: أَرَأَیْتَ إِنْ کَانَتْ یَئیسًا قَالَ عَلِیٌّ : فَآخِرُ الأَجَلَیْنِ قَالَ عُمَرُ : لَوْ وَضَعَتْ ذَا بَطْنِہَا وَزَوْجُہَا عَلَی نَعْشِہِ لَمْ یَدْخُلْ حُفْرَتَہُ لَکَانَتْ قَدْ حَلَّتْ۔",,,17381 17382,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِِ، عَنْ مُسْلِمٍ، عَنْ مَسْرُوقٍ، قَالَ: قَالَ عَبْدُ اللہِ: وَاللَّہِ مَنْ شَائَ لَقَاسَمْتُہُ لَنَزَلَتْ سُورَۃُ النِّسَائِ الْقُصْرَی بَعْدَ أَرْبَعَۃِ أَشْہُرٍ وَعَشْرًا۔ (ابوداؤد 2301۔ ابن ماجہ 2030)",,,17382 17383,"حَدَّثَنَا عبد الوہاب الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ أَنَّہُ قَالَ فِی الْمُتَوَفَّی عَنْہَا زَوْجُہَا وَہِیَ حَامِلٌ : إذَا وَضَعَتْ حَلَّتْ۔",,,17383 17384,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ أَنَّہُ کَانَ یَقُولُ : إذَا طَلَّقَ الرَّجُلُ امْرَأَتَہُ وَہِیَ حَامِلٌ ، أَوْ تُوُفِّیَ عَنْہَا فَإِنَّ أَجَلَہَا أَنْ تَضَعَ حَمْلَہَا۔",,,17384 17385,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ ، قَالَ : قَالَ عَبْدُ اللہِ : أَجَلُ کُلِّ حَامِلٍ أَنْ تَضَعَ حَمْلَہَا قَالَ : وَکَانَ عَلِیٌّ یَقُولُ : آخِرُ الأَجَلَیْنِ۔",,,17385 17386,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِِ ، عَنْ مُسْلِمٍ وَلَمْ یُذْکَرْ فِیہِ مَسْرُوقٌ ، عَنْ عَلِیٍّ أَنَّہُ کَانَ یَقُولُ : آخِرُ الأَجَلَیْنِ۔",,,17386 17387,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ مُطَرِّفٍ ، عَنْ عَمْرِو بْنِ سَالِمٍ قَالَ : قَالَ أُبَیُّ بْنُ کَعْبٍ : یَا رَسُولَ اللہِ ، إنَّ عِدَدًا مِنْ عِدَدِ النِّسَائِ لَمْ یُذْکَرْ فِی کِتَابِ اللہِ ، الصِّغَارُ وَالْکِبَارُ وَأُولاَتُ الأَحْمَالِ فَأَنْزَلَ اللَّہُ تَعَالَی : {وَاللاَّئِی یَئِسْنَ مِنَ الْمَحِیضِ مِنْ نِسَائِکُمْ إنِ ارْتَبْتُمْ فَعِدَّتُہُنَّ ثَلاَثَۃُ أَشْہُرٍ وَاللاَّئِی لَمْ یَحِضْنَ وَأُولاَتُ الأَحْمَالِ أَجَلُہُنَّ أَنْ یَضَعْنَ حَمْلَہُنَّ}۔ (حاکم 492۔ ابن جریر 141)",,,17387 17388,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ قَالَ : کُنْتُ فِی حَلْقَۃٍ فِیہَا عَبْدُ الرَّحْمَنِ بْنُ أَبِی لَیْلَی قَالَ : فَقَالَ : آخِرُ الأَجَلَیْنِ قَالَ : فَذَکَرْتُ حَدِیثَ عَبْدِ اللہِ بْنِ عُتْبَۃَ ، عَنْ سُبَیْعَۃَ قَالَ فَضمَزَ لِی أَصْحَابُہُ قَالَ: فَقُلْتُ : إنِّی لَجَرِیئٌ عَلَی عَبْدِ اللہِ بْنِ عُتْبَۃَ إِنْ کَذَبْتُ عَلَیْہِ وَہُوَ فِی نَاحِیَۃِ المَسْجِد۔\n\n(بخاری 4532۔ نسائی 5715)",,,17388 17389,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، عَنِ ابْنِ عَبَّاسٍ فِی الْحَامِلِ الْمُتَوَفَّی عَنْہَا زَوْجُہَا : عِدَّتُہَا آخِرُ الأَجَلَیْنِ۔",,,17389 17390,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ، عَنِ الزُّہْرِیِّ، عَنْ عُبَیْدِ اللہِ، عَنْ أَبِیہِ قَالَ: وَضَعَتْ سُبَیْعَۃُ بَعْدَ وَفَاۃِ زَوْجِہَا بِعِشْرِینَ، أَوْ بِشَہْرٍ ، أَوْ نَحْوِ ذَلِکَ فَمَرَّ بِہَا أَبُو السَّنَابِلِ بْنُ بَعْکَکٍ ، فَقَالَ : قَدْ تَصَنَّعْتِ لِلأَزْوَاجِ ؟ لاَ ، حَتَّی یَأْتِیَ عَلَیْک أَرْبَعَۃَ أَشْہُرٍ وَعَشْرًا فَأَتَتِ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَذَکَرَتْ ذَلِکَ لَہُ، فَقَالَ: قَدْ حَلَلْتِ لِلأَزْوَاجِ۔\n\n(بخاری 5319۔ بیہقی 419)",,,17390 17391,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ، عَنْ مَسْرُوقٍ وَعَمْرِو بْنِ عُتْبَۃَ أَنَّہُمَا کَتَبَا إلَی سُبَیْعَۃَ بِنْتِ الْحَارِثِ یَسْأَلاَنِہَا عَنْ أَمْرِہَا فَکَتَبَتْ إلَیْہِمَا أَنَّہَا وَضَعَتْ بَعْدَ وَفَاۃِ زَوْجِہَا بِخَمْسَۃٍ وَعِشْرِینَ لَیْلَۃً فَتَہَیَّأَتْ تَطْلُبُ الْخَیْرَ فَمَرَّ بِہَا أَبُو السَّنَابِلِ بْنُ بَعْکَکٍ ، فَقَالَ : قدْ أَسْرَعْتِ ، اعْتَدِّی آخِرَ الأَجَلَیْنِ أَرْبَعَۃَ أَشْہُرٍ وَعَشْرًا فَأَتَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقُلْتُ : یَا رَسُولَ اللہِ ، اسْتَغْفِرْ لِی ، فَقَالَ : وَمَا ذَاکِ ؟ فَأَخْبَرَتْہُ الْخَبَرَ ، فَقَالَ : إِنْ وَجَدْتِ زَوْجًا صَالِحًا فَتَزَوَّجِی۔ (بخاری 5319۔ مسلم 1122)",,,17391 17392,"حَدَّثَنَا شَبَابَۃُ ، عَنْ شُعْبَۃَ ، عَنْ عُبَیْدِ بْنِ الْحَسَنِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ مَعْقِلٍ قَالَ : شَہِدْتُ عَلِیًّا وَسَأَلَہُ رَجُلٌ عَنِ امْرَأَۃٍ تُوُفِّیَ عَنْہَا زَوْجُہَا وَہِیَ حَامِلٌ قَالَ : تَتَرَبَّصُ أَبْعَدَ الأَجَلَیْنِ ، فَقَالَ رَجُل إِنَّ ابْنَ مَسْعُودٍ: یَقُولُ تَسْفِی نَفْسَہَا ؟ فَقَالَ عَلِیٌّ : إنَّ فَرُّوخَ لاَ یَعْلَمُ۔",,,17392 17393,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ فِرَاسٍ ، عَنِ الشَّعْبِیِّ ، عَنْ مَسْرُوقٍ ، عَنْ عَبْدِ اللہِ أَنَّہُ سُئِلَ عَنْ رَجُلٍ تَزَوَّجَ امْرَأَۃً فَمَاتَ عَنْہَا وَلَمْ یَدْخُلْ بِہَا وَلَمْ یَفْرِضْ لَہَا صَدَاقًا ، فَقَالَ عَبْدُ اللہِ : لَہَا الصَّدَاقُ وَلَہَا الْمِیرَاثُ وَعَلَیْہَا الْعِدَّۃُ ، فَقَالَ مَعْقِلُ بْنُ یَسَارٍ : شَہِدْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَضَی فِی بِرْوَعَ بِنْتِ وَاشِقٍ مِثْلَ ذَلِکَ۔ (ابن ماجہ 1891۔ احمد 4/280)",,,17393 17394,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، عَنْ عَلْقَمَۃَ ، عَنْ عَبْدِ اللہِ : مِثْلَہُ۔\n\n(ابوداؤد 2108۔ ابن ماجہ 1891)",,,17394 17395,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : أَخْبَرَنَا سُفْیَانُ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، عَنْ عَلْقَمَۃَ ، عَنْ عَبْدِ اللہِ بِنَحْوٍ مِنْ حَدِیثِ ابْنِ مَہْدِیٍّ ، عَنْ فِرَاسٍ۔ (ترمذی 1145۔ ابوداؤد 2108)",,,17395 17396,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ أن ابْنَ عُمَرَ زَوَّجَ ابْنًا لَہُ امْرَأَۃً مِنْ أَہْلِہِ ، فَتُوُفِّیَ قَبْلَ أَنْ یَدْخُلَ بِہَا ، وَلَمْ یُسَمِّ لَہَا صَدَاقًا ، فَطَلَبُوا إلَی ابْنِ عُمَرَ الصَّدَاقَ ، فَقَالَ : لَیْسَ لَہَا صَدَاقٌ ، فَأَبَوْا أَنْ یَرْضَوْا بِذَلِکَ، فَجَعَلُوا بَیْنَہُمْ زَیْدَ بْنَ ثَابِتٍ ، فَأَتَوْہُ فَقَالَ : لَیْسَ لَہَا صَدَاقٌ۔",,,17396 17397,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ قَالَ قَالَ زَیْدُ بْنُ ثَابِتٍ تَرِثُ وَتَعْتَدُّ۔,,,17397 17398,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ أَبِی الشَّعْثَائِ ، وَعَطَائٍ فِی الَّذِی یُفَوَّضُ إلَیْہِ فَیَمُوتُ قَبْلَ أَنْ یَفْرِضَ قَالاَ : لَہَا الْمِیرَاثُ وَلَیْسَ لَہَا صَدَاقٌ۔",,,17398 17399,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرو وَعَطَائِ بْنِ السَّائِبِ ، عَنْ عَبْدِ خَیْرٍ یُرَی أَنَّہُ عَنْ عَلِیٍّ قَالَ : لَہَا الْمِیرَاثُ وَلاَ صَدَاقَ لَہَا۔",,,17399 17400,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ أَنَّ رَجُلاً بِالْمَدِینَۃِ تَزَوَّجَ امْرَأَۃً فَلَمْ یَفْرِضْ لَہَا وَلَمْ یَدْخُلْ بِہَا قَالُوا : لَہَا الْمِیرَاثُ وَلاَ مَہْرَ لَہَا وَقَالَ مَسْرُوقٌ : لاَ یَکُونُ مِیرَاثٌ حَتَّی یَکُونَ قَبْلَہُ مَہْرٌ۔",,,17400 17401,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لَہَا نِصْفُ الصَّدَاقِ ، أَوِ الصَّدَاقُ ، شَکَّ أَبُو بَکْرٍ۔",,,17401 17402,"حَدَّثَنَا ابْنُ أَبِی زَائِدَۃَ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ، عَنْ عَلْقَمَۃَ قَالَ : جَائَ رَجُلٌ إلَی ابْنِ مَسْعُودٍ ، فَقَالَ : إنَّ رَجُلاً مِنَّا تَزَوَّجَ امْرَأَۃً وَلَمْ یَفْرِضْ لَہَا وَلَمْ یُجَامِعْہَا حَتَّی مَاتَ ، فَقَالَ ابْنُ مَسْعُودٍ : مَا سُئِلْت عَنْ شَیْئٍ مُنْذُ فَارَقْت النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَشَدَّ عَلَیَّ مِنْ ہَذَا، سَلُوا غَیْرِی فَتَرَدَّدُوا فِیہَا شَہْرًا قَالَ: فَقَالَ: مَنْ أَسْأَلُ وَأَنْتُمْ أَخِیَّۃُ أَصْحَابِ مُحَمَّدٍ بِہَذَا الْبَلَدِ؟ فَقَالَ: سَأَقُولُ فِیہَا بِرَأْیِی فَإِنْ یَکُنْ صَوَابًا فَمِنَ اللہِ ، وَإِنْ یَکُنْ خَطَأً فَمِنِّی وَمِنَ الشَّیْطَانِ ، أَرَی أَنَّ لَہَا مَہْرَ نِسَائِہَا لاَ وَکْسَ وَلاَ شَطَطَ وَلَہَا الْمِیرَاثُ وَعَلَیْہَا عِدَّۃُ الْمُتَوَفَّی عَنْہَا زَوْجُہَا ، فَقَالَ: نَاسٌ مِنْ أَشْجَعَ : نَشْہَدُ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَضَی مِثْلَ الَّذِی قَضَیْت فِی امْرَأَۃٍ مِنَّا یُقَالُ لَہَا بِرْوَعُ ابْنَۃُ وَاشِقٍ قَالَ : فَمَا رَأَیْتُ ابْنَ مَسْعُودٍ فَرِحَ بِشَیْئٍ مَا فَرِحَ یَوْمَئِذٍ بِہِ۔(ابن حبان 4101۔ حاکم 180)",,,17402 17403,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ قَالَ : تَزَوَّجَ ابْنٌ لِعَبْدِ اللہِ بْنِ عُمَرَ بِنْتًا لِعُبَیْدِ اللہِ بْنِ عُمَرَ کَانَتْ أُمُّہَا أَسْمَائَ بِنْتَ زَیْدِ بْنِ الْخَطَّابِ فَتُوُفِّیَ وَلَمْ یَکُنْ فَرَضَ لَہَا صَدَاقًا فَطَلَبُوا مِنْہُ الصَّدَاقَ وَالْمِیرَاثَ ، فَقَالَ ابْنُ عُمَرَ : لَہَا الْمِیرَاثُ وَلاَ صَدَاقَ لَہَا فَأَبَوْا ذَلِکَ عَلَی ابْنِ عُمَرَ فَجَعَلُوا بَیْنَہُمْ زَیْدَ بْنَ ثَابِتٍ ، فَقَالَ زَیْدٌ : لَہَا الْمِیرَاثُ وَلاَ صَدَاقَ لَہَا۔",,,17403 17404,"حَدَّثَنَا عَبْدَۃُ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ عَبْدِ خَیْرٍ ، عَنْ عَلِیٍّ قَالَ : لَہَا الْمِیرَاثُ وَلاَ صَدَاقَ لَہَا۔",,,17404 17405,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی الَّتِی یُتَوَفَّی عَنْہَا زَوْجُہَا قَبْلَ أَنْ یَفْرِضَ لَہَا وَقَبْلَ أَنْ یَدْخُلَ بِہَا : أَنَّ لَہَا صَدَاقَ نِسَائِہَا وَیُحَدِّثُ بِذَلِکَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَعِدَّۃَ الْمُتَوَفَّی وَلَہَا الْمِیرَاثُ۔ (سعید بن منصور 933۔ عبدالرزاق 10900)",,,17405 17406,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الشَّیْبَانِیِّ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَمَّنْ أَخْبَرَہُ ، عَنْ عَلِیٍّ قَالَ : لَہَا الْمِیرَاثُ وَلاَ صَدَاقَ لَہَا۔",,,17406 17407,"حدثنا أبو عبد الرحمن بقی بن مخلد ، قَالَ : حدثنا أبو بکر عبد اللہ بن محمد بن أبی شیبۃ ، قال:\n حَدَّثَنَا جَعْفَرُ بْنُ عَوْنٍ قَالَ : أَخْبَرَنَا رَبِیعَۃُ بن عُثْمَانَ ، عَنْ مُحَمَّدِ بْنِ یَحْیَی بْنِ حَبَّانَ ، عَنْ نَہَارٍ الْعَبْدِیِّ، وَکَانَ مِنْ أَصْحَابِ أَبِی سَعِیدٍ الْخُدْرِیِّ ، عَنْ أَبِی سَعِیدٍ أَنَّ رَجُلاً أَتَی بِابْنَۃٍ لَہُ إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : إنَّ ابْنَتِی ہَذِہِ أَبَتْ أَنْ تَتَزَوَّجَ قَالَ ، فَقَالَ لَہَا : أَطِیعِی أَبَاک قَالَ ، قَالَتْ : لاَ حَتَّی تُخْبِرَنِی مَا حَقُّ الزَّوْجِ عَلَی زَوْجَتِہِ ؟ فَرَدَّدَتْ عَلَیْہِ مَقَالَتَہَا قَالَ ، فَقَالَ : حَقُّ الزَّوْجِ عَلَی زَوْجَتِہِ أَنْ لَوْ کَانَ بِہِ قُرْحَۃٌ فَلَحَسَتْہَا ، أَوِ ابْتَدَرَ مَنْخِرَاہُ صَدِیدًا ، أَوْ دَمًا ثُمَّ لَحَسَتْہُ مَا أَدَّتْ حَقَّہُ قَالَ ، فَقَالَتْ : وَالَّذِی بَعَثَک بِالْحَقِّ لاَ أَتَزَوَّجُ أَبَدًا قَالَ ، فَقَالَ : لاَ تُنْکِحُوہُنَّ إلاَّ بِإِذْنِہِنَّ۔ (ابن حبان 4164۔ حاکم 188)",,,17407 17408,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَبِی نَصْرٍ عَبْدِ اللہِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ مُسَاوِرٍ الْحِمْیَرِیِّ ، عَنْ أُمہِ قَالَت : سَمِعْتُ أُمَّ سَلَمَۃَ تَقُولُ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : أَیُّمَا امْرَأَۃٍ مَاتَتْ وَزَوْجُہَا عَنْہَا رَاضٍ دَخَلَتِ الْجَنَّۃَ۔ (ترمذی 1161۔ طبرانی 884)",,,17408 17409,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ سُلَیْمَانَ ، عَنْ لَیْثٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عُمَرَ قَالَ : أَتَتِ امْرَأَۃٌ نَبِیَّ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَتْ : یَا رَسُولَ اللہِ ، مَا حَقُّ الزَّوْجِ عَلَی زوجتہ ؟ قَالَ : لاَ تَمْنَعُہُ نَفْسَہَا وَلَوْ کَانَتْ عَلَی ظَہْرِ قَتَبٍ قَالَتْ : یَا رَسُولَ اللہِ ، مَا حَقُّ الزَّوْجِ عَلَی زَوْجَتِہِ ؟ قَالَ : لاَ تَصَدَّقُ بِشَیْئٍ مِنْ بَیْتِہِ إلاَّ بِإِذْنِہِ فَإِنْ فَعَلَتْ کَانَ لَہُ الأَجْرُ وَعَلَیْہَا الْوِزْرُ ، قَالَتْ : یَا نَبِی اللہ مَا حَقُّ الزَّوْجِ عَلَی امرأتہ قَالَ : لاَ تَخْرُجَ مِنْ بَیْتِہِ إِلا بِإِذْنِہِ فَإِنْ فَعَلَتْ لَعَنَتْہَا مَلاَئِکَۃُ اللہِ وَمَلاَئِکَۃُ الرَّحْمَۃِ وَمَلاَئِکَۃُ الْغَضَبِ حَتَّی تَتُوبَ ، أَوْ تراجع قَالَتْ : یَا نَبِیَّ اللہِ : فَإِنْ کَانَ لَہَا ظَالِمًا ؟ قَالَ : وَإِنْ کَانَ لَہَا ظَالِمًا ، قَالَتْ : وَالَّذِی بَعَثَک بِالْحَقِّ لاَ یَمْلِکُ عَلَیَّ أَمْرِی أَحَدٌ بَعْدَ ہَذَا أَبَدًا مَا بَقِیتُ۔",,,17409 17410,"حدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ بُشَیرِ بْنِ یَسَارٍ ، عَنْ حُصَیْنِ بْنِ مِحْصَنٍ أَنَّ عَمَّۃً لَہُ أَتَتِ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ تَطْلُبُ حَاجَۃً فَلَمَّا قَضَتْ حَاجَتَہَا قَالَ : أَلَکِ زَوْجٌ ؟ قَالَتْ : نَعَمْ ، قَالَ : فَأَیْنَ أَنْتِ مِنْہُ ؟ قَالَتْ : مَا آلُوہُ خَیْرًا إلاَّ مَا عَجَزْتُ عَنْہُ قَالَ : انْظُرِی ، فَإِنَّہُ جَنَّتُکِ وَنَارُکِ۔\n\n(احمد 4/341۔ حاکم 189)",,,17410 17411,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِِ ، عَنْ أَبِی ظَبْیَانَ قَالَ : لَمَّا قَدِمَ مُعَاذٌ مِنَ الْیَمَنِ قَالَ : یَا رَسُولَ اللہِ ، رَأَیْنَا قَوْمًا یَسْجُدُ بَعْضُہُمْ لِبَعْضٍ أَفَلاَ نَسْجُدُ لَکَ ؟ فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ ، إنَّہُ لاَ یَسْجُدُ أَحَدٌ لأَحَدٍ دون اللہ وَلَوْ کُنْتُ آمِرًا أَحَدًا یَسْجُدُ لأَحَدٍ لأَمَرْتُ النِّسَائَ یَسْجُدْنَ لأَزْوَاجِہِنَّ۔",,,17411 17412,"حَدَّثَنَا عبد اللہ بْنُ نُمَیْرٍ قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ أَبِی ظَبْیَانَ ، عَنْ رَجُلٍ مِنَ الأَنْصَارِ ، عَنْ مُعَاذِ بْنِ جَبَلٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِمِثْلِ حَدِیثِ أَبِی مُعَاوِیَۃَ۔ (ابن ماجہ 1853۔ حارث 498)",,,17412 17413,"حَدَّثَنَا عبد اللہ بْنُ إدْرِیسَ ، عَنِ الأَعْمَشِِ ، عَنِ الْمِنْہَالِ ، عَنْ عَبْدِ اللہِ بْنِ الْحَارِثِ قَالَ : ثَلاَثَۃٌ لاَ تُجَاوِزُ صَلاَۃُ أَحَدِہِمْ رَأْسَہُ ، إمَامٌ أَمَّ قَوْمًا وَہُمْ لَہُ کَارِہُونَ ، وَامْرَأَۃٌ تَعْصِی زَوْجَہَا ، وَعَبْدٌ آبِقٌ مِنْ سَیِّدِہِ۔",,,17413 17414,"حَدَّثَنَا وَکِیعٌ ، عَنْ قُرَّۃَ بْنِ خَالِدٍ ، عَنِ امْرَأَۃٍ مِنْ بَنِی عُطَارِدٍ یُقَالُ لَہَا رَبِیعَۃُ قَالَتْ : قالَتْ عَائِشَۃُ : یَا مَعاشِرَ النِّسَائِ ، لَوْ تَعْلَمْنَ حَقَّ أَزْوَاجِکُنَّ عَلَیْکُنَّ لَجَعَلَتِ الْمَرْأَۃُ مِنْکُنَّ تَمْسَحُ الْغُبَارَ ، عَنْ وَجْہِ زَوْجِہَا بِحُرِّ وَجْہِہَا۔",,,17414 17415,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ ہِلاَلِ بْنِ یَِسَافٍ ، عَنْ زِیَادِ بْنِ أَبِی الْجَعْدِ ، عَنْ عَمْرِو بْنِ الْحَارِثِ بْن الْمُصْطَلِقِ قَالَ : کَانَ یُقَالُ : أَشَدُّ النَّاسِ عَذَابًا اثْنَانِ : امْرَأَۃٌ تَعْصِی زَوْجَہَا وَإِمَامُ قوْمٍ وَہُمْ لَہُ کَارِہُونَ۔",,,17415 17416,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ، عَنْ حُمَیْدٍ، عَنْ أُمِّہِ قَالَتْ: کُنَّ نِسَائُ أَہْلِ الْمَدِینَۃِ إذَا أَرَدْنَ أَنْ یَبْنِینَ بِامْرَأَۃٍ عَلَی زَوْجِہَا بَدَأْنَ بِعَائِشَۃَ فَأَدْخَلْنَہَا عَلَیْہَا فَتَضَعُ یَدَہَا عَلَی رَأْسِہَا تَدْعُو لَہَا وَتَأْمُرُہَا بِتَقْوَی اللہِ وَحَقِّ الزَّوْجِ۔",,,17416 17417,"حَدَّثَنَا عُبَیْدُ اللہِ ، عَنْ إسْمَاعِیلَ بْنِ عَبْدِ الْمَلِکِ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : لاَ یَنْبَغِی لِشَیْئٍ أَنْ یَسْجُدَ لِشَیْئٍ وَلَوْ کَانَ ذَلِکَ لَکَانَ النِّسَائُ لأَزْوَاجِہِنَّ۔",,,17417 17418,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِِ ، عَنْ أَبِی حَازِمٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا دَعَا الرَّجُلُ امْرَأَتَہُ إلَی فِرَاشِہِ فَأَبَتْ فَبَاتَ غَضْبَانَ عَلَیْہَا لَعَنَتْہَا الْمَلاَئِکَۃُ حَتَّی تُصْبِحَ۔\n\n(بخاری 5193۔ مسلم 122)",,,17418 17419,"حَدَّثَنَا عَفَّانُ قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ قَالَ : أَخْبَرَنَا عَلِیُّ بْنُ زَیْدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ عَائِشَۃَ قَالَتْ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَوْ کُنْتُ آمِرًا أَحَدًا أَنْ یَسْجُدَ لأَحَدٍ لأَمَرْتُ الْمَرْأَۃَ أَنْ تَسْجُدَ لِزَوْجِہَا وَلَوْ أَنَّ رَجُلاً أَمَرَ امْرَأَتَہُ أَنْ تَنْتَقِلَ مِنْ جَبَلٍ أَحْمَرَ إلَی جَبَلٍ أَسْوَدَ ، أَوْ مِنْ جَبَلٍ أَسْوَدَ إلَی جَبَلٍ أَحْمَرَ کَانَ نَوْلَہَا أَنْ تَفْعَلَ۔",,,17419 17420,"حَدَّثَنَا مُلاَزِمُ بْنُ عَمْرو ، عَنْ عَبْدِ اللہِ بْنِ بَدْرٍ ، عَنْ قَیْسِ بْنِ طَلْقٍ ، عَنْ أَبِیہِ طَلْقِ بْنِ عَلِیٍّ قَالَ : جَلَسْنا عِنْدَ نَبِیِّ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَسَمِعْتُ نَبِیَّ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : إذَا دَعَا الرَّجُلُ زَوْجَتَہُ لِحَاجَتِہِ فَلْتَأْتِہِ ، وَإِنْ کَانَتْ عَلَی التَّنُّورِ۔ (ترمذی 1160۔ احمد 4/23)",,,17420 17421,"حَدَّثَنَا ابْنُ نُمَیْرٍ قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ إبْرَاہِیمَ قَالَ : کَانُوا یَقُولُونَ : لَوْ أَنَّ امْرَأَۃً مَصَّتْ أَنْفَ زَوْجِہَا مِنَ الْجُذَامِ حَتَّی تَمُوتَ مَا أَدَّتْ حَقَّہُ۔",,,17421 17422,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ بْنِ جَابِرٍ ، قَالَ : سَمِعْتُ الْقَاسِمَ بْنَ مُخَیْمِرَۃَ یَذْکُرُ أَنَّ سَلْمَانَ قَدَّمَہُ قَوْمٌ لِیُصَلِّیَ بِہِمْ فَأَبَی عَلَیْہِمْ حَتَّی دَفَعُوہُ ، فَلَمَّا صَلَّی بِہِمْ قَالَ : أَکُلُّکُمْ رَاضٍ ؟ قَالُوا : نَعَمْ ، قَالَ : الْحَمْدُ لِلَّہِ ، إنِّی سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : ثَلاَثَۃٌ لاَ تُقْبَلُ صَلاَتُہُمْ : الْمَرْأَۃُ تَخْرُجُ مِنْ بَیْتِ زَوْجِہَا بِغَیْرِ إذْنِہِ وَالْعَبْدُ الآبِقُ وَالرَّجُلُ یَؤُمُّ قَوْمًا وَہُمْ لَہُ کَارِہُونَ۔",,,17422 17423,"حَدَّثَنَا عَلِیُّ بْنُ حَسَنِ بْنِ شَقِیقٍ ، قَالَ : حَدَّثَنِی حُسَیْنُ بْنُ وَاقِدٍ قَالَ : حدَّثَنَا أَبُو غَالِبٍ ، عَنْ أَبِی أُمَامَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : ثَلاَثَۃٌ لاَ تُجَاوِزُ صَلاَتُہُمْ آذَانَہُمْ حَتَّی یَرْجِعُوا : الْعَبْدُ الآبِقُ وَامْرَأَۃٌ بَاتتْ وَزَوْجُہَا عَلَیْہَا سَاخِطٌ وَإِمَامُ قَوْمٍ وَہُمْ لَہُ کَارِہُونَ",,,17423 17424,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ ، عَنْ زَیْدِ بْنِ وَہْبٍ قَالَ : کَتَبَ إلَیْنَا عُمَرُ : إنَّ الْمَرْأَۃَ لاَ تَصُومُ تَطَوُّعًا إلاَّ بِإِذْنِہِ یَعْنِی زَوْجَہَا۔",,,17424 17425,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ ، عَنْ مِقْسَمٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ تَصُومُ تَطَوُّعًا وَہُوَ شَاہِدٌ إلاَّ بِإِذْنِہِ یَعْنِی زَوْجَہَا۔",,,17425 17426,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو عن یَحْیَی بْنِ جَعْدَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : خَیْرُ فَائِدَۃٍ اسْتَفَادَہَا الْمُسْلِمُ بَعْدَ الإِسْلاَمِ امْرَأَۃٌ جَمِیلَۃٌ ، تَسُرُّہُ إذَا نَظَرَ إلَیْہَا وَتُطِیعُہُ إذَا أَمَرَہَا وَتَحْفَظُہُ إذَا غَابَ عَنْہَا فِی مَالِہِ وَنَفْسِہَا۔ (ابوداؤد 1661۔ سعید بن منصور 501)",,,17426 17427,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنْ مُعَاوِیَۃَ بْنِ قُرَّۃَ ، عَنْ أَبِیہِ ، قَالَ : قَالَ عُمَرُ : مَا اسْتَفَادَ رَجُلٌ ، أَوْ قَالَ عَبْدٌ بَعْدَ إیمَانٍ بِاللَّہِ خَیْرًا مِنِ امْرَأَۃٍ حَسَنَۃِ الْخُلُقِ وَدُودٍ وَلُودٍ ، وَمَا اسْتَفَادَ رَجُلٌ بَعْدَ الْکُفْرِ بِاللَّہِ شَرًّا مِنِ امْرَأَۃٍ سَیِّئَۃِ الْخُلُقِ حَدِیدَۃِ اللِّسَانِ ثُمَّ قَالَ : إنَّ مِنْہُنَّ غُنْمًا لاَ یُحْذَی مِنْہُ وَإِنَّ مِنْہُنَّ غُلاً یُفْدَی مِنْہُ۔",,,17427 17428,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبْزَی قَالَ : مَثَلُ الْمَرْأَۃِ الصَّالِحَۃِ عِنْدَ الرَّجُلِ کَمَثَلِ التَّاجِ الْمَخُوصِ بِالذَّہَبِ عَلَی رَأْسِ الْمَلِکِ وَمَثَلُ الْمَرْأَۃِ السَّوْئِ عِنْدَ الرَّجُلِ الصَّالِحِ مَثَلُ الْحِمْلِ الثَّقِیلِ عَلَی الشَّیْخِ الْکَبِیرِ۔",,,17428 17429,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ شُعْبَۃَ ، عَنْ فِرَاسٍ ، عَنِ الشَّعْبِیِّ ، عَنْ أَبِی بُرْدَۃَ ، عَنْ أَبِی مُوسَی قَالَ : ثَلاَثَۃٌ یَدْعُونَ فَلاَ یُسْتَجَابُ لَہُمْ : رَجُلٌ آتی سَفِیہًا مَالَہُ وَقَالَ اللَّہُ تَبَارَکَ وَتَعَالَی : {وَلاَ تُؤْتُوا السُّفَہَائَ أَمْوَالَکُم} وَرَجُلٌ کَانَتْ عِنْدَہُ امْرَأَۃٌ سَیِّئَۃُ الْخُلُقِ فَلَمْ یُطَلِّقْہَا ، أَوْ لَمْ یُفَارِقْہَا وَرَجُلٌ کَانَ لَہُ عَلَی رَجُلٍ حَقٌّ فَلَمْ یُشْہِدْ عَلَیْہِ۔",,,17429 17430,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَبِی نَصْرٍ عَبْدِ اللہِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ ہِلاَلِ بْنِ یَِسَافٍ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو قَالَ : أَلاَ أُخْبِرُکُمْ بِالثَّلاَثِ الْفَوَاقِرِ ، قَالَ : وَمَا ہُنَّ ؟ قَالَ : إمَامٌ جَائِرٌ ، إِنْ أَحْسَنْتَ لَمْ یَشْکُرْ ، وَإِنْ أَسَأْتَ لَمْ یَغْفِرْ وَجَارُ سَوْئٍ إِنْ رَأَی حَسَنَۃً غَطَّاہَا ، وَإِنْ رَأَی سَیِّئَۃً أَفْشَاہَا وَامْرَأَۃُ السَّوْئِ إِنْ شَہِدْتَہَا غَاظَتکَ ، وَإِنْ غِبْتَ عَنْہَا خَانَتْکَ۔",,,17430 17431,حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ جَعْدَۃَ بْنِ ہُبَیْرَۃَ أنہ کَانَ إذَا زَوَّجَ شَیْئًا مِنْ بَنَاتِہِ خَلاَ بِہَا فَنَہَاہَا ، عَنْ سَیِّئِ الأَخْلاَقِ وَأَمَرَہَا بِأَحْسَنِہَا۔,,,17431 17432,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : أَخْبَرَنَا شَیْبَانُ قَالَ أَخْبَرَنَا عَبْدُ الْمَلِکِ بْنُ عُمَیْرٍ ، عَنْ زَیْدِ بْنِ عُقْبَۃَ ، عَنْ سَمُرَۃَ بْنِ جُنْدُبٍ ، قَالَ : سَمِعْتُ عُمَرَ بْنَ الْخَطَّابِ یَقُولُ : النِّسَائُ ثَلاَثَۃٌ : امْرَأَۃٌ ہَیِّنَۃٌ لَیِّنَۃٌ عَفِیفَۃٌ مُسْلِمَۃٌ وَدُودٌ وَلُودٌ تُعِینُ أَہْلَہَا عَلَی الدَّہْرِ ، وَلاَ تُعِینُ الدَّہْرَ عَلَی أَہْلِہَا ، وَقَلَّ مَا تَجِدُہَا ، ثَانِیَۃٌ : امْرَأَۃٌ عَفِیفَۃٌ مُسْلِمَۃٌ إنَّمَا ہِیَ وِعَائٌ لِلْوَلَدِ لَیْسَ عِنْدَہَا غَیْرُ ذَلِکَ ، ثَالِثَۃٌ : غُلٌّ قَمِلٌ یَجْعَلُہَا اللَّہُ فِی عُنُقِ مَنْ یَشَائُ وَلاَ یَنْزِعُہَا غَیْرُہُ ، الرِّجَالُ ثَلاَثَۃٌ : رَجُلٌ عَفِیفٌ مُسْلِمٌ عَاقِلٌ یَأْتَمِرُ فِی الأُمُورِ إذَا أَقْبَلَتْ وَتَشَبَّہت ، فَإِذَا وَقَعَتْ خَرَجَ مِنْہَا بِرَأْیِہِ وَرَجُلٌ عَفِیفٌ مُسْلِمٌ لَیْسَ لَہُ رَأْیٌ فَإِذَا وَقَعَ الأَمْرُ أَتَی ذَا الرَّأْیِ وَالْمَشْورَۃِ فَشَاوَرَہُ وَاسْتَأْمَرَہُ ثُمَّ نَزَلَ عِنْدَ أَمْرِہِ، وَرَجُلٌ حَائِرٌ بَائِرٌ لاَ یَأْتَمِرُ رُشْدًا وَلاَ یُطِیعُ مُرْشِدًا۔",,,17432 17433,"حدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ عَبْدِ الْمَلِکِ بْنِ أَبِی سُلَیْمَانَ ، عَنْ عَطَائٍ ، عَنْ جَابِرِ بن عَبْدِ اللہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : إنَّ الْمَرْأَۃَ تُنْکَحُ عَلَی دِینِہَا وَمَالِہَا وَجَمَالِہَا فَعَلَیْکَ بِذَاتِ الدِّینِ تَرِبَتْ یَدَاک۔ (مسلم 1087۔ ترمذی 1086)",,,17433 17434,"حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ ، قَالَ : حَدَّثَنِی مُحَمَّدُ بْنُ مُوسَی الْمَدَنِیُّ قَالَ : أَخْبَرَنِی سَعْدُ بْنُ إِسْحَاقَ ، عَنْ عَمَّتِہِ، عَنْ أَبِی سَعِیدٍ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: تُنْکَحُ الْمَرْأَۃُ عَلَی إحْدَی خِصَالٍ ثَلاَثٍ: تُنْکَحُ الْمَرْأَۃُ عَلَی مَالِہَا ، عَلَی جَمَالِہَا ، تُنْکَحُ عَلَی دِینِہَا ، عَلَیْک بِذَاتِ الدِّینِ وَالْخُلُقِ تَرِبَتْ یَمِینُکَ۔\n\n(حاکم 161۔ احمد 3/80)",,,17434 17435,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ یَحْیَی بْنِ جَعْدَۃَ رَفَعَہُ قَالَ : تُنْکَحُ الْمَرْأَۃُ عَلَی دِینِہَا وَخُلُقِہَا وَمَالِہَا وَجَمَالِہَا ، أَیْنَ بِکَ ، عَنْ ذَاتِ الْخُلُقِ وَالدِّینِ ، تَرِبَتْ یَمِینُکَ۔ (سعید بن منصور 502)",,,17435 17436,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ مُجَاہِدٍ ، عَنْ یَحْیَی بْنِ جَعْدَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: تُنْکَحُ الْمَرْأَۃُ عَلَی مَالِہَا وَعَلَی حَسَبِہَا وَعَلَی جَمَالِہَا وَعَلَی دِینِہَا فَعَلَیْکَ بِذَاتِ الدِّینِ، تَرِبَتْ یَمِینُکَ۔",,,17436 17437,"حدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ سَالِمٍ ، عَنْ کُرَیْبٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَوْ أَنَّ أَحَدَکُمْ إذَا أَرَادَ أَنْ یَأْتِیَ أَہْلَہُ قَالَ : بِسْمِ اللہِ اللَّہُمَّ جَنِّبْنَا الشَّیْطَانَ وَجَنِّبِ الشَّیْطَانَ مَا رَزَقْتنَا ، فَإِنَّہُ إِنْ یُقْدَرْ بَیْنَہُمَا وَلَدٌ فِی ذَلِکَ لَمْ یَضُرَّہُ شَیْطَانٌ أَبَدًا۔ (بخاری 3271۔ مسلم 116)",,,17437 17438,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ دَاوُدَ ، عَنْ أَبِی نَضْرَۃَ ، عَنْ أَبِی سَعِیدٍ مَوْلَی أَبِی أُسَیْدٍ قَالَ : تَزَوَّجْتُ وَأَنَا مَمْلُوکٌ فَدَعَوْتُ نَفَرًا مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِیہِمُ ابْنُ مَسْعُودٍ ، وَأَبُو ذَرٍّ وَحُذَیْفَۃُ قَالَ : وَأُقِیمَتِ الصَّلاَۃُ قَالَ : فَذَہَبَ أَبُو ذَرٍّ لِیَتَقَدَّمَ فَقَالُوا : إلَیْکَ ، قَالَ : أَوَ کَذَلِکَ ؟ قَالُوا : نَعَمْ ، قَالَ : فَتَقَدَّمْتُ إلَیْہِمْ وَأَنَا عَبْدٌ مَمْلُوکٌ وَعَلَّمُونِی فَقَالُوا : إذَا أُدْخِلَ عَلَیْکَ أَہْلُکَ فَصَلِّ عَلَیْکَ رَکْعَتَیْنِ ثُمَّ سَلِ اللَّہَ تَعَالَی مِنْ خَیْرِ مَا دَخَلَ عَلَیْکَ وَتَعَوَّذْ بِہِ مِنْ شَرِّہِ ثُمَّ شَأْنَکَ وَشَأْنَ أَہْلِکَ۔",,,17438 17439,"حَدَّثَنَا الْحَسَنُ بْنُ مُوسَی، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عَطَائِ بْنِ السَّائِبِ، عَنِ ابْنِ أَخِی عَلْقَمَۃَ بن قَیس، عَنْ عَلْقَمَۃَ أَنَّ ابْنَ مَسْعُودٍ کَانَ إذا غَشِیَ أَہْلَہُ فَأَنْزَلَ قَالَ: اللَّہُمَّ لاَ تَجْعَلْ لِلشَّیْطَانِ فِیمَا رَزَقْتنَا نَصِیبًا۔",,,17439 17440,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ أُمِّ سَلَمَۃَ قَالَتْ : کَانَتْ لاَ تُزَفُّ بِالْمَدِینَۃِ جَارِیَۃٌ إلَی زَوْجِہَا حَتَّی یُمَرَّ بِہَا فِی الْمَسْجِدِ فَتُصَلِّیَ فِیہِ قَالَ أَبُو بَکْرٍ : قَالَ : أُرَاہُ قَالَ : رَکْعَتَیْنِ وَحَتَّی یُمَرَّ بِہَا عَلَی أَزْوَاجِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَیَدْعُونَ لَہَا۔",,,17440 17441,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ شَقِیقٍ قَالَ : جَائَ رَجُلٌ إلَی عَبْدِ اللہِ یُقَالُ لَہُ أَبُو جَرِیرٍ ، فَقَالَ : إنِّی تَزَوَّجْتُ جَارِیَۃً شَابَّۃً وَإِنِّی أَخَافُ أَنْ تَفْرَکَنِی قَالَ ، فَقَالَ عَبْدُ اللہِ : إنَّ الإِلْفَ مِنَ اللہِ وَالْفَرْکَ مِنَ الشَّیْطَانِ، یُرِیدُ أَنْ یُکَرِّہَ إلَیْکُمْ مَا أَحَلَّ اللَّہُ لَکُمْ ، فَإِذَا أَتَتْک فَمُرْہَا فَلْتُصَلِّ خلفک رَکْعَتَیْنِ۔",,,17441 17442,"حدَّثَنَا یَحْیَی بْنُ آدَمَ قَالَ : حدَّثَنَا شَرِیکٌ ، عَنْ خُصَیْفٍ ، عَنْ مُجَاہِدٍ فِی قَوْلِہِ : {وَلاَ تُمْسِکُوا بِعِصَمِ الْکَوَافِرِ} قَالَ : إذَا لَحِقَتِ امْرَأَۃُ الْمُسْلِمِ بِالْمُشْرِکِینَ لَمْ یُعْتَدَّ بِہَا مِنْ نِسَائِہِ۔",,,17442 17443,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ قَالَ : حدَّثَنَا شَرِیکٌ ، عَنْ سَالِمٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ مِثْلَہُ۔",,,17443 17444,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ حُمَیْدٍ ، عَنْ أَنَسٍ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ لِعَبْدِ الرَّحْمَنِ بن عوف : أَوْلِمْ وَلَوْ بِشَاۃٍ یَعْنِی ، حِینَ تَزَوَّجَ۔ (بخاری 2049۔ ابوداؤد 2102)",,,17444 17445,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ زُہَیْرٍ ، عَنْ بَیَانٍ ، قَالَ : سَمِعْتُ أَنَسًا یَقُولُ : بَنَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِامْرَأَۃٍ فَأَرْسَلَنِی فَدَعَوْتُ رِجَالاً إلَی الطَّعَامِ۔ (بخاری 5170۔ ترمذی 3219)",,,17445 17446,"حَدَّثَنَا جَرِیرٌ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الْحَکَمِ قَالَ : لَمَّا تَزَوَّجَ بِلاَلٌ أَتَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِذَہَبٍ، قَالَ لِبِلاَلٍ : سُقْ ہَذَا ، ثُمَّ قَالَ : أَعِینُوا أَخَاکُمْ فِی وَلِیمَتِہِ۔ (ابوداؤد 226۔ سعید بن منصور 588)",,,17446 17447,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورِ بن صَفِیَّۃَ ، عَنْ أُمِّہِ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَوْلَمَ عَلَی بَعْضِ نِسَائِہِ بِمُدَّیْنِ مِنْ شَعِیرٍ۔ (نسائی 6607۔ احمد 6/113),,,17447 17448,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنْ حَفْصَۃَ قَالَتْ : لَمَّا تَزَوَّجَ أَبِی : سِیرِینُ دَعَا أَصْحَابَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سَبْعَۃَ أَیَّامٍ فَلَمَّا کَانَ یَوْمُ الأَنْصَارِ دَعَاہُمْ وَدَعَا أُبَیَّ بْنَ کَعْبٍ وَزَیْدَ بْنَ ثَابِتٍ قالَ ہِشَامٌ : وَأَظُنُّہُ قَالَ وَمُعَاذًا قَالَ : فَکَانَ أُبَیٌّ صَائِمًا فَلَمَّا طَعِمُوا دَعَا أُبَیّ بْنُ کَعْبٍ وَأَمَّنَ الْقَوْمُ۔",,,17448 17449,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حُمَیْدٍ ، عَنْ أَنَسِ بْنِ مَالِکٍ قَالَ : أَوْلَمَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِزَیْنَبَ فَأَشْبَعَ الْمُسْلِمِینَ خُبْزًا وَلَحْمًا۔ (بخاری 4793۔ مسلم 1048)",,,17449 17450,"حَدَّثَنَا عَفَّانُ قَالَ : حدَّثَنَا جَعْفَرُ بْنُ سُلَیْمَانَ ، قَالَ : حَدَّثَنِی مَالِکُ بْنَ دِینَارٍ قَالَ حَدَّثَتْنِی عَجُوزٌ مِنَ الْحَیِّ قَالَتْ : زَوَّجَ أَبُو مُوسَی الأَشْعَرِیُّ بَعْضَ بَنِیہِ قَالَتْ : فَأَوْلَمَ عَلَیْہِ فَدَعَا نَاسًا۔",,,17450 17451,"حَدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ نَافِعٍ قَالَ : کَانَ ابْنُ عُمَرَ یُطْعِمُ عَلَی خِتَانِ الصِّبْیَانِ۔",,,17451 17452,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ، عَنْ أَبِی إسْرَائِیلَ، عَنِ الأَعْمَشِ أن أَبَا وَائِلٍ: أَوْلَمَ بِرَأْسِ بَقَرَۃٍ وَأَرْبَعَۃِ أَرْغِفَۃٍ۔",,,17452 17453,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ إِسْحَاقَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمِ بْنِ عَبْدِ اللہِ قَالَ : عَرَّسْتُ فِی عَہْدِ أَبِی فَآذَنَ أَبِی النَّاسَ ، وَکَانَ فِیمَنْ آذَنَ لأَبِی أَیُّوبَ۔",,,17453 17454,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، عَنْ یُونُسَ الأَیْلِیِّ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ أَنَّ حَمْزَۃَ بْنَ عَبْدِ اللہِ بْنِ عُمَرَ نَحَرَ جَزُورًا۔,,,17454 17455,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُمَرَ بْنِ حَمْزَۃَ قَالَ : أَخْبَرَنِی سَالِمُ بْنُ عَبْدِ اللہِ قَالَ : خَتَنَنِی أَبِی أَنَا وَنُعَیْمَ بْنَ عَبْدِ اللہِ فَذَبَحَ عَلَیْنَا کَبْشًا وَلَقَدْ رَأَیْتُنَا نَجْدِلُ بِہِ عَلَی الْغِلْمَانِ۔",,,17455 17456,"حدَّثَنَا حدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ قَالَ : کَانَ یقال : إِنَّ خَوْلَۃَ بِنْتَ حَکِیمٍ مِنَ اللاَّتِی وَہَبْنَ أَنْفُسَہُنَّ لِلنَّبِیِّ علیہ السلام۔ (بخاری 5113۔ مسلم 50)",,,17456 17457,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ مُجَاہِدٍ : {وَامْرَأَۃً مُؤْمِنَۃً إِنْ وَہَبَتْ نَفْسَہَا لِلنَّبِیِّ} قَالَ : لم تَہَبْ نَفْسَہَا۔",,,17457 17458,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ قَالَ : کَتَبَ عَبْدُ الْمَلِکِ إلَی أَہْلِ الْمَدِینَۃِ یَسْأَلُہُمْ قَالَ : فَکَتَبَ إلَیْہِ عَلِیٌّ قَالَ شُعْبَۃُ : وَظَنِّی أَنَّہُ ابْنُ حُسَیْنٍ قَالَ : وَأَخْبَرَنِی أَبَانُ بْنُ تَغْلِبَ ، عَنِ الْحَکَمِ أَنَّہُ عَلِیُّ بْنُ حُسَیْنٍ قَالَ : ہِیَ امْرَأَۃٌ مِنَ الأَزْدِ یُقَالُ لَہَا أَمُّ شَرِیکٍ وَہَبَتْ نَفْسَہَا لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔\n\n(نسائی 8928۔ احمد 6/462)",,,17458 17459,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : حَدَّثَنِی عَبْدُ اللہِ بْنُ أَبِی السَّفَرِ ، عَنِ الشَّعْبِیِّ أَنَّہَا امْرَأَۃٌ مِنَ الأَنْصَارِ وَہَبَتْ نَفْسَہَا لِلنَّبِیِّ وَہِیَ مِمَّنْ أَرْجَأَ۔",,,17459 17460,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ قَالَ : وَحَدَّثَنِی أَہْلُ الْمَدِینَۃِ أَنَّہُمْ کَانُوا یَقُولُونَ لِلشَّیْئِ : لَہُوَ أَعْظَمُ نَحِیًّا مِنْ نَحِیِّ أُمِّ شَرِیکٍ۔",,,17460 17461,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ مُحَمَّدِ بْنِ کَعْبٍ وَعُمَرَ بْنِ الْحَکَمِ ، وَعَبْدِ اللہِ بْنِ عُبَیدۃَ قَالُوا : الَّتِی وَہَبَتْ نَفْسَہَا لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَیْمُونَۃُ۔ (طبری 23۔ بیہقی 55)",,,17461 17462,"حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ ، عَنْ وَرْقَائَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ : {وَامْرَأَۃً مُؤْمِنَۃً إِنْ وَہَبَتْ نَفْسَہَا لِلنَّبِیِّ} قَالَ : بِغَیْرِ صَدَاقٍ۔",,,17462 17463,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ : (وَامْرَأَۃً مُؤْمِنَۃً إِنْ وَہَبَتْ نَفْسَہَا لِلنَّبِیِّ) قَالَ : فَعَلَتْ وَلَمْ یَفْعَلْ۔",,,17463 17464,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَوْفٍ قَالَ : حدَّثَنَا أَشْیَاخُ عُمَرِیِین مِنْ جُلَسَائِ قَسَامَۃَ بْنِ زُہَیْرٍ أَنَّ ہَمَّامَ بْنَ عُمَیْرٍ رَجُلٌ مِنْ بَنِی تَیْمِ اللہِ کَانَ جَمَعَ بَیْنَ أُخْتَیْنِ فِی الْجَاہِلِیَّۃِ فَلَمْ یُفَرِّقْ بَیْنَ وَاحِدَۃٍ مِنْہُمَا حَتَّی کَانَ فِی خِلاَفَۃِ عُمَرَ وَأَنَّہُ رُفِعَ شَأْنُہُ إلَی عُمَرَ فَأَرْسَلَ إلَیْہِ ، فَقَالَ : اخْتَرْ إحْدَاہُمَا وَاللَّہِ لَئِنْ قَرَبْتِ الأُخْرَی لأَضْرِبَنَّ رَأْسَکَ۔",,,17464 17465,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ قَالَ : إذَا أَسْلَمَ وَعِنْدَہُ أُخْتَانِ حَبَسَ الأُولَی مِنْہُمَا إِنْ شَائَ۔",,,17465 17466,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ إِسْحَاقَ بْنِ عَبْدِ اللہِ بْنِ أَبِی فَرْوَۃَ ، عَنْ أَبِی وَہْبٍ الْجَیْشَانِیِّ ، عَنْ أَبِی خِرَاشٍ الرُّعَیْنِیِّ ، عَنِ الدَّیْلَمِیِّ قَالَ : قدِمْتُ عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَعِنْدِی أُخْتَانِ تَزَوَّجْتُہُمَا فِی الْجَاہِلِیَّۃِ ، فَقَالَ : إذَا رَجَعْت فَطَلِّقْ إحْدَاہُمَا۔ (ترمذی 1129۔ احمد 4/232)",,,17466 17467,"حدَّثَنَا ابْنُ عُلَیَّۃَ وَمَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ ، عَنِ ابْنِ عُمَرَ قَالَ : أَسْلَمَ غَیْلاَنُ بْنُ سَلَمَۃ الثَّقَفِیُّ وَتَحْتَہُ عَشْرُ نِسْوَۃٍ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : خُذْ مِنْہُنَّ أَرْبَعًا۔\n\n(دار قطنی 271۔ بیہقی 183)",,,17467 17468,"حَدَّثَنَا غُنْدَرٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یُسْلِمُ وَعِنْدَہُ عَشْرُ ، أَوْ سِتُّ نِسْوَۃٍ قَالَ : یُمْسِکُ مِنْہُنَّ أَرْبَعًا۔",,,17468 17469,"حَدَّثَنَا بَکْرُ بْنُ عَبْدِ الرَّحْمَنِ قَالَ : حدَّثَنَا عِیسَی بْنُ الْمُخْتَارِ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ حُمَیْضَۃَ بْنِ الشَّمَرْدَلِ ، عَنْ قَیْسِ بْنِ الْحَارِثِ الأَسَدِیِّ أَنَّہُ أَسْلَمَ وَعِنْدَہُ ثَمَانِ نِسْوَۃٍ فَأَمَرَہُ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یَخْتَارَ مِنْہُنَّ أَرْبَعًا۔ (ابوداؤد 2236۔ ابن ماجہ 1952)",,,17469 17470,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنِ الشَّعْبِیِّ فِی قَوْلِہِ : {غَیْرِ أُولِی الإِرْبَۃِ} قَالَ : الَّذِی لَمْ یَبْلُغْ أرْبُہُ أَنْ یَطَّلِعَ عَلَی عَوْرَۃِ النِّسَائِ۔",,,17470 17471,"حَدَّثَنَا ابْنُ إدْرِیسَ أَظُنُّہُ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ قَالَ فِی قَوْلِہِ : {غَیْرِ أُولِی الإِرْبَۃِ} قَالَ : ہو الأَبْلَہُ الَّذِی لاَ یَعْرِفُ أَمْرَ النِّسَائِ۔",,,17471 17472,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ فِی قَوْلِہِ : {غَیْرِ أُولِی الإِرْبَۃِ مِنَ الرِّجَالِ} قَالَ : الَّذِی لاَ أرب لہ بِالنِّسَائِ۔",,,17472 17473,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ قَالَ : الْمَعْتُوہُ۔",,,17473 17474,"حدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّد ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ قَالَ : ہُوَ الَّذِی یَقُولُونَ : أَحْمَقُ",,,17474 17475,"حَدَّثَنَا عُبَیْدُ اللہِ ، عَنْ إسْرَائِیلَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ رَجُلٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : ہُوَ الَّذِی لاَ تَسْتَحْیِی مِنْہُ النِّسَائُ۔",,,17475 17476,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ عَوْنٍ ، عَنْ عِکْرِمَۃَ قَالَ : ہُوَ الَّذِی لاَ یَقُومُ إرْبُہُ۔",,,17476 17477,"حدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ قَالَ : فَرَّقَ عُمَرُ بْنُ الْخَطَّابِ بَیْنَہُمَا وَجَعَلَ صَدَاقَہَا فِی بَیْتِ الْمَالِ وَقَالَ الزُّہْرِیُّ : لَمْ یَکُنْ صَدَاقُہَا فِی بَیْتِ الْمَالِ ، ہُوَ بِمَا أَصَابَ مِنْ فَرْجِہَا۔",,,17477 17478,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ صَالِحِ بْنِ مُسْلِمٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : قَالَ عُمَرُ : یُفَرَّقُ بَیْنَہُمَا وَیُجعَلُ صَدَاقَہَا فِی بَیْتِ الْمَالِ وَقَالَ عَلِی : یُفَرَّقُ بَیْنَہُمَا وَلَہَا الصَّدَاقُ بِمَا اسْتَحَلَّ مِنْ فَرْجِہَا۔",,,17478 17479,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیِّبِ قَالَ : یُفَرَّقُ بَیْنَہُمَا وَلَہَا الصَّدَاقُ بِمَا اسْتَحَلَّ مِنْ فَرْجِہَا۔",,,17479 17480,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ قَالَ : یُفَرَّقُ بَیْنَہُمَا وَیُلْقَی الصَّدَاقُ فِی بَیْتِ الْمَالِ۔",,,17480 17481,"حَدَّثَنَا عَبْدَۃُ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ قَالَ : کُلُّ نِکَاحٍ فَاسِدٍ نَحْوَ الَّذِی تُزَوَّجُ فِی عِدَّتِہَا وَأَشْبَاہِہِ ، ہَذَا مِنَ النِّکَاحِ الْفَاسِدِ إذَا کَانَ قَدْ دَخَلَ بِہَا فَلَہَا الصَّدَاقُ وَیُفَرَّقُ بَیْنَہُمَا۔",,,17481 17482,"حَدَّثَنَا یَحْیَی بْنُ عَبْدِ الْمَلِکِ بْنِ أَبِی غَنِیَّۃَ ، عَنْ أَبِیہِ ، عَنِ الْحَکَمِ أَنَّہُ قَالَ : یُفَرَّقُ بَیْنَہَا وَبَیْنَ زَوْجِہَا وَیَکُونُ لَہَا الْمَہْرُ بِمَا اسْتَحَلَّ مِنْ فَرْجِہَا۔",,,17482 17483,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ إسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ ، عَنْ مَسْرُوقٍ قَالَ : قضَی عُمَرُ فِی امْرَأَۃٍ تَزَوَّجَتْ فِی عِدَّتِہَا أَنْ یُفَرَّقَ بَیْنَہُمَا مَا عَاشَا وَیُجْعَلُ صَدَاقُہَا فِی بَیْتِ الْمَالِ وَقَالَ : کَانَ نِکَاحُہَا حَرَامًا فَصَدَاقُہَا حَرَامًا ، وَقَضَی فِیہَا عَلِیٌّ أَنْ یُفَرَّقَ بَیْنَہُمَا وَتُوَفِّیَ عِدَّۃَ مَا بَقِیَ مِنَ الزَّوْجِ الأَوَّلِ ثُمَّ تَعْتَدُّ ثَلاَثَۃَ قُرُوئٍ وَلَہَا الصَّدَاقُ بِمَا اسْتَحَلَّ مِنْ فَرْجِہَا ثُمَّ إِنْ شَائَ خَطَبَہَا بَعْدَ ذَلِکَ۔",,,17483 17484,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی حَصِینٍ ، عَنْ عَبْدِ اللہِ بْنِ حَبِیبٍ قَالَ : خَرَجَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَلَقِیَ امْرَأَۃً فَأَعْجَبَتْہُ فَرَجَعَ إلَی أُمِّ سَلَمَۃَ وَعِنْدَہَا نِسْوَۃٌ یَدُفن طِیبًا قَالَ : فَعَرَفْنَ فِی وَجْہِہِ فَأَخْلَیْنَہُ فَقَضَی حَاجَتَہُ فَخَرَجَ ، فَقَالَ : مَنْ رَأَی مِنْکُمُ امْرَأَۃً فَأَعْجَبَتْہُ فَلِیَأْتِ أَہْلَہُ فَلْیُوَاقِعْہَا فَإِنَّ مَعَہَا مِثْلُ الَّذِی مَعَہَا۔ (مسلم 9)",,,17484 17485,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ عَبْدِ اللہِ بْنِ حَبِیبٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِمِثْلِ حَدِیثِ أَبِی حَصِینٍ إلاَّ إِنَّہُ لَمْ یَذْکُرْ : یَدُفْنَ طِیبًا۔",,,17485 17486,"حَدَّثَنَا وَکِیعٌ ، وَابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ اللہِ بْنِ حُلاَّمٍ قَالَ قَالَ عَبْدُ اللہِ : مَنْ رَأَی مِنْکُمُ امْرَأَۃً فَأَعْجَبَتْہُ فَلْیُوَاقِع أَہْلَہُ فَإِنَّ مَعَہُنَّ مِثْلَ الَّذِی مَعَہُنَّ۔ (دارمی 2215)",,,17486 17487,"حَدَّثَنَا عَبِیدَۃُ ، عَنْ مَنْصُورٍ ، عَنْ سَالِمِ بْنِ أَبِی الْجَعْدِ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَأَی امْرَأَۃً ، فَأَتَی أُمَّ سَلَمَۃَ فَوَاقَعَہَا وَقَالَ : إذَا رَأَی أحدکم امْرَأَۃً تُعْجِبُہُ فَلْیَأْتِ أَہْلَہُ فَإِنَّ مَعَہُنَّ مِثْلَ الَّذِی مَعَہُنَّ۔",,,17487 17488,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ أَشْعَثَ ، عَنْ أَبِی الزُّبَیرِ ، عَنْ جَابِرٍ بِنَحْوِ حَدِیثِ عَبْدِ اللہِ۔\n\n(مسلم9۔ ابوداؤد 2144)",,,17488 17489,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ ثَابِتٍ ، عَنْ مُطَرِّفٍ فِی الرَّجُلِ یَرَی الْمَرْأَۃَ تُعْجِبُہُ قَالَ : یَذْکُرُ أَخْسَائَ الْبَقَرِ۔",,,17489 17490,"حَدَّثَنَا زید بْنُ حُبَابٍ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ إبْرَاہِیمَ فِی الرَّجُلِ یَرَی الْمَرْأَۃَ فتعجبہ قَالَ : یَذْکُرُ مَنَاتِنہَا۔",,,17490 17491,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَلِیِّ بْنِ مُدْرِکٍ ، قَالَ : سَمِعْتُ النَّخَعِیّ قَالَ : تَزَوَّجَ الأَشْعَثُ امْرَأَۃً عَلَی حُکْمِہَا فَرُفِعَ إلَی عُمَرَ بْنِ الْخَطَّابِ ، فَقَالَ : أَرْضِہَا أَرْضِہَا۔",,,17491 17492,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ إسْمَاعِیلَ بْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ قَالَ : إذا تَزَوَّجَ الرَّجُلُ الْمَرْأَۃَ عَلَی حُکْمِہَا ، أَوْ حُکْمِہِ فَجَارٍ فِی الصَّدَاقِ أو جَارُوا رُدَّ ذَاکَ إلَی صَدَاقِ مِثْلِہَا لاَ وَکْسَ وَلاَ شَطَطَ وَالنِّکَاحُ جَائِزٌ۔",,,17492 17493,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی ہِلاَلٍ ، عَنْ مُحَمَّدِ بْنِ سِیرِینَ قَالَ : خَطَبَ عَمْرُو بْنُ حُرَیْثٍ إلَی عَدِیِّ بْنِ حَاتِمٍ ابْنَتَہُ فَأَبَی إلاَّ عَلَی حُکْمِہِ فَرَجَعَ عَمْرٌو فَاسْتَشَارَ أَصْحَابَہُ فَقَالُوا : أَتُرِیدُ أَنْ تُحَکِّمَ رَجُلاً مِنْ طیئٍ فِی عَقْدِکَ فَأَبَتْ نَفْسُہُ فَتَزَوَّجَہَا عَلَی حُکْمِہِ ثُمَّ انْصَرَفَ فَحَکَّمَ عَدِیٌّ سُنَّۃَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ثَمَانِینَ وَأَرْبَعِ مِئَۃٍ ، فَبَعَثَ إلَیْہِ عَمْرٌو بِعَشَرَۃِ آلاَفٍ وَقَالَ : جَہِّزْہَا۔",,,17493 17494,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ أَنَّ الأَشْعَثَ تَزَوَّجَ امْرَأَۃً عَلَی حُکْمِہَا فَسَأَلَہُ عُمَرُ عَنْہَا ، فَقَالَ : بِتُّ لَیْلَۃً لاَ یَعْلَمُہَا إلاَّ اللَّہُ مَخَافَۃَ أَنْ تَحْکُمَ عَلَیَّ فِی مَالِ قَیْسٍ ، فَقَالَ : لَیْسَ ذَلِکَ لَہَا إنَّمَا لَہَا مَہْرُ نِسَائِہَا۔",,,17494 17495,"حَدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ فِی رَجُلٍ تَزَوَّجَ امْرَأَۃً عَلَی حُکْمِہِ فَمَاتَتِ الْمَرْأَۃُ قَبْلَ أَنْ یَحْکُمَ الرَّجُلُ قَالَ : لَہَا صَدَاقُ نِسَائِہَا۔",,,17495 17496,"حَدَّثَنَا یَعْلَی ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ فِی رَجُلٍ تَزَوَّجَ امْرَأَۃً عَلَی حُکْمِہِ فَحَکَمَ عَشَرَۃَ دَرَاہِمَ قَالَ : یَجُوزُ ، قَدْ کَانَ الْمُسْلِمُونَ یَتَزَوَّجُونَ عَلَی أَقَلَّ مِنْ ذَلِکَ وَأَکْثَرَ۔",,,17496 17497,"حَدَّثَنَا حُمَیْدُ بنُ عَبْدِ الرَّحْمَنِ ، عَنِ السَّرِیِّ بْنِ یَحْیَی ، عَنِ الْحَسَنِ قَالَ : قَالَ رَجُلٌ لآخَرَ : بِالرِّفَائِ والبَنِیْنَ، فَقَالَ رَسُوْلَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تَقُوْلُوْا ہَکَذَا قُوْلُوْا : بَارَکَ اللَّہُ فِیْکَ وَبَارَکَ عَلَیْکَ۔",,,17497 17498,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ أَنَّ عَقِیلَ بْنَ أَبِی طَالِبٍ تَزَوَّجَ امْرَأَۃً مِنْ بَنِی جُشَمٍ فَدَعَاہُمْ فَقَالُوا : بِالرِّفَائِ وَالبَنِیْنَ ، فَقَالَ : لاَ تَقُوْلُوْا ذَاکَ : قَالُوا : کَیْفَ نَقُوْلُ یَا أَبَا یَزِیْدٍ ؟ قَالَ : تَقُوْلُوْنَ : بَارَکَ اللَّہُ لَکَ وَبَارَکَ عَلَیْکَ فَإنَّا کُنَّا نَقُوْلُ ، أَوْ نُؤْمَرُ بِذَلِکَ۔ (ابن ماجہ 1906۔ احمد 1/451)",,,17498 17499,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ بْنِ عُبَیْدٍ ، عَنْ عَمْرِو بْنِ سَعِیدٍ ، عَنْ أَبِی زُرْعَۃَ بْنِ عَمْرٍو ، عَنْ جَرِیرٍ قَالَ: سَأَلْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، عَنْ نَظْرَۃِ الْفُجَائَۃِ فَأَمَرَنِی أَنْ أَصْرِفَ بَصَرِی۔\n\n(مسلم 1699۔ ابوداؤد 2141)",,,17499 17500,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ إِسْحَاقَ بْنِ سُوَیْد ، عَنِ الْعَلاَئِ بْنِ زِیَادٍ قَالَ : کَانَ یُقَالُ : لاَ تُتْبِعَنَّ نَظَرَکَ حُسْنَ رِدَائِ امْرَأَۃٍ فَإِنَّ النَّظَرَ یَجْعَلُ شَہْوَۃً فِی الْقَلْبِ۔",,,17500 17501,"حَدَّثَنَا جَرِیرٌ ، عَنْ عَاصِمٍ الأَحْوَلِ ، عَنِ الشَّعْبِیِّ قَالَ : (قُلْ لِلْمُؤْمِنِینَ یَغُضُّوا مِنْ أَبْصَارِہِمْ) قُلْتُ لِلشَّعْبِیِّ : الرَّجُلُ یَنْظُرُ الْمَرْأَۃَ لاَ یَرَی مِنْہَا مُحَرَّمًا قَالَ : مَا لَکَ أَنْ تثقبہا بِعَیْنِکَ ؟۔",,,17501 17502,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ قَالَ : نَظْرَۃٌ یَہْوَاہَا الْقَلْبُ فَلاَ خَیْرَ فِیہَا۔",,,17502 17503,"حَدَّثَنَا وَکِیعٌ ، عَنْ شَرِیکٍ ، عَنْ أَبِی رَبِیعَۃَ الإِیَادِیِّ ، عَنِ ابْنِ بُرَیْدَۃَ ، عَنْ أَبِیہِ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ لِعَلِیٍّ : لاَ تُتْبِعِ النَّظْرَۃَ النَّظْرَۃَ فَإِنَّمَا لَکَ الأُولَی وَلَیْسَ لَکَ الآخِرَۃُ۔(ترمذی 2777۔ ابوداؤد 2142)",,,17503 17504,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ مُوسَی الْجُہَنِیِّ قَالَ : کُنْتُ مَعَ سَعِیدِ بْنِ جُبَیْرٍ فِی طَرِیقٍ فَاسْتَقْبَلَتْنَا امْرَأَۃٌ أو جاریۃ قَالَ : فَنَظَرْنَا إلَیْہَا جَمِیعًا قَالَ ثُمَّ إنَّ سَعِیدًا غَضَّ بَصَرَہُ فَنَظَرْتُ أنا ، قَالَ : فَقَالَ لِی سَعِیدٌ : الأُولَی لَکَ وَالثَّانِیَۃُ عَلَیْکَ۔",,,17504 17505,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ إسْمَاعِیلَ ، عَنْ قَیْسٍ قَالَ : کَانَ یُقَالُ : النَّظْرَۃُ الأُولَی لاَ یَمْلِکُہَا أَحَدٌ وَلَکِنِ الَّذِی یَدُسُّ النَّظَرَ دَسًّا۔",,,17505 17506,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ دَاوُدَ أَبِی الہیثم قَالَ قَالَ رَجُلٌ لاِِبْنِ سِیرِینَ : أَسْتَقْبِلُ الْقِبْلَۃَ فِی الطَّرِیقِ أَلَیْسَ لِی النَّظْرَۃُ الأُولَی ثُمَّ أَصْرِفُ عَنْہَا بَصَرِی ؟ قَالَ : أَمَا تَقْرَأُ الْقُرْآنَ : {یَغُضُّوا مِنْ أَبْصَارِہِمْ} {یَعْلَمُ خَائِنَۃَ الأَعْیُنِ، وَمَا تُخْفِی الصُّدُورُ}۔",,,17506 17507,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ خَالِدِ بْنِ مَحدُوجٍ ، قَالَ : سَمِعْتُ أَنَسًا یَقُولُ : إذَا لَقِیتَ الْمَرْأَۃَ فَغُضَّ عَیْنَیکَ حَتَّی تَمْضِیَ۔",,,17507 17508,"حَدَّثَنَا عَبْدُ الْوَہَّابِ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ قَالَ : لاَ یَضُرُّک حُسْنُ امْرَأَۃٍ مَا لَمْ تَعْرِفْہَا۔",,,17508 17509,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنْ عَمْرِو بْنِ سَعِیدٍ ، قَالَ : قَالَ سَعْدُ بْنُ أَبِی وَقَّاصٍ : بَیْنَا أَنَا أَطُوفُ بِالْبَیْتِ إذْ رَأَیْتُ امْرَأَۃً فَأَعْجَبَنِی دَلُّہَا فَأَرَدْتُ أَنْ أَسْأَلَ عَنْہَا فَوَجَدْتُہَا مَشْغُولَۃً وَلاَ یَضُرُّکَ حُسْنُ امْرَأَۃٍ مَا لَمْ تَعْرِفْہَا۔",,,17509 17510,حَدَّثَنَا إسْمَاعِیلُ بْنُ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ طَاوُوسٍ أَنَّہُ کَرِہَ أَنْ یَنْظُرَ الرَّجُلُ إلَی الْمَرْأَۃِ إلاَّ أَنْ یَکُونَ زَوْجًا ، أَوْ ذَا مَحْرَمٍ۔,,,17510 17511,"حَدَّثَنَا أَبُو أُسَامَۃَ قَالَ : أَخْبَرَنِی أَبُو عُمَیْرٍ ، عَنْ أَیُّوبَ قَالَ : کَانَ طَاوُوسٌ لاَ یَصْحَبُ رُفْقَۃً فِیہَا امْرَأَۃٌ۔",,,17511 17512,"حَدَّثَنَا عَفَّانُ قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ مُحَمَّدِ بْنِ إبْرَاہِیمَ ، عَنْ سَلَمَۃَ بْنِ أَبِی طُفَیْلٍ ، عَنْ عَلِیٍّ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : یَا عَلِیُّ ، إنَّ لَکَ کَنْزًا فِی الْجَنَّۃِ وَإِنَّکَ ذُو قَرْنَیْہَا فَلاَ تُتْبِعِ النَّظْرَۃَ النَّظْرَۃَ فَإِنَّمَا لَکَ الأُولَی وَلَیْسَتْ لَکَ الآخِرَۃُ۔ (احمد 1/159۔ دارمی 2709)",,,17512 17513,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، قَالَ : قَالَ ابْنُ عَبَّاسٍ : {یَعْلَمُ خَائِنَۃَ الأَعْیُنِ ، وَمَا تُخْفِی الصُّدُورُ} قَالَ : الرَّجُلُ یَکُونُ فِی الْقَوْمِ فَتَمُرُّ بِہِمُ الْمَرْأَۃُ فَیُرِیہِمْ أَنَّہُ یَغُضُّ بَصَرَہُ عَنْہَا فَإِنْ رَأَی مِنْہُمْ غَفَلَۃً نَظَرَ إلَیْہَا فَإِنْ خَافَ أَنْ یَفْطَنُوا بِہِ غَضَّ بَصَرَہُ وَقَدِ اطَّلَعَ اللَّہُ مِنْ قَلْبِہِ أَنَّہُ وَدَّ أَنَّہُ نَظَرَ إلَی عَوْرَتِہَا۔",,,17513 17514,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ أَبِی عَمْرٍو الشَّیْبَانِیِّ ، قَالَ : قَالَ أَبُو مُوسَی : لأَنْ تَمْتَلِئَ مَنْخِرَیَّ مِنْ رِیحِ جِیفَۃٍ أَحَبُّ إلَیَّ مِنْ أَنْ تَمْتَلِئَا مِنْ رِیحِ امْرَأَۃٍ۔",,,17514 17515,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : قَالَ عَبْدُ اللہِ : لأَنْ أُزَاحِمَ بَعِیرًا مَطْلِیًّا بِقَطِرَانٍ أَحَبُّ إلَیَّ مِنْ أَنْ أُزَاحِمَ امْرَأَۃً۔",,,17515 17516,"حَدَّثَنَا وَکِیعٌ ، عَنْ ثَابِتِ بْنِ عُمَارَۃَ ، عَنْ غُنَیْمِ بْنِ قَیْسٍ ، عَنْ أَبِی مُوسَی قَالَ : کُلُّ عَیْنٍ فَاعِلَۃٌ یَعْنِی زَانِیَۃً۔",,,17516 17517,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یُطَلِّقُ امْرَأَتَہُ تَطْلِیقَۃً ، أَوْ تَطْلِیقَتَیْنِ قَبْلَ أَنْ یَدْخُلَ بِہَا ثُمَّ غَشِیَہَا وَہُوَ یَرَی أَنَّ لَہُ عَلَیْہَا رَجْعَۃً قَالَ : لَہَا الصَّدَاقُ وَیُفَرَّقُ بَیْنَہُمَا۔",,,17517 17518,"حَدَّثَنَا مُحَمَّدُ بْنُ سَوَائٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ؛ فِی رَجُلٍ طَلَّقَ امْرَأَتَہُ ، ثُمَّ غَشِیَہَا وَہُوَ یَرَی أَنَّ لَہُ عَلَیْہَا رَجْعَۃً قَالَ : لَہَا الصَّدَاقُ کَامِلاً لِغِشْیَانِہِ إیَّاہَا۔",,,17518 17519,"حَدَّثَنَا مُحَمَّدُ بْنُ سَوَائٍ ، عَنْ سَعِیدٍ عن مَطَرٍ ، عَنِ الْحَکَمِ قَالَ : لَہَا الصَّدَاقُ کَامِلاً۔",,,17519 17520,"حَدَّثَنَا مُحَمَّدُ بْنُ سَوَائٍ ، عَنْ سَعِیدٍ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ قَالَ : لَہَا الصَّدَاقُ کَامِلاً۔",,,17520 17521,"حَدَّثَنَا مُحَمَّدُ بْنُ سَوَائٍ ، عَنْ سَعِیدٍ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ قَالَ : لَہَا صَدَاقٌ وَنِصْفُ۔",,,17521 17522,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ فِی رَجُلٍ طَلَّقَ امْرَأَتَہُ قَبْلَ أَنْ یَدْخُلَ بِہَا وَاحِدَۃً ثُمَّ غَشِیَہَا وَہُوَ یَرَی أَنَّ لَہُ عَلَیْہَا الرَّجْعَۃَ قَالَ : یُفَرَّقُ بَیْنَہُمَا وَلَہَا الصَّدَاقُ کَامِلاً۔",,,17522 17523,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ قَالَ: لَہَا صَدَاقٌ وَنِصْفٌ وَقَالَ الْحَکَمُ: لَہَا الصَّدَاقُ۔",,,17523 17524,"حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنِ الْمُثَنَّی ، عَنْ عَطَائٍ فِی رَجُلٍ طَلَّقَ امْرَأَتَہُ ثَلاَثًا وَجَہِلَ فَأَصَابَہَا قَالَ : لَہَا الصَّدَاقُ کَامِلاً۔",,,17524 17525,"حَدَّثَنَا عُمَرُ بْنُ ہَارُونَ ، عَنِ الأَوْزَاعِیِّ ، عَنْ عَطَائٍ قَالَ : لَہَا صَدَاقٌ وَنِصْفٌ۔",,,17525 17526,"حَدَّثَنَا حَفْصٌ ، عَنْ مِسْعَرٍ ، عَنْ حَمَّادٍ قَالَ : صَدَاقٌ وَنِصْفُ۔",,,17526 17527,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَبِیبٍ ، عَنْ عَمْرٍو ، عَنْ جَابِرِ بْنِ زَیْدٍ قَالَ : سُئِلَ عَمَّنْ تَزَوَّجَ امْرَأَۃً فَطَلَّقَہَا قَبْلَ أَنْ یَمَسَّہَا ثُمَّ قِیلَ لَہُ : إنَّہَا لَمْ تَحْرُمْ عَلَیْکَ فَدَخَلَ بِہَا بِالنِّکَاحِ الأَوَّلِ فَمَکَثَتْ عِنْدَہُ سَنَتَیْنِ فَوَلَدَتْ لَہُ أَوْلاَدًا فَعَلِمَ بِذَلِکَ أَنَّہَا عَلَیْہِ حَرَامٌ قَالَ : یُفَرَّقُ بَیْنَہُمَا وَیُعْطِی الْمَرْأَۃَ بِنِکَاحِہَا الأَوَّلِ نِصْفَ مَہْرِہَا ومن دُخُولِہِ بِہَا وَمُجَامَعَتِہِ إیَّاہَا مَہْرًا کَامِلاً۔",,,17527 17528,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ قَالَ : لَہَا الصَّدَاقُ۔",,,17528 17529,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ قَالَ : لَہَا صَدَاقٌ وَنِصْفُ۔",,,17529 17530,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ مُجَاہِدٍ وَمِقْسَمٍ ، عَنِ ابْنِ عَبَّاسٍ أَنَّ أَمَۃً أُعْتِقَتْ فَاخْتَارَتْ نَفْسَہَا قَبْلَ أَنْ یُدْخَلَ بِہَا قَالَ : لاَ شَیْئَ لَہَا ، لاَ یُجْمَعُ عَلَیْہِ أَمْرٌ یَذْہَبُ بِنَفْسِہَا وَمَالِہِ۔",,,17530 17531,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ أَنَّہُ کَانَ یَقُولُ : إذَا أُعْتِقَتِ الأَمَۃُ وَہِیَ تَحْتَ الْعَبْدِ فَخُیِّرَتْ فَاخْتَارَتْ نَفْسَہَا قَبْلَ أَنْ یَدْخُلَ بِہَا فَلاَ صَدَاقَ لَہَا وَہِیَ تَطْلِیقَۃٌ بَائِنَۃٌ۔",,,17531 17532,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ فِی رَجُلٍ تزَوَّجَ أَمَتَہُ عَلَی مَہْرٍ مُسَمًّی ثُمَّ أَعْتَقَہَا قَبْلَ أَنْ یَدْخُلَ بِہَا زَوْجُہَا فَتُخَیَّرُ فَتَخْتَارُ نَفْسَہَا قَالَ : یَبْطُلُ النِّکَاحُ وَیُرَدُّ عَلَی الزَّوْجِ مَہْرُہُ۔",,,17532 17533,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : إذَا اخْتَارَتْ نَفْسَہَا وَقَدْ أُعْتِقَتْ قَبْلَ أَنْ یَدْخُلَ بِہَا فَلاَ صَدَاقَ لَہَا۔",,,17533 17534,"حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ ، عَنْ ہِشَامٍ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ مُجَاہِدٍ قَالَ : لاَ شَیْئَ لَہَا۔",,,17534 17535,"حَدَّثَنَا مُحَمَّدُ بْنُ سَوَائٍ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ قَالَ : لاَ یَسَعُہَا أَنْ تَقَارَّہُ حَتَّی تُرَافِعَہُ إلَی السُّلْطَانِ فَإِمَّا حَدٌّ وَإِمَّا مُلاَعَنَۃٌ۔",,,17535 17536,"حَدَّثَنَا مُحَمَّدُ بْنُ سَوَائٍ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ قَالَ : إذَا أکْذَبَ نَفْسَہُ عِنْدَ رَہْطٍ تَسَاکَنَا وَاسْتَغْفَرَ رَبَّہُ وَلاَ یَعُودُ لِذَلِکَ۔",,,17536 17537,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنِ ابْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ قَالَ : إذَا قَذَفَہَا بِالزِّنَا إِنْ شَائَ أَکْذَبَ نَفْسَہُ وَجُلِدَ وَرُدَّتْ إلَیْہِ امْرَأَتُہُ۔",,,17537 17538,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ عُبَیْدِ اللہِ ، عَنِ الشَّعْبِیِّ فِی الرَّجُلِ یَقْذِفُ امْرَأَتَہُ بِالزِّنَا ثُمَّ لاَ تُرَافِعُہُ قَالَ : یُکَذِّبُ نَفْسَہُ وَہُمَا عَلَی نِکَاحِہِمَا۔",,,17538 17539,حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ عَطَائٍ الْخُرَاسَانِیِّ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ قَالَ لَہَا نِصْفُ الصَّدَاقِ وَلاَ مِیرَاثَ لَہَا ، وَلاَ عِدَّۃَ عَلَیْہَا۔,,,17539 17540,حَدَّثَنَا عَبْدُ الْوَہَّابِ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ بِمِثْلِہِ۔,,,17540 17541,"حَدَّثَنَا عَبْدَۃُ وَمُحَمَّدُ بْنُ سَوَائٍ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ قَالَ : لَہَا نِصْفُ الصَّدَاقِ وَلاَ مِیرَاثَ لَہَا وَلاَ عِدَّۃَ عَلَیْہَا۔",,,17541 17542,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ أَنَّہُ کَانَ یَقُولُ : إذَا طَلَّقَہَا قَبْلَ أَنْ یَدْخُلَ بِہَا وَہُوَ مَرِیضٌ فَإِنَّہَا لاَ تَرِثُہُ وَلاَ عِدَّۃَ عَلَیْہَا وَلَہَا نِصْفُ الصَّدَاقِ۔",,,17542 17543,"حَدَّثَنَا مُحَمَّدُ بْنُ سَوَائٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ جَابِرِ بْنِ زَیْدٍ أَنَّہُ قَالَ : لَہَا الصَّدَاقُ کَامِلاً وَلاَ مِیرَاثَ لَہَا وَلاَ عِدَّۃَ عَلَیْہَا۔",,,17543 17544,حَدَّثَنَا مُحَمَّدُ بْنُ سَوَائٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ أَنَّہُ کَانَ یَقُولُہُ۔,,,17544 17545,"حَدَّثَنَا مُحَمَّدُ بْنُ سَوَائٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ قَالَ : لَہَا الصَّدَاقُ کَامِلاً وَلَہَا الْمِیرَاثُ وَعَلَیْہَا الْعِدَّۃُ۔",,,17545 17546,"حَدَّثَنَا جَرِیرٌ ، عَنِ الْمُغِیرَۃِ ، عَنِ الْحَارِثِ قَالَ : إذَا طَلَّقَ امْرَأَتَہُ فِی مَرَضِہِ ثَلاَثًا ، أَوْ تَطْلِیقَۃً قَبْلَ أَنْ یَدْخُلَ بِہَا فَلاَ مِیرَاثَ بَیْنَہُمَا۔",,,17546 17547,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الشَّعْبِیِّ قَالَ : إذَا طَلَّقَہَا قَبْلَ أَنْ یَدْخُلَ بِہَا فَلاَ مِیرَاثَ لَہَا۔",,,17547 17548,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ سَیْفٍ ، عَنِ ابْنِ أَبِی نُجَیْحٍ ، عَنْ مُجَاہِدٍ أَنَّہُ کَرِہَ أَنْ یَتَزَوَّجَ الرَّجُلُ امْرَاَۃَ زَوْجِ أُمِّہِ قَالَ : وَکَانَ طَاوُوْسٌ وَعَطَاء لاَ یَرَیَانِ بِہِ بَأْسًا۔",,,17548 17549,"حَدَّثَنَا وَکِیْعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ قَالَ : لاَ بَأسَ أَنْ یَتَزَوَّجَ الرَّجُلُ امْرَاَۃَ زَوْجِ أُمِّہِ۔",,,17549 17550,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَبِیبِ بْنُ أَبِی حَبِیبٍ ، عَنْ عَمْرِو بنِ ہَرِمٍ ، عَنْ جَابِرٍ بْنِ زَیْدٍ ، عَنِ ابْنِ عَبَّاسٍ، قَالَ : لاَ تُزَاحِمْ مَنْ زَاحَمَ أَبُوکَ ، زَوْجَ أُمِّکَ۔",,,17550 17551,"حدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ فِی الْمَرْأَۃِ تَزَوَّج وَلَہَا زَوْجٌ قَالَ : إِنْ جَائَتْ بِہِ وَہُوَ یَشُکُّ فِیْہِ فَہُوَ للأَوَّلِ ، وَإِنْ جَائَتْ بِہِ وَہُوَ لاَ یَشُکُّ فِیْہِ فَہُوَ لِلآخَرِ۔",,,17551 17552,"حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ فِی رَجُلٍ طَلَّقَ امْرَأَتَہُ وَتَزَوَّجَہَا آخَرٌ فی عدتہا وَقَدْ حَاضَتْ حَیْضَۃً : الوَلَدُ لِلآخَرِ۔",,,17552 17553,"حَدَّثَنَا وَکِیعٌ ، عَنْ جَرِیرٍ ، عَنْ قَیْسِ بْنِ سَعْدٍ ، عَنْ مُجَاہِدٍ قَالَ : إذَا قَبَّلَہَا ، أَوْ لَمَسَہَا ، أَوْ نَظَرَ إلَی فَرْجِہَا حَرُمَتْ عَلَیْہِ ابْنَتُہَا۔",,,17553 17554,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : إذَا قَبَّلَ الأُمَّ لَمْ تَحِلَّ لَہُ ابْنَتُہَا وَإِذَا قَبَّلَ ابْنَتَہَا لَمْ تَحِلَّ لَہُ أُمُّہَا۔",,,17554 17555,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یُقَبِّلُ الْمَرْأَۃَ ، أَوْ یَلْمِسُہَا ، أَوْ یَأْتِیہَا فِی غَیْرِ فَرْجِہَا ، إِنْ شَائَ تَزَوَّجَہَا ، وَإِنْ شَائَ تَزَوَّجَ ابْنَتَہَا ، وَإِنْ کَانَتِ الْبِنْتَ ، تَزَوَّجَ الأُمَّ إِنْ شَائَ۔,,,17555 17556,"حَدَّثَنَا مُحَمَّدُ بْنُ یَزِیدَ ، عَنْ أَبِی الْعَلاَئِ ، عَنْ قَتَادَۃَ وَأَبِی ہَاشِمٍ قَالاَ : فِی الرَّجُلِ یُقَبِّلُ أم امْرَأتہ ، أَوِ ابْنَتَہَا ، قَالاَ : حَرُمَتْ عَلَیْہِ امرأتہ۔",,,17556 17557,"حَدَّثَنَا شَرِیکٌ ، عَنِ السُّدِّیِّ ، عَنْ أَبِی مَالِکٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ بَأْسَ أَنْ یَنْظُرَ الْمَمْلُوکُ إلَی شَعْرِ مَوْلاَتِہِ۔",,,17557 17558,حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ مُغِیرَۃَ ، عَنِ الشَّعْبِیِّ ، أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ تَضَعَ الْمَرْأَۃُ ثَوْبَہَا عِنْدَ مَمْلُوکِہَا ، وَإِنْ کَانَ یُکْرَہُ أَنْ یَرَی شَعْرَہَا۔,,,17558 17559,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، وَعَطَائٍ أَنَّہُمَا کَرِہَا أَنْ یَرَی الْعَبْدُ شَعْرَ مَوْلاَتِہِ۔,,,17559 17560,"حَدَّثَنَا مُحَمَّدُ بْنُ یَزِیدَ ، عَنْ عُبَیْدَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : تَسْتَتِرُ الْمَرْأَۃُ مِنْ غُلاَمِہَا۔",,,17560 17561,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ یُونُسَ بْنِ أَبِی إِسْحَاقَ ، عَنْ طَارِقٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : لاَ تَغُرَّنَّکُمْ ہَذِہِ الآیَۃُ : {إلاَّ مَا مَلَکَتْ أَیْمَانُکُمْ} إنَّمَا عَنَی بِہَا الإِمَائَ وَلَمْ یَعْنِ بِہَا الْعَبِیدَ۔",,,17561 17562,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ أَنَّہُ کَرِہَ أَنْ یَدْخُلَ الْمَمْلُوکُ عَلَی مَوْلاَتِہِ بِغَیْرِ إذْنِہَا۔,,,17562 17563,حَدَّثَنَا ابْنُ یَمَانٍ ، عَنْ سُفْیَانَ ، عَنْ جُوِیبرٍ ، عَنِ الضَّحَّاکِ أَنَّہُ کَرِہَ أَنْ یَنْظُرَ الْمَمْلُوکُ إلَی شَعْرِ مَوْلاَتِہِ۔,,,17563 17564,حَدَّثَنَا جَرَیْرٌ ، عَنْ مُغِیْرَۃُ ، عَنِ الشَّعْبِیِّ أَنَّہُ کَرِہَ أَنْ یُسِفَّ الرَّجُلُ النَّظَرَ إِلَی أُخْتِہِ أَو ابْنَتِہِ۔,,,17564 17565,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ أَنَّہُ کَرِہَ أَنْ یَنْظُرَ الرَّجُلُ إلَی شَعْرِ ابْنَتِہِ ، أَوْ أُخْتِہِ۔,,,17565 17566,حَدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ فِی الرَّجُلِ یَرَی مِنَ النِّسَائِ مَا یُحَرِّمُ عَلَیْہِ نِکَاحَہُ رُؤُوسُہُنَّ یَسْتَتِرْنَ أَحَبُّ إلَیَّ ، وَإِنْ رَأَی فَلاَ بَأْسَ۔,,,17566 17567,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الأَعْمَشِ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ أَبِی الْبَخْتَرِیِّ ، عَنْ أَبِی صَالِحٍ أَنَّ الْحَسَنَ وَالْحُسَیْنَ کَانَا یَدْخُلاَنِ عَلَی أُخْتِہِمَا أُمِّ کُلْثُومٍ وَہِیَ تمتشط۔,,,17567 17568,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ فِی الْمَرْأَۃِ تَضَعُ خِمَارَہَا عِنْدَ أَخِیہَا قَالَ وَاللَّہِ مَا لَہَا ذَاکَ۔,,,17568 17569,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ أَنَّہُ کَرِہَ أَنْ یَنْظُرَ إلَی شَعَرِ کُلِّ ذِی مَحْرَمٍ۔,,,17569 17570,حَدَّثَنَا مُعْتَمِرٌ ، عَنْ أَبِیہِ ، عَنْ مُوَرِّقٍ أَنَّہُ کَانَ یُفَلِّی أُمَّہُ۔,,,17570 17571,حَدَّثَنَا مُعْتَمِرٌ ، عَنْ أَبِیہِ أَنَّ طَلْقًا کَانَ یُذَوِّبُ أُمَّہُ۔,,,17571 17572,حَدَّثَنَا وکیع عن شریک عن رجل عن الضحاک أنہ کان یمشط أمہ۔,,,17572 17573,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ أَنَّہُ قَالَ : لاَ بَأْسَ أَنْ یَنْظُرَ إلَی شَعْرِ أُمِّہِ وَأَنْ تَسْتَتِرَ أَحَبُّ إلَیَّ۔",,,17573 17574,"حَدَّثَنَا یَعْلَی ، عَنْ سُفْیَانَ ، عَنْ مُزَاحِمِ بْنِ زُفَرَ ، عَنِ الضَّحَّاکِ قَالَ : لَوْ دَخَلْتُ عَلَی أُمِّی لَقُلْت : أَیَّتُہَا الْعَجُوزُ ، غَطِّی رَأْسَک۔",,,17574 17575,حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ سُفْیَانَ ، عَنْ سَالِمِ بْنِ أَبِی حَفْصَۃَ ، عَنْ مُنْذِرٍ ، عَنِ ابْنِ الْحَنَفِیَّۃِ أَنَّہُ کَانَ یُذَوِّبُ أُمَّہُ۔,,,17575 17576,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ ، عَنْ مُزَاحِمٍ ، عَنِ الضَّحَّاکِ قَالَ: لَوْ دَخَلْتُ عَلَی أُمِّی لَقُلْت : غَطِّی رَأْسَکِ۔",,,17576 17577,"حَدَّثَنَا وَکِیعٌ ، وَابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ أَبِی الزَّعْرَائِ ، عَنْ عِکْرِمَۃَ قَالَ : مُبَاشَرَۃُ الرَّجُلِ أُخْتَہُ أو أُمَّہُ شُعْبَۃٌ مِنَ الزِّنَا۔",,,17577 17578,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ مُحَمَّدِ بْنِ عَلِیٍّ قَالَ : کَانَ الْحَسَنُ وَالْحُسَیْنُ لاَ یَرَیَانِ أُمَّہَاتِ الْمُؤْمِنِینَ ، وَکَانَ ابْنُ عَبَّاسٍ یَرَی أَنَّ رُؤْیَتَہُنَّ لَہُمَا حِلٌّ۔",,,17578 17579,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ قَالَ : قُلْتُ لِسَعِیدِ بْنِ جُبَیْرٍ أَیَرَی الرَّجُلُ رَأْسَ خَتَِنَتِہِ قَالَ : فَتَلاَ عَلَیَّ الآیَۃَ: {وَلاَ یُبْدِینَ زِینَتَہُنَّ إلاَّ لِبُعُولَتِہِنَّ ، أَوْ آبَائِہِنَّ ، أَوْ آبَائِ بُعُولَتِہِنَّ ، أَوْ أَبْنَائِہِنَّ ، أَوْ أَبْنَائِ بُعُولَتِہِنَّ ، أَوْ إخْوَانِہِنَّ ، أَوْ بَنِی إخْوَانِہِنَّ ، أَوْ بَنِی أَخَوَاتِہِنَّ} الآیَۃَ ، فَقَالَ : أَرَاہَا فِیہِنَّ۔",,,17579 17580,"حَدَّثَنَا عَفَّانُ قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ قَالَ : أَخْبَرَنَا دَاوُد ، عَنِ الشَّعْبِیِّ ، وَعِکْرِمَۃَ فِی ہَذِہِ : {وَلاَ یُبْدِینَ زِینَتَہُنَّ إلاَّ لِبُعُولَتِہِنَّ ، أَوْ آبَائِہِنَّ ، أَوْ آبَائِ بُعُولَتِہِنَّ} حَتَّی فَرَغَ مِنْہَا قَالاَ : لَمْ یُذْکَرَ الْعَمُّ وَالْخَالُ لأَنَّہُمَا ینعتان لأَبْنَائِہِمَا وَقَالاَ : لاَ تَضَعُ خِمَارَہَا عِنْدَ الْعَمِّ وَالْخَالِ۔",,,17580 17581,حَدَّثَنَا عَبَّادُ بْنُ العَوَّامِ ، عَنْ صَخْرِ بْنُ جُوَیْرِیَۃَ ، عَنْ نَافِعٍ أَنَّ ابْنَ عُمَرَ سُئِلَ عَنِ امْرَأَۃٍ أَحَلَّتْ جَارِیَتَہَا لِزَوْجِہَا ، فَقَالَ ابْنُ عُمَرَ لاَ أَدْرِی ، لَعَلَّ ہَذَا لَوْ کَانَ عَلَی عَہْدِ عُمَرَ لَرَجَمَہُ ، إنَّہَا لاَ تَحِلُّ لَکَ جَارِیَۃٌ إلاَّ جَارِیَۃً إِنْ شِئْتَ بِعْتہَا ، وَإِنْ شِئْتَ أَعْتَقْتہَا ، وَإِنْ شِئْتَ وَہَبْتہَا ، وَإِنْ شِئْتَ أَنْکَحْتہَا مَنْ شِئْت۔,,,17581 17582,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ قَالَ : لاَ یَحِلُّ فَرْجٌ إلاَّ بِمِلْکٍ ، أَوْ نِکَاحٍ ، إِنْ طَلَّقَ جَازَ ، وَإِنْ أَعْتَقَ جَازَ ، وَإِنْ وَہَبَ جَازَ۔",,,17582 17583,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : سَأَلْتُہ عَنِ امْرَأَۃٍ تُحِلُّ وَلِیدَتَہَا لابْنِہَا قَالَ : لاَ تَحِلُّ لَہُ إلاَّ بِنِکَاحٍ ، أَوْ بِہِبَۃٍ ، أَوْ بِشِرَائٍ۔",,,17583 17584,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ قَالَ : لاَ یُعَارُ الْفَرْجُ ، وَإِنْ وَقَعَ عَلَیْہَا فَہِیَ لَہُ۔",,,17584 17585,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ فِی الرَّجُلِ قَالَ لآخَرَ : جَارِیَتِی لَکَ تَطَؤُہَا فَإِنْ حَمَلَتْ فَہِیَ لَکَ ، وَإِنْ لَمْ تَحْمِلْ رَدَدْتہَا عَلَیَّ ، قَالَ : إذَا وَطِئَہَا فَہِیَ لَہُ۔",,,17585 17586,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْحَکَمِ وَعَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ قَالاَ : إذَا أُحِلَّ لَہُ فَرْجُہَا فَہِیَ لَہُ۔",,,17586 17587,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنٍ ، عَنْ مُطَرِّفٍ ، عَنْ رَجُلٍ ، عَنْ إبْرَاہِیمَ فِی امْرَأَۃٍ أَحَلَّتْ لِرَجُلٍ جَارِیَتَہَا فَوَلَدَتْ مِنْہُ ، فَقَالَ إبْرَاہِیمُ : ہَذَا فَرْجٌ أَتَاہُ بِجَہَالَۃٍ فَأُلْحِقْ بِہِ الْوَلَدَ وَادْفَعْ إلَی ہَذِہِ وَلِیدَتَہَا۔",,,17587 17588,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ یَزِیدَ بْنِ إبْرَاہِیمَ ، عَنْ أَیُّوبَ ، عَنِ ابْنِ سِیرِینَ قَالَ : الْفَرْجُ لاَ یُعَارُ۔",,,17588 17589,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ قَالَ : حدَّثَنِی مُوسَی بْنُ خَیْشُومٍ قَالَ سَأَلَ عِکْرِمَۃَ رَجُلٌ قَالَ : أَمَۃٌ لِصَاحِبَتِی أَحَلَّتْہَا لِی قَالَ : لاَ تَحِلُّ لَکَ إلاَّ أَنْ تَمْلِکَ رَقَبَتَہَا۔",,,17589 17590,حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یَقَعُ عَلَی مُکَاتَبَتِہِ قَالَ یَحسبُ لَہَا صَدَاقُ مِثْلِہَا۔,,,17590 17591,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ مُطَرِّفٍ ، عَنِ الْحَکَمِ قَالَ : إذَا غَشِیَ مُکَاتَبَتَہُ فَہِیَ أُمُّ وَلَدِہِ۔",,,17591 17592,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنِ الدَّسْتَوَائِیِّ ، عَنْ قَتَادَۃَ فِی رَجُل وَطِیئَ مُکَاتَبَتَہُ قَالَ إِنْ کَانَ اسْتَکْرَہَہَا فَعَلَیْہِ الْعُقْرُ وَالْحَدُّ ، وَإِنْ کَانَتْ طَاوَعَتْہُ فَعَلَیْہِ الْحَدُّ وَلَیْسَ عَلَیْہِ الْعُقْرُ۔,,,17592 17593,"حَدَّثَنَا ابْنُ إدْرِیسَ قَالَ: کَانَ ابْنُ أَبِی لَیْلَی یَقُولُ: تَعُودُ الْمُکَاتَبَۃُ فَتَکُونُ أُمَّ وَلَدٍ یَعْنِی إذَا وَطِئَہَا فَوَلَدَتْ۔",,,17593 17594,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ فِی الرَّجُلِ یُکَاتِبُ امْرَأَتَہُ وَیَشْتَرِطُ عَلَیْہَا فِی الْمُکَاتَبَۃِ أَنْ یَطَأَہَا قَالَ : لاَ بَأْسَ بِہِ ، لَہُ شَرْطُہُ وَلَہُ أَنْ یَطَأَہَا۔",,,17594 17595,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْن أَبِی خَالِدٍ ، عَنِ الشَّعْبِیِّ فِی رَجُلٍ وَطِیئَ مُکَاتَبَتَہُ ، فَقَالَ : مَا رَقَّ مِنْہَا مہر لِمَا أُعْتِقَ مِنْہَا۔",,,17595 17596,"حدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ جَابِرٍ ، عَنِ الشَّعْبِیِّ قَالَ : لَیْسَ عَلَی زَانٍ عُقْرٌ۔",,,17596 17597,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ قَالَ : سَأَلْتُ الْحَکَمَ وَحَمَّادًا ، عَنْ عَبْدِ رَجُلٍ اسْتَکْرَہَ حُرَّۃً قَالاَ: لاَ عُقْرَ عَلَیْہِ، لاَ یَضُرُّک حُرَّۃً کَانَتْ ، أَوْ أَمَۃً۔",,,17597 17598,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ وَعَنْ رَجُلٍ ، عَنِ الزُّہْرِیِّ قَالاَ : إِنْ کَانَتْ بِکْرًا فَالْعُقْرُ وَالْحَدُّ ، وَإِنْ کَانَتْ ثَیِّبًا فَالْحَدُّ۔",,,17598 17599,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی حَنِیفَۃَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ قَالَ : لاَ یَجْتَمِعُ حَدٌّ وَلاَ صَدَاقٌ عَلَی زَانٍ۔",,,17599 17600,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، عَنْ إبْرَاہِیمَ قَالَ : إذَا أَوْقَعْتُ عَلَیْہِ الْحَدَّ لَمْ آخُذْ مِنْہُ الْعُقْرَ۔",,,17600 17601,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ یَزِیْدَ بْنِ مُعْنِق قَالَ : قَالَ ابْنُ عُمَرَ : لأَنْ یجعل فِی رَأْسِی مِخْیَطٌ حَتَّی یخبو أَحَبُّ إلَیَّ مِنْ أَنْ تُقَبِّلَ رَأْسِی امْرَأَۃٌ لَیْسَتْ بِمَحْرَمٍ۔",,,17601 17602,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ قَالَ : لأَنْ یثقب القمل دِمَاغ رَجُلٍ خَیْرٌ لَہُ مِنْ أَنْ تُفَلیہ امْرَأَۃٌ یَحِلُّ لَہُ نِکَاحُہَا ، قَالَ : وَذَکَرَ أَنَّ امْرَأَۃً کَانَتْ تُفَلِّی مَرَّۃ رَجُلاً فَقَبَّلَتْہُ۔",,,17602 17603,"حَدَّثَنَا غُنْدَرٌ ، عَنْ عُثْمَانَ بْنِ غِیَاثٍ ، قَالَ : سَمِعْتُ الْحَسَنَ یَقُولُ : لاَ یَحِلُّ لِأَمْرَأَۃٍ تَغْسِلُ رَأْسَ رَجُلٍ لَیْسَ بَیْنَہَا وَبَیْنَہُ مَحْرَمٌ۔",,,17603 17604,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ بَشِیرِ بْنِ عُقْبَۃَ قَالَ : حدَّثَنِی یَزِیدُ بْنُ عَبْدِ اللہِ بْنِ الشِّخِّیرِ ، عَنْ مَعْقِلِ بْنِ یَسَارٍ قَالَ : لأَنْ یَعْمِدَ أَحَدُکُمْ إلَی مِخْیَطٍ فَیَغْرِزُ بِہِ فِی رَأْسِی أَحَبُّ إلَیَّ مِنْ أَنْ تَغْسِلَ رَأْسِی امْرَأَۃٌ لَیْسَتْ مِنِّی ذَاتَ مَحْرَمٍ۔",,,17604 17605,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ شُعْبَۃَ ، قَالَ : سَمِعْتُ قَتَادَۃَ یَقُولُ : سَافَرْت مَعَ امْرَأَۃٍ إلَی مَکَّۃَ نَصَفَ وَإِنَّ فِیہَا لَبَقیۃً فَکَانَتْ تَغْسِلُ رَأْسِی ، أَوْ تُفَلِّی رَأْسِی۔",,,17605 17606,"حَدَّثَنَا عُبَیْدُ اللہِ ، عَنْ سُفْیَانَ ، عَنْ قَیْسِ بْنِ مُسْلِمٍ ، عَنْ طَارِقِ بْنِ شِہَابٍ ، عَنْ أَبِی مُوسَی قَالَ : أَتَیْتُ امْرَأَۃً مِنْ قَوْمِی فَغَسَلَتْ ثِیَابِی وَمَشَطَتْ رَأْسِی۔",,,17606 17607,"حدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ عَنِ الْحَسَنِ فِی الرَّجُلِ یَتَزَوَّجُ الأَمَۃَ قَالَ : لَیْسَ لَہُ أَنْ یُخْرِجَہَا مِنَ المِصْرِ۔",,,17607 17608,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ مُبَارَکٍ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ عَطَائٍ وَمَکْحُولٍ قَالاَ : لَیْسَ لَہُمْ بُدٌّ من أَنْ یَسْتَخْدِمُوہَا۔",,,17608 17609,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ أَیُّوبَ بْنِ مُوسَی ، عَنِ ابْنِ قُسَیْطٍ أَنَّ سعِیدَ بْنَ الْمُسَیَّبِ سُئِلَ عَنْ رَجُلٍ بُشِّرَ بِجَارِیَۃٍ ، فَقَالَ بَعْضُ الْقَوْمِ : ہَبْہَا لِی ، فَقَالَ سَعِیدُ بْنُ الْمُسَیَّبِ ، لَمْ تَحِلَّ الْمَوْہُوبَۃُ لأَحَدٍ بَعْدَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَلَوْ أَصْدَقَہَا سَوْطًا حَلَّتْ لَہُ",,,17609 17610,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ زَمْعَۃَ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ قَالَ : لاَ یَحِلُّ لأَحَدٍ أَنْ یَہَبَ ابْنَتَہُ بِغَیْرِ مَہْرٍ إلاَّ لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,17610 17611,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ قَالَ : سَأَلْتُ الْحَکَمَ وَحَمَّادًا ، عَنْ رَجُلٍ وَہَبَ ابْنَتَہُ لِرَجُلٍ فَقَالاَ : لاَ یَجُوزُ إلاَّ بِصَدَاقٍ۔",,,17611 17612,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ عُبیدِ اللہِ بْنِ عُبَیْدٍ قَالَ : سُئِلَ مَکْحُولٌ ، عَنِ الرَّجُلِ یَہَبُ أُخْتَہُ ، أَوِ ابْنَتَہُ لِلرَّجُل وَلاَ یَفْرِضُ لَہَا صَدَاقًا ، فَقَالَ مَکْحُولٌ وَالزُّہْرِیُّ : لَمْ تَحِلَّ الْمَوْہُوبَۃُ لأَحَدٍ بَعْدَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,17612 17613,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ مُحَمَّدِ بْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ قَالَ : أَیُّمَا امْرَأَۃٍ وَہَبَہَا أَبُوہَا لِرَجُلٍ ، أَوْ وَہَبَتْ نَفْسَہَا لِرَجُلٍ فَلَہَا مہر مِثْلُہَا إِنْ دَخَلَ بِہَا ، وَإِلاَّ فَإِنَّمَا عَلَیْہِ الْمُتْعَۃُ إِنْ طَلَّقَہَا قَبْلَ أَنْ یَدْخُلَ بِہَا۔",,,17613 17614,"حَدَّثَنَا عَبِیْدَۃُ بْنُ حُمَیْدٍ ، عَنْ عَبْدِ الْمَلِکِ قَالَ : سُئِلَ عَطَائٌ ، عَنِ امْرَأَۃٍ وَہَبَتْ نَفْسَہَا لِرَجُلٍ قَالَ : لاَ یَکُونُ إلاَّ بِصَدَاقٍ۔",,,17614 17615,"حَدَّثَنَا عَبدَۃ بْنُ سُلَیْمَانَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ أَنَّہَا قَالَتْ : مَا تَسْتَحِی امْرَأَۃٌ أَنْ تَہَبَ نَفْسَہَا لِرَجُلٍ حَتَّی أَنْزَلَ اللَّہُ تَعَالَی : {تُرْجِی مَنْ تَشَائُ مِنْہُنَّ وَتُؤْوِی إلَیْک مَنْ تَشَائُ} قَالَتْ : فَقُلْتُ: إنَّ رَبَّک لَیُسَارِعُ لَکَ فِی ہَوَاک۔ (بخاری 5113۔ مسلم 50)",,,17615 17616,"حَدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ فِی امْرَأَۃٍ وَہَبَتْ نَفْسَہَا لِرجُلٍ ، فَقَالَ : لاَ یَصْلُحُ إلاَّ بِصَدَاقٍ ، لَمْ یَکُنْ ذَلِکَ إلاَّ لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,17616 17617,"حَدَّثَنَا ہُشَیْم ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ فِیْمَنْ تَزَوَّجَ ذَاتَ مَحْرَمٍ مِنْہُ فَدَخَلَ بَہَا قَالَ : لَہَا الصَّدَاقُ",,,17617 17618,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ أنہ قَالَ : لَہَا مَا أَخَذَتْ۔",,,17618 17619,حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ حَمَّادٍ مِثْلَہُ۔,,,17619 17620,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ قَالَ : لاَ صَدَاقَ لَہَا دَخَلَ بِہَا ، أَوْ لَمْ یَدْخُلْ بِہَا ، أَیَصْدُقُ الرَّجُلُ أُخْتَہُ ، أَوْ أُمَّہُ ؟۔",,,17620 17621,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ فِی رَجُلٍ تَزَوَّجَ أُخْتَہُ فِی الرَّضَاعَۃِ وَہُوَ لاَ یَعْلَمُ ثُمَّ عَلِمَ بَعْدَ ذَلِکَ قَالَ : بَطَلَ النِّکَاحُ فَإِنْ دَخَلَ بِہَا فَلَہَا الصَّدَاقُ بِمَا اسْتَحَلَّ مِنْ فَرْجِہَا ، وَإِنْ لَمْ یَکُنْ دَخَلَ بِہَا فُرِّقَ بَیْنَہُمَا وَلاَ صَدَاقَ۔",,,17621 17622,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ مَطَرٍ ، عَنِ الْحَکَمِ فِی رَجُلٍ تَزَوَّجَ أُخْتَہُ ، أَوْ أُخْتَ امْرَأَتِہِ مِنَ الرَّضَاعَۃِ فَدَخَلَ بِہَا وَہُوَ لاَ یَشْعُرُ قَالَ : لَہَا الصَّدَاقُ کَامِلاً",,,17622 17623,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ مَطَرٍ ، عَنِ الْحَسَنِ قَالَ : لَہَا الصَّدَاقُ بما أحدث",,,17623 17624,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ حَمَّادٍ قَالَ : کُلُّ جِمَاعٍ دُرِئَ فِیہِ الْحَدُّ فَفِیہِ الصَّدَاقُ کَامِلاً۔",,,17624 17625,"حَدَّثَنَا عُمَرُ بْنُ ہَارُونَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ فِی رَجُلٍ تَزَوَّجَ امْرَأَۃً فَإِذَا ہِیَ أُخْتُہُ مِنَ الرَّضَاعَۃِ فَأَصَابَہَا وَلَمْ یَشْعُرْ بِہَا قَالَ : یُفَرَّقُ بَیْنَہُمَا وَلَیْسَ لَہَا الصَّدَاقُ کُلُّہُ ، لَہَا بَعْضُہُ۔",,,17625 17626,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیْمَ ، عَنِ الأَسْوَدِ ، عَنْ عَائِشَۃَ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ تَزَوَّجَہَا وَہِیَ ابْنَۃُ تِسْعٍ وَمَاتَ عَنْہَا وَہِیَ ابْنَۃُ ثَمَانَ عَشَرَۃَ۔ (مسلم 72۔ احمد 42),,,17626 17627,حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ أَنَّ الزُّبَیْرَ زَوَّجَ ابْنَۃً لَہُ صَغِیرَۃً حِینَ نُفِسَتْ یَعْنِی حِینَ وُلِدَتْ۔,,,17627 17628,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ أَنَّہُ زَوَّجَ ابْنًا لَہُ ابْنَۃً لِمُصْعَبٍ صَغِیرَۃً۔,,,17628 17629,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، أَنَّ عُمَرَ خَطَبَ إلَی عَلِیٍّ ابْنَتَہُ أُمَّ کُلْثُومٍ ، فَقَالَ عَلِیٌّ : إنَّہَا صَغِیرَۃٌ فَانْظُرْ إلَیْہَا ، فَأَرْسَلَہَا إلَیْہِ بِرِسَالَۃٍ فَمَازَحَہَا ، فَقَالَتْ : لَوْلاَ أَنَّک شَیْخٌ ، أَوْ لَوْلاَ أَنَّک أَمِیرُ الْمُؤْمِنِینَ فَأَعْجَبَ عُمَرَ مُصَاہَرَتُہُ فَخَطَبَہَا فَأَنْکَحَہَا إیَّاہُ۔",,,17629 17630,حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ، عَنِ ابْنِ جُرَیْجٍ، عَنِ ابْنِ طَاوُوسٍ، عَنْ أَبِیہِ أَنَّہُ کَانَ یَکْرَہُ نِکَاحَ الصَّغِیرَیْنِ۔,,,17630 17631,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ قَالَ : کَانَ الحسن لاَ یُعْجِبُہُ نِکَاحُ الصِّغَارِ۔",,,17631 17632,"حَدَّثَنَا مُحَمَّدُ بِنُ فُضَیْلٍ ، عَنْ یَزِیْدَ بِنْ أَبِی زِیَادٍ ، عَنْ زَیْدٍ بِنْ وَہْبٍ قَالَ : کَتَبَ إلَیْنَا عُمَرُ إِنَّ الأَعْرَابِیَّ لاَ یَنْکِحُ الْمُہَاجِرَۃَ ، یُخْرِجَہَا مِنْ دَارِ الْہِجْرَۃِ۔",,,17632 17633,حَدَّثَنَا عَبَّادُ بِنَ العَوَّامِ ، عَنْ ہِشَامٍ ، عَنِ الحَسَنِ أَنَّہُ کَرِہَ أَنْ یَتَزَوَّجَ الأَعْرَابِیُّ المُہَاجِرَۃَ,,,17633 17634,حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ مُحَمَّدٍ بِنْ سَالِمٍ ، عَنِ الشَّعْبِیِّ أَنَّہُ کَرِہَ أَنْ یَتَزَوَّجَ الأَعْرَابِیُّ المُہَاجِرَۃَ لِیُخْرِجَہَا مِنَ المِصْرِ۔,,,17634 17635,"حَدَّثَنَا عَبِیْدَۃُ بِنْ حُمَیْدٍ ، عَنِ الرَّکِیْنِ ، عَنْ أَبِیہِ قَالَ : خَطَبَ مَنْظُوْرُ بِنْ زَبَّان إِلَی خَالِہِ وَکَانَا حَاجَّیْنِ ، أَوْ مُعْتَمِرَیْنِ فَقَالَ : نَعَمْ إَذَا رَجَعْتُ أَنْکَحْتُکَ ، فَخَرَجَ إِلَیْہَا أَخُوْہَاَ ابْنُ أُمِّہَا وَأَبِیْہَا فَأَنْکَحَہَا ابْنَ خَالِہَا فَقَدِمَ وَقَد أنکحت ، فَغَضِبَ أَبُوہَا غَضَبًا شَدِیْدًا وَقَالَ : إِنِّی أبرأ إِلَی اللہِ مِنْ ہَذَا النِّکَاحِ ، إِنِّی سَمِعْتُ عُمَرَ یَقُوْلُ : لاَ یُنْکَحُ المُہَاجِرَاتُ الأَعْرَابَ۔",,,17635 17636,"حَدَّثَنَا ابْنُ إدْرِیس ، عَنِ ابْنِ جُرَیْجٍ ، عن الزہری ، عَنْ عَمْرِو بْنِ الشَّرِیدِ قَالَ : سُئِلَ ابْنُ عَبَّاسٍ ، عَنْ رَجُلٍ لَہُ امْرَأَۃٌ وَسُرِّیَّۃٌ ولدت إحْدَاہُمَا غُلاَمًا وَأَرْضَعَتْ إحْدَاہُمَا جَارِیَۃً ہَلْ یَصْلُحُ لِلْغُلاَمِ أَنْ یَتَزَوَّجَ الْجَارِیَۃَ ؟ قَالَ : لاَ ، اللِّقَاحُ وَاحِدٌ۔",,,17636 17637,حَدَّثَنَا ہُشَیْمٌ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنْ مُجَاہِدٍ أَنَّہُ کَرِہَ لَبَنَ الْفَحْلِ وَکَرِہَ قَوْلَ إبْرَاہِیمَ فِیہِ۔,,,17637 17638,حَدَّثَنَا ہُشَیْمٌ ، وَابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ أَنَّہُ کَرِہَہُ یَعْنِی لَبَنَ الْفَحْلِ,,,17638 17639,حَدَّثَنَا ہُشَیْمٌ ، عَنْ عَبْدِ اللہِ بْنِ سَبْرَۃَ ، عَنِ الشَّعْبِیِّ ، أَنَّہُ کَرِہَہُ۔,,,17639 17640,"حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ قَالَ : کَانَ یَرَی لَبَنَ الْفَحْلِ یُحَرِّم۔",,,17640 17641,حَدَّثَنَا وَکِیعٌ ، عَنْ سفیان ، عَنْ خُصَیْفٍ ، عَنْ سَالِمٍ أنَّہُ کَرِہَہُ۔,,,17641 17642,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَبَّادِ بْنِ مَنْصُورٍ قَالَ : سَأَلْتُ الْقَاسِمَ بْنَ مُحَمَّدٍ : قُلْتُ امْرَأَۃ أَبِی أَرْضَعَتْ جَارِیَۃً مِنْ عَرَضِ النَّاسِ بِلِبَانِ إخْوَتِی مِنْ أَبِی ، تَحِلُّ لِی ؟ قَالَ : لاَ ، أَبُوک أَبُوہَا ، وَسَأَلْت طَاوُوسًا ، فَقَالَ مِثْلَ ذَلِکَ وَسَأَلْت الْحَسَنَ ، فَقَالَ مِثْلَ ذَلِکَ وَسَأَلْت مُجَاہِدًا ، فَقَالَ : اخْتَلَفَ فِیہِ النَّاسُ وَلاَ أَقُولُ فِیہَا شَیْئًا وَسَأَلْت ابْنَ سِیرِینَ ، فَقَالَ مِثْلَ قَوْلِ مُجَاہِدٍ۔",,,17642 17643,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ قَالَ : ذَکَرْت ذَلِکَ لِمُحَمَّدِ بْنِ سِیرِینَ ، فَقَالَ نُبِّئْت أَنَّ أُنَاسًا مِنْ أَہْلِ الْمَدِینَۃِ اخْتَلَفُوا فِیہِ فَمِنْہُمْ مَنْ کَرِہَہُ وَمِنْہُمْ مَنْ لَمْ یَکْرَہْہُ وَمَنْ کَرِہَ أَفْضَلُ فِی أَنْفُسِنَا مِمَّنْ لَمْ یَکْرَہْہُ ، وَکَانَ الْقَاسِمُ بْنُ مُحَمَّدٍ فِیمَنْ یَکْرَہُہُ۔",,,17643 17644,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو قَالَ : قدِمَ الزُّہْرِیُّ المدینۃ فِی أَوَّلِ خِلاَفَۃِ ہِشَامٍ فَذَکَرَ أَنَّ عُرْوَۃَ کَانَ یُحَدِّثُ ، عَنْ عَائِشَۃَ أَنَّ أَبَا الْقُعَیْسِ جَائَ یَسْتَأْذِنُ عَلَی عَائِشَۃَ وَقَدْ أَرْضَعَتْہُمَا امْرَأَۃُ أَخِیہِ فَأَبَتْ أَنْ تَأْذَنَ لَہُ فَزَعَمَ عُرْوَۃُ أَنَّ عَائِشَۃَ ذَکَرَتْ ذَلِکَ لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : فَہَلاَّ أَذِنْت لَہُ ؟ فَإِنَّ الرَّضَاعَۃَ تُحَرِّمُ مَا تُحَرِّمُ الْوِلاَدَۃُ فَفَزِعَ أَہْلُ الْمَدِینَۃِ لِذَلِکَ فَطَلَّقَ عَبْدُ اللہِ بْنُ أَبِی حَبِیبَۃَ مَوْلَی الزُّبَیْرِ امْرَأَتَہُ عِنْدَ ذَلِکَ۔",,,17644 17645,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ قَالَ : ذُکِرَ لَبَنُ الْفَحْلِ ، فَقَالَ وَقَدْ کَرِہَہُ أُنَاسٌ وَرَخَّصَ فِیہِ أُنَاسٌ ، فَکَانَ مَنْ کَرِہَہُ عِنْدَ النَّاسِ أَفْضَلُ ، وَکَانَ الْقَاسِمُ بْنُ مُحَمَّدٍ مِمَّنْ کَرِہَہُ۔",,,17645 17646,حَدَّثَنَا مَالِکٌ ، عَنْ حَمَّادِ بْنِ زَیْدٍ ، عَنْ ہِشَامٍ أَنَّ أَبَاہُ کَرِہَ لَبَنَ الْفَحْلِ۔,,,17646 17647,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ أَبِی عُبَیدَۃَ بْنِ عَبْدِ اللہِ بْنِ زَمْعَۃَ عَن أُمِہ زَینَب ابنَۃ أَبِی سَلَمَۃَ قَالَت : کَانَتْ أَسْمَائُ أَرْضَعَتْنِی ، وَکَانَ الزُّبَیْرُ یَدْخُلُ عَلَیَّ وَأَنَا أَمْتَشِطُ وَیَأْخُذُ الْقَرْنَ مِنْ قُرُونِی وَیَقُولُ : أَقْبِلِی عَلیَّ فحدثنی بربی أنَّہُ أَبِی وَأن مَا وَلَدَ إخْوَتِی ، فَلَمَّا کَانَ یوم الْحَرَّۃِ أَرْسَلَ عَبْدُ اللہِ بْنُ الزُّبَیْرِ یَخْطُبُ ابْنَتِی عَلَی حَمْزَۃَ بن الزُّبَیْر وَحَمْزَۃُ وَمُصْعَبٌ لِلْکَلْبِیَّۃِ فَأَرْسَلْت إلَیْہِ : ہَلْ تَصْلُحُ لَہُ ؟ فَأَرْسَلَ إلَیَّ : إنَّمَا تُرِیدِینَ مَنْعِی بِنْتَکِ وَأَنَا أَخُوک ، وَمَا وَلَدَتْ أَسْمَائُ فَہُمْ إخْوَتُک وما وَلَدُ الزُّبَیْرِ لِغَیْرِ أَسْمَائَ فَلَیْسَ لَکَ بِإِخْوَۃٍ فَأَرْسِلِی فَسَلِی فَأَرْسَلْتُ فَسَأَلْتُ وَأَصْحَابُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مُتَوَافِرُونَ وَأُمَّہَاتُ الْمُؤْمِنِینَ فَقَالُوا : إنَّ الرَّضَاعَۃَ مِنْ قِبَلِ الرِّجَالِ لاَ تُحَرِّمُ شَیْئًا۔",,,17647 17648,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ یَزِیدَ بْنِ عَبْدِ اللہِ بْنِ قُسَیْطٍ قَالَ : سَأَلْتُ أَبَا سَلَمَۃَ بْنَ عَبْدِ الرَّحْمَنِ وَسَعِیدَ بْنَ الْمُسَیَّبِ وَعَطَائً وَسُلَیْمَانَ ابْنَی یَسَارٍ ، عَنِ الرَّضَاعَۃِ مِنْ قِبَلِ الرِّجَالِ فَقَالُوا : لاَ تُحَرِّمُ شَیْئًا۔",,,17648 17649,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو قَالَ : حدَّثَنِی آل رَافِعِ بْنِ خَدِیجٍ أَنَّ رَافِعَ بْنَ خَدِیجٍ زَوَّجَ ابْنَتَہُ ابْنَ أَخِیہِ رِفَاعَۃَ بْنِ خَدِیجٍ وَقَدْ أَرْضَعَتْہَا أُمُّ وَلَدٍ لَہُ سِوَی أُمِّ ابنہِ الَّذِی أَنْکَحَہَا إیَّاہُ۔",,,17649 17650,حَدَّثَنَا شَرِیکٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ وَعَنْ جَابِرٍ ، عَنْ عَامِرٍ أَنَّہُمَا کَانَا لاَ یَرَیَانِ لَبَنَ الْفَحْلِ شَیْئًا۔,,,17650 17651,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ ، عَنْ أَبِی قِلاَبَۃَ أَنَّہُ لَمْ یَرَ بِلَبَنِ الْفَحْلِ بَأْسًا۔,,,17651 17652,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ قَالَ : أَوَّلُ مَا سَمِعْت بِلَبَنِ الْفَحْلِ وَنَحْنُ بِمَکَّۃَ فَجَعَلَ إیَاسُ بْنُ مُعَاوِیَۃَ یَقُولُ : وَمَا بَأْسُ ہَذَا وَمَنْ یَکْرَہُ ہَذَا ؟۔",,,17652 17653,حَدَّثَنَا ہُشَیْمٌ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ کَانَ لاَ یَرَی لَبَنَ الْفَحْلِ شَیْئًا۔,,,17653 17654,حَدَّثَنَا عُبَید اللہِ بْنُ مُوسَی ، عَنْ مُحَمَّدِ بْنِ رَاشِدٍ ، عَنْ مَکْحُولٍ أَنَّہُ کَانَ لاَ یَرَی بِلَبَنِ الْفَحْلِ بَأْسًا۔,,,17654 17655,حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَہْلِ بْنِ سَعْدٍ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَرَّقَ بَیْنَ الْمُتَلاَعِنَیْنِ وَقَالَ حسَابُکُمَا عَلَی اللہِ۔ (بخاری 6854۔ ابوداؤد 2245),,,17655 17656,حَدَّثَنَا یَزِیدُ ، عَنْ عَبَّادِ بْنِ مَنْصُورٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَرَّقَ بَیْنَہُمَا وَقَضَی أَنْ لاَ قُوتَ لَہا عَلَیہ وَلاَ نَفَقَۃَ۔ (ابوداؤد 2250۔ طیالسی 2667),,,17656 17657,"حَدَّثَنَا حَفْصٌ، عَنِ الأَعْمَشِ، عَنْ إبْرَاہِیمَ، عَنْ عُمَرَ، قَالَ: الْمُتَلاَعِنَانِ یُفَرَّقُ بَیْنَہُمَا وَلاَ یَجْتَمِعَانِ أَبَدًا۔",,,17657 17658,"حَدَّثَنَا وَکِیعٌ، عَنْ قَیْسٍ ، عَنْ عَاصِمٍ ، عَنْ زِرٍّ ، عَنْ عَلِیٍّ وعَنْ أَبِی وَائِلٍ ، عَنْ عَبْدِ اللہِ قَالاَ: لاَ یَجْتَمِعَا الْمُتَلاَعِنَانِ أَبَدًا۔",,,17658 17659,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ قَالَ : الْمُتَلاَعِنَانِ لاَ یَجْتَمِعَا فِی مِصْرٍ۔",,,17659 17660,"حَدَّثَنَا حَفْصٌ قَالَ : سَأَلْتُ عَمرًا ، فَقَالَ : کَانَ الْحَسَنُ یُفَرِّقُ بَیْنَہُمَا فَلاَ یَجْتَمِعَانِ أَبَدًا",,,17660 17661,"حَدَّثَنَا جَرِیرٌ عَن مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : إذَا لاَعَنَ الرَّجُلُ امْرَأَتَہُ فُرِّقَ بَیْنَہُمَا فَلاَ یَجْتَمِعَانِ أَبَدًا۔",,,17661 17662,"حَدَّثَنَا یَزِیدُ ، عَنْ حَبِیبٍ ، عَنْ عَمْرِو بْنِ ہَرِمٍ ، عَنْ جَابِرِ بْنِ زَیْدٍ قَالَ : لاَ یَجْتَمِعَانِ۔",,,17662 17663,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ زَمْعَۃَ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ قَالَ : لاَ یَجْتَمِعَانِ۔",,,17663 17664,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ حَسَنٍ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ قَالَ : لاَ یَجْتَمِعَانِ۔",,,17664 17665,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنِ الشَّعْبِیِّ قَالَ : الْمُتَلاَعِنَانِ لاَ یَجْتَمِعَانِ۔",,,17665 17666,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ ابْنِ إِسْحَاقَ ، عَنِ ابْنِ شِہَابٍ قَالَ : مَضَتِ السُّنَّۃُ أَنَّہُمَا إذَا فُرِّقَ بَیْنَہُمَا لَمْ یَجْتَمِعَا أَبَدًا۔",,,17666 17667,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ قَالَ : فِی رَجُلٍ لاَعَنَ ثُمَّ أَکْذَبَ نَفْسَہُ فِی الْعِدَّۃِ قَالَ : إذَا لاَعَنَ انْقَطَعَ مَا بَیْنَہُمَا۔",,,17667 17668,"حدَّثَنَا حَفْصٌ، عَنْ دَاوُدَ، عَنِ سَعِیدِ بْنِ الْمُسَیَّبِ فِیَ المُلاَعِنِ یُکَذِّبُ نَفْسَہُ قَالَ: یُضْرَبُ وَہُوَ خَاطِب۔",,,17668 17669,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ مُطَرِّفٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : إِنْ أَکْذَبَ نَفْسَہُ جُلِدَ وَأُلْزِقَ بِہِ الْوَلَدُ وَرُدَّتْ إلَیْہِ امْرَأَتُہُ۔",,,17669 17670,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ حَمَّادٍ أَنہ سُئِلَ عَنِ الْمُتَلاَعِنَیْنِ ، فَقَالَ : یَتَزَوَّجُہَا إِنْ أَکْذَبَ نَفْسَہُ۔",,,17670 17671,"حدَّثَنَا ابْنُ عُیَیْنَۃَ، عَنْ عَمْرٍو، عَنْ سَعَیْدِ بِنْ جُبَیْرٍ، عَنِ ابْنِ عُمَرَ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَرَّقَ بَیْنَ المُتَلاَعِنَیْنِ وَقَالَ : حِسَابُکُمَا عَلَی اللہِ ، أَحَدُکُمَا کَاذِبٌ لاَ سَبِیْلَ لَکَ عَلَیْہَا فَقَالَ : یَا رَسُوْلَ اللہِ! فَمَالِی؟ قَالَ: لاَ مَالَ لَکَ ، إِنْ کُنْتَ صَادِقَاً فَہُوَ بِمَا اسْتَحْلَلْتَ مِنْ فَرْجِہَا ، وَإِنْ کُنْتَ کَاذِبَاً فَذَلِکَ أَبْعَدُ لَکَ۔\n\n(بخاری 5350۔ مسلم 5)",,,17671 17672,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ دَاوُدَ ، عَنْ سَعِیْدِ بِنِ جُبَیْرٍ أَنَّہُ فَرَّقَ بَیْنَ المُتَلاَعِنَیْنِ قَالَ : فَتَعَلَّقَ بِہَا فَقَالَ : مَالِی ، فَقُلْتُ لاَ مَالَ لَکَ ، قَالَ : فَانْطَلَقَ إِلَی أَبِی بُرْدَۃَ وَقَالَ : یَذْہَبُ مَالِی وَامْرَأَتِی جَمِیعًا ؟ قَالَ : لاَ ، قَالَ : إِنَّ الَّذِی أَمَرْتَہُ أَنْ یُلاَعِنَ بَیْنَنَا قَالَ لاَ شَیْئَ لَکَ ، قَالَ : وَفَعَلَ ذَلِکَ ؟ قَالَ : نَعَمْ! قَالَ : فَجِئْتُ قَالَ : فَقَالَ أَبُو بُرْدَۃَ : مَا یَقُوْلُ ہَذَا ؟ قَالَ : قُلْتُ : وَمَا یَقُوْلُ ؟ قَالَ : یَقُوْلُ : ذَہَبَتِ امْرَأَتُہُ وَمَالُہُ ، قَالَ : قُلْتُ : مَا یَحْمِلُ الفُسَّاقَ عَلَی أَنْ یَزْنُوا ؟ یَتَزَوَّجُ المَرْأَۃَ ثُمَّ یَقْذِفُہَا ثُمَّ یُلاَعِنُہَا ویَأْخُذُ مَالَہُ ؟ قَالَ : فَکَتَبَ بِہِ إِلَی الحَجَّاجِ قَالَ : فَقَالَ : صَدَقَ ، قَالَ : ثُمَّ إِنَّ رَجُلاً أَتَانِی ، قَالَ : فَظَنَنْتُ أَنَّ الحَجَّاجَ أَمَرَہُ ، فَقَالَ : الَّذِی قُلْتَ أَشَیْئٌ قُلْتَہُ بِرَأْیِکَ ، أَوْ شَیْئٌ بَلَغَکَ ؟ قُلْتُ : قَضَی بِہِ رَسُوْلُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی أُخْتِ بَنِی العَجْلاَن۔\n\n(بخاری 5349۔ مسلم 4)",,,17672 17673,"حَدَّثَنَا عِیْسَی بْنُ یُوْنُسَ ، عَنِ الأَوْزَاعِیِّ ، عَنْ یَحْیَی بِنْ أَبِی کَثِیْرٍ أَنَّ عَلِیَّاً أُتِیَ فِیَ امْرَأَۃٍ تَزَوَّجَتْ رَجُلاً عَلَی أَنَّ عَلَیْہَا الصَّدَاقَ وبِیَدِہَا الفُرْقَۃُ والجِمَاعُ ، فَقَالَ عَلِیٌّ : خَالَفْتَ السُّنَّۃَ وَوَلَّیْتَ الأَمْرَ غَیْرَ أَہْلِہِ، عَلَیْکَ الصَّدَاقُ وَبِیَدِکَ الجِمَاعُ والفُرْقَۃُ ، وَلَکَ السُّنَّۃُ۔",,,17673 17674,"حَدَّثَنَا غُنْدَرٌ عَنْ أَشْعَثَ ، عَنِ الحَسَنِ قَالَ : لَیْسَ لِلنِّسَائِ أَنْ یَصْدُقْنَ الرِّجَالَ۔",,,17674 17675,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حَمَّادِ بْنِ أبِی الدَّرْدَائِ قَالَ : سَأَلْتُ الشَّعْبِیَّ عَنْ رَجُلٍ زَوَّجَ أُخْتَاً لَہُ بِوَاسِطَۃٍ فَکَرِہَتْ قَالَ: ہِیَ أَحَقُّ بِنَفْسِہَا قُلْتُ: إِنَّہُ أَخُوْہَا لأَبِیْہَا وَأُمِّہَا۔ قَالَ: ہِیَ أَحَقُّ بِنَفْسِہَا مِنْ أَبِیْہَا إِذَا کَرِہَتْ۔",,,17675 17676,"حَدَّثَنَا غُنْدَرٌ ، عَنْ أَشْعَثَ ، عَنِ الحَسَنِ فِی رَجُلٍ زَوَّجَ أُخْتَہُ وأَبُوہَا غَائِبٌ قَالَ : الأَمْرُ إِلَی أَبِیْہَا۔",,,17676 17677,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنْ بَکْرٍ ، عَنِ الْمُغِیرَۃِ بْنِ شُعْبَۃَ قَالَ : خَطَبْت امْرَأَۃً ، فَقَالَ لِی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : ہَلْ نَظَرْت إلَیْہَا ؟ قُلْتُ : لاَ ، قَالَ : فَانْظُرْ إلَیْہَا ، فَإِنَّہُ أَحْرَی أَنْ یُؤْدَمَ بَیْنَکُمَا۔\n\n(ترمذی 1087۔ ابن ماجہ 1865)",,,17677 17678,"حَدَّثَنَا یُونُسُ بن مُحَمَّدٍ قَالَ : حدَّثَنَا عَبْدُ الْوَاحِدِ بْنِ زِیَاد قَالَ : حَدَّثَنَا مُحَمَّدُ بْنُ إِسْحَاقَ ، عَنْ دَاوُدَ بْنِ الْحُصَیْنِ ، عَنْ وَاقِدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ سَعْدِ بْنِ مُعَاذٍ ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا خَطَبَ أَحَدُکُمَ امْرَأَۃً فَإِنِ اسْتَطَاعَ أَنْ یَنْظُرَ مِنْہَا إلَی مَا یَدْعُوہُ إلَی نِکَاحِہَا فَلْیَفْعَلْ فَخَطَبْت جَارِیَۃً مِنْ بَنِی سَلِمَۃَ فَکُنْت أَتَخَبَّأُ تَحْتَ الْکَرَبِ حَتَّی نَظَرْت مِنْہَا إلَی مَا یَدْعُونِی إلَی نِکَاحِہَا فَتَزَوَّجْتہَا۔",,,17678 17679,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ مُحَمَّدِ بْنِ سُلَیْمَانَ ، عَنْ عَمِّہِ سَہْلِ بْنِ أَبِی حَثْمَۃَ ، عَنْ مُحَمَّدِ بْنِ مَسْلَمَۃَ قَالَ : خَطَبْت امْرَأَۃً فَجَعَلْتُ أَتَخَبَّأُ لَہَا حَتَّی نَظَرْت إلَیْہَا فِی نَخْلٍ لَہَا فَقِیلَ لہ: أَتَفْعَلُ ہَذَا وَأَنْتَ صَاحِبُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ قَالَ : فَقُلْتُ : سَمِعْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : إذَا أَلْقَی اللَّہُ فِی قَلْبِ امْرِئٍ مِنْکُمْ خِطْبَۃَ امْرَأَۃٍ فَلاَ بَأْسَ أَنْ یَنْظُرَ إلَیْہَا۔ (طبرانی 500)",,,17679 17680,"حَدَّثَنَا عَبْدُ الرَّزَّاقِ ، عَنْ مَعْمَرٍ ، عَنِ ابن طَاوُوسٍ قَالَ : أَرَدْت أَنْ أَتَزَوَّجَ امْرَأَۃً ، فَقَالَ لِی أَبِی : اذْہَبْ فَانْظُرْ إلَیْہَا قَالَ : فَلَبِسْت وَتَہَیَّأْت فَلَمَّا رَآنِی قَالَ : لاَ تَذْہَبْ۔",,,17680 17681,"حَدَّثَنَا وَکِیعٌ ، عَنْ رَبِیعٍ ، عَنِ الْحَسَنِ قَالَ : لاَ بَأْسَ أَنْ یَنْظُرَ إلَیْہَا قَبْلَ أَنْ یَتَزَوَّجَہَا۔",,,17681 17682,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ زَمْعَۃَ ، عَنِ الزُّہْرِیِّ فِی الرَّجُلِ یَتَزَوَّجُ الْمَرْأَۃَ قَالَ : لاَ بَأْسَ أَنْ یَنْظُرَ إلَیْہَا قَبْلَ أَنْ یَتَزَوَّجَہَا لأَنَّ اللَّہَ عَزَّ وَجَلَّ یَقُولُ : {وَلَوْ أَعْجَبَک حُسْنُہُنَّ}۔",,,17682 17683,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عن سہل بن مُحَمَّدِ بْنِ أَبِی حَثْمَۃَ ، عَنْ عَمِّہِ سلیمان بْنِ أَبِی حَثْمَۃَ قَالَ : رَأَیْتُ مُحَمَّدَ بْنَ مَسْلَمَۃَ یُطَارِدُ نُبَیْتَۃَ بِنْتَ الضَّحَّاکِ وَہِیَ عَلَی إِنْجَارٍ مِنْ أَنَاجِیرِ الْمَدِینَۃِ بِبَصَرِہِ ، فَقُلْتُ : أَتَفْعَلُ ہَذَا ؟ قَالَ : نَعَمْ ، سَمِعْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : إذَا أَلْقَی اللَّہُ فِی قَلْبِ امْرِئٍ خِطْبَۃَ امْرَأَۃٍ فَلاَ بَأْسَ أَنْ یَنْظُرَ إلَیْہَا۔ (ابن حبان 4042)",,,17683 17684,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ قَالَ : سَأَلْتُ عَبِیْدَۃَ ، عَنْ قَوْلِہِ : {فِی یَتَامَی النِّسَائِ اللاَّتِی لاَ تُؤْتُونَہُنَّ مَا کُتِبَ لَہُنَّ وَتَرْغَبُونَ أَنْ تَنْکِحُوہُنَّ} قَالَ : تَرْغَبُونَ فِیہِنَّ۔",,,17684 17685,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنِ الْحَسَنِ ، قَالَ : قَالَ فِی ہَذِہِ : تَرْغَبُونَ عَنْہُنَّ۔",,,17685 17686,"حَدَّثَنَا عَبْدَۃُ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ فِی قَوْلِہِ : {وَمَا یُتْلَی عَلَیْکُمْ فِی الْکِتَابِ فِی یَتَامَی النِّسَائِ اللاَّتِی لاَ تُؤْتُونَہُنَّ مَا کُتِبَ لَہُنَّ وَتَرْغَبُونَ أَنْ تَنْکِحُوہُنَّ} قَالَتْ : أُنْزِلَتْ فِی الْیَتِیمَۃِ تَکُونُ عِنْدَ الرَّجُلِ فَتَشْرَکُہُ فِی مَالِہِ فَیَرْغَبُ عَنْہا أَنْ یَتَزَوَّجَہَا وَیَکْرَہَ أَنْ یَتَزَوَّجَہَا غَیْرُہُ فَیَشْرَکَہُ فِی مَالِہِ فَیَعْضُلَہَا فَلاَ یَتَزَوَّجُہَا وَلاَ یُزَوِّجُہَا غَیْرَہُ۔ (بخاری 5131۔ مسلم 2315)",,,17686 17687,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، عَنْ عُمَرَ ، قَالَ : مَنْ کَانَتْ عِنْدَہُ فِی حِجْرِہِ تَرَکَۃٌ بِہَا عُوَارٌ فَلْیَضُمَّہَا إلَیْہِ ، وَإِنْ کَانَتْ رَغبَۃً بِہِ فَلْیُزَوِّجْہَا غَیْرَہُ۔",,,17687 17688,"حَدَّثَنَا عُبَیْدُ اللہِ عن إسْرَائِیلَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی سَلَمَۃَ : {وَتَرْغَبُونَ أَنْ تَنْکِحُوہُنَّ} قَالَ : الْمَرْأَۃُ یَکُونُ بِہَا عَرَجٌ ، أَوْ عَوَرٌ فَلاَ یَنْکِحُونَہَا حَتَّی یَرِثُوہَا۔",,,17688 17689,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، عَنْ عَمَّارٍ ، عَنْ عَطَائٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ : {وَمَا یُتْلَی عَلَیْکُمْ فِی الْکِتَابِ فِی یَتَامَی النِّسَائِ} قَالَ : مَا یُتْلَی عَلَیْکُمْ فِی أَوَّلِ السُّورَۃِ مِنَ الْمَوَارِیثِ ، وَکَانُوا لاَ یُوَرِّثُونَ امْرَأَۃً وَلاَ صَبِیًّا حَتَّی یَحْتَلِمَ۔",,,17689 17690,"حَدَّثَنَا عُبَیْدُ اللہِ عن إسْرَائِیلَ ، عَنِ السُّدِّیِّ ، عَنْ أَبِی مَالِکٍ فِی قَوْلِ اللہِ : {وَمَا یُتْلَی عَلَیْکُمْ فِی الْکِتَابِ فِی یَتَامَی النِّسَائِ اللاَّتِی لاَ تُؤْتُونَہُنَّ مَا کُتِبَ لَہُنَّ وَتَرْغَبُونَ أَنْ تَنْکِحُوہُنَّ} ، فَقَالَ : کَانَتِ الْمَرْأَۃُ إذَا کَانَتْ عِنْدَ وَلِیٍّ رَغِبَ عَنْ حَسَبِہَا ، أَوْ حُسْنِہَا ، شَکَّ أَبُو بَکْرٍ ، ثُمَّ تَزَوَّجَہَا وَلَمْ یَتْرُکْ أَحَدًا یَتَزَوَّجُہَا : {وَالْمُسْتَضْعَفِینَ مِنَ الْوِلْدَانِ وَأَنْ تَقُومُوا لِلْیَتَامَی بِالْقِسْطِ} قَالَ : کَانُوا لاَ یُوَرِّثُونَ إلاَّ الأَکْبَرَ فَالأَکْبَرَ۔",,,17690 17691,حَدَّثَنَا أَبُو خَالِد الأَحْمَر، عَنْ حَجَّاجِ، عَنْ قَتَادَۃَ، عَنِ الحَسَنِ أَنَّہُ کَرِہَ ذَبَائِحَہُمْ وَنِسَائَہُمْ، یَعْنِی الصَّابِئِیْنَ۔,,,17691 17692,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ إسْمَاعِیلَ ، عَنْ أَبِی مَالِکٍ : {فَانْکِحُوا مَا طَابَ لَکُمْ مِنَ النِّسَائِ} قَالَ : مَا حَلَّ لَکُمْ مِنَ النِّسَائِ ، ذَلِکَ أَدْنَی أَلاَّ تَعُولُوا۔",,,17692 17693,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ { وَإِنْ خِفْتُمْ أَلاَّ تقْسِطُوا فِی الْیَتَامَی فَانْکِحُوا مَا طَابَ لَکُمْ مِنَ النِّسَائِ} یَقُولُ : مَا أَحْلَلْت لَکُمْ۔",,,17693 17694,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ سِمَاکٍ ، عَنْ عِکْرِمَۃَ : { وَإِنْ خِفْتُمْ أَلاَّ تُقْسِطُوا فِی الْیَتَامَی} قَالَ : کَانَ الرَّجُلُ مِنْ قُرَیْشٍ یَکُونُ عِنْدَہُ النِّسْوَۃُ وَیَکُونُ عِنْدَہُ الأَیْتَامُ فَیَذْہَبُ مَالُہُ فَیَمِیلُ عَلَی الأَیْتَامِ فَنَزَلَتْ ہَذِہِ الآیَۃُ : {فَانْکِحُوا مَا طَابَ لَکُمْ مِنَ النِّسَائِ}۔",,,17694 17695,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ مُطَرِّفٍ ، عَنْ عَامِرٍ قَالَ : قَوْلُہُ : {وَالْمُحْصَنَاتُ مِنَ الَّذِینَ أُوتُوا الْکِتَابَ مِنْ قَبْلِکُمْ} قَالَ : إِحْصَانُ الیَہُوْدِیَۃِ وَالنَّصْرَانِیَۃِ أَنْ تَغْتَسِلَ مِنَ الجَنَابَۃِ وأَنْ تُحْصِنَ فَرْجَہَا۔",,,17695 17696,"حَدَّثَنَا إدْرِیسُ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ قولہ : {وَالْمُحْصَنَاتُ مِنَ الَّذِینَ أُوتُوا الْکِتَابَ مِنْ قَبْلِکُمْ} قَالَ: العَفَائِفُ۔",,,17696 17697,"حدَّثَنَا ابْنُ إِدْرِیْسُ، عَنْ لَیْثٍ، عَنْ مُجَاہِدٍ قَالَ: {عَلِمَ اللّہُ أَنَّکُمْ سَتَذْکُرُونَہُنَّ} قَالَ: ذِکْرُہُ إِیَّاہَا فِی نَفْسِہِ۔",,,17697 17698,"حَدَّثَنَا وَکِیعٌ ، عَنْ یَزِیْدَ ، عَنِ الحَسَنِ : {عَلِمَ اللّہُ أَنَّکُمْ سَتَذْکُرُونَہُنَّ} قَالَ : فِیَ الخِطْبَۃِ۔",,,17698 17699,"أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ إِسْمَاعِیْل بِنْ رَافِعٍ ، عَنْ زَیْدِ بِنْ أَسْلَمَ ، قَالَ : سَمِعْتُہ یَقُوْلُ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ نَکَحَ امْرَأَۃً وَہُوَ یُرِیْدُ أَنْ یَذْہَبَ بِمَہْرِہَا فَہُوَ عِنْدَ اللہِ زَانٍ یَوْمَ القِیَامَۃِ۔",,,17699 17700,"حَدَّثَنَا وَکِیْعٌ ، عَنْ مَالِکِ بِنِ مِغْوَلٍ ، عَنْ أُمِّ ہَمَدَانَ ، عَنْ عَمَّتِہَا ، عَنْ عَائِشَۃَ وَأُمِّ سَلَمَۃَ قَالَتَا : لَیْسَ شَیْئٌ أَشَدُّ مِنْ مَہْرِ امْرَأَۃٍ ، أَوْ أَجْرِ أَجِیْرٍ۔",,,17700 17701,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَشْعَثَ ، عَنِ الحَکَمِ قَالَ: لاَ بأْسَ أَنْ یَتَزَوَّجَہا عَلَی مَا بَقِیَ مِنْ کِتَابَتِہَا",,,17701 17702,"حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ ، عَنْ ہُرَیْمِ ، عَنْ بَیَانٍ ، عَنِ الشَّعْبِیِّ ، عَنِ ابْنِ عَبَّاسٍ : {ذَلِکَ أَدْنَی أَنْ لاَ تَعُولُوا} قَالَ : تَمِیلُوا",,,17702 17703,"حَدَّثَنَا جَرِیرٌ، عَنْ مُفَضَّلِ بْنِ مُہَلْہِلٍ، عَنْ مُغِیرَۃَ، عَنْ أَبِی رَزِینٍ {ذَلِکَ أَدْنَی أَنْ لاَ تَعُولُوا} قَالَ: تَمِیلُوا۔",,,17703 17704,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ یُونُسَ ، عَنْ مُجَاہِدٍ : {ذَلِکَ أَدْنَی أَنْ لاَ تَعُولُوا} قَالَ : تَمِیلُوا۔",,,17704 17705,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ قُرَّۃَ ، عَنِ الْحَسَنِ : {ذَلِکَ أَدْنَی أَنْ لاَ تَعُولُوا} قَالَ : تَمِیلُوا۔",,,17705 17706,"حَدَّثَنَا عَثَّام بْنُ عَلِیٍّ وَمُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ إسْمَاعِیلَ ، عَنْ أَبِی مَالِکٍ : {ذَلِکَ أَدْنَی أَنْ لاَ تَعُولُوا} قَالَ : تَمِیلُوا۔",,,17706 17707,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ جُوَیْبِر ، عَنِ الضَّحَّاکِ : {ذَلِکَ أَدْنَی أَنْ لاَ تَعُولُوا} قَالَ : تَمِیلُوا۔",,,17707 17708,"حَدَّثَنَا ہُشَیْمُ بْنُ بَشِیرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ وَعَنْ یُونُسَ ، عَنِ الْحَسَنِ قَالاَ : یَجُوزُ تَزْوِیجُ الْمَرِیضِ وَبَیْعُہُ وَشِرَاؤُہُ۔",,,17708 17709,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ مَنْصُورٍ، عَنْ إبْرَاہِیمَ فِی الْمَرِیضِ ہُوَ یَتَزَوَّجُ؟ قَالَ: ہُوَ جَائِزٌ مِنْ غَیْرِ الثَّلاَثِ۔",,,17709 17710,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ قَالَ : أَرَادَ عَبْدُ الرَّحْمَنِ ابْنُ أُمِّ الْحَکَمِ أَنْ یَشْتَرِیَ ثُمُنَہُ مِنْ بِنْتِ جَرِیرٍ وَہُوَ مَرِیضٌ فَأَبَتْ فَتَزَوَّجَ عَلَیْہَا ثَلاَثًا وَہُوَ مَرِیضٌ فَجَازَ",,,17710 17711,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ قَالَ : إنَّ مُعَاوِیَۃَ أَجَازَہُ۔",,,17711 17712,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ عَبْدِ اللہِ بْنِ یَزِیدَ الْبَاہِلِیِّ قَالَ : سَأَلْتُ عَطَائً عَنْ رَجُلٍ یَتَزَوَّجُ وَہُوَ مَرِیضٌ أَیَجُوزُ ذَلِکَ ؟ فَقَالَ : إنَّ النَّاسَ یَقُولُونَ إنَّہُ یَجُوزُ۔",,,17712 17713,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ یَتَزَوَّجُ وَہُوَ مَرِیضٌ قَالَ : إِنْ کَانَ مُضَارًّا لَمْ یَجُزْ ، وَإِنْ کَانَ إنَّمَا تَزَوَّجَہَا لِتَقُومَ عَلَیْہِ فَہُوَ جَائِزٌ۔",,,17713 17714,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَبْدِ الْخَالِقِ ، عَنْ حَمَّادٍ فِی الرَّجُلِ یَتَزَوَّجُ فِی مَرَضِہِ قَالَ : ہُوَ مِنْ ثُلُثہ۔",,,17714 17715,"حَدَّثَنَا أَبُو عَاصِمٍ ، عَنِ ابْنِ جُرَیْجٍ قَالَ : سَأَلْتُ عَطَائً ، عَنِ الْمَرِیضِ یَتَزَوَّجُ ؟ قَالَ : مَا أَرَاہُ إلاَّ حَدَثًا۔",,,17715 17716,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ فِی الرَّجُلِ یَتَزَوَّجُ فِی مَرَضہ قَالَ : لاَ یَجُوزُ۔",,,17716 17717,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ خَلِیفَۃَ بْنِ غَالِبٍ قَالَ : سَأَلْتُ نَافِعًا عَنْہُ ، فَقَالَ : ہُوَ جَائِزٌ وَتَرِثُہُ وَتَأْخُذُ صَدَاقَہَا۔",,,17717 17718,حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ خَلِیفَۃَ بْنِ غَالِبٍ ، عَنْ نَافِعٍ أَنَّ ابْنَ أَبِی رَبِیعَۃَ تَزَوَّجَ وَہُوَ مَرِیضٌ أَرَادَ أَنْ تَرِثَہُ ، وَکَانَ بَیْنَہُ وَبَیْنَہَا قَرَابَۃٌ۔,,,17718 17719,"حَدَّثَنَا یَحْیَی بْنُ سَعِیْدٍ ، عَنْ سُفْیَانَ ، عَنِ الأَعْمَشِ ، عَنْ مُسْلِمٍ ، عَنْ مَسْرُوْقٍ قَالَ : کَانَتِ المَرْأَۃُ إِذَا ذَہَبَتْ إِلَی المُشْرِکِیْنَ أَعْطَوْا زَوْجَہَا مِثْلَ مَہْرِہَا وَإِذَا ذَہَبَتْ إِلَی قَوْمٍ لَیْسَ بَیْنَہَا وَبَیْنَہُمْ عَہْدٌ مِنَ المُشْرِکِیْنَ {فَعَاقَبْتُمْ} فَأَصَبْتُمْ غَنِیْمَۃً {فَآتُوا الَّذِینَ ذَہَبَتْ أَزْوَاجُہُم مِّثْلَ مَا أَنفَقُوا} یَقُوْلُ : ٰاتُوْا زَوْجَہَا مِنَ الغَنِیْمَۃِ مِثْلَ مَہْرِہَا۔",,,17719 17720,حَدَّثَنَا یَحْیَی بْنُ سَعِیْدٍ ، عَنْ سُفْیَانَ ، عَنْ خَصِیْفٍ ، عَنْ مُجَاہِدٍ مِثْلَہُ ، أَوْ نَحْوَہُ۔,,,17720 17721,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ مُخْتَارِ بْنِ منیح ، عَنْ قَتَادَۃَ ، عَنْ عُرْوَۃَ بْنِ الزُّبَیْرِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : تَخَیَّرُوا لِنُطَفِکُمْ (ابن عدی 2187)",,,17721 17722,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیم أَنَّ عَلْقَمَۃَ کَانَ إذَا تَزَوَّجَ تَزَوَّجَ إلَی أَدْنَی بَیْتَۃٍ۔,,,17722 17723,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ الرَّبَذِیِّ ، عَنْ عَبْدِ اللہِ بْنِ خِرَاشٍ قَالَ : رَأَیْتُ أَبَا ذَرٍّ بِالرَّبَذَۃِ وَعِنْدَہُ امْرَأَۃٌ لَہُ سَحْمَائُ ، أَوْ شَحْبَائُ قَالَ : وَہُوَ فِی مِظَلَّۃٍ لَہُ سَوْدَائَ قَالَ : فَقِیلَ لَہُ : یَا أَبَا ذَرٍّ ، لَوِ اتَّخَذْت امْرَأَۃً ہی أَرْفَعَ مِنْ ہَذِہِ ، فَقَالَ : وَاللَّہِ لأَنْ أَتَّخِذَ امْرَأَۃً تَضَعُنِی أَحَبُّ إلَیَّ مِنْ أَنْ أَتَّخِذَ امْرَأَۃً تَرْفَعُنِی۔",,,17723 17724,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدِ بْنِ سِیرِینَ ، قَالَ : قَالَ : عُمَرُ بْنُ الْخَطَّابِ : مَا بَقِیَ فِیَّ مِنْ أَخْلاَقِ الْجَاہِلِیَّۃِ شَیْئٌ إلاَّ أَنِّی لَسْتُ أُبَالِی أَیَّ الْمُسْلِمِینَ نَکَحْتُ وَأَیَّہُمْ أَنْکَحْتُ۔",,,17724 17725,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ قَالَ : کَانَ عَلْقَمَۃُ یَخْطُبُ إلَی مَنْ ہُوَ أَسْفَلُ مِنْہُ۔",,,17725 17726,"حَدَّثَنَا یَزِیدُ قَالَ : حدَّثَنَا ہِشَام ، عَنْ مُحَمَّدِ بْنِ سِیرِینَ ؛ أَنَّ رَجُلاً تَزَوَّجَ ابْنَۃَ عَبْدٍ خَیَّاطٍ فَوَلَدَتْ عِنْدَہُ غُلاَمًا فَانْتَفَی مِنْہُ ، فَقَالَ لَہُ شُرَیْحٌ : مَا الَّذِی دَلَّک عَلَی أَنْ تَزَوَّجَ بِنْتَ عَبْدٍ خَیَّاطٍ وَأَنْتَ رَجُلٌ مِنَ الْعَرَبِ فِی شَرَفٍ مِنَ الْعَطَائِ ہو الَّذِی دَعَاک إلَی أَنْ تَنْتَفِیَ مِنْہُ ۔",,,17726 17727,"حَدَّثَنَا عَبْدُ اللہِ بْنُ مُبَارَکٍ ، عَنْ إِسْمَاعِیلَ مَوْلَی بَنِی مَخْزُوْمٍ قَالَ : سَأَلْتُ عَطَائً عَنِ امْرَأَۃٍ قَالَتْ لِعَبْدِہَا: أُعْتِقَکَ عَلَی أَنْ تَزَوَّجَنِی فَقَالَ : لَوْ أَنَّہَا بَدَأَتْ یَعْتِقُہُ ! قَالَ : وَسَأَلْتُ عَبْدَ اللہِ بْنَ عُبَیْدِ بْنِ عُمَیْرٍ فَقَالَ مِثْلَ قَوْلِ عَطَائٍ ، قَالَ : فَسَأَلْتُ مُجَاہِدًا فغَضِبَ وَقَالَ : فِی ہَذِہِ عُقُوْبَۃٌ مِنَ اللہِ وَمِنَ السُّلْطَانِ",,,17727 17728,"حَدَّثَنَا وَکِیْعٌ ، عَنْ إِسْمَاعِیْلَ بَنْ مُسْلِمٍ ، عَنْ عَطَائٍ وَعبْدِ اللہِ بْنِ عُبَیْدِ بْنِ عُمَیْرٍ قَالاَ : تَعْتِقُہُ وَلاَ تُشَاطِرُہُ وَقَالَ مُجَاہِدٌ : فِی ہَذِہِ عُقُوْبَۃٌ مِنَ اللہِ وَمِنَ السُّلْطَانِ۔",,,17728 17729,"حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ فِی قَوْلِہِ : {وَأُحْضِرَتِ الأَنْفُسُ الشُّحَّ} قَالَ : فِی النَّفَقَۃِ۔",,,17729 17730,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی بِشْرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ قَالَ : نُصِیبُہَا مِنْ نَفْسِہِ وَمِنْ مَالِہِ",,,17730 17731,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ رَجُلٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ قَالَ : النَّفَقَۃُ وَالأَیَّامُ۔",,,17731 17732,"حدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ : {أَوْ أَکْنَنتُمْ فِی أَنفُسِکُمْ} قَالَ : ذَکَرَہُ إِیَّاہُ فِی نَفْسِہِ۔",,,17732 17733,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الحَسَنِ : {أَوْ أَکْنَنتُمْ فِی أَنفُسِکُمْ} : الخِطْبَۃَ۔",,,17733 17734,حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ مُغِیرَۃَ ، عَنِ الشَّعْبِیِّ وَحَمَّادٍ أَنَّہُمَا کَانَا لاَ یَرَیَانِ بَأْسًا لِلنُّفَسَائِ أَنْ تُزَوَّجَ حَتَّی تَطْہُرَ۔,,,17734 17735,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مُغِیرَۃَ ، عَنِ الشَّعْبِیِّ وَالْمُسَیِّبِ بْنِ رَافِعٍ أَنَّہُمَا قَالاَ فِی النُّفَسَائِ: لاَ تُزَوَّجُ حَتَّی یَذْہَبَ الدَّمُ۔",,,17735 17736,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ وَحَمَّادٍ قَالاَ : فِی النُّفَسَائِ : تُزَوَّجُ ، وَإِنْ لَمْ یَذْہَبِ الدَّمُ۔",,,17736 17737,"حَدَّثَنَا غُنْدَرٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ قَالَ : کَانَ یَکْرَہُہُ فَإِنْ تَزَوَّجَتْ فَالنِّکَاحُ جَائِزٌ۔",,,17737 17738,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنِ الجَلْد بِنْ أَیُّوْبٍ ، عَنْ مَعَاوِیَۃ بْنِ قُرّۃ ، عَنْ عَائِذِ بْنِ عَمْروٍ رَجُلٌ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَکَانَ مِمَّنْ بَایَعَ تَحْتَ الشَّجَرَۃِ ؛ أَنَّ امْرَأَۃً مِنْ نِسَائِہِ نَفَسَتْ فَرَأَتِ الطُّہْرَ لِعِشْرِیَنَ لَیْلَۃً فَاغْتَسَلَتْ ثُمَّ جَائَتْ فَدَخَلَتْ مَعَہُ فِی لِحَافِہِ فَقَالَ : مَنْ ہَذِہِ ؟ فَقَالَتْ : فُلاَنَۃُ ، فَقَالَ : أَوَلَیْسَ قَدْ نَفِسْت ؟ قَالَتْ : إذًا قَدْ رَأَیْت الطُّہْرَ ، قَالَ : فَضَرَبَہَا بِرِجْلِہِ حَتَّی أَخْرَجَہَا مِنَ اللِّحَافِ وَقَالَ : لاَ تغُرنی عَنْ دِینِی حَتَّی یَمْضِیَ أَرْبَعُونَ یَوْمًا۔",,,17738 17739,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، عَنْ عُثْمَانَ بْنِ أَبِی الْعَاصِ أَنَّہُ قَالَ : لِنِسَائِہِ : لاَ تَشَرَّفْنَ لِی دُونَ أَرْبَعِینَ لَیْلَۃً فِی النِّفَاسِ۔",,,17739 17740,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَبْدِ اللہِ بْنِ یَسَارٍ ، عَنْ عُمَرَ ، قَالَ : تَجْلِسُ النُّفَسَائُ أَرْبَعِینَ یَوْمًا۔",,,17740 17741,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ، عَنْ أَبِیہِ، عَنِ الْحَسَنِ قَالَ: تَرَبَّصُ النُّفَسَائُ أَرْبَعِینَ یَوْمًا ثُمَّ تَغْتَسِلُ وَتُصَلِّی، وَقَالَ الشَّعْبِیُّ : تَرَبَّصُ شَہْرَیْنِ ثُمَّ ہِیَ بِمَنْزِلَۃِ الْمُسْتَحَاضَۃِ۔",,,17741 17742,"حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ قَالَ : لاَ تَجْلِسُ النُّفَسَائُ أَکْثَرَ مِنْ أَرْبَعِینَ لیلۃ ، وقَالَ : عَطَائٌ : تَجْلِسُ عَادَتَہَا الَّتِی اعْتَادَتْ ، وَلاَ تَجْلِسُ أَکْثَرَ مِنْ أَرْبَعِینَ لَیْلَۃً۔",,,17742 17743,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی عَوَانَۃَ ، عَنْ أَبِی بِشْرٍ ، عَنْ یُوسُفَ بْنِ مَاہَکٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : تَجْلِسُ النُّفَسَائُ نَحْوًا مِنْ أَرْبَعِینَ یَوْمًا۔",,,17743 17744,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ زُہَیْرٍ قَالَ : حدَّثَنَا عَلِیُّ بْنُ عَبْدِ الأَعْلَی ، عَنْ أَبِی سَہْلٍ ، عَنْ مُسَّۃَ ، عَنْ أُمِّ سَلَمَۃَ قَالَتْ : کَانَتِ النُّفَسَائُ تَقْعُدُ عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَرْبَعِینَ یَوْمًا ، وَکُنَّا نُلَطِّخُ عَلَی وُجُوہِنَا الْوَرْسَ مِنَ الْکَلَفِ۔ (ترمذی 139۔ ابوداؤد 315)",,,17744 17745,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ أَبِی یَزِیدَ أَنَّہُ سَأَلَ ابْنَ عَبَّاسٍ عَنْ رَجُلٍ اشْتَرَی جَارِیَۃً وَہِیَ حَامِلٌ أَیَطَأُہَا ؟ قَالَ : لاَ ، وَقَرَأَ : (وَأُولاَتُ الأَحْمَالِ أَجَلُہُنَّ أَنْ یَضَعْنَ حَمْلَہُنَّ)۔",,,17745 17746,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ قَالَ : قُلْتُ لَہُ : إنَّ أَبَا مُوسَی نَہَی حِینَ فَتَحَ تُسْتَرَ : أَلاَ تُوطَأُ الْحَبَالَی ، وَلاَ یُشَارِکُ الْمُشْرِکِینَ فِی أَوْلاَدِہِمْ ، فَإِنَّ الْمَائَ یَزِیدُ فِی الْوَلَدِ ، أَشَیْئٌ قَالَہُ بِرَأْیِہِ ؟ أَوْ شَیْئٌ رَوَاہُ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ فَقَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَوْمَ أَوْطَاسٍ أَنْ تُوطَأَ حَامِلٌ حَتَّی تَضَعَ ، أَوْ حَائل حَتَّی تُسْتَبْرَأَ۔",,,17746 17747,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ حَجَّاجٍ ، عَنْ قَتَادَۃَ ، عَنْ أَبِی قِلاَبَۃَ قَالَ قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَیْسَ مِنَّا مَنْ وَطِیئَ حُبْلَی۔",,,17747 17748,حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنْ مِقْسَمٍ ، عَنِ ابْنِ عَبَّاسٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِثْلَہُ۔ (احمد 1/256۔ طبرانی 12090),,,17748 17749,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ یَزِیدَ بْنِ أَبِی حَبِیبٍ ، عَنْ أَبِی مَرْزُوقٍ ، مَوْلَی تُجِیبَ ، قَالَ : غَزَوْنَا مَعَ رُوَیْفِعِ بْنِ ثَابِتٍ الأَنْصَارِیِّ نَحْوَ الْمَغْرِبِ فَفَتَحْنَا قَرْیَۃً یُقَالُ لَہَا جَرْبَۃُ قَالَ : فَقَامَ فِینَا خَطِیبًا ، فَقَالَ : إنِّی لاَ أَقُولُ فِیکُمْ إلاَّ مَا سَمِعْت مِنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ فِینَا یَوْمَ خَیْبَرَ قَالَ : مَنْ کَانَ یُؤْمِنُ بِاللَّہِ وَالْیَوْمِ الآخِرِ فَلاَ یُسْقِیَنَّ مَائَہُ زَرْعَ غَیْرِہِ۔ (احمد 4/108۔ طبرانی 4483)",,,17749 17750,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ یَزِیدَ بْنِ أَبِی حَبِیبٍ ، عَنْ حَنَشٍ الصَّنْعَانِیِّ ، عَنْ أَبِی مَرْزُوقٍ ، مَوْلَی تُجِیبَ ، عَنْ رُوَیْفِعِ بْنِ ثَابِتٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِمِثْلِہِ,,,17750 17751,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ حَجَّاجٍ ، عَنْ عَبْدِ اللہِ بْنِ زَیْدٍ ، عَنْ عَلِیٍّ قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أَنْ تُوطَأَ الْحَامِلُ حَتَّی تَضَعَ ، أَوِ الْحَائِضُ حَتَّی تُسْتَبْرَأَ بِحَیْضَۃٍ۔",,,17751 17752,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ صِلَۃَ وَقُثَمٍ وَنَاجِیَۃَ بْنِ کَعْبٍ قَالُوا : أَیُّمَا رَجُلٍ اشْتَرَی جَارِیَۃً حُبْلَی فَلاَ یَطَؤُہَا حَتَّی تَضَعَ حَمْلَہَا وَأَیُّمَا رَجُلٍ اشْتَرَی جَارِیَۃً فَلاَ یَقْرَبْہَا حَتَّی تَحِیضَ۔",,,17752 17753,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : نُہِیَ أَنْ یَطَأَ الرَّجُلُ وَلِیدَۃً ، أَوِ امْرَأَۃً وَفِی بَطْنِہَا جَنِینٌ لِغَیْرِہِ۔",,,17753 17754,"حَدَّثَنَا أَبُو أُسَامَۃَ، عَنْ أَشْعَثَ، عَنِ الْحَسَنِ قَالَ: لَمَّا فُتِحَتْ تُسْتَرُ أَصَابَ أَبُو مُوسَی سَبَایَا فَکَتَبَ إلَیْہِ عُمَرُ أَنْ لاَ یَقَعَ أَحَدٌ عَلَی امْرَأَۃٍ حبلی حَتَّی تَضَعَ وَلاَ تُشَارِکُوا الْمُسْلِمِینَ فِی أَوْلاَدِہمْ فَإِنَّ الْمَائَ تَمَامُ الْوَلَدِ۔",,,17754 17755,حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ، عَنْ مَعْمَرٍ، عَنْ عَمْرِو بْنِ مُسْلِمٍ، عَنْ طَاوُوسٍ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَمَرَ مُنَادِیًا فنادی فِی غَزْوَۃٍ غَزَاہَا ؛ أَنْ لاَ یَطَأَ الرِّجَالُ حَامِلاً حَتَّی تَضَعَ ، وَلاَ حَائِلاً حَتَّی تَحِیضَ۔,,,17755 17756,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ قَالَ : حدَّثَنَا الْقَاسِمُ وَمَکْحُولٌ ، عَنْ أَبِی أُمَامَۃَ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی یَوْمَ خَیْبَرَ عن أَنْ تُوطَأَ الْحَبَالَی حَتَّی یَضَعْنَ۔",,,17756 17757,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : أَخْبَرَنَا شُعْبَۃُ ، عَنْ یَزِیدَ بْنِ خُمَیْرٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ جُبَیْرِ بْنِ نُفَیْرٍ ، عَنْ أَبِیہِ ، عَنْ أَبِی الدَّرْدَائِ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَرَّ عَلَی امْرَأَۃٍ مُجِحٍّ وَہِیَ عَلَی بَابِ خِبَائٍ ، أَوْ فُسْطَاطٍ ، فَقَالَ : لِمَنْ ہَذِہِ ؟ فَقَالُوا : لِفُلاَنٍ ، قَالَ : أَیُلِمُّ بِہَا ؟ قَالُوا : نَعَمْ ، قَالَ : لَقَدْ ہَمَمْت أَنْ أَلْعَنَہُ لَعْنَۃً تَدْخُلُ مَعَہُ قَبْرَہُ ، فَکَیْفَ یَسْتَخْدِمُہُ وَہُوَ یَغْذُوہُ فِی بَصَرِہِ وَسَمْعِہِ ، کَیْفَ یَرِثُہُ وَہُوَ لاَ یَحِلُّ لَہُ۔\n\n(مسلم 1066۔ ابوداؤد 2149)",,,17757 17758,"حَدَّثَنَا ہُشَیْم ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ أَنَّ رَجُلاً کَانَتْ عِنْدَہُ یَتِیْمَۃٌ وکَانَتْ تَحْضُرُ مَعَہُ طَعَامَہُ قَالَ : فَخَافَتِ امْرَأَتہ أَنْ یَتَزَوَّجَہَا عَلَیْہَا قَالَ : وَغَابَ الرَّجُلُ غَیْبَۃً فَاسْتَعَانَتِ امْرَأَتہ نِسْوَۃً عَلَیْہَا فَضَبَطْنَہَا لَہَا وَأَفْسَدَتْ عُذْرَتَہَا بِیَدِہَا ، وَقَدِمَ الرَّجُلُ فَجَعَلَ یَفْقِدُہَا ، عَنْ مَائِدَتِہِ ، فَقَالَ لاِمْرَأَتِہِ : مَا شَأْنُ فُلاَنَۃَ لاَ تَحْضُرُ طَعَامِی کَمَا کَانَتْ تَحْضُرُ ؟ فَقَالَتْ : دَعْ عَنْک فُلاَنَۃَ ، فَقَالَ : مَا شَأْنُہَا ؟ قَالَ : فَقَذَفَتْہَا قَالَ : فَانْطَلَقَ الرجل حَتَّی دَخَلَ عَلَیْہَا ، فَقَالَ : مَا شَأْنُک ؟ مَا أَمْرُک ؟ قَالَ : فَجَعَلَتْ لاَ تَزِیدُ عَلَی الْبُکَائِ ، فَقَالَ : أَخْبِرِینِی فَأَخْبَرَتْہُ قَالَ : فَانْطَلَقَ إلَی عَلِیٍّ رضی اللہ عنہ فَذَکَرَ ذَلِکَ لَہُ فَأَرْسَلَ إلَی امْرَأَۃِ الرَّجُلِ وَإِلَی النِّسْوَۃِ فَسَأَلَہُنَّ قَالَ : فَمَا لَبِثْنَ أَنِ اعْتَرَفْنَ قَالَ : فَقَالَ لِلْحَسَنِ : اقْضِ فِیہَا ، فَقَالَ الْحَسَنُ : أَرَی الْحَدَّ عَلَی مَنْ قَذَفَہَا وَالْعُقْرَ عَلَیْہَا وَعَلَی الْمُمْسِکَاتِ قَالَ : فَقَالَ عَلِیٌّ : لَوْ کُلِّفت إبِلٌ طَحِینًا لَطَحَنَتْ قَالَ : وَمَا یَطْحَنُ یَوْمَئِذٍ بَعِیرٌ۔",,,17758 17759,"حَدَّثَنَا ہُشَیْمُ بْنُ بَشِیرٍ ، عَنْ إسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ أَنَّ جَوَارٍ أَرْبَعًا اجْتَمَعْنَ ، فَقَالَتْ إحْدَاہُنَّ : ہِیَ رَجُلٌ ، وَقَالَتِ الأُخْرَی : ہِیَ امْرَأَۃٌ وَقَالَتِ الثَّالِثَۃُ : أَنَا أَبُو الَّتِی زَعَمَتْ أَنَّہَا امْرَأَۃٌ وَقَالَتِ الرَّابِعَۃُ : أَنَا أَبُو الذی زَعَمَتْ أَنَّہَا رَجُلٌ، فَخَطَبَتِ الَّتِی زَعَمَتْ أَنَّہَا أَبُو الرَّجُلِ إلَی الَّتِی زَعَمَتْ أَنَّہَا أَبُو الْمَرْأَۃِ ، فَزَوَّجَتْہَا، فَأَفْسَدَتِ الَّتِی زَعَمَتْ أَنَّہَا رَجُلٌ الْجَارِیَۃَ الَّتِی زَوَّجَتْہَا ، فَاخْتَصَمُوا إلَی عَبْدِ الْمَلِکِ بْنِ مَرْوَانَ ، فَجَعَلَ صَدَاقَہَا عَلَی أَرْبَعَتِہِنَّ ، وَرَفَعَ حِصَّۃَ الَّتِی زَعَمَتْ أَنَّہَا امْرَأَۃٌ ، لأَنَّہَا أَمْکَنَتْ مِنْ نَفْسِہَا ، قَالَ : فَذَکَرَتْ ذَلِکَ لِعَبْدِ اللہِ بْنِ مَعقِلٍ الْمُزَنِیّ ، فَقَالَ : لَوْ أَنِّی وُلِّیتُ ذَلِکَ لَمْ أَرَ الصَّدَاقَ إلاَّ عَلَی الَّتِی أَفْسَدَتْہَا۔",,,17759 17760,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنْ إبْرَاہِیمَ أَنَّ امْرَأَۃً افْتَضَّتْ جَارِیَۃً بِأُصْبُعِہَا وَقَالَتْ : إنَّہَا زَنَتْ فَرَفَعَتْ إلَی عَلِیٍّ فَغَرَّمَہَا الْعُقْرَ وَضَرَبَہَا ثَمَانِینَ لِقَذْفِہَا إیَّاہَا۔",,,17760 17761,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ أَبِی بِشْرٍ ، عَنِ الشَّعْبِیِّ ؛ أَنَّ نِسْوَۃً کُنَّ بِالشَّامِ ، فَأَشِرْنَ وَبَطِرن وَلَعِبْنَ الْحُزُقَّۃَ ، فَرَکِبَتْ وَاحِدَۃٌ الأُخْرَی ، وَنَخَسَتِ الأُخْرَی ، فَأَذْہَبَتْ عُذْرَتَہَا ، فَرُفِعَ ذَلِکَ إلَی عَبْدِ الْمَلِکِ بْنِ مَرْوَانَ ، فَسَأَلَ عَنْ ذَلِکَ فَضَالَۃَ بْنَ عُبَیْدٍ وَقَبِیصَۃَ بْنَ ذُؤَیْبٍ ، فَقَالاَ : عَلَیْہِنَّ الدِّیَۃُ، وَیُرْفَعُ نَصِیبَ وَاحِدَۃٍ ، وَقَالَ ابْنُ مُعْقِلٍ : یَرَی مِنْ نَطَفِہَا إلَی نَاخِسَتِہَا ، وَقَالَ الشَّعْبِیُّ : وَأَنَا أَرَی ذَلِکَ وَلَہَا عُقْرُہَا۔",,,17761 17762,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ حُمَیْدٍ ، عَنْ بَکْرٍ ؛ أَنَّ جَارِیَتَیْنِ کَانَتَا بِالْحَمَّامِ ، فَدَفَعَتْ إحْدَاہُمَا الأُخْرَی فَانْتَقَضَتْ عُذْرَتُہَا ، فَقَضَی لَہَا شُرَیْحٌ : عَلَیْہَا بِمِثْلِ صَدَاقِہَا۔",,,17762 17763,حدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ أنَّہُ قَالَ فِی رَجُلَیْنِ تَزَوَّجَا أُخْتَیْنِ فَأُدْخِلَ عَلَی کُلِّ وَاحِدٍ مِنْہُمَا امْرَأَۃُ صَاحِبِہِ قَالَ لَہُمَا الصَّدَاقُ وَیَرْجِعُ الزَّوْجَانِ عَلَی مَنْ غَیَّرَہُمَا۔,,,17763 17764,حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُحَمَّدِ بْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ أَنَّ عَلِیًّا قَالَ ذَلِکَ۔,,,17764 17765,حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ أَنَّہُ قَالَ ذَلِکَ أَیْضًا۔,,,17765 17766,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ خِلاَسٍ قَالَ : تَزَوَّجَ أَخَوَانِ أُخْتَیْنِ ، فَأُدْخِلَتِ امْرَأَۃُ ہَذَا عَلَی ہَذَا ، وَامْرَأَۃُ ہَذَا عَلَی ہَذَا ، فَرُفِعَ ذَلِکَ إلَی عَلِیٍّ ، فَرَدَّ کُلَّ وَاحِدَۃٍ مِنْہُمَا إلَی زَوْجِہَا ، وَأَمَرَ زَوْجَہَا أَنْ لاَ یَقْرَبَہَا حَتَّی تَنْقَضِیَ عِدَّتُہَا ، وَجَعَلَ لِکُلِّ وَاحِدَۃٍ مِنْہُمَا الصَّدَاقَ عَلَی الَّذِی وَطِئَہَا لِغِشْیَانِہِ إیَّاہَا ، وَجَعَلَ جَہَازَہَا وَالْغُرْمَ عَلَی الَّذِی زَوَّجَہَا۔",,,17766 17767,حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ أَبِی بَکْرٍ عَنَ أَبی مَسْعُوْدٍ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی عَنْ مَہْرِ البَغِیِّ۔ (بخاری 2237۔ ترمذی 1276),,,17767 17768,"حَدَّثَنَا عَفَّانُ قَالَ : حدَّثَنَا أَبَانُ الْعَطَّارُ قَالَ : حَدَّثَنِی یَحْیَی بْنُ أَبِی کَثِیرٍ ، عَنْ إبْرَاہِیمَ بْنِ قَارِظٍ ، عَنِ السَّائِبِ بْنِ یَزِیدَ ، عَنْ رَافِعِ بْنِ خَدِیجٍ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : کَسْبُ الْحَجَّامِ خَبِیثٌ وَمَہْرُ الْبَغِیِّ خَبِیثٌ۔ (مسلم 1199۔ ابوداؤد 3414)",,,17768 17769,"حَدَّثَنَا شَبَابَۃُ ، عَنْ شُعْبَۃَ ، عَنْ عَوْنِ بْنِ أَبِی جُحَیْفَۃَ ، عَنْ أَبِیہِ قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ کَسْب مَہْرِ الْبَغِیِّ۔ (احمد 4/308)",,,17769 17770,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ عَبْدِ الْجَبَّارِ بْنِ عَبَّاسٍ ، عَنْ عَوْنِ بْنِ أَبِی جُحَیْفَۃَ ، عَنْ أَبِیہِ قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ مَہْرِ الْبَغِیِّ۔ (ابویعلی 892۔ طبرانی 273)",,,17770 17771,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِِ ، عَنْ أَبِی سُفْیَانَ ، عَنْ جَابِرٍ فِی قَوْلِہِ : {وَمَنْ یُکْرِہْہُّنَّ فَإِنَّ اللَّہَ مِنْ بَعْدِ إکْرَاہِہِنَّ غَفُورٌ رَحِیمٌ} قَالَ : کَانَ عَبْدُ اللہِ بْنُ أُبَیِّ ابْنُ سَلُولَ یَقُولُ لِجَارِیَتِہِ : اذْہَبِی فَابْغِینَا شَیْئًا فَأَنْزَلَ اللَّہُ تَعَالَی : {وَلاَ تُکْرِہُوا فَتَیَاتِکُمْ عَلَی الْبِغَائِ إِنْ أَرَدْنَ تَحَصُّنًا لِتَبْتَغُوا عَرَضَ الْحَیَاۃِ الدُّنْیَا وَمَنْ یُکْرِہْہُّنَّ فَإِنَّ اللَّہَ مِنْ بَعْدِ إکْرَاہِہِنَّ غَفُورٌ رَحِیمٌ}۔ (مسلم 26)",,,17771 17772,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ قَالَ : کَانُوا یُکْرِہُونَ أَنْ یَتَزَوَّجُوا عَلَی الدِّرْہَمِ وَالدِّرْہَمَیْنِ مِثْلَ مَہْرِ الْبَغِیِّ۔",,,17772 17773,حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطَائٍ ، عَنْ أَبِی ہُرَیْرَۃَ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی عَنْ مَہْرِ الْبَغِیِّ۔,,,17773 17774,"حَدَّثَنَا مُعَاذُ بنُ مُعَاذٍ ، عَنْ أَشْعَثَ ، عَنِ الحَسَنِ فِی رَجُلٍ تَزَوَّجَ أَمَۃً وَحُرَّۃً فِی عُقْدَۃٍ قَالَ : یُفَرَّقُ بَیْنَہُ وَبَیْنَ الأَمَۃِ ، أَوْ فِی رَجُلٍ تَزَوَّجَ أُخْتَیْنِ فِی عُقْدَۃٍ قَالَ : یُفَرَّقُ بَیْنَہُمَا۔",,,17774 17775,"حَدَّثَنَا حَفْصُ بنُ غِیَاثٍ ، عَنْ أَبِی حَنِیْفَۃَ ، عَنْ حَمَّادٍ ، عَنْ إِبرَاہِیْمَ قَالَ : إِذَا تَزَوَّجَ حُرَّۃً وَأَمَۃً فِی عُقْدَۃٍ فَسَدَ نِکَاحُہُمَا۔",,,17775 17776,"حَدَّثَنَا عَبْدَۃُ بنَ سُلَیْمَان ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الحَسَنِ ؛ فِی رَجُلٍ تَزَوَّجَ امْرَأَۃً ، ثُمَّ دَخَلَ بِہَا ، ثُمَّ مَاتَ ، ثُمَّ قَامَتِ البَیِّنَۃُ أَنَّہَا أُخْتُہُ مِنَ الرَّضَاعَۃِ قَالَ : لَہَا الصَّدَاقُ وَلاَ مِیْرَاثَ لَہَا۔",,,17776 17777,حَدَّثَنَا حَفْصُ بنُ غِیَاثٍ ، عَنِ الحَجَّاجِ ، عَنِ الرُّکَیْنِ ؛ أَنَّ المُغِیْرَۃَ ابْنَ شُعْبَۃَ خَطَبَ امْرَأَۃً، وَہُوَ وَلِیُّہَا، ومَعَہُ أَوْلِیَائُ مِثْلَہُ ، فأَمَرَ بَعْضَ أَوْلِیَائِہَا أَنْ یُزَوِّجَہَا إِیَّاہُ۔,,,17777 17778,"حَدَّثَنَا مُعَاذُ بنُ مَعَاذٍ ، عَنْ أشْعَثَ ، عَنِ الحَسَنِ قَالَ : إِذَا أَرَادَ وَلِیُّ المَرْأَۃِ أَنْ یُزَوَّجِہَا بإِذْنِہَا مِنْ نَفْسِہِ وَلَّی أَمْرَہَا رَجُلاً ثُمَّ تَزَوَّجَہَا بِشَہَادَۃِ العُدُوْلِ۔",,,17778 17779,حَدَّثَنَا حَفْصٌ ، عَنْ عَاصِمٍ ، عَنِ ابْنِ سِیرِینَ ، عَنْ شُرَیْحٍ أَنَّہُ کَانَ لاَ یُجِیْزُ نِکَاحَ المُضْطَہَدِ۔,,,17779 17780,"حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ سُفْیَانَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ قَالَ : لاَ نِکَاحَ لِمُضْطَہَدٍ۔",,,17780 17781,"حَدَّثَنَا عَبْدُ الأَعْلَی قَالَ : سُئِلَ عَنْ رَجُلٍ تَزَوَّجَ امْرَأَۃً عَلَی عَاجِلٍ أَوْ آجِلٍ فَدَخَلَ بِہَا فَادَّعَتْ أنَّہُ لَمْ یَِبَِرأ إِلِیْہَا مِنَ العَاجِلِ فَقَالَ : حَدَّثَنَا سَعِیدٍ ، عَنْ قَتَادَۃَ أَنَّہُ کَانَ یَقُوْلُ : المَخْرَجُ عَلَیْہَا فِیَ العَاجِلِ ، أَنَّہُ بَقِیَ عَلَیْہِ کَذَا وکَذَا وَدُخُوْلُہُ عَلَیْہَا أَبْرَأَہُ۔",,,17781 17782,"حَدَّثَنَا عَبْدُالأَعْلَی، عَنْ سَعِیدٍ، عَنْ قَتَادَۃَ، عَنِ الحَسَنِ ومَطَرٍ، عَنِ الحَسَنِ أَنَّہُ کَانَ یَقُوْلُ: المَخْرَجُ عَلَیْہِ۔",,,17782 17783,حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ حُمَیْدٍ ، عَنْ أَنَسٍ أَنَّہُ شَکَّ فِی وَلَدٍ لَہُ فَأَمَرَ أَنْ یُدْعَی لَہُ الْقَافَۃُ۔,,,17783 17784,"حَدَّثَنَا أَبُوبَکْرِ بْنُ عَیَّاشٍ، عَنْ أَسْلَمَ الْمُنْقِرِیِّ ، عَنْ عبد اللہِ بْنِ عُبَیْدِ بْنِ عُمَیْرٍ قَالَ : بَاعَ عَبْدُ الرَّحْمَنِ بْنُ عَوْفٍ جَارِیَۃً کَانَ وَقَعَ عَلَیْہَا قَبْلَ أَنْ یَسْتَبْرِئَہَا فَظَہَرَ بِہَا حَمْلٌ عِنْدَ الَّذِی اشْتَرَاہَا فَخَاصَمَہُ إلَی عُمَرَ ، فَقَالَ عُمَرُ ہَلْ کُنْت تَقَعُ عَلَیْہَا ؟ قَالَ : نَعَمْ ، قَالَ : فَبِعْتہَا قَبْلَ أَنْ تَسْتَبْرِئَہَا ؟ قَالَ : نَعَمْ ، قَالَ : مَا کُنْت لِذَلِکَ بِخَلِیقٍ ، قَالَ : فَدَعَا الْقَافَۃَ فَنَظَرُوا إلَیْہِ فَأَلْحَقُوہُ بِہِ ، قَالَ : فَوُلِدَ لَہُ مِنْہَا ولد کَثِیرٌ فَمَا عَیَّرُوہُ بِہِ۔",,,17784 17785,"حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنْ عَطَائٍ فِی الرَّجُلِ یَشُکُّ فِی وَلَدِہِ قَالَ : مُرْہُ فَلْیَسْتَلْحِقْہُ فَإِنَّ عُمَرَ بْنَ الْخَطَّابِ قَالَ : مَنْ أَقَرَّ أَنَّہُ أَصَابَ وَلِیدَۃً ، أَوْ غَشِیَ أَلْحَقْنَا بِہِ وَلَدَہَا ، وَسَأَلْت عِکْرِمَۃَ بْنِ خَالِدٍ ، فَقَالَ : مُرْہُ فَلْیَسْتَلْحِقْہُ۔",,,17785 17786,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : أَخْبَرَنَا سَعِیدُ بْنُ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ رَجَائِ بْنِ حَیْوَۃَ ، عَنْ قَبِیصَۃَ بْنِ ذُؤَیْبٍ ، قَالَ : قَالَ عُمَرُ : حَصِّنُوہُنَّ ، أَوْ لاَ تُحْصِنُوہُنَّ ، لاَ تَلِدُ امْرَأَۃٌ مِنْہُنَّ عَلَی فِرَاشِ أَحَدِکُمْ إلاَّ أَلْحَقْتہ بِہِ یَعْنِی السَّرَارِیَّ۔",,,17786 17787,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَمَّار ، عَنْ أَبِی مُسْلِمٍ ، عَنْ أَبِی عمْرَانَ ، عَنْ أَبِی یَحْیَی قَالَ: رَأَیْتُ رَجُلاً سَأَلَ ابْنَ عَبَّاسٍ ، فَقَالَ : یَا أبا عَبَّاسٍ إنِّی رَجُلٌ أَعْبَثُ بِذَکَرِی حَتَّی أُنْزِلَ ، قَالَ : فَقَالَ ابْنُ عَبَّاسٍ: أُفٍّ أُفٍّ ، ہُوَ خَیْرٌ مِنَ الزِّنَا وَنِکَاحُ الإِمَائِ خَیْرٌ مِنْہُ۔",,,17787 17788,حَدَّثَنَا وَکِیعٌ ، عَنْ عِصَام بْنِ قُدَامَۃَ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ ہُوَ الْفَاعِلُ بِنَفْسِہِ۔,,,17788 17789,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنْ شَیْخٍ قَالَ: سُئِلَ ابْنُ عُمَرَ عَنْہَا یَعْنِی الْخَضْخَضَۃَ ، فَقَالَ: ذَاکَ الْفَاعِلُ بِنَفْسِہِ۔",,,17789 17790,"حَدَّثَنَا وَکِیعٌ، عَنْ أَفْلَحَ، عَنِ الْقَاسِمِ قَالَ: سُئِلَ عَنِ {الَّذِینَ ہُمْ لِفُرُوجِہِمْ حَافِظُونَ إلاَّ عَلَی أَزْوَاجِہِمْ، أَوْ مَا مَلَکَتْ أَیْمَانُہُمْ فَإِنَّہُمْ غَیْرُ مَلُومِینَ فَمَنِ ابْتَغَی وَرَائَ ذَلِکَ فَأُولَئِکَ ہُمَ الْعَادُونَ}: فَمَنِ ابْتَغَی وَرَائَ ذَلِکَ فَہُوَ عَادٍ۔",,,17790 17791,"حدَّثَنَا ابْنُ نُمَیْرٍ وَأَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ أَبِی الزِّنَادِ ، عَنِ الأَعْرَجِ ، عَنْ أَبِی ہُرَیْرَۃَ قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الشِّغَارِ ، وَزَادَ ابْنُ نُمَیْرٍ : الشِّغَارُ أَنْ یَقُولَ الرَّجُلُ : زَوِّجْنِی ابْنَتَکَ حَتَّی أُزَوِّجَک ابْنَتِی ، أَوْ زَوِّجْنِی أُخْتَکَ حَتَّی أُزَوِّجَک أُخْتِی۔ (مسلم 61۔ ابن ماجہ 1884)",,,17791 17792,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ عَبْدِ اللہِ بْنِ دِینَارٍ ، عَنِ ابْنِ عُمَرَ وَعَبْدَۃ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ قَالَ: نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، عَنِ الشِّغَارِ۔(بخاری 6960۔ مسلم 58)",,,17792 17793,حَدَّثَنَا وَکِیعٌ ، عَنْ معقل ، عَنْ عَطَائٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِثْلہ,,,17793 17794,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ إِبْرَاہِیمَ بْنِ عَبْدِ الأَعْلَی ، عَنْ سُوَیْد بْنِ غَفَلَۃَ قَالَ : کَانُوا یَکْرَہُونَ الشِّغَارَ وَالشِّغَارُ : الرَّجُلُ یُزَوِّجُ الرَّجُلَ عَلَی أَنْ یُزَوِّجَہُ بِغَیْرِ مَہْرٍ۔",,,17794 17795,"حَدَّثَنَا عُمَرُ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ فِی الْمُشَاغِرَیْنِ : یُقَرَّانِ عَلَی نِکَاحِہِمَا وَیُؤْخَذُ لِکُلِّ وَاحِدٍ مِنْہُمَا صَدَاقٌ۔",,,17795 17796,"حَدَّثَنَا عَفَّانُ قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ حُمَیْدٍ ، عَنِ الْحَسَنِ ، عَنْ عِمْرَانَ بْنِ حُصَیْنٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : لاَ شِغَارَ فِی الإِسْلاَمِ۔ (ترمذی 1123۔ ابوداؤد 2574",,,17796 17797,حَدَّثَنَا عُمَرُ بْنُ ہَارُونَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی عَنِ الشِّغَارِ۔ (مسلم 62۔ احمد 3/339),,,17797 17798,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِِ ، عَنِ الْمَسْعُودِیِّ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الأَحْوَصِ ، عَنْ عَبْدِ اللہِ قَالَ : عَلَّمَنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ خُطْبَۃَ الصَّلاَۃِ وَخُطْبَۃَ الْحَاجَۃِ فَأَمَّا خُطْبَۃُ الصَّلاَۃِ فَالتَّشَہُّدُ ، وَأَمَّا خُطْبَۃُ الْحَاجَۃِ ، فَـ إِنَّ : الْحَمْدَ لِلَّہِ نَسْتَعِینُہُ وَنَسْتَغْفِرُہُ وَنَعُوذُ بِاللَّہِ مِنْ شُرُورِ أَنْفُسِنَا مَنْ یَہْدِہِ اللَّہُ فَلاَ مُضِلَّ لَہُ ، وَمَنْ یُضْلِلْ فَلاَ ہَادِیَ لَہُ ، وَأَشْہَدُ أَنْ لاَ إلَہَ إلاَّ اللَّہُ وَأَشْہَدُ أنَّ مُحَمَّدًا عَبْدُہُ وَرَسُولُہُ ، ثُمَّ یَقْرَأُ ثَلاَثَ آیَاتٍ مِنْ کِتَابِ اللہِ : {اتَّقُوا اللَّہَ حَقَّ تُقَاتِہِ وَلاَ تَمُوتُنَّ إلاَّ وَأَنْتُمْ مُسْلِمُونَ} {وَاتَّقُوا اللَّہَ الَّذِی تَسَائَلُونَ بِہِ وَالأَرْحَامَ إنَّ اللَّہَ کَانَ عَلَیْکُمْ رَقِیبًا} {اتَّقُوا اللَّہَ وَقُولُوا قَوْلاً سَدِیدًا یُصْلِحْ لَکُمْ أَعْمَالَکُمْ وَیَغْفِرْ لَکُمْ ذُنُوبَکُمْ} ثُمَّ تَعْمِدُ لِحَاجَتِک۔ (ابوداؤد 2111۔ احمد 1/432)",,,17798 17799,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ أَنَّ الْحُسَیْنَ بْنَ عَلِیٍّ کَانَ یُزَوِّجُ بَعْضَ بَنَاتِ الْحَسَنِ وَہُوَ یتعرق العرق۔,,,17799 17800,حَدَّثَنَا وَکِیعٌ ، عَنْ نَصْرٍ ، عَنْ عَطَائٍ أَنَّہُ قَرَأَ بِسْمِ اللہِ الرَّحْمَنِ الرَّحِیمِ ثُمَّ زَوَّجَ۔,,,17800 17801,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، عَنْ سُفْیَانَ ، عَنْ إسْمَاعِیلَ أَنَّ مَسْرُوقًا زَوَّجَ شُرَیْحًا وَلَمْ یَخْطُبْ ثُمَّ قَالَ : قَدْ قُضِیت تِلْکَ الْحَاجَۃَ۔",,,17801 17802,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی بَکْرِ بْنِ حَفْصٍ ، قَالَ : سَمِعْتُ عُرْوَۃَ بْنَ الزُّبَیْرِ یَقُولُ : خَطَبْت إلَی ابْنِ عُمَرَ ابْنَتَہُ ، فَقَالَ : إِنَّ ابْنَ أَبِی عَبْدِ اللہِ لأَہْلٌ أَنْ یُنْکَحَ ؟ نَحْمَدُ اللَّہَ وَنُصَلِّی عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَقَدْ زَوَّجْنَاک عَلَی مَا أَمَرَ اللَّہُ: {إمْسَاکٌ بِمَعْرُوفٍ ، أَوْ تَسْرِیحٌ بِإِحْسَانٍ} قَالَ : شُعْبَۃُ : أَحْسَبُہُ قَالَ : أَنْکَحَ عُمَرُ بْنُ الْخَطَّابِ رَجُلاً وَہُوَ یَمْشِی ، قَالَ : شُعْبَۃُ : قَالَ أَبُو بَکْرِ بْنُ حَفْصٍ : لاَ أَدْرِی الَّذِی قَالَ: أَحْسَبُہُ عُرْوَۃُ بْنُ الزُّبَیْرِ أَوِ ابْنُ عُمَرَ۔ (بیہقی 147)",,,17802 17803,"حَدَّثَنَا حَفْصٌ ، عَنْ عَبْدِ اللہِ بْنِ مُسْلِمٍ ، عَنْ حُمَیْدَۃَ مَوْلاَۃٍ لِعُمَرَ بْنِ عَبْدِ الْعَزِیزِ قَالَتْ : کَانَ عُمَرُ یَقُولُ : لاَ تَدَعِینَ بَنَاتِی یَنَمْنَ مُسْتَلْقِیَاتٍ عَلَی ظُہُورِہِنَّ فَإِنَّ الشَّیْطَانَ یَظَلُّ یَطْمَعُ مَا دُمْنَ کَذَلِکَ۔",,,17803 17804,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ ہِشَامٍ قَالَ : کَانَ ابْنُ سِیرِینَ یَکْرَہُ أَنْ تَکُونَ الْمَرْأَۃُ مُسْتَلْقِیَۃً",,,17804 17805,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ قَالَ : إذَا أَسْلَمَتِ الْمَرْأَۃُ وَلَہَا زَوْجٌ یَہُودِیٌّ ، أَوْ نَصْرَانِیٌّ ، أَوْ مَجُوسِیٌّ ، وَلَمْ یُسْلِمْ ہُوَ فَلاَ شَیْئَ لَہَا مَا لَمْ یَدْخُلْ بِہَا۔",,,17805 17806,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ عُبَیْدَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : لاَ شَیْئَ لَہَا۔",,,17806 17807,"حَدَّثَنَا عَبَّادُ بن العَوام ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ قَالَ : یُفَرَّقُ بَیْنَہُمَا وَلَہَا نِصْفُ الصَّدَاقِ۔",,,17807 17808,"حَدَّثَنَا حَرَمِیُّ بْنُ عُمَارَۃَ بْنِ أَبِی حَفْصَۃَ ، عَنْ شُعْبَۃَ ، عَنِ الْہَیْثُمِ ، عَنْ حَمَّادٍ قَالَ : لَہَا نِصْفُ الصَّدَاقِ۔",,,17808 17809,"حَدَّثَنَا یَزِیدُ، عَنْ حَبِیبٍ ، عَنْ عَمْرِو بْنِ ہَرِمٍ ، عَنْ جَابِرِ بْنِ زَیْدٍ؛ سُئِلَ عَنْ رَجُلٍ کَانَتْ تَحْتَہُ نَصْرَانِیَّۃٌ فَأَسْلَمَتْ ، وَأَبَی زَوْجُہَا أَنْ یُسْلِمَ قَالَ : أَرَی أَنْ یُفَرَّقَ بَیْنَہُمَا ، فَإِنْ کَانَ دَخَلَ بِہَا فَلَہَا الْمَہْرُ کَامِلاً ، وَإِنْ لَمْ یَکُنْ دَخَلَ بِہَا رَدَّتْ إلَیْہِ مَا أَعْطَاہَا",,,17809 17810,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ أَنَّہُ قَالَ : لَہَا نِصْفُ الصَّدَاقِ۔",,,17810 17811,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ الشَّیْبَانِیِّ ، عَمَّنْ حَدَّثَہُ عَنْ مَسْرُوقٍ أَنَّہُ قَالَ : فِی رَجُلٍ أَقَرَّ لامْرَأَتِہِ بِصَدَاقِہَا فِی مَرَضِہِ قَالَ : لاَ یَجُوزُ ذَلِکَ",,,17811 17812,حَدَّثَنَا ہُشَیْمٌ ، عَنِ الْعَوَّامِ أَنَّ مَسْرُوقًا أَجَازَ إقْرَارَہُ۔,,,17812 17813,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْحَکَمِ ، عَنْ إبْرَاہِیمَ قَالَ : یَجُوزُ إقْرَارُہُ لَہَا بِصَدَاقِ مِثْلِہَا۔",,,17813 17814,حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ أَنَّہُ کَانَ یُجِیزُ ذَلِکَ۔,,,17814 17815,حَدَّثَنَا ہُشَیْمٌ ، عَنْ بَعْضِ أَصْحَابِہِ ، عَنِ الشَّعْبِیِّ ، أَنَّہُ کَانَ لاَ یُجِیزُ إقْرَارَہُ لَہَا لأَنَّہَا وَارِثٌ ، وَلاَ یَجُوزُ وَصِیَّۃٌ لِوَارِثٍ۔,,,17815 17816,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ قَالَ : الْقَوْلُ قَوْلُ الرَّجُلِ وَقَالَ حَمَّادُ ، وَابْنُ ذَکْوَانَ : الْقَوْلُ قَوْلُہَا مَا بَیْنَہَا وَبَیْنَ مَہْرِ مِثْلِہَا۔",,,17816 17817,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : قَالَ : ہُوَ قَوْلُہَا مَا بَیْنَہَا وَبَیْنَ صَدَاقِ نِسَائِہَا۔",,,17817 17818,"حَدَّثَنَا عَبْدُالرَّحْمَنِ بْنُ مَہْدِیٍّ، عَنْ سُفْیَانَ، عَنْ عَطَائِ بْنِ السَّائِبِ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ وَعَنْ إسْمَاعِیلَ بْنِ سَالِمٍ، عَنِ الشَّعْبِیِّ قَالاَ: فِی رَجُلٍ تَزَوَّجَ امْرَأَۃً عَلَی عَاجِلٍ، أَوْ آجِلٍ فَدَخَلَ بِہَا قَالاَ: الْبَیِّنَۃُ أَنَّہُ دَفَعَہُ إلَیْہَا۔",,,17818 17819,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ فِی الْمَرْأَۃِ تَدَّعِی الصَّدَاقَ بَعْدَ وَفَاۃِ زَوْجِہَا قَالَ : یَسْأَلُہَا الْبَیِّنَۃَ۔",,,17819 17820,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ خَالِدِ بْنِ دِینَارٍ ، عَنِ الْحَکَمِ قَالَ : بینتہا وَقَالَ حَمَّادٌ : صَدَاقُ نِسَائِہَا۔",,,17820 17821,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ قَالَ : الْبَیِّنَۃُ عَلَی أَہْلِ الصَّدَاقِ أَوْلِیَائِ الْمَرْأَۃِ وَعَلَی أَہْلِ الرَّجُلِ الْمُخْرَجِ مِنْ ذَلِکَ۔",,,17821 17822,"حدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنِ الْعَلاَئِ بْنِ الْمُسَیَّبِ ، عَنِ الْفُضَیْلِ ، عَنْ إبْرَاہِیمَ فِی الرَّجُلِ یَقْذِفُ امْرَأَتَہُ قَبْلَ أَنْ یَدْخُلَ بِہَا قَالَ : یُلاَعِنُہَا وَلَہَا نِصْفُ الصَّدَاقِ فَإِنْ ظَہَرَ بِہَا حَمْلٌ فَلَہَا الصَّدَاقُ کَامِلاً۔",,,17822 17823,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ مُطَرِّفٍ ، عَنْ عَامِرٍ قَالَ : إذَا قَذَفَ الرَّجُلُ امْرَأَتَہُ قَبْلَ أَنْ یَدْخُلَ بِہَا لاَعَنَہَا وَلَہَا نِصْفُ الصَّدَاقِ۔",,,17823 17824,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، وَابْنِ عُمَرَ قَالاَ : إذَا قَذَفَہَا قَبْلَ أَنْ یَدْخُلَ بِہَا لاَعَنَہَا وَلَہَا نِصْفُ الصَّدَاقِ۔",,,17824 17825,حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ زُرَارَۃَ بْنِ أَوْفَی مِثْلَہُ۔,,,17825 17826,حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ مِثْلَہُ۔,,,17826 17827,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ قَالَ : إذَا قَذَفَ الرَّجُلُ امْرَأَتَہُ قَبْلَ أَنْ یَدْخُلَ بِہَا لاَعَنَ وَلَہَا نِصْفُ الصَّدَاقِ۔",,,17827 17828,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُطَرِّفٍ ، عَنِ الْحَکَمِ قَالَ : إذَا کَانَ بِہَا حَمْلٌ فَلَہَا الصَّدَاقُ کَامِلاً۔",,,17828 17829,"حَدَّثَنَا أَبُو بَحْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ قَالَ : یُلاَعِنُ وَلَہَا نِصْفُ الصَّدَاقِ۔",,,17829 17830,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقْسِمُ بَیْنَ نِسَائِہِ فَیَعْدِلُ ثُمَّ یَقُولُ : اللَّہُمَّ ہَذِہِ قِسْمَتِی فِیمَا أَمْلِکُ فَلاَ تَلُمْنِی فِیمَا تَمْلِکُ أَنْتَ وَلاَ أَمْلِکُ",,,17830 17831,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ: أَخْبَرَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ، عَنْ عَبْدِ اللہِ بْنِ یَزِیدَ، عَنْ عَائِشَۃَ قَالَتْ: کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقْسِمُ بَیْنَ نِسَائِہِ فَیَعْدِلُ ثُمَّ یَقُولُ : اللَّہُمَّ ہَذَا فِعْلِی فِیمَا أَمْلِکُ فَلاَ تَلُمْنِی فِیمَا تَمْلِکُ وَلاَ أَمْلِکُ۔ (احمد 6/144۔ ابن حبان 4205)",,,17831 17832,حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ یَحْیَی بْنِ سَعِیدٍ أَنَّ مُعَاذًا کَانَتْ لَہُ امْرَأَتَانِ ، وَکَانَ یَکْرَہُ أَنْ یَتَوَضَّأَ فِی یَوْمِ ہَذِہِ عِنْدَ ہَذِہِ ، أَوْ یَکُونَ فِی یَوْمِ ہَذِہِ عِنْدَ ہَذِہِ,,,17832 17833,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ ہَارُونَ بْنِ إبْرَاہِیمَ ، قَالَ : سَمِعْتُ مُحَمَّدًا یَقُولُ فِی الذی لہ امْرَأَتَانِ : یُکْرَہُ أَنْ یَتَوَضَّأَ فِی بَیْتِ إحْدَاہُمَا دُونَ الأُخْرَی۔",,,17833 17834,"حَدَّثَنَا مُحَمَّدُ بْنُ بکر ، عَنْ عُبَیْدٍ أَبِی الْحَزمِ ، عَنْ جَابِرِ بْنِ زَیْدٍ قَالَ : کَانَتْ لِی امْرَأَتَانِ فَکُنْت أَعْدِلُ بَیْنَہُمَا حَتَّی فِی الْقُبَلِ",,,17834 17835,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَنْ شَرِیکٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ قَالَ : کَانُوا یَسْتَحِبُّونَ أَنْ یَعْدِلُوا بَیْنَ النِّسَائِ حَتَّی فِی الطِّیبِ ، یَتَطَیَّبُ لِہَذِہِ کَمَا یَتَطَیَّبُ لِہَذِہِ۔",,,17835 17836,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ فِی الرَّجُلِ یَجْمَعُ بَیْنَ الضَّرَائِرِ ، فَقَالَ : إِنْ کَانُوا لَیُسَوُّونَ بَیْنَہُمْ حَتَّی تَبْقَی الْفَضْلَۃُ مِمَّا لاَ یُکَالُ مِنَ السَّوِیقِ وَالطَّعَامِ ، فَیَقْسِمُونَہُ کَفًّا کَفًّا إذَا کَانَ یَبْقَی الشَّیْئُ مِمَّا لاَ یَسْتَطِعْ کَیْلَہُ۔",,,17836 17837,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ قَالَ : لَمَّا مَرِضَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ اسْتَحَلَّ نِسَائَہُ أَنْ یُمَرَّضَ فِی بَیْتِ عَائِشَۃَ قَالَ : فَأَحْلَلْنَ لَہُ ، فَکَانَ فِی بَیْتِ عَائِشَۃَ۔\n\n(بخاری 198۔ مسلم 91)",,,17837 17838,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہَمَّامِ بْنِ یَحْیَی ، عَنْ قَتَادَۃَ ، عَنِ النَّضْرِ بْنِ أَنَسٍ ، عَنْ بَشِیرِ بْنِ نَہِیکٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ کَانَت لَہُ امْرَأَتَانِ ، فَکَانَ یَمِیلُ مَعَ إحْدَاہُمَا عَلَی الأُخْرَی بُعِثَ یَوْمَ الْقِیَامَۃِ وَأَحَدُ شِقَّیْہِ سَاقِطٌ۔ (ترمذی 1141۔ ابوداؤد 2126",,,17838 17839,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ غَالِبٍ قَالَ : سَأَلْتُ الْحَسَنَ ، أَوْ سُئِلَ عَنْ رَجُلٍ تَکُونُ لَہُ امْرَأَتَانِ فِی بَیْتٍ قَالَ : کَانُوا یَکْرَہُونَ الْوَجْسَ وَہُوَ أَنْ یَطَأَ إحْدَاہُمَا وَالأُخْرَی تری ، أَوْ تَسْمَعُ۔",,,17839 17840,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ أَبِی شَیْبَۃَ ، قَالَ : سَمِعْتُ عِکْرِمَۃَ یُحَدِّثُ عَنِ ابْنِ عَبَّاسٍ ، قَالَ : کَانَ یَنَامُ بَیْنَ جَارِیَتَیْنِ",,,17840 17841,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ، عَنْ شَرِیکٍ، عَنْ لَیْثٍ، عَنْ عَطَائٍ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ یَنَامَ الرَّجُلُ بَیْنَ الأَمَتَیْنِ۔,,,17841 17842,"ہُشَیْمٌ ، عَنْ خَالِدٍ ، عَنْ عزرۃ عن شریح أَنّہ قَالَ فی رَجُلٍ أُہْدیَتْ إلَیْہِ امْرَأَتُہُ فَزَعَمَ أَنَّہُ لَمْ یَدْخُلْ بِہَا ، وَأَقَرَّتْ ہِیَ بِذَلِکَ ، فَقَضَی لَہَا بِنِصْفِ الصَّدَاقِ ، وَأَلْزَمَہَا الْعِدَّۃَ وَقَالَ : لاَ أُصدِّقُکَ عَلَی نَفْسِکَ وَلاَ أُصدِّقُکِ لِنَفْسِک۔",,,17842 17843,"حَدَّثَنَا مُحَمَّدُ بْنُ یَزِیدَ ، عَنْ أَیُّوبَ أَبِی الْعَلاَئِ ، عَنْ مَنْصُورٍ ، عَنِ الْحَسَنِ قَالَ : عَلَیْہِ کَامِلاً إِنْ شَائَتْ أَخَذَتْہُ ، وَإِنْ شَائَتْ تَرَکَتْہُ۔",,,17843 17844,"حدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ عُمَرَ بْنِ عَامِرٍ قَالَ : سَأَلَ الشَّعْبِیَّ رَجُلٌ ، فَقَالَ رَجُلٌ قَالَ لِلرَّجُلِ : إذَا مَضَی شَوَّالٌ زَوَّجْتُک ابْنَتِی ، فَقَالَ : لَیْسَ ہَذَا بِنِکَاحٍ۔",,,17844 17845,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ فِی الْعَبْدِ یَتَزَوَّجُ بِإِذْنِ مَوْلاَہُ قَالَ : عَلَیْہِ النَّفَقَۃُ۔",,,17845 17846,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ أَبِیہِ ، عَنِ الْحَسَنِ قَالَ : لاَ تَحَسَّرُ الْمَرْأَۃُ عِنْدَ وَلَدٍ وَلا وَالِدٍ وَلاَ أَخٍ إلاَّ عِنْدَ زَوْجِہَا۔",,,17846 17847,"حَدَّثَنَا وَکِیعٌ ، وَابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ أَبِی الزَّعْرَائِ ، عَنْ عِکْرِمَۃَ قَالَ : مُبَاشَرَۃُ الرَّجُلِ أُمَّہُ وَأُخْتَہُ شُعْبَۃٌ مِنَ الزِّنَا۔",,,17847 17848,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عَاصِمٍ ، عَنْ أَبِی عُثْمَانَ ، عَنْ سَلْمَانَ قَالَ : مَا أُبَالِی إذَا خَلَوْت بِأَہْلِی وَأَغْلَقْت بَابِی وَأَرْخَیْت سِتْرِی حَدَّثْت بِہِ النَّاسَ ، أَوْ صَنَعْت ذَلِکَ وَالنَّاسُ یَنْظُرُونَ۔",,,17848 17849,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ عُمَر بْنِ حَمْزَۃَ الْعُمَرِیِّ قَالَ : حدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ سَعْدٍ مَوْلًی لأَبِی سُفْیَانَ ، قَالَ : سَمِعْتُ أَبَا سَعِیدٍ الْخُدْرِیِّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ مِنْ شَرِّ النَّاسِ عِنْدَ اللہِ مَنْزِلَۃً یَوْمَ الْقِیَامَۃِ الرَّجُلَ یُفْضِی إلَی امْرَأَتِہِ وَتُفْضِی إلَیْہِ ثُمَّ یَنْشُرُ سِرَّہَا۔\n\n(مسلم 124۔ ابوداؤد 4837)",,,17849 17850,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنِ الْجُرَیْرِیِّ ، عَنْ أَبِی نَضْرَۃَ ، عَنِ الطُّفَاوِیِّ ، عَنْ أَبِی ہریرۃ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : عسی أَحَدُکُمْ یُخْبِرُ بِمَا صَنَعَ بِأَہْلِہِ ؟ وَعَسَی إحْدَاکُنَّ أَنْ تُخْبِرَ بِمَا یصْنَعُ بِہَا زَوْجُہَا ، فَقَامَتِ امْرَأَۃٌ سَوْدَائُ ، فَقَالَتْ : یَا رَسُولَ اللہِ ، إنَّہُمْ لَیَفْعَلُونَ وَإِنَّہُنَّ لَیَفْعَلْنَ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: أَلاَ أُخْبِرُکُمْ بِمَثَلِ ذَلِکَ؟ إنما مَثَلُ ذَلِکَ کَمَثَلِ شَیْطَانٍ لَقِیَ شَیْطَانَۃً فَوَقَعَ عَلَیْہَا فِی الطَّرِیقِ وَالنَّاسُ یَنْظُرُونَ فَقَضَی حَاجَتَہُ مِنْہَا وَالنَّاسُ یَنْظُرُونَ۔(ابوداؤد 4015۔ احمد 2/540)",,,17850 17851,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ عَوَّامٍ ، عَنْ مُجَاہِدٍ : {وَإِذَا مَرُّوا بِاللَّغْوِ مَرُّوا کِرَامًا} قَالَ : کانوا إذَا أَتَوْا عَلَی ذِکْرِ النِّکَاحِ کَنَوْا عَنْہُ",,,17851 17852,"حَدَّثَنَا حَفْصٌ، عَنْ مُحَمَّدِ بْنِ قَیْسٍ، عَنْ حَبِیبٍ قَالَ: کَانَ عُمَرُ لاَ یُجِیزُ النِّکَاحَ فِی عَامِ سَنَۃٍ یَعْنِی مَجَاعَۃً۔",,,17852 17853,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عُبَیْدَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : إذَا أنْکَحَ الْمَرْأَۃَ الْوَلِیُّ فَلَمْ تَرْضَ ثُمَّ رَضِیَتْ بَعْدُ لَمْ یَصْلُحْ ذَلِکَ النِّکَاحُ حَتَّی یَکُونَ نِکَاحٌ جَدِیدٌ۔",,,17853 17854,"حدَّثَنَا ہُشَیْمٌ، عَنْ مُجَالِدٍ ، عَنِ الشَّعْبِیِّ ، عَنْ عُمَرَ ، قَالَ: إذَا أَقَرَّ بِوَلَدِہِ مَرَّۃً وَاحِدَۃً فَلَیْسَ لَہُ أَنْ یَنْفِیَہُ۔",,,17854 17855,"حَدَّثَنَا حَفْصٌ ، عَنْ مُجَالِدٍ ، عَنِ الشَّعْبِیِّ ، عَنْ عَلِیٍّ قَالَ : إذَا أَقَرَّ بِہِ فَلَیْسَ لَہُ أَنْ یَنْفِیَہُ",,,17855 17856,"حَدَّثَنَا حَفْصٌ، عَنْ مُجَالِدٍ، عَنْ شُرَیْحٍ قَالَ: إذَا أَقَرَّ بِہِ، أَوْ ہُنِّئَ بِہِ، أَوْ أَوْلَمَ عَلَیْہِ فَلَیْسَ لَہُ أَنْ یَنْتَفِیَ مِنْہُ",,,17856 17857,"حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الشَّعْبِیِّ وَغَیْرِہِ ، عَنْ عُمَرَ ، قَالَ : إذَا أَقَرَّ بِالْوَلَدِ طَرْفَۃَ عَیْنٍ فَلَیْسَ لَہُ أَنْ یَنْفِیَہُ۔",,,17857 17858,"حَدَّثَنَا ابْنُ أَبِی زَائِدَۃَ، عَنْ مُجَالِدٍ، عَنِ الشَّعْبِیِّ قَالَ: جَائَ رَجُلٌ بِابْنٍ لَہُ قَدْ أَقَرَّ بِہِ ثُمَّ أَرَادَ أَنْ یَنْفِیَہُ فَشَہِدُوا أَنَّہُ وُلِدَ فِی بَیْتِہِ وَأَنَّہُمْ ہَنَّؤُوہُ بِہِ وَأَقَرَّ بِہِ ، فَقَالَ شُرَیْحٌ : الْزَمْ وَلَدَک قَالَ عَامِرٌ : کان عُمَرَ یَقْضِی بِذَلِکَ۔",,,17858 17859,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ قَالَ : إذَا أَقَرَّ الرَّجُلُ بِوَلَدِہِ فَلَیْسَ لَہُ أَنْ یَنْفِیَہُ عَلَی حَالٍ۔",,,17859 17860,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ وَعُبَیْدَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : إذَا أَقَرَّ بِالْوَلَدِ فَلَیْسَ لَہُ أَنْ یَنْتَفِیَ مِنْہُ ، وَقَالَ حَمَّادٌ : إذَا أَقَرَّ بِالْحَمْلِ فَلَیْسَ لَہُ أَنْ یُنْکِرَہُ ، إِنْ شَائَ یَقُولُ : أَخْطَأْت فِی الْعِدَّۃِ",,,17860 17861,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ حَمَّادٍ قَالَ : إذَا تَبَیَّنَ حَمْلُ سُرِّیَّتِہِ فَلَہُ إنْکَارُہُ مَا لَمْ یُقِرَّ بِہِ بَعْدَ مَا تَضَعُ ، وَإِنْ کَانَ قَدْ أَقَرَّ بِالْحَمْلِ ثُمَّ أَنْکَرَہُ بَعْدَ مَا تَضَعُ فَلَہُ ذَلِکَ۔",,,17861 17862,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنَ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ قَالَ : إذَا أَقَرَّ بِوَلَدِہِ ثُمَّ نَفَاہُ لَزِمَہُ۔",,,17862 17863,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ قَالَ : إذَا انْتَفَی الرَّجُلُ مِنْ وَلَدِہِ لاَعَنَ أُمَّہُ إِنْ کَانَتْ حَیَّۃً ، وَإِنْ کَانَتْ قَدْ مَاتَتْ جُلِدَ الْحَدَّ وَأُلْزِقَ بِہِ الْوَلَدُ فَإِنْ کَانَ ابْنَ سُرِّیَّۃٍ صَارَ عَبْدًا۔",,,17863 17864,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَمَّادٍ وَالْحَکَمِ قَالاَ : إذَا أَقَرَّ بِوَلَدِہِ ثُمَّ نَفَاہُ قَالَ الْحَکَمُ : یُضْرَبُ وَقَالَ حَمَّادٌ : یَلْزَمُ الْوَلَدُ بِالإِقْرَارِ وَیُلاَعِنُ وَذَکَرَ أَنَّ سُفْیَانَ کَانَ یَقُولُہُ۔",,,17864 17865,"حَدَّثَنَا عَبْدَۃُ ، عَنْ سُفْیَانَ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ فِی الرَّجُلِ یُقِرُّ بِوَلَدِہِ ثُمَّ یَنْتَفِی مِنْہُ قَالَ : یُلاَعِنُ بِکِتَابِ اللہِ وَیَلْزَمُ الْوَلَدُ بِقَضَائِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,17865 17866,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ حَمَّادٍ فِی رَجُلٍ أَقَرَّ بِوَلَدٍ لہ مِنْ جَارِیَتِہِ حَتَّی صَارَ رَجُلاً وَزَوَّجَہُ ثُمَّ أَنْکَرَہُ قَالَ : لَیْسَ إنْکَارُہُ بِشَیْئٍ ، یُلْزَقُ بِہِ",,,17866 17867,"حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ قَالَ لَہُ : أَنْ یَنْفِیَہُ ، وَإِنْ کَانَ رَجُلاً۔",,,17867 17868,"حَدَّثَنَا عَبْدَۃُ ، عَنْ عَاصِمٍ قَالَ : جَائَتِ امْرَأَۃٌ إلَی أَبِی مُوسَی وَأَبُوہَا وَزَوْجُہَا وَأُمُّہَا وَہِیَ حُبْلَی یَقُولُ زَوْجُہَا : ہِیَ جَارِیَۃٌ وَإِنَّمَا کُنْت أَلْعَبُ مَعَہَا فَکَلَّمَ الْجَارِیَۃَ ، فَقَالَتْ : زَوَّجَنِیہِ أَبِی وَأُمِّی ، وَکَانَ یَدْخُلُ عَلَیَّ فَیَصْنَعُ بِی مَا یَصْنَعُ الرَّجُلُ بِامْرَأَتِہِ قَالَ : فَضَرَبَ رَأْسَہُ بِالدِّرَّۃِ وَقَالَ : ہِیَ امْرَأَتُک وَالْوَلَدُ وَلَدُک۔",,,17868 17869,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ وَہُوَ قَوْلُ قَتَادَۃَ : {إذَا أُحْصِنَّ} قَالَ : إذَا أَحْصَنَتْہُنَّ الْبُعُولَۃُ۔",,,17869 17870,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ حُصَیْنٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ کَانَ یَقْرَؤُہَا : {فَإِذَا أُحْصِنَّ} یَقُولُ : إذَا تَزَوَّجْنَ",,,17870 17871,"حَدَّثَنَا ابْنُ إدْرِیسَ، عَنِ الأَعْمَشِِ، عَنْ إبْرَاہِیمَ، عَنِ الأَسْوَدِ، عَنْ عَائِشَۃَ قَالَتْ: کَانَ زَوْجُ بَرِیرَۃَ حُرًّا",,,17871 17872,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ عَاصِمٍ ، عَنِ الشَّعْبِیِّ قَالَ : کَانَ زَوْجُہَا حُرًّا۔",,,17872 17873,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ قَالَ : حدَّثَنَا سَعِیدٌ ، عَنْ أَبِی مَعْشَرٍ ، عَنِ النَّخَعِیِّ ، عَنِ الأَسْوَدِ أَنَّ عَائِشَۃَ حَدَّثَتْہُ : أن زَوْجَ بَرِیرَۃَ کَانَ حُرًّا حِینَ أُعْتِقَتْ۔",,,17873 17874,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، وَابْنُ إدْرِیسَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنْ صَفِیَّۃَ ابْنَۃِ أَبِی عُبَیْدٍ قَالَتْ : کَانَ زَوْجُ بَرِیرَۃَ عَبْدًا",,,17874 17875,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ أَنَّ زَوْجَ بَرِیرَۃَ کَانَ عَبْدًا۔,,,17875 17876,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنْ عِکْرِمَۃَ ، أَنَّ زَوْجَ بَرِیرَۃَ کَانَ عَبْدًا أَسْوَدَ یُقَالُ لَہُ مُغِیثٌ ، عَبْدٌ لِبَنِی الْمُغِیرَۃِ مِنْ بَنِی مَخْزُومٍ۔,,,17876 17877,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ قَالَ : حدَّثَنَا سَعِیدُ بْنُ أَبِی عَرُوبَۃَ ، عَنْ أَیُّوبَ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : کَانَ عَبْدًا أَسْوَدَ لِبَنِی الْمُغِیرَۃِ یُقَالُ لَہُ مُغِیثٌ کَأَنِّی أَنْظُرُ إلَیْہِ فِی طُرُقِ الْمَدِینَۃِ یَتْبَعُہَا وَدُمُوعُہُ تسیل عَلَی لِحْیَتِہِ یَتَرَضَّاہَا کَی تَخْتَارَہُ فَلَمْ تَخْتَرْہُ یَعْنِی زَوْجَ بَرِیرَۃَ۔",,,17877 17878,"حَدَّثَنَا حَفْصٌ، عَنْ ہِشَامٍ، عَنْ عِکْرِمَۃَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: کان زَوْجُ بَرِیرَۃَ عَبْدا أَسْوَدُ یُقَالُ لَہُ مُغِیثٌ۔",,,17878 17879,حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عَنْ عَائِشَۃَ أَنَّہَا أَعْتَقَتْ بَرِیرَۃَ فَخَیَّرَہَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَکَانَ لَہَا زَوْجٌ حُرٌّ۔,,,17879 17880,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ سِمَاکٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ قَالَتْ : کَانَ زَوْجُ بَرِیرَۃَ عَبْدًا",,,17880 17881,"حدَّثَنَا وَکِیعٌ ، عَنْ زِیَادِ بْنِ خَیْثَمَۃَ ، عَنْ نُعَیْمِ بْنِ أَبِی ہِنْدٍ ، عَنْ عُمَرَ الأَعْوَرِ ، عَنْ عَبْدِ اللہِ بْنِ جَعْفَرٍ ، قَالَ : قَالَتْ عَائِشَۃُ : الْبَیَاضُ نِصْفُ الْحُسْنِ",,,17881 17882,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الأَحْوَصِ ، عَنْ عَبْدِ اللہِ قَالَ : أعْطِیَ یُوسُفُ وَأُمُّہُ ثُلُثَ الْحُسْنِ۔",,,17882 17883,"حَدَّثَنَا عَفَّانُ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ ثَابِتٍ ، عَنْ أَنَسٍ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : أُعْطِیَ یُوسُفُ شَطْرَ الْحُسْنِ۔ (احمد 3/148۔ حاکم 570",,,17883 17884,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنِ الْجَرِیرِیِّ ، عَنْ أَبِی نَضْرَۃَ ، عَنِ الطُّفَاوِیِّ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: لاَ یُبَاشِرُ الرَّجُلُ الرَّجُلَ وَلاَ الْمَرْأَۃُ الْمَرْأَۃَ إِلاَّ الْوَالِدُ وَلَدَہُ أَوِ الْوَلَدُ وَالِدَہُ۔\n\n(ابوداؤد 4015۔ احمد 2/325)",,,17884 17885,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ مَنْصُورٍ ، عَنْ أَبِی وَائِلٍ ، عَنْ عبد اللہِ قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ تُبَاشِرَ الْمَرْأَۃُ الْمَرْأَۃَ فِی ثَوْبٍ وَاحِدٍ أَجْلَ أَنْ تَصِفَہَا لِزَوْجِہَا۔ (بخاری 5240۔ ابوداؤد 2143",,,17885 17886,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنِ الضَّحَّاکِ بْنِ عُثْمَانَ قَالَ : أخبرنی زَیْدُ بْنُ أَسْلَمَ ، عْن عَبْدِ الرَّحْمَنِ بْنِ أَبِی سَعِیدٍ الْخُدْرِیِّ ، عَنْ أَبِیہِ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : لاَ تُفْضِی الْمَرْأَۃُ إلَی الْمَرْأَۃِ فِی ثَوْبٍ وَاحِدٍ وَلاَ الرَّجُلُ إلَی الرَّجُلِ فِی ثَوْبٍ وَاحِدٍ۔ (ترمذی 2793۔ ابوداؤد 4014)",,,17886 17887,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ قَالَ : حَدَّثَنَی یَحْیَی بْنُ أَیُّوبَ الْمِصْرِیُّ قَالَ : أَخْبَرَنِی عَیَّاشُ بْنُ عَبَّاسٍ الْحِمْیَرِیُّ ، عَنْ أَبِی الْحُصَیْنِ الْحَجَرِیِّ الْہَیْثَمِ ، عَنْ عَامِرٍ الْحَجَرِیِّ ، قَالَ : سَمِعْتُ أَبَا رَیْحَانَۃَ صَاحِبَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَنْہَی عَنْ مُعَاکَمَۃِ ، أَوْ مُکَاعَمَۃِ الْمَرْأَۃِ الْمَرْأَۃَ لَیْسَ بَیْنَہُمَا شَیْئٌ ، ومُعَاکَمَۃِ أَوْ مُکَاعَمَۃِ الرَّجُلِ الرَّجُلَ فِی شِعَارٍ لَیْسَ بَیْنَہُمَا شَیْئٌ۔\n\n(ابوداؤد 4046۔ احمد 4/134)",,,17887 17888,"حَدَّثَنَا أَحْمَدُ بْنُ عَبْدِ اللہِ ، عَنِ أبی شِہَابٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یُبَاشِرَ الرَّجُلُ الرَّجُلَ وَالْمَرْأَۃُ الْمَرْأَۃَ قَالَ ابْنُ أَبِی لَیْلَی : وَأَنَا أَرَی فِی ذَلِکَ تَعْزِیرًا۔ (حاکم 287۔ احمد 3/348)",,,17888 17889,"حَدَّثَنَا عُبَید اللہِ ، عَنْ إسْرَائِیلَ ، عَنْ سِمَاکٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یُبَاشِرَ الرَّجُلُ الرَّجُلَ وَالْمَرْأَۃُ الْمَرْأَۃَ۔ (احمد 1/314۔ ابن حبان 5582)",,,17889 17890,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ زَیْدِ بْنِ أَسْلَمَ أَنَّ رَجُلاً سَأَلَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَسْتَأْذِنُ عَلَی أُمِّی ؟ قَالَ : نَعَمْ ، أَتُحِبُّ أَنْ تَرَاہَا عُرْیَانَۃً۔ (بیہقی 97",,,17890 17891,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ مُسْلِمِ بْنِ نذیر ، عَنْ حُذَیْفَۃَ قَالَ : إِنْ لَمْ تَفْعَلْ أَوْشَکَ أَنْ تَرَی مِنْہَا مَا یَسُوئُک",,,17891 17892,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی حَصِینٍ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ، قَالَ : قَالَ رجل لِعُمَرَ : أسْتَأْذِنُ عَلَی أُمِّی ؟ قَالَ : نَعَمْ ، اسْتَأْذِنْ عَلَیْہَا۔",,,17892 17893,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ ، عَنْ عَلْقَمَۃَ ، عَنْ عَبْدِ اللہِ قَالَ : جَائَ إلَیْہِ رَجُلٌ ، فَقَالَ: أَسْتَأْذِنُ عَلَی أُمِّی ؟ قَالَ : نَعَمْ ، مَا عَلَی کُلِّ أَحْیَانِہَا تُحِبُّ أَنْ تَرَاہَا۔",,,17893 17894,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ قَالَ : کَانَ عَطَائٌ وَأَخَوَاتٌ لَہُ بِمَکَّۃَ فِی بَیْتٍ وَأَہْلُ مَکَّۃَ یَخْتَلِفُ أَحَدُہُمْ إلَی أَہْلِہِ فِی اللَّیْلِ مِرَارًا ، فَکَانَ یَأْتِیہِنَّ بِاللَّیْلِ فَسَأَلَ ابْنَ عَبَّاسٍ : أَسْتَأْذِنُ عَلَیْہِنَّ کُلَّمَا دَخَلْت؟ فَقَالَ : نَعَمْ ، وَلَمْ یُرَخِّصْ لَہُ فِی الدُّخُولِ عَلَیْہِنَّ بِغَیْرِ إذْنٍ۔",,,17894 17895,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ أَشْعَثَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ قَالَ : اسْتَأْذِنْ عَلَی أُمِّکَ ، وَإِنْ کَانَتْ عَجُوزًا",,,17895 17896,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ أَشْعَثَ ، عَنِ الزُّہْرِیِّ ، عَنْ ہُزَیْلٍ ، عَنْ عَبْدِ اللہِ قَالَ : عَلَیْکُمْ أَنْ تَسْتَأْذِنُوا عَلَی أُمَّہَاتِکُمْ۔",,,17896 17897,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ أَشْعَثَ ، عَنْ کُرْدُوسٍ ، عَنْ أَبِیہِ ، عَنْ عَبْدِ اللہِ قَالَ : یَسْتَأْذِنُ الرَّجُلُ عَلَی أَبِیہِ وَأُمِّہِ وَعَلَی ابْنِہِ وَعَلَی أخیہ وعلی أُخْتِہِ۔",,,17897 17898,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، وعَنْ ہِشَامٍ ، عَنِ الْحَسَنِ قَالاَ یَسْتَأْذِنُ عَلَیْہَا۔,,,17898 17899,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنِ الْجُرَیْرِیِّ ، عَنْ أَبِی السَّلِیلِ ، عَنْ صِلَۃَ قَالَ یَسْتَأْذِنُ الرَّجُلُ عَلَی أُمِّہِ۔,,,17899 17900,حَدَّثَنَا وَکِیعٌ ، عَنْ ہَمَّامٍ ، عن قتادۃ عَنْ أَبِی ہُرَیْرَۃَ أَنَّہُ قَالَ یستأذن علیہا یعنی علی أمہ,,,17900 17901,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ قَالَ سَأَلْتُ عِکْرِمَۃَ قَالَ : قُلْتُ أَیَسْتَأْذِنُ الرَّجُلُ عَلَی أُمِّہِ وَعَلَی أُخْتِہِ ؟ قَالَ : نَعَمْ ، اسْتَأْذِنْ عَلَیْہِمَا۔",,,17901 17902,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِِ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ أَبِی الْبَخْتَرِیِّ قَالَ : سَأَلَ رَجُلٌ عِکْرِمَۃَ أَسْتَأْذِنُ عَلَی أُمِّی ؟ قَالَ : نَعَمْ ، اسْتَأْذِنْ عَلَی أُمِّک۔",,,17902 17903,"حَدَّثَنَا أَبُو أُسَامَۃَ، عَنْ مِسْعَرٍ، عَنْ عَمْرِو بْنِ مُرَّۃَ، عَنْ أَبِی الْبَخْتَرِیِّ قَالَ: وَأَخُو الْمَرْأَۃِ یَسْتَأْذِنُ عَلَیْہَا۔",,,17903 17904,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ أَبِی یَزِیدَ سَمِعَ ابْنَ عَبَّاسٍ یَقُولُ : إنَّہُ لَمْ یُؤْمَرْ بِہَا أَکْثَرُ النَّاسِ الإِذْنَ وَإِنِّی آمُرُ جَارِیَتِی ہذہ أَنْ تَسْتَأْذِنَ عَلَیَّ۔",,,17904 17905,"حَدَّثَنَا أَبُو خَالِدٍ، عَنْ عبدالملک، عَنْ عَطَائٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: غَلَبَ الشَّیْطَانُ النَّاسِ عَلَی الاستئذان فِی السَّاعَاتِ {الَّذِینَ مَلَکَتْ أَیْمَانُکُمْ وَالَّذِینَ لَمْ یَبْلُغُوا الْحُلُمَ مِنْکُمْ}۔",,,17905 17906,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : أَخْبَرَنَا ابْنُ عَوْنٍ ، عَنْ مُحَمَّدِ فی قولہ {وَالَّذِینَ لَمْ یَبْلُغُوا الْحُلُمَ مِنْکُمْ} قَالَ : کَانَ أَہْلُنا یُعَلِّمُونَا أَنْ نُسَلِّمَ قَالَ : فَکَانَ أَحَدُنَا إذَا جَائَ یَقُولُ : السَّلاَمُ عَلَیْکُمْ أَیَدْخُلُ فُلاَنٌ ؟۔",,,17906 17907,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی حَصِینٍ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ قَالَ : نَزَلَتْ فِی النِّسَائِ: {لِیَسْتَأْذِنْکُمُ الَّذِینَ مَلَکَتْ أَیْمَانُکُمْ}۔",,,17907 17908,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُوسَی بْنِ أَبِی عَائِشَۃَ ، عَنِ الشَّعْبِیِّ : {لِیَسْتَأْذِنْکُمُ الَّذِینَ مَلَکَتْ أَیْمَانُکُمْ} قَالَ : لَیْسَتْ بِمَنْسُوخَۃٍ قُلْتُ : فَإِنَّ النَّاسَ لاَ یَعْمَلُونَ بِہَا قَالَ : اللَّہُ الْمُسْتَعَانُ۔",,,17908 17909,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حَنْظَلَۃَ ، قَالَ : سَمِعْتُ الْقَاسِمَ وَسُئِلَ عَنِ الإِذْنِ ، فَقَالَ : اسْتَأْذِنْ عِنْدَ کُلِّ عَوْرَۃٍ ثُمَّ ہُوَ طَوَافٌ بَعْدَہَا۔",,,17909 17910,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ : {وَلاَ تَعْزِمُوا عُقْدَۃَ النِّکَاحِ حَتَّی یَبْلُغَ الْکِتَابُ أَجَلَہُ} قَالَ: انْقِضَائُ الْعِدَّۃِ۔",,,17910 17911,"حَدَّثَنَا وَکِیعٌ وَالْفَضْلُ ، عَنْ سُفْیَانَ ، عَنْ لَیث ، عَنْ مُجَاہِدٍ : {وَلاَ تَعْزِمُوا عُقْدَۃَ النِّکَاحِ حَتَّی یَبْلُغَ الْکِتَابُ أَجَلَہُ} قَالَ : انْقِضَائُ الْعِدَّۃِ۔",,,17911 17912,"حَدَّثَنَا عُبَیْدُ اللہِ ، عَنْ إسْرَائِیلَ ، عَنِ السُّدِّیِّ ، عَنْ أَبِی مَالِکٍ : {وَلاَ تَعْزِمُوا عُقْدَۃَ النِّکَاحِ حَتَّی یَبْلُغَ الْکِتَابُ أَجَلَہُ} قَالَ : لاَ تُوَاعِدُوہَا فِی عِدَّتِہَا إِنِّی أَتَزَوَّجُک حین تَنْقَضِیَ عِدَّتُک۔",,,17912 17913,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ، عَنْ مَنْصُورٍ، عَنْ مُجَاہِدٍ : {وَاہْجُرُوہُنَّ فِی الْمَضَاجِعِ} قَالَ : لاَ تَقْرَبْہَا۔",,,17913 17914,"حَدَّثَنَا جَرِیرٌ، عَنْ مُغِیرَۃَ، عَنْ إبْرَاہِیمَ وَالشَّعْبِیِّ: قوْلُہُ {وَاہْجُرُوہُنَّ فِی الْمَضَاجِعِ} قَالاَ: لاَ یُضَاجِعُہَا",,,17914 17915,"حَدَّثَنَا حَفْصٌ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ، عَنْ أَبِی الضُّحَی، عَنِ ابْنِ عَبَّاسٍ: {وَاہْجُرُوہُنَّ فِی الْمَضَاجِعِ} قَالَ: إذَا أَطَاعَتْہُ فِی الْمَضْجَعِ فَلَیْسَ لَہُ أَنْ یَضْرِبَہَا۔",,,17915 17916,"حَدَّثَنَا یُونُسُ بْنُ مُحَمَّدٍ قَالَ : حدَّثَنَا شَرِیکٌ ، عَنْ حُصَیْنٍ ، عَنْ عِکْرِمَۃَ وَمِقْسَمٍ : قَوْلُہُ {وَاہْجُرُوہُنَّ فِی الْمَضَاجِعِ وَاضْرِبُوہُنَّ} قَالَ : مِقْسَمٌ : وَلاَ تَقْرَبُ فِرَاشَہَا وَقَالَ عِکْرِمَۃُ : ہُوَ الْکَلاَمُ وَقَالاَ جَمِیعًا : {واضْرِبُوہُنَّ} ضَرْبٌ غَیْرُ مُبَرِّحٍ۔",,,17916 17917,"حَدَّثَنَا عَفَّانُ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حُمَیْدٍ ، عَنِ الْحَسَنِ : {واضْرِبُوہُنَّ} قَالَ : ضَرْبًا غَیْرُ مُبَرِّحٍ غَیْرُ مُؤَثِّرٍ۔",,,17917 17918,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ أَبِی سَلاَّمٍ الْفِہْرِیِّ ، قَالَ : سَمِعْتُ عَلِیَّ بْنَ عَبْدِ اللہِ بْنِ عَبَّاسٍ یَقُولُ : إذَا جَامَعْتَ فَاسْتَتِرْ۔",,,17918 17919,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنْ أَبِی قِلاَبَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا جَامَعَ أَحَدُکُمْ فَلْیَسْتَتِرْ وَلاَ یَتَجَرَّدَانِ تَجَرُّدَ الْعَیْرَیْنِ۔ (طبرانی 7683۔ بزار 1448)",,,17919 17920,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ أَبِی سَلاَّمٍ الفہری ، قَالَ : سَمِعْتُ عَلِیَّ بْنَ عَبْدِ اللہِ بْنِ عَبَّاسٍ یَنْہَی مُسْلِمًا أَنْ یُرَاضِعَ نَصْرَانِیًّا۔",,,17920 17921,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ صَالِحٍ ، عَنْ غَالِبٍ أَبِی الْہُذَیْلِ ، عَنْ أَبِی جَعْفَرٍ أَنَّہُ کَرِہَ أَنْ تُرْضِعَ الْیَہُودِیَّۃُ وَالنَّصْرَانِیَّۃ الصَّبِیَّ وَقَالَ : إنَّہَا تَشْرَبُ الْخَمْرَ۔",,,17921 17922,"حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرب ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ قَالَ : کَانَ یَکْرَہُ أَنْ تُرْضِعَ امْرَأَتہ بِلَبَنِ الْفُجُورِ۔",,,17922 17923,"حَدَّثَنَا شَرِیکٌ ، عَنْ إبْرَاہِیمَ قَالَ : لاَ بَأْسَ بِرَضَاعِ الزَّانِیَۃِ ، أَوْ لَبَنِ الْمَجُوسِیَّۃِ۔",,,17923 17924,"حَدَّثَنَا ہُشَیْمٌ قَالَ : أَخْبَرَنَا مَنْصُورٌ ، عَنِ ابْنِ سِیرِینَ ، عَنْ عَائِشَۃَ أَنَّہَا کَانَتْ تَقُولُ لِلنِّسَائِ : لاَ تَصِفننی لأَزْوَاجِکُنَّ۔",,,17924 17925,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ إسْمَاعِیلَ الْمَکِّیِّ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ قَالَ : إذَا تَزَوَّجَ الرجل أَمَۃً وَقَعَ عَلَیْہَا وَلَمْ یَسْتَبْرِئْہَا۔",,,17925 17926,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عُبَیْدَۃَ ، عَنْ إبْرَاہِیمَ قَالَ إِذَا تَزَوَّجَہَا لَمْ یَسْتَبْرِئْہَا۔,,,17926 17927,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ إسْمَاعِیلَ ، عَنِ الْحَسَنِ قَالَ : إذَا تَزَوَّجَ الأَمَۃَ تَزَوُّجًا لَمْ یَسْتَبْرِئْہَا۔",,,17927 17928,"حَدَّثَنَا ابْنُ مُسْہِرٍ ، وَأَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ قَالَ قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَخْطُبُ الرَّجُلُ عَلَی خِطْبَۃِ أَخِیہِ وَلاَ یَبِع عَلَی بَیْعِ أَخِیہِ إلاَّ أَنْ یَأْذَنَ لَہُ۔\n\n(مسلم 50۔ ابوداؤد 2074)",,,17928 17929,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَخْطُب عَلَی خِطْبَۃِ أَخِیہِ۔ (مسلم 520۔ ترمذی 1134)",,,17929 17930,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنْ مُدْرِکٍ ، عَنِ ابْنِ أَبِی أَوْفَی ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَزْنِی حِینَ یَزْنِی وَہُوَ مُؤْمِنٌ۔",,,17930 17931,حَدَّثَنَا الْحَسَنُ بْنُ مُوسَی ، عَنْ شُعْبَۃَ ، عَنْ فِرَاسٍ ، عَنْ مُدْرِکٍ ، عَنِ ابْنِ أَبِی أَوْفَی ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِثْلَہُ۔ (طیالسی 823۔ احمد 4/352),,,17931 17932,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ أَبِی سُلَیْمَانَ ، عَنْ یَحْیَی بْنِ عَبَّادٍ ، عَنْ أَبَانَ بْنِ عُثْمَانَ قَالَ : یُعْرَفُ الزُّنَاۃُ بِنَتْنِ فُرُوجِہِمْ یَوْمَ الْقِیَامَۃِ۔",,,17932 17933,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ أَبِی الضُّحَی ، عَنْ مَسْرُوقٍ قَالَ : إنَّ أَکْبَرَ مَا یُصِیبُ النَّاسَ مِنَ الذُّنُوبِ الزِّنَا ، ہُوَ شَہْوَۃٌ وَلَیْسَ لَہُ رِیحٌ فَیُؤخَذ وَلاَ یَکَادُ تُقَامُ حُدُودُہُ۔",,,17933 17934,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ سُفْیَانَ ، عَنْ زَکَرِیَّا بْنِ صُہَیْبٍ ، عَنْ أَبِی صَالِحٍ قَالَ : بَلَغَنِی أَنَّ أَکْثَرَ ذُنُوبِ أَہْلِ الْجَنَّۃِ فِی النِّسَائِ۔",,,17934 17935,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ إبْرَاہِیمَ بْنِ مُہَاجِرٍ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ قَالَ لِغِلْمَانِہِ : مَنْ أَرَادَ مِنْکُمُ الْبَائَۃَ زَوَّجْنَاہُ ، لاَ یَزْنِی مِنْکُمُ الزَّانِی إلاَّ نَزَعَ اللَّہُ نُورَ الإِیمَانِ مِنْ قَلْبِہِ فَإِنْ شَائَ أَنْ یَرُدَّہُ رَدَّہُ ، وَإِنْ شَائَ أَنْ یَمْنَعَہُ مَنَعَہُ۔",,,17935 17936,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ الْعَوَّامِ ، عَنْ عَلِیِّ بْنِ مُدْرِکٍ ، عَنْ أَبِی زُرْعَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ قَالَ : الإِیمَانُ نزہٌ فَمَنْ زَنَی فَارَقَہُ الإِیمَانُ فَمَنْ لاَمَ نَفْسَہُ وَرَاجَعَ رَاجَعَہُ الإِیمَانُ۔",,,17936 17937,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ سُلَیْمَانَ التَّیْمِیِّ ، عَنْ أَبِی عُثْمَانَ ، عَنْ أُسَامَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَا تَرَکْت بَعْدِی عَلَی أُمَّتِی فِتْنَۃً أَضَرَّ عَلَی الرِّجَالِ مِنَ النِّسَائِ۔\n\n(بخاری 5096۔ مسلم 2097)",,,17937 17938,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لَمْ یَکُنْ کُفْرُ مَنْ مَضَی إلاَّ مِنْ قِبَلِ النِّسَائِ وَہُوَ کَائِنٌ کُفْرُ مَنْ بَقِیَ مِنْ قِبَلِ النِّسَائِ۔",,,17938 17939,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ یَحْیَی بْنِ عَبَّادِ بن عَبْدِ اللہِ بْنِ الزُّبَیْرِ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ قَالَتْ : سَمِعْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : لاَ یَزْنِی الزَّانِی حِینَ یَزْنِی وَہُوَ مُؤْمِنٌ۔",,,17939 17940,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ یَزِیدَ بْنِ أَبِی حَبِیبٍ ، عَنْ بَعْجَۃَ الْجُہَنِیِّ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِمِثْلِہِ۔ (بخاری 2475۔ مسلم 100,,,17940 17941,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ قَالَ : حدَّثَنِی یَحْیَی بْنُ أَیُّوبَ الْمِصْرِیُّ قَالَ : حَدَّثَنِی یَزِیدُ بْنُ أَبِی حَبِیبٍ ، عَنْ بُکَیْرِ بْنِ عَبْدِ اللہِ بْنِ الأَشَجِّ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ أَنَّ عُمَرَ بْنَ الْخَطَّابِ رُفِعَ إلَیْہِ خَصِیٌّ تَزَوَّجَ امْرَأَۃً وَلَمْ یُعْلِمْہَا فَفَرَّقَ بَیْنَہُمَا۔",,,17941 17942,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ سَعِیدِ بْنِ یُوسُفَ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ أَنَّ عَلِیَّ بْنَ أَبِی طَالِبٍ کان یقُول : لاَ یَنْکِحُ الْخَصِیُّ حُرَّۃً مُسْلِمَۃً۔",,,17942 17943,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ قَالَ : سَأَلْتُ حَمَّادًا ، عَنْ رَجُلٍ زَوَّجَ ابْنَتَہُ ثُمَّ مَاتَ الزَّوْجُ وَلَمْ تَعْلَمِ الابْنَۃُ بِذَلِکَ ، فَقَالَ : لاَ تَرِثُ وَسَأَلْت الْحَکَمَ ، فَقَالَ : تَرِثُ۔",,,17943 17944,"حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنْ دَاوُدَ بْنِ جُبَیْرٍ قَالَ : زَفَّ سَعِیدُ بْنُ جُبَیْرٍ ابْنَتَہُ إلَی زَوْجِہَا۔",,,17944 17945,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ رَجُلٍ حَدَّثَہُ أَنَّ امْرَأَۃً سَأَلَتِ ابْنَہَا أَنْ یُزَوِّجَہَا فَکَرِہَ ذَلِکَ ، وَذَہَبَ إلَی عُمَرَ فَذَکَر ذَلِکَ لَہُ ، فَقَالَ عمر : اذْہَبْ فَإِذَا کَانَ غَدًا أَتَیْتُکُمْ قَالَ : فَجَائَ عُمَرُ فَکَلَّمَہَا وَلَمْ یُکْثِرْ ثُمَّ أَخَذَ بِیَدِ ابْنِہَا ، فَقَالَ لَہُ : زَوِّجْہَا فَوَالَّذِی نَفْسُ عُمَرَ بِیَدِہِ لَوْ أَنَّ حَنْتَمَۃَ بِنْتَ ہِشَامٍ یَعْنِی عُمَرُ أُمَّ نَفْسِہِ سَأَلَتْنِی أَنْ أُزَوِّجَہَا لَزَوَّجْتہَا ، فَزَوَّجَ الرَّجُلُ أُمَّہُ۔",,,17945 17946,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : أَخْبَرَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ ثَابِتٍ وَإِسْمَاعِیلَ بْنِ عَبْدِ اللہِ بْنِ أَبِی طَلْحَۃَ أَنَّ أَبَا طَلْحَۃَ خَطَبَ أُمَّ سُلَیْمٍ ، فَقَالَتْ : یَا أَبَا طَلْحَۃَ أَلَسْتَ تَعْلَمُ أَنَّ آلَہَتِکَ الَّتِی تَعْبُدُ خَشَبَۃً تنبت مِنَ الأَرْضِ ، نَجَرَہَا حَبَشِیُّ بَنِی فُلاَنٍ قَالَ : بَلَی ، قَالَتْ : فَلاَ تَسْتَحْیِی مِنْ ذَلِکَ أسلم فَإِنَّک إِنْ أَسْلَمْتَ لَمْ أُرِدْ مِنْک صَدَاقًا غَیْرَہُ قَالَ حَتَّی أَنْظُرَ قَالَ : فَذَہَبَ ثُمَّ جَائَ ، فَقَالَ : أَشْہَدُ أَنْ لاَ إلَہَ إلاَّ اللَّہُ وَأَنَّ مُحَمَّدًا رَسُولُ اللہِ قَالَتْ : یَا أَنَسُ ، قُمْ فَزَوِّجْ أَبَا طَلْحَۃَ ، فَزَوَّجَہَا۔",,,17946 17947,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، قَالَ : حَدَّثَنا حُسَیْنُ بْنُ وَاقِدٍ قَالَ : حدَّثَنِی یَزِیدُ النَّحْوِیُّ ، عَنْ عِکْرِمَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ إذَا قَدِمَ مِنْ مَغَازِیہِ قَبَّلَ فَاطِمَۃَ۔ (بخاری 3623۔ مسلم 97)",,,17947 17948,حَدَّثَنَا وَکِیعٌ ، عَنْ مَالِکِ بْنِ مِغْوَلٍ ، عَنْ أَبِی حَصِینٍ ، عَنْ مُجَاہِدٍ أَنَّ أَبَا بَکْرٍ قَبَّلَ رَأْسَ عَائِشَۃَ۔,,,17948 17949,حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ عَبْدِ الْوَاحِدِ بْنِ أیمن ، عَنْ أَبِی بَکْرِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ الْحَارِثِ بْنِ ہِشَامٍ أَنَّ خَالِدَ بْنَ الْوَلِیدِ اسْتَشَارَ أُخْتَہُ فِی شَیْئٍ فَأَشَارَتْ علیہ فَقَبَّلَ رَأْسَہَا۔ (ترمذی 1172۔ دارمی 2782),,,17949 17950,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ مُجَالِدٍ ، عَنِ الشَّعْبِیِّ ، عَنْ جَابِرٍ قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یُدْخلَ عَلَی الْمُغِیبَاتِ۔",,,17950 17951,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ وَمِسْعَرٍ ، عَنْ سَعِیدِ بْنِ إبْرَاہِیمَ ، عَنْ حُمَیْدِ بْنِ عَبْدِ الرَّحْمَنِ، قَالَ: قَالَ عُمَرُ: أَلاَ لاَ یَلِجُ رَجُلٌ عَلَی امْرَأَۃٍ إلاَّ وَہِیَ ذَاتُ مَحْرَمٍ مِنْہُ ، وَإِنْ قِیلَ : حَمْوُہَا ؟ أَلاَ إنَّ حَمْوَہَا الْمَوْتُ۔",,,17951 17952,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ أَبِی مَعْبَدٍ ، قَالَ : سَمِعْتُ ابْنَ عَبَّاسٍ یَقُولُ : سَمِعْت النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : أَلاَ لاَ یَخْلُوَنَّ رَجُلٌ بِامْرَأَۃٍ إلاَّ وَمَعَہَا ذُو مَحْرَمٍ۔ (بخاری 3006۔ مسلم 424)",,,17952 17953,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی زُبَیْرٍ ، عَنْ جَابِرٍ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : أَلاَ لاَ یَبِیتَنَّ رَجُلٌ عِنْدَ امْرَأَۃٍ إلاَّ أَنْ یَکُونَ نَاکِحًا ، أَوْ ذَا مَحْرَمٍ۔ (مسلم 19۔ ابن حبان 5587)",,,17953 17954,"حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ قَالَ : حدَّثَنَا لَیْثُ بْنُ سَعْدٍ ، عَنْ یَزِیدَ بْنِ أَبِی حَبِیبٍ ، عَنْ أَبِی الْخَیْرِ ، عَنْ عُقْبَۃَ بْنِ عَامِرٍ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : إیَّاکُمْ وَالدُّخُولَ عَلَی النِّسَائِ ، فَقَالَ رَجُلٌ مِنَ الأَنْصَارِ : یَا رَسُولَ اللہِ ، إلاَّ الْحَمْوَ ؟ فَقَالَ : الْحَمْوُ الْمَوْتُ۔ (بخاری 5232۔ مسلم 21)",,,17954 17955,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، قَالَ : سَمِعْتُ ذَکْوَانَ یُحَدِّثُ عَنْ مَوْلًی لِعَمْرِو بْنِ الْعَاصِ أنَّہُ أَرْسَلَہُ إلَی عَلِیٍّ یَسْتَأْذِنُ عَلَی أَسْمَائَ ابْنَۃِ عُمَیْسٍ فَأَذِنَ لَہُ حَتَّی إذَا فَرَغَ مِنْ حَاجَتِہِ سَأَلَ الْمَوْلَی عَمْرًا عَنْ ذَلِکَ ، فَقَالَ إنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَانَا أَنْ نَدْخُلَ عَلَی النِّسَائِ بِغَیْرِ إذْنِ أَزْوَاجِہِنَّ۔\n\n(ترمذی 2779۔ احمد 4/203)",,,17955 17956,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ زِیَادِ بْنِ فَیَّاضٍ ، عَنْ تَمِیمِ بْنِ سَلَمَۃَ قَالَ : قَالَ عَمْرُو بْنُ الْعَاصِ : نُہِینَا أَنْ نَدْخُلَ عَلَی الْمُغِیبَاتِ إلاَّ بِإِذْنِ أَزْوَاجِہِنَّ۔",,,17956 17957,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : أَخْبَرَنَا ہِشَامٌ ، عَنِ الْحَسَنِ ، وَابْنِ سِیرِینَ أَنَّہُمَا کَانَا لاَ یَرَیَانِ بَأْسًا أَنْ یَتَزَوَّجَ الرَّجُلُ عَلَی کَذَا وَکَذَا وَصِیفًا۔",,,17957 17958,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : لاَ بَأْسَ أَنْ یَتَزَوَّجَ الرَّجُلُ عَلَی بِنْتٍ وَخَادِمٍ وَعَلَی الْوُصَفَائِ وَالْوَصَائِفِ۔",,,17958 17959,"حَدَّثَنَا وَکِیعٌ ، عَنِ الْعَلاَئِ بْنِ عَبْدِ الْکَرِیمِ الْیَامِیِّ ، عَنْ عَمَّارِ بْنِ عِمْرَانَ رَجُلٍ مِنْ زَیْدِ اللہِ ، عَنِ امْرَأَۃٍ مِنْہُمْ ، عَنْ عَائِشَۃَ أَنَّہَا شَوَّفَتْ جَارِیَۃً وَطَافَتْ بِہَا وَقَالَتْ : لَعَلَّنَا نَتَصَید بِہَا شَبَابَ قُرَیْشٍ۔",,,17959 17960,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا أُسَامَۃُ بْنُ زَیْدٍ ، عَنْ أَبِی حَازِمٍ ، عَنْ سَہْلِ بْنِ سَعْدٍ السَّاعِدِیِّ أَنَّہُمْ مَرُّوا عَلَیْہِ بِجَارِیَۃٍ قَدْ زُیِّنَتْ قَالَ : فَدَعَا بِہَا وَنَظَرَ إلَیْہَا وَأَجْلَسَہَا فِی حِجْرِہِ ، وَمَسَحَ عَلَی رَأْسِہَا وَدَعَا لَہَا بِالْبَرَکَۃِ۔",,,17960 17961,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا أُسَامَۃُ بْنُ زَیْدٍ ، عَنْ بَعْضِ أَشْیَاخِہِ قَالَ قَالَ : عُمَرُ : إذَا أَرَادَ أحَدٌ مِنْکُمْ أَنْ یُحَسِّنَ الْجَارِیَۃَ فَلْیُزَیِّنْہَا وَلْیَطَّوَّفْ بِہَا یَتَعَرَّضُ بِہَا رِزْقَ اللہِ۔",,,17961 17962,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، قَالَ : قَالَ عُمَرُ : لاَ تُکْرِہُوا فَتَیَاتِکُمْ عَلَی الرجل الدَّمِیمِ مِنَ الرِّجَالِ فَإِنَّہُنَّ یُحْبِبْنَ مِنْ ذَلِکَ مَا تُحِبُّونَ۔",,,17962 17963,حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ أَنَّہُ کَانَ یَکْرَہُ أَنْ یَتَزَوَّجَ الرَّجُلُ فِی أَرْضِ الْحَرْبِ وَیَدَعُ وَلَدَہُ فِیہِمْ۔,,,17963 17964,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ مُجَاہِدٍ أَنَّہُ کَرِہَ نِکَاحَ نَصَارَی أَہْلِ الرُّومِ مِنْ غَیْرِ أَہْلِ الْعَہْدِ قَالَ : فَوَصَفَ مُحَمَّدٌ الرَّجُلَ یَکُونُ أَسِیرًا فَیُرِیدُ أَنْ یَتَزَوَّجَ فَیَکْرَہُ ذَلِکَ لَہُ۔",,,17964 17965,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ قَالَ : لاَ یُحْصِنُ الرَّجُلَ نِکَاحُ الْحَرَامِ۔",,,17965 17966,حَدَّثَنَا إِسْمَاعِیلُ بْنُ عَیَّاشٍ، عَنْ عَبْدِالْعَزِیزِ بْنِ عُبَیْدِاللہِ عن الشعبی قَالَ لاَ یُحْصِنُ الرَّجُلَ نِکَاحُ الْحَرَامِ۔,,,17966 17967,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ بُدَیل بْنِ مَیْسَرَۃَ ، عَنْ أَبِی عَطِیَّۃَ ، عَنِ امْرَأَۃٍ مِنْہُمْ قَالَت : سَمِعْتُ عُمَرَ یَنْہَی عَنِ النَّقْشِ وَالتَّطَارِیفِ فِی الْخِضَابِ۔",,,17967 17968,"حَدَّثَنَا وَکِیعٌ ، عَنْ زَکَرِیَّا قَالَ حَدَّثَتْنِی أُمَیَّۃُ قَالَتْ : کُنْت أُقین الْعَرَائِسَ بِالْمَدِینَۃِ فَسَأَلْت عَائِشَۃَ عَنِ الْخِضَابِ ، فَقَالَتْ : لاَ بَأْسَ بِہِ مَا لَمْ یَکُنْ فِیہِ نَقْشٌ۔",,,17968 17969,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ خَالِد ، عَنْ شَیْخٍ أَنَّ عُمَرَ نَہَی عَنْ نَقْشٍ فِی الْخِضَابِ وَالتَّطَارِیفِ۔,,,17969 17970,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ عَبْدِ اللہِ بْنِ حَفْصٍ ، عَنْ یَعْلَی بْنِ مُرَّۃَ قَالَ : مَرَرْت عَلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَأَنَا مُتَخَلِّقٌ بِالزَّعْفَرَانِ ، فَقَالَ لِی : یَا یَعْلَی ، ہَلْ لَکَ امْرَأَۃٌ ؟ فَقُلْتُ : لاَ ، قَالَ : فَاذْہَبْ فَاغْسِلْہُ ثُمَّ اغْسِلْہُ ثُمَّ لاَ تَعُدْ ، قَالَ : فَغَسَلْتہ ثُمَّ غَسَلْتہ ثُمَّ لَمْ أَعُدْ۔\n\n(ترمذی 2816۔ احمد 4/171)",,,17970 17971,حَدَّثَنَا مُعْتَمِرٌ وَجَرِیرٌ ، عَنِ الرُّکَیْنِ ، عَنِ الْقَاسِمِ بْنِ حَسَّانَ ، عَنْ عَمِّہِ عَبْدِ الرَّحْمَنِ بْنِ حَرْمَلَۃَ ، عَنْ عَبْدِ اللہِ أَنَّ نَبِیَّ اللہِ کَرِہَ الصُّفْرَۃَ یَعْنِی الْخَلُوقَ۔ (ابوداؤد 4219۔ ابویعلی 5074),,,17971 17972,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ صُہَیْبٍ ، عَنْ أَنَسٍ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی عَنِ التَّزَعْفُرِ۔ (مسلم 1663۔ ابوداؤد 4176),,,17972 17973,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنِ الْحَسَنِ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَأَی سَوَّادَ بْنَ عَمْرٍو مُتَخَلِّقًا، فَقَالَ : خطْ خطْ ، وَرْسْ وَرْسْ۔ (عبدالرزاق 18038)",,,17973 17974,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ ہِشَامٍ ، عَنْ کَثِیرٍ مَوْلَی ابْنِ سَمُرَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ تَقْرَبُ الْمَلاَئِکَۃُ مُتَضَمِّخًا بِخَلُوقٍ۔",,,17974 17975,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ أَنَّ الأَشْعَرِیَّ لَمَّا قَدِمَ الْبَصْرَۃَ رَأَی قَیْسَ بْنَ عُبَادٍ وَعَلَیْہِ أَثَرُ صُفْرَۃٍ، أَوْ قَالَ: خَلُوقٍ قَالَ: فَنَظَرَ إلَیْہِ فَانْطَلَقَ فغَسَلُہُ ثُمَّ جَائَ، فَقَالَ الأَشْعَرِیُّ: مَا أَسْرَعُ مَا أعتب ہَذَا۔",,,17975 17976,حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی أنَّہُ دُعِیَ إلَی عُرْسٍ بِلَیْلٍ فَادَّہَنَ بِدُہْنٍ فِیہِ صُفْرَۃٌ فَأَصْبَحَ وَفِی لِحْیَتِہِ صُفْرَۃٌ فَغَسَلَہَا فَلَمْ یَذْہَبْ فَغَسَلَہَا بِصَابُونٍ۔,,,17976 17977,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : أَخْبَرَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ عَطَائٍ الْخُرَاسَانِیِّ ، عَنْ یَحْیَی بْنِ یَعْمَُرَ ، عَنْ عَمَّارٍ قَالَ : قَدِمْت مِنَ سَفَرٍ فَمَسَّحَنِی أَہْلِی بِشَیْئٍ مِنَ صُفْرَۃٍ فَأَتَیْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَسَلَّمْت عَلَیْہِ فَلَمْ یَرُدَّ عَلَیَّ وَلَمْ یُرَحِّبْ بِی وَقَالَ : انْطَلِقْ فَاغْسِلْ عَنْک ہَذَا ، فَذَہَبْتُ فَغَسَلْتُہُ فَبَقِیَ مِنْ أَثَرِہِ شَیْئٌ فَأَتَیْتُہُ فَسَلَّمْت عَلَیْہِ فَلَمْ یَرُدَّ عَلَیَّ وَلَمْ یُرَحِّبْ بِی ، فَقَالَ : انْطَلِقْ فَاغْسِلْ عَنْک ہَذَا ، فَذَہَبْتُ فَغَسَلْتہ ثُمَّ جِئْت فَسَلَّمْت عَلَیْہِ فَرَحَّبَ بِی وَقَالَ : إنَّ الْمَلاَئِکَۃَ لاَ تَقْرَبُ جِنَازَۃَ کَافِرٍ وَلاَ جُنُبٍ وَلاَ مُتَضَمِّخٍ بِخَلُوقٍ۔ (مسندہ 441)",,,17977 17978,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ إِسْحَاقَ ، عَنِ النُّعْمَانِ بْنِ سَعْدٍ قَالَ : رَأَیْتُ الْمُغِیرَۃَ بْنَ شُعْبَۃَ مُضَمَّخًا بِالْخَلُوقِ کَأَنَّہُ عُرْجُونٌ۔",,,17978 17979,"حَدَّثَنَا ہُشَیْمُ بْنُ أَبِی سَاسَانَ ، عَنْ أَبَانَ بْنِ کَثِیرٍ النَّہْشَلِیِّ قَالَ : رَأَیْتُ أَنَسًا قَدْ مَسَحَ ذِرَاعَیْہِ بِشَیْئٍ مِنْ خَلُوقٍ مِنْ وَضَحٍ کَانَ بِہِ۔",,,17979 17980,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عُرْوَۃَ ، عَنْ عَائِشَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ: الْوَلَدُ لِلْفِرَاشِ۔ (بخاری 2421۔ مسلم 1081)",,,17980 17981,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ أَبِی یَزِیدَ ، عَنْ أَبِیہِ ، عَنْ عُمَرَ ، قَالَ : قضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِالْوَلَدِ لِلْفِرَاشِ۔ (احمد 25۔ ابویعلی 199)",,,17981 17982,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدٍ وَأَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : الْوَلَدُ لِلْفِرَاشِ۔ (مسلم 1081۔ ترمذی 1157)",,,17982 17983,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : أَخْبَرَنَا حُسَیْنُ الْمُعَلِّمُ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : الْوَلَدُ لِلْفِرَاشِ وَلِلْعَاہِرِ الأَثْلَبُ قِیلَ : وَمَا الأَثْلَبُ ؟ قَالَ : الْحَجَرُ۔\n\n(ابوداؤد 2268۔ احمد 2/179)",,,17983 17984,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ شُرَحْبِیلَ بْنِ مُسْلِمٍ ، قَالَ : سَمِعْتُ أَبَا أُمَامَۃَ الْبَاہِلِیَّ یَقُولُ : سَمِعْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : الْوَلَدُ لِلْفِرَاشِ۔ (ترمذی 2120۔ ابوداؤد 2269)",,,17984 17985,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : أَخْبَرَنَا مَہْدِیُّ بْنُ مَیْمُونٍ ، عَنْ مُحَمَّدِ بْنِ أَبِی یَعْقُوبَ ، عَنِ الْحَسَنِ بْنِ سَعْدٍ قَالَ: حَدَّثَنِی رَبَاحٌ الْحَبَشِیُّ، عَنْ عُثْمَانَ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَضَی بِالْوَلَدِ لِلْفِرَاشِ۔",,,17985 17986,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ مُحَمَّدِ بْنِ زِیَادٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْوَلَدُ لِلْفِرَاشِ وَلِلْعَاہِرِ الْحَجَرُ۔ (بخاری 6750۔ احمد 2/386)",,,17986 17987,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : أَخْبَرَنَا سَعِیدٌ ، عَنْ قَتَادَۃَ ، عَنْ شَہْرِ بْنِ حَوْشَبٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ غَنْمٍ ، عَنْ عَمْرِو بْنِ خَارِجَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : الْوَلَدُ لِلْفِرَاشِ۔",,,17987 17988,"حُدِّثْتُ عن جَرِیر ، عَنْ مُغِیرَۃَ ، عَن أَبِی وَائِلٍ ، عَنْ عَبْدِ اللہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنَّہُ قَالَ: الْوَلَدُ لِلْفِرَاشِ۔ (ابویعلی 5126۔ ابن حبان 4104)",,,17988 17989,"حَدَّثَنَا أَبُو أُسَامَۃَ قَالَ : حدَّثَنِی شُعْبَۃُ قَالَ : سَأَلْتُ الْحَکَمَ وَحَمَّادًا ، عَنِ الرَّجُلِ یَلْحَقُ بِأَرْضِ الْعَدُوِّ أَتَتَزَوَّجُ امْرَأَتُہُ ؟ قَالَ : أَحَدُہُمَا : لاَ ، وَقَالَ : الآخَرُ : نَعَمْ۔",,,17989 17990,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ حَمَّادِ بْنِ زَیْدٍ قَالَ : حدَّثَنَا عَاصِمٌ قَالَ عُمَرُ بْنُ الْخَطَّابِ : عَلَیْکُمْ بِالأَبْکَارِ مِنَ النِّسَائِ فَإِنَّہُنَّ أَعْذَبُ أَفْوَاہًا وَأَصَحُّ أَرْحَامًا وَأَرْضَی بِالْیَسِیرِ۔",,,17990 17991,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ قَالَ : أَخْبَرَنَا سُفْیَانُ ، عَنْ عَمْرِو بْنِ قَیْسٍ ، عَنْ رَجُلٍ ، عَنِ ابْنِ مَسْعُودٍ قَالَ : تَزَوَّجُوا الأَبْکَارَ فَإِنَّہُنَّ أَقَلُّ خِبًّا وَأَشَدُّ وُدًّا۔",,,17991 17992,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ عَبْدِ اللہِ بْنِ عُثْمَانَ بْنِ خُثَیْمٍ ، عَنْ مَکْحُولٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : عَلَیْکُمْ بِالْجَوَارِی الشَّوَابِّ فَانْکِحُوہُنَّ فَإِنَّہُنَّ أَطْیَبُ أَفْوَاہًا وَأَعَزُّ أَخْلاَقًا أفیح أَرْحَامًا۔ (سعید بن منصور 514۔ عبدالرزاق 19342)",,,17992 17993,"حَدَّثَنَا مُحَمَّدُ بْنُ عُبَیْدٍ ، عَنِ الأَعْمَشِِ ، عَنْ سَالِمٍ ، عَنْ جَابِرٍ ، قَالَ : سَأَلَنِی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : بِکْرًا تَزَوَّجْت أَمْ ثَیِّبًا ؟ قَالَ : قُلْتُ : لاَ بَلْ ثَیِّبًا قَالَ : فَہَلاَّ جَارِیَۃً تُلاَعِبُہَا وَتُلاَعِبُک۔\n\n(ابوداؤد 2041۔ بیہقی 351)",,,17993 17994,"حَدَّثَنَا عَبِیدَۃُ بْنُ حُمَیْدٍ، عَنِ الأَسْوَدِ بْنِ قَیْسٍ الْعَبْدِیِّ، عَنْ نُبَیْحِ بْنِ عَبْدِ اللہِ الْعَنَزِیِّ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ قَالَ: مَشَیْت مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقَالَ: أَلَک امْرَأَۃٌ یَا جَابِرُ؟ قُلْتُ: نَعَمْ ، فَقَالَ : ثَیِّبًا نَکَحْت أَمْ بِکْرًا ؟ قُلْتُ: تَزَوَّجْتہَا وَہِیَ ثَیِّبٌ ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَلَوْلاَ تَزَوَّجْتہا جَارِیَۃً تُلاَعِبُہَا قَالَ : قُلْتُ لَہُ : قتل أبی مَعَک یَوْم کَذَا وَکَذَا وَترَکَ جَوَارِیًا لہ فَکَرِہْت أَنْ أَضُمَّ إلَیْہِنَّ جَارِیَۃً ، فَتَزَوَّجْت ثَیِّبًا تَقْصَعُ قَمْلَ إحْدَاہُنَّ ، وَتَخِیطُ دِرْعَ إحْدَاہُنَّ إذَا تَخَرَّقَ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : فَإِنَّک نِعِمَّا رَأَیْت۔ (مسلم 55۔ احمد 3/358)",,,17994 17995,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدِ بْنِ سِیرِینَ ، قَالَ : قَالَ عُمَرُ بْنُ الْخَطَّابِ : مَا بَقِیَ فِی شَیْئٍ مِنْ أَخْلاَقِ الْجَاہِلِیَّۃِ ، إلاَّ أَنِّی لاَ أُبَالِی إلی أَیِٔ الْمُسْلِمِینَ نَکَحْتُ وَأَیَّہُمْ أَنْکَحْتُ۔",,,17995 17996,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللہِ الأَسَدِیُّ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ عُمَرَ ، أَنَّہُ نَہَی أَنْ یَتَزَوَّجَ الْعَرَبِیُّ الأَمَۃَ,,,17996 17997,"حَدَّثَنَا سُوَیْد بْنُ عَمْرٍو الْکَلْبِیُّ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ أَبِی سَلَمَۃَ قَالَ : أَخْبَرَنَا مُحَمَّدُ بْنُ عَبْدِ اللہِ بْنِ کَثِیرِ بْنِ الصَّلْتِ قَالَ نَکَحَ مَوْلًی لَنَا عَرَبِیَّۃً فَأُوتِیَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ لیستعدی عَلَیْہِ ، فَقَالَ : وَاللَّہِ لَقَدْ عَدَا مَوْلَی أَلِ کَثِیرٍ طَوْرَہُ۔",,,17997 17998,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ حَبِیبٍ ، عَنْ إبْرَاہِیمَ بْنِ مُحَمَّدِ بْنِ طَلْحَۃَ ، قَالَ : قَالَ عُمَرُ : لأَمْنَعَنَّ فُرُوجَ ذَوَاتِ الأَحْسَابِ مِنَ النِّسَائِ إلاَّ مِنَ الأَکْفَائِ۔",,,17998 17999,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حَدَّثَنِی مِسْعَر ، قَالَ : حَدَّثَنِی عُمَرُ بْنُ قَیْسٍ ، عَنْ عَمْرِو بْنِ أَبِی قُرَّۃَ الْکِنْدِیِّ قَالَ : عَرَضَ أَبِی عَلَی سَلْمَانَ أُخْتًا لہ فَأَبَی وَتَزَوَّجَ مَوْلاَۃً لَہُ یُقَالُ لَہَا بُقَیْرَۃُ۔",,,17999 18000,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الْکِنْدِیِّ ، عَنْ سَلْمَانَ قَالَ : لاَ نَؤُمُّہُمْ وَلاَ نَنْکِحُ نِسَائَہُمْ",,,18000 18001,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللہِ الأَسَدِیُّ ، عَنِ ابْنِ أَبِی ذِئْبٍ قَالَ قَالَ ابْنُ شِہَابٍ فِی الْعَرَبِیِّ وَالْمَوْلَی : لاَ یَسْتَوِیَانِ فِی النَّسَبِ۔",,,18001 18002,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ قَالَ : حدَّثَنَا حَسَنٌ ، قَالَ : سَأَلْتُ ابْنَ أَبِی لَیْلَی ، عَنِ الْکُفُؤِ فِی النِّکَاحِ ، فَقَالَ : فِی الدِّینِ وَالْمَنْصِبِ قَالَ : قُلْتُ : فِی الْمَالِ ؟ قَالَ : لاَ۔",,,18002 18003,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، وَأَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِِ ، عَنْ شَقِیقٍ ، عَنْ عَبْدِ اللہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ أَحَدَ أَغْیَرُ مِنَ اللہِ وَلِذَلِکَ حَرَّمَ الْفَوَاحِشَ مَا ظَہَرَ مِنْہَا ، وَمَا بَطَنَ۔\n\n(مسلم 33۔ بخاری 7403)",,,18003 18004,حَدَّثَنَا الْحُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ عَبْدِ الْمَلِکِ بْنِ عُمَیْرٍ ، عَنْ وَرَّادٍ ، عَنِ الْمُغِیرَۃِ بْنِ شُعْبَۃَ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ أَتَعْجَبُونَ مِنْ غَیْرَۃِ سَعْدٍ ؟ فَوَاللَّہِ لأَنَا أَغْیَرُ مِنْ سَعْدٍ وَاللَّہُ أَغْیَرُ مِنِّی وَمن أَجْلِ غَیْرَۃِ اللہِ حَرَّمَ الْفَوَاحِشَ مَا ظَہَرَ مِنْہَا ، وَمَا بَطَنَ۔ (بخاری 7416۔ مسلم 17,,,18004 18005,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ قَالَ : حدَّثَنَا الْحَجَّاجُ بْنُ أَبِی عُثْمَانَ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ مُحَمَّدِ بْنِ إبْرَاہِیمَ ، عَنِ ابْنِ عَتِیکٍ الأَنْصَارِیِّ ، عَنْ أَبِیہِ ، قَالَ : قَالَ : نَبِیُّ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مِنَ الْغَیْرَۃِ مَا یُحِبُّ اللَّہُ وَمِنْہَا مَا یُبْغِضُ اللَّہُ فَأَمَّا الْغَیْرَۃُ الَّتِی یُحِبُّ اللَّہُ فَالْغَیْرَۃُ فِی الرِّیبَۃِ ، وَأَمَّا الْغَیْرَۃُ الَّتِی یُبْغِضُ اللَّہُ فَالْغَیْرَۃُ فِی غَیْرِ رِیبَۃٍ۔ (احمد 5/445۔ دارمی 2226)",,,18005 18006,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الأَحْوَصِ ، قَالَ : قَالَ عَبْدُ اللہِ : احْبِسُوا النِّسَائَ فِی الْبُیُوتِ فَإِنَّ النِّسَائَ عَوْرَۃٌ وَإِنَّ الْمَرْأَۃَ إذَا خَرَجَتْ مِنْ بَیْتِہَا اسْتَشْرَفَہَا الشَّیْطَانُ وَقَالَ : لَہَا : إنَّک لاَ تَمُرِّینَ بِأَحَدٍ إلاَّ أُعْجِبَ بِک۔ (ترمذی 1173۔ ابن حبان 5598)",,,18006 18007,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ حَارِثَۃَ بْنِ مُضَرِّبٍ ، قَالَ : قَالَ عُمَرُ : اسْتَعِینُوا عَلَی النِّسَائِ بِالْعُرْیِ إنَّ إحْدَاہُنَّ إذَا کَثُرَتْ ثِیَابُہَا وَحَسُنَتْ زِینَتُہَا أَعْجَبَہَا الْخُرُوجُ۔",,,18007 18008,"حَدَّثَنَا عَبْدُ اللہِ بْنُ رَجَائٍ ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنَ ، عَنْ سُمَیٍّ ، عَنْ أَبِی بَکْرٍ بْنِ عَبْدِ الرَّحْمَنِ بْنِ الْحَارِثِ بْنِ ہِشَامٍ قَالَ : کُلُّ شَیْئٍ مِنَ الْمَرْأَۃِ عَوْرَۃٌ حَتَّی ظُفُرُہَا۔",,,18008 18009,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنِّی غَیُورٌ وَإِنَّ إبْرَاہِیمَ کَانَ غَیُورًا ، وَمَا مِنَ امْرِئٍ لاَ یَغَارُ إلاَّ مَنْکُوسُ الْقَلْبِ۔",,,18009 18010,"حَدَّثَنَا یَحْیَی بْنُ الْیَمَانِ، عَنْ سُفْیَانَ، عَنْ جَابِرٍ وَمُطَرِّفٍ، عَنِ الشَّعْبِیِّ قَال: إذَا دُرِأَ اللِّعَانَ أُلْزِقَ بِہِ الْوَلَدُ۔",,,18010 18011,حَدَّثَنَا یَحْیَی بْنُ الْیَمَانِ ، عَنْ سُفْیَانَ ، عَنْ لَیْثٍ ، عَنْ َمُجَاہِدٍ ، وَعَطَائٍ مِثْلَہُ۔,,,18011 18012,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ قَالَ: حدَّثَنَا زُہَیْرٌ ، عَنْ مُطَرِّفٍ ، عَنِ الشَّعْبِیِّ قَالَ : إذَا لَمْ یَکُنْ لِعَانٌ أُلْحِقَ الْوَلَدُ بِالْوَالِدِ۔",,,18012 18013,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ قَالَ : حدَّثَنَا سَعِیدٌ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، وَالْحَسَنِ قَالاَ : إذَا زَنَی الرَّجُلُ بِالْمَرْأَۃِ فَلَیْسَ لَہُ أَنْ یَتَزَوَّجَ ابْنَتَہَا وَلاَ أُمَّہَا۔",,,18013 18014,"حَدَّثَنَا شَرِیکٌ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ عَطَائٍ قَالَ : إذَا أَتَی الرَّجُلُ الْمَرْأَۃَ حَرَامًا حَرُمَتْ عَلَیْہِ ابْنَتُہَا وَإِذَا أَتَی ابْنَتَہَا حَرُمَتْ عَلَیْہِ أُمُّہَا۔",,,18014 18015,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنْ مُجَاہِدٍ ، وَعَطَائٍ فِی الرَّجُلِ یَفْجُرُ بِالْمَرْأَۃِ قَالاَ : لاَ یَحِلُّ لَہُ شَیْئٌ مِنْ بَنَاتِہَا۔",,,18015 18016,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ اللہِ بْنِ مُسَبِّحٍ ، قَالَ : سَأَلْتُ إبْرَاہِیمَ ، عَنْ رَجُلٍ فَجَرَ بِأَمَۃٍ ثُمَّ أَرَادَ أَنْ یَتَزَوَّجَ أُمَّہَا قَالَ : لاَ یَتَزَوَّجُہَا۔",,,18016 18017,"حدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ قَالَ : حدَّثَنَا سَیْفٌ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ طَاوُوسٍ ، أَنَّہُ کَانَ یَقُولُ : لو أنَّ رَجُلاً تَزَوَّجَ امْرَأَۃً فَطَلَّقَہَا ، أَوْ مَاتَ عَنْہَا وَلَہَا ابْنَۃٌ ، یَحِلُّ لابْنِ الرَّجُلِ أَنْ یَتَزَوَّجَہَا۔",,,18017 18018,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ قَالَ : حدَّثَنَا سَیْفٌ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ عَطَائٍ قَالَ : لاَ بَأْسَ بِہِ۔",,,18018 18019,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ قَالَ : حدَّثَنَا سَیْفٌ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ؛ أَنَّہُ کَرِہَہُ۔",,,18019 18020,حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ سَیْفٍ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ عِکْرِمَۃَ مَوْلَی ابْنِ عَبَّاسٍ ؛ أَنَّہُ کَرِہَہُ۔,,,18020
