{"hadithnumber": "1028", "text": "ہشام بن عروہ رحمہ اللہ اپنے والد ( عروہ بن زبیر رحمہ اللہ ) سے روایت کرتے ہیں ، انھوں نے کہا کہ رسول"}
{"hadithnumber": "1029", "text": "یحیی بن سعید رحمہ اللہ سے روایت ہے کہ بے شک عبداللہ بن عیاش بن ابی ربیعہ رحمہ اللہ نے اپنے ایک غلام"}
{"hadithnumber": "1030", "text": "عطاء بن یسار رحمہ اللہ سے روایت ہے کہ انصار میں سے بنوحارثہ خاندان کا ایک شخص اپنی دودھ والی اونٹنی"}
{"hadithnumber": "1031", "text": "حضرت معاذ بن سعد یا سعد بن معاذ رضی اللہ عنہ سے روایت ہے کہ حضرت کعب بن مالک رضی اللہ عنہ کی ایک لون"}
{"hadithnumber": "1032", "text": "حضرت عبداللہ بن عباس رضی اللہ عنہ سے روایت ہے کہ ، ان سے عرب کے عیسائیوں کے ذبح کے متعلق سوال کیا گی"}
{"hadithnumber": "1033", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ حضرت عبداللہ بن عباس رضی اللہ عنہ فرمایا کرتے تھے جو چیز ( ذب"}
{"hadithnumber": "1034", "text": "سعید بن مسیب رحمہ اللہ سے روایت ہے ، وہ کہا کرتے تھے کہ جس چیز سے بھی ( جانور کو ) ذبح کیا جائے ، چن"}
{"hadithnumber": "1035", "text": "ابومُرّہ رحمہ اللہ جو کہ عقیل بن ابی طالب کے آزاد کردہ غلام ہیں ، سے روایت ہے ، انھوں نے حضرت ابوہری"}
{"hadithnumber": "1036", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہ سے روایت ہے ، وہ فرمایا کرتے تھے کہ جب اونٹنی کو نحر ( قربان ) کر د"}
{"hadithnumber": "1037", "text": "سعید بن مسیب رحمہ اللہ سے روایت ہے ، وہ کہا کرتے تھے کہ پیٹ کے بچے کا ذبح کرنا اس کی ماں کے ذبح کرنے"}
{"hadithnumber": "1038", "text": "نافع رحمہ اللہ سے روایت ہے ، کہتے ہیں کہ میں نے دو پرندوں پر ایک پتھر پھینکا ، اس حال میں کہ میں ( م"}
{"hadithnumber": "1039", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ بے شک قاسم بن محمد رحمہ اللہ اس شکار کو ناپسند کرتے تھے جسے م"}
{"hadithnumber": "1041", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہ سے روایت ہے ، وہ سکھائے ہوئے شکاری کتے کے متعلق فرمایا کرتے تھے کہ"}
