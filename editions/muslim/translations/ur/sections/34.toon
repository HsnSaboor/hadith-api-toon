{"hadithnumber": "4972", "text": "ہمام بن حارث نے حضرت عدی بن حاتم  رضی اللہ تعالیٰ عنہ  سے روایت کی  ، کہا : میں نے عرض کی  : اللہ کے"}
{"hadithnumber": "4973", "text": "بیا ن نے شعبی سے ، انھوں نے عدی بن حاتم  رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا : میں نے رسول اللہ"}
{"hadithnumber": "4974", "text": "معاذ عنبری نے کہا : ہمیں شعبہ نے عبداللہ ابی سفر سے حدیث بیان کی ، انھوں نے شعبی سے ، انھوں نے عدی ب"}
{"hadithnumber": "4975", "text": "ابن علیہ نے کہا : مجھے شعبہ نے عبداللہ بن ابی سفر سےخبر دی ، انھوں نے کہا : میں نے شعبی کو کہتے ہوئے"}
{"hadithnumber": "4976", "text": "غندر نے کہا :  ہمیں شعبہ نے عبداللہ بن ابی سفر سے  ، انھوں نے اور کچھ دیگر لوگوں نے جن کا شعبہ نے ذک"}
{"hadithnumber": "4977", "text": "۔  عبداللہ بن نمیر نے کہا : ہمیں زکریا نے عامر  ( شعبی )  سے حدیث بیان کی ، انھوں نے عدی بن حاتم رضی"}
{"hadithnumber": "4978", "text": "عیسیٰ بن یونس نے کہا :  ہمیں زکریا بن ابی زائدہ نے اسی سند کے ساتھ حدیث بیان کی ۔"}
{"hadithnumber": "4979", "text": "سعید بن مسروق نے کہا : شعبی نے ہمیں حدیث بیان کی ، کہا : میں نے حضرت عدی بن حاتم  رضی اللہ تعالیٰ عن"}
{"hadithnumber": "4980", "text": "حکم نے شعبی سے  ، انھوں نے حضرت عدی بن حاتم رضی اللہ تعالیٰ عنہ  سے ، انھوں نے نبی کریم صلی اللہ علی"}
{"hadithnumber": "4981", "text": "علی بن مسہرنے عاصم سے ، انھوں نے شعبی سے ، انھوں نے حضرت عدی بن حاتم  رضی اللہ تعالیٰ عنہ  سے روایت"}
{"hadithnumber": "4982", "text": "عبداللہ بن مبارک نے کہا :  ہمیں عاصم نے شعبی سے خگر دی ، انھوں نے حضرت عدی بن حاتم  رضی اللہ تعالیٰ"}
{"hadithnumber": "4983", "text": "ابن مبارک نے حیوہ بن شریح سے روایت کی ، انھوں نے کہا : میں نے ربیعہ بن یزید دمشقی کو کہتے ہوئے سنا :"}
{"hadithnumber": "4984", "text": "زہیر بن وہب اور مقری دونوں نے حیوہ سے اسی سند کے ساتھ ابن مبارک کی حدیث کی طرح روایت  کی ، البتہ ابن"}
{"hadithnumber": "4985", "text": "ابو عبداللہ حماد بن خالد خیاط نے معاویہ بن صالح سے  ، انھوں نے عبدالرحمان بن جبیر سے  ، انھوں نے اپن"}
{"hadithnumber": "4986", "text": "معن بن عیسیٰ نے کہا :  مجھے معاویہ نے عبدالرحمان بن جبیربن نفیر سے حدیث بیان کی ، انھوں نے اپنے والد"}
{"hadithnumber": "4987", "text": "محمد بن حاتم نے کہا : ہمیں عبدالرحمان بن مہدی نے معاویہ بن صالح سے حدیث بیان کی ، انہوں نے علاء سے ،"}
{"hadithnumber": "4988", "text": "ابو بکر بن ابی شیبہ ، اسحاق بن ابراہیم اور ابن ابی عمر نے کہا : ہمیں سفیان بن عینیہ نے زہری سے حدیث"}
{"hadithnumber": "4989", "text": "یونس نے ابن شہاب سے ، انہوں نے ابو ادریس خولانی سے روایت کی کہ انہوں نے حضرت ابو ثعلبہ خشنی  رضی الل"}
{"hadithnumber": "4990", "text": "عمرو  بن حارث نے کہا کہ ابن شہاب نے انھیں اب ادریس خولانی سے حدیث بیان کی ، انھوں نے حضرت ابو ثعلبہ"}
{"hadithnumber": "4991", "text": "امام مالک رحمۃ اللہ علیہ  بن انس  ، ابن ابی ذئب ، عمرو بن حارث ، یونس بن یزید وغیرہ نے اور  معمر ، ی"}
{"hadithnumber": "4992", "text": "عبدالرحمان بن مہدی نے مالک سے ، انھوں نے اسماعیل بن ابی حکیم سے  ، انھوں نے عبیدہ بن سفیان سے  ، انھ"}
{"hadithnumber": "4993", "text": "ابن وہب نے کہا : مجھے امام مالک بن انس نے اسی سند کے ساتھ اسی کے مانند روایت کی ۔"}
{"hadithnumber": "4994", "text": "معاذ عنبری نے کہا : ہمیں شعبہ نے حکم سے ، انھوں نے میمون بن مہران سے ، انھوں نے حضرت ابن عباس  رضی ا"}
{"hadithnumber": "4995", "text": "سہل بن حماد نے شعبہ سے اسی سند کے ساتھ اسی کے مانند روایت کی ۔"}
{"hadithnumber": "4996", "text": "ابو عوانہ نے کہا : ہمیں  حکیم اور ابو بشر نے میمون بن مہران سے حدیث بیا ن کی ، انھوں نے حضرت  ابن عب"}
{"hadithnumber": "4997", "text": "ہشیم اور ابوعوانہ نے ابو بشر سے ، انہوں نے میمون بن مہران سے روایت کی ، انھوں نے ابن عباس رضی اللہ ت"}
{"hadithnumber": "4998", "text": "ابو زبیر نے  حضرت جابر سے روایت کی ، کہا :  کہ رسول اللہ صلی اللہ علیہ وسلم نے ہمیں ابوعبیدہ بن الجر"}
{"hadithnumber": "4999", "text": "عمرو نے حضرت جابر بن عبداللہ  رضی اللہ تعالیٰ عنہ  سے سنا ، وہ کہہ رہے تھے : رسول اللہ  صلی اللہ علی"}
{"hadithnumber": "5000", "text": "عمر و نے حضرت جابر  رضی اللہ تعالیٰ عنہ    کو پتوں و الے لشکر کے بارے میں بیان کرتے ہوئے سناکہ ( جب"}
{"hadithnumber": "5001", "text": "ہشام بن عروہ نے وہب بن کیسان سے ، انھوں  نے جابر بن عبداللہ  رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا"}
{"hadithnumber": "5002", "text": "امام مالک بن انس نے ابو نعیم وہب بن کیسان سے روایت کی کہ حضرت جابر بن عبداللہ رضی اللہ تعالیٰ عنہ  ن"}
{"hadithnumber": "5003", "text": "ولید بن کثیر نے کہا : میں نے وہب بن کیسان کو کہتے ہوئے سنا : میں نے حضرت جابر بن عبداللہ رضی اللہ تع"}
{"hadithnumber": "5004", "text": "عبیداللہ بن مقسم نے حضرت جابر بن عبداللہ  رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا : رسول اللہ  صلی ال"}
{"hadithnumber": "5005", "text": "امام مالک بن انس نے ابن شہاب سے ، انھوں نے محمد بن علی ( ابن حنفیہ )  کے دو بیٹوں عبداللہ اورحسن سے"}
{"hadithnumber": "5006", "text": "سفیان ، عبیداللہ ، یونس اور معمر سب نے زہری سے اسی سند کے ساتھ روایت کی اور یونس کی حدیث میں ہے : او"}
{"hadithnumber": "5007", "text": "حضرت ابو ثعلبہ رضی اللہ تعالیٰ عنہ  نے کہا کہ رسول اللہ  صلی اللہ علیہ وسلم  نے گھریلو گدھوں کا گوشت"}
{"hadithnumber": "5008", "text": "عبیداللہ نے کہا : مجھے نافع اور سالم نے حضرت  ابن عمر  رضی اللہ تعالیٰ عنہ  سے حدیث بیان کی کہ رسول"}
{"hadithnumber": "5009", "text": "ابن جریج اور امام مالک نے نافع سے ، انھوں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا : ر"}
{"hadithnumber": "5010", "text": "علی بن مسہر نے شیبانی سے روایت کی ، انھوں نے کہا :  میں نے حضرت عبداللہ بن اوفیٰ  رضی اللہ تعالیٰ عن"}
{"hadithnumber": "5011", "text": "عبدالواحد بن زیاد نے کہا : ہمیں سلیمانی شیبانی نے حدیث بیا ن کی ، انھوں نے کہا : میں نے عبداللہ بن ا"}
{"hadithnumber": "5012", "text": "عدی بن ثابت نے کہا : میں نے حضرت براء اورحضرت عبداللہ بن اوفیٰ رضی اللہ تعالیٰ عنہ  سے سنا ،  دونوں"}
{"hadithnumber": "5013", "text": "ابو اسحاق نے کہا : حضرت براء  رضی اللہ تعالیٰ عنہ  نے بیان کیا کہ خیبر کے دن ہم نے گدھے پکڑ لیے ، پھ"}
{"hadithnumber": "5014", "text": "ثابت بن عبید نے کہا :  میں نے حضرت براء رضی اللہ تعالیٰ عنہ  کویہ کہتے ہوئے سنا کہ ہمیں پالتو گدھوں"}
{"hadithnumber": "5015", "text": "جریر نے عاصم سے  ، انھوں نے شعبی سے ، انھوں نے براء بن عاذب  رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا"}
{"hadithnumber": "5016", "text": "حفص بن غیاث نے عاصم سے اسی سند کے ساتھ اسی کے  مانند روایت کی ۔"}
{"hadithnumber": "5017", "text": "حضرت ابن عباس رضی اللہ تعالیٰ عنہ  سے ر وایت ہے  ، کہا :  مجھے پتہ نہیں کہ رسول اللہ  صلی اللہ علیہ"}
{"hadithnumber": "5018", "text": "حاتم بن اسماعیل نے یزید بن ابی عبید سے ، انھوں نے سلمہ بن اکوع  رضی اللہ تعالیٰ عنہ سے روایت کی ، ان"}
{"hadithnumber": "5019", "text": "حماد بن مسعدہ ، صفوان بن عیسیٰ اور   ابو عاصم نبیل سب نے یزید بن ابی عبید سے اسی  سند کے ساتھ روایت"}
{"hadithnumber": "5020", "text": "ایوب نے محمد  ( بن سیرین  )  سے  ، انھوں نے حضرت انس رضی اللہ تعالیٰ عنہ سے روایت کی ،  کہا  : جب رس"}
{"hadithnumber": "5021", "text": "۔  ہشا م بن حسان نے محمد بن سیرین سے انھوں نے حضرت انس بن ما لک  رضی اللہ تعالیٰ عنہ  سے روایت کی  ،"}
{"hadithnumber": "5022", "text": "محمد بن علی نے حضرت جا بر بن عبد اللہ  رضی اللہ تعالیٰ عنہ  سے روایت کی کہ جنگ خیبر کے دن رسول اللہ"}
{"hadithnumber": "5023", "text": "محمد بن بکر نے کہا  :  ہمیں ابن جریج نے خبردی  ، کہا  :  مجھے ابو زبیر نے بتا یا کہ انھوں نے حضرت جا"}
{"hadithnumber": "5024", "text": "ابن وہب اور ابو عاصم نے ابن جریج سے اسی سند کے ساتھ روایت کی ۔"}
{"hadithnumber": "5025", "text": "عبد اللہ بن نمیر  ،  حفص بن غیاث اور وکیع نے ہشام سے ،  انھوں نے  ( اپنی اہلیہ  )  فاطمہ سے  ، انھوں"}
{"hadithnumber": "5026", "text": "ابو معاویہ اور ابو اسامہ دونوں نے ہشام سے اسی سند کے ساتھ روایت کی ۔"}
{"hadithnumber": "5027", "text": "عبد اللہ بن دینار سے روایت ہے  ، انھوں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  کو کہتے ہو ئے سنا کہ رسو"}
{"hadithnumber": "5028", "text": "لیث نے نافع سے ،  انھوں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے روایت کی  ، کہا :  ایک شخص نے رسول ا"}
{"hadithnumber": "5029", "text": "عبد اللہ بن نمیر نے کہا :  ہمیں عبید اللہ نے حدیث بیان کی  ، انھوں نے نافع سے ،  انھوں نے حضرت ابن ع"}
{"hadithnumber": "5030", "text": "یحییٰ نے عبید اللہ سے اسی سند سے اسی کے مانند روایت کی ۔"}
{"hadithnumber": "5031", "text": "ایوب  ، مالک بن مغول  ، ابن جریج  ، موسیٰ بن عقبہ اور اسامہ سب نے نافع سے ،  انھوں نے حضرت ابن عمر ر"}
{"hadithnumber": "5032", "text": "عبید اللہ کے والد معاذ نے کہا :  ہمیں شعبہ نے تو بہ عنبری سے حدیث بیان کی  ، انھوں نے  شعبی سے سنا"}
{"hadithnumber": "5033", "text": "محمدبن جعفر نے کہا  :  ہمیں شعبہ نے تو بہ عنبری سے حدیث بیان کی ،  انھوں نے کہا  :  شعبی نے مجھ سے ک"}
{"hadithnumber": "5034", "text": "امام مالک نے ابن شہاب سے انھوں نے ابو امامہ بن سہل بن حنیف سے ،  انھوں نے حضرت عبد اللہ بن عباس رضی"}
{"hadithnumber": "5035", "text": "یو نس نے ابن شہاب سے ،  انھوں نے ابو امامہ بن سہل بن حنیف انصاری سے روایت کی کہ حضرت عبد اللہ بن عبا"}
{"hadithnumber": "5036", "text": "صالح بن کیسان نے ابن شہاب سے  ،  انھوں نے ابو امامہ بن سہل سے ،  انھوں نے حضرت ابن عباس رضی اللہ تعا"}
{"hadithnumber": "5037", "text": "معمر نے زہری سے ،  انھوں نے ابو امامہ بن سہل بن حنیف سے ،  انھوں نے حضرت ابن عباس رضی اللہ تعالیٰ عن"}
{"hadithnumber": "5038", "text": "ابن منکدر سے روایت ہے کہ ابو امامہ بن سہل نے انھیں بتا یا کہ ابن عباس رضی اللہ تعالیٰ عنہ  نے کہا رس"}
{"hadithnumber": "5039", "text": "سعید بن جبیر نے کہا  :  میں نے حضرت ابن عباس رضی اللہ تعالیٰ عنہ  کو یہ کہتے ہوئے سنا کہ میری خالہ ا"}
{"hadithnumber": "5040", "text": "شیبانی نے یزید بن اصم سے روایت کی ،  کہا :  مدینہ منورہ میں ایک دلھا نے ہماری دعوت کی اور ہمیں تیرہ"}
{"hadithnumber": "5041", "text": "ابو زبیر نے حضرت جا بت بن عبد اللہ  رضی اللہ تعالیٰ عنہ  کو کہتے ہو ئے سنا کہ رسول اللہ  صلی اللہ عل"}
{"hadithnumber": "5042", "text": "ابو زبیر نے کہا : میں نے حضرت جابر  رضی اللہ تعالیٰ عنہ  سے سانڈے کے متعلق سوال کیا ، انھوں نے کہا :"}
{"hadithnumber": "5043", "text": "داود نے ابو نضرہ سے  ، انھوں نے حضرت ابو سعید رضی اللہ تعالیٰ عنہ  سے  روایت کی ، کہا : ایک شخص نے ع"}
{"hadithnumber": "5044", "text": "ابوعقیل دورقی نے کہا : ہمیں ابو نضرہ نے حضرت ابو سعید  رضی اللہ تعالیٰ عنہ  سے حدیث بیان کی کہ ایک ا"}
{"hadithnumber": "5045", "text": "ابو عوانہ نے ابو یعفور سے ، انھوں نے حضرت عبداللہ بن اوفیٰ  رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا :"}
{"hadithnumber": "5046", "text": "ابو بکر بن ابی شیبہ ، اسحاق بن ابراہیم اور ابن ابی عمر سب نے ابن عینیہ سے ، انھوں نے ابو یعفور سے اس"}
{"hadithnumber": "5047", "text": "شعبہ نے ابو یعفور سے یہ حدیث اسی سند سے روایت کی اور انھوں نے  \" سات غزوات \"  کہا ۔"}
{"hadithnumber": "5048", "text": "محمد بن جعفر نے کہا : ہمیں شعبہ نے ہشام بن زید سے حدیث بیان کی ، انھوں نےحضرت انس بن مالک رضی اللہ ت"}
{"hadithnumber": "5049", "text": "یحییٰ بن یحییٰ اور خالد بن حارث دونوں نے شعبہ سے اسی سند کے ساتھ روایت کی ، یحییٰ کی حدیث میں :  \" ا"}
{"hadithnumber": "5050", "text": "معاذ عنبری نے کہا : ہمیں کہمس نے ابن بریدہ سے حدیث بیان کی ، انھوں نے کہا : حضرت عبداللہ بن مغفل رضی"}
{"hadithnumber": "5051", "text": "عثمان بن عمر نے کہا : ہمیں کہمس نے اسی سند کے ساتھ اسی کے مانند خبر دی ۔"}
{"hadithnumber": "5052", "text": "محمد بن جعفر اورعبدالرحمان بن مہدی نے کہا : ہمیں شعبہ نے قتادہ سے انھوں نے عقبہ بن صہیان سے  ، انھوں"}
{"hadithnumber": "5053", "text": "اسماعیل بن علیہ نے ایوب سے ، انھوں نے سعید بن جبیر سے روایت کی کہ حضرت عبداللہ بن مغفل  رضی اللہ تعا"}
{"hadithnumber": "5054", "text": "ثقفی نے ایوب سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی ۔"}
{"hadithnumber": "5055", "text": "اسماعیل بن علیہ نے خالد حذا ء سے ، انھوں نے ابوقلابہ سے  ، انھوں نے ابو اشعث سے اور انھوں نے حضرت شد"}
{"hadithnumber": "5056", "text": "ہشیم ، عبدالوہاب ثقفی  ، شعبہ  ، سفیان اور منصور ، سب نے خالد حذا ء سے ابن علیہ کی سند سے اور اس کی"}
{"hadithnumber": "5057", "text": "محمد بن جعفر نے کہا : ہمیں شعبہ نے حدیث بیان کی ، کہا : میں نے ہشام بن زید بن انس بن مالک  رضی اللہ"}
{"hadithnumber": "5058", "text": "یحییٰ بن سعید ، عبدالرحمان بن مہدی ، خالد بن حارث اورابو اسامہ  ، سب نے شعبہ سے اسی سند کے ساتھ حدیث"}
{"hadithnumber": "5059", "text": "عبیداللہ کے والد معاذ ( عنبری )  نے کہا :  ہمیں شعبہ نے عدی ( بن ثابت انصاری )  سے حدیث بیان کی ، ان"}
{"hadithnumber": "5060", "text": "محمد بن جعفر اور عبدالرحمان بن  مہدی نے شعبہ سے اسی سندکے ساتھ اسی کے مانند حدیث بیا ن کی ۔"}
{"hadithnumber": "5061", "text": "ابو عوانہ نے ابو بشر سے ،  انھوں نے سعید بن جبیر سے  روایت کی ، کہا : ایک مرتبہ حضرت ابن عمر رضی الل"}
{"hadithnumber": "5062", "text": "ہشیم نے کہا : ہمیں ابو بشر نے سعید بن جبیر سے  روایت کی  ، کہا :  ( ایک بار )  حضرت ابن عمر رضی اللہ"}
{"hadithnumber": "5063", "text": "یحییٰ بن سعید ، محمد بن بکیر اور حجاج بن محمد نے کہا : مجھے ابو زبیر نے بتایا ، انھوں نے حضرت جابر ب"}
