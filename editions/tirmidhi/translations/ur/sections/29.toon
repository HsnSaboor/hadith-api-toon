{"hadithnumber": "2090", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے  ( مرنے کے بعد )"}
{"hadithnumber": "2091", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”قرآن اور علم فرائض سیکھ"}
{"hadithnumber": "2092", "text": "جابر بن عبداللہ رضی الله عنہما کہتے ہیں کہ  سعد بن ربیع کی بیوی اپنی دو بیٹیوں کو جو سعد سے پیدا ہوئ"}
{"hadithnumber": "2093", "text": "ہزیل بن شرحبیل کہتے ہیں کہ  ابوموسیٰ اور سلمان بن ربیعہ کے پاس ایک آدمی آیا اور اس نے ان سے بیٹی،"}
{"hadithnumber": "2094", "text": "علی رضی الله عنہ کہتے ہیں کہ  تم لوگ یہ آیت پڑھتے ہو «من بعد وصية توصون بها أو دين» ”تم سے کی گئی و"}
{"hadithnumber": "2095", "text": "علی رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فیصلہ کیا: ”حقیقی بھائی وارث ہوں گے نہ"}
{"hadithnumber": "2096", "text": "جابر بن عبداللہ رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم میری عیادت کی غرض سے تشریف"}
{"hadithnumber": "2097", "text": "جابر بن عبداللہ رضی الله عنہما کہتے ہیں کہ  میں بیمار ہوا تو رسول اللہ صلی اللہ علیہ وسلم میری عیادت"}
{"hadithnumber": "2098", "text": "عبداللہ بن عباس رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”اللہ کی جانب"}
{"hadithnumber": "2099", "text": "عمران بن حصین رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے پاس ایک آدمی نے آ کر عرض ک"}
{"hadithnumber": "2100", "text": "قبیصہ بن ذویب رضی الله عنہ کہتے ہیں کہ  ابوبکر رضی الله عنہ کے پاس ایک دادی یا نانی نے آ کر کہا: می"}
{"hadithnumber": "2101", "text": "قبیصہ بن ذویب رضی الله عنہ کہتے ہیں کہ  ابوبکر رضی الله عنہ کے پاس ایک دادی یا نانی میراث سے اپنا حص"}
{"hadithnumber": "2102", "text": "عبداللہ بن مسعود رضی الله عنہ سے روایت ہے کہ  وہ  ( پوتے کے ترکہ میں )  دادی اور اس کے بیٹے کے حصہ ک"}
{"hadithnumber": "2103", "text": "ابوامامہ بن سہل بن حنیف رضی الله عنہما کہتے ہیں کہ  عمر بن خطاب رضی الله عنہ نے ابوعبیدہ رضی الله عن"}
{"hadithnumber": "2104", "text": "ام المؤمنین عائشہ رضی الله عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”ماموں اس آدمی"}
{"hadithnumber": "2105", "text": "ام المؤمنین عائشہ رضی الله عنہا سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم کا ایک آزاد کردہ غلام ک"}
{"hadithnumber": "2106", "text": "عبداللہ بن عباس رضی الله عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم کے زمانے میں ایک آدمی م"}
{"hadithnumber": "2107", "text": "اسامہ بن زید رضی الله عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”مسلمان کافر کا"}
{"hadithnumber": "2108", "text": "جابر رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”دو مختلف مذہب کے لوگ ایک د"}
{"hadithnumber": "2109", "text": "ابوہریرہ رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”قاتل  ( مقتول کا )  وا"}
{"hadithnumber": "2110", "text": "عمر رضی الله عنہ کہتے ہیں کہ  دیت عاقلہ ۱؎ پر واجب ہے، اور بیوی اپنے شوہر کی دیت میں سے کسی چیز کا و"}
{"hadithnumber": "2111", "text": "ابوہریرہ رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے بنی لحیان کی ایک عورت کے بارے"}
{"hadithnumber": "2112", "text": "تمیم داری رضی الله عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم سے سوال کیا: اس مشرک کے بارے"}
{"hadithnumber": "2113", "text": "عبداللہ بن عمرو رضی الله عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جو شخص کسی ا"}
{"hadithnumber": "2114", "text": "عبداللہ بن عمرو رضی الله عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”ولاء کا وارث"}
{"hadithnumber": "2115", "text": "واثلہ بن اسقع رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”عورت تین قسم کی میر"}
