{"metadata":{"name":"Sunan Ibn Majah","section":{"29":" Chapters on Food"},"section_detail":{"29":{"hadithnumber_first":3251,"hadithnumber_last":3370,"arabicnumber_first":3251,"arabicnumber_last":3370}}},"hadiths":[{"hadithnumber":3359,"arabicnumber":3359,"text":"Rapporté par ‘Ali : J’ai préparé de la nourriture et j’ai invité le Messager d’Allah (ﷺ). Il est venu et a vu des images dans la maison, alors il est reparti","grades":[{"name":"Al-Albani","grade":"Sahih"},{"name":"Muhammad Fouad Abd al-Baqi","grade":"Sahih"},{"name":"Shuaib Al Arnaut","grade":"Sahih"},{"name":"Zubair Ali Zai","grade":"Sahih"}],"reference":{"book":29,"hadith":109}}]}