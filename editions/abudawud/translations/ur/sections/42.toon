{"hadithnumber": "4649", "text": "عبدالرحمٰن بن اخنس سے روایت ہے کہ  وہ مسجد میں تھے، ایک شخص نے علی رضی اللہ عنہ کا  ( برائی کے ساتھ"}
{"hadithnumber": "4650", "text": "ریاح بن حارث کہتے ہیں  میں کوفہ کی مسجد میں فلاں شخص ۱؎ کے پاس بیٹھا تھا، ان کے پاس کوفہ کے لوگ جمع"}
{"hadithnumber": "4651", "text": "انس بن مالک رضی اللہ عنہ بیان کرتے ہیں  نبی اکرم صلی اللہ علیہ وسلم احد پہاڑ پر چڑھے پھر آپ کے پیچھے"}
{"hadithnumber": "4652", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  میرے پاس جبرائیل آئے، ان"}
{"hadithnumber": "4653", "text": "جابر رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جہنم میں ان لوگوں میں سے"}
{"hadithnumber": "4654", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ( موسیٰ کی روایت میں «فل"}
{"hadithnumber": "4655", "text": "مسور بن مخرمہ رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم حدیبیہ کے زمانے میں نکلے، پھر"}
{"hadithnumber": "4656", "text": "عمر بن خطاب رضی اللہ عنہ کے مؤذن اقرع کہتے ہیں  مجھے عمر نے ایک پادری کے پاس بلانے کے لیے بھیجا، میں"}
{"hadithnumber": "4657", "text": "عمران بن حصین رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  میری امت کے سب سے"}
{"hadithnumber": "4658", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  میرے صحابہ کو برا ب"}
{"hadithnumber": "4659", "text": "عمرو بن ابی قرہ کہتے ہیں کہ  حذیفہ رضی اللہ عنہ مدائن میں تھے اور وہ ان باتوں کا ذکر کیا کرتے تھے، ج"}
{"hadithnumber": "4660", "text": "حارث بن ہشام عبداللہ بن زمعہ رضی اللہ عنہ کہتے ہیں کہ  جب رسول اللہ صلی اللہ علیہ وسلم کی بیماری سخت"}
{"hadithnumber": "4661", "text": "عبیداللہ بن عبداللہ بن عتبہ سے روایت ہے کہ  عبداللہ بن زمعہ رضی اللہ عنہ نے انہیں یہی بات بتائی اور"}
{"hadithnumber": "4662", "text": "ابوبکرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے حسن بن علی رضی اللہ عنہما کو فرمای"}
{"hadithnumber": "4663", "text": "محمد بن سیرین کہتے ہیں کہ  حذیفہ رضی اللہ عنہ نے کہا: لوگوں میں کوئی ایسا نہیں جس کو فتنہ پہنچے اور"}
{"hadithnumber": "4664", "text": "ثعلبہ بن ضبیعہ کہتے ہیں کہ  ہم حذیفہ رضی اللہ عنہ کے پاس گئے تو آپ نے کہا: میں ایک ایسے شخص کو جانتا"}
{"hadithnumber": "4665", "text": "ضبیعہ بن حصین ثعلبی سے بھی  اسی مفہوم کی حدیث مروی ہے۔"}
{"hadithnumber": "4666", "text": "قیس بن عباد کہتے ہیں کہمیں نے علی رضی اللہ عنہ سے کہا: ہمیں آپ  ( معاویہ رضی اللہ عنہ سے جنگ کے لیے"}
