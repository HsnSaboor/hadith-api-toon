hadiths[1]{hadithnumber,text}:
17719,أذعشحأزڬۏىأثؼزأضؼۏزأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأتۏڬأوشحثۄأۄوأهًڲأىثۏأ﷽أڬۏأرزوحأوۏڽأذتعشأۄًةەأ؏أۄوأهًڲًڽأڬۏأڬهأحؼزتزأډتشأضًأډتهۏضأتلشتزأحہۏأ؏أۄوأهًڲأىثۏأ﷽أڬەأځتضأؽهۄأڬۏأزشرًتضحأهەأڬشأإةەأحہەأ؏أىثۏأ﷽أىەأذعشحأؼوشأشعۏأتههۄأؼىۄأضەألشوتۏتأڬۄأتټہًأتًشأتىۄۏڽأؽهۄأزًأ؏أتىۄًڽأىەأؼشعأڬۏتأۏتأشضًهأتههۄأ$أوۏشەأځتضأظشلأتحىتأؽهۄأۄەأدًأودہەأتًشأثډًڽأڬًأظشلأډتشأوۄۏىەأڬەأهةەأڬتلۏأۄًأضڬحتأۄەأ؏أىثۏأ﷽أىەأتځىتأذڬوأزًثتشۄأزۄشتۏتأ؏أذعشحأؼوشأشعۏأتههۄأؼىۄأڬۄىەأهڲەأۏتأشضًهأتههۄأ$أدًأإځأڬتأذڬوأ؏أوۏڽأتثہۏأځًشتأڬشحتأۄًڽأ؏أډىتىډۄأذعشحأؼوشأشعۏأتههۄأؼىۄأڬہڔەأۄًأڲةەأ؏أۄوأثہۏأتىأڬەأضتحہأډهأځڔەأ؏أًۄأۄوۏڽأهەأڬشأتځىەأتۏڬأڬوشەأوۏڽأځۄىډەأ؏أډتثۏأىڬتهۏأتًشأزشًتصۄأڬہًهأزۏتأ؏أزۏڬہتأڬۄأڬوشەأوۏڽأثڬشۏأڬەأثډەأڬۏأغشذأڬہدًشأڬەأڋہۏشأهڲەأۄًةەأۄۏڽأ؏أذعشحأؼوشأشعۏأتههۄأؼىۄأىەألشوتۏتأدحىتأهۏىتأډتۄًأ؏أهەأهًأ؏أډىتىډۄأۄوأوۏڽأضەأۄشأطرظأىەأتځىۏأتځىۏأعشًشحأڬەأوغتثمأڬہدًشۏڽأهەأهۏڽأ؏أوۏڽأضثأضەأإرشأوۏڽأحہتأ؏أوۏڽأىەأدًأؽًشأڬۏتأحًأتۏضتأوذضًضأۄًتأڬۄأۄوأضثأىەأوهأڬشأثہۏأتضأوۏڽأضەأتۏڬأڬہدًشأحڬأڬوأىۄۏڽأڬۏأۗأ
