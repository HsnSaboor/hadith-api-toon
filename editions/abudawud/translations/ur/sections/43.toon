{"hadithnumber": "5149", "text": "عوف بن مالک اشجعی کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  میں اور بیوہ عورت جس کے چہرے"}
{"hadithnumber": "5150", "text": "سہل رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  قیامت کے دن میں اور یتیم کی کف"}
{"hadithnumber": "5151", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جبرائیل مجھے بر"}
{"hadithnumber": "5152", "text": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  انہوں نے ایک بکری ذبح کی تو  ( گھر والوں )  سے کہا: کیا"}
{"hadithnumber": "5153", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  ایک شخص نبی اکرم صلی اللہ علیہ وسلم کے پاس آیا، اپنے پڑوسی کی شکا"}
{"hadithnumber": "5154", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص اللہ اور یوم آخرت"}
{"hadithnumber": "5155", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  میں نے عرض کیا: اللہ کے رسول! میرے دو پڑوسی ہیں، میں ان"}
{"hadithnumber": "5156", "text": "علی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کی آخری بات  ( انتقال کے موقع پر )  یہ تھ"}
{"hadithnumber": "5157", "text": "معرور بن سوید کہتے ہیں کہ  میں نے ابوذر کو ربذہ  ( مدینہ کے قریب ایک گاؤں )  میں دیکھا وہ ایک موٹی چ"}
{"hadithnumber": "5158", "text": "معرور بن سوید کہتے ہیں کہ  ہم ابوذر رضی اللہ عنہ کے پاس ربذہ میں آئے تو کیا دیکھتے ہیں کہ ان کے جسم"}
{"hadithnumber": "5159", "text": "ابومسعود انصاری رضی اللہ عنہ کہتے ہیں کہ  میں اپنے ایک غلام کو مار رہا تھا اتنے میں میں نے اپنے پیچھ"}
{"hadithnumber": "5160", "text": "اس سند سے بھی اعمش سے اسی طریق سے اسی مفہوم کی حدیث اسی طرح مروی ہے، اس میں یہ ہے کہ  میں اپنے ایک ک"}
{"hadithnumber": "5161", "text": "ابوذر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تمہارے غلاموں اور لونڈیوں م"}
{"hadithnumber": "5162", "text": "رافع بن مکیث رضی اللہ عنہ سے روایت ہے (یہ ان صحابہ میں سے تھے جو صلح حدیبیہ میں نبی اکرم صلی اللہ عل"}
{"hadithnumber": "5163", "text": "رافع بن مکیث سے روایت ہے، اور رافع قبیلہ جہنیہ سے تعلق رکھتے تھے اور صلح حدیبیہ کے موقع پر رسول اللہ"}
{"hadithnumber": "5164", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  ایک شخص رسول اللہ صلی اللہ علیہ وسلم کے پاس آیا اور عرض ک"}
{"hadithnumber": "5165", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  مجھ سے نبی توبہ ابوالقاسم صلی اللہ علیہ وسلم نے فرمایا:  جس نے اپ"}
{"hadithnumber": "5166", "text": "ہلال بن یساف کہتے ہیں کہ  ہم سوید بن مقرن رضی اللہ عنہ کے گھر اترے، ہمارے ساتھ ایک تیز مزاج بوڑھا تھ"}
{"hadithnumber": "5167", "text": "معاویہ بن سوید بن مقرن کہتے ہیں  میں نے اپنے ایک غلام کو طمانچہ مار دیا تو ہمارے والد نے ہم دونوں کو"}
{"hadithnumber": "5168", "text": "زاذان کہتے ہیں کہ  میں ابن عمر رضی اللہ عنہما کے پاس آیا، آپ نے اپنا ایک غلام آزاد کیا تھا، آپ نے زم"}
{"hadithnumber": "5169", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب غلام اپنے آقا"}
{"hadithnumber": "5170", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو کسی کی بیوی یا غلام و"}
{"hadithnumber": "5171", "text": "انس بن مالک رضی اللہ عنہ سے روایت ہے کہ  ایک شخص نے رسول اللہ صلی اللہ علیہ وسلم کے کسی ایک کمرے سے"}
{"hadithnumber": "5172", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا:  جو"}
{"hadithnumber": "5173", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب نگاہ اندر پہنچ گئی تو"}
{"hadithnumber": "5174", "text": "ہزیل کہتے ہیں کہ  ایک شخص رسول اللہ صلی اللہ علیہ وسلم کے پاس آیا،  ( عثمان کی روایت میں ہے کہ وہ سع"}
{"hadithnumber": "5175", "text": "سعد رضی اللہ عنہ نے  نبی اکرم صلی اللہ علیہ وسلم سے اسی طرح روایت کی ہے۔"}
{"hadithnumber": "5176", "text": "کلدہ بن حنبل سے روایت ہے کہ  صفوان بن امیہ رضی اللہ عنہ نے انہیں دودھ، ہرن کا بچہ اور چھوٹی چھوٹی کک"}
{"hadithnumber": "5177", "text": "ربعی کہتے ہیں کہ بنو عامر کے ایک شخص نے ہم سے بیان کیا کہ  اس نے نبی اکرم صلی اللہ علیہ وسلم کے پاس"}
{"hadithnumber": "5178", "text": "ربعی بن حراش کہتے ہیں کہ مجھ سے بیان کیا گیا ہے کہ  بنی عامر کے ایک شخص نے نبی اکرم صلی اللہ علیہ وس"}
{"hadithnumber": "5179", "text": "بنو عامر کے ایک شخص سے روایت ہے کہ  اس نے نبی اکرم صلی اللہ علیہ وسلم سے اجازت طلب کی، پھر راوی نے ا"}
{"hadithnumber": "5180", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  میں انصار کی مجالس میں سے ایک مجلس میں بیٹھا ہوا تھا اتنے می"}
{"hadithnumber": "5181", "text": "ابوموسیٰ اشعری رضی اللہ عنہ سے روایت ہے کہ  وہ عمر رضی اللہ عنہ کے پاس آئے، اور ان سے اندر آنے کی اج"}
{"hadithnumber": "5182", "text": "عبید بن عمیر سے روایت ہے کہ  ابوموسیٰ رضی اللہ عنہ نے عمر رضی اللہ عنہ سے اجازت مانگی، پھر راوی نے ی"}
{"hadithnumber": "5183", "text": "اس سند سے بھی ابوموسیٰ رضی اللہ عنہ سے یہی قصہ مروی ہے، اس میں ہے کہ  عمر رضی اللہ عنہ نے ابوموسیٰ س"}
{"hadithnumber": "5184", "text": "ربیعہ بن ابوعبدالرحمٰن اور دوسرے بہت سے علماء سے اس سلسلہ میں مروی ہے  عمر رضی اللہ عنہ نے ابوموسیٰ"}
{"hadithnumber": "5185", "text": "قیس بن سعد رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ہمارے گھر ملاقات کے لیے تشریف لائے"}
{"hadithnumber": "5186", "text": "عبداللہ بن بسر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم جب کسی کے دروازے پر آتے تو درو"}
{"hadithnumber": "5187", "text": "جابر رضی اللہ عنہ کہتے ہیں کہ  وہ اپنے والد کے قرضے کے سلسلے میں گفتگو کرنے کے لیے رسول اللہ صلی الل"}
{"hadithnumber": "5188", "text": "نافع بن عبدالحارث رضی اللہ عنہ کہتے ہیں کہ  میں رسول اللہ صلی اللہ علیہ وسلم کے ساتھ نکلا یہاں تک کہ"}
{"hadithnumber": "5189", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  کسی آدمی کو بلا بھیجنا"}
{"hadithnumber": "5190", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب کوئی آدمی کھانے کے"}
{"hadithnumber": "5191", "text": "عبیداللہ بن ابی یزید کہتے ہیں کہ  انہوں نے ابن عباس رضی اللہ عنہما کو کہتے سنا کہ آیت استیذان پر اکث"}
{"hadithnumber": "5192", "text": "عکرمہ سے روایت ہے کہ  عراق کے کچھ لوگوں نے کہا: ابن عباس! اس آیت کے بارے میں آپ کا کیا خیال ہے جس می"}
{"hadithnumber": "5193", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  قسم ہے اس ذات کی جس کے ق"}
{"hadithnumber": "5194", "text": "عبداللہ بن عمرو رضی اللہ عنہما سے روایت ہے کہ  ایک شخص نے رسول اللہ صلی اللہ علیہ وسلم سے پوچھا: اسل"}
{"hadithnumber": "5195", "text": "عمران بن حصین رضی اللہ عنہما کہتے ہیں کہ  ایک شخص نبی اکرم صلی اللہ علیہ وسلم کے پاس آیا اور اس نے"}
{"hadithnumber": "5196", "text": "معاذ بن انس رضی اللہ عنہ نے نبی اکرم صلی اللہ علیہ وسلم سے اسی مفہوم کی حدیث روایت کی ہے  لیکن اس می"}
{"hadithnumber": "5197", "text": "ابوامامہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ کے نزدیک سب سے بہتر"}
{"hadithnumber": "5198", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  چھوٹا بڑے کو سلام کرے گا"}
{"hadithnumber": "5199", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  سوار پیدل چلنے والے کو س"}
{"hadithnumber": "5200", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  جب تم میں سے کوئی اپنے بھائی سے ملے تو اسے سلام کرے، پھر اگر ان د"}
{"hadithnumber": "5201", "text": "عمر رضی اللہ عنہ سے روایت ہے کہ  وہ نبی اکرم صلی اللہ علیہ وسلم کے پاس آئے اور آپ اپنے ایک کمرے میں"}
{"hadithnumber": "5202", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کچھ ایسے بچوں کے پاس آئے جو کھیل رہے تھے"}
{"hadithnumber": "5203", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ہمارے پاس آئے اور میں ابھی ایک بچہ تھا، آ"}
{"hadithnumber": "5204", "text": "شہر بن حوشب کہتے ہیں کہ  انہیں اسماء بنت یزید رضی اللہ عنہا نے خبر دی ہے کہ ہم عورتوں کے پاس سے نبی"}
{"hadithnumber": "5205", "text": "سہیل بن ابوصالح کہتے ہیں کہ  میں اپنے والد کے ساتھ شام گیا تو وہاں لوگوں  ( یعنی قافلے والوں )  کا گ"}
{"hadithnumber": "5206", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب کوئی یہودی تم"}
{"hadithnumber": "5207", "text": "انس رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم کے اصحاب نے آپ سے عرض کیا: اہل کتاب  ("}
{"hadithnumber": "5208", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں سے کوئی مجلس م"}
{"hadithnumber": "5209", "text": "ابوجری ہجیمی رضی اللہ عنہ کہتے ہیں کہ  میں نبی اکرم صلی اللہ علیہ وسلم کے پاس آیا اور میں نے کہا: «ع"}
{"hadithnumber": "5210", "text": "علی بن ابی طالب رضی اللہ عنہ سے روایت ہے (ابوداؤد کہتے ہیں: حسن بن علی نے اسے مرفوع کیا ہے) ، وہ کہت"}
{"hadithnumber": "5211", "text": "براء بن عازب رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب دو مسلمان آپس م"}
{"hadithnumber": "5212", "text": "براء رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب دو مسلمان آپس میں ملتے او"}
{"hadithnumber": "5213", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  جب یمن کے لوگ آئے تو رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:"}
{"hadithnumber": "5214", "text": "قبیلہ عنزہ کے ایک شخص سے روایت ہے کہ  اس نے ابوذر رضی اللہ عنہ سے جب وہ شام سے واپس لائے گئے کہا: می"}
{"hadithnumber": "5215", "text": "ابو سعید خدری رضی اللہ عنہ سے روایت ہے کہ  جب قریظہ کے لوگ سعد کے حکم  ( فیصلہ )  پر اترے تو نبی اکر"}
{"hadithnumber": "5216", "text": "اس سند سے بھی شعبہ سے یہی حدیث مروی ہے  اس میں ہے: جب وہ مسجد سے قریب ہوئے تو آپ نے انصار سے فرمایا:"}
{"hadithnumber": "5217", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  میں نے طور طریق اور چال ڈھال میں فاطمہ رضی اللہ عنہا سے"}
{"hadithnumber": "5218", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  اقرع بن حابس رضی اللہ عنہ نے نبی اکرم صلی اللہ علیہ وسلم کو حسین"}
{"hadithnumber": "5219", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  عائشہ! خوش ہو ج"}
{"hadithnumber": "5220", "text": "شعبی سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم جعفر بن ابی طالب رضی اللہ عنہ سے ملے تو انہیں چمٹا"}
{"hadithnumber": "5221", "text": "ایاس بن دغفل کہتے ہیں کہ  میں نے ابونضرہ کو دیکھا انہوں نے حسن بن علی رضی اللہ عنہما کے گال پر بوسہ"}
{"hadithnumber": "5222", "text": "براء رضی اللہ عنہ کہتے ہیں کہ  میں ابوبکر رضی اللہ عنہ کے ساتھ آیا، پہلے پہل جب وہ مدینہ آئے تو کیا"}
{"hadithnumber": "5223", "text": "عبدالرحمٰن بن ابی لیلیٰ کا بیان ہے کہ  عبداللہ بن عمر رضی اللہ عنہما نے ان سے بیان کیا اور راوی نے ا"}
{"hadithnumber": "5224", "text": "اسید بن حضیرانصاری رضی اللہ عنہ کہتے ہیں کہ  وہ کچھ لوگوں سے باتیں کر رہے تھے اور وہ مسخرے والے آدمی"}
{"hadithnumber": "5225", "text": "زارع سے روایت ہے، وہ وفد عبدالقیس میں تھے وہ کہتے ہیں  جب ہم مدینہ پہنچے تو اپنے اونٹوں سے جلدی جلدی"}
{"hadithnumber": "5226", "text": "ابوذر رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے مجھ کو پکارا: اے ابوذر! میں نے کہا: م"}
{"hadithnumber": "5227", "text": "عمران بن حصین رضی اللہ عنہما کہتے ہیں کہ  ہم زمانہ جاہلیت میں کہا کرتے تھے: «أنعم الله بك عينا وأنعم"}
{"hadithnumber": "5228", "text": "عبداللہ بن رباح انصاری کہتے ہیں کہ  ابوقتادہ رضی اللہ عنہ نے ہم سے بیان کیا کہ: نبی اکرم صلی اللہ عل"}
{"hadithnumber": "5229", "text": "ابومجلز کہتے ہیں کہ  معاویہ رضی اللہ عنہ ابن زبیر اور ابن عامر رضی اللہ عنہ کے پاس آئے، تو ابن عامر"}
{"hadithnumber": "5230", "text": "ابوامامہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ہمارے پاس ایک چھڑی کا سہارا لیے ہوئے"}
{"hadithnumber": "5231", "text": "غالب کہتے ہیں کہ  ہم حسن کے دروازے پر بیٹھے تھے اتنے میں ایک شخص آیا اور کہنے لگا: میرے باپ نے میرے"}
{"hadithnumber": "5232", "text": "ابوسلمہ سے روایت ہے کہ عائشہ رضی اللہ عنہا نے ان سے بیان کیا کہ  نبی اکرم صلی اللہ علیہ وسلم نے ان س"}
{"hadithnumber": "5233", "text": "ابوعبدالرحمٰن فہری کہتے ہیں کہ  میں غزوہ حنین میں رسول اللہ صلی اللہ علیہ وسلم کے ساتھ شریک تھا، ہم"}
{"hadithnumber": "5234", "text": "مرداس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ہنسے تو ابوبکر رضی اللہ عنہ یا عمر رضی"}
{"hadithnumber": "5235", "text": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم میرے پاس سے گزرے، میں اور م"}
{"hadithnumber": "5236", "text": "اس سند سے بھی اعمش سے (ان کی سابقہ سند سے) یہی حدیث مروی ہے اس میں ہے کہ  رسول اللہ صلی اللہ علیہ وس"}
{"hadithnumber": "5237", "text": "انس بن مالک رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نکلے  ( راہ میں )  ایک اونچا ق"}
{"hadithnumber": "5238", "text": "دکین بن سعید مزنی رضی اللہ عنہ کہتے ہیں کہ  ہم نبی اکرم صلی اللہ علیہ وسلم کے پاس آئے اور آپ سے غلہ"}
{"hadithnumber": "5239", "text": "عبداللہ بن حبشی رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص  ( بلا ض"}
{"hadithnumber": "5240", "text": "عروہ بن زبیر نے اس حدیث کو  نبی اکرم صلی اللہ علیہ وسلم سے اسی طرح مرفوعاً روایت کیا ہے۔"}
{"hadithnumber": "5241", "text": "حسان بن ابراہیم کہتے ہیں  میں نے ہشام بن عروہ سے جو عروہ کے محل سے ٹیک لگائے ہوئے تھے بیر کے درخت کا"}
{"hadithnumber": "5242", "text": "بریدہ رضی اللہ عنہ کہتے ہیں  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا ہے: انسان کے جسم"}
{"hadithnumber": "5243", "text": "ابوذر رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  ابن آدم کے ہر جوڑ پر صبح"}
{"hadithnumber": "5244", "text": "ابوالاسود الدیلی نے ابوذر سے یہی حدیث روایت کی ہے  اور نبی اکرم صلی اللہ علیہ وسلم کا ذکر اس کے وسط"}
{"hadithnumber": "5245", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ایک شخص نے جس نے کبھی"}
{"hadithnumber": "5246", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے  وہ کبھی اسے موقوفاً روایت کرتے ہیں اور کبھی اسے نبی اکرم"}
{"hadithnumber": "5247", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  ایک چوہیا آئی اور چراغ کی بتی کو پکڑ کر کھینچتی ہوئی لائ"}
{"hadithnumber": "5248", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب سے ہماری سانپوں سے لڑ"}
{"hadithnumber": "5249", "text": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  سانپ کوئی بھی ہو"}
{"hadithnumber": "5250", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص سانپوں ک"}
{"hadithnumber": "5251", "text": "عباس بن عبدالمطلب رضی اللہ عنہ کہتے ہیں کہ  ہم نے رسول اللہ صلی اللہ علیہ وسلم سے عرض کیا: ہم زمزم ک"}
{"hadithnumber": "5252", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  سانپوں کو مار"}
{"hadithnumber": "5253", "text": "ابولبابہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے ان سانپوں کو مارنے سے روکا ہے"}
{"hadithnumber": "5254", "text": "نافع سے روایت ہے کہ  ابن عمر رضی اللہ عنہما نے لبابہ رضی اللہ عنہ کی حدیث سننے کے بعد ایک سانپ اپنے"}
{"hadithnumber": "5255", "text": "اسامہ نے نافع سے یہی حدیث روایت کی ہے  اس میں ہے نافع نے کہا: پھر اس کے بعد میں نے اسے ان کے گھر میں"}
{"hadithnumber": "5256", "text": "محمد بن ابو یحییٰ کہتے ہیں کہ  مجھ سے میرے والد نے بیان کیا کہ وہ اور ان کے ایک ساتھی دونوں ابو سعید"}
{"hadithnumber": "5257", "text": "ابوسائب کہتے ہیں کہ  میں ابو سعید خدری رضی اللہ عنہ کے پاس آیا، اسی دوران کہ میں ان کے پاس بیٹھا ہوا"}
{"hadithnumber": "5258", "text": "اس سند سے ابن عجلان سے یہی حدیث مختصراً مروی ہے، اس میں ہے کہ  اسے  ( سانپ کو )  تین بار آگاہ کر دو،"}
{"hadithnumber": "5259", "text": "ہشام بن زہرہ کے غلام ابوسائب نے خبر دی ہے کہ  وہ ابو سعید خدری رضی اللہ عنہ کے پاس آئے، پھر راوی نے"}
{"hadithnumber": "5260", "text": "ابولیلیٰ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم سے گھروں میں نکلنے والے سانپوں کے متعلق دریافت"}
{"hadithnumber": "5261", "text": "ابن مسعود رضی اللہ عنہ کہتے ہیں کہ  سبھی سانپوں کو مارو سوائے اس سانپ کے جو سفید ہوتا ہے چاندی کی چھ"}
{"hadithnumber": "5262", "text": "سعد رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے چھپکلی کو مارنے کا حکم دیا ہے، اور اسے"}
{"hadithnumber": "5263", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے چھپکلی کو پہلے ہی"}
{"hadithnumber": "5264", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  پہلے وار میں ستر نیکیا"}
{"hadithnumber": "5265", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  نبیوں میں سے ایک نبی ا"}
{"hadithnumber": "5266", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  انبیاء میں سے ایک نبی"}
{"hadithnumber": "5267", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے چار جانوروں کے قتل سے روک"}
{"hadithnumber": "5268", "text": "عبداللہ (عبداللہ بن مسعود) رضی اللہ عنہ کہتے ہیں کہ  ہم رسول اللہ صلی اللہ علیہ وسلم کے ساتھ ایک سفر"}
{"hadithnumber": "5269", "text": "عبدالرحمٰن بن عثمان سے روایت ہے کہ  ایک طبیب نے رسول اللہ صلی اللہ علیہ وسلم سے مینڈک کو دوا میں است"}
{"hadithnumber": "5270", "text": "عبداللہ بن مغفل رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے  ( کھیل کود اور ہنسی مذاق"}
{"hadithnumber": "5271", "text": "ام عطیہ انصاریہ رضی اللہ عنہا سے روایت ہے کہ  مدینہ میں ایک عورت عورتوں کا ختنہ کیا کرتی تھی تو رسول"}
{"hadithnumber": "5272", "text": "ابواسید انصاری رضی اللہ عنہ سے روایت ہے کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم کو اس وقت فرماتے ہ"}
{"hadithnumber": "5273", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے مرد کو دو عورتوں کے بیچ"}
{"hadithnumber": "5274", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  اللہ عزوجل فرماتا ہے:"}
