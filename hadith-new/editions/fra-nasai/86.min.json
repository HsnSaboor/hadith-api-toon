{"metadata":{"name":"Sunan an Nasai","section":{"1":"The Book of Purification"},"section_detail":{"1":{"hadithnumber_first":1,"hadithnumber_last":324,"arabicnumber_first":1,"arabicnumber_last":324}}},"hadiths":[{"hadithnumber":86,"arabicnumber":86,"text":"Rapporté par Abu Hurairah : Le Messager d'Allah (ﷺ) a dit : \"Lorsque l'un de vous fait les ablutions, qu'il mette de l'eau dans son nez puis la rejette","grades":[{"name":"Abu Ghuddah","grade":"Sahih"},{"name":"Al-Albani","grade":"Sahih"},{"name":"Zubair Ali Zai","grade":"Sahih - Agreed Upon"}],"reference":{"book":1,"hadith":86}}]}