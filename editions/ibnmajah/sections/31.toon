{"hadithnumber": "3533", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عُبَيْدِ بْنِ عَبْدِ الرَّحْمَنِ الْكِنْدِيُّ قَالَ: حَدَّثَنَا عَلِيُّ بْ", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'}", "reference": "Book 31, Hadith 98", "international_number": "3533", "narrator_chain": ""}
{"hadithnumber": "3534", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَبْدَةُ بْنُ سُلَيْمَانَ،‏‏‏‏ عَنْ هِشَ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 31, Hadith 99", "international_number": "3534", "narrator_chain": ""}
{"hadithnumber": "3535", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ عَمْرِو بْنِ السَّرْحِ،‏‏‏‏ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ،‏‏‏‏ أَخْ", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 31, Hadith 100", "international_number": "3535", "narrator_chain": ""}
{"hadithnumber": "3536", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ،‏‏‏‏ حَدَّثَنَا عَبْدَةُ بْنُ سُلَيْمَانَ،‏‏‏", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 31, Hadith 101", "international_number": "3536", "narrator_chain": ""}
{"hadithnumber": "3537", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ،‏‏‏‏ أَنْبَأَنَا شُعْبَ", "grades": "{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 31, Hadith 102", "international_number": "3537", "narrator_chain": ""}
{"hadithnumber": "3538", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ سُفْيَانَ،‏‏‏‏ عَنْ سَ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 31, Hadith 103", "international_number": "3538", "narrator_chain": ""}
{"hadithnumber": "3539", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا أَبُو الْأَحْوَصِ،‏‏‏‏ عَنْ سِمَاكٍ،‏‏‏‏", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 31, Hadith 104", "international_number": "3539", "narrator_chain": ""}
{"hadithnumber": "3540", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ أَبِي جَنَابٍ،‏‏‏‏ عَن", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 31, Hadith 105", "international_number": "3540", "narrator_chain": ""}
{"hadithnumber": "3541", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ،‏‏‏‏ عَنْ مُحَمَّد", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 31, Hadith 106", "international_number": "3541", "narrator_chain": ""}
{"hadithnumber": "3542", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ وَمُجَاهِدُ بْنُ مُوسَى،‏‏‏‏ ومحمد بن خلف العسقلاني،‏‏‏‏ قَالُوا:‏‏‏‏ ح", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 31, Hadith 107", "international_number": "3542", "narrator_chain": ""}
{"hadithnumber": "3543", "arabic": "حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ،‏‏‏‏ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نَافِعٍ،‏‏‏‏ عَن", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 31, Hadith 108", "international_number": "3543", "narrator_chain": ""}
{"hadithnumber": "3544", "arabic": "حَدَّثَنَا عَمْرُو بْنُ رَافِعٍ،‏‏‏‏ حَدَّثَنَا هُشَيْمٌ،‏‏‏‏ عَنْ يَعْلَى بْنِ عَطَاءٍ،‏‏‏‏ عَنْ رَ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 31, Hadith 109", "international_number": "3544", "narrator_chain": ""}
{"hadithnumber": "3545", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ،‏‏‏‏ عَنْ ه", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 31, Hadith 110", "international_number": "3545", "narrator_chain": ""}
{"hadithnumber": "3546", "arabic": "حَدَّثَنَا يَحْيَى بْنُ عُثْمَانَ بْنِ سَعِيدِ بْنِ كَثِيرِ بْنِ دِينَارٍ الْحِمْصِيُّ،‏‏‏‏ حَدَّثَن", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 31, Hadith 111", "international_number": "3546", "narrator_chain": ""}
{"hadithnumber": "3547", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَفَّانُ،‏‏‏‏ حَدَّثَنَا وَهْيبٌ،‏‏‏‏ قَ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 31, Hadith 112", "international_number": "3547", "narrator_chain": ""}
{"hadithnumber": "3548", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ،‏‏‏‏ حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ الْأَنْصَارِيُّ،‏‏‏", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 31, Hadith 113", "international_number": "3548", "narrator_chain": ""}
{"hadithnumber": "3549", "arabic": "حَدَّثَنَا هَارُونُ بْنُ حَيَّانَ،‏‏‏‏ حَدَّثَنَا إِبْرَاهِيمُ بْنُ مُوسَى،‏‏‏‏ أَنْبَأَنَا عَبْدَةُ", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 31, Hadith 114", "international_number": "3549", "narrator_chain": ""}
