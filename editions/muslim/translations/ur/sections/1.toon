{"hadithnumber": "98", "text": "( ابن علیہ کے بجائے  )  محمد بن بشر نےکہا  :  ہمیں ابو حیان نے  سابقہ سند سے وہی حدیث بیان کی  ،  ال"}
{"hadithnumber": "99", "text": "حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا  :  ’’مجھ سے  ( دین کے بار"}
{"hadithnumber": "100", "text": "مالک بن انس نے ابو سہیل سے  ،  اور انہوں نے اپنے والد سے روایت کی  ،  انہوں نے حضرت طلحہ بن عبیداللہ"}
{"hadithnumber": "101", "text": "اسماعیل بن جعفر نے ابو سہیل سے  ،  انہوں نے اپنے والد سے  ،  انہوں نےحضرت طلحہ بن عبید اللہ  ‌رضی ‌ا"}
{"hadithnumber": "102", "text": "ہاشم بن قاسم ابونضر نے کہا :  ہمیں سلیمان بن مغیرہ نے ثابت کے حوالے سے یہ حدیث سنائی  ،  انہوں نے حض"}
{"hadithnumber": "103", "text": "بہزنے کہا  :  ہمیں سلیمان بن مغیرہ نے ثابت سے حدیث سنائی اور انہوں نے حضرت انس  ‌رضی ‌اللہ ‌عنہ ‌ ‌"}
{"hadithnumber": "104", "text": "عمر و بن عثمان نے کہا  :  ہمیں موسیٰ بن طلحہ نےحدیث سنائی  ،  انہوں نےکہا  :  مجھےحضرت ابوایوب  ‌رضی"}
{"hadithnumber": "105", "text": "محمد بن عثمان بن عبد اللہ بن موہب اور ان کے والد عثمان دونوں موسیٰ بن طلحہ سے سنا وہ  حضرت ابو ایوب"}
{"hadithnumber": "106", "text": "یحییٰ بن یحییٰ تمیمی او رابوبکر بن ابی شیبہ نے کہا  :  ہمیں ابو احوص نے حدیث بیان کی  ،  انہوں نے اب"}
{"hadithnumber": "107", "text": "حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ ایک اعرابی رسول اللہ ﷺ کے پاس آیا اور کہا  :  اے"}
{"hadithnumber": "108", "text": "ابومعاویہ نے اعمش سے حدیث سنائی  ،  انہوں نے ابو سفیان سے اور انہوں نے حضرت جابر ‌رضی ‌اللہ ‌عنہ ‌ ‌"}
{"hadithnumber": "109", "text": "شیبان نے اعمش سے  ،  انہوں نے ابو صالح اور ابو سفیان سے اور انہوں نے حضرت جابر ‌رضی ‌اللہ ‌عنہ ‌ ‌"}
{"hadithnumber": "110", "text": "سلمہ بن  شبیب  ‘ حسن بن اعین ‘ معقل یعنی عبد اللہ ‘ ابوالزبیر ‘ جابر سے روایت ہے کہ ایک شخص نے رسول"}
{"hadithnumber": "111", "text": "ابو خالد سلیمان بن حیان احمر نے ابومالک اشجعی سے  ،  انہوں نے سعد بن عبیدہ سے  ،  انہوں نے حضرت ابن"}
{"hadithnumber": "112", "text": "یحییٰ بن زکریا نے ہمیں حدیث بیان کی  ،  کہا  :  مجھے سعد بن طارق  (  ابو مالک اشجعی )  نے حدیث بیان"}
{"hadithnumber": "113", "text": "عاصم بن محمد بن زید عبد اللہ بن عمر نے اپنے والد سے حدیث بیان کی  ،  کہا  :  حضرت عبد اللہ بن عمر  ‌"}
{"hadithnumber": "114", "text": "عکرمہ بن خالد  ،  طاؤس کو حدیث سنا رہے تھے کہ ایک آدمی نے حضرت عبد اللہ بن عمر  ‌رضی ‌اللہ ‌عنہ ‌ ‌"}
{"hadithnumber": "115", "text": "خلف بن ہشام نے  بیان کیا  ( کہا )  ہمیں حماد بن زید نے ابو جمرہ سے حدیث بیان کی  ،  انہوں نے کہا  :"}
{"hadithnumber": "116", "text": "شعبہ نے ابو جمرہ سے حدیث بیان  کی  ،  انہوں نے کہا  :  میں حضرت عبد اللہ بن عباس  ‌رضی ‌اللہ ‌عنہ ‌"}
{"hadithnumber": "117", "text": "قرہ بن خالد نے ابوجمرہ سے حدیث بیان کی  ،  انہوں نے حضرت ابن عباس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے اور انہوں"}
{"hadithnumber": "118", "text": "( اسماعیل )  ابن علیہ نے کہا  :  ہمیں سعید بن ابی عروبہ نے قتادہ سے حدیث سنائی ،  انہوں نےکہا  :  مج"}
{"hadithnumber": "119", "text": "ابن ابی عدی نے سعید کےحوالے سے قتادہ سے روایت کی ،  انہوں نے کہا کہ مجھے عبد القیس کے وفد سے ملاقات"}
{"hadithnumber": "120", "text": "محمد بن بکار  بصری ‘ عاصم بن جریج ‘ محمد بن رافع ‘ عبد الرزاق  ‘ ابن جریج ‘ ابو قرعہ ‘ ابو نضرہ ‘ اب"}
{"hadithnumber": "121", "text": "بن ابی شیبہ  ،  ابو کریب اور اسحاق بن ابراہیم سب نے  وکیع سے حدیث سنائی  ۔  ابو بکر نے کہا  :  وکیع"}
{"hadithnumber": "122", "text": "بشر بن سری اور ابو عاصم نے زکریا بن اسحاق سے خبر دی کہ یحییٰ بن عبداللہ بن صیفی نے ابو معبد سے اور ا"}
{"hadithnumber": "123", "text": "اسماعیل بن امیہ نے یحییٰ بن عبداللہ بن صیفی سے  ،  انہوں نے ابو معبد سے ا ور انہوں نے حضرت ابن عباس"}
{"hadithnumber": "124", "text": "جناب عبید اللہ بن عبد اللہ بن عتبہ بن مسعود نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ ج"}
