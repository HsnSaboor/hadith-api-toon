{"hadithnumber": "3059", "text": "سعید بن جبیر نے حضرت ابن عباس رضی اللہ تعالیٰ عنہ   سے روایت کی ، کہا : اللہ کےرسول صلی اللہ علیہ وس"}
{"hadithnumber": "3060", "text": "عطاء نے حضرت ابن عباس رضی اللہ تعالیٰ عنہ   سے روایت کی  ، کہا : رسول اللہ  صلی اللہ علیہ وسلم  نے ص"}
{"hadithnumber": "3061", "text": "لیث نے ابن شہاب سے ، انھوں نے سالم بن عبداللہ سے ، انھوں نے عبداللہ بن عمر رضی اللہ تعالیٰ عنہ   سے"}
{"hadithnumber": "3062", "text": "یونس نے ابن شہاب سے ، انھوں نےسالم سے ، انھوں نےاپنے والد سے روایت کی ، فرمایا : رسول اللہ  صلی اللہ"}
{"hadithnumber": "3063", "text": "خالد بن حارث نے عبیداللہ سے  ، انھوں نے نافع سے ، انھوں نے عبداللہ  ( بن عمر رضی اللہ تعالیٰ عنہ   )"}
{"hadithnumber": "3064", "text": "ہمیں یحییٰ نے عبیداللہ سے روایت بیا ن کی ،  ( کہا :  )  مجھے نافع نے ابن عمر  رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "3065", "text": "عبیداللہ نے نافع سےروایت کی کہا :  میں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ   کو دیکھا کہ وہ حجر اسود"}
{"hadithnumber": "3066", "text": "ابوطفیل بکری  رضی اللہ تعالیٰ عنہ  نے حدیث بیان کی کہ انھوں نے حضرت ابن عباس  رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "3067", "text": "مجھے حرملہ بن یحییٰ نے حدیث سنائی  ،  ( کہا :  )  ہمیں ابن وہب نے خبر دی ،  ( کہا :  )  مجھے یونس او"}
{"hadithnumber": "3068", "text": "نافع نے حضرت ابن عمر  رضی اللہ تعالیٰ عنہ   سے روایت کی کہ حضرت عمر  رضی اللہ تعالیٰ عنہ   نے حجر اس"}
{"hadithnumber": "3069", "text": "ہمیں خلف بن ہشام ، مقدمی  ، ابوکامل ، اورقتیبہ بن سعید سب نے حماد سے حدیث بیان کی ، خلف نے کہا : ہمی"}
{"hadithnumber": "3070", "text": "عابس بن ربیعہ سے روایت ہے  ، کہا :  میں نے حضرت عمر  رضی اللہ تعالیٰ عنہ   کو حجر اسود کو بوسہ دیتے"}
{"hadithnumber": "3071", "text": "سوید بن غفلہ سے روایت ہے  ، کہا : میں نے حضرت عمر  رضی اللہ تعالیٰ عنہ   کودیکھا کہ انھوں نے حجر اسو"}
{"hadithnumber": "3072", "text": "عبدالرحمان نے سفیان سے اسی سند کے ساتھ روایت کی  ، اور کہا : لیکن میں نے ابو القاسم کو دیکھا وہ تم س"}
{"hadithnumber": "3073", "text": "حضرت ابن عباس  رضی اللہ تعالیٰ عنہ   سے روایت ہے کہ اللہ کےرسول  صلی اللہ علیہ وسلم  نے حجۃ الوداع م"}
{"hadithnumber": "3074", "text": "علی بن مسہر نے ہمیں حدیث سنائی  ، انھوں نے ابن جریج سے  ، انھوں نے جابر  رضی اللہ تعالیٰ عنہ   سے رو"}
{"hadithnumber": "3075", "text": "علی بن خشرم نے ہمیں حدیث بیان کی ،  ( کہا :  ) ہمیں عیسیٰ بن یونس نے ابن جریج سے خبر دی  ، نیز ہمیں"}
{"hadithnumber": "3076", "text": "حضرت عائشہ  رضی اللہ تعالیٰ عنہا    سے روایت ہے  ، کہا : نبی کریم  صلی اللہ علیہ وسلم  نے حجۃ الوداع"}
{"hadithnumber": "3077", "text": "ابو طفیل  رضی اللہ تعالیٰ عنہ   فرماتے ہیں : میں نے رسول اللہ صلی اللہ علیہ وسلم  کو دیکھا ، آپ بیت"}
{"hadithnumber": "3078", "text": "حضرت ام سلمہ  رضی اللہ تعالیٰ عنہا    سے روایت ہے ، کہا : میں نے رسول اللہ  صلی اللہ علیہ وسلم  سے ش"}
{"hadithnumber": "3079", "text": "ہمیں ابو معاویہ نے ہشام بن عروہ سے خبر دی ، انھوں نے اپنے والد ( عروہ بن زبیر )  سے ، انھوں نے حضرت"}
{"hadithnumber": "3080", "text": "ابو  اسامہ نے ہمیں حدیث بیان کی ،  ( کہا :  )  ہمیں ہشام بن عروہ نے حدیث بیان کی کہ مجھے میرے والد"}
{"hadithnumber": "3081", "text": "سفیان نے ہمیں  حدیث  سنائی  ، کہا :  میں نے زہری سے سنا ، وہ عروہ بن زبیر  رضی اللہ تعالیٰ عنہ   سے"}
{"hadithnumber": "3082", "text": "عقیل نے ابن شہاب سے روایت کی انھوں نے کہا  :  مجھے عروہ بن زبیر  رضی اللہ تعالیٰ عنہ   نے خبر دی کہا"}
{"hadithnumber": "3083", "text": "یو نس نے ابن شہاب سے انھوں نے عروہ بن زبیر رضی اللہ تعالیٰ عنہ   سے روایت کی کہ حضرت عائشہ رضی اللہ"}
{"hadithnumber": "3084", "text": "حضرت انس رضی اللہ تعالیٰ عنہ   سے روایت ہے کہا  :  انصار صفا مروہ کے در میان طواف کرنا نا پسند کرتے"}
{"hadithnumber": "3085", "text": "ہمیں یحییٰ بن سعید نے ابن جریج سے حدیث  بیان کی :   ( کہا  :  )  مجھے ابو زبیر نے خبر دی کہ انھوں نے"}
{"hadithnumber": "3086", "text": "ہمیں محمد بن بکر نے خبر دی  ( کہا :   )  ہمیں ابن جریج نے اسی سند کے ساتھ اس کے مانند حدیث بیان کی"}
{"hadithnumber": "3088", "text": "عطاء نے خبر دی  ( کہا :   )  مجھے ابن عباس رضی اللہ تعالیٰ عنہ   نے خبر دی کہ نبی  صلی اللہ علیہ وسل"}
{"hadithnumber": "3089", "text": "ابن عباس رضی اللہ تعالیٰ عنہ   کے آزاد کردہ غلا م ابو معبد نے  ( عبد اللہ  )  ابن عباس رضی اللہ تعال"}
{"hadithnumber": "3090", "text": "ابن جریج سے روایت ہے  :   ( کہا  :  )  مجھے ابو زبیر نے اسی سند کے ساتھ حدیث بیان کی  ، انھوں نے  ("}
{"hadithnumber": "3091", "text": "ابو حوص نے حصین سے حدیث بیان کی ،  انھوں نے کثیر بن مدرک سے انھوں نے عبد الرحمٰن بن یزید سے روایت کی"}
{"hadithnumber": "3094", "text": "زیادبگا ئی نے حصین سے حدیث بیان کی  ، انھوں نے کثیر بن مدرک اشجعی سے انھوں نے عبد الرحمٰن بن یزید او"}
