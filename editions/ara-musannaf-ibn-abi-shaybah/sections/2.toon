metadata:
  section_id: 2
  section_name: كتاب الطهارة
  hadith_first: 1
  hadith_last: 263

hadiths[263]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
1,"حَدَّثَنِی بَقِیُّ بْنُ مَخْلَدٍ ، رَحِمَہُ اللہ تعالی ، قَالَ: حدَّثَنَا أَبُو بَکْرٍ، عَبْدُاللہِ بْنُ مُحَمَّدِ بْنِ أَبِی شَیْبَۃَ ، قَالَ:\n\n(۱) حَدَّثَنَا ہُشَیْمُ بْنُ بَشِیرٍ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ صُہَیْبٍ ، عَنْ أَنَسِ بْنِ مَالِکٍ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ إذَا دَخَلَ الْخَلاَئَ ، قَالَ : أَعُوذُ بِاللَّہِ مِنَ الْخُبُثِ وَالْخَبَائِثِ۔ (بخاری ۱۴۲، ۶۳۲۲۔ ابوداؤد ۴۔۵)",,,1,,كتاب الطهارة
2,"(۲) حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ قَاسِمٍ الشَّیْبَانِیِّ ، عَنْ زَیْدِ بْنِ أَرْقَمَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ : إنَّ ہَذِہِ الْحُشُوشَ مُحْتَضَرَۃٌ ، فَإِذَا دَخَلَ أَحَدُکُمُ الْخَلاَئَ فَلْیَقُلِ: اللَّہُمَّ إنِّی أَعُوذُ بِکَ مِنَ الْخُبْثِ وَالْخَبَائِثِ۔ (نسائی۹۹۰۵۔ ابن ماجہ ۲۹۶)",,,2,,كتاب الطهارة
3,"(۳) حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ الْعَبْدِیُّ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ عُمَرَ ، قَالَ : حدَّثَنِی الْحَسَنُ بْنُ مُسْلِمِ بْنِ یَنَّاق ، عَنْ رَجُلٍ مِنْ أَصْحَابِ عَبْدِ اللہِ بْنِ مَسْعُودٍ ، قَالَ: قَالَ عَبْدُ اللہِ : إذَا دَخَلْتَ الْغَائِطَ ، فَأَرَدْتَ التَّکَشُّفَ ، فَقُلِ : اللَّہُمَّ إنِّی أَعُوذُ بِکَ مِنَ الرِّجْسِ النَّجِسِ ، وَالْخُبْثِ وَالْخَبَائِثِ ، وَالشَّیْطَانِ الرَّجِیمِ۔",,,3,,كتاب الطهارة
4,"(۴) حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ ، قَالَ : کَانَ حُذَیْفَۃُ إذَا دَخَلَ الْخَلاَئَ ، قَالَ : أَعُوذُ بِاللَّہِ مِنَ الرِّجْسِ النَّجِسِ ، الْخَبِیثِ الْمُخْبَثِ ، الشَّیْطَانِ الرَّجِیمِ۔",,,4,,كتاب الطهارة
5,"(۵) حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی مَعْشَرٍ ، وَہُوَ نَجِیحٌ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی طَلْحَۃَ ، عَنْ أَنَسٍ ، أَنَّ النَّبِیَّ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ کَانَ إذَا دَخَلَ الْکَنِیفَ ، قَالَ : بِسْمِ اللہِ ، اللَّہُمَّ إنِّی أَعُوذُ بِکَ مِنَ الْخُبْثِ وَالْخَبَائِثِ۔ (طبرانی ۳۵۷)",,,5,,كتاب الطهارة
6,"(۶) حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنِ الزِّبْرِقَانِ الْعَبْدِیِّ ، عَنِ الضَّحَّاکِ بْنِ مُزَاحِمٍ ، قَالَ : إذَا دَخَلْتَ الْخَلاَئَ فَقُلِ : اللَّہُمَّ إنِّی أَعُوذُ بِکَ مِنَ الرِّجْسِ النَّجِسِ ، الْخَبِیثِ الْمُخْبِثِ ، الشَّیْطَانِ الرَّجِیمِ۔",,,6,,كتاب الطهارة
7,"(۷) حَدَّثَنَا یَحْیَی بْنُ أَبِی بُکَیْرٍ ، قَالَ : أَخْبَرَنَا إسْرَائِیلُ ، قَالَ : حَدَّثَنَا یُوسُفُ بْنُ أَبِی بُرْدَۃَ ، قَالَ : سَمِعْتُ أبِی یَقُولُ : دَخَلْتُ عَلَی عَائِشَۃَ رَضِیَ اللَّہُ عَنْہا ، فَسَمِعْتُہَا تَقُولُ : کَانَ رَسُولُ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ إذَا خَرَجَ مِنَ الْغَائِطِ قَالَ : غُفْرَانَک۔ (ابن ماجہ ۳۰۰۔ نسائی ۹۹۰۷)",,,7,,كتاب الطهارة
8,"(۸) حَدَّثَنَا ہُشَیْمٌ ، عَنِ الْعَوَّامِ ، عَنْ إبْرَاہِیمَ التَّیْمِیِّ ؛ أَنَّ نُوحًا النَّبِیَّ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ کَانَ إذَا خَرَجَ مِنَ الْغَائِطِ قَالَ : الْحَمْدُ لِلَّہِ الَّذِی أَذْہَبَ عَنِّی الأَذَی ، وَعَافَانِی۔",,,8,,كتاب الطهارة
9,"(۹) حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا الْعَوَّامُ ، قَالَ : حُدِّثْتُ ، أَنَّ نُوحًا کَانَ یَقُولُ : الْحَمْدُ لِلَّہِ الَّذِی أَذَاقَنِی لَذَّتَہُ ، وَأَبْقَی فِیَّ مَنْفَعَتَہُ ، وَأَذْہَبَ عَنِّی أَذَاہُ۔ (بیہقی ۴۴۶۹)",,,9,,كتاب الطهارة
10,"(۱۰) حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، وَوَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ أَبِی عَلِیٍّ ؛ أَنَّ أَبَا ذَرٍّ کَانَ یَقُولُ إذَا خَرَجَ مِنَ الْخَلاَئِ : الْحَمْدُ لِلَّہِ الَّذِی أَذْہَبَ عَنِّی الأَذَی ، وَعَافَانِی۔ (طبرانی ۳۷۲)",,,10,,كتاب الطهارة
11,"(۱۱) حَدَّثَنَا عَبْدَۃُ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ ، قَالَ : کَانَ حُذَیْفَۃُ یَقُولُ إذَا خَرَجَ ، یَعْنِی مِنَ الْخَلاَئِ : الْحَمْدُ لِلَّہِ الَّذِی أَذْہَبَ عَنِّی الأَذَی وَعَافَانِی۔",,,11,,كتاب الطهارة
12,"(۱۲) حَدَّثَنَا وَکِیعٌ ، عَنْ زَمْعَۃَ ، عَنْ سَلَمَۃَ بْنِ وَہْرَام ، عَنْ طَاوُوسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ : إذَا خَرَجَ أَحَدُکُمْ مِنَ الْخَلاَئِ فَلْیَقُلِ : الْحَمْدُ لِلَّہِ الَّذِی أَذْہَبَ عَنِّی مَا یُؤْذِینِی ، وَأَمْسَکَ عَلَیَّ مَا یَنْفَعُنِی۔ (طبرانی ۳۷۱، دار قطنی۱/۵۷)",,,12,,كتاب الطهارة
13,"(۱۳) حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ ، قَالَ ، حَدَّثَنَا ہُرَیْمٌ ، عَنْ لَیْثٍ ، عَنِ الْمِنْہَالِ بْنِ عَمْرٍو ، قَالَ : کَانَ أَبُو الدَّرْدَائِ إذَا خَرَجَ مِنَ الْخَلاَئِ قَالَ : الْحَمْدُ لِلَّہِ الَّذِی أَمَاطَ عَنِّی الأَذَی ، وَعَافَنِی۔",,,13,,كتاب الطهارة
14,"(۱۴) حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، وَمُحَمَّدُ بْنُ عَبْدِ اللہِ بْنِ الزُّبَیْرِ ، عَنْ کَثِیرِ بْنِ زَیْدٍ ، قَالَ : حدَّثَنِی رُبَیْحُ بْنُ عَبْدِ الرَّحْمَنِ بْنِ أَبِی سَعِیدٍ الْخُدْرِیِّ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ أَبِی سَعِیدٍ الْخُدْرِیِّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ : لاَ وُضُوئَ لِمَنْ لَمْ یَذْکُرِ اسْمَ اللہِ عَلَیْہِ۔ (طبرانی۳۸۰۔ احمد ۳/۴۱)",,,14,,كتاب الطهارة
15,"(۱۵) حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا وُہَیْبٌ ، قَالَ : حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ حَرْمَلَۃَ ، أَنَّہُ سَمِعَ أَبَا ثِفَالٍ یُحَدِّثُ ، أَنَّہُ سَمِعَ رَبَاحَ بْنَ عَبْدِ الرَّحْمَنِ بْنِ أَبِی سُفْیَانَ بْنِ حُوَیْطِبٍ یَقُولُ : حَدَّثَتْنِی جَدَّتِی ، أَنَّہَا سَمِعَتْ أَبَاہَا یَقُولُ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : لاَ صَلاَۃَ لِمَنْ لاَ وُضُوئَ لَہُ ، وَلاَ وُضُوئَ لِمَنْ لَمْ یَذْکُرِ اسْمَ اللہِ عَلَیْہِ۔ (ترمذی۲۵،۲۶۔ ابن ماجہ ۳۹۸)",,,15,,كتاب الطهارة
16,"(۱۶) حَدَّثَنَا عَبْدَۃُ ، عَنْ حَارِثَۃَ ، عَنْ عَمْرَۃَ ، قَالَتْ : سَأَلْتُ عَائِشَۃَ : کَیْفَ کَانَتْ صَلاَۃُ رَسُولِ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ ؟ قَالَتْ : کَانَ إذَا تَوَضَّأَ فَوَضَعَ یَدَہُ فِی الْمَائِ ، سَمَّی فَتَوَضَّأَ ، وَیُسْبِغُ الْوُضُوئَ۔\r\r\n(طبرانی ۳۸۳۔ ابن ماجہ ۱۰۶۲)",,,16,,كتاب الطهارة
17,"(۱۷) حَدَّثَنَا خَلَفُ بْنُ خَلِیفَۃَ ، عَنْ لَیْثٍ ، عَنْ حُسَیْنِ بْنِ عُمَارَۃَ ، عَنْ أَبِی بَکْرٍ ، قَالَ : إذَا تَوَضَّأَ الْعَبْدُ ، فَذَکَرَ اسْمَ اللہِ حِینَ یَأْخُذُ فِی وَضُوئِہِ ، طَہُرَ جَسَدُہُ کُلُّہُ ، وَإِذَا تَوَضَّأَ وَلَمْ یَذْکُرِ اسْمَ اللہِ ، لَمْ یَطْہُرْ مِنْہُ ، إِلاَّ مَا أَصَابَہُ الْمَائُ۔",,,17,,كتاب الطهارة
18,"(۱۸) حَدَّثَنَا وَکِیعٌ ، عَنْ رَبِیعٍ ، عَنِ الْحَسَنِ ، أَنَّہُ قَالَ : یُسَمِّی إذَا تَوَضَّأَ ، فَإِنْ لَمْ یَفْعَلْ أَجْزَأَہُ۔",,,18,,كتاب الطهارة
19,"(۱۹) حَدَّثَنَا وَکِیعُ بْنُ الْجَرَّاحِ ، عَنْ سُفْیَانَ ، عَنْ أَبِی ہَاشِمٍ الْوَاسِطِیِّ ، عَنْ أَبِی مِجْلَزٍ ، عَنْ قَیْسِ بْنِ عُبَادٍ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ، قَالَ : مَنْ قَالَ إذَا فَرَغَ مِنْ وُضُوئِہِ : سُبْحَانَک اللَّہُمَّ وَبِحَمْدِکَ ، أَشْہَدُ أَنْ لاَ إلَہَ إِلاَّ أَنْتَ ، أَسْتَغْفِرُک وَأَتُوبُ إلَیْک ، خُتِمَتْ بِخَاتَمٍ ، ثُمَّ رُفِعَتْ تَحْتَ الْعَرْشِ ، فَلَمْ تُکْسَرْ إلَی یَوْمِ الْقِیَامَۃِ۔\r\r\n(نسائی ۹۹۱۰۔ طبرانی ۳۹۱)",,,19,,كتاب الطهارة
20,"(۲۰) حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، وَعَبْدُ اللہِ بْنُ دَاوُد ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ بْنِ الْمُہَاجِرِ ، عَنْ سَالِمِ بْنِ أَبِی الْجَعْدِ ، قَالَ : کَانَ عَلِیٌّ إذَا فَرَغَ مِنْ وُضُوئِہِ ، قَالَ : أَشْہَدُ أَنْ لاَ إلَہَ إِلاَّ اللَّہُ ، وَأَشْہَدُ أَنَّ مُحَمَّدًا عَبْدُہُ وَرَسُولُہُ ، رَبِّ اجْعَلْنِی مِنَ التَّوَّابِینَ ، وَاجْعَلْنِی مِنَ الْمُتَطَہِّرِینَ۔",,,20,,كتاب الطهارة
21,"(۲۱) حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، قَالَ : حدَّثَنَا مُعَاوِیَۃُ بْنُ صَالِحٍ ، عَنْ رَبِیعَۃَ بْنِ یَزِیدَ ، عَنْ أَبِی إدْرِیسَ الْخَوْلاَنِیِّ ، وَأَبِی عُثْمَانَ ، عَنْ جُبَیْرِ بْنِ نُفَیْرِ بْنِ مَالِکٍ الْحَضْرَمِیِّ ، عَنْ عُقْبَۃَ بْنِ عَامِرٍ الْجُہَنِیِّ ، أَنَّ رَسُولَ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ قَالَ : مَا مِنْ أَحَدٍ یَتَوَضَّأُ فَیُحْسِنُ الْوُضُوئَ ، ثُمَّ یُصَلِّی رَکْعَتَیْنِ ، مُقْبِلٌ بِقَلْبِہِ وَوَجْہِہِ عَلَیْہِمَا إِلاَّ وَجَبَتْ لَہُ الْجَنَّۃُ ۔ قَالَ :  فَقَالَ عُمَرُ : مَا قَبْلَہَا أَکْثَرُ مِنْہَا ، کَأَنَّک جِئْتَ آنِفًا ؟ قَالَ رَسُولُ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ : مَنْ تَوَضَّأَ فَقَالَ : أَشْہَدُ أَنْ لاَ إلَہَ إِلاَّ اللَّہُ ، وَحْدَہُ لاَ شَرِیکَ لَہُ ، وَأَشْہَدُ أَنَّ مُحَمَّدًا عَبْدُہُ وَرَسُولُہُ ، فُتِحَتْ لَہُ ثَمَانیَۃُ أَبْوَابِ الْجَنَّۃِ ، یَدْخُلُ مِنْ أَیِّہَا شَائَ۔ (مسلم ۲۱۰۔ ترمذی ۵۵)",,,21,,كتاب الطهارة
22,"(۲۲) حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، قَالَ : حدَّثَنِی عَمْرُو بْنُ عَبْدِ اللہِ بْنِ وَہْبٍ النَّخَعِیُّ ، عَنْ زَیْدٍ الْعَمِّیِّ ، عَنْ أَنَسِ بْنِ مَالِکٍ ، عَنِ النَّبِیِّ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ قَاَلَ : مَنْ تَوَضَّأَ فَقَالَ : أَشْہَدُ أَنْ لاَ إلَہَ إِلاَّ اللَّہُ ، وَحْدَہُ لاَ شَرِیکَ لَہُ ، وَأَشْہَدُ أَنَّ مُحَمَّدًا عَبْدُہُ وَرَسُولُہُ ، ثَلاَثَ مَرَّاتٍ ، فُتِحَتْ لَہُ ثَمَانیَۃُ أَبْوَابٍ الْجَنَّۃِ ، یَدْخُلُ مِنَ أَیِّہَا شَائَ۔\r\r\n(ابن ماجہ ۴۶۹۔ احمد ۳/۲۶۵)",,,22,,كتاب الطهارة
23,"(۲۳) حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ عَوْفٍ ، عَنْ أَبِی الْمِنْہَالِ ، أَنَّ أَبَا الْعَالِیَۃِ رَأَی رَجُلاً یَتَوَضَّأُ ، فَلَمَّا فَرَغَ قَالَ : اللَّہُمَّ اجْعَلْنِی مِنَ التَّوَّابِینَ ، وَاجْعَلْنِی مِنَ الْمُتَطَہِّرِینَ ، فَقَالَ : إنَّ الطُّہُورَ بِالْمَائِ حَسَنٌ ، وَلَکِنَّہُمُ الْمُتَطَہِّرُونَ مِنَ الذُّنُوبِ۔",,,23,,كتاب الطهارة
24,"(۲۴) حَدَّثَنَا الْمُقْرِیئُ ، عَنْ سَعِیدِ بْنِ أَبِی أَیُّوبَ ، قَالَ : حدَّثَنِی زُہْرَۃُ بْنُ مَعْبَدٍ أَبُو عَقِیلٍ ، أَنَّ ابْنَ عَمٍّ لَہُ أَخْبَرَہُ ، أَنََّہُ سَمِعَ عُقْبَۃَ بْنَ عَامِرٍ یَقُولُ : قَالَ رَسُولُ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ : مَنْ تَوَضَّأَ فَأَتَمَّ وُضُوئَہُ ، ثُمَّ رَفَعَ رَأْسَہُ إلَی السَّمَائِ ، فَقَالَ : أَشْہَدُ أَنْ لاَ إلَہَ إِلاَّ اللَّہُ ، وَحْدَہُ لاَ شَرِیکَ لَہُ ، وَأَنَّ مُحَمَّدًا عَبْدُہُ وَرَسُولُہُ ، فُتِحَتْ لَہُ ثَمَانیَۃُ أَبْوَابٍ الْجَنَّۃِ ، یَدْخُلُ مِنْ أَیِّہَا شَائَ۔ (احمد ۴/۱۵۰۔ طبرانی ۱۷/۹۱۶)",,,24,,كتاب الطهارة
25,"(۲۵) حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ ، قَالَ : کَانَ حُذَیْفَۃُ إذَا تَطَہَّرَ قَالَ : أَشْہَدُ أَنْ لاَ إلَہَ إِلاَّ اللَّہُ ، وَأَشْہَدُ أَنَّ مُحَمَّدًا عَبْدُہُ وَرَسُولُہُ ، اللَّہُمَّ اجْعَلْنِی مِنَ التَّوَّابِینَ ، وَاجْعَلْنِی مِنَ الْمُتَطَہِّرِینَ۔",,,25,,كتاب الطهارة
26,"(۲۶) حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ (ح) وَحَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، کِلاَہُمَا عَنْ سِمَاکِ بْنِ حَرْبٍ ، عنْ مُصْعَبِ بْنِ سَعْدٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ : لاَ تُقْبَلُ صَلاَۃٌ إِلاَّ بِطُہُورٍ ، وَلاَ صَدَقَۃٌ مِنْ غُلُولٍ۔\r\r\n(مسلم۱/۲۰۴۔ ابن ماجہ ۲۷۲)",,,26,,كتاب الطهارة
27,"(۲۷) حَدَّثَنَا یُونُسُ بْنُ مُحَمَّدٍ ، عَنْ لَیْثِ بْنِ سَعْدٍ ، عَنْ یَزِیدَ بْنِ أَبِی حَبِیبٍ ، عَنِ ابْنِ سِنَانٍ ، عَنْ أَنَسٍ ، عَنِ النَّبِیِّ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لاَ تُقْبَلُ صَدَقَۃٌ مِنْ غُلُولٍ ، وَلاَ صَلاَۃٌ بِغَیْرِ طُہُورٍ۔ (ابن ماجہ ۲۷۳)",,,27,,كتاب الطهارة
28,"(۲۸) حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا وُہَیْبٌ ، قَالَ: حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ حَرْمَلَۃَ ، أَنَّہُ سَمِعَ أَبَا ثِفَالٍ یُحَدِّثُ ، قَالَ: سَمِعْتُ رَبَاحَ بْنَ عَبْدِ الرَّحْمَنِ بْنِ أَبِی سُفْیَانَ بْنِ حُوَیْطِبٍ یَقُولُ : حَدَّثَتْنِی جَدَّتِی ، أَنَّہَا سَمِعَتْ أَبَاہَا یَقُولُ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : لاَ صَلاَۃَ لِمَنْ لاَ وُضُوئَ لَہُ۔ \r\r\n(ترمذی۲۵،۲۶۔ ابن ماجہ ۳۹۸)",,,28,,كتاب الطهارة
29,"(۲۹) حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ ، وَعُبَیْدُ بْنُ سَعِیدٍ ، عَنْ شُعْبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ أَبِی الْمُلَیْحِ ، عَنْ أَبِیہِ ، عَنِ النَّبِیِّ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إنَّ اللَّہَ لاَ یَقْبَلُ صَلاَۃً بِغَیْرِ طُہُورٍ ، وَلاَ صَدَقَۃً مِنْ غُلُولٍ۔\r\r\n(ابوداؤد ۶۰۔ ابن ماجہ ۲۷۱)",,,29,,كتاب الطهارة
30,"(۳۰) حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ آدَمَ بْنِ عَلِیٍّ ، قَالَ : سَمِعْتُ ابْنَ عُمَرَ یَقُولُ : إنَّ أُنَاسًا یُدْعَوْنَ الْمَنْقُوصُونَ یَوْمَ الْقِیَامَۃِ ، فَقَالَ رَجُلٌ : مَنْ ہُمْ أَبَا عَبْدِ الرَّحْمَنِ ؟ قَالَ : کَانَ أَحَدُہُمْ یُنْقِصُ طُہُورَہُ ، وَالْتِفَاتَہُ فِی صَلاَتِہِ۔",,,30,,كتاب الطهارة
31,"(۳۱) حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی عُبَیْدَۃَ ، قَالَ : قَالَ عَبْدُ اللہِ : لاَ تُقْبَلُ صَلاَۃٌ إِلاَّ بِطُہُورٍ۔",,,31,,كتاب الطهارة
32,"(۳۲) حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مُجَمِّعُ بْنُ یَحْیَی ، عَنْ خَالِدِ بْنِ زَیْدٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : لاَ تُقْبَلُ صَلاَۃٌ بِغَیْرِ طُہُورٍ۔",,,32,,كتاب الطهارة
33,"(۳۳) حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ أَبِی حَصِینٍ ، عَنِ الْمُسْتَوْرِدِ بْنِ الأَحْنَفِ ، قَالَ : قَالَ عُمَرُ : لاَ تُقْبَلُ صَلاَۃٌ بِغَیْرِ طُہُورٍ۔",,,33,,كتاب الطهارة
34,"(۳۴) حَدَّثَنَا عَبِیدَۃُ بْنُ حُمَیْدٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ عُمَیْرٍ ، عَنْ أَبِی رَوْحٍ ، قَالَ : صَلَّی رَسُولُ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ بِأَصْحَابِہِ ، فَقَرَأَ بِسُورَۃِ الرُّومِ ، فَتَرَدَّدَ فِیہَا ، فَلَمَّا انْصَرَفَ قَالَ : إنَّمَا یُلَبِّسُ عَلَیْنَا صَلاَتَنَا قَوْمٌ یَحْضُرُونَ الصَّلاَۃَ بِغَیْرِ طُہُورٍ ، مَنْ شَہِدَ الصَّلاَۃَ فَلْیُحْسِنِ الطُّہُورَ۔ (احمد ۳/۴۷۱۔ نسائی ۱۰۱۹)",,,34,,كتاب الطهارة
35,"(۳۵) حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ مَنْصُورٍ ، عَنْ سَالِمِ بْنِ أَبِی الْجَعْدِ ، عَنْ ثَوْبَانَ مَوْلَی رَسُولِ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ : لاَ یُحَافِظُ عَلَی الطُّہُورِ إِلاَّ مُؤْمِنٌ۔\n\n(ابن ماجہ۲۷۷۔ احمد ۵/۲۷۶)",,,35,,كتاب الطهارة
36,"(۳۶) حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ : لَنْ یُحَافِظَ عَلَی الْوُضُوئِ إِلاَّ مُؤْمِنٌ۔ (ابن ماجہ ۲۷۸)",,,36,,كتاب الطهارة
37,"(۳۷) حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا أَبَانُ الْعَطَّارُ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ زَیْدِ بْنِ سَلاَّم ، عَنْ أَبِی سَلاَّمٍ ، عَنْ أبِی مَالِکٍ الأَشْعَرِیِّ ، أَنَّ رَسُولَ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ کَانَ یَقُولُ : الطُّہُورُ شَطْرُ الإِیمَانِ۔\r\r\n(احمد ۵/۳۴۲۔ بیہقی ۱/۴۲)",,,37,,كتاب الطهارة
38,"(۳۸) حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی لَیْلَی الْکِنْدِیِّ ، عَنْ حِجْرِ بْنِ عَدِیٍّ ، قَالَ : حدَّثَنَا عَلِیٌّ أَنَّ الطُّہُورَ شَطْرُ الإِیمَانِ۔",,,38,,كتاب الطهارة
39,"(۳۹) حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ شِمْرٍ ، عَنْ شَہْرِ بْنِ حَوْشَبٍ ، عَنْ أَبِی أُمَامَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ : إذَا تَوَضَّأَ الرَّجُلُ الْمُسْلِمُ خَرَجَتْ ذُنُوبُہُ مِنْ سَمْعِہِ وَبَصَرِہِ وَیَدَیْہِ وَرِجْلَیْہِ ، فَإِنْ جَلَسَ جَلَسَ مَغْفُورًا لَہُ۔ (احمد ۵/۲۵۲)",,,39,,كتاب الطهارة
40,"(۴۰) حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عَاصِمٍ ، عَنْ زِرٍّ ، عَنْ عَبْدِ اللہِ ، قَالَ : قُلْتُ یَا رَسُولَ اللہِ ، کَیْفَ تَعْرِفُ مَنْ لَمْ تَرَ مِنْ أُمَّتِکَ ؟ قَالَ : ہُمْ غُرٌّ مُحَجَّلُونَ ، بُلْقٌ مِنْ آثَارِ الْوُضُوئِ۔ (احمد ۱/۴۵۲)",,,40,,كتاب الطهارة
41,"(۴۱) حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، قَالَ : کَانَ أَبِی یَقُولُ : الْوُضُوئُ شَطْرُ الصَّلاَۃِ۔",,,41,,كتاب الطهارة
42,"(۴۲) حَدَّثَنَا یَحْیَی بْنُ زَکَرِیَّا بْنِ أَبِی زَائِدَۃَ ، عَنْ أَبِی مَالِکٍ الأَشْجَعِیِّ ، عَنْ أَبِی حَازِمٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ : تَرِدُونَ عَلَیَّ غُرًّا مُحَجَّلِینَ مِنَ الْوُضُوئِ ، سِیمَائُ أُمَّتِی لَیْسَتْ لأَحَدٍ غَیْرِہَا۔ (ابن ماجہ ۴۲۸۲۔ ابو یعلی ۶۱۸۱)",,,42,,كتاب الطهارة
43,"(۴۳) حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ یَعْلَی بْنِ عَطَائٍ ، عَنْ یَزِیدَ بْنِ طَلْقٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْبَیْلَمَانِیِّ ، عَنْ عَمْرِو بْنِ عَبسَۃَ ، عَنِ النَّبِیِّ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إنَّ الْعَبْدَ إذَا تَوَضَّأَ فَغَسَلَ یَدَیْہِ ، خَرَّتْ خَطَایَاہُ مِنْ یَدَیْہِ ، وَإِذَا غَسَلَ وَجْہَہُ خَرَّتْ خَطَایَاہُ مِنْ وَجْہِہِ ، وَإِذَا غَسَلَ ذِرَاعَیْہِ وَمَسَحَ بِرَأْسِہِ خَرَّتْ خَطَایَاہُ مِنْ ذِرَاعَیْہِ وَرَأْسِہِ ، وَإِذَا غَسَلَ رِجْلَیْہِ خَرَّتْ خَطَایَاہُ مِنْ رِجْلَیْہِ۔ (ابن ماجہ ۲۸۳)",,,43,,كتاب الطهارة
44,"(۴۴) حَدَّثنَاَ یَحْیَی بْنُ أَبِی بُکَیْر ، قَالَ : حدَّثَنَا زُہَیْرُ بْنُ مُحَمَّدٍ ، عَنْ عَبْدِ اللہِ بْنِ مُحَمَّدِ بْنِ عَقِیلٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ أَبِی سَعِیدٍ ، أَنَّہُ سَمِعَ رَسُولَ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : أَلاَ أَدُلُّکُمْ عَلَی شَیْئٍ یُکَفِّرُ اللَّہُ بِہِ الْخَطَایَا وَیَزِیدُ بِہِ فِی الْحَسَنَاتِ ؟ قَالُوا : بَلَی ، یَا رَسُولَ اللہِ ، قَالَ : إسْبَاغُ الْوُضُوئِ عِنْدَ الْمَکَارِہِ ، وَکَثْرَۃُ الْخُطَی إلَی ہَذِہِ الْمَسَاجِدِ۔ (ابن ماجہ ۴۲۷۔ ابو یعلی ۱۳۵۰)",,,44,,كتاب الطهارة
45,"(۴۵) حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، عَنْ أَبِی مَالِکٍ الأَشْجَعِیِّ ، عَنْ کَثِیرِ بْنِ مُدْرِکٍ ، عَنِ الأَسْوَدِ بْنِ یَزِیدَ ، قَالَ : قَالَ عَبْدُ اللہِ : الْکَفَّارَاتُ إسْبَاغُ الْوُضُوئِ بِالسَّبَرَاتِ ، وَنَقْلُ الأَقْدَامِ إلَی الْجُمُعَاتِ ، وَانْتِظَارُ الصَّلاَۃِ بَعْدَ الصَّلاَۃِ۔",,,45,,كتاب الطهارة
46,"(۴۶) حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ أَبِی صَخْرَۃَ ، قَالَ : سَمِعْتُ حُمْرَانَ یَقُولُ : کُنْتُ أَضَعُ لِعُثْمَانَ طَہُورَہُ ، فَقَالَ : حَدَّثَنَا رَسُولُ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ : مَا مِنْ رَجُلٍ یَتَوَضَّأُ فَیُحْسِنُ الْوُضُوئَ ، إِلاَّ غُفِرَ لَہُ مَا بَیْنَہُ وَبَیْنَ الصَّلاَۃِ الأُخْرَی۔ (مسلم ۱/۲۰۷)",,,46,,كتاب الطهارة
47,"(۴۷) حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ سَالِمٍ ، عَنْ یَزِیدَ بْنِ بِشْرٍ ، قَالَ : إنَّ اللَّہَ أَوْحَی إلَی مُوسَی أَنْ تَوَضَّہُ ، فَإِنْ لَمْ تَفْعَلْ فَأَصَابَتْک مُصِیبَۃٌ ، فَلاَ تَلُومَنَّ إِلاَّ نَفْسَک۔",,,47,,كتاب الطهارة
48,"(۴۸) حَدَّثَنَا إِسْحَاقُ بْنُ سُلَیْمَانَ الرَّازِیّ ، عَنْ أَبِی سِنَانٍ ، عَنْ ثَابِتٍ ، عَنِ الضَّحَّاکِ ؛ فِی قَوْلِہِ تَعَالَی : (وَقُومُوا لِلَّہِ قَانِتِینَ) ، قَالَ : مُطِیعِینَ لِلَّہِ فِی الْوُضُوئِ۔ (بقرہ آیت ۲۳۸)",,,48,,كتاب الطهارة
49,"(۴۹) حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ عُثْمَانَ بْنِ حَکِیمٍ ، عَنْ مُحَمَّدِ بْنِ الْمُنْکَدِرِ ، عَنْ حُمْرَانَ ، قَالَ : سَمِعْتُ عُثْمَانَ یَقُولُ : مَنْ تَوَضَّأَ فَأَحْسَنَ الْوُضُوئَ وَأَسْبَغَہُ وَأَتَمَّہُ ، خَرَجَتْ خَطَایَاہُ مِنْ جَسَدِہِ حَتَّی تَخْرُجَ مِنْ تَحْتِ أَظْفَارِہِ۔ (مسلم ۱/۲۱۶)",,,49,,كتاب الطهارة
50,"(۵۰) حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ شَقِیقٍ ، عَنْ سَلَمَۃَ بْنِ سَبْرَۃَ ، عَنْ سَلْمَانَ ، قَالَ : إذَا تَوَضَّأَ الرَّجُلُ الْمُسْلِمُ ، وُضِعَتْ خَطَایَاہُ عَلَی رَأْسِہِ فَتَحَاتَتْ ، کَمَا یَتَحَاتُّ عِذْقُ النَّخْلَۃِ۔ (ابن حبان ۴/۳۱۷)",,,50,,كتاب الطهارة
51,(۵۱) حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ شَقِیقٍ ، عَنْ سَلَمَۃَ بْنِ سَبْرَۃَ ، عَنْ سَلْمَانَ مِثْلَہُ۔,,,51,,كتاب الطهارة
52,"(۵۲) حَدَّثَنَا قَبِیصَۃُ بْنُ عُقْبَۃَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عَلِیِّ بْنِ زَیْدٍ ، عَنْ أَبِی عُثْمَانَ ، قَالَ : کُنْتُ مَعَ سَلْمَانَ فَأَخَذَ غُصْنًا مِنْ شَجَرَۃٍ یَابِسَۃٍ فَحَتَّہُ ، ثُمَّ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : مَنْ تَوَضَّأَ فَأَحْسَنَ الْوُضُوئَ ، تَحَاتَّتْ خَطَایَاہُ کَمَا یَتَحَاتُّ الْوَرَقُ۔ (احمد۴۳۷، جلد۵ ۔ طبرانی ۶۱۵۱)",,,52,,كتاب الطهارة
53,"(۵۳) حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنِ الإِفْرِیقِیِّ ، عَنْ أَبِی غُطَیْفٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : مَنْ تَوَضَّأَ عَلَی طُہْرٍ کُتِبَ لَہُ عَشْرُ حَسَنَاتٍ۔",,,53,,كتاب الطهارة
54,"(۵۴) حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی حَیَّۃَ ، قَالَ : رَأَیْتُ عَلِیًّا تَوَضَّأَ فَأَنْقَی کَفَّیْہِ ، ثُمَّ غَسَلَ وَجْہَہُ ثَلاَثًا وَذِرَاعَیْہِ ثَلاَثًا ، وَمَسَحَ بِرَأْسِہِ ، ثُمَّ غَسَلَ قَدَمَیْہِ إلَی الْکَعْبَیْنِ ، ثُمَّ قَامَ فَشَرِبَ فَضْلَ وَضُوئِہِ ، ثُمَّ قَالَ : إنَّمَا أَرَدْتُ أَنْ أُرِیَکُمْ طُہُورَ رَسُولِ اللّٰہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ ۔ (ابوداؤد ۱۱۷۔ ترمذی ۴۸)",,,54,,كتاب الطهارة
55,"(۵۵) حَدَّثَنَا شَرِیکٌ ، عَنْ خَالِدِ بْنِ عَلْقَمَۃَ ، عَنْ عَبْدِ خَیْرٍ ، عَنْ عَلِیٍّ ، قَالَ : تَوَضَّأَ فَمَضْمَضَ ثَلاَثًا وَاسْتَنْشَقَ ثَلاَثًا مِنْ کَفٍّ وَاحِدٍ وَغَسَلَ وَجْہَہُ ثَلاَثًا ، ثُمَّ أَدْخَلَ یَدَہُ فِی الرَّکْوَۃِ فَمَسَحَ رَأْسَہُ وَغَسَلَ رِجْلَیْہِ ، ثُمَّ قَالَ : ہَذَا وُضُوئُ نَبِیِّکُمْ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ ۔ (ابن خزیمۃ ۱۴۷۔ ابن حبان ۱۰۵۶)",,,55,,كتاب الطهارة
56,"(۵۶) حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا سَعِیدُ بْنُ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ مُسْلِمِ بْنِ یَسَارٍ ، عَنْ حُمْرَانَ ، قَالَ : دَعَا عُثْمَانُ بِمَائٍ فَتَوَضَّأَ ثُمَّ ضَحِکَ ، فَقَالَ : أَلاَ تَسْأَلُونِی مِمَّا أَضْحَکُ ؟ قَالُوا : یَا أَمِیرَ الْمُؤْمِنِینَ مَا أَضْحَکَک ؟ قَالَ : رَأَیْتُ رَسُولَ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ تَوَضَّأَ کَمَا تَوَضَّأْتُ فَمَضْمَضَ وَاسْتَنْشَقَ وَغَسَلَ وَجْہَہُ ثَلاَثًا وَیَدَیْہِ ثَلاَثًا ، وَمَسَحَ بِرَأْسِہِ وَظَہْرِ قَدَمَیْہِ۔ (احمد ۲۵۸، جلد۱)",,,56,,كتاب الطهارة
57,(۵۷) حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرِو بْنِ یَحْیَی ، عَنْ أَبِیہِ ، عَنْ عَبْدِ اللہِ بْنِ زَیْدٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ تَوَضَّأَ فَغَسَلَ وَجْہَہُ ثَلاَثًا وَیَدَیْہِ مَرَّتَیْنِ ، وَمَسَحَ بِرَأْسِہِ وَرِجْلَیْہِ مَرَّتَیْنِ۔ (بخاری ۱۸۵۔ مسلم ۲۱۱),,,57,,كتاب الطهارة
58,"(۵۸) حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ سُفْیَانَ ، عَنْ مُوسَی بْنِ أَبِی عَائِشَۃَ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ؛ أَنَّ رَجُلاً سَأَلَ النَّبِیَّ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ عَنِ الْوُضُوئِ ؟ فَدَعَا بِمَائٍ فَتَوَضَّأَ ثَلاَثًا ثَلاَثًا ، ثُمَّ قَالَ : ہَکَذَا الطُّہُورُ ، فَمَنْ زَادَ ، أَوْ نَقَصَ فَقَدْ تَعَدَّی ، أًوْظَلَمَ۔ (ابوداؤد ۱۳۶، جلد۲)",,,58,,كتاب الطهارة
59,"(۵۹) حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ مُحَمَّدِ بْنِ عَقِیلٍ ، عَنِ الرُّبَیِّعِ بِنْتِ مُعَوِّذِ بْنِ عَفْرَائَ ، قَالَتْ : أَتَانَا رَسُولُ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ فَوَضَعْنَا لَہُ الْمِیضَأَۃَ فَتَوَضَّأَ ثَلاَثًا ثَلاَثًا ، وَمَسَحَ بِرَأْسِہِ یَبْدَأَُ بِمُؤَخَّرِہِ۔\r\r\n(احمد ۳۵۹، جلد۶)",,,59,,كتاب الطهارة
60,"(۶۰) حَدَّثَنَا وَکِیعٌ ، عَنْ حَسَنِ بْنِ عُقْبَۃَ الْمُرَادِیِّ ، أَبِی کِبْرَانَ ، قَالَ : سَمِعْتُ عَبْدَ خَیْرٍ الْہَمْدَانِیَّ یَقُولُ : قَالَ عَلِیٌّ : أَلاَ أُرِیکُمْ وُضُوئَ رَسُولِ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ ؟ ثُمَّ تَوَضَّأَ ثَلاَثًا ، ثَلاَثًا۔",,,60,,كتاب الطهارة
61,"(۶۱) حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ عَمْرِو بْنِ دِینَار ، عَنْ سُمَیْعٍ ، عَنْ أَبِی أُمَامَۃَ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ تَوَضَّأَ فَغَسَلَ یَدَیْہِ ثَلاَثًا ، وَتَمَضْمَضَ وَاسْتَنْشَقَ ثَلاَثًا ثَلاَثًا ، وَتَوَضَّأَ ثَلاَثًا ثَلاَثًا۔ (احمد ۲۵۸، جلد۵۔ طبرانی ۷۹۹۰)",,,61,,كتاب الطهارة
62,"(۶۲) حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی النَّضْرِ ، عَنْ أَبِی أَنَسٍ ؛ أَنَّ عُثْمَانَ تَوَضَّأَ بِالْمَقَاعِدِ ، فَقَالَ : أَلاَ أُرِیکُمْ وُضُوئَ رَسُولِ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ ؟ ثُمَّ تَوَضَّأَ لَنَا ثَلاَثًا ثَلاَثًا۔ (دار قطنی ۱۱۔ مسلم ۹)",,,62,,كتاب الطهارة
63,(۶۳) حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ عَامِرِ بْنِ شَقِیقٍ ، عَنْ أَبِی وَائِلٍ ، عَنْ عُثْمَانَ ؛ أَنَّ النَّبِیَّ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ تَوَضَّأَ ثَلاَثًا ثَلاَثًا۔,,,63,,كتاب الطهارة
64,(۶۴) حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنَ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، عْن عَطَائِ بْنِ یَسَارٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ تَوَضَّأَ ، فَغَرَفَ غَرْفَۃً فَمَضْمَضَ مِنْہَا وَاسْتَنْثَرَ ، ثُمَّ غَرَفَ غَرْفَۃً فَغَسَلَ وَجْہَہُ ، ثُمَّ غَرَفَ غَرْفَۃً فَغَسَلَ یَدَہُ الْیُمْنَی ، ثُمَّ غَرَفَ غَرْفَۃً فَغَسَلَ یَدَہُ الْیُسْرَی ، ثُمَّ غَرَفَ غَرْفَۃً فَمَسَحَ رَأْسَہُ وَأُذُنَیْہِ دَاخِلَہُمَا بالسَّبَّابَتَیْنِ ، وَخَالَفَ بِإِبْہَامَیْہِ إلَی ظَاہِرِ أُذُنَیْہِ فَمَسَحَ بَاطِنَہُمَا وَظَاہِرَہُمَا ، ثُمَّ غَرَفَ غَرْفَۃً فَغَسَلَ رِجْلَہُ الْیُمْنَی ، ثُمَّ غَرَفَ غَرْفَۃً فَغَسَلَ رِجْلَہُ الْیُسْرَی۔ (ابن ماجہ۴۳۹۔ نسائی ۱۰۵),,,64,,كتاب الطهارة
65,"(۶۵) حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ؛ أَنَّ عُثْمَانَ تَوَضَّأَ ثَلاَثًا ثَلاَثًا ، وَمَسَحَ بِرَأْسِہِ مَسْحَۃً ، وَغَسَلَ رِجْلَیْہِ غَسْلاً ، ثُمَّ قَالَ : ہَکَذَا رَأَیْتُ رَسُولَ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ تَوَضَّأَ۔",,,65,,كتاب الطهارة
66,"(۶۶) حَدَّثَنَا شَرِیکٌ ، عَنْ ثَابِتٍ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : قُلْتُ لَہُ : حُدِّثْتَ عَنْ جَابِرٍ ، أَنَّ النَّبِیَّ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ تَوَضَّأَ مَرَّۃً مَرَّۃً ؟ قَالَ : نَعَمْ۔ (ابن ماجہ ۴۱۰۔ دار قطنی ۸)",,,66,,كتاب الطهارة
67,"(۶۷) حَدَّثَنَا ابْنُ عُیَیْنَۃَ، عَنْ بَیَانٍ، عَنِ الشَّعْبِیِّ، عَنْ قَرَظَۃَ ، قَالَ : شَیَّعْنَا عُمَرَ إلَی صِرَارٍ ، فَتَوَضَّأَ فَغَسَلَ مَرَّتَیْنِ۔ \r\r\n(ابن سعد ۷)",,,67,,كتاب الطهارة
68,"(۶۸) حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، عَنْ قَرَظَۃَ ، قَالَ ، سَمِعْتُ عُمَرَ یَقُولُ : الْوُضُوئُ ثَلاَثٌ ثَلاَثٌ ، وَثِنْتَانِ تُجْزِیَانِ۔",,,68,,كتاب الطهارة
69,"(۶۹) حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، عَنْ عُمَرَ ، قَالَ : فِی الْمَضْمَضَۃِ ، وَالْاِسْتِنْشَاقِ ، وَغَسْلِ الْوَجْہِ ، وَغَسْلِ الْیَدَیْنِ وَالرِّجْلَیْنِ ثِنْتَانِ تُجْزیَانِ ، وَثَلاَثٌ أَفْضَلُ۔",,,69,,كتاب الطهارة
70,"(۷۰) حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، عَنْ مُسْلِمِ بْنِ صُبَیْحٍ ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ یَتَوَضَّأُ ثَلاَثًا ثَلاَثًا ، ثُمَّ مَسَحَ بِرَأْسِہِ وَأُذُنَیْہِ۔",,,70,,كتاب الطهارة
71,"(۷۱) حَدَّثَنَا جَرِیرٌ ، عَنْ یَزِیدَ ، قَالَ : رَأَیْتُ عَبْدَ الرَّحْمَنِ بْنَ أَبِی لَیْلَی تَوَضَّأَ فَمَضْمَضَ وَاسْتَنْشَقَ مَرَّۃً ، أَوْ مَرَّتَیْنِ ، وَغَسَلَ وَجْہَہُ ثَلاَثًا وَذِرَاعَیْہِ ثَلاَثًا ثَلاَثًا ، وَمَسَحَ بِرَأْسِہِ وَغَسَلَ رِجْلَیْہِ ثَلاَثًا ثَلاَثًا ، وَلَمْ أَرَہُ خَلَّلَ لِحْیَتَہُ، ثُمَّ قَالَ : ہَکَذَا رَأَیْتُ عَلِیًّا تَوَضَّأَ۔",,,71,,كتاب الطهارة
72,"(۷۲) حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ مُسْلِمٍ ، قَالَ : رَأَیْتُ عَبْدَ الرَّحْمَنِ بْنَ أَبِی لَیْلَی تَوَضَّأَ ثَلاَثًا ثَلاَثًا۔",,,72,,كتاب الطهارة
73,"(۷۳) حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ إسْمَاعِیلَ بْنِ إبْرَاہِیمَ ، قَالَ : رَأَیْتُ ابْنَ عَبَّاسٍ تَوَضَّأَ فِی دَارِ النَّدْوَۃِ مَرَّۃً مَرَّۃً۔",,,73,,كتاب الطهارة
74,(۷۴) حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، عْن عَطَائِ بْنِ یَسَارٍ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّ النَّبِیَّ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ تَوَضَّأَ غَرْفَۃً غَرْفَۃً۔,,,74,,كتاب الطهارة
75,"(۷۵) حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنِ الشَّعْبِیِّ ، أَنَّ عُمَرَ تَوَضَّأَ مَرَّتَیْنِ ، قَالَ عَامِرٌ : وَفَعَلَہُ أَبُو بَکْرٍ۔",,,75,,كتاب الطهارة
76,"(۷۶) حَدَّثَنَا وَکِیعٌ ، وَالْفَضْلُ قَالاَ : حَدَّثَنَا سُفْیَانُ ، عَنْ عَاصِمِ بْنِ عُبَیْدِ اللہِ ، قَالَ : رَأَیْتُ سَالِمَ بْنَ عَبْدِ اللہِ تَوَضَّأَ مَرَّۃً مَرَّۃً۔",,,76,,كتاب الطهارة
77,"(۷۷) حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، وَابْنُ فُضَیْلٍ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، عَنْ إبْرَاہِیمَ ، قَالَ : یُجْزِئُکَ مِنَ الْوُضُوئِ مَرَّتَیْنِ مَرَّتَیْنِ ، وَإِنْ ثَلَّثْتَ فَقَدْ أَسْبَغْت۔",,,77,,كتاب الطهارة
78,"(۷۸) حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : الْوُضُوئُ وِتْرٌ۔",,,78,,كتاب الطهارة
79,"(۷۹) حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، قَالَ : سَأَلْتُ الزُّہْرِیَّ کَمْ یَکْفِی مِنَ الْوُضُوئِ عَنِ الْوَجْہِ وَالذِّرَاعَیْنِ ؟ قَالَ : مَا أَرَی وَاحِدَۃً سَابِغَۃً إِلاَّ کَافِیَۃً ، قَالَ : فَقُلْتُ لَہُ : إنَّ مَیْمُونًا یَقُولُ : ثَلاَثٌ عَلَی الْوَجْہِ وَثَلاَثٌ عَلَی الذِّرَاعَیْنِ ! فَقَالَ : ذَلِکَ أَبْلَغُ الْوُضُوئِ۔",,,79,,كتاب الطهارة
80,"(۸۰) حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا الْجَرِیرِیُّ ، عَنْ عُرْوَۃَ بْنِ قَبِیصَۃَ ، عَنْ رَجُلٍ مِنَ الأَنْصَارِ ، عَنْ أَبِیہِ ؛ أَنَّ عُثْمَانَ قَالَ : أَلاَ أُرِیکُمْ کَیْفَ کَانَ وُضُوئُ رَسُولِ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ ؟ قَالُوا : بَلَی ، فَدَعَا بِمَائٍ فَمَضْمَضَ ثَلاَثًا ، وَاسْتَنْشَقَ ثَلاَثًا ، وَغَسَلَ وَجْہَہُ ثَلاَثًا ، وَذِرَاعَیْہِ ثَلاَثًا ، وَمَسَحَ بِرَأْسِہِ وَغَسَلَ قَدَمَیْہِ ، ثُمَّ قَالَ : وَاعْلَمُوا أَنَّ الأُذُنَیْنِ مِنَ الرَّأْسِ ، ثُمَّ قَالَ : تَحَرَّیْتُ ، أَوْ تَوَخَّیْتُ لَکُمْ وُضُوئَ رَسُولِ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ۔ (احمد ۶۱، جلد۱۔ دار قطنی ۱۰۴)",,,80,,كتاب الطهارة
81,"(۸۱) حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ ثَوْبَانَ ، عَنْ عَبْدِ اللہِ بْنِ الْفَضْلِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ ہُرْمُزَ، عَنْ أَبِی ہُرَیْرَۃَ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ تَوَضَّأَ مَرَّتَیْنِ مَرَّتَیْنِ۔ \r\r\n(ابوداؤد ۱۳۷۔ ترمذی۴۳)",,,81,,كتاب الطهارة
82,"(۸۲) حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ جَابِرٍ ، عَنِ الْحَسَنِ ، قَالَ : الْوُضُوئُ مَرَّۃً وَمَرَّتَانِ وَثَلاَثٌ۔",,,82,,كتاب الطهارة
83,"(۸۳) حَدَّثَنَا وَکِیعٌ ، قَالَ حَدَّثَنَا دَاوُدُ بْنُ قَیْسٍ ، عَنْ عُبَیْدِ اللہِ بْنِ مِقْسَمٍ ، عَنِ الْقَاسِمِ قَالَ : أَمَّا مَنْ کَانَ یُحْسِنُ الْوُضُوئَ فَمَرَّۃً مَرَّۃً۔",,,83,,كتاب الطهارة
84,"(۸۴) حَدَّثَنَا یَحْیَی بْنُ سُلَیْمٍ، عَنْ إسْمَاعِیلَ بْنِ کَثِیرٍ ، عَنْ عَاصِمِ بْنِ لَقِیطِ بْنِ صَبِرَۃَ ، عَنْ أَبِیہِ ، قَالَ : قُلْتُ : یَا رَسُولَ اللہِ ، أَخْبِرْنِی عَنِ الْوُضُوئِ ؟ قَالَ : أَسْبِغِ الْوُضُوئَ ، وَخَلِّلْ بَیْنَ الأَصَابِعِ ، وَبَالِغْ فِی الاِسْتِنْشَاقِ ، إِلاَّ أَنْ تَکُونَ صَائِمًا۔ (ابن ماجہ ۴۴۸۔ ابوداؤد ۱۴۳)",,,84,,كتاب الطهارة
85,"(۸۵) حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ وَاقِدٍ ، عَنْ مُصْعَبِ بْنِ سَعْدٍ ، قَالَ : مَرَّ عُمَرُ عَلَی قَوْمٍ یَتَوَضَّؤُونَ ، فَقَالَ : خَلِّلُوا۔",,,85,,كتاب الطهارة
86,"(۸۶) حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنِ أَبیِ مِسْکِینٍ ، عَنْ ہُزَیْلٍ ، قَالَ : قَالَ عَبْدُ اللہِ : لَیَنْہَکَنَّ الرَّجُلُ مَا بَیْنَ أَصَابِعِہِ بِالْمَائِ ، أَوْ لَتَنْہَکَنَّہُ النَّارُ۔ (عبدالرزاق ۶۸)",,,86,,كتاب الطهارة
87,"(۸۷) حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : حدَّثَنِی مَنْ سَمِعَ حُذَیْفَۃَ یَقُولُ : خَلِّلُوا بَیْنَ الأَصَابِعِ فِی الْوُضُوئِ قَبْلَ أَنْ تُخَلِّلَہَا النَّارُ۔",,,87,,كتاب الطهارة
88,"(۸۸) حَدَّثَنَا ہُشَیْمٌ ، عَنْ عِمْرَانَ بْنِ أَبِی عَطَائٍ ، قَالَ : رَأَیْتُ ابْنَ عَبَّاسٍ تَوَضَّأَ فَغَسَلَ قَدَمَیْہِ حَتَّی تَتَبَّعَ بَیْنَ أَصَابِعِہِ فَغَسَلَہُنَّ۔",,,88,,كتاب الطهارة
89,"(۸۹) حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ شَیْبَۃَ بْنِ نِصَاحٍ ، قَالَ : صَحِبْتُ الْقَاسِمَ بْنَ مُحَمَّدٍ إلَی مَکَّۃَ فَرَأَیْتُہُ إذَا تَوَضَّأَ لِلصَّلاَۃِ یُدْخِلُ أَصَابِعَ یَدَیْہِ بَیْنَ أَصَابِعِ رِجْلَیْہِ ، قَالَ : وَہُوَ یَصُبُّ الْمَائَ عَلَیْہَا ، فَقُلْتُ لَہُ : یَا أَبَا مُحَمَّدٍ ، لِمَ تَصْنَعُ ہَذَا ؟ فَقَالَ : رَأَیْتُ عَبْدَ اللہِ بْنَ عُمَرَ یَصْنَعُہُ۔",,,89,,كتاب الطهارة
90,(۹۰) حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنِ الْقَاسِمِ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ رَآہُ فِی سَفَرٍ یَنْزِعُ خُفَّیْہِ ، ثُمَّ یُخَلِّلُ أَصَابِعَہُ۔,,,90,,كتاب الطهارة
91,"(۹۱) حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ طَلْحَۃَ ، عَنْ عَبْدِ اللہِ ، قَالَ : خَلِّلُوا بَیْنَ أَصَابِعِکُمْ بِالْمَائِ قَبْل أَنْ تَحْشُوَہَا النَّارُ۔ (طبرانی ۹۲۱۳)",,,91,,كتاب الطهارة
92,(۹۲) حَدَّثَنَا یَحْیَی بْنُ یَعْلَی التَّیْمِیُّ ، عَنْ مَنْصُورٍ ، عَنْ طَلْحَۃَ ، عَنْ عَبْدِ اللہِ ، بِمِثْلِ حَدِیثِ ابْنِ نُمَیْرٍ۔,,,92,,كتاب الطهارة
93,"(۹۳) حَدَّثَنَا وَکِیعٌ ، عَنِ أَبیِ مَکِینٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : إذَا تَوَضَّأْتَ فَابْدَأْ بِأَصَابِعِکَ فَخَلِّلْہَا ، فَإِنَّہُ کَانَ یُقَالُ : ہُوَ مَقِیلُ الشَّیْطَانِ۔",,,93,,كتاب الطهارة
94,"(۹۴) حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ عَبْدِ الأَعْلَی ، قَالَ : رَأَیْتُ ابْنَ الْحَنَفِیَّۃِ تَوَضَّأَ ، فَخَلَّلَ أَصَابِعَہُ۔",,,94,,كتاب الطهارة
95,"(۹۵) حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : خَلِّلُوا أَصَابِعَکُمْ بِالْمَائِ ، لاَ تُخَلِّلُہَا نَارٌ قَلِیلٌ بُقْیاہا۔",,,95,,كتاب الطهارة
96,"(۹۶) حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ ہِشَامٍ ، عَنْ یَحْیَی ، أَنَّ أَبَا بَکْرٍ الصِّدِّیقَ ، قَالَ : لَتُخَلِّلُنَّ أَصَابِعَکُمْ بِالْمَائِ، أَوْ لَیُخَلِّلَنَّہَا اللَّہُ بِالنَّارِ۔",,,96,,كتاب الطهارة
97,"(۹۷) حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ وَاصِلِ بْنِ السَّائِبِ ، عَنْ أَبِی سَوْرَۃَ ، عَنْ عَمِّہِ أَبِی أَیُّوبَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ : حَبَّذَا الْمُتَخَلِّلُونَ ، أَنْ تُخَلِّلَ بَیْنَ أَصَابِعِکَ بِالْمَائِ ، وَأَنْ تُخَلِّلَ مِنَ الطَّعَامِ۔ (طبرانی ۴۰۶۱۔ احمد ۴۱۶، جلد۵)",,,97,,كتاب الطهارة
98,"(۹۸) حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ حَسَّانَ بْنِ بِلاَلٍ ، قَالَ : رَأَیْتُ عَمَّارَ بْنَ یَاسِرٍ تَوَضَّأَ فَخَلَّلَ لِحْیَتَہُ ، فَقُلْتُ لَہُ ؟ فَقَالَ : رَأَیْتُ رَسُولَ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ فَعَلَہُ۔ (ترمذی ۳۰۔ ابن ماجہ ۴۲۹)",,,98,,كتاب الطهارة
99,"(۹۹) حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی حَمْزَۃَ ، قَالَ : رَأَیْتُ ابْنَ عَبَّاسٍ یُخَلِّلُ لِحْیَتَہُ إذَا تَوَضَّأَ۔",,,99,,كتاب الطهارة
100,(۱۰۰) حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یُخَلِّلُ لِحْیَتَہُ۔,,,100,,كتاب الطهارة
101,"(۱۰۱) حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ أَبِی مَعْنٍ ، قَالَ : رَأَیْتُ أَنَسًا تَوَضَّأَ فَخَلَّلَ لِحْیَتَہُ۔",,,101,,كتاب الطهارة
102,(۱۰۲) حَدَّثَنَا وَکِیعٌ ، عَنْ أُسَامَۃَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یُخَلِّلُ لِحْیَتَہُ إذَا تَوَضَّأَ۔,,,102,,كتاب الطهارة
103,"(۱۰۳) حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : رَأَیْتُ سَعِیدَ بْنَ جُبَیْرٍ تَوَضَّأَ وَخَلَّلَ لِحْیَتَہُ۔",,,103,,كتاب الطهارة
104,"(۱۰۴) حَدَّثَنَا وَکِیعٌ ، عَنِ الْمُعَلَّی بْنِ جَابِرٍ ، عَنِ الأَزْرَقِ بْنِ قَیْسٍ ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ یُخَلِّلُ لِحْیَتَہُ۔",,,104,,كتاب الطهارة
105,"(۱۰۵) حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنِ النَّضْرِ بْنِ مَعْبَدٍ ، قَالَ : رَأَیْتُ أَبَا قِلاَبَۃَ إذَا تَوَضَّأَ خَلَّلَ لِحْیَتَہُ۔",,,105,,كتاب الطهارة
106,"(۱۰۶) حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا الْحَسَنُ بْنُ صَالِحٍ ، عَنْ مُوسَی بْنِ أَبِی عَائِشَۃَ ، عَنْ یَزِیدَ الرَّقَاشِیِّ ، عَنْ أَنَسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ کَانَ إذَا تَوَضَّأَ یُخَلِّلُ لِحْیَتَہُ۔ (ابن ماجہ ۴۳۱۔ ابن سعد ۳۸۶)",,,106,,كتاب الطهارة
107,(۱۰۷) حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ مُجَاہِدٍ ؛ أَنَّہُ کَانَ یُخَلِّلُ لِحْیَتَہُ إذَا تَوَضَّأَ۔,,,107,,كتاب الطهارة
108,"(۱۰۸) حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ خَالِدِ بْنِ دِینَارٍ ، قَالَ : رَأَیْتُ ابْنَ سِیرِینَ تَوَضَّأَ فَخَلَّلَ لِحْیَتَہُ۔",,,108,,كتاب الطهارة
109,"(۱۰۹) حَدَّثَنَا ابن إدْرِیسَ ، عَنْ ہِشَامٍ ، قَالَ : کَانَ ابْنُ سِیرِینَ یُخَلِّلُہَا۔",,,109,,كتاب الطهارة
110,"(۱۱۰) حَدَّثَنَا یَحْیَی بْنُ الْیَمَانِ، قَالَ: حدَّثَنَا سُفْیَانُ، عَنِ الزُّبَیْرِ بْنِ عَدِیٍّ، عَنِ الضَّحَّاکِ، قَالَ: رَأَیْتُہ یُخَلِّلُ لِحْیَتَہُ۔",,,110,,كتاب الطهارة
111,"(۱۱۱) حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی عَاصِمٍ ، عَنْ رَجُلٍ لَمْ یُسَمِّہِ ؛ أَنَّ عَلِیًّا مَرَّ عَلَی رَجُلٍ یَتَوَضَّأُ ، فَقَالَ : خَلِّلْ ، یَعْنِی لِحْیَتَہُ۔`",,,111,,كتاب الطهارة
112,"(۱۱۲) حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ عُمَرَ بْنِ سُلَیْمٍ الْبَاہِلِیِّ ، قَالَ : حدَّثَنِی أَبُو غَالِبٍ ، قَالَ : قُلْتُ لأَبِی أُمَامَۃَ : أَخْبِرْنَا عَنْ وُضُوئِ رَسُولِ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ ، فَتَوَضَّأَ ثَلاَثًا ، وَخَلَّلَ لِحْیَتَہُ ، وَقَالَ : ہَکَذَا رَأَیْتُ رَسُولَ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ یَفْعَلُ۔",,,112,,كتاب الطهارة
113,"(۱۱۳) حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا إسْرَائِیلُ ، عَنْ عَامِرِ بْنِ شَقِیقٍ ، عَنْ أَبِی وَائِلٍ ، قَالَ : رَأَیْتُ عُثْمَانَ یَتَوَضَّأُ فَخَلَّلَ لِحْیَتَہُ ثَلاَثًا ، وَقَالَ : رَأَیْتُ رَسُولَ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ فَعَلَہُ۔(ابن حبان ۱۰۸۱۔ ترمذی ۳۱)",,,113,,كتاب الطهارة
114,"(۱۱۴) حَدَّثَنَا وَکِیعٌ ، عَنِ الْہَیْثُمِّ بْنِ جَمَّازٍ ، عَنْ یَزِیدَ بْنِ أَبَانَ ، عَنْ أَنَسٍ ؛ عَنِ النَّبِیِّ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ ، قَالَ: أَتَانِی جِبْرِیلُ فَقَالَ : إذَا تَوَضَّأْتَ فَخَلِّلْ لِحْیَتَک۔",,,114,,كتاب الطهارة
115,(۱۱۵) حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ إذَا تَوَضَّأَ خَلَّلَ لِحْیَتَہُ۔,,,115,,كتاب الطهارة
116,(۱۱۶) حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ ، حَدَّثَنَا حَسَنُ بْنُ صَالِحٍ ، عَنْ أَبِی الْہَیْثُمِّ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ تَوَضَّأَ وَخَلَّلَ لِحْیَتَہُ۔,,,116,,كتاب الطهارة
117,"(۱۱۷) حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدِ الزُّبَیْدِیِّ ، قَالَ : سَأَلْتُ إبْرَاہِیمَ : أُخَلِّلُ لِحْیَتِی بِالْمَائِ ، أَوْ یَکْفِیہَا مَا مَرَّ عَلَیْہَا ؟ قَالَ : یَکْفِیہَا مَا مَرَّ عَلَیْہَا۔",,,117,,كتاب الطهارة
118,"(۱۱۸) حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، قَالَ : کَانَ الْحَسَنُ لاَ یَفْعَلُ ، یَعْنِی لاَ یُخَلِّلُ لِحْیَتَہُ۔",,,118,,كتاب الطهارة
119,"(۱۱۹) حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ عَبْدِ الأَعْلَی ، عَنِ ابْنِ الْحَنَفِیَّۃِ ، قَالَ : رَأَیْتُہُ مَسَحَ جَانِبَیْ لِحْیَتِہِ وَعَارِضَیْہِ ، وَلَمْ یُخَلِّلْہَا۔",,,119,,كتاب الطهارة
120,"(۱۲۰) حَدَّثَنَا إِسْحَاقُ بْنُ سُلَیْمَانَ الرَّازِیّ ، عَنْ أَبِی جَعْفَرٍ ، عَنِ الرَّبِیعِ ، عَنْ أَبِی الْعَالِیَۃِ ، قَالَ : حسْبُک مَا سَالَ مِنْ وَجْہِکَ عَلَی لِحْیَتِک۔",,,120,,كتاب الطهارة
121,"(۱۲۱) حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ ثُوَیْرٍ ، قَالَ : رَأَیْتُ أَبَا جَعْفَرٍ لاَ یُخَلِّلُ لِحْیَتَہُ۔",,,121,,كتاب الطهارة
122,(۲۲) حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، وَمُحَمَّدِ بْنِ عَلِیٍّ ، وَمُجَاہِدٍ ، وَالْقَاسِمِ ؛ أَنَّہُمْ کَانُوا یَمْسَحُونَ لِحَاہُمْ ، وَلاَ یُخَلِّلُونَہَا۔,,,122,,كتاب الطهارة
123,"(۱۲۳) حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ یَزِیدَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، قَالَ : رَأَیْتُہُ تَوَضَّأَ ، وَلَمْ أَرَہُ خَلَّلَ لِحْیَتَہُ ، ثُمَّ قَالَ : ہَکَذَا رَأَیْتُ عَلِیًّا تَوَضَّأَ۔",,,123,,كتاب الطهارة
124,"(۱۲۴) حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ أَبِیہِ ، عَنِ الْحَسَنِ ، قَالَ : یُجْزِئُک مَا سَالَ مِنْ وَجْہِکَ عَلَی لِحْیَتِکَ ، وَلاَ تُخَلِّلْ۔",,,124,,كتاب الطهارة
125,"(۱۲۵) حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنَ ، قَالَ : سُئِلَ الْقَاسِمُ بْنُ مُحَمَّدٍ عَنْ تَخْلِیلِ اللِّحْیَۃِ ؟ فَقَالَ : مَا عَلَیَّ کَدُّہَا۔",,,125,,كتاب الطهارة
126,"(۱۲۶) حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ مَنْصُورٍ ، قَالَ : رَأَیْتُ إبْرَاہِیمَ تَوَضَّأَ وَلَمْ یُخَلِّلْ لِحْیَتَہُ۔",,,126,,كتاب الطهارة
127,"(۱۲۷) حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُسْلِمِ بْنِ أَبِی فَرْوَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، قَالَ : إنِ اسْتَطَعْتَ أَنْ تَبْلُغَ بِالْمَائِ أُصُولَ اللِّحْیَۃِ فَافْعَلْ۔",,,127,,كتاب الطهارة
128,"(۱۲۸) حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، عَنِ الأَشْعَثِ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : رَأَیْتُہُ یَغْسِلُ لِحْیَتَہُ ، فَقُلْتُ لَہُ : مِنَ السُّنَّۃِ غَسْلُ اللِّحْیَۃِ ؟ فَقَالَ : لاَ۔",,,128,,كتاب الطهارة
129,(۱۲۹) حَدَّثَنَا غُنْدَرٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ أَنَّہُ کَانَ یَرَی بَلَّ أُصُولِہَا مِنَ الْمَائِ ، یَعْنِی اللِّحْیَۃَ۔,,,129,,كتاب الطهارة
130,(۱۳۰) حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ۔ وَعُبَیْدَۃُ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُمَا کَانَا یَسْتَحِبَّانِ أَنْ یَمْسَحَا بَاطِنَ اللِّحْیَۃِ فِی الْوُضُوئِ۔,,,130,,كتاب الطهارة
131,"(۱۳۱) حَدَّثَنَا وَکِیعٌ ، عَنْ مُحَمَّدِ بْنِ قَیس، عَنْ مُحَارِبٍ ، عَنِ ابْنِ سَابِطٍ ، قَالَ: إذَا تَوَضَّأْتَ فَلاَ تَنْسَ الْفَنِیکَیْنِ۔",,,131,,كتاب الطهارة
132,"(۱۳۲) حَدَّثَنَا یَحْیَی بْنُ الْیَمَانِ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ شُبْرُمَۃَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : مَا بَالُ الرَّجُلِ یَغْسِلُ لِحْیَتَہُ قَبْلَ أَنْ تَنْبُتَ ، فَإِذَا نَبَتَتْ لَمْ یَغْسِلْہَا!",,,132,,كتاب الطهارة
133,"(۱۳۳) حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، عَنْ عُثْمَانَ بْنِ عَفَّانَ ، قَالَ : رَأَیْتُ النَّبِیَّ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ تَوَضَّأَ فَمَسَحَ رَأْسَہُ مَسْحَۃً۔ (ابن ماجہ ۴۳۵)",,,133,,كتاب الطهارة
134,(۱۳۴) حَدَّثَنَا حُسینُ بْنُ عَلِیٍّ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنِ الزُّہْرِیِّ ، عَنْ حُمْرَانَ ، عَنْ عُثْمَانَ ، أَنَّ النَّبِیَّ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ مَسَحَ مَرَّۃً۔,,,134,,كتاب الطهارة
135,(۱۳۵) حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنْ أَبِی إِسْحَاقَ ، عَمَّنْ حَدَّثَہُ ، عَنْ عَلِیٍّ ، أَنَّ النَّبِیَّ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ کَانَ یَتَوَضَّأُ ثَلاَثًا ثَلاَثًا ، إِلاَّ الْمَسْحَ مَرَّۃً مَرَّۃً۔,,,135,,كتاب الطهارة
136,(۱۳۶) حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ یَمْسَحُ مُقَدَّمَ رَأْسِہِ مَرَّۃً وَاحِدَۃً۔,,,136,,كتاب الطهارة
137,(۱۳۷) حَدَّثَنَا وَکِیعٌ ، عَنْ أُسَامَۃَ بْنِ زَیْدٍ ، عَنْ نَافِعٍ ، أَنَّ ابْنَ عُمَرَ کَانَ یَمْسَحُ یَافُوخَہُ مَرَّۃً۔,,,137,,كتاب الطهارة
138,"(۱۳۸) حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، قَالَ : دَخَلْتُ عَلَی عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، فَدَعَا بِوَضُوئٍ فَتَوَضَّأَ ، وَمَسَحَ رَأْسَہُ مَرَّۃً ، وَغَسَلَ قَدَمَیْہِ ثَلاَثًا ثَلاَثًا ، قَالَ : ہَکَذَا رَأَیْتُ عَلِیًّا یَتَوَضَّأُ۔",,,138,,كتاب الطهارة
139,"(۱۳۹) حَدَّثَنَا شَرِیکٌ ، عَنْ سِنَانٍ الْبَجَلِیِّ ، عَنْ إبْرَاہِیمَ ، قَالَ : تُجْزِیُٔ مَسْحَۃٌ لِلرَّأْسِ۔",,,139,,كتاب الطهارة
140,(۱۴۰) حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ أَبِی الْعَلاَئِ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسٍ ، أَنَّہُ کَانَ یَمْسَحُ رَأْسَہُ ثَلاَثًا۔,,,140,,كتاب الطهارة
141,"(۱۴۱) حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَبْدِ رَبِّ بْنِ أَیْمَنَ قَالَ: قُلْتُ لِعَطَائٍ: أَیُجْزِئُنِی أَنْ أَمْسَحَ رَأْسِی مَسْحَۃً؟ قَالَ: نَعَمْ۔",,,141,,كتاب الطهارة
142,"(۱۴۲) حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ ثُوَیْرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : لَوْ کُنْتُ عَلَی شَاطِیِٔ الْفُرَاتِ مَا زِدْتُ عَلَی مَسْحَۃٍ۔",,,142,,كتاب الطهارة
143,"(۱۴۳) حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ ، وَحَمَّادًا عَنْ مَسْحِ الرَّأْسِ ؟ فَقَالاَ : مَرَّۃً۔",,,143,,كتاب الطهارة
144,"(۱۴۴) حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ خَالِدِ بْنِ أَبِی بَکْرٍ ، قَالَ : رَأَیْتُ سَالِمًا مَسَحَ رَأْسَہُ وَاحِدَۃً",,,144,,كتاب الطهارة
145,"(۱۴۵) حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ مُحَمَّدِ بْنِ عَقِیلٍ ، قَالَ : حدَّثَتْنِی الرُّبَیِّعُ قَالَ : قَالَتْ : أَتَانَا النَّبِیُّ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ فَتَوَضَّأَ ، وَمَسَحَ بِرَأْسِہِ مَرَّتَیْنِ۔ (ابوداؤد ۱۲۷۔ ترمذی ۳۳)",,,145,,كتاب الطهارة
146,"(۱۴۶) حَدَّثَنَا وَکِیعٌ ، عَنِ الرَّبیعِ ، عَنِ الْحَسَنِ ، قَالَ : کَانَ یَأْمُرُ أَنْ یُمْسَحَ عَلَی الرَّأْسِ مَرَّۃً۔",,,146,,كتاب الطهارة
147,"(۱۴۷) حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ دَاوُدَ بْنِ أَبِی الْفُرَاتِ ، عَنْ إبْرَاہِیمَ الصَّائِغِ ، عَنْ عَطَائٍ ، أَنَّہُ قَالَ : یُمْسَحُ الرَّأْسُ مَرَّۃً وَاحِدَۃً۔",,,147,,كتاب الطهارة
148,(۱۴۸) حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، أَنَّ النَّبِیَّ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ مَسَحَ رَأْسَہُ مَرَّۃً وَاحِدَۃً۔,,,148,,كتاب الطهارة
149,(۱۴۹) حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللہِ الأَسَدِیِّ ، عَنْ إسْرَائِیلَ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، وَزَاذَانَ، وَمَیْسَرَۃَ ؛ أَنَّہُمْ کَانُوا إذَا تَوَضَّؤُوا مَسَحُوا رُؤُوسَہُمْ ثَلاَثًا۔,,,149,,كتاب الطهارة
150,"(۱۵۰) حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ لَیْثٍ ، عَنْ طَلْحَۃَ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، قَالَ : رَأَیْتُ النَّبِیَّ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ تَوَضَّأَ فَمَسَحَ رَأْسَہُ ہَکَذَا ؛ وَأَمَرَّ حَفْصٌ بِیَدَیْہِ عَلَی رَأْسِہِ حَتَّی مَسَحَ قَفَاہُ۔\r\r\n(احمد ۴۸۱۔ ابوداؤد ۱۳۳)",,,150,,كتاب الطهارة
151,"(۱۵۱) حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ قَالَ : قُلْتُ لِحُمَیْدٍ : أَکَانَ أَنَسُ بْنُ مَالِکٍ إذَا مَسَحَ رَأْسَہُ یُقَلِّبُ شَعَرَہُ ؟ قَالَ : لاَ۔",,,151,,كتاب الطهارة
152,(۱۵۲) حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، أَنَّہُ کَانَ یَمْسَحُ رَأْسَہُ ہَکَذَا ، مِنْ مُقَدَّمِہِ إلَی مُؤَخَّرِہِ ، ثُمَّ رَدَّ یَدَیْہِ إلَی مُقَدَّمِہِ۔,,,152,,كتاب الطهارة
153,"(۱۵۳) حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ مُحَمَّدِ بْنِ عَقِیلٍ ، قَالَ : حدَّثَتْنِی الرُّبَیِّعُ ، قَالَتْ : کَانَ رَسُولُ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ یَأْتِینَا فَیُکْثِرُ ، قَالَتْ : فَوَضَعْنَا لَہُ الْمِیضَأَۃَ ، فَأَتَانَا فَتَوَضَّأَ ، وَمَسَحَ رَأْسَہُ بَدَأَ بِمُؤَخَّرِہِ ، ثُمَّ رَدَّ یَدَیْہِ عَلَی نَاصِیَتِہِ۔",,,153,,كتاب الطهارة
154,(۱۵۴) حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، أَنَّ ابْنَ عُمَرَ کَانَ یَمْسَحُ رَأْسَہُ ہَکَذَا ، وَوَضَعَ أَیُّوبُ کَفَّہُ وَسْطَ رَأْسِہِ ، ثُمَّ أَمَرَّہَا عَلَی مُقَدَّمِ رَأْسِہِ۔,,,154,,كتاب الطهارة
155,"(۱۵۵) حَدَّثَنَا حَمَّادُ بْنُ مَسْعَدَۃَ ، عَنْ یَزِیدَ ، قَالَ : کَانَ سَلَمَۃُ یَمْسَحُ مُقَدَّمَ رَأْسِہِ۔",,,155,,كتاب الطهارة
156,"(۱۵۶) حَدَّثَنَا وَکِیعُ بْنُ الْجَرَّاحِ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ سُلَیْمَانَ بْنِ مُوسَی ، قَالَ : قَالَ النَّبِیُّ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ : مَنْ تَوَضَّأَ فَلْیُمَضْمِضْ وَلْیَسْتَنْشِق ، وَالأُذُنَانِ مِنَ الرَّأْسِ۔ (دار قطنی ۱۵)",,,156,,كتاب الطهارة
157,"(۱۵۷) حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، وَالْحَسَنِ قَالاَ : الأُذُنَانِ مِنَ الرَّأْسِ۔",,,157,,كتاب الطهارة
158,"(۱۵۸) حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ عَمْرِو بْنِ مُہَاجِرٍ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : الأُذُنَانِ مِنَ الرَّأْسِ۔",,,158,,كتاب الطهارة
159,"(۱۵۹) حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، عَنْ أَبِی مُوسَی ، قَالَ : الأُذُنَانِ مِنَ الرَّأْسِ۔",,,159,,كتاب الطهارة
160,"(۱۶۰) حَدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عَلِیِّ بْنِ زَیْدٍ ، عَنْ یُوسُفَ بْنِ مِہْرَانَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : الأُذُنَانِ مِنَ الرَّأْسِ۔",,,160,,كتاب الطهارة
161,"(۱۶۱) حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدِ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ۔ وَعَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، وَالْحَسَنِ قَالُوا : الأُذُنَانِ مِنَ الرَّأْسِ۔",,,161,,كتاب الطهارة
162,"(۱۶۲) حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : الأُذُنَانِ مِنَ الرَّأْسِ۔",,,162,,كتاب الطهارة
163,"(۱۶۳) حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ أُسَامَۃَ ، عَنْ ہِلاَلِ بْنِ أُسَامَۃَ ، عَنِ ابْنِ عُمَرَ ، قَالَ : الأُذُنَانِ مِنَ الرَّأْسِ۔",,,163,,كتاب الطهارة
164,"(۱۶۴) حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ نَافِعٍ ، قَالَ : کَانَ ابْنُ عُمَرَ یَمْسَحُ أُذُنَیْہِ ، وَیَقُولُ : ہُمَا مِنَ الرَّأْسِ۔",,,164,,كتاب الطهارة
165,"(۱۶۵) حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : مَا أَقْبَلَ مِنَ الأَذُنَیْنِ فَمِنَ الْوَجْہِ ، وَمَا أَدْبَرَ فَمِنَ الرَّأْسِ۔",,,165,,كتاب الطهارة
166,(۱۶۶) حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ؛ کَانَ یَغْسِلُ أُذُنَیْہِ مَعَ وَجْہِہِ ، وَیَمْسَحُہُمَا مَعَ رَأْسِہِ۔,,,166,,كتاب الطهارة
167,"(۱۶۷) حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ عَبْدِ الْمَلِکِ بْنِ مَیْسَرَۃَ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : الأُذُنَانِ مِنَ الرَّأْسِ۔",,,167,,كتاب الطهارة
168,"(۱۶۸) حَدَّثَنَا عَبْدُ الْحَمِیدِ بْنُ عَبْدِ الرَّحْمَنِ الْحِمَّانِیُّ ، عَنْ إسْمَاعِیلَ بْنِ عَبْدِ الْمَلِکِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ: الأُذُنَانِ مِنَ الرَّأْسِ۔",,,168,,كتاب الطهارة
169,"(۱۶۹) حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ الْجُرَیْرِیِّ ، عَنْ عُرْوَۃَ بْنِ قَبِیصَۃَ ، عَنْ رَجُلٍ مِنَ الأَنْصَارِ ، عَنْ أَبِیہِ ، عَنْ عُثْمَانَ ، قَالَ : وَاعْلَمُوا أَنَّ الأُذُنَیْنِ مِنَ الرَّأْسِ۔",,,169,,كتاب الطهارة
170,"(۱۷۰) حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : سَأَلْتُہُ عَنْ مَسْحِ الأُذُنَیْنِ مَعَ الرَّأْسِ ، أَوْ مَعَ الْوَجْہِ ؟ فَقَالَ : مَعَ کُلٍّ۔",,,170,,كتاب الطهارة
171,"(۱۷۱) حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، عَنْ حُمَیْدٍ ، قَالَ : رَأَیْتُ أَنَسًا تَوَضَّأَ ، فَجَعَلَ یَمْسَحُ ظَاہِرَ أُذُنَیْہِ وَبَاطِنَہُمَا ، فَنَظَرْتُ إلَیْہِ ، فَقَالَ : إنَّ ابْنَ مَسْعُودٍ کَانَ یَأْمُرُ بِذَلِکَ۔",,,171,,كتاب الطهارة
172,(۱۷۲) حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنَ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، عْن عَطَائِ بْنِ یَسَارٍ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّ رَسُولَ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ مَسَحَ أُذُنَیْہِ ، دَاخِلَہُمَا بِالسِّبَابَتَیْنِ ، وَخَالَفَ بِإِبْہَامَیْہِ إلَی ظَاہِرِ أُذُنَیْہِ فَمَسَحَ بَاطِنَہُمَا وَظَاہِرَہُمَا۔,,,172,,كتاب الطهارة
173,"(۱۷۳) حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ إذَا تَوَضَّأَ أَدْخَلَ الإِصْبُعَیْنِ اللَّتَیْنِ تَلِیَانِ الإِبْہَامَیْنِ فِی أُذُنَیْہِ ، فَمَسَحَ بَاطِنَہُمَا وَخَالَفَ بِالإِبْہَامَیْنِ إلَی ظَاہِرِہِمَا۔\r\r\n(عبدالرزاق ۲۹)",,,173,,كتاب الطهارة
174,"(۱۷۴) حَدَّثَنَا غُنْدَرٌ، عَنْ شُعْبَۃَ ، عَنِ الْہَیْثُمِّ ، عَنْ حَمَّادٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ، وَإِبْرَاہِیمَ ، أَنَّہُمَا قَالاَ فِی الأُذُنَیْنِ: امْسَحْ ظَاہِرَہُمَا وَبَاطِنَہُمَا۔",,,174,,كتاب الطهارة
175,"(۱۷۵) حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنْ عُثْمَانَ ، قَالَ : وَکَانَ مِنْ غِلْمَۃِ ابْنِ الزُّبَیْرِ ، قَالَ : وَضَّأْتُ ابْنَ عُمَرَ فَرَأَیْتُہُ یَمْسَحُ ظَاہِرَ أُذُنَیْہِ۔",,,175,,كتاب الطهارة
176,"(۱۷۶) حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ سَلْعٍ ، عَنْ عَبْدِ خَیْرٍ ، قَالَ : کُنَّا مَعَ عَلِیٍّ یَوْمًا صَلاَۃَ الْغَدَاۃِ ، فَلَمَّا انْصَرَفَ دَعَا الْغُلاَمَ بِالطَّسْتِ فَتَوَضَّأَ ، ثُمَّ أَدْخَلَ إصْبَعَیْہِ فِی أُذُنَیْہِ ، ثُمَّ قَالَ لَنَا : ہَکَذَا رَأَیْتُ رَسُولَ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ تَوَضَّأَ۔",,,176,,كتاب الطهارة
177,(۱۷۷) حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، قَالَ ، حَدَّثَنَا دَاوُد بْنُ أَبِی الْفُرَاتِ ، عَنْ مُحَمَّدِ بْنِ زَیْدٍ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ بْنِ یَزِیدَ ، أَنَّ عُمَرَ بْنَ الْخَطَّابِ تَوَضَّأَ فَأَدْخَلَ أُصْبَعَیْہِ فِی بَاطِنِ أُذُنَیْہِ وَظَاہِرِہِمَا ، فَمَسَحَہُمَا۔,,,177,,كتاب الطهارة
178,"(۱۷۸) حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، قَالَ : رَأَیْتُ عِکْرِمَۃَ یَمْسَحُ عَلَی رِجْلَیْہِ ، وَکَانَ یَقُولُ بِہِ۔",,,178,,كتاب الطهارة
179,"(۱۷۹) حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَقُولُ إنَّمَا ہُوَ الْمَسْحُ عَلَی الْقَدَمَیْنِ ، وَکَانَ یَقُولُ : یَمْسَحُ ظَاہِرَہُمَا وَبَاطِنَہُمَا۔",,,179,,كتاب الطهارة
180,"(۱۸۰) حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : غَسْلَتَانِ وَمَسْحَتَانِ۔ (عبدالرزاق ۵۵)",,,180,,كتاب الطهارة
181,"(۱۸۱) حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ، قَالَ : إنَّمَا ہُوَ الْمَسْحُ عَلَی الْقَدَمَیْنِ ، أَلاَ تَرَی أَنَّ مَا کَانَ عَلَیْہِ الْغَسْلُ جُعِلَ عَلَیْہِ التَّیَمُّمُ ، وَمَا کَانَ عَلَیْہِ الْمَسْحُ أُہْمِلَ ، فَلَمْ یُجْعَلْ عَلَیْہِ التَّیَمُّمُ۔",,,181,,كتاب الطهارة
182,"(۱۸۲) حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ حُمَیْدٍ ، قَالَ : کَانَ أَنَسٌ إذَا مَسَحَ عَلَی قَدَمَیْہِ بَلَّہُمَا۔",,,182,,كتاب الطهارة
183,"(۱۸۳) حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ خَیْرٍ ، عَنْ عَلِیٍّ ، قَالَ : لَوْ کَانَ الدِّینُ بِرَأْیٍ کَانَ بَاطِنُ الْقَدَمَیْنِ أَحَقَّ بِالْمَسْحِ مِنْ ظَاہِرِہِمَا ، وَلَکِنْ رَأَیْتُ رَسُولَ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ مَسَحَ ظَاہِرَہُمَا۔ (احمد ۱/۷۳۷)",,,183,,كتاب الطهارة
184,"(۱۸۴) حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ مَالِکِ بْنِ مِغْوَلٍ ، عَنْ زُبَیْدٍ الْیَامِیِّ ، عَنِ الشَّعْبِیِّ ، قَالَ : نَزَلَ جِبْرِیلُ بِالْمَسْحِ عَلَی الْقَدَمَیْنِ۔",,,184,,كتاب الطهارة
185,"(۱۸۵) حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ ، قَالَ : نَزَلَ جِبْرِِیلُ بِالْمَسْحِ۔ (ابن جریر ۱۲۹)",,,185,,كتاب الطهارة
186,"(۱۸۶) حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنِ الزُّبَیْرِ بْنِ عَدِیٍّ ، عَنْ إبْرَاہِیمَ ، قَالَ : سَأَلْتُ الأَسْوَدَ : أَکَانَ عُمَرُ یَغْسِلُ قَدَمَیْہِ ؟ قَالَ : نَعَمْ ، کَانَ یَغْسِلُہُمَا غَسْلاً۔",,,186,,كتاب الطهارة
187,(۱۸۷) حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ حُمَیْدٍ ؛ أَنَّ أَنَسًا کَانَ یَغْسِلُ قَدَمَیْہِ وَرِجْلَیْہِ حَتَّی یَسِیلَ الْمَائُ۔,,,187,,كتاب الطهارة
188,"(۱۸۸) حَدَّثَنَا شَرِیکٌ ، عَنْ زِیَادِ بْنِ عِلاَقَۃَ ، عَنِ ابْنِ غَرْبَائَ ؛ أَنَّ عُمَرَ بْنَ الْخَطَّابِ رَأَی رَجُلاً غَسَلَ ظَاہِرَ قَدَمَیْہِ وَتَرَکَ بَاطِنَہُمَا فَقَالَ : لِمَ تَرَکْتَہُمَا لِلنَّارِ؟",,,188,,كتاب الطهارة
189,"(۱۸۹) حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ قَاَلَ : اغْسِلِ الْقَدَمَیْنِ إلَی الْکَعْبَیْنِ۔",,,189,,كتاب الطهارة
190,"(۱۹۰) حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی بِشْرٍ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : إِنْ کُنْتُ لأَسْکُبُ عَلَیْہِ الْمَائَ ، فَیَغْسِلُ رِجْلَیْہِ۔",,,190,,كتاب الطهارة
191,"(۱۹۱) حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنِ الْحَسَنِ بْنِ صَالِحٍ ، عَنْ أَبِی الْجَحَّافِ ، عَنِ الْحَکَمِ ، قَالَ : سَمِعْتُہُ یَقُولُ : مَضَتِ السُّنَّۃُ مِنْ رَسُولِ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ وَالْمُسْلِمِینَ ، یَعْنِی بِغَسْلِ الْقَدَمَیْنِ۔",,,191,,كتاب الطهارة
192,"(۱۹۲) حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی حَیَّۃَ ، قَالَ : رَأَیْتُ عَلِیًّا تَوَضَّأَ فَغَسَلَ قَدَمَیْہِ إلَی الْکَعْبَیْنِ، وَقَالَ : أَرَدْتُ أَنْ أُرِیَکُمْ طُہُورَ نَبِیِّکُمْ صلی اللہ علیہ وسلم۔",,,192,,كتاب الطهارة
193,"(۱۹۳) حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ خَالِدٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّہُ قَرَأَ : { وَأَرْجُلَکُمْ } یَعْنِی : رَجَعَ الأَمْرُ إلَی الْغَسْلِ۔",,,193,,كتاب الطهارة
194,"(۱۹۴) حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، أنَّہُ کَانَ یَقْرَأُ : { فَاغْسِلُوا وُجُوہَکُمْ وَأَیْدِیَکُمْ إلَی الْمَرَافِقِ وَامْسَحُوا بِرُئُ وْسِکُمْ وَأَرْجُلَکُمْ } ، یَقُولُ : رَجَعَ الأَمْرُ إلَی الْغَسْلِ۔",,,194,,كتاب الطهارة
195,"(۱۹۵) حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ أَبِیہِ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : عَادَ الأَمْرُ إلَی الْغَسْلِ۔",,,195,,كتاب الطهارة
196,"(۱۹۶) حَدَّثَنَا حَفْصٌ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ : { فَاغْسِلُوا وُجُوہَکُمْ وَأَیْدِیَکُمْ } ، قَالَ : ذَاکَ الْغَسْلُ الدَّلْکُ۔",,,196,,كتاب الطهارة
197,(۱۹۷) حَدَّثَنَا وَکِیعٌ ، عَنْ عِمْرَانَ ، عَنْ أَبِی مِجْلَزٍ ؛ أَنَّہُ کَانَ یَغْسِلُ قَدَمَیْہِ۔,,,197,,كتاب الطهارة
198,"(۱۹۸) حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ محمد بن عَقِیلٍ ، قَالَ : حدَّثَتْنِی الرُّبَیِّعُ ، قَالَتْ ، کَانَ رَسُولُ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ یَأْتِینَا ، فَتَوَضَّأَ ، فَغَسَلَ رِجْلَیْہِ ثَلاَثًا۔",,,198,,كتاب الطهارة
199,"(۱۹۹) حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ رَوْحِ بْنِ الْقَاسِمِ ، عَنْ عَبْدِ اللہِ بْنِ مُحَمَّدِ بْنِ عَقِیلٍ ، عَنِ الرُّبَیِّعِ ابْنَۃِ مُعَوِّذِ بْنِ عَفْرَائَ ، قَالَتْ : أَتَانِی ابْنُ عَبَّاسٍ فَسَأَلَنِی عَنْ ہَذَا الْحَدِیثِ ، تَعْنِی حَدِیثَہَا الَّذِی ذَکَرَتْ ، أَنَّہَا رَأَتِ النَّبِیَّ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ تَوَضَّأَ ، وَأَنَّہُ غَسَلَ رِجْلَیْہِ ؟ قَالَتْ : فَقَالَ ابْنُ عَبَّاسٍ : أَبَی النَّاسُ إِلاَّ الْغَسْلَ ، وَلاَ أَجِدُ فِی کِتَابِ اللہِ إِلاَّ الْمَسْحَ۔ (احمد ۶/۳۵۸۔ حمیدی ۳۴۲)",,,199,,كتاب الطهارة
200,"(۲۰۰) حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ مُحَمَّدِ بْنِ مَحْمُودٍ ، قَالَ : رَأَی رَسُولُ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ رَجُلاً أَعْمَی یَتَوَضَّأُ ، فَغَسَلَ وَجْہَہُ وَیَدَیْہِ ، فَجَعَلَ النَّبِیُّ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : بَاطِنَ قَدَمَیْک، فَجَعَلَ یَغْسِلُ بَاطِنَ قَدَمَیْہِ۔ (عبدالرزاق ۷۷)",,,200,,كتاب الطهارة
201,"(۲۰۱) حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : قُلْتُ لَہُ : أَدْرَکْتَ أَحَدًا مِنْہُمْ یَمْسَحُ عَلَی الْقَدَمَیْنِ ؟ قَالَ : مُحْدَثٌ۔",,,201,,كتاب الطهارة
202,(۲۰۲) حَدَّثَنَا حَمَّادُ بْنُ مَسْعَدَۃَ ، عَنْ یَزِیدَ مَوْلَی سَلَمَۃَ ؛ کَانَ یَغْسِلُ قَدَمَیْہِ۔,,,202,,كتاب الطهارة
203,(۲۰۳) حَدَّثَنَا إِسْحَاقِ الأَزْرَقُ ، عَنْ أَیُّوبَ أَبِی الْعَلاَئِ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسٍ ؛ أَنَّہُ کَانَ یَمْسَحُ عَلَی الرَّأْسِ ثَلاَثًا ، یَأْخُذُ لِکُلِّ مَسْحَۃٍ مَائً عَلَی حِدَۃٍ۔,,,203,,كتاب الطهارة
204,"(۲۰۴) حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ شُعْبَۃَ ، عَنْ قَتَادَۃَ ، قَالَ : سَأَلْتُہُ ؟ فَقَالَ : کَانَ عَلِیُّ بْنُ أَبِی طَالِبٍ یَأْخُذُ لِرَأْسِہِ مَائً۔ قَالَ : وَسَأَلْتُ حَمَّادًا فَقَالَ : یَأْخُذُ لِرَأْسِہِ مَائً۔",,,204,,كتاب الطهارة
205,"(۲۰۵) حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : کَانَ یَرَی أَنْ یَأْخُذَ مَائً لِمَسْحِ رَأْسِہِ۔",,,205,,كتاب الطهارة
206,"(۲۰۶) حَدَّثَنَا أَبُو عَامِرٍ الْعَقَدِیُّ ، عَنْ أَفْلَحَ ، قَالَ : رَأَیْتُ الْقَاسِمَ تَوَضَّأَ ، فَأَخَذَ لِرَأْسِہِ مَائً جَدِیدًا۔",,,206,,كتاب الطهارة
207,(۲۰۷) حَدَّثَنَا حَفْصٌ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یُجَدِّدُ لِمَسْحِ الرَّأْسِ الْمَائَ۔,,,207,,كتاب الطهارة
208,(۲۰۸) حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، عْن عَطَائِ بْنِ یَسَارٍ ، عَنِ ابْنِ عبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ غَرَفَ غَرْفَۃً ، فَمَسَحَ رَأْسَہُ وَأُذُنَیْہِ۔,,,208,,كتاب الطهارة
209,(۲۰۹) حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَأْخُذُ لِرَأْسِہِ مَائً جَدِیدًا۔,,,209,,كتاب الطهارة
210,"(۲۱۰) حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ مُوسَی بْنِ أَبِی عَائِشَۃَ ، عَنْ مُصْعَبِ بْنِ سَعْدٍ ، قَالَ : خُذْ لِرَأْسِکَ مَائً جَدِیدًا۔",,,210,,كتاب الطهارة
211,"(۲۱۱) حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرَ ، عَنْ وَاقِدٍ ، عَنْ مُصْعَبِ بْنِ سَعْدٍ ، قَالَ : خُذْ لِرَأْسِکَ مَائً جَدِیدًا۔",,,211,,كتاب الطهارة
212,"(۲۱۲) حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ مُحَمَّدِ بْنِ عَقِیلٍ ، قَالَ : حدَّثَتْنِی الرُّبَیِّعُ بِنْتُ مُعَوِّذِ بْنِ عَفْرَائَ، قَالَتْ : أَتَانَا النَّبِیُّ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ فَتَوَضَّأَ ، وَمَسَحَ رَأْسَہُ بِمَا بَقِیَ مِنْ وَضُوئِہِ۔",,,212,,كتاب الطهارة
213,(۲۱۳) حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ۔ وَعَنْ حُمَیْدٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُمَا کَانَا یَمْسَحَانِ رُؤُوسَہُمَا بِفَضْلِ أَیْدِیہِمَا۔,,,213,,كتاب الطهارة
214,(۲۱۴) حَدَّثَنَا وَکِیعٌ ، عَنْ مَعْمَرٍ ، عَنْ أَبِی جَعْفَرٍ ، عَنِ النَّبِیِّ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ ؛ أَنَّہُ کَانَ یَمْسَحُ رَأْسَہُ بِفَضْلِ وَضُوئِہِ۔,,,214,,كتاب الطهارة
215,"(۲۱۵) حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا نَسِیَ أَنْ یَمْسَحَ رَأْسَہُ وَفِی لِحْیَتِہِ بَلَلٌ ، فَذَکَرَ وَہُوَ فِی الصَّلاَۃِ ، فَإِنْ کَانَ فِی لِحْیَتِہِ بَلَلٌ فَلْیَمْسَحْ رَأْسَہُ۔",,,215,,كتاب الطهارة
216,"(۲۱۶) حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : إذَا نَسِیَ مَسْحَ رَأْسِہِ ، فَوَجَدَ فِی لِحْیَتِہِ بَلَلاً، أَجْزَأَہُ أَنْ یَمْسَحَ بِہِ رَأْسَہُ",,,216,,كتاب الطهارة
217,(۲۱۷) حَدَّثَنَا حَفْصٌ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ۔ وَعَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، مِثْلُہُ۔,,,217,,كتاب الطهارة
218,"(۲۱۸) حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی قَوْلِہِ ؛ فِی الرَّجُلِ یَذْکُرُ فِی الصَّلاَۃِ أَنَّہُ لَمْ یَمْسَحْ رَأْسَہُ وَفِی لِحْیَتِہِ بَلَلٌ ، قَالَ : یَمْسَحُ رَأْسَہُ مِنْ بَلَلِ لِحْیَتِہِ۔",,,218,,كتاب الطهارة
219,"(۲۱۹) حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ قَتَادَۃَ ، عَنْ خِلاَسٍ ، فِیمَا یَعْلَمُ حَمَّادٌ ، عَنْ عَلِیٍّ ، قَالَ: إذَا تَوَضَّأَ الرَّجُلُ فَنَسِیَ أَنْ یَمْسَحَ بِرَأْسِہِ فَوَجَدَ فِی لِحْیَتِہِ بَلَلاً ، أَخَذَ مِنْ لِحْیَتِہِ فَمَسَحَ رَأْسَہُ۔",,,219,,كتاب الطهارة
220,(۲۲۰) حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ، عَنِ الْحَکَمِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی، عَنْ کَعْبِ بْنِ عُجْرَۃَ ، عَنْ بِلاَلٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ مَسَحَ عَلَی الْخُفَّیْنِ وَالْخِمَارِ۔ (طبرانی ۱۰۶۰۔ ابن خزیمۃ ۱۸۰),,,220,,كتاب الطهارة
221,"(۲۲۱) حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، وَابْنُ نُمَیْرٍ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ یَزِیدَ بْنِ أَبِی حَبِیبٍ ، عَنْ مَرْثَدِ بْنِ عَبْدِ اللہِ الْیَزَنِیِّ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عُسَیْلَۃَ الصُّنَابِحِیِّ ، قَالَ : رَأَیْتُ أَبَا بَکْرٍ یَمْسَحُ عَلَی الْخِمَارِ۔",,,221,,كتاب الطهارة
222,(۲۲۲) حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ الْقَطَّانُ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ أَشْعَثَ ، عَنْ أَبِیہِ ؛ أَنَّ أَبَا مُوسَی خَرَجَ مِنَ الْخَلاَئِ فَمَسَحَ عَلَی قَلَنْسُوَتِہِ۔,,,222,,كتاب الطهارة
223,"(۲۲۳) حَدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ أَبِی غَالِبٍ ، قَالَ : رَأَیْتُ أَبَا أُمَامَۃَ یَمْسَحُ عَلَی الْعِمَامَۃِ۔",,,223,,كتاب الطهارة
224,(۲۲۴) حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ سُفْیَانَ ، عَنْ سِمَاکٍ ، عَنِ الْحَسَنِ ، عَنْ أُمِّہِ ، عَنْ أُمِّ سَلَمَۃَ ؛ أَنَّہَا کَانَتْ تَمْسَحُ عَلَی الْخِمَارِ۔,,,224,,كتاب الطهارة
225,"(۲۲۵) حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ عَاصِمٍ ، قَالَ : رَأَیْتُ أَنَسًا یَمْسَحُ عَلَی الْخُفَّیْنِ وَالْعِمَامَۃِ۔",,,225,,كتاب الطهارة
226,"(۲۲۶) حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سُفْیَانَ ، عَنْ عِمْرَانَ بْنِ مُسْلِمٍ ، عَنْ سُوَیْد بْنِ غَفَلَۃَ ، قَالَ : قَالَ عُمَرُ : إِنْ شِئْتَ فَامْسَحْ عَلَی الْعِمَامَۃِ ، وَإِنْ شِئْتَ فَانْزِعْہَا۔",,,226,,كتاب الطهارة
227,"(۲۲۷) حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ عِمْرَانَ بْنِ مُسْلِمٍ ، عَنْ سُوَیْد بْنِ غَفَلَۃَ ، عَنْ نُبَاتَۃَ ، قَالَ: سَأَلْتُ عُمَرَ بْنَ الْخَطَّابِ عَنِ الْمَسْحِ عَلَی الْعِمَامَۃِ ؟ قَالَ : إِنْ شِئْتَ فَامْسَحْ عَلَیْہَا ، وَإِنْ شِئْتَ فَلاَ۔",,,227,,كتاب الطهارة
228,"(۲۲۸) حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِیہِ ، عَنْ طَارِقٍ ، قَالَ : رَأَیْتُ حَکِیمَ بْنَ جَابِرٍ یَمْسَحُ عَلَی الْعِمَامَۃِ۔",,,228,,كتاب الطهارة
229,"(۲۲۹) حَدَّثَنَا یُونُسُ بْنُ مُحَمَّدٍ ، عَنْ دَاوُدَ بْنِ أَبِی الْفُرَاتِ ، عَنْ مُحَمَّدِ بْنِ زَیْدٍ ، عَنْ أَبِی شُرَیْحٍ ، عَنْ أَبِی مُسْلِمٍ مَوْلَی زَیْدِ بْنِ صُوحَانَ ، قَالَ : کُنْتُ مَعَ سَلْمَانَ فَرَأَی رَجُلاً یَنْزِعُ خُفَّیْہِ لِلْوُضُوئِ ، فَقَالَ لَہُ سَلْمَانُ : امْسَحْ عَلَی خُفَّیْک وَعَلَی خِمَارِکَ وَبِنَاصِیَتِکَ ، فَإِنِّی رَأَیْتُ رَسُولَ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ یَمْسَحُ عَلَی الْخُفَّیْنِ وَالْخِمَارِ۔ (احمد ۵/۴۳۹۔ ابن ماجہ ۵۶۳)",,,229,,كتاب الطهارة
230,(۲۳۰) حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ التَّیْمِیِّ ، عَنْ بَکْرٍ ، عَنِ ابْنِ الْمُغِیرَۃِ بْنِ شُعْبَۃَ ، عَنْ أَبِیہِ ، أَنَّ النَّبِیَّ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ مَسَحَ مُقَدَّمَ رَأْسِہِ ، وَمَسَحَ عَلَی الْعِمَامَۃِ۔ (مسلم ۸۳۔ ترمذی ۱۰۰),,,230,,كتاب الطهارة
231,"(۲۳۱) حَدَّثَنَا مُحَمَّدُ بْنُ مُصْعَبٍ ، عَنِ الأَوْزَاعِیِّ ، عَنْ یَحْییَ بْنِ أَبِی کَثِیرٍ ، عَنْ أَبِی سَلَمَۃ ، عَنْ جَعْفَرِ بْنِ عَمْرِو بْنِ أُمَیَّۃَ الضَّمْرِیِّ ، عَنْ أَبِیہِ ، قَالَ : رَأَیْتُ النَّبِیَّ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ یَمْسَحُ عَلَی الْخُفَّیْنِ وَالْعِمَامَۃِ۔ (ابن ماجہ ۵۶۲۔ احمد ۴/۱۳۹)",,,231,,كتاب الطهارة
232,"(۲۳۲) حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ عَبَّادِ بْنِ إِسْحَاقَ ، عَنْ أَبِی عُبَیْدَۃَ بْنِ مُحَمَّدِ بْنِ عَمَّارِ بْنِ یَاسِرٍ ، قَالَ : سَأَلْتُ جَابِرًا عَنِ الْمَسْحِ عَلَی الْعِمَامَۃِ ؟ فَقَالَ : أَمِسَّ الْمَائَ الشَّعْرَ۔",,,232,,كتاب الطهارة
233,"(۲۳۳) حَدَّثَنَا وَکِیعُ بْنُ الْجَرَّاحِ ، عَنِ الرَّبِیعِ بْنِ سُلَیْمٍ ، عَنْ أَبِی لَبِیدٍ ، قَالَ : رَأَیْتُ عَلِیًّا أَتَی الْغَیْطَ عَلَی بَغْلَۃٍ لَہُ ، وَعَلَیْہِ إزَارٌ وَرِدَائٌ وَعِمَامَۃٌ وَخُفَّانِ ، فَرَأَیْتُہُ بَالَ ، ثُمَّ تَوَضَّأَ فَحَسَرَ الْعِمَامَۃَ ، فَرَأَیْتُ رَأْسَہُ مِثْلَ رَاحَتِی ، عَلَیْہِ مِثْلُ خَطِّ الأَصَابِعِ مِنَ الشَّعْرِ فَمَسَحَ بِرَأْسِہِ ، ثُمَّ مَسَحَ عَلَی خُفَّیْہِ۔",,,233,,كتاب الطهارة
234,(۲۳۴) حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَنْ سُفْیَانَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ لاَ یَمْسَحُ عَلَی الْعِمَامَۃِ۔,,,234,,كتاب الطهارة
235,"(۲۳۵) حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشِ ، عَنْ مُغِیرَۃَ ، قَالَ : کَانَ إذَا کَانَتْ عَلَی إبْرَاہِیمَ عِمَامَۃٌ ، أَوْ قَلَنْسُوَۃٌ رَفَعَہَا ، ثُمَّ مَسَحَ عَلَی یَافُوخِہِ۔",,,235,,كتاب الطهارة
236,"(۲۳۶) حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی الْبَخْتَرِیِّ ، قَالَ : رَأَیْتُ الشَّعْبِیَّ تَوَضَّأَ فَحَسَرَ الْعِمَامَۃَ۔",,,236,,كتاب الطهارة
237,(۲۳۷) حَدَّثَنَا مَعْنُ بْنُ عِیسَی، عَنْ مَالِکِ بْنِ أَنَسٍ، عَنْ ہِشَامٍ، عَنْ أَبِیہِ، أَنَّہُ کَانَ یَنْزِعُ الْعِمَامَۃَ وَیَمْسَحُ رَأْسَہُ بِالْمَائِ۔,,,237,,كتاب الطهارة
238,(۲۳۸) حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، أَنَّ رَسُولَ اللہِ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ تَوَضَّأَ فَرَفَعَ الْعِمَامَۃَ فَمَسَحَ مُقَدَّمَ رَأْسِہِ۔,,,238,,كتاب الطهارة
239,"(۲۳۹) حَدَّثَنَا أَبُو عَامِرٍ الْعَقَدِیُّ ، عَنْ أَفْلَحَ ، قَالَ : کَانَ الْقَاسِمُ لاَ یَمْسَحُ عَلَی الْعِمَامَۃِ ، یَحْسِرُ عَنْ رَأْسِہِ فَیَمْسَحُ عَلَیْہِ۔",,,239,,كتاب الطهارة
240,"(۲۴۰) حَدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : الرَّجُلُ یَمْسَحُ عَلَی نَاصِیَتِہِ وَعَلَی عِمَامَتِہِ۔",,,240,,كتاب الطهارة
241,(۲۴۱) حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدِ بْنِ سِیرِینَ ، عَنْ عَمْرِو بْنِ وَہْبٍ الثَّقَفِیِّ ، عَنِ الْمُغِیرَۃِ بْنِ شُعْبَۃَ؛ أَنَّ النَّبِیَّ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ تَوَضَّأَ فَمَسَحَ بِنَاصِیَتِہِ ، وَمَسَحَ عَلَی الْعِمَامَۃِ۔ (احمد ۴/۲۴۹۔ نسائی ۱۱۲),,,241,,كتاب الطهارة
242,"(۲۴۲) حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : الْمَرْأَۃُ وَالرَّجُلُ فِی مَسْحِ الرَّأْسِ سَوَائٌ۔",,,242,,كتاب الطهارة
243,"(۲۴۳) حَدَّثَنَا وَکِیعٌ ، عَنْ مَالِکِ بْنِ أَنَسٍ ، عَنْ نَافِعٍ ، قَالَ : رَأَیْتُ صَفِیَّۃَ بِنْتَ أَبِی عُبَیْدٍ تَوَضَّأَتْ ، فَأَدْخَلَتْ یَدَیْہَا تَحْتَ خِمَارِہَا ، فَمَسَحَتْ بِنَاصِیَتِہَا۔",,,243,,كتاب الطهارة
244,"(۲۴۴) حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ عَبْدِ الأَعْلَی ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، قَالَ : تُدْخِلُ الْمَرْأَۃُ یَدَیْہَا تَحْتَ خِمَارِہَا فَتَمْسَحُ بِنَاصِیَتِہَا۔",,,244,,كتاب الطهارة
245,"(۲۴۵) حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ عِکْرِمَۃَ ، قَالَ : تَمْسَحُ عَارِضَیْہَا۔",,,245,,كتاب الطهارة
246,"(۲۴۶) حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : تَمْسَحُ الْمَرْأَۃُ بِنَاصِیَتِہَا وَعَارِضَیْہَا ، إذَا کَانَتْ قَدْ مَسَحَتْ لِلصُّبْحِ۔",,,246,,كتاب الطهارة
247,"(۲۴۷) حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ فِی الْمَرْأَۃِ إذَا أَرَادَتْ أَنْ تَمْسَحَ رَأْسَہَا ، قَالَ : تُدْخِلُ یَدَیْہَا تَحْتَ الْخِمَارِ فَتَمْسَحُ مُقَدَّمَ رَأْسِہَا ، یُجْزِیُٔ عَنْہَا۔",,,247,,كتاب الطهارة
248,(۲۴۸) حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ ہِشَامٍ ، عَنْ فَاطِمَۃَ ابْنَۃِ الْمُنْذِرِ ؛ أَنَّہَا کانَتْ تَمْسَحُ عَلَی الْعَارِضَیْنِ ، وَقَدْ کَانَتْ أَدْرَکَتْ أَزْوَاجَ النَّبِیِّ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ۔,,,248,,كتاب الطهارة
249,"(۲۴۹) حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی خَلْدَۃَ خَالِدِ بْنِ دِینَارٍ ؛ أَنَّ أَبَا الْعَالِیَۃِ سُئِلَ : کَیْفَ تَمْسَحُ الْمَرْأَۃُ رَأْسَہَا ؟ فَقَالَ لامْرَأَتِہِ : أَخْبِرِیہَا ، فَقَالَتْ : ہَکَذَا ، وَأَمَرَّتْ یَدَیْہَا عَلَی جَانِبِ رَأْسِہَا فَمَسَحَتْہُ۔",,,249,,كتاب الطهارة
250,(۲۵۰) حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ سُفْیَانَ ، عَنْ سِمَاکٍ ، عَنِ الْحَسَنِ ، عَنْ أُمِّہِ ، عَنْ أُمِّ سَلَمَۃَ ؛ أَنَّہَا کَانَتْ تَمْسَحُ عَلَی الْخِمَارِ۔,,,250,,كتاب الطهارة
251,"(۲۵۱) حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، قَالَ : سُئِلَ عَنِ الْمَرْأَۃِ تَمْسَحُ عَلَی خِمَارَہَا ؟ فَقَالَ : لاَ ، وَلَکِنْ تَمْسَحُ عَلَی رَأْسِہَا۔",,,251,,كتاب الطهارة
252,"(۲۵۲) حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا تَوَضَّأَتِ الْمَرْأَۃُ فَلْتَنْزِعْ خِمَارَہَا وَلْتَمْسَحْ بِرَأْسِہَا۔",,,252,,كتاب الطهارة
253,"(۲۵۳) حَدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : الْمَرْأَۃُ تَمْسَحُ عَلَی نَاصِیَتِہَا وَعَلَی خِمَارِہَا۔",,,253,,كتاب الطهارة
254,"(۲۵۴) حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، قَالَ : قَالَ حَمَّادٌ : تَنْزِعُ الْمَرْأَۃُ خِمَارَہَا عِنْدَ کُلِّ وُضُوئٍ۔",,,254,,كتاب الطهارة
255,(۲۵۵) حَدَّثَنَا عَبْدُ الْعَزِیزِ بْنُ مُحَمَّدٍ الدَّرَاوَرْدِیُّ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، عْن أَبِیہِ ؛ أَنَّ عُمَرَ کَانَ لَہُ قُمْقُمٌ یُسَخَّنُ لَہُ فِیہِ الْمَائُ۔,,,255,,كتاب الطهارة
256,(۲۵۶) حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ سَعْدٍ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، عْن أَبِیہِ ؛ أَنَّ عُمَرَ کَانَ لَہُ قُمْقُمٌ یُسَخَّنُ لَہُ فِیہِ الْمَائُ۔ (دار قطنی ۱),,,256,,كتاب الطهارة
257,"(۲۵۷) حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، قَالَ : سَأَلْتُ نَافِعًا عَنِ الْمَائِ السُّخْنِ ؟ فَقَالَ : کَانَ ابْنُ عُمَرَ یَتَوَضَّأُ بِالْحَمِیمِ۔",,,257,,كتاب الطهارة
258,"(۲۵۸) حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ إِسْحَاقَ بْنِ سُوَیْد ، عَنْ یَحْیَی بْنِ یَعْمَُرَ ، قَالَ : یُتَطَہَّرُ بِمَائٍ یُطْبَخُ بِالنَّارِ ، وَإِذَا تَوَضَّأْتُ بِالْمَائِ السُّخْنِ مَزَجْتُہُ۔",,,258,,كتاب الطهارة
259,"(۲۵۹) حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ عَمْرٍو قَالَ : حَدَّثَنَا أَبُو سَلَمَۃَ ، قَالَ : قَالَ ابْنُ عَبَّاسٍ : إنَّا نَدَّہِنُ بِالدُّہْنِ وَقَدْ طُبِخَ عَلَی النَّارِ ، وَنَتَوَضَّأُ بِالْحَمِیمِ وَقَدْ أُغْلِیَ عَلَی النَّارِ۔",,,259,,كتاب الطهارة
260,"(۲۶۰) حَدَّثَنَا وَکِیعٌ ، عَنْ قُرَّۃَ ، قَالَ : سَأَلْتُ الْحَسَنَ عَنِ الْوُضُوئِ بِالْمَائِ السُّخْنِ ؟ فَقَالَ : لاَ بَأْسَ بِہِ۔",,,260,,كتاب الطهارة
261,"(۲۶۱) حَدَّثَنَا شَرِیکٌ ، عَنْ بَدْرٍ ، قَالَ : أَتَیْتُ أَبَا وَائِلٍ یَوْمَ جُمُعَۃٍ ، وَہُوَ یُسَخَّنُ لَہُ الْمَائُ۔",,,261,,كتاب الطهارة
262,(۲۶۲) حَدَّثَنَا حَمَّادُ بْنُ مَسْعَدَۃَ ، عَنْ یَزِیدَ ، أَنَّ سَلَمَۃَ کَانَ یُسَخَّنُ لَہُ الْمَائُ فَیَتَوَضَّأُ بِہِ۔,,,262,,كتاب الطهارة
263,(۲۶۳) حَدَّثَنَا قَاسِمُ بْنُ مَالِکٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، أَنَّہُ کَرِہَ الْوُضُوئَ بِالْمَائِ السَُّخْنِ۔,,,263,,كتاب الطهارة
