{"hadithnumber": "3966", "text": "ابراہیم نخعی اور سعید بن جبیر سے روایت ہے کہ  وہ دونوں خالی زمین کو کرائے پر اٹھانے میں کوئی حرج نہی"}
{"hadithnumber": "3967", "text": "محمد بن سیرین کہتے ہیں کہ  مجھے معلوم ہے کہ شریح مضارب ۱؎ کے سلسلے میں صرف دو طرح کے فیصلے دیتے تھے،"}
{"hadithnumber": "3968", "text": "سعید بن مسیب کہتے ہیں کہ  خالی زمین کو سونے، چاندی کے بدلے کرائے پر اٹھانے میں کوئی حرج نہیں ہے۔"}
{"hadithnumber": "3969", "text": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  میں عمار اور سعد رضی اللہ عنہما بدر کی لڑائی کے روز شریک"}
{"hadithnumber": "3970", "text": "زہری کہتے ہیں کہ  مفاوضہ کے طور پر دو غلام شریکوں پھر ایک مکاتبت کر لے تو یہ جائز ہے اس میں شرط یہ ہ"}
{"hadithnumber": "3971", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  مجھے حکم دیا گیا ہے کہ"}
{"hadithnumber": "3972", "text": "انس بن مالک رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مجھے حکم دیا گیا ہ"}
{"hadithnumber": "3973", "text": "میمون بن سیاہ نے  انس بن مالک رضی اللہ عنہ سے پوچھا: ابوحمزہ! کس چیز سے مسلمان کی جان، اور اس کا مال"}
{"hadithnumber": "3974", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  جب رسول اللہ صلی اللہ علیہ وسلم کا انتقال ہوا تو بعض عرب مرتد"}
{"hadithnumber": "3975", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  جب رسول اللہ صلی اللہ علیہ وسلم اللہ تعالیٰ کو پیارے ہو گئے اور ا"}
{"hadithnumber": "3976", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: مجھے حکم دیا گیا ہے کہ می"}
{"hadithnumber": "3977", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: مجھے حکم دیا گیا ہے کہ می"}
{"hadithnumber": "3978", "text": "ابوہریرہ رضی اللہ عنہ فرماتے ہیں کہ  جب رسول اللہ صلی اللہ علیہ وسلم کی وفات ہوئی اور آپ کے بعد ابوب"}
{"hadithnumber": "3979", "text": "ابوہریرہ رضی اللہ عنہ بیان کرتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مجھے حکم دیا گیا ہے"}
{"hadithnumber": "3980", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ   ( ارتداد کا فتنہ ظاہر ہونے پر )  ابوبکر رضی اللہ عنہ نے ان مرتدی"}
{"hadithnumber": "3981", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مجھے حکم دیا گیا ہے کہ م"}
{"hadithnumber": "3982", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مجھے حکم دیا گیا ہے کہ م"}
{"hadithnumber": "3983", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ہم لوگوں سے اس وقت تک جن"}
{"hadithnumber": "3984", "text": "نعمان بن بشیر رضی اللہ عنہما کہتے ہیں کہ  ہم نبی اکرم صلی اللہ علیہ وسلم کے ساتھ تھے کہ ایک شخص نے آ"}
{"hadithnumber": "3985", "text": "ایک شخص ۱؎ کہتے ہیں کہ  ہمارے پاس رسول اللہ صلی اللہ علیہ وسلم آئے اور ہم مدینے کی مسجد کے ایک خیمے"}
{"hadithnumber": "3986", "text": "اوس رضی اللہ عنہ کہتے ہیں کہ  ہمارے پاس رسول اللہ صلی اللہ علیہ وسلم تشریف لائے اور ہم لوگ خیمہ میں"}
{"hadithnumber": "3987", "text": "اوس رضی اللہ عنہ کہتے ہیں کہ  میں قبیلہ ثقیف کے ایک وفد میں رسول اللہ صلی اللہ علیہ وسلم کے پاس آیا،"}
{"hadithnumber": "3988", "text": "اوس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مجھے حکم دیا گیا ہے کہ میں لو"}
{"hadithnumber": "3989", "text": "ابوادریس خولانی کہتے ہیں کہ  میں نے معاویہ رضی اللہ عنہ کو خطبہ دیتے ہوئے سنا  ( انہوں نے رسول اللہ"}
{"hadithnumber": "3990", "text": "عبداللہ بن مسعود رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  ناحق جو بھی خو"}
{"hadithnumber": "3991", "text": "عبداللہ بن عمرو بن عاص رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  قسم اس ذ"}
{"hadithnumber": "3992", "text": "عبداللہ بن عمرو رضی اللہ عنہما روایت کرتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  اللہ تعالی"}
{"hadithnumber": "3993", "text": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  مومن کا  ( ناحق )  قتل اللہ تعالیٰ کے نزدیک پوری دنیا کے"}
{"hadithnumber": "3994", "text": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  مومن کا قتل اللہ تعالیٰ کے نزدیک دنیا کے ہلاک و برباد ہو"}
{"hadithnumber": "3995", "text": "بریدہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مومن کا  ( ناحق )  قتل اللہ"}
{"hadithnumber": "3996", "text": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  سب سے پہلی چیز ج"}
{"hadithnumber": "3997", "text": "عبداللہ بن مسعود رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  سب سے پہلے لو"}
{"hadithnumber": "3998", "text": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  لوگوں کے درمیان قیامت کے روز سب سے پہلے خون کا فیصلہ کیا"}
{"hadithnumber": "3999", "text": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  قیامت کے روز سب سے پہلے لوگوں کے درمیان خون کا فیصلہ کیا"}
{"hadithnumber": "4000", "text": "عمرو بن شرحبیل کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  قیامت کے روز لوگوں کے درمیان سب"}
{"hadithnumber": "4001", "text": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  لوگوں کے درمیان سب سے پہلے خون کا فیصلہ کیا جائے گا۔"}
{"hadithnumber": "4002", "text": "عبداللہ بن مسعود رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:   ( قیامت کے دن"}
{"hadithnumber": "4003", "text": "جندب رضی اللہ عنہ کہتے ہیں کہ  مجھ سے فلاں  ( صحابی )  نے بیان کیا کہ رسول اللہ صلی اللہ علیہ وسلم ن"}
{"hadithnumber": "4004", "text": "سالم بن ابی الجعد سے روایت ہے کہ  ابن عباس رضی اللہ عنہما سے اس شخص کے بارے میں پوچھا کیا گیا جس نے"}
{"hadithnumber": "4005", "text": "سعید بن جبیر کہتے ہیں کہ  اس آیت «ومن يقتل مؤمنا متعمدا» کے سلسلے میں اہل کوفہ میں اختلاف ہوا تو میں"}
{"hadithnumber": "4006", "text": "سعید بن جبیر کہتے ہیں کہ  میں نے ابن عباس رضی اللہ عنہما سے پوچھا: جس نے کسی مومن کو جان بوجھ کر قتل"}
{"hadithnumber": "4007", "text": "سعید بن جبیر کہتے ہیں کہ عبدالرحمٰن بن ابی لیلی نے مجھے حکم دیا کہ  میں ابن عباس سے ان دو آیتوں «ومن"}
{"hadithnumber": "4008", "text": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  ایک  ( مشرک )  قوم کے لوگوں نے بہت زیادہ قتل کئے، کثر"}
{"hadithnumber": "4009", "text": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  مشرکین میں سے کے کچھ لوگوں نے محمد صلی اللہ علیہ وسلم"}
{"hadithnumber": "4010", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  قیامت کے دن مقتو"}
{"hadithnumber": "4011", "text": "زید بن ثابت رضی اللہ عنہ  کہتے ہیں: «ومن يقتل مؤمنا متعمدا فجزاؤه جهنم خالدا فيها‏» یہ پوری آیت آخر"}
{"hadithnumber": "4012", "text": "زید بن ثابت رضی اللہ عنہ سے روایت ہے کہ  انہوں نے اس آیت: «ومن يقتل مؤمنا متعمدا فجزاؤه جهنم» کے بار"}
{"hadithnumber": "4013", "text": "زید بن ثابت رضی اللہ عنہ کہتے ہیں کہ  جب آیت: «ومن يقتل مؤمنا متعمدا فجزاؤه جهنم خالدا فيها» نازل ہو"}
{"hadithnumber": "4014", "text": "ابوایوب انصاری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو اللہ تعالیٰ کی"}
{"hadithnumber": "4015", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  کبائر یہ ہیں: اللہ کے ساتھ غی"}
{"hadithnumber": "4016", "text": "عبداللہ بن عمرو رضی اللہ عنہما روایت کرتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  کبائر  ( ب"}
{"hadithnumber": "4017", "text": "صحابی رسول عمیر رضی اللہ عنہ بیان کرتے ہیں کہ  ایک شخص نے عرض کیا: اللہ کے رسول! کبائر کیا ہیں؟ آپ ن"}
{"hadithnumber": "4018", "text": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  میں نے عرض کیا: اللہ کے رسول! کون سا گناہ بڑا ہے؟ آپ نے ف"}
{"hadithnumber": "4019", "text": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  میں نے عرض کیا: اللہ کے رسول! کون سا گناہ سب سے بڑا ہے؟ آ"}
{"hadithnumber": "4020", "text": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم سے پوچھا: کون سا گناہ"}
{"hadithnumber": "4021", "text": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اس ذات کی قسم جس"}
{"hadithnumber": "4022", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  کیا تمہیں معلوم نہیں کہ رسول اللہ صلی اللہ علیہ وسلم نے"}
{"hadithnumber": "4023", "text": "ام المؤمنین عائشہ رضی اللہ عنہا نے کہا:  عمار! کیا تمہیں نہیں معلوم کہ کسی مسلمان شخص کا خون حلال نہ"}
{"hadithnumber": "4024", "text": "ابوامامہ بن سہل اور عبداللہ بن عامر بن ربیعہ بیان کرتے ہیں کہ  ہم عثمان رضی اللہ عنہ کے ساتھ تھے اور"}
{"hadithnumber": "4025", "text": "عرفجہ بن شریح اشجعی رضی اللہ عنہ کہتے ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم کو منبر پر لوگوں کو"}
{"hadithnumber": "4026", "text": "عرفجہ بن شریح رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  میرے بعد فتنہ و فساد"}
{"hadithnumber": "4027", "text": "عرفجہ رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا:  میرے بعد فت"}
{"hadithnumber": "4028", "text": "اسامہ بن شریک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص میری امت میں"}
{"hadithnumber": "4029", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  قبیلہ عکل کے آٹھ آدمی نبی اکرم صلی اللہ علیہ وسلم کے پاس آئے،"}
{"hadithnumber": "4030", "text": "انس رضی اللہ عنہ سے روایت ہے کہ  قبیلہ عکل کے کچھ لوگ نبی اکرم صلی اللہ علیہ وسلم کے پاس آئے اور اسل"}
{"hadithnumber": "4031", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے پاس قبیلہ عکل کے آٹھ آدمی آئے، پھر انہ"}
{"hadithnumber": "4032", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کے پاس قبیلہ عکل یا عرینہ کے چند آدمی آئے،"}
{"hadithnumber": "4033", "text": "انس بن مالک رضی اللہ عنہ سے روایت ہے کہ  عرینہ کے کچھ لوگ رسول اللہ صلی اللہ علیہ وسلم کے پاس آئے، ا"}
{"hadithnumber": "4034", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے پاس عرینہ کے کچھ لوگ آئے تو رسول اللہ"}
{"hadithnumber": "4035", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  قبیلہ عرینہ کے کچھ لوگ رسول اللہ صلی اللہ علیہ وسلم کے پاس آئے، انہیں"}
{"hadithnumber": "4036", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  قبیلہ عرینہ کے کچھ لوگ اسلام لائے تو انہیں مدینے کی آب و ہوا راس نہیں"}
{"hadithnumber": "4037", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  قبیلہ عکل یا عرینہ کے کچھ لوگ رسول اللہ صلی اللہ علیہ وسلم کے"}
{"hadithnumber": "4038", "text": "اس سند سے بھی  عبدالاعلی سے اسی طرح روایت ہے"}
{"hadithnumber": "4039", "text": "انس رضی اللہ عنہ سے روایت ہے کہ  قبیلہ عرینہ کے کچھ لوگ حرہ میں ٹھہرے، پھر وہ نبی اکرم صلی اللہ علیہ"}
{"hadithnumber": "4040", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  قبیلہ عرینہ کے کچھ اعرابی  ( دیہاتی )  نبی اکرم صلی اللہ علیہ"}
