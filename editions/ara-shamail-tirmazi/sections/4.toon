metadata:
  section_id: 4
  section_name: رسول اللہ صلی اللہ علیہ وسلم کے مبارک بالوں کا بیان
  hadith_first: 24
  hadith_last: 31

hadiths[8]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
24,"حَدَّثَنَا عَلِيُّ بْنُ حُجْرٍ قَالَ: أَخْبَرَنَا إِسْمَاعِيلُ بْنُ إِبْرَاهِيمَ، عَنْ حُمَيْدٍ، عَنْ أنَسِ بْنِ مَالِكٍ قَالَ: ((كَانَ شَعْرُ رَسُولِ اللَّهِ صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ إِلَى نِصْفِ أُذُنَيْهِ))",,,24,,رسول اللہ صلی اللہ علیہ وسلم کے مبارک بالوں کا بیان
25,"حَدَّثَنَا هَنَّادُ بْنُ السَّرِيِّ قَالَ: أَخْبَرَنَا عَبْدُ الرَّحْمَنِ بْنُ أَبِي الزِّنَادِ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، قَالَتْ: ((كُنْتُ أَغْتَسِلُ أَنَا وَرَسُولُ اللَّهِ صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ مِنْ إِنَاءٍ وَاحِدٍ، وَكَانَ لَهُ شَعْرٌ فَوْقَ الْجُمَّةِ وَدُونَ الْوَفْرَةِ))",,,25,,رسول اللہ صلی اللہ علیہ وسلم کے مبارک بالوں کا بیان
26,"حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ قَالَ: أَنَا أَبُو قَطَنٍ قَالَ: حَدَّثَنَا شُعْبَةُ، عَنْ أَبِي إِسْحَاقَ، عَنِ الْبَرَاءِ بْنِ عَازِبٍ قَالَ: ((كَانَ رَسُولُ اللَّهِ صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ مَرْبُوعًا، بَعِيدَ مَا بَيْنَ الْمِنْكَبَيْنِ، وَكَانَتْ جُمَّتُهُ تَضْرِبُ شَحْمَةَ أُذُنَيْهِ))",,,26,,رسول اللہ صلی اللہ علیہ وسلم کے مبارک بالوں کا بیان
27,"حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ قَالَ: أَنَا أَبُو قَطَنٍ قَالَ: حَدَّثَنَا شُعْبَةُ، عَنْ أَبِي إِسْحَاقَ، عَنِ الْبَرَاءِ بْنِ عَازِبٍ قَالَ: ((كَانَ رَسُولُ اللَّهِ صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ مَرْبُوعًا، بَعِيدَ مَا بَيْنَ الْمِنْكَبَيْنِ، وَكَانَتْ جُمَّتُهُ تَضْرِبُ شَحْمَةَ أُذُنَيْهِ))",,,27,,رسول اللہ صلی اللہ علیہ وسلم کے مبارک بالوں کا بیان
28,"حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى بْنِ أَبِي عُمَرَ ،أَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ ابْنِ أَبِي نَجِيحٍ، عَنْ مُجَاهِدٍ، عَنْ أُمِّ هَانِئٍ بِنْتِ أَبِي طَالِبٍ، قَالَتْ: ((قَدِمَ رَسُولُ اللَّهِ صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ مَكَّةَ قَدْمَةً وَلَهُ أَرْبَعُ غَدَائِرَ))",,,28,,رسول اللہ صلی اللہ علیہ وسلم کے مبارک بالوں کا بیان
29,"حَدَّثَنَا سُوَيْدُ بْنُ نَصْرٍ قَالَ: حَدَّثَنَا عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ، عَنْ مَعْمَرٍ، عَنْ ثَابِتٍ الْبُنَانِيِّ، عَنْ أَنَسٍ: ((أَنَّ شَعْرَ رَسُولِ اللَّهِ صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ كَانَ إِلَى أَنْصَافِ أُذُنَيْهِ))",,,29,,رسول اللہ صلی اللہ علیہ وسلم کے مبارک بالوں کا بیان
30,"حَدَّثَنَا سُوَيْدُ بْنُ نَصْرٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ، عَنْ يُونُسَ بْنِ يَزِيدَ، عَنِ الزُّهْرِيِّ أَنَا عُبَيْدُ اللَّهِ بْنُ عَبْدِ اللَّهِ بْنِ عُتْبَةَ، عَنِ ابْنِ عَبَّاسٍ: ((أَنَّ رَسُولَ اللَّهِ صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ كَانَ يُسْدِلُ شَعْرَهُ، وَكَانَ الْمُشْرِكُونَ يَفْرِقُونَ رُءُوسَهُمْ، وَكَانَ أَهْلُ الْكِتَابِ يُسْدِلُونَ رُءُوسَهُمْ، وَكَانَ يُحِبُّ مُوَافَقَةَ أَهْلِ الْكِتَابِ فِيمَا لَمْ يُؤْمَرْ فِيهِ بِشَيْءٍ، ثُمَّ فَرَقَ رَسُولُ اللَّهِ صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ رَأْسَهُ))",,,30,,رسول اللہ صلی اللہ علیہ وسلم کے مبارک بالوں کا بیان
31,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ ،أَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، عَنْ إِبْرَاهِيمَ بْنِ نَافِعٍ الْمَكِّيِّ، عَنِ ابْنِ أَبِي نَجِيحٍ، عَنْ مُجَاهِدٍ، عَنْ أُمِّ هَانِئٍ، قَالَتْ: ((رَأَيْتُ رَسُولَ اللَّهِ صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ ذَا ضَفَائِرَ أَرْبَعٍ))",,,31,,رسول اللہ صلی اللہ علیہ وسلم کے مبارک بالوں کا بیان
