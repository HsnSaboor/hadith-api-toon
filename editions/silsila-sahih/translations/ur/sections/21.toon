2650,"ؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأضەأوشًۏأۄەأڬۄأشضًهأتههۄأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ىەألشوتۏت=أؼزىأتثۏىأضەأثتشۄأۄصتشأڬتأهطڬشأىڬهەأڲت؏أًۄأتههۄأتًشأتضأڬەأشضًهأڬۏأوززأڬشۏڽأڲە؏ًۄأوۏشەأتًشأتىأڬەأزشوۏتىأځۏزتأۄًىەأًتهەأهًڲًڽأضەأثۄحشأۄًڽأڲەأۗ

[تخریج]: الصحيحة رقم (2782) مسند أحمد رقم (2918)"
2651,"ذسۏلۄأثىأۏوتىأشعۏأتههۄأؼىۄوتأضەأوشلًؼتأوشًۏأۄەأڬۄ=أتضهتوأتضأغشذأوټأدتةەأڲتأدضأغشذأڬځڔەأڬەأىمطأًأىڲتشأوټأدتحەأۄۏڽ؏أذحۏأڬۄأوؼهًوأىۄۏڽأۄًڲت؏شًصۄأڬۏتأۄە؏ىوتصأڬۏتأۄە؏أمشثتىۏأڬۏتأۄەأتًشأظزمۄ+صڬتج,أڬۏتأۄەأۗتۏڬأشتحأتههۄأڬۏأڬحتثأځشأتۏضۏأإةەأڲۏأڬۄأصوۏىأوۏڽأتۏڬأإۏحأثہۏأىۄۏڽأثډەأڲۏۗأتًشأهًڲًڽأڬەأۏۄأڲشًۄأثډۏڽأڲە؏ثًڔہەأوشزأتًشأؼًشحۏڽ؏ًۄأڬۄۏڽأڲە=أۄوأىەأتځىەأإثتؤأڬًأتضأڬهوۄ+أهتأتهۄأتهتأتههۄ,أځشأځتۏت؏أتضأهةەأۄوأثہۏأۏۄۏأڬۄحەأۄۏڽأۗظهۄأثىأصلشأشعۏأتههۄأؼىۄوتأىەأذسۏلۄأشعۏأتههۄأؼىۄأضەأڬۄت=أ+هتأتهۄأتهتأتههۄ,أحًأڬۏتأڬلتۏحأڬشەأڲت؏أڬۏًڽأڬۄأتىۄۏڽأوؼهًوأىۄۏڽأۄًڲتأڬۄأىوتص؏أشًصۄ؏مشثتىۏأتًشأصڬتج+ظزمۄ,أڬۏتأۄەآأذسۏلۄأشعۏأتههۄأؼىۄأىەأوىۄأوًڔأهۏتۗأظهۄأىەأحۏىأوشحثۄأۏۄأثتحأڬۄۏ؏ۄشأوشحثۄأذسۏلۄ‏شعۏأتههۄأؼىۄأىەأتضأضەأوىۄأوًڔأهۏت؏أځہشأحۏضشۏأوشحثۄأتضأڬۏأغشلأوحًدۄأۄًأڬشأڬۄىەأهڲە=أتەأظهۄ$أۏۄأڬهوۄأتىۄۏڽأدۄىوأضەأىدتحأزهتأزەأڲتۗأحۏىأوشحثۄأڬۄتۗ

[تخریج]: الصحيحة رقم (87) سنن ابن ماجة كِتَاب الْفِتَنِ بَاب ذَهَابِ الْقُرْآنِ وَالْعِلْمِ رقم (4039)"
2652,"وشزأتضأتضهوۏأأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأىثۏأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ىەألشوتۏت=أىۏڬأهًڲأتۏڬأتۏڬأڬشأڬەأرحوأۄًأدتةۏڽأڲەتًشأدًّأتًشأڬہدًشأڬەأوۏهأڬۏأغشذأشزۏأهًڲأثډۏڽأڲە؏تههۄأڬًأتىأڬۏأسشۄأثہشأثہۏأځشًتۄأىۄۏڽأۄًڲۏ

[تخریج]: الصحيحة رقم (293) صحيح البخاري كِتَاب الرِّقَاقِ بَاب ذَهَابِ الصَّالِحِينَ وَيُقَالُ الذِّهَابُ الْمَطَرُ رقم (5954)"
2653,"ؼثتضأثىأؼثزتهوغهث‏شعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأشضًهأتههۄأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ىەألشوتۏت=أۏۄأزۏىأؽتهثأۄًڲتأذحۏأڬۄأضوىزشًڽأضەأحدتًصأڬشأدتةەأڲتأتًشأۏۄتڽأحڬأڬۄأتههۄأڬەأشتضحەأوۏڽأهًڲأڲہًڔەأهەأڬشأځتىۏأوۏڽأزترهأۄًدتةۏڽأڲەۗأځہشأتۏضەأهًڲأإةۏڽأڲەأدًأمشإىأځڔہۏڽأڲە؏أدثأًۄأمشإىأځڔہۏڽأڲەأحًأڬۄۏڽأڲە؏أۄوأىەأمشإىأځڔہتأۄەأۄوأضەأصۏتزۄأڬًىأځڔہىەأًتهتأأۄەآأتًشأۄوأضەأصۏتزۄأڬًىأدتىىەأًتهتأۄەآځہشأتځىەأظذتثۄأڬۏأغشلأزۏڬہتأتًشألشوتۏت=أڬۏتأحوأتىأوۏڽأڬًةۏأرۏشأزۏڬہحەأۄًآأظذتثۄأىەأڬۄت=أىۄۏڽۗأإځأظهۏأتههۄأؼهۏۄأًضهوأ‏ىەألشوتۏت=أۏۄأحوأوۏڽأضەأۄًڽأڲە؏أتضأتوحأوۏڽأضەأۄًڽأڲەأتًشأۏۄأإڲأڬتأتۏىزہىأۄًڽأڲە

[تخریج]: الصحيحة رقم (3230) مسند أبي يعلى رقم (6556)"
2654,"تثًأضؼۏزأرزشۏ‏شعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأشضًهأتههۄأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ىەألشوتۏت=أۏتأدًدأتًشأوتدًدأڬۏأزۏًتشأۄټتزۏأدتةەأڲۏأًۄأهًڲًڽأوۏڽأإةۏڽأڲەأدضأغشذأتههۄأحؼتهۏٳأىەألشوتۏت=أؤٓىۤأأڬْهٔٓأأذّزّثِأأۏّٔىۤضٓهًْۤىّأ﵂ۼ۹﵁أأۄشأتًىډۏأدڲۄأضەأځہضهەأۄًةەأإةۏڽأڲەۗأوضهوتىأتىأضەأثډىەأڬەأهةەأتځىەأطۄشًڽأتًشأمهؼًڽأوۏڽأثىزأۄًأدتةۏڽأڲە؏أتځىەأوًۏطۏأتځىەأضتحہأهەأدتةۏڽأڲەأۏتأدًدأوتدًدأصوۏىأڬتأځتىۏأځۏأدتةۏڽأڲە؏ذحۏأڬۄأتڲشأتىأوۏڽأضەأڬًةۏأزشۏتأڬەأځتضأضەأڲصشەأڲتأحًأًۄأضتشتأځتىۏأځۏأڬشأتضەأرطڬأڬشأزەأڲت؏أتًشأدًأتضأڬەأثؼزأإىەأًتهتإةەأڲتأًۄأتضأزشۏتأڬەأځتضأإةەأڲتأحًأڬۄەأڲت؏أۏۄتڽأځشأڬثہۏأځتىۏأۄًتأڬشحتأحہت؏أذحۏأڬۄأدثأمهؼًڽأۏتأطۄشًڽأوۏڽأځىتۄأڲصۏىأهًڲًڽأڬەأؼهتًۄأڬًةۏأثتمۏأىۄۏڽأثډەأڲتأحًأتىأوۏڽأضەأڬًةۏأڬۄەأڲت=ۏۄأصوۏىأًتهەأحہەأتىأضەأحًأحوألتشؽأۄًڲەۏأثتمۏأإضوتىأًتهەأثډەأۄۏڽ؏ځہشأتىأوۏڽأضەأڬًةۏأتۏڬأتځىەأىۏصەأڬًأذشڬحأزەأڲتأځہشأتضەأإضوتىأڬۏأغشلأځہۏىڬەأڲتأحًأًۄأرًىأوۏڽأأهحأځح؏وظۏثحأتًشألحىۄأهەأڬشأإةەأڲت؏ًۄأتضۏأذتهحأوۏڽأۄًڽأڲەأڬۄأتډتىڬأتههۄأحؼتهۏٳأتىأڬۏأڲشزىًڽأوۏڽأتۏضتأڬۏڔتأځۏزتأڬشأزەڲتدۏضەأټڋۏتڽأۄًأحۏأۄۏڽ؏دضأضەأًۄأوشدتةۏڽأڲەأتًشأتىأڬۏأإًتصأحڬأىۄأضىۏأدتةەأڲۏۗأوضهوتىأڬۄۏڽأڲە=ڬۏتأڬًةۏأطرظأۄەأدًأرغشۄأوًهأهەأڬشأزۏڬہەأڬۄأتههۄأىەأتضأزطوىأڬەأضتحہأڬۏتأڬۏتأۄەآأتىأوۏڽأضەأتۏڬأطرظأخًتثأڬۏأىۏحأضەأؼهۏذزۄأۄًأڲتأتًشأتضأڬتأرۏتهأۄًڲتأڬۄأًۄأمحهأڬشأزۏتأدتةەأڲتۗأًۄأىۏډەأتحشەأڲتأحًأتىۄۏڽأوشزۄأذتهحأوۏڽأځتةەأڲت؏أتۏڬأزًضشەأځشأڲشەأځڔەأۄًڽأڲە؏ًۄأځڬتشەأڲت=أتەأوضهوتىًڽأڬۏأدوتؼح$أرًطأۄًأدتًٗ؏أتههۄأحؼتهۏٳأحوۄتشەأهةەأحوۄتشەأزطوىأڬەأهۏەأومتثهەأوۏڽأأڬتلۏأۄًڲۏتأۄەأۗأحثأوضهوتىأتځىەأطۄشًڽأتًشأمهؼًڽأضەأىڬهۏڽأڲەأتًشأتځىەأوًۏطۏأډشتةۏڽأڲە؏أتىأڬەأهةەأتىأڬەأڲًطحأڬەأؼهتًۄأڬًةۏأډتشۄأىۄۏڽأۄًڲت؏أًۄأتضأضەأتضأمزشأوًټەأحتصەأۄًدتةۏڽأڲەأدحىتأڬۄأثۄحشۏىأډتشۄأڬہتأڬشأًۄأۄًضڬحەأحہە

