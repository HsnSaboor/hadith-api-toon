metadata:

hadiths[186]{hadithnumber,arabic,bengali,english,french,indonesian,russian,urdu,grades,reference,international_number,narrator_chain,chapter_intro}:
{"hadithnumber": "1843", "arabic": "حَدَّثَنَا يَحْيَى بْنُ يَحْيَى التَّمِيمِيُّ، وَمُحَمَّدُ بْنُ رُمْحِ بْنِ الْمُهَاجِرِ، قَالاَ أَخْبَرَنَا اللَّيْثُ، ح وَحَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا لَيْثٌ، عَنْ نَافِعٍ، عَنْ عَبْدِ اللَّهِ، قَالَ سَمِعْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم يَقُولُ ‏ ‏ إِذَا أَرَادَ أَحَدُكُمْ أَنْ يَأْتِيَ الْجُمُعَةَ فَلْيَغْتَسِلْ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "When any one of you intends to come for Jumu'a prayer, he should take a bath.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abdullah is reported to have heard Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1844", "arabic": "حَدَّثَنَا قُتَيْبَةُ بْنُ سَعِيدٍ، حَدَّثَنَا لَيْثٌ، ح وَحَدَّثَنَا ابْنُ رُمْحٍ، أَخْبَرَنَا اللَّيْثُ، عَنِ ابْنِ، شِهَابٍ عَنْ عَبْدِ اللَّهِ بْنِ عَبْدِ اللَّهِ بْنِ عُمَرَ، عَنْ عَبْدِ اللَّهِ بْنِ عُمَرَ، عَنْ رَسُولِ اللَّهِ صلى الله عليه وسلم أَنَّهُ قَالَ وَهُوَ قَائِمٌ عَلَى الْمِنْبَرِ ‏ ‏ مَنْ جَاءَ مِنْكُمُ الْجُمُعَةَ فَلْيَغْتَسِلْ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "He who comes for Jumu'a he should take a bath.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abdullah b. Umar is reported to have said that The Messenger of Allah (may peace be up on him) was standing on the pulpit when he said this:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1845", "arabic": "وَحَدَّثَنِي مُحَمَّدُ بْنُ رَافِعٍ، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَخْبَرَنَا ابْنُ جُرَيْجٍ، أَخْبَرَنِي ابْنُ شِهَابٍ، عَنْ سَالِمٍ، وَعَبْدِ اللَّهِ، ابْنَىْ عَبْدِ اللَّهِ بْنِ عُمَرَ عَنِ ابْنِ عُمَرَ، عَنِ النَّبِيِّ صلى الله عليه وسلم .‏ بِمِثْلِهِ ‏.‏", "bengali": "", "english": "This hadith has been narrated by Ibn Umar by another chain of transmitters.", "french": "", "indonesian": "", "russian": "", "urdu": "سفیان بن عیینہ نے زہری سے انھوں نے ابو سلمہ سے اور انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے ر", "grades": "", "reference": "", "international_number": "1845", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1846", "arabic": "وَحَدَّثَنِي حَرْمَلَةُ بْنُ يَحْيَى، أَخْبَرَنَا ابْنُ وَهْبٍ، أَخْبَرَنِي يُونُسُ، عَنِ ابْنِ شِهَابٍ، عَنْ سَالِمِ بْنِ عَبْدِ اللَّهِ، عَنْ أَبِيهِ، قَالَ سَمِعْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم يَقُولُ ‏.‏ بِمِثْلِهِ ‏.‏", "bengali": "", "english": "'Abdullah (b. Umar) reported on the authority of his father that he heard like this from the Messenger of Allah (ﷺ).", "french": "", "indonesian": "", "russian": "", "urdu": "یونس اور عمر  ( بن حارث  )  دونوں نے ابن شہاب سے اسی سند کے ساتھ یہ روایت کی اس میں   )  ما اذن لنبي", "grades": "", "reference": "", "international_number": "1846", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1847", "arabic": "وَحَدَّثَنِي حَرْمَلَةُ بْنُ يَحْيَى، أَخْبَرَنَا ابْنُ وَهْبٍ، أَخْبَرَنِي يُونُسُ، عَنِ ابْنِ شِهَابٍ، حَدَّثَنِي سَالِمُ بْنُ عَبْدِ اللَّهِ، عَنْ أَبِيهِ، ‏.‏ أَنَّ عُمَرَ بْنَ الْخَطَّابِ، بَيْنَا هُوَ يَخْطُبُ النَّاسَ يَوْمَ الْجُمُعَةِ دَخَلَ رَجُلٌ مِنْ أَصْحَابِ رَسُولِ اللَّهِ صلى الله عليه وسلم فَنَادَاهُ عُمَرُ أَيَّةُ سَاعَةٍ هَذِهِ فَقَالَ إِنِّي شُغِلْتُ الْيَوْمَ فَلَمْ أَنْقَلِبْ إِلَى أَهْلِي حَتَّى سَمِعْتُ النِّدَاءَ فَلَمْ أَزِدْ عَلَى أَنْ تَوَضَّأْتُ ‏.‏ قَالَ عُمَرُ وَالْوُضُوءَ أَيْضًا وَقَدْ عَلِمْتَ أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم كَانَ يَأْمُرُ بِالْغُسْلِ ‏.‏", "bengali": "", "english": "What is this hour (for attending the prayer)? He said: I was busy today and I did not return to my house when I heard the call (to Friday prayer), and I did no more but performed ablution only. Upon this Umar said: just ablution! You know that the Messenger of Allah (ﷺ) commanded (us) to take a bath (on Friday).", "french": "", "indonesian": "", "russian": "", "urdu": "عبد العزیز بن محمد نے کہا :  یزید بن ہاد نے ہمیں محمد بن ابرا ہیم سے حدیث بیان کی انھوں نے ابو سلمہ", "grades": "", "reference": "", "international_number": "1847", "narrator_chain": "'Abdullah (b. 'Umar) reported from his father that while he was addressing the people on Friday (sermon), a person, one of the Companions of the Messenger of Allah (ﷺ), entered (the mosque). Umar said to him loudly:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1848", "arabic": "حَدَّثَنَا إِسْحَاقُ بْنُ إِبْرَاهِيمَ، أَخْبَرَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، عَنِ الأَوْزَاعِيِّ، قَالَ حَدَّثَنِي يَحْيَى بْنُ أَبِي كَثِيرٍ، حَدَّثَنِي أَبُو سَلَمَةَ بْنُ عَبْدِ الرَّحْمَنِ، حَدَّثَنِي أَبُو هُرَيْرَةَ، قَالَ بَيْنَمَا عُمَرُ بْنُ الْخَطَّابِ يَخْطُبُ النَّاسَ يَوْمَ الْجُمُعَةِ إِذْ دَخَلَ عُثْمَانُ بْنُ عَفَّانَ فَعَرَّضَ بِهِ عُمَرُ فَقَالَ مَا بَالُ رِجَالٍ يَتَأَخَّرُونَ بَعْدَ النِّدَاءِ ‏.‏ فَقَالَ عُثْمَانُ يَا أَمِيرَ الْمُؤْمِنِينَ مَا زِدْتُ حِينَ سَمِعْتُ النِّدَاءَ أَنْ تَوَضَّأْتُ ثُمَّ أَقْبَلْتُ ‏.‏ فَقَالَ عُمَرُ وَالْوُضُوءَ أَيْضًا أَلَمْ تَسْمَعُوا رَسُولَ اللَّهِ صلى الله عليه وسلم يَقُولُ ‏ ‏ إِذَا جَاءَ أَحَدُكُمْ إِلَى الْجُمُعَةِ فَلْيَغْتَسِلْ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "Umar b. Khattab was delivering a sermon to the people on Friday when 'Uthman b. 'Affan came there. 'Umar hinting to him said: What would become of those persons who come after the call to prayer? Upon this 'Uthman said: Commander of the faithful, I did no more than this that after listening to the call, I performed ablution and came (to the mosque). 'Umar said: Just ablution! Did you not hear the Messenger of Allah (my peace be upon him) say this: When any one of you comes for Jumu'a, he should take a bath.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira reported:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1849", "arabic": "حَدَّثَنَا يَحْيَى بْنُ يَحْيَى، قَالَ قَرَأْتُ عَلَى مَالِكٍ عَنْ صَفْوَانَ بْنِ سُلَيْمٍ، عَنْ عَطَاءِ، بْنِ يَسَارٍ عَنْ أَبِي سَعِيدٍ الْخُدْرِيِّ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ الْغُسْلُ يَوْمَ الْجُمُعَةِ وَاجِبٌ عَلَى كُلِّ مُحْتَلِمٍ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "Taking a bath on Friday is essential for every adult person.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Sa'id al-Khudri reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1850", "arabic": "حَدَّثَنِي هَارُونُ بْنُ سَعِيدٍ الأَيْلِيُّ، وَأَحْمَدُ بْنُ عِيسَى، قَالاَ حَدَّثَنَا ابْنُ وَهْبٍ، أَخْبَرَنِي عَمْرٌو، عَنْ عُبَيْدِ اللَّهِ بْنِ أَبِي جَعْفَرٍ، أَنَّ مُحَمَّدَ بْنَ جَعْفَرٍ، حَدَّثَهُ عَنْ عُرْوَةَ بْنِ الزُّبَيْرِ، عَنْ عَائِشَةَ، أَنَّهَا قَالَتْ كَانَ النَّاسُ يَنْتَابُونَ الْجُمُعَةَ مِنْ مَنَازِلِهِمْ مِنَ الْعَوَالِي فَيَأْتُونَ فِي الْعَبَاءِ وَيُصِيبُهُمُ الْغُبَارُ فَتَخْرُجُ مِنْهُمُ الرِّيحُ فَأَتَى رَسُولَ اللَّهِ صلى الله عليه وسلم إِنْسَانٌ مِنْهُمْ وَهُوَ عِنْدِي فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ لَوْ أَنَّكُمْ تَطَهَّرْتُمْ لِيَوْمِكُمْ هَذَا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "The people came for Jumu'a prayer from their houses in the neighbouring villages dressed in woollen garments on which dust was settled and this emitted a foul smell. A person among them (those who were dressed so) came to the Messenger of Allah (ﷺ) while he was in my house. The Messenger of Allah (may peace he upon him) said to him: Were you to cleanse yourselves on this day.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "'Aisha reported:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1851", "arabic": "وَحَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، أَخْبَرَنَا اللَّيْثُ، عَنْ يَحْيَى بْنِ سَعِيدٍ، عَنْ عَمْرَةَ، عَنْ عَائِشَةَ، أَنَّهَا قَالَتْ كَانَ النَّاسُ أَهْلَ عَمَلٍ وَلَمْ يَكُنْ لَهُمْ كُفَاةٌ فَكَانُوا يَكُونُ لَهُمْ تَفَلٌ فَقِيلَ لَهُمْ لَوِ اغْتَسَلْتُمْ يَوْمَ الْجُمُعَةِ ‏.‏", "bengali": "", "english": "The people (mostly) were workers and they had no servants. Ill-smell thus emitted out of them. It was said to them: Were you to take bath on Friday.", "french": "", "indonesian": "", "russian": "", "urdu": "حضرت برید رضی اللہ تعالیٰ عنہ  سے روا یت ہے انھوں نے کہا :  رسول اللہ  صلی اللہ علیہ وسلم  نے فر ما", "grades": "", "reference": "", "international_number": "1851", "narrator_chain": "'Aisha reported:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1852", "arabic": "وَحَدَّثَنَا عَمْرُو بْنُ سَوَّادٍ الْعَامِرِيُّ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، أَخْبَرَنَا عَمْرُو بْنُ، الْحَارِثِ أَنَّ سَعِيدَ بْنَ أَبِي هِلاَلٍ، وَبُكَيْرَ بْنَ الأَشَجِّ، حَدَّثَاهُ عَنْ أَبِي بَكْرِ بْنِ الْمُنْكَدِرِ، عَنْ عَمْرِو، بْنِ سُلَيْمٍ عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِي سَعِيدٍ الْخُدْرِيِّ، عَنْ أَبِيهِ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ غُسْلُ يَوْمِ الْجُمُعَةِ عَلَى كُلِّ مُحْتَلِمٍ وَسِوَاكٌ وَيَمَسُّ مِنَ الطِّيبِ مَا قَدَرَ عَلَيْهِ ‏\"\"‏ ‏.‏ إِلاَّ أَنَّ بُكَيْرًا لَمْ يَذْكُرْ عَبْدَ الرَّحْمَنِ وَقَالَ فِي الطِّيبِ وَلَوْ مِنْ طِيبِ الْمَرْأَةِ ‏.‏\"", "bengali": "", "english": "Bathing on Friday for every adult, using of Miswak and applying some perfume, that is available-these are essential. So far as the perfume is concerned, it may be that used by a lady.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "'Abd al-Rahman son of Abd Sa'id al-Khudri reported on the authority of his father that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1853", "arabic": "حَدَّثَنَا حَسَنٌ الْحُلْوَانِيُّ، حَدَّثَنَا رَوْحُ بْنُ عُبَادَةَ، حَدَّثَنَا ابْنُ جُرَيْجٍ، ح وَحَدَّثَنِي مُحَمَّدُ، بْنُ رَافِعٍ حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَخْبَرَنَا ابْنُ جُرَيْجٍ، أَخْبَرَنِي إِبْرَاهِيمُ بْنُ مَيْسَرَةَ، عَنْ طَاوُسٍ، عَنِ ابْنِ عَبَّاسٍ، أَنَّهُ ذَكَرَ قَوْلَ النَّبِيِّ صلى الله عليه وسلم فِي الْغُسْلِ يَوْمَ الْجُمُعَةِ ‏.‏ قَالَ طَاوُسٌ فَقُلْتُ لاِبْنِ عَبَّاسٍ وَيَمَسُّ طِيبًا أَوْ دُهْنًا إِنْ كَانَ عِنْدَ أَهْلِهِ قَالَ لاَ أَعْلَمُهُ ‏.‏", "bengali": "", "english": "I asked Ibn Abbas it one should apply to oneself perfume or oil which is available with his wife. He (Ibn Abbas) said: I do not know of it.", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن ادریس اور وکیع نے شعبہ  سے اور انھوں نے معاویہ بن قرہ سے روایت کی ، انھوں نے کہا : میں نے", "grades": "", "reference": "", "international_number": "1853", "narrator_chain": "Tawus reported that Ibn Abbas narrated the words of the Messenger of Allah (ﷺ) about taking bath on Friday. Tawus said:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1854", "arabic": "وَحَدَّثَنَاهُ إِسْحَاقُ بْنُ إِبْرَاهِيمَ، أَخْبَرَنَا مُحَمَّدُ بْنُ بَكْرٍ، ح وَحَدَّثَنَا هَارُونُ بْنُ عَبْدِ، اللَّهِ حَدَّثَنَا الضَّحَّاكُ بْنُ مَخْلَدٍ، كِلاَهُمَا عَنِ ابْنِ جُرَيْجٍ، بِهَذَا الإِسْنَادِ ‏.‏", "bengali": "", "english": "This hadith has been narrated by Ibn Juraij with the came chain of transmitters.", "french": "", "indonesian": "", "russian": "", "urdu": "محمد بن جعفر نے کہا : شعبہ نے ہمیں معاویہ بن قرہ سے حدیث بیان کی ، انھوں نے کہا : میں نے حضرت عبدالل", "grades": "", "reference": "", "international_number": "1854", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1855", "arabic": "وَحَدَّثَنِي مُحَمَّدُ بْنُ حَاتِمٍ، حَدَّثَنَا بَهْزٌ، حَدَّثَنَا وُهَيْبٌ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ طَاوُسٍ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ حَقٌّ لِلَّهِ عَلَى كُلِّ مُسْلِمٍ أَنْ يَغْتَسِلَ فِي كُلِّ سَبْعَةِ أَيَّامٍ يَغْسِلُ رَأْسَهُ وَجَسَدَهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "Abu Huraira reported that the Messenger of Allah (ﷺ) said. it is the right of Allah upon every Muslim that he should take a bath (at least) on one day (Friday) during the seven days (of the week) and he should wash his head and body.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1856", "arabic": "وَحَدَّثَنَا قُتَيْبَةُ بْنُ سَعِيدٍ، عَنْ مَالِكِ بْنِ أَنَسٍ، فِيمَا قُرِئَ عَلَيْهِ عَنْ سُمَىٍّ، مَوْلَى أَبِي بَكْرٍ عَنْ أَبِي صَالِحٍ السَّمَّانِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ مَنِ اغْتَسَلَ يَوْمَ الْجُمُعَةِ غُسْلَ الْجَنَابَةِ ثُمَّ رَاحَ فَكَأَنَّمَا قَرَّبَ بَدَنَةً وَمَنْ رَاحَ فِي السَّاعَةِ الثَّانِيَةِ فَكَأَنَّمَا قَرَّبَ بَقَرَةً وَمَنْ رَاحَ فِي السَّاعَةِ الثَّالِثَةِ فَكَأَنَّمَا قَرَّبَ كَبْشًا أَقْرَنَ وَمَنْ رَاحَ فِي السَّاعَةِ الرَّابِعَةِ فَكَأَنَّمَا قَرَّبَ دَجَاجَةً وَمَنْ رَاحَ فِي السَّاعَةِ الْخَامِسَةِ فَكَأَنَّمَا قَرَّبَ بَيْضَةً فَإِذَا خَرَجَ الإِمَامُ حَضَرَتِ الْمَلاَئِكَةُ يَسْتَمِعُونَ الذِّكْرَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "Abu Huraira reported that the Messenger of, Allah (ﷺ) said. He who takes a bath on Friday, the bath which is obligatory after the sexual discharge and then goes (to the mosque), he is like one who offers a she-camel as a sacrifice, and he who comes at the second hour would be like one who offers a cow, and he who comes at the third hour is live one who offers a ram with horns, and he who comes at the fourth hour is like one who offers a hen, and he who comes at the fifth hour is like one who offers an egg. And when the Imam comes out, the angels are also present and listen to the mention of God (the sermon).", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1857", "arabic": "وَحَدَّثَنَا قُتَيْبَةُ بْنُ سَعِيدٍ، وَمُحَمَّدُ بْنُ رُمْحِ بْنِ الْمُهَاجِرِ، قَالَ ابْنُ رُمْحٍ أَخْبَرَنَا اللَّيْثُ، عَنْ عُقَيْلٍ، عَنِ ابْنِ شِهَابٍ، أَخْبَرَنِي سَعِيدُ بْنُ الْمُسَيَّبِ، أَنَّ أَبَا هُرَيْرَةَ، أَخْبَرَهُ أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ إِذَا قُلْتَ لِصَاحِبِكَ أَنْصِتْ ‏.‏ يَوْمَ الْجُمُعَةِ وَالإِمَامُ يَخْطُبُ فَقَدْ لَغَوْتَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "If you (even) ask your companion to be quiet on Friday while the Imam is delivering the sermon, you have in fact talked irrelevance.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1858", "arabic": "وَحَدَّثَنِي عَبْدُ الْمَلِكِ بْنُ شُعَيْبِ بْنِ اللَّيْثِ، حَدَّثَنِي أَبِي، عَنْ جَدِّي، حَدَّثَنِي عُقَيْلُ بْنُ، خَالِدٍ عَنِ ابْنِ شِهَابٍ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِيزِ، عَنْ عَبْدِ اللَّهِ بْنِ إِبْرَاهِيمَ بْنِ قَارِظٍ، وَعَنِ ابْنِ الْمُسَيَّبِ، أَنَّهُمَا حَدَّثَاهُ أَنَّ أَبَا هُرَيْرَةَ قَالَ سَمِعْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم يَقُولُ ‏.‏ بِمِثْلِهِ ‏.‏", "bengali": "", "english": "A hadith like this has been narrated by Abu Huraira by another chain of transmitters.", "french": "", "indonesian": "", "russian": "", "urdu": "عبد الرحمٰن بن مہدی اور داؤد نے کہا  :  ہمیں شعبہ نے ابو اسحاق سے حدیث بیان کی انھوں نے کہا :  میں ن", "grades": "", "reference": "", "international_number": "1858", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1859", "arabic": "وَحَدَّثَنِيهِ مُحَمَّدُ بْنُ حَاتِمٍ، حَدَّثَنَا مُحَمَّدُ بْنُ بَكْرٍ، أَخْبَرَنَا ابْنُ جُرَيْجٍ، أَخْبَرَنِي ابْنُ، شِهَابٍ بِالإِسْنَادَيْنِ جَمِيعًا فِي هَذَا الْحَدِيثِ ‏.‏ مِثْلَهُ غَيْرَ أَنَّ ابْنَ جُرَيْجٍ قَالَ إِبْرَاهِيمُ بْنُ عَبْدِ اللَّهِ بْنِ قَارِظٍ ‏.‏", "bengali": "", "english": "\"Ibrahim bin 'Abdullah bin Qariz.\"", "french": "", "indonesian": "", "russian": "", "urdu": "حضرت ابو سعید خدری  رضی اللہ تعالیٰ عنہ  نے حدیث بیان کی کہ حجرت اسید بن حضیر رضی اللہ تعالیٰ عنہ  ا", "grades": "", "reference": "", "international_number": "1859", "narrator_chain": "Ibn Juraij narrated a similar Hadith (as no. 1965) from Ibn Shihab with both chains, except that Ibn Juraij said:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1860", "arabic": "وَحَدَّثَنَا ابْنُ أَبِي عُمَرَ، حَدَّثَنَا سُفْيَانُ، عَنْ أَبِي الزِّنَادِ، عَنِ الأَعْرَجِ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ إِذَا قُلْتَ لِصَاحِبِكَ أَنْصِتْ ‏.‏ يَوْمَ الْجُمُعَةِ وَالإِمَامُ يَخْطُبُ فَقَدْ لَغِيتَ ‏\"\"‏ ‏.‏ قَالَ أَبُو الزِّنَادِ هِيَ لُغَةُ أَبِي هُرَيْرَةَ وَإِنَّمَا هُوَ فَقَدْ لَغَوْتَ ‏.‏\"", "bengali": "", "english": "The same hadith has been narrated by Abu Huraira, but instead of the word laghauta the word laghita has been used. Abu Zinad (one of the narrators) says that laghita is the dialect of Abu Huraira, whereas it is laghauta.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1861", "arabic": "وَحَدَّثَنَا يَحْيَى بْنُ يَحْيَى، قَالَ قَرَأْتُ عَلَى مَالِكٍ ح وَحَدَّثَنَا قُتَيْبَةُ بْنُ سَعِيدٍ، عَنْ مَالِكِ بْنِ أَنَسٍ، عَنْ أَبِي الزِّنَادِ، عَنِ الأَعْرَجِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم ذَكَرَ يَوْمَ الْجُمُعَةِ فَقَالَ ‏ ‏ فِيهِ سَاعَةٌ لاَ يُوَافِقُهَا عَبْدٌ مُسْلِمٌ وَهُوَ يُصَلِّي يَسْأَلُ اللَّهَ شَيْئًا إِلاَّ أَعْطَاهُ إِيَّاهُ ‏\"\"‏ ‏.‏ زَادَ قُتَيْبَةُ فِي رِوَايَتِهِ وَأَشَارَ بِيَدِهِ يُقَلِّلُهَا.\"", "bengali": "", "english": "There is a time on Friday at which no Muslim servant would pray and would ask Allah for a thing (that is good) but He would give it to him. Qutaiba pointed with the help of his hand that it (the time) is short.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1862", "arabic": "حَدَّثَنَا زُهَيْرُ بْنُ حَرْبٍ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ إِبْرَاهِيمَ، حَدَّثَنَا أَيُّوبُ، عَنْ مُحَمَّدٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ أَبُو الْقَاسِمِ صلى الله عليه وسلم ‏ ‏ إِنَّ فِي الْجُمُعَةِ لَسَاعَةً لاَ يُوَافِقُهَا مُسْلِمٌ قَائِمٌ يُصَلِّي يَسْأَلُ اللَّهَ خَيْرًا إِلاَّ أَعْطَاهُ إِيَّاهُ.\"\" وَقَالَ بِيَدِهِ يُقَلِّلُهَا يُزَهِّدُهَا.\"", "bengali": "", "english": "There is a time on Friday at which no Muslim would stand and pray and beg Allah for what Is good but He would give it to him; and he pointed with his hand that (this time) is short and narrow.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira reported Abu'l-Qasim (the kunya of the Holy Prophet) (ﷺ) as saying:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1863", "arabic": "حَدَّثَنَا ابْنُ الْمُثَنَّى، حَدَّثَنَا ابْنُ أَبِي عَدِيٍّ، عَنِ ابْنِ عَوْنٍ، عَنْ مُحَمَّدٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ أَبُو الْقَاسِمِ صلى الله عليه وسلم بِمِثْلِهِ ‏.‏", "bengali": "", "english": "A hadith like this has been narrated by Abu Huraira.", "french": "", "indonesian": "", "russian": "", "urdu": "ابن ابی عدی نے سعید سے روایت کی ، وکیع نے ہشام دستوائی سے روایت کی ، ان دونوں نے قتادہ سے اسی سند کے", "grades": "", "reference": "", "international_number": "1863", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1864", "arabic": "وَحَدَّثَنِي حُمَيْدُ بْنُ مَسْعَدَةَ الْبَاهِلِيُّ، حَدَّثَنَا بِشْرٌ، - يَعْنِي ابْنَ مُفَضَّلٍ - حَدَّثَنَا سَلَمَةُ، وَهُوَ ابْنُ عَلْقَمَةَ عَنْ مُحَمَّدٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ أَبُو الْقَاسِمِ صلى الله عليه وسلم ‏بِمِثْلِهِ ‏.‏", "bengali": "", "english": "This hadith has been narrated by Abu Huraira by another chain of transmitters.", "french": "", "indonesian": "", "russian": "", "urdu": "ہمام نےکہا : ہم سے  قتادہ نے حضرت انس بن مالک  رضی اللہ تعالیٰ عنہ  سے حدیث بیان کی کہ رسول اللہ  صل", "grades": "", "reference": "", "international_number": "1864", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1865", "arabic": "وَحَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ سَلاَّمٍ الْجُمَحِيُّ، حَدَّثَنَا الرَّبِيعُ، - يَعْنِي ابْنَ مُسْلِمٍ - عَنْ مُحَمَّدِ بْنِ زِيَادٍ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم أَنَّهُ قَالَ ‏ ‏ إِنَّ فِي الْجُمُعَةِ لَسَاعَةً لا يُوَافِقُهَا مُسْلِمٌ يَسْأَلُ اللَّهَ فِيهَا خَيْرًا إِلاَّ أَعْطَاهُ إِيَّاهُ ‏\"\"‏ ‏.‏ قَالَ وَهِيَ سَاعَةٌ خَفِيفَةٌ\"", "bengali": "", "english": "\"There is a time on Friday at which no Muslim would ask Allah for what is good but He would give it to him.\" And further said: \"This is a very short time.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira reported Allah's Apostle (ﷺ) as saying:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1866", "arabic": "وَحَدَّثَنَاهُ مُحَمَّدُ بْنُ رَافِعٍ، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، حَدَّثَنَا مَعْمَرٌ، عَنْ هَمَّامِ بْنِ مُنَبِّهٍ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم ‏.‏ وَلَمْ يَقُلْ وَهِيَ سَاعَةٌ خَفِيفَةٌ ‏.‏", "bengali": "", "english": "\" That time is short.\"", "french": "", "indonesian": "", "russian": "", "urdu": "خالد بن حارث نے کہا : شعبہ نے ہمیں قتادہ کے حوالے سے حدیث بیان کی ، انھوں نے کہا : میں نے حضرت انس", "grades": "", "reference": "", "international_number": "1866", "narrator_chain": "Hammam b. Munabbih reported this hadith from Abu Huraira who reported from the Messenger of Allah (ﷺ) but he did not say:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1867", "arabic": "وَحَدَّثَنِي أَبُو الطَّاهِرِ، وَعَلِيُّ بْنُ خَشْرَمٍ، قَالاَ أَخْبَرَنَا ابْنُ وَهْبٍ، عَنْ مَخْرَمَةَ بْنِ، بُكَيْرٍ ح وَحَدَّثَنَا هَارُونُ بْنُ سَعِيدٍ الأَيْلِيُّ، وَأَحْمَدُ بْنُ عِيسَى، قَالاَ حَدَّثَنَا ابْنُ وَهْبٍ، أَخْبَرَنَا مَخْرَمَةُ، عَنْ أَبِيهِ، عَنْ أَبِي بُرْدَةَ بْنِ أَبِي مُوسَى الأَشْعَرِيِّ، قَالَ قَالَ لِي عَبْدُ اللَّهِ بْنُ عُمَرَ أَسَمِعْتَ أَبَاكَ يُحَدِّثُ عَنْ رَسُولِ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ فِي شَأْنِ سَاعَةِ الْجُمُعَةِ قَالَ: قُلْتُ نَعَمْ سَمِعْتُهُ يَقُولُ سَمِعْتُ رَسُولَ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ يَقُولُ: «هِيَ مَا بَيْنَ أَنْ يَجْلِسَ الإِمَامُ إِلَى أَنْ تُقْضَى الصَّلاَةُ».", "bengali": "", "english": "'Abdullah b. Umar said to me: Did you hear anything from your father narrating something from the messenger of Allah (ﷺ) about the time on Friday? I said: Yes, I heard him say from the Messenger of Allah (ﷺ) (these words):\" It is between the time when the Imam sits down and the end of the prayer.\"", "french": "", "indonesian": "", "russian": "", "urdu": "حفص بن غیاث نے اعمش سے روایت کی ، انھوں نے ابراہیم سے ، انھوں  عبیدہ  ( سلمانی )  سےاور انھوں نے عبد", "grades": "", "reference": "", "international_number": "1867", "narrator_chain": "Abu Burda b. Abu Musa al-Ash'ari reported:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1868", "arabic": "وَحَدَّثَنِي حَرْمَلَةُ بْنُ يَحْيَى، أَخْبَرَنَا ابْنُ وَهْبٍ، أَخْبَرَنِي يُونُسُ، عَنِ ابْنِ شِهَابٍ، أَخْبَرَنِي عَبْدُ الرَّحْمَنِ الأَعْرَجُ، أَنَّهُ سَمِعَ أَبَا هُرَيْرَةَ، يَقُولُ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ خَيْرُ يَوْمٍ طَلَعَتْ عَلَيْهِ الشَّمْسُ يَوْمُ الْجُمُعَةِ فِيهِ خُلِقَ آدَمُ وَفِيهِ أُدْخِلَ الْجَنَّةَ وَفِيهِ أُخْرِجَ مِنْهَا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "The best day on which the sun has risen is Friday; on it Adam was created, on it he was made to enter Paradise, on it he. was expelled from it.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1869", "arabic": "وَحَدَّثَنَا قُتَيْبَةُ بْنُ سَعِيدٍ، حَدَّثَنَا الْمُغِيرَةُ، - يَعْنِي الْحِزَامِيَّ - عَنْ أَبِي الزِّنَادِ، عَنِ الأَعْرَجِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ النَّبِيَّ صلى الله عليه وسلم قَالَ ‏ ‏ خَيْرُ يَوْمٍ طَلَعَتْ عَلَيْهِ الشَّمْسُ يَوْمُ الْجُمُعَةِ فِيهِ خُلِقَ آدَمُ وَفِيهِ أُدْخِلَ الْجَنَّةَ وَفِيهِ أُخْرِجَ مِنْهَا وَلاَ تَقُومُ السَّاعَةُ إِلاَّ فِي يَوْمِ الْجُمُعَةِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "The best day on which the sun has risen is Friday; on it Adam was created. on it he was made to enter Paradise, on it he was expelled from it. And the last hour will take place on no day other than Friday.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira reported the Messenger of Allah (ﷺ) as saying:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1870", "arabic": "وَحَدَّثَنَا عَمْرٌو النَّاقِدُ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ أَبِي الزِّنَادِ، عَنِ الأَعْرَجِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ نَحْنُ الآخِرُونَ وَنَحْنُ السَّابِقُونَ يَوْمَ الْقِيَامَةِ بَيْدَ أَنَّ كُلَّ أُمَّةٍ أُوتِيَتِ الْكِتَابَ مِنْ قَبْلِنَا وَأُوتِينَاهُ مِنْ بَعْدِهِمْ ثُمَّ هَذَا الْيَوْمُ الَّذِي كَتَبَهُ اللَّهُ عَلَيْنَا هَدَانَا اللَّهُ لَهُ فَالنَّاسُ لَنَا فِيهِ تَبَعٌ الْيَهُودُ غَدًا وَالنَّصَارَى بَعْدَ غَدٍ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "We who are the last shall be the first on the Day of Resurrection, except that every Ummah was given the Book before us and we were given it after them. It was this day which Allah prescribed for us and guided us to it and the people came after us with regard to it, the Jews observing the next day and the Christians the day following that.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1871", "arabic": "وَحَدَّثَنَا ابْنُ أَبِي عُمَرَ، حَدَّثَنَا سُفْيَانُ، عَنْ أَبِي الزِّنَادِ، عَنِ الأَعْرَجِ، عَنْ أَبِي هُرَيْرَةَ، وَابْنِ طَاوُسٍ عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ نَحْنُ الآخِرُونَ وَنَحْنُ السَّابِقُونَ يَوْمَ الْقِيَامَةِ ‏\"\"‏ ‏.‏ بِمِثْلِهِ ‏.‏\"", "bengali": "", "english": "We are the last and would be the first on the Day of Resurrection.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "A hadith like this has been narrated by Abu Huraira that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1872", "arabic": "وَحَدَّثَنَا قُتَيْبَةُ بْنُ سَعِيدٍ، وَزُهَيْرُ بْنُ حَرْبٍ، قَالاَ حَدَّثَنَا جَرِيرٌ، عَنِ الأَعْمَشِ، عَنْ أَبِي صَالِحٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ نَحْنُ الآخِرُونَ الأَوَّلُونَ يَوْمَ الْقِيَامَةِ وَنَحْنُ أَوَّلُ مَنْ يَدْخُلُ الْجَنَّةَ بَيْدَ أَنَّهُمْ أُوتُوا الْكِتَابَ مِنْ قَبْلِنَا وَأُوتِينَاهُ مِنْ بَعْدِهِمْ فَاخْتَلَفُوا فَهَدَانَا اللَّهُ لِمَا اخْتَلَفُوا فِيهِ مِنَ الْحَقِّ فَهَذَا يَوْمُهُمُ الَّذِي اخْتَلَفُوا فِيهِ هَدَانَا اللَّهُ لَهُ - قَالَ يَوْمُ الْجُمُعَةِ - فَالْيَوْمُ لَنَا وَغَدًا لِلْيَهُودِ وَبَعْدَ غَدٍ لِلنَّصَارَى ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "We are the last (but) we would be the first on the Day of Resurrection, and we would be the first to enter Paradise, but that they were given the Book before us and we were given after them. They disagreed and Allah guided us aright on whatever they disagreed regarding the truth. And it was this day of theirs about which they disagreed, but Allah guided us to it, and that is Friday for us; the next day is for the Jews and the day following for the Christians.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1873", "arabic": "وَحَدَّثَنَا مُحَمَّدُ بْنُ رَافِعٍ، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَخْبَرَنَا مَعْمَرٌ، عَنْ هَمَّامِ بْنِ مُنَبِّهٍ، أَخِي وَهْبِ بْنِ مُنَبِّهٍ قَالَ هَذَا مَا حَدَّثَنَا أَبُو هُرَيْرَةَ، عَنْ مُحَمَّدٍ، رَسُولِ اللَّهِ صلى الله عليه وسلم قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ نَحْنُ الآخِرُونَ السَّابِقُونَ يَوْمَ الْقِيَامَةِ بَيْدَ أَنَّهُمْ أُوتُوا الْكِتَابَ مِنْ قَبْلِنَا وَأُوتِينَاهُ مِنْ بَعْدِهِمْ وَهَذَا يَوْمُهُمُ الَّذِي فُرِضَ عَلَيْهِمْ فَاخْتَلَفُوا فِيهِ فَهَدَانَا اللَّهُ لَهُ فَهُمْ لَنَا فِيهِ تَبَعٌ فَالْيَهُودُ غَدًا وَالنَّصَارَى بَعْدَ غَدٍ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "We who are the last would be the first on the Day of Resurrection but they (other Ummahs) were given the Book before us and we were given after them, and this was the day that was prescribed for them but they disagreed on it. And Allah guided us to it. and they came after us with regard to it, the Jews observing the next day and the Christians the day following that.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira reported Muhammad, the Messenger of Allah (ﷺ), as saying:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1874", "arabic": "وَحَدَّثَنَا أَبُو كُرَيْبٍ، وَوَاصِلُ بْنُ عَبْدِ الأَعْلَى، قَالاَ حَدَّثَنَا ابْنُ فُضَيْلٍ، عَنْ أَبِي مَالِكٍ، الأَشْجَعِيِّ عَنْ أَبِي حَازِمٍ، عَنْ أَبِي هُرَيْرَةَ، وَعَنْ رِبْعِيِّ بْنِ حِرَاشٍ، عَنْ حُذَيْفَةَ، قَالاَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ أَضَلَّ اللَّهُ عَنِ الْجُمُعَةِ مَنْ كَانَ قَبْلَنَا فَكَانَ لِلْيَهُودِ يَوْمُ السَّبْتِ وَكَانَ لِلنَّصَارَى يَوْمُ الأَحَدِ فَجَاءَ اللَّهُ بِنَا فَهَدَانَا اللَّهُ لِيَوْمِ الْجُمُعَةِ فَجَعَلَ الْجُمُعَةَ وَالسَّبْتَ وَالأَحَدَ وَكَذَلِكَ هُمْ تَبَعٌ لَنَا يَوْمَ الْقِيَامَةِ نَحْنُ الآخِرُونَ مِنْ أَهْلِ الدُّنْيَا وَالأَوَّلُونَ يَوْمَ الْقِيَامَةِ الْمَقْضِيُّ لَهُمْ قَبْلَ الْخَلاَئِقِ ‏\"\"‏ ‏.‏ وَفِي رِوَايَةِ وَاصِلٍ الْمَقْضِيُّ بَيْنَهُمْ ‏.‏\"", "bengali": "", "english": "It was Friday from which Allah diverted those who were before us. For the Jews (the day set aside for prayer) was Sabt (Saturday), and for the Christians it was Sunday. And Allah turned towards us and guided us to Friday (as the day of prayer) for us. In fact, He (Allah) made Friday, Saturday and Sunday (as days of prayer). In this order would they (Jews and Christians) come after us on the Day of Resurrection. We are the last of (the Ummahs) among the people in this world and the first among the created to be judged on the Day of Resurrection. In one narration it is: ', to be judged among them\".", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It is narrated by Abu Huraira and Huraira that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1875", "arabic": "حَدَّثَنَا أَبُو كُرَيْبٍ، أَخْبَرَنَا ابْنُ أَبِي زَائِدَةَ، عَنْ سَعْدِ بْنِ طَارِقٍ، حَدَّثَنِي رِبْعِيُّ بْنُ، حِرَاشٍ عَنْ حُذَيْفَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ هُدِينَا إِلَى الْجُمُعَةِ وَأَضَلَّ اللَّهُ عَنْهَا مَنْ كَانَ قَبْلَنَا ‏\"\"‏ ‏.‏ فَذَكَرَ بِمَعْنَى حَدِيثِ ابْنِ فُضَيْلٍ ‏.‏\"", "bengali": "", "english": "We were guided aright to Friday (as a day of prayer and meditation), but Allah diverted those who were before us from it. The rest of the hadith is the same.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Huraira reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1876", "arabic": "وَحَدَّثَنِي أَبُو الطَّاهِرِ، وَحَرْمَلَةُ، وَعَمْرُو بْنُ سَوَّادٍ الْعَامِرِيُّ، قَالَ أَبُو الطَّاهِرِ حَدَّثَنَا وَقَالَ الآخَرَانِ، أَخْبَرَنَا ابْنُ وَهْبٍ، أَخْبَرَنِي يُونُسُ، عَنِ ابْنِ شِهَابٍ، أَخْبَرَنِي أَبُو عَبْدِ اللَّهِ، الأَغَرُّ أَنَّهُ سَمِعَ أَبَا هُرَيْرَةَ، يَقُولُ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ إِذَا كَانَ يَوْمُ الْجُمُعَةِ كَانَ عَلَى كُلِّ بَابٍ مِنْ أَبْوَابِ الْمَسْجِدِ مَلاَئِكَةٌ يَكْتُبُونَ الأَوَّلَ فَالأَوَّلَ فَإِذَا جَلَسَ الإِمَامُ طَوَوُا الصُّحُفَ وَجَاءُوا يَسْتَمِعُونَ الذِّكْرَ وَمَثَلُ الْمُهَجِّرِ كَمَثَلِ الَّذِي يُهْدِي الْبَدَنَةَ ثُمَّ كَالَّذِي يُهْدِي بَقَرَةً ثُمَّ كَالَّذِي يُهْدِي الْكَبْشَ ثُمَّ كَالَّذِي يُهْدِي الدَّجَاجَةَ ثُمَّ كَالَّذِي يُهْدِي الْبَيْضَةَ».", "bengali": "", "english": "When it is Friday, the angels stand at every door of the mosque and record the people in the order of their arrival, and when the Imam sits (on the pulpit for delivering the sermon) they fold up their sheets (manuscripts of the Qur'an) and listen to the mention (of Allah). And he who comes early is like one who offers a she-camel as a sacrifice, the next like one who offers a cow, the next a ram, the next a hen, the next an egg.", "french": "", "indonesian": "", "russian": "", "urdu": "حضرت نواس بن سمعان کلابی  رضی اللہ تعالیٰ عنہ  کہتے ہیں کہ میں نے رسول اللہ  صلی اللہ علیہ وسلم  کو", "grades": "", "reference": "", "international_number": "1876", "narrator_chain": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1877", "arabic": "حَدَّثَنَا يَحْيَى بْنُ يَحْيَى، وَعَمْرٌو النَّاقِدُ، عَنْ سُفْيَانَ، عَنِ الزُّهْرِيِّ، عَنْ سَعِيدٍ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم بِمِثْلِهِ ‏.‏", "bengali": "", "english": "This hadith has been narrated by Abu Huraira through another chain of transmitters.", "french": "", "indonesian": "", "russian": "", "urdu": "حضرت ابن عباس  رضی اللہ تعالیٰ عنہ  سےروایت ہے کہ جبرئیل علیہ السلام نبی اکرم  صلی اللہ علیہ وسلم  ک", "grades": "", "reference": "", "international_number": "1877", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1878", "arabic": "وَحَدَّثَنَا قُتَيْبَةُ بْنُ سَعِيدٍ، حَدَّثَنَا يَعْقُوبُ، - يَعْنِي ابْنَ عَبْدِ الرَّحْمَنِ - عَنْ سُهَيْلٍ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ عَلَى كُلِّ بَابٍ مِنْ أَبْوَابِ الْمَسْجِدِ مَلَكٌ يَكْتُبُ الأَوَّلَ فَالأَوَّلَ - مَثَّلَ الْجَزُورَ ثُمَّ نَزَّلَهُمْ حَتَّى صَغَّرَ إِلَى مَثَلِ الْبَيْضَةِ - فَإِذَا جَلَسَ الإِمَامُ طُوِيَتِ الصُّحُفُ وَحَضَرُوا الذِّكْرَ ‏\"\"‏ ‏.\"", "bengali": "", "english": "There is an angel on every door of the mosque recording him first who (comes) first (to the mosque for Friday prayer). And he  likened him to one who offers a camel as a sacrifice and then he went on in the descending order till he reached the point at which the minimum (sacrifice) is that of an egg. And when the Imam sits (on the pulpit) the sheets are folded and they (the angels) attend to the mention of Allah.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1879", "arabic": "حَدَّثَنَا أُمَيَّةُ بْنُ بِسْطَامٍ، حَدَّثَنَا يَزِيدُ، - يَعْنِي ابْنَ زُرَيْعٍ - حَدَّثَنَا رَوْحٌ، عَنْ سُهَيْلٍ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ مَنِ اغْتَسَلَ ثُمَّ أَتَى الْجُمُعَةَ فَصَلَّى مَا قُدِّرَ لَهُ ثُمَّ أَنْصَتَ حَتَّى يَفْرُغَ مِنْ خُطْبَتِهِ ثُمَّ يُصَلِّيَ مَعَهُ غُفِرَ لَهُ مَا بَيْنَهُ وَبَيْنَ الْجُمُعَةِ الأُخْرَى وَفَضْلَ ثَلاَثَةِ أَيَّامٍ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "He who took a bath and then came for Jumu'a prayer and then prayed what was fixed for him, then kept silence till the Imam finished the sermon, and then prayed along with him, his sins between that time and the next Friday would be forgiven, and even of three days more.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu-Huraira reported Allah's Apostle (ﷺ) as saying:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1880", "arabic": "وَحَدَّثَنَا يَحْيَى بْنُ يَحْيَى، وَأَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ وَأَبُو كُرَيْبٍ قَالَ يَحْيَى أَخْبَرَنَا وَقَالَ الآخَرَانِ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، عَنِ الأَعْمَشِ، عَنْ أَبِي صَالِحٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنْ تَوَضَّأَ فَأَحْسَنَ الْوُضُوءَ ثُمَّ أَتَى الْجُمُعَةَ فَاسْتَمَعَ وَأَنْصَتَ غُفِرَ لَهُ مَا بَيْنَهُ وَبَيْنَ الْجُمُعَةِ وَزِيَادَةُ ثَلاَثَةِ أَيَّامٍ وَمَنْ مَسَّ الْحَصَى فَقَدْ لَغَا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "He who performed ablution well, then came to Friday prayer, listened (to the sermon), kept silence all (his sins) between that time and the next Friday would be forgiven with three days extra, and he who touched pebbles caused an interruption.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1881", "arabic": "وَحَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَإِسْحَاقُ بْنُ إِبْرَاهِيمَ، قَالَ أَبُو بَكْرٍ حَدَّثَنَا يَحْيَى، بْنُ آدَمَ حَدَّثَنَا حَسَنُ بْنُ عَيَّاشٍ، عَنْ جَعْفَرِ بْنِ مُحَمَّدٍ، عَنْ أَبِيهِ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، قَالَ كُنَّا نُصَلِّي مَعَ رَسُولِ اللَّهِ صلى الله عليه وسلم ثُمَّ نَرْجِعُ فَنُرِيحُ نَوَاضِحَنَا ‏.‏ قَالَ حَسَنٌ فَقُلْتُ لِجَعْفَرٍ فِي أَىِّ سَاعَةٍ تِلْكَ قَالَ زَوَالَ الشَّمْسِ ‏.‏", "bengali": "", "english": "We used to observe (Jumu'a) prayer with the Messenger of Allah (ﷺ) and then we returned and gave rest to our camels used for carrying water. Hassan[ (one of the narrators) said: I asked Ja'far what time that was. He said.. It is the time when the sun passes the meridian.", "french": "", "indonesian": "", "russian": "", "urdu": "عیسیٰ بن یونس اور عبداللہ بن نمیر نے اعمش سے باقی ماندہ اسی سند کےساتھ اسی کے مانند روایت بیان کی ۔", "grades": "", "reference": "", "international_number": "1881", "narrator_chain": "Jabir b. 'Abdullah reported:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1882", "arabic": "وَحَدَّثَنِي الْقَاسِمُ بْنُ زَكَرِيَّاءَ، حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ، ح وَحَدَّثَنِي عَبْدُ اللَّهِ بْنُ عَبْدِ، الرَّحْمَنِ الدَّارِمِيُّ حَدَّثَنَا يَحْيَى بْنُ حَسَّانَ، قَالاَ جَمِيعًا حَدَّثَنَا سُلَيْمَانُ بْنُ بِلاَلٍ، عَنْ جَعْفَرٍ، عَنْ أَبِيهِ، أَنَّهُ سَأَلَ جَابِرَ بْنَ عَبْدِ اللَّهِ مَتَى كَانَ رَسُولُ اللَّهِ صلى الله عليه وسلم يُصَلِّي الْجُمُعَةَ قَالَ كَانَ يُصَلِّي ثُمَّ نَذْهَبُ إِلَى جِمَالِنَا فَنُرِيحُهَا ‏.‏ زَادَ عَبْدُ اللَّهِ فِي حَدِيثِهِ حِينَ تَزُولُ الشَّمْسُ يَعْنِي النَّوَاضِحَ ‏.‏", "bengali": "", "english": "that he asked Jabir b. 'Abdullah when the Messenger of Allah (ﷺ) observed Jumu'a prayer. He said: He used to observe prayer, and we then went (back) to our camels and gave them rest. 'Abdullah made this addition in his narration: \"Till the sun passed the meridian. and the camels used for carrying water (took rest).\"", "french": "", "indonesian": "", "russian": "", "urdu": "حفص اور ابو معاویہ نے بھی اعمش سے باقی ماندہ سابقہ سند کے ساتھ اسی کے مانند ر وایت بیان کی ہے ۔", "grades": "", "reference": "", "international_number": "1882", "narrator_chain": "Ja'far reported on the authority of his father:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1883", "arabic": "وَحَدَّثَنَا عَبْدُ اللَّهِ بْنُ مَسْلَمَةَ بْنِ قَعْنَبٍ، وَيَحْيَى بْنُ يَحْيَى، وَعَلِيُّ بْنُ حُجْرٍ، قَالَ يَحْيَى أَخْبَرَنَا وَقَالَ الآخَرَانِ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ أَبِي حَازِمٍ، عَنْ أَبِيهِ، عَنْ سَهْلٍ، قَالَ مَا كُنَّا نَقِيلُ وَلاَ نَتَغَدَّى إِلاَّ بَعْدَ الْجُمُعَةِ - زَادَ ابْنُ حُجْرٍ - فِي عَهْدِ رَسُولِ اللَّهِ صلى الله عليه وسلم ‏.‏", "bengali": "", "english": "We did not have a siesta or lunch till after the Friday prayer. (Ibn Hajr added: ) \"During the lifetime of the Messenger of Allah (ﷺ).\"", "french": "", "indonesian": "", "russian": "", "urdu": "معاذ بن ہشام نے اپنے والد سے حدیث بیان کی ، انھوں نے قتادہ سے ، انھوں نے سالم بن ابی جعد غطفانی سے ،", "grades": "", "reference": "", "international_number": "1883", "narrator_chain": "Sahl b. Said said:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1884", "arabic": "وَحَدَّثَنَا يَحْيَى بْنُ يَحْيَى، وَإِسْحَاقُ بْنُ إِبْرَاهِيمَ، قَالاَ أَخْبَرَنَا وَكِيعٌ، عَنْ يَعْلَى بْنِ، الْحَارِثِ الْمُحَارِبِيِّ عَنْ إِيَاسِ بْنِ سَلَمَةَ بْنِ الأَكْوَعِ، عَنْ أَبِيهِ، قَالَ كُنَّا نُجَمِّعُ مَعَ رَسُولِ اللَّهِ صلى الله عليه وسلم إِذَا زَالَتِ الشَّمْسُ ثُمَّ نَرْجِعُ نَتَتَبَّعُ الْفَىْءَ ‏.‏", "bengali": "", "english": "We used to observe the Friday prayer with the Messenger of Allah (ﷺ) when the sun passed the meridian. and we then returned and tried to find out afternoon shadow (of the walls for protecting themselves from the heat of the sun).", "french": "", "indonesian": "", "russian": "", "urdu": "شعبہ اور ہمام نے قتادہ سے اسی سند کے ساتھ روایت کی ۔ اس میں شعبہ نے سورہ کہف کی آخری  ( دس ) آیات کہ", "grades": "", "reference": "", "international_number": "1884", "narrator_chain": "Iyas b. Salama b. al-Akwa' reported on the authority of his father:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1885", "arabic": "وَحَدَّثَنَا إِسْحَاقُ بْنُ إِبْرَاهِيمَ، أَخْبَرَنَا هِشَامُ بْنُ عَبْدِ الْمَلِكِ، حَدَّثَنَا يَعْلَى بْنُ الْحَارِثِ، عَنْ إِيَاسِ بْنِ سَلَمَةَ بْنِ الأَكْوَعِ، عَنْ أَبِيهِ، قَالَ كُنَّا نُصَلِّي مَعَ رَسُولِ اللَّهِ صلى الله عليه وسلم الْجُمُعَةَ فَنَرْجِعُ وَمَا نَجِدُ لِلْحِيطَانِ فَيْئًا نَسْتَظِلُّ بِهِ ‏.‏", "bengali": "", "english": "We used to observe the Friday prayer with the Messenger of Allah (ﷺ), and when we returned we did not find the shadow of the walls in which we could take protection (from the heat of the sun).", "french": "", "indonesian": "", "russian": "", "urdu": "حضرت ابی بن کعب  رضی اللہ تعالیٰ عنہ  سے روایت ہے ، انھوں نے کہا : رسول اللہ  صلی اللہ علیہ وسلم  نے", "grades": "", "reference": "", "international_number": "1885", "narrator_chain": "Iyas b. Salama b. Akwa' reported on the authority of his father, saying:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1886", "arabic": "وَحَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ عُمَرَ الْقَوَارِيرِيُّ، وَأَبُو كَامِلٍ الْجَحْدَرِيُّ جَمِيعًا عَنْ خَالِدٍ، - قَالَ أَبُو كَامِلٍ حَدَّثَنَا خَالِدُ بْنُ الْحَارِثِ، - حَدَّثَنَا عُبَيْدُ اللَّهِ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ كَانَ رَسُولُ اللَّهِ صلى الله عليه وسلم يَخْطُبُ يَوْمَ الْجُمُعَةِ قَائِمًا ثُمَّ يَجْلِسُ ثُمَّ يَقُومُ ‏.‏ قَالَ كَمَا يَفْعَلُونَ الْيَوْمَ ‏.‏", "bengali": "", "english": "Ibn 'Umar said that the Messenger of Allah (ﷺ) used to deliver the sermon on Friday while standing. He would then sit and then stand (for the second sermon) as they (the Muslims) do nowadays.", "french": "", "indonesian": "", "russian": "", "urdu": "شعبہ نے قتادہ سے ، انہوں نے سالم بن ابی جعد سے ، انہوں نے معدان بن ابی طلحہ سے  ، انھوں نے حضرت ابو", "grades": "", "reference": "", "international_number": "1886", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1887", "arabic": "وَحَدَّثَنَا يَحْيَى بْنُ يَحْيَى، وَحَسَنُ بْنُ الرَّبِيعِ، وَأَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ قَالَ يَحْيَى أَخْبَرَنَا وَقَالَ الآخَرَانِ، حَدَّثَنَا أَبُو الأَحْوَصِ، عَنْ سِمَاكٍ، عَنْ جَابِرِ بْنِ سَمُرَةَ، قَالَ كَانَتْ لِلنَّبِيِّ صلى الله عليه وسلم خُطْبَتَانِ يَجْلِسُ بَيْنَهُمَا يَقْرَأُ الْقُرْآنَ وَيُذَكِّرُ النَّاسَ ‏.‏", "bengali": "", "english": "The Apostle of Allah (ﷺ) gave two sermons between which he sat, recited the Qur'an and exhorted the people.", "french": "", "indonesian": "", "russian": "", "urdu": "سعید بن ابی عروبہ اور ابان عطار نے قتادہ سے اسی  سابقہ سند کے ساتھ روایت کی  ، ان دونوں   ( سعید اور", "grades": "", "reference": "", "international_number": "1887", "narrator_chain": "Jabir b. Samura said:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1888", "arabic": "وَحَدَّثَنَا يَحْيَى بْنُ يَحْيَى، أَخْبَرَنَا أَبُو خَيْثَمَةَ، عَنْ سِمَاكٍ، قَالَ أَنْبَأَنِي جَابِرُ بْنُ، سَمُرَةَ أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم كَانَ يَخْطُبُ قَائِمًا ثُمَّ يَجْلِسُ ثُمَّ يَقُومُ فَيَخْطُبُ قَائِمًا فَمَنْ نَبَّأَكَ أَنَّهُ كَانَ يَخْطُبُ جَالِسًا فَقَدْ كَذَبَ فَقَدْ وَاللَّهِ صَلَّيْتُ مَعَهُ أَكْثَرَ مِنْ أَلْفَىْ صَلاَةٍ.", "bengali": "", "english": "Jabir b. Samura said that the Messenger of Allah (ﷺ) used to deliver the sermon while standing. He would then sit down and then stand up and address in a standing posture; and whoever informed you that he (the Holy Prophet) delivered the sermon while sitting told a lie. By Allah. I prayed with him more than two thousand times.", "french": "", "indonesian": "", "russian": "", "urdu": "یزید بن کیسان نے کہا : ہمیں ابو حازم نے حضرت ابو ہریرۃ  رضی اللہ تعالیٰ عنہ  سے حدیث سنائی ، انھوں ن", "grades": "", "reference": "", "international_number": "1888", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1889", "arabic": "حَدَّثَنَا عُثْمَانُ بْنُ أَبِي شَيْبَةَ، وَإِسْحَاقُ بْنُ إِبْرَاهِيمَ، كِلاَهُمَا عَنْ جَرِيرٍ، - قَالَ عُثْمَانُ حَدَّثَنَا جَرِيرٌ، - عَنْ حُصَيْنِ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ سَالِمِ بْنِ أَبِي الْجَعْدِ، عَنْ جَابِرِ، بْنِ عَبْدِ اللَّهِ أَنَّ النَّبِيَّ صلى الله عليه وسلم كَانَ يَخْطُبُ قَائِمًا يَوْمَ الْجُمُعَةِ فَجَاءَتْ عِيرٌ مِنَ الشَّامِ فَانْفَتَلَ النَّاسُ إِلَيْهَا حَتَّى لَمْ يَبْقَ إِلاَّ اثْنَا عَشَرَ رَجُلاً فَأُنْزِلَتْ هَذِهِ الآيَةُ الَّتِي فِي الْجُمُعَةِ ‏{‏ وَإِذَا رَأَوْا تِجَارَةً أَوْ لَهْوًا انْفَضُّوا إِلَيْهَا وَتَرَكُوكَ قَائِمًا‏}‏", "bengali": "", "english": "Jabir b. Abdullah reported that the Apostle (ﷺ) was delivering the sermon on Friday in a standing posture when a caravan from Syria arrived. The people flocked towards it till no one was left (with the Holy Prophet) but twelve persons, and it was on this occasion that this verse in regard to Jumu'a was revealed.\" And when they see merchandise or sport. they break away to it and leave thee standing.\"", "french": "", "indonesian": "", "russian": "", "urdu": "ابواسماعیل بشیر نے ابو حازم سے اور انھوں نے حضرت ابو ہریرۃ  رضی اللہ تعالیٰ عنہ  سے روایت کی ، انھوں", "grades": "", "reference": "", "international_number": "1889", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1890", "arabic": "وَحَدَّثَنَاهُ أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ إِدْرِيسَ، عَنْ حُصَيْنٍ، بِهَذَا الإِسْنَادِ قَالَ وَرَسُولُ اللَّهِ صلى الله عليه وسلم يَخْطُبُ ‏.‏ وَلَمْ يَقُلْ قَائِمًا ‏.‏", "bengali": "", "english": "This hadith has been narrated by Husain with the same chain of transmitters but with this alteration that he did not make mention of the standing position.", "french": "", "indonesian": "", "russian": "", "urdu": "عمرہ بنت عبدالرحمان نے  ، اور وہ رسول اللہ  صلی اللہ علیہ وسلم  کی زوجہ حضرت عائشہ  رضی اللہ تعالیٰ", "grades": "", "reference": "", "international_number": "1890", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1891", "arabic": "وَحَدَّثَنَا رِفَاعَةُ بْنُ الْهَيْثَمِ الْوَاسِطِيُّ، حَدَّثَنَا خَالِدٌ، - يَعْنِي الطَّحَّانَ - عَنْ حُصَيْنٍ، عَنْ سَالِمٍ، وَأَبِي، سُفْيَانَ عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، قَالَ كُنَّا مَعَ النَّبِيِّ صلى الله عليه وسلم يَوْمَ الْجُمُعَةِ فَقَدِمَتْ سُوَيْقَةٌ قَالَ فَخَرَجَ النَّاسُ إِلَيْهَا فَلَمْ يَبْقَ إِلاَّ اثْنَا عَشَرَ رَجُلاً أَنَا فِيهِمْ - قَالَ - فَأَنْزَلَ اللَّهُ ‏{‏ وَإِذَا رَأَوْا تِجَارَةً أَوْ لَهْوًا انْفَضُّوا إِلَيْهَا وَتَرَكُوكَ قَائِمًا‏}‏ إِلَى آخِرِ الآيَةِ ‏.‏", "bengali": "", "english": "I was along with the Messenger of Allah (ﷺ) on Friday when a caravan arrived. The people went to it, and none but twelve persons were left behind and I was one of them; and it was on this occasion that this verse was revealed:\" And when they see merchandise or sport away to it, and leave thee standing\" (lxii. 1 1). they break", "french": "", "indonesian": "", "russian": "", "urdu": "بیان ( بن بشر ) نے قیس بن ابی حازم سے اور انھوں نے حضرت عقبہ بن عامر  رضی اللہ تعالیٰ عنہ  سے  روایت", "grades": "", "reference": "", "international_number": "1891", "narrator_chain": "Jabir b. Abdullah reported:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1892", "arabic": "وَحَدَّثَنَا إِسْمَاعِيلُ بْنُ سَالِمٍ، أَخْبَرَنَا هُشَيْمٌ، أَخْبَرَنَا حُصَيْنٌ، عَنْ أَبِي سُفْيَانَ، وَسَالِمِ، بْنِ أَبِي الْجَعْدِ عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، قَالَ بَيْنَا النَّبِيُّ صلى الله عليه وسلم قَائِمٌ يَوْمَ الْجُمُعَةِ إِذْ قَدِمَتْ عِيرٌ إِلَى الْمَدِينَةِ فَابْتَدَرَهَا أَصْحَابُ رَسُولِ اللَّهِ صلى الله عليه وسلم حَتَّى لَمْ يَبْقَ مَعَهُ إِلاَّ اثْنَا عَشَرَ رَجُلاً فِيهِمْ أَبُو بَكْرٍ وَعُمَرُ - قَالَ - وَنَزَلَتْ هَذِهِ الآيَةُ ‏{‏ وَإِذَا رَأَوْا تِجَارَةً أَوْ لَهْوًا انْفَضُّوا إِلَيْهَا‏}‏", "bengali": "", "english": "While the Messenger of Allah (ﷺ) was delivering (a sermon) on Friday, a caravan of merchandise came to Medina. The Companions of the Messenger of Allah (ﷺ) rushed towards it till only twelve persons were left with him including Abu Bakr and 'Umar; and it was at this occasion that this verse was revealed.\" And when they see merchandise or sport, they break away to it.\"", "french": "", "indonesian": "", "russian": "", "urdu": "محمد بن عبداللہ بن نمیر نے بیان کیا  ، کہا : میرے والد نے ہمیں حدیث بیان کی ، کہا :  مجھ سے اسماعیل", "grades": "", "reference": "", "international_number": "1892", "narrator_chain": "Jabir b. Abdullah reported:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1893", "arabic": "وَحَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، وَابْنُ، بَشَّارٍ قَالاَ حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، حَدَّثَنَا شُعْبَةُ، عَنْ مَنْصُورٍ، عَنْ عَمْرِو بْنِ مُرَّةَ، عَنْ أَبِي عُبَيْدَةَ، عَنْ كَعْبِ بْنِ عُجْرَةَ، قَالَ دَخَلَ الْمَسْجِدَ وَعَبْدُ الرَّحْمَنِ بْنُ أُمِّ الْحَكَمِ يَخْطُبُ قَاعِدًا فَقَالَ انْظُرُوا إِلَى هَذَا الْخَبِيثِ يَخْطُبُ قَاعِدًا وَقَالَ اللَّهُ تَعَالَى ‏{‏ وَإِذَا رَأَوْا تِجَارَةً أَوْ لَهْوًا انْفَضُّوا إِلَيْهَا وَتَرَكُوكَ قَائِمًا‏}‏", "bengali": "", "english": "Look at this wretched person; he delivers the sermon while sitting, whereas Allah said:\" And when they see merchandise or sport, they break away to it and leave thee standing.\"", "french": "", "indonesian": "", "russian": "", "urdu": "۔  وکیع اور ابو اسامہ نے اسماعیل سے اسی سند کے سات اسی طرح روایت بیان کی ، البتہ ابو اسامہ نے عقبہ ب", "grades": "", "reference": "", "international_number": "1893", "narrator_chain": "Ka'b b. 'Ujra reported that he entered the mosque and saw Abd al-Rahman b. Umm Hakam delivering the sermon in a sitting posture. Upon this he said:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1894", "arabic": "وَحَدَّثَنِي الْحَسَنُ بْنُ عَلِيٍّ الْحُلْوَانِيُّ، حَدَّثَنَا أَبُو تَوْبَةَ، حَدَّثَنَا مُعَاوِيَةُ، - وَهُوَ ابْنُ سَلاَّمٍ - عَنْ زَيْدٍ، - يَعْنِي أَخَاهُ - أَنَّهُ سَمِعَ أَبَا سَلاَّمٍ، قَالَ حَدَّثَنِي الْحَكَمُ بْنُ مِينَاءَ، أَنَّحَدَّثَاهُ أَنَّهُمَا، سَمِعَا رَسُولَ اللَّهِ صلى الله عليه وسلم يَقُولُ عَلَى أَعْوَادِ مِنْبَرِهِ ‏ ‏ لَيَنْتَهِيَنَّ أَقْوَامٌ عَنْ وَدْعِهِمُ الْجُمُعَاتِ أَوْ لَيَخْتِمَنَّ اللَّهُ عَلَى قُلُوبِهِمْ ثُمَّ لَيَكُونُنَّ مِنَ الْغَافِلِينَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "People must cease to neglect the Friday prayer or Allah will seal their hearts and then they will be among the negligent.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abdullah b. Umar and Abu Huraira said that they heard Allah's Messenger (ﷺ) say on the planks of his pulpit:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1895", "arabic": "حَدَّثَنَا حَسَنُ بْنُ الرَّبِيعِ، وَأَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ قَالاَ حَدَّثَنَا أَبُو الأَحْوَصِ، عَنْ سِمَاكٍ، عَنْ جَابِرِ بْنِ سَمُرَةَ، قَالَ كُنْتُ أُصَلِّي مَعَ رَسُولِ اللَّهِ صلى الله عليه وسلم فَكَانَتْ صَلاَتُهُ قَصْدًا وَخُطْبَتُهُ قَصْدًا ‏.‏", "bengali": "", "english": "I used to pray with the Messenger of Allah (ﷺ) and both his prayer and sermon were of moderate length.", "french": "", "indonesian": "", "russian": "", "urdu": "یونس نے ابن شہاب  ( زہری )  سے روایت کی  ، انھوں نے کہا :  مجھے سالم بن عبداللہ بن عمر  رضی اللہ تعا", "grades": "", "reference": "", "international_number": "1895", "narrator_chain": "Jabir b. Samura reported:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1896", "arabic": "وَحَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَابْنُ، نُمَيْرٍ قَالاَ حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ، حَدَّثَنَا زَكَرِيَّاءُ، حَدَّثَنِي سِمَاكُ بْنُ حَرْبٍ، عَنْ جَابِرِ بْنِ سَمُرَةَ، قَالَ كُنْتُ أُصَلِّي مَعَ النَّبِيِّ صلى الله عليه وسلم الصَّلَوَاتِ فَكَانَتْ صَلاَتُهُ قَصْدًا وَخُطْبَتُهُ قَصْدًا ‏.‏ وَفِي رِوَايَةِ أَبِي بَكْرٍ زَكَرِيَّاءُ عَنْ سِمَاكٍ.", "bengali": "", "english": "I used to observe prayer with the Messenger of Allah (ﷺ) and his prayer was of moderate length and his sermon too was of moderate length.", "french": "", "indonesian": "", "russian": "", "urdu": "حضرت عبداللہ بن مسعود  رضی اللہ تعالیٰ عنہ  کہتے ہیں کہ  رسول اللہ  صلی اللہ علیہ وسلم  نے فرمایا :", "grades": "", "reference": "", "international_number": "1896", "narrator_chain": "Jabir b. Samura reported:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1897", "arabic": "وَحَدَّثَنِي مُحَمَّدُ بْنُ الْمُثَنَّى، حَدَّثَنَا عَبْدُ الْوَهَّابِ بْنُ عَبْدِ الْمَجِيدِ، عَنْ جَعْفَرِ بْنِ مُحَمَّدٍ، عَنْ أَبِيهِ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، قَالَ كَانَ رَسُولُ اللَّهِ صلى الله عليه وسلم إِذَا خَطَبَ احْمَرَّتْ عَيْنَاهُ وَعَلاَ صَوْتُهُ وَاشْتَدَّ غَضَبُهُ حَتَّى كَأَنَّهُ مُنْذِرُ جَيْشٍ يَقُولُ ‏\"‏ صَبَّحَكُمْ وَمَسَّاكُمْ ‏\"‏ ‏.‏ وَيَقُولُ ‏\"‏ بُعِثْتُ أَنَا وَالسَّاعَةَ كَهَاتَيْنِ ‏\"‏ ‏.‏ وَيَقْرُنُ بَيْنَ إِصْبَعَيْهِ السَّبَّابَةِ وَالْوُسْطَى وَيَقُولُ ‏\"‏ أَمَّا بَعْدُ فَإِنَّ خَيْرَ الْحَدِيثِ كِتَابُ اللَّهِ وَخَيْرُ الْهُدَى هُدَى مُحَمَّدٍ وَشَرُّ الأُمُورِ مُحْدَثَاتُهَا وَكُلُّ بِدْعَةٍ ضَلاَلَةٌ ‏\"‏ ‏.‏ ثُمَّ يَقُولُ ‏\"‏ أَنَا أَوْلَى بِكُلِّ مُؤْمِنٍ مِنْ نَفْسِهِ مَنْ تَرَكَ مَالاً فَلأَهْلِهِ وَمَنْ تَرَكَ دَيْنًا أَوْ ضَيَاعًا فَإِلَىَّ وَعَلَىَّ ‏\"‏ ‏.‏", "bengali": "", "english": "When Allah's Messenger (may peace he upon him) delivered the sermon, his eyes became red, his voice rose, and his anger increased so that he was like one giving a warning against the enemy and saying: \"The enemy has made a morning attack on you and in the evening too.\" He would also say: \"The Last Hour and I have been sent like these two.\" And he would join his forefinger and middle finger; and would further say: \"The best of the speech is embodied in the Book of Allah, and the best of the guidance is the guidance given by Muhammad. And the most evil affairs are their innovations; and every innovation is error.\" He would further say:, I am more dear to a Muslim even than his self; and he who left behind property that is for his family; and he who dies under debt or leaves children (in helplessness), the responsibility (of paying his debt and bringing up his children) lies on me.\"", "french": "", "indonesian": "", "russian": "", "urdu": "ابراہیم بن سعد نے ابن شہاب  ( زہری )  سے اور انھوں نے عامر بن واثلہ سے  روایت کی کہ نافع بن عبدالحار", "grades": "", "reference": "", "international_number": "1897", "narrator_chain": "Jabir b. Abdullah said:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1898", "arabic": "وَحَدَّثَنَا عَبْدُ بْنُ حُمَيْدٍ، حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ، حَدَّثَنِي سُلَيْمَانُ بْنُ بِلاَلٍ، حَدَّثَنِي جَعْفَرُ، بْنُ مُحَمَّدٍ عَنْ أَبِيهِ، قَالَ سَمِعْتُ جَابِرَ بْنَ عَبْدِ اللَّهِ، يَقُولُ كَانَتْ خُطْبَةُ النَّبِيِّ صلى الله عليه وسلم يَوْمَ الْجُمُعَةِ يَحْمَدُ اللَّهَ وَيُثْنِي عَلَيْهِ ثُمَّ يَقُولُ عَلَى إِثْرِ ذَلِكَ وَقَدْ عَلاَ صَوْتُهُ ‏.‏ ثُمَّ سَاقَ الْحَدِيثَ بِمِثْلِهِ ‏.‏", "bengali": "", "english": "I heard Jabir b. 'Abdullah saying that in the sermon of the Messenger of Allah (ﷺ) he praised Allah, lauded Him (and subsequently said  and raised his voice, and the rest of the hadith is the same).", "french": "", "indonesian": "", "russian": "", "urdu": "شعیب نے زہری سے خبر دی ، انھوں نے کہا : مجھے عامر بن واثلہ  لیثی نے حدیث بیان کی کہ نافع بن عبدالحار", "grades": "", "reference": "", "international_number": "1898", "narrator_chain": "Ja'far b. Muhammad said on the authority of his father:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1899", "arabic": "وَحَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا وَكِيعٌ، عَنْ سُفْيَانَ، عَنْ جَعْفَرٍ، عَنْ أَبِيهِ، عَنْ جَابِرٍ، قَالَ كَانَ رَسُولُ اللَّهِ صلى الله عليه وسلم يَخْطُبُ النَّاسَ يَحْمَدُ اللَّهَ وَيُثْنِي عَلَيْهِ بِمَا هُوَ أَهْلُهُ ثُمَّ يَقُولُ ‏ ‏ مَنْ يَهْدِهِ اللَّهُ فَلاَ مُضِلَّ لَهُ وَمَنْ يُضْلِلْ فَلاَ هَادِيَ لَهُ وَخَيْرُ الْحَدِيثِ كِتَابُ اللَّهِ ‏\"\"‏ ‏.‏ ثُمَّ سَاقَ الْحَدِيثَ بِمِثْلِ حَدِيثِ الثَّقَفِيِّ ‏.‏\"", "bengali": "", "english": "He whom Allah guides aright, there is none to mislead him, and he who is led astray, there is none to guide him (aright), and the best of the talk is embodied in the Book of Allah. And the rest of the hadith is the same.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Jabir reported that the Messenger of Allah (ﷺ), while delivering the sermon' to the people, praised Allah, and lauded Him for what He deserves, and would then say:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1900", "arabic": "وَحَدَّثَنَا إِسْحَاقُ بْنُ إِبْرَاهِيمَ، وَمُحَمَّدُ بْنُ الْمُثَنَّى، كِلاَهُمَا عَنْ عَبْدِ الأَعْلَى، - قَالَ ابْنُ الْمُثَنَّى حَدَّثَنِي عَبْدُ الأَعْلَى، وَهُوَ أَبُو هَمَّامٍ - حَدَّثَنَا دَاوُدُ، عَنْ عَمْرِو بْنِ سَعِيدٍ، عَنْ سَعِيدِ بْنِ جُبَيْرٍ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ ضِمَادًا، قَدِمَ مَكَّةَ وَكَانَ مِنْ أَزْدِ شَنُوءَةَ وَكَانَ يَرْقِي مِنْ هَذِهِ الرِّيحِ فَسَمِعَ سُفَهَاءَ مِنْ أَهْلِ مَكَّةَ يَقُولُونَ إِنَّ مُحَمَّدًا مَجْنُونٌ ‏.‏ فَقَالَ لَوْ أَنِّي رَأَيْتُ هَذَا الرَّجُلَ لَعَلَّ اللَّهَ يَشْفِيهِ عَلَى يَدَىَّ - قَالَ - فَلَقِيَهُ فَقَالَ يَا مُحَمَّدُ إِنِّي أَرْقِي مِنْ هَذِهِ الرِّيحِ وَإِنَّ اللَّهَ يَشْفِي عَلَى يَدِي مَنْ شَاءَ فَهَلْ لَكَ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ إِنَّ الْحَمْدَ لِلَّهِ نَحْمَدُهُ وَنَسْتَعِينُهُ مَنْ يَهْدِهِ اللَّهُ فَلاَ مُضِلَّ لَهُ وَمَنْ يُضْلِلْ فَلاَ هَادِيَ لَهُ وَأَشْهَدُ أَنْ لاَ إِلَهَ إِلاَّ اللَّهُ وَحْدَهُ لاَ شَرِيكَ لَهُ وَأَنَّ مُحَمَّدًا عَبْدُهُ وَرَسُولُهُ أَمَّا بَعْدُ ‏\"‏ ‏.‏ قَالَ فَقَالَ أَعِدْ عَلَىَّ كَلِمَاتِكَ هَؤُلاَءِ ‏.‏ فَأَعَادَهُنَّ عَلَيْهِ رَسُولُ اللَّهِ صلى الله عليه وسلم ثَلاَثَ مَرَّاتٍ - قَالَ - فَقَالَ لَقَدْ سَمِعْتُ قَوْلَ الْكَهَنَةِ وَقَوْلَ السَّحَرَةِ وَقَوْلَ الشُّعَرَاءِ فَمَا سَمِعْتُ مِثْلَ كَلِمَاتِكَ هَؤُلاَءِ وَلَقَدْ بَلَغْنَ نَاعُوسَ الْبَحْرِ - قَالَ - فَقَالَ هَاتِ يَدَكَ أُبَايِعْكَ عَلَى الإِسْلاَمِ - قَالَ - فَبَايَعَهُ ‏.‏ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ وَعَلَى قَوْمِكَ ‏\"‏ ‏.‏ قَالَ وَعَلَى قَوْمِي - قَالَ - فَبَعَثَ رَسُولُ اللَّهِ صلى الله عليه وسلم سَرِيَّةً فَمَرُّوا بِقَوْمِهِ فَقَالَ صَاحِبُ السَّرِيَّةِ لِلْجَيْشِ هَلْ أَصَبْتُمْ مِنْ هَؤُلاَءِ شَيْئًا فَقَالَ رَجُلٌ مِنَ الْقَوْمِ أَصَبْتُ مِنْهُمْ مِطْهَرَةً ‏.‏ فَقَالَ رُدُّوهَا فَإِنَّ هَؤُلاَءِ قَوْمُ ضِمَادٍ ‏.‏", "bengali": "", "english": "Dimad came to Mecca and he belonged to the tribe of Azd Shanu'a, and he used to protect the person who was under the influence of charm. He heard the foolish people of Mecca say that Muhammad (ﷺ) was under the spell. Upon this he said: If I were to come across this man, Allah might cure him at my hand. He met him and said: Muhammad, I can protect (one) who is under the influence of charm, and Allah cures one whom He so desires at my hand. Do you desire (this)? Upon this the Messenger of Allah (ﷺ) said: Praise is due to Allah, we praise Him, ask His help; and he whom Allah guides aright there is none to lead him astray, and he who is led astray there is none to guide him, and I bear testimony to the fact that there is no god but Allah, He is One, having no partner with Him, and that Muhammad is His Servant and Messenger. Now after this he (Dimad) said: Repeat these words of yours before me, and the messenger of Allah (ﷺ) repeated these to him thrice; and he said I have heard the words of soothsayers and the words of magicians, and the words of poets, but I have never heard such words as yours, and they reach the depth (of the ocean of eloquence) ; bring forth your hand so that I should take oath of fealty to you on Islam. So he took an oath of allegiance to him. The Messenger of Allah (ﷺ) said: It (this allegiance of yours) is on behalf of your people too. He said: It is on behalf of my people too. The Messenger of Allah (ﷺ) sent an expedition and the flying column passed by his people. The leader of the flying column said to the detachment: Did you find anything from these people? One of the people said: I found a utensil for water. Upon this he (the commander) said: Return it, for he is one of the people of Dimad.", "french": "", "indonesian": "", "russian": "", "urdu": "یونس نے ابن شہاب سے  روایت کی ، انھوں نے کہا : مجھے عروہ بن زبیر نے بتایا کہ مسود بن مخرمہ اور عبدال", "grades": "", "reference": "", "international_number": "1900", "narrator_chain": "Ibn 'Abbas reported:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1901", "arabic": "حَدَّثَنِي سُرَيْجُ بْنُ يُونُسَ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ عَبْدِ الْمَلِكِ بْنِ أَبْجَرَ، عَنْ أَبِيهِ، عَنْ وَاصِلِ بْنِ حَيَّانَ، قَالَ قَالَ أَبُو وَائِلٍ خَطَبَنَا عَمَّارٌ فَأَوْجَزَ وَأَبْلَغَ فَلَمَّا نَزَلَ قُلْنَا يَا أَبَا الْيَقْظَانِ لَقَدْ أَبْلَغْتَ وَأَوْجَزْتَ فَلَوْ كُنْتَ تَنَفَّسْتَ ‏.‏ فَقَالَ إِنِّي سَمِعْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم يَقُولُ ‏ ‏ إِنَّ طُولَ صَلاَةِ الرَّجُلِ وَقِصَرَ خُطْبَتِهِ مَئِنَّةٌ مِنْ فِقْهِهِ فَأَطِيلُوا الصَّلاَةَ وَاقْصُرُوا الْخُطْبَةَ وَإِنَّ مِنَ الْبَيَانِ سِحْرًا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "'Ammar delivered to us the sermon. It was short and eloquent. When he (, Ammir) descended (from the pulpit) we said to him: 0 Abd al-Yaqzn, you have delivered a short and eloquent sermon. Would that you had lengthened (the sermon). He said: I have heard the Messenger of Allah (ﷺ) as saying: The lengthening of prayer by a man and the shortness of the sermon is the sign of his understanding (of faith). So lengthen the prayer and shorten the sermon, for there is charm (in precise) expression.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Wa'il reported:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1902", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَمُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، قَالاَ حَدَّثَنَا وَكِيعٌ، عَنْ سُفْيَانَ، عَنْ عَبْدِ الْعَزِيزِ بْنِ رُفَيْعٍ، عَنْ تَمِيمِ بْنِ طَرَفَةَ، عَنْ عَدِيِّ بْنِ حَاتِمٍ، أَنَّ رَجُلاً، خَطَبَ عِنْدَ النَّبِيِّ صلى الله عليه وسلم فَقَالَ مَنْ يُطِعِ اللَّهَ وَرَسُولَهُ فَقَدْ رَشِدَ وَمَنْ يَعْصِهِمَا فَقَدْ غَوَى ‏.‏ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ بِئْسَ الْخَطِيبُ أَنْتَ ‏.‏ قُلْ وَمَنْ يَعْصِ اللَّهَ وَرَسُولَهُ ‏\"\"‏ ‏.‏ قَالَ ابْنُ نُمَيْرٍ فَقَدْ غَوِيَ ‏.‏\"", "bengali": "", "english": "that a person recited a sermon before the Messenger of Allah (ﷺ) thus: He who obeys Allah and His Apostle, he in fact follows the right path, and he who disobeys both of them, he goes astray. Upon this the Messenger of Allah (ﷺ) said: What a bad speaker you are; say: He who disobeys Allah and His Apostle. Ibn Numair added: He in fact went astray.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "'Adi b. Hatim reported:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1903", "arabic": "حَدَّثَنَا قُتَيْبَةُ بْنُ سَعِيدٍ، وَأَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ وَإِسْحَاقُ الْحَنْظَلِيُّ جَمِيعًا عَنِ ابْنِ عُيَيْنَةَ، - قَالَ قُتَيْبَةُ حَدَّثَنَا سُفْيَانُ، - عَنْ عَمْرٍو، سَمِعَ عَطَاءً، يُخْبِرُ عَنْ صَفْوَانَ بْنِ، يَعْلَى عَنْ أَبِيهِ، أَنَّهُ سَمِعَ النَّبِيَّ صلى الله عليه وسلم يَقْرَأُ عَلَى الْمِنْبَرِ ‏{‏ وَنَادَوْا يَا مَالِكُ‏}‏", "bengali": "", "english": "0 Malik.\"", "french": "", "indonesian": "", "russian": "", "urdu": "ہمیں معمر نے زہری سے اسی سند کے ساتھ خبر دی ۔", "grades": "", "reference": "", "international_number": "1903", "narrator_chain": "Safwan b. Ya'la reported on the authority of his father that he heard the Messenger of Allah (ﷺ) reciting (verses of the Qur'an) on the pulpit. and\" They cried:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1904", "arabic": "وَحَدَّثَنِي عَبْدُ اللَّهِ بْنُ عَبْدِ الرَّحْمَنِ الدَّارِمِيُّ، أَخْبَرَنَا يَحْيَى بْنُ حَسَّانَ، حَدَّثَنَا سُلَيْمَانُ، بْنُ بِلاَلٍ عَنْ يَحْيَى بْنِ سَعِيدٍ، عَنْ عَمْرَةَ بِنْتِ عَبْدِ الرَّحْمَنِ، عَنْ أُخْتٍ، لِعَمْرَةَ قَالَتْ أَخَذْتُ ‏{‏ ق وَالْقُرْآنِ الْمَجِيدِ‏}‏ مِنْ فِي رَسُولِ اللَّهِ صلى الله عليه وسلم يَوْمَ الْجُمُعَةِ وَهُوَ يَقْرَأُ بِهَا عَلَى الْمِنْبَرِ فِي كُلِّ جُمُعَةٍ ‏.‏", "bengali": "", "english": "I memorised (surah) \"Qaf, by the glorious Qur'an\" from the mouth of the Messenger of Allah (ﷺ) on Friday for he recited it on the pulpit on every Friday.", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن نمیر نے کہا : اسماعیل بن ابی خالد نے ہمیں حدیث بیان کی ، انھوں نے عبداللہ بن عیسیٰ بن عبد", "grades": "", "reference": "", "international_number": "1904", "narrator_chain": "'Amra daughter of Abd al-Rahman reported on the authority of the sister of Amra:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1905", "arabic": "وَحَدَّثَنِيهِ أَبُو الطَّاهِرِ، أَخْبَرَنَا ابْنُ وَهْبٍ، عَنْ يَحْيَى بْنِ أَيُّوبَ، عَنْ يَحْيَى بْنِ سَعِيدٍ، عَنْ عَمْرَةَ، عَنْ أُخْتٍ، لِعَمْرَةَ بِنْتِ عَبْدِ الرَّحْمَنِ كَانَتْ أَكْبَرَ مِنْهَا ‏.‏ بِمِثْلِ حَدِيثِ سُلَيْمَانَ بْنِ بِلاَلٍ ‏.‏", "bengali": "", "english": "I did not memorise (Surah) Qaf but from the mouth of the Messenger of Allah (ﷺ) as he used to deliver the. sermon along with it on every Friday. She also added: Our oven and that of the Messenger of Allah (ﷺ) was one.", "french": "", "indonesian": "", "russian": "", "urdu": "محمد بن بشر نے اسماعیل بن ابی خالد سے اسی سند کے ساتھ روایت کی کہ حضرت ابی ابن کعب  رضی اللہ تعالیٰ", "grades": "", "reference": "", "international_number": "1905", "narrator_chain": "The daughter of Haritha b. Nu'man said:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1906", "arabic": "حَدَّثَنِي مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، حَدَّثَنَا شُعْبَةُ، عَنْ خُبَيْبٍ، عَنْ عَبْدِ، اللَّهِ بْنِ مُحَمَّدِ بْنِ مَعْنٍ عَنْ بِنْتٍ لِحَارِثَةَ بْنِ النُّعْمَانِ، قَالَتْ مَا حَفِظْتُ ‏{‏ ق‏}‏ إِلاَّ مِنْ فِي رَسُولِ اللَّهِ صلى الله عليه وسلم يَخْطُبُ بِهَا كُلَّ جُمُعَةٍ ‏.‏ قَالَتْ وَكَانَ تَنُّورُنَا وَتَنُّورُ رَسُولِ اللَّهِ صلى الله عليه وسلم وَاحِدًا ‏.‏", "bengali": "", "english": "Our oven and that of the Messenger of Allah (ﷺ) was one for two years, or for one year or for a part of a year; and I learnt\" Qaf. By the Glorious Qur'an\" from no other source than the tongue of Allah's Messenger (ﷺ) who used to recite it every Friday on the pulpit when he delivered the sermon to the people.", "french": "", "indonesian": "", "russian": "", "urdu": "محمد بن جعفر غندر نے شعبہ سے روایت کی ، انھوں نے حکم سے ، انھوں نے مجاہد سے  ، انھوں نے ابن ابی لیلی", "grades": "", "reference": "", "international_number": "1906", "narrator_chain": "Umm Bisham hint Haritha b. Nu'man said:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1907", "arabic": "وَحَدَّثَنَا عَمْرٌو النَّاقِدُ، حَدَّثَنَا يَعْقُوبُ بْنُ إِبْرَاهِيمَ بْنِ سَعْدٍ، حَدَّثَنَا أَبِي، عَنْ مُحَمَّدِ، بْنِ إِسْحَاقَ قَالَ حَدَّثَنِي عَبْدُ اللَّهِ بْنُ أَبِي بَكْرِ بْنِ مُحَمَّدِ بْنِ عَمْرِو بْنِ حَزْمٍ الأَنْصَارِيُّ، عَنْ يَحْيَى بْنِ عَبْدِ اللَّهِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ سَعْدِ بْنِ زُرَارَةَ، عَنْ أُمِّ هِشَامٍ بِنْتِ حَارِثَةَ بْنِ النُّعْمَانِ، قَالَتْ لَقَدْ كَانَ تَنُّورُنَا وَتَنُّورُ رَسُولِ اللَّهِ صلى الله عليه وسلم وَاحِدًا سَنَتَيْنِ أَوْ سَنَةً وَبَعْضَ سَنَةٍ وَمَا أَخَذْتُ ‏{‏ ق وَالْقُرْآنِ الْمَجِيدِ‏}‏ إِلاَّ عَنْ لِسَانِ رَسُولِ اللَّهِ صلى الله عليه وسلم يَقْرَؤُهَا كُلَّ يَوْمِ جُمُعَةٍ عَلَى الْمِنْبَرِ إِذَا خَطَبَ النَّاسَ ‏.‏", "bengali": "", "english": "\"Our oven and the oven of the Messenger of Allah (ﷺ) were the same for two years, or for one year and part of a year. And I only learned \"Surah Qaf. By the Glorious Quran\" from the tongue of the Messenger of Allah (ﷺ), who used to recited it every Friday from the Minbar, when he addresses the people.\"", "french": "", "indonesian": "", "russian": "", "urdu": "معاذ عنبری نےشعبہ  سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی ۔", "grades": "", "reference": "", "international_number": "1907", "narrator_chain": "It was narrated that Umm Hisham bin Harithah bin An-Nu'man said:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1908", "arabic": "وَحَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ إِدْرِيسَ، عَنْ حُصَيْنٍ، عَنْ عُمَارَةَ، بْنِ رُؤَيْبَةَ قَالَ رَأَى بِشْرَ بْنَ مَرْوَانَ عَلَى الْمِنْبَرِ رَافِعًا يَدَيْهِ فَقَالَ قَبَّحَ اللَّهُ هَاتَيْنِ الْيَدَيْنِ لَقَدْ رَأَيْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم مَا يَزِيدُ عَلَى أَنْ يَقُولَ بِيَدِهِ هَكَذَا ‏.‏ وَأَشَارَ بِإِصْبَعِهِ الْمُسَبِّحَةِ ‏.‏", "bengali": "", "english": "Allah, disfigure these hands! I have seen Allah's Messenger (ﷺ) gesture no more than this with his hands, and he pointed with his forefinger.", "french": "", "indonesian": "", "russian": "", "urdu": "ابو بکر بن ابی شیبہ اور ابن نمیر نے وکیع سے  ، انھوں نے اعمش سے اور انھوں نے ابو وائل سے روایت کی ،", "grades": "", "reference": "", "international_number": "1908", "narrator_chain": "Umara b. Ruwaiba said he saw Bishr b. Marwan on the pulpit raising his hands and said:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1909", "arabic": "وَحَدَّثَنَاهُ قُتَيْبَةُ بْنُ سَعِيدٍ، حَدَّثَنَا أَبُو عَوَانَةَ، عَنْ حُصَيْنِ بْنِ عَبْدِ الرَّحْمَنِ، قَالَ رَأَيْتُ بِشْرَ بْنَ مَرْوَانَ يَوْمَ جُمُعَةٍ يَرْفَعُ يَدَيْهِ ‏.‏ فَقَالَ عُمَارَةُ بْنُ رُؤَيْبَةَ ‏.‏ فَذَكَرَ نَحْوَهُ ‏.‏", "bengali": "", "english": "This hadith has been narrated by another chain of transmitters on the authority of Husain b. Abd al-Rahman.", "french": "", "indonesian": "", "russian": "", "urdu": "ابو معاویہ نے اعمش سے  ، انھوں نے ابو وائل سے روایت کی ، انھوں نے کہا : حضرت عبداللہ کے پاس ایک آدمی", "grades": "", "reference": "", "international_number": "1909", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1910", "arabic": "وَحَدَّثَنَا أَبُو الرَّبِيعِ الزَّهْرَانِيُّ، وَقُتَيْبَةُ بْنُ سَعِيدٍ، قَالاَ حَدَّثَنَا حَمَّادٌ، - وَ هُوَ ابْنُ زَيْدٍ - عَنْ عَمْرِو بْنِ دِينَارٍ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، قَالَ بَيْنَا النَّبِيُّ صلى الله عليه وسلم يَخْطُبُ يَوْمَ الْجُمُعَةِ إِذْ جَاءَ رَجُلٌ فَقَالَ لَهُ النَّبِيُّ صلى الله عليه وسلم ‏\"‏ أَصَلَّيْتَ يَا فُلاَنُ \"‏ ‏.‏ قَالَ لاَ ‏.‏ قَالَ ‏\"‏ قُمْ فَارْكَعْ ‏\"‏ ‏.‏", "bengali": "", "english": "So and so, have you prayed (two rak'ahs)? He said: No. He (the Holy Prophet) said: Then stand and pray.", "french": "", "indonesian": "", "russian": "", "urdu": "عیسیٰ بن یونس نے کہا : اعمش نے ہم سے اپنی اسی سند کے ساتھ ان دونوں  ( وکیع اور ابو معاویہ )  کی حدیث", "grades": "", "reference": "", "international_number": "1910", "narrator_chain": "Jabir b. 'Abdullah reported that while Allah's Messenger (ﷺ) was delivering the sermon on Friday a person came there, and the Messenger of Allah (ﷺ) said to him:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1911", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَيَعْقُوبُ الدَّوْرَقِيُّ، عَنِ ابْنِ عُلَيَّةَ، عَنْ أَيُّوبَ، عَنْ عَمْرٍو، عَنْ جَابِرٍ، عَنِ النَّبِيِّ صلى الله عليه وسلم كَمَا قَالَ حَمَّادٌ وَلَمْ يَذْكُرِ الرَّكْعَتَيْنِ ‏.‏", "bengali": "", "english": "This hadith is narrated by Jabir through another chain of transmitters but Hammad (one of the narrators) made no mention of the two rak'ahs.", "french": "", "indonesian": "", "russian": "", "urdu": "مہدی بن میمون نے کہا :  واصل حدب نے ہمیں ابو وائل سے حدیث بیان کی ، انھوں نے کہا :  ایک دن ہم صبح کی", "grades": "", "reference": "", "international_number": "1911", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1912", "arabic": "وَحَدَّثَنَا قُتَيْبَةُ بْنُ سَعِيدٍ، وَإِسْحَاقُ بْنُ إِبْرَاهِيمَ، قَالَ قُتَيْبَةُ حَدَّثَنَا وَقَالَ، إِسْحَاقُ أَخْبَرَنَا سُفْيَانُ، عَنْ عَمْرٍو، سَمِعَ جَابِرَ بْنَ عَبْدِ اللَّهِ، يَقُولُ دَخَلَ رَجُلٌ الْمَسْجِدَ وَرَسُولُ اللَّهِ صلى الله عليه وسلم يَخْطُبُ يَوْمَ الْجُمُعَةِ فَقَالَ ‏\"‏ أَصَلَّيْتَ ‏\"‏ ‏.‏ قَالَ لاَ ‏.‏ قَالَ ‏\"‏ قُمْ فَصَلِّ الرَّكْعَتَيْنِ ‏\"‏ ‏.‏ وَفِي رِوَايَةِ قُتَيْبَةَ قَالَ ‏\"‏ صَلِّ رَكْعَتَيْنِ ‏\"‏ ‏.‏", "bengali": "", "english": "Have you observed prayer? He said: No. He (the Holy Prophet) said: Stand and offer the two rak'ahs. According to Qutaiba, the words are:\" He said: Offer two rak'ahs.\"", "french": "", "indonesian": "", "russian": "", "urdu": "منصور نے ( ابووائل )  شقیق سے روایت کی ، انھوں نے کہا : بنو بجیلہ میں سے ایک آدمی جسے نہیک بن سنان ک", "grades": "", "reference": "", "international_number": "1912", "narrator_chain": "Jabir b. 'Abdullah said that a person entered the Mosque while the Messenger of Allah (ﷺ) was delivering the sermon on Friday. Upon this he (the Holy Prophet) said:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1913", "arabic": "وَحَدَّثَنِي مُحَمَّدُ بْنُ رَافِعٍ، وَعَبْدُ بْنُ حُمَيْدٍ، قَالَ ابْنُ رَافِعٍ حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَخْبَرَنَا ابْنُ جُرَيْجٍ، أَخْبَرَنِي عَمْرُو بْنُ دِينَارٍ، أَنَّهُ سَمِعَ جَابِرَ بْنَ عَبْدِ اللَّهِ، يَقُولُ جَاءَ رَجُلٌ وَالنَّبِيُّ صلى الله عليه وسلم عَلَى الْمِنْبَرِ يَوْمَ الْجُمُعَةِ يَخْطُبُ فَقَالَ لَهُ ‏ ‏ أَرَكَعْتَ رَكْعَتَيْنِ ‏\"\"‏ ‏.‏ قَالَ لاَ. فَقَالَ: «ارْكَعْ».\"", "bengali": "", "english": "Have you offered two rak'ahs? He said: No. Upon this he said: Then observe (them).", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Jabir b. 'Abdullah reported that a person came (in the Mosque) while the Messenger of Allah (ﷺ) was delivering the sermon on Friday (standing) on the pulpit. He (the Holy Prophet) said to him:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1914", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُحَمَّدٌ، - وَهُوَ ابْنُ جَعْفَرٍ - حَدَّثَنَا شُعْبَةُ، عَنْ عَمْرٍو، قَالَ سَمِعْتُ جَابِرَ بْنَ عَبْدِ اللَّهِ، أَنَّ النَّبِيَّ صلى الله عليه وسلم خَطَبَ فَقَالَ ‏ ‏ إِذَا جَاءَ أَحَدُكُمْ يَوْمَ الْجُمُعَةِ وَقَدْ خَرَجَ الإِمَامُ فَلْيُصَلِّ رَكْعَتَيْنِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "When any one of you comes for the Friday (prayer) and the Imam comes out (from his apartment), (even then) should observe two rak'ahs (of prayer).", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Jabir b. 'Abdullah said that the Messenger of Allah (ﷺ) delivered the sermon and said:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1915", "arabic": "وَحَدَّثَنَا قُتَيْبَةُ بْنُ سَعِيدٍ، حَدَّثَنَا لَيْثٌ، ح وَحَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، أَخْبَرَنَا اللَّيْثُ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، أَنَّهُ قَالَ جَاءَ سُلَيْكٌ الْغَطَفَانِيُّ يَوْمَ الْجُمُعَةِ وَرَسُولُ اللَّهِ صلى الله عليه وسلم قَاعِدٌ عَلَى الْمِنْبَرِ فَقَعَدَ سُلَيْكٌ قَبْلَ أَنْ يُصَلِّيَ فَقَالَ لَهُ النَّبِيُّ صلى الله عليه وسلم ‏\"‏ أَرَكَعْتَ رَكْعَتَيْنِ ‏\"‏ ‏.‏ قَالَ لاَ ‏.‏ قَالَ ‏\"‏ قُمْ فَارْكَعْهُمَا ‏\"‏ ‏.‏", "bengali": "", "english": "Have you observed two rak'ahs? He said: No. He (the Holy Prophet) said: Stand and observe them", "french": "", "indonesian": "", "russian": "", "urdu": "شعبہ نے ابو اسحاق سے انھوں نے اسود سے انھوں نے حضرت عبد اللہ بن مسعود رضی اللہ تعالیٰ عنہ  سے اور ان", "grades": "", "reference": "", "international_number": "1915", "narrator_chain": "Jabir reported that Sulaik Ghatafani came on Friday (for prayer) while the Messenger of Allah (ﷺ) was sitting on the pulpit. Sulaik also sat down before observing prayer. The Apostle of Allah (ﷺ) said:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1916", "arabic": "وَحَدَّثَنَا إِسْحَاقُ بْنُ إِبْرَاهِيمَ، وَعَلِيُّ بْنُ خَشْرَمٍ، كِلاَهُمَا عَنْ عِيسَى بْنِ يُونُسَ، - قَالَ ابْنُ خَشْرَمٍ أَخْبَرَنَا عِيسَى، - عَنِ الأَعْمَشِ، عَنْ أَبِي سُفْيَانَ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، قَالَ جَاءَ سُلَيْكٌ الْغَطَفَانِيُّ يَوْمَ الْجُمُعَةِ وَرَسُولُ اللَّهِ صلى الله عليه وسلم يَخْطُبُ فَجَلَسَ فَقَالَ لَهُ ‏ ‏ يَا سُلَيْكُ قُمْ فَارْكَعْ رَكْعَتَيْنِ وَتَجَوَّزْ فِيهِمَا - ثُمَّ قَالَ - إِذَا جَاءَ أَحَدُكُمْ يَوْمَ الْجُمُعَةِ وَالإِمَامُ يَخْطُبُ فَلْيَرْكَعْ رَكْعَتَيْنِ وَلْيَتَجَوَّزْ فِيهِمَا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "Sulaik Ghatafani came on Friday when the Messenger of Allah (ﷺ) was delivering the sermon. He (Sulaik) sat down. He (the Holy Prophet) said to him: 0 Sulaik I stand and observe two rak'ahs and make them short, and then said: When any one of you comes on Friday, while the Imam delivers the sermon, he should observe two rak'ahs and should make them short.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Jabir b. 'Abdullah reported:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1917", "arabic": "وَحَدَّثَنَا شَيْبَانُ بْنُ فَرُّوخَ، حَدَّثَنَا سُلَيْمَانُ بْنُ الْمُغِيرَةِ، حَدَّثَنَا حُمَيْدُ بْنُ هِلاَلٍ، قَالَ قَالَ أَبُو رِفَاعَةَ انْتَهَيْتُ إِلَى النَّبِيِّ صلى الله عليه وسلم وَهُوَ يَخْطُبُ قَالَ فَقُلْتُ يَا رَسُولَ اللَّهِ رَجُلٌ غَرِيبٌ جَاءَ يَسْأَلُ عَنْ دِينِهِ لاَ يَدْرِي مَا دِينُهُ - قَالَ - فَأَقْبَلَ عَلَىَّ رَسُولُ اللَّهِ صلى الله عليه وسلم وَتَرَكَ خُطْبَتَهُ حَتَّى انْتَهَى إِلَىَّ فَأُتِيَ بِكُرْسِيٍّ حَسِبْتُ قَوَائِمَهُ حَدِيدًا - قَالَ - فَقَعَدَ عَلَيْهِ رَسُولُ اللَّهِ صلى الله عليه وسلم وَجَعَلَ يُعَلِّمُنِي مِمَّا عَلَّمَهُ اللَّهُ ثُمَّ أَتَى خُطْبَتَهُ فَأَتَمَّ آخِرَهَا ‏.‏", "bengali": "", "english": "I came to the Prophet (ﷺ) when he was delivering the sermon, and I said: Messenger of Allah, here is a stranger and he wants to learn about this religion and he does not know what this religion is. The Messenger of Allah (ﷺ) looked at me and left his sermon till he came to me, and he was given a chair and I thought that Its legs were made of iron. The Messenger of Allah (ﷺ) sat In it and he began to teach me what Allah had taught him. He then came (to the pulpit) for his sermon and completed it to the end.", "french": "", "indonesian": "", "russian": "", "urdu": "مغیرہ نے ابرا ہیم سے روا یت کی ، انھوں نے کہا : علقم ہشام آئے اور ایک مسجد میں داخل ہو ئے اس میں نما", "grades": "", "reference": "", "international_number": "1917", "narrator_chain": "Abu Rifa'a reported:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1918", "arabic": "حَدَّثَنَا عَبْدُ اللَّهِ بْنُ مَسْلَمَةَ بْنِ قَعْنَبٍ، حَدَّثَنَا سُلَيْمَانُ، - وَهُوَ ابْنُ بِلاَلٍ - عَنْ جَعْفَرٍ، عَنْ أَبِيهِ، عَنِ ابْنِ أَبِي رَافِعٍ، قَالَ اسْتَخْلَفَ مَرْوَانُ أَبَا هُرَيْرَةَ عَلَى الْمَدِينَةِ وَخَرَجَ إِلَى مَكَّةَ فَصَلَّى لَنَا أَبُو هُرَيْرَةَ الْجُمُعَةَ فَقَرَأَ بَعْدَ سُورَةِ الْجُمُعَةِ فِي الرَّكْعَةِ الآخِرَةِ ‏{‏ إِذَا جَاءَكَ الْمُنَافِقُونَ‏}‏ - قَالَ - فَأَدْرَكْتُ أَبَا هُرَيْرَةَ حِينَ انْصَرَفَ فَقُلْتُ لَهُ إِنَّكَ قَرَأْتَ بِسُورَتَيْنِ كَانَ عَلِيُّ بْنُ أَبِي طَالِبٍ يَقْرَأُ بِهِمَا بِالْكُوفَةِ ‏.‏ فَقَالَ أَبُو هُرَيْرَةَ إِنِّي سَمِعْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم يَقْرَأُ بِهِمَا يَوْمَ الْجُمُعَةِ ‏.‏", "bengali": "", "english": "Marwan appointed Abu Huraira as his deputy in Medina and he himself left for Mecca. Abu Huraira led us in the Jumu'a prayer and recited after Surah Jumu'a in the second rak'ah:\" When the hypocrites came to thee\" (Surah 63). I then met Abu Huraira as he came back and said to him: You have recited two surahs which 'Ali b. Abu Talib used to recite in Kufah. Upon this Abu Huraira said: I heard the Messenger of Allah (ﷺ) reciting these two in the Friday (prayer).", "french": "", "indonesian": "", "russian": "", "urdu": "اسماعیل بن ابرا ہیم  ( ابن علیہ  )  نے داودبن ابی ہند سے انھوں نے شعبی سے اور انھوں نے علقمہ سے روا", "grades": "", "reference": "", "international_number": "1918", "narrator_chain": "Ibn Abu Rafi' said:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1919", "arabic": "وَحَدَّثَنَا قُتَيْبَةُ بْنُ سَعِيدٍ، وَأَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ قَالاَ حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِيلَ، ح وَحَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا عَبْدُ الْعَزِيزِ، - يَعْنِي الدَّرَاوَرْدِيَّ - كِلاَهُمَا عَنْ جَعْفَرٍ، عَنْ أَبِيهِ، عَنْ عُبَيْدِ اللَّهِ بْنِ أَبِي رَافِعٍ، قَالَ اسْتَخْلَفَ مَرْوَانُ أَبَا هُرَيْرَةَ ‏.‏ بِمِثْلِهِ غَيْرَ أَنَّ فِي، رِوَايَةِ حَاتِمٍ فَقَرَأَ بِسُورَةِ الْجُمُعَةِ فِي السَّجْدَةِ الأُولَى وَفِي الآخِرَةِ ‏{‏ إِذَا جَاءَكَ الْمُنَافِقُونَ‏}‏ وَرِوَايَةُ عَبْدِ الْعَزِيزِ مِثْلُ حَدِيثِ سُلَيْمَانَ بْنِ بِلاَلٍ ‏.‏", "bengali": "", "english": "\" That he recited Surah Jumu'a (lxii.) in the first rak'ah and\" The hypocrites came\" in the second rak'ah.", "french": "", "indonesian": "", "russian": "", "urdu": "عبد الاعلیٰ نے کہا :  ہم سے داودنے عامر  ( شعبی ) سے اور انھوں نے علقمہ سے روا یت کی ،  انھوں نے کہا", "grades": "", "reference": "", "international_number": "1919", "narrator_chain": "This hadith is narrated by Abdullah b. Abu Rafi' with the same chain of transmitters but with this modification:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1920", "arabic": "حَدَّثَنَا يَحْيَى بْنُ يَحْيَى، وَأَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ وَإِسْحَاقُ جَمِيعًا عَنْ جَرِيرٍ، - قَالَ يَحْيَى أَخْبَرَنَا جَرِيرٌ، - عَنْ إِبْرَاهِيمَ بْنِ مُحَمَّدِ بْنِ الْمُنْتَشِرِ، عَنْ أَبِيهِ، عَنْ حَبِيبِ بْنِ، سَالِمٍ مَوْلَى النُّعْمَانِ بْنِ بَشِيرٍ عَنِ النُّعْمَانِ بْنِ بَشِيرٍ، قَالَ كَانَ رَسُولُ اللَّهِ صلى الله عليه وسلم يَقْرَأُ فِي الْعِيدَيْنِ وَفِي الْجُمُعَةِ بِـ ‏{‏ سَبِّحِ اسْمَ رَبِّكَ الأَعْلَى‏}‏ وَ ‏{‏ هَلْ أَتَاكَ حَدِيثُ الْغَاشِيَةِ‏}‏ قَالَ وَإِذَا اجْتَمَعَ الْعِيدُ وَالْجُمُعَةُ فِي يَوْمٍ وَاحِدٍ يَقْرَأُ بِهِمَا أَيْضًا فِي الصَّلاَتَيْنِ.", "bengali": "", "english": "\" Glorify The name of Thy Lord, the Most High\" (Surah lxxxvii.), and:\" Has there come to thee the news of the overwhelming event\" (lxxxviii.). And when the 'Id and Jumu'a combined on a day he recited these two (surah) in both the prayers.", "french": "", "indonesian": "", "russian": "", "urdu": "حضرت ابو ہریرہ  رضی اللہ تعالیٰ عنہ  سے روا یت ہے کہ رسول اللہ  صلی اللہ علیہ وسلم  نے نماز عصر کے ب", "grades": "", "reference": "", "international_number": "1920", "narrator_chain": "Nu'man b. Bashir reported that the Messenger of Allah (ﷺ) used to recite on two 'Ids and in Friday prayer:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1921", "arabic": "وَحَدَّثَنَاهُ قُتَيْبَةُ بْنُ سَعِيدٍ، حَدَّثَنَا أَبُو عَوَانَةَ، عَنْ إِبْرَاهِيمَ بْنِ مُحَمَّدِ بْنِ الْمُنْتَشِرِ، بِهَذَا الإِسْنَادِ ‏.‏", "bengali": "", "english": "This hadith has been narrated by Ibrahim b Muhammad b. al-Muntashir with the same chain of transmitters.", "french": "", "indonesian": "", "russian": "", "urdu": "منصور نے قتادہ سے روا یت کی انھوں نے کہا :  ہمیں ابو عالیہ نے حضرت ابن عباس رضی اللہ تعالیٰ عنہ  سے", "grades": "", "reference": "", "international_number": "1921", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1922", "arabic": "وَحَدَّثَنَا عَمْرٌو النَّاقِدُ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ ضَمْرَةَ بْنِ سَعِيدٍ، عَنْ عُبَيْدِ، اللَّهِ بْنِ عَبْدِ اللَّهِ قَالَ كَتَبَ الضَّحَّاكُ بْنُ قَيْسٍ إِلَى النُّعْمَانِ بْنِ بَشِيرٍ يَسْأَلُهُ أَىَّ شَىْءٍ قَرَأَ رَسُولُ اللَّهِ صلى الله عليه وسلم يَوْمَ الْجُمُعَةِ سِوَى سُورَةِ الْجُمُعَةِ فَقَالَ كَانَ يَقْرَأُ ‏{‏ هَلْ أَتَاكَ‏}‏", "bengali": "", "english": "\" Has there reached...\" (Surah lxxxviii, ).", "french": "", "indonesian": "", "russian": "", "urdu": "شعبہ سعید اور معاذ بن ہشام نے اپنے والد کے واسطے سے قتادہ سے اسی سند کے ساتھ یہ روا یت بیان کی ،  ال", "grades": "", "reference": "", "international_number": "1922", "narrator_chain": "Dahhak b. Qais wrote to Nu'man b. Bashir asking him what the Messenger of Allah (ﷺ) recited on Friday besides Surah Jumu'a He said that he recited:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1923", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدَةُ بْنُ سُلَيْمَانَ، عَنْ سُفْيَانَ، عَنْ مُخَوَّلِ، بْنِ رَاشِدٍ عَنْ مُسْلِمٍ الْبَطِينِ، عَنْ سَعِيدِ بْنِ جُبَيْرٍ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ النَّبِيَّ صلى الله عليه وسلم كَانَ يَقْرَأُ فِي صَلاَةِ الْفَجْرِ يَوْمَ الْجُمُعَةِ ‏{‏ الم * تَنْزِيلُ‏}‏ السَّجْدَةُ وَ ‏{‏ هَلْ أَتَى عَلَى الإِنْسَانِ حِينٌ مِنَ الدَّهْرِ‏}‏ وَأَنَّ النَّبِيَّ صلى الله عليه وسلم كَانَ يَقْرَأُ فِي صَلاَةِ الْجُمُعَةِ سُورَةَ الْجُمُعَةِ وَالْمُنَافِقِينَ ‏.‏", "bengali": "", "english": "The Apostle of Allah (ﷺ) used to recite in the morning prayer on Friday Surah\" Alif-Lam-Mim, Tanz'il ul-Sajda\" (Surah xxxii.): Surely there came over the man a time\" (Surah lxxvii) and he used to recite in Jumu'a prayer Surahs Jumu'a and al-Munafiqin.", "french": "", "indonesian": "", "russian": "", "urdu": "عطاء بن یزید لیثی نے خبر دی کہ انھوں نے ابو سعید خدری  رضی اللہ تعالیٰ عنہ  کو کہتے ہوئے سنا کہ رسول", "grades": "", "reference": "", "international_number": "1923", "narrator_chain": "Ibn Abbas reported:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1924", "arabic": "وَحَدَّثَنَا ابْنُ نُمَيْرٍ، حَدَّثَنَا أَبِي ح، وَحَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا وَكِيعٌ، كِلاَهُمَا عَنْ سُفْيَانَ، بِهَذَا الإِسْنَادِ ‏.‏ مِثْلَهُ ‏.‏", "bengali": "", "english": "A hadith like this has been narrated by Sufyan with the same chain of transmitters.", "french": "", "indonesian": "", "russian": "", "urdu": "نافع نے حضرت ابن عمر  رضی اللہ تعالیٰ عنہ  سے روایت کی کہ رسول اللہ  صلی اللہ علیہ وسلم  نے فرمایا :", "grades": "", "reference": "", "international_number": "1924", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1925", "arabic": "وَحَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، حَدَّثَنَا شُعْبَةُ، عَنْ مُخَوَّلٍ، بِهَذَا الإِسْنَادِ ‏.‏ مِثْلَهُ فِي الصَّلاَتَيْنِ كِلْتَيْهِمَا ‏.‏ كَمَا قَالَ سُفْيَانُ.", "bengali": "", "english": "Mukhawwil has narrated this hadith on the authority of Sufyan.", "french": "", "indonesian": "", "russian": "", "urdu": "ہشام کے والد عروہ نے حضرت ابن عمر  رضی اللہ تعالیٰ عنہ  سے روایت کی ، انھوں نے کہا : رسول اللہ  صلی", "grades": "", "reference": "", "international_number": "1925", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1926", "arabic": "حَدَّثَنِي زُهَيْرُ بْنُ حَرْبٍ، حَدَّثَنَا وَكِيعٌ، عَنْ سُفْيَانَ، عَنْ سَعْدِ بْنِ إِبْرَاهِيمَ، عَنْ عَبْدِ، الرَّحْمَنِ الأَعْرَجِ عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم ‏.‏ أَنَّهُ كَانَ يَقْرَأُ فِي الْفَجْرِ يَوْمَ الْجُمُعَةِ ‏{‏ الم * تَنْزِيلُ‏}‏ وَ ‏{‏ هَلْ أَتَى‏}‏", "bengali": "", "english": "Abu Huraira reported that the Messenger of Allah (ﷺ) used to recite in the dawn prayer on Friday\" Alif-Lam-Mim, Tanzil\" and\" Surely there came.\"", "french": "", "indonesian": "", "russian": "", "urdu": "حضرت ابن عمر  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہا : رسول اللہ  صلی اللہ علیہ وسلم  نے فرمایا :  \" ج", "grades": "", "reference": "", "international_number": "1926", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1927", "arabic": "حَدَّثَنِي أَبُو الطَّاهِرِ، حَدَّثَنَا ابْنُ وَهْبٍ، عَنْ إِبْرَاهِيمَ بْنِ سَعْدٍ، عَنْ أَبِيهِ، عَنِ الأَعْرَجِ، عَنْ أَبِي هُرَيْرَةَ، ‏.‏ أَنَّ النَّبِيَّ صلى الله عليه وسلم كَانَ يَقْرَأُ فِي الصُّبْحِ يَوْمَ الْجُمُعَةِ بِـ ‏{‏ الم * تَنْزِيلُ‏}‏ فِي الرَّكْعَةِ الأُولَى وَفِي الثَّانِيَةِ ‏{‏ هَلْ أَتَى عَلَى الإِنْسَانِ حِينٌ مِنَ الدَّهْرِ لَمْ يَكُنْ شَيْئًا مَذْكُورًا‏}‏", "bengali": "", "english": "\" Alif-Lam-Mim, Tanzil\" in the first rak'ah, and in the second one:\" Surely there came over the man a time when he was nothing that could be mentioned.\"", "french": "", "indonesian": "", "russian": "", "urdu": "لیث نے خیر بن نعیم حضرمی سے روایت کی ، انھوں نے عبداللہ بن ہبیرہ سے ، انھوں نے ابو تمیم جیشانی سے او", "grades": "", "reference": "", "international_number": "1927", "narrator_chain": "Abu Huraira reported that the Messenger of Allah (ﷺ) used to recite in the dawn prayer on Friday:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1928", "arabic": "وَحَدَّثَنَا يَحْيَى بْنُ يَحْيَى، أَخْبَرَنَا خَالِدُ بْنُ عَبْدِ اللَّهِ، عَنْ سُهَيْلٍ، عَنْ أَبِيهِ، عَنْ أَبِي، هُرَيْرَةَ قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ إِذَا صَلَّى أَحَدُكُمُ الْجُمُعَةَ فَلْيُصَلِّ بَعْدَهَا أَرْبَعًا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "When any one of you observes the Jumu'a prayer (two obligatory rak'ahs in congregation), he should observe four (rak'ahs) afterwards.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1929", "arabic": "وَحَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَمْرٌو النَّاقِدُ، قَالاَ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ إِدْرِيسَ، عَنْ سُهَيْلٍ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ إِذَا صَلَّيْتُمْ بَعْدَ الْجُمُعَةِ فَصَلُّوا أَرْبَعًا ‏\"‏ ‏.‏ - زَادَ عَمْرٌو فِي رِوَايَتِهِ قَالَ ابْنُ إِدْرِيسَ قَالَ سُهَيْلٌ فَإِنْ عَجِلَ بِكَ شَىْءٌ فَصَلِّ رَكْعَتَيْنِ فِي الْمَسْجِدِ وَرَكْعَتَيْنِ إِذَا رَجَعْتَ ‏\"‏ ‏.‏", "bengali": "", "english": "When you observe prayer after (the two obligatory rak'ahs) of Jumu'ah, you should observe four rak'ahs (and 'Amr in his narration has made this addition that Ibn Idris said this on the authority of Suhail): And if you are in a hurry on account of something, you should observe two rak'ahs in the mosque and two when you return (to your house).", "french": "", "indonesian": "", "russian": "", "urdu": "حضرت عقبہ بن عامر  جہنی رضی اللہ تعالیٰ عنہ  کہتے تھے کہ تین ا وقات ہیں ، رسول اللہ  صلی اللہ علیہ و", "grades": "", "reference": "", "international_number": "1929", "narrator_chain": "Suhail reported on the authority of Abu Huraira that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1930", "arabic": "وَحَدَّثَنِي زُهَيْرُ بْنُ حَرْبٍ، حَدَّثَنَا جَرِيرٌ، ح وَحَدَّثَنَا عَمْرٌو النَّاقِدُ، وَأَبُو كُرَيْبٍ قَالاَ حَدَّثَنَا وَكِيعٌ، عَنْ سُفْيَانَ، كِلاَهُمَا عَنْ سُهَيْلٍ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ مَنْ كَانَ مِنْكُمْ مُصَلِّيًا بَعْدَ الْجُمُعَةِ فَلْيُصَلِّ أَرْبَعًا ‏\"‏ ‏.‏ وَلَيْسَ فِي حَدِيثِ جَرِيرٍ ‏\"‏ مِنْكُمْ ‏\"‏ ‏.‏", "bengali": "", "english": "When any one amongst you observes prayer after Jumu'a, he should observe four rak'ahs. (In the hadith transmitted by Jarir the word minkum is not recorded.)", "french": "", "indonesian": "", "russian": "", "urdu": "ابو عمار شداد بن عبداللہ اور یحییٰ بن ابی کثیر نے ابو امامہ سے روایت کی ۔  ۔  ۔ عکرمہ نے کہا : شداد", "grades": "", "reference": "", "international_number": "1930", "narrator_chain": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1931", "arabic": "وَحَدَّثَنَا يَحْيَى بْنُ يَحْيَى، وَمُحَمَّدُ بْنُ رُمْحٍ، قَالاَ أَخْبَرَنَا اللَّيْثُ، ح وَحَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا لَيْثٌ، عَنْ نَافِعٍ، عَنْ عَبْدِ اللَّهِ، أَنَّهُ كَانَ إِذَا صَلَّى الْجُمُعَةَ انْصَرَفَ فَسَجَدَ سَجْدَتَيْنِ فِي بَيْتِهِ ثُمَّ قَالَ كَانَ رَسُولُ اللَّهِ صلى الله عليه وسلم يَصْنَعُ ذَلِكَ ‏.‏", "bengali": "", "english": "The Messenger of Allah (may peace be updn him) used to do this.", "french": "", "indonesian": "", "russian": "", "urdu": "وہیب نے کہا : ہم سے عبداللہ بن طاوس نے حدیث بیان کی ، انھوں نے اپنے والد  ( طاوس )  سے اور انھوں نے", "grades": "", "reference": "", "international_number": "1931", "narrator_chain": "Nafi' reported that when 'Abdullah (b. 'Umar) observed the Friday prayer and came back he observed two rak'ahs in his house, and then said:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1932", "arabic": "وَحَدَّثَنَا يَحْيَى بْنُ يَحْيَى، قَالَ قَرَأْتُ عَلَى مَالِكٍ عَنْ نَافِعٍ، عَنْ عَبْدِ اللَّهِ بْنِ عُمَرَ، أَنَّهُ وَصَفَ تَطَوُّعَ صَلاَةِ رَسُولِ اللَّهِ صلى الله عليه وسلم قَالَ فَكَانَ لاَ يُصَلِّي بَعْدَ الْجُمُعَةِ حَتَّى يَنْصَرِفَ فَيُصَلِّي رَكْعَتَيْنِ فِي بَيْتِهِ ‏.‏ قَالَ يَحْيَى أَظُنُّنِي قَرَأْتُ فَيُصَلِّي أَوْ أَلْبَتَّةَ ‏.‏", "bengali": "", "english": "He did not observe (Nafl) prayer after Jumu'a till he went back and observed two rak'ahs in his house. Yahya said: I guess that I uttered these words (before Imam Malik) that he of course observed (them).", "french": "", "indonesian": "", "russian": "", "urdu": "معمر نے باقی ماندہ سابقہ سند کے ساتھ طاوس کے بیٹے سے ، انھوں نے اپنے والد سے اور انھوں نے حضرت عائشہ", "grades": "", "reference": "", "international_number": "1932", "narrator_chain": "'Abdullah b. 'Umar, while describing the Nafl prayer of the Messenger of Allah (ﷺ), said:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1933", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَزُهَيْرُ بْنُ حَرْبٍ، وَابْنُ، نُمَيْرٍ قَالَ زُهَيْرٌ حَدَّثَنَا سُفْيَانُ، بْنُ عُيَيْنَةَ حَدَّثَنَا عَمْرٌو، عَنِ الزُّهْرِيِّ، عَنْ سَالِمٍ، عَنْ أَبِيهِ، أَنَّ النَّبِيَّ صلى الله عليه وسلم كَانَ يُصَلِّي بَعْدَ الْجُمُعَةِ رَكْعَتَيْنِ ‏.‏", "bengali": "", "english": "Salim narrated on the authority of his father that the Messenger of Allah (ﷺ) used to observe two rak'ahs after Jumu'a.", "french": "", "indonesian": "", "russian": "", "urdu": "حضرت ابن  عباس  رضی اللہ تعالیٰ عنہ  کے  آزاد کردہ غلام کریب سے روایت ہے کہ عبداللہ بن عباس  رضی الل", "grades": "", "reference": "", "international_number": "1933", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1934", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا غُنْدَرٌ، عَنِ ابْنِ جُرَيْجٍ، قَالَ أَخْبَرَنِي عُمَرُ، بْنُ عَطَاءِ بْنِ أَبِي الْخُوَارِ أَنَّ نَافِعَ بْنَ جُبَيْرٍ، أَرْسَلَهُ إِلَى السَّائِبِ ابْنِ أُخْتِ نَمِرٍ يَسْأَلُهُ عَنْ شَىْءٍ، رَآهُ مِنْهُ مُعَاوِيَةُ فِي الصَّلاَةِ فَقَالَ نَعَمْ ‏.‏ صَلَّيْتُ مَعَهُ الْجُمُعَةَ فِي الْمَقْصُورَةِ فَلَمَّا سَلَّمَ الإِمَامُ قُمْتُ فِي مَقَامِي فَصَلَّيْتُ فَلَمَّا دَخَلَ أَرْسَلَ إِلَىَّ فَقَالَ لاَ تَعُدْ لِمَا فَعَلْتَ إِذَا صَلَّيْتَ الْجُمُعَةَ فَلاَ تَصِلْهَا بِصَلاَةٍ حَتَّى تَكَلَّمَ أَوْ تَخْرُجَ فَإِنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم أَمَرَنَا بِذَلِكَ أَنْ لاَ تُوصَلَ صَلاَةٌ حَتَّى نَتَكَلَّمَ أَوْ نَخْرُجَ ‏.‏", "bengali": "", "english": "Yes, I observed the Jumu`a prayer along with him in Maqsura and when the Imam pronounced salutation I stood up at my place and observed (Sunan rak`ahs). As he entered (the apartment) he sent for me and said: Do not repeat what you have done. Whenever you have observed the Jumu`a prayer, do not observe (Sunan prayer) till you, have talked or gone out, for the Messenger of Allah (ﷺ) had ordered us to do this and not to combine two (types of) prayers without talking or going out.", "french": "", "indonesian": "", "russian": "", "urdu": "یحییٰ بن ایوب ، قتیبہ ، اور علی بن حجر نے اسماعیل بن جعفر سے حدیث بیان کی ، ابن ایوب نے کہا : ہمیں ا", "grades": "", "reference": "", "international_number": "1934", "narrator_chain": "`Umar b. `Ata' b. Abu Khuwar said that Nafi` b. Jubair sent him to al- Sa'ib the son of Namir's sister to ask him about what he had seen in the prayer of Mu`awiya. He said:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1935", "arabic": "وَحَدَّثَنَا هَارُونُ بْنُ عَبْدِ اللَّهِ، حَدَّثَنَا حَجَّاجُ بْنُ مُحَمَّدٍ، قَالَ قَالَ ابْنُ جُرَيْجٍ أَخْبَرَنِي عُمَرُ بْنُ عَطَاءٍ، أَنَّ نَافِعَ بْنَ جُبَيْرٍ، أَرْسَلَهُ إِلَى السَّائِبِ بْنِ يَزِيدَ ابْنِ أُخْتِ نَمِرٍ ‏.‏ وَسَاقَ الْحَدِيثَ بِمِثْلِهِ غَيْرَ أَنَّهُ قَالَ فَلَمَّا سَلَّمَ قُمْتُ فِي مَقَامِي وَلَمْ يَذْكُرِ الإِمَامَ ‏.‏", "bengali": "", "english": "When he (the Imam) pronounced salutation I stood up at my place. No mention was made of the Imam in it.", "french": "", "indonesian": "", "russian": "", "urdu": "عروہ نے حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے روایت کی ، انھوں نے  فرمایا : رسول اللہ  صلی اللہ علیہ", "grades": "", "reference": "", "international_number": "1935", "narrator_chain": "The same hadith is narrated on the authority of 'Umar b. Ata' but with this modification:", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1951", "arabic": "حَدَّثَنَا  يَحْيَى بْنُ يَحْيَى التَّمِيمِيُّ ،  ومُحَمَّدُ بْنُ رُمْحِ بْنِ الْمُهَاجِرِ ، قَالَا:", "bengali": "", "english": "Abdullah is reported to have heard Allah's Messenger (ﷺ) as saying:When any one of you intends to come for Jumu'a prayer, he should take a bath", "french": "", "indonesian": "", "russian": "", "urdu": "نافع نے حضرت عبداللہ  ( بن عمر رضی اللہ تعالیٰ عنہ  )  سے روایت کی ، انھوں نےکہا : میں نے رسول اللہ", "grades": "", "reference": "Book 7, Hadith 1", "international_number": "1951", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1952", "arabic": "حَدَّثَنَا  قُتَيْبَةُ بْنُ سَعِيدٍ ، حَدَّثَنَا لَيْثٌ. ح وحَدَّثَنَا  ابْنُ رُمْحٍ ، أَخْبَرَنَا", "bengali": "", "english": "Abdullah b. Umar is reported to have said that The Messenger of Allah (may peace be up on him) was standing on the pulpit when he said this:He who comes for Jumu'a he should take a bath", "french": "", "indonesian": "", "russian": "", "urdu": "لیث نے ابن شہاب سے ، انھوں نے عبداللہ بن عبداللہ بن عمیر سے  ، انھوں نے حضرت عبداللہ بن عمر  رضی الل", "grades": "", "reference": "Book 7, Hadith 2", "international_number": "1952", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1953", "arabic": "وحَدَّثَنِي  مُحَمَّدُ بْنُ رَافِعٍ ، حَدَّثَنَا  عَبْدُ الرَّزَّاقِ ، أَخْبَرَنَا  ابْنُ جُرَيْجٍ ،", "bengali": "", "english": "This hadith has been narrated by Ibn Umar by another chain of transmitters", "french": "", "indonesian": "", "russian": "", "urdu": "ابن جریج نے کہا : ابن شہاب نے عبداللہ بن عمر رضی اللہ تعالیٰ عنہ  کے دونوں بیٹوں سالم اورعبداللہ سے", "grades": "", "reference": "Book 7, Hadith 3", "international_number": "1953", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1954", "arabic": "وحَدَّثَنِي  حَرْمَلَةُ بْنُ يَحْيَى ، أَخْبَرَنَا  ابْنُ وَهْبٍ ، أَخْبَرَنِي  يُونُسُ ، عَنْ  ابْن", "bengali": "", "english": "Abdullah (b. Umar) reported on the authority of his father that he heard like this from the Messenger of Allah (ﷺ)", "french": "", "indonesian": "", "russian": "", "urdu": "یونس نے ابن شہاب سے  ، انھوں نے سالم بن عبداللہ سے اورانھوں نے اپنے والد سے روایت کی ، انھوں نے کہا", "grades": "", "reference": "Book 7, Hadith 4", "international_number": "1954", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1955", "arabic": "وحَدَّثَنِي  حَرْمَلَةُ بْنُ يَحْيَى ، أَخْبَرَنَا  ابْنُ وَهْبٍ ، أَخْبَرَنِي  يُونُسُ ، عَنْ  ابْن", "bengali": "", "english": "Abdullah (b. 'Umar) reported from his father that while he was addressing the people on Friday (sermon), a person, one of the Companions of the Messenger of Allah (ﷺ), entered (the mosque). Umar said to him loudly:What is this hour (for attending the prayer)? He said: I was busy today and I did not return to my house when I heard the call (to Friday prayer), and I did no more but performed ablution only. Upon this Umar said: just ablution! You know that the Messenger of Allah (ﷺ) commanded (us) to take a bath (on Friday)", "french": "", "indonesian": "", "russian": "", "urdu": "حضرت عبداللہ رضی اللہ تعالیٰ عنہ  سے  روایت ہے کہ حضرت عمر بن خطاب رضی اللہ تعالیٰ عنہ  جمعے کے دن ل", "grades": "", "reference": "Book 7, Hadith 5", "international_number": "1955", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1956", "arabic": "حَدَّثَنَا  إسحاق بْنُ إِبْرَاهِيمَ ، أَخْبَرَنَا  الْوَلِيدُ بْنُ مُسْلِمٍ ، عَنْ  الْأَوْزَاعِيِّ", "bengali": "", "english": "Abu Huraira reported:Umar b. Khattab was delivering a sermon to the people on Friday when 'Uthman b. 'Affan came there. 'Umar hinting to him said: What would become of those persons who come after the call to prayer? Upon this 'Uthman said: Commander of the faithful, I did no more than this that after listening to the call, I performed ablution and came (to the mosque). 'Umar said: Just ablution! Did you not hear the Messenger of Allah (my peace be upon him) say this: When any one of you comes for Jumu'a, he should take a bath", "french": "", "indonesian": "", "russian": "", "urdu": "حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  نے کہا :   ( ایک بار )  حضرت عمر بن خطاب  رضی اللہ تعالیٰ عنہ  ج", "grades": "", "reference": "Book 7, Hadith 6", "international_number": "1956", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1957", "arabic": "حَدَّثَنَا  يَحْيَى بْنُ يَحْيَى ، قَالَ: قَرَأْتُ عَلَى  مَالِكٍ ، عَنْ  صَفْوَانَ بْنِ سُلَيْمٍ ،", "bengali": "", "english": "Sa'id al-Khudri reported Allah's Messenger (ﷺ) as saying:Taking a bath on Friday is essential for every adult person", "french": "", "indonesian": "", "russian": "", "urdu": "حضرت ابو سعید خدری رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ رسول اللہ  صلی اللہ علیہ وسلم  نے فر ما یا  :", "grades": "", "reference": "Book 7, Hadith 7", "international_number": "1957", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1958", "arabic": "حَدَّثَنِي  هَارُونُ بْنُ سَعِيدٍ الْأَيْلِيُّ ،  وَأَحْمَدُ بْنُ عِيسَى ، قَالَا: حَدَّثَنَا  ابْنُ", "bengali": "", "english": "Aisha reported:The people came for Jumu'a prayer from their houses in the neighbouring villages dressed in woollen garments on which dust was settled and this emitted a foul smell. A person among them (those who were dressed so) came to the Messenger of Allah (ﷺ) while he was in my house. The Messenger of Allah (may peace he upon him) said to him: Were you to cleanse yourselves on this day", "french": "", "indonesian": "", "russian": "", "urdu": "عروہ بن زبیر نے حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے روایت کی  ،  انھوں نے کہا :  جمعے کے لیے لو گ", "grades": "", "reference": "Book 7, Hadith 8", "international_number": "1958", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1959", "arabic": "وحَدَّثَنَا وحَدَّثَنَا  مُحَمَّدُ بْنُ رُمْحٍ ، أَخْبَرَنَا  اللَّيْثُ ، عَنْ  يَحْيَى بْنِ سَعِيدٍ", "bengali": "", "english": "Aisha reported:The people (mostly) were workers and they had no servants. Ill-smell thus emitted out of them. It was said to them: Were you to take bath on Friday", "french": "", "indonesian": "", "russian": "", "urdu": "عمرہ نے حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے روایت کی  ، انھوں نے کہا :  لو گ کا م کا ج والے تھے ان", "grades": "", "reference": "Book 7, Hadith 9", "international_number": "1959", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1960", "arabic": "وحَدَّثَنَا  عَمْرُو بْنُ سَوَّادٍ الْعَامِرِيُّ ، حَدَّثَنَا  عَبْدُ اللَّهِ بْنُ وَهْبٍ ، أَخْبَرَ", "bengali": "", "english": "Abd al-Rahman son of Abd Sa'id al-Khudri reported on the authority of his father that the Messenger of Allah (ﷺ) said:Bathing on Friday for every adult, using of Miswak and applying some perfume, that is available-these are essential. So far as the perfume is concerned, it may be that used by a lady", "french": "", "indonesian": "", "russian": "", "urdu": "سعید بن ابی بلال اور بکیر بن اشج نے ابو بکر بن منکد ر سے حدیث بیان کی ،  انھوں نے عمرو بن سلیم سے ان", "grades": "", "reference": "Book 7, Hadith 10", "international_number": "1960", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1961", "arabic": "حَدَّثَنَا  حَسَنٌ الْحُلْوَانِيُّ ، حَدَّثَنَا  رَوْحُ بْنُ عُبَادَةَ ، حَدَّثَنَا  ابْنُ جُرَيْجٍ", "bengali": "", "english": "Tawus reported that Ibn Abbas narrated the words of the Messenger of Allah (ﷺ) about taking bath on Friday. Tawus said:I asked Ibn Abbas it one should apply to oneself perfume or oil which is available with his wife. He (Ibn Abbas) said: I do not know of it", "french": "", "indonesian": "", "russian": "", "urdu": "روح بن عباوہ اور عبد الرزاق نے ابن جریج سے حدیث بیان کی انھوں نے کہا مجھے ابراہیم بن میسر ہ نے طاوس", "grades": "", "reference": "Book 7, Hadith 11", "international_number": "1961", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1962", "arabic": "وحَدَّثَنَاه  إسحاق بْنُ إِبْرَاهِيمَ ، أَخْبَرَنَا  مُحَمَّدُ بْنُ بَكْرٍ . ح وحَدَّثَنَا  هَارُونُ", "bengali": "", "english": "This hadith has been narrated by Ibn Juraij with the came chain of transmitters", "french": "", "indonesian": "", "russian": "", "urdu": "محمد بن بکر اور ضحاک  بن مخلددونوں نے بن جریج سے اسی سند کے ساتھ  ( سابقہ  )  حدیث بیان کی ۔", "grades": "", "reference": "Book 7, Hadith 12", "international_number": "1962", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1963", "arabic": "وحَدَّثَنِي  مُحَمَّدُ بْنُ حَاتِمٍ ، حَدَّثَنَا  بَهْزٌ ، حَدَّثَنَا  وُهَيْبٌ ، حَدَّثَنَا  عَبْدُ", "bengali": "", "english": "Abu Huraira reported that the Messenger of Allah (ﷺ) said. it is the right of Allah upon every Muslim that he should take a bath (at least) on one day (Friday) during the seven days (of the week) and he should wash his head and body", "french": "", "indonesian": "", "russian": "", "urdu": "طاوس نے حضڑت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے اور انھوں نے نبی اکرم  صلی اللہ علیہ وسلم  سے روایت ک", "grades": "", "reference": "Book 7, Hadith 13", "international_number": "1963", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1964", "arabic": "وحَدَّثَنَا  قُتَيْبَةُ بْنُ سَعِيدٍ ، عَنْ  مَالِكِ بْنِ أَنَسٍ فِيمَا قُرِئَ عَلَيْهِ، عَنْ  سُمَي", "bengali": "", "english": "Abu Huraira reported that the Messenger of, Allah (ﷺ) said. He who takes a bath on Friday, the bath which is obligatory after the sexual discharge and then goes (to the mosque), he is like one who offers a she-camel as a sacrifice, and he who comes at the second hour would be like one who offers a cow, and he who comes at the third hour is live one who offers a ram with horns, and he who comes at the fourth hour is like one who offers a hen, and he who comes at the fifth hour is like one who offers an egg. And when the Imam comes out, the angels are also present and listen to the mention of God (the sermon)", "french": "", "indonesian": "", "russian": "", "urdu": "ابو صالح سمنان نے حضرت ابو ہریرہ  رضی اللہ تعالیٰ عنہ  سے روایت کی کہ رسول اللہ  صلی اللہ علیہ وسلم", "grades": "", "reference": "Book 7, Hadith 14", "international_number": "1964", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1965", "arabic": "وحَدَّثَنَا  قُتَيْبَةُ بْنُ سَعِيدٍ ،  وَمُحَمَّدُ بْنُ رُمْحِ بْنِ الْمُهَاجِرِ ، قَالَ ابْنُ رُمْ", "bengali": "", "english": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:If you (even) ask your companion to be quiet on Friday while the Imam is delivering the sermon, you have in fact talked irrelevance", "french": "", "indonesian": "", "russian": "", "urdu": "قتیبہ بن سعید اور محمد بن رمح بن مہاجر نے حدیث بیان کی ، ابن رمح نے کہا :  ہمیں لیث نے عقیل بن خالد", "grades": "", "reference": "Book 7, Hadith 15", "international_number": "1965", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1966", "arabic": "وحَدَّثَنِي  عَبْدُ الْمَلِكِ بْنُ شُعَيْبِ بْنِ اللَّيْثِ ، حَدَّثَنِي  أَبِي ، عَنْ  جَدِّي ، حَدّ", "bengali": "", "english": "A hadith like this has been narrated by Abu Huraira by another chain of transmitters", "french": "", "indonesian": "", "russian": "", "urdu": "عبد الملک  بن شعیب بن لیث نے کہا :  مجھ سے میرے والد شعیب نے میرے دادالیث سے حدیث بیان کی انھوں نے ک", "grades": "", "reference": "Book 7, Hadith 16", "international_number": "1966", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1967", "arabic": "وحَدَّثَنِيهِ  مُحَمَّدُ بْنُ حَاتِمٍ ، حَدَّثَنَا  مُحَمَّدُ بْنُ بَكْرٍ ، أَخْبَرَنَا  ابْنُ جُرَي", "bengali": "", "english": "Ibn Juraij narrated a similar Hadith (as no. 1965) from Ibn Shihab with both chains, except that Ibn Juraij said:\"Ibrahim bin 'Abdullah bin Qariz", "french": "", "indonesian": "", "russian": "", "urdu": "ابن جریج نے کہا  :  ابن شہاب نے مجھے اس حدیث کی دونوں سندوں کے ساتھ اس حدیث میں اسی کے مانند خبردی ا", "grades": "", "reference": "Book 7, Hadith 17", "international_number": "1967", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1968", "arabic": "وحَدَّثَنَا  ابْنُ أَبِي عُمَرَ ، حَدَّثَنَا  سُفْيَانُ ، عَنْ  أَبِي الزِّنَادِ ، عَنْ  الْأَعْرَجِ", "bengali": "", "english": "The same hadith has been narrated by Abu Huraira, but instead of the word laghauta the word laghita has been used. Abu Zinad (one of the narrators) says that laghita is the dialect of Abu Huraira, whereas it is laghauta", "french": "", "indonesian": "", "russian": "", "urdu": "ابو زناد نے عرج سے انھوں نے حضرت ابو ہریرۃ رضی اللہ تعالیٰ عنہ  سے اور انھوں نے نبی اکرم  صلی اللہ ع", "grades": "", "reference": "Book 7, Hadith 18", "international_number": "1968", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1969", "arabic": "وحَدَّثَنَا  يَحْيَى بْنُ يَحْيَى ، قَالَ: قَرَأْتُ عَلَى  مَالِكٍ . ح وحَدَّثَنَا  قُتَيْبَةُ بْنُ", "bengali": "", "english": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:There is a time on Friday at which no Muslim servant would pray and would ask Allah for a thing (that is good) but He would give it to him. Qutaiba pointed with the help of his hand that it (the time) is short", "french": "", "indonesian": "", "russian": "", "urdu": "یحییٰ بن یحییٰ اور قتیبہ  بن سعید  نے مالک بن انس انھوں نے ابو زناد سے انھوں نے اعرج سے اور انھوں نے", "grades": "", "reference": "Book 7, Hadith 19", "international_number": "1969", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1970", "arabic": "حَدَّثَنَا  زُهَيْرُ بْنُ حَرْبٍ ، حَدَّثَنَا  إِسْمَاعِيلُ بْنُ إِبْرَاهِيمَ ، حَدَّثَنَا  أَيُّوبُ", "bengali": "", "english": "Abu Huraira reported Abu'l-Qasim (the kunya of the Holy Prophet) (ﷺ) as saying:There is a time on Friday at which no Muslim would stand and pray and beg Allah for what Is good but He would give it to him; and he pointed with his hand that (this time) is short and narrow", "french": "", "indonesian": "", "russian": "", "urdu": "ایوب نے محمد سے انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی انھوں نے کہا :  ابو القاسم", "grades": "", "reference": "Book 7, Hadith 20", "international_number": "1970", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1971", "arabic": "حَدَّثَنَا  ابْنُ الْمُثَنَّى ، حَدَّثَنَا  ابْنُ أَبِي عَدِيٍّ ، عَنْ  ابْنِ عَوْنٍ ، عَنْ  مُحَمَّ", "bengali": "", "english": "A hadith like this has been narrated by Abu Huraira", "french": "", "indonesian": "", "russian": "", "urdu": "ابن عون نے محمد سے اور انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی انھوں نے کہا ابو الق", "grades": "", "reference": "Book 7, Hadith 21", "international_number": "1971", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1972", "arabic": "وحَدَّثَنِي  حُمَيْدُ بْنُ مَسْعَدَةَ الْبَاهِلِيُّ ، حَدَّثَنَا  بِشْرٌ يَعْنِي ابْنَ مُفَضَّلٍ ، ح", "bengali": "", "english": "This hadith has been narrated by Abu Huraira by another chain of transmitters", "french": "", "indonesian": "", "russian": "", "urdu": "سلمہ بن علقمہ نے محمد سے اورانھوں  نے حضرت ابو ہریرۃ رضی اللہ تعالیٰ عنہ  سے روا یت کی انھوں نے کہا", "grades": "", "reference": "Book 7, Hadith 22", "international_number": "1972", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1973", "arabic": "وحَدَّثَنَا  عَبْدُ الرَّحْمَنِ بْنُ سَلَّامٍ الْجُمَحِيُّ ، حَدَّثَنَا  الرَّبِيعُ يَعْنِي ابْنَ مُ", "bengali": "", "english": "Abu Huraira reported Allah's Apostle (ﷺ) as saying:\"There is a time on Friday at which no Muslim would ask Allah for what is good but He would give it to him.\" And further said: \"This is a very short time", "french": "", "indonesian": "", "russian": "", "urdu": "محمد بن زیاد نے حضرت ابو ہریرۃ رضی اللہ تعالیٰ عنہ  سے اور انھوں نے نبی اکرم  صلی اللہ علیہ وسلم  سے", "grades": "", "reference": "Book 7, Hadith 23", "international_number": "1973", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1974", "arabic": "وحَدَّثَنَاه  مُحَمَّدُ بْنُ رَافِعٍ ، حَدَّثَنَا  عَبْدُ الرَّزَّاقِ ، حَدَّثَنَا  مَعْمَرٌ ، عَنْ", "bengali": "", "english": "Hammam b. Munabbih reported this hadith from Abu Huraira who reported from the Messenger of Allah (ﷺ) but he did not say:\" That time is short", "french": "", "indonesian": "", "russian": "", "urdu": "ہمام بن منبہ نے حضڑت ابو ہریرۃ رضی اللہ تعالیٰ عنہ  سے اور انھوں نے نبی  صلی اللہ علیہ وسلم  سے روای", "grades": "", "reference": "Book 7, Hadith 24", "international_number": "1974", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1975", "arabic": "وحَدَّثَنِي  أَبُو الطَّاهِرِ ،  وَعَلِيُّ بْنُ خَشْرَمٍ ، قَالَا: أَخْبَرَنَا  ابْنُ وَهْبٍ ، عَنْ", "bengali": "", "english": "Abu Burda b. Abu Musa al-Ash'ari reported:'Abdullah b. Umar said to me: Did you hear anything from your father narrating something from the messenger of Allah (ﷺ) about the time on Friday? I said: Yes, I heard him say from the Messenger of Allah (ﷺ) (these words):\" It is between the time when the Imam sits down and the end of the prayer", "french": "", "indonesian": "", "russian": "", "urdu": "ابو بردہ بن ابی مو سیٰ اشعری رضی اللہ تعالیٰ عنہ  سے روا یت ہے کہا :  مجھ سے حضرت عبد اللہ بن عمر  ر", "grades": "", "reference": "Book 7, Hadith 25", "international_number": "1975", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1976", "arabic": "وحَدَّثَنِي  حَرْمَلَةُ بْنُ يَحْيَى ، أَخْبَرَنَا  ابْنُ وَهْبٍ ، أَخْبَرَنِي  يُونُسُ ، عَنْ  ابْن", "bengali": "", "english": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:The best day on which the sun has risen is Friday; on it Adam was created, on it he was made to enter Paradise, on it he. was expelled from it", "french": "", "indonesian": "", "russian": "", "urdu": "ابن شہاب نے کہا  :  مجھے عبد الرحمٰن اعرج نے خبر دی انھوں نے حضرت ابو ہریرۃ رضی اللہ تعالیٰ عنہ  کو", "grades": "", "reference": "Book 7, Hadith 26", "international_number": "1976", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1977", "arabic": "وحَدَّثَنَا  قُتَيْبَةُ بْنُ سَعِيدٍ ، حَدَّثَنَا  الْمُغِيرَةُ يَعْنِي الْحِزَامِيَّ ، عَنْ  أَبِي", "bengali": "", "english": "Abu Huraira reported the Messenger of Allah (ﷺ) as saying:The best day on which the sun has risen is Friday; on it Adam was created. on it he was made to enter Paradise, on it he was expelled from it. And the last hour will take place on no day other than Friday", "french": "", "indonesian": "", "russian": "", "urdu": "ابو زناد نے اعرج سے اور انھوں نے حضرت ابو ہریرۃ رضی اللہ تعالیٰ عنہ  سے رو یت کی کہ نبی کریم  صلی ال", "grades": "", "reference": "Book 7, Hadith 27", "international_number": "1977", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1978", "arabic": "وحَدَّثَنَا  عَمْرٌو النَّاقِدُ ، حَدَّثَنَا  سُفْيَانُ بْنُ عُيَيْنَةَ ، عَنْ  أَبِي الزِّنَادِ ، ع", "bengali": "", "english": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:We who are the last shall be the first on the Day of Resurrection, except that every Ummah was given the Book before us and we were given it after them. It was this day which Allah prescribed for us and guided us to it and the people came after us with regard to it, the Jews observing the next day and the Christians the day following that", "french": "", "indonesian": "", "russian": "", "urdu": "عمر و ناقد نے کہا  : ہمیں سفیان بن عیینہ نے ابو زناد سے حدیث سنا ئی انھوں نے اعرج سے اور انھوں نے حج", "grades": "", "reference": "Book 7, Hadith 28", "international_number": "1978", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1979", "arabic": "وحَدَّثَنَا  ابْنُ أَبِي عُمَرَ ، حَدَّثَنَا  سُفْيَانُ ، عَنْ  أَبِي الزِّنَادِ ، عَنْ  الْأَعْرَجِ", "bengali": "", "english": "A hadith like this has been narrated by Abu Huraira that the Messenger of Allah (ﷺ) said:We are the last and would be the first on the Day of Resurrection", "french": "", "indonesian": "", "russian": "", "urdu": "ابن ابی عمر نے کہا :  ہمیں سفیان نے ابو زناد سے حدیث سنا ئی انھوں نے اعرج سے اور انھوں نے حضرت ابو ہ", "grades": "", "reference": "Book 7, Hadith 29", "international_number": "1979", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1980", "arabic": "وحَدَّثَنَا  قُتَيْبَةُ بْنُ سَعِيدٍ ،  وَزُهَيْرُ بْنُ حَرْبٍ ، قَالَا: حَدَّثَنَا  جَرِيرٌ ، عَنْ", "bengali": "", "english": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:We are the last (but) we would be the first on the Day of Resurrection, and we would be the first to enter Paradise, but that they were given the Book before us and we were given after them. They disagreed and Allah guided us aright on whatever they disagreed regarding the truth. And it was this day of theirs about which they disagreed, but Allah guided us to it, and that is Friday for us; the next day is for the Jews and the day following for the Christians", "french": "", "indonesian": "", "russian": "", "urdu": "ابو صالح نے حضرت ابو ہریرۃ  رضی اللہ تعالیٰ عنہ سے روا یت کی انھوں نے کہا :  رسول اللہ  صلی اللہ علی", "grades": "", "reference": "Book 7, Hadith 30", "international_number": "1980", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1981", "arabic": "وحَدَّثَنَا  مُحَمَّدُ بْنُ رَافِعٍ ، حَدَّثَنَا  عَبْدُ الرَّزَّاقِ ، أَخْبَرَنَا  مَعْمَرٌ ، عَنْ", "bengali": "", "english": "Abu Huraira reported Muhammad, the Messenger of Allah (ﷺ), as saying:We who are the last would be the first on the Day of Resurrection but they (other Ummahs) were given the Book before us and we were given after them, and this was the day that was prescribed for them but they disagreed on it. And Allah guided us to it. and they came after us with regard to it, the Jews observing the next day and the Christians the day following that", "french": "", "indonesian": "", "russian": "", "urdu": "وہب بن منبہ کے بھا ئی ہمام بن منبہ نے کہا :  یہ حدیث ہے حضرت ابو ہریرۃ رضی اللہ تعالیٰ عنہ  نے ہمیں", "grades": "", "reference": "Book 7, Hadith 31", "international_number": "1981", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1982", "arabic": "وحَدَّثَنَا  أَبُو كُرَيْبٍ ،  وَوَاصِلُ بْنُ عَبْدِ الْأَعْلَى ، قَالَا: حَدَّثَنَا  ابْنُ فُضَيْلٍ", "bengali": "", "english": "It is narrated by Abu Huraira and Huraira that the Messenger of Allah (ﷺ) said:It was Friday from which Allah diverted those who were before us. For the Jews (the day set aside for prayer) was Sabt (Saturday), and for the Christians it was Sunday. And Allah turned towards us and guided us to Friday (as the day of prayer) for us. In fact, He (Allah) made Friday, Saturday and Sunday (as days of prayer). In this order would they (Jews and Christians) come after us on the Day of Resurrection. We are the last of (the Ummahs) among the people in this world and the first among the created to be judged on the Day of Resurrection. In one narration it is: ', to be judged among them", "french": "", "indonesian": "", "russian": "", "urdu": "ابو کریب اور واصل بن عبدالاعلیٰ نے کہا : ہم سے ابن فضیل نے ابومالک اشجعی ( سعد بن طارق )  سے حدیث بی", "grades": "", "reference": "Book 7, Hadith 32", "international_number": "1982", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1983", "arabic": "حَدَّثَنَا  أَبُو كُرَيْبٍ ، أَخْبَرَنَا  ابْنُ أَبِي زَائِدَةَ ، عَنْ  سَعْدِ بْنِ طَارِقٍ ، حَدَّث", "bengali": "", "english": "Huraira reported Allah's Messenger (ﷺ) as saying:We were guided aright to Friday (as a day of prayer and meditation), but Allah diverted those who were before us from it. The rest of the hadith is the same", "french": "", "indonesian": "", "russian": "", "urdu": "ابن ابی زائدہ نے ( ابومالک )  سعد بن طارق سے خبر دی ، انھوں نے کہا : ربعی بن حراش نے مجھے حضرت حذیفہ", "grades": "", "reference": "Book 7, Hadith 33", "international_number": "1983", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1984", "arabic": "وحَدَّثَنِي  أَبُو الطَّاهِرِ ،  وَحَرْمَلَةُ ،  وَعَمْرُو بْنُ سَوَّادٍ الْعَامِرِيُّ ، قَالَ  أَبُ", "bengali": "", "english": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:When it is Friday, the angels stand at every door of the mosque and record the people in the order of their arrival, and when the Imam sits (on the pulpit for delivering the sermon) they fold up their sheets (manuscripts of the Qur'an) and listen to the mention (of Allah). And he who comes early is like one who offers a she-camel as a sacrifice, the next like one who offers a cow, the next a ram, the next a hen, the next an egg", "french": "", "indonesian": "", "russian": "", "urdu": "ابوعبداللہ اغر نے خبر دی کہ انھوں نے حضرت ابو ہریرۃ  رضی اللہ تعالیٰ عنہ  سے سنا ، وہ کہہ رہے تھے :", "grades": "", "reference": "Book 7, Hadith 34", "international_number": "1984", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1985", "arabic": "حَدَّثَنَا  يَحْيَى بْنُ يَحْيَى ،  وَعَمْرٌو النَّاقِدُ ، عَنْ  سُفْيَانَ ، عَنْ  الزُّهْرِيِّ ، عَ", "bengali": "", "english": "This hadith has been narrated by Abu Huraira through another chain of transmitters", "french": "", "indonesian": "", "russian": "", "urdu": "سعید ( بن مسیب )  نے حضرت ابو ہریرۃ  رضی اللہ تعالیٰ عنہ  سے اور انھوں نے نبی کریم   صلی اللہ علیہ و", "grades": "", "reference": "Book 7, Hadith 35", "international_number": "1985", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1986", "arabic": "وحَدَّثَنَا  قُتَيْبَةُ بْنُ سَعِيدٍ ، حَدَّثَنَا  يَعْقُوبُ يَعْنِي ابْنَ عَبْدِ الرَّحْمَنِ ، عَنْ", "bengali": "", "english": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:There is an angel on every door of the mosque recording him first who (comes) first (to the mosque for Friday prayer). And he [the Prophet] likened him to one who offers a camel as a sacrifice and then he went on in the descending order till he reached the point at which the minimum (sacrifice) is that of an egg. And when the Imam sits (on the pulpit) the sheets are folded and they (the angels) attend to the mention of Allah", "french": "", "indonesian": "", "russian": "", "urdu": "سہیل کے والد ابو صالح سمان نے حضرت ابو ہریرۃ  رضی اللہ تعالیٰ عنہ  سے روایت کی کہ رسول اللہ   صلی ال", "grades": "", "reference": "Book 7, Hadith 36", "international_number": "1986", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1987", "arabic": "حَدَّثَنَا  أُمَيَّةُ بْنُ بِسْطَامٍ ، حَدَّثَنَا  يَزِيدُ يَعْنِي ابْنَ زُرَيْعٍ ، حَدَّثَنَا  رَوْ", "bengali": "", "english": "Abu-Huraira reported Allah's Apostle (ﷺ) as saying:He who took a bath and then came for Jumu'a prayer and then prayed what was fixed for him, then kept silence till the Imam finished the sermon, and then prayed along with him, his sins between that time and the next Friday would be forgiven, and even of three days more", "french": "", "indonesian": "", "russian": "", "urdu": "سہیل نے اپنے والد ( ابو صالح )  سے ، انھوں نے حضرت ابو ہریرۃ  رضی اللہ تعالیٰ عنہ  سے اور انھوں نے ن", "grades": "", "reference": "Book 7, Hadith 37", "international_number": "1987", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1988", "arabic": "وحَدَّثَنَا  يَحْيَى بْنُ يَحْيَى ،  وَأَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ،  وَأَبُو كَريْب ، قَالَ يَ", "bengali": "", "english": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:He who performed ablution well, then came to Friday prayer, listened (to the sermon), kept silence all (his sins) between that time and the next Friday would be forgiven with three days extra, and he who touched pebbles caused an interruption", "french": "", "indonesian": "", "russian": "", "urdu": "اعمش نے ابو صالح سے اور انھوں نے حضرت ابو ہریرۃ  رضی اللہ تعالیٰ عنہ  سے روایت کی ، انھوں نے کہا : ر", "grades": "", "reference": "Book 7, Hadith 38", "international_number": "1988", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1989", "arabic": "وحَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ،  وَإسحاق بْنُ إِبْرَاهِيمَ ، قَالَ أَبُو بَكْرٍ: حَد", "bengali": "", "english": "Jabir b. 'Abdullah reported:We used to observe (Jumu'a) prayer with the Messenger of Allah (ﷺ) and then we returned and gave rest to our camels used for carrying water. Hassan[ (one of the narrators) said: I asked Ja'far what time that was. He said.. It is the time when the sun passes the meridian", "french": "", "indonesian": "", "russian": "", "urdu": "حسن بن عیاش نے جعفر بن محمد سے ، انھوں نے اپنے والد  ( محمد  )  سے اور انھوں نے حضرت جابر بن عبداللہ", "grades": "", "reference": "Book 7, Hadith 39", "international_number": "1989", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1990", "arabic": "وحَدَّثَنِي  الْقَاسِمُ بْنُ زَكَرِيَّاءَ ، حَدَّثَنَا  خَالِدُ بْنُ مَخْلَدٍ . ح وحَدَّثَنِي  عَبْد", "bengali": "", "english": "Ja'far reported on the authority of his father:that he asked Jabir b. 'Abdullah when the Messenger of Allah (ﷺ) observed Jumu'a prayer. He said: He used to observe prayer, and we then went (back) to our camels and gave them rest. 'Abdullah made this addition in his narration: \"Till the sun passed the meridian. and the camels used for carrying water (took rest)", "french": "", "indonesian": "", "russian": "", "urdu": "قاسم بن زکریا نے کہا : ہمیں خالد بن مخلد نے حدیث بیان کی ، نیز عبداللہ بن عبدالرحمان دارمی نے کہا :", "grades": "", "reference": "Book 7, Hadith 40", "international_number": "1990", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1991", "arabic": "وحَدَّثَنَا  عَبْدُ اللَّهِ بْنُ مَسْلَمَةَ بْنِ قَعْنَبٍ ،  وَيَحْيَى بْنُ يَحْيَى ،  وَعَلِيُّ بْن", "bengali": "", "english": "Sahl b. Said said:We did not have a siesta or lunch till after the Friday prayer. (Ibn Hajr added: ) \"During the lifetime of the Messenger of Allah (ﷺ)", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن مسلمہ بن قعنب ، یحییٰ بن یحییٰ اور علی بن حجر میں سے یحییٰ نے کہا : ہمیں خبر دی اور دوسرے", "grades": "", "reference": "Book 7, Hadith 41", "international_number": "1991", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1992", "arabic": "وحَدَّثَنَا  يَحْيَى بْنُ يَحْيَى ،  وَإسحاق بْنُ إِبْرَاهِيمَ ، قَالَا: أَخْبَرَنَا  وَكِيعٌ ، عَنْ", "bengali": "", "english": "Iyas b. Salama b. al-Akwa' reported on the authority of his father:We used to observe the Friday prayer with the Messenger of Allah (ﷺ) when the sun passed the meridian. and we then returned and tried to find out afternoon shadow (of the walls for protecting themselves from the heat of the sun)", "french": "", "indonesian": "", "russian": "", "urdu": "وکیع نے یعلیٰ بن حارث محاربی سے روایت کی ، انھوں نے ایاس بن سلمہ بن اکوع سے اور انھوں نے اپنے والد (", "grades": "", "reference": "Book 7, Hadith 42", "international_number": "1992", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1993", "arabic": "وحَدَّثَنَا  إسحاق بْنُ إِبْرَاهِيمَ ، أَخْبَرَنَا  هِشَامُ بْنُ عَبْدِ الْمَلِكِ ، حَدَّثَنَا  يَعْ", "bengali": "", "english": "Iyas b. Salama b. Akwa' reported on the authority of his father, saying:We used to observe the Friday prayer with the Messenger of Allah (ﷺ), and when we returned we did not find the shadow of the walls in which we could take protection (from the heat of the sun)", "french": "", "indonesian": "", "russian": "", "urdu": "ہشام بن عبدالملک نے یعلیٰ بن حارث سے باقی ماندہ اسی سند  کے ساتھ روایت کی ہم رسول اللہ   صلی اللہ عل", "grades": "", "reference": "Book 7, Hadith 43", "international_number": "1993", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1994", "arabic": "وحَدَّثَنَا  عُبَيْدُ اللَّهِ بْنُ عُمَرَ الْقَوَارِيرِيُّ ،  وَأَبُو كَامِلٍ الْجَحْدَرِيُّ ، جميعا", "bengali": "", "english": "Ibn 'Umar said that the Messenger of Allah (ﷺ) used to deliver the sermon on Friday while standing. He would then sit and then stand (for the second sermon) as they (the Muslims) do nowadays", "french": "", "indonesian": "", "russian": "", "urdu": "حضرت ابن عمر  رضی اللہ تعالیٰ عنہ  سے روایت ہے انھوں نے کہا : رسول اللہ   صلی اللہ علیہ وسلم  جمعے ک", "grades": "", "reference": "Book 7, Hadith 44", "international_number": "1994", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1995", "arabic": "وحَدَّثَنَا  يَحْيَى بْنُ يَحْيَى ،  وَحَسَنُ بْنُ الرَّبِيعِ ،  وَأَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ", "bengali": "", "english": "Jabir b. Samura said:The Apostle of Allah (ﷺ) gave two sermons between which he sat, recited the Qur'an and exhorted the people", "french": "", "indonesian": "", "russian": "", "urdu": "ابو احوص نے سماک سے اور انھوں نے حضرت جابر بن سمرۃ  رضی اللہ تعالیٰ عنہ  سے روایت کی  ، انھوں نے کہا", "grades": "", "reference": "Book 7, Hadith 45", "international_number": "1995", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1996", "arabic": "وحَدَّثَنَا  يَحْيَى بْنُ يَحْيَى ، أَخْبَرَنَا  أَبُو خَيْثَمَةَ ، عَنْ  سِمَاكٍ ، قَالَ: أَنْبَأَن", "bengali": "", "english": "Jabir b. Samura said that the Messenger of Allah (ﷺ) used to deliver the sermon while standing. He would then sit down and then stand up and address in a standing posture; and whoever informed you that he (the Holy Prophet) delivered the sermon while sitting told a lie. By Allah. I prayed with him more than two thousand times", "french": "", "indonesian": "", "russian": "", "urdu": "ابو خثیمہ نے سماک سے روایت کی ، انھوں نے کہا : حضرت جابر بن سمرۃ  رضی اللہ تعالیٰ عنہ  نے مجھے خبر د", "grades": "", "reference": "Book 7, Hadith 46", "international_number": "1996", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1997", "arabic": "حَدَّثَنَا  عُثْمَانُ بْنُ أَبِي شَيْبَةَ ،  وَإسحاق بْنُ إِبْرَاهِيمَ ، كِلَاهُمَا، عَنْ  جَرِيرٍ ،", "bengali": "", "english": "Jabir b. Abdullah reported that the Apostle (ﷺ) was delivering the sermon on Friday in a standing posture when a caravan from Syria arrived. The people flocked towards it till no one was left (with the Holy Prophet) but twelve persons, and it was on this occasion that this verse in regard to Jumu'a was revealed.\" And when they see merchandise or sport. they break away to it and leave thee standing", "french": "", "indonesian": "", "russian": "", "urdu": "جریر نے حصین بن عبدالرحمان سے روایت کی ، انھوں نے سالم بن ابی جعد سے اور انھوں نے حضرت جابر بن عبدال", "grades": "", "reference": "Book 7, Hadith 47", "international_number": "1997", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1998", "arabic": "وحَدَّثَنَاه  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، حَدَّثَنَا  عَبْدُ اللَّهِ بْنُ إِدْرِيسَ ، عَنْ  ح", "bengali": "", "english": "This hadith has been narrated by Husain with the same chain of transmitters but with this alteration that he did not make mention of the standing position", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن ادریس نے حصین سے اسی سند کے ساتھ روایت کی ، کہا :   ( جب تجارتی قافلہ آیاتو )  رسول اللہ", "grades": "", "reference": "Book 7, Hadith 48", "international_number": "1998", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "1999", "arabic": "وحَدَّثَنَا  رِفَاعَةُ بْنُ الْهَيْثَمِ الْوَاسِطِيُّ ، حَدَّثَنَا  خَالِدٌ يَعْنِي الطَّحَّانَ ، عَ", "bengali": "", "english": "Jabir b. Abdullah reported:I was along with the Messenger of Allah (ﷺ) on Friday when a caravan arrived. The people went to it, and none but twelve persons were left behind and I was one of them; and it was on this occasion that this verse was revealed:\" And when they see merchandise or sport away to it, and leave thee standing\" (lxii. 1 1). they break", "french": "", "indonesian": "", "russian": "", "urdu": "خالد طحان نے حصین سے روایت کی ، انھوں نے سالم اور ابو سفیان سے اور انھوں نے حضرت جابر بن عبداللہ  رض", "grades": "", "reference": "Book 7, Hadith 49", "international_number": "1999", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2000", "arabic": "وحَدَّثَنَا  إِسْمَاعِيلُ بْنُ سَالِمٍ ، أَخْبَرَنَا  هُشَيْمٌ ، أَخْبَرَنَا  حُصَيْنٌ ، عَنْ  أَبِي", "bengali": "", "english": "Jabir b. Abdullah reported:While the Messenger of Allah (ﷺ) was delivering (a sermon) on Friday, a caravan of merchandise came to Medina. The Companions of the Messenger of Allah (ﷺ) rushed towards it till only twelve persons were left with him including Abu Bakr and 'Umar; and it was at this occasion that this verse was revealed.\" And when they see merchandise or sport, they break away to it", "french": "", "indonesian": "", "russian": "", "urdu": "ہشیم نے کہا : ہمیں حصین نے ابو سفیان اور سالم بن ابی جعد سے خبر دی ، انھوں نے حضرت جابربن عبداللہ  ر", "grades": "", "reference": "Book 7, Hadith 50", "international_number": "2000", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2001", "arabic": "وحَدَّثَنَا وحَدَّثَنَا  مُحَمَّدُ بْنُ الْمُثَنَّى ،  وَابْنُ بَشَّارٍ ، قَالَا: حَدَّثَنَا  مُحَمّ", "bengali": "", "english": "Ka'b b. 'Ujra reported that he entered the mosque and saw Abd al-Rahman b. Umm Hakam delivering the sermon in a sitting posture. Upon this he said:Look at this wretched person; he delivers the sermon while sitting, whereas Allah said:\" And when they see merchandise or sport, they break away to it and leave thee standing", "french": "", "indonesian": "", "russian": "", "urdu": "حضرت کعب بن عجرہ  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ وہ مسجد میں آئے  ، دیکھاکہ ( اموی والی )  عبدا", "grades": "", "reference": "Book 7, Hadith 51", "international_number": "2001", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2002", "arabic": "وحَدَّثَنِي  الْحَسَنُ بْنُ عَلِيٍّ الْحُلْوَانِيُّ ، حَدَّثَنَا  أَبُو تَوْبَةَ ، حَدَّثَنَا  مُعَا", "bengali": "", "english": "Abdullah b. Umar and Abu Huraira said that they heard Allah's Messenger (ﷺ) say on the planks of his pulpit:People must cease to neglect the Friday prayer or Allah will seal their hearts and then they will be among the negligent", "french": "", "indonesian": "", "russian": "", "urdu": "حکم بن مینا ء نے حدیث بیان کی کہا :  حضرت عبد اللہ بن عمر اور حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  نے", "grades": "", "reference": "Book 7, Hadith 52", "international_number": "2002", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2003", "arabic": "حَدَّثَنَا  حَسَنُ بْنُ الرَّبِيعِ ،  وَأَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، قَالَا: حَدَّثَنَا  أَبُو", "bengali": "", "english": "Jabir b. Samura reported:I used to pray with the Messenger of Allah (ﷺ) and both his prayer and sermon were of moderate length", "french": "", "indonesian": "", "russian": "", "urdu": "ابوا حوص نے سما ک بن حرب سے اور انھوں نے حضرت جا بربن سمرہ رضی اللہ تعالیٰ عنہ  سے روایت کی انھوں نے", "grades": "", "reference": "Book 7, Hadith 53", "international_number": "2003", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2004", "arabic": "وحَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ،  وَابْنُ نُمَيْرٍ ، قَالَا: حَدَّثَنَا  مُحَمَّدُ بْ", "bengali": "", "english": "Jabir b. Samura reported:I used to observe prayer with the Messenger of Allah (ﷺ) and his prayer was of moderate length and his sermon too was of moderate length", "french": "", "indonesian": "", "russian": "", "urdu": "ابو بکر بن ابی شیبہ اور ابن نمیر نے کہا  :  ہمیں محمد بن بشر نے حدیث بیان کی ،  ہمیں زکریا نے حدیث ب", "grades": "", "reference": "Book 7, Hadith 54", "international_number": "2004", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2005", "arabic": "وحَدَّثَنِي  مُحَمَّدُ بْنُ الْمُثَنَّى ، حَدَّثَنَا  عَبْدُ الْوَهَّابِ بْنُ عَبْدِ الْمَجِيدِ ، عَ", "bengali": "", "english": "Jabir b. Abdullah said:When Allah's Messenger (may peace he upon him) delivered the sermon, his eyes became red, his voice rose, and his anger increased so that he was like one giving a warning against the enemy and saying: \"The enemy has made a morning attack on you and in the evening too.\" He would also say: \"The Last Hour and I have been sent like these two.\" And he would join his forefinger and middle finger; and would further say: \"The best of the speech is embodied in the Book of Allah, and the best of the guidance is the guidance given by Muhammad. And the most evil affairs are their innovations; and every innovation is error.\" He would further say:, I am more dear to a Muslim even than his self; and he who left behind property that is for his family; and he who dies under debt or leaves children (in helplessness), the responsibility (of paying his debt and bringing up his children) lies on me", "french": "", "indonesian": "", "russian": "", "urdu": "عبد الوہاب بن عبد المجید  ( ثقفی  )  نے جعفر  ( صادق  )  بن محمد  ( باقر  ) سے روایت کی انھوں نے اپن", "grades": "", "reference": "Book 7, Hadith 55", "international_number": "2005", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2006", "arabic": "وحَدَّثَنَا  عَبْدُ بْنُ حُمَيْدٍ ، حَدَّثَنَا  خَالِدُ بْنُ مَخْلَدٍ ، حَدَّثَنِي  سُلَيْمَانُ بْنُ", "bengali": "", "english": "Ja'far b. Muhammad said on the authority of his father:I heard Jabir b. 'Abdullah saying that in the sermon of the Messenger of Allah (ﷺ) he praised Allah, lauded Him (and subsequently said [other words] and raised his voice, and the rest of the hadith is the same", "french": "", "indonesian": "", "russian": "", "urdu": "سلیمان بن بلال نے کہا  :  مجھ سے جعفر  بن محمد نے اپنے نے اپنے والد سے روایت کی انھوں نے کہا :  میں", "grades": "", "reference": "Book 7, Hadith 56", "international_number": "2006", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2007", "arabic": "وحَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، حَدَّثَنَا  وَكِيعٌ ، عَنْ  سُفْيَانَ ، عَنْ  جَعْفَ", "bengali": "", "english": "Jabir reported that the Messenger of Allah (ﷺ), while delivering the sermon' to the people, praised Allah, and lauded Him for what He deserves, and would then say:He whom Allah guides aright, there is none to mislead him, and he who is led astray, there is none to guide him (aright), and the best of the talk is embodied in the Book of Allah. And the rest of the hadith is the same", "french": "", "indonesian": "", "russian": "", "urdu": "سفیان نے جعفر سے انھوں نے اپنے والد  ( محمد باقر  ) سے اور انھوں نے حضرت جا بر رضی اللہ تعالیٰ عنہ س", "grades": "", "reference": "Book 7, Hadith 57", "international_number": "2007", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2008", "arabic": "وحَدَّثَنَا  إسحاق بْنُ إِبْرَاهِيمَ ،  وَمُحَمَّدُ بْنُ الْمُثَنَّى ، كلاهما، عَنْ  عَبْدِ الْأَعْل", "bengali": "", "english": "Ibn 'Abbas reported:Dimad came to Mecca and he belonged to the tribe of Azd Shanu'a, and he used to protect the person who was under the influence of charm. He heard the foolish people of Mecca say that Muhammad (ﷺ) was under the spell. Upon this he said: If 1 were to come across this man, Allah might cure him at my hand. He met him and said: Muhammad, I can protect (one) who is under the influence of charm, and Allah cures one whom He so desires at my hand. Do you desire (this)? Upon this the Messenger of Allah (ﷺ) said: Praise is due to Allah, we praise Him, ask His help; and he whom Allah guides aright there is none to lead him astray, and he who is led astray there is none to guide him, and I bear testimony to the fact that there is no god but Allah, He is One, having no partner with Him, and that Muhammad is His Servant and Messenger. Now after this he (Dimad) said: Repeat these words of yours before me, and the messenger of Allah (ﷺ) repeated these to him thrice; and he said I have heard the words of soothsayers and the words of magicians, and the words of poets, but I have never heard such words as yours, and they reach the depth (of the ocean of eloquence) ; bring forth your hand so that I should take oath of fealty to you on Islam. So he took an oath of allegiance to him. The Messenger of Allah (ﷺ) said: It (this allegiance of yours) is on behalf of your people too. He said: It is on behalf of my people too. The Messenger of Allah (ﷺ) sent an expedition and the flying column passed by his people. The leader of the flying column said to the detachment: Did you find anything from these people? One of the people said: I found a utensil for water. Upon this he (the commander) said: Return it, for he is one of the people of Dimad", "french": "", "indonesian": "", "russian": "", "urdu": "حضرت ابن عباس  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ ضمادمکہ آیا ، وہ  ( قبیلہ )  از دشنوء سے تھا اور", "grades": "", "reference": "Book 7, Hadith 58", "international_number": "2008", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2009", "arabic": "حَدَّثَنِي  سُرَيْجُ بْنُ يُونُسَ ، حَدَّثَنَا  عَبْدُ الرَّحْمَنِ بْنُ عَبْدِ الْمَلِكِ بْنِ أَبْجَ", "bengali": "", "english": "Abu Wa'il reported:'Ammar delivered to us the sermon. It was short and eloquent. When he (, Ammir) descended (from the pulpit) we said to him: 0 Abd al-Yaqzn, you have delivered a short and eloquent sermon. Would that you had lengthened (the sermon). He said: I have heard the Messenger of Allah (ﷺ) as saying: The lengthening of prayer by a man and the shortness of the sermon is the sign of his understanding (of faith). So lengthen the prayer and shorten the sermon, for there is charm (in precise) expression", "french": "", "indonesian": "", "russian": "", "urdu": "ابو وائل نے کہا : ہمارے سامنے حضرت عمار رضی اللہ تعالیٰ عنہ نے خطبہ دیا ۔ انتہائی مختصر اورانتہائی ب", "grades": "", "reference": "Book 7, Hadith 59", "international_number": "2009", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2010", "arabic": "حَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ،  وَمُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ ، قَال", "bengali": "", "english": "Adi b. Hatim reported:that a person recited a sermon before the Messenger of Allah (ﷺ) thus: He who obeys Allah and His Apostle, he in fact follows the right path, and he who disobeys both of them, he goes astray. Upon this the Messenger of Allah (ﷺ) said: What a bad speaker you are; say: He who disobeys Allah and His Apostle. Ibn Numair added: He in fact went astray", "french": "", "indonesian": "", "russian": "", "urdu": "ابو بکر بن ابی شیبہ اور محمد بن عبداللہ بن نمیر نے کہا : ہمیں وکیع نے سفیان سے حدیث بیان کی ، انھوں", "grades": "", "reference": "Book 7, Hadith 60", "international_number": "2010", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2011", "arabic": "حَدَّثَنَا  قُتَيْبَةُ بْنُ سَعِيدٍ ،  وَأَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ،  وَإسحاق الْحَنْظَلِيُّ", "bengali": "", "english": "Safwan b. Ya'la reported on the authority of his father that he heard the Messenger of Allah (ﷺ) reciting (verses of the Qur'an) on the pulpit. and\" They cried:0 Malik", "french": "", "indonesian": "", "russian": "", "urdu": "صفوان کے والد حضرت یعلیٰ بن امیہ  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ انھوں نے نبی کریم  صلی اللہ عل", "grades": "", "reference": "Book 7, Hadith 61", "international_number": "2011", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2012", "arabic": "وحَدَّثَنِي  عَبْدُ اللَّهِ بْنُ عَبْدِ الرَّحْمَنِ الدَّارِمِيُّ ، أَخْبَرَنَا  يَحْيَى بْنُ حَسَّا", "bengali": "", "english": "Amra daughter of Abd al-Rahman reported on the authority of the sister of Amra:I memorised (surah) \"Qaf, by the glorious Qur'an\" from the mouth of the Messenger of Allah (ﷺ) on Friday for he recited it on the pulpit on every Friday", "french": "", "indonesian": "", "russian": "", "urdu": "سلیمان بن بلال نے یحییٰ بن سعید سے روایت کی ، انھوں نے عمرہ بنت عبدالرحمان ( بن سعد بن زرارہ انصاریہ", "grades": "", "reference": "Book 7, Hadith 62", "international_number": "2012", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2013", "arabic": "وحَدَّثَنِيهِ  أَبُو الطَّاهِرِ ، أَخْبَرَنَا  ابْنُ وَهْبٍ ، عَنْ  يَحْيَى بْنِ أَيُّوبَ ، عَنْ  يَ", "bengali": "", "english": "The daughter of Haritha b. Nu'man said:I did not memorise (Surah) Qaf but from the mouth of the Messenger of Allah (ﷺ) as he used to deliver the. sermon along with it on every Friday. She also added: Our oven and that of the Messenger of Allah (ﷺ) was one", "french": "", "indonesian": "", "russian": "", "urdu": "یحییٰ بن ایوب نے یحییٰ بن سعید سے ، انھوں نے عمرہ سے اور انھوں نے اپنی بہن سے جو عمر میں ان سے بڑی ت", "grades": "", "reference": "Book 7, Hadith 63", "international_number": "2013", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2014", "arabic": "حَدَّثَنِي  مُحَمَّدُ بْنُ بَشَّارٍ ، حَدَّثَنَا  مُحَمَّدُ بْنُ جَعْفَرٍ ، حَدَّثَنَا  شُعْبَةُ ، ع", "bengali": "", "english": "Umm Bisham hint Haritha b. Nu'man said:Our oven and that of the Messenger of Allah (ﷺ) was one for two years, or for one year or for a part of a year; and I learnt\" Qaf. By the Glorious Qur'an\" from no other source than the tongue of Allah's Messenger (ﷺ) who used to recite it every Friday on the pulpit when he delivered the sermon to the people", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن محمد بن معن نے حارثہ بن نعمان کی بیٹی ( ام ہشام )  سے روایت کی ، انھوں نے کہا : میں نے سو", "grades": "", "reference": "Book 7, Hadith 64", "international_number": "2014", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2015", "arabic": "وحَدَّثَنَا  عَمْرٌو النَّاقِدُ ، حَدَّثَنَا  يَعْقُوبُ بْنُ إِبْرَاهِيمَ بْنِ سَعْدٍ ، حَدَّثَنَا", "bengali": "", "english": "It was narrated that Umm Hisham bin Harithah bin An-Nu'man said:\"Our oven and the oven of the Messenger of Allah (ﷺ) were the same for two years, or for one year and part of a year. And I only learned \"Surah Qaf. By the Glorious Quran\" from the tongue of the Messenger of Allah (ﷺ), who used to recited it every Friday from the Minbar, when he addresses the people", "french": "", "indonesian": "", "russian": "", "urdu": "یحییٰ بن عبداللہ بن عبدالرحمان بن سعد نے زرارہ نے ام ہشام بنت حارثہ بن نعمان  رضی اللہ تعالیٰ عنہ  س", "grades": "", "reference": "Book 7, Hadith 65", "international_number": "2015", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2016", "arabic": "وحَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، حَدَّثَنَا  عَبْدُ اللَّهِ بْنُ إِدْرِيسَ ، عَنْ  حُ", "bengali": "", "english": "Umara b. Ruwaiba said he saw Bishr b. Marwan on the pulpit raising his hands and said:Allah, disfigure these hands! I have seen Allah's Messenger (ﷺ) gesture no more than this with his hands, and he pointed with his forefinger", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن ادریس نے حصین سے اور انھوں نے حضرت عمارہ بن رویبہ ( ثقفی )   رضی اللہ تعالیٰ عنہ  سے روای", "grades": "", "reference": "Book 7, Hadith 66", "international_number": "2016", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2017", "arabic": "وحَدَّثَنَاه  قُتَيْبَةُ بْنُ سَعِيدٍ ، حَدَّثَنَا  أَبُو عَوَانَةَ ، عَنْ  حُصَيْنِ بْنِ عَبْدِ الر", "bengali": "", "english": "This hadith has been narrated by another chain of transmitters on the authority of Husain b. Abd al-Rahman", "french": "", "indonesian": "", "russian": "", "urdu": "ابو  عوانہ نے حصین بن عبدالرحمان سے روایت کی ، انھوں نے کہا : میں نے جمعے کے دن بشر بن مروان کو دونو", "grades": "", "reference": "Book 7, Hadith 67", "international_number": "2017", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2018", "arabic": "وحَدَّثَنَا  أَبُو الرَّبِيعِ الزَّهْرَانِيُّ ،  وَقُتَيْبَةُ بْنُ سَعِيدٍ ، قَالَا: حَدَّثَنَا  حَم", "bengali": "", "english": "Jabir b. 'Abdullah reported that while Allah's Messenger (ﷺ) was delivering the sermon on Friday a person came there, and the Messenger of Allah (ﷺ) said to him:So and so, have you prayed (two rak'ahs)? He said: No. He (the Holy Prophet) said: Then stand and pray", "french": "", "indonesian": "", "russian": "", "urdu": "حماد بن زید نے عمرو بن دینار سے اور انھوں نے حضرت جابر بن عبداللہ  رضی اللہ تعالیٰ عنہ  سے روایت کی", "grades": "", "reference": "Book 7, Hadith 68", "international_number": "2018", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2019", "arabic": "حَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ،  وَيَعْقُوبُ الدَّوْرَقِيُّ ، عَنْ  ابْنِ عُلَيَّةَ ،", "bengali": "", "english": "This hadith is narrated by Jabir through another chain of transmitters but Hammad (one of the narrators) made no mention of the two rak'ahs", "french": "", "indonesian": "", "russian": "", "urdu": "ایوب نے عمرو ( بن دینار )  سے  ، انھوں نے حضرت جابر  رضی اللہ تعالیٰ عنہ  سے اور انھوں نے نبی کریم", "grades": "", "reference": "Book 7, Hadith 69", "international_number": "2019", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2020", "arabic": "وحَدَّثَنَا  قُتَيْبَةُ بْنُ سَعِيدٍ ،  وَإسحاق بْنُ إِبْرَاهِيمَ ، قَالَ قُتَيْبَةُ: حَدَّثَنَا، وَ", "bengali": "", "english": "Jabir b. 'Abdullah said that a person entered the Mosque while the Messenger of Allah (ﷺ) was delivering the sermon on Friday. Upon this he (the Holy Prophet) said:Have you observed prayer? He said: No. He (the Holy Prophet) said: Stand and offer the two rak'ahs. According to Qutaiba, the words are:\" He said: Offer two rak'ahs", "french": "", "indonesian": "", "russian": "", "urdu": "قتیبہ بن سعید اور اسحاق بن ابراہیم میں سے قتیبہ نے کہا : ہمیں حدیث  سنائی اور اسحاق نے کہا : ہمیں خب", "grades": "", "reference": "Book 7, Hadith 70", "international_number": "2020", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2021", "arabic": "وحَدَّثَنِي  مُحَمَّدُ بْنُ رَافِعٍ ،  وَعَبْدُ بْنُ حميد ، قَالَ  ابْنُ رَافِعٍ : حَدَّثَنَا  عَبْد", "bengali": "", "english": "Jabir b. 'Abdullah reported that a person came (in the Mosque) while the Messenger of Allah (ﷺ) was delivering the sermon on Friday (standing) on the pulpit. He (the Holy Prophet) said to him:Have you offered two rak'ahs? He said: No. Upon this he said: Then observe (them)", "french": "", "indonesian": "", "russian": "", "urdu": "ابن جریج نے کہا : ہمیں عمرو بن دینار نے خبر دی کہ انھوں نے حضرت جابر بن عبداللہ  رضی اللہ تعالیٰ عنہ", "grades": "", "reference": "Book 7, Hadith 71", "international_number": "2021", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2022", "arabic": "حَدَّثَنَا  مُحَمَّدُ بْنُ بَشَّارٍ ، حَدَّثَنَا  مُحَمَّدٌ وَهُوَ ابْنُ جَعْفَرٍ ، حَدَّثَنَا  شُعْ", "bengali": "", "english": "Jabir b. 'Abdullah said that the Messenger of Allah (ﷺ) delivered the sermon and said:When any one of you comes for the Friday (prayer) and the Imam comes out (from his apartment), (even then) should observe two rak'ahs (of prayer)", "french": "", "indonesian": "", "russian": "", "urdu": "شعبہ نے عمرو ( بن دینار )  سے روایت کی ، انھوں نے کہا : میں نے حضرت جابر بن عبداللہ  رضی اللہ تعالیٰ", "grades": "", "reference": "Book 7, Hadith 72", "international_number": "2022", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2023", "arabic": "وحَدَّثَنَا  قُتَيْبَةُ بْنُ سَعِيدٍ ، حَدَّثَنَا  لَيْثٌ . ح وحَدَّثَنَا  مُحَمَّدُ بْنُ رُمْحٍ ، أ", "bengali": "", "english": "Jabir reported that Sulaik Ghatafani came on Friday (for prayer) while the Messenger of Allah (ﷺ) was sitting on the pulpit. Sulaik also sat down before observing prayer. The Apostle of Allah (ﷺ) said:Have you observed two rak'ahs? He said: No. He (the Holy Prophet) said: Stand and observe them", "french": "", "indonesian": "", "russian": "", "urdu": "ابو زبیر نے حضرت جابر  رضی اللہ تعالیٰ عنہ  سے روایت کی کہ سلیک غطفانی  رضی اللہ تعالیٰ عنہ  جمعے کے", "grades": "", "reference": "Book 7, Hadith 73", "international_number": "2023", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2024", "arabic": "وحَدَّثَنَا  إسحاق بْنُ إِبْرَاهِيمَ ،  وَعَلِيُّ بْنُ خَشْرَمٍ ، كلاهما، عَنْ  عِيسَى بْنِ يُونُسَ", "bengali": "", "english": "Jabir b. 'Abdullah reported:Sulaik Ghatafani came on Friday when the Messenger of Allah (ﷺ) was delivering the sermon. He (Sulaik) sat down. He (the Holy Prophet) said to him: 0 Sulaik I stand and observe two rak'ahs and make them short, and then said: When any one of you comes on Friday, while the Imam delivers the sermon, he should observe two rak'ahs and should make them short", "french": "", "indonesian": "", "russian": "", "urdu": "ابو سفیان ( طلحہ بن نافع واسطی )  نے حضرت جابر بن عبداللہ  رضی اللہ تعالیٰ عنہ  سے  روایت کی ، انھوں", "grades": "", "reference": "Book 7, Hadith 74", "international_number": "2024", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2025", "arabic": "وحَدَّثَنَا  شَيْبَانُ بْنُ فَرُّوخَ ، حَدَّثَنَا  سُلَيْمَانُ بْنُ الْمُغِيرَةِ ، حَدَّثَنَا  حُمَي", "bengali": "", "english": "Abu Rifa'a reported:I came to the Prophet (ﷺ) when he was delivering the sermon, and I said: Messenger of Allah, here is a stranger and he wants to learn about this religion and he does not know what this religion is. The Messenger of Allah (ﷺ) looked at me and left his sermon till he came to me, and he was given a chair and I thought that Its legs were made of iron. The Messenger of Allah (ﷺ) sat In it and he began to teach me what Allah had taught him. He then came (to the pulpit) for his sermon and completed it to the end", "french": "", "indonesian": "", "russian": "", "urdu": "حضرت  ابو رفاعہ ( تمیم بن اُسید عدوی  رضی اللہ تعالیٰ عنہ  )  نے کہا کہ میں نبی   صلی اللہ علیہ وسلم", "grades": "", "reference": "Book 7, Hadith 75", "international_number": "2025", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2026", "arabic": "حَدَّثَنَا  عَبْدُ اللَّهِ بْنُ مَسْلَمَةَ بْنِ قَعْنَبٍ ، حَدَّثَنَا  سُلَيْمَانُ وَهُوَ ابْنُ بِلَ", "bengali": "", "english": "Ibn Abu Rafi' said:Marwan appointed Abu Huraira as his deputy in Medina and he himself left for Mecca. Abu Huraira led us in the Jumu'a prayer and recited after Surah Jumu'a in the second rak'ah:\" When the hypocrites came to thee\" (Surah 63). I then met Abu Huraira as he came back and said to him: You have recited two surahs which 'Ali b. Abu Talib used to recite in Kufah. Upon this Abu Huraira said: I heard the Messenger of Allah (ﷺ) reciting these two in the Friday (prayer)", "french": "", "indonesian": "", "russian": "", "urdu": "سلیمان جو ہلال ( تمیمی )  کے بیٹے ہیں ، انھوں نے جعفر  ( صادق )  سے ، انھوں نے اپنے والد سے اور انھو", "grades": "", "reference": "Book 7, Hadith 76", "international_number": "2026", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2027", "arabic": "وحَدَّثَنَا  قُتَيْبَةُ بْنُ سَعِيدٍ ،  وَأَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، قَالَا: حَدَّثَنَا  حَا", "bengali": "", "english": "This hadith is narrated by Abdullah b. Abu Rafi' with the same chain of transmitters but with this modification:\" That he recited Surah Jumu'a (lxii.) in the first rak'ah and\" The hypocrites came\" in the second rak'ah", "french": "", "indonesian": "", "russian": "", "urdu": "حاتم بن اسماعیل اور عبدالعزیز دراوردی دونوں نے ( اپنی اپنی سندکے ساتھ )  جعفر سے روایت کی ، انھوں نے", "grades": "", "reference": "Book 7, Hadith 77", "international_number": "2027", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2028", "arabic": "حَدَّثَنَا  يَحْيَى بْنُ يَحْيَى ،  وَأَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ،  وَإسحاق ، جميعا، عَنْ  جَر", "bengali": "", "english": "Nu'man b. Bashir reported that the Messenger of Allah (ﷺ) used to recite on two 'Ids and in Friday prayer:\" Glorify The name of Thy Lord, the Most High\" (Surah lxxxvii.), and:\" Has there come to thee the news of the overwhelming event\" (lxxxviii.). And when the 'Id and Jumu'a combined on a day he recited these two (surah) in both the prayers", "french": "", "indonesian": "", "russian": "", "urdu": "جریر نے ابراہیم بن محمد بن منتشر سے ، انھوں نے اپنے والد سے ، انھوں نے حضرت نعمان بن بشیر کے آزاد کر", "grades": "", "reference": "Book 7, Hadith 78", "international_number": "2028", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2029", "arabic": "وحَدَّثَنَاه  قُتَيْبَةُ بْنُ سَعِيدٍ ، حَدَّثَنَا  أَبُو عَوَانَةَ ، عَنْ  إِبْرَاهِيمَ بْنِ مُحَمّ", "bengali": "", "english": "This hadith has been narrated by Ibrahim b Muhammad b. al-Muntashir with the same chain of transmitters", "french": "", "indonesian": "", "russian": "", "urdu": "ابو عوانہ نے ابراہیم بن محمد بن منتشر سے اسی سند کے ساتھ ( اسی کے مانند )  ر وایت کی ۔", "grades": "", "reference": "Book 7, Hadith 79", "international_number": "2029", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2030", "arabic": "وحَدَّثَنَا  عَمْرٌو النَّاقِدُ ، حَدَّثَنَا  سُفْيَانُ بْنُ عُيَيْنَةَ ، عَنْ  ضَمْرَةَ بْنِ سَعِيد", "bengali": "", "english": "Dahhak b. Qais wrote to Nu'man b. Bashir asking him what the Messenger of Allah (ﷺ) recited on Friday besides Surah Jumu'a He said that he recited:\" Has there reached...\" (Surah lxxxviii)", "french": "", "indonesian": "", "russian": "", "urdu": "عبیداللہ بن عبداللہ نے کہا : ضحاک بن قیس نے حضرت نعمان بن بشیر  رضی اللہ تعالیٰ عنہ  کوخط لکھ کر پوچ", "grades": "", "reference": "Book 7, Hadith 80", "international_number": "2030", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2031", "arabic": "حَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، حَدَّثَنَا  عَبْدَةُ بْنُ سُلَيْمَانَ ، عَنْ  سُفْيَا", "bengali": "", "english": "Ibn Abbas reported:The Apostle of Allah (ﷺ) used to recite in the morning prayer on Friday Surah\" Alif-Lam-Mim, Tanz'il ul-Sajda\" (Surah xxxii.): Surely there came over the man a time\" (Surah lxxvii) and he used to recite in Jumu'a prayer Surahs Jumu'a and al-Munafiqin", "french": "", "indonesian": "", "russian": "", "urdu": "عبدہ بن سلیمان نے سفیان سے روایت کی ، انھوں نے مخول بن راشد سے ، انھوں نے مسلم البطین سے ، انہوں نے", "grades": "", "reference": "Book 7, Hadith 81", "international_number": "2031", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2032", "arabic": "وحَدَّثَنَا  ابْنُ نُمَيْرٍ ، حَدَّثَنَا  أَبِي . ح وحَدَّثَنَا  أَبُو كُرَيْبٍ ، حَدَّثَنَا  وَكِيع", "bengali": "", "english": "A hadith like this has been narrated by Sufyan with the same chain of transmitters", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن نمیر اور وکیع دونوں نے سفیان سے اسی سند کے ساتھ اسی ( سابقہ حدیث )  کے مانند روایت کی ۔", "grades": "", "reference": "Book 7, Hadith 82", "international_number": "2032", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2033", "arabic": "وحَدَّثَنَا  مُحَمَّدُ بْنُ بَشَّارٍ ، حَدَّثَنَا  مُحَمَّدُ بْنُ جَعْفَرٍ ، حَدَّثَنَا  شُعْبَةُ ،", "bengali": "", "english": "Mukhawwil has narrated this hadith on the authority of Sufyan", "french": "", "indonesian": "", "russian": "", "urdu": "شعبہ نے مخول سے اسی سندکے ساتھ دونوں نمازوں کے بارے میں اسی ( سابقہ حدیث )  کے مانند روایت کی جس طرح", "grades": "", "reference": "Book 7, Hadith 83", "international_number": "2033", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2034", "arabic": "حَدَّثَنِي  زُهَيْرُ بْنُ حَرْبٍ ، حَدَّثَنَا  وَكِيعٌ ، عَنْ  سُفْيَانَ ، عَنْ  سَعْدِ بْنِ إِبْرَا", "bengali": "", "english": "Abu Huraira reported that the Messenger of Allah (ﷺ) used to recite in the dawn prayer on Friday\" Alif-Lam-Mim, Tanzil\" and\" Surely there came", "french": "", "indonesian": "", "russian": "", "urdu": "سفیان نے سعد بن ابراہیم سے ، انہوں نے عبدالرحمان اعرج سے ، انھوں نے ابوہریرۃ  رضی اللہ تعالیٰ عنہ  س", "grades": "", "reference": "Book 7, Hadith 84", "international_number": "2034", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2035", "arabic": "حَدَّثَنِي  أَبُو الطَّاهِرِ ، حَدَّثَنَا  ابْنُ وَهْبٍ ، عَنْ  إِبْرَاهِيمَ بْنِ سَعْدٍ ، عَنْ  أَب", "bengali": "", "english": "Abu Huraira reported that the Messenger of Allah (ﷺ) used to recite in the dawn prayer on Friday:\" Alif-Lam-Mim, Tanzil\" in the first rak'ah, and in the second one:\" Surely there came over the man a time when he was nothing that could be mentioned", "french": "", "indonesian": "", "russian": "", "urdu": "۔  ابراہیم بن سعد نے اپنے والد ( سعد بن ابراہیم ) سے ، انھوں نے عبدالرحمان اعرج سے اور انھوں نے حضرت", "grades": "", "reference": "Book 7, Hadith 85", "international_number": "2035", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2036", "arabic": "وحَدَّثَنَا  يَحْيَى بْنُ يَحْيَى ، أَخْبَرَنَا  خَالِدُ بْنُ عَبْدِ اللَّهِ ، عَنْ  سُهَيْلٍ ، عَنْ", "bengali": "", "english": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:When any one of you observes the Jumu'a prayer (two obligatory rak'ahs in congregation), he should observe four (rak'ahs) afterwards", "french": "", "indonesian": "", "russian": "", "urdu": "۔  خالد بن عبداللہ نے سہیل سے ، انھوں نے اپنے والد  ( ابوصالح )  سے اور انھوں نے حضرت ابو ہریرۃ  رضی", "grades": "", "reference": "Book 7, Hadith 86", "international_number": "2036", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2037", "arabic": "وحَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ،  وَعَمْرٌو النَّاقِدُ ، قَالَا: حَدَّثَنَا  عَبْدُ ا", "bengali": "", "english": "Suhail reported on the authority of Abu Huraira that the Messenger of Allah (ﷺ) said:When you observe prayer after (the two obligatory rak'ahs) of Jumu'ah, you should observe four rak'ahs (and 'Amr in his narration has made this addition that Ibn Idris said this on the authority of Suhail): And if you are in a hurry on account of something, you should observe two rak'ahs in the mosque and two when you return (to your house)", "french": "", "indonesian": "", "russian": "", "urdu": "ابوبکر بن ابی شیبہ اور عمرو الناقد نے کہا : ہمیں عبداللہ بن ادریس نے سہیل سے حدیث سنائی ، انھوں نے ا", "grades": "", "reference": "Book 7, Hadith 87", "international_number": "2037", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2038", "arabic": "وحَدَّثَنِي  زُهَيْرُ بْنُ حَرْبٍ ، حَدَّثَنَا  جَرِيرٌ . ح وحَدَّثَنَا  عَمْرٌو النَّاقِدُ ،  وَأَب", "bengali": "", "english": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:When any one amongst you observes prayer after Jumu'a, he should observe four rak'ahs. (In the hadith transmitted by Jarir the word minkum is not recorded)", "french": "", "indonesian": "", "russian": "", "urdu": "جریر اور سفیان نے سہیل سے ، انھوں نے اپنے والد سے اور انھوں نے حضرت ابو ہریرۃ  رضی اللہ تعالیٰ عنہ", "grades": "", "reference": "Book 7, Hadith 88", "international_number": "2038", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2039", "arabic": "وحَدَّثَنَا  يَحْيَى بْنُ يَحْيَى ،  وَمُحَمَّدُ بْنُ رُمْحٍ ، قَالَا: أَخْبَرَنَا  اللَّيْثُ . ح وح", "bengali": "", "english": "Nafi' reported that when 'Abdullah (b. 'Umar) observed the Friday prayer and came back he observed two rak'ahs in his house, and then said:The Messenger of Allah (may peace be updn him) used to do this", "french": "", "indonesian": "", "russian": "", "urdu": "لیث نے نافع سے اورانھوں نے حضرت عبداللہ بن عمر  رضی اللہ تعالیٰ عنہ  سے روایت کی کہ جب وہ جمعہ پڑھ ل", "grades": "", "reference": "Book 7, Hadith 89", "international_number": "2039", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2040", "arabic": "وحَدَّثَنَا  يَحْيَى بْنُ يَحْيَى ، قَالَ: قَرَأْتُ عَلَى  مَالِكٍ ، عَنْ  نَافِعٍ ، عَنْ  عَبْدِ ال", "bengali": "", "english": "Abdullah b. 'Umar, while describing the Nafl prayer of the Messenger of Allah (ﷺ), said:He did not observe (Nafl) prayer after Jumu'a till he went back and observed two rak'ahs in his house. Yahya said: I guess that I uttered these words (before Imam Malik) that he of course observed (them)", "french": "", "indonesian": "", "russian": "", "urdu": "یحییٰ بن یحییٰ نے کہا : میں نے امام مالکؒ  پر ( حدیث کی )  قراءت کی ، انھوں نے نافع سے اورانھوں نے ح", "grades": "", "reference": "Book 7, Hadith 90", "international_number": "2040", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2041", "arabic": "حَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ،  وَزُهَيْرُ بْنُ حَرْبٍ ،  وَابْنُ نُمَيْرٍ ، قَالَ ز", "bengali": "", "english": "Salim narrated on the authority of his father that the Messenger of Allah (ﷺ) used to observe two rak'ahs after Jumu'a", "french": "", "indonesian": "", "russian": "", "urdu": "سالم نے اپنے والد ( حضرت عبداللہ بن عمر  رضی اللہ تعالیٰ عنہ  )  سے روایت کی کہ نبی اکرم  صلی اللہ ع", "grades": "", "reference": "Book 7, Hadith 91", "international_number": "2041", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2042", "arabic": "حَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، حَدَّثَنَا  غُنْدَرٌ ، عَنْ  ابْنِ جُرَيْجٍ ، قَالَ:", "bengali": "", "english": "Umar b. `Ata' b. Abu Khuwar said that Nafi` b. Jubair sent him to al- Sa'ib the son of Namir's sister to ask him about what he had seen in the prayer of Mu`awiya. He said:Yes, I observed the Jumu`a prayer along with him in Maqsura and when the Imam pronounced salutation I stood up at my place and observed (Sunan rak`ahs). As he entered (the apartment) he sent for me and said: Do not repeat what you have done. Whenever you have observed the Jumu`a prayer, do not observe (Sunan prayer) till you, have talked or gone out, for the Messenger of Allah (ﷺ) had ordered us to do this and not to combine two (types of) prayers without talking or going out", "french": "", "indonesian": "", "russian": "", "urdu": "غندر نے ابن جریج سے روایت کی ، انھوں نے کہا : مجھے عمر بن عطاء بن ابی خوار نے بتایا کہ نافع بن جبیر", "grades": "", "reference": "Book 7, Hadith 92", "international_number": "2042", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
{"hadithnumber": "2043", "arabic": "وحَدَّثَنَا هَارُونُ بْنُ عَبْدِ اللَّهِ ، حَدَّثَنَا  حَجَّاجُ بْنُ مُحَمَّدٍ ، قَالَ: قَالَ  ابْنُ", "bengali": "", "english": "The same hadith is narrated on the authority of 'Umar b. Ata' but with this modification:When he (the Imam) pronounced salutation I stood up at my place. No mention was made of the Imam in it", "french": "", "indonesian": "", "russian": "", "urdu": "حجاج بن محمد نے کہا : ابن جریج نے کہا :  مجھے عمر بن عطاء نے بتایا کہ نافع بن جبیر نے انھیں نمر کے ب", "grades": "", "reference": "Book 7, Hadith 93", "international_number": "2043", "narrator_chain": "", "chapter_intro": "The Book of Prayer - Friday"}
