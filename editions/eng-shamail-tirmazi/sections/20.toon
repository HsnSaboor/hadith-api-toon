  section_name: Chapter 20
  hadith_first: 123
  hadith_last: 125

hadiths[3]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
123,"Qaila bint Makhrama said that she saw Allah’s Messenger (Allah bless him and give him peace) in the mosque squatting on his heels. She said: ""When I saw Allah’s Messenger (Allah bless him and give him peace) displaying humility in the mosque, I trembled with fright.""",,,48838,"'Abdu’llah ibn Hassan reported on the authority of his grandmothers:",Chapter 20
124,"His paternal uncle said that he saw the Prophet (Allah bless him and give him peace) lying on his back in the mosque, placing one of his legs over the other.",,,48839,"'Abbad ibn Tamim reported:",Chapter 20
125,"“When Allah’s Messenger (Allah bless him and give him peace) sat in the mosque, he pressed his legs against his stomach with his hands.”",,,48840,"Abu Sa'id al-Khudri said:",Chapter 20
