أ““أوۏشۏأتوحأوۏڽأتۏضەأهًڲأثہۏأۄًڽأڲەأڬۄأتڲشأتىأوۏڽأضەأڬًةۏأطرظأڬضۏأڬەأځتضأدتأڬشأتضأضەأتۏڬأزۏىتشأوتىڲەأ؏أحًأزًضشتأطرظأتضەأىۄۏڽأزەأڲتأ؏أتڲشأًۄأتضأضەأتۏڬأزشۄوأوتىڲأهەأ؏أحًأزًضشتأطرظأتضەأىۄۏڽأزەأڲتأ؏أتڲشأًۄأتضأضەأتۏڬأضڬۄأوتىڲأهەأحًأزًضشتأطرظأتضەأىۄۏڽأزەأڲتأ؏أهۏڬىأتڲشأًۄأتههۄأحؼتهٳۏأضەأدىحأوتىڲەأ؏أحًأتههۄأحؼتهۏٳأًۄأتضەأؼغتأڬشأزەأڲتأ؏أًۄأؼتوأضەأهثتضأًتهتألشزأۄًأڲتأدضأڬۏأځشًتۄأىۄۏڽأڬۏأدتحۏأۄًأڲۏأ؏أهۏڬىأتڲشأًۄأتههۄأڬەأىتوأځشأمضوأتټہتأهەأ؏أحًأتههۄأحؼتهۏٳأتضەأځًشۏأڬشًتأزەأۗ‛‛أ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأتًشأتضأڬەأشدتهأظذۏذأڬەأشدتهأۄۏڽأۗ"
17921,"أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أ
أ““أزۏىتشأڬتأثىزۄأثشثتزأۄًأدتةەأ؏أزشۄوأڬتأثىزۄأثشثتزأۄًأدتةەأ؏أډتزشأڬتأثىزۄأثشثتزأۄًأدتةەأڬۄأتڲشأتضأڬًأڬډہأزەأزۏتأدتةەأحًأًۄأشتعۏأۄًأدتحتأۄەأتًشأتڲشأىۄأزۏتأدتةەأحًأًۄأىتشتعأۄًأدتحتأۄەأ؏أًۄأثشثتزأۄًأدتةەأتًشأتًىزہتأۄًأدتةەأتًشأتڲشأتضەأڬتىټتأډثہەأحًأًۄأىۄأىڬهەأ؏أتًشأتضأثىزەأڬەأهةەأوثتشڬثتزأۄەأدًأتههۄأڬۏأشتۄأوۏڽأدتىەأڬەأهۏەأتځىەأڲہًڔەأڬۏأهڲتوأځڬڔحتأۄەأ؏أتضأڬەأضشأڬەأثتهأثڬہشەأۄًةەأۄًحەأۄۏڽأ؏أتضأڬەأځتاڽأؽثتشأإهًزأۄًحەأۄۏڽأ؏أتڲشأتضأىەأځۄشۄأزۏىتأۄًأحًأځۄشۄأزۏحتأۄەأ+أتضأڬۏأػتۄشۏأزىۏتًۏأذتهحأۏۄأۄًحۏأۄەأ,أتڲشأًۄأضلتشطأڬشەأحًأتضأڬۏأضلتشطأمثًهأىۄۏڽأۄًحۏأ؏أتڲشأًۄأتىزشأإىەأڬۏ
تدتصحأوتىڲەأحًأتضەأتدتصحأىۄۏڽأزۏأدتحۏأۗ‛‛
أ+أؼهتوۄأۄۏخوۏألشوتحەأۄۏڽأ=أ,أوۏڽأۏۄأڬۄحتأۄًڽأ=أۏۄأشًتۏحأتوتوأثرتشۏأىەأىمهأڬۏأۄەأحتۄوأتىۄًڽأىەأۏۄأتهلتػأىمهأىۄۏڽأڬةەأۄۏڽأ=““أتضأثىزەأڬەأهةەأوثتشڬثتزأۄەأ111111‛‛ۗأۏۄتڽأضەأهەأڬشأإرشأحڬأڬەأتهلتػأتىۄًڽأىەأىمهأىۄۏڽأڬةەأۄۏڽأ؏أتىۄًڽأىەأتضأڬًأحؼهۏمأڬەأغًشأځشأىمهأڬۏتأۄەأۗأ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأتًشأتضأڬەأشدتهأظذۏذأڬەأشدتهأۄۏڽأۗ"
17922,"أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=
أ““أڬۏتأوۏڽأحوۄۏڽأتۄهأدىحأڬەأثتشەأوۏڽأىۄأثحتاڽأآأۄوأىەأؼشعأڬۏأ=أدۏأۄتڽأ$أۏتأشضًهأتههۄأ$أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أۄشأڬوصًشأطرظأدًأڬوأحشأذۏخۏحأڬتأوتهڬأۄًأ؏أدضأڬتأهثتضأؼتوأضتأۄًأ؏أدضأڬۏأځشًتۄأىۄأڬۏأدتحۏأۄًأ؏أهۏڬىأتڲشأًۄأتههۄأڬەأىتوأځشأمضوأتټہتأهەأحًأتههۄأحؼتهۏٳأتضەأځًشۏأڬشًتأزەأ؏أڬۏتأوۏڽأحوۄۏڽأتۄهأدۄىوأڬەأثتشەأوۏڽأىۄأثحتاڽأآأۄوأىەأؼشعأڬۏأ=أدۏأۄتڽأ$أۏتأشضًهأتههۄأ$أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أۄشأ““أدػأ‛‛0أ““أدؼػأ‛‛أۗ““أوحڬثشأۗ‛‛
أشتًۏأثۏتىأڬشحەأۄۏڽأ=أوۏڽأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ$أ““أدػأ‛‛أضەأوشتزأڬۏتأۄەأآأإځأىەأتشطتزألشوتۏتأ=أدًأثہتشۏأثہشڬوأۄًأ؏أوۏڽأىەأزشۏتلحأڬۏتأ=““أدؼػأ‛‛أضەأوشتزأڬۏتأۄەأآأإځأىەألشوتۏتأ=أدًأرًزأڬًأثڔتأضودہحتأۄًأۗ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأ؏أتځىەأتضحتزأؼثزتههۄأثىأوذوزأثىأضؼۏزأثىأتثًوشۏوأڬەأذًتهەأضەأىمهأڬۏأۄەأتًشأًۄأعؼۏلأۄەأۗ"
17923,"أذعشحأضشتمۄأثىأوتهڬأثىأدؼطوأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أ
أ““أتەأضشتمۄأ$أڬۏتأوۏڽأحوۄۏڽأتۄهأدىحأتًشأتۄهأدۄىوأڬەأثتشەأوۏڽأىۄأثحتاڽأآأوۏڽأىەأؼشعأڬۏأ=أدۏأۄتڽأ$أۏتأشضًهأتههۄأ$أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أدۄتڽأحڬأتۄهأدۄىوأڬتأحؼهمأۄەأ؏أحًأۄشأرًزځضىزأ؏أثزحوۏصأوحڬثشأطرظأ+أدۄىوۏأۄًأڲتأ,أدۄتڽأحڬأتۄهأدىحأڬتأحؼهمأۄەأ؏أحًأڬوصًشأتًشأوؽهًثأهًڲأ+أدىحۏأۄًڽأڲەأ,أ‛‛ۗ
أۏۄأشًتۏحأغثشتىۏأىەأوؼدوأڬثۏشأتًشأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأتًشأتضأڬۏأضىزأذضىأۄەأۗ

[تخریج]: حدیث : 17923 - اخرجه الطبراني في """"المعجم الكبير """" (6589)"
17924,"أذعشحأؼثزتههۄأثىأؼوشًأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=†أڬۏتأوۏڽأحوۄۏڽأتۄهأدىحأڬەأثتشەأوۏڽأثحتاڽأآأوۏڽأىەأؼشعأڬۏأ=أدۏأۄتڽأ$أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أڬوصًشأتًشأوؽهًثأهًڲأ‛‛
أۏۄأشًتۏحأغثشتىۏأىەأىمهأڬۏأۄەأتًشأتضأڬەأشدتهأڬۏأحًخۏمأڬۏأڲةۏأۄەأۗ"
