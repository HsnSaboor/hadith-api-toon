{"hadithnumber": "4856", "text": "عبداللہ بن عمرو رضی اللہ عنہما سے روایت ہے کہ  جب رسول اللہ صلی اللہ علیہ وسلم نے فتح مکہ کیا تو خطب"}
{"hadithnumber": "4857", "text": "عمرو بن حزم کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے اہل یمن کے لیے ایک کتاب لکھی، اس میں فرائض"}
{"hadithnumber": "4858", "text": "عمرو بن حزم رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے اہل یمن کو ایک کتاب لکھی جس"}
{"hadithnumber": "4859", "text": "محمد بن شہاب زہری کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کی وہ کتاب پڑھی جو آپ نے عمرو بن"}
{"hadithnumber": "4860", "text": "زہری کہتے ہیں کہ  ابوبکر بن حزم میرے پاس ایک تحریر لے آئے جو چمڑے کے ایک ٹکڑے پر رسول اللہ صلی اللہ"}
{"hadithnumber": "4861", "text": "محمد بن عمرو بن حزم کہتے ہیں کہ  وہ تحریر جس میں رسول اللہ صلی اللہ علیہ وسلم نے عمرو بن حزم رضی الل"}
{"hadithnumber": "4862", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  ایک اعرابی  ( دیہاتی )  نبی اکرم صلی اللہ علیہ وسلم کے دروازے"}
{"hadithnumber": "4863", "text": "سہل بن سعد ساعدی رضی اللہ عنہ بیان کرتے ہیں کہ  ایک شخص نے ایک سوراخ سے رسول اللہ صلی اللہ علیہ وسلم"}
{"hadithnumber": "4864", "text": "ابوہریرہ رضی اللہ عنہ روایت کرتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جو شخص اجازت کے بغی"}
{"hadithnumber": "4865", "text": "ابوہریرہ رضی اللہ عنہ روایت کرتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”اگر کوئی بلا اجازت"}
{"hadithnumber": "4866", "text": "ابو سعید خدری رضی اللہ عنہ سے روایت ہے کہ  وہ نماز پڑھ رہے تھے، اچانک مروان کا بیٹا ان کے آگے سے گزر"}
{"hadithnumber": "4867", "text": "سعید بن جبیر کہتے ہیں کہ  عبدالرحمٰن بن ابزیٰ نے مجھے حکم دیا کہ میں ابن عباس رضی اللہ عنہما سے ان د"}
{"hadithnumber": "4868", "text": "سعید بن جبیر کہتے ہیں کہ  اہل کوفہ میں اس آیت: «ومن يقتل مؤمنا متعمدا‏» کے بارے میں اختلاف ہو گیا، م"}
{"hadithnumber": "4869", "text": "سعید بن جبیر کہتے ہیں کہ  میں نے ابن عباس رضی اللہ عنہما سے کہا: کیا مومن کو جان بوجھ کر قتل کرنے وا"}
