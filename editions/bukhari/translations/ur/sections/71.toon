{"hadithnumber": "5467", "text": "مجھ سے اسحاق بن نضر نے بیان کیا، کہا ہم سے ابواسامہ نے بیان کیا، کہا کہ مجھ سے یزید نے بیان کیا، ان"}
{"hadithnumber": "5468", "text": "ہم سے مسدد نے بیان کیا، کہا ہم سے یحییٰ نے بیان کیا، ان سے ہشام نے، ان سے ان کے والد نے اور ان سے عا"}
{"hadithnumber": "5469", "text": "ہم سے اسحاق بن نضر نے بیان کیا، کہا ہم سے ابواسامہ نے بیان کیا، کہا ہم سے ہشام بن عروہ نے بیان کیا،"}
{"hadithnumber": "5470", "text": "ہم سے مطر بن فضل نے بیان کیا، کہا ہم سے یزید بن ہارون نے، انہیں عبداللہ بن عون نے خبر دی، انہیں انس"}
{"hadithnumber": "5470", "text": "ہم سے مطر بن فضل نے بیان کیا، کہا ہم سے یزید بن ہارون نے، انہیں عبداللہ بن عون نے خبر دی، انہیں انس"}
{"hadithnumber": "5471", "text": "ہم سے ابوالنعمان نے بیان کیا، کہا ہم سے حماد بن زید نے بیان کیا، ان سے ایوب سختیانی نے، ان سے محمد ب"}
{"hadithnumber": "5472", "text": "اور اصبغ بن فرج نے بیان کیا کہ مجھے عبداللہ بن وہب نے خبر دی، انہیں جریر بن حازم نے، انہیں ایوب سختی"}
{"hadithnumber": "5473", "text": "ہم سے عبدان نے بیان کیا، کہا ہم سے عبداللہ بن مبارک نے بیان کیا، کہا ہم کو معمر نے خبر دی، انہیں زہر"}
{"hadithnumber": "5474", "text": "ہم سے علی بن عبداللہ مدینی نے بیان کیا، کہا ہم سے سفیان بن عیینہ نے بیان کیا، ان سے زہری نے بیان کیا"}
