{"hadithnumber": "1763", "arabic": "[1763] عَنْ عُبَیْدِ اللّٰہِ بْنِ عَبْدِ اللّٰہِ بْنِ عُتْبَۃَ بْنِ مَسْعُودٍ، أَ نَّہُ دَخَلَ عَلَ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Daif'}", "reference": "Book 54, Hadith 1", "international_number": "1763", "narrator_chain": ""}
{"hadithnumber": "1764", "arabic": "[1764] عَنْ عَائِشَۃَ زَوْجِ النَّبِیِّ  ﷺ ، أَ نَّہَا اشْتَرَتْ نُمْرُقَۃً فِیہَا تَصَاوِیرُ، فَلَ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 54, Hadith 2", "international_number": "1764", "narrator_chain": ""}
{"hadithnumber": "1765", "arabic": "[1765] عَنْ سُلَیْمَانَ بْنِ یَسَارٍ، أَ نَّہُ قَالَ : دَخَلَ رَسُولُ اللّٰہِ  ﷺ  بَیْتَ مَیْمُونَۃ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 54, Hadith 3", "international_number": "1765", "narrator_chain": ""}
{"hadithnumber": "1766", "arabic": "[1766] عَنْ خَالِدِ بْنِ الْوَلِیدِ بْنِ الْمُغِیرَۃِ : أَنَّہُ دَخَلَ مَعَ رَسُولِ اللّٰہِ  ﷺ  بَی", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih Lighairihi'}", "reference": "Book 54, Hadith 4", "international_number": "1766", "narrator_chain": ""}
{"hadithnumber": "1767", "arabic": "[1767] عَنْ عَبْدِ اللّٰہِ بْنِ عُمَرَ : أَنَّ رَجُلاً نَادَی رَسُولَ اللّٰہِ  ﷺ  فَقَالَ : یَا رَس", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Mauquf Sahih'}", "reference": "Book 54, Hadith 5", "international_number": "1767", "narrator_chain": ""}
{"hadithnumber": "1768", "arabic": "[1768] عَنْ سُفْیَانَ بْنِ أبِی زُہَیْرٍ، وَہُوَ رَجُلٌ مِنْ أَزْدِ شَنُوئَ ۃَ مِنْ أَصْحَابِ رَس", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 54, Hadith 6", "international_number": "1768", "narrator_chain": ""}
{"hadithnumber": "1769", "arabic": "[1769] عَنْ عَبْدِ اللّٰہِ بْنِ عُمَرَ، أَنَّ رَسُولَ اللّٰہِ  ﷺ  قَالَ:مَنِ اقْتَنَی کَلْباً إِلاّ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 54, Hadith 7", "international_number": "1769", "narrator_chain": ""}
{"hadithnumber": "1770", "arabic": "[1770] عَنْ عَبْدِ اللّٰہِ بْنِ عُمَرَ : أَنَّ رَسُولَ اللّٰہِ  ﷺ  أَمَرَ بِقَتْلِ الْکِلَابِ۔", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 54, Hadith 8", "international_number": "1770", "narrator_chain": ""}
{"hadithnumber": "1771", "arabic": "[1771] عَنْ أبِی ہُرَیْرَۃَ، أَنَّ رَسُولَ اللّٰہِ  ﷺ  قَالَ: رَأْسُ الْکُفْرِ نَحْوَ الْمَشْرِقِ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Daif'}", "reference": "Book 54, Hadith 9", "international_number": "1771", "narrator_chain": ""}
{"hadithnumber": "1772", "arabic": "[1772] عَنْ أبِی سَعِیدٍ الْخُدْرِیِّ أَ نَّہُ قَالَ : قَالَ رَسُولُ اللّٰہِ  ﷺ  : یُوشِکُ أَنْ ی", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 54, Hadith 10", "international_number": "1772", "narrator_chain": ""}
{"hadithnumber": "1773", "arabic": "[1773] عَنِ ابْنِ عُمَرَ : أَنَّ رَسُولَ اللّٰہِ  ﷺ  قَالَ: لَا یَحْتَلِبَنَّ أَحَدٌ مَاشِیَۃَ أَ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 54, Hadith 11", "international_number": "1773", "narrator_chain": ""}
{"hadithnumber": "1774", "arabic": "[1774] عَنْ مَالِکٌ، أَ نَّہُ بَلَغَہُ، أَنَّ رَسُولَ اللّٰہِ  ﷺ  قَالَ : مَا مِنْ نَبِیٍّ إِلاَّ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 54, Hadith 12", "international_number": "1774", "narrator_chain": ""}
{"hadithnumber": "1775", "arabic": "[1775] عَنْ نَافِعٍ، أَنَّ ابْنَ عُمَرَ کَانَ یُقَرَّبُ إِلَیْہِ عَشَاؤُہُ، فَیَسْمَعُ قِرَائَ ۃَ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 54, Hadith 13", "international_number": "1775", "narrator_chain": ""}
{"hadithnumber": "1776", "arabic": "[1776] عَنْ مَیْمُونَۃَ زَوْجِ النَّبِیِّ  ﷺ ، أَنَّ رَسُولَ اللّٰہِ  ﷺ  سُئِلَ عَنِ الْفَأْرَۃِ ت", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 54, Hadith 14", "international_number": "1776", "narrator_chain": ""}
{"hadithnumber": "1777", "arabic": "[1777] عَنْ سَہْلِ بْنِ سَعْدٍ السَّاعِدِیِّ، أَنَّ رَسُولَ اللّٰہِ  ﷺ  قَالَ : إِنْ کَانَ فَفِی ال", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 54, Hadith 15", "international_number": "1777", "narrator_chain": ""}
{"hadithnumber": "1778", "arabic": "[1778] عَنْ عَبْدِ اللّٰہِ بْنِ عُمَرَ، أَنَّ رَسُولَ اللّٰہِ  ﷺ  قَالَ : الشُّؤْمُ فِی الدَّارِ و", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 54, Hadith 16", "international_number": "1778", "narrator_chain": ""}
{"hadithnumber": "1779", "arabic": "[1779] عَنْ یَحْیَی بْنِ سَعِیدٍ، أَ نَّہُ قَالَ : جَائَتِ امْرَأَۃٌ إِلَی رَسُولِ اللّٰہِ  ﷺ  فَق", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 54, Hadith 17", "international_number": "1779", "narrator_chain": ""}
{"hadithnumber": "1780", "arabic": "[1780] عَنْ یَحْیَی بْنِ سَعِیدٍ، أَنَّ رَسُولَ اللّٰہِ قَالَ لِلَقْحَۃٍ تُحْلَبُ :مَنْ یَحْلُبُ ہَ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 54, Hadith 18", "international_number": "1780", "narrator_chain": ""}
{"hadithnumber": "1781", "arabic": "[1781] عَنْ یَحْیَی بْنِ سَعِیدٍ، أَنَّ عُمَرَ بْنَ الْخَطَّابِ قَالَ لِرَجُلٍ : مَا اسْمُکَ ؟ فَقَ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Mauquf Sahih'}", "reference": "Book 54, Hadith 19", "international_number": "1781", "narrator_chain": ""}
{"hadithnumber": "1782", "arabic": "[1782] عَنْ أَ نَسِ بْنِ مَالِکٍ، أَ نَّہُ قَالَ : احْتَجَمَ رَسُولُ اللّٰہِ  ﷺ ، حَجَمَہُ أَبُو", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 54, Hadith 20", "international_number": "1782", "narrator_chain": ""}
{"hadithnumber": "1783", "arabic": "[1783] وَحَدَّثَنِی مَالِکٌ، أَ نَّہُ بَلَغَہُ، أَنَّ رَسُولَ اللّٰہِ  ﷺ  قَالَ : إِنْ کَانَ دَوَا", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 54, Hadith 21", "international_number": "1783", "narrator_chain": ""}
{"hadithnumber": "1784", "arabic": "[1784] عَنِ ابْنِ مُحَیِّصَۃَ الْأَنْصَاری أَحَدِ بَنِی حَارِثَۃَ، أَ نَّہُ اسْتَأْذَنَ رَسُولَ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Shadh'}", "reference": "Book 54, Hadith 22", "international_number": "1784", "narrator_chain": ""}
{"hadithnumber": "1785", "arabic": "[1785] عَنْ عَبْدِ اللّٰہِ بْنِ دِینَارٍ، عَنْ عَبْدِ اللّٰہِ بْنِ عُمَرَ، أَ نَّہُ قَالَ : رَأَیْ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih Lighairihi'}", "reference": "Book 54, Hadith 23", "international_number": "1785", "narrator_chain": ""}
{"hadithnumber": "1786", "arabic": "[1786] عَنْ مَالِکٍ، أَ نَّہُ بَلَغَہُ، أَنَّ عُمَرَ بْنَ الْخَطَّابِ أَرَادَ الْخُرُوجَ إِلَی ال", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih Lighairihi'}", "reference": "Book 54, Hadith 24", "international_number": "1786", "narrator_chain": ""}
{"hadithnumber": "1787", "arabic": "[1787] عَنْ أبِی لُبَابَۃَ : أَنَّ رَسُولَ اللّٰہِ  ﷺ  نَہَی عَنْ قَتْلِ الْحَیَّاتِ الَّتِی فِی ا", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Mauquf Daif'}", "reference": "Book 54, Hadith 25", "international_number": "1787", "narrator_chain": ""}
{"hadithnumber": "1788", "arabic": "[1788] عَنْ سَائِبَۃَ مَوْلَاۃٍ لِعَائِشَۃَ : أَنَّ رَسُولَ اللّٰہِ  ﷺ  نَہَی عَنْ قَتْلِ الْجِنَّا", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 54, Hadith 26", "international_number": "1788", "narrator_chain": ""}
{"hadithnumber": "1789", "arabic": "[1789] عَنْ أبِی السَّائِبِ مَوْلَی ہِشَامِ بْنِ زُہْرَۃَ، أَ نَّہُ قَالَ : دَخَلْتُ عَلَی أبِی س", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Daif'}", "reference": "Book 54, Hadith 27", "international_number": "1789", "narrator_chain": ""}
{"hadithnumber": "1790", "arabic": "[1790] مَالِکٌ، أَ نَّہُ بَلَغَہُ : أَنَّ رَسُولَ اللّٰہِ  ﷺ  کَانَ إِذَا وَضَعَ رِجْلَہُ فِی الْغ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih Lighairihi'}", "reference": "Book 54, Hadith 28", "international_number": "1790", "narrator_chain": ""}
{"hadithnumber": "1791", "arabic": "[1791] عَنْ خَوْلَۃَ بِنْتِ حَکِیمٍ : أَنَّ رَسُولَ اللّٰہِ  ﷺ  قَالَ : مَنْ نَزَلَ مَنْزِلاً فَلْی", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 54, Hadith 29", "international_number": "1791", "narrator_chain": ""}
{"hadithnumber": "1792", "arabic": "[1792] عَنْ عَمْرِو بْنِ شُعَیْبٍ, عَنْ أَبِیہِ، عَنْ جَدِّہِ، أَنَّ رَسُولَ اللّٰہِ  ﷺ  قَالَ : ا", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Mauquf Daif'}", "reference": "Book 54, Hadith 30", "international_number": "1792", "narrator_chain": ""}
{"hadithnumber": "1793", "arabic": "[1793] عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ، أَنَّہُ کَانَ یَقُولُ: قَالَ رَسُولُ اللّٰہِ  ﷺ  : الشَّیْطَ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 54, Hadith 31", "international_number": "1793", "narrator_chain": ""}
{"hadithnumber": "1794", "arabic": "[1794] عَنْ أبِی ہُرَیْرَۃَ, أَنَّ رَسُولَ اللّٰہِ  ﷺ  قَالَ : لَا یَحِلُّ لاِمْرَأَۃٍ تُؤْمِنُ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 54, Hadith 32", "international_number": "1794", "narrator_chain": ""}
{"hadithnumber": "1795", "arabic": "[1795] عَنْ خَالِدِ بْنِ مَعْدَانَ یَرْفَعُہُ : إِنَّ اللّٰہَ تَبَارَکَ وَتَعَالَی رَفِیقٌ یُحِبُّ ا", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 54, Hadith 33", "international_number": "1795", "narrator_chain": ""}
{"hadithnumber": "1796", "arabic": "[1796] عَنْ أبِی ہُرَیْرَۃَ أَنَّ رَسُولَ اللّٰہِ  ﷺ  قَالَ :السَّفَرُ قِطْعَۃٌ مِنَ الْعَذَابِ، ی", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih Lighairihi'}", "reference": "Book 54, Hadith 34", "international_number": "1796", "narrator_chain": ""}
{"hadithnumber": "1797", "arabic": "[1797] اَنَّ أَبَا ہُرَیْرَۃَ قَالَ : قَالَ رَسُولُ اللّٰہِ  ﷺ : لِلْمَمْلُوکِ طَعَامُہُ وَکِسْوَتُ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 54, Hadith 35", "international_number": "1797", "narrator_chain": ""}
{"hadithnumber": "1798", "arabic": "[1798] مَالِکٌ، أَ نَّہُ بَلَغَہُ، أَنَّ عُمَرَ بْنَ الْخَطَّابِ کَانَ یَذْہَبُ إِلَی الْعَوَالِی", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Hasan'}", "reference": "Book 54, Hadith 36", "international_number": "1798", "narrator_chain": ""}
{"hadithnumber": "1799", "arabic": "[1799] مَالِکٌ، عَنْ عَمِّہِ أبِی سُہَیْلِ بْنِ مَالِکٍ، عَنْ أَبِیہِ، أَ نَّہُ سَمِعَ عُثْمَانَ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Daif'}", "reference": "Book 54, Hadith 37", "international_number": "1799", "narrator_chain": ""}
{"hadithnumber": "1800", "arabic": "[1800] عَنْ عَبْدِ اللّٰہِ بْنِ عُمَرَ، أَنَّ رَسُولَ اللّٰہِ  ﷺ  قَالَ : إنَّ الْعَبْدَ إِذَا نَصَ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 54, Hadith 38", "international_number": "1800", "narrator_chain": ""}
{"hadithnumber": "1801", "arabic": "[1801] مَالِکٌ، أَ نَّہُ بَلَغَہُ، أَنَّ أَمَۃً کَانَتْ لِعَبْدِ اللّٰہِ بْنِ عُمَرَ بْنِ الْخَطّ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih Lighairihi'}", "reference": "Book 54, Hadith 39", "international_number": "1801", "narrator_chain": ""}
{"hadithnumber": "1802", "arabic": "[1802] عَنْ عَبْدِ اللّٰہِ بْنِ دِینَارٍ، أَنَّ عَبْدَ اللّٰہِ بْنَ عُمَرَ قَالَ : کُنَّا إِذَا بَا", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 54, Hadith 40", "international_number": "1802", "narrator_chain": ""}
{"hadithnumber": "1803", "arabic": "[1803] عَنْ أُمَیْمَۃَ بِنْتِ رُقَیْقَۃَ، أَ نَّہَا قَالَتْ : أَتَیْتُ رَسُولَ اللّٰہِ  ﷺ  فِی نِ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 54, Hadith 41", "international_number": "1803", "narrator_chain": ""}
{"hadithnumber": "1804", "arabic": "[1804] عَنْ عَبْدِ اللّٰہِ بْنِ دِینَارٍ، أَنَّ عَبْدَ اللّٰہِ بْنَ عُمَرَ کَتَبَ إِلَی عَبْدِ الْم", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Mauquf Daif'}", "reference": "Book 54, Hadith 42", "international_number": "1804", "narrator_chain": ""}
{"hadithnumber": "1805", "arabic": "[1805] عَنْ عَبْدِ اللّٰہِ بْنِ دِینَارٍ، عَنْ عَبْدِ اللّٰہِ بْنِ عُمَرَ، أَنَّ رَسُولَ اللّٰہِ  ﷺ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Mauquf Sahih'}", "reference": "Book 54, Hadith 43", "international_number": "1805", "narrator_chain": ""}
{"hadithnumber": "1806", "arabic": "[1806] عَنْ أبِی ہُرَیْرَۃَ، أَنَّ رَسُولَ اللّٰہِ  ﷺ  قَالَ :إِذَا سَمِعْتَ الرَّجُلَ یَقُولُ : ہ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 54, Hadith 44", "international_number": "1806", "narrator_chain": ""}
{"hadithnumber": "1807", "arabic": "[1807] عَنْ أبِی ہُرَیْرَۃَ أَنَّ رَسُولَ اللّٰہِ  ﷺ  قَالَ :لَا یَقُلْ أَحَدُکُمْ : یَا خَیْبَۃَ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Mauquf Daif'}", "reference": "Book 54, Hadith 45", "international_number": "1807", "narrator_chain": ""}
{"hadithnumber": "1890", "arabic": "حَدَّثَنِي مَالِكٌ، عَنْ صَفْوَانَ بْنَ سُلَيْمٍ، عَنْ عَطَاءِ بْنِ يَسَارٍ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم سَأَلَهُ رَجُلٌ فَقَالَ يَا رَسُولَ اللَّهِ أَسْتَأْذِنُ عَلَى أُمِّي فَقَالَ ‏\"‏ نَعَمْ ‏\"‏ ‏.‏ قَالَ الرَّجُلُ إِنِّي مَعَهَا فِي الْبَيْتِ ‏.‏ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ اسْتَأْذِنْ عَلَيْهَا ‏\"‏ ‏.‏ فَقَالَ الرَّجُلُ إِنِّي خَادِمُهَا ‏.‏ فَقَالَ لَهُ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ اسْتَأْذِنْ عَلَيْهَا أَتُحِبُّ أَنْ تَرَاهَا عُرْيَانَةً ‏\"‏ ‏.‏ قَالَ لاَ ‏.‏ قَالَ ‏\"‏ فَاسْتَأْذِنْ عَلَيْهَا ‏\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1891", "arabic": "وَحَدَّثَنِي مَالِكٌ، عَنِ الثِّقَةِ، عِنْدَهُ عَنْ بُكَيْرِ بْنِ عَبْدِ اللَّهِ بْنِ الأَشَجِّ، عَنْ بُسْرِ بْنِ سَعِيدٍ، عَنْ أَبِي سَعِيدٍ الْخُدْرِيِّ، عَنْ أَبِي مُوسَى الأَشْعَرِيِّ، أَنَّهُ قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ الاِسْتِئْذَانُ ثَلاَثٌ فَإِنْ أُذِنَ لَكَ فَادْخُلْ وَإِلاَّ فَارْجِعْ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1892", "arabic": "وَحَدَّثَنِي مَالِكٌ، عَنْ رَبِيعَةَ بْنِ أَبِي عَبْدِ الرَّحْمَنِ، عَنْ غَيْرِ، وَاحِدٍ، مِنْ عُلَمَائِهِمْ أَنَّ أَبَا مُوسَى الأَشْعَرِيَّ، جَاءَ يَسْتَأْذِنُ عَلَى عُمَرَ بْنِ الْخَطَّابِ فَاسْتَأْذَنَ ثَلاَثًا ثُمَّ رَجَعَ فَأَرْسَلَ عُمَرُ بْنُ الْخَطَّابِ فِي أَثَرِهِ فَقَالَ مَا لَكَ لَمْ تَدْخُلْ فَقَالَ أَبُو مُوسَى سَمِعْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم يَقُولُ ‏\"‏ الاِسْتِئْذَانُ ثَلاَثٌ فَإِنْ أُذِنَ لَكَ فَادْخُلْ وَإِلاَّ فَارْجِعْ ‏\"‏ ‏.‏ فَقَالَ عُمَرُ وَمَنْ يَعْلَمُ هَذَا لَئِنْ لَمْ تَأْتِنِي بِمَنْ يَعْلَمُ ذَلِكَ لأَفْعَلَنَّ بِكَ كَذَا وَكَذَا ‏.‏ فَخَرَجَ أَبُو مُوسَى حَتَّى جَاءَ مَجْلِسًا فِي الْمَسْجِدِ يُقَالُ لَهُ مَجْلِسُ الأَنْصَارِ فَقَالَ إِنِّي أَخْبَرْتُ عُمَرَ بْنَ الْخَطَّابِ أَنِّي سَمِعْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم يَقُولُ ‏\"‏ الاِسْتِئْذَانُ ثَلاَثٌ فَإِنْ أُذِنَ لَكَ فَادْخُلْ وَإِلاَّ فَارْجِعْ ‏\"‏ ‏.‏ فَقَالَ لَئِنْ لَمْ تَأْتِنِي بِمَنْ يَعْلَمُ هَذَا لأَفْعَلَنَّ بِكَ كَذَا وَكَذَا ‏.‏ فَإِنْ كَانَ سَمِعَ ذَلِكَ أَحَدٌ مِنْكُمْ فَلْيَقُمْ مَعِي ‏.‏ فَقَالُوا لأَبِي سَعِيدٍ الْخُدْرِيِّ قُمْ مَعَهُ ‏.‏ وَكَانَ أَبُو سَعِيدٍ أَصْغَرَهُمْ فَقَامَ مَعَهُ فَأَخْبَرَ بِذَلِكَ عُمَرَ بْنَ الْخَطَّابِ ‏.‏ فَقَالَ عُمَرُ بْنُ الْخَطَّابِ لأَبِي مُوسَى أَمَا إِنِّي لَمْ أَتَّهِمْكَ وَلَكِنْ خَشِيتُ أَنْ يَتَقَوَّلَ النَّاسُ عَلَى رَسُولِ اللَّهِ صلى الله عليه وسلم ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1893", "arabic": "حَدَّثَنِي مَالِكٌ، عَنْ عَبْدِ اللَّهِ بْنِ أَبِي بَكْرٍ، عَنْ أَبِيهِ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ إِنْ عَطَسَ فَشَمِّتْهُ ثُمَّ إِنْ عَطَسَ فَشَمِّتْهُ ثُمَّ إِنْ عَطَسَ فَشَمِّتْهُ ثُمَّ إِنْ عَطَسَ فَقُلْ إِنَّكَ مَضْنُوكٌ ‏\"\"‏ ‏.‏ قَالَ عَبْدُ اللَّهِ بْنُ أَبِي بَكْرٍ لاَ أَدْرِي أَبَعْدَ الثَّالِثَةِ أَوِ الرَّابِعَةِ", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1894", "arabic": "وَحَدَّثَنِي مَالِكٌ، عَنْ نَافِعٍ، أَنَّ عَبْدَ اللَّهِ بْنَ عُمَرَ، كَانَ إِذَا عَطَسَ فَقِيلَ لَهُ يَرْحَمُكَ اللَّهُ ‏.‏ قَالَ يَرْحَمُنَا اللَّهُ وَإِيَّاكُمْ وَيَغْفِرُ لَنَا وَلَكُمْ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1895", "arabic": "حَدَّثَنِي مَالِكٌ، عَنْ إِسْحَاقَ بْنِ عَبْدِ اللَّهِ بْنِ أَبِي طَلْحَةَ، أَنَّ رَافِعَ بْنَ إِسْحَاقَ، مَوْلَى الشِّفَاءِ أَخْبَرَهُ قَالَ دَخَلْتُ أَنَا وَعَبْدُ اللَّهِ بْنُ أَبِي طَلْحَةَ، عَلَى أَبِي سَعِيدٍ الْخُدْرِيِّ نَعُودُهُ فَقَالَ لَنَا أَبُو سَعِيدٍ أَخْبَرَنَا رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ أَنَّ الْمَلاَئِكَةَ لاَ تَدْخُلُ بَيْتًا فِيهِ تَمَاثِيلُ أَوْ تَصَاوِيرُ ‏\"\"‏ ‏.‏ شَكَّ إِسْحَاقُ لاَ يَدْرِي أَيَّتَهُمَا قَالَ أَبُو سَعِيدٍ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1896", "arabic": "وَحَدَّثَنِي مَالِكٌ، عَنْ أَبِي النَّضْرِ، عَنْ عُبَيْدِ اللَّهِ بْنِ عَبْدِ اللَّهِ بْنِ عُتْبَةَ بْنِ مَسْعُودٍ، أَنَّهُ دَخَلَ عَلَى أَبِي طَلْحَةَ الأَنْصَارِيِّ يَعُودُهُ قَالَ فَوَجَدَ عِنْدَهُ سَهْلَ بْنَ حُنَيْفٍ فَدَعَا أَبُو طَلْحَةَ إِنْسَانًا فَنَزَعَ نَمَطًا مِنْ تَحْتِهِ فَقَالَ لَهُ سَهْلُ بْنُ حُنَيْفٍ لِمَ تَنْزِعُهُ قَالَ لأَنَّ فِيهِ تَصَاوِيرَ وَقَدْ قَالَ فِيهَا رَسُولُ اللَّهِ صلى الله عليه وسلم مَا قَدْ عَلِمْتَ ‏.‏ فَقَالَ سَهْلٌ أَلَمْ يَقُلْ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ إِلاَّ مَا كَانَ رَقْمًا فِي ثَوْبٍ ‏\"\"‏ ‏.‏ قَالَ بَلَى وَلَكِنَّهُ أَطْيَبُ لِنَفْسِي ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1897", "arabic": "وَحَدَّثَنِي مَالِكٌ، عَنْ نَافِعٍ، عَنِ الْقَاسِمِ بْنِ مُحَمَّدٍ، عَنْ عَائِشَةَ، زَوْجِ النَّبِيِّ صلى الله عليه وسلم أَنَّهَا اشْتَرَتْ نُمْرُقَةً فِيهَا تَصَاوِيرُ فَلَمَّا رَآهَا رَسُولُ اللَّهِ صلى الله عليه وسلم قَامَ عَلَى الْبَابِ فَلَمْ يَدْخُلْ فَعَرَفَتْ فِي وَجْهِهِ الْكَرَاهِيَةَ وَقَالَتْ يَا رَسُولَ اللَّهِ أَتُوبُ إِلَى اللَّهِ وَإِلَى رَسُولِهِ فَمَاذَا أَذْنَبْتُ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ فَمَا بَالُ هَذِهِ النُّمْرُقَةِ ‏\"‏ ‏.‏ قَالَتِ اشْتَرَيْتُهَا لَكَ تَقْعُدُ عَلَيْهَا وَتَوَسَّدُهَا ‏.‏ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ إِنَّ أَصْحَابَ هَذِهِ الصُّوَرِ يُعَذَّبُونَ يَوْمَ الْقِيَامَةِ يُقَالُ لَهُمْ أَحْيُوا مَا خَلَقْتُمْ ‏\"‏ ‏.‏ ثُمَّ قَالَ ‏\"‏ إِنَّ الْبَيْتَ الَّذِي فِيهِ الصُّوَرُ لاَ تَدْخُلُهُ الْمَلاَئِكَةُ ‏\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1898", "arabic": "حَدَّثَنِي مَالِكٌ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَبْدِ اللَّهِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ أَبِي صَعْصَعَةَ، عَنْ سُلَيْمَانَ بْنِ يَسَارٍ، أَنَّهُ قَالَ دَخَلَ رَسُولُ اللَّهِ صلى الله عليه وسلم بَيْتَ مَيْمُونَةَ بِنْتِ الْحَارِثِ فَإِذَا ضِبَابٌ فِيهَا بَيْضٌ وَمَعَهُ عَبْدُ اللَّهِ بْنُ عَبَّاسٍ وَخَالِدُ بْنُ الْوَلِيدِ فَقَالَ ‏\"‏ مِنْ أَيْنَ لَكُمْ هَذَا ‏\"‏ ‏.‏ فَقَالَتْ أَهْدَتْهُ لِي أُخْتِي هُزَيْلَةُ بِنْتُ الْحَارِثِ ‏.‏ فَقَالَ لِعَبْدِ اللَّهِ بْنِ عَبَّاسٍ وَخَالِدِ بْنِ الْوَلِيدِ ‏\"‏ كُلاَ ‏\"‏ ‏.‏ فَقَالاَ أَوَلاَ تَأْكُلُ أَنْتَ يَا رَسُولَ اللَّهِ فَقَالَ ‏\"‏ إِنِّي تَحْضُرُنِي مِنَ اللَّهِ حَاضِرَةٌ ‏\"‏ ‏.‏ قَالَتْ مَيْمُونَةُ أَنَسْقِيكَ يَا رَسُولَ اللَّهِ مِنْ لَبَنٍ عِنْدَنَا فَقَالَ ‏\"‏ نَعَمْ ‏\"‏ ‏.‏ فَلَمَّا شَرِبَ قَالَ ‏\"‏ مِنْ أَيْنَ لَكُمْ هَذَا ‏\"‏ ‏.‏ فَقَالَتْ أَهْدَتْهُ لِي أُخْتِي هُزَيْلَةُ ‏.‏ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ أَرَأَيْتِكِ جَارِيَتَكِ الَّتِي كُنْتِ اسْتَأْمَرْتِينِي فِي عِتْقِهَا أَعْطِيهَا أُخْتَكِ وَصِلِي بِهَا رَحِمَكِ تَرْعَى عَلَيْهَا فَإِنَّهُ خَيْرٌ لَكِ ‏\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1899", "arabic": "وَحَدَّثَنِي مَالِكٌ، عَنِ ابْنِ شِهَابٍ، عَنْ أَبِي أُمَامَةَ بْنِ سَهْلِ بْنِ حُنَيْفٍ، عَنْ عَبْدِ اللَّهِ بْنِ عَبَّاسٍ، عَنْ خَالِدِ بْنِ الْوَلِيدِ بْنِ الْمُغِيرَةِ، أَنَّهُ دَخَلَ مَعَ رَسُولِ اللَّهِ صلى الله عليه وسلم بَيْتَ مَيْمُونَةَ زَوْجِ النَّبِيِّ صلى الله عليه وسلم فَأُتِيَ بِضَبٍّ مَحْنُوذٍ فَأَهْوَى إِلَيْهِ رَسُولُ اللَّهِ صلى الله عليه وسلم بِيَدِهِ ‏.‏ فَقَالَ بَعْضُ النِّسْوَةِ اللاَّتِي فِي بَيْتِ مَيْمُونَةَ أَخْبِرُوا رَسُولَ اللَّهِ صلى الله عليه وسلم بِمَا يُرِيدُ أَنْ يَأْكُلَ مِنْهُ ‏.‏ فَقِيلَ هُوَ ضَبٌّ يَا رَسُولَ اللَّهِ ‏.‏ فَرَفَعَ يَدَهُ فَقُلْتُ أَحَرَامٌ هُوَ يَا رَسُولَ اللَّهِ فَقَالَ ‏ ‏ لاَ وَلَكِنَّهُ لَمْ يَكُنْ بِأَرْضِ قَوْمِي فَأَجِدُنِي أَعَافُهُ ‏\"\"‏ ‏.‏ قَالَ خَالِدٌ فَاجْتَرَرْتُهُ فَأَكَلْتُهُ وَرَسُولُ اللَّهِ صلى الله عليه وسلم يَنْظُرُ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1900", "arabic": "وَحَدَّثَنِي مَالِكٌ، عَنْ عَبْدِ اللَّهِ بْنِ دِينَارٍ، عَنْ عَبْدِ اللَّهِ بْنِ عُمَرَ، أَنَّ رَجُلاً، نَادَى رَسُولَ اللَّهِ صلى الله عليه وسلم فَقَالَ يَا رَسُولَ اللَّهِ مَا تَرَى فِي الضَّبِّ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ لَسْتُ بِآكِلِهِ وَلاَ بِمُحَرِّمِهِ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1901", "arabic": "حَدَّثَنِي مَالِكٌ، عَنْ يَزِيدَ بْنِ خُصَيْفَةَ، أَنَّ السَّائِبَ بْنَ يَزِيدَ، أَخْبَرَهُ أَنَّهُ، سَمِعَ سُفْيَانَ بْنَ أَبِي زُهَيْرٍ، وَهُوَ رَجُلٌ مِنْ أَزْدِ شَنُوءَةَ مِنْ أَصْحَابِ رَسُولِ اللَّهِ صلى الله عليه وسلم وَهُوَ يُحَدِّثُ نَاسًا مَعَهُ عِنْدَ بَابِ الْمَسْجِدِ فَقَالَ سَمِعْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم يَقُولُ ‏ ‏ مَنِ اقْتَنَى كَلْبًا لاَ يُغْنِي عَنْهُ زَرْعًا وَلاَ ضَرْعًا نَقَصَ مِنْ عَمَلِهِ كُلَّ يَوْمٍ قِيرَاطٌ ‏\"\"‏ ‏.‏ قَالَ آنْتَ سَمِعْتَ هَذَا مِنْ رَسُولِ اللَّهِ صلى الله عليه وسلم فَقَالَ إِي وَرَبِّ هَذَا الْمَسْجِدِ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1902", "arabic": "وَحَدَّثَنِي مَالِكٌ، عَنْ نَافِعٍ، عَنْ عَبْدِ اللَّهِ بْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ مَنِ اقْتَنَى كَلْبًا إِلاَّ كَلْبًا ضَارِيًا أَوْ كَلْبَ مَاشِيَةٍ نَقَصَ مِنْ عَمَلِهِ كُلَّ يَوْمٍ قِيرَاطَانِ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1903", "arabic": "وَحَدَّثَنِي مَالِكٌ، عَنْ نَافِعٍ، عَنْ عَبْدِ اللَّهِ بْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم أَمَرَ بِقَتْلِ الْكِلاَبِ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1904", "arabic": "حَدَّثَنِي مَالِكٌ، عَنْ أَبِي الزِّنَادِ، عَنِ الأَعْرَجِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ رَأْسُ الْكُفْرِ نَحْوَ الْمَشْرِقِ وَالْفَخْرُ وَالْخُيَلاَءُ فِي أَهْلِ الْخَيْلِ وَالإِبِلِ وَالْفَدَّادِينَ أَهْلِ الْوَبَرِ وَالسَّكِينَةُ فِي أَهْلِ الْغَنَمِ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1905", "arabic": "وَحَدَّثَنِي مَالِكٌ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَبْدِ اللَّهِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ أَبِي صَعْصَعَةَ، عَنْ أَبِيهِ، عَنْ أَبِي سَعِيدٍ الْخُدْرِيِّ، أَنَّهُ قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ يُوشِكُ أَنْ يَكُونَ خَيْرُ مَالِ الْمُسْلِمِ غَنَمًا يَتْبَعُ بِهَا شَعَفَ الْجِبَالِ وَمَوَاقِعَ الْقَطْرِ يَفِرُّ بِدِينِهِ مِنَ الْفِتَنِ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1906", "arabic": "وَحَدَّثَنِي مَالِكٌ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ لاَ يَحْتَلِبَنَّ أَحَدٌ مَاشِيَةَ أَحَدٍ بِغَيْرِ إِذْنِهِ أَيُحِبُّ أَحَدُكُمْ أَنْ تُؤْتَى مَشْرُبَتُهُ فَتُكْسَرَ خِزَانَتُهُ فَيُنْتَقَلَ طَعَامُهُ وَإِنَّمَا تَخْزُنُ لَهُمْ ضُرُوعُ مَوَاشِيهِمْ أَطْعِمَاتِهِمْ فَلاَ يَحْتَلِبَنَّ أَحَدٌ مَاشِيَةَ أَحَدٍ إِلاَّ بِإِذْنِهِ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1907", "arabic": "وَحَدَّثَنِي مَالِكٌ، أَنَّهُ بَلَغَهُ أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏\"‏ مَا مِنْ نَبِيِّ إِلاَّ قَدْ رَعَى غَنَمًا ‏\"‏ ‏.‏ قِيلَ وَأَنْتَ يَا رَسُولَ اللَّهِ قَالَ ‏\"‏ وَأَنَا ‏\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1908", "arabic": "وَحَدَّثَنِي مَالِكٌ، عَنْ نَافِعٍ، أَنَّ ابْنَ عُمَرَ، كَانَ يُقَرَّبُ إِلَيْهِ عَشَاؤُهُ فَيَسْمَعُ قِرَاءَةَ الإِمَامِ وَهُوَ فِي بَيْتِهِ فَلاَ يَعْجَلُ عَنْ طَعَامِهِ حَتَّى يَقْضِيَ حَاجَتَهُ مِنْهُ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1909", "arabic": "وَحَدَّثَنِي مَالِكٌ، عَنِ ابْنِ شِهَابٍ، عَنْ عُبَيْدِ اللَّهِ بْنِ عَبْدِ اللَّهِ بْنِ عُتْبَةَ بْنِ مَسْعُودٍ، عَنْ عَبْدِ اللَّهِ بْنِ عَبَّاسٍ، عَنْ مَيْمُونَةَ، زَوْجِ النَّبِيِّ صلى الله عليه وسلم أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم سُئِلَ عَنِ الْفَأْرَةِ تَقَعُ فِي السَّمْنِ فَقَالَ ‏ ‏ انْزِعُوهَا وَمَا حَوْلَهَا فَاطْرَحُوهُ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1910", "arabic": "وَحَدَّثَنِي مَالِكٌ، عَنْ أَبِي حَازِمِ بْنِ دِينَارٍ، عَنْ سَهْلِ بْنِ سَعْدٍ السَّاعِدِيِّ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ إِنْ كَانَ فَفِي الْفَرَسِ وَالْمَرْأَةِ وَالْمَسْكَنِ ‏\"\"‏ ‏.‏ يَعْنِي الشُّؤْمَ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1911", "arabic": "وَحَدَّثَنِي مَالِكٌ، عَنِ ابْنِ شِهَابٍ، عَنْ حَمْزَةَ، وَسَالِمٍ، ابْنَىْ عَبْدِ اللَّهِ بْنِ عُمَرَ عَنْ عَبْدِ اللَّهِ بْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ الشُّؤْمُ فِي الدَّارِ وَالْمَرْأَةِ وَالْفَرَسِ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1912", "arabic": "وَحَدَّثَنِي مَالِكٌ، عَنْ يَحْيَى بْنِ سَعِيدٍ، أَنَّهُ قَالَ جَاءَتِ امْرَأَةٌ إِلَى رَسُولِ اللَّهِ صلى الله عليه وسلم فَقَالَتْ يَا رَسُولَ اللَّهِ دَارٌ سَكَنَّاهَا وَالْعَدَدُ كَثِيرٌ وَالْمَالُ وَافِرٌ فَقَلَّ الْعَدَدُ وَذَهَبَ الْمَالُ ‏.‏ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ دَعُوهَا ذَمِيمَةً ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1913", "arabic": "حَدَّثَنِي مَالِكٌ، عَنْ يَحْيَى بْنِ سَعِيدٍ، أَنَّ رَسُولَ اللَّهِ قَالَ لِلَقْحَةٍ تُحْلَبُ ‏\"‏ مَنْ يَحْلُبُ هَذِهِ ‏\"‏ ‏.‏ فَقَامَ رَجُلٌ فَقَالَ لَهُ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ مَا اسْمُكَ ‏\"‏ ‏.‏ فَقَالَ لَهُ الرَّجُلُ مُرَّةُ ‏.‏ فَقَالَ لَهُ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ اجْلِسْ ‏\"‏ ‏.‏ ثُمَّ قَالَ ‏\"‏ مَنْ يَحْلُبُ هَذِهِ ‏\"‏ ‏.‏ فَقَامَ رَجُلٌ فَقَالَ لَهُ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ مَا اسْمُكَ ‏\"‏ ‏.‏ فَقَالَ حَرْبٌ ‏.‏ فَقَالَ لَهُ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ اجْلِسْ ‏\"‏ ‏.‏ ثُمَّ قَالَ ‏\"‏ مَنْ يَحْلُبُ هَذِهِ ‏\"‏ ‏.‏ فَقَامَ رَجُلٌ فَقَالَ لَهُ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ مَا اسْمُكَ ‏\"‏ ‏.‏ فَقَالَ يَعِيشُ ‏.‏ فَقَالَ لَهُ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ احْلُبْ ‏\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1914", "arabic": "وَحَدَّثَنِي مَالِكٌ، عَنْ يَحْيَى بْنِ سَعِيدٍ، أَنَّ عُمَرَ بْنَ الْخَطَّابِ، قَالَ لِرَجُلٍ مَا اسْمُكَ فَقَالَ جَمْرَةُ ‏.‏ فَقَالَ ابْنُ مَنْ فَقَالَ ابْنُ شِهَابٍ ‏.‏ قَالَ مِمَّنْ قَالَ مِنَ الْحُرَقَةِ ‏.‏ قَالَ أَيْنَ مَسْكَنُكَ قَالَ بِحَرَّةِ النَّارِ ‏.‏ قَالَ بِأَيِّهَا قَالَ بِذَاتِ لَظًى ‏.‏ قَالَ عُمَرُ أَدْرِكْ أَهْلَكَ فَقَدِ احْتَرَقُوا ‏.‏ قَالَ فَكَانَ كَمَا قَالَ عُمَرُ بْنُ الْخَطَّابِ رضى الله عنه ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1915", "arabic": "حَدَّثَنِي مَالِكٌ، عَنْ حُمَيْدٍ الطَّوِيلِ، عَنْ أَنَسِ بْنِ مَالِكٍ، أَنَّهُ قَالَ احْتَجَمَ رَسُولُ اللَّهِ صلى الله عليه وسلم حَجَمَهُ أَبُو طَيْبَةَ فَأَمَرَ لَهُ رَسُولُ اللَّهِ صلى الله عليه وسلم بِصَاعٍ مِنْ تَمْرٍ وَأَمَرَ أَهْلَهُ أَنْ يُخَفِّفُوا عَنْهُ مِنْ خَرَاجِهِ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1916", "arabic": "وَحَدَّثَنِي مَالِكٌ، أَنَّهُ بَلَغَهُ أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ إِنْ كَانَ دَوَاءٌ يَبْلُغُ الدَّاءَ فَإِنَّ الْحِجَامَةَ تَبْلُغُهُ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1917", "arabic": "وَحَدَّثَنِي مَالِكٌ، عَنِ ابْنِ شِهَابٍ، عَنِ ابْنِ مُحَيِّصَةَ الأَنْصَارِيِّ، أَحَدِ بَنِي حَارِثَةَ أَنَّهُ اسْتَأْذَنَ رَسُولَ اللَّهِ صلى الله عليه وسلم فِي إِجَارَةِ الْحَجَّامِ فَنَهَاهُ عَنْهَا فَلَمْ يَزَلْ يَسْأَلُهُ وَيَسْتَأْذِنُهُ حَتَّى قَالَ ‏ ‏ اعْلِفْهُ نُضَّاحَكَ ‏\"\"‏ ‏.‏ يَعْنِي رَقِيقَكَ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1918", "arabic": "حَدَّثَنِي مَالِكٌ، عَنْ عَبْدِ اللَّهِ بْنِ دِينَارٍ، عَنْ عَبْدِ اللَّهِ بْنِ عُمَرَ، أَنَّهُ قَالَ رَأَيْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم يُشِيرُ إِلَى الْمَشْرِقِ وَيَقُولُ ‏ ‏ هَا إِنَّ الْفِتْنَةَ هَا هُنَا إِنَّ الْفِتْنَةَ هَا هُنَا مِنْ حَيْثُ يَطْلُعُ قَرْنُ الشَّيْطَانِ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1919", "arabic": "وَحَدَّثَنِي مَالِكٌ، أَنَّهُ بَلَغَهُ أَنَّ عُمَرَ بْنَ الْخَطَّابِ، أَرَادَ الْخُرُوجَ إِلَى الْعِرَاقِ فَقَالَ لَهُ كَعْبُ الأَحْبَارِ لاَ تَخْرُجْ إِلَيْهَا يَا أَمِيرَ الْمُؤْمِنِينَ فَإِنَّ بِهَا تِسْعَةَ أَعْشَارِ السِّحْرِ وَبِهَا فَسَقَةُ الْجِنِّ وَبِهَا الدَّاءُ الْعُضَالُ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1920", "arabic": "حَدَّثَنِي مَالِكٌ، عَنْ نَافِعٍ، عَنْ أَبِي لُبَابَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم نَهَى عَنْ قَتْلِ الْحَيَّاتِ الَّتِي فِي الْبُيُوتِ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1921", "arabic": "وَحَدَّثَنِي مَالِكٌ، عَنْ نَافِعٍ، عَنْ سَائِبَةَ، مَوْلاَةٍ لِعَائِشَةَ ‏.‏ أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم نَهَى عَنْ قَتْلِ الْجِنَّانِ الَّتِي فِي الْبُيُوتِ إِلاَّ ذَا الطُّفْيَتَيْنِ وَالأَبْتَرَ فَإِنَّهُمَا يَخْطِفَانِ الْبَصَرَ وَيَطْرَحَانِ مَا فِي بُطُونِ النِّسَاءِ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1922", "arabic": "وَحَدَّثَنِي مَالِكٌ، عَنْ صَيْفِيٍّ، مَوْلَى ابْنِ أَفْلَحَ عَنْ أَبِي السَّائِبِ، مَوْلَى هِشَامِ بْنِ زُهْرَةَ أَنَّهُ قَالَ دَخَلْتُ عَلَى أَبِي سَعِيدٍ الْخُدْرِيِّ فَوَجَدْتُهُ يُصَلِّي فَجَلَسْتُ أَنْتَظِرُهُ حَتَّى قَضَى صَلاَتَهُ فَسَمِعْتُ تَحْرِيكًا تَحْتَ سَرِيرٍ فِي بَيْتِهِ فَإِذَا حَيَّةٌ فَقُمْتُ لأَقْتُلَهَا فَأَشَارَ أَبُو سَعِيدٍ أَنِ اجْلِسْ فَلَمَّا انْصَرَفَ أَشَارَ إِلَى بَيْتٍ فِي الدَّارِ فَقَالَ أَتَرَى هَذَا الْبَيْتَ فَقُلْتُ نَعَمْ ‏.‏ قَالَ إِنَّهُ قَدْ كَانَ فِيهِ فَتًى حَدِيثُ عَهْدٍ بِعُرْسٍ فَخَرَجَ مَعَ رَسُولِ اللَّهِ صلى الله عليه وسلم إِلَى الْخَنْدَقِ فَبَيْنَا هُوَ بِهِ إِذْ أَتَاهُ الْفَتَى يَسْتَأْذِنُهُ فَقَالَ يَا رَسُولَ اللَّهِ ائْذَنْ لِي أُحْدِثُ بِأَهْلِي عَهْدًا فَأَذِنَ لَهُ رَسُولُ اللَّهِ صلى الله عليه وسلم وَقَالَ ‏\"‏ خُذْ عَلَيْكَ سِلاَحَكَ فَإِنِّي أَخْشَى عَلَيْكَ بَنِي قُرَيْظَةَ ‏\"‏ فَانْطَلَقَ الْفَتَى إِلَى أَهْلِهِ فَوَجَدَ امْرَأَتَهُ قَائِمَةً بَيْنَ الْبَابَيْنِ فَأَهْوَى إِلَيْهَا بِالرُّمْحِ لِيَطْعُنَهَا وَأَدْرَكَتْهُ غَيْرَةٌ فَقَالَتْ لاَ تَعْجَلْ حَتَّى تَدْخُلَ وَتَنْظُرَ مَا فِي بَيْتِكَ ‏.‏ فَدَخَلَ فَإِذَا هُوَ بِحَيَّةٍ مُنْطَوِيَةٍ عَلَى فِرَاشِهِ فَرَكَزَ فِيهَا رُمْحَهُ ثُمَّ خَرَجَ بِهَا فَنَصَبَهُ فِي الدَّارِ فَاضْطَرَبَتِ الْحَيَّةُ فِي رَأْسِ الرُّمْحِ وَخَرَّ الْفَتَى مَيِّتًا فَمَا يُدْرَى أَيُّهُمَا كَانَ أَسْرَعَ مَوْتًا الْفَتَى أَمِ الْحَيَّةُ فَذُكِرَ ذَلِكَ لِرَسُولِ اللَّهِ صلى الله عليه وسلم فَقَالَ ‏\"‏ إِنَّ بِالْمَدِينَةِ جِنًّا قَدْ أَسْلَمُوا فَإِذَا رَأَيْتُمْ مِنْهُمْ شَيْئًا فَآذِنُوهُ ثَلاَثَةَ أَيَّامٍ فَإِنْ بَدَا لَكُمْ بَعْدَ ذَلِكَ فَاقْتُلُوهُ فَإِنَّمَا هُوَ شَيْطَانٌ ‏\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1923", "arabic": "حَدَّثَنِي مَالِكٌ، أَنَّهُ بَلَغَهُ أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم كَانَ إِذَا وَضَعَ رِجْلَهُ فِي الْغَرْزِ وَهُوَ يُرِيدُ السَّفَرَ يَقُولُ ‏ ‏ بِاسْمِ اللَّهِ ‏.‏ اللَّهُمَّ أَنْتَ الصَّاحِبُ فِي السَّفَرِ وَالْخَلِيفَةُ فِي الأَهْلِ اللَّهُمَّ ازْوِ لَنَا الأَرْضَ وَهَوِّنْ عَلَيْنَا السَّفَرَ اللَّهُمَّ إِنِّي أَعُوذُ بِكَ مِنْ وَعْثَاءِ السَّفَرِ وَمِنْ كَآبَةِ الْمُنْقَلَبِ وَمِنْ سُوءِ الْمَنْظَرِ فِي الْمَالِ وَالأَهْلِ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1924", "arabic": "وَحَدَّثَنِي مَالِكٌ، عَنِ الثِّقَةِ، عِنْدَهُ عَنْ يَعْقُوبَ بْنِ عَبْدِ اللَّهِ بْنِ الأَشَجِّ، عَنْ بُسْرِ بْنِ سَعِيدٍ، عَنْ سَعْدِ بْنِ أَبِي وَقَّاصٍ، عَنْ خَوْلَةَ بِنْتِ حَكِيمٍ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ مَنْ نَزَلَ مَنْزِلاً فَلْيَقُلْ أَعُوذُ بِكَلِمَاتِ اللَّهِ التَّامَّاتِ مِنْ شَرِّ مَا خَلَقَ ‏.‏ فَإِنَّهُ لَنْ يَضُرَّهُ شَىْءٌ حَتَّى يَرْتَحِلَ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1925", "arabic": "حَدَّثَنِي مَالِكٌ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ حَرْمَلَةَ، عَنْ عَمْرِو بْنِ شُعَيْبٍ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ الرَّاكِبُ شَيْطَانٌ وَالرَّاكِبَانِ شَيْطَانَانِ وَالثَّلاَثَةُ رَكْبٌ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1926", "arabic": "وَحَدَّثَنِي مَالِكٌ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ حَرْمَلَةَ، عَنْ سَعِيدِ بْنِ الْمُسَيَّبِ، أَنَّهُ كَانَ يَقُولُ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ الشَّيْطَانُ يَهُمُّ بِالْوَاحِدِ وَالاِثْنَيْنِ فَإِذَا كَانُوا ثَلاَثَةً لَمْ يَهُمَّ بِهِمْ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1927", "arabic": "وَحَدَّثَنِي مَالِكٌ، عَنْ سَعِيدِ بْنِ أَبِي سَعِيدٍ الْمَقْبُرِيِّ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ لاَ يَحِلُّ لاِمْرَأَةٍ تُؤْمِنُ بِاللَّهِ وَالْيَوْمِ الآخَرِ تُسَافِرُ مَسِيرَةَ يَوْمٍ وَلَيْلَةٍ إِلاَّ مَعَ ذِي مَحْرَمٍ مِنْهَا ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1928", "arabic": "حَدَّثَنِي مَالِكٌ، عَنْ أَبِي عُبَيْدٍ، مَوْلَى سُلَيْمَانَ بْنِ عَبْدِ الْمَلِكِ عَنْ خَالِدِ بْنِ مَعْدَانَ، يَرْفَعُهُ ‏ ‏ إِنَّ اللَّهَ تَبَارَكَ وَتَعَالَى رَفِيقٌ يُحِبُّ الرِّفْقَ وَيَرْضَى بِهِ وَيُعِينُ عَلَيْهِ مَا لاَ يُعِينُ عَلَى الْعُنْفِ فَإِذَا رَكِبْتُمْ هَذِهِ الدَّوَابَّ الْعُجْمَ فَأَنْزِلُوهَا مَنَازِلَهَا فَإِنْ كَانَتِ الأَرْضُ جَدْبَةً فَانْجُوا عَلَيْهَا بِنِقْيِهَا وَعَلَيْكُمْ بِسَيْرِ اللَّيْلِ فَإِنَّ الأَرْضَ تُطْوَى بِاللَّيْلِ مَا لاَ تُطْوَى بِالنَّهَارِ وَإِيَّاكُمْ وَالتَّعْرِيسَ عَلَى الطَّرِيقِ فَإِنَّهَا طُرُقُ الدَّوَابِّ وَمَأْوَى الْحَيَّاتِ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1929", "arabic": "وَحَدَّثَنِي مَالِكٌ، عَنْ سُمَىٍّ، مَوْلَى أَبِي بَكْرٍ عَنْ أَبِي صَالِحٍ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ السَّفَرُ قِطْعَةٌ مِنَ الْعَذَابِ يَمْنَعُ أَحَدَكُمْ نَوْمَهُ وَطَعَامَهُ وَشَرَابَهُ فَإِذَا قَضَى أَحَدُكُمْ نَهْمَتَهُ مِنْ وَجْهِهِ فَلْيُعَجِّلْ إِلَى أَهْلِهِ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1930", "arabic": "حَدَّثَنِي مَالِكٌ، أَنَّهُ بَلَغَهُ أَنَّ أَبَا هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ لِلْمَمْلُوكِ طَعَامُهُ وَكِسْوَتُهُ بِالْمَعْرُوفِ وَلاَ يُكَلَّفُ مِنَ الْعَمَلِ إِلاَّ مَا يُطِيقُ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1931", "arabic": "وَحَدَّثَنِي مَالِكٌ، أَنَّهُ بَلَغَهُ أَنَّ عُمَرَ بْنَ الْخَطَّابِ، كَانَ يَذْهَبُ إِلَى الْعَوَالِي كُلَّ يَوْمِ سَبْتٍ فَإِذَا وَجَدَ عَبْدًا فِي عَمَلٍ لاَ يُطِيقُهُ وَضَعَ عَنْهُ مِنْهُ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1932", "arabic": "وَحَدَّثَنِي مَالِكٌ، عَنْ عَمِّهِ أَبِي سُهَيْلِ بْنِ مَالِكٍ، عَنْ أَبِيهِ، أَنَّهُ سَمِعَ عُثْمَانَ بْنَ عَفَّانَ، وَهُوَ يَخْطُبُ وَهُوَ يَقُولُ لاَ تُكَلِّفُوا الأَمَةَ غَيْرَ ذَاتِ الصَّنْعَةِ الْكَسْبَ فَإِنَّكُمْ مَتَى كَلَّفْتُمُوهَا ذَلِكَ كَسَبَتْ بِفَرْجِهَا وَلاَ تُكَلِّفُوا الصَّغِيرَ الْكَسْبَ فَإِنَّهُ إِذَا لَمْ يَجِدْ سَرَقَ وَعِفُّوا إِذْ أَعَفَّكُمُ اللَّهُ وَعَلَيْكُمْ مِنَ الْمَطَاعِمِ بِمَا طَابَ مِنْهَا ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1933", "arabic": "حَدَّثَنِي مَالِكٌ، عَنْ نَافِعٍ، عَنْ عَبْدِ اللَّهِ بْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ الْعَبْدُ إِذَا نَصَحَ لِسَيِّدِهِ وَأَحْسَنَ عِبَادَةَ اللَّهِ فَلَهُ أَجْرُهُ مَرَّتَيْنِ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1934", "arabic": "وَحَدَّثَنِي مَالِكٌ، أَنَّهُ بَلَغَهُ أَنَّ أَمَةً، كَانَتْ لِعَبْدِ اللَّهِ بْنِ عُمَرَ بْنِ الْخَطَّابِ رَآهَا عُمَرُ بْنُ الْخَطَّابِ وَقَدْ تَهَيَّأَتْ بِهَيْئَةِ الْحَرَائِرِ فَدَخَلَ عَلَى ابْنَتِهِ حَفْصَةَ فَقَالَ أَلَمْ أَرَ جَارِيَةَ أَخِيكِ تَجُوسُ النَّاسَ وَقَدْ تَهَيَّأَتْ بِهَيْئَةِ الْحَرَائِرِ وَأَنْكَرَ ذَلِكَ عُمَرُ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
