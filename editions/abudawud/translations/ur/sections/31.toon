{"hadithnumber": "3926", "text": "عبداللہ بن عمرو رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  مکاتب ۱؎ اس و"}
{"hadithnumber": "3927", "text": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جس غلام نے سو او"}
{"hadithnumber": "3928", "text": "ام المؤمنین ام سلمہ رضی اللہ عنہا کے مکاتب غلام نبھان کہتے ہیں کہ  میں نے ام سلمہ رضی اللہ عنہا کو ک"}
{"hadithnumber": "3929", "text": "عروہ سے روایت ہے کہ  ام المؤمنین عائشہ رضی اللہ عنہا نے انہیں بتایا کہ بریرہ رضی اللہ عنہا اپنے بدل"}
{"hadithnumber": "3930", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  بریرہ رضی اللہ عنہا اپنے بدل کتابت میں تعاون کے لیے ان"}
{"hadithnumber": "3931", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  ام المؤمنین جویریہ بنت حارث بن مصطلق رضی اللہ عنہا ثابت"}
{"hadithnumber": "3932", "text": "سفینہ کہتے ہیں کہ  میں ام المؤمنین ام سلمہ رضی اللہ عنہا کا غلام تھا، وہ مجھ سے بولیں: میں تمہیں آزا"}
{"hadithnumber": "3933", "text": "اسامہ بن عمیر الہذلی رضی اللہ عنہ سے روایت ہے کہ  ایک شخص نے غلام میں سے اپنے حصہ کو آزاد کر دیا، نب"}
{"hadithnumber": "3934", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں  ایک شخص نے کسی غلام میں سے اپنا حصہ آزاد کر دیا تو نبی اکرم صلی اللہ"}
{"hadithnumber": "3935", "text": "قتادہ اس سند سے بھی نبی اکرم صلی اللہ علیہ وسلم سے مرفوعاً روایت کرتے ہیں کہ  آپ نے فرمایا:  جس نے ک"}
{"hadithnumber": "3936", "text": "قتادہ اس سند سے بھی روایت کرتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جس نے کسی مشترک غلام"}
{"hadithnumber": "3937", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو اپنے مشترک غلام میں س"}
{"hadithnumber": "3938", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے کسی مشترک غلام"}
{"hadithnumber": "3939", "text": "اس سند سے سعید سے بھی اسی مفہوم کی حدیث اسی طریق سے مروی ہے  ابوداؤد کہتے ہیں: اور اسے روح بن عبادہ"}
{"hadithnumber": "3940", "text": "عبداللہ بن عمر رضی اللہ عنہما سے رویت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص  ( مشتر"}
{"hadithnumber": "3941", "text": "اس سند سے بھی اسی مفہوم کی  روایت ابن عمر رضی اللہ عنہما سے مرفوعاً مروی ہے۔ راوی کہتے ہیں: نافع نے"}
{"hadithnumber": "3942", "text": "اس سند سے بھی ابن عمر رضی اللہ عنہما سے یہی حدیث مرفوعاً مروی ہے  ایوب کہتے ہیں: مجھے نہیں معلوم کہ"}
{"hadithnumber": "3943", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص  ( مشترک )"}
{"hadithnumber": "3944", "text": "اس سند سے بھی ابن عمر رضی اللہ عنہما سے  ابراہیم بن موسیٰ کی روایت کے ہم معنی روایت مرفوعاً مروی ہے۔"}
{"hadithnumber": "3945", "text": "اس سند سے بھی ابن عمر رضی اللہ عنہما سے مالک کی روایت کے ہم معنی روایت مرفوعاً مروی ہے  مگر اس میں:"}
{"hadithnumber": "3946", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جو شخص  ( مشترک )"}
{"hadithnumber": "3947", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جب غلام دو آدمیوں"}
{"hadithnumber": "3948", "text": "تلب بن ثعلبہ تمیمی عنبری رضی اللہ عنہ روایت کرتے ہیں کہ  ایک شخص نے غلام میں سے اپنا حصہ آزاد کر دیا"}
{"hadithnumber": "3949", "text": "سمرہ بن جندب رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جو کسی قرابت دار م"}
{"hadithnumber": "3950", "text": "عمر بن خطاب رضی اللہ عنہ کہتے ہیں  جو کسی قرابت دار محرم کا مالک ہو جائے تو وہ  ( ملکیت میں آتے ہی )"}
{"hadithnumber": "3951", "text": "حسن کہتے ہیں  جو کسی قرابت دار محرم کا مالک ہو جائے تو  ( وہ ملکیت میں آتے ہی )  آزاد ہو جائے گا۔"}
{"hadithnumber": "3952", "text": "جابر بن زید اور حسن سے بھی اسی کے ہم مثل مروی ہے  ابوداؤد کہتے ہیں: سعید حماد  ( حماد بن سلمہ )  سے"}
{"hadithnumber": "3953", "text": "بنی خارجہ قیس عیلان کی ایک خاتون سلامہ بنت معقل کہتی ہیں کہ  جاہلیت میں مجھے میرے چچا لے کر آئے اور"}
{"hadithnumber": "3954", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں  ہم رسول اللہ صلی اللہ علیہ وسلم اور ابوبکر رضی اللہ عنہ کے"}
{"hadithnumber": "3955", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  ایک شخص نے اپنے غلام کو اپنے مرنے کے بعد آزاد کر دیا اور"}
{"hadithnumber": "3956", "text": "عطاء بن ابی رباح کہتے ہیں کہ  مجھ سے جابر بن عبداللہ رضی اللہ عنہما نے یہی روایت بیان کی ہے اور اس م"}
{"hadithnumber": "3957", "text": "جابر رضی اللہ عنہ کہتے ہیں کہ  ایک ابومذکور نامی انصاری نے اپنے یعقوب نامی ایک غلام کو اپنے مرنے کے"}
{"hadithnumber": "3958", "text": "عمران بن حصین رضی اللہ عنہما کہتے ہیں کہ ایک شخص نے اپنی موت کے وقت اپنے چھ غلاموں کو آزاد کر دیا ان"}
{"hadithnumber": "3959", "text": "اس سند سے بھی ابوقلابہ سے اسی طریق سے اسی مفہوم کی حدیث مروی ہے  اور اس میں یہ نہیں ہے کہ رسول اللہ"}
{"hadithnumber": "3960", "text": "ابوزید رضی اللہ عنہ کہتے ہیں کہ  ایک انصاری نے ... آگے انہوں نے اسی مفہوم کی حدیث بیان کی اس میں یہ"}
{"hadithnumber": "3961", "text": "عمران بن حصین رضی اللہ عنہما کہتے ہیں کہ  ایک شخص نے اپنی موت کے وقت اپنے چھ کے چھ غلاموں کو آزاد کر"}
{"hadithnumber": "3962", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو کسی غلام کو آ"}
{"hadithnumber": "3963", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  زنا کا بچہ تینوں میں سب"}
{"hadithnumber": "3964", "text": "غریف بن دیلمی کہتے ہیں  ہم واثلہ بن اسقع رضی اللہ عنہ کے پاس آئے اور ہم نے ان سے کہا: آپ ہم سے کوئی"}
{"hadithnumber": "3965", "text": "ابونجیح سلمی رضی اللہ عنہ کہتے ہیں کہ  ہم نے رسول اللہ صلی اللہ علیہ وسلم کے ساتھ طائف کے محل کا محا"}
{"hadithnumber": "3966", "text": "شرحبیل بن سمط کہتے ہیں کہ  انہوں نے عمرو بن عبسہ رضی اللہ عنہ سے کہا: آپ ہم سے کوئی ایسی حدیث بیان ک"}
{"hadithnumber": "3967", "text": "شرحبیل بن سمط کہتے ہیں کہ  انہوں نے کعب بن مرہ یا مرہ بن کعب رضی اللہ عنہ سے کہا کہ مجھ سے کوئی ایسی"}
{"hadithnumber": "3968", "text": "ابوالدرداء رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو مرتے وقت غلام آزاد"}
