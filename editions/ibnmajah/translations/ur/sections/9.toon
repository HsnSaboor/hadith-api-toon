{"hadithnumber": "1999", "text": "مسور بن مخرمہ رضی اللہ عنہما کہتے ہیں کہ  علی بن ابی طالب رضی اللہ عنہ نے ابوجہل کی بیٹی کو پیغام دی"}
{"hadithnumber": "2000", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی تھیں  کیا عورت اس بات سے نہیں شرماتی کہ وہ اپنے آپ کو نبی اکرم"}
{"hadithnumber": "2001", "text": "ثابت کہتے ہیں کہ  ہم انس بن مالک رضی اللہ عنہ کے ساتھ بیٹھے تھے، ان کے پاس ان کی ایک بیٹی تھی، انس ر"}
{"hadithnumber": "2002", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  قبیلہ بنی فزارہ کا ایک شخص رسول اللہ صلی اللہ علیہ وسلم کے پاس آ"}
{"hadithnumber": "2003", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  ایک بدوی  ( دیہاتی )  نبی اکرم صلی اللہ علیہ وسلم کے پ"}
{"hadithnumber": "2004", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  عبد بن زمعہ اور سعد رضی اللہ عنہما دونوں زمعہ کی لونڈی"}
{"hadithnumber": "2005", "text": "عمر بن خطاب رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلیاللہ علیہ وسلم  نے صاحب فراش کے لیے بچے کا فیص"}
{"hadithnumber": "2006", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  بچہ صاحب فراش کا ہے اور ز"}
{"hadithnumber": "2007", "text": "ابوامامہ باہلی رضی اللہ عنہ کہتے ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم کو فرماتے سنا:  بچہ صاحب"}
{"hadithnumber": "2008", "text": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  ایک عورت نے نبی اکرم صلی اللہ علیہ وسلم کے پاس آ کر"}
{"hadithnumber": "2009", "text": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے اپنی بیٹی زینب رضی ال"}
{"hadithnumber": "2010", "text": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے اپنی بیٹی زی"}
{"hadithnumber": "2011", "text": "جدامہ بنت وہب اسدیہ رضی اللہ عنہا کہتی ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  م"}
{"hadithnumber": "2012", "text": "اسماء بنت یزید رضی اللہ عنہا کہتی ہیں کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  اپنی"}
{"hadithnumber": "2013", "text": "ابوامامہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کے پاس ایک عورت آئی، اس کے ساتھ دو ب"}
{"hadithnumber": "2014", "text": "معاذ بن جبل رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب کوئی عورت اپنے شوہ"}
{"hadithnumber": "2015", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  حرام کام حلال"}
