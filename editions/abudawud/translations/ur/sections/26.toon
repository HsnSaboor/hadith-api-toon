{"hadithnumber": "3641", "text": "کثیر بن قیس کہتے ہیں کہ  میں ابو الدرداء رضی اللہ عنہ کے ساتھ دمشق کی مسجد میں بیٹھا تھا کہ اتنے میں"}
{"hadithnumber": "3642", "text": "اس سند سے بھی ابو الدرداء رضی اللہ عنہ سے  اسی مفہوم کی حدیث مرفوعاً مروی ہے۔"}
{"hadithnumber": "3643", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص حصول علم کے لیے ک"}
{"hadithnumber": "3644", "text": "ابونملہ انصاری رضی اللہ عنہ کہتے ہیں کہ  وہ رسول اللہ صلی اللہ علیہ وسلم کے پاس بیٹھے ہوئے تھے اور آ"}
{"hadithnumber": "3645", "text": "زید بن ثابت رضی اللہ عنہ کہتے ہیں  اللہ کے رسول صلی اللہ علیہ وسلم نے مجھے حکم دیا تو میں نے آپ کی خ"}
{"hadithnumber": "3646", "text": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں  میں ہر اس حدیث کو جو رسول اللہ صلی اللہ علیہ وسلم سے سنتا ی"}
{"hadithnumber": "3647", "text": "مطلب بن عبداللہ بن حنطب کہتے ہیں کہ  زید بن ثابت رضی اللہ عنہ معاویہ رضی اللہ عنہ کے پاس آئے اور ان"}
{"hadithnumber": "3648", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں  ہم لوگ تشہد اور قرآن کے علاوہ کچھ نہیں لکھتے تھے۔"}
{"hadithnumber": "3649", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں  جب مکہ فتح ہوا تو نبی اکرم صلی اللہ علیہ وسلم کھڑے ہوئے، پھر انہوں ن"}
{"hadithnumber": "3650", "text": "ولید (ولید بن مزید) کہتے ہیں  میں نے ابوعمرو  ( اوزاعی )  سے کہا:  وہ لوگ لکھ دیں  سے کیا مراد ہے؟ ا"}
{"hadithnumber": "3651", "text": "عبداللہ بن زبیر رضی اللہ عنہما کہتے ہیں کہ  میں نے زبیر رضی اللہ عنہ سے پوچھا: آپ رسول اللہ صلی اللہ"}
{"hadithnumber": "3652", "text": "جندب رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے اللہ تعالیٰ کی کتاب می"}
{"hadithnumber": "3653", "text": "ابو سلام ایک شخص سے جس نے نبی اکرم صلی اللہ علیہ وسلم کی خدمت کی ہے روایت کرتے ہیں، وہ کہتے ہیں کہ"}
{"hadithnumber": "3654", "text": "عروہ کہتے ہیں  ابوہریرہ رضی اللہ عنہ ام المؤمنین عائشہ رضی اللہ عنہا کے حجرے کے بغل میں بیٹھے تھے او"}
{"hadithnumber": "3655", "text": "عروہ بن زبیر کہتے ہیں کہ  ام المؤمنین عائشہ رضی اللہ عنہا نے کہا: کیا تمہیں ابوہریرہ رضی اللہ عنہ پر"}
{"hadithnumber": "3656", "text": "معاویہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے ایسی باتوں سے منع فرمایا ہے جس میں ب"}
{"hadithnumber": "3657", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے فتوی دیا  اور سلیم"}
{"hadithnumber": "3658", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس سے کوئی دین کا مسئلہ"}
{"hadithnumber": "3659", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم لوگ  ( علم د"}
{"hadithnumber": "3660", "text": "زید بن ثابت رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا:  اللہ"}
{"hadithnumber": "3661", "text": "سہل بن سعد رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  قسم اللہ کی، اگر تیر"}
{"hadithnumber": "3662", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  بنی اسرائیل سے روایت کرو"}
{"hadithnumber": "3663", "text": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم ہم سے بنی اسرائیل کی باتیں ا"}
{"hadithnumber": "3664", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس شخص نے ایسا علم صرف د"}
{"hadithnumber": "3665", "text": "عوف بن مالک اشجعی رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا:"}
{"hadithnumber": "3666", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں  میں غریب و خستہ حال مہاجرین کی جماعت میں جا بیٹھا، ان میں بعض ب"}
{"hadithnumber": "3667", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  میرا ایسی قوم کے ساتھ"}
{"hadithnumber": "3668", "text": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیںمجھ سے رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم مجھ پر سورۃ"}
