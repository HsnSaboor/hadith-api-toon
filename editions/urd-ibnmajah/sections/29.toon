hadiths[120]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
3251,عبداللہ بن سلام رضی اللہ عنہ کہتے ہیں کہ  جب نبی اکرم صلی اللہ علیہ وسلم مدینہ تشریف لائے تو لوگ آپ ,,,,,3251
3252,"عبداللہ بن عمر رضی اللہ عنہما کہتے تھے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  سلام کو پھیلاؤ،",,,,,3252
3253,عبداللہ بن عمرو رضی اللہ عنہما سے روایت ہے کہ  ایک شخص نے رسول اللہ صلی اللہ علیہ وسلم سے پوچھا اور ,,,,,3253
3254,"جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ایک شخص کا کھان",,,,,3254
3255,"عمر بن خطاب رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ایک آدمی کا کھانا دو",,,,,3255
3256,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مومن ایک آنت میں کھاتا ",,,,,3256
3257,"عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  کافر سات آنتوں م",,,,,3257
3258,"ابوموسیٰ اشعری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مومن صرف ایک آنت ",,,,,3258
3259,ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے کبھی کسی کھانے میں عیب نہیں لگایا,,,,,3259
3260,"انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہوسلما نے فرمایا:  جو یہ پسند کرے کہ الل",,,,,3260
3261,ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم بیت الخلاء سے نکلے تو کھانا لایا گیا,,,,,3261
3262,"ابوحجیفہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  میں ٹیک لگا کر نہیں کھات",,,,,3262
3263,عبداللہ بن بسر رضی اللہ عنہ کہتے ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم کی خدمت میں ایک بکری ہدی,,,,,3263
3264,ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم اپنے چھ صحابہ کے ساتھ کھان,,,,,3264
3265,عمر بن ابی سلمہ رضی اللہ عنہما کہتے ہیں کہ  جب میں کھانے جا رہا تھا تو مجھ سے نبی اکرم صلی اللہ علیہ,,,,,3265
3266,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  تم میں ہر شخص کو چاہیئے ک",,,,,3266
3267,عمر بن ابی سلمہ رضی اللہ عنہما کہتے ہیں کہ  میں بچہ تھا اور نبی اکرم صلی اللہ علیہ وسلم کے زیر تربیت,,,,,3267
3268,"جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  بائیں ہاتھ سے مت کھاؤ، اس ل",,,,,3268
3269,"عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں سے کوئ",,,,,3269
3270,"جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم میں سے کوئی اپنے ہاتھ کو ",,,,,3270
3271,ام عاصم بیان کرتی ہیں کہ  ہمارے پاس رسول اللہ صلی اللہ علیہ وسلم کے غلام نبیشہ رضی اللہ عنہ آئے، اس,,,,,3271
3272,معلی بن راشد ابوالیمان بیان کرتے ہیں کہ  مجھ سے میری دادی نے ہذیل کے نبیشہ الخیر نامی شخص سے نقل کیا,,,,,3272
3273,"عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب دستر خوان لگا",,,,,3273
3274,عکراش بن ذویب رضی اللہ عنہ کہتے ہیں  نبی اکرم صلی اللہ علیہ وسلم کی خدمت میں ایک لگن لایا گیا جس میں,,,,,3274
3275,عبداللہ بن بسر رضی اللہ عنہ بیان کرتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے پاس ایک پیالا لایا گیا,,,,,3275
3276,واثلہ بن اسقع لیثی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ثرید کے اونچے حصہ پر ہا,,,,,3276
3277,"عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب کھانا رکھ دی",,,,,3277
3278,معقل بن یسار رضی اللہ عنہ کہتے ہیں کہ  دوپہر کا کھانا کھانے کے دوران ایک لقمہ ان سے گر گیا، تو انہوں,,,,,3278
3279,"جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں سے کسی کے ہاتھ سے ",,,,,3279
3280,"ابوموسیٰ اشعری رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  مردوں میں بہت سے لو",,,,,3280
3281,"انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  عورتوں پر عائشہ رضی ا",,,,,3281
