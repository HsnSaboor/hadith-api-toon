hadiths[45]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
1763,عبیداللہ بن عبداللہ بن عتبہ بن مسعود رحمہ اللہ سے روایت ہے کہ بلاشبہ وہ حضرت ابوطلحہ انصاری رضی اللہ,,,1763,,
1764,سیدہ عائشہ رضی اللہ عنہا زوجہ پیغمبر ﷺ سے روایت ہے کہ انھوں نے ایک چھوٹا تکیہ خریدا جس میں تصویریں ت,,,1764,,
1765,"سلیمان بن یسار رحمہ اللہ سے روایت ہے ، کہتے ہیں : رسول اللہ ﷺ ( اپنی زوجہ محترہ ) سیدہ میمونہ بنت حا",,,1765,,
1766,حضرت خالد بن ولید بن مغیرہ رضی اللہ عنہ سے روایت ہے ، وہ رسول اللہ ﷺ کے ہمراہ سیدہ میمونہ رضی اللہ ع,,,1766,,
1767,حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ ایک آدمی نے رسول اللہ ﷺ کو پکارا اور عرض کیا کہ اے,,,1767,,
1768,حضرت سفیان بن ابی زہیر رضی اللہ عنہ جو کہ اَزْدِشنُوء ہ قبیلے میں سے ایک فرد ( تھے اور ) رسول اللہ ﷺ,,,1768,,
1769,"حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ نے فرمایا :’’ جس شخص نے کوئی بھ",,,1769,,
1770,حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ بے شک رسول اللہ ﷺ نے کتوں کے قتل کرنے کا حکم فرمای,,,1770,,
1771,"حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ بے شک رسول اللہ ﷺ نے فرمایا :’’ کفر کا سر ( بڑا کفر ) مشرق",,,1771,,
1772,"حضرت ابوسعید خدری رضی اللہ عنہ سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا :’’ قریب ہے کہ مسلمان کا بہترین ",,,1772,,
1773,"حضرت ابن عمر رضی اللہ عنہما سے روایت ہے کہ یقیناً رسول اللہ ﷺ نے فرمایا :’’ کوئی بھی شخص کسی دوسرے ش",,,1773,,
1774,"امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ بلاشبہ رسول اللہ ﷺ نے فرمایا :’’ کوئی نبی ایسا نہیں ہوا جس نے",,,1774,,
1775,نافع رحمہ اللہ سے روایت ہے کہ بیشک حضرت ابن عمر رضی اللہ عنہما کے سامنے شام کا کھانا پیش کر دیا جاتا,,,1775,,
1776,سیدہ میمونہ رضی اللہ عنہا زوجہ پیغمبر ﷺ سے روایت ہے کہ یقیناً رسول اللہ ﷺ سے چوہے کے متعلق سوال کیا ,,,1776,,
1777,"سہل بن سعد ساعدی رضی اللہ عنہ سے روایت ہے کہ بیشک رسول اللہ ﷺ نے فرمایا :’’ اگر وہ ہوتی تو گھوڑے ، ع",,,1777,,
1778,"حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ نے فرمایا :’’ نحوست تو گھر ، عو",,,1778,,
1779,یحیی بن سعید رحمہ اللہ سے روایت ہے ، کہتے ہیں کہ ایک عورت رسول اللہ ﷺ کے پاس آئی اور کہنے لگی کہ اے ,,,1779,,
1780,یحیی بن سعید رحمہ اللہ سے روایت ہے کہ بے شک رسول اللہ ﷺ نے بہت دودھ دینے والی ( دودھیل ) اونٹنی جس ک,,,1780,,
1781,"یحیی بن سعید رحمہ اللہ سے روایت ہے کہ بلاشبہ حضرت عمر بن خطاب رضی اللہ عنہ نے ایک آدمی سے کہا : تمھا",,,1781,,
1782,حضرت انس بن مالک رضی اللہ عنہ سے روایت ہے ، کہتے ہیں کہ رسول اللہ ﷺ نے پچھنے لگوائے ۔ حضرت ابوطیبہ ر,,,1782,,
1783,"امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ بلاشبہ رسول اللہ ﷺ نے فرمایا :’’ اگر کوئی دوائی ایسی ہے جو بی",,,1783,,
1784,ابن محیصہ انصاری رضی اللہ عنہ جو کہ ( خزرج قبیلے کی شاخ ) بنوحارثہ میں سے ایک فرد تھے ، سے روایت ہے ,,,1784,,
1785,حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے ، کہتے ہیں کہ بلاشک میں نے رسول اللہ ﷺ کو دیکھا ، آپ ,,,1785,,
1786,امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ بے شک حضرت عمر بن خطاب رضی اللہ عنہ نے عراق کی طرف نکلنے کا ا,,,1786,,
1787,حضرت ابولبابہ رضی اللہ عنہ سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ نے ان سفید باریک چھوٹے سانپوں کو قتل کر,,,1787,,
1788,سائبہ رحمۃ اللہ علیہما جو کہ سیدہ عائشہ رضی اللہ عنہا کی آزاد کردہ لونڈی ہیں ، سے روایت ہے کہ بلاشبہ,,,1788,,
1789,ابوسائب رحمہ اللہ ( عبداللہ بن سائب ) جو ہشام بن زہرہ کے آزاد کردہ غلام ہیں ، سے روایت ہے ، کہتے ہیں,,,1789,,
1790,امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ بلاشبہ رسول اللہ ﷺ جب رکاب ( سواری پر چڑھنے کے لیے پائیدان ) ,,,1790,,
1791,"سیدہ خولہ بنت حکیم رضی اللہ عنہا سے روایت ہے کہ یقیناً رسول اللہ ﷺ نے فرمایا :’’ جو کوئی شخص کسی بھی",,,1791,,
1792,عمرو بن شعیب رحمہ اللہ اپنے والد ( شعیب بن محمد رحمہ اللہ ) سے اور وہ اپنے دادا ( حضرت عبداللہ بن عم,,,1792,,
1793,"سعید بن مسیب رحمہ اللہ سے روایت ہے ، وہ کہا کرتے تھے کہ رسول اللہ ﷺ نے فرمایا :’’ شیطان ایک آدمی اور",,,1793,,
1794,"حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ نے فرمایا :’’ کوئی ایسی عورت جو اللہ او",,,1794,,
1795,خالد بن معدان رحمہ اللہ سے روایت ہے ، وہ اسے مرفوع ( یعنی رسول اللہ ﷺ سے ) بیان کرتے ہیں کہ بلاشبہ ا,,,1795,,
1796,"حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ نے فرمایا :’’ سفر عذاب کا ایک ٹکڑا ہے ۔",,,1796,,
1797,"حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا :’’ غلام کے لیے اس کا کھانا اور کپڑے",,,1797,,
1798,امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ بیشک حضرت عمر بن خطاب رضی اللہ عنہ ہر ہفتے کے دن عوالی ( مدین,,,1798,,
1799,امام مالک رحمہ اللہ اپنے چچا ابوسہیل بن مالک رحمہ اللہ سے اور وہ اپنے والد ( مالک بن ابی عامر اصبحی ,,,1799,,
1800,"حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ نے فرمایا :’’ غلام جب اپنے ( عا",,,1800,,
1801,امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ بے شک حضرت عبداللہ بن عمر بن خطاب رضی اللہ عنہما کی ایک لونڈی,,,1801,,
1802,حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے ، کہتے ہیں کہ ہم جب رسول اللہ ﷺ کی سمع و طاعت ( بات س,,,1802,,
1803,حضرت امیمہ بنت رقیقہ رضی اللہ عنہا سے روایت ہے ، کہتی ہیں کہ میں کچھ عورتوں میں ( شامل ہو کر ) رسول ,,,1803,,
1804,عبداللہ بن دینار رضی اللہ عنہ سے روایت ہے کہ بے شک حضرت عبداللہ بن عمر رضی اللہ عنہما نے ( حضرت عبدا,,,1804,,
1805,"حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ نے فرمایا :’’ جس شخص نے اپنے بھ",,,1805,,
1806,"حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ یقیناً رسول اللہ ﷺ نے فرمایا :’’ جب تم کسی شخص کو یہ کہتے ",,,1806,,
1807,"حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ بے شک رسول اللہ ﷺ نے فرمایا :’’ تم میں سے کوئی بھی ہرگز یہ",,,1807,,
