{"hadithnumber": "1402", "arabic": "حَدَّثَنَا عِيسَى بْنُ حَمَّادٍ الْمِصْرِيُّ، ‏‏‏‏‏‏أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، ‏‏‏‏‏‏عَنْ سَ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Bukhari'}", "reference": "Book 5, Hadith 600", "international_number": "1402", "narrator_chain": ""}
{"hadithnumber": "1403", "arabic": "حَدَّثَنَا يَحْيَى بْنُ عُثْمَانَ بْنِ سَعِيدِ بْنِ كَثِيرِ بْنِ دِينَارٍ الْحِمْصِيُّ، ‏‏‏‏‏‏حَدَّث", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 5, Hadith 601", "international_number": "1403", "narrator_chain": ""}
{"hadithnumber": "1404", "arabic": "حَدَّثَنَا أَبُو مُصْعَبٍ الْمَدَنِيُّ أَحْمَدُ بْنُ أَبِي بَكْرٍ، ‏‏‏‏‏‏حَدَّثَنَا مَالِكُ بْنُ أَن", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Bukhari And Muslim'}", "reference": "Book 5, Hadith 602", "international_number": "1404", "narrator_chain": ""}
{"hadithnumber": "1405", "arabic": "حَدَّثَنَا إِسْحَاق بْنُ مَنْصُورٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، ‏‏‏‏‏‏عَنْ عُبَيْ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 5, Hadith 603", "international_number": "1405", "narrator_chain": ""}
{"hadithnumber": "1406", "arabic": "حَدَّثَنَا إِسْمَاعِيل بْنُ أَسَدٍ، ‏‏‏‏‏‏حَدَّثَنَا زَكَرِيَّا بْنُ عَدِيٍّ، ‏‏‏‏‏‏أَنْبَأَنَا عُبَ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 5, Hadith 604", "international_number": "1406", "narrator_chain": ""}
{"hadithnumber": "1407", "arabic": "حَدَّثَنَا إِسْمَاعِيل بْنُ عَبْدِ اللَّهِ الرَّقِّيُّ، ‏‏‏‏‏‏حَدَّثَنَا عِيسَى بْنُ يُونُسَ، ‏‏‏‏‏‏", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Munkar'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 5, Hadith 605", "international_number": "1407", "narrator_chain": ""}
{"hadithnumber": "1408", "arabic": "حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ الْجَهْمِ الْأَنْمَاطِيُّ، ‏‏‏‏‏‏حَدَّثَنَا أَيُّوبُ بْنُ سُوَيْدٍ،", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 5, Hadith 606", "international_number": "1408", "narrator_chain": ""}
{"hadithnumber": "1409", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْأَعْلَى، ‏‏‏‏‏‏عَنْ مَعْمَرٍ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Bukhari And Muslim'}", "reference": "Book 5, Hadith 607", "international_number": "1409", "narrator_chain": ""}
{"hadithnumber": "1410", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ شُعَيْبٍ، ‏‏‏‏‏‏حَدَّثَنَا يَزِيدُ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Bukhari And Muslim'}", "reference": "Book 5, Hadith 608", "international_number": "1410", "narrator_chain": ""}
{"hadithnumber": "1411", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو أُسَامَةَ، ‏‏‏‏‏‏عَنْ عَبْدِ الْ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 5, Hadith 609", "international_number": "1411", "narrator_chain": ""}
{"hadithnumber": "1412", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِيل، ‏‏‏‏‏‏ وَعِيسَى بْنُ يُ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 5, Hadith 610", "international_number": "1412", "narrator_chain": ""}
{"hadithnumber": "1413", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو الْخَطَّابِ الدِّمَشْقِيُّ، ‏‏‏‏‏‏حَدَّثَنَ", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Very Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 5, Hadith 611", "international_number": "1413", "narrator_chain": ""}
