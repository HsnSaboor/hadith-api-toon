hadiths[65]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
617,ابوذر رضی الله عنہ کہتے ہیں کہ  میں رسول اللہ صلی اللہ علیہ وسلم کے پاس آیا، آپ کعبہ کے سائے میں بی,,,,,617
618,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جب تم نے اپنے مال کی زکاۃ",,,,,618
619,انس رضی الله عنہ کہتے ہیں کہ  ہم لوگوں کی خواہش ہوتی تھی کہ کوئی عقلمند اعرابی  ( دیہاتی )  آئے اور,,,,,619
620,"علی رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”میں نے گھوڑوں اور غلاموں کی ز",,,,,620
621,عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے زکاۃ کی دستاویز تحریر کرا,,,,,621
622,"عبداللہ بن مسعود رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”تیس گائے میں ا",,,,,622
623,معاذ بن جبل رضی الله عنہ کہتے ہیں  نبی اکرم صلی اللہ علیہ وسلم نے مجھے یمن بھیجا اور حکم دیا کہ میں ,,,,,623
624,"عمرو بن مرہ کہتے ہیں کہ  میں نے ابوعبیدہ بن عبداللہ سے پوچھا: کیا وہ  ( اپنے والد )  عبداللہ بن مسعو",,,,,624
625,عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے معاذ رضی الله عنہ کو یمن,,,,,625
626,"ابو سعید خدری رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”پانچ اونٹوں ۱؎ سے کم",,,,,626
627,اس سند سے بھی  ابو سعید خدری رضی الله عنہ نے نبی اکرم صلی اللہ علیہ وسلم سے اسی طرح کی حدیث بیان کی ,,,,,627
628,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”مسلمان پر نہ اس کے گھوڑو",,,,,628
629,"عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”شہد میں ہر دس مش",,,,,629
630,نافع کہتے ہیں کہ  مجھ سے عمر بن عبدالعزیز نے شہد کی زکاۃ کے بارے میں پوچھا تو میں نے کہا کہ ہمارے پا,,,,,630
631,"عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جسے کوئی مال حاص",,,,,631
632,عبداللہ بن عمر رضی الله عنہما کہتے ہیں  جسے کوئی مال حاصل ہو تو اس پر زکاۃ نہیں جب تک کہ اس کے ہاں ا,,,,,632
633,"عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”ایک سر زمین پر ",,,,,633
634,"اس سند سے بھی  قابوس سے اسی طرح مروی ہے۔ \r\n\r\nامام ترمذی کہتے ہیں: ۱- ابن عباس کی حدیث قابوس بن ابی ظ",,,,,634
635,عبداللہ بن مسعود کی اہلیہ زینب رضی الله عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ہم سے خطاب,,,,,635
636,اس سند سے بھی  عبداللہ بن مسعود کی اہلیہ زینب رضی الله عنہا کے واسطے سے نبی اکرم صلی اللہ علیہ وسلم ,,,,,636
637,عبداللہ بن عمرو رضی الله عنہما کہتے ہیں کہ  دو عورتیں رسول اللہ صلی اللہ علیہ وسلم کے پاس آئیں ان ک,,,,,637
638,معاذ رضی الله عنہ کہتے ہیں کہ  انہوں نے نبی اکرم صلی اللہ علیہ وسلم کو لکھا، وہ آپ سے سبزیوں کی زکاۃ,,,,,638
639,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس فصل کی سینچائی بارش ی",,,,,639
640,عبداللہ بن عمر رضی الله عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے یہ طریقہ جاری فرمایا ک,,,,,640
641,عبداللہ بن عمرو رضی الله عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے لوگوں سے خطاب کیا تو فرما,,,,,641
642,"ابوہریرہ رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جانور کا زخم رائیگاں ",,,,,642
643,عبدالرحمٰن بن مسعود بن نیار کہتے ہیں کہ  سہل بن ابی حثمہ رضی الله عنہ ہماری مجلس میں آئے تو بیان کی,,,,,643
644,عتاب بن اسید رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم لوگوں کے پاس ایک آدمی بھیجتے تھے,,,,,644
645,"رافع بن خدیج رضی الله عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا: ”صحیح ڈھنگ",,,,,645
646,"انس بن مالک رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”زکاۃ وصول کرنے میں ظل",,,,,646
647,"جریر رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جب زکاۃ وصول کرنے والا تمہارے",,,,,647
648,اس سند سے بھی  جریر رضی الله عنہ کے واسطہ سے نبی اکرم صلی اللہ علیہ وسلم سے اسی طرح مروی ہے۔ \r\n\r\nاما,,,,,648
649,ابوجحیفہ رضی الله عنہ کہتے ہیں کہ  ہمارے پاس رسول اللہ صلی اللہ علیہ وسلم کا مصدق  ( زکاۃ وصول کرنے ,,,,,649
650,"عبداللہ بن مسعود رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جو لوگوں سے سوال",,,,,650
651,سفیان نے بھی حکیم بن جبیر سے  یہ حدیث اسی سند سے روایت کی ہے۔ جب سفیان نے یہ حدیث روایت کی تو ان سے ,,,,,651
652,"عبداللہ بن عمرو رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”کسی مالدار کے",,,,,652
653,حبشی بن جنادہ سلولی رضی الله عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو حجۃ الوداع میں ,,,,,653
654,"اس سند سے بھی  عبدالرحیم بن سلیمان سے اسی طرح مروی ہے۔ \r\n\r\nامام ترمذی کہتے ہیں: اس سند سے یہ حدیث غر",,,,,654
655,ابو سعید خدری رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے زمانے میں ایک شخص ۱؎ کے پھلو,,,,,655
656,"معاویہ بن حیدہ قشیری رضی الله عنہ کہتے ہیں:  رسول اللہ صلی اللہ علیہ وسلم کے پاس جب کوئی چیز لائی جا",,,,,656
657,ابورافع رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے بنی مخزوم کے ایک شخص کو صدقہ کی وصو,,,,,657
658,"سلمان بن عامر رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جب تم میں سے کوئی",,,,,658
659,فاطمہ بنت قیس رضی الله عنہا کہتی ہیں کہ  میں نے زکاۃ کے بارے میں پوچھا، یا نبی اکرم صلی اللہ علیہ وس,,,,,659
660,"فاطمہ بنت قیس رضی الله عنہا سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”مال میں زکاۃ کے ",,,,,660
661,"ابوہریرہ رضی الله عنہ کہتے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے بھی کسی پاکیزہ چیز کا ",,,,,661
662,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اللہ صدقہ قبول کرتا ہے ا",,,,,662
663,"انس رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم سے پوچھا گیا: رمضان کے بعد کون سے روزے افض",,,,,663
664,"انس بن مالک رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”صدقہ رب کے غصے کو بجھ",,,,,664
665,عبدالرحمٰن بن بجید کی دادی  ام بجید حواء رضی الله عنہا  ( جو رسول اللہ صلی اللہ علیہ وسلم سے بیعت کر,,,,,665
666,صفوان بن امیہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے حنین کے روز مجھے دیا، آپ مجھ,,,,,666
667,بریدہ رضی الله عنہ کہتے ہیں کہ  میں نبی اکرم صلی اللہ علیہ وسلم کے پاس بیٹھا ہوا تھا، اتنے میں ایک ع,,,,,667
668,عمر رضی الله عنہ کہتے ہیں کہ  انہوں نے کسی کو ایک گھوڑا اللہ کی راہ میں دیا، پھر دیکھا کہ وہ گھوڑا ب,,,,,668
669,"عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  ایک شخص نے عرض کیا: اللہ کے رسول! میری والدہ فوت ہو چکی ",,,,,669
670,ابوامامہ باہلی رضی الله عنہ کہتے ہیں کہ  میں نے حجۃ الوداع کے سال رسول اللہ صلی اللہ علیہ وسلم کو اپ,,,,,670
671,"ام المؤمنین عائشہ رضی الله عنہا سے روایت ہے کہ  کہ نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جب عورت ا",,,,,671
672,"ام المؤمنین عائشہ رضی الله عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جب عورت اپنے ش",,,,,672
673,ابو سعید خدری رضی الله عنہ کہتے ہیں  ہم لوگ جب رسول اللہ صلی اللہ علیہ وسلم ہمارے درمیان موجود تھے -,,,,,673
674,عبداللہ بن عمرو رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے ایک شخص کو مکہ کی گلیو,,,,,674
675,عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے صدقہ فطر مرد، عورت، آزاد,,,,,675
676,عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے رمضان کا صدقہ فطر ایک صاع,,,,,676
677,عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم عید الفطر کے دن نماز کے لیے ,,,,,677
678,علی رضی الله عنہ کہتے ہیں کہ  عباس رضی الله عنہ نے رسول اللہ صلی اللہ علیہ وسلم سے اپنی زکاۃ وقت سے ,,,,,678
679,"علی رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے عمر رضی الله عنہ سے فرمایا: ”ہم عباس سے",,,,,679
680,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا: ”تم میں سے کوئ",,,,,680
681,"سمرہ بن جندب رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”مانگنا ایک زخم ہے جس",,,,,681
