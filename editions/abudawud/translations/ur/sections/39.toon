{"hadithnumber": "4291", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ اس امت کے لیے ہر صد"}
{"hadithnumber": "4292", "text": "حسان بن عطیہ کہتے ہیں کہ  مکحول اور ابن ابی زکریا: خالد بن معدان کی طرف چلے، میں بھی ان کے ساتھ چلا"}
{"hadithnumber": "4293", "text": "اس سند سے بھی حسان بن عطیہ سے یہی حدیث مروی ہے  اس میں یہ اضافہ ہے:  پھر جلدی سے مسلمان اپنے ہتھیارو"}
{"hadithnumber": "4294", "text": "معاذ بن جبل رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  بیت المقدس کی آبادی م"}
{"hadithnumber": "4295", "text": "معاذ بن جبل رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  بڑی جنگ، قسطنطنیہ کی"}
{"hadithnumber": "4296", "text": "عبداللہ بن بسر رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  بڑی جنگ اور فتح"}
{"hadithnumber": "4297", "text": "ثوبان رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  قریب ہے کہ دیگر قومیں تم پر"}
{"hadithnumber": "4298", "text": "ابوالدرداء رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:   ( دجال سے )  جنگ کے ر"}
{"hadithnumber": "4299", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  قریب ہے کہ مسلما"}
{"hadithnumber": "4300", "text": "زہری کہتے ہیں  سلاح خیبر کے قریب  ( ایک جگہ )  ہے۔"}
{"hadithnumber": "4301", "text": "عوف بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ تعالیٰ اس امت پر"}
{"hadithnumber": "4302", "text": "ایک صحابی رسول رضی اللہ عنہ روایت کرتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  حبشہ کے کافرو"}
{"hadithnumber": "4303", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  قیامت قائم نہیں ہو گی جب"}
{"hadithnumber": "4304", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  قیامت قائم نہیں ہو گی"}
{"hadithnumber": "4305", "text": "بریدہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم فرماتے ہیں:  تم سے ایک ایسی قوم لڑے گی ج"}
{"hadithnumber": "4306", "text": "ابوبکرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  میری امت کے کچھ لوگ دجلہ"}
{"hadithnumber": "4307", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  لوگ شہر بسائیں گے انہیں شہروں میں سے ایک شہر ہو گا جسے بصرہ یا"}
{"hadithnumber": "4308", "text": "صالح بن درہم کہتے ہیں کہ  ہم حج کے ارادہ سے چلے تو اچانک ہمیں ایک شخص ملا ۱؎ جس نے ہم سے پوچھا: کیا"}
