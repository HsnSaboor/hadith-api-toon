{"hadithnumber": "2859", "text": "نواس بن سمعان کلابی رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اللہ تعالیٰ ن"}
{"hadithnumber": "2860", "text": "جابر بن عبداللہ انصاری رضی الله عنہما کہتے ہیں کہ  ایک دن رسول اللہ صلی اللہ علیہ وسلم ہم لوگوں کے پ"}
{"hadithnumber": "2861", "text": "عبداللہ بن مسعود رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے عشاء پڑھی۔ پھر پلٹے تو عب"}
{"hadithnumber": "2862", "text": "جابر بن عبداللہ رضی الله عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”میری مثال اور مج"}
{"hadithnumber": "2863", "text": "حارث اشعری رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”اللہ تعالیٰ نے یحییٰ"}
{"hadithnumber": "2864", "text": "اس سند سے بھی  حارث اشعری رضی الله عنہ نبی اکرم صلی اللہ علیہ وسلم سے اسی طرح اسی کی ہم معنی حدیث رو"}
{"hadithnumber": "2865", "text": "ابوموسیٰ اشعری رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اس مومن کی مثال جو"}
{"hadithnumber": "2866", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”مومن کی مثال اس کھیتی کی"}
{"hadithnumber": "2867", "text": "عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”درختوں میں ایک د"}
{"hadithnumber": "2868", "text": "ابوہریرہ رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”بھلا بتاؤ تو صحیح، ا"}
{"hadithnumber": "2868", "text": "ابوہریرہ رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”بھلا بتاؤ تو صحیح، ا"}
{"hadithnumber": "2869", "text": "انس رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”میری امت کی مثال بارش کی ہے،"}
{"hadithnumber": "2870", "text": "بریدہ رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے دو کنکریاں پھینکتے ہوئے فرمایا: ”کیا"}
{"hadithnumber": "2871", "text": "عبداللہ بن عمر رضی الله عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”تمہاری مدت گز"}
{"hadithnumber": "2872", "text": "عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”لوگ سو اونٹ کی ط"}
{"hadithnumber": "2873", "text": "سفیان بن عیینہ زہری سے اسی سند سے اسی طرح روایت کرتے ہیں  اور انہوں نے کہا: تم ان میں ایک بھی سواری"}
{"hadithnumber": "2874", "text": "ابوہریرہ رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”میری اور میری امت کی"}
