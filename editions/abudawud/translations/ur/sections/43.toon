{"hadithnumber": "5057", "text": "عرباض بن ساریہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم سونے سے پہلے «المسبحات» ۱؎ پڑھ"}
{"hadithnumber": "5058", "text": "عبداللہ بن عمر رضی اللہ عنہما ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم جب اپنی خواب گاہ میں آتے تو کہتے:"}
{"hadithnumber": "5059", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص کسی جگہ لیٹے اور"}
{"hadithnumber": "5060", "text": "عبادہ بن صامت رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: جو شخص نیند سے بیدار"}
{"hadithnumber": "5061", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم رات کی نیند سے جب بیدار ہو"}
{"hadithnumber": "5062", "text": "علی رضی اللہ عنہ کہتے ہیں کہ  فاطمہ رضی اللہ عنہا نبی اکرم صلی اللہ علیہ وسلم کے پاس چکی پیسنے سے اپ"}
{"hadithnumber": "5063", "text": "ابوسلورد بن ثمامہ کہتے ہیں کہ  علی رضی اللہ عنہ نے ابن اعبد سے کہا: کیا میں تم سے اپنے اور رسول اللہ"}
{"hadithnumber": "5064", "text": "اس سند سے بھی علی رضی اللہ عنہ کے واسطہ سے نبی اکرم صلی اللہ علیہ وسلم سے یہی حدیث مروی ہے اس میں ہے"}
{"hadithnumber": "5065", "text": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  دو خصلتیں یا دو"}
{"hadithnumber": "5066", "text": "زبیر کی بیٹیوں ام الحکم یا ضباعہ میں سے کسی ایک سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم کے پاس"}
{"hadithnumber": "5067", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  ابوبکر صدیق رضی اللہ عنہ نے عرض کیا: اللہ کے رسول! مجھے کچھ ای"}
{"hadithnumber": "5068", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم جب صبح کرتے تو فرماتے: «اللهم بك أصبح"}
{"hadithnumber": "5069", "text": "انس بن مالک رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: جو شخص صبح کے وقت ا"}
{"hadithnumber": "5070", "text": "بریدہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: جو شخص صبح کے وقت یا شام کے و"}
{"hadithnumber": "5071", "text": "عبداللہ بن مسعود رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم جب شام کرتے تو یہ دعا پڑھت"}
{"hadithnumber": "5072", "text": "ابو سلام کہتے ہیں کہ  وہ حمص کی مسجد میں تھے کہ ایک شخص کا وہاں سے گزر ہوا، لوگوں نے کہا، یہ نبی اکر"}
