{"metadata":{"name":"Sunan Ibn Majah","section":{"0":"The Book of the Sunnah"},"section_detail":{"0":{"hadithnumber_first":1,"hadithnumber_last":266,"arabicnumber_first":1,"arabicnumber_last":266}}},"hadiths":[{"hadithnumber":156,"arabicnumber":156,"text":"Rapporté par ‘Abdullah bin ‘Amr : J’ai entendu le Messager d’Allah ﷺ dire : « Il n’y a personne sur terre, ni sous le ciel, qui soit plus véridique dans ses paroles qu’Abu Dharr. »","grades":[{"name":"Al-Albani","grade":"Sahih"},{"name":"Muhammad Fouad Abd al-Baqi","grade":"Sahih"},{"name":"Shuaib Al Arnaut","grade":"Hasan Lighairihi"},{"name":"Zubair Ali Zai","grade":"Hasan"}],"reference":{"book":0,"hadith":156}}]}