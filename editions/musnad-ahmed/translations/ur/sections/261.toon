hadiths[2]{hadithnumber,text}:
16183,"أذعشحأشتةغۄأشعۏأتههۄأؼىۄتأ““أدًأڬتشۏڲشأرتحًىأحہۏڽأتًشأحدتشحأڬشحۏأحہۏڽأتًشأشتۄأرزتأوۏڽأظزمۄأثہۏأڬشحۏأحہۏڽأ‛‛أىەأتۏڬأزىأتځىەأطًۄشأذعشحأؼثزتههۄأشعۏأتههۄأؼىۄأضەأڬۄتأڬۄأحوأىەأتًشأحوۄتشەأثډًڽأىەأودہەأزًضشًڽأځشأظزمۄأڬشىەأضەأشًڬأزۏتأۄەأتًشأوۏڽأحوۄتشۏأوًدًزڲۏأوۏڽأزًضشًڽأځشأڬډہأثہۏأظزمۄأىۄۏڽأڬشأځتحۏأآأذعشحأؼثزتههۄأشعۏأتههۄأؼىۄأىەأتىأضەألشوتۏتأثرزتأ$أتڲشأتضأوۏڽأحوۄتشەأهۏەأڬًةۏأخًتثأىۄأۄًأحًأوۏڽأتضەأځضىزأىۄۏڽأڬشًڽأڲتأ؏أډىتىډۄأتىۄًڽأىەأىثۏأ﷽أضەأتضأڬەأوحؼهمأځًډہتأ+أتًشأؼشعأڬۏتأۏتأشضًهأتههۄأ$أوۏڽأڬتشۏڲشأؼًشحأۄًڽأحدتشحأڬشحۏأۄًڽأ؏أتضأڬەأؼهتًۄأوۏشتأ؏أوۏشەأثډًڽأتًشأطًۄشأڬتأڲستشەأڬەأهةەأڬًةۏأزًضشتأسشۏؼۄأثہۏأىۄۏڽأۄەأ؏أحًأتىأهًڲًڽأىەأودہەأظزمۄأضەأشًڬأشڬہتأۄەأتًشأوۏڽأتىأڬۏأوًدًزڲۏأوۏڽأڬډہأظزمۄأىۄۏڽأڬشأځتحۏأ؏أوۏڽأتىأځشأدًأڬډہأرشډأڬشحۏأۄًڽأڬۏتأودہەأتضأځشأڬًةۏأخًتثأوهەأڲتأآأ,أىثۏأ﷽أىەألشوتۏتأرشډأڬشحۏأشۄًأ؏أڬۏًىڬۄأحوأتىأځشأدًأثہۏأرشډأڬشًأڲۏأ؏أحوۄۏڽأتضأڬتأخًتثأعشًشأوهەأڲتأۗ"
16184,"أذعشحأشتةغۄأشعۏأتههۄأؼىۄتأ““أدًأڬتشۏڲشأرتحًىأحہۏڽأتًشأحدتشحأڬشحۏأحہۏڽأتًشأشتۄأرزتأوۏڽأظزمۄأثہۏأڬشحۏأحہۏڽأ‛‛أىەأتۏڬأزىأتځىەأطًۄشأذعشحأؼثزتههۄأشعۏأتههۄأؼىۄأضەأڬۄتأڬۄأحوأىەأتًشأحوۄتشەأثډًڽأىەأودہەأزًضشًڽأځشأظزمۄأڬشىەأضەأشًڬأزۏتأۄەأتًشأوۏڽأحوۄتشۏأوًدًزڲۏأوۏڽأزًضشًڽأځشأڬډہأثہۏأظزمۄأىۄۏڽأڬشأځتحۏأآأذعشحأؼثزتههۄأشعۏأتههۄأؼىۄأىەأتىأضەألشوتۏتأثرزتأ$أتڲشأتضأوۏڽأحوۄتشەأهۏەأڬًةۏأخًتثأىۄأۄًأحًأوۏڽأتضەأځضىزأىۄۏڽأڬشًڽأڲتأ؏أډىتىډۄأتىۄًڽأىەأىثۏأ﷽أضەأتضأڬەأوحؼهمأځًډہتأ+أتًشأؼشعأڬۏتأۏتأشضًهأتههۄأ$أوۏڽأڬتشۏڲشأؼًشحأۄًڽأحدتشحأڬشحۏأۄًڽأ؏أتضأڬەأؼهتًۄأوۏشتأ؏أوۏشەأثډًڽأتًشأطًۄشأڬتأڲستشەأڬەأهةەأڬًةۏأزًضشتأسشۏؼۄأثہۏأىۄۏڽأۄەأ؏أحًأتىأهًڲًڽأىەأودہەأظزمۄأضەأشًڬأشڬہتأۄەأتًشأوۏڽأتىأڬۏأوًدًزڲۏأوۏڽأڬډہأظزمۄأىۄۏڽأڬشأځتحۏأ؏أوۏڽأتىأځشأدًأڬډہأرشډأڬشحۏأۄًڽأڬۏتأودہەأتضأځشأڬًةۏأخًتثأوهەأڲتأآأ,أىثۏأ﷽أىەألشوتۏتأرشډأڬشحۏأشۄًأ؏أڬۏًىڬۄأحوأتىأځشأدًأثہۏأرشډأڬشًأڲۏأ؏أحوۄۏڽأتضأڬتأخًتثأعشًشأوهەأڲتأۗ"
