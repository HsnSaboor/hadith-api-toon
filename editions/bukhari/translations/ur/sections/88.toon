{"hadithnumber": "6918", "text": "ہم سے قتیبہ بن سعید نے بیان کیا، انہوں نے کہا ہم کو جریر بن عبدالحمید نے بیان کیا، انہوں نے اعمش سے،"}
{"hadithnumber": "6919", "text": "ہم سے مسدد بن مسرہد نے بیان کیا، کہا ہم سے بشر بن مفضل نے، کہا ہم سے سعید بن ایاس جریری نے، (دوسری س"}
{"hadithnumber": "6920", "text": "ہم سے محمد بن حسین بن ابراہیم نے بیان کیا، انہوں نے کہا ہم سے عبیداللہ بن موسیٰ کوفی نے بیان کیا، ان"}
{"hadithnumber": "6921", "text": "ہم سے خلاد بن یحییٰ نے بیان کیا، کہا ہم سے سفیان ثوری نے، انہوں نے منصور اور اعمش سے، انہوں نے ابووا"}
{"hadithnumber": "6922", "text": "ہم سے ابوالنعمان محمد بن فضل سدوسی نے بیان کیا، کہا ہم سے حماد بن زید نے، انہوں نے ایوب سختیانی سے،"}
{"hadithnumber": "6923", "text": "ہم سے مسدد بن مسرہد نے بیان کیا، کہا ہم سے یحییٰ بن سعید قطان نے، انہوں نے قرۃ بن خالد سے، کہا مجھ س"}
{"hadithnumber": "6925", "text": "ابوبکر صدیق رضی اللہ عنہ نے کہا  میں تو اللہ کی قسم اس شخص سے لڑوں گا جو نماز اور زکوٰۃ میں فرق کرے،"}
{"hadithnumber": "6926", "text": "ہم سے محمد بن مقاتل ابوالحسن مروزی نے بیان کیا، کہا ہم کو عبداللہ بن مبارک نے خبر دی، کہا ہم کو شعبہ"}
{"hadithnumber": "6927", "text": "ہم سے ابونعیم نے بیان کیا، انہوں نے سفیان بن عیینہ سے، انہوں نے زہری سے، انہوں نے عروہ سے، انہوں نے"}
{"hadithnumber": "6928", "text": "ہم سے مسدد نے بیان کیا، انہوں نے کہا ہم سے یحییٰ بن سعید قطان نے، انہوں نے سفیان بن عیینہ، اور امام"}
{"hadithnumber": "6929", "text": "ہم سے عمر بن حفص بن غیاث نے بیان کیا، کہا ہم سے ہمارے والد نے، کہا ہم سے اعمش نے، کہا مجھ سے شقیق اب"}
{"hadithnumber": "6930", "text": "ہم سے عمر بن حفص بن غیاث نے بیان کیا، کہا ہم ہمارے سے والد نے، کہا ہم سے اعمش نے، کہا ہم سے خیثمہ بن"}
{"hadithnumber": "6931", "text": "ہم سے محمد بن مثنیٰ نے بیان کیا، انہوں نے کہا ہم سے عبدالوہاب نے بیان کیا، کہا میں نے یحییٰ بن سعید"}
{"hadithnumber": "6932", "text": "ہم سے یحییٰ بن سلیمان نے بیان کیا، کہا مجھ سے ابن وہب نے، کہا کہ مجھ سے عمر بن محمد بن زید بن عبدالل"}
{"hadithnumber": "6933", "text": "ہم سے عبداللہ بن محمد مسندی نے بیان کیا، کہا ہم سے ہشام بن یوسف نے بیان کیا، کہا ہم کو معمر نے خبر د"}
{"hadithnumber": "6934", "text": "ہم سے موسیٰ بن اسماعیل نے بیان کیا، کہا ہم سے عبدالواحد بن زیادہ نے، کہا ہم سے سلمان شیبانی نے، کہا"}
{"hadithnumber": "6935", "text": "ہم سے علی بن عبداللہ مدینی نے بیان کیا، کہا ہم سے سفیان نے بیان کیا، کہا ہم سے ابوالزناد نے بیان کیا"}
{"hadithnumber": "6936", "text": "اور ابوعبداللہ امام بخاری رحمہ اللہ نے بیان کیا، ان سے لیث بن سعد نے بیان کیا انہوں نے کہا کہ مجھ سے"}
{"hadithnumber": "6937", "text": "ہم سے اسحاق بن ابراہیم نے بیان کیا، کہا ہم کو وکیع نے خبر دی (دوسری سند) امام بخاری رحمہ اللہ نے کہا"}
{"hadithnumber": "6938", "text": "ہم سے عبدان نے بیان کیا، کہا ہم کو عبداللہ بن مبارک نے خبر دی، کہا ہم کو معمر نے خبر دی، انہیں زہری"}
{"hadithnumber": "6939", "text": "ہم سے موسیٰ بن اسماعیل نے بیان کیا، کہا ہم سے ابوعوانہ وضاح شکری نے بیان کیا، ان سے حصین بن عبدالرحم"}
