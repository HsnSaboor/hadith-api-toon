metadata:
  section_id: 27
  section_name: Chapters on Slaughtering
  hadith_first: 3162
  hadith_last: 3199
  arabic_first: 3162
  arabic_last: 3199

hadiths[38]{hadithnumber,text,reference_book,reference_hadith}:
3162,"حدثنا ابو بكر بن ابي شيبة، وهشام بن عمار، قالا حدثنا سفيان بن عيينة، عن عبيد الله بن ابي يزيد، عن ابيه، عن سباع بن ثابت، عن ام كرز، قالت سمعت النبي صلى الله عليه وسلم يقول "" عن الغلام، شاتان مكافيتان وعن الجارية، شاة",27,1
3163,حدثنا ابو بكر بن ابي شيبة، حدثنا عفان، حدثنا حماد بن سلمة، انبانا عبد الله بن عثمان بن خثيم، عن يوسف بن ماهك، عن حفصة بنت عبد الرحمن، عن عايشة، قالت امرنا رسول الله صلى الله عليه وسلم ان نعق عن الغلام شاتين وعن الجارية شاة,27,2
3164,"حدثنا ابو بكر بن ابي شيبة، حدثنا عبد الله بن نمير، حدثنا هشام بن حسان، عن حفصة بنت سيرين، عن سلمان بن عامر، انه سمع النبي صلى الله عليه وسلم يقول "" ان مع الغلام عقيقة فاهريقوا عنه دما واميطوا عنه الاذى",27,3
3165,"حدثنا هشام بن عمار، حدثنا شعيب بن اسحاق، حدثنا سعيد بن ابي عروبة، عن قتادة، عن الحسن، عن سمرة، عن النبي صلى الله عليه وسلم قال "" كل غلام مرتهن بعقيقته تذبح عنه يوم السابع ويحلق راسه ويسمى",27,4
3166,"حدثنا يعقوب بن حميد بن كاسب، حدثنا عبد الله بن وهب، حدثني عمرو بن الحارث، عن ايوب بن موسى، انه حدثه ان يزيد بن عبد المزني حدثه ان النبي صلى الله عليه وسلم قال "" يعق عن الغلام ولا يمس راسه بدم",27,5
3167,"حدثنا ابو بشر، بكر بن خلف حدثنا يزيد بن زريع، عن خالد الحذاء، عن ابي المليح، عن نبيشة، قال نادى رجل رسول الله صلى الله عليه وسلم فقال يا رسول الله انا كنا نعتر عتيرة في الجاهلية في رجب فما تامرنا قال "" اذبحوا لله عز وجل في اى شهر ما كان وبروا الله واطعموا "" . قالوا يا رسول الله انا كنا نفرع فرعا في الجاهلية فما تامرنا قال "" في كل سايمة فرع تغذوه ماشيتك حتى اذا استحمل ذبحته فتصدقت بلحمه - اراه قال - على ابن السبيل فان ذلك هو خير",27,6
3168,"حدثنا ابو بكر بن ابي شيبة، وهشام بن عمار، قالا حدثنا سفيان بن عيينة، عن الزهري، عن سعيد بن المسيب، عن ابي هريرة، عن النبي صلى الله عليه وسلم قال "" لا فرعة ولا عتيرة "" . قال هشام في حديثه والفرعة اول النتاج . والعتيرة الشاة يذبحها اهل البيت في رجب",27,7
3169,"حدثنا محمد بن ابي عمر العدني، حدثنا سفيان بن عيينة، عن زيد بن اسلم، عن ابيه، عن ابن عمر، ان النبي صلى الله عليه وسلم قال "" لا فرعة ولا عتيرة "" . قال ابن ماجه هذا من فرايد العدني",27,8
3170,"حدثنا محمد بن المثنى، حدثنا عبد الوهاب، حدثنا خالد الحذاء، عن ابي قلابة، عن ابي الاشعث، عن شداد بن اوس، ان رسول الله صلى الله عليه وسلم قال "" ان الله عز وجل كتب الاحسان على كل شىء فاذا قتلتم فاحسنوا القتلة واذا ذبحتم فاحسنوا الذبح وليحد احدكم شفرته وليرح ذبيحته",27,9
3171,"حدثنا ابو بكر بن ابي شيبة، حدثنا عقبة بن خالد، عن موسى بن محمد بن ابراهيم التيمي، اخبرني ابي، عن ابي سعيد الخدري، قال مر النبي صلى الله عليه وسلم برجل وهو يجر شاة باذنها فقال "" دع اذنها وخذ بسالفتها",27,10
3172,"حدثنا محمد بن عبد الرحمن ابن اخي، حسين الجعفي حدثنا مروان بن محمد، حدثنا ابن لهيعة، حدثني قرة بن حيوييل، عن الزهري، عن سالم بن عبد الله بن عمر، عن ابيه عبد الله بن عمر، قال امر رسول الله صلى الله عليه وسلم بحد الشفار وان توارى عن البهايم وقال "" اذا ذبح احدكم فليجهز "" . حدثنا جعفر بن مسافر، حدثنا ابو الاسود، حدثنا ابن لهيعة، عن يزيد بن ابي حبيب، عن سالم، عن ابيه، عن النبي صلى الله عليه وسلم مثله",27,11
3173,حدثنا عمرو بن عبد الله، حدثنا وكيع، عن اسراييل، عن سماك، عن عكرمة، عن ابن عباس، {ان الشياطين ليوحون الى اوليايهم} قال كانوا يقولون ما ذكر عليه اسم الله فلا تاكلوا وما لم يذكر اسم الله عليه فكلوه . فقال الله عز وجل {ولا تاكلوا مما لم يذكر اسم الله عليه},27,12
3174,"حدثنا ابو بكر بن ابي شيبة، حدثنا عبد الرحيم بن سليمان، عن هشام بن عروة، عن ابيه، عن عايشة ام المومنين، ان قوما، قالوا يا رسول الله ان قوما ياتونا بلحم لا ندري ذكر اسم الله عليه ام لا قال "" سموا انتم وكلوا "" . وكانوا حديث عهد بالكفر",27,13
3175,حدثنا ابو بكر بن ابي شيبة، حدثنا ابو الاحوص، عن عاصم، عن الشعبي، عن محمد بن صيفي، قال ذبحت ارنبين بمروة فاتيت بهما النبي صلى الله عليه وسلم فامرني باكلهما,27,14
3176,حدثنا ابو بشر، بكر بن خلف حدثنا غندر، حدثنا شعبة، سمعت حاضر بن مهاجر، يحدث عن سليمان بن يسار، عن زيد بن ثابت، ان ذيبا، نيب في شاة فذبحوها بمروة فرخص لهم رسول الله صلى الله عليه وسلم في اكلها,27,15
3177,"حدثنا محمد بن بشار، حدثنا عبد الرحمن بن مهدي، حدثنا سفيان، عن سماك بن حرب، عن مري بن قطري، عن عدي بن حاتم، قال قلت يا رسول الله انا نصيد الصيد فلا نجد سكينا الا الظرار وشقة العصا . قال "" امرر الدم بما شيت واذكر اسم الله عليه",27,16
3178,"حدثنا محمد بن عبد الله بن نمير، حدثنا عمر بن عبيد الطنافسي، عن سعيد بن مسروق، عن عباية بن رفاعة، عن جده، رافع بن خديج قال كنا مع رسول الله صلى الله عليه وسلم في سفر فقلت يا رسول الله انا نكون في المغازي فلا يكون معنا مدى فقال "" ما انهر الدم وذكر اسم الله عليه فكل غير السن والظفر فان السن عظم والظفر مدى الحبشة",27,17
3179,"حدثنا ابو كريب، حدثنا مروان بن معاوية، حدثنا هلال بن ميمون الجهني، عن عطاء بن يزيد الليثي، - قال عطاء لا اعلمه الا عن ابي سعيد الخدري - ان رسول الله صلى الله عليه وسلم مر بغلام يسلخ شاة فقال له رسول الله صلى الله عليه وسلم "" تنح حتى اريك "" . فادخل رسول الله صلى الله عليه وسلم يده بين الجلد واللحم فدحس بها حتى توارت الى الابط وقال "" يا غلام هكذا فاسلخ "" . ثم مضى وصلى للناس ولم يتوضا",27,18
3180,"حدثنا ابو بكر بن ابي شيبة، حدثنا خلف بن خليفة، ح وحدثنا عبد الرحمن بن ابراهيم، انبانا مروان بن معاوية، جميعا عن يزيد بن كيسان، عن ابي حازم، عن ابي هريرة، ان رسول الله صلى الله عليه وسلم اتى رجلا من الانصار فاخذ الشفرة ليذبح لرسول الله صلى الله عليه وسلم فقال له رسول الله صلى الله عليه وسلم "" اياك والحلوب",27,19
3181,"حدثنا علي بن محمد، حدثنا عبد الرحمن المحاربي، عن يحيى بن عبيد الله، عن ابيه، عن ابي هريرة، قال حدثني ابو بكر بن ابي قحافة، ان رسول الله صلى الله عليه وسلم قال له ولعمر "" انطلقوا بنا الى الواقفي "" . قال فانطلقنا في القمر حتى اتينا الحايط فقال مرحبا واهلا . ثم اخذ الشفرة ثم جال في الغنم فقال رسول الله صلى الله عليه وسلم "" اياك والحلوب "" . او قال "" ذات الدر",27,20
3182,حدثنا هناد بن السري، حدثنا عبدة بن سليمان، عن عبيد الله، عن نافع، عن ابن لكعب بن مالك، عن ابيه، ان امراة، ذبحت شاة بحجر فذكر ذلك لرسول الله صلى الله عليه وسلم فلم ير به باسا,27,21
3183,"حدثنا محمد بن عبد الله بن نمير، حدثنا عمر بن عبيد، عن سعيد بن مسروق، عن عباية بن رفاعة، عن جده، رافع بن خديج قال كنا مع النبي صلى الله عليه وسلم في سفر فند بعير فرماه رجل بسهم فقال النبي صلى الله عليه وسلم "" ان لها اوابد - احسبه قال - كاوابد الوحش فما غلبكم منها فاصنعوا به هكذا",27,22
3184,"حدثنا ابو بكر بن ابي شيبة، حدثنا وكيع، عن حماد بن سلمة، عن ابي العشراء، عن ابيه، قال قلت يا رسول الله ما تكون الذكاة الا في الحلق واللبة قال "" لو طعنت في فخذها لاجزاك",27,23
3185,حدثنا ابو بكر بن ابي شيبة، وعبد الله بن سعيد، قالا حدثنا عقبة بن خالد، عن موسى بن محمد بن ابراهيم التيمي، عن ابيه، عن ابي سعيد الخدري، قال نهى رسول الله صلى الله عليه وسلم ان يمثل بالبهايم,27,24
3186,حدثنا علي بن محمد، حدثنا وكيع، عن شعبة، عن هشام بن زيد بن انس بن مالك، عن انس بن مالك، قال نهى رسول الله صلى الله عليه وسلم عن صبر البهايم,27,25
3187,"حدثنا علي بن محمد، حدثنا وكيع، ح وحدثنا ابو بكر بن خلاد الباهلي، حدثنا عبد الرحمن بن مهدي، قالا حدثنا سفيان، عن سماك، عن عكرمة، عن ابن عباس، قال قال رسول الله صلى الله عليه وسلم "" لا تتخذوا شييا فيه الروح غرضا",27,26
3188,حدثنا هشام بن عمار، حدثنا سفيان بن عيينة، انبانا ابن جريج، حدثنا ابو الزبير، انه سمع جابر بن عبد الله، يقول نهى رسول الله صلى الله عليه وسلم ان يقتل شىء من الدواب صبرا,27,27
3189,حدثنا سويد بن سعيد، حدثنا ابن ابي زايدة، عن محمد بن اسحاق، عن ابن ابي نجيح، عن مجاهد، عن ابن عمر، قال نهى رسول الله صلى الله عليه وسلم عن لحوم الجلالة والبانها,27,28
3190,حدثنا ابو بكر بن ابي شيبة، حدثنا وكيع، عن هشام بن عروة، عن فاطمة بنت المنذر، عن اسماء بنت ابي بكر، قالت نحرنا فرسا فاكلنا من لحمه على عهد رسول الله صلى الله عليه وسلم,27,29
3191,حدثنا بكر بن خلف ابو بشر، حدثنا ابو عاصم، حدثنا ابن جريج، اخبرني ابو الزبير، انه سمع جابر بن عبد الله، يقول اكلنا زمن خيبر الخيل وحمر الوحش,27,30
3192,حدثنا سويد بن سعيد، حدثنا علي بن مسهر، عن ابي اسحاق الشيباني، قال سالت عبد الله بن ابي اوفى عن لحوم الحمر الاهلية، فقال اصابتنا مجاعة يوم خيبر ونحن مع النبي صلى الله عليه وسلم وقد اصاب القوم حمرا خارجا من المدينة فنحرناها وان قدورنا لتغلي اذ نادى منادي النبي صلى الله عليه وسلم ان اكفيوا القدور ولا تطعموا من لحوم الحمر شييا . فاكفاناها . فقلت لعبد الله بن ابي اوفى حرمها تحريما قال تحدثنا انما حرمها رسول الله صلى الله عليه وسلم البتة من اجل انها تاكل العذرة,27,31
3193,حدثنا ابو بكر بن ابي شيبة، حدثنا زيد بن الحباب، عن معاوية بن صالح، حدثني الحسن بن جابر، عن المقدام بن معديكرب الكندي، ان رسول الله صلى الله عليه وسلم حرم اشياء حتى ذكر الحمر الانسية,27,32
3194,حدثنا سويد بن سعيد، حدثنا علي بن مسهر، عن عاصم، عن الشعبي، عن البراء بن عازب، قال امرنا رسول الله صلى الله عليه وسلم ان نلقي لحوم الحمر الاهلية نيية ونضيجة ثم لم يامرنا به بعد,27,33
3195,"حدثنا يعقوب بن حميد بن كاسب، حدثنا المغيرة بن عبد الرحمن، عن يزيد بن ابي عبيد، عن سلمة بن الاكوع، قال غزونا مع رسول الله صلى الله عليه وسلم غزوة خيبر فامسى الناس قد اوقدوا النيران فقال النبي صلى الله عليه وسلم "" علام توقدون "" . قالوا على لحوم الحمر الانسية فقال "" اهريقوا ما فيها واكسروها "" . فقال رجل من القوم او نهريق ما فيها ونغسلها فقال النبي صلى الله عليه وسلم "" او ذاك",27,34
3196,حدثنا محمد بن يحيى، حدثنا عبد الرزاق، انبانا معمر، عن ايوب، عن ابن سيرين، عن انس بن مالك، ان منادي النبي، صلى الله عليه وسلم نادى ان الله ورسوله ينهيانكم عن لحوم الحمر الاهلية فانها رجس,27,35
3197,حدثنا عمرو بن عبد الله، حدثنا وكيع، عن سفيان، ح وحدثنا محمد بن يحيى، حدثنا عبد الرزاق، حدثنا الثوري، ومعمر، جميعا عن عبد الكريم الجزري، عن عطاء، عن جابر بن عبد الله، قال كنا ناكل لحوم الخيل . قلت فالبغال قال لا,27,36
3198,حدثنا محمد بن المصفى، حدثنا بقية، حدثني ثور بن يزيد، عن صالح بن يحيى بن المقدام بن معديكرب، عن ابيه، عن جده، عن خالد بن الوليد، قال نهى رسول الله صلى الله عليه وسلم عن لحوم الخيل والبغال والحمير,27,37
3199,"حدثنا ابو كريب، حدثنا عبد الله بن المبارك، وابو خالد الاحمر وعبدة بن سليمان عن مجالد، عن ابي الوداك، عن ابي سعيد، قال سالنا رسول الله صلى الله عليه وسلم عن الجنين فقال "" كلوه ان شيتم فان ذكاة الجنين ذكاة امه "" . قال ابو عبد الله سمعت الكوسج اسحق بن منصور يقول في قولهم في الذكاة لا يقضى بها مذمة قال مذمة بكسر الذال من الذمام وبفتح الذال من الذم",27,38
