{"hadithnumber": "4140", "text": "حضرت اسامہ بن زید رضی اللہ عنہ سے روایت ہے کہ نبی صلی اللہ علیہ وسلم نے فرمایا :   \" مسلمان کافر کا"}
{"hadithnumber": "4141", "text": ")  وہیب نے ہمیں ابن طاوس سے حدیث بیان کی ،  انہوں نے اپنے والد سے اور انہوں نے حضرت ابن عباس رضی الل"}
{"hadithnumber": "4142", "text": "روح بن قاسم نے باقی ماندہ سابقہ سند کے ساتھ حضرت ابن عباس رضی اللہ عنہ سے اور انہوں نے رسول اللہ صلی"}
{"hadithnumber": "4143", "text": "معمر نے ہمیں ابن طاوس سے باقی ماندہ سابقہ سند سے روایت کی :  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا"}
{"hadithnumber": "4144", "text": "یحییٰ بن ایوب نے ابن طاوس سے اسی سند کے ساتھ وہیب اور روح بن قاسم کی حدیث کے ہم معنی روایت بیان کی"}
{"hadithnumber": "4145", "text": "سفیان بن عیینہ نے ہمیں محمد بن منکدر سے حدیث بیان کی :  انہوں نے حضرت جابر بن عبداللہ رضی اللہ عنہ س"}
{"hadithnumber": "4146", "text": "ابن جریج نے ہمیں حدیث بیان کی ،  انہوں نے کہا :  مجھے ابن منکدر نے حضرت جابر بن عبداللہ رضی اللہ عنہ"}
{"hadithnumber": "4147", "text": "سفیان  ( ثوری )  نے ہمیں حدیث بیان کی ،  انہوں نے کہا :  میں نے محمد بن منکدر سے سنا ،  انہوں نے کہا"}
{"hadithnumber": "4148", "text": "بہز نے ہمیں حدیث بیان کی :  شعبہ نے ہمیں حدیث بیان کی :  مجھے محمد بن منکدر نے خبر دی ،  انہوں نے کہ"}
{"hadithnumber": "4149", "text": "نضر بن شمیل ،  ابو عامر عقدی اور وہب بن جریر سب نے شعبہ سے اسی سند کے ساتھ حدیث بیان کی ،  وہب بن جر"}
{"hadithnumber": "4150", "text": "ہشام نے ہمیں حدیث بیان کی :  ہمیں قتادہ نے سالم بن ابی جعد سے حدیث بیان کی ،  انہوں نے معدان بن ابی"}
{"hadithnumber": "4151", "text": "سعید بن ابی عروبہ اور شعبہ دونوں نے قتادہ سے اسی سند کے ساتھ اسی کے ہم معنی حدیث بیان کی"}
{"hadithnumber": "4152", "text": "ابن ابی خالد نے ابواسحاق سے اور انہوں نے حضرت براء  ( بن عازب )  رضی اللہ عنہ سے روایت کی ،  انہوں ن"}
{"hadithnumber": "4153", "text": "شعبہ نے ہمیں ابواسحاق سے حدیث بیان کی ،  انہوں نے کہا :  میں نے حضرت براء بن عازب رضی اللہ عنہ سے سن"}
{"hadithnumber": "4154", "text": "زکریا نے ہمیں ابواسحاق کے واسطے سے حضرت براء رضی اللہ عنہ سے حدیث بیان کی کہ آخری سورت جو پوری نازل"}
{"hadithnumber": "4155", "text": "عمار بن رزیق نے ہمیں ابواسحاق کے حوالے سے حضرت براء رضی اللہ عنہ سے اسی کے مانند حدیث بیان کی مگر ان"}
{"hadithnumber": "4156", "text": "ابوسفر نے حضرت براء رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  آخری آیت جو اتاری گئی ،   ( يَسْتَفْ"}
{"hadithnumber": "4157", "text": "یونس نے مجھے ابن شہاب سے خبر دی ،  انہوں نے ابوسلمہ بن عبدالرحمان سے اور انہوں نے حضرت ابوہریرہ رضی"}
{"hadithnumber": "4158", "text": "عقیل ،  ابن شہاب  ( زہری )  کے بھتیجے اور ابن ابی ذئب سب نے زہری سے اسی سند کے ساتھ یہ حدیث بیان کی"}
{"hadithnumber": "4159", "text": "اعرج نے حضرت ابوہریرہ رضی اللہ عنہ سے اور انہوں نے نبی صلی اللہ علیہ وسلم سے روایت کی ،  آپ نے فرمای"}
{"hadithnumber": "4160", "text": "ہمام بن منبہ سے روایت ہے ،  انہوں نے کہا :  یہ وہ احادیث ہیں جو ہمیں حضرت ابوہریرہ رضی اللہ عنہ نے ر"}
{"hadithnumber": "4161", "text": "معاذ عنبری نے ہمیں حدیث بیان کی :  ہمیں شعبہ نے عدی سے حدیث بیان کی کہ انہوں نے ابوحازم سے سنا ،  ان"}
{"hadithnumber": "4162", "text": "محمد بن جعفر )  غندر اور عبدالرحمان بن مہدی نے کہا :  ہمیں شعبہ نے اسی سند کے ساتھ حدیث بیان کی ،  م"}
