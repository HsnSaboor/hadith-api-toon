{"hadithnumber": "6385", "text": "ہم سے اسماعیل بن ابی اویس نے بیان کیا، انہوں نے کہا کہ مجھ سے امام مالک نے بیان کیا، انہوں نے کہا ہم"}
{"hadithnumber": "6386", "text": "ہم سے مسدد نے بیان کیا، انہوں نے کہا ہم سے حماد بن زید رضی اللہ عنہ نے بیان کیا کہ  نبی کریم صلی الل"}
{"hadithnumber": "6387", "text": "ہم سے ابوالنعمان نے بیان کیا، کہا ہم سے حماد بن زید نے بیان کیا، ان سے عمرو نے اور ان سے جابر رضی ال"}
{"hadithnumber": "6388", "text": "ہم سے عثمان بن ابی شیبہ نے بیان کیا، کہا ہم سے جریر نے بیان کیا، ان سے منصور نے، ان سے سالم نے، ان س"}
{"hadithnumber": "6389", "text": "ہم سے مسدد نے بیان کیا، انہوں نے کہا ہم سے عبدالوارث نے بیان کیا، ان سے عبدالعزیز نے بیان کیا اور ان"}
{"hadithnumber": "6390", "text": "ہم سے فروہ بن ابی المغراء نے بیان کیا، انہوں نے کہا ہم سے عبیدہ بن حمید نے بیان کیا، ان سے عبدالملک"}
{"hadithnumber": "6391", "text": "ہم سے ابراہیم بن المنذر نے بیان کیا، کہا ہم سے انس بن عیاض نے بیان کیا، ان سے ہشام نے، ان سے ان کے و"}
{"hadithnumber": "6392", "text": "ہم سے ابن سلام نے بیان کیا، کہا ہم کو وکیع نے خبر دی، انہیں ابن ابی خالد نے، کہا میں نے ابن ابی اوفی"}
{"hadithnumber": "6393", "text": "ہم سے معاذ بن فضالہ نے بیان کیا، ان سے ہشام نے بیان کیا، ان سے یحییٰ نے، ان سے ابوسلمہ نے بیان کیا،"}
{"hadithnumber": "6394", "text": "ہم سے حسن بن ربیع نے بیان کیا، کہا ہم سے ابوالاحوص نے بیان کیا، ان سے عاصم نے اور ان سے انس رضی اللہ"}
{"hadithnumber": "6395", "text": "ہم سے عبداللہ بن محمد نے بیان کیا، انہوں نے کہا ہم سے ہشام نے بیان کیا، انہیں معمر نے خبر دی، انہیں"}
{"hadithnumber": "6396", "text": "ہم سے محمد بن مثنی ٰ نے بیان کیا، انہوں نے کہا ہم سے انصاری نے بیان کیا، ان سے ہشام بن حسان نے بیان"}
{"hadithnumber": "6397", "text": "ہم سے علی نے بیان کیا، ان سے سفیان نے کہا، ان سے ابوالزناد نے، ان سے اعرج نے اور ان سے ابوہریرہ رضی"}
{"hadithnumber": "6398", "text": "کیا، ان سے شعبہ نے، ان سے ابواسحاق نے، ان سے ابن ابی موسیٰ نے، ان سے ان کے والد نے کہ  نبی کریم صلی"}
{"hadithnumber": "6399", "text": "ہم سے محمد بن مثنیٰ نے بیان کیا، کہا ہم سے عبیداللہ بن عبدالمجید نے بیان کیا، کہا ہم سے اسرائیل نے ب"}
{"hadithnumber": "6400", "text": "ہم سے مسدد نے بیان کیا، کہا ہم سے اسماعیل بن ابراہیم نے، انہیں ایوب نے خبر دی، انہیں محمد نے اور ان"}
{"hadithnumber": "6401", "text": "ہم سے قتیبہ بن سعید نے بیان کیا، انہوں نے کہا ہم سے عبدالوہاب نے بیان کیا، انہوں نے کہا ہم سے ایوب ن"}
{"hadithnumber": "6402", "text": "ہم سے علی بن عبداللہ نے بیان کیا، کہا ہم سے سفیان نے بیان کیا کہ زہری نے بیان کیا کہ ہم سے سعید بن م"}
{"hadithnumber": "6403", "text": "ہم سے عبداللہ بن مسلمہ قعنبی نے بیان کیا، ان سے امام مالک نے بیان کیا، ان سے سمی نے، ان سے ابوصالح ن"}
{"hadithnumber": "6404", "text": "ہم سے عبداللہ بن محمد مسندی نے بیان کیا، کہا ہم سے عبدالملک بن عمرو نے، کہا کہ ہم سے عمر بن ابی زائد"}
{"hadithnumber": "6405", "text": "ہم سے عبداللہ بن مسلمہ نے بیان کیا، ان سے امام مالک نے بیان کیا، ان سے سمی نے بیان کیا، ان سے ابوصال"}
{"hadithnumber": "6406", "text": "ہم سے زہیر بن حرب نے بیان کیا، انہوں نے کہا ہم سے ابن فضیل نے بیان کیا، ان سے عمارہ نے، ان سے ابوزرع"}
{"hadithnumber": "6407", "text": "ہم سے محمد بن علاء نے بیان کیا، کہا ہم سے ابواسامہ نے بیان کیا، ان سے یزید بن عبداللہ نے، ان سے ابوب"}
{"hadithnumber": "6408", "text": "ہم سے قتیبہ بن سعید نے بیان کیا، کہا ہم سے جریر بن عبدالحمید نے بیان کیا، ان سے اعمش نے، ان سے ابوصا"}
{"hadithnumber": "6409", "text": "ہم سے ابوالحسن محمد بن مقاتل نے بیان کیا، انہوں نے کہا ہم کو عبداللہ بن مبارک نے خبر دی، انہوں نے کہ"}
{"hadithnumber": "6410", "text": "ہم سے علی بن عبداللہ نے بیان کیا، انہوں نے کہا ہم سے سفیان نے بیان کیا، انہوں نے کہا کہ ہم نے یہ حدی"}
{"hadithnumber": "6411", "text": "ہم سے عمر بن حفص بن غیاث نے بیان کیا، کہا مجھ سے میرے والد نے بیان کیا، کہا ہم سے اعمش نے بیان کیا،"}
