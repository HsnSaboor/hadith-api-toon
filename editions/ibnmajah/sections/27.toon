hadiths[count]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}:
2898,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَهِشَامُ بْنُ عَمَّارٍ، قَالاَ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عُبَيْدِ اللَّهِ بْنِ أَبِي يَزِيدَ، عَنْ أَبِيهِ، عَنْ سِبَاعِ بْنِ ثَابِتٍ، عَنْ أُمِّ كُرْزٍ، قَالَتْ سَمِعْتُ النَّبِيَّ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ عَنِ الْغُلاَمِ، شَاتَانِ مُكَافِئَتَانِ وَعَنِ الْجَارِيَةِ، شَاةٌ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۷۴ (۱۳۴۰)، سنن ابی داود/الحج ۲ (۱۷۲۶)، سنن الترمذی/الرضاع ۱۵ (۱۱۶۹)،(تحفة الأشراف:۴۰۰۴)، وقد أخرجہ: صحیح البخاری/جزء الصید ۲۶ (۱۸۶۴ مختصراً)، مسند احمد (۳/ ۵۴)، سنن الدارمی/الاستئذان ۴۶ (۲۷۲۰),,It was\nnarrated that Umm Kurz said:,Chapters on Slaughtering
2899,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَفَّانُ، حَدَّثَنَا حَمَّادُ بْنُ سَلَمَةَ، أَنْبَأَنَا عَبْدُ اللَّهِ بْنُ عُثْمَانَ بْنِ خُثَيْمٍ، عَنْ يُوسُفَ بْنِ مَاهَكَ، عَنْ حَفْصَةَ بِنْتِ عَبْدِ الرَّحْمَنِ، عَنْ عَائِشَةَ، قَالَتْ أَمَرَنَا رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ أَنْ نَعُقَّ عَنِ الْغُلاَمِ شَاتَيْنِ وَعَنِ الْجَارِيَةِ شَاةً ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۳۰۳۵)، وقد أخرجہ: صحیح البخاری/تقصیر الصلاة ۴ (۱۰۸۸)، صحیح مسلم/الحج ۷۴ (۱۳۳۹)، سنن ابی داود/الحج ۲ (۱۷۲۳)، سنن الترمذی/الرضاع ۱۵ (۱۶۶۹)، موطا امام مالک/الإستئتذان ۱۴ (۳۷)، مسند احمد (۲/۲۳۶،۳۴۰،۳۴۷،۴۲۳،۴۳۷،۴۴۵،۴۹۳),2899,It was\nnarrated that ‘Aishah said:,Chapters on Slaughtering
2900,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، حَدَّثَنَا هِشَامُ بْنُ حَسَّانَ، عَنْ حَفْصَةَ بِنْتِ سِيرِينَ، عَنْ سَلْمَانَ بْنِ عَامِرٍ، أَنَّهُ سَمِعَ النَّبِيَّ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ إِنَّ مَعَ الْغُلاَمِ عَقِيقَةً فَأَهْرِيقُوا عَنْهُ دَمًا وَأَمِيطُوا عَنْهُ الأَذَى ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح مسلم/الحج ۷۴ (۱۳۴۱)، الجہاد ۱۸۱ (۳۰۶۱)،(تحفة الأشراف:۶۵۱۵)، وقد أخرجہ: صحیح البخاری/جزاء الصید ۲۶ (۳۰۶۱)، مسند احمد (۱/۳۴۶),,It was\nnarrated from Salman bin ‘Amir that he heard the Prophet (ﷺ)\nsay:,Chapters on Slaughtering
2901,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا شُعَيْبُ بْنُ إِسْحَاقَ، حَدَّثَنَا سَعِيدُ بْنُ أَبِي عَرُوبَةَ، عَنْ قَتَادَةَ، عَنِ الْحَسَنِ، عَنْ سَمُرَةَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ كُلُّ غُلاَمٍ مُرْتَهَنٌ بِعَقِيقَتِهِ تُذْبَحُ عَنْهُ يَوْمَ السَّابِعِ وَيُحْلَقُ رَأْسُهُ وَيُسَمَّى ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الحج ۴ (۱۵۲۰)، الجہاد ۶۲ (۲۷۸۴،۲۸۷۶)سنن النسائی/الحج ۴ (۲۶۲۹)،(تحفة الأشراف:۱۷۸۷۱)، وقد أخرجہ: مسند احمد (۶/۷۱،۷۶،۷۹ ۱۶۵),,It was\nnarrated from Samurah that the Prophet (ﷺ) said:,Chapters on Slaughtering
2902,"حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، حَدَّثَنِي عَمْرُو بْنُ الْحَارِثِ، عَنْ أَيُّوبَ بْنِ مُوسَى، أَنَّهُ حَدَّثَهُ أَنَّ يَزِيدَ بْنَ عَبْدٍ الْمُزَنِيَّ حَدَّثَهُ أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ يُعَقُّ عَنِ الْغُلاَمِ وَلاَ يُمَسُّ رَأْسُهُ بِدَمٍ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۸۲۱۱، ومصباح الزجاجة:۱۰۲۳)، وقد أخرجہ: سنن النسائی/الحج ۴ (۲۶۲۹)، مسند احمد (۲/۲۱،۶/۲۹۴،۳۰۳،۳۱۴),,Yazid\nbin ‘Abdul-Muzani narrated that the Prophet (ﷺ) said:,Chapters on Slaughtering
2903,"حَدَّثَنَا أَبُو بِشْرٍ، بَكْرُ بْنُ خَلَفٍ حَدَّثَنَا يَزِيدُ بْنُ زُرَيْعٍ، عَنْ خَالِدٍ الْحَذَّاءِ، عَنْ أَبِي الْمَلِيحِ، عَنْ نُبَيْشَةَ، قَالَ نَادَى رَجُلٌ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ فَقَالَ يَا رَسُولَ اللَّهِ إِنَّا كُنَّا نَعْتِرُ عَتِيرَةً فِي الْجَاهِلِيَّةِ فِي رَجَبٍ فَمَا تَأْمُرُنَا قَالَ ‏""‏ اذْبَحُوا لِلَّهِ عَزَّ وَجَلَّ فِي أَىِّ شَهْرٍ مَا كَانَ وَبَرُّوا اللَّهَ وَأَطْعِمُوا ‏""‏ ‏.‏ قَالُوا يَا رَسُولَ اللَّهِ إِنَّا كُنَّا نُفْرِعُ فَرَعًا فِي الْجَاهِلِيَّةِ فَمَا تَأْمُرُنَا قَالَ ‏""‏ فِي كُلِّ سَائِمَةٍ فَرَعٌ تَغْذُوهُ مَاشِيَتُكَ حَتَّى إِذَا اسْتَحْمَلَ ذَبَحْتَهُ فَتَصَدَّقْتَ بِلَحْمِهِ - أُرَاهُ قَالَ - عَلَى ابْنِ السَّبِيلِ فَإِنَّ ذَلِكَ هُوَ خَيْرٌ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Hasan,takhreej: «سنن ابی داود/المناسک ۲۶ (۱۸۱۱)،(تحفة الأشراف:۵۵۶۴),2903,It was\nnarrated that Nubaishah said:,Chapters on Slaughtering
2904,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَهِشَامُ بْنُ عَمَّارٍ، قَالاَ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ الزُّهْرِيِّ، عَنْ سَعِيدِ بْنِ الْمُسَيَّبِ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ لاَ فَرَعَةَ وَلاَ عَتِيرَةَ ‏""""‏ ‏.‏ قَالَ هِشَامٌ فِي حَدِيثِهِ وَالْفَرَعَةُ أَوَّلُ النَّتَاجِ ‏.‏ وَالْعَتِيرَةُ الشَّاةُ يَذْبَحُهَا أَهْلُ الْبَيْتِ فِي رَجَبٍ ‏.‏""",Al-Albani: Sahih Isnaad; Muhammad Fouad Abd al-Baqi: Sahih Isnaad; Shuaib Al Arnaut: Sahih Muquf; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۵۵۵، ومصباح الزجاجة:۱۰۲۴),,It was\nnarrated from Abu Hurairah that the Prophet (ﷺ) said:,Chapters on Slaughtering
2905,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِي عُمَرَ الْعَدَنِيُّ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ زَيْدِ بْنِ أَسْلَمَ، عَنْ أَبِيهِ، عَنِ ابْنِ عُمَرَ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ لاَ فَرَعَةَ وَلاَ عَتِيرَةَ ‏""""‏ ‏.‏ قَالَ ابْنُ مَاجَهْ هَذَا مِنْ فَرَائِدِ الْعَدَنِيِّ ‏.‏""",Al-Albani: Daif Isnaad; Muhammad Fouad Abd al-Baqi: Daif Isnaad; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۰۷۷، ومصباح الزجاجة:۱۰۲۵),,It was\nnarrated from Muhammad bin Abu (‘Umar) ‘Adani that the Prophet\n(ﷺ) said:,Chapters on Slaughtering
2906,"حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، حَدَّثَنَا عَبْدُ الْوَهَّابِ، حَدَّثَنَا خَالِدٌ الْحَذَّاءُ، عَنْ أَبِي قِلاَبَةَ، عَنْ أَبِي الأَشْعَثِ، عَنْ شَدَّادِ بْنِ أَوْسٍ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ إِنَّ اللَّهَ عَزَّ وَجَلَّ كَتَبَ الإِحْسَانَ عَلَى كُلِّ شَىْءٍ فَإِذَا قَتَلْتُمْ فَأَحْسِنُوا الْقِتْلَةَ وَإِذَا ذَبَحْتُمْ فَأَحْسِنُوا الذَّبْحَ وَلْيُحِدَّ أَحَدُكُمْ شَفْرَتَهُ وَلْيُرِحْ ذَبِيحَتَهُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن ابی داود/الحج ۲۶ (۱۸۱۰)، سنن النسائی/الحج ۲ (۲۶۲۲)،۱۰ (۲۶۳۸)،(تحفة الأشراف:۱۱۱۷۳)، وقد أخرجہ: سنن الترمذی/الحج ۸۷ (۹۳۰)، مسند احمد (۴/۱۰،۱۱،۱۲),,It was\nnarrated from Shaddad bin Aws that the Messenger of Allah\n(ﷺ) said:,Chapters on Slaughtering
2907,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عُقْبَةُ بْنُ خَالِدٍ، عَنْ مُوسَى بْنِ مُحَمَّدِ بْنِ إِبْرَاهِيمَ التَّيْمِيِّ، أَخْبَرَنِي أَبِي، عَنْ أَبِي سَعِيدٍ الْخُدْرِيِّ، قَالَ مَرَّ النَّبِيُّ ـ صلى الله عليه وسلم ـ بِرَجُلٍ وَهُوَ يَجُرُّ شَاةً بِأُذُنِهَا فَقَالَ ‏ ‏ دَعْ أُذُنَهَا وَخُذْ بِسَالِفَتِهَا ‏""""‏ ‏.‏""",Al-Albani: Hasan Isnaad; Muhammad Fouad Abd al-Baqi: Hasan Isnaad; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۵۲۲)، وقد أخرجہ: صحیح البخاری/الحج ۱ (۱۵۱۳)، جزاء الصید ۲۳ (۱۸۵۴)،۲۴ (۱۸۵۵)، المغازي ۷۷ (۴۳۹۹)، الاستئذان ۲ (۶۲۲۸)، صحیح مسلم/الحج ۷۱ (۱۳۳۴)، سنن ابی داود/الحج ۲۶ (۱۸۰۹)، سنن الترمذی/الحج ۸۵ (۹۲۸)، سنن النسائی/الحج ۸ (۲۶۳۴)،۹ (۲۶۳۶)، موطا امام مالک/الحج ۳۰ (۹۷)، مسند احمد (۱/۲۱۹،۲۵۱،۳۲۹،۳۴۶،۳۵۹)، سنن الدارمی/الحج ۲۳ (۱۸۷۳),,It was\nnarrated that Abu Sa’eed Al-Khudri said:,Chapters on Slaughtering
2908,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الرَّحْمَنِ ابْنُ أَخِي، حُسَيْنٍ الْجُعْفِيِّ حَدَّثَنَا مَرْوَانُ بْنُ مُحَمَّدٍ، حَدَّثَنَا ابْنُ لَهِيعَةَ، حَدَّثَنِي قُرَّةُ بْنُ حَيْوَئِيلَ، عَنِ الزُّهْرِيِّ، عَنْ سَالِمِ بْنِ عَبْدِ اللَّهِ بْنِ عُمَرَ، عَنْ أَبِيهِ عَبْدِ اللَّهِ بْنِ عُمَرَ، قَالَ أَمَرَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ بِحَدِّ الشِّفَارِ وَأَنْ تُوَارَى عَنِ الْبَهَائِمِ وَقَالَ ‏ ‏ إِذَا ذَبَحَ أَحَدُكُمْ فَلْيُجْهِزْ ‏""""‏ ‏.‏ حَدَّثَنَا جَعْفَرُ بْنُ مُسَافِرٍ، حَدَّثَنَا أَبُو الأَسْوَدِ، حَدَّثَنَا ابْنُ لَهِيعَةَ، عَنْ يَزِيدَ بْنِ أَبِي حَبِيبٍ، عَنْ سَالِمٍ، عَنْ أَبِيهِ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ مِثْلَهُ ‏.‏""",Al-Albani: Daif Isnaad; Muhammad Fouad Abd al-Baqi: Daif Isnaad; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۴۱۷، ومصباح الزجاجة:۱۰۲۶),,It was\nnarrated that ‘Abdullah bin ‘Umar said:,Chapters on Slaughtering
2909,حَدَّثَنَا عَمْرُو بْنُ عَبْدِ اللَّهِ، حَدَّثَنَا وَكِيعٌ، عَنْ إِسْرَائِيلَ، عَنْ سِمَاكٍ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، ‏{إِنَّ الشَّيَاطِينَ لَيُوحُونَ إِلَى أَوْلِيَائِهِمْ}‏ قَالَ كَانُوا يَقُولُونَ مَا ذُكِرَ عَلَيْهِ اسْمُ اللَّهِ فَلاَ تَأْكُلُوا وَمَا لَمْ يُذْكَرِ اسْمُ اللَّهِ عَلَيْهِ فَكُلُوهُ ‏.‏ فَقَالَ اللَّهُ عَزَّ وَجَلَّ ‏{وَلاَ تَأْكُلُوا مِمَّا لَمْ يُذْكَرِ اسْمُ اللَّهِ عَلَيْهِ}‏ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/جزاء الصید ۲۳ (۱۸۵۳)، صحیح مسلم/الحج ۷۱ (۱۳۳۵)، سنن الترمذی/الحج ۸۵ (۹۲۸)، سنن النسائی/آداب القضاة ۹ (۵۳۹۱)،(تحفة الأشراف:۱۱۰۴۸)، وقد أخرجہ: مسند احمد (۱/۲۱۲،۳۱۳،۳۵۹)، سنن الدارمی/المناسک ۲۳ (۱۸۷۵),2909,It was\nnarrated from Ibn ‘Abbas:,Chapters on Slaughtering
2910,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ سُلَيْمَانَ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ أُمِّ الْمُؤْمِنِينَ، أَنَّ قَوْمًا، قَالُوا يَا رَسُولَ اللَّهِ إِنَّ قَوْمًا يَأْتُونَا بِلَحْمٍ لاَ نَدْرِي ذُكِرَ اسْمُ اللَّهِ عَلَيْهِ أَمْ لاَ قَالَ ‏ ‏ سَمُّوا أَنْتُمْ وَكُلُوا ‏""""‏ ‏.‏ وَكَانُوا حَدِيثَ عَهْدٍ بِالْكُفْرِ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن الترمذی/الحج ۸۳ (۹۲۴)،(تحفة الأشراف:۳۰۷۶),,"It was\nnarrated from ‘Aishah, the Mother of the Believers, that some\npeople said:",Chapters on Slaughtering
2911,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو الأَحْوَصِ، عَنْ عَاصِمٍ، عَنِ الشَّعْبِيِّ، عَنْ مُحَمَّدِ بْنِ صَيْفِيٍّ، قَالَ ذَبَحْتُ أَرْنَبَيْنِ بِمَرْوَةٍ فَأَتَيْتُ بِهِمَا النَّبِيَّ ـ صلى الله عليه وسلم ـ فَأَمَرَنِي بِأَكْلِهِمَا ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۱۶ (۱۲۰۹)، سنن ابی داود/الحج ۱۰ (۱۷۴۳)، سنن النسائی/الحیض ۲۴ (۲۱۵)، الحج ۵۷ (۲۷۶۱)،(تحفة الأشراف:۱۷۵۰۲)، وقد أخرجہ: موطا امام مالک/الحج ۴۱ (۱۲۷،۱۲۸)، سنن الدارمی/المناسک ۱۱ (۱۸۴۵)،۳۴ (۱۸۹۲),2911,It was\nnarrated that Muhammad bin Saifi said:,Chapters on Slaughtering
2912,حَدَّثَنَا أَبُو بِشْرٍ، بَكْرُ بْنُ خَلَفٍ حَدَّثَنَا غُنْدَرٌ، حَدَّثَنَا شُعْبَةُ، سَمِعْتُ حَاضِرَ بْنَ مُهَاجِرٍ، يُحَدِّثُ عَنْ سُلَيْمَانَ بْنِ يَسَارٍ، عَنْ زَيْدِ بْنِ ثَابِتٍ، أَنَّ ذِئْبًا، نَيَّبَ فِي شَاةٍ فَذَبَحُوهَا بِمَرْوَةٍ فَرَخَّصَ لَهُمْ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ فِي أَكْلِهَا ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن النسائی/الحج ۲۶ (۲۶۶۵)،(تحفة الأشراف:۶۶۱۷),2912,,Chapters on Slaughtering
2913,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، حَدَّثَنَا سُفْيَانُ، عَنْ سِمَاكِ بْنِ حَرْبٍ، عَنْ مُرِّيِّ بْنِ قَطَرِيٍّ، عَنْ عَدِيِّ بْنِ حَاتِمٍ، قَالَ قُلْتُ يَا رَسُولَ اللَّهِ إِنَّا نَصِيدُ الصَّيْدَ فَلاَ نَجِدُ سِكِّينًا إِلاَّ الظِّرَارَ وَشِقَّةَ الْعَصَا ‏.‏ قَالَ ‏ ‏ أَمْرِرِ الدَّمَ بِمَا شِئْتَ وَاذْكُرِ اسْمَ اللَّهِ عَلَيْهِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۱۶ (۱۲۱۰)، سنن ابی داود/الحج ۱۰ (۱۷۴۳)، سنن النسائی/الحیض ۲۴ (۲۱۵)، الحج ۵۷ (۲۷۶۲،۲۷۶۳)،(تحفة الأشراف:۲۶۰۰)، وقد أخرجہ: موطا امام مالک/الحج ۴۱ (۱۲۷،۱۲۸)، سنن الدارمی/المناسک ۱۱ (۱۸۴۵),,It was\nnarrated that ‘Adi bin Hatim said:,Chapters on Slaughtering
2914,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا عُمَرُ بْنُ عُبَيْدٍ الطَّنَافِسِيُّ، عَنْ سَعِيدِ بْنِ مَسْرُوقٍ، عَنْ عَبَايَةَ بْنِ رِفَاعَةَ، عَنْ جَدِّهِ، رَافِعِ بْنِ خَدِيجٍ قَالَ كُنَّا مَعَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ فِي سَفَرٍ فَقُلْتُ يَا رَسُولَ اللَّهِ إِنَّا نَكُونُ فِي الْمَغَازِي فَلاَ يَكُونُ مَعَنَا مُدًى فَقَالَ ‏ ‏ مَا أَنْهَرَ الدَّمَ وَذُكِرَ اسْمُ اللَّهِ عَلَيْهِ فَكُلْ غَيْرَ السِّنِّ وَالظُّفْرِ فَإِنَّ السِّنَّ عَظْمٌ وَالظُّفْرَ مُدَى الْحَبَشَةِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/العلم ۵۳ (۱۳۳)، الحج ۵ (۱۵۲۲)،۸ (۱۵۲۵،۱۰ (۱۵۲۸)، صحیح مسلم/الحج ۲ (۱۱۸۲)، سنن ابی داود/الحج ۹ (۱۷۳۷)، سنن النسائی/الحج ۱۷ (۲۶۵۲)،(تحفة الأشراف:۸۳۲۶)، وقد أخرجہ: موطا امام مالک/الحج ۸ (۲۲)، مسند احمد (۲/۴۸،۵۵،۶۵)، سنن الدارمی/المناسک ۵ (۱۸۳۱),,It was\nnarrated that Rafi’ bin Khadij said:,Chapters on Slaughtering
2915,"حَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِيَةَ، حَدَّثَنَا هِلاَلُ بْنُ مَيْمُونٍ الْجُهَنِيُّ، عَنْ عَطَاءِ بْنِ يَزِيدَ اللَّيْثِيِّ، - قَالَ عَطَاءٌ لاَ أَعْلَمُهُ إِلاَّ عَنْ أَبِي سَعِيدٍ الْخُدْرِيِّ - أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ مَرَّ بِغُلاَمٍ يَسْلُخُ شَاةً فَقَالَ لَهُ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏""‏ تَنَحَّ حَتَّى أُرِيَكَ ‏""‏ ‏.‏ فَأَدْخَلَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ يَدَهُ بَيْنَ الْجِلْدِ وَاللَّحْمِ فَدَحَسَ بِهَا حَتَّى تَوَارَتْ إِلَى الإِبْطِ وَقَالَ ‏""‏ يَا غُلاَمُ هَكَذَا فَاسْلُخْ ‏""‏ ‏.‏ ثُمَّ مَضَى وَصَلَّى لِلنَّاسِ وَلَمْ يَتَوَضَّأْ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۶۵۲، ومصباح الزجاجة:۱۰۲۷)، وقد أخر جہ: صحیح مسلم/الحج ۲ (۱۱۸۳)، مسند احمد (۲/۱۸۱،۳/۳۳۳،۳۳۶),2915,It was\nnarrated from Abu Sa’eed Al-Khudri that the Messenger of Allah\n(ﷺ) passed by a boy who was skinning a sheep. The Messenger of\nAllah\n(ﷺ) said to him:,Chapters on Slaughtering
2916,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا خَلَفُ بْنُ خَلِيفَةَ، ح وَحَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ، أَنْبَأَنَا مَرْوَانُ بْنُ مُعَاوِيَةَ، جَمِيعًا عَنْ يَزِيدَ بْنِ كَيْسَانَ، عَنْ أَبِي حَازِمٍ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ أَتَى رَجُلاً مِنَ الأَنْصَارِ فَأَخَذَ الشَّفْرَةَ لِيَذْبَحَ لِرَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ فَقَالَ لَهُ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِيَّاكَ وَالْحَلُوبَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۰۳۲، ومصباح الزجاجة:۱۰۲۸)، وقد أخرجہ: صحیح البخاری/الحج ۲ (۱۵۱۴)،۲۸ (۱۵۵۲)،۲۹ (۱۵۵۳)، صحیح مسلم/الحج ۳ (۱۱۸۷)، سنن النسائی/الحج ۵۶ (۲۷۵۹)، موطا امام مالک/الحج ۸ (۲۳)، مسند احمد (۲/۱۷،۱۸،۲۹،۳۶،۳۷)، سنن الدارمی/المناسک ۸۲ (۱۹۷۰),,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\ncame to\na man from among the Ansar who had picked up a knife to\nslaughter an\nanimal for the Messenger of Allah (ﷺ). The Messenger of\nAllah (ﷺ)\nsaid to him:,Chapters on Slaughtering
2917,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ الْمُحَارِبِيُّ، عَنْ يَحْيَى بْنِ عُبَيْدِ اللَّهِ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ حَدَّثَنِي أَبُو بَكْرِ بْنُ أَبِي قُحَافَةَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ لَهُ وَلِعُمَرَ ‏""‏ انْطَلِقُوا بِنَا إِلَى الْوَاقِفِيِّ ‏""‏ ‏.‏ قَالَ فَانْطَلَقْنَا فِي الْقَمَرِ حَتَّى أَتَيْنَا الْحَائِطَ فَقَالَ مَرْحَبًا وَأَهْلاً ‏.‏ ثُمَّ أَخَذَ الشَّفْرَةَ ثُمَّ جَالَ فِي الْغَنَمِ فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏""‏ إِيَّاكَ وَالْحَلُوبَ ‏""‏ ‏.‏ أَوْ قَالَ ‏""‏ ذَاتَ الدَّرِّ ‏""‏ ‏.‏",Al-Albani: Sahih Isnaad; Muhammad Fouad Abd al-Baqi: Sahih Isnaad; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۵۲، ومصباح الزجاجة:۱۰۲۹)، وقد أخرجہ: مسند احمد (۳/۱۸۳،۲۲۵),2917,Abu\nHurairah narrated that Abu Bakr bin Abu Quhafah narrated that the\nMessenger of Allah (ﷺ) said to him and to ‘Umar:,Chapters on Slaughtering
2918,حَدَّثَنَا هَنَّادُ بْنُ السَّرِيِّ، حَدَّثَنَا عَبْدَةُ بْنُ سُلَيْمَانَ، عَنْ عُبَيْدِ اللَّهِ، عَنْ نَافِعٍ، عَنِ ابْنٍ لِكَعْبِ بْنِ مَالِكٍ، عَنْ أَبِيهِ، أَنَّ امْرَأَةً، ذَبَحَتْ شَاةً بِحَجَرٍ فَذُكِرَ ذَلِكَ لِرَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ فَلَمْ يَرَ بِهِ بَأْسًا ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۸۷۳،۸۰۱۳،۱۸۱۳)، وقد أخرجہ: صحیح البخاری/الحج ۲۶ (۱۵۴۹)، اللباس ۶۹ (۵۹۵۱)، صحیح مسلم/الحج ۳ (۱۱۸۴)، سنن ابی داود/الحج ۲۷ (۱۸۱۲)، سنن الترمذی/الحج ۱۳ (۸۲۵)، سنن النسائی/الحج ۵۴ (۲۷۵۰)، موطا امام مالک/الحج ۹ (۲۸)، حم۲/۳،۲۸،۳۴،۴۱،۴۳،۴۷،۴۸،۵۳،۷۶،۷۷،۷۹،۱۳۱، سنن الدارمی/المناسک ۱۳ (۱۸۴۹),2918,,Chapters on Slaughtering
2919,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا عُمَرُ بْنُ عُبَيْدٍ، عَنْ سَعِيدِ بْنِ مَسْرُوقٍ، عَنْ عَبَايَةَ بْنِ رِفَاعَةَ، عَنْ جَدِّهِ، رَافِعِ بْنِ خَدِيجٍ قَالَ كُنَّا مَعَ النَّبِيِّ ـ صلى الله عليه وسلم ـ فِي سَفَرٍ فَنَدَّ بَعِيرٌ فَرَمَاهُ رَجُلٌ بِسَهْمٍ فَقَالَ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏ ‏ إِنَّ لَهَا أَوَابِدَ - أَحْسَبُهُ قَالَ - كَأَوَابِدِ الْوَحْشِ فَمَا غَلَبَكُمْ مِنْهَا فَاصْنَعُوا بِهِ هَكَذَا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الحج ۲۷ (۱۸۱۳)،(تحفة الأشراف:۲۶۰۴),,It was\nnarrated that Rafi’ bin Khadij said:,Chapters on Slaughtering
2920,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا وَكِيعٌ، عَنْ حَمَّادِ بْنِ سَلَمَةَ، عَنْ أَبِي الْعُشَرَاءِ، عَنْ أَبِيهِ، قَالَ قُلْتُ يَا رَسُولَ اللَّهِ مَا تَكُونُ الذَّكَاةُ إِلاَّ فِي الْحَلْقِ وَاللَّبَّةِ قَالَ ‏ ‏ لَوْ طَعَنْتَ فِي فَخِذِهَا لأَجْزَأَكَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ:(تحفة الأشراف:۱۳۹۴۱، ومصباح الزجاجة:۱۰۳۰)، وقد أخرجہ: سنن النسائی/الحج ۵۴ (۲۷۵۳)، مسند احمد (۲/۳۴۱،۳۵۲،۴۷۶),,It was\nnarrated from Abu ‘Ushara’ that his father said:,Chapters on Slaughtering
2921,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَبْدُ اللَّهِ بْنُ سَعِيدٍ، قَالاَ حَدَّثَنَا عُقْبَةُ بْنُ خَالِدٍ، عَنْ مُوسَى بْنِ مُحَمَّدِ بْنِ إِبْرَاهِيمَ التَّيْمِيِّ، عَنْ أَبِيهِ، عَنْ أَبِي سَعِيدٍ الْخُدْرِيِّ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ أَنْ يُمَثَّلَ بِالْبَهَائِمِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن الترمذی/الحج ۱۴ (۸۲۸)،(تحفة الأشراف:۴۷۳۵),2921,It was\nnarrated that Abu Sa’eed Al-Khudri said:,Chapters on Slaughtering
2922,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، عَنْ شُعْبَةَ، عَنْ هِشَامِ بْنِ زَيْدِ بْنِ أَنَسِ بْنِ مَالِكٍ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنْ صَبْرِ الْبَهَائِمِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الحج ۲۷ (۱۸۱۴)، سنن الترمذی/الحج ۱۵ (۸۲۹)، سنن النسائی/الحج ۵۵ (۲۷۵۴)،(تحفة الأشراف:۳۷۸۸)، وقد أخرجہ: موطا امام مالک/الحج ۱۰ (۳۴)، مسند احمد (۴/۵۵،۵۶)، سنن الدارمی/المناسک ۱۴ (۱۸۵۰),2922,It was\nnarrated that Anas bin Malik said:,Chapters on Slaughtering
2923,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، ح وَحَدَّثَنَا أَبُو بَكْرِ بْنُ خَلاَّدٍ الْبَاهِلِيُّ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، قَالاَ حَدَّثَنَا سُفْيَانُ، عَنْ سِمَاكٍ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لاَ تَتَّخِذُوا شَيْئًا فِيهِ الرُّوحُ غَرَضًا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۷۵۰، و مصباح الزجاجة:۱۰۳۱)، وقد أخرجہ: مسند احمد (۵/۱۹۲),,It was\nnarrated from Ibn ‘Abbas that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Slaughtering
2924,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، أَنْبَأَنَا ابْنُ جُرَيْجٍ، حَدَّثَنَا أَبُو الزُّبَيْرِ، أَنَّهُ سَمِعَ جَابِرَ بْنَ عَبْدِ اللَّهِ، يَقُولُ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ أَنْ يُقْتَلَ شَىْءٌ مِنَ الدَّوَابِّ صَبْرًا ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/الحج ۱۴ (۸۲۷)،(تحفة الأشراف:۶۶۰۸)، وقد أخرجہ: سنن الدارمی/المناسک ۸ (۱۸۳۸),2924,Jabir\nbin ‘Abdullah said:,Chapters on Slaughtering
2925,حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، حَدَّثَنَا ابْنُ أَبِي زَائِدَةَ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ، عَنِ ابْنِ أَبِي نَجِيحٍ، عَنْ مُجَاهِدٍ، عَنِ ابْنِ عُمَرَ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنْ لُحُومِ الْجَلاَّلَةِ وَأَلْبَانِهَا ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۳۶۲، ومصباح الزجاجة:۱۰۳۲)، وقد أخرجہ: مسند احمد (۳/۲۷۳),2925,It was\nnarrated that Ibn ‘Umar said:,Chapters on Slaughtering
2926,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا وَكِيعٌ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ فَاطِمَةَ بِنْتِ الْمُنْذِرِ، عَنْ أَسْمَاءَ بِنْتِ أَبِي بَكْرٍ، قَالَتْ نَحَرْنَا فَرَسًا فَأَكَلْنَا مِنْ لَحْمِهِ عَلَى عَهْدِ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «حدیث أبي بکر بن أبي شیبة أخرجہ: صحیح البخاری/الحج ۱۸ (۱۵۳۹)،۱۴۳ (۱۷۵۴)، اللباس ۷۳ (۵۹۲۲)،۷۴ (۵۹۲۳)،۷۹ (۵۹۲۸)،۸۱ (۵۹۳۰)،(تحفة الأشراف:۱۷۴۸۵)، وحدیث محمد بن رمح تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۷۵۱۴)، وقد أخرجہ: صحیح مسلم/الحج ۷ (۱۱۸۹)، سنن ابی داود/الحج ۱۱ (۱۷۴۵)، سنن الترمذی/الحج ۷۷ (۹۱۷)، سنن النسائی/الحج ۴۱ (۲۶۸۷)، موطا امام مالک/الحج ۷ (۱۷)، مسند احمد (۶/۹۸،۱۰۶،۱۳۰،۱۶۲،۱۸۱،۱۸۶،۱۹۲،۲۰۰،۲۰۷،۲۰۹،۲۱۴،۲۱۶،۲۳۷،۲۳۸،۲۴۴،۲۴۵،۲۵۸)، سنن الدارمی/المناسک ۱۰ (۱۸۴۴),2926,It was\nnarrated that Asm’a bint Abu Bakr said:,Chapters on Slaughtering
2927,حَدَّثَنَا بَكْرُ بْنُ خَلَفٍ أَبُو بِشْرٍ، حَدَّثَنَا أَبُو عَاصِمٍ، حَدَّثَنَا ابْنُ جُرَيْجٍ، أَخْبَرَنِي أَبُو الزُّبَيْرِ، أَنَّهُ سَمِعَ جَابِرَ بْنَ عَبْدِ اللَّهِ، يَقُولُ أَكَلْنَا زَمَنَ خَيْبَرَ الْخَيْلَ وَحُمُرَ الْوَحْشِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۷ (۱۱۹۰)،(تحفة الأشراف:۱۷۶۴۵)، وقد أخرجہ: مسند احمد (۶/۱۰۹،۲۰۷),2927,It was\nnarrated from Abu Zubair that he heard Jabir bin ‘Abdullah\nsay:,Chapters on Slaughtering
2928,حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ، عَنْ أَبِي إِسْحَاقَ الشَّيْبَانِيِّ، قَالَ سَأَلْتُ عَبْدَ اللَّهِ بْنَ أَبِي أَوْفَى عَنْ لُحُومِ الْحُمُرِ الأَهْلِيَّةِ، فَقَالَ أَصَابَتْنَا مَجَاعَةٌ يَوْمَ خَيْبَرَ وَنَحْنُ مَعَ النَّبِيِّ ـ صلى الله عليه وسلم ـ وَقَدْ أَصَابَ الْقَوْمُ حُمُرًا خَارِجًا مِنَ الْمَدِينَةِ فَنَحَرْنَاهَا وَإِنَّ قُدُورَنَا لَتَغْلِي إِذْ نَادَى مُنَادِي النَّبِيِّ ـ صلى الله عليه وسلم ـ أَنِ اكْفَئُوا الْقُدُورَ وَلاَ تَطْعَمُوا مِنْ لُحُومِ الْحُمُرِ شَيْئًا ‏.‏ فَأَكْفَأْنَاهَا ‏.‏ فَقُلْتُ لِعَبْدِ اللَّهِ بْنِ أَبِي أَوْفَى حَرَّمَهَا تَحْرِيمًا قَالَ تَحَدَّثْنَا أَنَّمَا حَرَّمَهَا رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ أَلْبَتَّةَ مِنْ أَجْلِ أَنَّهَا تَأْكُلُ الْعَذِرَةَ ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: «سنن النسائی/الحج ۴۱ (۲۶۹۵)،۴۲ (۶۲۹۶،۲۷۰۴)،(تحفة الأشراف:۱۶۰۲۶)، وقد أخرجہ: صحیح البخاری/الغسل ۱۴ (۲۶۷)، الحج ۱۸ (۱۵۳۹)، اللباس ۷۰ (۵۹۱۸)، صحیح مسلم/الحج ۷ (۱۱۹۰)، بدون ذکر'' بعد ثلاثة ''، مسند احمد (۶/۲۰۰،۲۰۷،۲۰۹،۲۱۴،۲۱۶،۲۳۷،۲۳۸،۲۴۴،۲۴۵،۲۵۸),2928,It was\nnarrated that Abu Ishaq Shaibani said:,Chapters on Slaughtering
2929,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا زَيْدُ بْنُ الْحُبَابِ، عَنْ مُعَاوِيَةَ بْنِ صَالِحٍ، حَدَّثَنِي الْحَسَنُ بْنُ جَابِرٍ، عَنِ الْمِقْدَامِ بْنِ مَعْدِيكَرِبَ الْكِنْدِيِّ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ حَرَّمَ أَشْيَاءَ حَتَّى ذَكَرَ الْحُمُرَ الإِنْسِيَّةَ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/العلم ۵۳ (۱۳۴)، الصلاة ۹ (۳۶۶)، الحج ۲۱ (۱۵۴۲)، جزاء الصید ۱۳ (۱۸۳۸)،۱۵ (۱۸۴۲)، اللباس ۸ (۵۷۹۴)،۱۳ (۵۸۰۳)،۱۵ (۵۸۰۶)، صحیح مسلم/الحج ۱ (۱۱۷۷)، سنن ابی داود/المناسک ۳۲ (۱۸۲۴)، سنن الترمذی/الحج ۱۸ (۸۳۳)، سنن النسائی/الحج ۳۰ (۲۶۷۰)،(تحفة الأشراف:۸۳۲۵)، موطا امام مالک/الحج ۴ (۹)، مسند احمد (۲/۴،۸،۲۲،۲۹،۳۲،۳۴،۴۱،۵۴،۵۶،۵۸،۶۳،۶۵،۱۷۷،۱۱۹)، سنن الدارمی/المناسک ۹ (۱۸۳۹),2929,,Chapters on Slaughtering
2930,حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ، عَنْ عَاصِمٍ، عَنِ الشَّعْبِيِّ، عَنِ الْبَرَاءِ بْنِ عَازِبٍ، قَالَ أَمَرَنَا رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ أَنْ نُلْقِيَ لُحُومَ الْحُمُرِ الأَهْلِيَّةِ نِيئَةً وَنَضِيجَةً ثُمَّ لَمْ يَأْمُرْنَا بِهِ بَعْدُ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/اللباس۳۷ (۵۸۵۲)، صحیح مسلم/الحج ۱ (۱۱۷۷)،(تحفة الأشراف:۷۲۲۶)،(أنظر ما قبلہ),2930,It was\nnarrated that Bara’ bin ‘Azib said:,Chapters on Slaughtering
2931,"حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، حَدَّثَنَا الْمُغِيرَةُ بْنُ عَبْدِ الرَّحْمَنِ، عَنْ يَزِيدَ بْنِ أَبِي عُبَيْدٍ، عَنْ سَلَمَةَ بْنِ الأَكْوَعِ، قَالَ غَزَوْنَا مَعَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ غَزْوَةَ خَيْبَرَ فَأَمْسَى النَّاسُ قَدْ أَوْقَدُوا النِّيرَانَ فَقَالَ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏""‏ عَلاَمَ تُوقِدُونَ ‏""‏ ‏.‏ قَالُوا عَلَى لُحُومِ الْحُمُرِ الإِنْسِيَّةِ فَقَالَ ‏""‏ أَهْرِيقُوا مَا فِيهَا وَاكْسِرُوهَا ‏""‏ ‏.‏ فَقَالَ رَجُلٌ مِنَ الْقَوْمِ أَوْ نُهَرِيقُ مَا فِيهَا وَنَغْسِلُهَا فَقَالَ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏""‏ أَوْ ذَاكَ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/جزاء الصید ۱۵ (۱۸۴۱)،۱۶ (۱۸۴۳)، اللباس۱۴ (۵۸۰۴)،۳۷ (۵۸۵۳)، صحیح مسلم/الحج ۱ (۱۱۷۸)، سنن ابی داود/المناسک ۳۲ (۱۸۲۹)، سنن الترمذی/الحج ۱۹ (۸۳۴)، سنن النسائی/الحج ۳۲ (۲۶۷۲،۲۶۷۳)،۳۷ (۲۶۸۰)، الزینة من المجتبیٰ ۴۶ (۵۳۲۷)،(تحفة الأشراف:۵۳۷۵)، وقد أخرجہ: مسند احمد (۱/۲۱۵،۲۲۱،۲۲۸،۲۷۹،۳۳۷)، سنن الدارمی/المناسک ۹ (۱۸۴۰),2931,It was\nnarrated that Salamah bin Akwa’ said:,Chapters on Slaughtering
2932,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَنْبَأَنَا مَعْمَرٌ، عَنْ أَيُّوبَ، عَنِ ابْنِ سِيرِينَ، عَنْ أَنَسِ بْنِ مَالِكٍ، أَنَّ مُنَادِيَ النَّبِيِّ، ـ صلى الله عليه وسلم ـ نَادَى إِنَّ اللَّهَ وَرَسُولَهُ يَنْهَيَانِكُمْ عَنْ لُحُومِ الْحُمُرِ الأَهْلِيَّةِ فَإِنَّهَا رِجْسٌ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «حدیث نافع تقدم تخریجہ،(۲۹۲۹)، وحدیث عبد اللہ بن دینار تقدم تخریجہ،(۲۹۳۰)،(تحفة الأشراف:۲۹۳۰),2932,It was\nnarrated from Anas bin Malik that the caller of the Prophet\n(ﷺ)\ncried out:,Chapters on Slaughtering
2933,حَدَّثَنَا عَمْرُو بْنُ عَبْدِ اللَّهِ، حَدَّثَنَا وَكِيعٌ، عَنْ سُفْيَانَ، ح وَحَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، حَدَّثَنَا الثَّوْرِيُّ، وَمَعْمَرٌ، جَمِيعًا عَنْ عَبْدِ الْكَرِيمِ الْجَزَرِيِّ، عَنْ عَطَاءٍ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، قَالَ كُنَّا نَأْكُلُ لُحُومَ الْخَيْلِ ‏.‏ قُلْتُ فَالْبِغَالُ قَالَ لاَ ‏.‏,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/المناسک ۳۰ (۱۷۷۰)،(تحفة الأشراف:۱۵۷۱۵),2933,It was\nnarrated that ‘Ata’ narrated that Jabir bin ‘Abdullah said:,Chapters on Slaughtering
2934,حَدَّثَنَا مُحَمَّدُ بْنُ الْمُصَفَّى، حَدَّثَنَا بَقِيَّةُ، حَدَّثَنِي ثَوْرُ بْنُ يَزِيدَ، عَنْ صَالِحِ بْنِ يَحْيَى بْنِ الْمِقْدَامِ بْنِ مَعْدِيكَرِبَ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، عَنْ خَالِدِ بْنِ الْوَلِيدِ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنْ لُحُومِ الْخَيْلِ وَالْبِغَالِ وَالْحَمِيرِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/جزاء الصید ۱۴ (۱۸۴۰)، صحیح مسلم/الحج ۱۳ (۱۲۰۵)، سنن ابی داود/الحج ۳۸ (۱۸۴۰)، سنن النسائی/الحج ۲۷ (۲۶۶۶)،(تحفة الأشراف:۳۴۶۳)، وقد أخرجہ: موطا امام مالک/الحج ۲ (۴)، مسند احمد (۵/۴۱۶،۴۱۸،۴۲۱)، سنن الدارمی/المناسک ۶ (۱۸۳۴),2934,It was\nnarrated that Khalid bin Walid said:,Chapters on Slaughtering
2935,"حَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ، وَأَبُو خَالِدٍ الأَحْمَرُ وَعَبْدَةُ بْنُ سُلَيْمَانَ عَنْ مُجَالِدٍ، عَنْ أَبِي الْوَدَّاكِ، عَنْ أَبِي سَعِيدٍ، قَالَ سَأَلْنَا رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ عَنِ الْجَنِينِ فَقَالَ ‏ ‏ كُلُوهُ إِنْ شِئْتُمْ فَإِنَّ ذَكَاةَ الْجَنِينِ ذَكَاةُ أُمِّهِ ‏""""‏ ‏.‏ قَالَ أَبُو عَبْد اللَّهِ سَمِعْتُ الْكَوْسَجَ إِسْحَقَ بْنَ مَنْصُورٍ يَقُولُ فِي قَوْلِهِمْ فِي الذَّكَاةِ لَا يُقْضَى بِهَا مَذِمَّةٌ قَالَ مَذِمَّةٌ بِكَسْرِ الذَّالِ مِنْ الذِّمَامِ وَبِفَتْحِ الذَّالِ مِنْ الذَّمِّ.""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/المناسک ۳۴ (۱۸۳۳)،(تحفة الأشراف:۱۷۵۷۷)، وقد أخرجہ: مسند احمد (۶/۳۰),,It was\nnarrated that Abu Sa’eed said:,Chapters on Slaughtering
3162,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَهِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الضحایا ۲۱ (۲۸۳۵،۲۸۳۶)، سنن النسائی/العقیقة ۳ (۴۲۲۲،۴۲۲۳)،(تحفة الأشراف:۱۷۸۳۳)، وقد أخرجہ: سنن الترمذی/الأضاحي ۱۷ (۱۵۱۶)، مسند احمد (۶/۳۸۱،۴۲۲)، سنن الدارمی/الأضاحي ۹ (۲۰۰۹),3162,,Chapters on Slaughtering
3163,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا عَفَّانُ، ‏‏‏‏‏‏حَدَّثَنَا حَمَّادُ بْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن الترمذی/الأضاحي ۱۶ (۱۵۱۳)،(تحفة الأشراف:۱۷۸۳۳)، وقد أخرجہ: مسند احمد (۶/۳۱،۸۲،۱۵۸،۲۵۱)، سنن الدارمی/الأضاحي ۹ (۲۰۰۹),3163,,Chapters on Slaughtering
3164,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، ‏‏‏‏‏‏حَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «صحیح البخاری/العقیقة ۲ (۷۱ ۵۴)، سنن ابی داود/الضحایا۲۱ (۲۸۳۹)، سنن الترمذی/الضحایا ۱۷ (۱۵۱۵)،(تحفة الأشراف:۴۴۸۵)، وقد أخرجہ: سنن النسائی/العقیقة ۱ (۴۲۱۹)، مسند احمد (۴/۱۷،۱۸،۲۱۴)، سنن الدارمی/الأضاحي ۹ (۲۰۱۰),3164,,Chapters on Slaughtering
3165,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا شُعَيْبُ بْنُ إِسْحَاق، ‏‏‏‏‏‏حَدَّثَنَا سَعِيدُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Hasan,takhreej: «سنن الترمذی/الأضاحي ۲۳ (۱۵۲۲)، سنن ابی داود/الضحایا ۲۱ (۲۸۳۷،۲۸۳۸)، سنن النسائی/العقیقة ۴ (۴۲۲۵)،(تحفة الأشراف:۴۵۸۱)، وقد أخرجہ: صحیح البخاری/العقیقة ۲ (۵۴۷۲)، مسند احمد (۵/۷،۸،۱۲،۱۷،۱۸،۲۲)، سنن الدارمی/الأضاحي ۹ (۲۰۱۲),3165,,Chapters on Slaughtering
3166,حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، ‏‏‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۸۳۲),3166,,Chapters on Slaughtering
3167,حَدَّثَنَا أَبُو بِشْرٍ بَكْرُ بْنُ خَلَفٍ، ‏‏‏‏‏‏حَدَّثَنَا يَزِيدُ بْنُ زُرَيْعٍ، ‏‏‏‏‏‏عَنْ خَالِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الضحایا ۱۰ (۲۸۱۳)،۲۰ (۲۸۳۰)، سنن النسائی/الفرع والعتیرة ۱ (۴۲۳۵)،(تحفة الأشراف:۱۱۵۸۶)، وقد أخرجہ: مسند احمد (۵/۷۵،۷۶)، سنن الدارمی/الأضي ۶ (۲۰۰۱),3167,,Chapters on Slaughtering
3168,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَهِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/العقیقة ۴ (۵۴۷۴)، صحیح مسلم/الأضاحي ۶ (۱۹۷۶)، سنن ابی داود/الأضاحي ۲۰ (۲۸۳۱)، سنن النسائی/الفرع والعتیرة (۴۲۲۷)،(تحفة الأشراف:۱۳۱۲۷)، وقد أخرجہ: سنن الترمذی/الأضاحي ۱۵ (۱۵۱۲)، مسند احمد (۲/۲۳۹،۲۵۴،۲۸۵)، سنن الدارمی/الأضاحي ۸ (۲۰۰۷),3168,,Chapters on Slaughtering
3169,حَدَّثَنَا مُحَمَّدُ بْنُ أَبِي عُمَرَ الْعَدَنِيُّ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۶۴۸، ومصباح الزجاجة:۱۰۹۶),3169,,Chapters on Slaughtering
3170,حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْوَهَّابِ، ‏‏‏‏‏‏حَدَّثَنَا خَالِدٌ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الصید ۱۱ (۱۹۵۵)، سنن ابی داود/الأضاحي ۱۲ (۲۸۱۵)، سنن الترمذی/الدیات ۱۴ (۱۴۰۹)، سنن النسائی/الضحایا ۲۱ (۴۴۱۰)،۲۶ (۴۴۱۹)،(تحفة الأشراف:۴۸۱۷)، وقد أخرجہ: مسند احمد (۴/۱۲۳،۱۲۴،۱۲۵)، سنن الدارمی/الأضاحي۱۰ (۲۰۱۳),3170,,Chapters on Slaughtering
3171,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ حَدَّثَنَا عُقْبَةُ بْنُ خَالِدٍ عَنْ مُوسَى بْنِ مُحَمّ,Al-Albani: Very Daif Isnaad; Muhammad Fouad Abd al-Baqi: Very Daif Isnaad; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۲۹۳، ومصباح الزجاجة:۱۰۹۷),3171,,Chapters on Slaughtering
3172,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الرَّحْمَنِ، ‏‏‏‏‏‏ابْنُ أَخِي حُسَيْنٍ الْجُعْفِيِّ، ‏‏‏‏‏‏حَدَّثَ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۹۰۵، ومصباح الزجاجة:۱۰۹۸)، وقد أخرجہ: مسند احمد (۲/۱۰۸),3172,,Chapters on Slaughtering
3173,حَدَّثَنَا عَمْرُو بْنُ عَبْدِ اللَّهِ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏عَنْ إِسْرَائِيلَ، ‏‏‏‏‏‏عَن,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الأضاحي ۱۳ (۲۸۱۸)،(تحفة الأشراف:۶۱۱۱)، وقد أخرجہ: سنن النسائی/الضحایا ۴۰ (۴۴۴۸),3173,,Chapters on Slaughtering
3174,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ سُلَيْمَانَ، ‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۷۰۲۷)، وقد أخرجہ: صحیح البخاری/البیوع ۵ (۲۰۵۷)، الصید ۲۱ (۵۵۰۷)، التوحید ۱۳ (۷۳۹۸)، صحیح مسلم/الأضاحي ۵ (۱۹۷۱)، سنن ابی داود/الأضاحي ۱۹ (۲۸۲۹)، سنن النسائی/الضحایا ۳۸ (۴۴۴۱)، موطا امام مالک/الذبائح ۱ (۱)، سنن الدارمی/الأضاحي ۱۴ (۲۰۱۹),3174,,Chapters on Slaughtering
3175,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو الْأَحْوَصِ، ‏‏‏‏‏‏عَنْ عَاصِمٍ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الضحایا ۱۷ (۲۸۲۲)، سنن النسائی/الصید ۲۵ (۴۳۱۸)، الضحایا ۱۹ (۴۴۰۴)،(تحفة الأشراف:۱۱۲۲۴)، وقد أخرجہ: مسند احمد (۲/۱۲،۷۶،۸۰),3175,,Chapters on Slaughtering
3176,حَدَّثَنَا أَبُو بِشْرٍ بَكْرُ بْنُ خَلَفٍ، ‏‏‏‏‏‏حَدَّثَنَا غُنْدَرٌ، ‏‏‏‏‏‏حَدَّثَنَا شُعْبَةُ، ‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih Lighairihi; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن النسائی/الضحایا ۱۷ (۴۴۰۵)،۲۳ (۴۴۱۲)،(تحفة الأشراف:۳۷۱۸)، وقد أخرجہ: مسند احمد (۴/۱۸۴),3176,,Chapters on Slaughtering
3177,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، ‏‏‏‏‏‏حَدَّث,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Hasan,takhreej: «سنن ابی داود/الضحایا ۱۵ (۲۸۲۴)، سنن النسائی/الذبائح ۲۰ (۴۳۰۹)، الضحایا ۱۸ (۴۴۰۶)،(تحفة الأشراف:۹۸۷۵)، وقد أخرجہ: مسند احمد (۴/۲۵۶،۲۵۸),3177,,Chapters on Slaughtering
3178,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، ‏‏‏‏‏‏حَدَّثَنَا عُمَرُ بْنُ عُبَيْدٍ الطَّن,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الشرکة ۳ (۲۴۸۸)،۱۶ (۲۵۰۷)، الجہاد ۱۹۱ (۳۰۷۵)، الذبائح ۱۵ (۵۴۹۸)،۱۸ (۵۵۰۳)،۲۰ (۵۵۰۶)،۲۳ (۵۵۰۹)،۳۶ (۵۵۴۳)،۳۷ (۵۵۴۴)، صحیح مسلم/الاضاحی ۴ (۱۹۶۸)، سنن ابی داود/الأضاحي ۱۵ (۲۸۲۱)، سنن الترمذی/الصید ۱۹ (۱۴۹۲)، سنن النسائی/الذبائح ۱۷ (۴۳۰۲)، الضحایا ۱۵ (۴۳۹۶)،۲۶ (۴۴۱۴)،(تحفة الأشراف:۳۵۶۱)، وقد أخرجہ: مسند احمد (۳/۴۶۳،۴۶۴،۴/۱۴۰،۱۴۲),3178,,Chapters on Slaughtering
3179,حَدَّثَنَا أَبُو كُرَيْبٍ، ‏‏‏‏‏‏حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِيَةَ، ‏‏‏‏‏‏حَدَّثَنَا هِلَالُ بْن,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن ابی داود/الطہارة ۷۳ (۱۸۵)،(تحفة الأشراف:۴۱۵۸),3179,,Chapters on Slaughtering
3180,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا خَلَفُ بْنُ خَلِيفَةَ، ‏‏‏‏‏‏ح وحَدَّث,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۳۴۶۲)، وقد أخرجہ: صحیح مسلم/الأشربة ۲۰ (۲۰۳۸)، سنن الترمذی/الزہد ۳۹ (۲۳۶۹),3180,,Chapters on Slaughtering
3181,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الرَّحْمَنِ الْمُحَارِبِيُّ، ‏‏‏‏‏‏عَنْ ي,Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۶۲۷، ومصباح الزجاجة:۱۱۰۰),3181,,Chapters on Slaughtering
3182,حَدَّثَنَا هَنَّادُ بْنُ السَّرِيِّ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدَةُ بْنُ سُلَيْمَانَ، ‏‏‏‏‏‏عَنْ عُبَيْدِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الوکالة ۴ (۲۳۰۴)، الذبائح ۱۸ (۵۵۰۱،۵۵۰۲)،۱۹ (۵۵۰۴،۵۵۰۵)،(تحفة الأشراف:۱۱۱۳۴)، وقد أخرجہ: مسند احمد (۲/۷۶،۳/۴۵۴،۶/۳۸۶),3182,,Chapters on Slaughtering
3183,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، ‏‏‏‏‏‏حَدَّثَنَا عُمَرُ بْنُ عُبَيْدٍ، ‏‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «انظر حدیث رقم:(۳۱۳۷)،(تحفة الأشراف:۳۵۱۶),3183,,Chapters on Slaughtering
3184,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏عَنْ حَمَّادِ بْنِ سَلَ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الأضاحي ۱۶ (۲۸۲۵)، سنن الترمذی/الصید ۱۳ (۱۴۸۱)، سنن النسائی/الضحایا ۲۴ (۴۴۱۳)،(تحفة الأشراف:۱۵۶۹۴)، وقد أخرجہ: مسند احمد (۴/۳۳۴)، سنن الدارمی/الأضاحي ۱۲ (۲۰۱۵),3184,,Chapters on Slaughtering
3185,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَعَبْدُ اللَّهِ بْنُ سَعِيدٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏,Al-Albani: Very Daif Isnaad; Muhammad Fouad Abd al-Baqi: Very Daif Isnaad; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۲۹۴، ومصباح الزجاجة:۱۱۰۱),3185,,Chapters on Slaughtering
3186,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏عَنْ شُعْبَةَ، ‏‏‏‏‏‏عَنْ هِشَامِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الصید ۲۵ (۵۵۱۳)، صحیح مسلم/الصید ۱۲ (۱۹۵۶)، سنن ابی داود/الأضاحي ۱۲ (۲۸۱۶)، سنن النسائی/الضحایا ۴۰ (۴۴۴۴)،(تحفة الأشراف:۱۶۴۰)، وقد أخرجہ: مسند احمد (۳/۱۱۷،۱۷۱،۱۹۱),3186,,Chapters on Slaughtering
3187,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏ح وحَدَّثَنَا أَبُو بَكْرِ بْنُ خ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن الترمذی/الصید ۹ (۱۴۷۵)،(تحفة الأشراف:۶۱۱۲)، وقد أخرجہ: صحیح مسلم/الصید ۱۲ (۱۹۵۷)، سنن النسائی/الضحایا ۴۰ (۴۴۴۸)، مسند احمد (۱/۲۱۶،۲۷۳،۲۸۰،۲۸۵،۲۹۷،۳۴۰،۳۴۵),3187,,Chapters on Slaughtering
3188,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏أَنْبَأَنَا ابْن,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الصید ۱۲ (۱۹۵۹)،(تحفة الأشراف:۲۸۳۱)، وقد أخرجہ: مسند احمد (۳/۳۱۸،۳۳۹،۵/۴۲۲،۴۲۳),3188,,Chapters on Slaughtering
3189,حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، ‏‏‏‏‏‏حَدَّثَنَا ابْنُ أَبِي زَائِدَةَ، ‏‏‏‏‏‏عَنْ مُحَمَّدِ بْنِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الجہاد ۵۲ (۳۷۸۵)، سنن الترمذی/الأطعمة ۲۴ (۱۸۲۴)،(تحفة الأشراف:۷۳۸۷)، وقد أخرجہ: مسند احمد (۱/۲۱۹،۲۲۶،۲۴۱،۲۵۳،۳۲۱),3189,,Chapters on Slaughtering
3190,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏عَنْ هِشَامِ بْنِ عُرْو,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الصید ۲۴ (۵۵۱۰ و ۵۵۱۱)،۲۷ (۵۵۱۹)، صحیح مسلم/الصید ۶ (۱۹۴۲)، سنن النسائی/الضحایا ۲۲ (۴۴۱۱)،۳۲ (۴۴۲۵،۴۴۲۶)،(تحفة الأشراف:۱۵۷۴۶)، وقد أخرجہ: مسند احمد (۶/۳۴۵،۳۴۶،۳۵۳)، سنن الدارمی/الأضاحي ۲۲ (۲۰۳۵),3190,,Chapters on Slaughtering
3191,حَدَّثَنَا بَكْرُ بْنُ خَلَفٍ أَبُو بِشْرٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو عَاصِمٍ، ‏‏‏‏‏‏حَدَّثَنَا ابْنُ ج,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الصید ۶ (۱۹۴۱)، سنن النسائی/الذبائح ۲۹ (۴۳۳۲)،(تحفة الأشراف:۲۸۱۰)، وقد أخرجہ: صحیح البخاری/المغازي ۳۸ (۴۲۱۹)، الصید ۲۷ (۵۵۲۰)،۲۸ (۵۵۲۴)، سنن ابی داود/الأطعمة ۲۶ (۳۷۸۸)،۳۴ (۳۸۰۸)، سنن الترمذی/الأطعمة ۵ (۱۷۹۳)، مسند احمد (۳/۳۲۲،۳۵۶،۳۶۱،۳۶۲،۳۸۵)، سنن الدارمی/الأضاحي ۲۲ (۲۰۳۶),3191,,Chapters on Slaughtering
3192,حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، ‏‏‏‏‏‏حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ، ‏‏‏‏‏‏عَنْ أَبِي إِسْحَاق,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/المغازي ۳۸ (۴۲۲۰)، الصید ۲۸ (۱۹۳۷)، صحیح مسلم/الصید ۵ (۴۳۷)، سنن النسائی/الصید ۳۱ (۴۳۴۴)،(تحفة الأشراف:۵۱۶۴)، وقد أخرجہ: مسند احمد (۴/۳۵۵،۳۵۶،۳۵۷،۳۸۱),3192,,Chapters on Slaughtering
3193,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا زَيْدُ بْنُ الْحُبَاب، ‏‏‏‏‏‏عَنْ مُعَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۵۵۴، ومصباح الزجاجة:۱۱۰۲)، وقد أخرجہ: مسند احمد (۴/۸۹،۱۳۲),3193,,Chapters on Slaughtering
3194,حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، ‏‏‏‏‏‏حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ، ‏‏‏‏‏‏عَنْ عَاصِمٍ، ‏‏‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/المغازي ۳۸ (۴۲۲۶)، الصید ۲۸ (۵۵۲۵،۵۵۲۶)، صحیح مسلم/الصید ۵ (۱۹۳۸)، سنن النسائی/الصید والذبائح ۳۱ (۴۳۴۳)،(تحفة الأشراف:۱۷۷۰)، وقد أخرجہ: مسند احمد (۴/۲۹۷),3194,,Chapters on Slaughtering
3195,حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، ‏‏‏‏‏‏حَدَّثَنَا الْمُغِيرَةُ بْنُ عَبْدِ الرَّحْمَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/المظالم ۳۲ (۲۴۷۷)، صحیح مسلم/الجہاد ۴۳ (۱۸۰۲)،(تحفة الأشراف:۴۵۴۲)، وقد أخرجہ: مسند احمد (۴/۴۸،۵۰),3195,,Chapters on Slaughtering
3196,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الرَّزَّاقِ، ‏‏‏‏‏‏أَنْبَأَنَا مَعْمَرٌ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الجہاد ۱۳۰ (۲۹۹۱)، المغازي ۳۸ (۴۱۹۸)، الذبائح ۲۸ (۵۵۲۸)، سنن النسائی/الطہارة ۵۵ (۶۹)، الصیدوالذبائح ۳۱ (۴۳۴۵)،(تحفة الأشراف:۱۴۵۷)، وقد أخرجہ: صحیح مسلم/الصید ۶ (۱۹۴۱)، مسند احمد (۳/۱۱۱،۱۲۱،۱۶۴)، سنن الدارمی/الأضاحي ۲۱ (۲۰۳۴),3196,,Chapters on Slaughtering
3197,حَدَّثَنَا عَمْرُو بْنُ عَبْدِ اللَّهِ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏عَنْ سُفْيَانَ، ‏‏‏‏‏‏ح وحَد,Al-Albani: Sahih Isnaad; Muhammad Fouad Abd al-Baqi: Sahih Isnaad; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن النسائی/الصید ۲۹ (۴۳۳۵)،(تحفة الأشراف:۲۴۳۰),3197,,Chapters on Slaughtering
3198,حَدَّثَنَا مُحَمَّدُ بْنُ الْمُصَفَّى، ‏‏‏‏‏‏حَدَّثَنَا بَقِيَّةُ، ‏‏‏‏‏‏حَدَّثَنِي ثَوْرُ بْنُ يَزِ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الأطعمة ۲۶ (۳۷۹۰)، سنن النسائی/الذبائح ۳۰ (۴۳۳۶)،(تحفة الأشراف:۳۵۰۵)، وقد أخرجہ: مسند احمد (۴/۸۹،۹۰),3198,,Chapters on Slaughtering
3199,حَدَّثَنَا أَبُو كُرَيْبٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ، ‏‏‏‏‏‏ وَأَبُو خَالِدٍ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: سنن ابی داود/الأضاحي ۱۸ (۲۸۲۷)، سنن الترمذی/الأطعمة ۲ (۱۴۷۶)،(تحفة الأشراف:۳۹۸۶)، وقد أخرجہ: مسند احمد (۲/۳۱،۳۹،۵۳),3199,,Chapters on Slaughtering
