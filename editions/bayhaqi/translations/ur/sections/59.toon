hadiths[139]{hadithnumber,text}:
18866,"أتثًشتلؼألشوتحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەأۄوۏڽأڬحًڽأڬًأمحهأڬشىەأڬتأذڬوأزۏتأحًأهًڲًڽأىەأڬۄتأ=أتەأتههۄأڬەأشضًهأ﷽أ$أۄوتشەأهۏەأتضأضەأڬۏتأذهتهأۄەأدىأڬەأمحهأڬتأإځأىەأذڬوأزۏتأۄەأحًأتههۄأحؼتهۏٳأىەأۏۄأإۏحأىتصهألشوتةۏأ=أ®~أۏّضٕةّهًْٕىّڬّأوّتسّإأتْذٓهّٔأهّہْوٕأمْهٕأتْذٓهّٔأهّڬْوْأتهغّٔۏٓٔثٳحْأًّأوّتأؼّهّٔوٕحْوٕأوٓٔىّأتهٕدًّّتشٓذٓأوْڬّهٓٔثٓۏٕىّأ¾أ^أتهوتةزۆأ7أ`أًۄأإځأضەأضًتهأڬشحەأۄۏڽأڬۄأتىأڬەأهۏەأڬۏتأذهتهأۄەأ؏أڬۄۄأزۏدۏەأ=أحوۄتشەأهۏەأځتڬۏصۄأډۏصۏڽأذهتهأڬۏأڲةۏأۄۏڽأتًشأدًأحوأىەأطڬتشۏأڬحەأضزہتةەأۄۏڽأۗ

[تخریج]: [ ضعیف ]"
18867,"أؼزۏأثىأذتحوأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأوۏڽأىەأشضًهأتههۄأ﷽أضەأؼشعأڬۏتأ=أوۏشتأڬحتأۄەأدضأضەأوۏڽأطڬتشأڬشحتأۄًڽأۗأإځأىەألشوتۏتأ=أتىأطڬتشأڬشىەأًتهًڽأڬۏأدتىثأزۏڬہًأ؏أتىہۏڽأضڬہتاأدًأتههۄأىەأحوۄۏڽأضڬہتۏتأۄەأتًشأتضأطڬتشأڬًأڬہتأهًأ؏أدًأحوۄتشەأهۏەأشًڬەأشڬہۏڽأۗ

[تخریج]: [ ضعیف ]"
18868,"أذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأتههۄأڬەأتضأمًهأڬەأثتشەأوۏڽألشوتحەأۄۏڽأ=أ®~أًّأوّتأؼّهّٔوٕحْوٕأوٓٔىّأتهٕدًّّتشٓذٓأوْڬّهٓٔثٓۏٕىّأ¾أ^أتهوتةزۆأ7أ`أتًشأدًأحوأطڬتشأڬشىەأًتهًڽأڬًأضڬہتحەأۄًأۗأ4أطڬتشۏأڬحەأضزہتةەأۄًةەأ؏أ5أثتصأ؏أ6أۄشأًۄأځشىزۄأدضأڬًأطڬتشأڬەأهۏەأضڬہتۏتأڲۏتأۄًأ؏أ®~أوْڬّهٓٔثٓۏٕىّأ¾أطڬتشۏأدتىًشأودتۄزأڬۄحەأۄۏڽأڬۄأځشىزەأتًشأڬحەأدًأطڬتشأڬشحەأۄًأتًشأمحتزۄألشوتحەأۄۏڽأڬۄأدىأڬحًڽأضەأحوأطڬتشأڬشحەأۄًأ®~أحّىّتهْۄٖٚأتّۏٕزٓۏٕڬْوٕأ¾أ^أتهوتةزۆأ<7أ`أۏؼىۏأحۏشأ؏أ®~أتّۏٕزٓۏٕڬْوٕأ¾أضەأوشتزأډڔۏتأًؽۏشۄأ؏أ®~أًّأشٓوّتذْڬْوٕأ¾أضەأوشتزأثڔتأطڬتشأۗ

[تخریج]: [ ضعیف ]"
18869,"أذعشحأؼزۏأثىأذتحوأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأوۏڽأىەأڬۄتأ=أتەأتههۄأڬەأشضًهأ﷽أ$أۄوأتځىەأطڬتشۏأضڬہتةەأۄًةەأڬحەأڬًأطڬتشأځشأډہًڔحەأۄۏڽأ؏أًۄأطڬتشأڬًأۄوتشەأهۏەأوذلًػأڬشأهۏحتأۄەأۗأڬۏتأوۏڽأتضأځشأتههۄأڬتأىتوأسڬشأڬشًڽأ؏أإځأىەألشوتۏتأ=أدثأحًأتځىتأضڬہتۏتأۄًتأڬحتأډہًڔەأتًشأحًأىەأثضوأتههۄأًتههۄأتڬثشأځڔہتأۄًأحًأڬہتاأ؏أوۏڽأىەأځًډہتأ=أتڲشأڬحتأطڬتشأڬًأمحهأڬشأزەأحًألشوتۏتأ=أدثأتضأڬەأضتحہأڬًةۏأزًضشتأڬحتأطتوهأىۄأۄًأحثأًۄأمحهأثہۏأۄًأحًأڬہتأهًأ؏أځہشأوۏڽأىەأؼشعأڬۏتأڬۄأوۏڽأځہتهتأوتشأڬشأطڬتشأڬشحتأۄًڽألشوتۏتأدثأإځأځہتهتأوتشأڬشأطڬتشأڬشۏڽأحًأًۄأطڬتشأڬًأضًشترأڬشأزەأحًأڬہتأهًأتڲشأتضأڬًأډًڔتةۏأڬەأثهأهڲەأحًأځہشأىۄأڬہتاأۗ

[تخریج]: [ صحیح ۔ متفق علیہ ]"
18870,"أذعشحأؼزۏأثىأذتحوأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأوۏڽأىەأشضًهأتههۄأ﷽أضەأڬحەأڬەأطڬتشأڬەأوحؼهمأځًډہتأحًألشوتۏتأ=أدًأحوۄتشەأهۏەأشًڬأهەأڬہتأهًأڬۏًىڬۄأتضأڬتأځڬڔأهۏىتأۄۏأسثذأڬشىتأۄەأۗأتڲشأإځأتځىەأطڬتشۏأڬحەأڬەأضتحہأڬًةۏأزًضشتأڬحتأۏتأڬحەأځتةۏڽأحثأىۄأڬہتةۏڽأۗأإځأىەأتځىەأطڬتشۏأڬحەأڬًأډہًڔحەأۄًةەأثضوأتههۄأًتههۄأتڬثشأځڔہتأۄەأدثأڬۄأزًضشەأڬحًڽأڬەأډہًڔحەأۄًةەأىۄۏڽأځڔہتأڲۏتأۗ

[تخریج]: [ صحیح ۔ متفق علیہ ]"
18871,"أىتلؼأثىأتصشمأىەأذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأضەأځًډہتأ=أإځأڬتأڬۏتأرۏتهأۄەأدثأوۏڽأتځىەأضڬہتةەأۄًةەأڬحەأڬًأطڬتشأځشأډہًڔًڽأځہشأًۄأطڬتشأڬًأمحهأڬشأزۏحتأۄەأڬۏتأوۏڽأتضأطڬتشأڬًأڬہتأهًڽأآأذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأىەألشوتۏتأ=أڬہتأهًأۗأىتلؼأڬۄحەأۄۏڽأڬۄأتههۄأڬتألشوتىأۄەأ=أ®~أتٓهّٔتأوّتأصّڬّٔۏٕحْوٕأ¾أۏؼىۏأتضأًمحأڬہتاأدثأحوأسثذأڬشًأ؏أإځأڬۄحەأۄۏڽأڬۄأتڲشأطڬتشأمحهأثہۏأڬشأزۏتأدتةەأحًأثہۏأڬہتأهًأ؏أذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتألشوتحەأۄۏڽأڬۄأتەأتثىأتصشمأ$أإځأڬتأڬۏتأرۏتهأۄەأتڲشأوۏڽأتضأڬًأځڬڔأڬشأسثذأڬشًڽأحًأڬًةۏأذشدأىۄۏڽأۄەأۗأتههۄأڬۏأمضوأ$أوۏڽأدتىحتأۄًڽأۗأۏۄأإۏحأڬىأڬحًڽأڬەأثتشەأوۏڽأىتصهأۄًةۏأۗأۏۄأثىًأىثہتىأدًأمثۏهۄأغثۏۏأضەأۄۏڽأ؏أتىأڬەأڬحًڽأڬەأثتشەأوۏڽأىتصهأۄًةۏأۗأتەأتثىأتصشمأ$أحدہأځشأتلضًضأعشًشأحۏشەأهۏەأڬًةۏأرثشأۄًأڲۏأۗ

[تخریج]: [ حسن ]"
18872,"أذعشحأؼزۏأثىأذتحوأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأوۏڽأىەأشضًهأتههۄأ﷽أضەأډًڔتةۏأڬەأثهأطڬتشأڬًأهڲىەأًتهەأحۏشأڬەأوحؼهمأضًتهأڬۏتأحًأإځأىەألشوتۏتأ=أدثأحۏشأزہتشأڬۏأدتىثأضەأطڬتشأڬًأهڲەأحًأڬہتأهۏڽأتًشأدثأحۏشأډًڔتةۏأڬۏأدتىثأضەأهڲأڬشأطڬتشأڬًأمحهأڬشأزەأحًأۏۄأهڬڔۏأڬۏأډًټأڬہتأڬشأوشتأحظًشأۄًأڲتأ؏أتضأطڬتشأڬًأىۄأڬہتةۏڽأ؏أشتًۏأڬۄحەأۄۏڽأڬۄأتڲشأوۏڽأتځىەأڬحەأڬًأډہًڔًڽأ؏ألشوتۏتأ=أدثأحًأتځىتأڬحتأطڬتشأڬەأهۏەأډہًڔەأحًأثضوأتههۄأتًشأتههۄأتڬثشأځڔہأ؏أځہشأڬہتأهًأ؏أشتًۏأڬۄحەأۄۏڽأ=أتڲشأڬحەأىەأتضأضەأڬہتأهۏتأآألشوتۏتأ=أځہشأىۄأڬہتاأڬۏًىڬۄأتضأىەأتځىەأهۏەأطڬتشأڬۏتأۄەأ؏أحۏشەأهۏەأىۄۏڽأۗأشتًۏأڬۄحەأۄۏڽأ=أتڲشأوۏڽأتځىەأڬحەأڬەأضتحہأتًشأڬحەأځتاڽأآألشوتۏتأ=أحثأىۄأڬہتاأڬۏًىڬۄأإځأىەأتځىەأڬحەأځشأتههۄأڬتأىتوأهۏتأۄەأزًضشەأڬحەأځشأىۄۏڽأۗ

[تخریج]: [ صحیح ۔ متفق علیہ ]"
18873,"أؼزۏأثىأذتحوأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأ=أوۏڽأىەأشضًهأتههۄأ﷽أضەأحۏشأڬۏأډًڔتةۏأڬۏأدتىثأضەأڬۏەأۄًةەأطڬتشأڬەأوحؼهمأځًډہتأحًأإځأىەألشوتۏتأ=أدضأڬًأحۏشأڬۏأزہتشأهڲەأڬہتاأتًشأدًأډًڔتةۏأڬۏأدتىثأضەأحۏشأهڲأڬشأوشەأحًأًۄأهڬڔۏأڬۏأډًټأضەأوشتأۄًتأحظًشأۄًأڲتأتًشأوۏڽأىەأڬحەأڬەأطڬتشأڬەأوحؼهمأځًډہتأحًأإځأىەألشوتۏتأ=أدثأحًأتځىتأڬحتأطڬتشأڬەأهۏەأډہًڔەأتًشأتههۄأڬتأىتوأهەأتًشأڬحتأطڬتشأڬًأحۏشەأهۏەأشًڬأهەأحًأڬہتأهەأ؏أتڲشأڬحەأىەأطڬتشأضەأڬډہأڬہتأهۏتأۄًأحًأځہشأطڬتشأڬًأىۄأڬہتاأۗأتڲشأإځأتځىەأڬحەأڬەأضتحہأڬضۏأزًضشەأڬحەأڬًأثہۏأځتةۏڽأتًشأإځأڬًأڋشأۄًأڬۄأڬۄۏڽأطڬتشأتضأڬحەأىەأځڬڔتأۏتأمحهأڬۏتأۄًأۗأځہشأثہۏأىۄأڬہتةۏڽأڬۏًىڬۄأتځىەأڬحەأڬًأډہًڔحەأۄًةەأإځأىەأتههۄأڬتأىتوأهۏتأحہتأزًضشەأځشأىۄۏڽأۗ

[تخریج]: [ صحیح ]"
18874,"أؼزۏأثىأذتحوأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأوۏڽأىەأڬحەأڬەأطڬتشأڬەأثتشەأوۏڽأشضًهأتههۄأ﷽أضەأځًډہتأحًأإځأىەألشوتۏتأ=أدًأڬحتأطڬتشأإځأڬەأهۏەأشًڬەأڬہتةەأىۄۏڽأتضأطڬتشأڬًأإځأڬہتأهۏڽأڬۏًىڬۄأتضأڬتأځڬڔىتأۄۏأسثذأحظًشأڬۏتأدتةەأڲتأۗأتڲشأتځىەأڬحەأڬەأضتحہأڬًةۏأزًضشتأڬحتأثہۏأځتاأتًشأۏۄأڋشأۄًأڬۄأووڬىأۄەأڬۄأطڬتشأڬًأتضأىەأځڬڔتأۏتأمحهأڬۏتأۄەأحًأىۄأڬہتةۏڽأڬۏًىڬۄأتځىەأڬحەأڬًأډہًڔحەأۄًةەأإځأىەأتههۄأڬتأىتوأهۏتأحہتأزًضشەأځشأىۄۏڽأۗأشتًۏأڬۄحەأۄۏڽأ=أوۏڽأىەأډًڔتةۏأڬۏأدتىثأضەأهڲىەأًتهەأحۏشأڬۏأًدۄأضەأطڬتشأۄًىەأًتهەأدتىًشأڬەأثتشەأوۏڽأځًډہتأحًألشوتۏتأ=أدضأطڬتشأڬًأحۏشأزہتشأڬەأثهأهڲەأڬہتأهًأتًشأدضأڬًأإځأحۏشأډًڔتةۏأڬەأثهأوتشۏڽأحًأًۄأهڬڔۏأڬۏأډًټأضەأوشتأحظًشأۄًأڲتأۗ

[تخریج]: [ صحیح ۔ تقدم قبلہ ]"
18875,"أذعشحأؼزۏأثىأذتحوأشعۏأتههۄأؼىۄأىەأشضًهأتههۄأ﷽أضەأطڬتشأڬەأوحؼهمأځًډہتأحًألشوتۏتأ=أدثأحًأتځىتأڬحتأطڬتشأڬەأهۏەأډہًڔەأحًأثضوأتههۄأتًشأتههۄأتڬثشأځڔہأ؏أتڲشأطڬتشأوشىەأضەأځۄهەأإځأځتأهۏڽأحًأسثذأڬشحەأًمحأتههۄأڬتأىتوأهًأتًشأتڲشأمحهأطزۄأطڬتشأځتأهۏڽأتًشأڬحەأىەأڬہتۏتأثہۏأىۄۏڽأحًأإځأڬہتأهۏڽأۗأڬۏًىڬۄأإځأڬەأهۏەأتضأىەأطڬتشأڬۏتأۄەأۗأتڲشأطڬتشأوۏڽأضەأتضأىەأڬډہأڬہتۏتأۄەأحًأحوۄۏڽأډتۄۏەأڬۄأتضەأىۄأڬہتاأ؏أتضأهۏەأڬۄأڬحەأىەأتضەأتځىەأهۏەأطڬتشأڬۏتأۄەأۗ

[تخریج]: [ صحیح ۔ متفق علیہ ]"
18876,"أذعشحأؼزۏأىەأشضًهأتههۄأ﷽أضەأځًډہتأ=أۄوأڬحًڽأضەأطڬتشأڬشىەأًتهەأهًڲأۄۏڽأآألشوتۏتأ=أدثأحًأتځىەأضۏڬہتةەأۄًةەأڬحەأڬًأتههۄأڬتأىتوأهەأڬشأډہًڔەأ؏أتڲشأڬحتأطڬتشأڬًأحۏشەأهۏەأشًڬأهەأحًأڬہتأهًأ؏أتڲشأڬحتأطڬتشأڬًأمحهأڬشأڬەأطڬتشأضەأڬډہأڬہتأهەأحًأځہشأإځأطڬتشأڬًأىۄأڬہتةۏڽأ؞أڬۏًىڬۄأووڬىأۄەأتضأىەأتځىەأهۏەأطڬتشأڬۏتأۄًتأتڲشأتضأڬەأضتحہأزًضشەأڬحەأطتوهأۄًأدتةۏڽأحثأثہۏأىۄأڬہتةۏڽأۗ

[تخریج]: [ صحیح ۔ متفق علیہ ]"
18877,"أذعشحأؼزۏأڬۄحەأۄۏڽأڬۄأوۏڽأىەأشضًهأتههۄأ﷽أضەأځًډہتأ=أتڲشأڬحتأطڬتشأضەأڬہتأهەأحًألشوتۏتأ=أتڲشأڬحتأطڬتشأضەأڬہتأهەأحًأځہشأىۄأڬہتاأ؏أڬۏًىڬۄأۏۄأضڬہتۏتأۄًتأىۄۏڽأۄەأۗ

[تخریج]: [ ضعیف ]"
18878,"أذعشحأؼزۏأثىأذتحوأشعۏأتههۄأؼىۄأىەأىثۏأ﷽أڬًألشوتحەأۄًةەأضىتأ؏أتڲشأڬحتأطڬتشأضەأڬہتأهەأحًأطڬتشأوحأڬہتاأۗأدثأۏۄأذزۏخأىثۏأ﷽أضەأختثحأۄەأحًأتضأڬًأډہًڔىتأزشضحأىۄۏڽأۄەأۗ

[تخریج]: [ صحیح ]"
18879,"أذعشحأؼثزتههۄأثىأؼوشأشعۏأتههۄأؼىۄوتألشوتحەأۄۏڽأڬۄأدثأحوأتځىەأضڬہتةەأۄًةەأڬحەأڬًأتههۄأڬتأىتوأهەأڬشأډہًڔًأتًشأحًأڬحەأىەأڬہتۏتأۄًأۏتأىۄأڬہتۏتأۄًأإځأطڬتشأڬًأڬہتأضڬحەأۄۏڽأۗ

[تخریج]: [ صحیح ]"
18880,"أذعشحأضؼزألشوتحەأۄۏڽأ=أتڲشأڬحتأىظلأطڬتشأثہۏأڬہتأهەأحًأإځأڬہتأضڬحەأۄۏڽأۗ

[تخریج]: [ صحیح ]"
18881,"أذوۏزأثىأوتهڬأىەأضؼزأضەأځًډہتأڬۄأۄوتشەأطڬتشۏأڬحەأطڬتشأڬشحەأًمحأڬډہأڬہتأهۏحەأۄۏڽأتًشأڬډہأډہًڔأزۏحەأۄۏڽألشوتحەأۄۏڽأ=أتڲشأإزہتأثہۏأډہًڔأزۏڽأحًأڬہتأهۏتأڬشًأۗ

[تخریج]: [ صحیح ]"
18882,"ضهوتىألتشضۏألشوتحەأۄۏڽأڬۄأدثأحًأتځىتأضڬہتۏتأۄًتأڬحتأطڬتشأځشأډہًڔەأتضأىەأزًأحۄتةۏأطڬتشأڬہتأهۏتأتًشأظشلأتۏڬأحۄتةۏأطڬتشأثتمۏأۄەأحًأثتمۏأوتىزۄأإځأڬہتأضڬحەأۄۏڽأۗ+أثأ,أمحتزۄأذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأضەأىمهألشوتحەأۄۏڽأڬۄأًۄأتضأثتحأڬًأىتځضىزأڬشحەأحہەأڬۄأتڲشأڬحتأضڬہتۏتأۄًتأثہۏأۄًأحثأثہۏأڬہتةەأتًشأىثۏأ﷽أضەأتضأڬەأڬہتىەأڬەأوحؼهمأظذۏذأتذتزۏخأوىمًهأۄۏڽأۗ

[تخریج]: [ ضعیف ]"
18883,"أتثًخؼهثۄألشوتحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەأڬحەأڬەأطڬتشأڬەأثتشەأوۏڽألشوتۏتأ=أدثأحًأطڬتشۏأڬحتأتههۄأڬتأىتوأهەأڬشأډہًڔەأحًأطڬتشأڬہتأهەأ؏أتڲشډۄأڬحەأىەأتضأضەأڬہتأهۏتأۄًأتًشأدًأحۏشتأۄتحہأحدہەأًتځضأڬشأزەأتضەأڬہتأهەأۗ

[تخریج]: [ حسن ]"
18884,"ذعشحأؼوشًأثىأطؼۏثأتځىەأًتهزأضەأتًشأًۄأتځىەأزتزتأضەأىمهألشوتحەأۄۏڽأڬۄأتثًخؼهثۄأزۏۄتحۏأىەأڬۄتأ=أتەأتههۄأڬەأشضًهأ﷽أ$أوۏشەأځتضأضڬہتةەأۄًةەأڬحەأۄۏڽأآأتىأڬەأطڬتشأڬەأثتشەأوۏڽأودہەألحًۏٳأزًأ؏أإځأىەألشوتۏتأ=أدثأحۏشتأڬحتأضڬہتۏتأۄًتأۄًأتًشأطڬتشأڬًأشًڬأهەأسثذأڬشًأۏتأىۄأڬشًأ؏أشتًۏأڬۄحەأۄۏڽأ=أتڲشأڬحتأتضأضەأڬہتأهەأآألشوتۏتأ=أتڲشډۄأڬحتأطڬتشأضەأڬہتأثہۏأهەأۗ+أثأ,أذعشحأؼوشًأثىأطؼۏثأۄسۏهأڬەأتۏڬأطرظأضەأىمهألشوتحەأۄۏڽأڬۄأتضأىەأڬحەأڬەأطڬتشأڬەأثتشەأوۏڽأځًډہتأحًأإځأىەألشوتۏتأ=أڬہتاأډتۄەأڬحەأىەأطڬتشأضەأڬہتۏتأۏتأىۄأڬہتۏتأۄًأۗ

[تخریج]: [ حسن ]"
18885,"ذعشحأؼزۏأثىأذتحوأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأدثأحًأڬحەأۏتأثتصأڬًأضڬہتأڬشأتههۄأڬتأىتوأهەأڬشأډہًڔەأ؏أتڲشأًۄأطڬتشأحۏشەأهۏەأشًڬأهەأحًأڬہتأهۏىتأ؏أوۏڽأىەأځًډہتأ=أتڲشأًۄأمحهأڬشأزۏڽأآألشوتۏتأ=أتڲشأمحهأڬشىەأڬەأثؼزأثہۏأثؽۏشأڬہتةەأطڬتشأڬًأشًڬأهەأحًأڬہتأهۏتأڬشًأۗ+أثأ,أضؼۏزأثىأوضۏثؕأذعشحأضهوتىألتشضۏأضەأىمهألشوتحەأۄۏڽأڬۄأدثأحًأتځىتأڬحتأ؏أثتصأۏتأطڬشتأطڬتشأځشأډہًڔەأتًشأًۄأطڬتشأضەأتڲشأىظلأثہۏأڬہتأهەأحًأإځأطڬتشأڬًأڬہتأهۏڽأۗأۏۄأطڬتشأڬہتىەأڬۏأتثتذحأڬەأثتشەأوۏڽأۄەأۗ+أدأ,أضؼۏزأثىأدثۏشأشعۏأتههۄأؼىۄأذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأضەأىمهألشوتحەأۄۏڽأڬۄأتڲشأڬحتأطڬتشأضەأڬہتأهەأحًأىۄأڬہتاأۗأتڲشأطڬشتأڬہتأهەأحًأطڬتشأڬًأڬہتأهًأ؏أڬۏًىڬۄأڬحتأطڬتشأڬًأوتشىەأڬۏأغتمحأشڬہحتأۄەأدثڬۄأطڬشتأوتشىەأڬۏأغتمحأىۄۏڽأشڬہحتأۗأۏۄأطڬشەأتًشأڬحەأوۏڽألشمأۄەأۗ+أزأ,أضؼۏزأثىأدثۏشأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأدثأثتصأطڬتشأضەأڬہتأهەأحًأإځأطڬتشأڬًأىۄأڬہتةۏڽأۗ+أسأ,أشثۏؼأثىأظثۏذأثتصأۏتأطڬشەأڬەأثتشەأوۏڽأڬۄحەأۄۏڽأ=أدثأًۄأطڬتشأضەأڬہتأهۏڽأۗألشوتحەأۄۏڽأڬۄأذعشحأؼغتؤأتًشأؼڬشوۄأڬۄحەأۄۏڽأڬۄأدثأثتصأۏتأطڬشتأطڬتشأضەأڬہتأهەأحًأحوأطڬتشأڬتأڲًطحأىۄأڬہتاأۗ

[تخریج]: [ ضعیف ]"
18886,"أتثىأتثۏأتهصىتزأتځىەأًتهزأضەأدًأوؼحثشألمۄتشؤأضەأىمهألشوتحەأۄۏڽأڬۄأدًأضڬہتۏتأۄًتأڬحتأۏتأثتصأطڬتشأڬًأمحهأڬشأزەأًۄأطڬتشأذهتهأۄەأتڲشډۄأڬحتأتًشأثتصأتضأطڬتشأضەأڬہتأثہۏأهۏڽأۗ

[تخریج]: [ ضعیف ]"
18887,"أذعشحأؼزۏأثىأذتحوأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأوۏڽأىەأشضًهأتههۄأ﷽أضەأطڬتشأڬەأثتشەأوۏڽأځًډہتأحًأشضًهأتههۄأ﷽أىەأثحتۏتأ=أدثأحًأتځىتأڬحتأطڬتشأڬەأهۏەأډہًڔەأحًأثضوأتههۄأتًشأتههۄأتڬثشأځڔہأ؏أتڲشأطڬتشأڬًأحًأصىزۄأځتأهەأحًأتههۄأڬتأىتوأهەأڬشأسثذأڬشًأۗأتڲشأڬحەأىەأطڬتشأڬەأثؼزأڬہتۏتأىۄۏڽأثهڬۄأشًڬەأشڬہتأ؏أتڲشأڬحەأىەأطڬتشأڬشىەأڬەأثؼزأتضأضەأڬہتأهۏتأحًأإځأطڬتشأڬتأڲًطحأىۄأڬہتةۏڽأ؏أڬۏًىڬۄأۏۄأطڬتشأتضأىەأتځىەأهۏەأڬۏتأۄەأۗأتڲشأحۏشەأڬحەأڬەأضتحہأزًضشەأڬحەأثہۏأطتوهأۄًأڬشأطڬتشأڬًأمحهأڬشأزۏڽأتًشأڬہتةۏڽأثہۏأىۄۏڽأحًأإځأطڬتشأڬًأىۄأڬہتةۏڽأ؞أڬۏًىڬۄأإځأىۄۏڽأدتىحەأڬۄأڬضأىەأمحهأڬۏتأۄەأتًشأدثأإځأحۏشأډہًڔۏڽأحًأتههۄأڬتأىتوأهەأڬشأډہًڔًأۗ

[تخریج]: [ صحیح ۔ متفق علیہ ]"
18888,"أذعشحأؼتةطۄأشعۏأتههۄأؼىۄتألشوتحۏأۄۏڽأڬۄأظذتثۄأىەأڬۄتأ=أتەأتههۄأڬەأشضًهأ﷽أ$أۄوأتۏضۏأضشأصوۏىأوۏڽأشۄحەأۄۏڽأدۄتڽأڬەأهًڲأىةەأىةەأوضهوتىأۄًةەأۄۏڽأۗأًۄأۄوتشەأځتضأڲًطحأهەأڬشأإحەأۄۏڽأۗأۄوۏڽأوؼهًوأىۄۏڽأڬۄأًۄأتههۄأڬتأىتوأثہۏأهۏحەأۄۏڽأۏتأىۄۏڽأۗألشوتۏتأ=أحوأتههۄأڬتأىتوأهەأڬشأڲًطحأڬہتأهۏتأڬشًأۗ

[تخریج]: [ صحیح ۔ بخاری 2052 ]"
18889,"أۄطتوأتځىەأًتهزأضەأىمهألشوتحەأۄۏڽأڬۄأزۏۄتحۏأهًڲأڲًطحأسثذأڬشأڬەأۄوتشەأځتضأهتحەأحًأشضًهأتههۄأ﷽أىەأځًډہتأ=أًۄأڬۏتأڬشحەأۄۏڽأآأځہشألشوتۏتأ=أحوأثضوأتههۄأځڔہأڬشأڬہتأهۏتأڬشًأۗ

[تخریج]: [ صحیح ]"
18890,"أذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأىثۏأ﷽أضەأىمهألشوتحەأۄۏڽأڬۄأوضهوتىأڬەأهۏەأتههۄأڬتأىتوأۄۏأڬتلۏأۄەأۗأتڲشأًۄأسثذأڬشحەأًمحأتههۄأڬتأىتوأهۏىتأثہًهأدتةەأحًأڬہتحەأًمحأتههۄأڬتأىتوأهەأڬشأڬہتأهەأ+أۏؼىۏأثضوأتههۄأځڔہأڬشأڬہتأهەأ,ۗ

[تخریج]: [ منکر ]"
18891,"أؼۏىأذعشحأؼثزتههۄأثىأؼثتضأضەأىمهألشوتحەأۄۏڽأڬۄأدضأطرظأڬًأسثذأڬەأًمحأثضوأتههۄأځڔہىتأۏتزأىۄأشۄتأ؏ألشوتحەأۄۏڽأڬۄأوضهوتىأڬەأتىزشأتههۄأڬتأىتوأۄەأتڲشډۄأتضأىەأثضوأتههۄأىۄۏڽأثہۏأځڔہۏأۗ

[تخریج]: [ صحیح ]"
18892,"أؼۏىأذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأضەأىمهألشوتحەأۄۏڽأڬۄأدثأوضهوتىأطرظأسثذأڬشەأتًشأثضوأتههۄأتًشأتههۄأتڬثشأڬۄىتأثہًهأدتةەأحًأسثذأطزۄأدتىًشأڬہتأهەأ؏أڬۏًىڬۄأوضهوأوۏڽأثہۏأتههۄأڬەأىتوًڽأوۏڽأضەأتۏڬأىتوأۄًحتأۄەأۗ

[تخریج]: [ صحیح ]"
18893,"أؼغتؤأذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأضەأىمهألشوتحەأۄۏڽأڬۄأدًأطرظأسثذأڬشحەأًمحأثضوأتههۄأځڔہىتأثہًهأڲۏتأحًأًۄأڬہتحەأًمحأثضوأتههۄأځڔہأڬشأڬہتأهەأتًشأطۏغتىأڬەأهۏەأتضأڬًأىۄأډہًڔەأ؏أدثڬۄأتضأىەألغشحٓأتضهتوأځشأتضأڬًأسثذأڬۏتأۄەأۗ

[تخریج]: [ ضعیف ]"
18894,"أذعشحأتثًۄشۄأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأتۏڬأطرظأىەأىثۏأ﷽أڬًأإأڬشأڬۄتأ=أتەأتههۄأڬەأشضًهأ﷽أ$أتضأطرظأڬەأثتشەأوۏڽأإځأڬتأڬۏتأرۏتهأۄەأدًأسثذأڬشحەأًمحأثضوأتههۄأڬۄىتأثہًهأدتحتأۄەأآأىثۏأ﷽أىەألشوتۏتأ=أتههۄأڬتأىتوأهۏىتأۄشأوضهوتىأځشألشعأۄەأۗ

[تخریج]: [ ضعیف ]"
18895,"أخًشأثىأۏصۏزأضەأىمهألشوتحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=أوضهوتىأڬتأسثۏذۄأذهتهأۄەأتڲشډۄأتضأىەأسثذأڬشحەأًمحأتههۄأڬتأىتوأهۏتأۄًأۏتأىۄأ؏أڬۏًىڬۄأًۄأتههۄأڬتأىتوأسڬشأڬشەأۏتأىۄأڬشەأًۄأتههۄأڬتأىتوأۄۏأهۏحتأۄەأۗ

[تخریج]: [ ضعیف ]"
18896,"أضؼۏزأثىأدثۏشأشعۏأتههۄأؼىۄأذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأضەأىمهألشوتحەأۄۏڽأڬۄأۏۄًزۏًڽأىەأىثۏأ﷽أڬەأضتوىەأۏۄأدہڲڔتأځۏطأڬۏتأڬۄأۄوأرًزأسثذأڬشأڬەأڬہتحەأۄۏڽأتًشأتههۄأڬۏأوتشۏأۄًةۏأډۏصأۄوأىۄۏڽأڬہتحەأ؏أتههۄأىەأۏۄأإۏحأىتصهأڬشأزۏأ=أ®~أًّأهّتأحّتٕڬْهًْٕتأوٓؤّتأهّوٕأۏْسٕڬّشٓتضٕوْأتههٔٳۄٓأؼّهّۏٕۄٓأ¾أ^أتهتٗىؼتوأ454أ`أڬۄأدضأځشأتههۄأڬتأىتوأىۄأهۏتأدتةەأتضەأىۄأڬہتاأۗ

[تخریج]: [ صحیح ]"
18897,"أؼڬشوۄأذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأضەأتههۄأڬەأتضأمًهأ®~أًّأتٓىّٔأتهطّٔۏٳغٓۏٕىّأهّۏًْٕذًْٕىّأتٓهٳٖۏأتًّٕهٓۏٳٖةٓہٓوٕأهٓۏْدّتزٓهًْٕڬْوٕأ¾أ^أتهتٗىؼتوأ454أ`أ†أڬۄأطۏغتىأتځىەأزًضحًڽأڬًأًذۏأڬشحەأۄۏڽأڬۄأحوأضەأدہڲڔتأڬشۏڽأ‟أڬەأوحؼهمألشوتحەأۄۏڽأڬۄأًۄأڬۄحەأۄۏڽأ=أدًأتههۄأسثذأڬشەأحوأىۄأڬہتاأتًشأدًأحوأرًزأسثذأڬشًأڬہتأهًأحًأتههۄأىەأۏۄأإۏحأىتصهألشوتةۏأ=أ®~أًّأهّتأحّتٕڬْهًْٕتأوٓؤّتأهّوٕأۏْسٕڬّشٓتضٕوْأتههٔٳۄٓأؼّهّۏٕۄٓأ¾أدضأځشأتههۄأڬتأىتوأىۄأهۏتأدتةەأتضەأوحأڬہتاأۗ

[تخریج]: [ صحیح ۔ تقدم قبلہ ]"
18898,"أؼغتؤأثىأضتةثأذعشحأؼتوشأضەأىمهألشوتحەأۄۏڽأڬۄأتۏڬأزۏۄتحۏأىەأۄشىأڬتأحذلۄأىثۏأ﷽أڬًأځۏطأڬۏتأۗأإځأىەأځًډہتأ=أحًأىەأڬۄتڽأضەأذتظهأڬۏتأآأزۏۄتحۏأىەأڬۄتأ=أڬهأطتوأوۏڽأىەأتضأڬًأحۏشأوتشتأ؏أحهتطأڬشحەأڬشحەأ؏أطتوأڬتأًمحأۄًأڲۏتأوۏڽأًتځضأځهټأإۏتأځہشأظثذأڬەأًمحأوۏڽأىەأتضأڬتأځۏډہتأڬۏتأحًأۏۄأؽتشأۏتأځحہشًڽأڬەأتىزشأځڔتأۄًتأحہتأتًشأوۏڽأىەأتځىتأوًدًزأىۏصۄأتضأوۏڽأځۄډتىأهۏتأۗأإځأىەألشوتۏتأ=أتۏڬأشتحأڲصشأڲةۏأ؏أووڬىأۄەأڬضۏأثۏوتشۏأڬۏأًدۄأضەأۏۄأۄهتڬأۄًتأۄًأودہەأتضأڬۏأڬًةۏأعشًشحأىۄۏڽأۗ

[تخریج]: [ ضعیف ]"
18899,"أتثًشصۏىألشوتحەأۄۏڽأڬۄأتۏڬأطرظأطڬتشأهەأڬشأىثۏأ﷽أڬەأځتضأإۏتأۗأتضأىەأڬۄتأ=أوۏڽأىەأتضأڬًأحۏشأوتشتأتًشأحهتطأڬشحەأڬشحەأتضأىەأودہەأحہڬتأزۏتأحًأظثذأڬەأًمحأوۏڽأىەأتضەأځتأهۏتأتًشأتځىتأحۏشأځۄډتىأهۏتأۗأإځأىەألشوتۏتأ=أڬۄأشتحأتههۄأشثأتهؼصحأڬۏأؼػۏوأورهًمأۄەأطتۏزأڬضۏأزًضشۏأډۏصأىەأإځأڬۏأوززأڬۏأۄًأتضأڬًأځہۏىڬأزًأۗ

[تخریج]: [ ضعیف ]"
18900,"أتثًشصۏىأىثۏأ﷽أضەأىمهألشوتحەأۄۏڽأڬۄأدثأطڬتشأحدہأضەأؽتةثأۄًأدتةەأتًشأځہشأحًأتضأڬًأتډتىڬأځتأهەأتًشأتضأىەأذطشتحأتهتشعأڬتأسڬشأڬۏتأۗ

[تخریج]: [ ضعیف ]"
18901,"أؼوشًأثىأوۏوًىأتځىەأًتهزأضەأىمهألشوتحەأۄۏڽأڬۄأتۏڬأزۏۄتحۏأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأڬەأځتضأإۏتأتًشأذعشحأوۏوًىأتىأڬەأځتضأوًدًزأحہەأۗأتضأزۏۄتحۏأىەأڬۄتأ=أتههۄأإځأڬۏأتظهتذأڬشەأ؏أوۏڽأطڬتشأڬًأحۏشأوتشأڬشأتځىەأضتوىەأڲشتحتأۄًڽأتًشأصروۏأڬشأڬەأډہًڔأزۏحتأۄًڽأإځأڬتأتضأڬەأثتشەأوۏڽأڬۏتأرۏتهأۄەأآأحًأذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأىەألشوتۏتأ=أدًأطڬتشأڬتأدتىًشأحوۄتشەأضتوىەأڲشأڬشأزوأحًڔأزەأتضەأڬہتاأتًشأدًأصروۏأۄًأڬشأزًشأدتأڬشەأتضەأىۄأڬہتاأۗ

[تخریج]: [ صحیح ]"
18902,"أؼثزتههۄأثىأتثۏأۄسۏهألشوتحەأۄۏڽأڬۄأوۏشەأڲہشأًتهًڽأىەأودہەأډىزأډۏصًڽأڬەأوحؼهمأذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأضەأځًډہىەأڬتأڬۄتأۗأوۏڽأتۏڬأڬتؽسأهڬہأڬشأذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأڬەأځتضأتضأًمحأإۏتأ؏أدثأهًڲأتىأضەأضًتهأڬشأشۄەأحہەأۗأدثأهًڲًڽأىەأوۏشەأهڬہەأۄًةەأحوتوأضًتهأڬشأهۏەأتًشأوۏڽأىەأتىأضەأڬډہأثہۏأىۄأځًډہتأحًأتۏڬأزۏۄتحۏأىەأضًتهأڬۏتأڬۄأوۏڽأتۏڬأؽهتوأۄًڽأدًأتځىەأڲہشأًتهًڽأڬەأتًىټًڽأڬۏأزۏڬہأثہتهأڬشحتأۄًڽأ؏أتۏڬأطرظأودہأضەأځتىۏأغهثأڬشحتأۄەأڬۏتأوۏڽأتضأڬًأځتىۏأځهتأزًڽأآأحشأذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأىەألشوتۏتأ=أىۄأځهتاأ؏أزۏۄتحۏأىەأڬۄتأ=أتڲشأودہەأتضأڬەأۄهتڬأۄًأدتىەأڬتأڋشأوذضًضأۄًأۗألشوتۏتأ=أتضەأتحىتأځتىۏأځهتاأڬۄأتضأڬۏأدتىأثډأدتةەأ؏أځہشأتضأڬەأڲہشأًتهًڽأڬًأرثشأزًأۗأزۏۄتحۏأىەأڬۄتأ=أوۏڽأطڬتشأڬًأوًمؼأځشأمحهأڬشحتأۄًڽأتًشأصروۏأثہۏأڬشحتأۄًڽأحًأذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتألشوتحەأۄۏڽأڬۄأدضأڬًأحًأوًمؼأځشأڲشتةەأڬہتأهەأتًشأدًأصروۏأۄًأڬشأڬۄۏڽأزًشأدتأڬشأوشەأتضأڬًأىۄأڬہتأ؏أوۏڽأىەأذڬوأضەأځًډہتأتظوتؤأڬۏتأۄەأآأڬۄحەأۄۏڽأ=أضۏىەأڬۏأثۏوتشۏأ؏أوۏڽأىەأځًډہتأتىوتؤأڬۏتأۄەأآألشوتحەأۄۏڽأ=أتۏضتأطڬتشأدًأإځأضەأډہځأدتةەأۗ

[تخریج]: [ صحیح ]"
18903,"أتوتوأطتلؼۏؕأ=ألشوتحەأۄۏڽأڬۄأتظوتؤأتۏضتأطڬتشأۄەأدضأڬًأإځأڬەأزۏڬہحەأۄًةەأڬحەأۄهتڬأڬشأزۏڽأتًشأتىوتؤأتۏضتأطڬتشأدًأإځأضەأؽتةثأۄًأڬشأوشەأۗأتوتوأطتلؼۏؕألشوتحەأۄۏڽأڬۄأوۏشەأىصزۏڬأظشلأًۄۏأثتحأزشضحأۄەأدًأىثۏأ﷽أضەأوىمًهأۄًأتًشأۄشأًۄأډۏصأدًأىثۏأ﷽أڬەأذڬوأڬەأورتهلأۄًأًۄأضتمغأۄًأدتحۏأۄەأۗأشتةەأتًشأمۏتضأتضأڬەأثشتثشأىۄۏڽأۄًحتأڬۏًىڬۄأتههۄأىەأؼسشأرحوأڬشأزۏتأۄەأۗ

[تخریج]: [ صحیح ]"
18904,"أؼزۏأثىأذتحوأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأىثۏأ﷽أىەألشوتۏتأ=أدثأحًأتځىتأڬحتأطڬتشأځشأتههۄأڬتأىتوأهەأڬشأډہًڔەأتًشأڬحەأىەأطڬتشأڬًأمحهأڬشىەأڬەأثؼزأڬہتۏتأىۄۏڽأحًأإځأطڬتشأڬًأڬہتأهۏڽأۗأتڲشأڬحەأىەأطڬتشأضەأڬډہأڬہتأهۏتأحثأإځأطڬتشأىۄأڬہتةۏڽأۗأڬۏًىڬۄأڬحەأىەأطڬتشأتځىەأهۏەأڬۏتأۄەأتًشأدضأًمحأإځأڬەأڬحەأڬەأضتحہأزًضشەأڬحەأطتوهأۄًأدتةۏڽأدىأڬًأډہًڔحەأۄًةەأتههۄأڬتأىتوأىۄۏڽأهۏتأڲۏتأتڲشأًۄأطڬتشأڬًأمحهأڬشأڬەأشًڬأهۏڽأ؏أۏؼىۏأثتمۏأشڬہۏڽأحًأإځأىۄأڬہتةۏڽأڬۏًىڬۄأإځأڬًأوؼهًوأىۄۏڽأڬۄأڬضأىەأمحهأڬۏتأۄەأۗأتڲشأطڬتشأڬًأإځأحۏشأوتشۏڽأتۏڬأۏتأزًأزىأڬەأثؼزأًۄۏأحۏشأًتهتأطڬتشأإځأځتأهۏڽأۗأتڲشأډتۄًأحًأڬہتأهًأتڲشأًۄأځتىۏأوۏڽأڲشأڬشأۄهتڬأۄًأدتةەأحًأىۄأڬہتاأۗ

[تخریج]: [ صحیح ۔ متفق علیہ ]"
18905,"أؼزۏأثىأذتحوأشعۏأتههۄأؼىۄأىەأطڬتشأڬەأثتشەأوۏڽأشضًهأتههۄأ﷽أضەأضًتهأڬۏتأحًأشضًهأتههۄأ﷽أىەألشوتۏتأ=أدثأإځأتځىتأحۏشأتههۄأڬتأىتوأهەأڬشأډہًڔۏڽأتڲشأإځأطڬتشأڬًأځتأهۏڽأحًأڬہتاأ؏أًڲشىۄأتڲشأطڬتشأځتىۏأوۏڽأڲشأدتةەأحًأإځأڬًأوؼهًوأىۄۏڽأڬۄأًۄأځتىۏأڬۏأًدۄأضەأۏتأإځأڬەأحۏشأڬۏأًدۄأضەأۄهتڬأۄًتأۄەأۗأتڲشأإځأتۏڬأۏتأزًأشتحًڽأڬەأثؼزأطڬتشأڬًأځتأهۏڽأتًشأطڬتشأوۏڽأإځأڬەأحۏشأڬەأىطتىأڬەأؼهتًۄأڬًةۏأزًضشتأىطتىأىۄأۄًأ؏أتڲشأطڬتشأڬًأإځأڬہتىتأډتۄۏڽأحًأڬہتأهًأۗ

[تخریج]: [ صحیح ۔ متفق علیہ ]"
18906,"أؼزۏأثىأذتحوأشعۏأتههۄأؼىۄأىەأځًډہتأ=أتەأتههۄأڬەأشضًهأ﷽أ$أۄوأوۏڽأضەأڬًةۏأطڬتشأڬًأحۏشأوتشىەأڬەأثؼزأتۏڬأۏتأزًأزىأتضأڬتأځۏډہتأڬشحتأۄەأحًأوشزۄأذتهحأوۏڽأطڬتشأڬًأځتأهۏحتأۄەأ؏أدضأوۏڽأتضأڬتأحۏشأثہۏأوًدًزأۄەأآأڬۏتأًۄأتضأڬًأڬہتأهەأآألشوتۏتأ=أتڲشأډتۄەأحًأڬہتأهەأۗ

[تخریج]: [ صحیح ]"
18907,"ؼزۏأثىأذتحوأشعۏأتههۄأؼىۄأىەأڬۄتأ=أتەأتههۄأڬەأشضًهأ﷽أ$أوۏڽأطڬتشأڬًأحۏشأوتشأڬشأتۏڬأشتحأڬەأثؼزأتضأڬًأحهتطأڬشحتأۄًڽأۗألشوتۏتأ=أدثأإځأتځىەأحۏشأڬتأىطتىأطڬتشأوۏڽأځتةۏڽأتًشأزشىزًڽأىەأتضأضەأڬډہأثہۏأىۄأڬہتۏتأۄًأحًأإځأڬہتأهۏڽأۗ+أثأ,أؼزۏأثىأذتحوأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأىثۏأ﷽أىەألشوتۏتأ=أدثأإځأتځىەأحۏشأڬەأىطتىأڬەأؼهتًۄأڬًةۏأزًضشتأىطتىأوۏڽأىۄأزۏڬہۏڽأتًشأإځأڬًأۏمۏىأۄًأڬۄأإځأىەأتضأڬًأمحهأڬۏتأۄەأحًأڬہتأهًأۗ

[تخریج]: [ صحیح ]"
18908,"أضؼۏزأثىأدثۏشأشعۏأتههۄأؼىۄأذعشحأؼزۏأثىأذتحوأشعۏأتههۄأؼىۄأضەأىمهألشوتحەأۄۏڽأڬۄأىثۏأ﷽أىەألشوتۏتأ=أدثأإځأطڬتشأوۏڽأتځىەأحۏشأڬەأؼهتًۄأڬضۏأڬتأىطتىأىۄأزۏڬہۏڽأتًشأإځأڬًأۏمۏىأۄًأڬۄأحًأىەأتضأڬًأمحهأڬۏتأۄەأحًأڬہتأهًأۗ

[تخریج]: [ صحیح ]"
18909,"أضؼۏزأثىأدثۏشأشعۏأتههۄأؼىۄأؼزۏأثىأذتحوأشعۏأتههۄأؼىۄأضەأىمهألشوتحەأۄۏڽأڬۄأوۏڽأىەأځًډہتأ=أتەأتههۄأڬەأشضًهأ﷽أ$أوۏڽأطڬتشأڬشحتأۄًڽأتًشأظثذأڬەأًمحأوۏڽأتځىتأحۏشأطڬتشأوۏڽأځتحتأۄًڽأۗألشوتۏتأ=أدثأحًأتځىتأحۏشأطڬتشأوۏڽأځتةەأتًشأحدہەأتضأڬەأمحهأڬتأۏمۏىأۄًأتًشأڬضۏأزشىزەأڬتأىطتىأثہۏأتضأوۏڽأىۄأزۏڬہەأحًأڬہتأهًأۗ

[تخریج]: [ صحیح ]"
18910,"أتثًخؼهثۄأرخىۏأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=أدثأحًأطڬتشأڬًأحۏشأوتشەأتًشأطڬتشأحۏىأزىأحڬأؽتةثأشۄىەأڬەأثؼزأوهأدتةەأحًأثزثًأځۏزتأۄًىەأضەأځۄهەأإځأڬہتأضڬحەأۄۏڽأۗ

[تخریج]: [ صحیح ۔ متفق علیہ ]"
18911,"أتثًخؼهثۄأرخىۏأشعۏأتههۄأؼىۄأشضًهأتههۄأ﷽أضەأىمهألشوتحەأۄۏڽأڬۄأتضأطڬتشأڬەأوحؼهمأدًأحۏىأزىأڬەأثؼزأځتأهۏتأدتةەألشوتۏتأثزثًزتشأۄًىەأضەأمثهأڬہتأدتأضڬحتأۄەأۗ

[تخریج]: [ صحیح ]"
18912,"أؼوشًأثىأطؼۏثأتځىەأًتهزأضەأتًشأًۄأتځىەأزتزتأضەأىمهألشوتحەأۄۏڽأڬۄأتۏڬأزۏۄتحۏأدضأڬًأتثًخؼهثۄأڬۄتأدتحتأحہتأۗأتضأىەأشضًهأتههۄأ﷽أضەأځًډہتأ=أوۏشەأمًضأڬەأثتشەأوۏڽألحًۏٳأزۏڽأ؏ألشوتۏتأ=أدًأحۏشتأحۏشأًتځضأڬشأزەأڬہتأهەأ؏أتضأىەأڬۄتأ=أسثذأڬشأڬەأۏتأثؽۏشأسثذأڬۏەأآأځہشأتضأىەأڬۄتأ=أتڲشأًۄأودہأضەأؽتةثأۄۏأشۄەأآألشوتۏتأ=أتڲشأًۄأحدہأضەأؽتةثأشۄەأدثأحڬأرشتثأىۄأۄًأۏتأڬضۏأزًضشەأحۏشأڬتأىطتىأىۄأزۏڬہۏڽأ؏أتضأىەأڬۄتأ=أودًضأڬەأثشحىًڽأڬەأثتشەأوۏڽألحًۏٳأزۏڽأۗأڬۏتأًۄأودثًشۏأڬەأًمحأتضحؼوتهأڬۏەأدتأضڬحەأۄۏڽأآألشوتۏتأ=أزہًأڬشأتضحؼوتهأڬشأهًأۗ

[تخریج]: [ حسن ]"
18913,"تثًخؼهثۄأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأوۏڽأىەأشضًهأتههۄأ﷽أضەأځًډہتأڬۄأوۏشەأحۏشأڬەأثتشەأوۏڽألحًۏٳأزۏڽأآألشوتۏتأ=أڬہتاأدًأحوۄتشتأحۏشأحدہەأهًټتأزەأۗأوۏڽأىەأڬۄتأ=أتڲشأًۄأودہأضەأډہځأدتةەأحًألشوتۏتأ=أتڲشأطڬتشأحدہأضەأؽتةثأثہۏأشۄەأتًشأتځىەأحۏشأڬەأؼهتًۄأتضأوۏڽأڬًةۏأىطتىأىۄأزۏڬہەأۏتأرشتثأىۄأۄًأۗطۏرألشوتحەأۄۏڽأ=أتۏضتأڲًطحأدضأڬۏأثًأحثزۏهأۄًأدتةەأ؏أۏۄأڬہتىتأذشتوأىۄۏڽأۄەأ؏أڬۏًىڬۄأىثۏأ﷽أضەأوىمًهأۄەأڬۄأإځأىەأتۏضۏأډشثۏأڬہتةۏأدضأڬۏأثًأحثزۏهأۄًأډڬۏأحہۏأۗ

[تخریج]: [ حسن ]"
18914,"أذعشحأتىضأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أڬًأدًأڬۏأشًټۏأتًشأتۏضۏأډشثۏأدضأڬۏأثًأحثزۏهأۄًأډڬۏأحہۏأځشأزؼًحأزۏأڲةۏأۗ

[تخریج]: [ صحیح ۔ بخاری 2069 ]"
18915,"أؼوۏشأثىأضهوۄأعوشۏألشوتحەأۄۏڽأڬۄأىثۏأ﷽أىەأشًذتؤأىتوۏأدڲۄأځشأتۏڬأصروۏأڲزہەأڬًأزۏڬہتأۗأوذوزأثىأتثۏأثڬشأىەأتځىۏأذزۏخأوۏڽأصۏتزۄأڬۏتأۄەأڬۄأدىڲهأوۏڽأۗأڬۄتأڲۏتأ=أتەأتههۄأڬەأشضًهأ﷽أ$أۏۄأصروۏأڲزہتأۄەأۗأإځأىەألشوتۏتأ=أتضأڬًأډہًڔأزًأتضأڬتأوتهڬأإأدتةەأڲتأ؏أحًأثۄصأمثۏهەأڬتأتۏڬأطرظأإۏتأۗأتضأىەأڬۄتأ=أتەأتههۄأڬەأشضًهأ﷽أ$أوۏڽأىەأتضأڬًأطڬتشأڬۏتأحہتأۗأإځأتځىەأتضحؼوتهأوۏڽأهتأضڬحەأۄًأحًأشضًهأتههۄأ﷽أىەأتثًثڬشأشعۏأتههۄأؼىۄأڬًأذڬوأزۏتأڬۄأًۄأتځىەأضتحہۏًڽأوۏڽأحمضۏوأڬشأزۏڽأ؏أځہشأإځأډهحەأۄًةەأتختثۄأىتوۏأدڲۄأدًأؼشدأتًشأشًۏخۏۄأڬەأزشوۏتىأۄەأځۄىډەأحًأتۏڬأۄشىأدًأضتةەأوۏڽأدضوأڬًأټۏڔہتأڬۏەأۄًةەأثۏټہتأحہتأتًشأتضأوۏڽأحۏشأثہۏأوًدًزأحہتأحًأشضًهأتههۄأ﷽أىەأتۏڬأطرظأڬًأتضأڬەأځتضأڬہڔتأڬشأزۏتأحتڬۄأڬًةۏأطرظأتضەأىۄأځڬڔەأۏۄتڽأحڬأڬۄأضتشەأهًڲأڲصشأدتةۏڽأۗ

[تخریج]: [ صحیح ]"
18916,"أؼوۏشأثىأضهوۄأعوشۏأتۏڬأثۄصۏأطرظأضەأىمهألشوتحەأۄۏڽأڬۄأىثۏأ﷽أذتهحٓأتذشتوأوۏڽأشًذتؤأڬەأدىڲهأڬەأثؼعأذظەأضەأڲصشەأحًأًۄتڽأتۏڬأصروۏأًذطۏأڲزہتأوًدًزأحہتأحًأهًڲًڽأىەأشضًهأتههۄأ﷽أڬًأثحتۏتأۗ

[تخریج]: [ صحیح ۔ تقدم قبلہ ]"
18917,"أذعشحأؼزۏأثىأذتحوأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=أدثأحًأطڬتشأځشأتځىەأڬحەأڬًأډہًڔەأحًأثضوأتههۄأتًشأتههۄأتڬثشأڬۄۄأ؏أتڲشأڬحتأطڬتشأڬًأحۏشەأهۏەأثتمۏأشڬہەأتًشأطڬتشأڬًأحًأصىزۄأځتأهەأحًأسثذأڬشأتًشأتڲشأڬحەأىەأطڬتشأڬًأمحهأڬشأڬەأڬہتۏتأىۄۏڽأحًأًۄأطڬتشأڬہتأهًأۗأتڲشأحًأتځىەأڬحەأڬەأضتحہأڬضۏأزًضشەأڬحەأڬًأځتةەأڬۄأتضأىەأطڬتشأڬًأمحهأڬشأزۏتأۄەأحًأإځأىۄأڬہتةۏڽأڬۏًىڬۄأإځأىۄۏڽأدتىحەأڬۄأڬضأىەأمحهأڬۏتأۄەأتًشأتڲشأحًأطڬتشأڬًأحۏشأوتشەأحًأثضوأتههۄأتًشأتههۄأتڬثشأځڔہأۗأتڲشأطڬتشأحدہأضەأتۏڬأزىأؽتةثأشۄەأتًشأتضأوۏڽأحًأتځىەأحۏشأڬتأىطتىأځتةەأډتۄەأحًأڬہتأهەأ؏أتڲشأإځأتضأڬًأځتىۏأوۏڽأڋًثتأۄًتأځتحەأۄۏڽأحًأځہشأىۄأڬہتةۏڽأۗ

[تخریج]: [ صحیح ۔ متفق علیہ ]"
18918,"تثًخؼهثۄأرطىۏأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأوۏڽأىەأشضًهأتههۄأ﷽أڬەأځتضأإأڬشأڬۄتأ=أتەأتههۄأڬەأشضًهأ﷽أ$أۄوتشتأؼهتمۄأطڬتشأًتهتأۄەأۗأوۏڽأًۄتڽأضزہتةەأۄًةەأتًشأثؽۏشأضزہتةەأۄًةەأڬحًڽأضەأطڬتشأڬشحتأۄًڽأۗأإځأۄوۏڽأثحتةۏڽأۄوتشەأهۏەأتضأوۏڽأضەأڬۏتأذهتهأۄەأتًشأڬۏتأذشتوأآأ؏أإځأىەألشوتۏتأ=أدًأضزہتۏتأۄًتأڬحتأطڬتشأڬشەأتًشأحۏشەأهۏەأطڬتشأڬًأشًڬأثہۏأهەأحًأتههۄأڬتأىتوأهەأڬشأڬہتأهًأتًشأدًأؽۏشأضزہتۏتأۄًتأڬحتأطڬتشأڬشەأ؏أتڲشأإځأطڬتشأڬًأسثذأڬشأهۏڽأحًأڬہتأهًأ؏أتڲشأسثذأڬتأوًمؼۄأىۄأوهأضڬەأحًأىۄأڬہتاأۗ+أثأ,أذۏًۄأڬۏأذزۏخأوۏڽأۄەأڬۄأوۏڽأضزہتةەأتًشأؽۏشأضزہتةەأڬحًڽأضەأطڬتشأڬشحتأۄًڽأۗ

[تخریج]: [ صحیح ۔ متفق علیہ ]"
18919,"أؼزۏأثىأذتحوأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأوۏڽأىەأشضًهأتههۄأ﷽أضەأطڬتشأڬەأثتشەأوۏڽأځًډہتأڬۄأوۏڽأتځىتأڬحتأطڬتشأځشأډہًڔحتأۄًڽأحًأتضأڬەأضتحہأڬًةۏأزًضشتأڬحتأثہۏأځتحتأۄًڽأۗأودہەأوؼهًوأىۄۏڽأڬۄأزًىًڽأوۏڽأضەأڬضأىەأطڬتشأڬًأځڬڔتأۗأإځأىەألشوتۏتأ=أحًأطڬتشأڬًأىۄأڬہتأڬۏًىڬۄأحًأىەأتځىەأڬحەأڬًأډہًڔحەأًمحأتههۄأڬتأىتوأهۏتأحہتأ؏أزًضشەأڬحەأځشأىۄۏڽأۗ

[تخریج]: [ صحیح ۔ متفق علیہ ]"
18920,"أذعشحأؼزۏألشوتحەأۄۏڽأڬۄأوۏڽأىەأڬۄتأ=أتەأتههۄأڬەأشضًهأ﷽أ$أوۏڽأتځىەأڬحەأڬًأطڬتشأځشأډہًڔحتأۄًڽأۗ

[تخریج]: [ صحیح ]"
18921,"أؼزۏأثىأذتحوأشعۏأتههۄأؼىۄأىەأشضًهأتههۄأ﷽أضەأطڬتشأڬەأثتشەأوۏڽأضًتهأڬۏتأتضأىەأذزۏخأڬًأسڬشأڬۏتأدضأوۏڽأۏۄأحہتأڬۄأإځأىەألشوتۏتأ=أتڲشأحۏشتأڬحتأزًضشەأڬحًڽأڬەأضتحہأوهأڬشأطڬتشأڬًأمحهأڬشأزەأتًشأتضأطڬتشأڬًأڬہتةەأىۄۏڽأحًأإځأتضأضەأڬډہأىۄأڬہتةۏڽأڬۏًىڬۄأإځأىۄۏڽأدتىحەأڬۄأڬضأىەأتضأڬًأمحهأڬۏتأۄەأۗ

[تخریج]: [ صحیح ]"
18922,"أتثًخؼهثۄأرطىۏأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأوۏڽأىەأشضًهأتههۄأ﷽أضەأڬۄتأ=أۄوأطڬتشأڬەأؼهتمۄأوۏڽأشۄحەأۄۏڽأۗأوۏڽأتځىۏأڬوتىأضەأطڬتشأڬشحتأۄًڽأۗأثؼعأتًمتحأسثذأڬتأوًمؼأوهأدتحتأۄەأتًشأڬثہۏأسثذأڬشىەأڬتأوًمؼأىۄۏڽأوهحتأۗأشضًهأتههۄأ﷽أىەألشوتۏتأ=أدًأحۏشۏأڬوتىأ؏أڬحتأ؏أۄتحہأحدہأځشأهًټأزەأتضەأڬہتأهًأسثذأۄًأۏتأىۄأۄًأۗ

[تخریج]: [ حسن ۔ تقدم برقم 18883 ]"
18923,"أؼمثۄأثىأؼتوشأدۄىۏأ؏أذسۏلۄأثىأۏوتىأشعۏأتههۄأؼىۄوتألشوتحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=أًۄأطڬتشأذهتهأۄەأدًأحۏشۏأمًضأًتځضأڬشەأۗ

[تخریج]: [ ضعیف ]"
18924,"أتثًًتمزأهۏخۏألشوتحەأۄۏڽأڬۄأدثأىثۏأ﷽أوزۏىۄأإةەأۗأهًڲأتًىټًڽأڬۏأڬًۄتىأتًشأثڬشۏًڽأڬۏأشتىۏڽأڬتټأهۏحەأحہەأۗأىثۏأ﷽أىەألشوتۏتأ=أدًأڲًطحأصىزۄأدتىًشأضەأڬتټتأڲۏتأًۄأوشزتشأڬەأذڬوأوۏڽأۄەأۗ

[تخریج]: [ ضعیف ]"
18925,أذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتألشوتحەأۄۏڽأڬۄأتہهأڬحتثأڬتأطڬتشأڬہتأهًأهۏڬىأودًضأڬتأطڬتشأىۄأڬہتاأۗ
18926,"ذعشحأدتثشأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأودًضأڬەأڬحەأتًشأځشىزەأڬەأطڬتشأضەأۄوۏڽأوىؼأڬۏتأڲۏتأۄەأۗ+أثأ,أدتثشأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأودًضأڬەأسثۏذۄأتًشأتىأڬەأڬحەأتًشأځشىزەأڬەأطڬتشأضەأوىؼألشوتۏتأڲۏتأۗ

[تخریج]: [ ضعیف ]"
18927,"أؼثتۏۄأثىأشلتؼۄأتځىەأزتزتأشتلؼأثىأرزۏدأضەأىمهألشوتحەأۄۏڽأڬۄأتەأتههۄأڬەأشضًهأ﷽أ$أڬهأۄوأزطوىأضەأوهىەأًتهەأۄۏڽأۗأۄوتشەأځتضأډہشۏأىۄۏڽأۄەأۗألشوتۏتأ=أدًأرًىأثۄتةەأتًشأدضأځشأتههۄأڬتأىتوأهۏتأڲۏتأۄًأڬہتأهۏڽأهۏڬىأزتىحأتًشأىترىأضەأسثذأىۄأڬشۏڽأ؏أڬۏًىڬۄأزتىحأۄڋۏأۄەأدثڬۄأىترىأذثطۏًڽأڬۏأډہشۏأۄەأۗأشتًۏأڬۄحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أڬًأوتهأؽىۏوحأوهتأدضأوۏڽأضەأتۏڬأتًىټأثہتڲأڲۏتأۗأظذتثۄأىەأځڬڔىەأڬۏأڬًططأڬۏأهۏڬىأڬتوۏتثأىۄأۄًةەأحًأتۏڬأطرظأىەأحۏشأوتشأڬشأشًڬأهۏتأحًأشضًهأتههۄأ﷽أىەألشوتۏتأ=أثؼعأتًىټأثہتڲأدتحەأۄۏڽأدضأغشذأدىڲهۏأدتىًشأۄًحەأۄۏڽأ؏أتڲشأتىأوۏڽأڬًةۏأمتثًأىۄأإةەأحًأتضەأتضأغشذأحۏشأوتشتأدتةەأ؏أًۄأتًىټأڬىًۏڽأوۏڽأڲشأڲۏتأۗأظذتثۄأتضأڬًأڲشزىأڬۏأدتىثأضەأىذشأىۄأڬشأضڬەأحًأذعشحأؼثزتههۄأثىأؼوشأشعۏأتههۄأؼىۄوتأىەأزًأزشہوأڬەأثزهەأرشۏزأهۏتأۗ

[تخریج]: [ صحیح ۔ متفق علیہ ]"
18928,"ؼثتۏۄأثىأشلتؼۄأثىأشتلؼأثىأرزۏدأتځىەأزتزتأشتلؼأضەأىمهألشوتحەأۄۏڽأڬۄأۄوأحۄتوۄأڬەأؼهتمۄأسًتهذهۏلۄأوۏڽأحہەأ؏أهًڲأثہًڬەأحہەأتىہۏڽأتًىټأتًشأثڬشۏتڽأوهۏڽأۗأدثأشضًهأتههۄأ﷽أإةەأحًأۄىڋۏتڽأډًهۄًڽأځشأحہۏڽأ؏أشضًهأتههۄأ﷽أىەأۄىڋۏًڽأڬًأتىڋۏهىەأڬتأذڬوأزۏتأۗأځہشأزىأڬەأزشوۏتىأحمضۏوألشوتةۏأ؏أتۏڬأتًىټأزضأثڬشۏًڽأڬەأثشتثشأشڬہتأۗأشتًۏألشوتحەأۄۏڽأڬۄأتۏڬأتًىټأثہتڲأڲۏتأهۏڬىأهًڲًڽأڬەأځتضأڬوصًشأضتأڲہًڔتأحہتأ؏أتۏڬأطرظأىەأحۏشأوتشأڬشأشًڬأهۏتأحًأشضًهأتههۄأ﷽أىەألشوتۏتأ=أثؼعأتًىټأثہتڲأدتحەأۄۏڽأدضأغشذأدىڲهۏأدتىًشأۄًحەأۄۏڽأتڲشأتىأوۏڽأڬًةۏأمتثًأىۄأإةەأحًأتضأغشذأحۏشأوتشتأدتةەأۗ+أثأ,أشتلؼأثىأرزۏدألشوتحەأۄۏڽأڬۄأوۏڽأىەأؼشعأڬۏتأ=أتەأتههۄأڬەأشضًهأ﷽أ$أۄوأڬهأڬەأزىأزطوىأضەأوهىەأًتهەأۄۏڽأتًشأۄوتشەأځتضأډہشۏتڽأىۄۏڽأۄۏڽأ؏أڬۏتأۄوأضشأڬىڋًڽأڬەأضتحہأسثذأڬشأضڬحەأۄۏڽأآأإځأىەألشوتۏتأ=أدًأډۏصأرًىأثۄتةەأتًشأتضأځشأثضوأتههۄأځڔہۏأدتةەأحًأتضەأڬہتىتأدتةصأۄەأۗأتهثحۄأزتىحأتًشأىترىأىۄأۄًأتًشأوۏڽأحوۄۏڽأتضأڬەأثتشەأوۏڽأثحتحتأۄًڽأزتىحأۄڋۏأۄەأتًشأىترىأذثطۄأڬۏأډہشۏأۄەأۗ

[تخریج]: [ صحیح ۔ متفق علیہ ]"
18929,"أشتلؼأثىأرزۏدألشوتحەأۄۏڽأڬۄأسًتهذهۏلۄأومتوأځشأۄوأشضًهأتههۄأ﷽أڬەأضتحہأحہەأۗأهًڲًڽأڬًأتًىټأتًشأثڬشۏتڽأوهۏڽأۗأؼثتۏۄأڬۄحەأۄۏڽأڬۄأوزۏىۄأوۏڽأتًىټأڬىًۏڽأوۏڽأڲشأڲۏتأۗأًۄأڬًڬہأڬۏأدتىثأضەأسثذأڬشأزۏتأڲۏتأحًأتثىأؼوشأشعۏأتههۄأؼىۄوتأىەأزضًتڽأذظۄأزًأزشہوأڬەأثزهەأوۏڽأرشۏزأهۏتأۗ

[تخریج]: [ صحیح ۔ متفق علیہ ]"
18930,أؼثزتهشذوىأتًشأوذوزأذعشحأدتثشأشعۏأتههۄأؼىۄأڬەأزًىًڽأثۏټەأتځىەأًتهزأضەأىمهألشوتحەأۄۏڽأڬۄأتۏڬأثہتڲۏأۄًةۏأڲتةەأۄوتشەأځتضأضەأڲصشۏأ؏أًۄأدضأڬەأځتضأضەأثہۏأڲصشحۏأحًأټڬشأوتشحۏأۗ
18931,"تثًؼطشتؤأزتشوۏأتځىەأًتهزأضەأىمهألشوتحەأۄۏڽأڬۄأتىہًڽأىەأڬۄتأ=أتەأتههۄأڬەأشضًهأ﷽أ$أسثذأظشلأذهمأضەأڬۏتأدتحتأۄەأآألشوتۏتأ=أتڲشأحًأتضأڬەأشتىأوۏڽأىۏصۄأوتشأزۏحتأحًأًۄأثہۏأحدہەأڬتلۏأۄًحتأۗطۏرألشوتحەأۄۏڽأڬۄأۏۄأڬىًۏڽأوۏڽأڲشىەأًتهەأدتىًشأتًشأتضأڬەأوطتثۄۄأتطۏتؤأوۏڽأۄەأۗ

[تخریج]: [ ضعیف ]"
18932,"أؼڬشوۄأذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأضەأىمهألشوتحەأۄۏڽأڬۄأدًأډًځتةەأمتثًأوۏڽأىۄأإةۏڽأًۄأطڬتشأڬەأمتةوأومتوأۄەأڬۄأإځأتضأڬًأىۏصۄأوتشۏڽأۗ

[تخریج]: [ صحیح ]"
18933,"أذثۏثأثىأتثۏأختثحألشوتحەأۄۏڽأڬۄأتۏڬأطرظأذعشحأؼهۏأثىأتثۏأغتهثأشعۏأتههۄأؼىۄأڬەأځتضأإۏتأتًشأڬۄتأ=أوۏشتأتًىټأثہتڲأڲۏتأحہتأۗأوۏڽأىەأتضأڬًأىۏصۄأوتشتأحہتأ؏ألشوتۏتأ=أودہەأتضأڬۏأضشۏىأۄزۏۄأوۏڽأزۏىتأۗ

[تخریج]: [ ضعیف ]"
18934,"أؽعثتىأۏؼىۏأتثىأۏصۏزأثدهۏأتځىەأًتهزأضەأىمهألشوتحەأۄۏڽأڬۄأهًڲأڬًلۄأإةەأ؏أًۄتڽأوذهەأڬەأتۏڬأطرظأىەأځڔتاأڬۏتأتًشأتًىټىۏأرشۏزۏأۗأًۄأثہتڲأڲةۏأۗأځہشأتضأىەأزًضشۏأرشۏزۏأحًأتضأڬەأثہتڲأدتىەأڬەأڋشەأۗأتههۄأڬتأىتوأهۏتأًۄأوشأڲةۏأحًأتىہًڽأىەأإأڬشأذعشحأؼثزتههۄأضەأضًتهأڬۏتأحًأتىہًڽأىەأڬہتىەأڬتأذڬوأزۏتأ؏أهۏڬىأمثۏهەأڬەأهًڲأڬہتىەأځشأحۏتشأىۄأۄًةەأ؏أدثأحڬأتۏڬأټڬڔتأؼثزتههۄأڬەأځتضأىۄأهتةەأدثأتىہًڽأىەأڬہتأهۏتأحًأمثۏهۄأڬەأهًڲأڬہتىەأځشأحۏتشأۄًأڲةەأۗ

[تخریج]: [ ضعیف ]"
18935,"أؼثتۏۄأثىأشتلؼأذعشحأشتلؼأثىأرزۏدأضەأىمهألشوتحەأۄۏڽأڬۄأوۏڽأىەأڬۄتأ=أتەأتههۄأڬەأشضًهأ﷽أ$أۄوأڬهأزطوىأضەأوهىەأًتهەأۄۏڽأتًشأۄوتشەأځتضأډہشۏتڽأىۄۏڽأۄۏڽأۗأڬۏتأۄوأثتىضأڬەأډہهڬەأًؽۏشۄأضەأسثذأڬشأهۏڽأآأإځأىەألشوتۏتأ=أدًأډۏصأرًىأثۄتأزەأتًشأتضأځشأتههۄأڬتأىتوأهۏتأڲۏتأۄًأڬہتاأهۏڬىأدًأىترىأتًشأزتىحأضەأسثذأڬۏتأڲۏتأۄًأتضەأىۄأڬہتاأ؏أڬۏًىڬۄأزتىحأتىضتىأڬۏأۄڋۏأۄەأدثڬۄأىترىأذثطۄأڬۏأډہشۏأۄەأۗ

[تخریج]: [ صحیح ۔ تقدم ]"
18936,"أؼثتۏۄأثىأشلتؼۄأتځىەأزتزتأضەأىمهألشوتحەأۄۏڽأڬۄأۄوأىەأڬۄتأ=أتەأتههۄأڬەأشضًهأ﷽أ$أۄوأڬهأزطوىأضەأوهتمتحأڬشىەأًتهەأۄۏڽأتًشأۄوتشەأځتضأډہشۏتڽأىۄۏڽأۄۏڽأ؏أڬۏتأۄوأڬضۏأهڬڔۏأضەأسثذأڬشأهۏڽأآألشوتۏتأ=أدًأډۏصأرًىأثۄتأزەأتًشأتضأځشأثضوأتههۄأًتههۄأتڬثشأځڔہتأڲۏتأۄًأحًأڬہتأهًأ؏أهۏڬىأدًأىترىأ؏أزتىحأضەأسثذأڬۏتأڲۏتأۄًأىۄأڬہتاأ؏أڬۏًىڬۄأزتىحأتىضتىۏأۄڋۏأۄەأدثڬۄأىترىأذثطۄأڬۏأډہشۏأۄەأۗأشتًۏأڬۄحەأۄۏڽأڬۄأۄوۏڽأتًىټأتًشأثڬشۏتڽأوهۏڽأتًشأتۏڬأتًىټأزضأثڬشۏًڽأڬەأثشتثشأحہتأۗأتۏڬأتًىټأثہتڲأڲۏتأدضەأحۏشأوتشأڬشأشًڬتأڲۏتأ؏أحًأشضًهأتههۄأ﷽أىەألشوتۏتأڬۄأثؼعأتًىټأدىڲهۏأدتىًشًڽأڬۏأغشذأۄًحەأۄۏڽأۗأدثأڬًةۏأتًىټأثہتڲأدتةەأحًأتضأڬەأضتحہأتۏضتأۄۏأضهًڬأڬشًأتًشأڬہتأهًأۗ

[تخریج]: [ صحیح ۔ تقدم قبلہ ]"
18937,"أشتلؼأثىأرزۏدأىەأشضًهأتههۄأ﷽أضەأڬۄتأ=أڬهأۄوأزطوىأضەأوهىەأًتهەأۄۏڽأ؏أۄوتشەأځتضأډہشۏتڽأىۄۏڽأۄۏڽأۗأشضًهأتههۄأ﷽أىەألشوتۏتأ=أدهزۏأڬشأ؏أدًأډۏصأرًىأثۄتأزەأتًشأتههۄأڬتأىتوأهۏتأڲۏتأۄًأڬہتاأ؏أهۏڬىأزتىحأتًشأىترىأضەأسثذأىۄأڬۏتأڲۏتأۄًأ؏أوۏڽأحوۄۏڽأثحتحتأۄًڽأزتىحأۄڋۏأۄەأتًشأىترىأذثطۄأڬۏأډہشۏأۄەأۗأدهزثتصأهًڲًڽأىەأثڬشۏتڽأسثذأڬشأزۏڽأتًشأۄىڋۏتڽأځڬتىەأڬەأهۏەأشڬہأزۏڽأتًشأشضًهأتههۄأ﷽أضثأضەأإرشأوۏڽأحہەأۗأدثأىثۏأ﷽أڬتأڲصشأۄىڋۏًڽأڬەأځتضأضەأۄًتأحًأتىہۏڽأتىڋۏهىەأڬتأذڬوأزەأزۏتأتًشأتىأڬەأزشوۏتىأحمضۏوأڬشأزۏتأۗأإځأىەأتۏڬأتًىټأڬًأزضأثڬشۏًڽأڬەأثشتثشأمشتشأزۏتأۗأهًڲًڽأڬتأتًىټأثہتڲأڲۏتأۗأتىأڬەأځتضأڲہًڔتأثہۏأىۄۏڽأحہتأۗأتۏڬأطرظأىەأحۏشأوتشتأحًأتههۄأىەأتضأڬًأشًڬأزۏتأحًأإځأىەألشوتۏتأ=أۏۄأتًىټأثہتڲأدتحەأۄۏڽأدضأغشذأدىڲهۏأدتىًشأۄًحەأۄۏڽأۗأدثأڬًةۏأتًىټأثہتڲأدتةەأحًأتضأڬەأضتحہأۏۄۏأضهًڬأڬشأڬەأڬہتأهًأۗ

[تخریج]: [ صحیح ۔ متفق علیہ ]"
18938,أضتثمۄأذزۏخأڬۏأغشذأۄە
18939,"أتثًخؼهثۄألشوتحەأۄۏڽأڬۄأوۏڽأشضًهأتههۄأ﷽أڬەأځتضأإۏتأۗأإځأىەألشوتۏتأ=أدثأحًأىەأثحتۏتأڬۄأإځأطڬتشأڬەأؼهتمۄأوۏڽأشۄحەأۄۏڽأدضأڬًأإځأڬۏأمًضأهڲەأتضأځشأثضوأتههۄأتًشأتههۄأتڬثشأځڔہًأ؏أځہشأڬہتاأۗ

[تخریج]: [ صحیح ]"
18940,"أوضشًمأؼثزتههۄأضەأىمهألشوتحەأۄۏڽأڬۄأدثأحوأطڬتشأڬشًأتًشأًۄأځۄتڔأضەأڲشأڬشأوشأدتةەأحًأوحأڬہتاأ؏أووڬىأۄەأًۄأڲشىەأڬۏأًدۄأضەأوشتأۄًأۏتأځتىۏأوۏڽأڲشأڬشأوشەأحثأثہۏأىۄأڬہتاأڬۏًىڬۄأووڬىأۄەأځتىۏأڬۏأًدۄأضەأۄهتڬأۄًتأۄًأۗ

[تخریج]: [ صحیح ]"
18941,"أؼزۏأثىأذتحوأشعۏأتههۄأؼىۄأىەأطڬتشأڬەأوحؼهمأشضًهأتههۄأ﷽أضەأضًتهأڬۏتأحًأإځأىەألشوتۏتأ=أتڲشأحًأتههۄأڬتأىتوأهەأڬشأطڬتشأڬًأحۏشأوتشأڬشأۄهتڬأڬشأزەأحًأڬہتأهەأ؏أتڲشأطڬتشأځتىۏأوۏڽأڲشأڬشأۄهتڬأۄًأدتةەأحًأىۄأڬہتاأ؞أڬۏًىڬۄأوؼهًوأىۄۏڽأڬۄأحۏشأۏتأځتىۏأوۏڽأڲشىەأڬۏأًدۄأضەأۄهتڬأۄًتأۄەأۗ

[تخریج]: [ صحیح ۔ متفق علیہ ]"
18942,"أوضشًمأذعشحأؼثزتههۄأضەأىمهألشوتحەأۄۏڽأڬۄأدثأحوأطڬتشأڬشًأتًشأًۄأځۄتڔأضەأڲشأڬشأۄهتڬأۄًأدتةەأحًأىۄأڬہتاأ؏أووڬىأۄەأًۄأځۄتڔأضەأڲشىەأڬۏأًدۄأضەأۄهتڬأۄًتأۄًأ؏أتڲشأځتىۏأوۏڽأڲشأڬشأۄهتڬأۄًأدتةەأحثأثہۏأىۄأڬہتاأ؏أڬۏًىڬۄأتضأوۏڽأتذحوتهأۄەأڬۄأځتىۏأڬۏأًدۄأضەأمحهأۄًتأۗ

[تخریج]: [ صحیح ۔ تقدم قبل واحد ]"
18943,"أذعشحأؼثزتههۄأثىأوؽلهأىەأتۏڬأضتحہۏأڬًأڬىڬشۏأځہۏىڬحەأۄًةەأزۏڬہتأ؏ألشوتۏتأ=أڬىڬشۏأىۄأځہۏىڬًأ؏أڬۏًىڬۄأشضًهأتههۄأ﷽أىەأتضأڬًأىتځضىزألشوتۏتأحہتأۏتأوىؼأڬۏتأحہتأ؏أڬۏًىڬۄأىۄأحًأتضأضەأطڬتشأڬۏتأدتأضڬحتأۄەأتًشأىۄأزطوىأڬًأۄهتڬأڬۏتأدتأضڬحتأۄەأ؏أهۏڬىأۏۄأزتىحأڬًأحًڔأتًشأإىڬہأڬًأځہًڔأضڬحۏأۄەأۗأتضأڬەأثؼزأثہۏأًۄأڬىڬشۏأځہۏىڬحتأشۄتأحًأتضأضەأڬۄىەأهڲەأ=أوۏڽأحدہەأثحتأشۄتأۄًڽأڬۄأإځأىەأىتځضىزأڬۏتأۏتأوىؼأڬۏتأحًأحثأثہۏأڬىڬشۏأځہۏىڬأشۄتأۄەأۗأوۏڽأحدہأضەأتحىۏأوزحأحڬأڬهتوأىۄأڬشًڽأڲتأۗ

[تخریج]: [ صحیح ۔ متفق علیہ ]"
18944,"أذعشحأؼثزتههۄأثىأوؽلهأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەأڬىڬشۏأځہۏىڬىەأضەأوىؼألشوتۏتأتًشأڬۄتأڬۄأتضأضەأىۄأحًأطڬتشأڬۏتأدتأضڬحتأۄەأىۄأۄۏأزطوىأڬتأىمظتىأڬۏتأدتأضڬحتأۄەأ؏أهۏڬىأڬىڬشۏأځہۏىڬىتأإىڬہأڬًأځہًڔەأڲتأۏتأزتىحأحًڔەأڲتأۗ

[تخریج]: [ صحیح ۔ متفق علیہ ]"
18945,"أصشأثىأذثۏطألشوتحەأۄۏڽأڬۄأوۏڽأوزۏىۄأإۏتأتًشأؼۏزأڬەأزىأىڬهتأۗأتډتىڬأتۏڬأطرظأدًأرًزأڬتوأڬشحتأحہتأهًڲًڽأڬەأضتحہأۏًڽأډهأشۄتأحہتأدۏضەأضًتشأۄًأتًشأڬۄۄأشۄتأحہتأرهًظأىۏحأضەأۄدشحأڬشًأۗأظشلأوۄتدشۏىأڬۏأوطتثۄحأترحۏتشأڬشحەأۄًةەأثؽۏشأىۏحأڬەأۄدشحأىۄأڬشًأ؏أتًشأرشڲًطأڬًأهتټہۏأضەأوتشىەأضەأثډًأ؏أهۏڬىأحوأتضەأىۏصۄأتًشأڬتىټەأضەأسثذأڬشأضڬحەأۄًأۗ

[تخریج]: [ حسن ]"
18946,"أصۏزأثىأتضهوأذعشحأؼثزتههۄأثىأؼوشأشعۏأتههۄأؼىۄوتأضەأىمهألشوتحەأۄۏڽأڬۄأتۏضتأطڬتشأدًأثىزًمأضەأڬۏتأدتةەأڲًۏتأڬۄأًۄأهڬڔۏأڬۏأډًټأضەأوشتأحظًشأۄًأڲتأۗ

[تخریج]: [ حسن ]"
18947,"أوتهڬأىتلؼأضەأىمهألشوتحەأۄۏڽأڬۄأوۏڽأىەأزًأځشىزەأځحہشأضەأطڬتشأڬۏەأتًشأزًىًڽأڬًأځڬڔأثہۏأهۏتأۗأتۏڬأحًأوشأڲۏتأدضأڬًأؼثزتههۄأثىأؼوشأشعۏأتههۄأؼىۄوتأىەأځہۏىڬأزۏتأتًشأزًضشتأثہۏأسثذأضەأځۄهەأۄهتڬأۄًأڲۏتأتضأڬًأثہۏأځہۏىڬأزۏتأۗ

[تخریج]: [ صحیح ]"
18948,"أوتهڬأىتلؼأضەأىمهألشوتحەأۄۏڽأڬۄأوۏڽأىەأزًأځشىزەأځحہشأضەأطڬتشأڬۏەأتًشأزًىًڽأڬًأځڬڔأثہۏأهۏتأۗأتۏڬأحًأوشأڲۏتأدضأڬًأؼثزتههۄأثىأؼوشأشعۏأتههۄأؼىۄوتأىەأځہۏىڬأزۏتأتًشأزًضشتأثہۏأسثذأضەأځۄهەأۄهتڬأۄًأڲۏتأتضأڬًأثہۏأځہۏىڬأزۏتأۗ

[تخریج]: [ صحیح ۔ متفق علیہ ]"
18949,"أذعشحأؼزۏأثىأذتحوأشعۏأتههۄأؼىۄأىەأىۏصۄأڬۏأډًڔتةۏأڬۏأدتىثأضەأڬۏەأۄًةەأطڬتشأڬەأثتشەأوۏڽأضًتهأڬۏتأحًأإځأىەألشوتۏتأ=أدضأڬًأىۏصۄأڬۏأزہتشأهڲەأڬہتأهًأتًشأدضأطڬتشأڬًأىۏصۄأڬۏأډًڔتةۏأڬۏأدتىثأهڲەأًۄأهڬڔۏأڬۏأډًټأضەأوشتأحظًشأۄًأڲتأ؏أىۄأڬہتاأۗ

[تخریج]: [ صحیح ۔ متفق علیہ ]"
18950,"أذعشحأؼهۏأثىأتثًغهذۄأذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأضەأتههۄأڬەأتضأتشطتزأ=أ®~أوّإأتْہٓهّٔأهٓؽّۏٕشٓأتههٔٳۄٓأثٓۄٙأ¾أڬەأثتشەأوۏڽأىمهألشوتحەأۄۏڽأڬۄأتضأضەأوشتزأدًحۏًڽأڬەأىتوأځشأډہًڔأدتةەأۗأتًشأ®تهوىرىمۆ¾أتۏضتأدتىًشأدضأڬتأڲهتأڲہًىټأڬشأوتشتأڲۏتأۄًأ؏أ®تهوًمًسۄ¾أ؏أتۏضتأدتىًشأدًأهڬڔۏأڬۏأډًټأضەأوتشتأدتةەأ؏أ®تهوحشزۏۆ¾أ؏أتۏضتأدتىًشأدًأځۄتڔأضەأڲشأڬشأوشأدتةەأ؏أ®تهىغۏذۆ¾أ؏أًۄأثڬشۏأدًأزًضشۏأثڬشۏأڬەأضۏىڲأهڲىەأڬۏأًدۄأضەأۄهتڬأۄًأدتةەأ؏أ®ًوتأتڬهأتهضثؼ¾أ؏أدضأڬًأزشىزەأىەأځہتڔأڬہتۏتأ؏أإځأىەأځڬڔتأحًأتضأڬۏأزوأذشڬحأڬشأشۄۏأحہۏأتًشأإىڬہأثہۏأوحذشڬأحہۏأحًأتههۄأڬتأىتوأهەأڬشأسثذأڬشًأۗأۏۄأذهتهأۄەأ؏أتۏڬأزًضشۏأدڲۄأتضأڬۏأحلضۏشأ®تهتأوتأسڬۏحو¾أ؏أتۏضەأدتىًشأدىأوۏڽأشًذأۄًأحوأسثذأڬشأهًأًۄأذهتهأۄەأ؏أ®ًوتأسثذأؼهۏأتهىظث¾أ؏أدىأڬًأحہتىًڽأځشأسثذأڬۏتأڲۏتأۄًأ؏أتىأڬەأىتوأځشأوطہًشأڬۏتأڲۏتأۄًأ؏أزًضشۏأحلضۏشأوۏڽأۄەأڬۄأۏۄأثحأۄۏڽأ؏أتىأحضحمضوًتأثتأهتصهٳوأ؏أتۏضەأحۏشأدىأڬەأسشۏؼەأمضوحأڬتأذتهأوؼهًوأڬشحەأۄۏڽأ؏أ®سٳهڬوألضم¾أ؏أدضأىەأتىأدتىًشًڽأضەأڬډہأڬہتۏتأۏۄأڲىتۄأۄەأۗ

[تخریج]: [ ضعیف ]"
18951,"أذعشحأؼثزتههۄأثىأؼوشأشعۏأتههۄأؼىۄوتأىثۏأ﷽أضەأىمهألشوتحەأۄۏڽأڬۄأتىأڬۏأوهتمتحأصۏزأثىأؼوشًأثىأىلۏهأضەأثهزذأڬۏأىډهۏأدتىثأۄًةۏأۗأۏۄأًذۏأىتصهأۄًىەأضەأځۄهەأڬۏأثتحأۄەأۗأصۏزأىەأإځأڬەأضتوىەأڲًطحأځۏطأڬۏتأحًأإځأىەأڬہتىەأضەأتىڬتشأڬشأزۏتأ؏أتًشألشوتۏتأ=أدًأحہتىًڽأځشأسثذأڬۏتأدتةەأًۄأوۏڽأىۄۏڽأڬہتحتأۗأوۏڽأحًأظشلأًۄأڬہتحتأۄًڽأدضأځشأتههۄأڬتأىتوأهۏتأڲۏتأۄًأۗ

[تخریج]: [ صحیح ۔ بخاری 3026 ]"
18952,"أذعشحأتثًغلۏهألشوتحەأۄۏڽأڬۄأذعشحأؼهۏأشعۏأتههۄأؼىۄأضەأځًډہتأڲۏتأ=أڬۏتأشضًهأتههۄأ﷽أىەأحوۄتشەأهۏەأڬًةۏأډۏصأورظًظأڬۏأۄەأآألشوتحەأۄۏڽأ=أؼتوأهًڲًڽأضەأۄوتشەأهۏەأڬډہأرتظأحًأىۄۏڽأڬۏتأهۏڬىأدًأوۏشۏأحهًتشأڬەأوۏتىأوۏڽأۄەأۗأځہشأتىہًڽأىەأتۏڬأظذۏلۄأىڬتهتأدضأوۏڽأحہتأڬۄأتههۄأتضأځشأهؼىحألشوتةەأدًأؽۏشأتههۄأڬەأهۏەأسثذأڬشحتأۄەأتًشأدًأصوۏىأڬۏأؼهتوتحأڬًأډًشۏأڬشحتأۄەأتًشأتځىەأًتهزۏىأځشأهؼىحأڬشىەأًتهەأطرظأځشأتًشأدًأثزؼحۏأتىضتىأڬًأدڲۄأزەأۗ

[تخریج]: [ صحیح ۔ مسلم 1978 ]"
18953,"أوذوزأثىأصۏزألشوتحەأۄۏڽأڬۄأتۏڬأطرظأىەأثڬشۏأسثذأڬۏأۗأتضأڬەأرۏتهأوۏڽأًۄأوشأڲةۏأ؏أهۏڬىأتضأىەأذشڬحأڬۏأ؏أتضأىەأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأتضأڬەأثتشەأوۏڽأضًتهأڬۏتأحًألشوتۏتأ=أڬہتأهًأ؏أدثأصۏزأثىأختثحأضەأضًتهأۄًتأحًأتىہًڽأىەأڬۄتأ=أىۄأڬہتاأڬۏًىڬۄأوشزۄأڬثہۏأذشڬحأثہۏأڬشحتأۄەأۗ

[تخریج]: [ صحیح ]"
18954,"أتثًوشۄأڬەأؽهتوأؼمۏهأىەأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأضًتهأڬۏتأڬۄأتۏڬأسثذأطزۄأثڬشۏأڬتأثؼعأذظۄأذشڬحأڬشحتأۄەأحًأتثًۄشۏشۄأشعۏأتههۄأؼىۄأىەأڬہتىەأڬۏأتدتصحأزۏأحًأصۏزأثىأختثحأضەأتضأڬەأثتشەأوۏڽأضًتهأۄًتأحًأتىہًڽأىەأڬۄتأ=أوشزتشأوۏشەأرۏتهأوۏڽأذشڬحأڬشحتأۄەأىۄأڬہتاأۗ

[تخریج]: [ صحیح ]"
18955,"أذعشحأصۏزأثىأختثحأىەألشوتۏتأڬۄأڬضۏأثڬشۏأوۏڽأثہۏڔۏتأڬډهۏتڽأڲتڔہأزۏحتأۄەأ؏أځہشأًۄأتضأڬًأځحہشأضەأسثذأڬشأهۏحەأۄۏڽأحًأىثۏأ﷽أىەأتضأڬەأڬہتىەأڬۏأتدتصحأزۏأۗ

[تخریج]: [ ضعیف ]"
18956,"أصۏزأثىأختثحأىەأىثۏأ﷽أضەأتۏضۏأثڬشۏأدضأوۏڽأثہۏڔۏەأىەأزتىحأڲتڔہأزۏەأۄًڽأ؏أتضەأصىزۄأځڬڔأڬشأسثذأڬشأزۏتأڲۏتأۗأإځأىەأتۏضۏأثڬشۏأڬًأڬہتىەأڬتأذڬوأزۏتأۗ

[تخریج]: [ ضعیف جدًا ]"
18957,"أؼغتؤأثىأۏضتشألشوتحەأۄۏڽأڬۄأثىًأذتشخۄأڬتأتۏڬأطرظأتذزأڬۏأڬضۏأڲہتټۏأوۏڽأتًىټىۏتڽأډشتأشۄتأحہتأۗأتۏڬأتًىټىۏأوشىەأهڲۏأهۏڬىأتضأطرظأڬەأځتضأىذشأڬەأهۏەأڬًةۏأډۏصأوًدًزأىۄأحہۏأۗأتضأىەأڬہًىټۏأځڬڔأڬشأتضأڬەأهثۄأوۏڽأزەأوتشۏأدضأضەأرًىأثۄۄأڲۏتأۗأځہشأىثۏأ﷽أڬًأثحتۏتأحًأإځأىەأڬہتىەأڬۏأتدتصحأزەأزۏأۗ

[تخریج]: [ ضعیف ]"
18958,"ؼوشًأثىأطشذثۏهأذعشحأؼتةطۄأشعۏأتههۄأؼىۄتأضەأىمهألشوتحەأۄۏڽأڬۄأۄوتشۏأتۏڬأثڬشۏأوشىەأهڲۏأحًأۄوأىەأسثذأڬشأڬەأحمضۏوأڬشأزۏأحًأىثۏأ﷽أىەأځًډہتأ=أحوۄتشۏأثڬشۏأڬتأڬۏتأثىتأآأڬۄحۏأۄۏڽأ=أًۄأوشىەأهڲۏأحہۏأ؏أۄوأىەأسثذأڬشأڬەأڲًطحأحمضۏوأڬشأزۏتأۗأظشلأتۏڬأڬىزہەأ؏أطتىەأڬتأڲًطحأثتمۏأۄەأۗأإځأىەألشوتۏتأ=أوڬوهأثڬشۏأحوۄتشەأهۏەأۄەأضًتةەأطتىەأڬەأۗ+أثأ,أصۄشۏأتثىأوضۏثأضەأىمهألشوتحەأۄۏڽأڬۄأسثذأتضأًمحأثہۏأۄًأضڬحتأۄەأدثأإىڬہأتًشأزوأذشڬحأڬشأشۄەأۄًڽأتًشأځتاڽأثہۏأذشڬحأڬشەأۗ

[تخریج]: [ ضعیف ]"
18959,"أذعشحأدتثشأثىأؼثزتههۄأشعۏأتههۄأؼىۄوتأىەألشوتۏتأڬۄأحۏىأضًأڬتأمتلهۄأىثۏأ﷽أىەأذعشحأتثًؼثۏزۄأثىأدشتذأڬۏأوتشحأوۏڽأشًتىۄأڬۏتأحتڬۄأۄوأمشۏطۏأمتلهًڽأځشأىڲتۄأشڬہۏڽأ؏أۄوأىەأضتذهأضوىزشأځشأمۏتوأڬۏتأ؏أزًضشۏأوشحثۄأضلۏتىأڬۄحەأۄۏڽأڬۄأۄوأضتذهأضوىزشأځشأإزہتأوتۄأټہۄشەأشۄەأ؏أۄوۏڽأضرحأثہًڬأهڲۏأ؏أدضأڬۏأثىتأځشأځحەأڬہتىەأځشأودثًشأۄًةەأحًأتضأهطڬشأڬتأىتوأۄۏأذثۏطأرثغأشڬہأزۏتأڲۏتأحًأضوىزشأىەأضتذهأځشأوډہهۏأځہۏىڬۏأدضأڬًأؼىثشأڬۄتأدتحتأۄەأۗأۄوأىەأىظلأوتۄأوډہهۏأڬہتةۏأتًشأتضأڬۏأډشثۏأڬتأحۏهأهڲتۏتأ؏أۏۄتڽأحڬأڬۄأۄوتشەأدضوأوعثًغأۄًأڲةەأۗأشتًۏأڬۄحەأۄۏڽأڬۄأتثًؼثۏزۄأىەأتضأڬۏأځضهۏًڽأوۏڽأضەأتۏڬأهەأڬشأڬہڔۏأڬۏأتًشأتځىەأضتحہأتۏڬأهوثتأإزوۏأهەأڬشأڲصشأڲةەأ؏أزًضشۏأوشحثۄأضلۏتىألشوتحەأۄۏڽأڬۄأتثًؼثۏزۄأىەأوډہهۏأڬۏأتۏڬأځضهۏأڬہڔۏأڬشأڬەأتځىەأضتحہأتۏڬأإزوۏأتًشأتًىټأضوۏحأتضأڬەأىۏډەأضەأڲصشأڲةەأدتثشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأتۏڬأطرظأىەأحۏىأتًىټأتۏڬأوشحثۄأزًضشۏأتًشأحۏضشۏأوشحثۄأثہۏأحۏىأحۏىأتًىټأسثذأڬۏەأۗأځہشأتثًؼثۏزۄأىەأتضأڬًأوىؼأڬشأزۏتأۗ

[تخریج]: [ صحیح ۔ متفق علیہ ]"
18960,"أذوۏزۏأضلۏتىأضەأىمهألشوتحەأۄۏڽأڬۄأتضأىەأضتذهأڬتأسڬشأىۄۏڽأڬۏتألشوتحەأۄۏڽأڬۄأتثًؼثۏزۄأىەأتضأڬۏأځضهۏًڽأوۏڽأضەأتۏڬأځضهۏأهەأڬشأڬہڔۏأڬۏأۗأځہشأتۏڬأهوثەأإزوۏأتًشأهطڬشأوۏڽأثڔەأتًىټأڬتأتىحرتثأڬۏتأتًشأتضأڬًأذڬوأزۏتأڬۄأًۄأضًتشأۄًأڬەأتضأڬەأىۏډەأضەأڲصشأدتةەأحًأًۄأڲصشأڲۏتأۗأۄوأىەأىثۏأ﷽أڬًأثحتۏتأحًأإځأىەأځًډہتأ=أڬۏتأحوۄتشەأځتضأڬډہأوًدًزأۄەأآأۄوأىەأڬۄتأ=أتثأحًأڬډہأوًدًزأىۄۏڽأۗ

[تخریج]: [ صحیح ۔ تقدم قبلہ ]"
18961,"ذعشحأدتثشأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأۄوأىەأذثۏطأتهرثغأڬۏأدىڲأهڔۏأۗأۄوتشەأتوۏشأتثًؼثۏزۄأحہەأۗأۄوأىەأطزۏزأثہًڬأوذضًضأڬۏأحًأضوىزشأىەأضتذهأځشأوشزۄأوډہهۏأځہۏىڬۏأ؏أۄوأىەأتحىۏأثڔۏأوډہهۏأىۄأزۏڬہۏأحہۏأۗأتضأڬتأىتوأؼىثشأحہتأۗأۄوأتضەأځىزشۄأشًصأحڬأڬہتحەأشۄەأ؏أتثًؼثۏزۄأىەأتضأڬۏأۄڋۏًڽأوۏڽأضەأتۏڬأۄڋۏأڬہڔۏأڬۏأحًأضًتشأتضأڬەأىۏډەأضەأڲصشأڲۏتأۗ+أثأ,أتثًصثۏشأىەأدتثشأشعۏأتههۄأؼىۄأضەأضىتأڬۄأتثًؼثۏزۄأىەأڬۄتأ=أڬہتأهًأ؏أدثأۄوأىثۏأڬشۏوأ﷽أڬەأځتضأإةەأحًأۄوأىەأإځأڬەأضتوىەأتضأڬتأحسڬشۄأڬۏتأحًأإځأىەألشوتۏتأ=أتههۄأىەأحوۄتشەأهۏەأشتصمأىڬتهتأتضەأڬہتاأ؏أثهڬۄأتڲشأحوۄتشەأځتضأۄەأحًأۄوۏڽأثہۏأڬہهتاأ؏أإځأڬۏأرزوحأوۏڽأتضأڬتأثؼعأذظۄأځۏطأڬۏتأڲۏتأحًأإځأىەأڬہتۏتأۗ

[تخریج]: [ صحیح ]"
18962,"أذعشحأدتثشأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەأتثًؼثۏزۄأڬًأۄوتشتأتوۏشأومششأڬشأڬەأثہۏدتأۗأحتڬۄأۄوأمشۏطأڬەأمتلهًڽأڬۏأىڲشتىۏأڬشأضڬۏڽأتًشأۄوتشەأځتضأڬہدًشًڽأڬۏأتۏڬأحہۏهۏأڬەأؼهتًۄأڬًةۏأصتزأشتۄأىۄأحہتأحًأتثًؼثۏزۄأۄوۏڽأظشلأتۏڬأتۏڬأڬہدًشأزۏحەأۗأۄوأىەأځًډہتأ=أحوأتضأڬتأڬۏتأڬشحەأحہەأآأشتًۏأڬۄحەأۄۏڽأ=أۄوأتضأڬًأډًضحەأدۏضەأثډۄأډًضحتأۄەأۗأځہشأتضأڬەأثؼزأځتىۏأځۏأهۏحەأدًأۄوۏڽأتۏڬأزىأڬەأهۏەأڬتلۏأۄًحتأتًشأۄوأتځىۏأهتټہۏًڽأضەأځحەأدہتڔأڬشأځتىۏأوۏڽأحشأڬشأڬەأڬہتأهۏحەأحًأۄوۏڽأضتذهأضوىزشأځشأتۏڬأثڔەأټۏهەأڬۏأوتىىزأتۏڬأوډہهۏأىػشأإةۏأۗأتضأڬتأىتوأؼىثشأحہتأۗأتثًؼثۏزۄأىەأڬۄتأ=أۏۄأوززأۄەأۗأځہشأڬۄىەأهڲەأ=أۄوأتههۄأڬەأشتضحەأوۏڽأشضًهأتههۄأ﷽أڬەأمتظزأۄۏڽأ؏أودثًشأڬۏەأڲةەأۄۏڽأڬہتاأ؏أۄوأحۏىأضًأتلشتزأىەأتۏڬأوۄۏىۄأحڬأوډہهۏأڬہتةۏأۗأۏۄتڽأحڬأڬۄأۄوأوًټەأۄًأڲةەأتًشأۄوأتضأوډہهۏأڬۏأإىڬہأڬەأڲہڔەأضەأتۏڬأڲہڔتأحۏهأڬتأىڬتهأهۏحەأحہەأتًشأتضأضەأثۏهأڬۏأوتىىزأتۏڬأټڬڔتأڬتټأهۏحەأۗأتثًؼثۏزۄأىەأحۏشۄأإزوۏأهەأڬشأإىڬہأڬەأضًشترأوۏڽأڬہڔەأڬشأزۏەأتًشأتضأڬۏأتۏڬأځضهۏأڬہڔۏأڬشأڬەأتضأڬەأىۏډەأضەأتۏڬأثڔەأتًىټأځشأڬدتًتأشڬہأڬشأڲصتشأزۏتأتًشأۄوأىەأتضأڬتأڲًطحأصتزشتۄأڬەأهۏەأترحۏتشأڬشأهۏتأۗأۄوأىەأوزۏىۄأوۏڽأإأڬشأشضًهأتههۄأ﷽أڬًأثحتۏتأحًأإځأىەألشوتۏتأ=أۏۄأتههۄأىەأحوۄتشەأهۏەأشصمأىڬتهتأحہتأۗأڬۏتأحوۄتشەأځتضأتضأڬتأڲًطحأۄەأ؏أۄوۏڽأثہۏأڬہهتاأحًأڬډہأذظۄأۄوأىەأشضًهأتههۄأ﷽أڬۏأغشلأثہۏدتأحًأإځأىەأحىتًهألشوتۏتأۗأ+أثأ,أتذوزأثىأۏًىضأڬۏأشًتۏحأوۏڽأۄەأڬۄأۄوأضتذهأضوىزشأځشأډهەأحًأۄوأىەأتۏڬأثڔەأټۏهەأڬۏأوتىىزأڬًةۏأډۏصأزۏڬہۏأۗأدثأۄوأتضأڬەأمشۏثأإةەأحًأًۄأؼىثشأوډہهۏأحہۏأۗأۄوأتضأڬۏأإىڬہأڬەأضًتشرأضەأډشثۏأڬتأتۏڬأثشحىأىڬتهأهۏحەأحہەأتًشأۄوأثۏهأڬەأوتىىزأتضأضەأټڬڔتأڬتټأهۏحەأحہەأۗأشتًۏأڬۄحەأۄۏڽأڬۄأتىہۏڽأتضأوډہهۏأڬەأإىڬہأڬەأضًشترأوۏڽأثټہتۏتأڲۏتأۗأتضأذزۏخأڬەأإرشأوۏڽأۄەأڬۄأتضأڬتأڲًطحأۄوأىەأشضًهأتههۄأ﷽أڬًأثہۏدتأحًأإځأىەأحىتًهألشوتۏتأۗ

[تخریج]: [ صحیح ]"
18963,"أذعشحأدتثشأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأإځأىەأذعشحأتثًؼثۏزۄأڬًأحۏىأضًأإزوۏًڽأڬتأتوۏشأومششأڬشأڬەأضتذهأضوىزشأڬۏأدتىثأشتًىۄأڬۏتأۗأدتثشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأ=أوۏڽأثہۏأتىأوۏڽأطتوهأحہتأ؏أدثأۄوأىەأڬډہأضلشأغەأڬۏتأحًأۄوتشتأصتزشتۄأرحوأۄًأڲۏتأۗأذعشحأتثًؼثۏزۄأىەأځًشەأهطڬشأڬتأصتزشتۄأدوؼأڬشأهۏتأدًأڬہدًشأڬۏأزًأحہۏهۏتڽأحہۏڽأحًأۄشأزىأۄوتشۏأحہًڔۏأحہًڔۏأرًشتڬأۄًتأڬشحۏأحہۏأۗأۏۄتڽأحڬأڬۄأًۄأثہۏأرحوأۄًأڲةۏأ؏أځہشأۄوۏڽأشًصتىۄأتۏڬأڬہدًشأوهحۏأحہۏأۗأوۏڽأىەأځًډہتأ=أڬۏتأتۏڬأڬہدًشأڬلتۏحأڬشأدتحۏأحہۏأۗأشتًۏأڬۄحەأۄۏڽأ=أدثأصتزشتۄأرحوأۄًأڲۏتأحًأۄوأضتذهأضوىزشأځشأإأڲةەأ؏أدۄتڽأټۏهەأڬۏأوتىىزأتۏڬأوډہهۏأځڔۏأحہۏأحًأځًشەأهطڬشأىەأتټہتشۄأزىأتضأڬًأڬہتۏتأ؏أځہشأتثًؼثۏزۄأڬەأذڬوأضەأتضأڬۏأزًأځضهۏتڽأڬہڔۏأڬۏأڲةۏڽأحًأضًتشۏأځشأڬدتًتأشڬہأڬەأتضأڬەأىۏډەأضەأڲصتشۏأڲةۏأدًأتضأڬۏأتًىډتةۏأحڬأىۄأځۄىډأضڬۏأۗ

[تخریج]: [ صحیح ۔ متفق علیہ ]"
18964,"أذعشحأدتثشأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەأضتذهأضوىزشأڬۏأدتىثأتۏڬأډہًټتأهطڬشأثہۏدتأ؏أۄوتشتأصتزشتۄأرحوأۄًأڲۏتأۏۄتڽأحڬأڬۄأۄوأىەأحوتوأهطڬشأضەأصتزشتۄأڬًأدوؼأڬۏتأتًشأۄشأزىأتۏڬأطرظأڬەأذظۄأوۏڽأظشلأتۏڬأڬہدًشأإحۏأحہۏأۗأتۏڬأطرظأىەأدتثشأشعۏأتههۄأؼىۄأضەأڬۄتأ=أتەأتثًؼثزتههۄأ$أڬۏتأتۏڬأڬہدًشأتىضتىأڬًأڬلتۏحأڬشأدتحۏأحہۏأآأتضأىەأڬۄتأ=أتەأثہحۏدەأ$أۄوأىەأصتزشتۄأڬەأرحوأۄًىەأڬًأځتأهۏتأدضأًمحأًۄأرحوأۄًأڲۏتأ؏أدتثشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأ=أتضۏأزًشتىأۄوأىەأثۄحأثڔۏأډۏصأزۏڬہۏأۗأدثأۄوأتضأڬەأمشۏثأڲةەأحًأًۄأضوىزشأضەأثتۄشأڋتهۏأڲةۏأوډہهۏأحہۏأحًأهطڬشأىەأًۄتڽأتټہتشۄأزىأمۏتوأڬۏتأًۄأدحىتأډتۄحەأڬہتحەأۏۄتڽأحڬأڬۄأًۄأوًټەأحتصەأۄًأڲةەأۗ

[تخریج]: [ صحیح ۔ متفق علیہ ]"
18965,"أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأتۏڬأطرظأىەأشضًهأتههۄأ﷽أضەأځًډہتأ=أتەأتههۄأڬەأشضًهأ﷽أ$أۄوأضوىزشۏأضلشأوۏڽأتځىەأضتحہأحہًڔتأځتىۏأشڬہحەأۄۏڽأۗأتڲشأتضأڬەأضتحہأًعًأڬشۏڽأحًأځۏتضەأشۄأدتحەأۄۏڽأ؏أڬۏتأۄوأضوىزشأڬەأځتىۏأضەأًعًأڬشأهۏڽأإځأىەألشوتۏتأ=أتضأڬتأځتىۏأځتڬأتًشأوشزتشأذهتهأۄەأۗ

[تخریج]: [ صحیح ]"
18966,"أذعشحأدتثشأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأإځأضەأضوىزشأڬەأثتشەأوۏڽأضًتهأڬۏتأڲۏتأحًأإځأىەألشوتۏتأ=أتضأڬتأځتىۏأځتڬأتًشأوشزتشأذهتهأۄەأۗ

[تخریج]: [ صحیح ]"
18967,"أذعشحأذسۏلۄألشوتحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=أتههۄأىەأحوۄتشەأهۏەأضوىزشأڬتأطڬتشأسثذأڬەأذڬوأوۏڽأشڬہتأۄەأۗ

[تخریج]: [ ضعیف ]"
18968,"ذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأىەأتثًثڬشأشعۏأتههۄأؼىۄأڬًأۏۄأڬۄحەأۄًةەأضىتأڬۄأضوىزشأوۏڽأوًدًزأطڬتشأتههۄأىەأحوۄتشەأهۏەأسثذأڬشأزۏتأۄەأحوأڬہتاأ؏أڬۏًىڬۄأۏۄأسثذأطزۄأۄەأۗ+أثأ,أتثًؼثزتهشذوىأىەأتثًثڬشأظزۏمأشعۏأتههۄأؼىۄأڬًأۏۄألشوتحەأۄًةەأضىتأڬۄأضوىزشأوۏڽأوًدًزأډۏصۏڽأتههۄأىەأحوۄتشەأهۏەأسثذأڬشأزۏأۄۏڽأۗ

[تخریج]: [ ضعیف ]"
18969,"ذعشحأتثًغلۏهألشوتحەأۄۏڽأڬۄأضوىزشۏأوشزتشأڬەأثتشەأوۏڽأتثًثڬشأظزۏمأشعۏأتههۄأؼىۄأضەأځًډہتأڲۏتأحًألشوتۏتأڬۄأتضأڬتأځتىۏأځتڬأتًشأوشزتشأذهتهأۄەأۗ+أثأ,أؼوشًأثىأزۏىتشأتًشأتثًصثۏشأىەأتۏڬأظذتثۏأضەأضىتأ؏أدًأڬۄحەأحہەأڬۄأضوىزشأوۏڽأۄشأډۏصأسثذأطزۄأۄەأۗ

[تخریج]: [ حسن ]"
18970,"أؼڬشوۄأذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتألشوتحەأۄۏڽأ=أدضأډۏصأڬًأضوىزشأثتۄشأځہۏىڬأزەأتًشأضوىزشأضەأڬۏتأۄًتأطڬتشأډتۄەأۏۄًزۏأۏتأؼۏضتةۏأۏتأودًضۏأڬشەأتضأڬتأڬہتىتأذهتهأۄەأۗ

[تخریج]: [ ضعیف ]"
18971,"أؼڬشوۄأذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأضەأىمهألشوتحەأۄۏڽأ=أًۄأوډہهۏأإځأڬًأىمظتىأىۄأزەأڲۏأ؏أدضأڬًأهًڲًڽأوۏڽأضەأڬضۏأىەأثہۏأطڬتشأڬۏتأۄًأۗ

[تخریج]: [ ضعیف ]"
18972,"أذعشحأؼثزتههۄأثىأؼوشًأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أۄوأدۄتزأڬەأهۏەأىڬهەأحًأضرحأثہًڬأوذضًضأۄًةۏأۏۄتڽأحڬأڬۄأهطڬشأوۏڽأتۏڬأۏتأزًأزًأڬہدًشۏڽأحمضۏوأڬۏأدتحۏڽأۗأتضأزًتشىأۄوأضوىزشأڬەأڬىتشەأځشأحہەأۗأدثأضوىزشأىەأوشزۄأوډہهۏأثتۄشأځہۏىڬأزۏأحًأهًڲًڽأىەأتضأڬتأڲًطحأۏتأډشثۏأدحىتأډتۄتأڬتټأهۏتأۗأًۄأوډہهۏأتۏڬأټۏهەأڬۏأوتىىزأحہۏأۗأودہەأځحۄأډهتأڬۄأهًڲًڽأىەأدثأإأڬشأشضًهأتههۄأ﷽أڬًأثحتۏتأحًأإځأ﷽أىەأځًډہتأ=أڬۏتأحوۄتشەأځتضأتضأوۏڽأضەأڬډہأوًدًزأۄەأۗ

[تخریج]: [ صحیح ]"
18973,"أدتثشأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەأمشۏطۏأمتلهەأڬۏأحهتطأوۏڽأۄوتشەأحۏىأضًأإزوۏًڽأڬەأمتلهەأڬتأتثًؼثۏزۄأثىأدشتذأڬًأتوۏشأثىتأڬشأثہۏدتأۗأۄوأىەأضتذهأضوىزشأځشأمۏتوأڬۏتأۏۄتڽأحڬأڬۄأۄوتشتأصتزشتۄأرحوأۄًأڲۏتأدضأڬۏأثىتأځشأۄوأىەأزشرحًڽأڬەأځحەأڬہتةەأۗأځہشأضوىزشأىەأؼىثشأىتوۏأوډہهۏأثتۄشأځہۏىڬۏأحًأۄوأىەأځىزشۄأشًصأحڬأوډہهۏأڬتأڲًطحأڬہتۏتأۗأۄوتشەأدضوأحىزشضحأۄًأڲةەأۗأتثًؼثۏزۄأىەأتضأڬۏأتۏڬأځضهۏأڬًأڬہڔتأڬۏتأتًشأهطڬشأوۏڽأضەأثڔتأتًىټأتًشأهوثەأإزوۏأڬًأتضأځشأضًتشأڬشأڬەأتضأڬەأىۏډەأضەأڲصتشأزۏتأۗأتۏڬأطرظأىەأحۏىأتًىټأسثذأڬۏەأ؏أځہشأزًضشەأزىأثہۏأۗأتضأڬەأثؼزأتثًؼثۏزۄأىەأوىؼأڬشأزتۏأۗأظذتثۄأڬتأرۏتهأۄەأڬۄأًۄأمۏضأثىأضؼزأحہەأۗ

[تخریج]: [ صحیح ۔ متفق علیہ ]"
18974,"أؼڬشوۄأذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأضەأىمهألشوتحەأۄۏڽأڬۄأوۏڽأڲًتۄۏأزۏحتأۄًڽأڬۄأذعشحأتثًثڬشأظزۏمأشعۏأتههۄأؼىۄأىەألشوتۏتأ=أتۏضۏأوډہهۏأدًأوشىەأڬەأثؼزأځتىۏأځشأحۏشأإحۏأۄەأتضأڬەأهۏەأذهتهأۄەأدًأڬہتىتأډتۄەأۗ

[تخریج]: [ صحیح ]"
18975,"أًڬۏؼأضلۏتىأضەأىمهألشوتحەأۄۏڽأڬۄأوشىەأڬەأثؼزأځتىۏأڬەأتًځشأحۏشأإىەأًتهۏأوډہهۏأذهتهأۄەأۗ

[تخریج]: [ صحیح ]"
18976,"أدتثشأثىأصۏزألشوتحەأۄۏڽأڬۄأذعشحأؼوشأثىأرغتثأشعۏأتههۄأؼىۄأىەألشوتۏتأ=أټڋۏأتًشأوډہهۏأحوتوأسثذأڬۏأۄًةۏأۄۏڽأۗ

[تخریج]: [ ضعیف ]"
18977,"أذعشحأؼهۏأثىأتثۏأغتهثأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أوډہهۏتڽأتًشأټڋۏأسثذأڬۏأۄًةۏأۄۏڽأۗ

[تخریج]: [ ضعیف ]"
18978,"أذعشحأتىضأتثًتۏًثأضەأىمهألشوتحەأۄۏڽأڬۄأتىہًڽأىەأظذتثۄأڬەأضتحہأضوىزشۏأضلشأڬۏتأحًأتۏڬأوډہهۏأڬًأوشزۄأذتهحأوۏڽأځتىۏأځشأحۏشحەأځتۏتأحًأتىہًڽأىەأتثًتۏًثأضەأتضأڬەأثتشەأوۏڽأځًډہتأۗأتضأىەأڬۄتأ=أڬۏتأًۄأځتڬۏصۄأۄەأتضأڬۏأثًأحثزۏهأىۄۏڽأۄًةۏأآأتىہًڽأىەأڬۄتأ=أدۏأۄتڽأ$أحًألشوتۏتأ=أڬہتاأتًشأوۏشتأذظۄأثہۏأشڬہىتأڬۏًىڬۄأًۄأشًصۄأزتشأحہەأۗ

[تخریج]: [ ضعیف ]"
18979,"أذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتألشوتحەأۄۏڽأڬۄأوشىەأڬەأثؼزأوډہهۏأڬتأځتىۏأځشأحۏشأإىتأتضأڬەأڬہتىەأوۏڽأڬًةۏأذشدأىۄۏڽأۗ

[تخریج]: [ ضعیف ]"
18980,"أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأتًشأذعشحأصۏزأثىأختثحأشعۏأتههۄأؼىۄأڬتأرۏتهأۄەأڬۄأدضأڬًأضوىزشأثتۄشأځہۏىڬەأتضأوډہهۏأڬەأڬہتىەأوۏڽأڬًةۏأذشدأىۄۏڽأۗ

[تخریج]: [ صحیح ]"
18981,"أتثًضهوۄأخًۏثأضەأىمهألشوتحەأۄۏڽأڬۄأضوىزشأىەأثۄحأضتشۏأوډہهۏتڽأثتۄشأځہۏىڬأزۏڽأحًأۄوأىەأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأتىأڬەأثتشەأوۏڽألحًۏٳأځًډہتأۗأتىہًڽأىەأڬہتىەأڬۏأتدتصحأزەأزۏأۗأۄوأىەأتثًۄشۏشۄأشعۏأتههۄأؼىۄأڬەألحًۏٳأضەأثەأشؽثحۏأڬشحەأۄًةەأوشًتىأڬەأځتضأإةەأحًأتىہًڽأىەأصۏزأثىأختثحأشعۏأتههۄأؼىۄأضەأضًتهأڬۏتأحًألشوتۏتأ=أذهتهأۄۏڽأحوأڬہتأضڬحەأۄًأۗ

[تخریج]: [ ضعیف ]"
18982,"أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أوۏڽأثذشۏىأإۏتأحًأًۄتڽأڬەأهًڲًڽأىەأضوىزشأڬۏأثتۄشأځہۏىڬۏأۄًةۏأوډہهۏأڬەأثتشەأوۏڽأودہأضەأځًډہتأحًأوۏڽأىەأتىہۏڽأڬہتىەأڬتأذڬوأزۏتأۗأځہشأوۏڽأىەأذعشحأؼوشأشعۏأتههۄأؼىۄأضەأتضأڬەأثتشەأوۏڽأځًډہتأحًأتىہًڽأىەأڬۄتأ=أحًأىەأتىأڬًأڬۏتأذڬوأزۏتأآأتثًۄشۏشۄأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأ=أوۏڽأىەأتىأڬًأڬہتىەأڬتأڬۄتأۗأذعشحأؼوشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأ=أتڲشأحًأتضأڬەأؼهتًۄأڬډہأتًشأڬۄحتأحًأوۏڽأحدہەأزەأوتشحتأۗأځہشأذعشحأؼوشأىەأۏۄأإۏحأحهتًحأڬۏأ=أ®~أتْذٓهّٔأهّڬْوٕأظّۏٕزْأتهٕثّذٕشٓأًّأغّؼّتوْۄٚأوّحّتؼَتأهّٔڬْوٕأ¾أ^أتهوتةزۆأ<9أ`أدًأتضأضەأطڬتشأڬۏتأدتةەأتًشأدضأڬًأۏۄأثتۄشأځہۏىڬأزەأۗ

[تخریج]: [ ضعیف ]"
18983,"أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأثذشۏىأإۏتأحًأشثسۄأىتوۏأدڲۄأځشأؼشتمأڬەأوذشوأهًڲًڽأىەأځتىۏأځشأحۏشأإىەأًتهەأطڬتشأڬەأثتشەأوۏڽأودہأضەأځًډہتأ؏أًۄأتضأڬەأرشۏزىەأتًشأڬہتىەأڬەأثتشەأوۏڽأضًتهأڬشأشۄەأحہەأحًأوۏڽأىەأذتهحأتذشتوأوۏڽأتىأڬًأۏۄأطڬتشأرشۏزأڬشأڬہتىەأڬۏأتدتصحأزەأزۏأۗأځہشأوۏڽأوزۏىۄأإۏتأحًأتضأوضةهۄأڬەأثتشەأوۏڽأوۏشەأزهأوۏڽأطڬأحہتأدًأوۏڽأىەأتىأڬًأذڬوأزۏتأحًأوۏڽأىەأذعشحأؼوشأشعۏأتههۄأؼىۄأڬەأضتوىەأحسڬشۄأڬۏتأۗأتىہًڽأىەأځًډہتأ=أإځأىەأتضأڬەأثتشەأوۏڽأتىأڬًأڬۏتأذڬوأزۏتأۄەأآأتثًۄشۏشۄأڬۄحەأۄۏڽأ=أوۏڽأىەأتىہۏڽأرشۏزأڬشأڬہتىەأڬۏأتدتصحأزۏأۄەأۗأذعشحأؼوشأشعۏأتههۄأؼىۄأىەألشوتۏتأ=أتڲشأحًأتضأڬەأؼهتًۄأڬًةۏأتًشأثتحأڬۄحتأحًأوۏڽأۏۄأڬشحتأڲًۏتأڬۄأتضأڬًأزہوڬۏأزەأشۄەأحہەأۗ

[تخریج]: [ صحیح ]"
18984,"أتثًودهصأذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأضەأتههۄأڬەأتضأمًهأ=أ®~أتْذٓهّٔأهّڬْوٕأظّۏٕزْأتهٕثّذٕشٓأًّأغّؼّتوْۄٚأوّحّتؼَتأهّٔڬْوٕأ¾أ^أتهوتةزۆأ<9أ`أ†أضوىزشأڬتأطڬتشأحوۄتشەأهۏەأذهتهأڬشأزۏتأڲۏتأتًشأتضأڬتأڬہتىتأحوۄتشەأهۏەألتةزۄأڬۏأډۏصأۄەأڬەأثتشەأوۏڽألشوتحەأۄۏڽأڬۄأتضأڬتأطڬتشأحًأًۄأۄەأدضأطڬتشأڬۏتأڲۏتأتًشأڬہتىەأضەأوشتزأدًأًۄأثتۄشأځہۏىڬأزەأۗ

[تخریج]: [ صحیح ]"
18985,"أضؼۏزأثىأدثۏشأذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأضەأىمهألشوتحەأۄۏڽأڬۄأتضأڬتأطڬتشأدًأتضأضەأذتظهأڬۏتأدتةەأتًشأتضأڬتأڬہتىتأدًأثتۄشأځہۏىڬأزەأۗ

[تخریج]: [ صحیح ]"
18986,"أؼثزتهشذوىأثىأتثًۄشۏشۄأىەأذعشحأؼثزتههۄأثىأؼوشأشعۏأتههۄأؼىۄوتأضەأضوىزشأڬەأثتۄشأځہۏىڬەأۄًةەأطڬتشأڬەأثتشەأوۏڽأضًتهأڬۏتأحًألشوتۏتأ=أتضەأىۄأڬہتۏتأدتةەأۗأىتلؼأڬۄحەأۄۏڽأ=أځہشأؼثزتههۄأثىأؼوشأمشإىأهەأڬشأإةەأتًشأۏۄأإۏحأحهتًحأڬۏأ®~أتْذٓهّٔأهّڬْوٕأظّۏٕزْأتهٕثّذٕشٓأًّأغّؼّتوْۄٚأ¾أ^أتهوتةزۆأ<9أ`أىتلؼأڬۄحەأۄۏڽأ=أځہشأؼثزتههۄأثىأؼوشأشعۏأتههۄأؼىۄوتأىەأودہەأؼثزتهشذوىأثىأتثًۄشۏشۄأڬًأثهتىەأثہۏدتأڬۄأتضأڬەأڬہتىەأوۏڽأڬًةۏأذشدأىۄۏڽأۄەأۗ

[تخریج]: [ صحیح ]"
18987,أىتلؼألشوتحەأۄۏڽأڬۄأذعشحأؼثزتهشذوىأثىأتثًۄشۏشۄأىەأؼثزتههۄأثىأؼوشأضەأضوىزشأڬەأثتۄشأځہۏىڬۏأۄًةۏأډۏصأڬەأثتشەأوۏڽأضًتهأڬۏتأحًأتىہًڽأىەأۏؼىۏأتثىأؼوشأشعۏأتههۄأؼىۄوتأىەأتضأڬەأڬہتىەأضەأوىؼأڬشأزۏتأۗ
18988,"أضؼزأدتشۏأىەأذعشحأؼثزتههۄأثىأؼوشأشعۏأتههۄأؼىۄوتأضەأځًډہتأ=أًۄأوډہهۏتڽأدًأتۏڬأزًضشۏأڬًأمحهأڬشأزۏحۏأۄۏڽأۏتأضشزۏأڬۏأًدۄأضەأوشأدتحۏأۄۏڽأآألشوتۏتأ=أتىأڬەأڬہتىەأوۏڽأڬًةۏأذشدأىۄۏڽأۄەأۗأضؼزأڬۄحەأۄۏڽأ=أځہشأوۏڽأىەأؼثزتههۄأثىأؼوشًأشعۏأتههۄأؼىۄوتأضەأځًډہتأحًأتىہًڽأىەأثہۏأتضۏأڬەأوخهأۄۏألشوتۏتأۗ

[تخریج]: [ صحیح ]"
18989,"أذعشحأدتثشألشوتحەأۄۏڽأ=أدضأڬًأضوىزشأوتشأزەأۏتأثتۄشأځہۏىڬأزەأۏتأطڬتشأڬشأهۏتأدتةەأڬہتأهًأتًشأدًأضوىزشأوۏڽأوشىەأڬەأثؼزأحۏشأإةەأتضەأىۄأڬہتاأۗ

[تخریج]: [ صحیح ]"
18990,أذعشحأدتثشأىثۏأ﷽أضەأىمهألشوتحەأۄۏڽأڬۄأدثأوډہهۏأځتىۏأځشأحۏشأإةەأحًأىۄأڬہتاأتًشأدثأضوىزشأثتۄشأځہۏىڬأزەأحثأڬہتأهًأتًشأدًأتضأڬەأڬىتشًڽأځشأوهأدتةەأڬہتأهًأۗ
18991,"تثىأتثۏأتًلۏٳأثۏتىأڬشحەأۄۏڽأڬۄأوۏڽأىەأىثۏأ﷽أڬەأضتحہأضتحأؽصًەأڬۏەأۗأۄوأإځأ﷽أڬەأضتحہأټڋۏأڬہتحەأحہەأۗ+أثأ,أتثىأؼثزتىأڬۏأشًتۏحأوۏڽأۄەأڬۄأوۏڽأىەأتثىأتثۏأتًلۏٳأضەأټڋۏأڬەأثتشەأوۏڽأځًډہتأحًأتثىأتثۏأتًلۏٳأىەأڬۄتأ=أۄوأىەأشضًهأتههۄأ﷽أڬەأضتحہأډہأۏتأضتحأؽصًەأڬۏەأتًشأۄوأإځأ﷽أڬەأضتحہأټڋۏأڬہتحەأحہەأۗ+أدأ,أتثًًهۏزأضەأوىمًهأۄەأضتحأؽصًەأۏتأډہأۗ

[تخریج]: [ صحیح ۔ متفق علیہ ]"
18992,"أتثًۏؼلًشأڬۄحەأۄۏڽأڬۄأوۏڽأىەأتځىەأضتحہۏأؼثزتههۄأثىأتثۏأتًلۏٳأضەأټڋۏأڬەأثتشەأوۏڽأځًډہتأحًأتىہًڽأىەأڬۄتأ=أڬًةۏأذشدأىۄۏڽأۄوأضتحأؽصًتحأوۏڽأشضًهأتههۄأ﷽أڬەأضتحہأحہەأتًشأټڋۏأڬہتحەأحہەأۗ

[تخریج]: [ صحیح ۔ متفق علیہ ]"
18993,أذعشحأؼثزتههۄأثىأتًلۏأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أۄوأىەأشضًهأتههۄأ﷽أڬەأضتحہأډہأۏتأضتحأؽصًتحأهڔەأتًشأۄوأټڋۏأڬہتأهۏتأڬشحەأحہەأۗ
18994,"أضهوتىأشعۏأتههۄأؼىۄأضەأوىمًهأۄەأڬۄأىثۏأضەأټڋۏأڬەأثتشەأوۏڽأځًډہتأڲۏتأحًأإځأىەألشوتۏتأ=أۏۄأتههۄأڬتأثۄحأثڔتأهطڬشأۄەأىۄأحًأوۏڽأتضەأڬہتحتأۄًڽأتًشأىۄأۄۏأذشتوأمشتشأزۏحتأۄًڽأۗ

[تخریج]: [ منکر ]"
18995,"أتثًؼخوتىأىۄزۏألشوتحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=أصوۏىأځشأتههۄأڬتأضثأضەأثڔتأهطڬشأټڋۏأۄەأىۄأوۏڽأڬہتحتأۄًڽأتًشأىۄأۄۏأذشتوأمشتشأزۏحتأۄًڽأۗ

[تخریج]: [ ضعیف ]"
18996,"ضهوتىألشوتحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أضەأځًډہتأڲۏتأحًأإځأ﷽أىەأثہۏأتضۏأڬەأوخهألشوتۏتأتًشألشوتۏتأ=أتههۄأڬتأثڔتأهطڬشأۄەأۗطۏرألشوتحەأۄۏڽأ=أۏۄأوثتذأۄەأدثأذشتوأمشتشأىۄۏڽأزۏتأحًأذهتهأۄەأۗأظشلأرًزأڬہتةۏأىۄۏڽأۗ

[تخریج]: [ منکر ]"
18997,"ذعشحأؼثزتههۄأثىأؼوشأشعۏأتههۄأؼىۄوتألشوتحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=أۄوتشەأهۏەأزًأوشزتشأتًشأزًأرًىأذهتهأڬۏەأڲةەأۄۏڽأۗأزًأوشزتشأضەأوشتزأوډہهۏأتًشأټڋۏأۄەأتًشأزًأرًىأضەأوشتزأدڲشأًأحهۏأۄەأۗ+أثأ,أصۏزأثىأتضهوأذعشحأؼثزتههۄأثىأؼوشأشعۏأتههۄأؼىۄوتأضەأىمهألشوتحەأۄۏڽأڬۄأۄوتشەأهۏەأزًأوشزتشأذهتهأڬۏەأڲةەأۄۏڽأۗ

[تخریج]: [ منکر ]"
18998,"أضىتىأثىأؼثزتههۄأىەأذعشحأتىضأثىأوتهڬأضەأټڋۏأڬەأثتشەأوۏڽأځًډہتأحًألشوتۏتأ=أۄوأشضًهأتههۄأ﷽أڬەأضتحہأرۏثشأڲةەأتًشأۄوتشەأضتحہأذعشحأؼوشأشعۏأتههۄأؼىۄأثہۏأوًدًزأحہەأدىأڬەأځتضأتۏڬأټًڬشۏأحہۏأدضأوۏڽأټڋۏتڽأحہۏڽأدًأتضأىەأتځىۏأځډہهۏأدتىثأشڬہۏأحہۏڽأحًأًۄأًۄتڽأضەأټڋۏتڽأىڬتهأڬشأۄوۏڽأزۏحەأتًشأۄوۏڽأڬہتحەأۄًةەأشضًهأتههۄأ﷽أزۏڬہحەأحہەأۗأذعشحأتىضأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأدثأۄوأوزۏىۄأًتځضأإةەأحًأۄوأىەأتىأضەأرشۏزأهۏڽأ؏أځہشأۄوأهوثتأصوتىۄأتضأضەأڬہتحەأشۄەأۗ

[تخریج]: [ صحیح ]"
18999,"أذعشحأؼثزتههۄأثىأؼوشأشعۏأتههۄأؼىۄوتألشوتحەأۄۏڽأڬۄأذعشحأؼوشأثىأرغتثأشعۏأتههۄأؼىۄأضەأټڋۏأڬەأثتشەأوۏڽأضًتهأڬۏتأڲۏتأحًألشوتۏتأوۏڽأځضىزأڬشحتأۄًڽأڬۄأوۏشەأځتضأټڋۏأڬۏأثہشۏأۄًةۏأتۏڬأټًڬشۏأۄًأدضەأۄوأڬہتحەأشۄۏڽأۗ

[تخریج]: [ صحیح ]"
19000,"ًتۄثأثىأؼثزتههۄأولترشۏأتًشأؼثزتههۄأثىأؼوشأشعۏأتههۄأؼىۄوتأىثۏأ﷽أڬۏأځشًشطأوۏڽأوًدًزأؼًشحأڬەأځتضأإةەأۗأتضأىەأتىأڬەأضتوىەأڲہۏأوۏڽأثہىۏأۄًةۏأټڋۏأځۏطأڬۏأتًشأڬۄتأ=أتەأوظشۏأ$أۏۄأڬہتاأطتۏزأإځأڬًأډًځتةەأتضأضەأصۏتزۄأوذثًثأۄًڽأۗأوۏڽأىەأڬۄتأ=أۄوۏڽأډًځتةەأصۏتزۄأوذثًثأۄۏڽأحًأتضأىەأڬۄتأ=أتەأوظشۏأ$أڬضۏأىثۏأ﷽أىەأتههۄأضەأتۏضەأځشىزەأڬەأڲًطحأڬتأضًتهأڬۏتأدضأڬًأسثذأىۄأڬۏتأدتةەأحًأتههۄأىەأوډہهۏتڽأتًشأټڋۏأؼغتأڬۏڽأۗ+أثأ,أظزۏأثىأؼدهتىأتثًتوتوۄأثتۄهۏألشوتحەأۄۏڽأڬۄأىثۏأ﷽أىەألشوتۏتأ=أؼوشتىأڬۏأثۏټۏأوشۏوأىەأتځىەأشثأضەأضًتهأڬۏتأڬۄأتضەأتۏضتأڲًطحأڬہهتةەأدضأوۏڽأرًىأىۄأۄًأحًأتههۄأىەأتضأڬًأټڋۏأڬہهتةۏأۗأتضأىەأڬۄتأ=أتەأتههۄأ$أتضأڬًأثؽۏشأزًزہأڬەأصىزۄأشڬہأتًشأحًأتضأڬًأثؽۏشأإًتصأڬەأشتىأڬەأځۏډہەأهڲتأزەأوۏڽأىەأځًډہتأ=أتەأتثًتهلعهأ$أطۏتؼأڬۏتأۄەأآأتىہًڽأىەأڬۄتأ=أإًتصأۗ

[تخریج]: [ ضعیف ]"
19001,"أذعشحأتىضأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأتصًتدأوغۄشتحأټڋۏأڬہتحۏڽأتًشأتۏڬأزًضشۏأڬًأحذلۄأزۏتأڬشحۏأحہۏڽأۗأۏصۏزأڬۄحەأۄۏڽأ=أوۏڽأىەأضؼۏزأضەأځًډہتأ=أإځأىەأذعشحأتىضأشعۏأتههۄأؼىۄأضەأضىتأۄەأآأتىہًڽأىەأڬۄتأ=أۄتڽأوۏڽأىەأضىتأۄەأۗ

[تخریج]: [ ضعیف ]"
19002,"ضؼۏزأثىأوضۏثألشوتحەأۄۏڽأڬۄأذعشحأؼوشأشعۏأتههۄأؼىۄأؼثزتههۄأثىأؼوشأشعۏأتههۄأؼىۄوتأومزتزأثىأضًۏزأتًشأظۄۏثأټڋۏأڬہتحەأحہەأۗأذعشحأؼوشأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أتڲشډۄأۄوتشەأځتضأتۏڬأۏتأزًأټًڬشۏتڽأثہۏأڬۏًڽأىۄأۄًڽأۗ+أثأ,أذعشحأؼهۏأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأوډہهۏأتًشأټڋۏأسثذأڬۏأۄًةۏأۄەأۗ

[تخریج]: [ صحیح ]"
19003,"أذعشحأتثًضؼۏزأرزشۏأشعۏأتههۄأؼىۄأزۏڬہحەأڬۄأتىأڬەأثۏټەأتًشأڲہشأًتهەأټڋۏأڬہتحەأۄۏڽأحًأتىأڬًأوىؼأىۄأڬشحەأتًشأرًزأىۄأڬہتحەأۗأصۏىثأڬۄحۏأۄۏڽأ=أوۏشتأرۏتهأۄەأڬۄأًۄأتضأڬًأتډہتأىۄأضودہحەأۗ

[تخریج]: [ ضعیف ]"
19004,"أذعشحأؼثزتهشذوىأثىأؼخوتىألشوتحەأۄۏڽأڬۄأتۏڬأڋتڬټشأىەأوۏىڋڬأڬًأمحهأڬشأڬەأزًتةۏًڽأوۏڽأتضحؼوتهأڬشىەأڬەأثتشەأوۏڽأځًډہتأحًأإځأ﷽أىەأتضأڬەأمحهأضەأوىؼأڬشأزۏتأۗ

[تخریج]: [ ضعیف ]"
