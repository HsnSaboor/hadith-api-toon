hadiths[61]{hadithnumber,text}:
11635,"أذعشحأؼوشأثىأرغتثأشعۏأتههۄأؼىۄأضەأتضأمظۄأوۏڽأوىمًهأۄەأڬۄأتىأ+أؼًشحًڽأ,أڬەأثتځأ+أطؼۏثأؼهۏۄأتهضهتوأ,أىەأځًډہتأ=أحوۄۏڽأڬۏضەأؼهوأۄەأتضأڬۏأمًحأتًشأتوتىحأزتشۏأڬتأآأحًأتضأىەأڬۄتأ=أتضأڬۏأمًحأۏۄأۄەأڬۄأتضأىەأتڬۏهەأۄۏأًۄأڋًهأڬہۏىډأهۏتأدضەأزضأإزوۏأتټہتحەأحہەأتًشأتضأڬۏأتوتىحأتضأڬتأۏۄأڬۄىتأڬۄأحًأوۏشەأځۏډہەأډهأتًشأشتضحۄأثحتأزۏىتأ؏أۏۄأتضأهۏەأڬۄأۄًتأحۏشتأدضوأوۏشەأهۏەأؼۏتڽأىۄأڬشأزەأۗ

[تخریج]: [ ضعیف ]"
11636,"أتۏڬأشًتۏحأوۏڽأتهلتػأۄۏڽأڬۄأطؼۏثأىەأڬۄتأ=أوۏڽأتشتزۄأشڬہحتأۄًڽأڬۄأوۏڽأحۏشتأىڬتذأتىأزًأثۏټۏًڽأوۏڽأضەأڬضۏأتۏڬأثۏټۏأڬەأضتحہأڬشأزًڽأڲتأ؏أتضأطشغأځشأڬۄأحًأوۏشەأۄتڽأإټہأضتهأىًڬشۏأڬشەأۗأځضأتڲشأحًأزضأضتهأځًشەأڬشەأڲتأحًأحۏشۏأغشلأضەأۄەأتًشأوۏڽأتشتزۄأىۄۏڽأشڬہحتأڬۄأحدہأځشأضرحۏأڬشًڽأۗأتڲشأتههۄأىەأډتۄتأحًأحًأودہەأظتهذأهًڲًڽأوۏڽأځتةەأڲتأۗأ^أتهمظظأ=أ5:أ`أۏؼىۏأشۄىەأڬەأتؼحثتشأضەأتډہتأتًشأدًأوۏڽأىەأڬۄتأۄەأتضأڬًأځًشتأڬشىەأوۏڽأۗأوًضۏٳأىەأڬۄتأ=أۏۄأوۏشەأتًشأحۏشەأزشوۏتىأۄەأڬۄأوۏڽأزًىًڽأوزحًڽأوۏڽأضەأڬضۏأڬًأځًشتأڬشًڽأۗأځضأوۏشەأتًځشأصۏتزحۏأىۄأۄًأۗأ^أتهمظظأ=أ5;أ`أتضأىەأڬۄتأ=أۄتڽأتههۄأحؼتهۏٳأدًأۄوأىەأڬۄتأتضأځشأًڬۏهأۄەأۗأ+أۏًضلأ,أځضأتضأ+أطؼۏثأ,أىەأتضأڬەأضتحہأثۏټۏأڬۏأطتزۏأڬۏأتًشأًۄأتضأڬەأضتحہأشۄەأتًشأتىأڬۏأثڬشۏًڽأڬتأڬتوأڬشحەأشۄەأۗ

[تخریج]: [ ضعیف ]"
11637,"أذعشحأضؼۏزأثىأدثۏشأشعۏأتههۄأؼىۄأضەأشًتۏحأۄەأڬۄأودہەأتۄهأۄۏشۄأڬەأۏۄًزۏًڽأوۏڽأضەأتۏڬأإزوۏأوهتأ؏أتضأىەأودہأضەأضًتهأڬۏتأڬۄأوًضۏٳأ+أؼهۏۄأتهضهتوأ,أىەأزًىًڽأوزحًڽأوۏڽأضەأڬضأڬًأځًشتأڬۏتأآأوۏڽأىەأڬۄتأ=أوۏڽأىۄۏڽأدتىحتأۗأوۏڽأڬهأتثىأؼثتضأڬەأځتضأدتاڽأڲتأ؏أډىتىډۄأوۏڽأتىأڬەأځتضأڲۏتأ؏أوۏڽأىەأتىأضەأضًتهأڬۏتأحًأتىہًڽأىەأدًتثأزۏتأڬۄأوًضۏٳأ+أؼهۏۄأتهضهتوأ,أىەأًۄأوزحأځًشۏأڬۏأدًأصۏتزۄأتًشأځتڬۏصۄأحہۏأۗأوۏڽأىەأۏۄًزۏأڬًأرثشأزۏأحًأتضأىەأڬۄتأ=أحوۄتشتأًۄأظتذثأؼتهوأۄەأۗ

[تخریج]: [ صحیح ]"
11638,"أذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄوتأضەأشًتۏحأۄەأڬۄأشضًهأتههۄأ﷽أضەأضًتهأڬۏتأڲۏتأڬۄأوًضۏٳأ+أؼهۏۄأتهضهتوأ,أىەأزًىًڽأوزحًڽأوۏڽأضەأڬًىضۏأځًشۏأڬۏأآأإځأ﷽أىەألشوتۏتأ=أزًىًڽأوۏڽأضەأثؼزأًتهۏأتًشأځتڬۏصۄأۗ

[تخریج]: [ ضعیف ]"
11639,"أذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄوتأضەأشًتۏحأۄەأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=أوۏڽأىەأدثشتةۏهأضەأضًتهأڬۏتأڬۄأوًضۏٳأ+أؼهۏۄأتهضهتوأ,أىەأزًىًڽأوزحًڽأوۏڽأضەأڬًىضۏأځًشۏأڬۏأآأحًأدثشتةۏهأىەأڬۄتأ=أتىأوۏڽأضەأدًأځًشۏأ+أ43أ,أحہۏأتًشأوڬوهأحہۏأۗ

[تخریج]: [ ضعیف ۔ الحمیدی 545 ]"
11640,"أذعشحأؼثزتههۄأثىأؼوشأشعۏأتههۄأؼىۄوتأضەأشًتۏحأۄەأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=أحۏىأإزوۏأډهأشۄەأحہەأ؏أتىأڬًأثتشطأىەأشًڬأزۏتأۗأتىہًڽأىەأتۏڬأځۄتڔأڬۏأؽتشأوۏڽأځىتۄأهۏأۗأتضۏأزًشتىأتۏڬأځحہشأځۄتڔأضەأڲشتأتًشأؽتشأڬەأوىۄأځشأإأڲۏتأۗأًۄأتۏڬأزًضشەأضەأڬۄىەأهڲەأ=أتځىەأتځىەأثۄحشۏڽأتؼوتهأۏتزأڬشًأتًشأتىأڬەأضتحہأتههۄأڬًأځڬتشًأحتڬۄأًۄأتضأڬۏأًدۄأضەأحوۄتشەأتًځشأضەأځحہشأۄټتأزەأۗأتىأوۏڽأضەأتۏڬأىەأڬۄتأ=أتەأتههۄأ$أوۏشەأًتهزۏىأثًڔہەأحہەأتًشأوۏشۏأثۏًۏأتًشأثډەأثہۏأحہەأۗأوۏڽأتىأڬۏأځشًشطأڬەأهۏەأثڬشۏتڽأډشتحتأحہتأۗأدثأوۏڽأطتوأڬًأًتځضأإحتأحًأضثأضەأځۄهەأوۏڽأتځىەأًتهزۏىأڬًأزًزہأځهتحتأۗأتۏڬأزىأزشرحأڬۏأحهتطأوۏڽأزًشأىڬهأڲۏتأ؏أدثأًتځضأإۏتأحًأًۄأزًىًڽأضًأډڬەأحہەأۗأوۏڽأىەأثشحىأځڬڔتأتًشأزًزہأزًۄتأۗأځہشأوۏڽأزًزہأهەأڬشأتځىەأًتهزۏىأڬەأضشأڬەأځتضأڬہڔتأۄًأڲۏتأتًشأوۏشەأثډەأوۏشەأځتاڽأڬەأځتضأثهڬأشۄەأحہەأۗأوۏڽأىەأىتځضىزأڬۏتأڬۄأتىأڬًأىۏىزأضەأثۏزتشأڬشًڽأۗأوۏڽأڬہڔتأشۄتأۏۄتڽأحڬأڬۄألدشأځہًټأځڔۏأۗأتەأتههۄأ$أثۏطڬأحًأدتىحتأۄەأوۏڽأىەأۏۄأظشلأحۏشۏأشعتأڬەأهۏەأڬۏتأحًأۄوأضەأتضأځحہشأڬًأۄټتأزەأحتڬۄأۄوأإضوتىأزۏڬہأهۏڽأۗأًۄأځحہشأۄټتأتًشأتىہًڽأىەأإضوتىأزۏڬہأهۏتأتًشأزًضشەأىەأڬۄتأ=أتەأتههۄأ$أوۏشۏأتۏڬأډډتأصتزأحہۏأ؏أوۏڽأتضەأځضىزأڬشحتأحہتأًۄأودہەأضثأهًڲًڽأضەأصۏتزۄأوذثًثأحہۏأۗأوۏڽأىەأتضأضەأصىتأڬشىەأڬتأڬۄتأ؏أتضأىەأڬۄتأ=أځۄهەأحًأودہەأضًأزۏىتشأزەأۗأوۏڽأىەأڬًططأڬۏأ؏أضًأزۏىتشأدوؼأڬۏەأ؏أځہشأتضأڬەأځتضأإۏتأۗأدثأوۏڽأتضأڬۏأټتىڲًڽأڬەأزشوۏتىأحہتأحًأتضأىەأڬۄتأ=أتههۄأضەأڋشأتًشأوۄشأڬًأىۄأحًڔأوڲشأدتةصأغشۏمەأضەأ+أىڬتذأضەأ,أۗأوۏڽأڬہڔتأۄًأڲۏتأۗأتەأتههۄأ$أحًأدتىحتأۄەأوۏڽأىەأۏۄأڬتوأحۏشۏأشعتأڬەأهۏەأڬۏتأحًأۄوأضەأتضأځحہشأڬًأۄټتأزەأۗأًۄأحہًڔتأضتأتًشأۄټأڲۏتأتًشأحۏضشەأىەأڬۄتأ=أتەأتههۄأ$أوۏڽأىەأتۏڬأوصزًشأهڲتۏتأحہتأدثأتضأىەأتځىتأڬتوأڬۏتأحًأوۏڽأىەأوصزًشۏأزۏأۗأتضأىەأهۏىەأضەأتىڬتشأڬشأزۏتأۗأتضأىەأثەأشؽثحۏأڬۏأۗأوۏڽأۄوۏطۄأتضأضەأڬتوأڬشحتأشۄتأۏۄتڽأحڬأڬۄأوۏڽأىەأتضأضەأثۄحأصۏتزۄأڲتةۏڽأتًشأثڬشۏتڽأدوؼأڬشأهۏڽأۗأًۄأإزوۏأإۏتأتًشأتضأىەأڬۄتأ=أتههۄأضەأڋشأتًشأودہەأوۏشتأذمأزەأتًشأوۏشەأتًځشأػهوأىۄأڬشأۗأوۏڽأىەأڬۄتأ=أدتأتًشأۏۄأڲتةۏڽأتًشأثڬشۏتڽأهەأدتأۗأتضأىەأڬۄتأ=أتههۄأضەأڋشأتًشأوستمأىۄأڬشأۗأوۏڽأىەأڬۄتأ=أوۏڽأوستمأىۄۏڽأڬشأشۄتأدتأتًشأڲتةۏڽأتًشأثڬشۏتڽأهەأدتأۗأًۄأهەأڲۏتأۗأتەأتههۄأ$أحًأدتىحتأۄەأوۏڽأىەأۏۄأحۏشۏأشعتأڬەأهۏەأڬۏتأحہتأحًأثتمۏأوتىزۄأځحہشأثہۏأۄټتأزەأۗأتههۄأحؼتهۏٳأىەأًۄأځحہشأثہۏأۄټتأزۏتأځہشأًۄأىڬهەأتًشأډهىەأهڲەأۗ

[تخریج]: [ بخاری 2272 ، مسلم 2743 ]"
11641,"أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأوۏڽأىەأشضًهأتههۄأ﷽أضەأضىتأ=أتههۄأىەأڬًةۏأىثۏأتۏضتأىۄۏڽأثہۏدتأدضأىەأثڬشۏتڽأىۄأډشتةۏأۄًڽأۗأظذتثۄأىەأځًډہتأ=أۏتأشضًهأتههۄأ﷽أ$أإځأىەأثہۏأډشتةۏأۄۏڽأآأإځأ﷽أىەألشوتۏتأ=أۄتڽأوۏڽأثہۏأمشتشۏغأوۏڽأتۄهأوڬۄأڬۏأثڬشۏتڽأډشتحتأحہتأۗ

[تخریج]: [ بخاری 2262 ]"
11642,"أذعشحأدتثشأضەأشًتۏحأۄەأڬۄأذعشحأرزۏدۄأشعۏأتههۄأؼىۄتأىەأىثۏأ﷽أڬًأزًأضلشًڽأڬۏأوصزًشۏأزۏأۗأدشطأڬۏأغشلأضلشأۄًتأۗأتۏڬأضلشأڬەأثزهەأتۏڬأتًىټىۏأزۏأۗأزًضشۏأشًتۏحأڬەأتهلتػأۄۏڽأڬۄأإځأ﷽أىەألشوتۏتأ=أوۏڽأىەأرزۏدۄأضەأزًأضلشًڽأوۏڽأتًىټىۏأتدشحأهۏأۗ

[تخریج]: [ صحیح ]"
11643,"أذعشحأؼتةطۄأضەأشًتۏحأۄەأڬۄأشضًهأتههۄأ﷽أتًشأذعشحأتثًثڬشأشعۏأتههۄأؼىۄأىەأثىۏأزۏهأڬەأإزوۏأڬًأوصزًشۏأځشأشڬہتأۗأځہشأثىۏأؼثتزأضەأوتۄشأشۄثشأهۏتأۗأتهرشۏحأڬتأوؼىۏأوتۄشأشۄثأشۄەأۗأتضأىەأتځىتأۄتحہأرتىزتىأؼتظأثىأًتةهأڬەأضتحہأًؼزۄأڬشأڬەأڋثًۏتأحہتأڬۄأًۄأڬلتشأمشۏطأڬەأزۏىأځشأشۄەأڲتأۗأهۏڬىأتىأزًىًڽأڬًأتضأځشأتغوۏىتىأحہتأۗأتىہًڽأىەأتضەأتځىۏأضًتشۏتڽأزۏأحہۏڽأتًشأًؼزۄأڬۏتأحہتأڬۄأحۏىأشتحًڽأثؼزأؽتشأخًشأإةەأڲتأۗأډىتىډۄأًۄأزًىًڽأڬەأځتضأحۏضشۏأشتحأڬۏأظثذأڬًأإۏتأ؏أًۄأزًىًڽأضًتشأۄًةەأتًشأؼتوشأثىألۄۏشۄأتًشأزۏهۏأإزوۏأثہۏأضتحہأۗأۏۄأشۄثشأضتذهأڬەأڬىتشەأضەأإځأتًشأتثًثڬشأڬًأهەأڬشأډهتأحہتأۗ

[تخریج]: [ بخاری 2263 ]"
11644,"أذعشحأتثىأؼوشأضەأشًتۏحأۄەأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=أحوۄتشۏأوختهأتًشأحوأضەأځۄهەأۏۄًزۏًڽأتًشأىظشتىۏًڽأڬۏأوختهأتۏضۏأۄەأڬۄأڬضۏأطرظأىەأڬةۏأوصزًشأڬتوأځشأهڲتةەأتًشأتضأىەأڬۄتأ=أڬًىأۄەأدًأتۏڬأمۏشتغأڬەأثزهەأظثذأضەأزًځۄشأحڬأڬتوأڬشەأآأځضأىظتشۏٳأىەأڬتوأڬۏتأ؏أځہشأتضأىەأڬۄتأ=أڬًىأۄەأدًأزًځۄشأضەأؼظشأحڬأتۏڬأمۏشتغأڬەأثزهەأۏۄأڬتوأڬشەأڲتأۗأۏۄًزۏًڽأىەأۏۄأڬتوأڬۏتأۗأځہشأتضأىەأڬۄتأ=أڬًىأۄەأدًأزًأمۏشتغأڬەأثزهەأؼظشأضەأوؽشثأحڬأڬتوأڬشەأڲتأآأحًأحوأىەأڬتوأڬۏتأۗأۏۄًزأًأىظتشۏٳأؽعثأوۏڽأإأڲةەأتًشأڬۄىەأهڲەأ=أڬۏتأۄەأۄوأڬتوأصۏتزۄأڬشۏڽأتًشأوصزًشۏأڬوأوهەأۗأًۄأإزوۏأڬۄىەأهڲتأ=أڬۏتأوۏڽأىەأحوأڬًأڬوأتدشحأزۏأۄەأًۄأڬۄۏڽأڲەأ=أىۄۏڽأځہشأًۄأڬۄەأڲتأ=أًۄأوۏشتألعهأحہتأدضەأډتۄتأزەأزۏتأۗ

[تخریج]: [ بخاری 2268 ]"
11645,"أذعشحأؼثزتههۄأثىأؼوشأشعۏأتههۄأؼىۄوتأضەأشًتۏحأۄەأڬۄأشضًهأتههۄأ﷽أڬًأوىثشأځشألشوتحەأۄًةەأضىتأ=أحوۄتشتأصوتىۄأڲصشەأۄًةەأصوتىًڽأڬەأومتثهەأوۏڽأتضأغشذأۄەأدۏضەأىوتصأؼظشأضەأىوتصأوؽشثأڬتأًمحأۄًحتأۄەأۗأتۄهٓأحًشتۆأڬًأحًشتۆأزۏأڲةۏأ؏أتىہًڽأىەأتضأځشأؼوهأڬۏتأۏۄتڽأحڬأڬۄأزًځۄشأۄًأڲةۏأۗأځہشأًۄأؼتدصأإأڲةەأ؏أځضأتىہۏڽأتۏڬأتۏڬأمۏشتغأزۏتأڲۏتأتًشأتۄهأتىدۏهأڬًأتىدۏهأزۏأڲةۏأۗأتىہًڽأىەأتضأځشأؼوهأڬۏتأۏۄتڽأحڬأڬۄأؼظشأڬۏأىوتصأۄًأڲةۏأۗأځہشأًۄأؼتدصأإأڲةەأ؏أځضأتىہۏڽأتۏڬأتۏڬأمۏشتغأزۏتأڲۏتأ؏أځہشأحوأڬًأمشإىأزۏتأڲۏتأځضأحوأىەأضۏڬہتأۏۄتڽأحڬأڬۄأوؽشثأۄًأڲةۏأځضأحوأڬًأزًأزًأمۏشتغأزۏەأڲةەأۗأځضأتۄهأحًشتۆأتًشأتۄهأتىدۏهأىەأڬۄتأ=أتەأۄوتشەأشثأ$أتىأڬًأؼوهأڬوأتًشأثزهۄأصۏتزۄأزۏتأۄەأۗأتههۄأحؼتهۏٳأىەأڬۄتأ=أڬۏتأوۏڽأىەأحوۄتشەأتدشأوۏڽأڬًةۏأڬوۏأۄەأآأتىہًڽأىەأڬۄتأ=أىۄۏڽأ؏أځہشأڬۄتأ=أۏۄأوۏشتألعهأۄەأوۏڽأدضەأډتۄحتأۄًڽأؼغتأڬشحتأۄًڽأۗ

[تخریج]: [ بخاری 7467 ]"
11646,"أذعشحأتثًوًضۏٳأشعۏأتههۄأؼىۄأىثۏأ﷽أضەأىمهألشوتحەأۄۏڽأڬۄأوضهوتىًڽأتًشأۏۄًزۏًڽأًأؼۏضتةۏًڽأڬۏأوختهأتضأإزوۏأڬۏأغشذأۄەأدضأىەأڬډہأوصزًشأهڲتةەأڬۄأًۄأظثذأضەأشتحأحڬأتۏڬأوؼهًوأوؼتًعەأځشأڬتوأڬشۏڽأڲەأۗأځضأتىہًڽأىەأزًځۄشأحڬأڬتوأڬۏتأۗأځہشأتىہًڽأىەأڬۄتأ=أۄوۏڽأحۏشۏأوصزًشۏأڬۏأڬًةۏأعشًشحأىۄۏڽأۗأدًأحًأىەأطشغأهڲتةۏأۄەأتًشأدًأۄوأىەأڬتوأڬۏتأًۄأثہۏأثتغهأۄەأۗأځضأتضأىەأتىأڬًأڬۄتأ=أحوأتۏضەأىۄأڬشًأثتمۏأزىأثہۏأڬتوأڬشًأۗأځہشأتځىۏأوڬوهأتدشحأهًأ؏أځضأتىہًڽأىەأتىڬتشأڬشأزۏتأتًشأًۄأډہًڔأڬشأډهەأڲةەأتضأىەأتًشأهًڲًڽأڬًأوصزًشۏأځشأهڲتۏتأتًشأڬۄتأ=أحوأثتمۏأزىأڬتوأڬشًأتًشأحوۄتشەأهۏەأًۄۏأۄەأدًأوۏڽأىەأطشغأهڲتةۏأۄەأ؏أځضأتىہًڽأىەأڬتوأڬۏتأۏۄتڽأحڬأڬۄأؼظشأڬتأًمحأۄًأڲۏتأ؏أتىہًڽأىەأڬۄتأ=أدًأۄوأىەأڬتوأڬۏتأًۄأثتغهأۄەأتًشأدًأتدشحأحًأىەأۄوتشەأهۏەأومششأڬۏأحہۏأًۄأثہۏأحۏشۏأۄۏأۄەأۗأۄوۏڽأتضأڬۏأڬًةۏأعشًشحأىۄۏڽأځضأتضأىەأتىأضەأڬۄتأ=أثتمۏأزىأثہۏأڬتوأڬشًأ؏أزىأڬتأحہًڔتأضتأذظۄأشۄأڲۏتأۄەأتًشأتځىۏأتدشحأهەأهًأۗأتىہًڽأىەأتىڬتشأڬشأزۏتأۗأتضأإزوۏأىەأتۏڬأتًشأمًوأڬًأوصزًشۏأځشأهڲتۏتأۗأتىہًڽأىەأثتمۏأزىأڬتوأڬۏتأۏۄتڽأحڬأڬۄأدثأوؽشثأۄًةۏأحًأتىہًڽأىەأځۄهۏأزًأدوتؼحًڽأڬۏأتدشحأځًشۏأهەأهۏأۗأځضأۏۄأوختهأۄەأۏۄًزأًأىظتشۏٳأڬۏأڬۄأتىہًڽأىەأتضأډۏصأڬًأډہًڔأزۏتأدًأتههۄأىەأتىأڬًأذڬوأزۏتأحہتأتًشأوضهوتىًڽأڬۏأوختهأۏۄأڬۄأتىہًڽأىەأتههۄأڬۏأۄزتۏحأڬًأتًشأشضًهأتههۄأ﷽أدًأډۏصأهەأڬشأإةەأتضەأمثًهأڬشأهۏتأۗ

[تخریج]: [ بخاری 2271 ]"
11647,"ذعشحأتثًوضؼًزأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أدثأۄوۏڽأظزمۄأڬتأذڬوأزۏحەأحًأۄوأوۏڽأضەأثؼعأهًڲأثتصتشأڬۏأغشلأدتحەأثًدہأتټہتحەأتًشأتۏڬأوزأ+أؽهۄأ,أڬتأذتظهأڬشحەأۗأهۏڬىأإدأثؼعأتۏضەأۄۏڽأدىأڬەأځتضأتۏڬأهتڬہأوًدًزأۄۏڽأتًشأوۏڽأتځىەأإځأڬًأتۏضتأرۏتهأڬشحتأۄًڽأۗذعشحأشتلؼأثىأرزۏدأشعۏأتههۄأؼىۄأضەأصوۏىأضًىەأتًشأډتىزۏأڬەأؼًعأڬشتةەأځشأزۏىەأڬەأثتشەأوۏڽأوىمًهأۄەأڬۄأشضًهأتههۄأ﷽أڬەأظذتثۄأتدشحأځشأڬتوأڬۏتأڬشحەأحہەأۗ

[تخریج]: [ بخاری 2273 ]"
11648,"أذعشحأؼثزتهشذوىأثىأؼًلأشعۏأتههۄأؼىۄأىەأصوۏىأڬشتةەأځشأهۏأ؏أًۄأتىأڬەأمثعۄأوۏڽأشۄۏأۗأۏۄتڽأحڬأڬۄأًۄألًحأۄًأڲةەأۗأتىأڬەأثۏټەأىەأڬۄتأ=أوۏڽأىەأتځىەأثتځأڬەأمثعۄأوۏڽأصۏتزۄأؼشظۄأشۄىەأڬۏأًدۄأضەأڲوتىأڬۏتأڬۄأًۄأتىأڬۏأوهڬۏحأۄەأۗأۏۄتڽأحڬأڬۄأًلتحأڬەأًمحأتىہًڽأىەأثحتۏتأتًشأۄوۏڽأذڬوأزۏتأڬۄأضًىتأتًشأډتىزۏأزەأڬشأڬډہأڬشتۏۄأتزتأڬشۏڽأۗ

[تخریج]: [ ضعیف ]"
11649,"أذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄأضەأوىمًهأۄەأڬۄأىثۏأ﷽أڬًأڬډہأوطڬهأځۏطأإةۏأۗأذعشحأؼهۏأشعۏأتههۄأؼىۄأڬًأتضأڬتأځحۄأډهتأۗأًۄأڬتوأڬۏأحهتطأوۏڽأىڬهەأحتڬۄأڬډہأهەأڬشأىثۏأ﷽أڬەأځتضأإةۏڽأۗأًۄأۏۄًزۏأڬەأثتؽأوۏڽأإةەأتًشأضحشۄأڋًهأځتىۏأزۏتأۗأۄشأڋًهأڬەأثزهەأڬہدًشۏڽأۗأۏۄًزۏأىەأضحشۄأؼدًۄأڬہدًشۏڽأزەأزۏڽأۗأًۄأهەأڬشأىثۏأ﷽أڬەأځتضأإةەأۗأإځأ﷽أىەألشوتۏتأ=أتەأتثًتهذضىأ$أۏۄأڬۄتڽأضەأهتةەأۄًأآألشوتىەأهڲەأ=أودہەأځحۄأډهتأحہتأڬۄأإځأحىڲۏأوۏڽأۄۏڽأ؏أتەأتههۄأڬەأىثۏأ$أوۏڽأىڬهتأوۏڽأڬتوأحهتطأڬشىەأهڲتأحتڬۄأإځأ﷽أڬەأهۏەأڬہتىتأهتاڽأۗأإځأ﷽أىەألشوتۏتأ=أحدہەأتههۄأتًشأتضأڬەأشضًهأ﷽أڬۏأوذثحأىەأتضأډۏصأځشأتثہتشتأآأذعشحأؼهۏأىەألشوتۏتأ=أۄتڽأتههۄأڬەأشضًهأ﷽أ$أإځأ﷽أىەألشوتۏتأ=أدًأثىزۄأتههۄأتًشأتضأڬەأشضًهأ﷽أضەأوذثحأڬشحتأۄەأحًألمشأًألتمۄأتضأڬۏأغشلأثۄىەأًتهەأضۏهتثأضەأثہۏأصۏتزۄأدهزۏأإحتأۄەأۗأدًأتههۄأتًشأتضأڬەأشضًهأضەأوذثحأڬشحتأۄەأًۄأدلتڬطۏأۏؼىۏأظثشأڬەأهۏەأحۏتشأۄًأدتةەأۗ

[تخریج]: [ ضعیف ]"
11650,"أودتۄزألشوتحەأۄۏڽأڬۄأذعشحأؼهۏأۄوتشەأځتضأإةەأۗأإځأىەأزہتشۏأزتشأډتزشأتًڔہۏأۄًةۏأحہۏأۗأڬۄىەأهڲەأ=أدثأۏۄأإۏحأىتصهأۄًةۏأ®~ألّحًّّهّٔأؼّىٕۄْوٕألّوّتأتّٗىٕحّأثٓوّهًْوِأ¾أ+أځضأإځأتىأضەأوىۄأځہۏشأهۏڽأۗأإځأمتثهأوهتوحأىۄۏڽأۄۏڽأ,أحًأۄوأوۏڽأضەأۄشأتۏڬأڬًألًحأۄًىەأڬتأۏمۏىأۄًأڲۏتأۗأدثأىثۏأ﷽أڬًأذڬوأۄًتأڬۄأإځأۄوأضەأوىۄأځہۏشأهۏڽأۗأدثأۏۄأإۏحأىتصهأۄًةۏأحًأذعشحأؼهۏأشعۏأتههۄأؼىۄأىەأثۏتىأڬۏتأڬۄأًۄأتۏڬأتىظتشۏأؼًشحأڬەأځتضأضەأڲصشەأتًشأتضأڬەأزشًتصەأڬەأضتوىەأوټۏأحہۏأۗأوۏڽأىەأڬۄتأ=أحًأتضەأڲًىزہىەأڬتأتشتزۄأشڬہحۏأۄەأآأتضأىەأڬۄتأ=أۄتڽأۗأوۏڽأىەأطشغأهڲتةۏأڬۄأۄشأڋًهأڬەأثزهەأڬہدًشأزەأۗأوۏڽأىەأتضأوټۏأڬًأڲًىزہتأتًشأتضأىەأودہەأضًهۄأڬہدًشۏڽأزۏڽأۗأوۏڽأًۄأهەأڬشأىثۏأ﷽أڬەأځتضأإۏتأ؏أذعشحألتغوۄأشعۏأتههۄأؼىۄتأضەأثہۏأوشًۏأۄەأڬۄأذعشحأؼهۏأىەأۏۄًزۏأڬەأثتؽأڬًأځتىۏأهڲتۏتأتًشأۄشأڋًهأڬەأثزهەأڬہدًشأهۏأۗ

[تخریج]: [ ضعیف ]"
11651,"أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأشًتۏحأۄەأڬۄأإځأىەألشوتۏتأ=أإزوۏأتځىەأثہتةۏأڬەأضًزەأځشأضًزتأىۄأڬشەأتًشأىۄأتځىەأثہتةۏأڬۏأوىڲىۏأځشأوىڲىۏأڬشەأتًشأىۄأثًهۏأهڲتاأتًشأىۄأځحہشأځہۏىڬىەأضەأثۏؼأڬشًأتًشأدًأتدشحأځشأڬضۏأڬًأشڬہەأ؏أتضەأوصزًشۏأغەأڬشأهۏىۏأډتۄۏەأۗ

[تخریج]: [ ضعیف ]"
11652,"أذعشحأتثًضؼۏزأرزشۏأضەأشًتۏحأۄەأڬۄأشضًهأتههۄأ﷽أىەأوصزًشأڬۏأتدشحأضەأوىؼأڬۏتأۏؼىۏأًۄأتضەأًتعذأڬشأهەأۗ

[تخریج]: [ ضعیف ]"
11653,"ذعشحأؼًلأثىأوتهڬألشوتحەأۄۏڽأڬۄأۄوأىەأدىڲأڬۏأتًشأۄوتشەأتوۏشأؼوشًأثىأؼتظأحہەأتًشأۄوأوۏڽأؼوشأثىأرغتثأتًشأتثًؼثۏزۄأثہۏأحہەأۗأۄوۏڽأطزحأڬۏأثہًڬأهڲۏأۗأوۏڽأډهتأڬۄأڬًةۏأڬتوأحهتطأڬشًڽأۗأوۏڽأىەأتۏڬأمًوأڬًأځتۏتأًۄأتًىټأسثذأڬشىتأډتۄحەأحہەأۗأوۏڽأىەأڬۄتأ=أتڲشأحوأډتۄًأحًأوۏڽأحوۄتشتأۏۄأڬتوأڬشأزۏحتأۄًڽأتًشأودہەأتضأضەأڬډہأزەأزۏىتأۗأوۏڽأىەأڲًطحأثىتۏتأۗأځہشأوۏڽأؼوشأڬەأځتضأإۏتأۗأتىہًڽأىەأضًتهأڬۏتأ=أۏۄأڬۄتڽأضەأإۏتأۄەأآأوۏڽأىەأثحتۏتأحًأتىہًڽأىەأڬۄتأ=أحًأىەأتدشحأوۏڽأدهزۏأڬۏأۄەأتًشأڬہتىەأضەأتىڬتشأڬشأزۏتأۗأځہشأوۏڽأىەأتثًؼثۏزۄأڬًأثحتۏتأحًأتضأىەأثہۏأذعشحأؼوشأًتهۏأثتحأڬۄۏأتًشأڬہتىەأضەأتىڬتشأڬشأزۏتأۗأوۏڽأىەأۏۄأزۏڬہأڬشأتضەأډہًڔأزۏتأ؏أڬۄحەأۄۏڽأ=أځہشأۄوۏڽألحذأوهۏأحًأوۏڽأشضًهأتههۄأ﷽أڬەأځتضأإۏتأ؏أإځأ﷽أىەألشوتۏتأ=أتًىټأًتهەأحوأۄًأتًشأودہەأڬډہأىۄأڬۄتأۗطۏرألشوتحەأۄۏڽأ=أتضأوۏڽأۏۄأثتحأۄەأڬۄأڬۄأتدشحأودۄًهأحہۏأتًشأسوۄأوۏڽأډۏصأىمزأحہۏأۗ

[تخریج]: [ ضعیف ]"
11654,"أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأشًتۏحأۄەأڬۄأوصزًشأڬًأتضأڬتأذمأځضۏىۄأرطڬأۄًىەأضەأځۄهەأزًأتًشأتضأڬۏأوصزًشۏأڬتوأڬەأذضتثأضەأتضەأثحتأزًأۗ

[تخریج]: [ ضعیف ]"
11655,"ذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأشًتۏحأۄەأڬۄأوۏڽأىەأۏحۏوۏأڬۏأذتهحأوۏڽأځشًشطأځتةۏأتًشأوۏڽأىەأوضڬۏىۏأڬۏأذتهحأوۏڽأۄدشحأڬۏأتًشأوۏڽأتثًؼلتىأڬەأۄتڽأوصزًشأحہتأتًشأتضأڬەأثۏټەأؽصًتىأڬەأۄتڽأثہۏأتځىەأځۏټأڬەأثمزشأڬہتىەأځشأتًشأتځىەأڲہشأًتهًڽأڬەأڬہتىەأڬەأثمزشأۗأدثأًۄأڲہشأځشأۄًحەأحًأهڬڔۏتڽأتڬټہۏأڬشحتأتًشأدثأًۄأضلشأځشأۄًحەأحًأتضأڬتأضتوتىأحۏتشأڬشحتأۗتثأضتشۏأحؼشۏلۏڽأتههۄأڬەأهۏەأۄۏڽأدضأىەأزۏىأڬًأوعثًغۏأثرطۏأتًشأتثًۄشۏشۄأشعۏأتههۄأؼىۄأڬًأتوتوأثىتۏتأۗتضأوۏڽأۏۄأىۄۏڽأۄەأڬۄأىثۏأ﷽أىەأدتىأهۏىەأڬەأثؼزأثہۏأثشمشتشأشۄىەأزۏتأتًشأتذحوتهأۄەأڬۄأۏۄتڽأزًىًڽأڬەأزشوۏتىأشعتوىزۏأحہۏأىۄأڬۄأؼمزأحہتأۗ

[تخریج]: [ ضعیف ۔ ابن ماجہ 247 ]"
11656,"أتثىأؼثتضأشعۏأتههۄأؼىۄوتأضەأثہۏأوىمًهأۄەأڬۄأۏۄأزًىًڽأڬۏأشعتوىزۏأضەأۄًأڲتأىۄأڬۄأ+أؼمزأ,أهتصوأڬشىەأضەأۗ

[تخریج]: [ ضعیف ]"
11657,"أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأشًتۏحأۄەأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=أتههۄأحؼتهۏٳأىەألشوتۏتأ=أحۏىأهًڲأتۏضەأۄۏڽأڬۄأمۏتوحأڬەأزىأدىأضەأوۏڽأدہڲڔتأڬشًڽأڲتأ=أًۄأإزوۏأدًأوۏشەأىتوأضەأهۏحتأۄەأ؏أځہشأزہًڬتأزۏحتأۄەأتًشأًۄأإزوۏأدًأڬضۏأإصتزأڬًأثۏډأڬشأتضأڬۏأمۏوحأڬہتحتأۄەأتًشأًۄأإزوۏأدًأوصزًشأشڬہحتأۄەأتضأضەأڬتوأځًشتأهۏحتأۄەأهۏڬىأتدشحأىۄۏڽأزۏحتأۗ

[تخریج]: [ بخاری 2227 ]"
11658,"أځډہهۏأشًتۏحأڬۏأغشذأۄەأۗ

[تخریج]: [ صحیح ]"
11659,"أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأشًتۏحأۄەأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=أوصزًشأڬًأتضأڬۏأوصزًشۏأتضأڬتأځضۏىۄأرطڬأۄًىەأضەأځۄهەأزًأۗ

[تخریج]: [ ضعیف ]"
11660,"تثًتوتوۆأتهىدۏألشوتحەأۄۏڽأ=أوۏڽأذدأوۏڽأڬشتۏۄأځشأدتىًشأزۏحتأحہتأتًشأهًڲأڬۄحەأحہەأ=أحۏشتأذدأىۄۏڽأۄەأۗأوۏڽأذعشحأتثىأؼوشأشعۏأتههۄأؼىۄوتأضەأوهتأتًشأڬۄتأ=أتەأتثًؼثزتهشذوىأ$أوۏڽأڬشتۏۄأځشأدتىًشأزۏحتأۄًڽأتًشأهًڲأڬۄحەأۄۏڽأ=أوۏشتأذدأىۄۏڽأۄەأحًأتثىأؼوشأشعۏأتههۄأؼىۄأىەأڬۄتأ=أڬۏتأحًأىەأتذشتوأىۄۏڽأثتىزہتأآأتًشأحهثۏۄأىۄۏڽأځڬتشتأتًشأثۏحأتههۄأڬتأغًتلأىۄۏڽأڬۏتأتًشأؼشلتحأضەأىۄۏڽأهًټتأتًشأحًأىەأشوةۏأذدتشأىۄۏڽأڬۏأآأتثًتوتوۆألشوتحەأۄۏڽأ=أوۏڽأىەأدًتثأزۏتأ=أڬۏًڽأىۄۏڽأ؏أوۏڽأىەأضتشەأڬتوأڬۏەأۄۏڽأحًأتثىأؼوشأشعۏأتههۄأؼىۄوتأىەأڬۄتأ=أحۏشتأذدأزشضحأۄەأۗأ+أځہشألشوتۏتأ,أتۏڬأإزوۏأشضًهأتههۄأ﷽أڬەأځتضأإۏتأتًشأتضۏأغشذأضًتهأڬۏتأدضأغشذأحًأىەأڬۏتأۄەأ؏أإځأ﷽أرتوًطأشۄەأ؏أإځأ﷽أىەأڬًةۏأدًتثأىۄأزۏتأۏۄتڽأحڬأڬۄأۏۄأإۏحأىتصهأۄًةۏأ=أ®~أهّۏٕضّأؼّهّۏٕڬْوٕأدْىّتذُأتّٗىٕأحّثٕحّؽًْتألّعٕهتَأوٓىٕأشّثٔٓڬْوٕأ¾أحوأځشأڬًةۏأڲىتۄأىۄۏڽأڬۄأحوأتههۄأڬتألعهأحهتطأڬشًأۗځہشأإځأ﷽أىەأتضأإزوۏأڬًأثهتۏتأتًشأتضأڬەأضتوىەأۏۄأإۏحأځڔہۏأ؏أځہشألشوتۏتأ=أحۏشتأذدأزشضحأۄەأۗ

[تخریج]: [ صحیح ۔ 2/155/6434 ، ابوداؤد1733 ]"
11661,"أوضهوۄأثىأىًلهأثىًأخمۏلأڬەأتۏڬأإزوۏأضەأشًتۏحأڬشحەأۄۏڽأ؏أتضأىەأتځىەأًتهزأضەأىمهأڬۏتأڬۄأوۏڽأىەأذعشحأؼوشأشعۏأتههۄأؼىۄأضەأضىتأ=أإځأتؼهتىأڬشأشۄەأحہەأڬۄأضًتشۏًڽأځشأضتوتىأإرشأوۏڽأهتزتأڬشًأۗأثۏطڬأۄتحہأهټڬەأۄًحەأۄۏڽأتًشأځتاڽأوعثًغأۄًحەأۄۏڽأۗ

[تخریج]: [ ضعیف ]"
11662,"أتثًوؽۏشۄأخملۏألشوتحەأۄۏڽأڬۄأوۏشەأًتهزأىەأثحهتۏتأڬۄأًۄأتځىەأًتهزأڬەأضتحہأوىۏٳأوۏڽأحہەأۗأتىہًڽأىەأتۏڬأتؼهتىأڬشىەأًتهەأڬًأضىتأ=أتەأهًڲًأ$أضًتشۏًڽأځشأثًدہأإرشأوۏڽأهتزتأڬشًأ؏أثۏطڬأځتاڽأوعثًغأۄًحەأۄۏڽأتًشأۄتحہأهټڬەأۄًحەأۄۏڽأۗأوۏڽأىەأتځىەأًتهزأضەأڬۄتأ=أۏۄأڬًىأۄەأآأتىہًڽأىەألشوتۏتأ=أۏۄأؼوشأشعۏأتههۄأؼىۄأۄۏڽأۗ

[تخریج]: [ ضعیف ]"
11663,"ذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأشًتۏحأۄەأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=أدثأحوأضتوتىأهتأزًأحًأۏۄأڬتوأإرشأوۏڽأڬشًأۗأثۏطڬأۄتحہأهټڬەأۄًحەأۄۏڽأتًشأځتاڽأوعثًغأۄًحەأۄۏڽأۗصۄشۏأىثۏأ﷽أضەأتۏڬأشًتۏحأىمهألشوتحەأۄۏڽأڬۄأضًتشۏًڽأځشأضتوتىأإرشأوۏڽأهتزتأڬشًأ؏أثۏطڬأۄتحہأهټڬەأۄًحەأۄۏڽأتًشأځتاڽأوعثًغأۄًحەأۄۏڽأۗ

[تخریج]: [ ضعیف ]"
11664,"أتوتوأطتلؼۏأشذوۆأتههۄأؼهۏۄأضەأشًتۏحأۄەأڬۄأمتعۏأطشۏذأوڬتىًڽأڬًأضلۏزۏأڬشىەأًتهەأڬەأځتضأڲةەأۗأتضأىەأڲہشأڬًأضلۏزۏأڬۏأحًأتضأڬتأڲہشأدهأڲۏتأ+أدضأڬۏأضلۏزۏأڬۏأحہۏأ,أتضأىەأڬۄتأ+أدضأڬتأڲہشأدهتأحہتأ,أ=أحوأودہەأعتوىأثىتحەأۄًأدثڬۄأوۏشتأڲہشأدهأڲۏتأۄەأحًأمتعۏأطشۏذأىەأڬۄتأ=أحۏشۏأڬۏتأشتةەأۄەأتڲشأتضأڬتأڲہشأدهتأۄًحتأحًأڬۏتأحًأتضأځشأتځىۏأتدشحأډہًڔحتأۗأۏۄأرثشأتثىأؼۏىۄأىەأثۏتىأڬۏأۄەأۗ

[تخریج]: [ صحیح ۔ الام 4/41 ]"
11665,"أذعشحأؼهۏأشعۏأتههۄأؼىۄأضەأتۏڬأشًتۏحأوىمًهأۄەأڬۄأإځأڬضۏأڬۏأتدشحأځشأعتوىأىۄۏڽأثىحەأحہەأۗأؼغتؤأثىأتثۏأشثتذأضەأوىمًهأۄەأڬۄأڬتشۏڲشأتًشأوصزًشأځشأڬًةۏأعوتىحأىۄۏڽأۄەأۗ

[تخریج]: [ ضعیف ۔ الام 4/41 ]"
11666,"أذعشحأؼهۏأشعۏأتههۄأؼىۄأڬتشۏڲشأتًشأشىڲىەأًتهەأڬۏأعوتىحأزۏحەأحہەأتًشألشوتۏتأ=أتضأوۏڽأعوتىحأزشضحأۄەأۗ

[تخریج]: [ ضعیف ]"
11667,"محتزۄأرهتضأضەأىمهألشوتحەأۄۏڽأڬۄأذعشحأؼهۏأشعۏأتههۄأؼىۄأوصزًشأڬًأعوتىحأزۏتأڬشحەأحہەأۗطؼثۏأضەأوىمًهأۄەأڬۄأذعشحأؼهۏأشعۏأتههۄأؼىۄأوصزًشأڬًأعوتىحأزۏتأڬشحەأحہەأۗ

[تخریج]: [ ضعیف ]"
11668,"أتثىأتثۏأطؼطتؤألشوتحەأۄۏڽأوۏڽأطشۏذأڬەأځتضأڲۏتأًۄأوضحشۏأتًشأشىڲىەأًتهەأڬۏأعوتىحأزۏحەأحہەأۗ

[تخریج]: [ ضعیف ]"
11669,"أطؼثۄأتثًۄۏطوأضەأىمهألشوتحەأۄۏڽأڬۄأًۄأثظشۄأضەأحۏهأهەأڬشأإةەأ؏أتىہًڽأىەأحۏهأهتىەأڬۏأتدشحأثہۏأهۏأتًشأحۏهأًتهتأثشحىأحۏىأۏتأډتشأضًأڬتأحہتأۗأًۄأڲشأڬشأټًټأڲۏتأ؏أوۏڽأىەأتشتزۄأڬۏتأڬۄأتىأضەأظهذأۄًأدتةەأۗأهۏڬىأتضأىەأتىڬتشأڬشأزۏتأۗأوۏڽأطشۏذأڬەأځتضأۏۄأوؼتوهۄأهەأڬشأڲۏتأ؏أطشۏذأىەأتىأضەأڬۄتأڬۄأتضأىەأتدشحأتضأهۏەأزۏأحہۏأڬۄأإځأسوۄأزتشأۄۏڽأۗأمتعۏأطشۏذأىەأتضەأعتوىأټہۄشتۏتأ؏أځہشأهًڲأۄوۏطۄأڬًططأڬشحەأشۄەأ؏أۏۄتڽأحڬأڬۄأوۏشۏأتىأضەأظهذأۄًأڲةۏأۗ

[تخریج]: [ ضعیف ]"
11670,"تؼوطألشوتحەأۄۏڽأڬۄأوۏڽأىەأتثشتۄۏوأضەأوضحشۏأڬەأثتشەأوۏڽأضًتهأڬۏتأحًأتىہًڽأىەألشوتۏتأ=أًۄأعتوىأۄەأۗتۏڬأشًتۏحأڬەأوغتثمأتثشتۄۏوأىەأڬۄتأ=أًۄأعتوىأىۄۏڽأۄەأۗ

[تخریج]: [ صحیح ]"
11671,"أذعشحأؼوشأشعۏأتههۄأؼىۄأضەأوىمًهأۄەأڬۄأدًأإزوۏأڬشتۏۄأځشأڬًةۏأډۏصأهەأۗأځہشأتضأڬتأضتحہۏأسًتهذهۏلۄأڬۏأغشلأثہۏأحدتًصأڬشەأحًأتضأځشأڬشتۏۄأًتدثأۄەأتًشأعوتىأىۄۏڽأۄەأۗأڬشتۏۄأځشأزۏىەأًتهەأىەأدًأڬشتۏۄأمثعأڬشأهۏتأتًشأًۄأسًتهذهۏلۄأڬۏأغشلأحدتًصأڬشأڲۏتأحًأتضأځشأوڬوهأڬشتۏۄأًتدثأۄەأۗأدثأتدشحأوۏڽأطشغأىۄأۄًأتًشأدثأحڬأًۄأصۏتزحۏأىۄأڬشەأتًشأتضأځشأعوتىأىۄۏڽأۄەأۗ

[تخریج]: [ صحیح ]"
11672,"أتوتوأطتلؼۏأشذوۆأتههۄأؼهۏۄألشوتحەأۄۏڽأ=أضصتأتزثأۄەأۗأتههۄأڬۏأذزًزأوۏڽأضەأذزأىۄۏڽأۄەأتًشأتضأڬتأحشڬأڬشىتأثہۏأدتةصأۄەأۗأإځأىۄۏڽأزۏڬہحەأڬډہأڬتوأشضًهأتههۄأ﷽أڬەأصوتىەأوۏڽأۄًةەأدًأذزًزأوۏڽأضەأىۄأحہەأوخهتَأتههۄأڬەأشتضحەأوۏڽأرۏتىحأڬشىتأتًشأتضأڬەأؼهتًۄأزۏڲشأڬتوأتًشأتىہۏڽأڬثہۏأذزأىۄأهڲۏأ؏أثهڬۄأإځأىەأوؼتلأڬشأزۏتأتًشأۏۄأثہۏأثۏتىأڬۏتأڲۏتأۄەأڬۄأذعشحأؼوشأشعۏأتههۄأؼىۄأىەأڬضۏأؼًشحأڬۏأغشلأڬًةۏأډۏصأثہۏدۏأ؏أځہشأإځأڬًأځحۄأډهتأڬۄأتضأؼًشحأىەأًۄأڲوأڬشأزۏأۄەأحًأذعشحأؼوشأشعۏأتههۄأؼىۄأىەأتضأثتشەأوۏڽأوطًشۄأڬۏتأ؏أتۏڬأإزوۏأىەأڬۄتأ=أإځأوازثأۄۏڽأۗأذعشحأؼهۏأشعۏأتههۄأؼىۄأىەأتضأضەأڬۄتأ=أتڲشأتضأىەأتدحۄتزأضەأۏۄأثتحأڬۄۏأحًأتضأىەأؽهغۏأڬۏأۗأتڲشأتدحہتزأىۄۏڽأڬۏتأحًأتضأىەأإځأڬەأضتحہأزۏحأځشأرۏتىحأڬۏأتًشألشوتۏتأ=أوۏشتأرۏتهأۄەأڬۄأإځأدثأحڬأتضأڬۏأمًوأڬًأثحتأىۄأزۏڽأتضأًمحأحڬأىۄأثۏټہۏڽأتًشأذعشحأؼهۏأشعۏأتههۄأؼىۄأىەأڬۄتأ=أدًأڬًةۏأذزأوۏڽأمحهأۄًأدتةەأوۏشەأرۏتهأوۏڽأتضأڬتأمحهأذمأۄەأوڲشأطشتثأڬۏأذزأوۏڽأوشىەأًتهتأۗأثۏطڬأًۄأتۏضۏأډۏصأۄەأڬۄأۄوأىەأتضەأىثۏأ﷽أڬەأثؼزأزۏڬہتأۄەأۗأدًأطشتثأڬۏأذزأوۏڽألًحأۄًحتأۄەأتضأڬۏأزۏحأۏتأحًأثۏحأتهوتهأضەأتزتأۄًأڲۏأۏتأتوتوأ+أرهۏلۄأ,أڬەأسوۄأۄًأڲۏأۗ

[تخریج]: [ صحیح ]"
11673,"أذضىألشوتحەأۄۏڽأڬۄأذعشحأؼوشأشعۏأتههۄأؼىۄأڬًأځحۄأډهتأڬۄأتۏڬأضشڬطأؼًشحأڬەأځتضأهًڲأإحەأۄۏڽأۗأذعشحأؼوشأىەأتضأڬەأځتضأتۏڬأإزوۏأثہۏدتأ؏أتضأإزوۏأىەأڬۄتأ=أذعشحأؼوشأشعۏأتههۄأؼىۄأىەأإځأڬًأځۏؽتوأثہۏدتأۄەأ؏أتضأڬتأدًتثأزًأۗأًۄأدصؼألصؼأڬشىەأهڲۏأۗأتضأڬۏأذشڬحأضەأتضأڬەأشذوأڬتأثډۄأذشڬحأڬشأڲۏتأ؏أتضأىەأتضەأىڬتهأزۏتأ؏أځہشأتضەأزشزصۄأطشًؼأۄًأڲۏتأحًأتضأىەأدىۏىأثہۏأځہۏىڬأزۏتأۗأتضەأذعشحأؼوشأڬەأځتضأهتۏتأڲۏتأ؏أإځأىەأوۄتدشۏىأڬۏأغشلأځۏؽتوأثہۏدتأتًشأتىأضەأتضأثتشەأوۏڽأشتةەأوتىڲۏأحًأتىہًڽأىەأڬۄتأ=أتەأتوۏشتهوًوىۏىأ$أإځأځشأڬډہأىۄۏڽأۄەأۗأإځأحًأوؼهوأتًشأوازثأۄۏڽأتًشأمًوأوۏڽأذعشحأؼهۏأشعۏأتههۄأؼىۄأثہۏأحہەأ؏أإځأرتوًطأحہەأۗأذعشحأؼوشأشعۏأتههۄأؼىۄأىەأڬۄتأ=أتەأتثًتهذضىأ$أإځأتضأثتشەأوۏڽأڬۏتأڬۄحەأۄۏڽأآأإځأڬۄىەأهڲەأ=أتڲشأًۄأإځأڬەأمشۏثۏأحہەأستحۏأتىحمتوأڬۏأًدۄأضەأحًأًۄأڲىتۄأڲتشأۄۏڽأۗأتڲشأتىأڬتأتدحۄتزأحہتأحًأتىہًڽأىەأؽهغۏأڬۏأتًشأتەأتوۏشتهوًوىۏىأ$أوۏڽأإځأڬًأزۏحأڬتأسوۄأزتشأضودہحتأۄًڽأۗأذعشحأؼوشأىەأڬۄتأ=أحًأىەأضډأڬۄتأۄەأتًشألشوتۏتأ=أدتاأتضأڬۏأمًوأځشأتضأ+أزۏحأ,أڬًأحمضۏوأڬشأزًأۗ

[تخریج]: [ ضعیف ]"
11674,"ذعشحأؼهۏأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أدضأإزوۏأځشأذزأهڲەأ؏أوۏڽأتځىەأسۄىأوۏڽأتضأڬەأثتشەأوۏڽأڬًةۏأډۏصأځتحتأۄًڽأوڲشأظتذثٓأروشأتڲشألًحأۄًأدتةەأحًأتضأڬۏأزۏحأزۏأدتةەأڲۏأۗأتضأهۏەأڬۄأشضًهأتههۄأ﷽أىەأتضەأدتشۏأىۄۏڽأڬۏتأۗهوأۏضىۄأضەأوشتزأۏۄأۄەأڬۄأډتهۏضأضەأتضۏأڬەأؼهتًۄأىۄۏڽأدتشۏأڬۏتأتًشأذزأوۏڽأدًأتىہًڽأىەأصۏتزۄأڬۏتأًۄأڋشتىەأڬۏأًدۄأضەأۄەأۗأډتهۏضأڬہدًشأڬۏأټۄىۏأضەأتًشأدًحًڽأضەأتًشأڬځڔەأڬەأڬىتشەأضەأۏۄأذزأىثۏأ﷽أضەأختثحأۄەأۗ

[تخریج]: [ بخاری 6778 ، مسلم 1707 ]"
11675,"أؼغتؤأضەأتۏضەأوؼهوأڬەأثتشەأوۏڽأځًډہتأڲۏتأدًأتزثأڬەأهۏەأثډەأڬًأوتشأهەأتًشأتضەأىمظتىأځۄىډتةەأحًألشوتۏتأ=أًۄأسوۄأزتشأۄەأۗ

[تخریج]: [ حسن ]"
11676,"أذعشحأؼثزتههۄأثىأؼثتضأضەأوىمًهأۄەأڬۄأشضًهأتههۄأ﷽أڬەأډىزأظذتثۄأځتىۏأڬەأځتضأضەأڲصشەأ؏أًۄتڽأتۏڬأإزوۏأحہتأدضەأثډہًأىەأڬتټتأۄًتأحہتأۗأتضأمثۏهەأڬتأتۏڬأإزوۏأظذتثۄأڬەأځتضأإۏتأتًشأڬۄىەأهڲتأ=أحوأوۏڽأضەأڬًةۏأزوأڬشىەأًتهتأۄەأآأۄوتشەأتۏڬأإزوۏأڬًأثډہًأىەأڋضأهۏتأۄەأۗأتۏڬأإزوۏأتىأظذتثۄأوۏڽأضەأڲۏتأ؏أتضأىەأډىزأثڬشۏًڽأڬەأؼًعأضًشۄألتحذۄأڬەأضتحہأزوأڬۏتأۗأتضأإزوۏأڬًأطلتؤأوهأڲةۏأۗأۏۄأظذتثۏأثڬشۏتڽأهەأڬشأظذتثۄأڬەأځتضأإةەأۗأتىہًڽأىەأتضألؼهأڬًأىتځضىزأڬۏتأتًشأڬۄتأ=أحًأىەأتههۄأڬۏأڬحتثأځشأتدشحأهۏأۄەأۗأًۄأشضًهأتههۄأ﷽أڬەأځتضأإةەأتًشأإځأڬًأثحتۏتأحًأإځأ﷽أىەألشوتۏتأ=أحوأدضأډۏصأځشأتدشحأهۏحەأۄًأتىأوۏڽأتههۄأڬۏأڬحتثأصۏتزۄأذمأزتشأۄەأۗ

[تخریج]: [ بخاری 5737 ]"
11677,أذعشحأتثًضؼۏزأضەأشًتۏحأۄەأڬۄأتىظتشأظذتثۄأڬشتوأڬۏأدوتؼحأڬضۏأضلشأوۏڽأڲةۏأۗأتىہًڽأىەأشتضحەأوۏڽأڬضۏأؼشثأمثۏهەأڬەأمشۏثأځڔتاأڋتهتأتًشأتىأضەأڬہتىتأغهثأڬۏتأحًأتىہًڽأىەأوۄوتىأىًتصۏأضەأتىڬتشأڬشأزۏتأۗأمثۏهەأڬەأضشزتشأڬًأضتىځأىەأڬتټأهۏتأ؏أتىہًڽأىەأۄشأغشذأڬًططأڬۏأهۏڬىأڬډہأتلتمۄأىۄأۄًتأۗأتۏڬأطرظأڬۄىەأهڲتأ=أتضأدوتؼحأڬەأځتضأدتاأدًأحوۄتشەأۄتڽأټہۄشۏأۄًةۏأۄەأطتۏزأتىأڬەأځتضأتضأڬتأڬًةۏأؼهتدأۄًأۗأډىتىډۄأتىہًڽأىەأڬۄتأ=أتەأدوتؼحأ$أۄوتشەأضشزتشأڬًأضتىځأىەأڬتټأهۏتأۄەأتًشأۄوأۄشأغشذأڬًططأڬشأډڬەأۄۏڽأهۏڬىأتلتمۄأۄۏڽأهۏڬىأتلتمۄأىۄۏڽأۄًأشۄتأۗأحوۄتشەأځتضأتضأڬتأڬًةۏأؼهتدأتًشأذهأۄەأآأحًأتۏڬأظذتثۏأڬۄىەأهڲەأ=أۄتڽأوۏڽأزوأڬشىتأدتىحتأۄًڽأۗأهۏڬىأۄوأىەأحوأضەأڬہتىتأوتىڲتأحًأحوأىەأوۄتىأىًتصۏأضەأتىڬتشأڬشأزۏتأتثأوۏڽأتۏڬأزوأڬشًڽأڲتأدثأحوأودہەأتضأڬتأڬډہأؼًعأزًأۗأډىتىډۄأتىہًڽأىەأظذتثۄأضەأثڬشۏًڽأڬەأتۏڬأشۏًڔأځشأظهذأڬشأهۏأۗأًۄأظذتثۏأڲةەأتًشأتضەأزوأڬشىەأهڲەأتًشأًۄأضًشجألتحذۄأځڔہحەأشۄەأۗأحہًڔۏأزۏشأثؼزوأًۄأثتهڬهأحىزشضحأۄًأڲۏتأڲًۏتأتضەأشضۏًڽأضەأڬہًهأزۏتأڲۏتأۄًأتًشأًۄأتضەأډهىەأهڲتأڲًۏتأتضەأڬًةۏأحڬهلأىۄأۄًأۗأډىتىډۄأتىہًڽأىەأًؼزەأڬەأوغتثمأًۄأؼًعأتزتأڬشأزۏتأۗأهًڲًڽأىەأڬۄتأ=أتضەأحمضۏوأڬشأهًأًۄأزوأًتهەأظذتثۏأڬۄىەأهڲەأ=أټہۄشًأ$أۄوأشضًهأتههۄأ﷽أڬەأځتضأدتأڬشأوضةهۄأوؼهًوأڬشۏڽأځہشأًۄأدًأذڬوألشوتةۏڽأۗأډىتىډۄأًۄأظثذأڬەأًمحأشضًهأتههۄأ﷽أڬۏأرزوحأوۏڽأذتعشأۄًةەأتًشأًۄأمظۄأثۏتىأڬۏتأۗأشضًهأتههۄأ﷽أوضڬشتةەأتًشألشوتۏتأ=أۄوۏڽأڬۏضەأوؼهًوأۄًتأڬۄأۏۄأزوأۄەأځہشألشوتۏتأ=أتضەأحمضۏوأڬشأهًأتًشأتځىەأضتحہأوۏشتأذظۄأثہۏأشڬہىتأۗ
11678,أًعۏىأثىأؼغتؤألشوتحەأۄۏڽأ=أوزۏىۄأوۏڽأحۏىأوؼهوأثډًڽأڬًأځڔہتحەأحہەأۗأذعشحأؼوشأثىأرغتثأشعۏأتههۄأؼىۄأتىأوۏڽأضەأۄشأتۏڬأڬًأوتۄتىۄأزضأزشۄوأوؼتًعۄأؼغتألشوتحەأحہەأۗ
11679,"+أتهلأ,أطؼثۄألشوتحۏأۄۏڽأڬۄأوۏڽأىەأوؼتًۏۄأثىأمشۄأضەأوؼهوأڬۏأتدشحأڬەأثتشەأوۏڽأضًتهأڬۏتأحًأتىہًڽأىەأڬۄتأ=أوۏڽأتضأڬەأهۏەأتدشحأڬۏأشتةەأشڬہحتأۄًڽأۗ+أثأ,أذڬوأڬۄحەأۄۏڽأ=أوۏڽأىەأڬضۏأضەأتضأڬۏأڬشتۄحأىۄۏڽأضىۏأۗأتوتوأثرتشۏأشذوۆأتههۄأؼهۏۄأحشدوۄأوۏڽأسڬشأڬشحەأۄۏڽأڬۄأذڬوأىەألشوتۏتأ=أوۏڽأىەأوؼهوأڬۏأتدشحأڬەأثتشەأوۏڽأڬضۏأڬۏأڬشتۄحأىۄۏڽأضىۏأتًشألشوتۏتأ=أتثىأضۏشۏىأثہۏأوؼهوأڬۏأتدشحأڬەأثتشەأوۏڽأذشدأىۄۏڽأضودہحەأحہەأۗ+أدأ,أؼغتشأتًشأتثًمهتثۄأثډًڽأڬًأحؼهۏوأزۏىەأځشأتدشحأهۏىەأوۏڽأڬًةۏأذشدأىۄۏڽأضودہحەأحہەأۗ+أزأ,أذعشحأذضىأشذوۆأتههۄأؼهۏۄأضەأوىمًهأۄەأ=أدثأوؼهوأمغؼأحؼهمۏأڬشەأتًشأؼزهأىۄأڬشەأحًأۏۄأتضأڬتأػهوأهڬہتأدتةەأڲتأۗ

[تخریج]: [ صحیح ۔ أخرجہ ابن الجعد 1103 ]"
11680,"أذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأثزشأڬەأمۏزۏًڽأځشأڬًةۏألزۏۄأىۄأحہتأۗأشضًهأتههۄأ﷽أىەأتىأڬًألزۏۄأځشأومششأڬۏتأحہتأڬۄأًۄأتىظتشأڬەأثډًڽأڬًأهڬہىتأضڬہتأزۏڽأۗأتۏڬأزىأتىظتشأڬتأتۏڬأثډۄأشًحتأۄًتأتځىەأثتځأڬەأځتضأإۏتأۗأثتځأىەأځًډہتأ=أڬۏتأوؼتوهۄأۄەأآأتضأىەأڬۄتأ=أودہەأوۏشەأتضحتزأىەأوتشتأۄەأ=أتضأىەأڬۄتأ=أرثۏخأإزوۏأثزشأڬتأڬۏىۄأغهثأڬشحتأۄەأۗأتههۄأڬۏأمضوأ$أإةىزۄأحًأتضأڬەأځتضأىۄأدتىتأۗ

[تخریج]: [ ضعیف ]"
11681,"أذعشحأؼثتزۄأثىأظتوحأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأوۏڽأىەأتۄهأظلۄأڬًأهڬہىتأتًشأمشإىأودۏزأځڔہىتأضڬہتۏتأۗأتىأوۏڽأضەأتۏڬأإزوۏأىەأڬوتىأۄزۏەأڬەأغًشأځشأزۏأۗأوۏڽأىەأڬۄتأ=أڬًةۏأوتهأىۄۏڽأۗأوۏڽأتضەأتههۄأڬەأشتضحەأوۏڽأځہۏىڬأزًڽأڲتأۗأوۏڽأعشًشأشضًهأتههۄأ﷽أڬەأځتضأدتاڽأڲتأتًشأإځأ﷽أضەأتضأثتشەأوۏڽأضًتهأڬشًڽأڲتأۗأوۏڽأإځأ﷽أڬەأځتضأإۏتأتًشأوۏڽأىەأڬۄتأ=أۏتأشضًهأتههۄأ﷽أودہەأتۏڬأإزوۏأىەأهڬہىەأتًشأمشإىأودۏزأڬەأثزهەأڬوتىأزۏأۄەأ؏أًۄأوتهأحًأىۄۏڽأ؏أوۏڽأتضەأتههۄأڬەأشتضحەأوۏڽأځہۏىڬًڽأڲتأآأإځأ﷽أىەألشوتۏتأ=أتڲشأحًأځضىزأڬشحتأۄەأڬۄأإڲأڬتأغًمأڋتهەأحًأتضەأمثًهأڬشأۗ

[تخریج]: [ صحیح ]"
11682,"أذعشحأؼثتزۄأثىأظتوحأشعۏأتههۄأؼىۄأضەأشًتۏحأۄەأڬۄأىثۏأڬشۏوأ﷽أىەألشوتۏتأ=أتڲشأحدہەأتډہتأهڲەأڬۄأحًأإڲأڬتأغًمأځۄىەأحًأڬحتثحأضڬہتىەأځشأتدشحأهەأهەأۗ

[تخریج]: [ صحیح ]"
11683,"أتۏڬأشًتۏحأڬەأتهلتػأۄۏڽأڬۄأوۏڽأىەأڬۄتأ=أۏتأشضًهأتههۄأ﷽أ$أإځأ﷽أڬتأتضأثتشەأوۏڽأڬۏتأرۏتهأۄەأآأإځأ﷽أىەألشوتۏتأ=أإڲأڬتأتىڲتشۄأۄەأدضەأحًأىەأتځىەأزًىًڽأڬىزہًڽأڬەأزشوۏتىأهټڬتۏتأۄەأۗ

[تخریج]: [ صحیح ]"
11684,"أؼغۏۄأثىأمۏضأڬهتثۏألشوتحەأۄۏڽأ=أذعشحأتثۏأثىأڬؼثأشعۏأتههۄأؼىۄأىەأتۏڬأإزوۏأڬًأمشإىأځتڬأضڬہتۏتأ؏أًۄأۏوىأضەأتىأڬەأهۏەأڬوتىأهەأڬشأإۏتأۗأتىہًڽأىەأىثۏأ﷽أضەأتضأثتشەأوۏڽأضًتهأڬۏتأحًأإځأ﷽أىەألشوتۏتأ=أتڲشأحًأىەأځڬڔتأحًأڲًۏتأحًأىەأدۄىوأڬۏأڬوتىأځڬڔۏأۄەأۗ

[تخریج]: [ ضعیف ]"
11685,"أذعشحأتثًزشزتؤأشعۏأتههۄأؼىۄأضەأوىمًهأۄەأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=أدضأىەأمشإىأڬۏأحؼهۏوأځشأڬوتىأهۏأ؏أتههۄأتضەأإڲأڬۏأڬوتىأځۄىتةەأڲتأۗ

[تخریج]: [ ضعیف ]"
11686,"أذعشحأتثًزشزتؤأشعۏأتههۄأؼىۄأضەأشًتۏحأۄەأڬۄأدضأىەأمشإىأڬۏأحؼهۏوأځشأڬوتىأهۏأۗ

[تخریج]: [ صحیح ]"
11687,"ذعشحأتثًۄشۏشۄأضەأشًتۏحأۄەأڬۄأىثۏأ﷽أىەأهًىڋۏأڬۏأڬوتةۏأضەأوىؼألشوتۏتأۄەأۗتضأضەأوشتزًۄأهًىڋۏأۄەأدًألتذطۄأۄًأۗأدضأغشذأتثًوضؼًزأتىظتشۏأشعۏأتههۄأؼىۄأضەأوىمًهأۄەأڬۄأىثۏأ﷽أىەألشوتۏتأ=ألتذطۄأڬۏأڬوتةۏأرثۏخأۄەأۗ

[تخریج]: [ بخاری 2283 ]"
11688,"ذعشحأتثًۄشۏشۄأضەأشًتۏحأۄەأڬۄأىثۏأ﷽أىەأڬحەأڬۏأڬوتةۏأتًشأڲتىتأڲتىەأًتهۏأڬۏأڬوتةۏأضەأوىؼألشوتۏتأۗطۏرألشوتحەأۄۏڽأ=أتذحوتهأۄەأڬۄأتضأڬوتةۏأضەأوىؼألشوتۏتأۄًأدضأڬتأوؼهًوأىۄأۄًأڬۄأڬۄتڽأضەأتىہًڽأىەأڬوتۏتأۄەأذشتوأوۏڽأًتمؼأۄًىەأڬەأڋشأضەأۗ

[تخریج]: [ صحیح ]"
11689,"أؼثزتهشذوىأمشطۏألشوتحۏأۄۏڽأڬۄأشلتؼۄأثىأشتلؼأتىظتشأڬۏأودهضأڬۏأغشلأإةەأتًشألشوتۏتأ=أإدأۄوۏڽأشضًهأتههۄأ﷽أىەأثؼعأډۏصًڽأضەأوىؼأڬۏتأۄەأ؏أۄوۏڽأهًىڋۏأڬۏأڬوتةۏأضەأوىؼألشوتۏتأوڲشأدًأتضأىەأتځىەأۄتحہأضەأڬوتۏتأتًشأتځىۏأتىڲهۏأضەأتطتشۄأڬۏتأدۏضەأضًحأڬتحىتأ؏أىمطأًأىڲتشأتًشأځہًهأځحۏأًؽۏشۄأۗ

[تخریج]: [ صحیح ۔ ابوداؤد 3426 ]"
11690,"أذعشحأشتلؼأثىأرزۏدأضەأشًتۏحأۄەأڬۄأشضًهأتههۄأ﷽أىەأهًىڋۏأڬۏأڬوتةۏأضەأوىؼألشوتۏتأۏۄتڽأحڬأڬۄأؼهوأۄًأدتةەأڬۄأتضأىەأڬۄتڽأضەأڬوتۏتأۗ

[تخریج]: [ صحیح ]"
11691,"أذعشحأومزتوأثىأوؼزأۏڬشثأشعۏأتههۄأؼىۄأضەأوىمًهأۄەأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=أتىضتىأدًأڬہتىتأڬہتحتأۄەأتضأڬتأثۄحشأًۄأڬہتىتأۄەأدًأۄتحہأڬۏأڬوتةۏأضەأڬہتةەأۗأتههۄأڬەأىثۏأزتازأ+أؼهۏۄأتهضهتوأ,أتځىەأۄتحہأڬۏأڬوتةۏأضەأڬہتحەأحہەأۗ

[تخریج]: [ بخاری 2072 ]"
11692,"ذعشحأتثًۄشۏشۄأضەأشًتۏحأۄەأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=أزتازأ+أؼهۏۄأتهضهتوأ,أځشأصثًشأڬۏأحهتًحأإضتىأڬشأزۏأڲةۏأحہۏأۗأډىتىډۄأًۄأتځىۏأضًتشۏأځشأصۏىأڬضىەأڬتأذڬوأزۏحەأحہەأتًشأصۏىأڬضۏأدتىەأضەأځۄهەأۄۏأځًشۏأصثًشأځڔہأهۏحەأحہەأتًشأإځأظشلأتځىەأۄتحہًڽأڬۏأڬوتةۏأۄۏأڬہتحەأحہەأۗذعشحأؼتةطۄألشوتحۏأۄەأڬۄأشضًهأتههۄأ﷽أڬەأظذتثۄأڬتوأڬشىەأًتهەأهًڲأحہەأۗأتۏڬأشًتۏحأوۏڽأۄەأڬۄأًۄأتځىەأوشۏعًڽأڬتأؼهتدأرًزأڬشحەأحہەأۗأرثتثأثىأتشحأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أوۏڽأهًۄتشأڬتأڬتوأڬشحتأحہتأۗأتىضأثىأوتهڬأىثۏأ﷽أڬەأثۏټەأتثشتۄۏوأڬەأمظۄأوۏڽألشوتحەأۄۏڽأڬۄأإځأ﷽أىەأتثشتۄۏوأڬًأوزۏىۄأڬۏأتۏڬأهًۄتشۄأؼًشحأتوأضۏلأڬۏأغشلأثہۏدتأ؏أضہهأثىأضؼزأوىثشأًتهەأمظۄأوۏڽألشوتحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەأتۏڬأؼًشحأڬًأځۏؽتوأثہۏدتأڬۄأًۄأتځىەأؽهتوأڬًأذڬوأزەأڬۄأًۄأوۏشەأثۏټەأڬەأهۏەأوىثشأثىتةەأۗأذعشحأضۄهأضۏأوىمًهأۄەأڬۄأتۏڬأؼًشحأىثۏأ﷽أڬەأهۏەأډتزشأهەأڬشأإةۏأتًشألشوتىەأهڲۏأ=أۏتأشضًهأتههۄأ﷽أ$أوۏڽأىەأتځىەأۄتحہأضەأحۏتشأڬۏأۄەأحتڬۄأإځأڬًأځۄىتاڽأۗأذعشحأتثًوضؼًزأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أتىظتشۏًڽأڬتأتۏڬأإزوۏأحہتأدضأڬتأىتوأتثًطؼۏثأحہتأ؏أتضأڬتأؽهتوأڲًطحأڬشىەأًتهتأحہتأۗأتۏڬأشًتۏحأوۏڽأمظتثأڬەأهلػأۄۏڽأ=أتضأىەأڬۄتأ=أڬہتىتأحۏتشأڬشًأحتڬۄأوۏڽأشضًهأتههۄأ﷽أڬًأثهتاڽأۗأذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄأضەأذشوحأوڬۄأڬەأمظۄأوۏڽأوىمًهأۄەأڬۄأؼثتضأشعۏأتههۄأؼىۄأىەأڬۄتأ=أۏتأشضًهأتههۄأ﷽أتسرشأ+أثًټۏأ,أڬًأډہًڔأزۏڽأ؏أزتؽىەأڬەأهۏەأتًشأتځىۏأډہحًڽأڬەأهۏەأۗأإځأ﷽أىەألشوتۏتأ=أتسرشأڬًأډہًڔأزۏتأدتةەأۗأذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄأضەأوىمًهأۄەأڬۄأشضًهأتههۄأ﷽أىەأضۏىڲۏأهڲًتةۏأتًشأذدتوأڬًأتضأڬۏأتدشحأزۏأۗأتڲشأۏۄأإځأڬەأىصزۏڬأرثۏخأډۏصأۄًحۏأحًأىۄأزۏحەأتًشأۏۄأضتشەأتخشأڬوتةۏأڬەأدًتصأځشأزهتهحأڬشحەأۄۏڽأۗ

[تخریج]: [ بخاری 2073 ]"
11693,"أتثًوتدزۄأضەأوىمًهأۄەأڬۄأوۏڽأؽهتوأضەأهڔتأۗأوۏڽأىەأتضأڬتأڬتىأڬتټأڋتهتأۏتأتضأىەأوۏشتأڬتىأڬتټأڋتهتأۗأۄوتشۏأغشلأتثًثڬشأإةەأحًأۄوۏڽأتىأڬۏأغشلأځۏطأڬۏتأڲۏتأ=أۄوأىەأتىأځشأتځىتأدہڲڔتأځۏطأڬۏتأحًأتىہًڽأىەأۄوۏڽأذعشحأؼوشأشعۏأتههۄأؼىۄأڬۏأغشلأثہۏدأزۏتأۗأإځأىەألشوتۏتأ=أۏۄأوؼتوهۄأمظتظأحڬأځۄىډأڲۏتأۄەأۗأذدتوأڬًأثهتاأًۄأتضأضەأڬتټأزەأۗأزًأۏتأحۏىأزلؼۄألشوتۏتأ=أوۏڽأىەأشضًهأتههۄأ﷽أضەأضىتأۄەأڬۄأوۏڽأىەأتځىۏأرتهۄأڬًأؽهتوأۄثۄأڬۏتأ؏أتضأتوۏزأضەأڬۄأتضأوۏڽأرتهۄأڬەأهۏەأثشڬحأۄًأتًشأوۏڽأىەأڬۄتأ=أتضأڬًأذدتوأ؏أمظتةۏأتًشأزتؽىەأًتهەأڬەأضځشزأىۄأڬشىتأۗ

[تخریج]: [ ضعیف ]"
11694,"أۏۄأىۄۏأحىصۏۄۏأځشأوذوًهأۄەأىۄأڬۄأحذشۏوۏأځشأتًشأذدتوأڬۏأڬوتةۏأوۏڽأڬهتوأۄەأۗ

[تخریج]: [ ضعیف ]"
11695,"أذعشحأؼثزتههۄأشعۏأتههۄأؼىۄأضەأوىمًهأۄەأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=أذهتهأڬوتةۏأڬۏأغهثألشعأڬەأثؼزألشعأۄەأۗ

[تخریج]: [ ضعیف ]"
