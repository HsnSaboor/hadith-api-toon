{"hadithnumber": "5764", "text": "مجھ سے عبدالعزیز بن عبداللہ اویسی نے بیان کیا، کہا مجھ سے سلیمان بن بلال نے بیان کیا، ان سے ثور بن ز"}
{"hadithnumber": "5765", "text": "مجھ سے عبداللہ بن محمد مسندی نے بیان کیا، کہا کہ میں نے سفیان بن عیینہ سے سنا، کہا کہ سب سے پہلے یہ"}
{"hadithnumber": "5766", "text": "ہم سے عبید بن اسماعیل نے بیان کیا، کہا ہم سے ابواسامہ نے بیان کیا، ان سے ہشام بن عروہ نے، ان سے ان ک"}
{"hadithnumber": "5767", "text": "ہم سے عبداللہ بن یوسف نے بیان کیا، انہوں نے کہا کہ ہم کو امام مالک نے خبر دی، انہیں زید بن اسلم نے ا"}
{"hadithnumber": "5768", "text": "ہم سے علی بن عبداللہ مدینی نے بیان کیا، کہا ہم سے مروان بن معاویہ فزاری نے بیان کیا، کہا ہم کو ہاشم"}
{"hadithnumber": "5769", "text": "ہم سے اسحاق بن منصور نے بیان کیا، انہوں نے کہا ہم کو ابواسامہ حماد بن اسامہ نے خبر دی، انہوں نے کہا"}
{"hadithnumber": "5770", "text": "مجھ سے عبداللہ بن محمد مسندی نے بیان کیا، کہا ہم سے ہشام بن یوسف نے بیان کیا، کہا ہم کو معمر نے خبر"}
{"hadithnumber": "5771", "text": "اور ابوسلمہ سے روایت ہے انہوں نے ابوہریرہ رضی اللہ عنہ سے سنا کہ انہوں نے بیان کیا کہ  رسول اللہ صلی"}
{"hadithnumber": "5772", "text": "ہم سے سعید بن عفیر نے بیان کیا، انہوں نے کہا کہ مجھ سے عبداللہ بن وہب نے بیان کیا، ان سے یونس بن یزی"}
{"hadithnumber": "5775", "text": "اور زہری سے روایت ہے، انہوں نے بیان کیا کہ مجھے سنان بن ابی سنان الدؤلی نے خبر دی اور ان سے ابوہریرہ"}
{"hadithnumber": "5776", "text": "مجھ سے محمد بن بشار نے بیان کیا، کہا ہم سے ابن جعفر نے بیان کیا، ان سے شعبہ نے بیان کیا، کہا کہ میں"}
{"hadithnumber": "5777", "text": "ہم سے قتیبہ بن سعید نے بیان کیا، کہا ہم سے لیث بن سعد نے، ان سے سعید بن ابی سعید نے اور ان سے ابوہری"}
{"hadithnumber": "5778", "text": "ہم سے عبداللہ بن عبدالوہاب نے بیان کیا، انہوں نے کہا ہم سے خالد بن حارث نے بیان کیا، ان سے شعبہ نے ب"}
{"hadithnumber": "5779", "text": "ہم سے محمد بن سلام بیکندی نے بیان کیا، انہوں نے کہا ہم کو احمد بن بشیر ابوبکر نے خبر دی، انہوں نے کہ"}
{"hadithnumber": "5781", "text": "اور لیث نے زیادہ کیا ہے کہا کہ مجھ سے یونس نے بیان کیا، ان سے ابن شہاب زہری نے کہ  میں نے ابوادریس س"}
{"hadithnumber": "5782", "text": "ہم سے قتیبہ بن سعید نے بیان کیا، انہوں نے کہا ہم سے اسماعیل بن جعفر نے بیان کیا، انہوں نے کہا ہم سے"}
