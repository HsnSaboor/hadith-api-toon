{"hadithnumber": "2133", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ   ( ایک دن )  رسول اللہ صلی اللہ علیہ وسلم ہماری طرف نکلے، اس وقت"}
{"hadithnumber": "2134", "text": "ابوہریرہ رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”آدم اور موسیٰ نے باہم"}
{"hadithnumber": "2135", "text": "عمر رضی الله عنہ سے روایت ہے کہ  انہوں نے عرض کیا: اللہ کے رسول! جو عمل ہم کرتے ہیں اس کے بارے میں آ"}
{"hadithnumber": "2136", "text": "علی رضی الله عنہ کہتے ہیں کہ  ہم لوگ رسول اللہ صلی اللہ علیہ وسلم کے پاس بیٹھے ہوئے تھے، آپ زمین کری"}
{"hadithnumber": "2137", "text": "عبداللہ بن مسعود رضی الله عنہ کہتے ہیں کہ  ہم سے صادق و مصدوق رسول اللہ صلی اللہ علیہ وسلم نے بیان ک"}
{"hadithnumber": "2138", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”ہر بچہ فطرت  ( اسلام )"}
{"hadithnumber": "2139", "text": "سلمان رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”دعا کے سوا کوئی چیز تقدیر ک"}
{"hadithnumber": "2140", "text": "انس رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم اکثر یہ دعا پڑھتے تھے «يا مقلب القلوب ثبت"}
{"hadithnumber": "2141", "text": "عبداللہ بن عمرو بن عاص رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم  ( ایک بار )  ہماری"}
{"hadithnumber": "2142", "text": "انس رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جب اللہ تعالیٰ کسی بندے کے سا"}
{"hadithnumber": "2143", "text": "عبداللہ بن مسعود رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ہمارے درمیان کھڑے ہوئے اور ف"}
