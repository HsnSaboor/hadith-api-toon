hadiths[5]{hadithnumber,text}:
27689,"أذعشحأتوأثدۏزأشعۏأتههۄأؼىۄتأضەأوشًۏأۄەأڬۄأتۏڬأوشحثۄأوۏڽأىەأثتشڲتۄأىثًحأوۏڽأؼشعأڬۏتأۏتأشضًهأتههۄأ$أ+أ﷽أ,أثؼعأتًمتحأڬًةۏأوضڬۏىأوۏشەأڲہشأڬەأزشًتصەأځشأإأڬشأڬہڔتأۄًأدتحتأۄەأتًشأودہەأطشوأإحۏأۄەأڬۄأوۏشەأځتضأڲہشأوۏڽأڬډہأثہۏأىۄۏڽأۄەأ؏أدًأتضەأزەأضڬًڽأ؏أىثۏأ﷽أىەألشوتۏتأتضأڬەأۄتحہأځشأڬډہأىۄأڬډہأشڬہأزۏتأڬشًأتڲشډۄأًۄأدهتأۄًتأڬہشأۄۏأڬۏًڽأىۄأۄًأۗ"
27690,أڲصطحۄأذزۏخأتضأزًضشۏأضىزأضەأثہۏأوشًۏأۄەأۗأ
27691,"أذعشحأتوأثدۏزأشعۏأتههۄأؼىۄتأضەأوشًۏأۄەأڬۄأتۏڬأوشحثۄأوۏڽأىەأثتشڲتۄأىثًحأوۏڽأؼشعأڬۏتأۏتأشضًهأتههۄأ$أ+أ﷽أ,أثؼعأتًمتحأڬًةۏأوضڬۏىأوۏشەأڲہشأڬەأزشًتصەأځشأإأڬشأڬہڔتأۄًأدتحتأۄەأتًشأودہەأطشوأإحۏأۄەأڬۄأوۏشەأځتضأڲہشأوۏڽأڬډہأثہۏأىۄۏڽأۄەأ؏أدًأتضەأزەأضڬًڽأ؏أىثۏأ﷽أىەألشوتۏتأتضأڬەأۄتحہأځشأڬډہأىۄأڬډہأشڬہأزۏتأڬشًأتڲشډۄأًۄأدهتأۄًتأڬہشأۄۏأڬۏًڽأىۄأۄًأۗ"
27692,"أذعشحأتوأثدۏزأشعۏأتههۄأؼىۄتأضەأوشًۏأۄەأڬۄأتۏڬأوشحثۄأوۏڽأىەأثتشڲتۄأىثًحأوۏڽأؼشعأڬۏتأۏتأشضًهأتههۄأ$أ+أ﷽أ,أثؼعأتًمتحأڬًةۏأوضڬۏىأوۏشەأڲہشأڬەأزشًتصەأځشأإأڬشأڬہڔتأۄًأدتحتأۄەأتًشأودہەأطشوأإحۏأۄەأڬۄأوۏشەأځتضأڲہشأوۏڽأڬډہأثہۏأىۄۏڽأۄەأ؏أدًأتضەأزەأضڬًڽأ؏أىثۏأ﷽أىەألشوتۏتأتضأڬەأۄتحہأځشأڬډہأىۄأڬډہأشڬہأزۏتأڬشًأتڲشډۄأًۄأدهتأۄًتأڬہشأۄۏأڬۏًڽأىۄأۄًأۗ"
27693,أذعشحأتوأثدۏزأشعۏأتههۄأؼىۄتأضەأوشًۏأۄەأڬۄأتۏڬأوشحثۄأىثۏأ﷽أىەألشوتۏتأضتةهأڬەأۄتحہأځشأڬډہأىۄأڬډہأشڬہأزۏتأڬشًأتڲشډۄأًۄأدهتأۄًتأڬہشأۄۏأڬۏًڽأىۄأۄًأۗ
