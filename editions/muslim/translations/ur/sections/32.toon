{"hadithnumber": "4519", "text": "یحییٰ بن یحییٰ تمیمی نے کہا :  سلیم بن اخضر نے ہمیں ابن عون سے حدیث بیان کی ،  انہوں نے کہا :  میں ن"}
{"hadithnumber": "4520", "text": "ابن ابی عدی نے ابن عون سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی اور انہوں نے جویریہ بنت حارث رضی"}
{"hadithnumber": "4523", "text": "عبدالصمد بن عبدالوارث نے مجھے حدیث بیان کی ،  کہا :  ہمیں شعبہ نے حدیث سنائی ،  کہا :  مجھے علقمہ بن"}
{"hadithnumber": "4524", "text": "حسین بن ولید نے شعبہ سے یہی حدیث روایت کی"}
{"hadithnumber": "4525", "text": "حضرت ابوموسیٰ رضی اللہ عنہ سے روایت ہے ،  انہوں نے کہا :  رسول اللہ صلی اللہ علیہ وسلم اپنے ساتھیوں"}
{"hadithnumber": "4526", "text": "شعبہ نے سعید بن ابی بردہ سے ،  انہوں نے اپنے والد کے حوالے سے اپنے دادا  ( حضرت ابوموسیٰ اشعری رضی ا"}
{"hadithnumber": "4527", "text": "عمرو اور زید بن ابی انیسہ دونوں نے سعید بن ابی بردہ سے روایت کی ،  انہوں نے اپنے والد سے  ( آگے )  ا"}
{"hadithnumber": "4528", "text": "حضرت انس بن مالک رضی اللہ عنہ کہتے ہیں :  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   \" آسانی کرو ،"}
{"hadithnumber": "4529", "text": "عبیداللہ نے نافع سے ، انہوں نے حضرت ابن عمر رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  رسول اللہ صل"}
{"hadithnumber": "4530", "text": "ایوب اور صخر بن جویریہ دونوں نے نافع سے ،  انہوں نے حضرت ابن عمر رضی اللہ عنہ سے اور انہوں نے نبی صل"}
{"hadithnumber": "4531", "text": "عبداللہ بن دینار سے روایت ہے ،  انہوں نے حضرت عبداللہ بن عمر رضی اللہ عنہ سے سنا ،  وہ کہہ رہے تھے :"}
{"hadithnumber": "4532", "text": "عبداللہ  ( بن عمر رضی اللہ عنہ )  کے دو بیٹوں حمزہ اور سالم سے روایت ہے کہ حضرت عبداللہ بن عمر رضی ا"}
{"hadithnumber": "4533", "text": "محمد بن ابراہیم )  ابن ابی عدی اور محمد بن جعفر دونوں نے شعبہ سے حدیث بیان کی ،  انہوں نے سلیمان  ("}
{"hadithnumber": "4534", "text": "نضر بن شمیل اور عبدالرحمان  ( بن مہدی )  نے شعبہ سے اسی سند کے ساتھ حدیث بیان کی اور عبدالرحمان کی ح"}
{"hadithnumber": "4535", "text": "یزید بن عبدالعزیز نے اعمش سے ،  انہوں نے شقیق سے اور انہوں نے حضرت عبداللہ رضی اللہ عنہ سے روایت کی"}
{"hadithnumber": "4536", "text": "حضرت انس رضی اللہ عنہ سے روایت ہے ،  انہوں نے کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   \" ہر"}
{"hadithnumber": "4537", "text": "خُلید نے ابونضرہ سے ،  انہوں نے حضرت ابوسعید رضی اللہ عنہ سے اور انہوں نے نبی صلی اللہ علیہ وسلم سے"}
{"hadithnumber": "4538", "text": "مستمر بن ریان نے ہمیں حدیث بیان کی ،  کہا :  ہمیں ابونضرہ نے حضرت ابوسعید رضی اللہ عنہ سے حدیث بیان"}
{"hadithnumber": "4539", "text": "حضرت جابر رضی اللہ عنہ کہتے ہیں کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   \" جنگ ایک چال ہے"}
{"hadithnumber": "4540", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ،  انہوں نے کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :"}
{"hadithnumber": "4541", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ نبی صلی اللہ علیہ وسلم نے فرمایا :   \" دشمن سے مقابلے کی ت"}
{"hadithnumber": "4542", "text": "ابونضر سے روایت ہے ،  انہوں نے نبی صلی اللہ علیہ وسلم کے ساتھیوں میں سے قبیلہ اسلم کے ایک آدمی ،  جن"}
{"hadithnumber": "4543", "text": "خالد بن عبداللہ نے ہمیں اسماعیل بن ابی خالد سے حدیث بیان کی ،  انہوں نے حضرت عبداللہ بن ابی اوفیٰ رض"}
{"hadithnumber": "4544", "text": "وکیع بن جراح نے ہمیں اسماعیل بن ابی خالد سے حدیث بیان کی ،  انہوں نے کہا :  میں نے ابن ابی اوفیٰ رضی"}
{"hadithnumber": "4545", "text": "اسحاق بن ابراہیم اور ابن ابی عمر نے ابن عیینہ سے ،  انہوں نے اسماعیل سے اسی سند کے ساتھ حدیث بیان کی"}
{"hadithnumber": "4546", "text": "حضرت انس رضی اللہ عنہ سے روایت ہے کہ  ( جنگِ )  احد کے دن رسول اللہ صلی اللہ علیہ وسلم  ( بار بار )"}
{"hadithnumber": "4547", "text": "لیث نے نافع سے ،  انہوں نے حضرت عبداللہ رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ علیہ وسلم کے"}
{"hadithnumber": "4548", "text": "عبیداللہ بن عمر نے ہمیں نافع کے حوالے سے حضرت ابن عمر رضی اللہ عنہ سے حدیث بیان کی ،  انہوں نے کہا :"}
{"hadithnumber": "4549", "text": "سفیان بن عیینہ نے ہمیں زہری سے خبر دی ،  انہوں نے عبیداللہ سے ،  انہوں نے حضرت ابن عباس رضی اللہ عنہ"}
{"hadithnumber": "4550", "text": "معمر نے ہمیں زہری سے خبر دی ،  انہوں نے عبیداللہ بن عبداللہ بن عتبہ سے ،  انہوں نے حضرت ابن عباس رضی"}
{"hadithnumber": "4551", "text": "عمرو بن دینار نے مجھے خبر دی کہ انہیں ابن شہاب نے عبیداللہ بن عبداللہ بن عتبہ سے خبر دی ،  انہوں نے"}
{"hadithnumber": "4552", "text": "یحییٰ بن یحییٰ ،  محمد بن رمح اور قتیبہ بن سعید نے لیث سے حدیث بیان کی ،  انہوں نے نافع سے اور انہوں"}
{"hadithnumber": "4553", "text": "موسیٰ بن عقبہ نے نافع سے ،  انہوں نے حضرت ابن عمر رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ علی"}
{"hadithnumber": "4554", "text": "عبیداللہ نے نافع سے اور انہوں نے حضرت عبداللہ بن عمر رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  رسو"}
{"hadithnumber": "4555", "text": "ہمام بن منبہ سے روایت ہے ،  انہوں نے کہا :  یہ  ( احادیث )  ہیں جو ہمیں حضرت ابوہریرہ رضی اللہ عنہ ن"}
{"hadithnumber": "4556", "text": "ابوعوانہ نے سماک سے ،  انہوں نے مصعب بن سعد سے اور انہوں نے اپنے والد  ( حضرت سعد بن ابی وقاص رضی ال"}
{"hadithnumber": "4557", "text": "شعبہ نے ہمیں سماک بن حرب سے حدیث بیان کی ،  انہوں نے مصعب بن سعد سے اور انہوں نے اپنے والد سے روایت"}
{"hadithnumber": "4558", "text": "امام مالک نے نافع سے اور انہوں نے حضرت ابن عمر رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  نبی صلی ا"}
{"hadithnumber": "4559", "text": "لیث نے نافع سے ،  انہوں نے حضرت ابن عمر رضی اللہ عنہ سے روایت کی کہ نبی صلی اللہ علیہ وسلم نے نجد کی"}
{"hadithnumber": "4560", "text": "علی بن مسہر اور عبدالرحیم بن سلیمان نے عبیداللہ بن عمر سے ،  انہوں نے نافع سے اور انہوں نے حضرت ابن"}
{"hadithnumber": "4561", "text": "ٰ قطان نے عبیداللہ سے اسی سند کے ساتھ حدیث بیان کی"}
{"hadithnumber": "4562", "text": "ایوب نے ہمیں حدیث بیان کی ،  اور  ( ایک دوسری سند سے )  ابن عون نے کہا :  میں نے غنیمت کے بارے میں پ"}
{"hadithnumber": "4563", "text": "عبداللہ بن رجاء نے یونس سے ،  انہوں نے زہری سے ،  انہوں نے سالم سے اور انہوں نے اپنے والد  ( حضرت اب"}
{"hadithnumber": "4564", "text": "ابن مبارک اور ابن وہب دونوں نے یونس کے حوالے سے زہری سے حدیث بیان کی ،  انہوں نے کہا :  مجھ حضرت ابن"}
{"hadithnumber": "4565", "text": "عقیل بن خالد نے ابن شہاب سے ،  انہوں نے سالم سے اور انہوں نے حضرت عبداللہ رضی اللہ عنہ سے روایت کی ک"}
{"hadithnumber": "4566", "text": "ہشیم نے یحییٰ بن سعید سے ،  انہوں نے عمر بن کثیر بن افلح سے اور انہوں نے ابومحمد انصاری سے روایت کی"}
{"hadithnumber": "4567", "text": "لیث نے یحییٰ بن سعید سے ،  انہوں نے عمر بن کثیر بن افلح سے ،  انہوں نے ابومحمد  ( المعروف بہ )  مولی"}
{"hadithnumber": "4568", "text": "امام مالک بن انس کہتے ہیں :  مجھے یحییٰ بن سعید نے عمر بن کثیر بن افلح سے حدیث بیان کی ،  انہوں نے ا"}
{"hadithnumber": "4569", "text": "حضرت عبدالرحمان بن عوف رضی اللہ عنہ سے روایت ہے ،  انہوں نے کہا :  بدر کے دن جب میں صف میں کھڑا تھا"}
{"hadithnumber": "4570", "text": "معاویہ بن صالح نے عبدالرحمان بن جبیر سے ،  انہوں نے اپنے والد سے اور انہوں نے حضرت عوف بن مالک رضی ا"}
{"hadithnumber": "4571", "text": "صفوان بن عمرو نے عبدالرحمان بن جبیر بن نفیر سے ،  انہوں نے اپنے والد سے اور انہوں نے حضرت عوف بن مال"}
{"hadithnumber": "4572", "text": "ایاس بن سلمہ نے کہا :  مجھے میرے والد حضرت سلمہ بن اکوع رضی اللہ عنہ نے حدیث بیان کی ،  انہوں نے کہا"}
{"hadithnumber": "4573", "text": "حضرت سلمہ بن اکوع رضی اللہ عنہ نے کہا :  ہم نے بنوفزارہ سے جنگ لڑی ،  حضرت ابوبکر رضی اللہ عنہ ہمارے"}
{"hadithnumber": "4574", "text": "ہمام بن منبہ سے روایت ہے ،  انہوں نے کہا :  یہ احادیث ہیں جو حضرت ابوہریرہ رضی اللہ عنہ نے ہمیں محمد"}
{"hadithnumber": "4575", "text": "قتیبہ بن سعید ،  محمد بن عباد ،  ابوبکر بن ابی شیبہ اور اسحاق بن ابراہیم نے ہمیں حدیث بیان کی ،  الف"}
{"hadithnumber": "4576", "text": "معمر نے زہری سے اسی سند کے ساتھ روایت کی"}
{"hadithnumber": "4577", "text": "امام مالک نے زہری سے روایت کی کہ انہیں مالک بن اوس نے حدیث بیان کی ،  انہوں نے کہا :  حضرت عمر بن خط"}
{"hadithnumber": "4578", "text": "معمر نے ہمیں زہری سے خبر دی ،  انہوں نے مالک بن اوس بن حدثان سے روایت کی ،  انہوں نے کہا :  حضرت عمر"}
{"hadithnumber": "4579", "text": "ام المومنین حضرت عائشہ رصی اﷲ عنہا سے روایت ہے جب رسول اﷲ  صلی ‌اللہ ‌علیہ ‌وسلم  کی وفات ہوئی تو آپ"}
{"hadithnumber": "4580", "text": "ام المومنین حضرت عائشہ رضی ‌اللہ ‌عنہ  سے روایت ہے حضرت فاطمہ زہرا رضی ‌اللہ ‌عنہ  رسول اﷲ  صلی ‌الل"}
{"hadithnumber": "4581", "text": "ام المومنین حضرت عائشہ رضی اﷲ عنہا سے روایت ہے حضرت فاطمہ زہرا رضی ‌اللہ ‌عنہ  اور حضرت عباس دونوں ح"}
{"hadithnumber": "4582", "text": "ام المومنین حضرت عائشہ رضی اﷲ عنہما سے روایت ہے حضرت فاطمہ رضی اﷲ عنہا رسول اﷲ  صلی ‌اللہ ‌علیہ ‌وسل"}
{"hadithnumber": "4583", "text": "حضرت ‌ابوہریرہ ‌رضی ‌اللہ ‌عنہ ‌سے ‌روایت ‌ہے ‌رسول ‌اللہ ‌صلی ‌اللہ ‌علیہ ‌وسلم ‌نے ‌فرمایا ‌میرے ‌"}
{"hadithnumber": "4584", "text": "ترجمہ ‌وہی ‌جو ‌اوپر ‌٤٥٨٣ ‌میں ‌گزرا۔"}
{"hadithnumber": "4585", "text": "ابو ‌ہریرہ ‌رضی ‌اللہ ‌عنہ ‌سے ‌روایت ‌ہے ‌كہ ‌رسول ‌اللہ ‌صلی ‌اللہ ‌علیہ ‌وسلم ‌نے ‌فرمایا ‌ہمارا"}
{"hadithnumber": "4586", "text": "سلیم بن اخضر نے ہمیں عبیداللہ بن عمر سے خبر دی ،  کہا :  ہمیں نافع نے حضرت عبداللہ بن عمر رضی اللہ ع"}
{"hadithnumber": "4587", "text": "عبداللہ بن نمیر نے عبیداللہ سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی اور انہوں نے یہ نہیں کہا :"}
{"hadithnumber": "4588", "text": "ابوزمیل سماک حنفی نے کہا :  مجھے عبداللہ بن عباس رضی اللہ عنہ نے حدیث بیان کی ،  انہوں نے کہا :  جب"}
{"hadithnumber": "4589", "text": "لیث نے ہمیں سعید بن ابی سعید سے حدیث بیان کی کہ انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے سنا ،  وہ کہہ"}
{"hadithnumber": "4590", "text": "اور انہوں نے لیث کی حدیث کے مانند حدیث بیان کی ،  البتہ انہوں نے  ( آپ قتل کریں گے کے بجائے )  \"  اگ"}
{"hadithnumber": "4591", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ،  انہوں نے کہا :  ایک بار ہم مسجد میں تھے کہ  ( اچانک )  رسو"}
{"hadithnumber": "4592", "text": "ابن جریج نے موسیٰ بن عقبہ سے ،  انہوں نے نافع سے اور انہوں نے حضرت ابن عمر رضی اللہ عنہ سے روایت کی"}
{"hadithnumber": "4593", "text": "حفص بن میسرہ نے موسیٰ سے یہ حدیث اسی سند کے ساتھ بیان کی اور ابن جریج کی حدیث زیادہ لمبی اور زیادہ م"}
{"hadithnumber": "4594", "text": "ابن جریج نے ہمیں خبر دی ،  کہا :  مجھے ابوزبیر نے خبر دی ،  انہوں نے حضرت جابر بن عبداللہ رضی اللہ ع"}
{"hadithnumber": "4595", "text": "سفیان ثوری اور معقل بن عبیداللہ دونوں نے ابوزبیر سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی"}
{"hadithnumber": "4596", "text": "ابوبکر بن ابی شیبہ ،  محمد بن مثنیٰ اور ابن بشار نے  ۔  ۔  ان سب کے الفاظ قریب قریب ہیں  ۔  ۔  ہمیں"}
{"hadithnumber": "4597", "text": "عبدالرحمان بن مہدی نے شعبہ سے اسی سند کے ساتھ حدیث بیان کی اور انہوں نے اپنی حدیث میں کہا :  تو رسول"}
{"hadithnumber": "4598", "text": "حضرت عائشہ رضی اللہ عنہا سے روایت ہے ،  انہوں نے کہا :  خندق کے دن حضرت سعد رضی اللہ عنہ زخمی ہو گئے"}
{"hadithnumber": "4599", "text": "عروہ نے کہا :  مجھے بتایا گیا ہے کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   \" تم نے ان کے بارے می"}
{"hadithnumber": "4600", "text": "ابن نمیر نے ہشام سے حدیث بیان کی ،  کہا :  مجھے میرے والد نے حضرت عائشہ رضی اللہ عنہا سے خبر دی کہ ح"}
{"hadithnumber": "4601", "text": "عبدہ نے ہشام سے اسی سند کے ساتھ اسی طرح حدیث بیان کی ،  البتہ انہوں نے کہا :  اسی رات سے خوب بہنے لگ"}
