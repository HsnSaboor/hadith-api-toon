metadata:
  section_id: 61
  section_name: "The Names of the Prophet, may Allah Bless Him and Grant Him Peace"
  hadith_first: 1858
  hadith_last: 1858
  arabic_first: 1858
  arabic_last: 1858

hadiths[1]{hadithnumber,text,reference_book,reference_hadith}:
1858,"حدثني مالك، عن ابن شهاب، عن محمد بن جبير بن مطعم، ان النبي صلى الله عليه وسلم قال "" لي خمسة اسماء انا محمد وانا احمد وانا الماحي الذي يمحو الله بي الكفر وانا الحاشر الذي يحشر الناس على قدمي وانا العاقب",61,1
