{"hadithnumber": "4142", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے بستروں اور بچھونوں کا ذک"}
{"hadithnumber": "4143", "text": "جابر بن سمرہ رضی اللہ عنہ کہتے ہیں کہ  میں نبی اکرم صلی اللہ علیہ وسلم کے گھر میں داخل ہوا تو آپ کو"}
{"hadithnumber": "4144", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  انہوں نے اہل یمن کے سفر کے چند ساتھیوں کو دیکھا ان کے"}
{"hadithnumber": "4145", "text": "جابر رضی اللہ عنہ کہتے ہیں کہ  مجھ سے رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  کیا تم نے توشک اور گد"}
{"hadithnumber": "4146", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کا تکیہ، جس پر آپ رات کو س"}
{"hadithnumber": "4147", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کا گدا چمڑے کا تھا جس میں"}
{"hadithnumber": "4148", "text": "ام المؤمنین ام سلمہ رضی اللہ عنہا کہتی ہیں کہ  ان کا بسترا رسول اللہ صلی اللہ علیہ وسلم کے نماز پڑھن"}
{"hadithnumber": "4149", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم فاطمہ رضی اللہ عنہا کے پا"}
{"hadithnumber": "4150", "text": "فضیل سے یہی حدیث مروی ہے  اس میں ہے کہ وہ ایک منقش پردہ تھا۔"}
{"hadithnumber": "4151", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم اپنے گھر میں کسی ایسی چ"}
{"hadithnumber": "4152", "text": "علی رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  فرشتے اس گھر میں داخل نہیں ہوت"}
{"hadithnumber": "4153", "text": "ابوطلحہ انصاری رضی اللہ عنہ کہتے ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم کو فرماتے سنا:  فرشتے ای"}
