{"metadata":{"name":"Sunan Ibn Majah","section":{"17":"The Chapters on Pre-emption"},"section_detail":{"17":{"hadithnumber_first":2492,"hadithnumber_last":2501,"arabicnumber_first":2492,"arabicnumber_last":2501}}},"hadiths":[{"hadithnumber":2492,"arabicnumber":2492,"text":"Rapporté par Jabir : Le Messager d'Allah (ﷺ) a dit : \"Celui qui possède un palmier ou un terrain ne doit pas le vendre sans l'avoir d'abord proposé à son associé","grades":[{"name":"Al-Albani","grade":"Sahih"},{"name":"Muhammad Fouad Abd al-Baqi","grade":"Sahih"},{"name":"Shuaib Al Arnaut","grade":"Sahih"},{"name":"Zubair Ali Zai","grade":"Isnaad Sahih"}],"reference":{"book":17,"hadith":1}}]}