{"hadithnumber": "4773", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم لوگوں میں سب سے بہتر اخلاق والے تھے، ایک"}
{"hadithnumber": "4774", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  میں نے دس سال مدینہ میں نبی اکرم صلی اللہ علیہ وسلم کی خدمت کی، میں ای"}
{"hadithnumber": "4775", "text": "ہلال بیان کرتے ہیں کہ  ابوہریرہ رضی اللہ عنہ نے ہم سے بیان کرتے ہوئے کہا: نبی اکرم صلی اللہ علیہ وسل"}
{"hadithnumber": "4776", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  راست روی، خوش خل"}
{"hadithnumber": "4777", "text": "معاذ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے اپنا غصہ پی لیا حالانک"}
{"hadithnumber": "4778", "text": "نبی اکرم صلی اللہ علیہ وسلم کے اصحاب کے فرزندوں میں سے ایک شخص اپنے والد سے روایت کرتے ہیں کہ  رسول"}
{"hadithnumber": "4779", "text": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم لوگ پہلوان کس"}
{"hadithnumber": "4780", "text": "معاذ بن جبل رضی اللہ عنہ کہتے ہیں کہ  دو شخصوں نے نبی اکرم صلی اللہ علیہ وسلم کے پاس گالی گلوج کی تو"}
{"hadithnumber": "4781", "text": "سلیمان بن صرد کہتے ہیں کہ  دو شخصوں نے نبی اکرم صلی اللہ علیہ وسلم کے پاس گالی گلوج کی تو ان میں سے"}
{"hadithnumber": "4782", "text": "ابوذر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ہم سے فرمایا:  جب تم میں سے کسی کو غ"}
{"hadithnumber": "4783", "text": "بکر سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے ابوذر کو بھیجا آگے یہی حدیث مروی ہے۔ ابوداؤد کہتے"}
{"hadithnumber": "4784", "text": "ابووائل قاص کہتے ہیں کہ  ہم عروہ بن محمد بن سعدی کے پاس داخل ہوئے، ان سے ایک شخص نے گفتگو کی تو انہی"}
{"hadithnumber": "4785", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کو دو کاموں میں جب بھی اخت"}
{"hadithnumber": "4786", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے نہ کبھی کسی خادم کو مار"}
{"hadithnumber": "4787", "text": "عبداللہ بن زبیر رضی اللہ عنہما سے  اللہ کے فرمان  «خذ العفو»  عفو کو اختیار کرو  کی تفسیر کے سلسلے م"}
{"hadithnumber": "4788", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کو جب کسی شخص کے بارے میں"}
{"hadithnumber": "4789", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  ایک شخص رسول اللہ صلی اللہ علیہ وسلم کے پاس آیا، اس پر زردی کا نشان تھ"}
{"hadithnumber": "4790", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مومن بھولا بھالا اور شری"}
{"hadithnumber": "4791", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  ایک شخص نے رسول اللہ صلی اللہ علیہ وسلم سے  ( اندر آنے"}
{"hadithnumber": "4792", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  ایک شخص نے نبی اکرم صلی اللہ علیہ وسلم کے پاس اندر آنے"}
{"hadithnumber": "4793", "text": "اس سند سے بھی ام المؤمنین عائشہ رضی اللہ عنہا سے یہی واقعہ مروی ہے، وہ کہتی ہیں  آپ نے یعنی نبی اکرم"}
{"hadithnumber": "4794", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  میں نے کسی شخص کو نہیں دیکھا جس نے رسول اللہ صلی اللہ علیہ وسلم کے کان"}
{"hadithnumber": "4795", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم انصار کے ایک شخص پر سے گزرے،"}
{"hadithnumber": "4796", "text": "ابوقتادہ کہتے ہیں  ہم عمران بن حصین رضی اللہ عنہما کے ساتھ تھے اور وہاں بشیر بن کعب بھی تھے تو عمران"}
{"hadithnumber": "4797", "text": "ابومسعود رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  سابقہ نبوتوں کے کلام میں"}
{"hadithnumber": "4798", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  موم"}
{"hadithnumber": "4799", "text": "ابوالدرداء رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:   ( قیامت کے دن )  میزان"}
{"hadithnumber": "4800", "text": "ابوامامہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  میں اس شخص کے لیے جنت کے"}
{"hadithnumber": "4801", "text": "حارثہ بن وہب رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: «جواظ» جنت میں نہ داخ"}
{"hadithnumber": "4802", "text": "انس رضی اللہ عنہ کہتے ہیں کہ   ( نبی اکرم صلی اللہ علیہ وسلم کی اونٹنی )  عضباء مقابلے میں کبھی پیچھ"}
{"hadithnumber": "4803", "text": "اس سند سے بھی انس رضی اللہ عنہ سے یہی قصہ مرفوعاً مروی ہے  اس میں ہے، آپ نے فرمایا:  اللہ تعالیٰ کا"}
{"hadithnumber": "4804", "text": "ہمام کہتے ہیں کہ  ایک شخص آیا اور عثمان رضی اللہ عنہ کی تعریف انہی کے سامنے کرنے لگا، تو مقداد بن اس"}
{"hadithnumber": "4805", "text": "ابوبکرہ رضی اللہ عنہ کہتے ہیں کہ  ایک شخص نے نبی اکرم صلی اللہ علیہ وسلم کے پاس ایک شخص کی تعریف کی،"}
{"hadithnumber": "4806", "text": "مطرف کے والد عبداللہ بن شخیر کہتے ہیں کہ  میں بنی عامر کے وفد میں رسول اللہ صلی اللہ علیہ وسلم کے پا"}
{"hadithnumber": "4807", "text": "عبداللہ بن مغفل رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ رفیق ہے، رفق"}
{"hadithnumber": "4808", "text": "شریح کہتے ہیں کہ  میں نے ام المؤمنین عائشہ رضی اللہ عنہا سے دیہات  ( بادیہ )  جانے، وہاں قیام کرنے ک"}
{"hadithnumber": "4809", "text": "جریر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو رفق  ( نرمی )  سے محروم ک"}
{"hadithnumber": "4810", "text": "سعد رضی اللہ عنہ کہتے ہیں کہ  تاخیر اور آہستگی ہر چیز میں  ( بہتر )  ہے، سوائے آخرت کے عمل کے ۱؎۔ اع"}
{"hadithnumber": "4811", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جو لوگوں کا شکر ادا نہیں"}
{"hadithnumber": "4812", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  مہاجرین نے کہا: اللہ کے رسول! سارا اجر تو انصار لے گئے، آپ نے فرمایا:"}
{"hadithnumber": "4813", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس کو کوئی چیز"}
{"hadithnumber": "4814", "text": "جابر رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جس شخص کو کوئی چیز ملے اور"}
{"hadithnumber": "4815", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم لوگ راستوں میں ب"}
{"hadithnumber": "4816", "text": "ابوہریرہ رضی اللہ عنہ سے یہی قصہ مرفوعاً مروی ہے  اس میں یہ بھی ہے آپ نے فرمایا:  اور  ( بھولے بھٹکو"}
{"hadithnumber": "4817", "text": "ابن حجیر عدوی کہتے ہیں کہ  میں نے اس قصے میں عمر بن خطاب رضی اللہ عنہ کو نبی اکرم صلی اللہ علیہ وسلم"}
{"hadithnumber": "4818", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  ایک عورت رسول اللہ صلی اللہ علیہ وسلم کے پاس آئی، اور بولی: اللہ کے رس"}
{"hadithnumber": "4819", "text": "انس رضی اللہ عنہ سے روایت ہے کہ  ایک عورت تھی جس کی عقل میں کچھ فتور تھا پھر انہوں نے اسی مفہوم کی ح"}
{"hadithnumber": "4820", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا:  مجا"}
{"hadithnumber": "4821", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  ابوالقاسم صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں سے کوئی دھوپ م"}
{"hadithnumber": "4822", "text": "ابوحازم البجلی رضی اللہ عنہ کہتے ہیں کہ  وہ آئے اور رسول اللہ صلی اللہ علیہ وسلم خطبہ دے رہے تھے، تو"}
{"hadithnumber": "4823", "text": "جابر بن سمرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم مسجد میں داخل ہوئے اور لوگ حلقے"}
{"hadithnumber": "4824", "text": "اعمش سے بھی یہی حدیث مروی ہے  البتہ اس میں ہے  گویا کہ آپ اجتماعیت کو پسند فرماتے تھے ۔"}
{"hadithnumber": "4825", "text": "جابر بن سمرہ رضی اللہ عنہ کہتے ہیں کہ  جب ہم نبی اکرم صلی اللہ علیہ وسلم کے پاس آتے، تو ہم میں سے جس"}
{"hadithnumber": "4826", "text": "حذیفہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے اس پر لعنت فرمائی جو حلقہ کے بیچ"}
{"hadithnumber": "4827", "text": "سعید بن ابوالحسن کہتے ہیں کہ  ابوبکرہ رضی اللہ عنہ ایک گواہی کے سلسلے میں ہمارے ہاں آئے، تو ان کے لی"}
