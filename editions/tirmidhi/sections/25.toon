hadiths[count]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}:
1788,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُعَاذُ بْنُ هِشَامٍ، حَدَّثَنِي أَبِي، عَنْ يُونُسَ،,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأطعمة ۸ (۵۳۸۶)، ۲۳ (۵۴۱۵)، والرقاق ۱۶ (۶۴۵۰)، سنن ابن ماجہ/الأطعمة ۲۰ (۳۲۹۲)، والمؤلف في الزہد ۳۸ (۲۳۶۳)، والشمائل ۲۵ (تحفة الأشراف : ۱۴۴۴)، و مسند احمد (۳/۱۳۰),1788,,The Book on Food
1789,حَدَّثَنَا مَحْمُودُ بْنُ غَيْلَانَ، حَدَّثَنَا أَبُو دَاوُدَ، أَخْبَرَنَا شُعْبَةُ، عَنْ هِشَامِ بْ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الہبة ۵ (۲۵۷۲)، والصید ۱۰ (۵۴۸۹)، و ۳۲ (۵۵۳۵)، صحیح مسلم/الصید ۹ (۱۹۵۳)، سنن ابی داود/ الأطعمة ۲۷ (۳۷۹۱)، سنن النسائی/الصید ۲۵ (۴۳۱۷)، سنن ابن ماجہ/الصید ۱۷ (۳۲۴۳)، (تحفة الأشراف : ۱۶۲۹)، و مسند احمد (۳/۱۱۸، ۱۷۱)، سنن الدارمی/الصید ۷ (۲۰۵۶),1789,,The Book on Food
1790,حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، عَنْ عَبْدِ اللَّهِ بْنِ دِينَارٍ، عَنْ ابْنِ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف، (تحفة الأشراف : ۷۲۴۰),1790,,The Book on Food
1791,حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا إِسْمَاعِيل بْنُ إِبْرَاهِيمَ، أَخْبَرَنَا ابْنُ جُرَيْ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأطعمة ۳۲ (۳۸۰۱)، سنن النسائی/الحج ۸۹ (۲۸۳۹)، والصید ۲۷ (۴۳۲۸)، سنن ابن ماجہ/المناسک ۹۰ (۳۰۸۵)، والصید ۱۵ (۳۲۳۶)، (تحفة الأشراف : ۲۳۸۱)، و مسند احمد (۳/۲۹۷، ۳۱۸، ۳۲۲)، سنن الدارمی/المناسک ۹۰ (۱۹۸۴),1791,,The Book on Food
1792,حَدَّثَنَا هَنَّادٌ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، عَنْ إِسْمَاعِيل بْنِ مُسْلِمٍ، عَنْ عَبْدِ الْكَ,Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: سنن ابن ماجہ/الصید ۱۴ (۳۲۳۵)، و ۱۵ (۳۲۳۷),1792,,The Book on Food
1793,دَّثَنَا قُتَيْبَةُ، وَنَصْرُ بْنُ عَلِيٍّ، قَالاَ حَدَّثَنَا سُفْيَانُ، عَنْ عَمْرِو بْنِ دِينَارٍ،,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: صحیح,1793,,The Book on Food
1794,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا عَبْدُ الْوَهَّابِ الثَّقَفِيُّ، عَنْ يَحْيَى بْنِ سَ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih,takhreej: تخریج دارالدعوہ: انظر ما قبلہ (تحفة الأشراف : ۲۶۳۹),1794,,The Book on Food
1795,حَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا حُسَيْنُ بْنُ عَلِيٍّ الْجُعْفِيُّ، عَنْ زَائِدَةَ، عَنْ مُحَم,Ahmad Muhammad Shakir: Hasan Sahih; Al-Albani: Hasan Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۱۵۰۲۶),1795,,The Book on Food
1796,حَدَّثَنَا زَيْدُ بْنُ أَخْزَمَ الطَّائِيُّ، حَدَّثَنَا سَلْمُ بْنُ قُتَيْبَةَ، حَدَّثَنَا شُعْبَةُ،,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: انظر حدیث رقم ۱۴۶۴ و ۱۵۶۰,1796,,The Book on Food
1797,حَدَّثَنَا عَلِيُّ بْنُ عِيسَى بْنِ يَزِيدَ الْبَغْدَادِيُّ، حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ مُحَمّ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: انظر حدیث رقم ۱۴۶۴و ۱۵۶۰,1797,,The Book on Food
1798,حَدَّثَنَا سَعِيدُ بْنُ عَبْدِ الرَّحْمَنِ الْمَخْزُومِيُّ، وَأَبُو عَمَّارٍ، قَالَا:‏‏‏‏ حَدَّثَنَا,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: تخریج دارالدعوہ: صحیح البخاری/الوضوء ۶۷ (۲۳۵)، والذبائح ۳۴ (۵۵۳۸)، سنن ابی داود/ الأطعمة ۴۸ (۳۸۴۱)، سنن النسائی/الفرع والعتیرة ۱۰ (۴۲۶۳)، (تحفة الأشراف : ۱۸۰۶۵)، وط/الاستئذان ۷ (۲۰)، و مسند احمد (۶/۳۲۹، ۳۳۰، ۳۳۵) وسنن الدارمی/الطہارة ۵۹ (۷۶۵)، والأطعمة ۴۱ (۲۱۲۸، ۲۱۲۹، ۲۱۳۰، ۲۱۳۱),1798,,The Book on Food
1799,حَدَّثَنَا إِسْحَاق بْنُ مَنْصُورٍ، أَخْبَرَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، حَدَّثَنَا عُبَيْدُ ال,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/الأشربة ۱۳ (۲۰۲۰) سنن ابی داود/ الأطعمة ۲۰ (۳۷۷۶)، (تحفة الأشراف : ۸۵۷۹)، وط/صفة النبی ﷺ ۴ (۶)، و مسند احمد (۲/۱۰۶)، سنن الدارمی/الأطعمة ۹ (۲۰۷۳),1799,,The Book on Food
1800,حَدَّثَنَا عَبْدُ اللَّهِ بْنُ عَبْدِ الرَّحْمَنِ، قَالَ:‏‏‏‏ حَدَّثَنَا جَعْفَرُ بْنُ عَوْنٍ، عَنْ,Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: انظر ما قبلہ (لم یذکرہ المزي),1800,,The Book on Food
1801,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الْمَلِكِ بْنِ أَبِي الشَّوَارِبِ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْن,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/الأشربة ۱۸ (۲۰۳۴)، (تحفة الأشراف : ۱۲۷۲۷)، و مسند احمد (۲/۳۴۰، ۴۱۵),1801,,The Book on Food
1802,حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا ابْنُ لَهِيعَةَ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، أَنّ النَّب,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/الأشربة ۱۸ (۲۰۳۳)، سنن ابن ماجہ/الأطعمة ۱۳ (۳۲۷۹)، (تحفة الأشراف : ۲۷۸)، و مسند احمد (۳/۳۰۱، ۲۳۱، ۳۳۱)، ۳۳۷، ۳۶۶، ۳۹۴),1802,,The Book on Food
1803,حَدَّثَنَا الْحَسَنُ بْنُ عَلِيٍّ الْخَلَّالُ، حَدَّثَنَا عَفَّانُ بْنُ مُسْلِمٍ، حَدَّثَنَا حَمَّاد,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/الأشربة ۱۸ (۲۰۳۴)، سنن ابی داود/ الأطعمة ۵۰ (۳۸۴۵)، (تحفة الأشراف : ۱۸۰۳)، و مسند احمد (۳/۱۱۷، ۲۹۰)، سنن الدارمی/۱ الأطعمة ۸ (۲۰۷۱),1803,,The Book on Food
1804,حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ، أَخْبَرَنَا أَبُو الْيَمَانِ الْمُعَلَّى بْنُ رَاشِدٍ,Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: سنن ابن ماجہ/الأطعمة ۱۰ (۳۲۷۱)، (تحفة الأشراف : ۱۱۵۸۸)، (تحفة الأشراف : ۱۱۵۸۸),1804,,The Book on Food
1805,حَدَّثَنَا أَبُو رَجَاءٍ، حَدَّثَنَا جَرِيرٌ، عَنْ عَطَاءِ بْنِ السَّائِبِ، عَنْ سَعِيدِ بْنِ جُبَيْ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Hasan,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأطعمة ۱۸ (۳۷۷۲)، سنن ابن ماجہ/الأطعمة ۱۲ (۳۲۷۷)، (تحفة الأشراف : ۵۵۶۶)، سنن الدارمی/الأطعمة ۱۶ (۲۰۹۰),1805,,The Book on Food
1806,حَدَّثَنَا إِسْحَاق بْنُ مَنْصُورٍ، أَخْبَرَنَا يَحْيَى بْنُ سَعِيدٍ الْقَطَّانُ، عَنْ ابْنِ جُرَيْج,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأذان ۱۶ (۸۵۴)، والأطعمة ۴۹ (۵۴۵۲)، والاعتصام ۲۴ (۷۳۵۹)، صحیح مسلم/المساجد ۱۷ (۵۶۴)، سنن ابی داود/ الأطعمة ۴۱ (۳۸۲۲)، سنن النسائی/المساجد ۱۶ (۷۰۸)، (تحفة الأشراف : ۲۴۴۷)، و مسند احمد (۳/۳۷۴، ۳۸۷),1806,,The Book on Food
1807,حَدَّثَنَا مَحْمُودُ بْنُ غَيْلَانَ، حَدَّثَنَا أَبُو دَاوُدَ، أَنْبَأَنَا شُعْبَةُ، عَنْ سِمَاكِ بْ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۱۸۰۷),1807,,The Book on Food
1808,حَدَّثَنَا مُحَمَّدُ بْنُ مَدُّوَيْهِ، حَدَّثَنَا مُسَدَّدٌ، حَدَّثَنَا الْجَرَّاحُ بْنُ مَلِيحٍ وَا,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأطعمة ۴۱ (۳۸۲۸)، (تحفة الأشراف : ۱۰۱۲۷),1808,,The Book on Food
1809,حَدَّثَنَا هَنَّادٌ، حَدَّثَنَا وَكِيعٌ، عَنْ أَبِيهِ، عَنْ أَبِي إِسْحَاق، عَنْ شَرِيكِ بْنِ حَنْبَ,Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: (تحفة الأشراف : ۱۰۱۲۷),1809,,The Book on Food
1810,حَدَّثَنَا الْحَسَنُ بْنُ الصَّبَّاحِ الْبَزَّارُ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عُبَيْ,Ahmad Muhammad Shakir: Hasan; Al-Albani: Hasan; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: سنن ابن ماجہ/الأطعمة ۵۹ (۳۳۶۴)، (تحفة الأشراف : ۱۸۳۰۴),1810,,The Book on Food
1811,حَدَّثَنَا مُحَمَّدُ بْنُ حُمَيْدٍ، حَدَّثَنَا زَيْدُ بْنُ الْحُبَابِ، عَنْ أَبِي خَلْدَةَ، عَنْ أَب,Ahmad Muhammad Shakir: Daif Isnaad Maqtu; Al-Albani: Daif Isnaad Maqtu; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف، (تحفة الأشراف : ۱۸۶۴۶),1811,,The Book on Food
1812,حَدَّثَنَا قُتَيْبَةُ، عَنْ مَالِكِ بْنِ أَنَسٍ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، قَالَ:‏‏‏‏ قَ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح البخاری/بدء الخلق ۶ (۲۲۳۱۶)، والأشربة ۲۲ (۵۶۲۳، ۵۶۲۴)، والاستئذان ۴۹ (۶۲۹۵)، صحیح مسلم/الأشربة ۱۲ (۲۰۱۲)، سنن ابی داود/ الأشربة ۲۲ (۳۷۳۱-۳۷۳۴)، سنن ابن ماجہ/الأشربة ۱۶ (۳۴۱۰)، والأدب ۴۶ (۳۷۷۱)، (تحفة الأشراف : ۲۹۳۴)، و مسند احمد (۳/۳۵۵)، ویأتي برقم ۲۸۵۷,1812,,The Book on Food
1813,حَدَّثَنَا ابْنُ أَبِي عُمَرَ، وَغَيْرُ وَاحِدٍ، ‏‏‏‏‏‏قَالُوا:‏‏‏‏ حَدَّثَنَا سُفْيَانُ، عَنْ الزُّ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الاستئذان ۴۹ (۶۲۴۳)، صحیح مسلم/الأشربة ۱۲ (۲۰۱۵)، سنن ابی داود/ الأدب ۱۷۳ (۵۲۴۶)، سنن ابن ماجہ/الأدب ۴۶ (۳۷۶۹)، (تحفة الأشراف : ۶۸۱۴),1813,,The Book on Food
1814,حَدَّثَنَا مَحْمُودُ بْنُ غَيْلَانَ، حَدَّثَنَا أَبُو أَحْمَدَ الزُّبَيْرِيُّ، وَعُبَيْدُ اللَّهِ، ع,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الشرکة ۴ (۲۴۹۰)، صحیح مسلم/الأشربة ۲۵ (۲۰۴۵)، سنن ابی داود/ الأطعمة ۴۴ (۳۸۳۴)، سنن ابن ماجہ/الأطعمة ۴۱ (۳۳۳۱)، (تحفة الأشراف : ۶۶۶۷)، و مسند احمد (۲/۶۰)، سنن الدارمی/الأطعمة ۲۵ (۲۱۰۳),1814,,The Book on Food
1815,حَدَّثَنَا مُحَمَّدُ بْنُ سَهْلِ بْنِ عَسْكَرٍ الْبَغْدَادِيُّ، وَعَبْدُ اللَّهِ بْنُ عَبْدِ الرَّحْ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/الأشربة ۲۶ (۲۰۴۶)، سنن ابی داود/ الأطعمة ۴۲ (۳۸۳۰)، سنن ابن ماجہ/الأطعمة ۲۸ (۳۳۲۷)، (تحفة الأشراف : ۱۶۹۴۲)، سنن الدارمی/الأطعمة ۲۶ (۲۱۰۵),1815,,The Book on Food
1816,حَدَّثَنَا هَنَّادٌ، وَمَحْمُودُ بْنُ غَيْلَانَ، قَالَا:‏‏‏‏ حَدَّثَنَا أَبُو أُسَامَةَ، عَنْ زَكَرِ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/الذکر والدعاء ۲۴ (۲۷۳۴)، (تحفة الأشراف : ۸۵۷)، و مسند احمد (۳/۱۰۰، ۱۱۷),1816,,The Book on Food
1817,حَدَّثَنَا أَحْمَدُ بْنُ سَعِيدٍ الْأَشْقَرُ، وَإِبْرَاهِيمُ بْنُ يَعْقُوبَ، قَالَا:‏‏‏‏ حَدَّثَنَا,Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الطب ۳۴ (۳۹۲۵)، سنن ابن ماجہ/الطب ۴۴ (۳۵۴۲)، (تحفة الأشراف : ۳۰۱۰),1817,,The Book on Food
1818,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، حَدَّثَنَا عُبَيْدُ اللَّهِ، عَ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأطعمة ۱۲ (۵۳۹۳-۵۳۹۵)، صحیح مسلم/الأشربة ۳۴ (۲۰۶۰)، سنن ابن ماجہ/الأطعمة ۳ (۳۲۵۷)، (تحفة الأشراف : ۸۱۵۶)، و مسند احمد (۲/۲۱، ۴۳، ۷۴، ۱۴۵),1818,,The Book on Food
1819,حَدَّثَنَا إِسْحَاق بْنُ مُوسَى الْأَنْصَارِيُّ، حَدَّثَنَا مَعْنٌ، حَدَّثَنَا مَالِكٌ، عَنْ سُهَيْل,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأطعمة ۱۲ (۵۳۹۶-۵۳۹۷)، صحیح مسلم/الأشربة ۳۴ (۲۰۶۳)، سنن ابن ماجہ/الأطعمة ۳ (۳۲۵۶)، (تحفة الأشراف : ۱۲۷۳۹)، وط/صفة النبيﷺ ۶ (۹، ۱۰)، مسند احمد (۲/۳۷۵، ۲۵۷، ۴۱۵، ۴۳۵، ۴۳۷، ۴۵۵)، سنن الدارمی/الأطعمة ۱۳ (۲۰۸۴),1819,,The Book on Food
1820,حَدَّثَنَا الْأَنْصَارِيُّ، حَدَّثَنَا مَعْنٌ، حَدَّثَنَا مَالِكٌ، ح وحَدَّثَنَا قُتَيْبَةُ، عَنْ مَ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأطعمة ۱۱ (۵۳۹۲)، صحیح مسلم/الأشربة ۳۳ (۲۰۵۸)، و مسند احمد (۲/۴۰۷),1820,,The Book on Food
1821,حَدَّثَنَا حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا سُفْيَانُ، عَنْ أَبِي يَعْفُورٍ الْعَبْدِيِّ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الصید ۱۳ (۵۴۹۵)، صحیح مسلم/الصید ۸ (۱۹۲۲)، سنن ابی داود/ الأطعمة ۳۵ (۳۸۱۲)، سنن النسائی/الصید ۳۷ (۴۳۶۱)، (تحفة الأشراف : ۵۱۸۲)، و مسند احمد (۴/۳۵۳، ۳۵۷، ۳۸۰)، وسنن الدارمی/الصید ۵ (۲۰۵۳),1821,,The Book on Food
1822,حَدَّثَنَا حَدَّثَنَا مَحْمُودُ بْنُ غَيْلَانَ، حَدَّثَنَا أَبُو أَحْمَدَ، وَالْمُؤَمَّلُ، قَالَا:‏‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: انظر ما قبلہ,1822,,The Book on Food
1823,حَدَّثَنَا مَحْمُودُ بْنُ غَيْلَانَ، حَدَّثَنَا أَبُو النَّضْرِ هَاشِمُ بْنُ الْقَاسِمِ، قَالَ:‏‏‏‏,Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: سنن ابن ماجہ/الصید ۹ (۳۲۲۱)، (تحفة الأشراف : ۱۴۵۱، ۲۵۸۵),1823,,The Book on Food
1824,حَدَّثَنَا هَنَّادٌ، حَدَّثَنَا عَبْدَةُ، عَنْ مُحَمَّدِ بْنِ إِسْحَاق، عَنْ ابْنِ أَبِي نَجِيحٍ، عَ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأطعمة ۲۵ (۳۷۸۵)، سنن ابن ماجہ/الذبائح ۱۱ (۳۱۸۵)، (تحفة الأشراف : ۷۳۸۷),1824,,The Book on Food
1825,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُعَاذُ بْنُ هِشَامٍ، حَدَّثَنِي أَبِي، عَنْ قَتَادَة,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأشربة ۲۴ (۵۶۲۹)، سنن ابی داود/ الأشربة ۱۴ (۳۷۱۹)، سنن النسائی/الضحایا ۴۴ (۴۴۵۳)، سنن ابن ماجہ/الأشربة ۲۰ (۳۴۲۱)، (تحفة الأشراف : ۶۱۹۰)، و مسند احمد (۱/۲۲۶، ۲۴۱، ۳۳۹) سنن الدارمی/الأضاحي ۱۳ (۲۰۱۸),1825,,The Book on Food
1826,حَدَّثَنَا زَيْدُ بْنُ أَخْزَمَ الطَّائِيُّ، حَدَّثَنَا أَبُو قُتَيْبَةَ، عَنْ أَبِي الْعَوَّامِ، عَ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/المغازي ۷۴ (۴۳۸۵)، والصید ۲۶ (۵۵۱۷، ۵۵۱۸)، و کفارات الأیمان ۱۰ (۶۷۲۱)، صحیح مسلم/الأیمان ۳ (۱۶۴۹/۹)، سنن النسائی/الصید ۳۳ (۴۳۵۱)، (تحفة الأشراف : ۸۹۹۰),1826,,The Book on Food
1827,حَدَّثَنَا هَنَّادٌ، حَدَّثَنَا وَكِيعٌ، عَنْ سُفْيَانَ، عَنْ أَيُّوبَ، عَنْ أَبِي قِلاَبَةَ، عَنْ ز,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأطعمة ۲۹ (۳۷۹۷)، (تحفة الأشراف : ۴۴۸۲),1827,,The Book on Food
1828,حَدَّثَنَا حَدَّثَنَا الْفَضْلُ بْنُ سَهْلٍ الْأَعْرَجُ الْبَغْدَادِيُّ، حَدَّثَنَا إِبْرَاهِيمُ بْن,Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Takhreej-Group: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: (ضعیف) (سند میں ابراہیم بن عمر بن سفینہ جن کا لقب بریہ ہے، مستور ہیں، اور ابراہیم بن عبدالرحمن بن مہدی بصری صدوق راوی ہیں، لیکن ان سے منکر روایات آئی ہیں),1828,,The Book on Food
1829,حَدَّثَنَا الْحَسَنُ بْنُ مُحَمَّدٍ الزَّعْفَرَانِيُّ، حَدَّثَنَا حَجَّاجُ بْنُ مُحَمَّدٍ، قَالَ:‏‏‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (أخرجہ النسائي في الکبریٰ) (تحفة الأشراف : ۱۸۲۰۰),1829,,The Book on Food
1830,حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا شَرِيكٌ، عَنْ عَلِيِّ بْنِ الْأَقْمَرِ، عَنْ أَبِي جُحَيْفَةَ، قَا,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأطعمة ۱۳ (۵۳۹۸)، سنن ابی داود/ الأطعمة ۱۷ (۳۷۶۹)، سنن ابن ماجہ/الأطعمة ۶ (۳۲۶۲)، (تحفة الأشراف : ۱۱۸۰۱)، و مسند احمد (۴/۳۰۸)، سنن الدارمی/الأطعمة ۳۱ (۲۱۱۵),1830,,The Book on Food
1831,حَدَّثَنَا سَلَمَةُ بْنُ شَبِيبٍ، وَمَحْمُودُ بْنُ غَيْلَانَ، وَأَحْمَدُ بْنُ إِبْرَاهِيمَ الدَّوْرَ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأطعمة ۳۲ (۵۴۳۱)، والأشربة ۱۰ (۵۵۹۹)، و ۱۵ (۵۶۱۴)، والطب ۴ (۵۶۸۲)، والحیل ۱۲ (۶۹۷۲)، صحیح مسلم/الطلاق ۳ (۱۴۷۴)، سنن ابی داود/ الأشربة ۱۱ (۳۷۱۵)، سنن ابن ماجہ/الأطعمة ۳۶ (۳۳۲۳)، (تحفة الأشراف : ۱۶۷۹۶)، و مسند احمد (۶/۵۹),1831,,The Book on Food
1832,حَدَّثَنَا مُحَمَّدُ بْنُ عُمَرَ بْنِ عَلِيٍّ الْمُقَدَّمِيُّ، حَدَّثَنَا مُسْلِمُ بْنُ إِبْرَاهِيمَ,Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۸۹۷۴),1832,,The Book on Food
1833,حَدَّثَنَا الْحُسَيْنُ بْنُ عَلِيِّ بْنِ الْأَسْوَدِ الْبَغْدَادِيُّ، حَدَّثَنَا عَمْرُو بْنُ مُحَمّ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: صحیح مسلم/البر و الصلة ۴۲ (۲۶۲۵/۱۴۲)، سنن ابن ماجہ/الأطعمة ۵۸ (۳۳۶۲)، (تحفة الأشراف : ۱۱۹۵۱)، و مسند احمد (۵/۱۴۹، ۱۵۶، ۱۶۱، ۱۷۱),1833,,The Book on Food
1834,حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، حَدَّثَنَا شُعْبَةُ، عَنْ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/أحادیث الأنبیاء ۳۲ (۳۴۱۱)، و ۴۶ (۳۴۳۳)، وفضائل الصحابة ۳۰ (۳۷۶۹)، والأطعمة ۲۵ (۵۴۱۸)، صحیح مسلم/فضائل الصحابة ۱۲ (۲۴۳۱),1834,,The Book on Food
1835,حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عَبْدِ الْكَرِيمِ أَبِي,Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف، (تحفة الأشراف : ۴۹۴۷),1835,,The Book on Food
1836,حَدَّثَنَا مَحْمُودُ بْنُ غَيْلَانَ، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَخْبَرَنَا مَعْمَرٌ، عَنْ الزُّ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الوضوء ۵ (۲۰۸)، والأذان ۴۳ (۶۷۵)، والجہاد ۹۲ (۲۹۲۳)، والأطعمة ۲۰ (۵۴۰۸)، و ۲۶ (۵۴۲۲)، و ۵۸ (۵۴۶۲)، صحیح مسلم/الحیض ۲۴ (۳۵۵)، سنن ابن ماجہ/الطہارة ۶۶ (۴۹۰)، (تحفة الأشراف : ۱۰۷۰)، و مسند احمد (۴/۱۳۹، ۱۷۹) و (۵/۲۸۸),1836,,The Book on Food
1837,حَدَّثَنَا وَاصِلُ بْنُ عَبْدِ الْأَعْلَى، حَدَّثَنَا مُحَمَّدُ بْنُ فُضَيْلٍ، عَنْ أَبِي حَيَّانَ ا,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/أحادیث الأنبیاء ۳ (۳۳۴۰)، وتفسیر الإسراء ۵ (۴۷۱۲)، صحیح مسلم/الإیمان ۸۴ (۱۹۴)، سنن ابن ماجہ/الأطعمة ۲۸ (۳۳۰۷)، ویأتي عند المؤلف في صفة القیامة ۱۰ (۲۴۳۴)، (تحفة الأشراف : ۱۴۹۲۷),1837,,The Book on Food
1838,حَدَّثَنَا الْحَسَنُ بْنُ مُحَمَّدٍ الزَّعْفَرَانِيُّ، حَدَّثَنَا يَحْيَى بْنُ عَبَّادٍ أَبُو عَبَّا,Ahmad Muhammad Shakir: Munkar; Al-Albani: Munkar; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۱۶۱۹۴),1838,,The Book on Food
1839,حَدَّثَنَا الْحَسَنُ بْنُ عَرَفَةَ، حَدَّثَنَا مُبَارَكُ بْنُ سَعِيدٍ هُوَ أَخُو سُفْيَانَ بْنِ سَعِ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: صحیح مسلم/الأشربة ۳۰ (۲۰۵۲)، سنن ابی داود/ الأطعمة ۴۰ (۳۸۲۰)، سنن النسائی/الأیمان ۲۱ (۳۸۲۷)، سنن ابن ماجہ/الأطعمة ۳۳ (۳۳۱۷)، (تحفة الأشراف : ۲۷۵۸)، و مسند احمد ۳/۳۰۴، ۳۷۱، ۳۸۹، ۳۹۰)، سنن الدارمی/الأطعمة ۱۸ (۲۰۹۲),1839,,The Book on Food
1840,حَدَّثَنَا مُحَمَّدُ بْنُ سَهْلِ بْنِ عَسْكَرٍ الْبَغْدَادِيُّ، حَدَّثَنَا يَحْيَى بْنُ حَسَّانَ، حَ,Ahmad Muhammad Shakir: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/الأشربة ۳۰ (۲۰۵۱)، سنن ابن ماجہ/الأطعمة ۳۳ (۳۳۱۶)، (تحفة الأشراف : ۱۶۹۴۳),1840,,The Book on Food
1841,حَدَّثَنَا أَبُو كُرَيْبٍ مُحَمَّدُ بْنُ الْعَلَاءِ، حَدَّثَنَا أَبُو بَكْرِ بْنُ عَيَّاشٍ، عَنْ أَب,Ahmad Muhammad Shakir: Hasan; Bashar Awad Maarouf: Hasan; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۱۸۰۰۲),1841,,The Book on Food
1842,حَدَّثَنَا عَبْدَةُ بْنُ عَبْدِ اللَّهِ الْخُزَاعِيُّ الْبَصْرِيُّ، حَدَّثَنَا مُعَاوِيَةُ بْنُ هِشَ,Al-Albani: Hasan; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: انظر حدیث رقم ۱۸۳۹ (تحفة الأشراف : ۲۵۷۹),1842,,The Book on Food
1843,حَدَّثَنَا عَبْدَةُ بْنُ عَبْدِ اللَّهِ الْخُزَاعِيُّ، حَدَّثَنَا مُعَاوِيَةُ بْنُ هِشَامٍ، عَنْ سُف,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأطعمة ۴۵ (۳۸۳۶)، (وأخرجہ النسائي في الکبریٰ)، (تحفة الأشراف : ۱۶۹۰۸),1843,,The Book on Food
1844,حَدَّثَنَا إِسْمَاعِيل بْنُ مُوسَى الْفَزَارِيُّ، حَدَّثَنَا إِبْرَاهِيمُ بْنُ سَعْدٍ، عَنْ أَبِيهِ،,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأطعمة ۳۹ (۵۴۴۰)، صحیح مسلم/الأشربة والأطعمة ۲۳ (۲۰۴۳)، سنن ابی داود/ الأطعمة ۴۵ (۳۸۳۵)، سنن ابن ماجہ/الأطعمة ۳۷ (۳۳۲۵)، (تحفة الأشراف : ۵۲۱۹)، سنن الدارمی/الأطعمة ۲۴ (۲۱۰۲),1844,,The Book on Food
1845,حَدَّثَنَا الْحَسَنُ بْنُ مُحَمَّدٍ الزَّعْفَرَانِيُّ، حَدَّثَنَا عَفَّانُ، حَدَّثَنَا حَمَّادُ بْنُ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: انظر حدیث رقم ۷۲,1845,,The Book on Food
1846,حَدَّثَنَا يَحْيَى بْنُ مُوسَى، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، حَدَّثَنَا قَيْسُ بْنُ الرّ,Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Bashar Awad Maarouf: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأطعمة ۱۲ (۳۷۶۱)، (تحفة الأشراف : ۴۴۸۹),1846,,The Book on Food
1847,حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا إِسْمَاعِيل بْنُ إِبْرَاهِيمَ، عَنْ أَيُّوبَ، عَنْ ابْن,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأطعمة ۱۱ (۳۷۶۰)، سنن النسائی/الطہارة ۱۰۰ (۱۳۰)، وراجع صحیح مسلم/الحیض ۳۱ (۳۷۴)، (تحفة الأشراف : ۵۷۹۳)، و مسند احمد (۱/۳۵۹),1847,,The Book on Food
1848,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُعَاذُ بْنُ هِشَامٍ، حَدَّثَنِي أَبِي، عَنْ يُونُسَ، عَنْ قَتَادَةَ، عَنْ أَنَسٍ، قَالَ مَا أَكَلَ رَسُولُ اللَّهِ صلى الله عليه وسلم فِي خِوَانٍ وَلاَ فِي سُكُرُّجَةٍ وَلاَ خُبِزَ لَهُ مُرَقَّقٌ ‏.‏ قَالَ فَقُلْتُ لِقَتَادَةَ فَعَلَى مَا كَانُوا يَأْكُلُونَ قَالَ عَلَى هَذِهِ السُّفَرِ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ غَرِيبٌ ‏.‏ قَالَ مُحَمَّدُ بْنُ بَشَّارٍ وَيُونُسُ هَذَا هُوَ يُونُسُ الإِسْكَافُ ‏.‏ وَقَدْ رَوَى عَبْدُ الْوَارِثِ بْنُ سَعِيدٍ عَنْ سَعِيدِ بْنِ أَبِي عَرُوبَةَ عَنْ قَتَادَةَ عَنْ أَنَسٍ عَنِ النَّبِيِّ صلى الله عليه وسلم نَحْوَهُ ‏.‏,Al-Albani: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: سنن ابن ماجہ/الأطعمة ۱۱ (۳۲۴۰)، (تحفة الأشراف : ۱۰۰۶),1848,Narrated Yunus:,The Book on Food
1849,حَدَّثَنَا مَحْمُودُ بْنُ غَيْلاَنَ، حَدَّثَنَا أَبُو دَاوُدَ، أَخْبَرَنَا شُعْبَةُ، عَنْ هِشَامِ بْنِ زَيْدِ بْنِ أَنَسٍ، قَالَ سَمِعْتُ أَنَسًا، يَقُولُ أَنْفَجْنَا أَرْنَبًا بِمَرِّ الظَّهْرَانِ فَسَعَى أَصْحَابُ النَّبِيِّ صلى الله عليه وسلم خَلْفَهَا فَأَدْرَكْتُهَا فَأَخَذْتُهَا فَأَتَيْتُ بِهَا أَبَا طَلْحَةَ فَذَبَحَهَا بِمَرْوَةٍ فَبَعَثَ مَعِي بِفَخِذِهَا أَوْ بِوَرِكِهَا إِلَى النَّبِيِّ صلى الله عليه وسلم فَأَكَلَهُ ‏.‏ قَالَ قُلْتُ أَكَلَهُ قَالَ قَبِلَهُ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ جَابِرٍ وَعَمَّارٍ وَمُحَمَّدِ بْنِ صَفْوَانَ وَيُقَالُ مُحَمَّدُ بْنُ صَيْفِيٍّ ‏.‏ وَهَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَالْعَمَلُ عَلَى هَذَا عِنْدَ أَكْثَرِ أَهْلِ الْعِلْمِ لاَ يَرَوْنَ بِأَكْلِ الأَرْنَبِ بَأْسًا ‏.‏ وَقَدْ كَرِهَ بَعْضُ أَهْلِ الْعِلْمِ أَكْلَ الأَرْنَبِ وَقَالُوا إِنَّهَا تَدْمِي ‏.‏,Ahmad Muhammad Shakir: Daif Isnaad; Al-Albani: Daif Isnaad; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف، (تحفة الأشراف : ۱۷۱۹),1849,Narrated Hisham b. Zaid:,The Book on Food
1850,"حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، عَنْ عَبْدِ اللَّهِ بْنِ دِينَارٍ، عَنِ ابْنِ عُمَرَ، أَنَّ النَّبِيَّ صلى الله عليه وسلم سُئِلَ عَنْ أَكْلِ الضَّبِّ فَقَالَ ‏ ‏ لاَ آكُلُهُ وَلاَ أُحَرِّمُهُ ‏""""‏ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ عُمَرَ وَأَبِي سَعِيدٍ وَابْنِ عَبَّاسٍ وَثَابِتِ بْنِ وَدِيعَةَ وَجَابِرٍ وَعَبْدِ الرَّحْمَنِ ابْنِ حَسَنَةَ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَقَدِ اخْتَلَفَ أَهْلُ الْعِلْمِ فِي أَكْلِ الضَّبِّ فَرَخَّصَ فِيهِ بَعْضُ أَهْلِ الْعِلْمِ مِنْ أَصْحَابِ النَّبِيِّ صلى الله عليه وسلم وَغَيْرِهِمْ وَكَرِهَهُ بَعْضُهُمْ ‏.‏ وَيُرْوَى عَنِ ابْنِ عَبَّاسٍ أَنَّهُ قَالَ أُكِلَ الضَّبُّ عَلَى مَائِدَةِ رَسُولِ اللَّهِ صلى الله عليه وسلم وَإِنَّمَا تَرَكَهُ رَسُولُ اللَّهِ صلى الله عليه وسلم تَقَذُّرًا ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/البیوع ۳۰ (۲۰۹۲)، والأطعمة ۴ (۵۳۷۹)، و ۲۵ (۵۴۲۰)، صحیح مسلم/الأشربة والأطعمة ۲۱ (۲۰۴۱)، سنن ابی داود/ الأطعمة ۲۲ (۳۷۸۲)، سنن ابن ماجہ/الأطعمة ۲۶ (۳۳۰۴)، (تحفة الأشراف : ۱۹۸)، وط/النکاح ۲۱ (۵۱)، سنن الدارمی/الأطعمة ۱۹ (۲۰۹۴),,Narrated Ibn 'Umar:,The Book on Food
1851,حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ إِبْرَاهِيمَ، أَخْبَرَنَا ابْنُ جُرَيْجٍ، عَنْ عَبْدِ اللَّهِ بْنِ عُبَيْدِ بْنِ عُمَيْرٍ، عَنِ ابْنِ أَبِي عَمَّارٍ، قَالَ قُلْتُ لِجَابِرٍ الضَّبُعُ صَيْدٌ هِيَ قَالَ نَعَمْ ‏.‏ قَالَ قُلْتُ آكُلُهَا قَالَ نَعَمْ ‏.‏ قَالَ قُلْتُ لَهُ أَقَالَهُ رَسُولُ اللَّهِ صلى الله عليه وسلم قَالَ نَعَمْ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَقَدْ ذَهَبَ بَعْضُ أَهْلِ الْعِلْمِ إِلَى هَذَا وَلَمْ يَرَوْا بِأَكْلِ الضَّبُعِ بَأْسًا وَهُوَ قَوْلُ أَحْمَدَ وَإِسْحَاقَ ‏.‏ وَرُوِيَ عَنِ النَّبِيِّ صلى الله عليه وسلم حَدِيثٌ فِي كَرَاهِيَةِ أَكْلِ الضَّبُعِ وَلَيْسَ إِسْنَادُهُ بِالْقَوِيِّ وَقَدْ كَرِهَ بَعْضُ أَهْلِ الْعِلْمِ أَكْلَ الضَّبُعِ وَهُوَ قَوْلُ ابْنِ الْمُبَارَكِ ‏.‏ قَالَ يَحْيَى الْقَطَّانُ وَرَوَى جَرِيرُ بْنُ حَازِمٍ هَذَا الْحَدِيثَ عَنْ عَبْدِ اللَّهِ بْنِ عُبَيْدِ بْنِ عُمَيْرٍ عَنِ ابْنِ أَبِي عَمَّارٍ عَنْ جَابِرٍ عَنْ عُمَرَ قَوْلَهُ ‏.‏ وَحَدِيثُ ابْنِ جُرَيْجٍ أَصَحُّ ‏.‏ وَابْنُ أَبِي عَمَّارٍ هُوَ عَبْدُ الرَّحْمَنِ بْنُ عَبْدِ اللَّهِ بْنِ أَبِي عَمَّارٍ الْمَكِّيُّ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih,takhreej: تخریج دارالدعوہ: سنن ابن ماجہ/الأطعمة ۳۴ (۳۳۱۹)، (تحفة الأشراف : ۱۰۳۹۲),1851,Narrated Ibn Abi 'Ammar:,The Book on Food
1852,"حَدَّثَنَا هَنَّادٌ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، عَنْ إِسْمَاعِيلَ بْنِ مُسْلِمٍ، عَنْ عَبْدِ الْكَرِيمِ بْنِ أَبِي الْمُخَارِقِ أَبِي أُمَيَّةَ، عَنْ حِبَّانَ بْنِ جَزْءٍ، عَنْ أَخِيهِ، خُزَيْمَةَ بْنِ جَزْءٍ قَالَ سَأَلْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم عَنْ أَكْلِ الضَّبُعِ فَقَالَ ‏""‏ أَوَيَأْكُلُ الضَّبُعَ أَحَدٌ ‏""‏ ‏.‏ وَسَأَلْتُهُ عَنْ أَكْلِ الذِّئْبِ فَقَالَ ‏""‏ أَوَيَأْكُلُ الذِّئْبَ أَحَدٌ فِيهِ خَيْرٌ ‏""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ لَيْسَ إِسْنَادُهُ بِالْقَوِيِّ لاَ نَعْرِفُهُ إِلاَّ مِنْ حَدِيثِ إِسْمَاعِيلَ بْنِ مُسْلِمٍ عَنْ عَبْدِ الْكَرِيمِ أَبِي أُمَيَّةَ ‏.‏ وَقَدْ تَكَلَّمَ بَعْضُ أَهْلِ الْحَدِيثِ فِي إِسْمَاعِيلَ وَعَبْدِ الْكَرِيمِ أَبِي أُمَيَّةَ وَهُوَ عَبْدُ الْكَرِيمِ بْنُ قَيْسِ بْنِ أَبِي الْمُخَارِقِ وَعَبْدُ الْكَرِيمِ بْنُ مَالِكٍ الْجَزَرِيُّ ثِقَةٌ ‏.‏",Ahmad Muhammad Shakir: Sahih Lighairihi; Al-Albani: Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (أخرجہ النسائي في الکبریٰ)، (تحفة الأشراف : ۱۱۸۶۰)، و مسند احمد (۳/۴۹۷)،,1852,Narrated Khuzaimah bin Jaz':,The Book on Food
1853,حَدَّثَنَا قُتَيْبَةُ، وَنَصْرُ بْنُ عَلِيٍّ، قَالاَ حَدَّثَنَا سُفْيَانُ، عَنْ عَمْرِو بْنِ دِينَارٍ، عَنْ جَابِرٍ، قَالَ أَطْعَمَنَا رَسُولُ اللَّهِ صلى الله عليه وسلم لُحُومَ الْخَيْلِ وَنَهَانَا عَنْ لُحُومِ الْحُمُرِ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ أَسْمَاءَ بِنْتِ أَبِي بَكْرٍ ‏.‏ قَالَ أَبُو عِيسَى وَهَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ وَهَكَذَا رَوَى غَيْرُ وَاحِدٍ عَنْ عَمْرِو بْنِ دِينَارٍ عَنْ جَابِرٍ ‏.‏ وَرَوَاهُ حَمَّادُ بْنُ زَيْدٍ عَنْ عَمْرِو بْنِ دِينَارٍ عَنْ مُحَمَّدِ بْنِ عَلِيٍّ عَنْ جَابِرٍ وَرِوَايَةُ ابْنِ عُيَيْنَةَ أَصَحُّ ‏.‏ قَالَ وَسَمِعْتُ مُحَمَّدًا يَقُولُ سُفْيَانُ بْنُ عُيَيْنَةَ أَحْفَظُ مِنْ حَمَّادِ بْنِ زَيْدٍ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: سنن ابن ماجہ/الأطعمة (۲۸۹و ۳۲۹۰)، (تحفة الأشراف : ۱۲۹۳۵)، و مسند احمد (۲/۴۷۳)، (وراجع: صحیح البخاری/العتق ۱۸ (۲۵۵۷)، والأطعمة ۵۵ (۵۴۶۰)، و مسند احمد (۲/۲۸۳، ۴۰۹، ۴۳۰),1853,Narrated Jabir:,The Book on Food
1854,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا عَبْدُ الْوَهَّابِ الثَّقَفِيُّ، عَنْ يَحْيَى بْنِ سَعِيدٍ الأَنْصَارِيِّ، عَنْ مَالِكِ بْنِ أَنَسٍ، عَنِ الزُّهْرِيِّ، ح وَحَدَّثَنَا ابْنُ أَبِي عُمَرَ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ الزُّهْرِيِّ، عَنْ عَبْدِ اللَّهِ، وَالْحَسَنِ، ابْنَىْ مُحَمَّدِ بْنِ عَلِيٍّ عَنْ أَبِيهِمَا، عَنْ عَلِيٍّ، قَالَ نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم عَنْ مُتْعَةِ النِّسَاءِ زَمَنَ خَيْبَرَ وَعَنْ لُحُومِ الْحُمُرِ الأَهْلِيَّةِ ‏.‏,Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۱۴۴۰۲),1854,"Narrated 'Abdullah and Al-Hasan, the sons of Muhammad bin 'Ali:",The Book on Food
1855,حَدَّثَنَا سَعِيدُ بْنُ عَبْدِ الرَّحْمَنِ الْمَخْزُومِيُّ، حَدَّثَنَا سُفْيَانُ، عَنِ الزُّهْرِيِّ، عَنْ عَبْدِ اللَّهِ، وَالْحَسَنِ، هُمَا ابْنَا مُحَمَّدِ ابْنِ الْحَنَفِيَّةِ فَذَكَرَ نَحْوَهُ ‏.‏ وَعَبْدُ اللَّهِ بْنُ مُحَمَّدٍ يُكْنَى أَبَا هَاشِمٍ قَالَ الزُّهْرِيُّ وَكَانَ أَرْضَاهُمَا الْحَسَنُ بْنُ مُحَمَّدٍ ‏.‏ وَقَالَ غَيْرُ سَعِيدِ بْنِ عَبْدِ الرَّحْمَنِ عَنِ ابْنِ عُيَيْنَةَ، وَكَانَ، أَرْضَاهُمَا عَبْدُ اللَّهِ بْنُ مُحَمَّدٍ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: سنن ابن ماجہ/الأدب ۱۱ (۳۶۹۴)، (تحفة الأشراف : ۸۶۴۱),1855,Another chain and 'Abdullah bin Muhammad's Kunyah is Abu Hisham. Az-Zuhri said:,The Book on Food
1856,حَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا حُسَيْنُ بْنُ عَلِيٍّ الْجُعْفِيُّ، عَنْ زَائِدَةَ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو، عَنْ أَبِي سَلَمَةَ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم حَرَّمَ يَوْمَ خَيْبَرَ كُلَّ ذِي نَابٍ مِنَ السِّبَاعِ وَالْمُجَثَّمَةَ وَالْحِمَارَ الإِنْسِيَّ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ عَلِيٍّ وَجَابِرٍ وَالْبَرَاءِ وَابْنِ أَبِي أَوْفَى وَأَنَسٍ وَالْعِرْبَاضِ بْنِ سَارِيَةَ وَأَبِي ثَعْلَبَةَ وَابْنِ عُمَرَ وَأَبِي سَعِيدٍ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَرَوَى عَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ وَغَيْرُهُ عَنْ مُحَمَّدِ بْنِ عَمْرٍو هَذَا الْحَدِيثَ وَإِنَّمَا ذَكَرُوا حَرْفًا وَاحِدًا نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم عَنْ كُلِّ ذِي نَابٍ مِنَ السِّبَاعِ ‏.‏,Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Bashar Awad Maarouf: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف، (تحفة الأشراف : ۸۶۴۱),1856,Narrated Abu Hurairah:,The Book on Food
1857,"حَدَّثَنَا زَيْدُ بْنُ أَخْزَمَ الطَّائِيُّ، حَدَّثَنَا سَلْمُ بْنُ قُتَيْبَةَ، حَدَّثَنَا شُعْبَةُ، عَنْ أَيُّوبَ، عَنْ أَبِي قِلاَبَةَ، عَنْ أَبِي ثَعْلَبَةَ، قَالَ سُئِلَ رَسُولُ اللَّهِ صلى الله عليه وسلم عَنْ قُدُورِ الْمَجُوسِ فَقَالَ ‏ ‏ أَنْقُوهَا غَسْلاً وَاطْبُخُوا فِيهَا ‏""""‏ ‏.‏ وَنَهَى عَنْ كُلِّ سَبُعٍ ذِي نَابٍ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ مَشْهُورٌ مِنْ حَدِيثِ أَبِي ثَعْلَبَةَ وَرُوِيَ عَنْهُ مِنْ غَيْرِ هَذَا الْوَجْهِ ‏.‏ وَأَبُو ثَعْلَبَةَ اسْمُهُ جُرْثُومٌ وَيُقَالُ جُرْهُمٌ وَيُقَالُ نَاشِبٌ ‏.‏ وَقَدْ ذُكِرَ هَذَا الْحَدِيثُ عَنْ أَبِي قِلاَبَةَ عَنْ أَبِي أَسْمَاءَ الرَّحَبِيِّ عَنْ أَبِي ثَعْلَبَةَ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: سنن ابن ماجہ/الأطعمة ۷ (۳۲۶۷)، (تحفة الأشراف : ۱۰۶۸۵)، (وراجع: صحیح البخاری/الأطعمة ۲ (۵۳۷۶)، وصحیح مسلم/الأشربة والأطعمة ۱۳ (۲۰۲۲)، و سنن ابی داود/ الأطعمة ۲۰ (۳۷۷۷)، و موطا امام مالک/صفة النبي ﷺ ۱۰ (۳۲)، وسنن الدارمی/الأطعمة ۱ (۲۰۶۲),,Narrated Abu Tha'labah Al-Khushani:,The Book on Food
1858,"حَدَّثَنَا عَلِيُّ بْنُ عِيسَى بْنِ يَزِيدَ الْبَغْدَادِيُّ، حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ مُحَمَّدٍ الْعَيْشِيُّ، حَدَّثَنَا حَمَّادُ بْنُ سَلَمَةَ، عَنْ أَيُّوبَ، وَقَتَادَةَ، عَنْ أَبِي قِلاَبَةَ، عَنْ أَبِي أَسْمَاءَ الرَّحَبِيِّ، عَنْ أَبِي ثَعْلَبَةَ الْخُشَنِيِّ، أَنَّهُ قَالَ يَا رَسُولَ اللَّهِ إِنَّا بِأَرْضِ أَهْلِ الْكِتَابِ فَنَطْبُخُ فِي قُدُورِهِمْ وَنَشْرَبُ فِي آنِيَتِهِمْ ‏.‏ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏""‏ إِنْ لَمْ تَجِدُوا غَيْرَهَا فَارْحَضُوهَا بِالْمَاءِ ‏""‏ ‏.‏ ثُمَّ قَالَ يَا رَسُولَ اللَّهِ إِنَّا بِأَرْضِ صَيْدٍ فَكَيْفَ نَصْنَعُ قَالَ ‏""‏ إِذَا أَرْسَلْتَ كَلْبَكَ الْمُكَلَّبَ وَذَكَرْتَ اسْمَ اللَّهِ فَقَتَلَ فَكُلْ وَإِنْ كَانَ غَيْرَ مُكَلَّبٍ فَذُكِّيَ فَكُلْ وَإِذَا رَمَيْتَ بِسَهْمِكَ وَذَكَرْتَ اسْمَ اللَّهِ فَقَتَلَ فَكُلْ ‏""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏",Ahmad Muhammad Shakir: Sahih; Bashar Awad Maarouf: Hasan Sahih,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأطعمة ۱۶ (۳۷۶۷)، سنن النسائی/عمل الیوم واللیلة ۱۰۳ (۲۸۱)، سنن ابن ماجہ/الأطعمة ۷ (۳۲۶۴)، والمؤلف في الشمائل۲۵ (تحفة الأشراف : ۱۷۹۸۸)، و مسند احمد (۶/۱۴۳)، سنن الدارمی/الأطعمة ۱ (۲۰۶۳),1858,Narrated Abu Tha'labah Al-Khushani:,The Book on Food
1859,"حَدَّثَنَا سَعِيدُ بْنُ عَبْدِ الرَّحْمَنِ الْمَخْزُومِيُّ، وَأَبُو عَمَّارٍ قَالاَ حَدَّثَنَا سُفْيَانُ، عَنِ الزُّهْرِيِّ، عَنْ عُبَيْدِ اللَّهِ، عَنِ ابْنِ عَبَّاسٍ، عَنْ مَيْمُونَةَ، أَنَّ فَأْرَةً، وَقَعَتْ، فِي سَمْنٍ فَمَاتَتْ فَسُئِلَ عَنْهَا النَّبِيُّ صلى الله عليه وسلم فَقَالَ ‏""‏ أَلْقُوهَا وَمَا حَوْلَهَا وَكُلُوهُ ‏""‏ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ أَبِي هُرَيْرَةَ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَقَدْ رُوِيَ هَذَا الْحَدِيثُ عَنِ الزُّهْرِيِّ عَنْ عُبَيْدِ اللَّهِ عَنِ ابْنِ عَبَّاسٍ أَنَّ النَّبِيَّ صلى الله عليه وسلم سُئِلَ وَلَمْ يَذْكُرُوا فِيهِ عَنْ مَيْمُونَةَ وَحَدِيثُ ابْنِ عَبَّاسٍ عَنْ مَيْمُونَةَ أَصَحُّ ‏.‏ وَرَوَى مَعْمَرٌ عَنِ الزُّهْرِيِّ عَنْ سَعِيدِ بْنِ الْمُسَيَّبِ عَنْ أَبِي هُرَيْرَةَ عَنِ النَّبِيِّ صلى الله عليه وسلم نَحْوَهُ وَهُوَ حَدِيثٌ غَيْرُ مَحْفُوظٍ ‏.‏ قَالَ وَسَمِعْتُ مُحَمَّدَ بْنَ إِسْمَاعِيلَ يَقُولُ وَحَدِيثُ مَعْمَرٍ عَنِ الزُّهْرِيِّ عَنْ سَعِيدِ بْنِ الْمُسَيَّبِ عَنْ أَبِي هُرَيْرَةَ عَنِ النَّبِيِّ صلى الله عليه وسلم وَذَكَرَ فِيهِ أَنَّهُ سُئِلَ عَنْهُ فَقَالَ ‏""‏ إِذَا كَانَ جَامِدًا فَأَلْقُوهَا وَمَا حَوْلَهَا وَإِنْ كَانَ مَائِعًا فَلاَ تَقْرَبُوهُ ‏""‏ ‏.‏ فَقَالَ هَذَا خَطَأٌ أَخْطَأَ فِيهِ مَعْمَرٌ ‏.‏ قَالَ وَالصَّحِيحُ حَدِيثُ الزُّهْرِيِّ عَنْ عُبَيْدِ اللَّهِ عَنِ ابْنِ عَبَّاسٍ عَنْ مَيْمُونَةَ ‏.‏",Ahmad Muhammad Shakir: Mawdu; Al-Albani: Mawdu; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف، (تحفة الأشراف : ۱۳۰۳۴),1859,Narrated Ibn 'Abbas:,The Book on Food
1860,"حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ، أَخْبَرَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ عُمَرَ، عَنِ ابْنِ شِهَابٍ، عَنْ أَبِي بَكْرِ بْنِ عُبَيْدِ اللَّهِ بْنِ عَبْدِ اللَّهِ بْنِ عُمَرَ، عَنْ عَبْدِ اللَّهِ بْنِ عُمَرَ، أَنَّ النَّبِيَّ صلى الله عليه وسلم قَالَ ‏ ‏ لاَ يَأْكُلْ أَحَدُكُمْ بِشِمَالِهِ وَلاَ يَشْرَبْ بِشِمَالِهِ فَإِنَّ الشَّيْطَانَ يَأْكُلُ بِشِمَالِهِ وَيَشْرَبُ بِشِمَالِهِ ‏""""‏ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ جَابِرٍ وَعُمَرَ بْنِ أَبِي سَلَمَةَ وَسَلَمَةَ بْنِ الأَكْوَعِ وَأَنَسِ بْنِ مَالِكٍ وَحَفْصَةَ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَهَكَذَا رَوَى مَالِكٌ وَابْنُ عُيَيْنَةَ عَنِ الزُّهْرِيِّ عَنْ أَبِي بَكْرِ بْنِ عُبَيْدِ اللَّهِ عَنِ ابْنِ عُمَرَ ‏.‏ وَرَوَى مَعْمَرٌ وَعُقَيْلٌ عَنِ الزُّهْرِيِّ عَنْ سَالِمٍ عَنِ ابْنِ عُمَرَ وَرِوَايَةُ مَالِكٍ وَابْنِ عُيَيْنَةَ أَصَحُّ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأطعمة ۵۴ (۳۸۵۲)، سنن ابن ماجہ/الأطعمة ۲۲ (۳۲۹۶)، (تحفة الأشراف : ۱۲۴۶۴)، و مسند احمد (۲/۳۴۴)، سنن الدارمی/الأطعمة ۲۷ (۲۱۰۷),,Narrated 'Abdullah bin 'Umar:,The Book on Food
1861,"حَدَّثَنَا عَبْدُ اللَّهِ بْنُ عَبْدِ الرَّحْمَنِ، قَالَ حَدَّثَنَا جَعْفَرُ بْنُ عَوْنٍ، عَنْ سَعِيدِ بْنِ أَبِي عَرُوبَةَ، عَنْ مَعْمَرٍ، عَنِ الزُّهْرِيِّ، عَنْ سَالِمٍ، عَنْ أَبِيهِ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ إِذَا أَكَلَ أَحَدُكُمْ فَلْيَأْكُلْ بِيَمِينِهِ وَلْيَشْرَبْ بِيَمِينِهِ فَإِنَّ الشَّيْطَانَ يَأْكُلُ بِشِمَالِهِ وَيَشْرَبُ بِشِمَالِهِ ‏""""‏ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأشربة ۱ (۵۵۷۵)، (الشطر الأخیر)، صحیح مسلم/الأشربة ۸ (۲۰۰۳)، سنن ابی داود/ الأشربة ۵ (۳۶۷۹)، سنن النسائی/الأشربة ۲۲ (۵۵۸۵)، ۵۵۸۷، ۵۵۸۹)، (الشطر الأول) و ۴۵ (۵۶۷۴)، (الشطر الأخیر) و ۴۶ (۵۶۷۶، ۵۶۷۷)، (الشطر الأخیر)، سنن ابن ماجہ/الأشربة ۲ (۳۳۷۳)، (الشطر الأخیر و۹ (۳۶۸۷)، (الشطر الأول)، (تحفة الأشراف : ۷۵۱۶)، و مسند احمد (۲/۱۶، ۱۹، ۲۲، ۲۸، ۲۹، ۳۱، ۹۱، ۴۹۸),,Narrated Az-Zuhri:,The Book on Food
1862,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الْمَلِكِ بْنِ أَبِي الشَّوَارِبِ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ الْمُخْتَارِ، عَنْ سُهَيْلِ بْنِ أَبِي صَالِحٍ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ إِذَا أَكَلَ أَحَدُكُمْ فَلْيَلْعَقْ أَصَابِعَهُ فَإِنَّهُ لاَ يَدْرِي فِي أَيَّتِهِنَّ الْبَرَكَةُ ‏""""‏ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ جَابِرٍ ‏.‏ وَكَعْبِ بْنِ مَالِكٍ وَأَنَسٍ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ غَرِيبٌ لاَ نَعْرِفُهُ إِلاَّ مِنْ هَذَا الْوَجْهِ مِنْ حَدِيثِ سُهَيْلٍ ‏.‏ وَسَأَلْتُ مُحَمَّدًا عَنْ هَذَا الْحَدِيثِ فَقَالَ هَذَا حَدِيثُ عَبْدِ الْعَزِيزِ مِنَ الْمُخْتَلِفِ لاَ يُعْرَفُ إِلاَّ مِنْ حَدِيثِهِ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۷۳۱۸),,Narrated Abu Hurairah:,The Book on Food
1863,"حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا ابْنُ لَهِيعَةَ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، أَنَّ النَّبِيَّ صلى الله عليه وسلم قَالَ ‏ ‏ إِذَا أَكَلَ أَحَدُكُمْ طَعَامًا فَسَقَطَتْ لُقْمَةٌ فَلْيُمِطْ مَا رَابَهُ مِنْهَا ثُمَّ لْيَطْعَمْهَا وَلاَ يَدَعْهَا لِلشَّيْطَانِ ‏""""‏ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ أَنَسٍ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الوضوء ۷۱ (۲۴۲)، والأشربة ۴ (۵۵۸۵)، صحیح مسلم/الأشربة ۷ (۲۰۰۱)، سنن ابی داود/ الأشربة ۵ (۳۶۸۲)، سنن النسائی/الأشربة ۲۳ (۵۵۹۷)، سنن ابن ماجہ/الأشربة ۹ (۳۳۸۶)، (تحفة الأشراف : ۱۷۷۶۴)، وط/الأشربة ۴ (۹)، و مسند احمد (۶/۳۸، ۹۷، ۱۹۰، ۲۲۶),,Narrated Jabir:,The Book on Food
1864,"حَدَّثَنَا الْحَسَنُ بْنُ عَلِيٍّ الْخَلاَّلُ، حَدَّثَنَا عَفَّانُ بْنُ مُسْلِمٍ، حَدَّثَنَا حَمَّادُ بْنُ سَلَمَةَ، حَدَّثَنَا ثَابِتٌ، عَنْ أَنَسٍ، أَنَّ النَّبِيَّ صلى الله عليه وسلم كَانَ إِذَا مَا أَكَلَ طَعَامًا لَعِقَ أَصَابِعَهُ الثَّلاَثَ وَقَالَ ‏""‏ إِذَا مَا وَقَعَتْ لُقْمَةُ أَحَدِكُمْ فَلْيُمِطْ عَنْهَا الأَذَى وَلْيَأْكُلْهَا وَلاَ يَدَعْهَا لِلشَّيْطَانِ ‏""‏ ‏.‏ وَأَمَرَنَا أَنْ نَسْلُتَ الصَّحْفَةَ وَقَالَ ‏""‏ إِنَّكُمْ لاَ تَدْرُونَ فِي أَىِّ طَعَامِكُمُ الْبَرَكَةُ ‏""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: انظر حدیث رقم ۱۸۶۱ (تحفة الأشراف : ۸۵۸۴),1864,Narrated Anas:,The Book on Food
1865,"حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ، أَخْبَرَنَا أَبُو الْيَمَانِ الْمُعَلَّى بْنُ رَاشِدٍ، قَالَ حَدَّثَتْنِي جَدَّتِي أُمُّ عَاصِمٍ، وَكَانَتْ أُمَّ وَلَدٍ، لِسِنَانِ بْنِ سَلَمَةَ قَالَتْ دَخَلَ عَلَيْنَا نُبَيْشَةُ الْخَيْرِ وَنَحْنُ نَأْكُلُ فِي قَصْعَةٍ فَحَدَّثَنَا أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ مَنْ أَكَلَ فِي قَصْعَةٍ ثُمَّ لَحِسَهَا اسْتَغْفَرَتْ لَهُ الْقَصْعَةُ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ غَرِيبٌ لاَ نَعْرِفُهُ إِلاَّ مِنْ حَدِيثِ الْمُعَلَّى بْنِ رَاشِدٍ ‏.‏ وَقَدْ رَوَى يَزِيدُ بْنُ هَارُونَ وَغَيْرُ وَاحِدٍ مِنَ الأَئِمَّةِ عَنِ الْمُعَلَّى بْنِ رَاشِدٍ هَذَا الْحَدِيثَ ‏.‏""",Ahmad Muhammad Shakir: Hasan Sahih; Al-Albani: Hasan Sahih; Bashar Awad Maarouf: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأشربة ۵ (۳۶۸۱)، سنن ابن ماجہ/الأشربة ۱۰ (۳۳۹۳)، (تحفة الأشراف : ۳۰۱۴)، و مسند احمد (۳/۳۴۳),,Narrated Al-Mu'alla bin Rashid:,The Book on Food
1866,"حَدَّثَنَا قُتَيْبَةُ أَبُو رَجَاءٍ، حَدَّثَنَا جَرِيرٌ، عَنْ عَطَاءِ بْنِ السَّائِبِ، عَنْ سَعِيدِ بْنِ جُبَيْرٍ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ النَّبِيَّ صلى الله عليه وسلم قَالَ ‏ ‏ إِنَّ الْبَرَكَةَ تَنْزِلُ وَسَطَ الطَّعَامِ فَكُلُوا مِنْ حَافَتَيْهِ وَلاَ تَأْكُلُوا مِنْ وَسَطِهِ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ إِنَّمَا يُعْرَفُ مِنْ حَدِيثِ عَطَاءِ بْنِ السَّائِبِ ‏.‏ وَقَدْ رَوَاهُ شُعْبَةُ وَالثَّوْرِيُّ عَنْ عَطَاءِ بْنِ السَّائِبِ ‏.‏ وَفِي الْبَابِ عَنِ ابْنِ عُمَرَ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأشربة ۵ (۳۶۸۷)، (تحفة الأشراف : ۱۷۵۶۵)، و مسند احمد (۶/۷۲),,Narrated Ibn 'Abbas:,The Book on Food
1867,"حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ، أَخْبَرَنَا يَحْيَى بْنُ سَعِيدٍ الْقَطَّانُ، عَنِ ابْنِ جُرَيْجٍ، حَدَّثَنَا عَطَاءٌ، عَنْ جَابِرٍ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنْ أَكَلَ مِنْ هَذِهِ - قَالَ أَوَّلَ مَرَّةٍ الثُّومِ ثُمَّ قَالَ الثُّومِ وَالْبَصَلِ وَالْكُرَّاثِ فَلاَ يَقْرَبْنَا فِي مَسَاجِدِنَا ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ عُمَرَ وَأَبِي أَيُّوبَ وَأَبِي هُرَيْرَةَ وَأَبِي سَعِيدٍ وَجَابِرِ بْنِ سَمُرَةَ وَقُرَّةَ بْنِ إِيَاسٍ الْمُزَنِيِّ وَابْنِ عُمَرَ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/الأشربة ۶ (۱۹۹۷/۵۰)، سنن النسائی/الأشربة ۲۸ (۵۶۱۷)، (تحفة الأشراف : ۷۰۹۸)، و مسند احمد (۲/۲۹، ۳۵، ۴۷، ۵۶، ۱۰۱، ۱۵۵),,Narrated Jabir:,The Book on Food
1868,"حَدَّثَنَا مَحْمُودُ بْنُ غَيْلاَنَ، حَدَّثَنَا أَبُو دَاوُدَ، أَنْبَأَنَا شُعْبَةُ، عَنْ سِمَاكِ بْنِ حَرْبٍ، سَمِعَ جَابِرَ بْنَ سَمُرَةَ، يَقُولُ نَزَلَ رَسُولُ اللَّهِ صلى الله عليه وسلم عَلَى أَبِي أَيُّوبَ وَكَانَ إِذَا أَكَلَ طَعَامًا بَعَثَ إِلَيْهِ بِفَضْلِهِ فَبَعَثَ إِلَيْهِ يَوْمًا بِطَعَامٍ وَلَمْ يَأْكُلْ مِنْهُ النَّبِيُّ صلى الله عليه وسلم فَلَمَّا أَتَى أَبُو أَيُّوبَ النَّبِيَّ صلى الله عليه وسلم فَذَكَرَ ذَلِكَ لَهُ فَقَالَ ‏""‏ فِيهِ ثُومٌ ‏""‏ ‏.‏ فَقَالَ يَا رَسُولَ اللَّهِ أَحَرَامٌ هُوَ قَالَ ‏""‏ لاَ وَلَكِنِّي أَكْرَهُهُ مِنْ أَجْلِ رِيحِهِ ‏""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/الأشربة ۶ (۱۹۹۷/۵۷)، سنن النسائی/الأشربة ۳۷ (۵۶۴۸)، (تحفة الأشراف : ۶۷۱۶)، و مسند احمد (۲/۵۶),1868,Narrated Jabir bin Samurah:,The Book on Food
1869,حَدَّثَنَا مُحَمَّدُ بْنُ مَدُّويَهْ، حَدَّثَنَا مُسَدَّدٌ، حَدَّثَنَا الْجَرَّاحُ بْنُ مَلِيحٍ، وَالِدُ، وَكِيعٍ، عَنْ أَبِي إِسْحَاقَ، عَنْ شَرِيكِ بْنِ حَنْبَلٍ، عَنْ عَلِيٍّ، أَنَّهُ قَالَ نُهِيَ عَنْ أَكْلِ الثُّومِ، إِلاَّ مَطْبُوخًا ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/الأشربة ۶ (۹۷۷/۶۴)، و (انظر أیضا: الجنائز ۳۶ (۹۷۷/۱۰۶) والأضاحي ۵ (۹۷۷/۳۷)، (تحفة الأشراف : ۱۹۳۲),1869,Narrated Sharik bin Hanbal:,The Book on Food
1870,حَدَّثَنَا هَنَّادٌ، حَدَّثَنَا وَكِيعٌ، عَنْ أَبِيهِ، عَنْ أَبِي إِسْحَاقَ، عَنْ شَرِيكِ بْنِ حَنْبَلٍ، عَنْ عَلِيٍّ، قَالَ لاَ يَصْلُحُ أَكْلُ الثُّومِ إِلاَّ مَطْبُوخًا ‏.‏ قَالَ أَبُو عِيسَى هَذَا الْحَدِيثُ لَيْسَ إِسْنَادُهُ بِذَلِكَ الْقَوِيِّ وَقَدْ رُوِيَ هَذَا عَنْ عَلِيٍّ قَوْلَهُ وَرُوِيَ عَنْ شَرِيكِ بْنِ حَنْبَلٍ عَنِ النَّبِيِّ صلى الله عليه وسلم مُرْسَلاً ‏.‏ قَالَ مُحَمَّدٌ الْجَرَّاحُ بْنُ مَلِيحٍ صَدُوقٌ وَالْجَرَّاحُ بْنُ الضَّحَّاكِ مُقَارِبُ الْحَدِيثِ ‏.‏,Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأشربة ۸ (۵۵۹۲)، سنن ابی داود/ الأشربة ۷ (۳۶۹۹)، سنن النسائی/الأشربة ۴۰ (۵۶۵۹)، (تحفة الأشراف : ۲۲۴۰),1870,Narrated Sharik bin Hanbal:,The Book on Food
1871,"حَدَّثَنَا الْحَسَنُ بْنُ الصَّبَّاحِ الْبَزَّارُ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عُبَيْدِ اللَّهِ بْنِ أَبِي يَزِيدَ، عَنْ أَبِيهِ، أَنَّ أُمَّ أَيُّوبَ، أَخْبَرَتْهُ أَنَّ النَّبِيَّ صلى الله عليه وسلم نَزَلَ عَلَيْهِمْ فَتَكَلَّفُوا لَهُ طَعَامًا فِيهِ مِنْ بَعْضِ هَذِهِ الْبُقُولِ فَكَرِهَ أَكْلَهُ فَقَالَ لأَصْحَابِهِ ‏ ‏ كُلُوهُ فَإِنِّي لَسْتُ كَأَحَدِكُمْ إِنِّي أَخَافُ أَنْ أُوذِيَ صَاحِبِي ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ غَرِيبٌ ‏.‏ وَأُمُّ أَيُّوبَ هِيَ امْرَأَةُ أَبِي أَيُّوبَ الأَنْصَارِيِّ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/الأشربة ۹ (۱۰۰۵)، سنن ابی داود/ الأشربة ۱۰ (۳۷۱۱)، سنن ابن ماجہ/الأشربة ۱۲ (۳۳۹۸)، (تحفة الأشراف : ۷۸۳۶),,Narrated 'Ubaidullah bin Abi Burdah:,The Book on Food
1872,حَدَّثَنَا مُحَمَّدُ بْنُ حُمَيْدٍ، حَدَّثَنَا زَيْدُ بْنُ الْحُبَابِ، عَنْ أَبِي خَلْدَةَ، عَنْ أَبِي الْعَالِيَةِ، قَالَ الثُّومُ مِنْ طَيِّبَاتِ الرِّزْقِ ‏.‏ وَأَبُو خَلْدَةَ اسْمُهُ خَالِدُ بْنُ دِينَارٍ وَهُوَ ثِقَةٌ عِنْدَ أَهْلِ الْحَدِيثِ وَقَدْ أَدْرَكَ أَنَسَ بْنَ مَالِكٍ وَسَمِعَ مِنْهُ وَأَبُو الْعَالِيَةِ اسْمُهُ رُفَيْعٌ هُوَ الرِّيَاحِيُّ قَالَ عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ كَانَ أَبُو خَلْدَةَ خِيَارًا مُسْلِمًا ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Hasan,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأشربة ۴ (۳۶۷۶)، سنن ابن ماجہ/الأشربة ۵ (۳۳۷۹)، (تحفة الأشراف : ۱۱۶۲۶),1872,Narrated Abu Khaldah:,The Book on Food
1873,"حَدَّثَنَا قُتَيْبَةُ، عَنْ مَالِكِ بْنِ أَنَسٍ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، قَالَ قَالَ النَّبِيُّ صلى الله عليه وسلم ‏ ‏ أَغْلِقُوا الْبَابَ وَأَوْكِئُوا السِّقَاءَ وَأَكْفِئُوا الإِنَاءَ أَوْ خَمِّرُوا الإِنَاءَ وَأَطْفِئُوا الْمِصْبَاحَ فَإِنَّ الشَّيْطَانَ لاَ يَفْتَحُ غُلُقًا وَلاَ يَحِلُّ وِكَاءً وَلاَ يَكْشِفُ آنِيَةً وَإِنَّ الْفُوَيْسِقَةَ تُضْرِمُ عَلَى النَّاسِ بَيْتَهُمْ ‏""""‏ ‏.‏ قَالَ وَفِي الْبَابِ عَنِ ابْنِ عُمَرَ وَأَبِي هُرَيْرَةَ وَابْنِ عَبَّاسٍ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ وَقَدْ رُوِيَ مِنْ غَيْرِ وَجْهٍ عَنْ جَابِرٍ ‏.‏""",Bashar Awad Maarouf: Hasan; Zubair Ali Zai: Hasan,takhreej: تخریج دارالدعوہ: انظر ما یأتي,,Narrated Jabir:,The Book on Food
1874,"حَدَّثَنَا ابْنُ أَبِي عُمَرَ، وَغَيْرُ، وَاحِدٍ، قَالُوا حَدَّثَنَا سُفْيَانُ، عَنِ الزُّهْرِيِّ، عَنْ سَالِمٍ، عَنْ أَبِيهِ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ لاَ تَتْرُكُوا النَّارَ فِي بُيُوتِكُمْ حِينَ تَنَامُونَ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏""",Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/تفسیر سورة المائدة ۱۰ (۴۶۱۹)، والأشربة ۲ (۵۵۸۱)، و ۵ (۵۵۸۸)، صحیح مسلم/التفسیر ۶ (۳۰۳۲)، سنن ابی داود/ الأشربة ۱ (۳۶۶۹)، سنن النسائی/الأشربة ۲۰ (۵۵۸۱)، (تحفة الأشراف : ۱۰۵۳۸),,Narrated Salim:,The Book on Food
1875,حَدَّثَنَا مَحْمُودُ بْنُ غَيْلاَنَ، حَدَّثَنَا أَبُو أَحْمَدَ الزُّبَيْرِيُّ، وَعُبَيْدُ اللَّهِ، عَنِ الثَّوْرِيِّ، عَنْ جَبَلَةَ بْنِ سُحَيْمٍ، عَنِ ابْنِ عُمَرَ، قَالَ نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم أَنْ يَقْرِنَ بَيْنَ التَّمْرَتَيْنِ حَتَّى يَسْتَأْذِنَ صَاحِبَهُ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ سَعْدٍ مَوْلَى أَبِي بَكْرٍ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/الأشربة ۴ (۱۹۸۵)، سنن ابی داود/ الأشربة ۴ (۳۶۷۸)، سنن النسائی/الأشربة ۱۹ (۵۵۷۵)، سنن ابن ماجہ/الأشربة ۵ (۳۳۷۸)، (تحفة الأشراف : ۱۴۸۴۱)، و مسند احمد (۲/۲۷۹، ۴۰۸، ۴۰۹، ۴۹۶، ۵۱۸، ۵۲۶)، سنن الدارمی/الأشربة ۷ (۲۱۴۱),1875,Narrated Ibn 'Umar:,The Book on Food
1876,"حَدَّثَنَا مُحَمَّدُ بْنُ سَهْلِ بْنِ عَسْكَرٍ الْبَغْدَادِيُّ، وَعَبْدُ اللَّهِ بْنُ عَبْدِ الرَّحْمَنِ، قَالاَ حَدَّثَنَا يَحْيَى بْنُ حَسَّانَ، حَدَّثَنَا سُلَيْمَانُ بْنُ بِلاَلٍ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ بَيْتٌ لاَ تَمْرَ فِيهِ جِيَاعٌ أَهْلُهُ ‏""""‏ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ سَلْمَى امْرَأَةِ أَبِي رَافِعٍ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ غَرِيبٌ لاَ نَعْرِفُهُ مِنْ حَدِيثِ هِشَامِ بْنِ عُرْوَةَ إِلاَّ مِنْ هَذَا الْوَجْهِ ‏.‏ قَالَ وَسَأَلْتُ الْبُخَارِيَّ عَنْ هَذَا الْحَدِيثِ فَقَالَ لاَ أَعْلَمُ أَحَدًا رَوَاهُ غَيْرَ يَحْيَى بْنِ حَسَّانَ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأشربة (۵۶۰۱)، صحیح مسلم/الأشربة ۵ (۱۹۸۶)، سنن ابی داود/ الأشربة ۸ (۳۷۰۳)، سنن النسائی/الأشربة ۸ (۵۵۶۲)، سنن ابن ماجہ/الأشربة ۱۱ (۳۳۹۵)، (تحفة الأشراف : ۲۴۷۸)، و مسند احمد (۳/۲۹۴، ۳۰۰، ۳۰۲، ۳۱۷، ۳۶۳، ۳۶۹),,Narrated 'Aishah:,The Book on Food
1877,"حَدَّثَنَا هَنَّادٌ، وَمَحْمُودُ بْنُ غَيْلاَنَ، قَالاَ حَدَّثَنَا أَبُو أُسَامَةَ، عَنْ زَكَرِيَّا بْنِ أَبِي زَائِدَةَ، عَنْ سَعِيدِ بْنِ أَبِي بُرْدَةَ، عَنْ أَنَسِ بْنِ مَالِكٍ، أَنَّ النَّبِيَّ صلى الله عليه وسلم قَالَ ‏ ‏ إِنَّ اللَّهَ لَيَرْضَى عَنِ الْعَبْدِ أَنْ يَأْكُلَ الأَكْلَةَ أَوْ يَشْرَبَ الشَّرْبَةَ فَيَحْمَدَهُ عَلَيْهَا ‏""""‏ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ عُقْبَةَ بْنِ عَامِرٍ وَأَبِي سَعِيدٍ وَعَائِشَةَ وَأَبِي أَيُّوبَ وَأَبِي هُرَيْرَةَ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ ‏.‏ وَقَدْ رَوَاهُ غَيْرُ وَاحِدٍ عَنْ زَكَرِيَّا بْنِ أَبِي زَائِدَةَ نَحْوَهُ وَلاَ نَعْرِفُهُ إِلاَّ مِنْ حَدِيثِ زَكَرِيَّا بْنِ أَبِي زَائِدَةَ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/الأشربة ۵ (۱۹۸۷)، سنن النسائی/الأشربة ۱۶ (۵۵۷۱)، (تحفة الأشراف : ۴۳۵۱)، و مسند احمد (۳/۳، ۹، ۴۹، ۶۲، ۷۱، ۹۰) سنن الدارمی/الأشربة ۱۴ (۱۲۵۷),,Narrated Anas bin Malik:,The Book on Food
1878,"حَدَّثَنَا أَحْمَدُ بْنُ سَعِيدٍ الأَشْقَرُ، وَإِبْرَاهِيمُ بْنُ يَعْقُوبَ، قَالاَ حَدَّثَنَا يُونُسُ بْنُ مُحَمَّدٍ، حَدَّثَنَا الْمُفَضَّلُ بْنُ فَضَالَةَ، عَنْ حَبِيبِ بْنِ الشَّهِيدِ، عَنْ مُحَمَّدِ بْنِ الْمُنْكَدِرِ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم أَخَذَ بِيَدِ مَجْذُومٍ فَأَدْخَلَهُ مَعَهُ فِي الْقَصْعَةِ ثُمَّ قَالَ ‏ ‏ كُلْ بِسْمِ اللَّهِ ثِقَةً بِاللَّهِ وَتَوَكُّلاً عَلَيْهِ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ غَرِيبٌ لاَ نَعْرِفُهُ إِلاَّ مِنْ حَدِيثِ يُونُسَ بْنِ مُحَمَّدٍ عَنِ الْمُفَضَّلِ بْنِ فَضَالَةَ ‏.‏ وَالْمُفَضَّلُ بْنُ فَضَالَةَ هَذَا شَيْخٌ بَصْرِيٌّ وَالْمُفَضَّلُ بْنُ فَضَالَةَ شَيْخٌ آخَرُ مِصْرِيٌّ أَوْثَقُ مِنْ هَذَا وَأَشْهَرُ ‏.‏ وَقَدْ رَوَى شُعْبَةُ هَذَا الْحَدِيثَ عَنْ حَبِيبِ بْنِ الشَّهِيدِ عَنِ ابْنِ بُرَيْدَةَ أَنَّ ابْنَ عُمَرَ أَخَذَ بِيَدِ مَجْذُومٍ وَحَدِيثُ شُعْبَةَ أَثْبَتُ عِنْدِي وَأَصَحُّ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأطعمة ۲۹ (۵۴۲۶)، والأشربة ۲۷ (۵۶۳۲)، و ۲۸ (۵۶۳۳)، واللباس ۲۵ (۵۸۳۱)، و ۲۷ (۵۸۳۷)، صحیح مسلم/اللباس ۱ (۲۰۶۷)، سنن ابی داود/ الأشربة ۱۷ (۳۷۲۳)، سنن النسائی/الزینة ۳۳ (۵۳۰۳)، سنن ابن ماجہ/الأشربة ۱۷ (۳۴۱۴)، (تحفة الأشراف : ۳۳۷۳)، و مسند احمد (۵/۳۸۵، ۳۹۰، ۳۹۶، ۳۹۸، ۴۰۰، ۴۰۸),,Narrated Jabir bin ‘Abdullah :,The Book on Food
1879,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، حَدَّثَنَا عُبَيْدُ اللَّهِ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ الْكَافِرُ يَأْكُلُ فِي سَبْعَةِ أَمْعَاءٍ وَالْمُؤْمِنُ يَأْكُلُ فِي مِعًى وَاحِدٍ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ أَبِي هُرَيْرَةَ وَأَبِي سَعِيدٍ وَأَبِي بَصْرَةَ الْغِفَارِيِّ وَأَبِي مُوسَى وَجَهْجَاهٍ الْغِفَارِيِّ وَمَيْمُونَةَ وَعَبْدِ اللَّهِ بْنِ عَمْرٍو ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/الأشربة ۱۴ (۲۰۲۴)، سنن ابی داود/ الأشربة ۱۳ (۳۷۱۷)، سنن ابن ماجہ/الأشربة ۲۱ (۳۴۲۴)، (تحفة الأشراف : ۱۱۸۰)، و مسند احمد (۳/۱۱۸، ۱۸۲، ۲۷۷) سنن الدارمی/الأشربة ۲۴ (۲۱۷۳),,Narrated Ibn 'Umar:,The Book on Food
1880,"حَدَّثَنَا إِسْحَاقُ بْنُ مُوسَى الأَنْصَارِيُّ، حَدَّثَنَا مَعْنٌ، حَدَّثَنَا مَالِكٌ، عَنْ سُهَيْلِ بْنِ أَبِي صَالِحٍ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم ضَافَهُ ضَيْفٌ كَافِرٌ فَأَمَرَ لَهُ رَسُولُ اللَّهِ صلى الله عليه وسلم بِشَاةٍ فَحُلِبَتْ فَشَرِبَ ثُمَّ أُخْرَى فَشَرِبَهُ ثُمَّ أُخْرَى فَشَرِبَهُ حَتَّى شَرِبَ حِلاَبَ سَبْعِ شِيَاهٍ ثُمَّ أَصْبَحَ مِنَ الْغَدِ فَأَسْلَمَ فَأَمَرَ لَهُ رَسُولُ اللَّهِ صلى الله عليه وسلم بِشَاةٍ فَحُلِبَتْ فَشَرِبَ حِلاَبَهَا ثُمَّ أَمَرَ لَهُ بِأُخْرَى فَلَمْ يَسْتَتِمَّهَا فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ الْمُؤْمِنُ يَشْرَبُ فِي مِعًى وَاحِدٍ وَالْكَافِرُ يَشْرَبُ فِي سَبْعَةِ أَمْعَاءٍ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ غَرِيبٌ مِنْ حَدِيثِ سُهَيْلٍ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: سنن ابن ماجہ/الأطعمة ۲۵ (۳۳۰۱)، (تحفة الأشراف : ۷۸۲۱),,Narrated Abu Hurairah:,The Book on Food
1881,"حَدَّثَنَا الأَنْصَارِيُّ، حَدَّثَنَا مَعْنٌ، حَدَّثَنَا مَالِكٌ، ح وَحَدَّثَنَا قُتَيْبَةُ، عَنْ مَالِكٍ، عَنْ أَبِي الزِّنَادِ، عَنِ الأَعْرَجِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ طَعَامُ الاِثْنَيْنِ كَافِي الثَّلاَثَةِ وَطَعَامُ الثَّلاَثَةِ كَافِي الأَرْبَعَةِ ‏""""‏ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ جَابِرٍ وَابْنِ عُمَرَ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏""",Ahmad Muhammad Shakir: Sahih Lighairihi; Al-Albani: Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۳۱۷۷),,Narrated Abu Hurairah:,The Book on Food
1882,"وَرَوَى جَابِرٌ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ طَعَامُ الْوَاحِدِ يَكْفِي الاِثْنَيْنِ وَطَعَامُ الاِثْنَيْنِ يَكْفِي الأَرْبَعَةَ وَطَعَامُ الأَرْبَعَةِ يَكْفِي الثَّمَانِيَةَ ‏""""‏ ‏.‏ حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ عَنْ سُفْيَانَ عَنِ الأَعْمَشِ عَنْ أَبِي سُفْيَانَ عَنْ جَابِرٍ عَنِ النَّبِيِّ صلى الله عليه وسلم بِهَذَا ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الحج ۷۶ (۱۶۳۷)، والأشربة ۶ (۵۶۱۷)، صحیح مسلم/الأشربة ۱۵ (۲۰۲۷)، سنن النسائی/الحج ۶۵ (۲۹۶۷)، و ۶۶ (۲۹۶۸)، سنن ابن ماجہ/الأشربة ۲۱ (۳۴۲۲)، والمؤلف في الشمائل ۳۱ (۱۹۷، ۱۹۸، ۱۹۹)، (تحفة الأشراف : ۵۷۶۷)، و مسند احمد (۱/۲۱۴، ۲۲۰، ۳۴۲),,It has been reported from Jabir bin 'Abdullah and Ibn 'Umar that the Prophet (ﷺ) said:,The Book on Food
1883,حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا سُفْيَانُ، عَنْ أَبِي يَعْفُورٍ الْعَبْدِيِّ، عَنْ عَبْدِ اللَّهِ بْنِ أَبِي أَوْفَى، أَنَّهُ سُئِلَ عَنِ الْجَرَادِ، فَقَالَ غَزَوْتُ مَعَ النَّبِيِّ صلى الله عليه وسلم سِتَّ غَزَوَاتٍ نَأْكُلُ الْجَرَادَ ‏.‏ قَالَ أَبُو عِيسَى هَكَذَا رَوَى سُفْيَانُ بْنُ عُيَيْنَةَ عَنْ أَبِي يَعْفُورٍ هَذَا الْحَدِيثَ وَقَالَ سِتَّ غَزَوَاتٍ وَرَوَى سُفْيَانُ الثَّوْرِيُّ وَغَيْرُ وَاحِدٍ هَذَا الْحَدِيثَ عَنْ أَبِي يَعْفُورٍ فَقَالَ سَبْعَ غَزَوَاتٍ ‏. قَالَ وَفِي الْبَابِ عَنِ ابْنِ عُمَرَ وَجَابِرٍ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَأَبُو يَعْفُورٍ اسْمُهُ وَاقِدٌ وَيُقَالُ وَقْدَانُ أَيْضًا وَأَبُو يَعْفُورٍ الآخَرُ اسْمُهُ عَبْدُ الرَّحْمَنِ بْنُ عُبَيْدِ بْنِ نِسْطَاسَ ‏.‏,Ahmad Muhammad Shakir: Hasan; Al-Albani: Hasan; Bashar Awad Maarouf: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۸۶۸۹),1883,Narrated Abu Ya'fur Al-'Abdi:,The Book on Food
1884,"حَدَّثَنَا مَحْمُودُ بْنُ غَيْلاَنَ، حَدَّثَنَا أَبُو أَحْمَدَ، وَالْمُؤَمَّلُ، قَالاَ حَدَّثَنَا سُفْيَانُ، عَنْ أَبِي يَعْفُورٍ، عَنِ ابْنِ أَبِي أَوْفَى، قَالَ غَزَوْنَا مَعَ رَسُولِ اللَّهِ صلى الله عليه وسلم سَبْعَ غَزَوَاتٍ نَأْكُلُ الْجَرَادَ ‏.‏ قَالَ أَبُو عِيسَى وَرَوَى شُعْبَةُ، هَذَا الْحَدِيثَ عَنْ أَبِي يَعْفُورٍ، عَنِ ابْنِ أَبِي أَوْفَى، قَالَ غَزَوْتُ مَعَ رَسُولِ اللَّهِ صلى الله عليه وسلم غَزَوَاتٍ نَأْكُلُ الْجَرَادَ ‏.‏ حَدَّثَنَا بِذَلِكَ مُحَمَّدُ بْنُ بَشَّارٍ حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ حَدَّثَنَا شُعْبَةُ بِهَذَا ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih,takhreej: تخریج دارالدعوہ: صحیح مسلم/الأشربة ۱۶ (۲۰۲۸/۱۲۳)، سنن ابی داود/ الأشربة ۱۹ (۳۷۲۷) (تحفة الأشراف : ۱۷۲۳)، و مسند احمد (۳/۱۱۹، ۱۸۵، ۲۱۱),,Narrated Abu Ya'fur:,The Book on Food
1885,"حَدَّثَنَا مَحْمُودُ بْنُ غَيْلاَنَ، حَدَّثَنَا أَبُو النَّضْرِ، هَاشِمُ بْنُ الْقَاسِمِ قَالَ حَدَّثَنَا زِيَادُ بْنُ عَبْدِ اللَّهِ بْنِ عُلاَثَةَ، عَنْ مُوسَى بْنِ مُحَمَّدِ بْنِ إِبْرَاهِيمَ التَّيْمِيِّ، عَنْ أَبِيهِ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، وَأَنَسِ بْنِ مَالِكٍ، قَالاَ كَانَ رَسُولُ اللَّهِ صلى الله عليه وسلم إِذَا دَعَا عَلَى الْجَرَادِ قَالَ ‏""‏ اللَّهُمَّ أَهْلِكِ الْجَرَادَ اقْتُلْ كِبَارَهُ وَأَهْلِكْ صِغَارَهُ وَأَفْسِدْ بَيْضَهُ وَاقْطَعْ دَابِرَهُ وَخُذْ بِأَفْوَاهِهِمْ عَنْ مَعَاشِنَا وَأَرْزَاقِنَا إِنَّكَ سَمِيعُ الدُّعَاءِ ‏""‏ ‏.‏ قَالَ فَقَالَ رَجُلٌ يَا رَسُولَ اللَّهِ كَيْفَ تَدْعُو عَلَى جُنْدٍ مِنْ أَجْنَادِ اللَّهِ بِقَطْعِ دَابِرِهِ قَالَ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏""‏ إِنَّهَا نَثْرَةُ حُوتٍ فِي الْبَحْرِ ‏""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ غَرِيبٌ لاَ نَعْرِفُهُ إِلاَّ مِنْ هَذَا الْوَجْهِ ‏.‏ وَمُوسَى بْنُ مُحَمَّدِ بْنِ إِبْرَاهِيمَ التَّيْمِيُّ قَدْ تُكُلِّمَ فِيهِ وَهُوَ كَثِيرُ الْغَرَائِبِ وَالْمَنَاكِيرِ وَأَبُوهُ مُحَمَّدُ بْنُ إِبْرَاهِيمَ ثِقَةٌ وَهُوَ مَدَنِيٌّ ‏.‏",Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۵۹۷۱),1885,Narrated At-Taimi:,The Book on Food
1886,حَدَّثَنَا هَنَّادٌ، حَدَّثَنَا عَبْدَةُ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ، عَنِ ابْنِ أَبِي نَجِيحٍ، عَنْ مُجَاهِدٍ، عَنِ ابْنِ عُمَرَ، قَالَ نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم عَنْ أَكْلِ الْجَلاَّلَةِ وَأَلْبَانِهَا ‏.‏ قَالَ وَفِي الْبَابِ عَنْ عَبْدِ اللَّهِ بْنِ عَبَّاسٍ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ غَرِيبٌ ‏.‏ وَرَوَى الثَّوْرِيُّ عَنِ ابْنِ أَبِي نَجِيحٍ عَنْ مُجَاهِدٍ عَنِ النَّبِيِّ صلى الله عليه وسلم مُرْسَلاً ‏.‏,Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: سنن ابن ماجہ/الأشربة ۱۸ (۳۴۱۷)، (تحفة الأشراف : ۶۳۴۷),1886,Narrated Ibn 'Umar:,The Book on Food
1887,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُعَاذُ بْنُ هِشَامٍ، حَدَّثَنِي أَبِي، عَنْ قَتَادَةَ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ النَّبِيَّ صلى الله عليه وسلم نَهَى عَنِ الْمُجَثَّمَةِ وَلَبَنِ الْجَلاَّلَةِ وَعَنِ الشُّرْبِ مِنْ فِي السِّقَاءِ ‏.‏,Ahmad Muhammad Shakir: Hasan; Al-Albani: Hasan; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۴۴۳۶),1887,Narrated Ibn 'Abbas:,The Book on Food
1888,قَالَ مُحَمَّدُ بْنُ بَشَّارٍ وَحَدَّثَنَا ابْنُ أَبِي عَدِيٍّ، عَنْ سَعِيدِ بْنِ أَبِي عَرُوبَةَ، عَنْ قَتَادَةَ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، عَنِ النَّبِيِّ صلى الله عليه وسلم نَحْوَهُ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَفِي الْبَابِ عَنْ عَبْدِ اللَّهِ بْنِ عَمْرٍو ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأشربة ۲۰ (۳۷۲۸)، سنن ابن ماجہ/الأشربة ۲۳ (۳۴۲۸)، (تحفة الأشراف : ۶۱۴۹)، سنن الدارمی/الأشربة ۲۷ (۲۱۸۰),1888,"Another chain from Ibn 'Abbas, from the Prophet (ﷺ), with similar meaning.\n\n\n[Abu 'Eisa said:",The Book on Food
1889,حَدَّثَنَا زَيْدُ بْنُ أَخْزَمَ الطَّائِيُّ، حَدَّثَنَا أَبُو قُتَيْبَةَ، عَنْ أَبِي الْعَوَّامِ، عَنْ قَتَادَةَ، عَنْ زَهْدَمٍ الْجَرْمِيِّ، قَالَ دَخَلْتُ عَلَى أَبِي مُوسَى وَهُوَ يَأْكُلُ دَجَاجًا فَقَالَ ادْنُ فَكُلْ فَإِنِّي رَأَيْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم يَأْكُلُهُ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ ‏.‏ وَقَدْ رُوِيَ هَذَا الْحَدِيثُ مِنْ غَيْرِ وَجْهٍ عَنْ زَهْدَمٍ وَلاَ نَعْرِفُهُ إِلاَّ مِنْ حَدِيثِ زَهْدَمٍ ‏.‏ وَأَبُو الْعَوَّامِ هُوَ عِمْرَانُ الْقَطَّانُ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الوضوء ۱۸ (۱۵۳)، و ۱۹ (۱۵۴)، والأشربة ۲۵ (۵۶۳۰)، صحیح مسلم/الطہارة ۱۸ (۲۶۷)، سنن ابی داود/ الطہارة ۱۸ (۳۱)، (تحفة الأشراف : ۱۲۱۰۵)، و مسند احمد (۵/۲۹۵، ۲۹۶، ۳۰۰، ۳۰۹، ۳۱۰),1889,Narrated Zahdam Al-Jarmi:,The Book on Food
1890,حَدَّثَنَا هَنَّادٌ، حَدَّثَنَا وَكِيعٌ، عَنْ سُفْيَانَ، عَنْ أَيُّوبَ، عَنْ أَبِي قِلاَبَةَ، عَنْ زَهْدَمٍ، عَنْ أَبِي مُوسَى، قَالَ رَأَيْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم يَأْكُلُ لَحْمَ دَجَاجٍ ‏.‏ قَالَ وَفِي الْحَدِيثِ كَلاَمٌ أَكْثَرُ مِنْ هَذَا ‏.‏ وَهَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَقَدْ رَوَى أَيُّوبُ السَّخْتِيَانِيُّ هَذَا الْحَدِيثَ أَيْضًا عَنِ الْقَاسِمِ التَّمِيمِيِّ وَعَنْ أَبِي قِلاَبَةَ عَنْ زَهْدَمٍ (الْجَرْمِيِّ) ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأشربة ۲۳ (۵۶۲۴)، صحیح مسلم/الأشربة (۲۰۲۳)، سنن ابی داود/ الأشربة ۱۵ (۳۷۲۰)، سنن ابن ماجہ/الأشربة ۱۹ (۳۴۱۸)، (تحفة الأشراف : ۴۱۳۸)، و مسند احمد (۳/۶، ۶۷، ۶۹، ۹۳),1890,Narrated Zahdam:,The Book on Food
1891,حَدَّثَنَا الْفَضْلُ بْنُ سَهْلٍ الأَعْرَجُ الْبَغْدَادِيُّ، حَدَّثَنَا إِبْرَاهِيمُ بْنُ عَبْدِ الرَّحْمَنِ بْنِ مَهْدِيٍّ، عَنْ إِبْرَاهِيمَ بْنِ عُمَرَ بْنِ سَفِينَةَ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، قَالَ أَكَلْتُ مَعَ رَسُولِ اللَّهِ صلى الله عليه وسلم لَحْمَ حُبَارَى ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ غَرِيبٌ لاَ نَعْرِفُهُ إِلاَّ مِنْ هَذَا الْوَجْهِ ‏.‏ وَإِبْرَاهِيمُ بْنُ عُمَرَ بْنِ سَفِينَةَ رَوَى عَنْهُ ابْنُ أَبِي فُدَيْكٍ وَيُقَالُ بُرَيْهُ بْنُ عُمَرَ بْنِ سَفِينَةَ ‏.‏,Ahmad Muhammad Shakir: Munkar; Al-Albani: Daif; Bashar Awad Maarouf: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأشربة ۱۵ (۳۷۲۱)، (تحفة الأشراف : ۵۱۴۹),1891,Narrated Ibrahim bin 'Umar bin Safinah:,The Book on Food
1892,حَدَّثَنَا الْحَسَنُ بْنُ مُحَمَّدٍ الزَّعْفَرَانِيُّ، حَدَّثَنَا حَجَّاجُ بْنُ مُحَمَّدٍ، قَالَ قَالَ ابْنُ جُرَيْجٍ أَخْبَرَنِي مُحَمَّدُ بْنُ يُوسُفَ، أَنَّ عَطَاءَ بْنَ يَسَارٍ، أَخْبَرَهُ أَنَّ أُمَّ سَلَمَةَ أَخْبَرَتْهُ أَنَّهَا، قَرَّبَتْ إِلَى رَسُولِ اللَّهِ صلى الله عليه وسلم جَنْبًا مَشْوِيًّا فَأَكَلَ مِنْهُ ثُمَّ قَامَ إِلَى الصَّلاَةِ وَمَا تَوَضَّأَ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ عَبْدِ اللَّهِ بْنِ الْحَارِثِ وَالْمُغِيرَةِ وَأَبِي رَافِعٍ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ غَرِيبٌ مِنْ هَذَا الْوَجْهِ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: تخریج دارالدعوہ: سنن ابن ماجہ/الأشربة ۲۱ (۳۴۲۳)، (تحفة الأشراف : ۱۸۰۴۹)، و مسند احمد (۶/۴۳۴),1892,Narrated Umm Salamah:,The Book on Food
1893,"حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا شَرِيكٌ، عَنْ عَلِيِّ بْنِ الأَقْمَرِ، عَنْ أَبِي جُحَيْفَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ أَمَّا أَنَا فَلاَ آكُلُ مُتَّكِئًا ‏""""‏ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ عَلِيٍّ وَعَبْدِ اللَّهِ بْنِ عَمْرٍو وَعَبْدِ اللَّهِ بْنِ عَبَّاسٍ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ لاَ نَعْرِفُهُ إِلاَّ مِنْ حَدِيثِ عَلِيِّ بْنِ الأَقْمَرِ ‏.‏ وَرَوَى زَكَرِيَّا بْنُ أَبِي زَائِدَةَ وَسُفْيَانُ الثَّوْرِيُّ وَغَيْرُ وَاحِدٍ عَنْ عَلِيِّ بْنِ الأَقْمَرِ هَذَا الْحَدِيثَ وَرَوَى شُعْبَةُ عَنْ سُفْيَانَ الثَّوْرِيِّ هَذَا الْحَدِيثَ عَنْ عَلِيِّ بْنِ الأَقْمَرِ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأشربة ۱۴ (۵۶۱۳)، و ۱۸ (۵۷۱۹) والشرب ۱ (۲۳۵۲)، والہبة ۴ (۲۵۷۱)، صحیح مسلم/الأشربة ۱۷ (۲۰۲۹)، سنن ابی داود/ الأشربة ۱۹ (۳۷۲۶)، سنن ابن ماجہ/الأشربة ۲۲ (۳۴۲۵)، (تحفة الأشراف : ۱۵۷۴)، و موطا امام مالک/صفة النبي ﷺ ۹ (۱۷)، و مسند احمد (۳/۱۱۰، ۱۱۳، ۱۹۷)، سنن الدارمی/الأشربة ۱۸ (۲۱۶۲),,Narrated Abu Juhaidah:,The Book on Food
1894,حَدَّثَنَا سَلَمَةُ بْنُ شَبِيبٍ، وَمَحْمُودُ بْنُ غَيْلاَنَ، وَأَحْمَدُ بْنُ إِبْرَاهِيمَ الدَّوْرَقِيُّ، قَالُوا حَدَّثَنَا أَبُو أُسَامَةَ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، قَالَتْ كَانَ النَّبِيُّ صلى الله عليه وسلم يُحِبُّ الْحَلْوَاءَ وَالْعَسَلَ ‏.‏ هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ غَرِيبٌ ‏.‏ وَقَدْ رَوَاهُ عَلِيُّ بْنُ مُسْهِرٍ عَنْ هِشَامِ بْنِ عُرْوَةَ وَفِي الْحَدِيثِ كَلاَمٌ أَكْثَرُ مِنْ هَذَا ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/المساجد ۵۵ (۶۸۱)، (في سیاق طویل) سنن ابن ماجہ/الأشربة ۲۶ (۳۴۳۴)، (تحفة الأشراف : ۱۲۰۸۶)، و مسند احمد (۵/۳۰۳),1894,Narrated 'Aishah:,The Book on Food
1895,"حَدَّثَنَا مُحَمَّدُ بْنُ عُمَرَ بْنِ عَلِيٍّ الْمُقَدَّمِيُّ، حَدَّثَنَا مُسْلِمُ بْنُ إِبْرَاهِيمَ، حَدَّثَنَا مُحَمَّدُ بْنُ فَضَاءٍ، حَدَّثَنِي أَبِي، عَنْ عَلْقَمَةَ بْنِ عَبْدِ اللَّهِ الْمُزَنِيِّ، عَنْ أَبِيهِ، قَالَ قَالَ النَّبِيُّ صلى الله عليه وسلم ‏ ‏ إِذَا اشْتَرَى أَحَدُكُمْ لَحْمًا فَلْيُكْثِرْ مَرَقَتَهُ فَإِنْ لَمْ يَجِدْ لَحْمًا أَصَابَ مَرَقَةً وَهُوَ أَحَدُ اللَّحْمَيْنِ ‏""""‏ ‏.‏ وَفِي الْبَابِ عَنْ أَبِي ذَرٍّ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ غَرِيبٌ لاَ نَعْرِفُهُ إِلاَّ مِنْ هَذَا الْوَجْهِ مِنْ حَدِيثِ مُحَمَّدِ بْنِ فَضَاءٍ ‏.‏ وَمُحَمَّدُ بْنُ فَضَاءٍ هُوَ الْمُعَبِّرُ وَقَدْ تَكَلَّمَ فِيهِ سُلَيْمَانُ بْنُ حَرْبٍ وَعَلْقَمَةُ بْنُ عَبْدِ اللَّهِ هُوَ أَخُو بَكْرِ بْنِ عَبْدِ اللَّهِ الْمُزَنِيِّ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (أخربہ النسائي في الکبریٰ) (تحفة الأشراف : ۱۶۶۴۸),,Narrated 'Alqamah bin Al-Muzani:,The Book on Food
1896,"حَدَّثَنَا الْحُسَيْنُ بْنُ عَلِيِّ بْنِ الأَسْوَدِ الْبَغْدَادِيُّ، حَدَّثَنَا عَمْرُو بْنُ مُحَمَّدٍ الْعَنْقَزِيُّ، حَدَّثَنَا إِسْرَائِيلُ، عَنْ صَالِحِ بْنِ رُسْتُمَ أَبِي عَامِرٍ الْخَزَّازِ، عَنْ أَبِي عِمْرَانَ الْجَوْنِيِّ، عَنْ عَبْدِ اللَّهِ بْنِ الصَّامِتِ، عَنْ أَبِي ذَرٍّ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ لاَ يَحْقِرَنَّ أَحَدُكُمْ شَيْئًا مِنَ الْمَعْرُوفِ وَإِنْ لَمْ يَجِدْ فَلْيَلْقَ أَخَاهُ بِوَجْهٍ طَلِيقٍ وَإِنِ اشْتَرَيْتَ لَحْمًا أَوْ طَبَخْتَ قِدْرًا فَأَكْثِرْ مَرَقَتَهُ وَاغْرِفْ لِجَارِكَ مِنْهُ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ وَقَدْ رَوَاهُ شُعْبَةُ عَنْ أَبِي عِمْرَانَ الْجَوْنِيِّ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۱۹۳۹۴ و ۱۹۴۱۴),,Narrated Abu Dharr:,The Book on Food
1897,"حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، حَدَّثَنَا شُعْبَةُ، عَنْ عَمْرِو بْنِ مُرَّةَ، عَنْ مُرَّةَ الْهَمْدَانِيِّ، عَنْ أَبِي مُوسَى، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ كَمُلَ مِنَ الرِّجَالِ كَثِيرٌ وَلَمْ يَكْمُلْ مِنَ النِّسَاءِ إِلاَّ مَرْيَمُ ابْنَةُ عِمْرَانَ وَآسِيَةُ امْرَأَةُ فِرْعَوْنَ وَفَضْلُ عَائِشَةَ عَلَى النِّسَاءِ كَفَضْلِ الثَّرِيدِ عَلَى سَائِرِ الطَّعَامِ ‏""""‏ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ عَائِشَةَ وَأَنَسٍ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏""",Ahmad Muhammad Shakir: Hasan; Al-Albani: Hasan; Bashar Awad Maarouf: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأدب ۱۲۹ (۵۱۳۹)، (تحفة الأشراف : ۱۱۸۸۳)، و مسند احمد (۵/۳، ۵),,Narrated Abu Musa:,The Book on Food
1898,"حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عَبْدِ الْكَرِيمِ أَبِي أُمَيَّةَ، عَنْ عَبْدِ اللَّهِ بْنِ الْحَارِثِ، قَالَ زَوَّجَنِي أَبِي فَدَعَا أُنَاسًا فِيهِمْ صَفْوَانُ بْنُ أُمَيَّةَ فَقَالَ إِنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ انْهَسُوا اللَّحْمَ نَهْسًا فَإِنَّهُ أَهْنَأُ وَأَمْرَأُ ‏""""‏ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ عَائِشَةَ وَأَبِي هُرَيْرَةَ ‏.‏ قَالَ أَبُو عِيسَى وَهَذَا حَدِيثٌ حَسَنٌ لاَ نَعْرِفُهُ إِلاَّ مِنْ حَدِيثِ عَبْدِ الْكَرِيمِ ‏.‏ وَقَدْ تَكَلَّمَ بَعْضُ أَهْلِ الْعِلْمِ فِي عَبْدِ الْكَرِيمِ الْمُعَلِّمِ مِنْهُمْ أَيُّوبُ السَّخْتِيَانِيُّ مِنْ قِبَلِ حِفْظِهِ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: انظر حدیث رقم ۱۷۳,,Narrated 'Abdullah bin Al-Harith:,The Book on Food
1899,حَدَّثَنَا مَحْمُودُ بْنُ غَيْلاَنَ، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَخْبَرَنَا مَعْمَرٌ، عَنِ الزُّهْرِيِّ، عَنْ جَعْفَرِ بْنِ عَمْرِو بْنِ أُمَيَّةَ الضَّمْرِيِّ، عَنْ أَبِيهِ، أَنَّهُ رَأَى النَّبِيَّ صلى الله عليه وسلم احْتَزَّ مِنْ كَتِفِ شَاةٍ فَأَكَلَ مِنْهَا ثُمَّ مَضَى إِلَى الصَّلاَةِ وَلَمْ يَتَوَضَّأْ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَفِي الْبَابِ عَنِ الْمُغِيرَةِ بْنِ شُعْبَةَ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Hasan,takhreej: تخریج دارالدعوہ: سنن ابن ماجہ/الطلاق ۳۶ (۲۹۸۹)، والأدب ۱ (۳۶۶۳)، (تحفة الأشراف : ۱۰۹۴۸),1899,Narrated Ja'far bin 'Amr bin Umayyah Ad-Damri:,The Book on Food
1900,حَدَّثَنَا وَاصِلُ بْنُ عَبْدِ الأَعْلَى، حَدَّثَنَا مُحَمَّدُ بْنُ فُضَيْلٍ، عَنْ أَبِي حَيَّانَ التَّيْمِيِّ، عَنْ أَبِي زُرْعَةَ بْنِ عَمْرِو بْنِ جَرِيرٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ أُتِيَ النَّبِيُّ صلى الله عليه وسلم بِلَحْمٍ فَرُفِعَ إِلَيْهِ الذِّرَاعُ وَكَانَتْ تُعْجِبُهُ فَنَهَسَ مِنْهَا ‏.‏ قَالَ وَفِي الْبَابِ عَنِ ابْنِ مَسْعُودٍ وَعَائِشَةَ وَعَبْدِ اللَّهِ بْنِ جَعْفَرٍ وَأَبِي عُبَيْدَةَ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَأَبُو حَيَّانَ اسْمُهُ يَحْيَى بْنُ سَعِيدِ بْنِ حَيَّانَ وَأَبُو زُرْعَةَ بْنُ عَمْرِو بْنِ جَرِيرٍ اسْمُهُ هَرِمٌ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۸۸۸۸),1900,Narrated Abu Hurairah:,The Book on Food
1901,حَدَّثَنَا الْحَسَنُ بْنُ مُحَمَّدٍ الزَّعْفَرَانِيُّ، حَدَّثَنَا يَحْيَى بْنُ عَبَّادٍ أَبُو عَبَّادٍ، حَدَّثَنَا فُلَيْحُ بْنُ سُلَيْمَانَ، عَنْ عَبْدِ الْوَهَّابِ بْنِ يَحْيَى، مِنْ وَلَدِ عَبَّادِ بْنِ عَبْدِ اللَّهِ بْنِ الزُّبَيْرِ عَنْ عَبْدِ اللَّهِ بْنِ الزُّبَيْرِ، عَنْ عَائِشَةَ، قَالَتْ مَا كَانَ الذِّرَاعُ أَحَبَّ اللَّحْمِ إِلَى رَسُولِ اللَّهِ صلى الله عليه وسلم وَلَكِنْ كَانَ لاَ يَجِدُ اللَّحْمَ إِلاَّ غِبًّا فَكَانَ يُعَجَّلُ إِلَيْهِ لأَنَّهُ أَعْجَلُهَا نُضْجًا ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ غَرِيبٌ لاَ نَعْرِفُهُ إِلاَّ مِنْ هَذَا الْوَجْهِ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الشھادات ۱۰ (۲۶۵۴)، والأدب ۶ (۵۹۷۶)، والاستئذان ۳۵ (۶۲۷۳)، والمرتدین ۱ (۶۹۱۹)، صحیح مسلم/الإیمان ۳۸ (۸۷)، والمؤلف في الشھادات (۲۳۰۱)، وتفسیر النساء (۳۰۱۹) (تحفة الأشراف : ۱۱۶۷۹)، و مسند احمد (۵/۳۶، ۳۸),1901,Narrated 'Aishah:,The Book on Food
1902,"حَدَّثَنَا الْحَسَنُ بْنُ عَرَفَةَ، حَدَّثَنَا مُبَارَكُ بْنُ سَعِيدٍ، هُوَ أَخُو سُفْيَانَ بْنِ سَعِيدٍ الثَّوْرِيِّ عَنْ سُفْيَانَ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ نِعْمَ الإِدَامُ الْخَلُّ ‏""""‏ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ عَائِشَةَ وَأُمِّ هَانِئٍ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأدب ۴ (۵۹۷۳)، صحیح مسلم/الإیمان ۳۸ (۹۰)، سنن ابی داود/ الأدب ۱۲۹ (۵۱۴۱)، (تحفة الأشراف : ۸۶۱۸),,Narrated Jabir:,The Book on Food
1903,"حَدَّثَنَا مُحَمَّدُ بْنُ سَهْلِ بْنِ عَسْكَرٍ الْبَغْدَادِيُّ، حَدَّثَنَا يَحْيَى بْنُ حَسَّانَ، حَدَّثَنَا سُلَيْمَانُ بْنُ بِلاَلٍ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏""‏ نِعْمَ الإِدَامُ الْخَلُّ ‏""‏ ‏.‏ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ عَبْدِ الرَّحْمَنِ، أَخْبَرَنَا يَحْيَى بْنُ حَسَّانَ، عَنْ سُلَيْمَانَ بْنِ بِلاَلٍ، بِهَذَا الإِسْنَادِ نَحْوَهُ إِلاَّ أَنَّهُ قَالَ ‏""""‏ نِعْمَ الإِدَامُ أَوِ الأُدْمُ الْخَلُّ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ غَرِيبٌ مِنْ هَذَا الْوَجْهِ لاَ نَعْرِفُهُ مِنْ حَدِيثِ هِشَامِ بْنِ عُرْوَةَ إِلاَّ مِنْ حَدِيثِ سُلَيْمَانَ بْنِ بِلاَلٍ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Daif; Bashar Awad Maarouf: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/البر والصلة ۴ (۲۵۵۲)، سنن ابی داود/ الأدب ۱۲۹ (۵۱۴۳)، (تحفة الأشراف : ۷۲۵۹),,Narrated 'Aishah:,The Book on Food
1904,"حَدَّثَنَا أَبُو كُرَيْبٍ، مُحَمَّدُ بْنُ الْعَلاَءِ حَدَّثَنَا أَبُو بَكْرِ بْنُ عَيَّاشٍ، عَنْ أَبِي حَمْزَةَ الثُّمَالِيِّ، عَنِ الشَّعْبِيِّ، عَنْ أُمِّ هَانِئٍ بِنْتِ أَبِي طَالِبٍ، قَالَتْ دَخَلَ عَلَىَّ رَسُولُ اللَّهِ صلى الله عليه وسلم فَقَالَ ‏""‏ هَلْ عِنْدَكُمْ شَيْءٌ ‏""‏ ‏.‏ فَقُلْتُ لاَ إِلاَّ كِسَرٌ يَابِسَةٌ وَخَلٌّ ‏.‏ فَقَالَ النَّبِيُّ صلى الله عليه وسلم ‏""‏ قَرِّبِيهِ فَمَا أَقْفَرَ بَيْتٌ مِنْ أُدْمٍ فِيهِ خَلٌّ ‏""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ غَرِيبٌ مِنْ هَذَا الْوَجْهِ لاَ نَعْرِفُهُ مِنْ حَدِيثِ أُمِّ هَانِئٍ إِلاَّ مِنْ هَذَا الْوَجْهِ ‏.‏ وَأَبُو حَمْزَةَ الثُّمَالِيُّ اسْمُهُ ثَابِتُ بْنُ أَبِي صَفِيَّةَ وَأُمُّ هَانِئٍ مَاتَتْ بَعْدَ عَلِيِّ بْنِ أَبِي طَالِبٍ بِزَمَانٍ ‏.‏ وَسَأَلْتُ مُحَمَّدًا عَنْ هَذَا الْحَدِيثِ فَقَالَ لاَ أَعْرِفُ لِلشَّعْبِيِّ سَمَاعًا مِنْ أُمِّ هَانِئٍ ‏.‏ فَقُلْتُ أَبُو حَمْزَةَ كَيْفَ هُوَ عِنْدَكَ فَقَالَ أَحْمَدُ بْنُ حَنْبَلٍ تَكَلَّمَ فِيهِ وَهُوَ عِنْدِي مُقَارِبُ الْحَدِيثِ ‏.‏",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: صحیح البخاری/الصلح ۶ (۲۶۹۹)، والمغازي ۴۳ (۴۲۴۱) (في کلا الوضعین في سیاق طویل) (تحفة الأشراف : ۱۸۰۳),1904,Narrated Umm Hani' bint Abi Talib:,The Book on Food
1905,"حَدَّثَنَا عَبْدَةُ بْنُ عَبْدِ اللَّهِ الْخُزَاعِيُّ الْبَصْرِيُّ، قَالَ حَدَّثَنَا مُعَاوِيَةُ بْنُ هِشَامٍ، عَنْ سُفْيَانَ، عَنْ مُحَارِبِ بْنِ دِثَارٍ، عَنْ جَابِرٍ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ نِعْمَ الإِدَامُ الْخَلُّ ‏""""‏ ‏.‏ هَذَا أَصَحُّ مِنْ حَدِيثِ مُبَارَكِ بْنِ سَعِيدٍ ‏.‏""",Ahmad Muhammad Shakir: Hasan; Al-Albani: Hasan; Bashar Awad Maarouf: Hasan; Takhreej-Group: Sahih; Zubair Ali Zai: Hasan,takhreej: تخریج الحدیث: «صحیح مسلم/العتق 6 (1510)، سنن ابن ماجہ/الدعاء 11 (3659) (تحفة الأشراف: 12595)، و مسند احمد (2/230، 263، 276، 445) (صحیح),,Narrated Jabir:,The Book on Food
1906,حَدَّثَنَا عَبْدَةُ بْنُ عَبْدِ اللَّهِ الْخُزَاعِيُّ، حَدَّثَنَا مُعَاوِيَةُ بْنُ هِشَامٍ، عَنْ سُفْيَانَ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، أَنَّ النَّبِيَّ صلى الله عليه وسلم كَانَ يَأْكُلُ الْبِطِّيخَ بِالرُّطَبِ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ أَنَسٍ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ غَرِيبٌ ‏.‏ وَرَوَاهُ بَعْضُهُمْ عَنْ هِشَامِ بْنِ عُرْوَةَ عَنْ أَبِيهِ عَنِ النَّبِيِّ صلى الله عليه وسلم مُرْسَلٌ وَلَمْ يَذْكُرْ فِيهِ عَنْ عَائِشَةَ وَقَدْ رَوَى يَزِيدُ بْنُ رُومَانَ عَنْ عُرْوَةَ عَنْ عَائِشَةَ هَذَا الْحَدِيثَ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Takhreej-Group: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج الحدیث: «سنن ابی داود/ الزکاة 46 (1694) (تحفة الأشراف: 9728)، و مسند احمد (1/191، 194) (صحیح),1906,Narrated 'Aishah:,The Book on Food
1907,حَدَّثَنَا إِسْمَاعِيلُ بْنُ مُوسَى الْفَزَارِيُّ، حَدَّثَنَا إِبْرَاهِيمُ بْنُ سَعْدٍ، عَنْ أَبِيهِ، عَنْ عَبْدِ اللَّهِ بْنِ جَعْفَرٍ، قَالَ كَانَ النَّبِيُّ صلى الله عليه وسلم يَأْكُلُ الْقِثَّاءَ بِالرُّطَبِ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ غَرِيبٌ لاَ نَعْرِفُهُ إِلاَّ مِنْ حَدِيثِ إِبْرَاهِيمَ بْنِ سَعْدٍ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Sahih; Takhreej-Group: Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج الحدیث: «صحیح البخاری/الأدب 15 (5991)، سنن ابی داود/ الزکاة 45 (1697) (تحفة الأشراف: 8915)، و مسند احمد (2/163، 190، 193) (صحیح),1907,Narrated 'Abdullah bin Ja'far:,The Book on Food
1908,"حَدَّثَنَا الْحَسَنُ بْنُ مُحَمَّدٍ الزَّعْفَرَانِيُّ، حَدَّثَنَا عَفَّانُ، حَدَّثَنَا حَمَّادُ بْنُ سَلَمَةَ، أَخْبَرَنَا حُمَيْدٌ، وَثَابِتٌ، وَقَتَادَةُ، عَنْ أَنَسٍ، أَنَّ نَاسًا، مِنْ عُرَيْنَةَ قَدِمُوا الْمَدِينَةَ فَاجْتَوَوْهَا فَبَعَثَهُمُ النَّبِيُّ صلى الله عليه وسلم فِي إِبِلِ الصَّدَقَةِ وَقَالَ ‏ ‏ اشْرَبُوا مِنْ أَبْوَالِهَا وَأَلْبَانِهَا ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ غَرِيبٌ مِنْ هَذَا الْوَجْهِ ‏.‏ وَقَدْ رُوِيَ هَذَا الْحَدِيثُ مِنْ غَيْرِ وَجْهٍ عَنْ أَنَسٍ رَوَاهُ أَبُو قِلاَبَةَ عَنْ أَنَسٍ وَرَوَاهُ سَعِيدُ بْنُ أَبِي عَرُوبَةَ عَنْ قَتَادَةَ عَنْ أَنَسٍ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Takhreej-Group: Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج الحدیث: «صحیح البخاری/الأدب 11 (5984)، صحیح مسلم/البر والصلة 6 (2556)، سنن ابی داود/ الزکاة 45 (1696) (تحفة الأشراف: 3190)، و مسند احمد (4/80، 83، 84، 85) (صحیح),,Narrated Anas:,The Book on Food
1909,"حَدَّثَنَا يَحْيَى بْنُ مُوسَى، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، حَدَّثَنَا قَيْسُ بْنُ الرَّبِيعِ، ح قَالَ وَحَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا عَبْدُ الْكَرِيمِ الْجُرْجَانِيُّ، عَنْ قَيْسِ بْنِ الرَّبِيعِ الْمَعْنَى، وَاحِدٌ، عَنْ أَبِي هَاشِمٍ يَعْنِي الرُّمَّانِيَّ، عَنْ زَاذَانَ، عَنْ سَلْمَانَ، قَالَ قَرَأْتُ فِي التَّوْرَاةِ أَنَّ بَرَكَةَ الطَّعَامِ الْوُضُوءُ بَعْدَهُ فَذَكَرْتُ ذَلِكَ لِلنَّبِيِّ صلى الله عليه وسلم فَأَخْبَرْتُهُ بِمَا قَرَأْتُ فِي التَّوْرَاةِ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ بَرَكَةُ الطَّعَامِ الْوُضُوءُ قَبْلَهُ وَالْوُضُوءُ بَعْدَهُ ‏""""‏ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ أَنَسٍ وَأَبِي هُرَيْرَةَ ‏.‏ قَالَ أَبُو عِيسَى لاَ نَعْرِفُ هَذَا الْحَدِيثَ إِلاَّ مِنْ حَدِيثِ قَيْسِ بْنِ الرَّبِيعِ ‏.‏ وَقَيْسُ بْنُ الرَّبِيعِ يُضَعَّفُ فِي الْحَدِيثِ وَأَبُو هَاشِمٍ الرُّمَّانِيُّ اسْمُهُ يَحْيَى بْنُ دِينَارٍ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Takhreej-Group: Daif; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج الحدیث: «تفرد بہ المؤلف (تحفة الأشراف: 15828)، و مسند احمد (6/409) (ضعیف) (سند میں ابن ابی سوید مجہول راوی ہیں، اور سند میں انقطاع بھی ہے، اس لیے کہ عمر بن عبدالعزیز کا سماع خولہ سے معروف نہیں ہے، اس لیے وإنكم لمن ريحان الله کا فقرہ ضعیف ہے، لیکن پہلا فقرہ شواہد کی بنا پر صحیح لغیرہ ہے، ملاحظہ ہو: تخریج کتاب الزہد لوکیع بن الجراح بتحقیق، عبدالرحمن الفریوائی، حدیث نمبر 178، والضعیفة 3214، والصحیحة 4764)»,,Narrated Salman:,The Book on Food
1910,"حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ إِبْرَاهِيمَ، عَنْ أَيُّوبَ، عَنِ ابْنِ أَبِي مُلَيْكَةَ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم خَرَجَ مِنَ الْخَلاَءِ فَقُرِّبَ إِلَيْهِ طَعَامٌ فَقَالُوا أَلاَ نَأْتِيكَ بِوَضُوءٍ قَالَ ‏ ‏ إِنَّمَا أُمِرْتُ بِالْوُضُوءِ إِذَا قُمْتُ إِلَى الصَّلاَةِ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَقَدْ رَوَاهُ عَمْرُو بْنُ دِينَارٍ عَنْ سَعِيدِ بْنِ الْحُوَيْرِثِ عَنِ ابْنِ عَبَّاسٍ ‏.‏ وَقَالَ عَلِيُّ بْنُ الْمَدِينِيِّ قَالَ يَحْيَى بْنُ سَعِيدٍ كَانَ سُفْيَانُ الثَّوْرِيُّ يَكْرَهُ غَسْلَ الْيَدِ قَبْلَ الطَّعَامِ وَكَانَ يَكْرَهُ أَنْ يُوضَعَ الرَّغِيفُ تَحْتَ الْقَصْعَةِ ‏.""",Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Takhreej-Group: Sahih; Zubair Ali Zai: Daif,takhreej: تخریج الحدیث: «صحیح البخاری/الأدب 17 (5993)، صحیح مسلم/الفضائل 15 (2318)، سنن ابی داود/ الأدب 156 (5218) (تحفة الأشراف: 1546)، و مسند احمد (2/228، 269) (صحیح),,Narrated Ibn 'Abbas:,The Book on Food
1911,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا الْعَلاَءُ بْنُ الْفَضْلِ بْنِ عَبْدِ الْمَلِكِ بْنِ أَبِي سَوِيَّةَ أَبُو الْهُذَيْلِ، حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ عِكْرَاشٍ، عَنْ أَبِيهِ، عِكْرَاشِ بْنِ ذُؤَيْبٍ قَالَ بَعَثَنِي بَنُو مُرَّةَ بْنِ عُبَيْدٍ بِصَدَقَاتِ أَمْوَالِهِمْ إِلَى رَسُولِ اللَّهِ صلى الله عليه وسلم فَقَدِمْتُ عَلَيْهِ الْمَدِينَةَ فَوَجَدْتُهُ جَالِسًا بَيْنَ الْمُهَاجِرِينَ وَالأَنْصَارِ قَالَ ثُمَّ أَخَذَ بِيَدِي فَانْطَلَقَ بِي إِلَى بَيْتِ أُمِّ سَلَمَةَ فَقَالَ ‏""‏ هَلْ مِنْ طَعَامٍ ‏""‏ ‏.‏ فَأُتِينَا بِجَفْنَةٍ كَثِيرَةِ الثَّرِيدِ وَالْوَذْرِ وَأَقْبَلْنَا نَأْكُلُ مِنْهَا فَخَبَطْتُ بِيَدِي مِنْ نَوَاحِيهَا وَأَكَلَ رَسُولُ اللَّهِ صلى الله عليه وسلم مِنْ بَيْنِ يَدَيْهِ فَقَبَضَ بِيَدِهِ الْيُسْرَى عَلَى يَدِي الْيُمْنَى ثُمَّ قَالَ ‏""‏ يَا عِكْرَاشُ كُلْ مِنْ مَوْضِعٍ وَاحِدٍ فَإِنَّهُ طَعَامٌ وَاحِدٌ ‏""‏ ‏.‏ ثُمَّ أُتِينَا بِطَبَقٍ فِيهِ أَلْوَانُ الرُّطَبِ أَوِ التَّمْرِ عُبَيْدُ اللَّهِ شَكَّ قَالَ فَجَعَلْتُ آكُلُ مِنْ بَيْنِ يَدَىَّ وَجَالَتْ يَدُ رَسُولِ اللَّهِ صلى الله عليه وسلم فِي الطَّبَقِ وَقَالَ ‏""‏ يَا عِكْرَاشُ كُلْ مِنْ حَيْثُ شِئْتَ فَإِنَّهُ غَيْرُ لَوْنٍ وَاحِدٍ ‏""‏ ‏.‏ ثُمَّ أُتِينَا بِمَاءٍ فَغَسَلَ رَسُولُ اللَّهِ صلى الله عليه وسلم يَدَيْهِ وَمَسَحَ بِبَلَلِ كَفَّيْهِ وَجْهَهُ وَذِرَاعَيْهِ وَرَأْسَهُ وَقَالَ ‏""‏ يَا عِكْرَاشُ هَذَا الْوُضُوءُ مِمَّا غَيَّرَتِ النَّارُ ‏""‏ ‏.‏ وَفِي الْحَدِيثِ قِصَّةٌ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ غَرِيبٌ لاَ نَعْرِفُهُ إِلاَّ مِنْ حَدِيثِ الْعَلاَءِ بْنِ الْفَضْلِ وَقَدْ تَفَرَّدَ الْعَلاَءُ بِهَذَا الْحَدِيثِ وَلاَ نَعْرِفُ لِعِكْرَاشٍ عَنِ النَّبِيِّ صلى الله عليه وسلم إِلاَّ هَذَا الْحَدِيثَ ‏.‏",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,,1911,Narrated 'Ikrash bin Dhu'aib:,The Book on Food
1912,حَدَّثَنَا قُتَيْبَةُ بْنُ سَعِيدٍ، حَدَّثَنَا اللَّيْثُ، عَنْ مُعَاوِيَةَ بْنِ صَالِحٍ، عَنْ أَبِي طَالُوتَ، قَالَ دَخَلْتُ عَلَى أَنَسِ بْنِ مَالِكٍ وَهُوَ يَأْكُلُ الْقَرْعَ وَهُوَ يَقُولُ يَا لَكِ شَجَرَةً مَا أُحِبُّكِ إِلاَّ لِحُبِّ رَسُولِ اللَّهِ صلى الله عليه وسلم إِيَّاكِ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ حَكِيمِ بْنِ جَابِرٍ عَنْ أَبِيهِ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ غَرِيبٌ مِنْ هَذَا الْوَجْهِ ‏.‏,Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأدب ۱۳۰ (۵۱۴۷) (تحفة الأشراف : ۴۰۴۱)، و یأتي برقم ۱۹۱۶,1912,Narrated Abu Talut:,The Book on Food
1913,"حَدَّثَنَا مُحَمَّدُ بْنُ مَيْمُونٍ الْمَكِّيُّ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، حَدَّثَنِي مَالِكُ بْنُ أَنَسٍ، عَنْ إِسْحَاقَ بْنِ عَبْدِ اللَّهِ بْنِ أَبِي طَلْحَةَ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ رَأَيْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم يَتَتَبَّعُ فِي الصَّحْفَةِ - يَعْنِي الدُّبَّاءَ فَلاَ أَزَالُ أُحِبُّهُ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَقَدْ رُوِيَ هَذَا الْحَدِيثُ مِنْ غَيْرِ وَجْهٍ عَنْ أَنَسٍ وَرُوِيَ أَنَّهُ رَأَى الدُّبَّاءَ بَيْنَ يَدَىْ رَسُولِ اللَّهِ صلى الله عليه وسلم فَقَالَ لَهُ مَا هَذَا قَالَ ‏ ‏ هَذَا الدُّبَّاءُ نُكَثِّرُ بِهِ طَعَامَنَا ‏""""‏ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: صحیح البخاری/الزکاة ۱۰ (۱۴۱۸)، والأدب ۱۸ (۵۹۹۵)، صحیح مسلم/البر والصلة ۴۶ (۲۶۲۹)، کلاہما مع ذکر القصة المشھورة في رقم ۱۹۱۵، و مسند احمد (۶/۳۳، ۸۸، ۱۶۶، ۲۴۳)، ویأتي عند المؤلف برقم ۱۹۱۵,,Narrated Anas bin Malik:,The Book on Food
1914,"حَدَّثَنَا يَحْيَى بْنُ مُوسَى، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، عَنْ مَعْمَرٍ، عَنْ زَيْدِ بْنِ أَسْلَمَ، عَنْ أَبِيهِ، عَنْ عُمَرَ بْنِ الْخَطَّابِ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ كُلُوا الزَّيْتَ وَادَّهِنُوا بِهِ فَإِنَّهُ مِنْ شَجَرَةٍ مُبَارَكَةٍ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ لاَ نَعْرِفُهُ إِلاَّ مِنْ حَدِيثِ عَبْدِ الرَّزَّاقِ عَنْ مَعْمَرٍ وَكَانَ عَبْدُ الرَّزَّاقِ يَضْطَرِبُ فِي رِوَايَةِ هَذَا الْحَدِيثِ فَرُبَّمَا ذَكَرَ فِيهِ عَنْ عُمَرَ عَنِ النَّبِيِّ صلى الله عليه وسلم وَرُبَّمَا رَوَاهُ عَلَى الشَّكِّ فَقَالَ أَحْسَبُهُ عَنْ عُمَرَ عَنِ النَّبِيِّ صلى الله عليه وسلم وَرُبَّمَا قَالَ عَنْ زَيْدِ بْنِ أَسْلَمَ عَنْ أَبِيهِ عَنِ النَّبِيِّ صلى الله عليه وسلم مُرْسَلاً ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: صحیح مسلم/البر والصلة ۴۶ (۲۶۳۱)، (تحفة الأشراف : ۱۷۱۳),,Narrated 'Umar bin Al-Khattab:,The Book on Food
1915,حَدَّثَنَا أَبُو دَاوُدَ، سُلَيْمَانُ بْنُ مَعْبَدٍ حَدَّثَنَا عَبْدُ الرَّزَّاقِ، عَنْ مَعْمَرٍ، عَنْ زَيْدِ بْنِ أَسْلَمَ، عَنْ أَبِيهِ، عَنِ النَّبِيِّ صلى الله عليه وسلم نَحْوَهُ وَلَمْ يَذْكُرْ فِيهِ عَنْ عُمَرَ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: أنظر حدیث رقم ۱۹۱۳ (تحفة الأشراف : ۱۶۳۵۰),1915,,The Book on Food
1916,"حَدَّثَنَا مَحْمُودُ بْنُ غَيْلاَنَ، حَدَّثَنَا أَبُو أَحْمَدَ الزُّبَيْرِيُّ، وَأَبُو نُعَيْمٍ قَالاَ حَدَّثَنَا سُفْيَانُ، عَنْ عَبْدِ اللَّهِ بْنِ عِيسَى، عَنْ رَجُلٍ، يُقَالُ لَهُ عَطَاءٌ مِنْ أَهْلِ الشَّامِ عَنْ أَبِي أَسِيدٍ قَالَ قَالَ النَّبِيُّ صلى الله عليه وسلم ‏ ‏ كُلُوا الزَّيْتَ وَادَّهِنُوا بِهِ فَإِنَّهُ مِنْ شَجَرَةٍ مُبَارَكَةٍ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ غَرِيبٌ مِنْ هَذَا الْوَجْهِ إِنَّمَا نَعْرِفُهُ مِنْ حَدِيثِ سُفْيَانَ الثَّوْرِيِّ عَنْ عَبْدِ اللَّهِ بْنِ عِيسَى ‏.‏""",Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Bashar Awad Maarouf: Hasan; Zubair Ali Zai: Hasan,takhreej: تخریج دارالدعوہ: انظر حدیث رقم ۹۱۲ (تحفة الأشراف : ۱۰۸۴),,Narrated Abu Asid:,The Book on Food
1917,"حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ، حَدَّثَنَا سُفْيَانُ، عَنْ إِسْمَاعِيلَ بْنِ أَبِي خَالِدٍ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، يُخْبِرُهُمْ ذَاكَ عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ إِذَا كَفَى أَحَدَكُمْ خَادِمُهُ طَعَامَهُ حَرَّهُ وَدُخَانَهُ فَلْيَأْخُذْ بِيَدِهِ فَلْيُقْعِدْهُ مَعَهُ فَإِنْ أَبَى فَلْيَأْخُذْ لُقْمَةً فَلْيُطْعِمْهَا إِيَّاهُ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَأَبُو خَالِدٍ وَالِدُ إِسْمَاعِيلَ اسْمُهُ سَعْدٌ ‏.‏""",Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Bashar Awad Maarouf: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۶۰۲۷),,Narrated Isma'il bin Abi Khalid:,The Book on Food
1918,"حَدَّثَنَا يُوسُفُ بْنُ حَمَّادٍ الْمَعْنِيُّ الْبَصْرِيُّ، حَدَّثَنَا عُثْمَانُ بْنُ عَبْدِ الرَّحْمَنِ الْجُمَحِيُّ، عَنْ مُحَمَّدِ بْنِ زِيَادٍ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ أَفْشُوا السَّلاَمَ وَأَطْعِمُوا الطَّعَامَ وَاضْرِبُوا الْهَامَ تُورَثُوا الْجِنَانَ ‏""""‏ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ عَبْدِ اللَّهِ بْنِ عَمْرٍو وَابْنِ عُمَرَ وَأَنَسٍ وَعَبْدِ اللَّهِ بْنِ سَلاَمٍ وَعَبْدِ الرَّحْمَنِ بْنِ عَائِشٍ وَشُرَيْحِ بْنِ هَانِئٍ عَنْ أَبِيهِ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ غَرِيبٌ مِنْ حَدِيثِ ابْنِ زِيَادٍ عَنْ أَبِي هُرَيْرَةَ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: تخریج دارالدعوہ: صحیح البخاری/الطلاق ۲۵ (۵۳۰۳)، والأدب ۲۴ (۶۰۰۵)، سنن ابی داود/ الأدب ۱۳۱ (۵۱۵۰) (تحفة الأشراف : ۴۷۱۰)، و مسند احمد (۵/۳۳۳),,Narrated Abu Hurairah:,The Book on Food
1919,"حَدَّثَنَا هَنَّادٌ، حَدَّثَنَا أَبُو الأَحْوَصِ، عَنْ عَطَاءِ بْنِ السَّائِبِ، عَنْ أَبِيهِ، عَنْ عَبْدِ اللَّهِ بْنِ عَمْرٍو، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ اعْبُدُوا الرَّحْمَنَ وَأَطْعِمُوا الطَّعَامَ وَأَفْشُوا السَّلاَمَ تَدْخُلُوا الْجَنَّةَ بِسَلاَمٍ ‏""""‏ ‏.‏ قَالَ هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Hasan,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۸۳۸),,Narrated 'Abdullah bin 'Amr:,The Book on Food
1920,"حَدَّثَنَا يَحْيَى بْنُ مُوسَى، حَدَّثَنَا مُحَمَّدُ بْنُ يَعْلَى الْكُوفِيُّ، حَدَّثَنَا عَنْبَسَةُ بْنُ عَبْدِ الرَّحْمَنِ الْقُرَشِيُّ، عَنْ عَبْدِ الْمَلِكِ بْنِ عَلاَّقٍ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ قَالَ النَّبِيُّ صلى الله عليه وسلم ‏ ‏ تَعَشَّوْا وَلَوْ بِكَفٍّ مِنْ حَشَفٍ فَإِنَّ تَرْكَ الْعَشَاءِ مَهْرَمَةٌ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ مُنْكَرٌ لاَ نَعْرِفُهُ إِلاَّ مِنْ هَذَا الْوَجْهِ ‏.‏ وَعَنْبَسَةُ يُضَعَّفُ فِي الْحَدِيثِ وَعَبْدُ الْمَلِكِ بْنُ عَلاَّقٍ مَجْهُولٌ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Hasan,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأدب ۶۶ (۴۹۴۳) (تحفة الأشراف : ۸۷۸۹)، و مسند احمد (۲/۱۸۵، ۲۰۷),,Narrated Anas bin Malik:,The Book on Food
1921,"حَدَّثَنَا عَبْدُ اللَّهِ بْنُ الصَّبَّاحِ الْهَاشِمِيُّ، حَدَّثَنَا عَبْدُ الأَعْلَى، عَنْ مَعْمَرٍ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ أَبِيهِ، عَنْ عُمَرَ بْنِ أَبِي سَلَمَةَ، أَنَّهُ دَخَلَ عَلَى رَسُولِ اللَّهِ صلى الله عليه وسلم وَعِنْدَهُ طَعَامٌ فَقَالَ ‏ ‏ ادْنُ يَا بُنَىَّ وَسَمِّ اللَّهَ وَكُلْ بِيَمِينِكَ وَكُلْ مِمَّا يَلِيكَ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى وَقَدْ رُوِيَ عَنْ هِشَامِ بْنِ عُرْوَةَ عَنْ أَبِي وَجْزَةَ السَّعْدِيِّ عَنْ رَجُلٍ مِنْ مُزَيْنَةَ عَنْ عُمَرَ بْنِ أَبِي سَلَمَةَ ‏.‏ وَقَدِ اخْتَلَفَ أَصْحَابُ هِشَامِ بْنِ عُرْوَةَ فِي رِوَايَةِ هَذَا الْحَدِيثِ ‏.‏ وَأَبُو وَجْزَةَ السَّعْدِيُّ اسْمُهُ يَزِيدُ بْنُ عُبَيْدٍ ‏.‏""",Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۶۲۰۷)، و مسند احمد (۱/۲۵۷),,Narrated 'Umar bin Abi Salamah:,The Book on Food
1922,"حَدَّثَنَا أَبُو بَكْرٍ، مُحَمَّدُ بْنُ أَبَانَ حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا هِشَامٌ الدَّسْتَوَائِيُّ، عَنْ بُدَيْلِ بْنِ مَيْسَرَةَ الْعُقَيْلِيِّ، عَنْ عَبْدِ اللَّهِ بْنِ عُبَيْدِ بْنِ عُمَيْرٍ، عَنْ أُمِّ كُلْثُومٍ، عَنْ عَائِشَةَ، قَالَتْ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ إِذَا أَكَلَ أَحَدُكُمْ طَعَامًا فَلْيَقُلْ بِسْمِ اللَّهِ فَإِنْ نَسِيَ فِي أَوَّلِهِ فَلْيَقُلْ بِسْمِ اللَّهِ فِي أَوَّلِهِ وَآخِرِهِ ‏""""‏ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح البخاری/التوحید ۲ (۷۳۷۶) (وانظر أیضا: الأدب ۲۷ (۶۰۱۳)، صحیح مسلم/الفضائل ۱۵ (۲۳۱۹) (تحفة الأشراف : ۳۲۲۸),,Narrated Umm Kulthum:,The Book on Food
1923,"وَبِهَذَا الإِسْنَادِ عَنْ عَائِشَةَ، قَالَتْ كَانَ النَّبِيُّ صلى الله عليه وسلم يَأْكُلُ طَعَامًا فِي سِتَّةٍ مِنْ أَصْحَابِهِ فَجَاءَ أَعْرَابِيٌّ فَأَكَلَهُ بِلُقْمَتَيْنِ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ أَمَا إِنَّهُ لَوْ سَمَّى لَكَفَاكُمْ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَأُمُّ كُلْثُومٍ هِيَ بِنْتُ مُحَمَّدِ بْنِ أَبِي بَكْرٍ الصِّدِّيقِ رَضِيَ اللَّهُ عَنْهُ ‏.‏""",Ahmad Muhammad Shakir: Hasan; Al-Albani: Hasan; Bashar Awad Maarouf: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأدب ۶۶ (۴۹۴۲) (تحفة الأشراف : ۱۳۳۹۱),,"It is narrated with this chain of narration, from 'Aishah who said:",The Book on Food
1924,"حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا يَعْقُوبُ بْنُ الْوَلِيدِ الْمَدَنِيُّ، عَنِ ابْنِ أَبِي ذِئْبٍ، عَنِ الْمَقْبُرِيِّ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ إِنَّ الشَّيْطَانَ حَسَّاسٌ لَحَّاسٌ فَاحْذَرُوهُ عَلَى أَنْفُسِكُمْ مَنْ بَاتَ وَفِي يَدِهِ رِيحُ غَمَرٍ فَأَصَابَهُ شَيْءٌ فَلاَ يَلُومَنَّ إِلاَّ نَفْسَهُ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ غَرِيبٌ مِنْ هَذَا الْوَجْهِ ‏.‏ وَقَدْ رُوِيَ مِنْ حَدِيثِ سُهَيْلِ بْنِ أَبِي صَالِحٍ عَنْ أَبِيهِ عَنْ أَبِي هُرَيْرَةَ عَنِ النَّبِيِّ صلى الله عليه وسلم ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأدب ۶۶ (۴۹۴۱) (تحفة الأشراف : ۸۹۶۶),,Narrated Abu Hurairah:,The Book on Food
1925,"حَدَّثَنَا أَبُو بَكْرٍ، مُحَمَّدُ بْنُ إِسْحَاقَ الْبَغْدَادِيُّ الصَّاغَانِيُّ حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ الْمَدَائِنِيُّ، حَدَّثَنَا مَنْصُورُ بْنُ أَبِي الأَسْوَدِ، عَنِ الأَعْمَشِ، عَنْ أَبِي صَالِحٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنْ بَاتَ وَفِي يَدِهِ رِيحُ غَمَرٍ فَأَصَابَهُ شَيْءٌ فَلاَ يَلُومَنَّ إِلاَّ نَفْسَهُ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ غَرِيبٌ لاَ نَعْرِفُهُ مِنْ حَدِيثِ الأَعْمَشِ إِلاَّ مِنْ هَذَا الْوَجْهِ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الإیمان ۴۲ (۵۷)، والمواقیت ۳ (۵۲۴)، والزکاة ۲ (۱۴۰۱)، والبیوع ۵۸ (۲۱۵۷)، والشروط ۱ (۲۷۱۴، ۲۷۱۵)، والأحکام ۴۳ (۷۲۰۴)، صحیح مسلم/الإیمان ۲۳ (۵۶)، سنن النسائی/البیعة ۶ (۴۱۶۱)، و۱۶ (۴۱۷۹)، و ۱۷ (۴۱۸۲)، و ۲۴ (۴۱۹۴) (تحفة الأشراف : ۳۲۲۶)، و مسند احمد (۴/۳۵۸، ۳۶۱، ۳۶۴، ۳۶۵)، وسنن الدارمی/البیوع ۹ (۲۵۸۲),,Narrated Abu Hurairah:,The Book on Food
