{"hadithnumber": "3199", "text": "ایوب نے قاسم اور ابو قلابہ سے اور انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے روایت کی انھوں نے کہ"}
{"hadithnumber": "3200", "text": "ہمیں ابن عون نے قاسم سے حدیث بیان کی انھوں نے ام المومنین  ( حضرت عائشہ رضی اللہ تعالیٰ عنہا    رضی"}
{"hadithnumber": "3201", "text": "منصور نے ابرا ہیم سے انھوں نے اسود سے اور انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے روایت کی انھ"}
{"hadithnumber": "3202", "text": "یحییٰ بن یحییٰ ابو بکر بن ابی شیبہ اور بو کریب میں یحییٰ نے کہا  :  ابو معاویہ نے ہمیں خبردی اور دوس"}
{"hadithnumber": "3203", "text": "یحییٰ بن یحییٰ ابو بکر بن ابی شیبہ اور ابو کریب نے باقی ماندہ اسی سند کے ساتھ حضرت عائشہ رضی اللہ تع"}
{"hadithnumber": "3204", "text": "حکم نے ابرا ہیم سے انھوں نے اسود سے اور انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے روایت کی انھوں"}
{"hadithnumber": "3205", "text": "عمرہ بنت عبد الرحمن  رضی اللہ تعالیٰ عنہا  نے خبردی کہ ابن زیاد نے حضرت عائشہ  رضی اللہ تعالیٰ عنہا"}
{"hadithnumber": "3206", "text": "اسما عیل بن ابی خالد نے ہمیں خبردی انھوں نے شعبی سے اور انھوں نے مسروق سے روایت کی  ،  انھوں نے کہا"}
{"hadithnumber": "3207", "text": "داوداور زکریا دونوں نے شعبی سے حدیث بیان کی انھوں نے مسروق سے انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عن"}
{"hadithnumber": "3208", "text": "امام مالک نے ابو زناد سے انھوں نے اعرج سے اور انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت"}
{"hadithnumber": "3209", "text": "مغیرہ بن عبد الرحمٰن حزامی نے ابو زناد سے اور انھوں نے اعرج سے اسی سند کے ساتھ روایت کی اور کہا اس ا"}
{"hadithnumber": "3210", "text": "ہمام بن منبہ سے روایت ہے انھوں نے کہا  :  یہ احا دیث ہیں جو ہمیں  حضرت ابو ہر یرہ رضی اللہ تعالیٰ عن"}
{"hadithnumber": "3211", "text": "ثابت بنا نی نے حضرت انس  رضی اللہ تعالیٰ عنہ  سے روایت کی ،  انھوں نے کہا رسول اللہ  صلی اللہ علیہ و"}
{"hadithnumber": "3212", "text": "ہمیں وکیع نے مسعر سے حدیث بیان کی انھوں نے بکیر بن اخنس سے اور انھوں نے حضرت انس  رضی اللہ تعالیٰ عن"}
{"hadithnumber": "3213", "text": "ہمیں ابن بشر نے مسعر سے حدیث بیان کی  ،  ( کہا  )  مجھے بکیر بن اخنس نے حدیث بیان کی ،  انھوں نے کہا"}
{"hadithnumber": "3214", "text": "ابن جریج سے روایت ہے  ( انھوں نے کہا )  مجھے زبیر نے خبر دی کہا میں نے جا بر بن عبد اللہ  رضی اللہ ت"}
{"hadithnumber": "3215", "text": "ہمیں معقل نے ابو زبیر سے حدیث بیان کی کہا  :  میں نے حضرت جا بر  رضی اللہ تعالیٰ عنہ  سے ہدی  ( بیت"}
{"hadithnumber": "3216", "text": "ہمیں عبد الوارث بن سعید نے ابو تیاح ضبعی سے خبر دی  ( کہا  )  مجھ سے موسیٰ بن سلمہ ہذلی نے حدیث بیان"}
{"hadithnumber": "3217", "text": "اسماعیل بن علیہ نے ابو تیاح سے حدیث بیان کی انھوں نے موسیٰ بن سلمہ سے اور انھوں نے ابن عبا س رضی الل"}
{"hadithnumber": "3218", "text": "ابو قبیصہ ذؤیب نے حدیث بیان کی کہ رسول اللہ  صلی اللہ علیہ وسلم  ان کے ساتھ قر بانی کے اونٹ بھیجتے پ"}
{"hadithnumber": "3219", "text": "سعید بن منصور اور زہیر بن حرب نے ہمیں حدیث بیان کی دونوں نے کہا  :  ہمیں سفیان نے سلیما ن احول سے حد"}
{"hadithnumber": "3220", "text": "طاؤس کے بیٹے  ( عبد اللہ  )  نے اپنے والد سے انھوں نے حضرت ابن عباس رضی اللہ تعالیٰ عنہ  سے روایت کی"}
{"hadithnumber": "3221", "text": "حسن بن مسلم نے طاؤس سے خبر دی انھوں نے کہا  :  میں حضرت ابن عبا س رضی اللہ تعالیٰ عنہ  کے ساتھ تھا ک"}
{"hadithnumber": "3230", "text": "امام مالک نے نافع سے انھوں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے روایت کی کہ رسول اللہ  صلی اللہ ع"}
{"hadithnumber": "3231", "text": "ہمیں حماد نے حدیث بیان کی  ( کہا )  ہمیں ایوب نے نافع سے حدیث بیان کی انھوں نے کہا فتح مکہ کے دن رسو"}
{"hadithnumber": "3232", "text": "سفیان نے ہمیں ایوب سختیانی سے حدیث بیان کی انھون نے نافع سے اور انھوں نے حضرت ابن عمر رضی اللہ تعالی"}
{"hadithnumber": "3233", "text": "عبید اللہ نے نافع سے اور انھوں نے حضرت ابن عمر  رضی اللہ تعالیٰ عنہ  سے روایت کی کہا  :  رسول اللہ"}
{"hadithnumber": "3234", "text": "عبد اللہ عون نے ہمیں نا فع سے حدیث بیان کی انھوں نے حضرت عبد اللہ بن عمر رضی اللہ تعالیٰ عنہ  سے روا"}
{"hadithnumber": "3235", "text": "لیث نے ہمیں ابن شہاب سے خبر دی انھوں نے سالم سے انھوں نے اپنے والد  ( عبد اللہ بن عمر رضی اللہ تعالی"}
{"hadithnumber": "3236", "text": "یو نس نے مجھے ابن شہاب سے خبر دی  ( کہا )  مجھے سالم بن عبد اللہ نے اپنے والد  ( عبد اللہ بن عمر رضی"}
{"hadithnumber": "3237", "text": "ابن جریج نے ہمیں خبر دی کہا  :  میں نے عطا ء سے پو چھا  :  کیا آپ نے حضرت ابن عباس رضی اللہ تعالیٰ ع"}
{"hadithnumber": "3238", "text": "حضرت ابن عباس رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ نبی  صلی اللہ علیہ وسلم  کعبہ میں دا خل ہو ئے اور"}
{"hadithnumber": "3239", "text": "ہمیں اسماعیل بن ابی خالد نے خبر دی کہا میں نے رسول اللہ  صلی اللہ علیہ وسلم  کے صحابی عبد اللہ بن اب"}
{"hadithnumber": "3240", "text": "ابو معاویہ نے ہمیں ہشام بن عروہ سے خبر دی انھوں نے اپنے والد  ( عروہ )  سے انھوں نے حجرت عائشہ رضی ا"}
{"hadithnumber": "3241", "text": "ابن نمیر نے ہشام سے اسی سند کے ساتھ  ( یہی  )  حدیث بیان کی ۔"}
{"hadithnumber": "3242", "text": "سالم بن عبد اللہ سے روایت ہے کہ عبد اللہ بن محمد بن ابی بکر صدیق  رضی اللہ تعالیٰ عنہ  نے نبی  صلی ا"}
{"hadithnumber": "3243", "text": "ابن عمر رضی اللہ تعالیٰ عنہ  کے آزاد کردہ غلام نافع کہتے ہیں میں نے عبد اللہ بن ابی بکر ابی قحانہ  ر"}
{"hadithnumber": "3244", "text": "سعید یعنی ابن بیناء سے روایت ہے کہا میں نے عبد اللہ بن زبیر  رضی اللہ تعالیٰ عنہ  سے سنا وہ کہہ رہے"}
{"hadithnumber": "3245", "text": "عطا ء سے روایت ہے انھوں  نے کہا یزید بن معاویہ کے دور میں جب اہل شام نے  ( مکہ پر  )  حملہ کیا اور ک"}
{"hadithnumber": "3246", "text": "محمد بن بکر نے ہمیں حدیث بیان کی  ( کہا  )  ہمیں ابن جریج نے خبر دی انھوں نے کہا  :  میں نے عبد اللہ"}
{"hadithnumber": "3247", "text": "ابو عاصم اور عبد الرزاق دونوں نے ابن جریج سے اسی سند کے ساتھ  ( محمد  )  بن بکر کی حدیث کے مانند حدی"}
{"hadithnumber": "3248", "text": "ابو قزعہ سے روایت ہے کہ عبد الملک بن مروان جب بیت اللہ کا طواف کر رہا تھا تو اس نے کہا  : اللہ ابن ز"}
{"hadithnumber": "3249", "text": "ابو حوص نے ہمیں حدیث بیان کی  ( کہا )  ہمیں اشعت بن ابو شعثاء نے اسود بن یزید سے حدیث بیان کی انھوں"}
{"hadithnumber": "3250", "text": "شیبان نے ہمیں اشعت بن ابو شعثاء سے حدیث بیان کی انھوں نے اسود بن یزید سے اور انھوں نے حضرت عائشہ رضی"}
{"hadithnumber": "3251", "text": "امام مالکؒ نے ابن شہاب سے انھوں نے سلیمان بن یسار سے اور انھوں نے عبد اللہ بن عباس رضی اللہ تعالیٰ ع"}
{"hadithnumber": "3252", "text": "3252ابن جریج نے سابقہ سند کے ساتھ ابن عباس رضی اللہ تعالیٰ عنہ  سے اور انھوں نے فضل  رضی اللہ تعالیٰ"}
{"hadithnumber": "3253", "text": "ابو بکر بن ابی شیبہ نے کہا  : سفیان بن عیینہ نے ہمیں ابرا ہیم بن عقبہ سے حدیث بیان کی انھوں نے ابن ع"}
{"hadithnumber": "3254", "text": "ابو اسامہ نے سفیان سے باقی ماندہ سابقہ سند کے ساتھ حضرت ابن عبا س رضی اللہ تعالیٰ عنہ  سے روایت کی ا"}
{"hadithnumber": "3255", "text": "عبد الرحمٰن نے سفیان سے انھوں نے ابرا ہیم بن عقبہ سے اور انھوں نے کریب سے روایت کی کہ  :  ایک عورت ن"}
{"hadithnumber": "3256", "text": "ہم سے محمد بن مثنیٰ نے روایت کی کہا ہمیں عبد الرحمٰن نے باقی ماندہ سابقہ سند کے ساتھ ابن عباس رضی ال"}
{"hadithnumber": "3257", "text": "حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت ہے انھوں نے کہا رسول اللہ  صلی اللہ علیہ وسلم  نے ہمیں"}
{"hadithnumber": "3258", "text": "یحییٰ قطان نے ہمیں عبید اللہ سے حدیث بیان کی  ( کہا )  مجھے نا فع نے ابن عمر  رضی اللہ تعالیٰ عنہ  س"}
{"hadithnumber": "3259", "text": "ابو بکر بن ابی شیبہ نے ہمیں حدیث بیان کی کہا  :  ہم سے عبد اللہ ابن نمیر اور ابو اسامہ نے حدیث بیان"}
{"hadithnumber": "3260", "text": "ابن ‌عمر ‌رضی ‌اللہ ‌عنہ ‌سے ‌روایت ‌ہے ‌كہ ‌رسول ‌اللہ ‌صلی ‌اللہ ‌علیہ ‌وسلم ‌نے ‌فرمایا ‌حلال ‌نہ"}
{"hadithnumber": "3261", "text": "قزعہ ‌نے ‌كہا ‌میں ‌نے ‌ابو ‌سعید ‌سے ‌ایك ‌حدیث ‌سنی ‌جو ‌مجھے ‌بہت ‌پسند ‌آئی ‌اور ‌میں ‌نے ‌ان ‌س"}
{"hadithnumber": "3263", "text": "سہم بن منجاب نے قزعہ سے انھوں نے  ابو سعیدخدری  ‌رضی ‌اللہ ‌عنہ ‌ ‌ سے  روایت کی  ،  انھوں نے کہا  :"}
{"hadithnumber": "3264", "text": "معاذ عنبری نے قتادہ سے حدیث بیان کی انھوں نے قزعہ اور انھوں نے ابو سعید خدری رضی اللہ تعالیٰ عنہ  سے"}
{"hadithnumber": "3265", "text": "سعید نے قتادہ سے اسی سند کے ساتھ روایت کی اور کہا  :  تین  ( دن )  سے زیادہ کا سفر مگر یہ کہ محرم کے"}
{"hadithnumber": "3266", "text": "لیث نے ہمیں سعید بن ابی سعید سے حدیث بیان کی انھوں نے اپنے والد سے روایت کی حضرت ابو ہریرہ رضی اللہ"}
{"hadithnumber": "3267", "text": "ابن ابی ذئب سے روایت ہے  ( کہا )  ہمیں سعید ابن ابی سعید نے اپنے والد سے حدیث بیان کی انھوں نے حضرت"}
{"hadithnumber": "3268", "text": "امام مالک نے سعید بن ابی سعید مقبری سے انھوں نے اپنے والد سے اور انھوں نے حضرت ابو ہریرہ رضی اللہ تع"}
{"hadithnumber": "3269", "text": "ابو صالح نے اپنے والد سے انھوں نے ابو ہریرہ  رضی اللہ تعالیٰ عنہ  سے روایت کی انھوں نے کہا : رسول ال"}
{"hadithnumber": "3270", "text": "ابو معاویہ نے ہمیں اعمش سے حدیث بیان کی انھوں نے ابو صالح سے انھوں نے ابو سعید خدری رضی اللہ تعالیٰ"}
{"hadithnumber": "3271", "text": "وکیع نے اعمش سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی  ۔"}
{"hadithnumber": "3272", "text": "سفیان بن عیینہ نے ہمیں حدیث بیان کی  ( کہا )  ہمیں عمرو بن دینا ر نے ابو معبد سے حدیث بیان کی  ( کہا"}
{"hadithnumber": "3273", "text": "حماد نے ہمیں عمرو  (  بن دینا ر  )  سے اسی سند کے ساتھ اسی کے ہم معنی حدیث بیان کی  ۔"}
{"hadithnumber": "3274", "text": "ابن جریج نے  (  عمر و بن دینار سے )  اسی سند کے ساتھ اسی کے معنی روایت بیان کی اور یہ  ( جملہ  )  ذک"}
{"hadithnumber": "3275", "text": "سیدنا علی ازدی رضی اللہ عنہ سے روایت ہے کہ سیدنا ابن عمر رضی اللہ عنہما نے انہیں سکھایا کہ رسول اللہ"}
{"hadithnumber": "3276", "text": "اسماعیل بن علیہ نے ہمیں عاصم احول سے حدیث بیان کی ، انھوں نے عبداللہ بن سرجس سے روایت کی  ، انھوں نے"}
{"hadithnumber": "3277", "text": "ابومعاویہ ( محمد بن خازم )  اور عبدالواحد دونوں نے عاصم سے اسی سند کے ساتھ اسی کے مانند روایت بیان ک"}
{"hadithnumber": "3278", "text": "عبیداللہ نے نافع سے ، انھوں نے عبداللہ بن عمر  رضی اللہ تعالیٰ عنہ  سے  روایت کی ، انھوں نےکہا : رسو"}
{"hadithnumber": "3279", "text": "ایوب ، مالک اورضحاک سب نے نافع سے ، انھوں نے ابن عمر رضی اللہ تعالیٰ عنہ  سے اور انھوں نے نبی کریم ص"}
{"hadithnumber": "3280", "text": "اسماعیل بن علیہ نے ہمیں یحییٰ بن ابی اسحاق سے حدیث بیان کی  ، انھوں نے کیا : حضرت  انس بن مالک  رضی"}
{"hadithnumber": "3281", "text": "بشر بن مفضل نے ہمیں حدیث بیان کی ،  ( کہا :  )  ہمیں یحییٰ بن ابی اسحاق نے حضرت انس بن مالک  رضی الل"}
{"hadithnumber": "3282", "text": "امام مالک ؒ نے نافع سے ، انھوں نے عبداللہ بن عمر رضی اللہ تعالیٰ عنہ  سے روایت کی کہ رسول اللہ  صلی"}
{"hadithnumber": "3283", "text": "لیث نے ہمیں نافع سے حدیث بیان کی ، انھوں نےکہا : حضرت ابن عمر  رضی اللہ تعالیٰ عنہ  اس ر یتلی پتھریل"}
{"hadithnumber": "3284", "text": "انس ( بن عیاض )   ، یعنی ابوضمرہ نے موسیٰ بن عقبہ سے حدیث بیان کی ، انھوں نے نافع سے روایت کی کہ ابن"}
{"hadithnumber": "3285", "text": "حاتم ، یعنی ابن اسماعیل نے ہمیں موسیٰ بن عقبہ سے حدیث بیان کی ، انھوں نے سالم سے  ، انھوں نے اپنے وا"}
{"hadithnumber": "3286", "text": "اسماعیل بن جعفر نے ہمیں حدیث بیان کی ،  ( کہا :  )  ہمیں موسیٰ عقبہ نے سالم بن عبداللہ بن عمر رضی ال"}
{"hadithnumber": "3287", "text": "عمرو (  بن حارث )  نے ابن شہاب سے  ، انھوں نے حمید بن عبدالرحمان  ( بن عوف )  سے خبردی ، انھوں نے حض"}
