hadiths[count]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}:
1670,حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ، حَدَّثَنَا الْمُعْتَمِرُ بْنُ سُلَيْمَانَ، عَنْ أَبِي,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: صحیح البخاری/الجہاد ۳۱ (۲۸۳۱)، وتفسیر سورة النساء ۱۸ (۴۵۹۳)، وفضائل القرآن ۴ (۴۹۹۰)، صحیح مسلم/الإمارة ۴۰ (۱۸۹۸)، سنن النسائی/الجہاد ۴ (۳۱۰۳)، (تحفة الأشراف : ۱۸۵۹)، و مسند احمد (۴/۲۸۳، ۲۹۰، ۳۳۰)، سنن الدارمی/الجہاد ۲۸ (۲۴۶۴),1670,,The Book on Jihad
1671,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، عَنْ سُفْيَانَ، وَشُعْبَةَ، عَن,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الجہاد ۱۳۸ (۳۰۰۴)، والأدب ۳ (۵۹۷۲)، صحیح مسلم/البر والصلة ۱ (۲۵۴۹)، سنن ابی داود/ الجہاد ۳۳ (۲۵۲۹)، سنن النسائی/الجہاد ۵ (۳۱۰۵)، (تحفة الأشراف : ۸۶۳۴)، و مسند احمد (۲/۱۶۵، ۱۷۲، ۱۸۸، ۱۹۳، ۱۹۷، ۲۲۱),1671,,The Book on Jihad
1672,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى النَّيْسَابُورِيُّ، حَدَّثَنَا الْحَجَّاجُ بْنُ مُحَمَّدٍ، حَدَّثَ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/تفسیر سورة النساء ۱۱ (۴۵۸۴)، صحیح مسلم/الإمارة ۸ (۱۸۳۴)، سنن ابی داود/ الجہاد ۹۶ (۲۶۲۴)، سنن النسائی/البیعة ۲۸ (۴۲۰۵)، (تحفة الأشراف : ۵۶۵۱),1672,,The Book on Jihad
1673,حَدَّثَنَا أَحْمَدُ بْنُ عَبْدَةَ الضَّبِّيُّ الْبَصْرِيُّ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: تخریج دارالدعوہ: صحیح البخاری/الجہاد ۱۳ (۲۹۹۸)، سنن ابن ماجہ/الأدب ۴۵ (۳۷۳۸)، (تحفة الأشراف : ۷۴۱۹),1673,,The Book on Jihad
1674,حَدَّثَنَا إِسْحَاق بْنُ مُوسَى الْأَنْصَارِيُّ، حَدَّثَنَا مَعْنٌ، حَدَّثَنَا مَالِكٌ، عَنْ عَبْدِ,Ahmad Muhammad Shakir: Hasan; Al-Albani: Hasan; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الجہاد ۸۶ (۲۶۰۷)، (تحفة الأشراف : ۸۷۴۰)، وط/الاستئذان ۱۴ (۳۵)، و مسند احمد (۲/۱۸۶، ۲۱۴),1674,,The Book on Jihad
1675,حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، وَنَصْرُ بْنُ عَلِيٍّ، قَالَا:‏‏‏‏ حَدَّثَنَا سُفْيَانُ بْنُ عُيَي,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الجہاد ۱۵۷ (۳۰۳۰)، صحیح مسلم/الجہاد ۵ (۱۷۴۰)، سنن ابی داود/ الجہاد ۱۰۱ (۲۶۳۶)، (تحفة الأشراف : ۲۵۲۳),1675,,The Book on Jihad
1676,حَدَّثَنَا حَدَّثَنَا مَحْمُودُ بْنُ غَيْلَانَ، حَدَّثَنَا وَهْبُ بْنُ جَرِيرٍ، وَأَبُو دَاوُدَ الطّ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/المغازي ۱ (۳۹۴۹)، و ۷۷ (۴۴۰۴)، و ۸۹ (۴۴۷۱)، صحیح مسلم/الحج ۳۵ (۱۲۵۴)، والجہاد ۴۹ (۱۲۵۴/۱۴۳)، (تحفة الأشراف : ۳۶۷۹),1676,,The Book on Jihad
1677,حَدَّثَنَا حَدَّثَنَا مُحَمَّدُ بْنُ حُمَيْدٍ الرَّازِيُّ، حَدَّثَنَا سَلَمَةُ بْنُ الْفَضْلِ، عَنْ,Ahmad Muhammad Shakir: Daif Isnaad; Al-Albani: Daif Isnaad; Bashar Awad Maarouf: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۹۷۲۴),1677,,The Book on Jihad
1678,حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، أَنْبَأَنَا إِسْمَاعِيل بْنُ أَب,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الجہاد ۹۸ (۲۹۳۳)، و ۱۱۲ (۲۹۶۵)، و ۱۵۶ (۳۰۲۵)، والمغازي ۲۹ (۴۱۱۵)، والدعوات ۵۸ (۶۳۹۲)، والتوحید ۳۴ (۷۴۸۹)، صحیح مسلم/الجہاد ۶ ۷۰ (۱۷۴۲)، سنن ابی داود/ الجہاد ۹۸ (۲۶۳۱)، سنن النسائی/عمل الیوم و اللیلة (۶۰۲)، سنن ابن ماجہ/الجہاد ۱۵ (۲۷۹۶)، (تحفة الأشراف : ۵۱۵۴)، و مسند احمد (۴/۳۵۴),1678,,The Book on Jihad
1679,حَدَّثَنَا حَدَّثَنَا مُحَمَّدُ بْنُ عُمَرَ بْنِ الْوَلِيدِ الْكِنْدِيُّ الْكُوفِيُّ، وَأَبُو كُرَيْ,Ahmad Muhammad Shakir: Hasan; Al-Albani: Hasan; Zubair Ali Zai: Hasan,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الجہاد ۷۶ (۲۵۹۲)، سنن النسائی/الحج ۱۰۶ (۲۸۶۹)، سنن ابن ماجہ/الجہاد ۲۰ (۲۸۱۷) (تحفة الأشراف : ۲۸۸۹),1679,,The Book on Jihad
1680,حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا يَحْيَى بْنُ زَكَرِيَّا بْنِ أَبِي زَائِدَةَ، حَدَّثَنَ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan; Zubair Ali Zai: Hasan,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الجہاد ۷۶ (۲۵۹۱)، (تحفة الأشراف : ۱۹۲۲),1680,,The Book on Jihad
1681,حَدَّثَنَا مُحَمَّدُ بْنُ رَافِعٍ، حَدَّثَنَا يَحْيَى بْنُ إِسْحَاق وَهُوَ السَّالِحَانِيُّ، حَدَّثَ,Ahmad Muhammad Shakir: Hasan; Al-Albani: Hasan; Zubair Ali Zai: Hasan,takhreej: تخریج دارالدعوہ: سنن ابن ماجہ/الجہاد ۲۰ (۲۸۱۸)، (تحفة الأشراف : ۶۵۴۲),1681,,The Book on Jihad
1682,حَدَّثَنَا مَحْمُودُ بْنُ غَيْلَانَ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا سُفْيَانُ، عَنْ أَبِي إِسْحَاق،,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الجہاد ۷۸ (۲۵۹۷)، (تحفة الأشراف : ۱۵۶۷۹)، و مسند احمد (۴/۲۸۹),1682,,The Book on Jihad
1683,حَدَّثَنَا مُحَمَّدُ بْنُ شُجَاعٍ الْبَغْدَادِيُّ، حَدَّثَنَا أَبُو عُبَيْدَةَ الْحَدَّادُ، عَنْ عُث,Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Bashar Awad Maarouf: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۴۶۳۲),1683,,The Book on Jihad
1684,حَدَّثَنَا أَحْمَدُ بْنُ مُحَمَّدِ بْنِ مُوسَى، أَنْبَأَنَا عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ، أَنْبَ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف، (تحفة الأشراف : ۴۲۸۴),1684,,The Book on Jihad
1685,حَدَّثَنَا مَحْمُودُ بْنُ غَيْلَانَ، حَدَّثَنَا أَبُو دَاوُدَ الطَّيَالِسِيُّ، قَالَ:‏‏‏‏ أَنْبَأَنَ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الہبة ۳۳ (۲۶۲۷)، والجہاد ۵۵ (۲۸۶۷)، صحیح مسلم/الفضائل ۱۱ (۲۳۰۷/۴۹)، سنن ابی داود/ الأدب ۸۷ (۴۹۸۸)، (تحفة الأشراف : ۱۲۳۸),1685,,The Book on Jihad
1686,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، وَابْنُ أَبِي عَدِيٍّ، وأبو,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: انظر ما قبلہ,1686,,The Book on Jihad
1687,حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ، عَنْ ثَابِتٍ، عَنْ أَنَسٍ، قَالَ:‏‏‏‏ كَانَ,Ahmad Muhammad Shakir: Sahih; Bashar Awad Maarouf: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الجہاد ۴ ۲ (۲۸۲۰)، و۸۲ (۲۹۰۸)، و ۱۶۵ (۳۰۴۰)، والأدب ۳۹ (۶۰۳۳)، صحیح مسلم/الفضائل ۱۱ (۲۳۰۷/۴۸)، سنن ابن ماجہ/الجہاد ۹ (۲۷۷۲)، (تحفة الأشراف : ۲۸۹)، (وانظر ما تقدم برقم ۱۶۸۵),1687,,The Book on Jihad
1688,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، حَدَّثَنَا سُفْيَانُ الثَّوْرِي,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الجہاد ۶۱ (۲۸۸۴)، و۹۷ (۲۹۳۰)، والمغازي ۵۴ (۴۳۱۵-۴۳۱۷)، صحیح مسلم/الجہاد ۲۸ (۱۷۷۶)، (تحفة الأشراف : ۱۸۴۸)، و مسند احمد (۴/۲۸۹),1688,,The Book on Jihad
1689,حَدَّثَنَا مُحَمَّدُ بْنُ عُمَرَ بْنِ عَلِيٍّ الْمُقَدَّمِيُّ الْبَصْرِيُّ، حَدَّثَنِي أَبِي، عَنْ س,Ahmad Muhammad Shakir: Sahih Isnaad; Al-Albani: Sahih Isnaad; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۷۸۹۴),1689,,The Book on Jihad
1690,حَدَّثَنَا مُحَمَّدُ بْنُ صُدْرَانَ أَبُو جَعْفَرٍ الْبَصْرِيُّ، حَدَّثَنَا طَالِبُ بْنُ حُجَيْرٍ، ع,Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف، وانظر ما یأتي (تحفة الأشراف : ۱۱۲۵۴),1690,,The Book on Jihad
1691,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا وَهْبُ بْنُ جَرِيرِ بْنِ حَازِمٍ، حَدَّثَنَا أَبِي، ع,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الجہاد ۷۱ (۲۵۸۳، ۲۵۸۴)، سنن النسائی/الزینة ۱۲۰ (۵۳۸۶)، (تحفة الأشراف : ۱۱۴۶)، سنن الدارمی/السیر ۲۱ (۲۵۰۱),1691,,The Book on Jihad
1692,حَدَّثَنَا أَبُو سَعِيدٍ الْأَشَجُّ، حَدَّثَنَا يُونُسُ بْنُ بُكَيْرٍ، عَنْ مُحَمَّدِ بْنِ إِسْحَاق،,Ahmad Muhammad Shakir: Hasan; Al-Albani: Hasan; Bashar Awad Maarouf: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف وأعادہ في المناقب برقم ۳۷۳۸ (تحفة الأشراف : ۳۶۲۸),1692,,The Book on Jihad
1693,حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، عَنْ ابْنِ شِهَابٍ، عَنْ أَنَسِ بْنِ مَالِكٍ،,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/جزاء الصید ۱۸ (۱۸۴۶)، والجہاد ۱۶۹ (۳۰۴۴)، والمغازي ۴۸ (۴۲۸۶)، واللباس ۱۷ (۵۸۰۸)، صحیح مسلم/الحج ۸۴ (۱۳۵۷)، سنن ابی داود/ الجہاد ۱۲۷ (۲۶۸۵)، سنن النسائی/الحج ۱۰۷ (۲۷۸۰)، سنن ابن ماجہ/الجہاد ۱۸ (۱۸۰۵)، (تحفة الأشراف : ۱۵۲۷)، وط/الحج ۸۱ (۲۴۷)، و مسند احمد (۳/۱۰۹، ۱۶۴، ۱۸۰، ۱۸۶، ۲۲۴، ۲۳۱، ۲۳۲، ۲۴۰) سنن الدارمی/المناسک ۸۸ (۱۹۸۱),1693,,The Book on Jihad
1694,حَدَّثَنَا هَنَّادٌ، حَدَّثَنَا عَبْثَرُ بْنُ الْقَاسِمِ، عَنْ حُصَيْنٍ، عَنْ الشَّعْبِيِّ، عَنْ عُر,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: تخریج دارالدعوہ: صحیح البخاری/الجہاد ۴۳ (۲۷۵۰)، و۴۴ (۲۷۵۲)، والخمس ۸ (۳۱۱۹)، والمناقب ۲۸ (۳۶۴۳)، صحیح مسلم/الإمارة ۲۶ (۱۸۷۳)، سنن النسائی/الخیل ۷ (۴۶۰۴، ۳۶۰۵)، سنن ابن ماجہ/التجارات ۶۹ (۲۳۰۵)، والجہاد ۱۴ (۲۷۸۶)، (تحفة الأشراف : ۹۸۹۷)، و مسند احمد (۴/۳۷۵، ۳۷۶)، سنن الدارمی/الجہاد ۲۴ (۳۱۱۹),1694,,The Book on Jihad
1695,حَدَّثَنَا عَبْدُ اللَّهِ بْنُ الصَّبَّاحِ الْهَاشِمِيُّ الْبَصْرِيُّ، ‏‏‏‏‏‏حَدَّثَنَا يَزِيدُ بْنُ,Ahmad Muhammad Shakir: Hasan Sahih; Al-Albani: Hasan Sahih; Bashar Awad Maarouf: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الجہاد ۴۴ (۲۵۴۵)، (تحفة الأشراف : ۶۲۹۰)، و مسند احمد (۱/۲۷۲),1695,,The Book on Jihad
1696,حَدَّثَنَا أَحْمَدُ بْنُ مُحَمَّدٍ، أَخْبَرَنَا عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ، أَخْبَرَنَا ابْنُ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Hasan,takhreej: تخریج دارالدعوہ: سنن ابن ماجہ/الجہاد ۱۴ (۲۷۸۹)، (تحفة الأشراف : ۱۲۱۲۱)، و مسند احمد (۵/۳۰۰),1696,,The Book on Jihad
1697,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا وَهْبُ بْنُ جَرِيرٍ، حَدَّثَنَا أَبِي، عَنْ يَحْيَى ب,Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: تخریج دارالدعوہ: انظر ما قبلہ,1697,,The Book on Jihad
1698,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، حَدَّثَنَا سُفْيَانُ، قَالَ:‏‏‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/الإمارة ۲۷ (۱۸۷۵)، سنن ابی داود/ الجہاد ۴۶ (۲۵۴۷)، سنن النسائی/الخیل ۴ (۳۵۹۶)، سنن ابن ماجہ/الجہاد ۱۴ (۲۷۹۰)، (تحفة الأشراف : ۱۴۸۹۰)، و مسند احمد (۲/۲۵۰، ۴۳۶، ۴۶۱، ۴۷۶),1698,,The Book on Jihad
1699,حَدَّثَنَا مُحَمَّدُ بْنُ وَزِيرٍ الْوَاسِطِيُّ، حَدَّثَنَا إِسْحَاق بْنُ يُوسُفَ الْأَزْرَقُ، عَنْ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الجہاد ۵۶ (۲۸۶۸)، و۵۷ (۲۸۶۹)، و ۵۸ (۲۸۷۰)، والاعتصام ۶ (۷۳۳۶)، صحیح مسلم/الإمارة ۲۵ (۱۸۷۰)، سنن ابی داود/ الجہاد ۶۷ (۲۵۷۵)، سنن النسائی/الخیل ۱۲ (۳۶۱۳)، و ۱۳ (۳۶۱۴)، سنن ابن ماجہ/الجہاد ۴۴ (۲۸۷۷)، (تحفة الأشراف : ۷۸۹۵)، وط/الجہاد ۱۹ (۴۵)، و مسند احمد (۲/۵، ۵۵-۵۶) سنن الدارمی/الجہاد ۳۶ (۲۴۷۳),1699,,The Book on Jihad
1700,حَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا وَكِيعٌ، عَنْ ابْنِ أَبِي ذِئْبٍ، عَنْ نَافِعِ بْنِ أَبِي نَاف,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الجہاد ۶۷ (۲۵۷۴)، سنن النسائی/الخیل ۱۴ (۳۶۱۵، ۳۶۱۶، ۳۶۱۹)، سنن ابن ماجہ/الجہاد ۴۴ (۲۸۷۸)، (تحفة الأشراف : ۱۴۶۳۸)، و مسند احمد (۲/۲۵۶، ۳۵۸، ۴۲۵، ۴۷۴),1700,,The Book on Jihad
1701,حَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا إِسْمَاعِيل بْنُ إِبْرَاهِيمَ، حَدَّثَنَا أَبُو جَهْضَمٍ مُوسَ,Ahmad Muhammad Shakir: Sahih Isnaad; Al-Albani: Sahih Isnaad; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الصلاة ۱۳۱ (۸۰۸)، سنن النسائی/الطہارة ۱۰۶ (۱۴۱)، والخیل ۱۰ (۳۶۱۱)، سنن ابن ماجہ/الطہارة ۴۹ (۴۲۶)، (تحفة الأشراف : ۵۷۹۱)، و مسند احمد (۱/۲۲۵، ۲۳۵، ۲۴۹),1701,,The Book on Jihad
1702,حَدَّثَنَا أَحْمَدُ بْنُ مُحَمَّدِ بْنِ مُوسَى، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ، قَالَ:‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الجہاد ۷۷ (۲۵۹۴)، سنن النسائی/الجہاد ۴۳ (۳۱۸۱)، (تحفة الأشراف : ۱۰۹۲۳)، و مسند احمد (۵/۱۹۸),1702,,The Book on Jihad
1703,حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ، عَنْ سُهَيْلِ بْنِ أَبِي صَالِحٍ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/اللباس ۲۷ (۲۱۱۳)، سنن ابی داود/ الجہاد ۵۱ (۲۵۵)، (تحفة الأشراف : ۱۲۷۰۳)، و مسند احمد (۲/۲۶۳، ۳۱۱، ۳۲۷، ۳۴۳، ۳۸۵، ۳۹۲، ۴۱۴، ۴۴۴، ۴۷۶)، سنن الدارمی/الاستئذان ۴۴ (۲۷۱۸),1703,,The Book on Jihad
1704,حَدَّثَنَا عَبْدُ اللَّهِ بْنُ أَبِي زِيَادٍ، حَدَّثَنَا الْأَحْوَصُ بْنُ الْجَوَّابِ أَبُو الْجَوَّ,Ahmad Muhammad Shakir: Daif Isnaad; Al-Albani: Daif Isnaad; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف واعادہ في المناقب برقم ۳۷۲۵، (تحفة الأشراف : ۱۹۰۱),1704,,The Book on Jihad
1705,حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا اللَّيْثُ، عَنْ نَافِعٍ، عَنْ ابْنِ عُمَرَ، عَنِ النَّبِيِّ صَلَّى,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih,takhreej: تخریج دارالدعوہ: صحیح البخاری/الجمعة ۱۱ (۸۹۳)، والاستقراض ۲۰ (۲۴۰۹)، والعتق ۱۷ (۲۵۵۴)، والوصایا ۹ (۲۷۵۱)، والنکاح ۸۱ (۵۲۰۰)، والأحکام ۱ (۷۱۳۸)، صحیح مسلم/الإمارة ۵ (۱۸۲۹)، سنن ابی داود/ الخراج ۱ (۲۹۲۸)، (تحفة الأشراف : ۲۹۵)، و مسند احمد (۲/۵، ۴۵، ۱۱۱، ۱۲۱),1705,,The Book on Jihad
1706,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى النَّيْسَابُورِيُّ، حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ، حَدَّثَنَا,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: صحیح مسلم/الحج ۵۱ (۱۲۹۸/۳۱۱)، والإمارة (۱۸۳۸/۳۷)، (تحفة الأشراف : ۱۸۳۱۳)، و مسند احمد (۶/۴۰۲),1706,,The Book on Jihad
1707,حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا اللَّيْثُ، عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ نَافِعٍ، عَنْ ا,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: تخریج دارالدعوہ: صحیح البخاری/الجہاد ۱۰۸ (۲۹۵۵)، والأحکام ۴ (۷۱۴۴)، صحیح مسلم/الإمارة ۸ (۱۸۳۹)، سنن ابی داود/ الجہاد ۹۶ (۲۶۲۶)، سنن النسائی/البیعة ۳۴ (۴۲۱۱)، سنن ابن ماجہ/الجہاد ۴۰ (۲۸۶۴)، (تحفة الأشراف : ۸۰۸۸)، و مسند احمد (۲/۱۷، ۴۲),1707,,The Book on Jihad
1708,حَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا يَحْيَى بْنُ آدَمَ، عَنْ قُطْبَةَ بْنِ عَبْدِ الْعَزِيزِ، عَنْ,Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الجہاد ۵۶ (۲۵۶۲)، (تحفة الأشراف : ۶۴۳۱),1708,,The Book on Jihad
1709,حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، عَنْ سُفْيَانَ،,,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۱۹۲۸۰),1709,,The Book on Jihad
1710,حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا رَوْحُ بْنُ عُبَادَةَ، عَنْ ابْنِ جُرَيْجٍ، عَنْ أَبِي,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/اللباس ۲۹ (۲۱۱۶)، (تحفة الأشراف : ۲۸۱۶)، و مسند احمد (۳/۳۱۸، ۳۷۸),1710,,The Book on Jihad
1711,حَدَّثَنَا مُحَمَّدُ بْنُ الْوَزِيرِ الْوَاسِطِيُّ، حَدَّثَنَا إِسْحَاق بْنُ يُوسُفَ الْأَزْرَقُ، عَ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih,takhreej: تخریج دارالدعوہ: انظر حدیث رقم ۱۳۶۱,1711,,The Book on Jihad
1712,حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا اللَّيْثُ، عَنْ سَعِيدِ بْنِ أَبِي سَعِيدٍ الْمَقْبُرِيِّ، عَنْ عَ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/الإمارة ۳۲ (۱۸۸۵)، (تحفة الأشراف : ۱۲۰۹۸)، وط/الجہاد ۱۴ (۳۱)، و مسند احمد (۵/۲۹۷، ۳۰۴، ۳۰۸)، سنن الدارمی/الجہاد ۲۱ (۲۴۵۶),1712,,The Book on Jihad
1713,حَدَّثَنَا أَزْهَرُ بْنُ مَرْوَانَ الْبَصْرِيُّ، حَدَّثَنَا عَبْدُ الْوَارِثِ بْنُ سَعِيدٍ، عَنْ أَي,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الجنائز ۱ ۷ (۳۲۱۵)، سنن النسائی/الجنائز ۸۶ (۲۰۱۲)، و ۹۰ (۲۰۱۷)، و ۹۱ (۲۰۲۰)، سنن ابن ماجہ/الجنائز ۴۱ (۱۵۶۰)، (تحفة الأشراف : ۱۱۷۳۱)، و مسند احمد (۴/۱۹، ۲۰),1713,,The Book on Jihad
1714,حَدَّثَنَا هَنَّادٌ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، عَنْ الْأَعْمَشِ، عَنْ عَمْرِو بْنِ مُرَّةَ، عَنْ,Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف وأعادہ في تفسیر الأنفال (۳۰۸۴)، (تحفة الأشراف : ۹۶۲۸),1714,,The Book on Jihad
1715,حَدَّثَنَا مَحْمُودُ بْنُ غَيْلَانَ، حَدَّثَنَا أَبُو أَحْمَدَ، حَدَّثَنَا سُفْيَانُ، عَنْ ابْنِ أَب,Ahmad Muhammad Shakir: Daif Isnaad; Al-Albani: Daif Isnaad; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف، (تحفة الأشراف : ۶۴۷۵),1715,,The Book on Jihad
1716,حَدَّثَنَا ابْنُ أَبِي عُمَرَ، حَدَّثَنَا سُفْيَانُ، عَنْ يَزِيدَ بْنِ أَبِي زِيَادٍ، عَنْ عَبْدِ ال,Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الجہاد ۱۰۶ (۲۶۴۷)، (تحفة الأشراف : ۷۲۹۸),1716,,The Book on Jihad
1717,حَدَّثَنَا مَحْمُودُ بْنُ غَيْلَانَ، حَدَّثَنَا أَبُو دَاوُدَ، أَخْبَرَنَا شُعْبَةُ، عَنْ الْأَسْوَد,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الجنائز ۴۲ (۳۱۶۵)، سنن النسائی/الجنائز ۸۳ (۲۰۰۶)، سنن ابن ماجہ/الجنائز ۲۸ (۱۵۱۶)، (تحفة الأشراف : ۳۱۱۷)، سنن الدارمی/المقدمة ۷ (۴۶),1717,,The Book on Jihad
1718,حَدَّثَنَا حَدَّثَنَا ابْنُ أَبِي عُمَرَ، وَسَعِيدُ بْنُ عَبْدِ الرَّحْمَنِ الْمَخْزُومِيُّ، قَالَا:,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: صحیح البخاری/الجہاد ۱۹۶ (۳۰۸۲)، والمغازي ۸۲ (۴۴۲۶)، سنن ابی داود/ الجہاد ۱۷۶ (۲۷۷۹)، (تحفة الأشراف : ۳۸۰۰),1718,,The Book on Jihad
1719,"حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ، حَدَّثَنَا الْمُعْتَمِرُ بْنُ سُلَيْمَانَ، عَنْ أَبِيهِ، عَنْ أَبِي إِسْحَاقَ، عَنِ الْبَرَاءِ بْنِ عَازِبٍ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏""‏ ائْتُونِي بِالْكَتِفِ أَوِ اللَّوْحِ ‏""‏ ‏.‏ فَكَتَبَ ‏:‏ ‏(‏ لاَ يَسْتَوِي الْقَاعِدُونَ مِنَ الْمُؤْمِنِينَ ‏)‏ وَعَمْرُو بْنُ أُمِّ مَكْتُومٍ خَلْفَ ظَهْرِهِ فَقَالَ هَلْ لِي مِنْ رُخْصَةٍ فَنَزَلَتْ ‏:‏ ‏(‏ غَيْرُ أُولِي الضَّرَرِ ‏)‏ ‏.‏ وَفِي الْبَابِ عَنِ ابْنِ عَبَّاسٍ وَجَابِرٍ وَزَيْدِ بْنِ ثَابِتٍ ‏.‏ وَهَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ وَهُوَ حَدِيثٌ غَرِيبٌ مِنْ حَدِيثِ سُلَيْمَانَ التَّيْمِيِّ عَنْ أَبِي إِسْحَاقَ ‏.‏ وَقَدْ رَوَى شُعْبَةُ وَالثَّوْرِيُّ عَنْ أَبِي إِسْحَاقَ هَذَا الْحَدِيثَ ‏.",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الجہاد ۸۰ (۲۹۰۴)، وتفسیر الحشر ۳ (۴۸۸۵)، صحیح مسلم/الجہاد ۱۵ (۱۷۵۷)، سنن ابی داود/ الخراج والإمارة ۱۹ (۲۹۶۵)، (تحفة الأشراف : ۱۰۶۳۱)، و مسند احمد (۱/۲۵) (وانظر أیضا حدیث رقم ۱۶۱۰),1719,Narrated Al-Bara' bin 'Azib:,The Book on Jihad
1720,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، عَنْ سُفْيَانَ، وَشُعْبَةَ، عَنْ حَبِيبِ بْنِ أَبِي ثَابِتٍ، عَنْ أَبِي الْعَبَّاسِ، عَنْ عَبْدِ اللَّهِ بْنِ عَمْرٍو، قَالَ جَاءَ رَجُلٌ إِلَى النَّبِيِّ صلى الله عليه وسلم يَسْتَأْذِنُهُ فِي الْجِهَادِ فَقَالَ ‏""‏ أَلَكَ وَالِدَانِ ‏""‏ ‏.‏ قَالَ نَعَمْ ‏.‏ قَالَ ‏""‏ فَفِيهِمَا فَجَاهِدْ ‏""‏ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنِ ابْنِ عَبَّاسٍ ‏.‏ وَهَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَأَبُو الْعَبَّاسِ هُوَ الشَّاعِرُ الأَعْمَى الْمَكِّيُّ وَاسْمُهُ السَّائِبُ بْنُ فَرُّوخَ ‏.‏",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: سنن النسائی/الزینة ۴۰ (۵۱۵۱)، و۷۴ (۵۲۶۷)، (تحفة الأشراف : ۸۹۹۸)، و مسند احمد (۴/۳۹۲، ۳۹۳، ۴۰۷),1720,Narrated 'Abdullah bin 'Umar:,The Book on Jihad
1721,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى النَّيْسَابُورِيُّ، حَدَّثَنَا الْحَجَّاجُ بْنُ مُحَمَّدٍ، حَدَّثَنَا ابْنُ جُرَيْجٍ، فِي قَوْلِهِِ ‏:‏ ‏(‏أطِيعُوا اللَّهَ وَأَطِيعُوا الرَّسُولَ وَأُولِي الأَمْرِ مِنْكُمْ ‏)‏ قَالَ عَبْدُ اللَّهِ بْنُ حُذَافَةَ بْنِ قَيْسِ بْنِ عَدِيٍّ السَّهْمِيُّ بَعَثَهُ رَسُولُ اللَّهِ صلى الله عليه وسلم عَلَى سَرِيَّةٍ ‏.‏ أَخْبَرَنِيهِ يَعْلَى بْنُ مُسْلِمٍ عَنْ سَعِيدِ بْنِ جُبَيْرٍ عَنِ ابْنِ عَبَّاسٍ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ غَرِيبٌ لاَ نَعْرِفُهُ إِلاَّ مِنْ حَدِيثِ ابْنِ جُرَيْجٍ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/اللباس ۲ (۲۰۶۹/۱۵)، (تحفة الأشراف : ۱۰۴۵۹),1721,Narrated Al-Hajjaj bin Muhammad:,The Book on Jihad
1722,"حَدَّثَنَا أَحْمَدُ بْنُ عَبْدَةَ الضَّبِّيُّ الْبَصْرِيُّ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عَاصِمِ بْنِ مُحَمَّدٍ، عَنْ أَبِيهِ، عَنِ ابْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ لَوْ أَنَّ النَّاسَ يَعْلَمُونَ مَا أَعْلَمُ مِنَ الْوَحْدَةِ مَا سَرَى رَاكِبٌ بِلَيْلٍ ‏""""‏ ‏.‏ يَعْنِي وَحْدَهُ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الجہاد ۹۰ (۲۹۱۹- ۲۹۲۲)، واللباس ۲۹ (۵۸۳۹)، صحیح مسلم/اللباس ۳ (۲۰۷۶)، سنن ابی داود/ اللباس ۱۳ (۴۰۵۶)، سنن النسائی/الزینة ۹۲ (۵۳۱۲)، سنن ابن ماجہ/اللباس ۱۷ (۳۵۹۲)، (تحفة الأشراف : ۱۳۹۴)، و مسند احمد (۳/۱۲۷، ۱۸۰، ۲۱، ۲۵۵، ۲۷۳),,Narrated Ibn 'Umar:,The Book on Jihad
1723,"حَدَّثَنَا إِسْحَاقُ بْنُ مُوسَى الأَنْصَارِيُّ، حَدَّثَنَا مَعْنٌ، حَدَّثَنَا مَالِكٌ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ حَرْمَلَةَ، عَنْ عَمْرِو بْنِ شُعَيْبٍ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ الرَّاكِبُ شَيْطَانٌ وَالرَّاكِبَانِ شَيْطَانَانِ وَالثَّلاَثَةُ رَكْبٌ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى حَدِيثُ ابْنِ عُمَرَ حَدِيثٌ حَسَنٌ صَحِيحٌ لاَ نَعْرِفُهُ إِلاَّ مِنْ هَذَا الْوَجْهِ مِنْ حَدِيثِ عَاصِمٍ وَهُوَ ابْنُ مُحَمَّدِ بْنِ زَيْدِ بْنِ عَبْدِ اللَّهِ بْنِ عُمَرَ وَحَدِيثُ عَبْدِ اللَّهِ بْنِ عَمْرٍو حَدِيثٌ حَسَنٌ ‏.‏ قَالَ مُحَمَّدٌ هُوَ ثِقَةٌ صَدُوقٌ وَعَاصِمُ بْنُ عُمَرَ الْعُمَرِيُّ ضَعِيفٌ فِي الْحَدِيثِ لاَ أَرْوِي عَنْهُ شَيْئًا ‏.‏ وَحَدِيثُ عَبْدِ اللَّهِ بْنِ عَمْرٍو حَدِيثٌ حَسَنٌ""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: تخریج دارالدعوہ: صحیح البخاری/الہبة ۲۸ (۲۶۱۵)، وبدء الخلق ۸ (۳۲۴۸)، صحیح مسلم/فضائل الصحابة ۲۴ (۲۴۶۹)، سنن النسائی/الزینة ۸۸ (۵۳۰۴)، (تحفة الأشراف : ۱۶۴۸)، و مسند احمد (۳/۱۱۱، ۱۲۱-۱۲۲، ۲۰۷، ۲۰۹، ۲۲۹، ۲۳۸، ۲۵۱، ۲۷۷),,Narrated 'Amr bin Shu'aib:,The Book on Jihad
1724,"حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، وَنَصْرُ بْنُ عَلِيٍّ، قَالاَ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عَمْرِو بْنِ دِينَارٍ، سَمِعَ جَابِرَ بْنَ عَبْدِ اللَّهِ، يَقُولُ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ الْحَرْبُ خُدْعَةٌ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ عَلِيٍّ وَزَيْدِ بْنِ ثَابِتٍ وَعَائِشَةَ وَابْنِ عَبَّاسٍ وَأَبِي هُرَيْرَةَ وَأَسْمَاءَ بِنْتِ يَزِيدَ بْنِ السَّكَنِ وَكَعْبِ بْنِ مَالِكٍ وَأَنَسِ بْنِ مَالِكٍ ‏.‏ وَهَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/المناقب ۳۳ (۳۵۵۱)، واللباس ۳۵ (۵۸۴۸)، و۶۸ (۵۹۰۳)، صحیح مسلم/الفضائل ۲۵ (۲۳۳۷)، سنن ابی داود/ الترجل ۹ (۴۱۸۳)، سنن النسائی/الزینة ۹ (۵۰۶۳)، و ۵۹ (۵۲۳۴)، و ۹۳ (۵۲۴۸)، سنن ابن ماجہ/اللباس ۲۰ (۳۵۹۹)، (تحفة الأشراف : ۱۸۴۷)، و مسند احمد (۴/۲۸۱، ۲۹۵) و یأتي برقم ۳۶۳۵,,Narrated Jabir bin ‘Abdullah :,The Book on Jihad
1725,حَدَّثَنَا مَحْمُودُ بْنُ غَيْلاَنَ، حَدَّثَنَا وَهْبُ بْنُ جَرِيرٍ، وَأَبُو دَاوُدَ الطَّيَالِسِيُّ قَالاَ حَدَّثَنَا شُعْبَةُ، عَنْ أَبِي إِسْحَاقَ، قَالَ كُنْتُ إِلَى جَنْبِ زَيْدِ بْنِ أَرْقَمَ فَقِيلَ لَهُ كَمْ غَزَا النَّبِيُّ صلى الله عليه وسلم مِنْ غَزْوَةٍ قَالَ تِسْعَ عَشْرَةَ ‏.‏ فَقُلْتُ كَمْ غَزَوْتَ أَنْتَ مَعَهُ قَالَ سَبْعَ عَشْرَةَ ‏.‏ قُلْتُ أَيَّتُهُنَّ كَانَ أَوَّلَ قَالَ ذَاتُ الْعُشَيْرَاءِ أَوِ الْعُسَيْرَاءِ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: انظر حدیث رقم ۲۶۴,1725,Narrated Abu Ishaq:,The Book on Jihad
1726,حَدَّثَنَا مُحَمَّدُ بْنُ حُمَيْدٍ الرَّازِيُّ، حَدَّثَنَا سَلَمَةُ بْنُ الْفَضْلِ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَوْفٍ، قَالَ عَبَّأَنَا النَّبِيُّ صلى الله عليه وسلم بِبَدْرٍ لَيْلاً ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ أَبِي أَيُّوبَ ‏.‏ وَهَذَا حَدِيثٌ غَرِيبٌ لاَ نَعْرِفُهُ إِلاَّ مِنْ هَذَا الْوَجْهِ ‏.‏ وَسَأَلْتُ مُحَمَّدَ بْنَ إِسْمَاعِيلَ عَنْ هَذَا الْحَدِيثِ فَلَمْ يَعْرِفْهُ وَقَالَ مُحَمَّدُ بْنُ إِسْحَاقَ سَمِعَ مِنْ عِكْرِمَةَ ‏.‏ وَحِينَ رَأَيْتُهُ كَانَ حَسَنَ الرَّأْىِ فِي مُحَمَّدِ بْنِ حُمَيْدٍ الرَّازِيِّ ثُمَّ ضَعَّفَهُ بَعْدُ ‏.‏,Ahmad Muhammad Shakir: Hasan; Al-Albani: Hasan; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: سنن ابن ماجہ/الأطعمة ۶۰ (۳۳۶۷)، (تحفة الأشراف : ۴۴۹۶),1726,Narrated 'Abdur-Rahman bin 'Awf:,The Book on Jihad
1727,"حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، أَنْبَأَنَا إِسْمَاعِيلُ بْنُ أَبِي خَالِدٍ، عَنِ ابْنِ أَبِي أَوْفَى، قَالَ سَمِعْتُهُ يَقُولُ يَعْنِي النَّبِيَّ صلى الله عليه وسلم يَدْعُو عَلَى الأَحْزَابِ فَقَالَ ‏ ‏ اللَّهُمَّ مُنْزِلَ الْكِتَابِ سَرِيعَ الْحِسَابِ اهْزِمِ الأَحْزَابَ اللَّهُمَّ اهْزِمْهُمْ وَزَلْزِلْهُمْ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنِ ابْنِ مَسْعُودٍ ‏.‏ وَهَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۵۹۶۹)، وانظر: صحیح البخاری/الزکاة ۶۱ (۱۴۹۲)، والبیوع ۱۰۱ (۲۲۲۱)، والذبائح ۳۰ (۵۵۳۱، ۵۵۳۲)، صحیح مسلم/الحیض ۲۷ (۳۶۳-۳۶۵)، سنن ابی داود/ اللبا۴۱ (۴۱۲۱)، سنن النسائی/الفرع ۴ (۴۲۴۰-۴۲۴۴)، سنن ابن ماجہ/اللباس ۲۵ (۳۶۱۰)، وط/الصید ۶ (۱۶)، مسند احمد (۱/۲۳۷)، ۳۲۷، ۳۳۰، ۳۶۵، ۳۶۶، ۳۷۲)، سنن الدارمی/الأضاحي ۲۰ (۲۰۲۸),,Narrated Ibn Abi Awfa:,The Book on Jihad
1728,حَدَّثَنَا مُحَمَّدُ بْنُ عُمَرَ بْنِ الْوَلِيدِ الْكِنْدِيُّ الْكُوفِيُّ، وَأَبُو كُرَيْبٍ وَمُحَمَّدُ بْنُ رَافِعٍ قَالُوا حَدَّثَنَا يَحْيَى بْنُ آدَمَ، عَنْ شَرِيكٍ، عَنْ عَمَّارٍ يَعْنِي الدُّهْنِيَّ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، أَنَّ النَّبِيَّ صلى الله عليه وسلم دَخَلَ مَكَّةَ وَلِوَاؤُهُ أَبْيَضُ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ غَرِيبٌ لاَ نَعْرِفُهُ إِلاَّ مِنْ حَدِيثِ يَحْيَى بْنِ آدَمَ عَنْ شَرِيكٍ ‏.‏ قَالَ وَسَأَلْتُ مُحَمَّدًا عَنْ هَذَا الْحَدِيثِ فَلَمْ يَعْرِفْهُ إِلاَّ مِنْ حَدِيثِ يَحْيَى بْنِ آدَمَ عَنْ شَرِيكٍ وَقَالَ حَدَّثَنَا غَيْرُ وَاحِدٍ عَنْ شَرِيكٍ عَنْ عَمَّارٍ عَنْ أَبِي الزُّبَيْرِ عَنْ جَابِرٍ أَنَّ النَّبِيَّ صلى الله عليه وسلم دَخَلَ مَكَّةَ وَعَلَيْهِ عِمَامَةٌ سَوْدَاءُ ‏.‏ قَالَ مُحَمَّدٌ وَالْحَدِيثُ هُوَ هَذَا ‏.‏ قَالَ أَبُو عِيسَى وَالدُّهْنُ بَطْنٌ مِنْ بَجِيلَةَ وَعَمَّارٌ الدُّهْنِيُّ هُوَ عَمَّارُ بْنُ مُعَاوِيَةَ الدُّهْنِيُّ وَيُكْنَى أَبَا مُعَاوِيَةَ وَهُوَ كُوفِيٌّ وَهُوَ ثِقَةٌ عِنْدَ أَهْلِ الْحَدِيثِ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/الحیض ۲۷ (۳۶۶)، سنن ابی داود/ اللباس ۴۱ (۴۱۲۳)، سنن النسائی/الفرع ۴ (۴۲۴۶)، سنن ابن ماجہ/اللباس ۲۵ (۳۶۰۹)، (تحفة الأشراف : ۵۸۲۲)، وط/الصید ۶ (۱۷)، و مسند احمد (۱/۲۱۹، ۲۷۰، ۲۷۹، ۲۸۰، ۳۴۳),1728,Narrated Jabir:,The Book on Jihad
1729,حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا يَحْيَى بْنُ زَكَرِيَّا بْنِ أَبِي زَائِدَةَ، حَدَّثَنَا أَبُو يَعْقُوبَ الثَّقَفِيُّ، حَدَّثَنَا يُونُسُ بْنُ عُبَيْدٍ، مَوْلَى مُحَمَّدِ بْنِ الْقَاسِمِ قَالَ بَعَثَنِي مُحَمَّدُ بْنُ الْقَاسِمِ إِلَى الْبَرَاءِ بْنِ عَازِبٍ أَسْأَلُهُ عَنْ رَايَةِ، رَسُولِ اللَّهِ صلى الله عليه وسلم فَقَالَ كَانَتْ سَوْدَاءَ مُرَبَّعَةً مِنْ نَمِرَةٍ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ عَلِيٍّ وَالْحَارِثِ بْنِ حَسَّانَ وَابْنِ عَبَّاسٍ ‏.‏ قَالَ أَبُو عِيسَى وَهَذَا حَدِيثٌ حَسَنٌ غَرِيبٌ لاَ نَعْرِفُهُ إِلاَّ مِنْ حَدِيثِ ابْنِ أَبِي زَائِدَةَ ‏.‏ وَأَبُو يَعْقُوبَ الثَّقَفِيُّ اسْمُهُ إِسْحَاقُ بْنُ إِبْرَاهِيمَ وَرَوَى عَنْهُ أَيْضًا عُبَيْدُ اللَّهِ بْنُ مُوسَى ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan; Zubair Ali Zai: Hasan,takhreej: تخریج دارالدعوہ: سنن ابی داود/ اللباس ۴۲ (۴۱۲۷)، سنن النسائی/الفرع ۵۴ (۲۴۵۵، ۲۴۵۶)، سنن ابن ماجہ/اللباس ۲۶ (۳۶۱۳)، (تحفة الأشراف : ۶۶۴۲)، و مسند احمد (۴/۲۱۰، ۳۱۱),1729,Narrated Yunus bin 'Ubaid:,The Book on Jihad
1730,حَدَّثَنَا مُحَمَّدُ بْنُ رَافِعٍ، حَدَّثَنَا يَحْيَى بْنُ إِسْحَاقَ، وَهُوَ السَّالِحَانِيُّ حَدَّثَنَا يَزِيدُ بْنُ حَيَّانَ، قَالَ سَمِعْتُ أَبَا مِجْلَزٍ، لاَحِقَ بْنَ حُمَيْدٍ يُحَدِّثُ عَنِ ابْنِ عَبَّاسٍ، قَالَ كَانَتْ رَايَةُ رَسُولِ اللَّهِ صلى الله عليه وسلم سَوْدَاءَ وَلِوَاؤُهُ أَبْيَضَ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ غَرِيبٌ مِنْ هَذَا الْوَجْهِ مِنْ حَدِيثِ ابْنِ عَبَّاسٍ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/فضائل الصحابة ۵ (۳۶۶۵)، واللباس ۱ (۵۷۸۳)، و ۲ (۵۷۸۴)، و ۵ (۵۷۹۱)، صحیح مسلم/اللباس ۹ (۲۰۸۵)، سنن ابی داود/ اللباس ۲۸ (۴۰۸۵)، سنن النسائی/الزینة ۶۶ (۵۳۷۷)، سنن ابن ماجہ/اللباس ۶ (۳۵۶۹)، و ۹ (۳۵۷۶)، (تحفة الأشراف : ۶۷۲۶ و ۷۲۲۷ و ۸۳۵۸)، وط/اللباس ۵ (۹) و مسند احمد (۲/۵، ۱۰، ۳۲، ۴۲، ۴۴، ۴۶، ۵۵، ۵۶، ۶۰، ۶۵، ۶۷، ۶۹، ۷۴، ۷۶، ۸۱),1730,Narrated Ibn 'Abbas:,The Book on Jihad
1731,"حَدَّثَنَا مَحْمُودُ بْنُ غَيْلاَنَ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا سُفْيَانُ، عَنْ أَبِي إِسْحَاقَ، عَنِ الْمُهَلَّبِ بْنِ أَبِي صُفْرَةَ، عَمَّنْ سَمِعَ النَّبِيَّ صلى الله عليه وسلم يَقُولُ ‏ ‏ إِنْ بَيَّتَكُمُ الْعَدُوُّ فَقُولُوا‏:‏ حم لاَ يُنْصَرُونَ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ سَلَمَةَ بْنِ الأَكْوَعِ ‏.‏ وَهَكَذَا رَوَى بَعْضُهُمْ عَنْ أَبِي إِسْحَاقَ مِثْلَ رِوَايَةِ الثَّوْرِيِّ وَرُوِيَ عَنْهُ عَنِ الْمُهَلَّبِ بْنِ أَبِي صُفْرَةَ عَنِ النَّبِيِّ صلى الله عليه وسلم مُرْسَلاً ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف وانظر ما قبلہ (تحفة الأشراف : ۷۵۲۶),,Narrated Al-Muhallab bin Abi Sufrah:,The Book on Jihad
1732,حَدَّثَنَا مُحَمَّدُ بْنُ شُجَاعٍ الْبَغْدَادِيُّ، حَدَّثَنَا أَبُو عُبَيْدَةَ الْحَدَّادُ، عَنْ عُثْمَانَ بْنِ سَعْدٍ، عَنِ ابْنِ سِيرِينَ، قَالَ صَنَعْتُ سَيْفِي عَلَى سَيْفِ سَمُرَةَ بْنِ جُنْدَبٍ وَزَعَمَ سَمُرَةُ أَنَّهُ صَنَعَ سَيْفَهُ عَلَى سَيْفِ رَسُولِ اللَّهِ صلى الله عليه وسلم وَكَانَ حَنَفِيًّا ‏.‏ قَالَ أَبُو عِيسَى هَذَ حَدِيثٌ غَرِيبٌ لاَ نَعْرِفُهُ إِلاَّ مِنْ هَذَا الْوَجْهِ ‏.‏ وَقَدْ تَكَلَّمَ يَحْيَى بْنُ سَعِيدٍ الْقَطَّانُ فِي عُثْمَانَ بْنِ سَعْدٍ الْكَاتِبِ وَضَعَّفَهُ مِنْ قِبَلِ حِفْظِهِ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan; Zubair Ali Zai: Hasan,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف، وانظر سنن ابی داود/ اللباس ۴۰ (۴۱۱۷-۴۱۱۸)، و ق /اللباس ۱۳ (۳۵۰۸)، (تحفة الأشراف : ۸۲۵۷),1732,Narrated 'Uthman bin Sa'd:,The Book on Jihad
1733,حَدَّثَنَا أَحْمَدُ بْنُ مُحَمَّدِ بْنِ مُوسَى، أَنْبَأَنَا عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ، أَنْبَأَنَا سَعِيدُ بْنُ عَبْدِ الْعَزِيزِ، عَنْ عَطِيَّةَ بْنِ قَيْسٍ، عَنْ قَزَعَةَ، عَنْ أَبِي سَعِيدٍ الْخُدْرِيِّ، قَالَ لَمَّا بَلَغَ النَّبِيُّ صلى الله عليه وسلم عَامَ الْفَتْحِ مَرَّ الظَّهْرَانِ فَآذَنَنَا بِلِقَاءِ الْعَدُوِّ فَأَمَرَنَا بِالْفِطْرِ فَأَفْطَرْنَا أَجْمَعُونَ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَفِي الْبَابِ عَنْ عُمَرَ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الخمس ۵ (۳۱۰۸)، واللباس ۱۹ (۵۸۱۸)، صحیح مسلم/اللباس ۶ (۲۰۸۰)، سنن ابی داود/ اللباس ۸ (۴۰۳۶)، سنن ابن ماجہ/اللباس ۱ (۳۵۵۱)، (تحفة الأشراف : ۱۷۶۹۳)، و مسند احمد (۶/۳۲، ۱۳۱),1733,Narrated Abu Sa’id Al Khudri :,The Book on Jihad
1734,"حَدَّثَنَا مَحْمُودُ بْنُ غَيْلاَنَ، حَدَّثَنَا أَبُو دَاوُدَ الطَّيَالِسِيُّ، قَالَ أَنْبَأَنَا شُعْبَةُ، عَنْ قَتَادَةَ، حَدَّثَنَا أَنَسُ بْنُ مَالِكٍ، قَالَ رَكِبَ النَّبِيُّ صلى الله عليه وسلم فَرَسًا لأَبِي طَلْحَةَ يُقَالُ لَهُ مَنْدُوبٌ فَقَالَ ‏ ‏ مَا كَانَ مِنْ فَزَعٍ وَإِنْ وَجَدْنَاهُ لَبَحْرًا ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنِ ابْنِ عَمْرِو بْنِ الْعَاصِ ‏.‏ وَهَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏""",Ahmad Muhammad Shakir: Very Daif; Al-Albani: Very Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۹۳۲۸),,Narrated Anas bin Malik:,The Book on Jihad
1735,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، وَابْنُ أَبِي عَدِيٍّ، وَأَبُو دَاوُدَ قَالُوا حَدَّثَنَا شُعْبَةُ، عَنْ قَتَادَةَ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ كَانَ فَزَعٌ بِالْمَدِينَةِ فَاسْتَعَارَ رَسُولُ اللَّهِ صلى الله عليه وسلم فَرَسًا لَنَا يُقَالُ لَهُ مَنْدُوبٌ فَقَالَ ‏ ‏ مَا رَأَيْنَا مِنْ فَزَعٍ وَإِنْ وَجَدْنَاهُ لَبَحْرًا ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: صحیح مسلم/الحج ۸۴ (۱۳۵۸)، سنن ابی داود/ اللباس ۲۴ (۴۰۷۶)، سنن النسائی/الحج ۱۰۷ (۲۸۷۲)، والزینة ۱۰۹ (۵۳۴۶)، سنن ابن ماجہ/الجہاد۲۲ (۲۸۲۲)، واللباس ۱۴ (۲۵۸۵)، (تحفة الأشراف : ۲۶۸۹)، و مسند احمد (۳/۳۶۳، ۳۸۷),,Narrated Anas bin Malik:,The Book on Jihad
1736,"حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ، عَنْ ثَابِتٍ، عَنْ أَنَسٍ، قَالَ كَانَ النَّبِيُّ صلى الله عليه وسلم مِنْ أَجْرَإِ النَّاسِ وَأَجْوَدِ النَّاسِ وَأَشْجَعِ النَّاسِ ‏.‏ قَالَ وَقَدْ فَزِعَ أَهْلُ الْمَدِينَةِ لَيْلَةً سَمِعُوا صَوْتًا قَالَ فَتَلَقَّاهُمُ النَّبِيُّ صلى الله عليه وسلم عَلَى فَرَسٍ لأَبِي طَلْحَةَ عُرْىٍ وَهُوَ مُتَقَلِّدٌ سَيْفَهُ فَقَالَ ‏""‏ لَمْ تُرَاعُوا لَمْ تُرَاعُوا ‏""‏ ‏.‏ فَقَالَ النَّبِيُّ صلى الله عليه وسلم ‏""‏ وَجَدْتُهُ بَحْرًا ‏""‏ ‏.‏ يَعْنِي الْفَرَسَ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ صَحِيحٌ ‏.‏",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan; Zubair Ali Zai: Hasan,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۸۰۳۱),1736,Narrated Anas:,The Book on Jihad
1737,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، حَدَّثَنَا سُفْيَانُ الثَّوْرِيُّ، حَدَّثَنَا أَبُو إِسْحَاقَ، عَنِ الْبَرَاءِ بْنِ عَازِبٍ، قَالَ قَالَ لَنَا رَجُلٌ أَفَرَرْتُمْ عَنْ رَسُولِ اللَّهِ صلى الله عليه وسلم يَا أَبَا عُمَارَةَ قَالَ لاَ وَاللَّهِ مَا وَلَّى رَسُولُ اللَّهِ صلى الله عليه وسلم وَلَكِنْ وَلَّى سَرَعَانُ النَّاسِ تَلَقَّتْهُمْ هَوَازِنُ بِالنَّبْلِ وَرَسُولُ اللَّهِ صلى الله عليه وسلم عَلَى بَغْلَتِهِ وَأَبُو سُفْيَانَ بْنُ الْحَارِثِ بْنِ عَبْدِ الْمُطَّلِبِ آخِذٌ بِلِجَامِهَا وَرَسُولُ اللَّهِ صلى الله عليه وسلم يَقُولُ ‏ ‏ أَنَا النَّبِيُّ لاَ كَذِبْ أَنَا ابْنُ عَبْدِ الْمُطَّلِبْ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ عَلِيٍّ وَابْنِ عُمَرَ ‏.‏ وَهَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: انظر حدیث رقم ۲۶۴ و ۱۷۲۵,,Narrated Abu Ishaq:,The Book on Jihad
1738,حَدَّثَنَا مُحَمَّدُ بْنُ عُمَرَ بْنِ عَلِيٍّ الْمُقَدَّمِيُّ الْبَصْرِيُّ، حَدَّثَنِي أَبِي، عَنْ سُفْيَانَ بْنِ حُسَيْنٍ، عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ لَقَدْ رَأَيْتُنَا يَوْمَ حُنَيْنٍ وَإِنَّ الْفِئَتَيْنِ لَمُوَلِّيَتَيْنِ وَمَا مَعَ رَسُولِ اللَّهِ صلى الله عليه وسلم مِائَةُ رَجُلٍ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ غَرِيبٌ لاَ نَعْرِفُهُ مِنْ حَدِيثِ عُبَيْدِ اللَّهِ إِلاَّ مِنْ هَذَا الْوَجْهِ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: تخریج دارالدعوہ: سنن النسائی/الزینة ۴۴ (۵۱۹۰)، (تحفة الأشراف : ۱۰۸۱۸)، و مسند احمد (۴/۴۲۸، ۴۴۳),1738,Narrated Ibn 'Umar:,The Book on Jihad
1739,حَدَّثَنَا مُحَمَّدُ بْنُ صُدْرَانَ أَبُو جَعْفَرٍ الْبَصْرِيُّ، حَدَّثَنَا طَالِبُ بْنُ حُجَيْرٍ، عَنْ هُودِ بْنِ عَبْدِ اللَّهِ بْنِ سَعْدٍ، عَنْ جَدِّهِ، مَزِيدَةَ قَالَ دَخَلَ رَسُولُ اللَّهِ صلى الله عليه وسلم يَوْمَ الْفَتْحِ وَعَلَى سَيْفِهِ ذَهَبٌ وَفِضَّةٌ ‏.‏ قَالَ طَالِبٌ فَسَأَلْتُهُ عَنِ الْفِضَّةِ فَقَالَ كَانَتْ قَبِيعَةُ السَّيْفِ فِضَّةً ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ أَنَسٍ ‏.‏ وَهَذَا حَدِيثٌ غَرِيبٌ ‏.‏ وَجَدُّ هُودٍ اسْمُهُ مَزِيدَةُ الْعَصَرِيُّ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/اللباس ۴۸ (۵۸۷۰)، صحیح مسلم/اللباس ۱۵ (۲۰۹۴)، سنن ابی داود/ الخاتم ۱ (۴۲۱۶)، سنن النسائی/الزینة ۴۷ (۵۱۹۹)، و ۷ (۵۲۷۹-۵۲۸۲) سنن ابن ماجہ/اللباس ۳۹ (۳۶۴۱)، (تحفة الأشراف : ۱۵۵۴)، و مسند احمد (۳/۲۰۹)، وانظر الحدیث التالي,1739,Narrated Talib bin Hujair:,The Book on Jihad
1740,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا وَهْبُ بْنُ جَرِيرِ بْنِ حَازِمٍ، حَدَّثَنَا أَبِي، عَنْ قَتَادَةَ، عَنْ أَنَسٍ، قَالَ كَانَتْ قَبِيعَةُ سَيْفِ رَسُولِ اللَّهِ صلى الله عليه وسلم مِنْ فِضَّةٍ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ غَرِيبٌ ‏.‏ وَهَكَذَا رُوِيَ عَنْ هَمَّامٍ عَنْ قَتَادَةَ عَنْ أَنَسٍ وَقَدْ رَوَى بَعْضُهُمْ عَنْ قَتَادَةَ عَنْ سَعِيدِ بْنِ أَبِي الْحَسَنِ قَالَ كَانَتْ قَبِيعَةُ سَيْفِ رَسُولِ اللَّهِ صلى الله عليه وسلم مِنْ فِضَّةٍ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: صحیح البخاری/اللباس ۴۸ (۵۸۷۰)، سنن ابی داود/ الخاتم ۱ (۴۲۱۷)، سنن النسائی/الزینة ۴۷ (۵۲۰۱)، سنن ابن ماجہ/اللباس ۳۹ (۳۶۴۱),1740,Narrated Anas:,The Book on Jihad
1741,"حَدَّثَنَا أَبُو سَعِيدٍ الأَشَجُّ، حَدَّثَنَا يُونُسُ بْنُ بُكَيْرٍ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ، عَنْ يَحْيَى بْنِ عَبَّادِ بْنِ عَبْدِ اللَّهِ بْنِ الزُّبَيْرِ، عَنْ أَبِيهِ، عَنْ جَدِّهِ عَبْدِ اللَّهِ بْنِ الزُّبَيْرِ، عَنِ الزُّبَيْرِ بْنِ الْعَوَّامِ، قَالَ كَانَ عَلَى النَّبِيِّ صلى الله عليه وسلم دِرْعَانِ يَوْمَ أُحُدٍ فَنَهَضَ إِلَى الصَّخْرَةِ فَلَمْ يَسْتَطِعْ فَأَقْعَدَ طَلْحَةَ تَحْتَهُ فَصَعِدَ النَّبِيُّ صلى الله عليه وسلم عَلَيْهِ حَتَّى اسْتَوَى عَلَى الصَّخْرَةِ فَقَالَ سَمِعْتُ النَّبِيَّ صلى الله عليه وسلم يَقُولُ ‏ ‏ أَوْجَبَ طَلْحَةُ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ صَفْوَانَ بْنِ أُمَيَّةَ وَالسَّائِبِ بْنِ يَزِيدَ ‏.‏ وَهَذَا حَدِيثٌ حَسَنٌ غَرِيبٌ لاَ نَعْرِفُهُ إِلاَّ مِنْ حَدِيثِ مُحَمَّدِ بْنِ إِسْحَاقَ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح البخاری/اللباس ۴۵ (۵۸۶۵)، و ۴۶ (۵۸۶۶)، و ۴۷ (۵۸۶۷)، و ۵۰ (۵۸۷۳)، و ۵۳ (۵۸۷۶)، والأیمان والنذور ۶ (۶۶۵۱)، والاعتصام ۴ (۷۲۹۸)، صحیح مسلم/اللباس ۱۱ (۲۰۹۱)، سنن ابی داود/ الخاتم ۱ (۴۲۱۸)، سنن النسائی/الزینة ۴۳ (۵۱۶۷)، و ۵۳ (۵۲۱۷-۵۲۲۱)، سنن ابن ماجہ/اللباس ۳۹ (۳۶۳۹)، (تحفة الأشراف : ۸۴۷۱)، و مسند احمد (۲/۱۸، ۶۸، ۹۶، ۱۲۷),,Narrated Az-Zubair bin Al-'Awwam:,The Book on Jihad
1742,"حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، عَنِ ابْنِ شِهَابٍ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ دَخَلَ النَّبِيُّ صلى الله عليه وسلم عَامَ الْفَتْحِ وَعَلَى رَأْسِهِ الْمِغْفَرُ فَقِيلَ لَهُ ابْنُ خَطَلٍ مُتَعَلِّقٌ بِأَسْتَارِ الْكَعْبَةِ ‏.‏ فَقَالَ ‏ ‏ اقْتُلُوهُ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ غَرِيبٌ لاَ نَعْرِفُ كَبِيرَ أَحَدٍ رَوَاهُ غَيْرَ مَالِكٍ عَنِ الزُّهْرِيِّ ‏.‏""",Ahmad Muhammad Shakir: Hasan Sahih; Al-Albani: Hasan Sahih; Bashar Awad Maarouf: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الخاتم ۵ (۴۲۲۹)، (تحفة الأشراف : ۵۶۸۶),,Narrated Anas bin Malik:,The Book on Jihad
1743,"حَدَّثَنَا هَنَّادٌ، حَدَّثَنَا عَبْثَرُ بْنُ الْقَاسِمِ، عَنْ حُصَيْنٍ، عَنِ الشَّعْبِيِّ، عَنْ عُرْوَةَ الْبَارِقِيِّ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ الْخَيْرُ مَعْقُودٌ فِي نَوَاصِي الْخَيْلِ إِلَى يَوْمِ الْقِيَامَةِ الأَجْرُ وَالْمَغْنَمُ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنِ ابْنِ عُمَرَ وَأَبِي سَعِيدٍ وَجَرِيرٍ وَأَبِي هُرَيْرَةَ وَأَسْمَاءَ بِنْتِ يَزِيدَ وَالْمُغِيرَةِ بْنِ شُعْبَةَ وَجَابِرٍ ‏.‏ قَالَ أَبُو عِيسَى وَهَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَعُرْوَةُ هُوَ ابْنُ أَبِي الْجَعْدِ الْبَارِقِيُّ وَيُقَالُ هُوَ عُرْوَةُ بْنُ الْجَعْدِ ‏.‏ قَالَ أَحْمَدُ بْنُ حَنْبَلٍ وَفِقْهُ هَذَا الْحَدِيثِ أَنَّ الْجِهَادَ مَعَ كُلِّ إِمَامٍ إِلَى يَوْمِ الْقِيَامَةِ ‏.‏""",Ahmad Muhammad Shakir: Sahih Muquf; Al-Albani: Sahih Muquf; Bashar Awad Maarouf: Hasan; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف، (تحفة الأشراف : ۳۴۰۸ و ۳۴۱۱),,Narrated 'Urwah Al-Bariqi:,The Book on Jihad
1744,"حَدَّثَنَا عَبْدُ اللَّهِ بْنُ الصَّبَّاحِ الْهَاشِمِيُّ الْبَصْرِيُّ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، أَخْبَرَنَا شَيْبَانُ يَعْنِي ابْنَ عَبْدِ الرَّحْمَنِ، حَدَّثَنَا عِيسَى بْنُ عَلِيِّ بْنِ عَبْدِ اللَّهِ بْنِ عَبَّاسٍ، عَنْ أَبِيهِ، عَنِ ابْنِ عَبَّاسٍ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ يُمْنُ الْخَيْلِ فِي الشُّقْرِ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ غَرِيبٌ لاَ نَعْرِفُهُ إِلاَّ مِنْ هَذَا الْوَجْهِ مِنْ حَدِيثِ شَيْبَانَ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: سنن النسائی/الزینة ۴۸ (۵۲۰۷)، سنن ابن ماجہ/اللباس ۴۲ (۳۶۴۷)، (تحفة الأشراف : ۵۲۲۲)، و مسند احمد (۱/۲۰۴)، والمؤلف في الشمائل۱۳,,Narrated Ibn 'Abbas:,The Book on Jihad
1745,"حَدَّثَنَا أَحْمَدُ بْنُ مُحَمَّدٍ، أَخْبَرَنَا عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ، أَخْبَرَنَا ابْنُ لَهِيعَةَ، عَنْ يَزِيدَ بْنِ أَبِي حَبِيبٍ، عَنْ عُلَىِّ بْنِ رَبَاحٍ، عَنْ أَبِي قَتَادَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ خَيْرُ الْخَيْلِ الأَدْهَمُ الأَقْرَحُ الأَرْثَمُ ثُمَّ الأَقْرَحُ الْمُحَجَّلُ طَلْقُ الْيَمِينِ فَإِنْ لَمْ يَكُنْ أَدْهَمَ فَكُمَيْتٌ عَلَى هَذِهِ الشِّيَةِ ‏""""‏ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: صحیح البخاری/اللباس ۵۰ (۵۸۷۲)، و ۵۱ (۵۸۷۴)، و ۵۴ (۵۸۷۷)، سنن النسائی/الزینة ۵۰ (۵۲۱۱)، و ۷۸ (۵۲۸۳)، و ۷۹ (۵۲۸۴)، سنن ابن ماجہ/اللباس ۳۹ (۳۶۴۰)، (تحفة الأشراف : ۴۸۰)، و مسند احمد (۳/۱۰۱، ۱۶۱),,Narrated Abu Qatadah:,The Book on Jihad
1746,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا وَهْبُ بْنُ جَرِيرٍ، حَدَّثَنَا أَبِي، عَنْ يَحْيَى بْنِ أَيُّوبَ، عَنْ يَزِيدَ بْنِ أَبِي حَبِيبٍ، بِهَذَا الإِسْنَادِ نَحْوَهُ بِمَعْنَاهُ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ غَرِيبٌ صَحِيحٌ ‏.‏,Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الطہارة ۱۰ (۱۹)، سنن النسائی/الزینة ۵۱ (۵۲۱۶)، سنن ابن ماجہ/الطہارة ۱۱ (۳۰۳)، (تحفة الأشراف : ۱۵۱۲)، و مسند احمد (۳/۹۹، ۱۰۱، ۲۸۲)، والمؤلف الشمائل ۱۱ (۸۸),1746,Another chain with similar meaning.\n\n\n[Abu 'Eisa said:,The Book on Jihad
1747,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، حَدَّثَنَا سُفْيَانُ، قَالَ حَدَّثَنِي سَلْمُ بْنُ عَبْدِ الرَّحْمَنِ النَّخَعِيُّ، عَنْ أَبِي زُرْعَةَ بْنِ عَمْرِو بْنِ جَرِيرٍ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم أَنَّهُ كَرِهَ الشِّكَالَ مِنَ الْخَيْلِ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَقَدْ رَوَاهُ شُعْبَةُ عَنْ عَبْدِ اللَّهِ بْنِ يَزِيدَ الْخَثْعَمِيِّ عَنْ أَبِي زُرْعَةَ عَنْ أَبِي هُرَيْرَةَ عَنِ النَّبِيِّ صلى الله عليه وسلم نَحْوَهُ ‏.‏ وَأَبُو زُرْعَةَ بْنُ عَمْرِو بْنِ جَرِيرٍ اسْمُهُ هَرِمٌ ‏.‏ حَدَّثَنَا مُحَمَّدُ بْنُ حُمَيْدٍ الرَّازِيُّ حَدَّثَنَا جَرِيرٌ عَنْ عُمَارَةَ بْنِ الْقَعْقَاعِ قَالَ قَالَ لِي إِبْرَاهِيمُ النَّخَعِيُّ إِذَا حَدَّثْتَنِي فَحَدِّثْنِي عَنْ أَبِي زُرْعَةَ فَإِنَّهُ حَدَّثَنِي مَرَّةً بِحَدِيثٍ ثُمَّ سَأَلْتُهُ بَعْدَ ذَلِكَ بِسِنِينَ فَمَا أَخْرَمَ مِنْهُ حَرْفًا ‏.‏,Zubair Ali Zai: Sahih Bukhari,takhreej: تخریج دارالدعوہ: صحیح البخاری/الخمس ۵ (۳۱۰۶)، واللباس ۵۵ (۵۸۸۸، ۸۵۷۹) والمؤلف في الشمائل ۱۲ (تحفة الأشراف : ۵۰۲),1747,Narrated Abu Hurairah:,The Book on Jihad
1748,حَدَّثَنَا مُحَمَّدُ بْنُ وَزِيرٍ الْوَاسِطِيُّ، حَدَّثَنَا إِسْحَاقُ بْنُ يُوسُفَ الأَزْرَقُ، عَنْ سُفْيَانَ، عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم أَجْرَى الْمُضَمَّرَ مِنَ الْخَيْلِ مِنَ الْحَفْيَاءِ إِلَى ثَنِيَّةِ الْوَدَاعِ وَبَيْنَهُمَا سِتَّةُ أَمْيَالٍ وَمَا لَمْ يُضَمَّرْ مِنَ الْخَيْلِ مِنْ ثَنِيَّةِ الْوَدَاعِ إِلَى مَسْجِدِ بَنِي زُرَيْقٍ وَبَيْنَهُمَا مِيلٌ وَكُنْتُ فِيمَنْ أَجْرَى فَوَثَبَ بِي فَرَسِي جِدَارًا ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ أَبِي هُرَيْرَةَ وَجَابِرٍ وَعَائِشَةَ وَأَنَسٍ ‏.‏ وَهَذَا حَدِيثٌ صَحِيحٌ حَسَنٌ غَرِيبٌ مِنْ حَدِيثِ الثَّوْرِيِّ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: انظر ما قبلہ,1748,Narrated Ibn 'Umar:,The Book on Jihad
1749,"حَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا وَكِيعٌ، عَنِ ابْنِ أَبِي ذِئْبٍ، عَنْ نَافِعِ بْنِ أَبِي نَافِعٍ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ لاَ سَبَقَ إِلاَّ فِي نَصْلٍ أَوْ خُفٍّ أَوْ حَافِرٍ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۲۸۷۰),,Narrated Abu Hurairah:,The Book on Jihad
1750,حَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ إِبْرَاهِيمَ، حَدَّثَنَا أَبُو جَهْضَمٍ، مُوسَى بْنُ سَالِمٍ عَنْ عَبْدِ اللَّهِ بْنِ عُبَيْدِ اللَّهِ بْنِ عَبَّاسٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ كَانَ رَسُولُ اللَّهِ صلى الله عليه وسلم عَبْدًا مَأْمُورًا مَا اخْتَصَّنَا دُونَ النَّاسِ بِشَيْءٍ إِلاَّ بِثَلاَثٍ أَمَرَنَا أَنْ نُسْبِغَ الْوُضُوءَ وَأَنْ لاَ نَأْكُلَ الصَّدَقَةَ وَأَنْ لاَ نُنْزِيَ حِمَارًا عَلَى فَرَسٍ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ عَلِيٍّ ‏.‏ وَهَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَرَوَى سُفْيَانُ الثَّوْرِيُّ هَذَا عَنْ أَبِي جَهْضَمٍ فَقَالَ عَنْ عُبَيْدِ اللَّهِ بْنِ عَبْدِ اللَّهِ بْنِ عَبَّاسٍ عَنِ ابْنِ عَبَّاسٍ ‏.‏ قَالَ وَسَمِعْتُ مُحَمَّدًا يَقُولُ حَدِيثُ الثَّوْرِيِّ غَيْرُ مَحْفُوظٍ وَوَهِمَ فِيهِ الثَّوْرِيُّ وَالصَّحِيحُ مَا رَوَى إِسْمَاعِيلُ ابْنُ عُلَيَّةَ وَعَبْدُ الْوَارِثِ بْنُ سَعِيدٍ عَنْ أَبِي جَهْضَمٍ عَنْ عَبْدِ اللَّهِ بْنِ عُبَيْدِ اللَّهِ بْنِ عَبَّاسٍ عَنِ ابْنِ عَبَّاسٍ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: سنن النسائی/الزینة ۱۱۱ (۵۳۵۱)، وانظر أیضا: صحیح البخاری/بدء الخلق ۷ (۳۲۲۶)، واللباس ۹۲ (۵۹۵۸)، صحیح مسلم/اللباس ۲۶ (۲۱۰۶/۸۵)، سنن ابی داود/ اللباس ۴۸ (۴۱۵۵)، سنن النسائی/الزینة ۱۱۱ (۵۲۵۲)، (تحفة الأشراف : ۳۷۸۲ و ۴۶۶۳)، و مسند احمد (۴/۲۸),1750,Narrated Ibn 'Abbas:,The Book on Jihad
1751,"حَدَّثَنَا أَحْمَدُ بْنُ مُحَمَّدِ بْنِ مُوسَى، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ، قَالَ أَخْبَرَنَا عَبْدُ الرَّحْمَنِ بْنُ يَزِيدَ بْنِ جَابِرٍ، حَدَّثَنَا زَيْدُ بْنُ أَرْطَاةَ، عَنْ جُبَيْرِ بْنِ نُفَيْرٍ، عَنْ أَبِي الدَّرْدَاءِ، قَالَ سَمِعْتُ النَّبِيَّ صلى الله عليه وسلم يَقُولُ ‏ ‏ ابْغُونِي ضُعَفَاءَكُمْ فَإِنَّمَا تُرْزَقُونَ وَتُنْصَرُونَ بِضُعَفَائِكُمْ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: تخریج دارالدعوہ: صحیح البخاری/التعبیر ۴۵ (۷۰۴۲)، والأدب ۹۶ (۵۰۲۴)، سنن النسائی/الزینة ۱۱۳ (۵۳۶۱)، (تحفة الأشراف : ۵۹۸۶)، و مسند احمد (۱/۲۴۶)، سنن الدارمی/الرقاق ۳ (),,Narrated Abu Ad-Darda':,The Book on Jihad
1752,"حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ، عَنْ سُهَيْلِ بْنِ أَبِي صَالِحٍ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ لاَ تَصْحَبُ الْمَلاَئِكَةُ رُفْقَةً فِيهَا كَلْبٌ وَلاَ جَرَسٌ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ عُمَرَ وَعَائِشَةَ وَأُمِّ حَبِيبَةَ وَأُمِّ سَلَمَةَ ‏.‏ وَهَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف، وانظر: صحیح البخاری/الأنبیاء ۵۰ (۳۴۶۲)، واللباس ۶۷ (۵۸۹۹)، صحیح مسلم/اللباس ۲۵ (۲۱۰۳)، سنن ابی داود/ الترجل۱۸ (۴۲۰۳)، سنن النسائی/الزینة ۱۴ (۵۰۷۲)، و ۶۴ (۵۲۴۳)، سنن ابن ماجہ/اللباس ۳۳ (۳۶۲۱)، (تحفة الأشراف : ۱۴۹۸۵۱),,Narrated Abu Hurairah:,The Book on Jihad
1753,"حَدَّثَنَا عَبْدُ اللَّهِ بْنُ أَبِي زِيَادٍ، حَدَّثَنَا الأَحْوَصُ بْنُ الْجَوَّابِ أَبُو الْجَوَّابِ، عَنْ يُونُسَ بْنِ أَبِي إِسْحَاقَ، عَنْ أَبِي إِسْحَاقَ، عَنِ الْبَرَاءِ، أَنَّ النَّبِيَّ صلى الله عليه وسلم بَعَثَ جَيْشَيْنِ وَأَمَّرَ عَلَى أَحَدِهِمَا عَلِيَّ بْنَ أَبِي طَالِبٍ وَعَلَى الآخَرِ خَالِدَ بْنَ الْوَلِيدِ وَقَالَ ‏""‏ إِذَا كَانَ الْقِتَالُ فَعَلِيٌّ ‏""‏ ‏.‏ قَالَ فَافْتَتَحَ عَلِيٌّ حِصْنًا فَأَخَذَ مِنْهُ جَارِيَةً فَكَتَبَ مَعِي خَالِدُ بْنُ الْوَلِيدِ إِلَى النَّبِيِّ صلى الله عليه وسلم يَشِي بِهِ فَقَدِمْتُ عَلَى النَّبِيِّ صلى الله عليه وسلم فَقَرَأَ الْكِتَابَ فَتَغَيَّرَ لَوْنُهُ ثُمَّ قَالَ ‏""‏ مَا تَرَى فِي رَجُلٍ يُحِبُّ اللَّهَ وَرَسُولَهُ وَيُحِبُّهُ اللَّهُ وَرَسُولُهُ ‏""‏ ‏.‏ قَالَ قُلْتُ أَعُوذُ بِاللَّهِ مِنْ غَضَبِ اللَّهِ وَغَضَبِ رَسُولِهِ وَإِنَّمَا أَنَا رَسُولٌ ‏.‏ فَسَكَتَ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنِ ابْنِ عُمَرَ ‏.‏ وَهَذَا حَدِيثٌ حَسَنٌ غَرِيبٌ لاَ نَعْرِفُهُ إِلاَّ مِنْ حَدِيثِ الأَحْوَصِ بْنِ جَوَّابٍ ‏.‏ مَعْنَى قَوْلِهِ يَشِي بِهِ يَعْنِي النَّمِيمَةَ ‏.‏",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الترجل ۱۸ (۴۲۰۵)، سنن النسائی/الزینة ۱۶ (۵۰۸۰)، سنن ابن ماجہ/اللباس ۳۲ (۳۶۲۲)، (تحفة الأشراف : ۱۱۹۲۷)، و مسند احمد (۵/۱۴۷، ۱۵۰، ۱۵۴، ۱۵۶، ۱۶۹),1753,Narrated Al-Bara' :,The Book on Jihad
1754,"حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا اللَّيْثُ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ أَلاَ كُلُّكُمْ رَاعٍ وَكُلُّكُمْ مَسْئُولٌ عَنْ رَعِيَّتِهِ فَالأَمِيرُ الَّذِي عَلَى النَّاسِ رَاعٍ وَمَسْئُولٌ عَنْ رَعِيَّتِهِ وَالرَّجُلُ رَاعٍ عَلَى أَهْلِ بَيْتِهِ وَهُوَ مَسْئُولٌ عَنْهُمْ وَالْمَرْأَةُ رَاعِيَةٌ عَلَى بَيْتِ بَعْلِهَا وَهِيَ مَسْئُولَةٌ عَنْهُ وَالْعَبْدُ رَاعٍ عَلَى مَالِ سَيِّدِهِ وَهُوَ مَسْئُولٌ عَنْهُ أَلاَ فَكُلُّكُمْ رَاعٍ وَكُلُّكُمْ مَسْئُولٌ عَنْ رَعِيَّتِهِ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ أَبِي هُرَيْرَةَ وَأَنَسٍ وَأَبِي مُوسَى ‏.‏ وَحَدِيثُ أَبِي مُوسَى غَيْرُ مَحْفُوظٍ وَحَدِيثُ أَنَسٍ غَيْرُ مَحْفُوظٍ وَحَدِيثُ ابْنِ عُمَرَ حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف، وانظر: صحیح البخاری/المناقب ۲۳ (۳۵۴۷)، (تحفة الأشراف : ۷۲۰),,Narrated Ibn 'Umar:,The Book on Jihad
1755,"قَالَ حَكَاهُ إِبْرَاهِيمُ بْنُ بَشَّارٍ الرَّمَادِيُّ عَنْ سُفْيَانَ بْنِ عُيَيْنَةَ، عَنْ بُرَيْدِ بْنِ عَبْدِ اللَّهِ بْنِ أَبِي بُرْدَةَ، عَنْ أَبِي بُرْدَةَ، عَنْ أَبِي مُوسَى، عَنِ النَّبِيِّ صلى الله عليه وسلم ‏.‏ أَخْبَرَنِي بِذَلِكَ، مُحَمَّدٌ عَنْ إِبْرَاهِيمَ بْنِ بَشَّارٍ، ‏.‏ قَالَ وَرَوَى غَيْرُ، وَاحِدٍ، عَنْ سُفْيَانَ، عَنْ بُرَيْدٍ، عَنْ أَبِي بُرْدَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم مُرْسَلاً وَهَذَا أَصَحُّ ‏.‏ قَالَ مُحَمَّدٌ وَرَوَى إِسْحَاقُ بْنُ إِبْرَاهِيمَ عَنْ مُعَاذِ بْنِ هِشَامٍ عَنْ أَبِيهِ عَنْ قَتَادَةَ عَنْ أَنَسٍ عَنِ النَّبِيِّ صلى الله عليه وسلم ‏ ‏ إِنَّ اللَّهَ سَائِلٌ كُلَّ رَاعٍ عَمَّا اسْتَرْعَاهُ ‏""""‏ ‏.‏ قَالَ سَمِعْتُ مُحَمَّدًا يَقُولُ هَذَا غَيْرُ مَحْفُوظٍ وَإِنَّمَا الصَّحِيحُ عَنْ مُعَاذِ بْنِ هِشَامٍ عَنْ أَبِيهِ عَنْ قَتَادَةَ عَنِ الْحَسَنِ عَنِ النَّبِيِّ صلى الله عليه وسلم مُرْسَلاً ‏.‏""",Ahmad Muhammad Shakir: Hasan Sahih; Al-Albani: Hasan Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الترجل ۹ (۴۱۸۷)، سنن ابن ماجہ/اللباس ۳۶ (۳۶۳۵)، (تحفة الأشراف : ۱۷۰۱۹),,"Ibrahim bin Bash-shar Ar-Ramadi reported it from Sufyan bin 'Uyainah, from Buraid bin 'Abdullah bin Abu Burdah, from Abu Burdah, from Abu Musa, from the Prophet (ﷺ).\n\n\nMuhammad informed me of that, from Ibrahim bin Bash-Shar . Muhammad said:",The Book on Jihad
1756,"حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى النَّيْسَابُورِيُّ، حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ، حَدَّثَنَا يُونُسُ بْنُ أَبِي إِسْحَاقَ، عَنِ الْعَيْزَارِ بْنِ حُرَيْثٍ، عَنْ أُمِّ الْحُصَيْنِ الأَحْمَسِيَّةِ، قَالَتْ سَمِعْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم يَخْطُبُ فِي حَجَّةِ الْوَدَاعِ وَعَلَيْهِ بُرْدٌ قَدِ الْتَفَعَ بِهِ مِنْ تَحْتِ إِبْطِهِ قَالَتْ فَأَنَا أَنْظُرُ إِلَى عَضَلَةِ عَضُدِهِ تَرْتَجُّ سَمِعْتُهُ يَقُولُ ‏ ‏ يَا أَيُّهَا النَّاسُ اتَّقُوا اللَّهَ وَإِنْ أُمِّرَ عَلَيْكُمْ عَبْدٌ حَبَشِيٌّ مُجَدَّعٌ فَاسْمَعُوا لَهُ وَأَطِيعُوا مَا أَقَامَ لَكُمْ كِتَابَ اللَّهِ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ أَبِي هُرَيْرَةَ وَعِرْبَاضِ بْنِ سَارِيَةَ ‏.‏ وَهَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ وَقَدْ رُوِيَ مِنْ غَيْرِ وَجْهٍ عَنْ أُمِّ حُصَيْنٍ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الترجل ۱ (۴۱۵۹)، سنن النسائی/الزینة ۷ (۵۰۵۸)، (تحفة الأشراف : ۹۶۵۰)، و مسند احمد (۴/۸۶),,Narrated Umm Al-Husain Al-Ahmasiyyah:,The Book on Jihad
1757,"حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا اللَّيْثُ، عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ السَّمْعُ وَالطَّاعَةُ عَلَى الْمَرْءِ الْمُسْلِمِ فِيمَا أَحَبَّ وَكَرِهَ مَا لَمْ يُؤْمَرْ بِمَعْصِيَةٍ فَإِنْ أُمِرَ بِمَعْصِيَةٍ فَلاَ سَمْعَ عَلَيْهِ وَلاَ طَاعَةَ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ عَلِيٍّ وَعِمْرَانَ بْنِ حُصَيْنٍ وَالْحَكَمِ بْنِ عَمْرٍو الْغِفَارِيِّ ‏.‏ وَهَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih,takhreej: تخریج دارالدعوہ: سنن ابن ماجہ/الطب ۲۵ (۳۴۹۷)، وانظر أیضا: سنن ابی داود/ الطب ۱۴ (۳۸۷۸)، سنن النسائی/الزینة ۲۸ (۵۱۱۶)، (تحفة الأشراف : ۶۱۳۷)، و مسند احمد (۱/۳۵۴)، ویأتي عند المؤلف برقم ۲۰۴۸),,Narrated Ibn 'Umar:,The Book on Jihad
1758,حَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا يَحْيَى بْنُ آدَمَ، عَنْ قُطْبَةَ بْنِ عَبْدِ الْعَزِيزِ، عَنِ الأَعْمَشِ، عَنْ أَبِي يَحْيَى، عَنْ مُجَاهِدٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم عَنِ التَّحْرِيشِ بَيْنَ الْبَهَائِمِ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۱۲۷۸۸)، وانظر: مسند احمد (۲/۳۱۹، ۵۲۹),1758,Narrated Abu Yahya:,The Book on Jihad
1759,حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، عَنْ سُفْيَانَ، عَنِ الأَعْمَشِ، عَنْ أَبِي يَحْيَى، عَنْ مُجَاهِدٍ، أَنَّ النَّبِيَّ صلى الله عليه وسلم نَهَى عَنِ التَّحْرِيشِ بَيْنَ الْبَهَائِمِ ‏.‏ وَلَمْ يَذْكُرْ فِيهِ عَنِ ابْنِ عَبَّاسٍ ‏.‏ وَيُقَالُ هَذَا أَصَحُّ مِنْ حَدِيثِ قُطْبَةَ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/اللباس ۸۳ (۵۹۳۷)، و ۸۵ (۵۹۴۰، ۵۹۴۲)، و ۸۷ (۵۹۴۷)، صحیح مسلم/اللباس ۳۳ (۲۱۲۴)، سنن ابی داود/ الترجل ۵ (۴۱۶۸)، (۲۷۸۴)، سنن النسائی/الزینة ۲۳ (۵۰۹۸)، ۷۲ (۵۲۵۳)، سنن ابن ماجہ/النکاح ۵۲ (۱۹۸۷) (تحفة الأشراف : ۷۹۳۰)، و مسند احمد (۲/۲۱) ویأتي في الأدب ۳۳ (برقم ۲۷۸۳),1759,Abu Yahya reported from Mujahid:,The Book on Jihad
1760,وَرَوَى شَرِيكٌ، هَذَا الْحَدِيثَ عَنِ الأَعْمَشِ، عَنْ مُجَاهِدٍ، عَنِ ابْنِ عَبَّاسٍ، عَنِ النَّبِيِّ صلى الله عليه وسلم نَحْوَهُ وَلَمْ يَذْكُرْ فِيهِ عَنْ أَبِي يَحْيَى ‏.‏ حَدَّثَنَا بِذَلِكَ أَبُو كُرَيْبٍ عَنْ يَحْيَى بْنِ آدَمَ عَنْ شَرِيكٍ ‏.‏ وَرَوَى أَبُو مُعَاوِيَةَ عَنِ الأَعْمَشِ عَنْ مُجَاهِدٍ عَنِ النَّبِيِّ صلى الله عليه وسلم نَحْوَهُ ‏.‏ وَأَبُو يَحْيَى هُوَ الْقَتَّاتُ الْكُوفِيُّ وَيُقَالُ اسْمُهُ زَاذَانُ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ طَلْحَةَ وَجَابِرٍ وَأَبِي سَعِيدٍ وَعِكْرَاشِ بْنِ ذُؤَيْبٍ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/النکاح ۷۱ (۵۱۷۵)، والأشربة ۲۸ (۵۶۳۵)، والمرضی ۴ (۵۶۵۰)، واللباس ۲۸ (۵۸۳۸)، و ۳۶ (۵۸۴۹)، و ۴۵ (۵۸۶۳)، والأدب ۱۲۴ (۶۲۲۲)، صحیح مسلم/اللباس ۲ (۲۰۶۶)، (تحفة الأشراف : ۱۹۱۶)، و مسند احمد (۴/۲۸۴، ۲۹۹) وکلہم في سیاق طویل منہ ہذا الشق,1760,"Sharik narrated this Hadith from Al-A'mash, from Mujahid, from Ibn 'Abbas, from the Prophet (ﷺ) similarly, but he did not mention ""from Abu Yahya"" in it. This was narrated to us by Abu Kuraib from Yahya bin Adam, from Sharik. Abu Mu'awiyah reported it from Al-A'mash, from Mujahid, from the Prophet (ﷺ) similarly. And Abu Yahya is Al-Qattat Al-Kufi, and it is said that his name is Zadhan.\n\n\n[Abu 'Eisa said:",The Book on Jihad
1761,حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا رَوْحُ بْنُ عُبَادَةَ، عَنِ ابْنِ جُرَيْجٍ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، أَنَّ النَّبِيَّ صلى الله عليه وسلم نَهَى عَنِ الْوَسْمِ فِي الْوَجْهِ وَالضَّرْبِ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الرقاق ۱۶ (۶۴۵۶)، صحیح مسلم/اللباس ۶ (۲۰۸۲)، سنن ابی داود/ اللباس ۴۵ (۴۱۴۶)، سنن ابن ماجہ/الزہد ۱۱ (۴۱۵۱)، (تحفة الأشراف : ۱۷۱۰۷)، و مسند احمد (۶/۴۸، ۵۶، ۷۳، ۱۰۸، ۱۰۷),1761,Narrated Jabir:,The Book on Jihad
1762,حَدَّثَنَا مُحَمَّدُ بْنُ الْوَزِيرِ الْوَاسِطِيُّ، حَدَّثَنَا إِسْحَاقُ بْنُ يُوسُفَ الأَزْرَقُ، عَنْ سُفْيَانَ، عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ عُرِضْتُ عَلَى رَسُولِ اللَّهِ صلى الله عليه وسلم فِي جَيْشٍ وَأَنَا ابْنُ أَرْبَعَ عَشَرَةَ فَلَمْ يَقْبَلْنِي ثُمَّ عُرِضْتُ عَلَيْهِ مِنْ قَابِلٍ فِي جَيْشٍ وَأَنَا ابْنُ خَمْسَ عَشَرَةَ فَقَبِلَنِي ‏.‏ قَالَ نَافِعٌ فَحَدَّثْتُ بِهَذَا الْحَدِيثِ عُمَرَ بْنَ عَبْدِ الْعَزِيزِ فَقَالَ هَذَا حَدُّ مَا بَيْنَ الصَّغِيرِ وَالْكَبِيرِ ‏.‏ ثُمَّ كَتَبَ أَنْ يُفْرَضَ لِمَنْ بَلَغَ الْخَمْسَ عَشَرَةَ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan; Zubair Ali Zai: Hasan,takhreej: تخریج دارالدعوہ: سنن ابی داود/ اللباس ۳ (۴۰۲۵)، سنن ابن ماجہ/اللباس ۸ (۳۵۷۵)، (تحفة الأشراف : ۱۸۱۶۹),1762,Narrated Nafi:,The Book on Jihad
1763,حَدَّثَنَا ابْنُ أَبِي عُمَرَ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عُبَيْدِ اللَّهِ، نَحْوَهُ بِمَعْنَاهُ إِلاَّ أَنَّهُ قَالَ قَالَ عُمَرُ بْنُ عَبْدِ الْعَزِيزِ هَذَا حَدُّ مَا بَيْنَ الذُّرِّيَّةِ وَالْمُقَاتِلَةِ ‏.‏ وَلَمْ يَذْكُرْ أَنَّهُ كَتَبَ أَنْ يُفْرَضَ ‏.‏ قَالَ أَبُو عِيسَى حَدِيثُ إِسْحَاقَ بْنِ يُوسُفَ حَدِيثٌ حَسَنٌ صَحِيحٌ غَرِيبٌ مِنْ حَدِيثِ سُفْيَانَ الثَّوْرِيِّ ‏.‏,Ahmad Muhammad Shakir: Sahih; Zubair Ali Zai: Hasan,takhreej: تخریج دارالدعوہ: انظر ما قبلہ,1763,"Another chain with similar, but he (Nafi') said:",The Book on Jihad
1764,"حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا اللَّيْثُ، عَنْ سَعِيدِ بْنِ أَبِي سَعِيدٍ الْمَقْبُرِيِّ، عَنْ عَبْدِ اللَّهِ بْنِ أَبِي قَتَادَةَ، عَنْ أَبِيهِ، أَنَّهُ سَمِعَهُ يُحَدِّثُ، عَنْ رَسُولِ اللَّهِ صلى الله عليه وسلم أَنَّهُ قَامَ فِيهِمْ فَذَكَرَ لَهُمْ أَنَّ الْجِهَادَ فِي سَبِيلِ اللَّهِ وَالإِيمَانَ بِاللَّهِ أَفْضَلُ الأَعْمَالِ فَقَامَ رَجُلٌ فَقَالَ يَا رَسُولَ اللَّهِ أَرَأَيْتَ إِنْ قُتِلْتُ فِي سَبِيلِ اللَّهِ أَيُكَفِّرُ عَنِّي خَطَايَاىَ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏""‏ نَعَمْ إِنْ قُتِلْتَ فِي سَبِيلِ اللَّهِ وَأَنْتَ صَابِرٌ مُحْتَسِبٌ مُقْبِلٌ غَيْرُ مُدْبِرٍ ‏""‏ ‏.‏ ثُمَّ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏""‏ كَيْفَ قُلْتَ ‏""‏ ‏.‏ قُلْتُ أَرَأَيْتَ إِنْ قُتِلْتُ فِي سَبِيلِ اللَّهِ أَيُكَفِّرُ عَنِّي خَطَايَاىَ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏""‏ نَعَمْ وَأَنْتَ صَابِرٌ مُحْتَسِبٌ مُقْبِلٌ غَيْرُ مُدْبِرٍ إِلاَّ الدَّيْنَ فَإِنَّ جِبْرِيلَ قَالَ لِي ذَلِكَ ‏""‏ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ أَنَسٍ وَمُحَمَّدِ بْنِ جَحْشٍ وَأَبِي هُرَيْرَةَ ‏.‏ وَهَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَرَوَى بَعْضُهُمْ هَذَا الْحَدِيثَ عَنْ سَعِيدٍ الْمَقْبُرِيِّ عَنْ أَبِي هُرَيْرَةَ عَنِ النَّبِيِّ صلى الله عليه وسلم نَحْوَ هَذَا وَرَوَى يَحْيَى بْنُ سَعِيدٍ الأَنْصَارِيُّ وَغَيْرُ وَاحِدٍ نَحْوَ هَذَا عَنْ سَعِيدٍ الْمَقْبُرِيِّ عَنْ عَبْدِ اللَّهِ بْنِ أَبِي قَتَادَةَ عَنْ أَبِيهِ عَنِ النَّبِيِّ صلى الله عليه وسلم ‏.‏ وَهَذَا أَصَحُّ مِنْ حَدِيثِ سَعِيدٍ الْمَقْبُرِيِّ عَنْ أَبِي هُرَيْرَةَ ‏.‏",Ahmad Muhammad Shakir: Sahih; Zubair Ali Zai: Hasan,takhreej: تخریج دارالدعوہ: انظر رقم ۱۷۶۲,1764,Narrated 'Abdullah bin Abi Qatadah:,The Book on Jihad
1765,"حَدَّثَنَا أَزْهَرُ بْنُ مَرْوَانَ الْبَصْرِيُّ، حَدَّثَنَا عَبْدُ الْوَارِثِ بْنُ سَعِيدٍ، عَنْ أَيُّوبَ، عَنْ حُمَيْدِ بْنِ هِلاَلٍ، عَنْ أَبِي الدَّهْمَاءِ، عَنْ هِشَامِ بْنِ عَامِرٍ، قَالَ شُكِيَ إِلَى رَسُولِ اللَّهِ صلى الله عليه وسلم الْجِرَاحَاتُ يَوْمَ أُحُدٍ فَقَالَ ‏ ‏ احْفِرُوا وَأَوْسِعُوا وَأَحْسِنُوا وَادْفِنُوا الاِثْنَيْنِ وَالثَّلاَثَةَ فِي قَبْرٍ وَاحِدٍ وَقَدِّمُوا أَكْثَرَهُمْ قُرْآنًا ‏""""‏ ‏.‏ فَمَاتَ أَبِي فَقُدِّمَ بَيْنَ يَدَىْ رَجُلَيْنِ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ خَبَّابٍ وَجَابِرٍ وَأَنَسٍ ‏.‏ وَهَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَرَوَى سُفْيَانُ الثَّوْرِيُّ وَغَيْرُهُ هَذَا الْحَدِيثَ عَنْ أَيُّوبَ عَنْ حُمَيْدِ بْنِ هِلاَلٍ عَنْ هِشَامِ بْنِ عَامِرٍ ‏.‏ وَأَبُو الدَّهْمَاءِ اسْمُهُ قِرْفَةُ بْنُ بُهَيْسٍ أَوْ بَيْهَسٍ ‏.‏""",Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Bashar Awad Maarouf: Hasan; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: سنن ابی داود/ اللباس ۳ (۴۰۲۷)، (تحفة الأشراف : ۱۵۷۶۵),,Narrated Hisham bin 'Amr:,The Book on Jihad
1766,"حَدَّثَنَا هَنَّادٌ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، عَنِ الأَعْمَشِ، عَنْ عَمْرِو بْنِ مُرَّةَ، عَنْ أَبِي عُبَيْدَةَ، عَنْ عَبْدِ اللَّهِ، قَالَ لَمَّا كَانَ يَوْمُ بَدْرٍ وَجِيءَ بِالأُسَارَى قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَا تَقُولُونَ فِي هَؤُلاَءِ الأُسَارَى ‏""""‏ ‏.‏ فَذَكَرَ قِصَّةً فِي هَذَا الْحَدِيثِ طَوِيلَةً ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ عُمَرَ وَأَبِي أَيُّوبَ وَأَنَسٍ وَأَبِي هُرَيْرَةَ ‏.‏ وَهَذَا حَدِيثٌ حَسَنٌ وَأَبُو عُبَيْدَةَ لَمْ يَسْمَعْ مِنْ أَبِيهِ ‏.‏ وَيُرْوَى عَنْ أَبِي هُرَيْرَةَ قَالَ مَا رَأَيْتُ أَحَدًا أَكْثَرَ مَشُورَةً لأَصْحَابِهِ مِنْ رَسُولِ اللَّهِ صلى الله عليه وسلم ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف وأخرجہ النسائي في الکبریٰ)، (تحفة الأشراف : ۱۲۳۹۹),,Narrated Abu 'Ubaidah:,The Book on Jihad
1767,حَدَّثَنَا مَحْمُودُ بْنُ غَيْلاَنَ، حَدَّثَنَا أَبُو أَحْمَدَ، حَدَّثَنَا سُفْيَانُ، عَنِ ابْنِ أَبِي لَيْلَى، عَنِ الْحَكَمِ، عَنْ مِقْسَمٍ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ الْمُشْرِكِينَ، أَرَادُوا أَنْ يَشْتَرُوا، جَسَدَ رَجُلٍ مِنَ الْمُشْرِكِينَ فَأَبَى النَّبِيُّ صلى الله عليه وسلم أَنْ يَبِيعَهُمْ إِيَّاهُ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ غَرِيبٌ لاَ نَعْرِفُهُ إِلاَّ مِنْ حَدِيثِ الْحَكَمِ ‏.‏ وَرَوَاهُ الْحَجَّاجُ بْنُ أَرْطَاةَ أَيْضًا عَنِ الْحَكَمِ ‏.‏ وَقَالَ أَحْمَدُ بْنُ الْحَسَنِ سَمِعْتُ أَحْمَدَ بْنَ حَنْبَلٍ يَقُولُ ابْنُ أَبِي لَيْلَى لاَ يُحْتَجُّ بِحَدِيثِهِ ‏.‏ وَقَالَ مُحَمَّدُ بْنُ إِسْمَاعِيلَ ابْنُ أَبِي لَيْلَى صَدُوقٌ وَلَكِنْ لاَ يُعْرَفُ صَحِيحُ حَدِيثِهِ مِنْ سَقِيمِهِ وَلاَ أَرْوِي عَنْهُ شَيْئًا ‏.‏ وَابْنُ أَبِي لَيْلَى صَدُوقٌ فَقِيهٌ وَإِنَّمَا يَهِمُ فِي الإِسْنَادِ ‏.‏ حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ قَالَ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ دَاوُدَ عَنْ سُفْيَانَ الثَّوْرِيِّ قَالَ فُقَهَاؤُنَا ابْنُ أَبِي لَيْلَى وَعَبْدُ اللَّهِ بْنُ شُبْرُمَةَ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan,takhreej: تخریج دارالدعوہ: سنن ابی داود/ اللباس ۱ (۴۰۲۰)، سنن النسائی/عمل الیوم واللیلة ۱۱۸ (۳۰۹)، (تحفة الأشراف : ۴۳۲۶)، و مسند احمد (۳/۳۰، ۵۰),1767,Narrated Ibn 'Abbas:,The Book on Jihad
1768,"حَدَّثَنَا ابْنُ أَبِي عُمَرَ، حَدَّثَنَا سُفْيَانُ، عَنْ يَزِيدَ بْنِ أَبِي زِيَادٍ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِي لَيْلَى، عَنِ ابْنِ عُمَرَ، قَالَ بَعَثَنَا رَسُولُ اللَّهِ صلى الله عليه وسلم فِي سَرِيَّةٍ فَحَاصَ النَّاسُ حَيْصَةً فَقَدِمْنَا الْمَدِينَةَ فَاخْتَبَيْنَا بِهَا وَقُلْنَا هَلَكْنَا ثُمَّ أَتَيْنَا رَسُولَ اللَّهِ صلى الله عليه وسلم فَقُلْنَا يَا رَسُولَ اللَّهِ نَحْنُ الْفَرَّارُونَ ‏.‏ قَالَ ‏""‏ بَلْ أَنْتُمُ الْعَكَّارُونَ وَأَنَا فِئَتُكُمْ ‏""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ لاَ نَعْرِفُهُ إِلاَّ مِنْ حَدِيثِ يَزِيدَ بْنِ أَبِي زِيَادٍ ‏.‏ وَمَعْنَى قَوْلِهِ فَحَاصَ النَّاسُ حَيْصَةً يَعْنِي أَنَّهُمْ فَرُّوا مِنَ الْقِتَالِ ‏.‏ وَمَعْنَى قَوْلِهِ ‏""‏ بَلْ أَنْتُمُ الْعَكَّارُونَ ‏""‏ ‏.‏ وَالْعَكَّارُ الَّذِي يَفِرُّ إِلَى إِمَامِهِ لِيَنْصُرَهُ لَيْسَ يُرِيدُ الْفِرَارَ مِنَ الزَّحْفِ ‏.‏",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۱۱۵۱۶),1768,Narrated Ibn 'Umar:,The Book on Jihad
1769,حَدَّثَنَا مَحْمُودُ بْنُ غَيْلاَنَ، حَدَّثَنَا أَبُو دَاوُدَ، أَخْبَرَنَا شُعْبَةُ، عَنِ الأَسْوَدِ بْنِ قَيْسٍ، قَالَ سَمِعْتُ نُبَيْحًا الْعَنَزِيَّ، يُحَدِّثُ عَنْ جَابِرٍ، قَالَ لَمَّا كَانَ يَوْمُ أُحُدٍ جَاءَتْ عَمَّتِي بِأَبِي لِتَدْفِنَهُ فِي مَقَابِرِنَا فَنَادَى مُنَادِي رَسُولِ اللَّهِ صلى الله عليه وسلم رُدُّوا الْقَتْلَى إِلَى مَضَاجِعِهِمْ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ قَالَ أَبُو عِيسَى وَنُبَيْحٌ ثِقَةٌ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف، (تحفة الأشراف : ۱۱۵۱۶),1769,Narrated Jabir bin ‘Abdullah :,The Book on Jihad
1770,حَدَّثَنَا ابْنُ أَبِي عُمَرَ، وَسَعِيدُ بْنُ عَبْدِ الرَّحْمَنِ الْمَخْزُومِيُّ، قَالاَ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ الزُّهْرِيِّ، عَنِ السَّائِبِ بْنِ يَزِيدَ، قَالَ لَمَّا قَدِمَ رَسُولُ اللَّهِ صلى الله عليه وسلم مِنْ تَبُوكَ خَرَجَ النَّاسُ يَتَلَقَّوْنَهُ إِلَى ثَنِيَّةِ الْوَدَاعِ ‏.‏ قَالَ السَّائِبُ فَخَرَجْتُ مَعَ النَّاسِ وَأَنَا غُلاَمٌ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏,Ahmad Muhammad Shakir: Hasan; Al-Albani: Hasan; Bashar Awad Maarouf: Hasan,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الخاتم ۷ (۴۲۳۲)، سنن النسائی/الزینة ۴۱ (۵۱۶۴)، (تحفة الأشراف : ۹۸۹۵)، و مسند احمد (۵/۲۳),1770,Narrated As-Sa'ib bin Yazid:,The Book on Jihad
1771,حَدَّثَنَا ابْنُ أَبِي عُمَرَ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عَمْرِو بْنِ دِينَارٍ، عَنِ ابْنِ شِهَابٍ، عَنْ مَالِكِ بْنِ أَوْسِ بْنِ الْحَدَثَانِ، قَالَ سَمِعْتُ عُمَرَ بْنَ الْخَطَّابِ، يَقُولُ كَانَتْ أَمْوَالُ بَنِي النَّضِيرِ مِمَّا أَفَاءَ اللَّهُ عَلَى رَسُولِهِ مِمَّا لَمْ يُوجِفِ الْمُسْلِمُونَ عَلَيْهِ بِخَيْلٍ وَلاَ رِكَابٍ وَكَانَتْ لِرَسُولِ اللَّهِ صلى الله عليه وسلم خَالِصًا وَكَانَ رَسُولُ اللَّهِ صلى الله عليه وسلم يَعْزِلُ نَفَقَةَ أَهْلِهِ سَنَةً ثُمَّ يَجْعَلُ مَا بَقِيَ فِي الْكُرَاعِ وَالسِّلاَحِ عُدَّةً فِي سَبِيلِ اللَّهِ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَرَوَى سُفْيَانُ بْنُ عُيَيْنَةَ هَذَا الْحَدِيثَ عَنْ مَعْمَرٍ عَنِ ابْنِ شِهَابٍ ‏.‏,Al-Albani: Sahih; Zubair Ali Zai: Hasan,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۱۹۵۹۸),1771,Narrated 'Umar bin Al-Khattab:,The Book on Jihad
