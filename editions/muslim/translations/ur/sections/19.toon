{"hadithnumber": "3743", "text": "سہل بن سعد ساعدی رضی اﷲ عنہ سے روایت ہے عویمر عجلانی ،  عاصم بن عدی انصاری کے پاس آیا اور ان سے کہا"}
{"hadithnumber": "3744", "text": "سہل بن سعدؓ سے روایت ہے عویمر انصاریؓ جو بنی عجلان میں سے تھا عاصم بن عدیؓ کے پاس آیا پھر بیان کیا ح"}
{"hadithnumber": "3745", "text": "ابن جریج سے روایت ہے کہ مجھ سے ابن شہاب نے بیان کیا متاعنین کا حال او ران کا طریقہ سہل بن سعدؓ کی حد"}
{"hadithnumber": "3746", "text": "سعید بن جبیرؓ سے روایت ہے مجھ سے پوچھا گیا لعان کرنے والوں کا مسئلہ مصعب بن زبیر کی خلافت میں میں حی"}
{"hadithnumber": "3747", "text": "اس سند سے ہی مندرجہ بالا روایت نقل کی گئی ہے ۔"}
{"hadithnumber": "3748", "text": "عبداﷲ بن عمرؓ سے روایت ہے کہ رسول اﷲ ﷺ نے فرمایا لعان کرنے والوں کو تم دونوں کا حساب اﷲ تعالیٰ پر ہے"}
{"hadithnumber": "3749", "text": "عبداﷲ بن عمرؓ سے روایت ہے رسول اﷲ ﷺ نے جدائی کردی بنی عجلان کی جورو اور مرد میں اور فرمایا اﷲ تعالیٰ"}
{"hadithnumber": "3750", "text": "سعید بن جبیر سے روایت ہے کہ میں نے ابن عمرؓ سے لعان کو پوچھا تو انہوں نے نقل کیا جناب رسول اﷲ ﷺ سے ا"}
{"hadithnumber": "3751", "text": "سعید بن جبیر سے روایت ہے مصعب نے جدائی نہیں کی لعان کرنے والوں میں ۔  میں نے اس کا ذکر کیا عبداﷲ بن"}
{"hadithnumber": "3752", "text": "عبداﷲ بن عمر رضی اﷲ عنہ سے روایت ہے کہ ایک مرد نے لعانلعان کیا رسول اﷲ ﷺ کے زمانے میں پھر آپ نے جدائ"}
{"hadithnumber": "3753", "text": "عبداﷲ بن عمرؓ سے روایت ہے رسول اﷲ ﷺ نے لعان کروایا درمیان ایک مرد انصاری اور اس کی عورت کے اور جدائی"}
{"hadithnumber": "3754", "text": "وہی جو اوپر گزرا ۔"}
{"hadithnumber": "3755", "text": "عبداﷲ بن مسعودؓ سے روایت ہے میں جمعہ کی رات کو مسجد میں تھا اتنے میں ایک مرد انصاری آیا اور بولا اگر"}
{"hadithnumber": "3756", "text": "اعمش سے اس سند کے ساتھ اسی طرح منقول ہے ۔"}
{"hadithnumber": "3757", "text": "محمد سے روایت ہے میں نے انس بن مالک سے پوچھا یہ سمجھ کر کہ ان کو معلوم ہے ۔  انہوں نے کہا کہ ہلال بن"}
{"hadithnumber": "3758", "text": "عبداﷲ بن عباسؓ سے روایت ہے کہ رسول اﷲ ﷺ کے پاس لعان کا ذکر ہوا ۔  عاصم بن عدی نے اس میں کچھ کہا پھر"}
{"hadithnumber": "3759", "text": "ترجمہ دوسری روایت کا وہی ہے جو اوپر گزرا ۔  اس میں اتنا زیادہ ہے کہ وہ شخص جس کے ساتھ تہمت تھی موٹا"}
{"hadithnumber": "3760", "text": "قاسم بن محمد سے روایت ہے ابن عباس رضی اﷲ عنہما کے سامنے لعان والوں کا ذکر ہوا تو عبداﷲ بن شداد نے کہ"}
{"hadithnumber": "3761", "text": "ابوہریرہ رضی اﷲ عنہ سے روایت ہے سعد بن عبادہ انصاریؓ  ( انصار کے رئیس )  نے کہا یا رسول اﷲ ﷺ! اگر کو"}
{"hadithnumber": "3762", "text": "ابوہریرہ رضی اﷲ عنہ سے روایت ہے سعد بن عبادہؓ نے کہا یارسول اﷲ ﷺ! اگر میں اپنی بیوی کے پاس غیر مرد ک"}
{"hadithnumber": "3763", "text": "حضرت ابوہریرہ رضی اﷲ عنہ سے روایت ہے سعد بن عبادہؓ نے کہا  یارسول اﷲﷺ! اگر میں اپنی بیوی کے ساتھ کسی"}
{"hadithnumber": "3764", "text": "مغیرہ بن شعبہؓ سے روایت ہے سعد بن عبادہؓ نے کہا اگر میں اپنی بی بی کے پاس کسی مرد کو دیکھوں تو تلوار"}
{"hadithnumber": "3765", "text": "اس سند سے بھی یہ حدیث مروی ہے اس روایت میں ’’غَیْرَ مُصْفَعٍ ‘  ‘  کے الفاظ ہیں اور ’عَنْہ ‘  ‘  نہی"}
{"hadithnumber": "3766", "text": "ابوہریرہ رضی اﷲ عنہ سے روایت ہے ایک شخص بنی فزارہ میں سے آیا روسل اﷲ ﷺ کے پاس او رکہا میری جورو کو ا"}
{"hadithnumber": "3767", "text": "زہری نے ابن عینیہ کی حدیث کی مانند روایت کی اس میں اتنا فرق ہے کہ کہا اے رسول اﷲ ﷺ! میری عورت نے لڑک"}
{"hadithnumber": "3768", "text": "ابوہریرہ رضی اﷲ عنہ سے روایت ہے کہ تحقیق ایک اعرابی آیا رسول اﷲ ﷺ کے پاس او رکہا اے رسول اﷲ ﷺ! میری"}
{"hadithnumber": "3769", "text": "حضرت ابو ہریرہ رضی اﷲ عنہ نبی اکرم ﷺ سے اسی طرح کی روایت بیان کرتے ہیں ۔"}
