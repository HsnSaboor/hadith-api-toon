{"hadithnumber": "1651", "arabic": "[1651] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ عَلْقَمَۃَ بْنِ أَبِی عَلْقَمَۃَ، عَنْ أُمِّہِ، أَ نَّہَا", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 48, Hadith 1", "international_number": "1651", "narrator_chain": ""}
{"hadithnumber": "1652", "arabic": "[1652] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ مُسْلِمِ بْنِ أبِی مَرْیَمَ، عَنْ أبِی صَالِحٍ، عَنْ أبِی", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Mauquf Daif'}", "reference": "Book 48, Hadith 2", "international_number": "1652", "narrator_chain": ""}
{"hadithnumber": "1653", "arabic": "[1653] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ یَحْیَی بْنِ سَعِیدٍ، عَنِ ابْنِ شِہَابٍ : أَنَّ رَسُولَ الل", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Mauquf Sahih'}", "reference": "Book 48, Hadith 3", "international_number": "1653", "narrator_chain": ""}
{"hadithnumber": "1654", "arabic": "[1654] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ عَبْدِ اللّٰہِ بْنِ دِینَارٍ، عَنْ عَبْدِ اللّٰہِ بْنِ عُمَرَ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 48, Hadith 4", "international_number": "1654", "narrator_chain": ""}
{"hadithnumber": "1655", "arabic": "[1655] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ أبِی الزِّنَادِ، عَنِ الأَعْرَجِ، عَنْ أبِی ہُرَیْرَۃَ، أ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 48, Hadith 5", "international_number": "1655", "narrator_chain": ""}
{"hadithnumber": "1656", "arabic": "[1656] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ نَافِعٍ، وَعَبْدِ اللّٰہِ بْنِ دِینَارٍ، وَزَیْدِ بْنِ أَسْل", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Mauquf Sahih'}", "reference": "Book 48, Hadith 6", "international_number": "1656", "narrator_chain": ""}
{"hadithnumber": "1657", "arabic": "[1657] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنِ الْعَلَائِ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ أَبِیہِ أَ نَّہُ ق", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Mauquf Hasan'}", "reference": "Book 48, Hadith 7", "international_number": "1657", "narrator_chain": ""}
{"hadithnumber": "1658", "arabic": "[1658] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ أبِی بَکْرِ بْنِ نَافِعٍ، عَنْ أَبِیہِ نَافِعٍ مَوْلَی ابْن", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Mauquf Sahih'}", "reference": "Book 48, Hadith 8", "international_number": "1658", "narrator_chain": ""}
{"hadithnumber": "1659", "arabic": "[1659] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ أبِی الزِّنَادِ، عَنِ الأَعْرَجِ، عَنْ أبِی ہُرَیْرَۃَ، أ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 48, Hadith 9", "international_number": "1659", "narrator_chain": ""}
{"hadithnumber": "1660", "arabic": "[1660] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ أبِی الزِّنَادِ، عَنِ الأَعْرَجِ، عَنْ أبِی ہُرَیْرَۃَ، أ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 48, Hadith 10", "international_number": "1660", "narrator_chain": ""}
{"hadithnumber": "1661", "arabic": "[1661] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ عَمِّہِ أبِی سُہَیْلِ بْنِ مَالِکٍ، عَنْ أَبِیہِ، عَنْ کَعْ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 48, Hadith 11", "international_number": "1661", "narrator_chain": ""}
{"hadithnumber": "1662", "arabic": "[1662] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ أبِی الزِّنَادٍ، عَنِ الأَعْرَجِ، عَنْ أبِی ہُرَیْرَۃَ، أ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 48, Hadith 12", "international_number": "1662", "narrator_chain": ""}
{"hadithnumber": "1663", "arabic": "[1663] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ نَافِعٍ، عَنْ عَبْدِ اللّٰہِ بْنِ عُمَرَ : أَنَّ عُمَرَ بْنَ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 48, Hadith 13", "international_number": "1663", "narrator_chain": ""}
{"hadithnumber": "1664", "arabic": "[1664] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ إِسْحَاقَ بْنِ عَبْدِ اللّٰہِ بْنِ أبِی طَلْحَۃَ، أَ نَّہُ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 48, Hadith 14", "international_number": "1664", "narrator_chain": ""}
{"hadithnumber": "1665", "arabic": "[1665] حَدَّثَنِی عَنْ مَالِکٍ، عَنْ رَبِیعَۃَ بْنِ أبِی عَبْدِ الرَّحْمَنِ، عَنْ أَنَسِ بْنِ مَال", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 48, Hadith 15", "international_number": "1665", "narrator_chain": ""}
{"hadithnumber": "1666", "arabic": "[1666] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ نَافِعٍ، عَنْ عَبْدِ اللّٰہِ بْنِ عُمَرَ، أَنَّ رَسُولَ اللّ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 48, Hadith 16", "international_number": "1666", "narrator_chain": ""}
{"hadithnumber": "1667", "arabic": "[1667] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ سَعِیدِ بْنِ أبِی سَعِیدٍ الْمَقْبُرِیِّ، عَنْ أَبِیہِ، عَن", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Maqtu Sahih'}", "reference": "Book 48, Hadith 17", "international_number": "1667", "narrator_chain": ""}
{"hadithnumber": "1668", "arabic": "[1668] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ یَحْیَی بْنِ سَعِیدٍ، عَنْ سَعِیدِ بْنِ الَمُسَیَّبِ، أَ نَّ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 48, Hadith 18", "international_number": "1668", "narrator_chain": ""}
{"hadithnumber": "1669", "arabic": "[1669] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ أبِی الزُّبَیْرِ، عَنْ جَابِرِ بْنِ عَبْدِ اللّٰہِ السَّلَمِ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 48, Hadith 19", "international_number": "1669", "narrator_chain": ""}
{"hadithnumber": "1670", "arabic": "[1670] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنِ ابْنِ شِہَابٍ، عَنْ أبِی بَکْرِ بْنِ عُبَیْدِ اللّٰہِ بْنِ ع", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Mauquf Sahih'}", "reference": "Book 48, Hadith 20", "international_number": "1670", "narrator_chain": ""}
{"hadithnumber": "1776", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ زَيْدِ بْنِ أَسْلَمَ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ الأَنْصَارِيِّ، أَنَّهُ قَالَ خَرَجْنَا مَعَ رَسُولِ اللَّهِ صلى الله عليه وسلم فِي غَزْوَةِ بَنِي أَنْمَارٍ ‏.‏ قَالَ جَابِرٌ فَبَيْنَا أَنَا نَازِلٌ تَحْتَ شَجَرَةٍ إِذَا رَسُولُ اللَّهِ صلى الله عليه وسلم فَقُلْتُ يَا رَسُولَ اللَّهِ هَلُمَّ إِلَى الظِّلِّ ‏.‏ قَالَ فَنَزَلَ رَسُولُ اللَّهِ صلى الله عليه وسلم فَقُمْتُ إِلَى غِرَارَةٍ لَنَا فَالْتَمَسْتُ فِيهَا شَيْئًا فَوَجَدْتُ فِيهَا جِرْوَ قِثَّاءٍ فَكَسَرْتُهُ ثُمَّ قَرَّبْتُهُ إِلَى رَسُولِ اللَّهِ صلى الله عليه وسلم فَقَالَ ‏\"‏ مِنْ أَيْنَ لَكُمْ هَذَا ‏\"‏ ‏.‏ قَالَ فَقُلْتُ خَرَجْنَا بِهِ يَا رَسُولَ اللَّهِ مِنَ الْمَدِينَةِ ‏.‏ قَالَ جَابِرٌ وَعِنْدَنَا صَاحِبٌ لَنَا نُجَهِّزُهُ يَذْهَبُ يَرْعَى ظَهْرَنَا - قَالَ - فَجَهَّزْتُهُ ثُمَّ أَدْبَرَ يَذْهَبُ فِي الظَّهْرِ وَعَلَيْهِ بُرْدَانِ لَهُ قَدْ خَلَقَا - قَالَ - فَنَظَرَ رَسُولُ اللَّهِ صلى الله عليه وسلم إِلَيْهِ فَقَالَ ‏\"‏ أَمَا لَهُ ثَوْبَانِ غَيْرُ هَذَيْنِ ‏\"‏ ‏.‏ فَقُلْتُ بَلَى يَا رَسُولَ اللَّهِ لَهُ ثَوْبَانِ فِي الْعَيْبَةِ كَسَوْتُهُ إِيَّاهُمَا ‏.‏ قَالَ ‏\"‏ فَادْعُهُ فَمُرْهُ فَلْيَلْبَسْهُمَا ‏\"‏ ‏.‏ قَالَ فَدَعَوْتُهُ فَلَبِسَهُمَا ثُمَّ وَلَّى يَذْهَبُ ‏.‏ قَالَ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ مَا لَهُ ضَرَبَ اللَّهُ عُنُقَهُ أَلَيْسَ هَذَا خَيْرًا لَهُ ‏\"‏ ‏.‏ قَالَ فَسَمِعَهُ الرَّجُلُ فَقَالَ يَا رَسُولَ اللَّهِ فِي سَبِيلِ اللَّهِ ‏.‏ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ فِي سَبِيلِ اللَّهِ ‏\"‏ ‏.‏ قَالَ فَقُتِلَ الرَّجُلُ فِي سَبِيلِ اللَّهِ ‏.‏", "grades": "", "reference": "", "international_number": "1776", "narrator_chain": ""}
{"hadithnumber": "1777", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، أَنَّهُ بَلَغَهُ أَنَّ عُمَرَ بْنَ الْخَطَّابِ، قَالَ إِنِّي لأُحِبُّ أَنْ أَنْظُرَ، إِلَى الْقَارِئِ أَبْيَضَ الثِّيَابِ ‏.‏", "grades": "", "reference": "", "international_number": "1777", "narrator_chain": ""}
{"hadithnumber": "1778", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ أَيُّوبَ بْنِ أَبِي تَمِيمَةَ، عَنِ ابْنِ سِيرِينَ، قَالَ قَالَ عُمَرُ بْنُ الْخَطَّابِ إِذَا أَوْسَعَ اللَّهُ عَلَيْكُمْ فَأَوْسِعُوا عَلَى أَنْفُسِكُمْ جَمَعَ رَجُلٌ عَلَيْهِ ثِيَابَهُ ‏.‏", "grades": "", "reference": "", "international_number": "1778", "narrator_chain": ""}
{"hadithnumber": "1779", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ نَافِعٍ، أَنَّ عَبْدَ اللَّهِ بْنَ عُمَرَ، كَانَ يَلْبَسُ الثَّوْبَ الْمَصْبُوغَ بِالْمِشْقِ وَالْمَصْبُوغَ بِالزَّعْفَرَانِ ‏.‏", "grades": "", "reference": "", "international_number": "1779", "narrator_chain": ""}
{"hadithnumber": "1780", "arabic": "قَالَ يَحْيَى وَسَمِعْتُ مَالِكًا، يَقُولُ وَأَنَا أَكْرَهُ، أَنْ يَلْبَسَ الْغِلْمَانُ، شَيْئًا مِنَ الذَّهَبِ لأَنَّهُ بَلَغَنِي أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم نَهَى عَنْ تَخَتُّمِ الذَّهَبِ فَأَنَا أَكْرَهُهُ لِلرِّجَالِ الْكَبِيرِ مِنْهُمْ وَالصَّغِيرِ ‏.‏ قَالَ يَحْيَى وَسَمِعْتُ مَالِكًا يَقُولُ فِي الْمَلاَحِفِ الْمُعَصْفَرَةِ فِي الْبُيُوتِ لِلرِّجَالِ وَفِي الأَفْنِيَةِ قَالَ لاَ أَعْلَمُ مِنْ ذَلِكَ شَيْئًا حَرَامًا وَغَيْرُ ذَلِكَ مِنَ اللِّبَاسِ أَحَبُّ إِلَىَّ ‏.‏", "grades": "", "reference": "", "international_number": "1780", "narrator_chain": ""}
{"hadithnumber": "1781", "arabic": "وَحَدَّثَنِي مَالِكٌ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، زَوْجِ النَّبِيِّ صلى الله عليه وسلم أَنَّهَا كَسَتْ عَبْدَ اللَّهِ بْنَ الزُّبَيْرِ مِطْرَفَ خَزٍّ كَانَتْ عَائِشَةُ تَلْبَسُهُ ‏.‏", "grades": "", "reference": "", "international_number": "1781", "narrator_chain": ""}
{"hadithnumber": "1782", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ عَلْقَمَةَ بْنِ أَبِي عَلْقَمَةَ، عَنْ أُمِّهِ، أَنَّهَا قَالَتْ دَخَلَتْ حَفْصَةُ بِنْتُ عَبْدِ الرَّحْمَنِ عَلَى عَائِشَةَ زَوْجِ النَّبِيِّ صلى الله عليه وسلم وَعَلَى حَفْصَةَ خِمَارٌ رَقِيقٌ فَشَقَّتْهُ عَائِشَةُ وَكَسَتْهَا خِمَارًا كَثِيفًا ‏.‏", "grades": "", "reference": "", "international_number": "1782", "narrator_chain": ""}
{"hadithnumber": "1783", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ مُسْلِمِ بْنِ أَبِي مَرْيَمَ، عَنْ أَبِي صَالِحٍ، عَنْ أَبِي هُرَيْرَةَ، أَنَّهُ قَالَ نِسَاءٌ كَاسِيَاتٌ عَارِيَاتٌ مَائِلاَتٌ مُمِيلاَتٌ لاَ يَدْخُلْنَ الْجَنَّةَ وَلاَ يَجِدْنَ رِيحَهَا وَرِيحُهَا يُوجَدُ مِنْ مَسِيرَةِ خَمْسِمِائَةِ سَنَةٍ ‏.‏", "grades": "", "reference": "", "international_number": "1783", "narrator_chain": ""}
{"hadithnumber": "1784", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ يَحْيَى بْنِ سَعِيدٍ، عَنِ ابْنِ شِهَابٍ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَامَ مِنَ اللَّيْلِ فَنَظَرَ فِي أُفُقِ السَّمَاءِ فَقَالَ ‏ ‏ مَاذَا فُتِحَ اللَّيْلَةَ مِنَ الْخَزَائِنِ وَمَاذَا وَقَعَ مِنَ الْفِتَنِ كَمْ مِنْ كَاسِيَةٍ فِي الدُّنْيَا عَارِيَةٌ يَوْمَ الْقِيَامَةِ أَيْقِظُوا صَوَاحِبَ الْحُجَرِ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1785", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ عَبْدِ اللَّهِ بْنِ دِينَارٍ، عَنْ عَبْدِ اللَّهِ بْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ الَّذِي يَجُرُّ ثَوْبَهُ خُيَلاَءَ لاَ يَنْظُرُ اللَّهُ إِلَيْهِ يَوْمَ الْقِيَامَةِ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1786", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ أَبِي الزِّنَادِ، عَنِ الأَعْرَجِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ لاَ يَنْظُرُ اللَّهُ تَبَارَكَ وَتَعَالَى يَوْمَ الْقِيَامَةِ إِلَى مَنْ يَجُرُّ إِزَارَهُ بَطَرًا ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1787", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ نَافِعٍ، وَعَبْدِ اللَّهِ بْنِ دِينَارٍ، وَزَيْدِ بْنِ أَسْلَمَ، كُلُّهُمْ يُخْبِرُهُ عَنْ عَبْدِ اللَّهِ بْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ لاَ يَنْظُرُ اللَّهُ يَوْمَ الْقِيَامَةِ إِلَى مَنْ يَجُرُّ ثَوْبَهُ خُيَلاَءَ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1788", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنِ الْعَلاَءِ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ أَبِيهِ، أَنَّهُ قَالَ سَأَلْتُ أَبَا سَعِيدٍ الْخُدْرِيَّ عَنِ الإِزَارِ، فَقَالَ أَنَا أُخْبِرُكَ بِعِلْمٍ، سَمِعْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم يَقُولُ ‏ ‏ إِزْرَةُ الْمُؤْمِنِ إِلَى أَنْصَافِ سَاقَيْهِ لاَ جُنَاحَ عَلَيْهِ فِيمَا بَيْنَهُ وَبَيْنَ الْكَعْبَيْنِ مَا أَسْفَلَ مِنْ ذَلِكَ فَفِي النَّارِ مَا أَسْفَلَ مِنْ ذَلِكَ فَفِي النَّارِ لاَ يَنْظُرُ اللَّهُ يَوْمَ الْقِيَامَةِ إِلَى مَنْ جَرَّ إِزَارَهُ بَطَرًا ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1789", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ أَبِي بَكْرِ بْنِ نَافِعٍ، عَنْ أَبِيهِ، نَافِعٍ مَوْلَى ابْنِ عُمَرَ عَنْ صَفِيَّةَ بِنْتِ أَبِي عُبَيْدٍ، أَنَّهَا أَخْبَرَتْهُ عَنْ أُمِّ سَلَمَةَ، زَوْجِ النَّبِيِّ صلى الله عليه وسلم أَنَّهَا قَالَتْ حِينَ ذُكِرَ الإِزَارُ فَالْمَرْأَةُ يَا رَسُولَ اللَّهِ قَالَ ‏\"‏ تُرْخِيهِ شِبْرًا ‏\"‏ ‏.‏ قَالَتْ أُمُّ سَلَمَةَ إِذًا يَنْكَشِفُ عَنْهَا ‏.‏ قَالَ ‏\"‏ فَذِرَاعًا لاَ تَزِيدُ عَلَيْهِ ‏\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "1789", "narrator_chain": ""}
{"hadithnumber": "1790", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ أَبِي الزِّنَادِ، عَنِ الأَعْرَجِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ لاَ يَمْشِيَنَّ أَحَدُكُمْ فِي نَعْلٍ وَاحِدَةٍ لِيُنْعَلْهُمَا جَمِيعًا أَوْ لِيُحْفِهِمَا جَمِيعًا ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1791", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ أَبِي الزِّنَادِ، عَنِ الأَعْرَجِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ إِذَا انْتَعَلَ أَحَدُكُمْ فَلْيَبْدَأْ بِالْيَمِينِ وَإِذَا نَزَعَ فَلْيَبْدَأْ بِالشِّمَالِ وَلْتَكُنِ الْيُمْنَى أَوَّلَهُمَا تُنْعَلُ وَآخِرَهُمَا تُنْزَعُ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1792", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ عَمِّهِ أَبِي سُهَيْلِ بْنِ مَالِكٍ، عَنْ أَبِيهِ، عَنْ كَعْبِ الأَحْبَارِ، أَنَّ رَجُلاً، نَزَعَ نَعْلَيْهِ فَقَالَ لِمَ خَلَعْتَ نَعْلَيْكَ لَعَلَّكَ تَأَوَّلْتَ هَذِهِ الآيَةَ ‏{‏فَاخْلَعْ نَعْلَيْكَ إِنَّكَ بِالْوَادِي الْمُقَدَّسِ طُوًى‏}‏ قَالَ ثُمَّ قَالَ كَعْبٌ لِلرَّجُلِ أَتَدْرِي مَا كَانَتْ نَعْلاَ مُوسَى قَالَ مَالِكٌ لاَ أَدْرِي مَا أَجَابَهُ الرَّجُلُ فَقَالَ كَعْبٌ كَانَتَا مِنْ جِلْدِ حِمَارٍ مَيِّتٍ ‏.‏", "grades": "", "reference": "", "international_number": "1792", "narrator_chain": ""}
{"hadithnumber": "1793", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ أَبِي الزِّنَادِ، عَنِ الأَعْرَجِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّهُ قَالَ نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم عَنْ لِبْسَتَيْنِ وَعَنْ بَيْعَتَيْنِ عَنِ الْمُلاَمَسَةِ وَعَنِ الْمُنَابَذَةِ وَعَنْ أَنْ يَحْتَبِيَ الرَّجُلُ فِي ثَوْبٍ وَاحِدٍ لَيْسَ عَلَى فَرْجِهِ مِنْهُ شَىْءٌ وَعَنْ أَنْ يَشْتَمِلَ الرَّجُلُ بِالثَّوْبِ الْوَاحِدِ عَلَى أَحَدِ شِقَّيْهِ ‏.‏", "grades": "", "reference": "", "international_number": "1793", "narrator_chain": ""}
{"hadithnumber": "1794", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ نَافِعٍ، عَنْ عَبْدِ اللَّهِ بْنِ عُمَرَ، أَنَّ عُمَرَ بْنَ الْخَطَّابِ، رَأَى حُلَّةً سِيَرَاءَ تُبَاعُ عِنْدَ بَابِ الْمَسْجِدِ فَقَالَ يَا رَسُولَ اللَّهِ لَوِ اشْتَرَيْتَ هَذِهِ الْحُلَّةَ فَلَبِسْتَهَا يَوْمَ الْجُمُعَةِ وَلِلْوَفْدِ إِذَا قَدِمُوا عَلَيْكَ ‏.‏ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ إِنَّمَا يَلْبَسُ هَذِهِ مَنْ لاَ خَلاَقَ لَهُ فِي الآخِرَةِ ‏\"‏ ‏.‏ ثُمَّ جَاءَ رَسُولُ اللَّهِ صلى الله عليه وسلم مِنْهَا حُلَلٌ فَأَعْطَى عُمَرَ بْنَ الْخَطَّابِ مِنْهَا حُلَّةً فَقَالَ عُمَرُ يَا رَسُولَ اللَّهِ أَكَسَوْتَنِيهَا وَقَدْ قُلْتَ فِي حُلَّةِ عُطَارِدٍ مَا قُلْتَ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ لَمْ أَكْسُكَهَا لِتَلْبَسَهَا ‏\"‏ ‏.‏ فَكَسَاهَا عُمَرُ أَخًا لَهُ مُشْرِكًا بِمَكَّةَ ‏.‏", "grades": "", "reference": "", "international_number": "1794", "narrator_chain": ""}
{"hadithnumber": "1795", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ إِسْحَاقَ بْنِ عَبْدِ اللَّهِ بْنِ أَبِي طَلْحَةَ، أَنَّهُ قَالَ قَالَ أَنَسُ بْنُ مَالِكٍ رَأَيْتُ عُمَرَ بْنَ الْخَطَّابِ وَهُوَ يَوْمَئِذٍ أَمِيرُ الْمَدِينَةِ وَقَدْ رَقَعَ بَيْنَ كَتِفَيْهِ بِرُقَعٍ ثَلاَثٍ لَبَّدَ بَعْضَهَا فَوْقَ بَعْضٍ ‏.‏", "grades": "", "reference": "", "international_number": "1795", "narrator_chain": ""}
