{"hadithnumber": "254", "text": "سیدہ عائشہ رضی اللہ عنہا زوجہ پیغمبر ﷺ سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا :’’ کوئی بھی ایسا شخص جس"}
{"hadithnumber": "255", "text": "حضرت عائشہ رضی اللہ عنہا زوجہ پیغمبر ﷺ کہتی ہیں کہ میں رسول اللہ ﷺ کے سامنے سو رہی ہوتی اور میرے پاو"}
{"hadithnumber": "256", "text": "نبی کریم ﷺ کی زوجہ محترمہ سیدہ عائشہ رضی اللہ عنہا سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا :’’ جب تم می"}
{"hadithnumber": "257", "text": "اسماعیل بن ابی حکیم رحمہ اللہ سے روایت ہے ، ان کو یہ خبر پہنچی کہ بے شک رسول اللہ ﷺ نے ایک رات ایک ع"}
{"hadithnumber": "258", "text": "زید بن اسلم رحمہ اللہ اپنے والد اسلم سے روایت کرتے ہیں کہ حضرت عمر بن خطاب رضی اللہ عنہ رات کے وقت ن"}
{"hadithnumber": "259", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ سعید بن مسیب رحمہ اللہ کہا کرتے تھے کہ نماز عشاء سے پہلے سونا"}
{"hadithnumber": "260", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ حضرت عبداللہ بن عمر رضی اللہ عنہما کہا کرتے تھے کہ رات اور دن"}
{"hadithnumber": "261", "text": "سیدہ عائشہ رضی اللہ عنہا زوجہ پیغمبر ﷺ سے روایت ہے کہ یقیناً رسول اللہ ﷺ رات کے وقت گیارہ رکعات پڑھا"}
{"hadithnumber": "262", "text": "ابوسلمہ رضی اللہ عنہ بن عبدالرحمن بن عوف نے سیدہ عائشہ رضی اللہ عنہا زوجہ پیغمبر ﷺ سے سوال کیا کہ رس"}
{"hadithnumber": "263", "text": "ام المومنین سیدہ عائشہ رضی اللہ عنہا کہتی ہیں کہ رسول اللہ ﷺ رات کے وقت تیرہ رکعتیں پڑھتے ، پھر جب ص"}
{"hadithnumber": "264", "text": "حضرت عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ انھوں نے زوجہ پیغمبر ﷺ سیدہ میمونہ رضی اللہ عنہا"}
{"hadithnumber": "265", "text": "زید بن خالد جُہنی رضی اللہ عنہ سے روایت ہے کہ انھوں نے کہا کہ میں آج رات ضرور رسول اللہ ﷺ کی ( تہجد"}
{"hadithnumber": "266", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ ایک شخص نے رسول اللہ ﷺ سے رات کی نماز کے متعلق سوا"}
{"hadithnumber": "267", "text": "( عبداللہ ) بن محیریز رضی اللہ عنہ سے روایت ہے کہ ایک شخص جنھیں مخدجیّ کہا جاتا تھا ، نے ملک شام میں"}
{"hadithnumber": "268", "text": "سعید بن یسار رحمہ اللہ سے روایت ہے کہتے ہیں کہ میں مکہ کے راستے میں حضرت عبداللہ بن عمر رضی اللہ عنہ"}
{"hadithnumber": "269", "text": "سعید بن مسیب رحمہ اللہ سے روایت ہے کہ حضرت ابوبکر صدیق رضی اللہ عنہ جب ( سونے کے لیے ) بستر پر آنے ک"}
{"hadithnumber": "270", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ ایک شخص نے حضرت عبداللہ بن عمر رضی اللہ عنہما سے سوال کیا کہ"}
{"hadithnumber": "271", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ سیدہ عائشہ رضی اللہ عنہا زوجہ پیغمبر ﷺ فرمایا کرتی تھیں کہ جس"}
{"hadithnumber": "272", "text": "نافع رحمہ اللہ سے روایت ہے ، کہتے ہیں کہ میں مکہ میں حضرت عبداللہ بن عمر رضی اللہ عنہما کے ساتھ تھا"}
{"hadithnumber": "273", "text": "نافع رحمہ اللہ سے روایت کرتے ہیں کہ یقیناً حضرت عبداللہ بن عمر رضی اللہ عنہما وتر پڑھتے وقت دو رکعتو"}
{"hadithnumber": "274", "text": "ابن شہاب زُہری رحمہ اللہ روایت کرتے ہیں کہ حضرت سعد بن ابی وقّاص رضی اللہ عنہما نماز عشاء کے بعد ایک"}
{"hadithnumber": "275", "text": "عبداللہ بن دینار سے مروی ہے کہ عبداللہ بن عمر رضی اللہ عنہما فرمایا کرتے تھے کہ مغرب کی نماز دن کی ن"}
{"hadithnumber": "276", "text": "سعید بن جبیر رحمہ اللہ روایت کرتے ہیں کہ حضرت عبداللہ بن عباس رضی اللہ عنہما سو گئے ، پھر وہ بیدار ہ"}
{"hadithnumber": "277", "text": "امام مالک رحمہ اللہ سے روایت ہے ، ان کو یہ خبر پہنچی کہ حضرت عبداللہ بن عباس رضی اللہ عنہما ، حضرت ع"}
{"hadithnumber": "278", "text": "ہشام بن عروہ اپنے والد عروہ سے روایت کرتے ہیں کہ حضرت عبداللہ بن مسعود رضی اللہ عنہ نے فرمایا :’’ مج"}
{"hadithnumber": "279", "text": "یحیی بن سعید رحمہ اللہ روایت کرتے ہیں کہ حضرت عبادہ بن صامت رضی اللہ عنہ کچھ لوگوں کی امامت کروایا ک"}
{"hadithnumber": "280", "text": "عبدالرحمن بن قاسم رحمہ اللہ روایت کرتے ہیں کہ میں نے عبداللہ بن عامر بن ربیعہ رحمہ اللہ کو سنا ، وہ"}
{"hadithnumber": "281", "text": "عبدالرحمن بن قاسم رحمہ اللہ روایت کرتے ہیں کہ انھوں نے اپنے والد قاسم بن محمد رحمہ اللہ کو سنا ، وہ"}
{"hadithnumber": "282", "text": "سیدہ حفصہ رضی اللہ عنہا زوجہ پیغمبر ﷺ سے روایت ہے کہ بے شک رسول اللہ ﷺ ( کا یہ معمول تھا کہ ) جب موذ"}
{"hadithnumber": "283", "text": "سیدہ عائشہ رضی اللہ عنہا زوجہ پیغمبر ﷺ سے روایت ہے کہ یقیناً رسول اللہ ﷺ فجر کی دو سنتوں کو ( بہت )"}
