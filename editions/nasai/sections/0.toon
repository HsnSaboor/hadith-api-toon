{"hadithnumber": "3932", "arabic": "أَخْبَرَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ الْمُبَارَكِ، ‏‏‏‏‏‏عَنْ وَكِيعٍ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَ", "grades": "{'name': 'Abu Ghuddah', 'grade': 'Daif Isnaad'},{'name': 'Al-Albani', 'grade': 'Daif Isnaad'}", "reference": "Book 0, Hadith 0", "international_number": "3932", "narrator_chain": ""}
{"hadithnumber": "3933", "arabic": "أَخْبَرَنَا يَحْيَى بْنُ حَبِيبِ بْنِ عَرَبِيٍّ فِي حَدِيثِهِ، ‏‏‏‏‏‏عَنْ حَمَّادِ بْنِ زَيْدٍ، ‏‏‏‏", "grades": "{'name': 'Abu Ghuddah', 'grade': 'Sahih Isnaad Mauquf'},{'name': 'Al-Albani', 'grade': 'Sahih Isnaad Mauquf'}", "reference": "Book 0, Hadith 0", "international_number": "3933", "narrator_chain": ""}
{"hadithnumber": "3934", "arabic": "أَخْبَرَنَا مُحَمَّدُ بْنُ يَحْيَى بْنِ عَبْدِ اللَّهِ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا عَبْدُ اللَّهِ ب", "grades": "{'name': 'Abu Ghuddah', 'grade': 'Sahih Isnaad Maqtu'},{'name': 'Al-Albani', 'grade': 'Sahih Isnaad Maqtu'}", "reference": "Book 0, Hadith 0", "international_number": "3934", "narrator_chain": ""}
{"hadithnumber": "3935", "arabic": "أَخْبَرَنَا عَبْدُ الْمَلِكِ بْنُ شُعَيْبِ بْنِ اللَّيْثِ بْنِ سَعْدٍ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا أ", "grades": "{'name': 'Abu Ghuddah', 'grade': 'Sahih Isnaad Maqtu'},{'name': 'Al-Albani', 'grade': 'Sahih Isnaad Maqtu'}", "reference": "Book 0, Hadith 0", "international_number": "3935", "narrator_chain": ""}
{"hadithnumber": "3936", "arabic": "أَخْبَرَنِي مُحَمَّدُ بْنُ خَالِدِ بْنِ خَلِيٍّ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا بِشْرُ بْنُ شُعَيْبٍ، ‏", "grades": "{'name': 'Abu Ghuddah', 'grade': 'Daif Isnaad Maqtu'},{'name': 'Al-Albani', 'grade': 'Daif Isnaad Maqtu'}", "reference": "Book 0, Hadith 0", "international_number": "3936", "narrator_chain": ""}
{"hadithnumber": "3937", "arabic": "أَخْبَرَنَا أَحْمَدُ بْنُ مُحَمَّدِ بْنِ الْمُغِيرَةِ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا عُثْمَانُ بْنُ سَ", "grades": "{'name': 'Abu Ghuddah', 'grade': 'Daif'},{'name': 'Al-Albani', 'grade': 'Daif'}", "reference": "Book 0, Hadith 0", "international_number": "3937", "narrator_chain": ""}
{"hadithnumber": "3938", "arabic": "قَالَ الْحَارِثُ بْنُ مِسْكِينٍ قِرَاءَةً عَلَيْهِ وَأَنَا أَسْمَعُ:‏‏‏‏ عَنِ ابْنِ وَهْبٍ، ‏‏‏‏‏‏قَ", "grades": "{'name': 'Abu Ghuddah', 'grade': 'Sahih Isnaad Maqtu'},{'name': 'Al-Albani', 'grade': 'Sahih Isnaad Maqtu'}", "reference": "Book 0, Hadith 0", "international_number": "3938", "narrator_chain": ""}
