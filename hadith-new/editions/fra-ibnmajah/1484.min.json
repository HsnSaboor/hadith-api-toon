{"metadata":{"name":"Sunan Ibn Majah","section":{"6":"Chapters Regarding Funerals"},"section_detail":{"6":{"hadithnumber_first":1433,"hadithnumber_last":1637,"arabicnumber_first":1433,"arabicnumber_last":1637}}},"hadiths":[{"hadithnumber":1484,"arabicnumber":1484,"text":"Rapporté par ‘Abdullah bin Mas’ud : Le Messager d’Allah (ﷺ) a dit : “Le cortège funèbre doit être suivi, il ne doit pas suivre. Personne ne doit marcher devant lui.”","grades":[{"name":"Al-Albani","grade":"Daif"},{"name":"Muhammad Fouad Abd al-Baqi","grade":"Daif"},{"name":"Shuaib Al Arnaut","grade":"Daif"},{"name":"Zubair Ali Zai","grade":"Daif"}],"reference":{"book":6,"hadith":52}}]}