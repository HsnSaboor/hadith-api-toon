metadata:
  section_id: 15
  section_name: رسول اللہ صلی اللہ علیہ وسلم کی تلوار کا بیان
  hadith_first: 102
  hadith_last: 105

hadiths[4]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
102,“He (Allah bless him and give him peace) used to wear a signet ring on his right hand.”,,,102,"Anas ibn Malik said:",رسول اللہ صلی اللہ علیہ وسلم کی تلوار کا بیان
103,"""Allah’s Messenger (Allah bless him and give him peace) chose a signet ring of gold, and he used to wear it on his right hand. The people therefore chose signet rings of gold, so he threw it away (Allah bless him and give him peace) and said: 'I shall never wear it!' The people therefore threw their signet rings away.”",,,103,"Ibn 'Umar said:",رسول اللہ صلی اللہ علیہ وسلم کی تلوار کا بیان
104,“Ihe pommel of the sword of Allah’s Messenger (Allah bless him and give him peace) was made of silver.”,,,104,"Anas said:",رسول اللہ صلی اللہ علیہ وسلم کی تلوار کا بیان
105,"“The pommel of the sword of Allah’s Messenger (Allah bless him and give him peace) was made of silver.""",,,105,"Sa'id ibn Abi’l-Hasan al-Basri said:",رسول اللہ صلی اللہ علیہ وسلم کی تلوار کا بیان
