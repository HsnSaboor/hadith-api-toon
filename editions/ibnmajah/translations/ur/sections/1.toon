{"hadithnumber": "643", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  میں حالت حیض میں ہڈی چوستی تھی، پھر رسول اللہ صلی اللہ"}
{"hadithnumber": "644", "text": "انس رضی اللہ عنہ سے روایت ہے کہ  یہود حائضہ عورتوں کے ساتھ نہ تو گھر میں بیٹھتے، نہ ان کے ساتھ کھاتے"}
{"hadithnumber": "645", "text": "ام المؤمنین ام سلمہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم اس مسجد کے صحن میں داخل"}
{"hadithnumber": "646", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے اس عورت کے بارے میں جو"}
{"hadithnumber": "647", "text": "ام عطیہ رضی اللہ عنہا کہتی ہیں کہ  ہم حیض سے  ( پاکی کے بعد )  زرد یا گدلے مادہ کو کچھ بھی نہیں سمجھ"}
{"hadithnumber": "648", "text": "ام المؤمنین ام سلمہ رضی اللہ عنہا کہتی ہیں کہ  نفاس والی عورتیں رسول اللہ صلی اللہ علیہ وسلم کے زمان"}
{"hadithnumber": "649", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے نفاس والی عورتوں کے لیے مدت نفاس کی چا"}
{"hadithnumber": "650", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  جب کوئی شخص حیض کی حالت میں بیوی سے جماع کر لیتا تو نبی"}
{"hadithnumber": "651", "text": "عبداللہ بن سعد رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم سے حائضہ کے ساتھ کھانے"}
{"hadithnumber": "652", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نماز ادا کرتے تھے، اور میں"}
{"hadithnumber": "653", "text": "ام المؤمنین میمونہ رضی اللہ عنہا سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک چادر اوڑھ کر نم"}
{"hadithnumber": "654", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم ان کے پاس تشریف لائے تو"}
{"hadithnumber": "655", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  اللہ تعالیٰ کسی"}
{"hadithnumber": "656", "text": "معاذہ سے روایت ہے کہ  ایک عورت نے ام المؤمنین عائشہ رضی اللہ عنہا سے پوچھا: کیا حائضہ مہندی لگا سکتی"}
{"hadithnumber": "657", "text": "علی بن ابی طالب رضی اللہ عنہ کہتے ہیں کہ  میری ایک کلائی ٹوٹ گئی، میں نے نبی اکرم صلی اللہ علیہ وسلم"}
{"hadithnumber": "658", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم کو دیکھا کہ آپ حسین بن علی رضی"}
{"hadithnumber": "659", "text": "وائل بن حجر رضی اللہ عنہ کہتے ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم کو دیکھا کہ آپ کی خدمت میں"}
{"hadithnumber": "660", "text": "محمود بن ربیع رضی اللہ عنہ سے روایت ہے کہ  ان کو وہ کلی یاد ہے جو رسول اللہ صلی اللہ علیہ وسلم نے ڈو"}
{"hadithnumber": "661", "text": "ابو سعید خدری رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  عورت عورت کے اور"}
{"hadithnumber": "662", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کی شرمگاہ کبھی نہیں"}
{"hadithnumber": "663", "text": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے غسل جنابت کیا تو معمول"}
{"hadithnumber": "664", "text": "علی رضی اللہ عنہ کہتے ہیں کہ  ایک آدمی نبی اکرم صلی اللہ علیہ وسلم کے پاس آیا، اور اس نے عرض کیا ک"}
{"hadithnumber": "665", "text": "انس رضی اللہ عنہ سے روایت ہے کہ  ایک آدمی وضو کر کے نبی اکرم صلی اللہ علیہ وسلم کے پاس آیا، اور اس"}
{"hadithnumber": "666", "text": "عمر بن خطاب رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک آدمی کو دیکھا، جس نے وضو"}
