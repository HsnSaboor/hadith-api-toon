{"hadithnumber": "4829", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ایسے مومن کی مثال جو قرآن پڑھ"}
{"hadithnumber": "4830", "text": "اس سند سے بھی ابوموسیٰ رضی اللہ عنہ سے  شروع سے «طعمها مر»  ( اس کا مزا کڑوا ہے )  تک اسی طرح مرفوعا"}
{"hadithnumber": "4831", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: اچھے ہم نشین کی مثال .."}
{"hadithnumber": "4832", "text": "ابوسعید رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  مومن کے سوا کسی کو ساتھی ن"}
{"hadithnumber": "4833", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  آدمی اپنے دوست کے دین پر"}
{"hadithnumber": "4834", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  روحیں  ( عالم ارواح میں )"}
{"hadithnumber": "4835", "text": "ابوموسیٰ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم جب اپنے صحابہ میں سے کسی کو اپنے کام"}
{"hadithnumber": "4836", "text": "سائب رضی اللہ عنہ کہتے ہیں کہ  میں نبی اکرم صلی اللہ علیہ وسلم کے پاس آیا، تو لوگ میری تعریف اور میر"}
{"hadithnumber": "4837", "text": "عبداللہ بن سلام رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم جب گفتگو کرنے بیٹھتے تو آپ اک"}
{"hadithnumber": "4838", "text": "مسعر کہتے ہیں کہ  میں نے مسجد میں ایک بزرگ کو کہتے سنا کہ میں نے جابر بن عبداللہ رضی اللہ عنہما کو ک"}
{"hadithnumber": "4839", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کی گفتگو کا ہر لفظ الگ الگ"}
{"hadithnumber": "4840", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ہر وہ کلام جس کی ابتد"}
{"hadithnumber": "4841", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  ہر وہ خطبہ جس میں تشہد نہ"}
{"hadithnumber": "4842", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  ان کے پاس سے ایک بھکاری گزرا تو انہوں نے اس کو روٹی کا"}
{"hadithnumber": "4843", "text": "ابوموسیٰ اشعری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  معمر اور سن رسیدہ"}
{"hadithnumber": "4844", "text": "عبداللہ بن عمرو بن عاص رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  دو آدمیو"}
{"hadithnumber": "4845", "text": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  کسی شخص کے لیے"}
{"hadithnumber": "4846", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم جب بیٹھتے تھے تو اپنے ہاتھ سے ا"}
{"hadithnumber": "4847", "text": "قیلہ بنت مخرمہ رضی اللہ عنہا نے خبر دی ہے کہ  انہوں نے نبی اکرم صلی اللہ علیہ وسلم کو دیکھا، آپ دونو"}
{"hadithnumber": "4848", "text": "شرید بن سوید رضی اللہ عنہ کہتے ہیں کہ  میرے پاس سے رسول اللہ صلی اللہ علیہ وسلم گزرے اور میں اس طرح"}
{"hadithnumber": "4849", "text": "ابوبرزہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم عشاء سے پہلے سونے ۱؎ اور اس کے بعد با"}
{"hadithnumber": "4850", "text": "جابر بن سمرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم جب نماز فجر پڑھ لیتے تو چارزانو"}
{"hadithnumber": "4851", "text": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  دو آدمی تیسرے کو"}
{"hadithnumber": "4852", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے اسی کے مثل فرمایا، ابوصال"}
{"hadithnumber": "4853", "text": "سہیل بن ابی صالح کہتے ہیں کہ  میں اپنے والد کے پاس بیٹھا ہوا تھا، ان کے پاس ایک لڑکا تھا، وہ اٹھ کر"}
{"hadithnumber": "4854", "text": "کعب الایادی کہتے ہیں کہ  میں ابو الدرداء کے پاس آتا جاتا تھا تو ابو الدرداء نے کہا: رسول اللہ صلی ال"}
