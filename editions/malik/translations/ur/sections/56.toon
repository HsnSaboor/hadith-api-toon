{"hadithnumber": "1811", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ بلاشبہ مشرق کی جانب ( عراق ) سے دو شخص ( مدینہ منو"}
{"hadithnumber": "1812", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ بے شک حضرت عیسی ابن مریم علیہم السلام فرمایا کرتے تھے : ذکر ا"}
{"hadithnumber": "1813", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ بے شک سیدہ عائشہ رضی اللہ عنہا زوجہ پیغمبر ﷺ عشاء کے بعد اپنے"}
{"hadithnumber": "1814", "text": "مطلب بن عبداللہ بن حنطب مخزومی رحمہ اللہ سے روایت ہے کہ ایک آدمی نے رسول اللہ ﷺ سے سوال کیا کہ غیبت"}
{"hadithnumber": "1815", "text": "عطاء بن یسار رحمہ اللہ سے روایت ہے کہ بے شک رسول اللہ ﷺ نے فرمایا :’’ جس شخص کو اللہ تعالیٰ دو چیزوں"}
{"hadithnumber": "1816", "text": "زید بن اسلم رحمہ اللہ اپنے والد ( اسلم رحمہ اللہ جو حضرت عمر رضی اللہ عنہ کے آزاد کردہ غلام تھے ) سے"}
{"hadithnumber": "1817", "text": "عبداللہ بن دینار رحمہ اللہ سے روایت ہے ، کہتے ہیں : میں اور حضرت عبداللہ بن عمر رضی اللہ عنہما ، حضر"}
{"hadithnumber": "1818", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ نے فرمایا :’’ جب ( کسی جگہ ) تی"}
{"hadithnumber": "1819", "text": "صفوان بن سلیم رحمہ اللہ سے روایت ہے کہ ایک آدمی نے رسول اللہ ﷺ سے عرض کیا : کیا میں اپنی بیوی سے جھو"}
{"hadithnumber": "1820", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ حضرت عبداللہ بن مسعود رضی اللہ عنہ فرمایا کرتے تھے :’’ سچ کو"}
{"hadithnumber": "1821", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ لقمان حکیم سے کہا گیا : آپ کو اس مقام تک کس چیز نے پہنچایا ہے"}
{"hadithnumber": "1822", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ حضرت عبداللہ بن مسعود رضی اللہ عنہ فرمایا کرتے تھے : آدمی مسل"}
{"hadithnumber": "1823", "text": "صفوان بن سلیم رحمہ اللہ سے روایت ہے ، کہتے ہیں کہ رسول اللہ ﷺ سے کہا گیا : کیا مومن بزدل ہو سکتا ہے"}
{"hadithnumber": "1824", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ نے فرمایا :’’ یقیناً اللہ تعالیٰ تمھارے"}
{"hadithnumber": "1825", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ یقیناً رسول اللہ ﷺ نے فرمایا :’’ بدترین لوگوں میں سے دو چہ"}
{"hadithnumber": "1826", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ بے شک سیدہ ام سلمہ رضی اللہ عنہا زوجہ پیغمبر ﷺ نے عرض کیا کہ"}
{"hadithnumber": "1827", "text": "حضرت عمر بن عبدالعزیز رحمہ اللہ سے روایت ہے ، فرماتے ہیں : یہ تو کہا جاتا ہے کہ بے شک اللہ تبارک و ت"}
{"hadithnumber": "1828", "text": "حضرت انس بن مالک رضی اللہ عنہ سے روایت ہے ، کہتے ہیں کہ میں نے حضرت عمر بن خطاب رضی اللہ عنہ کو سنا"}
{"hadithnumber": "1829", "text": "قاسم بن محمد رحمہ اللہ ( بن ابی بکر صدیق رضی اللہ عنہ ) سے روایت ہے ، وہ فرمایا کرتے تھے : میں نے لو"}
{"hadithnumber": "1830", "text": "عامر بن عبداللہ بن زبیر رحمہ اللہ سے روایت ہے کہ جب وہ کڑک کی آواز سنتے تو گفتگو چھوڑ دیتے اور فرمات"}
{"hadithnumber": "1831", "text": "سیدہ عائشہ ام المومنین رضی اللہ عنہا سے روایت ہے کہ بلاشبہ نبی کریم ﷺ کی ازواج مطہرات نے جس وقت کہ ر"}
{"hadithnumber": "1832", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ نے فرمایا :’’ میرے ورثاء دینار تقسیم نہ"}
{"hadithnumber": "1833", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ نے فرمایا :’’ بنو آدم کی وہ آگ جسے وہ ج"}
{"hadithnumber": "1834", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ، انھوں نے فرمایا :’’ کیا تم اس ( جہنم کی آگ ) کو سرخ سمجھتے"}
{"hadithnumber": "1835", "text": "ابوالحباب سعید بن یسار رحمہ اللہ سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ نے فرمایا :’’ جس شخص نے پاکیزہ ("}
{"hadithnumber": "1836", "text": "حضرت انس بن مالک رضی اللہ عنہ سے روایت ہے ، کہتے ہیں : ( ان کے سوتیلے والد ) حضرت ابوطلحہ رضی اللہ ع"}
{"hadithnumber": "1837", "text": "زید بن اسلم رحمہ اللہ سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ نے فرمایا :’’ سائل ( مانگنے والے ) کو دیا کر"}
{"hadithnumber": "1838", "text": "عمرو بن معاذ ( بن سعد بن معاذ ) اشہلی انصاری رحمہ اللہ نے اپنی دادی ( حواء بنت یزید بن سکن رحمۃ اللہ"}
