hadiths[1449]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}: 25812,"حَدَّثنا أَبو بَکْر عَبْد اللہ بنُ مُحَمَّد بن أبی شَیْبۃ قَالَ :\n\n حدَّثَنَا أَبُو مُعَاوِیَۃَ ، وَوَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ تَمِیمِ بْنِ سَلَمَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ ہِلاَلٍ ، عَنْ جَرِیرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ یُحْرَمُ الرِّفْقَ یُحْرَمُ الْخَیْرَ۔\n\n(مسلم 2003۔ ابوداؤد 4776)",,,25812 25813,"حَدَّثَنَا شَرِیکٌ ، عَنِ الْمِقْدَامِ بْنِ شُرَیْحٍ ، عَنْ أَبِیہِ ، قَالَ : سَأَلْتُ عَائِشَۃَ رضی اللہ عنہا عَنِ الْبَِدَاوَۃِ فَقَالَتْ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَبْدُو إِلَی ہَذِہِ التِّلاَعِ ، وَإِنَّہُ أَرَادَ الْبَدَاوَۃَ مَرَّۃً ، فَأَرْسَلَ إلَیَّ نَاقَۃً مُحَرَّمَۃً مِنْ إبِلِ الصَّدَقَۃِ ، فَقَالَ لِی : یَا عَائِشَۃُ ، ارْفُقِی فَإِنَّ الرِّفْقَ لَمْ یَکُنْ فِی شَیْئٍ إلاَّ زَانَہُ ، وَلاَ نُزِعَ مِنْ شَیْئٍ قَطُّ إلاَّ شَانَہُ۔ (ابوداؤد 2470۔ احمد 6/58)",,,25813 25814,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، عَنْ یَعْلَی بْنِ مَمْلَکٍ ، عَنْ أُمِّ الدَّرْدَائِ ، عَنْ أَبِی الدَّرْدَائِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ أُعْطِیَ حَظَّہُ مِنَ الرِّفْقِ ، أُعْطِیَ حَظَّہُ مِنَ الْخَیْرِ ، وَمَنْ مُنِعَ حَظَّہُ مِنَ الرِّفْقِ ، مُنِعَ حَظَّہُ مِنَ الْخَیْرِ۔ (بخاری 464۔ ترمذی 2002)",,,25814 25815,"حَدَّثَنَا شَرِیکٌ ، عَنْ مُحَمَّدِ بْنِ أَبِی إسْمَاعِیلَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ ہِلاَلٍ ، عَنْ جَرِیرٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : مَنْ یُحْرَمُ الرِّفْقَ یُحْرَمُ الْخَیْرَ۔",,,25815 25816,حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ مُحَمَّدِ بْنِ أَبِی إسْمَاعِیلَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ ہِلاَلٍ ، عَنْ جَرِیرٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِنَحْوِہِ۔,,,25816 25817,"حَدَّثَنَا عَبْدَۃُ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، قَالَ : بَلَغَنِی أَنَّہُ مَکْتُوبٌ فِی التَّوْرَاۃِ ، الرِّفْقُ رَأْسُ الْحِکْمَۃِ۔",,,25817 25818,"حَدَّثَنَا وَکِیعٌ، حدثنا ابن أبی خالد، عَنْ قَیْسٍ، قَالَ: کَانَ یُقَالُ: مَنْ یُؤْتَی الرِّفْقَ فِی الدُّنْیَا یَنْفَعْہُ فِی الآخِرَۃِ۔",,,25818 25819,"حَدَّثَنَا وَکِیعٌ ، عَنْ ثَوْرٍ ، عَنْ خَالِدِ بْنِ مَعْدَانَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ اللَّہَ رَفِیقٌ یُحِبُّ الرِّفْقَ ، وَیُعْطِی عَلَیْہِ ، وَیُعِینُ عَلَیْہِ مَا لاَ یُعِینُ عَلَی الْعَنْفِ۔",,,25819 25820,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ یُونُسَ وَحُمَیْدٍ ، عَنِ الْحَسَنِ ، عَنْ عَبْدِ اللہِ بْنِ مُغَفَّلٍ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ اللَّہَ رَفِیقٌ یُحِبُّ الرِّفْقَ وَیَرْضَاہُ ، وَیُعْطِی عَلَیْہِ مَا لاَ یُعْطِی عَلَی الْعَنْفِ۔ (بخاری 672۔ ابوداؤد 4774)",,,25820 25821,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ سَعْدِ بْنِ سَعِیدٍ ، عَنِ الزُّہْرِیِّ ، عَنْ رَجُلٌ مِنْ بَلیّ ، قَالَ : دَخَلْت مَعَ أَبِی عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَانْتَجَاہُ دُونِی ، فَقُلْت لَہُ : یَا أَبَتِ ، أَیُّ شَیْئٍ قَالَ لَکَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ فَقَالَ : قَالَ لِی : إذَا ہَمَمْت بِالأَمْرِ فَعَلَیْک بِالتُّؤَدَۃِ ، حَتَّی یَأْتِیَک اللَّہُ بِالْمَخْرَجِ مِنْ أَمْرِک۔\n\n(بخاری 888)",,,25821 25822,"حَدَّثَنَا أَبُو الأَحْوَص ، عَنْ سِمَاکٍ ، عَنِ الْحَسَنِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ اللَّہَ تَعَالَی رَفِیقٌ یُحِبُّ الرِّفْقَ ، وَیُعْطِی عَلَیْہِ مَا لاَ یُعْطِی عَلَی الْعَنْفِ۔",,,25822 25823,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ زِیَادِ بْنِ عِلاَقَۃَ سَمِعَہُ مِنْ أُسَامَۃَ بْنِ شَرِیکٍ ، قَالَ : قَالَ رَجُلٌ : یَا رَسُولَ اللہِ ، مَا خَیْرُ مَا أُعْطِیَ الْعَبْدُ ؟ قَالَ : خُلُقٌ حَسَنٌ۔",,,25823 25824,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، وَمِسْعَرٍ ، عَنْ زِیَادِ بْنِ عِلاَقَۃَ ، عَنْ أُسَامَۃَ بْنِ شَرِیکٍ ، قَالُوا : یَا رَسُولَ اللہِ، مَا أَفْضَلُ مَا أُعْطِیَ الْمُسْلِمُ ؟ قَالَ : خُلُقٌ حَسَنٌ۔ (طیالسی 1233۔ طبرانی 470)",,,25824 25825,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ زَکَرِیَّا بْنِ سِیَاہٍ أَبِی یَحْیَی ، عَنْ عِمْرَانَ بْنِ رِیَاحٍ ، عَنْ عَلِیِّ بْنِ عُمَارَۃَ ، عَنْ جَابِرِ بْنِ سَمُرَۃَ ، قَالَ : کُنْتُ فِی مَجْلِسٍ فِیہِ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَأَبُو سَمُرَۃَ جَالِسٌ أَمَامِی ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ الْفُحْشَ وَالتَّفَحُّشَ لَیْسَا مِنَ الإِسْلاَمِ فِی شَیْئٍ ، وَإِنَّ أَحْسَنَ النَّاسِ إسْلاَمًا أَحْسَنُہُمْ خُلُقًا۔ (طبرانی 2072)",,,25825 25826,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، وَوَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ شَقِیقٍ ، عَنْ مَسْرُوقٍ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ، قَالَ : لَمْ یَکُنْ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَاحِشًا ، وَلاَ مُتَفَحِّشًا ، وَکَانَ یَقُولُ : إنَّ مِنْ خِیَارِکُمْ مَحَاسِنُکُمْ أَخْلاَقًا۔ (بخاری 3559۔ مسلم 1810)",,,25826 25827,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَکْمَلُ النَّاسِ إیمَانًا وَأَفْضَلُ الْمُؤْمِنِینَ إیمَانًا أَحْسَنُہُمْ خُلُقًا ، وَخِیَارُکُمْ خِیَارُکُمْ لِنِسَائِہِمْ۔ (ابوداؤد 4651۔ احمد 2/250)",,,25827 25828,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ خَالِدٍ ، عَنْ أَبِی قِلاَبَۃَ ، عَنْ عَائِشَۃَ ، قَالَتْ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَکْمَلُ الْمُؤْمِنِینَ إیمَانًا ، أَحْسَنُہُمْ خُلُقًا ، وَأَلْطَفُہُمْ بِأَہْلِہِ۔ (ترمذی 2612۔ حاکم 53)",,,25828 25829,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ دَاوُدَ ، عَنْ مَکْحُولٍ ، عَنْ أَبِی ثَعْلَبَۃَ الْخُشَنِیِّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ أَحَبَّکُمْ إلَیَّ وَأَقْرَبَکُمْ مِنِّی یَوْمَ الْقِیَامَۃِ ، أَحَاسِنُکُمْ أَخْلاَقًا ، وَإِنَّ أَبْعَدَکُمْ مِنِّی وَأَبْغَضَکُمْ إلَیَّ ، مَسَاوِئکُمْ أَخْلاَقًا ، الثَّرْثَارُونَ ، الْمُتَشَدِّقُونَ ، الْمُتَفَیْہِقُونَ۔(احمد 4/193۔ ابن حبان 482)",,,25829 25830,"حَدَّثَنَا أَبُو عَبْدِ الرَّحْمَنِ الْمُقْرِئُ ، عَنْ سَعِیدِ بْنِ أَبِی أَیُّوبَ ، عَنِ ابْنِ عَجْلاَنَ ، عَنِ الْقَعْقَاعِ ، عَنْ أَبِی صَالِحٍ، عَنْ أَبِی ہُرَیْرَۃَ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: أَکْمَلُ الْمُؤْمِنِینَ إیمَانًا أَحْسَنُہُمْ خُلُقًا۔\n\n(احمد 2/527۔ دارمی 2792)",,,25830 25831,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَعْبَدِ بْنِ خَالِدٍ ، عَنْ حَارِثَۃَ بْنِ وَہْبٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَدْخُلُ الْجَنَّۃَ الْجَوَّاظُ ، وَلاَ الْجَعْظَرِیُّ ، وَالْجَوَّاظُ : الْفَظُّ الْغَلِیظُ۔\n\n(مسلم 2190۔ ابوداؤد 4768)",,,25831 25832,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ شُعْبَۃَ ، عَنِ الْقَاسِمِ بْنِ أَبِی بَزَّۃَ ، عَنْ عَطَائٍ الْکَیْخَارَانِیِّ ، عَنْ أُمِّ الدَّرْدَائِ ، عَنْ أَبِی الدَّرْدَائِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : مَا مِنْ شَیْئٍ أَثْقَلُ فِی الْمِیزَانِ مِنْ خُلُقٍ حَسَنٍ۔\n\n(ابوداؤد 4766۔ احمد 6/446)",,,25832 25833,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَبِیبِ بْنِ أَبِی ثَابِتٍ ، عَنْ مَیْمُونِ بْنِ أَبِی شَبِیبٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : یَا مُعَاذُ ، وَقَدْ قَالَ وَکِیعٌ بِأَخَرَۃٍ : یَا أَبَا ذَرٍّ ، أَتْبِعِ السَّیِّئَۃَ الْحَسَنَۃَ تَمْحُہَا ، وَخَالِقِ النَّاسَ خُلُقًا حَسَنًا۔",,,25833 25834,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ مُحَمَّدِ بْنِ الْمُنْکَدِرِ ، عَنْ عُرْوَۃَ ، عَنْ عَائِشَۃَ ، قَالَتْ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ شِرَارَ النَّاسِ یَوْمَ الْقِیَامَۃِ الَّذِی یُتَّقَی مَخَافَۃَ فُحْشِہِ۔ (بخاری 6054۔ ابوداؤد 4758)",,,25834 25835,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الأَحْوَص ، عَنْ عَبْدِ اللہِ ، قَالَ : أَلأَمُ أَخْلاَقِ الْمُؤْمِنِ : الْفُحْشُ۔",,,25835 25836,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، عَنْ حَکِیمِ بْنِ جَابِرٍ ، قَالَ : قَالَ رَجُلٌ لِرَجُلٍ : أَوْصِنِی ، قَالَ : أَتْبِعِ السَّیِّئَۃَ الْحَسَنَۃَ تَمْحُہَا ، وَخَالِقِ النَّاسَ خُلُقًا حَسَنًا۔ (ترمذی 1987)",,,25836 25837,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ ثَابِتِ بْنِ عُبَیْدٍ ، قَالَ : کَانَ زَیْدُ بْنُ ثَابِتٍ مِنْ أَفْکَہِ النَّاسِ إذَا خَلاَ مَعَ أَہْلِہِ ، وَأَزْمَتِہِ إذَا جَلَسَ مَعَ الْقَوْمِ۔",,,25837 25838,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی الضُّحَی ، عَنْ مَسْرُوقٍ ، عَنْ عَائِشَۃَ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ لَہَا : یَا عَائِشَۃُ ، لاَ تَکُونِی فَاحِشَۃً۔ (مسلم 11۔ احمد 6/229)",,,25838 25839,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ زَکَرِیَّا ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْجَدَلِیِّ أَبِی عَبْدِ اللہِ ، قَالَ : قُلْتُ لِعَائِشَۃَ : کَیْفَ کَانَ خُلُقُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ قَالَتْ : کَانَ أَحْسَنَ النَّاسِ خُلُقًا ، لَمْ یَکُنْ فَاحِشًا ، وَلاَ مُتَفَحِّشًا ، وَلاَ سَخَّابًا فِی الأَسْوَاقِ۔ (احمد 6/236۔ ابن حبان 6443)",,,25839 25840,"حَدَّثَنَا أَبُو الأَحْوَص ، عَنْ أَبِی إِسْحَاقَ ، عَنْ رَجُلٍ مِنْ جُہَیْنَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : خَیْرُ مَا أُعْطِیَ الْمُؤْمِنُ خُلُقٌ حَسَنٌ ، وَشَرُّ مَا أُعْطِیَ الرَّجُلُ قَلبٌ سُوئٌ فِی صُورَۃٍ حَسَنَۃٍ۔",,,25840 25841,"حَدَّثَنَا یَزِیدُ بْنُ الْمِقْدَامِ بْنِ شُرَیْحٍ ، عَنْ أَبِیہِ الْمِقْدَامِ بْنِ شُرَیْحٍ ، عَنْ أَبِیہِ شُرَیْحٍ ، عَنْ جَدِّہِ ہَانِئِ بْنِ یَزِیدَ، قَالَ: قُلْتُ: یَا رَسُولَ اللہِ، أَخْبِرْنِی بِشَیْئٍ یُوجِبُ لِی الْجَنَّۃَ، قَالَ: عَلَیْک بِحُسْنِ الْکَلاَمِ، وَبَذْلِ الطَّعَامِ۔\n\n(ابوداؤد 4916۔ نسائی 5940)",,,25841 25842,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ عَبْدِ اللہِ بْنِ سَعِیدٍ ، عَنْ جَدِّہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَنْ تَسَعُوا النَّاسَ بِأَمْوَالِکُمْ فَلْیَسَعْہُمْ مِنْکُمْ بَسْطُ وَجْہٍ ، وَحُسْنُ خُلُقٍ۔ (بزار 1977)",,,25842 25843,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا إسْمَاعِیلُ ، عَنِ الشَّعْبِیِّ ، قَالَ : قَالَ عُمَرُ : حَسَبُ الرَّجُلِ : دِینُہُ ، وَمُرُوئَتُہُ : خُلُقُہُ ، وَأَصْلُہُ : عَقْلُہُ۔",,,25843 25844,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ مُعَاوِیَۃَ بْنِ صَالِحٍ ، قَالَ : أَخْبَرَنِی عَبْدُ الرَّحْمَنِ بْنُ جُبَیْرٍ ، عَنْ أَبِیہِ ، أَنَّہُ سَمِعَ النَّوَّاسَ بْنَ سَمْعَانَ الأَنْصَارِیَّ ، قَالَ : سَأَلْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الْبِرِّ وَالإِثْمِ قَالَ : الْبِرُّ حُسْنُ الْخُلُقِ ، وَالإِثْمُ مَا حَاکَ فِی نَفْسِکَ ، وَکَرِہْت أَنْ یَطَّلِعَ عَلَیْہِ النَّاسُ۔ (بخاری 295۔ مسلم 1980)",,,25844 25845,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا عَبْدُ الْوَارِثِ ، قَالَ : حَدَّثَنَا أَبُو التَّیَّاحِ ، قَالَ : حَدَّثَنَا أَنَسٌ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَحْسَنَ النَّاسِ خُلُقًا۔ (مسلم 267۔ احمد 3/212)",,,25845 25846,"حَدَّثَنَا شَرِیکٌ ، عَنْ خَلَفِ بْنِ حَوْشَبٍ ، عَنْ مَیْمُونِ بْنِ مِہْرَانَ ، قَالَ : قُلْتُ لأُمِّ الدَّرْدَائِ : ما سَمِعْت مِنَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ شیئا ؟ قَالَتْ : نَعَمْ ، دَخَلْت عَلَیْہِ وَہُوَ جَالِسٌ ، أَوْ قَالَتْ فِی الْمَسْجِدِ ، أَوْ ذَکَرَتْ غَیْرَہُ فَسَمِعْتہ یَقُولُ : أَوَّلُ مَا یُوضَعُ فِی الْمِیزَانِ الْخُلُقُ الْحَسَنُ۔ (طبرانی 647)",,,25846 25847,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، قَالَ : مَکْتُوبٌ فِی التَّوْرَاۃِ : یَکُونُ وَجْہُک بَسْطًا وَکَلِمَتُک طَیِّبَۃً تَکُونُ أَحَبَّ إلَی النَّاسِ مِنَ الَّذِینَ یُعْطُونَہُمُ الْعَطَائَ۔",,,25847 25848,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ سُفْیَانَ ، عَنْ سُہَیْلٍ ، عَنْ عَبْدِ اللہِ بْنِ دِینَارٍ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الإِیمَانُ بِضْعٌ وَسِتُّونَ بَابًا ، أَوْ بِضْعٌ وَسَبْعُونَ بَابًا أَعْظَمُہَا لاَ إلَہَ إلاَّ اللَّہُ ، وَأَدْنَاہَا إمَاطَۃُ الأَذَی عَنِ الطَّرِیقِ، وَالْحَیَائُ شُعْبَۃٌ مِنَ الإِیمَانِ۔(بخاری 9۔ مسلم 58)",,,25848 25849,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ ، عَنْ أَبِیہِ ، أنہ قَالَ :سَمِعَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجُلاً یَعِظُ أَخَاہُ فِی الْحَیَائِ ، فَقَالَ : الْحَیَائُ مِنَ الإِیمَانِ۔ (مسلم 59۔ احمد 2/9)",,,25849 25850,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ عَبْدِ اللہِ بْنِ دِینَارٍ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْحَیَائُ شُعْبَۃٌ مِنَ الإِیمَانِ۔ (ابن ماجہ 57۔ نسائی 11737)",,,25850 25851,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، قَالَ : ذَکَرَ عَبْدُ الرَّحْمَنِ بْنُ أَبِی بَکْرَۃَ ، قَالَ : قَالَ أَشَجُّ بَنِی عَصَرَ : قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ فِیک لَخُلُقَیْنِ یُحِبُّہُمَا اللَّہُ ، قَالَ : قُلْتُ : مَا ہُمَا ؟ قَالَ : الْحِلْمُ وَالْحَیَائُ ، قَالَ : قُلْتُ : أَقَدِیمًا کَانَ أَوْ حَدِیثًا ؟ قَالَ : لاَ بَلْ قَدِیمًا ، قُلْتُ : الْحَمْدُ لِلَّہِ الَّذِی جَبَلَنِی عَلَی خُلُقَیْنِ یُحِبُّہُمَا اللَّہُ۔ (نسائی 7746۔ احمد 4/206)",,,25851 25852,"حَدَّثَنَا وَکِیعٌ ، عَنْ خَالِدِ بْنِ رَبَاحٍ ، عَنْ أَبِی السَّوَّارِ ، عَنْ عِمْرَانَ بْنِ حُصَیْنٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْحَیَائُ خَیْرٌ کُلُّہُ۔ (بخاری 6117۔ احمد 4/426)",,,25852 25853,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ الأَعْمَشِ ، عَنْ حَبِیبٍ ، عَنْ مَیْمُونِ بْنِ أَبِی شَبِیبٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: إنَّ اللَّہَ یُحِبُّ الْحَیِیَّ الْحَلِیمَ المتعفف، وَیُبْغِضُ الْفَاحِشَ الْبَذِیئَ السَّائِلَ الْمُلْحِفَ۔",,,25853 25854,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْحَیَائُ مِنَ الإِیمَانِ ، وَالإِیمَانُ فِی الْجَنَّۃِ ، وَالْبَذَائُ مِنَ الْجَفَائِ ، وَالْجَفَائُ فِی النَّارِ۔\n\n(ترمذی 2009۔ احمد 2/501)",,,25854 25855,"حَدَّثَنَا شَبَابَۃُ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ قَتَادَۃَ ، عَنْ مَوْلًی لأَنَسٍ یُقَالُ لَہُ عَبْدُ اللہِ ، قَالَ : سَمِعْتُ أَبَا سَعِیدٍ الْخُدْرِیِّ یَقُولُ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَشَدَّ حَیَائً مِنْ عَذْرَاء فِی خِدْرِہَا ، وَکَانَ إذَا کَرِہَ شَیْئًا عَرَفْنَاہُ فِی وَجْہِہِ۔ (بخاری 3562۔ احمد 3/91)",,,25855 25856,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، عَنْ قَیْسٍ ، قَالَ : دَخَلَ عُیَیْنَۃُ عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَلَمْ یَسْتَأْذِنْ ، فَقَالَتْ عَائِشَۃُ : یَا رَسُولَ اللہِ ، مَنْ ہَذَا ؟ قَالَ : ہَذَا أَحْمَقُ مُطَاعٌ فِی قَوْمِہِ ، قَالَ : ثُمَّ أُتِیَ بِشَرَابٍ فَاسْتَتَرَ ، ثُمَّ شَرِبَ فَقَالَ : یَا رَسُولَ اللہِ ، مَا ہَذَا ؟ قَالَ : ہَذَا الْحَیَائُ خُلَّۃٌ فِیہِمْ أُعْطُوہَا وَمُنِعتموہا۔",,,25856 25857,"حَدَّثَنَا شَرِیکٌ ، عَنْ مَنْصُورٍ ، عَنْ رِبْعِیٍّ ، عَنْ أَبِی مَسْعُودٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: آخِرُ مَا أَدْرَکَ النَّاسُ مِنْ کَلاَمِ النُّبُوَّۃِ: إذَا لَمْ تَسْتَحْیِ فَافْعَلْ مَا شِئْت۔(بخاری 3483۔ احمد 4/122)",,,25857 25858,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَحْوَص بْنِ حَکِیمٍ ، عَنْ أَبِی عَوْنٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : قِلَّۃُ الْحَیَائِ کُفْرٌ۔",,,25858 25859,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ جَرِیرٍ ، عَنْ یَعْلَی بْنِ حَکِیمٍ ، قَالَ : أَکْثَرُ ظَنِّی أَنَّہُ عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : قَالَ ابْنُ عُمَرَ : إنَّ الْحَیَائَ وَالإِیمَانَ قُرِنَا جَمِیعًا ، فَإِذَا رُفِعَ أَحَدُہُمَا رُفِعَ الآخَرُ۔ (حاکم 22)",,,25859 25860,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنْ بَکْرٍ ، قَالَ : الْحَیَائُ مِنَ الإِیمَانِ ، وَالإِیمَانُ فِی الْجَنَّۃِ ، وَالْبَذَائُ مِنَ الْجَفَائِ ، وَالْجَفَائُ فِی النَّارِ۔",,,25860 25861,"حَدَّثَنَا وَکِیعٌ ، عَنْ شَرِیکٍ ، عَنْ سَالِمٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ (وَسَیِّدًا) ، قَالَ : الْحَلِیمُ۔",,,25861 25862,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، قَالَ : أَخْبَرَنِی مَالِکُ بْنُ أَنَسٍ ، قَالَ : أَخْبَرَنِی سَلَمَۃُ بْنُ صَفْوَانَ ، عَنْ یَزِیدَ بْنِ طَلْحَۃَ بْنِ رُکَانَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ لِکُلِّ شَیْئٍ خُلُقًا ، وَخُلُقُ الإِیمَانِ الْحَیَائُ۔ (ابن ماجہ 4181)",,,25862 25863,"حَدَّثَنَا حَفْصٌ ، عَنِ الأَشْعَث ، عَنِ الْحَسَنِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ مِنَ الْحَیَائِ ضَعْفًا ، وَإِنَّ مِنْہُ وَقَارًا لِلَّہِ۔",,,25863 25864,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، عَنْ أَبِی قَابُوسَ مَوْلًی لِعَبْدِ اللہِ بْنِ عَمْرٍو ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو یَبْلُغُ بِہِ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الرَّاحِمُونَ یَرْحَمُہُمُ الرَّحْمَان ، ارْحَمُوا من فی الأَرْضِ یَرْحَمُکُمْ مَنْ فِی السَّمَائِ۔ (ابوداؤد 4902۔ ترمذی 1924)",,,25864 25865,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ نَافِعِ بْنِ جُبَیْرٍ ، عَنْ جَرِیرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَرْحَمُ اللَّہُ مَنْ لاَ یَرْحَمُ النَّاسَ۔ (مسلم 1809)",,,25865 25866,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی ظَبْیَانَ ، عَنْ جَرِیرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَرْحَمُ اللَّہُ مَنْ لاَ یَرْحَمُ النَّاسَ۔",,,25866 25867,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ زَیْدِ بْنِ وَہْبٍ ، عَنْ جَرِیرٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِمِثْلِہِ۔ (بخاری 7376۔ ترمذی 1922),,,25867 25868,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عَامِرٍ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو یَرْوِیہِ ، قَالَ : مَنْ لَمْ یَرْحَمْ صَغِیرَنَا ، وَیَعْرِفْ حَقَّ کَبِیرِنَا ، فَلَیْسَ مِنَّا۔ (ابوداؤد 4904۔ احمد 2/422)",,,25868 25869,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مَنْصُورٍ ، عَنْ أَبِی عُثْمَانَ مَوْلَی الْمُغِیرَۃِ بْنِ شُعْبَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الصَّادِقَ الْمَصْدُوقَ أَبَا الْقَاسِمِ ، صَاحِبَ ہَذِہِ الْحُجْرَۃِ : لاَ تُنْزَعُ الرَّحْمَۃُ إلاَّ مِنْ شَقِیٍّ ، قَالَ شُعْبَۃُ : وَجَدْتہ مَکْتُوبًا عِنْدِی۔ (احمد 2/301۔ طیالسی 2529)",,,25869 25870,"حَدَّثَنَا ابْنُ عُلیَۃَ ، عَنْ زِیَادِ بْنِ مِخْرَاقٍ ، عَنْ مُعَاوِیَۃَ بْنِ قُرَّۃَ ، عَنْ أَبِیہِ ، أَنَّ رَجُلاً ، قَالَ لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنِّی لأَذْبَحُ الشَّاۃَ وَأنا أَرْحَمُہَا ، أَوْ قَالَ : إنِّی لأَرْحَمُ الشَّاۃَ إذَا ذَبَحْتہَا ، فَقَالَ : إنَّ الشَّاۃَ إِنْ رَحِمْتہَا رَحِمَک اللَّہُ مَرَّتَیْنِ۔ (بخاری 373۔ احمد 3/436)",,,25870 25871,"حَدَّثَنَا وَکِیعٌ ، عَنْ قُرَّۃَ بْنِ خَالِدٍ السَّدُوسِیِّ ، عَنْ أَبِی الْعَلاَئِ بْنِ عَبْدِ اللہِ بْنِ الشِّخِّیرِ ، عَنْ أَخِیہِ مُطَرِّفِ بْنِ عَبْدِ اللہِ بْنِ الشِّخِّیرِ ، قَالَ : إنَّ اللَّہَ لَیَرْحَم بِرَحْمَۃِ الْعُصْفُورِ۔",,,25871 25872,"حَدَّثَنَا وَکِیعٌ ، وَعَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ إسْمَاعِیلَ ، عَنْ قَیْسٍ ، عَنْ جَرِیرٍ ، قَالَ : قَالَ رَسُول اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَرْحَمُ اللَّہُ مَنْ لاَ یَرْحَمُ النَّاسَ۔",,,25872 25873,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، قَالَ : أَخْبَرَنَا الأَعْمَشُ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی عُبَیْدَۃَ ، قَالَ : قَالَ عَبْدُ اللہِ : ارْحَمْ مَنْ فِی الأَرْضِ یَرْحَمْکَ مَنْ فِی السَّمَائِ۔",,,25873 25874,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ، عَنْ ہِشَامٍ، عَنْ أَبِیہِ، قَالَ: بَلَغَنِی، أَنَّہُ مَکْتُوبٌ فِی التَّوْرَاۃِ کَمَا تَرْحَمُونَ تُرْحَمُونَ۔",,,25874 25875,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنْ أَبِی عُثْمَانَ ، عَنْ أُسَامَۃَ بْنِ زَیْدٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّمَا یَرْحَمُ اللَّہُ مِنْ عِبَادِہِ الرُّحَمَائَ۔",,,25875 25876,"حَدَّثَنَا وَکِیعٌ وعلی بن ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطَائٍ ، عَنْ جَابِرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ لاَ یَرْحَمْ لاَ یُرْحَمْ۔",,,25876 25877,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عَطَائِ بْنِ یَزِیدَ ، عَنْ أَبِی أَیُّوبَ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، قَالَ : لاَ یَحِلُّ لِمُسْلِمٍ أَنْ یَہْجُرَ أَخَاہُ فَوْقَ ثَلاَثٍ ، یَلْتَقِیَانِ فیَصُدُّ ہَذَا وَیَصُدُّ ہَذَا ، وَخَیْرُہُمَا الَّذِی یَبْدَأُ بِالسَّلاَمِ۔ (مسلم 1984۔ ترمذی 1932)",,,25877 25878,"حَدَّثَنَا یَحْیَی بْنُ آدَم ، عَنْ إسرَائیل ، عَنْ أَبِی إِسْحَاقَ ، عَنْ مُحَمَّدِ بْنِ سَعْدٍ ، عَنْ أَبِیہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لاَ یَحِلُّ لِمُسْلِمٍ أَنْ یَہْجُرَ أَخَاہُ فَوْقَ ثَلاَثٍ۔ (بخاری 246۔ ابویعلی 716)",,,25878 25879,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنْ عُمَارَۃَ بْنِ عُمَیر ، عَنْ أَبِی الأَحْوَص ، قَالَ : قَالَ عَبْدُ اللہِ : لاَ ہِجْرَۃَ بَیْنَ الْمُسْلِمَینِ فَوْقَ ثَلاَثٍ۔",,,25879 25880,"حَدَّثَنَا أَبُو عَبْدِ الرَّحْمَنِ الْمُقْرِئُ ، عَنْ سَعِیدِ بْنِ أَبِی أَیُّوبَ ، عَنْ خَالِدِ بْنِ یَزِیدَ ، عَنْ عَامِرِ بْنِ یَحْیَی الْمَعَافِرِیِّ ، عَنْ فَضَالَۃَ بْنِ عُبَیْدٍ صَاحِبِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : مَنْ ہَاجَرَ أَخَاہُ فَوْقَ ثَلاَثٍ ، فَہُوَ فِی النَّارِ إلاَّ أَنْ یَتَدَارَکَہُ اللَّہُ مِنْہُ بِتَوْبَۃٍ۔",,,25880 25881,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ، عَنْ سُفْیَانَ بْنِ حُسَیْنٍ ، عَنْ أَنَسٍ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، قَالَ: أَلاَ لاَ تَبَاغَضُوا، وَلاَ تَحَاسَدُوا، وَلاَ تَدَابَرُوا، وَکُونُوا عِبَادَ اللہِ إخْوَانًا، وَلاَ یَہْجُرَنَّ أَحَدُکُمْ أَخَاہُ فَوْقَ ثَلاَثَۃِ أَیَّامٍ۔\n\n(بخاری 6065۔ مسلم 1983)",,,25881 25882,"حَدَّثَنَا عُبَیْدُ بْنُ سَعِیدٍ الْقُرَشِیُّ ، عَنْ شُعْبَۃَ ، عَنْ یَزِیدَ بْنِ خُمَیْرٍ ، قَالَ : سَمِعْتُ سُلَیْمَ بْنَ عَامِرٍ یُحَدِّثُ عَنْ أَوْسَطَ بْنِ إسْمَاعِیلَ بْنِ أَوْسَطَ ، أَنَّہُ سَمِعَ أَبَا بَکْرٍ یَقُولُ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تَحَاسَدُوا ، وَلاَ تَبَاغَضُوا ، وَلاَ تَقَاطَعُوا ، وَلاَ تَدَابَرُوا ، وَکُونُوا عِبَادَ اللہِ إخْوَانًا۔\n\n(ابن ماجہ 3849۔ طیالسی 5)",,,25882 25883,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنِ التَّیْمِیِّ ، عَنْ أَنَسٍ ، قَالَ : لاَ ہِجْرَۃَ بَیْنَ الْمُسْلِمَینِ فَوْقَ ثَلاَثٍ۔",,,25883 25884,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ دَاوُدَ بْنِ شَابُورَ ، عَنْ مُجَاہِدٍ ، قَالَ : مَرَّ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِقَوْمٍ یَجُرُّونَ حَجَرًا فَقَالَ : مَا ہَذِہِ ؟ قَالُوا : حَجَرُ الأَشِدَّائِ ، قَالَ : أَلاَ أُخْبِرُکُمْ بِأَشَدِّ مِنْ ہَذَا ؟ الَّذِی یَکُونُ بَیْنَہُ وَبَیْنَ أَخِیہِ فَیَغْلِبُ شَیْطَانَہُ فَیَأْتِیہِ فَیُکَلِّمُہُ۔ (بزار 2053)",,,25884 25885,"حَدَّثَنَا وَکِیعٌ، عَنْ إسْمَاعِیلَ، عَنْ قَیْسٍ، قَالَ: قَالَ عُمَرُ: لاَ یَحِلُّ لِمُسْلِمٍ أَنْ یَہْجُرَ أَخَاہُ فَوْقَ ثَلاَثَۃِ أَیَّامٍ۔",,,25885 25886,"حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ ، عَنْ مُحَمَّدِ بْنِ ہِلاَلٍ ، عَنْ أَبِیہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَحِلُّ لِمُسْلِمٍ أَنْ یَہْجُرَ أَخَاہُ فَوْقَ ثَلاَثٍ۔ (مسلم 1984۔ ابوداؤد 4878)",,,25886 25887,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ التَّیْمِیِّ ، عَنِ الْحَارِثِ بْنِ سُوَیْد ، عَنْ عَبْدِ اللہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَا تَعُدُّونَ الصُّرَعَۃَ فِیکُمْ ؟ قَالَ : الَّذِی لاَ یَصْرَعُہُ الرِّجَالُ ، قَالَ : لاَ وَلَکِنَّہُ الَّذِی یَمْلِکُ نَفْسَہُ عِنْدَ الْغَضَبِ۔ (مسلم 2014۔ ابوداؤد 4746)",,,25887 25888,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : یَسِّرُوا ، وَلاَ تُعَسِّرُوا ، قَالَہَا ثَلاَثًا فَإِذَا غَضِبْتَ فَاسْکُتْ۔ (بزار 152)",,,25888 25889,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنِ الأَحْنَفِ بْنِ قَیْسٍ ، عَنِ ابْنِ عَمٍّ لَہُ مِنْ تَمِیمٍ ، عَنْ جَارِیَۃَ بْنِ قُدَامَۃَ ، أَنَّہُ قَالَ : یَا رَسُولَ اللہِ ، قُلْ لِی قَوْلاً وَأَقِلَّ لَعَلِّی أَعِیہِ ، قَالَ : لاَ تَغْضَبْ ، فَأَعَادَ عَلَیْہِ مِرَارًا کُلُّ ذَلِکَ یَقُولُ : لاَ تَغْضَبْ۔ (احمد 3/484)",,,25889 25890,حَدَّثَنَا عَبْدَۃُ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، عَنِ الأَحْنَفِ بْنِ قَیْسٍ ، عَنْ جَارِیَۃَ بْنِ قُدَامَۃَ ، عَنِ ابْنِ عَمٍّ لَہُ مِنْ بَنِی تَمِیمٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، مِثْلَہُ۔ (طبرانی 2104),,,25890 25891,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ عَدِیِّ بْنِ ثَابِتٍ ، عَنْ سُلَیْمَانَ بْنِ صُرَدٍ ، قَالَ : اسْتَبَّ رَجُلاَنِ عِنْدَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَجَعَلَ أَحَدُہُمَا تَحْمَرُّ عَیْنَاہُ وَتَنْتَفِخُ أَوْدَاجُہُ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنِّی لأَعْرِفُ کَلِمَۃً لَوْ قَالَہَا ہَذَا لَذَہَبَ عَنْہُ الَّذِی یَجِدُ : أَعُوذُ بِاللَّہِ مِنَ الشَّیْطَانِ الرَّجِیمِ فَقَالَ : الرَّجُلُ : وَہَلْ تَرَی بِی مِنْ جُنُونٍ۔ (مسلم 2015۔ ابوداؤد 47481)",,,25891 25892,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ عَبْدِ الْمَلِکِ بْنِ عُمَیْرٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، عَنْ مُعَاذٍ ، قَالَ : اسْتَبَّ رَجُلاَنِ عِنْدَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَغَضِبَ أَحَدُہُمَا غَضَبًا شَدِیدًا حَتَّی أَنَّہُ لَیُخَیَّلُ إلَیَّ أَنَّ أَنْفَہُ یَتَمَزَّعُ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنِّی لأَعْرِفُ کَلِمَۃً لَوْ قَالَہَا ہَذَا الْغَضْبَانُ لَذَہَبَ غَضَبُہُ : أَعُوذُ بِاللَّہِ الْعَظِیمِ مِنَ الشَّیْطَانِ الرَّجِیمِ۔ (ابوداؤد 4747۔ ترمذی 3452)",,,25892 25893,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ عَلِیِّ بْنِ زَیْدٍ ، عَنْ أَبِی نَضْرَۃَ ، عَنْ أَبِی سَعِیدٍ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : اتَّقُوا الْغَضَبَ فَإِنَّہَا جَمْرَۃٌ تُوقَدُ فِی قَلْبِ ابْنِ آدَمَ ، أَلَمْ تَرَ إلَی انْتِفَاخِ أَوْدَاجِہِ وَحُمْرَۃِ عَیْنَیْہِ ، فَمَنْ أَحَسَّ مِنْ ذَلِکَ شَیْئًا فَلْیَلْزِقْ بِالأَرْضِ۔ (بخاری 2842۔ مسلم 121)",,,25893 25894,"حَدَّثَنَا دَاوُد بْنُ عَبْدِ اللہِ ، قَالَ : أَخْبَرَنَا مَالِکُ بْنُ أَنَسٍ ، عَنِ ابْنِ شِہَابٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَیْسَ الشَّدِیدُ بِالصُّرَعَۃِ ، إنَّمَا الشَّدِیدُ الَّذِی یَمْلِکُ نَفْسَہُ عِنْدَ الْغَضَبِ۔ (بخاری 6114۔ مسلم 107)",,,25894 25895,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ حُمَیْدِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ رَجُلٍ مِنْ أَصْحَابِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أَنَّہُ أَتَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجُل ، فَقَالَ : أَوْصِنِی بِکَلِمَۃٍ ، وَلاَ تُکْثِرْ عَلَیَّ ، قَالَ : اجْتَنِبِ الْغَضَبَ ، فَأَعَادَ عَلَیْہِ فَقَالَ : اجْتَنِبِ الْغَضَبَ ، فَأَعَادَ عَلَیْہِ فَقَالَ : اجْتَنِبِ الْغَضَبَ۔\n\n(احمد 5/408۔ مالک 906)",,,25895 25896,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ أَبِی سَلَمَۃَ بْنِ عَبْدِ الرَّحْمَنِ ، أَنَّ عَبْدَ الرَّحْمَن بن عوف عَادَ أَبَا الرَّدَّادِ فَقَالَ : خَیْرُہُمْ وَأَوْصَلُہُمْ أَبُو مُحَمَّدٍ یَعْنِی ابْنَ عَوْفٍ ، سَمِعْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : قَالَ اللَّہُ : أَنَا اللَّہُ وَأَنَا الرَّحْمَان ، وَہِیَ الرَّحِمُ ، شَقَقْت لَہَا اسْمًا مِنِ اسْمِی ، فَمَنْ وَصَلَہَا وَصَلْتُہْ ، وَمَنْ قَطَعَہَا بَتَتُّہُ۔ (ترمذی 1907۔ ابوداؤد 1691)",,,25896 25897,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُعَاوِیَۃَ بْنِ أَبِی مُزَرِّدٍ ، عَنْ یَزِیدَ بْنِ رُومَانَ ، عَنْ عُرْوَۃَ ، عَنْ عَائِشَۃَ ، قَالَتْ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الرَّحِمُ مُعَلَّقَۃٌ بِالْعَرْشِ ، تَقُولُ : مَنْ وَصَلَنِی وَصَلَہُ اللَّہُ ، وَمَنْ قَطَعَنِی قَطَعَہُ اللَّہُ۔ (بخاری 5989۔ مسلم 1981)",,,25897 25898,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَوْفٍ ، عَنْ زُرَارَۃَ بْنِ أَوْفَی ، عَنْ عَبْدِ اللہِ بْنِ سَلاَمٍ ، قَالَ : لَمَّا قَدِمَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْمَدِینَۃَ انْجَفَلَ النَّاسُ نَحْوَہُ فَأَتَیْتہ ، فَلَمَّا نَظَرْت إلَیْہِ عَرَفْت أَنَّ وَجْہَہُ لَیْسَ بوَجْہِ کَذَّابٍ ، فَکَانَ أَوَّلَ شَیْئٍ سَمِعْتہ یَقُولُ: یَا أَیُّہَا النَّاسُ ، أَفْشُوا السَّلاَمَ ، وَصِلُوا الأَرْحَامَ ، وَأَطْعِمُوا الطَّعَامَ، وَصَلُّوا بِاللَّیْلِ وَالنَّاسُ نِیَامٌ۔ (ترمذی 2485۔ احمد 5/451)",,,25898 25899,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ عَطَائِ بْنِ أَبِی مَرْوَانَ ، عَنْ أَبِیہِ ، عَنْ کَعْبٍ ، قَالَ : وَالَّذِی فَلَقَ الْبْحَر لِبَنِی إسْرَائِیلَ ، إنَّ فِی التَّوْرَاۃِ مَکْتُوبا : ابْنَ آدَمَ ، اتَّقِ رَبَّک ، وَابْرَرْ وَالِدَیْک ، وَصِلْ رَحِمَک ، أَمُدُّ لَکَ فِی عُمْرِکَ ، وَأُیَسِّرُ لَکَ یُسْرَک ، وَأَصْرِفُ عَنْک عُسْرَک۔",,,25899 25900,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ مَغْرَائَ ، عَنِ ابْنِ عُمَرَ ، قَالَ : مَنِ اتَّقَی رَبَّہُ وَوَصَلَ رَحِمَہُ نُسِئَ لَہُ فِی عُمْرِہِ ، وَثَرَا مَالُہُ ، وَأَحَبَّہُ أَہْلُہُ۔ (بخاری 5985)",,,25900 25901,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی عَاصِمٍ الثَّقَفِیِّ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ اللہِ بْنِ قَارِبٍ ، قَالَ : سَمِعْتُ عَبْدَ اللہِ بْنَ عَمْرٍو یَقُولُ بِلِسَانٍ لَہُ ذُلَقٍ : إنَّ الرَّحِمَ مُعَلَّقَۃٌ بِالْعَرْشِ تُنَادِی بِلِسَانٍ لَہَا ذُلَقٍ : اللَّہُمَّ صِلْ مَنْ وَصَلَنِی ، وَاقْطَعْ مَنْ قَطَعَنِی۔ (طیالسی 2250)",,,25901 25902,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، قَالَ : أَخْبَرَنَا قَتَادَۃُ ، عَنْ أَبِی ثُمَامَۃَ الثَّقَفِیِّ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : تُوضَعُ الرَّحِمُ یَوْمَ الْقِیَامَۃِ ، وَلَہَا حُجْنَۃٌ کَحُجْنَۃِ الْمِغْزَلِ ، تَکَلَّمُ بِأَلْسِنَۃ طُلَقٍ ذُلَقٍ ، فَتَصِلُ مَنْ وَصَلَہَا ، وَتَقْطَعُ مَنْ قَطَعَہَا۔ (احمد 2/189)",,,25902 25903,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ شُعْبَۃَ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الْجَبَّارِ ، عَنْ مُحَمَّدِ بْنِ کَعْبٍ الْقُرَظِیِّ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : الرَّحِمُ شُجْنَۃٌ مِنَ الرَّحْمَن ، تَجِیئُ یَوْمَ الْقِیَامَۃِ ، تَقُولُ: یَا رَبِّ قُطِعْتُ ، یَا رَبِّ ظُلِمْتُ ، یَا رَبِّ أُسِیئَ إلَیَّ۔ (بخاری 65۔ احمد 2/295)",,,25903 25904,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، قَالَ : حدَّثَنَا مُوسَی بْنُ عُبَیْدَۃَ ، قَالَ : حَدَّثَنَا الْمُنْذِرُ بْنُ جَہْمٍ الأَسْلَمِیُّ ، عَنْ نَوْفَلِ بْنِ مُسَاحِقٍ ، عَنْ أُمِّ سَلَمَۃَ ، قَالَتْ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الرَّحِمُ شُجْنَۃٌ آخِذَۃٌ بِحُجْزَۃِ الرَّحْمَن تُنَاشِدُ حَقَّہَا فَیَقُولُ : أَلاَ تَرْضِینَ أَنْ أَصِلَ مَنْ وَصَلَکِ ، وَأَقْطَعَ مَنْ قَطَعَکِ ، مَنْ وَصَلَکِ فَقَدْ وَصَلَنِی ، وَمَنْ قَطَعَکِ فَقَدْ قَطَعَنِی۔ (طبرانی 970)",,,25904 25905,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : حدَّثَنَا فِطْرٌ ، عَنْ مُجَاہِدٍ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ الرَّحِمَ مُعَلَّقَۃٌ بِالْعَرْشِ وَلَیْسَ الْمُوَاصِلُ بِالْمُکَافِئِ ، وَلَکِنَّ الْمُوَاصِل الَّذِی إذَا انْقَطَعَتْ رَحِمُہُ وَصَلَہَا۔ (احمد 2/193۔ ابن حبان 445)",,,25905 25906,"حَدَّثَنَا شَرِیکٌ ، عَنْ سِمَاکٍ ، عَنْ زَوْجِ دُرَّۃَ ، عَنْ دُرَّۃَ ، قَالَتْ : قُلْتُ : یَا رَسُولَ اللہِ ، مَنْ أَتْقَی النَّاسِ ؟ قَالَ : آمِرُہُمْ بِالْمَعْرُوفِ وَأَنْہَاہُمْ عَنِ الْمُنْکَرِ ، وَأَوْصَلُہُمْ لِلرَّحِمِ۔ (طبرانی 657۔ احمد 6/432)",,,25906 25907,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ سُہَیْلِ بْنِ أَبِی صَالِحٍ ، عَنْ أَبِیہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَجْزِی وَلَدٌ وَالِدَہُ إلاَّ أَنْ یَجِدَہُ مَمْلُوکًا فَیَشْتَرِیَہُ فَیُعْتِقَہُ۔",,,25907 25908,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الْوَلِیدِ بْنِ الْعَیْزَارِ ، عَنْ سَعْدِ بْنِ إیَاسٍ أَبِی عَمْرٍو الشَّیْبَانِیِّ، عَنِ ابْنِ مَسْعُودٍ ، قَالَ : قُلْتُ : یَا رَسُولَ اللہِ ، أَیُّ الأَعْمَالِ أَفْضَلُ ؟ قَالَ : الصَّلاَۃُ لِمِیقَاتِہَا ، قَالَ : قُلْتُ : ثُمَّ أَیُّ ؟ قَالَ : بِرُّ الْوَالِدَیْنِ۔",,,25908 25909,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ، عَنْ أَبِی الدَّرْدَائِ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : الْوَالِدُ أَوْسَطُ أَبْوَابِ الْجَنَّۃِ ، فَإِنْ شِئْتَ فَاحْفَظْہُ ، وَإِنْ شِئْتَ فَضَیِّعْہُ۔ (ترمذی 1900۔ احمد 5/196)",,,25909 25910,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : لِلأُمِّ ثُلُثَا الْبِرِّ وَلِلأََبِ الثُّلُثُ۔",,,25910 25911,"حَدَّثَنَا شَرِیکٌ ، عَنْ مَنْصُورٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عَلِیٍّ ، عَنْ أَبِی سَلاَمَۃَ السُّلامِیِّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أُوصِی امْرَئًا بِأُمِّہِ ثَلاَثًا أُوصِی امْرَئًا بِأَبِیہِ ، أُوصِی امْرَئًا بِمَوْلاَہُ الَّذِی یَلِیہِ ، وَإِنْ کَانَ عَلَیْہِ مِنْہُ أَذًی یُؤْذِیہِ۔ (احمد 4/311۔ طبرانی 4184)",,,25911 25912,"حَدَّثَنَا شَرِیکٌ ، عَنْ عُمَارَۃَ بْنِ الْقَعْقَاعِ ، وَابْنِ شُبْرُمَۃَ ، عَنْ أَبِی زُرْعَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : جَائَ رَجُلٌ إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقَالَ : یَا رَسُولَ اللہِ ، نَبِّئْنِی بِأَحَقِّ النَّاسِ مِنِّی بِحُسْنِ الصُّحْبَۃِ ، فَقَالَ: نَعَمْ ، وَأَبِیک لَتُنَبَّأَنَّ ، أُمُّک ، قَالَ : ثُمَّ مَنْ ؟ قَالَ : أُمُّک ، قَالَ : ثُمَّ مَنْ ؟ قَالَ : أَبُوکَ۔\n\n(مسلم 1974۔ بخاری 5971)",,,25912 25913,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عُمَارَۃَ أَبِی سَعِیدٍ ، قَالَ : قُلْتُ لِلْحَسَنِ : إلَی مَا یَنْتَہِی الْعُقُوقُ ؟ قَالَ : أَنْ تُحَرِّمَہُمَا وَتَہْجُرَہُمَا وَتَحُدَّ النَّظَرَ إلَی وَجْہِ وَالِدَیْک ، یَا عُمَارَۃُ ، کَیْفَ الْبِرُّ لَہُمَا۔",,,25913 25914,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَسْمَائَ بْنِ عُبَیْدٍ ، عَنْ یُونُسَ بْنِ عُبَیْدٍ ، قَالَ : یُرْجَی لِلْمُرْہَقِ بِالْبِرِّ الْجَنَّۃُ ، وَیُخَافُ عَلَی المتألہ بِالْعُقُوقِ النَّارُ۔",,,25914 25915,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : بِرُّ الْوَالِدَیْنِ یُجْزِئُ مِنَ الْجِہَادِ۔ (بخاری 3004۔ مسلم 1975)",,,25915 25916,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا سُلَیْمَانُ التَّیْمِیُّ ، عَنْ سَعْدِ بْنِ مَسْعُودٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : مَا مِنْ مُسْلِمٍ لَہُ أَبَوَانِ فَیُصْبِحُ وَہُوَ مُحْسِنٌ إلَیْہِمَا إلاَّ فَتَحَ اللَّہُ لَہُ بَابَیْنِ مِنَ الْجَنَّۃِ ، وَلاَ یُمْسِی وَہُوَ مُسِیئٌ إلَیْہِمَا إلاَّ فَتَحَ اللَّہُ لَہُ بَابَیْنِ مِنَ النَّارِ ، وَلاَ سَخِطَ عَلَیْہِ وَاحِدٌ مِنْہُمَا فَیَرْضَی اللَّہُ عَنْہُ حَتَّی یَرْضَی عَنْہُ ، قَالَ: قُلْتُ : وَإِنْ کَانَا ظَالِمَیْنِ ؟ قَالَ : وَإِنْ کَانَا ظَالِمَیْنِ۔",,,25916 25917,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنْ سَالِمِ بْنِ أَبِی الْجَعْدِ ، وَمُجَاہِدٍ ، عَنْ أَبِی سَعِیدٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَدْخُلُ الْجَنَّۃَ عَاقٌ ، وَلاَ مُدْمِنُ خَمْرٍ ، وَلاَ مَنَّانٌ۔",,,25917 25918,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُعَاوِیَۃَ بْنِ إِسْحَاقَ ، عَنْ عُرْوَۃَ بْنِ الزُّبَیْرِ ، قَالَ : مَا بَرَّ وَالِدَہُ مَنْ شَدَّ الطَّرْفَ إلَیْہِ۔",,,25918 25919,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ : {فَلاَ تَقُلْ لَہُمَا أُفٍّ} قَالَ : إذَا بَلَغَا مِنَ الْکِبَرِ مَا کَانَ یَلِیَانِ مِنْہُ فِی الصِّغَرِ فَلاَ یَقُلْ لَہُمَا أُفٍّ۔",,,25919 25920,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ مُحَمَّدِ بْنِ طَلْحَۃَ بْنِ مُعَاوِیَۃَ بْنِ جَاہِمۃ السُّلَمِیِّ ، عَنْ أَبِیہِ ، قَالَ : أَتَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقُلْت : یَا رَسُولَ اللہِ ، إنِّی أُرِیدُ الْجِہَادَ مَعَک فِی سَبِیلِ اللہِ ، قَالَ : فَقَالَ : أُمُّکَ حَیَّۃٌ ؟ قَالَ : قُلْتُ : نَعَمْ ، یَا رَسُولَ اللہِ ، قَالَ : الْزَمْ رِجْلَیْہَا فَثَمَّ الْجَنَّۃُ۔ (ابن ماجہ 2781۔ حاکم 151)",,,25920 25921,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا ہِشَامُ بْنُ عُرْوَۃَ ، عَنْ أَبِیہِ {فَلاَ تَقُلْ لَہُمَا أُفٍّ} قَالَ : لاَ تَمْنَعْہُمَا شَیْئًا أَرَادَاہُ ، أَوْ قَالَ : أَحَبَّاہُ۔",,,25921 25922,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ مَیْمُونِ بْنِ أَبِی شَبِیبٍ ، قَالَ : قیلَ لِمُعَاذِ بْنِ جَبَلٍ مَا حَقُّ الْوَالِدِ عَلَی الْوَلَدِ ؟ قَالَ : لَوْ خَرَجْت مِنْ أَہْلِکَ وَمَالِکَ مَا أَدَّیْت حَقَّہُمَا قَالَ شُعْبَۃُ : وَإِنَّمَا حَدَّثَنِی بِہِ مَنْصُورُ بْنُ زَاذَانَ ، عَنِ الْحَکَمِ۔",,,25922 25923,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مَنْصُورٍ ، عَنْ سَالِمِ بْنِ أَبِی الْجَعْدِ ، عَنْ نُبَیْطِ بْنِ شَرِیط ، عَنْ جَابَانَ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لاَ یَدْخُلُ الْجَنَّۃَ عَاقٌ ، وَلاَ مُدْمِنُ خَمْرٍ ، وَلاَ مَنَّانٌ۔ (نسائی 5182۔ احمد 2/201)",,,25923 25924,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ إِسْحَاقَ ، عَنِ الشَّعْبِیِّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : رَحِمَ اللَّہُ وَالِدًا أَعَانَ وَلَدَہُ عَلَی بِرِّہِ۔",,,25924 25925,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، وَعَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ أَبِی بَکْرِ بْنِ مُحَمَّدِ بْنِ عَمْرِو بْنِ حَزْمٍ ، عَنْ عَمْرَۃَ ، عَنْ عَائِشَۃَ ، قَالَتْ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَا زَالَ جِبْرِیلُ یُوصِینِی بِالْجَارِ حَتَّی ظَنَنْت أَنَّہُ سَیُوَرِّثُہُ۔ (بخاری 6014۔ مسلم 2025)",,,25925 25926,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ بَشِیر بْن سَلْمَانَ ، عَنْ مُجَاہِدٍ ، قَالَ : کُنَّا جُلُوسًا عِنْدَ عَبْدِ اللہِ بْنِ عَمْرٍو فَقَالَ : إنِّی سَمِعْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُوصِی بِالْجَارِ حَتَّی حسبنا ، أَوْ رَأَیْنَا ، أَنَّہُ سَیُوَرِّثُہُ۔ (احمد 2/160)",,,25926 25927,"حَدَّثَنَا أَبُو الأَحْوَص ، عَنْ أَبِی حَصِینٍ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ کَانَ یُؤْمِنُ بِاللَّہِ وَالْیَوْمِ الآخِرِ فَلاَ یُؤْذِی جَارَہُ۔ (بخاری 6018۔ مسلم 68)",,,25927 25928,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا سَلاَّمُ بْنُ مِسْکِینٍ ، قَالَ : حَدَّثَنَا شَہْرُ بْنُ حَوْشَبٍ ، عَنْ مُحَمَّدِ بْنِ یُوسُف بْنِ عَبْدِ اللہِ بْنِ سَلاَمٍ أَنْ رَجُلاً أَتَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقَالَ : آذَانِی جَارِی ، فَقَالَ : اصْبِرْ ، ثُمَّ أَتَاہُ الثَّانِیَۃَ فَقَالَ : آذَانِی جَارِی ، فَقَالَ : اصْبِرْ ، ثُمَّ أَتَاہُ الثَّالِثَۃَ فَقَالَ : آذَانِی جَارِی ، فَقَالَ : اعْمَدْ إلَی مَتَاعِکَ فَاقْذِفْہُ فِی السِّکَّۃِ ، فَإِذَا مَرَّ بِکَ أَحَدٌ فَقُلْ : آذَانِی جَارِی ، فَتَحِقُّ عَلَیْہِ اللَّعْنَۃُ ، أَوْ تَجِبُ عَلَیْہِ اللَّعَنْۃُ۔ (بخاری 125۔ طبرانی 356)",,,25928 25929,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ دَاوُدَ بْنِ فَرَاہِیجَ ، قَالَ : سَمِعْتُ أَبَا ہُرَیْرَۃَ یُحَدِّثُ عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : أَوْصَانِی جِبْرِیلُ بِالْجَارِ حَتَّی ظَنَنْت أَنَّہُ یُوَرِّثُہُ۔ (ابن ماجہ 3674۔ احمد 2/259)",,,25929 25930,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ سَعِیدِ بْنِ أَبِی سَعِیدٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : اللَّہُمَّ إنِّی أَعُوذُ بِکَ مِنْ جَارِ سُوئٍ فِی دَارِ الْمُقَامَۃِ ، فَإِنَّ جَارَ الْبَادِیَۃِ یَتَحَوَّلُ۔ (بخاری 117۔ ابن حبان 1033)",,,25930 25931,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا مُحَمَّدُ بْنُ إِسْحَاقَ ، عَنْ یَزِیدَ بْنِ أَبِی حَبِیبٍ ، عَنْ سِنَانِ بْنِ سَعْدٍ، عَنْ أَنَسِ بْنِ مَالِکٍ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : مَا ہُوَ بِمُؤْمِنٍ مَنْ لَمْ یَأْمَنْ جَارُہُ بَوَائِقَہُ۔ (ابویعلی 4236)",,,25931 25932,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَوْزَاعِیُّ ، عَنْ عَبْدَۃَ بْنِ أَبِی لُبَابَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ قَلِیلَ مَنْ آذَی الْجَارَ۔ (طبرانی 23)",,,25932 25933,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا جَعْفَرُ بْنُ بُرْقَانَ ، عَنْ مَیْمُونَ بْنِ مِہْرَانَ ، قَالَ : کَانَ رَجُلٌ مِنَ الْمُسْلِمِینَ یَصُومُ ، فَکَانَ یَجْعَلُ لِسُحُورِہِ قُرْصًا فَجَائَتِ الشَّاۃُ فَأَخَذَتِ الْقُرْصَ ، فَقَامَتِ الْمَرْأَۃُ فَفَکَّتْ لِحْیَیَ الشَّاۃِ فَأَخَذَتِ الْقُرْصَ ، فَثَغَتِ الشَّاۃُ فَقَالَ : الرَّجُلُ : مَا یُدْرِیک مَا بَلَغَ ثِغَاہَا مِنْ أَذَی جَارِک۔",,,25933 25934,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، قَالَ : أَخْبَرَنِی جَارُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أَنَّہُ کَانَ یُرْمی بِالأَرْجَامِ وَالْجِیَف فَقَالَ : یَا مَعْشَرَ قُرَیْشٍ ، أَیُّ مُجَاوَرَۃٍ ہَذِہِ ؟۔ (ابن سعد 201)",,,25934 25935,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ أَبِی مَالِکٍ الأَشْجَعِیِّ ، عَنْ رِبْعِیٍّ ، عَنْ حُذَیْفَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : کُلُّ مَعْرُوفٍ صَدَقَۃٌ۔ (احمد 5/397)",,,25935 25936,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : قَالَ عَبْدُ اللہِ : کُلُّ مَعْرُوفٍ صَدَقَۃٌ۔",,,25936 25937,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ عَلِیِّ بْنِ زَیْدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: رَأْسُ الْعَقْلِ بَعْدَ الإِیمَانِ بِاللَّہِ مُدَارَاۃُ النَّاسِ ، وَلَنْ یَہْلِکَ رَجُلٌ بَعْدَ مَشْورَۃٍ ، وَأَہْلُ الْمَعْرُوفِ فِی الدُّنْیَا ہُمْ أَہْلُ الْمَعْرُوفِ فِی الآخِرَۃِ۔ (بیہقی 109)",,,25937 25938,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنْ أَبِی عُثْمَانَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَہْلُ الْمَعْرُوفِ فِی الدُّنْیَا ہُمْ أَہْلُ الْمَعْرُوفِ فِی الآخِرَۃِ ، وَأَہْلُ الْمُنْکَرِ فِی الدُّنْیَا ہُمْ أَہْلُ الْمُنْکَرِ فِی الآخِرَۃِ۔",,,25938 25939,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنْ مُجَاہِدٍ، قَالَ: مَنْ صَنَعَ مَعْرُوفًا إلَی غَنِیٍّ وَفَقِیرٍ، فَہُوَ صَدَقَۃٌ۔",,,25939 25940,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا عَبْدُ الْجَبَّارِ بْنُ عَبَّاسٍ ، عَنْ عَدِیِّ بْنِ ثَابِتٍ ، عَنْ عَبْدِ اللہِ بْنِ یَزِیدَ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : کُلُّ مَعْرُوفٍ صَدَقَۃٌ۔ (بخاری 231۔ احمد 4/307)",,,25940 25941,"حَدَّثَنَا مُحَمَّدُ بْنُ حَسَنٍ الأَزْدِیُّ، قَالَ: حدَّثَنَا عَبْدُالْحَمِیدِ الْبَصْرِیُّ، عَنْ مُحَمَّدِ بْنِ الْمُنْکَدِرِ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : کُلُّ مَعْرُوفٍ صَدَقَۃٌ۔(بخاری 6021۔ ترمذی 1970)",,,25941 25942,"حَدَّثَنَا مَالِکٌ ، عَنْ أَبِی عَوَانَۃَ ، عَنْ عَاصِمٍ ، عَنْ زِرٍّ ، عَنْ عَبْدِ اللہِ ، قَالَ : کُلُّ مَعْرُوفٍ صَدَقَۃٌ۔",,,25942 25943,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا سُفْیَانُ بْنُ حُسَیْنٍ ، عَنْ مُحَمَّدِ بْنِ الْمُنْکَدِرِ ، عَنْ جَابِرِ بْنِ عَبْدِاللہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : مَنْ عَالَ ثَلاَثَ بَنَاتٍ یَکْفِیہِنَّ وَیَرْحَمُہُنَّ وَیَرْفِقُ بِہِنَّ ، فَہُوَ فِی الْجَنَّۃِ ، أَوْ قَالَ : مَعِی فِی الْجَنَّۃِ۔ (احمد 3/303۔ ابویعلی 2207)",,,25943 25944,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ أَبِی مَالِکٍ الأَشْجَعِیِّ ، عَنْ زِیَادِ بْنِ حُدَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ وُلِدَتْ لَہُ ابْنَۃٌ فَلَمْ یَئِدْہَا وَلَمْ یُہِنْہَا ، وَلَمْ یُؤْثِرْ وَلَدَہُ عَلَیْہَا ، یَعْنِی الذُّکُورَ ، أَدْخَلَہُ اللَّہُ الْجَنَّۃَ۔ (ابوداؤد 5103۔ حاکم 177)",,,25944 25945,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشَ ، عَنِ الرَّقَاشِیِّ ، عَنْ أَنَسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ کَانَ لَہُ ابْنَتَانِ ، أَوْ أُخْتَانِ فَأَحْسَنَ إلَیْہِمَا مَا صَحِبَتَاہُ کُنْت أَنَا وَہُوَ فِی الْجَنَّۃِ کَہَاتَیْنِ - یَعْنِی کالسَّبَّابَۃِ وَالْوُسْطَی۔ (مسلم 2027۔ ترمذی 1914)",,,25945 25946,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ فِطْرٍ ، عَنْ شُرَحْبِیلَ بْنِ سَعد ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ أَدْرَکَتْ لَہُ ابْنَتَانِ فَأَحْسَنَ إلَیْہِمَا مَا صَحِبَتَاہُ ، أَوْ صَحِبَہُمَا ، أَدْخَلَہُ اللَّہُ الْجَنَّۃَ بِہِمَا۔\n\n(ابن ماجہ 3670۔ احمد 1/235)",,,25946 25947,"حَدَّثَنَا دَاوُد بْنُ عَبْدِاللہِ، قَالَ: حدَّثَنَا عَبْدُالْعَزِیزِ بْنُ مُحَمَّدٍ، عَنْ سُہَیْلِ بْنِ أَبِی صَالِحٍ السَّمَّانِ، عَنْ سَعِیدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ مُکْمِلٍ ، عَنْ أَیُّوبَ بْنِ بَشِیرٍ الْمُعَاوِیِّ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لاَ یَکُونُ لأَحَدِکُمْ ثَلاَثُ بَنَاتٍ ، أَوْ ثَلاَثُ أَخَوَاتٍ فَیُحْسِنُ إلَیْہِنَّ إلاَّ دَخَلَ الْجَنَّۃَ۔",,,25947 25948,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللہِ الأَسَدِیُّ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الْعَزِیزِ ، عَنْ عُبَیْدِ اللہِ بن أَبِی بَکْرٍ، عَنْ أَنَسٍ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ عَالَ جَارِیَتَیْنِ حَتَّی تَبْلُغَا جَائَ یَوْمَ الْقِیَامَۃِ أَنَا وَہُوَ ہَکَذَا وَضَمَّ إصْبَعَیْہِ۔ (مسلم 2027۔ ترمذی 1914)",,,25948 25949,"حَدَّثَنَا مُصْعَبُ بْنُ الْمِقْدَامِ ، قَالَ : حدَّثَنَا مِنْدَلٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ عُمَرَ بْنِ نَبْہَانَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ کَانَ لَہُ ثَلاَثُ بَنَاتٍ فَصَبَرَ عَلَی لاَوَائِہِنَّ وَسَرَّائِہِنَّ وَضَرَّائِہِنَّ أَدْخَلْنہُ الْجَنَّۃَ بِفَضْلِ رَحْمَتِہِ إیَّاہُنَّ ، قَالَ رَجُلٌ : واثنتان ؟ قَالَ : وَاثْنَتَانِ ، قَالَ رَجُلٌ : وَوَاحِدَۃٌ ؟ قَالَ : وَوَاحِدَۃٌ۔ (احمد 2/335۔ حاکم 176)",,,25949 25950,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ ثَابِتِ بْنِ عُبَیْدٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، قَالَ : مَرَّ بِی عَمْرُو بْنُ بُلَیْلٍ وَأَنَا مُتَصَبِّحٌ فِی النَّخْلِ فَحَرَّکَنِی بِرِجْلِہِ فَقَالَ : أَتَرْقُدُ فِی السَّاعَۃِ الَّتِی یَنْتَشِرُ فِیہَا عِبَادُ اللہِ۔",,,25950 25951,"حَدَّثَنَا حَفْصٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، قَالَ : کَانَ الزُّبَیْرُ یَنْہَی بَنِیہِ عَنِ التَّصَبُّحِ ، قَالَ : وَقَالَ عُرْوَۃُ : إنِّی لأَسْمَعُ بِالرَّجُلِ یَتَصَبَّحُ فَأَزْہَدُ فِیہِ۔",,,25951 25952,حَدَّثَنَا حَفْصٌ ، عَنْ طَلْحَۃَ بْنِ یَحْیَی ، عَنْ عَبْدِ اللہِ بْنِ فَرُّوخَ ، عَنْ طَلْحَۃَ بْنِ عُبَیْدِ اللہِ ، أَنَّہُ مَرَّ بِابْنٍ لَہُ قد تَصَبَّحَ ، فَذَکَرَ أَنَّہُ قَفَدہ ، وَنَہَاہُ عَنْ ذَلِکَ۔,,,25952 25953,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی سُفْیَانَ ، قَالَ : الْتَقَی ابْنُ الزُّبَیْرِ وَعُبَیْدُ بْنُ عُمَیْرٍ فَتَذَاکَرَا شَیئًا فَقَالَ لَہُ الآخَرُ : أَمَا عَلِمْت أَنَّ الأَرْضَ تَعِجُّ إلَی رَبِّہَا مِنْ نَوْمَۃِ عُلَمَائِہَا۔",,,25953 25954,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، قَالَ : قَالَ الزُّبَیْرُ : إنِّی لأَزْہَدُ فِی الرَّجُلِ یَتَصَبَّحُ۔",,,25954 25955,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی، عَنْ خَالِدِ بْنِ أَبِی بَکْرٍ، عَنْ عُبَیْدِ اللہِ، قَالَ: کَانَ سَالِمٌ لاَ یَتَصَبَّحُ، وَکَانَ یَقِیلُ۔",,,25955 25956,حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ خَالِدِ بْنِ أَبِی بَکْرٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عَبْدِ اللہِ مِثْلُہُ۔,,,25956 25957,حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، عَنْ مَکْحُولٍ مِثْلُہُ۔,,,25957 25958,حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنِ الْقَاسِمِ ، عَنْ عَائِشَۃَ ، أَنَّہَا کَانَتْ تَصَبَّحُ۔,,,25958 25959,"حَدَّثَنَا شَبَابَۃُ ، عَنْ شُعْبَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ عَبْدِ اللہِ بْنِ الشَّمَّاسِ ، قَالَ : أَتَیْتُ أُمَّ سَلَمَۃَ فَوَجَدْتہَا نَائِمَۃً - یَعْنِی بَعْدَ الصُّبْحِ۔",,,25959 25960,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، أَنَّ عَائِشَۃَ کَانَتْ إذَا طَلَعَتِ الشَّمْسُ نَامَتْ نَوْمَۃَ الضُّحَی۔,,,25960 25961,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ، عَنْ عَبْدِ الأَعْلَی، قَالَ: أَتَیْتُ سَعِیدَ بْنَ جُبَیْرٍ فَوَجَدْتہ نَائِمًا نَوْمَۃَ الضُّحَی۔",,,25961 25962,"قَالَ : قَالَ : حَدَّثَنَا عَبْدُ الْوَارِثِ ، قَالَ :حَدَّثَنَا أَیُّوبُ ، عَنِ ابْنِ سِیرِینَ ، أَنَّہُ کَانَ یَتَصَبَّحُ۔",,,25962 25963,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ أَبِی یَزِیدَ الْمَدِینِیِّ ، قَالَ : غَدَا عُمَرُ عَلَی صُہَیْبٍ فَوَجَدَہُ مُتَصَبِّحًا ، فَقَعَدَ حَتَّی اسْتَیْقَظَ ، فَقَالَ صُہَیْبٌ : أَمِیرُ الْمُؤْمِنِینَ قَاعِدٌ عَلَی مَقْعَدَتِہِ وَصُہَیْبٌ نَاعِمٌ مُتَصَبِّحٌ ، فَقَالَ لَہُ عُمَرُ : مَا کُنْت أُحِبُّ أَنْ تَدَعَ نَوْمَۃً تَرْفُقُ بِکَ ۔",,,25963 25964,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، قَالَ : کَانَ الزُّبَیْرُ شَدِیدًا عَلَی النِّسَائِ ، وَکَانَ یُکَسِّرُ عَلَیْہِنَّ عِیدَانَ الْمشَاحِبِ۔",,,25964 25965,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : کَانَ عُمَرُ یَضْرِبُ النِّسَائَ وَالْخَدَمَ۔",,,25965 25966,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ یَعْلَی بْنِ عَطَائٍ ، عَنْ أَبِیہِ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرو ، قَالَ : لاَ تَضْرِبْ خَادِمَک وَاضْرِبِ امْرَأَتَکَ وَوَلَدَک۔",,,25966 25967,"حَدَّثَنَا عَبْدَۃُ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنِ الْقَاسِمِ ، أَنَّ رِجَالاً نُہُوا عَنْ ضَرْبِ النِّسَائِ ، وَقِیلَ : لَنْ یَضْرِبَ خِیَارُکُمْ ، قَالَ الْقَاسِمُ : وَکَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ خَیْرَہُمْ کَانَ لاَ یَضْرِبُ۔\n\n(ابوداؤد 2139۔ بیہقی 304)",,,25967 25968,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، قَالَتْ : مَا ضَرَبَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ خَادِمًا لَہُ ، وَلاَ امْرَأَۃً ، وَلاَ ضَرَبَ شَیْئًا بِیَدِہِ۔ (مسلم 1814۔ ابوداؤد 4753)",,,25968 25969,"حَدَّثَنَا یَحْیَی بْنُ سُلَیْمٍ الطَّائِفِیُّ ، عَنْ إسْمَاعِیلَ بْنِ کَثِیرٍ ، عَنْ عَاصِمِ بْنِ لَقِیطِ بْنِ صَبِرَۃَ ، عَنْ أَبِیہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تَضْرِبَنَّ ظَعِینَتَکَ ضَرْبَک أَمَتِک۔",,,25969 25970,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَبِیبِ بْنِ أَبِی ثَابِتٍ ، عَنْ مَیْمُونِ بْنِ أَبِی شَبِیبٍ ، قَالَ : قَالَ عَمَّارٌ : مَنْ ضَرَبَ عَبْدَہُ ظَالِمًا أُقِیدَ مِنْہُ۔",,,25970 25971,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، عَنْ عَبْدِ اللہِ بْنِ زَمْعَۃَ ، قَالَ : خَطَبَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، ثُمَّ ذَکَرَ النِّسَائَ فَوَعَظَہُمْ فِیہِنَّ فَقَالَ : إلاَمَ یَجْلِدُ أَحَدُکُمُ امْرَأَتَہُ جَلْدَ الأَمَۃِ ، ولَعَلَّہُ أَنْ یُضَاجِعَہَا مِنْ آخِرِ یَوْمِہِ۔ (بخاری 4942۔ مسلم 2191)",,,25971 25972,"حَدَّثَنَا شَرِیکٌ ، عَنِ الرُّکَیْنِ ، عَنْ نُعَیْمِ بْنِ حَنْظَلَۃَ ، عَنْ عَمَّارٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ کَانَ لَہُ وَجْہَانِ فِی الدُّنْیَا کَانَ لَہُ یَوْمَ الْقِیَامَۃِ لِسَانَانِ مِنْ نَارٍ۔ (ابوداؤد 4840۔ دارمی 2764)",,,25972 25973,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ اللہِ بْنِ عَامِرٍ ، عَنِ الزُّہْرِیِّ ، أَنَّ رَجُلاً سَلَّمَ عَلَی النَّبِیِّ ثَلاَثَ مَرَّاتٍ فَلَمْ یَرُدَّ عَلَیْہِ فَقِیلَ لَہُ : لِمَ ؟ فَقَالَ : إِنَّہُ ذُو وَجْہَیْنِ۔",,,25973 25974,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : تَجِدُ مِنْ شَرِّ النَّاسِ عِنْدَ اللہِ یَوْمَ الْقِیَامَۃِ ذُو الْوَجْہَیْنِ۔ (بخاری 6058۔ ترمذی 2025)",,,25974 25975,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِیہِ ، عَنْ عِکْرِمَۃَ ، قَالَ : قَالَ لَقَمِنٌ ذُو الْوَجْہَیْنِ لاَ یَکُونَ عِنْدَ اللہِ أَمِینًا۔ (بخاری 313۔ احمد 2/365)",,,25975 25976,"حَدَّثَنَا وَکِیعٌ ، عَنِ الْمَسْعُودِیِّ ، عَنْ مَالِکِ بْنِ أَسْمَائَ بْنِ خَارِجَۃَ ، عَنْ أَبِیہِ ، قَالَ : سَمِعْتُ ابْنَ مَسْعُودٍ یَقُولُ : إنَّ ذَا اللِّسَانَیْنِ لَہُ لِسَانَانِ مِنْ نَارٍ یَوْمَ الْقِیَامَۃِ۔ (طبرانی 9168)",,,25976 25977,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ الأَعْمَشِ ، قَالَ : رَآنِی إبْرَاہِیمُ وَأَنَا أَتَمَخَّطُ بِیَمِینِی فَنَہَانِی وَقَالَ : عَلَیْک بِیَسَارِکَ ، وَلاَ تَعْتَادَنَّ تَمْتَخِطُ بِیَمِینِک۔",,,25977 25978,"حَدَّثَنَا ابْنُ فُضَیْلٍ، عَنِ الأَعْمَشِ ، عَنْ بَعْضِ أَصْحَابِہِ ، عَنْ مَسْرُوقٍ ، عَنْ عَائِشَۃَ ، قَالَتْ: کَانَت یَمِینُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لِطَعَامِہِ وَصَلاَتِہِ، وَکَانَت شِمَالُہُ لِمَا سِوَی ذَلِکَ۔ (بخاری 168۔ مسلم 66)",,,25978 25979,حَدَّثَنَا وَکِیعٌ ، عَنْ مُسَافِرٍ ، عَنْ رُزَیْقِ بْنِ سَوَّارٍ ، أَنَّ الْحَسَنَ بْنَ عَلِیٍّ امْتَخَطَ بِیَمِینِہِ۔,,,25979 25980,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنِ الأَعْمَشِ، عَنْ إبْرَاہِیمَ، قَالَ: کَانُوا یَکْرَہُونَ أَنْ یَمْتخِطَ الرَّجُلُ بِیَمِینِہِ۔",,,25980 25981,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنِ الْحَکَمِ أَبِی مُعَاذٍ ، قَالَ : رَأَیْتُ الْحَسَنَ یَتَمَخَّطُ بِیَمِینِہِ۔",,,25981 25982,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیلَی ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ مُحَمَّدِ بْنِ شُرَحْبِیلَ ، عَنْ قَیْسِ بْنِ سَعْدٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الرَّجُلُ أَحَقُّ بِصَدْرِ دَابَّتِہِ۔",,,25982 25983,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ رَافِعٍ ، عَن مُحَمَّدِ بْنِ یَحْیَی بْنِ حَبَّانَ ، عَنْ عَمِّہ ، عَنْ أَبِی سَعِید قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الرَّجُلُ أَحَقُّ بِصَدْرِ دَابَّتِہِ وَإِذَا رَجَعَ إلَی مَجْلِسِہِ ، فَہُوَ أَحَقُّ بِہِ۔\n\n(مسلم 1715۔ ابوداؤد 4819)",,,25983 25984,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ مَنْصُورٍ، عَنْ إبْرَاہِیمَ، قَالَ: کَانَ یُقَالُ: الرَّجُلُ أَحَقُّ بِصَدْرِ دَابَّتِہِ وَفِرَاشِہِ۔",,,25984 25985,"حَدَّثَنَا مُحَمَّدُ بْنُ الفُضَیْل ، عَنْ سُفْیَانَ الْعَطَّارِ ، قَالَ : رَأَیْتُ الشَّعْبِیَّ مُرْتَدِفًا خَلْفَ رَجُلٍ ، قَالَ : وَکَانَ یَقُولُ : صَاحِبُ الدَّابَّۃِ أَحَقُّ بِمُقَدَّمِہَا۔",,,25985 25986,"حَدَّثَنَا وَکِیعٌ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، عَنْ عِیسَی بْنِ عَاصِمٍ ، قَالَ : قَالَ عَبْدُ اللہِ ، الرَّجُلُ أَحَقُّ بِصَدْرِ دَابَّتِہِ : وَالرَّجُلُ أَحَقُّ بِصَدْرِ فِرَاشِہِ۔",,,25986 25987,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، قَالَ : حدَّثَنَا حَبِیبُ بْنُ شَہِیدٍ ، عَنْ عَبْدِ اللہِ بْنِ بُرَیْدَۃَ ، أَنَّ مُعَاذَ بْنَ جَبَلٍ أَتَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِدَابَّۃٍ لِیَرْکَبَہَا ، فَقَالَ لہ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : رَبُّ الدَّابَّۃِ أَحَقُّ بِصَدْرِہَا ، قَالَ : فَقَالَ مُعَاذٌ : فَہِیَ لَکَ یَا نَبِیَّ اللہِ ، فَرَکِبَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَأَرْدَفَ مُعَاذًا۔\n\n(ترمذی 2773۔ ابوداؤد 2565)",,,25987 25988,"حَدَّثَنَا شَبَابَۃ ، قَالَ: حدَّثَنَا سُلَیْمَانُ بْنُ الْمُغِیرَۃِ ، قَالَ: رَأَیْتُ حُمَیْدَ بْنَ ہِلاَلٍ وَالْحَسَنَ ، وَابْنَ سِیرِینَ، وَعَطَائً وَبَکْرَ بْنَ عَبْدِ اللہِ لاَ یُحْفُونَ شَوَارِبَہُمْ۔",,,25988 25989,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ مُحَمَّدِ بْنِ ہِلاَلٍ ، قَالَ : رَأَیْتُ سَعِیدَ بْنَ الْمُسَیَّبِ وَعُمَرَ بْنَ عَبْدِ الْعَزِیزِ وَسَالِمًا وَعُرْوَۃَ بْنَ الزُّبَیْرِ وَجَعْفَرَ بْنَ الزُّبَیْرِ وَعُبَیْدَ اللہِ بْنَ عَبْدِ اللہِ بْنِ عُتْبَۃَ وَأَبَا بَکْرِ بْنَ عَبْدِ الرَّحْمَنِ بْنِ الْحَارِثِ بْنِ ہِشَامٍ لاَ یُحْفُونَ شَوَارِبَہُمْ جِدًّا ، یَأْخُذُونَ مِنْہَا أَخْذًا حَسَنًا۔",,,25989 25990,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَن ثَابِتِ بْنِ قَیْسٍ ، عَنِ نَافِعَ بْنَ جُبَیْرٍ ، وَعِرَاک بن مَالِکَ : مِثْلَہ۔",,,25990 25991,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ زَمْعَۃَ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ سِمَاکِ بْنِ یَزِیدَ ، قَالَ : کَانَ عَلِیٌّ یَأْخُذُ مِنْ لِحْیَتِہِ مِمَّا یَلِی وَجْہَہُ۔",,,25991 25992,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ شُعْبَۃَ ، عَنْ عَمْرِو بْنِ أَیُّوبَ مِنْ وَلَدِ جَرِیرٍ ، عَنْ أَبِی زُرْعَۃَ ، قَالَ : کَانَ أَبُو ہُرَیْرَۃَ یَقْبِضُ عَلَی لِحْیَتِہِ ، ثُمَّ یَأْخُذُ مَا فَضَلَ عَنِ الْقُبْضَۃِ۔",,,25992 25993,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مَنْصُورٍ ، قَالَ : سَمِعْتُ عَطَائَ بْنَ أَبِی رَبَاحٍ ، قَالَ : کَانُوا یُحِبُّونَ أَنْ یُعْفُوا اللِّحْیَۃَ إلاَّ فِی حَجٍّ ، أَوْ عُمْرَۃٍ ، وَکَانَ إبْرَاہِیمُ یَأْخُذُ مِنْ عَارِضِ لِحْیَتِہِ۔",,,25993 25994,حَدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ ، أَنَّہُ کَانَ یَأْخُذُ مِنْ لِحْیَتِہِ ، وَلاَ یُوجِبُہُ۔,,,25994 25995,"حَدَّثَنَا عَائِذُ بْنُ حَبِیبٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : کَانُوا یُرَخِّصُونَ فِیمَا زَادَ عَلَی الْقُبْضَۃِ مِنَ اللِّحْیَۃِ أَنْ یُؤْخَذَ مِنْہَا۔",,,25995 25996,"حَدَّثَنَا أَبُو عَامِرٍ الْعَقَدِیُّ ، عَنْ أَفْلَحَ ، قَالَ : کَانَ الْقَاسِمُ إذَا حَلَقَ رَأْسَہُ أَخَذَ مِنْ لِحْیَتِہِ وَشَارِبِہِ۔",,,25996 25997,"حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، وَوَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ یَأْخُذُ مَا فَوْقَ الْقُبْضَۃِ ، وَقَالَ وَکِیعٌ : مَا جَازَ الْقُبْضَۃَ۔",,,25997 25998,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی ہِلاَلٍ ، عَنْ قَتَادَۃَ ، قَالَ : قَالَ جَابِرٌ : لاَ نَأْخُذُ مِنْ طُولِہَا إلاَّ فِی حَجٍّ ، أَوْ عُمْرَۃٍ۔",,,25998 25999,حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ عَمْرِو بْنِ أَیُّوبَ ، عَنْ أَبِی زُرْعَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، أَنَّہُ کَانَ یَأْخُذُ مِنْ لِحْیَتِہِ مَا جَازَ الْقُبْضَۃَ۔,,,25999 26000,"حَدَّثَنَا وَکِیعٌ، عَنْ أَبِی ہِلاَلٍ، قَالَ: سَأَلْتُ الْحَسَنَ، وَابْنَ سِیرِینَ فَقَالاَ: لاَ بَأْسَ بِہِ أَنْ تَأْخُذَ مِنْ طُولِ لِحْیَتِک۔",,,26000 26001,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ مَنْصُورٍ، عَنْ إبْرَاہِیمَ، قَالَ: کَانُوا یُبَطِّنُونَ لِحَاہُمْ وَیَأْخُذُونَ مِنْ عَوَارِضِہَا۔",,,26001 26002,حَدَّثَنَا وَکِیعٌ ، عَنْ حُسَیْنٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ کَرِہَ أَنْ یَتَحَذَّفَ کِلْ أو کِرد یَرْکُوش۔,,,26002 26003,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : انْہَکُوا الشَّوَارِبَ وَاعْفُوا اللِّحَی۔ (بخاری 5893۔ مسلم 222)",,,26003 26004,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ یُوسُفَ بْنِ صُہَیْبٍ ، عَنْ حَبِیبِ بْنِ یَسَارٍ ، عَنْ زَیْدِ بْنِ أَرْقَمَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَیْسَ مِنَّا مَنْ لَمْ یَأْخُذْ مِنْ شَارِبِہِ۔ (ترمذی 2761)",,,26004 26005,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ عُثْمَانَ الْحَاطِبِیِّ ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ یُحْفِی شَارِبَہُ۔",,,26005 26006,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنْ حَبِیبٍ ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ قَدْ جَزَّ شَارِبَہُ کَأَنَّہُ قَدْ حَلَقَہُ۔",,,26006 26007,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ وَمُحَمَّدٍ أَنَّہُمَا کَانَا یُحْفِیَانِ شَوَارِبَہُمَا۔,,,26007 26008,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، قَالَ : رَأَیْتُ عَبْدَ اللہِ یُحْفِی شَارِبَہُ۔",,,26008 26009,"حَدَّثَنَا قَبِیصَۃُ بْنُ عُقْبَۃَ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنَ ، عَنْ عُبَیْدِ اللہِ بْنِ أَبِی رَافِعٍ ، قَالَ: رَأَیْتُ أَبَا سَعِیدٍ وَرَافِعَ بْنَ خَدِیجٍ وَسَلَمَۃَ بْنَ الأَکْوَعِ ، وَابْنَ عُمَرَ وَجَابِرَ بْنَ عَبْدِ اللہِ وَأَبَا أُسَیْدَ یُنْہِکُونَ شَوَارِبَہُمَا أَخَا الْحَلْقِ۔",,,26009 26010,"حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ ، قَالَ : حدَّثَنَا ہُرَیْمٌ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ مَکْحُولٍ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ، قَالَ : أُمِرْنَا أَنْ نَبْشُرَ الشَّوَارِبَ بَشْرًا۔",,,26010 26011,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ عُمَرَ ، قَالَ : سُئِلَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ : مَا السُّنَّۃُ فِی قص الشَّارِبِ ؟ قَالَ : یُقَصُّ حَتَّی یَبْدُوَ الإِطَارُ وَیُقْطَعُ فَضْلُ الشَّارِبَیْنِ۔",,,26011 26012,"حَدَّثَنَا وَکِیعٌ ، عَنْ مَعْقِلٍ ، عَنْ مَیْمُونٍ ، قَالَ : کَانَ ابْنُ عُمَرَ یَعْتَرِضُ شَارِبَہُ فَیَجُزُّہُ کَمَا یَجُزُّ الْغَنَمَ۔",,,26012 26013,"حَدَّثَنَا جَعْفَرُ بْنُ عَوْنٍ ، قَالَ : أَخْبَرَنَا أَبُو الْعُمَیْسِ ، عَنْ عَبْدِ المجید بْنِ سُہَیْلٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عبد اللہ بن عُتْبَۃَ ، قَالَ : جَائَ رَجُلٌ مِنَ الْمَجُوسِ إلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : قد حَلَقَ لِحْیَتَہُ ، وَأَطَالَ شَارِبَہُ ، فَقَالَ لَہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَا ہَذَا ؟ قَالَ : ہَذَا فِی دِینِنَا، قَالَ: فِی دِینِنَا أَنْ نَجُزَّ الشَّارِبَ، وَأَنْ نُعْفِیَ اللِّحْیَۃَ۔ (مسلم 222۔ احمد 2/366)",,,26013 26014,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ سِمَاکٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : أَخْذُ الشَّارِبِ مِنَ الدِّینِ۔ (ترمذی 2760۔ احمد 1/301)",,,26014 26015,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَنْ حَسَنٍ ، عَنْ سِمَاکٍ ، عَنْ عِکْرِمَۃَ قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُصُّ مِنْ شَارِبِہِ ، وَکَانَ إِبْرَاہِیمُ ، خَلِیلُ اللہِ ، یَقُصُّ شَارِبَہُ ، أَوْ مِنْ شَارِبِہِ۔",,,26015 26016,"حَدَّثَنَا عَائِذُ بْنُ حَبِیبٍ ، عَنْ أَشْعَثَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : کُنَّا نُؤْمَرُ أَنْ نُوَفِّیَ السِّبَالَ ، وَنَأْخُذَ مِنَ الشَّوَارِبِ۔ (ابوداؤد 4198۔ احمد 5/265)",,,26016 26017,"حَدَّثَنَا وَکِیعٌ ، عَنْ زَکَرِیَّا ، عَنْ مُصْعَبِ بْنِ شَیْبَۃَ ، عَنْ طَلْقِ بْنِ حَبِیبٍ ، عَنِ ابن الزُّبَیْرِ ، عَنْ عَائِشَۃَ ، قَالَتْ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مِنَ الْفِطْرَۃِ قَصُّ الشَّارِبِ ، وَإِعْفَائُ اللِّحْیَۃِ۔\n\n(بخاری 6287۔ مسلم 1663)",,,26017 26018,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عَبَّادِ بْنِ تَمِیمٍ ، عَنْ عَمِّہِ ، قَالَ : رَأَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مُسْتَلْقِیًا فِی الْمَسْجِد ، قَدْ وَضَعَ إحْدَی رِجْلَیْہِ عَلَی الأُخْرَی۔",,,26018 26019,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنَ ، عَنْ یَحْیَی بْنِ عَبْدِ اللہِ بْنِ مَالِکٍ ، عَنْ أَبِیہِ ، قَالَ : دَخَلَ عَلَی عُمَرَ أَو رُئِی مُسْتَلْقِیًا وَاضِعًا إحْدَی رِجْلَیْہِ عَلَی الأُخْرَی۔",,,26019 26020,حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ سُفْیَانَ بْنِ حُسَیْنٍ ، عَنِ الزُّہْرِیِّ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، عَنْ عَبْدِ اللہِ بْنِ عَبْدِ اللہِ بْنِ الْحَارِثِ ، أَنَّہُ رَأَی أُسَامَۃَ بْنَ زَیْدٍ جَالِسًا وَاضِعًا إحْدَی رِجْلَیْہِ عَلَی الأُخْرَی۔,,,26020 26021,"حَدَّثَنَا وَکِیعٌ، عَنْ أُسَامَۃَ، عَنْ نَافِعٍ، قَالَ : کَانَ ابْنُ عُمَرَ یَضْطَجِعُ فَیَضَعُ إحْدَی رِجْلَیْہِ عَلَی الأُخْرَی۔",,,26021 26022,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ أُسَامَۃَ ، عَنْ نَافِعٍ : قَالَ ابْنُ عُمَرَ یَسْتَلْقِی عَلَی قَفَاہُ وَیَضَعُ إحْدَی رِجْلَیْہِ عَلَی الأُخْرَی لاَ یَرَی بِذَلِکَ بَأْسًا ، وَیَفْعَلُہُ وَہُوَ جَالِسٌ لاَ یَرَی بِذَلِکَ بَأْسًا۔",,,26022 26023,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : إنَّمَا یَنْہَی عَنْ ذَلِکَ أَہْلُ الْکِتَابِ ، وَقَالَ عَامِرٌ وَمُحَمَّدُ بْنُ عَلِیٍّ : لاَ بَأْسَ بہ۔",,,26023 26024,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ الغَسِیل ، قَالَ : حدَّثَنِی عَمْرُو بْنُ أَبِی عَمْرٍو ، أَنَّ بِلاَلاً فَعَلَہُ : وَضَعَ إحْدَی رِجْلَیْہِ عَلَی الأُخْرَی۔",,,26024 26025,حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ الْعَزِیزِ الْمَاجِشُونِ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، أَنَّ عُمَرَ وَعُثْمَانَ کَانَا یَفْعَلاَنِہِ۔ (بخاری 475۔ ابوداؤد 4834),,,26025 26026,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، عَنْ عَمِّہِ، قَالَ: رَأَیْتُ ابْنَ مَسْعُودٍ فِی الأَرَاکِ مُسْتَلْقِیًا وَاضِعًا إحْدَی رِجْلَیْہِ عَلَی الأُخْرَی وَہُوَ یَقُولُ: {رَبَّنَا لاَ تَجْعَلْنَا فِتْنَۃً لِلْقَوْمِ الظَّالِمِینَ}۔",,,26026 26027,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ عِمْرَانَ - یَعْنِی ابْنَ مُسْلِمٍ - قَالَ : رَأَیْتُ أَنَسًا وَاضِعًا إحْدَی رِجْلَیْہِ عَلَی الأُخْرَی ۔",,,26027 26028,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ الْعَوَّامِ ، عَنِ الْحَکَمِ ، قَالَ : سَأَلْتُ أَبَا مِجْلَزٍ عَنِ الرَّجُلِ یَجْلِسُ ، وَیَضَعُ إحْدَی رِجْلَیْہِ عَلَی الأُخْرَی فَقَالَ : لاَ بَأْسَ بِہِ ، إنَّمَا ہُوَ شَیْئٌ کَرِہَتْہُ الْیَہُودُ ، قَالُوا : إِنَّہُ خَلَقَ السَّمَاوَاتِ وَالأَرْضَ فِی سِتَّۃِ أَیَّامٍ ، ثُمَّ اسْتَوَی یَوْمَ السَّبْتِ فَجَلَسَ تِلْکَ الْجِلْسَۃَ۔",,,26028 26029,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی ہِلاَلٍ ، عَنِ ابْنِ سِیرِینَ ، أَنَّ ہَارُونَ بْنَ رِئَابٍ ، قَالَ لَہُ وَہُوَ جَالِسٌ عَلَی سَرِیرِہِ وَاضِعًا إحْدَی رِجْلَیْہِ عَلَی الأُخْرَی : یُکْرَہُ ہَذَا یَا أَبَا بَکْرٍ ؟ قَالَ : لاَ۔",,,26029 26030,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، قَالَ : حدَّثَنِی الرَّبِیعُ بْنُ الْمُنْذِرِ ، قَالَ : حَدَّثَنِی أَبِی ، قَالَ : رَأَیْتُ مُحَمَّدَ بْنَ الْحَنَفِیَّۃِ وَاضِعًا إحْدَی رِجْلَیْہِ عَلَی الأُخْرَی۔",,,26030 26031,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ إسْرَائِیلَ ، قَالَ : قیلَ لَہُ : أَرَأَیْت الشَّعْبِیَّ یَضَعُ إحْدَی رِجْلَیْہِ عَلَی الأُخْرَی ؟ قَالَ : نَعَمْ۔",,,26031 26032,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنْ إسْمَاعِیلَ بْنِ أبی إسْمَاعِیلَ رَاشِدٍ ، قَالَ : اسْتَلْقَیْت فَرَفَعْت إحْدَی رِجْلَیْ عَلَی رُکْبَتِی ، فَرَمَانِی سَعِیدٌ بِحَصَیَاتٍ ، ثُمَّ قَالَ : إنَّ ابْنَ عَبَّاسٍ کَانَ یَنْہَی عَنْ ہَذَا۔",,,26032 26033,حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی ہِلاَلٍ ، عَنِ ابْنِ سِیرِینَ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّہُ کَرِہَ أَنْ یَضْطَجِعَ وَیَضَعَ إحْدَی رِجْلَیْہِ عَلَی الأُخْرَی۔,,,26033 26034,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْمَاعِیل ، عَنْ وَاصِلٍ ، أَنَّ جَرِیرًا جَلَسَ وَوََضَعَ إحْدَی رِجْلَیْہِ عَلَی الأُخْرَی فَقَالَ لَہُ کَعْبٌ : ضَعْہَا ، فَإن ہَذَا لاَ یَصْلُحُ لِبَشَرٍ۔",,,26034 26035,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ عَبْدِ اللہِ بْنِ مُرَّۃَ ، عَنْ عَمْرِو بْنِ عُتْبَۃَ بْنِ فَرْقَدٍ ، أَنَّ کَعْبًا ، قَالَ لَہُ : ضَعْہَا ، فَإِنَّ ہَذَا لاَ یَصْلُحُ لِبَشَرٍ۔",,,26035 26036,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ حَبِیبٍ ، قَالَ : رَآنِی مُحَمَّدٌ وَقَدْ وَضَعْت رِجْلِی ہَکَذَا وَوَضَعَ قَدَمَہُ الْیُمْنَی عَلَی فَخِذِہِ الْیُسْرَی ، قَالَ : فَقَالَ : ارْفَعْہَا ، قَدْ تَوَاطَؤُوا عَلَی الْکَرَاہِیَۃِ لَہَا ، قَالَ : فَذَکَرْت لِلْحَسَنِ ، قَالَ : کَانَتِ الْیَہُودُ یَکْرَہُونَہُ فَخَالَفَہُمُ الْمُسْلِمُونَ۔",,,26036 26037,"حَدَّثَنَا حُمَیْدٌ ، عَنْ حَسَنٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ کَرِہَ أَنْ یَجْلِسَ الرَّجُلُ فَیَضَعَ عَقِبَہُ عَلَی فَخِذِہِ وقال : ہُوَ التَّوَرُّکُ۔",,,26037 26038,حَدَّثَنَا حُمَیْدٌ ، عَنْ حَسَنٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، أَنَّہُ نَہَی عَنْہُ۔,,,26038 26039,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، أَنَّہُ کَرِہَ التَّرَبُّعَ وَقَالَ : جِلْسَۃُ مَمْلَکَۃٍ۔",,,26039 26040,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ الْمُجَالِدِ ، قَالَ : أَخْبَرَنِی عَامِرٌ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : قَالَ الْعَبَّاسُ لابْنِہِ عَبْدِ اللہِ بن عباس : یَا بُنَیَّ ، إنِّی أَرَی أَمِیرَ الْمُؤْمِنِینَ یُقَرِّبُک ، وَیَسْتَشِیرُک مَعَ أُنَاسٍ مِنْ أَصْحَابِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَیَخْلُو بِکَ ، فَاحْفَظْ عَنِّی ثَلاَثًا : اتَّقِ اللَّہَ لاَ یُجَرِّبَنَّ عَلَیْک کِذْبَۃً ، وَلاَ تُفْشِیَنَّ لَہُ سِرًّا ، وَلاَ تَغتَابنَّ عِنْدَہُ أَحَدًا ، قَالَ : فَقُلْت لابْنِ عَبَّاسٍ : یَا أَبَا عَبَّاسٍ ، کُلُّ وَاحِدَۃٍ مِنْہُنَّ خَیْرٌ مِنْ أَلْفٍ ، قَالَ : وَمِنْ عَشَرَۃِ آلاَفٍ۔",,,26040 26041,"حَدَّثَنَا عَبْدُاللہِ بْنُ إدْرِیسَ، عَنِ ابْنِ عَجْلاَنَ، عَنْ إبْرَاہِیمَ بْنِ مُرَّۃَ، عَنْ مُحَمَّدِ بْنِ شِہَابٍ، قَالَ: قَالَ عُمَرُ: لاَ تَعْتَرِضْ فِیمَا لاَ یَعْنِیک ، وَاعْتَزِلْ عَدُوَّک ، وَاحْتَفِظْ مِنْ خَلِیلک إلاَّ الأَمِین ، فَإِنَّ الأَمِین لاَ یُعَادِلُہُ شَیْئٌ، لاَ تَصْحَبِ الْفَاجِرَ فَیُعَلِّمُک مِنْ فُجُورِہِ ، وَلاَ تُفْشِ إلَیْہِ بسِرّک ، وَاسْتَشِرْ فِی أَمْرِکَ الَّذِینَ یَخْشَوْنَ اللَّہَ۔",,,26041 26042,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ، قَالَ : لاَ تُحَدِّثْ بِالْحَدِیثِ مَنْ لاَ یَعْرِفُہُ ، فَإِنَّ مَنْ لاَ یَعْرِفُہُ یَضُرُّہُ ، وَلاَ یَنْفَعُہُ۔",,,26042 26043,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : حدَّثَنَا حُمَیْدٌ الطَّوِیلُ ، عَنْ أَنَسٍ ، قَالَ : کُنْتُ مَعَ الْغِلْمَانِ فَمَرَّ عَلَیْنَا النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَسَلَّمَ عَلَیْنَا ، ثُمَّ بَعَثَنِی فِی حَاجَۃٍ وَجَلَسَ فِی جِدَارٍ ، أَوْ فِی ظِلٍّ حَتَّی أَتَیْتہ فَأَبْلَغْتہ حَاجَتَہُ ، فَلَمَّا أَتَیْتُ أُمَّ سُلَیْمٍ ، قَالَتْ : مَا حَبَسَک الْیَوْمَ ؟ قُلْتُ : بَعَثَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی حَاجَۃٍ ، قَالَتْ : مَا ہِیَ ؟ قُلْتُ : أَنَّہَا سِرٌّ ، قَالَتْ : فَاحْفَظْ سِرَّ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : فَمَا حَدَّثْت بِہَا أَحَدًا قَطُّ۔ (بخاری 1139۔ مسلم 145)",,,26043 26044,"حَدَّثَنَا حَفْصُ بْنِ غِیَاثٍ ، عَنْ لَیْثٍ ، عَنْ أَبِی ہُبَیْرَۃَ یَحْیَی بْنِ عَبَّادٍ ، قَالَ : الْمُسْلِمُ مِرْآۃُ أَخِیہِ ، فَإِذَا أَخَذَ عَنْہُ شَیْئًا فَلْیُرِہِ۔",,,26044 26045,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ غَالِبٍ ، قَالَ : سَأَلْتُ الْحَسَنَ أو سَأَلَہُ رَجُلٌ عَنِ الرَّجُلِ یَأْخُذُ عَنِ الرَّجُلِ الشَّیْئَ فَیَقُولُ : لاَ یَکُنْ بِکَ السُّوئُ ، أَوْ صُرِفَ عَنْک السُّوئَ ، قَالَ : فَقَالَ : یَقُولُ : لاَ یَکُنْ بِکَ السُّوئُ فَإِنَّہُ إِلاَّ یَکُنْ بہ خَیْرٌ مِنْ أَنْ یَکُونَ بِہِ ثُمَّ یُصْرَفُ۔",,,26045 26046,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ بُرْدٍ ، عَنْ سُلَیْمَانَ بْنِ مُوسَی ، قَالَ : قَالَ عُمَرُ : إذَا أَخَذَ أَحَدُکُمْ عَنْ أَخِیہِ شَیْئًا فَلْیُرِہِ إِیَّاہ۔",,,26046 26047,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ یَحْیَی بْنِ عُبَیْدِ اللہِ التَّیْمِیِّ ، قَالَ : سَمِعْتُ أَبِی یَقُولُ : سَمِعْت أَبَا ہُرَیْرَۃَ یَقُولُ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَحَدُکُمْ مِرْآۃُ أَخِیہِ ، فَإِذَا رَأَی أَذًی فَلْیُمِطْہُ عَنْہُ۔\n\n(بخاری 239۔ ابوداؤد 4882)",,,26047 26048,"حَدَّثَنَا وَکِیعٌ، عَنْ شُعْبَۃَ، عَنْ یَحْیَی بْنِ الْحُصَیْنِ، عَنْ طَارِقِ بْنِ شِہَابٍ، قَالَ: کَانَ بَیْنَ خَالِدِ بْنِ الْوَلِیدِ وَبَیْنَ سَعْدٍ کَلاَمٌ ، قَالَ : فَتَنَاوَلَ رَجُلٌ خَالِدًا عِنْدَ سَعْدٍ ، قَالَ : فَقَالَ : سَعْدٌ : مَہْ ، فَإِنَّ مَا بَیْنَنَا لَمْ یَبْلُغْ دِینَنَا۔",,,26048 26049,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ شَقِیقٍ ، عَنْ زَیْدِ بْنِ صُوحَانَ ، قَالَ : قَالَ عُمَرُ : مَا یَمْنَعُکُمْ إذَا رَأَیْتُمُ الرَّجُلَ یَخْرِقُ أَعْرَاضَ النَّاسِ أن لاَ تُغَیِّرُوا عَلَیْہِ؟ قَالُوا: نَتَّقِی لِسَانَہُ، قَالَ: ذَاکَ أَدْنَی أَنْ تَکُونُوا شُہَدَائَ۔",,,26049 26050,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنْ قَیْسٍ ، أَنَّ عَمْرَو بْنَ الْعَاصِ مَرَّ عَلَی بَغْلٍ مَیِّتٍ فَقَالَ لأَصْحَابِہِ : إِنْ یَأْکُلْ أَحَدُکُمْ مِنْ ہَذَا حَتَّی یَمْلاَ بَطْنَہُ خَیْرٌ مِنْ أَنْ یَأْکُلَ لَحْمَ أَخِیہِ الْمُسْلِمِ۔",,,26050 26051,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إبْرَاہِیمَ ، قَالَ : حَدَّثَنَا الْعَلاَئُ ، عَنْ أَبِیہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أَنَّہُ قَالَ لَہُ : مَا الْغِیبَۃُ یَا رَسُولَ اللہِ ؟ قَالَ : ذِکْرُک أَخَاک بِمَا یَکْرَہُ ، قَالَ : أَفَرَأَیْت إِنْ کَانَ فِی أَخِی مَا أَقُولُ یَا رَسُولَ اللہِ ؟ قَالَ : إِنْ کَانَ فِی أَخِیک مَا تَقُولُ ، فَقَدِ اغْتَبْتہ ، وَإِنْ لَمْ یَکُنْ فِیہِ مَا تَقُولُ ، فَقَدْ بَہَتَّہُ۔ (مسلم 2001۔ ابوداؤد 4841)",,,26051 26052,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْحَکَمِ ، عَنِ ابْنٍ لأَبِی الدَّرْدَائِ ، أَنَّ رَجُلاً وَقَعَ فِی رَجُلٍ فَرَدَّ عَنْہُ آخَرُ فَقَالَ أَبُو الدَّرْدَائِ : سَمِعْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : مَنْ ذَبَّ عَنْ عِرْضِ أَخِیہِ کَانَ لَہُ حِجَابًا مِنَ النَّارِ۔ (ترمذی 1931۔ احمد 6/450)",,,26052 26053,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ عَوْنٍ ، قَالَ : وَقَعَ رَجُلٌ فِی رَجُلٍ فَرَدَّ عَلَیْہِ آخَرُ فَقَالَتْ أُمُّ الدَّرْدَائِ : لَقَدْ غَبَطْتُک ، إِنَّہُ مَنْ ذَبَّ عَنْ عِرْضِ أَخِیہِ ، وَقَاہُ اللَّہُ ، قَالَ مِسْعَرٌ : نَفْحَ ، أَوْ لَفْحَ النَّارِ۔",,,26053 26054,"حَدَّثَنَا شَرِیکٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : قَالَ عَبْدُ اللہِ : إذَا قُلْتَ مَا فِی الرَّجُلِ فَلَمْ تُزَکِّہِ۔",,,26054 26055,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ زِیَادِ بْنِ عِلاَقَۃَ ، عَنْ أُسَامَۃَ بْنِ شَرِیکٍ ، قَالَ : شَہِدْت الأَعْرَابَ یَسْأَلُونَ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : عَلَیْنَا حَرَجٌ فِی کَذَا وَکَذَا ؟ فَقَالَ : عِبَادَ اللہِ ، وَضَعَ اللَّہُ الْحَرَجَ إلاَّ مَنِ اقْتَرَضَ مِنْ عِرْضِ أَخِیہِ شَیْئًا فَذَلِکَ الَّذِی حَرَجٌ۔",,,26055 26056,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ شُعْبَۃَ ، عَنْ مُعَاوِیَۃَ بْنِ قُرَّۃَ ، قَالَ : لَوْ رَأَیْت أَقْطَعَ فَذَکَرْتہ فَقُلْت الأَقْطَعُ کَانَتْ غِیبَۃً ، قَالَ : فَذَکَرْتہ لأَبِی إِسْحَاقَ فَقَالَ : صَدَقَ۔",,,26056 26057,"حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ ، عَنْ عَبْدِ اللہِ بْنِ بَکْرٍ ، عَنْ أَبِیہِ ، قَالَ أَبُو مُوسَی الأَشْعَرِیُّ : لَوْ رَأَیْت رَجُلاً یَرْضَعُ شَاۃً فِی الطَّرِیقِ فَسَخِرْت مِنْہُ خِفْت أَنْ لاَ أَمُوتَ حَتَّی أَرْضَعَہَا۔",,,26057 26058,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، قَالَ : أَخْبَرَنَا حَسَنٌ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنِ الشَّعْبِیِّ ، عَنِ ابْنِ مَسْعُودٍ ، قَالَ : إذَا قُلْتَ مَا ہُوَ فِیہِ ، وَہُوَ لاَ یَسْمَعُ ، فَقَدِ اغْتَبْتہ ، وَإِذَا قُلْتَ مَا لَیْسَ فِیہِ ، فَقَدْ بَہَتَّہُ۔",,,26058 26059,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : قَالَ عَبْدُ اللہِ : لَوْ سَخِرْت مِنْ کَلْبٍ لَخَشِیت أَنْ أَکُونَ کَلْبًا۔",,,26059 26060,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : قَالَ عَبْدُ اللہِ : الْبَلاَئُ مُوَکَّلٌ بِالْقَوْلِ۔",,,26060 26061,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن أَبِی الضُّحَی ، عَنْ مَسْرُوقٍ، قَالَ: إذَا قُلْتَ مَا فِیہِ، فَقَدِ اغْتَبْتہ ، وَإِنْ قُلْتَ مَا لَیْسَ فِیہِ ، فَقَدْ بَہَتَّہ۔",,,26061 26062,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنِ ابْنِ عَجْلاَنَ ، عَنِ الْحَارِثِ ، قَالَ : کُنْتُ أَخِذًا بِیَدِ إبْرَاہِیمَ وَنَحْنُ نُرِید الْمَسْجِدَ ، قَالَ : فَذَکَرْت رَجُلاً فَاغْتَبْتہ ، قَالَ فَقَالَ لی إبْرَاہِیمُ : ارْجِعْ فَتَوَضَّأْ ، کَانُوا یَعُدُّونَ ہَذَا ہُجْرًا۔",,,26062 26063,حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ عُرْوَۃَ ، أَنَّہُ کَانَ لَہُ مُشْطٌ مِنْ عِظَامِ الْفِیلِ وَمَدْہَنٌ مِنْ عِظَامِ الْفِیلِ۔,,,26063 26064,"حَدَّثَنَا عَبْدَۃُ ، عَنْ ہِشَامٍ ، قَالَ : رَأَیْتُ أَبِی یَدَّہِنُ فِی مَدْہَنٍ مِنْ عِظَامِ الْفِیلِ۔",,,26064 26065,حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، أَنَّہُ کَانَ لَہُ مَدْہَنٌ مِنْ عَاجٍ یَدَّہِنُ فِیہِ۔,,,26065 26066,"حَدَّثَنَا وَکِیعٌ ، عَنْ أُسَامَۃَ بْنِ زَیْدٍ ، عَنْ إسْمَاعِیلَ بْنِ أُمَیَّۃَ ، عَنْ أُمہِ ، عَنْ سُرِّیَّۃٍ لِعُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَتْ : أَتَیْتہ بِمَدْہَنٍ مِنْ عَاجٍ ، أَوْ مُشْطٍ مِنْ عَاجٍ فَکَرِہَہُ وَقَالَ : ہُوَ مَیْتَۃٌ۔",,,26066 26067,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، أَنَّہُ کَرِہَ الْعَاجَ۔,,,26067 26068,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، أَنَّہُ کَرِہَ الْعَاجَ۔,,,26068 26069,حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، أَنَّہُ کَرِہَ الْعَاجَ کُلَّہُ ، وَأَنْ یُتَّخَذَ مِنْہُ مِشْطًا۔,,,26069 26070,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی خُزَیْمَۃَ ، عَنِ الْحَسَنِ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ التَّرَجُّلِ إلاَّ غِبًّا۔ (ابوداؤد 4156۔ ترمذی 1756)",,,26070 26071,حَدَّثَنَا وَکِیعٌ ، عَنْ جُوَیْرِیَۃَ بْنِ أَسْمَائَ ، عَنْ نَافِعٍ ، أَنَّ ابْنَ عُمَرَ کَانَ رُبَّمَا ادَّہَنَ فِی الْیَوْمِ مَرَّتَیْنِ۔,,,26071 26072,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا سَعِید ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ التَّرَجُّلِ إلاَّ غِبًّا۔",,,26072 26073,"حَدَّثَنَا یُونُسُ بْنُ مُحَمَّدٍ ، قَالَ : حدَّثَنَا أَبُو ہِلاَلٍ ، عَنْ شَیْبَۃَ بْنِ ہِشَامٍ ، عَنْ مُغِیرَۃَ بْنِ الْحَارِثِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : التَّرَجُّلُ غِبًّا۔",,,26073 26074,"حَدَّثَنَا ابْنُ أَبِی عَدِیٍّ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : کَانُوا یَکْرَہُونَ التَّرَجُّلَ کُلَّ یَوْمٍ۔",,,26074 26075,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، وَعَبْدُ اللہِ بْنُ نُمَیْرٍ ، قَالاَ : حدَّثَنَا عُبَید اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا کَانَ ثَلاَثَۃٌ فَلاَ یَتَسَارَّ اثْنَانِ دُونَ الآخَرِ ، وَقَالَ ابْنُ نُمَیْرٍ : یَتَنَاج۔ (مسلم 1717۔ احمد 2/141)",,,26075 26076,"حَدَّثَنَا أَبُو الأَحْوَص ، عَنْ مَنْصُورٍ ، عَنْ أَبِی وَائِلٍ ، عَنْ عَبْدِ اللہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا کنا ثَلاَثَۃً أَنْ یَتَنَاجَی اثْنَانِ دُونَ وَاحِدٍ أَجْلَ أَنْ یُحْزِنَہُ حَتَّی یَخْتَلِطَ بِالنَّاسِ۔\n\n(مسلم 1718۔ بخاری 6290)",,,26076 26077,"حَدَّثَنَا أَبُو الأَحْوَص ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الأَحْوَص ، قَالَ : قَالَ عَبْدُ اللہِ : إذَا کَانَ ثَلاَثَۃُ نَفَرٍ فلا یَنْتَجِی اثْنَانِ دُونَ وَاحِدٍ ، فَإِنَّ ذَلِکَ یَسُوئُہُ۔",,,26077 26078,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ سَعِیدِ بْنِ أَبِی سَعِیدٍ ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ وَہُوَ یُنَاجِی رَجُلاً ، فَأَدْخَلْت رَأْسِی بَیْنَہُمَا فَضَرَبَ ابْنُ عُمَرَ صَدْرِی وَقَالَ : إذَا رَأَیْت اثْنَیْنِ یَتَنَاجَیَانِ فَلاَ تَدْخُلْ بَیْنَہُمَا إلاَّ بِإِذْنِہِمَا۔",,,26078 26079,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی صَالِحٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : إذَا کَانَ الْقَوْمُ أَرْبَعَۃً فَلاَ بَأْسَ أَنْ یَتَنَاجَی اثْنَانِ دُونَ صَاحِبَیْہِمَا۔ (ابوداؤد 4818)",,,26079 26080,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو سَمِعَ جَابِرًا یَقُولُ : مَرَّ رَجُلٌ فِی الْمَسْجِدِ بِسِہَامٍ فَقَالَ لَہُ : رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَمْسِکْ بِنِصَالِہَا۔",,,26080 26081,"حَدَّثَنَا وَکِیعٌ ، عَنْ بُرَیْدِ بْنِ عَبْدِ اللہِ ، عَنْ أَبِی بُرْدَۃَ ، عَنْ أَبِیہِ ، قَالَ : إذَا مَرَّ أَحَدُکُمْ فِی الْمَسْجِدِ بِنَبْلٍ فَلْیُمْسِکْ بِنِصَالِہَا۔",,,26081 26082,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : حدَّثَنَا عَاصِمٌ ، عَنِ الْحَسَنِ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَأَی قَوْمًا یَتَعَاطَوْنَ سَیْفًا مَشْہُورًا فَقَالَ : لَعَنَ اللَّہُ ہَؤُلاَئِ ، فَقُلْت للحسن : إنَّہُ کَانَ فِی الْمَسْجِدِ ، فَقَالَ : لاَ ، بَلْ فِی رَحْبَۃٍ مِنْ رِحَابِ الْمَسْجِدِ۔ (احمد 5/41۔ حاکم 290)",,,26082 26083,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ لَیْثٍ، عَنْ مُجَاہِدٍ، قَالَ: مَلْعُونٌ مَنْ نَاوَلَ أَخَاہُ السَّیْفَ مَسْلُولاً فِی الْمَسْجِدِ۔",,,26083 26084,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَسْلَمَ الْمُنْقِرِیِّ ، عَنْ عَبْدِ اللہِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ أَبْزَی ، أَنَّہُ کَرِہَ سَلَّ السَّیْفِ فِی الْمَسْجِدِ۔,,,26084 26085,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ مُحَمَّدِ بْنِ الْمُنْکَدِرِ ، عَنِ الْحَسَنِ ، قَالَ : سَمِعْتُہُ یَقُولُ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ نَاوَلَ أَخَاہُ السَّیْفَ فَلْیَغْمِدْہُ۔",,,26085 26086,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یُتَعَاطَی السَّیْفُ مَسْلُولاً۔ (ترمذی 2163۔ ابوداؤد 2581)",,,26086 26087,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَلِیِّ بْنِ زَیْدِ بْنِ جُدْعَانَ ، عَنِ الْحَسَنِ ، قَالَ : نَہَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یُتَعَاطَی السَّیْفُ مَسْلُولاً ، وَمَرَّ بِقَوْمٍ یَتَعَاطَوْنَ سَیْفًا مَسْلُولاً فَقَالَ : أَلَمْ أَنْہَکُمْ عن ہَذَا ؟ لَعَنَ اللَّہُ مَنْ فَعَلَ ہَذَا۔ (احمد 3/361)",,,26087 26088,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ عَلِیِّ بْنِ زَیْدِ بْنِ جُدْعَانَ ، عَنِ الْحَسَنِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَقُمْ رَجُلٌ لِرَجُلٍ ، وَلَکِنْ لِیُوسِعْ لَہُ۔",,,26088 26089,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لاَ یُقِیمَنَّ أَحَدُکُمْ أَخَاہُ مِنْ مَجْلِسِہِ ، ثُمَّ یَجْلِسَ فِیہِ ، قَالَ : وَکَانَ ابْنُ عُمَرَ إذَا قَامَ لَہُ الرَّجُلُ عن مَجْلِسِہِ لَمْ یَجْلِسْ فِیہِ۔ (مسلم 1714۔ احمد 2/89)",,,26089 26090,"حَدَّثَنَا ابْنُ نُمَیْرٍ وَأَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یُقِیمَنَّ الرَّجُلُ الرَّجُلَ عَنْ مَقْعَدِہِ ثُمَّ یَقْعُدَ فِیہِ ، وَلَکِنْ تَفَسَّحُوا وَتَوَسَّعُوا۔\n\n(مسلم 1714۔ احمد 2/16)",,,26090 26091,"حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ عَبْدِ رَبِّہِ بْنِ سَعِیدٍ ، عَنْ مَوْلًی لأَبِی مُوسَی ، عَنْ سَعِیدِ بْنِ أَبِی الْحَسَنِ ، عَنْ أَبِی بَکْرَۃَ ، أَنَّہُ دُعِیَ إلَی شَہَادَۃٍ فَقَامَ لَہُ رَجُلٌ مِنْ مَجْلِسِہِ فَقَالَ لَہُ : إنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی إذَا قَامَ الرَّجُلُ لِلرَّجُلِ عَنْ مَجْلِسِہِ أَنْ یَجْلِسَ فِیہِ ، وَنَہَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یَمْسَحَ الرَّجُلُ یَدَہُ بِثَوْبِ مَنْ لاَ یَکْسُو۔ (ابوداؤد 4794۔ احمد 5/44)",,,26091 26092,"حَدَّثَنَا یُونُسُ بْنُ مُحَمَّدٍ ، قَالَ: حدَّثَنَا فُلَیْحٌ ، عَنْ أَیُّوبَ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ یَعْقُوبَ بْنِ أَبِی یَعْقُوبَ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَقُومُ الرَّجُلُ لِلرَّجُلِ عَنْ مَجْلِسِہِ ، وَلَکِنِ افْسَحُوا یَفْسَحَ اللَّہُ لَکُمْ۔ (احمد 2/338)",,,26092 26093,"حَدَّثَنَا أَبُو الأَحْوَص ، عَنْ عَطَائٍ ، عَنْ أَبِی الْبَخْتَرِیِّ ، قَالَ : کَانَ یُکْرَہُ أَنْ یَقُومَ الرَّجُلُ مِنْ مَجْلِسِہِ لِلرَّجُلِ لِیَجْلِسَ فِیہِ۔",,,26093 26094,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ مِسْعَرٍ ، عَنْ أَبِی الْعَنْبَسِ ، عَنْ أَبِی الْعَدَبَّسِ ، عَنْ أَبِی مَرْزُوقٍ ، عَنْ أَبِی غَالِبٍ ، عَنْ أَبِی أُمَامَۃَ ، قَالَ : خَرَجَ عَلَیْنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مُتَوَکِّئًا عَلَی عَصًا ، فَقُمْنَا إلَیْہِ فَقَالَ : لاَ تَقُومُوا کَمَا تَقُومُ الأَعَاجِمُ یُعَظِّمُ بَعْضُہَا بَعْضًا۔ (ابوداؤد 5187۔ ابن ماجہ 3836)",,,26094 26095,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ حَبِیبِ بْنِ شَہِیدٍ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ : دَخَلَ مُعَاوِیَۃُ بَیْتًا فِیہِ عَبْدُ اللہِ بْنُ عَامِرٍ، وَعَبْدُ اللہِ بْنُ الزُّبَیْرِ ، فَقَامَ عَبْدُ اللہِ بْنُ عَامِرٍ وَلَمْ یَقُمْ عَبْدُ اللہِ بْنُ الزُّبَیْرِ فَقَالَ مُعَاوِیَۃُ لابْنِ عَامِرٍ : اجْلِسْ ، فَإِنِّی سَمِعْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : مَنْ سَرَّہُ أَنْ یَتَمَثَّلَ لَہُ الرِّجَالُ قِیَامًا فَلْیَتَبَوَّأْ مَقْعَدَہُ مِنَ النَّارِ۔ (ترمذی 2755۔ ابوداؤد 5186)",,,26095 26096,"عَفَّان ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ حُمَیْدٍ ، عَنْ أَنَسٍ ، قَالَ : مَا کَانَ شَخْصٌ أَحَبَّ إلَیْہِمْ مِنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَکَانُوا إذَا رَأَوْہُ لَمْ یَقُومُوا لِمَا یَعْلَمُونَ مِنْ کَرَاہِیَتِہِ لِذَلِکَ۔\n\n(ترمذی 2754)",,,26096 26097,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ أَبِیہِ ، عَنْ طَارِقٍ ، قَالَ : کُنَّا جُلُوسًا عِنْدَ الشَّعْبِیِّ ، فَجَائَ جَرِیرُ بْنُ یَزِیدَ ، فَدَعَا لَہُ الشَّعْبِیُّ بِوِسَادَۃٍ فَقُلْنَا لَہُ : یَا أَبَا عَمْرٍو نَحْنُ عِنْدَکَ أَشْیَاخٌ ، دَعَوْت لِہَذَا الْغُلاَمِ بِوِسَادَۃٍ ؟ فَقَالَ : إنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إذَا أَتَاکُمْ کَرِیمُ قَوْمٍ فَأَکْرِمُوہُ۔",,,26097 26098,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ طَارِق ، عَنِ الشَّعْبِیِّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا أَتَاکُمْ کَرِیمُ قَوْمٍ فَأَکْرِمُوہُ۔ (ابوداؤد 511)",,,26098 26099,"حَدَّثَنَا عُبَیْدُ اللہِ ، قَالَ : أَخْبَرَنَا حَسَنُ بْنُ صَالِحٍ ، عَنْ عَاصِمٍ ، قَالَ : طَرَحَ أَبُو قِلاَبَۃَ لِرَجُلٍ وِسَادَۃً فَقَالَ أَبُو قِلاَبَۃَ : إِنَّہُ کَانَ یُقَالُ : لاَ تَرُدَّ عَلَی أَخِیک کَرَامَتَہُ۔",,,26099 26100,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، قَالَ : دَخَلَ عَلِیٌّ وَرَجُلٌ ، فَطَرَحَ لَہُمَا وِسَادَتَیْنِ ، فَجَلَسَ عَلِیٌّ وَلَمْ یَجْلِسِ الآخَرُ ، فَقَالَ عَلِیٌّ : لاَ یَرُدُّ الْکَرَامَۃَ إلاَّ حِمَارٌ۔",,,26100 26101,"حَدَّثَنَا وَکِیعٌ ، عَنِ الْحَسَنِ ، عَنْ سِمَاکٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : خُذِ الْحُکْمَ مِمَّنْ سَمِعْتہ ، فَإِنَّمَا ہُوَ مِثْلُ الرَّمْیَۃِ مِنْ غَیْرِ رَامٍ۔",,,26101 26102,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا زَکَرِیَّا بْنُ أَبِی زَائِدَۃَ ، قَالَ : حَدَّثَنِی عَلِیُّ بْنُ الأَقْمَرِ ، أَنَّ أَبَا جُحَیْفَۃَ کَانَ یَقُولُ : جَالِسُوا الْکُبَرَائَ ، وَخَالِطُوا الْحُکَمَائَ ، وَسَائِلُوا الْعُلَمَائَ۔",,,26102 26103,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ أَبِی جَعْفَرٍ الْخَطْمِیِّ ، أَنَّ جَدَّہُ وَہُوَ عُمَیْرُ بْنُ حَبِیبٍ أَوْصَی بَنِیہِ فَقَالَ : یَا بَنِیَّ ، إیَّاکُمْ وَمُجَالَسَۃَ السُّفَہَائِ ، فَإِنَّ مُجَالَسَتَہُمْ دَائٌ ، إِنَّہُ مَنْ یَحْلُمُ ، عَنِ السَّفِیہِ یُسَرَّ بِحِلْمِہِ ، وَمَنْ یُحبہ یَنْدَمُ ، وَمَنْ لاَ یَقَرُّ بِقَلِیلِ مَا یَجِیئُ بِہِ السَّفِیہُ یَقَرُّ بِالْکَثِیرِ ، وَإِذَا أَرَادَ أَحَدُکُمْ أَنْ یَأْمُرَ بِالْمَعْرُوفِ وَیَنْہَی عَنِ الْمُنْکَرِ فَلْیُوَطِّنْ نَفْسَہُ عَلَی الصَّبْرِ عَلَی الأَذَی ، فَإِنَّہُ مَنْ یَصْبِرُ لاَ یَجِدُ لِلأَذَی مَسًّا۔",,,26103 26104,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ، قَالَ : قَالَ أَبُو الدَّرْدَائِ : إنَّ مِنْ فِقْہِ الرَّجُلِ مَمْشَاہُ وَمَدْخَلَہُ ، قَالَ أَبُو قِلاَبَۃَ : قَاتَلَ اللَّہُ الشَّاعِرَ حَیْثُ یَقُولُ :\n\nعَنِ الْمَرْئِ لاَ تَسْأَلْ وأبصر قَرِینَہُ وَ کُلُّ قَرِینٍ بِالْمُقَارَنِ مُہْتَدِی",,,26104 26105,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عن أبی إسحاق، عَنْ مُرَّۃَ، أَوْ ہُبَیْرَۃَ، قَالَ: قَالَ عَبْدُ اللہِ: اعْتَبِرُوا النَّاسَ بِأخْدانِہِمْ۔",,,26105 26106,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ مَیْمُونٍ الْجُہَنِیِّ أَبی مَنْصُورا ، قَالَ : سَمِعْتُ إبْرَاہِیمَ یَقُولُ : إذَا دَخَلَ أَحَدُکُمْ بَیْتًا فَأَیْنَمَا أَجْلَسُوہُ فَلْیَجْلِسْ ، ہُمْ أَعْلَمُ بِعَوْرَۃِ بَیْتِہِمْ۔",,,26106 26107,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، قَالَ : رَأَیْتُ شُرَیْحًا یَمْشِی مُخْتَصِرًا۔",,,26107 26108,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ خَالِدٍ الْحَذَّائِ ، عَنْ حُمَیْدِ بْنِ ہِلاَلٍ ، قَالَ : إنَّمَا یُکْرَہُ الاخْتِصَارُ فِی الصَّلاَۃِ لأَنَّ إبْلِیسَ أُہْبِطَ مُخْتَصِرًا۔",,,26108 26109,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنِ الْحَکَمِ بْنِ عَطِیَّۃَ ، قَالَ : سَمِعْتُ الْحَسَنَ یَقُولُ إذَا حَدَّثَ الرَّجُلُ الرَّجُلَ بِحَدِیثٍ وَقَالَ : اکْتُمْ عَلَیَّ ، فَہِیَ أَمَانَۃٌ۔",,,26109 26110,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنِ الشَّعْبِیِّ مِثْلُہُ۔,,,26110 26111,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا ابْنُ أَبِی ذِئْبٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَطَائٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ جَابِرِ بْنِ عَتِیکٍ ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إذَا حَدَّثَ الرَّجُلُ الرَّجُلَ بِالْحَدِیثِ ، ثُمَّ الْتَفَتَ فَہِیَ أَمَانَۃٌ۔ (ابوداؤد 4835۔ ترمذی 1959)",,,26111 26112,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی وَائِلٍ ، عَنْ عَبْدِ اللہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إیَّاکُمْ وَالْکَذِبَ ، فَإِنَّ الْکَذِبَ یَہْدِی إلَی الْفُجُورِ ، وَإِنَّ الْفُجُورَ یَہْدِی إلَی النَّارِ ، وَإِنَّ الرَّجُلَ لَیَکْذِبُ وَیَتَحَرَّی الْکَذِبَ حَتَّی یُکْتَبَ عِنْدَ اللہِ کَذَّابًا ، وَعَلَیْکُمْ بِالصِّدْقِ ، فَإِنَّ الصِّدْقَ بِرٌّ ، وَالْبِرُّ یَہْدِی إلَی الْجَنَّۃِ ، وَإِنَّ الرَّجُلَ یَصْدُقُ وَیَتَحَرَّی الصِّدْقَ حَتَّی یُکْتَبَ عِنْدَ اللہِ صِدِّیقًا۔ (مسلم 105۔ ابوداؤد 4950)",,,26112 26113,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ مُرَّۃَ بْنِ شَرَاحِیلَ ، قَالَ : قَالَ عَبْدُ اللہِ : إنَّ الرَّجُلَ لَیَصْدُقُ وَیَتَحَرَّی الصِّدْقَ حَتَّی مَا یَکُونُ لِلْفُجُورِ فِی قَلْبِہِ مَوْضِعُ إبْرَۃٍ یَسْتَقِرُّ فِیہِ ، وَإِنَّہُ لَیَکْذِبُ وَیَتَحَرَّی الْکَذِبَ حَتَّی مَا یَکُونُ لِلصِّدْقِ فِی قَلْبِہِ مَوْضِعُ إبْرَۃٍ یَسْتَقِرُّ فِیہِ۔",,,26113 26114,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَبْدِ اللہِ ، وَعَنْ مُجَاہِدٍ، عَنْ أَبِی مَعْمَرٍ، عَنْ عَبْدِ اللہِ، وَعَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ أَبِی الْبَخْتَرِیِّ ، عَنْ عَبْدِ اللہِ ، قَالَ : لاَ یَصْلُحُ الْکَذِبُ فِی جَدٍّ ، وَلاَ ہَزْلٍ ، ثُمَّ تَلاَ عَبْدُ اللہِ {اتَّقُوا اللَّہَ وَکُونُوا مَعَ الصَّادِقِینَ}۔ (دارمی 2715)",,,26114 26115,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، عَنْ قَیْسٍ ، قَالَ : قَالَ أَبُو بَکْرٍ : إیَّاکُمْ وَالْکَذِبَ فَإِنَّہُ مُجَانِبُ الإِیمَانَ۔",,,26115 26116,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ مَالِکِ بْنِ الْحَارِثِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ، عَنْ عَبْدِ اللہِ ، قَالَ : الْمُؤْمِنُ یُطْوَی عَلَی الْخِلاَلِ کُلِّہَا غَیْرِ الْخِیَانَۃِ وَالْکَذِبِ۔",,,26116 26117,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سُفْیَانَ ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنْ مُصْعَبِ بْنِ سَعْدٍ ، عَنْ سَعْدٍ ، قَالَ : الْمُؤْمِنُ یُطْبَعُ عَلَی الْخِلاَلِ کُلِّہَا غَیْرِ الْخِیَانَۃِ وَالْکَذِبِ۔ (بزار 1139۔ ابو یعلی 707)",,,26117 26118,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا إسْمَاعِیلُ بْنُ أَبِی خَالِدٍ ، قَالَ : ذُکِرَ عِنْدَ عَامِرٍ ، أَنَّ الْمُنَافِقَ الَّذِی إذَا حَدَّثَ کَذَبَ ، فَقَالَ عَامِرٌ : لاَ أَدْرِی مَا تَقُولُونَ ؟ إِنْ کَانَ کَذَّابًا ، فَہُوَ مُنَافِقٌ۔",,,26118 26119,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَبِیبٍ ، عَنْ مَیْمُونِ بْنِ أَبِی شَبِیبٍ ، عَنْ عُمَرَ ، قَالَ : لاَ تَبْلُغُ حَقِیقَۃَ الإِیمَانِ حَتَّی تَدَعَ الْکَذِبَ فِی الْمِزَاحِ۔",,,26119 26120,"حَدَّثَنَا یَزِیدُ ، قَالَ : أَخْبَرَنَا عَوْنٌ ، قَالَ : ذُکِرَ الْکَذِبُ عِنْدَ مُحَمَّدٍ فِی الْحَرْبِ ، أَنَّہُ لاَ بَأْسَ بِہِ ، فَقَالَ مُحَمَّدٌ : لاَ أَعْلَمُ الْکَذِبَ إلاَّ حَرَامًا۔",,,26120 26121,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، قَالَ : حُدِّثْت عَنْ أَبِی أُمَامَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : یُطْوَی الْمُؤْمِنُ عَلَی الْخِلاَلِ کُلِّہَا غَیْرِ الْخِیَانَۃِ وَالْکَذِبِ۔ (احمد 5/252)",,,26121 26122,"حَدَّثَنَا شَبَابَۃُ ، عَنِ اللَّیْثِ ، عَنِ ابْنِ عَجْلاَنَ ، أَنَّ رَجُلاً مِنْ مَوَالِی عَبْدِ اللہِ بْنِ عَامِرٍ بن رَبیعۃ العدوی ، حَدَّثَہُ عَنْ عَبْدِ اللہِ بْنِ عَامِرٍ ، أَنَّہُ قَالَ : دَعَتْنِی أُمِّی یَوْمًا وَرَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَاعِدٌ فِی بَیْتِنَا ، فَقَالَتْ : ہَا تَعَالَ أُعْطِیک ، فَقَالَ لَہَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : وَمَا أَرَدْت أَنْ تُعْطِیَہُ ؟ قَالَتْ : تَمْرًا ، فَقَالَ لَہَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَمَا إنَّک لَوْ لَمْ تُعْطِہِ شَیْئًا کُتِبَتْ عَلَیْکِ کِذْبَۃٌ۔\n\n(ابوداؤد 4952۔ احمد 3/447)",,,26122 26123,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ عَبْدِ اللہِ بْنِ مُرَّۃَ ، عَنْ مَسْرُوقٍ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَرْبَعٌ مَنْ کُنَّ فِیہِ ، فَہُوَ مُنَافِقٌ خَالِصٌ ، وَمَنْ کَانَتْ فِیہِ خَلَّۃٌ مِنْہُنَّ کَانَتْ فِیہِ خَلَّۃٌ مِنْ نِفَاقٍ حَتَّی یَدَعَہَا : إذَا حَدَّثَ کَذَبَ ، وَإِذَا وَعَدَ أَخْلَفَ ، وَإِذَا عَاہَدَ غَدَرَ ، وَإِذَا خَاصَمَ فَجَرَ۔ (مسلم 106۔ ابو داؤد 4655)",,,26123 26124,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ عُمَارَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، قَالَ : قَالَ عَبْدُ اللہِ : اعْتَبِرُوا الْمُنَافِقَ بِثَلاَثٍ : إذَا حَدَّثَ کَذَبَ ، وَإِذَا وَعَدَ أَخْلَفَ ، وَإِذَا عَاہَدَ غَدَرَ۔ (نسائی 11754)",,,26124 26125,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ سِمَاکٍ ، عَن صُبَیح بْنِ عَبْدِ اللہِ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ، قَالَ : ثَلاَثٌ مَنْ کُنَّ فِیہِ فَہُوَ مُنَافِقٌ : إذَا حَدَّثَ کَذَبَ وَإِذَا وَعَدَ أَخْلَفَ وَإِذَا اُؤْتُمِنَ خَانَ: قَالَ : وَتَلاَ ہَذِہِ الآیَۃَ : {وَمِنْہُمْ مَنْ عَاہَدَ اللَّہَ لَئِنْ آتَانَا مِنْ فَضْلِہِ } إلَی قَوْلِہِ : { نِفَاقًا فِی قُلُوبِہِمْ } إلَی قَوْلِہِ : { بِمَا کَانُوا یَکْذِبُونَ } (التوبۃ: 75 تا 77)",,,26125 26126,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ یَزِیدَ ، عَنْ مُجَاہِدٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : ثَلاَثٌ مَنْ کُنَّ فِیہِ ، فَہُوَ مُنَافِقٌ : الَّذِی إذَا حَدَّثَ کَذَبَ ، وَإِذَا وَعَدَ أَخْلَفَ ، وَإِذَا اُؤْتُمِنَ خَانَ۔\n\n(بخار ی33۔ ترمذی 2631)",,,26126 26127,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : ثَلاَثٌ مَنْ کُنَّ فِیہِ ، فَہُوَ مُنَافِقٌ ، وَإِنْ صَامَ وَصَلَّی وَقَالَ إِنِّی مُسْلِمٍ : إذَا حَدَّثَ کَذَبَ ، وَإِذَا اؤْتُمِنَ خَانَ ، وَإِذَا وَعَدَ أَخْلَفَ۔",,,26127 26128,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَبِیبٍ ، عَنْ مَیْمُونِ بْنِ أَبِی شَبِیبٍ ، عَنِ الْمُغِیرَۃِ بْنِ شُعْبَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ حَدَّثَ عَنِّی بِحَدِیثٍ وَہُوَ یُرَی ، أَنَّہُ کَذِبٌ ، فَہُوَ أَحَدُ الْکَاذِبَِیْنِ۔\n\n(ترمذی 2662۔ احمد 4/252)",,,26128 26129,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، عَنْ سَمُرَۃََ بْنِ جُنْدَبٍ ، قَالَ : قَالَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ حَدَّثَ عَنِّی حَدِیثًا وَہُوَ یُرَی ، أَنَّہُ کَذِبٌ ، فَہُوَ أَحَدُ الْکَاذِبَیْنِ۔\n\n(ابن ماجہ 39۔ احمد 20)",,,26129 26130,حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْحَکَمِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، عَنْ عَلِیٍّ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِمِثْلِ حَدِیثِ سَمُرَۃَ۔ (ابن ماجہ 38),,,26130 26131,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ شُعْبَۃَ ، قَالَ : حدَّثَنِی خُبَیْبٌ ، عَنْ حَفْصِ بْنِ عَاصِمٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : کَفَی بِالْمَرْئِ کَذِبًا أَنْ یُحَدِّثَ بِکُلِّ مَا سَمِعَ۔ (مسلم 5۔ ابوداؤد 4953)",,,26131 26132,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی عُثْمَانَ ، قَالَ : قَالَ عُمَرُ : حَسْبُ امْرِئٍ مِنَ الْکَذِبِ أَنْ یُحَدِّثَ بِکُلِّ مَا سَمِعَ۔",,,26132 26133,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الأَحْوَص ، عَنْ عَبْدِ اللہِ ، قَالَ : بحسْبِ امْرِئٍ مِنَ الْکَذِبِ أَنْ یُحَدِّثَ بِکُلِّ مَا سَمِعَ۔",,,26133 26134,"حَدَّثَنَا حَرَمِیُّ بْنُ عُمَارَۃَ بْنِ أَبِی حَفْصَۃَ ، عَنْ شُعْبَۃَ ، عَنْ رَجُلٍ ، قَالَ : قَالَ شُرَیْحٌ : الْحِلْمُ کَنْزٌ مُوفَّرٌ۔",,,26134 26135,"حَدَّثَنَا عَبْدُ الرَّحْمَان بْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عَاصِمٍ الأَحْوَلِ ، قَالَ : قَالَ الشَّعْبِیُّ : زَیَّنَ الْعِلْمَ حِلْمُ أَہْلِہِ۔",,,26135 26136,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، قَالَ : قَالَ مُعَاوِیَۃُ : لاَ حِلْمَ إلاَّ التَجَارِب۔",,,26136 26137,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ زَمْعَۃَ ، عَنْ سَلَمَۃَ بْنِ وَہْرَام ، عَنْ طَاوُوسٍ ، قَالَ : مَا جُعِلَ الْعِلْمُ ، أَوَ مَا حُمِلَ الْعِلْمُ فِی مِثْلِ جِرَابِ حِلْمٍ۔",,,26137 26138,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ سَعِیدِ بْنِ زَیْدٍ ، قَالَ : سَمِعْتُ بُرْدًا ، عَنْ سُلَیْمَانَ بْنِ مُوسَی ، قَالَ : مَا جُمِعَ شَیْئٌ إلَی شَیْئٍ أَزْیَنَ مِنْ عِلْمٍ إلَی حِلْمٍ۔",,,26138 26139,"حَدَّثَنَا عَفَّانُ، قَالَ: حدَّثَنَا عَرْعَرَۃُ بْنُ الْبِرِنْدِ، عَنِ ابْنِ عَوْنٍ، عَنِ الْحَسَنِ، قَالَ: قَالَ الأَحْنَفُ بْنُ قَیْسٍ: إنِّی لَسْت بِحَلِیمٍ ، وَلَکِنِّی أَتَحَالَمُ۔",,,26139 26140,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مَنْصُورٍ، عَنْ عبد اللہِ، قَالَ: لاَ تَنْشُرْ بَزَّک إلاَّ عِنْدَ مَنْ یبغیہ۔ (احمد 360)",,,26140 26141,"حَدَّثَنَا غُنْدَرٌ، عَنْ شُعْبَۃَ، عَنِ الأَعْمَش، عَنْ مُسْلِم، عَن مَسْروق قَالَ: لاَ تَنْشُرْ بَزَّک إلاَّ عِنْدَ مَنْ یُرِیدُہُ۔",,,26141 26142,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ، قَالَ : لاَ تُحَدِّثْ بِالْحَدِیثِ إلاَّ مَنْ یَعْرِفُہُ ، فَإِنَّ مَنْ لاَ یَعْرِفُہُ یَضُرُّہُ ، وَلاَ یَنْفَعُہُ۔",,,26142 26143,"حَدَّثَنَا وَکِیعٌ، عَنْ شُعْبَۃَ، عَنْ عَمَّارٍ الدُّہْنِیِّ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ: لاَ أَنْشُرُ بَزِّی عِنْدَ مَنْ لاَ یُرِیدُہُ۔",,,26143 26144,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مِسْعَرٍ ، عَنْ عُبَیْدِ بْنِ الْحَسَنِ ، عَنِ ابْنِ مَعْقِلٍ ، عَنِ ابْنِ مَسْعُودٍ ، قَالَ : لاَ تَنْشُرْ سِلْعَتَکَ إلاَّ عِنْدَ مَنْ یُرِیدُہَا۔",,,26144 26145,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ عُثْمَانَ بْنِ خُثَیْمٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: خَیْرُ أَکْحَالِکُمُ الإِثْمِدُ ، یَجْلُو الْبَصَرَ ، وَیُنْبِتُ الشَّعْرَ۔",,,26145 26146,"حَدَّثَنَا عَبْدُالرَّحِیمِ بْنُ سُلَیْمَانَ، عَنْ إسْمَاعِیلَ بْنِ مُسْلِمٍ، عَنْ مُحَمَّدِ بْنِ الْمُنْکَدِرِ، عَنْ جَابِرٍ، قَالَ: سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : عَلَیْکُمْ بِالإثْمدِ عِنْدَ النَّوْمِ فَإِنَّہُ یَشُدُّ الْبَصَرَ وَیُنْبِتُ الشَّعْرَ۔",,,26146 26147,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنْ حَفْصَۃَ ، عَنْ أَنَسٍ ، أَنَّہُ کَانَ یَکْتَحِلُ ثَلاَثًا فِی کُلِّ عَیْنٍ۔,,,26147 26148,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنِ ابْنِ سِیرِینَ ، أَنَّہُ کَانَ یَکْتَحِلُ اثْنَتَیْنِ فِی ذِہِ ، وَاثْنَتَیْنِ فِی ذِہِ ، وَوَاحِدَۃً بَیْنَہُمَا۔,,,26148 26149,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ عَبْدِ الْحَمِیدِ بْنِ جَعْفَرٍ ، عَنْ عِمْرَانَ بْنِ أَبِی أَنَسٍ ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَکْتَحِلُ بِالإثْمدِ ، یَکْتَحِلُ الْیُمْنَی ثَلاَثَۃَ مَرَاوِدَ وَالْیُسْرَی مِرْوَدَیْنِ۔",,,26149 26150,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ عَبَّادِ بْنِ مَنْصُورٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : کَانَ لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مُکْحُلَۃٌ یَکْتَحِلُ مِنْہَا ثَلاَثَۃً فِی کُلِّ عَیْنٍ۔",,,26150 26151,"حَدَّثَنَا حُسَیْنُ بْنُ عَبْدِ الرَّحْمَنِ الْحَارِثِیُّ ، عَنِ ابْنِ عَوْنٍ ، عَنِ النَّضْرِ بْنِ أَنَسٍ ، أَنَّہُ قَالَ فِی الْکُحْلِ : أَمَّا أَنَا فَإِنِّی أَکْتَحِلُ ثَلاَثًا ہَاہُنَا ، وَثَلاَثًا ہَاہُنَا ، وَوَاحِدَۃً بَیْنَہُمَا فَذَکرت ذلک لمحمد فَقَالَ : أَمَّا أَنا فَإِنِّی أَکتَحِلُ ثَلاَثًا ہَاہُنَا واثنتین ہَاہُنَا وَوَاحِدَۃً بَیْنَہُمَا۔",,,26151 26152,"حَدَّثَنَا وَکِیعٌ ، عَنْ مَالِکِ بْنِ مِغْوَلٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ أَبِی الْمُغِیرَۃِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : مَنِ اکْتَحَلَ فَلْیُوتِرْ۔ (ابوداؤد 36۔ احمد 2/351)",,,26152 26153,"حَدَّثَنَا عَائِذُ بْنُ حَبِیبٍ ، عَنْ سَدیرٍ ، قَالَ : کُنْتُ عِنْدَ أَبِی جَعْفَرٍ ، فَلَمَّا أَرَدْت أَنْ أَرْکَبَ أَخَذَ بِالرِّکَابِ وَقَالَ : مَا عَلَیْک أَنْ أُؤْجَرَ ، وَلَیْسَ بِہِ بَأْسٌ۔",,,26153 26154,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الأَجْلَحِ ، عَنْ عَامِرٍ ، قَالَ : دَعَا عُمَرُ زَیْدَ بْنَ صُوحَانَ ، فَضَفَنَہُ عَلَی الرَّحْلِ کَمَا تَضْفِنُونَ أَنْتُمْ أُمَرَائَکُمْ ، ثُمَّ الْتَفَتَ إلَی النَّاسِ فَقَالَ : افْعَلُوا بِزَیْدٍ وَأَصْحَابِہِ مِثْلَ ہَذَا۔",,,26154 26155,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ إبْرَاہِیمَ بْنِ مُہَاجِرٍ ، عَنْ مُجَاہِدٍ ، قَالَ : رُبَّمَا أَمْسَکَ لِی ابْنُ عَبَّاسٍ ، أَوِ ابْنُ عُمَرَ بِالرِّکَابِ۔",,,26155 26156,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی قَیْسٍ ، قَالَ : رَأَیْتُ إبْرَاہِیمَ غُلاَمًا أَعْوَرَ آخِذًا لِعَلْقَمَۃَ بِالرِّکَابِ ، أَحْسَبُہُ ، قَالَ : یَوْمَ الجُمُعَۃ۔",,,26156 26157,"حَدَّثَنَا عَفَّانُ، قَالَ: حدَّثَنَا مَہْدِیُّ بْنُ مَیْمُونٍ ، قَالَ: حَدَّثَنَا عَبْدُ اللہِ بْنُ صُبَیْحٍ الْحَنَفِیُّ ، وَذَہَبَ لِیَرْکَبَ فَأَخَذَ رَجُلٌ بِرِکَابِہِ فَقَالَ : بَلَغَنِی أَنَّ مُطَرِّفًا کَانَ یَقُولُ : مَا کُنْت لأَمْنَعَ أَخًا لِی یُرِیدُ کَرَامَتِی أَنْ یُکْرِمَنِی۔",,,26157 26158,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ زَیْدٍ ، قَالَ : حَدَّثَنَا غَالِبٌ الْقَطَّانُ ، قَالَ : أَرَدْت یَوْمًا أَنْ أَرْکَبَ حِمَارًا ، فَجَائَ شُعَیْبٌ یَمْسِکُ بِالرِّکَابِ ، فَسَأَلْت الْحَسَنَ فَقَالَ : اقْبَلْ کَرَامَۃَ أَخِیک۔",,,26158 26159,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عُبَیْدِ اللہِ بْنِ الأَخْنَسِ ، عَنِ الْوَلِیدِ بْنِ عَبْدِ اللہِ ، عَنْ یُوسُفَ بْنِ مَاہَکَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنِ اقْتَبَسَ عِلْمًا مِنَ النُّجُومِ اقْتَبَسَ شُعْبَۃً مِنَ السِّحْرِ ، زَادَ مَا زَادَ۔ (ابوداؤد 3900۔ ابن ماجہ 3726)",,,26159 26160,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ أَنْ یَتَعَلَّمَ مِنَ النُّجُومِ وَالْقَمَرِ مَا یَہْتَدِی بِہِ۔",,,26160 26161,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، قَالَ : حدَّثَنِی یَحْیَی بْنُ أَیُّوبَ ، قَالَ : حَدَّثَنَا عَبْدُ اللہِ بْنُ طَاوُوسٍ ، عَنْ أَبِیہِ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : یَنْظُرُونَ فِی النُّجُومِ وَفِی حُرُوفِ أَبِی جَادٍ ، قَالَ : أَرَی أُولَئِکَ قَوْمًا لاَ خَلاَقَ لَہُمْ۔",,,26161 26162,"حَدَّثَنَا غَسَّانُ بْنُ مُضَرَ ، عَنْ سَعِیدِ بْنِ یَزِیدَ ، عَنْ أَبِی نَضْرَۃَ ، قَالَ : قَالَ عُمَرُ : تَعَلَّمُوا مِنْ ہَذِہِ النُّجُومِ مَا تَہْتَدُونَ بِہِ فِی ظُلْمَۃِ الْبَرِّ وَالْبَحْرِ ، ثُمَّ أَمْسِکُوا۔",,,26162 26163,حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ عَبْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ یَضْرِبُ وَلَدَہُ عَلَی اللَّحْنِ۔,,,26163 26164,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ ثَوْرٍ ، عَنْ عُمَرَ بْنِ زَیْدٍ ، قَالَ : کَتَبَ عُمَرُ إلَی أَبِی مُوسَی : أَمَّا بَعْدُ فَتَفَقَّہُوا فِی السُّنَّۃِ وَتَفَقَّہُوا فِی الْعَرَبِیَّۃِ۔",,,26164 26165,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، قَالَ : قَالَ سُلَیْمَانُ بْنُ دَاوُد لاِبْنِہِ : مَنْ أَرَاْدَ أَنْ یَغِیظَ عَدُوَّہُ فَلاَ یَرْفَعَ الْعَصَا ، عَنْ وَلَدِہِ۔",,,26165 26166,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : کَانُوا یَقُولُونَ : أَکْرِمْ وَلَدَک وَأَحْسِنْ أَدَبَہُ۔",,,26166 26167,"حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنِ ابْنِ عَوْنٍ، قَالَ: سُئِلَ مُحَمَّدٌ عَنِ النَّحْوِ، قَالَ: لاَ أَعْلَمُ بِہِ بَأْسًا إِنْ لَمْ یَکُنْ فِیہِ بَغْیٌ۔",,,26167 26168,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ زِیَادِ بْنِ فَیَّاضٍ ، عَنْ عَمْرِو بْنِ مَیْمُونٍ ، أَنَّہُ کَرِہَ لاَ بِحَمْدِ اللہِ۔,,,26168 26169,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ یُکْرَہُ أَنْ یَقُولَ الرَّجُلُ لاَ بِحَمْدِ اللہِ وَلَکِنْ قُولُوا : نَعَمْ بِحَمْدِ اللَّہِ۔",,,26169 26170,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ یُقَالُ : یُکْرَہُ أَنْ یَقُولَ الرَّجُلُ لاَ بِحَمْدِ اللہِ وَلَکِنْ یَقُولُ : لاَ وَالْحَمْدُ لِلَّہِ۔",,,26170 26171,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ دِینَارٍ ، عَنْ ہِشَامٍ ، أَنَّ مُحَمَّدًا کَانَ إذَا قَلَّمَ أَظْفَارَہُ دَفَنَہَا۔",,,26171 26172,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : حدَّثَنَا ہِشَامُ بْنُ حَسَّانٍ ، قَالَ : أَخْبَرَنَا حَبِیبُ بْنُ شَہِیدٍ ، عَنْ مُعَاوِیَۃَ بْنِ قُرَّۃَ ، قَالَ : اسْتَأْذَنْت عَلَی مُسْلِمِ بْنِ یَسَارٍ فَجَلَست ثُمَّ أَذِنَ لِی ، فَدَخَلْت عَلَیْہِ فَقَالَ : لَقَدَ اسْتَأْذَنْت عَلَیَّ وَإِنِّی لأدْفِنُ بَعْضَ وَلَدِی ، قَالَ : وَکَانَ بَعْضُ نِسَائِہِ أَسْقَطَتْ فَدَفَنَہُ۔",,,26172 26173,حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ یَزِیدَ بْنِ عَبْدِ الْمَلِکِ ، عَنْ مُحَمَّدِ بْنِ عَلِیٍّ ، أَنَّہُ أَمَرَ حَجَّامًا یَحْجُمُہُ أَنْ یُفْرِغَ مَحْجَمَۃَ دَمٍ لِکَلْبٍ یَلَغُہَا۔,,,26173 26174,حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ الْجَبَّارِ بْنِ عَبَّاسٍ ، عَنْ رَجُلٍ مِنْ بَنِی ہَاشِمٍ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَمَرَ بِدَفْنِ الشَّعْرِ وَالظُّفْرِ وَالدَّمِ۔ (بخاری 2094۔ بزار 2968),,,26174 26175,حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، عَنْ إبْرَاہِیمَ بْنِ مُہَاجِرٍ ، عَنْ مُجَاہِدٍ ، أنَّہُ کَانَ إذَا قَلَّمَ أَظْفَارَہُ دَفَنَہَا ، أَوْ أَمَرَ بِہَا فَدُفِنَتْ۔,,,26175 26176,حدَّثَنَا أَبُو بَکْرٍ الْحَنَفِیُّ ، عَنْ أَفْلَحَ ، عَنِ الْقَاسِمِ ، أَنَّہُ کَانَ یَدْفِنُ شَعْرَہُ بِمِنًی۔,,,26176 26177,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مَہْدِیٍّ ، قَالَ : دَخَلْنَا عَلَی مُحَمَّدِ بْنِ سِیرِینَ یَوْمَ جُمُعَۃٍ بَعْدَ الْعَصْرِ ، فَدَعَا بِمِقْصٍ فَقَلَّمَ أَظْفَارَہُ فَجَمَعَہَا ، قَالَ مَہْدِیٌّ : فَأَنْبَأَنَا ہِشَامٌ ، أَنَّہُ کَانَ یَأْمُرُ بِہَا أَنْ تُدْفَنَ۔",,,26177 26178,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ أَشْعَثَ ، عَنْ أَبِی بُرْدَۃَ ، قَالَ : دَخَلْت مَسْجِدَ الْمَدِینَۃِ فَإِذَا عَبْدُ اللہِ بْنُ سَلاَمٍ ، فَسَلَّمْت ثُمَّ جَلَسْت ، فَقَالَ : یَا ابْنَ أَخِی ، إنَّک جَلَسْت وَنَحْنُ نُرِیدُ الْقِیَامَ۔",,,26178 26179,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَشْعَثَ ، قَالَ : حدَّثَنِی رَجُلٌ ، أَنَّ رَجُلاً جَلَسَ إلَی الْحَسَنِ فَقَالَ لَہُ : جَلَسْت إلَیْنَا عَلَی حِینِ قِیَامٍ مِنَّا ، أَفَتَأْذَنُ۔",,,26179 26180,"حَدَّثَنَا وَکِیعٌ ، عَنْ عِمْرَانَ، عَنْ أَبِی مِجْلَزٍ ، قَالَ: إذَا جَلَسَ إلَیْک رَجُلٌ مُتَعَمِّدًا فَلاَ تَقُمْ حَتَّی تَسْتَأْذِنَہُ۔",,,26180 26181,حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِیہِ ، عَنْ رَجُلٍ ، عَنْ إبْرَاہِیمَ مِثْلُہُ۔,,,26181 26182,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ أَبِی حَنِیفَۃَ ، عَنْ إبْرَاہِیمَ بْنِ مُحَمَّدِ بْنِ الْمُنْتَشِرِ ، عَنْ أَنَسِ بْنِ مَالِکٍ ، قَالَ: مَا جَلَسَ إلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَحَدٌ فَقَامَ حَتَّی یَقُومَ۔",,,26182 26183,"حَدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ، عَنْ مُحَمَّدٍ، قَالَ: کَانَ لاَ یَرَی بَأْسًا إذَا جَلَسَ الرَّجُلُ إلَی الرَّجُلِ أَنْ یَقُومَ، وَلاَ یَسْتَأْذِنَہُ۔",,,26183 26184,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُوسَی بْنِ نَافِعٍ ، قَالَ : قعَدْت إلَی سَعِیدِ بْنِ جُبَیْرٍ ، فَلَمَّا أَرَادَ أَنْ یَقُومَ ، قَالَ : أَتَأْذَنُونَ ؟ إنَّکُمْ جَلَسْتُمْ إلَیَّ۔",,,26184 26185,"حَدَّثَنَا أَبُو الأَحْوَص ، عَنْ مَنْصُورٍ ، عَنْ رِبْعِیٍّ ، قَالَ : حدَّثَنِی رَجُلٌ مِنْ بَنِی عَامِرٍ اسْتَأْذَنَ عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ فِی بَیْتٍ فَقَالَ : أَلِجُ ؟ فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لِخَادِمِہِ : اخْرُجْ إلَی ہَذَا فَعَلِّمْہُ الاسْتِئْذَانَ وَقُلْ لَہُ : قُلِ السَّلاَمُ عَلَیْکُمْ أَدْخُلُ ؟ فَسَمِعَہُ الرَّجُلُ فَقَالَ : السَّلاَمُ عَلَیْکُمْ أَدْخُلُ ؟ فَأَذِنَ لَہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَدَخَلَ۔ (بخاری 1084۔ ابوداؤد 5134)",,,26185 26186,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنَ سَمِعَ عَامِرَ بْنَ عَبْدِ اللہِ بْنِ الزُّبَیْرِ یَقُولُ : حدَّثَتْنِی رَیْحَانَۃُ ، أَنَّ أَہْلَہَا أَرْسَلُوہَا إلَی عُمَرَ ، فَدَخَلَتْ عَلَیْہِ بِغَیْرِ إذْنٍ ، فَعَلَّمَہَا فَقَالَ لَہَا : اخْرُجِی فَسَلِّمِی ، فَإِذَا رُدَّ عَلَیْک فَاسْتَأْذِنِی۔",,,26186 26187,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ وَاصِلِ بْنِ السَّائِبِ ، عَنْ أَبِی سَوْرَۃَ ، عَنْ أَبِی أیُّوبَ الأَنْصَارِیِّ ، قَالَ : قلْنا یَا رَسُولَ اللہِ ، ہَذَا السَّلاَمُ فَمَا الاسْتِئْنَاسُ ، قَالَ : یَتَکَلَّمُ الرَّجُلُ بِتَسْبِیحَۃٍ وَتَکْبِیرَۃٍ وَتَحْمِیدَۃٍ ، وَیَتَنَحْنَحُ ، وَیُؤْذِنُ أَہْلَ الْبَیْتِ۔ (ابن ماجہ 3707)",,,26187 26188,"حَدَّثَنَا یَحْیَی بْنُ مُحَمَّدٍ الْقُرَشِیُّ أَبُو زُکَیْرٍ سَمِعَ زَیْدَ بْنَ أَسْلَمَ یَقُولُ : بَعَثَنِی أَبِی إلَی ابْنِ عُمَرَ فَقُلْت : أَلِجُ ؟ فَقَالَ : لاَ تَقُلْ ہَکَذَا ، وَلَکِنْ قُلْ : السَّلاَمُ عَلَیْکُمْ ، فَإِذَا قِیلَ وَعَلَیْکُمْ ، فَادْخُلْ۔",,,26188 26189,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنِ الْمُغِیرَۃِ ، عَنِ الْحَارِثِ ، عَنْ عَبْدِ اللہِ بْنِ نُجَیٍّ ، عَنْ عَلِیٍّ ، قَالَ : کَانَ لِی مِنَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَدْخَلاَنِ : مَدْخَلٌ بِاللَّیْلِ ، وَمَدْخَلٌ بِالنَّہَارِ ، فَکُنْت إذَا أَتَیْتہ وَہُوَ یُصَلِّی یَتَنَحْنَحُ لِی۔",,,26189 26190,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، قَالَ : اسْتَأْذَنْت عَلَی عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی وَہُوَ یُصَلِّی بِالظَّلاَمِ فَفَتَحَ لِی۔",,,26190 26191,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنْ ہِلاَلِ بْنِ یَِسَافٍ ، عَنْ زُہْرَۃَ بْنِ حُمِیضَۃَ ، قَالَ : رَدَفْت أَبَا بَکْرٍ فَکُنَّا نَمُرُّ بِالْقَوْمِ فَنُسَلِّمُ عَلَیْہِمْ فَیَرُدُّونَ عَلَیْنَا أَکْثَرَ مِمَّا نُسَلِّمُ ، فَقَالَ أَبُو بَکْرٍ : مَا زَالَ النَّاسُ غَالِبِینَ لَنَا مُنْذُ الْیَوْمِ۔",,,26191 26192,"حَدَّثَنَا غُنْدَرٌ وَأَبُو أُسَامَۃَ ، عَنْ شُعْبَۃَ ، عَنْ عَبْدِ الْمَلِکِ بْنِ مَیْسَرَۃَ ، عَنْ زَیْدِ بْنِ وَہْبٍ ، عَنْ عُمَر ، قَالَ : کُنْتُ رِدْفَ أَبِی بَکْرٍ فَذَکَرَ ، مِثْلَہُ ، ثُمَّ قَالَ : لَقَدْ فَضَلَنَا النَّاسُ الْیَوْمَ بِخَیْرٍ کَثِیرٍ۔",,,26192 26193,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ أَبِی الْبَخْتَرِیِّ ، قَالَ : جَائَ رَجُلٌ إِلَی عَلِی فَقَالَ : السَّلاَمُ عَلَیْک یَا أَمِیرَ الْمُؤْمِنِینَ وَرَحْمَۃُ اللہِ وَبَرَکَاتُہُ ، فَقَالَ : وَعَلَیْکُمْ فَظَنَّ أَنَّہُ لَمْ یَسْمَعْ فَقَالَ: السَّلاَمُ عَلَیْک یَا أَمِیرَ الْمُؤْمِنِینَ وَرَحْمَۃُ اللہِ وَبَرَکَاتُہُ ، فَقَالَ : وَعَلَیْکُمْ ، فَقَالَ : أَلاَ تَرُدُّ عَلَیَّ لِمَا أَقُولُ لَکَ؟ قَالَ : أَلَیْسَ قَدْ فَعَلْت ؟۔",,,26193 26194,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، قَالَ : حدَّثَنِی سَعِیدُ بْنُ أَبِی سَعِیدٍ الْمَقْبُرِیُّ ، عَنْ أَبِی ہُرَیْرَۃَ، أَنَّ رَجُلاً دَخَلَ الْمَسْجِدَ وَرَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ جَالِسٌ فِی نَاحِیَۃِ الْمَسْجِدِ ، فَصَلَّی ، ثُمَّ جَائَ فَسَلَّمَ عَلَیْہِ فَقَالَ : وَعَلَیْک السَّلاَمُ۔ (بخاری 6251۔ ترمذی 2692)",,,26194 26195,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ عِمْرَانَ بْنِ أَبِی أَنَسٍ ، عَنْ مَالِکِ بْنِ أَوْسِ بْنِ الْحَدَثَانِ ، قَالَ : قدِمَ أَبُو ذَرٍّ مِنَ الشَّامِ فَدَخَلَ الْمَسْجِدَ وَفِیہِ عُثْمَانُ فَقَالَ : السَّلاَمُ عَلَیْکُمْ ، فَقَالَ : وَعَلَیْکُمُ السَّلاَمُ ، کَیْفَ أَنْتَ یَا أَبَا ذَرٍّ ؟ قَالَ : بِخَیْرٍ ، کَیْفَ أَنْتَ یَا عُثْمَانُ ؟۔ قَالَ : بِخَیر۔",,,26195 26196,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرٍ ، عَنْ مَیْمُونٍ ، أَنَّ رَجُلاً سَلَّمَ عَلَی سَلْمَانَ الْفَارِسِیِّ فَقَالَ : السَّلاَمُ عَلَیْکُمْ وَرَحْمَۃُ اللہِ وَبَرَکَاتُہُ ، فَقَالَ : سَلْمَانُ : حَسْبُک حَسْبُک ، ثُمَّ رَدَّ عَلَیہ الَّذِی قَالَ ، ثُمَّ زَادَ أُخْرَی ، فَقَالَ لَہُ الرَّجُلُ : أَتَعْرِفُنِی یَا أَبَا عَبْدِ اللہِ ؟ فَقَالَ : أَمَّا رُوحِی فَقَدْ عَرَفَ رُوحَک۔",,,26196 26197,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ یَرُدُّ السَّلاَمَ کَمَا یُقَالَ لَہُ : السَّلاَمُ عَلَیْکُمْ۔",,,26197 26198,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ الْجَلْدِ بْنِ أَیُّوبَ ، عَنْ مُعَاوِیَۃَ بْنِ قُرَّۃَ ، قَالَ : أَوْصَانِی أَبِی ، قَالَ: إذَا سُلِّمَ عَلَیْک، فَلاَ تَقُلْ : وَعَلَیْک ، قُلْ : وَعَلَیْکُمْ ، فَإِنَّ مَعَہُ مَلاَئِکَۃٌ۔",,,26198 26199,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَبِی حَیَّانَ ، عَنْ عَبْدِ الرَّحْمَنِ الرَّحَّالِ ، قَالَ : کَانَ الرَّبِیعُ بْنُ خُثَیْمٍ إذَا رَدَّ السَّلاَمَ یَقُولُ : وَعَلَیْکُمْ یَعْنِی یَنْوِی الرَّدَّ عَلَی مَا سُلِّمَ عَلَیْہِ۔",,,26199 26200,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، أَنَّ شُرَیْحًا إذَا رَدَّ قَالَ : وَعَلَیْکُمْ۔",,,26200 26201,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ زَید بن وَہب ، أَنَّہُ کَانَ إذَا سُلِّمَ عَلَیْہِ قَالَ : وَعَلَیْکُمُ السَّلاَمُ وَرَحْمۃ اللہ وَبَرَکَاتُہ وَمَغْفِرَتہ۔",,,26201 26202,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ، عَنِ الأَعْمَشِ، عَنْ إبْرَاہِیمَ، قَالَ: إذَا رَدَّ الرَّجُلُ فَلْیَقُلْ: وَعَلَیْکُمْ - یَعْنِی مَعَہُ الْمَلاَئِکَۃُ۔",,,26202 26203,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، وَابْنُ عَوْنٍ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ کَانَ إذَا رَدَّ ، قَالَ : وَعَلَیْکُمْ وَرَحْمَۃُ اللہِ۔",,,26203 26204,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَانَ مُحَمَّدٌ إذَا رَدَّ ، قَالَ : وَعَلَیْکُمْ۔",,,26204 26205,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ غَالِبٍ ، قَالَ : إنَّا لَجُلُوسٌ بِبَابِ الْحَسَنِ إذْ جَائَہُ رَجُلٌ ، فَقَالَ : حَدَّثَنِی أَبِی ، عَنْ جَدِّی ، قَالَ : بَعَثَنِی أَبِی إلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقَالَ : ائْتِہِ فَأَقْرِئْہُ السَّلاَمَ ، فَأَتَیْتہ فَقُلْت : إنَّ أَبِی یُقْرِئُک السَّلاَمَ ، فَقَالَ : وَعَلَیْک وَعَلَی أَبِیک السَّلاَمُ۔ (ابوداؤد 5189۔ احمد 5/366)",,,26205 26206,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ أَشْعَثَ ، عَنْ مُحَمَّدِ بْنِ أَبِی الْمُجَالِدِ ، عَنِ ابْنِ أَبِی أَوْفَی ، قَالَ : قُلْتُ لَہُ : إنَّ بَنِی أَخِیک یُقْرِئُونَک السَّلاَمَ ، ثُمَّ أَہْلَ الْمَسْجِدِ ، قَالَ : وَعَلَیْک وَعَلَیْہِمْ۔",,,26206 26207,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ شُعْبَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، قَالَ : قَالَ لی عَبْدُ اللہِ : إذَا لَقِیت عُمَرَ ، أَوْ کَلِمَۃٌ نَحْوُہَا ، فَأَقْرِئْہُ السَّلاَمَ ، قَالَ : فَلَقِیتہ فَأَقْرَأْتہ فَقَالَ : عَلَیْہِ ، أَوْ وَعَلَیْہِ السَّلاَمُ وَرَحْمَۃُ اللہِ۔",,,26207 26208,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ زَکَرِیَّا ، عَنِ الشَّعْبِیِّ ، عَنْ أَبِی سَلَمَۃَ ، أَنَّ عَائِشَۃَ حَدَّثَتْہُ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ لَہَا : إنَّ جِبْرِیلَ یَقْرَأُ عَلَیْک السَّلاَمَ ، فَقَالَتْ : وَعَلَیْہِ السَّلاَمُ وَرَحْمَۃُ اللہِ۔\n\n(بخاری 6253۔ ترمذی 2693)",,,26208 26209,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ وَأَبُو أُسَامَۃَ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَانَ مُحَمَّدٌ إذَا قِیلَ لَہُ إنَّ فُلاَنًا یُقْرِئُک السَّلاَمَ ، قَالَ : وَعَلَیْک وَعَلَیْہِ السَّلاَمُ۔",,,26209 26210,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنِ الجلدِ بْنِ أَیُّوبَ ، عَنْ مُعَاوِیَۃَ بْنِ قُرَّۃَ ، عَنْ أَبِیہِ ، قَالَ : أوْصَانِی أَبِی ، قَالَ : إذَا لَقِیت رَجُلاً فَلاَ تَقُلْ : السَّلاَمُ عَلَیْک ، قُلْ : السَّلاَمُ عَلَیْکُمْ۔",,,26210 26211,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنْ زِیَادِ بْنِ بَیَانٍ ، عَنْ مَیْمُونِ بْنِ مِہْرَانَ ، أَنَّ رَجُلاً سَلَّمَ عَلَی أَبِی بَکْرٍ فَقَالَ : السَّلاَمُ عَلَیْک یَا خَلِیفَۃَ رَسُولِ اللہِ ، فَقَالَ أَبُو بَکْرٍ : مِنْ بَیْنِ ہَؤُلاَئِ أَجْمَعِینَ۔",,,26211 26212,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِالرَّحْمَنِ الرُّؤَاسِیُّ، عَنْ حَسَنِ بْنِ صَالِحٍ، عَنْ إبْرَاہِیمَ بْنِ مُحَمَّدِ بْنِ الْمُنْتَشِرِ، عَنْ خَالِدِ بْنِ أبی الصَّلْتِ ، قَالَ : دَخَلَ ابْنُ سِیرِینَ عَلَی ابْنِ ہُبَیْرَۃَ فَقَالَ : السَّلاَمُ عَلَیْکُمْ ، فَقَالَ : ابْنُ ہُبَیْرَۃَ: مَا ہَذَا السَّلاَمُ؟ فَقَالَ: ہَکَذَا کَانَ یُسَلَّمُ عَلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔ (ترمذی 2689۔ ابوداؤد 5153)",,,26212 26213,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ عِمْرَانَ بْنِ أَبِی أَنَسٍ ، عَنْ مَالِکِ بْنِ أَوْسِ بْنِ الْحَدَثَانِ ، قَالَ : قدِمَ أَبُو ذَرٍّ مِنَ الشَّامِ فَدَخَلَ الْمَسْجِدَ وَفِیہِ عُثْمَانُ ، فَقَالَ : السَّلاَمُ عَلَیْکُمْ۔",,,26213 26214,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا حَسَن ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : جَائَ عمر إلَی بَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقَالَ : السَّلاَمُ عَلَی رَسُولِ اللہِ ، السَّلاَمُ عَلَیْکُمْ۔ (بخاری 1085۔ احمد 1/325)",,,26214 26215,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَنْ حَسَنٍ ، عَنْ مُجَالِدٍ ، قَالَ : کَانَ یُسَلَّمُ عَلَی عُمَرَ السَّلاَمُ عَلَیْک یَا أَمِیرَ الْمُؤْمِنِینَ ، السَّلاَمُ عَلَیْکُمْ یَعْنِی عَلَی مَنْ عِنْدَہُ۔",,,26215 26216,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَانَ مُحَمَّدٌ یَکْرَہُ أَنْ یَقُولَ السَّلاَمُ عَلَیْک حَتَّی یَقُولَ السَّلاَمُ عَلَیْکُمْ۔",,,26216 26217,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا سَلَّمَ الرَّجُلُ عَلَی الرَّجُلِ ، وَإِنْ کَانَ وَحْدَہُ فَلْیَقُلِ السَّلاَمُ عَلَیْکُمْ - یَعْنِی مَعَہُ الْمَلاَئِکَۃُ۔",,,26217 26218,"أَبُو أُسَامَۃَ، عَنْ عَبْدِ الْمُؤْمِنِ، قَالَ: سَلَّمْت عَلَی رَجُلٍ یَمْشِی مَعَ مُسْلِمِ بْنِ یَسَارٍ فَقُلْت: السَّلاَمُ عَلَیْک، فَقَالَ لِی مُسْلِمٌ : مَہْ ، فَقُلْت : إنِّی عَرَفْتہ ، فَقَالَ : وَإِنْ إذَا سَلَّمْت فَقُلْ : السَّلاَمُ عَلَیْکُمْ ، فَإِنَّ مَعَہُ حَفَظَۃٌ۔",,,26218 26219,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ أَبِی غِفَارٍ ، عَنْ أَبِی عُثْمَانَ ، قَالَ : جَائَ رَجُلٌ إلَی سَلْمَانَ ، فَقَالَ : إنَّ فُلاَنًا یُقْرِئُک السَّلاَمَ ، فَقَالَ : مُذْ کَمْ ؟ فَذَکَرَ أَیَّامًا فَقَالَ : أَمَا لَوْ لَمْ تَفْعَلْ لَکَانَتْ أَمَانَۃً تُؤَدِّیہَا۔",,,26219 26220,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنٍ ، عَنْ عَبْدِ الأَعْلَی ، عَنِ ابْنِ الْحَنَفِیَّۃِ ؛ فِی الرَّجُلِ یَقُولُ : أقْرِئْ فُلاَنًا السَّلاَمَ ، قَالُوا : ہِیَ أَمَانَۃٌ إلاَّ أَنْ یَنْسَی۔",,,26220 26221,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَاصِمٍ ، قَالَ : قُلْتُ لأَبِی مِجْلَزٍ : قَوْلُ الرَّجُلِ لِلرَّجُلِ : أَقْرِئْ فُلاَنًا السَّلاَمَ ، وَلاَ حَرَجَ ، قَالَ : ہِیَ أَمَانَۃٌ ، وَإذَا قَالَ : أُبَلِّغُ عَنْک ، کَانَ فِی سَعَۃٍ۔",,,26221 26222,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ أَبِی غِفَارٍ ، عَنْ أَبِی تَمِیمَۃَ الْہُجَیْمِیِّ ، عَنْ أَبِی جُرَیٍّ الْہُجَیْمِیِّ ، قَالَ : أَتَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقُلْت : عَلَیْک السَّلاَمُ یَا رَسُولَ اللہِ ، قَالَ : لاَ تَقُلْ : عَلَیْک السَّلاَمُ ، فَإِنَّ عَلَیْک السَّلاَمُ تَحِیَّۃُ الْمَوْتَی۔",,,26222 26223,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، أَنَّ رَجُلاً سَلَّمَ عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقَالَ : عَلَیْک السَّلاَمُ یَا نبی اللہِ ، فَکَرِہَ ذَلِکَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَقَالَ : تِیکَ تَحِیَّۃُ الْمَوْتَی۔",,,26223 26224,"حَدَّثَنَا عُبَیْدُ اللہِ ، عَنْ حَسَنٍ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، أَنَّہُ کَرِہَ أَنْ یَقُولَ : عَلَیْکُمُ السَّلاَمُ ، إنَّمَا قَالَ : {وَسَلاَمٌ عَلَی الْمُرْسَلِینَ}۔",,,26224 26225,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ نَافِعٍ ، قَالَ : کُنْتُ أَسِیرُ مَعَ عَبْدِ اللہِ بْنِ أَبِی زَکَرِیَّا فِی أَرْضِ الرُّومِ ، فَبَالَتْ دَابَّتِی ، فَقَامَتْ فَبَالَتْ ، فَلَحِقْتُہُ فَقَالَ : أَلاَ سَلَّمْتَ ؟ فَقُلْت : إنَّمَا فَارَقْتُک الآنَ ، قَالَ : وَإِنْ فَارَقْتَنِی ، کَانَ أَصْحَابُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَتَسَایَرُونَ فَتَفْرُقُ بَیْنَہُمُ الشَّجَرَۃُ فَیَلْتَقُونَ فَیُسَلِّمُ بَعْضُہُمْ عَلَی بَعْضٍ۔",,,26225 26226,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنْ مُجَاہِدٍ ، قَالَ : کَانَ الرَّجُلاَنِ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَتَسَایَرَانِ فَتَفْرُقُ بَیْنَہُمَا الشَّجَرَۃُ فَیَلْتَقِیَانِ فَیُسَلِّمُ أَحَدُہُمَا عَلَی الآخَرِ۔",,,26226 26227,حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ أَبِی الْبَخْتَرِیِّ ، وَسَعِیدِ بْنِ جُبَیْرٍ أَنَّہُمَا کَانَا یَشْکِیَانِ بُطُونَہُمَا فَیَجِیئَانِ فَیُسَلِّمَانِ۔,,,26227 26228,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ : کَانَ لاَ یُفَارِقُنِی إلاَّ عَلَی سَلاَمٍ ، أَجِیئُ ، ثُمَّ أَذْہَبُ فَیُسَلِّمُ عَلَیَّ ، ثُمَّ أَجِیئُ ، ثُمَّ أَذْہَبُ فَیُسَلِّمُ عَلَیَّ۔",,,26228 26229,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ الْعَوَّامِ ، عَنْ إبْرَاہِیمَ التَّیْمِیِّ ، قَالَ : إِنْ کَانَ الرَّجُلُ مِنْہُمْ لَیُفَارِقُ صَاحِبَہُ ، مَا یَحُولُ بَیْنَہُ إلاَّ شَجَرَۃٌ ، ثُم یَلقَاہُ فَیُسَلِّمُ عَلَیہ۔",,,26229 26230,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ سِمَاکٍ ، قَالَ : تَذَاکَرُوا الْمُصَافَحَۃَ فَقَالَ النُّعْمَانُ بْنُ حُمَیْدٍ : دَخَلْت عَلَی سَلْمَانَ مَعَ خَالِی عَبَّادِ بْنِ شُرَحْبِیلَ ، فَلَمَّا رَآہُ صَافَحَہُ سَلْمَانُ۔",,,26230 26231,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، وَابْنُ نُمَیْرٍ ، عَنِ الأَجْلَحِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْبَرَائِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَا مِنْ مُسْلِمَیْنِ یَلْتَقِیَانِ فَیَتَصَافَحَانِ إلاَّ غُفِرَ لَہُمَا قَبْلَ أَنْ یَتَفَرَّقَا۔\n\n(ابوداؤد 5170۔ ابن ماجہ 3703)",,,26231 26232,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ حَنْظَلَۃَ السَّدُوسِیِّ ، عَنْ أَنَسٍ ، قَالَ : قلْنَا : یَا رَسُولَ اللہِ ، أَیُصَافِحُ بَعْضُنَا بَعْضًا ؟ قَالَ : نَعَمْ۔ (ترمذی 2728۔ احمد 3/198)",,,26232 26233,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسٍ ، أَنَّ أَصْحَابَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : کَانَ یُصَافِحُ بَعْضُہُمْ بَعْضًا۔ (بخاری 6263۔ ترمذی 2729)",,,26233 26234,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ غَالِبٍ ، قَالَ: قُلْتُ لِلشَّعْبِیِّ : إنَّ ابْنَ سِیرِینَ کَانَ یَکْرَہُ الْمُصَافَحَۃَ ، قَالَ: فَقَالَ الشَّعْبِیُّ : کَانَ أَصْحَابُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَتَصَافَحُونَ ، وَإِذَا قَدِمَ أَحَدُہُمْ مِنْ سَفَرٍ عَانَقَ صَاحِبَہُ۔",,,26234 26235,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، قَالَ : سَأَلْتُ ابْنَ عَوْنٍ ، عَنِ الْمُصَافَحَۃِ ، قَالَ : کَانَ مُحَمَّدٌ لاَ یَفْعَلُہُ بِنَا ، وَلاَ نَفْعَلُہُ بِہِ ، وَکَانَ إذَا مَدَّ رَجُلٌ یَدَہُ ، لَمْ یَمْنَعْ یَدَہُ مِنْ أَحَدٍ۔",,,26235 26236,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنِ ابْنِ الأَسْوَدِ ، قَالَ : إنَّ مِنْ تَمَامِ التَّحِیَّۃِ الْمُصَافَحَۃَ۔",,,26236 26237,"حَدَّثَنَا شَرِیکٌ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الأَسْوَدِ ، قَالَ : إنَّ مِنْ تَمَامِ التَّحِیَّۃِ الْمُصَافَحَۃَ۔",,,26237 26238,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ یَحْیَی بن أَیُّوبَ ، عَنْ عُبَیْدِ اللہِ بْنِ زَحْرٍ ، عَنْ عَلِیِّ بْنِ یَزِیدَ ، عَنِ الْقَاسِمِ ، عَنْ أَبِی أُمَامَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : تَمَامُ تَحِیَّتِکُمُ الْمُصَافَحَۃُ۔ (ترمذی 2731)",,,26238 26239,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی عَبْدِ اللہِ الْعَسْقَلاَنِیِّ ، قَالَ : أَخْبَرَنِی مَنْ رَأَی ابْنَ مُحَیْرِیزٍ یُصَافِحُ نَصْرَانِیًّا فِی مَسْجِدِ دِمَشْقَ۔",,,26239 26240,حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، أَنَّہُ کَانَ یَکْرَہُ أَنْ یُصَافِحَ الْمُسْلِمُ الْیَہُودِیَّ ، وَالنَّصْرَانِیَّ۔,,,26240 26241,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : إنَّمَا الْمُشْرِکُونَ نَجَسٌ فَلاَ تُصَافِحُوہُمْ ، فَمَنْ صَافَحَہُمْ فَلْیَتَوَضَّأْ۔",,,26241 26242,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : سَأَلْتُہ عَنْ مُصَافَحَۃِ الْمَجُوسِیِّ فَکَرِہَ ذَلِکَ۔",,,26242 26243,حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الأَجْلَحِ ، عَنِ الشَّعْبِیِّ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ تَلَقَّی جَعْفَرَ بْنَ أَبِی طَالِبٍ فَالْتَزَمَہُ ، وَقَبَّلَ مَا بَیْنَ عَیْنَیْہِ۔ (ابوداؤد 5178۔ حاکم 624),,,26243 26244,حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حَجَّاجِ بْنِ دِینَارٍ ، عَنْ عُتْبَۃَ بن أَبِی عُثْمَانَ ، أَنَّ عُمَرَ اعْتَنَقَ حُذَیْفَۃَ۔,,,26244 26245,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی بَلْجٍ ، قَالَ : رَأَیْتُ عَمْرَو بْنَ مَیْمُونٍ وَالأَسْوَدَ بْنَ ہلال الْتَقَیَا وَاعْتَنَقَ کُلٌّ مِنْہُمَا صَاحِبَہُ۔",,,26245 26246,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ عَبَّادِ بْنِ عَبَّادٍ ، قَالَ : رَأَیْتُ أَبَا مِجْلَزٍ وَخَالِدًا الأَثْبَجَ الْتَقَیَا ، فَاعْتَنَقَ کُلٌّ مِنْہُمَا صَاحِبَہُ۔",,,26246 26247,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ إیَاسِ بْنِ دَغْفَلٍ ، قَالَ : رَأَیْتُ أَبَا نَضْرَۃَ قَبَّلَ خَدَّ الْحَسَنِ۔",,,26247 26248,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، قَالَ : أَخْبَرَنَا ثَابِتٌ ، عَنْ مُعَاذَۃَ الْعَدَوِیَّۃِ ، قَالَتْ : کَانَ أَصْحَابُ صِلَۃِ بْنِ أَشْیَمَ إذَا دَخَلُوا عَلَیْہِ یَلْتزِم بَعْضُہُمْ بَعْضًا۔",,,26248 26249,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، قَالَ : حدَّثَنَا جَرِیرُ بْنُ حَازِمٍ ، قَالَ : حَدَّثَنَا الْحَسَنُ ، عَنِ الْمُہَاجِرِ بْنِ قُنْفُذٍ ، أَنَّہُ سَلَّمَ عَلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ یَبُولُ فَلَمْ یَرُدَّ عَلَیْہِ حَتَّی فَرَغَ۔\n\n(ابوداؤد 18۔ ابن ماجہ 350)",,,26249 26250,"حَدَّثَنَا عُمَرُ بْنُ سَعْدٍ ، عَنْ سُفْیَانَ ، عَنِ الضَّحَّاکِ بْنِ عُثْمَانَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : مَرَّ رَجُلٌ عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ یَبُولُ ، فَسَلَّمَ عَلَیْہِ فَلَمْ یَرُدَّ عَلَیْہِ۔ (مسلم 115۔ ترمذی 90)",,,26250 26251,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ مُحَمَّدِ بْنِ زِیَادٍ الأَلْہَانِیِّ ، عَنْ أَبِی أُمَامَۃَ ، قَالَ : أَمَرَنَا نَبِیُّنَا صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ نُفْشِیَ السَّلاَمَ۔ (ابن ماجہ 3693۔ طبرانی 7524)",,,26251 26252,"حَدَّثَنَا أَبُو الأَحْوَص ، عَنْ أَبِی إِسْحَاقَ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لِلْمُسْلِمِ عَلَی الْمُسْلِمِ یُسَلِّمُ عَلَیْہِ إذَا لَقِیَہُ۔",,,26252 26253,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ أَبِیہِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَمْرٍو ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : اعْبُدُوا الرَّحْمَان ، وَأَفْشُوا السَّلاَمَ۔ (بخاری 981۔ ابن ماجہ 3694)",,,26253 26254,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَوْفٍ ، عَنْ زُرَارَۃَ بْنِ أَوْفَی ، قَالَ : حدَّثَنِی عَبْدُ اللہِ بْنُ سَلاَمٍ ، قَالَ : لَمَّا قَدِمَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْمَدِینَۃَ انْجَفَلَ النَّاسُ قِبَلَہُ ، وَقِیلَ : قَدِمَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَجِئْت فِی النَّاسِ لأَنْظُرَ ، فَلَمَّا تَبَیَّنْت وَجْہَہُ ، عَرَفْت أَنَّ وَجْہَہُ لَیْسَ بِوَجْہِ کَذَّابٍ ، فَکَانَ أَوَّلَ شَیْئٍ سَمِعْتہ یَتَکَلَّمُ بِہِ أَنْ قَالَ : یَا أَیُّہَا النَّاسُ ، أَفْشُوا السَّلاَمَ۔",,,26254 26255,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ أَشْعَثَ بْنِ أَبِی الشَّعْثَائِ الْمُحَارِبِیِّ ، عَنْ مُعَاوِیَۃَ بْنِ سُوَیْد ، عَنِ الْبَرَائِ بْنِ عَازِبٍ ، قَالَ : أَمَرَنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِإِفْشَائِ السَّلاَمِ۔",,,26255 26256,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، وَابْنُ نُمَیْرٍ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : وَالَّذِی نَفْسِی بِیَدِہِ ، لاَ تَدْخُلُوا الْجَنَّۃَ حَتَّی تُؤْمِنُوا ، وَلاَ تُؤْمِنُوا حَتَّی تَحَابُّوا ، أَلاَ أَدُلُّکُمْ عَلَی أَمْرٍ إذَا فَعَلْتُمُوہُ تَحَابَبْتُمْ ؟ أَفْشُوا السَّلاَمَ ۔ (مسلم 93۔ ترمذی 2688)",,,26256 26257,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ إِسْحَاقَ ، عَنِ النُّعْمَانِ بْنِ سَعْدٍ ، عَنْ عَلِیٍّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ فِی الْجَنَّۃِ غُرَفًا تُرَی ظُہُورُہَا مِنْ بُطُونِہَا ، وَبُطُونُہَا مِنْ ظُہُورِہَا ، فَقَامَ أَعْرَابِیٌّ فَقَالَ : لِمَنْ ہِیَ یَا رَسُولَ اللہِ ؟ قَالَ : ہِیَ لِمَنْ قَالَ طَیَّبَ الْکَلاَمَ ، وَأَطْعَمَ الطَّعَامَ ، وَأَفْشَی السَّلاَمَ ، وَصَلَّی بِاللَّیْلِ وَالنَّاسُ نِیَامٌ۔ (ترمذی 123۔ ابویعلی 434)",,,26257 26258,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : حدَّثَنَا شَیْبَانُ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ یَعیش بن الْوَلِیدِ ، عَنْ مَوْلًی لِلزُّبَیْرِ ، عَنِ الزُّبَیْرِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَلاَ أُنَبِّئُکُمْ بِأَمْرٍ إذَا فَعَلْتُمُوہُ تَحَابَبْتُمْ ؟ أَفْشُوا السَّلاَمَ بَیْنَکُمْ۔ (احمد 164۔ بیہقی 232)",,,26258 26259,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ زَیْدِ بْنِ وَہْبٍ ، عَنْ عَبْدِ اللہِ ، قَالَ : إنَّ السَّلاَمَ اسْمٌ مِنْ أَسْمَائِ اللہِ فَأَفْشُوہُ۔",,,26259 26260,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنِ الأَعْمَشِ ، عَنِ الْمِنْہَالِ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : إِنْ کُنْت لأَخْرُجُ إلَی السُّوقِ وَمَا لِی حَاجَۃٌ إلاَّ أَنْ أُسَلِّمَ وَیُسَلَّمَ عَلَیَّ۔",,,26260 26261,"حَدَّثَنَا حَفْصٌ، عَنْ عَاصِمٍ، عَنْ أَبِی عُثْمَانَ، عَنْ أَبِی ہُرَیْرَۃَ، قَالَ: إنَّ أَبْخَلَ النَّاسِ الَّذِی یَبْخَلُ بِالسَّلاَمِ۔",,,26261 26262,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَمَّارٍ الدُّہْنِیِّ ، عَنْ رَجُلٍ ، عَنْ کُرَیْبٍ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّہُ کَتَبَ إلَی رَجُلٍ مِنْ أَہْلِ الْکِتَابِ : السَّلاَمُ عَلَیْک۔",,,26262 26263,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا کَتَبْت إلَی الْیَہُودِیِّ وَالنَّصْرَانِیِّ فِی الْحَاجَۃِ فَابْدَأْہُ بِالسَّلاَمِ ، وَقَالَ مُجَاہِدٌ : اکْتُبِ السَّلاَمُ عَلَی مَنِ اتَّبَعَ الْہُدَی۔",,,26263 26264,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا الْمَسْعُودِیُّ ، عَنْ عَوْنِ بْنِ عَبْدِ اللہِ ، قَالَ : سَأَلَ مُحَمَّدُ بْنُ کَعْبٍ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ عَنِ ابْتِدَائِ أَہْلِ الذِّمَّۃِ بِالسَّلاَمِ فَقَالَ : تَرُدُّ عَلَیْہِمْ ، وَلاَ تَبْتَدِئہُمْ ، فَقُلْت : فَکَیْفَ تَقُولُ أَنْتَ ؟ فقَالَ : مَا أَرَی بَأْسًا أَنْ تَبْتَدِئہُمْ ، قُلْتُ : لِمَ ؟ قَالَ : لِقَوْلِ اللہِ {فَاصْفَحْ عَنْہُمْ وَقُلْ سَلاَمٌ فَسَوْفَ یَعْلَمُونَ}۔",,,26264 26265,حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ مُحَمَّدِ بْنِ زِیَادٍ الأَلْہَانِیِّ وَشُرَحْبِیلُ بْنُ مُسْلِمٍ ، عَنْ أَبِی أُمَامَۃَ ، أَنَّہُ کَانَ لاَ یَمُرُّ بِمُسْلِمٍ ، وَلاَ یَہُودِیٍّ ، وَلاَ نَصْرَانِیٍّ إلاَّ بَدَأَہُ بِالسَّلاَمِ۔,,,26265 26266,حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنِ ابْنِ عَجْلاَنَ ، أَنَّ عَبْدَ اللہِ وَأَبَا الدَّرْدَائِ وَفَضَالَۃَ بْنَ عُبَیْدٍ کَانُوا یَبْدَؤُونَ أَہْلَ الشِّرْکِ بِالسَّلاَمِ۔,,,26266 26267,"حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ أَبِی عِیسَی ، قَالَ : قَالَ عَبْدُ اللہِ : إنَّ مِنْ رَأْسِ التَّوَاضُعِ أَنْ تَبْدَأَ بِالسَّلاَمِ مَنْ لَقِیتَ۔",,,26267 26268,"حَدَّثَنَا عَفَان قَالَ : حدَّثَنَا عَبْدُ الوَاحِدِ بْنُ زِیَادٍ ، قَالَ : حَدَّثَنَا عَاصِمٌ ، عَنِ الشَّعْبِیِّ ، قَالَ : کَتَبَ أَبُو بُرْدَۃَ إلَی رَجُلٍ مِنْ أَہْلِ الذِّمَّۃِ یُسَلِّمُ عَلَیْہِ ، فَقِیلَ لَہُ : لِمَ قُلْتُ لَہُ ؟ فَقَالَ : إِنَّہُ بَدَأَنِی بِالسَّلاَمِ۔",,,26268 26269,"حَدَّثَنَا عَبْدُ اللہِ بْنُ بَکْرٍ السَّہْمِیُّ ، عَنْ حَاتِمِ بْنِ أَبِی صَغِیرَۃَ ، عَنْ عَطِیَّۃَ وَکَانَ کَاتِبًا لِعَبْدِ اللہِ بْنِ مُطَرِّفِ بْنِ الشِّخِّیرِ ، قَالَ : سَمِعْتُ عَبْدَ اللہِ بْنَ مُطَرِّفِ بْنِ الشِّخِّیرِ یَقُولُ : مَا عَلَی وجہ الأَرْضِ رَجُلٌ یَبْدَأُ آخَرَ بِالسَّلاَمِ إلاَّ کَانَ ذَلِکَ صَدَقَۃً عَلَیْہِ إلَی یَوْمِ الْقِیَامَۃِ۔",,,26269 26270,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ زَیْدِ بْنِ وَہْبٍ ، عَنْ عَبْدِ اللہِ ، قَالَ : إنَّ الرَّجُلَ إذَا مَرَّ بِالْقَوْمِ فَسَلَّمَ عَلَیْہِمْ فَرَدُّوا عَلَیْہِ کَانَ لَہُ فَضْلُ دَرَجَۃٍ عَلَیْہِمْ لأَنَّہُ أَذْکَرَہُمُ السَّلاَمَ۔",,,26270 26271,"حَدَّثَنَا وَکِیعٌ ، عَنِ الْمَسْعُودِیِّ ، عَنْ عَلِیِّ بْنِ الأَقْمَرِ ، عَنْ أَبِی عَاصِمٍ ، قَالَ : قَالَ عَبْدُ اللہِ : الْبَادِئُ بِالسَّلاَمِ یُرْبِی عَلَی صَاحِبِہِ فِی الأَجْرِ۔",,,26271 26272,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ عَوْنٍ ، عَنِ الشَّعْبِیِّ ، عَنْ شُرَیْحٍ ، قَالَ : مَا الْتَقَی رَجُلاَنِ قَطُّ إلاَّ کَانَ أَوْلاَہُمَا بِاللَّہِ الَّذِی یَبْدَأُ بِالسَّلاَمِ۔",,,26272 26273,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ مُسْلِمٍ ، عَنْ مَسْرُوقٍ ، عَنْ عَائِشَۃَ ، أَنَّہُ أَتَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَاسٌ مِنَ الْیَہُودِ فَقَالُوا : السَّامُ عَلَیْک یَا أَبَا الْقَاسِمِ ، فَقَالَ : وَعَلَیْکُمْ۔ (مسلم 11۔ احمد 229)",,,26273 26274,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ وَمُحَمَّدُ بْنُ بِشْرٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: إذَا سَلَّمَ عَلَیْکُمْ أَحَدٌ مِنْ أَہْلِ الْکِتَابِ فَقُولُوا: وَعَلَیْکُمْ۔ (مسلم 1705۔ ابوداؤد 5165)",,,26274 26275,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ یَزِیدَ بْنِ أَبِی حَبِیبٍ ، عَنْ مَرْثَدِ بْنِ عَبْدِ اللہِ الْیَزَنِیِّ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ الْجُہَنِیِّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنِّی رَاکِبٌ غَدًا إلَی یَہُود فَلاَ تَبْدَؤُوہُمْ بِالسَّلاَمِ ، فَإِذَا سَلَّمُوا عَلَیْکُمْ فَقُولُوا : وَعَلَیْکُمْ۔ (ابن ماجہ 3699۔ احمد 4/144)",,,26275 26276,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ دِینَارٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ الْیَہُودَ إذَا لَقُوکُمْ وَقَالُوا : السَّامُ عَلَیْکُمْ ، فَقُولُوا لَہُمْ : وَعَلَیْکُمْ۔",,,26276 26277,"حَدَّثَنَا أَبُو أُسَامَۃَ وَوَکِیعٌ ، عَنِ ابْنِ عَوْنٍ ، عَنْ حُمَیْدِ بْنِ زَادَوَیْہِ ، عَنْ أَنَسٍ ، قَالَ : نُہِینَا ، أَوْ أُمِرْنَا أَنْ لاَ نَزِیدَ أَہْلَ الْکِتَابِ عَلَی وَعَلَیْکُمْ۔ (احمد 3/113)",,,26277 26278,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ الْحَمِیدِ بْنِ جَعْفَرٍ ، عَنْ یَزِیدَ بْنِ أَبِی حَبِیبٍ ، عَنْ مَرْثَدِ بْنِ عَبْدِ اللہِ الْیَزَنِیِّ ، عَنْ أَبِی بَصْرَۃَ الْغِفَارِیِّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّا غَادُونَ إلَی یَہُودَ فَلاَ تَبْدَؤُوہُمْ بِالسَّلاَمِ ، فَإِنْ سَلَّمُوا فَقُولُوا : وَعَلَیْکُمْ۔ (مسندہ 668)",,,26278 26279,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنٍ ، عَنْ سِمَاکٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : مَنْ سَلَّمَ عَلَیْکُمْ مِنْ خَلْقِ اللہِ فَرُدُّوا عَلَیْہِمْ ، وَإِنْ کَانَ یَہُودِیًّا ، أَوْ نَصْرَانِیًّا ، أَوْ مَجُوسِیًّا۔",,,26279 26280,"حَدَّثَنَا ابْنُ فُضَیْلٍ، عَنْ مَعَنْ، عَنْ إبْرَاہِیمَ ، قَالَ: إذَا سَلَّمَ عَلَیْک الرَّجُلُ مِنْ أَہْلِ الْکِتَابِ فَقُلْ وَعَلَیْک۔",,,26280 26281,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ زُہَیْرٍ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : إذَا سَلَّمَ عَلَیْکُمْ یَہُودِیٌّ ، أَوْ نَصْرَانِیٌّ فَقُولُوا : وَعَلَیْکُمْ۔",,,26281 26282,"حَدَّثَنَا یَحْیَی بْنُ سُلَیْمٍ ، عَنْ زَمْعَۃَ ، عَنْ سَلَمَۃ بْنِ وَہْرَام ، عَنْ طَاوُوسٍ ، قَالَ : کَانَ إذَا سَلَّمَ عَلَیْہِ الْیَہُودِیُّ وَالنَّصْرَانِیُّ ، قَالَ : عَلاَک السَّلاَمُ۔",,,26282 26283,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَاصِمٍ ، عَنِ ابْنِ سِیرِینَ ، وَعَنْ أَبِی مَعْشَرٍ، عَنْ إبْرَاہِیمَ، وَعَنْ حَمَّادٍ، عَنْ إبْرَاہِیمَ ، قَالاَ : إذَا قُلْتَ حَیَّاک اللَّہُ ، فَقُلْ : بِالسَّلاَمِ۔",,,26283 26284,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ عَبْدِ الْمَجِیدِ ، قَالَ : کَانَ الحسن یَکْرَہُ أَنْ یَقُولَ الرَّجُلُ حَیَّاک اللَّہُ إلاَّ أَنْ یَقُولَ : بِالسَّلاَمِ۔",,,26284 26285,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنَْابْنُ عُیَیْنَۃَ ، عَنْ مُحَمَّدِ بْنِ سُوقَۃَ ، قَالَ : جَائَنَا مَیْمُونُ بْنُ مِہْرَانَ فَقَالَ لَہُ رَجُلٌ حَیَّاک اللَّہُ فَقَالَ : لاَ تَقُلْ ہَکَذَا ، ہَذِہِ تَحِیَّۃُ الشَّبابِّ ، وَلَکِنْ قُلْ : حَیَّاکُمَ اللَّہُ بِالسَّلاَمِ۔",,,26285 26286,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یَسْتَحِبُّونَ إذَا قَالَ الرَّجُلُ لِلرَّجُلِ حَیَّاک اللَّہُ أَنْ یَقُولَ : بِالسَّلاَمِ۔",,,26286 26287,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا مِسْعَرٌ ، قَالَ : حَدَّثَنِی عَلْقَمَۃُ بْنُ مَرْثَدٍ ، عَنْ عَطَائِ بْنِ أَبِی رَبَاحٍ ، أَنَّہُ کَرِہَ ، أَوْ قَالَ : کَانَ یُکْرَہُ السَّلاَمُ بِالْیَدِ وَلَمْ یَرَ بِالرَّأْسِ بَأْسًا۔",,,26287 26288,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ حُمَیْدٍ ، عَنْ أَنَسٍ ، قَالَ : أَتَانَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَنَحْنُ صِبْیَانٌ فَسَلَّمَ عَلَیْنَا۔ (بخاری 6247۔ ابوداؤد 5161)",,,26288 26289,"حَدَّثَنَا وَکِیعٌ ، عَنْ حُبَیبِّ بْنِ حُجْرٍ القیسی ، عَنْ ثَابِتٍ ، عَنْ أَنَسٍ ، قَالَ : مَرَّ عَلَیْنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَنَحْنُ صِبْیَانٌ فَقَالَ : السَّلاَمُ عَلَیْکُمْ یَا صِبْیَانُ۔ (احمد 3/183۔ دارقطنی 627)",,,26289 26290,حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنِ الْحَکَمِ ، عَنْ شُرَیْحٍ ، أَنَّہُ کَانَ یُسَلِّمُ عَلَی الصِّبْیَانِ۔,,,26290 26291,حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ، عَنْ حَجَّاجٍ، عَنِ الْحَکَمِ، أَنَّ شُرَیْحًا کَانَ یَمُرُّ عَلَی الصِّبْیَانِ فَیُسَلِّمُ عَلَیْہِمْ۔,,,26291 26292,"حَدَّثَنَا وَکِیعٌ وَحَفْصٌ ، عَنْ حَنَشِ بْنِ الْحَارِثِ ، قَالَ : کَانَ عَمْرُو بْنُ مَیْمُونٍ یَمُرُّ عَلَیْنَا وَنَحْنُ صِبْیَانٌ فَیُسَلِّمُ عَلَیْنَا۔",,,26292 26293,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ، عَنْ أُبَیّ بن عَبْداللہِ قَالَ: کَانَ إِبرَاہِیم یَمُرُّ عَلَیْنَا وَنَحْنُ صِبْیَانٌ فَیُسَلِّمُ عَلَیْنَا۔",,,26293 26294,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَانَ مُحَمَّدٌ یُسَلِّمُ عَلَی الصِّبْیَانِ ، وَلاَ یُسْمِعُہُمْ۔",,,26294 26295,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی حُسَیْنٍ سَمِعَہُ مِنْ شَہْرٍ یَقُولُ : أَخْبَرَتْہُ أَسْمَائُ بِنْتُ یَزِیدَ ، قَالَتْ : مَرَّ عَلَیْنَا النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی نِسْوَۃٍ فَسَلَّمَ عَلَیْنَا۔ (ترمذی 2697۔ ابوداؤد 5162)",,,26295 26296,حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ جَابِرٍ ، عَنْ طَارِقٍ التَّیْمِیِّ ، عَنْ جَرِیرٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَرَّ عَلَی نِسْوَۃٍ فَسَلَّمَ عَلَیْہِنَّ۔ (احمد 3/363۔ ابویعلی 7506),,,26296 26297,حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ مُجَاہِدٍ ، أَنَّ ابْنَ عُمَرَ مَرَّ عَلَی امْرَأَۃٍ فِی ظلۃ فَسَلَّمَ عَلَیْہَا۔,,,26297 26298,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ بِشرِ بن حَرب قَالَ : رَأَیت ابن عُمَر مَرَّ عَلَی امْرَأَۃٍ فَسَلَّمَ عَلَیْہَا۔",,,26298 26299,حَدَّثَنَا وَکِیعٌ ، عَنِ ابن ذَرٍّ ، عَنْ مُجَاہِدٍ ، أَنَّ عُمَرَ مَرَّ عَلَی نِسْوَۃٍ فَسَلَّمَ عَلَیْہِنَّ۔,,,26299 26300,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ زُرْزُر ، قَالَ : سَأَلْتُ عَطَائً عَنِ السَّلاَمِ عَلَی النِّسَائِ فَقَالَ : إِنْ کُنَّ شَوَابَّ فَلاَ۔",,,26300 26301,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : قُلْتُ لِمُحَمَّدٍ : أُسَلِّمُ عَلَی الْمَرْأَۃِ ؟ قَالَ : لاَ أَعْلَمُ بِہِ بَأْسًا۔",,,26301 26302,حَدَّثَنَا حَفْصٌ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ، أَنَّہُ کَانَ لاَ یَرَی أَنْ یُسَلِّمَ الرَّجُلُ عَلَی الْمَرْأَۃِ إلاَّ أَنْ یَدْخُلَ عَلَیْہَا فِی بَیْتِہَا فَیُسَلِّمَ عَلَیْہَا۔,,,26302 26303,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ قُرَیْرٍ ، قَالَ : جَائَ رَجُلٌ إلَی الْحَسَنِ فَقَالَ : أُسَلِّمُ عَلَی النِّسَائِ ؟ قَالَ : الْحَقْ بِأَہْلِک۔",,,26303 26304,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنِ الْحَسَنِ عن عُبَیْدِ اللہِ ، قَالَ : کَانَ عَمْرُو بْنُ مَیْمُونٍ یُسَلِّمُ عَلَی النِّسَائِ وَالصِّبْیَانِ۔",,,26304 26305,"حَدَّثَنَا أَبُو أُسَامَۃَ، عَنْ عَمْرِو بْنِ عُثْمَانَ، قَالَ: رَأَیْتُ مُوسَی بْنَ طَلْحَۃَ مَرَّ عَلَی نِسْوَۃٍ جُلُوسٍ فَسَلَّمَ عَلَیْہِنَّ۔",,,26305 26306,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ ، وَحَمَّادًا ، عَنِ السَّلاَمِ عَلَی النِّسَائِ فَکَرِہَہُ حماد عَلَی الشَّابَّۃِ وَالْعَجُوزِ ، وَقَالَ الْحَکَمُ : کَانَ شُرَیْحٌ یُسَلِّمُ عَلَی کُلِّ أَحَدٍ ، قُلْتُ : النِّسَائُ ؟ قَالَ : عَلَی کُلِّ أَحَدٍ۔",,,26306 26307,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَوْزَاعِیِّ ، عَنْ یَحْیَی ، عَنْ أَبِی قِلاَبَۃَ ، قَالَ : قَالَ أَبُو مَسْعُودٍ لأَبِی عَبْدِ اللہِ ، أَوْ قَالَ أَبُو عَبْدِ اللہِ لأَبِی مَسْعُودٍ : مَا سَمِعْت النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ فِی زَعَمُوا ؟ ، قَالَ : سَمِعْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : بِئْسَ مَطِیَّۃُ الرَّجُلِ : زَعَمُوا۔ (احمد 5/401۔ طحاوی 185)",,,26307 26308,حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ مَنْصُورٍ ، عَنْ عَبْدِ اللہِ ، أَنَّہُ کَرِہَ زَعَمُوا۔,,,26308 26309,حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ وَسُفْیَانُ ، عَنْ عَبْدِ رَبِّہِ ، عَنْ مُجَاہِدٍ ، أَنَّہُ کَرِہَ زَعَمُوا ، ثُمَّ قَرَأَ سُفْیَانُ {زَعَمَ الَّذِینَ کَفَرُوا}۔,,,26309 26310,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الأَعْمَشِ ، عَنْ شُرَیْحٍ ، قَالَ : زَعَمُوا زَامِلَۃُ الْکَذِبِ۔",,,26310 26311,"حَدَّثَنَا وَکِیعٌ ، عَنْ قَیس ، عن أَبِی یَحیَی ، عن مُجَاہِد ، عن ابن عَون قَال : زَعَمُوا زَامِلَۃُ الْکَذِبِ ، فَلاَ تَکُونَنَّ لِلْکَذِبِ زَامِلَۃ۔",,,26311 26312,"حَدَّثَنَا عُمَرُ بْنُ سَعْدٍ أَبُو دَاوُدَ ، عَنْ سُفْیَانَ ، عَنْ یَحْیَی بْنِ ہَانِئٍ ، قَالَ : قَالَ لِی أَبِی : یَا بُنَیَّ ، ہَبْ لِی من الْحَدِیثِ زَعَمُوا وَسَوْفَ۔",,,26312 26313,"حَدَّثَنَا ابْنُ أَبِی عُبَیْدَۃَ ، عَنْ أَبِیہِ ، عَنِ الأَعْمَشِ ، عَنْ یَحْیَی بْنِ وَثَّابٍ ، قَالَ : قَالَ لِی شُرَیْحٌ : إنَّ زَعَمُوا کُنْیَۃُ الْکَذِبِ۔",,,26313 26314,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ حَبِیبٍ ، قَالَ : سَأَلْتُ أَبَا قِلاَبَۃَ فَقَالَ : زَعَمُوا۔",,,26314 26315,"حَدَّثَنَا وَکِیعٌ ، عَنْ قُرَّۃَ ، قَالَ : سَمِعْتُ الْحَسَنَ یَقُولُ : زَعَمُوا وَاللَّہِ۔",,,26315 26316,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ شُعْبَۃَ ، عَنْ ثَابِتٍ ، قَالَ : قُلْتُ لابْنِ عُمَرَ : أَنُہِیَ ، عَنْ نَبِیذِ الْجَرِّ ، فَقَالَ : زَعَمُوا ذَلِکَ ، قَالَ : قُلْتُ : أَنْتَ سَمِعْتہ مِنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ فَقَالَ : زَعَمُوا ذَلِکَ۔",,,26316 26317,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ سُئِلَ عَنْ شَیْئٍ فَقَالَ : زَعَمُوا۔",,,26317 26318,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : سَأَلْتُ الْقَاسِمَ عَنِ الرَّجُلِ یُوتِرُ عَلَی رَاحِلَتِہِ ، قَالَ : زَعَمُوا أَنَّ ابْنَ عُمَرَ کَانَ یُوتِرُ بِالأَرْضِ۔",,,26318 26319,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عُثْمَانَ الثَّقَفِیِّ ، عَنْ سَالِمِ بْنِ أَبِی الْجَعْدِ ، عَنِ ابْنِ أبی عَمْرَۃ ، قَالَ : قیلَ یَا رَسُولَ اللہِ ، کَیْفَ أَصْبَحْت ؟ قَالَ : بِخَیْرٍ مِنْ قَوْمٍ لَمْ یَشْہَدُوا جِنَازَۃً وَلَمْ یَعُودُوا مَرِیضًا۔\n\n(طبرانی 7329)",,,26319 26320,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ عَبْدِ اللہِ بْنِ مُسْلِمٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ سَابِطٍ ، عَنْ جَابِرٍ ، قَالَ : قُلْتُ: کَیْفَ أَصْبَحْت یَا رَسُولَ اللہِ ؟ قَالَ : بِخَیْرٍ مِنْ رَجُلٍ لَمْ یُصْبِحْ صَائِمًا وَلَمْ یَعُدْ سَقِیمًا۔",,,26320 26321,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنِ الأَعْمَشِ ، عَنْ خَیْثَمَۃَ ، قَالَ : سَأَلْتُ عَائِشَۃَ : کَیْفَ أَصْبَحْت ؟ قَالَتْ : بِنِعْمَۃٍ مِنَ اللہِ۔",,,26321 26322,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : مَرَرْت بِعَامِرٍ الشَّعْبِیِّ وَہُوَ جَالِسٌ بِفِنَائِہِ فَقُلْت : کَیْفَ أَنْتَ؟ فَقَالَ : کَانَ شُرَیْحٌ إذَا قِیلَ لَہُ : کَیْفَ أَنْتَ ؟ قَالَ : بِنِعْمَۃٍ وَمَدَّ إصْبَعَہُ السَّبَّابَۃَ إلَی السَّمَائِ۔",,,26322 26323,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، قَالَ : أَخْبَرَنَا ابْنُ عَوْنٍ ، قَالَ : حدَّثَنِی بَکْرٌ ، قَالَ : قَالَ : قَالَ رَجُلٌ لأَبِی تَمِیمَۃَ الہُجَیمِی : کَیْفَ أَنْتُمْ ؟ قَالَ : بَیْنَ نِعْمَتَیْنِ : بَیْنَ ذَنْبٍ مَسْتُورٍ ، وَثَنَائٍ لاَ یَعْلَمُ بِہِ أَحَدٌ مِنْ ہَؤُلاَئِ النَّاسِ ، وَاللَّہِ مَا بَلَغْتُہُ ، وَلاَ أَنَا بِذَلِکَ۔",,,26323 26324,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، قَالَ : سَمِعْتُ إبْرَاہِیمَ وَسُلِّمَ عَلَیْہِ فَقَالَ : وَعَلَیْکُمْ ، فقیل لہ : کَیْفَ أَنْتَ ؟ قَالَ : بِنِعْمَۃٍ مِنَ اللہِ۔",,,26324 26325,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا إبْرَاہِیمُ بْنُ حُمَیْدٍ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنِ الشَّعْبِیِّ ، أَنَّ رَجُلاً ، قَالَ لَہُ : کَیْفَ أَصْبَحْت یَا أَبَا عَمْرٍو ؟ فَقَالَ : بِنِعْمَۃٍ ، قُلْتُ : مِمَّنْ ؟ قَالَ : مِنَ اللہِ۔",,,26325 26326,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، قَالَ : کَانَ عَلِیٌّ إذَا سُئِلَ وَہُوَ مَرِیضٌ ، کَیْفَ أَنْتَ ؟ قَالَ : بِشَرٍّ : وَقَرَأَ ہَذِہِ الآیَۃَ : {وَنَبْلُوکُمْ بِالشَّرِّ وَالْخَیْرِ فِتْنَۃً}۔",,,26326 26327,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، قَالَ : لَقِیَ رَجُلٌ عِکْرِمَۃَ بِالْمَدِینَۃِ فَقَالَ : کَیْفَ أَنْتَ ؟ قَالَ : أَنَا بِشَرٍّ یَدَایَ مُتَشَقِّقَتَانِ وَأَنَا کَذَا وَأَنَا وَکَذَا، قَالَ: وَکَانَ یَتَأَوَّلُ ہَذِہِ الآیَۃَ: {وَنَبْلُوکُمْ بِالشَّرِّ وَالْخَیْرِ فِتْنَۃً وَإِلَیْنَا تُرْجَعُونَ}۔",,,26327 26328,"حَدَّثَنَا الْحَسَنُ بْنُ مُوسَی ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، أَنَّ أَبَا عَبْدِ الرَّحْمَنِ السُّلَمِیّ کَانَ إذَا قِیلَ لَہُ : کَیْفَ أَنْتَ ؟ قَالَ : بِخَیْرٍ نَحْمَدُ اللَّہَ ، قَالَ عَطَائٌ : فَذَکَرْت ذَلِکَ لأَبِی الْبَخْتَرِیِّ فَقَالَ : أَنَّی أَخْذُہَا ؟ ثَلاَثًا۔",,,26328 26329,"حَدَّثَنَا إسْمَاعِیلُ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : لَقِیَ رَجُلٌ مُحَمَّدًا فَقَالَ : کَیْفَ أَنْتَ ؟ قَالَ : بِشَرٍّ ، أَجُوعُ فَلاَ أَسْتَطِیعُ أَنْ أَشْبَعَ ، وَأَعْطَشُ فَلاَ أَسْتَطِیعُ أَنْ أُرْوَی۔",,,26329 26330,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ زَائِدَۃَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یَکْرَہُونَ أَنْ تُوطَأَ أَعْقَابُہُمْ۔ (دارمی 524)",,,26330 26331,"حَدَّثَنَا سُوَیْد بْنُ عَمْرٍو الْکَلْبِیُّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ ثَابِتٍ ، عنْ شُعَیْبِ بْنِ عَبْدِ اللہِ بْنِ عَمْرٍو ، عَنْ أَبِیہِ ، قَالَ : مَا رُئِیَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَأْکُلُ مُتَّکِئًا قَطُّ ، وَلاَ یَطَأُ عَقِبَیہِ رَجُلاَنِ۔\n\n(ابوداؤد 3764۔ احمد 2/165)",,,26331 26332,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ التَّیْمِیِّ ، عَنِ الْحَارِثِ بْنِ سُوَیْد ، أَنَّ عَمَّارًا دَعَا عَلَی رَجُلٍ فَقَالَ : اللَّہُمَّ إِنْ کَانَ کَاذِبًا فَابْسُطْ لَہُ الدُّنْیَا وَاجْعَلْہُ مَوْطِأَ الْعَقِبَیْنِ۔",,,26332 26333,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مِسْعَرٍ ، قَالَ : حدَّثَنَا عُمَرُ بْنُ قَیْسٍ ، عَنْ عَمْرِو بْنِ أَبِی قُرَّۃَ الْکِنْدِیِّ ، قَالَ : انْطَلَقَ سَلْمَانُ، وَأَبِی حَتَّی أَتَیَا دَارَ سَلْمَانَ ، وَدَخَلَ سَلْمَانُ الدَّارَ فَقَالَ: السَّلاَمُ عَلَیْکُمْ ، ثُمَّ أَذِنَ لأَبِی قُرَّۃَ۔",,,26333 26334,"حَدَّثَنَا ابن فُضَیْلٌ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : إذَا دَخَلْت عَلَی أَہْلِکَ فَقُلْ : السَّلاَمُ عَلَیْکُمْ تَحِیَّۃً مِنْ عِنْدِ اللہِ مُبَارَکَۃً طَیِّبَۃً۔",,,26334 26335,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ حُصَیْنٍ ، عَنْ أَبِی مَالِکٍ الْغِفَارِیِّ ، قَالَ : إذَا دَخَلْت عَلَی أَہْلِکَ فَقُلْ : السَّلاَمُ عَلَیْکُمْ۔",,,26335 26336,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ أَبِی خَلْدَۃَ ، قَالَ : دَخَلْت مَعَ أَبِی الْعَالِیَۃِ بَیْتَہُ فَسَلَّمَ وَلَیْسَ فِیہِ أَحَدٌ ، وَقَالَ شَیْئًا لَمْ أَفْہَمْہُ۔",,,26336 26337,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبرنا ابْنُ عَوْنٍ ، عَنْ مُحَمَّدٍ فِی قَوْلِہِ تَعَالَی : {وَالَّذِینَ لَمْ یَبْلُغُوا الْحُلُمَ مِنْکُمْ} قَالَ : کَانَ أَہْلُونَا یُعَلِّمُونَا أَنْ نُسَلِّمَ ، وَکَانَ أَحَدُنَا إذَا جَائَ یَقُولُ : السَّلاَمُ عَلَیْکُمْ ، أَیَدْخُلُ فُلاَنٌ ؟۔",,,26337 26338,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللہِ الأَسَدِیُّ ، قَالَ : حدَّثَنَا مَعْقِلٌ ، عَنْ عَبْدِ الْکَرِیمِ ، قَالَ : کَانَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ إذَا دَخَلَ بَیْتًا ، قَالَ : بِسْمِ اللہِ وَالْحَمْدُ لِلَّہِ ، وَلاَ قُوَّۃَ إلاَّ بِاَللَّہِ وَالسَّلاَمُ عَلَی نَبِیِّ اللہِ ، اللَّہُمَّ افْتَحْ لِی أَبْوَابَ رَحْمَتِکَ {وَأَدْخِلْنِی مُدْخَلَ صِدْقٍ وَأَخْرِجْنِی مُخْرَجَ صِدْقٍ وَاجْعَلْ لِی مِنْ لَدُنْک سُلْطَانًا نَصِیرًا} وَہَبْ لِی مِنْ لَدُنْک رَحْمَۃً ، إنَّک أَنْتَ الْوَہَّابُ ، اللَّہُمَّ احْفَظْنِی مِنْ فَوْقِی أَنْ أُخْتَطَفَ ، وَمِنْ تَحْتِ رِجْلِی أَنْ یُخْسَفَ بِی ، وَعَنْ یَمِینِی ، وَعَنْ شِمَالِی مِنَ الشَّیْطَانِ الرَّجِیمِ۔",,,26338 26339,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنِ الأَعْمَشِ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ أَبِی عُبَیْدَۃَ ، قَالَ : کَانَ عَبْدُ اللہِ إذَا دَخَلَ دَارَہُ اسْتَأْنَسَ وَتَکَلَّمَ ، ثُمَّ رَفَعَ صَوْتَہُ۔",,,26339 26340,"حَدَّثَنَا ابْنُ المُبَارَکِ ، عَنْ مَعْمَرٍ ، عَنْ قَتَادَۃَ ، أَنَّ یَہُودِیًّا حَلَبَ لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَاقَۃً فَقَالَ : اللَّہُمَّ جَمِّلْہُ ، فَاسْوَدَّ شَعْرُہُ۔ (ابوداؤد 492)",,,26340 26341,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ أَن تَقُول للیَہُودِی ہَدَاکَ اللہ۔",,,26341 26342,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : جَائَ یَہُودِیٌّ إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقَالَ : ادْعُ اللَّہَ لِی ، فَقَالَ : کَثَّرَ اللَّہُ مَالَک وَوَلَدَک وَأَصَحَّ جِسْمَک وَأَطَالَ عُمْرَک۔",,,26342 26343,"حَدَّثَنَا الْفَضْلُ، عَنْ أَبِی سِنَانٍ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ، قَالَ: لَوْ قَالَ لِی فِرْعَوْنُ بَارَکَ اللَّہُ فِیک لَقُلْت وَفِیک۔",,,26343 26344,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ أَشْعَثَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : سَأَلْتُہ عَنِ الرَّجُلِ یَسْتَأْذِنُ عَلَیَّ ، وَلاَ یُسَلِّمُ آذَنُ لَہُ ؟ قَالَ : أَکْرَہُ أَنْ آذَنَ لَہُ وَالنَّاسُ یَفْعَلُونَہُ۔",,,26344 26345,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : لاَ تَأْذَنُوا حَتَّی تُؤْذَنُوا بِالسَّلاَمِ۔",,,26345 26346,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الأَحْوَص ، عَنْ عَبْدِ اللہِ ، قَالَ : إذَا دُعِیت ، فَہُوَ إذْنُک ، فَسَلِّمْ ، ثُمَّ ادْخُلْ۔",,,26346 26347,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ الْجُرَیْرِیِّ ، عَنِ ابْنِ بُرَیْدَۃَ ، قَالَ : اسْتَأْذَنَ رَجُلٌ عَلَی رَجُلٍ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ قَائِمٌ عَلَی الْبَابِ فَقَالَ : أَدْخُلُ ، ثَلاَثَ مَرَّاتٍ ، وَہُوَ یَنْظُرُ إلَیْہِ ، فَلَمْ یَأْذَنْ لَہُ ، ثُمَّ قَالَ : السَّلاَمُ عَلَیْکُمْ أَدْخُلُ ، فَقَالَ : ادْخُلْ ، ثُمَّ قَالَ : لَوْ أَقَمْت إلَی اللَّیْلِ تَقُولُ أَدْخُلُ ، مَا أَذِنْت لَکَ حَتَّی تَبْدَأَ بِالسَّلاَمِ۔",,,26347 26348,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ صَالِحٍ القُدادی ، قَالَ : بَعَثَنِی أَہْلِی إلَی سَعِیدِ بْنِ جُبَیْرٍ بِہَدِیَّۃٍ ، فَانْتَہَیْت إلَی الْبَابِ وَہُوَ یَتَوَضَّأُ فَقُلْتُ : أَدْخُلُ ؟ فَسَکَتَ ثَلاَثًا ، قَالَ : قُلْ : السَّلاَمُ عَلَیْکُمْ ، قَالَ : فَدَخَلْت فَقَالَ : لَمْ أَرَک تَہْتَدِی إلَی السُّنَّۃِ فَعَلَّمْتُک۔",,,26348 26349,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ مُحَمَّدِ بْنِ الْمُنْکَدِرِ ، عَنْ جَابِرٍ ، قَالَ : اسْتَأْذَنْت النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقَالَ : مَنْ ہَذَا ؟ فَقُلْت : أَنَا ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَنَا أَنَا۔ (بخاری 6250۔ مسلم 38)",,,26349 26350,"حَدَّثَنَا وَکِیعٌ ، عَنْ عِمْرَانَ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ : کَانَ ابْنُ عُمَرَ إذَا اسْتَأْذَنَ فَقِیلَ لَہُ : ادْخُلْ بِسَلاَمٍ ، رَجَعَ ، قَالَ : لاَ أَدْرِی أَدْخُلُ بِسَلاَمٍ ، أَوْ بِغَیْرِ سَلاَمٍ۔",,,26350 26351,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنْ أَبِی الجَراح ، عَنْ رَجُلٍ مِنْ أَہْلِ الْحِجَازِ ، قَالَ : قالَتِ امْرَأَتِی: ائْتِنِی بِأَبِی ہُرَیْرَۃَ حَتَّی أَسْتَفْتِیَہُ ، عَنْ بَعْضِ شأنی، فَأَتَیْتہ، فَجَائَ مَعِی، فَلَمَّا انْتَہَیْنَا إلَی الْبَابِ ، قَالَ: ادْخُلِ الدَّارَ، فَدَخَلْت فَقُلْت : ہَذَا أَبُو ہُرَیْرَۃَ قَدْ جَائَ فَقَالَ : السَّلاَمُ عَلَیْکُمْ أَدْخُلُ ، فَقُلْنَا : ادْخُلْ بِسَلاَمٍ ، فَعَادَ فَقَالَ : السَّلاَمُ عَلَیْکُمْ أَدْخُلُ ، فَقُلْنَا : ادْخُلْ بِسَلاَمٍ ، قَالَ : قُولُوا : ادْخُلْ ، فَقَالَ : السَّلاَمُ عَلَیْکُمْ أَدْخُلُ ؟ فَقُلْنَا لَہُ : ادْخُلْ ، فَدَخَلَ۔",,,26351 26352,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ عِکْرِمَۃَ ، قَالَ : إذَا دَخَلْت بَیْتًا لَیْسَ فِیہِ أَحَدٌ فَقُلْ : السَّلاَمُ عَلَیْنَا وَعَلَی عِبَادِ اللہِ الصَّالِحِینَ۔",,,26352 26353,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ ہِشَامِ بْنِ سَعْدٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ فِی الرَّجُلِ یَدْخُلُ فِی الْبَیْتِ ، أَوْ فِی الْمَسْجِدِ لَیْسَ فِیہِ أَحَدٌ ، قَالَ : یَقُولُ : السَّلاَمُ عَلَیْنَا وَعَلَی عِبَادِ اللہِ الصَّالِحِینَ۔",,,26353 26354,"حَدَّثَنَا أَبو الأَحوص ، عَن مَنْصُورٍ ، عَنْ إبْرَاہِیمَ قَالَ : قُل : السَّلاَمُ عَلَیْنَا وَعَلَی عِبَادِ اللہِ الصَّالِحِینَ۔",,,26354 26355,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی سِنَانٍ ، عَنْ مَاہَانَ فِی قَوْلِہِ تَعَالَی : {فَإِذَا دَخَلْتُمْ بُیُوتًا فَسَلِّمُوا عَلَی أَنْفُسِکُمْ تَحِیَّۃً مِنْ عِنْدِ اللہِ مُبَارَکَۃً طَیِّبَۃً} قَالَ : تَقُولُ : السَّلاَمُ عَلَیْنَا مِنْ رَبِّنَا۔",,,26355 26356,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ، عَنْ عَبْدِالْکَرِیمِ، عَنْ مُجَاہِدٍ، قَالَ: تَقُولُ: السَّلاَمُ عَلَیْنَا، وَعَلَی عِبَادِ اللہِ الصَّالِحِینَ۔",,,26356 26357,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ مُجَاہِدٍ ، قَالَ : إِذَا دَخَلْتَ بَیْتًا ، لَیْسَ فِیہِ أَحَدٌ ، فَقُلْ بِسْمِ اللہِ ، الْحَمْدُ لِلَّہِ ، السَّلاَمُ عَلَیْنَا ، وَعَلَی عِبَادِ اللہِ الصَّالِحِینَ۔",,,26357 26358,"حَدَّثَنَا ابْنُ فُضَیْلٍ، عَنْ عَبْدِالْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ: إذَا لَمْ یَکُنْ فِیہِ أَحَدٌ فَقُلْ: السَّلاَمُ عَلَیْنَا مِنْ رَبِّنَا۔",,,26358 26359,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ: حدَّثَنَا ابْنُ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ، أَنَّ رَجُلاً کَتَبَ لابْنِ عُمَرَ: بِسْمِ اللہِ لِفُلاَنٍ، فَقَالَ : ابْنُ عُمَرَ : مَہْ ، إنَّ اسْمَ اللہِ ہُوَ لَہُ وَحْدَہُ۔",,,26359 26360,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ یُکْرَہُ أَنْ یُکْتَبَ أَوَّلَ الرِّسَالَۃِ بِسْمِ اللہِ الرَّحْمَن الرَّحِیمِ لِفُلاَنٍ ، وَلاَ یَرَی بَأْسًا أَنْ یُکْتَبَ فِی أول والعُنْوان۔",,,26360 26361,"حَدَّثَنَا ابْنُ مَہْدِیٍّ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ، عَنْ حُمَیْدٍ، عَنْ بَکْرٍ، قَالَ: أکْتُبْ إلَی فُلاَنٍ، وَلاَ أکْتُبْ لِفُلاَنٍ۔",,,26361 26362,"حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ إسْرَائِیلَ ، عَنْ إسْمَاعِیلَ بْنِ سَلمان ، عَنْ دِینَارٍ ، عَنِ ابْنِ الْحَنَفِیَّۃِ ، قَالَ : لاَ بَأْسَ أَنْ یَکْتُبَ : بِسْمِ اللہِ لِفُلاَنٍ۔",,,26362 26363,حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ إسْرَائِیلَ ، عَنِ الشَّعْبِیِّ مِثْلُہُ۔,,,26363 26364,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ قَالَ : إذَا کَتَبَ کَتَبَ : السَّلاَمُ عَلَیْک فِیمَا أَحْمَدُ اللَّہَ الَّذِی لاَ إلَہَ إلاَّ ہُوَ وَہُوَ لِلْحَمْدِ أَہْلٌ تَبَارَکَ وَتَعَالَی : {لَہُ الْمُلْکُ وَلَہُ الْحَمْدُ وَہُوَ عَلَی کُلِّ شَیْئٍ قَدِیرٌ}۔",,,26364 26365,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ مُحَمَّدِ بْنِ سُوقَۃَ ، قَالَ : أَتَیْتُ نُعَیْمَ بْنَ أَبِی ہِنْدٍ فَأَخْرَجَ إلَیَّ صَحِیفَۃً فَإِذَا فِیہَا مِنْ أَبِی عُبَیْدَۃَ بْنِ الْجَرَّاحِ وَمُعَاذِ بْنِ جَبَلٍ إلَی عُمَرَ بْنِ الْخَطَّابِ سَلاَمٌ عَلَیْک أَمَّا بَعْدُ فَکَتَبَ إلَیْہِمَا مِنْ عُمَرَ بْنِ الْخَطَّابِ إلَی أَبِی عُبَیْدَۃَ بْنِ الْجَرَّاحِ وَمُعَاذِ بْنِ جَبَلٍ سَلاَمٌ عَلَیْکُمَا أَمَّا بَعْدُ۔",,,26365 26366,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ زَکَرِیَّا بْنِ أَبِی زَائِدَۃَ ، عَنِ الْعَبَّاسِ بْنِ ذَرِیحٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : کَتَبَتْ عَائِشَۃُ إلَی مُعَاوِیَۃَ : أَمَّا بَعْدُ۔",,,26366 26367,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ، قَالَ : حدَّثَنِی مَنْ قَرَأَ کِتَابَ عُثْمَانَ ، أَوْ مَنْ قُرِیء عَلَیْہِ: أَمَّا بَعْدُ۔",,,26367 26368,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، قَالَ : قرَأْت رَسَائِلَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کُلَّمَا انْقَضَتْ قِصَّۃٌ ، قَالَ : أَمَّا بَعْدُ۔ (بخاری 7۔ مسلم 1393)",,,26368 26369,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا زَکَرِیَّا ، قَالَ : سَمِعْتُ عَامِرًا یَقُولُ : قَالَ زِیَادٌ : إنَّ فَصْلَ الْخِطَابِ الَّذِی أُعْطِیَ دَاوُد أَمَّا بَعْدُ۔",,,26369 26370,"حَدَّثَنَا عُمَرُ بْنُ سَعْدٍ، عَنْ سُفْیَانَ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، أَنَّہُ کَتَبَ فِی رِسَالَۃٍ: أَمَّا بَعْدُ ، ثُمَّ قَالَ : کَانَ فِی رَسَائِلِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَمَّا بَعْدُ۔",,,26370 26371,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، قَالَ : أَرْسَلَنِی أَبِی إلَی ابْنِ عُمَرَ فَرَأَیْتہ یَکْتُبُ بِسْمِ اللہِ الرَّحْمَن الرَّحِیمِ أَمَّا بَعْدُ۔",,,26371 26372,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، قَالَ : قرَأْت فِی رَسَائِلَ مِنْ رَسَائِلِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کُلَّمَا انْقَضَی أَمْرٌ ، قَالَ : أَمَّا بَعْدُ۔ (بخاری 1121)",,,26372 26373,"حَدَّثَنَا عُمَرُ بْنُ سَعْدٍ أَبُو دَاوُدَ ، عَنْ سُفْیَانَ ، عَنِ الأَسْوَدِ بْنِ قَیْسٍ ، عَنْ ثَعْلَبَۃَ بْنِ عِبَادٍ ، عَنْ سَمُرَۃََ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ خَطَبَ فَقَالَ : أَمَّا بَعْدُ۔ (ابن حبان 2856۔ ابن خزیمۃ 1397)",,,26373 26374,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، وَابْنُ نُمَیْرٍ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، أَنَّ أَبَا حُمَیْدٍ السَّاعِدِیَّ حَدَّثَہُ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ خَطَبَ فَقَالَ : أَمَّا بَعْدُ۔ (بخاری 925۔ مسلم 1464)",,,26374 26375,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حدَّثَنَا ہِشَامُ بْنُ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ تَکَلَّمَ فَقَالَ : أَمَّا بَعْدُ۔ (بخاری 4141۔ مسلم 2137)",,,26375 26376,"حَدَّثَنَا مَیْمُونٌ الزَّعْفَرَانِیُّ ، عَنْ جَعْفَرِ بْنِ مُحَمَّدٍ ، عَنْ أَبِیہِ ، عَنْ جَابِرٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ خَطَبَ فَقَالَ : أَمَّا بَعْدُ۔ (مسلم 592۔ احمد 3/310)",,,26376 26377,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ عَبْدِ الْمَلِکِ بْنِ عُمَیْرٍ ، عَنْ رِبْعِیِّ بْنِ حِرَاشٍ ، عَنِ الطُّفَیْلِ بْنِ سَخْبَرَۃَ أَخٍ لعَائِشَۃَ مِنَ الرَّضَاعَۃِ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : أَمَّا بَعْدُ۔\n\n(ابن ماجہ 2118۔ حاکم 3)",,,26377 26378,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ أَبِی حَیَّانَ ، عَنْ یَزِیدَ بْنِ حَیَّانَ ، عَنْ زَیْد بْنِ أَرْقَمَ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ خَطَبَہُمْ فَقَالَ : أَمَّا بَعْدُ۔ (مسلم 1874۔ ابوداؤد 4934)",,,26378 26379,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنِ ابْنِ أَبِی لَیْلَی ، قَالَ : کَتَبَ أَبُو الدَّرْدَائِ إلَی مَسْلَمَۃَ بْنِ مَخْلَدٍ وَہُوَ أَمِیرٌ بِمِصْرَ : أَمَّا بَعْدُ۔",,,26379 26380,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عَبْدِ اللہِ بْنِ ہُبَیْرَۃَ ، قَالَ : کَتَبَ أَبُو الدَّرْدَائِ إلَی سَلْمَانَ : أَمَّا بَعْدُ ۔ وَکَتَبَ سَلْمَانُ إلَی أَبِی الدَّرْدَائِ أَمَّا بَعْدُ۔",,,26380 26381,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنْ سَعِیدِ بْنِ أَبِی بُرْدَۃَ ، قَالَ : کَتَبَ عُمَرُ إلَی أَبِی مُوسَی : أَمَّا بَعْدُ۔",,,26381 26382,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ إِسْحَاقَ ، عَنْ عُبَیْدِ اللہِ الْقُرَشِیِّ ، عَنْ عَبْدِ اللہِ بْنِ عُکَیْمٍ ، قَالَ : خَطَبَنَا أَبُو بَکْرٍ فَقَالَ : أَمَّا بَعْدُ۔",,,26382 26383,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ عُمَرَ بْنِ عَبْدِ الرَّحْمَنِ بْنِ دِلاَفٍ ، عَنْ أَبِیہِ ، عَنْ عَمِّ أَبِیہِ بِلاَلِ بْنِ الْحَارِثِ ، قَالَ : خَطَبَ عُمَرُ بْنُ الْخَطَّابِ فَقَالَ : أَمَّا بَعْدُ۔",,,26383 26384,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : کَتَبَ أَبُو مُوسَی إلَی عَامِرِ بْنِ عَبْدِ اللہِ الَّذِی کَانَ یُدْعَی ابْنَ عَبْدِ الْقَیْسِ : أَمَّا بَعْدُ۔",,,26384 26385,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ، عَنِ الأَعْمَشِ، عَنْ إِبْرَاہِیمَ، عَن عَلْقَمَۃَ، قَالَ: أَقْبَلْت مَعَ عَبْدِاللہِ مِنَ السَّیْلَحین فَصَحِبَہُ دَہَّاقِینَ مِنْ أَہْلِ الْحِیرَۃِ ، فَلَمَّا دَخَلُوا الْکُوفَۃَ أَخَذُوا فِی طَرِیقٍ غَیْرِ طَرِیقِہِمْ ، فَالْتَفَتَ إلَیْہِمْ فَرَآہُمْ قَدْ عَدَلُوا ، فَأَتْبَعَہُمُ السَّلاَمَ ، فَقُلْت : أَتُسَلِّمُ عَلَی ہَؤُلاَئِ الْکُفَّارِ ، فَقَالَ : نَعَمْ إِنَّہُم صَحِبُونِی وَلِلصُّحْبَۃِ حَقٌّ۔",,,26385 26386,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ عَاصِمٍ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، قَالَ : مَا زَادَہُمْ عَبْدُ اللہِ عَنِ الإِشَارَۃِ۔",,,26386 26387,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ شُعَیْبِ بْنِ الْحَبْحَابِ ، قَالَ : کُنْتُ مَعَ عَلِیِّ بْنِ عَبْدِ اللہِ الْبَارِقِیِّ ، فَمَرَّ عَلَیْنَا یَہُودِیٌّ ، أَوْ نَصْرَانِیٌّ عَلَیْہِ کَارَۃٌ مِنْ طَعَامٍ ، فَسَلَّمَ عَلَیْہِ عَلِیٌّ ، فَقَالَ شُعَیْبٌ : فَقُلْت : إِنَّہُ یَہُودِیٌّ، أَوْ نَصْرَانِیٌّ ، فَقَرَأَ عَلِیٌّ آخِرَ سُورَۃِ الزُّخْرُفِ {وَقِیلِہِ یَا رَبِّ إنَّ ہَؤُلاَئِ قَوْمٌ لاَ یُؤْمِنُونَ فَاصْفَحْ عَنْہُمْ وَقُلْ سَلاَمٌ فَسَوْفَ یَعْلَمُونَ}۔",,,26387 26388,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، قَالَ : حدَّثَنَا مَعْمَر ، قَالَ : بَلَغَنِی ، أَنَّ أَبَا ہُرَیْرَۃَ مَرَّ عَلَی یَہُودِیٍّ فَسَلَّمَ ، فَقِیلَ لَہُ : إِنَّہُ یَہُودِیٌّ ، فَقَالَ : یَا یَہُودِیُّ ، رُدَّ عَلَیَّ سَلاَمِی ، وَأَدْعُو لَکَ ، قَالَ : قَدْ رَدَدْتہ ، قَالَ : اللَّہُمَّ کَثِّرْ مَالَہُ وَوَلَدَہُ۔",,,26388 26389,"حَدَّثَنَا أَبُو الأَحْوَص ، عَنْ عَاصِمٍ ، عَنْ مُحَمَّدٍ ، قَالَ : یُسَلِّمُ الرَّاکِبُ عَلَی الْمَاشِی ، وَالْمَاشِی عَلَی الْقَاعِدِ ، فَإِذَا الْتَقَیَا بَدَأَ خیرہما۔",,,26389 26390,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، قَالَ : کُنْتُ أَنَا وَالشَّعْبِیُّ فَلَقِینَا رَجُلاً رَاکِبًا ، فَبَدَأَہُ الشَّعْبِیُّ بِالسَّلاَمِ فَقُلْت : أَتَبْدَؤُہُ وَنَحْنُ رَاجِلاَنِ وَہُوَ رَاکِبٌ ؟ فَقَالَ : لَقَدْ رَأَیْت شُرَیْحًا یُسَلِّمُ عَلَی الرَّاکِبِ۔",,,26390 26391,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ وَسُلَیْمَانَ بْنِ مُوسَی ، قَالاَ : یُسَلِّمُ الصَّغِیرُ علی الْکَبِیرِ ، وَالْقَائِمُ عَلَی الْقَاعِدِ ، وَیُسَلِّمُ الرَّاکِبُ عَلَی الْمَاشِی ، وَالْقَلِیلُونَ عَلَی الْکَثِیرِینَ۔",,,26391 26392,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ أَبِی حَیَّانَ التَّیْمِیِّ ، عَنْ أَبِی الزِّنْبَاعِ ، عَنْ أَبِی الدِّہْقَانَۃِ ، قَالَ : قیلَ لِعُمَرَ بْنِ الْخَطَّابِ : إنَّ ہَاہُنَا غُلاَمًا مِنْ أَہْلِ الْحِیرَۃِ ، لَمْ یُرَ قَطُّ أَحْفَظُ مِنْہُ ، وَلاَ أَکْتُبُ مِنْہُ ، فَإِنْ رَأَیْت أَنْ تَتَّخِذَہُ کَاتِبًا بَیْنَ یَدَیْک، إذَا کَانَتْ لَکَ الْحَاجَۃُ شَہِدَک، قَالَ: فَقَالَ عُمَرُ: قَدِ اتَّخَذْت إذًا بِطَانَۃً مِنْ دُونِ الْمُؤْمِنِینَ۔",,,26392 26393,"حَدَّثَنَا وَکِیعٌ ، عَنِ الْمَسْعُودِیِّ ، عَنِ الْقَاسِمِ ، قَالَ : کَانَ لِعَبْدِ اللہِ کَاتِبٌ نَصْرَانِیٌّ۔",,,26393 26394,حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ سِمَاکٍ ، عَنْ عِیَاضٍ الأَشْعَرِیِّ ، أَنَّ أَبَا مُوسَی کَانَ لَہُ کَاتِبٌ نَصْرَانِیٌّ۔,,,26394 26395,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ شَقِیقٍ ، قَالَ : جَائَنَا کِتَابُ أَبِی بَکْرٍ وَنَحْنُ بِالْقَادِسِیَّۃِ ، وَکَتَبَ عَبْدُ اللہِ بْنُ الأَرْقَمِ۔",,,26395 26396,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ بْنِ مُحَمَّدٍ ، أنَّ عُبَیْدَ اللہِ بْنِ أَبِی رَافِعٍ کَاتِبِ عَلِیٍّ أَخْبَرَہُ۔,,,26396 26397,"حَدَّثَنَا جَعْفَرُ بْنُ عَوْنٍ، عَنْ إبْرَاہِیمَ بْنِ إسْمَاعِیلَ، عَنِ الزُّہْرِیِّ، عَنْ عُبَیْدِ بْنِ السَّبَّاقِ، عَنْ زَیْدِ بْنِ ثَابِتٍ، أَنَّ أَبَا بَکْرٍ، قَالَ لَہُ: قدْ کُنْتَ تَکْتُبُ الْوَحْیَ لِرَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَاجْمَعِ الْقُرْآنَ فَاکْتُبْہُ۔\n\n(بخاری 4679۔ ترمذی 3103)",,,26397 26398,حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، عَنْ کَاتِبٍ لِعَلِی۔,,,26398 26399,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ، عَنِ الأَعْمَشِ، عَنِ الْمُسَیَّبِ بْنِ رَافِعٍ، قَالَ: حدَّثَنِی وَرَّادٌ کَاتِبُ الْمُغِیرَۃِ بْنِ شُعْبَۃَ۔",,,26399 26400,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ بَجَالَۃَ ، قَالَ : کُنت کَاتِبًا لِجَِزِی بْنِ مُعَاوِیَۃَ۔",,,26400 26401,حَدَّثَنَا عَبْدُ اللہِ بْنُ بَکْرٍ السَّہْمِیُّ ، عَنْ حَاتِمِ بْنِ أَبِی صَغِیرَۃَ ، عَنْ عَطِیَّۃَ ، کَاتِبٍ لِعَبْدِ اللہِ بْنِ مُطَرِّفٍ۔,,,26401 26402,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا شُعْبَۃُ ، عَنْ مَنصُور ، عَنِ ابْنِ سِیرِینَ ، أَنَّ الْعَلاَئَ بْنَ الْحَضْرَمِیِّ کَتَبَ إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَبَدَأَ بِنَفْسِہِ۔ (ابوداؤد 5092۔ حاکم 636)",,,26402 26403,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : کَتَبَ أَبُو مُوسَی : مِنْ عَبْدِ اللہِ بْنِ قَیْسٍ إلَی عَامِرِ بْنِ عَبْدِ اللہِ۔",,,26403 26404,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنْ مَیْمُونِ بْنِ مِہْرَانَ ، أَنَّ ابْنَ عُمَرَ کَتَبَ إلَی عُمَرَ بْنِ الْخَطَّابِ فَکَتَبَ : مِنْ عَبْدِ اللہِ بْنِ عُمَرَ إلَی عُمَرَ ، قَالَ جَعْفَرٌ : قَالَ مَیْمُونٌ : إنَّمَا ہُوَ شَیْئٌ یُعَظِّمُ بِہِ الأَعَاجِمُ بَعْضُہَا بَعْضًا۔",,,26404 26405,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ کَہْمَسٍ ، قَالَ : قَالَ لِی عَبْدُ اللہِ بْنُ مُسْلِمِ بْنِ یَسَارٍ : أَوَ حَرَجٌ عَلَیَّ أَلاَ أَبْدَأَ بِہِ فِی الْکِتَابِ ، فَإِنَّہُ لاَ یُبْدَأُ إلاَّ بِأَمِینٍ وَیَبْدَأُ الرَّجُلُ بِأَبِیہِ۔",,,26405 26406,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، قَالَ : کَتَبْت إلَی شُعْبَۃَ بِبَغْدَادَ فَبَدَأْت بِاسْمِہِ ، فَکَتَبَ إلَیَّ یَنْہَانِی وَیَذْکُرُ أَنَّ الْحَکَمَ کَانَ یَکْرَہُہُ۔",,,26406 26407,حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، عَنْ شَیْخٍ ، أَنَّ زَیْدَ بْنَ ثَابِتٍ کَتَبَ إلَی مُعَاوِیَۃَ فَبَدَأَ بِمُعَاوِیَۃَ۔,,,26407 26408,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، قَالَ : کَانَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ یُکْتَبُ إلَیْہِ فَیُبْدَأَ بِہِ ، فَلَمْ یَرَ بِہِ بَأْسًا۔",,,26408 26409,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : کَانَتْ لابْنِ عُمَرَ حَاجَۃٌ إلَی مُعَاوِیَۃَ ، فَأَرَادَ أَنْ یَکْتُبَ إلَیْہِ فَقَالُوا : لَوْ بَدَأْت بِہِ ، فَلَمْ یَزَالُوا بِہِ حَتَّی کَتَبَ : بِسْمِ اللہِ الرَّحْمَن الرَّحِیمِ إلَی مُعَاوِیَۃَ۔",,,26409 26410,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، قَالَ : کَتَبَ رَجُلٌ کِتَابًا مِنَ الْحَسَنِ إلَی صَالِحِ بْنِ عَبْدِ الرَّحْمَنِ فَکَتَبَ : بِسْمِ اللہِ الرَّحْمَن الرَّحِیمِ مِنَ الْحَسَنِ إلَی صَالِحٍ ، فَقَالَ : الرَّجُلُ : یَا أَبَا سَعِیدٍ ، لَوْ بَدَأْت بِہِ ، فَبَدَأَ بِہِ۔",,,26410 26411,حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ إسْمَاعِیلَ الْمَکِّیِّ ، عَنِ الْحَسَنِ وَالنَّخَعِیِّ أَنَّہُمَا لَمْ یَرَیَا بَأْسًا أَنْ یَکْتُبَ الرَّجُلُ إلَی الرَّجُلِ فَیَبْدَأَ بِہِ۔,,,26411 26412,"حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ سُفْیَانَ ، عَنْ أَبِی فَزَارَۃَ ، عَنِ الْحَکَمِ ، قَالَ : لاَ بَأْسَ أَنْ تَبْدَأَ بِغَیْرِکَ إذَا کَتَبْت إلَیْہِ۔",,,26412 26413,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَطَائِ بْنِ أَبِی مَیْمُونَۃَ ، قَالَ : سَمِعْتُ أَبَا رَافِعٍ یُحَدِّثُ ، عَنْ أَبِی ہُرَیْرَۃَ ، أَنَّ زَیْنَبَ کَانَ اسْمُہَا بَرَّۃَ ، فَقِیلَ لَہَا : تُزَکِّی نَفْسَہَا ، فَسَمَّاہَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ زَیْنَبَ۔\n\n(مسلم 17۔ احمد 2/430)",,,26413 26414,"حَدَّثَنَا الْحَسَنُ بْنُ مُوسَی ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّ ابْنَۃً لِعُمَرَ کَانَ یُقَالُ لَہَا عَاصِیَۃُ، فَسَمَّاہَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ جَمِیلَۃَ۔(مسلم 15۔ ابوداؤد 4913)",,,26414 26415,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنِ الْعَلاَئِ بْنِ الْمُسَیَّبِ ، عَنْ خَیْثَمَۃَ ، قَالَ : کَانَ اسْمُ أَبِی فِی الْجَاہِلِیَّۃِ عَزِیزًا ، فَسَمَّاہُ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَبْدَ الرَّحْمَن۔ (احمد 4/178۔ ابن حبان 5828)",,,26415 26416,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا سَمِعَ الاِسْمَ الْقَبِیحَ حَوَّلَہُ إلَی مَا ہُوَ أَحْسَنُ مِنْہُ۔ (ترمذی 2839)",,,26416 26417,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، قَالَ : حدَّثَنَا الْمَسْعُودِیُّ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ مَوْلَی آلِ طَلْحَۃَ ، عَنْ کُرَیْبٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : کَانَ اسْمُ جُوَیْرِیَۃَ بَرَّۃَ ، فَحَوَّلَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ اسْمَہَا۔\n\n(احمد 1/316)",,,26417 26418,"حَدَّثَنَا حُمَیدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، أَنَّ رَجُلاً کَانَ اسْمُہُ الْحُبَابَ ، فَسَمَّاہُ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَبْدَ اللہِ وَقَالَ: الْحُبَابُ شَیْطَانٌ ، وَکَانَ اسْمُ رَجُلٍ الْمُضْطَجِعَ فَسَمَّاہُ الْمُنْبَعِثَ۔\n\n(ابن سعد 541)",,,26418 26419,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا زَکَرِیَّا ، عَنْ عَامِرٍ ، قَالَ : لَمْ یُدْرِکِ الإِسْلاَمَ مِنْ عُصَاۃِ قُرَیْشٍ غَیْرُ مُطِیعٍ ، وَکَانَ اسْمُہُ الْعَاصِیَ ، فَسَمَّاہُ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مُطِیعًا۔ (مسلم 140۔ احمد 3/412)",,,26419 26420,"حَدَّثَنَا یَحْیَی بْنُ یَعْلَی أَبُو الْمُحَیَّاۃِ ، عَنْ عَبْدِ الْمَلِکِ بْنِ عُمَیْرٍ ، قَالَ : حدَّثَنِی ابْنُ أَخِی عَبْدِ اللہِ بْنِ سَلاَمٍ ، عَنْ عَبْدِ اللہِ بْنِ سَلاَمٍ ، قَالَ : قَدِمْت عَلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَلَیْسَ اسْمِی عَبْدَ اللہِ بْنَ سَلاَمٍ ، فَسَمَّانِی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَبْدَ اللہِ بْنَ سَلاَمٍ۔ (ترمذی 3256۔ حاکم 413)",,,26420 26421,"حَدَّثَنَا یَزِیدُ بْنُ الْمِقْدَامِ بْنِ شُرَیْحٍ ، عَنِ الْمِقْدَامِ بْنِ شُرَیْحٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ہَانِئِ بْنِ شُرَیْحٍ ، قَالَ : وَفَدَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی قَوْمِہِ فَسَمِعَہُمْ یُسَمُّونَ رَجُلاً عَبْدَ الْحَجَرِ ، فَقَالَ لَہُ : مَا اسْمُک ؟ قَالَ: عَبْدُ الْحَجَرِ ، فَقَالَ لَہُ : رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّمَا أَنْتَ عَبْدُ اللہِ۔",,,26421 26422,"حَدَّثَنَا ہَاشِمُ بْنُ الْقَاسِمِ ، قَالَ : حدَّثَنَا أَبُو عَقِیلٍ ، قَالَ : حَدَّثَنَا مُجَالِدُ بْنُ سَعِیدٍ ، عَنِ الشَّعْبِیِّ ، عَنْ مَسْرُوقٍ ، قَالَ : لَقِیت عُمَرَ بْنَ الْخَطَّابِ فَقَالَ : مَنْ أَنْتَ ؟ فَقُلْت : مَسْرُوقُ بْنُ الأَجْدَعِ ، فَقالَ عُمَر : سَمِعْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : الأَجْدَعُ شَیْطَانٌ۔ (ابوداؤد 4918۔ بزار 318)",,,26422 26423,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الأَعْمَشِ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَرِہَ عَبْدُ رَبِّہِ۔,,,26423 26424,حَدَّثَنَا وَکِیعٌ ، عَنْ قَیْسٍ الأسدی ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ مُجَاہِدٍ ، أَنَّہُ کَرِہَ عَبْدُ رَبِّہِ۔,,,26424 26425,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، قَالَ : کَرِہَ اللَّہُ مَالکًا۔",,,26425 26426,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنِ الرُّکَیْنِ ، عَنْ أَبِیہِ ، عَنْ سَمُرَۃََ ، قَالَ : نَہَانَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ نُسَمِّیَ رَقِیقَنَا أَرْبَعَۃَ أَسْمَائٍ : أَفْلَحَ وَنَافِعًا وَرَبَاحًا وَیَسَارًا۔ (مسلم 1685۔ ابوداؤد 4920)",,,26426 26427,"حَدَّثَنَا مُحَمَّدُ بْنُ عُبَیْدٍ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی سُفْیَانَ ، عَنْ جَابِرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنِّی عَسَیت إِنْ شَائَ اللَّہُ أَنْ أَنْہَی أُمَّتِی أَنْ یُسَمُّوا نَافِعًا وَأَفْلَحَ وَبَرَکَۃً ، قَالَ الأَعْمَشُ : لاَ أَدْرِی ذَکَرَ رَافِعًا أَمْ لاَ ، لأِنَّ الرَّجُلَ إذَا جَائَ یَقُولُ : أَثَمَّ بَرَکَۃٌ ، فَیَقُولُونَ : لاَ۔ (بخاری 833۔ ابوداؤد 4921)",,,26427 26428,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ أَبِی خَلْدَۃَ ، عَنْ أَبِی الْعَالِیَۃِ ، قَالَ : تَفْعَلُونَ شَرًّا مِنْ ذَلِکَ ، تُسَمُّونَ أَوْلاَدَکُمْ أَسْمَائَ الأَنْبِیَائِ ، ثُمَّ تَلْعُنْونَہُمْ۔",,,26428 26429,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ، عَنِ ابْنِ أَبِی نَجِیحٍ، عَنْ مُجَاہِدٍ، قَالَ: أَحَبُّ الأَسْمَائِ إلَی اللہِ عَبْدُاللہِ، وَعَبْدُالرَّحْمَن۔",,,26429 26430,"حَدَّثَنَا ابْنُ أَبِی عَدِیٍّ ، عَنْ دَاوُدَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : أَحَبُّ الأَسْمَائِ إلیہ أَسْمَائُ الأَنْبِیَائِ۔",,,26430 26431,"حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ ، قَالَ : حدَّثَنَا الْعُمَرِیُّ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَحَبُّ الأَسْمَائِ إلَی اللہِ عَبْدُ اللہِ ، وَعَبْدُ الرَّحْمَن۔ (مسلم 1682۔ ابوداؤد 4910)",,,26431 26432,"حَدَّثَنَا مُحَمَّدُ بْنُ الْحَسَنِ ، قَالَ : حدَّثَنَا أَبُو عَوَانَۃَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، أَنَّ ابْنَ الْحَنَفِیَّۃِ کَانَ یُکَنَّی أَبَا الْقَاسِمِ۔",,,26432 26433,"حَدَّثَنَا مُحَمَّدٌ بْنُ الْحَسَنِ ، قَالَ : حدَّثَنَا أَبُو عَوَانَۃَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ مُحَمَّدُ بْنُ الأَشْعَث وَکَانَ ابْنَ أُخْتِ عَائِشَۃَ وَکَانَ یُکَنَّی أَبَا الْقَاسِمِ۔",,,26433 26434,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ فِطْرٍ ، عَنْ مُنْذِرٍ ، عَنْ مُحَمَّدِ بْنِ الْحَنَفِیَّۃِ ، قَالَ : قَالَ عَلِیٌّ لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنْ وُلِدَ لِی غُلاَمٌ بَعْدَکَ أُسَمِّیہِ بِاسْمِکَ وَأُکَنِّیہِ بِکُنْیَتِکَ ؟ قَالَ : نَعَمْ۔ (ابوداؤد 4928)",,,26434 26435,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ ، عَنْ أَبِیہِ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لاَ تَتْرُکُوا النَّارَ فِی بُیُوتِکُمْ حِینَ تَنَامُونَ۔ (بخاری 6293۔ مسلم 1596)",,,26435 26436,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ بُرَیْدِ بْنِ عَبْدِ اللہِ ، عَنْ أَبِی بُرْدَۃَ ، عَنْ أَبِی مُوسَی ، قَالَ : احْتَرَقَ بَیْتٌ بِالْمَدِینَۃِ عَلَی أَہْلِہِ ، فَحُدِّثَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِشَأْنِہِمْ فَقَالَ : إنَّمَا ہَذِہِ النَّارُ عَدُوٌّ لَکُمْ ، فَإِذَا نِمْتُمْ فَأَطْفِئُوہَا عَنْکُمْ۔ (بخاری 6294۔ مسلم 1596)",,,26436 26437,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : أَمَرَنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَنَہَانَا ، فَأَمَرَنَا أَنْ نُطْفِئَ سُرُجَنَا۔ (بخاری 6296۔ مسلم 1594)",,,26437 26438,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : کَانَ یُکْرَہُ أَنْ نَدَعَ السُّراجَ حَتَّی نُصْبِحَ۔",,,26438 26439,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ الْقَطَّانُ ، عَنْ مُحَمَّدِ بْنِ أَبِی یَحْیَی ، عَنْ أَبِیہِ ، عَنْ أَبِی سَعِیدٍ ، قَالَ : قَالَ لنا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَوْمَ الْحُدَیْبِیَۃِ : لاَ تُوقِدُوا نَارًا بِلَیْلٍ ، ثُمَّ قَالَ : أَوْقِدُوا وأطفؤا فَإِنَّہُ لَنْ یُدْرِکَ قَوْمٌ مُدَّکُمْ ، وَلاَ صَاعَکُمْ۔ (نسائی 8855۔ احمد 3/26)",,,26439 26440,"حَدَّثَنَا عَمْرُو بْنُ طَلْحَۃَ ، عَنْ أَسْبَاطِ بْنِ نَصْرٍ ، عَنْ سِمَاکٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إذَا نِمْتُمْ فَأَطْفِئُوہَا۔ (بخاری 1222۔ ابوداؤد 5205)",,,26440 26441,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ أَبِی الْعُمَیْسِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی زِیَادٍ ، عَنْ أُمِّ وَلَدٍ لِعَبْدِاللہِ بْنِ مَسْعُودٍ، قَالَتْ : کَانَ عَبْدُ اللہِ یَأْمُرُ بِدَارِہِ فَتُکْنَسُ حَتَّی لَوِ الْتَمَسْت فِیہَا تَبِنَۃً ، أَوْ قَصَبَۃً مَا قَدَرْت عَلَیْہَا۔",,,26441 26442,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سُرِّیَّۃِ الرَّبِیعِ ، قَالَتْ : کَانَ الرَّبِیعُ یَأْمُرُ بِالدَّارِ تُنَظَّفُ کُلَّ یَوْمٍ۔",,,26442 26443,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مَنْصُورٌ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : لَمَّا قَدِمَ الأَشْعَرِیُّ الْبَصْرَۃَ ، قَالَ لَہُمْ : فیما تقولون إنَّ أَمِیرَ الْمُؤْمِنِینَ بَعَثَنِی إلَیْکُمْ لأَعَلِّمَکُمْ سُنَّتَکُمْ وَأُنَظِّفَ لَکُمْ طُرُقَکُمْ۔",,,26443 26444,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ ، قَالَ : سَمِعْتُ أَبَا ہُرَیْرَۃَ یَقُولُ : قَالَ أَبُو الْقَاسِمِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : سَمُّوا بِاسْمِی ، وَلاَ تَکَنَّوْا بِکُنْیَتِی۔ (بخاری 3539۔ مسلم 1684)",,,26444 26445,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی سُفْیَانَ ، عَنْ جَابِرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : تَسَمَّوْا بِاسْمِی ، وَلاَ تَکَنَّوْا بِکُنْیَتِی۔ (احمد 313۔ ابویعلی 1918)",,,26445 26446,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ حُمَیْدٍ ، عَنْ أَنَسٍ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِالْبَقِیعِ ، فَنَادَی رَجُلٌ آخَرَ یَا أَبَا الْقَاسِمِ ، فَالْتَفَتَ إلَیْہِ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقَالَ : إنِّی لَمْ أَعْنِکَ یَا رَسُولَ اللہِ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : تَسَمَّوْا بِاسْمِی ، وَلاَ تَکَنَّوْا بِکُنْیَتِی۔ (بخاری 2120۔ مسلم 1682)",,,26446 26447,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ سَالِمٍ ، عَنْ جَابِرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: تَسَمَّوا بِاسْمِی ، وَلاَ تَکَنَّوْا بِکُنْیَتِی ، فَإِنَّمَا جُعِلْت قَاسِمًا أَقْسِمُ بَیْنَکُمْ۔ (بخاری 6187۔ مسلم 1683)",,,26447 26448,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی عَمْرَۃَ ، عَنْ عَمِّہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تَجْمَعُوا بَیْنَ اسْمِی وَکُنْیَتِی۔ (احمد 5/364۔ ابن سعد 107)",,,26448 26449,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ مُحَمَّدِ بْنِ الْمُنْکَدِرِ سَمِعَ جَابِرًا یَقُولُ : وُلِدَ لِرَجُلٍ مِنَّا غُلاَمٌ ، قَالَ : فَسَمَّاہُ الْقَاسِمَ ، قَالَ : فَقُلْنَا : لاَ نُکَنِّیہِ أَبَا الْقَاسِمِ ولاَ نُنْعِمُہُ عَیْنًا ، فَأَتَی رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَذَکَرَ لَہُ ذَلِکَ فَقَالَ : أَسْم ابْنَک عَبْدَ الرَّحْمَن۔ (بخاری 6186۔ مسلم 1684)",,,26449 26450,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : قُلْتُ لِمُحَمَّدٍ : أَکَانَ یُکْرَہُ أَنْ یُکَنَّی الرَّجُلُ بِأَبِی الْقَاسِمِ ، وَإِنْ لَمْ یَکُنِ اسْمُہُ مُحَمَّدًا ؟ قَالَ : نَعَمْ۔",,,26450 26451,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ سُلَیْمَانَ الأَحْوَلِ ، قَالَ : کُنَّا نَطُوفُ وَمَعَنَا مِقْسَمٌ فَجَعَلَ طَاوُوسٌ یُحَدِّثُہُ وَیَقُولُ إِیہًا فَقُلْنَا : أَبُو الْقَاسِمِ ، فَقَالَ : وَاللَّہِ لاَ أَکْنِیہِ بِہَا۔",,,26451 26452,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ، عَنْ أَبِی الْمُہَلَّبِ ، عَنْ عِمْرَانَ بْنِ حُصَیْنٍ ، قَالَ : بَیْنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی بَعْضِ أَسْفَارِہِ وَامْرَأَۃٌ مِنَ الأَنْصَارِ عَلَی نَاقَۃٍ ، فَضَجِرَتْ فَلَعَنَتْہَا ، فَسَمِعَ ذَلِکَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقَالَ : خُذُوا مَا عَلَیْہَا وَدَعُوہَا فَإِنَّہَا مَلْعُونَۃٌ ، قَالَ عِمْرَانُ بْنُ حُصَیْنٍ : فَکَأَنِّی أَرَاہَا تَجُولُ فِی السُّوقِ مَا یَعْرِضُ لَہَا أَحَدٌ۔ (مسلم 2004۔ ابوداؤد 2554)",,,26452 26453,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ أَخْبَرَنَا سُلَیْمَانُ التَّیْمِیُّ ، عَنْ أَبِی عُثْمَانَ ، عَنْ أَبِی بَرْزَۃَ ، أَنَّ جَارِیَۃً بَیْنَمَا ہِیَ عَلَی بَعِیرٍ ، أَوْ رَاحِلَۃٍ عَلَیْہَا مَتَاعٌ لِلْقَوْمِ بَیْنَ جَبَلَیْنِ فَتَضَایَقَ بِہَا الْجَبَلُ ، فَأَتَی عَلَیْہَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَلَمَّا أَبْصَرَتْہُ جَعَلَتْ تَقُولُ : حل اللَّہُمَّ الْعَنْہُ حَلَّ اللَّہُمَّ الْعَنْہُ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ صَاحِبُ الرَّاحِلَۃِ ؟ لاَ یَصْحَبُنَا بَعِیرٌ ، أَوْ رَاحِلَۃٌ عَلَیْہَا لَعَنْۃٌ مِنَ اللہِ ، أَوْ کَمَا قَالَ۔\n\n(مسلم 2005۔ احمد 4/419)",,,26453 26454,"حَدَّثَنَا شَبَابَۃُ ، قَالَ : حدَّثَنَا لَیْثُ بْنُ سَعْدٍ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنَ، عَنْ أَبِیہِ، عَنْ أَبِی ہُرَیْرَۃَ، قَالَ: بَیْنَمَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَسِیرُ فِی نَاسٍ مِنْ أَصْحَابِہِ إذْ لَعَنْ رَجُلٌ مِنْہُمْ بَعِیرَہُ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَنْ لَعَنْ بَعِیرَہُ ؟ فَقَالَ: أَنَا یَا رَسُولَ اللہِ، قَالَ: أَخِّرْہُ عَنَّا، فَقَدْ أُجِبْت۔ (احمد 2/428)",,,26454 26455,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ شِمْرٍ ، عَنْ یَحْیَی بْنِ وَثَّابٍ ، عَنْ عَائِشَۃَ ، أَنَّہَا قُرِّبَ إلَیْہَا بَعِیرًا لِتَرْکَبَہُ ، فَالْتَوَی عَلَیْہَا فَلَعَنَتْہُ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تَرْکَبِیہِ فَإِنَّک لَعَنْتِیہِ۔\n\n(احمد 6/257۔ ابویعلی 4716)",,,26455 26456,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنِ الْجُرَیْرِیِّ ، عَنْ أَبِی عُثْمَانَ ، قَالَ : بَیْنَمَا عُمَرُ یَسِیرُ فِی أصْحَابِہِ وَفِی الْقَوْمِ رَجُلٌ یَسِیرُ عَلَی بَعِیرٍ لَہُ مِنَ الْقَوْمِ یَضَعُہُ حَیْثُ یَشَائُ ، فَلاَ أَدْرِی بِمَا الْتَوَی عَلَیْہِ فَلَعَنْہُ ، فَقَالَ عُمَرُ : مَنْ ہَذَا اللاَّعِنُ ؟ قَالُوا : فُلاَنٌ ، قَالَ : تَخَلَّفْ عَنَّا أَنْتَ وَبَعِیرُک ، لاَ تَصْحَبُنَا رَاحِلَۃٌ مَلْعُونَۃٌ۔",,,26456 26457,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ بُرْدِ بْنِ سِنَانٍ ، عَنْ سُلَیْمَانَ بْنِ مُوسَی ، قَالَ : إنَّ لِکُلِّ شَیْئٍ شَرَفًا ، وَأَشْرَفُ الْمَجَالِسِ مَا اسْتَقْبَلَ بِہِ الْقِبْلَۃَ ، وقَالَ : مَا رَأَیْت سُفْیَانَ یَجْلِسُ إلاَّ مُسْتَقْبِلَ الْقِبْلَۃِ۔",,,26457 26458,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَانَ مُحَمَّدٌ إذَا نَامَ اسْتَقْبَلَ الْقِبْلَۃَ وَرُبَّمَا اسْتَلْقَی۔",,,26458 26459,حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، أَنَّ ابْنَ مَسْعُودٍ جَلَسَ مُسْتَقْبِلَ الْقِبْلَۃِ۔,,,26459 26460,"حَدَّثَنَا وَکِیعٌ، عَنْ مُحَمَّدِ بْنِ عَبْدِاللہِ الشُّعَیْثِیِّ ، عَنْ مَکْحُولٍ ، قَالَ: أَفْضَلُ الْمَجَالِسِ مُسْتَقْبِلَ الْقِبْلَۃِ۔",,,26460 26461,"حَدَّثَنَا وَکِیعٌ، عَنْ ثَوْرٍ، عَنْ سُلَیْمَانَ بْنِ مُوسَی، قَالَ: لِکُلِّ شَیْئٍ سَیِّدٌ، وَسَیِّدُ الْمَجَالِسِ مُسْتَقْبِلَ الْقِبْلَۃِ۔",,,26461 26462,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنِ الْجُرَیْرِیِّ ، عَنْ أَبِی الْعَلاَئِ ، قَالَ : مَا أُعْطِیَ عَبْدٌ بَعْدَ الإِسْلاَمِ أَفْضَلَ مِنْ عَقْلٍ صَالِحٍ یُرْزَقُہُ۔",,,26462 26463,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا زَکَرِیَّا ، عَنْ عَامِرٍ ، قَالَ : قَالَ عُمَرُ : حَسْبُ الرَّجُلِ دِینُہُ وَمُرُوئَتُہُ: خُلُقُہُ ، وَأَصْلُہُ : عَقْلُہُ۔",,,26463 26464,حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی السَّفَرِ ، عَنِ الشَّعْبِیِّ ، عَنْ زِیَادِ بْنِ حُدِیرٍ ، عَنْ عُمَرَ بِنَحْوِہِ۔,,,26464 26465,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، قَالَ : {فَإِنْ آنَسْتُمْ مِنْہُمْ رُشْدًا} قَالَ : عَقْلاً۔",,,26465 26466,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا إسْمَاعِیلُ بْنُ أَبِی خَالِدٍ ، عَنْ عَامِرٍ ، قَالَ : قَالَ عُمَرُ : حَسْبُ الْمَرْئِ دِینُہُ وَمُرُوئَتُہُ ، خُلُقُہُ ، وَأَصْلُہُ : عَقْلُہُ۔",,,26466 26467,"حَدَّثَنَا جَرِیرٌ ، عَنْ قَابُوسَ ، عَنْ أَبِیہِ ، عَنِ ابْنِ عَبَّاسٍ فِی قَوْلِہِ تَعَالَی : {قَسَمٌ لِذِی حِجْرٍ} قَالَ : لذی النُّہَی وَالْعَقْلِ۔",,,26467 26468,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنْ عِکْرِمَۃَ فِی قَوْلِہِ: {قَسَمٌ لِذِی حِجْرٍ} قَالَ: لِذِی لُبٍّ وَلِذِی عَقْلٍ۔",,,26468 26469,"حَدَّثَنَا خَلَفُ بْنُ خَلِیفَۃَ ، عَن ہِلاَلِ بن خَبَّاب ، عَن مُجاہِد : {قَسَمٌ لِذِی حِجْرٍ} قَالَ : لِذِی عَقْلٍ۔",,,26469 26470,"حَدَّثَنَا وَکِیعٌ ، عَن سُفیان ، عن الأَغَر ، عَنْ خَلِیفَۃَ بْنِ حُصَیْنٍ ، عَنْ أَبِی نَصْرٍ ، عَنِ ابْنِ عَبَّاسٍ {قَسَمٌ لِذِی حِجْرٍ} : لِذِی لُبٍّ۔",,,26470 26471,"حَدَّثَنَا عَبْدَۃُ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ {قَسَمٌ لِذِی حِجْرٍ} قَالَ : لِذِی عَقْلٍ۔",,,26471 26472,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، عَنْ نَتْفِ الشَّیْبِ وَقَالَ : ہُوَ نُورُ الْمُؤْمِنِ۔\n\n(ترمذی 2821۔ ابن ماجہ 3721)",,,26472 26473,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَیُّوبَ السِّخْتِیَانِیِّ ، عَنْ یُوسُفَ ، عَنْ طَلْقِ بْنِ حَبِیبٍ ، أَنَّ حَجَّامًا أَخَذَ مِنْ شَارِبِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَرَأَی شَیْبَۃً فِی لِحْیَتِہِ ، فَأَہْوَی إلَیْہَا ، فَأَخَذَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِیَدِہِ وَقَالَ : مَنْ شَابَ شَیْبَۃً فِی الإِسْلاَمِ کَانَتْ لَہُ نُورًا یَوْمَ الْقِیَامَۃِ۔ (ترمذی 1635۔ ابن سعد 433)",,,26473 26474,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنِ الْمُثَنَّی ، عَنْ قَتَادَۃَ ، عَنْ أَنَسٍ ، أَنَّہُ کَانَ یَکْرَہُ نَتْفَ الشَّیْبِ۔ (مسلم 104),,,26474 26475,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ ہِشَامٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : عُذِّبَ رَجُلٌ فِی نَتْفِ الشَّیْبِ۔",,,26475 26476,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حُمَیْدٍ الأَعْرَجِ ، عَنْ مُجَاہِدٍ ، قَالَ : کَانَ یَقُولُ : لاَ تَنْتِفُوا الشَّیْبَ فَإِنَّہُ نُورٌ یَوْمَ الْقِیَامَۃِ۔",,,26476 26477,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ کَرِہَ نَتْفَ الشَّیْبِ وَلَمْ یَرَ بِقَصِّہِ بَأْسًا۔,,,26477 26478,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مُغِیرَۃَ ، عَنِ الشَّعْبِیِّ ، قَالَ : سَمِعْتُ عَبْدَ اللہِ بْنَ عُمَرَ یَقُولُ : الْقُعُودُ بَیْنَ الظِّلِّ وَالشَّمْسِ مَقْعَدُ الشَّیْطَانِ۔",,,26478 26479,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ قَتَادَۃَ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یَقْعُدَ الرَّجُلُ بَیْنَ الظِّلِّ وَالشَّمْسِ۔ (بخاری 1174۔ عبدالرزاق 19800)",,,26479 26480,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، عَنْ زِیَادٍ مَوْلَی بَنِی مَخْزُومٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : حرْفُ الظِّلِّ مَقْعَدُ الشَّیْطَانِ۔ (ابوداؤد 4788۔ احمد 2/383)",,,26480 26481,"حَدَّثَنَا وَکِیعٌ ، عَنْ قُرَّۃَ ، عَنْ نُفَیْعٍ الْجَمَّالِ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ، قَالَ: حرْفُ الظِّلِّ مَقِیلُ الشَّیْطَانِ۔",,,26481 26482,"حَدَّثَنَا عَلِیُّ بْنُ الْجَعْدِ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ مُحَمَّدِ بْنِ وَاسِعٍ ، عَنْ أَبِی عِیَاضٍ ، عَنْ عُبَیْدِ بْنِ عُمَیْرٍ ، قَالَ : حَدُّ الظِّلِّ وَالشَّمْسِ مَقَاعِدُ الشَّیْطَانِ۔",,,26482 26483,"حَدَّثَنَا عَبْدُالأَعْلَی، عَنْ خَالِدٍ، عَنْ عِکْرِمَۃَ فِی الَّذِی یَقْعُدُ بَیْنَ الظِّلِّ وَالشَّمْسِ: قَالَ ذَاکَ مَقْعَدُ الشَّیْطَانِ۔",,,26483 26484,حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ أَبِی الْمُنِیبِ ، عَنِ ابْنِ بُرَیْدَۃَ ، عَنْ أَبِیہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أَنَّہُ نَہَی أَنْ یُقْعَدَ بَیْنَ الشَّمْسِ وَالظِّلِّ۔ (ابن ماجہ 372۔ حاکم 272),,,26484 26485,"حَدَّثَنَا وَکِیعٌ ، عَنْ عِمْرَانَ بْنِ حُدَیْرٍ ، قَالَ : سَمِعْتُ عِکْرِمَۃَ یَقُولُ : مَنِ اسْتَمَعَ حَدِیث قَوْمٍ وَہُمْ لَہُ کَارِہُونَ صُبَّ فِی أُذُنِہِ الآنُکُ یَوْمَ الْقِیَامَۃِ یَعْنِی الرَّصَاصَ۔ (بخاری 7042۔ ابوداؤد 4985)",,,26485 26486,"حَدَّثَنَا عَبْدُ اللہِ بْنُ الْمُبَارَکِ ، عَنْ سَعِیدِ بْنِ أَبِی أَیُّوبَ ، عَنْ عَطَائِ بْنِ دِینَارٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تَتَّخِذُوا ظُہُورَ الدَّوَابِّ کَرَاسِیَ لأَحَادِیثِکُمْ ، فَرُبَّ رَاکِبِ مَرْکُوبَۃٍ ہِیَ خَیْرٌ مِنْہُ وَأَطْوَعُ لِلَّہِ وَأَکْثَرُ ذِکْرًا۔ (احمد 3/440۔ دارمی 2668)",,,26486 26487,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ سَعِیدٍ الزُّبَیْدِیِّ ، عَنْ إبْرَاہِیمَ التَّیْمِیِّ ، أَنَّ عُمَرَ کَرِہَ الْوُقُوفَ عَلَی الدَّابَّۃِ۔,,,26487 26488,"حَدَّثَنَا وَکِیعٌ، عَنْ کَامِل، عَن حَبِیب قَالَ: کَانَ یَکرہ طُول الْوُقُوفِ عَلَی الدَّابَّۃِ وَأَنْ تُضْرَبَ وَہِیَ محسنۃ۔",,,26488 26489,"حَدَّثَنَا ابْنُ إدْرِیسَ، عَنْ مُوسَی الْجُہَنِیِّ، قَالَ: رَأَیْتُ الشَّعْبِیَّ وَطَلْحَۃَ مُتَوَاقِفَیْنِ عَلَی دَارِ سَعْدِ بْنِ طَلْحَۃَ۔",,,26489 26490,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا دَاوُد بْنُ أَبِی ہِنْدٍ ، عَنْ أَبِی نَضْرَۃَ ، عَنْ أَبِی سَعِیدٍ ، أَنَّ أَبَا مُوسَی اسْتَأْذَنَ عَلَی عُمَرَ ثَلاَثًا فَلَمْ یَأْذَنْ لَہُ ، قَالَ: فَانْصَرَفَ فَأَرْسَلَ إلَیْہِ عُمَرُ : مَا رَدَّک؟ قَالَ : اسْتَأْذَنْت الاِسْتِئْذَانَ الَّذِی أَمَرَنَا بِہِ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ثَلاَثًا ، فَإِنْ أُذِنَ لَنَا دَخَلْنَا ، وَإِنْ لَمْ یُؤْذَنْ لَنَا رَجَعْنَا ، قَالَ : لِتَأْتِینَّ عَلَی ہَذَا بِبَیِّنَۃٍ ، أَوْ لأَفْعَلَنَّ وَأَفْعَلَنَّ ، فَأَتَی مَجْلِسَ قَوْمِہِ فَنَاشَدَہُمْ ، فَشَہِدُوا لَہُ ، فَخَلَّی عَنْہُ۔\n\n(بخاری 2062۔ مسلم 35)",,,26490 26491,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ، قَالَ : قَالَ عَلِیٌّ : الأُولَی إذن ، وَالثَّانِیَۃُ مُؤَامَرَۃٌ ، وَالثَّالِثَۃُ عَزْمَۃٌ ، إمَّا أَنْ یُؤْذَنُوا وَإِمَّا أَنْ یُرَدُّوا۔",,,26491 26492,"حَدَّثَنَا إِسْحَاقُ الأَزْرَقُ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : الاِسْتِئْذَانُ ثَلاَثٌ ، فَإِنْ أُذِنَ لَکَ وَإِلاَّ فَارْجِعْ۔",,,26492 26493,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ فِی الْقَوْمِ یَسْتَأْذِنُونَ ، قَالَ : قَالَ : إِنْ قَالَ رَجُلٌ مِنْہُمُ السَّلاَمُ عَلَیْکُمْ أَنَدْخُلُ ، أَجْزَأَ ذَلِکَ عَنْہُمْ۔",,,26493 26494,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، قَالَ : دَخَلْنَا عَلَی أَبِی رَزِینٍ وَنَحْنُ ذُو عَدَدٍ ، فَکَانَ کُلُّ إنْسَانٍ مِنَّا یُسَلِّمُ وَیَسْتَأْذِنُ ، فَقَالَ : إِنَّہُ إذَا أُذِنَ لأَوَّلِکُمْ أُذِنَ لآخِرِکُمْ۔",,,26494 26495,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ سُلَیْمَانَ التَّیْمِیِّ ، عَنْ أَنَسِ بْنِ مَالِکٍ ، قَالَ : عَطَسَ رَجُلاَنِ عِنْدَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَشَمَّتَ ، أَوْ سَمَّتَ أَحَدَہُمَا وَلَمْ یُشَمِّتِ الآخَرَ ، فَقِیلَ : یَا رَسُولَ اللہِ ، عَطَسَ عِنْدَکَ رَجُلاَنِ فَشَمَّتَ أَحَدَہُمَا وَلَمْ تُشَمِّتِ الآخَرَ ، فَقَالَ : إنَّ ہَذَا حَمِدَ اللَّہَ ، وَإِنَّ ہَذَا لَمْ یَحْمَدِ اللَّہَ۔\n\n(بخاری 6221۔ مسلم 2292)",,,26495 26496,"حَدَّثَنَا قَاسِمُ بْنُ مَالِکٍ الْمُزَنِیّ ، عَنْ عَاصِمِ بْنِ کُلَیْبٍ ، عَنْ أَبِی بُرْدَۃَ ، قَالَ : دَخَلْت عَلَی أَبِی مُوسَی وَہُوَ فِی بَیْتِ بِنْتِ الْفَضْلِ فَعَطَسْت فَلَمْ یُشَمِّتْنِی وَعَطَسَتْ فَشَمَّتَہَا ؟ فَرَجَعْت إلَی أُمِّی فَأَخْبَرْتُہَا ، فَلَمَّا جَائَہَا ، قَالَتْ : عَطَسَ عِنْدَکَ ابْنِی فَلَمْ تُشَمِّتْہُ وَعَطَسَتْ فَشَمَّتَّہَا ، قَالَ : إنَّ ابْنَک عَطَسَ وَلَمْ یَحْمَدِ اللَّہَ فَلَمْ أُشَمِّتْہُ ، وَعَطَسَتْ ہذہ وَحَمِدَتِ اللَّہَ فَشَمَّتُّہَا ، وَسَمِعْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : إذَا عَطَسَ أَحَدُکُمْ فَحَمِدَ اللَّہَ فَشَمِّتُوہُ ، وَإِذَا لَمْ یَحْمَدِ اللَّہَ فَلاَ تُشَمِّتُوہُ۔ (بخاری 941۔ مسلم 2292)",,,26496 26497,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ عَمْرٍو ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مِنْ حَقِّ الْمُسْلِمِ عَلَی الْمُسْلِمِ تَشْمِیتُ الْعَاطِسِ إذَا حَمِدَ اللَّہَ۔ \n\n(مسلم 1704)",,,26497 26498,"حَدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنْ أَبِی مُنَیْنٍ ، عَنْ أَبِی حَازِمٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : کُنَّا جُلُوسًا عِنْدَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَعَطَسَ رَجُلٌ فَحَمِدَ اللَّہَ فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : یَرْحَمُک اللَّہُ ، ثُمَّ عَطَسَ آخَرُ فَسَکَتَ ، فَلَمْ یَقُلْ لَہُ شَیْئًا ، فَقَالَ : یَا رَسُولَ اللہِ ، عَطَسَ ہَذَا فَقُلْت لَہُ : رَحِمَک اللَّہُ ، وَعَطَسْت فَلَمْ تَقُلْ لِی شَیْئًا ؟ فَقَالَ : إنَّ ہَذَا حَمِدَ اللَّہَ وَأَنْتَ سَکَتَّ۔ (بخاری 930)",,,26498 26499,"حَدَّثَنَا مُحَمَّدُ بْنُ سَوَائٍ، عَنْ غَالِبٍ، قَالَ: کَانَ الْحَسَنُ، وَابْنُ سِیرِینَ لاَ یُشَمِّتَانِ الْعَاطِسَ حَتَّی یَحْمَدَاللَّہَ۔",,,26499 26500,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ عُبَیْدِ اللہِ ، قَالَ : عَطَسَ رجل عِنْدَ الْقَاسِمِ فَقَالَ لَہُ الْقَاسِمُ : قُلْ : الْحَمْدُ لِلَّہِ ، فَلَمَا قَالَ شَمَّتَہُ۔",,,26500 26501,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ النُّعْمَانِ بْنِ سَالِمٍ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ، أَنَّ رَجُلاً عَطَسَ عِنْدَہُ فَشَمَّتَہُ ، ثُمَّ عَطَسَ فَشَمَّتَہُ ، ثُمَّ عَادَ فِی الثَّالِثَۃِ فَقَالَ : إنَّک مَضْنُوکٌ۔",,,26501 26502,"حَدَّثَنَا وَکِیعٌ ، عَنْ فِطْرٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : شَمِّتِ الْعَاطِسَ مَا بَیْنَکَ وَبَیْنَہُ ثَلاَثًا ، فَإِنْ زَادَ ، فَہُوَ رِیحٌ۔",,,26502 26503,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ عِکْرِمَۃَ بْنِ عَمَّارٍ ، قَالَ : حدَّثَنِی إیَاسُ بْنُ سَلَمَۃَ بْنِ الأَکْوَعِ ، أَنَّ أَبَاہُ حَدَّثَہُ ، أَنَّ رَجُلاً عَطَسَ عِنْدَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقَالَ : رَحِمَک اللَّہُ ، ثُمَّ عَطَسَ الثَّانِیَۃَ ، فَقَالَ : ہُوَ مَزْکُومٌ۔ (مسلم 2292۔ ابوداؤد 4998)",,,26503 26504,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ مُصْعَبِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ ذُؤَیْبٍ ، قَالَ : عَطَسَ رَجُلٌ عِنْدَ ابْنِ الزُّبَیْرِ فَشَمَّتَہُ ، ثُمَّ عَطَسَ فَشَمَّتَہُ ، ثُمَّ عَطَسَ الثَّالِثَۃَ فَشَمَّتَہُ ، ثُمَّ عَطَسَ فِی الرَّابِعَۃِ فَقَالَ لَہُ : ابْنُ الزُّبَیْرِ : إنَّک مَضْنُوکٌ فَامْتَخِط۔",,,26504 26505,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مُغِیرَۃَ ، عَنِ الشَّعْبِیِّ ، قَالَ : قَالَ عَمْرُو بْنُ الْعَاصِ : إذَا عَطَسَ أَحَدُکُمْ ثَلاَثَ مَرَّاتٍ فَشَمِّتُوہُ ، فَإِنْ زَادَ فَلاَ تُشَمِّتُوہُ ، فَإِنَّمَا ہُوَ دَائٌ یَخْرُجُ مِنْ رَأْسِہِ۔",,,26505 26506,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا مُحَمَّدُ بْنُ إِسْحَاقَ ، عَنْ مُحَمَّدِ بْنِ جَعْفَرِ بْنِ الزُّبَیْرِ ، أَنَّ رَجُلاً عَطَسَ عِنْدَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَشَمَّتَہُ ، ثُمَّ عَطَسَ فَشَمَّتَہُ ، ثُمَّ عَطَسَ فَشَمَّتَہُ ، ثُمَّ عَطَسَ الرَّابِعَۃَ فَقَالَ لَہُ : النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّک مَضْنُوکٌ فَامْتَخِط۔",,,26506 26507,"حَدَّثَنَا إِسْحَاقُ الأَزْرَقُ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یَعْطِسُ مِرَارًا ، قَالَ : شَمِّتْہُ مَرَّۃً وَاحِدَۃً۔",,,26507 26508,حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، قَالَ یُجْزِئُہُ أَنْ یُشَمِّتَہُ مَرَّۃً وَاحِدَۃً۔,,,26508 26509,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ أَبِی الْمُنَبِّہِ ، قَالَ : سَأَلْتُ الْحَسَنَ عَنِ الرَّجُلِ یَحْتَاجُ إلَی الدُّخُولِ عَلَی أَہْلِ الذِّمَّۃِ مِنْ مَطَرٍ ، أَوْ بَرْدٍ ، أَیَسْتَأْذِنُ عَلَیْہِمْ ؟ قَالَ : نَعَمْ۔",,,26509 26510,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : قُلْتُ لِمُحَمَّدٍ : کَیْفَ أَسْتَأْذِنُ عَلَی أَہْلِ الْکِتَابِ ؟ قَالَ : إِنْ شِئْتَ قُلْتَ : السَّلاَمُ عَلَی مَنِ اتَّبَعَ الْہُدَی أَلِجُ ؟۔",,,26510 26511,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ، عَن حُصَیْنٍ، عَنْ أَبِی مَالِکٍ الْغِفَارِیِّ ، قَالَ: إذَا دَخَلْت بَیْتًا فِیہِ الْمُشْرِکُونَ فَقُلْ: السَّلاَمُ عَلَیْنَا وَعَلَی عِبَادِ اللہِ الصَّالِحِینَ، یَحْسَبُونَ أَنَّک قَدْ سَلَّمْت عَلَیْہِمْ، وَقَدْ صَرَفْت السَّلاَمَ عَنہُمْ۔",,,26511 26512,حَدَّثَنَا وَکِیعٌ ، عَن سُفْیَانَ ، عَن مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، أَنَّہُ کَانَ یَسْتَأْذِنُ عَلَی أَہْلِ الذِّمَّۃِ۔,,,26512 26513,"حَدَّثَنَا وَکِیعٌ، عَن سُفْیَانَ، عَنْ أَبِی سِنَانٍ، عَن سَعِیدِ بْنِ جُبَیْرٍ، قَالَ: لاَ تَدْخُلْ عَلَی أَہْلِ الْکِتَابِ إلاَّ بِإِذْنٍ۔",,,26513 26514,"حَدَّثَنَا وَکِیعٌ ، عَن سُفْیَانَ ، عَن حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، أَنَّہُ کَانَ یَقُولُ : أندرآیم۔",,,26514 26515,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ أَبِی الْمُنَبِّہِ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَن مُجَاہِدٍ ، قَالَ : عَطَسَ رَجُلٌ عِنْدَ ابْنِ عُمَرَ فَقَالَ: أَشْہَبُ، قَالَ ابْنُ عُمَرَ: أَشْہَبُ اسْمُ شَیْطَانٍ، وَضَعَہُ إبْلِیسُ بَیْنَ الْعَطْسَۃِ وَالْحَمْدُ لِلَّہِ لِیُذْکَرَ۔",,,26515 26516,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَن مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ کَانَ یَکْرَہَ أَنْ یَقُولَ : أَشْہَبُ ، إذَا عَطَسَ۔",,,26516 26517,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَن حُصَیْنٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا عَطَسَ وَہُوَ وَحْدَہُ فَلْیَقُلِ : الْحَمْدُ لِلَّہِ رَبِّ الْعَالَمِینَ ، ثُمَّ یَقُولُ : یَرْحَمُنَا اللَّہُ وَإِیَّاکُمْ ، فَإِنَّہُ یُشَمِّتُہُ مَنْ سَمِعَہُ مِنْ خَلْقِ اللہِ۔",,,26517 26518,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ عَاصِمٍ ، عَنْ أَبِی وَائِلٍ ، قَالَ : إذَا عَطَسْت وَأَنْتَ وَحْدَک فَرُدَّ عَلَی مَنْ مَعَک یَعْنِی مِنَ الْمَلاَئِکَۃِ۔",,,26518 26519,"حَدَّثَنَا علی بْنُ مُسْہِرٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عِیسَی ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، عَنْ عَلِیٍّ ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا عَطَسَ أَحَدُکُمْ فَلْیَقُلْ : الْحَمْدُ لِلَّہِ ، وَلْیَرُدَّ عَلَیْہِ مَنْ حَوْلَہُ رَحِمَک اللَّہُ ، وَلْیَرُدَّ عَلَیْہِمْ : یَہْدِیکُمُ اللَّہُ وَیُصْلِحُ بَالَکُمْ۔ (ترمذی 2741۔ احمد 5/122)",,,26519 26520,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ، عَنْ عَبْدِ اللہِ ، قَالَ : إذَا عَطَسَ أَحَدُکُمْ فَلْیَقُلِ : الْحَمْدُ لِلَّہِ ، وَلْیَقُلْ مَنْ عِندَہُ : یَرْحَمُک اللَّہُ ، وَلْیَرُدَّ عَلَیْہِمْ : یَغْفِرُ اللَّہُ لَنَا وَلَکُمْ۔ \n\n(بخاری 934۔ حاکم 266)",,,26520 26521,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ، قَالَ: کَانَ أَصحَاب عَبد اللہ إذَا عَطَسَ الرَّجُل، فَقَالَ الْحَمْدُ لِلَّہِ قَالُوا : یَرْحَمُنَا اللَّہُ وَإِیَّاک ، وَیَقُول ہُو : یَغْفِرُ اللَّہُ لَنَا وَلَکُمْ۔",,,26521 26522,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنِ ابْنِ عَجْلاَنَ ، عَن نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ إذَا شَمَّتَ الْعَاطِسَ ، قَالَ : یَرْحَمُنَا اللَّہُ وَإِیَّاکُمْ ، فَإِذَا عَطَسَ ہُوَ فَشُمِّتَ ، قَالَ : یَغْفِرُ اللَّہُ لَنَا وَلَکُمْ وَیَرْحَمُنَا وَإِیَّاکُمْ۔",,,26522 26523,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنِ ابْنِ عَجْلاَنَ ، عَنِ الْحَارِثِ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ عَبْدُ اللہِ إذَا عَطَسَ فَشُمِّتَ ، قَالَ : یَغْفِرُ اللَّہُ لَنَا وَلَکُمْ۔",,,26523 26524,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ إذَا شَمَّتُوا الْعَاطِسَ ، قَالُوا : یَغْفِرُ اللَّہُ لَنَا وَلَکُمْ۔",,,26524 26525,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنِ الْحَجَّاجِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : إذَا شَمَّتَّ الْعَاطِسَ فَقُلْ : یَرْحَمُک اللَّہُ ، وَیَقُولُ ہُوَ : یَہْدِیکُمُ اللَّہُ وَیُصْلِحُ بَالَکُمْ۔",,,26525 26526,"حَدَّثَنَا سُوَیْد بْنُ عَمْرٍو ، قَالَ : أَخْبَرَنَا الْمَاجِشُونُ ، عَنْ عَبْدِ اللہِ بْنِ دِینَارٍ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إذَا رَدَّ فَلْیَقُلْ : یَہْدِیکُمُ اللَّہُ وَیُصْلِحُ بَالَکُمْ۔\n\n(بخاری 6224۔ احمد 2/353)",,,26526 26527,"حَدَّثَنَا عَائِذُ بْنُ حَبِیبٍ ، عَن طَلْحَۃَ بْنِ یَحْیَی ، قَالَ : سَمِعْتُ عُرْوَۃَ بْنَ الزُّبَیْرِ ، وَیَحْیَی وَعِیسَی بْنَ أَبِی طَلْحَۃَ وَإِبْرَاہِیمَ بْنَ مُحَمَّدِ بْنِ طَلْحَۃَ یقولون إذَا عَطَسَ أَحَدُکُمْ فَقِیلَ لَہُ : یَرْحَمُک اللَّہُ ، قَالَ: یَہْدِیکُمُ اللَّہُ وَیُصْلِحُ بَالَکُمْ۔",,,26527 26528,"حَدَّثَنَا عَبْدُ اللہِ بْنُ الْمُبَارَکِ ، عَن یُونُسَ ، عَنِ الزُّہْرِیِّ ، قَالَ : حدَّثَنَا أَبُو بَکْرِ بْنُ عَبْدِ الرَّحْمَنِ بْنِ الْحَارِثِ ، عَن مَرْوَانَ بْنِ الْحَکَمِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ بْنِ عَبْدِ یَغُوثَ ، عَن أُبَیٍّ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إنَّ مِنَ الشِّعْرِ حِکْمَۃً۔",,,26528 26529,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ، عَنِ الزُّہْرِیِّ، عَن عُرْوَۃَ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، قَالَ: مِنَ الشِعْرِ حِکْمَۃٌ۔",,,26529 26530,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حدَّثَنَا زَائِدَۃُ ، عَن سِمَاکٍ ، عَن عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَقُولُ : إنَّ مِنَ الشِّعْرِ حُکْمًا۔",,,26530 26531,"حَدَّثَنَا یَحْیَی بْنُ أَبِی بُکَیر ، قَالَ : حدَّثَنَا حُسَامُ بْنُ الْمِصَکِّ ، عَنِ ابْنِ بُرَیْدَۃَ ، عَنْ أَبِیہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ مِنَ الشِّعْرِ حُکْمًا۔",,,26531 26532,"حَدَّثَنَا وَکِیعٌ ، عَن ہِشَامٍ ، عَنْ أَبِیہِ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إنَّ مِنَ الشِّعْرِ حُکْمًا۔",,,26532 26533,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ إبْرَاہِیمَ بْنِ مَیْسَرَۃَ ، عَنِ ابْنِ الشَّرِیدِ ، أَوْ یَعْقُوبَ بْنِ عَاصِمٍ سَمِعَ أَحَدُہُمَا الشَّرِیدَ یَقُولُ : أَرْدَفَنِی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ خَلْفَہُ فَقَالَ : ہَلْ مَعَک مِنْ شِعْرِ أُمَیَّۃَ بْنِ أَبِی الصَّلْتِ شَیْئٌ؟ قُلْتُ: نَعَمْ، قَالَ: ہِیہِ ، فَأَنْشَدْتہ بَیْتًا فَقَالَ : ہِیہِ ، فَلَمْ یَزَلْ یَقُولُ : ہِیہِ ہِیہِ حَتَّی أَنْشَدْتہ مِئَۃ۔",,,26533 26534,"حَدَّثَنَا طَلْقُ بْنُ غَنَّامٍ ، عَن قَیْسٍ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَبِیدَۃَ ، عَنْ عَبْدِ اللہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إنَّ مِنَ الشِّعْرِ حُکْمًا ، وَإِنَّ مِنَ الْبَیَانِ سِحْرًا۔",,,26534 26535,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ عَبْدِ اللہِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ یَعْلَی ، عَنْ عَمْرِو بْنِ الشَّرِیدِ ، عَنْ أَبِیہِ ، قَالَ : أَنْشَدْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِئَۃ قَافِیَۃٍ مِنْ شِعْرِ أُمَیَّۃَ بْنِ أَبِی الصَّلْتِ یَقُولُ بَیْنَ کُلِّ قَافِیَۃٍ : ہِیہِ ، وَقَالَ : إِنْ کَادَ لَیُسْلِمُ۔",,,26535 26536,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ، عَن مُحَمَّدِ بْنِ إِسْحَاقَ ، عَن یَعْقُوبَ بْنِ عُتْبَۃ ، عَن عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَدَّقَ أُمَیَّۃَ بْنَ أَبِی الصَّلْتِ فِی شَیْئٍ مِنْ شِعْرِہِ ، أَوْ قَالَ فِی بَیْتَیْنِ مِنْ شِعْرِہِ، فَقَالَ :\n\nزُحَلٌ وَثَوْرٌ تَحْتَ رِجْلِ یَمِینِہ وَالنَّسْرُ لِلاُخْرَی وَلَیْثٌ مُرْصَدُ\n\nقالَ : فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : صَدَقَ۔\n\nوَالشَّمْسُ تَطْلُعُ کُلَّ آخِرِ لَیْلَۃٍ حَمْرَائَ یُصْبِحُ لَوْنُہَا یَتَوَرَّدُ\n\nفَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : صَدَقَ۔",,,26536 26537,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَن زَائِدَۃَ ، عَن سِمَاکٍ ، عَن عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَتَمَثَّلُ مِنَ الأَشْعَارِ :وَیَأْتِیک بِالأَخْبَارِ مَنْ لَمْ تُزَوِّدْ۔",,,26537 26538,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَن زَائِدَۃَ ، عَنْ عَبْدِ الْمَلِکِ بْنِ عُمَیْرٍ ، عَن مُوسَی بْنِ طَلْحَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إنَّ أَصْدَقَ کَلِمَۃٍ ، قَالَہَا شَاعِرٌ کَلِمَۃُ لَبِیدٍ ، ثُمَّ تَمَثَّلَ أَوَّلَہُ وَتَرَکَ آخِرَہُ :\n\nأَلاَ کُلُّ شَیْئٍ مَا خَلاَ اللَّہَ بَاطِلٌ۔\n\nوَکَادَ أُمَیَّۃُ بْنُ أَبِی الصَّلْتِ أَنْ یُسْلِمَ۔",,,26538 26539,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَن سُفْیَانَ ، عَنْ عَبْدِ الْمَلِکِ بْنِ عُمَیْرٍ ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ أَصْدَقَ کَلِمَۃٍ ، قَالَہَا الشَّاعِرُ کَلِمَۃُ لَبِیَدٍ :أَلاَ کُلُّ شَیْئٍ مَا خَلاَ اللَّہَ بَاطِلٌ۔وَکَادَ أُمَیَّۃُ بْنُ أَبِی الصَّلْتِ یُسْلِمَ۔",,,26539 26540,"حَدَّثَنَا عَبْدَۃَ بْنِ سُلَیْمَانَ ، عَنْ أَبِی حیان ، عَن حَبِیبِ بْنِ أَبِی ثَابِتٍ ، أَنَّ حَسَّانَ بْنَ ثَابِتٍ أَنْشَدَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَبْیَاتًا فَقَالَ :\n\nشَہِدْت بِإِذْنِ اللہِ أَنَّ مُحَمَّدًا\n\nوَأَنَّ أَبَا یَحْیَی وَیَحْیَی کِلاَہُمَا\n\nوَأَنَّ أَخَا الأَحْقَافِ إذَا قَامَ فِیہُمُ\n\nرَسُولُ الَّذِی فَوْقَ السَّمَاوَاتِ مِنْ عَلُ\n\nلَہُ عَمَلٌ فِی دِینِہِ مُتَقَبَّلُ\n\nیَقُولُ بِذَاتِ اللہِ فِیہِمْ وَیَعْدِلُ",,,26540 26541,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَن مُجَالِدٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : اسْتَأْذَنَ حَسَّانُ النَّبِیَّ فِی قُرَیْشٍ ، قَالَ : کَیْفَ تَصْنَعُ بِنَسَبِی فِیہِمْ ؟ قَالَ : أَسُلُّک مِنْہُمْ کَمَا تُسَلُّ الشَّعْرَۃُ مِنَ الْعَجِینِ۔",,,26541 26542,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَن مُجَالِدٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : ذُکِرَ عِنْدَ عَائِشَۃَ حَسَّانُ فَقِیلَ لَہَا : إِنَّہُ قَدْ أَعَانَ عَلَیْک وَفَعَلَ وَفَعَلَ ، فَقَالَتْ : مَہْلاً ، فَإِنِّی سَمِعْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : إنَّ اللَّہَ یُؤَیِّدُ حَسَّانَ فِی شِعْرِہِ بِرُوحِ الْقُدُسِ۔",,,26542 26543,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَن مُجَالِدٍ ، عَنِ الشَّعْبِیِّ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : اہْجُ الْمُشْرِکِینَ , فَإِنَّ رُوحَ الْقُدُسِ مَعَک۔",,,26543 26544,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَن ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، أَنَّ حَسَّانَ بْنَ ثَابِتٍ سَأَلَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یَہْجُوَ أَبَا سُفْیَانَ ، قَالَ : فَکَیْفَ بِقَرَابَتِی ؟ قَالَ : وَالَّذِی أَکْرَمَک لأسُلَّنَّکَ مِنْہُمْ سَلَّ الشَّعْرِ مِنَ الْعَجِینِ۔",,,26544 26545,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ عَدِیِّ بْنِ ثَابِتٍ ، عَنِ الْبَرَائِ بْنِ عَازِبٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لِحَسَّانَ بْنِ ثَابِتٍ : اہْجُ الْمُشْرِکِینَ , فَإِنَّ جِبْرِیلَ مَعَک۔",,,26545 26546,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی خَالِدٍ الْوَالِبِیِّ ، قَالَ : کُنَّا نُجَالِسُ أَصْحَابَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَتَنَاشَدُونَ الأَشْعَارَ وَیَذْکُرُونَ أَمْرَ الْجَاہِلِیَّۃِ۔",,,26546 26547,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عن أسامۃ , عَن نَافِعٍ ، قَالَ : کَانَت لِعَبْدِ اللہِ بن رواحۃ جَارِیَۃٌ ، فَکَانَ یُکَاتِمُ امْرَأَتَہُ غَشَیَانَہَا ، قَالَ : فَوَقَعَ عَلَیْہَا ذَاتَ یَوْمٍ ، فَجَائَ إلَی امْرَأَتِہِ فَاتَّہَمَتْہُ أَنْ یَکُونَ وَقَعَ عَلَیْہَا ، فَأَنْکَرَ ذَلِکَ فَقَالَتْ لہ : اقْرَأْ إذًا الْقُرْآنَ ، فَقَالَ :\n\nشَہِدْت بِإِذْنِ اللہِ أَنَّ مُحَمَّدًا\n\nوَأَنَّ أَبَا یَحْیَی وَیَحْیَی کِلاَہُمَا\n\nرَسُولُ الَّذِی فَوْقَ السَّمَاوَاتِ مِنْ عَلُ\n\nلَہُ عَمَلٌ فِی دِینِہِ مُتَقَبَّلُ\n\nفَقَالَتْ : أَولَی لکَ۔",,,26547 26548,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، عَن مِسْعَرٍ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَن خَیْثَمَۃَ ، قَالَ أَتَی عُمَرَ شَاعِرٌ فَقَالَ : أُنْشِدُک ، فَاسْتَنْشَدَہُ ، فَجَعَلَ ہُوَ یُنْشِدُہُ ، فَذَکَرَ مُحَمَّدًا فَقَالَ : غَفَرَ اللَّہُ لِمُحَمَّدٍ بِمَا صَبَرَ ، قَالَ : یَقُولُ عُمَرُ : قَدْ فَعَلَ ، ثُمَّ أَبَا بَکْرٍ جَمِیعًا وَعُمَرَ ، فَقَالَ : مَا شَائَ اللَّہُ۔",,,26548 26549,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَن مُصْعَبِ بْنِ سُلَیْمٍ ، عَنْ أَنَسٍ ، قَالَ : تَمَثَّلَ الْبَرَائُ بَیْتًا مِنْ شِعْرٍ فَقُلْت : تُمَثِّلُ أَخِی بِبَیْتٍ مِنْ شِعْرٍ لاَ تَدْرِی لَعَلَّہُ آخِرُ شَیْئٍ تَکَلَّمْت بِہِ ، قَالَ : لاَ أَمُوتُ عَلَی فِرَاشِی ، لَقَدْ قَتَلْت مِنَ الْمُشْرِکِینَ وَالْمُنَافِقِینَ مِئَۃ إلاَّ رَجُلاً۔",,,26549 26550,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی خَالِدٍ الْوَالِبِیِّ ، قَالَ : کُنْتُ أَجْلِسُ مَعَ أَصْحَابِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَلَعَلَّہُمْ لاَ یَذْکُرُونَ إلاَّ الشِّعْرَ حَتَّی یَتَفَرَّقُوا۔",,,26550 26551,حَدَّثَنَا وَکِیعٌ ، عَنِ الْحَسَنِ ، عَنْ أَبِی الْجَحَّافِ ، عَنِ الشَّعْبِیِّ ، قَالَ کَانَ أَبُو بَکْرٍ شَاعِرًا ، وَکَانَ عُمَرُ شَاعِرًا ، وَکَانَ عَلِیٌّ شَاعِرًا۔,,,26551 26552,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : أَخْبَرَنَا مُجَالِدٌ ، قَالَ : أَخْبَرَنَی عَامِرٌ ، قَالَ : أَخْبَرَنَا رِبْعِیُّ بْنُ حِرَاشٍ ، أَنَّہُ أَتَی عُمَرَ فِی نَفَرٍ مِنْ غَطَفَانَ فَذَکَرُوا الشِّعْرَ فَقَالَ عُمَرُ : أَیُّ شُعَرَائِکُمْ أَشْعَرُ ؟ فَقَالُوا : أَنْتَ أَعْلَمُ یَا أَمِیرَ الْمُؤْمِنِینَ ، قَالَ : فَقَالَ عُمَرُ : مَنِ الَّذِی یَقُولُ :\n\nأَتَیْتُک عَارِیًّا خَلِقًا ثِیَابِی\n\nعَلَی خَوْفٍ تُظَنُّ بِی الظُّنُونُ\n\nفَأَلْفَیْت الأَمَانَۃَ لَمْ تَخُنْہَا\n\nکَذَلِکَ کَانَ نُوحٌ لاَ یَخُونُ\n\nقُلنا النَّابِغَۃُ , ثُمَّ قَالَ مِثْلَ ذَلِکَ ، ثُمَّ قَالَ : مَنِ الَّذِی یَقُولُ :\n\nحَلَفْت فَلَمْ أَتْرُکْ لِنَفْسِکَ رِیبَۃً\n\nوَلَیْسَ وَرَائَ اللہِ لِلْمَرْئِ مَذْہَبُ\n\nثُمَّ قَالَ : مَنِ الَّذِی یَقُولُ :\n\nإلاَ سُلَیْمَانَ إذْ قَالَ الإِلَہُ لَہُ\n\nقُمْ فِی الْبَرِیَّۃِ فَازْجُرْہَا عَلی الْفَنَدِ\n\nقلْنَا : النَّابِغَۃُ ، قَالَ : ہَذَا أَشْعَرُ شُعَرَائِکُمْ۔",,,26552 26553,"حَدَّثَنَا وَکِیعٌ ، عَن سُفْیَانَ ، عَنْ أَبِیہِ ، عَنْ أَبِی الضُّحَی ، أَنَّ أَبَا بَکْرٍ اسْتَنْشَدَ مَعْدِی کَرِبَ فَأَنْشَدَہُ ، وَقَالَ : مَا اسْتَنْشَدْت فِی الإِسْلاَمِ أَحَدًا قَبْلَک۔",,,26553 26554,"حَدَّثَنَا وَکِیعٌ ، عَن سَعِیدِ بْنِ حَسَّانَ ، عَنْ عَبْدِ اللہِ بْنِ عُبَیْدِ بْنِ عُمَیْرٍ ، قَالَ : قَالَ أَبُو بَکْرٍ : رُبَّمَا قَالَ الشَّاعِرُ الْکَلِمَۃَ الْحِکَمِیَّۃَ۔",,,26554 26555,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَن زَکَرِیَّا ، عَنْ أَبِی إِسْحَاقَ ، عَن ہَانِئٍ ، قَالَ : سَمِعْتُ عَلِیًّا یَقُولُ :\n\nاشْدُدْ حَیَازِیمَکَ لِلْمَوْتِ\n\nوَلاَ تَجْزَعْ مِنَ الْمَوْتِ\n\nفإنَّ الْمَوْتَ لاَقِیکَا\n\nإذَا حَلَّ بِوَادِیکَا",,,26555 26556,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَن یَزِیدَ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : قَالَ عَلِیُّ بْنُ أَبِی طَالِبٍ لِلْمُرَادِیِّ :\n\nأُرِیدُ حَیَاتَہُ وَیُرِیدُ قَتْلِی\n\nعَذِیرَک مِنْ خَلِیِّکَ مِنْ مُرَادِ",,,26556 26557,"حَدَّثَنَا یَعلی بْنُ عُبَیْدٍ ، عَنْ أَبِی حَیَّانَ ، عَن مُجَمِّعٍ ، قَالَ : بَنَی عَلِیٌّ سِجْنًا فَسَمَّاہُ نَافِعًا ، ثُمَّ بَدَا لَہُ فَکَسَّرَہُ وَبَنَی أَحْصَنَ مِنْہُ ، ثُمَّ قَالَ بَیْتَ شِعْرٍ :\n\nأَلَمْ تَرَونی کَیِّسًا مُکَیَّسًا\n\nبَنَیْت بَعْدَ نَافِعٍ مُخَیَّسًا",,,26557 26558,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَن دَاوُد ، عَنِ الشَّعْبِیِّ ، أَنَّ عُمَرَ کَتَبَ إلَی الْمُغِیرَۃِ أَنْ یَسْتَنْطِق الشُّعَرَائَ عَندَہُ۔,,,26558 26559,"حَدَّثَنَا وَکِیعٌ ، عَن سُفْیَانَ ، عَنْ عَبْدِ الْمَلِکِ بْنِ أَبِی بَشِیر ، عَن عِکْرِمَۃَ ، قَالَ : کُنْتُ أَسِیرُ مَعَ ابْنِ عَبَّاسٍ وَنَحْنُ مُنْطَلِقُونَ إلَی عَرَفَاتٍ ، فَکُنْت أُنْشِدُہُ الشِّعْرَ ، وَیَفْتَحُہُ عَلَیَّ۔",,,26559 26560,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَن شُعْبَۃَ ، عَن قَتَادَۃَ ، عَن مُطَرِّفِ بْنِ عَبْدِ اللہِ ، قَالَ : خَرَجْت مَعَ عِمْرَانَ بْنِ حُصَیْنٍ إلَی الْکُوفَۃِ ، فَکَانَ لاَ یَأْتِی عَلَیْہِ یَوْمٌ إلاَّ أَنْشَدَنَا فِیہِ الشِّعْرَ۔",,,26560 26561,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَن مُحَمَّدِ بْنِ سِیرِینَ ، عَن کَثِیرِ بْنِ أَفْلَحَ ، قَالَ : کَانَ أخِرُ مَجْلِسٍ جَلَسْنَا فِیہِ مَعَ زَیْدِ بْنِ ثَابِتٍ مَجْلِسًا تَنَاشَدْنَا فِیہِ الشِّعْرَ۔",,,26561 26562,"حَدَّثَنَا عَبْدَۃُ ، عَن ہِشَامٍ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، قَالَتْ : قدِمْنَا الْمَدِینَۃَ وَہِیَ وَبِیئۃٌ فَاشْتَکَی أَبُو بَکْرٍ وَاشْتَکَی بِلاَلٌ ، قَالَتْ : فَکَانَ أَبُو بَکْرٍ تعنی إذَا أَفَاقَ یَقُولُ :\n\nکُلُّ امْرِئٍ مُصْبِحٌ فِی أَہْلِہِ\n\nوَالْمَوْتُ أَدْنَی مِنْ شِرَاکِ نَعْلِہِ\n\nقالَتْ : وَکَانَ بِلاَلٌ إذَا أَفَاقَ یَقُولُ :\n\nأَلاَ لَیْتَ شِعْرِی ہَلْ أَبِیتَنَّ لَیْلَۃً\n\nوہَلْ أَرِدَنَّ یَوْمًا مِیَاہَ مِجَنَّۃٍ\n\nبِوَادٍ وَحَوْلِی إذْخِرٌ وَجَلِیلُ\n\nوَہَلْ یَبْدُوَنَّ لِی شَامَۃٌ وَطَفِیلُ",,,26562 26563,"حَدَّثَنَا عَبْدَۃُ، عَن ہِشَامِ بْنِ عُرْوَۃَ، عَنْ أَبِیہِ، عَنْ عَائِشَۃَ، قَالَتْ: کَانَتْ تَتَمَثَّلُ ہَذَیْنِ الْبَیْتَیْنِ مِنْ قَوْلِ لَبِیَدٍ:\n\nذَہَبَ الَّذِینَ یُعَاشُ فِی أَکْنَافِہِمْ\n\nیَتَأَکَّلُونَ مَشِیحَۃً وَخِیَانَۃً\n\nوَبَقِیت فِی خَلَفٍ کَجِلْدِ الأَجْرَبِ\n\nوَیُعَابُ قَائِلُہُمْ وَإِنْ لَمْ یَشْغَبْ",,,26563 26564,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَن ہِشَامٍ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، قَالَتْ : کَانَ عُمَرُ یَتَمَثَّلُ بِہَذَا الْبَیْتِ :\n\nإلَیْک تَعْدُو قَلِقًا وَضِینُہَا \n\nمُعْترِضًا فِی بَطْنِہَا جَنِینُہَا۔\n\nمُخَالِفًا دِینَ النَّصَارَی دِینہَا۔",,,26564 26565,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَن مُسْلِمٍ ، عَن مَسْرُوقٍ ، عَنْ عَائِشَۃَ ، قَالَتْ : دَخَلَ عَلَیْہَا حَسَّانُ بْنُ ثَابِتٍ بَعْدَ مَا کُفَّ بَصَرُہُ ، فَقِیلَ لَہَا ، أَتُدْخِلِینَ عَلَیْک ہَذَا الَّذِی قَالَ اللَّہُ : {وَالَّذِی تَوَلَّی کِبْرَہُ مِنْہُمْ لَہُ عَذَابٌ عَظِیمٌ} قَالَتْ : أَوَلَیْسَ فِی عَذَابٍ عَظِیمٍ ، قَدْ کُفَّ بَصَرُہُ ، قَالَ : فَأَنْشَدَہَا بَیْتًا ، قَالَہُ لاِبْنَتِہِ :\n\nحَصَانٌ رَزَانٌ مَا تُزَنُّ بِرِیبَۃٍ وَتُصْبِحُ غَرْثَی مِنْ لُحُومِ الْغَوَافِلِ\n\nقالَتْ : لَکِنَّ أَنْتَ لَسْت کَذَلِکَ۔",,,26565 26566,حَدَّثَنَا وَکِیعٌ ، عَن سُفْیَانَ ، عَنْ أَبِی فَزَارَۃَ ، عَنِ الْحَکَمِ ، أَنَّ عَبْدَ الرَّحْمَن بْنَ أَبِی لَیْلَی أَنْشَدَ شِعْرًا فِی الْمَسْجِدِ وَالْمُؤَذِّنُ یُقِیمُ۔,,,26566 26567,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَن ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، قَالَ : مَا رَأَیْت أَحَدًا أَعْلَمَ بِشِعْرٍ ، وَلاَ فَرِیضَۃٍ ، وَلاَ أَعْلَمَ بِفِقْہٍ مِنْ عَائِشَۃَ۔",,,26567 26568,"حَدَّثَنَا شَرِیکٌ ، عَن فُرَاتٍ ، عَن سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : (الْقَانِعُ) السَّائِلُ ، ثُمَّ أَنْشَدَ بیت شَمَّاخٍ وَقَالَ:\n\nلَمَالُ الْمَرْئِ یُصْلِحُہُ فیغنی ۔۔۔ مَفَاقِرُہُ أَعَفُّ مِنَ الْقَنُوعِ۔",,,26568 26569,"حَدَّثَنَا شَرِیکٌ ، عَن بَیَانٍ ، عَنْ عَامِرٍ {فَإِذَا ہُمْ بِالسَّاہِرَۃِ} قَالَ : بِالأَرْضِ ، ثُمَّ أَنْشَدَ بیتا لأُمَیَّۃِ :\n\nفأتانا بلَحْمٍ بسَاہِرَۃٍ وَبَحْر",,,26569 26570,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَاصِمٍ ، قَالَ : مَا سَمِعت الْحَسَنَ یَتَمَثَّلُ بِبَیْتٍ مِنْ شِعْرٍ قَطُّ إلاَّ ہَذَا الْبَیْتَ :\n\nلَیْسَ مَنْ مَاتَ فَاسْتَرَاحَ بِمَیِّتٍ إنَّمَا الْمَیِّتُ مَیِّتُ الأَحْیَائِ\n\nثُمَّ قَالَ : صَدَقَ وَاللَّہِ ، إِنَّہُ لَیَکُونُ حَیًّا وَہُوَ مَیِّتُ الْقَلْبِ۔",,,26570 26571,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَن ہِشَامٍ ، قَالَ : سَمِعْتُ أَبِی یَقُولُ : تَرَکْتہَا یَعْنِی عَائِشَۃَ قَبْلَ أَنْ تَمُوتَ بِثَلاَثِ سِنِینَ ، وَمَا رَأَیْت أَحَدًا أَعْلَمَ بِکِتَابِ اللہِ ، وَلاَ بِسُنَّۃٍ ، عَن رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَلاَ بِشِعْرٍ ، وَلاَ فَرِیضَۃٍ مِنْہَا۔",,,26571 26572,"حَدَّثَنَا أَبُو دَاوُدَ ، قَالَ : الطَّیَالِسِیُّ ، عَن مِسْمَعِ بْنِ مَالِکٍ الْیَرْبُوعِیِّ ، قَالَ : سَمِعْتُ عِکْرِمَۃَ یَقُولُ : کَانَ ابْنُ عَبَّاسٍ إذَا سُئِلَ عَن شَیْئٍ مِنَ الْقُرْآنِ أَنْشَدَ أشْعَارًا مِنْ أَشْعَارِہِمْ۔",,,26572 26573,"حَدَّثَنَا حُسَین بْنُ عَلِیٍّ ، عَنِ ابْنِ أَبْجَرَ ، قَالَ : مَرَّ عَامِرٌ بِرَجُلَیْنِ عِنْدَ مَجْمَعِ طَرِیقَیْنِ وَہُمَا یَغتَبَانہ وَیَقَعَانِ فِیہِ فَقَالَ :\n\nہَنِیئًا مَرِیئًا غَیْرَ دَائِ مُخَامِرٍ لِعَزَّۃَ مِنْ أَعْرَاضِنَا مَا اسْتَحَلَّتِ",,,26573 26574,"حَدَّثَنَا یَحْیَی بْنُ وَاضِحٍ ، عَن مُحَمَّدِ بْنِ إِسْحَاقَ ، عَن یَزِیدَ بْنِ عَبْدِ اللہِ بْنِ قُسَیْطٍ ، عَنْ أَبِی الْحَسَنِ الْبَرَّادِ ، قَالَ : لَمَّا نَزَلَتْ ہَذِہِ الآیَۃُ {وَالشُّعَرَائُ یَتَّبِعُہُمَ الْغَاوُونَ} جَائَ عَبْدُ اللہِ بْنُ رَوَاحَۃَ وَکَعْبُ بْنُ مَالِکٍ وَحَسَّانُ بْنُ ثَابِتٍ إلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُمْ یَبْکُونَ ، فَقَالُوا : یَا رَسُولَ اللہِ ، أَنْزَلَ اللَّہُ ہَذِہِ الآیَۃَ وَہُوَ یَعْلَمُ أَنَّا شُعَرَائُ ، فَقَالَ : اقَرَؤُوا مَا بَعْدَہَا : {إلاَ الَّذِینَ آمَنُوا وَعَمِلُوا الصَّالِحَاتِ} أَنْتُمْ {وَانْتَصَرُوا} أَنْتُمْ۔",,,26574 26575,"حَدَّثَنَا وَکِیعٌ ، عَن سُفْیَانَ ، عَن سَلَمَۃَ، عَن عِکْرِمَۃَ: {وَالشُّعَرَائُ یَتَّبِعُہُمَ الْغَاوُونَ} قَالَ: عُصَاۃُ الْجِنِّ۔",,,26575 26576,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ أَبِی جَعْفَرٍ الْخَطْمِیِّ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَبْنِی الْمَسْجِدَ ، وَعَبْدُ اللہِ بْنُ رَوَاحَۃَ یَقُولُ :\n\nأَفْلَحَ مَنْ یُعَالِجُ الْمَسَاجِدَا۔\n\nوَرَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ :\n\nقَدْ أَفْلَحَ مَنْ یُعَالِجُ الْمَسَاجِدَا۔\n\nیَتْلُو الْقُرْآنَ قَائِمًا وَقَاعِدَا۔\n\nوَرَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ :\n\nوَیَتْلُو الْقُرْآنَ قَائِمًا وَقَاعِدَا۔\n\nوَہُمْ یَبْنُونَ الْمَسْجِدَ۔",,,26576 26577,"حَدَّثَنَا أَبُو أُسَامَۃَ ، حدَّثَنَا مُجَالِدٌ ، عَنْ عَامِرٍ ، أَنَّ حَارِثَۃَ بْنَ بَدْرٍ التَّیْمِیَّ مِنْ أَہْلِ الْبَصْرَۃِ ، قَالَ :\n\nأَلاَ أَبْلِغَنْ ہَمْدَانَ إِمَّا لَقِیتہَا سَلاَما فَلاَ یَسْلَمُ عَدُوٌّ یَعِیبُہَا\n\nلَعَمْرُ یَمِینًا إنَّ ہَمْدَانَ تَتَّقِی الإلَہُ وَیَقْضِی بِالْکِتَابِ خَطِیبُہَا\n\nوقال :\n\nفشَیَّب رَأْسِی وَاسْتَخَفَّ حَلومَنَا رُعُودُ الْمَنَایَا حَوْلَہَا وَبُرُوقُہَا\n\nوَإِنَّا لَتَسْتَحْلِی الْمَنَایَا نُفُوسُنَا وَنَتْرُکُ أُخْرَی مَرَّۃً مَا نَذُوقُہَا\n\nقالَ عَامِرٌ : فَحُدِّثَ بِہَذَا الْحَدِیثِ عَبْدُ اللَّہُ بْنُ جَعْفَرٍ ، فقَالَ : کُنَّا نَحْنُ أَحَقَّ بِہَذِہِ الأَبْیَاتِ مِنْ ہَمَدَانَ۔",,,26577 26578,"حَدَّثَنَا یَزِیدُ ، قَالَ : أَخْبَرَنَا عَبْدُ الْمَلِکِ بْنُ قُدَامَۃَ الْجُمَحِیُّ ، قَالَ : حَدَّثَنِی عُمَر بْنُ شُعَیْبٍ ، أَخو عَمْرُو بْنُ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، قَالَ : لَمَّا رَفَعَ النَّاسُ أَیْدِیَہُمْ مِنْ صِفِّینَ ، قَالَ عَمْرُو بْنُ الْعَاصِ :\n\nشَبَّتِ الْحَرْبُ فَأَعْدَدْت لَہَا\n\nیَصِلُ الشَّدَّ بِشَدٍّ فَإِذَا\n\nجُرْشُعٌ أَعْظَمُہُ جُفْرَتْہُ\n\nمُفْرَعَ الْحَارِکِ ملویَّ الثبج\n\nونت الْخَیْلُ مِنَ الشد مَعَجْ\n\nفَإِذَا ابْتَلَّ مِنَ الْمَائِ حدج\n\nقالَ : وَقَالَ عَبْدُ اللہِ بْنُ عَمْرٍو :\n\nلَوْ شَہِدْت جَمَلٌ مَقَامِی وَمَشْہَدِی\n\nبِصِفِّینَ یَوْمًا شَابَ مِنْہَا الذَّوَائِبُ\n\nغَدَاۃَ أَتَی أَہْلُ الْعِرَاقِ کَأَنَّہُمْ\n\nوَجِئْنَاہُمْ بِرَدًی کَأَنَّ صُفُوفَنَا\n\nوَدَارَتْ رَحَانَا وَاسْتَدَارَتْ رَحَاہُمْ\n\nإذَا قُلْتَ قَدْ وَلَّوْا سِرَاعًا بَدَتْ لَنَا\n\nفَقَالُوا لَنَا إنَّا نَرَی أَنْ تُبَایِعُوا\n\nسَحَابُ رَبِیعٍ رفَّعتہ الْجَنَائِبُ\n\nمِنَ الْبَحْرِ مَدُّ مَوْجُہِ مُتَرَاکِبُ\n\nسَرَاۃَ النَّہَار مَا تُوَالّی الْمَنَاکِبُ\n\nکَتَائِبُ مِنْہُمْ فَارْجَحَنَّتْ کَتَائِبُ\n\nعَلِیًّا فَقُلْنَا بَلْ نَرَی أَنْ تُضَارَبُوا",,,26578 26579,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَن حَمْزَۃَ أَبِی عِمَارَۃَ ، قَالَ : قَالَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ لِعُبَیْدِ اللہِ بْنِ عَبْدِ اللہِ بْنِ عُتْبَۃَ : مَالَک وَلِلشِّعْرِ ؟ قَالَ : وَہَلْ یَسْتَطِیعُ الْمَصْدُورُ إلاَّ أَنْ یَنْفُثَ۔",,,26579 26580,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَن مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنِ الزُّہْرِیِّ ، قَالَ : کنت إذَا لَقِیت عُبَیْدَ اللہِ بْنَ عَبْدِ اللہِ فَکَأَنَّمَا أُفَجِّرُ بِہِ بَحْرًا۔",,,26580 26581,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنِ الْوَلِیدِ بْنِ جُمَیْعٍ ، عَنْ أَبِی سَلَمَۃَ ، قَالَ : لَمْ یَکُنْ أَصْحَابُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مُتَحَزِّقین ، وَلاَ مُتَمَاوِتِینَ ، وَکَانُوا یَتَنَاشَدُونَ الشِّعْرَ فِی مَجَالِسِہِمْ ، وَیَذْکُرُونَ أمْرَ جَاہِلِیَّتِہِمْ ، فَإِذَا أُرِیدَ أَحَدُہُمْ عَلَی شَیْئٍ مِنْ دِینِہِ دَارَتْ حَمَالِیقُ عَیْنَیْہِ کَأَنَّہُ مَجْنُونٌ۔",,,26581 26582,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنِ ابْنِ شُبْرُمَۃَ ، قَالَ : سَمعتہ یَقُول کَانَ الفَرَزْدَق مِن أَشْعَر النَّاس۔",,,26582 26583,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنِ أَبی سُفیَان السَّعدِی ، قَالَ : سَمِعْتُ الْحَسَنَ یَتَمَثَّلُ ہَذَا الْبَیْتَ :\n\nیَسُرُّ الْفَتَی مَا کَانَ قَدَّمَ مِنْ تُقًی إذَا عَرَفَ الدَّائَ الَّذِی ہُوَ قَاتِلُہْ۔",,,26583 26584,"حَدَّثَنَا مُحَمَّدُ بْنُ الْحَسَنِ ، قَالَ : حدَّثَنَا أَبُو عَوَانَۃَ ، عَنْ إبْرَاہِیمَ بْنِ مُہَاجِرٍ ، عَنْ عَامِرٍ ، عَنْ عَائِشَۃَ ، قَالَتْ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا اسْتَرَاثَ الْخَبَرَ تَمَثَّلَ بِبَیْتِ طَرَفَۃَ : وَیَأْتِیک بِالأَخْبَارِ مَنْ لَمْ تُزَوِّدْ۔",,,26584 26585,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ، قَالَ: أَخْبَرَنَا ابْنُ عُیَیْنَۃَ، عَنْ عَبْدِالرَّحْمَنِ، عَنْ أَبِیہِ، قَالَ: کُنْتُ أُجَالِسُ أَصْحَابَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَعَ أَبِی فِی الْمَسْجِدِ فَیَتَنَاشَدُونَ الأَشْعَارَ ، وَیَذْکُرُونَ حَدِیثَ الْجَاہِلِیَّۃِ۔",,,26585 26586,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا شَرِیکٌ ، عَن سِمَاکِ بْنِ حَرْبٍ ، عَنْ جَابِرِ بْنِ سَمُرَۃَ ، قَالَ : کُنَّا نَأْتِی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَیَجْلِسُ أَحَدُنَا حَیْثُ یَنْتَہِی، وَکَانُوا یَتَذَاکَرُونَ الشِّعْرَ وَحَدِیثَ الْجَاہِلِیَّۃِ عِنْدَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَلاَ یَنْہَاہُمْ ، وَرُبَّمَا تَبَسَّمَ۔",,,26586 26587,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا شُعْبَۃُ ، عَن قَتَادَۃَ ، عَن مُطَرِّفٍ ، قَالَ : صَحِبْت عِمْرَانَ بْنَ حُصَیْنٍ فِی سَفَرٍ ، فَمَا کَانَ یَوْمٌ إلاَّ یُنْشِدُ فِیہِ شِعْرًا۔",,,26587 26588,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا ہِشَامٌ ، قَالَ : سَأَلَ رَجُلٌ مُحَمَّدًا وَہُوَ فِی الْمَسْجِدِ وَالرَّجُلُ یُرِیدُ أَنْ یُصَلِّیَ : أَیَتَوَضَّأُ مَنْ یُنْشِدُ الشِّعْرَ ؟ وَیُنْشِدُ الشِّعْرَ فِی الْمَسْجِدِ ؟ قَالَ : وَأَنْشَدَہُ أَبْیَاتًا مِنْ شِعْرِ حَسَّانَ ذَلِکَ الرَّقِیقِ ، ثُمَّ افْتَتَحَ الصَّلاَۃَ۔",,,26588 26589,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَن حَمَّادِ بْنِ زَیْدٍ ، عَنْ عَلِیِّ بْنِ زَیْدِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی بَکْرَۃَ ، عَنِ الأَسْوَدِ بْنِ سَرِیعٍ ، قَالَ : قُلْتُ : یَا رَسُولَ اللہِ ، إنِّی مَدَحْت اللَّہَ مَدْحَۃً وَمَدَحْتُک أُخْرَی ، قَالَ : ہَاتِ , وَابْدَأْ بِمَدْحِکَ اللَّہَ۔",,,26589 26590,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا دَیْلَمُ بْنُ غَزْوَانَ ، قَالَ : حَدَّثَنَا ثَابِتٌ ، عَنْ أَنَسٍ ، قَالَ : حَضَرَتْ حَرْبًا فَقَالَ عَبْدُ اللہِ بْنُ رَوَاحَۃَ :\n\nیَا نَفْسُ أَلاَ أَرَاک تَکْرَہِینَ الْجَنَّۃَ أَحْلِفُ بِاَللَّہِ لَتَنْزِلَنَّہْ طَائعۃ أَو لَتکرہِنَّہ",,,26590 26591,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ عَلِیِّ بْنِ زَیْدِ بْنِ جُدْعَانَ ، عَنِ الْقَاسِمِ ، عَنْ عَائِشَۃَ ، قَالَتْ : تَمَثَّلْت بِہَذَا الْبَیْتِ ، وَأَبُو بَکْرٍ یَقْضِی :\n\nوَأَبْیَضُ یُسْتَسْقَی الْغَمَامُ بِوَجْہِہِ ثِمَالْ الْیَتَامَی عِصْمَۃٌ لِلأََرَامِلِ\n\nفَقَالَ أَبُو بَکْرٍ : ذَاکَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,26591 26592,"حَدَّثَنَا مُعْتَمِرٌ ، عَن مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، أَنَّ رسول اللہ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لَمْ یَقُلْ شَیْئًا مِنَ الشِّعْرِ إلاَّ قَدْ قِیلَ لہ إلاَّ ہَذَا :\n\nہَذَا الْحِمَالُ لاَ حِمَالُ خَیْبَرْ ہَذَا أَبَرَّ رَبَّنَا وَأَطْہَرْ",,,26592 26593,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْبَرَائِ ، قَالَ : رَأَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَوْمَ الْخَنْدَقِ ، وَکَانَ کَثِیرَ شَعْرِ الصَّدْرِ وَہُوَ یَرْتَجِزُ بِرَجَزِ عَبْدِ اللہِ بْنِ رَوَاحَۃَ وَہُوَ یَقُولُ :\n\nاللَّہُمَّ لَوْلاَ أَنْتَ مَا اہْتَدَیْنَا\n\nوَلاَ تَصَدَّقْنَا وَلاَ صَلَّیْنَا\n\nفَأَنْزِلَنْ سَکِینَۃً عَلَیْنَا\n\nوَثَبِّتِ الأَقْدَامَ إِنْ لاَقَیْنَا\n\nإنَّ الأُلَی قَدْ بَغَوْا عَلَیْنَا\n\nوَإِنْ أَرَادُوا فِتْنَۃً أَبَیْنَا",,,26593 26594,"حَدَّثَنَا شَرِیکٌ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْبَرَائِ ، قَالَ : مَا وَلَّی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ دُبُرَہُ یَوْمَ حُنَیْنٍ ، قَالَ : وَالْعَبَّاسُ ، وَأَبُو سُفْیَانَ آخِذَانِ بِلِجَامِ بَغْلَتِہِ وَہُوَ یَقُولُ :\n\nأَنَا النَّبِیُّ لاَ کَذِبْ أَنَا ابْنُ عَبْدِ الْمُطَّلِبْ",,,26594 26595,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ الأَسْوَدِ بْنِ قَیْسٍ ، عَن جُنْدَبِ بْنِ سُفْیَانَ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ فِی غَارٍ فَنُکِبَ فَقَالَ :\n\nہَلْ أَنْتِ إلاَّ إصْبَعٌ دُمِیتِ وَفِی سَبِیلِ اللہِ مَا لَقِیتِ۔",,,26595 26596,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا حُمَیْدٌ ، عَنْ أَنَسٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ :\n\nإنَّ الْعَیْشَ عَیْشُ الآخِرَہْ فَاغْفِرْ لِلأََنْصَارِ وَالْمُہَاجِرَہْ",,,26596 26597,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَبِی الْمُعَلَّی ، عَن سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّہُ کَانَ یَقْرَأُ (دَارَسْت) وَیَقُولُ : دَارِسٌ کَطَعْمِ الصَّابِ وَالْعَلْقَمِ۔",,,26597 26598,"حَدَّثَنَا وَکِیعٌ ، عَن ثَابِتٍ بْنِ أَبِی صَفِیَّۃَ ، عَن شَیْخٍ یُکَنَّی أَبَا عَبْدِ الرَّحْمَنِ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : الزَّنِیمُ : اللَّئِیمُ الْمُلْزِقُ ، ثُمَّ أَنْشَدَ ہَذَا الْبَیْتَ :\n\nزَنِیمٌ تَدَاعَاہُ الرِّجَالُ زِیَادَۃً کَمَا زِیدَ فِی عَرْضِ الأَدِیمِ الأَکَارِعُ",,,26598 26599,"حَدَّثَنَا مَالِکُ بْنُ إسْمَاعِیلَ ، قَالَ : أَخْبَرَنَا مَسْعُودُ بْنُ سَعْدٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنِ ابْنِ عِبَادٍ ، عَنْ أَبِیہِ ، أَنَّ رَجُلاً مِنْ بَنِی لَیْثٍ أَتَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقَالَ : یَا رَسُولَ اللہِ ، أُنْشِدُک ؟ قَالَ : لاَ ، فَأَنْشَدَہُ فِی الرَّابِعَۃِ مَدْحَۃً لَہُ فَقَالَ : إِنْ کَانَ أَحَدٌ مِنَ الشُّعَرَائِ یُحْسِنُ ، فَقَدْ أَحْسَنْت۔",,,26599 26600,"حَدَّثَنَا وَکِیعٌ ، عَن مِسْعَرٍ ، عَن قَتَادَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : مَا کُنْت أَدْرِی مَا قَوْلُہُ : {رَبَّنَا افْتَحْ بَیْنَنَا وَبَیْنَ قَوْمِنَا بِالْحَقِّ} حَتَّی سَمِعْت بِنْتَ ذِی یَزَنٍ تَقُولُ : تَعَالَی أُفَاتِحْک۔",,,26600 26601,حَدَّثَنَا أَحْمَدُ بْنُ بِشْرٍ، عَن مُجَالِدٍ، عَنْ عَامِرٍ، أَنَّ ابْنَ الزُّبَیْرِ اسْتَنْشَدَ أَبْیَاتَ خَالِدٍ وَہُوَ یَطُوفُ بِالْبَیْتِ۔,,,26601 26602,"حَدَّثَنَا جَعْفَرُ بْنُ عَوْنٍ ، عَن ہِشَامِ بْنِ عُرْوَۃَ ، قَالَ : کَانَ ابْنُ الزُّبَیْرِ یَحْمِلُ عَلَیْہِمْ حَتَّی یُخْرِجَہُمْ مِنَ الأَبْوَابِ وَیَقُولُ : لَوْ کَانَ قَرْنِی وَاحِدًا کَفَیْتہ ؛\n\nویقول:\n\nولَسْنَا عَلَی الأَعْقَابِ تَدْمَی کُلُومُنَا وَلَکِنْ عَلَی أَقْدَامِنَا تَقْطُرُ الدِّما",,,26602 26603,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حدَّثَنَا ہِشَامٌ ، عَنْ أَبِیہِ ، أَنَّ أَہْلَ الشَّامِ کَانُوا یُقَاتِلُونَ ابْنَ الزُّبَیْرِ وَیَصِیحُونَ بِہِ : یَا ابْنَ ذَاتِ النِّطَاقَیْنِ ، فَقَالَ : ابْنُ الزُّبَیْرِ :\n\nوتِلْکَ شَکَاۃٌ ظَاہِرٌ عَنک عَارُہَا\n\nفَقَالَتْ أَسْمَائُ : عَیَّرُوک بِہِ ؟ قَالَ : نَعَمْ ، قَالَتْ : فَہُوَ وَاللَّہِ حَقٌ۔",,,26603 26604,حَدَّثَنَا وَکِیعٌ ، عَن سُفْیَانَ ، عَن رَجُلٍ ، أَنَّ ابْنَ الزُّبَیْرِ کَانَ یُنْشِدُ الشِّعْرَ وَہُوَ یَطُوفُ بِالْبَیْتِ۔,,,26604 26605,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَن دَاوُد ، أَنَّ سَعِیدَ بْنَ الْمُسَیَّبِ ، قَالَ : لاَ تَطْلُعُ الشَّمْسُ حَتَّی یَصْحَبَہَا ثَلاَثُ مِئَۃِ مَلَکٍ وَسَبْعُونَ مَلَکًا ، أَمَا سَمِعْت أُمَیَّۃَ بْنَ أَبِی الصَّلْتِ یَقُولُ :\n\nلَیْسَتْ بِطَالِعَۃٍ لَنَا فِی رِسْلِہَا إلاَ مُعَذَّبَۃً وَإِلاَّ تُجْلَدُ",,,26605 26606,"حَدَّثَنَا حَفْصٌ، عَن مُجَالِدٍ، عَنِ الشَّعْبِیِّ، قَالَ: کَانَ یَکْرَہُ أَنْ یَکْتُبَ أَمَامَ الشِّعْرِ بِسْمِ اللہِ الرَّحْمَن الرَّحِیمِ۔",,,26606 26607,"حَدَّثَنَا حَفْصٌ ، وَأَبُو مُعَاوِیَۃَ ، وَوَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لأَنْ یَمْتَلِئَ جَوْفُ الرَّجُلِ قَیْحًا حَتَّی یَرِیہِ ، خَیْرٌ لَہُ مِنْ أَنْ یَمْتَلِئَ شِعْرًا ، إلاَّ أَنْ حَفْصًا لَمْ یَقُلْ : جوف۔",,,26607 26608,"حَدَّثَنَا یُونُسُ بْنُ مُحَمَّدٍ ، قَالَ : حدَّثَنَا لَیْثُ بْنُ سَعْدٍ ، عَن سَعِیدِ بْنِ عَبْدِ اللہِ ، عَن یُحَنَّسَ مَوْلَی مُصْعَبِ بْنِ الزُّبَیْرِ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ، قَالَ : بَیْنَمَا نَحْنُ عِنْدَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بالعرج إذْ عَرَضَ شَاعِرٌ یُنْشِدُ فَقَالَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: خُذُوا الشَّیْطَانَ أَوِ أَمْسِکُوا الشَّیْطَانَ لأَنْ یَمْتَلِئَ جَوْفُ الرَّجُلِ قَیْحًا خَیْرٌ لَہُ مِنْ أَنْ یَمْتَلِئَ شِعْرًا۔ (بخاری 3588۔ مسلم 1769)",,,26608 26609,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَن حَنْظَلَۃَ ، عَن سَالِمٍ ، عَنْ أَبِیہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لأَنْ یَمْتَلِئَ الرَّجُلُ قَیْحًا خَیْرٌ لَہُ مِنْ أَنْ یَمْتَلِئَ شِعْرًا۔ (بخاری 6154۔ احمد 2/96)",,,26609 26610,"حَدَّثَنَا وَکِیعٌ ، عَن سُفْیَان ، عَن سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنْ أَبِی الزَّعْرَائِ ، قَالَ : قَالَ عَبْدُ اللہِ : لأَنْ یَمْتَلِئَ جَوْفُ الرَّجُلِ قَیْحًا خَیْرٌ مِنْ أَنْ یَمْتَلِئَ شِعْرًا۔",,,26610 26611,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا غُنْدَرٌ ، عَن شُعْبَۃَ ، عَن سَعْدِ بْنِ إِبْرَاہِیمَ ، عَن أَبِیہِ ، عَن عُثْمَانَ ، قَالَ : لأَنْ یَمْتَلِئَ جَوْفُ الرَّجُلِ قَیْحًا خَیْرٌ لَہُ مِنْ أَنْ یَمْتَلِئَ شِعْرًا۔",,,26611 26612,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَن ہِشَامِ بْنِ عَائِذٍ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : لأَنْ یَمْتَلِئَ جَوْفُ الرَّجُلِ قَیْحًا خَیْرٌ مِنْ أَنْ یَمْتَلِئَ شِعْرًا۔",,,26612 26613,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنْ عَمْرِو بْنِ حُرَیْثٍ ، قَالَ : قَالَ عُمَر : لأَنْ یَمْتَلِئَ جَوْفُ الرَّجُلِ قَیْحًا خَیْرٌ لَہُ مِنْ أَنْ یَمْتَلِئَ شِعْرًا۔",,,26613 26614,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی الضُّحَی ، عَن مَسْرُوقٍ ، أَنَّہُ تَمَثَّلَ مَرَّۃً بِبَیْتِ شِعْرٍ فَسَکَتَ عَن آخِرِہِ وَقَالَ : إنِّی لأَکْرَہُ أَنْ یُکْتَبَ فِی صَحِیفَتِی بَیْتُ شِعْرٍ۔",,,26614 26615,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا الأَسْوَدُ بْنُ شَیْبَانَ ، قَالَ : حَدَّثَنَا أَبُو نَوْفَلِ بْنُ أَبِی عَقْرَبٍ ، قَالَ : سَأَلْتُ عَائِشَۃَ : ہَلْ کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُتسَامَعُ عَندَہُ الشِّعْرُ ، قَالَتْ : کَانَ أَبْغَضَ الْحَدِیثِ إلَیْہِ۔ (ابوداؤد 1477۔ احمد 134)",,,26615 26616,"حَدَّثَنَا غُنْدَرٌ ، عَن شُعْبَۃَ ، عَنِ الْعَوَّامِ ، عَنْ إبْرَاہِیمَ، قَالَ: کَانُوا یَکْرَہُونَ مِنَ الشِّعْرِ مَا ضَاہَی الْقُرْآنَ۔",,,26616 26617,"حَدَّثَنَا الأَسْوَدُ بْنُ عَامِرٍ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَن قَتَادَۃَ ، عَن یُونُسَ بْنِ جُبَیْرٍ ، عَن مُحَمَّدِ بْنِ سَعْدٍ ، عَن سَعْدٍ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لأَنْ یَمْتَلِئَ جَوْفُ أَحَدِکُمْ قَیْحًا یَرِیہِ ، خَیْرٌ لَہُ مِنْ أَنْ یَمْتَلِئَ شِعْرًا۔ (مسلم 1769۔ احمد 1/175)",,,26617 26618,"حَدَّثَنَا عَبْدُ اللہِ بْنُ بَکْرٍ السَّہْمِیُّ ، قَالَ : سَمِعْتُ حَبِیبَ بْنَ شَہِیدٍ یَذْکُرُ ، عَن مُعَاوِیَۃَ بْنِ قُرَّۃَ ، أَنَّ عُمَرَ بْنَ الْخَطَّابِ قَالَ : مَا یَسُرُّنِی أَنَّ لِی بِمَا أَعْلَمُ مِنْ مَعَارِیضِ الْقَوْلِ مِثْلَ أَہْلِی وَمَالِی ، أَوَلاَ یَحسَبُون أَنِّی أَوَدُّ أَنَّ لِی مِثل أَہلِی وَمالِی وَددتُ أَنَّ لِی مِثل أَہلِی وَمالِی ، ثُمَّ مِثْلَ أَہْلِی وَمَالِی ۔",,,26618 26619,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی عُثْمَانَ ، قَالَ : قَالَ عُمَرُ : إنَّ فِی الْمَعَارِیضِ مَا یَکُفُّ ، أَوْ یَعِفُّ الرَّجُلَ عَنِ الْکَذِبِ۔",,,26619 26620,"حَدَّثَنَا عُقْبَۃُ بْنُ خَالِدٍ ، عَن شُعْبَۃَ ، عَن قَتَادَۃَ ، عَن مُطَرِّفِ بْنِ عَبْدِ اللہِ بْنِ الشِّخِّیرِ ، عَن عِمْرَانَ بْنِ حُصَیْنٍ ، قَالَ : إنَّ فِی الْمَعَارِیضِ لَمَنْدُوحَۃً عَنِ الْکَذِبِ۔ (ابن عدی 49۔ بیہقی 199)",,,26620 26621,"حَدَّثَنَا جَرِیرٌ ، عَن مَنْصُورٍ ، قَالَ : بَلَغَنِی عَنِ ابْنِ عَبَّاسٍ ، أَنَّہُ قَالَ : مَا أُحِبُّ لِی بِالْمَعَارِیضِ کَذَا وَکَذَا۔",,,26621 26622,"حَدَّثَنَا جَرِیرٌ ، عَن مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ لَہُمْ کَلاَمٌ یَتَکَلَّمُونَ بِہِ یَدْرَؤُونَ بِہِ عنْ أَنْفُسِہِمْ مَخَافَۃَ الْکَذِبِ۔",,,26622 26623,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَن حَبِیبِ بْنِ شَہِیدٍ ، عَنْ عَمْرِو بْنِ سَعِیدٍ ، قَالَ : قَالَ حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ : مَا أُحِبُّ أَنَّ لِی بِنَصِیبِی مِنَ الْمَعَارِیضِ مِثْلَ أَہْلِی وَمَالِی ، وَلَعَلَّکُمْ تَرَوْنَ أَنِّی لاَ أُحِبُّ أَنَّ لِی مِثْلَ أَہْلِی وَمَالِی، وَوَدِدْت أَنَّ لِی مِثْلَ أَہْلِی وَمَالِی۔",,,26623 26624,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الْعَلاَئِ بْنِ الْمُسَیَّبِ ، عَنْ أَبِیہِ ، قَالَ : لاَ تَقُلْ لِصَاحِبِکَ یَا حِمَارُ ، یَا کَلْبُ ، یَا خِنْزِیرُ ، فَیَقُولَ لَکَ یَوْمَ الْقِیَامَۃِ : أَتَرَانِی خُلِقْت کَلْبًا ، أَوْ حِمَارًا ، أَوْ خِنْزِیرًا ؟۔",,,26624 26625,"حَدَّثَنَا جَرِیرٌ ، عَن لَیْثٍ ، عَن مُجَاہِدٍ ، قَالَ : اسْتَسْقَی مُوسَی لِقَوْمِہِ فَقَالَ : اشْرَبُوا یَا حَمِیرُ ، قَالَ : فَقَالَ اللَّہُ لَہُ : لاَ تُسَمِّ عِبَادِی حَمِیرًا۔",,,26625 26626,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یَقُولُونَ : إذَا قَالَ الرَّجُلُ لِلرَّجُلِ : یَا حِمَارُ یَا کَلْبُ یَا خِنْزِیرُ ، قَالَ لَہُ یَوْمَ الْقِیَامَۃِ : أَتَرَانِی خَلَقْتُہ کَلْبًا ، أَوْ حِمَارًا ، أَوْ خِنْزِیرًا ؟۔",,,26626 26627,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ، عَن دَاوُد بْنِ أَبِی ہِنْدٍ، عَن بَکْرِ بْنِ عَبْدٍالْمُزَنِیّ، عَنْ عَلْقَمَۃَ بْنِ عَبْدِاللہِ، أَنَّ ابْنَ عُمَرَ قَالَ لِرَجُلٍ کَلَّمَ صَاحِبَہُ یَوْمَ الْجُمُعَۃِ وَالإِمَامُ یَخْطُبُ : أَمَّا أَنْتَ فَحِمَارٌ ، وَأَمَّا صَاحِبُک فَلاَ جُمُعَۃَ لَہُ۔",,,26627 26628,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنْ أَبِی عُثْمَانَ ، عَن سَعْدٍ ، وَأَبِی بَکْرَۃَ ، کِلاَہُمَا یَقُولُ : سَمِعَتْہ أُذُنَایَ ، وَوَعَاہُ قَلْبِی مُحَمَّدًا صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : مَنِ ادَّعَی إلَی غَیْرِ أَبِیہِ ، وَہُوَ یَعْلَمُ أَنَّہُ غَیْرُ أَبِیہِ ، فَالْجَنَّۃُ عَلَیْہِ حَرَامٌ۔ (مسلم 115۔ ابن ماجہ 2610)",,,26628 26629,"حَدَّثَنَا غُنْدَرٌ ، عَن شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَن مُجَاہِدٍ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ، رَفَعَہُ ، قَالَ : مَنِ ادَّعَی إلَی غَیْرِ أَبِیہِ فَلَنْ یَرِیحَ رِیحَ الْجَنَّۃِ ، فَلَمَّا رَأَی ذَلِکَ نُعَیْمُ بْنُ أَبِی أُمَیَّۃَ ، وَکَانَ مُعَاوِیَۃُ أَرَادَ أَنْ یَدَّعِیَہُ ، قَالَ لِمُعَاوِیَۃَ : إنَّمَا أَنَا سَہْمٌ مِنْ کِنَانَتِکَ ، فَاقْذِفْنِی حَیْثُ شِئْت۔ (ابن ماجہ 2611۔ احمد 171)",,,26629 26630,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا مُحَمَّدُ بْنُ عَمْرٍو ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ تَوَلَّی غَیْرَ مَوَالِیہِ فَعَلَیْہِ لَعَنَۃُ اللہِ وَالْمَلاَئِکَۃِ وَالنَّاسِ أَجْمَعِینَ۔\n\n(مسلم 1146۔ ابوداؤد 5073)",,,26630 26631,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا سَعِیدُ بْنُ أَبِی عَرُوبَۃَ ، عَن قَتَادَۃَ ، عَن شَہْرِ بْنِ حَوْشَبٍ ، عَنْ عَبْدٗ الرَّحْمَنِ بْنِ غَنْمٍ ، عَنْ عَمْرِو بْنِ خَارِجَۃَ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ خَطَبَہُمْ وَہُوَ عَلَی رَاحِلَتِہِ ، وَإِنَّ رَاحِلَتَہُ لَتَقْصَعُ بِجَرَّتِہَا ، وَإِنَّ لُعَابَہَا یَسِیلُ بَیْنَ کَتِفَیَّ فَقَالَ : مَنِ ادَّعَی إلَی غَیْرِ أَبِیہِ ، أَوْ تَوَلَّی غَیْرَ مَوَالِیہِ فَعَلَیْہِ لَعَنَۃُ اللہِ ، لاَ یُقْبَلُ مِنْہُ صَرْفٌ ، وَلاَ عَدْلٌ ، أَوْ قَالَ : عَدْلٌ ، وَلاَ صَرْفٌ۔",,,26631 26632,"حَدَّثَنَا شَبَابَۃُ ، قَالَ : حدَّثَنَا ابْنُ أَبِی ذِئْبٍ ، عَنِ الْحَارِثِ ، عَنْ أَبِی سَلَمَۃَ ، عَن سَعِیدِ بْنِ زَیْدٍ ، قَالَ : أَشْہَدُ عَلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سَمِعْتہ یَقُولُ : مَنْ تَوَلَّی مَوْلًی بِغَیْرِ إذْنِہِ فَعَلَیْہِ لَعَنَۃُ اللہِ۔",,,26632 26633,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنِ الأَعْمَشِ ، عَنْ عَبْدِ اللہِ بْنِ مُرَّۃَ ، عَنْ أَبِی مَعْمَرٍ ، قَالَ : قَالَ أَبُو بَکْرٍ : کَفَرَ بِاللَّہِ مَنِ ادَّعَی نَسَبًا لاَ یُعْلَمُ ، وَتَبَرَّأَ مِنْ نَسَبٍ ، وَإِنْ دَقَّ۔ (دارمی 2863۔ احمد 215)",,,26633 26634,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَن شُرَحْبِیلَ بْنِ مُسْلِمٍ ، قَالَ : سَمِعْتُ أَبَا أُمَامَۃَ الْبَاہِلِیَّ یَقُولُ : سَمِعْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : مَنِ ادَّعَی إلَی غَیْرِ أَبِیہِ وَانْتَمَی إلَی غَیْرِ مَوَالِیہِ ، فَعَلَیْہِ لَعَنَۃُ اللہِ التَّابِعَۃ إلَی یَوْمِ الْقِیَامَۃِ۔ (ترمذی 2120۔ ابوداؤد 2862)",,,26634 26635,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا وُہَیْبٌ ، عَنْ عَبْدِ اللہِ بْنِ عُثْمَانَ ، عَن سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : مَنِ ادَّعَی إلَی غَیْرِ أَبِیہِ ، أَوْ تَوَلَّی غَیْرَ مَوَالِیہِ ، فَعَلَیْہِ لَعَنَۃُ اللہِ وَالْمَلاَئِکَۃِ وَالنَّاسِ أَجْمَعِینَ۔ (احمد 1/328۔ ابویعلی 2540)",,,26635 26636,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَاصِمٍ ، عَن زِرٍّ ، قَالَ : أَتَیْتُ صَفْوَانَ بْنَ عَسَّالٍ الْمُرَادِیَّ فَقَالَ لِی : مَا جَائَ بِکَ ؟ فَقُلْت : ابْتِغَائَ الْعِلْمِ ، قَالَ : فَإِنَّ الْمَلاَئِکَۃَ تَضَعُ أَجْنِحَتَہَا لِطَالِبِ الْعِلْمِ۔",,,26636 26637,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَن شِمْرِ ، عَن سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : مُعَلِّمُ الْخَیْرِ یَسْتَغْفِرُ لَہُ کُلُّ شَیْئٍ حَتَّی الْحُوتُ فِی الْبَحْرِ۔ (دارمی 343۔ عبدالبر 180)",,,26637 26638,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَن ہَارُونَ بْنِ عَنتَرَۃَ ، عَنْ أَبِیہِ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : مَا یسْلُک رَجُلٌ طَرِیقًا یَلْتَمِسُ فِیہَا الْعِلْمَ إلاَّ سَہَّلَ اللَّہُ لَہُ طَرِیقًا إلَی الْجَنَّۃِ۔ (ابوداؤد 3638۔ دارمی 345)",,,26638 26639,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَمْرِو بْنِ قَیْسٍ الْمُلاَئِیِّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : فَضْلُ الْعِلْمِ خَیْرٌ مِنْ فَضْلِ الْعِبَادَۃِ ، وَمِلاَکُ دِینِکُمُ الْوَرَعُ۔ (حاکم 92۔ بزار 2969)",,,26639 26640,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ، عَنِ الأَحْنَفِ ، قَالَ : قَالَ عُمَرُ : تَفَقَّہُوا قَبْلَ أَنْ تُسَوَّدُوا۔ (دارمی 250)",,,26640 26641,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ سَلَکَ طَرِیقًا یَلْتَمِسُ فِیہِ عِلْمًا ، سَہَّلَ اللَّہُ لَہُ طَرِیقًا إلَی الْجَنَّۃِ۔\n\n(مسلم 2074۔ ابوداؤد 3638)",,,26641 26642,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَن لَیْثٍ ، عَن طَاوُوس ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : مَنْہُومَانِ لاَ یَشْبَعَانِ : طَالِبُ عِلْمٍ وَطَالِبُ دُنْیَا۔ (دارمی 334)",,,26642 26643,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَن شَقِیق ، عَنْ عَبْدِ اللہِ ، قَالَ : تَعَلَّمُوا ، فَإِنَّ أَحَدَکُمْ لاَ یَدْرِی مَتَی یُخْتل إلَیْہِ۔",,,26643 26644,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَن تَمِیمِ بْنِ سَلَمَۃَ ، عَنْ أَبِی عُبَیْدَۃَ ، قَالَ : قَالَ عَبْدُ اللہِ : اغْدُ عَالِمًا ، أَوْ مُتَعَلِّمًا ، وَلاَ تَغْدُ بَیْنَ ذَلِکَ۔",,,26644 26645,"حَدَّثَنَا وَکِیعٌ ، عَن مِسْعَرٍ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَن سَالِمِ بْنِ أَبِی الْجَعْدِ ، قَالَ : قَالَ أَبُو الدَّرْدَائِ : تَعَلَّمُوا قَبْلَ أَنْ یُرْفَعَ الْعِلْمُ ، فَإِنَّ الْعَالِمَ وَالْمُتَعَلِّمَ فِی الأَجْرِ سَوَائٌ۔",,,26645 26646,"حَدَّثَنَا ابْنُ فُضَیْلٍ، عَنِ الأَعْمَشِ، عَن سَالِمٍ، قَالَ: قَالَ أَبُو الدَّرْدَائِ: مُعَلِّمُ الْعِلْمِ وَمُتَعَلِّمُہُ فِی الأَجْرِ سَوَائٌ۔",,,26646 26647,"حَدَّثَنَا وَکِیعٌ ، عَن سُفْیَانَ ، عَنْ أَبِی الزَّعْرَائِ ، عَنْ أَبِی الأَحْوَصِ ، قَالَ : قَالَ عَبْدُ اللہِ : إنَّ الرَّجُلَ لاَ یُولَدُ عَالِمًا ، وَإِنَّمَا الْعِلْمُ بِالتَّعَلُّمِ۔",,,26647 26648,حَدَّثَنَا دَاوُد ، عَن سُفْیَانَ ، عَنْ عَلِیِّ بْنِ الأَقْمَرِ ، عَنْ أَبِی الأَحْوَصِ ، عَنْ عَبْدِ اللہِ مِثْلُہُ۔,,,26648 26649,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا التیمی ، عَن سَیَّارٍ ، عَنْ عَائِذِ اللہِ ، قَالَ : الَّذِی یَتَتَبَّعُ الأَحَادِیثَ لِیُحَدِّثَ بِہَا لاَ یَجِدُ رِیحَ الْجَنَّۃِ۔",,,26649 26650,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَن سُفْیَانَ ، عَن بُرْدٍ ، عَن مَکْحُولٍ ، قَالَ: مَنْ طَلَبَ الْحَدِیثَ لیجاری بِہِ السُّفَہَائَ، أَوْ لِیُمَارِیَ بِہِ الْعُلَمَائَ ، أَوْ لِیَصْرِفَ بِہِ وُجُوہَ النَّاسِ إلَیْہِ ، فَہُوَ فِی النَّارِ۔ (دارمی 374)",,,26650 26651,"حَدَّثَنَا سُرَیْجُ بْنُ النُّعْمَانِ ، قَالَ : حدَّثَنَا فُلَیْحٌ ، عَنْ أَبِی طِوَالَۃَ عَبْدِ اللہِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ مَعْمَرٍ ، عَن سَعِیدِ بْنِ یَسَارٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ تَعَلَّمَ عِلْمًا مِمَّا یُبْتَغَی بِہِ وَجْہُ اللہِ لاَ یَتَعَلَّمُہُ إلاَّ لِیُصِیبَ بِہِ عَرَضًا مِنَ الدُّنْیَا لَمْ یَجِدْ عَرْفَ الْجَنَّۃِ یَوْمَ الْقِیَامَۃِ - یَعْنِی رِیحَہَا۔ (ابوداؤد 3656۔ ابن ماجہ 252)",,,26651 26652,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ أَیُّوبَ ، عَن مُجَالِدٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : مَا عَلِمْت أَحَدًا مِنَ النَّاسِ کَانَ أَطْلَبَ لِلْعِلْمِ فِی أُفُقٍ مِنَ الآفَاقِ مِنْ مَسْرُوقٍ۔",,,26652 26653,حَدَّثَنَا وَکِیعٌ، عَن سُفْیَانَ، عَن رَجُلٍ لَمْ یُسَمِّہِ، أَنَّ مَسْرُوقًا رَحَلَ فِی حَرْفٍ، وَأَنَّ أَبَا سَعِیدٍ رَحَلَ فِی حَرْفٍ۔,,,26653 26654,"حَدَّثَنَا عَلِیُّ بْنُ صَالِحٍ ، عَنْ أَبِیہِ ، قَالَ : حدَّثَنَا الشَّعْبِیُّ بِحَدِیثٍ ، ثُمَّ قَالَ لِی : أَعْطَیْتُکَہُ بِغَیْرِ شَیْئٍ ، وَإِنْ کَانَ الرَّاکِبُ لَیَرْکَبُ إلَی الْمَدِینَۃِ فِیمَا دُونَہُ۔ (بخاری 5083۔ مسلم 241)",,,26654 26655,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَن رَجُلٍ ، قَالَ : قَالَ لِی الشَّعْبِیُّ أحَادِیثٌ أَعْطَیْنَاکہَا بِغَیْرِ شَیْئٍ ، وَإِنْ کَانَ الرَّاکِبُ لَیَرْکَبُ فِیمَا دُونَہَا إلَی الْمَدِینَۃِ۔",,,26655 26656,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَن شُعْبَۃَ ، عَن عُمَارَۃَ ، عَنْ أَبِی مِجْلَزٍ ، عَن قَیْسِ بْنِ عُبَادٍ ، قَالَ : خَرَجْت إلَی الْمَدِینَۃِ أَطْلُبُ الْعِلْمَ وَالشَّرَفَ۔",,,26656 26657,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ جَعْفَرِ بْنِ إیَاسٍ ، عَنْ أَبِی نَضْرَۃَ ، عَنْ أَبِی سَعِیدٍ ، قَالَ : تَحَدَّثُوا ، فَإِنَّ الْحَدِیثَ یَہِیجُ الْحَدِیثَ۔",,,26657 26658,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا کَہْمَسُ بْنُ الْحَسَنِ ، عَنْ عَبْدِ اللہِ بْنِ بُرَیْدَۃَ ، قَالَ : قَالَ عَلِیٌّ : تَزَاوَرُوا وَتَذَاکَرُوا الْحَدِیثَ فَإِنَّکُمْ إِنْ لاَ تَفْعَلُوا یَدْرُسْ۔",,,26658 26659,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا فِطْرٌ ، عَن شَیْخٍ ، قَالَ : سَمِعْتُ عِکْرِمَۃَ یَقُولُ : تَذَاکَرُوا الْحَدِیثَ ، فَإِنَّ إحْیَائَہُ ذِکْرُہُ۔ (دارمی 619)",,,26659 26660,حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنْ إسْمَاعِیلَ بْنِ رَجَائٍ ، أَنَّہُ کَانَ یَأْتِی صِبْیَانَ الْکُتَّابِ فَیَعْرِضُ عَلَیْہِمْ حَدِیثَہُ کَیْ لاَ یَنْسَی۔,,,26660 26661,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عِیسَی بْنُ الْمُسَیَّبِ ، قَالَ : سَمِعْتُ إبْرَاہِیمَ یَقُولُ : إذَا سَمِعْت حَدِیثًا فَحَدِّثْ بہ حِینَ تَسْمَعُہُ ، وَلَوْ أَنْ تُحَدِّثَ بِہ مَنْ لاَ یَشْتَہِیہِ ، فَإِنَّہُ یَکُونُ کَالْکِتَابِ فِی صَدْرِک۔",,,26661 26662,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَن یَزِیدَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، قَالَ : إحْیَائُ الْحَدِیثِ مُذَاکَرَتُہُ ، فَقَالَ لَہُ عَبْدُ اللہِ بْنُ شَدَّادٍ : کَمْ مِنْ حَدِیثٍ قَدْ أَحْیَیْتہ فِی صَدْرِی۔",,,26662 26663,"حَدَّثَنَا وَکِیعٌ ، قَالَ: حدَّثَنَا الأَعْمَشُ ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : آفَۃُ الْعِلْمِ النِّسْیَانُ، وَإِضَاعَتُہُ أَنْ تُحَدِّثَ بِہِ غَیْرَ أَہْلِہِ۔ (دارمی 624)",,,26663 26664,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی الْعُمَیْسِ ، عَنِ الْقَاسِمِ ، قَالَ : قَالَ عَبْدُ اللہِ : آفَۃُ الْعِلْمِ النِّسْیَانُ۔",,,26664 26665,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، وَأَبُو أُسَامَۃَ ، عَن عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَن نَافِعٍ ، عَن سَعِیدِ بْنِ أَبِی ہِنْدٍ، عَنْ أَبِی مُوسَی، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: مَنْ لَعِبَ بِالنَّرْدِ، فَقَدْ عَصَی اللَّہَ وَرَسُولَہُ۔\n\n(مالک 958۔ احمد 4/394)",,,26665 26666,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، وَأَبُو أُسَامَۃَ ، عَن سُفْیَانَ ، عَنْ عَلْقَمَۃَ بْنِ مَرْثَدٍ ، عَن سُلَیْمَانَ بْنِ بُرَیْدَۃَ ، عَنْ أَبِیہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : مَنْ لَعِبَ بِالنَّرْدَشِیرِ فَکَأَنَّمَا غَمَسَ یَدَہُ فِی لَحْمِ خِنْزِیرٍ وَدَمِہِ۔\n\n(بخاری 1271۔ مسلم 1770)",,,26666 26667,"حَدَّثَنَا وَکِیعٌ ، عَن سُفْیَانَ ، عَنْ عَلْقَمَۃَ بْنِ مَرْثَدٍ ، عَنِ ابْنِ بُرَیْدَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَذَکَرَ مِثْلَہُ۔ (احمد 5/352)",,,26667 26668,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَن قَتَادَۃَ ، قَالَ : بَلَغَنَا أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، سُئِلَ عَنِ اللَّعِبِ بِالْکَعْبَیْنِ فَقَالَ : إِنَّہَا مَیْسِرُ الأَعَاجِمِ ، قَالَ : وَکَانَ قَتَادَۃُ یَکْرَہُ اللَّعِبَ بِکُلِّ شَیْئٍ حَتَّی یَکْرَہَ اللَّعِبَ بِالْعَصَا۔ (احمد 1/446۔ بیہقی 215)",,,26668 26669,"حَدَّثَنَا مُعْتَمِرٌ وَجَرِیرٌ ، عَنِ الرُّکَیْنِ ، عَنِ الْقَاسِمِ بْنِ حَسَّانَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ حَرْمَلَۃَ ، عَنْ عَبْدِ اللہِ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، عَنِ الضَّرْبِ بِالْکِعَابِ۔",,,26669 26670,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَن سَعِیدِ بْنِ أَبِی عَرُوبَۃَ ، عَن قَتَادَۃَ ، عَنْ أَبِی أَیُّوبَ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ، قَالَ : مَثَلُ الَّذِی یَلْعَبُ بِالْکَعْبَیْنِ ، وَلاَ یُقَامِرُ کَمَثَلِ الْمُدَّہِنِ بِشَحْمِہِ ، وَلاَ یَأْکُلُ لَحْمَہُ۔",,,26670 26671,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَن حَبِیبِ بْنِ أَبِی عَمْرَۃَ ، عَن مُجَاہِدٍ ، عَنِ ابْنِ عُمر قَالَ : لأَنْ أَضَعَ یَدِی فِی لَحْمِ خِنْزِیرٍ أَحَبُّ إلَیَّ مِنْ أَنْ أَلْعَبَ بِالنَّرْدِ۔",,,26671 26672,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَن مُحَمَّدِ بْنِ إِسْحَاقَ ، عَن بُرْدِ بْنِ مَعْمَرِ بْنِ یَزِیدَ ، قَالَ : سَأَلْتُ عَائِشَۃَ رضی اللہ عنہا عَنِ النَّرْدَشِیرِ ، قَالَتْ : قَبَّحَ اللَّہُ النَّرْدَشِیرَ وَقَبَّحَ مَنْ لَعِبَ بِہَا۔",,,26672 26673,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ إسْمَاعِیلَ بْنِ سُمَیْعٍ ، قَالَ : حدَّثَنَا أَبُو الأَشْعَثِ النَّخَعِیُّ ، قَالَ : سَمِعْتُ ابْنَ عَبَّاسٍ یَقُولُ : لأَنْ یَتَلَطَّخَ الرَّجُلُ بِدَمِ خِنْزِیرٍ حَتَّی یَسْتَوْسِعَ مِنہ خَیْرٌ لَہُ مِنْ أَنْ یَلْعَبَ بِالْکِعَابِ۔",,,26673 26674,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، قَالَ : قَالَ عَلِیٌّ : النَّرْدُ ، أَوِ الشِّطْرَنْجُ مِنَ الْمَیْسِرِ۔",,,26674 26675,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَن مُحَمَّدِ بْنِ إِسْحَاقَ ، عَن نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : کَانَ إذَا وَجَدَ نَرْدًا فِی بَیْتٍ کَسَّرَہَا وَضَرَبَ مَنْ لَعِبَ بِہَا۔",,,26675 26676,"حَدَّثَنَا وَکِیعٌ ، قَالَ: حدَّثَنَا مِسْعَرٌ وَسُفْیَانُ ، عَنْ عَبْدِالْمَلِکِ بْنِ عُمَیْرٍ، عَنْ أَبِی الأَحْوَصِ، قَالَ سُفْیَانُ: عَنْ عَبْدِ اللہِ ، وَقَصَّرَ بِہِ مِسْعَرٌ : إیَّاکُمْ وَہَذِہِ الْکِعَابَ الْمَوْسُومَۃَ الَّتِی تُزْجَرُ زَجْرًا ، فَإِنَّہَا مِنَ الْمَیْسِرِ۔",,,26676 26677,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا أُسَامَۃَ بْنُ زِید ، عَن سَعِیدِ بْنِ أَبِی ہِنْدٍ سَمِعَہُ مِنْہُ ، عَنْ أَبِی مُوسَی ، قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ لَعِبَ بِالنَّرْدِ ، فَقَدْ عَصَی اللَّہَ وَرَسُولَہُ۔",,,26677 26678,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا سَلاَّمُ بْنُ مِسْکِینٍ، عَن قَتَادَۃَ، عَنْ أَبِی أَیُّوبَ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو، قَالَ: مَنْ لَعِبَ بِالنَّرْدِ قِمَارًا ، کَانَ کَآکِلِ لَحْمِ الْخِنْزِیرِ ، وَمَنْ لَعِبَ بِہَا غَیْرِ قِمَارٍ کَانَ کَالْمُدَّہِنِ بِوَدَکِ الْخِنْزِیرِ۔",,,26678 26679,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا معمر ، عَن بَسَّامٍ ، قَالَ : سَأَلْتُ أَبَا جَعْفَرٍ عَنِ اللَّعِبِ بِالنَّرْدِ فَکَرِہَہُ۔",,,26679 26680,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا کَامِلٌ أَبُو الْعَلاَئِ، قَالَ: سَمِعْتُ صَلْتًا الدِّہَان مُنْذُ أَرْبَعِینَ سَنَۃً، عَنْ عَلِیٍّ، قَالَ: لأَنْ أَطْلِی بِجِوَائِ قِدْرٍ أَحَبُّ إلَیَّ مِنْ أَطْلِی بِخَلُوقٍ، وَلأَنْ أَقْلِبَ جَمْرَتَیْنِ أَحَبُّ إلَیَّ مِنْ أَنْ أَقْلِبَ کَعْبَیْنِ۔",,,26680 26681,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عُبَیْدُ اللہِ بْنُ الْوَلِیدِ ، عَن فُضَیْلِ بْنِ مُسْلِمٍ ، عَنْ أَبِیہِ ، عَنْ عَلِیٍّ ، أَنَّہُ کَانَ إذَا مَرَّ بِہِمْ وَہُمْ یَلْعَبُونَ بِالنَّرْدِشِیرِ عَقَلَہُمْ إلَی نِصْفِ النَّہَارِ۔",,,26681 26682,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا فُضَیْلُ بْنُ مَرْزُوقٍ ، عَن مَیْسَرَۃَ النَّہْدِیِّ ، قَالَ : مَرَّ عَلِیٌّ عَلَی قَوْمٍ یَلْعَبُونَ بِالشِّطْرَنْجِ ، فَقَالَ : {مَا ہَذِہِ التَّمَاثِیلُ الَّتِی أَنْتُمْ لَہَا عَاکِفُونَ}۔",,,26682 26683,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مَعْمَرٌ ، عَن بَسَّامٍ ، عَنْ أَبِی جَعْفَرٍ ، أَنَّہُ کَرِہَ اللَّعِبَ بِالشِّطْرَنْجِ۔",,,26683 26684,"حَدَّثَنَا عَلِیُّ بْنُ ہَاشِم ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْحَکَمِ فِی الشِّطْرَنْجِ ، قَالَ : کَانُوا یُنْزِلُونَ النَّاظِرَ إلَیْہَا کَالنَّاظِرِ إلَی لَحْمِ الْخِنْزِیرِ ، وَالَّذِی یُقْلِبُہَا کَالَّذِی یُقْلِبُ لَحْمَ الْخِنْزِیرِ۔",,,26684 26685,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إبْرَاہِیمُ بْنُ إسْمَاعِیلَ بْنُ مُجَمِّعٍ ، عَن عُبَیْدٍ مَوْلَی سَلَمَۃَ بْنِ الأَکْوَعِ ، عن سَلَمَۃَ بْنِ الأَکْوَعِ أَنَّہُ کَانَ یَنْہَی بَنِیہِ عَنِ اللَّعِبِ بِأَرْبَعَۃَ عَشَرَ أَشَدَّ النَّہْیِ۔",,,26685 26686,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إسْرَائِیلُ ، عَنْ جَابِرٍ ، عَن نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : کَانَ ابْنُ عُمَرَ یَنْہَی عَنِ اللَّعِبِ بِالشُّہَارْدَۃِ۔",,,26686 26687,حَدَّثَنَا وَکِیعٌ ، عَنِ الْعُمَرِیِّ ، عَن نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ مَرَّ عَلَی قَوْمٍ یَلْعَبُونَ بِأَرْبَعَۃَ عَشَرَ فَکَسَّرَہَا عَلَی رَأْسِ أَحَدِہِمْ۔,,,26687 26688,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إبْرَاہِیمُ بْنُ إسْمَاعِیلَ بْنِ مُجَمِّعٍ ، عَنْ عَبْدِ الْکَرِیمِ أَبِی أُمَیَّۃَ ، عَن أُمِّ قُثُم قَالَتْ : دَخَلَ عَلَیْنَا عَلِیٌّ وَنَحْنُ نَلْعَبُ بِأَرْبَعَۃَ عَشَرَ فَقَالَ : مَا ہَذَا ؟ فَقُلْنَا : نَحْنُ صِیَامٌ نَتَلَہَّی بِہِ ، قَالَ : أَفَلاَ أَشْتَرِی لَکُمْ بِدِرْہَمٍ جَوْزًا تَلْہُونَ بِہِ وَتَدَعُونَہَا ، قَالَ : فَاشْتَرَی لَنَا بِدِرْہَمٍ جَوْزًا۔",,,26688 26689,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَن بَسَّامٍ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : کَانَ عَلِیُّ بْنُ الْحُسَیْنِ یُلاَعِبُ أَہْلَہُ بِالشُّہَارْدَۃِ۔",,,26689 26690,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، قَالَ : حدَّثَنی الضَّحَّاکُ بْنُ عُثْمَانَ ، قَالَ : أَخْبَرَنَی نَافِعٌ ، أَنَّ ابْنَ عُمَرَ دَخَلَ عَلَی جَارِیَتَیْنِ لَہُ تَلْعَبَانِ بِالشُّہَارْدَۃِ فَضَرَبَہُمَا بہا حَتَّی تَکَسَّرَتْ۔",,,26690 26691,"حَدَّثَنَا صَفْوَانُ بْنُ عِیسَی ، عَن یَزِیدَ بْنِ أَبِی عُبَیْدٍ ، قَالَ : کَانَ سَلَمَۃُ بْنُ الأَکْوَعِ یَنْہَی بَنِیہِ أَنْ یَلْعَبُوا بِأَرْبَعَۃَ عَشَرَ ، وَیَقُولُ : إنَّہُمْ یَکْذِبُونَ فِیہَا وَیَفْجُرُونَ۔",,,26691 26692,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ إسْمَاعِیلَ بْنِ عَبْدِ الْمَلِکِ ، عَن سَعِیدِ بْنِ جُبَیْرٍ ، أَنَّہُ کَرِہَ اللَّعِبَ بِالشُّہَارْدَۃِ۔,,,26692 26693,"حَدَّثَنَا حَفْصٌ ، عَن لَیْثٍ ، عَن طَاوُوس ، قَالَ : کَانَ یَکْرَہُ الْقِمَارَ وَیَقُولُ : إِنَّہُ مِنَ الْمَیْسِرِ حَتَّی لَعِبِ الصِّبْیَانِ بِالْجَوْزِ وَالْکِعَابِ۔",,,26693 26694,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ نَجِیحٍ ، قَالَ : رَأَیْتُ ابْنَ سِیرِینَ مَرَّ عَلَی غِلْمَانٍ یَوْمَ الْعِیدِ بالْمِرْبَد وَہُمْ یَتَقَامَرُونَ بِالْجَوْزِ ، فَقَالَ : یَا غِلْمَانُ ، لاَ تُقَامِرُوا ، فَإِنَّ الْقِمَارَ مِنَ الْمَیْسِرِ۔",,,26694 26695,"حَدَّثَنَا وَکِیعٌ ، عَن سُفْیَانَ ، عَنْ عَاصِمٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : کُلُّ شَیْئٍ فِیہِ خَطَرٌ ، فَہُوَ مِنَ الْمَیْسِرِ۔",,,26695 26696,"حَدَّثَنَا وَکِیعٌ ، عَن سُفْیَانَ ، عَن لَیْثٍ ، عَنْ عَطَائٍ ، وَمُجَاہِدٍ ، وَطَاوُوس ، أَوِ اثْنَیْنِ مِنْہُمْ ، قَالاََ : کُلُّ شَیْئٍ مِنَ الْقِمَارِ ، فَہُوَ مِنَ الْمَیْسِرِ حَتَّی لَعِبِ الصِّبْیَانِ بِالْجَوْزِ۔",,,26696 26697,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ أَسْلَمَ الْمُنْقِرِیِّ ، قَالَ : کَانَ سَعِیدُ بْنُ جُبَیْرٍ إذَا مَرَّ عَلَی أَصْحَابِ النَّرْدِ لَمْ یُسَلِّمْ عَلَیْہِمْ۔",,,26697 26698,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَن یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَن زِیَادِ بْنِ حُدَیْرٍ ، أَنَّہُ مَرَّ عَلَی قَوْمٍ یَلْعَبُونَ بِالنَّرْدِ فَسَلَّمَ وَہُوَ لاَ یَعْلَمُ ، ثُمَّ رَجَعَ فَقَالَ : رُدُّوا عَلَیَّ سَلاَمِی۔",,,26698 26699,حَدَّثَنَا وَکِیعٌ ، عَن أُمِّ غُرَابٍ ، عَن بُنَانَۃَ ، أَنَّ عُثْمَانَ کَانَ یَتَمَطَّرُ فِی أَوَّلِ مَطْرَۃٍ۔,,,26699 26700,حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ اللہِ بْنِ الْمُؤَمِّلِ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، أَنَّ ابْنَ عَبَّاسٍ کَانَ یَتَمَطَّرُ ، یُخْرِجُ ثِیَابَہُ حَتَّی یُخْرِجَ سَرْجَہُ فِی أَوَّلِ مَطْرَۃٍ۔,,,26700 26701,حَدَّثَنَا وَکِیعٌ ، عَنِ الرَّبِیعِ ، عَن یَزِیدَ بْنِ أَبَانَ ، عَنْ أَنَسٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَتَمَطَّرُ فِی أَوَّلِ مَطْرَۃٍ۔,,,26701 26702,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَن سعد بْنِ رَزِینٍ عَمَّنْ حَدَّثَہُ ، عَنْ عَلِیٍّ ، أَنَّہُ کَانَ إذَا رأی الْمَطَرَ خَلَعَ ثِیَابَہُ وَجَلَسَ ، وَیَقُولُ : حدِیثُ عَہْدٍ بِالْعَرْشِ۔",,,26702 26703,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا جَعْفَرُ بْنُ سُلَیْمَانَ ، قَالَ : حَدَّثَنَا ثَابِتٌ ، قَالَ : حَدَّثَنَا أَنَسٌ ، قَالَ : أَصَابَنَا وَنَحْنُ مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَطَرٌ ، قَالَ : فَخَرَجَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَحَسَرَ ثَوْبَہُ عَنہُ حَتَّی أَصَابَہُ ، فَقُلْنَا : یَا رَسُولَ اللہِ ، لِمَ صَنَعْت ہَذَا ؟ قَالَ : لأَنَّہُ حَدِیثُ عَہْدٍ بِرَبِّہِ۔\n\n(ابوداؤد 5059۔ مسلم 615)",,,26703 26704,"حَدَّثَنَا عَبْدُ اللہِ بْنُ بَکْرٍ السَّہْمِیُّ ، قَالَ : حدَّثَنَا حَاتِمُ بْنُ أَبِی صَغِیرَۃَ ، عَنِ النُّعْمَانِ بْنِ سَالِمٍ ، أَنَّ عَمْرَو بْنَ أَوْسٍ أَخْبَرَہُ ، أَنَّ أَبَاہُ أَوْسًا أَخْبَرَہُ ، قَالَ : إنَّا لَقُعُودٌ عِنْدَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ یَقُصُّ عَلَیْنَا وَیُذَکِّرُنَا۔ (ابن ماجہ 3929۔ احمد 8)",,,26704 26705,"حَدَّثَنَا وَکِیعٌ ، عَن مَالِکِ بْنِ مِغْوَلٍ ، قَالَ : قَالَ أَبُو عَبْدِ الرَّحْمَنِ السُّلَمِیُّ : لاَ تُجَالِسُوا مِنَ الْقُصَّاصِ إلاَّ أَبَا الأَحْوَصِ۔",,,26705 26706,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، قَالَ : ذَکَرُوا عِنْدَ الشَّعْبِیِّ الْجُلُوسَ مَعَ الْقُصَّاصِ کَعَدْلِ عِتْقِ رَقَبَۃٍ ، فَقَالَ : لأَنْ أُعْتِقَ رَقَبَۃً أَحَبُّ إلَیَّ مِنْ أَنْ أَجْلِسَ مَعَ الْقُصَّاصِ أَرْبَعَۃَ أَشْہُرٍ۔",,,26706 26707,"حَدَّثَنَا جَرِیرٌ ، عَن مُغِیرَۃَ ، قَالَ : کَانَ إبْرَاہِیمُ التَّیْمِیُّ یُذَکِّرُ فِی مَنْزِلِ أَبِی وَائِلٍ ، فَجَعَلَ أَبُو وَائِلٍ یَنْتَفِضُ کَمَا یَنْتَفِضُ الطَّیْرُ۔",,,26707 26708,"حَدَّثَنَا جَرِیرٌ ، قَالَ : کَانَ الْحَسَنُ یَقُصُّ ، وَکَانَ سَعِیدُ بْنُ جُبَیْرٍ یَقُصُّ۔",,,26708 26709,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَن دَاوُد بْنِ سَابُورَ ، عَن مُجَاہِدٍ ، قَالَ : کُنَّا نَفْخَرُ عَلَی النَّاسِ بِأَرْبَعَۃٍ : بِفَقِیہِنَا وَبِقَاصِّنَا وَبِمُؤَذِّنِنَا وَبِقَارِئِنَا ، فَقِیہُنَا ابْنُ عَبَّاسٍ ، وَمُؤَذِّنُنَا أَبُو مَحْذُورَۃَ ، وَقَاصُّنَا عُبَیْدُ بْنُ عُمَیْرٍ ، وَقَارِئُنَا عَبْدُ اللہِ بْنُ السَّائِبِ۔",,,26709 26710,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَن مُجَاہِدٍ ، عَن یَزِیدَ بْنِ شَجَرَۃَ ، أَنَّہُ کَانَ یَقُصُّ ، وَکَانَ یُوَافِقُ قَوْلُہُ فِعْلَہُ۔,,,26710 26711,"حَدَّثَنَا غُنْدَرٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ عَبْدِ الْمَلِکِ بْنِ مَیْسَرَۃَ ، عَن کُرْدُوسٍ ، قَالَ : کَانَ یَقُصُّ ، فقَالَ: حَدَّثَنِی رَجُلٌ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لأَنْ أَجْلِسَ فِی مِثْلِ ہَذَا الْمَجْلِسِ أَحَبُّ إلَیَّ مِنْ أَنْ أُعْتِقَ أَرْبَعَ رِقَابٍ ، یَعْنِی الْقَصَصَ۔ (احمد 3/474)",,,26711 26712,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ حَجَّاجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : رَأَیْتُ تَمِیمًا الدَّارِیَّ یَقُصُّ فِی عَہْدِ عُمَرَ بْنِ الْخَطَّابِ رضی اللہ عَنہما۔",,,26712 26713,"حَدَّثَنَا مُحَمَّدُ بْنُ عُبَیْدٍ ، قَالَ : حدَّثَنَا عَبْدُ اللہِ بْنُ حَبِیبِ بْنِ أَبِی ثَابِتٍ ، قَالَ : رَأَیْتُ مُحَمَّدَ بْنَ کَعْبٍ الْقُرَظِیَّ یَقُصُّ۔",,,26713 26714,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَن عُبَیْدِ اللہِ ، عَن نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : لَمْ یُقَصَّ زَمَانَ أَبِی بَکْرٍ ، وَلاَ عُمَرَ ، إنَّمَا کَانَ الْقَصَصُ زَمَنَ الْفِتْنَۃِ۔",,,26714 26715,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، قَالَ: حدَّثَنَا سُفْیَانُ ، عَن سَعِیدٍ الْجُرَیْرِیِّ، عَنْ أَبِی عُثْمَانَ ، قَالَ: کَتَبَ عَامِلٌ لِعُمَرَ بْنِ الْخَطَّابِ إلَیْہِ ، أَنَّ ہَاہُنَا قَوْمًا یَجْتَمِعُونَ فَیَدْعُونَ لِلْمُسْلِمِینَ وَلِلأَمِیرِ ، فَکَتَبَ إلَیْہِ عُمَرُ : أَقْبِلْ وَأَقْبِلْ بِہِمْ مَعَک ، فَأَقْبَلَ ، وَقَالَ عُمَرُ لِلْبَوَّابِ : أَعِدَّ لِی سَوْطًا ، فَلَمَّا دَخَلُوا عَلَی عُمَرَ أَقْبَلَ عَلَی أَمِیرِہِمْ ضَرْبًا بِالسَّوْطِ ، فَقَالَ : یَا أمیر المؤمنین ، إنَّا لَسْنَا أُولَئِکَ الَّذِینَ یَعْنِی أُولَئِکَ قَوْمٌ یَأْتُونَ مِنْ قِبَلِ الْمَشْرِقِ۔",,,26715 26716,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَن سُفْیَانَ ، عَنْ أَبِی حَصِینٍ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ، أَنَّ عَلِیًّا رَأَی رَجُلاً یَقُصُّ ، فقَالَ : عَلِمْت النَّاسِخَ وَالْمَنْسُوخَ ؟ قَالَ : لاَ قَالَ : ہَلَکْت وَأَہْلَکْت۔",,,26716 26717,"حَدَّثَنَا وَکِیعٌ ، عَن سُفْیَانَ ، عَنْ أَبِی سِنَانٍ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی الْہُذَیْلِ ، عَنْ عَبْدِاللہِ بْنِ خَبَّابٍ ، قَالَ: رَآنِی أَبِی وَأَنَا عِنْدَ قَاصٍّ ، فَلَمَّا رَجَعت أَخَذَ الْہِرَاوَۃَ ، قَالَ : قَرْنٌ قَدْ طَالَعَ الْعَمَالِقَۃَ۔",,,26717 26718,"حَدَّثَنَا ابْنُ مَہْدِیٍّ، عَن سُفْیَانَ، عَنْ أَبِیہِ، قَالَ: سَمِعْتُ إبْرَاہِیمَ التَّیْمِیَّ، قَالَ: إنَّمَا حَمَلَنِی عَلَی مَجْلِسِی ہَذَا أَنِّی رُؤیت کَأَنِّی أُقَسِّمُ رَیْحَانًا ، فَذَکَرْت ذَلِکَ لإِبْرَاہِیمَ فَقَالَ : إنَّ الرَّیْحَانَ لَہُ مَنْظَرٌ وَطَعْمُہُ مُرٌّ۔",,,26718 26719,"حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، قَالَ : حَدَّثَنَی عُقْبَۃُ بْنُ حُرَیْثٍ ، قَالَ : سَمِعْتُ ابْنَ عُمَرَ ، وَجَائَ رَجُلٌ قَاصٌّ وَجَلَسَ فِی مَجْلِسِہِ فَقَالَ ابْنُ عُمَرَ : قُمْ مِنْ مَجْلِسِنَا ، فَأَبَی أَنْ یَقُومَ ، فَأَرْسَلَ ابْنُ عُمَرَ إلَی صَاحِبِ الشُّرَطِ : أَقِمِ الْقَاصَّ ، فَبَعَثَ إلَیْہِ فَأَقَامَہُ۔",,,26719 26720,"حَدَّثَنَا شَرِیکٌ ، عَنْ عَاصِمٍ ، عَنْ أَبِی وَائِلٍ ، عَنْ عَلْقَمَۃَ ، قَالَ : قیلَ لَہُ : أَلاَ تَقُصُّ عَلَیْنَا ؟ قَالَ : إنِّی أَکْرَہُ أَنْ آمُرَکُمْ بِمَا لاَ أَفْعَلُ۔",,,26720 26721,"حَدَّثَنَا شَرِیکٌ ، عَنْ أَبِی سِنَانٍ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی الْہُذَیْلِ ، عَن خَبَّابٍ ، قَالَ : رَأَی ابْنَہُ عِنْدَ قَاصٍّ ، فَلَمَّا رَجَعَ اتَّزَرَ وَأَخَذَ السَّوْطَ وَقَالَ : أَمَعَ الْعَمَالِقَۃِ ، ہَذَا قَرْنٌ قَدْ طَلَعَ۔",,,26721 26722,"حَدَّثَنَا شَرِیکٌ ، عَنْ إبْرَاہِیمَ ، عَن مُجَاہِدٍ ، قَالَ : دَخَلَ قَاصٌّ فَجَلَسَ قَرِیبًا مِنَ ابْنِ عُمَرَ فَقَالَ لَہُ : قُمْ ، فَأَبَی أَنْ یَقُومَ ، فَأَرْسَلَ إلَی صَاحِبِ الشُّرَطِ ، فَأَرْسَلَ إلَیْہِ شُرْطِیًّا فَقَامَ۔",,,26722 26723,"حَدَّثَنَا شَرِیکٌ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : بَلَغَ عُمَرَ ، أَنَّ رَجُلاً یَقُصُّ بِالْبَصْرَۃِ فَکَتَبَ إلَیْہِ : {الر تِلْکَ آیَاتُ الْکِتَابِ الْمُبِینِ إنَّا أَنْزَلْنَاہُ قُرْآنًا عَرَبِیًّا لَعَلَّکُمْ تَعْقِلُونَ نَحْنُ نَقُصُّ عَلَیْک أَحْسَنَ الْقَصَصِ} إلَی آخِرِ الآیَۃِ ، قَالَ : فَعَرَفَ الرَّجُلُ فَتَرَکَہُ۔",,,26723 26724,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ إسْمَاعِیلَ ، عَن أُکَیْلٍ ، قَالَ : قَالَ إبْرَاہِیمُ : مَا أَحَدٌ مِمَّنْ یَذْکُرُ أَرْجَی فِی نَفْسِی أَنْ یَسْلَمَ مِنْہُ یَعْنِی إبْرَاہِیمَ التَّیْمِیَّ ، وَلَوَدِدْت ، أَنَّہُ یَسْلَمُ مِنْہُ کَفَافًا لاَ عَلَیْہِ ، وَلاَ لَہُ۔",,,26724 26725,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَن سُفْیَانَ ، عَن سَلَمَۃَ ، عَنْ أَبِی الدَّرْدَائِ - جَارٍ لِسَلَمَۃَ - قَالَ : قُلْتُ لِعَائِشَۃَ أَوْ قَالَ لَہَا رَجُلٌ : آتِیَ الْقَاصَّ یَدْعُو لِی ، فَقَالَتْ : لأَنْ تَدْعُوَ لِنَفْسِکَ خَیْرٌ مِنْ أَنْ یَدْعُوَ لَکَ الْقَاصُّ۔",,,26725 26726,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَن عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَن نَافِعٍ ، قَالَ : لَمْ یَکُنْ قَاصٌّ فِی زَمَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، وَلاَ زَمَنِ أَبِی بَکْرٍ، وَلاَ زَمَنِ عُمَرَ، وَلاَ فِی زَمَنِ عُثْمَانَ۔ (ابن ماجہ 3754۔ ابن حبان 6261)",,,26726 26727,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، حَدَّثَنَا مُعَاوِیَۃُ بْنُ صَالِحٍ ، قَالَ : حدَّثَنَی یَحْیَی بْنُ سَعِیدٍ الْکَلاَعِیُّ ، عَن جُبَیْرِ بْنِ نُفَیْرٍ الْحَضْرَمِیِّ ، أَنَّ أُمَّ الدَّرْدَائِ بَعَثَتْہُ إلَی نَوْفَلِ بْنِ فُلاَنٍ وَقَاصٍّ مَعَہُ ، یَقُصَّانِ فِی الْمَسْجِدِ ، فَقَالَتْ : قُلْ لَہُمَا : لِیَتَّقِیَا اللَّہَ وَتَکُنْ مَوْعِظَتُہُمَا لِلنَّاسِ لأَنْفُسِہِمَا۔",,,26727 26728,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَن مِسْعَرٍ ، عَن عُبَیْدِ بْنِ الْحَسَنِ ، عَنِ ابْنِ مَعْقِلٍ ، قَالَ : کَانَ رَجُلٌ لاَ یَزَالُ یَقُصُّ فَقَالَ لَہُ ابْنُ مَسْعُودٍ : انْشُرْ سِلْعَتَکَ عَلَی مَنْ یُرِیدُہَا۔",,,26728 26729,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَن یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، عَنِ ابْنِ عُمَرَ ، قَالَ : قبَّلْنَا یَدَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔ (ابوداؤد 2640۔ احمد 23)",,,26729 26730,حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَن یَزِیدَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، عَنِ ابْنِ عُمَرَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِمِثْلِہِ۔,,,26730 26731,"حَدَّثَنَا ابْنُ إدْرِیسَ وَغُنْدَرٌ ، وَأَبُو أُسَامَۃَ ، عَن شُعْبَۃَ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ عَبْدِ اللہِ بْنِ سَلِمَۃَ ، عَن صَفْوَانَ بْنِ عَسَّالٍ ، أَنَّ قَوْمًا مِنَ الْیَہُودِ قَبَّلُوا یَدَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَرِجْلَیْہِ۔\n\n(ترمذی 2733۔ احمد 4/239)",,,26731 26732,"حَدَّثَنَا وَکِیعٌ ، عَن سُفْیَانَ ، عَن زِیَادِ بْنِ فَیَّاضٍ ، عَن تَمِیمِ بْنِ سَلَمَۃَ ، أَنَّ أَبَا عُبَیْدَۃَ قَبَّلَ یَدَ عُمَرَ ، قَالَ تَمِیمٌ : وَالْقُبْلَۃُ سُنَّۃٌ۔ (بیہقی 101)",,,26732 26733,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ، عَن مَالِکٍ، عَن طَلْحَۃَ، قَالَ: قبَّلَ خَیْثَمَۃُ یَدِی، قَالَ مَالِکٌ: وَقَبَّلَ طَلْحَۃُ یَدِی۔",,,26733 26734,"حَدَّثَنَا وَکِیعٌ ، عَن سُفْیَانَ ، عَن لَیْثٍ ، عَن مُجَاہِدٍ ، أَنَّہُ کَرِہَ أَنْ یَقُولَ الرَّجُلُ : ذَیّا۔",,,26734 26735,"حَدَّثَنَا وَکِیعٌ ، عَن سُفْیَانَ ، عَنْ أَبِی سُعَادٍ ، عَنْ عَبْدِ اللہِ بْنِ مُحَمَّدِ بْنِ الْحَنَفِیَّۃِ ، أَنَّہُ سَمِعَ رَجُلاً یَقُولُ: یَا ہَنَاۃُ ، فَنَہَاہُ۔",,,26735 26736,"حَدَّثَنَا حَفْصٌ ، عَن عِیسَی بْنِ الْمُسَیَّبِ ، أَنَّہُ کَرِہَ کُلَّ شَیْئٍ یَکُونُ آخِرُہُ : وَیْہِ۔",,,26736 26737,"حَدَّثَنَا ابْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، عَن مُوسَی بْنِ سُلَیْمَانَ ، عَنِ الْقَاسِمِ بْنِ مُخَیْمِرَۃَ ، قَالَ : قَالَ لُقْمَانُ لابْنِہِ وَہُوَ یَعِظُہُ : یَا بُنَیَّ ، إیَّاکَ وَالتَّقَنُّعَ فَإِنَّہُ مَخْوَفَۃٌ بِاللَّیْلِ مَذَلَّۃٌ ، أَوْ مَذَمَّۃٌ بِالنَّہَارِ۔",,,26737 26738,"حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَن سَہْلِ بْنِ خَلِیفَۃَ ، عَن عُبَیْدَۃَ ، قَالَ : رَأَیْتُ طَاوُوسًا عَلَیْہِ مُقَنَّعَۃٌ مِثْلُ مُقَنَّعَۃِ الرُّہْبَانِ۔",,,26738 26739,"حَدَّثَنَا أَبُو الأَحْوَصِ، عَنْ أَبِی إِسْحَاقَ، عَنْ أَبِی الْعَلاَئِ، قَالَ: رَأَیْتُ الْحَسَنَ بْنَ عَلِیٍّ یُصَلِّی مُقَنِّعًا رَأْسَہُ۔ (عبدالرزاق 19840۔ بزار 2886)",,,26739 26740,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَن عُبَیْدِ اللہِ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : مَنْ نَامَ وَفِی یَدِہِ رِیحُ غَمَرٍ فَأَصَابَہُ شَیْئٌ فَلاَ یَلُومَنَّ إلاَّ نَفْسَہُ۔",,,26740 26741,"حَدَّثَنَا وَکِیعٌ ، عَن سُفْیَانَ ، عَن وَاصِلٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إنَّ الشَّیْطَانَ یَحْضُرُ الدَّسَمَ۔",,,26741 26742,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، قَالَ : حدَّثَنَا زُہَیْرٌ ، عَن سُہَیْلٍ ، عَنْ أَبِیہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ نَامَ وَفِی یَدِہِ غَمَرٌ لَمْ یَغْسِلْہُ فَأَصَابَہُ شَیْئٌ فَلاَ یَلُومَنَّ إلاَّ نَفْسَہُ۔\n\n(ابوداؤد 3848۔ ترمذی 1859)",,,26742 26743,"حَدَّثَنَا وَکِیعٌ ، عَن سُفْیَانَ ، عَن حَبِیبِ بْنِ أَبِی ثَابِتٍ ، عَن مَیْمُونِ بْنِ أَبِی شَبِیبٍ ، قَالَ : قَالَ صَعْصَعَۃُ لابْنِ أَخِیہِ : إنِّی کُنْت أَحَبَّ إلَی أَبِیک مِنْک فَأَنْتَ أَحَبُّ إلَیَّ مِنِ ابْنِی ، إذَا لَقِیت الْمُؤْمِنَ فَخَالِطْہُ ، وَإِذَا لَقِیت الْفَاجِرَ فَخَالِقْہُ۔",,,26743 26744,"حَدَّثَنَا مُحَمَّدُ بْنُ عُبَیْدٍ ، عَنِ الأَعْمَشِ ، عَن یَحْیَی بْنِ وَثَّابٍ ، عَن رَجُلٍ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْمُؤْمِنُ الَّذِی یُخَالِطُ النَّاسَ وَیَصْبِرُ عَلَی أَذَاہُمْ أَفْضَلُ مِنَ الَّذِی لاَ یُخَالِطُ النَّاسَ ، وَلاَ یَصْبِرُ عَلَی أَذَاہُمْ۔ (ترمذی 2507۔ احمد 2/43)",,,26744 26745,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَن حَبِیبِ بْنِ أَبِی ثَابِتٍ عن عبد اللہ بن باہ ، قَالَ : قَالَ عَبْدُ اللہِ بْنُ مَسْعُودٍ : خَالِطُوا النَّاسَ وَزَایِلُوہُمْ وَصَافِحُوہُمْ وَدِینُکُمْ فلاَ تَکْلِمُونَہُ۔ (طبرانی 9757)",,,26745 26746,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : حدَّثَنِی مُسْلِمٌ الْبَطِینُ ، عنْ إبْرَاہِیمَ التَّیْمِیِّ ، عَنْ أَبہ: ، عَنْ عَمْرِو بْنِ مَیْمُونٍ ، قَالَ : مَا أَخْطَأَنِی ابْنُ مَسْعُودٍ خَمِیسًا إلاَّ أَتَیْتہ فِیہِ ، قَالَ: فَمَا سَمِعْتہ یَقُولُ لِشَیْئٍ قَطُّ ، قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَلَمَّا کَانَ ذَاتَ عَشِیَّۃٍ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، قَالَ : فَنَکَّسَ ، قَالَ : فَنَظَرْت إلَیْہِ وَہُوَ قَائِمٌ مُنحَلَّۃً أَزْرَارُ قَمِیصِہِ ، قَدَ اغْرَوْرَقَتْ عَیْنَاہُ وَانْتَفَخَتْ أَوْدَاجُہُ، قَالَ : أَوْ دُونَ ذَلِکَ ، أَوْ فَوْقَ ذَلِکَ ، أَوْ قَرِیبًا مِنْ ذَلِکَ ، أَوْ شَبِیہًا بِذَلِکَ۔ (احمد 1/452۔ دارمی 270)",,,26746 26747,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : کَانَ أَنَسُ بْنُ مَالِکٍ إذَا حَدَّثَ عَن رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَدِیثًا فَفَرَغَ مِنْہُ ، قَالَ : أَوْ کَمَا قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔\n\n(دارمی 276۔ احمد 205)",,,26747 26748,"حَدَّثَنَا حَفْصٌ ، عَنْ عَاصِمٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : حدَّثَ بِحَدِیثٍ فَقِیلَ لَہُ : أَتَرْفَعُ ہَذَا ؟ فَقَالَ : دُونَہُ أَحَبُّ إلَیْنَا إِنْ کَانَ خَطَأٌ فِی ذَلِکَ ، أَوْ زِیَادَۃٌ ، أَوْ نُقْصَانٌ کَانَ أَحَبَّ إلَیْنَا۔",,,26748 26749,"حَدَّثَنَا غُنْدَرٌ ، عَن شُعْبَۃَ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنِ ابْنِ أَبِی لَیْلَی ، قَالَ : قلْنَا لِزَیْدِ بْنِ أَرْقَمَ : حَدِّثْنَا ، قَالَ : کَبِرْنَا وَنَسِینَا ، وَالْحَدِیثُ علَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ شَدِیدٌ۔ (ابن ماجہ 25۔ احمد 370)",,,26749 26750,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَن حَمَّادِ بْنِ زَیْدٍ ، عَن یَحْیَی بْنِ سَعِیدٍ ، عَنِ السَّائِبِ بْنِ یَزِیدَ ، قَالَ : خَرَجْت مَعَ سَعْدِ بْنِ مَالِکٍ مِنَ الْمَدِینَۃِ إلَی مَکَّۃَ ، فَمَا سَمِعْتہ یُحَدِّثُ حَدِیثًا حَتَّی رَجَعْنا۔",,,26750 26751,"حَدَّثَنَا شَبَابَۃُ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، قَالَ : حَدَّثَنَا تَوْبَۃُ الْعَنْبَرِیُّ ، قَالَ : قَالَ لِی الشَّعْبِیُّ : أَرَأَیْت الْحَسَنَ حِینَ یَقُولُ ، قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَقَدْ جَلَسْت إلَی ابْنِ عُمَرَ ، فَمَا سَمِعْتہ یُحَدِّثُ عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إلاَّ حَدِیثًا ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أُتِیَ بِضَبٍّ فَقَالَ : إِنَّہُ لَیْسَ مِنْ طَعَامِی ، وَأَمَّا أَنْتُمْ فَکُلُوہُ۔ (بخاری 7267۔ مسلم 1543)",,,26751 26752,"حَدَّثَنَا أَبُو بَکر ، قَالَ : حَدَّثَنَا شُعْبَۃُ ، قَالَ : حدَّثَنَا عَبْدُ اللہِ بْنُ أَبِی السَّفَرِ ، عَنِ الشَّعْبِیِّ ، قَالَ : جَلَسْت إلَی ابْنِ عُمَرَ سَنَۃً فَمَا سَمِعْتہ یُحَدِّثُ عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِشَیْئٍ۔ (ابن ماجہ 26۔ احمد 2/157)",,,26752 26753,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَن شُعْبَۃَ ، عَن سَعْدِ بْنِ إِبْرَاہِیمَ ، عَن أَبِیہِ ، قَالَ : قَالَ عُمَرَ لابْنِ مَسْعُودٍ وَلأَبِی الدَّرْدَائِ وَلأَبِی مَسْعُودٍ وَعُقْبَۃَ بْنِ عَمْرٍو : أَحْسَبُ مَا ہَذَا الْحَدِیثُ ، عَن رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، قَالَ : وَأَحْسَبُہُ حَبَسَہُمْ بِالْمَدِینَۃِ حَتَّی أُصِیبَ۔",,,26753 26754,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، سَمِعَ سَہْلَ بْنَ سَعْدٍ یَقُولُ : اطَّلَعَ رَجُلٌ مِنْ جُحْرٍ فِی حُجْرَۃِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَمَعَہُ مِدْرًی یَحُکُّ بِہِ رَأْسَہُ فَقَالَ : لَوْ أَعْلَمُ أَنَّک تَنْظُرُ لَطَعَنْتُ بِہِ فِی عَیْنِکَ : إنَّمَا الاِسْتِئْذَانُ مِنَ الْبَصَرِ۔ (بخاری 6241۔ مسلم 1698)",,,26754 26755,"حَدَّثَنَا وَکِیعٌ ، عَن بَرَکَۃَ بْنِ یَعْلَی التَّیْمِیِّ ، عَنْ أَبِی سُوَیْد الْعَبْدِیِّ ، قَالَ : کُنَّا بِبَابِ ابْنِ عُمَرَ نَسْتَأْذِنُ عَلَیْہِ ، فَحَانَتْ مِنِّی الْتِفَاتَۃٌ ، فَرَآنِی فَقَالَ : أَیُّکُمُ اطَّلَعَ فِی دَارِی ؟ قَالَ قُلْتُ : أَنَا أَصْلَحَک اللَّہُ ، حَانَتْ مِنِّی الْتِفَاتَۃٌ فَنَظَرْت ، قَالَ : وَیْحَک لَکَ أنْ تَطَّلِعَ فِی دَارِی!۔",,,26755 26756,"حَدَّثَنَا وَکِیعٌ ، عَن سُفْیَانَ ، عَن مَنْصُورٍ ، عَن طَلْحَۃَ ، عَنِ الْہُذَیْلِ بْنِ شُرَحْبِیلَ ، أَنَّ سَعْدًا اسْتَأْذَنَ عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَأَدْخَلَ رَأْسَہُ ، فَقَالَ النبی صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّمَا جُعِلَ الاِسْتِئْذَانُ مِنْ أَجْلِ النَّظَرِ۔ (ابوداؤد 5131۔ طبرانی 5386)",,,26756 26757,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَوْفٍ ، عَنِ الْحَسَنِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ سَبَقَہُ بَصَرُہُ إلَی الْبُیُوتِ ، فَقَدْ دَمَرَ یَعْنِی دَخَلَ۔",,,26757 26758,"حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، عَن طَلْحَۃَ ، عَن ہُزَیْلٍ ، قَالَ : جَائَ رَجُلٌ فَوَقَفَ عَلَی بَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَسْتَأْذِنُ ، فَقَامَ عَلَی الْبَابِ ، فَقَالَ لہ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : ہَکَذَا ، عَنک ہَکَذَا ، فَإِنَّمَا الاِسْتِئْذَانُ مِنَ النَّظَرِ۔",,,26758 26759,"حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ ، عَن سُلَیْمَانَ بْنِ بِلاَلٍ ، عَن سُہَیْلٍ ، عَنْ أَبِیہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَوْ أَنَّ أَحَدًا اطَّلَعَ عَلَی نَاسٍ بِغَیْرِ إذْنِہِمْ حَلَّ لَہُمْ أَنْ یَفْقَؤُوا عَیْنَہُ۔ (بخاری 6888۔ مسلم 1699)",,,26759 26760,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا حُمَیْدٌ ، عَنْ أَنَسِ بْنِ مَالِکٍ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ فِی بَیْتِہِ ، فَاطَّلَعَ رَجُلٌ مِنْ خَلَلِ الْبَابِ ، فَسَدَّدَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ علیہ بِمِشْقَصٍ ، فَتَأَخَّرَ الرَّجُلُ۔ (بخاری 6242۔ مسلم 1699)",,,26760 26761,"حَدَّثَنَا وَکِیعٌ ، عَن سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَن مُسْلِمِ بْنِ نَذِیرٍ ، قَالَ : اسْتَأْذَنَ رَجُلٌ عَلَی حُذَیْفَۃَ فَأَدْخَلَ رَأْسَہُ فَقَالَ لَہُ حُذَیْفَۃُ : قَدْ أَدْخَلْت رَأْسَک فَأَدْخِلْ إِسْتَک۔",,,26761 26762,"حَدَّثَنَا شَرِیکٌ بْنُ عَبْدِ اللہِ ، عَن سِمَاکٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَبْدِ اللہِ ، عَنْ أَبِیہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ کَذَبَ عَلَیَّ مُتَعَمِّدًا فَلْیَتَبَوَّأْ مَقْعَدَہُ مِنَ النَّارِ۔ (بخاری 6888۔ ترمذی 2659)",,,26762 26763,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنْ أَنَسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ کَذَبَ عَلَیَّ مُتَعَمِّدًِا فَلْیَتَبَوَّأْ مَقْعَدَہُ مِنَ النَّارِ۔ (بخاری 108۔ مسلم 10)",,,26763 26764,حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنِ الْحَکَمِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، عَنْ عَلِیٍّ مِثْلُ حَدِیثِ ابْنِ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَن حَبِیبٍ۔ (بزار 621),,,26764 26765,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنِ الأَوْزَاعِیِّ ، عَن حَسَّانَ بْنِ عَطِیَّۃَ ، عَنْ أَبِی کَبْشَۃَ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ کَذَبَ عَلَیَّ مُتَعَمِّدًا فَلْیَتَبَوَّأْ مَقْعَدَہُ مِنَ النَّارِ۔\n\n(بخاری 3461۔ ترمذی 2669)",,,26765 26766,"حَدَّثَنَا غُنْدَرٌ ، عَن شُعْبَۃَ ، عَنْ جَامِعِ بْنِ شَدَّادٍ ، عَنْ عَامِرِ بْنِ عَبْدِ اللہِ بْنِ الزُّبَیْرِ ، عَنْ أَبِیہِ ، قَالَ : قُلْتُ لِلزُّبَیْرِ : یَا أَبَتِی ، مَالِی لاَ أَسْمَعُک تُحَدِّثُ عَن رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَمَا أسْمَعُ ابْنَ مَسْعُودٍ وَفُلاَنًا وَفُلاَنًا ؟ فَقَالَ : أما إنِّی لَمْ أُفَارِقْہُ مُنْذُ أَسْلَمْت ، وَلَکِنِّی سَمِعْت مِنْہُ کَلِمَۃً : مَنْ کَذَبَ عَلَیَّ مُتَعَمِّدًا فَلْیَتَبَوَّأْ مَقْعَدَہُ مِنَ النَّارِ۔ (بخاری 107۔ ابوداؤد 3643)",,,26766 26767,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا زَکَرِیَّا ، عَن خَالِدِ بْنِ سَلَمَۃَ ، عَن مُسْلِمٍ مَوْلَی خَالِدِ بْنِ عُرْفُطَۃَ ، أَنَّ خَالِدَ بْنَ عُرْفُطَۃَ ذَکَرَ الْمُخْتَارَ فَقَالَ : کَذَّابٌ ، وَسَمِعْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : مَنْ کَذَبَ عَلَیَّ مُتَعَمِّدًا فَلْیَتَبَوَّأْ مَقْعَدَہُ مِنْ جَہَنَّمَ۔ (احمد 5/292۔ ابویعلی 6833)",,,26767 26768,"حَدَّثَنَا یَحیَی بْنُ یَعْلَی التَّیْمِیُّ ، عَن مُحَمَّدِ بْنِ إِسْحَاقَ ، عَن مَعْبَدِ بْنِ کَعْبٍ ، عَنْ أَبِی قَتَادَۃَ ، قَالَ : سَمِعْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ عَلَی ہَذَا الْمِنْبَرِ : إیَّاکُمْ وَکَثْرَۃَ الْحَدِیثِ عَلَیَّ ، فَمَنْ قَالَ فَلْیَقُلْ حَقًّا ، أَوْ صِدْقًا ، وَمَنْ تَقَوَّلَ عَلَیَّ مَا لَمْ أَقُلْ فَلْیَتَبَوَّأْ مَقْعَدَہُ مِنَ النَّارِ۔ (احمد 5/297۔ دارمی 237)",,,26768 26769,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، وَأَبُو أُسَامَۃَ ، قَالَ : حدَّثَنَا عُبَیْدُ اللہِ بْنُ عُمَرَ، عَنْ أَبِی بَکْرِ بْنِ سَالِمٍ، عَنْ أَبِیہِ، عَنْ جَدِّہِ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إنَّ الَّذِی یَکْذِبُ عَلَیَّ یُبْنَی لَہُ بَیْتٌ فِی النَّارِ۔\n\n(احمد 2/22۔ طبرانی 13154)",,,26769 26770,"حَدَّثَنَا غُنْدَرٌ ، عَن شُعْبَۃَ ، عَن مَنْصُورٍ ، عَن رِبْعِیِّ بْنِ حِرَاشٍ ، أَنَّہُ سَمِعَ عَلِیًّا یَخْطُبُ یَقُولُ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: لاَ تَکْذِبُوا عَلَیَّ، فَإِنَّہُ مَنْ یَکْذِبْ عَلَیَّ یَلِجَ النَّارَ۔(بخاری 106۔ مسلم 123)",,,26770 26771,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا ہَمَّامٌ ، قَالَ : حَدَّثَنَا زَیْدُ بْنُ أَسْلَمَ ، عَنْ عَطَائِ بْنِ یَسَارٍ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ کَذَبَ عَلَیَّ ، أَحْسَبُہُ قَالَ : مُتَعَمِّدًا ، فَلْیَتَبَوَّأْ مَقْعَدَہُ مِنَ النَّارِ۔ (مسلم 2298۔ احمد 3/44)",,,26771 26772,"حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَن مُطَرِّفٍ ، عَنْ عَطِیَّۃَ ، عَنْ أَبِی سَعِیدٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ کَذَبَ عَلَیَّ مُتَعَمِّدًا فَلْیَتَبَوَّأْ مَقْعَدَہُ مِنَ النَّارِ۔ (ابن ماجہ 37)",,,26772 26773,"حَدَّثَنَا أَبُو عَبْدِ الرَّحْمَنِ الْمُقُْرِیء ، عَن سَعِیدِ بْنِ أَبِی أَیُّوبَ ، قَالَ : حدَّثَنَی بَکْرُ بْنُ عَمْرٍو ، عَنْ أَبِی عُثْمَانَ مُسْلِمِ بْنِ یَسَارٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ تَقَوَّلَ عَلَیَّ مَا لَمْ أَقُلْ فَلْیَتَبَوَّأْ مَقْعَدَہُ مِنَ النَّارِ۔ (بخار ی110۔ مسلم 10)",,,26773 26774,"حَدَّثَنَا غُنْدَرٌ ، عَن شُعْبَۃَ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَن مُرَّۃَ ، عَن رَجُلٍ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ قَامَ فِینَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : قدْ رَأَیْتُمُونِی وَسَمِعْتُمْ مِنِّی وَسَتُسْأَلُونَ عَنی، فَمَنْ کَذَبَ عَلَیَّ فَلْیَتَبَوَّأْ مَقْعَدَہُ مِنَ النَّارِ۔ (احمد 5/412)",,,26774 26775,"قَال حُدِّثْت عَن ہُشَیْمٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ کَذَبَ عَلَیَّ مُتَعَمِّدًا فَلْیَتَبَوَّأْ مَقْعَدَہُ مِنَ النَّارِ۔ (ابن ماجہ 33۔ دارمی 231)",,,26775 26776,"حدَّثَنَا یَزِیدُ ، قَالَ : أَخْبَرَنَا سُلَیْمَانُ التَّیْمِیُّ ، عَنْ أَنَسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ کَذَبَ عَلَیَّ مُتَعَمِّدًا فَلْیَتَبَوَّأْ مَقْعَدَہُ مِنَ النَّارِ ، وَرُبَّمَا قَالَ : فَلْیَتَبَوَّأْ مَقْعَدَہُ مِنَ النَّارِ مُتَعَمِّدًا۔\n\n(نسائی 5914۔ احمد 3/116)",,,26776 26777,"حَدَّثَنَا سُوَیْد بْنُ عَمْرو ، قَالَ : حدَّثَنَا أَبُو عَوَانَۃَ ، عَنْ عَبْدِ الأَعْلَی ، عَن سَعِیدِ بْنِ جُبَیْرٍ ، عنِ ابْنِ عَبَّاسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ کَذَبَ عَلَیَّ مُتَعَمِّدًا فَلْیَتَبَوَّأْ مَقْعَدَہُ مِنَ النَّارِ۔\n\n(ترمذی 2951۔ احمد 1/293)",,,26777 26778,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، قَالَ : حدَّثَنَا سَعِیدُ بْنُ عُبَیْدٍ ، عَنْ عَلِیِّ بْنِ رَبِیعَۃَ ، عَنِ الْمُغِیرَۃِ بْنِ شُعْبَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ کَذِبًا عَلَیَّ لَیْسَ کَکَذِبِ أَحَدِکُمْ ، فَمَنْ کَذَبَ عَلَیَّ مُتَعَمِّدًا فَلْیَتَبَوَّأْ مَقْعَدَہُ مِنَ النَّارِ۔ (بخاری 1291۔ مسلم 15)",,,26778 26779,"حَدَّثَنَا أَبُو بَکْرٍ قَالَ : وَجَدْت فِی کِتَاب أَبی مُحَمَّدِ بْنِ أَبِی شَیْبَۃَ : عَنْ عَبْدِ الْحَمِیدِ بْنِ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ مَحمُود بن لَبِید ، عَنْ عُثْمَانَ بْنِ عَفَّان ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ کَذَبَ عَلَیَّ مُتَعَمِّدًا فَلْیَتَبَوَّأْ مَقْعَدَہُ مِنَ النَّارِ۔ (احمد 1/70۔ بزار 384)",,,26779 26780,"حَدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَن أَبِی حَیَّانَ ، عَن یَزِیدَ بْنِ حَیَّانَ ، عَن زَیْدِ بْنِ أَرْقَمَ ، قَالَ : سَمِعْتُہُ یَقُولُ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ کَذَبَ عَلَیَّ مُتَعَمِّدًا فَلْیَتَبَوَّأْ مَقْعَدَہُ مِنَ النَّارِ۔ \n\n(احمد 4/366۔ طبرانی 5017)",,,26780 26781,"حدَّثَنَا أَبُو بَکْرٍ عَبْدُ اللہِ بْنُ مُحَمَّدِ بْنِ أَبِی شَیْبَۃَ ، قَالَ : حدَّثَنَا جَرِیرٌ ، عَن مُغِیرَۃَ ، عَنْ أَبِی رَزِینٍ ، قَالَ: قِیلَ لِلْعَبَّاسِ : أَنْتَ أَکْبَرُ ، أَوْ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ قَالَ : ہُوَ أَکْبَرُ مِنِّی وَوُلِدْت أَنَا قَبْلَہُ۔\n\n(حاکم 320)",,,26781 26782,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَن سُفْیَانَ ، عَنْ أَبِیہِ ، قَالَ : قیلَ لأَبِی وَائِلٍ : أَیُّکُمَا أَکْبَرُ ؟ أَنْتَ أَکْبَرُ ، أَوِ الرَّبِیعُ بْنُ خُثَیْمٍ ؟ قَالَ : أَنَا أَکْبَرُ مِنْہُ سِنًّا وَہُوَ أَکْبَرُ مِنِّی عَقْلاً۔",,,26782 26783,حَدَّثَنَا وَکِیعٌ ، عَن سُفْیَانَ ، عَنْ أَبِیہِ ، عَنْ أَبِی وَائِلٍ بِنَحْوٍ مِنْہُ۔,,,26783 26784,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَن سُفْیَانَ ، عَن حَبِیبِ بْنِ أَبِی ثَابِتٍ ، عَن مُجَاہِدٍ ، عَنْ أَبِی مَعْمَرٍ ، عَنِ الْمِقْدَادِ بْنِ الأَسْوَدِ قَالَ : أَمَرَنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ نَحْثُوَ فِی وُجُوہِ الْمَدَّاحِینَ التُّرَابَ۔ (مسلم 2297۔ احمد 6/5)",,,26784 26785,"حَدَّثَنَا غُنْدَرٌ ، عَن شُعْبَۃَ ، عَن مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، عَن ہَمَّامِ بْنِ الْحَارِثِ ، أَنَّ رَجُلاً جَعَلَ یَمْدَحُ عُثْمَانَ ، فَعَمَدَ الْمِقْدَادُ فَجَثَا عَلَی رُکْبَتَیْہِ ، قَالَ : وَکَانَ رَجُلاً ضَخْمًا ، قَالَ : فَجَعَلَ یَحْثُو فِی وَجْہِہِ الْحَصَی ، فَقَالَ لَہُ عُثْمَانُ : مَا شَأْنُک ؟ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا رَأَیْتُمُ الْمَدَّاحِینَ فَاحْثُوا فِی وُجُوہِہِمُ التُّرَابَ۔ (مسلم 2297۔ احمد 6/5)",,,26785 26786,"حَدَّثَنَا غُنْدَرٌ ، عَن شُعْبَۃَ ، عَن سَعْدِ بْنِ إبْرَاہِیمَ ، عَن مَعْبَدٍ الْجُہَنِیِّ ، عَن مُعَاوِیَۃَ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : إیَّاکُمْ وَالتَّمَادُحَ فَإِنَّہُ الذَّبْحُ۔ (احمد 4/98۔ طبرانی 815)",,,26786 26787,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَن عِمْرَانَ بْنِ مُسْلِمٍ ، عَنْ إبْرَاہِیمَ التَّیْمِیِّ ، عَنْ أَبِیہِ قَالَ : کُنَّا قُعُودًا عِنْدَ عُمَرَ بْنِ الْخَطَّابِ ، فَدَخَلَ عَلَیْہِ رَجُلٌ فَسَلَّمَ عَلَیْہِ ، فَأَثْنَی عَلَیْہِ رَجُلٌ مِنَ الْقَوْمِ فِی وَجْہِہِ ، فَقَالَ لہ عُمَرُ : عَقَرْت الرَّجُلَ عَقَرَک اللَّہُ ، تُثْنِی عَلَیْہِ فِی وَجْہِہِ فِی دِینِہِ۔",,,26787 26788,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ قَالَ : حدَّثَنَا عُبَیْدُ اللہِ بْنُ عُمَرَ ، عَن زَیْدِ بْنِ أَسْلَمَ ، عَنْ أَبِیہِ أَسْلَمَ ، قَالَ : سَمِعْتُ عُمَرَ یَقُولُ : الْمَدِیحُ الذَّبْحُ۔ (بخاری 336)",,,26788 26789,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الأَحْوَصِ قَالَ : قَالَ عَبْدُ اللہِ : إذَا طَلَبَ أَحَدُکُمُ الْحَاجَۃَ فَلْیَطْلُبْہَا طَلَبًا یَسِیرًا، وَلاَ یَأْتِی الرَّجُلَ فَیُثْنِیَ عَلَیْہِ فِی وَجْہِہِ فَیَقْطَعَ ظَہْرَہُ فَلاَ یَمْنَعُہُ شَیْئًا۔",,,26789 26790,"حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ قَالَ : حدَّثَنَا شُعْبَۃُ ، عَن خَالِدٍ الْحَذَّائِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی بَکْرَۃَ ، عَنْ أَبِیہِ قَالَ : مَدَحَ رَجُلٌ رَجُلاً عِنْدَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقَالَ لَہُ : النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : وَیْحَک ، قَطَعْت عُنُقَ صَاحِبِکَ مِرَارًا ، ثُمَّ قَالَ : إِنْ کَانَ أَحَدکم مَادِحًا أَخَاہُ لاَ مَحَالَۃَ فَلْیَقُلْ لَہُ : أَحْسَبُ ، وَلاَ أُزَکِّی عَلَی اللہِ أَحَدًا۔ (مسلم 2296۔ ابن ماجہ 3744)",,,26790 26791,"حَدَّثَنَا غُنْدَرٌ، عَن شُعْبَۃَ ، عَنْ عَاصِمٍ قَالَ : قُلْتُ لغنیم : أَیُکْرَہُ لِلرَّجُلِ أَنْ یَمْدَحَ أَخَاہُ وَہُوَ شَاہِدٌ؟ قَالَ: نَعَمْ ، فَقُلْت : وَإِنْ کَانَ غَائِبًا ؟ قَالَ : کَانَ یُقَالُ : لاَ تَمْدَحْ أَخَاک۔",,,26791 26792,"حَدَّثَنَا أَبُو دَاوُدَ عُمَرُ بْنُ سَعْدٍ ، عَن سُفْیَانَ، عَن لَیْثٍ، عَن طَاوُوس، عَنِ ابْنِ عَبَّاسٍ قَالَ: لاَ أُزَکِّی بعد النبی صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَحَدًا۔",,,26792 26793,"حَدَّثَنَا یُونُسُ بْنُ مُحَمَّدٍ قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ عَلِیِّ بْنِ الْحَکَمِ ، عَنْ عَطَائِ بْنِ أَبِی رَبَاحٍ ، أَنَّ رَجُلاً کَانَ یَمْدَحُ رَجُلاً عِنْدَ ابْنِ عُمَرَ ، فَجَعَلَ ابْنُ عُمَرَ یَحْثُو التُّرَابَ نَحْوَ وَجْہِہِ بِأَصَابِعِہِ ، وَقَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا رَأَیْتُمُ الْمَادِحِینَ فَاحْثُوا فِی أَفْوَاہِہِمُ التُّرَابَ ؟۔ \n\n(احمد 2/94۔ ابن حبان 5770)",,,26793 26794,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا سُفْیَانُ ، عَن مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، عَن ہَمَّامٍ قَالَ : جَائَ رَجُلٌ فَأَثْنَی عَلَی عُثْمَانَ فِی وَجْہِہِ فَأَخَذَ الْمِقْدَادُ بْنُ الأَسْوَدِ تُرَابًا فَحَثَاہُ فِی وَجْہِہِ ، وَقَالَ : إنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : إذَا لَقِیتُمُ الْمَدَّاحِینَ فَاحْثُوا فِی وُجُوہِہِمُ التُّرَابَ۔ (مسلم 2297۔ ابوداؤد 4771)",,,26794 26795,"حَدَّثَنَا وَکِیعٌ ، عَن سُفْیَانَ ، عَن عِمْرَانَ بْنِ مُسْلِمٍ ، عَنْ إبْرَاہِیمَ التَّیْمِیِّ ، عَنْ أَبِیہِ قَالَ : کُنَّا جُلُوسًا عِنْدَ عُمَرَ فَأَثْنَی رَجُلٌ عَلَی رَجُلٍ فِی وَجْہِہِ حِینَ أَدْبَرَ فَقَالَ عمر : عَقَرْت الرَّجُلَ ، عَقَرَک اللَّہُ۔",,,26795 26796,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ عَلِیِّ بْنِ زَیْدٍ ، عَن سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَنْ یَہْلَکَ امْرُؤٌ بَعْدَ مَشْورَۃٍ۔",,,26796 26797,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، عَن یَحْیَی بْنِ أَبِی کَثِیرٍ قَالَ : قَالَ سُلَیْمَانُ بْنُ دَاوُد لابْنِہِ : یَا بُنَیَّ ، لاَ تَقْطَعْ أَمْرًا حَتَّی تُؤَامِرَ مُرْشِدًا ، فَإِنَّک إذَا فَعَلْت ذَلِکَ لَمْ تَحْزَنْ عَلَیْہِ۔",,,26797 26798,"حَدَّثَنَا وَکِیعٌ، عَن سُفْیَانَ، عَن رَجُلٍ، عَنِ الضَّحَّاکِ قَالَ: مَا أَمَرَ اللَّہُ نَبِیَّہُ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِالْمُشَاوَرَۃِ إلاَّ لِمَا یَعْلَمَ فِیہَا مِنَ الْفَضْلِ ، ثُمَّ تَلاَ {وَشَاوِرْہُمْ فِی الأَمْرِ}۔",,,26798 26799,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ قَالَ : إذَا اخْتَلَفَ النَّاسُ فِی شَیْئٍ فَانْظُرْ کَیْفَ صَنَعَ فِیہِ عُمَرُ فَإِنَّہُ کَانَ لاَ یَصْنَعُ شَیْئًا حَتَّی یَسْأَلَ وَیُشَاوِرَ۔",,,26799 26800,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ إیَاسِ بْنِ دَغْفَلٍ قَالَ : حدَّثَنَا الْحَسَنُ قَالَ : مَا تشَاوَرَ قَوْمٌ إلاَّ ہُدُوا لأَرْشَدِ أَمْرِہِمْ۔",,,26800 26801,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ عَبْدِ الْحَمِیدِ بْنِ جَعْفَرٍ قَالَ : حدَّثَنَی أَبُو مُصْعَبٍ الأَنْصَارِیُّ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : اطْلُبُوا الْحَوَائِجَ إلَی حِسَانِ الْوُجُوہِ۔",,,26801 26802,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَن طَلْحَۃَ ، عَنْ عَطَائٍ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : ابْتَغُوا الْخَیْرَ عِنْدَ حِسَانِ الْوُجُوہِ۔ (ابن ابی الدنیا 53)",,,26802 26803,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْتَمِسُوا الْمَعْرُوفَ عِنْدَ حِسَانِ الْوُجُوہِ۔ (طبرانی 983)",,,26803 26804,"حَدَّثَنَا وَکِیعٌ، عَنِ ابْنِ عَوْنٍ، عَنْ إبْرَاہِیمَ قَالَ: کَانُوا یَکْرَہُونَ إذَا اجْتَمَعُوا أَنْ یُخْرِجَ الرَّجُلُ أَحْسَنَ حَدِیثِہِ۔",,,26804 26805,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی ہِلاَلٍ ، عَنِ ابْنِ بُرَیْدَۃَ ، قَالَ عُمَرُ : مَا تَعَلَّمَ الرَّجُلُ الْفَارِسِیَّۃَ إلاَّ خَبث ، وَلاَ خَبث إلاَّ نَقَصَتْ مُرُوئَتُہُ۔",,,26805 26806,"حَدَّثَنَا وَکِیعٌ ، عَن ثَوْرٍ ، عَنْ عَطَائٍ قَالَ : لاَ تَعَلَّمُوا رَطَانَۃَ الأَعَاجِمِ ، وَلاَ تَدْخُلُوا عَلَیْہِمْ کَنَائِسَہُمْ ، فَإِنَّ السَّخَطَۃ تَنْزِلُ عَلَیْہِمْ۔",,,26806 26807,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَن دَاوُد بْنِ أَبِی ہِنْدٍ ، أَنَّ مُحَمَّدَ بْنَ سَعْدِ بْنِ أَبِی وَقَّاصٍ سَمِعَ قَوْمًا یَتَکَلَّمُونَ بِالْفَارِسِیَّۃِ فَقَالَ : مَا بَالُ الْمَجُوسِیَّۃِ بَعْدَ الْحَنِیفِیَّۃِ۔",,,26807 26808,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی خَلْدَۃَ قَالَ : کَلَّمَنِی أَبُو الْعَالِیَۃِ بِالْفَارِسِیَّۃِ۔",,,26808 26809,"حَدَّثَنَا وَکِیعٌ ، عَنِ النَّہَّاسِ بْنِ قَہْمٍ ، قَالَ : سَمِعْتُ شَیْخًا بِمَکَّۃَ یَقُولُ : أَشْرَفَ أَبُو ہُرَیْرَۃَ مِنْ ہَذَا الْبَابِ عَلَی ہَذَا السُّوقِ فَقَالَ : یَا بَنِی فَرُّوخَ ، سحت وداست۔",,,26809 26810,"حَدَّثَنَا وَکِیعٌ ، عَن شُعْبَۃَ ، عَن مُحَمَّدِ بْنِ زِیَادٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أُتِیَ بِتَمْرٍ مِنَ الصَّدَقَۃِ ، فَتَنَاوَلَ الْحَسَنُ بْنُ عَلِیٍّ تَمْرَۃً فَلاَکَہَا فِی فِیہِ ، فَقَالَ لَہُ : النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : کِخْ کِخْ ، لاَ تَحِلُّ لَنَا الصَّدَقَۃُ۔",,,26810 26811,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَن حَبِیبِ بْنِ أَبِی عَمْرَۃَ ، عَن مُنْذِرٍ الثَّوْرِیِّ قَالَ : سَأَلَ رَجُلٌ ابْنَ الْحَنَفِیَّۃِ ، عَنِ الْجُبْنِ فَقَالَ: یَا جَارِیَۃُ، اذْہَبِی بِہَذَا الدِّرْہَمِ فَاشْتَرِی بِہِ ینیرا، فَاشْتَرَتْ بِہِ ینیرا، ثُمَّ جَائَتْ بِہِ یَعْنِی الْجُبْنَ۔",,,26811 26812,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَن بُرْدٍ ، عَنِ الزُّہْرِیِّ قِیلَ لَہُ : أَیَکْتَنِی الرَّجُلُ قَبْلَ أَنْ یُولَدَ لَہُ ؟ قَالَ : کَانَ رِجَالٌ مِنْ أَصْحَابِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَکْتَنُوا قَبْلَ أَنْ یُولَدَ لَہُمْ۔",,,26812 26813,"حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ قَالَ: کَنَّانِی عَبْدُ اللہِ بِأَبِی شِبْلٍ، وَکَانَ عَلْقَمَۃُ لاَ یُولَدُ لَہُ۔",,,26813 26814,"حَدَّثَنَا مُحَمَّدُ بْنُ الْحَسَنِ الأَسَدِیُّ ، عَنْ أَبِی عَوَانَۃَ ، عَن ہِلاَلِ بْنِ أَبِی حُمَیْدٍ قَالَ : کَنَّانِی عُرْوَۃُ قَبْلَ أَنْ یُولَدَ لِی۔",,,26814 26815,"حَدَّثَنَا وَکِیعٌ ، عَن ہِشَامٍ ، عَن مَوْلًی لِلزُّبَیْرِ ، عَنْ عَائِشَۃَ ، أَنَّہَا قَالَتْ لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : یَا رَسُولَ اللہِ ، کُلُّ أَزْوَاجِکَ قَدْ کَنَّیْتہ غَیْرِی ، قَالَ : فَأَنْتِ أُمُّ عَبْدِ اللہِ۔ (بخاری 851۔ ابوداؤد 4931)",,,26815 26816,"حَدَّثَنَا یَحْیَی بْنُ أَبِی بُکَیْرٍ قَالَ : حدَّثَنَا زُہَیْرُ بْنُ مُحَمَّدٍ ، عَنْ عَبْدِ اللہِ بْنِ مُحَمَّدِ بْنِ عَقِیلٍ ، عَن حَمْزَۃَ بْنِ صُہَیْبٍ ، أَنَّ عُمَرَ قَالَ لِصُہَیْبٍ : مَا لَکَ تَکْتَنِی بِأَبِی یَحْیَی وَلَیْسَ لَکَ وَلَدٌ ؟ قَالَ : کَنَّانِی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِأَبِی یَحْیَی۔ (ابن ماجہ 3738۔ احمد 16)",,,26816 26817,"حَدَّثَنَا وَکِیعٌ ، عَن شُعْبَۃَ ، عَنْ أَبِی التَّیَّاحِ ، عَنْ أَنَسٍ قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَأْتِینَا ، فَکَانَ یَقُولُ لأَخٍ لِی صَغِیرٍ : یَا أَبَا عُمَیْرٍ ، مَا فَعَلَ النُّغَیْرُ ؟۔",,,26817 26818,"حَدَّثَنَا وَکِیعٌ ، عَن سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ قَالَ : لاَ بَأْسَ أَنْ یَکْتَنِیَ الرَّجُلُ قَبْلَ أَنْ یُولَدَ لَہُ۔",,,26818 26819,"حَدَّثَنَا وَکِیعٌ ، عَن مِسْعَرٍ ، عَن شَیْخٍ ، قَالَ : سَمِعْتُ ابْنَ عُمَرَ ، أَوْ جَابِرًا قَالَ : کَانَ فِی کَلاَمِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ تَرْتِیلٌ ، أَوْ تَرْسِیلٌ۔ (ابوداؤد 4805)",,,26819 26820,"حَدَّثَنَا وَکِیعٌ، عَنْ أَبِی الْعُمَیْسِ، عَنْ عَطِیَّۃَ، عَنِ ابْنِ عُمَرَ قَالَ: الإنْبِعَاق فِی الْکَلاَمِ مِنْ شَقَاشِقِ الشَّیْطَانِ۔",,,26820 26821,"حَدَّثَنَا وَکِیعٌ ، عَن سُفْیَانَ ، عَن أُسَامَۃَ ، عَنِ الزُّہْرِیِّ ، عَن عُرْوَۃَ ، عَنْ عَائِشَۃَ رضی اللہ عنہا قَالَتْ : کَانَ کَلاَمُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَلاَمًا فَصْلاً ، یَفْہَمُہُ کُلُّ مَنْ سَمِعَہُ۔ \n\n(ابوداؤد 4806۔ ترمذی 3639)",,,26821 26822,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا نَافِعُ بْنُ عُمَرَ الْجُمَحِیُّ ، عَن بِشْرِ بْنِ عَاصِمٍ ، عَنْ أبِیہِ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو - قَالَ نَافِعٌ : أُرَاہُ رَفَعَہُ - قَالَ : إنَّ اللَّہَ یَبْغُضُ الْبَلِیغَ مِنَ الرِّجَالِ الَّذِی یَتَخَلَّلُ بِلِسَانِہِ تَخَلُّلَ الْبَاقِرَۃِ بِلِسَانِہَا۔ (ابوداؤد 4966۔ ترمذی 2853)",,,26822 26823,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا ابْنُ أَبِی خَالِدٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ عُمَیْرٍ قَالَ : قَامَ رَجُلٌ فَتَکَلَّمَ بَیْنَ یَدَیِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَتَّی أَزْبَدَ شِدْقَاہُ فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : تَعَلَّمُوا ، وَإِیَّاکُمْ وَشَقَاشِقَ الْکَلاَمِ ، فَإِنَّ شَقَاشِقَ الْکَلاَمِ مِنَ شَقَائِقِ الشَّیْطَانِ۔",,,26823 26824,حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ، عَن یَزِیدَ، عَنْ أَبِی جَعْفَرٍ، أَنَّہُ کَانَ یَکْرَہُ أَنْ یُسْمِعَ الْمُبْتَلَی التَّعْوِیذَ مِنَ الْبَلاَئِ۔,,,26824 26825,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَن مُجَاہِدٍ قَالَ : کَانَ یَکْرَہُ أَنْ یَقُولَ اللَّہُمَّ لاَ تَبْتَلِنِی إلاَّ بِالَّتِی ہِیَ أَحْسَنُ وَیَقُولُ : قَالَ اللَّہُ تَعَالَی : (وَنَبْلُوکُمْ بِالشَّرِّ وَالْخَیْرِ فِتْنَۃً)۔",,,26825 26826,حَدَّثَنَا عَبْدُ اللہِ بْنُ مُبَارَکٍ، عَن مَعْمَرٍ، عَنِ ابْنِ طَاوُوس، عَنْ أَبِیہِ، أَنَّہُ کَانَ إذَا اجْتَمَعَتْ عَندَہُ الرَّسَائِلُ أَمَرَ بِہَا فَأُحْرِقَتْ۔,,,26826 26827,حَدَّثَنَا وَکِیعٌ ، عَن سُفْیَانَ ، عَنِ النُّعْمَانِ بْنِ قَیْسٍ ، أَنَّ عَبِیدَۃَ أَوْصَی أَنْ تُمْحَی کُتُبُہُ۔,,,26827 26828,"حَدَّثَنَا مُعْتَمِرٌ ، عَن کَہْمَسٍ ، عَنْ عَبْدِ اللہِ بْنِ مُسْلِمِ بْنِ یَسَارٍ ، عَن مُسْلِمِ بْنِ یَسَارٍ قَالَ : کَانَ إذَا جَائَہُ الْکِتَابُ مَحَا مَا کَانَ فِیہِ مِنْ ذِکْرِ اللہِ ، ثُمَّ أَلْقَاہُ۔",,,26828 26829,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ جَامِعِ بْنِ شَدَّادٍ ، عَنِ الأَسْوَدِ بْنِ ہِلاَلٍ قَالَ : أُتِیَ عَبْدَ اللہِ بِصَحِیفَۃٍ فِیہَا حَدِیثٌ ، فَأَتَی بِمَائٍ فَمَحَاہَا ، ثُمَّ غَسَلَہَا ، ثُمَّ أَمَرَ بِہَا فَأُحْرِقَتْ۔",,,26829 26830,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ قَالَ : قُلْتُ لِعَبِیدَۃَ : وَجَدْت کِتَابًا أَقْرَؤُہُ ؟ قَالَ : لاَ۔ (ابوداؤد 1480)",,,26830 26831,حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ الْوَلِیدِ بْنِ ثَعْلَبَۃَ الطَّائِیِّ ، عَنِ الضَّحَّاکِ ، أَنَّہُ کَانَ یَکْرَہُ أَنْ یُکْتَبَ الْحَدِیثُ فِی الْکَرَارِیسِ۔,,,26831 26832,"حَدَّثَنَا وَکِیعٌ ، عَنِ الْوَلِیدِ بْنِ ثَعْلَبَۃَ ، عَنْ عَبْدِ اللہِ مُؤَذِّنِ الضَّحَّاکِ ، عَنِ الضَّحَّاکِ قَالَ : لاَ تَتَّخِذُوا لِلْحَدِیثِ کَرَارِیسَ کَکَرَارِیسِ الْمُصْحَفِ۔",,,26832 26833,حَدَّثَنَا وَکِیعٌ ، عَنِ الْحَسَنِ ، عَن لَیْثٍ ، عَن مُجَاہِدٍ ، أَنَّہُ کَرِہَ الْکَرَارِیسَ۔,,,26833 26834,حَدَّثَنَا وَکِیعٌ، عَنْ أَبِی عَوَانَۃَ، عَن سُلَیْمَانَ بْنِ أَبِی الْعَتِیکِ، عَنْ أَبِی مَعْشَرٍ، عَنْ إبْرَاہِیمَ، أَنَّہُ کَرِہَہَا۔,,,26834 26835,"حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَن عِیسَی ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: لاَ تَسُبُّوا اللَّیْلَ، وَلاَ النَّہَارَ، وَلاَ الشَّمْسَ، وَلاَ الْقَمَرَ، وَلاَ الرِّیحَ، فَإِنَّہَا تُبْعَثُ عَذَابًا عَلَی قَوْمٍ ، وَرَحْمَۃً عَلَی آخَرِینَ۔ (ابویعلی 2191)",,,26835 26836,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ الأَوْزَاعِیِّ ، عَنِ الزُّہْرِیِّ قَالَ : حدَّثَنَا ثَابِتٌ الزُّرَقِیُّ ، عَنْ أَبِی ہُرَیْرَۃَ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تَسُبُّوا الرِّیحَ فَإِنَّہَا مِنْ رُوحِ اللہِ ، تَأْتِی بِالرَّحْمَۃِ وَالْعَذَابِ ، وَلَکِنْ سَلُوا اللَّہَ مِنْ خَیْرِہَا ، وَتَعَوَّذُوا بِاللَّہِ مِنْ شَرِّہَا۔ (ابوداؤد 5056۔ احمد 268)",,,26836 26837,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ عَاصِمٍ الأَحْوَلِ ، عَنِ الْحَسَنِ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ فِی سَیْرٍ ، فَہَبَّتْ رِیحٌ ، فَکَشَفَتْ عَن رَجُلٍ قَطِیفَۃً کَانَتْ عَلَیْہِ ، فَلَعَنَہَا فَقَالَ لَہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : ألَعَنْتہَا ؟ قَالَ : یَا رَسُولَ اللہِ ، کَشَفَتْ قَطِیفَتِی ، فَقَالَ : إذَا رَأَیْتہَا فَسَلِ اللَّہَ مِنْ خَیْرِہَا ، وَتَعَوَّذْ بِاللَّہِ مِنْ شَرِّہَا ، وَلاَ تَلْعَنْہَا فَإِنَّہَا مَأْمُورَۃٌ۔ (ابوداؤد 4872۔ ترمذی 1978)",,,26837 26838,"حَدَّثَنَا شَبَابَۃُ قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنِ الْہَیْثمِ قَالَ : رَأَی عَاصِمُ بْنُ ضَمْرَۃَ قَوْمًا یَتَّبِعُونَ رَجُلاً فَقَالَ : إِنَّہَا فِتْنَۃٌ لِلْمَتْبُوعِ مَذَلَّۃٌ لِلتَّابِعِ۔",,,26838 26839,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ الْعَوَّامِ ، عَن حَبِیبِ بْنِ أَبِی ثَابِتٍ قَالَ : تَبعَ ابْنَ مَسْعُودٍ نَاسٌ فَجَعَلُوا یَمْشُونَ خَلْفَہُ فَقَالَ : أَلَکُمْ حَاجَۃٌ ؟ قَالُوا : لاَ ، قَالَ : ارْجِعُوا فَإِنَّہَا ذِلَّۃٌ لِلتَّابِعِ فِتْنَۃٌ لِلْمَتْبوعِ۔",,,26839 26840,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَن ہَارُونَ بْنِ عَنتَرَۃَ ، عَن سُلَیْمِ بْنِ حَنْظَلَۃَ قَالَ : أَتَیْنَا أُبَیَّ بْنَ کَعْبٍ لِنَتَحَدَّثَ عِندَہُ ، فَلَمَّا قَامَ قُمْنَا نَمْشِی مَعَہُ ، فَلَحِقَہُ عُمَرُ فَرَفَعَ عَلَیْہِ الدِّرَّۃَ فَقَالَ : یَا أَمِیرَ الْمُؤْمِنِینَ ، اعْلَمْ مَا تَصْنَعُ ؟ قَالَ : إنَّمَا تَرَی فِتْنَۃً لِلْمَتْبُوعِ ذِلَّۃً لِلتَّابِعِ۔",,,26840 26841,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَاصِمٍ قَالَ : لَم یَکُن ابن سِرِین یَتْرک أَحَدًا یَمشِی مَعَہُ۔",,,26841 26842,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَاصِمٍ قَالَ : کَانَ أَبُو الْعَالِیَۃِ إذَا جَلَسَ إلَیْہِ أَکْثَرُ مِنْ أَرْبَعَۃٍ قَامَ۔",,,26842 26843,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ قَالَ : حدَّثَنَا مِسْعَرٌ ، عَنْ عَبْدِ الْمَلِکِ بْنِ عُمَیْرٍ ، عَن مُصْعَبِ بْنِ سَعْدٍ ، عَن سَعْدٍ قَالَ : یَا بَنِیَّ ، تَعَلَّمُوا الرَّمْیَ فَإِنَّہُ خَیْرُ لَعِبِکُمْ۔",,,26843 26844,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَن مُحَمَّدِ بْنِ إِسْحَاقَ، عَن مُحَمَّدِ بْنِ إبْرَاہِیمَ، عَن رَافِعِ بْنِ سَالِمٍ الْفَزَارِیِّ قَالَ: مَرَّ عُمَرُ بْنُ الْخَطَّابِ بِنَا فَقَالَ : ارْمُوا ، فَإِنَّ الرَّمْیَ عُدَّۃٌ وَجَلاَدَۃٌ۔",,,26844 26845,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَن طَلْحَۃَ بْنِ یَحْیَی ، عَنْ أَبِی بُرْدَۃَ قَالَ : قَالَ سَعِیدُ بْنُ الْعَاصِ : إذَا عَلَّمْت وَلَدِی الْقُرْآنَ وَأَحْجَجْتُہُ وَزَوَّجْتہ ، فَقَدْ قَضَیْت حَقَّہُ ، وَبَقِیَ حَقِّی عَلَیْہِ۔",,,26845 26846,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَن لَیْثٍ ، عَن مُجَاہِدٍ قَالَ : لاَ تَحْضُرُ الْمَلاَئِکَۃُ شَیْئًا مِنْ لَہْوِکُمْ غَیْرَ الرِّہَانِ وَالرَّمْیِ ، نِعْمَ مُلْتَہَی الْمُؤْمِنِ الْقَوْسُ وَالنَّبْلُ۔",,,26846 26847,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَن حَجَّاجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَرَّ عَلَی أُنَاسٍ من أَسْلم یَرْمُونَ فَقَالَ : خُذُوا وَأَنَا مَعَ ابْنِ الأَدْرَعِ ، فَقَالُوا : یَا رَسُولَ اللہِ ، نَأْخُذُ وَأَنْتَ مَعَ بَعْضِنَا دُونَ بَعْضٍ ، فَقَالَ : خُذُوا وَأَنَا مَعَکُمْ یَا بَنِی إسْمَاعِیلَ۔ (بخاری 2899۔ احمد 4/50)",,,26847 26848,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ، عَنْ عَبْدِاللہِ بْنِ سَعِیدٍ، عَنْ أَبِیہِ، عَنِ ابن أَبِی حَدْرَدٍ الأَسْلَمِیِّ قَالَ: مَرَّ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِنَاسٍ مِنْ أَسْلَمَ وَہُمْ یَتَنَاضَلُونَ فَقَالَ: ارْمُوا یَا بَنِی إسْمَاعِیلَ، فَإِنَّ أَبَاکُمْ کَانَ رَامِیًا، ارْمُوا وَأَنَا مَعَ ابْنِ الأَدْرَعِ، فَأَمْسَکَ الْقَوْمُ بِأَیْدِیہِمْ فَقَالَ: مَا لَکُمْ لاَ تَرْمُونَ؟ قَالُوا: یَا رَسُولَ اللہِ، أَنَرْمِی وَقَدْ قُلْتَ: أَنَا مَعَ ابْنِ الأَدْرَعِ ، وَقَدْ عَلِمْنَا أَنَّ حِزْبَک لاَ یُغْلَبُ؟ قَالَ: ارْمُوا وَأَنَا مَعَکُمْ کُلِّکُمْ۔ (مسند 629)",,,26848 26849,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ عَبْدِ اللہِ بْنِ سَعِیدٍ ، عَنْ أَبِیہِ ، عَن رَجُلٍ مِنْ أَسْلَمَ یُقَالُ لَہُ ابْنُ الأَدْرَعِ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : تَمَعْدَدُوا وَاخْشَوْشِنُوا وَانْتَضِلُوا وَامْشُوا حُفَاۃً۔ (طبرانی 84)",,,26849 26850,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : أَخْبَرَنَا الدَّسْتَوَائِیُّ ، عَن یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ أَبِی سَلاَّمٍ ، عَنْ عَبْدِ اللہِ بْنِ الأَزْرَقِ ، عَن عُقْبَۃَ بْنِ عَامِرٍ الْجُہَنِیِّ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : إنَّ اللَّہَ لَیُدْخِلُ بِالسَّہْمِ الْوَاحِدِ الثَّلاَثَۃَ الْجَنَّۃَ : صَانِعَہُ یَحْتَسِبُ فِی صَنْعَتِہِ الْخَیْرَ ، وَالرَّامِیَ بِہِ ، وَالْمُمِدَّ بِہِ ، وَقَالَ : ارْمُوا وَارْکَبُوا، وَإِنْ تَرْمُوا أَحَبُّ إلَیَّ مِنْ أَنْ تَرْکَبُوا ، وَکُلُّ مَا یَلْہُو بِہِ الْمَرْئُ الْمُسْلِمُ بَاطِلٌ إلاَّ رَمْیَہُ بِقَوْسِہِ ، وَتَأْدِیبَہُ فَرَسَہُ، وَمُلاَعَبَتَہُ أَہْلَہُ ، فَإِنَّہُنَّ مِنَ الْحَقِّ۔",,,26850 26851,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ بْنِ جَابِرٍ قَالَ : حدَّثَنَا أَبُو سَلاَّمٍ الدِّمَشْقِیُّ ، عَن خَالِدِ بْنِ زَیْدٍ الْجُہَنِیِّ ، عَن عُقْبَۃَ بْنِ عَامِرٍ ، عَن رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَذَکَرَہُ نَحْوَہُ إلاَّ أَنَّہُ قَالَ : وَمُنَبِّلَہُ۔ (ابوداؤد 2505۔ احمد 4/146)",,,26851 26852,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنِ الأَوْزَاعِیِّ ، عَن بِلاَلِ بْنِ سَعْدٍ قَالَ : أَدْرَکْتہمْ یَشْتَدُّونَ بَیْنَ الأَغْرَاضِ وَیَضْحَکُ بَعْضُہُمْ إلَی بَعْضٍ ، فَإِذَا کَانَ اللَّیْلُ کَانُوا رُہْبَانًا۔",,,26852 26853,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ، عَنِ الأَعْمَشِ، عَنْ إبْرَاہِیمَ التَّیْمِیِّ، عَنْ أَبِیہِ قَالَ: رَأَیْتُ حُذَیْفَۃَ یَشْتدُّ بَیْنَ الْہَدَفَیْنِ۔",,,26853 26854,"حَدَّثَنَا أَبُو بَکْر بْنُ عَیَّاشٍ ، عَنْ عَاصِمٍ ، عَنْ أَبِی الْعَدَبَّسِ ، قَالَ : سَمِعْتُ عُمَرَ یَقُولُ : أَخِیفُوا الْہَوَامَّ قَبْلَ أَنْ تُخِیفَکُمْ ، وَانْتَضِلُوا وَتَمَعْدَدُوا وَاخْشَوْشِنُوا وَاجْعَلُوا الرَّأْسَ رَأْسَیْنِ ، وَفَرِّقُوا عَنِ الْمَنِیَّۃِ ، وَلاَ تُلِثُّوا بِدَارٍ مُعْجِزَۃٍ ، وَأَخِیفُوا الْحَیَّاتِ قَبْلَ أَنْ تُخِیفَکُمْ وَأَصْلِحُوا مَثَاوِیَکُمْ۔",,,26854 26855,حَدَّثَنَا زِیَادُ بْنُ الرَّبِیعِ ، عَن یُونُسَ بْنِ عُبَیْدٍ ، عَنْ أَبِی قِلاَبَۃَ ، أَنَّ ابْنَ عَبَّاسٍ کَانَ إذَا خَرَجَ مِنْ بَیْتِہِ إلَی الْمَسْجِدِ عَرَفَ جِیرَانُ الطَّرِیقِ ، أَنَّہُ قَدْ مَرَّ مِنْ طِیبِ رِیحِہِ۔,,,26855 26856,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ أَبِی الْعُمَیْسِ ، عَنِ الْقَاسِمِ بْنِ عَبْدِ الرَّحْمَنِ قَالَ : کَانَ عَبْدُ اللہِ یَتَطَیَّبُ بِطِیبٍ فِیہِ مِسْکٌ۔",,,26856 26857,"حَدَّثَنَا عَلِیُّ بْنُ حَفْصٍ قَالَ : أَخْبَرَنَا ابْنُ أَبِی ذِئْبٍ ، عَن عُثْمَانَ بْنِ عُبَیْدِ اللہِ مَوْلًی لِسَعْدِ بْنِ أَبِی وَقَّاصٍ قَالَ : رَأَیْتُ ابْنَ عُمَرَ وَأَبَا ہُرَیْرَۃَ وَأَبَا قَتَادَۃَ وَأَبَا أُسَیْدَ السَّاعِدِیَّ یَمُرُّونَ عَلَیْنَا وَنَحْنُ فِی الْکُتَّابِ فَنَجِدُ مِنْہُمْ رِیحَ الْعَبِیرِ وَہُوَ الْخَلُوقُ۔",,,26857 26858,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ إبْرَاہِیمَ قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُعْرَفُ بِرِیحِ الطِّیبِ إذَا أَقْبَلَ۔ (عبدالرزاق 7934۔ ابن سعد 398)",,,26858 26859,"حَدَّثَنَا وَکِیعٌ ، عَن مِسْعَرٍ ، عَن مُحَمَّدِ بْنِ جُحَادَۃَ ، عَن طَلْحَۃَ بْنِ مُصَرِّفٍ قَالَ : کَانَ ابْنُ مَسْعُودٍ یُعْرَفُ بِرِیحِ الطِّیبِ۔",,,26859 26860,"حَدَّثَنَا وَکِیعٌ ، عَنِ الْمَسْعُودِیِّ ، عَن سُلَیْمَانَ بْنِ مِینَائَ ، عَن نُفَیْعٍ مَوْلَی عَبْدِ اللہِ قَالَ : کَانَ عَبْدُ اللہِ مِنْ أَطْیَبِ النَّاسِ رِیحًا ، وَأَنْقَاہُمْ ثَوْبًا أَبْیَضَ۔",,,26860 26861,"حَدَّثَنَا وَکِیعٌ ، عَن مُحَمَّدِ بْنِ قَیْسٍ ، عَنِ الشَّعْبِیِّ قَالَ : کَانَ عَبْدُ اللہِ بْنُ جَعْفَرٍ یَسْحَقُ الْمِسْکَ ، ثُمَّ جَعَلَہُ عَلَی یَافُوخِہِ۔",,,26861 26862,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، أَنَّ عُمَرَ بْنَ الْخَطَّابِ خَرَجَ یَوْمَ عِیدٍ ، فَمَرَّ بِالنِّسَائِ ، فَوَجَدَ رِیحَ رَأْسِ امْرَأَۃٍ فَقَالَ : مَنْ صَاحِبَۃُ ہَذَا ؟ أَمَا لَوْ عَرَفْتہَا لَفَعَلْت وَفَعَلْت ، إنَّمَا تَطَیَّبُ الْمَرْأَۃُ لِزَوْجِہَا، فَإِذَا خَرَجَتْ لَبِسَتْ أُطَیْمِرَہَا ، أَوْ أُطَیْمِرَ خَادِمِہَا ، فَتَحَدَّثَ النِّسَائُ ، أَنَّہَا قَامَتْ عَن حَدَثٍ۔",,,26862 26863,"حَدَّثَنَا وَکِیعٌ ، عَن ثَابِتِ بْنِ عُمَارَۃَ ، عَن غُنَیْمِ بْنِ قَیْسٍ ، عَنْ أَبِی مُوسَی قَالَ : أَیُّمَا امْرَأَۃٍ استعْطرَتْ ، ثُمَّ خَرَجَتْ لتُوجَدَ رِیحُہَا فَہِی فَاعِلَۃ ، وَکُل عَین فَاعِلَۃ۔",,,26863 26864,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانُ ، عَنْ عَاصِمِ بْنِ عُبَیْدِ اللہِ ، عَنْ عُبَیْدٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَیُّمَا امْرَأَۃٍ تَطَیَّبَتْ ثُمَّ خَرَجَتْ إلَی الْمَسْجِدِ لِیُوجَدَ رِیحُہَا ، لَمْ تُقْبَلْ لَہَا صَلاَۃٌ حَتَّی تَغْتَسِلَ اغْتِسَالَہَا مِنَ الْجَنَابَۃِ۔ (ابوداؤد 4171۔ احمد 2/246)",,,26864 26865,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَن مُحَمَّدِ بْنِ عَجْلاَنَ ، عَن یَعْقُوبَ بْنِ عَبْدِ اللہِ بْنِ الأَشَجِّ ، عَن بُسْرِ بْنِ سَعِیدٍ ، عَن زَیْنَبَ امْرَأَۃِ عَبْدِ اللہِ قَالَتْ : قَالَ لَنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا خَرَجَتْ إحْدَاکُنَّ إلَی الْمَسْجِدِ فَلاَ تَمَسَّ طِیبًا۔ (مسلم 328۔ احمد 6/363)",,,26865 26866,حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی الْعُمَیْسِ ، عَنِ الْقَاسِمِ بن أَبِی بَزَّۃَ ، عَنْ أَبِی عُبَیْدَۃَ ، عَنْ عَبْدِ اللہِ بْنِ مَسْعُودٍ ، أَنَّہُ وَجَدَ مِنِ امْرَأَتِہِ رِیحَ مِجْمَرٍ وَہِیَ بِمَکَّۃَ ، فَأَقْسَمَ عَلَیْہَا أَلاَ تَخْرُجَ تِلْکَ اللَّیْلَۃَ۔,,,26866 26867,"حَدَّثَنَا وَکِیعٌ ، عَن کَثِیرِ بْنِ زَیْدٍ ، عَن عُثْمَانَ بْنِ عَبْدِ اللہِ بْنِ سُرَاقَۃَ ، عَن أُمِّہِ قَالَتْ : نَزَلَ بِی حَمَوِیٌّ فَمَسِسْت طِیبًا ، ثُمَّ خَرَجْت فَأَرْسَلَتْ إلَیَّ حَفْصَۃُ : إنَّمَا الطِّیبُ لِلْفِرَاشِ۔",,,26867 26868,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، أَنَّ امْرَأَتَہُ اسْتَأْذَنَتْہُ أَنْ تَأْتِیَ أَہْلَہَا ، فَأَذِنَ لَہَا فَوَجَدَ بِہَا رِیحُ دُخْنۃ فحبسہا ، وَقَالَ : إنَّ الْمَرْأَۃَ إذَا تَطَیَّبَتْ ثُمَّ خَرَجَتْ فَإِنَّمَا طِیبُہَا شَنَارٌ فِیہِ نَارٌ۔",,,26868 26869,"حَدَّثَنَا وَکِیعٌ ، عَن مُوسَی بْنِ عُبَیْدَۃَ ، عَن مُحَمَّدِ بْنِ الْمُنْکَدِرِ قَالَ : زَارَتْ أَسْمَائُ أُخْتَہَا عَائِشَۃَ ، وَالزُّبَیْرُ غَائِبٌ ، فَدَخَلَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَوَجَدَ رِیحَ طِیبٍ فَقَالَ : مَا عَلَی امْرَأَۃٍ أَنْ لاَ تَطَیَّبَ وَزَوْجُہَا غَائِبٌ۔ (طبرانی 280)",,,26869 26870,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ، عَنِ ابْنِ عَجْلاَنَ، عَنْ عَبْدِ اللہِ بْنِ دِینَارٍ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: الإِیمَانُ سِتُّونَ ، أَوْ سَبْعُونَ ، أَوْ بِضْعَۃٌ وَاحِدُ الْعَدَدَیْنِ: أَعْلاَہَا شَہَادَۃُ أَنْ لاَ إلَہَ إلاَّ اللَّہُ ، وَأَدْنَاہَا إمَاطَۃُ الأَذَی عَنِ الطَّرِیقِ ، وَالْحَیَائُ شُعْبَۃٌ مِنَ الإِیمَانِ۔ (بخاری 9۔ مسلم 63)",,,26870 26871,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبَانَ بْنِ صَمْعَۃَ ، عَنْ أَبِی الْوَازِعِ ، عَنْ أَبِی بَرْزَۃَ قَالَ : قُلْتُ : یَا رَسُولَ اللہِ ، دُلَّنِی عَلَی عَمَلٍ أَنْتَفِعُ بِہِ ، قَالَ : نَحِّ الأَذَی عَن طَرِیقِ الْمُسْلِمِینَ۔ (مسلم 2021۔ ابن ماجہ 3681)",,,26871 26872,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : أَخْبَرَنَا جَرِیرُ بْنُ حَازِمٍ قَالَ : حَدَّثَنَا بَشَّارُ بْنُ أَبِی سَیْفٍ ، عَنِ الْوَلِیدِ بْنِ عَبْدِ الرَّحْمَنِ ، عَن عِیَاضِ بْنِ غُطَیْفٍ ، عَنْ أَبِی عُبَیْدَۃَ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : مَنْ عَادَ مَرِیضًا ، أَوْ أَنْفَقَ عَلَی أَہْلِہِ ، أَوْ مَازَ أَذًی عَن طَرِیقٍ فَحَسَنَۃٌ بِعَشْرَۃِ أَمْثَالِہَا۔",,,26872 26873,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَن یَحْیَی بْنِ سَعِیدٍ ، عَن مُحَمَّدِ بْنِ یَحْیَی بْنِ حَبَّانَ قَالَ : خَرَجَ رَجُلٌ مَعَ مُعَاذٍ ، فَجَعَلَ لاَ یَرَی أَذًی فِی طَرِیقٍ إلاَّ نَحَّاہُ ، فَلَمَّا رَأَی ذَلِکَ الرَّجُلُ جَعَلَ لاَ یَمُرُّ بِشَیْئٍ إلاَّ نَحَّاہُ ، فَقَالَ لَہُ : مَا حَمَلَک عَلَی ہَذَا ؟ قَالَ : الَّذِی رَأَیْتُک تَصْنَعُ ، قَالَ : أَصَبْت ، أَوْ أَحْسَنْت ، إِنَّہُ مَنْ أَمَاطَ أَذًی ، عَن طَرِیقٍ کُتِبَتْ لَہُ حَسَنَۃٌ ، وَمَنْ کُتِبَتْ لَہُ حَسَنَۃٌ دَخَلَ الْجَنَّۃَ۔",,,26873 26874,"حَدَّثَنَا الْحَسَنُ بْنُ مُوسَی ، قَالَ : سَمِعْتُ أَبَا ہِلاَلٍ قَالَ : حَدَّثَنَا قَتَادَۃُ ، عَنْ أَنَسٍ قَالَ : کَانَتْ شَجَرَۃٌ عَلَی طَرِیقِ النَّاسِ، فَکَانَتْ تُؤْذِیہِمْ، فَعَزَلَہَا رَجُلٌ، عَن طَرِیقِ النَّاسِ، قَالَ: قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: فَلَقَدْ رَأَیْتہ یَتَقَلَّبُ فِی ظِلِّہَا فِی الْجَنَّۃِ۔ (احمد 154۔ ابویعلی 3048)",,,26874 26875,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : کَانَ عَلَی طَرِیقٍ غُصْنُ شَجَرَۃٍ یُؤْذِی النَّاسَ ، فَأَمَاطَہَا رَجُلٌ فَأُدْخِلَ الْجَنَّۃَ۔ (ابن ماجہ 3682)",,,26875 26876,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : أَخْبَرَنَا ہِشَامُ بْنُ حَسَّانَ ، عَن وَاصِلٍ مَوْلَی أَبِی عُیَیْنَۃَ ، عَن یَحْیَی بْنِ عَقِیلٍ، عَن یَحْیَی بْنِ یَعْمُرَ، عَنْ أَبِی ذَرٍّ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ: عُرِضَتْ عَلَیَّ أُمَّتِی بِأَعْمَالِہَا، حَسَنِہَا وَسَیِّئِہَا ، فَرَأَیْت فِی مَحَاسِنِ أَعْمَالِہَا الأَذَی یُنَحَّی عَنِ الطَّرِیقِ ، وَرَأَیْت فِی سَیِّیء أَعْمَالِہَا النُّخَامَۃُ فِی الْمَسْجِدِ لاَ تُدْفَنُ۔ (مسلم 390۔ احمد 5/180)",,,26876 26877,"حَدَّثَنَا أَبُو أُسَامَۃَ قَالَ : حدَّثَنَا إسْمَاعِیلُ بن قَیْسٍ ، قَالَ : سَمِعْتُ سَعْدًا یَقُولُ : اتَّقُوا ہَذِی الْمُلاَعِن ، ثُمَّ قَالَ إسْمَاعِیلُ : یَعْنِی التَّحَشُّشَ عَلَی ظَہْرِ الطَّرِیقِ۔",,,26877 26878,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنْ عَوْنِ بْنِ عَبْدِ اللہِ ، عَنْ أَبِی ہُرَیْرَۃَ قَالَ : إیَّاکُمْ وَالْمُلاَعن ، قَالُوا : وَمَا الْمُلاَعِنُ ؟ قَالَ : قَارِعَۃُ الْجُلُوسِ عَلَی الطَّرِیقِ وَتَحْتَ الشَّجَرَۃِ یَسْتَظِلُّ تَحْتَہَا الرَّاکِبُ۔\n\n(مسلم 226۔ ابوداؤد 26)",,,26878 26879,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : أَخْبَرَنَا ہِشَامٌ ، عَنِ الْحَسَنِ ، عَنْ جَابِرٍ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تَنْزِلُوا عَلَی جَوَادِّ الطَّرِیقِ ، وَلاَ تَقْضُوا عَلَیْہَا الْحَاجَاتِ۔",,,26879 26880,"حَدَّثَنَا وَکِیعٌ ، عَن شُعْبَۃَ ، عَن خُلَیْدِ بْنِ جَعْفَرٍ ، عَنْ أَبِی نَضْرَۃَ ، عَنْ أَبِی سَعِیدٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ذَکَرَ الْمِسْکُ فَقَالَ : ہُوَ أَطْیَبُ طِیبِکُمْ۔ (مسلم 1766)",,,26880 26881,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ عَوْنٍ ، عَن ابْنِ سِیرِینَ ، عَن ابن عُمَر قَالَ : أَطْیَب طیبکم : الْمِسْکَ۔",,,26881 26882,حَدَّثَنَا وَکِیعٌ ، عَنْ إبْرَاہِیمَ بْنِ إسْمَاعِیلَ ، عَن عُبَیْدٍ مَوْلَی سَلَمَۃَ ، عَن سَلَمَۃَ ، أَنَّہُ کَانَ إذَا تَوَضَّأَ أَخَذَ الْمِسْکَ فَمَسَحَ بِہِ وَجْہَہُ وَیَدَیْہِ۔,,,26882 26883,"حَدَّثَنَا وَکِیعُ ، عَن مُحَمَّدِ بْنِ قَیْسٍ ، عَنِ الشَّعْبِیِّ قَالَ : کَانَ عَبْدُ اللہِ بْنُ جَعْفَرٍ یَسْحَقُ الْمِسْکَ ، ثُمَّ یَجْعَلُہُ عَلَی یَافُوخِہِ۔",,,26883 26884,"حَدَّثَنَا وَکِیعٌ ، عَنِ الرَّبِیعِ ، عَنِ ابْنِ سِیرِینَ قَالَ : لاَ بَأْسَ بِالْمِسْکِ لِلْحَیِّ وَالْمَیِّتِ۔",,,26884 26885,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی رَوَّادٍ ، عَنِ الضَّحَّاکِ قَالَ : الْمِسْکُ مَیْتَۃٌ وَدَمٌ۔",,,26885 26886,حَدَّثَنَا وَکِیعٌ ، عَن سُفْیَانَ ، عَن لَیْثٍ ، عَن مُجَاہِدٍ ، أَنَّہُ کَرِہَ أَنْ یُجْعَلَ الْمِسْکُ فِی الْمُصْحَفِ۔,,,26886 26887,حَدَّثَنَا وَکِیعٌ ، عَنِ الرَّبِیعِ ، عَنِ الْحَسَنِ ، أَنَّہُ کَانَ یَکْرَہُ الْمِسْکَ لِلْحَیِّ وَالْمَیِّتِ۔,,,26887 26888,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَن سُفْیَانَ ، عَن عِمْرَانَ بْنِ مُسْلِمٍ ، عَنْ عَلِیِّ بْنِ عُمَارَۃَ قَالَ : جَائَ أَبُو أَیُّوبَ ، فَأَرَادَ أَنْ یَبِیتَ عَلَی سَطْحٍ لَنَا أَجْلَحَ ، قَالَ : کِدْت أَنْ أَبَیْت اللَّیْلَۃَ لاَ ذِمَّۃَ لِی۔",,,26888 26889,"حَدَّثَنَا مَرْوَانُ ، عَنِ الْعَلاَء بْنِ عَبْدِ الرَّحْمَنِ قَالَ : سَأَلْتُ مُجَاہِدًا عَنِ الرَّجُلِ یَنَامُ فَوْقَ السَّطْحِ لَیْسَ عَلَیْہِ حَائِطٌ ، فَقَالَ مُجَاہِدٌ : إنَّمَا قِیلَ ذَاکَ لِمَنْ سَقَطَ فَمَات۔",,,26889 26890,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ عَمْرِو بْنِ عَلْقَمَۃَ ، عَنِ ابْنِ أَبِی حُسَیْنٍ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تَقْطَعْ مَنْ کَانَ یَصِلُ أَبَاک ، یُطْفَأْ بِذَلِکَ نُورُک ، إنَّ وِدَّک وِدُّ أَبِیک۔ (مسلم11۔ ابوداؤد 5100)",,,26890 26891,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَن ہَارُونَ بْنِ عَنتَرَۃَ ، عَنْ عَوْنِ بْنِ عَبْدِ اللہِ قَالَ : قَالَ عَبْدُ اللہِ : صِلْ مَنْ کَانَ أَبُوک یُوَاصِلُ ، فَإِنَّ صِلَۃً للْمَیِّتِ فِی قَبْرِہِ أَنْ تَصِلَ مَنْ کَانَ یُوَاصِلُ۔",,,26891 26892,"حَدَّثَنَا عَفَّانُ قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَن ثَابِتٍ ، عَن بِلاَلٍ ، عَنْ أَبِیہِ قَالَ : إن مِنْ صِلَۃِ الرَّجُلِ أَبَاہُ أَنْ یَصِلَ إخْوَانَہُ الَّذِینَ کَانَ یَصِلُہُمْ ، قَالَ حَمَّادٌ : أَحْسَبُہُ ، عَنْ أَبِی مُوسَی ، قِیلَ لِحَمَّادٍ : بِلاَلُ بْنُ أَبِی بُرْدَۃَ ؟ قَالَ : نَعَمْ۔",,,26892 26893,"حَدَّثَنَا ابْنُ نُمَیْرٍ قَالَ : حدَّثَنَا ہِشَامٌ ، عَنْ أَبِیہِ قَالَ : مَکْتُوبٌ فِی التَّوْرَاۃِ : أَحْبِبْ حَبِیبَک وَحَبِیبَ أَبِیک۔",,,26893 26894,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : أَخْبَرَنَا أَبُو عَقِیلٍ قَالَ : حَدَّثَنَا سَلَمَۃُ بْنُ عَبْدِ اللہِ بْنِ عُمَرَ ، أَنَّ عُمَرَ بْنَ الْخَطَّابِ قَالَ : تَرِّبُوا صُحُفَکُمْ أَنْجَحُ لَہَا۔",,,26894 26895,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : أَخْبَرَنَا بَقِیَّۃُ قَالَ : حَدَّثَنَا أَبُو أَحْمَدَ الدِّمَشْقِیِّ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : تَرِّبُوا صُحُفَکُمْ أَنْجَحُ لَہَا وَالتُّرَابُ مُبَارَکٌ۔\n\n(ترمذی 2713۔ ابن ماجہ 3774)",,,26895 26896,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : أَخْبَرَنَا أَبُو شَیْبَۃَ ، عَن رَجُلٍ ، عَنِ الشَّعْبِیِّ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : تَرِّبُوا صُحُفَکُمْ أَعْظَمُ لِلْبَرَکَۃِ۔",,,26896 26897,"حَدَّثَنَا شَرِیکٌ ، عَنِ الْعَبَّاسِ بْنِ ذُرَیْحٍ ، عَنِ الشَّعْبِیِّ قَالَ : قَالَ ابْنُ عَبَّاسٍ : إنِّی لأَرَی لِجَوَابِ الْکِتَابِ عَلَیَّ حَقًّا کَرَدِّ السَّلاَمِ۔ (ابن عدی 176)",,,26897 26898,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ عَاصِمٍ الأَحْوَلِ ، عَنْ عَامِرٍ ، عَنِ ابْنِ عُمَرَ قَالَ : مَا کُنْت أُبَالِی لَوْ کُنْت عَاشِرَ عَشَرَۃٍ عَلَی دَابَّۃٍ بَعْدَ أَنْ تُطِیقَنَا۔",,,26898 26899,حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَن خَالِدٍ ، عَن عِکْرِمَۃَ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ تَلَقَّاہُ غُلاَمَانِ مِنْ بَنِی عَبْدِ الْمُطَّلِبِ ، فَحَمَلَ وَاحِدًا بَیْنَ یَدَیْہِ وَالآخَرَ خَلْفَہُ۔ (عبدالرزاق 19482),,,26899 26900,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَن حَبِیبِ بْنِ الشَّہِیدِ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ قَالَ : قَالَ عَبْدُ اللہِ بْنُ جَعْفَرٍ لابْنِ الزُّبَیْرِ : أَتَذْکُرُ إذْ تَلَقَّیْنَا رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنَا وَأَنْتَ ، وَابْنُ عَبَّاسٍ ؟ قَالَ : نَعَمْ ، فَحَمَلَنَا وَتَرَکَک۔ (مسلم 1885۔ احمد 1/203)",,,26900 26901,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ، عَنْ عَاصِمٍ قَالَ: حدَّثَنَا مُوَرِّقُ الْعِجْلِیّ قَالَ: حَدَّثَنَی عَبْدُ اللہِ بْنُ جَعْفَرٍ قَالَ: کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا قَدِمَ مِنْ سَفَرٍ تُلُقِّیَ بِنَا ، قَالَ: فَتُلُقِّیَ بِی ، وَبِالْحَسَنِ، أَوْ بِالْحُسَیْنِ ، قَالَ : فَحَمَلَ أَحَدَنَا بَیْنَ یَدَیْہِ ، وَالآخَرَ خَلْفَہُ ، حَتَّی دَخَلْنَا الْمَدِینَۃَ۔ (ابوداؤد 2559۔ احمد 203)",,,26901 26902,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَن سُفْیَانَ الْعَطَّارِ ، قَالَ : رَأَیْتُ الشَّعْبِیَّ مُرْتَدِفًا خَلْفَ رَجُلٍ ، قَالَ : وَکَانَ یَقُولُ : صَاحِبُ الدَّابَّۃِ أَحَقُّ بِمُقَدَّمِہَا۔",,,26902 26903,حَدَّثَنَا عَبْدُالْوَہَّابِ الثَّقَفِیُّ، عَن خَالِدٍ، عَن مُحَمَّدِ بْنِ سِیرِینَ، أَنَّہُ کَانَ یَکْرَہُ أَنْ یَرْکَبَ ثَلاَثَۃٌ عَلَی دَابَّۃٍ۔,,,26903 26904,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الأَجْلَحِ ، عَنِ الشَّعْبِیِّ قَالَ : أَیُّمَا ثَلاَثَۃٍ رَکِبُوا عَلَی دَابَّۃٍ فَأَحَدُہُمْ مَلْعُونٌ۔",,,26904 26905,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَن جِبْرِیلَ بْنِ أَحْمَرَ ، عَنِ ابْنِ بُرَیْدَۃَ قَالَ : رَآنِی أَبِی رِدْفَ ثَالِثٍ فَقَالَ : مَلْعُونٌ۔",,,26905 26906,"حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِر ، عَنْ عَامِرٍ قَالَ : خَرَجْتُ إلَی الْحِیرَۃِ أَنْظُرُ إلَی الْفِیلِ ، فَرَأَیْت الْحَارِثَ الأَعْوَرَ رَاکِبًا وَخَلْفَہُ رِدْفٌ ، قَالَ : فَقَالَ : لَوْ صَلُحَ ثَلاَثَۃٌ حَمَلْنَاک۔",,,26906 26907,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ إسْمَاعِیلَ ، عَن حسن ، عَن مُہَاجِرِ بْنِ قُنْفُذٍ قَالَ : کُنَّا نَتَحَدَّثُ مَعَہُ إذْ مَرَّ ثَلاَثَۃٌ عَلَی حِمَارٍ ، فَقَالَ لِلآخِرِ مِنْہُمْ : انْزِلْ لَعَنَک اللَّہُ ، قَالَ : فَقِیلَ لَہُ : تَلْعَنُ ہَذَا الإِِنْسَان ؟ قَالَ : فَقَالَ : إنَّا قَدْ نُہِینَا عَن ہَذَا : أَنْ یَرْکَبَ الثَّلاَثَۃُ عَلَی الدَّابَّۃِ۔ (طبرانی 782)",,,26907 26908,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی الْعَنْبَسِ ، عَن زَاذَانَ قَالَ : رَأَی ثَلاَثَۃً عَلَی بَغْلٍ فَقَالَ لِیَنْزِلْ أَحَدُکُمْ ، فَإِنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لَعَنَ الثَّالِثَ۔ (ابوداؤد 299)",,,26908 26909,"حَدَّثَنَا وَکِیعٌ ، عَن بَشِیرِ بْنِ سَلْمَانَ ، عَن سَیَّارِ أَبِی الْحَکَمِ ، عَن طَارِقِ بْنِ شِہَابٍ قَالَ : کَانَ عَبْدُ اللہِ إذَا صَلَّی الْفَجْرَ لَمْ یَدَعْ أَحَدًا مِنْ أَہْلِہِ صَغِیرًا ، وَلاَ کَبِیرًا یُطرِق حَتَّی تَطْلُعَ الشَّمْسُ۔",,,26909 26910,"حَدَّثَنَا وَکِیعٌ ، عَن فُضَیْلِ بْنِ غَزْوَانَ ، عَن مُہَاجِرِ بْنِ شَمَّاسٍ ، عَنْ عَمِّہِ قَالَ : کُنْتُ أَخْرُجُ إلَی جَبَّانَۃٍ مِنْ ہَذِہِ الْجَبَابِینِ أَنْصِبُ بِفَخٍّ لِی ، فَخَرَجْت ثَلاَثَ غَدَوَاتٍ أَرَی رَجُلاً بَعْدَ الْفَجْرِ جَالِسًا فِی مَکَان، قُلْتُ: یَا عَبْدَ اللہِ ، مَنْ أَنْتَ ؟ قَالَ : أَنَا حُذَیْفَۃُ بْنُ الْیَمَانِ ، قَالَ : قُلْتُ : أَیُّ شَیْئٍ تَصْنَعُ ہَاہُنَا ؟ قَالَ : أَنْظُرُ إلَی الشَّمْسِ مِنْ أَیْنَ تَطْلُعُ ؟۔",,,26910 26911,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ قَالَ: حدَّثَنَا إسْمَاعِیلُ قَالَ: حَدَّثَنی قَیْسُ بْنُ أَبِی حَازِمٍ، عَن مُدْرِکِ بْنِ عَوْفٍ قَالَ: مَرَرْت عَلَی بِلاَلٍ وَہُوَ بِالشَّامِ جَالِسٌ غُدْوَۃً، فَقُلْت: مَا یُجلسک یَا أَبَا عَبْدِ اللہِ، قَالَ: أَنْتَظِرُ طُلُوعَ الشَّمْسِ۔",,,26911 26912,حَدَّثَنَا أَبُو الأَحْوَصِ ، عَن سِمَاکٍ ، عَنْ جَابِرِ بْنِ سَمُرَۃَ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ إذَا صَلَّی الْفَجْرَ جَلَسَ فِی مُصَلاَّہُ حَتَّی تَطْلُعَ الشَّمْسُ۔,,,26912 26913,"حَدَّثَنَا وَکِیعٌ ، عَن سَلَمَۃَ ، عَنِ الضَّحَّاکِ قَالَ : عَجَبًا لأَصْحَابِ عَبْدِ اللہِ ، إنَّہُمْ یَنْظُرُونَ إلَی الشَّمْسِ مِنْ حَیْثُ تَطْلُعُ ، أَوَلاَ یَعْلَمُونَ أَنَّ الْفَجْرَ إذَا طَلَعَ مِنْ مَوْضِعٍ طَلَعَتْ مِنْہُ الشَّمْسُ۔",,,26913 26914,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ أَبِی بِشْرٍ ، عَن جُنْدُبِ بْنِ عَبْدِ اللہِ الْبَجَلِیِّ ، ثُمَّ الْقَسْرِیِّ قَالَ : اسْتَأْذَنْت عَلَی حُذَیْفَۃَ ثَلاَثَ مَرَّاتٍ فَلَمْ یُؤْذَنْ لِی فَرَجَعْت : فَإِذَا رَسُولُہُ قَدْ لَحِقَنِی فَقَالَ : مَا رَدَّک ؟ قُلْتُ : ظَنَنْت أَنَّک نَائِمٌ ؟ قَالَ : مَا کُنْت لأَنَامَ حَتَّی أَنْظُرَ مِنْ أَیْنَ تَطْلُعُ الشَّمْسُ قَالَ : فَحَدَّثْتُ بِہِ مُحَمَّدًا فَقَالَ : قَدْ فَعَلَہُ غَیْرُ وَاحِدٍ مِنْ أَصْحَابِ مُحَمَّدٍ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,26914 26915,"حَدَّثَنَا وَکِیعٌ ، عَن سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ قَالَ : لاَ تَبِتْ فِی بَیْتٍ وَحْدَک ، فَإِنَّ الشَّیْطَانَ أَشَدُّ مَا یَکُونُ وَلَعًا۔",,,26915 26916,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یُسَافِرَ الرَّجُلُ وَحْدَہُ ، أَوْ یَبِیتَ فِی بَیْتٍ وَحْدَہُ۔ (ابوداؤد 311۔ احمد 91)",,,26916 26917,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَاصِمِ بن مُحَمَّد ، عَنْ أَبِیہِ ، عَنِ ابْنِ عُمَرَ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَوْ یَعْلَمُ أَحَدُکُمْ مَا فِی الْوَحْدَۃِ مَا سَارَ أَحَدُکُمْ بِاللَّیْلِ۔ (بخاری 2998۔ ترمذی 1673)",,,26917 26918,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَن سُفْیَانَ ، عَنْ أَبِیہِ ، عَن مُحَمَّدِ بْنِ عَبْدِ اللہِ بْنِ یَزِیدَ قَالَ : کَانَ أَبِی لاَ یَأْتَمِن عَلَی حَدِیثِہِ أَہْلَہُ ، کَانَ یَخْلُو ہُوَ وَأَصْحَابُہُ فِی غُرْفَۃٍ یَتَحَدَّثُونَ۔",,,26918 26919,"حَدَّثَنَا وَکِیعٌ ، عَن سُفْیَانَ ، عَن سَلَمَۃَ ، عَن عِیسَی بْنِ عَاصِمٍ ، عَن زِرٍّ ، عَنْ عَبْدِ اللہِ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الطِّیَرَۃُ شِرْکٌ ، الطِّیَرَۃُ شِرْکٌ ، وَمَا مِنَّا إلاَّ ، وَلَکِنَّ اللَّہَ یُذْہِبُہُ بِالتَّوَکُّلِ۔ (ابوداؤد 3905۔ ابن ماجہ 3538)",,,26919 26920,"حَدَّثَنَا وَکِیعٌ ، عَن سُفْیَانَ ، عَن حَبِیبِ بْنِ أَبِی ثَابِتٍ ، عَن عُرْوَۃَ بْنِ عَامِرٍ قَالَ : سُئِلَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الطِّیَرَۃِ فَقَالَ : أَحْسَنُہَا الْفَأْلُ ، وَلاَ تَرُدَّ مُسْلِمًا ، فَإِذَا رَأَی أَحَدُکُمْ مِنْ ذَلِکَ مَا یَکْرَہُ فَلْیَقُلْ : اللَّہُمَّ لاَ یَأْتِی بِالْحَسَنَاتِ ، وَلاَ یَدْفَعُ السَّیِّئَاتِ إلاَّ أَنْتَ ، وَلاَ حَوْلَ وَلاَ قُوَّۃَ إلاَّ بِک۔\n\n(ابوداؤد 3914۔ بیہقی 139)",,,26920 26921,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی جُنَابٍ ، عَنْ أَبِیہِ ، عَنِ ابْنِ عُمَرَ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ عَدْوَی ، وَلاَ طِیَرَۃَ ، وَلاَ ہَامَۃَ ، فَقَامَ إلَیْہِ رَجُلٌ فَقَالَ : یَا رَسُولَ اللہِ ، الْبَعِیرُ یَکُونُ بِہِ الْجَرَبُ فَتُجْرَبُ بِہِ الإِبِلُ ؟ قَالَ : ذَلِکَ الْقَدَرُ ، فَمَنْ أَجْرَبَ الأَوَّلَ ؟۔ (بخاری 5717۔ مسلم 1742)",,,26921 26922,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَن سِمَاکٍ ، عَن عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ عَدْوَی لاَ طِیَرَۃَ ، وَلاَ ہَامَۃَ وَلاَ صَفَرَ۔ (احمد 229)",,,26922 26923,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ الْجُرَیرِیِّ ، عَنِ الْمُضَارِبِ بْنِ حَزْنٍ قَالَ : قُلْتُ لأَبِی ہُرَیْرَۃَ : أَسَمِعْت مِنْ نَبِیِّکَ شَیْئًا فَحَدِّثْنِیہِ ، قَالَ : نَعَمْ ، قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ عَدْوَی ، وَلاَ طِیَرَۃَ ، وَلاَ ہَامَۃَ ، وَخَیْرُ الطِّیَرَۃِ الْفَأْلُ ، وَالْعَیْنُ حَقٌّ۔ (بخاری 5740۔ احمد 2/487)",,,26923 26924,"حَدَّثَنَا عَلِی بْنُ مُسْہِرٍ ، عَن مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُحِبُّ الْفَأْلَ الْحَسَنَ وَیَکْرَہُ الطِّیَرَۃَ۔ (ابن ماجہ 3536۔ ابن حبان 6121)",,,26924 26925,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : أَخْبَرَنَا شُعْبَۃُ ، عَن قَتَادَۃَ ، عَنْ أَنَسٍ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ عَدْوَی ، وَلاَ طِیَرَۃَ ، وَأُحِبُّ الْفَأْلَ الصَّالِحَ۔ (بخاری 5756۔ ابن ماجہ 3537)",,,26925 26926,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ قَالَ : قَالَ عَبْدُ اللہِ : لاَ تَضُر الطِّیَرَۃُ إلاَّ مَنْ تَطَیَّرَ۔",,,26926 26927,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ قَالَ : حدَّثَنَا الْفُرَاتُ بْنُ سُلَیمَانَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَن زِیَادِ بْنِ أَبِی مَرْیَمَ قَالَ : خَرَجَ سَعْدُ بْنُ أَبِی وَقَّاصٍ فِی سَفَرٍ ، قَالَ : فَأَقْبَلَتِ الظِّبَائُ نَحْوَہُ حَتَّی إذَا دَنَتْ مِنْہُ رَجَعَتْ ، فَقَالَ لَہُ رَجُلٌ : أَیُّہَا الأَمِیرُ ، ارْجِعْ ، فَقَالَ لَہُ : سَعْدٌ : أَخْبِرْنِی مِنْ أَیُّہَا تَطَیَّرْت ؟ أَمِنْ قُرُونِہَا حِینَ أَقْبَلَتْ أَمْ مِنْ أَدْبَارِہَا حِینَ أَدْبَرَتْ ؟ ، ثُمَّ قَالَ سَعْدٌ عِنْدَ ذَلِکَ : إنَّ الطِّیَرَۃَ لَشُعْبَۃٌ مِنَ الشِّرْکِ۔",,,26927 26928,"حَدَّثَنَا وَکِیعٌ ، عَن سُفْیَانَ ، عَن مَرْزُوقِ أبی بُکَیْر التَّیْمِیِّ ، عَن عِکْرِمَۃَ ، أَنَّ ابْنَ عَبَّاسٍ لُزِقَ بِمَجْذُومٍ فَقُلْت لَہُ : تَلْزَقُ بِمَجْذُومٍ ؟ قَالَ : فَأَمْضِ ، وَقَالَ : لَعَلَّہُ خَیْرٌ مِنِّی وَمِنْک۔",,,26928 26929,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَن عُبَیْدِ اللہِ بْنِ أَبِی یَزِیدَ ، عَنْ أَبِیہِ ، عَن سِبَاعِ بْنِ ثَابِتٍ ، عَن أُمِّ کُرْزٍ قَالَتْ قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَقِرُّوا الطَّیْرَ عَلَی مَکِنَاتِہَا۔ (ابوداؤد 828۔ طیالسی 1634)",,,26929 26930,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَن سُلَیْمَانَ بْنِ الْقَاسِمِ ، عَن أُمِّہِ قَالَ : سَأَلَتْ أُمُّ سَعِیدٍ سُرِّیَّۃَ عَلِیٍّ : ہَلْ کَانَ الْحَسَنُ وَالْحُسَیْنُ یَتَطَیَّرَانِ ؟ قَالَتْ : کَانَا یَحُسَّانِ وَیَمْضِیَانِ۔",,,26930 26931,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ عَوْفٍ ، عَن حَیَّانَ ، عَن قَطَنِ بْنِ قَبِیصَۃَ ، عَنْ أَبِیہِ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْعِیَافَۃُ وَالطِّیَرَۃُ وَالطَّرْقُ مِنَ الْجِبْتِ۔ (ابوداؤد 3902۔ احمد 3/477)",,,26931 26932,"حَدَّثَنَا شَرِیکٌ ، عَنْ عَبْدِ الْمَلِکِ بْنِ عُمَیْرٍ ، عَن رَجَائِ بْنِ حَیْوَۃَ ، عَنْ أَبِی الدَّرْدَائِ قَالَ : ثَلاَثٌ مَنْ کُنَّ فِیہِ ، فَہُوَ مُنَافِقٌ : مَنْ تَکَہَّنَ ، أَوِ اسْتَقْسَمَ ، أَوْ رَجَعَتْہُ طِیَرَۃٌ مِنْ سَفَرٍ۔",,,26932 26933,"حَدَّثَنَا عَلِیُّ بْنُ الْجَعْدِ ، عَن یَزِیدَ بْنِ إِبْرَاہِیمَ ، عَن أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ غَولَ ، وَلاَ صَفَرَ۔ (مسلم 1745۔ احمد 3/293)",,,26933 26934,"حَدَّثَنَا شَرِیکٌ وَہُشَیْمٌ ، عَن یَعْلَی بْنِ عَطَائٍ ، عَنْ عَمْرِو بْنِ الشَّرِیدِ ، عَنْ أَبِیہِ قَالَ : کَانَ فِی وَفْدِ ثَقِیفٍ رَجُلٌ مَجْذُومٌ ، فَأَرْسَلَ إلَیْہِ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّا قَدْ بَایَعْناک فَارْجِعْ۔",,,26934 26935,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ اللہِ بْنِ سَعِیدٍ ، عَن مُحَمَّدِ بْنِ عَبْدِ اللہِ بْنِ عَمْرٍو بْنِ عُثْمَانَ ، عَنْ أَمَۃِ فَاطِمَۃَ بِنْتِ حُسَیْنٍ، عَنِ ابْنِ عَبَّاسٍ قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: لاَ تُدِیمُوا النَّظَرَ إلَی الْمَجْذُومِینَ۔",,,26935 26936,"حَدَّثَنَا وَکِیعٌ ، عَنِ النَّہَّاسِ بْنِ قَہْمٍ ، قَالَ : سَمِعْتُ شَیْخًا بِمَکَّۃَ یُحَدِّثُ عَنْ أَبِی ہُرَیْرَۃَ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : فِرَّ مِنَ الْمَجْذُومِ فِرَارَک مِنَ الأَسَدِ۔",,,26936 26937,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ مُسْلِمٍ ، عَنِ الْوَلِیدِ بْنِ عَبْدِ اللہِ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَرَّ عَلَی مَجْذُومٍ فَخَمَّرَ أَنْفَہُ فَقِیلَ لَہُ : یَا رَسُولَ اللہِ ، أَلَیْسَ قُلْتَ : لاَ عَدْوَی ، وَلاَ طِیَرَۃَ ؟ قَالَ : بَلَی۔",,,26937 26938,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَن مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أبِی ہُرَیْرَۃَ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لاَ یُورِدُ الْمُمْرِضَ عَلَی الْمُصِحِّ۔ (مسلم 104۔ ابن ماجہ 3541)",,,26938 26939,"حَدَّثَنَا وَکِیعٌ ، عَن أُسَامَۃَ بْنِ زَیْدٍ ، عَن نَافِعِ بْنِ جُبَیْرٍ قَالَ : قَالَ کَعْبٌ لِعَبْدِ اللہِ بْنِ عَمْرٍو : ہَلْ تَطَیَّرُ ؟ قَالَ : نَعَمْ ، قَالَ : فَمَا تَقُولُ ؟ قَالَ : أَقُولُ اللَّہُمَّ لاَ طَیْرَ إلاَّ طَیْرُک ، وَلاَ خَیْرَ إلاَّ خَیْرُک ، وَلاَ رَبَّ لَنَا غَیْرَک قَالَ : أَنْتَ أَفْقَہُ الْعَرَبِ۔",,,26939 26940,حَدَّثَنَا مُحَمَّدٌ بْنُ سَوَائٍ ، عَن خَالِدِ الْحَذَّائِ ، عَنْ أَبِی قِلاَبَۃَ ، أَنَّہُ کَانَ یُعْجِبُہُ أَنْ یُتَّقَی الْمَجْذُومُ۔,,,26940 26941,"حَدَّثَنَا غَسَّانُ بْنُ مُضَرَ ، عَن سَعِیدِ بْنِ یَزِیدَ ، عَن عِکْرِمَۃَ قَالَ : مَا لَکُمْ لاَ تَسْأَلُونَنَا أَفْلَسْتُمْ ؟۔",,,26941 26942,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَن مِسْعَرٍ ، عَن سَعْدِ بْنِ إبْرَاہِیمَ قَالَ : قَالَ ابْنُ عَبَّاسٍ : مَا سَأَلَنِی رَجُلٌ عَن مَسْأَلَۃٍ إلاَّ عَرَفْت ، فَقِیہٌ ہُوَ ، أَوْ غَیْرُ فَقِیہٍ۔",,,26942 26943,"حَدَّثَنَا عُمَرُ بْنُ سَعْدٍ ، عَن سُفْیَانَ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَن سَعِیدِ بْنِ جُبَیْرٍ قَالَ : مَا أَحَدٌ یَسْأَلُنِی؟۔",,,26943 26944,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو قَالَ : قَالَ لَنَا عُرْوَۃُ : ائْتُونِی فَتَلَقَّوْا مِنِّی۔",,,26944 26945,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ قَالَ : کَانَ عُرْوَۃُ یَتَأَلَّفُ النَّاسَ عَلَی حَدِیثِہِ۔",,,26945 26946,"حَدَّثَنَا عُمَرُ بْنُ سَعْدٍ ، عَن سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ السَّائِبِ ، عَن زَاذَانَ قَالَ : سَأَلْتُ ابْنَ مَسْعُودٍ عَنْ أَشْیَائَ مَا أَحَدٌ یَسْأَلُنِی عنہا۔",,,26946 26947,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَن سِمَاکٍ ، عَن خَالِدِ بن عَرْعَرَۃ ، قَالَ : أَتَیْتُ الرَّحْبَۃَ فَإِذَا أَنَا بِنَفَرٍ جُلُوسٍ قَرِیبًا مِنْ ثَلاَثِینَ ، أَوْ أَرْبَعِینَ رَجُلاً فَقَعَدْتُ مَعَہُمْ ، فَخَرَجَ عَلَیْنَا عَلِیٌّ ، فَمَا رَأَیْتہ أَنْکَرَ أَحَدًا مِنَ الْقَوْمِ غَیْرِی فَقَالَ : أَلاَ رَجُلٌ یَسْأَلُنِی فَیَنْتَفِعُ وَیَنْتَفِعُ جُلَسَاؤُہُ۔",,,26947 26948,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَن یَحْیَی بْنِ سَعِیدٍ قَالَ : نُرَاہ عَن سَعید بن المُسَیّب لَمْ یَکُنْ أَحَدٌ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ سَلُونِی إلاَّ عَلِیُّ بْنُ أَبِی طَالِبٍ۔",,,26948 26949,"حَدَّثَنَا ہُشَیْمٌ ، عَن مُجَالِدٍ ، عَنِ الشَّعْبِیِّ ، عَنْ جَابِرٍ ، أَنَّ عُمَرَ بْنَ الْخَطَّابِ أَتَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِکِتَابٍ أَصَابَہُ مِنْ بَعْضِ الْکُتُبِ ، فَقَالَ : یَا رَسُولَ اللہِ ، إنِّی أَصَبْتُ کِتَابًا حَسَنًا مِنْ بَعْضِ أَہْلِ الْکِتَابِ ، قَالَ : فَغَضِبَ ، وَقَالَ : أَمُتَہَوِّکُونَ فِیہَا یَا ابْنَ الْخَطَّابِ ، وَالَّذِی نَفْسِی بِیَدِہِ ، لَقَدْ جِئْتُکُمْ بِہَا بَیْضَائَ نَقِیَّۃً ، لاَ تَسْأَلُوہُمْ عَن شَیْئٍ فَیُخْبِرُوکُمْ بِحَقٍّ فَتُکَذِّبُوا بِہِ ، أَوْ بِبَاطِلٍ فَتُصَدِّقُوا بِہِ ، وَالَّذِی نَفْسِی بِیَدِہِ ، لَوْ کَانَ مُوسَی کان حَیًّا الیَوم مَا وَسِعَہُ إلاَّ أَنْ یَتَّبِعَنی۔",,,26949 26950,"حَدَّثَنَا ابْنُ مَہْدِیٍّ، عَن سُفْیَانَ، عَن سَعْدِ بْنِ إِبْرَاہِیمَ، عَن عَطَائِ بْنِ یَسَارٍ قَالَ: کَانَتِ الْیَہُودُ تَجِیئُ إلَی الْمُسْلِمِینَ فَیُحَدِّثُونَہُمْ فَیَسْتَحْسِنُونَ، أَوْ قَالَ: یَسْتَحِبُّونَ، فَذَکَرُوا ذَلِکَ لِرَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقَالَ : لاَ تُصَدِّقُوہُمْ ، وَلاَ تُکَذِّبُوہُمْ قُولُوا : {آمَنَّا بِاَللَّہِ وَمَا أُنْزِلَ إلَیْنَا وَمَا أُنْزِلَ إلَیْکُمْ} إلَی آخِرِ الآیَۃِ۔",,,26950 26951,"حَدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَنْ أَیُّوبَ ، عَن عِکْرِمَۃَ قَالَ : قَالَ ابْنُ عَبَّاسٍ : تَسْأَلُونَ أَہْلَ الْکِتَابِ عَن کُتُبِہِمْ وَعَندَکُمْ کِتَابُ اللہِ أَقْرَبُ الْکُتُبِ عَہْدًا بِاللَّہِ تَقْرَؤُونَہُ مَحْضًا لَمْ یَشُبْ۔ (بخاری 2685)",,,26951 26952,"حَدَّثَنَا یَعْلَی قَالَ : حدَّثَنَا الأَعْمَشُ ، عَن عُمَارَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ قَالَ : قَالَ عَبْدُ اللہِ : لاَ تَسْأَلُوا أَہْلَ الْکِتَابِ عَن شَیْئٍ فَتُکَذِّبُوا بِحَقٍّ ، أَوْ تُصَدِّقُوا بِبَاطِلٍ ، فَإِنَّہُمْ لَنْ یَہْدُوکُمْ وَیَضِلُّونَ أَنْفُسَہُمْ ، وَلَیْسَ أَحَدٌ مِنْہُمْ إلاَّ فِی قَلْبِہِ تَالِیَۃٌ تَدْعُوہُ إلَی دَیْنِہِ کَتَالِیَۃِ الْمَالِ۔",,,26952 26953,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنِ الرَّبِیعِ بْنِ سَعْدٍ قَالَ : رَأَیْتُ جَابِرًا یَکْتُبُ عِنْدَ ابْنِ سَابِطٍ فِی أَلْوَاحٍ۔",,,26953 26954,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ حَرْمَلَۃَ قَالَ : کُنْتُ سَیِّئَ الْحِفْظِ ، فَرَخَّصَ لِی سَعِیدُ بْنُ الْمُسَیَّبِ فِی الْکِتَابِ۔",,,26954 26955,"حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ عَبْدِ اللہِ بْنِ سُفْیَانَ ، عَنْ عَمِّہِ ، أَنَّہُ سَمِعَ عُمَرَ بْنَ الْخَطَّابِ یَقُولُ : قیِّدُوا الْعِلْمَ بِالْکِتَابِ۔ (دارمی 497)",,,26955 26956,"حَدَّثَنَا وَکِیعٌ، عَنْ عِکْرِمَۃَ بْنِ عَمَّارٍ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ قَالَ: قَالَ ابْنُ عَبَّاسٍ: قیِّدُوا الْعِلْمَ بِالْکِتَابِ۔",,,26956 26957,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَن عُبَیْدِ اللہِ بْنِ الأَخْنَسِ ، عَنِ الْوَلِیدِ بْنِ عَبْدِ اللہِ ، عَن یُوسُفَ بْنِ مَاہَکَ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو قَالَ : کُنْتُ أَکْتُبُ کُلَّ شَیْئٍ أَسْمَعُہُ مِنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَأُرِیدُ حِفْظَہُ ، فَنَہَتْنِی قُرَیْشٌ عَن ذَلِکَ وقَالُوا : تَکْتُبُ کُلَّ شَیْئٍ تَسْمَعُہُ مِنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَرَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَتَکَلَّمُ فِی الرِّضَا وَالْغَضَبِ قَالَ : فَأَمْسَکْت فَذَکَرْت ذَلِکَ لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَأَشَارَ بِیَدِہِ إلَی فِیہِ فَقَالَ : اکْتُبْ فَوَالَّذِی نَفْسِی بِیَدِہِ : مَا یَخْرُجُ مِنْہُ إلاَّ حَقٌّ۔\n\n(دارمی 484۔ احمد 2/192)",,,26957 26958,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَن مِسْعَرٍ ، عَن مَعْن قَالَ : أَخْرَجَ إلَیَّ عَبْدُ الرَّحْمَنِ بْنِ عَبْدِ اللہِ کِتَابًا وَحَلَفَ لِی أَنَّہُ خَطُّ أَبِیہِ بِیَدِہِ۔",,,26958 26959,"حَدَّثَنَا جَرِیرٌ ، عَن مَنْصُورٍ ، عَنْ إبْرَاہِیمَ قَالَ : لاَ بَأْسَ بِکِتَابِ الأَطْرَافِ۔",,,26959 26960,"حَدَّثَنَا وَکِیعٌ ، عَن أَبِی کِبْران قَالَ : سَمِعت الضَحَاک یَقُول إِذَا سَمِعت شَیئًا فَاکتُبہ وَلَو فی حائط۔",,,26960 26961,"حَدَّثَنَا وَکِیعٌ ، عَن حُسَیْنِ بْنِ عُقَیْلٍ قَالَ : أَمْلَی عَلَیَّ الضَّحَّاکُ مَنَاسِکَ الْحَجِّ۔",,,26961 26962,"حَدَّثَنَا وَکِیعُ ، عَن عُمْرَانَ بْنِ حُدَیْرٍ ، عَنْ أَبِی مِجْلَزٍ ، عَن بَشِیرِ بْنِ نَہِیکٍ قَالَ : کُنْتُ أَکْتُبُ مَا أَسْمَعُہُ مِنْ أَبِی ہُرَیْرَۃَ ، فَلَمَّا أَرَدْت أَنْ أُفَارِقَہُ أَتَیْتہ بِکِتَابِی فَقُلْت ہَذَا سَمِعْتہ مِنْک ؟ قَالَ : نَعَمْ۔",,,26962 26963,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَن حَمَّادِ بْنِ زَیْدٍ ، عَن یَحْیَی بْنِ عَتِیقٍ ، عَنِ ابْنِ سِیرِینَ قَالَ : کُنْتُ أَلْقَی عَبِیْدَۃَ بِالأَطْرَافِ فَأَسْأَلُہُ۔",,,26963 26964,حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَن عُثْمَانَ بْنِ حَکِیمٍ ، عَن سَعِیدِ بْنِ جُبَیْرٍ ، أَنَّہُ کَانَ یَکُونُ مَعَ ابْنِ عَبَّاسٍ ، فَیَسْمَعُ مِنْہُ الْحَدِیثَ فَیَکْتُبُہُ فِی وَاسِطَۃِ الرَّحْلِ ، فَإِذَا نَزَلَ نَسَخَہُ۔,,,26964 26965,"حَدَّثَنَا سُلَیْمَانُ بْنُ حَرْبٍ قَالَ : حدَّثَنَا حَمَّادُ بْنُ زَیْدٍ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ قَالَ : الْکِتَابُ أَحَبُّ إلَیَّ مِنَ النِّسْیَانِ۔",,,26965 26966,"حَدَّثَنَا سُلَیْمَانُ بْنُ حَرْبٍ قَالَ : حدَّثَنَا حَمَّادُ بْنُ زَیْدٍ ، عَنْ أَیُّوبَ ، عَنْ أَبِی الْمَلِیحِ قَالَ : یَعِیبُونَ عَلَیْنَا الْکِتَابَ وَقَدْ قَالَ اللَّہُ تَعَالَی : {عِلْمُہَا عِنْدَ رَبِّی فِی کِتَابٍ}۔",,,26966 26967,حَدَّثَنَا حَفْصٌ، عَن مُجَالِدٍ، عَنِ الشَّعْبِیِّ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَبْدِ اللہِ، أَنَّہُ کَانَ إذَا سَمِعَ شَیْئًا کَتَبَہُ۔,,,26967 26968,"حَدَّثَنَا وَکِیعٌ، عَنْ أَبِیہِ ، عَنْ عَبْدِ اللہِ بْنِ حَنَشٍ قَالَ: رَأَیْتُہُمْ عِنْدَ الْبَرَائِ یَکْتُبُونَ عَلَی أَکُفِّہِمْ بِالْقَصَبِ۔",,,26968 26969,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَن شُعْبَۃَ ، عَنْ جَابِرٍ ، عَنْ عَبْدِ اللہِ بْنِ یَسَارٍ قَالَ : سَمِعَتْ عَلِیًّا یَخْطُبُ یَقُولُ : أَعْزِمُ عَلَی کُل مَنْ کَانَ عَندَہُ کِتَابٌ إلاَّ رَجَعَ فَمَحَاہُ ، فَإِنَّمَا ہَکَذَا النَّاسُ حَیْثُ تَتَبَّعُوا أَحَادِیثَ عُلَمَائِہِمْ وَتَرَکُوا کِتَابَ رَبِّہِمْ۔",,,26969 26970,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَن کَہْمَسَ ، عَنْ أَبِی نَضْرَۃَ قَالَ : قلْنَا لأَبِی سَعِیدٍ الْخُدْرِیِّ : لَوِ اکْتَبْتَنَا الْحَدِیثَ ؟ فَقَالَ : لاَ نُکْتِبُکُمْ ، خُذُوا عَنَّا کَمَا أَخَذْنَا عَن نَبِیِّنَا صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,26970 26971,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ أَبِی مَالِکٍ الأَشْجَعِیِّ ، عَن سُلَیْمَانَ بْنِ الأَسْوَدِ الْمُحَارِبِیِّ قَالَ : کَانَ ابْنُ مَسْعُودٍ یَکْرَہُ کِتَابَ الْعِلْمِ۔",,,26971 26972,"حَدَّثَنَا جَرِیرٌ ، عَن مُغِیرَۃَ قَالَ : کَانَ عُمَرُ یَکْتُبُ إلَی عُمَّالِہِ : لاَ تُخَلِّدُنَّ عَلَیَّ کِتَابًا۔",,,26972 26973,"حَدَّثَنَا جَرِیرٌ ، عَن مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : قَالَ لِی عَبِیْدَۃُ : لاَ تُخَلِّدُنَّ عَلَیَّ کِتَابًا۔",,,26973 26974,"حَدَّثَنَا وَکِیعٌ ، عَن طَلْحَۃَ بْنِ یَحْیَی ، عَنْ أَبِی بُرْدَۃَ قَالَ : کَتَبْت عَنْ أَبِی کِتَابًا کَبِیرًا فَقَالَ : ائْتِنِی بِکُتُبِکَ ، فَأَتَیْتہ بِہَا فَغَسَلَہَا۔",,,26974 26975,"حَدَّثَنَا وَکِیعٌ ، عَنِ الْحَکَمِ بْنِ عَطِیَّۃَ ، عَنِ ابْنِ سِیرِینَ قَالَ : إنَّمَا ضَلَّتْ بَنُو إسْرَائِیلَ بِکُتُبٍ وَرِثُوہَا عَن آبَائِہِمْ۔",,,26975 26976,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ ، أَنَّ مَرْوَانَ دَعَا زَیْدَ بْنَ ثَابِتٍ وَقَوْمًا یَکْتُبُونَ وَہُوَ لاَ یَدْرِی، فَأَعْلَمُوہُ فَقَالَ : أَتَدْرُونَ لَعَلَّ کُلَّ شَیْئٍ حَدَّثْتُکُمْ لَیْسَ کَمَا حَدَّثْتُکُمْ۔",,,26976 26977,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ، عَنِ الأَعْمَشِ، عَنْ جَامِعِ بْنِ شَدَّادٍ، عَنِ الأَسْوَدِ بْنِ ہِلاَلٍ قَالَ: أُتِیَ عَبْدُ اللہِ بِصَحِیفَۃٍ فِیہَا حَدِیثٌ ، فَدَعَا بِمَائٍ فَمَحَاہَا ، ثُمَّ غَسَلَہَا ، ثُمَّ أَمَرَ بِہَا فَأُحْرِقَتْ ، ثُمَّ قَالَ : أُذَکِّرُ بِاللَّہِ رَجُلاً یَعْلَمُہَا عِنْدَ أَحَدٍ إلاَّ أَعْلَمَنِی بِہِ ، وَاللَّہِ لَوْ أَعْلَمُ أَنَّہَا بِدیر ہِنْد لاَنْتَعَلْتُ إلَیْہَا ، بِہَذَا ہَلَکَ أَہْلُ الْکِتَابِ قَبْلَکُمْ حَتَّی نَبَذُوا کِتَابَ اللہِ وَرَائَ ظُہُورِہِمْ کَأَنَّہُمْ لاَ یَعْلَمُونَ۔",,,26977 26978,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَن کَہْمَسٍ ، عَنْ عَبْدِ اللہِ بْنِ مُسْلِمٍ ، عَنْ أَبِیہِ قَالَ : کُلُّ الْکِتَابِ أَکْرَہُ ، قَالَ : أَرَاہُ یَعْنِی مَا کَانَ فِیہِ مِنْ ذِکْرِ اللہِ ، قُلْتُ لِمُعْتَمِرٍ : یَعْنِی الْخَاتَمَ ؟ قَالَ : نَعَمْ۔",,,26978 26979,"حَدَّثَنَا مُعَاذٌ قَالَ : حدَّثَنَا ابْنُ عَوْنٍ ، عَنِ الْقَاسِمِ ، أَنَّہُ کَانَ لاَ یَکْتُبُ الْحَدِیثَ۔",,,26979 26980,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ أَیُّوبَ ، قَالَ : سَمِعْتُ سَعِیدَ بْنَ جُبَیْرٍ قَالَ : کُنَّا نَخْتَلِفُ فِی أَشْیَائَ فَکَتَبْتہَا فِی کِتَابٍ ، ثُمَّ أَتَیْتُ بِہَا ابْنَ عُمَرَ أَسْأَلُہُ عنہا خَفِیًّا ، فَلَوْ عَلِمَ بِہَا کَانَتِ الْفَیْصَلُ فِیمَا بَیْنِی وَبَیْنَہُ۔",,,26980 26981,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَن شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ إبْرَاہِیمَ قَالَ : قَالَ عَبِیْدَۃُ : لاَ تُخَلِّدُنَّ عَلَیَّ کِتَابًا۔",,,26981 26982,حَدَّثَنَا ابْنُ إدْرِیسَ، عَن ہَارُونَ بْنِ عَنتَرَۃَ، عَنْ أَبِیہِ، عَنِ ابْنِ عَبَّاسٍ، أَنَّہُ رَخَّصَ لَہُ أَنْ یَکْتُبَ وَلَمْ یَکَدْ۔,,,26982 26983,"حَدَّثَنَا أَسْوَدُ بْنُ عَامِرٍ قَالَ : حدَّثَنَا عُمَارَۃُ بْنُ زَاذَانَ قَالَ : حَدَّثَنَا عَلِیُّ بْنُ الْحَکَمِ ، عَنْ عَطَائِ بْنِ أَبِی رَبَاحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : مَا مِنْ رَجُلٍ حَفِظَ عِلْمًا فَسُئِلَ عَنہُ فَکَتَمَہُ إلاَّ جِیئَ بہ یَوْمَ الْقِیَامَۃِ مُلَجَّمًا بِلِجَامٍ مِنْ نَارٍ۔ (ابوداؤد 3650۔ ابن حبان 95)",,,26983 26984,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَن حَجَّاجٍ ، عَنْ عَطَائٍ ، عَنْ أَبِی ہُرَیْرَۃَ قَالَ : مَنْ کَتَمَ عِلْمًا عِندَہُ أَلْجَمَہُ اللَّہُ یَوْمَ الْقِیَامَۃِ بِلِجَامٍ مِنْ نَارٍ۔ (احمد 499)",,,26984 26985,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ قَالَ : حدَّثَنَا ابْنُ عَوْنٍ قَالَ : کَان مِمَّنْ یَتَّبِعُ أَنْ یُحَدِّثَ بِالْحَدِیثِ کَمَا سَمِعَ : محمد بْنُ سِیرِینَ وَالْقَاسِمُ بْنُ مُحَمَّدٍ وَرَجَائُ بْنُ حَیْوَۃَ ، وَکَانَ مِمَّنْ لاَ یَتَّبِعُ ذَلِکَ : الْحَسَنُ وَإِبْرَاہِیمُ وَالشَّعْبِیُّ ، قَالَ ابْنُ عَوْنٍ : فَقُلْتُ لِمُحَمَّدٍ : إنَّ فُلاَنًا لاَ یَتَّبِعُ أَنْ یُحَدِّثَ بِالْحَدِیثِ کَمَا سَمِعَ ، فَقَالَ : أمَّا أَنَّہُ لَوِ اتَّبَعَہُ کَانَ خَیْرًا لَہُ۔",,,26985 26986,حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَن عُمَارَۃَ ، عَنْ أَبِی مَعْمَرٍ ، أَنَّہُ کَانَ یَتْبَعُ اللَّحْنَ فِی الْحَدِیثِ کَیْ یَجِیئُ بِہِ کَمَا سَمِعَ۔,,,26986 26987,حَدَّثَنَا صَفْوَان ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ وَالشَّعْبِیِّ أَنَّہُمَا کَانَا لاَ یَرَیَانِ بَأْسًا بِتَقْدِیمِ الْحَدِیثِ وَتَأْخِیرِہِ ، وَکَانَ ابْنُ سِیرِینَ یَتَکَلَّفُہُ کَمَا سَمِعَہ۔,,,26987 26988,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ، عَنْ إسْمَاعِیلِ بْنِ أُمَیَّۃَ قَالَ: کُنَّا نُرِیدُ نَافِعًا عَلَی إقَامَۃِ اللَّحْنِ فِی الْحَدِیثِ فَیَأْبَی۔",,,26988 26989,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ قَالَ : قلْت لأَبِی الضُّحَی : الْمُصَوِّرُونَ ، قَالَ : الْمُصَوِّرِینَ۔",,,26989 26990,"حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ قَالَ : قُلْتُ لَہُ : أَسْمَعُ اللَّحْنَ فِی الْحَدِیثِ ؟ قَالَ : أَقِمْہُ۔",,,26990 26991,حَدَّثَنَا أَبُو عَاصِمٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ یَجْعَلَ الرَّجُلُ فِی یَدِہِ الْخَیْطَ یَسْتَذْکِرُ بِہِ الرَّجُلُ فِی الشَّیْئِ۔,,,26991 26992,حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ ، عَن مَنْصُورِ بْنِ أَبِی الأَسْوَدِ ، عَن مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ کَرِہَ أَنْ یُرْبَطَ الْخَیْطُ فِی الْخَاتَمِ یَسْتَذْکِرُ بِہِ الْحَاجَۃَ۔,,,26992 26993,"ابْنُ فُضَیْلٍ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، عَن مَغْرَائَ الْعَبْدِیِّ ، عَن شُرَیْحٍ ، أَنَّہُ سَمِعَ صَوْتَ دُفٍّ فَقَالَ : إنَّ الْمَلاَئِکَۃَ لاَ یَدْخُلُونَ بَیْتًا فِیہِ دُفٌّ۔",,,26993 26994,"یَحْیَی بْنُ سَعِیدٍ ، وَابْنُ مَہْدِیٍّ ، عَن سُفْیَانَ ، عَن عِمْرَانَ بْنِ مُسْلِمٍ قَالَ : قَالَ لِی خَیْثَمَۃُ : أَمَا سَمِعْت سُوَیْدًا یَقُولُ : لاَ تَدْخُلُ الْمَلاَئِکَۃُ بَیْتًا فِیہِ دُفٌّ۔",,,26994 26995,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَن سُفْیَانَ ، عَن مَنْصُورٍ ، عَنْ إبْرَاہِیمَ قَالَ : کَانَ أَصْحَابُ عَبْدِ اللہِ یَسْتَقْبِلُونَ الْجَوَارِیَ فِی الأَزِقَّۃِ مَعَہُنَّ الدُّفُوفَ فَیَشُقُّونَہَا۔",,,26995 26996,حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَن یَحْیَی بْنِ سَعِیدٍ ، عَن سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ أَبِی ہُرَیْرَۃَ ، أَنَّ إبْرَاہِیمَ اخْتُتِنَ بِالْقَدُّومِ وَہُوَ ابْنُ مِئَۃ وَعِشْرِینَ سَنَۃً ، ثُمَّ عَاشَ بَعْدَ ذَلِکَ ، ثَمَانِینَ سَنَۃً۔(بخاری 3356۔ مسلم 1839),,,26996 26997,"حَدَّثَنَا عَبْدَۃُ ، عَن یَحْیَی بْنِ سَعِیدٍ ، عَن سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : کَانَ إبْرَاہِیمُ أَوَّلَ النَّاسِ أَضَافَ الضَّیْفَ ، وَأَوَّلَ النَّاسِ قَصَّ شَارِبَہُ وَقَلَّمَ أَظْفَارَہُ وَاسْتَحَدَّ ، وَأَوَّلَ النَّاسِ اخْتُتِنَ ، وَأَوَّلَ النَّاسِ رَأَی الشَّیْبَ فَقَالَ : یَا رَبِّ ، مَا ہَذَا ؟ قَالَ : الْوَقَارُ ، قَالَ : رَبِّ زِدْنِی وَقَارًا۔ (مالک4۔ ابن عدی 1511)",,,26997 26998,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَن حَجَّاجٍ ، عَن رَجُلٍ ، عَنْ أَبِی الْمَلِیحِ ، عَن شَدَّادِ بْنِ أَوْسٍ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْخِتَانُ سُنَّۃٌ لِلرِّجَالِ مَکْرُمَۃٌ لِلنِّسَائِ۔ (طبرانی 7112۔ احمد 75)",,,26998 26999,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَن سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : خَمْسٌ مِنَ الْفِطْرَۃِ فَذَکَرَ الْخِتَانَ۔",,,26999 27000,"حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ، عَنْ إسْرَائِیلَ، عَن مَنْصُورٍ، عَن مُجَاہِدٍ وَإِبْرَاہِیمَ ، قَالاَ: الْخِتَانُ من السُنَّۃِ۔ (ابن حبان 354۔ بزار 990)",,,27000 27001,"حَدَّثَنَا غُنْدَرٌ ، عَن شُعْبَۃَ ، عَن مَنْصُورٍ ، عَن مَالِکِ بْنِ الْحَارِثِ ، عَنْ عَمْرِو بْنِ شُرَحْبِیلَ ، أَنَّ عَبْدَ اللہِ قَالَ : إنَّ اللَّہَ یُحِبُّ أَنْ تُقْبَلَ رُخَصُہُ کَمَا یُحِبُّ أَنْ تُؤْتَی عَزَائِمُہُ۔ (طبرانی 1003)",,,27001 27002,"حَدَّثَنَا غُنْدَرُ ، عَن شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، عَنْ عَبْدِ اللہِ قَالَ : إنَّ اللَّہَ یُحِبُّ أَنْ تُؤْتَی رُخَصُہُ کَمَا یُحِبُّ أَنْ تُؤْتَی عَزَائِمُہُ۔",,,27002 27003,"حَدَّثَنَا وَکِیعٌ ، عَن سُفْیَانَ ، عَنْ أَبِیہِ ، عَن تَمِیمِ بْنِ سَلَمَۃَ ، عَنِ ابْنِ عُمَرَ قَالَ : إنَّ اللَّہَ یُحِبُّ أَنْ تُؤْتَی مَیَاسِرُہُ کَمَا یُحِبُّ أَنْ تُؤْتَی عَزَائِمُہُ۔ (احمد 108۔ ابن حبان 2742)",,,27003 27004,"حَدَّثَنَا وَکِیعٌ ، عَن سُفْیَانَ ، عَنْ أَبِیہِ قَالَ : ذَکَرْتہ لِعَبْدِ الرَّحْمَنِ الرَّحَّالِ قَالَ : قَالَ ابْنُ عَبَّاسٍ : إنَّ اللَّہَ یُحِبُّ أَنْ تُؤْتَی مَیَاسِرُہُ کَمَا یُحِبُّ أَنْ تُؤْتَی عَزَائِمُہُ۔",,,27004 27005,"حَدَّثَنَا وَکِیعٌ ، عَن مُوسَی بْنِ عُبَیْدَۃَ ، عَن مُحَمَّدِ بْنِ الْمُنْکَدِرِ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ اللَّہَ یُحِبُّ أَنْ تُقْبَلَ رُخَصُہُ کَمَا یُحِبُّ أَنْ تُؤْتَی فَرِیضَتُہُ۔",,,27005 27006,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَن حُصَیْنٍ ، عَنِ الشَّعْبِیِّ ، عَن مَسْرُوقٍ قَالَ : إنَّ اللَّہَ یُحِبُّ أَنْ تُؤْتَی رُخَصُہُ کَمَا یُحِبُّ أَنْ تُؤْتَی عَزَائِمُہُ۔",,,27006 27007,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ الْعَوَّامِ ، عَنْ إبْرَاہِیمَ التَّیْمِیِّ قَالَ : إنَّ اللَّہَ یُحِبُّ أَنْ تُؤْتَی مَیَاسِرُہُ کَمَا یُحِبُّ أَنْ یُطَاعَ فی عَزَائِمِہِ۔",,,27007 27008,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَن نَضْرَ بْنِ عَرَبِی ، عَنْ عَطَائٍ قَالَ : إذَا تَنَازَعَک أَمْرَانِ ، فَاحْمِلِ الْمُسْلِمِینَ عَلَی أَیْسَرِہِمَا۔",,,27008 27009,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَن ہِشَامٍ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ رضی اللہ عنہا قَالَتْ : مَا خُیِّرَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَیْنَ أَمْرَیْنِ أَحَدُہُمَا أَیْسَرُ مِنَ الآخَرِ إلاَّ أَخَذَ الَّذِی ہُوَ أَیْسَرُ۔ (مسلم 1814۔ احمد 31)",,,27009 27010,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَن لَیْثٍ ، عَن طَاوُوس ، عَنِ ابْنِ عَبَّاسٍ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : یَسِّرُوا ، وَلاَ تُعَسِّرُوا۔",,,27010 27011,"حَدَّثَنَا وَکِیعٌ ، عَن شُعْبَۃَ ، عَن سَعِیدِ بْنِ أَبِی بُرْدَۃَ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لَمَّا بَعَثَہُ ہُوَ وَمُعَاذًا إلَی الْیَمَنِ قَالَ : یَسِّرَا ، وَلاَ تُعَسِّرَا۔ (بخاری 3038۔ مسلم 1359)",,,27011 27012,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَوْفٍ ، عَن زِیَادِ بْنِ مِخْرَاقٍ ، عَنْ أَبِی کِنَانَۃَ ، عَنْ أَبِی مُوسَی قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : ابْنُ أُخْتِ الْقَوْمِ مِنہم۔ (احمد 396۔ بزار 1582)",,,27012 27013,"حَدَّثَنَا وَکِیعٌ ، عَن شُعْبَۃَ ، عَن قَتَادَۃَ ، عَنْ أَنَسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : ابْنُ أُخْتِ الْقَوْمِ مِنْ أَنْفُسِہِمْ۔ (بخاری 3528۔ مسلم 735)",,,27013 27014,"حَدَّثَنَا وَکِیعٌ ، عَن شُعْبَۃَ ، قَالَ : قُلْتُ لِمُعَاوِیَۃَ بْنِ قُرَّۃَ : سَمِعْت أَنَسَ بْنَ مَالِکٍ یَقُولُ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لِلنُّعْمَانِ بْنِ مُقَرِّنٍ : ابْنُ أُخْتِ الْقَوْمِ مِنْ أَنْفُسِہِمْ قَالَ : نَعَمْ۔(نسائی 2393۔ احمد 222)",,,27014 27015,"حَدَّثَنَا وَکِیعٌ ، عَن سُفْیَانَ ، عَنِ ابْنِ خُثَیْمٍ ، عَنْ إسْمَاعِیلَ بْنِ عُبَیْدِ اللہِ بْنِ رِفَاعَۃَ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ قَالَ : جَمَعَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قُرَیْشًا فَقَالَ : ہَلْ فِیکُمْ مِنْ غَیْرِکُمْ ؟ قَالُوا : لاَ إلاَّ ابْنُ أُخْتِنَا وَحَلِیفُنَا وَمَوْلاَنَا ، فَقَالَ : ابْنُ أُخْتِکُمْ مِنْکُمْ ، وَحَلِیفُکُمْ مِنْکُمْ ، وَمَوْلاَکُمْ مِنْکُمْ۔ (بخاری 75۔ احمد 340)",,,27015 27016,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَن مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ أَبِی سَلَمۃَ ، عَنْ أَبِی ہُرَیْرَۃَ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : حَدِّثُوا عَن بَنِی إسْرَائِیلَ ، وَلاَ حَرَجَ۔ (ابوداؤد 3654۔ احمد 502)",,,27016 27017,"حَدَّثَنَا وَکِیعٌ ، عَنِ الرَّبِیعِ بْنِ سَعْدٍ ، عَنِ ابْنِ سَابِطٍ ، عَنْ جَابِرٍ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : تَحَدَّثُوا عَن بَنِی إسْرَائِیلَ فَإِنَّہُ کَانَتْ فِیہِمْ أَعَاجِیبُ۔",,,27017 27018,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنِ الأَوْزَاعِیِّ ، عَن حَسَّانَ بْنِ عَطِیَّۃَ ، عَنْ أَبِی کَبْشَۃَ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : حَدِّثُوا عَن بَنِی إسْرَائِیلَ ، وَلاَ حَرَجَ۔",,,27018 27019,"حَدَّثَنَا عَفَّانُ قَالَ : حدَّثَنَا ہَمَّامٌ ، عَن زَیْدِ بْنِ أَسْلَمَ ، عَنْ عَطَائِ بْنِ یَسَارٍ ، عَنْ أَبِی سَعِیدٍ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : حَدِّثُوا عَن بَنِی إسْرَائِیلَ ، وَلاَ حَرَجَ۔ (احمد 39)",,,27019 27020,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَن یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَن عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ قَالَ : لَعَنَ اللَّہُ الْمُتَخَنِّثِینَ مِنَ الرِّجَالِ ، وَالْمُتَرَجِّلاَت مِنَ النِّسَائِ قَالَ : قُلْتُ لِعِکْرِمَۃَ : مَا الْمُتَرَجِّلاَتُ ؟ قَالَ : الْمُتَشَبِّہَاتُ بِالرِّجَالِ۔ (بخاری 5885۔ ابوداؤد 4094)",,,27020 27021,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ جَہْضَمِ بْنِ عَبْدِ اللہِ ، عَمنْ حَدَّث ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ قَالَ : لَعَنَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْمُتَخَنِّثِینَ مِنَ الرِّجَالِ الَّذِینَ یَتَشَبَّہُونَ بِالنِّسَائِ ، وَالْمُتَرَجِّلاَت مِنَ النِّسَائِ اللاَتِی یَتَشَبَّہْنَ بِالرِّجَالِ۔ (ابوداؤد 4095۔ احمد 1715)",,,27021 27022,"حَدَّثَنَا وَکِیعٌ ، عَن ہِشَامٍ ، عَنْ أَبِیہِ ، عَن زَیْنَبَ بِنْتِ أُمِّ سَلَمَۃَ ، عَن أُمِّ سَلَمَۃَ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ دَخَلَ عَلَیْہَا فَسَمِعَ مُخَنَّثًا وَہُوَ یَقُولُ لِعَبْدِ اللہِ بْنِ أَبِی أُمَیَّۃَ أَخِیہَا : إِنْ یَفْتَحِ اللَّہُ الطَّائِفَ غَدًا دَلَلْتُک عَلَی امْرَأَۃٍ تُقْبِلُ بِأَرْبَعٍ وَتُدْبِرُ بِثَمَانٍ ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَخْرِجُوہُمْ مِنْ بُیُوتِکُمْ۔ (مسلم 1715۔ ابوداؤد 4891)",,,27022 27023,حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنِ الْوَلِیدِ بْنِ الْعَیْزَارِ ، عَن عِکْرِمَۃَ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ لاَ یَدْخُلُ بَیْتًا فِیہِ مُخَنَّثٌ۔,,,27023 27024,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الأَجْلَحِ ، عَنِ الشَّعْبِیِّ قَالَ : لَعَنَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْمُتَشَبِّہِینَ مِنَ الرِّجَالِ بِالنِّسَائِ ، وَالْمُتَشَبِّہَات مِنَ النِّسَائِ بِالرِّجَالِ۔",,,27024 27025,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ قَالَ : حدَّثَنَا أَبُو حَیَّانَ ، عَن یُونُسَ ، عَنِ الْحَسَنِ یَرْفَعُہُ إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : لُعِنَ مِنَ الرِّجَالِ الْمُتَشَبِّہُ بِالنِّسَائِ وَلُعِنَ مِنَ النِّسَائِ الْمُتَشَبِّہَۃُ الْمُتَرَجِّلَۃُ۔",,,27025 27026,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَن حَسَنٍ ، عَنْ إبْرَاہِیمَ بْنِ عَبْدِ الأَعْلَی ، عَن سُوَیْد بْنِ غَفَلَۃَ قَالَ : الْمُتَشَبِّہَۃُ بِالرِّجَالِ مِنَ النِّسَائِ ، لَیْسَتْ مِنَّا وَلَسْنَا مِنْہَا۔",,,27026 27027,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ أَبِی سُفْیَانَ ، عَنْ جَابِرٍ قَالَ : جَائَ رَجُلٌ إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقَالَ : یَا رَسُولَ اللہِ ، أَیُّ الْمُسْلِمِینَ أَفْضَلُ ؟ فَقَالَ : مَنْ سَلِمَ الْمُسْلِمُونَ مِنْ لِسَانِہِ وَیَدِہِ۔\n\n(مسلم 65۔ احمد 372)",,,27027 27028,"حَدَّثَنَا غُنْدَرٌ ، عَن شُعْبَۃَ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ عَبْدِ اللہِ بْنِ الْحَارِثِ ، عَنْ أَبِی کَثِیرٍ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو قَالَ : قامَ رَجُلٌ فَقَالَ : یَا رَسُولَ اللہِ ، أَیُّ الإِسْلاَمِ أَفْضَلُ ، قَالَ : أَنْ یَسْلَمَ الْمُسْلِمُونَ مِنْ یَدِکَ وَلِسَانِک۔ (مسلم 64۔ احمد 36391)",,,27028 27029,"حَدَّثَنَا غُنْدَرٌ ، عَن شُعْبَۃَ ، عَنِ الْحَکَمِ ، قَالَ : سَمِعْتُ عُرْوَۃَ بْنَ النَّزَّالِ یُحَدِّثُ عَن مُعَاذِ بْنِ جَبَلٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ لَہُ : أَلاَ أَدُلُّک عَلَی أَمْلَکِ ذَلِکَ کُلِّہِ ، قَالَ : قُلْتُ : یَا رَسُولَ اللہِ ، قَوْلُک أَلاَ أَدُلُّکَ عَلَی أَمْلَکِ ذَلِکَ کُلِّہِ قَالَ : فَأَشَارَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِیَدِہ إلَی لِسَانِہِ ، قَالَ : قُلْتُ : یَا رَسُولَ اللہِ ، وَإِنَّا لَنُؤَاخَذُ بِمَا نَتَکَلَّمُ بِہِ ، قَالَ : ثَکِلَتْک أُمُّک یا مُعَاذُ ، وَہَلْ یَکُبُّ النَّاسَ عَلَی مَنَاخِرِہِمْ إلاَّ حَصَائِدُ أَلْسِنَتِہِمْ ، قَالَ شُعْبَۃُ : وَقَالَ الْحَکَمُ : وَحَدَّثَنِی بِہِ مَیْمُونُ بْنُ أَبِی شَبِیبٍ ، وَسَمِعْتہ مِنْہُ مُنْذُ أَرْبَعِینَ سَنَۃً۔ (ترمذی 2616۔ احمد 233)",,,27029 27030,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَن یَزِیدَ بْنِ حَیَّانَ ، عَن عَنبَس بْنِ عُقْبَۃَ قَالَ عَبْدُ اللہِ : وَالَّذِی لاَ إلَہَ غَیْرُہُ ، مَا عَلَی الأَرْضِ شَیْئٌ أَحْوَجُ إلَی طُولِ سِجْنٍ مِنْ لِسَانٍ۔ (ابوداؤد 159)",,,27030 27031,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنِ ابْنِ عَجْلاَنَ ، عَن زَیْدِ بْنِ أَسْلَمَ ، عَنْ أَبِیہِ قَالَ : دَخَلَ عُمَرُ عَلَی أَبِی بَکْرٍ وَہُوَ آخِذٌ بِلِسَانِہِ ہَکَذَا ، یَقُولُ : ہَا إنَّ ذَا أَوْرَدَنِی الْمَوَارِدَ۔",,,27031 27032,"حَدَّثَنَا غُنْدَرٌ ، عَن شُعْبَۃَ ، عَن یَعْلَی بْنِ عَطَائٍ ، عَنْ عَبْدِ اللہِ بْنِ سُفْیَانَ ، عَنْ أَبِیہِ قَالَ : قُلْتُ : یَا رَسُولَ اللہِ ، أَیُّ شَیْئٍ أَتْقَی ؟ فَأَشَارَ بِیَدِہِ إلَی لِسَانِہِ۔ (ترمذی 2410۔ احمد 384)",,,27032 27033,"حَدَّثَنَا وَکِیعٌ ، عَن سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ دِینَارٍ ، عَنِ ابْنِ عُمَرَ قَالَ : أَحَقُّ مَا طَہَّرَ الْمُسْلِمُ لِسَانَہُ۔",,,27033 27034,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ أَبِی أُمَامَۃَ بْنِ سَہْلٍ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَقُلْ أَحَدُکُمْ : إنِّی خَبِیثُ النَّفْسِ ، وَلْیَقُلْ ، إنِّی لَقِسُ النَّفْسِ۔ (بخاری 6180)",,,27034 27035,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَن ہِشَامٍ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ رضی اللہ عنہا ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : لاَ یَقُلْ أَحَدُکُمْ : خَبُثَتْ نَفْسِی ، وَلْیَقُلْ : لَقِسَتْ نَفْسِی۔ (بخاری 6179۔ مسلم 16)",,,27035 27036,"حَدَّثَنَا وَکِیعٌ، عَن مِسْعَرٍ، عَن سِمَاکٍ الْحَنَفِیِّ ، قَالَ: سَمِعْتُ ابْنَ عَبَّاسٍ یَکْرَہُ أَنْ یَقُولَ : إنِّی کَسْلاَنُ۔",,,27036 27037,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی رَاشِدٍ ، أَنَّ أُخْتًا لِعُبَیْدِ بْنِ عُمَیْرٍ اسْتَشْفَعَتْ لِرَجُلٍ عَلَیْہِ فَقَالَتْ : إنَّمَا ہُوَ بِاللَّہِ وَبِکَ ، فَغَضِبَ فَقَالَ : إنَّمَا ہُوَ بِاللَّہِ۔",,,27037 27038,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَن سُفْیَانَ ، عَن مُخْتَارٍ ، قَالَ : سَمِعْتُ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ یَکْرَہُ أَنْ یَقُولَ : اللَّہُمَّ تَصَدَّقَ عَلَیَّ ، وَلَکِنْ لِیَقُلْ : اللَّہُمَّ امْنُنْ عَلَیَّ۔",,,27038 27039,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : أَخْبَرَنَا ہِشَامٌ ، عَن حَفْصَۃَ ، عَنِ الرَّبِیعِ بْنِ زِیَادٍ ، عَن کَعْبٍ قَالَ : وَاللَّہِ مَا اسْتَقَامَ لِعَبْدٍ ثَنَائٌ فِی الأَرْضِ حَتَّی اسْتَقَرَّ لَہُ فِی أَہْلِ السَّمَائِ۔",,,27039 27040,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : أَخْبَرَنَا الْعَوَّامُ بْنُ حَوْشَبٍ قَالَ : الْتَقَیْت أَنَا وَإِیَاسُ بْنُ مُعَاوِیَۃَ بِذَاتِ عِرْقٍ فَذَکَرْنَا إبْرَاہِیمَ التَّیْمِیَّ فَقَالَ إیَاسٌ : لَوْلاَ کَرَامَتُہُ عَلَیَّ لأَثْنَیْتُ عَلَیْہِ فَقُلْت : ہَلْ تَعْرِفُہُ ؟ قَالَ : نَعَمْ ، قُلْتُ : فَلِمَ تَکْرَہُ الثَّنَائَ عَلَیْہِ ، قَالَ : إِنَّہُ کَانَ یُقَالُ : إنَّ الثَّنَائَ مِنَ الْجَزَائِ۔",,,27040 27041,"حَدَّثَنَا مُعَاذٌ ، عَن حُمَیْدٍ ، عَنْ أَنَسٍ قَالَ : قالَتِ الْمُہَاجِرُونَ : یَا رَسُولَ اللہِ ، مَا رَأَیْنَا مِثْلَ قَوْمٍ قَدِمْنَا عَلَیْہِمْ أَحْسَنَ بَذْلاً مِنْ کَثِیرٍ ، وَلاَ أَحْسَنَ مُوَاسَاۃً فِی قَلِیلٍ ، کَفَوْنَا المؤنۃ ، وَأَشْرَکُونَا فِی الْمَہْنَأِ ، قَدْ خَشِینَا أَنْ یَذْہَبُوا بِالأَجْرِ کُلِّہِ ، فَقَالَ : لاَ ، مَا أَثْنَیْتُمْ عَلَیْہِمْ وَدَعَوْتُمُ اللَّہَ لَہُمْ۔ (بخاری 217۔ ابوداؤد 4779)",,,27041 27042,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : أَخْبَرَنَا أَشْعَثُ بْنُ سَوَّارٍ ، عَن کُرْدُوسٍ ، عَنْ عَبْدِ اللہِ قَالَ : إنَّ لِلْقُلُوبِ نَشَاطًا وَإِقْبَالاً ، وَإِنَّ لَہَا لَتَوْلِیَۃً وَإِدْبَارًا ، فَحَدِّثُوا النَّاسَ مَا أَقْبَلُوا عَلَیْکُمْ۔",,,27042 27043,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَن عُثْمَانَ بْنَ غِیَاثٍ ، عَنْ أَبِی السَّلِیْلِ قَالَ : قدِمَ عَلَیْنَا رَجُلٌ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَکَانُوا یَجْتَمِعُونَ عَلَیْہِ ، فَصَعِدَ عَلَی ظَہْرِ بَیْتٍ فَحَدَّثَہُمْ۔",,,27043 27044,"حَدَّثَنَا جَعْفَرُ بْنُ عَوْنٍ قَالَ : أَخْبَرَنَا أَبُو الْعُمَیْسِ ، عَنْ أَبِی طَلْحَۃَ قَالَ : قَدِمَ أَنَسُ بْنُ مَالِکٍ الْکُوفَۃَ فَاجْتَمَعَنا عَلَیْہِ ، قَالَ : فَقُلْنَا : حَدِّثْنَا مَا سَمِعْت مِنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : وَہُوَ یَقُولُ : أَیُّہَا النَّاسُ ، انْصَرِفُوا عَنی ، حَتَّی أَلْجَأْنَاہُ إلَی حَائِطِ الْقَصْرِ فَقَالَ : لَوْ تَعْلَمُونَ مَا أَعْلَمُ لَبَکَیْتُمْ کَثِیرًا وَلَضَحِکْتُمْ قَلِیلاً أَیُّہَا النَّاسُ ، انْصَرِفُوا عَنی ، فَانْصَرَفْنَا عَنہُ۔ (احمد 180)",,,27044 27045,"حَدَّثَنَا عَفَّانُ قَالَ : حدَّثَنَا أَبُو ہِلاَلٍ قَالَ : حَدَّثَنَا الْحَسَنُ قَالَ : حَدِّثُوا النَّاسَ مَا أَقْبَلُوا عَلَیْکُمْ بِوُجُوہِہِمْ ، فَإِذَا الْتَفَتُوا فَاعْلَمُوا أَنَّ لَہُمْ حَاجَاتٍ۔ (دارمی 449)",,,27045 27046,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَن شَقِیقٍ ، عَنْ عَبْدِ اللہِ قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَتَخَوَّلُنَا بِالْمَوْعِظَۃِ مَخَافَۃَ السَّآمَۃِ عَلَیْنَا۔ (مسلم 2172۔ احمد 425)",,,27046 27047,حَدَّثَنَا جَرِیرٌ ، عَن مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، أَنَّہُ کَانَ إذَا رَأَی مِنْ أَصْحَابِہِ ہَشَاشًا یَعْنِی انْبِسَاطًا ذَکَّرَہُمْ۔,,,27047 27048,"حَدَّثَنَا ابْنُ إدْرِیسَ ، وَابْنُ عُیَیْنَۃَ ، وَأَبُو خَالِدٍ الأَحْمَرُ ، عَن مُحَمَّدِ بْنِ عَجْلاَنَ ، عَن بُکَیْر بْنِ عَبْدِ اللہِ بْنِ الأَشَجِّ ، عَن مَعْمَرٍ ، عَن عُبَیْدِ اللہِ بْنِ عَدِیِّ بْنِ الْخِیَارِ قَالَ : قَالَ عُمَرُ : لاَ تُبَغِّضُوا اللَّہَ إلَی عِبَادِہِ ، یَکُونُ أَحَدُکُمْ إمَامًا فَیُطَوِّلُ عَلَیْہِمْ مَا ہُمْ فِیہِ ، وَیَکُونُ أَحَدُکُمْ قَاصًّا فَیُطَوِّلُ عَلَیْہِمْ مَا ہُمْ فِیہِ۔",,,27048 27049,"حَدَّثَنَا وَکِیعٌ ، عَن مُوسَی بْنِ عُبَیْدَۃَ ، عَن مُحَمَّدِ بْنِ ثَابِتٍ ، عَنْ أَبِی ہُرَیْرَۃَ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا قَالَ الرَّجُلُ لأَخِیہِ : جَزَاک اللَّہُ خَیْرًا ، فَقَدْ أَبْلَغَ فِی الثَّنَائِ۔ (ترمذی 2035)",,,27049 27050,"حَدَّثَنَا وَکِیعٌ ، عَن أُسَامَۃَ بْنِ زَیْدٍ ، عَن طَلْحَۃَ بْنِ عُبَیْدِ اللہِ بْنِ کَرِیزٍ قَالَ : قَالَ عُمَرُ : لَوْ یَعْلَمُ أَحَدُکُمْ مَا لَہُ فِی قَوْلِہِ لأَخِیہِ : جَزَاک اللَّہُ خَیْرًا ، لأَکْثَرَ مِنْہَا بَعْضُکُمْ لِبَعْضٍ۔",,,27050 27051,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْبَرَائِ قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا أَخَذَ مَضْجَعَہُ قَالَ : اللَّہُمَّ إلَیْک أَسْلَمْت نَفْسِی ، وَإِلَیْک وَجَّہْت وَجْہِی ، وَإِلَیْک فَوَّضْت أَمْرِی ، وَإِلَیْک أَلْجَأْت ظَہْرِی ، رَغْبَۃً وَرَہْبَۃً إلَیْک ، لاَ مَلْجَأَ وَلاَ مَنْجَی مِنْک إلاَّ إلَیْک ، آمَنْت بِکِتَابِکَ الَّذِی أَنْزَلْت ، وَبِنَبِیِّکَ الَّذِی أَرْسَلْت ، أَوْ برَسُولِکَ الَّذِی أَرْسَلْت۔ (بخاری 6313۔ ترمذی 3394)",,,27051 27052,"حَدَّثَنَا وَکِیعٌ ، عَن سُفْیَانَ ، عَنْ عَبْدِ الْمَلِکِ بْنِ عُمَیْرٍ ، عَن رِبْعِیٍّ ، عَن حُذَیْفَۃَ قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا نَامَ قَالَ : اللَّہُمَّ بِاسْمِکَ أَحْیَا وَأَمُوتُ ، فَإِذَا اسْتَیْقَظَ قَالَ : الْحَمْدُ لِلَّہِ الَّذِی أَحْیَانَا بَعْدَ مَا أَمَاتَنَا وَإِلَیْہِ النُّشُورُ۔ (بخاری 6312۔ ترمذی 3417)",,,27052 27053,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ أَبِیہِ قَالَ : کُنْتُ قَاعِدًا عِنْدَ عَمَّارٍ فَأَتَاہُ رَجُلٌ فَقَالَ : أَلاَ أُعَلِّمُک کَلِمَاتٍ ، قَالَ کَأَنَّہُ یَرْفَعُہُنَّ إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا أَخَذْت مَضْجَعَک مِنَ اللَّیْلِ فَقُلْ : اللَّہُمَّ أَسْلَمْت نَفْسِی إلَیْک ، وَوَجَّہْت وَجْہِی إلَیْکَ ، وَفَوَّضْت أَمْرِی إلَیْک ، وَأَلْجَأْت ظَہْرِی إلَیْک ، آمَنْت بِکِتَابِکَ الْمُنْزَلِ ، وَنَبِیِّکَ الْمُرْسَلِ ، نَفْسِی خَلَقْتہَا ، لَکَ مَحْیَاہَا وَمَمَاتُہَا ، فَإِنْ کَفَتَّہا فَارْحَمْہَا ، وَإِنْ أَخَّرْتہَا فَاحْفَظْہَا بِحِفْظِ الإِیمَانِ۔",,,27053 27054,"حَدَّثَنَا غُنْدَرٌ ، عَن شُعْبَۃَ ، عَن یَعْلَی بْنِ عَطَائٍ ، قَالَ : سَمِعْتُ عَمْرَو بْنَ عَاصِمٍ یُحَدِّثُ أَنَّہُ سَمِعَ أَبَا ہُرَیْرَۃَ ، أَنَّ أَبَا بَکْرٍ قَالَ لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَخْبِرْنِی بِشَیْئٍ أَقُولُہُ إذَا أَمْسَیْت وَإِذَا أَصْبَحْت ، قَالَ: قُلِ اللَّہُمَّ ، عَالِمَ الْغَیْبِ وَالشَّہَادَۃِ ، فَاطِرَ السَّمَاوَاتِ وَالأَرْضِ ، رَبَّ کُلِّ شَیْئٍ وَمَلِیکَہُ ، أَشْہَدُ أَنْ لاَ إلَہَ إلاَّ أَنْتَ ، أَعُوذُ بِکَ مِنْ شَرِّ نَفْسِی وَمِنَ الشَّیْطَانِ وَشِرْکِہِ ، قُلْہُ إذَا أَصْبَحْت وَإِذَا أَمْسَیْت ، وَإِذَا أَخَذْت مَضْجَعَک۔ (نسائی 7715۔ دارمی 2689)",,,27054 27055,"حَدَّثَنَا غُنْدَرٌ ، عَن شُعْبَۃَ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی السَّفَرِ ، قَالَ : سَمِعْتُ أَبَا بَکْرِ بْنَ أَبِی مُوسَی یُحَدِّثُ عَنِ الْبَرَائِ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ إذَا اسْتَیْقَظَ قَالَ : الْحَمْدُ لِلَّہِ الَّذِی أَحْیَانَا بَعْدَ مَا أَمَاتَنَا وَإِلَیْہِ النُّشُورُ ، قَالَ شُعْبَۃُ : ہَذَا ، أَوْ نَحْوَ ہَذَا وَإِذَا نَامَ قَالَ : اللَّہُمَّ بِاسْمِکَ أَحْیَا وَبِاسْمِکَ أَمُوتُ۔ (مسلم 2083۔ احمد 302)",,,27055 27056,"حَدَّثَنَا ابْنُ نُمَیْرٍ قَالَ : حدَّثَنَا عُبَیْدُ اللہِ بْنُ عُمَرَ ، عَن سَعِیدِ بْنِ أَبِی سَعِیدٍ الْمَقْبُرِیِّ ، عَنْ أَبِی ہُرَیْرَۃَ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : إذَا أَرَادَ أَحَدُکُمْ أَنْ یَضْطَجِعَ عَلَی فِرَاشِہِ فَلْیَنْزِعْ دَاخِلَۃَ إزَارِہِ ، ثُمَّ لِیَنْفُضْ بِہَا فِرَاشَہُ فَإِنَّہُ لاَ یَدْرِی مَا خَلَّفَہُ عَلَیْہِ ، ثُمَّ لِیَضْطَجِعْ عَلَی شِقِّہِ الأَیْمَنِ ، ثُمَّ لِیَقُلْ ، بِاسْمِکَ رَبِّی وَضَعْت جَنْبِی وَبِکَ أَرْفَعُہُ ، فَإِنْ أَمْسَکْت نَفْسِی فَارْحَمْہَا ، وَإِنْ أَرْسَلْتَہَا فَاحْفَظْہَا بِمَا تَحْفَظُ بِہِ عِبَادَک الصَّالِحِینَ۔ (بخاری 7393۔ ترمذی 3401)",,,27056 27057,"حَدَّثَنَا غُنْدَرٌ ، عَن شُعْبَۃَ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَن سَعْدِ بْنِ عُبَیْدَۃَ ، عَنِ الْبَرَائِ بْنِ عَازِبٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أَنَّہُ قَالَ لِرَجُلٍ : إذَا أَخَذْت مَضْجَعَک فَقُلْ : اللَّہُمَّ أَسْلَمْت نَفْسِی إلَیْک ، وَوَجَّہْت وَجْہِی إلَیْک ، وَفَوَّضْت أَمْرِی إلَیْک ، وَأَلْجَأْت ظَہْرِی إلَیْک رَغْبَۃً وَرَہْبَۃً إلَیْک ، لاَ مَنْجَی ، وَلاَ مَلْجَأَ مِنْک إلاَّ إلَیْک ، آمَنْت بِکِتَابِکَ الَّذِی أَنْزَلْت ، وَنَبِیِّکَ الَّذِی أَرْسَلْت ، فَإِنْ مُتَّ ، مُتَّ عَلَی الْفِطْرَۃِ۔\n\n(بخاری 247۔ مسلم 2081)",,,27057 27058,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَن حَبِیبٍ ، عَنْ عَبْدِ اللہِ بْنِ بَابَاہُ ، عَنْ أَبِی ہُرَیْرَۃَ قَالَ : مَنْ قَالَ حِینَ یَأْوِی إلَی فِرَاشِہِ، لاَ إلَہَ إلاَّ اللَّہُ وَحْدَہُ، لاَ شَرِیکَ لَہُ، لَہُ الْمُلْکُ وَلَہُ الْحَمْدُ وَہُوَ عَلَی کُلِّ شَیْئٍ قَدِیرٌ، سُبْحَانَ اللہِ وَبِحَمْدِہِ الحَمدُ للہ ، لاَ إلَہَ إلاَّ اللَّہُ ، اللَّہُ أَکْبَرُ ، غُفِرْت ذُنُوبُہُ ، وَإِنْ کَانَتْ مِثْلَ زَبَدِ الْبَحْرِ۔\n\n(ابن حبان 5528)",,,27058 27059,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ قَالَ: حدَّثَنَا زُہَیْرٌ ، عَنْ أَبِی إِسْحَاقَ، عَن فَرْوَۃَ بْنِ نَوْفَلٍ، عَنْ أَبِیہِ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ لَہُ : مَجِیئٌ مَا جَائَ بِکَ ؟ قَالَ : جِئْت یَا رَسُولَ اللہِ تُعَلِّمُنِی شَیْئًا عِنْدَ مَنَامِی، قَالَ: إذَا أَخَذْت مَضْجَعَک فَاقْرَأْ {قُلْ یَا أَیُّہَا الْکَافِرُونَ} ثُمَّ نَمْ عَلَی خَاتِمَتِہَا فَإِنَّہَا بَرَائَۃٌ مِنَ الشِّرْکِ۔\n\n(ابوداؤد 5016۔ دارمی 3427)",,,27059 27060,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ أَبِی مَالِکٍ الأَشْجَعِیِّ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ نَوْفَلٍ الأَشْجَعِیِّ ، عَنْ أَبِیہِ قَالَ : قُلْتُ : یَا رَسُولَ اللہِ ، أَخْبِرْنِی بِشَیْئٍ أَقُولُہُ إذَا أَصْبَحْتُ وَإِذَا أَمْسَیْتُ ؟ قَالَ : اقْرَأْ {قُلْ یَا أَیُّہَا الْکَافِرُونَ} ثُمَّ نَمْ عَلَی خَاتِمَتِہَا فَإِنَّہَا بَرَائَۃٌ مِنَ الشِّرْکِ۔",,,27060 27061,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ قَالَ : حدَّثَنَا زُہَیْرٌ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمٍ ، عَنْ عَلِیٍّ قَالَ : إذَا أَخَذْتَ مَضْجَعَک فَقُلْ : بِسْمِ اللہِ وَفِی سَبِیلِ اللہِ وَعَلَی مِلَّۃِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَحِینَ تُدْخِلُ الْمَیِّتَ قَبْرَہُ۔",,,27061 27062,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : أَخْبَرَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ عَاصِمٍ ، عَن سَوَائٍ ، عَن حَفْصَۃَ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ إذَا أَخَذَ مَضْجَعَہُ قَالَ : رَبِّ قِنِی عَذَابَک یَوْمَ تَبْعَثُ عِبَادَک۔\n\n(ابوداؤد 5006۔ احمد 288)",,,27062 27063,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْبَرَائِ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لِرَجُلٍ : یَا فُلاَنُ ، إذَا أَوَیْت إلَی فِرَاشِکَ فَقُلْ : اللَّہُمَّ أَسْلَمْت نَفْسِی إلَیْک ، وَوَجَّہْت وَجْہِی إلَیْک وَوَلَّیْت ظَہْرِی إلَیْک ، لاَ مَلْجَأَ وَلاَ مَنْجَی مِنْک إلاَّ إلَیْک ، آمَنْتُ بِکِتَابِکَ الَّذِی أَنْزَلْت ، وَنَبِیِّکَ الَّذِی أَرْسَلْت فَإِنَّک مِتَّ مِنْ لَیْلَتِکَ مِتَّ عَلَی الْفِطْرَۃِ ، فَإِنْ أَصْبَحْت أَصَبْتَ خَیْرًا۔ (بخاری 7488۔ احمد 299)",,,27063 27064,"حَدَّثَنَا جَعْفَرُ بْنُ عَوْنٍ ، عَنِ الأَفْرِیقِیِّ ، عَنْ عَبْدِ اللہِ بْنِ یَزِیدَ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ لِرَجُلٍ مِنَ الأَنْصَارِ : کَیْفَ تَقُولُ حِینَ تُرِیدُ أَنْ تَنَامَ ؟ قَالَ : أَقُولُ بِاسْمِکَ وَضَعْت جَنْبِی فَاغْفِرْ لِی قَالَ : قَدْ غُفِرَ لَک۔ (نسائی 10606۔ احمد 173)",,,27064 27065,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَن زَائِدَۃَ ، عَن مَنْصُورٍ ، عَنْ إبْرَاہِیمَ قَالَ : کَانَ أَصْحَابُنَا یَأْمُرُونَنَا وَنَحْنُ غِلْمَانٌ إذَا أَوَیْنَا إلَی فِرَاشِنَا أَنْ نُسَبِّحَ ثَلاَثًا وثَلاَثِینَ ، وَنَحْمَدَ ثَلاَثًا وَثَلاَثِینَ ، وَنُکَبِّرَ أَرْبَعًا وَثَلاَثِینَ۔",,,27065 27066,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَن زَائِدَۃَ ، عَنْ عَاصِمٍ ، عَنِ الْمُسَیَّبِ ، عَن حَفْصَۃَ قَالَتْ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا أَخَذَ مَضْجَعَہُ وَضَعَ یَدَہُ الْیُمْنَی تَحْتَ خَدِّہِ الأَیْمَنِ۔",,,27066 27067,"حَدَّثَنَا عُبَیْدُ بْنُ سَعِیدٍ ، عَن شُعْبَۃَ ، عَنْ أَبِی المُؤَمِّلِ ، عَنِ الزُّہْرِیِّ ، عَن عُرْوَۃَ ، عَنْ عَائِشَۃَ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ إذَا صَلَّی رَکْعَتَیِ الْفَجْرِ اضْطَجَعَ وَوَضَعَ یَدَہُ الْیُمْنَی تَحْتَ خَدِّہِ الأَیْمَنِ۔\n\n(بخاری 626۔ مسلم 121)",,,27067 27068,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَن زَکَرِیَّا ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْبَرَائِ قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا نَامَ تَوَسَّدَ یَمِینَہُ تَحْتَ خَدِّہِ وَیَقُولُ : قِنِی عَذَابَک یَوْمَ تَبْعَثُ عِبَادَک۔ (احمد 290)",,,27068 27069,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی قَالَ : أَخْبَرَنَا إسْرَائِیلُ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی عُبَیْدَۃَ ، عَنْ أَبِیہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أَنَّہُ کَانَ إذَا نَامَ قَالَ : اللَّہُمَّ قِنِی عَذَابَک یَوْمَ تَجْمَعُ عِبَادَک ، وَکَانَ یَضَعُ یَمِینَہُ تَحْتَ خَدِّہِ۔ (ترمذی 255۔ احمد 394)",,,27069 27070,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ قَالَ : حدَّثَنَا عُبَیْدُ اللہِ ، عَن سَعِیدِ بْنِ أَبِی سَعِیدٍ الْمَقْبُرِیِّ ، عَنْ أَبِی ہُرَیْرَۃَ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : إذَا أَرَادَ أَحَدُکُمْ أَنْ یَضْطَجِعَ عَلَی فِرَاشِہِ فَلْیَضْطَجِعْ عَلَی شِقِّہِ الأَیْمَنِ۔",,,27070 27071,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَن سُفْیَانَ ، عَن سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنْ عَبْدِ اللہِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ أَبْزَی ، عَنْ أَبِیہِ قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا أَصْبَحَ قَالَ : أَصْبَحْنَا عَلَی فِطْرَۃِ الإِسْلاَمِ ، وَکَلِمَۃِ الإِخْلاَصِ ، وَدِینِ نَبِیِّنَا مُحَمَّدٍ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَمِلَّۃِ أَبِینَا إبْرَاہِیمَ حَنِیفًا مُسْلِمًا وَمَا کَانَ مِنَ الْمُشْرِکِینَ۔ (احمد 407۔ دارمی 2688)",,,27071 27072,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ قَالَ : حدَّثَنَا مِسْعَرٌ قَالَ : حَدَّثَنِی أَبُو عَقِیلٍ ، عَن سَابِقٍ ، عَنْ أَبِی سَلاَّمٍ خَادِمِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : مَا مِنْ مُسْلِمٍ ، أَوْ إنْسَانٍ ، أَوْ عَبْدٍ یَقُولُ حِینَ یُمْسِی وَیُصْبِحُ ثَلاَثَ مَرَّاتٍ : رَضِیت بِاللَّہِ رَبًّا وَبِالإِسْلاَمِ دِینًا وَبِمُحَمَّدٍ نَبِیًّا إلاَّ کَانَ حَقًّا عَلَی اللہِ أَنْ یُرْضِیَہُ یَوْمَ الْقِیَامَۃِ۔\n\n(ابن ماجہ 3870)",,,27072 27073,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَن مَنْصُورٍ ، عَن رِبْعِیِّ بْنِ حِرَاشٍ ، عَن رَجُلٍ مِنَ النَّخْعِ ، عَن سَلْمَانَ قَالَ : مَنْ قَالَ إذَا أَصْبَحَ : اللَّہُمَّ أَنْتَ رَبِّی لاَ شَرِیکَ لَکَ ، أَصْبَحْنَا وَأَصْبَحَ الْمُلْکُ لِلَّہِ ، وَالْحَمْدُ لِلَّہِ لاَ شَرِیکَ لَہُ وَإِذَا أَمْسَی مِثْلُ ذَلِکَ ، کَانَ کَفَّارَۃً لِمَا أحْدَثَ بَیْنَہُمَا۔",,,27073 27074,"حَدَّثَنَا ابْنُ إدْرِیسَ، عَن حُصَیْنٍ، عَن تَمِیمِ بْنِ سَلَمَۃَ، عَنْ عَبْدِاللہِ بْنِ سَبْرَۃَ، عَنِ ابْنِ عُمَرَ، أَنَّہُ کَانَ یَقُولُ إذَا أَصْبَحَ وَأَمْسَی : اللَّہُمَّ اجْعَلْنِی مِنْ أَفْضَلِ عِبَادِکَ الْغَدَاۃَ ، أَوِ الْعَشِیَّۃَ نَصِیبًا مِنْ خَیْرٍ تَقْسِمُہُ ، أو نُورًا تَہْدِی بِہِ، أو رَحْمَۃً تَنْشُرُہَا، أو رِزْقًا تَبْسُطُہُ، أو ضر تَکْشِفُہُ، أو بَلاَئً تدْفَعُہُ، أو فِتْنَۃً تَصْرِفُہَا، أو شَرًّا تَدْفَعُہُ۔",,,27074 27075,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَن حُصَیْنٍ ، عَنْ عَمْرِو بْنِ مُرَّۃَ قَالَ : قُلْتُ لِسَعِیدِ بْنِ الْمُسَیَّبِ : مَا تَقُولُون إذَا أَصْبَحْتُمْ وَأَمْسَیْتُمْ مِمَّا تَدْعُونَ بِہِ ؟ قَالَ : تَقُولُ : أَعُوذُ بوجہ اللہِ الْکَرِیمِ ، وَبِسْمِ اللہِ الْعَظِیمِ ، وَکَلِمَۃِ اللہِ التَّامَّۃِ ، مِنْ شَرِّ السَّآمَّۃِ وَالْعامَّۃِ ، وَمِنْ شَرِّ مَا خَلَقْت أَیْ رَبِّی ، وَشَرِّ مَا أَنْتَ آخِذٌ بِنَاصِیَتِہِ ، وَمِنْ شَرِّ ہَذَا الْیَوْمِ ، وَمِنْ شَرِّ مَا بَعْدَہُ ، وَشَرِّ الدُّنْیَا وَالآخِرَۃِ۔",,,27075 27076,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَن مُوسَی الْجُہَنِیِّ قَالَ : حدَّثَنِی رَجُلٌ ، عَن سَعِیدِ بْنِ جُبَیْرٍ ، أَنَّہُ قَالَ : مَنْ قَالَ (فَسُبْحَانَ اللہِ حِینَ تُمْسُونَ وَحِینَ تُصْبِحُونَ) حَتَّی یَفْرُغَ مِنَ الآیَۃِ ثَلاَثَ مَرَّاتٍ ، أَدْرَکَ مَا فَاتَہُ مِنْ یَوْمِہِ ، وَمَنْ قَالَہَا لَیلاً أَدْرَکَ مَا فَاتَہُ مِنْ یَوْمِہِ۔ (ابوداؤد 5037)",,,27076 27077,"حَدَّثَنَا الْحَسَنُ بْنُ مُوسَی قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ سُہَیْل بن أبی صالح ، عَنْ أَبِیہِ ، عَنِ أبی عیاش قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ قَالَ حِینَ یُصْبِحُ لاَ إلَہَ إلاَّ اللَّہُ وَحْدَہُ لاَ شَرِیکَ لَہُ ، لَہُ الْمُلْکُ وَلَہُ الْحَمْدُ وَہُوَ عَلَی کُلِّ شَیْئٍ قَدِیرٌ کَانَ لَہُ کَعَدْلِ رَقَبَۃٍ مِنْ وَلَدِ إسْمَاعِیلَ ، وَکُتِبَ لَہُ بہا عَشْرُ حَسَنَاتٍ ، وَحُطَّ عَنہُ بِہَا عَشْرُ سَیِّئَاتٍ ، وَرُفِعَتْ لَہُ بِہَا عَشْرُ دَرَجَاتٍ ، وَکَانَ فِی حِرْزٍ مِنَ الشَّیْطَانِ حَتَّی یُمْسِیَ ، وَإِذَا أَمْسَی مِثْلَ ذَلِکَ حَتَّی یُصْبِحَ۔ (ابن ماجہ 3867۔ احمد 60)",,,27077 27078,"حَدَّثَنَا وَکِیعٌ ، عَن سَعِیدِ بْنِ صَالِحٍ ، عَن رَجُلٍ لَمْ یُسَمِّہِ ، أَنَّ عُمَرَ کَتَبَ : لاَ تُخَلِّلُوا بِالْقَصَبِ۔",,,27078 27079,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ أَبِی بَکْرٍ الغسََّانِیِّ ، عَن ضَمُرَۃَ بْنِ حَبِیبٍ قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ السِّوَاکِ بِعُودِ الرَّیْحَانِ وَالرُّمَّانِ ، وَقَالَ یُحَرِّکُ عِرْقَ الْجُذَامِ۔",,,27079 27080,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ قَالَ : حدَّثَنَا إسْرَائِیلُ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْبَرَائِ قَالَ : مَرَّ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَلَی مَجْلِسٍ لِلأََنْصَارِ فَقَالَ : إِنْ أَبَیْتُمْ أَنْ لاَ تَجْلِسُوا فَاہْدُوا السَّبِیلَ ، وَردوا السَّلام ، وَأَعِینُوا الْمَظْلُومَ۔ (ترمذی 2726۔ احمد 282)",,,27080 27081,"حَدَّثَنَا ابْنُ نُمَیْرٍ قَالَ : حدَّثَنَا مُوسَی بْنُ عُبَیْدَۃ ، عَنْ أَیُّوبَ بْنِ خَالِدٍ ، عَن مَالِکِ بْنِ التَّیْہَانِ قَالَ : اجْتَمَعَتْ جَمَاعَۃٌ مِنَّا عِنْدَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقُلْنَا : یَا رَسُولَ اللہِ ، إنَّا أَہْلُ سَافِلَۃٍ وَأَہْلُ عَالِیَۃٍ ، نَجْلِسُ ہَذِہِ الْمَجَالِسَ فَمَا تَأْمُرُنَا ؟ قَالَ : أَعْطُوا الْمَجَالِسَ حَقَّہَا ، قُلْنَا وَمَا حَقہَا : قَالَ : غُضُّوا أَبْصَارَکُمْ ، وَرُدُّوا السَّلاَمَ ، وَأَرْشِدُوا الأَعْمَی ، وَأْمُرُوا بِالْمَعْرُوفِ ، وَانْہَوْا عَنِ الْمُنْکَرِ۔ (مسند 685)",,,27081 27082,"حَدَّثَنَا عَفَّانُ قَالَ : حدَّثَنَا عَبْدُ الْوَاحِدِ بْنُ زِیَادٍ قَالَ : حَدَّثَنَا عُثْمَانُ بْنُ حَکِیمٍ قَالَ : حَدَّثَنَی إِسْحَاقُ بْنُ عَبْدِ اللہِ بْنِ أَبِی طَلْحَۃَ قَالَ : حَدَّثَنِی أَبِی قَالَ : قَالَ أَبُو طَلْحَۃَ : کُنَّا جُلُوسًا بِالأَفْنِیَۃِ ، فَمَرَّ بِنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقَالَ : مَا لَکُمْ وَلِمَجَالِسِ الصُّعُدَاتِ اجتنبوا مجالس الصُّعُدَاتِ ؟ قَالَ : قُلْنَا : یَا رَسُولَ اللہِ ، إنَّا جَلَسْنَا بِغَیْرِ مَا بَأْسٍ نَتَذَاکَرُ وَنَتَحَدَّثُ ، قَالَ : فأَعْطُوا الْمَجَالِسَ حَقَّہَا ، قَالَ : قُلْنَا : وَمَا حَقُّہَا یَا رَسُولَ اللہِ ؟ قَالَ : غَضُّ الْبَصَرِ ، وَرَدُّ السَّلاَمِ ، وَحُسْنُ الْکَلاَمِ۔ (احمد 30۔ ابویعلی 1417)",,,27082 27083,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَن مَالِکِ بْنِ مِغْوَلٍ ، عَنِ الشَّعْبِیِّ قَالَ : مَا جَلَسَ الرَّبِیعُ بْنُ خُثَیْمٍ مَجْلِسًا مُنْذُ تَأَزَّرَ بِإِزَارٍ ، قَالَ : أَخَافُ أَنْ یُظْلَمَ رَجُلٌ فَلاَ أنصرہ ، أَوْ یَفْتَرِی رَجُلٌ عَلَی رَجُلٍ فَأُکَلَّفُ الشَّہَادَۃَ عَلَیْہِ ، وَلاَ أَغُضُّ الْبَصَرَ ، وَلاَ أَہْدِی السَّبِیلَ ، أَوْ تَقَعُ الْحَامِلَۃُ فَلاَ أَحْمِلُ عَلَیْہَا۔",,,27083 27084,"حَدَّثَنَا ہُشَیم ، عَنِ الْعَوَّامِ ، عَنِ ابْنِ أَبِی الْہُذَیْلِ قَالَ : کَانُوا یَکْرَہُونَ إذَا اتَّخَذُوا الْمَجَالِسَ أَنْ یعروہا لِلسُّفَہَائِ۔",,,27084 27085,"حَدَّثَنَا مَحْبُوبُ الْقَوَارِیرِیُّ ، عَنِ الصَّعْبِ بْنِ حَکِیمٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ قَالَ : أَتَیْتُ عُمَرَ بْنَ الْخَطَّابِ فَجَعَلَ یَقُولُ : یَا ابْنَ أَخِی ، ثُمَّ سَأَلَنِی فَانْتَسَبْت لَہُ ، فَعَرَفَ ، أَنَّ أَبِی لَمْ یُدْرِکِ الإِسْلاَمَ ، فَجَعَلَ یَقُولُ : یَا بُنَیَّ یَا بُنَیَّ۔",,,27085 27086,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : حدَّثَنَا إسْمَاعِیلُ ، عَن قَیْسٍ ، عَنِ الْمُغِیرَۃِ بْنِ شُعْبَۃَ قَالَ : مَا سَأَلَ أَحَدٌ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الدَّجَّالِ ، أَکْثَرَ مِمَّا سَأَلْتُہُ ، فَقَالَ : أَیْ بُنَیَّ ، وَمَا یُصِیبُک مِنْہُ۔\n\n(مسلم 1693۔ ابن ماجہ 4073)",,,27086 27087,"حَدَّثَنَا وَکِیعٌ ، عَن ہِشَامٍ ، عَنْ أَبِی وَجْزَۃَ السَّعْدِیِّ ، عَن رَجُلٍ مِنْ مُزَیْنَۃَ ، عَن عُمَرَ بْنِ أَبِی سَلَمَۃَ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أُتِیَ بِطَعَامٍ فَقَالَ : یَا عُمَرُ یَا بُنَیَّ ، سَمِّ اللَّہَ وَکُلْ بِیَمِینِکَ وَکُلْ مِمَّا یَلِیک۔\n\n(ابوداؤد 3771۔ احمد 26)",,,27087 27088,"حَدَّثَنَا عَفَّانُ قَالَ : حدَّثَنَا أَبُو عَوَانَۃَ ، عَنِ الْجَعْدِ أَبِی عُثْمَانَ ، عَنْ أَنَسٍ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ لَہُ : یَا بُنَیَّ۔ (مسلم 1693۔ ابوداؤد 4925)",,,27088 27089,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَن عُمَارَۃَ بْنِ زَاذَانَ ، عَن مَکْحُولٍ الأَزْدِیِّ قَالَ : سُئِلَ ابْنُ عُمَرَ عَنِ الرَّجُلِ یُحْرِمُ مِنْ سَمَرْقَنْدَ ، أَوْ مِنْ خُرَاسَانَ ، أَوْ مِنَ الْکُوفَۃِ فَقَالَ : یَا لَیْتَنَا نَنْفَلِتُ مِنْ وَقْتِنَا یَا بُنَیَّ۔",,,27089 27090,"حَدَّثَنَا غُنْدَرٌ ، عَن شُعْبَۃَ ، عَنْ أَبِی جَمْرَۃَ قَالَ : حدَّثَنَا إیَاسٌ عن قَتَادَۃَ ، عَن قَیْسِ بْنِ عُبَادٍ ، أَنَّ أُبَیَّ بْنَ کَعْبٍ قَالَ لَہُ : یَا بُنَیَّ ، لاَ یَسُوئُک اللَّہُ۔",,,27090 27091,"حَدَّثَنَا جَرِیرٌ ، عَن قَابُوسَ ، عَنْ أَبِیہِ ، عَنْ عَلِیٍّ ، أَنَّہُ قَالَ : یَا بُنَیَّ۔",,,27091 27092,"حَدَّثَنَا إِسْحَاقُ بْنُ سُلَیْمَانَ الرَّازِیّ ، عَن نُعَیْمٍ قَالَ : سَأَلْتُ عَاصِمًا ، عَن قَوْلِ اللہِ : {فَنَادَاہَا مِنْ تَحْتِہَا} قَالَ : {مِنْ تَحْتَہَا} مَفْتُوحَۃً ، قُلْتُ : عَمَّنْ تَرْوِی ؟ قَالَ : عَن زِرٍّ یَا بُنَیَّ۔",,,27092 27093,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنِ الزِّبْرِقَانِ ، قَالَ : قَالَ لِی أَبُو وَائل یَا بُنَیَّ۔",,,27093 27094,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ قَالَ : قُلْتُ لابْنِ صَاحِبٍ لِی : یَا بُنَیَّ ، فَکَرِہَ ذَلِکَ إبْرَاہِیمُ۔",,,27094 27095,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِیہِ ، عَن مُحَارِبٍ ، عَنِ شُتَیر بن شَکَل أَنَ امْرَأَۃً قَالَتْ لَہُ : یَا بُنَیَّ ، فَقَالَ : وَلَدْتنِی ، قَالَتْ : لاَ ، قَالَ : فَأَرْضَعْتنِی ؟ قَالَتْ : لاَ ، قَالَ : فَلِمَ تَکْذِبِینَ ؟۔",,,27095 27096,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : حدَّثَنَا سُفْیَانُ بْنُ حُسَیْنٍ ، عَنِ الزُّہْرِیِّ ، عَن حُمَیْدِ بْنِ عَبْدِ الرَّحْمَنِ ، عَن أُمِّہِ قَالَتْ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: لَمْ یَکْذِبْ مَنْ قَالَ خَیْرًا، أَوْ نَمَی خَیْرًا، أَوْ أَصْلَحَ بَیْنَ اثْنَیْنِ۔ (بخاری 2692۔ مسلم 2011)",,,27096 27097,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللہِ الأَسَدِیُّ ، عَن سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ عُثْمَانَ بْنِ خُثَیْمٍ ، عَن شَہْرٍ ، عَنْ أَسْمَائِ بِنْتِ یَزِیدَ قَالَتْ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَصْلُحُ الْکَذِبُ إلاَّ فِی ثَلاَثٍ : کذب الرَّجُلِ امْرَأَتَہُ لِیُرْضِیَہَا ، أَوْ إصْلاَحٌ بَیْنَ النَّاسِ ، أَوْ کَذِبٌ فِی الْحَرْبِ۔ (ترمذی 1939۔ احمد 461)",,,27097 27098,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : أَخْبَرَنَا ہِشَامُ بْنُ حَسَّانَ ، عَن مُحَمَّدِ بْنِ وَاسِعٍ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ سَتَرَ أَخَاہُ الْمُسْلِمَ فِی الدُّنْیَا سَتَرَہُ اللَّہُ فِی الدُّنْیَا وَالآخِرَۃِ ، وَمَنْ نَفَّسَ عَنْ أَخِیہِ کُرْبَۃً مِنْ کُرَبِ الدُّنْیَا نَفَّسَ اللَّہُ عَنہُ کُرْبَۃً مِنْ کُرَبِ یَوْمِ الْقِیَامَۃِ ، وَاللَّہُ فِی عَوْنِ الْعَبْدِ مَا کَانَ الْعَبْدُ فِی عَوْنِ أَخِیہِ۔ (عبدالرزاق 18933۔ احمد 514)",,,27098 27099,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ نَفَّسَ عَن مُسْلِمٍ کُرْبَۃً مِنْ کُرَبِ الدُّنْیَا نَفَّسَ اللَّہُ عَنہُ کُرْبَۃً مِنْ کُرَبِ الآخِرَۃِ یَوْمَ الْقِیَامَۃِ، وَمَنْ سَتَرَ مُسْلِمًا سَتَرَہُ اللَّہُ فِی الدُّنْیَا وَالآخِرَۃِ ، وَمَنْ یَسَّرَ عَلَی مُعْسِرٍ یَسَّرَ اللَّہُ عَلَیْہِ فِی الدُّنْیَا وَالآخِرَۃِ ، وَاللَّہُ فِی عَوْنِ الْعَبْدِ مَا کَانَ الْعَبْدُ فِی عَوْنِ أَخِیہِ۔ (ابوداؤد 4854۔ حاکم 377)",,,27099 27100,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَن زَیْدِ بْنِ وَہْبٍ قَالَ أُتِیَ ابْنُ مَسْعُودٍ فَقِیلَ لَہُ : ہَذَا فُلاَنٌ تَقْطُرُ لِحْیَتُہُ خَمْرًا ، فَقَالَ عَبْدُ اللہِ : إنَّا قَدْ نُہِینَا عَنِ التَّجَسُّسِ ، وَلَکِنْ إِنْ یَظْہَرَ لَنَا مِنْہُ شَیْئٌ نَأْخُذْہُ بِہِ۔",,,27100 27101,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ، عَنْ أَبِی إدْرِیسَ قَالَ : لاَ یَہْتِکُ اللَّہُ سِتْرَ عَبْدٍ فِی قَلْبِہِ مِثْقَالُ ذَرَّۃٍ مِنْ خَیْرٍ۔",,,27101 27102,"حَدَّثَنَا عَفَّانُ قَالَ : حَدَّثَنَا ہَمَّامٌ ، قَالَ : سَمِعْتُ إِسْحَاقَ بْنَ عَبْدِ اللہِ بْنِ أَبِی طَلْحَۃَ قَالَ : حدَّثَنِی شَیْبَۃُ الْخُضْرِی ، أَنَّہُ شَہِدَ عُرْوَۃَ یُحَدِّثُ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ ، عَنْ عَائِشَۃَ رضی اللہ عنہا ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : لاَ یَسْتُرُ اللَّہُ عَلَی عَبْدٍ فِی الدُّنْیَا إلاَّ سَتَرَ اللہ عَلَیْہِ فِی الآخِرَۃِ۔ (مسلم 2002۔ احمد 145)",,,27102 27103,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، عَنْ عَبْدِ الْوَاحِدِ بْنِ قَیْسٍ ، عَنْ أَبِی ہُرَیْرَۃَ قَالَ : مَنْ أَطْفَأَ عَن مُؤْمِنٍ سیئۃ فَکَأَنَّمَا أَحْیَا مَوْؤُودَۃً ۔",,,27103 27104,"حَدَّثَنَا الْحَسَنُ بْنُ مُوسَی قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَن سَعِیدٍ الْجَرِیرِیِّ ، عَنْ أَبِی نَضْرَۃَ ، عَن أُسَیْرِ بْنِ جَابِرٍ ، أَنَّ أُوَیْسًا الْقَرَنِیَّ کَانَ إذَا حَدَّثَ وَقَعَ حَدِیثُہُ مِنْ قُلُوبِنَا مَوْقِعًا لاَ یَقَعُہُ حَدِیثُ غَیْرِہِ۔",,,27104 27105,"حَدَّثَنَا الْحَسَنُ بْنُ مُوسَی قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَن یسار بْنِ سَلاَمَۃَ ، عَن شَہْرِ بْنِ حَوْشَبٍ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّہُ قَالَ : إذَا حَدَّثَ الرَّجُلُ الْقَوْمَ فإن حدیثہ یَقَعُ مِنْ قُلُوبِہِمْ مَوْقِعَہُ مِنْ قَلْبِہِ۔",,,27105 27106,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ أَبِی غَفَّارٍ ، عَنْ أَبِی تَمِیمَۃَ الْہُجَیْمِیِّ ، عَنْ أَبِی جُرَیٍّ الْہُجَیْمِیِّ قَالَ : أَتَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : قُلْتُ : أَنْتَ رَسُولُ اللہِ ؟ قَالَ : نَعَمْ ، قَالَ : قُلْتُ : یَا رَسُولَ اللہِ ، اعْہَدْ إلَیَّ ، قَالَ : لاَ تَسُبَّ أَحَدًا ، قَالَ : فَمَا سَبَبْت أَحَدًا عَبْدًا ، وَلاَ حُرًّا ، وَلاَ شَاۃً ، وَلاَ بَعِیرًا۔",,,27106 27107,"حَدَّثَنَا غُنْدَرٌ ، عَن شُعْبَۃَ ، عَن سَعْدِ بْنِ إبْرَاہِیمَ ، عَن حُمَیْدِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ عبْدِ اللہِ بْنِ عَمْرٍو ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : إنَّ أَکْبَرَ الذَّنْبِ عِنْدَ اللہِ أَنْ یَسُبَّ الرَّجُلُ وَالِدَیْہِ ، قَالُوا : وَکَیْفَ یَسُبُّ الرَّجُلُ وَالِدَیْہِ ؟ قَالَ : یَسُبُّ أَبَا الرَّجُلِ فَیَسُبُّ أَبَاہُ ، وَیَسُبُّ أُمَّہُ فَیَسُبُّ أُمَّہُ۔\n\n(بخاری 5973۔ ابوداؤد 5098)",,,27107 27108,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ أَبِیہِ قَالَ : یَبْلُغُ بِہِ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : إنَّ من أَرْبَی الرِّبَا تَفَضُّلُ الرَّجُلِ فِی عَرْضِ أَخِیہِ بِالشَّتْمِ ، وَإِنَّ أَکْبَرَ الْکَبَائِرِ شَتْمُ الرَّجُلِ وَالِدَیْہِ ، قِیلَ : یَا رَسُولَ اللہِ ، وَکَیْفَ یَشْتُمُ وَالِدَیْہِ ؟ قَالَ : یَسُبُّ النَّاسَ فَیَسْتَسِبُّ النَّاسُ بِہِمَا۔ (طبرانی 899)",,,27108 27109,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ عَاصِمٍ قَالَ : مَا رَأَیْت أَبَا وَائِلٍ سَابَّ شَیْئًا قَطُّ إلاَّ أَنَّہُ ذَکَرَ الْحَجَّاجَ مَرَّۃً فَقَالَ : اللَّہُمَّ أَطْعِمْہُ طَعَامًا مِنْ ضَرِیعٍ لاَ یُسْمِنُ ، وَلاَ یُغْنِی مِنْ جُوعٍ ، ثُمَّ قَالَ : إِنْ کَانَ أَحَبَّ إلَیْک۔",,,27109 27110,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَن حَجَّاجٍ ، عَن فُضَیْلٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، عَنْ عَبْدِ اللہِ قَالَ : لاَ یَدْخُلُ الْجَنَّۃَ مَنْ کَانَ فِی قَلْبِہِ مِثْقَالُ حَبَّۃِ خَرْدَلٍ مِنْ کِبْرٍ۔",,,27110 27111,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنِ الأَغَرِّ أَبِی مُسْلِمٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : یَقُولُ اللَّہُ : الْعَظَمَۃُ إزَارِی ، وَالْکِبْرِیَائُ رِدَائِی ، فَمَنْ نَازَعَنی وَاحِدًا مِنْہُمَا أَلْقَیْتہ فِی النَّارِ۔",,,27111 27112,"حَدَّثَنَا عَفَّانُ قَالَ : حدَّثَنَا عَبْدُ الْعَزِیزِ بْنُ مُسْلِمٍ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، عَنْ عَبْدِ اللہِ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَدْخُلُ الْجَنَّۃَ أَحَدٌ فِی قَلْبِہِ مِثْقَالُ حَبَّۃِ خَرْدَلٍ مِنْ کِبْرٍ ، وَلاَ یَدْخُلُ النَّارَ أَحَدٌ فِی قَلْبِہِ مِثْقَالُ حَبَّۃِ خَرْدَلٍ مِنْ إیمَانٍ۔ (مسلم 93۔ ابوداؤد 4088)",,,27112 27113,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ أَبِی حَیَّانَ ، عَنْ أَبِیہِ قَالَ : الْتَقَی عَبْدُ اللہِ بْنُ عَمْرٍو ، وَابْنُ عُمَرَ فَانْتَجَیَا بَیْنَہُمَا ، ثُمَّ انْصَرَفَ کُلُّ وَاحِدٍ مِنْہُمَا إلَی أَصْحَابِہِ فَانْصَرَفَ ابْنُ عُمَرَ وَہُوَ یَبْکِی ، فَقَالُوا لَہُ : مَا یُبْکِیک ؟ قَالَ : أَبْکَانِی الَّذِی زَعَمَ ہَذَا ، أَنَّہُ سَمِعَہُ مِنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَدْخُلُ الْجَنَّۃَ أَحَدٌ فِی قَلْبِہِ مِثْقَالُ حَبَّۃِ خَرْدَلٍ مِنْ کِبْرٍ۔ (احمد 164)",,,27113 27114,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : یَجِیئُ الْمُتَکَبِّرُونَ یَوْمَ الْقِیَامَۃِ ذَرًّا مِثْلَ صُوَرِ الرِّجَالِ ، یَعْلُوہُمْ کُلُّ شَیْئٍ مِنَ الصَّغَارِ ، قَالَ : ثُمَّ یُسَاقُونَ إلَی سِجْنِ فی جَہَنَّمَ یُقَالُ لَہُ بُولَسَ ، تَعْلُوہُمْ نَارُ الأَنْیَارِ ، یُسْقَوْنَ مِنْ طِینَۃِ الْخَبَالِ ، عُصَارَۃِ أَہْلِ النَّارِ۔ (ترمذی 2492۔ احمد 179)",,,27114 27115,"ابْنُ إدْرِیسَ ، وَابْنُ عُیَیْنَۃَ ، وَأَبُو خَالِدٍ الأَحْمَرَِِ ، عَنِ ابْنِ عَجْلاَنَ ، عَن بُکَیْر بْنِ عَبْدِ اللہِ بْنِ الأَشَجِّ ، عَن مَعْمَرِ بْنِ أَبِی حُیَیَّۃَ ، عَنْ عَبْدِ اللہِ بْنِ عَدِیِّ بْنِ الْخِیَارِ قَالَ : قَالَ عُمَرُ : إنَّ الْعَبْدَ إذَا تَعَظَّمَ وَعَدَا طَوْرَہُ وَہَصَہُ اللَّہُ إلَی الأَرْضِ ، وَقَالَ : اخْسَأْ أَخْسَأَکَ اللَّہُ ، فَہُوَ فِی نَفْسِہِ کَبِیرٌ ، وَفِی أَنْفُسِ النَّاسِ صغیر حتی لہو أحقر عند الناس من خنزیر۔",,,27115 27116,"حَدَّثَنَا غُنْدَرٌ ، عَن شُعْبَۃَ ، عَن یَعْلَی بْنِ عَطَائٍ ، قَالَ : سَمِعْتُ نَافِعَ بْنَ عَاصِمٍ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو قَالَ : لاَ یَدْخُلُ حَظِیرَۃَ الْقُدْسِ مُتَکَبِّرٌ۔",,,27116 27117,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَن ہَمَّامِ بْنِ الْحَارِثِ ، عَن حُذَیْفَۃَ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَدْخُلُ الْجَنَّۃَ قَتَّاتٌ۔ (بخاری 6056۔ مسلم 169)",,,27117 27118,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَن وَاصِلٍ ، عَن شَقِیقٍ ، عَن حُذَیْفَۃَ قَالَ : کُنَّا نَتَحَدَّثُ : أنہ لاَ یَدْخُلُ الْجَنَّۃَ قَتَّاتٌ۔ (مسلم 101۔ احمد 168)",,,27118 27119,"حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ أَبِی إِسْحَاقَ ، عَنْ عَمْرِو بْنِ مَیْمُونٍ قَالَ : لَمَّا رَفَعَ اللَّہُ مُوسَی نَجِیًّا رَأَی رَجُلاً مُتَعَلِّقًا بِالْعَرْشِ فَقَالَ : یَا رَبِّ ، مَنْ ہَذَا ؟ فَقَالَ : عَبْدٌ مِنْ عِبَادِی صَالِحٌ ، إِنْ شِئْتَ أَخْبَرْتُک بِعَمَلِہِ ، قَالَ : یَا رَبِّ ، أَخْبِرْنِی ، قَالَ : کَانَ لاَ یَمْشِی بِالنَّمِیمَۃِ۔",,,27119 27120,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ إِبْرَاہِیمَ ، عَن عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ قَالَ : کَانَتْ لَنَا جَارِیَۃٌ أَعْجَمِیَّۃٌ ، فَمَرِضَتْ فَجَعَلَتْ تَقُولُ عِنْدَ الْمَوْتِ : ہَذَا فُلاَنٌ تَمَرَّغَ فِی الْحَمْأَۃِ ، فَلَمَّا أَنْ مَاتَتْ سَأَلْنَا عَنِ الرَّجُلِ ، قَالَ : فَقَالَ : مَا کَانَ بِہِ بَأْسٌ إلاَّ أَنَّہُ کَانَ یَمْشِی بِالنَّمِیمَۃِ۔",,,27120 27121,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَن یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَن مُجَاہِدٍ وَسَالِمِ بْنِ أَبِی الْجَعْدَ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَدْخُلُ الْجَنَّۃَ مَنَّانٌ۔",,,27121 27122,"حَدَّثَنَا غُنْدَرٌ ، عَن شُعْبَۃَ ، عَن یَعْلَی بْنِ عَطَائٍ ، قَالَ : سَمِعْتُ نَافِعَ بْنَ عَاصِمٍ یُحَدِّثُ عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو قَالَ : لاَ یَدْخُلُ حَظِیرَۃَ الْقُدْسِ مَنَّانٌ۔",,,27122 27123,"حَدَّثَنَا غُنْدَرٌ ، عَن شُعْبَۃَ ، عَنْ عَلِیِّ بْنِ مُدْرِکٍ ، عَنْ أَبِی زُرْعَۃَ ، عَن خَرَشَۃَ بْنِ الْحُرِّ ، عَنْ أَبِی ذَرٍّ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : ثَلاَثَۃٌ لاَ یُکَلِّمُہُمُ اللَّہُ یَوْمَ الْقِیَامَۃِ ، وَلاَ یَنْظُرُ إلَیْہِمْ ، وَلاَ یُزَکِّیہِمْ وَلَہُمْ عَذَابٌ أَلِیمٌ ، قَالَ : فَقَرَأَہَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ثَلاَثَ مَرَّاتٍ ، فَقَالَ أَبُو ذَرٍّ : خَابُوا وَخَسِرُوا ، مَنْ ہُمْ یَا رَسُولَ اللہِ ؟ قَالَ : الْمُسْبِلُ وَالْمَنَّانُ وَالْمُنْفِقُ سِلْعَتَہُ بِالْحَلِفِ الْکَاذِبِ۔\n\n(مسلم 171۔ ابوداؤد 4085۔ احمد 148)",,,27123 27124,"حَدَّثَنَا غُنْدَرٌ ، عَن شُعْبَۃَ ، عَن مَنْصُورٍ ، عَن سَالِمِ بْنِ أَبِی الْجَعْدِ ، عَن نُبَیْطِ بْنِ شَرِیطٍ ، عَنْ جَابَانَ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَدْخُلُ الْجَنَّۃَ مَنَّانٌ۔",,,27124 27125,"حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَمْرِو بْنِ مَیْمُونٍ قَالَ : لَمَّا رَفَعَ اللَّہُ مُوسَی نَجِیًّا رَأَی رَجُلاً مُتَعَلِّقًا بِالْعَرْشِ فَقَالَ : یَا رَبِّ ، مَنْ ہَذَا ؟ قَالَ : عَبْدٌ مِنْ عِبَادِی صَالِحٌ ، إِنْ شِئْتَ أَخْبَرْتُک بِعَمَلِہِ، قَالَ : یَا رَبِّ ، أَخْبِرْنِی ، قَالَ : کَانَ لاَ یَحْسُدُ النَّاسَ مَا آتَاہُمُ اللَّہُ مِنْ فَضْلِہِ۔",,,27125 27126,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَن یَزِیدَ الرَّقَاشِیِّ ، عَنْ أَنَسٍ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ الْحَسَدَ لَیَأْکُلُ الْحَسَنَاتِ کَمَا تَأْکُلُ النَّارُ الْحَطَبَ۔ (ابن ماجہ 4210۔ ابویعلی 3644)",,,27126 27127,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَن یَزِیدَ الرَّقَاشِیِّ ، عَنِ الْحَسَنِ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : کَادَ الْحَسَدُ أَنْ یَغْلِبَ الْقَدَرَ ، وَکَادَتِ الْفَاقَۃُ أَنْ تَکُونَ کُفْرًا۔",,,27127 27128,"حَدَّثَنَا غُنْدَرٌ ، عَن شُعْبَۃَ ، عَنْ أَبِی رَجَائٍ ، عَنِ الْحَسَنِ ، {وَلاَ یَجِدُونَ فِی صُدُورِہِمْ حَاجَۃً مِمَّا أُوتُوا} قَالَ : الْحَسَدُ۔",,,27128 27129,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَن مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ فِی قَوْلِہِ تَعَالَی : {وَالَّذِینَ إذَا أَنْفَقُوا لَمْ یُسْرِفُوا وَلَمْ یَقْتُرُوا وَکَانَ بَیْنَ ذَلِکَ قَوَامًا} قَالَ: لاَ یُجِیعُہُمْ، وَلاَ یُعَرِّیہِمْ، وَلاَ یُنْفِقُ نَفَقَۃً یَقُولُ النَّاسُ: إِنَّہ أَسْرَفَ فِیہَا۔",,,27129 27130,"حَدَّثَنَا وَکِیعٌ ، عَن سُفْیَانَ ، عَنْ عَمْرِو بْنِ قَیْسٍ ، عَنِ الْمِنْہَالِ ، عَن سَعِیدِ بْنِ جُبَیْرٍ : {وَمَا أَنْفَقْتُمْ مِنْ شَیْئٍ فَہُوَ یُخْلِفُہُ وَہُوَ خَیْرُ الرَّازِقِینَ} قَالَ : فِی غَیْرِ إسْرَافٍ ، وَلاَ تَقْتِیرٍ۔",,,27130 27131,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ الأَعْمَشِ ، عَنِ الْحَکَمِ ، عَن یَحْیَی بْنِ الْجَزَّارِ ، عَنْ أَبِی الْعُبَیْدَیْنِ ، أَنَّہُ سَأَلَ ابْنَ مَسْعُودٍ عَنِ التَّبْذِیرِ فَقَالَ : إنْفَاقُ الْمَالِ فِی غَیْرِ حَقِّہِ۔",,,27131 27132,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَن حَمَّادِ بْنِ سَلَمَۃَ ، عَن دَاوُد قَالَ : قُلْتُ لِلْحَسَنِ : أَشْتَرِی لامْرَأَتِی فِی السَّنَۃِ طِیبًا بِعِشْرِینَ دِرْہَمًا أَسَرَفٌ ہَذَا ؟ قَالَ : لَیْسَ ہَذَا بِسَرَفٍ۔",,,27132 27133,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ إبْرَاہِیمَ بْنَ مَیْسَرَۃَ ، عَن طَاوُوس ، عَنِ ابْنِ عَبَّاسٍ قَالَ : الْبَسْ مَا شِئْت وَکُلْ مَا شِئْت مَا أَخْطَأَتْک خِلَّتَانِ : سَرَفٌ ، أَوْ مَخِیلَۃٌ۔",,,27133 27134,"حَدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَن مُحَمَّدِ بْنِ سُوقَۃَ ، عَن سَعِیدِ بْنِ جُبَیْرٍ قَالَ : سَأَلَہُ رَجُلٌ ، عَنْ إضَاعَۃِ الْمَالِ ، قَالَ : أَنْ یَرْزُقَک اللَّہُ رِزْقًا فَتُنْفِقُہُ فِیمَا حَرَّمَ عَلَیْک۔",,,27134 27135,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ الْعَوَّامِ قَالَ : قَالَ کَعْبٌ : أَنْفِقُوا لِخَلْفٍ یَأْتِیکُمْ۔",,,27135 27136,"حَدَّثَنَا عَفَّانُ ، عَن سُکَیْنِ بْنِ عَبْدِ الْعَزِیزِ ، عَنِ الْہَجَرِیِّ ، عَنْ أَبِی الأَحْوَصِ ، عَنْ عَبْدِ اللہِ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَا عَالَ مَنِ اقْتَصَدَ۔ (احمد 447۔ طبرانی 10118)",,,27136 27137,"حَدَّثَنَا وَکِیعٌ ، عَن یُوسُفَ ، عَنْ أَبِی السَّرِیَّۃِ بن الْحَسَنِ قَالَ : لَیْسَ فِی الطَّعَامِ إسْرَافٌ۔",,,27137 27138,"حَدَّثَنَا جَعْفَرُ بْنُ عَوْنٍ ، عَنْ أَبِی الْعُمَیْسِ ، عَن زِیَادٍ مَوْلَی مُصْعَبٍ ، عَنِ الْحَسَنِ ، أَنَّ أَصْحَابَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سَأَلُوہُ : مَا نَفَقَتنَا عَلَی أَہْلِینَا ؟ فَقَالَ : مَا أَنْفَقْتُمْ عَلَی أَہْلِیکُمْ فِی غَیْرِ إسْرَافٍ ، وَلاَ تَقْتِیرٍ ، فَہُوَ فِی سَبِیلِ اللہِ۔ (بیہقی 6554)",,,27138 27139,"حَدَّثَنَا غُنْدَرٌ ، عَن شُعْبَۃَ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ عَبْدِ اللہِ بْنِ الْحَارِثِ ، عَنْ أَبِی کَثِیرٍ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : إیَّاکُمْ وَالشُّحَّ فَإِنَّہُ أَہْلَکَ مَنْ قَبْلَکُمْ أَمَرَہُمْ بِالْقَطِیعَۃِ فَقَطَعُوا ، وَبِالْبُخْلِ فَبَخِلُوا ، وَبِالْفُجُورِ فَفَجَرُوا۔ (ابوداؤد 1695۔ احمد 191)",,,27139 27140,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَن مُحَمَّدِ بْنِ عَمْرٍو ، عَن صَفْوَانَ بْنِ سُلَیْمٍ ، عَن حُصَیْنِ بْنِ اللَّجْلاَجِ ، عَنْ أَبِی ہُرَیْرَۃَ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَجْتَمِعُ الشُّحُّ وَالإِیمَانُ فِی جَوْفِ رَجُلِ مُسْلِمٍ۔",,,27140 27141,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَن مُوسَی بْنِ عُلَیٍّ ، عَنْ أَبِیہِ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ مَرْوَانَ ، عَنْ أَبِی ہُرَیْرَۃَ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : شَرُّ مَا فِی الرَّجُلِ شُحٌّ ہَالِعٌ وَجُبْنٌ خَالِعٌ۔\n\n(ابوداؤد 2503۔ احمد 302)",,,27141 27142,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَن مُحَمَّدِ بْنِ الْمُنْکَدِرِ ، عَنْ جَابِرٍ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَوْ قَدْ جَائَ مَالُ الْبَحْرَیْنِ لَقَدْ أَعْطَیْتُک کَذَا وَکَذَا فَأَتَیْت أَبَا بَکْرٍ فَقُلْت : تَبْخَلُ عَنی ، قَالَ : وَأَیُّ دَائٍ أَدْوَأُ مِنَ الْبُخْلِ ؟ مَا سَأَلْتِی مِنْ مَرَّۃٍ إلاَّ وَأَنَا أُرِیدُ أَنْ أُعْطِیَک۔ (بخاری 2598۔ مسلم 1806)",,,27142 27143,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ جَامِعِ بْنِ شَدَّادٍ ، عَنِ الأَسْوَدِ بْنِ ہِلاَلٍ قَالَ : جَائَ رَجُلٌ إلَی عَبْدِ اللہِ فَقَالَ : خَشِیَتْ أَنْ تُصِیبَنِی ہَذِہِ الآیَۃُ {وَمَنْ یُوقَ شُحَّ نَفْسِہِ} الآیَۃَ ، مَا أَسْتَطِیعُ أَنْ أُعْطِیَ شَیْئًا أُطِیقُ مَنْعَہُ ، قَالَ عَبْدُ اللہِ : ذَاکَ الْبُخْلُ ، وَبِئْسَ الشَّیْئُ الْبُخْلُ۔",,,27143 27144,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَن کَہْمَسٍ ، عَنْ أَبِی الْعَلاَئِ ، عَنِ ابْنِ الأَحْمَسِ قَالَ : قلْت لأَبِی ذَرٍّ : حَدِیثٌ بَلَغَنِی عَنک تُحَدِّثُہ عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ ، قَالَ : سَمِعْتُہُ مِنْہُ وَقُلْتہ ، فَذَکَرَ ثَلاَثَۃً یَشْنَؤُہُمُ اللَّہُ : الْبَخِیلُ وَالْمَنَّانُ وَالْمُخْتَالُ۔",,,27144 27145,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمِ ، عَنْ أَبِی عُثْمَانَ ، وَعَبْدِ اللہِ بْنِ الْحَارِثِ ، عَن زَیْدِ بْنِ أَرْقَمَ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَقُولُ : اللَّہُمَّ إنِّی أَعُوذُ بِکَ مِنَ الْبُخْلِ۔",,,27145 27146,حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَمْرِو بْنِ مَیْمُونٍ ، عَن عُمَرَ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَتَعَوَّذُ مِنَ الْبُخْلِ۔,,,27146 27147,"حَدَّثَنَا شَبَابَۃُ قَالَ : حدَّثَنَا یُونُسُ بْنُ أَبِی إِسْحَاقَ ، عَنْ عَمْرِو بْنِ مَیْمُونٍ ، عَن عُمَرَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، مِثْلَہُ۔",,,27147 27148,حَدَّثَنَا وَکِیعٌ، عَن ہِشَامَ، عَن قَتَادَۃَ ، عَنْ أَنَسٍ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَتَعَوَّذُ مِنَ الْبُخْلِ۔,,,27148 27149,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عن حجاج ، عَن سُلَیْمَانَ بْنِ سُحَیْمٍ ، عَن طَلْحَۃَ بْنِ عُبَیْدِ اللہِ بْنِ کَرِیزٍ قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: إنَّ اللَّہَ جَوَادٌ یُحِبُّ الْجُود، وَیُحِبُّ مَعَالِیَ الأَخْلاَقِ وَیَکْرَہُ سَفْسَافَہَا۔\n\n(عبدالرزاق 20150۔ حاکم 628)",,,27149 27150,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، عَن یَحْیَی بْنِ أَبِی کَثِیرٍ قَالَ : کَانَ لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ من سَعْدِ بْنِ عُبَادَۃَ جَفْنَۃٌ تَدُورُ مَعَہُ حَیْثُمَا دَارَ مِنْ نِسَائِہِ ، وَکَانَ یَقُولُ فِی دُعَائِہِ : اللَّہُمَّ ارْزُقْنِی مَالاً فَإِنَّہُ لاَ یُصْلِحُ الْفِعَالَ إلاَّ الْمَالُ۔",,,27150 27151,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَن ہِشَامٍ ، عَنْ أَبِیہِ ، أَنَّ سَعْدَ بْنَ عُبَادَۃَ کَانَ یَدْعُو اللَّہُمَّ ہَبْ لِی حَمْدًا وَہَبْ لِی مَجْدًا ، ولاَ مَجْدَ إلاَّ بِفِعَالٍ ، وَلاَ فِعَالَ إلاَّ بِمَالٍ ، اللَّہُمَّ لاَ یُصْلِحُنِی الْقَلِیلُ ، وَلاَ أَصْلُحُ عَلَیْہِ۔\n\n(ابن سعد 614۔ حاکم 253)",,,27151 27152,"حَدَّثَنَا أَبُو أُسَامَۃَ قَالَ : حدَّثَنَا ہِشَامٌ ، عَنْ أَبِیہِ قَالَ : أَدْرَکْت سَعْدَ بْنَ عُبَادَۃَ وَہُوَ یُنَادِی عَلَی أُطُمِہِ : مَنْ أَحَبَّ شَحْمًا ، ولَحْمًا فَلْیَأْتِ سَعْدَ بْنَ عُبَادَۃَ ، ثُمَّ أَدْرَکْت ابْنَہُ بَعْدَ ذَلِکَ یَدْعُو بِہِ ، وَلَقَدْ کُنْت أَمْشِی فِی طَرِیقِ الْمَدِینَۃِ وَأَنَا شَابٌّ فَمَرَّ عَلَیَّ عَبْدُ اللہِ بْنُ عُمَرَ مُنْطَلِقًا إلَی أَرْضِہِ بالغابۃ ، فَقَالَ : یَا فَتَی ، انْظُرْ ہَلْ تَرَی عَلَی أُطُمِ سَعْدِ بْنِ عُبَادَۃَ أَحَدًا یُنَادِی ، فَنَظَرْت فَقُلْت : لاَ ، فَقَالَ : صَدَقْت۔",,,27152 27153,"حَدَّثَنَا أَبُو أُسَامَۃَ قَالَ : حدَّثَنَا ہِشَامٌ ، عَنْ أَبِیہِ قَالَ : کَانَ قَیْسُ بْنُ سَعْدِ بْنِ عُبَادَۃَ ارْتَحَلَ نَحْوَ الْمَدِینَۃِ وَمَعَہُ أَصْحَابٌ ، فَجَعَلَ یَنْحَرُ کُلَّ یَوْمٍ جَزُورًا حَتَّی بَلَغَ صِرَارَ۔",,,27153 27154,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، عَنِ ابْنِ سِیرِینَ قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا أَمْسَی قَسَمَ نَاسًا مِنْ أَہْلِ الصُّفَّۃِ بَیْنَ أُنَاسٍ مِنْ أَصْحَابِہِ ، فَکَانَ الرَّجُلُ یَذْہَبُ بِالرَّجُلِ ، وَالرَّجُلُ بِالرَّجُلَیْنِ ، وَالرَّجُلُ بِالثَّلاَثَۃِ حَتَّی ذَکَرَ عَشَرَۃً ، قَالَ : وَکَانَ سَعْدُ بْنُ عُبَادَۃَ یَرْجِعُ إلَی أَہْلِہِ کل لیلۃ بِثَمَانِینَ منہم یُعَشِّیہِمْ۔",,,27154 27155,"حَدَّثَنَا یَعْلَی ، عَن مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنِ الزُّہْرِیِّ ، عَن عُبَیْدِ اللہِ بْنِ عَبْدِ اللہِ ، عَنِ ابْنِ عَبَّاسٍ قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَجْوَدَ مِنَ الرِّیحِ الْمُرْسَلَۃِ۔ (بخار ی3220۔ احمد 230)",,,27155 27156,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ قَالَ : حدَّثَنَا إبْرَاہِیمُ بْنُ سَعْدٍ ، عَنِ الزُّہْرِیِّ ، عَن عُبَیْدِ اللہِ ، عَنِ ابْنِ عَبَّاسٍ قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَجْوَدَ النَّاسِ بِالْخَیْرِ ، وَکَانَ أَجْوَدَ مَا یَکُونُ حِینَ یَلْقَاہُ جِبْرِیلُ۔\n\n(بخاری 1902۔ مسلم 1803)",,,27156 27157,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی، عَن سَلَمَۃَ بْنِ أَبِی یَحْیَی الأَنْصَارِیِّ قَالَ: رَأَیْتُ أَنَسَ بْنَ مَالِکٍ یَجْلِسُ إلَی سَارِیَۃٍ۔",,,27157 27158,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنِ الْمُخْتَارِ بْنِ سَعْدٍ قَالَ : رَأَیْتُ الْقَاسِمَ بْنَ مُحَمَّدٍ یَجْلِسُ إلَی سَارِیَۃٍ۔",,,27158 27159,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَن ثَابِتِ بْنِ قَیْسٍ قَالَ : رَأَیْتُ نَافِعَ بْنَ جُبَیْرٍ یَجْلِسُ إلَی سَارِیَۃٍ۔",,,27159 27160,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَن خَالِدِ بْنِ أَبِی بَکْرٍ قَالَ : رَأَیْتُ عُبَیْدَ اللہِ بْنَ عَبْدِ اللہِ یَجْلِسُ إلَی سَارِیَۃٍ۔",,,27160 27161,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ الأَعْمَشِ قَالَ : کَانَ إبْرَاہِیمُ لاَ یَجْلِسُ إلَی أُسْطُوَانَۃٍ۔",,,27161 27162,"حَدَّثَنَا مَعَن ، عَن خَالِدِ بْنِ أَبِی بَکْرٍ قَالَ : لَمْ أَرَ سَالِمَ بْنَ عَبْدِ اللہِ یَجْلِسُ إلَی سَارِیَۃٍ۔",,,27162 27163,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ عَاصِمٍ ، عَنِ ابْنِ سِیرِینَ قَالَ : نَزَلَ عَلَیْنَا أَبُو قَتَادَۃَ الأَنْصَارِیُّ ، فَانْقَضَّ کَوْکَبٌ ، فَأَتْبَعْناہُ أَبْصَارَنَا ، فَنَہَانَا عَن ذَلِکَ۔ (احمد 299۔ حاکم 286)",,,27163 27164,حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ یُتْبَعَ الرَّجُلُ بَصَرَہُ الْکَوْکَبَ إذَا رمی بِہِ۔,,,27164 27165,حَدَّثَنَا قَبِیصَۃُ ، عَن سُفْیَانَ ، عَن ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ، عَنْ عَبْدِ اللہِ بْنِ الْحَارِثِ ، عَنْ أَبِی قَتَادَۃَ مِثْلُ حَدِیثِ عَبْدِ الرَّحِیمِ ، عَنْ عَاصِمٍ۔,,,27165 27166,"حَدَّثَنَا ہَاشِمُ بْنُ الْقَاسِمِ ، قَالَ : حدَّثَنَا أَبُو عَقِیلٍ قَالَ : حَدَّثَنَا عَمْرُو بْنُ خَالِدٍ الْقُرَشِیُّ ، قَالَ : سَمِعْتُ زَیْدَ بْنَ عَلِیٍّ یُحَدِّثُ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، عَنْ عَلِیٍّ ، أَنَّہُ کَانَ إذَا رَأَی الْکَوْکَبَ مُنْقَضًّا قَالَ : اللَّہُمَّ صَوِّبْہُ وَأَصِبْ بِہِ ، وَقِنَا شَرَّ مَا یَتْبَعُ۔",,,27166 27167,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : حدَّثَنَا شُعْبَۃُ ، عَن خَالِدٍ الْحَذَّائِ ، عَن غَیْلاَنَ بْنِ جَرِیرٍ ، عَن مُطَرِّفٍ قَالَ : لاَ یَکْذِبَن أَحَدُکُمْ مَرَّتَیْنِ ، یَقُولُ لِلشَیْئٍ : لاَ شَیْئَ ، لَیْسَ بِشَیْئٍ۔",,,27167 27168,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ قَالَ : أَخْبَرَنَا ابْنُ عَوْنٍ ، عَن مُحَمَّدٍ قَالَ : کَانَ یَقُولُ : إنَّ ہَذَا الْعِلْمَ دِینٌ فَانْظُرُوا عَمَّنْ تَأْخُذُونَہُ۔ (دارمی 419)",,,27168 27169,"حَدَّثَنَا جَرِیرٌ ، عَن مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : کَانَ یَکْرَہ أَنْ یَقُولُ : لَیْسَ فِی الْبَیْتِ أَحَدٌ ، وَلاَ بَأْسَ أَنْ یَقُولَ : لَیْسَ فِی الْبَیْتِ أَحَدٌ مِنَ النَّاسِ۔",,,27169 27170,"حَدَّثَنَا عَفَّانُ قَالَ : حدَّثَنَا حَمَّادُ بْنُ زَیْدٍ قَالَ : أَیُّوبُ قَالَ : حَدَّثَنَا سَعِیدُ بْنُ جُبَیْرٍ ذَاتَ یَوْمٍ حَدِیثًا فَقُمْت إلَیْہِ فَقُلْت : أَعِدْہُ ، فَقَالَ : إِنِّی مَا کُلُّ سَاعَۃٍ أَحْلِبُ فَأَشْرَبُ۔",,,27170 27171,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ عَبْدِ الْجَبَّارِ ، قَالَ : سَمِعْتُ ابْنَ شِہَابٍ یَقُولُ : تَرْدَادُ الْحَدِیثِ أَشَدُّ مِنْ نَقْلِ الْحِجَارَۃِ۔",,,27171 27172,"حَدَّثَنَا یَعْلَی قَالَ: حدَّثَنَا أَبُو حَیَّانَ، عَنْ عَبَایَۃَ قَالَ: وَضَّأْت ابْنَ عُمَرَ فَقُمْت، عَن یَمِینِہِ أُفْرِغُ عَلَیْہِ الْمَائَ، فَلَمَّا فَرَغَ صَعَّدَ فِیَّ بَصَرَہُ فَقَالَ: مِنْ أَیْنَ أَخَذَتْ ہَذَا الأَدَبَ؟ فَقُلْت: مِنْ جَدِّی رَافِعٍ، قَالَ: قَالَ: ہنیئا لک۔",,,27172 27173,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَن حَمَّادِ بْنِ زَیْدٍ ، عَن لَیْثٍ ، عَن مُجَاہِدٍ قَالَ : إذَا لَقِیْتَ أَخَاک فَلاَ تَسْأَلْہُ مِنْ أَیْنَ جِئْت ؟ وَلاَ أَیْنَ تَذْہَبُ ؟ وَلاَ تَحُدُّ النَّظَرَ إلَی أَخِیک۔",,,27173 27174,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَن حَجَّاجِ الصَّوَافِّ قَالَ : حدَّثَنَی یَحْیَی بْنُ أَبِی کَثِیرٍ قَالَ : بَلَغَنِی ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَقُولُ : إذَا مَرَّ أَحَدُکُمْ بِہَدَفٍ مَائِلٍ ، أَوْ صَدَفٍ ہَائِلٍ فَلْیُسْرِعِ الْمَشْیَ وَلْیَسْأَلِ اللَّہَ الْمُعَافَاۃَ۔",,,27174 27175,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَن عِمْرَانَ الْقَصِیرِ قَالَ : أَخْبَرَنِی سَعِیدُ بْنُ سُلَیْمَانَ ، عَن یَزِیدَ بْنِ نَعَامَۃَ الضَّبِّیِّ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا آخَی الرَّجُلُ الرَّجُلَ فَلْیَسْأَلْہُ ، عَنِ اسْمِہِ وَاسْمِ أَبِیہِ وَمِمَّنْ ہُوَ ، فَإِنَّہُ أَوْصَلُ لِلْمَوَدَّۃِ۔ (ابو نعیم 181)",,,27175 27176,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَن مُجَاہِدٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَأَی رَجُلاً فَسَأَلَ عَنہُ ، فَقَالَ رَجُلٌ : أَنَا أَعْرِفُ وَجْہَہُ ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَیْسَ تِلْکَ بِمَعْرِفَۃٍ۔",,,27176 27177,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، وَیَزِیدُ ، عَنْ مِسْعَرٍ ، عَنْ عُبَیْدِ بْنِ الْحَسَنِ ، عَنِ ابْنِ مَعْقِلٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : نَفَقَۃُ الرَّجُلِ عَلَی أَہْلِہِ صَدَقَۃٌ۔",,,27177 27178,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنِ الشَّعْبِیِّ قَالَ : إنَّ مِنَ النَّفَقَۃِ الَّتِی تُضَاعَفُ بِسَبْعِمِئَۃِ ضِعْفِ نَفَقَۃِ الرَّجُلِ عَلَی نَفْسِہِ وَأَہْلِ بَیْتِہِ۔",,,27178 27179,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : أَخْبَرَنَا شُعْبَۃُ ، عَنْ عَدِیِّ بْنِ ثَابِتٍ ، عَنْ عَبْدِ اللہِ بْنِ یَزِیدَ ، عَنْ أَبِی مَسْعُودٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : نَفَقَۃُ الرَّجُلِ عَلَی أَہْلِہِ صَدَقَۃٌ۔ (بخاری 55۔ مسلم 695)",,,27179 27180,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : أَخْبَرَنَا جَرِیرُ بْنُ حَازِمٍ قَالَ : حَدَّثَنَا بَشَّارُ بْنُ أَبِی سَیْفٍ ، عَنِ الْوَلِیدِ بْنِ عَبْدِ الرَّحْمَنِ ، عَن عِیَاضِ بْنِ غُطَیْفٍ قَالَ : دَخَلْنَا عَلَی أَبِی عُبَیْدَۃَ بْنِ الْجَرَّاحِ فَقَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : مَنْ أَنْفَقَ عَلَی أَہْلِہِ ، أَوْ مَازَ أَذًی عَن طَرِیقٍ فَہی حَسَنَۃٌ بِعَشْرِ أَمْثَالِہَا۔",,,27180 27181,"حَدَّثَنَا ابْنُ نُمَیْرٍ قَالَ : حدَّثَنَا ہِشَامُ بْنُ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ أَبِی مُرَاوِحَ ، عَنْ أَبِی ذَرٍّ قَالَ : قُلْتُ : یَا رَسُولَ اللہِ ، أَیُّ الأَعْمَالِ أَفْضَلُ ؟ قَالَ : إیمَانٌ بِاللَّہِ وَجِہَادٌ فِی سَبِیلِہِ ، قَالَ : قُلْتُ : أَیُّ الرِّقَابِ أَفْضَلُ ؟ قَالَ : أَنْفَسُہَا عِنْدَ أَہْلِہَا وَأَغْلاَہَا ، ثَمَنًا ، قُلْتُ : فَإِنْ لَمْ أَطِقْ ذَلِکَ ؟ قَالَ : تُعِینُ صَانِعًا ، أَوْ تَصْنَعُ لأَخْرَقَ ، قَالَ : فَإِنْ لَمْ أَسْتَطِعْ ؟ قَالَ : فَدَعِ النَّاسَ مِنَ الشَّرِّ ، فَإِنَّہَا صَدَقَۃٌ تَصَدَّقُ بِہَا عَلَی نَفْسِک۔",,,27181 27182,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَن شُعْبَۃَ ، عَن سَعِیدِ بْنِ أَبِی بُرْدَۃَ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : عَلَی کُلِّ مُسْلِمٍ صَدَقَۃٌ ، قَالَ : قِیلَ أَرَأَیْت إِنْ لَمْ یَجِدْ ؟ قَالَ : یَعْمَلُ بِیَدَیْہِ فَیَنْفَعُ نَفْسَہُ وَیَتَصَدَّقُ ، قَالَ : أَرَأَیْت إِنْ لَمْ یَسْتَطِعْ ؟ قَالَ : یُعِینُ ذَا الْحَاجَۃِ الْمَلْہُوفَ ، قَالَ : أَرَأَیْت إِنْ لَمْ یَسْتَطِعْ ؟ قَالَ: یَأْمُرُ بِالْمَعْرُوفِ أو الخیر ، قَالَ : أَرَأَیْت إِنْ لَمْ یَفْعَلْ ؟ قَالَ : یُمْسِکُ عَنِ الشَّرِّ فَإِنَّہَا صَدَقَۃٌ۔\n\n(بخاری 1445۔ مسلم 699)",,,27182 27183,"حَدَّثَنَا أَبُو أُسَامَۃَ قَالَ : حدَّثَنَا سُفْیَانُ ، عَن دِینَارٍ التَّمَّارِ ، عَنْ عَوْنِ بْنِ عَبْدِ اللہِ قَالَ : کَانَ عَبْدُ اللہِ یَمْشِی مَعَ نَاسٍ مِن أَصْحَابِہِ ذَاتَ یَوْمٍ فَانْقَطَعَ شِسْعُ نَعْلِہِ فَاسْتَرْجَعَ ، فَقَالَ لَہُ بَعْضُ الْقَوْمِ : یَا أَبَا عَبْدِ الرَّحْمَنِ ، تَسْتَرْجِعُ عَلَی سَیْرٍ ؟ قَالَ : مَا بِی أن لاَ تَکُونَ السُّیُورُ کَثِیرًا وَلَکِنَّہَا مُصِیبَۃٌ۔",,,27183 27184,"حَدَّثَنَا وَکِیعٌ ، عَن سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ اللہِ بْنِ خَلِیفَۃَ ، عَن عُمَرَ بْنِ الْخَطَّابِ ، أَنَّہُ انْقَطَعَ شِسْعُہُ فَاسْتَرْجَعَ ، وَقَالَ : کُلُّ مَا سَائَک ، فَہُوَ مُصِیبَۃٌ۔",,,27184 27185,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی قَالَ : أَخْبَرَنَا شَیْبَانُ ، عَن مَنْصُورٍ ، عَن مُجَاہِدٍ ، عَن سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : انْقَطَعَ قُبَالُ نَعْلِ عُمَرَ فَقَالَ : إنَّا لِلَّہِ وَإِنَّا إلَیْہِ رَاجِعُونَ ، فَقَالُوا : یَا أَمِیرَ الْمُؤْمِنِینَ ، أَفِی قُبَالِ نَعْلِکَ ؟ قَالَ : نَعَمْ ، کُلُّ شَیْئٍ أَصَابَ الْمُؤْمِنَ یَکْرَہُہُ ، فَہُوَ مُصِیبَۃٌ۔",,,27185 27186,"حَدَّثَنَا حُسَیْنُ بْنُ مُحَمَّدٍ قَالَ : حدَّثَنَا جَرِیرُ بْنُ حَازِمٍ ، عَنْ عَائِشَۃَ رضی اللہ عنہا قَالَتْ : قُولُوا : خَاتَمُ النَّبِیِّینَ ، وَلاَ تَقُولُوا : لاَ نَبِیَّ بَعْدَہُ۔",,,27186 27187,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَن مُجَالِدٍ قَالَ : أَخْبَرَنَا عَامِرٌ قَالَ : قَالَ رَجُلٌ عِنْدَ الْمُغِیرَۃِ بْنِ شُعْبَۃَ : صَلَّی اللَّہُ عَلَی مُحَمَّدٍ خَاتَمِ الأَنْبِیَائِ ، لاَ نَبِیَّ بَعْدَہُ ، قَالَ الْمُغِیرَۃُ : حَسْبُک إذَا قُلْتَ : خَاتَمُ الأَنْبِیَائِ ، فَإِنَّا کُنَّا نُحَدِّثُ، أَنَّ عِیسَی خَارِجٌ ، فَإِنْ ہُوَ خَرَجَ ، فَقَدْ کَانَ قَبْلَہُ وَبَعْدَہُ۔",,,27187 27188,"حَدَّثَنَا وَکِیعٌ، عَن یُونُسَ، عَنِ الزُّہْرِیِّ قَالَ: نَہَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، عَن قَتْلِ النَّمْلِ وَالنَّحْلِ۔\n\n(ابوداؤد 5225۔ احمد 332)",,,27188 27189,"حَدَّثَنَا وَکِیعٌ ، عَن حَمَّادٍ ، عَنْ إبْرَاہِیمَ قَالَ : إذَا آذَاک النَّمْلَ فَاقْتُلْہُ۔",,,27189 27190,"حَدَّثَنَا وَکِیعٌ ، عَن خَالِدِ بْنِ دِینَارٍ قَالَ : رَأَیْتُ أَبَا الْعَالِیَۃِ رَأَی نَمْلاً عَلَی بِسَاطٍ فَقَتَلَہُنَّ۔",,,27190 27191,"حَدَّثَنَا وَکِیعٌ ، عَنْ إبْرَاہِیمَ بْنِ نَافِعٍ ، عَن سُلَیْمَانَ الأَحْوَلِ ، عَن طَاوُوس قَالَ : إنَّا لَنُفرِّقَ النَّمْلَ بِالْمَائِ یَعْنِی إذَا آذَتْنَا۔",,,27191 27192,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَن ہِشَامِ بْنِ عُرْوَۃَ قَالَ : قَالَ لِی أَبِی : کَتَبْت ؟ قَالَ : قُلْتُ : نَعَمْ ، قَالَ : عَارَضْت ؟ قُلْتُ : لاَ ، قَالَ : لَمْ تَکْتُبْ۔ (رامھرمزی 718)",,,27192 27193,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ، عَن سَوَّارَ بْنِ عَبْدِ اللہِ قَالَ: کَانَ مُحَمَّدٌ یَکْرَہُ أَنْ یَرْفَعَ قَصَّۃً لاَ یَعْلَمُ مَا فِیہَا۔",,,27193 27194,"حَدَّثَنَا غُنْدَرٌ ، عَن شُعْبَۃَ ، قَالَ : سَمِعْتُ أَبَا إِسْحَاقَ یُحَدِّثُ قَالَ : کَانَ عَبْدُ اللہِ یَکْرَہُ أَنْ یَبْزُقَ الرَّجُلُ عَن یَمِینِہِ فِی غَیْرِ صَلاَۃٍ ، فَقَالَ لہ أَبَانُ : عَمَّنْ ؟ فَقَالَ : عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، عَنْ عَبْدِ اللہِ۔",,,27194 27195,"حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ عَوْنٍ قَالَ : کَانَ ابْنُ سِیرِینَ لَہُ بَابٌ عَن یَسَارِہِ مَسْدُودٌ ، وَکَانَ یَلْتَفِتُ إلَیْہِ فَیَبْزُقُ فِیہِ۔",,,27195 27196,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَن مِسْعَر ، عَن سَعْدِ بْنِ إبْرَاہِیمَ ، قَالَ : سَمِعْتُہُ یَقُولُ : مِنْ عَقْلِ الرَّجُلِ مَوْضِعُ بُزَاقِہِ۔",,,27196 27197,"حَدَّثَنَا وَکِیعٌ ، عَن مِسْعَرٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ قَالَ : کَانَ عَبْدُ اللہِ جَالِسًا مُسْتَقْبِلَ الْقِبْلَۃِ ، فأَرَادَ أَنْ یَبْزُقَ عَن شِمَالِہِ وَکَانَ مَشْغُولاً فَکَرِہَ أَنْ یَبْزُقَ عَن یَمِینِہِ۔",,,27197 27198,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَن حُمَیْدِ بْنِ ہِلاَلٍ ، أَنَّ مُعَاذًا تَفَلَ ذَاتَ یَوْمٍ ، عَن یَمِینِہِ ، ثُمَّ قَالَ : ہاہ ، مَا صَنَعْت ہَذَا مُنْذُ صَحِبْت النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أَوْ قَالَ : مُنْذُ أَسْلَمْت۔",,,27198 27199,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ قَالَ : حدَّثَنَا أَبُو ہِلاَلٍ ، عَن حُمَیْدِ بْنِ ہِلاَلٍ قَالَ : بَزَقَ أَبُو بَکْرٍ أو تَفَلَ عَن یَمِینِہِ فِی مِرْضَۃٍ مَرِضَہَا ، فَقَالَ : مَا فَعَلْتہ إلاَّ مَرَّۃً ، أَوْ قَالَ : غَیْرَ ہَذِہِ الْمَرَّۃِ۔",,,27199 27200,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ ابْنِ عَوْنٍ قَالَ : اعْتَذَرْت إلَی إبْرَاہِیمَ مِنْ شَیْئٍ بَلَغَہُ عَنی ، فَقَالَ : لاَ تَعْتَذِرْ ، قَدْ عَذَرْنَاک غَیْرَ مُعْتَذِرٍ۔",,,27200 27201,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا الأَعْمَشُ ، عَن سُلَیْمَانَ بْنِ مَیْسَرَۃَ ، عَن طَارِقِ بْنِ شِہَابٍ ، عَن رَافِعِ بْنِ أَبِی رَافِعٍ الطَّائِیِّ قَالَ : أَتَیْتُ أَبَا بَکْرٍ فَقُلْت : أَمَرْتَنِی بِمَا أَمَرْتَنِی بِہِ وَدَخَلْتَ فِیمَا دَخَلْتُ فِیہِ ، فَمَا زَالَ یَعْتَذِرُ إلَیَّ حَتَّی عَذَرْتہ۔",,,27201 27202,"حَدَّثَنَا حَفْصٌ، وَابْنُ نُمَیْرٍ، وَوَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ قَالَ قَالَ عَبْدُ اللہِ اتَّقُوا، وَقَالَ حَفْصٌ: إیَّاکُمْ وَالْمَعَاذِرَ ، فَإِنَّ کَثِیرًا مِنْہَا کَذِبٌ۔",,,27202 27203,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِاللہِ الأَسَدِیُّ، عَن سُفْیَانَ، عَن طَارِقٍ، عَنِ الشَّعْبِیِّ قَالَ: خَرَجَ إلَیْنَا شُرَیْحٌ یَعْتَذِرُ۔",,,27203 27204,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَن شُعْبَۃَ قَالَ : کُنْتُ أَمْشِی مَعَ الْحَکَمِ فَرَأَیْنَا أَبَا مَعْشَرٍ فَقَالَ الْحَکَمُ : إنَّ ہَذَا قَدْ بَلَغَہُ عَنی شَیْئٌ أَنِّی قُلْتہ ، وَلاَ وَاللَّہِ الَّذِی لاَ إلَہَ إلاَّ ہُوَ مَا قُلْتہ ، قَالَ : فَلَمَّا جَائَ أَبُو مَعْشَرٍ اعْتَذَرَ إلَیْہِ الْحَکَمُ ، وَقَالَ : قَدْ حَلَفْت لِشُعْبَۃَ أَنِّی لَمْ أَقُلِ الَّذِی بَلَغَک عَنی۔",,,27204 27205,"حَدَّثَنَا ابْنُ إدْرِیسَ، عَنْ عَمِّہِ، قَالَ: سَمِعْتُ الشَّعْبِیَّ یَقُولُ: أَتَانِی إبْرَاہِیمُ یَعْتَذِرُ إلَیَّ مِنْ أَمْرٍ مَا بَلَغَنِی عَنہُ۔",,,27205 27206,"حَدَّثَنَا حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَن مُوسَی بن عَلِی ، عَنْ أَبِیہِ أَنَّ رَجُلاً اکتَنَی بِأَبِی عِیسَی : فَقالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنَّ عِیسَی لاَ أَب لَہ۔",,,27206 27207,"حَدَّثَنَا حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَن عَبد اللہِ بْنُ عُمَرَ بْنُ حَفص ، عَن زَیْدِ بْنِ أَسْلَمَ ، عَنْ أَبِیہِ أَنَّ عُمَر ضَرَبَ ابنًا لَہ اکتَنَی بِأَبِی عِیسَی ، وَقَال : إِنَّ عِیسَی لَیسَ لَہُ أَب۔ (عبدالرزاق 19857)",,,27207 27208,"حَدَّثَنَا عَفَّانُ قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَن حُمَیْدٍ ، عَنِ الْحَسَنِ قَالَ : کَثْرَۃُ الضَّحِکِ تُمِیتُ الْقَلْبَ۔ (بخاری 252۔ ابن ماجہ 4217)",,,27208 27209,"حَدَّثَنَا عَفَّانُ ، عَن حَمَّادِ بْنِ سَلَمَۃَ ، عَن ثَابِتٍ ، عَنِ الْحَسَنِ قَالَ : ضَحِکُ الْمُؤْمِنِ غَفْلَۃٌ مِنْ قَلْبِہِ۔",,,27209 27210,"حَدَّثَنَا وَکِیعٌ ، عَن مِسْعَرٍ ، عَنْ عَوْنٍ قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لاَ یَضْحَکُ إلاَّ تَبَسُّمًا ، وَلاَ یَلْتَفِتُ إلاَّ مَعًا۔",,,27210 27211,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَن زَائِدَۃَ ، عَن مَنْصُورٍ ، عَن مُجَاہِدٍ قَالَ : بَلَغَ عُمَرَ ، أَنَّ عَامِلاً لَہُ لاَ یَقِیلْ ، فَکَتَبَ إلَیْہِ عُمَرُ : قِلْ ، فَإِنِّی حُدِّثْتُ أَنَّ الشَّیْطَانَ لاَ یَقِیلُ ، قَالَ مُجَاہِدٌ : إنَّ الشَّیَاطِینَ لاَ یَقِیلُونَ۔",,,27211 27212,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ وَوَکِیعٌ قَالَ : حدَّثَنَا مِسْعَرٌ قَالَ : حَدَّثَنَی ثَابِتُ بْنُ عُبَیْدٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، عَن خَوَّاتِ بْنِ جُبَیْرٍ وَکَانَ بَدْرِیًّا قَالَ : نَوْمُ أَوَّلِ النَّہَارِ خُرْقٌ ، وَأَوْسَطُہُ خُلُقٌ ، وَآخِرُہُ حُمْقٌ۔",,,27212 27213,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ بْنِ جَابِرٍ ، عَن مَکْحُولٍ ، أَنَّہُ کَانَ یَکْرَہُ النَّوْمَ بَعْدَ الْعَصْرِ ، وَقَالَ : یَخَافُ عَلَی صَاحِبِہِ مِنْہُ الْوَسْوَاسَ۔",,,27213 27214,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَن مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ قَالَ : مَرَّ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِرَجُلٍ مُنْبَطِحٍ عَلَی بَطْنِہِ ، فَقَالَ : إنَّ ہَذِہِ ضَجْعَۃٌ لاَ یُحِبُّہَا اللَّہُ۔\n\n(ترمذی 2768۔ احمد 287)",,,27214 27215,"حَدَّثَنَا الْحَسَنُ بْنُ مُوسَی قَالَ : حدَّثَنَا شَیْبَانُ ، عَن یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ أَبِی سَلَمَۃَ ، أَنَّ یَعِیشَ بْنَ قَیْسِ بْنِ طِخْفَۃَ حَدَّثَہُ ، عَنْ أَبِیہِ قَالَ : وَکَانَ أَبِی مِنْ أَصْحَابِ الصُّفَّۃِ ، قَالَ : بَیْنَا أَنَا نَائِمٌ عَلَی بَطْنِی مِنَ السَّحَرِ إذْ دَفَعَنی رَجُلٌ بِرِجْلِہِ فَقَالَ : ہَذِہِ ضَجْعَۃٌ یُبْغِضُہَا اللَّہُ ، فَرَفَعْت رَأْسِی فَإِذَا ہُوَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔ (ابوداؤد 5001۔ احمد 429)",,,27215 27216,"حَدَّثَنَا یُونُسُ بْنُ مُحَمَّدٍ قَالَ : حدَّثَنَا عَبْدُ الْوَاحِدِ بْنُ زِیَادٍ قَالَ : حَدَّثَنَا عَاصِمُ بْنُ کُلَیْبٍ ، عَنْ أَبِیہِ ، عَنْ أَبِی ہُرَیْرَۃَ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : کُلُّ خُطْبَۃٍ لَیْسَ فِیہَا تَشَہُّدٌ کَالْیَدِ الْجَذْمَائِ۔ (ترمذی 1106۔ ابوداؤد 4808)",,,27216 27217,"حَدَّثَنَا أَسْوَدُ بْنُ عَامِرٍ قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ عَطَائٍ ، عَنْ أَبِی الْبَخْتَرِیِّ قَالَ : کُلُّ حَاجَۃٍ لَیْسَ فِیہَا تَشَہُّدٌ فَہِیَ بَتْرَائُ۔",,,27217 27218,"حَدَّثَنَا أَسْوَدُ بْنُ عَامِرٍ قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، قَالَ : سَمِعت حُمَیْدَ بْنَ ہِلاَلٍ یَقول : کُل خطبۃ لَیْسَ فِیہَا تَشَہُّدٌ فَہِیَ بَتْرَائُ۔",,,27218 27219,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنِ الأَوْزَاعِیِّ ، عَن قُرَّۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : کُلُّ کَلاَمٍ ذِی بَالٍ لاَ یُبْدَأُ فِیہِ بِالْحَمْدِ لِلَّہِ ، فَہُوَ أَقْطَعُ۔\n\n(ابوداؤد 4807۔ احمد 359)",,,27219 27220,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَن حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ أَبِی الْمُہَزَّمِ ، عَنْ أَبِی ہُرَیْرَۃَ ، أَنَّہُ رَأَی رَجُلاً یَشْتَدُّ خَلْفَہُ غُلاَمٌ فَقَالَ : احْمِلْہُ فَإِنَّہُ أَخُوک الْمُسْلِمُ ، وَرُوحُہُ مِثْلُ رُوحِک۔",,,27220 27221,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَن یُوسُفَ بْنِ الْمُہَاجِرِ قَالَ : رَأَیْتُ أَبَا جَعْفَرٍ رَاکِبًا عَلَی بَغْلٍ ، أَوْ بَغْلَۃٍ مَعَہُ غُلاَمٌ یَمْشِی جَنَبَتیہ۔",,,27221 27222,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَن شُعْبَۃَ قَالَ حَدَّثَتْنِی شُمَیْسَۃُ ، قَالَتْ : سَمِعْت عَائِشَۃَ ، وَسُئلت عَنْ أَدَبِ الْیَتِیمِ فَقَالَتْ : إنِّی لأَضْرِبُ أَحَدَہُمْ حَتَّی یَنْبَسِطَ۔",,,27222 27223,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ الْعُرَنِیِّ ، أَنَّ رَجُلاً قَالَ لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مِمَّ أَضْرِبُ یَتِیمِی ؟ قَالَ : اضْرِبْہُ مِمَّا کُنْت ضَارِبًا مِنْہُ وَلَدَک۔ (طبری 260)",,,27223 27224,"حَدَّثَنَا عَفَّانُ قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ أَبِی جَعْفَرٍ الْخَطْمِیِّ ، أَنَّ أَبَاہُ سَأَلَ سَعِیدَ بْنَ الْمُسَیَّبِ ، أَوْ قَالَ : أَرْسِلْ مَوْلًی لَہُ وَأَنَا مَعَہُ یَسْأَلُہُ : مِمَّ یَضْرِبُ الرَّجُلُ یَتِیمَہُ ؟ قَالَ : مِمَّ یَضْرِبُ الرَّجُلُ وَلَدَہُ ، قَالَ أَبُو جَعْفَرٍ : وَسَأَلَ مُحَمَّدَ بْنَ کَعْبٍ فَقَالَ مِثْلُ ذَلِکَ۔",,,27224 27225,"حَدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ ، عَن مُحَمَّدٍ قَالَ : قرَأْت کِتَابًا فِیہِ مَا شَائَ اللَّہُ وَالأَمِیرُ فَقَالَ : مَا شَائَ الأَمِیرُ بَعْدَ اللہِ۔",,,27225 27226,"حَدَّثَنَا غُنْدَرٌ ، عَن شُعْبَۃَ ، عَن مَنْصُورٍ ، عَنْ عَبْدِ اللہِ بْنِ یَسَارٍ ، عَن حُذَیْفَۃَ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تَقُولُوا : مَا شَائَ اللَّہُ وَشَائَ فُلاَنٌ ، وَلَکِنْ قُولُوا : مَا شَائَ اللَّہُ ، ثُمَّ شَائَ فُلاَنٌ۔\n\n(ابوداؤد 4941۔ احمد 384)",,,27226 27227,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الأَجْلَحِ ، عَن یَزِیدَ بْنِ الأَصَمِّ ، عَنِ ابْنِ عَبَّاسٍ قَالَ : جَائَ رَجُلٌ إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَحَدَّثَہُ بِبَعْضِ الْکَلاَمِ فَقَالَ : مَا شَائَ اللَّہُ وَشِئْت ، فَقَالَ : جَعَلْتَنِی وَاللہ عَدْلاً ، لاَ بَلْ مَا شَائَ اللَّہُ۔ (ابن ماجہ 2117۔ احمد 214)",,,27227 27228,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَن سَالِمٍ ، عَن زُرْعَۃَ بْنِ مُسْلِمِ بْنِ جَرْہَدٍ ، عَنْ جَدِّہِ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَبْصَرَہُ فِی الْمَسْجِدِ وَعَلَیْہِ بُرْدَۃٌ قَدِ انْکَشَفَ فَخِذُہُ فَقَالَ : إنَّ الْفَخِذَ مِنَ الْعَوْرَۃِ۔ (ترمذی 2798۔ ابوداؤد 4010)",,,27228 27229,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ قَالَ : حدَّثَنَا ابْنُ صَالِحٍ ، عَن مَنْصُورٍ قَالَ : قَالَ عُمَرُ : فَخْذُ الرَّجُلِ مِنَ الْعَوْرَۃِ۔",,,27229 27230,"حَدَّثَنَا جَرِیرٌ ، عَن مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ کَانَ یَقُولُ : الْفَخِذُ مِنَ الْعَوْرَۃِ۔",,,27230 27231,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَن لَیْثٍ ، عَن مُجَاہِدٍ قَالَ : خُرُوجُ الْفَخْذِ فِی الْمَسْجِدِ مِنَ الْعَوْرَۃِ۔",,,27231 27232,"حَدَّثَنَا عُبَیْدُ اللہِ ، عَنْ إسْرَائِیلَ ، عَنْ أَبِی یَحْیَی ، عَن مُجَاہِدٍ ، عَنِ ابْنِ عَبَّاسٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : الْفَخْذُ مِنَ الْعَوْرَۃِ۔ (ترمذی 2796۔ احمد 275)",,,27232 27233,حَدَّثَنَا جَعفَر بْنُ عَوْنٍ ، عَنْ أَبِی الْعُمَیْسِ ، عَنْ عَوْنِ بْنِ أَبِی جُحَیْفَۃَ ، عَنْ أَبِیہِ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ آخَی بَیْنَ سَلْمَانَ ، وَأَبِی الدَّرْدَائِ۔ (بخاری 1968۔ ترمذی 2413),,,27233 27234,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَن ہِشَامِ بْنِ عُرْوَۃَ ، عَن بَشِیرِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ کَعْبِ بْنِ مَالِکٍ قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ آخَی بَیْنَ الزُّبَیْرِ وَبَیْنَ کَعْبِ بْنِ مَالِکٍ۔ (ابن سعد 102)",,,27234 27235,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَن زَائِدَۃَ ، عَنْ أَبِی فَرْوَۃَ قَالَ : قَالَ ابْنُ أَبِی لَیْلَی : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ آخَی بَیْنَ زَیْدٍ وحَمْزَۃَ ۔",,,27235 27236,حَدَّثَنَا قَبِیصَۃُ ، عَن حَمَّادِ بْنِ سَلَمَۃَ ، عَن ثَابِتٍ ، عَنْ أَنَسٍ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ آخَی بَیْنَ أَبِی طَلْحَۃَ وَبَیْنَ أَبِی عُبَیْدَۃَ بْنِ الْجَرَّاحِ۔ (حاکم 268),,,27236 27237,"حَدَّثَنَا عَفَّانُ قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَن ثَابِتٍ ، عَن شَہْرِ بْنِ حَوْشَبٍ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ آخَی بَیْنَ عَوْفِ بْنِ مَالِکٍ وَالصَّعْبِ بْنِ جَثَّامَۃَ۔",,,27237 27238,حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنِ الْحَجَّاجِ ، عَنِ الْحَکَمِ ، عَن مِقْسَمٍ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ لِعَلِیٍّ ، أَنتَ أَخِی وَصَاحِبِی۔ (ترمذی 3720۔ احمد 230),,,27238 27239,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ قَالَ : أَخْبَرَنَا حُمَیْدٌ ، عَنْ أَنَسٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ آخَی بَیْنَ عَبْدِ الرَّحْمَنِ بْنِ عَوْفٍ وَسَعْدِ بْنِ الرَّبِیعِ۔ (بخاری 2049۔ احمد 271)",,,27239 27240,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، عَن مُحَمَّدٍ قَالَ : مَا تَرَکَ الرَّجُلُ أَنْ یَأْخُذَ مِنْ دِرْہَمِ صَدِیقِہِ۔",,,27240 27241,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَن نَافِعٍ ، عَنِ ابْنِ عُمَرَ قَالَ : لَقَدْ رَأَیْتنَا وَمَا الرَّجُلُ الْمُسْلِمُ بِأَحَقَّ بِدِینَارِہِ ، وَلاَ دِرْہَمِہِ مِنْ أَخِیہِ الْمُسْلِمِ۔",,,27241 27242,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ قَالَ : قَالَ لَہُ عَلْقَمَۃُ : یَا أَبَا عَمْرٍو ، فَقَالَ : لَبَّیْکَ ، فَقَالَ لَہُ : عَلْقَمَۃُ : لبِّیْ یَدَیْک۔",,,27242 27243,"حَدَّثَنَا عَفَّانُ قَالَ : حدَّثَنَا أَبُو عَوَانَۃَ ، عَن مُغِیرَۃَ ، عَنْ أَبِی وَائِلٍ قَالَ : کَانَ إذَا دُعِیَ قَالَ : لَبَّیِ اللَّہَ ، وَلاَ یَقُولُ : لَبَّیْکَ۔",,,27243 27244,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَن سُفْیَانَ ، عَن سَعْدِ بْنِ یُوسُفَ بْنِ یَعْقُوبَ قَالَ : قالُوا لِطَاوُوس فِی عَبْدٍ لَہُ فَقَالَ : مَا لَہُ مَالٌ أکاتبہ ، وَلاَ ہُوَ صَالِحٌ فَأُزَوِّجُہُ ، وَکَانَ یَکْرَہُ الضَّرْبَ ، وَیَقُولُ : الْقَیْدُ۔",,,27244 27245,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ إبْرَاہِیمَ بْنِ طَہْمَانَ عَمَّنْ حَدَّثَہُ ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ ، أَنَّہُ کَانَ یَکْرَہُ أَنْ یَجْعَلَ الرَّجُلُ فِی عُنُقِ غُلاَمِہِ الرَّایَۃَ۔,,,27245 27246,حَدَّثَنَا ابْنُ إدْرِیسَ ، عَن ہِشَامٍ ، عَنِ الْحَسَنِ ، أَنَّہُ کَانَ یَکْرَہُ أَنْ یَجْعَلَ الرَّجُلُ فِی عُنُقِ غُلاَمِہِ الْبَرَّایَۃَ۔,,,27246 27247,"حَدَّثَنَا ابْنُ أَبِی زَائِدَۃٍ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَن مَسْرُوقٍ ، عَنْ عَبْدِ اللہِ ، أَنَّہُ قَالَ لِرَجُلٍ وَذَکَرَ امْرَأَتَہُ فَقَالَ : قیِّدْہَا۔",,,27247 27248,"حَدَّثَنَا وَکِیعٌ ، عَن أُسَامَۃَ بْنِ زَیْدٍ ، عَن مُحَمَّدِ بْنِ الْمُنْکَدِرِ ، عَنْ جَابِرٍ ، قَالَ : سَمِعْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : سَلُوا اللَّہَ عِلْمًا نَافِعًا وَتَعَوَّذُوا بِاللَّہِ مِنْ عِلْمٍ لاَ یَنْفَعُ۔ (بخار ی3220۔ احمد 230)",,,27248 27249,"حَدَّثَنَا وَکِیعٌ ، عَن شُعْبَۃَ ، عَن غَالِبٍ الْعَبْدِیِّ ، عَن رَجُلٍ مِنْ بَنِی نمیر ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، أَوْ جَدِّ أَبِیہِ قَالَ : قُلْتُ : یَا رَسُولَ اللہِ ، إنَّ أَبِی یُقْرِئُک السَّلاَمَ ، قَالَ : عَلَیْک وَعَلَی أَبِیک السَّلاَمُ ، قُلْتُ : یَا رَسُولَ اللہِ ، إنَّ قَوْمِی یُرِیدُونَ أَنْ یُعَرِّفُونِی ، قَالَ : لاَ بُدَّ مِنْ عَرِیفٍ ، وَالْعَرِیفُ فِی النَّارِ۔",,,27249 27250,"حَدَّثَنَا وَکِیعٌ ، عَنِ أََبِی سَعِید ، عَن رَجُلٍ لَمْ یَکُنْ یُسَمِّہِ سَمِعَ أَنَسًا یَقُولُ : وَیْلٌ لِلْعُرَفَائِ وَالنُّقَبَائِ ، وَیْلٌ لِلأمَنَائِ ، وَدَّ أَحَدُہُمْ یَوْمَ الْقِیَامَۃِ لَوْ کَانَ مُعَلَّقًا بِالثُّرَیَّا۔ (احمد 531۔ ابویعلی 6189)",,,27250 27251,"حَدَّثَنَا وَکِیعٌ ، عَن عِمْرَانَ بْنِ حُدَیْرٍ ، عَنْ عَبْدِ اللہِ بْنِ شَقِیقٍ ، عَن حَبِیبِ بْنِ حَیْدَۃَ قَالَ : لأَنْ أُقْطَعَ أَحَبُّ إلَیَّ مِنْ أَنْ أَکُونَ عَرِیفًا عَلَی عَشْرَۃٍ سَنَۃً۔",,,27251 27252,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَن عُثْمَانَ بْنِ حَکِیمٍ قَالَ : أَخْبَرَنِی عَبْدُ اللہِ بْنُ عُثْمَانَ ، عَنْ رَجُلُ مِنْ بَنِی سَلُولَ ، أَنَّہُ دَعَاہُ قَوْمُہُ لِیُعَرِّفُوہُ ، وَاخْتَارُوہُ لِذَلِکَ ، فَأَبَی وَامْتَنَعَ ، فَذَہَبَ إلَی عَبْدِ اللہِ بْنِ عَمْرٍو فَشَاوَرَہُ وَاسْتَأْمَرَہُ فَقَالَ : لاَ تَعْرِفَنَّ عَلَیْہِمْ فَجَاؤوا بِالْغَدْوَی فَلَمْ یَزَالُوا حَتَّی أَلْزَمُوہَا إیَّاہُ ، فَذَہَبَ إلَی عَبْدِ اللہِ بْنِ عَمْرٍو فَأَخْبَرَہُ ، أَنَّہُ قَدْ أُکْرِہَ فَقَالَ : أَوَّلُہَا شُفْعَۃٌ وَأَوْسَطُہَا خِیَانَۃٌ وَآخِرُہَا عَذَابُ النَّارِ۔",,,27252 27253,"حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَن غَالِبٍ قَالَ: إنَّا لَجُلُوسٌ إذْ رَجُلٌ دَخَلَ فَقَالَ: حَدَّثَنِی أَبِی، عَنْ جَدِّی، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ: مَنِ ابْتَدَأَ قَوْمًا بِسَلاَمٍ فَضَلَہُمْ بِعَشْرِ حَسَنَاتٍ ، وَقَالَ: بَعَثَنِی أَبِی إلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَقَالَ : ائْتِہِ فَأُقْرِئْہُ السَّلاَمَ ، وَقُلْ لَہُ ہُوَ یَطْلُبُ إلَیْک أَنْ تَجْعَلَ لَہُ الْعِرَافَۃُ مِنْ بَعْد ، قَالَ : الْعِرَافَۃُ حَقٌّ ، الْعِرَافَۃُ حَقٌّ ، وَلاَ بُدَّ مِنْ عُرَفَائَ ، وَلَکِنَّ الْعَرِیفَ بِمَنْزِلَۃٍ قَبِیحَۃٍ۔(ابوداؤد 5189۔ بزار 808)",,,27253 27254,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ قَالَ : حدَّثَنَا قُرَّۃُ ، عَن حُمَیْدِ بْنِ ہِلاَلٍ قَالَ : قَالَ أَبُو السَّوَّارِ : وَاللَّہُ لَوَدِدْت أَنَّ حَدَقَتِی فِی حِجْرِی مَکَانَ الْعِرَافَۃِ۔",,,27254 27255,"حَدَّثَنَا الْفَضْلُ قَالَ : حدَّثَنَا سَلاَّمُ بْنُ مِسْکِینٍ ، عَن مُحَمَّدِ بْنِ وَاسِعٍ ، عَنِ الْمَہْرِیِّ ، عَنْ أَبِی ہُرَیْرَۃَ قَالَ : قَالَ لِی : یَا مَہْرِیُّ ، لاَ تَکُنْ جَابِیًا ، وَلاَ عَرِیفًا ، وَلاَ شُرْطِیًّا۔",,,27255 27256,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَن مُحَمَّدٍ قَالَ : کَانَ عَبِیْدَۃُ عَرِیفَ قَوْمِہِ۔",,,27256 27257,"حَدَّثَنَا الْفَضْلُ ، عَن قُرَّۃَ قَالَ : کَانَ أَبُو السَّوَّارِ عَرِیفًا فِی زَمَنِ الْحَجَّاجِ۔",,,27257 27258,"حَدَّثَنَا غَسَّانُ بْنُ مُضَرَ ، عَن سَعِیدِ بْنِ یَزِیدَ ، عَنْ أَبِی نَضْرَۃَ ، عَنْ جَابِرٍ قَالَ : لَمَّا وَلِیَ عُمَرُ الْخِلاَفَۃَ فَرَضَ الْفَرَائِضَ ، وَدَوَّنَ الدَّوَاوِینَ ، وَعَرَّفَ الْعُرَفَائَ ، قَالَ جَابِرٌ : فَعَرَّفَنِی عَلَی أَصْحَابِی۔",,,27258 27259,"حَدَّثَنَا الْفَضْلُ قَالَ : حدَّثَنَا یُونُسُ بْنِ أَبِی إِسْحَاقَ قَالَ : رَأَیْتُ سَعِید بْنَ وَہْب وَکَانَ عَرِیفَ قَوْمِہِ۔",,,27259 27260,"حَدَّثَنَا مَرْحُومُ بن عَبْدِ العزیز ، عَنْ أَبِیہِ : کَانَ أَبُو السَّوَّارِ عَرِیفَ بَنِی عَدِیٍّ۔",,,27260
