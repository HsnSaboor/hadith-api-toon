أ““أتۄهأدىحأوۏڽأمزشأًأوىصهحأڬەأتؼحثتشأضەأضثأضەأڬوحشأطرظأدًأۄًأڲتأًۄأتځىۏأوهڬۏحأوۏڽأزًأۄصتشأضتهأ+أڬۏأوضتلحأ,أحڬأىػشأڬشأضڬەأڲتأتًشأًۄأزًشأڬەأذظەأڬًأثہۏأۏًڽأزۏڬہأهەأڲتأدضأغشذأىصزۏڬۏأذظەأڬًأزۏڬہأضڬەأڲتأتًشأًۄأتځىۏأثۏًۏًڽأتًشأرزوحأڲتشًڽأڬًأثہۏأزۏڬہأضڬەأڲتأۗ‛‛ أۏۄأشًتۏحأتوتوأتذوزأتًشأتوتوأتثًۏؼهۏٳأتًشأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأتىأڬۏأتضتىۏزأوۏڽأتۏڬأشتًۏأخًۏشأثىأتثًلترحۄأۄەأتًشأتضأڬەأعؼۏلأۄًىەأځشأتحلتمأۄەأۗ
18670,أذعشحأتىضأثىأوتهڬأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أوۏڽأىەأىثۏأتڬشوأ﷽أڬًأۏۄأتشطتزألشوتحەأۄًةەأضىتأۄەأ=
أ““أتۄهأدىحأوۏڽأدًأضثأضەأڬوأوشحثۄأڬتأطرظأۄًأڲتأتضأڬەأضشۄتىەأثہۏأزضأۄصتشأوهتصوۏىأوًدًزأۄًڽأڲەأدىأوۏڽأضەأۄشأتۏڬأڬەأۄتحہًڽأوۏڽأزًأزًأثشحىأۄًڽأڲەأ؏أتىأوۏڽأضەأتۏڬأضًىەأڬتأۄًأڲتأتًشأزًضشتأډتىزۏأڬتأۄًأڲتأتًشأتىأوۏڽأضەأۄشأتۏڬأوۏڽأورحهلأمضوأڬتأڬہتىتأۄًأڲتأًۄأطرظأإرشۏأثشحىأوۏڽأضەأثہۏأتضۏأغشذأڬہتةەأڲتأ؏أدضأغشذأځۄهەأوۏڽأضەأڬہتةەأڲتأتًشأتضەأإرشۏأثشحىأوۏڽأضەأثہۏأتضۏأغشذأڬۏأرًطثًأتًشأهسحأوذضًضأۄًأڲۏأدضأغشذأڬۏأځۄهەأثشحىأوۏڽأضەأوذضًضأۄًةۏأحہۏأ+أۏؼىۏأصۏتزۄأڬہتىەأڬۏأًدۄأضەأتضأڬۏأرًطثًأۏتأهسحأوۏڽأڬوۏأىۄۏڽأۄًأڲۏأ,"أتًشأځہشأًۄأضثأڬہتىتأوطڬأتسلشأڬۏأغشذأڬۏأرًطثًأوۏڽأحثزۏهأۄًأدتةەأڲتأ؏أتۄهأدىحأڬًأځۏطتثأۏتأځترتىۄأڬۏأذتدحأىۄۏڽأۄًأڲۏأتًشأىۄأتىۄۏڽأثهؽوأحہًڬىەأڬۏأعشًشحأۄًأڲۏأ؏أًۄأثہتةۏأثہتةۏأۄًڽأڲەأتًشأځهىڲًڽأځشأتۏڬأزًضشەأڬەأوزومتثهأثۏټہەأۄًڽأڲەأۗ‛‛ أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأتًشأتضأڬەأشدتهأخمۄأۄۏڽأۗ"""
18671,أذعشحأؼًلأثىأوتهڬأشعۏأتههۄأؼىۄأىثۏأتڬشوأ﷽أڬتأۏۄألشوتىأىمهأڬشحەأۄۏڽأ= أ““أودہەأتْضأطرظأڬەأثتشەأوۏڽأځحتأۄەأدًأدىحأوۏڽأضثأضەأإرشأوۏڽأزترهأۄًأڲتأ؏أًۄأتۏڬأتۏضتأطرظأۄًأڲتأدًأۏۄأڬۄەأڲتأ=أتەأوۏشەأځشًشزڲتشأ$أودہەأدۄىوأضەأزًشأڬشأزەأ؏أًۄأۏۄأىۄۏڽأڬۄەأڲتأ=أحًأودہەأدىحأوۏڽأزترهأڬشأزەأ؏أدثأتۄهأدىحأ؏أدىحأوۏڽأزترهأۄًأدتةۏڽأڲەأتًشأتۄهأدۄىوأ؏أدۄىوأوۏڽأزترهأۄًأدتةۏڽأڲەأتًشأظشلأًۄأطرظأثتمۏأشۄأدتةەأڲتأ؏أحًأًۄأڬۄەأڲتأ=أتەأوۏشەأځشًشزڲتشأ$أڬۏتأًدۄأۄەأڬۄأوۏڽأۏۄتڽأۄًڽأآأځشًشزڲتشألشوتةەأڲتأ=أتەأتثىأإزوأ$أۏۄأًۄأډۏصأۄەأدًأحوأىەأودہأضەأوتىڲۏأحہۏأ؏أًۄأڬۄەأڲتأ=أتەأوۏشەأځشًشزڲتشأ$أحًأودہەأدىحأڬەأمشۏثأڬشأزەأ؏أځشًشزڲتشألشوتةەأڲتأ=أتەأتثىأإزوأ$أحوأىەأحًأودہأضەأوتىڲىتأىۄۏڽأحہتأ؏أىثۏأتڬشوأ﷽ألشوتحەأۄۏڽأ=أځہشأتههۄأحؼتهۏٳأدىحأڬەأزشًتصەأڬەأځتضأتضأڬەأهۏەأتۏڬأزشرحأځۏزتأڬشەأڲتأ؏أًۄأطرظأۏۄأڬۄەأڲتأ=أتەأوۏشەأځشًشزڲتشأ$أودہەأتضأزشرحأڬەأمشۏثأڬشأزەأحتڬۄأوۏڽأتضأڬتأځہهأڬہتاڽأتًشأتضأڬەأضتةەأوۏڽأشۄًڽأ؏أحًأځشًشزڲتشألشوتةەأڲتأ=أتەأتثىأإزوأ$أحوأىەأحًأظشلأودہأضەأۏۄأضًتهأڬۏتأحہتأڬۄأوۏڽأحوۄۏڽأدۄىوأضەأزًشأڬشأزًڽأ؏أًۄأطرظأوضهضهأوتىڲحتأشۄەأڲتأ؏أۏۄتڽأحڬأڬۄأتضأضەأڬۄتأدتةەأڲتأ=أحوأدتاأ$أحوۄۏڽأًۄأضثأوهحتأۄەأ؏أدۄتڽأحڬأڬۄأحوۄتشەأمزوأځۄىډۏڽأڲەأتًشأدۄتڽأحڬأحوۄتشۏأإىڬہۏڽأزۏڬہۏڽأڲۏأۗ‛‛ أۏۄأشًتۏحأتوتوأغثشتىۏأىەأتضأڬۏأوتىىزأىمهأڬۏأۄەأ؏أحتۄوأتىۄًڽأىەأۏۄأتهلتػأىمهأڬۏەأۄۏڽأ=أ
أ““أځشًشزڲتشألشوتةەأڲتأ=أتەأتثىأإزوأ$أۏۄأًۄأډۏصأۄەأدًأحوأودہأضەأوتىڲأشۄەأحہەأ؏أتضۏأزًشتىأتضأڬەأضتوىەأدىحأڬەأزشًتصەأڬەأځتضأتۏڬأزشرحأىػشأإةەأڲتأ؏أدًأدىحأڬەأتىزشًىۏأذظەأوۏڽأۄًأڲتأ؏أًۄأڬۄەأڲتأ=أتەأوۏشەأځشًشزڲتشأ$أحًأودہەأتضأزشرحأڬەأمشۏثأڬشأزەأحتڬۄأوۏڽأتضأڬتأځہهأڬہتاڽأتًشأتضأڬەأضتةەأوۏڽأإأدتاڽأ؏أځشًشزڲتشألشوتةەأڲتأ=أتەأتثىأإزوأ$أحوأىەأحًأودہأضەأ+أوصۏزأڬډہأ,أوتىڲىتأىۄۏڽأحہتأ؏أًۄأطرظأڬۄەأڲتأ=أتەأوۏشەأځشًشزڲتشأ$أحۏشۏأوختهأڬۄتڽأۄەأ؏أحًأًۄأطرظأوضهضهأۏۄۏأڬشحتأشۄەأڲتأڬۄأدثأصۏتزۄأثۄحشأډۏصأزۏڬہەأڲتأحًأًۄأوتىڲىتأطشًؼأڬشأزەأڲتأ؏أۏۄتڽأحڬأڬۄأتضأضەأۏۄأڬۄتأدتةەأڲتأ=أحوأدتاأ$أحوۄۏڽأًۄأضثأڬډہأوهحتأۄەأ؏أدۄتڽأحڬأحوۄتشەأمزوأدتةۏڽأتًشأدًأحوۄتشۏأإىڬہۏڽأزۏڬہۏڽأ؏أحًأًۄأزًڔەأڲتأ؏أۏۄتڽأحڬأڬۄأًۄأحہڬأدتةەأڲتأ؏أتًشأًۄأتځىەأۄتحہأڬەأسشۏؼەأتطتشۄأڬشأڬەأڬۄەأڲتأ=أۏۄأتًشأۏۄأ؏أحًأتْضەأڬۄتأدتةەأڲتأ=أۏۄأحوۄۏڽأوهحتأۄەأتًشأتضأڬۏأوتىىزأوصۏزأوهحتأۄەأ؏أحًأًۄأشتعۏأۄًأدتةەأڲتأ؏أۏۄتڽأحڬأڬۄأًۄأۏۄأضودہەأڲتأڬۄأتههۄأحؼتهۏٳأىەأدًأڬډہأتضەأؼغتأڬۏتأۄەأ؏أًۄأتۄهأدىحأوۏڽأضەأڬضۏأڬًأؼغتأىۄۏڽأڬۏتأ؏أًۄأڬۄەأڲتأ=أتڲشأودہەأتدتصحأزۏأدتةەأحًأتههۄأحؼتهۏٳأىەأدًأڬډہأودہەأزۏتأۄەأ؏أوۏڽأتْضأوۏڽأضەأتۄهأدىحأڬًأڬہتىتأ؏أوطشًثأتًشأهثتضألشتۄوأڬشًڽأ؏أځہشأثہۏأدًأڬډہأوۏشەأځتضأۄەأ؏أتضأوۏڽأڬًةۏأڬوۏأىۄۏڽأۄًأڲۏأۗ‛‛ أتىأزًىًڽأشًتۏتحأڬۏأضىزأوۏڽأتۏڬأشتًۏأوًضۏٳأثىأؼثۏزۄأشثسۏأۄەأتًشأًۄأعؼۏلأۄەأۗ
18672,أذعشحأتثًتوتوۄأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أ أ““أدىحأوۏڽأزترهأۄًىەأًتهتأإرشۏأطرظأًۄأۄًأڲتأدًأځهأظشتغأځشأۏًڽأهًټأشۄتأۄًأڲتأ؏أدۏضەأڬضۏأهڔڬەأڬۏأتضأڬتأثتځأځټتةۏأڬشەأتًشأًۄأهڔڬتأتضأضەأثہتڲىتأډتۄحتأۄًأ؏أتضأطرظأڬتأؼوهأتضەأتضأمتثهأىۄۏڽأشۄىەأزەأڲتأڬۄأًۄأزًڔأضڬەأ؏أًۄأڬۄەأڲتأ=أتەأوۏشەأځشًشزڲتشأ$أحًأودہەأدىحأحڬأځۄىډتأزەأتًشأودہەأدۄىوأضەأىدتحأزۏزەأ؏أحًأتههۄأحؼتهۏٳأتضأڬۏأغشلأۏۄأًذۏأڬشەأڲتأ=أتەأوۏشەأثىزەأ$أتڲشأوۏڽأىەأحدہەأدۄىوأضەأىدتحأزۏزۏأتًشأوۏڽأىەأحدہەأدىحأوۏڽأزترهأڬشأزۏتأ؏أحًأڬۏتأحًأوۏشەأضتوىەأتځىەأڲىتۄًڽأتًشأرغتاڽأڬتأتؼحشتلأڬشأهەأڲتأآأثىزۄأدًتثأزەأڲتأ=أدۏأۄتڽأ$أتەأوۏشەأځشًشزڲتشأ$أحۏشۏأؼصحأتًشأحۏشەأدهتهأڬۏأمضوأۄەأ$أتڲشأحًأىەأودہەأدۄىوأضەأىدتحأؼغتأڬشأزۏأحًأوۏڽأحۏشەأضتوىەأتځىەأڲىتۄًڽأتًشأرغتاڽأڬتأتؼحشتلأڬشأهًڽأڲتأ؏أًۄأځهأظشتغأڬًأځتشأڬشأهەأڲتأ؏أځہشأًۄأطرظأۏۄأضًډەأڲتأتڲشأوۏڽأىەأتځىەأڲىتۄًڽأتًشأرغتاڽأڬتأتؼحشتلأڬشأهۏتأ؏أحًأتههۄأحؼتهۏٳأودہەأدۄىوأڬۏأغشلأًتځضأثہۏدأزەأڲتأ؏أتههۄأحؼتهۏٳأتضأثىزەأڬۏأغشلأۏۄأًذۏأڬشەأڲتأ=أتەأوۏشەأثىزەأ$أحًأوۏشەأضتوىەأتځىەأڲىتۄًڽأتًشأرغتاڽأڬتأتؼحشتلأڬشأهەأحتڬۄأوۏڽأحۏشۏأوؽلشحأڬشأزًڽأتًشأحدہەأدىحأوۏڽأزترهأڬشأزًڽأ؏أحًأثىزۄأڬۄەأڲتأ=أدۏأىۄۏڽأ$أحۏشۏأؼصحأڬۏأمضوأ$أوۏڽأىەأڬثہۏأڬضۏأڲىتۄأڬتأتشحڬتثأىۄۏڽأڬۏتأتًشأوۏڽأىەأڬثہۏأڬًةۏأرغتأىۄۏڽأڬۏأ؏أحًأتههۄأحؼتهۏٳأتضأڬۏأغشلأۏۄأًذۏأڬشەأڲتأ=أتەأوۏشەأثىزەأ$أحوۄتشەأرهتلأوۏشەأځتضأتۏڬأخثًحأۄەأ؏أًۄأثىزۄأتځىەأزتةۏڽأثتةۏڽأزۏڬہەأڲتأ؏أتْضەأڬًةۏأىػشأىۄۏڽأإةەأڲتأ؏أحًأًۄأڬۄەأڲتأ=أتەأوۏشەأځشًشزڲتشأ$أحًأتځىتأخثًحأودہەأزڬہتأ؏أحًأتههۄأحؼتهۏٳأتضأڬۏأدهزأڬًأڲًۏتةۏأؼغتأڬشەأڲتأ؏أحًأًۄأذمۏشأضودہەأدتىەأًتهەأڲىتۄًڽأڬتأتؼحشتلأڬشەأڲۏأ؏أدثأثىزۄأۏۄأظًشحذتهأزۏڬہەأڲتأحًأًۄأۏۄأڬۄەأڲتأ=أتەأوۏشەأځشًشزڲتشأ$أحۏشۏأؼصحأڬۏأمضوأوۏشەأڬډہأتۏضەأڲىتۄأثہۏأۄۏڽأ؏أدًأځًطۏزۄأۄۏڽأ؏أحًأځشًشزڲتشأتضأڬۏأغشلأۏۄأًذۏأڬشەأڲتأ=أتەأوۏشەأثىزەأ$أوۏڽأتىأڬەأثتشەأوۏڽأحوأضەأصۏتزۄأثۄحشأدتىحتأۄًڽأ؏أحوأوۏشەأضتوىەأتىأڬەأذًتهەأضەأتؼحشتلأڬشأهًأ؏أوۏڽأتىأڬەأذًتهەأضەأحوۄتشۏأوؽلشحأڬشأزًڽأڲتأتًشأحوۄۏڽأدىحأوۏڽأزترهأڬشأزًڽأڲتأ؏أحًأثىزۄأتځىەأڲىتۄًڽأڬتأتؼحشتلأڬشأهەأڲتأتًشأتههۄأحؼتهۏٳأتضەأدىحأوۏڽأزترهأڬشأزەأڲتأۗ‛‛ أشتًۏأثۏتىأڬشحەأۄۏڽأ=أځہشأىثۏأتڬشوأ﷽أۄىضأځڔەأ؏أۏۄتڽأحڬأڬۄأإځأڬەأتغشتلأڬەأزتىحأىػشأإىەأهڲەأ؏أإځأ﷽أىەأتشطتزألشوتۏتأ= أ““أۏۄأتضأطرظأڬتأذتهأۄەأدًأتۄهأدىحأوۏڽأضثأضەأڬوأحشأوشحثۄأڬتأۄًأڲتأ؏أحًأتضأڬتأڬۏتأذتهأۄًأڲتأآأدًأتضأضەأتًځشأۄًأڲتأۗ‛‛ أۏۄأشًتۏحأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏضەأشتًۏأۄۏڽأ؏أدىأضەأوۏڽأًتملأىۄۏڽأۄًڽأتًشأتىأوۏڽأعؼۏلأشتًۏأۄۏڽأدىأڬۏأڬوصًشأحًخۏمأڬۏأڲةۏأۄەأۗ
18673,أذعشحأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أ أ““أدىحأوۏڽأزترهأۄًىەأًتهتأإرشۏألشزأًۄأۄًأڲتأدضأڬەأځتضأضەأتضأڬتأځشًشزڲتشأڲصشەأڲتأتًشأتضأضەألشوتةەأڲتأ=أحوأتْټہًأتًشأدىحأوۏڽأزترهأۄًأدتاأ؏أحًأًۄأوتحہەأځشأثهأڋتهأڬشأتضأڬۏأغشلأوحًدۄأۄًأڲتأتًشأڬۄەأڲتأ=أڬۏتأحًأىەأوۏشەأهۏەأڬًةۏأډۏصأثتمۏأشۄىەأزۏأۄەأآأځشًشزڲتشألشوتةەأڲتأ=أدۏأۄتڽأ$أحوۄۏڽأتضأڬۏأوتىىزأوهحتأۄەأ؏أدضأځشأضًشدأغهًؼأۏتأؽشًثأۄًحتأحہتأۗ‛‛ أۏۄأشًتۏحأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأتًشأتضأڬەأشدتهأظذۏذأڬەأشدتهأۄۏڽأ؏أظشلأۄثۏشۄأثىأۏشۏوأڬتأوؼتوهۄأورحهلأۄەأتًشأًۄأخمۄأۄەأۗ
أ+أؼهتوۄأۄۏخوۏألشوتحەأۄۏڽأ=أ,أوۏڽأۏۄأڬۄحتأۄًڽأ=أتضأضەأځۄهەأتۏڬأ““أظذۏذأ‛‛أغًۏهأذزۏخأڲصشأډڬۏأۄەأدضەأذعشحأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄأىەأشًتۏحأڬۏتأۄەأ؏أوۏڽأىەأتْضەأثتثأ=أزًثتشۄأصىزۄأڬۏەأدتىەأ+أضەأوحؼهمأشًتۏتحأ
