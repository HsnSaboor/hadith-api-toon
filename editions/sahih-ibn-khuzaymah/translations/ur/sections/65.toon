hadiths[15]{hadithnumber,text}:
2169,"دىتثأوشخزأۏتأتثًوشخزأتځىەأًتهزأضەأشًتۏحأڬشحەأۄۏڽأڬۄأۄوأذعشحأتثًسشأشعۏأتههۄأؼىۄأضەأوهەأدثڬۄأًۄأزشوۏتىەأدوشەأڬەأځتضأحہەأۗأحًأوۏڽأىەأتىأضەأطثأمزشأڬەأثتشەأوۏڽأضًتهأڬۏتأۗأحًأتىۄًڽأىەألشوتۏتأ=““أطثأمزشأڬەأثتشەأوۏڽأودہأضەأصۏتزۄأشضًهأتههۄأ﷽أضەأځًډہىەأًتهتأڬًةۏأىۄۏڽأۄەأۗ‛‛أوۏڽأىەأؼشعأڬۏأ=أتەأتههۄأڬەأشضًهأ$أڬۏتأطثأمزشأڬەأثتشەأوۏڽأتىثۏتؤأڬشتوأځشأًذۏأىتصهأۄًةۏأحہۏأځہشأ+أتىثۏتؤأڬەأدتىەأڬەأثؼزأطثأمزشأثہۏأ,أًتځضأډهۏأڲةۏأآأحًأإځأىەألشوتۏتأ=‛‛أثهڬۄأطثأمزشأمۏتوحأحڬأوًدًزأۄەأۗأوۏڽأىەأڬۄتأ=أتەأتههۄأڬەأشضًهأ$أًۄأڬًىأضۏأشتحأۄەأآأإځأىەألشوتۏتأ=““أتڲشأودہەأتدتصحأۄًحۏأحًأوۏڽأحوۄۏڽأعشًشأثحتأزۏحتأۗأهۏڬىأحوأتضەأضتحأزىًڽأوۏڽأحهتطأڬشًأتًشأإدأڬەأثؼزأتضأڬەأثتشەأوۏڽأضًتهأىۄأڬشىتأۗأڬۄحەأۄۏڽأ=أځہشأشضًهأتههۄأ﷽أهًڲًڽأڬۏأغشلأوحًدۄأۄًأڬشأتىۄۏڽأثۏتىأڬشىەأهڲەأحًأوۏڽأىەأؼشعأڬۏأ=أتەأتههۄأڬەأشضًهأ$أًۄأڬًىأضەأضتحأزىًڽأوۏڽأۄەأآأحًأإځأودہأځشأتضأمزشأىتشتعأۄًةەأڬۄأتۏضۏأطزۏزأىتشتعۏأىۄأتضأضەأځۄهەأڬثہۏأۄًةۏأحہۏأتًشأىۄأثؼزأوۏڽأڬثہۏأۄًةۏأۗأځہشأإځأىەألشوتۏتأ=““أڬۏتأوۏڽأىەأحوۄۏڽأتضأڬەأثتشەأوۏڽأضًتهأڬشىەأضەأوىؼأىۄۏڽأڬۏتأحہتأآأتڲشأودہەأتدتصحأۄًحۏأحًأوۏڽأحوۄۏڽأعشًشأثحتأزۏحتأ؏أوۏڽأحوۄۏڽأتضأڬەأثتشەأوۏڽأعشًشأتضأڬۏأرثشأزەأزۏحتأۗأهۏڬىأودہەأتوۏزأۄەأڬۄأۏۄأإرشۏأضتحأزىًڽأوۏڽأۄًأڲۏأۗ‛‛

[تخریج]: (2169) اسنادہ ضعیف ۔ مرثد ابن عبداللہ الزمانی راوی مجہول الحال ہے ۔ الضعیفۃ : 3100 ۔ انظر الحدیث الاٰتی ۔"
2170,"ذعشحأوشخزأثۏتىأڬشحەأۄۏڽأڬۄأوۏڽأىەأذعشحأتثًسشأشعۏأتههۄأؼىۄأضەأضًتهأڬۏتأ؏أوۏڽأىەأڬۄتأڬۏتأإځأىەأشضًهأتههۄأ﷽أضەأطثأمزشأڬەأثتشەأوۏڽأضًتهأڬۏتأآأحًأإځأىەألشوتۏتأ=““أوۏڽأضثأهًڲًڽأضەأثڔہأڬشأطثأمزشأڬەأثتشەأوۏڽأضًتهأڬشىەأًتهتأطرظأحہتأۗ‛‛أڬۄحەأۄۏڽأ=أوۏڽأىەأڬۄتأ=أتەأتههۄأڬەأشضًهأ$أودہەأثحتةۏڽأڬۏتأطثأمزشأشوعتىأتهوثتشڬأوۏڽأۄەأۏتأتضأڬەأؼهتًۄأڬضۏأتًشأوۄۏىەأوۏڽأۄەأآأحًأإځأىەألشوتۏتأ=““أثهڬۄأًۄأشوعتىأوۏڽأۄەأۗ‛‛أوۏڽأىەأؼشعأڬۏتأ=““أتەأتههۄأڬەأشضًهأ$أڬۏتأطثأمزشأظشلأتىثۏتةەأڬشتوأڬەأصوتىەأوۏڽأۄًحۏأۄەأ؏أدثأتىثۏتةەأڬشتوألًحأۄًأدتحەأۄۏڽأحًأطثأمزشأثہۏأتټہتأهۏأدتحۏأۄەأآأۏتأۏۄأمۏتوحأحڬأثتمۏأشۄەأڲۏأآأإځأىەألشوتۏتأ=““أىۄۏڽأ؏أثهڬۄأۏۄأمۏتوحأحڬأشۄەأڲۏأۗأوۏڽأىەأځًډہتأ=أتەأتههۄأڬەأشضًهأ$أڬۏتأۏۄأشوعتىأوۏڽأۄەأآأإځأىەألشوتۏتأ=أتضەأځۄهەأتًشأإرشۏأزضأزضأزىًڽأوۏڽأحهتطأڬشًأۗأڬۄحەأۄۏڽأ=أځہشأإځأهًڲًڽأڬًأثۏتىأڬشحەأشۄەأحًأوۏڽأىەأإځأڬۏأثەأزہۏتىۏأضەألتةزۄأتټہتحەأۄًةەأؼشعأڬۏتأ=أتههۄأڬەأشضًهأ$أوۏڽأإځأڬًأمضوأزەأڬشأځًډہحتأۄًڽأڬۄأۏۄأڬىأثۏضأزىًڽأوۏڽأۄەأآأحًأشضًهأتههۄأ﷽أودہأځشأتۏضەأطزۏزأىتشتعأۄًةەأڬۄأتضأدۏضەأىتشتعأىۄأڬثہۏأځۄهەأۄًةەأحہەأىۄأڬثہۏأثؼزأوۏڽأۗأځہشأإځأىەألشوتۏتأ=““أثەأطڬأتڲشأتههۄأحؼتهۏٳأډتۄحتأحًأحوۄۏڽأتضأڬۏأتغهتؼأڬشأزۏحتأ؏أحوأتضەأإرشۏأضتحأزىًڽأوۏڽأحهتطأڬشًأۗ‛‛

[تخریج]: (2170) اسنادہ ضعیف ایضاً : مسند احمد : 5 / 171 ۔ سنن کبرٰی نسائی : 3413 ۔ صحیح ابن حبان : 3683 ۔"
2171,"ذعشحأتثًضؼۏزأرزشۏأشعۏأتههۄأؼىۄأضەأشًتۏحأۄەأڬۄأشضًهأتههۄأ﷽أىەأشوعتىأتهوثتشڬأڬەأځۄهەأزضأزىأتؼحڬتلأڬۏتأۗأځہشأإځأىەأزًضشتأؼطشۄأثہۏأتۏڬأحشڬۏأمثەأوۏڽأتؼحڬتلأڬۏتأ؏أدضأڬەأزشًتصەأځشأتۏڬأډټتةۏأهټڬتةۏأڲةۏأحہۏأۗأإځأىەأتځىەأزضحأوثتشڬأضەأًۄأډټتةۏأځڬڔۏأتًشأتضەأۄټتأڬشأمثەأڬەأڬًىەأوۏڽأشڬہأزۏتأۗأځہشأتځىتأضشأوثتشڬأثتۄشأىڬتهتأتًشأهًڲًڽأضەأثتحأډۏحأڬۏأحًأًۄأإځأڬەأمشۏثأإأڲةەأځضأإځأىەألشوتۏتأ=““أثەأطڬأوۏڽأىەأطثأمزشأڬۏأحهتطأوۏڽأځۄهتأؼطشۄأتؼحڬتلأڬۏتأځہشأوۏڽأىەأزشوۏتىەأؼطشەأوۏڽأثہۏأتؼحڬتلأڬۏتأۗأځہشأرًتثأوۏڽأوۏشەأځتضألشطحۄأإۏتأحًأودہەأثحتۏتأڲۏتأڬۄأطثأمزشأإرشۏأؼطشەأوۏڽأۄەأۗأهۄٳستأدًأطرظأحوأوۏڽأضەأځضىزأڬشەأڬۄأًۄأتؼحڬتلأڬشەأ؏أډىتىډۄأهًڲًڽأىەأإځأڬەأضتحہأ+أإرشۏأؼطشەأڬتأ,أتؼحڬتلأڬۏتأۗأإځأىەألشوتۏتأ=““أثەأطڬأودہەأًۄأغتمأشتحًڽأوۏڽأزڬہتةۏأڲةۏأۄەأتًشأتضأڬۏأظثذأڬًأوۏڽأىەأڬۏډڔأوۏڽأضدزۄأڬۏتأۄەأځہشأدثأإځأىەأتڬۏضًۏڽأشتحأڬۏأظثذأڬۏأتًشأإځأىەأظثذأحڬأىلهأىوتصأتزتأڬۏأحہۏأحًأثتشطأۄًأڲةۏأدضأضەأوضدزأڬۏأډہحأټځڬىەأهڲۏأۗأذعشحأتثًضؼۏزأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأحًأوۏڽأىەأڬۏډڔأزۏڬہتأۗأځہشأدثأإځأظثذأڬۏأىوتصأضەألتشؽأۄًأڬشأىڬهەأحًأإځأڬۏأځۏطتىۏأتًشأىتڬأځشأڬۏډڔأهڲتأۄًتأحہتأتًشأًۄأإرشۏأؼطشەأوۏڽأتڬۏضًۏڽأشتحأحہۏأۗ‛‛أۏۄأذزۏخأىۄتۏحأثهىزأوشحثۄأۄەأۗ‛‛

[تخریج]: (2171) صحیح بخاری ، کتاب فضل لیلۃ القدر ، باب تحری لیلۃ القدر فی الوتر… ، حدیث : 2018 ۔ صحیح مسلم ، کتاب الصیام ، باب فضل لیلۃ القدر ، حدیث : 1167 ۔ سنن ابن ماجہ : 1775 ۔ سنن کبریٰ نسائی : 3334 ۔ مسند احمد : 3 / 171 ۔"
2172,"ذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄوتأثۏتىأڬشحەأۄۏڽأڬۄأذعشحأؼوشأشعۏأتههۄأؼىۄأودہەأوذوزأ﷽أڬەأضتحہۏًڽأڬەأضتحہأثهتحەأحہەأتًشأودہەأذڬوأزۏتأڬۄأتضأًمحأحڬأثتحأىۄأڬشىتأدثأحڬأظذتثۄأڬشتوأثتحأډۏحأىۄأڬشأهۏڽأۗأڬۄحەأۄۏڽأ=أتىۄًڽأىەأظذتثۄأڬشتوأڬًأثهتۏتأتًشأتىأضەأطثأمزشأڬەأثتشەأوۏڽأضًتهأڬۏتأتًشأڬۄتأ=““أشضًهأتههۄأ﷽أڬتأۏۄألشوتىأۄەأڬۄأطثأمزشأڬًأإرشۏأؼطشەأوۏڽأحهتطأڬشًأ‛‛أودہەأثحتاأڬۄأحوۄتشەأرۏتهأوۏڽأۏۄأڬًىأضۏأشتحأۄەأۗأحًأثؼعأىەأڬۄتأ=أۏۄأتڬۏضًۏڽأشتحأۄەأۗأڬډہأىەأڬۄتأ=أحۏضًۏڽأشتحأۄەأتًشأثؼعأىەأځډۏضًۏڽأشتحأمشتشأزۏأۗأتضأزًشتىأوۏڽأرتوًطأشۄتأۗأځہشأتىۄًڽأىەأودہەأڬۄتأ=““أحوأڬۏًڽأىۄۏڽأثحتحەأآأوۏڽأىەأؼشعأڬۏأ=““أتەأتوۏشأتهوًوىۏىأ$أتڲشأإځأودہەأتدتصحأزۏڽأحًأوۏڽأثحتحتأۄًڽأحًأتىۄًڽأىەألشوتۏتأ=““أوۏڽأىەأحوۄۏڽأڲلحڲًأڬشىەأڬەأهۏەأۄۏأثهتۏتأۄەأۗ‛‛أحًأوۏڽأىەأڬۄتأ=أڬۏتأوۏڽأحوۄۏڽأتځىۏأشتةەأضەأثۏتىأڬشًڽأآأذعشحأؼوشأشعۏأتههۄأؼىۄأىەألشوتۏتأ=““أۄوأىەأحوۄتشۏأشتةەأۄۏأځًډہۏأۄەأۗ‛‛أحًأوۏڽأىەأؼشعأڬۏأ=أًۄأضحتةۏضًۏڽأشتحأۄەأۗأوۏڽأىەأزۏڬہتأۄەأڬۄأتههۄأحؼتهۏٳأىەأضتحأإضوتىأ؏أتًشأضتحأصوۏىۏڽأسڬشأڬۏأۄۏڽأۗأتىضتىأڬًأضتحأضەأځۏزتأڬۏتأڲۏتأۄەأتًشأصوۏىۏأىثتحتحأثہۏأضتحأمضوأڬۏأۄۏڽأۗ‛‛أحًأذعشحأؼوشأىەألشوتۏتأ=““أحوأىەأودہەأًۄأډۏصۏڽأثحتةۏأۄۏڽأدًأوۏڽأدتىحتأۄًڽأۗأودہەأًۄأډۏصأثحتاأدًأوۏڽأىۄۏڽأدتىحتأۗأصوۏىۏأىثتحتحأضتحأمضوأڬۏأۄۏڽأ؏أتضأضەأحوۄتشۏأڬۏتأوشتزأۄەأآأوۏڽأىەأؼشعأڬۏتأ=““أثەأطڬأتههۄأحؼتهۏٳألشوتحەأۄۏڽأ=أ®~خْؤّأطّمّمٕىّتأتهٕتّشٕعّأطّمَتأ أًّلّتڬٓہّۆَأًّٔئّثّٔت¾أ+أضًشۅأؼثضأ؏أ59أۗأ64أ,أ““أځہشأۄوأىەأصوۏىأڬًأتډہۏأغشذأځہتڔتأۗأځہشأۄوأىەأتضأوۏڽأتىتدأتڲتۏتأتًشأتىڲًشأتًشأضثصۏتڽأتًشأصۏحًىأتًشأڬہدًشۏڽأتًشأڲہىەأثتؽتحأتًشأوۏًەأتًشأډتشتأۗ‛‛أتًشأ~ئّثُٔأضەأوشتزأًۄأډتشتأۄەأدًأدتىًشأڬہتحەأۄۏڽأتًشأتىضتىأىۄۏڽأڬہتحەأۗأحًأذعشحأؼوشأشعۏأتههۄأؼىۄأىەألشوتۏتأ=““أڬۏتأحوأتضأثډەأڬۏأغشذأثحتىەأضەأثہۏأؼتدصأشۄەأ؏أدضأڬۏأتثہۏأحڬأؼمهأثہۏأځًشۏأىۄۏڽأۄًةۏأۗأتههۄأڬۏأمضوأ$أوۏشۏأشتةەأثہۏأحوۄتشۏأشتةەأڬەأوًتلمأۄەأتًشألشوتۏتأ=أوۏڽأىەأحوۄۏڽأذڬوأزۏتأحہتأڬۄأتىأظذتثۄأڬشتوأڬەأڲلحڲًأڬشأهۏىەأحڬأحوأثتحأىۄأڬشىتأتًشأوۏڽأتثأحوۄۏڽأذڬوأزۏحتأۄًڽأڬۄأحوأتىأڬەأضتحہأۄۏأڲلحڲًأڬۏتأڬشًأۗ‛‛

[تخریج]: (2172) اسنادہ صحیح : مسند احمد : 1 / 14 ، 43 ۔ مستدرک حاکم : 1 / 437 ، 438 ۔"
2173,"ذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄوتأثۏتىأڬشحەأۄۏڽأڬۄأذعشحأؼوشأشعۏأتههۄأؼىۄأتڬتثشأظذتثۄأڬشتوأشعۏأتههۄأؼىۄوأڬەأضتحہأودہأضەأوطًشۄأهۏتأڬشحەأحہەأتًشأودہەألشوتحەأحہەأ=““أدثأحڬأثصشڲأظذتثۄأڬشتوأثتحأډۏحأىۄأڬشأهۏڽأحوأڲلحڲًأىۄأڬشىتأۗ‛‛أحًأذعشحأؼوشأىەأتىأضەأطثٓأمزشأڬەأثتشەأوۏڽأځًډہتأ=““أحًأڬۄتأ=““أۏمۏىتأحوۄۏڽأوؼهًوأۄەأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأۄەأ=““أطثأمزشأڬًأإرشۏأؼطشەأڬۏأغتمأشتحًڽأوۏڽأحهتطأڬشًأۗ‛‛أځہشأتىۄًڽأىەأتثىأؼثتضأشعۏأتههۄأؼىۄأڬتأذعشحأؼوشأشعۏأتههۄأؼىۄأڬەأضتحہأمظۄأثۏتىأڬۏتأۗ‛‛

[تخریج]: (2173) انظر الحدیث السابق ۔"
2174,"ذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄوتأضەأوسڬًشۄأثتهتأڬۏأوخهأوشًۏأۄەأوڲشأتضأوۏڽأۏۄأتهلتػأۄۏڽأ=““أتهئثأ=أتضأڲہتضأتًشأډتشەأڬًأڬۄحەأۄۏڽأدًأډًأځتةەأڬہتحەأۄۏڽأتًشأتىضتىأىۄۏڽأڬہتحەأۗ‛‛

[تخریج]: (2174) انظر الحدیث السابق : 2172 ۔"
2175,"ذعشحأؼثزتهشذوتىأثۏتىأڬشحەأۄۏڽأڬۄأوۏڽأىەأذعشحأتثًثڬشۄأشعۏأتههۄأؼىۄأڬەأځتضأطثأمزشأڬتأحسڬشۄأڬۏتأحًأتىۄًڽأىەألشوتۏتأ=أشضًهأتههۄأ﷽أڬتألشوتىأضىىەأڬەأثؼزأوۏڽأحًأتضەأظشلأإرشۏأؼطشەأوۏڽأحهتطأڬشًڽأڲتأۗأوۏڽأىەأإځأڬًألشوتحەأۄًةەأضىتأ=““أطثأمزشأڬًأإرشۏأؼطشەأوۏڽأحهتطأڬشًأدثأىًأشتحۏڽأثتمۏأشۄأدتةۏڽأۏتأدثأضتحأثتمۏأشۄأدتةۏڽأۏتأځتىډأشۄأدتةۏڽأۏتأحۏىأثتمۏأشۄأدتةۏڽأۏتأإرشۏأشتحأوۏڽأحهتطأڬشًأ‛‛أذعشحأتثًثڬشۄأشعۏأتههۄأؼىۄأځۄهۏأثۏضأشتحًڽأوۏڽأتځىەأضتشەأضتهأڬەأوؼوًهأڬەأوغتثمأىوتصأځڔہحەأحہەأ؏أځہشأدثأإرشۏأؼطشۄأطشًؼأۄًأدتحتأحًأرًثأوذىحأًأشۏتعحأطشًؼأڬشأزۏحەأۗ‛‛

[تخریج]: (2175) اسنادہ حسن : سنن ترمذی ، کتاب الصوم ، باب ما جاء فی لیلۃ القدر ، حدیث : 794 ۔ سنن کبرٰی نسائی : 3389 ۔ مسند احمد : 5 / 36 ۔ صحیح ابن حبان : 3678 ۔"
2176,"ذعشحأتثًضؼۏزأرزشۏأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەأشوعتىأتهوثتشڬأڬەأزشوۏتىۏأؼطشەأوۏڽأتؼحڬتلأڬۏتأتًشأإځأطثأمزشأڬًأحهتطأڬشأشۄەأحہەأدثڬۄأتثہۏأإځأڬەأهۏەأوؼتوهەأڬۏأًعتذحأىۄۏڽأۄًةۏأحہۏأۗأځہشأإځأىەأرۏوەأتڬہتڔىەأڬتأذڬوأزۏتأحًأًۄأتڬہتڔأزةۏەأڲةەأۗأځہشأإځأڬەأهۏەأإرشۏأؼطشەأوۏڽأتضأڬۏأىطتىزۄۏأڬۏأڲةۏأحہۏأحًأإځأىەأذڬوأزۏتأتًشأرۏوەأزًثتشۄأهڲتأزةۏەأڲةەأۗأځہشأإځأۄوتشەأځتضأحطشۏلأهتةەأحًألشوتۏتأ=““أظًشحأذتهأۏۄأۄەأڬۄأودہەأطثأمزشأڬۏأىطتىزۄۏأڬۏأڲةۏأتًشأوۏڽأحوۄۏڽأثحتىەأڬەأهۏەأىڬهتأحًأزًأإزوۏأدہڲڔأشۄەأحہەأحًأودہەأطثأمزشأثہهتأزۏأڲةۏأۗأهۄٳستأحوأتضەأىًۏڽأ؏أضتحًۏڽأتًشأځتىډًۏڽأشتحأوۏڽأحهتطأڬشًأۗ‛‛أدىتثأتثًىعشۄأڬۄحەأۄۏڽأ=أوۏڽأىەأڬۄتأ=أتەأتثًضؼۏزأشعۏأتههۄأؼىۄأ$أثەأطڬأإځأۄوأضەأصۏتزۄأثۄحشأغًشأځشأڲىحۏأدتىحەأۄۏڽأ؏أحًأىًۏڽأ؏أضتحًۏڽأتًشأځتىډًۏڽأشتحأڬًىأضۏأثىحۏأۄەأآأتىۄًڽأىەألشوتۏتأ=أۄتڽأ؏أتًشأۄوأۄۏأتضأڬەأصۏتزۄأذمزتشأۄۏڽأۗأدثأتڬۏضًۏڽأشتحأۄًأحًأتضأڬەأضتحہأًتهۏأشتحأىًۏڽأۄەأۗأځہشأتۏڬأشتحأډہًڔأزًأ؏أځہشأتضأڬەأضتحہأًتهۏأضتحًۏڽأۄەأۗأځہشأتۏڬأشتحأډہًڔأزًأ؏أحًأتضأڬەأثؼزأًتهۏأځتىډًۏڽأۄەأۗأدىۄۏڽأحوأډًثۏضأ؏أډہثۏضأتًشأثتةۏضأڬتأىتوأزۏحەأۄًأۗأ+أتىۄۏڽأډہًڔأزًأ,أۗ

