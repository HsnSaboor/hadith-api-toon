{"hadithnumber": "5334", "text": "زینب رضی اللہ عنہا نے بیان کیا کہ  میں نبی کریم صلی اللہ علیہ وسلم کی زوجہ مطہرہ ام حبیبہ رضی اللہ ع"}
{"hadithnumber": "5335", "text": "زینب رضی اللہ عنہا نے بیان کیا کہ  اس کے بعد میں ام المؤمنین زینب بنت جحش رضی اللہ عنہا کے یہاں اس و"}
{"hadithnumber": "5336", "text": "زینب بنت ام سلمہ رضی اللہ عنہا نے کہا کہ میں نے ام سلمہ رضی اللہ عنہا کو بھی یہ کہتے سنا کہ  ایک خات"}
{"hadithnumber": "5337", "text": "حمید نے بیان کیا کہ میں نے زینب بنت ام سلمہ رضی اللہ عنہا سے پوچھا کہ  اس کا کیا مطلب ہے کہ ”سال بھر"}
{"hadithnumber": "5338", "text": "ہم سے آدم بن ابی ایاس نے بیان کیا، کہا ہم سے شعبہ نے، کہا ہم سے حمید بن نافع نے، ان سے زینب بنت ام س"}
{"hadithnumber": "5339", "text": "اور میں نے زینب بنت ام سلمہ سے سنا، وہ ام حبیبہ سے بیان کرتی تھیں کہ  نبی کریم صلی اللہ علیہ وسلم نے"}
{"hadithnumber": "5340", "text": "ہم سے مسدد نے بیان کیا، کہا ہم سے بشر نے بیان کیا، کہا ہم سے سلمہ بنت علقمہ نے بیان کیا، ان سے محمد"}
{"hadithnumber": "5341", "text": "مجھ سے عبداللہ بن عبدالوہاب نے بیان کیا، کہا ہم سے حماد بن زید نے بیان کیا، ان سے ایوب نے، ان سے حفص"}
{"hadithnumber": "5342", "text": "ہم سے فضل بن دکین نے بیان کیا، کہا ہم سے عبدالسلام بن حرب نے بیان کیا، ان سے ہشام بن حسان نے، ان سے"}
{"hadithnumber": "5343", "text": "امام بخاری رحمہ اللہ کے شیخ انصاری نے بیان کیا کہ ہم سے ہشام بن حسان نے بیان کیا، کہا ہم سے حفصہ بنت"}
{"hadithnumber": "5344", "text": "مجھ سے اسحاق بن منصور نے بیان کیا، کہا ہم کو روح بن عبادہ نے خبر دی، کہا ہم سے شبل بن عباد نے، ان سے"}
{"hadithnumber": "5345", "text": "ہم سے محمد بن کثیر نے بیان کیا، ان سے سفیان ثوری نے بیان کیا، ان سے عبداللہ بن ابی بکر بن عمرو بن حز"}
{"hadithnumber": "5346", "text": "ہم سے علی بن عبداللہ مدینی نے بیان کیا، کہا ہم سے سفیان بن عیینہ نے بیان کیا، ان سے زہری نے، ان سے ا"}
{"hadithnumber": "5347", "text": "ہم سے آدم بن ابی ایاس نے بیان کیا، کہا ہم سے شعبہ بن حجاج نے بیان کیا، کہا ہم سے عون بن ابی جحیفہ نے"}
{"hadithnumber": "5348", "text": "ہم سے علی بن جعد نے بیان کیا، انہوں نے کہا ہم کو شعبہ نے خبر دی، انہیں محمد بن جحادہ نے، انہیں ابوحا"}
{"hadithnumber": "5349", "text": "ہم سے عمرو بن زرارہ نے بیان کیا، کہا ہم کو اسماعیل بن علیہ نے خبر دی، انہیں ایوب سختیانی نے اور ان س"}
{"hadithnumber": "5350", "text": "ہم سے قتیبہ بن سعید نے بیان کیا، کہا ہم سے سفیان بن عیینہ نے بیان کیا، ان سے عمرو بن دینار نے، ان سے"}
