{"hadithnumber": "4911", "text": "ابوایوب انصاری رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  کسی مسلمان کے ل"}
{"hadithnumber": "4912", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  کسی مومن کے لیے درست نہیں"}
{"hadithnumber": "4913", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  کسی مسلمان کے"}
{"hadithnumber": "4914", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  کسی مسلمان کے لیے درست ن"}
{"hadithnumber": "4915", "text": "ابو خراش سلمی رضی اللہ عنہ کہتے ہیں کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  جس نے"}
{"hadithnumber": "4916", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  ہر دوشنبہ اور جمعرات کو ج"}
{"hadithnumber": "4917", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ظن و گمان کے پیچھے پڑنے"}
{"hadithnumber": "4918", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مومن مومن کا آئینہ ہے، ا"}
{"hadithnumber": "4919", "text": "ابو الدرداء رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  کیا میں تمہیں وہ بات"}
{"hadithnumber": "4920", "text": "ام حمید بن عبدالرحمٰن (ام کلثوم) رضی اللہ عنہا کہتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:"}
{"hadithnumber": "4921", "text": "ام کلثوم بنت عقبہ رضی اللہ عنہا کہتی ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو کسی بات میں جھوٹ"}
{"hadithnumber": "4922", "text": "ربیع بنت معوذ بن عفراء رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم میرے پاس اس صبح آئے،"}
{"hadithnumber": "4923", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  جب رسول اللہ صلی اللہ علیہ وسلم مدینے آئے تو حبشی آپ کی آمد پر خوش ہو"}
{"hadithnumber": "4924", "text": "نافع کہتے ہیں کہ  ابن عمر رضی اللہ عنہما نے ایک باجے کی آواز سنی تو اپنی دونوں انگلیاں کانوں میں ڈال"}
{"hadithnumber": "4925", "text": "نافع کہتے ہیں کہ  میں ابن عمر رضی اللہ عنہما کے پیچھے سوار تھا، کہ ان کا گزر ایک چرواہے کے پاس سے ہو"}
{"hadithnumber": "4926", "text": "نافع کہتے ہیں کہ  میں ابن عمر رضی اللہ عنہما کے ساتھ تھا تو آپ نے ایک بانسری بجانے والے کی آواز سنی"}
{"hadithnumber": "4927", "text": "سلام بن مسکین ایک شیخ سے روایت کرتے ہیں  جو ابووائل کے ساتھ ایک ولیمہ میں موجود تھے تو لوگ کھیل کود"}
{"hadithnumber": "4928", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کے پاس ایک ہجڑا لایا گیا جس نے اپنے ہ"}
{"hadithnumber": "4929", "text": "ام المؤمنین ام سلمہ رضی اللہ عنہا کہتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم ان کے ہاں تشریف لائے ان ک"}
{"hadithnumber": "4930", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے زنانے مردوں اور مردانی عو"}
{"hadithnumber": "4931", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  میں گڑیوں سے کھیلا کرتی تھی، کبھی کبھی رسول اللہ صلی ال"}
{"hadithnumber": "4932", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم غزوہ تبوک یا خیبر سے آئے،"}
{"hadithnumber": "4933", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مجھ سے شادی کی، میں سات"}
{"hadithnumber": "4934", "text": "ابواسامہ سے اسی کے ہم مثل مروی ہے  اس میں ہے  ( ان عورتوں نے کہا )  اچھا نصیبہ ہے پھر میری ماں نے مج"}
{"hadithnumber": "4935", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  جب ہم مدینہ آئے، تو میرے پاس کچھ عورتیں آئیں، اس وقت می"}
{"hadithnumber": "4936", "text": "ہشام بن عروہ سے اسی سند سے یہی حدیث مروی ہے  اس میں ہے: میں جھولے پر تھی اور میرے ساتھ میری سہیلیاں"}
{"hadithnumber": "4937", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  ہم مدینہ آئے اور بنی حارث بن خزرج میں اترے، قسم اللہ کی"}
{"hadithnumber": "4938", "text": "ابوموسیٰ اشعری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے چوسر کھیلا ا"}
{"hadithnumber": "4939", "text": "بریدہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جس نے نردشیر  ( چوسر )  کھیل"}
{"hadithnumber": "4940", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک شخص کو دیکھا کہ وہ کبوتری کا"}
{"hadithnumber": "4941", "text": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  رحم کرنے والوں پ"}
{"hadithnumber": "4942", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  میں نے صادق و مصدوق ابوالقاسم صلی اللہ علیہ وسلم کو جو اس کمرے می"}
{"hadithnumber": "4943", "text": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جو ہمارے چھوٹے پ"}
{"hadithnumber": "4944", "text": "تمیم داری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  یقیناً دین خیر خواہی کا"}
{"hadithnumber": "4945", "text": "جریر رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم سے سمع و طاعت پر بیعت کی، اور یہ"}
{"hadithnumber": "4946", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جو شخص کسی مسلمان کی دنیا"}
{"hadithnumber": "4947", "text": "حذیفہ رضی اللہ عنہ کہتے ہیں کہ  تمہارے نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  ہر بھلی بات صدقہ ہے ۱"}
{"hadithnumber": "4948", "text": "ابوالدرداء رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  قیامت کے دن تم اپنے او"}
{"hadithnumber": "4949", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ کے نزدیک سب"}
{"hadithnumber": "4950", "text": "ابو وہب جشمی رضی اللہ عنہ، انہیں شرف صحبت حاصل ہے، کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرما"}
{"hadithnumber": "4951", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  عبداللہ بن ابی طلحہ کی پیدائش پر میں ان کو لے کر نبی اکرم صلی اللہ علی"}
{"hadithnumber": "4952", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے عاصیہ کا نام بدل دیا ۱"}
{"hadithnumber": "4953", "text": "محمد بن عمرو بن عطا سے روایت ہے کہ  زینب بنت ابوسلمہ نے ان سے پوچھا: تم نے اپنی بیٹی کا نام کیا رکھا"}
{"hadithnumber": "4954", "text": "اسامہ بن اخدری تمیمی رضی اللہ عنہ سے روایت ہے کہ  ایک آدمی جسے  اصرم   ( بہت زیادہ کاٹنے والا )  کہا"}
{"hadithnumber": "4955", "text": "ابوشریح ہانی کندی رضی اللہ عنہ سے روایت ہے کہ  جب وہ رسول اللہ صلی اللہ علیہ وسلم کے پاس اپنی قوم کے"}
{"hadithnumber": "4956", "text": "سعید بن مسیب کے دادا (حزن رضی اللہ عنہ) سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے ان سے پوچھا:"}
{"hadithnumber": "4957", "text": "مسروق کہتے ہیں کہ  میں عمر بن خطاب رضی اللہ عنہ سے ملا تو انہوں نے پوچھا: تم کون ہو؟ میں نے کہا: مسر"}
{"hadithnumber": "4958", "text": "سمرہ بن جندب رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم اپنے بچے یا اپنے"}
{"hadithnumber": "4959", "text": "سمرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے منع فرمایا کہ ہم افلح، یسار، نافع اور"}
{"hadithnumber": "4960", "text": "جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اگر اللہ نے چاہا اور میں زند"}
{"hadithnumber": "4961", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  سب سے ذلیل نام والا اللہ"}
{"hadithnumber": "4962", "text": "ابوجبیرہ بن ضحاک کہتے ہیں کہ  ہمارے یعنی بنو سلمہ کے سلسلے میں یہ آیت نازل ہوئی «ولا تنابزوا بالألقا"}
{"hadithnumber": "4963", "text": "اسلم کہتے ہیں کہ  عمر بن خطاب رضی اللہ عنہ نے اپنے ایک بیٹے کو مارا جس نے اپنی کنیت ابوعیسیٰ رکھی تھ"}
{"hadithnumber": "4964", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  نبی کریم صلی اللہ علیہ وسلم نے ان سے فرمایا:  اے میرے بیٹے! ۔"}
{"hadithnumber": "4965", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  میرے نام پر نام رکھو"}
{"hadithnumber": "4966", "text": "جابر رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جو میرا نام رکھے، وہ میری کنی"}
{"hadithnumber": "4967", "text": "محمد بن حنفیہ کہتے ہیں کہ  علی رضی اللہ عنہ نے کہا: میں نے عرض کیا: اللہ کے رسول! اگر آپ کے بعد میرے"}
{"hadithnumber": "4968", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  ایک عورت رسول اللہ صلی اللہ علیہ وسلم کے پاس آئی اور کہ"}
{"hadithnumber": "4969", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ہمارے ہاں آتے تھے، اور میرا ایک چ"}
{"hadithnumber": "4970", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  انہوں نے عرض کیا: اللہ کے رسول! میری تمام سہیلیوں کی"}
{"hadithnumber": "4971", "text": "سفیان بن اسید حضرمی رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا: یہ"}
{"hadithnumber": "4972", "text": "ابومسعود رضی اللہ عنہ نے ابوعبداللہ (حذیفہ) رضی اللہ عنہ سے یا ابوعبداللہ نے ابومسعود سے کہا  نے «زع"}
{"hadithnumber": "4973", "text": "زید بن ارقم رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے انہیں خطبہ دیا تو «أما بعد» کہا"}
{"hadithnumber": "4974", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم میں سے کوئی  ( انگور"}
{"hadithnumber": "4975", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم میں سے کوئی  ( اپنے غ"}
{"hadithnumber": "4976", "text": "اس سند سے بھی ابوہریرہ رضی اللہ عنہ سے یہی حدیث مروی ہے  لیکن اس میں انہوں نے نبی اکرم صلی اللہ علیہ"}
{"hadithnumber": "4977", "text": "بریدہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم لوگ منافق کو سید نہ کہو"}
{"hadithnumber": "4978", "text": "سہل بن حنیف رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم میں سے کوئی میرا ن"}
{"hadithnumber": "4979", "text": "ام المؤمنین عائشہ رضی اللہ عنہا  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  تم میں سے کوئی یہ نہ کہے: م"}
{"hadithnumber": "4980", "text": "حذیفہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  تم یوں نہ کہو: جو اللہ چاہے"}
{"hadithnumber": "4981", "text": "عدی بن حاتم رضی اللہ عنہ سے روایت ہے کہ  ایک خطیب نے نبی اکرم صلی اللہ علیہ وسلم کے پاس خطبہ دیا، تو"}
{"hadithnumber": "4982", "text": "ابوالملیح ایک شخص سے روایت کرتے ہیں کہ  اس نے کہا: میں نبی اکرم صلی اللہ علیہ وسلم کے پیچھے سوار تھا"}
{"hadithnumber": "4983", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم سنو!  ( اور موسیٰ"}
{"hadithnumber": "4984", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  تم پر «أعراب»  ("}
{"hadithnumber": "4985", "text": "سالم بن ابی الجعد کہتے ہیں کہ  ایک شخص نے کہا: کاش میں نماز پڑھ لیتا تو مجھے سکون مل جاتا، مسعر کہتے"}
{"hadithnumber": "4986", "text": "عبداللہ بن محمد بن حنفیہ کہتے ہیں  میں اور میرے والد انصار میں سے اپنے ایک سسرالی رشتہ دار کے پاس اس"}
{"hadithnumber": "4987", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو دین کے علاوہ کسی"}
{"hadithnumber": "4988", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  مدینہ میں ایک بار  ( دشمن کا )  خوف ہوا، رسول اللہ صلی اللہ علیہ وسلم"}
{"hadithnumber": "4989", "text": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم جھوٹ سے بچو،"}
{"hadithnumber": "4990", "text": "معاویہ بن حیدہ قشیری رضی اللہ عنہ کہتے ہیں  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا: تباہی"}
{"hadithnumber": "4991", "text": "عبداللہ بن عامر رضی اللہ عنہ کہتے ہیں کہ  ایک دن میری ماں نے مجھے بلایا اور رسول اللہ صلی اللہ علیہ"}
{"hadithnumber": "4992", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی کریم صلی اللہ علیہ وسلم نے فرمایا:  آدمی کے گنہگار ہونے کے لی"}
{"hadithnumber": "4993", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  حسن ظن حسن عبادت میں"}
{"hadithnumber": "4994", "text": "ام المؤمنین صفیہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم اعتکاف میں تھے، میں ایک رات"}
{"hadithnumber": "4995", "text": "زید بن ارقم رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جب آدمی اپنے بھائی سے"}
{"hadithnumber": "4996", "text": "عبداللہ بن ابو حمساء رضی اللہ عنہ کہتے ہیں کہ  میں نے بعثت سے پہلے نبی اکرم صلی اللہ علیہ وسلم سے ای"}
{"hadithnumber": "4997", "text": "اسماء بنت ابی بکر رضی اللہ عنہما سے روایت ہے کہ  ایک عورت نے کہا: اللہ کے رسول! میری ایک پڑوسن یعنی"}
{"hadithnumber": "4998", "text": "انس رضی اللہ عنہ سے روایت ہے کہ  ایک شخص نبی اکرم صلی اللہ علیہ وسلم کے پاس آیا اور اس نے عرض کیا: ا"}
{"hadithnumber": "4999", "text": "نعمان بن بشیر رضی اللہ عنہما کہتے ہیں کہ  ابوبکر رضی اللہ عنہ نے نبی اکرم صلی اللہ علیہ وسلم سے اندر"}
{"hadithnumber": "5000", "text": "عوف بن مالک اشجعی رضی اللہ عنہ کہتے ہیں کہ  میں غزوہ تبوک میں رسول اللہ صلی اللہ علیہ وسلم کے پاس آی"}
{"hadithnumber": "5001", "text": "عثمان بن ابی العاتکہ کہتے ہیں کہ  انہوں نے جو یہ پوچھا کہ کیا پورے طور پر اندر آ جاؤں تو اس وجہ سے ک"}
{"hadithnumber": "5002", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  مجھ سے رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اے دو کانوں والے! ۔"}
{"hadithnumber": "5003", "text": "یزید بن سعید رضی اللہ عنہ کہتے ہیں کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  تم میں"}
{"hadithnumber": "5004", "text": "عبدالرحمٰن بن ابی لیلیٰ سے روایت ہے کہ  ہم سے صحابہ کرام رضی اللہ عنہم نے بیان کیا کہ وہ لوگ نبی اکر"}
{"hadithnumber": "5005", "text": "عبداللہ بن عمرو رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ تعالیٰ"}
{"hadithnumber": "5006", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو کوئی باتوں کو گھما"}
{"hadithnumber": "5007", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  دو آدمی ۱؎ پورب سے آئے تو ان دونوں نے خطبہ دیا، لوگ حی"}
{"hadithnumber": "5008", "text": "ابوظبیہ کا بیان ہے کہ عمرو بن العاص نے ایک دن کہا  اور  ( اس سے پہلے )  ایک شخص کھڑے ہو کر بے تحاشہ"}
{"hadithnumber": "5009", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم میں سے کسی کے لیے اپن"}
{"hadithnumber": "5010", "text": "ابی بن کعب رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  بعض اشعار دانائی پر مبن"}
{"hadithnumber": "5011", "text": "ابن عباس رضی اللہ عنہما کہتے ہیں کہ  ایک اعرابی نبی اکرم صلی اللہ علیہ وسلم کی خدمت میں حاضر ہوا اور"}
{"hadithnumber": "5012", "text": "بریدہ رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  بعض بیان یعنی گف"}
{"hadithnumber": "5013", "text": "سعید بن المسیب کہتے ہیں کہ  عمر رضی اللہ عنہ حسان رضی اللہ عنہ کے پاس سے گزرے، وہ مسجد میں شعر پڑھ ر"}
