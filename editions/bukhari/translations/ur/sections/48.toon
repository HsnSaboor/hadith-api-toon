{"hadithnumber": "2508", "text": "ہم سے مسلم بن ابراہیم نے بیان کیا، کہا ہم سے ہشام دستوائی نے بیان کیا، کہا ہم سے قتادہ نے بیان کیا،"}
{"hadithnumber": "2509", "text": "ہم سے مسدد نے بیان کیا، انہوں نے کہا ہم سے عبدالواحد بن زیاد نے بیان کیا، انہوں نے کہا کہ ہم سے اعمش"}
{"hadithnumber": "2510", "text": "ہم سے علی بن عبداللہ نے بیان کیا، کہا ہم سے سفیان بن عیینہ نے بیان کیا کہ عمرو بن دینار نے بیان کیا"}
{"hadithnumber": "2511", "text": "ہم سے ابونعیم نے بیان کیا، کہا کہ ہم سے زکریا بن ابی زائدہ نے بیان کیا، ان سے عامر شعبی نے اور ان سے"}
{"hadithnumber": "2512", "text": "ہم سے محمد بن مقاتل نے بیان کیا، کہا ہم کو عبداللہ بن مبارک نے خبر دی، انہیں زکریا نے خبر دی، انہیں"}
{"hadithnumber": "2513", "text": "ہم سے قتیبہ بن سعید نے بیان کیا، کہا ہم سے جریر نے بیان کیا، ان سے اعمش نے، ان سے ابراہیم نے، ان سے"}
{"hadithnumber": "2514", "text": "ہم سے خلاد بن یحییٰ نے بیان کیا، کہا ہم سے نافع بن عمر نے بیان کیا، ان سے ابن ابی ملیکہ نے کہ  میں ن"}
{"hadithnumber": "2515", "text": "ہم سے قتیبہ بن سعید نے بیان کیا، کہا ہم سے جریر نے بیان کیا، ان سے منصور نے، ان سے ابووائل نے کہ عبد"}
