metadata:

hadiths[39]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
7523,"معمر نے ہمام بن منبہ سے حدیث بیان کی ، کہا : یہ احادیث ہیں جو حضرت ابو ہریرۃ رضی اللہ تعالیٰ عنہ   ن",,,,,7523
7524,"ابن شہاب سے  روایت ہے  ، کہا : مجھے حضرت انس بن مالک رضی اللہ تعالیٰ عنہ   نے خبر دی کہ اللہ عزوجل ن",,,,,7524
7525,سفیان نے قیس بن مسلم سے اور انھوں نے طارق بن شہاب سے روایت کی کہ یہودیوں نے حضرت عمر رضی اللہ تعالیٰ,,,,,7525
7526,عبداللہ بن ادریس نے اپنے والد سے ، انھوں نے قیس بن مسلم سے اور انھوں نے طارق بن شہاب سے روایت کی ، ک,,,,,7526
7527,"ابو عمیس نے قیس بن مسلم سے اور انھوں نے طارق بن شہاب سے روایت کی  ، کہا : یہودیوں میں سے ایک شخص حضر",,,,,7527
7528,"یونس نے ابن شہاب سے روایت کی ، انھوں نے کہا : مجھے عروہ بن زبیر نے خبر دی کہ انھوں نے حضرت عائشہ رضی",,,,,7528
7529,"صالح نے ابن شہاب سے روایت کی ، کہا : مجھے عروہ نے بتایاکہ انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عنہا  ",,,,,7529
7530,"ابو اسامہ نے کہا : ہمیں ہشام نے اپنے والد  ( عروہ  ) سے حدیث بیان کی ،  انھوں نے حضرت عائشہ رضی اللہ",,,,,7530
7531,"عبدہ بن سلیمان نے ہشام سے انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عنہا    سے اللہ عزوجل کے فرمان :  "" جو",,,,,7531
7532,"ابو اسامہ نے کہا : ہمیں ہشام نے اپنے والد سے خبر دی انھوں نے اس عزوجل کے فرمان :  "" اور یہ لوگ آپ سے",,,,,7532
7533,عبد ہ بن سلیمان نے ہشام  ( بن عروہ ) سے انھوں نے اپنے والد سے اور انھوں نے حضرت عائشہ رضی اللہ تعالی,,,,,7533
7534,"ابو اسامہ نے کہا : ہمیں ہشام نے اپنے والد سے حدیث بیان کی ،  انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عنہ",,,,,7534
7535,"ابن نمیر نے کہا : ہمیں ہشام نے اسی سند کے ساتھ  ( یہی ) حدیث بیان کی ۔",,,,,7535
7536,"عروہ نے حضرت عائشہ رضی اللہ تعالیٰ عنہا    سے اس  ( اللہ )  عزوجل کے فرمان  :  "" جب کافرتم پر چڑھ آئ",,,,,7536
7537,"عبد ہ بن سلیمان نے کہا : ہمیں ہشام  ( ابن عروہ )  نے اپنے والدسے اور انھوں نے حضرت عائشہ رضی اللہ تع",,,,,7537
7538,"ابو اسامہ نے کہا : ہمیں ہشام بن عروہ نے اپنے والد سے بیان کیا انھوں نے حضرت عائشہ  رضی اللہ تعالیٰ ع",,,,,7538
7539,"ابو معاویہ نے ہشام بن عروہ سے اور انھوں نے اپنے والد سے روایت کی ،  انھوں نے کہا : مجھ سے حضرت عائشہ",,,,,7539
7540,"ابو اسامہ نے کہا :  ہمیں ہشام نے اسی سند کے ساتھ اسی کے مانند روایت کی ۔",,,,,7540
7541,"معاذ عنبری نے کہا : ہمیں شعبہ نے مغیرہ بن نعمان سے حدیث بیان کی انھوں نے حضرت سعید بن جبیر رضی اللہ ",,,,,7541
7542,"محمد بن جعفر اور نضر بن شمیل دونوں نے کہا : ہمیں شعبہ نے اسی سند کے ساتھ حدیث بیان کی ۔ ابن جعفر کی ",,,,,7542
7543,"منصور نے حضرت سعید بن جبیر رضی اللہ تعالیٰ عنہ   سے روایت کی کہا :  مجھ سے عبد الرحمٰن بن ایزدی نے ک",,,,,7543
7544,ابو معاویہ شیبان نے منصور بن معتمر سے انھوں نے سعید بن جیبر سے اور انھوں نے حضرت ابن عباس رضی اللہ ت,,,,,7544
7545,"عبد اللہ بن ہاشم اور عبد الرحمٰن بن بشر عبدی نے مجھے حدیث بیان کی دونوں نے کہا :  ہمیں یحییٰ بن سعید",,,,,7545
7546,"ابو بکر بن ابی شیبہ ہارون بن عبد اللہ اور عبد بن حمید نے ہمیں ھدیث بیان کی ،  عبد نے کہا :   ہمیں خب",,,,,7546
7547,"ابو معاویہ نے کہا :  ہمیں ابو عمیس نے اسی سند کے ساتھ اسی کے مانند روایت کی اور کہا :   "" آخری سورت ",,,,,7547
7548,"عطاء نے حضرت ابن عباس رضی اللہ تعالیٰ عنہ   سے روایت کی کہا :  مسلمانوں میں سے کچھ لوگ ایک شخص کو کو",,,,,7548
7549,"ابو اسحاق سے روایت ہے کہا :  میں نے حضرت براء بن عازب  رضی اللہ تعالیٰ عنہ   کو کہتے ہوئے سنا :  انص",,,,,7549
7550,"عون بن عبداللہ کے والد سے روایت ہے کہ حضرت ابن مسعود رضی اللہ تعالیٰ عنہ   نےکہا : ہمارے اسلام لانے ",,,,,7550
7551,"حضرت ابن عباس رضی اللہ تعالیٰ عنہ   سے روایت ہے   ، کہا :  ( جاہلی دور میں )  ایک عورت برہنہ ہوکر بی",,,,,7551
7552,"ابو معاویہ نے کہا : ہمیں اعمش نے ابو سفیان سے حدیث بیان کی ، انھوں نے حضرت جابر رضی اللہ تعالیٰ عنہ ",,,,,7552
7553,ابو عوانہ نے اعمش سے  ، انھوں نے ابو سفیان سے اور انھوں نے حضرت جابر رضی اللہ تعالیٰ عنہ   سے روایت ,,,,,7553
7554,عبداللہ بن ادریس نے اعمش سے ، انھوں نے ابراہیم سے ، انھوں نے ابو معمر سے اور انھوں نے حضرت عبداللہ ب,,,,,7554
7556,شعبہ نے سلیمان ( اعمش )  سے اسی سندکے ساتھ یہی  روایت کی ۔,,,,,7556
7558,"ابو بشر نے سعید بن  جبیر سے روایت کی ، کہا :  کہ میں نے سیدنا ابن عباس رضی اللہ عنہما سے کہا کہ سورۃ",,,,,7558
7559,علی بن مسہر نے ابو حیان سے ، انھوں نے شعبی سے اور انھوں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ   سے روا,,,,,7559
7560,"ابن ادریس نے کہا : ہمیں ابو حیان نے شعبی سے حدیث بیان کی ۔ انھوں نے حضرت عبداللہ بن عمر رضی اللہ تعا",,,,,7560
7561,اسماعیل بن علیہ اور عیسیٰ بن یونس دونوں نے ابوحیان سے اسی سند کے ساتھ ان دونوں کی حدیث کے مانند روای,,,,,7561
7562,"ہشیم نے ابو ہاشم سے ، انھوں نے ابو مجلز سے اور انھوں نے قیس بن عباد سے روایت کی ، کہا : میں نے حضرت ",,,,,7562
7563,"سفیان نے ابو ہاشم سے  ، انھوں نے ابو مجلز سے ، انھوں نے قیس بن عباد سے روایت کی  ، کہا : میں نے حضرت",,,,,7563
