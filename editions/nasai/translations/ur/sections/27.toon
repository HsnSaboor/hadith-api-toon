{"hadithnumber": "3537", "text": "مسور بن مخرمہ رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے سبیعہ رضی اللہ عنہا کو اپن"}
{"hadithnumber": "3538", "text": "ابوسنابل رضی الله عنہ کہتے ہیں کہ  سبیعہ اسلمیہ رضی اللہ عنہا کے شوہر کو مرے ہوئے ۲۳ یا ۲۵ راتیں گزر"}
{"hadithnumber": "3539", "text": "ابوسلمہ کہتے ہیں کہ  ابوہریرہ اور ابن عباس رضی اللہ عنہم میں اس عورت کی عدت کے بارے میں اختلاف ہو گی"}
{"hadithnumber": "3540", "text": "ابوسلمہ کہتے ہیں کہ  ابن عباس اور ابوہریرہ رضی اللہ عنہم سے اس عورت  ( کی عدت )  کے بارے میں پوچھا گ"}
{"hadithnumber": "3541", "text": "ابوسلمہ بن عبدالرحمٰن کہتے ہیں کہ  ابن عباس رضی اللہ عنہما سے ایسی عورت کے متعلق پوچھا گیا جس نے اپن"}
{"hadithnumber": "3542", "text": "سلیمان بن یسار سے روایت ہے، ابوہریرہ، ابن عباس (رضی الله عنہم) اور ابوسلمہ بن عبدالرحمٰن نے  اس عورت"}
{"hadithnumber": "3543", "text": "ام المؤمنین ام سلمہ رضی الله عنہا کہتی ہیں کہ  سبیعہ رضی اللہ عنہا نے اپنے شوہر کے انتقال کے کچھ دنو"}
{"hadithnumber": "3544", "text": "سلیمان بن یسار سے روایت ہے کہ  عبداللہ بن عباس رضی اللہ عنہما اور ابوسلمہ بن عبدالرحمٰن کے درمیان اس"}
{"hadithnumber": "3545", "text": "ابوسلمہ بن عبدالرحمٰن کہتے ہیں کہ  میں، ابن عباس اور ابوہریرہ رضی اللہ عنہم  ( سب )  ساتھ میں تھے، ا"}
{"hadithnumber": "3546", "text": "ابوسلمہ بن عبدالرحمٰن سے روایت ہے کہ  زینب بنت ابی سلمہ نے اپنی ماں ام المؤمنین ام سلمہ رضی اللہ عنہ"}
{"hadithnumber": "3547", "text": "ابوسلمہ بن عبدالرحمٰن کہتے ہیں کہ  ۔ ( ایک روز )  میں اور ابوہریرہ رضی اللہ عنہ دونوں ابن عباس رضی ا"}
{"hadithnumber": "3548", "text": "عبیداللہ بن عبداللہ کا بیان ہے کہ  ان کے باپ عبداللہ  ( عبداللہ بن عتبہ )  نے عمر بن عبداللہ بن ارقم"}
{"hadithnumber": "3549", "text": "زفر بن اوس بن حدثان نصری بیان کرتے ہیں کہ  ابوسنابل بن بعکک بن سباق رضی اللہ عنہ نے سبیعہ اسلمیہ رضی"}
{"hadithnumber": "3550", "text": "عبیداللہ بن عبداللہ سے روایت ہے کہ  عبداللہ بن عتبہ نے عمر بن عبداللہ بن ارقم زہری کو لکھا کہ تم سبی"}
{"hadithnumber": "3551", "text": "محمد بن سیرین کہتے ہیں کہ  میں کوفہ میں انصار کی ایک بڑی مجلس میں لوگوں کے درمیان بیٹھا ہوا تھا، اس"}
{"hadithnumber": "3552", "text": "علقمہ بن قیس سے روایت ہے کہ  ابن مسعود رضی اللہ عنہما نے کہا: جو کوئی مجھ سے مباہلہ کرنا چاہے میں اس"}
{"hadithnumber": "3553", "text": "عبداللہ بن مسعود رضی الله عنہ سے روایت ہے کہ  نسائی  ( یعنی طلاق )  کی چھوٹی سورۃ البقرہ کی  ( بڑی )"}
{"hadithnumber": "3554", "text": "عبداللہ بن مسعود رضی الله عنہ سے روایت ہے کہ  ان سے ایک ایسے آدمی کے متعلق پوچھا گیا جس نے کسی عورت"}
{"hadithnumber": "3555", "text": "ام المؤمنین عائشہ رضی الله عنہا سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”کسی عورت کے"}
{"hadithnumber": "3556", "text": "ام المؤمنین عائشہ رضی الله عنہا سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”کسی عورت کے"}
{"hadithnumber": "3557", "text": "ام المؤمنین ام حبیبہ رضی الله عنہا کہتی ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو اسی منبر سے ف"}
{"hadithnumber": "3558", "text": "فارعہ بنت مالک رضی الله عنہا سے روایت ہے کہ  ان کے شوہر  ( بھاگے ہوئے )  غلاموں کی تلاش میں نکلے  ("}
{"hadithnumber": "3559", "text": "فریعہ بنت مالک رضی الله عنہا سے روایت ہے کہ  ان کے شوہر نے کچھ غلام اپنے یہاں کام کرانے کے لیے اجرت"}
{"hadithnumber": "3560", "text": "فریعہ بنت مالک رضی الله عنہا کہتی ہیں کہ  ہمارے شوہر اپنے  ( بھاگے ہوئے کچھ )  غلاموں کی تلاش میں نک"}
