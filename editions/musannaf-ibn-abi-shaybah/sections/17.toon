hadiths[45]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}:
24713,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ الْعُکْلِیُّ ، عَنْ حُسَیْنِ بْنِ وَاقِدٍ ، عَنِ ابْنِ بُرَیْدَۃَ ، عَنْ أَبِیہِ ، قَالَ : عَقَّ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الْحَسَنِ وَالْحُسَیْنِ۔ (نسائی 4539۔ احمد 5/355)",,,24713,,
24714,"حَدَّثَنَا شَبَابَۃُ ، قَالَ : حدَّثَنَا مُغِیرَۃُ بْنُ مُسْلِمٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : عَقَّ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الْحَسَنِ وَالْحُسَیْنِ۔ (ابویعلی 1929۔ طبرانی 2573)",,,24714,,
24715,"حَدَّثَنَا أَبُو خَالِدٍ، وَیَعْلَی بْنُ عُبَیْدٍ، عَنْ یَحْیَی بْنِ سَعِیدٍ، عَنْ عِکْرِمَۃَ، قَالَ: عُقَّ عَنِ الْحَسَنِ وَالْحُسَیْنِ۔",,,24715,,
24716,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی بَکْرٍ ، عَنْ مُحَمَّدِ بْنِ عَلِیِّ بْنِ حُسَیْنٍ ، عَنْ عَلِیٍّ ، قَالَ : عَقَّ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الْحَسَنِ بِشَاۃٍ ،فَقَالَ : یَا فَاطِمَۃُ ، اِحْلِقِی رَأْسَہُ وَتَصَدَّقِی بِزِنَۃِ شَعْرِہِ ، فَوَزَنُوہُ فَکَانَ وَزْنُہُ دِرْہَمًا ، أَوْ بَعْضَ دِرْہَمٍ۔ (ترمذی 1519۔ مالک 2)",,,24716,,
24717,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللہِ الأَسَدِیُّ ، عَنْ شَرِیکٍ ، عَنِ ابْنِ عَقِیلٍ ، عَنْ عَلِیِّ بْنِ الْحُسَیْنِ ، عَنْ أَبِی رَافِعٍ ، قَالَ : قالَتْ فَاطِمَۃُ : یَا رَسُولَ اللہِ ، أَلاَ أَعُقَّ عَنِ ابْنِی دَمًا ، قَالَ : لاَ ، احْلِقِی رَأْسَہُ وَتَصَدَّقِی بِوَزْنِہِ عَلَی الْمَسَاکِینِ أَوَاقِی مِنْ وَرِقٍ ، أَوْ فِضَّۃٍ۔ (احمد 6/390۔ طبرانی 917)",,,24717,,
24718,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنْ مُحَمَّدٍ ، قَالَ : لَوْ أَعْلَمُ أَنَّہُ لَمْ یُعَقَّ عَنِّی ، لَعَقَقْتُ عَنْ نَفْسِی۔",,,24718,,
24719,"حَدَّثَنَا ابْنُ فُضَیْلٍ، عَنْ یَحْیَی بْنِ سَعِیدٍ، عَنْ مُحَمَّدِ بْنِ إِبْرَاہِیمَ، قَالَ: کَانَ یُؤْمَرُ بِالْعَقِیقَۃِ وَلَوْ بِعُصْفُورٍ۔ (بیہقی 71)",,,24719,,
24720,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، عَنْ سَمُرَۃََ ، عَنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : الْغُلاَمُ رَہِینَۃٌ بِعَقِیقَتِہِ ، یُذْبَحُ عَنْہُ۔ (ابوداؤد 2831۔ ترمذی 1522)",,,24720,,
24721,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ ہِشَامٍ ، عَنْ حَفْصَۃَ ابْنَۃِ سِیرِینَ ، عَنْ سَلْمَانَ بْنِ عَامِرٍ ؛ أَنَّہُ سَمِعَ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : إِنَّ مَعَ الْغُلاَمِ عَقِیقَتُہُ ، فَأَرِیقُوا عَنْہُ دَمًا ، وَأَمِیطُوا عَنْہُ الأَذَی۔\n\n(ابن ماجہ 3164۔ احمد 4/17)",,,24721,,
24722,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، عْن رَجُلٍ مِنْ بَنِی ضَمْرَۃَ ، عَنْ أَبِیہِ ، قَالَ : سُئِلَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الْعَقِیقَۃِ ؟ فَقَالَ : لاَ یُحِبّ اللَّہُ الْعُقُوقَ ، مَنْ وُلِدَ لَہُ مِنْکُمْ وَلَدٌ ، فَأَحَبَّ أَنْ یَنْسُکَ عَنْہُ فَلْیَفْعَلْ۔ (مالک 500)",,,24722,,
24723,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ، عَنْ عُبَیْدِاللہِ بْنِ أَبِی یَزِیدَ، عَنْ أَبِیہِ، عَنْ سَبَّاعِ بْنِ ثَابِتٍ، عَنْ أُمِّ کُرْزٍ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : عَنِ الْغُلاَمِ شَاتَانِ مُکَافِئَتَانِ ، وَعَنِ الْجَارِیَۃِ شَاۃٌ ، لاَ یَضُرُّکُمْ إِنَاثًا کُنَّ أَمْ ذُکْرَانًا۔\n\n(ابوداؤد 2829۔ ترمذی 1516)",,,24723,,
24724,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ عَطَائٍ ، عَنْ حَبِیبَۃَ بِنْتِ مَیْسَرَۃَ ، عَنْ أُمِّ کُرْزٍ ؛ سَمِعَتْ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : عَنِ الْغُلاَمِ شَاتَانِ مُکَافِأَتَانِ ، وَعَنِ الْجَارِیَۃِ شَاۃٌ۔ (احمد 6/422۔ دارمی 1966)",,,24724,,
24725,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ أَسْلَمَ ، عْن عَطَائٍ ؛ أَنَّ أُمَّ السِّبَاعِ سَأَلَتْ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَعُقَّ عَنْ أَوْلاَدِی ؟ قَالَ : نَعَمْ ، عَنِ الْغُلاَمِ شَاتَانِ ، وَعَنِ الْجَارِیَۃِ شَاۃٌ۔",,,24725,,
24726,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ یَزِید ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : عَنِ الْغُلاَمِ شَاتَانِ ، وَعَنِ الْجَارِیَۃِ شَاۃٌ۔",,,24726,,
24727,"حَدَّثَنَا وَکِیعٌ ، عَنْ دَاوُدَ بْنِ قَیْسٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، قَالَ : سُئِلَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الْعَقِیقَۃِ ؟ فَقَالَ : لاَ أُحِبُّ الْعُقُوقَ ، مَنْ وُلِدَ لَہُ مَوْلُودٌ ، فَأَحَبَّ أَنْ یَنْسُکَ عَنْہُ فَلْیَفْعَلْ؛ عَنِ الْغُلاَمِ شَاتَانِ ، وَعَنِ الْجَارِیَۃِ شَاۃٌ۔ (ابوداؤد 2835۔ احمد 2/185)",,,24727,,
24728,"حَدَّثَنَا شِہَابُ بْنُ مُحَمَّدٍ الْغَاضِرِیُّ ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنْ مُجَاہِدٍ ، قَالَ : فِی الْعَقِیقَۃِ شَاتَانِ مُکَافِأَتَانِ ، وَعَنِ الْجَارِیَۃِ شَاۃٌ۔",,,24728,,
24729,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ عَبْدِ اللہِ بْنِ عُثْمَانَ ، عَنْ یُوسُفَ بْنِ مَاہِکٍ ، عَنْ حَفْصَۃَ بِنْتِ عَبْدِ الرَّحْمَنِ ، عَنْ عَائِشَۃَ ؛ أَنَّہَا قَالَتْ : أَمَرَنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ نَعُقَّ عَنِ الْغُلاَمِ شَاتَانِ ، وَعَنِ الْجَارِیَۃِ شَاۃً۔ (ترمذی 1513۔ احمد 6/158)",,,24729,,
24730,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، عَنْ عَائِشَۃَ ، أَنَّہَا قَالَتْ : السُّنَّۃُ عَنِ الْغُلاَمِ شَاتَانِ مُکَافِأَتَانِ ، وَعَنِ الْجَارِیَۃِ شَاۃٌ۔",,,24730,,
24731,"حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنْ أَیُّوبَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ؛ أَنَّہُ کَانَ یَقُولُ: عَنِ الْجَارِیَۃِ وَعَنِ الْغُلاَمِ، شَاۃٌ، شَاۃٌ۔",,,24731,,
24732,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سَعِیدٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یَعُقُّ عَنِ الْغُلاَمِ وَالْجَارِیَۃِ ، شَاۃً ، شَاۃً۔,,,24732,,
24733,حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یَعُقُّ عَنِ الْغُلاَمِ وَالْجَارِیَۃِ شَاۃً ، شَاۃً۔,,,24733,,
24734,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ یَزِیدَ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : شَاۃً ، شَاۃً۔",,,24734,,
24735,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، قَالَ : ہُمَا سَوَائٌ۔",,,24735,,
24736,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ؛ أَنَّہُ کَانَ یَقُولُ فِی الْعَقِیقَۃِ : یُعَقُّ عَنِ الْغُلاَمِ وَالْجَارِیَۃِ ، شَاۃً ، شَاۃً۔",,,24736,,
24737,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، عَنْ سَمُرَۃََ ، عَنْ نَبِیِّ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : یُذْبَحُ عَنْہُ یَوْمَ السَّابِعِ ، وَیُحْلَقُ رَأْسُہُ وَیُسَمَّی۔",,,24737,,
24738,حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَمَرَ بِالْعَقِیقَۃِ یَوْمَ السَّابِعِ لِلْمَوْلُودِ ، وَوَضْعِ الأَذَی ، وَتَسْمِیَتِہِ۔,,,24738,,
24739,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ أَبِیہِ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : کَانَ لاَ یَرَی بَأْسًا أَنْ یُعَقَّ قَبْلَ السَّابِعِ ، أَوْ بَعْدَہُ ، وَکَانَ یَقُولُ : اجْعَلْ لَحْمَ الْعَقِیقَۃِ کَیْفَ شِئْتَ۔",,,24739,,
24740,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ قَالَ : فِی الْعَقِیقَۃِ شَاۃٌ مُسِنَّۃٌ ، تُذْبَحُ عَنْہُ یَوْمَ سَابِعِہِ، وَیُحْلَقُ رَأْسُہُ ، وَیُسَمَّی۔",,,24740,,
24741,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ عَبْدِ الْمَلِکِ بْنِ أَبِی سُلَیْمَانَ ، عَنْ عَبْدِ الْمَلِکِ بْنِ أَعْیَنَ ، عَنْ أَبِی جَعْفَرٍ، قَالَ : کَانَتْ فَاطِمَۃُ تَعُقُّ عَنْ وَلَدِہَا یَوْمَ السَّابِعِ ، وَتُسَمِّیہِ ، وَتَخْتِنُہُ ،وَتَحْلِقُ رَأْسَہُ ، وَتَتَصَدَّقُ بِوَزْنِہِ وَرِقًا۔",,,24741,,
24742,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا عَبْدُ الْوَارِثِ ، قَالَ : حَدَّثَنَا عَطَائُ بْنُ السَّائِبِ ، عَنْ مُحَارِبِ بْنِ دِثَارٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ فِی الْعَقِیقَۃِ : تُذْبَحُ عَنْہُ یَوْمَ السَّابِعِ ، وَیُحْلَقُ رَأْسُہُ ، وَیُتَصَدَّقُ بِوَزْنِ شَعْرِہِ فِضَّۃً ، وَیُلَطَّخُ رَأْسُہُ بِالدَّمِ۔",,,24742,,
24743,"حَدَّثَنَا عَبْدُ اللہِ بْنُ مُبَارَکِ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَابْنِ سِیرِینَ ؛ أَنَّہُمَا کَانَا یَکْرَہَانِ مِنَ الْعَقِیقَۃِ مَا یَکْرَہَانِ مِنَ الأُضْحِیَّۃِ ، قَالَ : وَہِیَ عِنْدَہُمَا بِمَنْزِلَۃِ الأُضْحِیَّۃِ ، یَأْکُلُ وَیُطْعِمُ۔",,,24743,,
24744,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إِدْرِیسَ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، عَنْ عَائِشَۃَ ، قَالَتْ: تُجْعَلُ جُدُولاً، فَیُطْبَخُ، فَیَأْکُلُ وَیُطْعِمُ۔",,,24744,,
24745,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَمَرَ بِالْعَقِیقَۃِ الَّتِی عَقَّتْہَا فَاطِمَۃُ عَنِ الْحَسَنِ وَالْحُسَیْنِ ، یَبْعَثُوا إِلَی الْقَابِلَۃِ مِنْہَا بِرِجْلٍ ، قَالَ : وَلاَ یُکْسَرُ مِنْہَا عَظْمٌ۔\n\n(ابوداؤد 379)",,,24745,,
24746,"حَدَّثَنَا عَبْدَۃُ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، عَنْ عَائِشَۃَ ، قَالَتْ : تُطْبَخُ جُدُولاً ، وَلاَ یُکْسَرُ مِنْہَا عَظْمٌ۔",,,24746,,
24747,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : سَأَلْتُہُ عَنِ الْعَقِیقَۃِ ؟ فَقَالَ : لاَ تُکْسَرُ عِظَامُہَا وَرَأْسُہَا ، وَلاَ یُمَسّ الصَّبِیّ بِشَیْئٍ مِنْ دَمِہَا۔",,,24747,,
24748,"حَدَّثَنَا وَکِیعٌ، عَنِ النَّہَّاسِ بْنِ قَہْمٍ، قَالَ: سَمِعْتُ عَطَائً یَقُولُ: کَانُوا یَسْتَحِبُّونَ أَنْ لاَ یُکْسَرَ لِلْعَقِیقَۃِ عَظْمٌ۔",,,24748,,
24749,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَام ، عَنِ الْحَسَنِ ، وَمُحَمَّدٍ ؛ أَنَّہُمَا کَرِہَا أَنْ یُلَطَّخَ رَأْسُ الصَّبِیِّ بِشَیْئٍ مِنْ دَمِ الْعَقِیقَۃِ ، وَقَالَ الْحَسَنُ : الدَّمُ رِجْسٌ۔",,,24749,,
24750,"حَدَّثَنَا عُثْمَانُ بْنُ مَطَرٍ، عَنْ ہِشَامٍ، عَنِ الْحَسَنِ، قَالَ: إِذَا ضَحَّوا عَنِ الْغُلاَمِ فَقَدْ أَجْزَأَتْ عَنِ الْعَقِیقَۃِ۔",,,24750,,
24751,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ ہِشَامٍ، عَنِ الْحَسَنِ، وَابْنِ سِیرِینَ، قَالاَ: تُجْزِئُ عَنْہُ مِنَ الْعَقِیقَۃِ الأُضْحِیَّۃُ۔",,,24751,,
24752,"حَدَّثَنَا عُثْمَانُ بْنُ مَطَرٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، قَالَ : لاَ تُجْزِئُ عَنْہُ حَتَّی یُعَقَّ عَنْہُ۔",,,24752,,
24753,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا ہِشَامٌ الدَّسْتَوَائِیُّ ، عَنْ قَتَادَۃَ ، قَالَ : یُسَمِّی عَلَی الْعَقِیقَۃِ کَمَا یُسَمِّی عَلَی الأُضْحِیَّۃِ : بِسْمِ اللہِ ، عَقِیقَۃُ فُلاَنٍ۔",,,24753,,
24754,"حَدَّثَنَا عُثْمَانُ بْنُ مَطَرٍ ، عَنْ سَعِیدٍ ، قَالَ : سُئِلَ قَتَادَۃُ: کَیْفَ تُنْحَرُ الْعَقِیقَۃُ ؟ قَالَ : یَسْتَقْبِلُ بِہَا الْقِبْلَۃَ ، ثُمَّ یَضَعُ الشَّفْرَۃَ عَلَی حَلْقِہَا ، ثُمَّ یَقُولُ: اللَّہُمَّ مِنْکَ وَلَکَ ، عَقِیقَۃُ فُلاَنٍ ، بِسْمِ اللہِ وَاللَّہُ أَکْبَرُ، ثُمَّ یَذْبَحُہَا۔",,,24754,,
24755,حَدَّثَنَا وَکِیعٌ ، عَنْ حُرَیْثِ بْنِ السَّائِبِ ، عَنِ الْحَسَنِ ؛ أَنَّ أَنَسَ بْنَ مَالِکٍ کَانَ یَعُقُّ عَنْ وَلَدِہِ بِالْجُزُرِ۔,,,24755,,
24756,حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ، وَمُحَمَّدٍ ؛ أَنَّہُمَا کَانَا لاَ یَرَیَانِ عَنْ الْجَارِیَۃِ عَقِیقَۃٌ۔,,,24756,,
24757,"حَدَّثَنَا حُرَیثُ ، عَنْ جَرِیر ، عَنْ مُغِیرَۃَ ، عَنْ أَبِی وَائِلٍ ، قَالَ : لاَ یُعَقُّ عَنِ الْجَارِیَۃِ ، وَلاَ تُکْرَمُ۔",,,24757,,
