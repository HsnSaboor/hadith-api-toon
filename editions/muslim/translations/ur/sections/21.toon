{"hadithnumber": "3900", "text": "یونس ،  ضحاک اور موسیٰ بن عقبہ سب نے نافع سے اسی سند کے ساتھ ان  ( عبیداللہ ،  ایوب اور لیث )  کی حد"}
{"hadithnumber": "3901", "text": "یحییٰ بن یحییٰ نے کہا :  میں نے امام مالک کے سامنے قراءت کی ،  انہوں نے نافع سے اور انہوں نے حضرت اب"}
{"hadithnumber": "3902", "text": "عبیداللہ نے ہمیں نافع سے حدیث بیان کی اور انہوں نے حضرت ابن عمر رضی اللہ عنہ سے روایت کی کہ رسول الل"}
{"hadithnumber": "3903", "text": "لیث نے ہمیں نافع سے ،  انہوں نے حضرت ابن عمر رضی اللہ عنہ سے روایت کی کہ نبی صلی اللہ علیہ وسلم نے ف"}
{"hadithnumber": "3904", "text": "ایوب نے نافع سے اسی سند کے ساتھ اسی طرح روایت کی"}
{"hadithnumber": "3905", "text": "لیث نے ہمیں ابن شہاب سے خبر دی ،  انہوں نے سالم بن عبداللہ بن عمر سے اور انہوں نے حضرت عبداللہ بن عم"}
{"hadithnumber": "3906", "text": "سفیان بن عیینہ نے زہری سے اسی سند کے ساتھ اسی کے مانند روایت کی"}
{"hadithnumber": "3907", "text": "یونس نے مجھے ابن شہاب سے خبر دی ،  کہا :  مجھے سالم بن عبداللہ بن عمر نے حدیث بیان کی کہ ان کے والد"}
{"hadithnumber": "3908", "text": "سفیان بن عیینہ نے ہمیں ابن جریج سے حدیث بیان کی ،  انہوں نے عطاء سے اور انہوں نے حضرت جابر بن عبدالل"}
{"hadithnumber": "3909", "text": "ابوعاصم نے ہمیں خبر دی ،  کہا :  ہمیں ابن جریج نے عطاء اور ابوزبیر سے خبر دی ،  ان دونوں نے حضرت جاب"}
{"hadithnumber": "3910", "text": "مخلد بن یزید جزری نے ہمیں خبر دی ،  کہا :  ہمیں ابن جریج نے حدیث سنائی ،  انہوں نے کہا :  مجھے عطاء"}
{"hadithnumber": "3911", "text": "زید بن ابی انیسہ سے روایت ہے ،  انہوں نے کہا :  ہم سے ابوولید مکی نے حدیث بیان کی جبکہ وہ عطاء بن اب"}
{"hadithnumber": "3912", "text": "سلیم بن حیان نے ہمیں حدیث بیان کی ،  کہا :  ہمیں سعید بن میناء نے حضرت جابر بن عبداللہ رضی اللہ عنہ"}
{"hadithnumber": "3913", "text": "حماد بن زید نے ہمیں حدیث بیان کی ،  کہا :  ہمیں ایوب نے ابوزبیر اور سعید بن میناء سے حدیث بیان کی ،"}
{"hadithnumber": "3914", "text": "اسماعیل بن علیہ نے ہمیں ایوب سے حدیث بیان کی ،  انہوں نے ابوزبیر سے ،  انہوں نے حضرت جابر بن عبداللہ"}
{"hadithnumber": "3915", "text": "رباح بن ابی معروف نے ہمیں حدیث بیان کی ، انہوں نے کہا :  میں نے عطاء سے سنا ،  انہوں نے حضرت جابر بن"}
{"hadithnumber": "3916", "text": "حماد بن زید نے ہمیں مطروراق سے حدیث بیان کی ،  انہوں نے عطاء سے اور انہوں نے حضرت جابر بن عبداللہ رض"}
{"hadithnumber": "3917", "text": "مہدی بن میمون نے ہمیں حدیث بیان کی ،  کہا :  ہمیں مطروراق نے عطاء سے حدیث بیان کی ،  انہوں نے حضرت ج"}
{"hadithnumber": "3918", "text": "اوزاعی نے عطاء سے اور انہوں نے حضرت جابر بن عبداللہ رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  رسول"}
{"hadithnumber": "3919", "text": "بکیر بن اخنس نے عطاء سے اور انہوں نے حضرت جابر بن عبداللہ رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :"}
{"hadithnumber": "3920", "text": "عبدالملک نے ہمیں عطاء سے حدیث بیان کی اور انہوں نے حضرت جابر رضی اللہ عنہ سے روایت کی ،  انہوں نے کہ"}
{"hadithnumber": "3921", "text": "ہمام نے حدیث بیان کی ،  کہا :  سلیمان بن موسیٰ نے عطاء سے سوال کیا اور کہا :  کیا آپ کو حضرت جابر بن"}
{"hadithnumber": "3922", "text": "عمرو  ( بن دینار )  نے حضرت جابر رضی اللہ عنہ سے روایت کی کہ نبی صلی اللہ علیہ وسلم نے مخابرہ  ( غلط"}
{"hadithnumber": "3923", "text": "سعید بن میناء نے ہمیں حدیث بیان کی ،  انہوں نے کہا :  میں نے حضرت جابر بن عبداللہ رضی اللہ عنہ سے سن"}
{"hadithnumber": "3924", "text": "زہیر نے ہمیں حدیث بیان کی ،  کہا :  ابوزبیر نے ہمیں حضرت جابر رضی اللہ عنہ سے حدیث بیان کی ،  انہوں"}
{"hadithnumber": "3925", "text": "ہشام بن سعد نے مجھے حدیث بیان کی کہ انہیں ابوزبیر مکی نے حدیث بیان کی ،  انہوں نے کہا :  میں نے حضرت"}
{"hadithnumber": "3926", "text": "ابو عوانہ نے ہمیں سلیمان  ( اعمش )  سے حدیث بیان کی ،  کہا :  ہمیں ابوسفیان  ( طلحہ بن نافع )  نے حض"}
{"hadithnumber": "3927", "text": "عمار بن رُزَیق نے اعمش سے اسی سند کے ساتھ یہی حدیث بیان کی ،  البتہ انہوں نے کہا :   \" وہ اسے کاشت ک"}
