{"hadithnumber": "4159", "text": "عبداللہ بن مغفل رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے  ( پابندی سے )  کنگھی کرنے"}
{"hadithnumber": "4160", "text": "عبداللہ بن بریدہ سے روایت ہے کہ  ایک صحابی رسول رضی اللہ عنہ فضالہ بن عبید رضی اللہ عنہ کے پاس مصر گ"}
{"hadithnumber": "4161", "text": "ابوامامہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے کچھ صحابہ نے ایک روز آپ کے پاس دن"}
{"hadithnumber": "4162", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کے پاس خوشبو کی ایک ڈبیہ تھی جس سے"}
{"hadithnumber": "4163", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس کے پاس بال ہوں تو اسے"}
{"hadithnumber": "4164", "text": "کریمہ بنت ہمام کا بیان ہے کہ  ایک عورت ام المؤمنین عائشہ رضی اللہ عنہا کے پاس آئی اور ان سے مہندی کے"}
{"hadithnumber": "4165", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  ہند بنت عتبہ رضی اللہ عنہا نے عرض کیا: اللہ کے نبی!"}
{"hadithnumber": "4166", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  ایک عورت نے پردے کے پیچھے سے اشارہ کیا، اس کے ہاتھ میں"}
{"hadithnumber": "4167", "text": "حمید بن عبدالرحمٰن سے روایت ہے کہ  معاویہ بن ابی سفیان رضی اللہ عنہما نے جس سال حج کیا میں نے آپ کو"}
{"hadithnumber": "4168", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے لعنت کی اس عورت پر جو دوس"}
{"hadithnumber": "4169", "text": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  اللہ نے جسم میں گودنے لگانے والیوں اور گودنے لگوانے والیو"}
{"hadithnumber": "4170", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  ملعون قرار دی گئی ہے بال جوڑنے والی، اور جڑوانے والی، با"}
{"hadithnumber": "4171", "text": "سعید بن جبیر کہتے ہیں  بالوں کی چوٹیاں بنا کر کسی چیز سے باندھنے میں کوئی مضائقہ نہیں ہے۔ ابوداؤد کہ"}
{"hadithnumber": "4172", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جسے خوشبو کا  ( تحفہ"}
{"hadithnumber": "4173", "text": "ابوموسیٰ اشعری رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جب عورت عطر لگائ"}
{"hadithnumber": "4174", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  ان سے ایک عورت ملی جس سے آپ نے خوشبو پھوٹتے محسوس کیا، اور اس کے"}
{"hadithnumber": "4175", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس عورت نے خوشبو کی دھون"}
{"hadithnumber": "4176", "text": "عمار بن یاسر رضی اللہ عنہما کہتے ہیں کہ  میں اپنے گھر والوں کے پاس رات کو آیا، میرے دونوں ہاتھ پھٹے"}
{"hadithnumber": "4177", "text": "عمار بن یاسر رضی اللہ عنہما کہتے ہیں کہ  میں نے خود اپنے ہاتھوں میں خلوق ملا، پہلی روایت زیادہ کامل"}
{"hadithnumber": "4178", "text": "ابوموسیٰ اشعری کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ اس شخص کی نماز قبول نہیں ف"}
{"hadithnumber": "4179", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مردوں کو زعفران لگانے سے منع فرمایا ہے"}
{"hadithnumber": "4180", "text": "عمار بن یاسر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تین آدمی ایسے ہیں"}
{"hadithnumber": "4181", "text": "ولید بن عقبہ کہتے ہیں کہ  جب اللہ کے نبی اکرم صلی اللہ علیہ وسلم نے مکہ فتح کیا تو ابن مکہ اپنے بچوں"}
{"hadithnumber": "4182", "text": "انس بن مالک رضی اللہ عنہ سے روایت ہے کہ  ایک شخص رسول اللہ صلی اللہ علیہ وسلم کے پاس آیا اس پر  ( زع"}
{"hadithnumber": "4183", "text": "براء رضی اللہ عنہ کہتے ہیں کہ  میں نے کسی شخص کو جو کان کی لو سے نیچے بال رکھے ہو اور سرخ جوڑے میں م"}
{"hadithnumber": "4184", "text": "براء رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے بال آپ کے دونوں کانوں کی لو تک پہنچتے"}
{"hadithnumber": "4185", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے بال آپ کے دونوں کانوں کی لو تک پہنچتے"}
{"hadithnumber": "4186", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے بال آپ کے آدھے کانوں تک رہتے ت"}
{"hadithnumber": "4187", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے بال «وفرہ» ۱؎ سے بڑے او"}
{"hadithnumber": "4188", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  اہل کتاب اپنے بالوں کا «سدل» کرتے یعنی انہیں لٹکا ہوا چھ"}
{"hadithnumber": "4189", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  جب میں رسول اللہ صلی اللہ علیہ وسلم کے سر میں مانگ نکال"}
{"hadithnumber": "4190", "text": "وائل بن حجر رضی اللہ عنہ کہتے ہیں کہ  میں نبی اکرم صلی اللہ علیہ وسلم کے پاس آیا، میرے بال لمبے تھے"}
{"hadithnumber": "4191", "text": "ام ہانی رضی اللہ عنہا کہتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم مکہ آئے اور  ( اس وقت )  آپ کی چار چو"}
{"hadithnumber": "4192", "text": "عبداللہ بن جعفر رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے جعفر کے گھر والوں کو ت"}
{"hadithnumber": "4193", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے «قزع» سے منع فرمایا ہے، ا"}
{"hadithnumber": "4194", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے «قزع» سے منع فرمایا ہے،"}
{"hadithnumber": "4195", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے ایک بچے کو دیکھا کہ اس"}
{"hadithnumber": "4196", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  میرے ایک چوٹی تھی، میری ماں نے مجھ سے کہا: میں اس کو نہیں کاٹو"}
{"hadithnumber": "4197", "text": "حجاج بن حسان کا بیان ہے  ہم انس بن مالک رضی اللہ عنہ کے پاس آئے، مجھ سے میری بہن مغیرہ نے بیان کیا:"}
{"hadithnumber": "4198", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم فرمایا:  پانچ چیزیں فطرت ہیں یا فطرت"}
{"hadithnumber": "4199", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے مونچھوں کے خوب کترنے،"}
{"hadithnumber": "4200", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے زیر ناف کے بال مونڈنے، ناخن کا"}
{"hadithnumber": "4201", "text": "جابر رضی اللہ عنہ کہتے ہیں کہ  ہم حج و عمرہ کے سوا ہمیشہ داڑھیوں کو لٹکتا رہنے دیتے تھے۔ ابوداؤد کہت"}
{"hadithnumber": "4202", "text": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  سفید ب"}
{"hadithnumber": "4203", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  یہود و نصاریٰ اپنی داڑھیا"}
{"hadithnumber": "4204", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  فتح مکہ کے دن  ( ابوبکر رضی اللہ عنہ کے والد )  ابوقحافہ"}
{"hadithnumber": "4205", "text": "ابوذر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  سب سے اچھی چیز جس سے اس بڑھ"}
{"hadithnumber": "4206", "text": "ابورمثہ رضی اللہ عنہ کہتے ہیں کہ  میں اپنے والد کے ساتھ نبی اکرم صلی اللہ علیہ وسلم کی خدمت میں گیا"}
{"hadithnumber": "4207", "text": "اس سند سے ابورمثہ رضی اللہ عنہ سے اس حدیث میں مروی ہے کہ  میرے والد نے رسول اللہ صلی اللہ علیہ وسلم"}
{"hadithnumber": "4208", "text": "ابورمثہ رضی اللہ عنہ کہتے ہیں کہ  میں اور میرے والد نبی اکرم صلی اللہ علیہ وسلم کے پاس آئے آپ نے ایک"}
{"hadithnumber": "4209", "text": "انس رضی اللہ عنہ سے روایت ہے کہ  ان سے نبی اکرم صلی اللہ علیہ وسلم کے خضاب کے متعلق پوچھا گیا تو انہ"}
{"hadithnumber": "4210", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم کھال کی سبتی جوتیاں پہنتے"}
{"hadithnumber": "4211", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کے پاس سے ایک شخص گزرا جس نے"}
{"hadithnumber": "4212", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  آخر زمانے میں ک"}
{"hadithnumber": "4213", "text": "ثوبان مولیٰ رسول اللہ صلی اللہ علیہ وسلم کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم جب کسی سفر پر تشر"}
