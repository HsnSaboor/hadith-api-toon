hadiths[205]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
1433,"علی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مسلمان کی مسلمان پر حسن سلوک ",,,,,1433
1434,"ابومسعود (عقبہ بن عمرو) انصاری رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  ایک",,,,,1434
1435,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مسلمان کے مسلمان پر پانچ",,,,,1435
1436,جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم اور ابوبکر رضی اللہ عنہ پید,,,,,1436
1437,انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم مریض کی عیادت اس کی بیماری کے تین ,,,,,1437
1438,"ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم مریض کے پاس ج",,,,,1438
1439,عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے ایک بیمار کی عیادت کی،,,,,,1439
1440,انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلیاللہ علیہ وسلم  ایک مریض کی عیادت کے لیے گئے، تو پ,,,,,1440
1441,"عمر بن خطاب رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے مجھ سے فرمایا:  جب تم کسی مریض ",,,,,1441
1442,"علی رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  جو شخص اپنے مسلمان",,,,,1442
1443,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے کسی مریض کی عیادت ",,,,,1443
1444,"رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اپنے مردوں کو «لا إله إلا الله»کی تلقین کرو ۔  صحیح مسلم/ال",,,,,1444
1445,"ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اپنے مردوں کو  ( جو",,,,,1445
1446,"عبداللہ بن جعفر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اپنے مردوں  ( جو ",,,,,1446
1447,"ام المؤمنین ام سلمہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم بیمار ",,,,,1447
1448,"معقل بن یسار رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اپنے مردوں کے پاس اس",,,,,1448
