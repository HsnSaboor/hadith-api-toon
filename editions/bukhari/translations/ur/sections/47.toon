{"hadithnumber": "2483", "text": "ہم سے عبداللہ بن یوسف نے بیان کیا، کہا ہم کو امام مالک نے خبر دی، انہیں وہب بن کیسان نے اور انہیں جا"}
{"hadithnumber": "2484", "text": "ہم سے بشر بن مرحوم نے بیان کیا، کہا کہ ہم سے حاتم بن اسماعیل نے بیان کیا، ان سے یزید بن ابی عبیدہ نے"}
{"hadithnumber": "2485", "text": "ہم سے محمد بن یوسف نے بیان کیا، انہوں نے کہا کہ ہم سے اوزاعی نے بیان کیا، انہوں نے کہا کہ ہم سے ابوا"}
{"hadithnumber": "2486", "text": "ہم سے محمد بن علاء نے بیان کیا، کہا ہم سے حماد بن اسامہ نے بیان کیا، ان سے برید نے، ان سے ابوبردہ نے"}
{"hadithnumber": "2487", "text": "ہم سے محمد بن عبداللہ بن مثنیٰ نے بیان کیا، انہوں نے کہا کہ مجھ سے میرے والد نے بیان نے بیان کیا، ان"}
{"hadithnumber": "2488", "text": "ہم سے علی بن حکم انصاری نے بیان کیا، کہا ہم سے ابوعوانہ نے بیان کیا، ان سے سعید بن مسروق نے، ان سے ع"}
{"hadithnumber": "2489", "text": "ہم سے خلاد بن یحییٰ نے بیان کیا، انہوں نے کہا ہم سے سفیان ثوری نے بیان کیا، کہا ہم سے جبلہ بن سحیم ن"}
{"hadithnumber": "2490", "text": "ہم سے ابوالولید نے بیان کیا، کہا ہم سے شعبہ نے بیان کیا، ان سے جبلہ نے بیان کیا کہ  ہمارا قیام مدینہ"}
{"hadithnumber": "2491", "text": "ہم سے عمران بن میسرہ ابوالحسن بصری نے بیان کیا، کہا کہ ہم سے عبدالوارث بن سعید نے بیان کیا، کہا ہم س"}
{"hadithnumber": "2492", "text": "ہم سے بشیر بن محمد نے بیان کیا، کہا ہم کو عبداللہ بن مبارک نے خبر دی، کہا ہم کو سعید بن ابی عروبہ نے"}
{"hadithnumber": "2493", "text": "ہم سے ابونعیم فضل بن دکین نے بیان کیا، کہا کہ ہم سے زکریا نے، کہا میں نے عامر بن شعبہ سے سنا، انہوں"}
{"hadithnumber": "2494", "text": "ہم سے عبدالعزیز بن عبداللہ عامری اویسی نے بیان کیا، انہوں نے کہا ہم سے ابراہیم بن سعد نے بیان کیا، ا"}
{"hadithnumber": "2495", "text": "ہم سے عبداللہ بن محمد مسندی نے بیان کیا، کہا ہم سے ہشام بن یوسف نے بیان کیا، کہا ہم کو معمر نے خبر د"}
{"hadithnumber": "2496", "text": "ہم سے مسدد نے بیان کیا، انہوں نے کہا ہم سے عبدالواحد نے بیان کیا، انہوں نے کہا ہم سے معمر نے بیان کی"}
{"hadithnumber": "2498", "text": "ہم سے عمرو بن علی فلاس نے بیان کیا، کہا کہ ہم سے ابوعاصم نے بیان کیا، ان سے عثمان نے جو اسود کے بیٹے"}
{"hadithnumber": "2499", "text": "ہم سے موسیٰ بن اسماعیل نے بیان کیا، کہا ہم سے جویریہ بن اسماء نے بیان کیا، ان سے نافع نے اور ان سے ع"}
{"hadithnumber": "2500", "text": "ہم سے قتیبہ بن سعید نے بیان کیا، کہا ہم سے لیث نے بیان کیا، ان سے یزید بن ابی حبیب نے، ان سے ابوالخی"}
{"hadithnumber": "2502", "text": "ہم سے اصبغ بن فرج نے بیان کیا، کہا کہ مجھے عبداللہ بن وہب نے خبر دی، کہا مجھے سعید بن ابی ایوب نے خب"}
{"hadithnumber": "2503", "text": "ہم سے مسدد نے بیان کیا، کہا ہم سے جویریہ بن اسماء نے بیان کیا، ان سے نافع نے اور ان سے عبداللہ بن عم"}
{"hadithnumber": "2504", "text": "ہم سے ابوالنعمان نے بیان کیا، کہا ہم سے جریر بن حازم نے بیان کیا، ان سے قتادہ نے، ان سے نضر بن انس ن"}
{"hadithnumber": "2506", "text": "ہم سے ابوالنعمان نے بیان کیا، کہا ہم سے حماد بن زید نے بیان کیا، انہیں عبدالملک بن جریج نے خبر دی، ا"}
{"hadithnumber": "2507", "text": "ہم سے محمد بن سلام نے بیان کیا، کہا کہ ہم کو وکیع نے خبر دی، انہیں سفیان ثوری نے، انہیں ان کے والد س"}
