{"metadata":{"name":"Sunan Ibn Majah","section":{"6":"Chapters Regarding Funerals"},"section_detail":{"6":{"hadithnumber_first":1433,"hadithnumber_last":1637,"arabicnumber_first":1433,"arabicnumber_last":1637}}},"hadiths":[{"hadithnumber":1509,"arabicnumber":1509,"text":"Rapporté par Abu Hurairah : Le Prophète (ﷺ) a dit : “Faites la prière funéraire pour vos enfants, car ils vous ont précédés (pour préparer votre place au Paradis).”","grades":[{"name":"Al-Albani","grade":"Very Daif"},{"name":"Muhammad Fouad Abd al-Baqi","grade":"Very Daif"},{"name":"Shuaib Al Arnaut","grade":"Very Daif"},{"name":"Zubair Ali Zai","grade":"Daif"}],"reference":{"book":6,"hadith":77}}]}