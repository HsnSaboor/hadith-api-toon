metadata:

hadiths[214]{hadithnumber,arabic,bengali,english,french,indonesian,russian,urdu,grades,reference,international_number,narrator_chain,chapter_intro}:
{"hadithnumber": "3286", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ الزُّهْرِيِّ، عَنْ عُرْوَةَ، عَنْ عَائِشَةَ، قَالَتْ صَلَّى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ فِي خَمِيصَةٍ لَهَا أَعْلاَمٌ فَقَالَ ‏ ‏ شَغَلَنِي أَعْلاَمُ هَذِهِ اذْهَبُوا بِهَا إِلَى أَبِي جَهْمٍ وَائْتُونِي بِأَنْبِجَانِيَّتِهِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“The Messenger of Allah (ﷺ) prayed in a Khamisah* that had markings on it. Then he said: ‘These markings distracted me. Take it to Abu Jahm and bring me an Anbijaniyyah.’”**", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was\\nnarrated that ‘Aishah said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3287", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو أُسَامَةَ، أَخْبَرَنِي سُلَيْمَانُ بْنُ الْمُغِيرَةِ، عَنْ حُمَيْدِ بْنِ هِلاَلٍ، عَنْ أَبِي بُرْدَةَ، قَالَ دَخَلْتُ عَلَى عَائِشَةَ فَأَخْرَجَتْ لِي إِزَارًا غَلِيظًا مِنَ الَّتِي تُصْنَعُ بِالْيَمَنِ وَكِسَاءً مِنْ هَذِهِ الأَكْسِيَةِ الَّتِي تُدْعَى الْمُلَبَّدَةَ وَأَقْسَمَتْ لِي لَقُبِضَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ فِيهِمَا ‏.‏", "bengali": "", "english": "“I entered upon ‘Aishah and she brought out to me a thick waist wrap of the type made in Yemen, and one of these cloaks that are called Mulabbadah,* and she swore to me that the Messenger of Allah (ﷺ) had passed away in them.”", "french": "", "indonesian": "", "russian": "", "urdu": "عمر بن خطاب رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم سب مل کر کھانا کھا", "grades": "", "reference": "", "international_number": "3287", "narrator_chain": "It was\\nnarrated that Abu Burdah said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3288", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ ثَابِتٍ الْجَحْدَرِيُّ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ الأَحْوَصِ بْنِ حَكِيمٍ، عَنْ خَالِدِ بْنِ مَعْدَانَ، عَنْ عُبَادَةَ بْنِ الصَّامِتِ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ صَلَّى فِي شَمْلَةٍ قَدْ عَقَدَ عَلَيْهَا ‏.‏", "bengali": "", "english": "It was narrated from ‘Ubadah bin Samit that the Messenger of Allah (ﷺ) prayed in a Shamlah tied with a knot.", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کھانے پینے کی چیزوں میں نہ", "grades": "", "reference": "", "international_number": "3288", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3289", "arabic": "حَدَّثَنَا يُونُسُ بْنُ عَبْدِ الأَعْلَى، حَدَّثَنَا ابْنُ وَهْبٍ، حَدَّثَنَا مَالِكٌ، عَنْ إِسْحَاقَ بْنِ عَبْدِ اللَّهِ بْنِ أَبِي طَلْحَةَ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ كُنْتُ مَعَ النَّبِيِّ ـ صلى الله عليه وسلم ـ وَعَلَيْهِ رِدَاءٌ نَجْرَانِيٌّ غَلِيظُ الْحَاشِيَةِ ‏.‏", "bengali": "", "english": "“I was with the Messenger of Allah (ﷺ) and over him was a Najrani upper wrap with a thick border.”", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں سے کسی کے پاس", "grades": "", "reference": "", "international_number": "3289", "narrator_chain": "It was\\nnarrated that Anas bin Malik said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3290", "arabic": "حَدَّثَنَا عَبْدُ الْقُدُّوسِ بْنُ مُحَمَّدٍ، حَدَّثَنَا بِشْرُ بْنُ عُمَرَ، حَدَّثَنَا ابْنُ لَهِيعَةَ، حَدَّثَنَا أَبُو الأَسْوَدِ، عَنْ عَاصِمِ بْنِ عُمَرَ بْنِ قَتَادَةَ، عَنْ عَلِيِّ بْنِ الْحُسَيْنِ، عَنْ عَائِشَةَ، قَالَتْ مَا رَأَيْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَسُبُّ أَحَدًا وَلاَ يُطْوَى لَهُ ثَوْبٌ ‏.‏", "bengali": "", "english": "“I never saw the Messenger of Allah (ﷺ) insulting anyone, and no garment was ever folded up for him.”*", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم میں سے کسی کا غلام جب", "grades": "", "reference": "", "international_number": "3290", "narrator_chain": "It was\\nnarrated that ‘Aishah said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3291", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ أَبِي حَازِمٍ، عَنْ أَبِيهِ، عَنْ سَهْلِ بْنِ سَعْدٍ السَّاعِدِيِّ، أَنَّ امْرَأَةً، جَاءَتْ إِلَى رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ بِبُرْدَةٍ - قَالَ وَمَا الْبُرْدَةُ قَالَ الشَّمْلَةُ - قَالَتْ يَا رَسُولَ اللَّهِ إِنِّي نَسَجْتُ هَذِهِ بِيَدِي لأَكْسُوَكَهَا ‏.‏ فَأَخَذَهَا رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ مُحْتَاجًا إِلَيْهَا فَخَرَجَ عَلَيْنَا فِيهَا وَإِنَّهَا لإِزَارُهُ فَجَاءَ فُلاَنُ بْنُ فُلاَنٍ - رَجُلٌ سَمَّاهُ يَوْمَئِذٍ - فَقَالَ يَا رَسُولَ اللَّهِ مَا أَحْسَنَ هَذِهِ الْبُرْدَةَ اكْسُنِيهَا ‏.‏ قَالَ ‏ ‏ نَعَمْ ‏\"\"‏ ‏.‏ فَلَمَّا دَخَلَ طَوَاهَا وَأَرْسَلَ بِهَا إِلَيْهِ فَقَالَ لَهُ الْقَوْمُ وَاللَّهِ مَا أَحْسَنْتَ كُسِيَهَا النَّبِيُّ ـ صلى الله عليه وسلم ـ مُحْتَاجًا إِلَيْهَا ثُمَّ سَأَلْتَهُ إِيَّاهَا وَقَدْ عَلِمْتَ أَنَّهُ لاَ يَرُدُّ سَائِلاً ‏.‏ فَقَالَ إِنِّي وَاللَّهِ مَا سَأَلْتُهُ إِيَّاهَا لأَلْبَسَهَا وَلَكِنْ سَأَلْتُهُ إِيَّاهَا لِتَكُونَ كَفَنِي ‏.‏ فَقَالَ سَهْلٌ فَكَانَتْ كَفَنَهُ يَوْمَ مَاتَ ‏.‏\"", "bengali": "", "english": "* “What type of woven sheet?” He said: “A Shamlah.” She said: “O Messenger of Allah, I have woven this with my own hands for you to wear.” The Messenger of Allah (ﷺ) took it, since he needed it. He came out to us wearing it as a lower wrap. So-and-so the son of so-and-so.” – a man whose name he told that day – said: “O Messenger of Allah, how beautiful this sheet is! Let me wear it.” He said: “Yes.” When he went inside he folded it up and sent it to him. The people said to him: “By Allah, you have not done well. The Prophet (ﷺ) wore it because he needed it, then you asked for it, and you knew that he would not refuse anyone who asked him for something.” He said: “By Allah, I did not ask for it so that I could wear it, rather I asked for it so that it could be my shroud.” Sahl said: “And it became his shroud the day he died.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was\\nnarrated from Sahl bin Sa’d Sa’idi that a woman came to the\\nMessenger of Allah (ﷺ) with a woven sheet – he said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3292", "arabic": "حَدَّثَنَا يَحْيَى بْنُ عُثْمَانَ بْنِ سَعِيدِ بْنِ كَثِيرِ بْنِ دِينَارٍ الْحِمْصِيُّ، حَدَّثَنَا بَقِيَّةُ بْنُ الْوَلِيدِ، عَنْ يُوسُفَ بْنِ أَبِي كَثِيرٍ، عَنْ نُوحِ بْنِ ذَكْوَانَ، عَنِ الْحَسَنِ، عَنْ أَنَسٍ، قَالَ لَبِسَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ الصُّوفَ وَاحْتَذَى الْمَخْصُوفَ وَلَبِسَ ثَوْبًا خَشِنًا خَشِنًا ‏.‏", "bengali": "", "english": "“The Messenger of Allah (ﷺ) wore wool and sandals, and he wore coarse, rough garments.”", "french": "", "indonesian": "", "russian": "", "urdu": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے خوان  ( میز )  پر کبھی نہیں کھا", "grades": "", "reference": "", "international_number": "3292", "narrator_chain": "It was\\nnarrated that Anas said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3293", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، قَالَ حَدَّثَنَا أَصْبَغُ بْنُ زَيْدٍ، حَدَّثَنَا أَبُو الْعَلاَءِ، عَنْ أَبِي أُمَامَةَ، قَالَ لَبِسَ عُمَرُ بْنُ الْخَطَّابِ ثَوْبًا جَدِيدًا فَقَالَ الْحَمْدُ لِلَّهِ الَّذِي كَسَانِي مَا أُوَارِي بِهِ عَوْرَتِي وَأَتَجَمَّلُ بِهِ فِي حَيَاتِي ثُمَّ قَالَ سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ مَنْ لَبِسَ ثَوْبًا جَدِيدًا فَقَالَ الْحَمْدُ لِلَّهِ الَّذِي كَسَانِي مَا أُوَارِي بِهِ عَوْرَتِي وَأَتَجَمَّلُ بِهِ فِي حَيَاتِي ‏.‏ ثُمَّ عَمَدَ إِلَى الثَّوْبِ الَّذِي أَخْلَقَ أَوْ أَلْقَى فَتَصَدَّقَ بِهِ كَانَ فِي كَنَفِ اللَّهِ وَفِي حِفْظِ اللَّهِ وَفِي سِتْرِ اللَّهِ حَيًّا وَمَيِّتًا ‏\"\"‏ ‏.‏ قَالَهَا ثَلاَثًا ‏.‏\"", "bengali": "", "english": "“Umar bin Khattab put on a new garment and said: Al-hamdu lillahil-ladhi kasani ma uwari bihi ‘awrati, wa atajammalu bihi fi hayati (Praise is to Allah Who has clothed me in something with which I conceal my nakedness and adorn myself in my life). Then he said: ‘I heard the Messenger of Allah (ﷺ) say: “Whoever puts on a new garment and says: Al-hamdu lillahil- ladhi kasani ma uwari bihi ‘awrati, wa atajammalu bihi fi hayati (Praise be to Allah Who has clothed me in something with which I conceal my nakedness and adorn myself in my life), then takes the garment that has worn out, or that he had taken off and gives it in charity, he will be under the shelter, protection and care of Allah, whether he lives or dies.’ He said this three times.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was\\nnarrated that Abu Umamah said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3294", "arabic": "حَدَّثَنَا الْحُسَيْنُ بْنُ مَهْدِيٍّ، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَنْبَأَنَا مَعْمَرٌ، عَنِ الزُّهْرِيِّ، عَنْ سَالِمٍ، عَنِ ابْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ رَأَى عَلَى عُمَرَ قَمِيصًا أَبْيَضَ فَقَالَ ‏\"‏ ثَوْبُكَ هَذَا غَسِيلٌ أَمْ جَدِيدٌ ‏\"‏ ‏.‏ قَالَ لاَ بَلْ غَسِيلٌ ‏.‏ قَالَ ‏\"‏ الْبَسْ جَدِيدًا وَعِشْ حَمِيدًا وَمُتْ شَهِيدًا ‏\"‏ ‏.‏", "bengali": "", "english": "“Is this garment of yours washed or a new one?” He said: “Rather it has been washed.” He said: “Ilbas jadida, wa `ish hamida, wa mut shahida (May you wear new clothes, live a good life and die as martyr).”", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے اس بات سے منع فرمایا", "grades": "", "reference": "", "international_number": "3294", "narrator_chain": "It was\\nnarrated from Ibn `Umar that the Messenger of Allah (ﷺ) saw\\n`Umar\\nwearing a white shirt and he said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3295", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ الزُّهْرِيِّ، عَنْ عَطَاءِ بْنِ يَزِيدَ اللَّيْثِيِّ، عَنْ أَبِي سَعِيدٍ الْخُدْرِيِّ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ نَهَى عَنْ لِبْسَتَيْنِ فَأَمَّا اللِّبْسَتَانِ فَاشْتِمَالُ الصَّمَّاءِ وَالاِحْتِبَاءُ فِي الثَّوْبِ الْوَاحِدِ لَيْسَ عَلَى فَرْجِهِ مِنْهُ شَىْءٌ ‏.‏", "bengali": "", "english": "It was narrated from Abu Sa’eed Al-Khudri that the Prophet (ﷺ) forbade two kinds of dress. Those two types of dress are Ishtimalus- Samma’* and Ihtiba’ in a single garment, with no part of it upon his private part.**", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب دستر خوان لگا", "grades": "", "reference": "", "international_number": "3295", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3296", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، وَأَبُو أُسَامَةَ عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ خُبَيْبِ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ حَفْصِ بْنِ عَاصِمٍ، عَنْ أَبِي هُرَيْرَةَ، ‏.‏ أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ نَهَى عَنْ لِبْسَتَيْنِ عَنِ اشْتِمَالِ الصَّمَّاءِ وَعَنِ الاِحْتِبَاءِ فِي الثَّوْبِ الْوَاحِدِ يُفْضِي بِفَرْجِهِ إِلَى السَّمَاءِ ‏.‏", "bengali": "", "english": "Ishtimalus-Samma’ and Ihtiba’, exposing one’s private part to the sky.", "french": "", "indonesian": "", "russian": "", "urdu": "رسول اللہ صلی اللہ علیہ وسلم کی بیٹی فاطمہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ن", "grades": "", "reference": "", "international_number": "3296", "narrator_chain": "It was\\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\\nforbade\\ntwo kinds of dress:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3297", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، وَأَبُو أُسَامَةَ عَنْ سَعْدِ بْنِ سَعِيدٍ، عَنْ عَمْرَةَ، عَنْ عَائِشَةَ، قَالَتْ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنْ لِبْسَتَيْنِ اشْتِمَالِ الصَّمَّاءِ وَالاِحْتِبَاءِ فِي ثَوْبٍ وَاحِدٍ وَأَنْتَ مُفْضٍ فَرْجَكَ إِلَى السَّمَاءِ ‏.‏", "bengali": "", "english": "“The Messenger of Allah (ﷺ) forbade two kinds of dress: Ishtimalus-Samma’ and Ihtiba’ in one garment, when you are exposing your private part to the sky.”", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  تم میں سے کوئی شخص جب اس", "grades": "", "reference": "", "international_number": "3297", "narrator_chain": "It was\\nnarrated that ‘Aishah said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3298", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا الْحَسَنُ بْنُ مُوسَى، عَنْ شَيْبَانَ، عَنْ قَتَادَةَ، عَنْ أَبِي بُرْدَةَ، عَنْ أَبِيهِ، قَالَ قَالَ لِي يَا بُنَىَّ لَوْ شَهِدْتَنَا وَنَحْنُ مَعَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ إِذَا أَصَابَتْنَا السَّمَاءُ لَحَسِبْتَ أَنَّ رِيحَنَا رِيحُ الضَّأْنِ ‏.‏", "bengali": "", "english": "“O my son, if only you could have seen us when we were with the Messenger of Allah (ﷺ), when rain fell on us; you would have thought that we smelled like sheep.”", "french": "", "indonesian": "", "russian": "", "urdu": "اسماء بنت یزید رضی اللہ عنہا کہتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کی خدمت میں کھانا لایا گیا تو", "grades": "", "reference": "", "international_number": "3298", "narrator_chain": "It was\\nnarrated from Abu Burdah that his father said to him:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3299", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عُثْمَانَ بْنِ كَرَامَةَ، حَدَّثَنَا أَبُو أُسَامَةَ، حَدَّثَنَا الأَحْوَصُ بْنُ حَكِيمٍ، عَنْ خَالِدِ بْنِ مَعْدَانَ، عَنْ عُبَادَةَ بْنِ الصَّامِتِ، قَالَ خَرَجَ عَلَيْنَا رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ذَاتَ يَوْمٍ وَعَلَيْهِ جُبَّةٌ رُومِيَّةٌ مِنْ صُوفٍ ضَيِّقَةُ الْكُمَّيْنِ فَصَلَّى بِنَا فِيهَا لَيْسَ عَلَيْهِ شَىْءٌ غَيْرُهَا ‏.‏", "bengali": "", "english": "“The Messenger of Allah (ﷺ) came out to us one day, wearing a Roman cloak of wool with narrow sleeves. He led us in prayer wearing that, and nothing else.”", "french": "", "indonesian": "", "russian": "", "urdu": "انس بن مالک رضی اللہ عنہ (جو قبیلہ بنی عبدالاشہل کے ایک شخص ہیں) کہتے ہیں کہ  میں نبی اکرم صلی اللہ", "grades": "", "reference": "", "international_number": "3299", "narrator_chain": "It was\\nnarrated that ‘Ubadah bin Samit said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3300", "arabic": "حَدَّثَنَا الْعَبَّاسُ بْنُ الْوَلِيدِ الدِّمَشْقِيُّ، وَأَحْمَدُ بْنُ الأَزْهَرِ، قَالاَ حَدَّثَنَا مَرْوَانُ بْنُ مُحَمَّدٍ، حَدَّثَنَا يَزِيدُ بْنُ السِّمْطِ، حَدَّثَنِي الْوَضِينُ بْنُ عَطَاءٍ، عَنْ مَحْفُوظِ بْنِ عَلْقَمَةَ، عَنْ سَلْمَانَ الْفَارِسِيِّ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ تَوَضَّأَ فَقَلَبَ جُبَّةَ صُوفٍ كَانَتْ عَلَيْهِ فَمَسَحَ بِهَا وَجْهَهُ ‏.‏", "bengali": "", "english": "It was narrated from Salman Farisi that the Messenger of Allah (ﷺ) performed ablution, then he turned his woolen cloak that he was wearing inside out and wiped his face with it.", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن حارث بن جزء زبیدی رضی اللہ عنہ کہتے ہیں کہ  ہم لوگ رسول اللہ صلی اللہ علیہ وسلم کے زمانے", "grades": "", "reference": "", "international_number": "3300", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3301", "arabic": "حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، حَدَّثَنَا مُوسَى بْنُ الْفَضْلِ، عَنْ شُعْبَةَ، عَنْ هِشَامِ بْنِ زَيْدٍ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ رَأَيْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَسِمُ غَنَمًا فِي آذَانِهَا وَرَأَيْتُهُ مُتَّزِرًا بِكِسَاءٍ ‏.‏", "bengali": "", "english": "“I saw the Messenger of Allah (ﷺ) marking sheep on their ears, and I saw him wearing a cloak around his wrist.”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  ہم لوگ رسول اللہ صلی اللہ علیہ وسلم کے زمانے میں چلتے پھر", "grades": "", "reference": "", "international_number": "3301", "narrator_chain": "It was\\nnarrated that Anas bin Malik said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3302", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، أَنْبَأَنَا عَبْدُ اللَّهِ بْنُ رَجَاءٍ الْمَكِّيُّ، عَنِ ابْنِ خُثَيْمٍ، عَنْ سَعِيدِ بْنِ جُبَيْرٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ خَيْرُ ثِيَابِكُمُ الْبَيَاضُ فَالْبَسُوهَا وَكَفِّنُوا فِيهَا مَوْتَاكُمْ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“The best of your garments are the white ones, so wear them and shroud your dead in them.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was\\nnarrated from Ibn ‘Abbas that the Messenger of Allah (ﷺ)\\nsaid:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3303", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، عَنْ سُفْيَانَ، عَنْ حَبِيبِ بْنِ أَبِي ثَابِتٍ، عَنْ مَيْمُونِ بْنِ أَبِي شَبِيبٍ، عَنْ سَمُرَةَ بْنِ جُنْدَبٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ الْبَسُوا ثِيَابَ الْبَيَاضِ فَإِنَّهَا أَطْهَرُ وَأَطْيَبُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“Wear white garments, for they are purer and better.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was\\nnarrated from Samurah bin Jundab that the Messenger of Allah\\n(ﷺ)\\nsaid:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3304", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ حَسَّانَ الأَزْرَقُ، حَدَّثَنَا عَبْدُ الْمَجِيدِ بْنُ أَبِي رَوَّادٍ، حَدَّثَنَا مَرْوَانُ بْنُ سَالِمٍ، عَنْ صَفْوَانَ بْنِ عَمْرٍو، عَنْ شُرَيْحِ بْنِ عُبَيْدٍ الْحَضْرَمِيِّ، عَنْ أَبِي الدَّرْدَاءِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِنَّ أَحْسَنَ مَا زُرْتُمُ اللَّهَ بِهِ فِي قُبُورِكُمْ وَمَسَاجِدِكُمُ الْبَيَاضُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“The best of that in which you visit Allah in your graves and your mosque is white (garments).”*", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was\\nnarrated from Abu Darda’ that the Messenger of Allah (ﷺ)\\nsaid:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3305", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو أُسَامَةَ، ح وَحَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، جَمِيعًا عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ إِنَّ الَّذِي يَجُرُّ ثَوْبَهُ مِنَ الْخُيَلاَءِ لاَ يَنْظُرُ اللَّهُ إِلَيْهِ يَوْمَ الْقِيَامَةِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“Whoever lets his garment drag out of pride, Allah will not look at him on the Day of Resurrection.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was\\nnarrated from Ibn ‘Umar that the Messenger of Allah (ﷺ)\\nsaid:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3306", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، عَنِ الأَعْمَشِ، عَنْ عَطِيَّةَ، عَنْ أَبِي سَعِيدٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ جَرَّ إِزَارَهُ مِنَ الْخُيَلاَءِ لَمْ يَنْظُرِ اللَّهُ إِلَيْهِ يَوْمَ الْقِيَامَةِ ‏\"\"‏ ‏.‏ قَالَ فَلَقِيتُ ابْنَ عُمَرَ بِالْبَلاَطِ فَذَكَرْتُ لَهُ حَدِيثَ أَبِي سَعِيدٍ عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ فَقَالَ وَأَشَارَ إِلَى أُذُنَيْهِ سَمِعَتْهُ أُذُنَاىَ وَوَعَاهُ قَلْبِي ‏.‏\"", "bengali": "", "english": "“The Messenger of Allah (ﷺ) said: ‘Whoever lets his lower wrap drag out of pride, Allah will not look at him on the Day of Resurrection.” He ( ‘Atiyyah) said \"I met Ibn 'Umar in Al-Balaat so I mentioned Abu Sa'eed's hadith from the Prophet (ﷺ). So he said and pointed to his ears 'My two ears heard it, and my heart preserved it.' \"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was\\nnarrated from ‘Atiyyah, that Abu Sa’eed said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3307", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو، عَنْ أَبِي سَلَمَةَ، عَنْ أَبِي هُرَيْرَةَ، قَالَ مَرَّ بِأَبِي هُرَيْرَةَ فَتًى مِنْ قُرَيْشٍ يَجُرُّ سَبَلَهُ فَقَالَ يَا ابْنَ أَخِي إِنِّي سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ مَنْ جَرَّ ثَوْبَهُ مِنَ الْخُيَلاَءِ لَمْ يَنْظُرِ اللَّهُ له يَوْمَ الْقِيَامَةِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“O my nephew! I heard the Messenger of Allah (ﷺ) saying ‘Whoever let his garment drag out of pride, Allah will not look at him on the Day of Resurrection.’”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was\\nnarrated that a young man of Quriash passed by Abu Hurairah\\nwith his\\ncloak dragging. He said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3308", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو الأَحْوَصِ، عَنْ أَبِي إِسْحَاقَ، عَنْ مُسْلِمِ بْنِ نُذَيْرٍ، عَنْ حُذَيْفَةَ، قَالَ أَخَذَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ بِأَسْفَلِ عَضَلَةِ سَاقِي أَوْ سَاقِهِ فَقَالَ ‏ ‏ هَذَا مَوْضِعُ الإِزَارِ فَإِنْ أَبَيْتَ ‏.‏ فَأَسْفَلَ فَإِنْ أَبَيْتَ فَأَسْفَلَ فَإِنْ أَبَيْتَ فَلاَ حَقَّ لِلإِزَارِ فِي الْكَعْبَيْنِ ‏\"\"‏ ‏.‏ حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، حَدَّثَنِي أَبُو إِسْحَاقَ، عَنْ مُسْلِمِ بْنِ نُذَيْرٍ، عَنْ حُذَيْفَةَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ مِثْلَهُ ‏.‏\"", "bengali": "", "english": "“The Messenger of Allah (ﷺ) took hold of the lower part of my calf or his calf and said: ‘This is where the lower wrap should come to. If you insist, then lower, and if you insist, then lower, but the lower wrap has no right to (come to) the ankle.’”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was\\nnarrated that Hudhaifah said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3309", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ الْعَلاَءِ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ أَبِيهِ، قَالَ قُلْتُ لأَبِي سَعِيدٍ هَلْ سَمِعْتَ مِنْ، رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ شَيْئًا فِي الإِزَارِ قَالَ نَعَمْ سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏\"‏ إِزْرَةُ الْمُؤْمِنِ إِلَى أَنْصَافِ سَاقَيْهِ لاَ جُنَاحَ عَلَيْهِ مَا بَيْنَهُ وَبَيْنَ الْكَعْبَيْنِ وَمَا أَسْفَلَ مِنَ الْكَعْبَيْنِ فِي النَّارِ ‏\"‏ ‏.‏ يَقُولُ ثَلاَثًا ‏\"‏ لاَ يَنْظُرُ اللَّهُ إِلَى مَنْ جَرَّ إِزَارَهُ بَطَرًا ‏\"‏ ‏.‏", "bengali": "", "english": "“I said to Abu Sa’eed: ‘Did you hear anything from the Messenger of Allah (ﷺ) concerning the lower wrap?’ He said: ‘Yes. I heard the Messenger of Allah (ﷺ) say: ‘The lower wrap of the believer should come to mid-calf, but there is no sin on him if it comes between that point and the ankle. But whatever is lower than the ankle is in the Fire.’ And he said three times: ‘Allah will not look at the one who lets his lower wrap drag out of vanity.’”", "french": "", "indonesian": "", "russian": "", "urdu": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  مجھے نہیں معلوم کہ رسول اللہ صلی اللہ علیہ وسلم نے کبھی بھنی ہ", "grades": "", "reference": "", "international_number": "3309", "narrator_chain": "It was\\nnarrated from ‘Ala bin ‘Abdur-Rahman that his father said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3310", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، أَنْبَأَنَا شَرِيكٌ، عَنْ عَبْدِ الْمَلِكِ بْنِ عُمَيْرٍ، عَنْ حُصَيْنِ بْنِ قَبِيصَةَ، عَنِ الْمُغِيرَةِ بْنِ شُعْبَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ يَا سُفْيَانَ بْنَ سَهْلٍ لاَ تُسْبِلْ فَإِنَّ اللَّهَ لاَ يُحِبُّ الْمُسْبِلِينَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“O Sufyan bin Sahl, do not let your garment hang, for Allah does not like those who let their garments hang below the ankles.’”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was\\nnarrated from Mughirah bin Shu’bah that the Messenger of Allah\\n(ﷺ) said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3311", "arabic": "حَدَّثَنَا يَعْقُوبُ بْنُ إِبْرَاهِيمَ الدَّوْرَقِيُّ، حَدَّثَنَا أَبُو تُمَيْلَةَ، عَنْ عَبْدِ الْمُؤْمِنِ بْنِ خَالِدٍ، عَنِ ابْنِ بُرَيْدَةَ، عَنْ أُمِّهِ، عَنْ أُمِّ سَلَمَةَ، قَالَتْ لَمْ يَكُنْ ثَوْبٌ أَحَبَّ إِلَى رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ مِنَ الْقَمِيصِ ‏.‏", "bengali": "", "english": "There was no garment more beloved to the Messenger of Allah (ﷺ) than the shirt.”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن حارث بن جزء زبیدی رضی اللہ عنہ کہتے ہیں کہ  ہم نے رسول اللہ صلی اللہ علیہ وسلم کے ساتھ مس", "grades": "", "reference": "", "international_number": "3311", "narrator_chain": "It was\\nnarrated that Umm Salamah said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3312", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا الْحُسَيْنُ بْنُ عَلِيٍّ، عَنِ ابْنِ أَبِي رَوَّادٍ، عَنْ سَالِمٍ، عَنْ أَبِيهِ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ الإِسْبَالُ فِي الإِزَارِ وَالْقَمِيصِ وَالْعِمَامَةِ مَنْ جَرَّ شَيْئًا خُيَلاَءَ لَمْ يَنْظُرِ اللَّهُ إِلَيْهِ يَوْمَ الْقِيَامَةِ ‏\"\"‏ ‏.‏ قَالَ أَبُو بَكْرٍ مَا أَغْرَبَهُ ‏.‏\"", "bengali": "", "english": "“Hanging down may apply to the waist wrap, shirt or turban. Whoever lets any of these drag out of pride, Allah will not look at him on the Day of Resurrection.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was\\nnarrated from Salim, from his father, that the Prophet (ﷺ)\\nsaid:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3313", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ عُثْمَانَ بْنِ حَكِيمٍ الأَوْدِيُّ، حَدَّثَنَا أَبُو غَسَّانَ، قَالَ حَدَّثَنَا حَسَنُ بْنُ صَالِحٍ، ح وَحَدَّثَنَا سُفْيَانُ بْنُ وَكِيعٍ، حَدَّثَنَا أَبِي، عَنِ الْحَسَنِ بْنِ صَالِحٍ، عَنْ مُسْلِمٍ، عَنْ مُجَاهِدٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ كَانَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ يَلْبَسُ قَمِيصًا قَصِيرَ الْيَدَيْنِ وَالطُّولِ ‏.‏", "bengali": "", "english": "“The Messenger of Allah (ﷺ) used to wear a shirt that was short in the sleeves and length.”", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  ہم لوگ قربانی کے گوشت میں سے پائے اکٹھا کر کے رکھ دیتے", "grades": "", "reference": "", "international_number": "3313", "narrator_chain": "It was\\nnarrated that Ibn ‘Abbas said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3314", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا ابْنُ دُكَيْنٍ، عَنْ زُهَيْرٍ، عَنْ عُرْوَةَ بْنِ عَبْدِ اللَّهِ بْنِ قُشَيْرٍ، حَدَّثَنِي مُعَاوِيَةُ بْنُ قُرَّةَ، عَنْ أَبِيهِ، قَالَ أَتَيْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ فَبَايَعْتُهُ وَإِنَّ زِرَّ قَمِيصِهِ لَمُطْلَقٌ ‏.‏ قَالَ عُرْوَةُ فَمَا رَأَيْتُ مُعَاوِيَةَ وَلاَ ابْنَهُ فِي شِتَاءٍ وَلاَ صَيْفٍ إِلاَّ مُطْلَقَةً أَزْرَارُهُمَا ‏.‏", "bengali": "", "english": "“I came to the Messenger of Allah (ﷺ) and gave him my pledge, and the buttons of his shirt were undone.”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تمہارے لیے دو مر", "grades": "", "reference": "", "international_number": "3314", "narrator_chain": "Mu’awiyah bin Qurrah narrated that his father said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3315", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا وَكِيعٌ، ح وَحَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا يَحْيَى، وَعَبْدُ الرَّحْمَنِ، قَالُوا حَدَّثَنَا سُفْيَانُ، عَنْ سِمَاكِ بْنِ حَرْبٍ، عَنْ سُوَيْدِ بْنِ قَيْسٍ، قَالَ أَتَانَا النَّبِيُّ ـ صلى الله عليه وسلم ـ فَسَاوَمَنَا سَرَاوِيلَ ‏.‏", "bengali": "", "english": "“The Prophet (ﷺ) came to us and haggled with us over the price of trousers.”", "french": "", "indonesian": "", "russian": "", "urdu": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تمہارے سالنوں کا سردا", "grades": "", "reference": "", "international_number": "3315", "narrator_chain": "It was\\nnarrated that Suwaid bin Qais said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3316", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا الْمُعْتَمِرُ بْنُ سُلَيْمَانَ، عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ نَافِعٍ، عَنْ سُلَيْمَانَ بْنِ يَسَارٍ، عَنْ أُمِّ سَلَمَةَ، قَالَتْ سُئِلَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ كَمْ تَجُرُّ الْمَرْأَةُ مِنْ ذَيْلِهَا قَالَ ‏\"‏ شِبْرًا ‏\"‏ ‏.‏ قُلْتُ إِذًا يَنْكَشِفَ عَنْهَا ‏.‏ قَالَ ذِرَاعٌ لاَ تَزِيدُ عَلَيْهِ ‏\"‏ ‏.‏", "bengali": "", "english": "“The Messenger of Allah (ﷺ) was asked about how long a woman’s hem should hang down. He said: ‘A hand span.’ I said: ‘But then (her legs and feet) will be uncovered.’ He said: ‘Then a forearm’s length, but no more than that.’”", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  سرکہ کیا ہی عم", "grades": "", "reference": "", "international_number": "3316", "narrator_chain": "It was\\nnarrated that Umm Salamah said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3317", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، عَنْ سُفْيَانَ، عَنْ زَيْدٍ الْعَمِّيِّ، عَنْ أَبِي الصِّدِّيقِ النَّاجِيِّ، عَنِ ابْنِ عُمَرَ، أَنَّ أَزْوَاجَ النَّبِيِّ، ـ صلى الله عليه وسلم ـ رُخِّصَ لَهُنَّ فِي الذَّيْلِ ذِرَاعًا فَكُنَّ يَأْتِيَنَّا فَنَذْرَعُ لَهُنَّ بِالْقَصَبِ ذِرَاعًا ‏.‏", "bengali": "", "english": "“The wives of the Prophet (ﷺ) were allowed to let their hems hang down, so they used to come to us and we would measure one forearms length for them with a reed.”", "french": "", "indonesian": "", "russian": "", "urdu": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  سرکہ کیا ہی عمد", "grades": "", "reference": "", "international_number": "3317", "narrator_chain": "It was\\nnarrated from Ibn ‘Umar:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3318", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، حَدَّثَنَا حَمَّادُ بْنُ سَلَمَةَ، عَنْ أَبِي الْمُهَزِّمِ، عَنْ أَبِي هُرَيْرَةَ، ‏.‏ أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ لِفَاطِمَةَ أَوْ لأُمِّ سَلَمَةَ ‏ ‏ ذَيْلُكِ ذِرَاعٌ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“Let your hem down one forearm’s length.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was\\nnarrated from Abu Hurairah that the Prophet (ﷺ) said to\\nFatimah, or\\nto Umm Salamah:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3319", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَفَّانُ، حَدَّثَنَا عَبْدُ الْوَارِثِ، حَدَّثَنَا حَبِيبٌ الْمُعَلِّمُ، عَنْ أَبِي الْمُهَزِّمِ، عَنْ أَبِي هُرَيْرَةَ، عَنْ عَائِشَةَ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ فِي ذُيُولِ النِّسَاءِ ‏\"‏ شِبْرًا ‏\"‏ ‏.‏ فَقَالَتْ عَائِشَةُ إِذًا تَخْرُجَ سُوقُهُنَّ ‏.‏ قَالَ ‏\"‏ فَذِرَاعٌ ‏\"‏ ‏.‏", "bengali": "", "english": "“A hand span.” ‘Aishah said: “This may show her calves.” He said: “Then a forearm’s length.”", "french": "", "indonesian": "", "russian": "", "urdu": "عمر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  زیتون کا تیل بطور سالن استعما", "grades": "", "reference": "", "international_number": "3319", "narrator_chain": "It was\\nnarrated from ‘Aishah that the Prophet (ﷺ) said, concerning\\nhow\\nlong a woman’s hem should hang down:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3320", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ مُسَاوِرٍ الْوَرَّاقِ، عَنْ جَعْفَرِ بْنِ عَمْرِو بْنِ حُرَيْثٍ، عَنْ أَبِيهِ، قَالَ رَأَيْتُ النَّبِيَّ ـ صلى الله عليه وسلم ـ يَخْطُبُ عَلَى الْمِنْبَرِ وَعَلَيْهِ عِمَامَةٌ سَوْدَاءُ ‏.‏", "bengali": "", "english": "“I saw the Prophet (ﷺ) delivering a sermon on the pulpit, wearing a black turban.”", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  زیتون کا تیل بطور سالن ا", "grades": "", "reference": "", "international_number": "3320", "narrator_chain": "It was\\nnarrated from Ja’far bin ‘Amr bin Huraith that his father\\nsaid:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3321", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا حَمَّادُ بْنُ سَلَمَةَ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ دَخَلَ مَكَّةَ وَعَلَيْهِ عِمَامَةٌ سَوْدَاءُ ‏.‏", "bengali": "", "english": "It was narrated from Jabir that the Prophet (ﷺ) entered Makkah wearing a black turban.", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے پاس جب دودھ آتا تو فرم", "grades": "", "reference": "", "international_number": "3321", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3322", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عُبَيْدُ اللَّهِ، أَنْبَأَنَا مُوسَى بْنُ عُبَيْدَةَ، عَنْ عَبْدِ اللَّهِ بْنِ دِينَارٍ، عَنِ ابْنِ عُمَرَ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ دَخَلَ يَوْمَ فَتْحِ مَكَّةَ وَعَلَيْهِ عِمَامَةٌ سَوْدَاءُ ‏.‏", "bengali": "", "english": "It was narrated from Ibn ‘Umar that the Prophet (ﷺ) entered (Makkah), on the Day of the Conquest of Makkah, wearing a black turban.", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہا کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس کو اللہ تعالی", "grades": "", "reference": "", "international_number": "3322", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3323", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو أُسَامَةَ، عَنْ مُسَاوِرٍ، حَدَّثَنِي جَعْفَرُ بْنُ عَمْرِو بْنِ حُرَيْثٍ، عَنْ أَبِيهِ، قَالَ كَأَنِّي أَنْظُرُ إِلَى رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ وَعَلَيْهِ عِمَامَةٌ سَوْدَاءُ قَدْ أَرْخَى طَرَفَيْهَا بَيْنَ كَتِفَيْهِ ‏.‏", "bengali": "", "english": "“It is as if I can see the Messenger of Allah (ﷺ), wearing a black turban, with the ends hanging down his shoulders.”", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم حلوا  ( شیرینی )  اور شہد", "grades": "", "reference": "", "international_number": "3323", "narrator_chain": "Ja’far\\nbin ‘Amr bin Huraith narrated that his father said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3324", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا إِسْمَاعِيلُ ابْنُ عُلَيَّةَ، عَنْ عَبْدِ الْعَزِيزِ بْنِ صُهَيْبٍ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ لَبِسَ الْحَرِيرَ فِي الدُّنْيَا لَمْ يَلْبَسْهُ فِي الآخِرَةِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“Whoever wears silk in this world will not wear it in the Hereafter.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was\\nnarrated from Anas bin Malik that the Messenger of Allah (ﷺ)\\nsaid:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3325", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ، عَنِ الشَّيْبَانِيِّ، عَنْ أَشْعَثَ بْنِ أَبِي الشَّعْثَاءِ، عَنْ مُعَاوِيَةَ بْنِ سُوَيْدٍ، عَنِ الْبَرَاءِ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنِ الدِّيبَاجِ وَالْحَرِيرِ وَالإِسْتَبْرَقِ ‏.‏", "bengali": "", "english": "“The Messenger of Allah (ﷺ) forbade brocade, silk, and embroidered brocade.”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن جعفر رضی اللہ عنہما کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو تر کھجور کے ساتھ", "grades": "", "reference": "", "international_number": "3325", "narrator_chain": "It was\\nnarrated that Bara’ bin ‘Azib said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3326", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا وَكِيعٌ، عَنْ شُعْبَةَ، عَنِ الْحَكَمِ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِي لَيْلَى، عَنْ حُذَيْفَةَ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنْ لُبْسِ الْحَرِيرِ وَالذَّهَبِ وَقَالَ ‏ ‏ هُوَ لَهُمْ فِي الدُّنْيَا وَلَنَا فِي الآخِرَةِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“The Messenger of Allah (ﷺ) forbade wearing silk and gold. He said: ‘They are for them in this world and for us in the Hereafter.’”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was\\nnarrated that Hudhaifah said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3327", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ سُلَيْمَانَ، عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ نَافِعٍ، أَنَّ عَبْدَ اللَّهِ بْنَ عُمَرَ، أَخْبَرَهُ أَنَّ عُمَرَ بْنَ الْخَطَّابِ رَأَى حُلَّةً سِيَرَاءَ مِنْ حَرِيرٍ فَقَالَ يَا رَسُولَ اللَّهِ لَوِ ابْتَعْتَ هَذِهِ الْحُلَّةَ لِلْوَفْدِ وَلِيَوْمِ الْجُمُعَةِ ‏.‏ فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِنَّمَا يَلْبَسُ هَذَا مَنْ لاَ خَلاَقَ لَهُ فِي الآخِرَةِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“O Messenger of Allah, why don’t you buy this two piece suit (to wear for meeting) the delegations, and on Fridays?” The Messenger of Allah (ﷺ) said: “This is only worn by one who has no share in the Hereafter.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was\\nnarrated from ‘Abdullah bin ‘Umar that ‘Umar bin Khattab saw a\\nsilken two piece suit (being offered for sale). He said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3328", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ، حَدَّثَنَا سَعِيدُ بْنُ أَبِي عَرُوبَةَ، عَنْ قَتَادَةَ، ‏.‏ أَنَّ أَنَسَ بْنَ مَالِكٍ، نَبَّأَهُمْ أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ رَخَّصَ لِلزُّبَيْرِ بْنِ الْعَوَّامِ وَلِعَبْدِ الرَّحْمَنِ بْنِ عَوْفٍ فِي قَمِيصَيْنِ مِنْ حَرِيرٍ مِنْ وَجَعٍ كَانَ بِهِمَا حِكَّةٍ ‏.‏", "bengali": "", "english": "It was narrated from Anas bin Malik that the Messenger of Allah (ﷺ) granted a concession to Zubair bin ‘Awwam and ‘Abdur-Rahman bin ‘Auf, allowing them to wear silk shirts, because of a rash they were suffering from.", "french": "", "indonesian": "", "russian": "", "urdu": "سلمیٰ رضی اللہ عنہا کہتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جس گھر میں کھجور نہ ہو وہ ا", "grades": "", "reference": "", "international_number": "3328", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3329", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا حَفْصُ بْنُ غِيَاثٍ، عَنْ عَاصِمٍ، عَنْ أَبِي عُثْمَانَ، عَنْ عُمَرَ، أَنَّهُ كَانَ يَنْهَى عَنِ الْحَرِيرِ، وَالدِّيبَاجِ، إِلاَّ مَا كَانَ هَكَذَا ثُمَّ أَشَارَ بِإِصْبَعِهِ ثُمَّ الثَّانِيَةِ ثُمَّ الثَّالِثَةِ ثُمَّ الرَّابِعَةِ فَقَالَ كَانَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ يَنْهَانَا عَنْهُ ‏.‏", "bengali": "", "english": "Then he gestured with his finger, then a second, and a third, and a fourth (i.e., the width of four fingers), and he said: “The Messenger of Allah (ﷺ) used to forbid it.”", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم کے پاس جب موسم کا پہلا پھل آتا ت", "grades": "", "reference": "", "international_number": "3329", "narrator_chain": "It was\\nnarrated from ‘Umar that he used to forbid silk and brocade,\\nexcept\\nfor what was like this:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3330", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا وَكِيعٌ، عَنْ مُغِيرَةَ بْنِ زِيَادٍ، عَنْ أَبِي عُمَرَ، مَوْلَى أَسْمَاءَ قَالَ رَأَيْتُ ابْنَ عُمَرَ اشْتَرَى عِمَامَةً لَهَا عَلَمٌ فَدَعَا بِالْجَلَمَيْنِ فَقَصَّهُ فَدَخَلْتُ عَلَى أَسْمَاءَ فَذَكَرْتُ ذَلِكَ لَهَا فَقَالَتْ بُؤْسًا لِعَبْدِ اللَّهِ يَا جَارِيَةُ هَاتِي جُبَّةَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ ‏.‏ فَجَاءَتْ بِجُبَّةٍ مَكْفُوفَةِ الْكُمَّيْنِ وَالْجَيْبِ وَالْفَرْجَيْنِ بِالدِّيبَاجِ ‏.‏", "bengali": "", "english": "“I saw Ibn ‘Umar buying a turban that had some markings, then he called for a pair of scissors and cut that off. I entered upon Asma’ and mentioned that to her, and she said: ‘May ‘Abdullah perish, O girl! Give me the garment of the Messenger of Allah (ﷺ).’ A garment was brought that was hemmed with brocade on the sleeves, necklines and openings (at the front and back).”", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  کچی کھجور اور", "grades": "", "reference": "", "international_number": "3330", "narrator_chain": "It was\\nnarrated that Abu ‘Umar, the freed slave of Asma’, said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3331", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ سُلَيْمَانَ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ، عَنْ يَزِيدَ بْنِ أَبِي حَبِيبٍ، عَنْ عَبْدِ الْعَزِيزِ بْنِ أَبِي الصَّعْبَةِ، عَنْ أَبِي الأَفْلَحِ الْهَمْدَانِيِّ، عَنْ عَبْدِ اللَّهِ بْنِ زُرَيْرٍ الْغَافِقِيِّ، سَمِعْتُهُ يَقُولُ سَمِعْتُ عَلِيَّ بْنَ أَبِي طَالِبٍ، يَقُولُ أَخَذَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ حَرِيرًا بِشِمَالِهِ وَذَهَبًا بِيَمِينِهِ ثُمَّ رَفَعَ بِهِمَا يَدَيْهِ فَقَالَ ‏ ‏ إِنَّ هَذَيْنِ حَرَامٌ عَلَى ذُكُورِ أُمَّتِي حِلٌّ لإِنَاثِهِمْ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“The Messenger of Allah (ﷺ) took hold of some silk in his left hand and some gold in his right, then he raised his hands and said: ‘These two are forbidden for the males of my nation, and permitted to the females.’”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "‘Ali\\nbin Abu Talib said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3332", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ سُلَيْمَانَ، عَنْ يَزِيدَ بْنِ أَبِي زِيَادٍ، عَنْ أَبِي فَاخِتَةَ، حَدَّثَنِي هُبَيْرَةُ بْنُ يَرِيمَ، عَنْ عَلِيٍّ، أَنَّهُ أُهْدِيَ لِرَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ حُلَّةٌ مَكْفُوفَةٌ بِحَرِيرٍ إِمَّا سَدَاؤُهَا وَإِمَّا لُحْمَتُهَا فَأَرْسَلَ بِهَا إِلَىَّ فَأَتَيْتُهُ فَقُلْتُ يَا رَسُولَ اللَّهِ مَا أَصْنَعُ بِهَا أَلْبَسُهَا قَالَ ‏ ‏ لاَ وَلَكِنِ اجْعَلْهَا خُمُرًا بَيْنَ الْفَوَاطِمِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“O Messenger of Allah, what should I do with these? Shall I wear them?” He said: “No, rather make them into head-cloths and give them to the Fatimahs.”**", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was\\nnarrated from ‘Ali that a two-piece suit hemmed with silk,\\neither\\non the wrap or the weft,* was given to the Messenger of Allah\\n(ﷺ),\\nand he sent them to me (‘Ali). I came to him and said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3333", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ سُلَيْمَانَ، عَنِ الإِفْرِيقِيِّ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ رَافِعٍ، عَنْ عَبْدِ اللَّهِ بْنِ عَمْرٍو، قَالَ خَرَجَ عَلَيْنَا رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ وَفِي إِحْدَى يَدَيْهِ ثَوْبٌ مِنْ حَرِيرٍ وَفِي الأُخْرَى ذَهَبٌ فَقَالَ ‏ ‏ إِنَّ هَذَيْنِ مُحَرَّمٌ عَلَى ذُكُورِ أُمَّتِي حِلٌّ لإِنَاثِهِمْ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“The Messenger of Allah (ﷺ) came out to us, and in one of his hands was a garment of silk and in the other was some gold. He said: ‘These are forbidden to the males of my nation and permitted to the females.’”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was\\nnarrated that ‘Abdullah bin ‘Umar said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3334", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا عِيسَى بْنُ يُونُسَ، عَنْ مَعْمَرٍ، عَنِ الزُّهْرِيِّ، عَنْ أَنَسٍ، قَالَ رَأَيْتُ عَلَى زَيْنَبَ بِنْتِ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ قَمِيصَ حَرِيرٍ سِيَرَاءَ ‏.‏", "bengali": "", "english": "“I saw Zainab the daughter of the Messenger of Allah (ﷺ) wearing a shirt of Siyara’ silk.*", "french": "", "indonesian": "", "russian": "", "urdu": "بسر سلمی کے دو بیٹے (رضی اللہ عنہما) کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ہمارے پاس تشریف لائے،", "grades": "", "reference": "", "international_number": "3334", "narrator_chain": "It was\\nnarrated that Anas said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3335", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، عَنْ شَرِيكِ بْنِ عَبْدِ اللَّهِ الْقَاضِي، عَنْ أَبِي إِسْحَاقَ، عَنِ الْبَرَاءِ، قَالَ مَا رَأَيْتُ أَجْمَلَ مِنْ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ مُتَرَجِّلاً فِي حُلَّةٍ حَمْرَاءَ ‏.‏", "bengali": "", "english": "“I never saw anyone more handsome then the Messenger of Allah (ﷺ), with his hair combed, wearing a red two-piece suit.”", "french": "", "indonesian": "", "russian": "", "urdu": "ابوحازم کہتے ہیں کہ  میں نے سہل بن سعد رضی اللہ عنہ سے پوچھا: کیا آپ نے میدہ دیکھا ہے؟ انہوں نے جواب", "grades": "", "reference": "", "international_number": "3335", "narrator_chain": "It was\\nnarrated that Bara’ said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3336", "arabic": "حَدَّثَنَا أَبُو عَامِرٍ عَبْدُ اللَّهِ بْنُ عَامِرِ بْنِ بَرَّادِ بْنِ يُوسُفَ بْنِ أَبِي بُرْدَةَ بْنِ أَبِي مُوسَى الأَشْعَرِيِّ، حَدَّثَنَا زَيْدُ بْنُ الْحُبَابِ، حَدَّثَنَا حُسَيْنُ بْنُ وَاقِدٍ، قَاضِي مَرْوَ حَدَّثَنِي عَبْدُ اللَّهِ بْنُ بُرَيْدَةَ، أَنَّ أَبَاهُ، حَدَّثَهُ قَالَ رَأَيْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَخْطُبُ فَأَقْبَلَ حَسَنٌ وَحُسَيْنٌ عَلَيْهِمَا قَمِيصَانِ أَحْمَرَانِ يَعْثُرَانِ وَيَقُومَانِ فَنَزَلَ النَّبِيُّ ـ صلى الله عليه وسلم ـ فَأَخَذَهُمَا فَوَضَعَهُمَا فِي حِجْرِهِ فَقَالَ ‏\"‏ صَدَقَ اللَّهُ وَرَسُولُهُ ‏{إِنَّمَا أَمْوَالُكُمْ وَأَوْلاَدُكُمْ فِتْنَةٌ}‏ رَأَيْتُ هَذَيْنِ فَلَمْ أَصْبِرْ ‏\"‏ ‏.‏ ثُمَّ أَخَذَ فِي خُطْبَتِهِ ‏.‏", "bengali": "", "english": "I saw the Messenger of Allah (ﷺ) delivering a sermon, and Hasan and Husain came forward, wearing red shirts, stumbling and getting up again. The Prophet (ﷺ) stepped down, picked them up and put them in his lap. Then he said: “Allah and His Messenger have spoken the truth. ‘Your wealth and your children are only a trial.’  I saw these two and I could not be patient. Then he resumed his sermon.”", "french": "", "indonesian": "", "russian": "", "urdu": "ام ایمن رضی اللہ عنہا کہتی ہیں کہ  انہوں نے آٹا چھانا، اور نبی اکرم صلی اللہ علیہ وسلم کے لیے اس کی", "grades": "", "reference": "", "international_number": "3336", "narrator_chain": "‘Abdullah bin Buraidah narrated that his father told him:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3337", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ، عَنْ يَزِيدَ بْنِ أَبِي زِيَادٍ، عَنِ الْحَسَنِ بْنِ سُهَيْلٍ، عَنِ ابْنِ عُمَرَ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنِ الْمُفَدَّمِ ‏.‏ قَالَ يَزِيدُ قُلْتُ لِلْحَسَنِ مَا الْمُفَدَّمُ قَالَ الْمُشْبَعُ بِالْعُصْفُرِ ‏.‏", "bengali": "", "english": "“The Messenger of Allah (ﷺ) forbade Al-Mufaddam.”", "french": "", "indonesian": "", "russian": "", "urdu": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے میدہ کی روٹی ایک آنکھ سے بھی", "grades": "", "reference": "", "international_number": "3337", "narrator_chain": "It was\\nnarrated that Ibn ‘Umar said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3338", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا وَكِيعٌ، عَنْ أُسَامَةَ بْنِ زَيْدٍ، عَنْ عَبْدِ اللَّهِ بْنِ حُنَيْنٍ، قَالَ سَمِعْتُ عَلِيًّا، يَقُولُ نَهَانِي رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ - وَلاَ أَقُولُ نَهَاكُمْ - عَنْ لُبْسِ الْمُعَصْفَرِ ‏.‏", "bengali": "", "english": "“I heard ‘Ali say: ‘The Messenger of Allah (ﷺ) forbade me – and I do not say that he forbade you – from wearing clothes dyed with safflower.’”", "french": "", "indonesian": "", "russian": "", "urdu": "عطا کہتے ہیں کہ  ابوہریرہ رضی اللہ عنہ نے اپنی قوم کی زیارت کی یعنی راوی کا خیال ہے کہ ینانامی بستی", "grades": "", "reference": "", "international_number": "3338", "narrator_chain": "It was\\nnarrated that ‘Abdullah bin Hunain said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3339", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا عِيسَى بْنُ يُونُسَ، عَنِ هِشَامِ بْنِ الْغَازِ، عَنْ عَمْرِو بْنِ شُعَيْبٍ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، قَالَ أَقْبَلْنَا مَعَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ مِنْ ثَنِيَّةِ أَذَاخِرَ فَالْتَفَتَ إِلَىَّ وَعَلَىَّ رَيْطَةٌ مُضَرَّجَةٌ بِالْعُصْفُرِ فَقَالَ ‏\"‏ مَا هَذِهِ ‏\"‏ ‏.‏ فَعَرَفْتُ مَا كَرِهَ فَأَتَيْتُ أَهْلِي وَهُمْ يَسْجُرُونَ تَنُّورَهُمْ فَقَذَفْتُهَا فِيهِ ثُمَّ أَتَيْتُهُ مِنَ الْغَدِ فَقَالَ ‏\"‏ يَا عَبْدَ اللَّهِ مَا فَعَلَتِ الرَّيْطَةُ ‏\"‏ ‏.‏ فَأَخْبَرْتُهُ فَقَالَ ‏\"‏ أَلاَ كَسَوْتَهَا بَعْضَ أَهْلِكَ فَإِنَّهُ لاَ بَأْسَ بِذَلِكَ لِلنِّسَاءِ ‏\"‏ ‏.‏", "bengali": "", "english": "“We came with the Messenger of Allah (ﷺ) was Thaniyyat Adhakhir. He turned to me, and I was wearing a thin cloak dyed with safflower, and said: ‘What is this?’ And I realized that he disliked it. I came to my family when they were heating their oven and threw it (in the oven). Then I came to him the following day and he said: ‘O ‘Abdullah, what happened to the thin cloak?’ I told him (what I had done) and he said: ‘Why did you not give it to some of your family to wear, for there is nothing wrong with it for women.’”", "french": "", "indonesian": "", "russian": "", "urdu": "قتادہ کہتے ہیں کہ  ہم لوگ انس بن مالک رضی اللہ عنہ کے پاس آتے تھے  ( اسحاق کی روایت میں یہ اضافہ ہے", "grades": "", "reference": "", "international_number": "3339", "narrator_chain": "It was\\nnarrated from ‘Amr bin Shu’aib, from his father, that his\\ngrandfather said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3340", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، عَنِ ابْنِ أَبِي لَيْلَى، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ مُحَمَّدِ بْنِ شُرَحْبِيلَ، عَنْ قَيْسِ بْنِ سَعْدٍ، قَالَ أَتَانَا النَّبِيُّ ـ صلى الله عليه وسلم ـ فَوَضَعْنَا لَهُ مَاءً يَتَبَرَّدُ بِهِ فَاغْتَسَلَ ثُمَّ أَتَيْتُهُ بِمِلْحَفَةٍ صَفْرَاءَ فَرَأَيْتُ أَثَرَ الْوَرْسِ عَلَى عُكَنِهِ ‏.‏", "bengali": "", "english": "“The Prophet (ﷺ) came to us and we gave him some water with which to cool down. He bathed, then I brought him a yellow blanket, and I saw the traces of Wars (the yellow dye) on the folds of his stomach.”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  سب سے پہلے ہم نے «فالوذج» کا نام اس وقت سنا جب جبرائیل ع", "grades": "", "reference": "", "international_number": "3340", "narrator_chain": "It was\\nnarrated that Qais bin Sa’d said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3341", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، أَنْبَأَنَا هَمَّامٌ، عَنْ قَتَادَةَ، عَنْ عَمْرِو بْنِ شُعَيْبٍ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ كُلُوا وَاشْرَبُوا وَتَصَدَّقُوا وَالْبَسُوا مَا لَمْ يُخَالِطْهُ إِسْرَافٌ أَوْ مَخِيلَةٌ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“The Messenger of Allah (ﷺ) said: ‘Eat and drink, give charity and wear clothes, as long as that does not involve any extravagance or vanity.’”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was\\nnarrated from ‘Amr bin Shu’aib, from his father, that his\\ngrandfather said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3342", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عَبَادَةَ، وَمُحَمَّدُ بْنُ عَبْدِ الْمَلِكِ الْوَاسِطِيَّانِ، قَالاَ حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، أَنْبَأَنَا شَرِيكٌ، عَنْ عُثْمَانَ بْنِ أَبِي زُرْعَةَ، عَنْ مُهَاجِرٍ، عَنِ ابْنِ عُمَرَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ لَبِسَ ثَوْبَ شُهْرَةٍ أَلْبَسَهُ اللَّهُ يَوْمَ الْقِيَامَةِ ثَوْبَ مَذَلَّةٍ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“The Messenger of Allah (ﷺ) said: ‘Whoever wears a garment of pride and vanity, Allah will clothe him, on the Day of Resurrection, in a garment of humiliation.’”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was\\nnarrated that Ibn ‘Umar said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3343", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الْمَلِكِ بْنِ أَبِي الشَّوَارِبِ، حَدَّثَنَا أَبُو عَوَانَةَ، عَنْ عُثْمَانَ بْنِ الْمُغِيرَةِ، عَنِ الْمُهَاجِرِ، عَنْ عَبْدِ اللَّهِ بْنِ عُمَرَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ لَبِسَ ثَوْبَ شُهْرَةٍ فِي الدُّنْيَا أَلْبَسَهُ اللَّهُ ثَوْبَ مَذَلَّةٍ يَوْمَ الْقِيَامَةِ ثُمَّ أَلْهَبَ فِيهِ نَارًا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“The Messenger of Allah (ﷺ) said: ‘Whoever wears a garment of pride and vanity in this world, Allah will clothe him in a garment of humiliation on the Day of Resurrection, then set it ablaze.’”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was\\nnarrated that ‘Abdullah bin ‘Umar said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3344", "arabic": "حَدَّثَنَا الْعَبَّاسُ بْنُ يَزِيدَ الْبَحْرَانِيُّ، حَدَّثَنَا وَكِيعُ بْنُ مُحْرِزٍ النَّاجِيُّ، حَدَّثَنَا عُثْمَانُ بْنُ جَهْمٍ، عَنْ زِرِّ بْنِ حُبَيْشٍ، عَنْ أَبِي ذَرٍّ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ مَنْ لَبِسَ ثَوْبَ شُهْرَةٍ أَعْرَضَ اللَّهُ عَنْهُ حَتَّى يَضَعَهُ مَتَى وَضَعَهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“Whoever wears a garment of pride and vanity, Allah will turn away from him until he takes it off.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was\\nnarrated from Abu Dharr that the Prophet (ﷺ) said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3345", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ زَيْدِ بْنِ أَسْلَمَ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ وَعْلَةَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ أَيُّمَا إِهَابٍ دُبِغَ فَقَدْ طَهُرَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“I heard the Messenger of Allah (ﷺ) say: ‘Any skin that has been tanned has been purified.’”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was\\nnarrated that Ibn ‘Abbas said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3346", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ الزُّهْرِيِّ، عَنْ عُبَيْدِ اللَّهِ بْنِ عَبْدِ اللَّهِ، عَنِ ابْنِ عَبَّاسٍ، عَنْ مَيْمُونَةَ، أَنَّ شَاةً، لِمَوْلاَةِ مَيْمُونَةَ مَرَّ بِهَا - يَعْنِي النَّبِيَّ ـ صلى الله عليه وسلم ـ - قَدْ أُعْطِيَتْهَا مِنَ الصَّدَقَةِ مَيْتَةً فَقَالَ ‏\"‏ هَلاَّ أَخَذُوا إِهَابَهَا فَدَبَغُوهُ فَانْتَفَعُوا بِهِ ‏\"‏ ‏.‏ فَقَالُوا يَا رَسُولَ اللَّهِ إِنَّهَا مَيْتَةٌ ‏.‏ قَالَ ‏\"‏ إِنَّمَا حَرُمَ أَكْلُهَا ‏\"‏ ‏.‏", "bengali": "", "english": "“Why don’t they take its skin and ten it, and make us of it?” They said: “O Messenger of Allah, it is dead meat.”* He said: “It is only unlawful to eat it.”", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  محمد صلی اللہ علیہ وسلم کے اہل و عیال نے کبھی بھی جو کی", "grades": "", "reference": "", "international_number": "3346", "narrator_chain": "It was\\nnarrated from Maimunah that he (meaning the Prophet (ﷺ))\\npassed by\\na dead sheep belonging to the freed slave woman of Maimunah,\\nthat had\\nbeen given to her in charity. He said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3347", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ سُلَيْمَانَ، عَنْ لَيْثٍ، عَنْ شَهْرِ بْنِ حَوْشَبٍ، عَنْ سَلْمَانَ، قَالَ كَانَ لِبَعْضِ أُمَّهَاتِ الْمُؤْمِنِينَ شَاةٌ فَمَاتَتْ فَمَرَّ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَلَيْهَا فَقَالَ ‏ ‏ مَا ضَرَّ أَهْلَ هَذِهِ لَوِ انْتَفَعُوا بِإِهَابِهَا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“One of the Mothers of the Believers had a sheep that died. The Messenger of Allah (ﷺ) passed by it and said: ‘It would not have harmed its owners if they had made use of its hide.’”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was\\nnarrated that Salman said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3348", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ، عَنْ مَالِكِ بْنِ أَنَسٍ، عَنْ يَزِيدَ بْنِ قُسَيْطٍ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ أُمِّهِ، عَنْ عَائِشَةَ، قَالَتْ أَمَرَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ أَنْ يُسْتَمْتَعَ بِجُلُودِ الْمَيْتَةِ إِذَا دُبِغَتْ ‏.‏", "bengali": "", "english": "“The Messenger of Allah (ﷺ) commanded that use should be made of the skins of dead animals, if they were tanned.”", "french": "", "indonesian": "", "russian": "", "urdu": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم اون کا لباس اور پیوند لگا جوتا پہ", "grades": "", "reference": "", "international_number": "3348", "narrator_chain": "It was\\nnarrated that ‘Aishah said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3349", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا جَرِيرٌ، عَنْ مَنْصُورٍ، ح وَحَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ، عَنِ الشَّيْبَانِيِّ، ح وَحَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا غُنْدَرٌ، عَنْ شُعْبَةَ، كُلُّهُمْ عَنِ الْحَكَمِ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِي لَيْلَى، عَنْ عَبْدِ اللَّهِ بْنِ عُكَيْمٍ، قَالَ أَتَانَا كِتَابُ النَّبِيِّ ـ صلى الله عليه وسلم ـ ‏ ‏ أَنْ لاَ تَنْتَفِعُوا مِنَ الْمَيْتَةِ بِإِهَابٍ وَلاَ عَصَبٍ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“There came to us a letter from the Prophet (ﷺ) (saying): ‘No not make use of the untanned skin and sinew of dead animals.’”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was\\nnarrated that ‘Abdullah bin ‘Ukaym said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3350", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، عَنْ سُفْيَانَ، عَنْ خَالِدٍ الْحَذَّاءِ، عَنْ عَبْدِ اللَّهِ بْنِ الْحَارِثِ، عَنْ عَبْدِ اللَّهِ بْنِ الْعَبَّاسِ، قَالَ كَانَ لِنَعْلِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قِبَالاَنِ مَثْنِيٌّ شِرَاكُهُمَا ‏.‏", "bengali": "", "english": "“The sandals of the Prophet (ﷺ) had two thongs doubled around their straps.”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  ایک شخص نے نبی اکرم صلی اللہ علیہ وسلم کے پاس ڈکار لی، تو", "grades": "", "reference": "", "international_number": "3350", "narrator_chain": "It was\\nnarrated that ‘Abdullah bin ‘Abbas said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3351", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، عَنْ هَمَّامٍ، عَنْ قَتَادَةَ، عَنْ أَنَسٍ، قَالَ كَانَ لِنَعْلِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قِبَالاَنِ ‏.‏", "bengali": "", "english": "“The sandals of the Prophet (ﷺ) had two thongs.”", "french": "", "indonesian": "", "russian": "", "urdu": "عطیہ بن عامر جہنی کہتے ہیں کہ  سلمان فارسی رضی اللہ عنہ کو کھانا کھانے پر مجبور کیا گیا تو میں نے ان", "grades": "", "reference": "", "international_number": "3351", "narrator_chain": "It was\\nnarrated that Anas said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3352", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا وَكِيعٌ، عَنْ شُعْبَةَ، عَنْ مُحَمَّدِ بْنِ زِيَادٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِذَا انْتَعَلَ أَحَدُكُمْ فَلْيَبْدَأْ بِالْيُمْنَى وَإِذَا خَلَعَ فَلْيَبْدَأْ بِالْيُسْرَى ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“When anyone of you puts on his sandals, let him start with the right, and when he takes them off, let him start with the left.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was\\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\\nsaid:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3353", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ إِدْرِيسَ، عَنِ ابْنِ عَجْلاَنَ، عَنْ سَعِيدِ بْنِ أَبِي سَعِيدٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لاَ يَمْشِي أَحَدُكُمْ فِي نَعْلٍ وَاحِدٍ وَلاَ خُفٍّ وَاحِدٍ لِيَخْلَعْهُمَا جَمِيعًا أَوْ لِيَمْشِ فِيهِمَا جَمِيعًا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said; “None of you should walk in one sandal or in one leather sock. Let him take them both off or walk in both of them.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3354", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، عَنِ الأَعْمَشِ، عَنْ أَبِي صَالِحٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ أَنْ يَنْتَعِلَ الرَّجُلُ قَائِمًا ‏.‏", "bengali": "", "english": "“The Messenger of Allah (ﷺ) forbade putting on sandals whilst standing.”", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم فرماتے تھے: «اللهم إني أعوذ بك من ال", "grades": "", "reference": "", "international_number": "3354", "narrator_chain": "It was\\nnarrated that Abu Hurairah said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3355", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، عَنْ سُفْيَانَ، عَنْ عَبْدِ اللَّهِ بْنِ دِينَارٍ، عَنِ ابْنِ عُمَرَ، قَالَ نَهَى النَّبِيُّ ـ صلى الله عليه وسلم ـ أَنْ يَنْتَعِلَ الرَّجُلُ قَائِمًا ‏.‏", "bengali": "", "english": "“The Prophet (ﷺ) forbade putting on sandals whilst standing.”", "french": "", "indonesian": "", "russian": "", "urdu": "جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  شام کا کھانا مت ترک کرو اگرچ", "grades": "", "reference": "", "international_number": "3355", "narrator_chain": "It was\\nnarrated that Ibn ‘Umar said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3356", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا دَلْهَمُ بْنُ صَالِحٍ الْكِنْدِيُّ، عَنْ حُجَيْرِ بْنِ عَبْدِ اللَّهِ الْكِنْدِيِّ، عَنِ ابْنِ بُرَيْدَةَ، عَنْ أَبِيهِ، أَنَّ النَّجَاشِيَّ، أَهْدَى لِرَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ خُفَّيْنِ سَاذَجَيْنِ أَسْوَدَيْنِ فَلَبِسَهُمَا ‏.‏", "bengali": "", "english": "It was narrated from Ibn Buraidah, from his father, that an-Najashi sent a pair of pure black Khuff as a gift to the Prophet (ﷺ) of, which he wore.", "french": "", "indonesian": "", "russian": "", "urdu": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس طرح چھری اونٹ کے ک", "grades": "", "reference": "", "international_number": "3356", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3357", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ الزُّهْرِيِّ، سَمِعَ أَبَا سَلَمَةَ، وَسُلَيْمَانَ بْنَ يَسَارٍ، يُخْبِرَانِ عَنْ أَبِي هُرَيْرَةَ، يَبْلُغُ بِهِ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ إِنَّ الْيَهُودَ وَالنَّصَارَى لاَ يَصْبُغُونَ فَخَالِفُوهُمْ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“The Jews and the Christians do not dye (their hair), so differ from them.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was\\nnarrated that Abu Hurairah attributed to the Prophet (ﷺ):", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3358", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ إِدْرِيسَ، عَنِ الأَجْلَحِ، عَنْ عَبْدِ اللَّهِ بْنِ بُرَيْدَةَ، عَنْ أَبِي الأَسْوَدِ الدِّيلِيِّ، عَنْ أَبِي ذَرٍّ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِنَّ أَحْسَنَ مَا غَيَّرْتُمْ بِهِ الشَّيْبَ الْحِنَّاءُ وَالْكَتَمُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“The best things with which you change gray hair are henna and Katam.”*", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was\\nnarrated from Abu Dharr that the Messenger of Allah (ﷺ)\\nsaid:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3359", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا يُونُسُ بْنُ مُحَمَّدٍ، حَدَّثَنَا سَلاَّمُ بْنُ أَبِي مُطِيعٍ، عَنْ عُثْمَانَ بْنِ مَوْهَبٍ، قَالَ دَخَلْتُ عَلَى أُمِّ سَلَمَةَ ‏.‏ قَالَ فَأَخْرَجَتْ إِلَىَّ شَعَرًا مِنْ شَعَرِ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ مَخْضُوبًا بِالْحِنَّاءِ وَالْكَتَمِ ‏.‏", "bengali": "", "english": "“I entered upon Umm Salamah and she brought out for me a hair of the Messenger of Allah (ﷺ), which was dyed with henna and Katam.”", "french": "", "indonesian": "", "russian": "", "urdu": "علی رضی اللہ عنہ کہتے ہیں کہ  میں نے کھانا تیار کیا، اور رسول اللہ صلی اللہ علیہ وسلم کو مدعو کیا، آ", "grades": "", "reference": "", "international_number": "3359", "narrator_chain": "It was\\nnarrated that ‘Uthman bin Mawhab said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3360", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا إِسْمَاعِيلُ ابْنُ عُلَيَّةَ، عَنْ لَيْثٍ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، قَالَ جِيءَ بِأَبِي قُحَافَةَ يَوْمَ الْفَتْحِ إِلَى النَّبِيِّ ـ صلى الله عليه وسلم ـ وَكَأَنَّ رَأْسَهُ ثَغَامَةٌ فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ اذْهَبُوا بِهِ إِلَى بَعْضِ نِسَائِهِ فَلْتُغَيِّرْهُ وَجَنِّبُوهُ السَّوَادَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“Abu Quhaifah was brought to the Prophet (ﷺ) on the Day of the Conquest (of Makkah), and his head was all white. The Messenger of Allah (ﷺ) said: ‘Take him to some of his womenfolk and let them change this, but avoid black.’”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was\\nnarrated from Jabir that he said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3361", "arabic": "حَدَّثَنَا أَبُو هُرَيْرَةَ الصَّيْرَفِيُّ، مُحَمَّدُ بْنُ فِرَاسٍ حَدَّثَنَا عُمَرُ بْنُ الْخَطَّابِ بْنِ زَكَرِيَّا الرَّاسِبِيُّ، حَدَّثَنَا دَفَّاعُ بْنُ دَغْفَلٍ السَّدُوسِيُّ، عَنْ عَبْدِ الْحَمِيدِ بْنِ صَيْفِيٍّ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، صُهَيْبِ الْخَيْرِ قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِنَّ أَحْسَنَ مَا اخْتَضَبْتُمْ بِهِ لَهَذَا السَّوَادُ أَرْغَبُ لِنِسَائِكُمْ فِيكُمْ وَأَهْيَبُ لَكُمْ فِي صُدُورِ عَدُوِّكُمْ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“The Messenger of Allah (ﷺ) said: ‘The best thing with which you can dye your hair is this black (dye). It makes your women desire you and creates fear in the hearts of your enemies.’”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was\\nnarrated that Suhaib Al-Khair said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3362", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو أُسَامَةَ، عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ سَعِيدِ بْنِ أَبِي سَعِيدٍ، أَنَّ عُبَيْدَ بْنَ جُرَيْجٍ، سَأَلَ ابْنَ عُمَرَ قَالَ رَأَيْتُكَ تُصَفِّرُ لِحْيَتَكَ بِالْوَرْسِ فَقَالَ ابْنُ عُمَرَ أَمَّا تَصْفِيرِي لِحْيَتِي فَإِنِّي رَأَيْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يُصَفِّرُ لِحْيَتَهُ ‏.‏", "bengali": "", "english": "“I see that you dye your beard yellow with Wars.” Ibn ‘Umar said: “As for my dyeing of my beard yellow with Wars, I saw the Messenger of Allah (ﷺ) dyeing his beard yellow.”", "french": "", "indonesian": "", "russian": "", "urdu": "ابوذر رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جب تم سالن پکاؤ تو اس میں شو", "grades": "", "reference": "", "international_number": "3362", "narrator_chain": "It was\\nnarrated from Sa’eed bin Abu Sa’eed that ‘Ubaid bin Juraij\\nasked Ibn ‘Umar:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3363", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ، حَدَّثَنَا مُحَمَّدُ بْنُ طَلْحَةَ، عَنْ حُمَيْدِ بْنِ وَهْبٍ، عَنِ ابْنِ طَاوُسٍ، عَنْ طَاوُسٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ مَرَّ النَّبِيُّ ـ صلى الله عليه وسلم ـ عَلَى رَجُلٍ قَدْ خَضَبَ بِالْحِنَّاءِ فَقَالَ ‏\"‏ مَا أَحْسَنَ هَذَا ‏\"‏ ‏.‏ ثُمَّ مَرَّ بِآخَرَ قَدْ خَضَبَ بِالْحِنَّاءِ وَالْكَتَمِ فَقَالَ ‏\"‏ هَذَا أَحْسَنُ مِنْ هَذَا ‏\"‏ ‏.‏ ثُمَّ مَرَّ بِآخَرَ قَدْ خَضَبَ بِالصُّفْرَةِ فَقَالَ ‏\"‏ هَذَا أَحْسَنُ مِنْ هَذَا كُلِّهِ ‏\"‏ ‏.‏ قَالَ وَكَانَ طَاوُسٌ يُصَفِّرُ ‏.‏", "bengali": "", "english": "“The Prophet (ﷺ) passed by a man who had dyed his hair with henna and said: ‘How handsome this is!’ Then he passed by another who had dyed his hair with henna and Katam, and said: ‘This one is more handsome than that one.’ Then he passed by another who had dyed his hair yellow and said: ‘This one is more handsome than all of them.’”", "french": "", "indonesian": "", "russian": "", "urdu": "معدان بن أبی طلحہ یعمری رضی اللہ عنہ سے روایت ہے کہ  عمر بن خطاب رضی اللہ عنہ جمعہ کے دن خطبے کے لی", "grades": "", "reference": "", "international_number": "3363", "narrator_chain": "It was\\nnarrated that Ibn ‘Abbas said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3364", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، حَدَّثَنَا أَبُو دَاوُدَ، حَدَّثَنَا زُهَيْرٌ، عَنْ أَبِي إِسْحَاقَ، عَنْ أَبِي جُحَيْفَةَ، قَالَ رَأَيْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ هَذِهِ مِنْهُ بَيْضَاءُ ‏.‏ يَعْنِي عَنْفَقَتَهُ ‏.‏", "bengali": "", "english": "“I saw the Messenger of Allah (ﷺ), and this part of his hair was white” – meaning the tuft of hair between the lower lip and the chin.", "french": "", "indonesian": "", "russian": "", "urdu": "ام ایوب رضی اللہ عنہا کہتی ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم کے لیے کھانا تیار کیا، اس میں", "grades": "", "reference": "", "international_number": "3364", "narrator_chain": "It was\\nnarrated that Abu Juhaifah said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3365", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، حَدَّثَنَا خَالِدُ بْنُ الْحَارِثِ، وَابْنُ أَبِي عَدِيٍّ، عَنْ حُمَيْدٍ، قَالَ سُئِلَ أَنَسُ بْنُ مَالِكٍ أَخَضَبَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ إِنَّهُ لَمْ يَرَ مِنَ الشَّيْبِ إِلاَّ نَحْوَ سَبْعَةَ عَشَرَ أَوْ عِشْرِينَ شَعَرَةً فِي مُقَدَّمِ لِحْيَتِهِ ‏.‏", "bengali": "", "english": "“Anas bin Malik was asked: ‘Did the Messenger of Allah (ﷺ) dye his hair?’ He said: ‘He did not have any white hair apart from approximately seventeen or twenty hairs at the front of his beard.’”", "french": "", "indonesian": "", "russian": "", "urdu": "جابر رضی اللہ عنہ سے روایت ہے کہ  کچھ لوگ نبی اکرم صلی اللہ علیہ وسلم کی خدمت میں حاضر ہوئے، آپ کو ا", "grades": "", "reference": "", "international_number": "3365", "narrator_chain": "It was\\nnarrated that Humaid said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3366", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عُمَرَ بْنِ الْوَلِيدِ الْكِنْدِيُّ، حَدَّثَنَا يَحْيَى بْنُ آدَمَ، عَنْ شَرِيكٍ، عَنْ عُبَيْدِ اللَّهِ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ كَانَ شَيْبُ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ نَحْوَ عِشْرِينَ شَعَرَةً ‏.‏", "bengali": "", "english": "“The white hair of the Prophet (ﷺ) numbered approximately twenty.”", "french": "", "indonesian": "", "russian": "", "urdu": "دخین حجری سے روایت ہے کہا انہوں نے عقبہ بن عامر جہنی رضی اللہ عنہ کو کہتے سنا کہ  رسول اللہ صلی اللہ", "grades": "", "reference": "", "international_number": "3366", "narrator_chain": "It was\\nnarrated that Ibn ‘Umar said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3367", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ ابْنِ أَبِي نَجِيحٍ، عَنْ مُجَاهِدٍ، قَالَ قَالَتْ أُمُّ هَانِئٍ دَخَلَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ مَكَّةَ وَلَهُ أَرْبَعُ غَدَائِرَ ‏.‏ تَعْنِي ضَفَائِرَ ‏.‏", "bengali": "", "english": "“Umm Hani said: ‘When the Messenger of Allah (ﷺ) entered Makkah he had four braids.’”", "french": "", "indonesian": "", "russian": "", "urdu": "سلمان فارسی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم سے گھی، پنیر اور جنگلی گدھے کے با", "grades": "", "reference": "", "international_number": "3367", "narrator_chain": "It was\\nnarrated that Mujahid said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3368", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَحْيَى بْنُ آدَمَ، عَنْ إِبْرَاهِيمَ بْنِ سَعْدٍ، عَنِ الزُّهْرِيِّ، عَنْ عُبَيْدِ اللَّهِ بْنِ عَبْدِ اللَّهِ، عَنِ ابْنِ عَبَّاسٍ، قَالَ كَانَ أَهْلُ الْكِتَابِ يَسْدُلُونَ أَشْعَارَهُمْ وَكَانَ الْمُشْرِكُونَ يَفْرِقُونَ وَكَانَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ يُحِبُّ مُوَافَقَةَ أَهْلِ الْكِتَابِ ‏.‏ قَالَ فَسَدَلَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ نَاصِيَتَهُ ثُمَّ فَرَقَ بَعْدُ ‏.‏", "bengali": "", "english": "“The People of the Book used to let their hair hang down, and the idolaters used to part their hair. The Messenger of Allah (ﷺ) liked to be more like the People of the Book. So the Messenger of Allah (ﷺ) let his forelock hang down, then after that he parted it.”", "french": "", "indonesian": "", "russian": "", "urdu": "نعمان بن بشیر رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کے پاس طائف سے انگور ہدیہ میں", "grades": "", "reference": "", "international_number": "3368", "narrator_chain": "It was\\nnarrated that Ibn ‘Abbas said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3369", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ، عَنْ إِبْرَاهِيمَ بْنِ سَعْدٍ، عَنِ ابْنِ إِسْحَاقَ، عَنْ يَحْيَى بْنِ عَبَّادٍ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، قَالَتْ كُنْتُ أَفْرِقُ خَلْفَ يَافُوخِ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ ثُمَّ أَسْدِلُ نَاصِيَتَهُ ‏.‏", "bengali": "", "english": "“I used to part the hair of the Messenger of Allah (ﷺ) behind his crown, and let his forelock hang down.”", "french": "", "indonesian": "", "russian": "", "urdu": "طلحہ رضی اللہ عنہ کہتے ہیں کہ  میں نبی اکرم صلی اللہ علیہ وسلم کی خدمت میں حاضر ہوا، اور آپ کے ہاتھ", "grades": "", "reference": "", "international_number": "3369", "narrator_chain": "It was\\nnarrated that ‘Aishah said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3370", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، أَنْبَأَنَا جَرِيرُ بْنُ حَازِمٍ، عَنْ قَتَادَةَ، عَنْ أَنَسٍ، قَالَ كَانَ شَعَرُ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ شَعَرًا رَجِلاً بَيْنَ أُذُنَيْهِ وَمَنْكِبَيْهِ.", "bengali": "", "english": "“The hair of the Messenger of Allah (ﷺ) was wavy, and (hung down) between his ears and his shoulders.”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے اس بات سے منع فرمایا ہے ک", "grades": "", "reference": "", "international_number": "3370", "narrator_chain": "It was\\nnarrated that Anas said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3371", "arabic": "حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ، حَدَّثَنَا ابْنُ أَبِي فُدَيْكٍ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِي الزِّنَادِ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، قَالَتْ كَانَ لِرَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ شَعَرٌ دُونَ الْجُمَّةِ وَفَوْقَ الْوَفْرَةِ.‏", "bengali": "", "english": "“The Messenger of Allah (ﷺ) had hair that came between his earlobes and his shoulders.”", "french": "", "indonesian": "", "russian": "", "urdu": "ابو الدرداء رضی اللہ عنہ کہتے ہیں کہ  میرے خلیل  ( جگری دوست )  رسول اللہ صلی اللہ علیہ وسلم نے مجھے", "grades": "", "reference": "", "international_number": "3371", "narrator_chain": "It was\\nnarrated that ‘Aishah said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3372", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا مُعَاوِيَةُ بْنُ هِشَامٍ، وَسُفْيَانُ بْنُ عُقْبَةَ، عَنْ سُفْيَانَ، عَنْ عَاصِمِ بْنِ كُلَيْبٍ، عَنْ أَبِيهِ، عَنْ وَائِلِ بْنِ حُجْرٍ، قَالَ رَآنِيَ النَّبِيُّ ـ صلى الله عليه وسلم ـ وَلِي شَعَرٌ طَوِيلٌ فَقَالَ ‏\"‏ ذُبَابٌ ذُبَابٌ ‏\"‏ ‏.‏ فَانْطَلَقْتُ فَأَخَذْتُهُ فَرَآنِيَ النَّبِيُّ ـ صلى الله عليه وسلم ـ فَقَالَ ‏\"‏ إِنِّي لَمْ أَعْنِكَ وَهَذَا أَحْسَنُ ‏\"‏ ‏.‏", "bengali": "", "english": "“The Prophet (ﷺ) saw me when I had long hair. He said: ‘Bad news, bad news!’ So I went away and cut it short. Then the Prophet (ﷺ) saw me and said: ‘I did not mean you, but this is better.’”", "french": "", "indonesian": "", "russian": "", "urdu": "خباب بن ارت رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  شراب سے بچو، اس لیے ک", "grades": "", "reference": "", "international_number": "3372", "narrator_chain": "It was\\nnarrated that Wa’il bin Hujr said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3373", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا أَبُو أُسَامَةَ، عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ عُمَرَ بْنِ نَافِعٍ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ نَهَى رَسُولُ اللَّهُ ـ صلى الله عليه وسلم ـ عَنِ الْقَزَعِ ‏.‏ قَالَ وَمَا الْقَزَعُ قَالَ أَنْ يُحْلَقَ مِنْ رَأْسِ الصَّبِيِّ مَكَانٌ وَيُتْرَكَ مَكَانٌ ‏.‏", "bengali": "", "english": "“The Messenger of Allah (ﷺ) forbade Qaza’.” He (Nafi’) said: “What is Qaza’?” He said: “It means shaving part of a child’s head and leaving another part.”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص دنیا م", "grades": "", "reference": "", "international_number": "3373", "narrator_chain": "It was\\nnarrated from Nafi’ that Ibn ‘Umar said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3374", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا شَبَابَةُ، حَدَّثَنَا شُعْبَةُ، عَنْ عَبْدِ اللَّهِ بْنِ دِينَارٍ، عَنِ ابْنِ عُمَرَ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنِ الْقَزَعِ ‏.‏", "bengali": "", "english": "“The Messenger of Allah (ﷺ) forbade Qaza’.”", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ بیان کرتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو دنیا میں شراب پئ", "grades": "", "reference": "", "international_number": "3374", "narrator_chain": "It was\\nnarrated that Ibn ‘Umar said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3375", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ أَيُّوبَ بْنِ مُوسَى، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ اتَّخَذَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ خَاتَمًا مِنْ وَرِقٍ ثُمَّ نَقَشَ فِيهِ مُحَمَّدٌ رَسُولُ اللَّهِ فَقَالَ ‏ ‏ لاَ يَنْقُشْ أَحَدٌ عَلَى نَقْشِ خَاتَمِي هَذَا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“The Messenger of Allah (ﷺ) wore a ring of silver, then he had engraved on it (the words) ‘Muhammad Rasul Allah’ (Muhammad the Messenger of Allah). And he said: ‘No one should have his ring engraved like this ring of mine.’”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was\\nnarrated that Ibn ‘Umar said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3376", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا إِسْمَاعِيلُ ابْنُ عُلَيَّةَ، عَنْ عَبْدِ الْعَزِيزِ بْنِ صُهَيْبٍ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ اصْطَنَعَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ خَاتَمًا فَقَالَ ‏ ‏ إِنَّا قَدِ اصْطَنَعْنَا خَاتَمًا وَنَقَشْنَا فِيهِ نَقْشًا فَلاَ يَنْقُشَنَّ عَلَيْهِ أَحَدٌ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“The Messenger of Allah (ﷺ) had a ring made for him, and he said: ‘I have had a ring made for me and had it engraved, and no one should make a ring with similar engraving.’”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was\\nnarrated that Anas bin Malik said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3377", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا عُثْمَانُ بْنُ عُمَرَ، حَدَّثَنَا يُونُسُ، عَنِ الزُّهْرِيِّ، عَنْ أَنَسِ بْنِ مَالِكٍ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ اتَّخَذَ خَاتَمًا مِنْ فِضَّةٍ لَهُ فَصٌّ حَبَشِيٌّ وَنَقْشُهُ مُحَمَّدٌ رَسُولُ اللَّهِ ‏.‏", "bengali": "", "english": "‘Muhammad Rasul Allah’ (Muhammad the Messenger of Allah).”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شراب پی کر م", "grades": "", "reference": "", "international_number": "3377", "narrator_chain": "It was\\nnarrated from Anas bin Malik that the Messenger of Allah (ﷺ)\\nwore a\\nring of silver, in which was an Ethiopian gemstone and the\\ninscription:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3378", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، عَنْ عُبَيْدِ اللَّهِ، عَنْ نَافِعِ بْنِ جُبَيْرٍ، مَوْلَى عَلِيٍّ عَنْ عَلِيٍّ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنِ التَّخَتُّمِ بِالذَّهَبِ ‏.‏", "bengali": "", "english": "“The Messenger of Allah (ﷺ) forbade wearing gold rings.”", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  شراب ان دو درختوں: کھجور", "grades": "", "reference": "", "international_number": "3378", "narrator_chain": "It was\\nnarrated that ‘Ali said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3379", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ، عَنْ يَزِيدَ بْنِ أَبِي زِيَادٍ، عَنِ الْحَسَنِ بْنِ سُهَيْلٍ، عَنِ ابْنِ عُمَرَ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنْ خَاتَمِ الذَّهَبِ ‏.‏", "bengali": "", "english": "“The Messenger of Allah (ﷺ) forbade gold rings.”", "french": "", "indonesian": "", "russian": "", "urdu": "نعمان بن بشیر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  شراب کئی چیزوں سے ب", "grades": "", "reference": "", "international_number": "3379", "narrator_chain": "It was\\nnarrated that Ibn ‘Umar said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3380", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ، عَنْ يَحْيَى بْنِ عَبَّادِ بْنِ عَبْدِ اللَّهِ بْنِ الزُّبَيْرِ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ أُمِّ الْمُؤْمِنِينَ، قَالَتْ أَهْدَى النَّجَاشِيُّ إِلَى رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ حَلْقَةً فِيهَا خَاتَمُ ذَهَبٍ فِيهِ فَصٌّ حَبَشِيٌّ فَأَخَذَهُ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ بِعُودٍ وَإِنَّهُ لَمُعْرِضٌ عَنْهُ أَوْ بِبَعْضِ أَصَابِعِهِ ثُمَّ دَعَا ابْنَةَ ابْنَتِهِ أُمَامَةَ بِنْتَ أَبِي الْعَاصِ فَقَالَ ‏ ‏ تَحَلَّىْ بِهَذَا يَا بُنَيَّةُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“Najashi sent some jewelry as a gift to the Messenger of Allah (ﷺ). Among that was a gold ring with an Ethiopian gemstone. The Messenger of Allah (ﷺ) picked it up with a stick – as if he found it distasteful – or with one of his fingers, then he called for his daughter, Umamah bint Abul-‘As, and said: ‘Wear this, O my daughter.’”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was\\nnarrated that ‘Aishah the Mother of the Believers said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3381", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ أَيُّوبَ بْنِ مُوسَى، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ كَانَ يَجْعَلُ فَصَّ خَاتَمِهِ مِمَّا يَلِي كَفَّهُ ‏.‏", "bengali": "", "english": "It was narrated from Ibn ‘Umar that the Prophet (ﷺ) used to wear (his ring) with the stone nearest his palm.", "french": "", "indonesian": "", "russian": "", "urdu": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے دس قسم کے لوگوں پر شراب کی وجہ", "grades": "", "reference": "", "international_number": "3381", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3382", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا إِسْمَاعِيلُ بْنُ أَبِي أُوَيْسٍ، حَدَّثَنِي سُلَيْمَانُ بْنُ بِلاَلٍ، عَنْ يُونُسَ بْنِ يَزِيدَ الأَيْلِيِّ، عَنِ ابْنِ شِهَابٍ، عَنْ أَنَسِ بْنِ مَالِكٍ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ لَبِسَ خَاتَمَ فِضَّةٍ فِيهِ فَصٌّ حَبَشِيٌّ كَانَ يَجْعَلُ فَصَّهُ فِي بَطْنِ كَفِّهِ ‏.‏", "bengali": "", "english": "It was narrated from Anas bin Malik that the Messenger of Allah (ﷺ) wore a silver ring with an Ethiopian gemstone, and he used to ear the stone in towards his palm.", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  جب سود کے سلسلے میں سورۃ البقرہ کی آخری آیات نازل ہوئ", "grades": "", "reference": "", "international_number": "3382", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3383", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، عَنْ إِبْرَاهِيمَ بْنِ الْفَضْلِ، عَنْ عَبْدِ اللَّهِ بْنِ مُحَمَّدِ بْنِ عَقِيلٍ، عَنْ عَبْدِ اللَّهِ بْنِ جَعْفَرٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ كَانَ يَتَخَتَّمُ فِي يَمِينِهِ ‏.‏", "bengali": "", "english": "It was narrated from ‘Abdullah bin Ja’far that the Prophet (ﷺ) used to wear a ring on his right hand.", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  عمر رضی اللہ عنہ کو خبر ملی کہ سمرہ رضی اللہ عنہ نے شراب", "grades": "", "reference": "", "international_number": "3383", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3384", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ إِدْرِيسَ، عَنْ عَاصِمٍ، عَنْ أَبِي بُرْدَةَ، عَنْ عَلِيٍّ، قَالَ نَهَانِي رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ أَنْ أَتَخَتَّمَ فِي هَذِهِ وَفِي هَذِهِ يَعْنِي الْخِنْصَرَ وَالإِبْهَامَ ‏.‏", "bengali": "", "english": "“The Messenger of Allah (ﷺ) forbade me to wear a ring on this and on this,” meaning the little finger and the thumb.", "french": "", "indonesian": "", "russian": "", "urdu": "ابوامامہ باہلی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  رات اور دن یعنی زم", "grades": "", "reference": "", "international_number": "3384", "narrator_chain": "It was\\nnarrated that ‘Ali said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3385", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ الزُّهْرِيِّ، عَنْ عُبَيْدِ اللَّهِ بْنِ عَبْدِ اللَّهِ، عَنِ ابْنِ عَبَّاسٍ، عَنْ أَبِي طَلْحَةَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ لاَ تَدْخُلُ الْمَلاَئِكَةُ بَيْتًا فِيهِ كَلْبٌ وَلاَ صُورَةٌ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“The angels do not enter a house in which there is a dog or an image.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was\\nnarrated from Abu Talhah that the Prophet (ﷺ) said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3386", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا غُنْدَرٌ، عَنْ شُعْبَةَ، عَنْ عَلِيِّ بْنِ مُدْرِكٍ، عَنْ أَبِي زُرْعَةَ، عَنْ عَبْدِ اللَّهِ بْنِ نُجَىٍّ، عَنْ أَبِيهِ، عَنْ عَلِيِّ بْنِ أَبِي طَالِبٍ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ إِنَّ الْمَلاَئِكَةَ لاَ تَدْخُلُ بَيْتًا فِيهِ كَلْبٌ وَلاَ صُورَةٌ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“The angels do not enter a house in which there is a dog or an image.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was\\nnarrated from ‘Ali bin Abu Talib that the Prophet (ﷺ) said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3387", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو، عَنْ أَبِي سَلَمَةَ، عَنْ عَائِشَةَ، قَالَتْ وَاعَدَ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ جِبْرِيلُ عَلَيْهِ السَّلاَمُ فِي سَاعَةٍ يَأْتِيهِ فِيهَا فَرَاثَ عَلَيْهِ فَخَرَجَ النَّبِيُّ ـ صلى الله عليه وسلم ـ فَإِذَا هُوَ بِجِبْرِيلَ قَائِمٌ عَلَى الْبَابِ فَقَالَ ‏ ‏ مَا مَنَعَكَ أَنْ تَدْخُلَ ‏\"\"‏ ‏.‏ قَالَ إِنَّ فِي الْبَيْتِ كَلْبًا وَإِنَّا لاَ نَدْخُلُ بَيْتًا فِيهِ كَلْبٌ وَلاَ صُورَةٌ ‏.‏\"", "bengali": "", "english": "“Jibril (as) promised the Messenger of Allah (ﷺ) that he would come to him at a certain hour, but he was late. The Prophet (ﷺ) went out and there was Jibril standing at the door. He said: ‘What kept you from entering?’ He said: ‘There is a dog in the house, and we do not enter a house in which there is a dog or an image.’”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was\\nnarrated that ‘Aishah said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3388", "arabic": "حَدَّثَنَا الْعَبَّاسُ بْنُ عُثْمَانَ الدِّمَشْقِيُّ، حَدَّثَنَا الْوَلِيدُ، حَدَّثَنَا عُفَيْرُ بْنُ مَعْدَانَ، حَدَّثَنَا سُلَيْمُ بْنُ عَامِرٍ، عَنْ أَبِي أُمَامَةَ، أَنَّ امْرَأَةً، أَتَتِ النَّبِيَّ ـ صلى الله عليه وسلم ـ فَأَخْبَرَتْهُ أَنَّ زَوْجَهَا فِي بَعْضِ الْمَغَازِي فَاسْتَأْذَنَتْهُ أَنْ تُصَوِّرَ فِي بَيْتِهَا نَخْلَةً فَمَنَعَهَا أَوْ نَهَاهَا ‏.‏", "bengali": "", "english": "It was narrated from Abu Umamah that a woman came to the Prophet (ﷺ) and told him that her husband was away on some military campaign. She asked him for permission to make an image of a palm tree in her house, and he did not let her, or he forbade her.", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ہر نشہ آور چیز", "grades": "", "reference": "", "international_number": "3388", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3389", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا وَكِيعٌ، عَنْ أُسَامَةَ بْنِ زَيْدٍ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، قَالَتْ سَتَرْتُ سَهْوَةً لِي - تَعْنِي الدَّاخِلَ - بِسِتْرٍ فِيهِ تَصَاوِيرُ فَلَمَّا قَدِمَ النَّبِيُّ ـ صلى الله عليه وسلم ـ هَتَكَهُ فَجَعَلْتُ مِنْهُ مَنْبُوذَتَيْنِ فَرَأَيْتُ النَّبِيَّ ـ صلى الله عليه وسلم ـ مُتَّكِئًا عَلَى إِحْدَاهُمَا ‏.‏", "bengali": "", "english": "“I covered a small room closet of mine, meaning, from the inside, with a curtain on which there were images. When the Prophet (ﷺ) came, he tore it down, so I made two pillows from it, and I saw the Prophet (ﷺ) reclining on one of them.”", "french": "", "indonesian": "", "russian": "", "urdu": "معاویہ رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  ہر نشہ لانے وال", "grades": "", "reference": "", "international_number": "3389", "narrator_chain": "It was\\nnarrated that ‘Aishah said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3390", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا أَبُو الأَحْوَصِ، عَنْ أَبِي إِسْحَاقَ، عَنْ هُبَيْرَةَ، عَنْ عَلِيٍّ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنْ خَاتَمِ الذَّهَبِ وَعَنِ الْمِيثَرَةِ يَعْنِي الْحَمْرَاءَ ‏.‏", "bengali": "", "english": "“The Messenger of Allah (ﷺ) forbade rings of gold and Al-Mitharah,”* meaning the red ones.", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ہر نشہ لانے والی", "grades": "", "reference": "", "international_number": "3390", "narrator_chain": "It was\\nnarrated that ‘Ali said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3391", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا زَيْدُ بْنُ الْحُبَابِ، حَدَّثَنَا يَحْيَى بْنُ أَيُّوبَ، حَدَّثَنِي عَيَّاشُ بْنُ عَبَّاسٍ الْحِمْيَرِيُّ، عَنْ أَبِي حُصَيْنٍ الْحَجْرِيِّ الْهَيْثَمِ، عَنْ عَامِرٍ الْحَجْرِيِّ، قَالَ سَمِعْتُ أَبَا رَيْحَانَةَ، صَاحِبَ النَّبِيِّ ـ صلى الله عليه وسلم ـ يَقُولُ كَانَ النَّبِيُّ ـ صلى الله عليه وسلم ـ يَنْهَى عَنْ رُكُوبِ النُّمُورِ ‏.‏", "bengali": "", "english": "“I heard Abu Raihanah, the Companion of the Prophet (ﷺ) say: ‘The Prophet (ﷺ) used to forbid riding on leopard skins.’”", "french": "", "indonesian": "", "russian": "", "urdu": "ابوموسیٰ اشعری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ہر نشہ لانے والی چ", "grades": "", "reference": "", "international_number": "3391", "narrator_chain": "It was\\nnarrated that ‘Amir Al-Hajri said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3392", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا وَكِيعٌ، عَنْ أَبِي الْمُعْتَمِرِ، عَنِ ابْنِ سِيرِينَ، عَنْ مُعَاوِيَةَ، قَالَ كَانَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ يَنْهَى عَنْ رُكُوبِ النُّمُورِ ‏.‏", "bengali": "", "english": "“The Messenger of Allah (ﷺ) used to forbid riding on leopard skins.”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ہر نشہ لانے والی", "grades": "", "reference": "", "international_number": "3392", "narrator_chain": "It was\\nnarrated that Mu’awiyah said:", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3550", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ،‏‏‏‏ عَنْ الزّ", "bengali": "", "english": "It was narrated that ‘Aishah said:“The Messenger of Allah (ﷺ) prayed in a Khamisah* that had markings on it. Then he said: ‘These markings distracted me. Take it to Abu Jahm and bring me an Anbijaniyyah.’”", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک چادر میں نماز پڑھی", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 32, Hadith 1", "international_number": "3550", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3551", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا أَبُو أُسَامَةَ،‏‏‏‏ أَخْبَرَنِي سُلَيْم", "bengali": "", "english": "It was narrated that Abu Burdah said:“I entered upon ‘Aishah and she brought out to me a thick waist wrap of the type made in Yemen, and one of these cloaks that are called Mulabbadah,* and she swore to me that the Messenger of Allah (ﷺ) had passed away in them.”", "french": "", "indonesian": "", "russian": "", "urdu": "ابوبردہ رضی اللہ عنہ کہتے ہیں کہ  میں ام المؤمنین عائشہ رضی اللہ عنہا کی خدمت میں حاضر ہوا، انہوں نے", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 32, Hadith 2", "international_number": "3551", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3552", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ ثَابِتٍ الْجَحْدَرِيُّ،‏‏‏‏ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ،‏‏‏‏ عَنْ", "bengali": "", "english": "It was narrated from ‘Ubadah bin Samit that the Messenger of Allah (ﷺ) prayed in a Shamlah tied with a knot", "french": "", "indonesian": "", "russian": "", "urdu": "عبادہ بن صامت رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک ایسی چادر میں نماز پڑ", "grades": "{'name': 'Al-Albani', 'grade': 'Daif Isnaad'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif Isnaad'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 32, Hadith 3", "international_number": "3552", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3553", "arabic": "حَدَّثَنَا يُونُسُ بْنُ عَبْدِ الْأَعْلَى،‏‏‏‏ حَدَّثَنَا ابْنُ وَهْبٍ،‏‏‏‏ حَدَّثَنَا مَالِكٌ،‏‏‏‏", "bengali": "", "english": "It was narrated that Anas bin Malik said:“I was with the Messenger of Allah (ﷺ) and over him was a Najrani upper wrap with a thick border.”", "french": "", "indonesian": "", "russian": "", "urdu": "انس بن مالک رضی اللہ عنہ کہتے ہیں  کہ میں نبی اکرم صلی اللہ علیہ وسلم کے ساتھ تھا، آپ کے جسم پر موٹے", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 32, Hadith 4", "international_number": "3553", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3554", "arabic": "حَدَّثَنَا عَبْدُ الْقُدُّوسِ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا بِشْرُ بْنُ عُمَرَ،‏‏‏‏ حَدَّثَنَا ابْن", "bengali": "", "english": "It was narrated that ‘Aishah said:“I never saw the Messenger of Allah (ﷺ) insulting anyone, and no garment was ever folded up for him.”", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  میں نے کبھی رسول اللہ صلی اللہ علیہ وسلم کو نہیں دیکھا", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 32, Hadith 5", "international_number": "3554", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3555", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ،‏‏‏‏ حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ أَبِي حَازِمٍ،‏‏‏‏ عَنْ أَبِ", "bengali": "", "english": "It was narrated from Sahl bin Sa’d Sa’idi that a woman came to the Messenger of Allah (ﷺ) with a woven sheet – he said:* “What type of woven sheet?” He said: “A Shamlah.” She said: “O Messenger of Allah, I have woven this with my own hands for you to wear.” The Messenger of Allah (ﷺ) took it, since he needed it. He came out to us wearing it as a lower wrap. So-and-so the son of so-and-so.” – a man whose name he told that day – said: “O Messenger of Allah, how beautiful this sheet is! Let me wear it.” He said: “Yes.” When he went inside he folded it up and sent it to him. The people said to him: “By Allah, you have not done well. The Prophet (ﷺ) wore it because he needed it, then you asked for it, and you knew that he would not refuse anyone who asked him for something.” He said: “By Allah, I did not ask for it so that I could wear it, rather I asked for it so that it could be my shroud.” Sahl said: “And it became his shroud the day he died.”", "french": "", "indonesian": "", "russian": "", "urdu": "سہل بن سعد ساعدی رضی اللہ عنہ سے روایت ہے کہ  ایک عورت رسول اللہ صلی اللہ علیہ وسلم کی خدمت میں «برد", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Bukhari'}", "reference": "Book 32, Hadith 6", "international_number": "3555", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3556", "arabic": "حَدَّثَنَا يَحْيَى بْنُ عُثْمَانَ بْنِ سَعِيدِ بْنِ كَثِيرِ بْنِ دِينَارٍ الْحِمْصِيُّ،‏‏‏‏ حَدَّثَن", "bengali": "", "english": "It was narrated that Anas said:“The Messenger of Allah (ﷺ) wore wool and sandals, and he wore coarse, rough garments.”", "french": "", "indonesian": "", "russian": "", "urdu": "انس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے اون کا  ( سادہ اور موٹا )  لباس پہنا ہ", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Very Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 32, Hadith 7", "international_number": "3556", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3557", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ،‏‏‏‏ قَالَ:‏‏‏‏ حَ", "bengali": "", "english": "It was narrated that Abu Umamah said:“Umar bin Khattab put on a new garment and said: Al-hamdu lillahil-ladhi kasani ma uwari bihi ‘awrati, wa atajammalu bihi fi hayati (Praise is to Allah Who has clothed me in something with which I conceal my nakedness and adorn myself in my life). Then he said: ‘I heard the Messenger of Allah (ﷺ) say: “Whoever puts on a new garment and says: Al-hamdu lillahil- ladhi kasani ma uwari bihi ‘awrati, wa atajammalu bihi fi hayati (Praise be to Allah Who has clothed me in something with which I conceal my nakedness and adorn myself in my life), then takes the garment that has worn out, or that he had taken off and gives it in charity, he will be under the shelter, protection and care of Allah, whether he lives or dies.’ He said this three times.”", "french": "", "indonesian": "", "russian": "", "urdu": "ابوامامہ رضی اللہ عنہ کہتے ہیں کہ  عمر بن خطاب رضی اللہ عنہ نے نیا کپڑا پہنا تو یہ دعا پڑھی: «الحمد", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 32, Hadith 8", "international_number": "3557", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3558", "arabic": "حَدَّثَنَا الْحُسَيْنُ بْنُ مَهْدِيٍّ،‏‏‏‏ حَدَّثَنَا عَبْدُ الرَّزَّاقِ،‏‏‏‏ أَنْبَأَنَا مَعْمَرٌ،‏", "bengali": "", "english": "It was narrated from Ibn `Umar that the Messenger of Allah (ﷺ) saw `Umar wearing a white shirt and he said:“Is this garment of yours washed or a new one?” He said: “Rather it has been washed.” He said: “Ilbas jadida, wa `ish hamida, wa mut shahida (May you wear new clothes, live a good life and die as martyr).”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے عمر رضی اللہ عنہ کو ای", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 32, Hadith 9", "international_number": "3558", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3559", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ،‏‏‏‏ عَنْ الزُّهْرِيِّ،‏‏‏‏ عَنْ ع", "bengali": "", "english": "It was narrated from Abu Sa’eed Al-Khudri that the Prophet (ﷺ) forbade two kinds of dress. Those two types of dress are Ishtimalus- Samma’* and Ihtiba’ in a single garment, with no part of it upon his private part", "french": "", "indonesian": "", "russian": "", "urdu": "ابو سعید خدری رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے دو طرح کے پہناوے سے منع فر", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 32, Hadith 10", "international_number": "3559", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3560", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ،‏‏‏‏ وَأَبُ", "bengali": "", "english": "It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) forbade two kinds of dress:Ishtimalus-Samma’ and Ihtiba’, exposing one’s private part to the sky", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے دو طرح کے پہناوے سے منع فرمایا", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 32, Hadith 11", "international_number": "3560", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3561", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ،‏‏‏‏ وَأَبُ", "bengali": "", "english": "It was narrated that ‘Aishah said:“The Messenger of Allah (ﷺ) forbade two kinds of dress: Ishtimalus-Samma’ and Ihtiba’ in one garment, when you are exposing your private part to the sky.”", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے دو طرح کے پہناوے سے منع", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 32, Hadith 12", "international_number": "3561", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3562", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا الْحَسَنُ بْنُ مُوسَى،‏‏‏‏ عَنْ شَيْبَان", "bengali": "", "english": "It was narrated from Abu Burdah that his father said to him:“O my son, if only you could have seen us when we were with the Messenger of Allah (ﷺ), when rain fell on us; you would have thought that we smelled like sheep.”", "french": "", "indonesian": "", "russian": "", "urdu": "ابوبردہ اپنے والد ابوموسیٰ اشعری سے روایت کرتے ہیں کہ  میرے والد نے مجھ سے کہا: میرے بیٹے! کاش تم ہم", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 32, Hadith 13", "international_number": "3562", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3563", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عُثْمَانَ بْنِ كَرَامَةَ،‏‏‏‏ حَدَّثَنَا أَبُو أُسَامَةَ،‏‏‏‏ حَدَّثَنَا ا", "bengali": "", "english": "It was narrated that ‘Ubadah bin Samit said:“The Messenger of Allah (ﷺ) came out to us one day, wearing a Roman cloak of wool with narrow sleeves. He led us in prayer wearing that, and nothing else.”", "french": "", "indonesian": "", "russian": "", "urdu": "عبادہ بن صامت رضی اللہ عنہ کہتے ہیں کہ  ایک دن رسول اللہ صلی اللہ علیہ وسلم اون کا بنا ہوا تنگ آستی", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 32, Hadith 14", "international_number": "3563", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3564", "arabic": "حَدَّثَنَا الْعَبَّاسُ بْنُ الْوَلِيدِ الدِّمَشْقِيُّ،‏‏‏‏ وَأَحْمَدُ بْنُ الْأَزْهَرِ،‏‏‏‏ قَالَا:‏", "bengali": "", "english": "It was narrated from Salman Farisi that the Messenger of Allah (ﷺ) performed ablution, then he turned his woolen cloak that he was wearing inside out and wiped his face with it", "french": "", "indonesian": "", "russian": "", "urdu": "سلمان فارسی رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے وضو فرمایا، پھر اون والے جب", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 32, Hadith 15", "international_number": "3564", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3565", "arabic": "حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ،‏‏‏‏ حَدَّثَنَا مُوسَى بْنُ الْفَضْلِ،‏‏‏‏ عَنْ شُعْبَةَ،‏‏‏‏ عَنْ", "bengali": "", "english": "It was narrated that Anas bin Malik said:“I saw the Messenger of Allah (ﷺ) marking sheep on their ears, and I saw him wearing a cloak around his wrist.”", "french": "", "indonesian": "", "russian": "", "urdu": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو بکریوں کے کانوں میں داغ", "grades": "{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 32, Hadith 16", "international_number": "3565", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3566", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ،‏‏‏‏ أَنْبَأَنَا عَبْدُ اللَّهِ بْنُ رَجَاءٍ الْمَكِّيُّ،‏‏‏‏", "bengali": "", "english": "It was narrated from Ibn ‘Abbas that the Messenger of Allah (ﷺ) said:“The best of your garments are the white ones, so wear them and shroud your dead in them.”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تمہارے بہترین ک", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 32, Hadith 17", "international_number": "3566", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3567", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ سُفْيَانَ،‏‏‏‏ عَنْ حَبِيبِ بْنِ", "bengali": "", "english": "It was narrated from Samurah bin Jundab that the Messenger of Allah (ﷺ) said:“Wear white garments, for they are purer and better.”", "french": "", "indonesian": "", "russian": "", "urdu": "سمرہ بن جندب رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  سفید کپڑے پہنو کہ یہ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 32, Hadith 18", "international_number": "3567", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3568", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ حَسَّانَ الْأَزْرَقُ،‏‏‏‏ حَدَّثَنَا عَبْدُ الْمَجِيدِ بْنُ أَبِي رَوَّادٍ", "bengali": "", "english": "It was narrated from Abu Darda’ that the Messenger of Allah (ﷺ) said:“The best of that in which you visit Allah in your graves and your mosque is white (garments).”", "french": "", "indonesian": "", "russian": "", "urdu": "ابوالدرداء رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  سب سے بہتر لباس جس کو", "grades": "{'name': 'Al-Albani', 'grade': 'Mawdu'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Mawdu'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 32, Hadith 19", "international_number": "3568", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3569", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا أَبُو أُسَامَةَ . ح حَدَّثَنَا عَلِيُّ ب", "bengali": "", "english": "It was narrated from Ibn ‘Umar that the Messenger of Allah (ﷺ) said:“Whoever lets his garment drag out of pride, Allah will not look at him on the Day of Resurrection.”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو اپنے کپڑے", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 32, Hadith 20", "international_number": "3569", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3570", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا أَبُو مُعَاوِيَةَ،‏‏‏‏ عَنْ الْأَعْمَشِ،", "bengali": "", "english": "It was narrated from ‘Atiyyah, that Abu Sa’eed said:“The Messenger of Allah (ﷺ) said: ‘Whoever lets his lower wrap drag out of pride, Allah will not look at him on the Day of Resurrection.” He ( ‘Atiyyah) said \"I met Ibn 'Umar in Al-Balaat so I mentioned Abu Sa'eed's hadith from the Prophet (ﷺ). So he said and pointed to his ears 'My two ears heard it, and my heart preserved it", "french": "", "indonesian": "", "russian": "", "urdu": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے غرور و تکبر س", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 32, Hadith 21", "international_number": "3570", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3571", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ،‏‏‏‏ عَنْ مُحَمَّد", "bengali": "", "english": "It was narrated that a young man of Quriash passed by Abu Hurairah with his cloak dragging. He said:“O my nephew! I heard the Messenger of Allah (ﷺ) saying ‘Whoever let his garment drag out of pride, Allah will not look at him on the Day of Resurrection.’”", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  ان کے پاس سے قریش کا ایک جوان اپنی چادر لٹکائے ہوئے گزرا، آپ نے ا", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 32, Hadith 22", "international_number": "3571", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3572", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا أَبُو الْأَحْوَصِ،‏‏‏‏ عَنْ أَبِي إِسْحَ", "bengali": "", "english": "It was narrated that Hudhaifah said:“The Messenger of Allah (ﷺ) took hold of the lower part of my calf or his calf and said: ‘This is where the lower wrap should come to. If you insist, then lower, and if you insist, then lower, but the lower wrap has no right to (come to) the ankle.’”", "french": "", "indonesian": "", "russian": "", "urdu": "حذیفہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے میری پنڈلی کے نیچے کا پٹھا پکڑا اور", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 32, Hadith 23", "international_number": "3572", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3573", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ،‏‏‏‏ عَنْ الْعَلَاءِ بْن", "bengali": "", "english": "It was narrated from ‘Ala bin ‘Abdur-Rahman that his father said:“I said to Abu Sa’eed: ‘Did you hear anything from the Messenger of Allah (ﷺ) concerning the lower wrap?’ He said: ‘Yes. I heard the Messenger of Allah (ﷺ) say: ‘The lower wrap of the believer should come to mid-calf, but there is no sin on him if it comes between that point and the ankle. But whatever is lower than the ankle is in the Fire.’ And he said three times: ‘Allah will not look at the one who lets his lower wrap drag out of vanity.’”", "french": "", "indonesian": "", "russian": "", "urdu": "عبدالرحمٰن کہتے ہیں کہ  میں نے ابو سعید خدری رضی اللہ عنہ سے کہا: کیا آپ نے رسول اللہ صلی اللہ علیہ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 32, Hadith 24", "international_number": "3573", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3574", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ،‏‏‏‏ أَنْبَأَنَا ش", "bengali": "", "english": "It was narrated from Mughirah bin Shu’bah that the Messenger of Allah (ﷺ) said:“O Sufyan bin Sahl, do not let your garment hang, for Allah does not like those who let their garments hang below the ankles.’”", "french": "", "indonesian": "", "russian": "", "urdu": "مغیرہ بن شعبہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  سفیان بن سہل!  ( ٹخ", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 32, Hadith 25", "international_number": "3574", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3575", "arabic": "حَدَّثَنَا يَعْقُوبُ بْنُ إِبْرَاهِيمَ الدَّوْرَقِيُّ،‏‏‏‏ حَدَّثَنَا أَبُو تُمَيْلَةَ،‏‏‏‏ عَنْ عَب", "bengali": "", "english": "It was narrated that Umm Salamah said:There was no garment more beloved to the Messenger of Allah (ﷺ) than the shirt.”", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین ام سلمہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کو کرتے  ( قمیص )  سے بڑ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 32, Hadith 26", "international_number": "3575", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3576", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا الْحُسَيْنُ بْنُ عَلِيٍّ،‏‏‏‏ عَنْ ابْنِ", "bengali": "", "english": "It was narrated from Salim, from his father, that the Prophet (ﷺ) said:“Hanging down may apply to the waist wrap, shirt or turban. Whoever lets any of these drag out of pride, Allah will not look at him on the Day of Resurrection.”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:   «اسبال»: تہبند،", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 32, Hadith 27", "international_number": "3576", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3577", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ عُثْمَانَ بْنِ حَكِيمٍ الْأَوْدِيُّ،‏‏‏‏ حَدَّثَنَا أَبُو غَسَّانَ،‏‏‏‏ قَا", "bengali": "", "english": "It was narrated that Ibn ‘Abbas said:“The Messenger of Allah (ﷺ) used to wear a shirt that was short in the sleeves and length.”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ایسی قمیص پہنتے جس کی آستی", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 32, Hadith 28", "international_number": "3577", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3578", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا ابْنُ دُكَيْنٍ،‏‏‏‏ عَنْ زُهَيْرٍ،‏‏‏‏ عَنْ عُرْوَةَ بْنِ عَ", "bengali": "", "english": "Mu’awiyah bin Qurrah narrated that his father said:“I came to the Messenger of Allah (ﷺ) and gave him my pledge, and the buttons of his shirt were undone.”", "french": "", "indonesian": "", "russian": "", "urdu": "قرہ رضی اللہ عنہ کہتے ہیں کہ  میں رسول اللہ صلی اللہ علیہ وسلم کے پاس آیا اور آپ سے بیعت کی، اس وقت", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 32, Hadith 29", "international_number": "3578", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3579", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ قَالَا:‏‏‏‏ حَدَّثَنَ", "bengali": "", "english": "It was narrated that Suwaid bin Qais said:“The Prophet (ﷺ) came to us and haggled with us over the price of trousers.”", "french": "", "indonesian": "", "russian": "", "urdu": "سوید بن قیس رضی اللہ عنہ کہتے ہیں کہ  ہمارے پاس نبی اکرم صلی اللہ علیہ وسلم تشریف لائے تو آپ نے ہم س", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 32, Hadith 30", "international_number": "3579", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3580", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا الْمُعْتَمِرُ بْنُ سُلَيْمَانَ،‏‏‏‏ عَنْ عُبَيْدِ اللَّهِ بْ", "bengali": "", "english": "It was narrated that Umm Salamah said:“The Messenger of Allah (ﷺ) was asked about how long a woman’s hem should hang down. He said: ‘A hand span.’ I said: ‘But then (her legs and feet) will be uncovered.’ He said: ‘Then a forearm’s length, but no more than that.’”", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین ام سلمہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم سے سوال کیا گیا: عورت اپ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 32, Hadith 31", "international_number": "3580", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3581", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ،‏‏‏‏ عَنْ سُفْيَانَ،‏‏‏‏ ع", "bengali": "", "english": "It was narrated from Ibn ‘Umar:“The wives of the Prophet (ﷺ) were allowed to let their hems hang down, so they used to come to us and we would measure one forearms length for them with a reed.”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم کی ازواج مطہرات رضی اللہ ع", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 32, Hadith 32", "international_number": "3581", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3582", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ،‏‏‏‏ حَدَّثَنَا حَ", "bengali": "", "english": "It was narrated from Abu Hurairah that the Prophet (ﷺ) said to Fatimah, or to Umm Salamah:“Let your hem down one forearm’s length.”", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فاطمہ یا ام سلمہ رضی اللہ عنہا", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih Lighairihi'},{'name': 'Shuaib Al Arnaut', 'grade': 'Very Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 32, Hadith 33", "international_number": "3582", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3583", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَفَّانُ،‏‏‏‏ حَدَّثَنَا عَبْدُ الْوَارِ", "bengali": "", "english": "It was narrated from ‘Aishah that the Prophet (ﷺ) said, concerning how long a woman’s hem should hang down:“A hand span.” ‘Aishah said: “This may show her calves.” He said: “Then a forearm’s length.”", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے عورتوں کے دامن کے سلس", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Very Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 32, Hadith 34", "international_number": "3583", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3584", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ،‏‏‏‏ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ،‏‏‏‏ عَنْ مُسَاوِرٍ الْوَ", "bengali": "", "english": "It was narrated from Ja’far bin ‘Amr bin Huraith that his father said:“I saw the Prophet (ﷺ) delivering a sermon on the pulpit, wearing a black turban.”", "french": "", "indonesian": "", "russian": "", "urdu": "عمرو بن حریث رضی اللہ عنہ کہتے ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم کو منبر پر خطبہ دیتے دیکھا", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih Lighairihi'}", "reference": "Book 32, Hadith 35", "international_number": "3584", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3585", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ حَدَّثَنَا حَمَّادُ بْنُ سَ", "bengali": "", "english": "It was narrated from Jabir that the Prophet (ﷺ) entered Makkah wearing a black turban", "french": "", "indonesian": "", "russian": "", "urdu": "جابر رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم جب مکہ میں  ( فتح کے دن )  داخل ہوئے،", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'}", "reference": "Book 32, Hadith 36", "international_number": "3585", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3586", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عُبَيْدُ اللَّهِ،‏‏‏‏ أَنْبَأَنَا مُوسَى", "bengali": "", "english": "It was narrated from Ibn ‘Umar that the Prophet (ﷺ) entered (Makkah), on the Day of the Conquest of Makkah, wearing a black turban", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم فتح مکہ کے دن مکہ میں داخل", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 32, Hadith 37", "international_number": "3586", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3587", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا أَبُو أُسَامَةَ،‏‏‏‏ عَنْ مُسَاوِرٍ،‏‏‏‏", "bengali": "", "english": "Ja’far bin ‘Amr bin Huraith narrated that his father said:“It is as if I can see the Messenger of Allah (ﷺ), wearing a black turban, with the ends hanging down his shoulders.”", "french": "", "indonesian": "", "russian": "", "urdu": "عمرو بن حریث رضی اللہ عنہ کہتے ہیں کہ  گویا میں رسول اللہ صلی اللہ علیہ وسلم کو دیکھ رہا ہوں، اور آ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih Lighairihi'}", "reference": "Book 32, Hadith 38", "international_number": "3587", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3588", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا إِسْمَاعِيل بْنُ عُلَيَّةَ،‏‏‏‏ عَنْ عَب", "bengali": "", "english": "It was narrated from Anas bin Malik that the Messenger of Allah (ﷺ) said:“Whoever wears silk in this world will not wear it in the Hereafter.”", "french": "", "indonesian": "", "russian": "", "urdu": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس آدمی نے دنیا میں", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 32, Hadith 39", "international_number": "3588", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3589", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ،‏‏‏‏ عَنْ الشَّيْب", "bengali": "", "english": "It was narrated that Bara’ bin ‘Azib said:“The Messenger of Allah (ﷺ) forbade brocade, silk, and embroidered brocade.”", "french": "", "indonesian": "", "russian": "", "urdu": "براء رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے  ( مردوں کے لیے )  دیباج، حریر اور اس", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 32, Hadith 40", "international_number": "3589", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3590", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ شُعْبَةَ،‏‏‏‏ عَنْ الْ", "bengali": "", "english": "It was narrated that Hudhaifah said:“The Messenger of Allah (ﷺ) forbade wearing silk and gold. He said: ‘They are for them in this world and for us in the Hereafter.’”", "french": "", "indonesian": "", "russian": "", "urdu": "حذیفہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے  ( مردوں کے لیے )  ریشم اور سونا پہن", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 32, Hadith 41", "international_number": "3590", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3591", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ سُلَيْمَانَ،‏‏‏‏", "bengali": "", "english": "It was narrated from ‘Abdullah bin ‘Umar that ‘Umar bin Khattab saw a silken two piece suit (being offered for sale). He said:“O Messenger of Allah, why don’t you buy this two piece suit (to wear for meeting) the delegations, and on Fridays?” The Messenger of Allah (ﷺ) said: “This is only worn by one who has no share in the Hereafter.”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  عمر بن خطاب رضی اللہ عنہ نے ریشم کا ایک سرخ جوڑا دیکھا تو", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 32, Hadith 42", "international_number": "3591", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3592", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ،‏‏‏‏ حَدَّثَنَا سَ", "bengali": "", "english": "It was narrated from Anas bin Malik that the Messenger of Allah (ﷺ) granted a concession to Zubair bin ‘Awwam and ‘Abdur-Rahman bin ‘Auf, allowing them to wear silk shirts, because of a rash they were suffering from", "french": "", "indonesian": "", "russian": "", "urdu": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے زبیر بن عوام اور عبدالرحمٰن بن", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 32, Hadith 43", "international_number": "3592", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3593", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا حَفْصُ بْنُ غِيَاثٍ،‏‏‏‏ عَنْ عَاصِمٍ،‏‏", "bengali": "", "english": "It was narrated from ‘Umar that he used to forbid silk and brocade, except for what was like this:Then he gestured with his finger, then a second, and a third, and a fourth (i.e., the width of four fingers), and he said: “The Messenger of Allah (ﷺ) used to forbid it.”", "french": "", "indonesian": "", "russian": "", "urdu": "عمر رضی اللہ عنہ سے روایت ہے کہ  وہ خالص ریشمی کپڑے  ( حریر و دیباج )  کے استعمال سے منع فرماتے تھے", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 32, Hadith 44", "international_number": "3593", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3594", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ مُغِيرَةَ بْنِ زِيَادٍ", "bengali": "", "english": "It was narrated that Abu ‘Umar, the freed slave of Asma’, said:“I saw Ibn ‘Umar buying a turban that had some markings, then he called for a pair of scissors and cut that off. I entered upon Asma’ and mentioned that to her, and she said: ‘May ‘Abdullah perish, O girl! Give me the garment of the Messenger of Allah (ﷺ).’ A garment was brought that was hemmed with brocade on the sleeves, necklines and openings (at the front and back).”", "french": "", "indonesian": "", "russian": "", "urdu": "اسماء رضی اللہ عنہا کے غلام ابوعمر کہتے ہیں کہ  میں نے ابن عمر رضی اللہ عنہما کو دیکھا کہ انہوں نے ا", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 32, Hadith 45", "international_number": "3594", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3595", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ سُلَيْمَانَ،‏‏‏‏ عَنْ مُحَمَّدِ بْنِ", "bengali": "", "english": "‘Ali bin Abu Talib said:“The Messenger of Allah (ﷺ) took hold of some silk in his left hand and some gold in his right, then he raised his hands and said: ‘These two are forbidden for the males of my nation, and permitted to the females.’”", "french": "", "indonesian": "", "russian": "", "urdu": "علی بن ابی طالب رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے اپنے بائیں ہاتھ میں ریشم ا", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 32, Hadith 46", "international_number": "3595", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3596", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ سُلَيْمَانَ،‏‏‏‏", "bengali": "", "english": "It was narrated from ‘Ali that a two-piece suit hemmed with silk, either on the wrap or the weft,* was given to the Messenger of Allah (ﷺ), and he sent them to me (‘Ali). I came to him and said:“O Messenger of Allah, what should I do with these? Shall I wear them?” He said: “No, rather make them into head-cloths and give them to the Fatimahs.”", "french": "", "indonesian": "", "russian": "", "urdu": "علی رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم کی خدمت میں ایک ریشمی  ( جوڑا )  تحفہ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 32, Hadith 47", "international_number": "3596", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3597", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ سُلَيْمَانَ،‏‏‏‏ عَنْ الْإِفْرِيقِيِّ", "bengali": "", "english": "It was narrated that ‘Abdullah bin ‘Umar said:“The Messenger of Allah (ﷺ) came out to us, and in one of his hands was a garment of silk and in the other was some gold. He said: ‘These are forbidden to the males of my nation and permitted to the females.’”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ہمارے پاس گھر سے نکل کر آئ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih Lighairihi'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 32, Hadith 48", "international_number": "3597", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3598", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا عِيسَى بْنُ يُونُسَ،‏‏‏‏ عَنْ مَعْمَرٍ،‏‏‏‏ عَنْ الزُّهْرِيّ", "bengali": "", "english": "It was narrated that Anas said:“I saw Zainab the daughter of the Messenger of Allah (ﷺ) wearing a shirt of Siyara’ silk", "french": "", "indonesian": "", "russian": "", "urdu": "انس رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کی صاحب زادی زینب رضی اللہ عنہا کو", "grades": "{'name': 'Al-Albani', 'grade': 'Shadh'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Shadh'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 32, Hadith 49", "international_number": "3598", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3599", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ عَنْ شَرِيكِ بْنِ عَبْدِ اللَّهِ الْقَاضِي،‏‏‏‏ عَن", "bengali": "", "english": "It was narrated that Bara’ said:“I never saw anyone more handsome then the Messenger of Allah (ﷺ), with his hair combed, wearing a red two-piece suit.”", "french": "", "indonesian": "", "russian": "", "urdu": "براء رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم سے زیادہ خوبصورت بال جھاڑے اور سن", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 32, Hadith 50", "international_number": "3599", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3600", "arabic": "حَدَّثَنَا أَبُو عَامِرٍ عَبْدُ اللَّهِ بْنُ عَامِرِ بْنِ بَرَّادِ بْنِ يُوسُفَ بْنِ أَبِي بُرْدَةَ", "bengali": "", "english": "‘Abdullah bin Buraidah narrated that his father told him:I saw the Messenger of Allah (ﷺ) delivering a sermon, and Hasan and Husain came forward, wearing red shirts, stumbling and getting up again. The Prophet (ﷺ) stepped down, picked them up and put them in his lap. Then he said: “Allah and His Messenger have spoken the truth. ‘Your wealth and your children are only a trial.’ [64:15] I saw these two and I could not be patient. Then he resumed his sermon.”", "french": "", "indonesian": "", "russian": "", "urdu": "بریدہ رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو خطبہ دیتے دیکھا، اتنے میں حسن", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 32, Hadith 51", "international_number": "3600", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3601", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ،‏‏‏‏ عَنْ يَزِيدَ", "bengali": "", "english": "It was narrated that Ibn ‘Umar said:“The Messenger of Allah (ﷺ) forbade Al-Mufaddam.”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے «مفدم» سے منع کیا ہے، یزی", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 32, Hadith 52", "international_number": "3601", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3602", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ أُسَامَةَ بْنِ زَيْدٍ،", "bengali": "", "english": "It was narrated that ‘Abdullah bin Hunain said:“I heard ‘Ali say: ‘The Messenger of Allah (ﷺ) forbade me – and I do not say that he forbade you – from wearing clothes dyed with safflower.’”", "french": "", "indonesian": "", "russian": "", "urdu": "علی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مجھے پیلے رنگ کے کپڑے پہننے سے روکا، م", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 32, Hadith 53", "international_number": "3602", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3603", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا عِيسَى بْنُ يُونُسَ،‏‏‏‏ عَنْ هِشَامِ بْنِ الْغَازِ،‏‏‏‏ عَن", "bengali": "", "english": "It was narrated from ‘Amr bin Shu’aib, from his father, that his grandfather said:“We came with the Messenger of Allah (ﷺ) was Thaniyyat Adhakhir. He turned to me, and I was wearing a thin cloak dyed with safflower, and said: ‘What is this?’ And I realized that he disliked it. I came to my family when they were heating their oven and threw it (in the oven). Then I came to him the following day and he said: ‘O ‘Abdullah, what happened to the thin cloak?’ I told him (what I had done) and he said: ‘Why did you not give it to some of your family to wear, for there is nothing wrong with it for women.’”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  ہم اذاخر ۱؎ کے موڑ سے رسول اللہ صلی اللہ علیہ و", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 32, Hadith 54", "international_number": "3603", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3604", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ ابْنِ أَبِي لَيْلَى،‏‏‏‏ عَنْ مُ", "bengali": "", "english": "It was narrated that Qais bin Sa’d said:“The Prophet (ﷺ) came to us and we gave him some water with which to cool down. He bathed, then I brought him a yellow blanket, and I saw the traces of Wars (the yellow dye) on the folds of his stomach.”", "french": "", "indonesian": "", "russian": "", "urdu": "قیس بن سعد رضی اللہ عنہ کہتے ہیں کہ  ہمارے پاس نبی اکرم صلی اللہ علیہ وسلم تشریف لائے، تو ہم نے آپ ک", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 32, Hadith 55", "international_number": "3604", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3605", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ،‏‏‏‏ أَنْبَأَنَا ه", "bengali": "", "english": "It was narrated from ‘Amr bin Shu’aib, from his father, that his grandfather said:“The Messenger of Allah (ﷺ) said: ‘Eat and drink, give charity and wear clothes, as long as that does not involve any extravagance or vanity.’”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہعلیہ وسلم  نے فرمایا:  کھاؤ", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 32, Hadith 56", "international_number": "3605", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3606", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عُبَادَةَ،‏‏‏‏ وَمُحَمَّدُ بْنُ عَبْدِ الْمَلِكِ الْوَاسِطِيَّانِ،‏‏‏‏ قَا", "bengali": "", "english": "It was narrated that Ibn ‘Umar said:“The Messenger of Allah (ﷺ) said: ‘Whoever wears a garment of pride and vanity, Allah will clothe him, on the Day of Resurrection, in a garment of humiliation.’”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس شخص نے شہرت ک", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 32, Hadith 57", "international_number": "3606", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3607", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الْمَلِكِ بْنِ أَبِي الشَّوَارِبِ،‏‏‏‏ حَدَّثَنَا أَبُو عَوَانَةَ،‏", "bengali": "", "english": "It was narrated that ‘Abdullah bin ‘Umar said:“The Messenger of Allah (ﷺ) said: ‘Whoever wears a garment of pride and vanity in this world, Allah will clothe him in a garment of humiliation on the Day of Resurrection, then set it ablaze.’”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس شخص نے دنیا م", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 32, Hadith 58", "international_number": "3607", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3608", "arabic": "حَدَّثَنَا الْعَبَّاسُ بْنُ يَزِيدَ الْبَحْرَانِيُّ،‏‏‏‏ حَدَّثَنَا وَكِيعُ بْنُ مُحْرِزٍ النَّاجِيّ", "bengali": "", "english": "It was narrated from Abu Dharr that the Prophet (ﷺ) said:“Whoever wears a garment of pride and vanity, Allah will turn away from him until he takes it off.”", "french": "", "indonesian": "", "russian": "", "urdu": "ابوذر رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جس شخص نے شہرت کی خاطر لباس", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 32, Hadith 59", "international_number": "3608", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3609", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ،‏‏‏‏ عَنْ زَيْدِ بْنِ أَسْلَمَ،‏‏‏", "bengali": "", "english": "It was narrated that Ibn ‘Abbas said:“I heard the Messenger of Allah (ﷺ) say: ‘Any skin that has been tanned has been purified.’”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  ہر و", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 32, Hadith 60", "international_number": "3609", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3610", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ،‏‏‏‏ عَنْ الزّ", "bengali": "", "english": "It was narrated from Maimunah that he (meaning the Prophet (ﷺ)) passed by a dead sheep belonging to the freed slave woman of Maimunah, that had been given to her in charity. He said:“Why don’t they take its skin and ten it, and make us of it?” They said: “O Messenger of Allah, it is dead meat.”* He said: “It is only unlawful to eat it.”", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین میمونہ رضی اللہ عنہا سے روایت ہے کہ  ان کی ایک لونڈی کو صدقہ کی ایک بکری ملی تھی جو مری", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 32, Hadith 61", "international_number": "3610", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3611", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ سُلَيْمَانَ،‏‏‏‏", "bengali": "", "english": "It was narrated that Salman said:“One of the Mothers of the Believers had a sheep that died. The Messenger of Allah (ﷺ) passed by it and said: ‘It would not have harmed its owners if they had made use of its hide.’”", "french": "", "indonesian": "", "russian": "", "urdu": "سلمان رضی اللہ عنہ کہتے ہیں کہ  امہات المؤمنین میں سے کسی ایک کے پاس ایک بکری تھی جو مر گئی، رسول ال", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih Lighairihi'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 32, Hadith 62", "international_number": "3611", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3612", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ،‏‏‏‏ عَنْ مَالِكِ", "bengali": "", "english": "It was narrated that ‘Aishah said:“The Messenger of Allah (ﷺ) commanded that use should be made of the skins of dead animals, if they were tanned.”", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے حکم فرمایا:  جب مردہ جا", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 32, Hadith 63", "international_number": "3612", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3613", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا جَرِيرٌ،‏‏‏‏ عَنْ مَنْصُورٍ . ح وحَدَّثَنَا أَبُو بَكْرِ بْن", "bengali": "", "english": "It was narrated that ‘Abdullah bin ‘Ukaym said:“There came to us a letter from the Prophet (ﷺ) (saying): ‘No not make use of the untanned skin and sinew of dead animals.’”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عکیم کہتے ہیں کہ  ہمارے پاس نبی اکرم صلی اللہ علیہ وسلم کا مکتوب آیا کہ مردار کی کھال او", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 32, Hadith 64", "international_number": "3613", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3614", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ سُفْيَانَ،‏‏‏‏ عَنْ خَالِدٍ الْح", "bengali": "", "english": "It was narrated that ‘Abdullah bin ‘Abbas said:“The sandals of the Prophet (ﷺ) had two thongs doubled around their straps.”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کی جوتیوں کے دو تسمے تھے، جو", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 32, Hadith 65", "international_number": "3614", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3615", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ،‏‏‏‏ عَنْ هَمَّامٍ", "bengali": "", "english": "It was narrated that Anas said:“The sandals of the Prophet (ﷺ) had two thongs.”", "french": "", "indonesian": "", "russian": "", "urdu": "انس رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کی جوتیوں کے دو تسمے تھے۔", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Bukhari'}", "reference": "Book 32, Hadith 66", "international_number": "3615", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3616", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ شُعْبَةَ،‏‏‏‏ عَنْ مُحَمَّدِ بْنِ زِيَادٍ،", "bengali": "", "english": "It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said:“When anyone of you puts on his sandals, let him start with the right, and when he takes them off, let him start with the left.”", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں سے کوئی جوتا پ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 32, Hadith 67", "international_number": "3616", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3617", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ إِدْرِيسَ،‏‏‏‏ عَنْ ابْنِ عَجْلَانَ،‏‏‏‏", "bengali": "", "english": "It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said; “None of you should walk in one sandal or in one leather sock. Let him take them both off or walk in both of them.”", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  کوئی بھی شخص ایک جوتا یا", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Bukhari And Muslim'}", "reference": "Book 32, Hadith 68", "international_number": "3617", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3618", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا أَبُو مُعَاوِيَةَ،‏‏‏‏ عَنْ الْأَعْمَشِ،‏‏‏‏ عَنْ", "bengali": "", "english": "It was narrated that Abu Hurairah said:“The Messenger of Allah (ﷺ) forbade putting on sandals whilst standing.”", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے کھڑے ہو کر جوتا پہننے سے منع فرما", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 32, Hadith 69", "international_number": "3618", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3619", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ سُفْيَانَ،‏‏‏‏ عَنْ عَبْدِ اللَّ", "bengali": "", "english": "It was narrated that Ibn ‘Umar said:“The Prophet (ﷺ) forbade putting on sandals whilst standing.”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے کھڑے کھڑے جوتا پہننے سے م", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 32, Hadith 70", "international_number": "3619", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3620", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ حَدَّثَنَا دَلْهَمُ بْنُ صَالِحٍ الْكِنْدِيُّ،‏", "bengali": "", "english": "It was narrated from Ibn Buraidah, from his father, that an-Najashi sent a pair of pure black Khuff as a gift to the Prophet (ﷺ) of, which he wore", "french": "", "indonesian": "", "russian": "", "urdu": "بریدہ رضی اللہ عنہ سے روایت ہے کہ  نجاشی  ( اصحمہ بن بحر )  نے رسول اللہ صلی اللہ علیہ وسلم کی خدمت", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 32, Hadith 71", "international_number": "3620", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3621", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ،‏‏‏‏ عَنْ الزُّهْرِيِّ،‏‏‏‏ سَمِعَ", "bengali": "", "english": "It was narrated that Abu Hurairah attributed to the Prophet (ﷺ):“The Jews and the Christians do not dye (their hair), so differ from them.”", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  یہود و نصاریٰ خضاب نہی", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 32, Hadith 72", "international_number": "3621", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3622", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ إِدْرِيسَ،‏‏‏‏ عَنْ الْأَجْلَحِ،‏‏‏‏ عَن", "bengali": "", "english": "It was narrated from Abu Dharr that the Messenger of Allah (ﷺ) said:“The best things with which you change gray hair are henna and Katam.”", "french": "", "indonesian": "", "russian": "", "urdu": "ابوذر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  بالوں کی سفیدی بدلنے کے لیے", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 32, Hadith 73", "international_number": "3622", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3623", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا يُونُسُ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا سَلَّامُ بْنُ أَبِي م", "bengali": "", "english": "It was narrated that ‘Uthman bin Mawhab said:“I entered upon Umm Salamah and she brought out for me a hair of the Messenger of Allah (ﷺ), which was dyed with henna and Katam.”", "french": "", "indonesian": "", "russian": "", "urdu": "عثمان بن موہب کہتے ہیں کہ  میں ام المؤمنین ام سلمہ رضی اللہ عنہا کی خدمت میں حاضر ہوا تو انہوں نے رس", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Bukhari'}", "reference": "Book 32, Hadith 74", "international_number": "3623", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3624", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا إِسْمَاعِيل بْنُ عُلَيَّةَ،‏‏‏‏ عَنْ لَي", "bengali": "", "english": "It was narrated from Jabir that he said:“Abu Quhaifah was brought to the Prophet (ﷺ) on the Day of the Conquest (of Makkah), and his head was all white. The Messenger of Allah (ﷺ) said: ‘Take him to some of his womenfolk and let them change this, but avoid black.’”", "french": "", "indonesian": "", "russian": "", "urdu": "جابر رضی اللہ عنہ کہتے ہیں کہ  فتح مکہ کے دن ابوقحافہ رضی اللہ عنہ کو نبی اکرم صلی اللہ علیہ وسلم کے", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 32, Hadith 75", "international_number": "3624", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3625", "arabic": "حَدَّثَنَا أَبُو هُرَيْرَةَ الصَّيْرَفِيُّ مُحَمَّدُ بْنُ فِرَاسٍ،‏‏‏‏ حَدَّثَنَا عُمَرُ بْنُ الْخَط", "bengali": "", "english": "It was narrated that Suhaib Al-Khair said:“The Messenger of Allah (ﷺ) said: ‘The best thing with which you can dye your hair is this black (dye). It makes your women desire you and creates fear in the hearts of your enemies.’”", "french": "", "indonesian": "", "russian": "", "urdu": "صہیب الخیر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو خضاب تم لگاتے ہو ان", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 32, Hadith 76", "international_number": "3625", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3626", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا أَبُو أُسَامَةَ،‏‏‏‏ عَنْ عُبَيْدِ اللَّ", "bengali": "", "english": "It was narrated from Sa’eed bin Abu Sa’eed that ‘Ubaid bin Juraij asked Ibn ‘Umar:“I see that you dye your beard yellow with Wars.” Ibn ‘Umar said: “As for my dyeing of my beard yellow with Wars, I saw the Messenger of Allah (ﷺ) dyeing his beard yellow.”", "french": "", "indonesian": "", "russian": "", "urdu": "عبید بن جریج سے روایت ہے کہ  انہوں نے ابن عمر رضی اللہ عنہما سے پوچھا: میں آپ کو اپنی داڑھی ورس سے ز", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 32, Hadith 77", "international_number": "3626", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3627", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا إِسْحَاق بْنُ مَنْصُورٍ،‏‏‏‏ حَدَّثَنَا مُحَمَّدُ بْنُ طَلْح", "bengali": "", "english": "It was narrated that Ibn ‘Abbas said:“The Prophet (ﷺ) passed by a man who had dyed his hair with henna and said: ‘How handsome this is!’ Then he passed by another who had dyed his hair with henna and Katam, and said: ‘This one is more handsome than that one.’ Then he passed by another who had dyed his hair yellow and said: ‘This one is more handsome than all of them.’”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کا گزر ایک ایسے شخص کے پاس ہ", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 32, Hadith 78", "international_number": "3627", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3628", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى،‏‏‏‏ حَدَّثَنَا أَبُو دَاوُدَ،‏‏‏‏ حَدَّثَنَا زُهَيْرٌ،‏‏‏‏ عَ", "bengali": "", "english": "It was narrated that Abu Juhaifah said:“I saw the Messenger of Allah (ﷺ), and this part of his hair was white” – meaning the tuft of hair between the lower lip and the chin", "french": "", "indonesian": "", "russian": "", "urdu": "ابوحجیفہ رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کے یہ بال یعنی داڑھی بچہ سفید", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 32, Hadith 79", "international_number": "3628", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3629", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى،‏‏‏‏ حَدَّثَنَا خَالِدُ بْنُ الْحَارِثِ،‏‏‏‏ وَابْنُ أَبِي عَد", "bengali": "", "english": "It was narrated that Humaid said:“Anas bin Malik was asked: ‘Did the Messenger of Allah (ﷺ) dye his hair?’ He said: ‘He did not have any white hair apart from approximately seventeen or twenty hairs at the front of his beard.’”", "french": "", "indonesian": "", "russian": "", "urdu": "حمید کہتے ہیں کہ  انس بن مالک رضی اللہ عنہ سے سوال کیا گیا: کیا رسول اللہ صلی اللہ علیہ وسلم نے خضاب", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 32, Hadith 80", "international_number": "3629", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3630", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عُمَرَ بْنِ الْوَلِيدِ الْكِنْدِيُّ،‏‏‏‏ حَدَّثَنَا يَحْيَى بْنُ آدَمَ،‏‏‏", "bengali": "", "english": "It was narrated that Ibn ‘Umar said:“The white hair of the Prophet (ﷺ) numbered approximately twenty.”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کا بڑھاپا تقریباً ً بیس بال", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 32, Hadith 81", "international_number": "3630", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3631", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ،‏‏‏‏ عَنْ ابْن", "bengali": "", "english": "It was narrated that Mujahid said:“Umm Hani said: ‘When the Messenger of Allah (ﷺ) entered Makkah he had four braids.’”", "french": "", "indonesian": "", "russian": "", "urdu": "ام ہانی رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم جب مکہ میں  ( فتح کے روز )  داخل ہوئ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 32, Hadith 82", "international_number": "3631", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3632", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا يَحْيَى بْنُ آدَمَ،‏‏‏‏ عَنْ إِبْرَاهِيم", "bengali": "", "english": "It was narrated that Ibn ‘Abbas said:“The People of the Book used to let their hair hang down, and the idolaters used to part their hair. The Messenger of Allah (ﷺ) liked to be more like the People of the Book. So the Messenger of Allah (ﷺ) let his forelock hang down, then after that he parted it.”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  اہل کتاب اپنے بالوں کو پیشانی پر لٹکائے رکھتے تھے، اور م", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 32, Hadith 83", "international_number": "3632", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3633", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا إِسْحَاق بْنُ مَنْصُورٍ،‏‏‏‏ عَنْ إِبْرَ", "bengali": "", "english": "It was narrated that ‘Aishah said:“I used to part the hair of the Messenger of Allah (ﷺ) behind his crown, and let his forelock hang down.”", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  میں رسول اللہ صلی اللہ علیہ وسلم کے سر پر چندیا کے پچھل", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 32, Hadith 84", "international_number": "3633", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3634", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ،‏‏‏‏ أَنْبَأَنَا ج", "bengali": "", "english": "It was narrated that Anas said:“The hair of the Messenger of Allah (ﷺ) was wavy, and (hung down) between his ears and his shoulders.”", "french": "", "indonesian": "", "russian": "", "urdu": "انس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے بال دونوں کانوں اور مونڈھوں کے درمیان", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 32, Hadith 85", "international_number": "3634", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3635", "arabic": "حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ حَدَّثَنَا ابْنُ أَبِي فُدَيْكٍ،‏‏‏‏ عَنْ عَبْدِ الر", "bengali": "", "english": "It was narrated that ‘Aishah said:“The Messenger of Allah (ﷺ) had hair that came between his earlobes and his shoulders.”", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے بال مونڈھوں سے اوپر اور", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 32, Hadith 86", "international_number": "3635", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3636", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا مُعَاوِيَةُ بْنُ هِشَامٍ،‏‏‏‏ وَسُفْيَان", "bengali": "", "english": "It was narrated that Wa’il bin Hujr said:“The Prophet (ﷺ) saw me when I had long hair. He said: ‘Bad news, bad news!’ So I went away and cut it short. Then the Prophet (ﷺ) saw me and said: ‘I did not mean you, but this is better.’”", "french": "", "indonesian": "", "russian": "", "urdu": "وائل بن حجر رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے مجھے دیکھا کہ میرے بال لمبے ہیں", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 32, Hadith 87", "international_number": "3636", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3637", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ قَالَا:‏‏‏‏ حَدَّثَنَ", "bengali": "", "english": "It was narrated from Nafi’ that Ibn ‘Umar said:“The Messenger of Allah (ﷺ) forbade Qaza’.” He (Nafi’) said: “What is Qaza’?” He said: “It means shaving part of a child’s head and leaving another part.”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے «قزع» سے منع فرمایا۔ راوی", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 32, Hadith 88", "international_number": "3637", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3638", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا شَبَابَةُ،‏‏‏‏ حَدَّثَنَا شُعْبَةُ،‏‏‏‏", "bengali": "", "english": "It was narrated that Ibn ‘Umar said:“The Messenger of Allah (ﷺ) forbade Qaza’.”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے «قزع» سے منع فرمایا ہے۔", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Bukhari'}", "reference": "Book 32, Hadith 89", "international_number": "3638", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3639", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ،‏‏‏‏ عَنْ أَيّ", "bengali": "", "english": "It was narrated that Ibn ‘Umar said:“The Messenger of Allah (ﷺ) wore a ring of silver, then he had engraved on it (the words) ‘Muhammad Rasul Allah’ (Muhammad the Messenger of Allah). And he said: ‘No one should have his ring engraved like this ring of mine.’”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے چاندی کی ایک انگوٹھی بنوا", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 32, Hadith 90", "international_number": "3639", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3640", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا إِسْمَاعِيل بْنُ عُلَيَّةَ،‏‏‏‏ عَنْ عَب", "bengali": "", "english": "It was narrated that Anas bin Malik said:“The Messenger of Allah (ﷺ) had a ring made for him, and he said: ‘I have had a ring made for me and had it engraved, and no one should make a ring with similar engraving.’”", "french": "", "indonesian": "", "russian": "", "urdu": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک انگوٹھی بنوائی، اور فرمایا", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 32, Hadith 91", "international_number": "3640", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3641", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى،‏‏‏‏ حَدَّثَنَا عُثْمَانُ بْنُ عُمَرَ،‏‏‏‏ حَدَّثَنَا يُونُسُ،‏‏‏‏", "bengali": "", "english": "It was narrated from Anas bin Malik that the Messenger of Allah (ﷺ) wore a ring of silver, in which was an Ethiopian gemstone and the inscription:‘Muhammad Rasul Allah’ (Muhammad the Messenger of Allah).”", "french": "", "indonesian": "", "russian": "", "urdu": "انس بن مالک رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے چاندی کی ایک انگوٹھی بنوائی", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 32, Hadith 92", "international_number": "3641", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3642", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ،‏‏‏‏ عَنْ عُبَيْدِ اللَّهِ،‏‏‏‏", "bengali": "", "english": "It was narrated that ‘Ali said:“The Messenger of Allah (ﷺ) forbade wearing gold rings.”", "french": "", "indonesian": "", "russian": "", "urdu": "علی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے سونے کی انگوٹھی پہننے سے منع فرمایا۔", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 32, Hadith 93", "international_number": "3642", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3643", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ،‏‏‏‏ عَنْ يَزِيدَ بْنِ أَبِي زِيَادٍ،‏", "bengali": "", "english": "It was narrated that Ibn ‘Umar said:“The Messenger of Allah (ﷺ) forbade gold rings.”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے سونے کی انگوٹھی  ( پہننے", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 32, Hadith 94", "international_number": "3643", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3644", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ،‏‏‏‏ عَنْ م", "bengali": "", "english": "It was narrated that ‘Aishah the Mother of the Believers said:“Najashi sent some jewelry as a gift to the Messenger of Allah (ﷺ). Among that was a gold ring with an Ethiopian gemstone. The Messenger of Allah (ﷺ) picked it up with a stick – as if he found it distasteful – or with one of his fingers, then he called for his daughter, Umamah bint Abul-‘As, and said: ‘Wear this, O my daughter.’”", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  نجاشی نے رسول اللہ صلی اللہ علیہ وسلم کی خدمت میں ایک چ", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 32, Hadith 95", "international_number": "3644", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3645", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ،‏‏‏‏ عَنْ أَيّ", "bengali": "", "english": "It was narrated from Ibn ‘Umar that the Prophet (ﷺ) used to wear (his ring) with the stone nearest his palm", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم اپنی انگوٹھی کے نگینے کو ہ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 32, Hadith 96", "international_number": "3645", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3646", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى،‏‏‏‏ حَدَّثَنَا إِسْمَاعِيل بْنُ أَبِي أُوَيْسٍ،‏‏‏‏ حَدَّثَنِي سُ", "bengali": "", "english": "It was narrated from Anas bin Malik that the Messenger of Allah (ﷺ) wore a silver ring with an Ethiopian gemstone, and he used to ear the stone in towards his palm", "french": "", "indonesian": "", "russian": "", "urdu": "انس بن مالک رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے چاندی کی انگوٹھی پہنی، اس م", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 32, Hadith 97", "international_number": "3646", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3647", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ،‏‏‏‏ عَنْ إ", "bengali": "", "english": "It was narrated from ‘Abdullah bin Ja’far that the Prophet (ﷺ) used to wear a ring on his right hand", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن جعفر رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم اپنے داہنے ہاتھ میں انگوٹ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 32, Hadith 98", "international_number": "3647", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3648", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ إِدْرِيسَ،‏‏‏‏ عَنْ", "bengali": "", "english": "It was narrated that ‘Ali said:“The Messenger of Allah (ﷺ) forbade me to wear a ring on this and on this,” meaning the little finger and the thumb", "french": "", "indonesian": "", "russian": "", "urdu": "علی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مجھے منع فرمایا کہ میں اس میں اور اس م", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 32, Hadith 99", "international_number": "3648", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3649", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ،‏‏‏‏ عَنْ الزّ", "bengali": "", "english": "It was narrated from Abu Talhah that the Prophet (ﷺ) said:“The angels do not enter a house in which there is a dog or an image.”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  ابوطلحہ رضی اللہ عنہ کہتے ہیں کہ نبی اکرم صلی اللہ عل", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 32, Hadith 100", "international_number": "3649", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3650", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا غُنْدَرٌ،‏‏‏‏ عَنْ شُعْبَةَ،‏‏‏‏ عَنْ عَلِيِّ بْنِ مُدْرِكٍ،", "bengali": "", "english": "It was narrated from ‘Ali bin Abu Talib that the Prophet (ﷺ) said:“The angels do not enter a house in which there is a dog or an image.”", "french": "", "indonesian": "", "russian": "", "urdu": "علی بن ابی طالب رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  فرشتے اس گھر میں د", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih Lighairihi'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 32, Hadith 101", "international_number": "3650", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3651", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ،‏‏‏‏ عَنْ مُحَمَّد", "bengali": "", "english": "It was narrated that ‘Aishah said:“Jibril (as) promised the Messenger of Allah (ﷺ) that he would come to him at a certain hour, but he was late. The Prophet (ﷺ) went out and there was Jibril standing at the door. He said: ‘What kept you from entering?’ He said: ‘There is a dog in the house, and we do not enter a house in which there is a dog or an image.’”", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  جبرائیل علیہ السلام نے رسول اللہ صلی اللہ علیہ وسلم کے", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 32, Hadith 102", "international_number": "3651", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3652", "arabic": "حَدَّثَنَا الْعَبَّاسُ بْنُ عُثْمَانَ الدِّمَشْقِيُّ،‏‏‏‏ حَدَّثَنَا الْوَلِيدُ،‏‏‏‏ حَدَّثَنَا عُفَ", "bengali": "", "english": "It was narrated from Abu Umamah that a woman came to the Prophet (ﷺ) and told him that her husband was away on some military campaign. She asked him for permission to make an image of a palm tree in her house, and he did not let her, or he forbade her", "french": "", "indonesian": "", "russian": "", "urdu": "ابوامامہ رضی اللہ عنہ سے روایت ہے کہ  ایک عورت نے نبی اکرم صلی اللہ علیہ وسلم کے پاس آ کر آپ کو بتا", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 32, Hadith 103", "international_number": "3652", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3653", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ أُسَامَةَ بْنِ زَيْدٍ،", "bengali": "", "english": "It was narrated that ‘Aishah said:“I covered a small room closet of mine, meaning, from the inside, with a curtain on which there were images. When the Prophet (ﷺ) came, he tore it down, so I made two pillows from it, and I saw the Prophet (ﷺ) reclining on one of them.”", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  میں نے اپنے روشن دان پر پردہ ڈالا یعنی اندر سے، پردے می", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Isnaad Hasan Bukhari And Muslim'}", "reference": "Book 32, Hadith 104", "international_number": "3653", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3654", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا أَبُو الْأَحْوَصِ،‏‏‏‏ عَنْ أَبِي إِسْحَاق،‏‏‏‏ عَنْ هُبَيْر", "bengali": "", "english": "It was narrated that ‘Ali said:“The Messenger of Allah (ﷺ) forbade rings of gold and Al-Mitharah,”* meaning the red ones", "french": "", "indonesian": "", "russian": "", "urdu": "علی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے سونے کی انگوٹھی پہننے اور گدے استعمال", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 32, Hadith 105", "international_number": "3654", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3655", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا زَيْدُ بْنُ الْحُبَابِ،‏‏‏‏ حَدَّثَنَا ي", "bengali": "", "english": "It was narrated that ‘Amir Al-Hajri said:“I heard Abu Raihanah, the Companion of the Prophet (ﷺ) say: ‘The Prophet (ﷺ) used to forbid riding on leopard skins.’”", "french": "", "indonesian": "", "russian": "", "urdu": "ابوریحانہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم چیتوں کی کھال پر سواری کرنے سے منع ف", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 32, Hadith 106", "international_number": "3655", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
{"hadithnumber": "3656", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ أَبِي الْمُعْتَمِرِ،‏‏", "bengali": "", "english": "It was narrated that Mu’awiyah said:“The Messenger of Allah (ﷺ) used to forbid riding on leopard skins.”", "french": "", "indonesian": "", "russian": "", "urdu": "معاویہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم چیتوں کی کھال پر سواری کرنے سے منع فرم", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 32, Hadith 107", "international_number": "3656", "narrator_chain": "", "chapter_intro": "Chapters on Dress"}
