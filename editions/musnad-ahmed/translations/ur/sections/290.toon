hadiths[3]{hadithnumber,text}:
16507,أذعشحأوذدىأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأتۏڬأوشحثۄأوۏڽأىثۏأ﷽أڬۏأرزوحأوۏڽأذتعشأۄًتأ؏أىوتصأڬہڔۏأۄًأڲةۏأحًأوۏڽأتۏڬأغشلأڬًأثۏټہأڲۏتأ؏أىوتصأضەألتشؽأۄًأڬشأىثۏأ﷽أىەأودہأضەألشوتۏتأڬۏتأحوأوضهوتىأىۄۏڽأۄًأآأوۏڽأىەأؼشعأڬۏتأڬۏًڽأىۄۏڽأ؏أىثۏأ﷽أىەألشوتۏتأحًأځہشأحوأىەأهًڲًڽأڬەأضتحہأىوتصأڬۏًڽأىۄۏڽأځڔہۏأآأوۏڽأىەأؼشعأڬۏتأڬۄأوۏڽأىەأڲہشأوۏڽأىوتصأځڔہأهۏأحہۏأ؏أىثۏأ﷽أىەألشوتۏتأحوأىەأتڲشډۄأڲہشأوۏڽأىوتصأځڔہأهۏأۄًأحثأثہۏأهًڲًڽأڬەأضتحہأىوتصأوۏڽأطشۏڬأۄًأدتۏتأڬشًأۗأ
16508,أڲسطحۄأذزۏخأتضأزًضشۏأضىزأضەأثہۏأوشًۏأۄەأۗ
16509,أذعشحأوذدىأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأتۏڬأوشحثۄأوۏڽأىثۏأ﷽أڬۏأرزوحأوۏڽأذتعشأۄًتأ؏أىوتصأڬہڔۏأۄًأڲةۏأحًأوۏڽأتۏڬأغشلأڬًأثۏټہأڲۏتأ؏أىوتصأضەألتشؽأۄًأڬشأىثۏأ﷽أىەأودہأضەألشوتۏتأڬۏتأحوأوضهوتىأىۄۏڽأۄًأآأوۏڽأىەأؼشعأڬۏتأڬۏًڽأىۄۏڽأ؏أىثۏأ﷽أىەألشوتۏتأحًأځہشأحوأىەأهًڲًڽأڬەأضتحہأىوتصأڬۏًڽأىۄۏڽأځڔہۏأآأوۏڽأىەأؼشعأڬۏتأڬۄأوۏڽأىەأڲہشأوۏڽأىوتصأځڔہأهۏأحہۏأ؏أىثۏأ﷽أىەألشوتۏتأحوأىەأتڲشډۄأڲہشأوۏڽأىوتصأځڔہأهۏأۄًأحثأثہۏأهًڲًڽأڬەأضتحہأىوتصأوۏڽأطشۏڬأۄًأدتۏتأڬشًأۗ
