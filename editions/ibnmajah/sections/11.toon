hadiths[count]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}:
1824,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا مُحَمَّدُ بْنُ مُصْعَبٍ، عَنِ الأَوْزَاعِيِّ، عَنْ يَحْيَى بْنِ أَبِي كَثِيرٍ، عَنْ هِلاَلِ بْنِ أَبِي مَيْمُونَةَ، عَنْ عَطَاءِ بْنِ يَسَارٍ، عَنْ رِفَاعَةَ الْجُهَنِيِّ، قَالَ كَانَ النَّبِيُّ ـ صلى الله عليه وسلم ـ إِذَا حَلَفَ قَالَ ‏ ‏ وَالَّذِي نَفْسُ مُحَمَّدٍ بِيَدِهِ ‏""""‏ ‏.‏""",Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: سنن ابی داود/الزکاة ۱۲ (۱۶۰۲)،(تحفة الأشراف:۸۶۵۷)، سنن النسائی/الزکاة ۲۹ (۲۵۰۱),,It was narrated that Rifa'ah Al - Juhani said:,The Chapters on Expiation
1825,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا عَبْدُ الْمَلِكِ بْنُ مُحَمَّدٍ الصَّنْعَانِيُّ، حَدَّثَنَا الأَوْزَاعِيُّ، عَنْ يَحْيَى بْنِ أَبِي كَثِيرٍ، عَنْ هِلاَلِ بْنِ أَبِي مَيْمُونَةَ، عَنْ عَطَاءِ بْنِ يَسَارٍ، عَنْ رِفَاعَةَ بْنِ عَرَابَةَ الْجُهَنِيِّ، قَالَ كَانَتْ يَمِينُ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ التَّى يَحْلِفُ بِهَا أَشْهَدُ عِنْدَ اللَّهِ ‏ ‏ وَالَّذِي نَفْسِي بِيَدِهِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/الزکاة ۷۰ (۱۵۰۳)،۷۱ (۱۵۰۴)،۷۴ (۱۵۰۷)،۷۷ (۱۵۱۱)،۷۸ (۱۵۱۲)، صحیح مسلم/الزکاة ۴ (۹۸۴)،(تحفة الأشراف:۸۲۷۰)، وقد أخرجہ: سنن ابی داود/الزکاة ۱۹ (۱۶۱۵)، سنن الترمذی/الزکاة ۳۵ (۶۷۶)،۳۶ (۶۷۷)، سنن النسائی/الزکاة ۳۰ (۲۵۰۲)، موطا امام مالک/الزکاة ۲۸ (۵۲)، مسند احمد (۲/۵،۵۵،۶۳،۶۶،۱۰۲،۱۱۴،۱۳۷)، سنن الدارمی/الزکاة ۲۷ (۱۷۰۲),,It was narrated that Rifa'ah bin 'Arabah A-Juhani said:,The Chapters on Expiation
1826,"حَدَّثَنَا أَبُو إِسْحَاقَ الشَّافِعِيُّ، إِبْرَاهِيمُ بْنُ مُحَمَّدِ بْنِ الْعَبَّاسِ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ رَجَاءٍ الْمَكِّيُّ، عَنْ عَبَّادِ بْنِ إِسْحَاقَ، عَنِ ابْنِ شِهَابٍ، عَنْ سَالِمٍ، عَنْ أَبِيهِ، قَالَ كَانَتْ أَكْثَرُ أَيْمَانِ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لاَ وَمُصَرِّفِ الْقُلُوبِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/الزکاة ۷۱ (۱۵۰۶)، صحیح مسلم/الزکاة ۴ (۹۸۴)، سنن ابی داود/الزکاة ۱۹ (۱۶۱۱)، سنن الترمذی/الزکاة ۳۵ (۶۷۶)، سنن النسائی/الزکاة ۳۲ (۲۵۰۴)،۳۳ (۲۵۰۵)،(تحفة الأشراف:۸۳۲۱)، وقد أخرجہ: موطا امام مالک/الزکاة ۲۸ (۵۲)، مسند احمد (۲/۵،۵۵،۶۳،۶۶،۱۰۲،۱۱۴،۱۳۷)، سنن الدارمی/الزکاة ۲۷ (۱۷۰۲),,It was narrated from Salim that his father said:,The Chapters on Expiation
1827,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ، ح وَحَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، حَدَّثَنَا مَعْنُ بْنُ عِيسَى، جَمِيعًا عَنْ مُحَمَّدِ بْنِ هِلاَلٍ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ كَانَتْ يَمِينُ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لاَ وَأَسْتَغْفِرُ اللَّهَ ‏""""‏ ‏.‏""",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: سنن ابی داود/الزکاة ۱۷ (۱۶۰۹)،(تحفة الأشراف:۶۱۳۳),,It was narrated that Abu Hurairah said:,The Chapters on Expiation
1828,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِي عُمَرَ الْعَدَنِيُّ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ الزُّهْرِيِّ، عَنْ سَالِمِ بْنِ عَبْدِ اللَّهِ بْنِ عُمَرَ، عَنْ أَبِيهِ، عَنْ عُمَرَ بْنِ الْخَطَّابِ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ سَمِعَهُ يَحْلِفُ بِأَبِيهِ فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِنَّ اللَّهَ يَنْهَاكُمْ أَنْ تَحْلِفُوا بِآبَائِكُمْ ‏""""‏ ‏.‏ قَالَ عُمَرُ فَمَا حَلَفْتُ بِهَا ذَاكِرًا وَلاَ آثِرًا ‏.‏""",Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: سنن النسائی/الزکاة ۳۵ (۲۵۰۸)،(تحفة الأشراف:۱۱۰۹۸)، وقد أخرجہ: مسند احمد (۳/۴۴۲،۶/۶),,"It was narrated from Salim bin 'Abdullah bin 'Umar, from his father, from 'Umar, that :",The Chapters on Expiation
1829,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ الأَعْلَى، عَنْ هِشَامٍ، عَنِ الْحَسَنِ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ سَمُرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لاَ تَحْلِفُوا بِالطَّوَاغِي وَلاَ بِآبَائِكُمْ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/الزکاة ۷۲ (۱۵۰۵)،۷۳ (۱۵۰۶)،۷۵ (۱۵۰۸)،۷۶ (۱۵۱۰)، صحیح مسلم/الزکاة ۴ (۹۸۵)، سنن ابی داود/الزکاة ۱۹ (۱۶۱۶،۱۶۱۷)، سنن الترمذی/الزکاة ۳۵ (۶۷۳)، سنن النسائی/الزکاة ۳۷ (۲۵۱۳)،(تحفة الأشراف:۴۲۶۹)، وقد أخرجہ: موطا امام مالک/الزکاة ۲۸ (۵۳)، مسند احمد (۳/۲۳،۷۳،۹۸)، سنن الدارمی/الزکاة ۲۷ (۱۷۰۴),,It was narrated from 'Abdur-Rahman bin Samurah that :,The Chapters on Expiation
1830,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ الدِّمَشْقِيُّ، حَدَّثَنَا عُمَرُ بْنُ عَبْدِ الْوَاحِدِ، عَنِ الأَوْزَاعِيِّ، عَنِ الزُّهْرِيِّ، عَنْ حُمَيْدٍ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ مَنْ حَلَفَ فَقَالَ فِي يَمِينِهِ بِاللاَّتِ وَالْعُزَّى فَلْيَقُلْ لاَ إِلَهَ إِلاَّ اللَّهُ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۳۴۵، ومصباح الزجاجة:۶۵۰),,It was narrated from Abu Hurairah that :,The Chapters on Expiation
1831,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، وَالْحَسَنُ بْنُ عَلِيٍّ الْخَلاَّلُ، قَالاَ حَدَّثَنَا يَحْيَى بْنُ آدَمَ، عَنْ إِسْرَائِيلَ، عَنْ أَبِي إِسْحَاقَ، عَنْ مُصْعَبِ بْنِ سَعْدٍ، عَنْ سَعْدٍ، قَالَ حَلَفْتُ بِاللاَّتِ وَالْعُزَّى فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ قُلْ لاَ إِلَهَ إِلاَّ اللَّهُ وَحْدَهُ لاَ شَرِيكَ لَهُ ثُمَّ انْفُثْ عَنْ يَسَارِكَ ثَلاَثًا وَتَعَوَّذْ وَلاَ تَعُدْ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ، ابن ماجہ،(تحفة الأشراف:۱۱۰۱۰، ومصباح الزجاجة:۶۵۱)، وقد أخرجہ: مسند احمد (۵/۵۲),,It was narrated that Sa'd said:,The Chapters on Expiation
1832,"حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، حَدَّثَنَا ابْنُ أَبِي عَدِيٍّ، عَنْ خَالِدٍ الْحَذَّاءِ، عَنْ أَبِي قِلاَبَةَ، عَنْ ثَابِتِ بْنِ الضَّحَّاكِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ حَلَفَ بِمِلَّةٍ سِوَى الإِسْلاَمِ كَاذِبًا مُتَعَمِّدًا فَهُوَ كَمَا قَالَ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: سنن ابی داود/الزکاة ۱ (۱۵۵۹)، بلفظ مختوما بدل صاعا سنن النسائی/الزکاة ۲۴ (۲۴۸۸)،(تحفة الأشراف:۴۰۴۲)، وقد أخرجہ: مسند احمد (۳/۵۹،۸۳،۹۷),,It was narrated that Thabit bin Ad-Dahhak said:,The Chapters on Expiation
1833,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا بَقِيَّةُ، عَنْ عَبْدِ اللَّهِ بْنِ مُحَرَّرٍ، عَنْ قَتَادَةَ، عَنْ أَنَسٍ، قَالَ سَمِعَ النَّبِيُّ ـ صلى الله عليه وسلم ـ رَجُلاً يَقُولُ أَنَا إِذًا لَيَهُودِيٌّ ‏.‏ فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ وَجَبَتْ ‏""""‏ ‏.‏""",Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۴۸۴،۲۹۴۲، ومصباح الزجاجة:۶۵۲),,It was narrated from Anas that the Messenger of Allah (ﷺ) heard a man say:,The Chapters on Expiation
1834,"حَدَّثَنَا عَمْرُو بْنُ رَافِعٍ الْبَجَلِيُّ، حَدَّثَنَا الْفَضْلُ بْنُ مُوسَى، عَنِ الْحُسَيْنِ بْنِ وَاقِدٍ، عَنْ عَبْدِ اللَّهِ بْنِ بُرَيْدَةَ، عَنْ أَبِيهِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ قَالَ إِنِّي بَرِيءٌ مِنَ الإِسْلاَمِ فَإِنْ كَانَ كَاذِبًا فَهُوَ كَمَا قَالَ وَإِنْ كَانَ صَادِقًا لَمْ يَعُدْ إِلَيْهِ الإِسْلاَمُ سَالِمًا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/الزکاة ۴۸ (۱۴۶۶)، صحیح مسلم/الزکاة ۱۴ (۱۰۰۰)، سنن الترمذی/الزکاة ۱۲ (۶۳۵،۶۳۶)، سنن النسائی/الزکاة ۸۲ (۲۵۸۴)،(تحفة الأشراف:۱۵۸۸۷)، وقد أخرجہ: مسند احمد (۳/۵۰۲،۳۶۳)، سنن الدارمی/الزکاة ۲۳ (۱۶۹۴),,It was narrated from Abdullah bin Buraidah that his father told that :,The Chapters on Expiation
1835,"حَدَّثَنَا مُحَمَّدُ بْنُ إِسْمَاعِيلَ بْنِ سَمُرَةَ، حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ سَمِعَ النَّبِيُّ ـ صلى الله عليه وسلم ـ رَجُلاً يَحْلِفُ بِأَبِيهِ فَقَالَ ‏ ‏ لاَ تَحْلِفُوا بِآبَائِكُمْ مَنْ حَلَفَ بِاللَّهِ فَلْيَصْدُقْ وَمَنْ حُلِفَ لَهُ بِاللَّهِ فَلْيَرْضَ وَمَنْ لَمْ يَرْضَ بِاللَّهِ فَلَيْسَ مِنَ اللَّهِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۸۲۶۸)، وقد أخرجہ: صحیح البخاری/الزکاة ۴۸ (۱۴۶۷)، صحیح مسلم/الزکاة ۴ (۱۰۰۱),,It was narrated that Ibn 'Umar said:,The Chapters on Expiation
1836,"حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِيلَ، عَنْ أَبِي بَكْرِ بْنِ يَحْيَى بْنِ النَّضْرِ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ رَأَى عِيسَى ابْنُ مَرْيَمَ رَجُلاً يَسْرِقُ فَقَالَ أَسَرَقْتَ قَالَ لاَ وَالَّذِي لاَ إِلَهَ إِلاَّ هُوَ ‏.‏ فَقَالَ عِيسَى آمَنْتُ بِاللَّهِ وَكَذَّبْتُ بَصَرِي ‏""""‏ ‏.‏""",Al-Albani: Sahih Hadith; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: صحیح البخاری/الزکاة ۵۰ (۱۴۷۱)،(تحفة الأشراف:۳۶۳۳),,It was narrated from Abu Hurairah that the Prophet (ﷺ) said:,The Chapters on Expiation
1837,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، عَنْ بَشَّارِ بْنِ كِدَامٍ، عَنْ مُحَمَّدِ بْنِ زَيْدٍ، عَنِ ابْنِ عُمَرَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِنَّمَا الْحَلِفُ حِنْثٌ أَوْ نَدَمٌ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: سنن النسائی/الزکاة ۸۶ (۲۵۹۱)،(تحفة الأشراف:۲۰۹۸)، وقد أخرجہ: سنن ابی داود/الزکاة ۲۷ (۱۶۴۳)، مسند احمد (۵/۲۷۵،۲۷۶،۲۷۹),,It was narrated from Ibn 'Umar that :,The Chapters on Expiation
1838,"حَدَّثَنَا الْعَبَّاسُ بْنُ عَبْدِ الْعَظِيمِ الْعَنْبَرِيُّ، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَنْبَأَنَا مَعْمَرٌ، عَنِ ابْنِ طَاوُسٍ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ حَلَفَ فَقَالَ إِنْ شَاءَ اللَّهُ فَلَهُ ثُنْيَاهُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: صحیح مسلم/الزکاة ۳۵ (۱۰۴۱)،(تحفة الأشراف:۱۴۹۱۰)، وقد أخرجہ: مسند احمد (۲/۳۳۱),,It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said:,The Chapters on Expiation
1839,"حَدَّثَنَا مُحَمَّدُ بْنُ زِيَادٍ، حَدَّثَنَا عَبْدُ الْوَارِثِ بْنُ سَعِيدٍ، عَنْ أَيُّوبَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ حَلَفَ وَاسْتَثْنَى إِنْ شَاءَ رَجَعَ وَإِنْ شَاءَ تَرَكَ غَيْرُ حَانِثٍ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن النسائی/الزکاة ۹۰ (۲۵۹۸)،(تحفة الأشراف:۱۲۹۱۰)، وقد أخرجہ: مسند احمد (۲/۳۷۷،۳۸۹),,It was narrated from Ibn 'Umar that the Messenger of Allah (ﷺ) said:,The Chapters on Expiation
1840,"حَدَّثَنَا عَبْدُ اللَّهِ بْنُ مُحَمَّدٍ الزُّهْرِيُّ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ أَيُّوبَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، رِوَايَةً قَالَ ‏ ‏ مَنْ حَلَفَ وَاسْتَثْنَى فَلَمْ يَحْنَثْ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: سنن ابی داود/الزکاة ۲۳ (۱۶۲۶)، سنن الترمذی/الزکاة ۲۲ (۶۵۰)، سنن النسائی/الزکاة ۸۷ (۲۵۹۳)،(تحفة الأشراف:۹۳۸۷)، وقد أخرجہ: مسند احمد (۱/۳۸۸،۴۴۱)، سنن الدارمی/الزکاة ۵ ۱ (۱۶۸۰),,It was narrated from Ibn 'Umar:,The Chapters on Expiation
1841,"حَدَّثَنَا أَحْمَدُ بْنُ عَبْدَةَ، أَنْبَأَنَا حَمَّادُ بْنُ زَيْدٍ، حَدَّثَنَا غَيْلاَنُ بْنُ جَرِيرٍ، عَنْ أَبِي بُرْدَةَ، عَنْ أَبِيهِ أَبِي مُوسَى، قَالَ أَتَيْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ فِي رَهْطٍ مِنَ الأَشْعَرِيِّينَ نَسْتَحْمِلُهُ فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏""‏ وَاللَّهِ مَا أَحْمِلُكُمْ وَمَا عِنْدِي مَا أَحْمِلُكُمْ عَلَيْهِ ‏""‏ ‏.‏ قَالَ فَلَبِثْنَا مَا شَاءَ اللَّهُ ثُمَّ أُتِيَ بِإِبِلٍ فَأَمَرَ لَنَا بِثَلاَثَةِ إِبِلٍ ذَوْدٍ غُرِّ الذُّرَى فَلَمَّا انْطَلَقْنَا قَالَ بَعْضُنَا لِبَعْضٍ أَتَيْنَا رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ نَسْتَحْمِلُهُ فَحَلَفَ أَلاَّ يَحْمِلَنَا ثُمَّ حَمَلَنَا ارْجِعُوا بِنَا ‏.‏ فَأَتَيْنَاهُ فَقُلْنَا يَا رَسُولَ اللَّهِ إِنَّا أَتَيْنَاكَ نَسْتَحْمِلُكَ فَحَلَفْتَ أَنْ لاَ تَحْمِلَنَا ‏.‏ ثُمَّ حَمَلْتَنَا فَقَالَ ‏""‏ وَاللَّهِ مَا أَنَا حَمَلْتُكُمْ فَإِنَّ اللَّهَ حَمَلَكُمْ وَاللَّهِ مَا أَنَا حَمَلْتُكُمْ بَلِ اللَّهُ حَمَلَكُمْ إِنِّي وَاللَّهِ إِنْ شَاءَ اللَّهُ لاَ أَحْلِفُ عَلَى يَمِينٍ فَأَرَى غَيْرَهَا خَيْرًا مِنْهَا إِلاَّ كَفَّرْتُ عَنْ يَمِينِي وَأَتَيْتُ الَّذِي هُوَ خَيْرٌ ‏""‏ ‏.‏ أَوْ قَالَ ‏""‏ أَتَيْتُ الَّذِي هُوَ خَيْرٌ وَكَفَّرْتُ عَنْ يَمِينِي ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: سنن ابی داود/الزکاة ۲۴ (۱۶۳۵)،(تحفة الأشراف:۴۱۷۷)، وقد أخرجہ: موطا امام مالک/الزکاة ۱۷ (۲۹)، مسند احمد (۳/۴،۳۱،۴۰،۵۶،۹۷),1841,It was narrated from Abu Burdah that his father Abu Musa said:,The Chapters on Expiation
1842,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، وَعَبْدُ اللَّهِ بْنُ عَامِرِ بْنِ زُرَارَةَ، قَالاَ حَدَّثَنَا أَبُو بَكْرِ بْنُ عَيَّاشٍ، عَنْ عَبْدِ الْعَزِيزِ بْنِ رُفَيْعٍ، عَنْ تَمِيمِ بْنِ طَرَفَةَ، عَنْ عَدِيِّ بْنِ حَاتِمٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ حَلَفَ عَلَى يَمِينٍ فَرَأَى غَيْرَهَا خَيْرًا مِنْهَا فَلْيَأْتِ الَّذِي هُوَ خَيْرٌ وَلْيُكَفِّرْ عَنْ يَمِينِهِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: صحیح البخاری/الزکاة ۸ (۴۱۱۰تعلیقاَ)، التوحید ۲۳ (۷۴۳۰تعلیقاً)، صحیح مسلم/الزکاة ۱۹ (۱۰۱۴)، سنن الترمذی/الزکاة ۲۸ (۶۶۱)، سنن النسائی/الزکاة ۴۸ (۲۵۲۶)،(تحفة الأشراف:۱۳۳۷۹)، وقد أخرجہ: موطا امام مالک/الصدقة ۱ (۱)مسند احمد (۲/۲۶۸،۳۳۱،۳۸۱،۴۱۸،۴۱۹،۲۳۱،۴۷۱،۵۳۸،۵۴۱)، سنن الدارمی/الزکاة ۳۵ (۱۷۱۷),,It was narrated from 'Adi bin Hatim that :,The Chapters on Expiation
1843,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِي عُمَرَ الْعَدَنِيُّ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، حَدَّثَنَا أَبُو الزَّعْرَاءِ، عَمْرُو بْنُ عَمْرٍو عَنْ عَمِّهِ أَبِي الأَحْوَصِ، عَوْفِ بْنِ مَالِكٍ الْجُشَمِيِّ عَنْ أَبِيهِ، قَالَ قُلْتُ يَا رَسُولَ اللَّهِ يَأْتِينِي ابْنُ عَمِّي فَأَحْلِفُ أَنْ لاَ، أُعْطِيَهُ وَلاَ أَصِلَهُ ‏.‏ قَالَ ‏ ‏ كَفِّرْ عَنْ يَمِينِكَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: صحیح البخاری/الزکاة ۹ (۱۴۱۳)،۱۰ (۱۴۱۷)، المناقب ۲۵ (۳۵۹۵)، الأدب ۳۴ (۶۰۲۳)، الرقاق ۴۹ (۶۵۳۹)،۵۱ (۶۵۶۳)، التوحید ۳۶ (۷۵۱۲)، صحیح مسلم/الزکاة ۲۰ (۱۰۱۶)، سنن الترمذی/صفة القیامة ۱ (۲۴۱۵)، سنن النسائی/الزکاة ۶۳ (۲۵۵۴)،(تحفة الأشراف:۹۸۵۲)، وقد أخرجہ: مسند احمد (۴/۲۵۶،۲۵۸،۲۵۹،۳۷۷),,It was narrated from Abul-Ahwas 'Awf bin Malik Al- Jushami that his father said:,The Chapters on Expiation
1844,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، عَنْ حَارِثَةَ بْنِ أَبِي الرِّجَالِ، عَنْ عَمْرَةَ، عَنْ عَائِشَةَ، قَالَتْ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ حَلَفَ فِي قَطِيعَةِ رَحِمٍ أَوْ فِيمَا لاَ يَصْلُحُ فَبِرُّهُ أَنْ لاَ يَتِمَّ عَلَى ذَلِكَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: سنن الترمذی/الزکاة ۲۶ (۶۵۸)، سنن النسائی/الزکاة ۸۲ (۲۵۸۳)،(تحفة الأشراف:۴۴۸۶)، وقد أخرجہ: مسند احمد (۴/۱۸،۲۱۴)، سنن الدارمی/الزکاة ۳۸ (۱۷۲۲،۱۷۲۳),,It was narrated from 'Aishah that the Messenger of Allah (ﷺ) said:,The Chapters on Expiation
1845,"حَدَّثَنَا عَبْدُ اللَّهِ بْنُ عَبْدِ الْمُؤْمِنِ الْوَاسِطِيُّ، حَدَّثَنَا عَوْنُ بْنُ عُمَارَةَ، حَدَّثَنَا رَوْحُ بْنُ الْقَاسِمِ، عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ عَمْرِو بْنِ شُعَيْبٍ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، ‏.‏ أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ مَنْ حَلَفَ عَلَى يَمِينٍ فَرَأَى غَيْرَهَا خَيْرًا مِنْهَا فَلْيَتْرُكْهَا فَإِنَّ تَرْكَهَا كَفَّارَتُهَا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/الصوم ۱۰ (۱۹۰۵)، النکاح ۲ (۵۰۶۵)، صحیح مسلم/النکاح ۱ (۱۴۰۰)، سنن ابی داود/النکاح ۱ (۲۰۴۶)، سنن الترمذی/النکاح ۱ (۱۰۸۱تعلیقاً)، سنن النسائی/الصیام ۴۳ (۲۲۴۱)، النکاح ۳ (۳۲۰۹)،(تحفة الأشراف:۹۴۱۷)، وقد أخرجہ: مسند احمد (۱/۵۸،۳۷۸،۴۲۴،۴۲۵،۴۳۲)، سنن الدارمی/النکاح ۲ (۲۲۱۲),,"It was narrated from 'Amr bin Shu'aib, from his father, that his grandfather said that the Prophet (ﷺ) said:",The Chapters on Expiation
1846,حَدَّثَنَا الْعَبَّاسُ بْنُ يَزِيدَ، حَدَّثَنَا زِيَادُ بْنُ عَبْدِ اللَّهِ الْبَكَّائِيُّ، حَدَّثَنَا عُمَرُ بْنُ عَبْدِ اللَّهِ بْنِ يَعْلَى الثَّقَفِيُّ، عَنِ الْمِنْهَالِ بْنِ عَمْرٍو، عَنْ سَعِيدِ بْنِ جُبَيْرٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ كَفَّرَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ بِصَاعٍ مِنْ تَمْرٍ وَأَمَرَ النَّاسَ بِذَلِكَ فَمَنْ لَمْ يَجِدْ فَنِصْفُ صَاعٍ مِنْ بُرٍّ ‏.‏,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۷۵۴۹، ومصباح الزجاجة:۶۵۴),1846,It was narrated that Ibn Abbas said:,The Chapters on Expiation
1847,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ سُلَيْمَانَ بْنِ أَبِي الْمُغِيرَةِ، عَنْ سَعِيدِ بْنِ جُبَيْرٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ كَانَ الرَّجُلُ يَقُوتُ أَهْلَهُ قُوتًا فِيهِ سَعَةٌ وَكَانَ الرَّجُلُ يَقُوتُ أَهْلَهُ قُوتًا فِيهِ شِدَّةٌ فَنَزَلَتْ ‏{مِنْ أَوْسَطِ مَا تُطْعِمُونَ أَهْلِيكُمْ}‏ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۶۹۵، ومصباح الزجاجة:۶۵۵),1847,It was narrated that Ibn 'Abbas said:,The Chapters on Expiation
1848,"حَدَّثَنَا سُفْيَانُ بْنُ وَكِيعٍ، حَدَّثَنَا مُحَمَّدُ بْنُ حُمَيْدٍ الْمَعْمَرِيُّ، عَنْ مَعْمَرٍ، عَنْ هَمَّامٍ، قَالَ سَمِعْتُ أَبَا هُرَيْرَةَ، يَقُولُ قَالَ أَبُو الْقَاسِمِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِذَا اسْتَلَجَّ أَحَدُكُمْ فِي الْيَمِينِ فَإِنَّهُ آثَمُ لَهُ عِنْدَ اللَّهِ مِنَ الْكَفَّارَةِ الَّتِي أُمِرَ بِهَا ‏""""‏ ‏.‏ حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا يَحْيَى بْنُ صَالِحٍ الْوُحَاظِيُّ، حَدَّثَنَا مُعَاوِيَةُ بْنُ سَلاَّمٍ، عَنْ يَحْيَى بْنِ أَبِي كَثِيرٍ، عَنْ عِكْرِمَةَ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ نَحْوَهُ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/النکاح ۸ (۵۰۷۳،۵۰۷۴)، صحیح مسلم/النکاح ۱ (۱۴۰۲)، سنن الترمذی/النکاح ۲ (۱۰۸۳)، سنن النسائی/النکاح ۴ (۳۲۱۴)،(تحفة الأشراف:۳۸۵۶)، وقد أخرجہ: مسند احمد (۱/۱۷۵،۱۷۶،۱۸۳)، سنن الدارمی/ النکاح ۳ (۲۲۱۳),,It was narrated that Hammam heard Abu Hurairah saying that 'Abul-Qasim (ﷺ) said:,The Chapters on Expiation
1849,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، عَنْ عَلِيِّ بْنِ صَالِحٍ، عَنْ أَشْعَثَ بْنِ أَبِي الشَّعْثَاءِ، عَنْ مُعَاوِيَةَ بْنِ سُوَيْدِ بْنِ مُقَرِّنٍ، عَنِ الْبَرَاءِ بْنِ عَازِبٍ، قَالَ أَمَرَنَا رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ بِإِبْرَارِ الْمُقْسِمِ ‏.‏,Al-Albani: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: سنن الترمذی/النکاح ۲ (۱۰۸۲)، سنن النسائی/النکاح ۴ (۳۲۱۶)،(تحفة الأشراف:۴۵۹۰)، مسند احمد (۵/۱۷),1849,It was narrated that Bara' bin 'Azib said:,The Chapters on Expiation
1850,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا مُحَمَّدُ بْنُ فُضَيْلٍ، عَنْ يَزِيدَ بْنِ أَبِي زِيَادٍ، عَنْ مُجَاهِدٍ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ صَفْوَانَ، أَوْ عَنْ صَفْوَانَ بْنِ عَبْدِ الرَّحْمَنِ الْقُرَشِيِّ، قَالَ لَمَّا كَانَ يَوْمُ فَتْحِ مَكَّةَ جَاءَ بِأَبِيهِ فَقَالَ يَا رَسُولَ اللَّهِ اجْعَلْ لأَبِي نَصِيبًا فِي الْهِجْرَةِ ‏.‏ فَقَالَ ‏""‏ إِنَّهُ لاَ هِجْرَةَ ‏""‏ ‏.‏ فَانْطَلَقَ فَدَخَلَ عَلَى الْعَبَّاسِ فَقَالَ قَدْ عَرَفْتَنِي فَقَالَ أَجَلْ ‏.‏ فَخَرَجَ الْعَبَّاسُ فِي قَمِيصٍ لَيْسَ عَلَيْهِ رِدَاءٌ فَقَالَ يَا رَسُولَ اللَّهِ قَدْ عَرَفْتَ فُلاَنًا وَالَّذِي بَيْنَنَا وَبَيْنَهُ جَاءَ بِأَبِيهِ لِيُبَايِعَكَ عَلَى الْهِجْرَةِ ‏.‏ فَقَالَ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏""‏ إِنَّهُ لاَ هِجْرَةَ ‏""‏ ‏.‏ فَقَالَ الْعَبَّاسُ أَقْسَمْتُ عَلَيْكَ ‏.‏ فَمَدَّ النَّبِيُّ ـ صلى الله عليه وسلم ـ يَدَهُ فَمَسَّ يَدَهُ فَقَالَ ‏""‏ أَبْرَرْتُ عَمِّي وَلاَ هِجْرَةَ ‏""‏ ‏.‏ حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا الْحَسَنُ بْنُ الرَّبِيعِ، عَنْ عَبْدِ اللَّهِ بْنِ إِدْرِيسَ، عَنْ يَزِيدَ بْنِ أَبِي زِيَادٍ، بِإِسْنَادِهِ نَحْوَهُ ‏.‏ قَالَ يَزِيدُ بْنُ أَبِي زِيَادٍ يَعْنِي لاَ هِجْرَةَ مِنْ دَارٍ قَدْ أَسْلَمَ أَهْلُهَا ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: سنن ابی داود/النکاح ۴۲ (۲۱۴۲)،(تحفة الأشراف:۱۱۳۹۶)، وقد أخرجہ: مسند احمد (۴/۴۴۷،۵/۳),,"It was narrated from Mujahid, that 'Abdur-Rahman bin Safwan, or Safwan bin 'Abdur- Rahman Al-Qurashi said:",The Chapters on Expiation
1851,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا عِيسَى بْنُ يُونُسَ، حَدَّثَنَا الأَجْلَحُ الْكِنْدِيُّ، عَنْ يَزِيدَ بْنِ الأَصَمِّ، عَنِ ابْنِ عَبَّاسٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِذَا حَلَفَ أَحَدُكُمْ فَلاَ يَقُلْ مَا شَاءَ اللَّهُ وَشِئْتَ ‏.‏ وَلَكِنْ لِيَقُلْ مَا شَاءَ اللَّهُ ثُمَّ شِئْتَ ‏""""‏ ‏.‏""",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Isnaad Sahih,takhreej: سنن الترمذی/الرضاع ۱۱ (۱۱۶۳)، تفسیر ۱۰ (۳۰۸۷)،(تحفة الأشراف:۱۰۶۹۲),,It was narrated from Ibn 'Abbas that the Messenger of Allah (ﷺ) said:,The Chapters on Expiation
1852,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عَبْدِ الْمَلِكِ بْنِ عُمَيْرٍ، عَنْ رِبْعِيِّ بْنِ حِرَاشٍ، عَنْ حُذَيْفَةَ بْنِ الْيَمَانِ، أَنَّ رَجُلاً، مِنَ الْمُسْلِمِينَ رَأَى فِي النَّوْمِ أَنَّهُ لَقِيَ رَجُلاً مِنْ أَهْلِ الْكِتَابِ فَقَالَ نِعْمَ الْقَوْمُ أَنْتُمْ لَوْلاَ أَنَّكُمْ تُشْرِكُونَ تَقُولُونَ مَا شَاءَ اللَّهُ وَشَاءَ مُحَمَّدٌ ‏.‏ وَذَكَرَ ذَلِكَ لِلنَّبِيِّ ـ صلى الله عليه وسلم ـ فَقَالَ ‏ ‏ أَمَا وَاللَّهِ إِنْ كُنْتُ لأَعْرِفُهَا لَكُمْ قُولُوا مَا شَاءَ اللَّهُ ثُمَّ شَاءَ مُحَمَّدٌ ‏""""‏ ‏.‏ حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الْمَلِكِ بْنِ أَبِي الشَّوَارِبِ، حَدَّثَنَا أَبُو عَوَانَةَ، عَنْ عَبْدِ الْمَلِكِ، عَنْ رِبْعِيِّ بْنِ حِرَاشٍ، عَنِ الطُّفَيْلِ بْنِ سَخْبَرَةَ، أَخِي عَائِشَةَ لأُمِّهَا عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ بِنَحْوِهِ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۶۱۲۰، ومصباح الزجاجة:۶۵۶)، وقد أخرجہ: مسند احمد (۶/۴۷،۷۶،۹۷،۱۱۲،۱۳۵),,It was narrated from Hudhaifah bin Yaman that :,The Chapters on Expiation
1853,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ مُوسَى، عَنْ إِسْرَائِيلَ، ح وَحَدَّثَنَا يَحْيَى بْنُ حَكِيمٍ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ مَهْدِيٍّ، عَنْ إِسْرَائِيلَ، عَنْ إِبْرَاهِيمَ بْنِ عَبْدِ الأَعْلَى، عَنْ جَدَّتِهِ، عَنْ أَبِيهَا، سُوَيْدِ بْنِ حَنْظَلَةَ قَالَ خَرَجْنَا نُرِيدُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ وَمَعَنَا وَائِلُ بْنُ حُجْرٍ فَأَخَذَهُ عَدُوٌّ لَهُ فَتَحَرَّجَ النَّاسُ أَنْ يَحْلِفُوا فَحَلَفْتُ أَنَا أَنَّهُ أَخِي فَخَلَّى سَبِيلَهُ فَأَتَيْنَا رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ فَأَخْبَرْتُهُ أَنَّ الْقَوْمَ تَحَرَّجُوا أَنْ يَحْلِفُوا وَحَلَفْتُ أَنَا أَنَّهُ أَخِي فَقَالَ ‏ ‏ صَدَقْتَ الْمُسْلِمُ أَخُو الْمُسْلِمِ ‏""""‏ ‏.‏""",Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Isnaad Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۱۸۰، ومصباح الزجاجة:۶۵۷)، وقد أخرجہ: مسند احمد (/۳۸۱۴),,It was narrated that Suwaid bin Hanzalah said:,The Chapters on Expiation
1854,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، أَنْبَأَنَا هُشَيْمٌ، عَنْ عَبَّادِ بْنِ أَبِي صَالِحٍ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِنَّمَا الْيَمِينُ عَلَى نِيَّةِ الْمُسْتَحْلِفِ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Hasan Lighairihi; Zubair Ali Zai: Hasan,takhreej: سنن الترمذی/الرضاع ۱۰ (۱۱۶۱)،(تحفة الأشراف:۱۸۲۹۴),,It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said:,The Chapters on Expiation
1855,"حَدَّثَنَا عَمْرُو بْنُ رَافِعٍ، حَدَّثَنَا هُشَيْمٌ، أَنْبَأَنَا عَبْدُ اللَّهِ بْنُ أَبِي صَالِحٍ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ يَمِينُكَ عَلَى مَا يُصَدِّقُكَ بِهِ صَاحِبُكَ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: صحیح مسلم/الرضاع ۱۷ (۱۴۶۷)، سنن النسائی/النکاح ۱۵ (۳۲۳۴)،(تحفة الأشراف:۸۸۴۹)، مسند احمد (۲/۱۶۸),,It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said:,The Chapters on Expiation
1856,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، عَنْ سُفْيَانَ، عَنْ مَنْصُورٍ، عَنْ عَبْدِ اللَّهِ بْنِ مُرَّةَ، عَنْ عَبْدِ اللَّهِ بْنِ عُمَرَ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنِ النَّذْرِ وَقَالَ ‏ ‏ إِنَّمَا يُسْتَخْرَجُ بِهِ مِنَ اللَّئِيمِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۰۸۴، ومصباح الزجاجة:۶۵۸)، وقد أخرجہ: سنن الترمذی/تفسیرالقرآن ۱۰ (۳۰۹۴)، مسند احمد (۵/۲۷۸،۲۸۲),,It was narrated that 'Abdullah bin 'Umar said:,The Chapters on Expiation
1857,"حَدَّثَنَا أَحْمَدُ بْنُ يُوسُفَ، حَدَّثَنَا عُبَيْدُ اللَّهِ، عَنْ سُفْيَانَ، عَنْ أَبِي الزِّنَادِ، عَنِ الأَعْرَجِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِنَّ النَّذْرَ لاَ يَأْتِي ابْنَ آدَمَ بِشَىْءٍ إِلاَّ مَا قُدِّرَ لَهُ وَلَكِنْ يَغْلِبُهُ الْقَدَرُ مَا قُدِّرَ لَهُ فَيُسْتَخْرَجُ بِهِ مِنَ الْبَخِيلِ فَيَتَيَسَّرُ عَلَيْهِ مَا لَمْ يَكُنْ يَتَيَسَّرُ عَلَيْهِ مِنْ قَبْلِ ذَلِكَ وَقَدْ قَالَ اللَّهُ أَنْفِقْ أُنْفِقْ عَلَيْكَ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۹۱۹، ومصباح الزجاجة:۶۵۹),,It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said:,The Chapters on Expiation
1858,"حَدَّثَنَا سَهْلُ بْنُ أَبِي سَهْلٍ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، حَدَّثَنَا أَيُّوبُ، عَنْ أَبِي قِلاَبَةَ، عَنْ عَمِّهِ، عَنْ عِمْرَانَ بْنِ الْحُصَيْنِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لاَ نَذْرَ فِي مَعْصِيَةٍ وَلاَ نَذْرَ فِيمَا لاَ يَمْلِكُ ابْنُ آدَمَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/النکاح ۱۵ (۵۰۹۰)، صحیح مسلم/الرضاع ۱۵ (۱۴۶۶)، سنن ابی داود/النکاح ۲ (۲۰۴۷)، سنن النسائی/النکاح ۱۳ (۳۲۳۲)،(تحفة الأشراف:۱۳۳۰۵)، وقد أخرجہ: مسند احمد (۲/۴۲۸)، سنن الدارمی/النکاح ۴ (۲۲۱۶),,It was narrated from 'Imran bin Husain that the Messenger of Allah (ﷺ) said:,The Chapters on Expiation
1859,"حَدَّثَنَا أَحْمَدُ بْنُ عَمْرِو بْنِ السَّرْحِ الْمِصْرِيُّ أَبُو طَاهِرٍ، حَدَّثَنَا ابْنُ وَهْبٍ، أَنْبَأَنَا يُونُسُ، عَنِ ابْنِ شِهَابٍ، عَنْ أَبِي سَلَمَةَ، عَنْ عَائِشَةَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ لاَ نَذْرَ فِي مَعْصِيَةٍ وَكَفَّارَتُهُ كَفَّارَةُ يَمِينٍ ‏""""‏ ‏.‏""",Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۸۶۸، ومصباح الزجاجة:۶۶۰),,It was narrated from 'Aishah that the Messenger of Allah (ﷺ) said:,The Chapters on Expiation
1860,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو أُسَامَةَ، عَنْ عُبَيْدِ اللَّهِ، عَنْ طَلْحَةَ بْنِ عَبْدِ الْمَلِكِ، عَنِ الْقَاسِمِ بْنِ مُحَمَّدٍ، عَنْ عَائِشَةَ، قَالَتْ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ نَذَرَ أَنْ يُطِيعَ اللَّهَ فَلْيُطِعْهُ وَمَنْ نَذَرَ أَنْ يَعْصِيَ اللَّهَ فَلاَ يَعْصِهِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: صحیح مسلم/الرضاع ۱۶ (۷۱۵)، سنن النسائی/النکاح ۶ (۳۲۲۱)،۱۰ (۳۲۳۶)،(تحفة الأشراف:۲۴۳۶)، وقد أخرجہ: صحیح البخاری/البیوع ۳۴ (۲۰۹۷)، الوکالة ۸ (۲۴۰۹)، الجہاد ۱۱۳ (۲۹۶۷)، المغازي ۱۸ (۴۰۵۲)، النکاح ۱۰ (۵۰۷۹)،۱۲۱ (۵۲۴۵)،۱۲۲ (۵۲۴۷)، النفقات ۱۲ (۵۳۶۷)، الدعوات ۵۳ (۶۳۸۷)، سنن ابی داود/النکاح ۳ (۲۰۴۸)، سنن الترمذی/النکاح ۱۳ (۱۱۰۰)، مسند احمد (۳/۲۹۴،۳۰۲،۳۰۸،۳۱۴،۳۶۲،۳۶۹،۳۷۴،۳۷۶)، سنن الدارمی/النکاح ۳۲ (۲۲۶۲),,It was narrated from 'Aishah that the Messenger of Allah (ﷺ) said:,The Chapters on Expiation
1861,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ رَافِعٍ، عَنْ خَالِدِ بْنِ يَزِيدَ، عَنْ عُقْبَةَ بْنِ عَامِرٍ الْجُهَنِيِّ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ نَذَرَ نَذْرًا وَلَمْ يُسَمِّهِ فَكَفَّارَتُهُ كَفَّارَةُ يَمِينٍ ‏""""‏ ‏.‏""",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۷۵۶)، ومصباح الزجاجة:۶۶۱),,It was narrated from 'Uqbah bin 'Amit Al-Juhani that the Messenger of Allah (ﷺ) said:,The Chapters on Expiation
1862,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا عَبْدُ الْمَلِكِ بْنُ مُحَمَّدٍ الصَّنْعَانِيُّ، حَدَّثَنَا خَارِجَةُ بْنُ مُصْعَبٍ، عَنْ بُكَيْرِ بْنِ عَبْدِ اللَّهِ بْنِ الأَشَجِّ، عَنْ كُرَيْبٍ، عَنِ ابْنِ عَبَّاسٍ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ مَنْ نَذَرَ نَذْرًا وَلَمْ يُسَمِّهِ فَكَفَّارَتُهُ كَفَّارَةُ يَمِينٍ وَمَنْ نَذَرَ نَذْرًا لَمْ يُطِقْهُ فَكَفَّارَتُهُ كَفَّارَةُ يَمِينٍ وَمَنْ نَذَرَ نَذْرًا أَطَاقَهُ فَلْيَفِ بِهِ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۲۱، ومصباح الزجاجة:۶۶۲)، وقد أخرجہ: مسند احمد (۴/۲۲۵،۴۹۳),,lt was narrated from Ibn 'Abbas that the Prophet (ﷺ) said:,The Chapters on Expiation
1863,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا حَفْصُ بْنُ غِيَاثٍ، عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، عَنْ عُمَرَ بْنِ الْخَطَّابِ، قَالَ نَذَرْتُ نَذْرًا فِي الْجَاهِلِيَّةِ فَسَأَلْتُ النَّبِيَّ ـ صلى الله عليه وسلم ـ بَعْدَ مَا أَسْلَمْتُ فَأَمَرَنِي أَنْ أُوفِيَ بِنَذْرِي ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۴۱۸۱، ومصباح الزجاجة:۶۶۳),1863,It was narrated that 'Umar bin Khattab said:,The Chapters on Expiation
1864,"حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، وَعَبْدُ اللَّهِ بْنُ إِسْحَاقَ الْجَوْهَرِيُّ، قَالاَ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ رَجَاءٍ، أَنْبَأَنَا الْمَسْعُودِيُّ، عَنْ حَبِيبِ بْنِ أَبِي ثَابِتٍ، عَنْ سَعِيدِ بْنِ جُبَيْرٍ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ رَجُلاً، جَاءَ إِلَى النَّبِيِّ ـ صلى الله عليه وسلم ـ فَقَالَ يَا رَسُولَ اللَّهِ إِنِّي نَذَرْتُ أَنْ أَنْحَرَ بِبُوَانَةَ فَقَالَ ‏""‏ فِي نَفْسِكَ شَىْءٌ مِنْ أَمْرِ الْجَاهِلِيَّةِ ‏""‏ ‏.‏ قَالَ لاَ ‏.‏ قَالَ ‏""‏ أَوْفِ بِنَذْرِكَ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۲۲۸، ومصباح الزجاجة:۶۶۴)، وقد أخرجہ: مسند احمد (۳/۴۹۳،۴/۲۲۵),1864,It was narrated from Ibn Abbas that a man came to the Prophet (ﷺ) and said:,The Chapters on Expiation
1865,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِيَةَ، عَنْ عَبْدِ اللَّهِ بْنِ عَبْدِ الرَّحْمَنِ الطَّائِفِيِّ، عَنْ مَيْمُونَةَ بِنْتِ كَرْدَمٍ الْيَسَارِيَّةِ، أَنَّ أَبَاهَا، لَقِيَ النَّبِيَّ ـ صلى الله عليه وسلم ـ وَهِيَ رَدِيفَةٌ لَهُ فَقَالَ إِنِّي نَذَرْتُ أَنْ أَنْحَرَ بِبُوَانَةَ فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏""‏ هَلْ بِهَا وَثَنٌ ‏""‏ ‏.‏ قَالَ لاَ ‏.‏ قَالَ ‏""‏ أَوْفِ بِنَذْرِكَ ‏""‏ ‏.‏ حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا ابْنُ دُكَيْنٍ، عَنْ عَبْدِ اللَّهِ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ يَزِيدَ بْنِ مِقْسَمٍ، عَنْ مَيْمُونَةَ بِنْتِ كَرْدَمٍ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ بِنَحْوِهِ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۹۰، ومصباح الزجاجة:۶۶۵)، وقد أخرجہ: سنن الترمذی/النکاح ۵ (۱۰۸۷)، سنن النسائی/النکاح ۱۷ (۳۲۳۷)، مسند احمد (۴/۲۴۵،۲۴۶)، سنن الدارمی/النکاح ۵ (۲۲۱۸),,It was narrated from Maimunah bint Kardam Al-Yasariyyah that :,The Chapters on Expiation
1866,"حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، عَنِ ابْنِ شِهَابٍ، عَنْ عُبَيْدِ اللَّهِ بْنِ عَبْدِ اللَّهِ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ سَعْدَ بْنَ عُبَادَةَ، اسْتَفْتَى رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ فِي نَذْرٍ كَانَ عَلَى أُمِّهِ تُوُفِّيَتْ وَلَمْ تَقْضِهِ فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ اقْضِهِ عَنْهَا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: سنن الترمذی/النکاح ۵ (۱۰۸۷)، سنن النسائی/النکاح ۱۷ (۳۲۳۷)،(تحفة الأشراف:۱۱۴۸۹)، وقد أخرجہ: مسند احمد (۴/۲۴۴، سنن الدارمی/النکاح ۵ (۲۲۱۸),,It was narrated from Ibn 'Abbas' that :,The Chapters on Expiation
1867,"حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا يَحْيَى بْنُ بُكَيْرٍ، حَدَّثَنَا ابْنُ لَهِيعَةَ، عَنْ عَمْرِو بْنِ دِينَارٍ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، ‏.‏ أَنَّ امْرَأَةً، أَتَتْ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ فَقَالَتْ إِنَّ أُمِّي تُوُفِّيَتْ وَعَلَيْهَا نَذْرُ صِيَامٍ فَتُوُفِّيَتْ قَبْلَ أَنْ تَقْضِيَهُ ‏.‏ فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لِيَصُمْ عَنْهَا الْوَلِيُّ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/البیوع ۵۸ (۲۱۴۰)، الشروط ۸ (۲۷۲۳)، النکاح ۴۵ (۵۱۴۲)، صحیح مسلم/النکاح ۶ (۱۴۱۳)، سنن ابی داود/النکاح ۱۸ (۲۰۸۰)، سنن الترمذی/النکاح ۳۸ (۱۱۳۴)، سنن النسائی/النکاح ۲۰ (۳۲۴۱)،(تحفة الأشراف:۱۳۱۲۳)، وقد أخرجہ: موطا امام مالک/النکاح ۱ (۱)، حم (۲/۲۳۸،۲۷۴،۳۱۱،۳۱۸،۳۹۴،۴۱۱،۴۲۷،۴۵۷،۴۶۲،۴۶۳،۴۸۷،۴۸۹،۵۵۸، سنن الدارمی/النکاح ۷ (۲۲۲۱),,It was narrated from Jabir  bin 'Abdullsh that :,The Chapters on Expiation
1868,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، عَنْ يَحْيَى بْنِ سَعِيدٍ، عَنْ عُبَيْدِ اللَّهِ بْنِ زَحْرٍ، عَنْ أَبِي سَعِيدٍ الرُّعَيْنِيِّ، أَنَّ عَبْدَ اللَّهِ بْنَ مَالِكٍ، أَخْبَرَهُ أَنَّ عُقْبَةَ بْنَ عَامِرٍ أَخْبَرَهُ أَنَّ أُخْتَهُ نَذَرَتْ أَنْ تَمْشِيَ حَافِيَةً غَيْرَ مُخْتَمِرَةٍ وَأَنَّهُ ذَكَرَ ذَلِكَ لِرَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ فَقَالَ ‏ ‏ مُرْهَا فَلْتَرْكَبْ وَلْتَخْتَمِرْ وَلْتَصُمْ ثَلاَثَةَ أَيَّامٍ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: صحیح مسلم/النکاح ۶ (۱۴۱۲)، البیوع ۸ (۱۴۱۲)،(تحفة الأشراف:۸۱۸۵)، وقد أخرجہ: صحیح البخاری/النکاح ۴۵ (۵۱۴۲)، سنن ابی داود/النکاح ۱۸ (۲۰۸۱)، سنن الترمذی/البیوع ۵۷ (۱۱۳۴)، سنن النسائی/النکاح ۲۰ (۳۲۳۸)، موطا امام مالک/النکاح ۱ (۲)، البیوع ۴۵ (۴۵)، مسند احمد (۲/۱۲۲،۱۲۴،۱۲۶،۱۳۰،۱۴۲،۱۵۳)، سنن الدارمی/النکاح ۷ (۲۲۲۲)، البیوع ۳۳ (۲۶۰۹),,"It was narrated from Abu Sa'eed Ar-Ru'aini that 'Abdullah bin Malik told him, that :",The Chapters on Expiation
1869,"حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ، عَنْ عَمْرِو بْنِ أَبِي عَمْرٍو، عَنِ الأَعْرَجِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ رَأَى النَّبِيُّ ـ صلى الله عليه وسلم ـ شَيْخًا يَمْشِي بَيْنَ ابْنَيْهِ فَقَالَ ‏""‏ مَا شَأْنُ هَذَا ‏""‏ ‏.‏ قَالَ ابْنَاهُ نَذْرٌ يَا رَسُولَ اللَّهِ ‏.‏ قَالَ ‏""‏ ارْكَبْ أَيُّهَا الشَّيْخُ فَإِنَّ اللَّهَ غَنِيٌّ عَنْكَ وَعَنْ نَذْرِكَ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: صحیح مسلم/الطلاق ۶ (۱۴۸۰)، سنن الترمذی/النکاح ۳۷ (۱۱۳۵)سنن النسائی/النکاح ۸ (۳۲۲۴)، الطلاق ۷۳ (۳۵۸۲)،(تحفة الأشراف:۱۸۰۳۷)، وقد أخرجہ: سنن ابی داود/الطلاق ۳۹ (۲۸۸۴)، موطا امام مالک/الطلاق ۲۳ (۶۷)، مسند احمد (۶/۴۱۴،۴۱۵)، سنن الدارمی/النکاح ۷ (۲۲۲۳),1869,It was narrated that Abu Hurairah said:,The Chapters on Expiation
1870,"حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا إِسْحَاقُ بْنُ مُحَمَّدٍ الْفَرْوِيُّ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ عُمَرَ، عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ عَطَاءٍ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ مَرَّ بِرَجُلٍ بِمَكَّةَ وَهُوَ قَائِمٌ فِي الشَّمْسِ فَقَالَ ‏""‏ مَا هَذَا ‏""‏ ‏.‏ قَالُوا نَذَرَ أَنْ يَصُومَ وَلاَ يَسْتَظِلَّ إِلَى اللَّيْلِ وَلاَ يَتَكَلَّمَ وَلاَ يَزَالَ قَائِمًا ‏.‏ قَالَ ‏""‏ لِيَتَكَلَّمْ وَلْيَسْتَظِلَّ وَلْيَجْلِسْ وَلْيُتِمَّ صِيَامَهُ ‏""‏ ‏.‏ حَدَّثَنَا الْحُسَيْنُ بْنُ مُحَمَّدِ بْنِ شَنَبَةَ الْوَاسِطِيُّ، حَدَّثَنَا الْعَلاَءُ بْنُ عَبْدِ الْجَبَّارِ، عَنْ وُهَيْبٍ، عَنْ أَيُّوبَ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ نَحْوَهُ وَاللَّهُ أَعْلَمُ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: صحیح مسلم/النکاح ۹ (۱۴۲۱)، سنن ابی داود/النکاح ۲۶ (۲۰۹۸)، سنن الترمذی/النکاح ۱۷ (۱۱۰۸)، سنن النسائی/النکاح ۳۱ (۳۲۶۲)،(تحفة الأشراف:۶۵۱۷)، وقد أخرجہ: موطا امام مالک/النکاح ۲ (۳)، مسند احمد (۱/۲۱۹،۲۴۲،۲۷۴،۳۵۴،۳۶۲)، سنن الدارمی/النکاح ۱۳ (۲۲۳۴),,It was narrated from Ibn Abbas that the  :,The Chapters on Expiation
2090,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ مُصْعَبٍ، ‏‏‏‏‏‏عَنْ ال,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۶۱۲، ومصباح الزجاجة:۷۳۵),2090,,The Chapters on Expiation
2091,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْمَلِكِ بْنُ مُحَمَّدٍ الصَّنْعَانِيُّ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۶۱۲، ومصباح الزجاجة:۷۳۶),2091,,The Chapters on Expiation
2092,حَدَّثَنَا أَبُو إِسْحَاق الشَّافِعِيُّ إِبْرَاهِيمُ بْنُ مُحَمَّدِ بْنِ الْعَبَّاسِ، ‏‏‏‏‏‏حَدَّثَن,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Daif,takhreej: سنن النسائی/الأیمان والنذور ۱ (۳۷۹۳)،(تحفة الأشراف:۶۸۶۵)، وقد أخرجہ: صحیح البخاری/القدر۱۴ (۶۶۱۷)، الأیمان ۳ (۶۶۲۸)، التوحید ۱۱ (۷۳۹۱)، سنن ابی داود/الأیمان والنذور ۱۲ (۳۲۶۳)، سنن الترمذی/الأیمان ۱۲ (۱۵۴۰)، مسند احمد (۲/۲۶،۶۷،۱۲۷)، سنن الدارمی/الأیمان والنذور ۱۲ (۲۳۹۵),2092,,The Chapters on Expiation
2093,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ . ح وحَدَّثَنَا,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: سنن ابی داود/الأیمان والنذور ۱۲ (۳۲۶۵)،(تحفة الأشراف:۱۴۸۰۲)، وقد أخرجہ: مسند احمد (۲/۲۸۸),2093,,The Chapters on Expiation
2094,حَدَّثَنَا مُحَمَّدُ بْنُ أَبِي عُمَرَ الْعَدَنِيُّ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: صحیح البخاری/الأیمان ۴ (۶۶۴۷)، صحیح مسلم/الأیمان والنذور۵ (۱۶۴۶)، سنن النسائی/الأیمان والنذور ۴ (۳۷۹۸)، سنن ابی داود/الأیمان والنذور ۵ (۳۲۵۰)،(تحفة الأشراف:۱۰۵۱۸)، وقد أخرجہ: سنن الترمذی/الأیمان ۸ (۱۵۳۳)، مسند احمد (۲/۱۱،۳۴،۶۹،۸۷،۱۲۵،۱۴۲),2094,,The Chapters on Expiation
2095,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْأَعْلَى، ‏‏‏‏‏‏عَنْ هِشَامٍ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: صحیح مسلم/الایمان ۲ (۱۶۴۸)، سنن النسائی/الأیمان ۹ (۳۸۰۵)،(تحفة الأشراف:۹۶۹۷)، وقد أخرجہ: مسند احمد (۵/۶۲),2095,,The Chapters on Expiation
2096,حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ الدِّمَشْقِيُّ، ‏‏‏‏‏‏حَدَّثَنَا عُمَرُ بْنُ عَبْدِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: صحیح البخاری/تفسیر سورة النجم ۲ (۴۸۶۰)، الادب ۷۴ (۶۱۰۷)، الاستئذان ۵۲ (۶۳۰۱)، الأیمان ۵ (۶۶۵۰)، صحیح مسلم/الأیمان ۲ (۱۶۴۷)، سنن ابی داود/الایمان ۴ (۲۳۴۷)، سنن الترمذی/الأیمان ۱۷ (۱۵۴۵)، سنن النسائی/الأیمان ۱۰ (۳۸۰۶)،(تحفة الأشراف:۱۲۲۷۶)، وقد أخرجہ: مسند احمد (۲/۳۰۹),2096,,The Chapters on Expiation
2097,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏ وَالْحَسَنُ بْنُ عَلِيٍّ الْخَلَّالُ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Sahih,takhreej: سنن النسائی/الأیمان والنذور ۱۱ (۳۸۰۷)،(تحفة الأشراف:۳۹۳۸)، وقد أخرجہ: مسند احمد (۱/۱۸۳),2097,,The Chapters on Expiation
2098,حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، ‏‏‏‏‏‏حَدَّثَنَا ابْنُ أَبِي عَدِيٍّ، ‏‏‏‏‏‏عَنْ خَالِدٍ الْح,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: صحیح البخاری/الجنائز۸۳ (۱۳۶۳)، الأدب ۴۴ (۶۰۴۷)،۷۳ (۶۱۰۵)، الأیمان ۷ (۶۶۵۲)، صحیح مسلم/الإیمان ۴۷ (۱۱۰)، سنن ابی داود/الأیمان ۹ (۳۲۵۷)، سنن الترمذی/الأیمان ۱۵ (۱۵۴۳)، سنن النسائی/الأیمان ۶ (۳۸۰۱)،۳۱ (۳۸۲۲)،(تحفة الأشراف:۲۰۶۲)، وقد أخرجہ: مسند احمد (۴/۳۳،۳۴),2098,,The Chapters on Expiation
2099,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا بَقِيَّةُ، ‏‏‏‏‏‏عَنْ عَبْدِ اللَّهِ بْنِ مُحَرَّ,Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۳۱۰، ومصباح الزجاجة:۷۳۷),2099,,The Chapters on Expiation
2100,حَدَّثَنَا عَمْرُو بْنُ رَافِعٍ الْبَجَلِيُّ، ‏‏‏‏‏‏حَدَّثَنَا الْفَضْلُ بْنُ مُوسَى، ‏‏‏‏‏‏عَنْ الْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الأیمان ۹ (۳۲۵۸)، سنن النسائی/الأیمان ۷ (۳۸۰۳)،(تحفة الأشراف:۱۹۵۹)، وقد أخرجہ: مسند احمد (۵/۳۵۵،۳۵۶),2100,,The Chapters on Expiation
2101,حَدَّثَنَا مُحَمَّدُ بْنُ إِسْمَاعِيل بْنِ سَمُرَةَ، ‏‏‏‏‏‏حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ، ‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۴۳۹، ومصباح الزجاجة:۷۳۸),2101,,The Chapters on Expiation
2102,حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، ‏‏‏‏‏‏حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِيل، ‏‏‏‏‏‏عَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:(۱۴۸۱۶))، وقد آخرجہ: صحیح البخاری/الأنبیاء ۴۸ (۳۴۴۳ تعلیقاً)، صحیح مسلم/الفضائل ۴۰ (۲۳۶۸)، سنن النسائی/آداب القضاة ۳۶ (۵۴۲۹)، مسند احمد (۲/۳۱۴،۳۸۳),2102,,The Chapters on Expiation
2103,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو مُعَاوِيَةَ، ‏‏‏‏‏‏عَنْ بَشَّارِ بْنِ كِدَ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۴۳۴، ومصباح الزجاجة:۷۳۹),2103,,The Chapters on Expiation
2104,حَدَّثَنَا الْعَبَّاسُ بْنُ عَبْدِ الْعَظِيمِ الْعَنْبَرِيُّ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الرَّزَّاقِ، ‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن الترمذی/الأیمان والنذور ۷ (۱۵۳۲)، سنن النسائی/الإیمان والنذور ۴۲ (۳۸۸۶)،(تحفة الأشراف:۱۳۵۲۳)، وقد أخرجہ: مسند احمد (۲/۳۰۹),2104,,The Chapters on Expiation
2105,حَدَّثَنَا مُحَمَّدُ بْنُ زِيَادٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْوَارِثِ بْنُ سَعِيدٍ، ‏‏‏‏‏‏عَنْ أَيُّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن ابی داود/الأیمان والنذور ۱۱ (۳۲۶۱،۳۲۶۲)، سنن الترمذی/الأیمان والنذور ۷ (۱۵۳۱)، سنن النسائی/الأیمان ۱۸ (۳۸۲۴)،۳۹ (۳۸۵۹)،(تحفة الأشراف:۷۵۱۷)، موطا امام مالک/النذ ور ۶ (۱۰)، مسند احمد (۲/۶،۱۰،۴۸،۱۵۳)، سنن الدارمی/النذور ۷ (۲۳۸۸),2105,,The Chapters on Expiation
2106,حَدَّثَنَا عَبْدُ اللَّهِ بْنُ مُحَمَّدٍ الزُّهْرِيُّ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «أنظر ما قبلہ،(تحفة الأشراف:۷۵۱۷),2106,,The Chapters on Expiation
2107,حَدَّثَنَا أَحْمَدُ بْنُ عَبْدَةَ، ‏‏‏‏‏‏أَنْبَأَنَا حَمَّادُ بْنُ زَيْدٍ، ‏‏‏‏‏‏حَدَّثَنَا غَيْلَان,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: صحیح البخاری/الخمس ۱۵ (۳۱۳۳)، المغازي ۷۴ (۴۳۸۵)، الصید ۲۶ (۵۵۱۷،۵۵۱۸)، ا لأیمان ۱ (۶۶۲۳)،۴ (۶۶۴۹)،۱۸ (۶۶۸۰)، کفارات الأیمان ۹ (۶۷۱۸)،۱۰ (۶۷۱۹)، التوحید ۵۶ (۷۵۵۵)، صحیح مسلم/الأیمان ۳ (۱۶۴۹)، سنن ابی داود/الأیمان والنذور ۱۷ (۲۲۷۶)، سنن النسائی/الأیمان والنذور ۱۴ (۳۸۱۱)،(تحفة الأشراف:۹۱۲۲)، وقد أخرجہ: مسند احمد (۴/۳۹۸،۴۰۱،۴۰۴،۴۱۸),2107,,The Chapters on Expiation
2108,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏ وَعَبْدُ اللَّهِ بْنُ عَامِرِ بْنِ زُرَارَةَ، ‏‏‏‏‏‏قَالَا,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: صحیح مسلم/الأیمان ۳ (۱۶۵۱)، سنن النسائی/الأیمان ۱۵ (۳۸۱۷)،(تحفة الأشراف:۹۸۵۱)، وقد أخرجہ: مسند احمد (۴/۲۵۶،۲۵۷،۲۵۸،۲۵۹)، سنن الدارمی/النذور ۹ (۲۳۹۰),2108,,The Chapters on Expiation
2109,حَدَّثَنَا مُحَمَّدُ بْنُ أَبِي عُمَرَ الْعَدَنِيُّ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: سنن النسائی/الأیمان والنذور ۱۵ (۳۸۱۹)،(تحفة الأشراف:۱۱۲۰۴)، وقد أخرجہ: مسند احمد (۴/۱۳۶،۱۳۷),2109,,The Chapters on Expiation
2110,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، ‏‏‏‏‏‏عَنْ حَارِثَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۷۸۹، ومصباح الزجاجة:۷۴۰),2110,,The Chapters on Expiation
2111,حَدَّثَنَا عَبْدُ اللَّهِ بْنُ عَبْدِ الْمُؤْمِنِ الْوَاسِطِيُّ، ‏‏‏‏‏‏حَدَّثَنَا عَوْنُ بْنُ عُمَار,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Munkar; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Hasan,takhreej: تفردبہ ابن ماجہ،(تحفة الأشراف:۸۷۶۲، ومصباح الزجاجة:۷۴۱)، وقد أخرجہ: سنن ابی داود/الأیمان والنذور ۱۵ (۳۲۷۴)، سنن النسائی/الأیمان ۱۶ (۳۸۲۳)، مسند احمد (۲/۲۱۲),2111,,The Chapters on Expiation
2112,حَدَّثَنَا الْعَبَّاسُ بْنُ يَزِيدَ، ‏‏‏‏‏‏حَدَّثَنَا زِيَادُ بْنُ عَبْدِ اللَّهِ الْبَكَّائِيُّ، ‏‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۶۳۶، ومصباح الزجاجة:۷۴۲),2112,,The Chapters on Expiation
2113,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، ‏‏‏‏‏‏حَدَّثَ,Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۵۱۸، ومصباح الزجاجة:۷۴۳),2113,,The Chapters on Expiation
2114,حَدَّثَنَا سُفْيَانُ بْنُ وَكِيعٍ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ حُمَيْدٍ الْمَعْمَرِيُّ، ‏‏‏‏‏‏عَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۴۷۹۸)، وقد أخرجہ: صحیح البخاری/الأیمان ۱ (۶۶۲۵)، صحیح مسلم/الأیمان ۶ (۱۶۵۵)، مسند احمد (۲/۲۷۸،۳۱۷),2114,,The Chapters on Expiation
2115,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏عَنْ عَلِيِّ بْنِ صَالِحٍ، ‏‏‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: صحیح البخاری/الجنائز ۲ (۱۲۳۹)، المظالم ۵ (۲۴۴۵)، النکاح ۷۱ (۵۱۷۵)، الأشربة ۳۸ (۵۶۳۵)، المرضی ۴ (۵۶۵۰)، اللباس ۳۶ (۵۸۴۹)،۴۵ (۵۸۶۳)، الأدب ۱۲۴ (۵۸۴۹)، الاستئذان ۸ (۶۲۳۵)، صحیح مسلم/اللباس ۲ (۲۰۶۶)، سنن الترمذی/الأدب ۴۵ (۲۸۰۹)، سنن النسائی/الجنائز ۵۳ (۱۹۴۱)، الأیمان ۱۲ (۳۸۰۹)،(تحفة الأشراف:۱۹۱۶)، وقد أخرجہ: مسند احمد (۴/۲۸۴،۲۸۷،۲۹۹),2115,,The Chapters on Expiation
2116,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ فُضَيْلٍ، ‏‏‏‏‏‏عَنْ يَ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۷۰۴، ومصباح الزجاجة:۷۴۴)، وقد أخرجہ: مسند احمد (۳/۴۳۰),2116,,The Chapters on Expiation
2117,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا عِيسَى بْنُ يُونُسَ، ‏‏‏‏‏‏حَدَّثَنَا الْأَجْلَحُ,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۵۵۲، ومصباح الزجاجة:۷۴۶)، وقد أخرجہ: مسند احمد (۱/۲۱۴،۲۲۴،۲۸۳،۳۴۷),2117,,The Chapters on Expiation
2118,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏عَنْ عَبْدِ الْم,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تجفة الأشراف:۳۳۱۸، ومصباح الزجاجة:۷۴۷)، وقد أخرجہ: مسند احمد (۳۹۳۵),2118,,The Chapters on Expiation
2119,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ مُوسَى، ‏‏‏‏‏‏عَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Lighairihi; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الأیمان ۸ (۳۲۵۶)،(تحفة الأشراف:۴۸۰۹)، وقد أخرجہ: مسند احمد (۴/۷۹),2119,,The Chapters on Expiation
2120,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، ‏‏‏‏‏‏أَنْبَأَن,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: صحیح مسلم/الأیمان ۴ (۱۶۵۳)، سنن ابی داود/الأیمان ۷ (۳۲۵۵)، سنن الترمذی/الأحکام ۱ (۱۳۵۴)،(تحفة الأشراف:۱۲۸۲۶)، وقد أخرجہ: سنن الدارمی/النذور ۱۱ (۲۳۹۴),2120,,The Chapters on Expiation
2121,حَدَّثَنَا عَمْرُو بْنُ رَافِعٍ، ‏‏‏‏‏‏حَدَّثَنَا هُشَيْمٌ، ‏‏‏‏‏‏أَنْبَأَنَا عَبْدُ اللَّهِ بْنُ أَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: أنظر ما قبلہ,2121,,The Chapters on Expiation
2122,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏عَنْ سُفْيَانَ، ‏‏‏‏‏‏عَنْ مَنْصُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: صحیح البخاری/القدر ۶ (۶۶۰۸)، الأیمان ۲۶ (۶۶۹۳)، صحیح مسلم/النذور ۲ (۱۶۳۹)، سنن ابی داود/الایمان ۲۱ (۳۲۸۷)، سنن النسائی/الایمان ۲۴ (۳۸۳۲،۳۸۳۳)،(تحفة الأشراف:۷۲۸۷)، وقد أخرجہ: مسند احمد (۲/۶۱،۸۶،۱۸)، سنن الدارمی/النذور ۵ (۲۳۸۵),2122,,The Chapters on Expiation
2123,حَدَّثَنَا أَحْمَدُ بْنُ يُوسُفَ، ‏‏‏‏‏‏حَدَّثَنَا عُبَيْدُ اللَّهِ، ‏‏‏‏‏‏عَنْ سُفْيَانَ، ‏‏‏‏‏‏عَن,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۳۶۷۰)، وقد أخرجہ: صحیح البخاری/الأیمان ۲۶ (۶۶۹۲)، صحیح مسلم/النذر ۲ (۱۶۴۰)، سنن ابی داود/الأیمان ۲۱ (۳۲۸۸)، سنن الترمذی/الأیمان ۱۰ (۱۵۳۸)، سنن النسائی/الأیمان ۲۵ (۳۸۳۶)، مسند احمد (۲/۲۳۵،۲۴۲،۳۰۱،۳۱۴،۴۱۲،۴۶۳),2123,,The Chapters on Expiation
2124,حَدَّثَنَا أَبُو سَهْلُ بْنُ أَبِي سَهْلٍ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏حَدَّثَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: صحیح مسلم/النذر ۳ (۱۶۴۱)، سنن ابی داود/الأیمان ۲۸ (۳۳۱۶)، سنن النسائی/الأیمان ۳۰ (۳۸۴۳)،۴۱ (۳۸۸۰)،(تحفة الأشرف:۱۰۸۸۴،۱۰۸۸۸)، وقد أخرجہ: مسند احمد (۴/۴۲۹،۴۳۴),2124,,The Chapters on Expiation
2125,حَدَّثَنَا أَحْمَدُ بْنُ عَمْرِو بْنِ السَّرْحِ الْمِصْرِيُّ أَبُو طَاهِرٍ، ‏‏‏‏‏‏حَدَّثَنَا ابْنُ و,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: سنن ابی داود/الأیمان ۲۲ (۳۲۹۰،۳۲۹۱)، سنن الترمذی/الایمان ۲ (۱۵۲۴)، سنن النسائی/الأیمان ۴۰ (۳۸۶۵)،(تحفة الأشراف:۱۷۷۷۰)، وقد أخرجہ: صحیح البخاری/الأیمان ۲۸ (۶۶۹۶)،۳۱ (۶۷۰۰)، موطا امام مالک/النذور۴ (۸)، مسند احمد (۶/۳۶،۴۱،۲۲۴)، سنن الدارمی/النذور ۳ (۲۳۸۳),2125,,The Chapters on Expiation
2126,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو أُسَامَةَ، ‏‏‏‏‏‏عَنْ عُبَيْدِ ا,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: صحیح البخاری/الإیمان والنذور ۲۸ (۶۶۹۶)،۳۱ (۶۷۰۰)، سنن ابی داود/الإیمان والنذور ۲۲ (۳۲۸۹)، سنن الترمذی/النذور الإیمان ۲ (۱۵۲۶)، سنن النسائی/الإیمان والنذور ۲۶ (۳۸۳۷)،۲۷ (۳۸۳۸،۳۸۳۹)،(تحفة الأشراف:۱۷۴۵۸)، وقد أخرجہ: موطا امام مالک/النذور (۸)، مسند احمد (۶/۳۶،۴۱،۲۲۴، سنن الدارمی/النذور ۳ (۲۳۸۳),2126,,The Chapters on Expiation
2127,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏حَدَّثَنَا إِسْمَاعِيل بْنُ رَافِ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۹۲۳)، وقد أخرجہ: صحیح مسلم/النذر ۵ (۱۶۴۵)، سنن ابی داود/الأیمان ۳۱ (۳۳۲۳)، سنن الترمذی/الأیمان ۴ (۱۵۲۸)، سنن النسائی/الأیمان ۴۰ (۳۸۶۳)، مسند احمد (۴/۱۴۴،۱۴۶،۱۴۷),2127,,The Chapters on Expiation
2128,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْمَلِكِ بْنُ مُحَمَّدٍ الصَّنْعَانِيُّ،,Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Hasan,takhreej: سنن ابی داود/الأیمان والنذور ۳۰ (۳۳۲۲)،(تحفة الأشراف:۶۳۴۱),2128,,The Chapters on Expiation
2129,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا حَفْصُ بْنُ غِيَاثٍ، ‏‏‏‏‏‏عَنْ عُبَيْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: صحیح البخاری/الاعتکاف ۵ (۲۰۳۲)،۱۵ (۲۰۴۲)،۱۶ (۲۰۴۳)، صحیح مسلم/الأیمان ۶ (۱۶۵۶)، سنن ابی داود/الصوم۸۰ (۲۴۷۴)، الأیمان ۳۲ (۳۳۲۵)، سنن الترمذی/الأیمان ۱۱ (۱۵۳۹)، سنن النسائی/الأیمان ۳۵ (۳۸۵۱)،(تحفة الأشراف:۱۰۵۵۰)، وقد أخرجہ: مسند احمد (۱/۳۷،۲/۲۰،۸۲،۱۵۳)، سنن الدارمی/النذور ۱ (۲۳۷۸),2129,,The Chapters on Expiation
2130,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏ وَعَبْدُ اللَّهِ بْنُ إِسْحَاق الْجَوْهَرِيُّ، ‏‏‏‏‏‏قَالَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۴۸۶، ومصباح الزجاجة:۷۵۰),2130,,The Chapters on Expiation
2131,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِيَةَ، ‏‏‏‏‏‏عَنْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۸۰۹۲، ومصباح الزجاجة:۷۵۱)، وقد أخرجہ: سنن ابی داود/الأیمان ۲۷ (۳۳۱۴)، مسند احمد (۶/۳۶۶),2131,,The Chapters on Expiation
2132,حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، ‏‏‏‏‏‏أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، ‏‏‏‏‏‏عَنْ ابْنِ شِهَابٍ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: صحیح البخاری/الوصایا ۱۹ (۲۷۶۱)، الأیمان والنذور۳۰ (۶۶۹۸)، الحیل ۳ (۶۹۵۹)، صحیح مسلم/النذور۱ (۱۶۳۸)، سنن ابی داود/الأیمان ۲۵ (۳۳۰۷)، سنن الترمذی/الأیمان ۱۹ (۱۵۴۶)، سنن النسائی/الوصایا ۸ (۳۶۸۶)، الأیمان ۳۴ (۳۸۴۸،۳۸۴۹،۳۸۵۰)،(تحفة الأشراف:۵۸۳۵)، وقد أخرجہ: موطا امام مالک/النذور۱ (۱)، مسند احمد (۱/۲۱۹،۳۲۹),2132,,The Chapters on Expiation
2133,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا يَحْيَى بْنُ بُكَيْرٍ، ‏‏‏‏‏‏حَدَّثَنَا ابْنُ لَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۵۵۴),2133,,The Chapters on Expiation
2134,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، ‏‏‏‏‏‏عَنْ يَحْيَى,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الأیمان ۲۳ (۳۲۹۳،۳۲۹۴)، سنن الترمذی/الأیمان ۱۶ (۱۵۴۴)، سنن النسائی/الأیمان ۳۲ (۳۸۴۶)،(تحفة الأشراف:۹۹۳۰)، وقد أخرجہ: مسند احمد (۳/۱۴۳،۴/ ۱۴۵،۱۴۹،۱۵۱)، سنن الدارمی/النذور ۲ (۲۳۷۹),2134,,The Chapters on Expiation
2135,حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/النذ ر ۴ (۱۶۴۳)،(تحفة الأشراف:۱۳۹۴۸)، وقد أخرجہ: مسند احمد (۲/۳۷۳)، سنن الدارمی/النذور ۲ (۲۳۸۱),2135,,The Chapters on Expiation
2136,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا إِسْحَاق بْنُ مُحَمَّدٍ الْفَرْوِيُّ، ‏‏‏‏‏‏حَدّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۹۳۴),2136,,The Chapters on Expiation
