{"metadata":{"name":"Sunan Abu Dawud","section":{"15":"Jihad (Kitab Al-Jihad)"},"section_detail":{"15":{"hadithnumber_first":2477,"hadithnumber_last":2787,"arabicnumber_first":2477,"arabicnumber_last":2787}}},"hadiths":[{"hadithnumber":2774,"arabicnumber":2774,"text":"Rapporté par Abu Bakrah رضي الله عنه : Quand quelque chose arrivait au Prophète ﷺ qui lui procurait de la joie (ou qui le rendait heureux), il se prosternait en reconnaissance envers Allah","grades":[{"name":"Al-Albani","grade":"Sahih"},{"name":"Muhammad Muhyi Al-Din Abdul Hamid","grade":"Sahih"},{"name":"Shuaib Al Arnaut","grade":"Sahih Lighairihi"},{"name":"Zubair Ali Zai","grade":"Isnaad Hasan"}],"reference":{"book":15,"hadith":298}}]}