metadata:
  section_id: 21
  section_name: رسول اللہ صلی اللہ علیہ وسلم کے سر مبارک کے کپڑے کا بیان
  hadith_first: 122
  hadith_last: 122

hadiths[1]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
122,’’سیدنا انس بن مالک رضی اللہ عنہ سے مروی ہے وہ فرماتے ہیں کہ رسول اللہ کثرت سے (تیل لگاکر) سر مبارک پر کپڑا رکھتے تھے گویا کہ آپ صلی اللہ علیہ وسلم کا کپڑا کسی تیلی (تیل نکالنے والے) کا کپڑا ہے۔ ‘‘,,,122,,رسول اللہ صلی اللہ علیہ وسلم کے سر مبارک کے کپڑے کا بیان
