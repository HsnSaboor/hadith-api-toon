hadiths[count]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}:
1720,حَدَّثَنَا إِسْحَاق بْنُ مَنْصُورٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، حَدَّثَنَا عُبَيْدُ الل,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: سنن النسائی/الزینة ۴۰ (۵۱۵۱)، و۷۴ (۵۲۶۷)، (تحفة الأشراف : ۸۹۹۸)، و مسند احمد (۴/۳۹۲، ۳۹۳، ۴۰۷),1720,,The Book on Clothing
1721,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُعَاذُ بْنُ هِشَامٍ، حَدَّثَنَا أَبِي، عَنْ قَتَادَة,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/اللباس ۲ (۲۰۶۹/۱۵)، (تحفة الأشراف : ۱۰۴۵۹),1721,,The Book on Clothing
1722,حَدَّثَنَا مَحْمُودُ بْنُ غَيْلَانَ، حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ، حَدَّثَنَا,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الجہاد ۹۰ (۲۹۱۹- ۲۹۲۲)، واللباس ۲۹ (۵۸۳۹)، صحیح مسلم/اللباس ۳ (۲۰۷۶)، سنن ابی داود/ اللباس ۱۳ (۴۰۵۶)، سنن النسائی/الزینة ۹۲ (۵۳۱۲)، سنن ابن ماجہ/اللباس ۱۷ (۳۵۹۲)، (تحفة الأشراف : ۱۳۹۴)، و مسند احمد (۳/۱۲۷، ۱۸۰، ۲۱، ۲۵۵، ۲۷۳),1722,,The Book on Clothing
1723,حَدَّثَنَا أَبُو عَمَّارٍ، حَدَّثَنَا الْفَضْلُ بْنُ مُوسَى، عَنْ مُحَمَّدِ بْنِ عَمْرٍو، حَدَّثَنَا,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: تخریج دارالدعوہ: صحیح البخاری/الہبة ۲۸ (۲۶۱۵)، وبدء الخلق ۸ (۳۲۴۸)، صحیح مسلم/فضائل الصحابة ۲۴ (۲۴۶۹)، سنن النسائی/الزینة ۸۸ (۵۳۰۴)، (تحفة الأشراف : ۱۶۴۸)، و مسند احمد (۳/۱۱۱، ۱۲۱-۱۲۲، ۲۰۷، ۲۰۹، ۲۲۹، ۲۳۸، ۲۵۱، ۲۷۷),1723,,The Book on Clothing
1724,حَدَّثَنَا مَحْمُودُ بْنُ غَيْلَانَ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا سُفْيَانُ، عَنْ أَبِي إِسْحَاق،,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/المناقب ۳۳ (۳۵۵۱)، واللباس ۳۵ (۵۸۴۸)، و۶۸ (۵۹۰۳)، صحیح مسلم/الفضائل ۲۵ (۲۳۳۷)، سنن ابی داود/ الترجل ۹ (۴۱۸۳)، سنن النسائی/الزینة ۹ (۵۰۶۳)، و ۵۹ (۵۲۳۴)، و ۹۳ (۵۲۴۸)، سنن ابن ماجہ/اللباس ۲۰ (۳۵۹۹)، (تحفة الأشراف : ۱۸۴۷)، و مسند احمد (۴/۲۸۱، ۲۹۵) و یأتي برقم ۳۶۳۵,1724,,The Book on Clothing
1725,حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، عَنْ نَافِعٍ، عَنْ إِبْرَاهِيمَ بْنِ عَبْدِ ا,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: انظر حدیث رقم ۲۶۴,1725,,The Book on Clothing
1726,حَدَّثَنَا إِسْمَاعِيل بْنُ مُوسَى الْفَزَارِيُّ، حَدَّثَنَا سَيْفُ بْنُ هَارُونَ الْبُرْجُمِيُّ، عَ,Ahmad Muhammad Shakir: Hasan; Al-Albani: Hasan; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: سنن ابن ماجہ/الأطعمة ۶۰ (۳۳۶۷)، (تحفة الأشراف : ۴۴۹۶),1726,,The Book on Clothing
1727,حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا اللَّيْثُ، عَنْ يَزِيدَ بْنِ أَبِي حَبِيبٍ، عَنْ عَطَاءِ بْنِ أَبِ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۵۹۶۹)، وانظر: صحیح البخاری/الزکاة ۶۱ (۱۴۹۲)، والبیوع ۱۰۱ (۲۲۲۱)، والذبائح ۳۰ (۵۵۳۱، ۵۵۳۲)، صحیح مسلم/الحیض ۲۷ (۳۶۳-۳۶۵)، سنن ابی داود/ اللبا۴۱ (۴۱۲۱)، سنن النسائی/الفرع ۴ (۴۲۴۰-۴۲۴۴)، سنن ابن ماجہ/اللباس ۲۵ (۳۶۱۰)، وط/الصید ۶ (۱۶)، مسند احمد (۱/۲۳۷)، ۳۲۷، ۳۳۰، ۳۶۵، ۳۶۶، ۳۷۲)، سنن الدارمی/الأضاحي ۲۰ (۲۰۲۸),1727,,The Book on Clothing
1728,حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، وَعَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ، عَن,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/الحیض ۲۷ (۳۶۶)، سنن ابی داود/ اللباس ۴۱ (۴۱۲۳)، سنن النسائی/الفرع ۴ (۴۲۴۶)، سنن ابن ماجہ/اللباس ۲۵ (۳۶۰۹)، (تحفة الأشراف : ۵۸۲۲)، وط/الصید ۶ (۱۷)، و مسند احمد (۱/۲۱۹، ۲۷۰، ۲۷۹، ۲۸۰، ۳۴۳),1728,,The Book on Clothing
1729,حَدَّثَنَا مُحَمَّدُ بْنُ طَرِيفٍ الْكُوفِيُّ، حَدَّثَنَا مُحَمَّدُ بْنُ فُضَيْلٍ، عَنْ الْأَعْمَشِ،,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan; Zubair Ali Zai: Hasan,takhreej: تخریج دارالدعوہ: سنن ابی داود/ اللباس ۴۲ (۴۱۲۷)، سنن النسائی/الفرع ۵۴ (۲۴۵۵، ۲۴۵۶)، سنن ابن ماجہ/اللباس ۲۶ (۳۶۱۳)، (تحفة الأشراف : ۶۶۴۲)، و مسند احمد (۴/۲۱۰، ۳۱۱),1729,,The Book on Clothing
1730,حَدَّثَنَا الْأَنْصَارِيُّ، حَدَّثَنَا مَعْنٌ، حَدَّثَنَا مَالِكٌ، ح وحَدَّثَنَا قُتَيْبَةُ، عَنْ مَ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/فضائل الصحابة ۵ (۳۶۶۵)، واللباس ۱ (۵۷۸۳)، و ۲ (۵۷۸۴)، و ۵ (۵۷۹۱)، صحیح مسلم/اللباس ۹ (۲۰۸۵)، سنن ابی داود/ اللباس ۲۸ (۴۰۸۵)، سنن النسائی/الزینة ۶۶ (۵۳۷۷)، سنن ابن ماجہ/اللباس ۶ (۳۵۶۹)، و ۹ (۳۵۷۶)، (تحفة الأشراف : ۶۷۲۶ و ۷۲۲۷ و ۸۳۵۸)، وط/اللباس ۵ (۹) و مسند احمد (۲/۵، ۱۰، ۳۲، ۴۲، ۴۴، ۴۶، ۵۵، ۵۶، ۶۰، ۶۵، ۶۷، ۶۹، ۷۴، ۷۶، ۸۱),1730,,The Book on Clothing
1731,حَدَّثَنَا الْحَسَنُ بْنُ عَلِيٍّ الْخَلَّالُ، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَخْبَرَنَا مَعْمَرٌ،,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف وانظر ما قبلہ (تحفة الأشراف : ۷۵۲۶),1731,,The Book on Clothing
1732,حَدَّثَنَا إِسْحَاق بْنُ مَنْصُورٍ، أَخْبَرَنَا عَفَّانُ، حَدَّثَنَا حَمَّادُ بْنُ سَلَمَةَ، عَنْ عَ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan; Zubair Ali Zai: Hasan,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف، وانظر سنن ابی داود/ اللباس ۴۰ (۴۱۱۷-۴۱۱۸)، و ق /اللباس ۱۳ (۳۵۰۸)، (تحفة الأشراف : ۸۲۵۷),1732,,The Book on Clothing
1733,حَدَّثَنَا حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا إِسْمَاعِيل بْنُ إِبْرَاهِيمَ، حَدَّثَنَا أَ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الخمس ۵ (۳۱۰۸)، واللباس ۱۹ (۵۸۱۸)، صحیح مسلم/اللباس ۶ (۲۰۸۰)، سنن ابی داود/ اللباس ۸ (۴۰۳۶)، سنن ابن ماجہ/اللباس ۱ (۳۵۵۱)، (تحفة الأشراف : ۱۷۶۹۳)، و مسند احمد (۶/۳۲، ۱۳۱),1733,,The Book on Clothing
1734,حَدَّثَنَا عَلِيُّ بْنُ حُجْرٍ، حَدَّثَنَا خَلَفُ بْنُ خَلِيفَةَ، عَنْ حُمَيْدٍ الْأَعْرَجِ، عَنْ عَ,Ahmad Muhammad Shakir: Very Daif; Al-Albani: Very Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۹۳۲۸),1734,,The Book on Clothing
1735,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، عَنْ حَمَّادِ بْنِ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: صحیح مسلم/الحج ۸۴ (۱۳۵۸)، سنن ابی داود/ اللباس ۲۴ (۴۰۷۶)، سنن النسائی/الحج ۱۰۷ (۲۸۷۲)، والزینة ۱۰۹ (۵۳۴۶)، سنن ابن ماجہ/الجہاد۲۲ (۲۸۲۲)، واللباس ۱۴ (۲۵۸۵)، (تحفة الأشراف : ۲۶۸۹)، و مسند احمد (۳/۳۶۳، ۳۸۷),1735,,The Book on Clothing
1736,حَدَّثَنَا هَارُونُ بْنُ إِسْحَاق الْهَمْدَانِيُّ، حَدَّثَنَا يَحْيَى بْنُ مُحَمَّدٍ الْمَدَنِيُّ، ع,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan; Zubair Ali Zai: Hasan,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۸۰۳۱),1736,,The Book on Clothing
1737,حَدَّثَنَا سَلَمَةُ بْنُ شَبِيبٍ، وَالْحَسَنُ بْنُ عَلِيٍّ الْخَلَّالُ، وغير واحد، ‏‏‏‏‏‏قَالُوا:‏‏‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: انظر حدیث رقم ۲۶۴ و ۱۷۲۵,1737,,The Book on Clothing
1738,حَدَّثَنَا يُوسُفُ بْنُ حَمَّادٍ الْمَعْنِيُّ الْبَصْرِيُّ، حَدَّثَنَا عَبْدُ الْوَارِثِ بْنُ سَعِيد,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: تخریج دارالدعوہ: سنن النسائی/الزینة ۴۴ (۵۱۹۰)، (تحفة الأشراف : ۱۰۸۱۸)، و مسند احمد (۴/۴۲۸، ۴۴۳),1738,,The Book on Clothing
1739,حَدَّثَنَا قُتَيْبَةُ، وَغَيْرُ وَاحِدٍ، ‏‏‏‏‏‏عَنْ عَبْدِ اللَّهِ بْنِ وَهْبٍ، عَنْ يُونُسَ، عَنْ ا,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/اللباس ۴۸ (۵۸۷۰)، صحیح مسلم/اللباس ۱۵ (۲۰۹۴)، سنن ابی داود/ الخاتم ۱ (۴۲۱۶)، سنن النسائی/الزینة ۴۷ (۵۱۹۹)، و ۷ (۵۲۷۹-۵۲۸۲) سنن ابن ماجہ/اللباس ۳۹ (۳۶۴۱)، (تحفة الأشراف : ۱۵۵۴)، و مسند احمد (۳/۲۰۹)، وانظر الحدیث التالي,1739,,The Book on Clothing
1740,حَدَّثَنَا مَحْمُودُ بْنُ غَيْلَانَ، حَدَّثَنَا حَفْصُ بْنُ عُمَرَ بْنِ عُبَيْدِ اللَّهِ الطَّنَافِس,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: صحیح البخاری/اللباس ۴۸ (۵۸۷۰)، سنن ابی داود/ الخاتم ۱ (۴۲۱۷)، سنن النسائی/الزینة ۴۷ (۵۲۰۱)، سنن ابن ماجہ/اللباس ۳۹ (۳۶۴۱),1740,,The Book on Clothing
1741,حَدَّثَنَا مُحَمَّدُ بْنُ عُبَيْدٍ الْمُحَارِبِيُّ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ أَبِي حَازِمٍ،,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح البخاری/اللباس ۴۵ (۵۸۶۵)، و ۴۶ (۵۸۶۶)، و ۴۷ (۵۸۶۷)، و ۵۰ (۵۸۷۳)، و ۵۳ (۵۸۷۶)، والأیمان والنذور ۶ (۶۶۵۱)، والاعتصام ۴ (۷۲۹۸)، صحیح مسلم/اللباس ۱۱ (۲۰۹۱)، سنن ابی داود/ الخاتم ۱ (۴۲۱۸)، سنن النسائی/الزینة ۴۳ (۵۱۶۷)، و ۵۳ (۵۲۱۷-۵۲۲۱)، سنن ابن ماجہ/اللباس ۳۹ (۳۶۳۹)، (تحفة الأشراف : ۸۴۷۱)، و مسند احمد (۲/۱۸، ۶۸، ۹۶، ۱۲۷),1741,,The Book on Clothing
1742,حَدَّثَنَا مُحَمَّدُ بْنُ حُمَيْدٍ الرَّازِيُّ، حَدَّثَنَا جَرِيرٌ، عَنْ مُحَمَّدِ بْنِ إِسْحَاق، عَ,Ahmad Muhammad Shakir: Hasan Sahih; Al-Albani: Hasan Sahih; Bashar Awad Maarouf: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الخاتم ۵ (۴۲۲۹)، (تحفة الأشراف : ۵۶۸۶),1742,,The Book on Clothing
1743,حَدَّثَنَا حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِيل، عَنْ جَعْفَرِ بْنِ مُحَمَّدٍ،,Ahmad Muhammad Shakir: Sahih Muquf; Al-Albani: Sahih Muquf; Bashar Awad Maarouf: Hasan; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف، (تحفة الأشراف : ۳۴۰۸ و ۳۴۱۱),1743,,The Book on Clothing
1744,حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، عَنْ حَمَّادِ بْنِ سَلَمَةَ، قَا,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: سنن النسائی/الزینة ۴۸ (۵۲۰۷)، سنن ابن ماجہ/اللباس ۴۲ (۳۶۴۷)، (تحفة الأشراف : ۵۲۲۲)، و مسند احمد (۱/۲۰۴)، والمؤلف في الشمائل۱۳,1744,,The Book on Clothing
1745,حَدَّثَنَا الْحَسَنُ بْنُ عَلِيٍّ الْخَلَّالُ، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَخْبَرَنَا مَعْمَرٌ،,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: صحیح البخاری/اللباس ۵۰ (۵۸۷۲)، و ۵۱ (۵۸۷۴)، و ۵۴ (۵۸۷۷)، سنن النسائی/الزینة ۵۰ (۵۲۱۱)، و ۷۸ (۵۲۸۳)، و ۷۹ (۵۲۸۴)، سنن ابن ماجہ/اللباس ۳۹ (۳۶۴۰)، (تحفة الأشراف : ۴۸۰)، و مسند احمد (۳/۱۰۱، ۱۶۱),1745,,The Book on Clothing
1746,حَدَّثَنَا إِسْحَاق بْنُ مَنْصُورٍ، أَخْبَرَنَا سَعِيدُ بْنُ عَامِرٍ، وَالْحَجَّاجُ بْنُ مِنْهَالٍ،,Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الطہارة ۱۰ (۱۹)، سنن النسائی/الزینة ۵۱ (۵۲۱۶)، سنن ابن ماجہ/الطہارة ۱۱ (۳۰۳)، (تحفة الأشراف : ۱۵۱۲)، و مسند احمد (۳/۹۹، ۱۰۱، ۲۸۲)، والمؤلف الشمائل ۱۱ (۸۸),1746,,The Book on Clothing
1747,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ الْأَنْصَارِيُّ، حَدَّثَ,Zubair Ali Zai: Sahih Bukhari,takhreej: تخریج دارالدعوہ: صحیح البخاری/الخمس ۵ (۳۱۰۶)، واللباس ۵۵ (۵۸۸۸، ۸۵۷۹) والمؤلف في الشمائل ۱۲ (تحفة الأشراف : ۵۰۲),1747,,The Book on Clothing
1748,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، وَمُحَمَّدُ بْنُ يَحْيَى،‏‏‏‏ وَغَيْرُ وَاحِدٍ، ‏‏‏‏‏‏قَالُوا:‏‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: انظر ما قبلہ,1748,,The Book on Clothing
1749,حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا رَوْحُ بْنُ عُبَادَةَ، حَدَّثَنَا ابْنُ جُرَيْجٍ، أَخْب,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۲۸۷۰),1749,,The Book on Clothing
1750,حَدَّثَنَا إِسْحَاق بْنُ مُوسَى الْأَنْصَارِيُّ، حَدَّثَنَا مَعْنٌ، حَدَّثَنَا مَالِكٌ، عَنْ أَبِي ا,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: سنن النسائی/الزینة ۱۱۱ (۵۳۵۱)، وانظر أیضا: صحیح البخاری/بدء الخلق ۷ (۳۲۲۶)، واللباس ۹۲ (۵۹۵۸)، صحیح مسلم/اللباس ۲۶ (۲۱۰۶/۸۵)، سنن ابی داود/ اللباس ۴۸ (۴۱۵۵)، سنن النسائی/الزینة ۱۱۱ (۵۲۵۲)، (تحفة الأشراف : ۳۷۸۲ و ۴۶۶۳)، و مسند احمد (۴/۲۸),1750,,The Book on Clothing
1751,حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ، عَنْ أَيُّوبَ، عَنْ عِكْرِمَةَ، عَنْ ابْنِ ع,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: تخریج دارالدعوہ: صحیح البخاری/التعبیر ۴۵ (۷۰۴۲)، والأدب ۹۶ (۵۰۲۴)، سنن النسائی/الزینة ۱۱۳ (۵۳۶۱)، (تحفة الأشراف : ۵۹۸۶)، و مسند احمد (۱/۲۴۶)، سنن الدارمی/الرقاق ۳ (),1751,,The Book on Clothing
1752,حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا أَبُو عَوَانَةَ، عَنْ عُمَرَ بْنِ أَبِي سَلَمَةَ، عَنْ أَبِيهِ، عَ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف، وانظر: صحیح البخاری/الأنبیاء ۵۰ (۳۴۶۲)، واللباس ۶۷ (۵۸۹۹)، صحیح مسلم/اللباس ۲۵ (۲۱۰۳)، سنن ابی داود/ الترجل۱۸ (۴۲۰۳)، سنن النسائی/الزینة ۱۴ (۵۰۷۲)، و ۶۴ (۵۲۴۳)، سنن ابن ماجہ/اللباس ۳۳ (۳۶۲۱)، (تحفة الأشراف : ۱۴۹۸۵۱),1752,,The Book on Clothing
1753,حَدَّثَنَا سُوَيْدُ بْنُ نَصْرٍ، أَخْبَرَنَا ابْنُ الْمُبَارَكِ، عَنْ الْأَجْلَحِ، عَنْ عَبْدِ اللَّ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الترجل ۱۸ (۴۲۰۵)، سنن النسائی/الزینة ۱۶ (۵۰۸۰)، سنن ابن ماجہ/اللباس ۳۲ (۳۶۲۲)، (تحفة الأشراف : ۱۱۹۲۷)، و مسند احمد (۵/۱۴۷، ۱۵۰، ۱۵۴، ۱۵۶، ۱۶۹),1753,,The Book on Clothing
1754,حَدَّثَنَا حُمَيْدُ بْنُ مَسْعَدَةَ، حَدَّثَنَا عَبْدُ الْوَهَّابِ الثَّقَفِيُّ، عَنْ حُمَيْدٍ، عَنْ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف، وانظر: صحیح البخاری/المناقب ۲۳ (۳۵۴۷)، (تحفة الأشراف : ۷۲۰),1754,,The Book on Clothing
1755,حَدَّثَنَا هَنَّادٌ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ أَبِي الزِّنَادِ، عَنْ هِشَامِ بْنِ عُرْوَةَ,Ahmad Muhammad Shakir: Hasan Sahih; Al-Albani: Hasan Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الترجل ۹ (۴۱۸۷)، سنن ابن ماجہ/اللباس ۳۶ (۳۶۳۵)، (تحفة الأشراف : ۱۷۰۱۹),1755,,The Book on Clothing
1756,حَدَّثَنَا عَلِيُّ بْنُ خَشْرَمٍ، أَخْبَرَنَا عِيسَى بْنُ يُونُسَ، عَنْ هِشَامٍ، عَنْ الْحَسَنِ، عَن,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الترجل ۱ (۴۱۵۹)، سنن النسائی/الزینة ۷ (۵۰۵۸)، (تحفة الأشراف : ۹۶۵۰)، و مسند احمد (۴/۸۶),1756,,The Book on Clothing
1757,حَدَّثَنَا مُحَمَّدُ بْنُ حُمَيْدٍ، حَدَّثَنَا أَبُو دَاوُدَ هُوَ الطَّيَالِسِيُّ، عَنْ عَبَّادِ بْن,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih,takhreej: تخریج دارالدعوہ: سنن ابن ماجہ/الطب ۲۵ (۳۴۹۷)، وانظر أیضا: سنن ابی داود/ الطب ۱۴ (۳۸۷۸)، سنن النسائی/الزینة ۲۸ (۵۱۱۶)، (تحفة الأشراف : ۶۱۳۷)، و مسند احمد (۱/۳۵۴)، ویأتي عند المؤلف برقم ۲۰۴۸),1757,,The Book on Clothing
1758,حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا يَعْقُوبُ بْنُ عَبْدِ الرَّحْمَنِ الْإِسْكَنْدَرَانِيُّ، عَنْ سُهَ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۱۲۷۸۸)، وانظر: مسند احمد (۲/۳۱۹، ۵۲۹),1758,,The Book on Clothing
1759,حَدَّثَنَا سُوَيْدُ بْنُ نَصْرٍ، أَخْبَرَنَا عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ، عَنْ عُبَيْدِ اللَّهِ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/اللباس ۸۳ (۵۹۳۷)، و ۸۵ (۵۹۴۰، ۵۹۴۲)، و ۸۷ (۵۹۴۷)، صحیح مسلم/اللباس ۳۳ (۲۱۲۴)، سنن ابی داود/ الترجل ۵ (۴۱۶۸)، (۲۷۸۴)، سنن النسائی/الزینة ۲۳ (۵۰۹۸)، ۷۲ (۵۲۵۳)، سنن ابن ماجہ/النکاح ۵۲ (۱۹۸۷) (تحفة الأشراف : ۷۹۳۰)، و مسند احمد (۲/۲۱) ویأتي في الأدب ۳۳ (برقم ۲۷۸۳),1759,,The Book on Clothing
1760,حَدَّثَنَا عَلِيُّ بْنُ حُجْرٍ، أَخْبَرَنَا عَلِيُّ بْنُ مُسْهِرٍ، حَدَّثَنَا أَبُو إِسْحَاق الشَّيْ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/النکاح ۷۱ (۵۱۷۵)، والأشربة ۲۸ (۵۶۳۵)، والمرضی ۴ (۵۶۵۰)، واللباس ۲۸ (۵۸۳۸)، و ۳۶ (۵۸۴۹)، و ۴۵ (۵۸۶۳)، والأدب ۱۲۴ (۶۲۲۲)، صحیح مسلم/اللباس ۲ (۲۰۶۶)، (تحفة الأشراف : ۱۹۱۶)، و مسند احمد (۴/۲۸۴، ۲۹۹) وکلہم في سیاق طویل منہ ہذا الشق,1760,,The Book on Clothing
1761,حَدَّثَنَا عَلِيُّ بْنُ حُجْرٍ، أَخْبَرَنَا عَلِيُّ بْنُ مُسْهِرٍ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الرقاق ۱۶ (۶۴۵۶)، صحیح مسلم/اللباس ۶ (۲۰۸۲)، سنن ابی داود/ اللباس ۴۵ (۴۱۴۶)، سنن ابن ماجہ/الزہد ۱۱ (۴۱۵۱)، (تحفة الأشراف : ۱۷۱۰۷)، و مسند احمد (۶/۴۸، ۵۶، ۷۳، ۱۰۸، ۱۰۷),1761,,The Book on Clothing
1762,حَدَّثَنَا مُحَمَّدُ بْنُ حُمَيْدٍ الرَّازِيُّ، حَدَّثَنَا أَبُو تُمَيْلَةَ، وَالْفَضْلُ بْنُ مُوسَى,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan; Zubair Ali Zai: Hasan,takhreej: تخریج دارالدعوہ: سنن ابی داود/ اللباس ۳ (۴۰۲۵)، سنن ابن ماجہ/اللباس ۸ (۳۵۷۵)، (تحفة الأشراف : ۱۸۱۶۹),1762,,The Book on Clothing
1763,حَدَّثَنَا زِيَادُ بْنُ أَيُّوبَ الْبَغْدَادِيُّ، حَدَّثَنَا أَبُو تُمَيْلَةَ، عَنْ عَبْدِ الْمُؤْمِ,Ahmad Muhammad Shakir: Sahih; Zubair Ali Zai: Hasan,takhreej: تخریج دارالدعوہ: انظر ما قبلہ,1763,,The Book on Clothing
1764,حَدَّثَنَا عَلِيُّ بْنُ حُجْرٍ، أَخْبَرَنَا الْفَضْلُ بْنُ مُوسَى، عَنْ عَبْدِ الْمُؤْمِنِ بْنِ خَال,Ahmad Muhammad Shakir: Sahih; Zubair Ali Zai: Hasan,takhreej: تخریج دارالدعوہ: انظر رقم ۱۷۶۲,1764,,The Book on Clothing
1765,حَدَّثَنَا عَبْدُ اللَّهِ بْنُ مُحَمَّدِ بْنِ الْحَجَّاجِ الصَّوَّافُ الْبَصْرِيُّ، حَدَّثَنَا مُعَا,Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Bashar Awad Maarouf: Hasan; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: سنن ابی داود/ اللباس ۳ (۴۰۲۷)، (تحفة الأشراف : ۱۵۷۶۵),1765,,The Book on Clothing
1766,حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ، حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ، ح,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف وأخرجہ النسائي في الکبریٰ)، (تحفة الأشراف : ۱۲۳۹۹),1766,,The Book on Clothing
1767,حَدَّثَنَا سُوَيْدُ بْنُ نَصْرٍ، أَخْبَرَنَا عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ، عَنْ سَعِيدٍ الْجُرَي,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan,takhreej: تخریج دارالدعوہ: سنن ابی داود/ اللباس ۱ (۴۰۲۰)، سنن النسائی/عمل الیوم واللیلة ۱۱۸ (۳۰۹)، (تحفة الأشراف : ۴۳۲۶)، و مسند احمد (۳/۳۰، ۵۰),1767,,The Book on Clothing
1768,حَدَّثَنَا يُوسُفُ بْنُ عِيسَى، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا يُونُسُ بْنُ أَبِي إِسْحَاق، عَنْ الش,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۱۱۵۱۶),1768,,The Book on Clothing
1769,حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا ابْنُ أَبِي زَائِدَةَ، عَنْ الْحَسَنِ بْنِ عَيَّاشٍ، عَنْ أَبِي إِ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف، (تحفة الأشراف : ۱۱۵۱۶),1769,,The Book on Clothing
1770,حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا عَلِيُّ بْنُ هَاشِمِ بْنِ الْبَرِيدِ، وَأَبُو سَعْدٍ ال,Ahmad Muhammad Shakir: Hasan; Al-Albani: Hasan; Bashar Awad Maarouf: Hasan,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الخاتم ۷ (۴۲۳۲)، سنن النسائی/الزینة ۴۱ (۵۱۶۴)، (تحفة الأشراف : ۹۸۹۵)، و مسند احمد (۵/۲۳),1770,,The Book on Clothing
1771,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، حَدَّثَنَا شُعْبَةُ، عَنْ يَ,Al-Albani: Sahih; Zubair Ali Zai: Hasan,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۱۹۵۹۸),1771,,The Book on Clothing
1772,"حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ عُمَرَ، عَنْ نَافِعٍ، عَنْ سَعِيدِ بْنِ أَبِي هِنْدٍ، عَنْ أَبِي مُوسَى الأَشْعَرِيِّ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ حُرِّمَ لِبَاسُ الْحَرِيرِ وَالذَّهَبِ عَلَى ذُكُورِ أُمَّتِي وَأُحِلَّ لإِنَاثِهِمْ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ عُمَرَ وَعَلِيٍّ وَعُقْبَةَ بْنِ عَامِرٍ وَأَنَسٍ وَحُذَيْفَةَ وَأُمِّ هَانِئٍ وَعَبْدِ اللَّهِ بْنِ عَمْرٍو وَعِمْرَانَ بْنِ حُصَيْنٍ وَعَبْدِ اللَّهِ بْنِ الزُّبَيْرِ وَجَابِرٍ وَأَبِي رَيْحَانَةَ وَابْنِ عُمَرَ وَوَاثِلَةَ بْنِ الأَسْقَعِ ‏.‏ وَحَدِيثُ أَبِي مُوسَى حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: تخریج دارالدعوہ: صحیح البخاری/اللباس ۴۱ (۵۸۵۷)، (وانظر أیضا: الخمس رقم ۳۱۰۷) سنن ابی داود/ اللباس ۴۴ (۴۱۳۴)، سنن ابن ماجہ/اللباس ۲۷ (۱۶۱۵)، (تحفة الأشراف : ۱۳۹۲)، و مسند احمد (۳/۱۲۲، ۲۰۳، ۲۴۵، ۲۶۹),,Narrated Abu Musa Al-Ash'ari:,The Book on Clothing
1773,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُعَاذُ بْنُ هِشَامٍ، حَدَّثَنَا أَبِي، عَنْ قَتَادَةَ، عَنِ الشَّعْبِيِّ، عَنْ سُوَيْدِ بْنِ غَفَلَةَ، عَنْ عُمَرَ، أَنَّهُ خَطَبَ بِالْجَابِيَةِ فَقَالَ نَهَى نَبِيُّ اللَّهِ صلى الله عليه وسلم عَنِ الْحَرِيرِ إِلاَّ مَوْضِعَ أُصْبُعَيْنِ أَوْ ثَلاَثٍ أَوْ أَرْبَعٍ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: انظر ما قبلہ,1773,Narrated Suwaid bin Ghafalah:,The Book on Clothing
1774,حَدَّثَنَا مَحْمُودُ بْنُ غَيْلاَنَ، حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ، حَدَّثَنَا هَمَّامٌ، حَدَّثَنَا قَتَادَةُ، عَنْ أَنَسِ بْنِ مَالِكٍ، أَنَّ عَبْدَ الرَّحْمَنِ بْنَ عَوْفٍ، وَالزُّبَيْرَ بْنَ الْعَوَّامِ، شَكَيَا الْقَمْلَ إِلَى النَّبِيِّ صلى الله عليه وسلم فِي غَزَاةٍ لَهُمَا فَرَخَّصَ لَهُمَا فِي قُمُصِ الْحَرِيرِ قَالَ وَرَأَيْتُهُ عَلَيْهِمَا ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/اللباس ۴۰ (۵۸۵۵)، صحیح مسلم/اللباس ۱۹ (۲۰۹۷)، سنن ابی داود/ اللباس ۴۴ (۴۱۳۶)، سنن النسائی/اللباس ۲۹ (۱۶۱۷)، (تحفة الأشراف : ۱۳۸۰۰)، و مسند احمد (۲/۲۴۵، ۳۱۴),1774,Narrated Anas bin Malik:,The Book on Clothing
1775,"حَدَّثَنَا أَبُو عَمَّارٍ، حَدَّثَنَا الْفَضْلُ بْنُ مُوسَى، عَنْ مُحَمَّدِ بْنِ عَمْرٍو، حَدَّثَنَا وَاقِدُ بْنُ عَمْرِو بْنِ سَعْدِ بْنِ مُعَاذٍ، قَالَ قَدِمَ أَنَسُ بْنُ مَالِكٍ فَأَتَيْتُهُ فَقَالَ مَنْ أَنْتَ فَقُلْتُ أَنَا وَاقِدُ بْنُ عَمْرِو بْنِ سَعْدِ بْنِ مُعَاذٍ، ‏.‏ قَالَ فَبَكَى وَقَالَ إِنَّكَ لَشَبِيهٌ بِسَعْدٍ وَإِنَّ سَعْدًا كَانَ مِنْ أَعْظَمِ النَّاسِ وَأَطْوَلِهِمْ وَإِنَّهُ بَعَثَ إِلَى النَّبِيِّ صلى الله عليه وسلم جُبَّةً مِنْ دِيبَاجٍ مَنْسُوجٌ فِيهَا الذَّهَبُ فَلَبِسَهَا رَسُولُ اللَّهِ صلى الله عليه وسلم فَصَعِدَ الْمِنْبَرَ فَقَامَ أَوْ قَعَدَ فَجَعَلَ النَّاسُ يَلْمُسُونَهَا فَقَالُوا مَا رَأَيْنَا كَالْيَوْمِ ثَوْبًا قَطُّ ‏.‏ فَقَالَ ‏ ‏ أَتَعْجَبُونَ مِنْ هَذِهِ لَمَنَادِيلُ سَعْدٍ فِي الْجَنَّةِ خَيْرٌ مِمَّا تَرَوْنَ ‏""""‏ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ أَسْمَاءَ بِنْتِ أَبِي بَكْرٍ ‏.‏ وَهَذَا حَدِيثٌ صَحِيحٌ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف وانظر: سنن ابن ماجہ/اللباس ۲۹ (۳۶۱۸)، (تحفة الأشراف : ۱۴۶۳),,Narrated Waqid bin 'Amr bin Sa'd bin Mu'adh:,The Book on Clothing
1776,حَدَّثَنَا مَحْمُودُ بْنُ غَيْلاَنَ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا سُفْيَانُ، عَنْ أَبِي إِسْحَاقَ، عَنِ الْبَرَاءِ، قَالَ مَا رَأَيْتُ مِنْ ذِي لِمَّةٍ فِي حُلَّةٍ حَمْرَاءَ أَحْسَنَ مِنْ رَسُولِ اللَّهِ صلى الله عليه وسلم لَهُ شَعْرٌ يَضْرِبُ مَنْكِبَيْهِ بَعِيدُ مَا بَيْنَ الْمَنْكِبَيْنِ لَمْ يَكُنْ بِالْقَصِيرِ وَلاَ بِالطَّوِيلِ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ جَابِرِ بْنِ سَمُرَةَ وَأَبِي رِمْثَةَ وَأَبِي جُحَيْفَةَ ‏.‏ وَهَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۱۳۴۰),1776,Narrated Al-Bara' :,The Book on Clothing
1777,حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، عَنْ نَافِعٍ، عَنْ إِبْرَاهِيمَ بْنِ عَبْدِ اللَّهِ بْنِ حُنَيْنٍ، عَنْ أَبِيهِ، عَنْ عَلِيٍّ، قَالَ نَهَانِي النَّبِيُّ صلى الله عليه وسلم عَنْ لُبْسِ الْقَسِّيِّ وَالْمُعَصْفَرِ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ أَنَسٍ وَعَبْدِ اللَّهِ بْنِ عَمْرٍو وَحَدِيثُ عَلِيٍّ حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏,Ahmad Muhammad Shakir: Munkar; Al-Albani: Munkar; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۱۷۵۱۶),1777,Narrated 'Ali:,The Book on Clothing
1778,"حَدَّثَنَا إِسْمَاعِيلُ بْنُ مُوسَى الْفَزَارِيُّ، حَدَّثَنَا سَيْفُ بْنُ هَارُونَ الْبُرْجُمِيُّ، عَنْ سُلَيْمَانَ التَّيْمِيِّ، عَنْ أَبِي عُثْمَانَ، عَنْ سَلْمَانَ، قَالَ سُئِلَ رَسُولُ اللَّهِ صلى الله عليه وسلم عَنِ السَّمْنِ وَالْجُبْنِ وَالْفِرَاءِ ‏.‏ فَقَالَ ‏ ‏ الْحَلاَلُ مَا أَحَلَّ اللَّهُ فِي كِتَابِهِ وَالْحَرَامُ مَا حَرَّمَ اللَّهُ فِي كِتَابِهِ وَمَا سَكَتَ عَنْهُ فَهُوَ مِمَّا عَفَا عَنْهُ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنِ الْمُغِيرَةِ ‏.‏ وَهَذَا حَدِيثٌ غَرِيبٌ لاَ نَعْرِفُهُ مَرْفُوعًا إِلاَّ مِنْ هَذَا الْوَجْهِ ‏.‏ وَرَوَى سُفْيَانُ وَغَيْرُهُ عَنْ سُلَيْمَانَ التَّيْمِيِّ عَنْ أَبِي عُثْمَانَ عَنْ سَلْمَانَ قَوْلَهُ وَكَأَنَّ الْحَدِيثَ الْمَوْقُوفَ أَصَحُّ ‏.‏ وَسَأَلْتُ الْبُخَارِيَّ عَنْ هَذَا الْحَدِيثِ فَقَالَ مَا أُرَاهُ مَحْفُوظًا رَوَى سُفْيَانُ عَنْ سُلَيْمَانَ التَّيْمِيِّ عَنْ أَبِي عُثْمَانَ عَنْ سَلْمَانَ مَوْقُوفًا ‏.‏ قَالَ الْبُخَارِيُّ وَسَيْفُ بْنُ هَارُونَ مُقَارِبُ الْحَدِيثِ وَسَيْفُ بْنُ مُحَمَّدٍ عَنْ عَاصِمٍ ذَاهِبُ الْحَدِيثِ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۱۷۴۸۹),,Narrated Salman:,The Book on Clothing
1779,"حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا اللَّيْثُ، عَنْ يَزِيدَ بْنِ أَبِي حَبِيبٍ، عَنْ عَطَاءِ بْنِ أَبِي رَبَاحٍ، قَالَ سَمِعْتُ ابْنَ عَبَّاسٍ، يَقُولُ مَاتَتْ شَاةٌ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم لأَهْلِهَا ‏ ‏ أَلاَ نَزَعْتُمْ جِلْدَهَا ثُمَّ دَبَغْتُمُوهُ فَاسْتَمْتَعْتُمْ بِهِ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ سَلَمَةَ بْنِ الْمُحَبِّقِ وَمَيْمُونَةَ وَعَائِشَةَ ‏.‏ وَحَدِيثُ ابْنِ عَبَّاسٍ حَسَنٌ صَحِيحٌ وَقَدْ رُوِيَ مِنْ غَيْرِ وَجْهٍ عَنِ ابْنِ عَبَّاسٍ عَنِ النَّبِيِّ صلى الله عليه وسلم نَحْوُ هَذَا ‏.‏ وَرُوِيَ عَنِ ابْنِ عَبَّاسٍ عَنْ مَيْمُونَةَ عَنِ النَّبِيِّ صلى الله عليه وسلم ‏.‏ وَرُوِيَ عَنْهُ عَنْ سَوْدَةَ وَسَمِعْتُ مُحَمَّدًا يُصَحِّحُ حَدِيثَ ابْنِ عَبَّاسٍ عَنِ النَّبِيِّ صلى الله عليه وسلم وَحَدِيثَ ابْنِ عَبَّاسٍ عَنْ مَيْمُونَةَ وَقَالَ احْتَمَلَ أَنْ يَكُونَ رَوَى ابْنُ عَبَّاسٍ عَنْ مَيْمُونَةَ عَنِ النَّبِيِّ صلى الله عليه وسلم وَرَوَى ابْنُ عَبَّاسٍ عَنِ النَّبِيِّ صلى الله عليه وسلم وَلَمْ يَذْكُرْ فِيهِ عَنْ مَيْمُونَةَ ‏.‏ قَالَ أَبُو عِيسَى وَالْعَمَلُ عَلَى هَذَا عِنْدَ أَكْثَرِ أَهْلِ الْعِلْمِ وَهُوَ قَوْلُ سُفْيَانَ الثَّوْرِيِّ وَابْنِ الْمُبَارَكِ وَالشَّافِعِيِّ وَأَحْمَدَ وَإِسْحَاقَ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/اللباس ۳۹ (۵۸۵۴)، سنن ابی داود/ اللباس ۴۴ (۴۱۳۹)، سنن ابن ماجہ/اللباس ۲۸ (۳۶۱۶)، (تحفة الأشراف : ۱۳۸۱۴)، وط/اللباس ۷ (۱۵)، و مسند احمد (۲/۲۸۳، ۴۳۰، ۴۷۷),,Narrated Ibn 'Abbas:,The Book on Clothing
1780,"حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، وَعَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ، عَنْ زَيْدِ بْنِ أَسْلَمَ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ وَعْلَةَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏""‏ أَيُّمَا إِهَابٍ دُبِغَ فَقَدْ طَهُرَ ‏""‏ ‏.‏ هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَالْعَمَلُ عَلَى هَذَا عِنْدَ أَكْثَرِ أَهْلِ الْعِلْمِ قَالُوا فِي جُلُودِ الْمَيْتَةِ إِذَا دُبِغَتْ فَقَدْ طَهُرَتْ ‏.‏ قَالَ أَبُو عِيسَى قَالَ الشَّافِعِيُّ أَيُّمَا إِهَابِ مَيْتَةٍ دُبِغَ فَقَدْ طَهُرَ إِلاَّ الْكَلْبَ وَالْخِنْزِيرَ ‏.‏ وَاحْتَجَّ بِهَذَا الْحَدِيثِ ‏.‏ وَقَالَ بَعْضُ أَهْلِ الْعِلْمِ مِنْ أَصْحَابِ النَّبِيِّ صلى الله عليه وسلم وَغَيْرِهِمْ إِنَّهُمْ كَرِهُوا جُلُودَ السِّبَاعِ وَإِنْ دُبِغَ وَهُوَ قَوْلُ عَبْدِ اللَّهِ بْنِ الْمُبَارَكِ وَأَحْمَدَ وَإِسْحَاقَ وَشَدَّدُوا فِي لُبْسِهَا وَالصَّلاَةِ فِيهَا ‏.‏ قَالَ إِسْحَاقُ بْنُ إِبْرَاهِيمَ إِنَّمَا مَعْنَى قَوْلِ رَسُولِ اللَّهِ صلى الله عليه وسلم ‏""‏ أَيُّمَا إِهَابٍ دُبِغَ فَقَدْ طَهُرَ ‏""‏ ‏.‏ جِلْدُ مَا يُؤْكَلُ لَحْمُهُ هَكَذَا فَسَّرَهُ النَّضْرُ بْنُ شُمَيْلٍ ‏.‏ وَقَالَ إِسْحَاقُ قَالَ النَّضْرُ بْنُ شُمَيْلٍ إِنَّمَا يُقَالُ الإِهَابُ لِجِلْدِ مَا يُؤْكَلُ لَحْمُهُ ‏.‏",Ahmad Muhammad Shakir: Very Daif; Al-Albani: Very Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۱۶۳۴۷),1780,Narrated Ibn 'Abbas:,The Book on Clothing
1781,"حَدَّثَنَا مُحَمَّدُ بْنُ طَرِيفٍ الْكُوفِيُّ، حَدَّثَنَا مُحَمَّدُ بْنُ فُضَيْلٍ، عَنِ الأَعْمَشِ، وَالشَّيْبَانِيِّ، عَنِ الْحَكَمِ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِي لَيْلَى، عَنْ عَبْدِ اللَّهِ بْنِ عُكَيْمٍ، قَالَ أَتَانَا كِتَابُ رَسُولِ اللَّهِ صلى الله عليه وسلم ‏ ‏ أَنْ لاَ تَنْتَفِعُوا مِنَ الْمَيْتَةِ بِإِهَابٍ وَلاَ عَصَبٍ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ ‏.‏ وَيُرْوَى عَنْ عَبْدِ اللَّهِ بْنِ عُكَيْمٍ عَنْ أَشْيَاخٍ لَهُمْ هَذَا الْحَدِيثُ ‏.‏ وَلَيْسَ الْعَمَلُ عَلَى هَذَا عِنْدَ أَكْثَرِ أَهْلِ الْعِلْمِ ‏.‏ وَقَدْ رُوِيَ هَذَا الْحَدِيثُ عَنْ عَبْدِ اللَّهِ بْنِ عُكَيْمٍ أَنَّهُ قَالَ أَتَانَا كِتَابُ النَّبِيِّ صلى الله عليه وسلم قَبْلَ وَفَاتِهِ بِشَهْرَيْنِ ‏.‏ قَالَ وَسَمِعْتُ أَحْمَدَ بْنَ الْحَسَنِ يَقُولُ كَانَ أَحْمَدُ بْنُ حَنْبَلٍ يَذْهَبُ إِلَى هَذَا الْحَدِيثِ لِمَا ذُكِرَ فِيهِ قَبْلَ وَفَاتِهِ بِشَهْرَيْنِ وَكَانَ يَقُولُ كَانَ هَذَا آخِرَ أَمْرِ النَّبِيِّ صلى الله عليه وسلم ‏.‏ ثُمَّ تَرَكَ أَحْمَدُ بْنُ حَنْبَلٍ هَذَا الْحَدِيثَ لَمَّا اضْطَرَبُوا فِي إِسْنَادِهِ حَيْثُ رَوَى بَعْضُهُمْ فَقَالَ عَنْ عَبْدِ اللَّهِ بْنِ عُكَيْمٍ عَنْ أَشْيَاخٍ لَهُمْ مِنْ جُهَيْنَةَ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih,takhreej: تخریج دارالدعوہ: انظر ما قبلہ,,Narrated 'Abdullah bin 'Ukaim:,The Book on Clothing
1782,"حَدَّثَنَا الأَنْصَارِيُّ، حَدَّثَنَا مَعْنٌ، حَدَّثَنَا مَالِكٌ، ح وَحَدَّثَنَا قُتَيْبَةُ، عَنْ مَالِكٍ، عَنْ نَافِعٍ، وَعَبْدِ اللَّهِ بْنِ دِينَارٍ، وَزَيْدِ بْنِ أَسْلَمَ، كُلُّهُمْ يُخْبِرُ عَنْ عَبْدِ اللَّهِ بْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ لاَ يَنْظُرُ اللَّهُ يَوْمَ الْقِيَامَةِ إِلَى مَنْ جَرَّ ثَوْبَهُ خُيَلاَءَ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ حُذَيْفَةَ وَأَبِي سَعِيدٍ وَأَبِي هُرَيْرَةَ وَسَمُرَةَ وَأَبِي ذَرٍّ وَعَائِشَةَ وَهُبَيْبِ بْنِ مُغْفِلٍ ‏.‏ وَحَدِيثُ ابْنِ عُمَرَ حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏""",Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Bashar Awad Maarouf: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۱۲۱۴۴),,Narrated 'Abdullah bin 'Umar:,The Book on Clothing
1783,"حَدَّثَنَا الْحَسَنُ بْنُ عَلِيٍّ الْخَلاَّلُ، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَخْبَرَنَا مَعْمَرٌ، عَنْ أَيُّوبَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏""‏ مَنْ جَرَّ ثَوْبَهُ خُيَلاَءَ لَمْ يَنْظُرِ اللَّهُ إِلَيْهِ يَوْمَ الْقِيَامَةِ ‏""‏ ‏.‏ فَقَالَتْ أُمُّ سَلَمَةَ فَكَيْفَ يَصْنَعْنَ النِّسَاءُ بِذُيُولِهِنَّ قَالَ ‏""‏ يُرْخِينَ شِبْرًا ‏""‏ ‏.‏ فَقَالَتْ إِذًا تَنْكَشِفَ أَقْدَامُهُنَّ ‏.‏ قَالَ ‏""‏ فَيُرْخِينَهُ ذِرَاعًا لاَ يَزِدْنَ عَلَيْهِ ‏""‏ ‏.‏ قَالَ هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: سنن ابن ماجہ/اللباس ۷ (۳۵۷۲)، (تحفة الأشراف : ۳۳۸۳) و مسند احمد (۵/۳۸۲، ۳۹۶، ۳۹۸، ۴۰۰، ۴۰۱),1783,Narrated Ibn 'Umar:,The Book on Clothing
1784,حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ، أَخْبَرَنَا عَفَّانُ، حَدَّثَنَا حَمَّادُ بْنُ سَلَمَةَ، عَنْ عَلِيِّ بْنِ زَيْدٍ، عَنْ أُمِّ الْحَسَنِ الْبَصْرِيِّ، أَنَّ أُمَّ سَلَمَةَ، حَدَّثَتْهُمْ أَنَّ النَّبِيَّ صلى الله عليه وسلم شَبَّرَ لِفَاطِمَةَ شِبْرًا مِنْ نِطَاقِهَا ‏.‏ قَالَ أَبُو عِيسَى وَرَوَى بَعْضُهُمْ عَنْ حَمَّادِ بْنِ سَلَمَةَ عَنْ عَلِيِّ بْنِ زَيْدٍ عَنِ الْحَسَنِ عَنْ أُمِّهِ عَنْ أُمِّ سَلَمَةَ ‏.‏ وَفِي هَذَا الْحَدِيثِ رُخْصَةٌ لِلنِّسَاءِ فِي جَرِّ الإِزَارِ لأَنَّهُ يَكُونُ أَسْتَرَ لَهُنَّ ‏.‏,Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: سنن ابی داود/ اللباس ۲۴ (۴۰۷۸)، (تحفة الأشراف : ۳۶۱۴),1784,Narrated Umm Salamah:,The Book on Clothing
1785,حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ إِبْرَاهِيمَ، حَدَّثَنَا أَيُّوبُ، عَنْ حُمَيْدِ بْنِ هِلاَلٍ، عَنْ أَبِي بُرْدَةَ، قَالَ أَخْرَجَتْ إِلَيْنَا عَائِشَةُ كِسَاءً مُلَبَّدًا وَإِزَارًا غَلِيظًا فَقَالَتْ قُبِضَ رُوحُ رَسُولِ اللَّهِ صلى الله عليه وسلم فِي هَذَيْنِ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ عَلِيٍّ وَابْنِ مَسْعُودٍ ‏.‏ وَحَدِيثُ عَائِشَةَ حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏,Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Zubair Ali Zai: Hasan,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الخاتم ۴ (۴۲۲۳)، سنن النسائی/الزینة ۴۶ (۵۱۹۸)، (تحفة الأشراف : ۱۹۸۲)، و مسند احمد (۵/۳۵۹),1785,Narrated Abu Burdah:,The Book on Clothing
1786,"حَدَّثَنَا عَلِيُّ بْنُ حُجْرٍ، حَدَّثَنَا خَلَفُ بْنُ خَلِيفَةَ، عَنْ حُمَيْدٍ الأَعْرَجِ، عَنْ عَبْدِ اللَّهِ بْنِ الْحَارِثِ، عَنِ ابْنِ مَسْعُودٍ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ كَانَ عَلَى مُوسَى يَوْمَ كَلَّمَهُ رَبُّهُ كِسَاءُ صُوفٍ وَجُبَّةُ صُوفٍ وَكُمَّةُ صُوفٍ وَسَرَاوِيلُ صُوفٍ وَكَانَتْ نَعْلاَهُ مِنْ جِلْدِ حِمَارٍ مَيِّتٍ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ غَرِيبٌ لاَ نَعْرِفُهُ إِلاَّ مِنْ حَدِيثِ حُمَيْدٍ الأَعْرَجِ ‏.‏ وَحُمَيْدٌ هُوَ ابْنُ عَلِيٍّ الْكُوفِيُّ ‏.‏ قَالَ سَمِعْتُ مُحَمَّدًا يَقُولُ حُمَيْدُ بْنُ عَلِيٍّ الأَعْرَجُ مُنْكَرُ الْحَدِيثِ وَحُمَيْدُ بْنُ قَيْسٍ الأَعْرَجُ الْمَكِّيُّ صَاحِبُ مُجَاهِدٍ ثِقَةٌ ‏.‏ وَالْكُمَّةُ الْقَلَنْسُوَةُ الصَّغِيرَةُ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Daif; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/اللباس ۱۶ (۲۰۸۷)، والذکر ۱۸ (۲۷۲۵)، سنن ابی داود/ الخاتم ۴ (۴۲۲۵)، سنن النسائی/الزینة ۵۲ (۵۲۱۳)، ۷۹ (۵۲۸۸)، و ۱۲۱ (۵۳۷۸)، سنن ابن ماجہ/اللباس ۴۳ (۳۶۴۸)، (تحفة الأشراف : ۱۰۳۱۸)، و مسند احمد (۱/۸۸، ۱۳۴، ۱۳۸),,Narrated Ibn Mas'ud:,The Book on Clothing
1787,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، عَنْ حَمَّادِ بْنِ سَلَمَةَ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، قَالَ دَخَلَ النَّبِيُّ صلى الله عليه وسلم مَكَّةَ يَوْمَ الْفَتْحِ وَعَلَيْهِ عِمَامَةٌ سَوْدَاءُ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ عَلِيٍّ وَعَمْرِو بْنِ حُرَيْثٍ وَابْنِ عَبَّاسٍ وَرُكَانَةَ ‏.‏ قَالَ أَبُو عِيسَى حَدِيثُ جَابِرٍ حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/اللباس ۱۸ (۵۸۱۲)، صحیح مسلم/اللباس ۵ (۲۰۷۹)، سنن النسائی/الزینة ۹۴ (۵۳۱۷)، والمؤلف في الشمائل ۸ (تحفة الأشراف : ۱۳۵۳)، و مسند احمد (۳/۱۳۴، ۱۸۴، ۲۵۱، ۲۹۱),1787,Narrated Jabir:,The Book on Clothing
1788,حَدَّثَنَا هَارُونُ بْنُ إِسْحَاقَ الْهَمْدَانِيُّ، حَدَّثَنَا يَحْيَى بْنُ مُحَمَّدٍ الْمَدَنِيُّ، عَنْ عَبْدِ الْعَزِيزِ بْنِ مُحَمَّدٍ، عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ كَانَ النَّبِيُّ صلى الله عليه وسلم إِذَا اعْتَمَّ سَدَلَ عِمَامَتَهُ بَيْنَ كَتِفَيْهِ ‏.‏ قَالَ نَافِعٌ وَكَانَ ابْنُ عُمَرَ يَسْدِلُ عِمَامَتَهُ بَيْنَ كَتِفَيْهِ ‏.‏ قَالَ عُبَيْدُ اللَّهِ وَرَأَيْتُ الْقَاسِمَ وَسَالِمًا يَفْعَلاَنِ ذَلِكَ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ غَرِيبٌ ‏.‏ وَفِي الْبَابِ عَنْ عَلِيٍّ وَلاَ يَصِحُّ حَدِيثُ عَلِيٍّ فِي هَذَا مِنْ قِبَلِ إِسْنَادِهِ ‏.,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأطعمة ۸ (۵۳۸۶)، ۲۳ (۵۴۱۵)، والرقاق ۱۶ (۶۴۵۰)، سنن ابن ماجہ/الأطعمة ۲۰ (۳۲۹۲)، والمؤلف في الزہد ۳۸ (۲۳۶۳)، والشمائل ۲۵ (تحفة الأشراف : ۱۴۴۴)، و مسند احمد (۳/۱۳۰),1788,Narrated Nafi':,The Book on Clothing
1789,حَدَّثَنَا سَلَمَةُ بْنُ شَبِيبٍ، وَالْحَسَنُ بْنُ عَلِيٍّ الْخَلاَّلُ، وَغَيْرُ، وَاحِدٍ، قَالُوا حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَخْبَرَنَا مَعْمَرٌ، عَنِ الزُّهْرِيِّ، عَنْ إِبْرَاهِيمَ بْنِ عَبْدِ اللَّهِ بْنِ حُنَيْنٍ، عَنْ أَبِيهِ، عَنْ عَلِيِّ بْنِ أَبِي طَالِبٍ، قَالَ نَهَانِي النَّبِيُّ صلى الله عليه وسلم عَنِ التَّخَتُّمِ بِالذَّهَبِ وَعَنْ لِبَاسِ الْقَسِّيِّ وَعَنِ الْقِرَاءَةِ فِي الرُّكُوعِ وَالسُّجُودِ وَعَنْ لِبَاسِ الْمُعَصْفَرِ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الہبة ۵ (۲۵۷۲)، والصید ۱۰ (۵۴۸۹)، و ۳۲ (۵۵۳۵)، صحیح مسلم/الصید ۹ (۱۹۵۳)، سنن ابی داود/ الأطعمة ۲۷ (۳۷۹۱)، سنن النسائی/الصید ۲۵ (۴۳۱۷)، سنن ابن ماجہ/الصید ۱۷ (۳۲۴۳)، (تحفة الأشراف : ۱۶۲۹)، و مسند احمد (۳/۱۱۸، ۱۷۱)، سنن الدارمی/الصید ۷ (۲۰۵۶),1789,Narrated 'Ali bin Abi Talib:,The Book on Clothing
1790,حَدَّثَنَا يُوسُفُ بْنُ حَمَّادٍ الْمَعْنِيُّ الْبَصْرِيُّ، حَدَّثَنَا عَبْدُ الْوَارِثِ بْنُ سَعِيدٍ، عَنْ أَبِي التَّيَّاحِ، حَدَّثَنَا حَفْصٌ اللَّيْثِيُّ، قَالَ أَشْهَدُ عَلَى عِمْرَانَ بْنِ حُصَيْنٍ أَنَّهُ حَدَّثَنَا أَنَّهُ، قَالَ نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم عَنِ التَّخَتُّمِ بِالذَّهَبِ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ عَلِيٍّ وَابْنِ عُمَرَ وَأَبِي هُرَيْرَةَ وَمُعَاوِيَةَ ‏.‏ قَالَ أَبُو عِيسَى حَدِيثُ عِمْرَانَ حَدِيثٌ حَسَنٌ ‏.‏ وَأَبُو التَّيَّاحِ اسْمُهُ يَزِيدُ بْنُ حُمَيْدٍ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف، (تحفة الأشراف : ۷۲۴۰),1790,Narrated 'Imran bin Husain:,The Book on Clothing
1791,حَدَّثَنَا قُتَيْبَةُ، وَغَيْرُ، وَاحِدٍ، عَنْ عَبْدِ اللَّهِ بْنِ وَهْبٍ، عَنْ يُونُسَ، عَنِ ابْنِ شِهَابٍ، عَنْ أَنَسٍ، قَالَ كَانَ خَاتَمُ النَّبِيِّ صلى الله عليه وسلم مِنْ وَرِقٍ وَكَانَ فَصُّهُ حَبَشِيًّا ‏.‏ قَالَ وَفِي الْبَابِ عَنِ ابْنِ عُمَرَ وَبُرَيْدَةَ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ غَرِيبٌ مِنْ هَذَا الْوَجْهِ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأطعمة ۳۲ (۳۸۰۱)، سنن النسائی/الحج ۸۹ (۲۸۳۹)، والصید ۲۷ (۴۳۲۸)، سنن ابن ماجہ/المناسک ۹۰ (۳۰۸۵)، والصید ۱۵ (۳۲۳۶)، (تحفة الأشراف : ۲۳۸۱)، و مسند احمد (۳/۲۹۷، ۳۱۸، ۳۲۲)، سنن الدارمی/المناسک ۹۰ (۱۹۸۴),1791,Narrated Anas:,The Book on Clothing
1792,حَدَّثَنَا مَحْمُودُ بْنُ غَيْلاَنَ، حَدَّثَنَا حَفْصُ بْنُ عُمَرَ بْنِ عُبَيْدٍ الطَّنَافِسِيُّ، حَدَّثَنَا زُهَيْرُ بْنُ مُعَاوِيَةَ أَبُو خَيْثَمَةَ، عَنْ حُمَيْدٍ، عَنْ أَنَسٍ، قَالَ كَانَ خَاتَمُ رَسُولِ اللَّهِ صلى الله عليه وسلم مِنْ فِضَّةٍ فَصُّهُ مِنْهُ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ غَرِيبٌ مِنْ هَذَا الْوَجْهِ ‏.‏,Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: سنن ابن ماجہ/الصید ۱۴ (۳۲۳۵)، و ۱۵ (۳۲۳۷),1792,Narrated Anas:,The Book on Clothing
1793,"حَدَّثَنَا مُحَمَّدُ بْنُ عُبَيْدٍ الْمُحَارِبِيُّ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ أَبِي حَازِمٍ، عَنْ مُوسَى بْنِ عُقْبَةَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ النَّبِيَّ صلى الله عليه وسلم صَنَعَ خَاتَمًا مِنْ ذَهَبٍ فَتَخَتَّمَ بِهِ فِي يَمِينِهِ ثُمَّ جَلَسَ عَلَى الْمِنْبَرِ فَقَالَ ‏ ‏ إِنِّي كُنْتُ اتَّخَذْتُ هَذَا الْخَاتَمَ فِي يَمِينِي ‏""""‏ ‏.‏ ثُمَّ نَبَذَهُ وَنَبَذَ النَّاسُ خَوَاتِيمَهُمْ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ عَلِيٍّ وَجَابِرٍ وَعَبْدِ اللَّهِ بْنِ جَعْفَرٍ وَابْنِ عَبَّاسٍ وَعَائِشَةَ وَأَنَسٍ ‏.‏ قَالَ أَبُو عِيسَى حَدِيثُ ابْنِ عُمَرَ حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَقَدْ رُوِيَ هَذَا الْحَدِيثُ عَنْ نَافِعٍ عَنِ ابْنِ عُمَرَ نَحْوَ هَذَا مِنْ غَيْرِ هَذَا الْوَجْهِ وَلَمْ يَذْكُرْ فِيهِ أَنَّهُ تَخَتَّمَ فِي يَمِينِهِ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: صحیح,,Narrated Ibn 'Umar:,The Book on Clothing
1794,حَدَّثَنَا مُحَمَّدُ بْنُ حُمَيْدٍ الرَّازِيُّ، حَدَّثَنَا جَرِيرٌ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ، عَنِ الصَّلْتِ بْنِ عَبْدِ اللَّهِ بْنِ نَوْفَلٍ، قَالَ رَأَيْتُ ابْنَ عَبَّاسٍ يَتَخَتَّمُ فِي يَمِينِهِ وَلاَ إِخَالُهُ إِلاَّ قَالَ رَأَيْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم يَتَخَتَّمُ فِي يَمِينِهِ ‏.‏ قَالَ أَبُو عِيسَى قَالَ مُحَمَّدُ بْنُ إِسْمَاعِيلَ حَدِيثُ مُحَمَّدِ بْنِ إِسْحَاقَ عَنِ الصَّلْتِ بْنِ عَبْدِ اللَّهِ بْنِ نَوْفَلٍ حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih,takhreej: تخریج دارالدعوہ: انظر ما قبلہ (تحفة الأشراف : ۲۶۳۹),1794,Narrated As-Salt bin 'Abdullah bin Nawfal:,The Book on Clothing
1795,حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِيلَ، عَنْ جَعْفَرِ بْنِ مُحَمَّدٍ، عَنْ أَبِيهِ، قَالَ كَانَ الْحَسَنُ وَالْحُسَيْنُ يَتَخَتَّمَانِ فِي يَسَارِهِمَا ‏.‏ وَهَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏,Ahmad Muhammad Shakir: Hasan Sahih; Al-Albani: Hasan Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۱۵۰۲۶),1795,Narrated Ja'far bin Muhammad :,The Book on Clothing
1796,حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، عَنْ حَمَّادِ بْنِ سَلَمَةَ، قَالَ رَأَيْتُ ابْنَ أَبِي رَافِعٍ يَتَخَتَّمُ فِي يَمِينِهِ فَسَأَلْتُهُ عَنْ ذَلِكَ، فَقَالَ رَأَيْتُ عَبْدَ اللَّهِ بْنَ جَعْفَرٍ يَتَخَتَّمُ فِي يَمِينِهِ ‏.‏ وَقَالَ عَبْدُ اللَّهِ بْنُ جَعْفَرٍ كَانَ النَّبِيُّ صلى الله عليه وسلم يَتَخَتَّمُ فِي يَمِينِهِ ‏.‏ قَالَ وَقَالَ مُحَمَّدُ بْنُ إِسْمَاعِيلَ هَذَا أَصَحُّ شَيْءٍ رُوِيَ فِي هَذَا الْبَابِ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: انظر حدیث رقم ۱۴۶۴ و ۱۵۶۰,1796,Narrated Hammad bin Salamah:,The Book on Clothing
1797,"حَدَّثَنَا الْحَسَنُ بْنُ عَلِيٍّ الْخَلاَّلُ، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَخْبَرَنَا مَعْمَرٌ، عَنْ ثَابِتٍ، عَنْ أَنَسِ بْنِ مَالِكٍ، أَنَّ النَّبِيَّ صلى الله عليه وسلم صَنَعَ خَاتَمًا مِنْ وَرِقٍ فَنَقَشَ فِيهِ مُحَمَّدٌ رَسُولُ اللَّهِ ثُمَّ قَالَ ‏""‏ لاَ تَنْقُشُوا عَلَيْهِ ‏""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ صَحِيحٌ حَسَنٌ ‏.‏ وَمَعْنَى قَوْلِهِ ‏""‏ لاَ تَنْقُشُوا عَلَيْهِ ‏""‏ ‏.‏ نَهَى أَنْ يَنْقُشَ أَحَدٌ عَلَى خَاتَمِهِ مُحَمَّدٌ رَسُولُ اللَّهِ ‏.‏",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: انظر حدیث رقم ۱۴۶۴و ۱۵۶۰,1797,Narrated Anas bin Malik:,The Book on Clothing
1798,حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ، أَخْبَرَنَا سَعِيدُ بْنُ عَامِرٍ، وَالْحَجَّاجُ بْنُ مِنْهَالٍ، قَالاَ حَدَّثَنَا هَمَّامٌ، عَنِ ابْنِ جُرَيْجٍ، عَنِ الزُّهْرِيِّ، عَنْ أَنَسٍ، قَالَ كَانَ رَسُولُ اللَّهِ صلى الله عليه وسلم إِذَا دَخَلَ الْخَلاَءَ نَزَعَ خَاتَمَهُ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ غَرِيبٌ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: تخریج دارالدعوہ: صحیح البخاری/الوضوء ۶۷ (۲۳۵)، والذبائح ۳۴ (۵۵۳۸)، سنن ابی داود/ الأطعمة ۴۸ (۳۸۴۱)، سنن النسائی/الفرع والعتیرة ۱۰ (۴۲۶۳)، (تحفة الأشراف : ۱۸۰۶۵)، وط/الاستئذان ۷ (۲۰)، و مسند احمد (۶/۳۲۹، ۳۳۰، ۳۳۵) وسنن الدارمی/الطہارة ۵۹ (۷۶۵)، والأطعمة ۴۱ (۲۱۲۸، ۲۱۲۹، ۲۱۳۰، ۲۱۳۱),1798,Narrated Anas:,The Book on Clothing
1799,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ الأَنْصَارِيُّ، حَدَّثَنَا أَبِي، عَنْ ثُمَامَةَ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ كَانَ نَقْشُ خَاتَمِ النَّبِيِّ صلى الله عليه وسلم مُحَمَّدٌ سَطْرٌ وَرَسُولُ سَطْرٌ وَاللَّهِ سَطْرٌ ‏.‏ قَالَ أَبُو عِيسَى حَدِيثُ أَنَسٍ حَدِيثٌ حَسَنٌ صَحِيحٌ غَرِيبٌ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/الأشربة ۱۳ (۲۰۲۰) سنن ابی داود/ الأطعمة ۲۰ (۳۷۷۶)، (تحفة الأشراف : ۸۵۷۹)، وط/صفة النبی ﷺ ۴ (۶)، و مسند احمد (۲/۱۰۶)، سنن الدارمی/الأطعمة ۹ (۲۰۷۳),1799,Narrated Anas bin Malik:,The Book on Clothing
1800,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، وَمُحَمَّدُ بْنُ يَحْيَى، وَغَيْرُ، وَاحِدٍ، قَالُوا حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ الأَنْصَارِيُّ، حَدَّثَنِي أَبِي، عَنْ ثُمَامَةَ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ كَانَ نَقْشُ خَاتَمِ النَّبِيِّ صلى الله عليه وسلم ثَلاَثَةَ أَسْطُرٍ مُحَمَّدٌ سَطْرٌ وَرَسُولُ سَطْرٌ وَاللَّهِ سَطْرٌ ‏.‏ وَلَمْ يَذْكُرْ مُحَمَّدُ بْنُ يَحْيَى فِي حَدِيثِهِ ثَلاَثَةَ أَسْطُرٍ ‏.‏ وَفِي الْبَابِ عَنِ ابْنِ عُمَرَ ‏.‏,Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: انظر ما قبلہ (لم یذکرہ المزي),1800,Narrated Anas bin Malik:,The Book on Clothing
1801,حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا رَوْحُ بْنُ عُبَادَةَ، حَدَّثَنَا ابْنُ جُرَيْجٍ، أَخْبَرَنِي أَبُو الزُّبَيْرِ، عَنْ جَابِرٍ، قَالَ نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم عَنِ الصُّورَةِ فِي الْبَيْتِ وَنَهَى أَنْ يُصْنَعَ ذَلِكَ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ عَلِيٍّ وَأَبِي طَلْحَةَ وَعَائِشَةَ وَأَبِي هُرَيْرَةَ وَأَبِي أَيُّوبَ ‏.‏ قَالَ أَبُو عِيسَى حَدِيثُ جَابِرٍ حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/الأشربة ۱۸ (۲۰۳۴)، (تحفة الأشراف : ۱۲۷۲۷)، و مسند احمد (۲/۳۴۰، ۴۱۵),1801,Narrated Jabir:,The Book on Clothing
1802,"حَدَّثَنَا إِسْحَاقُ بْنُ مُوسَى الأَنْصَارِيُّ، حَدَّثَنَا مَعْنٌ، حَدَّثَنَا مَالِكٌ، عَنْ أَبِي النَّضْرِ، عَنْ عُبَيْدِ اللَّهِ بْنِ عُتْبَةَ، أَنَّهُ دَخَلَ عَلَى أَبِي طَلْحَةَ الأَنْصَارِيِّ يَعُودُهُ ‏.‏ قَالَ فَوَجَدْتُ عِنْدَهُ سَهْلَ بْنَ حُنَيْفٍ ‏.‏ قَالَ فَدَعَا أَبُو طَلْحَةَ إِنْسَانًا يَنْزِعُ نَمَطًا تَحْتَهُ فَقَالَ لَهُ سَهْلٌ لِمَ تَنْزِعُهُ فَقَالَ لأَنَّ فِيهِ تَصَاوِيرَ وَقَدْ قَالَ النَّبِيُّ صلى الله عليه وسلم مَا قَدْ عَلِمْتَ ‏.‏ قَالَ سَهْلٌ أَوَلَمْ يَقُلْ ‏ ‏ إِلاَّ مَا كَانَ رَقْمًا فِي ثَوْبٍ ‏""""‏ فَقَالَ بَلَى وَلَكِنَّهُ أَطْيَبُ لِنَفْسِي ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/الأشربة ۱۸ (۲۰۳۳)، سنن ابن ماجہ/الأطعمة ۱۳ (۳۲۷۹)، (تحفة الأشراف : ۲۷۸)، و مسند احمد (۳/۳۰۱، ۲۳۱، ۳۳۱)، ۳۳۷، ۳۶۶، ۳۹۴),,Narrated Abu An-Nadr:,The Book on Clothing
1803,"حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ، عَنْ أَيُّوبَ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنْ صَوَّرَ صُورَةً عَذَّبَهُ اللَّهُ حَتَّى يَنْفُخَ فِيهَا يَعْنِي الرُّوحَ وَلَيْسَ بِنَافِخٍ فِيهَا وَمَنِ اسْتَمَعَ إِلَى حَدِيثِ قَوْمٍ وَهُمْ يَفِرُّونَ بِهِ مِنْهُ صُبَّ فِي أُذُنِهِ الآنُكُ يَوْمَ الْقِيَامَةِ ‏""""‏ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ عَبْدِ اللَّهِ بْنِ مَسْعُودٍ وَأَبِي هُرَيْرَةَ وَأَبِي جُحَيْفَةَ وَعَائِشَةَ وَابْنِ عُمَرَ ‏.‏ قَالَ أَبُو عِيسَى حَدِيثُ ابْنِ عَبَّاسٍ حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/الأشربة ۱۸ (۲۰۳۴)، سنن ابی داود/ الأطعمة ۵۰ (۳۸۴۵)، (تحفة الأشراف : ۱۸۰۳)، و مسند احمد (۳/۱۱۷، ۲۹۰)، سنن الدارمی/۱ الأطعمة ۸ (۲۰۷۱),,Narrated Ibn 'Abbas:,The Book on Clothing
1804,"حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا أَبُو عَوَانَةَ، عَنْ عُمَرَ بْنِ أَبِي سَلَمَةَ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ غَيِّرُوا الشَّيْبَ وَلاَ تَشَبَّهُوا بِالْيَهُودِ ‏""""‏ ‏.‏ قَالَ وَفِي الْبَابِ عَنِ الزُّبَيْرِ وَابْنِ عَبَّاسٍ وَجَابِرٍ وَأَبِي ذَرٍّ وَأَنَسٍ وَأَبِي رِمْثَةَ وَالْجَهْدَمَةِ وَأَبِي الطُّفَيْلِ وَجَابِرِ بْنِ سَمُرَةَ وَأَبِي جُحَيْفَةَ وَابْنِ عُمَرَ ‏.‏ قَالَ أَبُو عِيسَى حَدِيثُ أَبِي هُرَيْرَةَ حَدِيثٌ حَسَنٌ صَحِيحٌ وَقَدْ رُوِيَ مِنْ غَيْرِ وَجْهٍ عَنْ أَبِي هُرَيْرَةَ عَنِ النَّبِيِّ صلى الله عليه وسلم ‏.‏""",Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: سنن ابن ماجہ/الأطعمة ۱۰ (۳۲۷۱)، (تحفة الأشراف : ۱۱۵۸۸)، (تحفة الأشراف : ۱۱۵۸۸),,Narrated Abu Hurairah:,The Book on Clothing
1805,"حَدَّثَنَا سُوَيْدُ بْنُ نَصْرٍ، أَخْبَرَنَا ابْنُ الْمُبَارَكِ، عَنِ الأَجْلَحِ، عَنْ عَبْدِ اللَّهِ بْنِ بُرَيْدَةَ، عَنْ أَبِي الأَسْوَدِ، عَنْ أَبِي ذَرٍّ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ إِنَّ أَحْسَنَ مَا غُيِّرَ بِهِ الشَّيْبُ الْحِنَّاءُ وَالْكَتَمُ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَأَبُو الأَسْوَدِ الدِّيلِيُّ اسْمُهُ ظَالِمُ بْنُ عَمْرِو بْنِ سُفْيَانَ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Hasan,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأطعمة ۱۸ (۳۷۷۲)، سنن ابن ماجہ/الأطعمة ۱۲ (۳۲۷۷)، (تحفة الأشراف : ۵۵۶۶)، سنن الدارمی/الأطعمة ۱۶ (۲۰۹۰),,Narrated Abu Dharr:,The Book on Clothing
1806,حَدَّثَنَا حُمَيْدُ بْنُ مَسْعَدَةَ، حَدَّثَنَا عَبْدُ الْوَهَّابِ الثَّقَفِيُّ، عَنْ حُمَيْدٍ، عَنْ أَنَسٍ، قَالَ كَانَ رَسُولُ اللَّهِ صلى الله عليه وسلم رَبْعَةً لَيْسَ بِالطَّوِيلِ وَلاَ بِالْقَصِيرِ حَسَنَ الْجِسْمِ أَسْمَرَ اللَّوْنِ وَكَانَ شَعْرُهُ لَيْسَ بِجَعْدٍ وَلاَ سَبْطٍ إِذَا مَشَى يَتَكَفَّأُ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ عَائِشَةَ وَالْبَرَاءِ وَأَبِي هُرَيْرَةَ وَابْنِ عَبَّاسٍ وَأَبِي سَعِيدٍ وَجَابِرٍ وَوَائِلِ بْنِ حُجْرٍ وَأُمِّ هَانِئٍ ‏.‏ قَالَ أَبُو عِيسَى حَدِيثُ أَنَسٍ حَدِيثٌ حَسَنٌ صَحِيحٌ غَرِيبٌ مِنْ هَذَا الْوَجْهِ مِنْ حَدِيثِ حُمَيْدٍ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأذان ۱۶ (۸۵۴)، والأطعمة ۴۹ (۵۴۵۲)، والاعتصام ۲۴ (۷۳۵۹)، صحیح مسلم/المساجد ۱۷ (۵۶۴)، سنن ابی داود/ الأطعمة ۴۱ (۳۸۲۲)، سنن النسائی/المساجد ۱۶ (۷۰۸)، (تحفة الأشراف : ۲۴۴۷)، و مسند احمد (۳/۳۷۴، ۳۸۷),1806,Narrated Anas:,The Book on Clothing
1807,حَدَّثَنَا هَنَّادٌ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ أَبِي الزِّنَادِ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، قَالَتْ كُنْتُ أَغْتَسِلُ أَنَا وَرَسُولُ اللَّهِ، صلى الله عليه وسلم مِنْ إِنَاءٍ وَاحِدٍ وَكَانَ لَهُ شَعْرٌ فَوْقَ الْجُمَّةِ وَدُونَ الْوَفْرَةِ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ غَرِيبٌ مِنْ هَذَا الْوَجْهِ ‏.‏ وَقَدْ رُوِيَ مِنْ غَيْرِ وَجْهٍ عَنْ عَائِشَةَ أَنَّهَا قَالَتْ كُنْتُ أَغْتَسِلُ أَنَا وَرَسُولُ اللَّهِ صلى الله عليه وسلم مِنْ إِنَاءٍ وَاحِدٍ ‏.‏ وَلَمْ يَذْكُرُوا فِيهِ هَذَا الْحَرْفَ وَكَانَ لَهُ شَعْرٌ فَوْقَ الْجُمَّةِ وَدُونَ الْوَفْرَةِ ‏.‏ وَعَبْدُ الرَّحْمَنِ بْنُ أَبِي الزِّنَادِ ثِقَةٌ كَانَ مَالِكُ بْنُ أَنَسٍ يُوَثِّقُهُ وَيَأْمُرُ بِالْكِتَابَةِ عَنْهُ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۱۸۰۷),1807,Narrated 'Aishah:,The Book on Clothing
1808,حَدَّثَنَا عَلِيُّ بْنُ خَشْرَمٍ، أَخْبَرَنَا عِيسَى بْنُ يُونُسَ، عَنْ هِشَامٍ، عَنِ الْحَسَنِ، عَنْ عَبْدِ اللَّهِ بْنِ مُغَفَّلٍ، قَالَ نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم عَنِ التَّرَجُّلِ إِلاَّ غِبًّا ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأطعمة ۴۱ (۳۸۲۸)، (تحفة الأشراف : ۱۰۱۲۷),1808,Narrated 'Abdullah bin Mughaffal:,The Book on Clothing
1809,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، عَنْ هِشَامٍ، عَنِ الْحَسَنِ، بِهَذَا الإِسْنَادِ نَحْوَهُ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ أَنَسٍ ‏.‏,Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: (تحفة الأشراف : ۱۰۱۲۷),1809,Another chain with similar meaning.\n\n\n[Abu 'Eisa said:,The Book on Clothing
1810,"حَدَّثَنَا مُحَمَّدُ بْنُ حُمَيْدٍ، حَدَّثَنَا أَبُو دَاوُدَ، - هُوَ الطَّيَالِسِيُّ عَنْ عَبَّادِ بْنِ مَنْصُورٍ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ النَّبِيَّ صلى الله عليه وسلم قَالَ ‏""‏ اكْتَحِلُوا بِالإِثْمِدِ فَإِنَّهُ يَجْلُو الْبَصَرَ وَيُنْبِتُ الشَّعْرَ ‏""‏ ‏.‏ وَزَعَمَ أَنَّ النَّبِيَّ صلى الله عليه وسلم كَانَتْ لَهُ مُكْحُلَةٌ يَكْتَحِلُ بِهَا كُلَّ لَيْلَةٍ ثَلاَثَةً فِي هَذِهِ وَثَلاَثَةً فِي هَذِهِ ‏.‏ وَقَدْ رُوِيَ مِنْ غَيْرِ وَجْهٍ عَنِ النَّبِيِّ صلى الله عليه وسلم أَنَّهُ قَالَ ‏""‏ عَلَيْكُمْ بِالإِثْمِدِ فَإِنَّهُ يَجْلُو الْبَصَرَ وَيُنْبِتُ الشَّعْرَ ‏""‏ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ جَابِرٍ وَابْنِ عُمَرَ ‏.‏ قَالَ أَبُو عِيسَى حَدِيثُ ابْنِ عَبَّاسٍ حَدِيثٌ حَسَنٌ لاَ نَعْرِفُهُ عَلَى هَذَا اللَّفْظِ إِلاَّ مِنْ حَدِيثِ عَبَّادِ بْنِ مَنْصُورٍ ‏.‏",Ahmad Muhammad Shakir: Hasan; Al-Albani: Hasan; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: سنن ابن ماجہ/الأطعمة ۵۹ (۳۳۶۴)، (تحفة الأشراف : ۱۸۳۰۴),1810,Narrated Ibn 'Abbas:,The Book on Clothing
1811,"حَدَّثَنَا عَلِيُّ بْنُ حُجْرٍ، وَمُحَمَّدُ بْنُ يَحْيَى، قَالاَ حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، عَنْ عَبَّادِ بْنِ مَنْصُورٍ، نَحْوَهُ ‏.‏ وَقَدْ رُوِيَ مِنْ غَيْرِ وَجْهٍ عَنْ النَّبِيِّ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ قَالَ عَلَيْكُمْ بِالْإِثْمِدِ فَإِنَّهُ يَجْلُو الْبَصَرَ وَيُنْبِتُ الشَّعْرَ""",Ahmad Muhammad Shakir: Daif Isnaad Maqtu; Al-Albani: Daif Isnaad Maqtu; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف، (تحفة الأشراف : ۱۸۶۴۶),,It has been reported through other routed that the Prophet (ﷺ) said:,The Book on Clothing
1812,حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا يَعْقُوبُ بْنُ عَبْدِ الرَّحْمَنِ الإِسْكَنْدَرَانِيُّ، عَنْ سُهَيْلِ بْنِ أَبِي صَالِحٍ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ النَّبِيَّ صلى الله عليه وسلم نَهَى عَنْ لُبْسَتَيْنِ الصَّمَّاءِ وَأَنْ يَحْتَبِيَ الرَّجُلُ بِثَوْبِهِ لَيْسَ عَلَى فَرْجِهِ مِنْهُ شَيْءٌ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ عَلِيٍّ وَابْنِ عُمَرَ وَعَائِشَةَ وَأَبِي سَعِيدٍ وَجَابِرٍ وَأَبِي أُمَامَةَ ‏.‏ وَحَدِيثُ أَبِي هُرَيْرَةَ حَسَنٌ صَحِيحٌ غَرِيبٌ مِنْ هَذَا الْوَجْهِ وَقَدْ رُوِيَ هَذَا مِنْ غَيْرِ وَجْهٍ عَنْ أَبِي هُرَيْرَةَ عَنِ النَّبِيِّ صلى الله عليه وسلم ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح البخاری/بدء الخلق ۶ (۲۲۳۱۶)، والأشربة ۲۲ (۵۶۲۳، ۵۶۲۴)، والاستئذان ۴۹ (۶۲۹۵)، صحیح مسلم/الأشربة ۱۲ (۲۰۱۲)، سنن ابی داود/ الأشربة ۲۲ (۳۷۳۱-۳۷۳۴)، سنن ابن ماجہ/الأشربة ۱۶ (۳۴۱۰)، والأدب ۴۶ (۳۷۷۱)، (تحفة الأشراف : ۲۹۳۴)، و مسند احمد (۳/۳۵۵)، ویأتي برقم ۲۸۵۷,1812,Narrated Abu Hurairah:,The Book on Clothing
1813,"حَدَّثَنَا سُوَيْدُ بْنُ نَصْرٍ، أَخْبَرَنَا عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ، عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ النَّبِيَّ صلى الله عليه وسلم قَالَ ‏ ‏ لَعَنَ اللَّهُ الْوَاصِلَةَ وَالْمُسْتَوْصِلَةَ وَالْوَاشِمَةَ وَالْمُسْتَوْشِمَةَ ‏""""‏ ‏.‏ قَالَ نَافِعٌ الْوَشْمُ فِي اللَّثَةِ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ عَائِشَةَ وَابْنِ مَسْعُودٍ وَأَسْمَاءَ بِنْتِ أَبِي بَكْرٍ وَابْنِ عَبَّاسٍ وَمَعْقِلِ بْنِ يَسَارٍ وَمُعَاوِيَةَ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الاستئذان ۴۹ (۶۲۴۳)، صحیح مسلم/الأشربة ۱۲ (۲۰۱۵)، سنن ابی داود/ الأدب ۱۷۳ (۵۲۴۶)، سنن ابن ماجہ/الأدب ۴۶ (۳۷۶۹)، (تحفة الأشراف : ۶۸۱۴),,Narrated Ibn 'Umar:,The Book on Clothing
1814,حَدَّثَنَا عَلِيُّ بْنُ حُجْرٍ، أَخْبَرَنَا عَلِيُّ بْنُ مُسْهِرٍ، حَدَّثَنَا أَبُو إِسْحَاقَ الشَّيْبَانِيُّ، عَنْ أَشْعَثَ بْنِ أَبِي الشَّعْثَاءِ، عَنْ مُعَاوِيَةَ بْنِ سُوَيْدِ بْنِ مُقَرِّنٍ، عَنِ الْبَرَاءِ بْنِ عَازِبٍ، قَالَ نَهَانَا رَسُولُ اللَّهِ صلى الله عليه وسلم عَنْ رُكُوبِ الْمَيَاثِرِ ‏.‏ قَالَ وَفِي الْحَدِيثِ قِصَّةٌ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ عَلِيٍّ وَمُعَاوِيَةَ ‏.‏ وَحَدِيثُ الْبَرَاءِ حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَقَدْ رَوَى شُعْبَةُ عَنْ أَشْعَثَ بْنِ أَبِي الشَّعْثَاءِ نَحْوَهُ وَفِي الْحَدِيثِ قِصَّةٌ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الشرکة ۴ (۲۴۹۰)، صحیح مسلم/الأشربة ۲۵ (۲۰۴۵)، سنن ابی داود/ الأطعمة ۴۴ (۳۸۳۴)، سنن ابن ماجہ/الأطعمة ۴۱ (۳۳۳۱)، (تحفة الأشراف : ۶۶۶۷)، و مسند احمد (۲/۶۰)، سنن الدارمی/الأطعمة ۲۵ (۲۱۰۳),1814,Narrated Al-Bara' bin 'Azib:,The Book on Clothing
1815,حَدَّثَنَا عَلِيُّ بْنُ حُجْرٍ، أَخْبَرَنَا عَلِيُّ بْنُ مُسْهِرٍ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، قَالَتْ إِنَّمَا كَانَ فِرَاشُ النَّبِيِّ صلى الله عليه وسلم الَّذِي يَنَامُ عَلَيْهِ أَدَمٌ حَشْوُهُ لِيفٌ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ حَفْصَةَ وَجَابِرٍ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/الأشربة ۲۶ (۲۰۴۶)، سنن ابی داود/ الأطعمة ۴۲ (۳۸۳۰)، سنن ابن ماجہ/الأطعمة ۲۸ (۳۳۲۷)، (تحفة الأشراف : ۱۶۹۴۲)، سنن الدارمی/الأطعمة ۲۶ (۲۱۰۵),1815,Narrated 'Aishah:,The Book on Clothing
1816,حَدَّثَنَا مُحَمَّدُ بْنُ حُمَيْدٍ الرَّازِيُّ، حَدَّثَنَا أَبُو تُمَيْلَةَ، وَالْفَضْلُ بْنُ مُوسَى، وَزَيْدُ بْنُ حُبَابٍ، عَنْ عَبْدِ الْمُؤْمِنِ بْنِ خَالِدٍ، عَنْ عَبْدِ اللَّهِ بْنِ بُرَيْدَةَ، عَنْ أُمِّ سَلَمَةَ، قَالَتْ كَانَ أَحَبَّ الثِّيَابِ إِلَى النَّبِيِّ صلى الله عليه وسلم الْقَمِيصُ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ غَرِيبٌ إِنَّمَا نَعْرِفُهُ مِنْ حَدِيثِ عَبْدِ الْمُؤْمِنِ بْنِ خَالِدٍ تَفَرَّدَ بِهِ وَهُوَ مَرْوَزِيٌّ ‏.‏ وَرَوَى بَعْضُهُمْ هَذَا الْحَدِيثَ عَنْ أَبِي تُمَيْلَةَ عَنْ عَبْدِ الْمُؤْمِنِ بْنِ خَالِدٍ عَنْ عَبْدِ اللَّهِ بْنِ بُرَيْدَةَ عَنْ أُمِّهِ عَنْ أُمِّ سَلَمَةَ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/الذکر والدعاء ۲۴ (۲۷۳۴)، (تحفة الأشراف : ۸۵۷)، و مسند احمد (۳/۱۰۰، ۱۱۷),1816,Narrated Umm Salamah:,The Book on Clothing
1817,"حَدَّثَنَا زِيَادُ بْنُ أَيُّوبَ الْبَغْدَادِيُّ، حَدَّثَنَا أَبُو تُمَيْلَةَ، عَنْ عَبْدِ الْمُؤْمِنِ بْنِ خَالِدٍ، عَنْ عَبْدِ اللَّهِ بْنِ بُرَيْدَةَ، عَنْ أُمِّهِ، عَنْ أُمِّ سَلَمَةَ، قَالَتْ كَانَ أَحَبَّ الثِّيَابِ إِلَى النَّبِيِّ صلى الله عليه وسلم الْقَمِيصُ ‏.‏ قَالَ وَسَمِعْت مُحَمَّدَ بْنَ إِسْمَعِيلَ يَقُولُ حَدِيثُ عَبْدِ اللَّهِ بْنِ بُرَيْدَةَ عَنْ أُمِّهِ عَنْ أُمِّ سَلَمَةَ أَصَحُّ وَإِنَّمَا يُذْكَرُ فِيهِ أَبُو تُمَيْلَةَ عَنْ أُمِّهِ""",Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الطب ۳۴ (۳۹۲۵)، سنن ابن ماجہ/الطب ۴۴ (۳۵۴۲)، (تحفة الأشراف : ۳۰۱۰),,Narrated Umm Salamah:,The Book on Clothing
1818,حَدَّثَنَا عَلِيُّ بْنُ حُجْرٍ، أَخْبَرَنَا الْفَضْلُ بْنُ مُوسَى، عَنْ عَبْدِ الْمُؤْمِنِ بْنِ خَالِدٍ، عَنْ عَبْدِ اللَّهِ بْنِ بُرَيْدَةَ، عَنْ أُمِّ سَلَمَةَ، قَالَتْ كَانَ أَحَبَّ الثِّيَابِ إِلَى رَسُولِ اللَّهِ صلى الله عليه وسلم الْقَمِيصُ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأطعمة ۱۲ (۵۳۹۳-۵۳۹۵)، صحیح مسلم/الأشربة ۳۴ (۲۰۶۰)، سنن ابن ماجہ/الأطعمة ۳ (۳۲۵۷)، (تحفة الأشراف : ۸۱۵۶)، و مسند احمد (۲/۲۱، ۴۳، ۷۴، ۱۴۵),1818,Narrated Umm Salamah:,The Book on Clothing
1819,حَدَّثَنَا عَبْدُ اللَّهِ بْنُ مُحَمَّدِ بْنِ الْحَجَّاجِ الصَّوَّافُ الْبَصْرِيُّ، حَدَّثَنَا مُعَاذُ بْنُ هِشَامٍ الدَّسْتَوَائِيُّ، حَدَّثَنِي أَبِي، عَنْ بُدَيْلِ بْنِ مَيْسَرَةَ الْعُقَيْلِيِّ، عَنْ شَهْرِ بْنِ حَوْشَبٍ، عَنْ أَسْمَاءَ بِنْتِ يَزِيدَ بْنِ السَّكَنِ الأَنْصَارِيَّةِ، قَالَتْ كَانَ كُمُّ يَدِ رَسُولِ اللَّهِ صلى الله عليه وسلم إِلَى الرُّسْغِ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ غَرِيبٌ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأطعمة ۱۲ (۵۳۹۶-۵۳۹۷)، صحیح مسلم/الأشربة ۳۴ (۲۰۶۳)، سنن ابن ماجہ/الأطعمة ۳ (۳۲۵۶)، (تحفة الأشراف : ۱۲۷۳۹)، وط/صفة النبيﷺ ۶ (۹، ۱۰)، مسند احمد (۲/۳۷۵، ۲۵۷، ۴۱۵، ۴۳۵، ۴۳۷، ۴۵۵)، سنن الدارمی/الأطعمة ۱۳ (۲۰۸۴),1819,Narrated Asma' bint Yazid bin As-Sakan Al-Ansariyyah:,The Book on Clothing
1820,حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ، حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ، حَدَّثَنَا شُعْبَةُ، عَنِ الأَعْمَشِ، عَنْ أَبِي صَالِحٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ كَانَ رَسُولُ اللَّهِ صلى الله عليه وسلم إِذَا لَبِسَ قَمِيصًا بَدَأَ بِمَيَامِنِهِ ‏.‏ قَالَ أَبُو عِيسَى وَرَوَى غَيْرُ وَاحِدٍ هَذَا الْحَدِيثَ عَنْ شُعْبَةَ بِهَذَا الإِسْنَادِ عَنْ أَبِي هُرَيْرَةَ مَوْقُوفًا وَلاَ نَعْلَمُ أَحَدًا رَفَعَهُ غَيْرَ عَبْدِ الصَّمَدِ بْنِ عَبْدِ الْوَارِثِ عَنْ شُعْبَةَ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأطعمة ۱۱ (۵۳۹۲)، صحیح مسلم/الأشربة ۳۳ (۲۰۵۸)، و مسند احمد (۲/۴۰۷),1820,Narrated Abu Hurairah:,The Book on Clothing
1821,"حَدَّثَنَا سُوَيْدُ بْنُ نَصْرٍ، أَخْبَرَنَا عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ، عَنْ سَعِيدٍ الْجُرَيْرِيِّ، عَنْ أَبِي نَضْرَةَ، عَنْ أَبِي سَعِيدٍ، قَالَ كَانَ رَسُولُ اللَّهِ صلى الله عليه وسلم إِذَا اسْتَجَدَّ ثَوْبًا سَمَّاهُ بِاسْمِهِ عِمَامَةً أَوْ قَمِيصًا أَوْ رِدَاءً ثُمَّ يَقُولُ ‏ ‏ اللَّهُمَّ لَكَ الْحَمْدُ أَنْتَ كَسَوْتَنِيهِ أَسْأَلُكَ خَيْرَهُ وَخَيْرَ مَا صُنِعَ لَهُ وَأَعُوذُ بِكَ مِنْ شَرِّهِ وَشَرِّ مَا صُنِعَ لَهُ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ عُمَرَ وَابْنِ عُمَرَ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الصید ۱۳ (۵۴۹۵)، صحیح مسلم/الصید ۸ (۱۹۲۲)، سنن ابی داود/ الأطعمة ۳۵ (۳۸۱۲)، سنن النسائی/الصید ۳۷ (۴۳۶۱)، (تحفة الأشراف : ۵۱۸۲)، و مسند احمد (۴/۳۵۳، ۳۵۷، ۳۸۰)، وسنن الدارمی/الصید ۵ (۲۰۵۳),,Narrated Abu Sa'eed:,The Book on Clothing
1822,حَدَّثَنَا هِشَامُ بْنُ يُونُسَ الْكُوفِيُّ، حَدَّثَنَا الْقَاسِمُ بْنُ مَالِكٍ الْمُزَنِيُّ، عَنِ الْجُرَيْرِيِّ، نَحْوَهُ ‏.‏ وَهَذَا حَدِيثٌ حَسَنٌ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: انظر ما قبلہ,1822,,The Book on Clothing
1823,حَدَّثَنَا يُوسُفُ بْنُ عِيسَى، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا يُونُسُ بْنُ أَبِي إِسْحَاقَ، عَنِ الشَّعْبِيِّ، عَنْ عُرْوَةَ بْنِ الْمُغِيرَةِ بْنِ شُعْبَةَ، عَنْ أَبِيهِ، أَنَّ النَّبِيَّ صلى الله عليه وسلم لَبِسَ جُبَّةً رُومِيَّةً ضَيِّقَةَ الْكُمَّيْنِ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏,Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: سنن ابن ماجہ/الصید ۹ (۳۲۲۱)، (تحفة الأشراف : ۱۴۵۱، ۲۵۸۵),1823,Narrated 'Urwah bin Al-Mugirah bin Shu'bah:,The Book on Clothing
1824,حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا ابْنُ أَبِي زَائِدَةَ، عَنِ الْحَسَنِ بْنِ عَيَّاشٍ، عَنْ أَبِي إِسْحَاقَ، هُوَ الشَّيْبَانِيُّ عَنِ الشَّعْبِيِّ، قَالَ قَالَ الْمُغِيرَةُ بْنُ شُعْبَةَ أَهْدَى دِحْيَةُ الْكَلْبِيُّ لِرَسُولِ اللَّهِ صلى الله عليه وسلم خُفَّيْنِ فَلَبِسَهُمَا ‏.‏ قَالَ أَبُو عِيسَى وَقَالَ إِسْرَائِيلُ عَنْ جَابِرٍ عَنْ عَامِرٍ وَجُبَّةً فَلَبِسَهُمَا حَتَّى تَخَرَّقَا لاَ يَدْرِي النَّبِيُّ صلى الله عليه وسلم أَذَكِيٌّ هُمَا أَمْ لاَ ‏.‏ وَهَذَا حَدِيثٌ حَسَنٌ غَرِيبٌ ‏.‏ أَبُو إِسْحَاقَ الَّذِي رَوَى هَذَا عَنِ الشَّعْبِيِّ هُوَ أَبُو إِسْحَاقَ الشَّيْبَانِيُّ وَاسْمُهُ سُلَيْمَانُ وَالْحَسَنُ بْنُ عَيَّاشٍ هُوَ أَخُو أَبِي بَكْرِ بْنِ عَيَّاشٍ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأطعمة ۲۵ (۳۷۸۵)، سنن ابن ماجہ/الذبائح ۱۱ (۳۱۸۵)، (تحفة الأشراف : ۷۳۸۷),1824,Narrated Ash-Sha'bi:,The Book on Clothing
1825,حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا عَلِيُّ بْنُ هَاشِمِ بْنِ الْبَرِيدِ، وَأَبُو سَعْدٍ الصَّغَانِيُّ عَنْ أَبِي الأَشْهَبِ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ طَرَفَةَ، عَنْ عَرْفَجَةَ بْنِ أَسْعَدَ، قَالَ أُصِيبَ أَنْفِي يَوْمَ الْكُلاَبِ فِي الْجَاهِلِيَّةِ فَاتَّخَذْتُ أَنْفًا مِنْ وَرِقٍ فَأَنْتَنَ عَلَىَّ فَأَمَرَنِي رَسُولُ اللَّهِ صلى الله عليه وسلم أَنْ أَتَّخِذَ أَنْفًا مِنْ ذَهَبٍ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأشربة ۲۴ (۵۶۲۹)، سنن ابی داود/ الأشربة ۱۴ (۳۷۱۹)، سنن النسائی/الضحایا ۴۴ (۴۴۵۳)، سنن ابن ماجہ/الأشربة ۲۰ (۳۴۲۱)، (تحفة الأشراف : ۶۱۹۰)، و مسند احمد (۱/۲۲۶، ۲۴۱، ۳۳۹) سنن الدارمی/الأضاحي ۱۳ (۲۰۱۸),1825,Narrated 'Urfajah bin As'ad:,The Book on Clothing
1826,حَدَّثَنَا عَلِيُّ بْنُ حُجْرٍ، حَدَّثَنَا الرَّبِيعُ بْنُ بَدْرٍ، وَمُحَمَّدُ بْنُ يَزِيدَ الْوَاسِطِيُّ، عَنْ أَبِي الأَشْهَبِ، نَحْوَهُ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ غَرِيبٌ إِنَّمَا نَعْرِفُهُ مِنْ حَدِيثِ عَبْدِ الرَّحْمَنِ بْنِ طَرَفَةَ ‏.‏ وَقَدْ رَوَى سَلْمُ بْنُ زَرِيرٍ عَنْ عَبْدِ الرَّحْمَنِ بْنِ طَرَفَةَ نَحْوَ حَدِيثِ أَبِي الأَشْهَبِ ‏.‏ وَقَدْ رُوِيَ عَنْ غَيْرِ وَاحِدٍ مِنْ أَهْلِ الْعِلْمِ أَنَّهُمْ شَدُّوا أَسْنَانَهُمْ بِالذَّهَبِ وَفِي هَذَا الْحَدِيثِ حُجَّةٌ لَهُمْ ‏.‏ وَقَالَ عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ سَلْمُ بْنُ رَزِينٍ وَهُوَ وَهَمٌ وَأَبُو سَعْدٍ الصَّغَانِيُّ اسْمُهُ مُحَمَّدُ بْنُ مُيَسَّرٍ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/المغازي ۷۴ (۴۳۸۵)، والصید ۲۶ (۵۵۱۷، ۵۵۱۸)، و کفارات الأیمان ۱۰ (۶۷۲۱)، صحیح مسلم/الأیمان ۳ (۱۶۴۹/۹)، سنن النسائی/الصید ۳۳ (۴۳۵۱)، (تحفة الأشراف : ۸۹۹۰),1826,Another chain with similar meaning.\n\n\n[Abu 'Eisa said:,The Book on Clothing
1827,حَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا ابْنُ الْمُبَارَكِ، وَمُحَمَّدُ بْنُ بِشْرٍ، وَعَبْدُ اللَّهِ بْنُ إِسْمَاعِيلَ بْنِ أَبِي خَالِدٍ، عَنْ سَعِيدِ بْنِ أَبِي عَرُوبَةَ، عَنْ قَتَادَةَ، عَنْ أَبِي الْمَلِيحِ، عَنْ أَبِيهِ، أَنَّ النَّبِيَّ صلى الله عليه وسلم نَهَى عَنْ جُلُودِ السِّبَاعِ أَنْ تُفْتَرَشَ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأطعمة ۲۹ (۳۷۹۷)، (تحفة الأشراف : ۴۴۸۲),1827,Narrated Abu Al-Malih:,The Book on Clothing
1828,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، حَدَّثَنَا سَعِيدٌ، عَنْ قَتَادَةَ، عَنْ أَبِي الْمَلِيحِ، عَنْ أَبِيهِ، أَنَّ النَّبِيَّ صلى الله عليه وسلم نَهَى عَنْ جُلُودِ السِّبَاعِ ‏.‏,Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Takhreej-Group: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: (ضعیف) (سند میں ابراہیم بن عمر بن سفینہ جن کا لقب بریہ ہے، مستور ہیں، اور ابراہیم بن عبدالرحمن بن مہدی بصری صدوق راوی ہیں، لیکن ان سے منکر روایات آئی ہیں),1828,Another chain from Abu Al-Malih from his father:,The Book on Clothing
1829,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُعَاذُ بْنُ هِشَامٍ، حَدَّثَنِي أَبِي، عَنْ قَتَادَةَ، عَنْ أَبِي الْمَلِيحِ، أَنَّهُ كَرِهَ جُلُودَ السِّبَاعِ ‏.‏ قَالَ أَبُو عِيسَى وَلاَ نَعْلَمُ أَحَدًا قَالَ عَنْ أَبِي الْمَلِيحِ، عَنْ أَبِيهِ، غَيْرَ سَعِيدِ بْنِ أَبِي عَرُوبَةَ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (أخرجہ النسائي في الکبریٰ) (تحفة الأشراف : ۱۸۲۰۰),1829,"Another chain from Abu Al-Malik, that he (ﷺ) disliked predator skins. Abu 'Eisa said:",The Book on Clothing
1830,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، حَدَّثَنَا شُعْبَةُ، عَنْ يَزِيدَ الرِّشْكِ، عَنْ أَبِي الْمَلِيحِ، عَنِ النَّبِيِّ صلى الله عليه وسلم أَنَّهُ نَهَى عَنْ جُلُودِ السِّبَاعِ ‏.‏ وَهَذَا أَصَحُّ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأطعمة ۱۳ (۵۳۹۸)، سنن ابی داود/ الأطعمة ۱۷ (۳۷۶۹)، سنن ابن ماجہ/الأطعمة ۶ (۳۲۶۲)، (تحفة الأشراف : ۱۱۸۰۱)، و مسند احمد (۴/۳۰۸)، سنن الدارمی/الأطعمة ۳۱ (۲۱۱۵),1830,Narrated Abu Al-Malih:,The Book on Clothing
1831,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا أَبُو دَاوُدَ، حَدَّثَنَا هَمَّامٌ، عَنْ قَتَادَةَ، قَالَ قُلْتُ لأَنَسِ بْنِ مَالِكٍ كَيْفَ كَانَ نَعْلُ رَسُولِ اللَّهِ صلى الله عليه وسلم قَالَ لَهُمَا قِبَالاَنِ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأطعمة ۳۲ (۵۴۳۱)، والأشربة ۱۰ (۵۵۹۹)، و ۱۵ (۵۶۱۴)، والطب ۴ (۵۶۸۲)، والحیل ۱۲ (۶۹۷۲)، صحیح مسلم/الطلاق ۳ (۱۴۷۴)، سنن ابی داود/ الأشربة ۱۱ (۳۷۱۵)، سنن ابن ماجہ/الأطعمة ۳۶ (۳۳۲۳)، (تحفة الأشراف : ۱۶۷۹۶)، و مسند احمد (۶/۵۹),1831,Narrated Qatadah:,The Book on Clothing
1832,حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ، أَخْبَرَنَا حِبَّانُ بْنُ هِلاَلٍ، حَدَّثَنَا هَمَّامٌ، حَدَّثَنَا قَتَادَةُ، عَنْ أَنَسٍ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم كَانَ نَعْلاَهُ لَهُمَا قِبَالاَنِ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ قَالَ وَفِي الْبَابِ عَنِ ابْنِ عَبَّاسٍ وَأَبِي هُرَيْرَةَ ‏.‏,Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۸۹۷۴),1832,Narrated Qatadah:,The Book on Clothing
1833,"حَدَّثَنَا قُتَيْبَةُ، عَنْ مَالِكٍ، ح وَحَدَّثَنَا الأَنْصَارِيُّ، حَدَّثَنَا مَعْنٌ، حَدَّثَنَا مَالِكٌ، عَنْ أَبِي الزِّنَادِ، عَنِ الأَعْرَجِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ لاَ يَمْشِي أَحَدُكُمْ فِي نَعْلٍ وَاحِدَةٍ لِيُنْعِلْهُمَا جَمِيعًا أَوْ لِيُحْفِهِمَا جَمِيعًا ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ جَابِرٍ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: صحیح مسلم/البر و الصلة ۴۲ (۲۶۲۵/۱۴۲)، سنن ابن ماجہ/الأطعمة ۵۸ (۳۳۶۲)، (تحفة الأشراف : ۱۱۹۵۱)، و مسند احمد (۵/۱۴۹، ۱۵۶، ۱۶۱، ۱۷۱),,Narrated Abu Hurairah:,The Book on Clothing
1834,حَدَّثَنَا أَزْهَرُ بْنُ مَرْوَانَ الْبَصْرِيُّ، حَدَّثَنَا الْحَارِثُ بْنُ نَبْهَانَ، عَنْ مَعْمَرٍ، عَنْ عَمَّارِ بْنِ أَبِي عَمَّارٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم أَنْ يَنْتَعِلَ الرَّجُلُ وَهُوَ قَائِمٌ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ غَرِيبٌ ‏.‏ وَرَوَى عُبَيْدُ اللَّهِ بْنُ عَمْرٍو الرَّقِّيُّ هَذَا الْحَدِيثَ عَنْ مَعْمَرٍ عَنْ قَتَادَةَ عَنْ أَنَسٍ وَكِلاَ الْحَدِيثَيْنِ لاَ يَصِحُّ عِنْدَ أَهْلِ الْحَدِيثِ ‏.‏ وَالْحَارِثُ بْنُ نَبْهَانَ لَيْسَ عِنْدَهُمْ بِالْحَافِظِ وَلاَ نَعْرِفُ لِحَدِيثِ قَتَادَةَ عَنْ أَنَسٍ أَصْلاً ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/أحادیث الأنبیاء ۳۲ (۳۴۱۱)، و ۴۶ (۳۴۳۳)، وفضائل الصحابة ۳۰ (۳۷۶۹)، والأطعمة ۲۵ (۵۴۱۸)، صحیح مسلم/فضائل الصحابة ۱۲ (۲۴۳۱),1834,Narrated Abu Hurairah:,The Book on Clothing
1835,حَدَّثَنَا أَبُو جَعْفَرٍ السِّمْنَانِيُّ، حَدَّثَنَا سُلَيْمَانُ بْنُ عُبَيْدِ اللَّهِ الرَّقِّيُّ، حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ عَمْرٍو الرَّقِّيُّ، عَنْ مَعْمَرٍ، عَنْ قَتَادَةَ، عَنْ أَنَسٍ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم نَهَى أَنْ يَنْتَعِلَ الرَّجُلُ وَهُوَ قَائِمٌ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ غَرِيبٌ ‏.‏ وَقَالَ مُحَمَّدُ بْنُ إِسْمَاعِيلَ وَلاَ يَصِحُّ هَذَا الْحَدِيثُ وَلاَ حَدِيثُ مَعْمَرٍ عَنْ عَمَّارِ بْنِ أَبِي عَمَّارٍ عَنْ أَبِي هُرَيْرَةَ ‏.‏,Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف، (تحفة الأشراف : ۴۹۴۷),1835,Narrated Anas:,The Book on Clothing
1836,حَدَّثَنَا الْقَاسِمُ بْنُ دِينَارٍ، حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ السَّلُولِيُّ، كُوفِيٌّ حَدَّثَنَا هُرَيْمُ بْنُ سُفْيَانَ الْبَجَلِيُّ الْكُوفِيُّ، عَنْ لَيْثٍ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، قَالَتْ رُبَّمَا مَشَى النَّبِيُّ صلى الله عليه وسلم فِي نَعْلٍ وَاحِدَةٍ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الوضوء ۵ (۲۰۸)، والأذان ۴۳ (۶۷۵)، والجہاد ۹۲ (۲۹۲۳)، والأطعمة ۲۰ (۵۴۰۸)، و ۲۶ (۵۴۲۲)، و ۵۸ (۵۴۶۲)، صحیح مسلم/الحیض ۲۴ (۳۵۵)، سنن ابن ماجہ/الطہارة ۶۶ (۴۹۰)، (تحفة الأشراف : ۱۰۷۰)، و مسند احمد (۴/۱۳۹، ۱۷۹) و (۵/۲۸۸),1836,Narrated 'Aishah:,The Book on Clothing
1837,حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، أَنَّهَا مَشَتْ بِنَعْلٍ وَاحِدَةٍ ‏.‏ وَهَذَا أَصَحُّ ‏.‏ قَالَ أَبُو عِيسَى وَهَكَذَا رَوَاهُ سُفْيَانُ الثَّوْرِيُّ وَغَيْرُ وَاحِدٍ عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ مَوْقُوفًا وَهَذَا أَصَحُّ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/أحادیث الأنبیاء ۳ (۳۳۴۰)، وتفسیر الإسراء ۵ (۴۷۱۲)، صحیح مسلم/الإیمان ۸۴ (۱۹۴)، سنن ابن ماجہ/الأطعمة ۲۸ (۳۳۰۷)، ویأتي عند المؤلف في صفة القیامة ۱۰ (۲۴۳۴)، (تحفة الأشراف : ۱۴۹۲۷),1837,Narrated 'Abdur-Rahman bin Al-Qasim:,The Book on Clothing
1838,"حَدَّثَنَا الأَنْصَارِيُّ، حَدَّثَنَا مَعْنٌ، حَدَّثَنَا مَالِكٌ، ح وَحَدَّثَنَا قُتَيْبَةُ، عَنْ مَالِكٍ، عَنْ أَبِي الزِّنَادِ، عَنِ الأَعْرَجِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ إِذَا انْتَعَلَ أَحَدُكُمْ فَلْيَبْدَأْ بِالْيَمِينِ وَإِذَا نَزَعَ فَلْيَبْدَأْ بِالشِّمَالِ فَلْتَكُنِ الْيُمْنَى أَوَّلَهُمَا تُنْعَلُ وَآخِرَهُمَا تُنْزَعُ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏""",Ahmad Muhammad Shakir: Munkar; Al-Albani: Munkar; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۱۶۱۹۴),,Narrated Abu Hurairah:,The Book on Clothing
1839,"حَدَّثَنَا يَحْيَى بْنُ مُوسَى، حَدَّثَنَا سَعِيدُ بْنُ مُحَمَّدٍ الْوَرَّاقُ، وَأَبُو يَحْيَى الْحِمَّانِيُّ قَالاَ حَدَّثَنَا صَالِحُ بْنُ حَسَّانَ، عَنْ عُرْوَةَ، عَنْ عَائِشَةَ، قَالَتْ قَالَ لِي رَسُولُ اللَّهِ صلى الله عليه وسلم ‏""‏ إِذَا أَرَدْتِ اللُّحُوقَ بِي فَلْيَكْفِيكِ مِنَ الدُّنْيَا كَزَادِ الرَّاكِبِ وَإِيَّاكِ وَمُجَالَسَةَ الأَغْنِيَاءِ وَلاَ تَسْتَخْلِقِي ثَوْبًا حَتَّى تُرَقِّعِيهِ ‏""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ غَرِيبٌ لاَ نَعْرِفُهُ إِلاَّ مِنْ حَدِيثِ صَالِحِ بْنِ حَسَّانَ ‏.‏ قَالَ وَسَمِعْتُ مُحَمَّدًا يَقُولُ صَالِحُ بْنُ حَسَّانَ مُنْكَرُ الْحَدِيثِ وَصَالِحُ بْنُ أَبِي حَسَّانَ الَّذِي رَوَى عَنْهُ ابْنُ أَبِي ذِئْبٍ ثِقَةٌ ‏.‏ قَالَ أَبُو عِيسَى وَمَعْنَى قَوْلِهِ ‏""‏ وَإِيَّاكِ وَمُجَالَسَةَ الأَغْنِيَاءِ ‏""‏ ‏.‏ هُوَ نَحْوُ مَا رُوِيَ عَنْ أَبِي هُرَيْرَةَ عَنِ النَّبِيِّ صلى الله عليه وسلم أَنَّهُ قَالَ ‏""‏ مَنْ رَأَى مَنْ فُضِّلَ عَلَيْهِ فِي الْخَلْقِ وَالرِّزْقِ فَلْيَنْظُرْ إِلَى مَنْ هُوَ أَسْفَلُ مِنْهُ مِمَّنْ فُضِّلَ هُوَ عَلَيْهِ فَإِنَّهُ أَجْدَرُ أَنْ لاَ يَزْدَرِيَ نِعْمَةَ اللَّهِ عَلَيْهِ ‏""‏ ‏.‏ وَيُرْوَى عَنْ عَوْنِ بْنِ عَبْدِ اللَّهِ بْنِ عُتْبَةَ قَالَ صَحِبْتُ الأَغْنِيَاءَ فَلَمْ أَرَ أَحَدًا أَكْثَرَ هَمًّا مِنِّي أَرَى دَابَّةً خَيْرًا مِنْ دَابَّتِي وَثَوْبًا خَيْرًا مِنْ ثَوْبِي وَصَحِبْتُ الْفُقَرَاءَ فَاسْتَرَحْتُ ‏.‏",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: صحیح مسلم/الأشربة ۳۰ (۲۰۵۲)، سنن ابی داود/ الأطعمة ۴۰ (۳۸۲۰)، سنن النسائی/الأیمان ۲۱ (۳۸۲۷)، سنن ابن ماجہ/الأطعمة ۳۳ (۳۳۱۷)، (تحفة الأشراف : ۲۷۵۸)، و مسند احمد ۳/۳۰۴، ۳۷۱، ۳۸۹، ۳۹۰)، سنن الدارمی/الأطعمة ۱۸ (۲۰۹۲),1839,Narrated 'Aishah:,The Book on Clothing
1840,حَدَّثَنِي ابْنُ أَبِي عُمَرَ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ ابْنِ أَبِي نَجِيحٍ، عَنْ مُجَاهِدٍ، عَنْ أُمِّ هَانِئٍ، قَالَتْ قَدِمَ رَسُولُ اللَّهِ صلى الله عليه وسلم مَكَّةَ وَلَهُ أَرْبَعُ غَدَائِرَ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ غَرِيبٌ ‏.‏ قَالَ مُحَمَّدٌ لاَ أَعْرِفُ لِمُجَاهِدٍ سَمَاعًا مِنْ أُمِّ هَانِئٍ ‏.‏,Ahmad Muhammad Shakir: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/الأشربة ۳۰ (۲۰۵۱)، سنن ابن ماجہ/الأطعمة ۳۳ (۳۳۱۶)، (تحفة الأشراف : ۱۶۹۴۳),1840,Narrated Umm Hani:,The Book on Clothing
1841,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، حَدَّثَنَا إِبْرَاهِيمُ بْنُ نَافِعٍ الْمَكِّيُّ، عَنِ ابْنِ أَبِي نَجِيحٍ، عَنْ مُجَاهِدٍ، عَنْ أُمِّ هَانِئٍ، قَالَتْ قَدِمَ رَسُولُ اللَّهِ صلى الله عليه وسلم مَكَّةَ وَلَهُ أَرْبَعُ ضَفَائِرَ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ غَرِيبٌ ‏.‏ وَعَبْدُ اللَّهِ بْنُ أَبِي نَجِيحٍ مَكِّيٌّ أَبُو نَجِيحٍ اسْمُهُ يَسَارٌ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ غَرِيبٌ وَعَبْدُ اللَّهِ بْنُ أَبِي نَجِيحٍ مَكِّيٌّ""",Ahmad Muhammad Shakir: Hasan; Bashar Awad Maarouf: Hasan; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۱۸۰۰۲),,Another chain from Umm Hani' who said:,The Book on Clothing
1842,حَدَّثَنَا حُمَيْدُ بْنُ مَسْعَدَةَ، حَدَّثَنَا مُحَمَّدُ بْنُ حُمْرَانَ، عَنْ أَبِي سَعِيدٍ، وَهُوَ عَبْدُ اللَّهِ بْنُ بُسْرٍ قَالَ سَمِعْتُ أَبَا كَبْشَةَ الأَنْمَارِيَّ، يَقُولُ كَانَتْ كِمَامُ أَصْحَابِ رَسُولِ اللَّهِ صلى الله عليه وسلم بُطْحًا ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ مُنْكَرٌ ‏.‏ وَعَبْدُ اللَّهِ بْنُ بُسْرٍ بَصْرِيٌّ هُوَ ضَعِيفٌ عِنْدَ أَهْلِ الْحَدِيثِ ضَعَّفَهُ يَحْيَى بْنُ سَعِيدٍ وَغَيْرُهُ ‏.‏ وَبُطْحٌ يَعْنِي وَاسِعَةٌ ‏.‏,Al-Albani: Hasan; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: انظر حدیث رقم ۱۸۳۹ (تحفة الأشراف : ۲۵۷۹),1842,Narrated Abu Sa'eed - who is 'Abdullah bin Busr:,The Book on Clothing
1843,"حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا أَبُو الأَحْوَصِ، عَنْ أَبِي إِسْحَاقَ، عَنْ مُسْلِمِ بْنِ نَذِيرٍ، عَنْ حُذَيْفَةَ، قَالَ أَخَذَ رَسُولُ اللَّهِ صلى الله عليه وسلم بِعَضَلَةِ سَاقِي أَوْ سَاقِهِ فَقَالَ ‏ ‏ هَذَا مَوْضِعُ الإِزَارِ فَإِنْ أَبَيْتَ فَأَسْفَلُ فَإِنْ أَبَيْتَ فَلاَ حَقَّ لِلإِزَارِ فِي الْكَعْبَيْنِ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ رَوَاهُ الثَّوْرِيُّ وَشُعْبَةُ عَنْ أَبِي إِسْحَاقَ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأطعمة ۴۵ (۳۸۳۶)، (وأخرجہ النسائي في الکبریٰ)، (تحفة الأشراف : ۱۶۹۰۸),,Narrated Hudhaifa:,The Book on Clothing
1844,"حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا مُحَمَّدُ بْنُ رَبِيعَةَ، عَنْ أَبِي الْحَسَنِ الْعَسْقَلاَنِيِّ، عَنْ أَبِي جَعْفَرِ بْنِ مُحَمَّدِ بْنِ رُكَانَةَ، عَنْ أَبِيهِ، أَنَّ رُكَانَةَ، صَارَعَ النَّبِيَّ صلى الله عليه وسلم فَصَرَعَهُ النَّبِيُّ صلى الله عليه وسلم قَالَ رُكَانَةُ سَمِعْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم يَقُولُ ‏ ‏ إِنَّ فَرْقَ مَا بَيْنَنَا وَبَيْنَ الْمُشْرِكِينَ الْعَمَائِمُ عَلَى الْقَلاَنِسِ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ غَرِيبٌ وَإِسْنَادُهُ لَيْسَ بِالْقَائِمِ ‏.‏ وَلاَ نَعْرِفُ أَبَا الْحَسَنِ الْعَسْقَلاَنِيَّ وَلاَ ابْنَ رُكَانَةَ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأطعمة ۳۹ (۵۴۴۰)، صحیح مسلم/الأشربة والأطعمة ۲۳ (۲۰۴۳)، سنن ابی داود/ الأطعمة ۴۵ (۳۸۳۵)، سنن ابن ماجہ/الأطعمة ۳۷ (۳۳۲۵)، (تحفة الأشراف : ۵۲۱۹)، سنن الدارمی/الأطعمة ۲۴ (۲۱۰۲),,Narrated Abu Ja'far bin Muhammad bin Rukanah:,The Book on Clothing
1845,"حَدَّثَنَا مُحَمَّدُ بْنُ حُمَيْدٍ، حَدَّثَنَا زَيْدُ بْنُ حُبَابٍ، وَأَبُو تُمَيْلَةَ يَحْيَى بْنُ وَاضِحٍ عَنْ عَبْدِ اللَّهِ بْنِ مُسْلِمٍ، عَنْ عَبْدِ اللَّهِ بْنِ بُرَيْدَةَ، عَنْ أَبِيهِ، قَالَ جَاءَ رَجُلٌ إِلَى النَّبِيِّ صلى الله عليه وسلم وَعَلَيْهِ خَاتَمٌ مِنْ حَدِيدٍ فَقَالَ ‏""‏ مَا لِي أَرَى عَلَيْكَ حِلْيَةَ أَهْلِ النَّارِ ‏""‏ ‏.‏ ثُمَّ جَاءَهُ وَعَلَيْهِ خَاتَمٌ مِنْ صُفْرٍ فَقَالَ ‏""‏ مَا لِي أَجِدُ مِنْكَ رِيحَ الأَصْنَامِ ‏""‏ ‏.‏ ثُمَّ أَتَاهُ وَعَلَيْهِ خَاتَمٌ مِنْ ذَهَبٍ فَقَالَ ‏""‏ مَا لِي أَرَى عَلَيْكَ حِلْيَةَ أَهْلِ الْجَنَّةِ ‏""‏ ‏.‏ قَالَ مِنْ أَىِّ شَيْءٍ أَتَّخِذُهُ قَالَ ‏""‏ مِنْ وَرِقٍ وَلاَ تُتِمَّهُ مِثْقَالاً ‏""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ غَرِيبٌ ‏.‏ وَفِي الْبَابِ عَنْ عَبْدِ اللَّهِ بْنِ عَمْرٍو ‏.‏ وَعَبْدُ اللَّهِ بْنُ مُسْلِمٍ يُكْنَى أَبَا طَيْبَةَ وَهُوَ مَرْوَزِيٌّ ‏.‏",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: انظر حدیث رقم ۷۲,1845,Narrated 'Abdullah bin Buraidah:,The Book on Clothing
1846,حَدَّثَنَا ابْنُ أَبِي عُمَرَ، حَدَّثَنَا سُفْيَانُ، عَنْ عَاصِمِ بْنِ كُلَيْبٍ، عَنِ ابْنِ أَبِي مُوسَى، قَالَ سَمِعْتُ عَلِيًّا، يَقُولُ نَهَانِي رَسُولُ اللَّهِ صلى الله عليه وسلم عَنِ الْقَسِّيِّ وَالْمِيثَرَةِ الْحَمْرَاءِ وَأَنْ أَلْبَسَ خَاتَمِي فِي هَذِهِ وَفِي هَذِهِ ‏.‏ وَأَشَارَ إِلَى السَّبَّابَةِ وَالْوُسْطَى ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَابْنُ أَبِي مُوسَى هُوَ أَبُو بُرْدَةَ بْنُ أَبِي مُوسَى وَاسْمُهُ عَامِرُ بْنُ عَبْدِ اللَّهِ بْنِ قَيْسٍ ‏.‏,Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Bashar Awad Maarouf: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأطعمة ۱۲ (۳۷۶۱)، (تحفة الأشراف : ۴۴۸۹),1846,Narrated Ibn Abi Musa:,The Book on Clothing
1847,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُعَاذُ بْنُ هِشَامٍ، حَدَّثَنِي أَبِي، عَنْ قَتَادَةَ، عَنْ أَنَسٍ، قَالَ كَانَ أَحَبَّ الثِّيَابِ إِلَى رَسُولِ اللَّهِ صلى الله عليه وسلم يَلْبَسُهَا الْحِبَرَةُ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ غَرِيبٌ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأطعمة ۱۱ (۳۷۶۰)، سنن النسائی/الطہارة ۱۰۰ (۱۳۰)، وراجع صحیح مسلم/الحیض ۳۱ (۳۷۴)، (تحفة الأشراف : ۵۷۹۳)، و مسند احمد (۱/۳۵۹),1847,Narrated Anas:,The Book on Clothing
