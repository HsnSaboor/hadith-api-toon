{"hadithnumber": "3350", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  جب رسول اللہ صلی اللہ علیہ وسلم ہم میں باحیات تھے اس وقت مہر دس ا"}
{"hadithnumber": "3351", "text": "ابوالعجفاء کہتے ہیں کہ  عمر بن خطاب رضی اللہ عنہ نے فرمایا: لوگو سن لو عورتوں کے مہروں میں غلو نہ کر"}
{"hadithnumber": "3352", "text": "ام المؤمنین ام حبیبہ رضی الله عنہا سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے ان سے اس وقت نکاح"}
{"hadithnumber": "3353", "text": "انس بن مالک رضی الله عنہ کہتے ہیں کہ  عبدالرحمٰن بن عوف رضی اللہ عنہ نبی اکرم صلی اللہ علیہ وسلم کے"}
{"hadithnumber": "3354", "text": "انس رضی الله عنہ کہتے ہیں کہ  عبدالرحمٰن بن عوف رضی اللہ عنہ نے کہا: رسول اللہ صلی اللہ علیہ وسلم نے"}
{"hadithnumber": "3355", "text": "عبداللہ بن عمرو رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جس عورت سے نک"}
{"hadithnumber": "3356", "text": "علقمہ اور اسود کہتے ہیں کہ  عبداللہ بن مسعود رضی اللہ عنہ کے سامنے ایک ایسے شخص کا معاملہ پیش کیا گی"}
{"hadithnumber": "3357", "text": "علقمہ عبداللہ بن مسعود رضی الله عنہ سے روایت کرتے ہیں کہ  ان کے سامنے ایک ایسی عورت کا معاملہ پیش کی"}
{"hadithnumber": "3358", "text": "عبداللہ بن مسعود رضی الله عنہ سے روایت ہے کہ  ایک ایسا شخص جس نے ایک عورت سے شادی کی پھر مر گیا نہ ا"}
{"hadithnumber": "3359", "text": "علقمہ نے عبداللہ بن مسعود رضی الله عنہ سے  اسی طرح روایت کی ہے۔"}
{"hadithnumber": "3360", "text": "عبداللہ بن مسعود رضی الله عنہ سے روایت ہے کہ  ان کے پاس کچھ لوگ آئے اور انہوں نے کہا: ہم میں سے ایک"}
{"hadithnumber": "3361", "text": "سہل بن سعد رضی الله عنہ سے روایت ہے کہ  ایک عورت رسول اللہ صلی اللہ علیہ وسلم کے پاس آئی اور آپ سے ک"}
{"hadithnumber": "3362", "text": "نعمان بن بشیر رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے ایک شخص کے متعلق جس نے ا"}
{"hadithnumber": "3363", "text": "حبیب بن سالم کہتے ہیں کہ  نعمان بن بشیر رضی اللہ عنہما کے سامنے ایک ایسے شخص کا مقدمہ پیش ہوا جس کا"}
{"hadithnumber": "3364", "text": "حبیب بن سالم سے روایت ہے کہ  نعمان بن بشیر رضی اللہ عنہما نے فرمایا کہ رسول اللہ صلی اللہ علیہ وسلم"}
{"hadithnumber": "3365", "text": "سلمہ بن محبق رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے اس شخص کا فیصلہ جس نے اپنی بیو"}
{"hadithnumber": "3366", "text": "سلمہ بن محبق رضی الله عنہ سے روایت ہے کہ  ایک شخص نے اپنی بیوی کی لونڈی سے زنا کیا، یہ قضیہ رسول الل"}
{"hadithnumber": "3367", "text": "علی رضی الله عنہ روایت کرتے ہیں کہ  ان کو اطلاع ملی کہ ایک شخص ۱؎ ہے جو متعہ میں کچھ حرج اور قباحت ن"}
{"hadithnumber": "3368", "text": "علی ابن ابی طالب رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے خیبر کے دن متعہ اور گھ"}
{"hadithnumber": "3369", "text": "علی بن ابی طالب رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے خیبر کے دن عورتوں سے متعہ"}
{"hadithnumber": "3370", "text": "سبرہ جہنی رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے متعہ کرنے کی اجازت دی تو میں اور"}
{"hadithnumber": "3371", "text": "محمد بن حاطب رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”حلال اور حرام میں فر"}
{"hadithnumber": "3372", "text": "محمد بن حاطب رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”حلال و حرام  ( نکاح"}
{"hadithnumber": "3373", "text": "حسن رضی الله عنہ کہتے ہیں کہ  عقیل بن ابی طالب نے بنو جثم کی ایک عورت سے شادی کی تو انہیں «بالرفاء و"}
{"hadithnumber": "3374", "text": "انس رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے عبدالرحمٰن  ( عبدالرحمٰن بن عوف رضی"}
{"hadithnumber": "3375", "text": "انس رضی الله عنہ سے روایت ہے کہ  عبدالرحمٰن بن عوف رضی اللہ عنہ آئے اور ان پر زعفران کے رنگ کا اثر ت"}
{"hadithnumber": "3376", "text": "انس رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مجھ پر زردی کا اثر دیکھا  ( مجھ سے مرا"}
