metadata:
  section_id: 21
  section_name: رسول اللہ صلی اللہ علیہ وسلم کے سر مبارک کے کپڑے کا بیان
  hadith_first: 122
  hadith_last: 122

hadiths[1]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
122,"حَدَّثَنَا يُوسُفُ بْنُ عِيسَى قَالَ: حَدَّثَنَا وَكِيعٌ ، حَدَّثَنَا الرَّبِيعُ بْنُ صَبِيحٍ، عَنْ يَزِيدَ بْنِ أَبَانَ، عَنْ أَنَسِ بْنِ مَالِكٍ قَالَ: ((كَانَ رَسُولُ اللَّهِ صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ يُكْثِرُ الْقِنَاعَ كَأَنَّ ثَوْبَهُ ثَوْبُ زَيَّاتٍ))",,,122,,رسول اللہ صلی اللہ علیہ وسلم کے سر مبارک کے کپڑے کا بیان
