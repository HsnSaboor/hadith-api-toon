metadata:
  section_id: 13
  section_name: رسول اللہ صلی اللہ علیہ وسلم کی انگوٹھی کا بیان
  hadith_first: 85
  hadith_last: 92

hadiths[8]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
85,"حَدَّثَنَا قُتَيْبَةُ بْنُ سَعِيدٍ، وَغَيْرُ وَاحِدٍ، عَنْ عَبْدِ اللَّهِ بْنِ وَهْبٍ، عَنْ يُونُسَ، عَنِ ابْنِ شِهَابٍ، عَنْ أَنَسِ بْنِ مَالِكٍ قَالَ: ((كَانَ خَاتَمُ النَّبِيِّ صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ مِنْ وَرِقٍ، وَكَانَ فَصُّهُ حَبَشِيًّا))",,,85,,رسول اللہ صلی اللہ علیہ وسلم کی انگوٹھی کا بیان
86,"حَدَّثَنَا قُتَيْبَةُ حَدَّثَنَا أَبُو عَوَانَةَ، عَنْ أَبِي بِشْرٍ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ النَّبِيَّ صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ اتَّخَذَ خَاتَمًا مِنْ فِضَّةٍ، فَكَانَ يَخْتِمُ بِهِ وَلَا يَلْبَسُهُ. قَالَ أَبُو عِيسَى: "" أَبُو بِشْرٍ اسْمُهُ جَعْفَرُ بْنُ أَبِي وَحْشِيَّةَ",,,86,,رسول اللہ صلی اللہ علیہ وسلم کی انگوٹھی کا بیان
87,"حَدَّثَنَا مَحْمُودُ بْنُ غَيْلَانَ، اَنَا حَفْصُ بْنُ عُمَرَ بْنِ عُبَيْدٍ هُوَ الطَّنَافِسِيُّ حَدَّثَنَا زُهَيْرٌ أَبُو خَيْثَمَةَ، عَنْ حُمَيْدٍ، عَنْ أَنَسِ بْنِ مَالِكٍ قَالَ: ((كَانَ خَاتَمُ رَسُولِ اللَّهِ صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ مِنْ فِضَّةٍ فَصُّهُ مِنْهُ))",,,87,,رسول اللہ صلی اللہ علیہ وسلم کی انگوٹھی کا بیان
88,"حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ، حَدَّثَنَا مُعَاذُ بْنُ هِشَامٍ ،حَدَّثَنِي أَبِي، عَنْ قَتَادَةَ، عَنْ أَنَسِ بْنِ مَالِكٍ قَالَ: "" لَمَّا أَرَادَ رَسُولُ اللَّهِ صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ أَنْ يَكْتُبَ إِلَى الْعَجَمِ قِيلَ لَهُ: إِنَّ الْعَجَمَ لَا يَقْبَلُونَ إِلَّا  كِتَابًا عَلَيْهِ خَاتَمٌ، فَاصْطَنَعَ خَاتَمًا فَكَأَنِّي أَنْظُرُ إِلَى بَيَاضِهِ فِي كَفِّهِ """,,,88,,رسول اللہ صلی اللہ علیہ وسلم کی انگوٹھی کا بیان
89,"حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى ، حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ الْأَنْصَارِيِّ حَدَّثَنِي أَبِي، عَنْ ثُمَامَةَ، عَنْ أَنَسِ بْنِ مَالِكٍ قَالَ: "" كَانَ نَقْشُ خَاتَمِ رَسُولِ اللَّهِ صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ: مُحَمَّدٌ سَطْرٌ، وَرَسُولٌ سَطْرٌ، وَاللَّهُ سَطْرٌ """,,,89,,رسول اللہ صلی اللہ علیہ وسلم کی انگوٹھی کا بیان
90,"حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ أَبُو عَمْرٍو، أَنْبَأَ نُوحُ بْنُ قَيْسٍ، عَنْ خَالِدِ بْنِ قَيْسٍ، عَنْ قَتَادَةَ، عَنْ أَنَسِ بْنِ مَالِكٍ، أَنَّ النَّبِيَّ صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ كَتَبَ إِلَى كِسْرَى وَقَيْصَرَ وَالنَّجَاشِيِّ، فَقِيلَ لَهُ: إِنَّهُمْ لَا يَقْبَلُونَ كِتَابًا إِلَّا بِخَاتَمٍ فَصَاغَ رَسُولُ اللَّهِ صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ خَاتَمًا حَلْقَتُهُ فِضَّةٌ، وَنُقِشَ فِيهِ: مُحَمَّدٌ رَسُولُ اللَّهِ """,,,90,,رسول اللہ صلی اللہ علیہ وسلم کی انگوٹھی کا بیان
91,"حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ، أَنْبَأَنَا سَعِيدُ بْنُ عَامِرٍ، وَالْحَجَّاجُ بْنُ مِنْهَالٍ، عَنْ هَمَّامٍ، عَنِ ابْنِ جُرَيْجٍ، عَنِ الزُّهْرِيِّ، عَنْ أَنَسٍ بْنِ مَالِكٍ: أَنَّ النَّبِيَّ صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ كَانَ إِذَا دَخَلَ الْخَلَاءَ نَزَعَ خَاتَمَهُ """,,,91,,رسول اللہ صلی اللہ علیہ وسلم کی انگوٹھی کا بیان
92,"حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ قَالَ: حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ عُمَرَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ قَالَ: "" اتَّخَذَ رَسُولُ اللَّهِ صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ خَاتَمًا مِنْ وَرِقٍ، فَكَانَ فِي يَدِهِ ثُمَّ كَانَ فِي يَدِ أَبِي بَكْرٍ، وَيَدِ عُمَرَ، ثُمَّ كَانَ فِي يَدِ عُثْمَانَ، حَتَّى وَقَعَ فِي بِئْرِ أَرِيسٍ نَقْشُهُ: مُحَمَّدٌ رَسُولُ اللَّهِ """,,,92,,رسول اللہ صلی اللہ علیہ وسلم کی انگوٹھی کا بیان
