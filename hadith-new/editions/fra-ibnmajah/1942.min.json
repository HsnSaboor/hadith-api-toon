{"metadata":{"name":"Sunan Ibn Majah","section":{"9":"The Chapters on Marriage"},"section_detail":{"9":{"hadithnumber_first":1845,"hadithnumber_last":2015,"arabicnumber_first":1845,"arabicnumber_last":2015}}},"hadiths":[{"hadithnumber":1942,"arabicnumber":1942,"text":"Rapporté par 'Aishah : Parmi les choses qu’Allah a révélées dans le Coran puis abrogées, il y avait que rien ne rend le mariage interdit sauf dix allaitements ou cinq allaitements bien connus","grades":[{"name":"Al-Albani","grade":"Sahih"},{"name":"Muhammad Fouad Abd al-Baqi","grade":"Sahih"},{"name":"Shuaib Al Arnaut","grade":"Sahih"},{"name":"Zubair Ali Zai","grade":"Isnaad Sahih"}],"reference":{"book":9,"hadith":98}}]}