{"hadithnumber": "6500", "text": "قتیبہ بن سعید بن جمیل بن طریف ثقفی اور زہیر بن حرب نے کہا :  ہمیں جریر نے عمارہ بن قعقاع سے حدیث بیا"}
{"hadithnumber": "6501", "text": "فضیل نے عمارہ بن قعقاع سے ،  انہوں نے ابوزرعہ سے ،  انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی"}
{"hadithnumber": "6502", "text": "شریک نے عمارہ اور ابن شبرمہ سے حدیث بیان کی ،  انہوں نے ابوزرعہ سے ،  انہوں نے حضرت ابوہریرہ رضی الل"}
{"hadithnumber": "6503", "text": "محمد بن طلحہ اور وہیب دونوں نے ابن شبرمہ سے اسی سند کے ساتھ حدیث بیان کی ۔ \\n\\nوہیب کی حدیث میں ہے :"}
{"hadithnumber": "6504", "text": "وکیع نے سفیان سے اور یحییٰ بن سعید قطان نے سفیان اور شعبہ دونوں سے روایت کی ،  دونوں نے کہا :  ہمیں"}
{"hadithnumber": "6507", "text": "حضرت عبداللہ بن عمرو رضی اللہ عنہ نے بیان کیا کہ ایک شخص نے نبی صلی اللہ علیہ وسلم کی خدمت میں حاضر"}
{"hadithnumber": "6508", "text": "سلیمان بن مغیرہ نے کہا :  ہمیں حمید بن ہلال نے ابورافع سے حدیث بیان کی ،  انہوں نے حضرت ابوہریرہ رضی"}
{"hadithnumber": "6509", "text": "محمد بن سیرین نے حضرت ابوہریرہ رضی اللہ عنہ سے ،  انہوں نے نبی صلی اللہ علیہ وسلم سے روایت کی ،  آپ"}
{"hadithnumber": "6510", "text": "ابو عوانہ نے سہیل سے ،  انہوں نے اپنے والد  ( ابوصالح )  سے ،  انہوں نے حضرت ابوہریرہ رضی اللہ عنہ س"}
{"hadithnumber": "6511", "text": "جریر نے سہیل سے ،  انہوں نے اپنے والد  ( ابوصالح )  سے ،  انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے روا"}
{"hadithnumber": "6512", "text": "سلیمان بن بلال نے کہا :  مجھے سہیل نے اپنے والد  ( ابوصالح )  سے حدیث بیان کی ،  انہوں نے حضرت ابوہر"}
{"hadithnumber": "6513", "text": "ولید بن ولید نے عبداللہ بن دینار سے ،  انہوں نے حضرت عبداللہ بن عمر رضی اللہ عنہ سے روایت کی کہ ان ک"}
{"hadithnumber": "6514", "text": "حیوہ بن شریح نے ابن ہاد سے ،  انہوں نے عبداللہ بن دینار سے ،  انہوں نے حضرت عبداللہ بن عمر رضی اللہ"}
{"hadithnumber": "6515", "text": "ابراہیم بن سعد اور لیث بن سعد دونوں نے یزید بن عبداللہ بن اسامہ بن ہاد سے حدیث بیان کی ،  انہوں نے ع"}
{"hadithnumber": "6516", "text": "ابن مہدی نے ہمیں معاویہ بن صالح سے حدیث بیان کی ،  انہوں نے عبدالرحمٰن بن جبیر بن نفیر سے ،  انہوں ن"}
{"hadithnumber": "6517", "text": "عبداللہ بن وہب نے کہا :  مجھے معاویہ بن صالح نے  ( باقی ماندہ سابقہ سند کے ساتھ )  حضرت نواس بن سمعا"}
{"hadithnumber": "6518", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   \"\" اللہ"}
{"hadithnumber": "6519", "text": "حضرت عائشہ رضی اللہ عنہ سے روایت ہے ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   \" رَحم  ( خ"}
{"hadithnumber": "6520", "text": "زہیر بن حرب اور ابن ابی عمر نے کہا :  ہمیں سفیان نے زہری سے حدیث بیان کی ،  انہوں نے محمد بن جبیر بن"}
{"hadithnumber": "6521", "text": "امام مالک نے زہری سے روایت کی ،  محمد بن جبیر بن معطم نے خبر دی کہ ان کے والد نے انہیں بتایا کہ رسول"}
{"hadithnumber": "6522", "text": "معمر نے زہری سے اسی سند کے ساتھ اسی کے مانند روایت کی اور  ( اس میں ہے :  حضرت جبیر بن معطم رضی اللہ"}
{"hadithnumber": "6523", "text": "یونس نے ابن شہاب سے ،  انہوں نے حضرت انس بن مالک رضی اللہ عنہ سے روایت کی ،  کہا :  رسول اللہ صلی ال"}
{"hadithnumber": "6524", "text": "عقیل بن خالد نے کہا :  ابن شہاب نے کہا :  مجھے حضرت انس بن مالک رضی اللہ عنہ نے خبر دی کہ رسول اللہ"}
{"hadithnumber": "6525", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ ایک شخص نے عرض کی :  اللہ کے رسول! میرے  ( بعض )  رشتہ دار"}
{"hadithnumber": "6526", "text": "امام مالک نے ابن شہاب سے ،  انہوں نے حضرت انس بن مالک رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ"}
{"hadithnumber": "6530", "text": "ابوداؤد نے کہا :  ہمیں شعبہ نے قتادہ سے حدیث بیان کی ،  انہوں نے حضرت انس رضی اللہ عنہ سے روایت کی ک"}
{"hadithnumber": "6531", "text": ")   وہب بن جریر نے کہا :  ہمیں شعبہ نے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی اور مزید یہ کہا :"}
{"hadithnumber": "6532", "text": "امام مالک نے ابن شہاب سے ،  انہوں نے عطاء بن یزید لیثی سے ،  انہوں نے حضرت ابو ایوب انصاری رضی اللہ"}
{"hadithnumber": "6533", "text": "سفیان ،  یونس ،   ( محمد بن ولید )  زبیدی اور معمر سب نے زہری سے مالک کی سند کے ساتھ ،  اس قول کے سو"}
{"hadithnumber": "6534", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہ سے روایت ہے کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   \" مومن کے"}
{"hadithnumber": "6535", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   \" تین دن کے بعد"}
{"hadithnumber": "6536", "text": "اعرج نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   \" بدگما"}
{"hadithnumber": "6537", "text": "علاء کے والد  ( عبدالرحمٰن )  نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ علیہ و"}
{"hadithnumber": "6538", "text": "جریر نے اعمش سے ،  انہوں نے ابوصالح سے ،  انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  کہا :"}
{"hadithnumber": "6539", "text": "شعبہ نے ہمیں اعمش سے اسی سند کے ساتھ روایت کی :   \" ایک دوسرے سے قطع رحمی نہ کرو ،  ایک دوسرے سے روگ"}
{"hadithnumber": "6540", "text": ")   سہیل نے اپنے والد  ( ابوصالح )  سے ،  انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے اور انہوں نے نبی صل"}
{"hadithnumber": "6541", "text": "داؤد بن قیس نے ہمیں عامر بن کریز کے آزاد کردہ غلام ابوسعید سے ،  انہوں نے حضرت ابوہریرہ رضی اللہ عنہ"}
{"hadithnumber": "6542", "text": "اسامہ بن زید سے روایت ہے کہ انہوں نے عبداللہ بن عامر بن کریز کے آزاد کردہ غلام ابوسعید کو یہ کہتے ہو"}
{"hadithnumber": "6543", "text": "یزید بن اصم نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرما"}
{"hadithnumber": "6546", "text": "سفیان نے مسلم بن ابی مریم سے ،  انہوں نے ابوصالح سے روایت کی ،  انہوں نے حضرت ابوہریرہ رضی اللہ عنہ"}
{"hadithnumber": "6547", "text": "امام مالک بن انس نے مسلم بن ابی مریم سے ،  انہوں نے ابوصالح سے ،  انہوں نے حضرت ابوہریرہ رضی اللہ عن"}
{"hadithnumber": "6548", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   \" اللہ ت"}
{"hadithnumber": "6549", "text": "عبدالاعلیٰ بن حماد نے کہا :  ہمیں حماد بن سلمہ نے ثابت سے حدیث بیان کی ،  انہوں نے ابورافع سے ،  انہ"}
{"hadithnumber": "6550", "text": "ابوبکر بن محمد بن زنجویہ قشیری نے کہا :  ہمیں عبدالاعلیٰ بن حماد نرسی نے حماد بن سلمہ سے اسی سند کے"}
{"hadithnumber": "6551", "text": "سعید بن منصور اور ابوربیع زہرانی سے کہا :  ہمیں حماد بن زید نے ایوب سے حدیث بیان کی ،  انہوں نے ابوق"}
{"hadithnumber": "6552", "text": "ہشیم نے ہمیں خالد سے خبر دی ،  انہوں نے ابوقلابہ سے ،  انہوں نے ابواسماء سے ،  انہوں نے رسول اللہ صل"}
{"hadithnumber": "6553", "text": "یزید بن زُرَیع نے کہا :  ہمیں خالد نے ابوقلابہ سے ،  انہوں نے ابو اسماء رحبی سے ،  انہوں نے حضرت ثوب"}
{"hadithnumber": "6554", "text": "یزید بن ہارون نے کہا :  ہمیں عاصم احول نے ابوقلابہ عبداللہ بن زید سے خبر سنائی ،  انہوں نے ابو اشعث"}
{"hadithnumber": "6555", "text": "مروان بن معاویہ نے عاصم احول سے اسی سند کے ساتھ حدیث بیان کی ۔"}
{"hadithnumber": "6556", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   \" قیامت"}
{"hadithnumber": "6557", "text": "عثمان بن ابی شیبہ اور اسحٰق بن ابراہیم نے کہا :  ہمیں جریر نے اعمش سے حدیث بیان کی ،  انہوں نے ابووا"}
{"hadithnumber": "6558", "text": "شعبہ اور سفیان دونوں نے اعمش سے جریر کی سند کے ساتھ اسی کی حدیث کے مانند روایت کی ۔"}
{"hadithnumber": "6559", "text": "عثمان بن ابی شیبہ ،  زہیر بن حرب اور اسحٰق بن ابراہیم نے کہا؛ ہمیں جریر نے اعمش سے حدیث بیان کی ،  ا"}
{"hadithnumber": "6560", "text": "ابومعاویہ ،  سفیان ،  عیسیٰ بن یونس اور یحییٰ بن عبدالملک بن ابی غنیہ سب نے اعمش سے جریر کی سند کے س"}
{"hadithnumber": "6561", "text": "منصور نے ابراہیم سے ،  انہوں نے اسود  ( بن یزید نخعی )  سے روایت کی ،  انہوں نے کہا :  کچھ قریشی نوج"}
{"hadithnumber": "6562", "text": "اعمش نے ابراہیم سے ،  انہوں نے اسود سے ،  انہوں نے حضرت عائشہ رضی اللہ عنہا سے روایت کی ،  انہوں نے"}
{"hadithnumber": "6563", "text": "محمد بن بشر نے کہا :  ہمیں ہشام نے اپنے والد  ( عروہ )  سے حدیث بیان کی ،  انہوں نے حضرت عائشہ رضی ا"}
{"hadithnumber": "6564", "text": "ابو معاویہ نے ہمیں ہشام سے اسی سند کے ساتھ حدیث بیان کی ۔"}
{"hadithnumber": "6565", "text": "ابن شہاب نے عروہ بن زبیر سے ،  انہوں نے حضرت عائشہ رضی اللہ عنہا سے روایت کی کہ رسول اللہ صلی اللہ ع"}
{"hadithnumber": "6566", "text": "امام مالک بن انس نے یزید بن خُصَیفہ سے ،  انہوں نے عروہ بن زبیر سے ،  انہوں نے نبی صلی اللہ علیہ وسل"}
{"hadithnumber": "6567", "text": "عمرہ نے حضرت عائشہ رضی اللہ عنہا سے روایت کی ،  انہوں نے کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرما"}
{"hadithnumber": "6568", "text": "عطاء بن یسار نے حضرت ابوسعید اور حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  دونوں نے رسول اللہ صلی ال"}
{"hadithnumber": "6569", "text": "سفیان نے قریش کے ایک بزرگ ابن محیصن سے روایت کی ،  انہوں نے محمد بن قیس بن مخرمہ کو حضرت ابوہریرہ رض"}
{"hadithnumber": "6570", "text": "ابوزبیر نے کہا :  ہمیں حضرت جابر بن عبداللہ رضی اللہ عنہ نے حدیث بیان کی کہ رسول اللہ صلی اللہ علیہ"}
{"hadithnumber": "6571", "text": "عطاء بن ابی رباح نے حدیث بیان کی ،  کہا :  ایک دن حضرت ابن عباس رضی اللہ عنہ نے مجھ سے کہا :  کیا می"}
{"hadithnumber": "6572", "text": "مروان بن محمد دمشقی نے کہا؛ ہمیں سعید بن عبدالعزیز نے ربیعہ بن یزید سے حدیث بیان کی ،  انہوں نے ابو"}
{"hadithnumber": "6573", "text": "ابوبکر بن اسحٰق نے کہا :  ہمیں ابومسہر نے حدیث بیان کی ،  انہوں نے کہا :  ہمیں سعید بن عبدالعزیز نے"}
{"hadithnumber": "6574", "text": "ابواسحٰق نے کہا :  ہمیں یہ حدیث بشر کے دو بیٹوں حسن اور حسین نے اور محمد بن یحییٰ نے بیان کی ،  انہو"}
{"hadithnumber": "6575", "text": "ابواسماء نے حضرت ابوذر رضی اللہ عنہ سے روایت کی ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :"}
{"hadithnumber": "6576", "text": "حضرت جابر بن عبداللہ رضی اللہ عنہ سے روایت ہے کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   \" ظلم سے"}
{"hadithnumber": "6577", "text": "عبداللہ بن دینار نے حضرت ابن عمر رضی اللہ عنہ سے روایت کی ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم نے"}
{"hadithnumber": "6578", "text": "سالم نے اپنے والد سے روایت کی ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   \" مسلمان دوسرے مس"}
{"hadithnumber": "6579", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   \" کیا تم جانتے"}
{"hadithnumber": "6580", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   \" قیامت کے دن ت"}
{"hadithnumber": "6581", "text": "حضرت ابوموسیٰ رضی اللہ عنہ سے روایت ہے ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   \" اللہ ت"}
{"hadithnumber": "6582", "text": "ابوزبیر نے حضرت جابر رضی اللہ عنہ سے حدیث بیان کی ،  کہا :  دو لڑکے آپس میں لڑ پڑے ،  ایک لڑکا مہاجر"}
{"hadithnumber": "6583", "text": "سفیان بن عیینہ نے کہا :  عمرو  ( بن دینار )  نے حضرت جابر بن عبداللہ رضی اللہ عنہ سے سنا ،  وہ کہہ ر"}
{"hadithnumber": "6584", "text": ")   اسحٰق بن ابراہیم ،  اسحٰق بن منصور اور محمد بن رافع نے ہمیں حدیث بیان کی  ۔  ۔  ابن رافع نے کہا"}
{"hadithnumber": "6585", "text": "حضرت ابوموسیٰ رضی اللہ عنہ سے روایت ہے ،  انہوں نے کہا کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :"}
{"hadithnumber": "6586", "text": "زکریا نے ہمیں شعبی سے حدیث بیان کی ،  انہوں نے حضرت نعمان بن بشیر رضی اللہ عنہ سے روایت کی ،  کہا :"}
{"hadithnumber": "6587", "text": "مطرف نے شعبی سے ،  انہوں نے نعمان بن بشیر رضی اللہ عنہ سے ،  انہوں نے نبی صلی اللہ علیہ وسلم سے اسی"}
{"hadithnumber": "6588", "text": "وکیع نے اعمش سے ،  انہوں نے شعبی سے ،  انہوں نے حضرت نعمان بن بشیر رضی اللہ عنہ سے روایت کی ،  کہا :"}
{"hadithnumber": "6589", "text": "خیثمہ  ( بن عبدالرحمٰن )  نے حضرت نعمان بن بشیر رضی اللہ عنہ سے روایت کی ،  کہا :  رسول اللہ صلی الل"}
{"hadithnumber": "6590", "text": ")   شعبی نے حضرت نعمان بن بشیر رضی اللہ عنہ سے اور انہوں نے نبی صلی اللہ علیہ وسلم سے اسی طرح روایت"}
{"hadithnumber": "6591", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   \" ایک دوسرے کو"}
{"hadithnumber": "6592", "text": "حضرت ابوہریرہ رضی اللہ عنہ نے رسول اللہ صلی اللہ علیہ وسلم سے روایت کی کہ آپ صلی اللہ علیہ وسلم نے ف"}
{"hadithnumber": "6593", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   \" کیا تم جانتے"}
{"hadithnumber": "6594", "text": ")   رَوح  ( بن قاسم )  نے سہیل سے ،  انہوں نے اپنے والد  ( ابوصالح )  سے ،  انہوں نے حضرت ابوہریرہ ر"}
{"hadithnumber": "6595", "text": "وہیب نے کہا :  ہمیں سہیل نے اپنے والد سے حدیث بیان کی ،  انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے اور"}
{"hadithnumber": "6596", "text": "سفیان بن عیینہ نے ابن منکدر سے روایت کی ،  انہوں نے عروہ بن زبیر کو یہ کہتے ہوئے سنا کہ مجھے حضرت عا"}
{"hadithnumber": "6597", "text": "معمر نے ابن منکدر سے اسی سند کے ساتھ اسی کے ہم معنی روایت بیان کی ،  مگر انہوں نے کہا :   \" یہ قوم ک"}
{"hadithnumber": "6598", "text": "منصور نے تمیم بن سلمہ سے ،  انہوں نے عبدالرحمٰن بن ہلال سے ،  انہوں نے حضرت جریر رضی اللہ عنہ سے روا"}
{"hadithnumber": "6599", "text": "اعمش نے تمیم بن سلمہ سے ،  انہوں نے عبدالرحمٰن بن ہلال عبسی سے روایت کی ،  انہوں نے کہا :  میں نے حض"}
{"hadithnumber": "6600", "text": "محمد بن اسماعیل نے عبدالرحمٰن بن ہلال سے روایت کی ،  انہوں نے کہا :  میں نے حضرت جریر بن عبداللہ رضی"}
{"hadithnumber": "6601", "text": ")   نبی صلی اللہ علیہ وسلم کی اہلیہ حضرت عائشہ رضی اللہ عنہا سے روایت ہے کہ رسول اللہ صلی اللہ علیہ"}
{"hadithnumber": "6602", "text": "معاذ عنبری نے کہا :  ہمیں شعبہ نے مقدام بن شریح بن بانی سے حدیث بیان کی ،  انہوں نے اپنے والد سے ،"}
{"hadithnumber": "6603", "text": "محمد بن جعفر نے کہا :  ہمیں شعبہ نے حدیث بیان کی ،  انہوں نے کہا :  میں نے مقدام بن شریح بن بانی کو"}
{"hadithnumber": "6604", "text": "اسماعیل بن ابراہیم نے کہا :  ہمیں ایوب نے ابوقلابہ سے حدیث بیان کی ،  انہوں نے ابومہلب سے ،  انہوں ن"}
{"hadithnumber": "6605", "text": "حماد بن زید اور  ( عبدالوہاب )  ثقفی نے ایوب سے اسماعیل کی سند کے ساتھ اسی کی حدیث کے مانند حدیث بیا"}
{"hadithnumber": "6606", "text": "یزید بن زریع نے کہا :  ہمیں تیمی نے ابوعثمان سے حدیث بیان کی ،  انہوں نے حضرت ابوبرزہ اسلمی رضی اللہ"}
{"hadithnumber": "6607", "text": "معتمر بن سلیمان اور یحییٰ بن سعید نے سلیمان تیمی سے اسی سند کے ساتھ حدیث بیان کی ،  معتمر کی حدیث می"}
{"hadithnumber": "6608", "text": "سلیمان بن بلال نے مجھے خبر دی ،  کہا :  علاء بن عبدالرحمٰن سے روایت ہے ،  انہوں نے اپنے والد سے حدیث"}
{"hadithnumber": "6609", "text": "محمد بن جعفر نے علاء بن عبدالرحمٰن سے اسی سند کے ساتھ اسی کے مانند روایت کی ۔"}
{"hadithnumber": "6610", "text": "حفص بن میسرہ نے زید بن اسلم سے روایت کی کہ عبدالملک بن مروان نے حضرت ام درداء رضی اللہ عنہا کو اپنی"}
{"hadithnumber": "6611", "text": "معمر نے زید بن اسلم سے اسی سند سے حفص بن میسرہ کی حدیث کے ہم معنی روایت کی ۔"}
{"hadithnumber": "6612", "text": "ہشام بن سعد نے زید بن اسلم اور ابوحازم سے روایت کی ،  انہوں نے ام درداء رضی اللہ عنہ سے اور انہوں نے"}
{"hadithnumber": "6613", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم سے عرض کی گئی :  اللہ"}
{"hadithnumber": "6614", "text": "جریر نے اعمش سے ،  انہوں نے ابوضحیٰ سے ،  انہوں نے مسروق سے اور انہوں نے حضرت عائشہ رضی اللہ عنہا سے"}
{"hadithnumber": "6615", "text": "ابومعاویہ اور عیسیٰ بن یونس نے اعمش سے اسی سند کے ساتھ جریر کی حدیث کے مانند حدیث بیان کی ،  اور عیس"}
{"hadithnumber": "6616", "text": ")   عبداللہ بن نمیر نے کہا :  ہمیں اعمش نے ابوصالح سے حدیث بیان کی ،  انہوں نے حضرت ابوہریرہ رضی الل"}
{"hadithnumber": "6617", "text": "عبداللہ بن نمیر نے کہا :  ہمیں اعمش نے ابوسفیان سے حدیث بیان کی ،  انہوں نے حضرت جابر رضی اللہ عنہ س"}
{"hadithnumber": "6618", "text": "ابومعاویہ اور عیسیٰ بن یونس نے اعمش سے عبداللہ بن نمیر کی سند کے ساتھ اسی کی حدیث کے مانند حدیث بیان"}
{"hadithnumber": "6619", "text": "مغیرہ  بن عبدالرحمٰن حزامی نے ہمیں ابوزناد سے حدیث بیان کی ،  انہوں نے اعرج سے اور انہوں نے حضرت ابو"}
{"hadithnumber": "6620", "text": "ابوزناد نے ہمیں اسی سند کے ساتھ یہ روایت بیان کی ،  البتہ انہوں نے  \"\" او جلدة \"\"  کہا ۔ \\n\\nابوزناد ن"}
{"hadithnumber": "6621", "text": "ایوب نے عبدالرحمٰن اعرج سے ،  انہوں نے ابوہریرہ رضی اللہ عنہ سے ،  انہوں نے نبی صلی اللہ علیہ وسلم س"}
{"hadithnumber": "6622", "text": "نصریوں کے آزاد کردہ غلام سالم نے کہا :  میں نے حضرت ابوہریرہ رضی اللہ عنہ کو کہتے ہوئے سنا ،  کہہ رہ"}
{"hadithnumber": "6623", "text": "یونس نے ابن شہاب سے روایت کی ،  انہوں نے کہا :  مجھے سعید بن مسیب نے حضرت ابوہریرہ رضی اللہ عنہ سے خ"}
{"hadithnumber": "6624", "text": "ابن شہاب کے بھتیجے نے اپنے چچا سے روایت کی ،  انہوں نے کہا :  مجھے سعید بن مسیب نے حضرت ابوہریرہ رضی"}
{"hadithnumber": "6627", "text": ")   زہیر بن حرب اور ابومعن رقاشی نے ہمیں حدیث بیان کی  ۔  ۔  اور الفاظ زہیر کے ہیں  ۔  ۔  دونوں نے ک"}
{"hadithnumber": "6628", "text": "محمد بن مثنیٰ عنزی اور ابن بشار نے ہمیں حدیث بیان کی  ۔  ۔  الفاظ ابن مثنیٰ کے ہیں  ۔  ۔  دونوں نے ک"}
{"hadithnumber": "6629", "text": "نضر بن شمیل نے کہا :  ہمیں شعبہ نے حدیث بیان کی ،  انہوں نے کہا :  ہمیں ابوحمزہ نے خبر دی کہ میں نے"}
{"hadithnumber": "6630", "text": "اعرج نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   \" بدتری"}
{"hadithnumber": "6631", "text": "اعراک بن مالک نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی کہ انہوں نے رسول اللہ صلی اللہ علیہ وسلم کو"}
{"hadithnumber": "6632", "text": "سعید بن مسیب اور ابوزرعہ نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  کہا :  رسول اللہ صلی اللہ علیہ"}
{"hadithnumber": "6633", "text": "یونس نے ابن شہاب سے روایت کی ،  انہوں نے کہا :  مجھے حمید بن عبدالرحمان بن عوف نے خبر دی کہ ان کی وا"}
{"hadithnumber": "6634", "text": "صالح نے کہا :  ہمیں محمد بن مسلم بن عبیداللہ بن عبداللہ بن شہاب نے اسی سند کے ساتھ اسی کے مانند حدیث"}
{"hadithnumber": "6635", "text": "معمر نے ہمیں زہری سے اسی سند کے ساتھ آپ کے اس فرمان تک خبر دی :   \" اور اچھی بات پہنچائی \"  اور اس ک"}
{"hadithnumber": "6636", "text": "حضرت عبداللہ بن مسعود رضی اللہ عنہ سے روایت ہے ،  کہا :  محمد صلی اللہ علیہ وسلم نے فرمایا :   \" کیا"}
{"hadithnumber": "6637", "text": "جریر نے منصور سے ،  انہوں نے ابووائل  ( شقیق )  سے ،  انہوں نے حضرت عبداللہ بن مسعود رضی اللہ عنہ سے"}
{"hadithnumber": "6638", "text": "ابوبکر بن ابی شیبہ اور ہناد بن سری نے کہا :  ہمیں ابواحوص نے منصور سے حدیث بیان کی ،  انہوں نے ابوائ"}
{"hadithnumber": "6639", "text": "ابومعاویہ اور وکیع نے کہا :  ہمیں اعمش نے شقیق  ( ابووائل )  سے حدیث بیان کی ،  انہوں نے حضرت عبدالل"}
{"hadithnumber": "6640", "text": "ابن مسہر اور عیسیٰ بن یونس دونوں نے اعمش سے اسی سند کے ساتھ خبر دی ،  انہوں نے عیسیٰ کی روایت میں :"}
{"hadithnumber": "6641", "text": "جریر نے ہمیں اعمش سے حدیث بیان کی ،  انہوں نے ابراہیم تیمی سے ،  انہوں نے حارث بن سوید سے ،  انہوں ن"}
{"hadithnumber": "6642", "text": "ابومعاویہ اور عیسیٰ بن یونس نے اعمش سے اسی سند کے ساتھ اسی کے ہم معنی روایت کی ۔"}
{"hadithnumber": "6643", "text": "سعید بن مسیب نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :"}
{"hadithnumber": "6644", "text": "زبیدی نے زہری سے روایت کی ،  انہوں نے کہا :  مجھے حمید بن عبدالرحمٰن نے بتایا کہ حضرت ابوہریرہ رضی ا"}
{"hadithnumber": "6645", "text": "معمر اور شعیب دونوں نے زہری سے خبر دی ،  انہوں نے حمید بن عبدالرحمٰن بن عوف سے ،  انہوں نے ابوہریرہ"}
{"hadithnumber": "6646", "text": "یحییٰ بن یحییٰ اور محمد بن علاء نے کہا :  ہمیں ابومعاویہ نے اعمش سے حدیث بیان کی ،  انہوں نے عدی بن"}
{"hadithnumber": "6647", "text": "ابواسامہ نے کہا :  میں نے اعمش سے سنا ،  وہ کہہ رہے تھے :  میں نے عدی بن ثابت سے سنا ،  وہ کہہ رہے ت"}
{"hadithnumber": "6648", "text": "حفص بن غیاث نے اعمش سے اسی سند کے ساتھ روایت کی ۔"}
{"hadithnumber": "6649", "text": "یونس بن محمد نے حماد بن سلمہ سے ،  انہوں نے ثابت سے ،  انہوں نے حضرت انس رضی اللہ عنہ سے روایت کی کہ"}
{"hadithnumber": "6650", "text": "بہز نے کہا :  ہمیں حماد نے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی ۔"}
{"hadithnumber": "6651", "text": "مغیرہ حزامی نے ہمیں ابوزناد سے حدیث بیان کی ،  انہوں نے اعرج سے اور انہوں نے حضرت ابوہریرہ رضی اللہ"}
{"hadithnumber": "6652", "text": "ہمیں سفیان بن عیینہ نے ابوزناد سے اسی سند کے ساتھ روایت کی اور کہا :   \" جب تم میں سے کوئی  ( دوسرے"}
{"hadithnumber": "6653", "text": "سہیل کے والد  ( ابوصالح )  نے حضرت ابوہریرہ رضی اللہ عنہ سے اور انہوں نے نبی صلی اللہ علیہ وسلم سے ر"}
{"hadithnumber": "6654", "text": "شعبہ نے ہمیں قتادہ سے حدیث بیان کی ،  انہوں نے ابوایوب سے سنا ،  حضرت ابوہریرہ رضی اللہ عنہ سے حدیث"}
{"hadithnumber": "6655", "text": "نصر بن علی جبضمی نے کہا :  ہمیں میرے والد نے حدیث بیان کی ،  انہوں نے کہا :  ہمیں مثنیٰ  ( بن سعید )"}
{"hadithnumber": "6656", "text": "ہمام نے کہا :  ہمیں قتادہ نے ابوایوب یحییٰ بن مالک مراغی سے حدیث بیان کی ،  انہوں نے حضرت ابوہریرہ ر"}
{"hadithnumber": "6657", "text": "حفص بن غیاث نے ہشام بن عروہ سے ،  انہوں نے اپنے والد سے ،  انہوں نے حضرت ہشام بن حکیم بن حزام رضی ال"}
{"hadithnumber": "6658", "text": "ابواسامہ نے ہشام سے ،  انہوں نے اپنے والد سے روایت کی ،  انہوں نے کہا :  حضرت ہشام بن حکیم بن حزام ر"}
{"hadithnumber": "6659", "text": "وکیع ،  ابومعاویہ اور جریر سب نے ہشام سے اسی سند کے ساتھ حدیث بیان کی ،  اور جریر کی حدیث میں مزید ی"}
{"hadithnumber": "6660", "text": "ابن شہاب نے عروہ بن زبیر سے روایت کی کہ حضرت ہشام بن حکیم رضی اللہ عنہ نے ایک شخص کو دیکھا ،  وہ حمص"}
{"hadithnumber": "6661", "text": "سفیان بن عیینہ نے عمرو  ( بن دینار )  سے روایت کی ،  انہوں نے حضرت جابر رضی اللہ عنہ سے سنا ،  وہ کہ"}
{"hadithnumber": "6662", "text": "حماد بن زید نے عمرو بن دینار سے ،  انہوں نے حضرت جابر بن عبداللہ رضی اللہ عنہ سے روایت کی کہ ایک شخص"}
{"hadithnumber": "6663", "text": "قتیبہ بن سعید اور محمد بن رمح نے کہا :  ہمیں لیث اور ابوزبیر سے حدیث بیان کی ،  انہوں نے حضرت جابر ر"}
{"hadithnumber": "6664", "text": "ثابت نے ابوبردہ سے ،  انہوں نے حضرت ابوموسیٰ رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ علیہ وسل"}
{"hadithnumber": "6665", "text": "بُرید نے ابوبردہ سے ،  انہوں نے حضرت ابوموسیٰ رضی اللہ عنہ سے اور انہوں نے نبی صلی اللہ علیہ وسلم سے"}
{"hadithnumber": "6666", "text": ")   ایوب نے  ( محمد )  ابن سیرین سے روایت کی ،  کہا :  میں نے حضرت ابوہریرہ رضی اللہ عنہ کو یہ کہتے"}
{"hadithnumber": "6667", "text": "ابن عون نے محمد  ( بن سیرین )  سے ،  انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے اور انہوں نے نبی صلی الل"}
{"hadithnumber": "6668", "text": "ہمام بن منبہ سے روایت ہے ،  کہا :  یہ احادیث ہیں جو حضرت ابوہریرہ رضی اللہ عنہ نے رسول اللہ صلی اللہ"}
{"hadithnumber": "6669", "text": "ابو بکر  کے آزاد کردہ غلام سُمی نے ابوصالح سے ،  انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی کہ"}
{"hadithnumber": "6670", "text": "سہیل نے اپنے والد سے ،  انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  کہا :  رسول اللہ صلی اللہ"}
{"hadithnumber": "6671", "text": "اعمش نے ابوصالح سے ،  انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے اور انہوں نے نبی صلی اللہ علیہ وسلم سے"}
{"hadithnumber": "6672", "text": "ابورافع نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   \" ای"}
{"hadithnumber": "6673", "text": "ابان نے صمعہ نے کہا :  مجھے ابووازع نے حدیث بیان کی ،  کہا :  مجھے حضرت ابوبرزہ رضی اللہ عنہ نے حدیث"}
{"hadithnumber": "6674", "text": "ابوبکر بن شعیب بن حبحاب نے ابووازع راسبی سے ،  انہوں نے حضرت ابوبرزہ رضی اللہ عنہ سے روایت کی ،  انہ"}
{"hadithnumber": "6675", "text": "جویریہ  بن اسماء نے نافع سے ،  انہوں نے حضرت عبداللہ  ( بن عمر رضی اللہ عنہ )  سے روایت کی کہ رسول ا"}
{"hadithnumber": "6676", "text": "امام مالک بن انس نے نافع سے ،  انہوں نے حضرت ابن عمر رضی اللہ عنہ سے ،  انہوں نے نبی صلی اللہ علیہ و"}
{"hadithnumber": "6677", "text": "عبیداللہ بن عمر نے نافع سے ،  انہوں نے حضرت ابن عمر رضی اللہ عنہ سے روایت کی ،  کہا :  رسول اللہ صلی"}
{"hadithnumber": "6678", "text": "سعید مقبری نے حضرت ابوہریرہ رضی اللہ عنہ سے اور انہوں نے نبی صلی اللہ علیہ وسلم سے اسی کے مانند روای"}
{"hadithnumber": "6679", "text": "معمر نے ہمیں ہمام بن منبہ سے روایت کی ،  کہا :  یہ احادیث ہمیں حضرت ابوہریرہ رضی اللہ عنہ نے نبی صلی"}
{"hadithnumber": "6680", "text": "حضرت ابوسعید خدری اور حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ،  دونون نے کہا کہ رسول اللہ صلی اللہ ع"}
{"hadithnumber": "6681", "text": "ابو عمران جونی نے حضرت جندب رضی اللہ عنہ سے حدیث بیان کی کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :"}
{"hadithnumber": "6682", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   \" بہت سے غبار م"}
{"hadithnumber": "6683", "text": "حماد بن ابی سلمہ اور امام مالک نے سہیل بن ابی صالح ،  انہوں نے اپنے والد سے ،  انہوں نے حضرت ابوہریر"}
{"hadithnumber": "6684", "text": "روح بن قاسم اور سلیمان بن بلال نے سہیل سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی ۔"}
{"hadithnumber": "6685", "text": "مالک بن انس ،  لیث بن سعد اور یزید بن ہارون سب نے یحییٰ بن سعید سے روایت کی ،   ( اسی طرح )  محمد بن"}
{"hadithnumber": "6686", "text": "ہشام بن عروہ نے اپنے والد سے ،  انہوں نے حضرت عائشہ رضی اللہ عنہا سے اور انہوں نے نبی صلی اللہ علیہ"}
{"hadithnumber": "6687", "text": "عمر بن محمد کے والد نے کہا :  میں نے حضرت ابن عمر رضی اللہ عنہ کو یہ کہتے ہوئے سنا :  رسول اللہ صلی"}
{"hadithnumber": "6688", "text": "عبدالعزیز بن عبدالصمد عمی نے کہا :  ہمیں ابوعمران جونی نے عبداللہ بن صامت سے حدیث بیان کی ،  انہوں ن"}
{"hadithnumber": "6689", "text": "شعبہ نے ابو عمران جونی سے ،  انہوں نے عبداللہ بن صامت سے اور انہوں نے حضرت ابوذر رضی اللہ عنہ سے روا"}
{"hadithnumber": "6690", "text": "حضرت ابوذر رضی اللہ عنہ سے روایت ہے ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم نے مجھ سے فرمایا :   \" نی"}
{"hadithnumber": "6691", "text": "حضرت ابوموسیٰ رضی اللہ عنہ سے روایت ہے ،  انہوں نے کہا :  رسول اللہ صلی اللہ علیہ وسلم کے پاس جب کوئ"}
{"hadithnumber": "6692", "text": "حضرت ابوموسیٰ رضی اللہ عنہ نے نبی صلی اللہ علیہ وسلم سے روایت کی کہ آپ نے فرمایا :   \" نیک ہم نشیں ا"}
{"hadithnumber": "6693", "text": "معمر اور شعیب نے ابن شہاب زہری سے روایت کی ،  انہوں نے کہا :  مجھے عبداللہ بن ابی بکر بن حزم نے حدیث"}
{"hadithnumber": "6694", "text": "عراک بن مالک نے حضرت عائشہ رضی اللہ عنہا سے روایت کی ،  انہوں نے کہا :  میرے پاس ایک مسکین عورت آئی"}
{"hadithnumber": "6695", "text": "حضرت انس رضی اللہ عنہ سے روایت ہے ،  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   \" جس شخص نے دو لڑکیو"}
{"hadithnumber": "6696", "text": "امام مالک نے ابن شہاب سے ،  انہوں نے سعید بن مسیب سے ،  انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے اور ا"}
{"hadithnumber": "6697", "text": "سفیان اور معمر دونوں نے زہری سے مالک کی سند کے ساتھ انہی کے مفہوم میں حدیث بیان کی ،  مگر سفیان کی ح"}
{"hadithnumber": "6698", "text": "سہیل کے والد  ( ابوصالح )  نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ علیہ وسلم"}
{"hadithnumber": "6699", "text": "ابوعوانہ نے عبدالرحمٰن بن اصبہانی سے ،  انہوں نے ابوصالح ذکوان سے اور انہوں نے حضرت ابوسعید خدری رضی"}
{"hadithnumber": "6700", "text": "محمد بن جعفر اور معاذ نے کہا :  ہمیں شعبہ نے عبدالرحمان بن اصبہانی سے اسی سند کے ساتھ اس کے ہم معنی"}
{"hadithnumber": "6703", "text": "ابوبکر بن ابی شیبہ ،  محمد بن عبداللہ بن نمیر اور ابوسعید اشج نے ہمیں حدیث بیان کی  ۔  ۔  الفاظ ابوب"}
{"hadithnumber": "6704", "text": "قتیبہ بن سعید اور زہیر بن حرب نے کہا :  ہمیں جریر نے طلق بن معاویہ نخعی ابوغیاث سے حدیث بیان کی ،  ا"}
{"hadithnumber": "6705", "text": "جریر نے سہیل سے ،  انہوں نے اپنے والد  ( ابوصالح )  سے ،  انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے روا"}
{"hadithnumber": "6706", "text": ")   عبدالعزیز دراوردی ،  علاء بن مسیب اور امام مالک بن انس سب نے سہیل سے اسی سند کے ساتھ روایت کی ،"}
{"hadithnumber": "6707", "text": "عبدالعزیز بن عبداللہ بن ابی سلمی ماجثون نے سہیل سے ،  انہوں نے ابوصالح سے روایت کی ،  کہا :  ہم عرفہ"}
{"hadithnumber": "6708", "text": "ابوصالح نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   \" رو"}
{"hadithnumber": "6709", "text": "یزید بن اصم نے حضرت ابوہریرہ رضی اللہ عنہ سے مرفوعا ایک حدیث بیان کی ،  کہا :   \" لوگ سونے چاندی کی"}
{"hadithnumber": "6710", "text": "اسحاق بن عبداللہ بن ابی طلحہ نے حضرت انس بن مالک رضی اللہ عنہ سے روایت کی کہ ایک اعرابی نے رسول اللہ"}
{"hadithnumber": "6713", "text": "حماد بن زید نے کہا :  ہمیں ثابت بنانی نے حضرت انس بن مالک رضی اللہ عنہ سے حدیث بیان کی ،  انہوں نے ک"}
{"hadithnumber": "6714", "text": "جعفر بن سلیمان نے ہمیں حدیث سنائی ،  کہا :  ہمیں ثابت بنانی نے حضرت انس بن مالک رضی اللہ عنہ سے حدیث"}
{"hadithnumber": "6715", "text": "منصور نے سالم بن ابی جعد سے روایت کی ،  انہوں نے کہا :  ہمیں حضرت انس بن مالک رضی اللہ عنہ نے حدیث ب"}
{"hadithnumber": "6716", "text": "عمرو بن مرہ نے سالم بن ابی جعد سے ،  انہوں نے حضرت انس رضی اللہ عنہ سے اور انہوں نے نبی صلی اللہ علی"}
{"hadithnumber": "6717", "text": "ابوعوانہ ،  شعبہ اور ہشام نے قتادہ سے ،  انہوں نے حضرت انس رضی اللہ عنہ سے اور انہوں نے نبی صلی اللہ"}
{"hadithnumber": "6718", "text": "جریر نے  ( سلیمان )  اعمش سے ،  انہوں نے ابووائل سے ،  انہوں نے حضرت عبداللہ  ( بن مسعود رضی اللہ عن"}
{"hadithnumber": "6719", "text": "شعبہ اور سلیمان بن قرم نے سلیمان  ( اعمش )  سے ،  انہوں نے ابووائل سے ،  انہوں نے عبداللہ  ( بن مسعو"}
{"hadithnumber": "6720", "text": "ابومعاویہ اور محمد بن عبید نے اعمش سے ،  انہوں نے  ( ابووائل )  شقیق سے اور انہوں نے ابوموسیٰ رضی ال"}
{"hadithnumber": "6721", "text": "حماد بن زید نے ابوعمران جونی سے ،  انہوں نے عبداللہ بن صامت سے ،  انہوں نے حضرت ابوذر رضی اللہ عنہ س"}
{"hadithnumber": "6722", "text": "وکیع ،  محمد بن جعفر ،  عبدالصمد اور نضر سب نے شعبہ سے ،  انہوں نے ابوعمران جونی سے حماد بن زید کی س"}
