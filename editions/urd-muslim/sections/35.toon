metadata:

hadiths[59]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
5064,"ابوخثیمہ زہیر (  بن معاویہ )  نے اسود بن قیس سے حدیث بیان کی ، کہا : مجھے حضرت جندب بن سفیان ( بجلی ",,,,,5064
5065,ابو احوص سلام بن سلیم نے اسود بن قیس سے ، انھوں نے حضرت جندب بن سفیان  رضی اللہ تعالیٰ عنہ  سے  روای,,,,,5065
5066,"ابو عوانہ اور ابن عینیہ نے اسود بن قیس سے اسی سند کے ساتھ روایت کی اور دونوں نے کہا؛ "" اللہ کے نام پ",,,,,5066
5067,"عبیداللہ کے والد معاذ نے کہا :  ہمیں شعبہ نے اسود بن قیس سے حدیث بیا ن کی ، انھوں نے جندب بجلی  رضی ",,,,,5067
5068,"محمد بن جعفر نے کہا : ہمیں شعبہ نے اسی سند کے ساتھ اسی کے مانند روایت کی ۔",,,,,5068
5069,"مطرف نے عامر ( شعبی )  سے  ، انھوں نے حضرت براء رضی اللہ تعالیٰ عنہ  سے روایت کی  ، کہا :  میرے مامو",,,,,5069
5070,ہشیم نے داود سے  ، انھوں نے  ( عامر )  شعبی سے  ، انھوں نے حضرت براء بن عازب رضی اللہ تعالیٰ عنہ  سے,,,,,5070
5071,ابن ابی عدی داؤد سے ،  انھوں نے  ( عامر )  شعبی سے اور انھوں نے حضرت ابراء بن عازب رضی اللہ تعالیٰ ع,,,,,5071
5072,"فراس نے عامر سے ،  انھوں نے حضرت براء  رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہا  :  رسول اللہ  صلی ال",,,,,5072
5073,"محمد بن جعفر نے کہا  :  ہمیں شعبہ نے زبید یا می سے حدیث بیان کی  ، انھوں نے حضرت براء بن عازب رضی ال",,,,,5073
5074,"عبید اللہ کے والد معاذ نے کہا  :  ہمیں شعبہ نے زبید سے حدیث بیان کی  ، انھوں نے شعبی سے سنا  ، انھوں",,,,,5074
5075,"منصور نے شعبی سے ،  انھوں نے حضرت برا ء بن عازب  رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہا  :  رسول ال",,,,,5075
5076,"عاصم احول  نے شعبی سے روایت کی ،  کہا  :  مجھے حضرت برا ء بن عازب  رضی اللہ تعالیٰ عنہ  نے حدیث سنا ",,,,,5076
5077,"محمد بن جریر نے کہا  :  ہمیں شعبہ نے سلمہ سے حدیث بیان کی ،  انھوں نے ابو جحیفہ  رضی اللہ تعالیٰ عنہ",,,,,5077
5078,وَحَدَّثَنَاهُ ابْنُ الْمُثَنَّى ،  حَدَّثَنِي وَهْبُ بْنُ جَرِيرٍ ،  ح وحَدَّثَنَا إِسْحَاقُ بْنُ إ,,,,,5078
5079,اسماعیل بن ابرا ہیم  ( ابن علیہ )  نے ایوب سے ،  انھوں نے محمد  ( بن سیرین )  سے انھوں نے حضرت انس  ,,,,,5079
5080,"حماد بن زید نے کہا  :  ہمیں ایوب  اور ہشام نے محمد سے حدیث بیان کی  ،  انھوں نے حضرت انس بن ما لک رض",,,,,5080
5081,"حاتم بن وردان نے کہا  :  ہمیں ایو ب نے محمد بن سیرین سے حدیث بیان کی  ، انھوں نے حضرت انس بن مالک رض",,,,,5081
5082,"حضرت جا بر  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ رسول اللہ  صلی اللہ علیہ وسلم  نے فر ما یا  : صرف مس",,,,,5082
5083,ابو زبیر نے حضرت جابر بن عبد اللہ  رضی اللہ تعالیٰ عنہ کو کہتے ہوئے سنا کہ رسول اللہ  صلی اللہ علیہ ,,,,,5083
5084,قتیبہ بن سعید اور محمد بن رمح نے لیث سے انھوں نے یزید بن ابی حبیب سے انھوں نے ابو خیر سے انھوں نے حض,,,,,5084
5085,ہشام دستوائی یحییٰ بن ابی کیثر سے انھوں نے بعجہ جہنی سے انھوں نے حضرت عقبہ بن عامر رضی اللہ تعالیٰ ع,,,,,5085
5086,"معاویہ بن سلام نے کہا  :  مجھے یحییٰ بن ابی کثیر نے حدیث بیان کی ،  کہا مجھے بعجہ بن عبد اللہ نے بتا",,,,,5086
5087,"ابو عوانہ نے قتادہ سے انھوں نے حضرت انس رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہا  : نبی  صلی اللہ علی",,,,,5087
5088,"وکیع نے شعبہ سے ،  انھوں نے قتادہ سے انھوں نے حضرت انس  رضی اللہ تعالیٰ عنہ  سے روایت کی :  کہا رسول",,,,,5088
5089,"خالد بن حارث نے کہا  :  ہمیں شعبہ نے حدیث بیان کی :  کہا  :  مجھے قتادہ نے بتا یا کہا  :  میں نے حضر",,,,,5089
5090,سعید نے قتادہ سے ، انھوں نے حضرت  انس رضی اللہ تعالیٰ عنہ  سے ، انھوں نے نبی اکرم صلی اللہ علیہ وسلم,,,,,5090
5091,عروہ بن  زبیر نے حضرت  عائشہ  رضی اللہ تعالیٰ عنہا   سے روایت کی کہ رسول اللہ صلی اللہ علیہ وسلم نے ,,,,,5091
5092,یحییٰ بن سعید نے سفیان ( بن سعید )  سے رویت کی ، کہا مجھے میرے والد ( سعید بن مسروق )  نے عبایہ بن ر,,,,,5092
5093,"وکیع نے کہا :  ہمیں سفیان بن سعید بن مسروق نے اپنے والد سے حدیث سنائی ، انھوں نے عبایہ بن  رفاعہ  بن",,,,,5093
5094,۔  اسماعیل بن مسلم اور عمربن سعید نے سعید بن مسروق سے ،  انھوں نے عبایہ بن رفاعہ بن رافع بن خدیج سے ,,,,,5094
5095,زائدہ نے سعید بن مسروق سے اسی سند کے ساتھ یہ حدیث آخر تک پوری بیان کی اور اس میں کہا ( ہم نے عرض کی ,,,,,5095
5096,"زائد ہ نے سعید بن مسروق سے اسی سند کے ساتھ یہ حدیث آخر تک پو ری بیان کی اور اس میں کہا  :   (  ہم نے",,,,,5096
5097,"سفیان نے کہا  :  ہمیں زہری نے ابو عبید سے روایت کی کہا  :  میں عید کے مو قع پر حضرت علی بن ابی طا لب",,,,,5097
5098,"یو نس نے ابن شہاب سے روایت کی  ، کہا  :  مجھے ابن ازہر کے مو لیٰ ابو عبید نے حدیث بیان کی کہ انھوں ن",,,,,5098
5099,ابن شہاب کے بھتیجے صالح اور معمر سب نے زہری سے اسی سند کے ساتھ اسی کے مانند روایت کی  ۔,,,,,5099
5100,لیث نے نافع سے  ،  انھوں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے انھوں نے رسول اللہ  صلی اللہ علیہ و,,,,,5100
5101,ابن جریج اور ضحاک بن عثمان دونوں نے نافع سے ،  انھوں نے ابن عمر رضی اللہ تعالیٰ عنہ  سے انھوں نے نبی,,,,,5101
5102,"ابن ابی عمر اور عبد بن حمید نے ہمیں حدیث بیان کی  ، کہا  :  عبد الرزاق نے کہا  :  معمر نے ہمیں زہری ",,,,,5102
5103,"عبد اللہ بن ابی بکر نے حضرت عبد اللہ بن واقد  رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہا :  رسول اللہ  ",,,,,5103
5104,۔  ابو زبیر نے حضرت جابر رضی اللہ تعالیٰ عنہ سے اور انھوں نے رسول اللہ  صلی اللہ علیہ وسلم  سے روایت,,,,,5104
5105,"۔  ابن جریج نے کہا :  ہمیں  عطاء نے حدیث بیان کی  ، انھوں نے کہا : میں نے حضرت جابربن عبداللہ رضی ال",,,,,5105
5106,زید بن ابی انیسہ نے عطاء بن ابی رباح سے ، انھوں نے جابر بن عبداللہ  رضی اللہ تعالیٰ عنہ  سے روایت کی,,,,,5106
5107,"عمرو (  بن دینار )  نے عطاء سے  ، انھوں نے حضرت جابر  رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا : ہم رس",,,,,5107
5108,"ابو بکر بن ابی شیبہ نے کہا : ہمیں عبدالاعلیٰ نے جریری سے حدیث بیان کی ، انھوں نے ابونضرہ سے  ، انھوں",,,,,5108
5109,"حضرت سلمہ بن اکوع  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ رسول اللہ  صلی اللہ علیہ وسلم  نے فرمایا :  """,,,,,5109
5110,"معن بن عیسیٰ نے کہا : ہمیں معاویہ بن صالح نے ابوزاہریہ سے حدیث بیان کی  ، انھوں نے جبیر بن نفیر سے ،",,,,,5110
5111,زید بن حباب اور عبدالرحمان بن مہدی دونوں نے معاویہ بن صالح سے  اسی سند کے ساتھ رویت کی ۔,,,,,5111
5116,یحییٰ بن یحییٰ تمیمی ، ابو بکر بن ابی شیبہ ، عمرو ناقد اور زہیر بن حرب نے ہمیں سفیان بن عینیہ سے حدی,,,,,5116
5117,"ابن ابی عمر مکی نے کہا : ہمیں سفیان نے عبدالرحمان بن حمید بن عبدالرحمان بن عوف سے حدیث سنائی : انھوں",,,,,5117
5118,"اسحاق بن ابراہیم نے کہا : سفیان نے ہمیں خبر دی  ، کہا : مجھے عبدالرحمان بن حمید بن عبدالرحمان بن عوف",,,,,5118
5119,"یحییٰ بن کثیر عنبری ابو غسان نے کہا : ہمیں شعبہ نے مالک بن انس سے حدیث بیان کی ، انھوں نے عمر بن مسل",,,,,5119
5120,"محمد بن جعفر نے کہا : ہمیں شعبہ نے مالک بن انس سے حدیث بیا ن کی ، انھوں نے عمر یا عمرو بن مسلم سے اس",,,,,5120
5121,"معاذ عنبری نے کہا : ہمیں محمد بن عمر ولیثی نے عمر بن مسلم بن عمارہ بن اُکیمہ لیثی سے حدیث بیان کی ، ",,,,,5121
5122,"ابواسامہ نے کہا : مجھے محمد بن عمرو نے حدیث بیان کی ، کہا : ہمیں عمرو بن مسلم بن عمارہ لیثی نے حدیث ",,,,,5122
5123,سعید بن ابی ہلال نے عمرو بن مسلم جندعی سے روایت کی کہ حضرت سعید بن مسیب نے انھیں خبر دی کہ نبی اکرم ,,,,,5123
5124,"مروان بن معاویہ فزاری نے کہا  :  ہمیں منصور بن حیان نے حدیث بیان کی کہا  :  ابو طفیل عامر بن واثلہ  ",,,,,5124
5125,ابوخالد احمر سلیمان بن حیان نے منصور بن حیان سے انھوں نے ابو طفیل  رضی اللہ تعالیٰ عنہ  سے روایت کی ,,,,,5125
5126,"شعبہ نے کہا  :  میں نے قاسم بن ابی بزہ کو ابو طفیل  رضی اللہ تعالیٰ عنہ  سے حدیث بیان کرتے ہو ئے سنا",,,,,5126
