hadiths[143]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
534,"حضرت ابو مالک اشعری  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا :  ’’پاکیزگی نصف ایما",,,,,534
535,ابو عوانہ نے سماک بن حرب سےانہوں نے مصعب بن سعد سے روایت کی کہ عبد اللہ بن عمر  ‌رضی ‌اللہ ‌عنہ ‌ ‌ ,,,,,535
536,شعبہ  ، زائدہ اور اسرائیل سب نے سماک بن حرب سے اسی اسناد کے ساتھ رسول اللہ ﷺ سے یہی حدیث روایت کی ہے,,,,,536
537,"وہب بن منبہ کے بھائی ہمام بن منبہ سے روایت ہے ،  کہا :  یہ وہ احادیث ہیں جو حضرت ابو ہریرہ  ‌رضی ‌ال",,,,,537
538,یونس نے ابن شہاب سے روایت کی کہ عطاء بن یزید نے انہیں خبر دی کہ حمران نے  ،  جوحضرت عثمان  ‌رضی ‌الل,,,,,538
539,یعقوب کے والد ابراہیم  (  بن سعد )  نے ابن شہاب سے باقی ماندہ سند کے ساتھ حمران سے روایت کی کہ انہوں,,,,,539
540,جریر نے ہشام بن عروہ سے  ،  انہوں نے اپنے والد ( عروہ بن زبیر ) سے  ،  انہوں نے حضرت عثمان  ‌رضی ‌ال,,,,,540
541,ہشام سے  ( جریر کے بجائے )  ابو اسامہ  ،  وکیع اور سفیان کی سندوں سے بھی یہ روایت بیان کی گئی ۔  ان ,,,,,541
542,"ابن شہاب نے کہا :  لیکن عروہ ،  حمران کی جانب سے حدیث بیان کرتے ہیں کہ انہوں نے کہا : پھر جب عثمان ‌",,,,,542
543,اسحاق بن سعيد نے عمرو بن سعید بن عاص نے اپنے والد ( سعید بن عمرو ) سے اور انہوں نے اپنے والد  ( عمرو,,,,,543
544,"ابن عبدہ کی روایت میں ہے  : میں عثمان  ‌رضی ‌اللہ ‌عنہ ‌ ‌  کے پاس آیا تو انہوں نے وضو کیا  ۔  قتیبہ",,,,,544
545,"قتیبہ بن سعید ،  ابوبکر بن ابی شیبہ اور زہیر بن حرب نے کہا :   (  اس حدیث کے الفاظ قتیبہ اور ابوبکر ",,,,,545
546,"مسعر نےابو صخرہ جامع بن شداد سے روایت کی  ،  انہو ں نے کہا : میں نےحمران بن ابان سے سنا ،  انہوں نےک",,,,,546
547,عبید اللہ بن معاذ نے اپنےوالد سے اور محمد بن مثنیٰ اورابن بشار نے محمد بن جعفر  ( غندر )  سےروایت کی,,,,,547
548,مخرمہ کےوالد بکیر  (  بن عبد اللہ  )  نے حمران  ( مولیٰ عثمان  )  سے روایت کی کہ ایک دن حضرت عثمان ب,,,,,548
549,معاذ بن عبد الرحمن نے عثمان بن عفان ‌رضی ‌اللہ ‌عنہ ‌ ‌  کے مولیٰ حمران سے اور انہوں نے حضرت عثمان ب,,,,,549
550,علاء نے اپنے والد عبد الرحمن بن یعقوب سے اور انہوں نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ,,,,,550
551,محمد (  بن سیرین )  نےحضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  انہو ں نے نبی ﷺ سے روایت ,,,,,551
552,عمر بن اسحاق کےوالد اسحاق  ( بن عبد اللہ  )  نے حضرت ابوہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ رس,,,,,552
553,"عبدالرحمان بن مہدی نے کہا :  ہمیں معاویہ بن صالح نے ربیعہ بن یزید کے حوالے سے ابو ادریس خولانی سےحدی",,,,,553
554,زید بن حباب نے معاویہ بن صالح سے باقی ماندہ سابقہ سند کے ساتھ حضرت عقبہ بن عامر جہنی  ‌رضی ‌اللہ ‌عن,,,,,554
555,خالد  بن عبد اللہ نےعمرو بن یحییٰ بن عمارہ سے ،  انہوں نے اپنےوالد  ( یحییٰ بن عمارہ )  سے  ،  انہوں,,,,,555
556,( خالدبن عبداللہ کے بجائے )  سلیمان بن بلا ل نےعمرو بن یحییٰ سے باقی ماندہ پچھلی سند کے ساتھ یہی روا,,,,,556
557,"مالک بن انس نے عمرو بن یحییٰ کی سند سے یہی روایت بیان کی اور کہا : انہوں نےتین بار کلی کی اور ناک می",,,,,557
558,"بہز نے وہیب سے اور اس نے عمرو بن یحییٰ سے سابقہ راویوں کی اسناد کی طرح حدیث بیان کی اور اس میں کہا :",,,,,558
559,"ہارون بن سعید ایلی اور ابو طاہر نےحدیث بیان کی ،  انہوں نےکہا :  ہمیں ابن وہب نےحدیث سنائی ،  انہوں ",,,,,559
560,اعرج نےحضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے نبی ﷺ کی طرف منسوب کرتے ہوئے روایت کی کہ آپ نے فرمایا,,,,,560
561,"ہمام بن منبہ سےمنقول ہے  ،  انہوں نے کہا :  یہ احادیث ہیں جو حضرت ابوہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے ",,,,,561
562,مالک نے ابن شہاب سے  ،  انہوں نے ابو ادریس خولانی سے  ،  انہو ں نے حضرت ابوہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ,,,,,562
563,"یونس نے ابن شہاب سے روایت کی ، کہا :  مجھے ابو ادریس خولانی نے بیان کیا کہ انہوں نے حضرت ابو ہریرہ  ",,,,,563
564,"عیسیٰ بن طلحہ نےحضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ نبی ﷺ نے فرمایا : ’’جب تم میں سے",,,,,564
565,ابو زبیر نے حضرت جابر بن عبد اللہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  کو سنا ،  کہہ رہے تھے ،  رسول اللہ ﷺ نے فرما,,,,,565
566,"مخرمہ بن بکیر نے اپنےوالد سے  ،  انہوں نے شداد کے آزاد کردہ غلام سالم سے روایت کی  ،  انہوں نے کہا :",,,,,566
567,ایک اور سند سے محمد بن عبدالرحمان نے شداد بن ہاد کے آزادکردہ غلام ابو عبد اللہ  ( سالم  )  سے روایت ,,,,,567
568,ابوسلمہ بن عبد الرحمن نے بیان کیا کہ مہری کے آزاد کردہ غلام سالم نے مجھے بتایا کہ میں اور عبدالرحمن ,,,,,568
569,"نعیم بن عبد اللہ نے شداد بن بن ہاد کے آزاد کردہ غلام سالم سے روایت کی  ،  انہوں نے کہا :  میں حضرت ع",,,,,569
570,جریر نے منصور سے  ،  انہوں نے ہلال بن یساف سے  ،  انہوں نے ابو یحییٰ  (  مصدع ،  الاعرج )  سے اور ان,,,,,570
571,منصور کے دوسرے شاگرد سفیان اور شعبہ کے حوالے سے بھی باقی ماندہ اسی سند کے ساتھ یہی روایت بیان کی گئی,,,,,571
572,"یوسف بن ماہک نے حضرت عبد اللہ بن عمرو ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  کہا :  ایک سفر کے دوران م",,,,,572
573,ربیع بن مسلم نے محمد بن زیاد سے  ،  انہوں نے حضرت ابوہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ نبی ﷺ,,,,,573
574,شعبہ نےمحمد بن زیاد سے  ،  انہوں نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سےروایت کی کہ انہوں نے کچھ ,,,,,574
575,"سہیل کے والد ابو صالح نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  انہوں نے کہا :  رسول ا",,,,,575
576,"حضرت جابر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سےروایت ہے  ، انہوں نے کہا :  مجھے حضرت عمر بن خطاب  ‌رضی ‌اللہ ‌عنہ",,,,,576
577,"حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا : ’’جب ایک مسلم  (  یامومن",,,,,577
578,"حضرت عثمان بن عفان ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے  ،  انہوں نے کہا :  رسول اللہ ﷺ نے فرمایا : ’’جس",,,,,578
579,"عمارہ بن غزیہ انصاری نےنعیم بن عبداللہ مجمر سے روایت کی  ،  انہوں نے کہا : میں نے ابوہریرہ ﷺ کو وضو ",,,,,579
580,سعید بن ابی ہلال نے نعیم بن عبداللہ سےروایت کی  کہ انہوں نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  کو ,,,,,580
581,مروان نے ابو مالک اشجعی سعد بن طارق سے ،  انہوں نے ابو حازم سے اور انہوں نے حضرت ابو ہریرہ  ‌رضی ‌ال,,,,,581
582,( مروان کے بجائے  )  ابن فضیل نے ابو مالک اشجعی سے  ، انہوں نے ابو حازم سے اور انہوں نے حضرت ابو ہری,,,,,582
583,"حضرت حذیفہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے  ،  انہوں نے کہا :  رسول اللہ ﷺ نے فرمایا  :  ’’بلاشبہ ",,,,,583
584,اسماعیل  (  بن جعفر )  نے علاء سے  ،  انہوں نے اپنے والد سےاور انہوں نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌,,,,,584
585,اسماعیل کے بجائے )  عبدالعزیز دراوردی اور مالک نے علاء سے  ،  انہوں نے اپنےوالد عبد الرحمن سے اور ان,,,,,585
586,"ابو حازم سے روایت ہے  ،  انہوں نےکہا :  میں ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  کے پیچھے کھڑا تھا اور وہ ",,,,,586
587,اسماعیل نے بیان کیا کہ انہیں علاء نے خبر دی  ،  انہوں نے اپنے والد سے روایت کی  ،  انہوں نے حضرت ابو,,,,,587
588,( بجائے اسماعیل کے  )  مالک اور شعبہ نے اسی سند کے ساتھ علاء بن عبدالرحمن سے روایت کی  ،  شعبہ کی حد,,,,,588
589,"حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ نبی ﷺ نےفرمایا : ’’اگر مجھے یہ ڈر نہ ہوتا کہ میں",,,,,589
590,"مسعر نے مقدام بن شریح سے اور انہوں نے اپنے والد سے روایت کی  ،  انہوں نے کہا : میں نے حضرت عائشہ ؓ س",,,,,590
591,سفیان نے مقدام بن شریح سے باقی ماندہ سابقہ سند سے حضرت عائشہ ‎ؓؓؓؓؓؓؓؓؓؓؓؓؓؓسے روایت کی کہ نبی ﷺجب ا,,,,,591
592,"حضرت ابو موسیٰ اشعری  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت  ہے  ،  انہوں نے کہا :  میں رسول اللہﷺ کی خدمت م",,,,,592
593,ہشیم نے حصین سے  ،  انہوں نے ابو وائل سے  ،  انہوں نے حضرت حذیفہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ,,,,,593
594,منصور اور اعمش دونوں نے ابو وائل سے  ،  انہوں نے حضرت حذیفہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  ان,,,,,594
595,سفیان نے منصور کےحوالے سے اور حصین اور اعمش نے  ( بھی منصور کی طرح  )  ابو وائل سے اور انہوں  نے حضر,,,,,595
596,حضرت ابن عباس ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے ابو متوکل کو بتایا کہ انہوں نے ایک رات اللہ کے نبی ﷺ کے ہاں گز,,,,,596
597,ابن عیینہ نے زہری سے حدیث بیان کی  ،  انہوں نے سعید بن مسیب سے  ،  انہوں نے حضرت ابو ہریرہ ‌رضی ‌الل,,,,,597
598,مجھے یونس نے ابن شہاب زہری سے خبر دی ،  انہوں نے سعید بن مسیب سے  ،  انہوں نے حضرت ابو ہریرہ  ‌رضی ‌,,,,,598
599,"حضرت انس بن مالک ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے ،  انہوں نے کہا :  ہمارے لیے مونچھیں کترنے  ،  ناخ",,,,,599
600,عبید اللہ نےنافع سے  ،  انہوں نے حضرت ابن عمر ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے اور انہوں نے نبیﷺ سے روایت کی ,,,,,600
601,ابو بکر بن نافع نے اپنے والد سے  ، انہوں نے حضرت ابن عمر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے اور انہوں نے نبی ﷺ,,,,,601
602,عمر بن محمد نے نافع کے حوالے سے حضرت ابن عمر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سےروایت کی  ،  انہوں نے کہا کہ رس,,,,,602
603,"حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سےروایت ہے  ،  انہوں نے کہا :  رسول ا للہ ﷺ نے فرمایا : ’’ مونچ",,,,,603
604,"قتیبہ بن سعید  ،  ابو بکر بن ابی شیبہ او رزہیر بن حرب نے کہا :  ہمیں وکیع نے زکریا بن ابی زائدہ سےحد",,,,,604
605,ابو کریب نے بیان کیا  ،  ہمیں ابو زائدہ کے بیٹے نے اپنے والد  (  ابو زائدہ )  سے خبر دی ،  انہوں نے ,,,,,605
606,اعمش کے دوشاگرد وکیع اور ابو معاویہ كی سندوں سے حضرت سلمان  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے  (  اور,,,,,606
607,اعمش کے ایک اور شاگرد سفیان نے ان سے اور منصور سے  ،  ان دونوں نے ابراہیم سے  ،  انہوں نے عبد الرحمن,,,,,607
608,"ابوزبیر نے بیان کیا کہ انہوں نے حضرت جابر ‌رضی ‌اللہ ‌عنہ ‌ ‌  کو یہ کہتے ہوئے سنا  :  رسول اللہ ﷺ ن",,,,,608
609,زہیر بن حرب اور ابن نمیر دونوں نے کہا ،  ہمیں سفیان بن عیینہ نے حدیث سنائی  ،  نیز یحییٰ بن یحییٰ نے,,,,,609
610,حضرت ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے  ،  انہوں نے رسول اللہ ﷺ سے روایت کی  ،  آپ نے فرمای,,,,,610
611,محمد بن یحییٰ بن حبان اپنے چچا واسع بن حبان سے اور وہ حضرت ابن عمر   سے روایت کرتے ہیں کہ انہوں نےکہ,,,,,611
612,"یحییٰ بن سعید نے محمد بن یحییٰ سے  ،  انہوں نے اپنے چچا واسع بن حبان سے روایت کی  ،  انہوں نے کہا : ",,,,,612
613,ہمام نے یحییٰ بن ابی کثیر سے  ، انہوں نے عبد اللہ بن ابی قتادہ سے  ،  انہوں نے اپنے والد حضرت ابو قت,,,,,613
614,ہشام دستوائی نے یحییٰ بن ابی کثیر سے  ،  انہو ں نے عبد اللہ بن ابی قتادہ سے  ،  انہوں نے اپنے باپ  (,,,,,614
615,ایوب نے یحییٰ بن ابی کثیر سے  ،  انہوں نے عبد اللہ بن ابی قتادہ سے  ،  انہو ننے  (  اپنے والد )  حضر,,,,,615
