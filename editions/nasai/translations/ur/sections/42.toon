{"hadithnumber": "4337", "text": "خالد بن ولید رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے گھوڑے، خچر اور گدھے اور دان"}
{"hadithnumber": "4338", "text": "جابر رضی اللہ عنہ کہتے ہیں کہ  ہم لوگ گھوڑوں کا گوشت کھاتے تھے، عطاء کہتے ہیں: میں نے کہا: خچر؟ کہا:"}
{"hadithnumber": "4339", "text": "علی رضی اللہ عنہ نے  ابن عباس رضی اللہ عنہما سے کہا: نبی اکرم صلی اللہ علیہ وسلم نے خیبر کے دن نکاح"}
{"hadithnumber": "4340", "text": "علی بن ابی طالب رضی اللہ عنہ کہتے ہیں کہ  جنگ خیبر کے دن رسول اللہ صلی اللہ علیہ وسلم نے عورتوں کے س"}
{"hadithnumber": "4341", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے خیبر کے دن پالتو گدھوں"}
{"hadithnumber": "4342", "text": "اس سند سے بھی  ابن عمر رضی اللہ عنہما رسول اللہ صلی اللہ علیہ وسلم سے اسی جیسی روایت کرتے ہیں، اس می"}
{"hadithnumber": "4343", "text": "براء بن عازب رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے خیبر کے دن پالتو گدھوں کے گ"}
{"hadithnumber": "4344", "text": "عبداللہ بن ابی اوفی رضی اللہ عنہ کہتے ہیں کہ  جنگ خیبر کے دن ہم نے گاؤں سے باہر کچھ گدھے پکڑ کر پکا"}
{"hadithnumber": "4345", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم صبح کے وقت خیبر پہنچے اور وہ سب  ( خیبر و"}
{"hadithnumber": "4346", "text": "ابوثعلبہ خشنی رضی اللہ عنہ کہتے ہیں کہ  وہ لوگ  ( صحابہ کرام )  رسول اللہ صلی اللہ علیہ وسلم کے ساتھ"}
{"hadithnumber": "4347", "text": "ابوثعلبہ خشنی رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے دانت  ( سے پھاڑ نے )  وال"}
{"hadithnumber": "4348", "text": "جابر رضی اللہ عنہ کہتے ہیں کہ  غزوہ خیبر کے دن ہم نے گھوڑوں اور نیل گائے کا گوشت کھایا، اور ہمیں نبی"}
{"hadithnumber": "4349", "text": "عمیر بن سلمہ ضمری رضی اللہ عنہ کہتے ہیں کہ  اس دوران جب کہ ہم نبی اکرم صلی اللہ علیہ وسلم کے ساتھ رو"}
{"hadithnumber": "4350", "text": "ابوقتادہ رضی اللہ عنہ کہتے ہیں کہ  انہوں نے ایک نیل گائے شکار کیا اور اسے اپنے ساتھیوں کے پاس لے کر"}
{"hadithnumber": "4351", "text": "زہدم سے روایت ہے کہ  ابوموسیٰ رضی اللہ عنہ کے پاس ایک مرغی لائی گئی تو لوگوں میں سے ایک شخص وہاں سے"}
{"hadithnumber": "4352", "text": "زہدم جرمی کہتے ہیں کہ  ہم ابوموسیٰ اشعری رضی اللہ عنہ کے پاس تھے، اتنے میں انہیں ان کا کھانا پیش کیا"}
{"hadithnumber": "4353", "text": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے غزوہ خیبر کے دن پنجے و"}
{"hadithnumber": "4354", "text": "عبداللہ بن عمرو رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جو بھی انسان"}
{"hadithnumber": "4355", "text": "ابوہریرہ رضی اللہ عنہ روایت کرتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے سمندر کے پانی کے سلسلے میں ف"}
{"hadithnumber": "4356", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  ہمیں نبی اکرم صلی اللہ علیہ وسلم نے  ( سریہ فوجی ٹولی می"}
{"hadithnumber": "4357", "text": "جابر رضی اللہ عنہ کہتے ہیں کہ  ہمیں رسول اللہ صلی اللہ علیہ وسلم نے تین سو سواروں کے ساتھ بھیجا۔ ہما"}
{"hadithnumber": "4358", "text": "جابر رضی اللہ عنہ کہتے ہیں کہ  ہمیں رسول اللہ صلی اللہ علیہ وسلم نے ابوعبیدہ رضی اللہ عنہ کے ساتھ ای"}
