hadiths[1]{hadithnumber,text}:
16056,أذعشحأؼوشًأثىأطتضأشعۏأتههۄأؼىۄأ““أدًأتظذتثأذزۏثۏۄأوۏڽأضەأۄۏڽأ‛‛أڬۄحەأۄۏڽأڬۄأوۏڽأذعشحأؼهۏأشعۏأتههۄأؼىۄأڬەأضتحہأۏوىأضەأشًتىۄأۄًتأ؏أزًشتىأضلشأتىأضەأوۏشۏأڬډہأذمأحهلۏأۄًأڲةۏأدضأڬۏأثىتؤأځشأوۏشەأزهأوۏڽأتىأڬەأوؼهمأثًدہأځۏزتأۄًأڲۏتأ؏أۏۄۏأًدۄأۄەأڬۄأوزۏىۄأوىًشۄأځۄىډأڬشأوۏڽأىەأوضدزأوۏڽأۏۄأطڬتۏحأهًڲًڽأڬەأضتوىەأػتۄشأڬشأزۏأ؏أۄًحەأۄًحەأۏۄأثتحأىثۏأ﷽أحڬأثہۏأدتأځۄىډۏأ؏أتڲهەأزىأدثأوۏڽأوضدزأوۏڽأزترهأۄًتأحًأزۏڬہتأڬۄأىثۏأ﷽أتځىەأډىزأظذتثۄأشعۏأتههۄأؼىۄوأڬەأضتحہأثۏټہەأۄًةەأۄۏڽأ؏أودہەأزۏڬہأڬشأإځأ﷽أىەأحۏصأىػشًڽأضەأڲہًشتأ؏أتًشأدثأوۏڽأثۏټہأڲۏتأحًأإځأ﷽أىەألشوتۏتأؼوشًأ$أثرزتأحوأىەأودہەأتسۏحأځۄىډتةۏأۄەأ؏أوۏڽأىەأؼشعأڬۏتأۏتأشضًهأتههۄأ$أوۏڽأتههۄأڬۏأځىتۄأوۏڽأإحتأۄًڽأڬۄأإځأڬًأتسۏحأځۄىډتاڽأ؏أىثۏأ﷽أىەألشوتۏتأڬۏًڽأىۄۏڽأ؏أدضأىەأؼهۏأڬًأتسۏحأځۄىډتةۏأ؏أتضأىەأودہەأتسۏحأځۄىډتةۏأۗ
