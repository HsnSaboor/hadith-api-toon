13202,"أذعشحأتثًضؼۏزأرزشۏأشعۏأتههۄأؼىۄأضەأشًتۏحأۄەأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=أڬضۏأؽىۏأڬەأهۏەأظزمۄأدتةصأىۄۏڽأۄەأتضأثىزەأڬەأؼهتًۄأدًأتههۄأڬەأشتضحەأوۏڽأۄەأتًشأوضتلشأثىزۄأۏتأحۏشتأڬًةۏأځڔًضۏأدًأوضڬۏىأۄًأتضأڬًأظزمۄأزۏتأڲۏتأۄًأتًشأًۄأحدہەأحذلۄأزەأزەأۗ

[تخریج]: [ ضعیف ]"
13203,"أذعشحأمثۏظۄأثىأورتشمأشعۏأتههۄأؼىۄأضەأشًتۏحأۄەأڬۄأوۏڽأومشًعأۄًأڲۏتأ؏أتضأضهضهۄأوۏڽأشضًهأتههۄأ﷽أڬەأځتضأإۏتأحًأإځأ﷽أىەألشوتۏتأ=أمثۏظۄأتټہأڬہڔتأۄًأۏۄتڽأحڬأڬۄأۄوتشەأځتضأظزمۄأإةەأڲتأحًأۄوأحدہەأثحهتةۏڽأڲەأ؏أځہشأإځأ﷽أىەأڬۄتأ=أتەأمثۏظۄأ$أوتىڲىتأظشلأحۏىأإزوۏًڽأڬەأهۏەأدتةصأۄەأ؏أًۄأإزوۏأدضأڬًأډټۏأځڔأڲةۏأحًأتضأىەأضًتهأڬۏتأ؏أۏۄتڽأحڬأڬۄأًۄأمشعأتزتأۄًأڲۏتأ؏أځہشأًۄأشڬأدتةەأ؏أًۄأإزوۏأدضەأتډتىڬأإلحأځۄىډۏأتًشأتضأڬتأوتهأثشثتزأۄًأڲۏتأتضأىەأوتىڲتأ؏أۏۄتڽأحڬأڬۄأتضأڬتأوؼتوهۄأضۏزہتأۄًأڲۏتأ؏أځہشأًۄأشڬأڲۏتأ؏أحۏضشتأضرحأعشًشحأوىزأإزوۏأدضأڬەأوحؼهمأتضأڬۏأمًوأڬەأحۏىأإزوۏأڲًتۄۏأزۏڽأحًأتضأىەأضًتهأڬۏتأ؏أۏۄتڽأحڬأڬۄأڲصشأثضشأإضتىأۄًأڲةۏأ؏أځہشأًۄأشڬأڲۏتأ؏أتضأڬەأؼهتًۄأوتىڲىتأذشتوأۄەأ؏أ+أدًأتۏضتأڬشحتأۄەأ,أًۄأذشتوأڬہتحتأۄەأۗ

[تخریج]: [ صحیح ]"
13204,"أذضۏىأثىأؼهۏأشعۏأتههۄأؼىۄأضەأشًتۏحأۄەأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=أضًتهأڬشىەأًتهەأڬتأذمأۄەأتڲشډۄأًۄأڲہًڔەأځشأۄۏأڬۏًڽأىۄأضًتشأۄًأۗ

[تخریج]: [ ضعیف ]"
13205,"أذعشحأؼهۏأشعۏأتههۄأؼىۄأضەأځډہهۏأشًتۏحأڬۏأغشذأۄەأۗ

[تخریج]: [ ضعیف ]"
13206,"أؼهۏأثىأتثًغتهثأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأتههۄأحؼتهۏٳأىەأوتهأزتشأهًڲًڽأځشأۏۄألشعأڬۏتأۄەأڬۄأًۄأتځىەأوتهأڬۏأومزتشألمۏشأهًڲًڽأڬۏأوززأڬشۏڽأدًأتىأڬًأڬلتۏحأڬشأدتةەأۗأتڲشأًۄأثہًڬەأۄًڽأۏتأًۄأىىڲەأۄًڽأتًشأتڲشأوتهأزتشًڽأىەأتۏضتأىۄأڬۏتأحًأتههۄأڬًأۏۄأذمأذتظهأۄەأڬۄأمۏتوحأًتهەأزىأتىأڬتأوذتضثۄأڬشەأڲتأتًشأتىأڬًأتضأثتحأځشأؼستثأزەأڲتأۗ

[تخریج]: [ ضعیف ]"
13207,"أىثۏأ﷽أىەألشوتۏتأڬۄأدضأثىزەأىەأضًتهأڬۏتأذتهتىڬۄأتضأڬەأځتضأتحىتأوتهأحہتأدًأتضەأڬلتۏحأڬشەأحًأمۏتوحأڬەأزىأتضأذتهأوۏڽأإةەأڲتأڬۄأتضأڬەأډۄشەأځشأىًډىەأ؏أزتىحأهڲتىەأتًشأصروًڽأڬەأىطتىتحأۄًڽأڲەأ؏أځًډہتأڲۏتأ=أتەأتههۄأڬەأشضًهأ$أؽىۏأڬۏتأۄەأآألشوتۏتأ=أځډتضأزشۄوأۏتأتضأڬەأثشتثشأضًىتأۗ

[تخریج]: [ ضعیف ]"
13208,"أۏؼمًثأڬۄحەأۄۏڽأڬۄأۏۄأشًتۏحأؼمهأضەأڬًضًڽأزًشأۄەأ؏أتڲشډۄأذزۏخأذڬۏوأثىأدثۏشأؼىأصثۏزأۄەأهۏڬىأۏۄأتۄهأؼهوأځشأورلۏأىۄۏڽأۗ

[تخریج]: [ صحیح ]"
13209,"أثىًأتضزأڬتأتۏڬأإزوۏأڬۄحتأۄەأڬۄأوۏڽأتًشأوۏشۏأڲہشأًتهۏأثمۏؼأتهؽشمزأوۏڽأإةەأ؏أودہەأوۏشۏأڲہشأًتهۏأىەأڬۄتأڬۄأحًأىثۏأ﷽أڬەأځتضأدتأتًشأإځأضەأڬًةۏأډۏصأوتىڲأڬشأهتأ؏أۄوأڬہتةۏڽأ؏أوۏڽأىثۏأ﷽أڬەأځتضأڲۏتأۗأوۏڽأىەأتۏڬأإزوۏأڬًأزۏڬہتأدًأضًتهأڬشأشۄتأحہتأتًشأىثۏأ﷽ألشوتأشۄەأحہەأ=أوۏشەأځتضأڬًةۏأډۏصأىۄۏڽأۄەأدًأوۏڽأحدہەأزًڽأًۄأإزوۏأدثأڲۏتأحًأًۄأؽظەأوۏڽأحہتأتًشأًۄأۏۄأڬۄۄأشۄتأحہتأ=أتههۄأڬۏأمضوأ$أحًأتضأڬًأزۏحتأۄەأدضأڬًأډتۄحتأۄەأ؏أىثۏأ﷽أىەألشوتۏتأ=أًۄأؽظەأۄًأشۄتأۄەأتًشأوۏشەأځتضأڬًةۏأډۏصأتۏضۏأىۄۏڽأۄەأدًأوۏڽأتضەأزًڽأ؏ألشوتۏتأ=أدضأإزوۏأىەأحوأضەأضًتهأڬۏتأتًشأذتهتىڬۄأتضأڬەأځتضأتۏڬأتًمۏۄأۏتأتضأڬەأثشتثشأڬۏأڬًةۏأډۏصأۄەأحًأتضأىەأډوټأڬشأضًتهأڬۏتأۄەأ؏أتضزۏأڬۄحەأۄۏڽأ=أهموۄأوۏشەأۄتڽأتًمۏۄأضەأثۄحشأۄەأتًشأتًمۏۄأډتهۏضأزشۄوأڬتأۄًحتأۄەأ؏أتضأ+أإزوۏأ,أىەأڬۄتأ=أحًأوۏڽأهًټتأتًشأتضأڬەأوحؼهمأڬًةۏأضًتهأىۄأڬۏتأۗأتضأڬەأثؼزأشضًهأتههۄأ﷽أڬەأځتضأدًأتًشأڬطوطأځۏطأڬۏتأڲۏتأحًأتضأوۏڽأضەأۄوۏڽأثہۏأزۏتأڲۏتأ؏أۏتألشوتۏتأ=أۏۄتڽأحڬأڬۄأتههۄأحؼتهۏٳأىەأۄوۏڽأؽىۏأڬشأزۏتأۗ

[تخریج]: [ صحیح ۔ اخرجہ مالک 2111 ]"
13210,"أذعشحأتثًضؼۏزأرزشۏأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأوۏشەأًتهزأدىڲٓأتذزأوۏڽأطۄۏزأۄًأڲةەأتًشأۄوتشەأهۏەأڬًةۏأحشڬۄأىۄأډہًڔتأۗأۄوأضرحأعشًشحأوىزأۄًأڲةەأحًأوۏشۏأوتڽأىەأودہأضەأڬۄتأ=أتەأثۏټەأ$أشضًهأتههۄأ﷽أڬەأځتضأدتاأتًشأۄوتشەأهۏەأڬډہأوتىڲأهتاأۗأوۏڽأإځأڬەأځتضأإۏتأتًشأضهتوأڬۏتأتًشأثۏټہأڲۏتأ؏أإځأ﷽أتځىەأظذتثۄأشعۏأتههۄأؼىۄوأوۏڽأثۏټہەأۄًةەأحہەأ؏أځہشأوۏشۏأدتىثأوحًدۄأۄًأڬشأڬۄتأ=أدًأثەأځشًتأۄًأڲۏتأتههۄأحؼتهۏٳأتضأڬًأثەأځشًتأڬشأزەأڲتأ؏أدًأځتڬأزتوىأشۄتأتههۄأحؼتهۏٳأتضأڬۏأذلتػحألشوتةەأڲتأتًشأدضأىەأۄتحہأځہۏهتۏتأًۄأتضأڬًأتضأڬۏأغشلأهڲتأزەأ؏أتثًضؼۏزأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأ=أوۏڽأىەأضًډتأإځأ﷽أڬۏأوشتزأوۏڽأۄًڽأ‛أوۏڽأًتځضأإأڲۏتأتًشأڬًةۏأثتحأىۄأڬۏأ؏أوۏشۏأوتڽأىەأځًډہتأحًأوۏڽأىەأضتشۏأرثشأزەأزۏأۗأۄوۏڽأإځأىەأظثشأڬۏأحهمۏىأڬۏأۗأتههۄأحؼتهۏٳأىەأۄوۏڽأشصمأزۏتأۏۄتڽأحڬأڬۄأۄوأځۄهەأضەأصۏتزۄأعشًشحأوىزأۄًأڲةەأ؏أوۏشۏأوتڽأىەأودہەأشضًهأتههۄأ﷽أڬەأځتضأڬډہأهۏىەأڬەأهۏەأثہۏدتأ؏أوۏڽأإۏتأ؏أإځأ﷽أظذتثۄأشعۏأتههۄأؼىۄوأڬۏأودهضأوۏڽأحہەأۗأوۏڽأىەأضهتوأڬۄتأتًشأثۏټہأڲۏتأ؏أإځأوۏشۏأغشلأوحًدۄأۄًةەأتًشأځۄهەأًتهۏأثتحأڬۏأدضأوۏڽأۏۄأتهلتػأصۏتزۄأحہەأڬۄأدضأثىزەأىەأضًتهأڬۏتأذتهتىڬۄأتضأڬەأځتضأډتهۏضأزشۄوأۄۏڽأحًأًۄأډوټأڬشأضًتهأڬشىەأًتهتأۄەأ+أۏؼىۏأډوټىەأًتهتأۄەأ,أوۏڽأىەأتځىەأزهأوۏڽأضًډتأ؏أوۏشەأځتضأۏتمًحأۄەأًۄأتًمۏۄأضەأصۏتزۄأۄەأۗأتًمۏۄأډتهۏضأزشۄوأڬتأۄًحتأۄەأ؏أوۏڽأًتځضأإأڲۏتأتًشأإځأ﷽أضەأضًتهأىۄۏڽأڬۏتأ؏أؼثۏزأڬۄحەأۄۏڽأۏتمًحأتًىټىۏأۄەأۗ

[تخریج]: [ حسن ۔ احمد 11059 ]"
13211,"أؼوشًأثىأطؼۏثأتځىەأًتهزأضەأتًشأًۄأتځىەأزتزتأضەأىمهألشوتحەأۄۏڽأڬۄأىثۏأ﷽أىەألشوتۏتأ=أدضأڬەأځتضأډتهۏضأزشۄوأۄًڽأتًشأًۄأضًتهأڬشەأڲًۏتأڬۄأًۄأهًڲًڽأضەأډوټأڬشأوتىڲىەأًتهتأۄەأۗ

[تخریج]: [ نسائی 3/ 98 ]"
13212,"ضۄهأثىأذىػهۏۄألشوتحەأۄۏڽأڬۄأىثۏأ﷽أڬەأځتضأؼۏۏىۄأثىأذظىأتًشأتمشؼأثىأذتثضأإةەأ؏أتىأزًىًڽأىەأإځأ﷽أضەأضًتهأڬۏتأ؏أإځأ﷽أىەأتىأڬەأضًتهأڬەأوغتثمأزۏىەأڬتأذڬوأزۏتأتًشأوؼتًۏۄأڬًأذڬوأزۏتأڬۄأدًأڬډہأتىہًڽأىەأضًتهأڬۏتأۄەأ؏أتضأڬًأهڬہأزًأۗأشتًۏأڬۄحەأۄۏڽأڬۄأتمشؼأىەأتځىەأرغأڬًأتځىەأتوتوەأوۏڽأهځۏټأهۏتأتًشأډهتأڲۏتأتًشأؼۏۏىۄأىەأتځىتأرغأځڬڔتأتًشأىثۏأ﷽أڬەأځتضأإأڲۏتأتًشأتضأىەأڬۄتأ=أتەأوذوزأ﷽أ$أوۏڽأۏۄأرغأتځىۏأمًوأڬۏأغشلأهەأڬشأدتىەأًتهتأۄًڽأتًشأوۏڽأثہۏأىۄۏڽأدتىحتأڬۄأتضأوۏڽأڬۏتأۄەأۗشتًۏأڬۄحتأۄەأڬۄأتضأڬًأىثۏأ﷽أىەأځڬڔتأتًشأتضأوۏڽأزۏڬہتأتًشألشوتۏتأ=أتضأوۏڽأًۄأډۏصأهڬہۏأڲةۏأۄەأدضأڬتأوۏڽأىەأحۏشەأهۏەأذڬوأزۏتأحہتأۗځہشأهوثۏأذزۏخأسڬشأڬۏأتًشأىثۏأ﷽أىەألشوتۏتأڬۄأدضأثىزەأىەأضًتهأڬۏتأذتهتىڬۄأًۄأتضأډۏصأضەأثەأځشًتأۄەأ+أۏؼىۏأتضأڬًأعشًشحأىۄۏڽأ,أحًأًۄأدۄىوأڬۏأإڲأڬًأتڬټہتأڬشأشۄتأۄەأۗأظذتثۄأڬشتوأشعۏأتههۄأؼىۄوأىەأضًتهأڬۏتأڬۄأتەأتههۄأڬەأىثۏأ$أؽىۏٳأڬۏتأډۏصأۄەأڬۄأثؼزأوۏڽأضًتهأڬۏأڲىدتةطأۄۏأىۄأشۄەأآأحًأإځأ﷽أىەألشوتۏتأڬۄأًۄأتضأڬەأهۏەأضۏشأۄًىتأتۏڬأزىأتًشأشتحأۏتأتۏڬأشتحأتًشأزىأۗ

[تخریج]: [ صحیح ]"
13213,"أتىضأثىأوتهڬأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأتۏڬأطرظأإځأ﷽أڬەأځتضأإۏتأتًشألتمۄأڬۏأطڬتۏحأڬۏأ؏أځہشأًۄأهًټأڲۏتأۗأتضأىەأڬۄتأ=أتەأتههۄأڬەأىثۏأ﷽أ$أوۏڽأتځىەأڲہشأضەأإأشۄتأۄًڽأ؏أودہەأتوۏزأىۄۏڽأۄەأڬۄأوۏڽأڲہشأًتځضأدتاڽأتًشأڬًةۏأثىزۄأوشتأىۄأۄًأۗأشتًۏأڬۄحتأۄەأڬۄأإځأ﷽أىەأتضأڬًأڬۄتأڬۄأډهًأۏۄتڽأحڬأڬۄأحًأڬًةۏأډۏصأهەأإأدًأحًأځتةەأۗأشتًۏأڬۄحتأۄەأڬۄأًۄأډهەأذحۏٳأڬۄأتۏڬأډتزشأتۏڬأځۏتهۄأإۏتأ؏أتضأىەأڬۄتأ=أتەأتههۄأڬەأىثۏأ﷽أ$أتضأډتزشأڬًأثؼعأثډہتحەأتًشأثؼعأځۄىحەأحہەأتًشأۏۄأځۏتهۄأتضأوۏڽأضەأًۄأځۏحەأحہەأحًأىثۏأ﷽أىەألشوتۏتأ=أودہأضەأڬًىأتۏڬأزشۄوأوۏڽأۏۄأرشۏزەأڲتأآأتۏڬأإزوۏأىەأڬۄتأ=أتەأتههۄأڬەأىثۏأ$أوۏڽأتضأڬًأرشۏزًڽأڲتأ؏أځہشأىثۏأ﷽أىەألشوتۏتأ=أتۏڬأزشۄوأضەأصۏتزۄأڬۏأڬًىأرشۏزأهەأڲتأآأحًأتضأىەأڬۄتأ=أوۏڽأتضأڬًأزًأزشۄوأوۏڽأرشۏزًڽأڲتأحًأإځأ﷽أىەألشوتۏتأ=أۏۄأحۏشۏأۄۏڽأ؏أإځأ+أؼهۏۄأتهضهتوأ,أىەأتضأإزوۏأڬًأثهتۏتأتًشألشوتۏتأ=أتۏڬأزشۄوأڬتأڬهۄتڔتأرشۏزأتًشأتۏڬأزشۄوأڬتأتځىەأڲہشأًتهًڽأڬەأهۏەأڬہتىتأرشۏزتأشتًۏأڬۄحتأۄەأڬۄأتضأإزوۏأىەأتۏضتأڬۏتأ؏أځہشأًۄأىثۏأ﷽أڬەأځتضأإۏتأحًأإځأىەألشوتۏتأ=أتضأًتزۏأوۏڽأډهەأدتاأتًشأتضأوۏڽأضەأهڬڔۏتڽأًؽۏشۄأڬتټًأتًشأوذىحأڬشًأتًشأوۏشەأځتضأځىزشۄأزىًڽأڬەأثؼزأإىتأ؏أځہشأًۄأډهتأڲۏتأ؏أتضأىەأ43أزشۄوأځتةەأحًأإځأ﷽أىەأتضأڬًأڬۄتأڬۄأ8أزشۄوأڬتأتځىەأتۄهأڬەأهۏەأڬہتىتأتًشأځتىډأڬتأڬځڔتأًؽۏشۄأرشۏزًأۗأتضأىەأڬۄتأ=أتەأتههۄأڬەأىثۏأ﷽أ$أتههۄأحؼتهۏٳأإځأڬًأثشڬحأزەأدًأإځأىەأودہەأذڬوأزۏتأحًأإځأ﷽أىەألشوتۏتأ=أۏۄأحۏشەأهۏەأثۄحشأۄەأتضأضەأڬۄأحًأمۏتوحأًتهەأزىأإةەأتًشأحۏشەأډۄشەأځشأضًتهأڬشىەأڬۏأًدۄأضەأىطتىتحأۄًڽأۗأثۏطڬأضًتهأڬشىتأظشلأحۏىأإزوۏًڽأڬەأهۏەأدتةصأۄەأ=أۄهتڬحأًتهەأرًىأ؏أثڔۏأډټۏأتًشأثەأتىحۄتألمشأًتهەأضەأۗ

[تخریج]: [ ضعیف ]"
13214,"أذعشحأؼتةطۄأشعۏأتههۄأؼىۄتأضەأشًتۏحأۄەأڬۄأىثۏأ﷽أىەألشوتۏتأ=أشذوأتههۄأڬۏأغشلأضەأټۄىۏأۄەأ؏أتههۄأحؼتهۏٳأتضأڬًأوهتةەأڲتأدًأتضأڬًأوهتةەأڲتأتًشأتههۄأحؼتهۏٳأتضأڬًأڬتټەأڲتأدًأتضأڬًأڬتټەأڲتأۗ

[تخریج]: [ بخاری 5989 ۔ مسلم 2555 ]"
13215,"أؼثزتهشذوىأثىأؼًلألشوتحەأۄۏڽأڬۄأوۏڽأىەأإځأ﷽أڬًألشوتحەأۄًةەأضىتأڬۄأتههۄأحؼتهۏٳألشوتحتأۄەأ=أوۏڽأشذوتىأۄًڽأتًشأوۏڽأىەأظهۄأشذوۏأڬًأځۏزتأڬۏتأتًشأتضأڬًأوۏڽأىەأتځىەأىتوًڽأوۏڽأضەأوىحرثأڬۏتأۗأدًأتضأڬًأوهتةەأڲتأوۏڽأتضأڬًأوهتاڽأڲتأ؏أدًأتضأڬًأڬتټەأڲتأوۏڽأتضأڬًأڬتټًڽأڲتأۗ

[تخریج]: [ حسن لغیرہ ]"
13216,"أتۏعتَ

[تخریج]: [ حسن لغیرہ ]"
13217,"أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأشًتۏحأۄەأڬۄأىثۏأ﷽أىەألشوتۏتأ=أتههۄأحؼتهۏٳأىەأورهًمأڬًأځۏزتأڬۏتأۗأًۄأدثأحرهۏمأضەألتشؽأۄًتأحًأظهۄأشذوۏأىەأڬۄتأ=أۏۄأومتوأۄەأمغؼۏأشذوۏأضەأځىتۄأځڬڔىەأڬتأحًأتههۄأځتڬأىەألشوتۏتأ=أۄتڽأ؏أڬۏًڽأىۄۏڽأ$أڬۏتأحًأشتعۏأىۄۏڽأۄەأ؏أوۏڽأتضأڬًأوهتاڽأڲتأ؏أدًأحدہأڬًأوهتةەأڲتأتًشأوۏڽأتضأڬًأڬتټًڽأڲتأدًأحدہأڬًأڬتټەأڲتأحًأتضأىەأڬۄتأ=أڬۏًڽأىۄۏڽأتەأوۏشەأشثأ$أًۄأظهۄأشذوۏأحۏشەأهۏەأۄەأۗأىثۏأ﷽أىەألشوتۏتأ=أتڲشأحوأډتۄًأحًأځڔہًأ=أ®~ألّۄّهٕأؼّضّۏٕحْوٕأتٓىٕأحًّّهّٔۏٕحْوٕأتّىٕأحْلٕضٓزًْٕتألٓۏأتهٕتّشٕعٓأۗۗۗأ¾أ^أوذوزأ=أ55أۗأ56أ`

