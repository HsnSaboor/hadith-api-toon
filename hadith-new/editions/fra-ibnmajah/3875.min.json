{"metadata":{"name":"Sunan Ibn Majah","section":{"34":"Supplication"},"section_detail":{"34":{"hadithnumber_first":3827,"hadithnumber_last":3892,"arabicnumber_first":3827,"arabicnumber_last":3892}}},"hadiths":[{"hadithnumber":3875,"arabicnumber":3875,"text":"Rapporté par 'Aishah : Chaque fois que le Prophète (ﷺ) allait se coucher, il soufflait dans ses mains, récitait Al-Mu’awwidhatain, puis passait ses mains sur son corps","grades":[{"name":"Al-Albani","grade":"Sahih"},{"name":"Muhammad Fouad Abd al-Baqi","grade":"Sahih"},{"name":"Shuaib Al Arnaut","grade":"Sahih"},{"name":"Zubair Ali Zai","grade":"Sahih Bukhari"}],"reference":{"book":34,"hadith":49}}]}