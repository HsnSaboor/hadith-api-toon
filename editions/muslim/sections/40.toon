metadata:

hadiths[46]{hadithnumber,arabic,bengali,english,french,indonesian,russian,urdu,grades,reference,international_number,narrator_chain,chapter_intro}:
{"hadithnumber": "5712", "arabic": "حَدَّثَنِي أَبُو الطَّاهِرِ، أَحْمَدُ بْنُ عَمْرِو بْنِ سَرْحٍ وَحَرْمَلَةُ بْنُ يَحْيَى قَالاَ أَخْبَرَنَا ابْنُ وَهْبٍ، حَدَّثَنِي يُونُسُ، عَنِ ابْنِ شِهَابٍ، أَخْبَرَنِي أَبُو سَلَمَةَ بْنُ عَبْدِ الرَّحْمَنِ، قَالَ قَالَ أَبُو هُرَيْرَةَ سَمِعْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم يَقُولُ ‏ ‏ قَالَ اللَّهُ عَزَّ وَجَلَّ يَسُبُّ ابْنُ آدَمَ الدَّهْرَ وَأَنَا الدَّهْرُ بِيَدِيَ اللَّيْلُ وَالنَّهَارُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "I heard Allah's Messenger (ﷺ) as saying: Allah, the Exalted and Glorious, said: The son of Adam abuses Dahr (the time), whereas I am Dahr since in My hand are the day and the night.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira reported:", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5713", "arabic": "وَحَدَّثَنَاهُ إِسْحَاقُ بْنُ إِبْرَاهِيمَ، وَابْنُ أَبِي عُمَرَ، - وَاللَّفْظُ لاِبْنِ أَبِي عُمَرَ - قَالَ إِسْحَاقُ أَخْبَرَنَا وَقَالَ ابْنُ أَبِي عُمَرَ، حَدَّثَنَا سُفْيَانُ، عَنِ الزُّهْرِيِّ، عَنِ ابْنِ الْمُسَيَّبِ، عَنْ أَبِي، هُرَيْرَةَ أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ قَالَ اللَّهُ عَزَّ وَجَلَّ يُؤْذِينِي ابْنُ آدَمَ يَسُبُّ الدَّهْرَ وَأَنَا الدَّهْرُ أُقَلِّبُ اللَّيْلَ وَالنَّهَارَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "Allah, the Exalted and Glorious, said: The son of Adam displeases Me by abusing Dahr (time), whereas I am Dahr--I alternate the night and the day.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5714", "arabic": "وَحَدَّثَنَا عَبْدُ بْنُ حُمَيْدٍ، أَخْبَرَنَا عَبْدُ الرَّزَّاقِ، أَخْبَرَنَا مَعْمَرٌ، عَنِ الزُّهْرِيِّ، عَنِ ابْنِ، الْمُسَيَّبِ عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ قَالَ اللَّهُ عَزَّ وَجَلَّ يُؤْذِينِي ابْنُ آدَمَ يَقُولُ يَا خَيْبَةَ الدَّهْرِ ‏.‏ فَلاَ يَقُولَنَّ أَحَدُكُمْ يَا خَيْبَةَ الدَّهْرِ ‏.‏ فَإِنِّي أَنَا الدَّهْرُ أُقَلِّبُ لَيْلَهُ وَنَهَارَهُ فَإِذَا شِئْتُ قَبَضْتُهُمَا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "Allah, the Exalted and Glorious, said: The son of Adam causes Me pain as he says: Woe be upon the Time. None of you should say this: Woe be upon the Time, as I am the Time (because) I alternate the day and the night, and when I wish I can finish them up.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5715", "arabic": "حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا الْمُغِيرَةُ بْنُ عَبْدِ الرَّحْمَنِ، عَنْ أَبِي الزِّنَادِ، عَنِ الأَعْرَجِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ لاَ يَقُولَنَّ أَحَدُكُمْ يَا خَيْبَةَ الدَّهْرِ ‏.‏ فَإِنَّ اللَّهَ هُوَ الدَّهْرُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "None of you should say: Woe be upon the Time, for verily Allah is the Time.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5716", "arabic": "وَحَدَّثَنِي زُهَيْرُ بْنُ حَرْبٍ، حَدَّثَنَا جَرِيرٌ، عَنْ هِشَامٍ، عَنِ ابْنِ سِيرِينَ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ لاَ تَسُبُّوا الدَّهْرَ فَإِنَّ اللَّهَ هُوَ الدَّهْرُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "Do not curse Time, for it is Allah Who is Time.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira reported Allah's Apostle (ﷺ) as saying:", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5717", "arabic": "حَدَّثَنَا حَجَّاجُ بْنُ الشَّاعِرِ، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَخْبَرَنَا مَعْمَرٌ، عَنْ أَيُّوبَ، عَنِ ابْنِ، سِيرِينَ عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ لاَ يَسُبُّ أَحَدُكُمُ الدَّهْرَ فَإِنَّ اللَّهَ هُوَ الدَّهْرُ وَلاَ يَقُولَنَّ أَحَدُكُمْ لِلْعِنَبِ الْكَرْمَ ‏.‏ فَإِنَّ الْكَرْمَ الرَّجُلُ الْمُسْلِمُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "None of you should abuse Time for it is Allah Who is the Time, and none of you should call 'Inab (grape) as al-karm, for karm is a Muslim person.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5718", "arabic": "حَدَّثَنَا عَمْرٌو النَّاقِدُ، وَابْنُ أَبِي عُمَرَ، قَالاَ حَدَّثَنَا سُفْيَانُ، عَنِ الزُّهْرِيِّ، عَنْ سَعِيدٍ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ لاَ تَقُولُوا كَرْمٌ ‏.‏ فَإِنَّ الْكَرْمَ قَلْبُ الْمُؤْمِنِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "Do not use the word karm (for wine) for worthy of respect is the heart of a believer.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5719", "arabic": "حَدَّثَنَا زُهَيْرُ بْنُ حَرْبٍ، حَدَّثَنَا جَرِيرٌ، عَنْ هِشَامٍ، عَنِ ابْنِ سِيرِينَ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ لاَ تُسَمُّوا الْعِنَبَ الْكَرْمَ فَإِنَّ الْكَرْمَ الرَّجُلُ الْمُسْلِمُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "Do not name grape as karm, for worthy of respect is a Muslim.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5720", "arabic": "حَدَّثَنَا زُهَيْرُ بْنُ حَرْبٍ، حَدَّثَنَا عَلِيُّ بْنُ حَفْصٍ، حَدَّثَنَا وَرْقَاءُ، عَنْ أَبِي الزِّنَادِ، عَنِ الأَعْرَجِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ لاَ يَقُولَنَّ أَحَدُكُمُ الْكَرْمُ ‏.‏ فَإِنَّمَا الْكَرْمُ قَلْبُ الْمُؤْمِنِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "None of you should use the word al-harin (for grape) for the heart of a believer is karm (worthy of respect).", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5721", "arabic": "وَحَدَّثَنَا ابْنُ رَافِعٍ، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَخْبَرَنَا مَعْمَرٌ، عَنْ هَمَّامِ بْنِ مُنَبِّهٍ، قَالَ هَذَا مَا حَدَّثَنَا أَبُو هُرَيْرَةَ، عَنْ رَسُولِ اللَّهِ صلى الله عليه وسلم ‏.‏ فَذَكَرَ أَحَادِيثَ مِنْهَا وَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ لاَ يَقُولَنَّ أَحَدُكُمْ لِلْعِنَبِ الْكَرْمَ ‏.‏ إِنَّمَا الْكَرْمُ الرَّجُلُ الْمُسْلِمُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "None of you should use the word al-karm for 'Inab, for karm (worthy of respect) is a Muslim person.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira reported from Allah's Messenger (ﷺ) various ahadith, one of which is this that he said:", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5722", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ خَشْرَمٍ، أَخْبَرَنَا عِيسَى، - يَعْنِي ابْنَ يُونُسَ - عَنْ شُعْبَةَ، عَنْ سِمَاكِ، بْنِ حَرْبٍ عَنْ عَلْقَمَةَ بْنِ وَائِلٍ، عَنْ أَبِيهِ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ لاَ تَقُولُوا الْكَرْمُ ‏.‏ وَلَكِنْ قُولُوا الْحَبَلَةُ ‏\"\"‏ ‏.‏ يَعْنِي الْعِنَبَ ‏.‏\"", "bengali": "", "english": "Do not say al-karm (for the word vine) but say al-habala (that is grape).", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "'Alqama b. Wa'il reported, from his father, Allah's Apostle (ﷺ) having said:", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5723", "arabic": "وَحَدَّثَنِيهِ زُهَيْرُ بْنُ حَرْبٍ، حَدَّثَنَا عُثْمَانُ بْنُ عُمَرَ، حَدَّثَنَا شُعْبَةُ، عَنْ سِمَاكٍ، قَالَ سَمِعْتُ عَلْقَمَةَ بْنَ وَائِلٍ، عَنْ أَبِيهِ، أَنَّ النَّبِيَّ صلى الله عليه وسلم قَالَ ‏ ‏ لاَ تَقُولُوا الْكَرْمُ ‏.‏ وَلَكِنْ قُولُوا الْعِنَبُ وَالْحَبَلَةُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "This hadith has been reported by Alqama b. Wa'il on the authority of his father with a different chain of transmitters and with a slight variation of wording.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5724", "arabic": "حَدَّثَنَا يَحْيَى بْنُ أَيُّوبَ، وَقُتَيْبَةُ، وَابْنُ، حُجْرٍ قَالُوا حَدَّثَنَا إِسْمَاعِيلُ، - وَهُوَ ابْنُ جَعْفَرٍ - عَنِ الْعَلاَءِ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ لاَ يَقُولَنَّ أَحَدُكُمْ عَبْدِي وَأَمَتِي ‏.‏ كُلُّكُمْ عَبِيدُ اللَّهِ وَكُلُّ نِسَائِكُمْ إِمَاءُ اللَّهِ وَلَكِنْ لِيَقُلْ غُلاَمِي وَجَارِيَتِي وَفَتَاىَ وَفَتَاتِي ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "None of you should say: My bondman and my slave-girl, for all of you are the bondmen of Allah, and all your women are the slave-girls of Allah; but say: My servant, my girl, and my young man and my young girl.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5725", "arabic": "وَحَدَّثَنِي زُهَيْرُ بْنُ حَرْبٍ، حَدَّثَنَا جَرِيرٌ، عَنِ الأَعْمَشِ، عَنْ أَبِي صَالِحٍ، عَنْ أَبِي، هُرَيْرَةَ قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ لاَ يَقُولَنَّ أَحَدُكُمْ عَبْدِي ‏.‏ فَكُلُّكُمْ عَبِيدُ اللَّهِ وَلَكِنْ لِيَقُلْ فَتَاىَ ‏.‏ وَلاَ يَقُلِ الْعَبْدُ رَبِّي ‏.‏ وَلَكِنْ لِيَقُلْ سَيِّدِي ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "None of you should say: My bondman, for all of you are the bondmen of Allah, but say: My young man, and the servant should not say: My Lord, but should say: My chief.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5726", "arabic": "وَحَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَأَبُو كُرَيْبٍ قَالاَ حَدَّثَنَا أَبُو مُعَاوِيَةَ، ح وَحَدَّثَنَا أَبُو سَعِيدٍ الأَشَجُّ، حَدَّثَنَا وَكِيعٌ، كِلاَهُمَا عَنِ الأَعْمَشِ، بِهَذَا الإِسْنَادِ وَفِي حَدِيثِهِمَا ‏\"\"‏ وَلاَ يَقُلِ الْعَبْدُ لِسَيِّدِهِ مَوْلاَىَ ‏\"\"‏ ‏.‏ وَزَادَ فِي حَدِيثِ أَبِي مُعَاوِيَةَ ‏\"\"‏ فَإِنَّ مَوْلاَكُمُ اللَّهُ عَزَّ وَجَلَّ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "My Lord, and Abu Mu'awiya made an addition:\" For it is Allah, the Exalted and Glorious, Who is your Lord.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "This hadith has been reported on the authority of al-A'mash with the same chain of transmitters, and the words are that the servant should not say to his chief:", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5727", "arabic": "وَحَدَّثَنَا مُحَمَّدُ بْنُ رَافِعٍ، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَخْبَرَنَا مَعْمَرٌ، عَنْ هَمَّامِ بْنِ مُنَبِّهٍ، قَالَ هَذَا مَا حَدَّثَنَا أَبُو هُرَيْرَةَ، عَنْ رَسُولِ اللَّهِ صلى الله عليه وسلم ‏.‏ فَذَكَرَ أَحَادِيثَ مِنْهَا وَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ لاَ يَقُلْ أَحَدُكُمُ اسْقِ رَبَّكَ أَطْعِمْ رَبَّكَ وَضِّئْ رَبَّكَ ‏.‏ وَلاَ يَقُلْ أَحَدُكُمْ رَبِّي ‏.‏ وَلْيَقُلْ سَيِّدِي مَوْلاَىَ وَلاَ يَقُلْ أَحَدُكُمْ عَبْدِي أَمَتِي ‏.‏ وَلْيَقُلْ فَتَاىَ فَتَاتِي غُلاَمِي ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "None of you should say: Supply drink to your lord, feed your lord, help your lord in performing ablution, and none of you should say: My Lord. He should say: My chief, my patron; and none of you should say: My bondman, my slave-girl, but simply say: My boy, my girl, my servant.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira reported Allah's Messenger (ﷺ) so many ahadith and one of them is this that Allah's Messenger (ﷺ) said:", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5728", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ح وَحَدَّثَنَا أَبُو كُرَيْبٍ، مُحَمَّدُ بْنُ الْعَلاَءِ حَدَّثَنَا أَبُو أُسَامَةَ، كِلاَهُمَا عَنْ هِشَامٍ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، قَالَتْ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"\"‏ لاَ يَقُولَنَّ أَحَدُكُمْ خَبُثَتْ نَفْسِي ‏.‏ وَلَكِنْ لِيَقُلْ لَقِسَتْ نَفْسِي ‏\"\"‏ ‏.‏ هَذَا حَدِيثُ أَبِي كُرَيْبٍ وَقَالَ أَبُو بَكْرٍ عَنِ النَّبِيِّ صلى الله عليه وسلم ‏.‏ وَلَمْ يَذْكُرْ ‏\"\"‏ لَكِنْ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "None of you should say: \"My soul has become evil,\" but he should say: \"My soul has become remorseless.\" This hadith has been transmitted on the authority of Abu Bakr with a slight variation of wording.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "'A'isha reported Allah's Messenger (ﷺ) having said:", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5729", "arabic": "وَحَدَّثَنَاهُ أَبُو كُرَيْبٍ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، بِهَذَا الإِسْنَادِ ‏.‏", "bengali": "", "english": "This hadith has been narrated on the authority of Abia Mu'iwiya with the same chain of transmitters.", "french": "", "indonesian": "", "russian": "", "urdu": "وکیع نے اعمش سے ،  انھوں نے ابو سفیان سے ، انھوں نے حضرت جا بر  رضی اللہ تعالیٰ عنہ سے روایت کی ،  ک", "grades": "", "reference": "", "international_number": "5729", "narrator_chain": "", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5730", "arabic": "وَحَدَّثَنِي أَبُو الطَّاهِرِ، وَحَرْمَلَةُ، قَالاَ أَخْبَرَنَا ابْنُ وَهْبٍ، أَخْبَرَنِي يُونُسُ، عَنِ ابْنِ، شِهَابٍ عَنْ أَبِي أُمَامَةَ بْنِ سَهْلِ بْنِ حُنَيْفٍ، عَنْ أَبِيهِ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ لاَ يَقُلْ أَحَدُكُمْ خَبُثَتْ نَفْسِي ‏.‏ وَلْيَقُلْ لَقِسَتْ نَفْسِي ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "None of you should say:\" My soul has become evil,\" but he should say:\" My soul has become remorseless.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Umama b. Sahl b. Hunaif, on the authority of his father, reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5731", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو أُسَامَةَ، عَنْ شُعْبَةَ، حَدَّثَنِي خُلَيْدُ بْنُ جَعْفَرٍ، عَنْ أَبِي نَضْرَةَ، عَنْ أَبِي سَعِيدٍ الْخُدْرِيِّ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ كَانَتِ امْرَأَةٌ مِنْ بَنِي إِسْرَائِيلَ قَصِيرَةٌ تَمْشِي مَعَ امْرَأَتَيْنِ طَوِيلَتَيْنِ فَاتَّخَذَتْ رِجْلَيْنِ مِنْ خَشَبٍ وَخَاتَمًا مِنْ ذَهَبٍ مُغْلَقٍ مُطْبَقٍ ثُمَّ حَشَتْهُ مِسْكًا وَهُوَ أَطْيَبُ الطِّيبِ فَمَرَّتْ بَيْنَ الْمَرْأَتَيْنِ فَلَمْ يَعْرِفُوهَا فَقَالَتْ بِيَدِهَا هَكَذَا ‏\"\"‏ ‏.‏ وَنَفَضَ شُعْبَةُ يَدَهُ ‏.‏\"", "bengali": "", "english": "There was a woman from Bani Isra'il who was short-statured and she walked in the company of two tall women with wooden sandals in her feet and a ring of gold made of plates with musk filled in them and then looked up, and musk is the best of scents; then she walked between two women and they (the people) did not recognise her, and she made a gesture with her hand like this, and Shu'ba shook his hand in order to give an indication how she shook her hand.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abd Sa'id Khudri reported Allah's Apostle (ﷺ) as saying:", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5732", "arabic": "حَدَّثَنَا عَمْرٌو النَّاقِدُ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، عَنْ شُعْبَةَ، عَنْ خُلَيْدِ بْنِ جَعْفَرٍ، وَالْمُسْتَمِرِّ، قَالاَ سَمِعْنَا أَبَا نَضْرَةَ، يُحَدِّثُ عَنْ أَبِي سَعِيدٍ الْخُدْرِيِّ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم ذَكَرَ امْرَأَةً مِنْ بَنِي إِسْرَائِيلَ حَشَتْ خَاتَمَهَا مِسْكًا وَالْمِسْكُ أَطْيَبُ الطِّيبِ ‏.‏\"", "bengali": "", "english": "Abu Sa'id Khudri reported that Allah's Messenger (ﷺ) made a mention of a woman of Bana Isra'il who had filled her ring with musk and musk is the most fragrant of the scents.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5733", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَزُهَيْرُ بْنُ حَرْبٍ، كِلاَهُمَا عَنِ الْمُقْرِئِ، قَالَ أَبُو بَكْرٍ حَدَّثَنَا أَبُو عَبْدِ الرَّحْمَنِ الْمُقْرِئُ، عَنْ سَعِيدِ بْنِ أَبِي أَيُّوبَ، حَدَّثَنِي عُبَيْدُ اللَّهِ بْنُ أَبِي جَعْفَرٍ، عَنْ عَبْدِ الرَّحْمَنِ الأَعْرَجِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنْ عُرِضَ عَلَيْهِ رَيْحَانٌ فَلاَ يَرُدُّهُ فَإِنَّهُ خَفِيفُ الْمَحْمِلِ طَيِّبُ الرِّيحِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "He who is presented with a flower should not reject it, for it is light to carry and pleasant in odour.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5734", "arabic": "حَدَّثَنِي هَارُونُ بْنُ سَعِيدٍ الأَيْلِيُّ، وَأَبُو طَاهِرٍ وَأَحْمَدُ بْنُ عِيسَى قَالَ أَحْمَدُ حَدَّثَنَا وَقَالَ الآخَرَانِ، أَخْبَرَنَا ابْنُ وَهْبٍ، أَخْبَرَنِي مَخْرَمَةُ، عَنْ أَبِيهِ، عَنْ نَافِعٍ، قَالَ كَانَ ابْنُ عُمَرَ إِذَا اسْتَجْمَرَ اسْتَجْمَرَ بِالأَلُوَّةِ غَيْرِ مُطَرَّاةٍ وَبِكَافُورٍ يَطْرَحُهُ مَعَ الأَلُوَّةِ ثُمَّ قَالَ هَكَذَا كَانَ يَسْتَجْمِرُ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏.‏\"", "bengali": "", "english": "This is how Allah's Messenger (ﷺ) fumigated.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Nafi' reported that when Ibn Umar wanted fumigation he got it from aloeswood without mixing anything with it, or he put camphor along with aloeswood and then said:", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5862", "arabic": "وحَدَّثَنِي وحَدَّثَنِي  أَبُو الطَّاهِرِ أَحْمَدُ بْنُ عَمْرِو بْنِ سَرْحٍ ،  وَحَرْمَلَةُ بْنُ يَح", "bengali": "", "english": "Abu Huraira reported:I heard Allah's Messenger (ﷺ) as saying: Allah, the Exalted and Glorious, said: The son of Adam abuses Dahr (the time), whereas I am Dahr since in My hand are the day and the night", "french": "", "indonesian": "", "russian": "", "urdu": "ابو سلمہ بن عبد الرحمٰن نے بتا یا کہ حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  نے کہا  :  میں نے رسول اللہ", "grades": "", "reference": "Book 40, Hadith 1", "international_number": "5862", "narrator_chain": "", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5863", "arabic": "وحَدَّثَنَاه وحَدَّثَنَاه  إِسْحَاقُ بْنُ إِبْرَاهِيمَ ،  وَابْنُ أَبِي عُمَرَ ، وَاللَّفْظُ لِابْنِ", "bengali": "", "english": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:Allah, the Exalted and Glorious, said: The son of Adam displeases Me by abusing Dahr (time), whereas I am Dahr--I alternate the night and the day", "french": "", "indonesian": "", "russian": "", "urdu": "سفیان نے زہری سے حدیث بیان کی انھوں نے ابن مسیب سے ، انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ سےر", "grades": "", "reference": "Book 40, Hadith 2", "international_number": "5863", "narrator_chain": "", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5864", "arabic": "وحَدَّثَنَا وحَدَّثَنَا  عَبْدُ بْنُ حُمَيْدٍ ، أَخْبَرَنَا  عَبْدُ الرَّزَّاقِ ، أَخْبَرَنَا  مَعْم", "bengali": "", "english": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:Allah, the Exalted and Glorious, said: The son of Adam causes Me pain as he says: Woe be upon the Time. None of you should say this: Woe be upon the Time, as I am the Time (because) I alternate the day and the night, and when I wish I can finish them up", "french": "", "indonesian": "", "russian": "", "urdu": "معمرنے ہمیں زہری سے خبر دی انھوں نے ابن مسیب سے ،  انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے ر", "grades": "", "reference": "Book 40, Hadith 3", "international_number": "5864", "narrator_chain": "", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5865", "arabic": "حَدَّثَنَا  قُتَيْبَةُ ، حَدَّثَنَا  الْمُغِيرَةُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ  أَبِي الزِّنَادِ ،", "bengali": "", "english": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:None of you should say: Woe be upon the Time, for verily Allah is the Time", "french": "", "indonesian": "", "russian": "", "urdu": "اعرج نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی کہ رسول اللہ  صلی اللہ علیہ وسلم  نے فر ما ی", "grades": "", "reference": "Book 40, Hadith 4", "international_number": "5865", "narrator_chain": "", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5866", "arabic": "وحَدَّثَنِي  زُهَيْرُ بْنُ حَرْبٍ ، حَدَّثَنَا  جَرِيرٌ ، عَنْ  هِشَامٍ ، عَنْ  ابْنِ سِيرِينَ ، عَن", "bengali": "", "english": "Abu Huraira reported Allah's Apostle (ﷺ) as saying:Do not curse Time, for it is Allah Who is Time", "french": "", "indonesian": "", "russian": "", "urdu": "ابن سیرین نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی ،  انھوں نے نبی  صلی اللہ علیہ وسلم  سے", "grades": "", "reference": "Book 40, Hadith 5", "international_number": "5866", "narrator_chain": "", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5867", "arabic": "حَدَّثَنَا  حَجَّاجُ بْنُ الشَّاعِرِ ، حَدَّثَنَا  عَبْدُ الرَّزَّاقِ ، أَخْبَرَنَا  مَعْمَرٌ ، عَنْ", "bengali": "", "english": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:None of you should abuse Time for it is Allah Who is the Time, and none of you should call 'Inab (grape) as al-karm, for karm is a Muslim person", "french": "", "indonesian": "", "russian": "", "urdu": "ایوب نے ابن سیرین سے ،  انھوں نے حضرت ابوہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی  ، کہا  :  رسول اللہ", "grades": "", "reference": "Book 40, Hadith 6", "international_number": "5867", "narrator_chain": "", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5868", "arabic": "حَدَّثَنَا  عَمْرٌو النَّاقِدُ ،  وَابْنُ أَبِي عُمَرَ ، قَالَا: حَدَّثَنَا  سُفْيَانُ ، عَنْ  الزُّ", "bengali": "", "english": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:Do not use the word karm (for wine) for worthy of respect is the heart of a believer", "french": "", "indonesian": "", "russian": "", "urdu": "سعید نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ سے ،  انھوں نے نبی  صلی اللہ علیہ وسلم  سے روایت کی ،  کہ", "grades": "", "reference": "Book 40, Hadith 7", "international_number": "5868", "narrator_chain": "", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5869", "arabic": "حَدَّثَنَا  زُهَيْرُ بْنُ حَرْبٍ ، حَدَّثَنَا  جَرِيرٌ ، عَنْ  هِشَامٍ ، عَنْ  ابْنِ سِيرِينَ ، عَنْ", "bengali": "", "english": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:Do not name grape as karm, for worthy of respect is a Muslim", "french": "", "indonesian": "", "russian": "", "urdu": "ہشا م نے ابن سیرین سے ،  انھوں نے حضرت ابوہریرہ رضی اللہ تعالیٰ عنہ  سے انھوں  نے نبی  صلی اللہ علیہ", "grades": "", "reference": "Book 40, Hadith 8", "international_number": "5869", "narrator_chain": "", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5870", "arabic": "حَدَّثَنَا  زُهَيْرُ بْنُ حَرْبٍ ، حَدَّثَنَا  عَلِيُّ بْنُ حَفْصٍ ، حَدَّثَنَا  وَرْقَاءُ ، عَنْ  أ", "bengali": "", "english": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:None of you should use the word al-harin (for grape) for the heart of a believer is karm (worthy of respect)", "french": "", "indonesian": "", "russian": "", "urdu": "اعرج نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہا  :  رسول اللہ  صلی اللہ علیہ وسلم  نے", "grades": "", "reference": "Book 40, Hadith 9", "international_number": "5870", "narrator_chain": "", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5871", "arabic": "وحَدَّثَنَا  ابْنُ رَافِعٍ ، حَدَّثَنَا  عَبْدُ الرَّزَّاقِ ، أَخْبَرَنَا  مَعْمَرٌ ، عَنْ  هَمَّامِ", "bengali": "", "english": "Abu Huraira reported from Allah's Messenger (ﷺ) various ahadith, one of which is this that he said:None of you should use the word al-karm for 'Inab, for karm (worthy of respect) is a Muslim person", "french": "", "indonesian": "", "russian": "", "urdu": "ہمام بن منبہ نے کہا  :  یہ احا دیث ہیں جو ابو ہریرہ رضی اللہ تعالیٰ عنہ  نے ہمیں رسول اللہ  صلی اللہ", "grades": "", "reference": "Book 40, Hadith 10", "international_number": "5871", "narrator_chain": "", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5872", "arabic": "حَدَّثَنَا  عَلِيُّ بْنُ خَشْرَمٍ ، أَخْبَرَنَا  عِيسَى يَعْنِي ابْنَ يُونُسَ ، عَنْ  شُعْبَةَ ، عَن", "bengali": "", "english": "Alqama b. Wa'il reported, from his father, Allah's Apostle (ﷺ) having said:Do not say al-karm (for the word vine) but say al-habala (that is grape)", "french": "", "indonesian": "", "russian": "", "urdu": "عیسیٰ بن یو نس نے شعبہ سے ،  انھوں نے سماک بن حرب سے ،  انھوں نے علقمہ بن وائل سے ،  انھوں نے اپنے و", "grades": "", "reference": "Book 40, Hadith 11", "international_number": "5872", "narrator_chain": "", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5873", "arabic": "وحَدَّثَنِيهِ  زُهَيْرُ بْنُ حَرْبٍ ، حَدَّثَنَا  عُثْمَانُ بْنُ عُمَرَ ، حَدَّثَنَا  شُعْبَةُ ، عَن", "bengali": "", "english": "This hadith has been reported by Alqama b. Wa'il on the authority of his father with a different chain of transmitters and with a slight variation of wording", "french": "", "indonesian": "", "russian": "", "urdu": "عثمان بن عمر نے کہا  :  ہمیں شعبہ نے سماک سے حدیث بیان کی  ، انھوں نے کہا  :  میں نے علمقہ بن وائل س", "grades": "", "reference": "Book 40, Hadith 12", "international_number": "5873", "narrator_chain": "", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5874", "arabic": "حَدَّثَنَا  يَحْيَي بْنُ أَيُّوبَ ،  وَقُتَيْبَةُ ،  وَابْنُ حُجْرٍ ، قَالُوا: حَدَّثَنَا  إِسْمَاعِ", "bengali": "", "english": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:None of you should say: My bondman and my slave-girl, for all of you are the bondmen of Allah, and all your women are the slave-girls of Allah; but say: My servant, my girl, and my young man and my young girl", "french": "", "indonesian": "", "russian": "", "urdu": "لا ء کے والد نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ سے روایت کی کہ رسول اللہ  صلی اللہ علیہ وسلم  نے", "grades": "", "reference": "Book 40, Hadith 13", "international_number": "5874", "narrator_chain": "", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5875", "arabic": "وحَدَّثَنِي  زُهَيْرُ بْنُ حَرْبٍ ، حَدَّثَنَا  جَرِيرٌ ، عَنْ  الْأَعْمَشِ ، عَنْ  أَبِي صَالِحٍ ،", "bengali": "", "english": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:None of you should say: My bondman, for all of you are the bondmen of Allah, but say: My young man, and the servant should not say: My Lord, but should say: My chief", "french": "", "indonesian": "", "russian": "", "urdu": "جریر اعمش سے ،  انھوں نے ابو صالح سے ،  انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ سے روایت کی ،  ک", "grades": "", "reference": "Book 40, Hadith 14", "international_number": "5875", "narrator_chain": "", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5876", "arabic": "وحَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ،  وَأَبُو كُرَيْبٍ ، قَالَا: حَدَّثَنَا  أَبُو مُعَاو", "bengali": "", "english": "This hadith has been reported on the authority of al-A'mash with the same chain of transmitters, and the words are that the servant should not say to his chief:My Lord, and Abu Mu'awiya made an addition:\" For it is Allah, the Exalted and Glorious, Who is your Lord", "french": "", "indonesian": "", "russian": "", "urdu": "ابو معاویہ اور وکیع دونوں نے اعمش سے اسی سند کے ساتھ روایت کی ان دونوں کی حدیث میں ہے ۔   \" غلا م اپ", "grades": "", "reference": "Book 40, Hadith 15", "international_number": "5876", "narrator_chain": "", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5877", "arabic": "وحَدَّثَنَا  مُحَمَّدُ بْنُ رَافِعٍ ، حَدَّثَنَا  عَبْدُ الرَّزَّاقِ ، أَخْبَرَنَا  مَعْمَرٌ ، عَنْ", "bengali": "", "english": "Abu Huraira reported Allah's Messenger (ﷺ) so many ahadith and one of them is this that Allah's Messenger (ﷺ) said:None of you should say: Supply drink to your lord, feed your lord, help your lord in performing ablution, and none of you should say: My Lord. He should say: My chief, my patron; and none of you should say: My bondman, my slave-girl, but simply say: My boy, my girl, my servant", "french": "", "indonesian": "", "russian": "", "urdu": "ہمام منبہ نے کہا  :  یہ احادیث ہیں جو ہمیں حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  نے رسول اللہ  صلی الل", "grades": "", "reference": "Book 40, Hadith 16", "international_number": "5877", "narrator_chain": "", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5878", "arabic": "حَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، حَدَّثَنَا  سُفْيَانُ بْنُ عُيَيْنَةَ . ح وحَدَّثَنَا", "bengali": "", "english": "A'isha reported Allah's Messenger (ﷺ) having said:None of you should say: \"My soul has become evil,\" but he should say: \"My soul has become remorseless.\" This hadith has been transmitted on the authority of Abu Bakr with a slight variation of wording", "french": "", "indonesian": "", "russian": "", "urdu": "ابو بکر بن ابی شیبہ نے کہا  :  ہمیں سفیان بن عیینہ نے حدیث بیان کی  ۔ ابو کریب محمد بن علاء نے کہا", "grades": "", "reference": "Book 40, Hadith 17", "international_number": "5878", "narrator_chain": "", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5879", "arabic": "وحَدَّثَنَاه  أَبُو كُرَيْبٍ ، حَدَّثَنَا  أَبُو مُعَاوِيَةَ بِهَذَا الْإِسْنَادِ.", "bengali": "", "english": "This hadith has been narrated on the authority of Abia Mu'iwiya with the same chain of transmitters", "french": "", "indonesian": "", "russian": "", "urdu": "ابو کریب نے کہا  :  ہمیں ابو معاویہ نے اسی سند کے ساتھ  ( یہی )  حدیث بیان کی ۔", "grades": "", "reference": "Book 40, Hadith 18", "international_number": "5879", "narrator_chain": "", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5880", "arabic": "وحَدَّثَنِي  أَبُو الطَّاهِرِ ،  وَحَرْمَلَةُ ، قَالَا: أَخْبَرَنَا  ابْنُ وَهْبٍ ، أَخْبَرَنِي  يُو", "bengali": "", "english": "Abu Umama b. Sahl b. Hunaif, on the authority of his father, reported Allah's Messenger (ﷺ) as saying:None of you should say:\" My soul has become evil,\" but he should say:\" My soul has become remorseless", "french": "", "indonesian": "", "russian": "", "urdu": "ابو امامہ بن سہل حنیف نے اپنے والد سے روایت کی کہ نبی  صلی اللہ علیہ وسلم  نے فر ما یا  :  :  \"  تم", "grades": "", "reference": "Book 40, Hadith 19", "international_number": "5880", "narrator_chain": "", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5881", "arabic": "حَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، حَدَّثَنَا  أَبُو أُسَامَةَ ، عَنْ  شُعْبَةَ ، حَدَّث", "bengali": "", "english": "Abd Sa'id Khudri reported Allah's Apostle (ﷺ) as saying:There was a woman from Bani Isra'il who was short-statured and she walked in the company of two tall women with wooden sandals in her feet and a ring of gold made of plates with musk filled in them and then looked up, and musk is the best of scents; then she walked between two women and they (the people) did not recognise her, and she made a gesture with her hand like this, and Shu'ba shook his hand in order to give an indication how she shook her hand", "french": "", "indonesian": "", "russian": "", "urdu": "ابو اسامہ نے شعبہ سے روایت کی  ،  کہا  :  مجھے خُلید بن جعفرنے ابو نضر ہ سے  ، انھوں نے حضرت ابوسعید", "grades": "", "reference": "Book 40, Hadith 20", "international_number": "5881", "narrator_chain": "", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5882", "arabic": "حَدَّثَنَا  عَمْرٌو النَّاقِدُ ، حَدَّثَنَا  يَزِيدُ بْنُ هَارُونَ ، عَنْ  شُعْبَةَ ، عَنْ  خُلَيْدِ", "bengali": "", "english": "Abu Sa'id Khudri reported that Allah's Messenger (ﷺ) made a mention of a woman of Bana Isra'il who had filled her ring with musk and musk is the most fragrant of the scents", "french": "", "indonesian": "", "russian": "", "urdu": "یزید بن ہارون نے شعبہ سے  ،  انھوں نے  خلید بن جعفر اور مستمر سے روایت کی ،  ان دونوں نے کہا  :  ہم", "grades": "", "reference": "Book 40, Hadith 21", "international_number": "5882", "narrator_chain": "", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5883", "arabic": "حَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ،  وَزُهَيْرُ بْنُ حَرْبٍ ، كِلَاهُمَا، عَنْ  الْمُقْرِ", "bengali": "", "english": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:He who is presented with a flower should not reject it, for it is light to carry and pleasant in odour", "french": "", "indonesian": "", "russian": "", "urdu": "عبد الرحمٰن اعرج نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی کہا  :  رسول اللہ  صلی اللہ علیہ", "grades": "", "reference": "Book 40, Hadith 22", "international_number": "5883", "narrator_chain": "", "chapter_intro": "The Book Concerning the Use of Correct Words"}
{"hadithnumber": "5884", "arabic": "حَدَّثَنِي  هَارُونُ بْنُ سَعِيدٍ الْأَيْلِيُّ ،  وَأَبُو طَاهِرٍ ،  وَأَحْمَدُ بْنُ عِيسَى ، قَالَ", "bengali": "", "english": "Nafi' reported that when Ibn Umar wanted fumigation he got it from aloeswood without mixing anything with it, or he put camphor along with aloeswood and then said:This is how Allah's Messenger (ﷺ) fumigated", "french": "", "indonesian": "", "russian": "", "urdu": "نافع نے کہا  :  حضرت ابن عمر رضی اللہ تعالیٰ عنہ  جب خوشبو کا دھواں لیتے تو عودکا دھواں لیتے  ، اس م", "grades": "", "reference": "Book 40, Hadith 23", "international_number": "5884", "narrator_chain": "", "chapter_intro": "The Book Concerning the Use of Correct Words"}
