{"hadithnumber": "3561", "text": "عبداللہ بن عباس رضی الله عنہ سے روایت ہے کہ  آیت «متاعا الی الحول غیر اخراج» ... «الی آخرہ» جس میں م"}
{"hadithnumber": "3562", "text": "ابو سعید خدری رضی الله عنہ کی بہن فریعہ بنت مالک رضی الله عنہا کہتی ہیں کہ  میرے شوہر کا قدوم  ( بست"}
{"hadithnumber": "3563", "text": "زینب بنت ابی سلمہ رضی الله عنہا سے روایت ہے  انہوں نے یہ  ( آنے والی )  تین حدیثیں بیان کیں: ۱- زینب"}
{"hadithnumber": "3564", "text": "ام عطیہ رضی الله عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”کوئی عورت شوہر کے سوا کس"}
{"hadithnumber": "3565", "text": "ام المؤمنین ام سلمہ رضی الله عنہا کہتی ہیں کہ  وہ نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جس عورت کا"}
{"hadithnumber": "3566", "text": "ام عطیہ رضی الله عنہا کہتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جو کوئی عورت اللہ اور آخر"}
{"hadithnumber": "3567", "text": "ام حکیم بنت اسید اپنی ماں سے روایت کرتی ہیں کہ  ان کے شوہر کا انتقال ہو گیا اور اس وقت ان کی آنکھوں"}
{"hadithnumber": "3568", "text": "ام المؤمنین ام سلمہ رضی الله عنہا کہتی ہیں کہ  قریش کی ایک عورت آئی اور اس نے کہا: اللہ کے رسول! میر"}
{"hadithnumber": "3569", "text": "زینب بنت ابی سلمہ رضی الله عنہا اپنی ماں سے روایت کرتی ہیں کہ  ایک عورت نبی اکرم صلی اللہ علیہ وسلم"}
{"hadithnumber": "3570", "text": "ام المؤمنین ام سلمہ رضی الله عنہا سے روایت ہے کہ  قریش کی ایک عورت رسول اللہ صلی اللہ علیہ وسلم کے پ"}
{"hadithnumber": "3571", "text": "زینب (زینب بنت ام سلمہ رضی الله عنہا) سے روایت ہے کہ  ایک عورت نے ام المؤمنین ام حبیبہ رضی اللہ عنہا"}
{"hadithnumber": "3572", "text": "ام عطیہ رضی الله عنہا کہتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے اس عورت کو جس کا شوہر مر گیا ہو عد"}
{"hadithnumber": "3573", "text": "عبداللہ بن عباس رضی الله عنہما  اللہ تعالیٰ کے اس قول «والذين يتوفون منكم ويذرون أزواجا وصية لأزواجه"}
{"hadithnumber": "3574", "text": "عکرمہ  آیت کریمہ: «والذين يتوفون منكم ويذرون أزواجا وصية لأزواجهم متاعا إلى الحول غير إخراج‏» کے متع"}
{"hadithnumber": "3575", "text": "عبدالرحمٰن بن عاصم سے روایت ہے کہ  فاطمہ بنت قیس رضی اللہ عنہا نے انہیں بتایا ہے کہ وہ بنی مخزوم کے"}
{"hadithnumber": "3576", "text": "ابوسلمہ بن عبدالرحمٰن کہتے ہیں کہ  فاطمہ بنت قیس رضی اللہ عنہما نے مجھ سے بیان کیا کہ وہ ابوعمرو بن"}
{"hadithnumber": "3577", "text": "فاطمہ رضی الله عنہا کہتی ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم سے عرض کیا: میرے شوہر نے مجھے ت"}
{"hadithnumber": "3578", "text": "شعبی کہتے ہیں کہ  میں فاطمہ بنت قیس رضی اللہ عنہا کے پاس آیا اور ان سے ان کے معاملہ میں رسول اللہ صل"}
{"hadithnumber": "3579", "text": "فاطمہ بنت قیس رضی الله عنہا کہتی ہیں کہ  میرے شوہر نے مجھے طلاق دے دی تو میں نے  ( شوہر کے گھر سے )"}
{"hadithnumber": "3580", "text": "جابر رضی الله عنہ کہتے ہیں کہ  میری خالہ کو طلاق ہو گئی  ( اسی دوران )  انہوں نے اپنے کھجوروں کے باغ"}
{"hadithnumber": "3581", "text": "ابوبکر بن حفص کہتے ہیں کہ  میں اور ابوسلمہ دونوں فاطمہ بنت قیس رضی اللہ عنہا کے پاس گئے، انہوں نے کہ"}
{"hadithnumber": "3582", "text": "زہری کہتے ہیں کہ مجھ سے عبیداللہ بن عبداللہ بن عتبہ نے بیان کیا کہ  عبداللہ بن عمرو بن عثمان نے سعید"}
{"hadithnumber": "3583", "text": "فاطمہ بنت ابی حبیش رضی الله عنہا کہتی ہیں کہ  وہ رسول اللہ صلی اللہ علیہ وسلم کے پاس آئیں اور آپ سے"}
{"hadithnumber": "3584", "text": "عبداللہ بن عباس رضی الله عنہما  قرآن پاک کی آیت: «ما ننسخ من آية أو ننسها نأت بخير منها أو مثلها» یع"}
{"hadithnumber": "3585", "text": "عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  میری بیوی حالت حیض میں تھی اسی دوران میں نے اسے طلاق دے د"}
{"hadithnumber": "3586", "text": "عبداللہ بن عمر رضی الله عنہما سے روایت ہے کہ  انہوں نے اپنی بیوی کو حالت حیض میں طلاق دے دی، اس بات"}
{"hadithnumber": "3587", "text": "نافع کہتے ہیں کہ  جب ابن عمر رضی اللہ عنہما سے کسی ایسے شخص کے متعلق پوچھا جاتا جس نے اپنی بیوی کو ح"}
{"hadithnumber": "3588", "text": "عبداللہ بن عمر رضی الله عنہما سے روایت ہے کہ  انہوں نے اپنی بیوی کو طلاق دی اور بیوی اس وقت حیض سے ت"}
{"hadithnumber": "3589", "text": "طاؤس کہتے ہیں کہ  انہوں نے عبداللہ بن عمر سے اس وقت سنا جب ان سے ایک ایسے آدمی کے بارے میں پوچھا گی"}
{"hadithnumber": "3590", "text": "عبداللہ بن عباس اور ابن عمر رضی الله عنہم سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے  ( اور عمرو"}
{"hadithnumber": "3591", "text": "سلمہ بن نفیل کندی رضی الله عنہ کہتے ہیں کہ  میں رسول اللہ صلی اللہ علیہ وسلم کے پاس بیٹھا ہوا تھا، ا"}
{"hadithnumber": "3592", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اللہ تعالیٰ نے قیامت تک"}
{"hadithnumber": "3593", "text": "ابوہریرہ رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”کچھ گھوڑے ایسے ہیں جو"}
