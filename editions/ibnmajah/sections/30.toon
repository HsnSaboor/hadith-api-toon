hadiths[count]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}:
3107,"حَدَّثَنَا الْحُسَيْنُ بْنُ الْحَسَنِ الْمَرْوَزِيُّ، حَدَّثَنَا ابْنُ أَبِي عَدِيٍّ، ح وَحَدَّثَنَا إِبْرَاهِيمُ بْنُ سَعِيدٍ الْجَوْهَرِيُّ، حَدَّثَنَا عَبْدُ الْوَهَّابِ، جَمِيعًا عَنْ رَاشِدٍ أَبِي مُحَمَّدٍ الْحِمَّانِيِّ، عَنْ شَهْرِ بْنِ حَوْشَبٍ، عَنْ أُمِّ الدَّرْدَاءِ، عَنْ أَبِي الدَّرْدَاءِ، قَالَ أَوْصَانِي خَلِيلِي ـ صلى الله عليه وسلم ـ ‏ ‏ لاَ تَشْرَبِ الْخَمْرَ فَإِنَّهَا مِفْتَاحُ كُلِّ شَرٍّ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۰۱۸، ومصباح الزجاجة:۱۰۷۵),,It was\nnarrated that Abu Darda’ said:,Chapters on Drinks
3108,"حَدَّثَنَا الْعَبَّاسُ بْنُ عُثْمَانَ الدِّمَشْقِيُّ، حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، حَدَّثَنَا مُنِيرُ بْنُ الزُّبَيْرِ، أَنَّهُ سَمِعَ عُبَادَةَ بْنَ نُسَىٍّ، يَقُولُ سَمِعْتُ خَبَّابَ بْنَ الأَرَتِّ، عَنْ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ أَنَّهُ قَالَ ‏ ‏ إِيَّاكَ وَالْخَمْرَ فَإِنَّ خَطِيئَتَهَا تَفْرَعُ الْخَطَايَا كَمَا أَنَّ شَجَرَتَهَا تَفْرَعُ الشَّجَرَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن الترمذی/المناقب ۶۹ (۳۹۲۵)،(تحفة الأشراف:۶۶۴۱)، وقد أخرجہ: مسند احمد (۴/۳۰۵)، سنن الدارمی/السیر ۶۷ (۲۵۵۲),,‘Ubadah\nbin Samit said:,Chapters on Drinks
3109,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ مَنْ شَرِبَ الْخَمْرَ فِي الدُّنْيَا لَمْ يَشْرَبْهَا فِي الآخِرَةِ إِلاَّ أَنْ يَتُوبَ ‏""""‏ ‏.‏""",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۵۹۰۸، ومصباح الزجاجة:۱۰۷۶)، وقد أخرجہ: صحیح البخاری/الجنائز ۷۶ (۱۳۴۹ تعلیقاً),,It was\nnarrated from Ibn ‘Umar that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Drinks
3110,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا يَحْيَى بْنُ حَمْزَةَ، حَدَّثَنِي زَيْدُ بْنُ وَاقِدٍ، أَنَّ خَالِدَ بْنَ عَبْدِ اللَّهِ بْنِ حُسَيْنٍ، حَدَّثَهُ قَالَ حَدَّثَنِي أَبُو هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ مَنْ شَرِبَ الْخَمْرَ فِي الدُّنْيَا لَمْ يَشْرَبْهَا فِي الآخِرَةِ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۰۱۲، ومصباح الزجاجة:۱۰۷۷)، وقد أخرجہ: مسند احمد (۴/۳۴۷),,Abu\nHurairah narrated that the Messenger of Allah (ﷺ) said:,Chapters on Drinks
3111,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَمُحَمَّدُ بْنُ الصَّبَّاحِ، قَالاَ حَدَّثَنَا مُحَمَّدُ بْنُ سُلَيْمَانَ بْنِ الأَصْبَهَانِيِّ، عَنْ سُهَيْلٍ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مُدْمِنُ الْخَمْرِ كَعَابِدِ وَثَنٍ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحج۶ (۱۸۷۶)، صحیح مسلم/الإیمان ۶۵ (۱۴۷)،(تحفة الأشراف:۱۲۲۶۶)، وقد أخرجہ: مسند احمد (۲/۲۸۶،۴۲۲،۴۹۶),,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Drinks
3112,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا سُلَيْمَانُ بْنُ عُتْبَةَ، حَدَّثَنِي يُونُسُ بْنُ مَيْسَرَةَ بْنِ حَلْبَسٍ، عَنْ أَبِي إِدْرِيسَ، عَنْ أَبِي الدَّرْدَاءِ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ لاَ يَدْخُلُ الْجَنَّةَ مُدْمِنُ خَمْرٍ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن الترمذی/المناقب ۶۸ (۳۹۱۷)،(تحفة الأشراف:۷۵۵۳)، وقد أخرجہ: مسند احمد (۲/۷۴،۱۰۴),,It was\nnarrated from Abu Darda’ that the Prophet (ﷺ) said:,Chapters on Drinks
3113,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ الدِّمَشْقِيُّ، حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، حَدَّثَنَا الأَوْزَاعِيُّ، عَنْ رَبِيعَةَ بْنِ يَزِيدَ، عَنِ ابْنِ الدَّيْلَمِيِّ، عَنْ عَبْدِ اللَّهِ بْنِ عَمْرٍو، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏""‏ مَنْ شَرِبَ الْخَمْرَ وَسَكِرَ لَمْ تُقْبَلْ لَهُ صَلاَةٌ أَرْبَعِينَ صَبَاحًا وَإِنْ مَاتَ دَخَلَ النَّارَ فَإِنْ تَابَ تَابَ اللَّهُ عَلَيْهِ وَإِنْ عَادَ فَشَرِبَ فَسَكِرَ لَمْ تُقْبَلْ لَهُ صَلاَةٌ أَرْبَعِينَ صَبَاحًا فَإِنْ مَاتَ دَخَلَ النَّارَ فَإِنْ تَابَ تَابَ اللَّهُ عَلَيْهِ وَإِنْ عَادَ فَشَرِبَ فَسَكِرَ لَمْ تُقْبَلْ لَهُ صَلاَةٌ أَرْبَعِينَ صَبَاحًا فَإِنْ مَاتَ دَخَلَ النَّارَ فَإِنْ تَابَ تَابَ اللَّهُ عَلَيْهِ وَإِنْ عَادَ كَانَ حَقًّا عَلَى اللَّهِ أَنْ يَسْقِيَهُ مِنْ رَدْغَةِ الْخَبَالِ يَوْمَ الْقِيَامَةِ ‏""‏ ‏.‏ قَالُوا يَا رَسُولَ اللَّهِ وَمَا رَدْغَةُ الْخَبَالِ قَالَ ‏""‏ عُصَارَةُ أَهْلِ النَّارِ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۴۰۴۰، ومصباح الزجاجة:۱۰۷۸)، وقد أخرجہ: صحیح مسلم/الحج ۸۵ (۱۳۷۲)، سنن الترمذی/الدعوات ۵۴ (۳۴۵۴)، موطا امام مالک/الجامع ۱ (۲),3113,It was\nnarrated from ‘Abdullah bin ‘Amr that the Messenger of Allah\n(ﷺ) said:,Chapters on Drinks
3114,"حَدَّثَنَا يَزِيدُ بْنُ عَبْدِ اللَّهِ الْيَمَامِيُّ، حَدَّثَنَا عِكْرِمَةُ بْنُ عَمَّارٍ، حَدَّثَنَا أَبُو كَثِيرٍ السُّحَيْمِيُّ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ الْخَمْرُ مِنْ هَاتَيْنِ الشَّجَرَتَيْنِ النَّخْلَةِ وَالْعِنَبَةِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۵۰۶۸)، وقد أخرجہ: صحیح مسلم/الحج ۸۹ (۱۳۸۶)، مسند احمد (۲/۲۷۹،۳۰۹،۳۵۷),,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Drinks
3115,"حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، عَنْ يَزِيدَ بْنِ أَبِي حَبِيبٍ، أَنَّ خَالِدَ بْنَ كَثِيرٍ الْهَمْدَانِيَّ، حَدَّثَهُ أَنَّ السَّرِيَّ بْنَ إِسْمَاعِيلَ حَدَّثَهُ أَنَّ الشَّعْبِيَّ حَدَّثَهُ أَنَّهُ، سَمِعَ النُّعْمَانَ بْنَ بَشِيرٍ، يَقُولُ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِنَّ مِنَ الْحِنْطَةِ خَمْرًا وَمِنَ الشَّعِيرِ خَمْرًا وَمِنَ الزَّبِيبِ خَمْرًا وَمِنَ التَّمْرِ خَمْرًا وَمِنَ الْعَسَلِ خَمْرًا ‏""""‏ ‏.‏""",Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۷۷، ومصباح الزجاجة:۱۰۷۹),,It was\nnarrated from Nu’man bin Bashir that the Messenger of Allah\n(ﷺ)\nsaid:,Chapters on Drinks
3116,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، وَمُحَمَّدُ بْنُ إِسْمَاعِيلَ، قَالاَ حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ عُمَرَ بْنِ عَبْدِ الْعَزِيزِ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَبْدِ اللَّهِ الْغَافِقِيِّ، وَأَبِي، طُعْمَةَ مَوْلاَهُمْ أَنَّهُمَا سَمِعَا ابْنَ عُمَرَ، يَقُولُ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لُعِنَتِ الْخَمْرُ عَلَى عَشَرَةِ أَوْجُهٍ بِعَيْنِهَا وَعَاصِرِهَا وَمُعْتَصِرِهَا وَبَائِعِهَا وَمُبْتَاعِهَا وَحَامِلِهَا وَالْمَحْمُولَةِ إِلَيْهِ وَآكِلِ ثَمَنِهَا وَشَارِبِهَا وَسَاقِيهَا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Daif,takhreej: «صحیح البخاری/الحج ۴۸ (۱۵۹۴)، الاعتصام ۲ (۷۲۷۵)، سنن ابی داود/المناسک ۹۶ (۲۰۳۱)،(تحفة الأشراف:۴۸۴۹)، وقد أخرجہ: مسند احمد (۳/۴۱۰),,It was\nnarrated from Ibn ‘Umar that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Drinks
3117,"حَدَّثَنَا مُحَمَّدُ بْنُ سَعِيدِ بْنِ يَزِيدَ بْنِ إِبْرَاهِيمَ التُّسْتَرِيُّ، حَدَّثَنَا أَبُو عَاصِمٍ، عَنْ شَبِيبٍ، سَمِعْتُ أَنَسَ بْنَ مَالِكٍ، - أَوْ حَدَّثَنِي أَنَسٌ، - قَالَ لَعَنَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ فِي الْخَمْرِ عَشَرَةً عَاصِرَهَا وَمُعْتَصِرَهَا وَالْمَعْصُورَةَ لَهُ وَحَامِلَهَا وَالْمَحْمُولَةَ لَهُ وَبَائِعَهَا وَالْمُبْتَاعَةَ لَهُ وَسَاقِيَهَا وَالْمُسْتَقَاةَ لَهُ ‏""‏ ‏.‏ حَتَّى عَدَّ عَشَرَةً مِنْ هَذَا الضَّرْبِ ‏.‏",Al-Albani: Mawdu; Muhammad Fouad Abd al-Baqi: Mawdu; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۵۰۸، ومصباح الزجاجة:۱۰۸۰),3117,Anas\nsaid:,Chapters on Drinks
3118,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا أَبُو مُعَاوِيَةَ، حَدَّثَنَا الأَعْمَشُ، عَنْ مُسْلِمٍ، عَنْ مَسْرُوقٍ، عَنْ عَائِشَةَ، قَالَتْ لَمَّا نَزَلَتِ الآيَاتُ مِنْ آخِرِ سُورَةِ الْبَقَرَةِ فِي الرِّبَا خَرَجَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ فَحَرَّمَ التِّجَارَةَ فِي الْخَمْرِ ‏.‏,Al-Albani: Very Daif Isnaad; Muhammad Fouad Abd al-Baqi: Very Daif Isnaad; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۷۲۴، ومصباح الزجاجة:۱۰۸۱),3118,It was\nnarrated that ‘Aishah said:,Chapters on Drinks
3119,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا سُفْيَانُ، عَنْ عَمْرِو بْنِ دِينَارٍ، عَنْ طَاوُسٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ بَلَغَ عُمَرَ أَنَّ سَمُرَةَ، بَاعَ خَمْرًا فَقَالَ قَاتَلَ اللَّهُ سَمُرَةَ أَلَمْ يَعْلَمْ أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ لَعَنَ اللَّهُ الْيَهُودَ حُرِّمَتْ عَلَيْهِمُ الشُّحُومُ فَجَمَلُوهَا فَبَاعُوهَا ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۰۸۹، ومصباح الزجاجة:۱۰۸۲),,It was\nnarrated that Ibn ‘Abbas said:,Chapters on Drinks
3120,"حَدَّثَنَا الْعَبَّاسُ بْنُ الْوَلِيدِ الدِّمَشْقِيُّ، حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ عَبْدِ الْقُدُّوسِ، حَدَّثَنَا ثَوْرُ بْنُ يَزِيدَ، عَنْ خَالِدِ بْنِ مَعْدَانَ، عَنْ أَبِي أُمَامَةَ الْبَاهِلِيِّ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لاَ تَذْهَبُ اللَّيَالِي وَالأَيَّامُ حَتَّى تَشْرَبَ طَائِفَةٌ مِنْ أُمَّتِي الْخَمْرَ يُسَمُّونَهَا بِغَيْرِ اسْمِهَا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الأضاحي ۹ (۵۵۵۸)، صحیح مسلم/الأضاحي ۳ (۱۹۶۶)، سنن النسائی/الضحایا ۲۷ (۴۴۲۰)،(تحفة الأشراف:۱۲۵۰)، وقد أخرجہ: سنن الترمذی/الأضاحي ۲ (۱۴۹۴)، مسند احمد (۳/۹۹،۱۱۵،۱۷۰،۱۷۸،۱۸۳،۱۸۹،۲۱۱،۲۱۴،۲۲۲،۲۵۵،۲۵۸،۲۶۷،۲۷۲،۲۷۹،۲۸۱)، سنن الدارمی/الأضاحي ۱ (۱۹۸۸),,It was\nnarrated from Abu Umamah Al-Bahili that the Messenger of Allah\n(ﷺ)\nsaid:,Chapters on Drinks
3121,"حَدَّثَنَا الْحُسَيْنُ بْنُ أَبِي السَّرِيِّ، حَدَّثَنَا عُبَيْدُ اللَّهِ، حَدَّثَنَا سَعْدُ بْنُ أَوْسٍ الْعَبْسِيُّ، عَنْ بِلاَلِ بْنِ يَحْيَى الْعَبْسِيِّ، عَنْ أَبِي بَكْرِ بْنِ حَفْصٍ، عَنِ ابْنِ مُحَيْرِيزٍ، عَنْ ثَابِتِ بْنِ السِّمْطِ، عَنْ عُبَادَةَ بْنِ الصَّامِتِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ يَشْرَبُ نَاسٌ مِنْ أُمَّتِي الْخَمْرَ بِاسْمٍ يُسَمُّونَهَا إِيَّاهُ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Hasan,takhreej: «سنن ابی داود/الأضاحي ۴ (۲۷۹۵)، سنن الترمذی/الأضاحي ۲۲ (۱۵۲۱)،(تحفة الأشراف:۳۱۶۶)، وقد أخرجہ: مسند احمد (۳/۳۵۶،۳۶۲)، سنن الدارمی/الأضاحي ۱ (۱۹۸۹),,It was\nnarrated from ‘Ubadah bin Samit that the Messenger of Allah\n(ﷺ)\nsaid:,Chapters on Drinks
3122,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ الزُّهْرِيِّ، عَنْ أَبِي سَلَمَةَ، عَنْ عَائِشَةَ، تَبْلُغُ بِهِ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ كُلُّ شَرَابٍ أَسْكَرَ فَهُوَ حَرَامٌ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۴۹۶۸،۱۷۷۳۱، ومصباح الزجاجة:۱۰۸۳)، وقد أخرجہ: مسند احمد (۶/۲۲۰),,"It was\nnarrated from ‘Aishah, narrating it from the Prophet (ﷺ):",Chapters on Drinks
3123,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا صَدَقَةُ بْنُ خَالِدٍ، حَدَّثَنَا يَحْيَى بْنُ الْحَارِثِ الذِّمَارِيُّ، سَمِعْتُ سَالِمَ بْنَ عَبْدِ اللَّهِ بْنِ عُمَرَ، يُحَدِّثُ عَنْ أَبِيهِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ كُلُّ مُسْكِرٍ حَرَامٌ ‏""""‏ ‏.‏""",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۳۹۳۸، ومصباح الزجاجة:۱۰۸۴)، وقد أخرجہ: مسند احمد (۲/۳۲۱،۶/۲۲۰),,Salim\nbin ‘Abdullah bin ‘Umar narrated that his father said:,Chapters on Drinks
3124,"حَدَّثَنَا يُونُسُ بْنُ عَبْدِ الأَعْلَى، حَدَّثَنَا ابْنُ وَهْبٍ، أَخْبَرَنَا ابْنُ جُرَيْجٍ، عَنْ أَيُّوبَ بْنِ هَانِئٍ، عَنْ مَسْرُوقٍ، عَنِ ابْنِ مَسْعُودٍ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ كُلُّ مُسْكِرٍ حَرَامٌ ‏""""‏ ‏.‏ قَالَ ابْنُ مَاجَهْ هَذَا حَدِيثُ الْمِصْرِيِّينَ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۴۳۸)، وقد أخرجہ: سنن الترمذی/الاضاحي۱۱ (۱۵۰۶),,It was\nnarrated from Ibn Mas’ud that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Drinks
3125,"حَدَّثَنَا عَلِيُّ بْنُ مَيْمُونٍ الرَّقِّيُّ، حَدَّثَنَا خَالِدُ بْنُ حَيَّانَ، عَنْ سُلَيْمَانَ بْنِ عَبْدِ اللَّهِ بْنِ الزِّبْرِقَانِ، عَنْ يَعْلَى بْنِ شَدَّادِ بْنِ أَوْسٍ، سَمِعْتُ مُعَاوِيَةَ، يَقُولُ سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ كُلُّ مُسْكِرٍ حَرَامٌ عَلَى كُلِّ مُؤْمِنٍ ‏""""‏ ‏.‏ وَهَذَا حَدِيثُ الرَّقِّيِّينَ ‏.‏""",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الضحایا ۱ (۲۷۸۸)، سنن الترمذی/الأضاحي ۱۹ (۱۵۱۸)، سنن النسائی/الفرع والعتیرة (۴۲۲۹)،(تحفة الأشراف:۱۱۲۴۴)، وقد أخرجہ: مسند احمد (۴/۲۱۵،۵/۷۶),,Mu’awiyah said:,Chapters on Drinks
3126,"حَدَّثَنَا سَهْلٌ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، عَنْ مُحَمَّدِ بْنِ عَمْرِو بْنِ عَلْقَمَةَ، عَنْ أَبِي سَلَمَةَ، عَنِ ابْنِ عُمَرَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ كُلُّ مُسْكِرٍ خَمْرٌ وَكُلُّ خَمْرٍ حَرَامٌ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/الأضاحي ۱ (۱۴۹۳)،(تحفة الأشراف:۱۷۳۴۳)، وقد أخرجہ: مسند احمد (۵/۲۳۹),,It was\nnarrated from Ibn ‘Umar that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Drinks
3127,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا أَبُو دَاوُدَ، حَدَّثَنَا شُعْبَةُ، عَنْ سَعِيدِ بْنِ أَبِي بُرْدَةَ، عَنْ أَبِيهِ، عَنْ أَبِي مُوسَى، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ كُلُّ مُسْكِرٍ حَرَامٌ ‏""""‏ ‏.‏""",Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۶۸۷، ومصباح الزجاجة:۱۰۸۴؍ أ)، وقد أخرجہ: مسند احمد (۴/۳۶۸),,It was\nnarrated from Abu Musa that the Messenger of Allah (ﷺ) said:,Chapters on Drinks
3128,"حَدَّثَنَا إِبْرَاهِيمُ بْنُ الْمُنْذِرِ الْحِزَامِيُّ، حَدَّثَنَا أَبُو يَحْيَى، زَكَرِيَّا بْنُ مَنْظُورٍ عَنْ أَبِي حَازِمٍ، عَنْ عَبْدِ اللَّهِ بْنِ عُمَرَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ كُلُّ مُسْكِرٍ حَرَامٌ وَمَا أَسْكَرَ كَثِيرُهُ فَقَلِيلُهُ حَرَامٌ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الأضاحي ۴ (۲۷۹۶)، سنن الترمذی/الأضاحي ۴ (۱۴۹۶)، سنن النسائی/الضحایا ۱۳ (۴۳۹۵)،(تحفة الأشراف:۴۲۹۷),,It was\nnarrated from ‘Abdullah bin ‘Umar that the Messenger of Allah\n(ﷺ) said:,Chapters on Drinks
3129,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ، حَدَّثَنَا أَنَسُ بْنُ عِيَاضٍ، حَدَّثَنِي دَاوُدُ بْنُ بَكْرٍ، عَنْ مُحَمَّدِ بْنِ الْمُنْكَدِرِ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ مَا أَسْكَرَ كَثِيرُهُ فَقَلِيلُهُ حَرَامٌ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۰۴۶، ومصباح الزجاجة:۱۰۸۵),,It was\nnarrated from Jabir bin ‘Abdullah that the Messenger of Allah\n(ﷺ)\nsaid:,Chapters on Drinks
3130,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ، حَدَّثَنَا أَنَسُ بْنُ عِيَاضٍ، حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ عُمَرَ، عَنْ عَمْرِو بْنِ شُعَيْبٍ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ مَا أَسْكَرَ كَثِيرُهُ فَقَلِيلُهُ حَرَامٌ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Sanad Daif; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/الأضاحي ۱۸ (۱۵۱۷)،(تحفة الأشراف:۴۸۶۶),,"It was\nnarrated from ‘Amr bin Shu’aib, from his father, from his\ngrandfather, that the Messenger of Allah (ﷺ) said:",Chapters on Drinks
3131,"حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ نَهَى أَنْ يُنْبَذَ التَّمْرُ وَالزَّبِيبُ جَمِيعًا وَنَهَى أَنْ يُنْبَذَ الْبُسْرُ وَالرُّطَبُ جَمِيعًا ‏.‏ قَالَ اللَّيْثُ بْنُ سَعْدٍ حَدَّثَنِي عَطَاءُ بْنُ أَبِي رَبَاحٍ الْمَكِّيُّ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ مِثْلَهُ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن الترمذی/الحج ۶۶ (۹۰۵)، الأضاحي ۸ (۱۵۰۲)، سنن النسائی/الضحایا ۱۴ (۴۳۹۷)،(تحفة الأشراف:۶۱۵۸)، وقد أخرجہ: مسند احمد (۱/۲۷۵),,,Chapters on Drinks
3132,"حَدَّثَنَا يَزِيدُ بْنُ عَبْدِ اللَّهِ الْيَمَامِيُّ، حَدَّثَنَا عِكْرِمَةُ بْنُ عَمَّارٍ، عَنْ أَبِي كَثِيرٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لاَ تَنْبِذُوا التَّمْرَ وَالْبُسْرَ جَمِيعًا وَانْبِذُوا كُلَّ وَاحِدٍ مِنْهُمَا عَلَى حِدَتِهِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۶۲ (۱۳۱۸)، سنن ابی داود/الضحایا ۷ (۲۸۰۹)، سنن الترمذی/الحج ۶۶ (۹۰۴)،(تحفة الأشراف:۲۹۳۳)، وقد أخرجہ: سنن النسائی/الضحایا ۱۵ (۴۳۹۸)، موطا امام مالک/الضحایا۵ (۹)، سنن الدارمی/الأضاحي ۵ (۱۹۹۹),,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Drinks
3133,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، حَدَّثَنَا الأَوْزَاعِيُّ، عَنْ يَحْيَى بْنِ أَبِي كَثِيرٍ، عَنْ عَبْدِ اللَّهِ بْنِ أَبِي قَتَادَةَ، عَنْ أَبِيهِ، أَنَّهُ سَمِعَ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ لاَ تَجْمَعُوا بَيْنَ الرُّطَبِ وَالزَّهْوِ وَلاَ بَيْنَ الزَّبِيبِ وَالتَّمْرِ وَانْبِذُوا كُلَّ وَاحِدٍ مِنْهُمَا عَلَى حِدَتِهِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/المناسک ۱۴ (۱۷۵۱)،(تحفة الأشراف:۱۵۳۸۶),,"It was\nnarrated from ‘Abdullah bin Abu Qatadah, from his father, that\nhe\nheard the Messenger of Allah (ﷺ) say:",Chapters on Drinks
3134,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، ح وَحَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الْمَلِكِ بْنِ أَبِي الشَّوَارِبِ، حَدَّثَنَا عَبْدُ الْوَاحِدِ بْنُ زِيَادٍ، قَالاَ حَدَّثَنَا عَاصِمٌ الأَحْوَلُ، حَدَّثَتْنَا بَنَانَةُ بِنْتُ يَزِيدَ الْعَبْشَمِيَّةُ، عَنْ عَائِشَةَ، قَالَتْ كُنَّا نَنْبِذُ لِرَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ فِي سِقَاءٍ فَنَأْخُذُ قَبْضَةً مِنْ تَمْرٍ أَوْ قَبْضَةً مِنْ زَبِيبٍ فَنَطْرَحُهَا فِيهِ ثُمَّ نَصُبُّ عَلَيْهِ الْمَاءَ فَنَنْبِذُهُ غُدْوَةً فَيَشْرَبُهُ عَشِيَّةً وَنَنْبِذُهُ عَشِيَّةً فَيَشْرَبُهُ غُدْوَةً ‏.‏ وَقَالَ أَبُو مُعَاوِيَةَ نَهَارًا فَيَشْرَبُهُ لَيْلاً أَوْ لَيْلاً فَيَشْرَبُهُ نَهَارًا ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۸۷۴، ومصباح الزجاجة:۱۰۸۶),3134,It was\nnarrated that ‘Aishah said:,Chapters on Drinks
3135,حَدَّثَنَا أَبُو كُرَيْبٍ، عَنْ إِسْمَاعِيلَ بْنِ صَبِيحٍ، عَنْ أَبِي إِسْرَائِيلَ، عَنْ أَبِي عُمَرَ الْبَهْرَانِيِّ، عَنِ ابْنِ عَبَّاسٍ، قَالَ كَانَ يُنْبَذُ لِرَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ فَيَشْرَبُهُ يَوْمَهُ ذَلِكَ وَالْغَدَ وَالْيَوْمَ الثَّالِثَ فَإِنْ بَقِيَ مِنْهُ شَىْءٌ أَهْرَاقَهُ أَوْ أَمَرَ بِهِ فَأُهْرِيقَ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/المناسک ۱۴ (۱۷۵۰)،۲۳ (۱۷۷۸)،(تحفة الأشراف:۱۷۹۲۴)، وقد أخرجہ: وقد تقدم بلفظ اتم برقم (۳۰۰۰/۳۰۷۵)، صحیح البخاری/الحیض ۷ (۲۹۴)، الحج ۳۳ (۱۵۶۰)،۸۱ (۱۶۵۱)، العمرة ۹ (۱۷۸۸)، الأضاحي ۳ (۵۵۴۸)،صحیح مسلم/الحج ۱۷ (۱۲۱۱)، الحیض ۱ (۳۴۷)، موطا امام مالک/الحج ۵۸ (۱۷۹)، مسند احمد (۶/۲۴۸)، سنن الدارمی/المناسک ۶۲ (۱۹۴۵),3135,It was\nnarrated that Ibn ‘Abbas said:,Chapters on Drinks
3136,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الْمَلِكِ بْنِ أَبِي الشَّوَارِبِ، حَدَّثَنَا أَبُو عَوَانَةَ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، قَالَ كَانَ يُنْبَذُ لِرَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ فِي تَوْرٍ مِنْ حِجَارَةٍ ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۹۷۳، ومصباح الزجاجة:۱۰۸۷)، وقد أخرجہ: مسند احمد (۱/۳۱۱،۳۱۲),3136,It was\nnarrated that Jabir bin ‘Abdullah said:,Chapters on Drinks
3137,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو، حَدَّثَنَا أَبُو سَلَمَةَ، عَنْ أَبِي هُرَيْرَةَ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ أَنْ يُنْبَذَ فِي النَّقِيرِ وَالْمُزَفَّتِ وَالدُّبَّاءِ وَالْحَنْتَمَةِ وَقَالَ ‏ ‏ كُلُّ مُسْكِرٍ حَرَامٌ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الشرکة ۳ (۲۴۸۸)،۱۶ (۲۵۰۷)، الجہاد ۱۹۱ (۳۰۷۵)، الذبائح ۱۵ (۵۴۹۸)،۱۸ (۵۵۰۳)،۲۳ (۵۵۰۹)،۳۶ (۵۵۴۳)،۳۷ (۵۵۴۴)، صحیح مسلم/الأضاحي ۴ (۱۹۶۸)، سنن ابی داود/الاضاحي ۱۵ (۲۸۲۱)، سنن الترمذی/الأحکام ۵ (۱۴۹۱) ۱۶ (۱۴۹۲)، السیر ۴۰ (۱۶۰۰)، سنن النسائی/الصید والذبائح ۱۷ (۴۳۰۲)، الضحایا ۱۵ (۴۳۹۶)،۲۶ (۴۴۱۴،۴۴۱۵)،(تحفة الأشراف:۳۵۶۱)، وقد أخرجہ: مسند احمد (۳/۴۶۳،۴۶۴،۴/۱۴۰،۱۴۲),,It was\nnarrated that Abu Hurairah said:,Chapters on Drinks
3138,حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ أَنْ يُنْبَذَ فِي الْمُزَفَّتِ وَالْقَرْعِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الوکالة ۱ (۲۳۰۰)، الشرکة ۱۲ (۲۵۰۰)، الأضاحي ۲ (۵۵۴۷)،۷ (۵۵۵۵)، صحیح مسلم/الأضاحي ۲ (۱۹۶۵)، سنن الترمذی/الاضاحي ۷ (۱۵۰۰)، سنن النسائی/الضحایا ۱۲ (۴۳۸۴)،(تحفة الأشراف:۹۹۵۵)، وقد أخرجہ: مسند احمد (۴/۱۴۹،۱۵۲)، سنن الدارمی/الأضاحي ۴ (۱۹۹۱),3138,It was\nnarrated that Ibn ‘Umar said:,Chapters on Drinks
3139,حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ، حَدَّثَنَا أَبِي، عَنِ الْمُثَنَّى بْنِ سَعِيدٍ، عَنْ أَبِي الْمُتَوَكِّلِ، عَنْ أَبِي سَعِيدٍ الْخُدْرِيِّ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنِ الشُّرْبِ فِي الْحَنْتَمِ وَالدُّبَّاءِ وَالنَّقِيرِ ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۷۳۷، ومصباح الزجاجة:۱۰۸۸)، وقد أخرجہ: مسند احمد (۶/۳۶۸),3139,It was\nnarrated that Abu Sa’eed Al-Khudri said:,Chapters on Drinks
3140,حَدَّثَنَا أَبُو بَكْرٍ، وَالْعَبَّاسُ بْنُ عَبْدِ الْعَظِيمِ الْعَنْبَرِيُّ، قَالاَ حَدَّثَنَا شَبَابَةُ، عَنْ شُعْبَةَ، عَنْ بُكَيْرِ بْنِ عَطَاءٍ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ يَعْمَرَ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنِ الدُّبَّاءِ وَالْحَنْتَمِ ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الاضاحي ۵ (۲۷۹۹)،(تحفة الأشراف:۱۱۲۱۱)، وقد أخرجہ: سنن النسائی/الضحایا ۱۲ (۴۳۸۹)، مسند احمد (۵/۳۶۸),3140,It was\nnarrated that ‘Abdur-Rahman bin Ya’mar said:,Chapters on Drinks
3141,"حَدَّثَنَا عَبْدُ الْحَمِيدِ بْنُ بَيَانٍ الْوَاسِطِيُّ، حَدَّثَنَا إِسْحَاقُ بْنُ يُوسُفَ، عَنْ شَرِيكٍ، عَنْ سِمَاكٍ، عَنِ الْقَاسِمِ بْنِ مُخَيْمِرَةَ، عَنِ ابْنِ بُرَيْدَةَ، عَنْ أَبِيهِ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ كُنْتُ نَهَيْتُكُمْ عَنِ الأَوْعِيَةِ فَانْتَبِذُوا فِيهِ وَاجْتَنِبُوا كُلَّ مُسْكِرٍ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الأضاحي ۲ (۱۹۶۲)، سنن ابی داود/الأضاحي ۵ (۲۷۹۷)، سنن النسائی/الضحایا ۱۲ (۴۳۸۳)،(تحفة الأشراف:۲۷۱۵)، وقد أخرجہ: مسند احمد (۳/۳۱۲،۳۲۷),,It was\nnarrated from Ibn Buraidah from his father that the Prophet\n(ﷺ)\nsaid:,Chapters on Drinks
3142,"حَدَّثَنَا يُونُسُ بْنُ عَبْدِ الأَعْلَى، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، أَنْبَأَنَا ابْنُ جُرَيْجٍ، عَنْ أَيُّوبَ بْنِ هَانِئٍ، عَنْ مَسْرُوقِ بْنِ الأَجْدَعِ، عَنِ ابْنِ مَسْعُودٍ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ إِنِّي كُنْتُ نَهَيْتُكُمْ عَنْ نَبِيذِ الأَوْعِيَةِ أَلاَ وَإِنَّ وِعَاءً لاَ يُحَرِّمُ شَيْئًا كُلُّ مُسْكِرٍ حَرَامٌ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الأضاحي ۶ (۲۸۰۴)، سنن الترمذی/الاضاحي ۶ (۱۴۹۸)، سنن النسائی/الضحایا ۷ (۴۳۷۷)،۸ (۴۳۷۸)،۹ (۴۳۷۹)،(تحفة الأشراف:۱۰۱۲۵)، وقد أخرجہ: مسند احمد (۱/۸۰،۱۰۸،۱۲۸،۹ ۱۴)، سنن الدارمی/الأضاحي ۳ (۱۹۹۵),,It was\nnarrated from Ibn Mas’ud that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Drinks
3143,حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، حَدَّثَنَا الْمُعْتَمِرُ بْنُ سُلَيْمَانَ، عَنْ أَبِيهِ، حَدَّثَتْنِي رُمَيْثَةُ، عَنْ عَائِشَةَ، أَنَّهَا قَالَتْ أَتَعْجِزُ إِحْدَاكُنَّ أَنْ تَتَّخِذَ كُلَّ عَامٍ مِنْ جِلْدِ أُضْحِيَّتِهَا سِقَاءً ثُمَّ قَالَتْ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ أَنْ يُنْبَذَ فِي الْجَرِّ وَفِي كَذَا وَفِي كَذَا إِلاَّ الْخَلَّ ‏.‏,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Hasan,takhreej: «سنن الترمذی/الأضاحي ۹ (۱۵۰۳)، سنن النسائی/الضحایا ۱۰ (۴۳۸۱)،(تحفة الأشراف:۱۰۰۶۴)، وقد أخرجہ: مسند احمد (۱/۹۵،۱۰۵،۱۲۵،۱۳۲،۱۵۲),3143,It was\nnarrated that ‘Aishah said:,Chapters on Drinks
3144,حَدَّثَنَا إِسْحَاقُ بْنُ مُوسَى الْخَطْمِيُّ، حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، حَدَّثَنَا الأَوْزَاعِيُّ، عَنْ يَحْيَى بْنِ أَبِي كَثِيرٍ، عَنْ أَبِي سَلَمَةَ، عَنْ أَبِي هُرَيْرَةَ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ أَنْ يُنْبَذَ فِي الْجِرَارِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن ابی داود/الأضاحي ۶ (۲۸۰۲)، سنن الترمذی/الأضاحي ۵ (۱۴۹۷)، سنن النسائی/الضحایا ۴ (۴۳۷۴)،(تحفة الأشراف:۱۷۹۰)، وقد أخرجہ: موطا امام مالک/الضحایا ۱ (۱)، مسند احمد (۴/۲۸۴،۲۸۹،۳۰۰،۳۰۱)، سنن الدارمی/الأضاحي ۳ (۱۹۹۲),3144,It was\nnarrated that Abu Hurairah said:,Chapters on Drinks
3145,"حَدَّثَنَا مُجَاهِدُ بْنُ مُوسَى، حَدَّثَنَا الْوَلِيدُ، عَنْ صَدَقَةَ أَبِي مُعَاوِيَةَ، عَنْ زَيْدِ بْنِ وَاقِدٍ، عَنْ خَالِدِ بْنِ عَبْدِ اللَّهِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ أُتِيَ النَّبِيُّ ـ صلى الله عليه وسلم ـ بِنَبِيذِ جَرٍّ يَنِشُّ فَقَالَ ‏ ‏ اضْرِبْ بِهَذَا الْحَائِطَ فَإِنَّ هَذَا شَرَابُ مَنْ لاَ يُؤْمِنُ بِاللَّهِ وَالْيَوْمِ الآخِرِ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Hasan,takhreej: «سنن ابی داود/الأضاحي ۶ (۲۸۰۵)، سنن الترمذی/الأضاحي ۹ (۱۵۰۴)، سنن النسائی/الضحایا ۱۱ (۴۳۸۲)،(تحفة الأشراف:۱۰۰۳۱)، وقد أخرجہ: مسند احمد (۱/۸۳،۱۰۱،۱۰۹،۱۲۷،۱۲۹،۱۵۰),,It was\nnarrated that Abu Hurairah said:,Chapters on Drinks
3146,"حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، عَنْ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ أَنَّهُ قَالَ ‏ ‏ غَطُّوا الإِنَاءَ وَأَوْكُوا السِّقَاءَ وَأَطْفِئُوا السِّرَاجَ وَأَغْلِقُوا الْبَابَ فَإِنَّ الشَّيْطَانَ لاَ يَحُلُّ سِقَاءً وَلاَ يَفْتَحُ بَابًا وَلاَ يَكْشِفُ إِنَاءً فَإِنْ لَمْ يَجِدْ أَحَدُكُمْ إِلاَّ أَنْ يَعْرُضَ عَلَى إِنَائِهِ عُودًا وَيَذْكُرَ اسْمَ اللَّهِ فَلْيَفْعَلْ فَإِنَّ الْفُوَيْسِقَةَ تُضْرِمُ عَلَى أَهْلِ الْبَيْتِ بَيْتَهُمْ ‏""""‏ ‏.‏""",Al-Albani: Very Daif Isnaad; Muhammad Fouad Abd al-Baqi: Very Daif Isnaad; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۲۹۸، ومصباح الزجاجة:۱۰۸۹)، وقد أخرجہ: مسند احمد (۳/۳۲،۸۶),,It was\nnarrated from Jabir bin ‘Abdullah that the Messenger of Allah\n(ﷺ)\nsaid:,Chapters on Drinks
3147,"حَدَّثَنَا عَبْدُ الْحَمِيدِ بْنُ بَيَانٍ الْوَاسِطِيُّ، حَدَّثَنَا خَالِدُ بْنُ عَبْدِ اللَّهِ، عَنْ سُهَيْلٍ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ أَمَرَنَا رَسُولُ اللَّهِ بِتَغْطِيَةِ الإِنَاءِ وَإِيكَاءِ السِّقَاءِ وَإِكْفَاءِ الإِنَاءِ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن الترمذی/الأضاحي ۱۰ (۱۵۰۵)،(تحفة الأشراف:۳۴۸۱),3147,It was\nnarrated that Abu Hurairah said:,Chapters on Drinks
3148,حَدَّثَنَا عِصْمَةُ بْنُ الْفَضْلِ، حَدَّثَنَا حَرَمِيُّ بْنُ عُمَارَةَ بْنِ أَبِي حَفْصَةَ، حَدَّثَنَا حَرِيشُ بْنُ خِرِّيتٍ، أَنْبَأَنَا ابْنُ أَبِي مُلَيْكَةَ، عَنْ عَائِشَةَ، قَالَتْ كُنْتُ أَصْنَعُ لِرَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ ثَلاَثَةَ آنِيَةٍ مِنَ اللَّيْلِ مُخَمَّرَةً إِنَاءً لِطَهُورِهِ وَإِنَاءً لِسِوَاكِهِ وَإِنَاءً لِشَرَابِهِ ‏.‏,Al-Albani: Sahih Isnaad; Muhammad Fouad Abd al-Baqi: Sahih Isnaad; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۳۰۱، ومصباح الزجاجة:۱۰۹۰),3148,It was\nnarrated that ‘Aishah said:,Chapters on Drinks
3149,"حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، عَنْ نَافِعٍ، عَنْ زَيْدِ بْنِ عَبْدِ اللَّهِ بْنِ عُمَرَ، عَنْ عَبْدِ اللَّهِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ أَبِي بَكْرٍ، عَنْ أُمِّ سَلَمَةَ، أَنَّهَا أَخْبَرَتْهُ عَنْ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ إِنَّ الَّذِي يَشْرَبُ فِي إِنَاءِ الْفِضَّةِ إِنَّمَا يُجَرْجِرُ فِي بَطْنِهِ نَارَ جَهَنَّمَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الأضاحي ۳ (۱۹۷۷)، سنن ابی داود/الأضاحي ۳ (۲۷۹۱)، سنن الترمذی/الضحایا ۲۴ (۱۵۲۳)، سنن النسائی/الضحایا (۴۳۶۶)،(تحفة الأشراف:۱۸۱۵۲)، وقد أخرجہ: مسند احمد (۶/۲۸۹،۳۰۱،۳۱۱)، سنن الدارمی/الأضاحي ۲ (۱۹۹۱),,It was\nnarrated from Umm Salamah that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Drinks
3150,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الْمَلِكِ بْنِ أَبِي الشَّوَارِبِ، حَدَّثَنَا أَبُو عَوَانَةَ، عَنْ أَبِي بِشْرٍ، عَنْ مُجَاهِدٍ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِي لَيْلَى، عَنْ حُذَيْفَةَ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنِ الشُّرْبِ فِي آنِيَةِ الذَّهَبِ وَالْفِضَّةِ وَقَالَ ‏ ‏ هِيَ لَهُمْ فِي الدُّنْيَا وَهِيَ لَكُمْ فِي الآخِرَةِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «انظر ماقبلہ،(تحفة الأشراف:۱۸۱۵۲),,It was\nnarrated that Hudhaifah said:,Chapters on Drinks
3151,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا غُنْدَرٌ، عَنْ شُعْبَةَ، عَنْ سَعْدِ بْنِ إِبْرَاهِيمَ، عَنْ نَافِعٍ، عَنِ امْرَأَةِ ابْنِ عُمَرَ، عَنْ عَائِشَةَ، عَنْ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ مَنْ شَرِبَ فِي إِنَاءِ فِضَّةٍ فَكَأَنَّمَا يُجَرْجِرُ فِي بَطْنِهِ نَارَ جَهَنَّمَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/العیدین ۲۳ (۹۵۴)، الأضاحي ۴ (۵۵۴۹)،۷ (۵۵۵۴)،۹ (۵۵۵۸)، صحیح مسلم/الأضاحي ۱ (۱۹۶۲)، سنن الترمذی/الأضاحي ۲ (۱۴۹۴)، سنن النسائی/الضحایا ۱۳ (۴۳۹۳)،(تحفة الأشراف:۱۱۴۵۵)، وقد أخرجہ: مسند احمد (۳/۱۱۳،۱۱۷),,It was\nnarrated from ‘Aishah that the Prophet (ﷺ) said:,Chapters on Drinks
3152,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا ابْنُ مَهْدِيٍّ، حَدَّثَنَا عَزْرَةُ بْنُ ثَابِتٍ الأَنْصَارِيُّ، عَنْ ثُمَامَةَ بْنِ عَبْدِ اللَّهِ، عَنْ أَنَسٍ، أَنَّهُ كَانَ يَتَنَفَّسُ فِي الإِنَاءِ ثَلاَثًا وَزَعَمَ أَنَسٌ أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ كَانَ يَتَنَفَّسُ فِي الإِنَاءِ ثَلاَثًا ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/العیدین ۲۳ (۹۸۵)، الصید ۱۷ (۵۰۰)، الأضاحي ۱۲ (۵۵۶۲)، الأیمان ۱۵ (۶۶۷۴)، التوحید ۱۳ (۷۴۰۰)، صحیح مسلم/الأضاحي ۱ (۱۹۶۰)، سنن النسائی/الأضاحي ۳ (۴۳۷۳)،(تحفة الأشراف:۳۲۵۱)، وقد أخرجہ: مسند احمد (۴/ ۳۱۲،۳۱۳),3152,,Chapters on Drinks
3153,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، وَمُحَمَّدُ بْنُ الصَّبَّاحِ، قَالاَ حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِيَةَ، حَدَّثَنَا رِشْدِينُ بْنُ كُرَيْبٍ، عَنْ أَبِيهِ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ شَرِبَ فَتَنَفَّسَ فِيهِ مَرَّتَيْنِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih Lighairihi; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۹۲۱، ومصباح الزجاجة:۱۰۹۱)، وقد أخرجہ: موطا امام مالک/الضحایا۳ (۵)، مسند احمد (۳/۴۵۴،۴/۳۴۱),3153,,Chapters on Drinks
3154,حَدَّثَنَا أَحْمَدُ بْنُ عَمْرِو بْنِ السَّرْحِ، حَدَّثَنَا ابْنُ وَهْبٍ، عَنْ يُونُسَ، عَنِ ابْنِ شِهَابٍ، عَنْ عُبَيْدِ اللَّهِ بْنِ عَبْدِ اللَّهِ بْنِ عُتْبَةَ، عَنْ أَبِي سَعِيدٍ الْخُدْرِيِّ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنِ اخْتِنَاثِ الأَسْقِيَةِ أَنْ يُشْرَبَ مِنْ أَفْوَاهِهَا ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۶۹۹، ومصباح الزجاجة:۱۰۹۲)، وقد أخرجہ: مسند احمد (۵/۷۷،۳۴۰،۳۴۱),3154,It was\nnarrated that Abu Sa’eed Al-Khudri said:,Chapters on Drinks
3155,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا أَبُو عَامِرٍ، حَدَّثَنَا زَمْعَةُ بْنُ صَالِحٍ، عَنْ سَلَمَةَ بْنِ وَهْرَامَ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنِ اخْتِنَاثِ الأَسْقِيَةِ وَإِنَّ رَجُلاً بَعْدَمَا نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنْ ذَلِكَ قَامَ مِنَ اللَّيْلِ إِلَى سِقَاءٍ فَاخْتَنَثَهُ فَخَرَجَتْ عَلَيْهِ مِنْهُ حَيَّةٌ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «أنظر حدیث رقم:(۳۱۲۰),3155,It was\nnarrated that Ibn ‘Abbas said:,Chapters on Drinks
3156,حَدَّثَنَا بِشْرُ بْنُ هِلاَلٍ الصَّوَّافُ، حَدَّثَنَا عَبْدُ الْوَارِثِ بْنُ سَعِيدٍ، عَنْ أَيُّوبَ، عَنْ عِكْرِمَةَ، عَنْ أَبِي هُرَيْرَةَ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنِ الشُّرْبِ مِنْ فِي السِّقَاءِ ‏.‏,Al-Albani: Daif Isnaad; Muhammad Fouad Abd al-Baqi: Daif Isnaad; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۸۳۳، ومصباح الزجاجة:۱۰۹۳),3156,It was\nnarrated that Abu Hurairah said:,Chapters on Drinks
3157,حَدَّثَنَا بَكْرُ بْنُ خَلَفٍ أَبُو بِشْرٍ، حَدَّثَنَا يَزِيدُ بْنُ زُرَيْعٍ، حَدَّثَنَا خَالِدٌ الْحَذَّاءُ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ نَهَى أَنْ يُشْرَبَ مِنْ فَمِ السِّقَاءِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih Agreed Upon,takhreej: «أنظر حدیث رقم:(۳۰۹۹),3157,It was\nnarrated that Ibn ‘Abbas said:,Chapters on Drinks
3158,حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ، عَنْ عَاصِمٍ، عَنِ الشَّعْبِيِّ، عَنِ ابْنِ عَبَّاسٍ، قَالَ سَقَيْتُ النَّبِيَّ ـ صلى الله عليه وسلم ـ مِنْ زَمْزَمَ فَشَرِبَ قَائِمًا ‏.‏ فَذَكَرْتُ ذَلِكَ لِعِكْرِمَةَ فَحَلَفَ بِاللَّهِ مَا فَعَلَ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۶۰۹، ومصباح الزجاجة:۱۰۹۴),3158,"‘Asim\nnarrated from Sha’bi, from Ibn ‘Abbas who said:",Chapters on Drinks
3159,حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، أَنْبَأَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ يَزِيدَ بْنِ يَزِيدَ بْنِ جَابِرٍ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِي عَمْرَةَ، عَنْ جَدَّةٍ، لَهُ يُقَالُ لَهَا كَبْشَةُ الأَنْصَارِيَّةُ أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ دَخَلَ عَلَيْهَا وَعِنْدَهَا قِرْبَةٌ مُعَلَّقَةٌ فَشَرِبَ مِنْهَا وَهُوَ قَائِمٌ فَقَطَعَتْ فَمَ الْقِرْبَةِ تَبْتَغِي بَرَكَةَ مَوْضِعِ فِي رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الأطعمة ۲۷ (۵۴۲۳)،۳۷ (۵۴۳۸)، الأضاحي ۱۶ (۶۶۸۷)، صحیح مسلم/الأضاحي ۵ (۱۹۷۱)، سنن الترمذی/الأضاحي ۱۴ (۱۵۱۱)، سنن النسائی/الضحایا ۳۶ (۴۴۳۶)،(تحفة الأشراف:۱۶۱۶۵)وقد أخرجہ: سنن ابی داود/الأضاحي۱۰ (۲۸۱۲)، موطا امام مالک/الضحایا ۴ (۶۷)، مسند احمد (۶/۱۰۲،۲۰۹)، سنن الدارمی/الأضاحي ۶ (۱۶۱۶۵),3159,,Chapters on Drinks
3160,حَدَّثَنَا حُمَيْدُ بْنُ مَسْعَدَةَ، حَدَّثَنَا بِشْرُ بْنُ الْمُفَضَّلِ، حَدَّثَنَا سَعِيدٌ، عَنْ قَتَادَةَ، عَنْ أَنَسٍ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ نَهَى عَنِ الشُّرْبِ قَائِمًا ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الأضاحي ۱۰ (۲۸۱۳)،۲۰ (۲۸۳۰)، سنن النسائی/الفرع والعتیرة ۱ (۴۲۳۵)،(تحفة الأشراف:۱۱۵۸۵)، وقد أخرجہ: مسند احمد (۵/۷۵،۷۶)، سنن الدارمی/الأضاحي ۶ (۲۰۰۱),3160,,Chapters on Drinks
3161,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، عَنِ الزُّهْرِيِّ، عَنْ أَنَسِ بْنِ مَالِكٍ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ أُتِيَ بِلَبَنٍ قَدْ شِيبَ بِمَاءٍ وَعَنْ يَمِينِهِ أَعْرَابِيٌّ وَعَنْ يَسَارِهِ أَبُو بَكْرٍ فَشَرِبَ ثُمَّ أَعْطَى الأَعْرَابِيَّ وَقَالَ ‏ ‏ الأَيْمَنُ فَالأَيْمَنُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الأضاحي ۹ (۲۸۱۱)،(تحفة الأشراف:۷۴۷۳)، وقد أخرجہ: صحیح البخاری/العید ین۲۲ (۹۸۲)، الاضاحي ۶ (۵۵۵۲)، سنن الترمذی/الضحایا ۹ (۱۵۰۸)، سنن النسائی/العیدین ۲۹ (۱۵۹۰)، الأضاحي ۲ (۴۳۷۱)، وقد أخرجہ: مسند احمد (۲/۱۰۸،۱۵۲),,"It was\nnarrated from Anas bin Malik that the Messenger of Allah (ﷺ)\nwas\nbrought some milk mixed with water. On his right there was a\nBedouin\nand on his left was Abu Bakr. He drank some, then he gave it\nto the\nBedouin and said:",Chapters on Drinks
3162,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ عَيَّاشٍ، حَدَّثَنَا ابْنُ جُرَيْجٍ، عَنِ ابْنِ شِهَابٍ، عَنْ عُبَيْدِ اللَّهِ بْنِ عَبْدِ اللَّهِ، عَنِ ابْنِ عَبَّاسٍ، قَالَ أُتِيَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ بِلَبَنٍ وَعَنْ يَمِينِهِ ابْنُ عَبَّاسٍ وَعَنْ يَسَارِهِ خَالِدُ بْنُ الْوَلِيدِ فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ لاِبْنِ عَبَّاسٍ ‏ ‏ أَتَأْذَنُ لِي أَنْ أَسْقِيَ خَالِدًا ‏""""‏ ‏.‏ قَالَ ابْنُ عَبَّاسٍ مَا أُحِبُّ أَنْ أُوثِرَ بِسُؤْرِ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ عَلَى نَفْسِي أَحَدًا ‏.‏ فَأَخَذَ ابْنُ عَبَّاسٍ فَشَرِبَ وَشَرِبَ خَالِدٌ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الضحایا ۲۱ (۲۸۳۵،۲۸۳۶)، سنن النسائی/العقیقة ۳ (۴۲۲۲،۴۲۲۳)،(تحفة الأشراف:۱۷۸۳۳)، وقد أخرجہ: سنن الترمذی/الأضاحي ۱۷ (۱۵۱۶)، مسند احمد (۶/۳۸۱،۴۲۲)، سنن الدارمی/الأضاحي ۹ (۲۰۰۹),,It was\nnarrated that Ibn ‘Abbas said:,Chapters on Drinks
3163,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا دَاوُدُ بْنُ عَبْدِ اللَّهِ، عَنْ عَبْدِ الْعَزِيزِ بْنِ مُحَمَّدٍ، عَنِ الْحَارِثِ بْنِ أَبِي ذُبَابٍ، عَنْ عَمِّهِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِذَا شَرِبَ أَحَدُكُمْ فَلاَ يَتَنَفَّسْ فِي الإِنَاءِ فَإِذَا أَرَادَ أَنْ يَعُودَ فَلْيُنَحِّ الإِنَاءَ ثُمَّ لْيَعُدْ إِنْ كَانَ يُرِيدُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن الترمذی/الأضاحي ۱۶ (۱۵۱۳)،(تحفة الأشراف:۱۷۸۳۳)، وقد أخرجہ: مسند احمد (۶/۳۱،۸۲،۱۵۸،۲۵۱)، سنن الدارمی/الأضاحي ۹ (۲۰۰۹),,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Drinks
3164,حَدَّثَنَا بَكْرُ بْنُ خَلَفٍ أَبُو بِشْرٍ، حَدَّثَنَا يَزِيدُ بْنُ زُرَيْعٍ، عَنْ خَالِدٍ الْحَذَّاءِ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنِ التَّنَفُّسِ فِي الإِنَاءِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «صحیح البخاری/العقیقة ۲ (۷۱ ۵۴)، سنن ابی داود/الضحایا۲۱ (۲۸۳۹)، سنن الترمذی/الضحایا ۱۷ (۱۵۱۵)،(تحفة الأشراف:۴۴۸۵)، وقد أخرجہ: سنن النسائی/العقیقة ۱ (۴۲۱۹)، مسند احمد (۴/۱۷،۱۸،۲۱۴)، سنن الدارمی/الأضاحي ۹ (۲۰۱۰),3164,It was\nnarrated that Ibn ‘Abbas said:,Chapters on Drinks
3165,حَدَّثَنَا أَبُو بَكْرِ بْنُ خَلاَّدٍ الْبَاهِلِيُّ، حَدَّثَنَا سُفْيَانُ، عَنْ عَبْدِ الْكَرِيمِ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ أَنْ يُنْفَخَ فِي الإِنَاءِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Hasan,takhreej: «سنن الترمذی/الأضاحي ۲۳ (۱۵۲۲)، سنن ابی داود/الضحایا ۲۱ (۲۸۳۷،۲۸۳۸)، سنن النسائی/العقیقة ۴ (۴۲۲۵)،(تحفة الأشراف:۴۵۸۱)، وقد أخرجہ: صحیح البخاری/العقیقة ۲ (۵۴۷۲)، مسند احمد (۵/۷،۸،۱۲،۱۷،۱۸،۲۲)، سنن الدارمی/الأضاحي ۹ (۲۰۱۲),3165,It was\nnarrated that Ibn ‘Abbas said:,Chapters on Drinks
3166,حَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ عَبْدِ الرَّحْمَنِ الْمُحَارِبِيُّ، عَنْ شَرِيكٍ، عَنْ عَبْدِ الْكَرِيمِ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ لَمْ يَكُنْ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ يَنْفُخُ فِي الشَّرَابِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۸۳۲),3166,It was\nnarrated that Ibn ‘Abbas said:,Chapters on Drinks
3167,"حَدَّثَنَا مُحَمَّدُ بْنُ الْمُصَفَّى الْحِمْصِيُّ، حَدَّثَنَا بَقِيَّةُ، عَنْ مُسْلِمِ بْنِ عَبْدِ اللَّهِ، عَنْ زِيَادِ بْنِ عَبْدِ اللَّهِ، عَنْ عَاصِمِ بْنِ مُحَمَّدِ بْنِ زَيْدِ بْنِ عَبْدِ اللَّهِ بْنِ عُمَرَ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، قَالَ نَهَانَا رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ أَنْ نَشْرَبَ عَلَى بُطُونِنَا وَهُوَ الْكَرْعُ وَنَهَانَا أَنْ نَغْتَرِفَ بِالْيَدِ الْوَاحِدَةِ وَقَالَ ‏ ‏ لاَ يَلَغْ أَحَدُكُمْ كَمَا يَلَغُ الْكَلْبُ وَلاَ يَشْرَبْ بِالْيَدِ الْوَاحِدَةِ كَمَا يَشْرَبُ الْقَوْمُ الَّذِينَ سَخِطَ اللَّهُ عَلَيْهِمْ وَلاَ يَشْرَبْ بِاللَّيْلِ مِنْ إِنَاءٍ حَتَّى يُحَرِّكَهُ إِلاَّ أَنْ يَكُونَ إِنَاءً مُخَمَّرًا وَمَنْ شَرِبَ بِيَدِهِ وَهُوَ يَقْدِرُ عَلَى إِنَاءٍ يُرِيدُ التَّوَاضُعَ كَتَبَ اللَّهُ لَهُ بِعَدَدِ أَصَابِعِهِ حَسَنَاتٍ وَهُوَ إِنَاءُ عِيسَى ابْنِ مَرْيَمَ عَلَيْهِمَا السَّلاَمُ إِذْ طَرَحَ الْقَدَحَ فَقَالَ أُفٍّ هَذَا مَعَ الدُّنْيَا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الضحایا ۱۰ (۲۸۱۳)،۲۰ (۲۸۳۰)، سنن النسائی/الفرع والعتیرة ۱ (۴۲۳۵)،(تحفة الأشراف:۱۱۵۸۶)، وقد أخرجہ: مسند احمد (۵/۷۵،۷۶)، سنن الدارمی/الأضي ۶ (۲۰۰۱),,"It was\nnarrated from ‘Asim bin Muhammad bin Zaid bin ‘Abdullah, from\nhis\nfather, that his grandfather said:",Chapters on Drinks
3168,"حَدَّثَنَا أَحْمَدُ بْنُ مَنْصُورٍ أَبُو بَكْرٍ، حَدَّثَنَا يُونُسُ بْنُ مُحَمَّدٍ، حَدَّثَنَا فُلَيْحُ بْنُ سُلَيْمَانَ، عَنْ سَعِيدِ بْنِ الْحَارِثِ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، قَالَ دَخَلَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَلَى رَجُلٍ مِنَ الأَنْصَارِ وَهُوَ يُحَوِّلُ الْمَاءَ فِي حَائِطِهِ فَقَالَ لَهُ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِنْ كَانَ عِنْدَكَ مَاءٌ بَاتَ فِي شَنٍّ فَاسْقِنَا وَإِلاَّ كَرَعْنَا ‏""""‏ ‏.‏ قَالَ عِنْدِي مَاءٌ بَاتَ فِي شَنٍّ ‏.‏ فَانْطَلَقَ وَانْطَلَقْنَا مَعَهُ إِلَى الْعَرِيشِ فَحَلَبَ لَهُ شَاةً عَلَى مَاءٍ بَاتَ فِي شَنٍّ فَشَرِبَ ثُمَّ فَعَلَ مِثْلَ ذَلِكَ بِصَاحِبِهِ الَّذِي مَعَهُ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/العقیقة ۴ (۵۴۷۴)، صحیح مسلم/الأضاحي ۶ (۱۹۷۶)، سنن ابی داود/الأضاحي ۲۰ (۲۸۳۱)، سنن النسائی/الفرع والعتیرة (۴۲۲۷)،(تحفة الأشراف:۱۳۱۲۷)، وقد أخرجہ: سنن الترمذی/الأضاحي ۱۵ (۱۵۱۲)، مسند احمد (۲/۲۳۹،۲۵۴،۲۸۵)، سنن الدارمی/الأضاحي ۸ (۲۰۰۷),,It was\nnarrated that Jabir bin ‘Abdullah said:,Chapters on Drinks
3169,"حَدَّثَنَا وَاصِلُ بْنُ عَبْدِ الأَعْلَى، حَدَّثَنَا ابْنُ فُضَيْلٍ، عَنْ لَيْثٍ، عَنْ سَعِيدِ بْنِ عَامِرٍ، عَنِ ابْنِ عُمَرَ، قَالَ مَرَرْنَا عَلَى بِرْكَةٍ فَجَعَلْنَا نَكْرَعُ فِيهَا فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لاَ تَكْرَعُوا وَلَكِنِ اغْسِلُوا أَيْدِيَكُمْ ثُمَّ اشْرَبُوا فِيهَا فَإِنَّهُ لَيْسَ إِنَاءٌ أَطْيَبَ مِنَ الْيَدِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۶۴۸، ومصباح الزجاجة:۱۰۹۶),,It was\nnarrated that Ibn ‘Umar said:,Chapters on Drinks
3170,"حَدَّثَنَا أَحْمَدُ بْنُ عَبْدَةَ، وَسُوَيْدُ بْنُ سَعِيدٍ، قَالاَ حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ، عَنْ ثَابِتٍ الْبُنَانِيِّ، عَنْ عَبْدِ اللَّهِ بْنِ رَبَاحٍ، عَنْ أَبِي قَتَادَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ سَاقِي الْقَوْمِ آخِرُهُمْ شُرْبًا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الصید ۱۱ (۱۹۵۵)، سنن ابی داود/الأضاحي ۱۲ (۲۸۱۵)، سنن الترمذی/الدیات ۱۴ (۱۴۰۹)، سنن النسائی/الضحایا ۲۱ (۴۴۱۰)،۲۶ (۴۴۱۹)،(تحفة الأشراف:۴۸۱۷)، وقد أخرجہ: مسند احمد (۴/۱۲۳،۱۲۴،۱۲۵)، سنن الدارمی/الأضاحي۱۰ (۲۰۱۳),,It was\nnarrated from Abu Qatadah that the Messenger of Allah (ﷺ) said:,Chapters on Drinks
3171,حَدَّثَنَا أَحْمَدُ بْنُ سِنَانٍ، حَدَّثَنَا زَيْدُ بْنُ الْحُبَابِ، حَدَّثَنَا مِنْدَلُ بْنُ عَلِيٍّ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ، عَنِ الزُّهْرِيِّ، عَنْ عُبَيْدِ اللَّهِ بْنِ عَبْدِ اللَّهِ، عَنِ ابْنِ عَبَّاسٍ، قَالَ كَانَ لِرَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ قَدَحٌ مِنْ قَوَارِيرَ يَشْرَبُ فِيهِ ‏.‏,Al-Albani: Very Daif Isnaad; Muhammad Fouad Abd al-Baqi: Very Daif Isnaad; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۲۹۳، ومصباح الزجاجة:۱۰۹۷),3171,It was\nnarrated that Ibn ‘Abbas said:,Chapters on Drinks
3371,حَدَّثَنَا الْحُسَيْنُ بْنُ الْحَسَنِ الْمَرْوَزِيُّ،‏‏‏‏ حَدَّثَنَا بْنُ أَبِي عَدِيٍّ . ح وحَدَّثَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Lighairihi; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۹۸۵، ومصباح الزجاجة:۱۱۶۸),3371,,Chapters on Drinks
3372,حَدَّثَنَا الْعَبَّاسُ بْنُ عُثْمَانَ الدِّمَشْقِيُّ،‏‏‏‏ حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ،‏‏‏‏ ح,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۵۱۵، ومصباح الزجاجة:۱۱۶۹),3372,,Chapters on Drinks
3373,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ،‏‏‏‏ عَنْ عُبَيْدِ ال,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الأشربة ۸ (۲۰۰۳)،(تحفة الأشراف:۷۹۵۱)، وقد أخرجہ: صحیح البخاری/الأشربة ۱ (۵۵۷۵)، سنن الترمذی/الأشربة ۱ (۱۸۶۱)، موطا امام مالک/الأشربة ۴ (۱۱)، مسند احمد (۲/۱۹،۲۲،۲۸،۵/۹۸،۱۰۶،۱۳۳،۱۴۲)، سنن الدارمی/الأشربة ۳ (۲۱۳۵),3373,,Chapters on Drinks
3374,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ،‏‏‏‏ حَدَّثَنَا يَحْيَى بْنُ حَمْزَةَ،‏‏‏‏ قَالَ:‏‏‏‏ حَدَّثَنِي زَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۳۰۰، ومصباح الزجاجة:۱۱۷۰),3374,,Chapters on Drinks
3375,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ وَمُحَمَّدُ بْنُ الصَّبَّاحِ،‏‏‏‏ قَالَا:‏‏‏‏ حَدَّ,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۷۴۸، ومصباح الزجاجة:۱۱۷۱),3375,,Chapters on Drinks
3376,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ،‏‏‏‏ حَدَّثَنَا سُلَيْمَانُ بْنُ عُتْبَةَ،‏‏‏‏ حَدَّثَنِي يُونُسُ ب,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۹۴۶، ومصباح الزجاجة:۱۱۷۲)، وقد أخرجہ: مسند احمد (۲/۱۸۹،۶/۴۴۱),3376,,Chapters on Drinks
3377,حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ الدِّمَشْقِيُّ،‏‏‏‏ حَدَّثَنَا الْوَلِيدُ بْنُ مُسْل,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن النسائی/الأشربة ۴۳ (۵۶۶۷)،(تحفة الأشراف:۸۸۴۳)، وقد أخرجہ: سنن الترمذی/الأشربة ۱ (۱۸۶۲)، مسند احمد (۲/۳۵،۱۷۶،۱۸۹،۱۹۷،۵/۱۷۱،۶/۴۶۰),3377,,Chapters on Drinks
3378,حَدَّثَنَا يَزِيدُ بْنُ عَبْدِ اللَّهِ الْيَمَامِيُّ،‏‏‏‏ حَدَّثَنَا عِكْرِمَةُ بْنُ عَمَّارٍ،‏‏‏‏ ح,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الأشربة ۴ (۱۹۸۵)، سنن ابی داود/الأشربة ۴ (۳۶۷۸)، سنن الترمذی/الأشربة ۸ (۱۸۷۵)، سنن النسائی/الأشربة ۱۹ (۵۵۷۵)،(تحفة الأشراف:۱۴۸۴۱)، وقد أخرجہ: مسند احمد (۲/۲۷۹،۴۰۸،۴۰۹،۴۷۴،۴۹۶،۵۱۸،۵۲۶)، سنن الدارمی/ الأشربة ۷ (۲۱۴۱),3378,,Chapters on Drinks
3379,حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ،‏‏‏‏ أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ،‏‏‏‏ عَنْ يَزِيدَ بْنِ أَبِي,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Hasan,takhreej: «سنن ابی داود/الأشربة ۴ (۳۶۷۶،۳۶۷۷)، سنن الترمذی/الأشربة ۸ (۱۸۷۲،۱۸۷۳)،(تحفة الأشراف:۱۱۶۲۶)، وقد أخرجہ: مسند احمد (۴/۲۶۷،۲۷۳),3379,,Chapters on Drinks
3380,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ وَمُحَمَّدُ بْنُ إِسْمَاعِيل،‏‏‏‏ قَالَا:‏‏‏‏ حَدَّثَنَا وَكِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۲۹۶، ومصباح الزجاجة:۱۱۷۳)، وقد أخرجہ: سنن ابی داود/الأشربة ۲ (۳۶۷۴)، مسند احمد (۲/۲۵،۷۱)، دون قولہ: '' أکل ثمنہا'',3380,,Chapters on Drinks
3381,حَدَّثَنَا مُحَمَّدُ بْنُ سَعِيدِ بْنِ يَزِيدَ بْنِ إِبْرَاهِيمَ التُّسْتَرِيُّ،‏‏‏‏ حَدَّثَنَا أَبُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Hasan,takhreej: «سنن الترمذی/البیوع ۵۹ (۱۲۹۵)،(تحفة الأشراف:۹۰۰)، وقد أخرجہ: مسند احمد (۱/۳۱۶،۲/۹۷),3381,,Chapters on Drinks
3382,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ قَالَا:‏‏‏‏ حَدَّثَنَ,Al-Albani: Sahih Hadith; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/البیوع ۱۰۵ (۲۲۲۶)، صحیح مسلم/المساقاة ۱۲ (۱۵۸۰)، سنن ابی داود/البیوع ۶۶ (۳۴۹۰)، سنن النسائی/البیوع ۸۹ (۴۶۶۹)،(تحفة الأشراف:۱۷۶۳۶),3382,,Chapters on Drinks
3383,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا سُفْيَانُ،‏‏‏‏ عَنْ عَمْرِو بْنِ دِينَار,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/البیوع ۱۰۳ (۲۲۲۳)، الأنبیاء ۵۰ (۳۴۵۷)، صحیح مسلم/المساقاة ۱۳ (۱۵۸۲)، سنن النسائی/الفرع والعتیرة ۸ (۴۲۶۲)،(تحفة الأشراف:۱۰۵۰۱)، وقد أخرجہ: مسند احمد (۱/۲۵)، سنن الدارمی/الأشرابة ۹ (۲۱۵۰),3383,,Chapters on Drinks
3384,حَدَّثَنَا الْعَبَّاسُ بْنُ الْوَلِيدِ الدِّمَشْقِيُّ،‏‏‏‏ حَدَّثَنَا عَبْدُ السَّلَامِ بْنُ عَبْدِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۸۵۸، ومصباح الزجاجة:۱۱۷۴),3384,,Chapters on Drinks
3385,حَدَّثَنَا الْحُسَيْنُ بْنُ أَبِي السَّرِيِّ،‏‏‏‏ حَدَّثَنَا سَعْدُ بْنُ أَوْسٍ الْعَبْسِيُّ،‏‏‏‏ عَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۰۷۲)، وقد أخرجہ: مسند احمد (۵/۳۱۸),3385,,Chapters on Drinks
3386,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ،‏‏‏‏ عَنْ الزّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الوضو ۷۱ (۲۴۲)، الأشربة ۴ (۵۵۸۵،۵۵۸۶)، صحیح مسلم/الأشربة ۷ (۲۰۰۱)، سنن ابی داود/الأشربة ۵ (۳۶۸۲)، سنن الترمذی/الأشربة ۲ (۱۸۶۳)، سنن النسائی/الأشربة ۲۳ (۵۵۹۴)،(تحفة الأشراف:۱۷۷۶۴)، وقد أخرجہ: موطا امام مالک/الأشربة ۴ (۹)، مسند احمد (۶/۳۶،۹۷،۱۹۰،۲۲۶)، سنن الدارمی/الأشربة ۸ (۲۱۴۲),3386,,Chapters on Drinks
3387,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ،‏‏‏‏ حَدَّثَنَا صَدَقَةُ بْنُ خَالِدٍ،‏‏‏‏ حَدَّثَنَا يَحْيَى بْنُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۰۳۵)، وقد أخرجہ: صحیح مسلم/الأشربة ۷ (۲۰۰۳)، سنن ابی داود/الأشربة ۵ (۳۶۷۹)، سنن الترمذی/الأشربة ۱ (۱۸۶۱)،۲ (۱۸۶۴)، سنن النسائی/الأشربة ۴۶ (۵۶۷۶،۵۶۷۷)، مسند احمد (۲/۱۶،۲۹،۳۱،۹۱،۹۸،۱۰۵،۱۵۸),3387,,Chapters on Drinks
3388,حَدَّثَنَا يُونُسُ بْنُ عَبْدِ الْأَعْلَى،‏‏‏‏ حَدَّثَنَا ابْنُ وَهْبٍ،‏‏‏‏ أَخْبَرَنَا ابْنُ جُرَيْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih Lighairihi; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۵۶۳، ومصباح الزجاجة:۱۱۷۵),3388,,Chapters on Drinks
3389,حَدَّثَنَا عَلِيُّ بْنُ مَيْمُونٍ الرَّقِّيُّ،‏‏‏‏ حَدَّثَنَا خَالِدُ بْنُ حَيَّانَ،‏‏‏‏ عَنْ سُلَيْ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۴۵۱، ومصباح الزجاجة:۱۱۷۶),3389,,Chapters on Drinks
3390,حَدَّثَنَا سَهْلٌ،‏‏‏‏ حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ،‏‏‏‏ عَنْ مُحَمَّدِ بْنِ عَمْرِو بْنِ عَلْقَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن الترمذی/الأشربة ۲ (۱۸۶۴)، سنن النسائی/الأشربة ۲۳ (۵۵۹۰)،(تحفة الأشراف:۸۵۸۴)، وقد أخرجہ: حم (۲/۱۶،۲۹،۳۱،۱۰۴),3390,,Chapters on Drinks
3391,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ،‏‏‏‏ حَدَّثَنَا أَبُو دَاوُدَ،‏‏‏‏ حَدَّثَنَا شُعْبَةُ،‏‏‏‏ عَنْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/المغازي ۶۰ (۴۳۴۳،۴۳۴۴)، الأدب ۸۰ (۶۱۲۴)، الأحکام ۲۲ (۷۱۷۲)، صحیح مسلم/الأشربة ۷ (۱۷۳۳)، سنن ابی داود/الأشربة ۵ (۳۶۸۴)، الحدود ۱ (۴۳۵۶)، سنن النسائی/الأشربة ۲۳ (۵۵۹۸)،(تحفة الأشراف:۹۰۸۶)، وقد أخرجہ: مسند احمد (۴/۴۱۰،۴۱۶،۴۱۷),3391,,Chapters on Drinks
3392,حَدَّثَنَا إِبْرَاهِيمُ بْنُ الْمُنْذِرِ الْحِزَامِيُّ،‏‏‏‏ حَدَّثَنَا أَبُو يَحْيَى زَكَرِيَّا بْنُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۰۸۹، ومصباح الزجاجة:۱۱۷۷),3392,,Chapters on Drinks
3393,حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ،‏‏‏‏ حَدَّثَنَا أَنَسُ بْنُ عِيَاضٍ،‏‏‏‏ حَدَّثَنِي,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الأشربة ۵ (۳۶۸۱)، سنن الترمذی/الأشربة ۳ (۱۸۶۵)،(تحفة الأشراف:۳۰۱۴)، وقد أخرجہ: مسند احمد (۳/۳۴۳),3393,,Chapters on Drinks
3394,حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ،‏‏‏‏ حَدَّثَنَا أَنَسُ بْنُ عِيَاضٍ،‏‏‏‏ حَدَّثَنَا,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن النسائی/الأشربة ۲۵ (۵۶۱۰)،(تحفة الأشراف:۸۷۶۰)، وقد أخرجہ: مسند احمد (۲/۱۶۷،۱۷۹),3394,,Chapters on Drinks
3395,حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ،‏‏‏‏ أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ،‏‏‏‏ عَنْ أَبِي الزُّبَيْرِ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الأشربة ۱۱ (۱۹۸۶)، سنن النسائی/الأشربة ۸ (۵۵۶۴)،(تحفة الأشراف:۲۹۱۶)، وقد أخرجہ: مسند احمد (۳/۳۸۹),3395,,Chapters on Drinks
3396,حَدَّثَنَا يَزِيدُ بْنُ عَبْدِ اللَّهِ الْيَمَامِيُّ،‏‏‏‏ حَدَّثَنَا عِكْرِمَةُ بْنُ عَمَّارٍ،‏‏‏‏ ع,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الأشربة ۵ (۱۹۸۹)، سنن النسائی/الأشربة ۱۷ (۵۵۷۳)،(تحفة الأشراف:۱۴۸۴۲)، وقد أخرجہ: مسند احمد (۲/۵۲۶),3396,,Chapters on Drinks
3397,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ،‏‏‏‏ حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ،‏‏‏‏ حَدَّثَنَا الْأَوْزَا,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الأشربة ۱۱ (۵۶۰۲)، صحیح مسلم/الأشربة ۵ (۱۹۸۸)، سنن ابی داود/الأشربة ۸ (۳۷۰۴)، سنن النسائی/الأشربة ۶ (۵۵۵۳)،(تحفة الأشراف:۱۲۱۰۷)، وقد أخرجہ: موطا امام مالک/الأشربة ۱ (۸)، مسند احمد (۵/۲۹۵،۳۰۷،۳۰۹،۳۱۰)، سنن الدارمی/الأشربة ۱۵ (۲۱۵۶),3397,,Chapters on Drinks
3398,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا أَبُو مُعَاوِيَةَ . ح وحَدَّثَنَا مُحَمّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih Lighairihi; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۷۸۲۴)، وقد أخرجہ: صحیح مسلم/الأشربة ۹ (۲۰۰۵)، سنن ابی داود/الأشربة ۱۰ (۳۷۱۱)، سنن الترمذی/الأشربة ۷ (۱۸۷۱)، مسند احمد (۶/۴۶،۱۲۴),3398,,Chapters on Drinks
3399,حَدَّثَنَا أَبُو كُرَيْبٍ،‏‏‏‏ عَنْ إِسْمَاعِيل بْنِ صَبِيحٍ،‏‏‏‏ عَنْ أَبِي إِسْرَائِيلَ،‏‏‏‏ عَنْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الأشربة ۹ (۲۰۰۴)، سنن ابی داود/الأشربة ۱۰ (۳۷۱۳)، سنن النسائی/الأشربة ۵۵ (۵۷۴۰)،(تحفة الأشراف:۶۵۴۸)، وقد أخرجہ: مسند احمد (۱/۲۳۲،۲۴۰،۲۸۷،۳۵۵),3399,,Chapters on Drinks
3400,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الْمَلِكِ بْنِ أَبِي الشَّوَارِبِ،‏‏‏‏ حَدَّثَنَا أَبُو عَوَانَةَ،‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الأشربة ۶ (۱۹۹۹)، سنن النسائی/الأشربة ۲۷ (۵۶۱۶)،۳۸ (۵۶۵۰)،(تحفة الأشراف:۲۹۹۵)، وقد أخرجہ: سنن ابی داود/الأشربة ۷ (۳۷۰۲)، مسند احمد (۳/۳۰۴،۳۰۷،۳۳۶،۳۷۹،۳۸۴),3400,,Chapters on Drinks
3401,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ،‏‏‏‏ عَنْ مُحَمَّد,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۵۰۹۳، ومصباح الزجاجة:۱۱۷۸)، وقد أخرجہ: صحیح مسلم/الأشربة ۶ (۱۹۹۲)، سنن ابی داود/الأشربة ۷ (۳۶۹۳)، سنن النسائی/الأشربة ۳۸ (۵۶۴۹)، موطا امام مالک/الأشربة ۲ (۶)، مسند احمد (۲/۴۱۴،۴۹۱),3401,,Chapters on Drinks
3402,حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ،‏‏‏‏ أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ،‏‏‏‏ عَنْ نَافِعٍ، ‏‏‏‏‏‏عَن,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الأشربة ۶ (۱۹۹۸)،(تحفة الأشراف:۸۲۹۹)، وقد أخرجہ: سنن الترمذی/الأشربة ۵ (۱۸۶۴)، سنن النسائی/الأشربة ۳۷ (۵۶۴۸)، موطا امام مالک/الأشربة ۲ (۵)، مسند احمد (۲/۵۶),3402,,Chapters on Drinks
3403,حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ،‏‏‏‏ حَدَّثَنَا أَبِي،‏‏‏‏ عَنْ الْمُثَنَّى بْنِ سَعِيدٍ،‏‏‏‏ عَنْ أَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الأشربة ۶ (۱۹۹۶)، سنن النسائی/الأشربة ۳۲ (۵۶۳۶)،(تحفة الأشراف:۴۲۵۳)، وقد أخرجہ: مسند احمد (۳/۹۰),3403,,Chapters on Drinks
3404,حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ وَالْعَبَّاسُ بْنُ عَبْدِ الْعَظِيمِ الْعَنْبَرِيُّ،‏‏‏‏ قَالَا:‏‏‏‏ حَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن النسائی/الأشربة ۳۱ (۵۶۳۱)،(تحفة الأشراف:۹۷۳۶),3404,,Chapters on Drinks
3405,حَدَّثَنَا عَبْدُ الْحَمِيدِ بْنُ بَيَانٍ الْوَاسِطِيُّ،‏‏‏‏ حَدَّثَنَا إِسْحَاق بْنُ يُوسُفَ،‏‏‏‏ ع,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الجنائز ۳۶ (۹۷۷)، الأضاحي ۵ (۱۹۷۷)، الأشربة ۶ (۱۹۹۹)، سنن ابی داود/الأشربة ۷ (۳۶۹۸)، سنن الترمذی/الأشربة ۶ (۱۸۶۹)، الجنائز ۵۳ (۱۰۴۵)، الأضاحي ۱۴ (۱۵۱۰)، سنن النسائی/الجنائز ۱۰۰ (۲۰۳۴)، الأضاحي ۳۶ (۴۴۳۴)، الأشربة ۴۰ (۵۶۵۴،۵۶۵۵)،(تحفة الأشراف:۱۹۳۲)، وقد أخرجہ: مسند احمد (۵/۳۵۰،۳۵۶،۳۵۷،۳۶۱),3405,,Chapters on Drinks
3406,حَدَّثَنَا يُونُسُ بْنُ عَبْدِ الْأَعْلَى،‏‏‏‏ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ،‏‏‏‏ أَنْبَأَنَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۵۶۳، ومصباح الزجاجة:۱۱۷۹),3406,,Chapters on Drinks
3407,حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ،‏‏‏‏ حَدَّثَنَا الْمُعْتَمِرُ بْنُ سُلَيْمَانَ،‏‏‏‏ عَنْ أَبِيهِ،‏‏,Al-Albani: Daif Isnaad; Muhammad Fouad Abd al-Baqi: Daif Isnaad; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۷۸۴۰، ومصباح الزجاجة:۱۱۸۰)، وقد أخرجہ: مسند احمد (۶/۸۰،۹۸),3407,,Chapters on Drinks
3408,حَدَّثَنَا إِسْحَاق بْنُ مُوسَى الْخَطْمِيُّ،‏‏‏‏ حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ،‏‏‏‏ حَدَّثَنَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن النسائی/الأشربة ۳۳ (۵۶۳۸)،(تحفة الأشراف:۱۵۳۹۲)، وقد أخرجہ: صحیح مسلم/الأشربة ۶ (۱۹۹۳)، مسند احمد (۲/۵۴۰),3408,,Chapters on Drinks
3409,حَدَّثَنَا مُجَاهِدُ بْنُ مُوسَى،‏‏‏‏ حَدَّثَنَا الْوَلِيدُ،‏‏‏‏ عَنْ صَدَقَةَ أَبِي مُعَاوِيَةَ،‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الأشربة ۱۲ (۳۷۱۶)، سنن النسائی/الأشربة ۲۵ (۵۶۱۳)،۴۸ (۵۷۰۷)،(تحفة الأشراف:۱۲۲۹۷),3409,,Chapters on Drinks
3410,حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ،‏‏‏‏ أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ،‏‏‏‏ عَنْ أَبِي الزُّبَيْرِ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الأشربة ۱۲ (۲۰۱۲)، سنن ابی داود/الأشربة ۲۲ (۳۷۳۱)، سنن الترمذی/الأدب ۷۴ (۲۸۵۷)،(تحفة الأشراف:۲۹۲۴)، وقد أخرجہ: صحیح البخاری/الأشربة ۲۲ (۵۶۲۳)، مسند احمد (۳/۳۵۵),3410,,Chapters on Drinks
3411,حَدَّثَنَا عَبْدُ الْحَمِيدِ بْنُ بَيَانٍ الْوَاسِطِيُّ،‏‏‏‏ حَدَّثَنَا خَالِدُ بْنُ عَبْدِ اللَّهِ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۶۳۹، ومصباح الزجاجة:۱۱۸۱)، وقد أخرجہ: مسند احمد (۲/۳۶۷)، سنن الدارمی/الأشربة ۲۶ (۲۱۷۸),3411,,Chapters on Drinks
3412,حَدَّثَنَا عِصْمَةُ بْنُ الْفَضْلِ،‏‏‏‏ حَدَّثَنَا حَرَمِيُّ بْنُ عُمَارَةَ بْنِ أَبِي حَفْصَةَ،‏‏‏‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۶۲۳۷، ومصباح الزجاجة:۱۱۸۲),3412,,Chapters on Drinks
3413,حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ،‏‏‏‏ أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ،‏‏‏‏ عَنْ نَافِعٍ،‏‏‏‏ عَنْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الأشربة ۲۸ (۵۶۳۴)، صحیح مسلم/اللباس ۱ (۲۰۶۵)،(تحفة الأشراف:۱۸۱۸۲)، وقد أخرجہ: موطا امام مالک/صفة النبی ﷺ ۷ (۱۱)، مسند احمد (۶/۹۸،۳۰۱،۳۰۲،۳۰۴،۳۰۶)، سنن الدارمی/الأشربة ۲۵ (۲۱۷۵),3413,,Chapters on Drinks
3414,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الْمَلِكِ بْنِ أَبِي الشَّوَارِبِ،‏‏‏‏ حَدَّثَنَا أَبُو عَوَانَةَ،‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الأطعمة ۲۹ (۵۴۲۶)، الأشربة ۲۷ (۵۶۳۲)،۲۸ (۵۶۳۳)، اللباس ۲۵ (۵۸۳۱)،۲۷ (۵۸۳۷)، صحیح مسلم/اللباس ۲ (۲۰۶۷)، سنن ابی داود/الأشربة ۱۷ (۳۷۲۳)، سنن الترمذی/الأشربة ۱۰ (۱۸۷۸)، سنن النسائی/الزینة من المجتبیٰ ۳۳ (۵۳۰۳)،(تحفة الأشراف:۳۳۷۳)، وقد أخرجہ: مسند احمد (۵/۳۸۵،۳۹،۳۹۶،۳۹۸،۴۰۰،۴۰۸)، سنن الدارمی/الأشربة ۲۵ (۲۱۷۵،۲۱۷۶),3414,,Chapters on Drinks
3415,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا غُنْدَرٌ،‏‏‏‏ عَنْ شُعْبَةَ،‏‏‏‏ عَنْ سَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۷۸۶۵، ومصباح الزجاجة:۱۱۸۳)، وقد أخرجہ: مسند احمد (۶/۹۸),3415,,Chapters on Drinks
3416,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا ابْنُ مَهْدِيٍّ،‏‏‏‏ حَدَّثَنَا عَزْرَةُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الأشربة ۶۶ (۵۶۳۱)، صحیح مسلم/الأشربة ۱۶ (۲۰۲۸)، سنن الترمذی/الأشربة ۱۳ (۱۸۸۴)،(تحفة الأشراف:۴۹۸)، وقد أخرجہ: سنن ابی داود/الأشربة ۱۹ (۳۷۲۸)، مسند احمد (۳/۱۱۴،۱۱۹،۱۲۸،۱۸۵)، سنن الدارمی/الأشربة ۲۰ (۲۱۶۶),3416,,Chapters on Drinks
3417,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ،‏‏‏‏ وَمُحَمَّدُ بْنُ الصَّبَّاحِ،‏‏‏‏ قَالَا:‏‏‏‏ حَدَّثَنَا مَرْو,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/الأشربة ۱۴ (۱۸۸۶)،(تحفة الأشراف:۶۳۴۷)، وقد أخرجہ: مسند احمد (۱/۲۸۴،۲۸۵),3417,,Chapters on Drinks
3418,حَدَّثَنَا أَحْمَدُ بْنُ عَمْرِو بْنِ السَّرْحِ،‏‏‏‏ حَدَّثَنَا ابْنُ وَهْبٍ،‏‏‏‏ عَنْ يُونُسَ،‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الأشربة ۲۳ (۵۶۲۵،۵۶۲۶)، صحیح مسلم/الأشربة ۱۳ (۲۰۲۳)، سنن ابی داود/الأشربة ۱۵ (۳۷۲۰)، سنن الترمذی/الأشربة ۱۷ (۱۸۹۰)،(تحفة الأشراف:۴۱۳۸)، وقد أخرجہ: مسند احمد (۳/۶،۶۷،۶۹،۹۳)، سنن الدارمی/الأشربة ۱۹ (۲۱۹۵),3418,,Chapters on Drinks
3419,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ،‏‏‏‏ حَدَّثَنَا أَبُو عَامِرٍ،‏‏‏‏ حَدَّثَنَا زَمْعَةُ بْنُ صَالِ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۰۹۹، ومصباح الزجاجة:۱۱۸۴),3419,,Chapters on Drinks
3420,حَدَّثَنَا بِشْرُ بْنُ هِلَالٍ الصَّوَّافُ،‏‏‏‏ حَدَّثَنَا عَبْدُ الْوَارِثِ بْنُ سَعِيدٍ،‏‏‏‏ عَنْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الأشربة ۲۴ (۵۶۲۷،۵۶۲۸)،(تحفة الأشراف:۱۴۲۴۵)، وقد أخرجہ: مسند احمد (۲/۲۳۰،۲۴۷،۳۲۷،۳۵۳،۴۸۷)، سنن الدارمی/الأشربة ۱۹ (۲۱۶۴),3420,,Chapters on Drinks
3421,حَدَّثَنَا بَكْرُ بْنُ خَلَفٍ أَبُو بِشْرٍ،‏‏‏‏ حَدَّثَنَا يَزِيدُ بْنُ زُرَيْعٍ،‏‏‏‏ حَدَّثَنَا خَا,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الأشربة ۲۴ (۵۶۲۹)،(تحفة الأشراف:۶۰۵۶)، وقد أخرجہ: سنن ابی داود/الأشربة ۱۴ (۳۷۱۹)، الأطعمة ۲۵ (۳۷۸۶)، سنن الترمذی/الأطعمة ۲۴ (۱۸۲۵)، سنن النسائی/الضحایا ۴۳ (۴۴۵۳)، مسند احمد (۱/۲۲۶،۲۴۱،۲۹۳،۳۳۹)، سنن الدارمی/الأشربة ۱۹ (۲۱۶۳),3421,,Chapters on Drinks
3422,حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ،‏‏‏‏ حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ،‏‏‏‏ عَنْ عَاصِمٍ،‏‏‏‏ عَنْ ا,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحج ۷۶ (۱۶۳۷)، الأشربة ۱۶ (۵۶۱۷)، صحیح مسلم/الأشربة ۱۵ (۲۰۲۷)، ولیس عندہ ''فذکرت''، سنن الترمذی/الأشربة ۱۲ (۱۸۸۲)، الشمائل ۳۱ (۱۹۷،۱۹۹)، سنن النسائی/الحج ۱۶۵ (۲۹۶۷)،(تحفة الأشراف:۵۷۶۷)، وقد أخرجہ: مسند احمد (۱/۲۱۴،۲۲۰،۲۴۲،۲۴۳،۲۴۹،۲۸۷،۳۴۲،۳۶۹،۳۷۲),3422,,Chapters on Drinks
3423,حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ،‏‏‏‏ أَنْبَأَنَا سُفْيَانُ بْنُ عُيَيْنَةَ،‏‏‏‏ عَنْ يَزِيدَ ب,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن الترمذی/الأشربة ۱۸ (۱۸۹۲)،(تحفة الأشراف:۱۸۰۴۹)، وقد أخرجہ: مسند احمد (۶/۴۳۴),3423,,Chapters on Drinks
3424,حَدَّثَنَا حُمَيْدُ بْنُ مَسْعَدَةَ،‏‏‏‏ حَدَّثَنَا بِشْرُ بْنُ الْمُفَضَّلِ،‏‏‏‏ حَدَّثَنَا سَعِيدٌ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الأشربة ۱۴ (۲۰۲۴)، سنن الترمذی/الأشربة ۱۱ (۱۸۷۹)،(تحفة الأشراف:۱۱۸۰)، وقد أخرجہ: مسند احمد (۳/۱۳۱،۱۸۲،۲۷۷),3424,,Chapters on Drinks
3425,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ،‏‏‏‏ حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ،‏‏‏‏ عَنْ الزُّهْرِيِّ،‏‏‏‏ عَن,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الأشربة ۱۴ (۵۶۱۲)،۱۸ (۵۶۱۹)، المساقاة ۱ (۲۳۵۲)، الھبة ۴ (۲۵۷۱)، صحیح مسلم/الأشربة ۱۷ (۲۰۲۹)، سنن ابی داود/الأشربة ۱۹ (۳۷۲۶)، سنن الترمذی/الأشربة ۱۹ (۱۸۹۳)،(تحفة الأشراف:۱۵۲۸)، وقد أخرجہ: موطا امام مالک/صفة النبی ﷺ ۹ (۱۷)، مسند احمد (۳/۱۱۰،۱۱۳،۱۹۷)، سنن الدارمی/الأشربة ۱۸ (۲۱۶۲),3425,,Chapters on Drinks
3426,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ،‏‏‏‏ حَدَّثَنَا إِسْمَاعِيل بْنُ عَيَّاشٍ،‏‏‏‏ حَدَّثَنَا ابْنُ جُر,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۸۵۸، ومصباح الزجاجة:۱۱۸۵)، وقد أخرجہ: سنن ابی داود/الأشربة ۲۱ (۳۷۳۰)، سنن الترمذی/الدعوات ۵۵ (۳۴۵۵)، مسند احمد (۱/۲۲۰،۲۲۵),3426,,Chapters on Drinks
3427,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا دَاوُدُ بْنُ عَبْدِ اللَّهِ،‏‏‏‏ عَنْ عَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۵۴۹۰، ومصباح الزجاجة:۱۱۸۶),3427,,Chapters on Drinks
3428,حَدَّثَنَا بَكْرُ بْنُ خَلَفٍ أَبُو بِشْرٍ،‏‏‏‏ حَدَّثَنَا يَزِيدُ بْنُ زُرَيْعٍ،‏‏‏‏ عَنْ خَالِدٍ ا,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الأشربة ۲۰ (۳۷۲۸)، سنن الترمذی/الأشربة ۱۵ (۱۸۸۸)،(تحفة الأشراف:۶۰۵۶)، وقد أخرجہ: مسند احمد (۱/۲۲۰ھ ۳۰۹،۳۵۷)، سنن الدارمی/الأشربة ۲۷ (۲۱۸۰),3428,,Chapters on Drinks
3429,حَدَّثَنَا أَبُو بَكْرِ بْنُ خَلَّادٍ الْبَاهِلِيُّ،‏‏‏‏ حَدَّثَنَا سُفْيَانُ،‏‏‏‏ عَنْ عَبْدِ الْكَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Daif,takhreej: «(انظر حدیث رقم:۳۲۸۸)،(تحفة الأشراف:۶۱۴۹),3429,,Chapters on Drinks
3430,حَدَّثَنَا أَبُو كُرَيْبٍ،‏‏‏‏ حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ عَبْدِ الرَّحْمَنِ الْمُحَارِبِيُّ،,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Sahih,takhreej: «(أنظر حدیث رقم:۳۲۸۸),3430,,Chapters on Drinks
3431,حَدَّثَنَا مُحَمَّدُ بْنُ الْمُصَفَّى الْحِمْصِيُّ،‏‏‏‏ حَدَّثَنَا بَقِيَّةُ،‏‏‏‏ عَنْ مُسْلِمِ بْنِ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۴۳۳، ومصباح الزجاجة:۱۱۸۷),3431,,Chapters on Drinks
3432,حَدَّثَنَا أَحْمَدُ بْنُ مَنْصُورٍ أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا يُونُسُ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَن,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الأشربة ۲۰ (۵۶۱۳)، سنن ابی داود/الأشربة ۱۸ (۳۷۲۴)،(تحفة الأشراف:۲۲۵۰)، وقد أخرجہ: مسند احمد (۳/۳۲۸،۳۴۳،۳۴۴،۳۴۲)،۳۵۵، سنن الدارمی/الأشربة ۲۲ (۲۱۶۹),3432,,Chapters on Drinks
3433,حَدَّثَنَا وَاصِلُ بْنُ عَبْدِ الْأَعْلَى،‏‏‏‏ حَدَّثَنَا ابْنُ فُضَيْلٍ،‏‏‏‏ عَنْ لَيْثٍ،‏‏‏‏ عَنْ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۰۷۴، ومصباح الزجاجة:۱۱۸۸),3433,,Chapters on Drinks
3434,حَدَّثَنَا أَحْمَدُ بْنُ عَبْدَةَ،‏‏‏‏ وَسُوَيْدُ بْنُ سَعِيدٍ،‏‏‏‏ قَالَا:‏‏‏‏ حَدَّثَنَا حَمَّادُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن الترمذی/الأشربة ۲۰ (۱۸۹۴)،(تحفة الأشراف:۱۲۰۸۶)، وقد أخرجہ: صحیح مسلم/المساجد ۵۵ (۶۸۱)، مسند احمد (۵/۳۰۳)، سنن الدارمی/الأشربة ۲۸ (۲۱۸۱),3434,,Chapters on Drinks
3435,حَدَّثَنَا أَحْمَدُ بْنُ سِنَانٍ،‏‏‏‏ حَدَّثَنَا زَيْدُ بْنُ الْحُبَابِ،‏‏‏‏ حَدَّثَنَا مَنْدَلُ بْن,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۸۵۷، ومصباح الزجاجة:۱۱۸۹),3435,,Chapters on Drinks
