hadiths[507]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}: 24206,"حدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ أَبِی بُرْدَۃَ ، عَنْ أَبِیہِ ، قَالَ : بَعَثَہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إِلَی الْیَمَنِ ، فَسَأَلَہُ عَنْ أَشْرِبَۃٍ تُصْنَعُ بِہَا : الْبِتْعُ ، وَالْمِزْرُ ، وَالذُّرَۃُ ، فَقَالَ : کُلَّ مُسْکِرٍ حَرَامٌ۔\n\n(بخاری 4244۔ مسلم 75)",,,24206 24207,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ أَبِی سَلَمَۃَ ، عَنْ عَائِشَۃَ ؛ تَبْلُغُ بِہِ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : کُلُّ شَرَابٍ أَسْکَرَ ، فَہُوَ حَرَامٌ۔ (بخاری 5586۔ مسلم 69)",,,24207 24208,"حَدَّثَنَا إِسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ: کُلُّ مُسْکِرٍ حَرَامٌ ، قَالَ : وَقَالَ ابْنُ عُمَرَ : کُلُّ مُسْکِرٍ خَمْرٌ۔ (مسلم 73۔ ابوداؤد 3671)",,,24208 24209,"حَدَّثَنَا إِسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنْ أَبِی عُثْمَانَ ، عَنِ الْقَاسِمِ بْنِ مُحَمَّدٍ ، عَنْ عَائِشَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : کُلُّ مُسْکِرٍ حَرَامٌ۔ (ابوداؤد 3680۔ احمد 6/72)",,,24209 24210,"حَدَّثَنَا قَبِیصَۃُ ، عَنْ سُفْیَانَ ، عَنْ عَلِیِّ بْنِ بَذِیمَۃَ ، عَنْ قَیْسِ بْنِ حَبْتَرٍ ، عَنِ ابْنِ عَبَّاسٍ ، عن النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : کُلُّ مُسْکِرٍ حَرَامٌ۔ (ابوداؤد 3672)",,,24210 24211,"حَدَّثَنَا مُحَمَّدُ بْنُ عُبَیْدٍ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ یَزِیدَ بْنِ أَبِی حَبِیبٍ ، عَنْ مَرْثَدِ بْنِ عَبْدِ اللہِ الْیَزَنِیِّ ، عَنْ دَیْلَمٍ الْحِمْیَرِیِّ قَالَ : سَأَلْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقُلْتُ : یَا رَسُولَ اللہِ ، إِنَّا بِأَرْضٍ بَارِدَۃٍ نُعَالِجُ بِہَا عَمَلاً شَدِیدًا ، وَإِنَّا نَتَّخِذُ شَرَابًا مِنْ ہَذَا الْقَمْحِ نَتَقَوَّی بِہِ عَلَی أَعْمَالِنَا ، وَعَلَی بَرْدِ بِلاَدِنَا ؟ قَالَ : ہَلْ یُسْکِرُ ؟ قُلْتُ : نَعَمْ ، قَالَ : فَاجْتَنِبُوہُ ، قَالَ : ثُمَّ جِئْتُہُ مِنْ بَیْنِ یَدَیْہِ ، فَقُلْتُ لَہُ مِثْلَ ذَلِکَ ، فَقَالَ: ہَلْ یُسْکِرُ؟ قُلْتُ: نَعَمْ، قَالَ: فَاجْتَنِبُوہُ، قُلْتُ: إِنَّ النَّاسَ غَیْرُ تَارِکِیہِ ، قَالَ: فَإِنْ لَمْ یَتْرُکُوہُ فَاقْتُلُوہُمْ۔\n\n(ابوداؤد 3676۔ احمد 4/231)",,,24211 24212,"حَدَّثَنَا مُلاَزِمُ بْنُ عَمْرٍو ، عَنْ سِرَاجِ بْنِ عُقْبَۃَ ، عَنْ عَمَّتِہِ خَالِدَۃَ بِنْتِ طَلْقٍ ، قَالَتْ : حدَّثَنِی أَبِی ، قَالَ : کُنَّا جُلُوسًا عِنْدَ نَبِیِّ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَجَائَ صُحَارُ عَبْدِ الْقَیْسِ ، فَقَالَ : یَا رَسُولَ اللہِ ، مَا تَرَی فِی شَرَابٍ نَصْنَعُہُ مِنْ ثِمَارِنَا ؟ قَالَ : فَأَعْرَضَ عَنْہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَتَّی سَأَلَہُ ثَلاَثَ مَرَّاتٍ ، ثُمَّ قَامَ بِنَا النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَصَلَّی ، فَلَمَّا قَضَی الصَّلاَۃَ ، قَالَ : مَنِ السَّائِلُ عَنِ الْمُسْکِرِ ؟ یَا سَائِلاً عَنِ الْمُسْکِرِ ، لاَ تَشْرَبْہُ ، وَلاَ تَسْقِہِ أَحَدًا مِنَ الْمُسْلِمِینَ ، فَوَالَّذِی نَفْسُ مُحَمَّدٍ بِیَدِہِ ، مَا شَرِبَہُ قَطُّ رَجُلٌ ابْتِغَائَ لَذَّۃِ سُکْرِہِ ، فَیَسْقِیَہُ اللَّہُ خَمْرًا یَوْمَ الْقِیَامَۃِ۔ (طبرانی 8259)",,,24212 24213,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ عَمْرٍو ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : کُلُّ مُسْکِرٍ حَرَامٌ۔",,,24213 24214,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ أَبَانَ بْنِ عَبْدِ اللہِ الْبَجَلِیِّ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، قَالَ : قَالَ نَبِیُّ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : کُلُّ مُسْکِرٍ حَرَامٌ۔ (ابوداؤد 3678۔ احمد 2/171)",,,24214 24215,"حَدَّثَنَا عَبْد اللہِ بْنُ نُمَیْرٍ ، عَنِ الْحَسَنِ بْنِ عَمْرٍو ، عَنِ الْحَکَمِ ، عَنْ شَہْرِ بْنِ حَوْشَبٍ ، عَنْ أُمِّ سَلَمَۃَ ، قَالَتْ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ کُلٍّ مُسْکِرٍ وَمُفَتِّرٍ۔ (احمد 6/309۔ ابوداؤد 3679)",,,24215 24216,"حَدَّثَنَا وَکِیعٌ ، عَنْ مَعْرُوفِ بْنِ وَاصِلٍ ، عَنْ مُحَارِبِ بْنِ دِثَارٍ ، عَنِ ابْنِ بُرَیْدَۃَ ، عَنْ أَبِیہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : کُنْتُ نَہَیْتُکُمْ عَنِ الأَشْرِبَۃِ فِی ظُرُوفِ الأُدُمِ ، فَاشْرَبُوا فِی کُلِّ وِعَائٍ غَیْرَ أَنْ لاَ تَشْرَبُوا مُسْکِرًا۔ (ابوداؤد 3691)",,,24216 24217,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ أَبِی سِنَانٍ ، عَنْ مُحَارِبِ بْنِ دِثَارٍ ، عَنِ ابْنِ بُرَیْدَۃَ ، عَنْ أَبِیہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : اشْرَبُوا فِی الأَسْقِیَۃِ کُلِّہَا ، وَلاَ تَشْرَبُوا مُسْکِرًا۔",,,24217 24218,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ أَبِی حَیَّانَ ، عَنْ أَبِیہِ ، عَنْ مَرْیَمَ بِنْتِ طَارِقٍ ، عَنْ عَائِشَۃَ ؛ أَنَّہَا ، قَالَتْ : کُلُّ مُسْکِرٍ حَرَامٌ۔",,,24218 24219,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : کُلَّ مُسْکِرٍ حَرَامٌ ، وَقَالَ ابْنُ عُمَرَ : کُلُّ مُسْکِرٍ خَمْرٌ۔",,,24219 24220,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی بُرْدَۃَ ، قَالَ : قَالَ عُمَرُ : إِنَّ ہَذِہِ الأَنْبِذَۃَ تُنْبَذُ مِنْ خَمْسَۃِ أَشْیَائَ؛ مِنَ التَّمْرِ ، وَالزَّبِیبِ ، وَالْعَسَلِ ، وَالْبُرِّ ، وَالشَّعِیرِ ، فَمَا خَمَّرْتَہُ مِنْہَا ، ثُمَّ عَتَّقْتَہُ ، فَہُوَ خَمْرٌ۔",,,24220 24221,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنِ الْمُخْتَارِ ، قَالَ : سَأَلْتُ أَنَسًا عَنِ النَّبِیذِ ؟ فَقَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الظُّرُوفِ الْمُزَفَّتَۃِ ، وَقَالَ : کُلُّ مُسْکِرٍ حَرَامٌ۔ (مسلم 31۔ احمد 112)",,,24221 24222,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ أَبِی حَیَّانَ ، عَنْ أَبِیہِ ، عَنْ مَرْیَمَ بِنْتِ طَارِقٍ ، قَالَتْ : دَخَلْتُ عَلَی عَائِشَۃَ فِی نِسَائٍ مِنْ نِسَائِ الأَنْصَارِ ، فَجَعَلْنَ یَسْأَلْنَہَا عَنِ الظُّرُوفِ الَّتِی یُنْبَذُ فِیہَا ؟ فَقَالَتْ : یَا نِسَائَ الْمُؤْمِنِینَ ، إِنَّکُنَّ لَتُکثرن ظُرُوفًا وَتَسْأَلْنَ عنہا ، مَا کَانَ کَثِیرٌ مِنْہَا عَلَی عَہْدِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَاتَّقِینَ اللَّہَ ، وَمَا أَسْکَرَ إِحْدَاکُنَّ مِنَ الأَشْرِبَۃِ فَلْتَجْتَنِبْہُ ، وَإِنْ أَسْکَرَ مَائُ حُبِّہَا ، فَإِنَّ کُلَّ مُسْکِرٍ حَرَامٌ۔ (حاکم 147)",,,24222 24223,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُوسٍ ، وَمُجَاہِدٍ ؛ قَالُوا : قلِیلُ مَا أَسْکَرَ ، کَثِیرُہُ حَرَامٌ۔\n\n(بخاری 4619۔ مسلم 2322)",,,24223 24224,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَبِی حَیَّانَ ، عَنِ الشَّعْبِیِّ ، عَنِ ابْنِ عُمَرَ ، قَالَ : سَمِعْتُ عُمَرَ بْنَ الْخَطَّابِ یَخْطُبُ عَلَی مِنْبَرِ الْمَدِینَۃِ یَقُولُ : یَا أَیُّہَا النَّاسُ ، أَلا إِنَّہُ نَزَلَ تَحْرِیمُ الْخَمْرِ یَوْمَ نَزَلَ ، وَہِیَ مِنْ خَمْسَۃِ أَشْیَائَ ؛ مِنَ الْعِنَبِ ، وَالتَّمْرِ ، وَالْعَسَلِ ، وَالْحِنْطَۃِ ، وَالشَّعِیرِ ، وَالْخَمْرُ مَا خَامَرَ الْعَقْلَ۔",,,24224 24225,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنِ السَّائِبِ بْنِ یَزِیدَ ، قَالَ : قَالَ عُمَرُ بْنُ الْخَطَّابِ : ذُکِرَ لِی أَنَّ عُبَیْدَ اللہِ وَأَصْحَابَہُ شَرِبُوا شَرَابًا بِالشَّامِ ، وَأَنَا سَائِلٌ عَنْہُ ، فَإِنْ کَانَ مُسْکِرًا جَلَدْتُہُمْ۔",,,24225 24226,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنِ السَّائِبِ بْنِ یَزِیدَ ، قَالَ : رَأَیْتُ عُمَرَ یَحُدَّہُمْ۔",,,24226 24227,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ مُعَاوِیَۃَ بْنِ صَالِحٍ ، قَالَ: حدَّثَنَا حَاتِمُ بْنُ حُرَیْثٍ ، عَنْ مَالِکِ بْنِ أَبِی مَرْیَمَ، قَالَ : تَذَاکَرْنَا الطِّلاَئَ ، فَدَخَلَ عَلَیْنَا عَبْدُ الرَّحْمَنِ بْنُ غَنْمٍ فَتَذَاکَرْنَاہُ فَقَالَ : حَدَّثَنِی أَبُو مَالِکٍ الأَشْعَرِیُّ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ: یَشْرَبُ أُنَاسٌ مِنْ أُمَّتِی الْخَمْرَ ، یُسَمُّونَہَا بِغَیْرِ اسْمِہَا ، یُضْرَبُ عَلَی رُؤُوسِہِمْ بِالْمَعَازِفِ وَالْقَیْنَاتِ ، یَخْسِفُ اللَّہُ بِہِمُ الأَرْضَ ، وَیَجْعَلُ مِنْہُمُ الْقِرَدَۃَ وَالْخَنَازِیرَ۔\n\n(ابوداؤد 3681۔ احمد 5/342)",,,24227 24228,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ سَعْدِ بْنِ أَوْسٍ ، عَنْ بِلاَلِ بْنِ یَحْیَی ، عَنْ أَبِی بَکْرِ بْنِ حَفْصٍ ، عَنِ ابْنِ مُحَیْرِیزٍ ، عَنِ ابْنِ السِّمْطِ ، عَنْ عُبَادَۃَ بْنِ الصَّامِتِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَیَسْتَحِلَّنَّ آخِرُ أُمَّتِی الْخَمْرَ بِاسْمٍ تُسَمِّیہَا۔ (احمد 5/318۔ بزار 2689)",,,24228 24229,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حدَّثَنَا الثَّوْرِیُّ ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنْ ذَرِّ بْنِ عَبْدِ اللہِ ، عَنْ سَعِیدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ أَبْزَی ، عَنْ أَبِیہِ ، قَالَ : سَأَلْتُ أُبَیَّ بْنَ کَعْبٍ عَنِ النَّبِیذِ ؟ قَالَ : عَلَیْکَ بِالْمَائِ ، عَلَیْکَ بِالسَّوِیقِ ، عَلَیْکَ بِالْعَسَلِ ، عَلَیْکَ بِاللَّبَنِ الَّذِی نَجَعَتْ بِہِ ، قَالَ ، فَعَاوَدْتُہُ فَقَالَ : الْخَمْرَ تُرِیدُ ؟۔",,,24229 24230,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنْ مُحَمَّدٍ ، عَنْ عَبِیْدَۃَ ، قَالَ : أَحْدَثَ النَّاسُ أَشْرِبَۃً مَا أَدْرِی مَا ہِیَ ، فَلَیْسَ لِی شَرَابٌ مُنْذُ عِشْرِینَ سَنَۃً إِلاَّ الْمَائُ وَاللَّبَنُ وَالْعَسَلُ۔",,,24230 24231,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَوْزَاعِیِّ ، قَالَ : حدَّثَنَا أَبُو کَثِیرٍ ، قَالَ : سَمِعْتُ أَبَا ہُرَیْرَۃَ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : الْخَمْرُ مِنْ ہَاتَیْنِ الشَّجَرَتَیْنِ ؛ مِنَ الْعِنَبَۃِ وَالنَّخْلَۃِ۔ \n\n(مسلم 15۔ ابوداؤد 3670)",,,24231 24232,"حَدَّثَنَا زَیْدُ بْنُ حُبَابِ ، قَالَ : حدَّثَنَا الضَّحَّاکُ بْنُ عُثْمَانَ ، قَالَ : حَدَّثَنِی بُکَیْر بْنُ عَبْدِ اللہِ بْنِ الأَشَجِّ ، قَالَ : أُرَاہُ عَنْ عَامِرِ بْنِ سَعْدِ بْنِ أَبِی وَقَّاصٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَنْہَاکُمْ عَنْ قَلِیلِ مَا أَسْکَرَ کَثِیرُہُ۔ (نسائی 5119۔ دارمی 2099)",,,24232 24233,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی جَعْفَرٍ ، عَنِ الرَّبِیعِ ، عَنْ أَبِی الْعَالِیَۃِ ، أَوْ غَیْرِہِ، عَنِ ابْنِ مُغَفَّلٍ، قَالَ: أَنَا شَہِدْتُ مَعَ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی عَنْ نَبِیذِ الْجَرِّ ، وَأَنَا شَہِدْتُہُ رَخَّصَ وَقَالَ : اجْتَنِبُوا کُلَّ مُسْکِرٍ۔ (طحاوی 229۔ احمد 4/87)",,,24233 24234,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ ہُبَیْرَۃَ ، عَنْ عَلِیٍّ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الْجِعَۃِ۔ (ترمذی 3654۔ ابن ماجہ 3654)",,,24234 24235,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ إِسْمَاعِیلَ بْنِ سُمَیْعٍ ، عَنْ مُسْلِمٍ الْبَطِینِ ، قَالَ : سَأَلْتُ أَبَا عَمْرٍو الشَّیْبَانِیَّ عَنِ الْجِعَۃِ ؟فَقَالَ : شَرَابٌ یُصْنَعُ بِالْیَمَنِ مِنَ الشَّعِیرِ۔",,,24235 24236,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ أَبِی الْجُوَیْرِیَّۃِ ، قَالَ : سَأَلْتُ ابْنَ عَبَّاسٍ عَنِ الْبَاذِق ؟ فَقَالَ : سَبَقَ مُحَمَّدٌ الْبَاذِقَ، أَنَا أَوَّلُ الْعَرَبِ سَأَلَ ابْنَ عَبَّاسٍ عَنْ ذَلِکَ۔ (بخاری 5598۔ نسائی 5116)",,,24236 24237,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، قَالَ : بَلَغَنِی عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : کَانَ قَوْمٌ عَلَی شَرَابٍ ، فَسَکِرَ رَجُلٌ مِنْہُمْ ، فَجَلَدَہُمْ کُلَّہُمْ۔",,,24237 24238,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنِ الْعَلاَئِ بْنِ الْمِنْہَالِ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، قَالَ : أُتِیَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ بِقَوْمٍ قَعَدُوا عَلَی شَرَابٍ، مَعَہُمْ رَجُلٌ صَائِمٌ ، فَضَرَبَہُمْ وَقَالَ: لاَ تَقْعُدُوا مَعَہُمْ حَتَّی یَخُوضُوا فِی حَدِیثٍ غَیْرِہِ۔",,,24238 24239,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ، عَنْ عَلِیِّ بْنِ زَیْدٍ، عَنْ رَبِیعَۃَ بْنِ النَّابِغَۃِ، عَنْ أَبِیہِ، عَنْ عَلِیٍّ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : کُنْتُ نَہَیْتُکُمْ عَنْ ہَذِہِ الأَوْعِیَۃِ فَاشْرَبُوا فِیہَا ، وَاجْتَنِبُوا مَا أَسْکَرَ۔",,,24239 24240,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ شُعْبَۃَ ، عَنْ أَشْعَثَ بْنِ أَبِی الشَّعْثَائِ ، قَالَ : قُلْتُ لَہُ : کَانَ أَبُوکَ یَشْرَبُ النَّبِیذَ؟ قَالَ : نَعَمْ ، حَتَّی لَقِیَ عَبْدَ اللہِ بْنَ عُمَرَ فَنَہَاہُ عَنْہُ۔",,,24240 24241,"حَدَّثَنَا عُبَیْدُ اللہِ ، عَنْ إِسْرَائِیلَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَمْرِو بْنِ شُرَحْبِیلَ ، عَنْ عُمَرَ ، قَالَ : کَانَ مُنَادِی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إِذَا قَامَ إِلَی الصَّلاَۃِ نَادَی : {لاَ تَقْرَبُوا الصَّلاَۃَ وَأَنْتُمْ سُکَارَی}۔\n\n(ابوداؤد 3662۔ ترمذی 3049)",,,24241 24242,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ أَبِی بَکْرِ بْنِ حَفْصٍ ، عَنِ ابْنِ مُحَیْرِیزٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَیَشْرَبَنَّ طَائِفَۃٌ مِنْ أُمَّتِی الْخَمْرَ بِاسْمٍ یُسَمُّونَہَا إِیَّاہُ۔ (عبدالرزاق 17055)",,,24242 24243,"حَدَّثَنَا وَکِیعٌ ، عَنْ خَالِدِ بْنِ دِینَارٍ ، عَنْ شَیْخٍ ، قَالَ : سَمِعْتُ ابْنَ عَبَّاسٍ یَقُولُ : السَّکْرُ مِنَ الْکَبَائِرِ۔",,,24243 24244,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، قَالَ : حدَّثَنَا إِسْرَائِیلُ ، عَنْ إِبْرَاہِیمَ بْنِ مُہَاجِرٍ ، عَنِ الشَّعْبِیِّ ، عَنِ النُّعْمَانِ بْنِ بَشِیرٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : مِنَ الْحِنْطَۃِ خَمْرٌ ، وَمِنَ الشَّعِیرِ خَمْرٌ ، وَمِنَ الزَّبِیبِ خَمْرٌ ، وَمِنَ الْعَسَلِ خَمْرٌ۔ (ابوداؤد 3668۔ ترمذی 1872)",,,24244 24245,"حَدَّثَنَا وَکِیعٌ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنْ فُرَاتِ بْنِ سَلْمَان ، عَنْ رَجُلٍ مِنْ جُلَسَائِ الْقَاسِمِ، عَنْ عَائِشَۃَ، قَالَتْ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَوَّلُ مَا یُکْفأ فِی الإِسْلاَمِ بِشَرَابٍ ، یُقَالُ لَہُ : الطِّلاَئُ ۔\n\n(ابویعلی 4712)",,,24245 24246,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی حَیَّانَ ، عَنِ الشَّعْبِیِّ ، عَنْ عَائِشَۃَ ، قَالَتْ : حدَثَتْ أَشْرِبَۃٌ لَوْ کَانَتْ عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی عَنْہَا۔",,,24246 24247,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّ رَجُلاً قَالَ لابْنِ عُمَرَ : إِنَّ أَہْلَنَا یَنْبِذُونَ شَرَابًا لَہُمْ غَدْوَۃً فَیَشْرَبُونَہُ عَشِیَّۃً ، وَیَنْبِذُونَ عَشِیَّۃً فَیَشْرَبُونَہُ غَدْوَۃً ، قَالَ ابْنُ عُمَرَ : أَنْہَاکَ عَنِ السَّکَرِ قَلِیلِہِ وَکَثِیرِہِ ، وَأُشْہِدُ اللَّہَ عَلَیْک ، أَنَّ أَہْلَ خَیْبَرَ یَنْبِذُونَ شَرَابًا لَہُمْ مِنْ کَذَا وَکَذَا ، یُسَمُّونَہُ کَذَا وَکَذَا ، وَہِیَ الْخَمْرُ ، وَإِنَّ أَہْلَ فَدَک یَنْبِذُونَ شَرَابًا مِنْ کَذَا وَکَذَا ، یُسَمُّونَہَا کَذَا وَکَذَا ، وَہِیَ الْخَمْرُ ، فَعَدَّ أَرْبَعَۃَ أَشْرِبَۃٍ أَحَدُہَا الْعَسَلُ ۔ قَالَ ابْنُ عَوْنٍ : وَکَانَ ابْنُ سِیرِینَ یُسَمِّیہَا کُلَّہَا إِلاَّ الْعَسَلَ۔",,,24247 24248,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ إِسْمَاعِیلَ بْنِ سُمَیْعٍ ، عَنْ مَالِکِ بْنِ عُمَیْرٍ ؛ أَنَّ صَعْصَعَۃَ بْنَ صُوحَانَ أَتَی عَلِیًّا فَسَلَّمَ عَلَیْہِ ، فَقَالَ : یَا أَمِیرَ الْمُؤْمِنِینَ ، اِنْہِنَا عَمَّا نَہَاکَ عَنْہُ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : قَالَ : نَہَانَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الدُّبَّائِ ، وَالْحَنْتَمِ ، وَالْمُقَیَّرِ ، وَالْجِعَۃِ۔\n\n(ابوداؤد 3690۔ احمد 1/138)",,,24248 24249,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ حَبِیبٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، عَنِ الدُّبَّائِ ، وَالْحَنْتَمِ ، وَالْمُزَفَّتِ ، وَالنَّقِیرِ۔ (بخاری 53۔ مسلم 48)",,,24249 24250,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ مَنْصُورِ بْنِ حَیَّانَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : أَشْہَدُ عَلَی ابْنِ عَبَّاسٍ ، وَابْنِ عُمَرَ ، أَنَّہُمَا شَہِدَا أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی عَنِ الدُّبَّائِ ،وَالْحَنْتَمِ ، وَالْمُزَفَّتِ ، وَالنَّقِیرِ۔ (مسلم 1580۔ ابوداؤد 3683)",,,24250 24251,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، وَمُحَمَّدُ بْنُ عُبَیْدٍ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یُنْبَذَ فِی الْمُزَفَّتِ ، وَالدُّبَّائِ ، وَالْحَنْتَمِ ، وَالنَّقِیرِ۔\n\n(مسلم 1577۔ ابن حبان 5404)",,,24251 24252,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ مُحَمَّدِ بْنِ أَبِی إسْمَاعِیلَ ، عَنْ عُمَارَۃَ بْنِ عَاصِمٍ الْعَنَزِیِّ ، قَالَ : دَخَلْتُ عَلَی أَنَسِ بْنِ مَالِکٍ فَسَأَلْتُہُ عَنِ النَّبِیذِ ، فَقَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الدُّبَّائِ وَالْمُزَفَّتِ؟ فَأَعَدْتُہَا عَلَیْہِ فَقَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الدُّبَّائِ وَالْمُزَفَّتِ ، فَأَعَدْتُہَا عَلَیْہِ فَقَالَ: نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الدُّبَّائِ وَالْمُزَفَّتِ۔ (بخاری 5587۔ مسلم 1577)",,,24252 24253,"حَدَّثَنَا عَلِیُّ بْنُ إِسْحَاقَ ، عَنِ ابْنِ مُبَارَکٍ ، عَنْ وِقَائٍ ، عَنْ عَلِیِّ بْنِ رَبِیعَۃَ ، عَنْ سَمُرَۃََ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الدُّبَّائِ وَالْمُزَفَّتِ۔ (احمد 5/17)",,,24253 24254,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الدُّبَّائِ وَالنَّقِیرِ وَالْمُزَفَّتِ۔ (مسلم 1583۔ احمد 3/384)",,,24254 24255,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ مُحَارِبٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، عَنِ الدُّبَّائِ ، وَالْحَنْتَمِ ، وَالْمُزَفَّتِ ، قَالَ : وَأُرَاہُ قَالَ : وَالنَّقِیرِ۔ (مسلم 1582۔ احمد 2/42)",,,24255 24256,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : خَطَبَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ النَّاسَ ذَاتَ یَوْمٍ ، فَجِئْتُ وَقَدْ فَرَغَ ، فَسَأَلْتُ النَّاسَ : مَاذَا قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ قَالُوا : نَہَی أَنْ یُنْبَذَ فِی الْمُزَفَّتِ وَالْقَرْعِ۔ (مسلم 1581۔احمد 2/54)",,,24256 24257,"حَدَّثَنَا شَبَابَۃُ ، عَنْ شُعْبَۃُ ، عَنْ سَلَمَۃَ ، قَالَ : قَالَ أَبُو الْحَکَمِ : حَدَّثَنِی أَخِی ، عَنْ أَبِی سَعِیدٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی عَنْ نَبِیذِ الْجَرِّ ، وَالدُّبَّائِ ، وَالْمُزَفَّتِ۔ (احمد 66۔ ابویعلی 1302)",,,24257 24258,"حَدَّثَنَا شَبَابَۃُ ، قَالَ : حَدَّثَنَا شُعْبَۃَ ، عَنْ بُکَیْرِ بْنِ عَطَائٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَعْمُرَ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الدُّبَّائِ ، وَالْمُزَفَّتِ ، وَالْحَنْتَمِ۔ (ترمذی 713۔ ابن ماجہ 3404)",,,24258 24259,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، عَنْ عَائِشَۃَ ، قَالَتْ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الدُّبَّائِ وَالْحَنْتَمِ وَالْمُزَفَّتِ ، وَقَالَتْ : الْحَنْتَمُ جِرَارٌ یُجَائُ بِہَا مِنْ مِصْرَ ، یُعْمَلُ فِیہَا الْخَمْرُ۔\n\n(بخاری 5595۔ مسلم 1578)",,,24259 24260,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ أَشْعَثَ بْنِ عُمَیْرٍ الْعَبْدِیِّ ، عَنْ أَبِیہِ ، قَالَ : أَتَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَفْدُ عَبْدِ الْقَیْسِ ، فَلَمَّا أَرَادُوا الاِنْصِرَافَ قَالُوا : قَدْ حَفِظْتُمْ عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کُلَّ شَیْئٍ سَمِعْتُمْ مِنْہُ ، فَسَلُوہُ عَنِ النَّبِیذِ ؟ فَأَتَوْہُ فَقَالُوا : یَا رَسُولَ اللہِ ، إِنَّا بِأَرْضٍ وَخِمَۃٍ لاَ یُصْلِحُنَا فِیہَا إِلاَّ الشَّرَابُ ، قَالَ : فَقَالَ : وَمَا شَرَابُکُمْ ؟ قَالُوا : النَّبِیذُ ، قَالَ : فِی أَیِّ شَیْئٍ تَشْرَبُونَہُ ؟ قَالُوا: فِی النَّقِیرِ ، قَالَ : فَلاَ تَشْرَبُوا فِی النَّقِیرِ ، قَالَ : فَخَرَجُوا فَقَالُوا : وَاللَّہِ لاَ یُصَالِحُنَا قَوْمُنَا عَلَی ہَذَا ، فَرَجَعُوا فَسَأَلُوہُ ، فَقَالَ لَہُمْ مِثْلَ ذَلِکَ ، ثُمَّ عَادُوا ، فَقَالَ لَہُمْ : لاَ تَشْرَبُوا فِی النَّقِیرِ فَیَضْرِبَ مِنْکُمُ الرَّجُلُ ابْنَ عَمِّہِ ضَرْبَۃً لاَ یَزَالُ مِنْہَا أَعْرَجَ إِلَی یَوْمِ الْقِیَامَۃِ ، قَالَ : فَضَحِکُوا ، قَالَ : مِنْ أَیِّ شَیْئٍ تَضْحَکُونَ ؟ قَالُوا: یَا رَسُولَ اللہِ ، وَالَّذِی بَعَثَکَ بِالْحَقِّ لَقَدْ شَرِبْنَا فِی نَقِیرٍ لَنَا فَقَامَ بَعْضُنَا إِلَی بَعْضٍ ، فَضَرَبَ ہَذَا ضَرْبَۃً عَرِجَ مِنْہَا إِلَی یَوْمِ الْقِیَامَۃِ۔ (الطبرانی 122)",,,24260 24261,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا سُلَیْمَانُ التَّیْمِیُّ ، عَنْ أَسْمَائَ بِنْتِ یَزِیدَ ، عَنِ ابْنِ عَمٍّ لَہَا ، یُقَالُ لَہُ: أَنَسٌ ، أَنَّہُ سَمِعَ ابْنَ عَبَّاسٍ یَقُولُ : أَلَمْ یَقُلِ اللَّہُ تَعَالَی : {وَمَا أَتَاکُمَ الرَّسُولُ فَخُذُوہُ وَمَا نَہَاکُمْ عَنْہُ فَانْتَہُوا}؟ قَالُوا: بَلَی ، قَالَ: أَلَمْ یَقُلَ اللَّہُ تَعَالَی: {وَمَا کَانَ لِمُؤْمِنٍ وَلاَ مُؤْمِنَۃٍ إذَا قَضَی اللَّہُ وَرَسُولُہُ أَمْرًا}؟ قَالَ: فَأَشْہَدُ عَلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنَّہُ نَہَی عَنْ نَبِیذِ النَّقِیرِ، وَالْمُزَفَّتِ، وَالدُّبَّائِ، وَالْحَنْتَمِ۔\n\n(نسائی 5154)",,,24261 24262,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی شِمْرٍ الضُّبَعِیِّ ، قَالَ سَمِعْت عَائِذَ بْنَ عَمْرٍو یَنْہَی عَنِ الْحَنْتَمِ ، وَالدُّبَّائِ ، وَالْمُزَفَّتِ ، وَالنَّقِیرِ ، قَالَ : فَقُلْتُ لَہُ : عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ فَقَالَ : نَعَمْ۔\n\n(احمد 5/64۔ طبرانی 29)",,,24262 24263,"حَدَّثَنَا مُحَمَّدُ بْنُ مُصْعَبٍ ، عَنِ الأَوْزَاعِیِّ ، عَنْ یَحْیَی ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ نَبِیذِ الْجَرِّ ، وَالدُّبَّائِ ، وَالْمُزَفَّتِ ، وَعَنِ الظُّرُوفِ کُلِّہَا۔\n\n(ابن ماجہ 408۔ احمد 2/540)",,,24263 24264,"حَدَّثَنَا یُونُسُ بْنُ مُحَمَّدٍ ، قَالَ : حدَّثَنَا عَبْدُ الْوَاحِدِ بْنُ زِیَادٍ ، عَنْ عَاصِمٍ الأَحْوَلِ ، عَنْ فُضَیْلِ بْنِ زَیْدٍ، قَالَ : کُنَّا عِنْدَ عَبْدِ اللہِ بْنِ مُغَفَّلٍ فَتَذَاکَرْنَا الشَّرَابَ فَقَالَ : الْخَمْرُ حَرَامٌ ، فَقُلْتُ : الْخَمْرُ حَرَامٌ فِی کِتَابِ اللہِ ، قَالَ : فَأَیُّ شَیْئٍ تُرِیدُ ؟ تُرِیدُ مَا سَمِعْتُہُ مِنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَنْہَی عَنِ الدُّبَّائِ ، وَالْحَنْتَمِ ، وَالْمُزَفَّتِ۔ (احمد 4/87۔ دارمی 2112)",,,24264 24265,"حَدَّثَنَا أَحْمَدُ بْنُ إِسْحَاقَ ، قَالَ : حدَّثَنَا عَبْدُ الْوَاحِدِ بْنُ زِیَادٍ ، قَالَ : حَدَّثَنَا کُلَیْبُ بْنُ وَائِلٍ ، قَالَ : حَدَّثَتْنِی رَبِیبَۃُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أَحْسَبُہَا زَیْنَبَ ، قَالَتْ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الدُّبَّائِ ، وَالْحَنْتَمِ ، وَأُرَی فِیہِ النَّقِیرَ۔ (بخاری 3492۔ طبرانی 716)",,,24265 24266,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی فَرْوَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ؛ أَنَّہُ کَرِہَ الْمُزَفَّتَ وَقَالَ : لأَنْ أَشْرَبَ بَوْلَ حِمَارٍ أَحَبَّ إِلَیَّ مِنْ أَنْ أَشْرَبَ فِی مُزَفَّتٍ۔",,,24266 24267,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی ہَارُونَ الْعَبْدِیِّ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الْمُزَفَّتِ۔ (عبدالرزاق 16930)",,,24267 24268,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنْ سَعْدِ بْنِ عُبَیْدَۃَ ، عَنِ الْبَرَائِ ، قَالَ : أَمَرَنِی عُمَرُ أَنْ أُنَادِیَ یَوْمَ الْقَادِسِیَّۃِ : لاَ نَبِیذَ فِی دُبَّائٍ ، وَلاَ حَنْتَمٍ ، وَلاَ مُزَفَّتٍ۔",,,24268 24269,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ عَبْدِ الْمَلِکِ بْنِ نَافِعٍ ، قَالَ سَأَلْتُ ابْنَ عُمَرَ عَنِ الطِّلاَئِ یُطْبَخُ ؟ فَقَالَ : لاَ بَأْسَ ، قُلْتُ : إِنَّہُ فِی مُزَفَّتٍ ، قَالَ : لاَ تَشْرَبْہُ فِی مُزَفَّتٍ۔",,,24269 24270,حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ سُلَیْمَانَ التَّیْمِیِّ ، عَنْ أَبِی مِجْلَزٍ ، عَنْ رَجُل ، عَنْ أَبِی ہُرَیْرَۃَ ؛ أَنَّہُ نَہَی عَنِ الْمُزَفَّتِ۔,,,24270 24271,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ حَبِیبِ بْنِ أَبِی عَمْرَۃَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الدُّبَّائِ ، وَالْمُزَفَّتِ ، وَالْحَنْتَمِ ، وَالنَّقِیرِ ، وَأَنْ یُخْلَطَ الْبَلَحُ بِالزَّہْوِ۔\n\n(مسلم3۔ نسائی 5057)",,,24271 24272,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنِ الْمُخْتَارِ بْنِ فُلْفُلٍ ، قَالَ : سَأَلْتُ أَنَسَ بْنَ مَالِکٍ عَنِ النَّبِیذِ ؟ قَالَ : اجْتَنِبْ مُسْکِرَہُ فِی کُلِّ شَیْئٍ ، وَاجْتَنِبْ مَا سِوَی ذَلِکَ فِیمَا زُفِّتَ فِی دَنٍّ ، أَوْ قِرْبَۃٍ ، أَوْ قَرْعَۃٍ ، أَوْ جَرَّۃٍ۔",,,24272 24273,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا عَبْدُ الْخَالِقِ بْنُ سَلَمَۃَ ، قَالَ ، سَمِعْتُ سَعِیدَ بْنَ الْمُسَیَّبِ یَقُولُ: سَمِعْتُ ابْنَ عُمَرَ یَقُولُ عِنْدَ ہَذَا الْمِنْبَرِ ، وَأَشَارَ إِلَی مِنْبَرِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : قَدِمَ وَفْدُ عَبْدِ الْقَیْسِ عَلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَسَأَلُوہُ عَنِ الأَشْرِبَۃِ ؟ فَنَہَاہُمْ عَنِ الدُّبَّائِ ، وَالنَّقِیرِ ، وَالْحَنْتَمِ ، فَقُلْتُ : یَا أَبَا مُحَمَّدٍ ، الْمُزَفَّتِ ؟ وَظَنَنَّا أَنَّہُ نَسِیَہُ ، فَقَالَ : لَمْ أَسْمَعْہُ یَوْمَئِذٍ مِنِ ابْنِ عُمَرَ۔\n\n(مسلم 1583۔ احمد 2/41)",,,24273 24274,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ أَبِی التَّیَّاحِ ، عَنْ حَفْصٍ اللَّیْثِیِّ ، عَنْ عِمْرَانَ بْنِ الْحُصَیْنِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی عَنِ الْحَنْتَمِ۔ (ترمذی 1738۔ احمد 4/427),,,24274 24275,"حَدَّثَنَا عُبَیْدُ بْنُ سَعِیدٍ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عَنْ عَائِشَۃَ ، قَالَتْ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الدُّبَّائِ وَالْمُزَفَّتِ۔ (بخاری 5595۔ مسلم 35)",,,24275 24276,"حَدَّثَنَا عَبِیْدَۃُ بْنُ حُمَیْدٍ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ قَالَ : قُلْتُ لِعَائِشَۃَ : مَا نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِنَ الأَشْرِبَۃِ ؟ قَالَتْ : نَہَی عَنِ الدُّبَّائِ وَالْمُزَفَّتِ۔ \n\nقَالَ إِبْرَاہِیمُ : فَقُلْتُ لِلأََسْوَدِ : فَالْحَنْتَمُ وَالْجِرَارُ الْخُضْرُ ؟ فَقَالَ : تُرِیدُ أَنْ نَقُولَ مَا لَمْ یُقَلْ۔",,,24276 24277,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی حَمْزَۃَ جَارٍ لَہُمْ ، قَالَ : سَمِعْتُ ہِلاَلاً رَجُلاً مِنْ بَنِی مَازِنٍ یُحَدِّثُ ، عَنْ سُوَیْد بْنِ مُقَرِّنٍ ، قَالَ : أَتَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِنَبِیذٍ فِی جَرَّۃٍ ، فَسَأَلْتُہُ ؟ فَنَہَانِی عَنْہُ ، فَأَخَذْتُ الْجَرَّۃَ فَکَسَرْتہَا۔ (احمد 3/447۔ طیالسی 9264)",,,24277 24278,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی نَضْرَۃَ ، عَنْ أَبِی سَعِیدٍ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ نَبِیذِ الْجَرِّ الأَخْضَرِ ، قُلْتُ : فَالأَبْیَضُ ؟ قَالَ : لاَ أَدْرِی۔ (مسلم 1580۔ ترمذی 1877)",,,24278 24279,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ التَّیْمِیِّ ، عَنْ أُمَیْنَۃَ ، عَنْ عَائِشَۃَ ، قَالَتْ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ نَبِیذِ الْجَرِّ۔ (ابن ماجہ 3407۔ عبدالرزاق 16964)",,,24279 24280,"حَدَّثَنَا ابْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنِ ابْنِ أَبِی أَوْفَی ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، عَنِ جَرِّ الأَخْضَرِ ، قُلْتُ : فَالأَبْیَضُ ؟ قَالَ : لاَ أَدْرِی۔ (بخاری 5596۔ احمد 4/353)",,,24280 24281,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ سَعِیدِ بْنِ یَزِیدَ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ أَسِیدٍ ، قَالَ : قَالَ رَجُلٌ لابْنِ الزُّبَیْرِ: أَفْتِنَا فِی نَبِیذِ الْجَرِّ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی عَنْ نَبِیذِ الْجَرِّ۔\n\n(احمد 4/3۔ بزار 2227)",,,24281 24282,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ أَبِی حَیَّانَ ، عَنْ عَبَایَۃَ بْنِ رِفَاعَۃَ ، أَنَّ جَدَّہُ رَافِعَ بْنَ خَدِیجٍ رَأَی جَرَّۃً خَضْرَائَ لأَہْلِہِ فِی الشَّمْسِ ، فَأَخَذَ جُلْمُودًا فَرَمَاہَا فَکَسَرَہَا ، فَإِذَا فِیہَا سَمْنٌ فَقَالَ : أَدْرِکُوا سَمْنَکُمْ۔\n\nقَالَ یَحْیَی : ظَنَّ فِیہَا نَبِیذًا۔",,,24282 24283,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ حُصَیْنٍ ، عَنِ امْرَأَۃٍ مِنْ بَنِی شَیْبَانَ ، أَنَّ زَوْجَہَا أَتَاہُمْ فَحَدَّثَہُمْ ؛ أَنَّ أَمِیرَ الْمُؤْمِنِینَ عَلِیًّا نَہَاہُمْ عَنْ نَبِیذِ الْجَرِّ ، قَالَ : فَکَسَرْنَا جَرَّۃً لَنَا۔",,,24283 24284,"حَدَّثَنَا وَکِیعٌ ، عَنْ عُیَیْنَۃَ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِیہِ ؛ أَنَّ أَبَا بُرْدَۃَ قَدِمَ مِنْ سَفَرٍ ، فَبَدَأَ بِمَنْزِلِ أَبِی بَکْرَۃَ، فَرَأَی فِی الْبَیْتِ جَرَّۃً ، فَقَالَ : مَا ہَذِہِ ؟ فَقِیلَ : فِیہَا نَبِیذٌ لأَبِی بَکْرَۃَ ، فَقَالَ : وَدِدْتُ أَنَّکُمْ حَوَّلْتُمُوہَا فِی سِقَائٍ ۔",,,24284 24285,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ دَاوُدَ بْنِ فَرَاہِیجَ ، قَالَ : سَمِعْتُ أَبَا ہُرَیْرَۃَ یَنْہَی عَنْ نَبِیذِ الْجَرِّ۔",,,24285 24286,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ وَذَکَرُوا النَّبِیذَ ، فَقَالَ : لاَ أَرَی بِہِ بَأْسًا فِی السِّقَائِ ، وَأَکْرَہُہُ فِی الْجَرِّ الأَخْضَرِ۔",,,24286 24287,حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی رَجَائٍ ، عَنْ مَالِکِ بْنِ دِینَارٍ ؛ أَنَّ جَابِرَ بْنَ زَیْدٍ وَالْحَسَنَ کَانَا یَکْرَہَانِ نَبِیذَ الْجَرِّ۔,,,24287 24288,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ شُعْبَۃَ ، عَنْ ثَابِتٍ ، قَالَ : قُلْتُ لابْنِ عُمَرَ : نُہِیَ عَنْ نَبِیذِ الْجَرِّ ؟ قَالَ: زَعَمُوا ذَاکَ ، قُلْتُ : عَنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ قَالَ : زَعَمُوا ذَاکَ ، قُلْتُ : أَنْتَ سَمِعْتَہُ ؟ قَالَ : زَعَمُوا ذَاکَ ، قَالَ : وَصَرَفَہُ اللَّہُ عَنِّی۔ (مسلم 50۔ احمد 35)",,,24288 24289,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا شُعْبَۃُ ، عَنْ أَبِی جَمْرَۃَ ؛ أَنَّ امْرَأَۃً أَتَتِ ابْنَ عَبَّاسٍ ، وَقَدْ کُنْتُ حَلَفْتُ أَنْ لاَ أَسْأَلَ عَنْ نَبِیذِ الْجَرِّ ، فَقَالَتْ لِی : سَلْہُ ، فَأَبَیْتُ أَنْ أَسْأَلَہُ ، فَسَأَلَہُ رَجُلٌ عَنْ نَبِیذِ الْجَرِّ ؟ فَنَہَاہُ، فَقُلْتُ : یَا أَبَا عَبَّاسٍ ، إِنِّی أَنْتَبِذُ فِی جَرٍّ أَخْضَرَ ، فَأَشْرَبُہُ حُلْوًا طَیِّبًا فَیُقَرْقِرُ بَطْنِی ، فَقَالَ : لاَ تَشْرَبْہُ ، وَإِنْ کَانَ أَحْلَی مِنَ الْعَسَلِ۔ (مسلم 24)",,,24289 24290,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : حدَّثَنَا سُلَیْمَانُ التَّیْمِیُّ ، عَنْ طَاوُوسٍ ؛ أَنَّ رَجُلاً أَتَی ابْنَ عُمَرَ فَقَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ نَبِیذِ الْجَرِّ ؟ فَقَالَ ابْنُ عُمَرَ : نَعَمْ ، فَقَالَ طَاوُوسٌ : وَاللَّہِ إنِّی سَمِعْتُہُ مِنْہُ۔ (مسلم 53۔ احمد 2/35)",,,24290 24291,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا جَرِیرُ بْنُ حَازِمٍ ، قَالَ : حَدَّثَنِی یَعْلَی بْنُ حَکِیمٍ ، عَنْ صُہَیْرَۃَ بِنْتِ جَیْفَرٍ ، سَمِعَہُ مِنْہَا ، قَالَتْ : حَجَجْنَا ثُمَّ انْصَرَفْنَا إِلَی الْمَدِینَۃِ ، فَدَخَلْنَا عَلَی صَفِیَّۃَ بِنْتِ حُیَیٍّ ، فَوَافَقْنَا عِنْدَہَا نِسْوَۃً مِنْ أَہْلِ الْکُوفَۃِ ، فَقُلْنَ لَنَا : إِنْ شِئْتُنَّ سَأَلْنَا وَسَمِعْتُنَّ ، وَإِنْ شِئْتُنَّ اسْأَلْنَ وَسَمِعْنَا ، فَقُلْنَ : سَلْنَ ، فَسَأَلْنَ عَنْ أَشْیَائَ مِنْ أَمْرِ الْمَرْأَۃِ وَزَوْجِہَا ، وَمِنْ أَمْرِ الْمَحِیضِ ، وَسَأَلْنَ عَنْ نَبِیذِ الْجَرِّ ، فَقَالَتْ : أَکْثَرْتُنَّ یَا أَہْلَ الْعِرَاقِ عَلَیْنَا فِی نَبِیذِ الْجَرِّ ، حَرَّمَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَبِیذَ الْجَرِّ ، مَا عَلَی إِحْدَاکُنَّ أَنْ تَطْبُخَ تَمْرَہَا ، ثُمَّ تَدْلُکُہُ ، ثُمَّ تُصَفِّیہِ فَتَجْعَلُہُ فِی سِقَائِہَا ، وَتُوکِئُ عَلَیْہِ ، فَإِذَا طَابَ شَرِبَتْ وَسَقَتْ زَوْجَہَا۔\n\n(احمد 6/337۔ ابویعلی 7117)",,,24291 24292,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ شُمَیْسَۃَ أُمِّ سَلَمَۃَ الْعَتَکِیَّۃِ ، قَالَتْ : سَمِعْتُ عَائِشَۃَ تَقُولُ : لاَ تَشْرَبْنَ فِی رَاقُودٍ ، وَلاَ جَرَّۃٍ ، وَلاَ قَرْعَۃٍ۔",,,24292 24293,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ الْمُبَارَکِ ، عَنْ کَرِیمَۃَ بِنْتِ ہَمَّامٍ ، عَنْ عَائِشَۃَ ، أَنَّہَا سَمِعَتْہَا تَقُولُ : إِیَّاکُمْ وَنَبِیذَ الْجَرِّ الأَخْضَرِ۔",,,24293 24294,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ الأَعْلَی بْنِ کَیْسَانَ ، قَالَ : سَمِعْتُ ابْنَ أَبِی الْہُذَیْلِ یَقُولُ : مَا فِی نَفْسِی مِنْ نَبِیذِ الْجَرِّ شَیْئٌ إِلأَ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ نَہَی عَنْہُ ، وَکَانَ إِمَامَ عَدْلٍ۔",,,24294 24295,"حَدَّثَنَا وَکِیعٌ ، عَنْ جَعْفَرِ بْنِ بُرْقَانٍ ، عَنْ مَیْمُونٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ تَشْرَبْ نَبِیذَ الْجَرِّ۔",,,24295 24296,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : قَالَ عَبْدُ اللہِ : السَّکَرُ خَمْرٌ۔",,,24296 24297,"حَدَّثَنَا شَرِیکٌ ، عَنْ أَبِی فَرْوَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، عَنْ سَالِمٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : السَّکَرُ خَمْرٌ۔",,,24297 24298,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنِ الشَّعْبِیِّ ، وَإِبْرَاہِیمَ ، وَأَبِی رَزِینٍ ، قَالُوا : السَّکَرُ خَمْرٌ۔",,,24298 24299,"حَدَّثَنَا ہُشَیْمٌ، عَنِ ابْنِ شُبْرُمَۃَ، عَنْ أَبِی زُرْعَۃَ بْنِ عَمْرِو بنِ جَرِیرٍ، قَالَ: ہِیَ الْخَمْرُ، وَہِیَ أَلأَمُ مِنَ الْخَمْرِ۔",,,24299 24300,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : ہِیَ الْخَمْرُ۔",,,24300 24301,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ لَیْثٍ ، عَنْ حَرْبٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ سُئِلَ عَنِ السَّکَرِ ؟ فَقَالَ : الْخَمْرُ لَیْسَ لَہَا کُنْیَۃٌ۔",,,24301 24302,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ عَاصِمٍ ، عَنْ أَبِی وَائِلٍ ، قَالَ : جَائَ إِلَی عَبْدِ اللہِ نَفَرٌ مِنَ الأَعْرَابِ یَسْأَلُونَہُ عَنِ السَّکَرِ ؟ فَقَالَ : إِنَّ اللَّہَ لَمْ یَجْعَلْ شِفَائَ کُمْ فِیمَا حَرَّمَ عَلَیْکُمْ۔",,,24302 24303,حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنِ أَبِی حَصِینٍ ، عَنْ یَحْیَی ، عَنْ مَسْرُوقٍ ، عَنْ عَبْدِ اللہِ ؛ مِثْلَہُ۔,,,24303 24304,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ أَبِی وَائِلٍ ، قَالَ : اشْتَکَی رَجُلٌ مِنَ الْحَیِّ بَطْنَہُ ، فَقِیلَ لَہُ : إِنَّ بِکَ الصَّفْرَ ، فَنَعَتُوا لَہُ السَّکَرَ ، فَأَرْسَلَ إِلَی عَبْدِ اللہِ یَسْأَلُہُ عَنْ ذَلِکَ ؟ فَقَالَ عَبْدُ اللہِ : إِنَّ اللَّہَ تَعَالَی لَمْ یَجْعَلْ شِفَائَ کُمْ فِیمَا حَرَّمَ عَلَیْکُمْ۔",,,24304 24305,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، وَسُفْیَانَ ، عَنْ أَبِی حَصِینٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : السَّکَرُ خَمْرٌ۔",,,24305 24306,"حَدَّثَنَا شَرِیکٌ ، عَنْ سَلَمَۃَ بْنِ تَمَّامٍ ، عَنْ عَامِرٍ ، قَالَ : السَّکَرُ خَمْرٌ۔",,,24306 24307,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ فُضَیْلِ بْنِ غَزْوَانَ ، عَنْ عَاصِمٍ ، عَنْ زِرٍّ ، عَنْ أَبِی وَائِلٍ ، عَنْ عَبْدِ اللہِ ، قَالَ : نَبِیذُ الْعِنَبِ خَمْرٌ۔",,,24307 24308,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَبْدِ اللہِ بْنِ الْوَلِیدِ ، قَالَ حَدَّثَتْنِی مَیْمُونَۃُ بِنْتُ عَبْدِ الرَّحْمَنِ بْنِ مَعْقِلٍ ؛ أَنَّ أَبَاہَا سُئِلَ عَنْ نَبِیذِ نَقِیعِ الزَّبِیبِ ؟ فَکَرِہَہُ۔,,,24308 24309,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ سُلَیْمَانَ ، عَنْ أَشْعَثَ ، عَنْ بُکَیْر مَوْلًی لِعَبْدِ اللہِ بْنِ مَسْعُودٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : لأَنْ أَکُونَ حِمَارًا یُسْتَقَی عَلَیَّ أَحَبَّ إِلَیَّ مِنْ أَنْ أَشْرَبَ نَبِیذَ زَبِیبٍ مُعَتَّقٍ۔",,,24309 24310,حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ ، وَعَامِرٍ ، وَعَطَائٍ ؛ أَنَّہُمْ کَرِہُوا نَبِیذَ الْعِنَبِ۔,,,24310 24311,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ لَیْثٍ ، عَنْ حَرْبٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ سُئِلَ عَنْ نَقِیعِ الزَّبِیبِ ؟ فَقَالَ : الْخَمْرُ اجْتَنِبُوہَا۔",,,24311 24312,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنْ بُکَیْر ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : لأَنْ أَکُونَ حِمَارًا یُسْتَقَی عَلَیَّ ، أَحَبَّ إِلَیَّ مِنْ أَنْ أَشْرَبَ نَبِیذَ زَبِیبٍ مُعَتَّقٍ۔",,,24312 24313,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ أَبِی حَنِیفَۃَ ، عَنْ حَمَّادٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : اشْرَبْ نَبِیذَ الزَّبِیبِ الْمُنْقَعِ ، مَا دَامَ حُلْوًا یَحْرو اللِّسَانَ۔",,,24313 24314,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی عُمَرَ ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُنْقَعُ لَہُ الزَّبِیبُ ، فَیَشْرَبُہُ الْیَوْمَ ، وَالْغَدَ ، وَبَعْدَ الْغَدِ ، إِلَی أَنْ یُمْسِی الثَّالِثَۃَ ، ثُمَّ یَأْمُرُ بِہِ فَیُسْقَی ، أَوْ یُہْرَاقَ۔ (مسلم 1589۔ ابوداؤد 3706)",,,24314 24315,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا عَبْدُ الْوَاحِدِ بْنُ صَفْوَانَ ، قَالَ : سَمِعْتُ أَبِی یُحَدِّثُ ، عَنْ أُمِّہِ ، قَالَتْ : کُنْتُ أَمْغَثُ لِعُثْمَانَ الزَّبِیبَ غَدْوَۃً فَیَشْرَبُہُ عَشِیَّۃً ، أَوْ أَمْغَثُہُ عَشِیَّۃً فَیَشْرَبُہُ غَدْوَۃً ، فَقَالَ لَہَا عُثْمَانُ : لَعَلَّکِ تَجْعَلِینَ فِیہِ زَہْوًا ؟ قَالَتْ : رُبَّمَا فَعَلْتُ ، قَالَ ، فَلاَ تَفْعَلِی۔",,,24315 24316,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنْ مُوسَی بْنِ طَرِیفٍ ، عَنْ أَبِیہِ ، قَالَ : کَانَ یُنْبَذُ لِعَلِیٍّ زَبِیبٌ فِی جَرَّۃٍ بَیْضَائَ ، فَیَشْرَبُہُ۔",,,24316 24317,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ عَبْدِ الْمَلِکِ بْنِ نَافِعٍ ، قَالَ : قُلْتُ لابْنِ عُمَرَ : إِنِّی أَنْبِذُ نَبِیذَ زَبِیبٍ ، فَیَجِیئُ نَاسٌ مِنْ أَصْحَابِنَا فَیَقْذِفُونَ فِیہِ التَّمْرَ ، فَیُفْسِدُونَہُ عَلَیَّ ، فَکَیْفَ تَرَی ؟ قَالَ : لاَ بَأْسَ بِہِ۔",,,24317 24318,"حَدَّثَنَا وَکِیعٌ ، عَنْ سَعِیدِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ عِکْرِمَۃَ ؛ فِی نَبِیذِ الْعِنَبِ ، قَالَ : کَان أَعْلاَہُ حَرَامًا ، وَأَسْفَلُہُ حَرَامًا۔",,,24318 24319,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَلِیِّ بْنِ الأَقْمَرِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ بِنَبِیذِ الْعَصِیرِ۔",,,24319 24320,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حُلاَمِ بْنِ صَالِحٍ ، عَنْ سُلَیْکِ بْنِ مِسْحَلٍ ، قَالَ : خَرَجَ عُمَرُ حَاجًّا ، أَوْ مُعْتَمِرًا ، فَنَزَلَ عَلَی مَائٍ فَدَعَا بِسُفْرَۃٍ ، فَأَکَلَ وَأَکَلَ الْقَوْمُ ، ثُمَّ دَعَا بِشَرَابٍ ، فَأُتِیَ بِقَدَحٍ مِنْ نَبِیذٍ ، فَقَالَ : ادْفَعْہُ إِلَی عَبْدِ الرَّحْمَنِ بْنِ عَوْفٍ ، فَلَمَّا شَمَّہُ رَدَّہُ ، ثُمَّ دَفَعَہُ إِلَی سَعْدِ بْنِ أبِی وَقَّاصٍ ، فَلَمَّا شَمَّہُ رَدَّہُ ، قَالَ : فَہَاتِہِ فَذَاقَہُ ، فَقَالَ : یَا عَجْلاَنُ ، یَعْنِی غُلاَمَہُ ، مَا ہَذَا ؟ فَقَالَ : یَا أَمِیرَ الْمُؤْمِنِینَ ، جَعَلْتُ زَبِیبًا فِی سِقَائٍ ، ثُمَّ عَلَّقْتُہُ بِبَطْنِ الرَّاحِلَۃِ وَصَبَبْتُ عَلَیْہِ مِنَ الْمَائِ ، قَالَ : اِئْتِ بِشَاہِدَیْنِ عَلَی مَا تَقُولُ ، فَجَائَ بِشَاہِدَیْنِ ، فَشَہِدَا ، فَقَالَ : أَیْ بُنَیَّ ، اغْسِلْ سِقَائَ ک یَلِنُ لَنَا شَرَابُہُ ، فَإِنَّ السِّقَائَ یَغْتَلِمُ۔",,,24320 24321,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ مَنْصُورِ بْنِ حَیَّانَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : سَأَلَہُ رَجُلٌ ، فَقَالَ : نَعْمِدُ إِلَی الزَّبِیبِ فَنَغْسِلُہُ مِنْ غُبَارِہِ ، ثُمَّ نَجْعَلُہُ فِی دَنٍّ ، أَوْ فِی خَابِیَۃٍ ، فَنَدَعُہُ فِی الشِّتَائِ شَہْرَیْنِ ، وَفِی الصَّیْفِ أَقَلَّ مِنْ ذَلِکَ ؟ فَقَالَ سَعِیدٌ : تِلْکَ الْخَمْرُ اجْتَنِبُوہَا۔",,,24321 24322,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ عُمَرَ بْنِ عَامِرٍ ، عَنْ قتادۃ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ (ح) وَعَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالاَ : لاَ بَأْسَ بِشُرْبِ الْعَصِیرِ مَا لَمْ یَغْلِ ۔ قَالَ سَعِیدٌ : إِذَا غَلاَ ، فَہُوَ خَمْرٌ اجْتَنِبْہُ ، وَقَالَ إِبْرَاہِیمُ : إِذَا غَلاَ فَدَعْہُ۔",,,24322 24323,"حَدَّثَنَا جَرِیر ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا غَلاَ فَلا تَشْرَبہُ۔",,,24323 24324,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ یَزِیدَ بْنِ عَبْدِ اللہِ بْنِ قُسَیْطٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّہُ کَانَ لاَ یَرَی بِالْعَصِیرِ بَأْسًا مَا لَمْ یُزْبِدْ ، فَإِذَا أَزَبَدَ نَہَی عَنْہُ ، وَقَالَ : إِنَّمَا یُزْبِدُ الْخَمْرُ۔",,,24324 24325,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ خُصَیْفٍ ، قَالَ : سَأَلْتُ سَعِیدًا عَنِ الْعَصِیرِ ؟ فَقَالَ : اشْرَبْہُ مِنْ یَوْمٍ وَلَیْلَۃٍ۔",,,24325 24326,"حَدَّثَنَا مُحَمَّدٌ ، عَنْ شُعْبَۃَ ، عَنْ عَمْرِو بْنِ أَبِی حَکِیمٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : اشْرَبِ الْعَصِیرَ مَا لَمْ یَہْدُِرْ۔",,,24326 24327,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ أَبِی یَعْفُورَ عَبْدِ الرَّحْمَنِ بْنِ عُبَیْدٍ الْعَامِرِیِّ ، عَنْ أَیْمَنَ أَبِی ثَابِتٍ ، قَالَ : کُنْتُ جَالِسًا عِنْدَ ابْنِ عَبَّاسٍ ، فَجَائَ ہُ رَجُلٌ فَسَأَلَہُ عَنِ الْعَصِیرِ ؟ فَقَالَ : اشْرَبْہُ مَا دَامَ طَرِیًّا۔",,,24327 24328,"حَدَّثَنَا إِسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ، قَالَ : لاَ بَأْسَ بِشُرْبِ الْعَصِیرِ مَا لَمْ یَغْلِ ثَلاَثًا۔",,,24328 24329,"حَدَّثَنَا حَفْصٌ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : اشْرَبْہُ ثَلاَثًا ، مَا لَمْ یَغْلِ۔",,,24329 24330,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، وَوَکِیعٌ ، عَنْ ہِشَامِ بْنِ عَائِذٍ ، قَالَ : سَأَلْتُ إِبْرَاہِیمَ عَنِ الْعَصِیرِ ؟ فَقَالَ : اشْرَبْہُ مَا لَمْ یَتَغَیَّرْ۔",,,24330 24331,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ ہِشَامٍ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ بِشُرْبِہِ وَبَیْعِہِ مَا لَمْ یَغْلِ۔",,,24331 24332,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، وَأَبِی جَعْفَرٍ ، وَعَطَائٍ ، قَالُوا : اشْرَبِ الْعَصِیرَ ابنَ یَوْمٍ وَلَیْلَۃٍ۔",,,24332 24333,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ دِینَارٍ ، عَنِ الْحَسَنِ ، قَالَ : اشْرَبِ الْعَصِیرَ مَا لَمْ یَتَغَیَّرْ۔",,,24333 24334,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ عَبْدِ اللہِ بْنِ مُرَّۃَ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ سُئِلَ عَنِ الْعَصِیرِ ؟ قَالَ : اشْرَبْہُ مَا لَمْ یَأْخُذْہُ شَیْطَانُہُ ، قِیلَ : وَفِی کَمْ یَأْخُذُہُ شَیْطَانُہُ ؟ قَالَ : فِی ثَلاَثٍ۔",,,24334 24335,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا بَشِیرُ بْنُ عُقْبَۃَ ، قَالَ : سَأَلْتُ ابْنَ سِیرِینَ عَنْ عَصِیرِ الْعِنَبِ ؟ فَقَالَ : عَصِیرُ یَوْمِہِ فِی مَعْصَرَتِہِ ، قَالَ : اشْرَبْہُ فِی یَوْمِہِ ، فَإِنِّی أَکْرَہُ إِذَا حُوِّلَ فِی إِنَائٍ ، أَوْ وِعَائٍ ، وَقَالَ : عَلَیْکُمْ بِسُلاَفَۃِ الْعِنَبِ ، فَإِنَّہَا أَطْیَبُہُ ، فَاشْرَبْہُ۔",,,24335 24336,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی صَالِحٍ ، عَنْ جَابِرٍ ، قَالَ : کُنَّا مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَاسْتَسْقَی ، فَقَالَ رَجُلٌ : أَلاَ نُسْقِیکَ نَبِیذًا ؟ قَالَ : بَلَی ، قَالَ : فَخَرَجَ الرَّجُلُ یَشْتَدُّ ، فَجَائَ بِقَدَحٍ فِیہِ نَبِیذٌ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَلاَ خَمَّرْتَہُ وَلَوْ أَنْ تَعْرُضَ عَلَیْہِ عُودًا۔\n\n(مسلم 94۔ ابوداؤد 3727)",,,24336 24337,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : أَتَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ السِّقَایَۃَ ، فَقَالَ : اُسْقُونِی مِنْ ہَذَا ، فَقَالَ الْعَبَّاسُ : أَلاَ نَسْقِیکَ مِمَّا نَصْنَعُ فِی الْبُیُوتِ؟ قَالَ : لاَ ، وَلَکِنَ اسْقُونِی مِمَّا یَشْرَبُ النَّاسُ ، قَالَ : فَأُتِیَ بِقَدَحٍ مِنْ نَبِیذٍ فَذَاقَہُ فَقَطَّبَ ، ثُمَّ قَالَ : ہَلُمُّوا مَائً ، فَصَبَّہُ عَلَیْہِ ، ثُمَّ قَالَ : زِدْ فِیہِ ، مَرَّتَیْنِ ، أَوْ ثَلاَثًا ، ثُمَّ قَالَ : إِذَا أَصَابَکُمْ ہَذَا فَاصْنَعُوا بِہِ ہَکَذَا۔\n\n(دارقطنی 81)",,,24337 24338,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْمَاعِیلَ ، عَنْ قُرَّۃَ الْعِجْلِیّ ، عَنْ عَبْدِ الْمَلِکِ بْنِ الْقَعْقَاعِ ، عَنِ ابْنِ عُمَرَ ، قَالَ : کُنَّا عِنْدَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَأُتِیَ بِقَدَحٍ فِیہِ شَرَابٌ ، فَقَرَّبَہُ ثُمَّ رَدَّہُ ، فَقَالَ لَہُ بَعْضُ جُلَسَائِہِ : حَرَامٌ ہُوَ یَا رَسُولَ اللہِ ؟ قَالَ : فَقَالَ : رُدُّوہُ ، فَرَدُّوہُ ، ثُمَّ دَعَا بِمَائٍ فَصَبَّہُ عَلَیْہِ ، ثُمَّ شَرِبَ ، فَقَالَ : اُنْظُرُوا ہَذِہِ الأَشْرِبَۃَ ، إِذَا اغْتَلَمَتْ عَلَیْکُمْ فَاقْطَعُوا مُتُونَہَا بِالْمَائِ ۔ (نسائی 5205۔ بیہقی 305)",,,24338 24339,"حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ خَالِدِ بْنِ سَعْدٍ ، عَنْ أَبِی مَسْعُودٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَطِشَ وَہُوَ یَطُوفُ بِالْبَیْتِ حَوْلَ الْکَعْبَۃِ ، فَاسْتَسْقَی فَأُتِیَ بِنَبِیذٍ مِنَ السِّقَایَۃِ ، فَشَمَّہُ فَقَطَّبَ، فَقَالَ: عَلَیَّ بِذَنُوبٍ مِن زَمْزَمَ، فَصَبَّ عَلَیْہِ وَشَرِبَ، فَقَالَ رَجُلٌ: حَرَامٌ ہُوَ یَا رَسُولَ اللہِ؟ فَقَالَ: لاَ۔ \n\n(نسائی 5212۔ بیہقی 304)",,,24339 24340,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ أَشْعَثَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُنْبَذُ لَہُ فِی سِقَائٍ ، فَإِذَا لَمْ یَکُنْ سِقَائٌ ، نُبِذَ لَہُ فِی تَوْرٍ ۔ قَالَ أَشْعَثُ : وَالتَّوْرُ مِنْ لِحَائِ الشَّجَرِ۔\n\n(مسلم 1584۔ ابوداؤد 3695)",,,24340 24341,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ زَاذَانَ ، قَالَ : سَأَلْتُ ابْنَ عُمَرَ عَنِ النَّبِیذِ ؟ فَقُلْتُ لَہُ : إِنَّ لَنَا لُغَۃً غَیْرَ لُغَتِکُمْ ، فَفَسِّرْہُ لَنَا بِلُغَتِنَا ، فَقَالَ ابْنُ عُمَرَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الْحَنْتَمَۃِ ، وَہِیَ الْجَرَّۃُ ، وَنَہَی عَنِ الدُّبَّائِ ، وَہِیَ الْقَرْعَۃُ ، وَعَنِ الْمُزَفَّتِ وَہِیَ الْمُقَیَّرُ ، وَعَنِ النَّقِیرِ ، وَہِیَ النَّخْلَۃُ ، وَأَمَرَ أَنْ یُنْبَذَ فِی الأَسْقِیَۃِ۔ (مسلم 1583۔ ترمذی 1868)",,,24341 24342,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ سُلَیْمَانَ التَّیْمِیِّ ، عَنْ أُمَیْنَۃَ ؛ أَنَّہَا سَمِعَتْ عَائِشَۃَ تَقُولُ : أَتَعْجِزُ إِحْدَاکُنَّ أَنْ تَتَّخِذَ مِنْ مَسْکِ أُضْحِیَّتِہَا سِقَائً فِی کُلِّ عَامٍ ، فَإِنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی ، أَوْ مَنَعَ عَنْ نَبِیذِ الْجَرِّ ، وَالْمُزَفَّتِ ، وَأَشْیَائَ نَسِیَہَا التَّیْمِیُّ۔",,,24342 24343,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، عَنْ سِمَاکٍ ، عَنْ رَجُلٍ ؛ أَنَّہُ سَأَلَ الْحَسَنَ بْنَ عَلِیٍّ عَنِ النَّبِیذِ ؟ فَقَالَ : اشْرَبْ ، فَإِذَا رَہِبْتَ أَنْ تَسْکَرَ فَدَعْہُ۔",,,24343 24344,"حَدَّثَنَا مُعَاذٌ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : سَأَلْتُ مُحَمَّدًا عَنْ نَبِیذِ السِّقَائِ الَّذِی یُوکَی وَیُعَلَّقُ ؟ فَقَالَ : لاَ أَعْلَمُ بِہِ بَأْسًا۔",,,24344 24345,"حَدَّثَنَا خَالِدُ بْنُ حَرْمَلَۃَ الْعَبْدِیُّ ، عَنِ الْوَلِیدِ بْنِ عَمْرٍو ابْنِ أَخِی أَبِی نَضْرَۃَ ؛ أَنَّہُ سَأَلَ الْحَسَنَ عَنِ الْجُفِّ ؟ فَقَالَ : وَمَا الْجُفُّ ؟ قَالَ : سِقَائٌ عَلَی ثَلاَثِ قَوَائِمَ ، یُوکَی مِنْ أَعْلاَہ وَمِنْ أَسْفَلِہِ ، قَالَ : لاَ بَأْسَ بِہِ۔",,,24345 24346,"حَدَّثَنَا أَبُو الأَحْوَصِ، عَنْ أَبِی إِسْحَاقَ، عَنْ عَمْرِو بْنِ مَیْمُونٍ، قَالَ: قَالَ عُمَرُ: إِنَّا نَشْرَبُ ہَذَا الشَّرَابَ الشَّدِیدَ ، لِنَقْطَعَ بِہِ لُحُومَ الإِبِلِ فِی بُطُونِنَا أَنْ یُؤْذِیَنَا ، فَمَنْ رَابَہُ مِنْ شَرَابِہِ شَیْئٌ ، فَلْیَمْزُجْہُ بِالْمَائِ ۔",,,24346 24347,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إِسْمَاعِیلُ بْنُ أَبِی خَالِدٍ ، عَنْ قَیْسِ بْنِ أَبِی حَازِمٍ ، قَالَ : حَدَّثَنِی عُتْبَۃُ بْنُ فَرْقَدٍ ، قَالَ : قَدِمْتُ عَلَی عُمَرَ ، فَدَعَا بِعُسٍّ مِنْ نَبِیذٍ قَدْ کَادَ یَصِیرُ خَلاًّ ، فَقَالَ : اشْرَبْ ، فَأَخَذْتُہُ فَشَرِبْتُہُ ، فَمَا کِدْتُ أَنْ أَسِیغَہُ ، ثُمَّ أَخَذَہُ فَشَرِبَہُ ، ثُمَّ قَالَ : یَا عُتْبَۃُ ، إِنَّا نَشْرَبُ ہَذَا النَّبِیذَ الشَّدِیدَ لِنَقْطَعَ بِہِ لُحُومَ الإِبِلِ فِی بُطُونِنَا أَنْ یُؤْذِیَنَا۔",,,24347 24348,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن ہَمَّامٍ ، قَالَ : أُتِیَ عُمَرُ بِنَبِیذِ زَبِیبٍ مِنْ نَبِیذِ زَبِیبِ الطَّائِفِ ، قَالَ : فَلَمَّا ذَاقَہُ قَطَّبَ فَقَالَ : إِنَّ لِنَبِیذِ زَبِیبِ الطَّائِفِ لَعُرَامًا ، ثُمَّ دَعَا بِمَائٍ فَصَبَّہُ عَلَیْہِ فَشَرِبَ ، وَقَالَ : إِذَا اشْتَدَّ عَلَیْکُمْ فَصُبُّوا عَلَیْہِ الْمَائَ وَاشْرَبُوا۔",,,24348 24349,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّ قَوْمًا مِنْ ثَقِیفٍ لَقُوا عُمَرَ بْنَ الْخَطَّابِ وَہُوَ قَرِیبٌ مِنْ مَکَّۃَ ، فَدَعَاہُمْ بِأَنْبِذَتِہِمْ ، فَأَتَوْہُ بِقَدَحٍ مِنْ نَبِیذٍ فَقَرَّبَہُ مِنْ فِیہِ ، ثُمَّ دَعَا بِمَائٍ فَصَبَّہُ عَلَیْہِ مَرَّتَیْنِ ، أَوْ ثَلاَثًا ، فَقَالَ : اکْسِرُوہُ بِالْمَائِ ۔",,,24349 24350,"حَدَّثَنَا شَرِیکٌ، عَنْ إِبْرَاہِیمَ ، عَن مُجَاہِدٍ ، قَالَ : قَالَ عُمَرُ : إِنِّی رَجُلٌ مِعْجَارُ الْبَطْنِ ، أَوْ مِشْعَارُ الْبَطْنِ، فَأَشْرَبُ ہَذَا السَّوِیقَ فَلاَ یُلاَئِمُنِی ، وَأَشْرَبُ ہَذَا اللَّبَنَ فَلاَ یُلاَئِمُنِی ، وَأَشْرَبُ ہَذَا النَّبِیذَ الشَّدِیدَ فَیُسَہِّلُ بَطْنِی۔",,,24350 24351,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ عِمْرَانَ بْنِ مُسْلِمٍ ، عَنْ سُوَیْد بْنِ غَفَلَۃَ ، قَالَ : کُنْتُ أَشْرَبُ النَّبِیذَ مَعَ أَبِی الدَّرْدَائِ وَأَصْحَابِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِالشَّامِ ، فِی الْحِبَابِ الْعِظَامِ۔",,,24351 24352,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ سَعِیدِ بْنِ مَسْرُوقٍ ، عَنِ الشَّمَّاسِ ، قَالَ : قَالَ عَبْدُ اللہِ : مَا یَزَالُ الْقَوْمُ وَإِنَّ شَرَابَہُمْ لَحَلاَلٌ ، حَتَّی یَصِیرَ عَلَیْہِمْ حَرَامًا۔",,,24352 24353,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَمْرِو بْنِ مَیْمُونٍ ، قَالَ : لَمَّا طُعِنَ عُمَرُ أَتَاہُ الطَّبِیبُ ، فَقَالَ : أَیُّ الشَّرَابِ أَحَبَّ إِلَیْک ؟ قَالَ : النَّبِیذُ۔",,,24353 24354,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ سِمَاکٍ ، عَنْ أَبِی حَصِینٍ ، قَالَ : رَأَیْتُ زِرَّ بْنَ حُبَیْشٍ یَشْرَبُ نَبِیذَ الْخَوَابِی۔",,,24354 24355,"حَدَّثَنَا حَفْصٌ ، عَنْ حُمَیْدِ بْنِ سُلَیْمَانَ ، عَنْ مُجَاہِدٍ ، عَنْ عَائِشَۃَ ، قَالَتْ : کُنْت أَنْبِذُ لِرَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَکُنْت آخُذُ الْقُبْضَۃَ مِنَ الزَّبِیبِ فَأُلْقِیہَا فِیہِ۔",,,24355 24356,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُجَالِدٍ ، قَالَ : قَالَ عَامِرٌ : اشْرَبُوا نَبِیذَ الْعُرْسِ ، وَلاَ تَسْکَرُوا مِنْہُ۔",,,24356 24357,"حَدَّثَنَا وَکِیعٌ ، عَنْ عِیسَی بْنِ الْمُسَیَّبِ ، عَنِ الشَّعْبِیِّ ، عَنِ ابْنِ أَبِی لَیْلَی ، قَالَ : أَشْہَدُ عَلَی الْبَدْرِیِّینَ أَنَّہُمْ کَانُوا یَشْرَبُونَ نَبِیذَ الْعُرْسِ۔",,,24357 24358,"حَدَّثَنَا أَبُو مُعاویَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ التَّیْمِیِّ ، عَنْ أَبِیہِ ، عَنْ أَبِی ذَرٍّ ، قَالَ : یَکْفِینِی کُلَّ یَوْمٍ شَرْبَۃٌ مِنْ مَائٍ ، أَوْ شَرْبَۃٌ مِنْ نَبِیذٍ ، أَوْ شَرْبَۃٌ مِنْ لَبَنٍ ، وَفِی الْجُمُعَۃِ قَفِیزٌ مِنْ قَمْحٍ۔",,,24358 24359,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ عَبْدِ الْمَلِکِ ، قَالَ : سَأَلْتُ ابْنَ عُمَرَ عَنِ النَّبِیذِ الشَّدِیدِ ؟ فَقَالَ : جَلَسَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَجْلِسًا بِمَکَّۃَ ، فَجَائَ ہُ رَجُلٌ فَجَلَسَ إِلَی جَنْبِہِ ، فَوَجَدَ مِنْہُ رِیحًا شَدِیدَۃً ، فَقَالَ : مَا ہَذَا الَّذِی شَرِبْتَ ؟ فَقَالَ : نَبِیذٌ ، فَقَالَ : جِئْنِی مِنْہُ ، قَالَ : فَدَعَا بِمَائٍ فَصَبَّہُ عَلَیْہِ وَشَرِبَ ، ثُمَّ قَالَ : إِذَا اغْتَلَمَتْ عَلَیْکُم أَسْقِیَتُکُمْ فَاکْسِرُوہَا بِالْمَائِ ۔",,,24359 24360,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : صَنَعْتُ طَعَامًا فَدَعَوْتُ أَصْحَابَ عَبْدِاللہِ؛ عَمْرَو بْنَ شُرَحْبِیلَ، وَعَبْدَ اللہ بْنَ ذِئْبٍ، وَعُمَارَۃَ، وَمُرَّۃَ الْہَمْدَانِیَّ، وَعَمْرَو بْنَ مَیْمُونٍ فَسَقَیْتہمُ النَّبِیذَ وَالطِّلاَ فَشَرِبُوا ، فَقَالَ الأَعْمَشُ : قُلْتُ لَہُ : کَانُوا یَرَوْنَ الْخَوَابِی ؟ قَالَ : نَعَمْ ، کَانُوا یَنْظُرُونَ إِلَیْہَا وَہُمْ یَسْتَقُونَ مِنْہَا۔",,,24360 24361,حَدَّثَنَا حَفْصٌ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یَشْرَبُ النَّبِیذَ ، یُنْبَذُ لَہُ غَدْوَۃً فَیَشْرَبُہُ عَشِیَّۃً۔,,,24361 24362,"حَدَّثَنَا أَبُو أُسَامَۃَ، عَنْ أَبِی حَیَّانَ، عَنْ یُوسُفَ، قَالَ: کَانَ الْحَسَنُ یُدْعَی إِلَی الْعُرْسِ، فَیَشْرَبُ مِنْ نَبِیذِہِمْ۔",,,24362 24363,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : أَعْرَسْتُ فَدَعَوْتُ أَصْحَابَ عَلِیٍّ ، وَأَصْحَابَ عَبْدِ اللہِ ، مِنْ أَصْحَابِ عَلِیٍّ ؛ عُمَارَۃُ بْنُ عَبْدٍ ، وَہُبَیْرَۃُ بْنُ یَرِیْمَ ، وَالْحَارِثُ الأَعْوَرُ ، وَمِنْ أَصْحَابِ عَبْدِ اللہِ ؛ عَلْقَمَۃُ بْنُ قَیْسٍ ، وَعَبْدُ الرَّحْمَن بْنُ یَزِیدَ ، وَعَبْدُ اللہ بْنُ ذِئْبٍ ، فَنَبَذْت لَہُمْ فِی الْخَوَابِی ، فَکَانُوا یَشْرَبُونَ مِنْہَا ، فَقُلْتُ : وَہُمْ یَرَوْنَہَا ؟ قَالَ : نَعَمْ ، یَنْظُرُونَ إِلَیْہَا۔",,,24363 24364,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنِ الْحَسَنِ بْنِ صَالِحٍ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : النَّبِیذُ حَلاَلٌ۔",,,24364 24365,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ سُفْیَانَ الْعَطَّارِ ، قَالَ : سَأَلَ رَجُلٌ مَاہَانَ الْحَنَفِیَّ ، فَقَالَ : یَا أَبَا سَالِمٍ ، مَا تَقُولُ فِی النَّبِیذِ ؟ فَقَالَ : أَقُولُ فِی النَّبِیذِ : إِنَّ مَنْ حَرَّمَ مَا أَحَلَّ اللَّہُ ، کَمَنْ أَحَلَّ مَا حَرَّمَ اللَّہُ۔",,,24365 24366,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ الْجُرَیْرِیِّ ، عَنْ أَبِی الْعَلاَئِ ، قَالَ : انْتَہَی قَوْلُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی الأَشْرِبَۃِ إِلَی أَنْ قَالَ : لاَ تَشْرَبُوا مَا یُسَفِّہُ أَحْلاَمَکُمْ ، وَمَا یُذْہِبُ أَمْوَالَکُمْ۔",,,24366 24367,حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَاصِمٍ ، عَنْ مُحَمَّدٍ ؛ أَنَّہُ کَانَ لاَ یَنْبِذُ إِلاَّ فِی سِقَائٍ مُوکی۔,,,24367 24368,"حَدَّثَنَا مُلاَزِمُ بْنُ عَمْرٍو ، عَنْ عُجِیبَۃَ بْنِ عَبْدِ الْحَمِیدِ ، عَنْ عَمِّہِ قَیْسِ بْنِ طَلْقٍ ، عَنْ أَبِیہِ طَلْقِ بْنِ عَلِیٍّ، قَالَ : جَلَسْنَا عِنْدَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَجَائَ وَفْدُ عَبْدِ الْقَیْسِ فَقَالَ : مَا لَکُمْ قَدِ اصْفَرَّتْ أَلْوَانُکُمْ ، وَعَظُمَتْ بُطُونُکُمْ ، وَظَہَرَتْ عُرُوقُکُمْ ؟ قَالَ : قَالُوا : أَتَاکَ سَیِّدُنَا فَسَأَلَکَ عَنْ شَرَابٍ کَانَ لَنَا مُوَافِقًا فَنَہَیْتَہُ عَنْہُ ، وَکُنَّا بِأَرْضٍ مُحِِمَّۃٍ ، قَالَ : فَاشْرَبُوا مَا طَابَ لَکُمْ۔ (طبرانی 8256)",,,24368 24369,"حَدَّثَنَا جَرِیر ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لاَ خَیرَ فِی النَبِیذِ إِذَا کَان حُلوًا۔",,,24369 24370,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ سَعِیدِ بْنِ مَسْرُوقٍ ، قَالَ : دَعَانَا رَجُلٌ إِلَی طَعَامٍ فَأَکَلْنَا ، ثُمَّ أَتَانَا بِشَرَابٍ ، فَشَرِبَ الْقَوْمُ وَلَمْ أَشْرَبْ ، قَالَ : فَنَظَرَ إِلَیَّ بَکْرٌ ، یَعْنِی ابْنَ مَاعِزٍ ، نَظْرَۃً ظَنَنْتُ أَنَّہُ مَقَتَنِی۔",,,24370 24371,"حَدَّثَنَا یَزِیدُ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : إِذَا دَخَلْتْ عَلَی أَخِیکَ ، فَسَلْہُ عَنْ شَرَابِہِ ، فَإِنْ کَانَ نَبِیذُ سِقائٍ فَاشْرَبْ۔",,,24371 24372,"حَدَّثَنَا عَبِیْدَۃُ بْنُ حُمَیْدٍ ، عَنْ أَبِی مِسْکِینٍ ، عَنْ ہُزَیْلِ بْنِ شُرَحْبِیلَ ، قَالَ : مَرَّ عُمَرُ بْنُ الْخَطَّابِ عَلَی ثَقِیفٍ فَاسْتَسْقَاہُمْ ، فَقَالُوا : أَخْبِؤُوا نَبِیذَکُمْ ، فَسَقَوْہُ مَائً ، فَقَالَ : اسْقُونِی مِنْ نَبِیذِکُمْ یَا مَعْشَرَ ثَقِیفٍ ، قَالَ : فَسَقَوْہُ ، فَأَمَرَ الْغُلاَمَ فَصَبَّ ، ثُمَّ أَمْسَکَ بِیَدِہِ ، ثُمَّ قَالَ : یَا مَعْشَرَ ثَقِیفٍ ، إِنَّکُمْ تَشْرَبُونَ مِنْ ہَذَا الشَّرَابِ الشَّدِیدِ ، فَأَیَّکُمْ رَابَہُ مِنْ شَرَابِہِ شَیْئٌ ، فَلْیَکْسِرْہُ بِالْمَائِ ۔",,,24372 24373,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الأَسْوَدِ ، قَالَ : کَانَ عَبْدُ اللہِ یُنْبَذُ لَہُ فِی الْجَرِّ الأَخْضَرِ۔",,,24373 24374,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْمجَالِدِ بْنِ أَبِی رَاشِدٍ ، قَالَ : دَخَلَ عَمْرُو بْنُ حُرَیْثٍ عَلَی عَبْدِ اللہِ فِی حَاجَۃٍ ، قَالَ : فَقَالَ عَبْدُ اللہِ : یَا جَارِیَۃُ ، اسْقِینَا نَبِیذًا ، فَسَقَتْہُ مِنْ جَرٍّ أَخْضَرَ۔",,,24374 24375,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ مَنْصُورٍ ، عَنْ خَالِدِ بْنِ سَعْدٍ ، عَنْ أُمِّ وَلَدٍ لأَبِی مَسْعُودٍ الأَنْصَارِیِّ ، قَالَتْ : کُنْتُ أَنْبِذُ لأَبِی مَسْعُودٍ فِی الْجَرِّ الأَخْضَرِ۔",,,24375 24376,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی الْحَارِثِ التَّیْمِیِّ ، عَنْ أُمِّ مَعْبَدٍ ، قَالَ : قَالَتْ : یَا بُنَیَّ ، إِنَّ مُحَرِّمَ مَا أَحَلَّ اللَّہُ ، کَمُسْتَحِلِّ مَا حَرَّمَ اللَّہُ، إِنِّی کُنْتُ أَنْبِذُ النَّبِیذَ لِقَرَظَۃَ بْنِ کَعْبٍ، وَکَانَ رَجُلاً قَدْ آتَاہُ اللَّہُ خَیْرًا کَثِیرًا، فَیَسْقِیہِ أَصْحَابَ مُحَمَّدٍ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَکَانَ یَغْشَاہُ مِنْہُمْ ؛ مُعَاذُ بْنُ جَبَلٍ ، وَزَیْدُ بْنُ أَرْقَمَ ، فِی الدَّنِّ الْمُزَفَّتِ ، وَالْجَرِّ الأَخْضَرِ۔",,,24376 24377,حَدَّثَنَا وَکِیعٌ، عَنِ الْحَسَنِ بْنِ حَکِیمٍ، عَنْ أُمِّہِ؛ أَنَّ أَبَا بَرْزَۃَ کَانَ یَرَی أَہْلَہُ یَنْبِذُونَ فِی الْجَرِّ، وَلاَ یَنْہَاہُمْ۔,,,24377 24378,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ مُسْلِمٍ ، قَالَ : کَانَ ابْنُ أَبِی أَوْفَی یَشْرَبُ نَبِیذَ الْجَرِّ الأَخْضَرِ۔",,,24378 24379,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ مُغِیرَۃَ ، عَنْ أُم مُوسَی ، قَالتْ : کُنْتُ أَنْبِذُ لعَلِیٍّ فِی الْجَرِّ الأَخْضَرِ۔",,,24379 24380,"حَدَّثَنَا إِسْمَاعِیلُ بْنُ عُلَیَّۃَ ، عَنْ أَبِی ہَارُونَ الْغَنَوِیِّ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ : صَنَعَ قَیْسُ بْنُ عُبَادٍ لأُنَاسٍ مِنَ الْقُرَّائِ طَعَامًا ، ثُمَّ سَقَاہُمْ نَبِیذًا ، ثُمَّ قَالَ : تَدْرُونَ مَا النَّبِیذُ الَّذِی سَقَیْتُکُمْ ؟ قَالُوا : نَعَمْ ، سَقَیْتنَا نَبِیذًا ، قَالَ : لاَ ، وَلَکِنَّہُ نَبِیذُ جَرٍّ ، أَوْ جِرَارٍ ، ثُمَّ انْطَلَقَ إِلَی مَعْقِلِ بْنِ یَسَارٍ ، قَالَ : فَقَالَ : فِیمَا یُنْبَذُ لَکَ ؟ فَدَعَا الْجَارِیَۃَ ، فَجَائَ تْ بِجَرٍّ أَخْضَرَ ، فَقَالَ : یُنْبَذُ لِی فِی ہَذَا۔",,,24380 24381,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنْ ثَعْلَبَۃَ ، قَالَ : دَخَلْتُ عَلَی أَنَسِ بْنِ مَالِکٍ ، فَأَکَلْنَا عِنْدَہُ ، ثُمَّ دَعَا بِجُرَیرَۃٍ خَضْرَائَ فِیہَا نَبِیذٌ ، فَسَقَانَا۔",,,24381 24382,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن ہَمَّامٍ ، قَالَ : کَانَ یُنْبَذُ لِعَبْدِ اللہِ النَّبِیذُ فِی جِرَارٍ خُضْرٍ فَیَشْرَبُہُ ، وَکَانَ یُنْبَذُ لأُسَامَۃَ بْنِ زَیْدٍ فِی جَرٍّ أَخْضَرَ فَیَشْرَبُہُ۔",,,24382 24383,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنِ الْحَسَنِ بْنِ عَمْرٍو ، عَنْ شَقِیقٍ ، قَالَ : کَانَ ابْنُ مَسْعُودٍ یُنْبَذُ لَہُ فِی الْجَرِّ الأَخْضَرِ ، وَکَانَ شَقِیقٌ یَشْرَب النَبِیذَ فِی الْجَرِّ الأَخْضَر۔",,,24383 24384,حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَبْدِ اللہِ ، وَأَبِی مَسْعُودٍ ، وَأُسَامَۃَ ؛أَنَّہُمْ کَانُوا یَشْرَبُونَ نَبِیذَ الْجَرِّ۔,,,24384 24385,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، قَالَ : رَأَیْتُ عَبْدَ الرَّحْمَن بْنَ أَبِی لَیْلَی یَشْرَبُ نَبِیذَ الْجَرِّ الأَخْضَرِ ، بَعْدَ مَا یَسْکُنُ غَلَیَانُہُ۔",,,24385 24386,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ، عَنْ أَبِی فَرْوَۃَ، قَالَ: سَقَانِی عَبْدُ الرَّحْمَنِ بْنُ أَبِی لَیْلَی فِی جَرٍّ أَخْضَرَ، وَفِیہِ دُرْدِیٌّ ، وَسَقَیْتُہُ مِنْہُ۔",,,24386 24387,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ أَبِی فَرْوَۃَ الْجُہَنِیِّ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنْ عَبْدِ اللہِ ، قَالَ : کَانَ یَشْرَبُ نَبِیذَ الْجَرِّ الأَخْضَرِ۔",,,24387 24388,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : کَانَ عَمْرُو بْنُ شُرَحْبِیلَ یَنْبِذُ فِی الدَّنِّ ، وَیَنْبِذُ فِی الْجَرِّ الأَخْضَرِ۔",,,24388 24389,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : کَانَ ابْنُ الْحَنَفِیَّۃِ یَشْرَبُ نَبِیذَ الْجَرِّ الأَخْضَرِ۔",,,24389 24390,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ حُمْرَانَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : حدَّثَتْنِی أُمُّ حَفْصٍ ، قَالَتْ : کُنْتُ أَنْبِذُ لِعِمْرَانَ بْنِ حُصَیْنٍ فِی جَرٍّ۔ (ابن سعد 290)",,,24390 24391,حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ إِبْرَاہِیمَ بْنِ مُحَمَّدِ بْنِ الْمُنْتَشِرِ ، عَنْ أَبِیہِ ، عَنْ مَسْرُوقٍ ؛ أَنَّہُ کَانَ یَشْرَبُ نَبِیذَ الْجَرِّ۔,,,24391 24392,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، قَالَ : دَخَلْتُ عَلَی إِبْرَاہِیمَ ، وَالشَّعْبِیِّ ، وَہِلاَلِ بْنِ یَسَاف ، وَشَقِیقٍ ، وَسَعِیدِ بْنِ جُبَیْرٍ وَہُمْ فِی بُیُوتِہِمْ ، فَرَأَیْتہمْ یَشْرَبُونَ نَبِیذَ الْجَرِّ الأَخْضَرِ۔",,,24392 24393,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، عَنْ إِبْرَاہِیمَ ، عَنِ الأَسْوَدِ ؛ أَنَّہُ دَعَاہُمْ فِی عُرْسِہِ ، فَسَقَاہُمْ نَبِیذَ جَرٍّ أَخْضَرَ ، قَالَ : وَکَانَ إِبْرَاہِیمُ یَدْعُوہُمْ فِی عُرْسِہِ فَیَسْقِیہِمْ فِی جَرٍّ أَخْضَرَ۔",,,24393 24394,حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مَالِکِ بْنِ دِینَارٍ ، عَنْ أَبِی رَافِعٍ ؛ أَنَّہُ کَانَ یَشْرَبُ نَبِیذَ الْجَرِّ۔,,,24394 24395,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ مَنْصُورٍ ، قَالَ : قُلْتُ لإِبْرَاہِیمَ : إِنَّا نَنْبِذُ فِی الْجَرِّ الأَخْضَرِ ، ثُمَّ نُضِیفُہُ فِی الدَّوْرَقِ الْمُقَیَّرِ ، أَوْ فِی الإِنَائِ الْمُقَیَّرِ ؟ قَالَ : لاَ بَأْسَ بِہِ۔",,,24395 24396,"حَدَّثَنَا وَکِیعٌ ، عَنْ حُمْرَانَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ حَدَّثَتْنِی أُمُّ حَفْصٍ سُرِّیَّۃُ عِمْرَانَ بْنِ حُصَیْنٍ ، قَالَتْ : کُنْت أَنْتَبِذُ لِعِمْرَانَ بْنِ حُصَیْنٍ فِی الْجَرِّ الأَخْضَرِ فَیَشْرَبُہُ۔",,,24396 24397,حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ مَالِکٍ ، عَنِ الضَّحَّاکِ ؛ أَنَّہُ کَانَ یَشْرَبُ نَبِیذَ السَّوِیقِ۔,,,24397 24398,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَنْ أَبِی عَوَانَۃَ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ أَخِیہِ عِیسَی ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی، قَالَ: کُنْتُ أَشْرَبُ النَّبِیذَ فِی الْجِرَارِ الْخُضْرِ، مَعَ الْبَدْرِیَّۃِ مِنْ أَصحَاب مُحَمَّدٍ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,24398 24399,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ غَیْلاَنَ ، عَنْ عَبْدِ اللہِ بْنِ یَزِیدَ ، قَالَ : رَأَیْتُ أَبَا عُبَیْدَۃَ بْنَ عَبْدِ اللہِ بْنِ مَسْعُودٍ یَشْرَبُ النَّبِیذَ فِی جَرٍّ أَخْضَرَ ، وَقَالَ : إِنَّ مُحَرِّمَ مَا أَحَلَّ اللَّہُ ، کَمُسْتَحِلِّ مَا حَرَّمَ اللَّہُ۔",,,24399 24400,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنِ الْحَسَنِ بْنِ عَمْرٍو ، قَالَ : شَرِبْتُہُ عِنْدَ إِبْرَاہِیمَ نَبِیذًا فِی جَرٍّ أَخْضَرَ۔",,,24400 24401,حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ أَبِی الْمُغِیرَۃِ ، عَنْ أَبِیہِ ؛ أَنَّ أَبَا بَرْزَۃَ کَانَ یُنْبَذُ لَہُ فِی جَرٍّ أَخْضَرَ۔,,,24401 24402,حَدَّثَنَا عَبْدُ الصَّمَدِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی رَافِعٍ ؛ أَنَّ أَبَاہُ کَانَ یُنْبَذُ لَہُ فِی جَرٍّ، فَکَانَ یَشْرَبُہُ حُلْوًا بِالسَّوِیقِ۔,,,24402 24403,"حَدَّثَنَا خَلَفُ بْنُ خَلِیفَۃَ ، عَنِ الْعَلاَئِ بْنِ الْمُسَیَّبِ ، عَنْ حَکِیمِ بْنِ جُبَیْرٍ ، عَنْ إِبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عَنْ عَائِشَۃَ ، قَالَتْ : کَانَ یُنْبَذُ لِرَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی جَرٍّ أَخْضَرَ۔ (طبرانی 7428)",,,24403 24404,"حَدَّثَنَا وَکِیعٌ ، عَنِ الضَّحَّاکِ بْنِ یَسَارٍ ، عَنْ یَزِیدَ بْنِ عَبْدِ اللہِ بْنِ الشِّخِّیرِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ صُحَارٍ، عَنْ أَبِیہِ ، قَالَ : قُلْتُ : یَا رَسُولَ اللہِ ، إِنِّی رَجُلٌ مِسْقَامٌ ، فَأْذَنْ لِی فِی جَرَّۃٍ أَنْتَبِذُ فِیہَا ، فَأَذِنَ لِی۔ \n\n(احمد 31۔ بزار 2910)",,,24404 24405,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حَدَّثَنَا مِسْعَرٌ ، عَنْ سَہْلٍ أَبِی الأَسْدِ ، عَنْ مُسْرَدٍ ، قَالَ : کَانَ نَبِیذُ سَعْدٍ فِی جَرَّۃٍ خَضْرَائَ ، قَالَ : وَقَالَ : لاَ تَقُلْ اسْقِنِی مُحَطَّمًا۔",,,24405 24406,"حَدَّثَنَا أَبُو الأَحْوَصِ، عَنْ سِمَاکِ بْنِ حَرْبٍ ، عَنِ الْقَاسِمِ بْنِ عَبْدِ الرَّحْمَنِ ، قَالَ: حدَّثَتْنِی أُمُّ أَبِی عُبَیْدَۃَ، أَوْ أُمُّ عُبَیْدَۃَ أَنَّہُمْ کَانُوا یَنْبِذُونَ فِی الْجَرِّ الأَخْضَرِ، فَیَرَاہُمْ عَبْدُ اللہِ وَلاَ یَنْہَی عَنْ ذَلِکَ۔(عبدالرزاق 16953)",,,24406 24407,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ حُمَیْدٍ الطَّوِیلِ ، عَنْ عُقْبَۃَ بْنِ مَیْسَرَۃَ ، قَالَ : کُنَّا عِنْدَ مَعْقِلِ بْنِ یَسَارٍ فَدَعَا بِطَعَامٍ فَأَکَلْنَا ، ثُمَّ أُتِینَا بِقَدَحٍ مِنْ نَبِیذٍ فَشَرِبَ وَشَرِبْنَا ، حَتَّی انْتَہَی إِلَی ابْنٍ لَہُ ، فَأَبَی أَنْ یَشْرَبَ ، فَأَخَذَ مَعْقِلٌ عَصًی کَانَتْ عِنْدَہُ ، فَضَرَبَ بِہَا رَأْسَہُ فَشَجَّہُ ، ثُمَّ قَالَ لَہُ : أَتَفْعَلُ کَذَا وَکَذَا ، وَذَکَرَ مِنْ مَسَاوِئِہِ وَتَأْبَی أَنْ تَشْرَبَ مِنْ شَرَابٍ شَرِبَہُ أَبُوکَ وَعُمُومَتُکَ ، لأَنَّہُ نَبِیذُ جَرٍّ ؟۔",,,24407 24408,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مِسْحَاجِ بْنِ مُوسَی ، قَالَ : کُنْتُ نَازِلاً فِی دَارِ أَنَسٍ ، فَرَأَیْتُہُ یَشْرَبُ النَّبِیذَ فِی جَرٍّ أَخْضَرَ۔",,,24408 24409,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ زَیْدٍ ، قَالَ : حدَّثَنِی عَاصِمُ بْنُ بَہْدَلَۃَ ، قَالَ : أَدْرَکْتُ رِجَالاً کَانُوا یَتَّخِذُونَ ہَذَا اللَّیْلَ جَمَلاً ، یَشْرَبُونَ نَبِیذَ الْجَرِّ ، وَیَلْبَسُونَ الْمُعَصْفَرَ ، مِنْہُمْ زِرٌّ ، وَأَبُو وَائِلٍ۔",,,24409 24410,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، أَنَّہُ کَانَ یَشْرَبُ النَّبِیذَ لِثَلاَثٍ۔,,,24410 24411,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ سِمَاکٍ ، عَنِ الْقَاسِمِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِیہِ ، عَنْ أَبِی بُرْدَۃَ ، یَعْنِی ابْنَ نِیَارٍ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : اشْرَبُوا فِی الظُّرُوفِ ، وَلاَ تَسْکَرُوا۔\n\n(نسائی 5187۔ طبرانی 22)",,,24411 24412,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ یَحْیَی بْنِ الْحَارِثِ التَّیْمِیِّ ، عَنْ عَمْرِو بْنِ عَامِرٍ ، عَنْ أَنَسٍ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ النَّبِیذِ فِی ہَذِہِ الظُّرُوفِ ، ثُمَّ قَالَ : نَہَیْتُکُمْ عَنِ النَّبِیذِ ، فَاشْرَبُوا فِیمَا شِئْتُمْ ، مَنْ شَائَ أَوْکَی سِقَائَ ہُ عَلَی إِثْمٍ۔",,,24412 24413,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَبِی سِنَانٍ ، عَنْ مُحَارِبٍ ، عَنِ ابْنِ بُرَیْدَۃَ ، عَنْ أَبِیہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : نَہَیْتُکُمْ عَنِ النَّبِیذِ إِلاَّ فِی سِقَائٍ ، فَاشْرَبُوا فِی الأَسْقِیَۃِ کُلِّہَا ، وَلاَ تَشْرَبُوا مُسْکِرًا۔",,,24413 24414,"حَدَّثَنَا أَبُو الأَحْوَصِ، عَنْ یَحْیَی بْنِ الْحَارِثِ، عَنْ عَمْرِو بْنِ عَامِرٍ، عَنْ أَنَسٍ، قَالَ: نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الأَنْبِذَۃِ فِی الأَوْعِیَۃِ ، ثُمَّ قَالَ بَعْدُ : إِنِّی نَہَیْتُکُمْ عَنِ الأَنْبِذَۃِ فِی الأَوْعِیَۃِ ، فَاشْرَبُوا فِیمَا شِئْتُمْ ، مَنْ شَائَ أَوْکَأَ سِقَائَ ہُ عَلَی إِثْمٍ۔",,,24414 24415,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ سُلَیْمَانَ ، عَنْ مُجَاہِدٍ ، عَنْ أَبِی عِیَاضٍ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ، قَالَ : قِیلَ لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَیْسَ کُلُّ النَّاسِ یَجِدُ وِعَائً ، فَأَذِنَ لَہُمْ فِی شَیْئٍ مِنْہُ ، یَعْنِی الظُّرُوفَ۔ (بخاری 5593۔ مسلم 66)",,,24415 24416,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عَلِیِّ بْنِ زَیْدٍ ، عَنْ رَبِیعَۃَ بْنِ النَّابِغَۃِ ، عَنْ أَبِیہِ ، عَنْ عَلِیٍّ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : کُنْتُ نَہَیْتُکُمْ عَنْ ہَذِہِ الأَوْعِیَۃِ ، فَاشْرَبُوا فِیہَا ، وَاجْتَنِبُوا کُلَّ مَا أَسْکَرَ۔",,,24416 24417,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ یَحْیَی بْنِ الْحَارِثِ التَّیْمِیِّ ، عَنْ یَحْیَی بْنِ غَسَّانَ التَّیْمِیِّ ، عَنِ ابْنِ الرَّسِیمِ ، وَکَانَ رَجُلاً مِنْ أَہْلِ ہَجَرَ ، وَکَانَ فَقِیہًا حَدَّثَ ، عَنْ أَبِیہِ ؛ أَنَّہُ انْطَلَقَ إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی وَفْدٍ فِی صَدَقَۃٍ یَحْمِلُہَا إِلَیْہِ ، قَالَ : فَنَہَاہُمْ عَنِ النَّبِیذِ فِی ہَذِہِ الظُّرُوفِ ، فَرَجَعُوا إِلَی أَرْضِہِمْ ، وَہِیَ أَرْضُ تِہَامَۃَ حَارَّۃً ، فَاسْتَوْخَمُوہَا ، فَرَجَعُوا إِلَیْہِ الْعَامَ الثَّانِیَ فِی صَدَقَاتِہِمْ ، فَقَالُوا : یَا رَسُولَ اللہِ ، إِنَّک نَہَیْتَنَا عَنْ ہَذِہِ الأَوْعِیَۃِ فَتَرَکْنَاہَا ، وَشَقَّ ذَلِکَ عَلَیْنَا ، فَقَالَ : اذْہَبُوا فَاشْرَبُوا فِیمَا شِئْتُمْ، مَنْ شَائَ أَوْکَی سِقَائَ ہُ عَلَی إِثْمَ۔ (احمد 3/481۔ طبرانی 4634)",,,24417 24418,"حَدَّثَنَا عُمَرُ بْنُ سَعْدٍ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ سَالِمٍ ، عَنْ جَابِرٍ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الظُّرُوفِ ، فَشَکَتْ إِلَیْہِ الأَنْصَارُ ، فَقَالُوا : لَیْسَ لَنَا أَوْعِیَۃٌ ، فَقَالَ : فَلاَ إِذَنْ۔\n\n(بخاری 5592۔ ترمذی 1870)",,,24418 24419,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَمَّادٍ ، قَالَ : حدَّثَنَا فَرْقَدٌ السَّبَخِیُّ ، قَالَ : حَدَّثَنَا جَابِرُ بْنُ یَزِیدَ ، قَالَ: حَدَّثَنَا مَسْرُوقٌ، عَنْ عَبْدِ اللہِ ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنِّی نَہَیْتُکُمْ عَنْ ہَذِہِ الأَوْعِیَۃِ، وَإِنَّ الأَوْعِیَۃَ لاَ تُحِلُّ شَیْئًا ، وَلاَ تُحَرِّمُہُ ، فَاشْرَبُوا فِیہَا۔",,,24419 24420,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ طَارِقِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : کُلُّ حَلاَلٍ فِی کُلِّ ظَرْفٍ حَلاَلٌ ، وَکُلُّ حَرَامٍ فِی کُلِّ ظَرْفٍ حَرَامٌ۔",,,24420 24421,"حَدَّثَنَا وَکِیعٌ ، عَنْ سَعِیدِ بْنِ سَعِیدٍ الْبَجَلِیِّ ، عَنْ أَبِی الشَّعْثَائِ الْکِنْدِیِّ ، عَنِ ابْنِ عُمَرَ ، قَالَ : سَمِعْتُہُ یَقُولُ : الأَوْعِیَۃُ لاَ تُحِلُّ شَیْئًا ، وَلاَ تُحَرِّمُہُ۔",,,24421 24422,"حَدَّثَنَا عَبْدَۃُ، عَنْ صَالِحٍ، عَنِ الشَّعْبِیِّ ، قَالَ: نَبِیذُ الْمِزْرِ أَشَدُّ مِنْ نَبِیذِ الدَّنِّ ، وَمَا حَرَّمَ إِنَائٌ ، وَلاَ أَحَلَّ۔",,,24422 24423,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا إِسْمَاعِیلُ بْنُ أَبِی خَالِدٍ ، عَنِ الزُّبَیْرِ بْنِ عَدِیِّ ، قَالَ : ذُکِرَ عِنْدَ شُرَیْحٍ الأَسْقِیَۃُ الَّتِی تُنْبَذُ فِیہَا ، فَقَالَ شُرَیْحٌ : مَا یُحْلِلْنَ شَیْئًا ، وَلاَ یُحَرِّمْنَ ، وَلَکِنَ اُنْظُرُوا مَا تَجْعَلُونَ فِیہِ مِنْ حَلاَلٍ ، أَوْ حَرَامٍ۔",,,24423 24424,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنْ رَجُلٍ مِنْ بَنِی بَجِیلَۃَ ، عنِ ابْنِ عَبَّاسٍ ، قَالَ : کُلُّ حَلاَلٍ فِی کُلِّ ظَرْفٍ حَلاَلٌ ، وَکُلُّ حَرَامٍ فِی کُلِّ ظَرْفٍ حَرَامٌ۔",,,24424 24425,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ إِسْمَاعِیلَ بْنِ سُمَیْعٍ ، عَنْ مُسْلِمٍ الْبَطِینِ ، قَالَ : سَأَلْتُ أَبَا عَمْرٍو الشَّیْبَانِیَّ عَنِ الْجِعَۃِ ؟ قَالَ : شَرَابٌ یُصْنَعُ بِالْیَمَنِ مِنَ الشَّعِیرِ۔",,,24425 24426,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ مُحَمَّدِ بْنِ أَبِی إِسْمَاعِیلَ ، عَنْ عُمَارَۃَ بْنِ عَاصِمٍ ، عَنْ أَنَسٍ ، قَالَ : الْحَنْتَمُ جِرَارٌ حُمْرٌ ، کَانَتْ تَأْتِینَا مِنْ مِصْرَ۔",,,24426 24427,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، وَوَکِیعٌ ، عَنِ الصَّلْتِ بْنِ بَہْرَامَ ، قَالَ : سَأَلْتُ إبْرَاہِیمَ عَنِ الْحَنْتَمِ ؟ قَالَ : کَانَتْ جِرَارًا حُمْرًا مُقَیَّرَۃً ، یُؤْتَی بِہَا مِنَ الشَّامِ ، یُقَالُ لَہَا : الْحَنْتَمُ۔",,,24427 24428,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی الْحَارِثِ التَّیْمِیِّ ، عَنْ أُمِّ مَعْبَدٍ ، قَالَ : قُلْتُ : مَا قَالَ فِی ہَذِہِ الأَوْعِیَۃِ ؟ فَقَالَتْ : عَلَی الْخَبِیرِ سَقَطْتَ ، أَمَّا الْحَنَاتِمُ فَحَنَاتِمُ الْعَجَمِ ، الَّتِی یَدْخُلُ فِیہَا الرَّجُلُ فَیَکْنِسُہَا کَنْسًا : ظُرُوفُ الْخَمْرِ ، وَأَمَّا الدُّبَّائُ فَالْقَرْعُ ، وَأَمَّا الْمُزَفَّتُ فَالزِّقَاقُ الْمُقَیَّرَۃُ أَجْوَافُہَا ، الْمُلَوَّنَۃُ أَشْعَارُہَا بِالْقَارِ : ظُرُوفُ الْخَمْرِ ، وَأَمَّا النَّقِیرُ فَالنَّخْلَۃُ الثَّابِتَۃُ عُرُوقُہَا فِی الأَرْضِ ، الْمَنْقُورَۃُ نَقْرًا۔",,,24428 24429,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ مُسْلِمٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، قَالَ : إِنَّمَا کَانَتِ الْحَنَاتِمُ جِرَارًا حُمْرًا مُزَفَّتَۃً ، یُؤْتَی بِہَا مِنْ مِصْرَ ، وَلَیْسَتْ بِالْجِرَارِ الْخُضْرِ۔",,,24429 24430,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، قَالَ : الْحَنْتَمُ جِرَارٌ خُضْرٌ کَانَ یُجَائُ بِہَا مِنْ مِصْرَ ، فِیہَا الْخَمْرُ۔",,,24430 24431,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی بِشْرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : الْحَنْتَمُ الْجِرَارُ کُلُّہَا۔",,,24431 24432,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ أَبِی إِسْحَاقَ الشَّیْبَانِیِّ ، قَالَ : قُلْتُ لأَبِی بُرْدَۃَ : مَا الْبِتْعُ ؟ قَالَ : نَبِیذُ الْعَسَلِ، وَالْمِزْرُ نَبِیذُ الشَّعِیرِ۔",,,24432 24433,"حَدَّثَنَا مُحَمَّدُ بْنُ یَزِیدَ ، عَنْ سُفْیَانَ بْنِ حُسَیْنٍ ، عَنِ الْحَسَنِ ، وَابْنِ سِیرِینَ ، قَالَ : سَأَلْتُُہُمَا عَنِ النَّبِیذِ فِی الرَّصَاصِ ؟ فَکَرِہَاہُ۔",,,24433 24434,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ الْمُخْتَارِ ، قَالَ : سَأَلْتُ أَنَسًا ، فَقُلْتُ : الْقَارُورَۃِ وَالرَّصَاصِ ؟ فَقَالَ : لاَ بَأْسَ بِہِمَا ، فَقُلْتُ : إِنَّ النَّاسَ یَقُولُونَ ؟ قَالَ : فَدَعْ مَا یَرِیبُکَ إِلَی مَا لاَ یَرِیبُکَ۔",,,24434 24435,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی سَلَمَۃَ ، قَالَ : جِئْتُ وَہُمْ یَذْکُرُونَ نَبِیذَ الْجَرِّ عِنْدَ عِکْرِمَۃَ ، فَسَأَلَہُ إِنْسَانٌ عَنِ الرَّصَاصِ ؟ فَقَالَ : ذَلِکَ أَخْبَثُ ، أَوْ أَشَرُّ۔",,,24435 24436,حَدَّثَنَا وَکِیعٌ ، عَنْ أَبَانَ بْنِ صَمْعَۃَ ، عَنِ الْحَسَنِ ، أَنَّہُ کَرِہَہُ فِی الرَّصَاصِ۔,,,24436 24437,"حَدَّثَنَا مُحَمَّدُ بْنُ یَزِیدَ ، عَنْ أَبِی الأَشْہَبِ جَعْفَرِ بْنِ الْحَارِثِ النَّخَعِیِّ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، قَالَ : سَأَلْتُ ابْنَ عَبَّاسٍ عَنْ نَبِیذِ الرَّصَاصِ ؟ فَرَخَّصَ لِی فِی ذَلِکَ ، فَکَانَ لِجَدِّی جَرَّۃٌ مِنْ رَصَاصٍ یُنْبَذُ فِیہَا۔",,,24437 24438,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ الْعَلاَئِ بْنِ الْمُسَیَّبِ ، قَالَ : رَأَیْتُ إِبرَہِیمَ ، وَخَیْثَمَۃَ ،وَالْمُسَیَّبَ بْنَ رَافِعٍ مَعَہُم نَبِیذٌ فِی رَصَاصٍ یَشْرَبُونَہُ۔",,,24438 24439,"حَدَّثَنَا إِسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ الْحَذَّائِ ، قَالَ : کَانَ أَبُو قِلاَبَۃَ یُنْبَذُ لَہُ فِی سِقَائٍ ، ثُمَّ یُحَوِّلُہُ فِی بَاطیَّۃٍ مِنْ رَصَاصٍ۔",,,24439 24440,"حَدَّثَنَا الْفَضْلُ ، عَنْ أَبِی خَلْدَۃَ ، قَالَ : حدَّثَنِی غَیْلاَنُ بْنُ عُمَیْرَۃَ ، قَالَ : لَقِیتُ ابْنَ عُمَرَ ، فَسَأَلْتُہُ عَنِ الأَشْرِبَۃِ ؟ فَرَخَّصَ لِی فِی الرَّصَاصِ۔",,,24440 24441,حَدَّثَنَا أَبُو خَالِدٍ ، وَلَیْسَ بِالأَحْمَرِ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ؛ أَنَّہُ کَانَ یُنْبَذُ لَہُ فِی جَرَّۃٍ مِنْ رَصَاصٍ۔,,,24441 24442,حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ حُمَیْدٍ ، عَنْ بَکْرٍ ؛ أَنَّہُ کَانَ یُنْبَذُ لَہُ فِی الْقَوَارِیرِ۔,,,24442 24443,حَدَّثَنَا وَکِیعٌ ، عَنْ أَبَانَ بْنِ صَمْعَۃَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ رَخَّصَ فِی الزُّجَاجِ ، یَعْنِی النَّبِیذَ۔,,,24443 24444,"حَدَّثَنَا وَکِیعٌ ، عَنْ مَعْرُوفِ بْنِ وَاصِلٍ ، قَالَ حَدَّثَتْنِی وَالِدَتِی ، عَنِ امْرَأَۃٍ ، یُقَالُ لَہَا : بِنْتُ الأَقْعَصِ ، وَکَانَتْ کَنَّۃً لِعَبْدِ اللہِ بْنِ عُمَرَ ، أَنَّہَا أَتَتِ ابْنَ عُمَرَ بِجَرَّۃٍ خَضْرَائَ ، فَقَالَ : مَا ہَذَا ؟ قَالَتْ : نَنْبِذُ فِی ہَذِہِ ، فَأَدْخَلَ ابْنُ عُمَرَ یَدَہُ فِی جَوْفِہَا ، فَقَالَ : عَزَمْتُ عَلَیْکِ لَتَشْرَبِنَّ فِیہَا ، فَإِنَّمَا ہِیَ مِثْلُ الْقَارُورَۃِ۔",,,24444 24445,"حدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنِ الْحَکَمِ بْنِ عَطِیَّۃَ ، قَالَ : رَأَیْتُ مُحَمَّدًا یَشْرَبُ فِی الْقَوَارِیرِ۔",,,24445 24446,حَدَّثَنَا وَکِیعٌ ، عَنِ الْحَسَنِ بْنِ حَکِیمٍ ، عَنْ أُمِّہ ، عَنْ أَبِی بَرْزَۃَ ؛ أَنَّہُ کَرِہَ الشُّرْبَ فِی الزُّجَاجِ۔,,,24446 24447,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنِ الْمُخْتَارِ بْنِ فُلْفُلٍ ، قَالَ : سَأَلْتُ أَنَسًا فَقُلْتُ : الْقَارُورَۃُ وَالرَّصَاصَۃُ ؟ قَالَ : لاَ بَأْسَ بِہِمَا ، قُلْتُ : فَإِنَّ النَّاسَ یَقُولُونَ ؟ قَالَ : دَعْ مَا یَرِیبُکَ إِلَی مَا لاَ یَرِیبُک۔",,,24447 24448,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَبِیبِ بْنِ أَبِی عَمْرَۃَ ، قَالَ : جِئْتُ إِلَی سَعِیدِ بْنِ جُبَیْرٍ بِجَرَّۃٍ خَضْرَائَ ، فَأَدْخَلَ یَدَہُ فِیہَا فَقُلْتُ : أَنَنْبِذُ فِی ہَذِہِ ؟ قَالَ : نَعَمْ ، ہِیَ بِمَنْزِلَۃِ الْقَارُورَۃِ۔",,,24448 24449,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الْحَسَنِ بْنِ عَمْرٍو ، قَالَ : شَرِبْتُ عِنْدَ إِبْرَاہِیمَ ثَلاَثَ قَوَارِیرَ مِنْ نَبِیذٍ۔",,,24449 24450,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنِ النَّضْرِ بْنِ مُطَرِّفِ ، عَنِ الْقَاسِمِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِیہِ ، قَالَ : کَانَ عَبْدُ اللہِ یُنْبَذُ لَہُ فِی جَرٍّ ، وَیُجْعَلُ لَہُ فِیہِ عَکَرٌ۔",,,24450 24451,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ خَالِدِ بْنِ الْمَعْدِلِ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ عُمَرَ أُتِیَ بِنَبِیذٍ مِنْ نَبِیذِ الشَّامِ ، فَشَرِبَ مِنْہُ وَقَالَ : أَقْلَلْتُمْ عَکَرَہُ۔",,,24451 24452,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ أَبِی فَرْوَۃَ ، قَالَ : سَقَانِی عَبْدُ الرَّحْمَنِ بْنُ أَبِی لَیْلَی نَبِیذَ جَرٍّ وَفِیہِ دُرْدِیٌّ ، وَسَقَیْتُہُ مِنْہُ۔",,,24452 24453,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الْحَسَنِ بْنِ عَمْرٍو ، عَنْ أَبِی وَائِلٍ ، قَالَ : کَانَ یَسْقِینَا نَبِیذًا یُؤْذِینَا رِیحُ دُرْدِیِّہِ۔",,,24453 24454,"حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، قَالَ : سَأَلْتُ أَبَا جَعْفَرٍ ، عَنِ الرَّوْبَۃِ ، قَالَ : وَمَا الرَّوْبَۃُ ؟ قُلْتُ : الدُّرْدِیَّ ، قَالَ : لاَ بَأْسَ بِہِ۔",,,24454 24455,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَانَ یَنْبِذُ الطِّلاَئَ یَجْعَلُ فِیہِ الدُّرْدِیَّ۔,,,24455 24456,حَدَّثَنَا وَکِیعٌ ، عَنِ الْحَسَنِ بْنِ صَالِحٍ ، عَنِ الْحَسَنِ بْنِ عَمْرٍو ، عَنْ إبْرَاہِیمَ ، وَالشَّعْبِیِّ ؛ أَنَّہُمَا کَانَا یَجْعَلاَنِ فِی نَبِیذِہِمَا الدُّرْدِیَّ۔,,,24456 24457,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَمُحَمَّدٍ ، أَنَّہُمَا کَانَا یَکْرَہَانِ الْعَکَرَ۔,,,24457 24458,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ دَاوُدَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّہُ کَانَ یَکْرَہُ الْعَکَرَ۔,,,24458 24459,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ دَاوُدَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ : أَنَّہُ کَرِہَ الْعَکَرَ وَقَالَ : ہُوَ خَمْرٌ۔",,,24459 24460,حدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ، عَنْ سَعِیدِ بْنِ أَبِی عَرُوبَۃَ، عَنْ قَتَادَۃَ، عَنْ أَنَسٍ؛ أَنَّ أَبَا عُبَیْدَۃَ، وَمُعَاذَ بْنَ جَبَلٍ، وَأَبَا طَلْحَۃَ کَانُوا یَشْرَبُونَ مِنَ الطِّلاَئِ مَا ذَہَبَ ثُلُثَاہُ وَبَقِیَ ثُلُثُہُ۔,,,24460 24461,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ دَاوُدَ بْنِ أَبِی ہِنْدٍ ، قَالَ : سَأَلْتُ سَعِیدَ بْنَ الْمُسَیَّبِ عَنِ الشَّرَابِ الَّذِی کَانَ عُمَرُ بْنُ الْخَطَّابِ أَجَازَہُ لِلنَّاسِ ؟ قَالَ : ہُوَ الطِّلاَئُ الَّذِی قَدْ طُبِخَ حَتَّی ذَہَبَ ثُلُثَاہُ وَبَقِیَ ثُلُثُہُ۔",,,24461 24462,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ مَیْمُونٍ ، عَنْ أُمِّ الدَّرْدَائِ ، قَالَتْ : کُنْتُ أَطْبُخُ لأَبِی الدَّرْدَائِ الطِّلاَئَ مَا ذَہَبَ ثُلُثَاہُ وَبَقِیَ ثُلُثُہُ فَیَشْرَبُہُ۔",,,24462 24463,حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ حَجَّاجٍ ، عَنْ مَیْمُونٍ ، عَنْ أُمِّ الدَّرْدَائِ ، عَنْ أَبِی الدَّرْدَائِ ؛ أَنَّہُ کَانَ یَشْرَبُ مِنَ الطِّلاَئِ مَا ذَہَبَ ثُلُثَاہُ وَبَقِیَ ثُلُثُہُ۔,,,24463 24464,"حَدَّثَنَا وَکِیعُ بْنُ الْجَرَّاحِ ، عَنْ أَبَانَ بْنِ عَبْدِ اللہِ الْبَجَلِیِّ ، عَنْ رَجُلٍ قَدْ سَمَّاہُ ، قَالَ : کَانَ عَلِیٌّ یَرْزُقُ النَّاسَ مِنَ الطِّلاَئِ مَا ذَہَبَ ثُلُثَاہُ وَبَقِیَ ثُلُثُہُ۔",,,24464 24465,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنِ الْحَسَنِ بْنِ عَمْرٍو ، عَنْ فُضَیْلِ بْنِ عَمْرٍو ، قَالَ : قُلْتُ لإِبْرَاہِیمَ : مَا تَرَی فِی الطِّلاَئِ ؟ قَالَ : مَا ذَہَبَ ثُلُثَاہُ وَبَقِیَ ثُلُثُہُ ، وَمَا أَرَی بِالْمنصَّفِ بَأْسًا۔",,,24465 24466,"حَدَّثَنَا وَکِیعٌ ، عَنْ بَشِیرِ بْنِ الْمُہَاجِرِ ، عَنِ الْحَسَنِ ، قَالَ : اشْرَبْ مَا ذَہَبَ ثُلُثَاہُ وَبَقِیَ ثُلُثُہُ۔",,,24466 24467,"حَدَّثَنَا وَکِیعٌ ، عَنْ سَعْدِ بْنِ أَوْسٍ ، عَنْ أَنَسِ بْنِ سِیرِینَ ، قَالَ : کَانَ أَنَسُ بْنُ مَالِکٍ سَقِیمَ الْبَطْنِ ، فَأَمَرَنِی أَنْ أَطْبُخَ لَہُ طِلاَئً حَتَّی ذَہَبَ ثُلُثَاہُ وَبَقِیَ ثُلُثُہُ ، فَکَانَ یَشْرَبُ مِنْہُ الشَّرْبَۃَ عَلَی إِثْرِ الطَّعَامِ۔",,,24467 24468,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ حَکِیمِ بْنِ جُبَیْرٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : اشْرَبْ مِنَ الطِّلاَئِ مَا ذَہَبَ ثُلُثَاہُ وَبَقِیَ ثُلُثُہُ۔",,,24468 24469,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ یَعْلَی بْنِ عَطَائٍ ، قَالَ : سَمِعْتُ أَعْرَابِیًّا سَأَلَ سَعِیدَ بْنَ الْمُسَیَّبِ عَنِ الطِّلاَئِ عَلَی النِّصْفِ ؟ فَکَرِہَہُ ، وَقَالَ : عَلَیْک بِاللَّبَنِ۔",,,24469 24470,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ یَزِیدَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، وَأَبِی جُحَیْفَۃَ ، قَالاَ : کَانَ عَلِیٌّ یَرْزُقُنَا الطِّلاَئَ ، قَالَ : قُلْتُ : کَیْفَ کَانَ ؟ قَالَ : کُنَّا نَأْتَدِمُہُ بِالْخُبْزِ ، وَنَحْتَاسُہُ بِالْمَائِ ۔",,,24470 24471,"حَدَّثَنَا وَکِیعٌ ، عَنْ شَرِیکٍ ، عَنْ عَلِیِّ بْنِ سُلَیْمٍ ، قَالَ : سَمِعْتُ أنَسًا یَقُولُ : إِنِّی لأََشْرَبُ الطِّلاَئَ الْحُلْوَ الْقَارِصَ۔",,,24471 24472,"حَدَّثَنَا حَمَّاد بن خَالِدٍ ، عَنْ مُعَاوِیَۃَ بْنِ صَالِحٍ ، عَن سَالِمِ بْنِ سَالِمٍ قَال : دَخَلتُ عَلَی أَبِی أُمَامَۃَ وَہُوَ یَشْرَبُ طِلاَئَ الرَّبِّ۔",,,24472 24473,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْمَاعِیلَ بْنِ خَالِدٍ ، عَنْ عُثْمَانَ بْنِ قَیْسٍ ، قَالَ : خَرَجْتُ مَعَ جَرِیرٍ یَوْمَ الْجُمُعَۃِ إِلَی حَمَّامٍ لَہُ بِالْعَاقُولِ ، فَأُتِینَا بِطَعَامٍ فَأَکَلْنَا ، ثُمَّ أُتِینَا بِعَسَلٍ وَطِلاَئٍ ، فَقَالَ : جَرِیرٌ : اشْرَبُوا أَنْتُمُ الْعَسَلَ ، وَشَرِبَ ہُوَ الطِّلاَئَ وَقَالَ : إِنَّہُ یُسْتَنْکَرُ مِنْکُمْ ، وَلاَ یُسْتَنْکَرُ مِنِّی ، قُلْتُ : أَیُّ الطِّلاَئِ ہُوَ ؟ قَالَ : کُنْتُ أَجِدُ رِیحَہُ کَمَکَانِ تِلْکَ ، وَأَوْمَأَ بِیَدِہِ إِلَی أَقْصَی حَلَقَۃٍ فِی الْقَوْمِ۔",,,24473 24474,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا إِسْمَاعِیلُ بْنُ أَبِی خَالِدٍ ، عَنِ الْمُغِیرَۃِ بْنِ الْمُنْتَشِر ابْنِ أَخِی مَسْرُوقٍ ، قَالَ : قُلْتُ لَہُ : کَانَ مَسْرُوقٌ یَشْرَبُ الطِّلاَئَ ؟ قَالَ : نَعَمْ ، کَانَ یَطْبُخُہُ ثُمَّ یَشْرَبُہُ۔",,,24474 24475,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا إِسْمَاعِیلُ ، عَنْ أَبِی جَرِیرٍ ، عَنِ النَّضْرِ بْنِ أَنَسٍ ، قَالَ : غَزَا أَبُو عُبَیْدَۃَ بْنُ الْجَرَّاحِ فَأَتَی أَرْضَ الشَّامِ ، فَقِیلَ لأَبِی عُبَیْدَۃَ : إِنَّ ہَاہُنَا شَرَابًا تَشْرَبُہُ النَّصَارَی فِی صَوْمِہِمْ ، قَالَ : فَشَرِبَ مِنْہُ أَبُو عُبَیْدَۃَ۔",,,24475 24476,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا إِسْمَاعِیلُ ، عَنْ مُغِیرَۃَ ، عَنْ شُرَیْحٍ ؛ أَنَّ خَالِدَ بْنَ الْوَلِیدِ کَانَ یَشْرَبُ الطِّلاَئَ بِالشَّامِ۔",,,24476 24477,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنْ یَحْیَی بْنِ عُبَیْدٍ أَبِی عُمَرَ ، قَالَ : ذُکِرَ عِنْدَ ابْنِ عَبَّاسٍ الطِّلاَئُ ، وَذَکَرُوا طَبْخَہُ ، فَقَالَ ابْنُ عَبَّاسٍ : إِنَّ النَّارَ لاَ تُحِلُّ شَیْئًا ، وَلاَ تُحَرِّمُہُ لأَنَّ أَوَّلَہُ کَانَ حَلاَلاً۔",,,24477 24478,حَدَّثَنَا أَبُو خَالِدٍ ، عَنِ الأَعْمَشِ ، عَنِ الْحَکَمِ ، عَنْ شُرَیْحٍ ؛ أَنَّہُ کَانَ یَشْرَبُ الطِّلاَئَ الشَّدِیدَ۔,,,24478 24479,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ عَلِیِّ بْنِ بَذِیمَۃَ ، عَنْ أَبِی عُبَیْدَۃَ ؛ أَنَّہُ کَانَ یَشْرَبُ الطِّلاَئَ عِنْدَ مَرْوَانَ ، مَا یُحَمِّرُ وَجْنَتَیہِ۔,,,24479 24480,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَانَ یَشْتَرِی الطِّلاَئَ مِمَّنْ لاَ یَدْرِی مَنْ صَنَعَہُ ، ثُمَّ یَشْرَبُہُ۔,,,24480 24481,"حَدَّثَنَا شَرِیکٌ ، عَنِ السُّدِّیِّ ، عَنْ شَیْخٍ مِنَ الْحَضْرَمِیِّینَ ، قَالَ : قسَّمَ عَلِیٌّ طِلاَئً ، فَبَعَثَ إِلَیَّ بِقِدْرٍ ، فَکُنَّا نَأْکُلُہُ بِالْخُبْزِ کَمَا نَأْکُلُہُ بِالْکَامِخِ۔",,,24481 24482,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ ، عَن مُوسَی بْنِ عَبْدِ اللہِ بْنِ یَزِیدَ الأَنْصَارِیِّ ، قَالَ : کَانَتْ لِعَبْدِ الرَّحْمَنِ بْنِ بِشْرٍ الأَنْصَارِیِّ قَرْیَۃٌ یُصْنَعُ لَہُ بِہَا طَعَامٌ ، فَدَعَا نَاسًا مِنْ أَصْحَابِہِ فَأَکَلُوا ، ثُمَّ أُتُوا بِشَرَابٍ مِنَ الطِّلاَئِ ، وَفِیہِمْ أُنَاسٌ مِنْ أَہْلِ بَدْرٍ ، فَقَالُوا : مَا ہَذَا ؟ قَالُوا : شَرَابٌ یَصْنَعُہُ ابْنُ بِشْرٍ لِنَفْسِہِ ، فَقَالُوا : ہُوَ الرَّجُلُ لاَ یُرْغَبُ عَنْ شَرَابِہِ ، فَشَرِبُوا۔",,,24482 24483,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَطَائٍ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ، عَنْ عَلِیٍّ ، قَالَ : کَانَ یَرْزُقُنَا الطِّلاَئَ ، فَقُلْتُ لَہُ: مَا ہَیْئَتُہُ ؟ قَالَ : أَسْوَدُ ، یَأْخُذُہُ أَحَدُنَا بِإِصْبعِہِ۔",,,24483 24484,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا عَبْدُ اللہِ بْنُ الْوَلِیدِ الْمُزَنِیُّ ، قَالَ : حَدَّثَنِی عَبْدُ الْمَلِکِ بْنُ عُمَیْرٍ، عَنْ أَبِی الْہَیَّاجِ ؛ أَنَّ الْحَجَّاجَ دَعَاہُ فَقَالَ : أَرِنِی کِتَابَ عُمَرَ إِلَی عَمَّارٍ فِی شَأْنِ الطِّلاَئِ ، فَخَرَجَ وَہُوَ حَزِینٌ، فَلَقِیَہُ الشَّعْبِیُّ فَسَأَلَہُ ، فَأَخْبَرَہُ عَمَا قَالَ لَہُ الْحَجَّاجُ ، فَقَالَ لَہُ الشَّعْبِیُّ : ہَلمَّ صَحِیفَۃً وَدَوَاۃً ، فَوَاللَّہِ مَا سَمِعْتُہُ مِنْ أَبِیکَ إِلاَّ مَرَّۃً وَاحِدَۃً ، فَأَمْلَی عَلَیْہِ : بِسْمِ اللہِ الرَّحْمَنِ الرَّحِیمِ ، مِنْ عَبْدِ اللہِ عُمَرَ أَمِیرِ الْمُؤْمِنِینَ إِلَی عَمَّارِ بْنِ یَاسِرٍ ، أَمَّا بَعْدُ ؛ فَإِنِّی أُتِیتُ بِشَرَابٍ مِنْ قِبَلِ الشَّامِ ، فَسَأَلْتُ عَنْہُ کَیْفَ یُصْنَعُ ؟ فَأَخْبَرُونِی أَنَّہُمْ یَطْبُخُونَہُ حَتَّی یَذْہَبَ ثُلُثَاہُ وَیَبْقَی ثُلُثُہُ ، فَإِذَا فُعِلَ ذَلِکَ بِہِ ذَہَبَ رَسُّہُ وَرِیحُ جُنُونِہِ ، وَذَہَبَ حَرَامُہُ وَبَقِیَ حَلاَلُہُ ، قَالَ عَبْدُ اللہِ : وَأُرَاہُ قَالَ : وَالطَّیِّبُ مِنْہُ ، فَإِذَا أَتَاکَ کِتَابِی ہَذَا فَمُرْ مَنْ قِبَلَکَ فَلْیَتَوَسَّعُوا بِہِ فِی أَشْرِبَتِہِمْ ، وَالسَّلاَمُ۔",,,24484 24485,حَدَّثَنَا ابْنُ فُضَیْلٍ، عَنْ أَبِیہِ ؛ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ کَرِہَ الْمُنَصَّفَ ، وَبَعَثَ إِلَی أَہْلِ الأَمْصَارِ یَنْہَاہُمْ۔,,,24485 24486,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ دَاوُدَ بْنِ إبْرَاہِیمَ ، قَالَ : قُلْتُ لِطَاوُوسٍ : أَرَأَیْتَ ہَذَا الْعَصِیرَ الَّذِی یُطْبَخُ عَلَی النِّصْفِ وَالثُّلُثِ وَنَحْوِ ذَلِکَ ؟ قَالَ : أَرَأَیْتَ ہَذَا الَّذِی مِنْ نَحْوِ الْعَسَلِ إِنْ شِئْتَ أَکَلْتَ بِہِ الْخُبْزَ ، وَإِنْ شِئْتَ صَبَبْتَ عَلَیْہِ مَائً فَشَرِبْتَہُ ، وَمَا دُونَہُ فَلاَ تَشْرَبْہُ ، وَلاَ تَبِعْہُ ، وَلاَ تَنْتَفِعَنَّ بِثَمَنِہِ۔",,,24486 24487,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ بَشِیرِ بْنِ الْمُہَاجِرِ ، عَنْ عِکْرِمَۃَ ، وَالْحَسَنِ ، قَالاَ : اشْرَبْ مِنَ الطِّلاَئِ مَا ذَہَبَ ثُلُثَاہُ وَبَقِیَ ثُلُثُہُ۔",,,24487 24488,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ بُرَیْدِ بْنِ أَبِی مَرْیَمَ ، عْن أَنَسِ بْنِ مَالِکٍ ، قَالَ : کُنَّا نَنْبِذُ الرُّطَبَ وَالْبُسْرَ عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَلَمَّا نَزَلَ تَحْرِیمُ الْخَمْرِ ہَرَقْنَاہُمَا مِنَ الأَوْعِیَۃِ ، ثُمَّ تَرَکْنَاہُمَا۔ (طحاوی 213)",,,24488 24489,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ النَّجْرَانِیِّ ، قَالَ : قُلْتُ لِعَبْدِ اللہِ بْنِ عُمَرَ : إِنَّا بِأَرْضٍ ذَاتِ تَمْرٍ وَزَبِیبٍ ، فَہَلْ یُخْلَطُ التَّمْرُ وَالزَّبِیبُ فَنَنْبِذُہُمَا جَمِیعًا ؟ قَالَ : لاَ ، قُلْتُ : لِمَ ؟ قَالَ : إِنَّ رَجُلاً سَکِرَ عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَأُتِیَ بِہِ النَّبِیُّ وَہُوَ سَکْرَانُ ، فَضَرَبَہُ ، ثُمَّ سَأَلَہُ عَنْ شَرَابِہِ ، قَالَ : شَرِبْتُ نَبِیذًا ، قَالَ : أَیَّ نَبِیذٍ ؟ قَالَ : نَبِیذُ تَمْرٍ وَزَبِیبٍ ، قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تَخْلِطُوہُمَا، فَإِنَّ کُلَّ وَاحِدٍ مِنْہُمَا یَکْفِی وَحْدَہُ۔ (احمد 25۔ ابویعلی 5756)",,,24489 24490,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ الْعَبْدِیُّ ، عَنْ حَجَّاجِ بْنِ أَبِی عُثْمَانَ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی قَتَادَۃَ ، عَنْ أَبِیہِ ، عَنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لاَ تَنْبِذُوا التَّمْرَ وَالزَّبِیبَ جَمِیعًا ، وَلاَ تَنْبِذُوا الزَّہْوَ وَالرُّطَبَ ، وَانْبِذُوا کُلَّ وَاحِدٍ مِنْہُمَا عَلَی حِدَۃٍ۔ (بخاری 5602۔ مسلم 24)",,,24490 24491,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ حَبِیبٍ ، عَنْ أَبی أَرْطَاۃَ ، عَنْ أَبِی سَعِیدٍ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الزَّہْوِ وَالتَّمْرِ ، وَعَنِ الزَّبِیبِ وَالتَّمْرِ۔ (احمد 3/58۔ ابویعلی 1171)",,,24491 24492,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ حَبِیبٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یُخْلَطَ التَّمْرُ وَالزَّبِیبُ جَمِیعًا ، وَأَنْ یُخْلَطَ الْبُسْرُ وَالتَّمْرُ جَمِیعًا ، وَکَتَبَ إلَی أَہْلِ جُرَشَ یَنْہَاہُمْ عَنْ خَلْطِ التَّمْرِ وَالزَّبِیبِ۔ (مسلم 27۔ احمد 1/336)",,,24492 24493,"حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، عَنْ جَابِرٍ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یُنْبَذَ التَّمْرُ وَالزَّبِیبُ جَمِیعًا ، وَالتَّمْرُ وَالْبُسْرُ جَمِیعًا۔ (بخاری 5601۔ مسلم 1574)",,,24493 24494,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، عَنْ عُقْبَۃَ بْنِ عَبْدِ الْغَافِرِ ، قَالَ : کَانَ أَبُو سَعِیدٍ الْخُدْرِیِّ یَنْہَی أَنْ یُجْمَعَ بَیْنَ التَّمْرِ وَالزَّبِیبِ۔",,,24494 24495,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ حُمَیْدٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ کَانَ یَکْرَہُ الْبُسْرَ وَحْدَہُ ، وَأَنْ یُجْمَعَ بَیْنَہُ وَبَیْنَ التَّمْرِ ، وَلاَ یَرَی بَأْسًا بِالتَّمْرِ وَالزَّبِیبِ وَیَقُولُ : حلاَلاَنِ اجْتَمَعَا أَوْ تَفَرَّقَا ، قَالَ : وَکَانَ الْحَسَنُ یَکْرَہُ أَنْ یُجْمَعَ بَیْنَ التَّمْرِ وَالزَّبِیبِ۔",,,24495 24496,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ سِمَاکِ بْنِ مُوسَی الضَّبِّیِّ ، قَالَ : رَأَیْتُ جَارِیَۃَ أَنَسِ بْنِ مَالِکٍ تَقْطَعُ التَّذْنِیبَ مِنَ الْبُسْرِ ، فَتَنْبِذُہُ عَلَی حِدَۃٍ ، وَتنْبِذُ الْبُسْرِ عَلَی حِدَۃٍ۔",,,24496 24497,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ حَاتِمِ بْنِ أَبِی صَغِیرَۃَ ، عَنْ أَبِی مُصْعَبٍ الْمَدَنِیِّ ، قَالَ : سَمِعْتُ أَبَا ہُرَیْرَۃَ یَقُولُ : لَمَّا حُرِّمَتِ الْخَمْرُ کَانُوا یَأْخُذُونَ الْبُسْرَ فَیَقْطَعُونَ مِنْہُ کُلَّ مُذَنَّبٍ ، ثُمَّ یَأْخُذُ الْبُسْرَ فَیَفْضَخُہُ ، ثُمَّ یَشْرَبُہُ۔",,,24497 24498,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ مُحَارِبٍ ، عَنْ جَابِرٍ ، قَالَ : الْبُسْرُ وَالتَّمْرُ خَمْرٌ۔",,,24498 24499,"حَدَّثَنَا ابْنُ إدْرِیسَ ، وَمُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ یَزِیدَ ، عَنْ مُجَاہِدٍ ، قَالَ : سَأَلَ رَجُلٌ عُمَرَ عَنِ الْفَضِیخِ، فَقَالَ : وَمَا الْفَضِیخُ ؟ قَالَ : بُسْرٌ یُفْضَخُ ثُمَّ یُخْلَطُ بِالتَّمْرِ ، فَقَالَ : ذَاکَ الْفَضُوخُ ، قَالَ : حُرِّمَتِ الْخَمْرُ وَمَا شَرَابٌ غَیْرُہُ۔",,,24499 24500,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ أَشْعَثَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : یُکْرَہُ خَلْطُ الْبُسْرِ وَالتَّمْرِ ، وَالزَّبِیبِ وَالتَّمْرِ۔",,,24500 24501,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ یَزِیدَ بْنِ کَیْسَانَ ، قَالَ : سَأَلْتُ أَبَا الشَّعْثَائِ جَابِرَ بْنَ زَیْدٍ عَنِ الْفَضِیخِ ؟ قَالَ : وَمَا الْفَضِیخُ ؟ قُلْتُ : الْبُسْرُ وَالتَّمْرُ ، فَقَالَ : وَاللَّہِ لأَنْ تَأْخُذَ الْمَائَ وَتَغْلِیَہُ فَتَجْعَلَہُ فِی بَطْنِکَ ، خَیْرٌ مِنْ أَنْ تَجْمَعَہُمَا جَمِیعًا فِی بَطْنِک۔",,,24501 24502,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ أَشْعَثَ ، عَنْ ثَابِتِ بْنِ عُبَیْدٍ ، قَالَ : کَانَ أبُو مَسْعُودٍ الأَنْصَارِیُّ یَأْمُرُ أَہْلَہُ بِقَطْعِ الْمُذَنَّبِ مِنَ الْبُسْرِ ، فَیُنْبَذُ کُلُّ وَاحِدٍ مِنْہُمَا عَلَی حِدَۃٍ۔",,,24502 24503,"حَدَّثَنَا عَفَّانُ بْنُ مُسْلِمٍ، قَالَ: حدَّثَنَا الْمُثَنَّی بْنُ عَوْفٍ، قَالَ: حَدَّثَنَا أَبُو عَبْدِ اللہِ الْجَسْرِیُّ، عَنْ مَعْقِلِ بْنِ یَسَارٍ؛ أَنَّہُ سَأَلَہُ عَنِ الشَّرَابِ؟ فَقَالَ: کُنَّا بِالْمَدِینَۃِ وَکَانَتْ کَثِیرَۃَ التَّمْرِ ، فَحَرَّمَ عَلَیْنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْفَضِیخَ ، قَالَ : جَائَ رَجُلٌ یَسْأَلُہُ عَنْ أُمِّہِ ، قَدْ بَلَغَتْ سِنًّا لاَ تَأْکُلُ الطَّعَامَ ، أَیَسْقِیہَا النَّبِیذَ؟ قَالَ: قُلْتُ لَہُ : یَا مَعْقِلَ بْنَ یَسَارٍ ، قَالَ : مَا أَمَرْتَہُ بِہِ ؟ قَالَ : أَمَرْتُہُ أَنْ لاَ یَسْقِیَہَا۔ (طبرانی 505۔ طیالسی 934)",,,24503 24504,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی نَضْرَۃَ ، عَنْ أَبِی سَعِیدٍ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ التَّمْرِ وَالزَّبِیبِ یُخْلَطَانِ ، وَعَنِ الْبُسْرِ وَالتَّمْرِ یُخْلَطَانِ۔ (مسلم 20۔ ترمذی 1877)",,,24504 24505,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حُمَیْدٍ ، عَنْ أَنَسِ بْنِ مَالِکٍ ، قَالَ : کُنَّا فِی بَیْتِ أَبِی طَلْحَۃَ وَمَعَنَا سُہَیْلُ بْنُ بَیْضَائَ ، وَأُبَیُّ بْنُ کَعْبٍ ، وَأَبُو عُبَیْدَۃَ ، وَہُمْ یَشْرَبُونَ شَرَابًا لَہُمْ ، إِذْ نَادَی مُنَادٍ : أَلاَ إِنَّ الْخَمْرَ قَدْ حُرِّمَتْ ، فَوَاللَّہِ مَا نَظَرُوا أَصِدْقٌ ، أَوْ کَذِبٌ حَتَّی قَالُوا : یَا أَنَسُ ، أَکْفِئْ مَا بَقِیَ فِی الإِنَائِ ، فَأَکْفَأْنَاہُ ، وَہُوَ یَوْمَئِذٍ الْبُسْرُ وَالتَّمْرُ ، فَوَاللَّہِ مَا عَادُوا فِیہَا حَتَّی لَقُوا اللَّہَ۔ (مسلم 1570۔ ابوداؤد 3665)",,,24505 24506,"حَدَّثَنَا مُحَمَّدُ بْنُ مُصْعَبٍ ، عَنِ الأَوْزَاعِیِّ ، عَنْ یَحْیَی ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لاَ تَجْمَعُوا بَیْنَ الزَّہْوِ وَالرُّطَبِ ، وَالزَّبِیبِ وَالتَّمْرِ ، انْبِذُوا کُلَّ وَاحِدٍ مِنْہُمَا عَلَی حِدَۃٍ۔ (مسلم 1576۔ ابن حبان 5381)",,,24506 24507,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، عَنْ عَمَّارِ بْنِ رُزَیْقٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْحَکَمِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، قَالَ : کَانَ الرَّجُلُ یَمُرُّ عَلَی أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُمْ مُتَوَافِرُونَ ، فَیَلْعَنُونَہُ وَیَقُولُونَ : ہَذَا یَشْرَبُ الْخَلِیطَیْنِ : الزَّبِیبَ وَالتَّمْرَ۔",,,24507 24508,حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ حَبِیبِ بْنِ أَبِی عَمْرَۃَ ، عَنْ عَدِیِّ بْنِ ثَابِتٍ ، عَنِ الْبَرَائِ بْنِ عَازِبٍ ؛ أَنَّہُ کَانَ یَشْرَبُ الطِّلاَئَ عَلَی النِّصْفِ۔,,,24508 24509,"حَدَّثَنَا وَکِیعٌ ، عَنْ طَلْحَۃَ بْنِ جَبْرٍ ، قَالَ : رَأَیْتُ أَبَا جُحَیْفَۃَ یَشْرَبُ الطِّلاَئَ عَلَی النِّصْفِ۔",,,24509 24510,حَدَّثَنَا وَکِیعٌ، عَنْ جَرِیرِ بْنِ أَیُّوبَ، عَنْ أَبِی زُرْعَۃَ بْنِ عَمْرِو بْنِ جَرِیرٍ؛ أَنَّ جَرِیرًا کَانَ یَشْرَبُہُ عَلَی النِّصْفِ۔,,,24510 24511,حَدَّثَنَا عَبْدُالرَّحِیمِ بْنُ سُلَیْمَانَ، وَوَکِیعٌ، عَنْ عُبَیْدَۃَ، عَنْ خَیْثَمَۃَ، عَنْ أَنَسٍ؛ أَنَّہُ کَانَ یَشْرَبُہُ عَلَی النِّصْفِ۔,,,24511 24512,حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ أَشْعَثَ ، عَنْ جَعْفَرِ ؛ أَنَّ ابْنَ أَبْزَی کَانَ یَشْرَبُ الطِّلاَئَ عَلَی النِّصْفِ۔,,,24512 24513,حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنِ الْمُنْذِرِ ، عَنِ ابْنِ الْحَنَفِیَّۃِ ؛ أَنَّہُ کَانَ یشْرَبُ الطِّلاَئَ الْمقدی ، یَعْنِی مَا طُبِخَ عَلَی النِّصْفِ۔,,,24513 24514,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنِ الْحَکَمِ ، قَالَ : کَانَ شُرَیْحٌ یَشْرَبُ الطِّلاَئَ عَلَی النِّصْفِ ، یَشْرَبُ الطِّلاَئَ الشَّدِیدَ ، یَعْنِی الْمُنَصَّفَ۔",,,24514 24515,"حَدَّثَنَا شَرِیکٌ ، عَنْ أَیُّوبَ ، قَالَ : رَأَیْتُ أَبَا عُبَیْدَۃَ یَشْرَبُہُ عَلَی النِّصْفِ۔",,,24515 24516,حَدَّثَنَا ابْنُ أَبِی غنیۃَ ، عَن إِسْمَاعِیلَ ، عَنْ قَیْسٍ ، أّنَّہُ کَانَ یَشْرَبُہُ عَلَی النِّصْفِ۔,,,24516 24517,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ دِینَارٍ الأَعْرَجِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : شَرِبَ عِنْدِی الطِّلاَئَ عَلَی النِّصْفِ۔",,,24517 24518,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، وَوَکِیعٌ ، عَنِ الأَعْمَشِ ؛ أَنَّ إِبْرَاہِیمَ کَانَ یَشْرَبُہُ عَلَی النِّصْفِ۔,,,24518 24519,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنْ یَحْیَی ، قَالَ : رَأَیْتُہُ یَشْرَبُ الطِّلاَئَ عَلَی النِّصْفِ۔",,,24519 24520,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ مُجَالِدٍ ، عَنِ الشَّعْبِیِّ ، عَنْ شُرَیْحٍ ؛ أَنَّہُ کَانَ یَشْرَبُ مَعَہُ الطِّلاَئَ عَلَی النِّصْفِ ، قَالَ : فَشَرِبَ وَسَقَانِی۔",,,24520 24521,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَانَ یُنْبَذُ لَہُ الطِّلاَئُ وَیُجْعَلُ فِیہِ دُرْدِیٌّ۔,,,24521 24522,حَدَّثَنَا إِسْحَاقُ بْنُ سُلَیْمَانَ ، عَنِ أَبِی سِنَانٍ ، عَنْ ثَابِتٍ ، عَنِ الضَّحَّاکِ ؛ أَنَّہُ کَانَ یَنْبِذُ الْبُخْتُجَ۔,,,24522 24523,"حَدَّثَنَا إِسْحَاقُ بْنُ سُلَیْمَانَ ، عَنْ عَبْدِ اللہِ بْنِ جَابِرٍ ، عَنْ مُجَاہِدٍ ؛ فِی نَبِیذِ الْبُخْتُجِ ، قَالَ : کَانَ نَائِمًا فَأَنْبَہْتُہُ۔",,,24523 24524,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ بِنَبِیذِ الْبُخْتُجِ۔",,,24524 24525,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی حُجَیْرٍ ، قَالَ : سَقَانَا الضَّحَّاکُ نَبِیذَ الْبُخْتُجِ۔",,,24525 24526,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : سُئِلَ مُحَمَّدٌ عَنْ فَضِیخِ الْبُسْرِ وَحْدَہُ ؟ قَالَ : لاَ أَدْرِی مَا ہُوَ۔",,,24526 24527,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ حَاتِمِ بْنِ أَبِی صَغِیرَۃَ ، عَنْ أَبِی مُصْعَبٍ الْمَدَنِیِّ ، قَالَ : سَمِعْتُ أَبَا ہُرَیْرَۃَ یَقُولُ: کُنَّا نَأْخُذُ الْبُسْرَ فَنَفْضَخُہُ ، ثُمَّ نَشْرَبُہُ۔",,,24527 24528,حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنْ عِکْرِمَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ شَرِبَ الْفَضِیخَ عِنْدَ مَسْجِدِ الْفَضِیخِ۔ (احمد 2/106۔ ابویعلی 5707),,,24528 24529,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ ہِشَامٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، وَالْحَسَنِ ، قَالاَ : لاَ بَأْسَ أَنْ یُفْتَضَخَ الْعِذْقُ بِمَا فِیہِ۔",,,24529 24530,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ مِسحاجٍ ، قَالَ : سَمِعْتُ أَنَسًا وَہُوَ یَأْمُرُ خَادِمَہُ أَنْ یَقْطَعَ الرُّطَبَ مِنَ الْبُسْرِ ، فَیَنْتَبِذُ کُلَّ وَاحِدٍ مِنْہُمَا عَلَی حِدَۃٍ۔",,,24530 24531,حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ خَالِدٍ ، عَنْ عِکْرِمَۃَ ؛ أَنَّہُ کَرِہَ الْفَضِیخَ ، وَإِنْ کَانَ مَحْضًا۔,,,24531 24532,حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ ، لاَ بَأْسَ بِالتَّذْنُوبِ۔,,,24532 24533,حَدَّثَنَا مُحَمَّدُ بْنُ یَزِیدَ، عَنِ النُّعْمَانِ بْنِ الْمُنْذِرِ، عَنْ مَکْحُولٍ؛ أَنَّہُ کَانَ یَکْرَہُ الْمُرِّیَّ الَّذِی یُجْعَلُ فِیہِ الْخَمْرُ۔,,,24533 24534,"حَدَّثَنَا مُحَمَّدُ بْنُ یَزِیدَ ، عَنْ دَاوُدَ بْنِ عَمْرٍو ، عَنْ مَکْحُولٍ ، عَنْ أَبِی الدَّرْدَائِ ؛ فِی الْمُرِّیِّ یُجْعَلُ فِیہِ الْخَمْرُ ، قَالَ : لاَ بَأْسَ بِہِ ، ذَبَحَتْہُ الشَّمْسُ وَالْمِلْحُ۔",,,24534 24535,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، عَنِ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أَنَّہُ قَالَ : مَنْ شَرِبَ الْخَمْرَ فِی الدُّنْیَا لَمْ یَشْرَبْہَا فِی الآخِرَۃِ ، إِلاَّ أَنْ یَتُوبَ۔ (مسلم 78۔ احمد 2/21)",,,24535 24536,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ یَزِیدَ ، عَنْ مُجَاہِدٍ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ، قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ شَرِبَ الْخَمْرَ فَجَعَلَہَا فِی بَطْنِہِ ، لَمْ تُقْبَلْ لَہُ صَلاَۃٌ سَبْعًا ، إِنْ مَاتَ فِیہَا مَاتَ کَافِرًا ، فَإِنْ أَذْہَبَتْ عَقْلَہُ عَنْ شَیْئٍ مِنَ الْفَرَائِضِ ، لَمْ تُقْبَلْ لَہُ صَلاَۃٌ أَرْبَعِینَ یَوْمًا ، فَإِنْ مَاتَ فِیہَا مَاتَ کَافِرًا۔ (نسائی 5179۔ طبرانی 13492)",,,24536 24537,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ یَعْلَی بْنِ عَطَائٍ ، عَنْ حَسَّانِ بْنِ أَبِی وَجْزَۃَ ، عَنْ أَبِیہِ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ، قَالَ : لأَنْ أَزْنِیَ أَحَبَّ إِلَیَّ مِنْ أَنْ أَشْرَبَ خَمْرًا ، إِنِّی إِذَا شَرِبْتُ الْخَمْرَ تَرَکْتُ الصَّلاَۃَ ، وَمَنْ تَرَکَ الصَّلاَۃَ فَلاَ دِینَ لَہُ۔",,,24537 24538,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنِ الْعَوَّامِ بْنِ حَوْشَبٍ ، عَنِ الْمُسَیَّبِ بْنِ رَافِعٍ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ، قَالَ : مُعَاقِرُ الْخَمْرِ کَعَابِدِ اللاَّتِ وَالْعُزَّی۔",,,24538 24539,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ وَائِلِ بْنِ أبِی بَکْرٍ ، عَنْ أبِی بَکْرٍ ، عَنْ أَبِی بُرْدَۃَ ، عَنْ أبِی مُوسَی ، أَنَّہُ کَانَ یَقُولُ : مَا أُبَالِی أَشَرِبْتُ الْخَمْرَ ، أَمْ عَبَدْتُ ہَذِہِ السَّارِیَۃِ مِنْ دُونِ اللہِ۔",,,24539 24540,"حَدَّثَنَا ابْنُ مُبَارَکٌ ، عَنِ الأَوْزَاعِیِّ ، عَنْ سُلَیْمَانَ بْنِ حَبِیبٍ ؛ أَنَّ ابْنَ عُمَرَ قَالَ : لَوْ أَدْخَلْتُ إِصْبَعِی فِی خَمْرٍ مَا أَحْبَبْتُ أَنْ تَرْجِعَ إِلَیَّ۔",,,24540 24541,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنِ الأَوْزَاعِیِّ ، عَنْ عُرْوَۃَ بْنِ رُوَیْمٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَوَّلُ مَا نَہَانِی رَبِّی ؛ عَنْ شُرْبِ الْخَمْرِ ، وَعِبَادَۃِ الأَوْثَانِ ، وَمُلاَحَاۃِ الرِّجَالِ۔ (ابوداؤد 506)",,,24541 24542,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا مِسْعَرٌ ، عَنْ أَبِی عَوْنٍ ، عَنِ ابْنِ شَدَّادٍ ، قَالَ : قَالَ ابْنُ عَبَّاسٍ : حُرِّمَتِ الْخَمْرُ بِعَیْنِہَا ، قَلِیلِہَا وَکَثِیرِہَا ، وَالسَّکَرُ مِنْ کُلِّ شَرَابٍ۔",,,24542 24543,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ سَعْدِ بْنِ إِبْرَاہِیمَ ، عَن أَبِیہِ ؛ أَنَّہُ سَمِعَ عُثْمَانَ یَخْطُبُ ، فَذَکَرَ الْخَمْرَ فَقَالَ : ہِیَ مَجْمَعُ الْخَبَائِثِ ، أَوْ ہِی أُمُّ الْخَبَائِثِ ، ثُمَّ أَنْشَأَ یُحَدِّثُ عَنْ بَنِی إسْرَائِیلَ فَقَالَ : إِنَّ رَجُلاً خُیِّرَ بَیْنَ أَنْ یَقْتُلَ صَبِیًّا ، أَوْ یَمْحُوَ کِتَابًا ، أَوْ یَشْرَبَ خَمْرًا ، فَاخْتَارَ الْخَمْرَ فَمَا بَرِحَ حَتَّی فَعَلَہُنَّ کُلَّہُنَّ۔\n\n(ابن حبان 5348۔ بیہقی 287)",,,24543 24544,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ لَیْثٍ ، عَنْ طَلْحَۃَ ، عَنْ مَسْرُوقٍ ، قَالَ : شَارِبُ الْخَمْرِ کَعَابِدِ الْوَثَنِ۔",,,24544 24545,"حَدَّثَنَا مُحَمَّدُ بْنُ سُلَیْمَانَ الأَصْبَہَانِیُّ ، عَنْ سُہَیْلٍ ، عَنْ أَبِیہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، قَالَ : مُدْمِنُ الْخَمْرِ کَعَابِدِ الْوَثَنِ۔ (بخاری 386۔ ابن ماجہ 3375)",,,24545 24546,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ یَحْیَی بْنِ عَبَّادِ بْنِ عَبْدِ اللہِ بْنِ الزُّبَیْرِ ، عَنْ أَبِیہِ ، قَالَ : کُنَّا عِنْدَ عَائِشَۃَ ، فَمَرَّتْ جَلَبَۃٌ عَلَی بَابِہَا ، فَسَمِعَتِ الصَّوْتَ ، فَقَالَتْ : مَا ہَذَا ؟ فَقَالُوا : رَجُلٌ ضُرِبَ فِی الْخَمْرِ ، قَالَتْ سُبْحَانَ اللہِ ، سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : لاَ یَزْنِی الزَّانِی حِینَ یَزْنِی وَہُوَ مُؤْمِنٌ ، وَلاَ یَشْرَبُ الْخَمْرَ حِینَ یَشْرَبُ وَہُوَ مُؤْمِنٌ ، وَلاَ یَسْرِقُ السَّارِقُ حِینَ یَسْرِقُ وَہُوَ مُؤْمِنٌ ، فَإِیَّاکُمْ إِیَّاکُمْ۔",,,24546 24547,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَزْنِی الزَّانِی حِینَ یَزْنِی وَہُوَ مُؤْمِنٌ ، وَلاَ یَسْرِقُ حِینَ یَسْرِقُ وَہُوَ مُؤْمِنٌ ، وَلاَ یَشْرَبُ الْخَمْرَ حِینَ یَشْرَبُ وَہُوَ مُؤْمِنٌ ، وَلاَ یَنْتَہِبُ نُہْبَۃً ، یَرْفَعُ النَّاسُ فِیہَا أَبْصَارَہُمْ وَہُوَ مُؤْمِنٌ۔\n\n(نسائی 7126)",,,24547 24548,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنْ مُدْرِکٍ ، عَنِ ابْنِ أَبِی أَوْفَی ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَشْرَبُ الْخَمْرَ حِینَ یَشْرَبُہَا وَہُوَ مُؤْمِنٌ۔",,,24548 24549,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ کَانَ یَنہَی أَنْ تُسْقَی الْبَہَائِمُ الْخَمْرَ۔,,,24549 24550,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ بَلَغَہُ أَنَّ نِسَائً یَمْتَشِطْنَ بِالْخَمْرِ ، فَقَالَ : أَلْقَی اللَّہُ فِی رُؤُوسِہِنَّ الْحَاصَّۃَ۔",,,24550 24551,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُجَالِدٍ ، عَنْ أَبِی السَّفَرِ ، عَنِ امْرَأَتِہِ ؛ أَنَّ عَائِشَۃَ سُئِلَتْ عَنِ الْمَرْأَۃِ تَمْتَشِطُ بِالْعَسَلَۃِ فِیہَا الْخَمْرُ ؟ فَنَہَتْ عَنْ ذَلِکَ أَشَدَّ النَّہْیِ۔,,,24551 24552,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ حَمَّادٍ، عَنْ إِبْرَاہِیمَ، عَن حُذَیْفَۃَ، قَالَ : تَمْتَشِطُ بِالْخَمْرِ؟ لاَ طَیَّبَہَا اللَّہُ۔",,,24552 24553,"حَدَّثَنَا خَلَفُ بْنُ خَلِیفَۃَ ، عَنْ أَبِی ہَاشِمٍ ، عَنْ نَافِعٍ ، قَالَ : کَانَتْ لابْنِ عُمَرَ بُخْتِیَّۃٌ ،وَإِنَّہَا مَرِضَتْ فَوُصِفَ لِی أَنْ أُدَاوِیَہَا بِالْخَمْرِ ، فَدَاوَیْتُہَا ، ثُمَّ قُلْتُ لابْنِ عُمَرَ : إِنَّہُمْ وَصَفُوا لِی أَنْ أُدَاوِیَہَا بِالْخَمْرِ ، قَالَ : فَفَعَلْتُ ؟ قُلْتُ : لاَ ، وَقَدْ کُنْتُ فَعَلْتُ ، قَالَ : أَمَا إِنَّکَ لَوْ فَعَلْتَ لَعَاقَبْتُکَ۔",,,24553 24554,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ یَزِیدَ ، عَنْ مُجَاہِدٍ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ، قَالَ : لاَ یَدْخُلُ الْجَنَّۃَ مُدْمِنُ الْخَمْرِ ، وَلاَ عَاقٌّ ، وَلاَ مَنَّانٌ۔ (نسائی 5182۔ احمد 2/164)",,,24554 24555,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنْ سَالِمِ بْنِ أَبِی الْجَعْدِ ، وَمُجَاہِدٍ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَدْخُلُ الْجَنَّۃَ عَاقٌّ ، وَلاَ مُدْمِنٌ ، وَلاَ مَنَّانٌ۔ (بیہقی 7874)",,,24555 24556,"حَدَّثَنَا یَحْیَی بْنُ إِسْحَاقَ ، قَالَ : أَخْبَرَنَا یَحْیَی بْنُ أَیُّوبَ ، عَنْ عُبَیْدِ اللہِ بْنِ زُحَرَ ، عَنْ بَکْرِ بْنِ سَوَادَۃَ، عَنْ قَیْسِ بْنِ سَعْدِ بْنِ عُبَادَۃَ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إِنَّ رَبِّی حَرَّمَ عَلَیَّ الْخَمْرَ ، وَالْکُوبَۃَ ، وَالْقِنِّینَ ، یَعْنِی الْعُودَ ، ثُمَّ قَالَ : إِیَّاکُمْ وَالتّغْبِیرَ ، فَإِنَّہَا خَمْرُ الْعَالم۔ (احمد 3/422۔ بیہقی 222)",,,24556 24557,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا عَبْدُ الْعَزِیزِ ، قَالَ : حَدَّثَنِی نَافِعٌ ، عَنِ ابْنِ عُمَرَ ، قَالَ : نَزَلَ تَحْرِیمُ الْخَمْرِ وَإِنَّ بِالْمَدِینَۃِ خَمْسَۃَ أَشْرِبَۃٍ یَدْعُونَہَا الْخَمْرَ ، مَا فِیہَا خَمْرُ الْعِنَبِ۔ (بخاری 4616۔ مسلم 32)",,,24557 24558,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ أَبِی إِسْحَاقَ الشَّیْبَانِیِّ ، عَنْ عَبْدِ اللہِ بْنِ شَدَّادٍ ، قَالَ : لَمَّا أُسْرِیَ بِالنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أُوتِیَ بِدَابَّۃٍ حَتَّی أَتَی بَیْتَ الْمَقْدِسِ ، فَأُتِیَ بِإِنَائَیْنِ ؛ فِی وَاحِدٍ خَمْرٌ ، وَفِی آخَرَ لَبَنٌ ، فَأَخَذَ اللَّبَنَ ، فَقَالَ لَہُ جِبْرِیلُ : ہُدِیْتَ ، وَہُدِیَتْ أُمَّتُکَ۔ (ابن جریر 15)",,,24558 24559,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ وَائِلِ بْنِ دَاوُد التَّیْمِیِّ ، عَنْ إِبْرَاہِیمَ التَّیْمِیِّ ، قَالَ : قَالَ الأَشْعَرِیُّ : لأَنْ أُصَلِّی لِسَارِیَۃٍ أَحَبَّ إِلَیَّ مِنْ أَنْ أَشْرَبَ الْخَمْرَ۔",,,24559 24560,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ أَبِی الأَشْہَبِ ، عَنِ الْحَسَنِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَا یَسُرُّنِی أَنِّی شَرِبْتُ إنَائً مِنْ خَمْرٍ ، وَأَنِّی تَصَدَّقْتُ بِمِثْلِہِ ذَہَبًا۔",,,24560 24561,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ قَیْسٍ ، عَنْ مَکْحُولٍ ، قَالَ : أَوْصَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَعْضَ أَہْلِی أَلاَ یَشْرَبَ الْخَمْرَ ، فَإِنَّ شُرْبَہَا مِفْتَاحُ کُلِّ شَرٍّ۔",,,24561 24562,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ، عَنْ أَبِی حَیَّانَ، قَالَ: أَخْبَرَنِی أَبُو الْفُرَاتِ، عَنْ أَبِی دَاوُدَ ، قَالَ: کُنْتُ عِنْدَ مِنْبَرِ حُذَیْفَۃَ وَہُوَ بِالْمَدَائِنِ ، فَحَمِدَ اللَّہَ وَأَثْنَی عَلَیْہِ ، ثُمَّ قَالَ : أَمَّا بَعْدُ فَإِنَّ بَائِعَ الْخَمْرِ وَشَارِبَہَا فِی الإِثْمِ سَوَائٌ۔",,,24562 24563,"حَدَّثَنَا شَبَابَۃُ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ زُبَیْدٍ ، عَنْ خَیْثَمَۃَ ؛ أَنَّہُ سَمِعَہُ یَقُولُ : کُنْتُ قَاعِدًا عِنْدَ عَبْدِ اللہِ بْنِ عَمْرٍو ، فَذَکَرَ الْکَبَائِرَ حَتَّی ذَکَرَ الْخَمْرَ ، فَکَأَنَّ رَجُلاً تَہَاوَنَ بِہَا ، فَقَالَ عَبْدُ اللہِ بْنُ عَمْرٍو : لاَ یَشْرَبُہَا رَجُلٌ مُصْبِحًا إِلاَّ ظَلَّ مُشْرِکًا حَتَّی یُمْسِیَ۔",,,24563 24564,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنِ النُّعْمَانِ بْنِ أَبِی عَیَّاشٍ ، قَالَ : أرْسَلْنَا إِلَی عَبْدِ اللہِ بْنِ عَمْرٍو نَسْأَلُہُ عَنْ أَیِّ الْکَبَائِرِ أَکْبَرُ ؟ فَقَالَ : الْخَمْرُ ، فَأَعَدْنَا إِلَیْہِ الرَّسُولَ ، فَقَالَ : الْخَمْرُ ، إِنَّہُ مَنْ شَرِبَہَا لَمْ تُقْبَلْ لَہُ صَلاَۃٌ سَبْعًا ، فَإِنْ سَکِرَ لَمْ تُقْبَلْ لَہُ صَلاَۃٌ أَرْبَعِینَ یَوْمًا ، فَإِنْ مَاتَ فِیہَا مَاتَ مِیتَۃً جَاہِلِیَّۃً۔",,,24564 24565,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا سَعِیدُ بْنُ عَبْدِ الْعَزِیزِ ، عَنْ رَبِیعَۃَ بْنِ یَزِیدَ ، عَنِ ابْنِ الدَّیْلَمِیِّ ، قَالَ : سَأَلْتُ عَبْدَ اللہِ بْنَ عَمْرٍو عَنْ شَارِبِ الْخَمْرِ ؟ فَقَالَ : لاَ تُقْبَلُ لَہُ صَلاَۃٌ أَرْبَعِینَ یَوْمًا ، أَوْ أَرْبَعِینَ لَیْلَۃً۔",,,24565 24566,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ فِی الْحُبِّ تَقَعُ فِیہِ الْقَطْرَۃُ مِنَ الْخَمْرِ ، أَوِ الدَّمِ ، قَالَ : یُہْرَاقُ۔",,,24566 24567,حَدَّثَنَا إِسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنِ التَّیْمِیِّ ، عَنْ أُمِّ حِرَاشٍ ؛ أَنَّہَا رَأَتْ عَلِیًّا یَصْطَبِغُ بِخَلِّ الْخَمْرِ۔,,,24567 24568,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ مُعَاوِیَۃَ بْنِ صَالِحٍ ، عَنْ أَبِی الزَّاہِرِیَّۃِ ، عَنْ جُبَیْرِ بْنِ نُفَیْرٍ ، قَالَ : اخْتَلَفَ رَجُلاَنِ مِنْ أَصْحَابِ مُعَاذٍ فِی خَلِّ الْخَمْرِ ، فَسَأَلاَ أَبَا الدَّرْدَائِ ؟ فَقَالَ : لاَ بَأْسَ بِہِ۔",,,24568 24569,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِیہِ ، عَنْ مُسَرْبَلٍ الْعَبْدِیِّ ، عَنْ أُمِّہِ ، قَالَتْ : سَأَلْتُ عَائِشَۃَ عَنْ خَلِّ الْخَمْرِ ، قَالَتْ : لاَ بَأْسَ بِہِ ، ہُوَ إِدَامٌ۔",,,24569 24570,حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ اللہِ بْنِ نَافِعٍ ، عَنْ أَبِیہِ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ یَأْکُلَ مِمَّا کَانَ خَمْرًا فَصَارَ خَلاًّ۔,,,24570 24571,"حَدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَانَ مُحَمَّدٌ لاَ یَقُولُ : خَلُّ خَمْرٍ ، وَیَقُولُ : خَلُّ الْعِنَبِ ، وَکَانَ یَصْطَبِغُ فِیہِ۔",,,24571 24572,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ زَیْدٍ ، عَنْ یَحْیَی بْنِ عَتِیقٍ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا بِخَلِّ الْخَمْرِ۔,,,24572 24573,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ إِسْمَاعِیلَ بْنِ عَبْدِ الْمَلِکِ ، قَالَ : رَأَیْتُ سَعِیدَ بْنَ جُبَیْرٍ یَصْطَبِغُ بِخَلِّ خَمْرٍ۔",,,24573 24574,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ مُبَارَکٍ ، عَنِ الْحَسَنِ ، قَالَ : لاَ بَأْسَ بِخَلِّ خَمْرٍ۔",,,24574 24575,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ السُّدِّیِّ ، عَنْ یَحْیَی بْنِ عَبَّادٍ ، عَنْ أَنَسٍ ؛ أَنَّ أَبَا طَلْحَۃَ سَأَلَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ أَیْتَامٍ وَرِثُوا خَمْرًا ، أَیَجْعَلُہُ خَلاًّ ؟ فَکَرِہَہُ۔ (ابوداؤد 3667۔ احمد 119),,,24575 24576,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُثَنَّی بْنِ سَعِیدٍ ، قَالَ : شَہِدْتُ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ کَتَبَ إلَی عَامِلِہِ بِوَاسِطٍ أَنْ لاَ تَحْمِلُوا الْخَمْرَ مِنْ قَرْیَۃٍ إلَی قَرْیَۃٍ ، وَمَا أَدْرَکْتَ فَاجْعَلْہُ خَلاًّ۔",,,24576 24577,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، عَنِ الْقَاسِمِ ، عَنْ أَسْلَمَ ، قَالَ : قَالَ عُمَرُ : لاَ بَأْسَ بِخَلٍّ وَجَدْتَہُ مَعَ أَہْلِ الْکِتَابِ ، مَا لَمْ تَعْلَمْ أَنَّہُمْ تَعَمَّدُوا فَسَادَہَا بَعْدَ مَا صَارَتْ خَمْرًا۔",,,24577 24578,"حَدَّثَنَا یَحْیَی بْنُ زَکَرِیَّا بْنِ أَبِی زَائِدَۃَ، عَنِ ابْنِ جُرَیْجٍ، عَنْ عَطَائٍ، قَالَ : لاَ بَأْسَ أَنْ یُحَوَّلَ الْخَمْرُ خَلاًّ۔",,,24578 24579,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، وَحَفْصٌ ، عَنْ عَاصِمٍ ، عَنِ الشَّعْبِیِّ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : نَاوَلْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إدَاوَۃً مِنْ زَمْزَمَ ، فَشَرِبَہَا وَہُوَ قَائِمٌ۔ (مسلم 1602۔ احمد 220)",,,24579 24580,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ مُسْلِمٍ ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ یَشْرَبُ قَائِمًا۔",,,24580 24581,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَبِی سِنَانٍ ، عَنْ أَبِی الْمُعَارِکِ ، قَالَ : سَأَلْتُ أَبَا ہُرَیْرَۃَ عَنْ شُرْبِ الرَّجُلِ وَہُوَ قَائِمٌ ؟ قَالَ : لاَ بَأْسَ بِہِ۔",,,24581 24582,حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ؛ أَنَّ عَلِیًّا کَانَ یَشْرَبُ وَہُوَ قَائِمٌ۔,,,24582 24583,حَدَّثَنَا مُعْتَمِرٌ ، عن مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، أَنَّ سَعْدًا وَعَائِشَۃَ کَانَا لاَ یَرَیَانِ بَأْسًا بِالشُّرْبِ قَائِمًا۔,,,24583 24584,حَدَّثَنَا شَرِیکٌ ، عَنْ سَالِمٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ شَرِبَ مِنْ قِرْبَۃٍ وَہُوَ قَائِمٌ۔,,,24584 24585,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ مَیْسَرَۃَ ، قَالَ : رَأَیْتُ عَلِیًّا شَرِبَ قَائِمًا ، فَقُلْتُ : شَرِبْتَ قَائِمًا ؟ فَقَالَ : لَئِنْ شَرِبْتُ قَائِمًا ، لَقَدْ رَأَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَشْرَبُ قَائِمًا ، وَلَئِنْ شَرِبْتُ قَاعِدًا ، لَقَدْ رَأَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَشْرَبُ قَاعِدًا۔ (احمد 1/114)",,,24585 24586,حَدَّثَنَا شَرِیکٌ ، عَنْ عَاصِمٍ ، عَنْ عَبْدِ اللہِ بْنِ عَامِرٍ ؛ أَنَّہُ رَأَی ابْنَ عُمَرَ یَشْرَبُ قَائِمًا۔,,,24586 24587,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبَّادِ بْنِ مَنْصُورٍ ، قَالَ : رَأَیْتُ سَالِمًا یَشْرَبُ وَہُوَ قَائِمٌ۔",,,24587 24588,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَجْلاَنَ ، قَالَ : سَأَلْتُ إِبْرَاہِیمَ عْنہُ ؟ فَقَالَ : لاَ بَأْسَ بِہِ ، إِنْ شِئْتَ قَائِمًا ، وَإِنْ شِئْتَ قَاعِدًا۔",,,24588 24589,"حَدَّثَنَا یَحیی بن سَعِید ، عَنْ مُجَالِد قَالَ : رَأَیْتُ الشعبِی یَشْرَبُ قَائِمًا ، وَقَاعِدًا۔",,,24589 24590,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ وَاقِدٍ ، عَنْ زَاذَانَ ، قَالَ : لاَ بَأْسَ بِالشُّرْبِ قَائِمًا ، وَالْجُلُوسُ حِلْمٌ۔",,,24590 24591,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ، عَنِ الْحَسَنِ بْنِ الْحَکَمِ، عَنِ الْحُرِّ بْنِ صَیَّاحٍ، قَالَ : سَأَلَ رَجُلٌ ابْنَ عُمَرَ فَقَالَ: مَا تَرَی فِی الشُّرْبِ قَائِمًا ؟ فَقَالَ ابْنُ عُمَرَ : إِنِّی أَشْرَبُ وَأَنَا قَائِمٌ ، وَآکُلُ وَأَنَا أَمْشِی۔",,,24591 24592,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ عِمْرَانَ بْنِ حُدَیْرٍ ، عَنْ یَزِیدَ بْنِ عُطَارِدٍ أَبِی الْبَزَرَی ، قَالَ : قَالَ ابْنُ عُمَرَ : کُنَّا نَشْرَبُ وَنَحْنُ قِیَامٌ ، وَنَأْکُلُ وَنَحْنُ نَسْعَی عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔ (احمد 2/29)",,,24592 24593,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَبْدِ الْمَلِکِ بْنِ مَیْسَرَۃَ ، قَالَ : سَأَلْتُ طَاوُوسًا ، وَسَعِیدَ بْنَ جُبَیْرٍ عَنِ الشُّرْبِ قَائِمًا ؟ فَلَمْ یَرَیَا بِہِ بَأْسًا۔",,,24593 24594,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ، عَنِ ابْنِ أَبِی نَجِیحٍ، عَنْ مُجَاہِدٍ، قَالَ: أَخْبَرَنِی مَنْ رَأَی عَلِیًّا بِالْکُوفَۃِ یَشْرَبُ قَائِمًا۔",,,24594 24595,"حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ ، عَنْ مَالِکِ بْنِ أَنَسٍ ، عن عَامِرَ بْنَ عَبْدِ اللہِ بن الزُبَیر قَالَ : رَأَیتُ أَبِی یَشْرَبُ وَہُوَ قَائِمٌ۔",,,24595 24596,"حَدَّثَنَا حَفْصٌ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : کُنَّا نَشْرَبُ وَنَحْنُ قِیَامٌ ، وَنَأْکُلُ وَنَحْنُ نَمْشِی عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔ (احمد 108۔ دارمی 2126)",,,24596 24597,"حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ أَبِی سُلَیْمَانَ ، قَالَ : قَالَ لِی سَعِیدُ بْنُ جُبَیْرٍ : اشْرَبُ قَائِمًا۔",,,24597 24598,"حَدَّثَنَا أَبُوالأَحْوَصِ، عَنْ عَبْدِ اللہِ بْنِ شَرِیکٍ، عَنْ بِشْرِ بْنِ غَالِبٍ، قَالَ: رَأَیْتُ الْحُسَیْنَ شَرِبَ وَہُوَ قَائِمٌ۔",,,24598 24599,"حَدَّثَنَا وَکِیعٌ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ، عَنْ قَتَادَۃَ، عَنْ أَبِی عِیسَی الآُسْوَارِیِّ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ، قَالَ : زَجَرَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجُلاً شَرِبَ قَائِمًا۔ (مسلم 114۔ ابویعلی 984)",,,24599 24600,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسِ بْنِ مَالِکٍ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الشُّرْبِ قَائِمًا۔ (مسلم 1601۔ ابوداؤد 3710)",,,24600 24601,حَدَّثَنَا مُعْتَمِرٌ ، عَنْ مَعْمَرٍ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسٍ ؛ أَنَّہُ سَأَلَہُ عَنِ الشُّرْبِ قَائِمًا ؟ فَکَرِہَہُ۔,,,24601 24602,حَدَّثَنَا ہُشَیْمٌ ، عَنْ مَنْصُورٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَکْرَہُ الشُّرْبَ قَائِمًا۔,,,24602 24603,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ مَنْصُورٍ، عَنْ إِبْرَاہِیمَ ، قَالَ: إِنَّمَا کُرِہَ الشُّرْبُ قَائِمًا لِدَائٍ یَأْخُذُ الْبَطْنَ۔",,,24603 24604,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ ہِشَام ، عَنِ الْحَسَنِ ، عَنْ جَابِرٍ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الشُّرْبِ مِنْ أَفْوَاہِ الأَسْقِیَۃِ۔ (مسند 544)",,,24604 24605,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، عَنْ عُبَیْدِ اللہِ بْنِ عَبْدِ اللہِ بْنِ عُتْبَۃَ ، عَنْ أَبِی سَعِیدٍ ، قَالَ : شَرِبَ رَجُلٌ مِنْ سِقَائٍ فَانْسَابَ فِی بَطْنِہِ جَانٌّ ، فَنَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ اخْتِنَاثِ الأَسْقِیَۃِ۔ (مسلم 110۔ ابوداؤد 3713)",,,24605 24606,"حَدَّثَنَا یُونُسُ بْنُ مُحَمَّدٍ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ قَتَادَۃَ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الشُّرْبِ مِنْ فِی السِّقَائِ۔",,,24606 24607,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الشُّرْبِ مِنْ فِی السِّقَائِ۔",,,24607 24608,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنِ ابْنِ بِنْتِ أَنَسِ بْنِ مَالِکٍ ، عَنْ أَنَسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ دَخَلَ عَلَی أُمِّ سُلَیْمٍ وَفِی الْبَیْتِ قِرْبَۃٌ مُعَلَّقَۃٌ ، فَشَرِبَ مِنْ فِیہَا وَہُوَ قَائِمٌ۔ (احمد 6/376۔ طبرانی 25),,,24608 24609,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا بِالشُّرْبِ مِنْ فِی الإِدَاوَۃِ۔,,,24609 24610,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ سَالِمٍ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ، قَالَ: رَأَیْتُ ابْنَ عُمَرَ یَشْرَبُ مِنْ فِی الإِدَاوَۃِ۔",,,24610 24611,حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی رَوَّادٍ ، عَنْ نَافِعٍ ؛ أَنَّ ابْنَ عُمَرَ کَانَ یَشْرَبُ مِنْ فِی السِّقَائِ۔,,,24611 24612,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبَّادِ بْنِ مَنْصُورٍ ، قَالَ : رَأَیْتُ سَالِمَ بْنَ عَبْدِ اللہِ یَشْرَبُ مِنْ فِی الإِدَاوَۃِ۔",,,24612 24613,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنْ زَیْدِ بْنِ عَبْدِ اللہِ بْنِ عُمَرَ ، عَنْ عَبْدِ اللہِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ أَبِی بَکْرٍ ، عَنْ أُمِّ سَلَمَۃَ زَوْجِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَتْ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنَّ الَّذِی یَأْکُلُ وَیَشْرَبُ فِی آنِیَۃِ الذَّہَبِ وَالْفِضَّۃِ ، فَإِنَّمَا یُجَرْجَرُ فِی بَطْنِہِ نَارُ جَہَنَّمَ۔ (مسلم 1634۔ احمد 6/306)",,,24613 24614,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنْ زَیْدِ بْنِ عَبْدِ اللہِ بْنِ عُمَرَ ، عَنْ عَبْدِ اللہِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ أَبِی بَکْرٍ ، عَنْ أُمِّ سَلَمَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ مِثْلہ۔,,,24614 24615,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، قَالَ : اسْتَسْقَی حُذَیْفَۃُ بِالْمَدَائِنِ ، فَأَتَاہُ دِہْقَانٌ بِإِنَائٍ مِنْ فِضَّۃٍ فِیہِ شَرَابٌ ، فَأَرَادَ أَنْ یَضْرِبَ بِہِ وَجْہَہُ ، فَقِیلَ لَہُ : إِنَّ الدَّہَاقِینَ یُکْرِمُونَ الأُمَرَائَ بِہَذَا ، قَالَ : إِنِّی کُنْتُ نَہَیْتُہُ ، وَاتَّخَذْتُ عَلَیْہِ الْحُجَّۃَ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَانَا أَنْ نَشْرَبَ فِی الْفِضَّۃِ وَالذَّہَبِ۔ (مسلم 1637)",,,24615 24616,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ أَشْعَثَ بْنِ أَبِی الشَّعْثَائِ ، عَنْ مُعَاوِیَۃَ بْنِ سُوَیْد بْنِ مُقَرِّنٍ ، عَنِ الْبَرَائِ بْنِ عَازِبٍ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الشُّرْبِ فِی الْفِضَّۃِ ، فَإِنَّہُ مَنْ شَرِبَ فِیہِ فِی الدُّنْیَا ، لَمْ یَشْرَبْ فِیہِ فِی الآخِرَۃِ۔",,,24616 24617,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنِ الْعَلاَئِ ، عَنْ یَعْلَی بْنِ النُّعْمَانِ ، قَالَ : قَالَ عُمَرُ : مَنْ شَرِبَ فِی قَدَحٍ مُفَضَّضٍ ، سَقَاہُ اللَّہُ یَوْمَ الْقِیَامَۃِ جَمْرًا۔",,,24617 24618,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ رَجُلٍ ، عَنْ أَنَسِ بْنِ مَالِکٍ ؛ أَنَّہُ أُتِیَ بِجَامٍ مِنْ فِضَّۃٍ فِیہِ خَبِیصٌ ، فَأَمَرَ بِہِ فَحُوِّلَ عَلَی رَغِیفٍ ، ثُمَّ أَکَلَہُ۔,,,24618 24619,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، قَالَ : کَانَ زَاذَانُ ، وَمَیْسَرَۃُ ، وَسَعِیدُ بْنُ جُبَیْرٍ لاَ یَشْرَبُونَ فِی آنِیَۃِ الذَّہَبِ وَالْفِضَّۃِ ، وَلاَ یَدَّہِنُونَ فِی مَدَاہِنِ الذَّہَبِ وَالْفِضَّۃِ۔",,,24619 24620,حَدَّثَنَا وَکِیعٌ، عَنْ مِسْعَرٍ، عَنْ ثَابِتِ بْنِ عُبَیْدٍ، عَنْ بَشِیرِ بْنِ أَبِی مَسْعُودٍ؛ أَنَّہُ أُتِیَ بِإِنَائٍ مِنْ فِضَّۃٍ، فَکَرِہَہُ۔,,,24620 24621,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، قَالَ : کَانَ زَاذَانُ ، وَمَیْسَرَۃُ ، وَسَعِیدُ بْنُ جُبَیْرٍ یَشْرَبُونَ مِنَ الآنِیَۃِ الْمُفَضَّضَۃِ۔",,,24621 24622,حَدَّثَنَا جَرِیرٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ لاَ یَشْرَبُ فِی إِنَائٍ مُضَبَّبٍ بِفِضَّۃٍ ، وَیَشْرَبُ فِی قَدَحٍ فِیہِ حَلْقَۃٌ مِنْ وَرِقٍ۔,,,24622 24623,حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ عِمْرَانَ أَبِی الْعَوَّامِ الْقَطَّانِ ، عَنْ قَتَادَۃَ ؛ أَنَّ عِمْرَانَ بْنَ حُصَیْنٍ ، وَأَنَسَ بْنَ مَالِکٍ کَانَا یَشْرَبَانِ فِی الإِنَائِ الْمُفَضَّضِ۔,,,24623 24624,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حُمَیْدٍ ، قَالَ : دَخَلْتُ عَلَی الْقَاسِمِ بْنِ مُحَمَّدٍ وَہُوَ مَحْمُومٌ ، وَعَلَی صَدْرِہِ قَدَحٌ مُفَضَّضٌ فِیہِ مَائٌ۔",,,24624 24625,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، وَعَبْدُ الرَّحْمَن بْنُ مَہْدِیٍّ ، عَنْ مُحَمَّدِ بْنِ مُسْلِمٍ ، عَنْ إِبْرَاہِیمَ بْنِ مَیْسَرَۃَ ، قَالَ : رَأَیْتُ طَاوُوسًا یَشْرَبُ فِی قَدَحٍ مُضَبَّبٍ بِوَرِقٍ۔",,,24625 24626,"حَدَّثَنَا وَکِیعٌ ، عَنْ یَزِیدَ بْنِ زِیَادٍ الدِّمَشْقِیِّ ، عَنْ سُلَیْمَانَ بْنِ حَبِیبٍ ، وَسُلَیْمَانَ بْنِ دَاوُد ، قَالاَ : أَتَیْنَا عُمَرَ بْنَ عَبْدِ الْعَزِیزِ بِشَرَابٍ فِی قَدَحٍ مُفَضَّضٍ ، فَوَضَعَ فَاہُ بَیْنَ الضَّبتین فَشَرِبَ ، وَقَالَ : لاَ تُعِیدَاہُ عَلَیَّ۔",,,24626 24627,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، قَالَ : رَأَیْتُ أَبَا جَعْفَرٍ یَشْرَبُ فِی قَدَحٍ جیَشَانِیٍّ کَثِیرِ الْفِضَّۃِ ، وَسَقَانِی۔",,,24627 24628,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ مُعَاوِیَۃَ بْنَ قُرَّۃَ ، قُلْتُ : آتِی الصَّیَارِفَ فَأُوتَی بِقَدَحٍ مِنْ فِضَّۃٍ، أَشْرَبُ فِیہِ ؟ قَالَ : لاَ بَأْسَ۔",,,24628 24629,حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ لاَ یَشْرَبُ مِنْ قَدَحٍ فِیہِ حَلْقَۃُ فِضَّۃٍ ، وَلاَ ضَبَّۃُ فِضَّۃٍ۔,,,24629 24630,حَدَّثَنَا وَکِیعٌ ، عَنْ مَعْمَرٍ ، عَنْ أَبِی جَعْفَرٍ ، عَنْ عَلِیِّ بْنِ حُسَیْنٍ ؛ أَنَّہُ أُتِیَ بِقَدَحٍ مُفَضَّضٍ ، فَکَرِہَ أَنْ یَشْرَبَ فِیہِ۔,,,24630 24631,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَمُحَمَّدٍ ؛ أَنَّہُمَا کَرِہَا أَنْ یُضَبَّبَ الْقَدَحُ بِذَہَبٍ ، أَوْ فِضَّۃٍ۔,,,24631 24632,حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ أَنَّہُ کَانَ یَکْرَہُ أَنْ یَشْرَبَ فِی قَدَحٍ فِیہِ فِضَّۃٌ۔,,,24632 24633,"حَدَّثَنَا وَکِیعٌ ، عَنْ دَاوُدَ بْنِ قَیْسٍ ، قَالَ : أَتَیْتُ الْمُطَّلِبَ بْنَ عَبْدِ اللہِ بْنِ حَنْطَبٍ بِقَدَحٍ مُفَضَّضٍ ، فَلَمْ یَشْرَبْ فِیہِ۔",,,24633 24634,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : کَانَ ابْنُ عُمَرَ یَکْرَہُ أَنْ یَشْرَبَ فِی قَدَحٍ فِیہِ حَلْقَۃٌ مِنْ فِضَّۃٍ۔",,,24634 24635,حَدَّثَنَا وَکِیعٌ ، عَنِ ابن أَبِی رَوَّادٍ ، عَن نَافِع ، عن ابْن عُمَرَ ؛ أَنَّہُ کَانَ لاَ یَشْرَبُ فِی إِناء مُفَضَّضٍ۔,,,24635 24636,حَدَّثَنَا وَکِیعٌ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، عَنْ سَالِمٍ ؛ أَنَّہُ کَرِہَہُ۔,,,24636 24637,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ ، عَنْ أُمِّ عَمْرٍو بِنْتِ أَبِی عَمْرٍو ، قَالَتْ : کَانَتْ عَائِشَۃُ تَنْہَانَا أَنْ نَتَحَلَّی الذَّہَبَ ، أَوْ نُضَبِّبَ الآنِیَۃَ ، أَوْ نُحَلِّقَہَا بِالْفِضَّۃِ ، فَمَا بَرِحْنَا حَتَّی رَخَّصَتْ لَنَا وَأَذِنَتْ لَنَا أَنْ نَتَحَلَّی الذَّہَبَ ، وَمَا أَذِنَتْ لَنَا ، وَلاَ رَخَّصَتْ لَنَا أَنْ نُحَلِّقَ الآنِیَۃَ ، أَوْ نُضَبِّبَہَا بِالْفِضَّۃِ۔",,,24637 24638,حَدَّثَنَا مُحَمَّدُ بْنُ یَزِیدَ ، عَنْ أَیُّوبَ أَبِی الْعَلاَئِ ، عَنْ مَنْصُورٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَرِہَ أَنْ یَشْرَبَ فِی قَدَحٍ مُفَضَّضٍ۔,,,24638 24639,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ، عَنْ زَائِدَۃَ، عَنْ إِبْرَاہِیمَ بْنِ مُہَاجِرٍ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عُمَرَ ، وَابْنِ عَبَّاسٍ، قَالاَ : کَانَ یُکْرَہُ أَنْ یُشْرَبَ مِنْ ثُلْمَۃِ الْقَدَحِ ، أَوْ مِنْ عِنْدِ أُذُنِ الْقَدَحِ۔",,,24639 24640,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانُوا یَکْرَہُونَ أَنْ یُشْرَبَ مِنَ الثُّلْمَۃِ تَکُونُ فِی الإِنَائِ ، أَوْ یُشْرَبُ مِنْ قِبَلِ أُذُنِہِ۔",,,24640 24641,حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ إِبْرَاہِیمَ بْنِ مُہَاجِرٍ ، عَنْ مُجَاہِدٍ ؛ أَنَّہُ کَانَ یَکْرَہُ أَنْ یَشْرَبَ مِمَّا یَلِی عُرْوَۃَ الْقَدَحِ ، أَوِ الثُّلْمَۃِ تَکُونُ فِیہِ۔,,,24641 24642,حَدَّثَنَا عَبْدُ اللہِ بْنُ الْمُبَارَکِ ، عَنْ سَالِمٍ ، عَنْ عَطَائٍ ؛ أَنَّہُ کَانَ لاَ یَرَی بِالشُّرْبِ بِالنَّفَسِ الْوَاحِدِ بَأْسًا۔,,,24642 24643,"حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِیلَ ، عَنْ عَبْدِ اللہِ بْنِ یَزِیدَ ، قَالَ : لَمْ أَرَ أَحَدًا کَانَ أَعْجَلَ إِفْطَارًا مِنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، کَانَ لاَ یَنْتَظِرُ مُؤَذِّنًا ، وَیُؤْتَی بِقَدَحٍ مِنْ مَائٍ فَیَشْرَبُہُ بِنَفَسٍ وَاحِدٍ ، لاَ یَقْطَعُہُ حَتَّی یَفْرُغَ مِنْہُ۔",,,24643 24644,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، قَالَ : نُبِّئْتُ عَنْ مَیْمُونِ بْنِ مِہْرَانَ ، قَالَ : رَآنِی عُمَرُ بْنُ عَبْدِ الْعَزِیزِ وَأَنَا أَشْرَبُ ، فَجَعَلْتُ أَقْطَعُ شَرَابِی وَأَتَنَفَّسُ ، فَقَالَ : إِنَّمَا نُہِیَ أَنْ یُتَنَفَّسَ فِی الإِنَائِ ، فَإِذَا لَمْ تَتَنَفَّسْ فِی الإِنَائِ ، فَاشْرَبْہُ إِنْ شِئْتَ بِنَفَسٍ وَاحِدٍ۔",,,24644 24645,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ طَاوُوسٍ ، قَالَ : رَآنِی أَبِی وَنَحْنُ نَشْرَبُ بِنَفَسٍ وَاحِدٍ فَنَہَانَا ، أَوْ نَہَانِی۔",,,24645 24646,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ خَالِدٍ ، عَنْ عِکْرِمَۃَ ؛ أَنَّہُ کَرِہَ الشُّرْبَ بِنَفَسٍ وَاحِدٍ ، وَقَالَ : ہُوَ شُرْبُ الشَّیْطَانِ۔",,,24646 24647,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : نَہَی أَنْ یُتَنَفَّسَ فِی الإِنَائِ ، وَأَنْ یُنْفَخَ فِیہِ۔ (ابوداؤد 3721۔ ترمذی 1888)",,,24647 24648,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی قَتَادَۃَ ، عَنْ أَبِیہِ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إِذَا شَرِبَ أَحَدُکُمْ فَلاَ یَتَنَفَّسُ فِی الإِنَائِ۔\n\n(بخاری 5630۔ مسلم 65)",,,24648 24649,حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ خَالِدٍ ، عَنْ عِکْرِمَۃَ ؛ أَنَّہُ کَانَ یَکْرَہُ أَنْ یُتَنَفَّسَ فِی الإِنَائِ۔,,,24649 24650,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ عَزْرَۃَ بْنِ ثَابِتٍ ، عَنْ ثُمَامَۃَ ، قَالَ : کَانَ أَنَسٌ إِذَا شَرِبَ تَنَفَّسَ مَرَّتَیْنِ ، أَوْ ثَلاَثًا ، وَحَدَّثَ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ إِذَا شَرِبَ تَنَفَّسَ فِی الإِنَائِ ، ثَلاَثًا۔ (بخاری 5631۔ احمد 3/114)",,,24650 24651,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِیسِیُّ ، عَنِ الْحَکَمِ بْنِ عَطِیَّۃَ ، قَالَ : رَأَیْتُ ابْنَ سِیرِینَ یَتَنَفَّسُ ثَلاَثًا إِذَا شَرِبَ۔",,,24651 24652,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : إِذَا شَرِبْت فَتَنَفَّسْ فِی الإِنَائِ ثَلاَثًا۔",,,24652 24653,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ أَبِی بَکْرٍ ، قَالَ : جَلَسَ رَجُلٌ إِلَی ابْنِ عَبَّاسٍ فَقَالَ لَہُ : مِنْ أَیْنَ جِئْتَ ؟ قَالَ : شَرِبْتُ مِنْ مَائِ زَمْزَمَ ، قَالَ : فَشَرِبْتَ مِنْہَا کَمَا یَنْبَغِی ؟ قَالَ : إِذَا شَرِبْتَ مِنْہَا فَاسْتَقْبِلِ الْکَعْبَۃَ ، وَاذْکُرِ اسْمَ اللہِ ، وَتَنَفَّسْ ثَلاَثًا۔",,,24653 24654,حَدَّثَنَا وَکِیعٌ ، عَنْ عَزْرَۃَ بْنِ ثَابِتٍ ، عَنْ ثُمَامَۃَ بْنِ عَبْدِ اللہِ ، عَنْ أَنَسٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَتَنَفَّسُ فِی الإِنَائِ ثَلاَثًا۔ (مسلم 122),,,24654 24655,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشام ، عَنْ أَبِی عِصَام ، عَنْ أَنَسٍ قَالَ : کَانَ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَتَنَفَّسُ فِی الإِنَائِ ثَلاَثًا ، وَیَقُولُ : ہُوَ أَہْنَأُ ، وَأَمْرَأُ ، وَأَبْرَأُ۔(مسلم 123۔ ترمذی 1884)",,,24655 24656,"حَدَّثَنَا أَبُو الأَحْوَصِ، عَنْ سِمَاکٍ ، قَالَ: کُنْتُ فِی مَجْلِسِ مِنْ مَجَالِس الأَنْصَارِ فَأُتِیَ بَعْضُہُمْ بِشَرَابٍ، فَلَمَّا أَرَادَ أَنْ یَشْرَبَ نَفَخَ فِیہِ، فَقَالَ بَعْضُ الْقَوْمِ: مَہْلاً، فَإِنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَنْہَی عَنْہُ۔",,,24656 24657,"حَدَّثَنَا وَکِیعٌ ، عَنْ مَالِکِ بْنِ أَنَسٍ ، عَنْ أَیُّوبَ بْنِ حَبِیبٍ مَوْلَی بَنِی زُہْرَۃَ ، عَنْ أَبِی الْمُثَنَّی الْجُہَنِیِّ ، قَالَ : کُنْتُ عِنْدَ مَرْوَانَ بْنِ الْحَکَمِ فَدَخَلَ أَبُو سَعِیدٍ ، فَقَالَ لَہُ : سَمِعْتَ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَنْہَی عَنِ النَّفْخِ فِی الشَّرَابِ ؟ قَالَ : نَعَم ، قَالَ : فَقَالَ رَجُلٌ : إِنِّی لاَ أُرْوَی بِنَفَسٍ وَاحِدٍ ، قَالَ : أَبِنِ الإِنَائَ عَنْ فِیکَ ، ثُمَّ تَنَفَّسْ ، قَالَ : فَإِنْ رَأَیْتُ قَذَرًا ؟ قَالَ : فَأَہْرِقْہُ۔ (ابوداؤد 3715۔ دارمی 2121)",,,24657 24658,"حَدَّثَنَا عَبْدُ اللہِ بْنُ الْمُبَارَکِ ، عَنْ یُونُسَ ، عَنِ الزُّہْرِیِّ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ النَّفْخِ فِی الطَّعَامِ وَالشَّرَابِ ، قَالَ : وَلَمْ أَرَ أَحَدًا أَشَدَّ فِی ذَلِکَ مِنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ۔",,,24658 24659,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی أَنْ یُتَنَفَّسَ فِی الإِنَائِ ، وَأَنْ یُنْفَخَ فِیہِ۔,,,24659 24660,"حَدَّثَنَا وَکِیعٌ ، عَنْ ثَوْرٍ ، عَنْ یَزِیدَ ذِی الأَرْشِ ، عَنْ مَوْلاَۃً لِثَوْبَانَ ، قَالَتْ : أَتَیْتُ ثَوْبَانَ بِشَرَابٍ فَنَفَخْتُ فِیہِ ، فَأَبَی أَنْ یَشْرَبَ۔",,,24660 24661,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہَاشِمِ بْنِ البَرِیدِ ، عَنِ الْقَاسِمِ بْنِ مُسْلِمٍ مَوْلَی الْحَسَنِ بْنِ عَلِیٍّ ، قَالَ : اسْتَسْقَی عَلِیٌّ ، فَأَتَیْتُہُ بِشَرَابٍ فَنَفَخْتُ فِیہِ ، فَأَبَی أَنْ یَشْرَبَہُ ، وَقَالَ : اشْرَبْہُ أَنْتَ۔",,,24661 24662,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ؛ أَنَّہُ کَانَ یَکْرَہُ النَّفْخَ فِی الطَّعَامِ وَالشَّرَابِ۔,,,24662 24663,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : کَانَ یَکْرَہُہُ۔",,,24663 24664,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَجَّاجٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ إِیَاسٍ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّہُ کَرِہَ النَّفْخَ فِی الطَّعَامِ وَالشَّرَابِ۔,,,24664 24665,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنْ یَحْیَی ، عَنْ عَبْدِ اللہِ بْنِ أَبِی قَتَادَۃَ ، عَنْ أَبِیہِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی عَنِ النَّفْخِ فِی الإِنَائِ۔,,,24665 24666,حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنِ الأَوْزَاعِیِّ ، عَنْ وَاصِلٍ ، عَنْ مُجَاہِدٍ ؛ أَنَّہُ لَمْ یَکُنْ یَرَی بِالنَّفْخِ فِی الطَّعَامِ وَالشَّرَابِ بَأْسًا۔,,,24666 24667,حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ؛ أَنَّہُ کَانَ یَنْفُخُ فِی الطَّعَامِ وَالشَّرَابِ۔,,,24667 24668,"حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی الضُّحَی ، عَنْ مَسْرُوقٍ ، قَالَ : أُتِیَ عَبْدُ اللہِ بِشَرَابٍ ، فَقَالَ : نَاوِلْ عَلْقَمَۃَ ، نَاوِلِ الأَسْوَدَ۔",,,24668 24669,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، عَنْ عَبْدِ اللہِ ؛ بِنَحْوٍ مِنْہُ۔,,,24669 24670,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ، عَنِ الأَعْمَشِ ، عَنْ أَبِی الضُّحَی ، عَنْ مَسْرُوقٍ ، قَالَ : أُتِیَ عَبْدُ اللہِ بِشَرَابٍ، فَقَالَ : نَاوِلْ عَلْقَمَۃَ ، نَاوِلِ الأَسْوَدَ۔",,,24670 24671,"حَدَّثَنَا وَکِیعٌ ، عَنْ سَلَمَۃَ بْنِ مُحْرِزٍ ، قَالَ : اسْتَسْقَی طَاوُوسٌ ، فَأُتِیَ بِشَرَابٍ ، فَعَرَضَہُ عَلَی عَبْدِ اللہِ بْنِ الْحَسَنِ ، فَقَالَ : اشْرَبْ۔",,,24671 24672,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ غَیْلاَنَ بْنِ یَزِیدَ ، قَالَ : دُعِیَ أَبُو عُبَیْدَۃَ إِلَی وَلِیمَۃٍ ، فَأُتِیَ بِشَرَابٍ ، فَنَاوَلَ مَنْ عَلَی یَمِینِہِ۔",,,24672 24673,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : أَخْبَرَنِی شُعْبَۃُ ، عَنْ عُمَارَۃَ بْنِ أَبِی حَفْصَۃَ ، عَنْ عِکْرِمَۃَ ، قَالَ : أُتِیَ عُمَرُ بِشَرَابٍ ، وَہُوَ بِالْمَوْقِفِ عَشِیَّۃَ عَرَفَۃَ ، فَشَرِبَ ثُمَّ نَاوَلَ سَیِّدَ أَہْلِ الْیَمَنِ وَہُوَ عَنْ یَمِینِہِ، فَقَالَ: إِنِّی صَائِمٌ، فَقَالَ : عَزَمْتُ عَلَیْکَ إِلاَّ أَفْطَرْتَ وَأَمَرْتَ أَصْحَابَکَ فَأَفْطَرُوا۔",,,24673 24674,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، سَمِعَہُ مِنْ أَنَسٍ ، قَالَ : قدِمَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَأَنَا ابْنُ عَشْرٍ ، وَتُوُفِّیَ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَأَنَا ابْنُ عِشْرِینَ ، وَکُنَّ أُمَّہَاتِی یَحْثُثْنَنِی عَلَی خِدْمَتِہِ ، فَدَخَلَ عَلَیْنَا دَارَنَا، فَحَلَبْنَا لَہُ مِنْ شَاۃٍ دَاجِنٍ لَنَا، وَشِیْبَ لَہُ مِنْ بِئْرٍ فِی الدَّارِ، وَأَبُو بَکْرٍ عَنْ شِمَالِہِ ، وَأَعْرَابِیٌّ عَنْ یَمِینِہِ، وَکَانَ عُمَرُ نَاحِیَۃً ، فَقَالَ عُمَرُ : یَا رَسُولَ اللہِ ، أَعْطِ أَبَا بَکْرٍ ، فَأَعْطَی الأَعْرَابِیَّ ، وَقَالَ : الأَیْمَنُ فَالأَیْمَنُ۔\n\n(مسلم 125۔ مالک 17)",,,24674 24675,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، قَالَتْ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُحِبُّ الْعَسَلَ ، وَیُحِبُّ الْحَلْوَاء ۔ (بخاری 599۔ مسلم 1101)",,,24675 24676,"حَدَّثَنَا وَکِیعٌ ، عَنْ یُونُسَ ، عَنِ الزُّہْرِیِّ ، قَالَ : کَانَ أَحَبَّ الشَّرَابِ إِلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْحُلْوُ الْبَارِدُ۔ (ترمذی 1896)",,,24676 24677,"حَدَّثَنَا وَکِیعٌ، عَنْ شَرِیکٍ، عَنْ عَلِیِّ بْنِ سُلَیْمٍ، قَالَ: سَمِعْتُ أَنَسًا یَقُولُ: إِنِّی لأَشْرَبُ الطِّلاَئَ الْحُلْوَ الْقَارِص۔",,,24677 24678,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سُئِلَ : أَیُّ الشَّرَابِ أَحَبُّ إِلَیْکَ ؟ قَالَ : الْحُلْوُ الْبَارِدُ۔",,,24678 24679,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ دِینَارٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یُنْقَعُ لَہُ الزَّبِیبُ فِی قِرْبَۃٍ عَشِیَّۃً ، فَیَشْرَبُہُ غُدْوَۃً ، وَیُنْقَعُ لَہُ غُدْوَۃً ، فَیَشْرَبُہُ عَشِیَّۃً۔,,,24679 24680,"حَدَّثَنَا وَکِیعٌ ، عَنْ أُمِّ غُرَابٍ ، عَن بُنَانَۃَ ، قَالَتْ : کُنْتُ أَنْقَعُ لِعُثمَانَ الزَّبِیبَ عِشَائً ، فَیَشْرَبُ مِنْہُ ، وَیَأْکُلُ مِنْہُ۔",,,24680 24681,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلُ ، عَنْ جَابِرٍ ، عَنْ مُحَمَّد بن عَلِی ، وَعَامِر ، وَعَطَاء ؛ قَالُوا : لاَ بَأْسَ أَن یُنْقَعُ الزَّبِیبُ غُدْوَۃً ، وَیُشرَبُ عَشِیَّۃً۔",,,24681 24682,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ مُغِیرَۃَ، عَنْ إِبْرَاہِیمَ، قَالَ: لاَ بَأْسَ بِنَقِیعِ الزَّبِیبِ، قَالَ سُفْیَانُ: مَا لَمْ یَغْلِ۔",,,24682 24683,"حَدَّثَنَا وَکِیعٌ ، عَنْ سَلاَّمِ بْنِ مِسْکِینٍ ، عَنِ الْحَسَنِ ، قَالَ : لاَ بَأْسَ بِنَبِیذِ الزَّبِیبِ۔",,,24683 24684,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ مَالِکٍ ، عَنِ الضَّحَّاکِ ، قَالَ مَرَّۃً : عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إِنَّمَا النَّبِیذُ ؛ الَّذِی إِذَا بَلَغَ فَسَدَ ، وَأَمَّا مَا ازْدَادَ عَلَی طُولِ التَّرْکِ جَوْدَۃً ، فَلاَ خَیْرَ فِیہِ۔",,,24684 24685,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ رَجُلٍ ، یُقَالَ لَہُ : عِیسَی ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ؛ مِثْلَہُ۔",,,24685 24686,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَشْعَثَ ، عَنْ أَبِی الشَّعْثَائِ ، عَنْ مُعَاذٍ ، قَالَ : نَہَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ غُبَیْرَائِ السَّکَرِ۔",,,24686 24687,"حَدَّثَنَا وَکِیعٌ ، عَنْ خَارِجَۃَ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، عْن عَطَائِ بْنِ یَسَارٍ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ غُبَیْرَائِ السَّکَرِ۔ (مالک 10)",,,24687 24688,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن ہَمَّامِ بْنِ الْحَارِثِ ، قَالَ : أُتِیَ عُمَرُ بِنَبِیذِ زَبِیبٍ ، فَشَرِبَ مِنْہُ ، فَقَطَّبَ ، فَدَعَا بِمَائٍ فَصَبَّہُ عَلَیْہِ ، ثُمَّ شَرِبَ۔",,,24688 24689,"حَدَّثَنَا وَکِیعٌ، عَنْ مِسْعَرٍ، عَنِ أَبِی عَوْنٍ، قَالَ: أَتَی عُمَرُ قَوْمًا مِنْ ثَقِیفٍ، قَدْ حَضَرَ طَعَامُہُمْ، فَقَالَ: کُلُوا الثَّرِیدَ قَبْلَ اللَّحْمِ ، فَإِنَّہُ یَسُدَّ مَکَانَ الْخَلَلِ ، وَإِذَا اشْتَدَّ نَبِیذُکُمْ فَاکْسِرُوہُ بِالْمَائِ ، وَلاَ تَسْقُوہُ الأَعْرَابَ۔",,,24689 24690,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُمَیَّۃَ ، قَالَتْ : سَمِعْتُ عَائِشَۃَ تَقُولُ : إِنْ خَشِیتَ مِنْ نَبِیذِکَ فَاکْسِرْہُ بِالْمَائِ۔",,,24690 24691,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنْ قُرَّۃَ الْعِجْلِیّ ، عَنْ عَبْدِ الْمَلِکِ بْنِ الْقَعْقَاعِ ، عَنِ ابْنِ عُمَرَ ، قَالَ : کُنَّا عِنْدَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَأُتِیَ بِقَدَحٍ فِیہِ شَرَابٌ ، فَقَرَّبَہُ إِلَی فِیہِ ، ثُمَّ رَدَّہُ ، فَقَالَ لَہُ بَعْضُ جُلَسَائِہِ : أَحَرَامٌ ہُوَ یَا رَسُولَ اللہِ ؟ قَالَ : فَقَالَ : رُدُّوہُ ، فَرَدَّوہُ ، ثُمَّ دَعَا بِمَائٍ فَصَبَّہُ عَلَیْہِ ، ثُمَّ شَرِبَہُ ، فَقَالَ : اُنْظُرُوا ہَذِہِ الأَشْرِبَۃَ ، فَإِذَا اغْتَلَمَتْ عَلَیْکُمْ فَاقْطَعُوا مُتُونَہَا بِالْمَائِ۔",,,24691 24692,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ الْمُبَارَکِ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ سَالِمٍ الدَّوْسِیِّ ؛ أَنَّہُ سَمِعَ أَبَا ہُرَیْرَۃَ یَقُولُ : مَنْ رَابَہُ مِنْ نَبِیذِہِ فَلْیَشُنَّ عَلَیْہِ الْمَائَ ، فَیَذْہَبُ حَرَامُہُ ، وَیَبْقَی حَلاَلُہُ۔",,,24692 24693,"حَدَّثَنَا وَکِیعٌ ، عَنْ عِکْرِمَۃَ بْنِ عَمَّارٍ ، عَنْ أَبِی کَثِیرٍ الْحَنَفِیِّ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : مَنْ رَابَہُ مِنْ شَرَابِہِ شَیْئٌ ، فَلْیَکْسِرْہُ بِالْمَائِ۔",,,24693 24694,"حَدَّثَنَا وَکِیعٌ، عَنْ عَبْدِ الْوَاحِدِ بْنِ أَیْمَنَ، عَنْ أَبِیہِ، عَنْ نَافِعِ بْنِ عَبْدِ الْحَارِثِ ، قَالَ: قَالَ عُمَرُ: اشْرَبُوا ہَذَا النَّبِیذَ فِی ہَذِہِ الأَسْقِیَۃِ ، فَإِنَّہُ یُقِیمُ الصُّلْبَ ، وَیَہْضِمُ مَا فِی الْبَطْنِ ، وَإِنَّہُ لَمْ یَغْلِبْکُمْ مَا وَجَدْتُمُ الْمَائَ۔",,,24694 24695,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنْ مُنْذِرِ بْنِ أَبِی الْمُنْذِرِ ، قَالَ : رَأَیْتُ ابْنَ عَبَّاسٍ یَکْرَعُ فِی حَوْضِ زَمْزَمَ وَہُوَ قَائِمٌ۔",,,24695 24696,حَدَّثَنَا ابْنُ عُلیَّۃ ، عَنْ عُمَارَۃَ ، عَنْ عِکْرِمَۃَ ؛ أَنَّہُ کَرِہَ الْکَرْعَ فِی النَّہَرِ۔,,,24696 24697,"حَدَّثَنَا یُونُسُ بْنُ مُحَمَّدٍ ، عَنْ فُلَیْحِ بْنِ سُلَیْمَانَ ، عَنْ سَعِیدِ بْنِ الْحَارِثِ ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ ، قَالَ: دَخَلَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَلَی رَجُلٍ مِنَ الأَنْصَارِ وَہُوَ یُؤْتِی الْمَائَ فِی حَائِطٍ وَمَعَہُ صَاحِبٌ لَہُ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : ہَلْ عِنْدَکَ مَائٌ بَاتَ فِی ہَذِہِ اللَّیْلَۃِ فِی شَنٍّ ، وَإِلاَّ کَرَعْنا۔\n\n(بخاری 5613۔ ابوداؤد 3717)",,,24697 24698,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ سَعِیدِ بْنِ عَامِرٍ ، عَنِ ابن عُمَرُ ، قَالَ : مَرَرْنَا مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَلَی بِرْکَۃِ مَائٍ ، فَجَعَلْنَا نَکْرَعُ فِیہَا ، فَقَالَ : لاَ تَکْرَعُوا ، وَلَکِنِ اغْسِلُوا أَیْدِیَکُمْ ، وَاشْرَبُوا فِیہَا ، فَإِنَّہُ لَیْسَ مِنْ إِنَائٍ أَطْیَبُ مِنَ الْیَدِ۔ (ابن ماجہ 3433۔ ابویعلی 5675)",,,24698 24699,"حَدَّثَنَا بِشْرُ بْنُ الْمُفَضَّلِ ، عَنْ عَبْدِ اللہِ بْنِ عُثْمَانَ ، قَالَ : أَفَضْتُ مَعَ سَعِیدِ بْنِ جُبَیْرٍ عَشِیَّۃَ النَّحْرِ ، فَأَتَی حَوْضًا فِیہِ مَائُ زَمْزَمَ ، فَغَرَفَ بِیَدِہِ فَشَرِبَ مِنْہُ۔",,,24699 24700,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ؛ أَنَّ أَبَا حُمَیْدٍ أَتَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِشَرَابٍ وَہُوَ بِالْبَقِیعِ ، فَقَالَ : أَلاَ خَمَّرْتَہُ ، وَلَوْ أَنْ تَعْرُضَ عَلَیْہِ عُودًا۔ (نسائی 6633۔ احمد 3/294)",,,24700 24701,"حَدَّثَنَا وَکِیعٌ ، عَنْ فِطْرٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : غَلِّقُوا أَبْوَابَکُمْ ، وَخَمِّرُوا آنِیَتَکُمْ ، وَأَوْکِئُوا أَسْقِیَتکُمْ۔ (احمد 3/301۔ مالک 928)",,,24701 24702,"حَدَّثَنَا وَکِیعٌ ، عَنْ یُونُس ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الْوَدَّاکِ جَبْرِ بْنِ نَوْفٍ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ، قَالَ : کُنَّا نُؤْمَرُ أَنْ نُوْکِِی الأَسْقِیَۃَ۔",,,24702 24703,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَبِیبِ بْنِ جُرَیِّ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُعْجِبُہُ الإِنَائُ الْمُطْبَقُ۔",,,24703 24704,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ أَبِی جَعْفَرٍ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، عَنْ زَاذَانَ ، قَالَ : إِذَا بَاتَ الإِنَائُ غَیْرَ مُخَمَّرٍ تَفَلَ فِیہِ الشَّیْطَانُ ، فَذَکَرْت ذَلِکَ لإِبْرَاہِیمَ فَقَالَ : أَوْ شَرِبَ مِنْہُ۔",,,24704 24705,"حَدَّثَنَا وَکِیعٌ، عَنْ سَلاَّمِ بْنِ الْقَاسِمِ، عَنْ أُمِّہِ، عَنْ أُمِّ سَعِیدٍ، قَالَتْ: أَتَیْتُ عَلِیًّا بِسَحُورٍ، فَوَضَعْتُہُ بَیْنَ یَدَیْہِ وَہُوَ یُصَلِّی ، فَلَمَّا صَلَّی ، قَالَ : ہَلاَّ خَمَّرْتِیہِ ، ہَلْ رَأَیْتِ الشَّیْطَانَ حِینَ وَلَغَ فِیہِ؟ أَہْرِقِیہِ ، وَأَبَی أَنْ یَشْرَبَہُ۔",,,24705 24706,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ ہَارُونَ مَوْلَی قُرَیْشٍ ، قَالَ : رَأَیْتُ الْمُطَّلِبَ بْنَ حَنْطَبٍ یَشْرَبُ سَوِیقَ لَوْزٍ مُمَسَّکٍ۔",,,24706 24707,"حَدَّثَنَا أَبُو أُسَامَۃَ ، وَوَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی الْمُخْتَارِ ، عَنِ ابْنِ أَبِی أَوْفَی ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : سَاقِی الْقَوْمِ آخِرُہُمْ۔ (ابوداؤد 3718۔ احمد 4/354)",,,24707 24708,"حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ ، عَنْ سُلَیْمَانَ بْنِ الْمُغِیرَۃِ ، عَنْ ثَابِتٍ ، عَنْ عَبْدِ اللہِ بْنِ رَبَاحٍ ، عَنْ أَبِی قَتَادَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : سَاقِی الْقَوْمِ آخِرُہُمْ۔ (مسلم 311۔ ترمذی 1894)",,,24708 24709,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُبَارَکٍ ، عَنْ بَکْرِ بْنِ عَبْدِ اللہِ المُزَنِیِّ ، عَنْ عَبْدِ اللہِ بْنِ رَبَاحٍ ، عَنْ أَبِی قَتَادَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : سَاقِی الْقَوْمِ آخِرُہُمْ۔",,,24709 24710,"حدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : لاَ بَأْسَ بِشُرْبِ الْمَائِ الَّذِی یُوضَعُ لِلصَّدَقَۃِ۔",,,24710 24711,"حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ ، قَالَ : حدَّثَنَا عَبْدُ اللہِ بْنُ جَعْفَرٍ ، عَنْ أُمِّ بَکْرٍ ابْنَۃِ الْمِسْوَرِ ، قَالَتْ : کَانَ الْمِسْوَرُ لاَ یَشْرَبُ مِنَ الْمَائِ الَّذِی یُوضَعُ فِی الْمَسْجِدِ ، وَیَکْرَہُہُ ، وَیَرَی أَنَّہُ صَدَقَۃٌ۔",,,24711 24712,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : قَالَ سَعْدُ بْنُ عُبَادَۃَ : یَا رَسُولَ اللہِ ، مُرْنِی بِصَدَقَۃٍ ، قَالَ : اسْقِ الْمَائَ ، قَالَ : فَنَصَبَ سِقَائَیْنِ ، فَلَمْ یَزَالاَ مَنْصُوبَیْنِ ، رُبَّمَا سَعَیْتُ بَیْنَہُمَا وَأَنَا غُلاَمٌ۔\n\n(ابوداؤد 1676۔ احمد 6/7)",,,24712
