hadiths[3]{hadithnumber,text}:
16048,أذعشحأذتشخأثىأذضتىأثڬشۏأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأۄوأهًڲأوزۏىۄأوىًشۄأذتعشأۄًةەأحًأىثۏأ﷽أوىثشأځشأشًىمأتلشًصأحہەأتًشأإځأ﷽أڬەأضتوىەأذعشحأثهتهأشعۏأتههۄأؼىۄأحهًتشأهټڬتةەأڬہڔەأحہەأ؏أتًشأڬډہأڬتهەأدہىڋەأثہۏأىػشأإأشۄەأحہەأ؏أوۏڽأىەأتىأدہىڋًڽأڬەأوحؼهمأځًډہتأحًأهًڲًڽأىەأثحتۏتأڬۄأذعشحأؼوشًأثىأؼتظأشعۏأتههۄأؼىۄأتۏڬأؽصًەأضەأًتځضأإةەأۄۏڽأۗ
16049,"أذعشحأذتشخأثىأذضتىأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأتۏڬأوشحثۄأوۏڽأومتوأشثسۄأوۏڽأتۏڬأثًڔہۏأؼًشحأڬەأځتضأضەأڲسشتأدًأثىًحوۏوأضەأڬټأډڬۏأحہۏأ؏أتضأىەأځًډہتأڬۄأحوأڬۄتڽأدتأشۄەأۄًأآأوۏڽأىەأڬۄتأڬۄأىثۏأ﷽أڬۏأغشلأ؏أًۄأڬۄىەأهڲۏأڬۄأودہەأثہۏأتځىەأضتحہأهەأډهًأ؏أودہەأتىأضەأتۏڬأڬتوأۄەأ؏أوزۏىۄأوىًشۄأځۄىډأڬشأوۏڽأوضدزأىثًۏأوۏڽأزترهأۄًتأحًأىثۏأ﷽أهًڲًڽأوۏڽأڲہشەأۄًةەأحہەأ؏أتًشأتۏڬأضۏتۄأدہىڋتأهۄشتأشۄتأحہتأ؏أوۏڽأىەأهًڲًڽأضەأځًډہتأڬۄأإدأڬًةۏأرتظأثتحأۄەأآأهًڲًڽأىەأثحتۏتأڬۄأزشتظهأىثۏأ﷽أذعشحأؼوشًأثىأؼتظأشعۏأتههۄأؼىۄأڬًأتۏڬأهطڬشأزەأڬشأڬضۏأغشلأشًتىۄألشوتأشۄەأۄۏڽأۗأ أوۏڽأىەأإڲەأثڔہأڬشأؼشعأڬۏتأۏتأشضًهأتههۄأ$أتڲشأإځأوىتضثأضودہۏڽأحًأۄوتشەأتًشأثىًحوۏوأڬەأزشوۏتىأذدتصأڬًأثۏتثتىأمشتشأزەأزۏڽأ؏أڬۏًىڬۄأڬثہۏأتۏضتأۄۏأحہتأ؏أتضأځشأًۄأثڔہۏتأڬًزأڬشأضتوىەأإةۏأتًشأتضأڬۏأشڲأذوۏحأىەأدًطأوتشتأتًشأڬۄىەأهڲۏأۏتأشضًهأتههۄأ$أتځىەأوعشأڬًأإځأڬۄتڽأودثًشأڬشۏڽأڲەأآأوۏڽأىەأؼشعأڬۏتأۏتأشضًهأتههۄأ$أوۏڽأتضأثڔہۏتأڬًأتټہتأڬشأهتۏتأ؏أودہەأڬۏتأرثشأحہۏأڬۄأۏۄۏأودہأضەأدہڲڔىەأهڲەأڲۏأ؏أوۏڽأتههۄأڬۏأځىتۄأوۏڽأإحتأۄًڽأتضأثتحأضەأڬۄأتضأطرظأڬۏأغشذأۄًأدتاڽأدۏضەأځۄهًڽأىەأڬۄتأحہتأ؏أىثۏأ﷽أىەأځًډہتأځۄهًڽأىەأڬۏتأڬۄتأحہتأآأوۏڽأىەأؼشعأڬۏتأڬۄأإځأىەأتۏڬأثترثشأإزوۏأضەأځًډہتأ؏أۏۄأدوهۄأضىأڬشأضهتوأڬۄىەأهڲەأڬۄأۏۄأتذومأإزوۏأۄەأ؏أىثۏأ﷽أضەأڬۄۄأشۄتأۄەأڬۄأإځأىەأتۏڬأثتأرثشأإزوۏأضەأځًډہتأ؏أهۏڬىأىثۏأ﷽أىەألشوتۏتأحوأثۏتىأڬشًأ؏أزشتظهأىثۏأ﷽أځًشۏأثتحأضىىتأډتۄحەأحہەأۗأ
أوۏڽأىەأؼشعأڬۏتأڬۄأمًوأؼتزأىەأتځىەأتۏڬأإزوۏأمۏهأڬًأثغًشأًلزأڬەأڬًأثہۏدتأ؏أًۄأتۏڬأوۄۏىەأحڬأوؼتًۏۄأثىأثڬشأڬتأوۄوتىأثىتأشۄتأ؏أًۄأتىۄۏڽأطشتثأځهتحتأحہتأ؏أتًشأڋًوىۏًڽأضەأڲتىەأضىًتحتأحہتأ؏أتۏڬأزىأًۄأشًتىۄأۄًتأتًشأ““أدثتهأوۄشۄأ‛‛أځشأځۄىډتأتًشأڬۄىەأهڲتأتەأتههۄأ$أوۏڽأتضأهةەأىۄۏڽأإۏتأڬۄأتضأڬتأثزهۄأډڬتاڽأ؏أىۄأڬضۏأثۏوتشأڬەأهةەأڬۄأتضأڬتأؼهتدأڬشأضڬًڽأ؏أهۄستأحًأتځىەأثىزەأڬًأًۄأڬډہأځهتأدًأحًأځهتأضڬحتأۄەأ؏أتًشأوؼتًۏۄأثىأثڬشأڬًأتۏڬأوتۄأحڬأځهتىەأڬتأتىحػتوألشوتأ؏أزشتظهأۏۄأتضأطشتثأڬتأطڬشۏۄأحہتأدًأًۄأتضأڬەأۏۄتڽأتۏڬأوۄۏىۄأحڬأځۏحتأشۄتأحہتأ؏أتضۏأتخىتؤأوۏڽأضۏتۄأثتزهأإأڲةەأتًشأڬضۏأىەأإًتصأزەأڬشأڬۄتأڬۄأۏۄأرًثأثہشەأۄًةەأحہىأًتهتأثتزهأهەأهًأتًشأمًوأؼتزأوۏڽأڬضۏأتۏڬأطرظأڬًأثہۏأ+أځۏتضتأ,أىۄأډہًڔًأۗ"
16050,"أذعشحأذتشخأثىأذضتىأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأتۏڬأوشحثۄأوۏڽأومتوأشثسۄأوۏڽأتۏڬأثًڔہۏأؼًشحأڬەأځتضأضەأڲسشتأدًأثىًحوۏوأضەأڬټأډڬۏأحہۏأ؏أتضأىەأځًډہتأڬۄأحوأڬۄتڽأدتأشۄەأۄًأآأوۏڽأىەأڬۄتأڬۄأىثۏأ﷽أڬۏأغشلأ؏أًۄأڬۄىەأهڲۏأڬۄأودہەأثہۏأتځىەأضتحہأهەأډهًأ؏أودہەأتىأضەأتۏڬأڬتوأۄەأ؏أوزۏىۄأوىًشۄأځۄىډأڬشأوۏڽأوضدزأىثًۏأوۏڽأزترهأۄًتأحًأىثۏأ﷽أهًڲًڽأوۏڽأڲہشەأۄًةەأحہەأ؏أتًشأتۏڬأضۏتۄأدہىڋتأهۄشتأشۄتأحہتأ؏أوۏڽأىەأهًڲًڽأضەأځًډہتأڬۄأإدأڬًةۏأرتظأثتحأۄەأآأهًڲًڽأىەأثحتۏتأڬۄأزشتظهأىثۏأ﷽أذعشحأؼوشًأثىأؼتظأشعۏأتههۄأؼىۄأڬًأتۏڬأهطڬشأزەأڬشأڬضۏأغشلأشًتىۄألشوتأشۄەأۄۏڽأۗأ أوۏڽأىەأإڲەأثڔہأڬشأؼشعأڬۏتأۏتأشضًهأتههۄأ$أتڲشأإځأوىتضثأضودہۏڽأحًأۄوتشەأتًشأثىًحوۏوأڬەأزشوۏتىأذدتصأڬًأثۏتثتىأمشتشأزەأزۏڽأ؏أڬۏًىڬۄأڬثہۏأتۏضتأۄۏأحہتأ؏أتضأځشأًۄأثڔہۏتأڬًزأڬشأضتوىەأإةۏأتًشأتضأڬۏأشڲأذوۏحأىەأدًطأوتشتأتًشأڬۄىەأهڲۏأۏتأشضًهأتههۄأ$أتځىەأوعشأڬًأإځأڬۄتڽأودثًشأڬشۏڽأڲەأآأوۏڽأىەأؼشعأڬۏتأۏتأشضًهأتههۄأ$أوۏڽأتضأثڔہۏتأڬًأتټہتأڬشأهتۏتأ؏أودہەأڬۏتأرثشأحہۏأڬۄأۏۄۏأودہأضەأدہڲڔىەأهڲەأڲۏأ؏أوۏڽأتههۄأڬۏأځىتۄأوۏڽأإحتأۄًڽأتضأثتحأضەأڬۄأتضأطرظأڬۏأغشذأۄًأدتاڽأدۏضەأځۄهًڽأىەأڬۄتأحہتأ؏أىثۏأ﷽أىەأځًډہتأځۄهًڽأىەأڬۏتأڬۄتأحہتأآأوۏڽأىەأؼشعأڬۏتأڬۄأإځأىەأتۏڬأثترثشأإزوۏأضەأځًډہتأ؏أۏۄأدوهۄأضىأڬشأضهتوأڬۄىەأهڲەأڬۄأۏۄأتذومأإزوۏأۄەأ؏أىثۏأ﷽أضەأڬۄۄأشۄتأۄەأڬۄأإځأىەأتۏڬأثترثشأإزوۏأضەأځًډہتأ؏أهۏڬىأىثۏأ﷽أىەألشوتۏتأحوأثۏتىأڬشًأ؏أزشتظهأىثۏأ﷽أځًشۏأثتحأضىىتأډتۄحەأحہەأۗأ
وۏڽأىەأؼشعأڬۏتأڬۄأمًوأؼتزأىەأتځىەأتۏڬأإزوۏأمۏهأڬًأثغًشأًلزأڬەأڬًأثہۏدتأ؏أًۄأتۏڬأوۄۏىەأحڬأوؼتًۏۄأثىأثڬشأڬتأوۄوتىأثىتأشۄتأ؏أًۄأتىۄۏڽأطشتثأځهتحتأحہتأ؏أتًشأڋًوىۏًڽأضەأڲتىەأضىًتحتأحہتأ؏أتۏڬأزىأًۄأشًتىۄأۄًتأتًشأ““أدثتهأوۄشۄأ‛‛أځشأځۄىډتأتًشأڬۄىەأهڲتأتەأتههۄأ$أوۏڽأتضأهۏەأىۄۏڽأإۏتأڬۄأتضأڬتأثزهۄأډڬتاڽأ؏أىۄأڬضۏأثۏوتشأڬەأهۏەأڬۄأتضأڬتأؼهتدأڬشأضڬًڽأ؏أهۄستأحًأتځىەأثىزەأڬًأًۄأڬډہأځهتأدًأحًأځهتأضڬحتأۄەأ؏أتًشأوؼتًۏۄأثىأثڬشأڬًأتۏڬأوتۄأحڬأځهتىەأڬتأتىحػتوألشوتأ؏أزشتظهأۏۄأتضأطشتثأڬتأطڬشۏۄأحہتأدًأًۄأتضأڬەأۏۄتڽأتۏڬأوۄۏىۄأحڬأځۏحتأشۄتأحہتأ؏أتضۏأتخىتؤأوۏڽأضۏتۄأثتزهأإأڲةەأتًشأڬضۏأىەأإًتصأزەأڬشأڬۄتأڬۄأۏۄأرًثأثہشەأۄًةەأحہىأًتهتأثتزهأهەأهًأتًشأمًوأؼتزأوۏڽأڬضۏأتۏڬأطرظأڬًأثہۏأ+أځۏتضتأ,أىۄأډہًڔًأۗ"
