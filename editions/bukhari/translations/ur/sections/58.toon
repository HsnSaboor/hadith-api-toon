{"hadithnumber": "3157", "text": "لیکن جب عبدالرحمٰن بن عوف رضی اللہ عنہ نے گواہی دی کہ رسول اللہ صلی اللہ علیہ وسلم نے ہجر کے پارسیوں"}
{"hadithnumber": "3158", "text": "ہم سے ابوالیمان نے بیان کیا، انہوں نے کہا ہم کو شعیب نے خبر دی، انہیں زہری نے کہا کہ مجھ سے عروہ بن"}
{"hadithnumber": "3160", "text": "نعمان رضی اللہ عنہ نے کہا  تم کو تو اللہ پاک ایسی کئی لڑائیوں میں نبی کریم صلی اللہ علیہ وسلم کے سات"}
{"hadithnumber": "3161", "text": "ہم سے سہل بن بکار نے بیان کیا، کہا ہم سے وہیب نے بیان کیا، ان سے عمرو بن یحییٰ نے، ان سے عباس ساعدی"}
{"hadithnumber": "3162", "text": "ہم سے آدم بن ابی ایاس نے بیان کیا، کہا ہم سے شعبہ نے بیان کیا، کہا ہم سے ابوجمرہ نے بیان کیا، کہا کہ"}
{"hadithnumber": "3163", "text": "ہم سے احمد بن یونس نے بیان کیا، کہا ہم سے زہیر نے بیان کیا، ان سے یحییٰ بن سعید انصاری نے بیان کیا ک"}
{"hadithnumber": "3165", "text": "اور ابراہیم بن طہمان نے بیان کیا، ان سے عبدالعزیز بن صہیب نے اور ان سے انس بن مالک رضی اللہ عنہ نے ک"}
{"hadithnumber": "3166", "text": "ہم سے قیس بن حفص نے بیان کیا، انہوں نے کہا ہم سے عبدالواحد نے بیان کیا، انہوں نے کہا ہم سے حسن بن عم"}
{"hadithnumber": "3167", "text": "ہم سے عبداللہ بن یوسف نے بیان کیا، کہا ہم سے لیث بن سعد نے بیان کیا، کہا کہ مجھ سے سعد مقبری نے بیان"}
{"hadithnumber": "3168", "text": "ہم سے محمد بن سلام نے بیان کیا، ان سے سفیان بن عیینہ نے بیان کیا، ان سے سلیمان احول نے، انہوں نے سعی"}
{"hadithnumber": "3169", "text": "ہم سے عبداللہ بن یوسف نے بیان کیا، کہا ہم سے لیث بن سعد نے بیان کیا، کہا کہ مجھ سے سعید مقبری نے بیا"}
{"hadithnumber": "3170", "text": "ہم سے ابوالنعمان نے بیان کیا، کہا ہم سے ثابت بن یزید نے بیان کیا، ہم سے عاصم احول نے، کہا کہ  میں نے"}
{"hadithnumber": "3171", "text": "ہم سے عبداللہ بن یوسف نے بیان کیا، کہا ہم کو امام مالک نے خبر دی، انہیں عمرو بن عبداللہ کے غلام ابوا"}
{"hadithnumber": "3172", "text": "مجھ سے محمد بن سلام نے بیان کیا، کہا ہم کو وکیع نے خبر دی، انہیں اعمش نے، انہیں ابراہیم تیمی نے، ان"}
{"hadithnumber": "3173", "text": "ہم سے مسدد بن مسرہد نے بیان کیا، کہا ہم سے بشر بن مفضل نے، کہا ہم سے یحییٰ بن سعید انصاری نے، ان سے"}
{"hadithnumber": "3174", "text": "ہم سے یحییٰ بن بکیر نے بیان کیا، کہا ہم سے لیث بن سعد نے بیان کیا، ان سے یونس نے، ان سے ابن شہاب نے،"}
{"hadithnumber": "3175", "text": "مجھ سے محمد بن مثنیٰ نے بیان کیا، کہا ہم سے یحییٰ نے بیان کیا، کہا ہم سے ہشام نے بیان کیا، کہا کہ مج"}
{"hadithnumber": "3176", "text": "مجھ سے حمیدی نے بیان کیا، کہا ہم سے ولید بن مسلم نے بیان کیا، کہا ہم سے عبداللہ بن علاء بن زبیر نے ب"}
{"hadithnumber": "3177", "text": "ہم سے ابوالیمان نے بیان کیا، کہا ہم کو شعیب نے خبر دی، انہیں زہری نے، انہیں حمید بن عبدالرحمٰن نے کہ"}
{"hadithnumber": "3178", "text": "ہم سے قتیبہ بن سعید نے بیان کیا، کہا ہم سے جریر نے بیان کیا، ان سے اعمش نے، ان سے عبداللہ بن مرہ نے،"}
{"hadithnumber": "3179", "text": "ہم سے محمد بن کثیر نے بیان کیا، کہا ہم کو سفیان ثوری نے خبر دی، انہیں اعمش نے، انہیں ابراہیم تیمی نے"}
{"hadithnumber": "3180", "text": "ابوموسیٰ (محمد بن مثنیٰ) نے بیان کیا کہ ہم سے ہاشم بن قاسم نے بیان کیا، ان سے اسحاق بن سعید نے بیان"}
{"hadithnumber": "3181", "text": "ہم سے عبدان نے بیان کیا، کہا ہم کو ابوحمزہ نے خبر دی، کہا کہ میں نے اعمش سے سنا، انہوں نے بیان کیا ک"}
{"hadithnumber": "3182", "text": "ہم سے عبداللہ بن محمد نے بیان کیا، کہا ہم سے یحییٰ بن آدم نے، ان سے یزید بن عبدالعزیز نے، ان سے ان ک"}
{"hadithnumber": "3183", "text": "ہم سے قتیبہ بن سعید نے بیان کیا، کہا ہم سے حاتم نے بیان کیا، ان سے ہشام بن عروہ نے، ان سے ان کے باپ"}
{"hadithnumber": "3184", "text": "ہم سے احمد بن عثمان بن حکیم نے بیان کیا، کہا ہم سے شریح بن مسلمہ نے بیان کیا، کہا ہم سے ابراہیم بن ی"}
{"hadithnumber": "3185", "text": "ہم سے عبدان بن عثمان نے بیان کیا، انہوں نے کہا کہ مجھے میرے باپ نے خبر دی، انہیں شعبہ نے، انہیں ابوا"}
{"hadithnumber": "3186", "text": "ہم سے ابوالولید نے بیان کیا، کہا ہم سے شعبہ نے بیان کیا، ان سے سلیمان اعمش نے، ان سے ابووائل نے اور"}
{"hadithnumber": "3188", "text": "ہم سے سلیمان بن حرب نے بیان کیا، کہا ہم سے حماد نے بیان کیا، ان سے ایوب نے، ان سے نافع نے اور ان سے"}
{"hadithnumber": "3189", "text": "ہم سے علی بن عبداللہ نے بیان کیا، کہا ہم سے جریر نے بیان کیا، ان سے منصور نے، ان سے مجاہد نے، ان سے"}
