metadata:

hadiths[286]{hadithnumber,arabic,bengali,english,french,indonesian,russian,urdu,grades,reference,international_number,narrator_chain,chapter_intro}:
{"hadithnumber": "3673", "arabic": "حَدَّثَنَا يَحْيَى بْنُ يَحْيَى التَّمِيمِيُّ، قَالَ قَرَأْتُ عَلَى مَالِكٍ عَنْ مُحَمَّدِ بْنِ يَحْيَى بْنِ، حَبَّانَ عَنِ الأَعْرَجِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم نَهَى عَنِ الْمُلاَمَسَةِ وَالْمُنَابَذَةِ ‏.‏", "bengali": "", "english": "Abu Huraira (Allah be pleased with him) reported that Allah's Messenger (ﷺ) forbade (two types of transactions) Mulamasa and Munabadha", "french": "", "indonesian": "", "russian": "", "urdu": "معمر نے ہمیں ابن طاوس سے خبر دی ،  انہوں نے اپنے والد  ( طاوس بن کیسان )  سے ،  انہوں نے حضرت ابن عب", "grades": "", "reference": "", "international_number": "3673", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3674", "arabic": "وَحَدَّثَنَا أَبُو كُرَيْبٍ، وَابْنُ أَبِي عُمَرَ، قَالاَ حَدَّثَنَا وَكِيعٌ، عَنْ سُفْيَانَ، عَنْ أَبِي الزِّنَادِ، عَنِ الأَعْرَجِ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم مِثْلَهُ ‏.‏", "bengali": "", "english": "Abu Huraira (Allah be pleased with him) reported like this from Allah's Messenger (ﷺ).", "french": "", "indonesian": "", "russian": "", "urdu": "ابن جریج نے ہمیں خبر دی ،  کہا :  مجھے ابن طاوس نے اپنے والد  ( طاوس بن کیسان )  سے خبر دی کہ ابوصبہ", "grades": "", "reference": "", "international_number": "3674", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3675", "arabic": "وَحَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا ابْنُ نُمَيْرٍ، وَأَبُو أُسَامَةَ ح وَحَدَّثَنَا مُحَمَّدُ، بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ حَدَّثَنَا أَبِي ح، وَحَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، حَدَّثَنَا عَبْدُ الْوَهَّابِ، كُلُّهُمْ عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ خُبَيْبِ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ حَفْصِ بْنِ عَاصِمٍ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم بِمِثْلِهِ ‏.‏", "bengali": "", "english": "Abu Huraira reported from Allah's Messenger (ﷺ) a hadith like this through another chain cf transmitters.", "french": "", "indonesian": "", "russian": "", "urdu": "ابراہیم بن میسرہ نے طاوس سے روایت کی کہ ابوصبہاء نے حضرت ابن عباس رضی اللہ عنہ سے عرض کی :  آپ اپنے", "grades": "", "reference": "", "international_number": "3675", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3676", "arabic": "وَحَدَّثَنَا قُتَيْبَةُ بْنُ سَعِيدٍ، حَدَّثَنَا يَعْقُوبُ، - يَعْنِي ابْنَ عَبْدِ الرَّحْمَنِ - عَنْ سُهَيْلِ، بْنِ أَبِي صَالِحٍ عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم ‏.‏ مِثْلَهُ ‏.‏", "bengali": "", "english": "A hadith like this has been narrated on the authority of Abu Huraira (Allah be pleased with him) through another chain of transmitters.", "french": "", "indonesian": "", "russian": "", "urdu": "ہشام ،  یعنی دستوائی  ( کپڑے والے )  سے روایت ہے ،  انہوں نے کہا :  مجھے یحییٰ بن کثیر نے یعلیٰ بن ح", "grades": "", "reference": "", "international_number": "3676", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3677", "arabic": "وَحَدَّثَنِي مُحَمَّدُ بْنُ رَافِعٍ، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَخْبَرَنَا ابْنُ جُرَيْجٍ، أَخْبَرَنِي عَمْرُو، بْنُ دِينَارٍ عَنْ عَطَاءِ بْنِ مِينَاءَ، أَنَّهُ سَمِعَهُ يُحَدِّثُ، عَنْ أَبِي هُرَيْرَةَ، أَنَّهُ قَالَ نُهِيَ عَنْ بَيْعَتَيْنِ، الْمُلاَمَسَةِ وَالْمُنَابَذَةِ ‏.‏ أَمَّا الْمُلاَمَسَةُ فَأَنْ يَلْمِسَ كُلُّ وَاحِدٍ مِنْهُمَا ثَوْبَ صَاحِبِهِ بِغَيْرِ تَأَمُّلٍ وَالْمُنَابَذَةُ أَنْ يَنْبِذَ كُلُّ وَاحِدٍ مِنْهُمَا ثَوْبَهُ إِلَى الآخَرِ وَلَمْ يَنْظُرْ وَاحِدٌ مِنْهُمَا إِلَى ثَوْبِ صَاحِبِهِ‏.‏", "bengali": "", "english": "Two types of trarisactions have been forbidden (by the Holy Prophet), al-Mlulamasa and al-Munabadha. As far as Mulamasa transaction is concerned, it is that every one of them (the parties entering into transaction) should touch the garment of the other without careful consideration, and al-Munabadha is that every one of them should throw his cloth to the other and one of them should not see the cloth of his friend.", "french": "", "indonesian": "", "russian": "", "urdu": "معاویہ بن سلام نے ہمیں یحییٰ بن ابی کثیر سے حدیث بیان کی کہ یعلیٰ بن حکیم نے انہیں خبر دی ،  انہیں س", "grades": "", "reference": "", "international_number": "3677", "narrator_chain": "Abu Huraira (Allah be pleased with him) reported:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3678", "arabic": "وَحَدَّثَنِي أَبُو الطَّاهِرِ، وَحَرْمَلَةُ بْنُ يَحْيَى، - وَاللَّفْظُ لِحَرْمَلَةَ - قَالاَ أَخْبَرَنَا ابْنُ، وَهْبٍ أَخْبَرَنِي يُونُسُ، عَنِ ابْنِ شِهَابٍ، أَخْبَرَنِي عَامِرُ بْنُ سَعْدِ بْنِ أَبِي وَقَّاصٍ، أَنَّ أَبَا سَعِيدٍ، الْخُدْرِيَّ قَالَ نَهَانَا رَسُولُ اللَّهِ صلى الله عليه وسلم عَنْ بَيْعَتَيْنِ وَلِبْسَتَيْنِ نَهَى عَنِ الْمُلاَمَسَةِ وَالْمُنَابَذَةِ فِي الْبَيْعِ ‏.‏ وَالْمُلاَمَسَةُ لَمْسُ الرَّجُلِ ثَوْبَ الآخَرِ بِيَدِهِ بِاللَّيْلِ أَوْ بِالنَّهَارِ وَلاَ يَقْلِبُهُ إِلاَّ بِذَلِكَ وَالْمُنَابَذَةُ أَنْ يَنْبِذَ الرَّجُلُ إِلَى الرَّجُلِ بِثَوْبِهِ وَيَنْبِذَ الآخَرُ إِلَيْهِ ثَوْبَهُ وَيَكُونُ ذَلِكَ بَيْعَهُمَا مِنْ غَيْرِ نَظَرٍ وَلاَ تَرَاضٍ ‏.‏", "bengali": "", "english": "Allah's Messenger (ﷺ) forbade us (from), two types of business transactions and two ways of dressing. He forbade Mulamasa and Munabadha in transactions. Mulamasa means the touching of another's garment with his hand, whether at night or by day, without turning it over except this much. Munabadha means that a man throws his garment to another and the other throws his garment, and thus confirming their contract without the inspection of mutual agreement.", "french": "", "indonesian": "", "russian": "", "urdu": "عبید بن عمیر نے خبر دی کہ انہوں نے حضرت عائشہ رضی اللہ عنہا سے سنا ،  وہ بتا رہی تھیں کہ نبی صلی الل", "grades": "", "reference": "", "international_number": "3678", "narrator_chain": "Abu Sa'id al-Khudri (Allah be pleased with him) reported:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3679", "arabic": "وَحَدَّثَنِيهِ عَمْرٌو النَّاقِدُ، حَدَّثَنَا يَعْقُوبُ بْنُ إِبْرَاهِيمَ بْنِ سَعْدٍ، حَدَّثَنَا أَبِي، عَنْ صَالِحٍ، عَنِ ابْنِ شِهَابٍ، بِهَذَا الإِسْنَادِ ‏.‏", "bengali": "", "english": "This hadith has been narrated on the authority of Ibn Shihab through the same chain of transmitters.", "french": "", "indonesian": "", "russian": "", "urdu": "ابواسامہ نے ہمیں ہشام سے حدیث بیان کی ،  انہوں نے اپنے والد  ( عروہ )  سے اور انہوں نے حضرت عائشہ رض", "grades": "", "reference": "", "international_number": "3679", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3680", "arabic": "وَحَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ إِدْرِيسَ، وَيَحْيَى بْنُ سَعِيدٍ، وَأَبُو أُسَامَةَ عَنْ عُبَيْدِ اللَّهِ، ح وَحَدَّثَنِي زُهَيْرُ بْنُ حَرْبٍ، - وَاللَّفْظُ لَهُ - حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، عَنْ عُبَيْدِ اللَّهِ، حَدَّثَنِي أَبُو الزِّنَادِ، عَنِ الأَعْرَجِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم عَنْ بَيْعِ الْحَصَاةِ وَعَنْ بَيْعِ الْغَرَرِ ‏.‏", "bengali": "", "english": "Abu Huraira (Allah be pleased with him) reported that Allah's Messenger (ﷺ) forbade a transaction determined by throwing stones, and the type which involves some uncertainty.", "french": "", "indonesian": "", "russian": "", "urdu": "علی بن مسہر نے ہشام بن عروہ سے اسی سند کے ساتھ اسی کے ہم معنی حدیث بیان کی", "grades": "", "reference": "", "international_number": "3680", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3681", "arabic": "حَدَّثَنَا يَحْيَى بْنُ يَحْيَى، وَمُحَمَّدُ بْنُ رُمْحٍ، قَالاَ أَخْبَرَنَا اللَّيْثُ، ح وَحَدَّثَنَا قُتَيْبَةُ بْنُ، سَعِيدٍ حَدَّثَنَا لَيْثٌ، عَنْ نَافِعٍ، عَنْ عَبْدِ اللَّهِ، عَنْ رَسُولِ اللَّهِ صلى الله عليه وسلم أَنَّهُ نَهَى عَنْ بَيْعِ حَبَلِ الْحَبَلَةِ ‏.‏", "bengali": "", "english": "'Abdullah (b. 'Umar) (Allah be pleased with him) said that Allah's Messenger (ﷺ) forbade the transaction called habal al-habala.", "french": "", "indonesian": "", "russian": "", "urdu": "ابن شہاب سے روایت ہے ،  کہا :  مجھے ابوسلمہ بن عبدالرحمٰن نے خبر دی کہ عائشہ رضی اللہ عنہا نے کہا :", "grades": "", "reference": "", "international_number": "3681", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3682", "arabic": "حَدَّثَنِي زُهَيْرُ بْنُ حَرْبٍ، وَمُحَمَّدُ بْنُ الْمُثَنَّى، - وَاللَّفْظُ لِزُهَيْرٍ - قَالاَ حَدَّثَنَا يَحْيَى، - وَهُوَ الْقَطَّانُ - عَنْ عُبَيْدِ اللَّهِ، أَخْبَرَنِي نَافِعٌ، عَنِ ابْنِ عُمَرَ، قَالَ كَانَ أَهْلُ الْجَاهِلِيَّةِ يَتَبَايَعُونَ لَحْمَ الْجَزُورِ إِلَى حَبَلِ الْحَبَلَةِ ‏.‏ وَحَبَلُ الْحَبَلَةِ أَنْ تُنْتَجَ النَّاقَةُ ثُمَّ تَحْمِلَ الَّتِي نُتِجَتْ فَنَهَاهُمْ رَسُولُ اللَّهِ صلى الله عليه وسلم عَنْ ذَلِكَ ‏.‏", "bengali": "", "english": "Ibn 'Umar (Allah be pleased with them) reported that the people of pre-Islamic days used to sell the meat of the slaughtered camel up to habal al-habala. And habal al-habala implies that a she-camel should give birth and then the (born one should grow young) and become pregnant. Allah's Messenger (ﷺ) forbade them that (this transaction).", "french": "", "indonesian": "", "russian": "", "urdu": "عباد بن عباد نے ہمیں عاصم سے حدیث بیان کی ،  انہوں نے معاذ عدویہ سے ،  انہوں نے حضرت عائشہ رضی اللہ", "grades": "", "reference": "", "international_number": "3682", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3683", "arabic": "حَدَّثَنَا يَحْيَى بْنُ يَحْيَى، قَالَ قَرَأْتُ عَلَى مَالِكٍ عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ لاَ يَبِعْ بَعْضُكُمْ عَلَى بَيْعِ بَعْضٍ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "One amongst you should not enter into a transaction when another is bargaining.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Ibn 'Umar (Allah be pleased with them) reported Allah's Messenger (ﷺ) as having said this:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3684", "arabic": "حَدَّثَنَا زُهَيْرُ بْنُ حَرْبٍ، وَمُحَمَّدُ بْنُ الْمُثَنَّى، - وَاللَّفْظُ لِزُهَيْرٍ - قَالاَ حَدَّثَنَا يَحْيَى، عَنْ عُبَيْدِ اللَّهِ، أَخْبَرَنِي نَافِعٌ، عَنِ ابْنِ عُمَرَ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ لاَ يَبِعِ الرَّجُلُ عَلَى بَيْعِ أَخِيهِ وَلاَ يَخْطُبْ عَلَى خِطْبَةِ أَخِيهِ إِلاَّ أَنْ يَأْذَنَ لَهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "A person should not enter into a transaction when his brother is already making a transaction and he should not make a proposal of marriage when his brother has already made a proposal except when he gives permission.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Ibn 'Umar (Allah be pleased with them) reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3685", "arabic": "حَدَّثَنَا يَحْيَى بْنُ أَيُّوبَ، وَقُتَيْبَةُ بْنُ سَعِيدٍ، وَابْنُ، حُجْرٍ قَالُوا حَدَّثَنَا إِسْمَاعِيلُ، - وَهُوَ ابْنُ جَعْفَرٍ - عَنِ الْعَلاَءِ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ لاَ يَسُمِ الْمُسْلِمُ عَلَى سَوْمِ أَخِيهِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "A Muslim should not purchase (in opposition) to his brother.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3686", "arabic": "وَحَدَّثَنِيهِ أَحْمَدُ بْنُ إِبْرَاهِيمَ الدَّوْرَقِيُّ، حَدَّثَنِي عَبْدُ الصَّمَدِ، حَدَّثَنَا شُعْبَةُ، عَنِ الْعَلاَءِ، وَسُهَيْلٍ عَنْ أَبِيهِمَا، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم ح. وَحَدَّثَنَاهُ مُحَمَّدُ بْنُ الْمُثَنَّى، حَدَّثَنَا عَبْدُ الصَّمَدِ، حَدَّثَنَا شُعْبَةُ، عَنِ الأَعْمَشِ، عَنْ أَبِي، صَالِحٍ عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم ح. وَحَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ مُعَاذٍ، حَدَّثَنَا أَبِي، حَدَّثَنَا شُعْبَةُ، عَنْ عَدِيٍّ، - وَهُوَ ابْنُ ثَابِتٍ - عَنْ أَبِي حَازِمٍ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم نَهَى أَنْ يَسْتَامَ الرَّجُلُ عَلَى سَوْمِ أَخِيهِ ‏.‏ وَفِي رِوَايَةِ الدَّوْرَقِيِّ عَلَى سِيمَةِ أَخِيهِ ‏.‏\"", "bengali": "", "english": "This hadith has been narrated on the authority of Abu Huraira through another chain of transmitters but with a slight change of words.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3687", "arabic": "حَدَّثَنَا يَحْيَى بْنُ يَحْيَى، قَالَ قَرَأْتُ عَلَى مَالِكٍ عَنْ أَبِي الزِّنَادِ، عَنِ الأَعْرَجِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ لاَ يُتَلَقَّى الرُّكْبَانُ لِبَيْعٍ وَلاَ يَبِعْ بَعْضُكُمْ عَلَى بَيْعِ بَعْضٍ وَلاَ تَنَاجَشُوا وَلاَ يَبِعْ حَاضِرٌ لِبَادٍ وَلاَ تُصَرُّوا الإِبِلَ وَالْغَنَمَ فَمَنِ ابْتَاعَهَا بَعْدَ ذَلِكَ فَهُوَ بِخَيْرِ النَّظَرَيْنِ بَعْدَ أَنْ يَحْلُبَهَا فَإِنْ رَضِيَهَا أَمْسَكَهَا وَإِنْ سَخِطَهَا رَدَّهَا وَصَاعًا مِنْ تَمْرٍ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "Do not go out to meet riders to enter into transaction with them; none of you must buy in opposition to another, nor must you bid against one another; a townsman must not sell for a man from the desert, and do not tie up udders of carnels and sheep, and he who buys them after that has been done has two courses open to him: after he has milked them he may keep them if he is pleased with them, or he may return them along with a sit of dates if he is displeased with them.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira reported Allah's Messenger (may peace'be upon him) as saying:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3688", "arabic": "حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ مُعَاذٍ الْعَنْبَرِيُّ، حَدَّثَنَا أَبِي، حَدَّثَنَا شُعْبَةُ، عَنْ عَدِيٍّ، - وَهُوَ ابْنُ ثَابِتٍ - عَنْ أَبِي حَازِمٍ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم نَهَى عَنِ التَّلَقِّي لِلرُّكْبَانِ وَأَنْ يَبِيعَ حَاضِرٌ لِبَادٍ وَأَنْ تَسْأَلَ الْمَرْأَةُ طَلاَقَ أُخْتِهَا وَعَنِ النَّجْشِ وَالتَّصْرِيَةِ وَأَنْ يَسْتَامَ الرَّجُلُ عَلَى سَوْمِ أَخِيهِ ‏.‏", "bengali": "", "english": "Abu Huraira (Allah be pleased with him) reported that Allah's Messenger (ﷺ) forbade the (people) meeting the caravan (for entering into business transaction with them), and the selling of goods by a townsman on behalf of a man of the desert, and seeking by a woman the divorce of her sister (from her husband), and outbidding (against one another), and tying up the udders (of animals), and buying of (things) in opposition to one's brother.", "french": "", "indonesian": "", "russian": "", "urdu": "ابومعاویہ نے اعمش سے ،  انہوں نے مسلم سے ،  انہوں نے مسروق سے اور انہوں نے حضرت عائشہ رضی اللہ عنہا", "grades": "", "reference": "", "international_number": "3688", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3689", "arabic": "وَحَدَّثَنِيهِ أَبُو بَكْرِ بْنُ نَافِعٍ، حَدَّثَنَا غُنْدَرٌ، ح وَحَدَّثَنَاهُ مُحَمَّدُ بْنُ الْمُثَنَّى، حَدَّثَنَا وَهْبُ، بْنُ جَرِيرٍ ح وَحَدَّثَنَا عَبْدُ الْوَارِثِ بْنُ عَبْدِ الصَّمَدِ، حَدَّثَنَا أَبِي قَالُوا، جَمِيعًا حَدَّثَنَا شُعْبَةُ، بِهَذَا الإِسْنَادِ ‏.‏ فِي حَدِيثِ غُنْدَرٍ وَوَهْبٍ نُهِيَ ‏.‏ وَفِي حَدِيثِ عَبْدِ الصَّمَدِ أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم نَهَى ‏.‏ بِمِثْلِ حَدِيثِ مُعَاذٍ عَنْ شُعْبَةَ ‏.‏", "bengali": "", "english": "This hadith has been narrated through another chain of transmitters.", "french": "", "indonesian": "", "russian": "", "urdu": "اسماعیل بن زکریا نے ہمیں حدیث بیان کی ،  کہا :  ہمیں اعمش نے ابراہیم سے حدیث بیان کی ،  انہوں نے اسو", "grades": "", "reference": "", "international_number": "3689", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3690", "arabic": "حَدَّثَنَا يَحْيَى بْنُ يَحْيَى، قَالَ قَرَأْتُ عَلَى مَالِكٍ عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم نَهَى عَنِ النَّجْشِ ‏.‏", "bengali": "", "english": "Ibn Umar (Allah be pleased with them) reported that Allah's Messenger (ﷺ) forbade the outbidding (against another).", "french": "", "indonesian": "", "russian": "", "urdu": "حضرت جابر بن عبداللہ رضی اللہ عنہ سے روایت ہے ،  انہوں نے کہا :  حضرت ابوبکر رضی اللہ عنہ آئے ،  وہ", "grades": "", "reference": "", "international_number": "3690", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3691", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا ابْنُ أَبِي زَائِدَةَ، ح وَحَدَّثَنَا ابْنُ الْمُثَنَّى، حَدَّثَنَا يَحْيَى يَعْنِي ابْنَ سَعِيدٍ، ح وَحَدَّثَنَا ابْنُ نُمَيْرٍ، حَدَّثَنَا أَبِي كُلُّهُمْ، عَنْ عُبَيْدِ اللَّهِ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم نَهَى أَنْ تُتَلَقَّى السِّلَعُ حَتَّى تَبْلُغَ الأَسْوَاقَ ‏.‏ وَهَذَا لَفْظُ ابْنِ نُمَيْرٍ ‏.‏ وَقَالَ الآخَرَانِ إِنَّ النَّبِيَّ صلى الله عليه وسلم نَهَى عَنِ التَّلَقِّي ‏.‏", "bengali": "", "english": "Do not go out to meet merchandise in the way, (wait) until it is brought into the market. This hadith has been reported on the authority of Ibn Numair but with a slight change of words.", "french": "", "indonesian": "", "russian": "", "urdu": "سماک ابوزمیل سے روایت ہے ،   ( انہوں نے کہا :   )  مجھے عبداللہ بن عباس رضی اللہ عنہ نے حدیث بیان کی", "grades": "", "reference": "", "international_number": "3691", "narrator_chain": "Ibn 'Umar (Allah be pleased with them) reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3692", "arabic": "وَحَدَّثَنِي مُحَمَّدُ بْنُ حَاتِمٍ، وَإِسْحَاقُ بْنُ مَنْصُورٍ، جَمِيعًا عَنِ ابْنِ مَهْدِيٍّ، عَنْ مَالِكٍ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، عَنِ النَّبِيِّ صلى الله عليه وسلم ‏.‏ بِمِثْلِ حَدِيثِ ابْنِ نُمَيْرٍ عَنْ عُبَيْدِ اللَّهِ ‏.‏", "bengali": "", "english": "This hadith has been reported on the authority of 'Ubaidullah.", "french": "", "indonesian": "", "russian": "", "urdu": "سلیمان بن بلال نے کہا :  مجھے یحییٰ نے عبید بن حنین سے خبر دی کہ انہوں نے عبداللہ بن عباس رضی اللہ ع", "grades": "", "reference": "", "international_number": "3692", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3693", "arabic": "وَحَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ مُبَارَكٍ، عَنِ التَّيْمِيِّ، عَنْ أَبِي، عُثْمَانَ عَنْ عَبْدِ اللَّهِ، عَنِ النَّبِيِّ صلى الله عليه وسلم أَنَّهُ نَهَى عَنْ تَلَقِّي الْبُيُوعِ ‏.‏", "bengali": "", "english": "Do not meet the traders (in the way).", "french": "", "indonesian": "", "russian": "", "urdu": "حماد بن سلمہ نے ہمیں حدیث بیان کی ،   ( کہا :   )  ہمیں یحییٰ بن سعید نے عبید بن حنین سے خبر دی ،  ا", "grades": "", "reference": "", "international_number": "3693", "narrator_chain": "Abdullah (Allah be pleased with him) reported Allah's Apostle (ﷺ) as saying:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3694", "arabic": "حَدَّثَنَا يَحْيَى بْنُ يَحْيَى، أَخْبَرَنَا هُشَيْمٌ، عَنْ هِشَامٍ، عَنِ ابْنِ سِيرِينَ، عَنْ أَبِي هُرَيْرَةَ، قَالَ نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم أَنْ يُتَلَقَّى الْجَلَبُ ‏.", "bengali": "", "english": "Do not meet the merchandise (in the way).", "french": "", "indonesian": "", "russian": "", "urdu": "سفیان بن عیینہ نے ہمیں یحییٰ بن سعید سے حدیث بیان کی ،  انہوں نے عبید بن حنین سے سنا ،  وہ حضرت عباس", "grades": "", "reference": "", "international_number": "3694", "narrator_chain": "Abu Huraira (Allah be pleased with him) reported Allah's Messenger (may peace he upon him) as saying:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3695", "arabic": "حَدَّثَنَا ابْنُ أَبِي عُمَرَ، حَدَّثَنَا هِشَامُ بْنُ سُلَيْمَانَ، عَنِ ابْنِ جُرَيْجٍ، أَخْبَرَنِي هِشَامٌ، الْقُرْدُوسِيُّ عَنِ ابْنِ سِيرِينَ، قَالَ سَمِعْتُ أَبَا هُرَيْرَةَ، يَقُولُ إِنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ لاَ تَلَقَّوُا الْجَلَبَ ‏.‏ فَمَنْ تَلَقَّاهُ فَاشْتَرَى مِنْهُ فَإِذَا أَتَى سَيِّدُهُ السُّوقَ فَهُوَ بِالْخِيَارِ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "Do not meet the merchant in the way and enter into business transaction with him, and whoever meets him and buys from him (and in case it is done, see) that when the owner of (merchandise) comes into the market (and finds that he has been paid less price) he has the option (to declare the transaction null and void).", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira (Allah be pleased with him) reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3696", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَمْرٌو النَّاقِدُ، وَزُهَيْرُ بْنُ حَرْبٍ، قَالُوا حَدَّثَنَا سُفْيَانُ، عَنِ الزُّهْرِيِّ، عَنْ سَعِيدِ بْنِ الْمُسَيَّبِ، عَنْ أَبِي هُرَيْرَةَ، يَبْلُغُ بِهِ النَّبِيَّ صلى الله عليه وسلم قَالَ ‏ ‏ لاَ يَبِعْ حَاضِرٌ لِبَادٍ ‏\"\"‏ ‏.‏ وَقَالَ زُهَيْرٌ عَنِ النَّبِيِّ صلى الله عليه وسلم أَنَّهُ نَهَى أَنْ يَبِيعَ حَاضِرٌ لِبَادٍ ‏.\"", "bengali": "", "english": "The townsman'should not sell for a man from the desert (with a view to taking advantage of his ignorance of the market conditions of the city). And Zuhair reported from the Prophet (ﷺ) that he forbade the townsman to sell on behalf of the man from the desert.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira (Allah be pleased with him) reported it directly from Allah's Apostle (ﷺ):", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3697", "arabic": "وَحَدَّثَنَا إِسْحَاقُ بْنُ إِبْرَاهِيمَ، وَعَبْدُ بْنُ حُمَيْدٍ، قَالاَ حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَخْبَرَنَا مَعْمَرٌ، عَنِ ابْنِ طَاوُسٍ، عَنْ أَبِيهِ، عَنِ ابْنِ عَبَّاسٍ، قَالَ نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم أَنْ تُتَلَقَّى الرُّكْبَانُ وَأَنْ يَبِيعَ حَاضِرٌ لِبَادٍ ‏.‏ قَالَ فَقُلْتُ لاِبْنِ عَبَّاسٍ مَا قَوْلُهُ حَاضِرٌ لِبَادٍ قَالَ لاَ يَكُنْ لَهُ سِمْسَارًا.", "bengali": "", "english": "The riders (carrying merchandise) should not be met in the way, and townsman should not sell for a man of the desert. The narrator reported. I said to Ibn 'Abbas: What do these words really imply-\" The townsman for the man of the desert\"? He said: That he should work as a broker on his behalf.", "french": "", "indonesian": "", "russian": "", "urdu": "اسود بن سفیان کے مولیٰ عبداللہ بن یزید نے ابوسلمہ بن عبدالرحمٰن سے ،  انہوں نے فاطمہ بنت قیس رضی الل", "grades": "", "reference": "", "international_number": "3697", "narrator_chain": "Ibn 'Abbas (Allah be pleased with them) reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3698", "arabic": "حَدَّثَنَا يَحْيَى بْنُ يَحْيَى التَّمِيمِيُّ، أَخْبَرَنَا أَبُو خَيْثَمَةَ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، ح. وَحَدَّثَنَا أَحْمَدُ بْنُ يُونُسَ، حَدَّثَنَا زُهَيْرٌ، حَدَّثَنَا أَبُو الزُّبَيْرِ، عَنْ جَابِرٍ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"\"‏ لاَ يَبِعْ حَاضِرٌ لِبَادٍ دَعُوا النَّاسَ يَرْزُقِ اللَّهُ بَعْضَهُمْ مِنْ بَعْضٍ‏\"\"‏ ‏.‏ غَيْرَ أَنَّ فِي رِوَايَةِ يَحْيَى ‏\"\"‏ يُرْزَقُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "The townsman should not sell for a man from the desert, leave the people alone, Allah will give them provision from one another. Yahya reported it with a slight change of words.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Jabir (Allah be pleased with him) reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3699", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَمْرٌو النَّاقِدُ، قَالاَ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، عَنِ النَّبِيِّ صلى الله عليه وسلم بِمِثْلِهِ ‏.‏", "bengali": "", "english": "Jabir (Allah be pleased with him) reported a similar hadith from Allah's Apostle (ﷺ) through another chain of transmitters.", "french": "", "indonesian": "", "russian": "", "urdu": "عمران بن ابی انس نے ابوسلمہ سے روایت کی ،  انہوں نے کہا :  میں نے فاطمہ بنت قیس رضی اللہ عنہا سے دری", "grades": "", "reference": "", "international_number": "3699", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3700", "arabic": "وَحَدَّثَنَا يَحْيَى بْنُ يَحْيَى، أَخْبَرَنَا هُشَيْمٌ، عَنْ يُونُسَ، عَنِ ابْنِ سِيرِينَ، عَنْ أَنَسِ، بْنِ مَالِكٍ قَالَ نُهِينَا أَنْ يَبِيعَ، حَاضِرٌ لِبَادٍ ‏.‏ وَإِنْ كَانَ أَخَاهُ أَوْ أَبَاهُ ‏.‏", "bengali": "", "english": "We were forbidden that a townsman should sell for a man of the desert, even if he is his brother or father.", "french": "", "indonesian": "", "russian": "", "urdu": "یحییٰ بن ابی کثیر سے روایت ہے ،   ( کہا :   )  مجھے ابوسلمہ نے خبر دی کہ ضحاک بن قیس رضی اللہ عنہ کی", "grades": "", "reference": "", "international_number": "3700", "narrator_chain": "Anas b. Malik (Allah be pleased with him) reported:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3701", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، حَدَّثَنَا ابْنُ أَبِي عَدِيٍّ، عَنِ ابْنِ عَوْنٍ، عَنْ مُحَمَّدٍ، عَنْ أَنَسٍ،ح ‏.‏ وَحَدَّثَنَا ابْنُ الْمُثَنَّى، حَدَّثَنَا مُعَاذٌ، حَدَّثَنَا ابْنُ عَوْنٍ، عَنْ مُحَمَّدٍ، قَالَ قَالَ أَنَسُ بْنُ مَالِكٍ نُهِينَا عَنْ أَنْ يَبِيعَ حَاضِرٌ لِبَادٍ ‏.‏\"", "bengali": "", "english": "We were forbidden that a townsman should sell for a man of the desert.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Anas b. Malik (Allah be pleased with him) said:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3702", "arabic": "حَدَّثَنَا عَبْدُ اللَّهِ بْنُ مَسْلَمَةَ بْنِ قَعْنَبٍ، حَدَّثَنَا دَاوُدُ بْنُ قَيْسٍ، عَنْ مُوسَى بْنِ يَسَارٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنِ اشْتَرَى شَاةً مُصَرَّاةً فَلْيَنْقَلِبْ بِهَا فَلْيَحْلُبْهَا فَإِنْ رَضِيَ حِلاَبَهَا أَمْسَكَهَا وَإِلاَّ رَدَّهَا وَمَعَهَا صَاعٌ مِنْ تَمْرٍ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "He who bought a goat having its udder tied up should go back with it, milk it, and, if he is satisfied with its milk, he should retair it, otherwise he should return it along with a sa' of dates.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira (Allah be pleased with him) reported Allah's Messenger (may peace be'upon him) as saying:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3703", "arabic": "حَدَّثَنَا قُتَيْبَةُ بْنُ سَعِيدٍ، حَدَّثَنَا يَعْقُوبُ، - يَعْنِي ابْنَ عَبْدِ الرَّحْمَنِ الْقَارِيَّ - عَنْ سُهَيْلٍ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ مَنِ ابْتَاعَ شَاةً مُصَرَّاةً فَهُوَ فِيهَا بِالْخِيَارِ ثَلاَثَةَ أَيَّامٍ إِنْ شَاءَ أَمْسَكَهَا وَإِنْ شَاءَ رَدَّهَا وَرَدَّ مَعَهَا صَاعًا مِنْ تَمْرٍ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "He who buys a goat with its udder tied up has the option to retain the goat if he so desires or return it within three days, and in case he returns it he should do so along with a sa' of dates.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira (Allah be pleased with him) reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3704", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عَمْرِو بْنِ جَبَلَةَ بْنِ أَبِي رَوَّادٍ، حَدَّثَنَا أَبُو عَامِرٍ، - يَعْنِي الْعَقَدِيَّ - حَدَّثَنَا قُرَّةُ، عَنْ مُحَمَّدٍ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ مَنِ اشْتَرَى شَاةً مُصَرَّاةً فَهُوَ بِالْخِيَارِ ثَلاَثَةَ أَيَّامٍ فَإِنْ رَدَّهَا رَدَّ مَعَهَا صَاعًا مِنْ طَعَامٍ لاَ سَمْرَاءَ ‏\"\"‏‏.‏\"", "bengali": "", "english": "lie who buys a goat having its udder tied up has the option to return it within three days. If he returns it he should pay a sa' of dates. Wheat is not essential.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira (Allah be pleased with him) reported Allah's Apostle (ﷺ) as saying:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3705", "arabic": "حَدَّثَنَا ابْنُ أَبِي عُمَرَ، حَدَّثَنَا سُفْيَانُ، عَنْ أَيُّوبَ، عَنْ مُحَمَّدٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنِ اشْتَرَى شَاةً مُصَرَّاةً فَهُوَ بِخَيْرِ النَّظَرَيْنِ إِنْ شَاءَ أَمْسَكَهَا وَإِنْ شَاءَ رَدَّهَا وَصَاعًا مِنْ تَمْرٍ لاَ سَمْرَاءَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "He who buys a goat having its udder tied up has two courses left for him. He may retain it, and if he desires may return it along with a sa' of dates and not wheat.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira (Allah be pleased with him) reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3706", "arabic": "وَحَدَّثَنَاهُ ابْنُ أَبِي عُمَرَ، حَدَّثَنَا عَبْدُ الْوَهَّابِ، عَنْ أَيُّوبَ، بِهَذَا الإِسْنَادِ غَيْرَ أَنَّهُ قَالَ ‏ ‏ مَنِ اشْتَرَى مِنَ الْغَنَمِ فَهُوَ بِالْخِيَارِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\" He who buys a goat has the option....\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Ayyub narrated with the same chain of transmitters but with this change of words:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3707", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ رَافِعٍ، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، حَدَّثَنَا مَعْمَرٌ، عَنْ هَمَّامِ بْنِ مُنَبِّهٍ، قَالَ هَذَا مَا حَدَّثَنَا أَبُو هُرَيْرَةَ، عَنْ رَسُولِ اللَّهِ صلى الله عليه وسلم فَذَكَرَ أَحَادِيثَ مِنْهَا وَقَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ إِذَا مَا أَحَدُكُمُ اشْتَرَى لِقْحَةً مُصَرَّاةً أَوْ شَاةً مُصَرَّاةً فَهُوَ بِخَيْرِ النَّظَرَيْنِ بَعْدَ أَنْ يَحْلُبَهَا إِمَّا هِيَ وَإِلاَّ فَلْيَرُدَّهَا وَصَاعًا مِنْ تَمْرٍ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "Out of the ahadith which Abu Huraira (Allah be pleased with him) reported to us from Allah's Messenger (ﷺ) one is this that Allah's Messenger (ﷺ) said: If one among you buys a she-camel having its udder tied up he has the two options for him after milking it either (to retain it) or return it with a sa' of dates.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Hammam b. Munabbih said:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3708", "arabic": "حَدَّثَنَا يَحْيَى بْنُ يَحْيَى، حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ، ح وَحَدَّثَنَا أَبُو الرَّبِيعِ الْعَتَكِيُّ، وَقُتَيْبَةُ، قَالاَ حَدَّثَنَا حَمَّادٌ، عَنْ عَمْرِو بْنِ دِينَارٍ، عَنْ طَاوُسٍ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ مَنِ ابْتَاعَ طَعَامًا فَلاَ يَبِعْهُ حَتَّى يَسْتَوْفِيَهُ ‏\"\"‏ ‏.‏ قَالَ ابْنُ عَبَّاسٍ وَأَحْسِبُ كُلَّ شَىْءٍ مِثْلَهُ ‏.‏\"", "bengali": "", "english": "He who buys foodgrain should not sell it until he has taken possession of it.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Ibn Abbas (Allah be pleased with them) reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3709", "arabic": "حَدَّثَنَا ابْنُ أَبِي عُمَرَ، وَأَحْمَدُ بْنُ عَبْدَةَ، قَالاَ حَدَّثَنَا سُفْيَانُ، ح وَحَدَّثَنَا أَبُو بَكْرِ بْنُ، أَبِي شَيْبَةَ وَأَبُو كُرَيْبٍ قَالاَ حَدَّثَنَا وَكِيعٌ، عَنْ سُفْيَانَ، - وَهُوَ الثَّوْرِيُّ - كِلاَهُمَا عَنْ عَمْرِو، بْنِ دِينَارٍ بِهَذَا الإِسْنَادِ نَحْوَهُ ‏.‏", "bengali": "", "english": "A hadith like this has been narrated through the same chain of transmitters.", "french": "", "indonesian": "", "russian": "", "urdu": "یحییٰ بن آدم نے ہمیں خبر دی ،   ( کہا :   )  عمار بن رُزیق نے ہمیں ابواسحاق سے حدیث بیان کی ،  انہوں", "grades": "", "reference": "", "international_number": "3709", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3710", "arabic": "حَدَّثَنَا إِسْحَاقُ بْنُ إِبْرَاهِيمَ، وَمُحَمَّدُ بْنُ رَافِعٍ، وَعَبْدُ بْنُ حُمَيْدٍ، قَالَ ابْنُ رَافِعٍ حَدَّثَنَا وَقَالَ الآخَرَانِ، أَخْبَرَنَا عَبْدُ الرَّزَّاقِ، أَخْبَرَنَا مَعْمَرٌ، عَنِ ابْنِ طَاوُسٍ، عَنْ أَبِيهِ، عَنِ ابْنِ عَبَّاسٍ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنِ ابْتَاعَ طَعَامًا فَلاَ يَبِعْهُ حَتَّى يَقْبِضَهُ ‏\"\"‏ ‏.‏ قَالَ ابْنُ عَبَّاسٍ وَأَحْسِبُ كُلَّ شَىْءٍ بِمَنْزِلَةِ الطَّعَامِ ‏.‏\"", "bengali": "", "english": "He who buys food-rain should not sell it until he has taken possession of it. Ibn Abbas (Allah be pleased with them) said: I regard everything like food (so far as this principle is concerned).", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Ibn Abbas (Allah be pleased with them) reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3711", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَأَبُو كُرَيْبٍ وَإِسْحَاقُ بْنُ إِبْرَاهِيمَ قَالَ إِسْحَاقُ أَخْبَرَنَا وَقَالَ الآخَرَانِ، حَدَّثَنَا وَكِيعٌ، عَنْ سُفْيَانَ، عَنِ ابْنِ طَاوُسٍ، عَنْ أَبِيهِ، عَنِ ابْنِ عَبَّاسٍ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنِ ابْتَاعَ طَعَامًا فَلاَ يَبِعْهُ حَتَّى يَكْتَالَهُ ‏\"\"‏ ‏.‏ فَقُلْتُ لاِبْنِ عَبَّاسٍ لِمَ فَقَالَ أَلاَ تَرَاهُمْ يَتَبَايَعُونَ بِالذَّهَبِ وَالطَّعَامُ مُرْجَأٌ وَلَمْ يَقُلْ أَبُو كُرَيْبٍ مُرْجَأٌ ‏.‏\"", "bengali": "", "english": "He who buys foodgrain should not sell it, until he has weighed it (and then taken possession of it). I (Tawus) said to Ibn Abbas (Allah be pleased with them): Why is it so? Thereupon he said: Don't you see that they (the people) sell foodgrains against gold for the stipulated time. Abu Kuraib did not make any mention of the stipulated time.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Ibn Abbas (Allah be pleased with them) reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3712", "arabic": "حَدَّثَنَا عَبْدُ اللَّهِ بْنُ مَسْلَمَةَ الْقَعْنَبِيُّ، حَدَّثَنَا مَالِكٌ، ح وَحَدَّثَنَا يَحْيَى بْنُ يَحْيَى، قَالَ قَرَأْتُ عَلَى مَالِكٍ عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ مَنِ ابْتَاعَ طَعَامًا فَلاَ يَبِعْهُ حَتَّى يَسْتَوْفِيَهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "He who buys foodgrain should not sell it until he has taken full possession of it.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Ibn 'Umar (Allah be pleased with them) reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3713", "arabic": "حَدَّثَنَا يَحْيَى بْنُ يَحْيَى، قَالَ قَرَأْتُ عَلَى مَالِكٍ عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ كُنَّا فِي زَمَانِ رَسُولِ اللَّهِ صلى الله عليه وسلم نَبْتَاعُ الطَّعَامَ فَيَبْعَثُ عَلَيْنَا مَنْ يَأْمُرُنَا بِانْتِقَالِهِ مِنَ الْمَكَانِ الَّذِي ابْتَعْنَاهُ فِيهِ إِلَى مَكَانٍ سِوَاهُ قَبْلَ أَنْ نَبِيعَهُ ‏.‏", "bengali": "", "english": "We used to buy foodgrains during the lifetime of Allah's Messenger (ﷺ). He (the Holy Prophet) would then send to us one who commanded us to take them (the foodgrains) to a place other than the one where we had bought them before we sold it.", "french": "", "indonesian": "", "russian": "", "urdu": "عبدالرحمٰن نے ہمیں سفیان سے حدیث بیان کی ،  انہوں نے ابوبکر بن ابی جہم سے روایت کی ،  انہوں نے کہا :", "grades": "", "reference": "", "international_number": "3713", "narrator_chain": "Ibn Umar (Allah be pleased with them) reported:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3714", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ، عَنْ عُبَيْدِ اللَّهِ، ح وَحَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، - وَاللَّفْظُ لَهُ - حَدَّثَنَا أَبِي، حَدَّثَنَا عُبَيْدُ اللَّهِ، عَنْ نَافِعٍ، عَنِ ابْنِ، عُمَرَ أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ مَنِ اشْتَرَى طَعَامًا فَلاَ يَبِعْهُ حَتَّى يَسْتَوْفِيَهُ‏\"\"‏ ‏.‏ قَالَ وَكُنَّا نَشْتَرِي الطَّعَامَ مِنَ الرُّكْبَانِ جِزَافًا فَنَهَانَا رَسُولُ اللَّهِ صلى الله عليه وسلم أَنْ نَبِيعَهُ حَتَّى نَنْقُلَهُ مِنْ مَكَانِهِ ‏.\"", "bengali": "", "english": "He who buys foodgrain should not sell that before taking possession of it. He (the narrator) said: We used to buy foodgrain from the caravans in bulk, but Allah's Messenger (ﷺ) forbade us to re-sell that until we had shifted it to some other place.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Ibn Umar (Allah be pleased with them) reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3715", "arabic": "حَدَّثَنِي حَرْمَلَةُ بْنُ يَحْيَى، أَخْبَرَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، حَدَّثَنِي عُمَرُ بْنُ مُحَمَّدٍ، عَنْ نَافِعٍ، عَنْ عَبْدِ اللَّهِ بْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ مَنِ اشْتَرَى طَعَامًا فَلاَ يَبِعْهُ حَتَّى يَسْتَوْفِيَهُ وَيَقْبِضَهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "He who bought foodgrain should not sell it until he had taken full possession of it (after measuring it).", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Ibn 'Umar (Allah be pleased with them) reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3716", "arabic": "حَدَّثَنَا يَحْيَى بْنُ يَحْيَى، وَعَلِيُّ بْنُ حُجْرٍ، قَالَ يَحْيَى أَخْبَرَنَا إِسْمَاعِيلُ بْنُ جَعْفَرٍ، وَقَالَ عَلِيٌّ حَدَّثَنَا إِسْمَاعِيلُ، عَنْ عَبْدِ اللَّهِ بْنِ دِينَارٍ، أَنَّهُ سَمِعَ ابْنَ عُمَرَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنِ ابْتَاعَ طَعَامًا فَلاَ يَبِعْهُ حَتَّى يَقْبِضَهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "He who bought foodgrain should not sell it until he had taken possession of it.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Ibn 'Umar (Allah be pleased with them) reported Allah's Messenger (ﷺ) as saying,:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3717", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ الأَعْلَى، عَنْ مَعْمَرٍ، عَنِ الزُّهْرِيِّ، عَنْ سَالِمٍ، عَنِ ابْنِ عُمَرَ، أَنَّهُمْ كَانُوا يُضْرَبُونَ عَلَى عَهْدِ رَسُولِ اللَّهِ صلى الله عليه وسلم إِذَا اشْتَرَوْا طَعَامًا جِزَافًا أَنْ يَبِيعُوهُ فِي مَكَانِهِ حَتَّى يُحَوِّلُوهُ ‏.‏", "bengali": "", "english": "Ibn 'Umar (Allah be pleased with them) reported that they were beaten during the lifetime of Allah's Messenger (ﷺ) if they had bought foodgrains in bulk and then sold them in the spot without shifting them (to some other place).", "french": "", "indonesian": "", "russian": "", "urdu": "عروہ بن زبیر نے کہا :  یحییٰ بن سعید بن عاص نے عبدالرحمٰن بن حکم کی بیٹی سے شادی کی ،  بعد میں اسے ط", "grades": "", "reference": "", "international_number": "3717", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3718", "arabic": "وَحَدَّثَنِي حَرْمَلَةُ بْنُ يَحْيَى، حَدَّثَنَا ابْنُ وَهْبٍ، أَخْبَرَنِي يُونُسُ، عَنِ ابْنِ شِهَابٍ، أَخْبَرَنِي سَالِمُ بْنُ عَبْدِ اللَّهِ، أَنَّ أَبَاهُ، قَالَ قَدْ رَأَيْتُ النَّاسَ فِي عَهْدِ رَسُولِ اللَّهِ صلى الله عليه وسلم إِذَا ابْتَاعُوا الطَّعَامَ جِزَافًا يُضْرَبُونَ فِي أَنْ يَبِيعُوهُ فِي مَكَانِهِمْ وَذَلِكَ حَتَّى يُئْوُوهُ إِلَى رِحَالِهِمْ ‏.‏ قَالَ ابْنُ شِهَابٍ وَحَدَّثَنِي عُبَيْدُ اللَّهِ بْنُ عَبْدِ اللَّهِ بْنِ عُمَرَ أَنَّ أَبَاهُ كَانَ يَشْتَرِي الطَّعَامَ جِزَافًا فَيَحْمِلُهُ إِلَى أَهْلِهِ ‏.‏", "bengali": "", "english": "I saw people being beaten during the lifetime of Allah's Messenger (ﷺ) in case they bought the foodgrain in bulk, and then sold them at that spot before taking it to their places. This hadith is narrated on the authority of 'Ubaidullah b. Abdullah b. 'Umar through another chain of transmitters (and the words are):\" His father (Ibn 'Umar) used to buy foodgrains in bulk and then carried them to his people.\"", "french": "", "indonesian": "", "russian": "", "urdu": "فاطمہ بنت قیس رضی اللہ عنہا سے روایت ہے ،  انہوں نے کہا :  میں نے عرض کی :  اے اللہ کے رسول! مجھے می", "grades": "", "reference": "", "international_number": "3718", "narrator_chain": "Salim b. 'Abdullah (Allah be pleased with them) reported his father havingsaid this:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3719", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَابْنُ، نُمَيْرٍ وَأَبُو كُرَيْبٍ قَالُوا حَدَّثَنَا زَيْدُ بْنُ حُبَابٍ، عَنِ الضَّحَّاكِ بْنِ عُثْمَانَ، عَنْ بُكَيْرِ بْنِ عَبْدِ اللَّهِ بْنِ الأَشَجِّ، عَنْ سُلَيْمَانَ بْنِ يَسَارٍ، عَنْ أَبِي، هُرَيْرَةَ أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏\"‏ مَنِ اشْتَرَى طَعَامًا فَلاَ يَبِعْهُ حَتَّى يَكْتَالَهُ ‏\"‏ ‏.‏ وَفِي رِوَايَةِ أَبِي بَكْرٍ ‏\"‏ مَنِ ابْتَاعَ ‏\"‏ ‏.‏", "bengali": "", "english": "He who bought foodgrain should not sell it until he had measured it. In the narration of Abu Bakr there the word is Ibta' instead of Ishtara.", "french": "", "indonesian": "", "russian": "", "urdu": "شعبہ نے ہمیں عبدالرحمٰن بن قاسم سے حدیث بیان کی ،  انہوں نے اپنے والد  ( قاسم )  سے ،  انہوں نے حضرت", "grades": "", "reference": "", "international_number": "3719", "narrator_chain": "Abu Huraira (Allah be pleased with him) reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3720", "arabic": "حَدَّثَنَا إِسْحَاقُ بْنُ إِبْرَاهِيمَ، أَخْبَرَنَا عَبْدُ اللَّهِ بْنُ الْحَارِثِ الْمَخْزُومِيُّ، حَدَّثَنَا الضَّحَّاكُ، بْنُ عُثْمَانَ عَنْ بُكَيْرِ بْنِ عَبْدِ اللَّهِ بْنِ الأَشَجِّ، عَنْ سُلَيْمَانَ بْنِ يَسَارٍ، عَنْ أَبِي هُرَيْرَةَ، أَنَّهُ قَالَ لِمَرْوَانَ أَحْلَلْتَ بَيْعَ الرِّبَا ‏.‏ فَقَالَ مَرْوَانُ مَا فَعَلْتُ ‏.‏ فَقَالَ أَبُو هُرَيْرَةَ أَحْلَلْتَ بَيْعَ الصِّكَاكِ وَقَدْ نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم عَنْ بَيْعِ الطَّعَامِ حَتَّى يُسْتَوْفَى ‏.‏ قَالَ فَخَطَبَ مَرْوَانُ النَّاسَ فَنَهَى عَنْ بَيْعِهَا ‏.‏ قَالَ سُلَيْمَانُ فَنَظَرْتُ إِلَى حَرَسٍ يَأْخُذُونَهَا مِنْ أَيْدِي النَّاسِ ‏.‏", "bengali": "", "english": "Have you made lawful the transactions involving interest? Thereupon Marwan said: I have not done that. Thereupon Abu Huraira (ﷺ) said: You have made lawful the transactions with the help of documents only, whereas Allah's Messenger (ﷺ) forbade the transaction of foodgrains until full possession is taken of them. Marwan then addressed the people and forbade them to enter into such transactions (as are done with the help of documents). Sulaiman said: I saw the sentinels snatching (these documents) from the people.", "french": "", "indonesian": "", "russian": "", "urdu": "سفیان نے عبدالرحمٰن بن قاسم سے اور انہوں نے اپنے والد  ( قاسم )  سے روایت کی ،  انہوں نے کہا :  عروہ", "grades": "", "reference": "", "international_number": "3720", "narrator_chain": "Abu Huraira (Allah be please with him) is reported to have said to Marwan:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3721", "arabic": "حَدَّثَنَا إِسْحَاقُ بْنُ إِبْرَاهِيمَ، أَخْبَرَنَا رَوْحٌ، حَدَّثَنَا ابْنُ جُرَيْجٍ، حَدَّثَنِي أَبُو الزُّبَيْرِ، أَنَّهُ سَمِعَ جَابِرَ بْنَ عَبْدِ اللَّهِ، يَقُولُ كَانَ رَسُولُ اللَّهِ صلى الله عليه وسلم يَقُولُ ‏ ‏ إِذَا ابْتَعْتَ طَعَامًا فَلاَ تَبِعْهُ حَتَّى تَسْتَوْفِيَهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "When you purchase foodgrains, do not sell them until you have taken possession of them.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Jabir b. Abdullah (Allah be pleased with them) reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3722", "arabic": "حَدَّثَنِي أَبُو الطَّاهِرِ، أَحْمَدُ بْنُ عَمْرِو بْنِ سَرْحٍ أَخْبَرَنَا ابْنُ وَهْبٍ، حَدَّثَنِي ابْنُ جُرَيْجٍ، أَنَّ أَبَا الزُّبَيْرِ، أَخْبَرَهُ قَالَ سَمِعْتُ جَابِرَ بْنَ عَبْدِ اللَّهِ، يَقُولُ نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم عَنْ بَيْعِ الصُّبْرَةِ مِنَ التَّمْرِ لاَ يُعْلَمُ مَكِيلَتُهَا بِالْكَيْلِ الْمُسَمَّى مِنَ التَّمْرِ ‏.‏", "bengali": "", "english": "Jabir b. Abdullah (Allah be pleased with them) is reported to have said that Allah's Messenger (ﷺ) forbade the sale of a heap of dates the weight of which is unknown in accordance with the known weight of dates.", "french": "", "indonesian": "", "russian": "", "urdu": "ابن شہاب سے روایت ہے ،   ( انہوں نے کہا :   )  مجھے عبیداللہ بن عبداللہ بن عتبہ بن مسعود نے حدیث بیا", "grades": "", "reference": "", "international_number": "3722", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3723", "arabic": "حَدَّثَنَا إِسْحَاقُ بْنُ إِبْرَاهِيمَ، حَدَّثَنَا رَوْحُ بْنُ عُبَادَةَ، حَدَّثَنَا ابْنُ جُرَيْجٍ، أَخْبَرَنِي أَبُو الزُّبَيْرِ، أَنَّهُ سَمِعَ جَابِرَ بْنَ عَبْدِ اللَّهِ، يَقُولُ نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم ‏.‏ بِمِثْلِهِ غَيْرَ أَنَّهُ لَمْ يَذْكُرْ مِنَ التَّمْرِ ‏.‏ فِي آخِرِ الْحَدِيثِ ‏.‏", "bengali": "", "english": "This hadith is narrated on the authority of Jabir b. Abdullah (Allah be pleased with them) but with this variation that no mention is made of the dates (which one finds) at the end of the previous hadith.", "french": "", "indonesian": "", "russian": "", "urdu": "عبدالوہاب نے کہا :  میں نے یحییٰ بن سعید سے سنا ،   ( انہوں نے کہا :   )  مجھے سلیمان بن یسار نے خبر", "grades": "", "reference": "", "international_number": "3723", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3724", "arabic": "حَدَّثَنَا يَحْيَى بْنُ يَحْيَى، قَالَ قَرَأْتُ عَلَى مَالِكٍ عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ الْبَيِّعَانِ كُلُّ وَاحِدٍ مِنْهُمَا بِالْخِيَارِ عَلَى صَاحِبِهِ مَا لَمْ يَتَفَرَّقَا إِلاَّ بَيْعَ الْخِيَارِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "Both parties in a business transaction have the right to annul it so long as they have not separated; except in transactions which have been made subject to the right of parties to annul them.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Ibn 'Umar (Allah be pleased with them) reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3725", "arabic": "حَدَّثَنَا زُهَيْرُ بْنُ حَرْبٍ، وَمُحَمَّدُ بْنُ الْمُثَنَّى، قَالاَ حَدَّثَنَا يَحْيَى، وَهُوَ الْقَطَّانُ ح وَحَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ، ح وَحَدَّثَنَا ابْنُ نُمَيْرٍ، حَدَّثَنَا أَبِي كُلُّهُمْ، عَنْ عُبَيْدِ، اللَّهِ عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، عَنِ النَّبِيِّ صلى الله عليه وسلم ح. وَحَدَّثَنِي زُهَيْرُ بْنُ حَرْبٍ، وَعَلِيُّ بْنُ حُجْرٍ، قَالاَ حَدَّثَنَا إِسْمَاعِيلُ، ح وَحَدَّثَنَا أَبُو الرَّبِيعِ وَأَبُو كَامِلٍ قَالاَ حَدَّثَنَا حَمَّادٌ، - وَهُوَ ابْنُ زَيْدٍ - جَمِيعًا عَنْ أَيُّوبَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، عَنِ النَّبِيِّ صلى الله عليه وسلم ح. وَحَدَّثَنَا ابْنُ الْمُثَنَّى، وَابْنُ أَبِي عُمَرَ، قَالاَ حَدَّثَنَا عَبْدُ الْوَهَّابِ، قَالَ سَمِعْتُ يَحْيَى، بْنُ سَعِيدٍ ح وَحَدَّثَنَا ابْنُ رَافِعٍ، حَدَّثَنَا ابْنُ أَبِي فُدَيْكٍ، أَخْبَرَنَا الضَّحَّاكُ، كِلاَهُمَا عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، عَنِ النَّبِيِّ صلى الله عليه وسلم ‏.‏ نَحْوَ حَدِيثِ مَالِكٍ عَنْ نَافِعٍ ‏.‏\"", "bengali": "", "english": "This hadith has been narrated on the authority of Ibn 'Umar (Allah be pleased with them) through another chain of transmitters.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3726", "arabic": "حَدَّثَنَا قُتَيْبَةُ بْنُ سَعِيدٍ، حَدَّثَنَا لَيْثٌ، ح وَحَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، أَخْبَرَنَا اللَّيْثُ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، عَنْ رَسُولِ اللَّهِ صلى الله عليه وسلم أَنَّهُ قَالَ ‏ ‏ إِذَا تَبَايَعَ الرَّجُلاَنِ فَكُلُّ وَاحِدٍ مِنْهُمَا بِالْخِيَارِ مَا لَمْ يَتَفَرَّقَا وَكَانَا جَمِيعًا أَوْ يُخَيِّرُ أَحَدُهُمَا الآخَرَ فَإِنْ خَيَّرَ أَحَدُهُمَا الآخَرَ فَتَبَايَعَا عَلَى ذَلِكَ فَقَدْ وَجَبَ الْبَيْعُ وَإِنْ تَفَرَّقَا بَعْدَ أَنْ تَبَايَعَا وَلَمْ يَتْرُكْ وَاحِدٌ مِنْهُمَا الْبَيْعَ فَقَدْ وَجَبَ الْبَيْعُ ‏\"\"‏ ‏.\"", "bengali": "", "english": "When two persons enter into a transaction, each of them has the right to annul it so long as they are not separated and are together (at the place of transaction) ; or if one gives the other the right (to annul the transaction) But if one gives the other the option, the transaction is made on this condition (i. e. one has the right to annul the transaction), it becomes binding. And if they are separated after they have made the bargain and none of them annulled it, even then the transaction is binding.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Ibn 'Umar (Allah be pleased with thcm) reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3727", "arabic": "وَحَدَّثَنِي زُهَيْرُ بْنُ حَرْبٍ، وَابْنُ أَبِي عُمَرَ، كِلاَهُمَا عَنْ سُفْيَانَ، - قَالَ زُهَيْرٌ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، - عَنِ ابْنِ جُرَيْجٍ، قَالَ أَمْلَى عَلَىَّ نَافِعٌ سَمِعَ عَبْدَ اللَّهِ بْنَ عُمَرَ، يَقُولُ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ إِذَا تَبَايَعَ الْمُتَبَايِعَانِ بِالْبَيْعِ فَكُلُّ وَاحِدٍ مِنْهُمَا بِالْخِيَارِ مِنْ بَيْعِهِ مَا لَمْ يَتَفَرَّقَا أَوْ يَكُونُ بَيْعُهُمَا عَنْ خِيَارٍ فَإِذَا كَانَ بَيْعُهُمَا عَنْ خِيَارٍ فَقَدْ وَجَبَ ‏\"\"‏ ‏.‏ زَادَ ابْنُ أَبِي عُمَرَ فِي رِوَايَتِهِ قَالَ نَافِعٌ فَكَانَ إِذَا بَايَعَ رَجُلاً فَأَرَادَ أَنْ لاَ يُقِيلَهُ قَامَ فَمَشَى هُنَيَّةً ثُمَّ رَجَعَ إِلَيْهِ ‏.‏\"", "bengali": "", "english": "When two persons enter into a transac. tion, each one of them has the right to annul it so long as they are not separated, or their transaction gives one another (as a condition) the right of annulling, and if their transaction, has the right of annulling it the transaction becomes binding. Ibn Abi Umar made this addition that whenever he (Ibn Umar) entered into a transaction with a person with the intention of not breaking it, he walked a while and then returned to him.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abdullah b. 'Umar (Allah be pleased with them) reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3728", "arabic": "حَدَّثَنَا يَحْيَى بْنُ يَحْيَى، و يَحْيَى بْنُ أَيُّوبَ وَقُتَيْبَةُ وَابْنُ حُجْرٍ قَالَ يَحْيَى بْنُ يَحْيَى أَخْبَرَنَا وَقَالَ الآخَرُونَ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ جَعْفَرٍ، عَنْ عَبْدِ اللَّهِ بْنِ دِينَارٍ، أَنَّهُ سَمِعَ ابْنَ، عُمَرَ يَقُولُ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ كُلُّ بَيِّعَيْنِ لاَ بَيْعَ بَيْنَهُمَا حَتَّى يَتَفَرَّقَا إِلاَّ بَيْعُ الْخِيَارِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "There is no transaction between two persons entering a transaction until they separate, but only when there is an option to annul it.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Ibn Umar reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3729", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، عَنْ شُعْبَةَ، ح وَحَدَّثَنَا عَمْرُو بْنُ، عَلِيٍّ حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، وَعَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، قَالاَ حَدَّثَنَا شُعْبَةُ، عَنْ قَتَادَةَ، عَنْ أَبِي الْخَلِيلِ، عَنْ عَبْدِ اللَّهِ بْنِ الْحَارِثِ، عَنْ حَكِيمِ بْنِ حِزَامٍ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ الْبَيِّعَانِ بِالْخِيَارِ مَا لَمْ يَتَفَرَّقَا فَإِنْ صَدَقَا وَبَيَّنَا بُورِكَ لَهُمَا فِي بَيْعِهِمَا وَإِنْ كَذَبَا وَكَتَمَا مُحِقَتْ بَرَكَةُ بَيْعِهِمَا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "Both parties in a business transaction have the right to annul it so long as they have not separated; and if they speak the truth and make everything clear they will be blessed in their transaction; but if they tell a lie and conceal anything the blessing on their transaction will be blotted out.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Hakim b. Hazim (Allah be pleased with him) reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3730", "arabic": "حَدَّثَنَا عَمْرُو بْنُ عَلِيٍّ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، حَدَّثَنَا هَمَّامٌ، عَنْ أَبِي التَّيَّاحِ، قَالَ سَمِعْتُ عَبْدَ اللَّهِ بْنَ الْحَارِثِ، يُحَدِّثُ عَنْ حَكِيمِ بْنِ حِزَامٍ، عَنِ النَّبِيِّ صلى الله عليه وسلم ‏.‏ بِمِثْلِهِ ‏.‏ قَالَ مُسْلِمُ بْنُ الْحَجَّاجِ وُلِدَ حَكِيمُ بْنُ حِزَامٍ فِي جَوْفِ الْكَعْبَةِ وَعَاشَ مِائَةً وَعِشْرِينَ سَنَةً ‏.‏", "bengali": "", "english": "Hakim b. Hizam was born inside the Ka'ba and lived for one hundred and twenty years.", "french": "", "indonesian": "", "russian": "", "urdu": "زینب نے انہیں  ( حمید کو )  اپنی والدہ  ( حضرت ام سلمہ رضی اللہ عنہا )  سے اور نبی صلی اللہ علیہ وسل", "grades": "", "reference": "", "international_number": "3730", "narrator_chain": "A hadith like this has been transmitted on the authority of Hakim b. Hizam (Imam Muslim) said:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3731", "arabic": "حَدَّثَنَا يَحْيَى بْنُ يَحْيَى، وَيَحْيَى بْنُ أَيُّوبَ، وَقُتَيْبَةُ، وَابْنُ، حُجْرٍ قَالَ يَحْيَى بْنُ يَحْيَى أَخْبَرَنَا وَقَالَ الآخَرُونَ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ جَعْفَرٍ، عَنْ عَبْدِ اللَّهِ بْنِ دِينَارٍ، أَنَّهُ سَمِعَ ابْنَ، عُمَرَ يَقُولُ ذَكَرَ رَجُلٌ لِرَسُولِ اللَّهِ صلى الله عليه وسلم أَنَّهُ يُخْدَعُ فِي الْبُيُوعِ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنْ بَايَعْتَ فَقُلْ لاَ خِلاَبَةَ ‏\"\"‏ ‏.‏ فَكَانَ إِذَا بَايَعَ يَقُولُ لاَ خِيَابَةَ‏.‏\"", "bengali": "", "english": "A man mentioned to the Messenger of Allah (ﷺ) that he was deceived in a business transaction, whereupon Allah's Messenger (ﷺ) said: When you enter into a transaction, say: There should be no attempt to deceive.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abdullah b. Dinar narrated that he heard Ibn 'Umar (Allah be pleased with them) saying:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3732", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا سُفْيَانُ، ح وَحَدَّثَنَا مُحَمَّدُ بْنُ، الْمُثَنَّى حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، حَدَّثَنَا شُعْبَةُ، كِلاَهُمَا عَنْ عَبْدِ اللَّهِ بْنِ دِينَارٍ، بِهَذَا الإِسْنَادِ مِثْلَهُ وَلَيْسَ فِي حَدِيثِهِمَا فَكَانَ إِذَا بَايَعَ يَقُولُ لاَ خِيَابَةَ ‏.‏", "bengali": "", "english": "There should be no attempt to deceive.\"", "french": "", "indonesian": "", "russian": "", "urdu": "معاذ بن معاذ نے ہمیں حدیث بیان کی ،   ( کہا :   )  ہمیں شعبہ نے حمید بن نافع سے اکٹھی دو حدیثیں بیان", "grades": "", "reference": "", "international_number": "3732", "narrator_chain": "This hadith has been narrated on the authority of 'Abdullah b. Dinar with the same chain of transmitters but these words are not found in it.\" When he buys he should say:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3733", "arabic": "حَدَّثَنَا يَحْيَى بْنُ يَحْيَى، قَالَ قَرَأْتُ عَلَى مَالِكٍ عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم نَهَى عَنْ بَيْعِ الثَّمَرِ حَتَّى يَبْدُوَ صَلاَحُهَا نَهَى الْبَائِعَ وَالْمُبْتَاعَ.", "bengali": "", "english": "Ibn 'Umar (Allah be pleased with them) reported that Allah's Messenger (ﷺ) forbade the sale of fruits until they were clearly in good condition, he forbade it both to the seller and to the buyer.", "french": "", "indonesian": "", "russian": "", "urdu": "حمید بن نافع سے روایت ہے کہ انہوں نے زینب بنت ابی سلمہ رضی اللہ عنہا سے سنا ،  وہ حضرت ام سلمہ اور ح", "grades": "", "reference": "", "international_number": "3733", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3734", "arabic": "حَدَّثَنَا ابْنُ نُمَيْرٍ، حَدَّثَنَا أَبِي، حَدَّثَنَا عُبَيْدُ اللَّهِ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، عَنِ النَّبِيِّ صلى الله عليه وسلم بِمِثْلِهِ ‏.‏", "bengali": "", "english": "Another chain on the authority of Ibn 'Umar narrated the same as the above hadith.", "french": "", "indonesian": "", "russian": "", "urdu": "زینب بنت ابی سلمہ رضی اللہ عنہا سے روایت ہے ،  انہوں نے کہا :  جب ام حبیبہ رضی اللہ عنہا کے پاس  ( ا", "grades": "", "reference": "", "international_number": "3734", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3735", "arabic": "وَحَدَّثَنِي عَلِيُّ بْنُ حُجْرٍ السَّعْدِيُّ، وَزُهَيْرُ بْنُ حَرْبٍ، قَالاَ حَدَّثَنَا إِسْمَاعِيلُ، عَنْ أَيُّوبَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم نَهَى عَنْ بَيْعِ النَّخْلِ حَتَّى يَزْهُوَ وَعَنِ السُّنْبُلِ حَتَّى يَبْيَضَّ وَيَأْمَنَ الْعَاهَةَ نَهَى الْبَائِعَ وَالْمُشْتَرِيَ ‏.‏", "bengali": "", "english": "Ibn 'Umar (Allah be pleased with them) reported that Allah's Messenger (ﷺ) forbade the sale of palm-trees (i. e. their trults) until the dates began to ripen, and ears of corn until they were white and were safe from blight. He forbade the seller and the buyer.", "french": "", "indonesian": "", "russian": "", "urdu": "لیث بن سعد نے نافع سے روایت کی کہ صفیہ بنت ابی عبید نے انہیں حضرت حفصہ رضی اللہ عنہا سے یا حضرت عائش", "grades": "", "reference": "", "international_number": "3735", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3736", "arabic": "حَدَّثَنِي زُهَيْرُ بْنُ حَرْبٍ، حَدَّثَنَا جَرِيرٌ، عَنْ يَحْيَى بْنِ سَعِيدٍ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ لاَ تَبْتَاعُوا الثَّمَرَ حَتَّى يَبْدُوَ صَلاَحُهُ وَتَذْهَبَ عَنْهُ الآفَةُ قَالَ يَبْدُوَ صَلاَحُهُ حُمْرَتُهُ وَصُفْرَتُهُ ‏.‏", "bengali": "", "english": "Do not buy fruit until its good condition becomes clear, and (the danger) of blight is no more. He said: Its good condition becoming clear implies that it becomes red or yellow.", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن دینار نے نافع سے لیث کی حدیث کی سند کے ساتھ اسی کی مانند روایت بیان کی", "grades": "", "reference": "", "international_number": "3736", "narrator_chain": "Ibn Umar (Allah be pleased with them) reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3737", "arabic": "وَحَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، وَابْنُ أَبِي عُمَرَ، قَالاَ حَدَّثَنَا عَبْدُ الْوَهَّابِ، عَنْ يَحْيَى، بِهَذَا الإِسْنَادِ حَتَّى يَبْدُوَ صَلاَحُهُ لَمْ يَذْكُرْ مَا بَعْدَهُ", "bengali": "", "english": "This hadith is reported or the authority of Yahya with the same chain of transmitters up to\" until its good condition becomes clear,\" but lie did not mention what follows (these words).", "french": "", "indonesian": "", "russian": "", "urdu": "یحییٰ بن سعید کہتے ہیں :  میں نے نافع سے سنا ،  وہ صفیہ بنت ابوعبید سے حدیث بیان کر رہے تھے کہ انہوں", "grades": "", "reference": "", "international_number": "3737", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3738", "arabic": "حَدَّثَنَا ابْنُ رَافِعٍ، حَدَّثَنَا ابْنُ أَبِي فُدَيْكٍ، أَخْبَرَنَا الضَّحَّاكُ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، عَنِ النَّبِيِّ صلى الله عليه وسلم بِمِثْلِ حَدِيثِ عَبْدِ الْوَهَّابِ ‏.‏", "bengali": "", "english": "This hadith has been narrated on the authority of Ibn 'Umar through another chain of transmitters.", "french": "", "indonesian": "", "russian": "", "urdu": "ایوب اور عبیداللہ دونوں نے نافع سے ،  انہوں نے صفیہ بنت ابی عبید سے ،  انہوں نے نبی صلی اللہ علیہ وس", "grades": "", "reference": "", "international_number": "3738", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3739", "arabic": "حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، حَدَّثَنَا حَفْصُ بْنُ مَيْسَرَةَ، حَدَّثَنِي مُوسَى بْنُ عُقْبَةَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، عَنِ النَّبِيِّ صلى الله عليه وسلم بِمِثْلِ حَدِيثِ مَالِكٍ وَعُبَيْدِ اللَّهِ ‏.‏", "bengali": "", "english": "Nafi, reported on the authority of Ibn Umar (Allah be pleased with them) a hadith like that narrated before.", "french": "", "indonesian": "", "russian": "", "urdu": "حضرت عائشہ رضی اللہ عنہا نے نبی صلی اللہ علیہ وسلم سے روایت کی کہ آپ نے فرمایا :   \" کسی عورت کے لیے", "grades": "", "reference": "", "international_number": "3739", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3740", "arabic": "حَدَّثَنَا يَحْيَى بْنُ يَحْيَى، وَيَحْيَى بْنُ أَيُّوبَ، وَقُتَيْبَةُ، وَابْنُ، حُجْرٍ قَالَ يَحْيَى بْنُ يَحْيَى أَخْبَرَنَا وَقَالَ الآخَرُونَ، حَدَّثَنَا إِسْمَاعِيلُ، - وَهُوَ ابْنُ جَعْفَرٍ - عَنْ عَبْدِ اللَّهِ بْنِ دِينَارٍ، أَنَّهُ سَمِعَ ابْنَ عُمَرَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ لاَ تَبِيعُوا الثَّمَرَ حَتَّى يَبْدُوَ صَلاَحُهُ ‏\"\"‏ ‏.\"", "bengali": "", "english": "Do not buy fruits (on the trees) until their good condition becomes clear.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Ibn Umar (Allah be pleased with them) reported Allah's Messenger' (ﷺ) as saying:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3741", "arabic": "وَحَدَّثَنِيهِ زُهَيْرُ بْنُ حَرْبٍ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ، عَنْ سُفْيَانَ، ح وَحَدَّثَنَا ابْنُ الْمُثَنَّى، حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، حَدَّثَنَا شُعْبَةُ، كِلاَهُمَا عَنْ عَبْدِ اللَّهِ بْنِ دِينَارٍ، بِهَذَا الإِسْنَادِ وَزَادَ فِي حَدِيثِ شُعْبَةَ فَقِيلَ لاِبْنِ عُمَرَ مَا صَلاَحُهُ قَالَ تَذْهَبُ عَاهَتُهُ ‏.‏", "bengali": "", "english": "When (the danger of) blight is no more.", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن نمیر اور یزید بن ہارون ،  دونوں نے ہشام سے اسی سند کے ساتھ روایت کی ،  اور دونوں نے کہا :", "grades": "", "reference": "", "international_number": "3741", "narrator_chain": "In the hadith transmitted on the authority of Shu'ba it was stated that Ibn Umar (Allah be pleased with them) was asked what good condition implied. He said:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3742", "arabic": "حَدَّثَنَا يَحْيَى بْنُ يَحْيَى، أَخْبَرَنَا أَبُو خَيْثَمَةَ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، ح. وَحَدَّثَنَا أَحْمَدُ بْنُ يُونُسَ، حَدَّثَنَا زُهَيْرٌ، حَدَّثَنَا أَبُو الزُّبَيْرِ، عَنْ جَابِرٍ، قَالَ نَهَى - أَوْ نَهَانَا - رَسُولُ اللَّهِ صلى الله عليه وسلم عَنْ بَيْعِ الثَّمَرِ حَتَّى يَطِيبَ ‏.‏\"", "bengali": "", "english": "Jabir (Allah be pleased with him) reported that Allah's Messenger (ﷺ) forbade (or forbade us) the sale of fruits until they are ripe in a good condition.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3743", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ عُثْمَانَ النَّوْفَلِيُّ، حَدَّثَنَا أَبُو عَاصِمٍ، ح وَحَدَّثَنِي مُحَمَّدُ بْنُ حَاتِمٍ، - وَاللَّفْظُ لَهُ - حَدَّثَنَا رَوْحٌ، قَالاَ حَدَّثَنَا زَكَرِيَّاءُ بْنُ إِسْحَاقَ، حَدَّثَنَا عَمْرُو بْنُ دِينَارٍ، أَنَّهُ سَمِعَ جَابِرَ بْنَ عَبْدِ اللَّهِ، يَقُولُ نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم عَنْ بَيْعِ الثَّمَرِ حَتَّى يَبْدُوَ صَلاَحُهُ ‏.‏", "bengali": "", "english": "Jabir b. Abdullah (Allah be pleased with them) reported Allah's Messenger (ﷺ) forbidding the sale of fruit until its good condition is obvious.", "french": "", "indonesian": "", "russian": "", "urdu": "سہل بن سعد ساعدی رضی اﷲ عنہ سے روایت ہے عویمر عجلانی ،  عاصم بن عدی انصاری کے پاس آیا اور ان سے کہا", "grades": "", "reference": "", "international_number": "3743", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3744", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، وَابْنُ، بَشَّارٍ قَالاَ حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، حَدَّثَنَا شُعْبَةُ، عَنْ عَمْرِو بْنِ مُرَّةَ، عَنْ أَبِي الْبَخْتَرِيِّ، قَالَ سَأَلْتُ ابْنَ عَبَّاسٍ عَنْ بَيْعِ النَّخْلِ، فَقَالَ نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم عَنْ بَيْعِ النَّخْلِ حَتَّى يَأْكُلَ مِنْهُ أَوْ يُؤْكَلَ وَحَتَّى يُوزَنَ ‏.‏ قَالَ فَقُلْتُ مَا يُوزَنُ فَقَالَ رَجُلٌ عِنْدَهُ حَتَّى يَحْزَرَ ‏.‏", "bengali": "", "english": "I asked Ibn 'Abbas (Allah be pleased with them) about the sale of dates. He said: Allah's Messenger (ﷺ) forbade the sale of dates of the trees until one eats them or they are eaten (i. e. they are fit to be eaten) or until they are weighed (or measured). I said: What does it imply:\" Until it is weighed\"? Thereupon a person who was with him (Ibn Abbas) said: Until he is able to keep it with him (after plucking them).", "french": "", "indonesian": "", "russian": "", "urdu": "سہل بن سعدؓ سے روایت ہے عویمر انصاریؓ جو بنی عجلان میں سے تھا عاصم بن عدیؓ کے پاس آیا پھر بیان کیا ح", "grades": "", "reference": "", "international_number": "3744", "narrator_chain": "Abu Bakhtari reported:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3745", "arabic": "حَدَّثَنِي أَبُو كُرَيْبٍ، مُحَمَّدُ بْنُ الْعَلاَءِ حَدَّثَنَا مُحَمَّدُ بْنُ فُضَيْلٍ، عَنْ أَبِيهِ، عَنِ ابْنِ أَبِي، نُعْمٍ عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ لاَ تَبْتَاعُوا الثِّمَارَ حَتَّى يَبْدُوَ صَلاَحُهَا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "Do not sell the fruits until their good condition becomes evident.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira (Allah be pleased with him) reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3746", "arabic": "حَدَّثَنَا يَحْيَى بْنُ يَحْيَى، أَخْبَرَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ الزُّهْرِيِّ، ح وَحَدَّثَنَا ابْنُ، نُمَيْرٍ وَزُهَيْرُ بْنُ حَرْبٍ - وَاللَّفْظُ لَهُمَا - قَالاَ حَدَّثَنَا سُفْيَانُ، حَدَّثَنَا الزُّهْرِيُّ، عَنْ سَالِمٍ، عَنِ ابْنِ عُمَرَ، أَنَّ النَّبِيَّ صلى الله عليه وسلم نَهَى عَنْ بَيْعِ الثَّمَرِ حَتَّى يَبْدُوَ صَلاَحُهُ وَعَنْ بَيْعِ الثَّمَرِ بِالتَّمْرِ ‏.‏", "bengali": "", "english": "Ibn Umar (Allah be pleased with them) reported Allah's Apostle (ﷺ) forbidding the sale of fruits until their good condition becomes evident and the purchase of dates for dates.", "french": "", "indonesian": "", "russian": "", "urdu": "سعید بن جبیرؓ سے روایت ہے مجھ سے پوچھا گیا لعان کرنے والوں کا مسئلہ مصعب بن زبیر کی خلافت میں میں حی", "grades": "", "reference": "", "international_number": "3746", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3747", "arabic": "قَالَ ابْنُ عُمَرَ وَحَدَّثَنَا زَيْدُ بْنُ ثَابِتٍ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم رَخَّصَ فِي بَيْعِ الْعَرَايَا ‏.‏ زَادَ ابْنُ نُمَيْرٍ فِي رِوَايَتِهِ أَنْ تُبَاعَ ‏.‏", "bengali": "", "english": "Zaid b. Thabit (Allah be pleased with him) said that Allah's Messenger (ﷺ) gave a concession in case of the sale known as al-araya, there is an addition of the word an tuba'a in the hadith transmitted by Ibn Numair.", "french": "", "indonesian": "", "russian": "", "urdu": "اس سند سے ہی مندرجہ بالا روایت نقل کی گئی ہے ۔", "grades": "", "reference": "", "international_number": "3747", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3748", "arabic": "وَحَدَّثَنِي أَبُو الطَّاهِرِ، وَحَرْمَلَةُ، - وَاللَّفْظُ لِحَرْمَلَةَ - قَالاَ أَخْبَرَنَا ابْنُ وَهْبٍ، أَخْبَرَنِي يُونُسُ، عَنِ ابْنِ شِهَابٍ، حَدَّثَنِي سَعِيدُ بْنُ الْمُسَيَّبِ، وَأَبُو سَلَمَةَ بْنُ عَبْدِ الرَّحْمَنِ أَنَّ أَبَا هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ لاَ تَبْتَاعُوا الثَّمَرَ حَتَّى يَبْدُوَ صَلاَحُهُ وَلاَ تَبْتَاعُوا الثَّمَرَ بِالتَّمْرِ ‏\"\"‏ ‏.‏ قَالَ ابْنُ شِهَابٍ وَحَدَّثَنِي سَالِمُ بْنُ عَبْدِ اللَّهِ بْنِ عُمَرَ عَنْ أَبِيهِ عَنِ النَّبِيِّ صلى الله عليه وسلم مِثْلَهُ سَوَاءً ‏.‏\"", "bengali": "", "english": "Do not buy the fruit until their condition is clear, and do not buy the fresh dates. A hadith like this has been reported by Ibn 'Umar through another chain of transmitters.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira (Allah be pleased with him) reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3749", "arabic": "وَحَدَّثَنِي مُحَمَّدُ بْنُ رَافِعٍ، حَدَّثَنَا حُجَيْنُ بْنُ الْمُثَنَّى، حَدَّثَنَا اللَّيْثُ، عَنْ عُقَيْلٍ، عَنِ ابْنِ شِهَابٍ، عَنْ سَعِيدِ بْنِ الْمُسَيَّبِ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم نَهَى عَنْ بَيْعِ الْمُزَابَنَةِ وَالْمُحَاقَلَةِ وَالْمُزَابَنَةُ أَنْ يُبَاعَ ثَمَرُ النَّخْلِ بِالتَّمْرِ وَالْمُحَاقَلَةُ أَنْ يُبَاعَ الزَّرْعُ بِالْقَمْحِ وَاسْتِكْرَاءُ الأَرْضِ بِالْقَمْحِ ‏.‏ قَالَ وَأَخْبَرَنِي سَالِمُ بْنُ عَبْدِ اللَّهِ عَنْ رَسُولِ اللَّهِ صلى الله عليه وسلم أَنَّهُ قَالَ ‏ ‏ لاَ تَبْتَاعُوا الثَّمَرَ حَتَّى يَبْدُوَ صَلاَحُهُ وَلاَ تَبْتَاعُوا الثَّمَرَ بِالتَّمْرِ ‏\"\"‏ ‏.‏ وَقَالَ سَالِمٌ أَخْبَرَنِي عَبْدُ اللَّهِ، عَنْ زَيْدِ بْنِ ثَابِتٍ، عَنْ رَسُولِ اللَّهِ صلى الله عليه وسلم أَنَّهُ رَخَّصَ بَعْدَ ذَلِكَ فِي بَيْعِ الْعَرِيَّةِ بِالرُّطَبِ أَوْ بِالتَّمْرِ وَلَمْ يُرَخِّصْ فِي غَيْرِ ذَلِكَ.\"", "bengali": "", "english": "Do not sell fresh fruits on the trees until their good condition becomes manifest, and do not sell fresh dates on the trees against dry dates. Salim said: Abdullah informed me on the authority of Zaid b. Thabit, Allah's Messenger (ﷺ) having given concession afterwards in case of ariyya transactions by which dry dates can be exchanged with fresh dates, but he did not permit it in other cases.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Sa'id b. al-Musayyib said that Allah's Messenger (ﷺ) forbade the transaction of Af Muzabana and Muhaqala. Muzabana means that fresh dates on the trees should be sold against dry dates. Muhaqala implies that the wheat in the ear should be sold against the wheat and getting the land on rent for the wheat (produced in it). He (the narrator) said that the Prophet (ﷺ) had aid:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3750", "arabic": "حَدَّثَنَا يَحْيَى بْنُ يَحْيَى، قَالَ قَرَأْتُ عَلَى مَالِكٍ عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، عَنْ زَيْدِ، بْنِ ثَابِتٍ أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم رَخَّصَ لِصَاحِبِ الْعَرِيَّةِ أَنْ يَبِيعَهَا بِخَرْصِهَا مِنَ التَّمْرِ ‏.‏", "bengali": "", "english": "Zaid b. Thabit (Allah be pleased with him) reported Allah's Messenger (may peace he upon him) having given concession in case of 'ariyya for selling dry dates (with) fresh dates after measuring them out.", "french": "", "indonesian": "", "russian": "", "urdu": "سعید بن جبیر سے روایت ہے کہ میں نے ابن عمرؓ سے لعان کو پوچھا تو انہوں نے نقل کیا جناب رسول اﷲ ﷺ سے ا", "grades": "", "reference": "", "international_number": "3750", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3751", "arabic": "وَحَدَّثَنَا يَحْيَى بْنُ يَحْيَى، أَخْبَرَنَا سُلَيْمَانُ بْنُ بِلاَلٍ، عَنْ يَحْيَى بْنِ سَعِيدٍ، أَخْبَرَنِي نَافِعٌ، أَنَّهُ سَمِعَ عَبْدَ اللَّهِ بْنَ عُمَرَ، يُحَدِّثُ أَنَّ زَيْدَ بْنَ ثَابِتٍ، حَدَّثَهُ أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم رَخَّصَ فِي الْعَرِيَّةِ يَأْخُذُهَا أَهْلُ الْبَيْتِ بِخَرْصِهَا تَمْرًا يَأْكُلُونَهَا رُطَبًا ‏.‏", "bengali": "", "english": "Zaid b. Thabit reported that Allah's Messenger (ﷺ) give concession in case of 'ariyya transactions according to which the members of the household give dry dates according to a measure and then eat fresh dates (in exchange for it)", "french": "", "indonesian": "", "russian": "", "urdu": "سعید بن جبیر سے روایت ہے مصعب نے جدائی نہیں کی لعان کرنے والوں میں ۔  میں نے اس کا ذکر کیا عبداﷲ بن", "grades": "", "reference": "", "international_number": "3751", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3752", "arabic": "وَحَدَّثَنَاهُ مُحَمَّدُ بْنُ الْمُثَنَّى، حَدَّثَنَا عَبْدُ الْوَهَّابِ، قَالَ سَمِعْتُ يَحْيَى بْنَ سَعِيدٍ، يَقُولُ أَخْبَرَنِي نَافِعٌ، بِهَذَا الإِسْنَادِ مِثْلَهُ ‏.‏", "bengali": "", "english": "A hadith like this has been narrated on the authority of Nafi' with the same chain of transmitters.", "french": "", "indonesian": "", "russian": "", "urdu": "عبداﷲ بن عمر رضی اﷲ عنہ سے روایت ہے کہ ایک مرد نے لعانلعان کیا رسول اﷲ ﷺ کے زمانے میں پھر آپ نے جدائ", "grades": "", "reference": "", "international_number": "3752", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3753", "arabic": "وَحَدَّثَنَاهُ يَحْيَى بْنُ يَحْيَى، أَخْبَرَنَا هُشَيْمٌ، عَنْ يَحْيَى بْنِ سَعِيدٍ، بِهَذَا الإِسْنَادِ غَيْرَ أَنَّهُ قَالَ وَالْعَرِيَّةُ النَّخْلَةُ تُجْعَلُ لِلْقَوْمِ فَيَبِيعُونَهَا بِخَرْصِهَا تَمْرًا ‏.‏", "bengali": "", "english": "'Ariyya implies that date-palm trees should be donated to the people and then they sell it with a measure of dry dates.", "french": "", "indonesian": "", "russian": "", "urdu": "عبداﷲ بن عمرؓ سے روایت ہے رسول اﷲ ﷺ نے لعان کروایا درمیان ایک مرد انصاری اور اس کی عورت کے اور جدائی", "grades": "", "reference": "", "international_number": "3753", "narrator_chain": "Yahya b. Sa'id reported this hadith with the same chain of transmitters but with this change:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3754", "arabic": "وَحَدَّثَنَا مُحَمَّدُ بْنُ رُمْحِ بْنِ الْمُهَاجِرِ، حَدَّثَنَا اللَّيْثُ، عَنْ يَحْيَى بْنِ سَعِيدٍ، عَنْ نَافِعٍ، عَنْ عَبْدِ اللَّهِ بْنِ عُمَرَ، حَدَّثَنِي زَيْدُ بْنُ ثَابِتٍ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم رَخَّصَ فِي بَيْعِ الْعَرِيَّةِ بِخَرْصِهَا تَمْرًا ‏.‏ قَالَ يَحْيَى الْعَرِيَّةُ أَنْ يَشْتَرِيَ الرَّجُلُ ثَمَرَ النَّخَلاَتِ لِطَعَامِ أَهْلِهِ رُطَبًا بِخَرْصِهَا تَمْرًا ‏.‏", "bengali": "", "english": "'Ariyya implies that a person should buy fresh dates on the tree for his family to eat against a measure of dry dates.", "french": "", "indonesian": "", "russian": "", "urdu": "وہی جو اوپر گزرا ۔", "grades": "", "reference": "", "international_number": "3754", "narrator_chain": "Zaid b Thabit (Allah be pleased with him) reported that Allah's Messenger (ﷺ) gave concession in case of al-'ariyya transactions (for exchanging dates) for dates with measure. Yahya said:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3755", "arabic": "وَحَدَّثَنَا ابْنُ نُمَيْرٍ، حَدَّثَنَا أَبِي، حَدَّثَنَا عُبَيْدُ اللَّهِ، حَدَّثَنِي نَافِعٌ، عَنِ ابْنِ عُمَرَ، عَنْ زَيْدِ بْنِ ثَابِتٍ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم رَخَّصَ فِي الْعَرَايَا أَنْ تُبَاعَ بِخَرْصِهَا كَيْلاً ‏.‏", "bengali": "", "english": "Zaid b. Thabit (Allah be pleased with him) reported Allah's Messenger (ﷺ) granting concession in case of 'ariyya transactions and that implies selling of (dry dates for fresh dates) according to a measure.", "french": "", "indonesian": "", "russian": "", "urdu": "عبداﷲ بن مسعودؓ سے روایت ہے میں جمعہ کی رات کو مسجد میں تھا اتنے میں ایک مرد انصاری آیا اور بولا اگر", "grades": "", "reference": "", "international_number": "3755", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3756", "arabic": "وَحَدَّثَنَاهُ ابْنُ الْمُثَنَّى، حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، عَنْ عُبَيْدِ اللَّهِ، بِهَذَا الإِسْنَادِ وَقَالَ أَنْ تُؤْخَذَ بِخَرْصِهَا ‏.‏", "bengali": "", "english": "Ubaidullah reported this hadith with a slight change of words on the same authority (as quoted above).", "french": "", "indonesian": "", "russian": "", "urdu": "اعمش سے اس سند کے ساتھ اسی طرح منقول ہے ۔", "grades": "", "reference": "", "international_number": "3756", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3757", "arabic": "وَحَدَّثَنَا أَبُو الرَّبِيعِ، وَأَبُو كَامِلٍ قَالاَ حَدَّثَنَا حَمَّادٌ، ح وَحَدَّثَنِيهِ عَلِيُّ بْنُ حُجْرٍ، حَدَّثَنَا إِسْمَاعِيلُ، كِلاَهُمَا عَنْ أَيُّوبَ، عَنْ نَافِعٍ، بِهَذَا الإِسْنَادِ أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم رَخَّصَ فِي بَيْعِ الْعَرَايَا بِخَرْصِهَا ‏.‏", "bengali": "", "english": "Nafi, reported this hadith with the same chain of transmitters stating that Allah's Messengtr (ﷺ) granted concession in case of 'ariyya transactions (for exchange of the same commodity) with measure.", "french": "", "indonesian": "", "russian": "", "urdu": "محمد سے روایت ہے میں نے انس بن مالک سے پوچھا یہ سمجھ کر کہ ان کو معلوم ہے ۔  انہوں نے کہا کہ ہلال بن", "grades": "", "reference": "", "international_number": "3757", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3758", "arabic": "وَحَدَّثَنَا عَبْدُ اللَّهِ بْنُ مَسْلَمَةَ الْقَعْنَبِيُّ، حَدَّثَنَا سُلَيْمَانُ، - يَعْنِي ابْنَ بِلاَلٍ - عَنْ يَحْيَى، - وَهُوَ ابْنُ سَعِيدٍ - عَنْ بُشَيْرِ بْنِ يَسَارٍ، عَنْ بَعْضِ، أَصْحَابِ رَسُولِ اللَّهِ صلى الله عليه وسلم مِنْ أَهْلِ دَارِهِمْ مِنْهُمْ سَهْلُ بْنُ أَبِي حَثْمَةَ أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم نَهَى عَنْ بَيْعِ الثَّمَرِ بِالتَّمْرِ وَقَالَ ‏ ‏ ذَلِكَ الرِّبَا تِلْكَ الْمُزَابَنَةُ ‏\"\"‏ ‏.‏ إِلاَّ أَنَّهُ رَخَّصَ فِي بَيْعِ الْعَرِيَّةِ النَّخْلَةِ وَالنَّخْلَتَيْنِ يَأْخُذُهَا أَهْلُ الْبَيْتِ بِخَرْصِهَا تَمْرًا يَأْكُلُونَهَا رُطَبًا ‏.‏\"", "bengali": "", "english": "Bashair b. Yasir reported on the authority of some of the Companions of Allah's Messenger (ﷺ) among the members of his family among whom one was Sahl b. Abu Hathma that Allah's Messenger (ﷺ) forbade buying of fresh dates against dry dates and that it is Riba and this is Muzabana, but he made an exemption of 'ariyya (donations) of a tree or two in which case the members of a family sell dry dates and buy fresh dates for eating them.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3759", "arabic": "وَحَدَّثَنَا قُتَيْبَةُ بْنُ سَعِيدٍ، حَدَّثَنَا لَيْثٌ، ح وَحَدَّثَنَا ابْنُ رُمْحٍ، أَخْبَرَنَا اللَّيْثُ، عَنْ يَحْيَى، بْنِ سَعِيدٍ عَنْ بُشَيْرِ بْنِ يَسَارٍ، عَنْ أَصْحَابِ، رَسُولِ اللَّهِ صلى الله عليه وسلم أَنَّهُمْ قَالُوا رَخَّصَ رَسُولُ اللَّهِ صلى الله عليه وسلم فِي بَيْعِ الْعَرِيَّةِ بِخَرْصِهَا تَمْرًا ‏.‏", "bengali": "", "english": "Bushair b. Yasar reported on the authority of some of the Companion of Allah's Messenger (ﷺ) that he exempted the transactions, of 'ariyya (from the direct exchange of one kind) after measuring the dry dates (in exchange for fresh dates).", "french": "", "indonesian": "", "russian": "", "urdu": "ترجمہ دوسری روایت کا وہی ہے جو اوپر گزرا ۔  اس میں اتنا زیادہ ہے کہ وہ شخص جس کے ساتھ تہمت تھی موٹا", "grades": "", "reference": "", "international_number": "3759", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3760", "arabic": "وَحَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، وَإِسْحَاقُ بْنُ إِبْرَاهِيمَ، وَابْنُ أَبِي عُمَرَ، جَمِيعًا عَنِ الثَّقَفِيِّ، قَالَ سَمِعْتُ يَحْيَى بْنَ سَعِيدٍ، يَقُولُ أَخْبَرَنِي بُشَيْرُ بْنُ يَسَارٍ، عَنْ بَعْضِ، أَصْحَابِ رَسُولِ اللَّهِ صلى الله عليه وسلم مِنْ أَهْلِ دَارِهِ أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم نَهَى ‏.‏ فَذَكَرَ بِمِثْلِ حَدِيثِ سُلَيْمَانَ بْنِ بِلاَلٍ عَنْ يَحْيَى غَيْرَ أَنَّ إِسْحَاقَ وَابْنَ الْمُثَنَّى جَعَلاَ مَكَانَ الرِّبَا الزَّبْنَ وَقَالَ ابْنُ أَبِي عُمَرَ الرِّبَا ‏.‏", "bengali": "", "english": "Bushair b. Yasir reported on the authority of some of the Companions of Allah's Messenger (may peace be upon hinn) from among the members of his family that he forbade (the direct exchange of a commodity having different qualities) but with the change that Ishaq and Ibn al-Muthanna used the word Zabn in place of Riba and Ibn Abu 'Umar used the word Riba (interest).", "french": "", "indonesian": "", "russian": "", "urdu": "قاسم بن محمد سے روایت ہے ابن عباس رضی اﷲ عنہما کے سامنے لعان والوں کا ذکر ہوا تو عبداﷲ بن شداد نے کہ", "grades": "", "reference": "", "international_number": "3760", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3761", "arabic": "وَحَدَّثَنَاهُ عَمْرٌو النَّاقِدُ، وَابْنُ، نُمَيْرٍ قَالاَ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ يَحْيَى بْنِ، سَعِيدٍ عَنْ بُشَيْرِ بْنِ يَسَارٍ، عَنْ سَهْلِ بْنِ أَبِي حَثْمَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم نَحْوَ حَدِيثِهِمْ ‏.‏", "bengali": "", "english": "A hadith like this has been narrated on the authority of Sahl b. Abu Hathma.", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اﷲ عنہ سے روایت ہے سعد بن عبادہ انصاریؓ  ( انصار کے رئیس )  نے کہا یا رسول اﷲ ﷺ! اگر کو", "grades": "", "reference": "", "international_number": "3761", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3762", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَحَسَنٌ الْحُلْوَانِيُّ، قَالاَ حَدَّثَنَا أَبُو أُسَامَةَ، عَنِ الْوَلِيدِ، بْنِ كَثِيرٍ حَدَّثَنِي بُشَيْرُ بْنُ يَسَارٍ، مَوْلَى بَنِي حَارِثَةَ أَنَّ رَافِعَ بْنَ خَدِيجٍ، وَسَهْلَ بْنَ أَبِي حَثْمَةَ، حَدَّثَاهُ أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم نَهَى عَنِ الْمُزَابَنَةِ الثَّمَرِ بِالتَّمْرِ إِلاَّ أَصْحَابَ الْعَرَايَا فَإِنَّهُ قَدْ أَذِنَ لَهُمْ ‏.‏", "bengali": "", "english": "Sahl b. Abu Hathma reported Allah's Messenger (ﷺ) having forbidden Muzabana, i. e. exchange of fresh dates with dry dates. except in case of those to whom donations of some trees have been made. It is for them that concession has been given.", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اﷲ عنہ سے روایت ہے سعد بن عبادہؓ نے کہا یارسول اﷲ ﷺ! اگر میں اپنی بیوی کے پاس غیر مرد ک", "grades": "", "reference": "", "international_number": "3762", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3763", "arabic": "حَدَّثَنَا عَبْدُ اللَّهِ بْنُ مَسْلَمَةَ بْنِ قَعْنَبٍ، حَدَّثَنَا مَالِكٌ، ح وَحَدَّثَنَا يَحْيَى بْنُ يَحْيَى، - وَاللَّفْظُ لَهُ - قَالَ قُلْتُ لِمَالِكٍ حَدَّثَكَ دَاوُدُ بْنُ الْحُصَيْنِ، عَنْ أَبِي سُفْيَانَ، - مَوْلَى ابْنِ أَبِي أَحْمَدَ - عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم رَخَّصَ فِي بَيْعِ الْعَرَايَا بِخَرْصِهَا فِيمَا دُونَ خَمْسَةِ أَوْسُقٍ أَوْ فِي خَمْسَةِ - يَشُكُّ دَاوُدُ قَالَ خَمْسَةٌ أَوْ دُونَ خَمْسَةٍ - قَالَ نَعَمْ ‏.‏", "bengali": "", "english": "Abu Huraira (Allah be pleased with him) reported Allah's Messenger (ﷺ) having given exemption of 'ariyya transactions measuring less than five wasqs or up to five wasqs (the narrator Dawud is in doubt whether it was five or less than five).", "french": "", "indonesian": "", "russian": "", "urdu": "حضرت ابوہریرہ رضی اﷲ عنہ سے روایت ہے سعد بن عبادہؓ نے کہا  یارسول اﷲﷺ! اگر میں اپنی بیوی کے ساتھ کسی", "grades": "", "reference": "", "international_number": "3763", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3764", "arabic": "حَدَّثَنَا يَحْيَى بْنُ يَحْيَى التَّمِيمِيُّ، قَالَ قَرَأْتُ عَلَى مَالِكٍ عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم نَهَى عَنِ الْمُزَابَنَةِ وَالْمُزَابَنَةُ بَيْعُ الثَّمَرِ بِالتَّمْرِ كَيْلاً وَبَيْعُ الْكَرْمِ بِالزَّبِيبِ كَيْلاً ‏.‏", "bengali": "", "english": "Ibn Umar (Allah be pleased them) reported Allah's Messenger (ﷺ) having forbidden Muzabana, and Muzabana implies the selling of fresh dates for dry dates by measuring them out and the selling of raisins by measure for grapes.", "french": "", "indonesian": "", "russian": "", "urdu": "مغیرہ بن شعبہؓ سے روایت ہے سعد بن عبادہؓ نے کہا اگر میں اپنی بی بی کے پاس کسی مرد کو دیکھوں تو تلوار", "grades": "", "reference": "", "international_number": "3764", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3765", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَمُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، قَالاَ حَدَّثَنَا مُحَمَّدُ بْنُ، بِشْرٍ حَدَّثَنَا عُبَيْدُ اللَّهِ، عَنْ نَافِعٍ، أَنَّ عَبْدَ اللَّهِ، أَخْبَرَهُ أَنَّ النَّبِيَّ صلى الله عليه وسلم نَهَى عَنِ الْمُزَابَنَةِ بَيْعِ ثَمَرِ النَّخْلِ بِالتَّمْرِ كَيْلاً وَبَيْعِ الْعِنَبِ بِالزَّبِيبِ كَيْلاً وَبَيْعِ الزَّرْعِ بِالْحِنْطَةِ كَيْلاً ‏.‏", "bengali": "", "english": "'Abdullah (b. Umar) reported that Allah's Apostle (ﷺ) forbade Muzabana, i. e. buying of fresh dates (on) the trees for dry dates by measure, and the buying of grapes for raisins by measure and the selling of field of corn for corn by measure.", "french": "", "indonesian": "", "russian": "", "urdu": "اس سند سے بھی یہ حدیث مروی ہے اس روایت میں ’’غَیْرَ مُصْفَعٍ ‘  ‘  کے الفاظ ہیں اور ’عَنْہ ‘  ‘  نہی", "grades": "", "reference": "", "international_number": "3765", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3766", "arabic": "وَحَدَّثَنَاهُ أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا ابْنُ أَبِي زَائِدَةَ، عَنْ عُبَيْدِ اللَّهِ، بِهَذَا الإِسْنَادِ مِثْلَهُ.", "bengali": "", "english": "A hadith like this has been narrated on the authority of 'Ubaidullah with the same chain of transmitters.", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اﷲ عنہ سے روایت ہے ایک شخص بنی فزارہ میں سے آیا روسل اﷲ ﷺ کے پاس او رکہا میری جورو کو ا", "grades": "", "reference": "", "international_number": "3766", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3767", "arabic": "حَدَّثَنِي يَحْيَى بْنُ مَعِينٍ، وَهَارُونُ بْنُ عَبْدِ اللَّهِ، وَحُسَيْنُ بْنُ عِيسَى، قَالُوا حَدَّثَنَا أَبُو أُسَامَةَ، حَدَّثَنَا عُبَيْدُ اللَّهِ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم عَنِ الْمُزَابَنَةِ وَالْمُزَابَنَةُ بَيْعُ ثَمَرِ النَّخْلِ بِالتَّمْرِ كَيْلاً وَبَيْعُ الزَّبِيبِ بِالْعِنَبِ كَيْلاً وَعَنْ كُلِّ ثَمَرٍ بِخَرْصِهِ ‏.‏", "bengali": "", "english": "Ibn 'Umar (Allah be pleased with them) reported Allah's Messenger (ﷺ) having forbidden Muzabana, and Muzabana is the selling of dry dates by measure for fresh dates and the selling of raisins by measure for grapes and selling of all Ports of fruits on the basis of calculation.", "french": "", "indonesian": "", "russian": "", "urdu": "زہری نے ابن عینیہ کی حدیث کی مانند روایت کی اس میں اتنا فرق ہے کہ کہا اے رسول اﷲ ﷺ! میری عورت نے لڑک", "grades": "", "reference": "", "international_number": "3767", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3768", "arabic": "حَدَّثَنِي عَلِيُّ بْنُ حُجْرٍ السَّعْدِيُّ، وَزُهَيْرُ بْنُ حَرْبٍ، قَالاَ حَدَّثَنَا إِسْمَاعِيلُ، - وَهُوَ ابْنُ إِبْرَاهِيمَ - عَنْ أَيُّوبَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم نَهَى عَنِ الْمُزَابَنَةِ وَالْمُزَابَنَةُ أَنْ يُبَاعَ مَا فِي رُءُوسِ النَّخْلِ بِتَمْرٍ بِكَيْلٍ مُسَمًّى إِنْ زَادَ فَلِي وَإِنْ نَقَصَ فَعَلَىَّ ‏.‏", "bengali": "", "english": "Ibn 'Umar (Allah be pleased with them) reported Allah's Messenger (ﷺ) having forbidden Muzabana, and Muzabana implies the selling of dry dates for fresh dates on the tree with a definite measure (making it clear) that in case it increases, it belongs to me and if it is less, it is my responsibility.", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اﷲ عنہ سے روایت ہے کہ تحقیق ایک اعرابی آیا رسول اﷲ ﷺ کے پاس او رکہا اے رسول اﷲ ﷺ! میری", "grades": "", "reference": "", "international_number": "3768", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3769", "arabic": "وَحَدَّثَنَاهُ أَبُو الرَّبِيعِ، وَأَبُو كَامِلٍ قَالاَ حَدَّثَنَا حَمَّادٌ، حَدَّثَنَا أَيُّوبُ، بِهَذَا الإِسْنَادِ نَحْوَهُ ‏.‏", "bengali": "", "english": "A hadith like this has been transmitted on the authority of Ayyub.", "french": "", "indonesian": "", "russian": "", "urdu": "حضرت ابو ہریرہ رضی اﷲ عنہ نبی اکرم ﷺ سے اسی طرح کی روایت بیان کرتے ہیں ۔", "grades": "", "reference": "", "international_number": "3769", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3770", "arabic": "حَدَّثَنَا قُتَيْبَةُ بْنُ سَعِيدٍ، حَدَّثَنَا لَيْثٌ، ح وَحَدَّثَنِي مُحَمَّدُ بْنُ رُمْحٍ، أَخْبَرَنَا اللَّيْثُ، عَنْ نَافِعٍ، عَنْ عَبْدِ اللَّهِ، قَالَ نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم عَنِ الْمُزَابَنَةِ أَنْ يَبِيعَ ثَمَرَ حَائِطِهِ إِنْ كَانَتْ نَخْلاً بِتَمْرٍ كَيْلاً وَإِنْ كَانَ كَرْمًا أَنْ يَبِيعَهُ بِزَبِيبٍ كَيْلاً وَإِنْ كَانَ زَرْعًا أَنْ يَبِيعَهُ بِكَيْلِ طَعَامٍ ‏.‏ نَهَى عَنْ ذَلِكَ كُلِّهِ ‏.‏ وَفِي رِوَايَةِ قُتَيْبَةَ أَوْ كَانَ زَرْعًا.", "bengali": "", "english": "Abdullah (b. Umar) (Allah be pleased with them) reported Allah's Messenger (ﷺ) having forbidden Mazabana, and it implies that one should sell the fresh fruits of his orchard (for dry fruits) or, if it is fresh dates, for dry dates with a measure, or if it is grapes for raisins or if it is corn in the field for dry corn with a measure He (the Holy Prophet) in fact forbade all such transactions. Qutaiba has narrated it with a slight variation of words.", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ ‌بن ‌عمر ‌رضی ‌اللہ ‌عنہ ‌سے ‌روایت ‌ہے ‌رسول ‌اللہ ‌نے ‌فرمایا ‌جو ‌شخص ‌اپنا ‌حصہ ‌آزاد ‌ك", "grades": "", "reference": "", "international_number": "3770", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3771", "arabic": "وَحَدَّثَنِيهِ أَبُو الطَّاهِرِ، أَخْبَرَنَا ابْنُ وَهْبٍ، حَدَّثَنِي يُونُسُ، ح وَحَدَّثَنَاهُ ابْنُ رَافِعٍ، حَدَّثَنَا ابْنُ أَبِي فُدَيْكٍ، أَخْبَرَنِي الضَّحَّاكُ، ح وَحَدَّثَنِيهِ سُوَيْدُ بْنُ سَعِيدٍ، حَدَّثَنَا حَفْصُ بْنُ مَيْسَرَةَ، حَدَّثَنِي مُوسَى بْنُ عُقْبَةَ، كُلُّهُمْ عَنْ نَافِعٍ، بِهَذَا الإِسْنَادِ نَحْوَ حَدِيثِهِمْ.", "bengali": "", "english": "This hadith has been narrated on the authority of Nafi with another chain of transmitters.", "french": "", "indonesian": "", "russian": "", "urdu": "اس حدیث کی دوسری اسناد مذکورہیں  ۔", "grades": "", "reference": "", "international_number": "3771", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3772", "arabic": "حَدَّثَنَا يَحْيَى بْنُ يَحْيَى، قَالَ قَرَأْتُ عَلَى مَالِكٍ عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ مَنْ بَاعَ نَخْلاً قَدْ أُبِّرَتْ فَثَمَرَتُهَا لِلْبَائِعِ إِلاَّ أَنْ يَشْتَرِطَ الْمُبْتَاعُ ‏\"\".\"", "bengali": "", "english": "If anyone buys palm-trees after they have been fecundated the fruit belongs to the seller unless the buyer makes a proviso.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Ibn Umar (Allah be pleased with them) reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3773", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، ح وَحَدَّثَنَا ابْنُ نُمَيْرٍ، حَدَّثَنَا أَبِي، جَمِيعًا عَنْ عُبَيْدِ اللَّهِ، ح وَحَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، - وَاللَّفْظُ لَهُ - حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ، حَدَّثَنَا عُبَيْدُ اللَّهِ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ أَيُّمَا نَخْلٍ اشْتُرِيَ أُصُولُهَا وَقَدْ أُبِّرَتْ فَإِنَّ ثَمَرَهَا لِلَّذِي أَبَّرَهَا إِلاَّ أَنْ يَشْتَرِطَ الَّذِي اشْتَرَاهَا‏\"\"‏ ‏.‏\"", "bengali": "", "english": "Whichever tree is bought with its roots, and if it is fecundatedits fruit would belong to one who has grafted it except when the provision is laid down by the buyer.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Nafi reported on the authority of Ibn Umar (Allah be pleased with them) that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3774", "arabic": "وَحَدَّثَنَا قُتَيْبَةُ بْنُ سَعِيدٍ، حَدَّثَنَا لَيْثٌ، ح وَحَدَّثَنَا ابْنُ رُمْحٍ، أَخْبَرَنَا اللَّيْثُ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ النَّبِيَّ صلى الله عليه وسلم قَالَ ‏ ‏ أَيُّمَا امْرِئٍ أَبَّرَ نَخْلاً ثُمَّ بَاعَ أَصْلَهَا فَلِلَّذِي أَبَّرَ ثَمَرُ النَّخْلِ إِلاَّ أَنْ يَشْتَرِطَ الْمُبْتَاعُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "Whosoever grafts the tree and then sells its roots, its fruit will belong to one who grafts it except when provision is laid down by the buyer.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Ibn Umar (Allah be pleased with them) reported Allah's Apostle (ﷺ) as saying:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3775", "arabic": "وَحَدَّثَنَاهُ أَبُو الرَّبِيعِ، وَأَبُو كَامِلٍ قَالاَ حَدَّثَنَا حَمَّادٌ، ح وَحَدَّثَنِيهِ زُهَيْرُ بْنُ حَرْبٍ، حَدَّثَنَا إِسْمَاعِيلُ، كِلاَهُمَا عَنْ أَيُّوبَ، عَنْ نَافِعٍ، بِهَذَا الإِسْنَادِ نَحْوَهُ ‏.‏", "bengali": "", "english": "This hadith has been narrated on the authority of Nafi, with the same chain of transmitters.", "french": "", "indonesian": "", "russian": "", "urdu": "قتادہ ‌رضی ‌اللہ ‌عنہ ‌نے ‌ابن ‌ابی ‌عروبہ ‌كی ‌حدیث ‌كی ‌مانند ‌روایت ‌كی ‌اور ‌حدیث ‌میں ‌یہ ‌بھی", "grades": "", "reference": "", "international_number": "3775", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3776", "arabic": "حَدَّثَنَا يَحْيَى بْنُ يَحْيَى، وَمُحَمَّدُ بْنُ رُمْحٍ، قَالاَ أَخْبَرَنَا اللَّيْثُ، ح وَحَدَّثَنَا قُتَيْبَةُ بْنُ، سَعِيدٍ حَدَّثَنَا لَيْثٌ، عَنِ ابْنِ شِهَابٍ، عَنْ سَالِمِ بْنِ عَبْدِ اللَّهِ بْنِ عُمَرَ، عَنْ عَبْدِ اللَّهِ بْنِ عُمَرَ، قَالَ سَمِعْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم يَقُولُ ‏ ‏ مَنِ ابْتَاعَ نَخْلاً بَعْدَ أَنْ تُؤَبَّرَ فَثَمَرَتُهَا لِلَّذِي بَاعَهَا إِلاَّ أَنْ يَشْتَرِطَ الْمُبْتَاعُ وَمَنِ ابْتَاعَ عَبْدًا فَمَالُهُ لِلَّذِي بَاعَهُ إِلاَّ أَنْ يَشْتَرِطَ الْمُبْتَاعُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "He who buys a tree after it has been fecundated, its fruit belongs to one who sells it except when the provision has been laid down by the buyer (that it will belong to him), and he who buys a slave, his property belongs to one who sells him except when a provision has been laid down by the buyer (that it will be transferred to him with the slave).", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abdullah b. Umar (Allah be pleased with them) reported Allah's Massenger (ﷺ) as saying:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3777", "arabic": "وَحَدَّثَنَاهُ يَحْيَى بْنُ يَحْيَى، وَأَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ وَزُهَيْرُ بْنُ حَرْبٍ قَالَ يَحْيَى أَخْبَرَنَا وَقَالَ الآخَرَانِ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ الزُّهْرِيِّ، بِهَذَا الإِسْنَادِ مِثْلَهُ ‏.‏", "bengali": "", "english": "A hadith like this has been narrated on the authority of al Zuhri.", "french": "", "indonesian": "", "russian": "", "urdu": "لیث نے ہمیں ابن شہاب سے حدیث بیان کی ،  انہوں نے عروہ سے روایت کی ،  حضرت عائشہ رضی اللہ عنہا نے انہ", "grades": "", "reference": "", "international_number": "3777", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3778", "arabic": "وَحَدَّثَنِي حَرْمَلَةُ بْنُ يَحْيَى، أَخْبَرَنَا ابْنُ وَهْبٍ، أَخْبَرَنِي يُونُسُ، عَنِ ابْنِ شِهَابٍ، حَدَّثَنِي سَالِمُ بْنُ عَبْدِ اللَّهِ بْنِ عُمَرَ، أَنَّ أَبَاهُ، قَالَ سَمِعْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم يَقُولُ بِمِثْلِهِ ‏.‏", "bengali": "", "english": "Ibn Umar reported on the authority of his father as Allah's Apostle (ﷺ) saying so.", "french": "", "indonesian": "", "russian": "", "urdu": "یونس نے مجھے ابن شہاب سے خبر دی ،  انہوں نے عروہ بن زبیر سے ،  انہوں نے نبی صلی اللہ علیہ وسلم کی اہ", "grades": "", "reference": "", "international_number": "3778", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3779", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَمُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، وَزُهَيْرُ بْنُ حَرْبٍ، قَالُوا جَمِيعًا حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ ابْنِ جُرَيْجٍ، عَنْ عَطَاءٍ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، قَالَ نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم عَنِ الْمُحَاقَلَةِ وَالْمُزَابَنَةِ وَالْمُخَابَرَةِ وَعَنْ بَيْعِ الثَّمَرِ حَتَّى يَبْدُوَ صَلاَحُهُ وَلاَ يُبَاعُ إِلاَّ بِالدِّينَارِ وَالدِّرْهَمِ إِلاَّ الْعَرَايَا ‏.‏", "bengali": "", "english": "Jabir b. Abdullah (Allah be pleased with them) reported that Allah's Messenger (ﷺ) had forbidden Muhaqala. and Muzabana, Mukhibara and the sale of fruits until their good condition becomes clear, and (he commanded) that (commodities) should not be sold but for the dinar and dirham except in case of araya.", "french": "", "indonesian": "", "russian": "", "urdu": "ابواسامہ نے کہا :  ہمیں ہشام بن عروہ نے حدیث بیان کی ،  انہوں نے کہا :  مجھے میرے والد نے حضرت عائشہ", "grades": "", "reference": "", "international_number": "3779", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3780", "arabic": "وَحَدَّثَنَا عَبْدُ بْنُ حُمَيْدٍ، أَخْبَرَنَا أَبُو عَاصِمٍ، أَخْبَرَنَا ابْنُ جُرَيْجٍ، عَنْ عَطَاءٍ، وَأَبِي، الزُّبَيْرِ أَنَّهُمَا سَمِعَا جَابِرَ بْنَ عَبْدِ اللَّهِ، يَقُولُ نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم فَذَكَرَ بِمِثْلِهِ ‏.‏", "bengali": "", "english": "Jabir b. 'Abdullah (Allah be pleased with them) reported that Allah's Messenger (ﷺ) forbade the types of sales as described before.", "french": "", "indonesian": "", "russian": "", "urdu": "ابن نمیر ،  وکیع اور جریر سب نے ہشام بن عروہ سے اسی سند کے ساتھ ابواسامہ کی حدیث کے ہم معنی روایت بی", "grades": "", "reference": "", "international_number": "3780", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3781", "arabic": "حَدَّثَنَا إِسْحَاقُ بْنُ إِبْرَاهِيمَ الْحَنْظَلِيُّ، أَخْبَرَنَا مَخْلَدُ بْنُ يَزِيدَ الْجَزَرِيُّ، حَدَّثَنَا ابْنُ، جُرَيْجٍ أَخْبَرَنِي عَطَاءٌ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم نَهَى عَنِ الْمُخَابَرَةِ وَالْمُحَاقَلَةِ وَالْمُزَابَنَةِ وَعَنْ بَيْعِ الثَّمَرَةِ حَتَّى تُطْعِمَ وَلاَ تُبَاعُ إِلاَّ بِالدَّرَاهِمِ وَالدَّنَانِيرِ إِلاَّ الْعَرَايَا ‏.‏ قَالَ عَطَاءٌ فَسَّرَ لَنَا جَابِرٌ قَالَ أَمَّا الْمُخَابَرَةُ فَالأَرْضُ الْبَيْضَاءُ يَدْفَعُهَا الرَّجُلُ إِلَى الرَّجُلِ فَيُنْفِقُ فِيهَا ثُمَّ يَأْخُذُ مِنَ الثَّمَرِ ‏.‏ وَزَعَمَ أَنَّ الْمُزَابَنَةَ بَيْعُ الرُّطَبِ فِي النَّخْلِ بِالتَّمْرِ كَيْلاً ‏.‏ وَالْمُحَاقَلَةُ فِي الزَّرْعِ عَلَى نَحْوِ ذَلِكَ يَبِيعُ الزَّرْعَ الْقَائِمَ بِالْحَبِّ كَيْلاً ‏.‏", "bengali": "", "english": "Jabir explained (these terms) for us. As for Mukhabara it is this that a wasteland is given by a person to another and he makes an investment in it and then gets a share in the produce. According to him (Jabir), Muzabana is the sell of fresh dates on the tree for dry dates with a measure, and Muhaqala in agriculture implies that one should sell the standing crop for grains with a measure.", "french": "", "indonesian": "", "russian": "", "urdu": "ہشام بن عروہ نے ہمیں عبدالرحمٰن بن قاسم سے حدیث بیان کی ،  انہوں نے اپنے والد سے ،  انہوں نے حضرت عا", "grades": "", "reference": "", "international_number": "3781", "narrator_chain": "Jabir b. 'Abdullah (Allah be pleased with them) reported that Allah's Messenger (ﷺ) forbade Mukhabara and Muhaqala, and Muzabana, and the sale of the fruit until it is fit for eating, and its sale but with dirham and dinar. Exception is made in case of 'araya. Ata' said:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3782", "arabic": "حَدَّثَنَا إِسْحَاقُ بْنُ إِبْرَاهِيمَ، وَمُحَمَّدُ بْنُ أَحْمَدَ بْنِ أَبِي خَلَفٍ، كِلاَهُمَا عَنْ زَكَرِيَّاءَ، قَالَ ابْنُ أَبِي خَلَفٍ حَدَّثَنَا زَكَرِيَّاءُ بْنُ عَدِيٍّ، أَخْبَرَنَا عُبَيْدُ اللَّهِ، عَنْ زَيْدِ بْنِ أَبِي أُنَيْسَةَ، حَدَّثَنَا  أَبُو الْوَلِيدِ الْمَكِّيُّ، وَهُوَ جَالِسٌ عِنْدَ عَطَاءِ بْنِ أَبِي رَبَاحٍ عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم نَهَى عَنِ الْمُحَاقَلَةِ وَالْمُزَابَنَةِ وَالْمُخَابَرَةِ وَأَنْ تُشْتَرَى النَّخْلُ حَتَّى تُشْقِهَ - وَالإِشْقَاهُ أَنْ يَحْمَرَّ أَوْ يَصْفَرَّ أَوْ يُؤْكَلَ مِنْهُ شَىْءٌ - وَالْمُحَاقَلَةُ أَنْ يُبَاعَ الْحَقْلُ بِكَيْلٍ مِنَ الطَّعَامِ مَعْلُومٍ وَالْمُزَابَنَةُ أَنْ يُبَاعَ النَّخْلُ بِأَوْسَاقٍ مِنَ التَّمْرِ وَالْمُخَابَرَةُ الثُّلُثُ وَالرُّبُعُ وَأَشْبَاهُ ذَلِكَ ‏.‏ قَالَ زَيْدٌ قُلْتُ لِعَطَاءِ بْنِ أَبِي رَبَاحٍ أَسَمِعْتَ جَابِرَ بْنَ عَبْدِ اللَّهِ يَذْكُرُ هَذَا عَنْ رَسُولِ اللَّهِ صلى الله عليه وسلم قَالَ نَعَمْ ‏.‏", "bengali": "", "english": "Did You bear Jabir b. Abdullah (Allah be pleased with them) making a mention of it that he had heard it directly from Allah's Messenger (ﷺ)? He said: Yes.", "french": "", "indonesian": "", "russian": "", "urdu": "سماک نے عبدالرحمٰن بن قاسم سے ،  انہوں نے اپنے والد سے ،  انہوں نے حضرت عائشہ رضی اللہ عنہا سے روایت", "grades": "", "reference": "", "international_number": "3782", "narrator_chain": "Jabir b. Abdullah (Allah be pleased with them) reported Allah's Messenger (ﷺ) forbidding Muhaqala, and Muzabana, and Mukhabara, and the buying of date-palm until its fruit is ripened (ripening means that its colour becomes red or yellow, or it is fit for being eaten). And Muhaqala implies that crops in the field are bought for grains according to a customary measure. Muzabana implies that date-palm should be sold for dry dates by measuring them with wisqs, and al-Mukhabara is (a share), maybe one-third or one-fourth (in produce) or something like it. Zaid (one of the narrators) said to Ata' b. Abu Rabah (the other narrator):", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3783", "arabic": "وَحَدَّثَنَا عَبْدُ اللَّهِ بْنُ هَاشِمٍ، حَدَّثَنَا بَهْزٌ، حَدَّثَنَا سَلِيمُ بْنُ حَيَّانَ، حَدَّثَنَا سَعِيدُ بْنُ، مِينَاءَ عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، قَالَ نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم عَنِ الْمُزَابَنَةِ وَالْمُحَاقَلَةِ وَالْمُخَابَرَةِ وَعَنْ بَيْعِ الثَّمَرَةِ حَتَّى تُشْقِحَ ‏.‏ قَالَ قُلْتُ لِسَعِيدٍ مَا تُشْقِحُ قَالَ تَحْمَارُّ وَتَصْفَارُّ وَيُؤْكَلُ مِنْهَا ‏.‏", "bengali": "", "english": "What does ripening imply? He said: It meant that they become red or become yellow and are fit for eating.", "french": "", "indonesian": "", "russian": "", "urdu": "ہمیں محمد بن جعفر نے حدیث بیان کی ،  کہا :  ہمیں شعبہ نے حدیث بیان کی ،  انہوں نے کہا :  میں نے عبدا", "grades": "", "reference": "", "international_number": "3783", "narrator_chain": "Jabir b. Abdullah (Allah be pleased with them) reported Allah's Messenger (ﷺ) forbidding Muzabana and Muhaqala, and Mukhabara, and the sale of fruits until they are ripe. I (the narrator) said to Sa'id (the other narrator):", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3784", "arabic": "حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ عُمَرَ الْقَوَارِيرِيُّ، وَمُحَمَّدُ بْنُ عُبَيْدٍ الْغُبَرِيُّ، - وَاللَّفْظُ لِعُبَيْدِ اللَّهِ - قَالاَ حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ، حَدَّثَنَا أَيُّوبُ، عَنْ أَبِي الزُّبَيْرِ، وَسَعِيدِ بْنِ مِينَاءَ، عَنْ جَابِرِ بْنِ، عَبْدِ اللَّهِ قَالَ نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم عَنِ الْمُحَاقَلَةِ وَالْمُزَابَنَةِ وَالْمُعَاوَمَةِ وَالْمُخَابَرَةِ - قَالَ أَحَدُهُمَا بَيْعُ السِّنِينَ هِيَ الْمُعَاوَمَةُ - وَعَنِ الثُّنْيَا وَرَخَّصَ فِي الْعَرَايَا ‏.‏", "bengali": "", "english": "Sale years ahead is Mu'awama, and making exceptional but he made an exemption of araya.", "french": "", "indonesian": "", "russian": "", "urdu": "ابوداؤد نے ہمیں حدیث بیان کی ،   ( کہا :   )  ہمیں شعبہ نے اسی سند سے اسی کے ہم معنی حدیث بیان کی", "grades": "", "reference": "", "international_number": "3784", "narrator_chain": "Jabir b. Abdullah (Allah be pleased with them) reported Allah's Messenger (ﷺ) forbidding Muhaqala and Muzabana and Mu'awama and Mukhabara. (One of the narrators) 'said:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3785", "arabic": "وَحَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ حُجْرٍ، قَالاَ حَدَّثَنَا إِسْمَاعِيلُ، - وَهُوَ ابْنُ عُلَيَّةَ - عَنْ أَيُّوبَ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، عَنِ النَّبِيِّ صلى الله عليه وسلم ‏.‏ بِمِثْلِهِ غَيْرَ أَنَّهُ لاَ يَذْكُرُ بَيْعُ السِّنِينَ هِيَ الْمُعَاوَمَةُ ‏.‏", "bengali": "", "english": "A hadith like this has been narrated on the authority of Jabir (Allah be pleased with him) from Allah's Apostle (ﷺ). but he made no mention of transactions years (ahead) implying Mu'awama.", "french": "", "indonesian": "", "russian": "", "urdu": "عروہ نے حضرت عائشہ رضی اللہ عنہا سے روایت کی ،  انہوں نے کہا :  بریرہ رضی اللہ عنہا کا شوہر غلام تھا", "grades": "", "reference": "", "international_number": "3785", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3786", "arabic": "وَحَدَّثَنِي إِسْحَاقُ بْنُ مَنْصُورٍ، حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ عَبْدِ الْمَجِيدِ، حَدَّثَنَا رَبَاحُ بْنُ، أَبِي مَعْرُوفٍ قَالَ سَمِعْتُ عَطَاءً، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، قَالَ نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم عَنْ كِرَاءِ الأَرْضِ وَعَنْ بَيْعِهَا السِّنِينَ وَعَنْ بَيْعِ الثَّمَرِ حَتَّى يَطِيبَ ‏.‏", "bengali": "", "english": "Jabir b. Abdullah (Allah be pleased with them) reported that Allah's Messenger (ﷺ) forbade leasing of land, and selling ahead for years and selling of fruits before they become ripe.", "french": "", "indonesian": "", "russian": "", "urdu": "ربیعہ بن ابوعبدالرحمٰن نے قاسم بن محمد سے ،  انہوں نے نبی صلی اللہ علیہ وسلم کی اہلیہ حضرت عائشہ رضی", "grades": "", "reference": "", "international_number": "3786", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3787", "arabic": "وَحَدَّثَنِي أَبُو كَامِلٍ الْجَحْدَرِيُّ، حَدَّثَنَا حَمَّادٌ، - يَعْنِي ابْنَ زَيْدٍ - عَنْ مَطَرٍ الْوَرَّاقِ، عَنْ عَطَاءٍ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم نَهَى عَنْ كِرَاءِ الأَرْضِ ‏.‏", "bengali": "", "english": "Jabir b. Abdullah (Allah be pleased with them) reported Allah's Messenger (ﷺ) having forbidden the renting of land.", "french": "", "indonesian": "", "russian": "", "urdu": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ،  انہوں نے کہا :  حضرت عائشہ رضی اللہ عنہا نے چاہا کہ ایک لو", "grades": "", "reference": "", "international_number": "3787", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3788", "arabic": "وَحَدَّثَنَا عَبْدُ بْنُ حُمَيْدٍ، حَدَّثَنَا مُحَمَّدُ بْنُ الْفَضْلِ، - لَقَبُهُ عَارِمٌ وَهُوَ أَبُو النُّعْمَانِ السَّدُوسِيُّ - حَدَّثَنَا مَهْدِيُّ بْنُ مَيْمُونٍ، حَدَّثَنَا مَطَرٌ الْوَرَّاقُ، عَنْ عَطَاءٍ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنْ كَانَتْ لَهُ أَرْضٌ فَلْيَزْرَعْهَا فَإِنْ لَمْ يَزْرَعْهَا فَلْيُزْرِعْهَا أَخَاهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "He who has land should cultivate it himself, but if he does not cultivate it himself, then he should let his brother cultivate it.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Jabir b. Abdullah (Allah be pleased with them) reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3789", "arabic": "حَدَّثَنَا الْحَكَمُ بْنُ مُوسَى، حَدَّثَنَا هِقْلٌ، - يَعْنِي ابْنَ زِيَادٍ - عَنِ الأَوْزَاعِيِّ، عَنْ عَطَاءٍ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، قَالَ كَانَ لِرِجَالٍ فُضُولُ أَرَضِينَ مِنْ أَصْحَابِ رَسُولِ اللَّهِ صلى الله عليه وسلم فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنْ كَانَتْ لَهُ فَضْلُ أَرْضٍ فَلْيَزْرَعْهَا أَوْ لِيَمْنَحْهَا أَخَاهُ فَإِنْ أَبَى فَلْيُمْسِكْ أَرْضَهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "He, who has surplus land (in his possession) should cultivate it, or he should lend it to his brother for benefit, but if he refuses to accept it, he should retain it.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Jabir b. Abdullah (Allah be pleased with them) reported some of the Companions of Allah's Messenger (ﷺ) had surplus of land. Thereupon Allah's Messenger (ﷺ) said:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3790", "arabic": "وَحَدَّثَنِي مُحَمَّدُ بْنُ حَاتِمٍ، حَدَّثَنَا مُعَلَّى بْنُ مَنْصُورٍ الرَّازِيُّ، حَدَّثَنَا خَالِدٌ، أَخْبَرَنَا الشَّيْبَانِيُّ، عَنْ بُكَيْرِ بْنِ الأَخْنَسِ، عَنْ عَطَاءٍ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، قَالَ نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم أَنْ يُؤْخَذَ لِلأَرْضِ أَجْرٌ أَوْ حَظٌّ ‏.‏", "bengali": "", "english": "Jabir b. Abdullah (Allah be pleased with them) reported Allah's Messenger (ﷺ) having forbidden taking of rent or share of land.", "french": "", "indonesian": "", "russian": "", "urdu": "حضرت جابر بن عبداللہ رضی اللہ عنہ کہتے ہیں :  نبی صلی اللہ علیہ وسلم نے  ( میثاقِ مدینہ میں )  دیتوں", "grades": "", "reference": "", "international_number": "3790", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3791", "arabic": "حَدَّثَنَا ابْنُ نُمَيْرٍ، حَدَّثَنَا أَبِي، حَدَّثَنَا عَبْدُ الْمَلِكِ، عَنْ عَطَاءٍ، عَنْ جَابِرٍ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنْ كَانَتْ لَهُ أَرْضٌ فَلْيَزْرَعْهَا فَإِنْ لَمْ يَسْتَطِعْ أَنْ يَزْرَعَهَا وَعَجَزَ عَنْهَا فَلْيَمْنَحْهَا أَخَاهُ الْمُسْلِمَ وَلاَ يُؤَاجِرْهَا إِيَّاهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "He who has land should cultivate it, but if he does not find it possible to cultivate it, or finds himself helpless to do so, he should lend it to his Muslim brother, but he should not accept rent from him.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Jabir (Allah be pleased with him) reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3792", "arabic": "وَحَدَّثَنَا شَيْبَانُ بْنُ فَرُّوخَ، حَدَّثَنَا هَمَّامٌ، قَالَ سَأَلَ سُلَيْمَانُ بْنُ مُوسَى عَطَاءً فَقَالَ أَحَدَّثَكَ جَابِرُ بْنُ عَبْدِ اللَّهِ أَنَّ النَّبِيَّ صلى الله عليه وسلم قَالَ ‏ ‏ مَنْ كَانَتْ لَهُ أَرْضٌ فَلْيَزْرَعْهَا أَوْ لِيُزْرِعْهَا أَخَاهُ وَلاَ يُكْرِهَا ‏\"\"‏ ‏.‏ قَالَ نَعَمْ ‏.‏\"", "bengali": "", "english": "Did Jabir b. 'Abdullah (Allah be pleased with them) reported Allah's Apostle (ﷺ) as saying:\" He who has land should cultivate it himself, or let his brother cultivate it, and should not give on rent\"? He said: Yes.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Sulaiman b. Musa asked Ata':", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3793", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا سُفْيَانُ، عَنْ عَمْرٍو، عَنْ جَابِرٍ، أَنَّ النَّبِيَّ صلى الله عليه وسلم نَهَى عَنِ الْمُخَابَرَةِ ‏.‏", "bengali": "", "english": "Jabir (Allah be pleased with him) reported Allah's Apostle (ﷺ) having forbidden Mukhabara.", "french": "", "indonesian": "", "russian": "", "urdu": "شیبان نے اعمش سے اسی سند کے ساتھ حدیث بیان کی ،  البتہ انہوں نے کہا :   \" جس نے اپنے آزاد کرنے والوں", "grades": "", "reference": "", "international_number": "3793", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3794", "arabic": "وَحَدَّثَنِي حَجَّاجُ بْنُ الشَّاعِرِ، حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ عَبْدِ الْمَجِيدِ، حَدَّثَنَا سَلِيمُ بْنُ، حَيَّانَ حَدَّثَنَا سَعِيدُ بْنُ مِينَاءَ، قَالَ سَمِعْتُ جَابِرَ بْنَ عَبْدِ اللَّهِ، يَقُولُ إِنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ مَنْ كَانَ لَهُ فَضْلُ أَرْضٍ فَلْيَزْرَعْهَا أَوْ لِيُزْرِعْهَا أَخَاهُ وَلاَ تَبِيعُوهَا ‏\"\"‏ ‏.‏ فَقُلْتُ لِسَعِيدٍ مَا قَوْلُهُ وَلاَ تَبِيعُوهَا يَعْنِي الْكِرَاءَ ‏.‏ قَالَ نَعَمْ ‏.‏\"", "bengali": "", "english": "He who has surplus of land should either cultivate it himself, or let his brother cultivate it, an should not sell it. I (the narrator) said to Sa'id: What does his statement\" do not sell it\" mean? Does it imply\" rent\"? He said: Yes.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Jabir b. Abdullah (Allah be pleased with them) heard Allah's Messenger (ﷺ) say:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3795", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ يُونُسَ، حَدَّثَنَا زُهَيْرٌ، حَدَّثَنَا أَبُو الزُّبَيْرِ، عَنْ جَابِرٍ، قَالَ كُنَّا نُخَابِرُ عَلَى عَهْدِ رَسُولِ اللَّهِ صلى الله عليه وسلم فَنُصِيبُ مِنَ الْقِصْرِيِّ وَمِنْ كَذَا فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنْ كَانَتْ لَهُ أَرْضٌ فَلْيَزْرَعْهَا أَوْ فَلْيُحْرِثْهَا أَخَاهُ وَإِلاَّ فَلْيَدَعْهَا‏\"\"‏ ‏.‏\"", "bengali": "", "english": "We used to cultivate land on rent during the lifetime of Allah's Apostle (ﷺ) and we got a share out of the grain left in the ears after threshing them and something unspecified. Allah's Messenger (ﷺ) said: He who has land should cultivate it or let his brother till it, otherwise he should leave it.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Jabir b. 'Abdullah reported:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3796", "arabic": "حَدَّثَنِي أَبُو الطَّاهِرِ، وَأَحْمَدُ بْنُ عِيسَى، جَمِيعًا عَنِ ابْنِ وَهْبٍ، - قَالَ ابْنُ عِيسَى حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، - حَدَّثَنِي هِشَامُ بْنُ سَعْدٍ، أَنَّ أَبَا الزُّبَيْرِ الْمَكِّيَّ، حَدَّثَهُ قَالَ سَمِعْتُ جَابِرَ بْنَ عَبْدِ اللَّهِ، يَقُولُ كُنَّا فِي زَمَانِ رَسُولِ اللَّهِ صلى الله عليه وسلم نَأْخُذُ الأَرْضَ بِالثُّلُثِ أَوِ الرُّبُعِ بِالْمَاذِيَانَاتِ فَقَامَ رَسُولُ اللَّهِ صلى الله عليه وسلم فِي ذَلِكَ فَقَالَ ‏ ‏ مَنْ كَانَتْ لَهُ أَرْضٌ فَلْيَزْرَعْهَا فَإِنْ لَمْ يَزْرَعْهَا فَلْيَمْنَحْهَا أَخَاهُ فَإِنْ لَمْ يَمْنَحْهَا أَخَاهُ فَلْيُمْسِكْهَا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "We used to get land (on rent) during the lifetime of Allah's Messeuge, (ﷺ) with a share of one-third or one-fourth (of the produce from the land irrigated) with the help of canals. Thereupon Allah's Messenger (ﷺ) stood up (to address) and said: HRe who has land should cultivate it, and if he does not cultivate it, he should lend it to his brother, and if he does not lend it to his brother, he should then retain it.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Jabir b. Abdullah (Allah be pleased with them) reported:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3797", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، حَدَّثَنَا يَحْيَى بْنُ حَمَّادٍ، حَدَّثَنَا أَبُو عَوَانَةَ، عَنْ سُلَيْمَانَ، حَدَّثَنَا أَبُو سُفْيَانَ، عَنْ جَابِرٍ، قَالَ سَمِعْتُ النَّبِيَّ صلى الله عليه وسلم يَقُولُ ‏ ‏ مَنْ كَانَتْ لَهُ أَرْضٌ فَلْيَهَبْهَا أَوْ لِيُعِرْهَا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "I heard Allah's Apostle (ﷺ) as saying: He who has (surplus) land should donate it (to others), or lend it.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Jabir (Allah he pleased with him) reported:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3798", "arabic": "وَحَدَّثَنِيهِ حَجَّاجُ بْنُ الشَّاعِرِ، حَدَّثَنَا أَبُو الْجَوَّابِ، حَدَّثَنَا عَمَّارُ بْنُ رُزَيْقٍ، عَنِ الأَعْمَشِ، بِهَذَا الإِسْنَادِ غَيْرَ أَنَّهُ قَالَ ‏ ‏ فَلْيَزْرَعْهَا أَوْ فَلْيُزْرِعْهَا رَجُلاً ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "This hadith has been narrated on the authority of A'mash with the same chain of transmitters, but with a slight change of words.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3799", "arabic": "وَحَدَّثَنِي هَارُونُ بْنُ سَعِيدٍ الأَيْلِيُّ، حَدَّثَنَا ابْنُ وَهْبٍ، أَخْبَرَنِي عَمْرٌو، - وَهُوَ ابْنُ الْحَارِثِ - أَنَّ بُكَيْرًا، حَدَّثَهُ أَنَّ عَبْدَ اللَّهِ بْنَ أَبِي سَلَمَةَ حَدَّثَهُ عَنِ النُّعْمَانِ بْنِ أَبِي عَيَّاشٍ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم نَهَى عَنْ كِرَاءِ الأَرْضِ ‏.‏ قَالَ بُكَيْرٌ وَحَدَّثَنِي نَافِعٌ، أَنَّهُ سَمِعَ ابْنَ عُمَرَ، يَقُولُ كُنَّا نُكْرِي أَرْضَنَا ثُمَّ تَرَكْنَا ذَلِكَ حِينَ سَمِعْنَا حَدِيثَ رَافِعِ بْنِ خَدِيجٍ ‏.‏\"", "bengali": "", "english": "Nafi` reported to me that he heard Ibn `Umar (Allah be pleased with them) saying: We usedto give land on rent; we then abandoned this practice when we heard the hadith of Rafi` b. Khadij.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Jabir b. `Abdullah (Allah be pleased with them) reportedthat Allah's Messenger (ﷺ) had forbidden renting of land. Bukair (one of the narrators) said:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3800", "arabic": "وَحَدَّثَنَا يَحْيَى بْنُ يَحْيَى، أَخْبَرَنَا أَبُو خَيْثَمَةَ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، قَالَ نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم عَنْ بَيْعِ الأَرْضِ الْبَيْضَاءِ سَنَتَيْنِ أَوْ ثَلاَثًا ‏.‏", "bengali": "", "english": "Jabir (Allah be pleased with him) reported Allah's Messenger (ﷺ) forbidding the selling (renting of) uncultivated land for two years or three.", "french": "", "indonesian": "", "russian": "", "urdu": "وکیع ،  عبداللہ بن نمیر اور ابو احمد زبیری سب نے سفیان سے ،  انہوں نے سہیل سے اسی سند کے ساتھ اسی کے", "grades": "", "reference": "", "international_number": "3800", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3801", "arabic": "وَحَدَّثَنَا سَعِيدُ بْنُ مَنْصُورٍ، وَأَبُو بَكْرِ بْنُ شَيْبَةَ وَعَمْرٌو النَّاقِدُ وَزُهَيْرُ بْنُ حَرْبٍ قَالُوا حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ حُمَيْدٍ الأَعْرَجِ، عَنْ سُلَيْمَانَ بْنِ عَتِيقٍ، عَنْ جَابِرٍ، قَالَ نَهَى النَّبِيُّ صلى الله عليه وسلم عَنْ بَيْعِ السِّنِينَ ‏.‏ وَفِي رِوَايَةِ ابْنِ أَبِي شَيْبَةَ عَنْ بَيْعِ الثَّمَرِ سِنِينَ ‏.‏", "bengali": "", "english": "\" Selling of the fruits (on the tree) in advance for two years.\"", "french": "", "indonesian": "", "russian": "", "urdu": "محمد بن یحییٰ بن حبان نے اعرج سے ،  انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی", "grades": "", "reference": "", "international_number": "3801", "narrator_chain": "Jabir (Allah be pleased with him) reported Allah's Apostle (ﷺ) forbidding selling of (produce) in advance for two years, and in the narmtion of Ibu Abd Shaiba (the words are):", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3802", "arabic": "حَدَّثَنَا حَسَنُ بْنُ عَلِيٍّ الْحُلْوَانِيُّ، حَدَّثَنَا أَبُو تَوْبَةَ، حَدَّثَنَا مُعَاوِيَةُ، عَنْ يَحْيَى بْنِ، أَبِي كَثِيرٍ عَنْ أَبِي سَلَمَةَ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنْ كَانَتْ لَهُ أَرْضٌ فَلْيَزْرَعْهَا أَوْ لِيَمْنَحْهَا أَخَاهُ فَإِنْ أَبَى فَلْيُمْسِكْ أَرْضَهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "He who has land should cultivate it or lend it to his brother, but if he refuses, he should retain his land.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira (Allah be pleased with him) reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3803", "arabic": "وَحَدَّثَنَا الْحَسَنُ الْحُلْوَانِيُّ، حَدَّثَنَا أَبُو تَوْبَةَ، حَدَّثَنَا مُعَاوِيَةُ، عَنْ يَحْيَى بْنِ أَبِي كَثِيرٍ، أَنَّ يَزِيدَ بْنَ نُعَيْمٍ، أَخْبَرَهُ أَنَّ جَابِرَ بْنَ عَبْدِ اللَّهِ أَخْبَرَهُ أَنَّهُ، سَمِعَ رَسُولَ اللَّهِ صلى الله عليه وسلم يَنْهَى عَنِ الْمُزَابَنَةِ وَالْحُقُولِ ‏.‏ فَقَالَ جَابِرُ بْنُ عَبْدِ اللَّهِ الْمُزَابَنَةُ الثَّمَرُ بِالتَّمْرِ ‏.‏ وَالْحُقُولُ كِرَاءُ الأَرْضِ ‏.‏", "bengali": "", "english": "I heard Allah's Messenger (ﷺ) forbidding Muzabana, and Huqul. Jabir b. Abdullah (Allah be pleased with them) said: Muzabana means the selling of fruits for dry dates and Huqul is the renting of land.", "french": "", "indonesian": "", "russian": "", "urdu": "حفص بن عاصم نے حضرت ابوہریرہ رضی اللہ عنہ سے اور انہوں نے نبی صلی اللہ علیہ وسلم سے اسی کے مانند روا", "grades": "", "reference": "", "international_number": "3803", "narrator_chain": "Jabir b. Abdullah (Allah be pleased with them) reported:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3804", "arabic": "حَدَّثَنَا قُتَيْبَةُ بْنُ سَعِيدٍ، حَدَّثَنَا يَعْقُوبُ، - يَعْنِي ابْنَ عَبْدِ الرَّحْمَنِ الْقَارِيَّ - عَنْ سُهَيْلِ بْنِ أَبِي صَالِحٍ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم عَنِ الْمُحَاقَلَةِ وَالْمُزَابَنَةِ ‏.", "bengali": "", "english": "Abu Huraira (Allah be pleased with him) reported Allah's Messenger (ﷺ) forbidding Muhaqala and Muzabana.", "french": "", "indonesian": "", "russian": "", "urdu": "ابوصالح نے حضرت ابوہریرہ رضی اللہ عنہ سے اور انہوں نے نبی صلی اللہ علیہ وسلم سے اسی کے مانند روایت ک", "grades": "", "reference": "", "international_number": "3804", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3805", "arabic": "وَحَدَّثَنِي أَبُو الطَّاهِرِ، أَخْبَرَنَا ابْنُ وَهْبٍ، أَخْبَرَنِي مَالِكُ بْنُ أَنَسٍ، عَنْ دَاوُدَ بْنِ الْحُصَيْنِ، أَنَّ أَبَا سُفْيَانَ، مَوْلَى ابْنِ أَبِي أَحْمَدَ أَخْبَرَهُ أَنَّهُ، سَمِعَ أَبَا سَعِيدٍ الْخُدْرِيَّ، يَقُولُ نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم عَنِ الْمُزَابَنَةِ وَالْمُحَاقَلَةِ ‏.‏ وَالْمُزَابَنَةُ اشْتِرَاءُ الثَّمَرِ فِي رُءُوسِ النَّخْلِ ‏.‏ وَالْمُحَاقَلَةُ كِرَاءُ الأَرْضِ ‏.‏", "bengali": "", "english": "Abu Sa'id al-Khudri (Allah be pleased with him) reported Allah's Messenger (ﷺ) having forbidden Mazabana and Muhaqala. Muzibana means the buying of fruits on the trees and Muhaqala is the renting of land.", "french": "", "indonesian": "", "russian": "", "urdu": "عمرو بن دینار نے عطاء بن میناء سے روایت کی کہ انہوں نے ان  ( عطاء )  کو حضرت ابوہریرہ رضی اللہ عنہ س", "grades": "", "reference": "", "international_number": "3805", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3806", "arabic": "حَدَّثَنَا يَحْيَى بْنُ يَحْيَى، وَأَبُو الرَّبِيعِ الْعَتَكِيُّ، قَالَ أَبُو الرَّبِيعِ حَدَّثَنَا وَقَالَ، يَحْيَى أَخْبَرَنَا حَمَّادُ بْنُ زَيْدٍ، عَنْ عَمْرٍو، قَالَ سَمِعْتُ ابْنَ عُمَرَ، يَقُولُ كُنَّا لاَ نَرَى بِالْخِبْرِ بَأْسًا حَتَّى كَانَ عَامُ أَوَّلَ فَزَعَمَ رَافِعٌ أَنَّ نَبِيَّ اللَّهِ صلى الله عليه وسلم نَهَى عَنْهُ ‏.‏", "bengali": "", "english": "I heard Ibn Umar (Allah be pleased with them) say: We did not see any harm in renting of the land, but as the first year was over Rafi' alleged Allah's Apostle (ﷺ) having forbidden that.", "french": "", "indonesian": "", "russian": "", "urdu": "یونس نے مجھے ابن شہاب سے خبر دی ،  انہوں نے کہا :  مجھے عامر بن سعد بن ابی وقاص نے بتایا کہ حضرت ابو", "grades": "", "reference": "", "international_number": "3806", "narrator_chain": "Zaid b. Amr reported:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3807", "arabic": "وَحَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا سُفْيَانُ، ح وَحَدَّثَنِي عَلِيُّ بْنُ حُجْرٍ، وَإِبْرَاهِيمُ، بْنُ دِينَارٍ قَالاَ حَدَّثَنَا إِسْمَاعِيلُ، - وَهُوَ ابْنُ عُلَيَّةَ - عَنْ أَيُّوبَ، ح وَحَدَّثَنَا إِسْحَاقُ بْنُ إِبْرَاهِيمَ، أَخْبَرَنَا وَكِيعٌ، حَدَّثَنَا سُفْيَانُ، كُلُّهُمْ عَنْ عَمْرِو بْنِ دِينَارٍ، بِهَذَا الإِسْنَادِ ‏.‏ مِثْلَهُ وَزَادَ فِي حَدِيثِ ابْنِ عُيَيْنَةَ فَتَرَكْنَاهُ مِنْ أَجْلِهِ ‏.‏", "bengali": "", "english": "\" We abandoned it (renting) on account of that.\"", "french": "", "indonesian": "", "russian": "", "urdu": "صالح نے ابن شہاب سے اسی سند کے ساتھ یہی حدیث بیان کی", "grades": "", "reference": "", "international_number": "3807", "narrator_chain": "This hadith has been narrated on the authority of Amr b. Dinar with the same chain of transmitters but (in) the hadith transmitted on the authority of 'Uyainah (the words are):", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3808", "arabic": "وَحَدَّثَنِي عَلِيُّ بْنُ حُجْرٍ، حَدَّثَنَا إِسْمَاعِيلُ، عَنْ أَيُّوبَ، عَنْ أَبِي الْخَلِيلِ، عَنْ مُجَاهِدٍ، قَالَ قَالَ ابْنُ عُمَرَ لَقَدْ مَنَعَنَا رَافِعٌ نَفْعَ أَرْضِنَا ‏.‏", "bengali": "", "english": "Rafi forbade us from benefitting from our land (in the form of rent).", "french": "", "indonesian": "", "russian": "", "urdu": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ،  انہوں نے کہا :  رسول اللہ صلی اللہ علیہ وسلم نے کنکر پھینک", "grades": "", "reference": "", "international_number": "3808", "narrator_chain": "Ibn 'Umar (Allah be pleased with them) reported:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3809", "arabic": "وَحَدَّثَنَا يَحْيَى بْنُ يَحْيَى، أَخْبَرَنَا يَزِيدُ بْنُ زُرَيْعٍ، عَنْ أَيُّوبَ، عَنْ نَافِعٍ، أَنَّ ابْنَ عُمَرَ، كَانَ يُكْرِي مَزَارِعَهُ عَلَى عَهْدِ رَسُولِ اللَّهِ صلى الله عليه وسلم وَفِي إِمَارَةِ أَبِي بَكْرٍ وَعُمَرَ وَعُثْمَانَ وَصَدْرًا مِنْ خِلاَفَةِ مُعَاوِيَةَ حَتَّى بَلَغَهُ فِي آخِرِ خِلاَفَةِ مُعَاوِيَةَ أَنَّ رَافِعَ بْنَ خَدِيجٍ يُحَدِّثُ فِيهَا بِنَهْىٍ عَنِ النَّبِيِّ صلى الله عليه وسلم فَدَخَلَ عَلَيْهِ وَأَنَا مَعَهُ فَسَأَلَهُ فَقَالَ كَانَ رَسُولُ اللَّهِ صلى الله عليه وسلم يَنْهَى عَنْ كِرَاءِ الْمَزَارِعِ ‏.‏ فَتَرَكَهَا ابْنُ عُمَرَ بَعْدُ ‏.‏ وَكَانَ إِذَا سُئِلَ عَنْهَا بَعْدُ قَالَ زَعَمَ رَافِعُ بْنُ خَدِيجٍ أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم نَهَى عَنْهَا ‏.‏", "bengali": "", "english": "Allah's Messenger (ﷺ) used to forbid the renting of land. So Ibn Umar (Allah be pleased with them) abandoned it, and subsequently whenever he was asked about it, he said: Rafi b. Khadij (Allah be pleased with him) alleged that Allah's Messenger (ﷺ) forbade it.", "french": "", "indonesian": "", "russian": "", "urdu": "لیث نے نافع سے ،  انہوں نے حضرت عبداللہ  ( بن عمر رضی اللہ عنہ )  سے اور انہوں نے رسول اللہ صلی اللہ", "grades": "", "reference": "", "international_number": "3809", "narrator_chain": "Nafi reported that Ibn Umar (Allah be pleased with them) rented his land during the lifetime of Allah's Messenger (ﷺ) and during the caliphate of Abu Bakr and that of Umar and that of Uthman (Allah be pleased with them) and during the early period of Muawiya's caliphate until at the end of Muawiya's reign, it reached him (Ibn 'Umar) that Rafi b. Khadij (Allah be pleased with him) narratted (a hadith) in which (there was a decree) of prohibition by Allah's Apostle (ﷺ). He (Ibn 'Umar) went to him (Rafi b. Khadij) and I was with him and he asked him, whereupon he said:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3810", "arabic": "وَحَدَّثَنَا أَبُو الرَّبِيعِ، وَأَبُو كَامِلٍ قَالاَ حَدَّثَنَا حَمَّادٌ، ح وَحَدَّثَنِي عَلِيُّ بْنُ حُجْرٍ، حَدَّثَنَا إِسْمَاعِيلُ، كِلاَهُمَا عَنْ أَيُّوبَ، بِهَذَا الإِسْنَادِ ‏.‏ مِثْلَهُ وَزَادَ فِي حَدِيثِ ابْنِ عُلَيَّةَ قَالَ فَتَرَكَهَا ابْنُ عُمَرَ بَعْدَ ذَلِكَ فَكَانَ لاَ يُكْرِيهَا ‏.‏", "bengali": "", "english": "Ibn Umar abandoned it afterwards and he did not rent it (the land).", "french": "", "indonesian": "", "russian": "", "urdu": "عبیداللہ سے روایت ہے ،  انہوں نے کہا :  مجھے نافع نے حضرت ابن عمر رضی اللہ عنہ سے خبر دی ،  انہوں نے", "grades": "", "reference": "", "international_number": "3810", "narrator_chain": "This hadith has been narrated on the authority of Ayyub and he made an addition in the hadith narrated by Ibn Ulayya in which he said:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3811", "arabic": "وَحَدَّثَنَا ابْنُ نُمَيْرٍ، حَدَّثَنَا أَبِي، حَدَّثَنَا عُبَيْدُ اللَّهِ، عَنْ نَافِعٍ، قَالَ ذَهَبْتُ مَعَ ابْنِ عُمَرَ إِلَى رَافِعِ بْنِ خَدِيجٍ حَتَّى أَتَاهُ بِالْبَلاَطِ فَأَخْبَرَهُ أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم نَهَى عَنْ كِرَاءِ الْمَزَارِعِ ‏.‏", "bengali": "", "english": "I went to Rafi b. Khadij in the company of Ibn 'Umar (All be pleased with them) until he (Ibn 'Umar) came to him at Balat (a place near Prophet's Mosque at Medina) and he (Rafi b. Khadij) informed him that Allah's Messenger (ﷺ) had forbidden the renting of land.", "french": "", "indonesian": "", "russian": "", "urdu": "امام مالک نے نافع سے ،  انہوں نے حضرت ابن عمر رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ علیہ وس", "grades": "", "reference": "", "international_number": "3811", "narrator_chain": "Nafi reported:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3812", "arabic": "وَحَدَّثَنِي ابْنُ أَبِي خَلَفٍ، وَحَجَّاجُ بْنُ الشَّاعِرِ، قَالاَ حَدَّثَنَا زَكَرِيَّاءُ بْنُ عَدِيٍّ، أَخْبَرَنَا عُبَيْدُ اللَّهِ بْنُ عَمْرٍو، عَنْ زَيْدٍ، عَنِ الْحَكَمِ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّهُ أَتَى رَافِعًا فَذَكَرَ هَذَا الْحَدِيثَ عَنِ النَّبِيِّ صلى الله عليه وسلم ‏.‏", "bengali": "", "english": "Nafi, reported from Ibn Umar (Allah be pleated with them) that he came to Rafi and he narrated this hadith from Allah's Apostle (ﷺ).", "french": "", "indonesian": "", "russian": "", "urdu": "عبیداللہ نے کہا :  مجھے نافع نے حضرت ابن عمر رضی اللہ عنہ سے خبر دی ،  انہوں نے نبی صلی اللہ علیہ وس", "grades": "", "reference": "", "international_number": "3812", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3813", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، حَدَّثَنَا حُسَيْنٌ، - يَعْنِي ابْنَ حَسَنِ بْنِ يَسَارٍ - حَدَّثَنَا ابْنُ، عَوْنٍ عَنْ نَافِعٍ، أَنَّ ابْنَ عُمَرَ، كَانَ يَأْجُرُ الأَرْضَ - قَالَ - فَنُبِّئَ حَدِيثًا عَنْ رَافِعِ بْنِ خَدِيجٍ - قَالَ - فَانْطَلَقَ بِي مَعَهُ إِلَيْهِ - قَالَ - فَذَكَرَ عَنْ بَعْضِ عُمُومَتِهِ ذَكَرَ فِيهِ عَنِ النَّبِيِّ صلى الله عليه وسلم أَنَّهُ نَهَى عَنْ كِرَاءِ الأَرْضِ ‏.‏ قَالَ فَتَرَكَهُ ابْنُ عُمَرَ فَلَمْ يَأْجُرْهُ ‏.‏", "bengali": "", "english": "He then went to him along with me. He (Rafi) narrated from some of his uncles in which it was mentioned that Allah's Apostle (ﷺ) forbade the renting of land. Ibn 'Umar (Allah be pleased with them) then abandoned this practice of renting.", "french": "", "indonesian": "", "russian": "", "urdu": "اسماعیل بن جعفر نے ہمیں علاء سے حدیث بیان کی ،  انہوں نے اپنے والد  ( عبدالرحمٰن )  سے ،  انہوں نے ح", "grades": "", "reference": "", "international_number": "3813", "narrator_chain": "Nafi, reported that Ibn Umar (Allah be pleased with them) used to rent the land, and that he was conveyed the hadith transmitted on the authority of Rafi b. Khadij. He (the narrator) said:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3814", "arabic": "وَحَدَّثَنِيهِ مُحَمَّدُ بْنُ حَاتِمٍ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، حَدَّثَنَا ابْنُ عَوْنٍ، بِهَذَا الإِسْنَادِ وَقَالَ فَحَدَّثَهُ عَنْ بَعْضِ، عُمُومَتِهِ عَنِ النَّبِيِّ صلى الله عليه وسلم ‏.‏", "bengali": "", "english": "This hadith has been narrated through another chain of transmitters.", "french": "", "indonesian": "", "russian": "", "urdu": "احمد بن ابراہیم دورقی نے مجھے یہی حدیث بیان کی ،  کہا :  مجھے عبدالصمد نے حدیث بیان کی ،  کہا :  ہمی", "grades": "", "reference": "", "international_number": "3814", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3815", "arabic": "وَحَدَّثَنِي عَبْدُ الْمَلِكِ بْنُ شُعَيْبِ بْنِ اللَّيْثِ بْنِ سَعْدٍ، حَدَّثَنِي أَبِي، عَنْ جَدِّي، حَدَّثَنِي عُقَيْلُ بْنُ خَالِدٍ، عَنِ ابْنِ شِهَابٍ، أَنَّهُ قَالَ أَخْبَرَنِي سَالِمُ بْنُ عَبْدِ اللَّهِ، أَنَّ عَبْدَ اللَّهِ بْنَ عُمَرَ، كَانَ يُكْرِي أَرَضِيهِ حَتَّى بَلَغَهُ أَنَّ رَافِعَ بْنَ خَدِيجٍ الأَنْصَارِيَّ كَانَ يَنْهَى عَنْ كِرَاءِ الأَرْضِ فَلَقِيَهُ عَبْدُ اللَّهِ فَقَالَ يَا ابْنَ خَدِيجٍ مَاذَا تُحَدِّثُ عَنْ رَسُولِ اللَّهِ صلى الله عليه وسلم فِي كِرَاءِ الأَرْضِ قَالَ رَافِعُ بْنُ خَدِيجٍ لِعَبْدِ اللَّهِ سَمِعْتُ عَمَّىَّ - وَكَانَا قَدْ شَهِدَا بَدْرًا - يُحَدِّثَانِ أَهْلَ الدَّارِ أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم نَهَى عَنْ كِرَاءِ الأَرْضِ ‏.‏ قَالَ عَبْدُ اللَّهِ لَقَدْ كُنْتُ أَعْلَمُ فِي عَهْدِ رَسُولِ اللَّهِ صلى الله عليه وسلم أَنَّ الأَرْضَ تُكْرَى ثُمَّ خَشِيَ عَبْدُ اللَّهِ أَنْ يَكُونَ رَسُولُ اللَّهِ صلى الله عليه وسلم أَحْدَثَ فِي ذَلِكَ شَيْئًا لَمْ يَكُنْ عَلِمَهُ فَتَرَكَ كِرَاءَ الأَرْضِ ‏.‏", "bengali": "", "english": "Ibn Khadij, what is this that you narrate from Allah's Messenger (ﷺ) pertaining to renting of land? Rafi b. Khadij said to Abdullah: I heard it from two uncles of mine and they had participated in the Battle of Badr who narrated to the members of the family that Allah's Messenger (ﷺ) forbade the renting of land. Abdullah said: I knew it that the land was rented during the lifetime of Allah's Messenger (ﷺ). Abdullah then apprehended that Allah's Messenger (ﷺ) might have said something new in this connection (in regard to prohibition of renting) which I failed to know. So he abandoned the renting of land.", "french": "", "indonesian": "", "russian": "", "urdu": "اعرج نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   \" بیع ک", "grades": "", "reference": "", "international_number": "3815", "narrator_chain": "Salim b. Abdullah reported that AbduUah b. Umar (Allah be pleased with them) used to give land on rent until (this news) reached him that Rafi b. Khadij Ansari used to forbid the renting of land. Abdullah met him and said:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3816", "arabic": "وَحَدَّثَنِي عَلِيُّ بْنُ حُجْرٍ السَّعْدِيُّ، وَيَعْقُوبُ بْنُ إِبْرَاهِيمَ، قَالاَ حَدَّثَنَا إِسْمَاعِيلُ، - وَهُوَ ابْنُ عُلَيَّةَ - عَنْ أَيُّوبَ، عَنْ يَعْلَى بْنِ حَكِيمٍ، عَنْ سُلَيْمَانَ بْنِ يَسَارٍ، عَنْ رَافِعِ بْنِ خَدِيجٍ، قَالَ كُنَّا نُحَاقِلُ الأَرْضَ عَلَى عَهْدِ رَسُولِ اللَّهِ صلى الله عليه وسلم فَنُكْرِيهَا بِالثُّلُثِ وَالرُّبُعِ وَالطَّعَامِ الْمُسَمَّى فَجَاءَنَا ذَاتَ يَوْمٍ رَجُلٌ مِنْ عُمُومَتِي فَقَالَ نَهَانَا رَسُولُ اللَّهِ صلى الله عليه وسلم عَنْ أَمْرٍ كَانَ لَنَا نَافِعًا وَطَوَاعِيَةُ اللَّهِ وَرَسُولِهِ أَنْفَعُ لَنَا نَهَانَا أَنْ نُحَاقِلَ بِالأَرْضِ فَنُكْرِيَهَا عَلَى الثُّلُثِ وَالرُّبُعِ وَالطَّعَامِ الْمُسَمَّى وَأَمَرَ رَبَّ الأَرْضِ أَنْ يَزْرَعَهَا أَوْ يُزْرِعَهَا وَكَرِهَ كِرَاءَهَا وَمَا سِوَى ذَلِكَ ‏.‏", "bengali": "", "english": "We used to give on rent land during the lifetime of Allah's Messenger (ﷺ). We rented it on the share of one-third or one-fourth of the (produce) along with a definite quantity of corn. One day a person from among my uncles came to us and said: Allah's Messenger (ﷺ) forbade us this act which was a source of benefit to us, but the obedience to Allah and to His Messenger (ﷺ) is more beneficial to us. He forbade us that we should rent land with one-third or one-fourth of (the produce) and the corn of a measure, and he commanded the owner of land that he should cultivate it or let it be cultivated by other (persons) but he showed disapproval of renting it or anything besides it.", "french": "", "indonesian": "", "russian": "", "urdu": "معاذ عنبری نے کہا :  ہمیں شعبہ نے عدی بن ثابت سے حدیث بیان کی ،  انہوں نے ابوحازم سے اور انہوں نے حض", "grades": "", "reference": "", "international_number": "3816", "narrator_chain": "Rafi b. Khadij (Allah be pleased with him) reported:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3817", "arabic": "وَحَدَّثَنَاهُ يَحْيَى بْنُ يَحْيَى، أَخْبَرَنَا حَمَّادُ بْنُ زَيْدٍ، عَنْ أَيُّوبَ، قَالَ كَتَبَ إِلَىَّ يَعْلَى بْنُ حَكِيمٍ قَالَ سَمِعْتُ سُلَيْمَانَ بْنَ يَسَارٍ، يُحَدِّثُ عَنْ رَافِعِ بْنِ خَدِيجٍ، قَالَ كُنَّا نُحَاقِلُ بِالأَرْضِ فَنُكْرِيهَا عَلَى الثُّلُثِ وَالرُّبُعِ ‏.‏ ثُمَّ ذَكَرَ بِمِثْلِ حَدِيثِ ابْنِ عُلَيَّةَ ‏.‏", "bengali": "", "english": "We used to give land on rent, and we rented it on one-third or one-fourth share. The rest of the hadith is the same.", "french": "", "indonesian": "", "russian": "", "urdu": "غندر ،  وہب بن جریر اور عبدالصمد بن عبدالوارث سب نے کہا :  ہمیں شعبہ نے اسی سند کے ساتھ شعبہ سے روای", "grades": "", "reference": "", "international_number": "3817", "narrator_chain": "Rafi b. Khadij (Allah be pleased with him) reported:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3818", "arabic": "وَحَدَّثَنَا يَحْيَى بْنُ حَبِيبٍ، حَدَّثَنَا خَالِدُ بْنُ الْحَارِثِ، ح وَحَدَّثَنَا عَمْرُو بْنُ عَلِيٍّ، حَدَّثَنَا عَبْدُ الأَعْلَى، ح وَحَدَّثَنَا إِسْحَاقُ بْنُ إِبْرَاهِيمَ، أَخْبَرَنَا عَبْدَةُ، كُلُّهُمْ عَنِ ابْنِ أَبِي عَرُوبَةَ، عَنْ يَعْلَى بْنِ حَكِيمٍ، بِهَذَا الإِسْنَادِ ‏.‏ مِثْلَهُ ‏.‏", "bengali": "", "english": "Another chain narrated the same as the above hadith.", "french": "", "indonesian": "", "russian": "", "urdu": "حضرت ابن عمر رضی اللہ عنہ سے روایت ہے کہ رسول اللہ صلی اللہ علیہ وسلم نے  ( خریدنے کے ارادے کے بغیر", "grades": "", "reference": "", "international_number": "3818", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3819", "arabic": "وَحَدَّثَنِيهِ أَبُو الطَّاهِرِ، أَخْبَرَنَا ابْنُ وَهْبٍ، أَخْبَرَنِي جَرِيرُ بْنُ حَازِمٍ، عَنْ يَعْلَى بْنِ، حَكِيمٍ بِهَذَا الإِسْنَادِ عَنْ رَافِعِ بْنِ خَدِيجٍ، عَنِ النَّبِيِّ صلى الله عليه وسلم وَلَمْ يَقُلْ عَنْ بَعْضِ عُمُومَتِهِ ‏.‏", "bengali": "", "english": "This hadith has been narrated on the authority of Rafi' b. Khadij with the same chain of transmitters, but in it no mention is made of some of his uncles.", "french": "", "indonesian": "", "russian": "", "urdu": "ابن ابی زائدہ ،  یحییٰ بن سعید اور  ( عبداللہ )  ابن نمیر ،  ان سب نے عبیداللہ سے ،  انہوں نے نافع س", "grades": "", "reference": "", "international_number": "3819", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3820", "arabic": "حَدَّثَنِي إِسْحَاقُ بْنُ مَنْصُورٍ، أَخْبَرَنَا أَبُو مُسْهِرٍ، حَدَّثَنِي يَحْيَى بْنُ حَمْزَةَ، حَدَّثَنِي أَبُو عَمْرٍو الأَوْزَاعِيُّ، عَنْ أَبِي النَّجَاشِيِّ، مَوْلَى رَافِعِ بْنِ خَدِيجٍ عَنْ رَافِعٍ، أَنَّ ظُهَيْرَ بْنَ رَافِعٍ، - وَهُوَ عَمُّهُ - قَالَ أَتَانِي ظُهَيْرٌ فَقَالَ لَقَدْ نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم عَنْ أَمْرٍ كَانَ بِنَا رَافِقًا ‏.‏ فَقُلْتُ وَمَا ذَاكَ مَا قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم فَهُوَ حَقٌّ ‏.‏ قَالَ سَأَلَنِي كَيْفَ تَصْنَعُونَ بِمَحَاقِلِكُمْ فَقُلْتُ نُؤَاجِرُهَا يَا رَسُولَ اللَّهِ عَلَى الرَّبِيعِ أَوِ الأَوْسُقِ مِنَ التَّمْرِ أَوِ الشَّعِيرِ ‏.‏ قَالَ ‏ ‏ فَلاَ تَفْعَلُوا ازْرَعُوهَا أَوْ أَزْرِعُوهَا أَوْ أَمْسِكُوهَا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "Allah's Messenger (ﷺ) forbade a practice which was useful for us. I said: What is this? (I believe) that whatrver Allah's Messenger (ﷺ) says is absolutely true. He (Zuhair) said that he (the Holy Prophet) asked me: What do you do with your cultivable lands? I said: Allah's Messenger, we rent those irrigated by canals for dry dates or barley. He said: Don't do that. Cultivate them or let them be cultivated (by others) or retain them yourself.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Rafi (Allah be pleased with him) reported that Zuhair b. Rafi (who was his uncle) came to me and said:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3821", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ حَاتِمٍ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، عَنْ عِكْرِمَةَ بْنِ عَمَّارٍ، عَنْ أَبِي النَّجَاشِيِّ، عَنْ رَافِعٍ، عَنِ النَّبِيِّ صلى الله عليه وسلم بِهَذَا وَلَمْ يَذْكُرْ عَنْ عَمِّهِ ظُهَيْرٍ.", "bengali": "", "english": "This hadith has been transmitted on the authority of Rafi from the Prophet (ﷺ) about this, but he did not make mention of his uncle Zuhair.", "french": "", "indonesian": "", "russian": "", "urdu": "حضرت عبداللہ رضی اللہ عنہ نے نبی صلی اللہ علیہ وسلم سے روایت کی کہ نبی صلی اللہ علیہ وسلم نے  ( راست", "grades": "", "reference": "", "international_number": "3821", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3822", "arabic": "حَدَّثَنَا يَحْيَى بْنُ يَحْيَى، قَالَ قَرَأْتُ عَلَى مَالِكٍ عَنْ رَبِيعَةَ بْنِ أَبِي عَبْدِ الرَّحْمَنِ، عَنْ حَنْظَلَةَ بْنِ قَيْسٍ، أَنَّهُ سَأَلَ رَافِعَ بْنَ خَدِيجٍ عَنْ كِرَاءِ الأَرْضِ، فَقَالَ نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم عَنْ كِرَاءِ الأَرْضِ قَالَ فَقُلْتُ أَبِالذَّهَبِ وَالْوَرِقِ فَقَالَ أَمَّا بِالذَّهَبِ وَالْوَرِقِ فَلاَ بَأْسَ بِهِ ‏.‏", "bengali": "", "english": "Allah's Messenger (ﷺ) forbade the renting of land. I said: Is it forbidden (even if it is paid) in gold (dinar) and silver (dirham)? Thereupon he said: If it is paid in gold and silver, there is no harm in it.", "french": "", "indonesian": "", "russian": "", "urdu": "ہُشَیم نے ہمیں ہشام سے خبر دی ،  انہوں نے ابن سیرین سے اور انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے رو", "grades": "", "reference": "", "international_number": "3822", "narrator_chain": "Hanzala b. Qais reported that he asked Rafi b. Khadij (Allah be pleased with him) about renting of land, whereupon he said:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3823", "arabic": "حَدَّثَنَا إِسْحَاقُ، أَخْبَرَنَا عِيسَى بْنُ يُونُسَ، حَدَّثَنَا الأَوْزَاعِيُّ، عَنْ رَبِيعَةَ بْنِ أَبِي، عَبْدِ الرَّحْمَنِ حَدَّثَنِي حَنْظَلَةُ بْنُ قَيْسٍ الأَنْصَارِيُّ، قَالَ سَأَلْتُ رَافِعَ بْنَ خَدِيجٍ عَنْ كِرَاءِ الأَرْضِ، بِالذَّهَبِ وَالْوَرِقِ فَقَالَ لاَ بَأْسَ بِهِ إِنَّمَا كَانَ النَّاسُ يُؤَاجِرُونَ عَلَى عَهْدِ النَّبِيِّ صلى الله عليه وسلم عَلَى الْمَاذِيَانَاتِ وَأَقْبَالِ الْجَدَاوِلِ وَأَشْيَاءَ مِنَ الزَّرْعِ فَيَهْلِكُ هَذَا وَيَسْلَمُ هَذَا وَيَسْلَمُ هَذَا وَيَهْلِكُ هَذَا فَلَمْ يَكُنْ لِلنَّاسِ كِرَاءٌ إِلاَّ هَذَا فَلِذَلِكَ زُجِرَ عَنْهُ ‏.‏ فَأَمَّا شَىْءٌ مَعْلُومٌ مَضْمُونٌ فَلاَ بَأْسَ بِهِ ‏.‏", "bengali": "", "english": "I asked Rafi' b. Khadij about the renting of land for gold and silver, whereupon he said: There is no harm in it for the people let out land situated near canals and at the ends of the streamlets or portion of fields. (But it so happened) that at times this was destroyed and that was saved. whereas (on other occasions) this portion was saved and the other was destroyed and thus no rent was payable to the people (who let out lands) but for this one (which was saved). It was due to this that he (the Holy Prophet) prohibited it. But if there is something definite and reliable (e. g. money). there is no harm in it.", "french": "", "indonesian": "", "russian": "", "urdu": "ابن جریج نے کہا :  مجھے ہشام قردوسی نے ابن سیرین سے خبر دی ،  انہوں نے کہا :  میں نے حضرت ابوہریرہ ر", "grades": "", "reference": "", "international_number": "3823", "narrator_chain": "Hanzala b. Qais al-Ansri reported:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3824", "arabic": "حَدَّثَنَا عَمْرٌو النَّاقِدُ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ يَحْيَى بْنِ سَعِيدٍ، عَنْ حَنْظَلَةَ، الزُّرَقِيِّ أَنَّهُ سَمِعَ رَافِعَ بْنَ خَدِيجٍ، يَقُولُ كُنَّا أَكْثَرَ الأَنْصَارِ حَقْلاً - قَالَ - كُنَّا نُكْرِي الأَرْضَ عَلَى أَنَّ لَنَا هَذِهِ وَلَهُمْ هَذِهِ فَرُبَّمَا أَخْرَجَتْ هَذِهِ وَلَمْ تُخْرِجْ هَذِهِ فَنَهَانَا عَنْ ذَلِكَ وَأَمَّا الْوَرِقُ فَلَمْ يَنْهَنَا ‏.‏", "bengali": "", "english": "We were the major agriculturists of the Ansar and so we let out land (saying): The produce of this (part of land) would be ours and (the produce) of that would be theirs. But it so happened that at times this (land) gave harvest, but the other one produced nothing. So he (the Holy Prophet) forbade this. But so far as the payment in silver (dirham, a coin) is concerned, he did not forbid.", "french": "", "indonesian": "", "russian": "", "urdu": "ابوبکر بن ابی شیبہ ،  عمرو ناقد اور زُہَیر بن حرب نے کہا :  ہمیں سفیان نے زہری سے حدیث بیان کی ،  ان", "grades": "", "reference": "", "international_number": "3824", "narrator_chain": "Hanzala reported that he heard Rafi' b. Khadij (Allah be pleased with him) say:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3825", "arabic": "حَدَّثَنَا أَبُو الرَّبِيعِ، حَدَّثَنَا حَمَّادٌ، ح وَحَدَّثَنَا ابْنُ الْمُثَنَّى، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، جَمِيعًا عَنْ يَحْيَى بْنِ سَعِيدٍ، بِهَذَا الإِسْنَادِ نَحْوَهُ ‏.‏", "bengali": "", "english": "This hadith has been narrated on the authority of Yahya b. Sa'id with the same chain of transmitters.", "french": "", "indonesian": "", "russian": "", "urdu": "طاوس کے بیٹے نے اپنے والد سے ،  انہوں نے حضرت ابن عباس رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  ر", "grades": "", "reference": "", "international_number": "3825", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3826", "arabic": "حَدَّثَنَا يَحْيَى بْنُ يَحْيَى، أَخْبَرَنَا عَبْدُ الْوَاحِدِ بْنُ زِيَادٍ، ح وَحَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي، شَيْبَةَ حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ، كِلاَهُمَا عَنِ الشَّيْبَانِيِّ، عَنْ عَبْدِ اللَّهِ بْنِ السَّائِبِ، قَالَ سَأَلْتُ عَبْدَ اللَّهِ بْنَ مَعْقِلٍ عَنِ الْمُزَارَعَةِ، فَقَالَ أَخْبَرَنِي ثَابِتُ بْنُ الضَّحَّاكِ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم نَهَى عَنِ الْمُزَارَعَةِ ‏.‏ وَفِي رِوَايَةِ ابْنِ أَبِي شَيْبَةَ نَهَى عَنْهَا ‏.‏ وَقَالَ سَأَلْتُ ابْنَ مَعْقِلٍ ‏.‏ وَلَمْ يُسَمِّ عَبْدَ اللَّهِ ‏.‏", "bengali": "", "english": "I asked Abdullah b. Ma'qil about Muzara'a (cultivating land on share basis in the produce). He said: Thabit b. Dahhak informed me that Allah's Messenger (ﷺ) forbade Muzara'a as Ibn Abu Shaiba forbade it with a slight change of words. He (the narrator) said: I asked Ibn Ma'qil but he did not name 'Abdullah.", "french": "", "indonesian": "", "russian": "", "urdu": "یحییٰ بن یحییٰ تمیمی اور احمد بن یونس نے کہا :  ہمیں ابوخثیمہ زہیر نے حدیث سنائی ،  کہا :  ہمیں ابوز", "grades": "", "reference": "", "international_number": "3826", "narrator_chain": "Abdullah b. al Sa'ib reported:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3827", "arabic": "حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ، أَخْبَرَنَا يَحْيَى بْنُ حَمَّادٍ، أَخْبَرَنَا أَبُو عَوَانَةَ، عَنْ سُلَيْمَانَ، الشَّيْبَانِيِّ عَنْ عَبْدِ اللَّهِ بْنِ السَّائِبِ، قَالَ دَخَلْنَا عَلَى عَبْدِ اللَّهِ بْنِ مَعْقِلٍ فَسَأَلْنَاهُ عَنِ الْمُزَارَعَةِ، فَقَالَ زَعَمَ ثَابِتٌ أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم نَهَى عَنِ الْمُزَارَعَةِ وَأَمَرَ بِالْمُؤَاجَرَةِ وَقَالَ ‏ ‏ لاَ بَأْسَ بِهَا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "We visited 'Abdullah b. Ma'qil and asked him about sharing of crops, whereupon he said: Thabit alleged that Allah's Messenger (ﷺ) forbade Muzara'a and commanded leasing it out on rent (for money) and said: There is no harm in it.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abdullah b. al-Sa'ib reported:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3828", "arabic": "حَدَّثَنَا يَحْيَى بْنُ يَحْيَى، أَخْبَرَنَا حَمَّادُ بْنُ زَيْدٍ، عَنْ عَمْرٍو، أَنَّ مُجَاهِدًا، قَالَ لِطَاوُسٍ انْطَلِقْ بِنَا إِلَى ابْنِ رَافِعِ بْنِ خَدِيجٍ فَاسْمَعْ مِنْهُ الْحَدِيثَ عَنْ أَبِيهِ، عَنِ النَّبِيِّ صلى الله عليه وسلم - قَالَ - فَانْتَهَرَهُ قَالَ إِنِّي وَاللَّهِ لَوْ أَعْلَمُ أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم نَهَى عَنْهُ مَا فَعَلْتُهُ وَلَكِنْ حَدَّثَنِي مَنْ هُوَ أَعْلَمُ بِهِ مِنْهُمْ - يَعْنِي ابْنَ عَبَّاسٍ - أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ لأَنْ يَمْنَحَ الرَّجُلُ أَخَاهُ أَرْضَهُ خَيْرٌ لَهُ مِنْ أَنْ يَأْخُذَ عَلَيْهَا خَرْجًا مَعْلُومًا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "Come along with me to Ibn Rafi b. Khadij in order to listen from him the hadith transmitted on the authority of his father (pertaining to the renting of land) from Allah's Apostle (ﷺ). He (Tawus) scolded him and said: By Allah, it I were to know that Allah's Messenger (ﷺ) had forbidden it, I would have never done it. But it has been narrated to me by one who has better knowledge of it amongst them (and he meant Ibn 'Abbas) that Allah's Messenger (ﷺ) said: It is better if a person lends, his land to his brother (for cultivation) than that he gets recognised rent on it.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Mujahid said to Tiwus:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3829", "arabic": "وَحَدَّثَنَا ابْنُ أَبِي عُمَرَ، حَدَّثَنَا سُفْيَانُ، عَنْ عَمْرٍو، وَابْنُ، طَاوُسٍ عَنْ طَاوُسٍ، أَنَّهُ كَانَ يُخَابِرُ قَالَ عَمْرٌو فَقُلْتُ لَهُ يَا أَبَا عَبْدِ الرَّحْمَنِ لَوْ تَرَكْتَ هَذِهِ الْمُخَابَرَةَ فَإِنَّهُمْ يَزْعُمُونَ أَنَّ النَّبِيَّ صلى الله عليه وسلم نَهَى عَنِ الْمُخَابَرَةِ ‏.‏ فَقَالَ أَىْ عَمْرُو أَخْبَرَنِي أَعْلَمُهُمْ بِذَلِكَ يَعْنِي ابْنَ عَبَّاسٍ أَنَّ النَّبِيَّ صلى الله عليه وسلم لَمْ يَنْهَ عَنْهَا إِنَّمَا قَالَ ‏ ‏ يَمْنَحُ أَحَدُكُمْ أَخَاهُ خَيْرٌ لَهُ مِنْ أَنْ يَأْخُذَ عَلَيْهَا خَرْجًا مَعْلُومًا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "I said to him: Abu Abd al-Rahrman, I wish if you abandon this renting of land, for they alleged that Allah's Apostle (ﷺ) forbade Mukhabara. He siad: Amr, one who has informed me has the best knowledge of it among them (he meant Ibn Abbas). (He said) that Allah's Apostle (ﷺ) did not prohibit it altogether, but said: Lending of land by one among you to his brother is better for him than getting a specified amount of produce from it.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Tawus reported that he let out his land on rent, whereupon Amr said:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3830", "arabic": "حَدَّثَنَا ابْنُ أَبِي عُمَرَ، حَدَّثَنَا الثَّقَفِيُّ، عَنْ أَيُّوبَ، ح وَحَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَإِسْحَاقُ بْنُ إِبْرَاهِيمَ جَمِيعًا عَنْ وَكِيعٍ، عَنْ سُفْيَانَ، ح وَحَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، أَخْبَرَنَا اللَّيْثُ، عَنِ ابْنِ جُرَيْجٍ، ح وَحَدَّثَنِي عَلِيُّ بْنُ حُجْرٍ، حَدَّثَنَا الْفَضْلُ بْنُ مُوسَى، عَنْ شَرِيكٍ، عَنْ شُعْبَةَ، كُلُّهُمْ عَنْ عَمْرِو بْنِ دِينَارٍ، عَنْ طَاوُسٍ، عَنِ ابْنِ عَبَّاسٍ، عَنِ النَّبِيِّ صلى الله عليه وسلم ‏.‏ نَحْوَ حَدِيثِهِمْ ‏.‏", "bengali": "", "english": "A hadith like this has been transmitted on the authority of Ibn Abbas (Allah be pleased with them).", "french": "", "indonesian": "", "russian": "", "urdu": "موسیٰ بن یسار نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا ،  رسول اللہ صلی اللہ علیہ و", "grades": "", "reference": "", "international_number": "3830", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3831", "arabic": "وَحَدَّثَنِي عَبْدُ بْنُ حُمَيْدٍ، وَمُحَمَّدُ بْنُ رَافِعٍ، - قَالَ عَبْدٌ أَخْبَرَنَا وَقَالَ ابْنُ رَافِعٍ، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، - أَخْبَرَنَا مَعْمَرٌ، عَنِ ابْنِ طَاوُسٍ، عَنْ أَبِيهِ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ النَّبِيَّ صلى الله عليه وسلم قَالَ ‏ ‏ لأَنْ يَمْنَحَ أَحَدُكُمْ أَخَاهُ أَرْضَهُ خَيْرٌ لَهُ مِنْ أَنْ يَأْخُذَ عَلَيْهَا كَذَا وَكَذَا ‏\"\"‏ ‏.‏ لِشَىْءٍ مَعْلُومٍ ‏.‏ قَالَ وَقَالَ ابْنُ عَبَّاسٍ هُوَ الْحَقْلُ وَهُوَ بِلِسَانِ الأَنْصَارِ الْمُحَاقَلَةُ.\"", "bengali": "", "english": "If one among you lets out land to his brother, that is better for him than if he receives such and such (the definite thing). Ibn 'Abbis (Allah be pleased with them) said: It is Haql, and in the parlance of the Ansr it is Muhaqala.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Ibn Abbas (Allah be pleased with them) reported Allah's Apostle (ﷺ) as saying:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3832", "arabic": "وَحَدَّثَنَا عَبْدُ اللَّهِ بْنُ عَبْدِ الرَّحْمَنِ الدَّارِمِيُّ، أَخْبَرَنَا عَبْدُ اللَّهِ بْنُ جَعْفَرٍ الرَّقِّيُّ، حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ عَمْرٍو، عَنْ زَيْدِ بْنِ أَبِي أُنَيْسَةَ، عَنْ عَبْدِ الْمَلِكِ أَبِي زَيْدٍ، عَنْ طَاوُسٍ، عَنِ ابْنِ، عَبَّاسٍ عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ مَنْ كَانَتْ لَهُ أَرْضٌ فَإِنَّهُ أَنْ يَمْنَحَهَا أَخَاهُ خَيْرٌ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "He who has land, it is better for him that he should let it out to his brother.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Ibn Abbas (Allah be pleased with them) reported Allah's Apostle (ﷺ) as saying:", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3833", "arabic": "حَدَّثَنَا  ابْنُ أَبِي عُمَرَ ، حَدَّثَنَا  سُفْيَانُ ، عَنْ  أَيُّوبَ ، عَنْ  مُحَمَّدٍ ، عَنْ  أَ", "bengali": "", "english": "Abu Huraira (Allah be pleased with him) reported Allah's Messenger (ﷺ) as saying:He who buys a goat having its udder tied up has two courses left for him. He may retain it, and if he desires may return it along with a sa' of dates and not wheat", "french": "", "indonesian": "", "russian": "", "urdu": "سفیان نے ہمیں ایوب سے حدیث بیان کی ،  انہوں نے محمد  ( بن سیرین )  سے ،  انہوں نے حضرت ابوہریرہ رضی", "grades": "", "reference": "Book 21, Hadith 33", "international_number": "3833", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3834", "arabic": "وحَدَّثَنَاه  ابْنُ أَبِي عُمَرَ ، حَدَّثَنَا  عَبْدُ الْوَهَّابِ ، عَنْ  أَيُّوبَ ، بِهَذَا الْإِسْ", "bengali": "", "english": "Ayyub narrated with the same chain of transmitters but with this change of words:\" He who buys a goat has the option", "french": "", "indonesian": "", "russian": "", "urdu": "عبدالوہاب نے ایوب سے اسی سند کے ساتھ حدیث بیان کی ،  لیکن انہوں نے کہا :   \" جس نے  ( دودھ روکی ہوئی", "grades": "", "reference": "Book 21, Hadith 34", "international_number": "3834", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3835", "arabic": "حَدَّثَنَا  مُحَمَّدُ بْنُ رَافِعٍ ، حَدَّثَنَا  عَبْدُ الرَّزَّاقِ ، حَدَّثَنَا  مَعْمَرٌ ، عَنْ  ه", "bengali": "", "english": "Hammam b. Munabbih said:Out of the ahadith which Abu Huraira (Allah be pleased with him) reported to us from Allah's Messenger (ﷺ) one is this that Allah's Messenger (ﷺ) said: If one among you buys a she-camel having its udder tied up he has the two options for him after milking it either (to retain it) or return it with a sa' of dates", "french": "", "indonesian": "", "russian": "", "urdu": "ہمام بن منبہ سے روایت ہے ،  انہوں نے کہا :  یہ احادیث ہیں جو ہمیں حضرت ابوہریرہ رضی اللہ عنہ نے رسول", "grades": "", "reference": "Book 21, Hadith 35", "international_number": "3835", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3837", "arabic": "حَدَّثَنَا  ابْنُ أَبِي عُمَرَ ،  وَأَحْمَدُ بْنُ عَبْدَةَ ، قَالَا: حَدَّثَنَا  سُفْيَانُ . ح وحَدّ", "bengali": "", "english": "Ibn Abbas (Allah be pleased with them) reported Allah's Messenger (ﷺ) as saying:He who buys foodgrain should not sell it until he has taken possession of it", "french": "", "indonesian": "", "russian": "", "urdu": "سفیان بن عیینہ اور سفیان ثوری نے عمرو بن دینار سے اسی سند کے ساتھ اسی کے مطابق روایت کی", "grades": "", "reference": "Book 21, Hadith 36", "international_number": "3837", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3838", "arabic": "حَدَّثَنَا  إِسْحَاقُ بْنُ إِبْرَاهِيمَ ،  وَمُحَمَّدُ بْنُ رَافِعٍ ،  وَعَبْدُ بْنُ حميد ، قَالَ اب", "bengali": "", "english": "A hadith like this has been narrated through the same chain of transmitters", "french": "", "indonesian": "", "russian": "", "urdu": "معمر نے ابن طاوس سے خبر دی ،  انہوں نے اپنے والد سے اور انہوں نے حضرت ابن عباس رضی اللہ عنہ سے روایت", "grades": "", "reference": "Book 21, Hadith 37", "international_number": "3838", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3839", "arabic": "حَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ،  وَأَبُو كُرَيْبٍ ،  وَإِسْحَاقُ بْنُ إِبْرَاهِيمَ ،", "bengali": "", "english": "Ibn Abbas (Allah be pleased with them) reported Allah's Messenger (ﷺ) as saying:He who buys food-rain should not sell it until he has taken possession of it. Ibn Abbas (Allah be pleased with them) said: I regard everything like food (so far as this principle is concerned)", "french": "", "indonesian": "", "russian": "", "urdu": "ابوبکر بن ابی شیبہ ،  ابو کُرَیب اور اسحاق بن ابراہیم نے ہمیں حدیث بیان کی  ۔  ۔  اسحاق نے کہا :  ہم", "grades": "", "reference": "Book 21, Hadith 38", "international_number": "3839", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3840", "arabic": "حَدَّثَنَا  عَبْدُ اللَّهِ بْنُ مَسْلَمَةَ الْقَعْنَبِيُّ ، حَدَّثَنَا  مَالِكٌ . ح وحَدَّثَنَا  يَح", "bengali": "", "english": "Ibn 'Umar (Allah be pleased with them) reported Allah's Messenger (ﷺ) as saying:He who buys foodgrain should not sell it until he has taken full possession of it", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن مسلمہ قعنبی نے ہمیں حدیث سنائی ،  کہا :  ہمیں مالک نے حدیث سنائی ۔  اور یحییٰ بن یحییٰ نے", "grades": "", "reference": "Book 21, Hadith 40", "international_number": "3840", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3841", "arabic": "حَدَّثَنَا  يَحْيَي بْنُ يَحْيَي ، قَالَ: قَرَأْتُ عَلَى  مَالِكٍ ، عَنْ  نَافِعٍ ، عَنْ  ابْنِ عُمَ", "bengali": "", "english": "Ibn Umar (Allah be pleased with them) reported:We used to buy foodgrains during the lifetime of Allah's Messenger (ﷺ). He (the Holy Prophet) would then send to us one who commanded us to take them (the foodgrains) to a place other than the one where we had bought them before we sold it", "french": "", "indonesian": "", "russian": "", "urdu": "یحییٰ بن یحییٰ نے سابقہ سند کے ساتھ حضرت ابن عمر رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  رسول ال", "grades": "", "reference": "Book 21, Hadith 41", "international_number": "3841", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3843", "arabic": "قَالَ: وَكُنَّا نَشْتَرِي الطَّعَامَ مِنَ الرُّكْبَانِ جِزَافًا، فَنَهَانَا رَسُولُ اللَّهِ صَلَّى ا", "bengali": "", "english": "Ibn 'Umar (Allah be pleased with them) reported Allah's Messenger (ﷺ) as saying:He who bought foodgrain should not sell it until he had taken full possession of it (after measuring it)", "french": "", "indonesian": "", "russian": "", "urdu": "نیز انہوں  ( حضرت ابن عمر رضی اللہ عنہ )  نے کہا :  ہم اہل قافلہ سے بغیر ماپ  ( اور وزن )  کے غلہ خر", "grades": "", "reference": "Book 21, Hadith 43", "international_number": "3843", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3844", "arabic": "حَدَّثَنِي  حَرْمَلَةُ بْنُ يَحْيَي ، أَخْبَرَنَا  عَبْدُ اللَّهِ بْنُ وَهْبٍ ، حَدَّثَنِي  عُمَرُ ب", "bengali": "", "english": "Ibn 'Umar (Allah be pleased with them) reported Allah's Messenger (ﷺ) as saying,:He who bought foodgrain should not sell it until he had taken possession of it", "french": "", "indonesian": "", "russian": "", "urdu": "عمر بن محمد نے نافع سے ،  انہوں نے حضرت عبداللہ بن عمر رضی اللہ عنہ سے روایت کی کہ اللہ کے رسول صلی", "grades": "", "reference": "Book 21, Hadith 44", "international_number": "3844", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3846", "arabic": "حَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، حَدَّثَنَا  عَبْدُ الْأَعْلَى ، عَنْ  مَعْمَرٍ ، عَنْ", "bengali": "", "english": "Jabir b. Abdullah (Allah be pleased with them) reported Allah's Messenger (ﷺ) saying:: If You sell fruits to your brother (and Jabir b. Ahduthh reported through another chain of narrators: If you were to sell fruits to your brother) and these is a stricken with Calamity, it is not permissible for you to get anything from him. Why do you get the wealth of your brother, without jutification?", "french": "", "indonesian": "", "russian": "", "urdu": "معمر نے زہری سے ،  انہوں نے سالم سے ،  انہوں نے حضرت ابن عمر رضی اللہ عنہ سے روایت کی کہ رسول اللہ ص", "grades": "", "reference": "Book 21, Hadith 42", "international_number": "3846", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3847", "arabic": "وحَدَّثَنِي  حَرْمَلَةُ بْنُ يَحْيَي ، حَدَّثَنَا  ابْنُ وَهْبٍ ، أَخْبَرَنِي  يُونُسُ ، عَنْ  ابْنِ", "bengali": "", "english": "Salim b. 'Abdullah (Allah be pleased with them) reported his father havingsaid this:I saw people being beaten during the lifetime of Allah's Messenger (ﷺ) in case they bought the foodgrain in bulk, and then sold them at that spot before taking it to their places. This hadith is narrated on the authority of 'Ubaidullah b. Abdullah b. 'Umar through another chain of transmitters (and the words are):\" His father (Ibn 'Umar) used to buy foodgrains in bulk and then carried them to his people", "french": "", "indonesian": "", "russian": "", "urdu": "یونس نے مجھے ابن شہاب  ( زہری )  سے خبر دی ،  انہوں نے کہا :  مجھے سالم بن عبداللہ نے بتایا کہ ان کے", "grades": "", "reference": "Book 21, Hadith 46", "international_number": "3847", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3848", "arabic": "حَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ،  وَابْنُ نُمَيْرٍ ،  وَأَبُو كُرَيْبٍ ، قَالُوا: حَدّ", "bengali": "", "english": "Abu Huraira (Allah be pleased with him) reported Allah's Messenger (ﷺ) as saying:He who bought foodgrain should not sell it until he had measured it. In the narration of Abu Bakr there the word is Ibta' instead of Ishtara", "french": "", "indonesian": "", "russian": "", "urdu": "ابوبکر بن ابی شیبہ ،  ابن نمیر اور ابو کریب نے کہا :  ہمیں زید بن حباب نے ضحاک بن عثمان سے حدیث بیان", "grades": "", "reference": "Book 21, Hadith 47", "international_number": "3848", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3849", "arabic": "حَدَّثَنَا  إِسْحَاقُ بْنُ إِبْرَاهِيمَ ، أَخْبَرَنَا  عَبْدُ اللَّهِ بْنُ الْحَارِثِ الْمَخْزُومِيّ", "bengali": "", "english": "Abu Huraira (Allah be please with him) is reported to have said to Marwan:Have you made lawful the transactions involving interest? Thereupon Marwan said: I have not done that. Thereupon Abu Huraira (ﷺ) said: You have made lawful the transactions with the help of documents only, whereas Allah's Messenger (ﷺ) forbade the transaction of foodgrains until full possession is taken of them. Marwan then addressed the people and forbade them to enter into such transactions (as are done with the help of documents). Sulaiman said: I saw the sentinels snatching (these documents) from the people", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن حارث مخزومی نے ہمیں خبر دی ،  کہا :  ہمیں ضحاک بن عثمان نے بکیر بن عبداللہ بن اشج سے حدیث", "grades": "", "reference": "Book 21, Hadith 48", "international_number": "3849", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3850", "arabic": "حَدَّثَنَا  إِسْحَاقُ بْنُ إِبْرَاهِيمَ ، أَخْبَرَنَا  رَوْحٌ ، حَدَّثَنَا  ابْنُ جُرَيْجٍ ، حَدَّثَ", "bengali": "", "english": "Jabir b. Abdullah (Allah be pleased with them) reported Allah's Messenger (ﷺ) as saying:When you purchase foodgrains, do not sell them until you have taken possession of them", "french": "", "indonesian": "", "russian": "", "urdu": "حضرت جابر بن عبداللہ رضی اللہ عنہ کہتے ہیں کہ رسول اللہ صلی اللہ علیہ وسلم فرمایا کرتے تھے :   \" جب", "grades": "", "reference": "Book 21, Hadith 49", "international_number": "3850", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3851", "arabic": "حَدَّثَنِي  أَبُو الطَّاهِرِ أَحْمَدُ بْنُ عَمْرِو بْنِ سَرْحٍ ، أَخْبَرَنَا  ابْنُ وَهْبٍ ، حَدَّثَ", "bengali": "", "english": "Jabir b. Abdullah (Allah be pleased with them) is reported to have said that Allah's Messenger (ﷺ) forbade the sale of a heap of dates the weight of which is unknown in accordance with the known weight of dates", "french": "", "indonesian": "", "russian": "", "urdu": "روح بن عبادہ نے ہمیں حدیث بیان کی ،  کہا :  ہمیں ابن جریج نے ابوزبیر سے خبر دی ،  انہوں نے جابر بن ع", "grades": "", "reference": "Book 21, Hadith 50", "international_number": "3851", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3852", "arabic": "حَدَّثَنَا  إِسْحَاقُ بْنُ إِبْرَاهِيمَ ، حَدَّثَنَا  رَوْحُ بْنُ عُبَادَةَ ، حَدَّثَنَا  ابْنُ جُرَ", "bengali": "", "english": "This hadith is narrated on the authority of Jabir b. Abdullah (Allah be pleased with them) but with this variation that no mention is made of the dates (which one finds) at the end of the previous hadith", "french": "", "indonesian": "", "russian": "", "urdu": "روح بن عبادہ نے ہمیں حدیث بیان کی ،  کہا :  ہمیں ابن جریج نے ابوزبیر سے خبر دی ،  انہوں نے جابر بن ع", "grades": "", "reference": "Book 21, Hadith 51", "international_number": "3852", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3853", "arabic": "حَدَّثَنَا  يَحْيَي بْنُ يَحْيَي ، قَالَ: قَرَأْتُ عَلَى  مَالِكٍ ، عَنْ  نَافِعٍ ، عَنْ  ابْنِ عُمَ", "bengali": "", "english": "Ibn 'Umar (Allah be pleased with them) reported Allah's Messenger (ﷺ) as saying:Both parties in a business transaction have the right to annul it so long as they have not separated; except in transactions which have been made subject to the right of parties to annul them", "french": "", "indonesian": "", "russian": "", "urdu": "امام مالک نے نافع سے اور انہوں نے حضرت ابن عمر رضی اللہ عنہ سے روایت کی کہ اللہ کے رسول صلی اللہ علی", "grades": "", "reference": "Book 21, Hadith 52", "international_number": "3853", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3854", "arabic": "حَدَّثَنَا  زُهَيْرُ بْنُ حَرْبٍ ،  وَمُحَمَّدُ بْنُ الْمُثَنَّى ، قَالَا: حَدَّثَنَا  يَحْيَي وَهُو", "bengali": "", "english": "This hadith has been narrated on the authority of Ibn 'Umar (Allah be pleased with them) through another chain of transmitters", "french": "", "indonesian": "", "russian": "", "urdu": "عبیداللہ ،  ایوب ،  یحییٰ بن سعید اور ضحاک نے نافع سے ،  انہوں نے حضرت ابن عمر رضی اللہ عنہ سے اور ا", "grades": "", "reference": "Book 21, Hadith 53", "international_number": "3854", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3855", "arabic": "حَدَّثَنَا  قُتَيْبَةُ بْنُ سَعِيدٍ ، حَدَّثَنَا  لَيْثٌ . ح وَحَدَّثَنَا  مُحَمَّدُ بْنُ رُمْحٍ ، أ", "bengali": "", "english": "Ibn 'Umar (Allah be pleased with thcm) reported Allah's Messenger (ﷺ) as saying:When two persons enter into a transaction, each of them has the right to annul it so long as they are not separated and are together (at the place of transaction) ; or if one gives the other the right (to annul the transaction) But if one gives the other the option, the transaction is made on this condition (i. e. one has the right to annul the transaction), it becomes binding. And if they are separated after they have made the bargain and none of them annulled it, even then the transaction is binding", "french": "", "indonesian": "", "russian": "", "urdu": "لیث نے ہمیں نافع سے خبر دی ،  انہوں نے حضرت ابن عمر رضی اللہ عنہ سے اور انہوں نے رسول اللہ صلی اللہ", "grades": "", "reference": "Book 21, Hadith 54", "international_number": "3855", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3856", "arabic": "وحَدَّثَنِي  زُهَيْرُ بْنُ حَرْبٍ ،  وَابْنُ أَبِي عُمَرَ ، كِلَاهُمَا عَنْ سُفْيَانَ، قَالَ زُهَيْر", "bengali": "", "english": "Abdullah b. 'Umar (Allah be pleased with them) reported Allah's Messenger (ﷺ) as saying:When two persons enter into a transac. tion, each one of them has the right to annul it so long as they are not separated, or their transaction gives one another (as a condition) the right of annulling, and if their transaction, has the right of annulling it the transaction becomes binding. Ibn Abi Umar made this addition that whenever he (Ibn Umar) entered into a transaction with a person with the intention of not breaking it, he walked a while and then returned to him", "french": "", "indonesian": "", "russian": "", "urdu": "زہیر بن حرب اور ابن ابی عمر دونوں نے سفیان سے روایت کی ۔  زہیر نے کہا :  ہمیں سفیان بن عیینہ نے ابن", "grades": "", "reference": "Book 21, Hadith 55", "international_number": "3856", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3857", "arabic": "حَدَّثَنَا  يَحْيَي بْنُ يَحْيَى ،  وَيَحْيَي بْنُ أَيُّوبَ ،  وَقُتَيْبَةُ ،  وَابْنُ حُجْرٍ ، قَال", "bengali": "", "english": "Ibn Umar reported Allah's Messenger (ﷺ) as saying:There is no transaction between two persons entering a transaction until they separate, but only when there is an option to annul it", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن دینار سے روایت ہے کہ انہوں نے حضرت ابن عمر رضی اللہ عنہ سے سنا وہ کہہ رہے تھے ۔  رسول الل", "grades": "", "reference": "Book 21, Hadith 56", "international_number": "3857", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3858", "arabic": "حَدَّثَنَا  مُحَمَّدُ بْنُ الْمُثَنَّى ، حَدَّثَنَا  يَحْيَي بْنُ سَعِيدٍ ، عَنْ  شُعْبَةَ . ح وحَدّ", "bengali": "", "english": "Hakim b. Hazim (Allah be pleased with him) reported Allah's Messenger (ﷺ) as saying:Both parties in a business transaction have the right to annul it so long as they have not separated; and if they speak the truth and make everything clear they will be blessed in their transaction; but if they tell a lie and conceal anything the blessing on their transaction will be blotted out", "french": "", "indonesian": "", "russian": "", "urdu": "ابوخلیل نے عبداللہ بن حارث سے ،  انہوں نے حضرت حکیم بن حزام رضی اللہ عنہ سے اور انہوں نے نبی صلی الل", "grades": "", "reference": "Book 21, Hadith 57", "international_number": "3858", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3859", "arabic": "حَدَّثَنَا  عَمْرُو بْنُ عَلِيٍّ ، حَدَّثَنَا  عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ ، حَدَّثَنَا  هَمَّ", "bengali": "", "english": "A hadith like this has been transmitted on the authority of Hakim b. Hizam (Imam Muslim) said:Hakim b. Hizam was born inside the Ka'ba and lived for one hundred and twenty years", "french": "", "indonesian": "", "russian": "", "urdu": "ابوتیاح سے روایت ہے ،  انہوں نے کہا :  میں نے عبداللہ بن حارث سے سنا ،  وہ حکیم بن حزام رضی اللہ عنہ", "grades": "", "reference": "Book 21, Hadith 58", "international_number": "3859", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3860", "arabic": "حَدَّثَنَا  يَحْيَي بْنُ يَحْيَي ،  وَيَحْيَي بْنُ أَيُّوبَ ،  وَقُتَيْبَةُ ،  وَابْنُ حُجْرٍ ، قَال", "bengali": "", "english": "Abdullah b. Dinar narrated that he heard Ibn 'Umar (Allah be pleased with them) saying:A man mentioned to the Messenger of Allah (ﷺ) that he was deceived in a business transaction, whereupon Allah's Messenger (ﷺ) said: When you enter into a transaction, say: There should be no attempt to deceive", "french": "", "indonesian": "", "russian": "", "urdu": "اسماعیل بن جعفر نے عبداللہ بن دینار سے روایت کی ،  انہوں نے حضرت ابن عمر رضی اللہ عنہ سے سنا ،  وہ ک", "grades": "", "reference": "Book 21, Hadith 59", "international_number": "3860", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3861", "arabic": "حَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، حَدَّثَنَا  وَكِيعٌ ، حَدَّثَنَا  سُفْيَانُ . ح وحَدّ", "bengali": "", "english": "This hadith has been narrated on the authority of 'Abdullah b. Dinar with the same chain of transmitters but these words are not found in it.\" When he buys he should say:There should be no attempt to deceive", "french": "", "indonesian": "", "russian": "", "urdu": "سفیان اور شعبہ دونوں نے عبداللہ بن دینار سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی ،  لیکن ان دون", "grades": "", "reference": "Book 21, Hadith 60", "international_number": "3861", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3862", "arabic": "حَدَّثَنَا  يَحْيَي بْنُ يَحْيَي ، قَالَ: قَرَأْتُ عَلَى  مَالِكٍ ، عَنْ  نَافِعٍ ، عَنْ  ابْنِ عُمَ", "bengali": "", "english": "Ibn 'Umar (Allah be pleased with them) reported that Allah's Messenger (ﷺ) forbade the sale of fruits until they were clearly in good condition, he forbade it both to the seller and to the buyer", "french": "", "indonesian": "", "russian": "", "urdu": "امام مالک نے نافع سے ،  انہوں نے حضرت ابن عمر رضی اللہ عنہ سے روایت کی کہ اللہ کے رسول صلی اللہ علیہ", "grades": "", "reference": "Book 21, Hadith 61", "international_number": "3862", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3863", "arabic": "حَدَّثَنَا  ابْنُ نُمَيْرٍ ، حَدَّثَنَا  أَبِي ، حَدَّثَنَا  عُبَيْدُ اللَّهِ ، عَنْ  نَافِعٍ ، عَنْ", "bengali": "", "english": "Another chain on the authority of Ibn 'Umar narrated the same as the above hadith", "french": "", "indonesian": "", "russian": "", "urdu": "عبیداللہ نے ہمیں نافع سے حدیث بیان کی ،  انہوں نے حضرت ابن عمر رضی اللہ عنہ سے ،  انہوں نے نبی صلی ا", "grades": "", "reference": "Book 21, Hadith 62", "international_number": "3863", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3864", "arabic": "وحَدَّثَنِي  عَلِيُّ بْنُ حُجْرٍ السَّعْدِيُّ ،  وَزُهَيْرُ بْنُ حَرْبٍ ، قَالَا: حَدَّثَنَا  إِسْمَ", "bengali": "", "english": "Ibn 'Umar (Allah be pleased with them) reported that Allah's Messenger (ﷺ) forbade the sale of palm-trees (i. e. their trults) until the dates began to ripen, and ears of corn until they were white and were safe from blight. He forbade the seller and the buyer", "french": "", "indonesian": "", "russian": "", "urdu": "حضرت ابن عمر رضی اللہ عنہ سے روایت ہے کہ رسول اللہ صلی اللہ علیہ وسلم نے کھجور کی بیع سے منع فرمایا", "grades": "", "reference": "Book 21, Hadith 63", "international_number": "3864", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3865", "arabic": "حَدَّثَنِي  زُهَيْرُ بْنُ حَرْبٍ ، حَدَّثَنَا  جَرِيرٌ ، عَنْ  يَحْيَي بْنِ سَعِيدٍ ، عَنْ  نَافِعٍ", "bengali": "", "english": "Ibn Umar (Allah be pleased with them) reported Allah's Messenger (ﷺ) as saying:Do not buy fruit until its good condition becomes clear, and (the danger) of blight is no more. He said: Its good condition becoming clear implies that it becomes red or yellow", "french": "", "indonesian": "", "russian": "", "urdu": "جریر نے ہمیں یحییٰ بن سعید سے حدیث بیان کی ،  انہوں نے نافع سے ،  انہوں نے حضرت ابن عمر رضی اللہ عنہ", "grades": "", "reference": "Book 21, Hadith 64", "international_number": "3865", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3866", "arabic": "وحَدَّثَنَا  مُحَمَّدُ بْنُ الْمُثَنَّى ،  وَابْنُ أَبِي عُمَرَ ، قَالَا: حَدَّثَنَا  عَبْدُ الْوَهّ", "bengali": "", "english": "This hadith is reported or the authority of Yahya with the same chain of transmitters up to\" until its good condition becomes clear,\" but lie did not mention what follows (these words)", "french": "", "indonesian": "", "russian": "", "urdu": "عبدالوہاب نے یحییٰ سے اسی سند کے ساتھ  \" حتیٰ کہ اس کی صلاحیت واضح ہو جائے \"  تک حدیث بیان کی ،  اس", "grades": "", "reference": "Book 21, Hadith 65", "international_number": "3866", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3867", "arabic": "حَدَّثَنَا  ابْنُ رَافِعٍ ، حَدَّثَنَا  ابْنُ أَبِي فُدَيْكٍ ، أَخْبَرَنَا  الضَّحَّاكُ ، عَنْ  نَاف", "bengali": "", "english": "This hadith has been narrated on the authority of Ibn 'Umar through another chain of transmitters", "french": "", "indonesian": "", "russian": "", "urdu": "ابن ابی فُدیک نے ہمیں حدیث بیان کی ،  کہا :  ہمیں ضحاک نے نافع سے خبر دی ،  انہوں نے حضرت ابن عمر رض", "grades": "", "reference": "Book 21, Hadith 66", "international_number": "3867", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3868", "arabic": "حَدَّثَنَا  سُوَيْدُ بْنُ سَعِيدٍ ، حَدَّثَنَا  حَفْصُ بْنُ مَيْسَرَةَ ، حَدَّثَنِي  مُوسَى بْنُ عُق", "bengali": "", "english": "Nafi, reported on the authority of Ibn Umar (Allah be pleased with them) a hadith like that narrated before", "french": "", "indonesian": "", "russian": "", "urdu": "موسیٰ بن عقبہ نے مجھے نافع سے حدیث بیان کی ،  انہوں نے حضرت ابن عمر رضی اللہ عنہ سے ،  انہوں نے نبی", "grades": "", "reference": "Book 21, Hadith 67", "international_number": "3868", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3869", "arabic": "حَدَّثَنَا  يَحْيَي بْنُ يَحْيَي ،  وَيَحْيَي بْنُ أَيُّوبَ ،  وَقُتَيْبَةُ ،  وَابْنُ حُجْرٍ ، قَال", "bengali": "", "english": "Ibn Umar (Allah be pleased with them) reported Allah's Messenger' (ﷺ) as saying:Do not buy fruits (on the trees) until their good condition becomes clear", "french": "", "indonesian": "", "russian": "", "urdu": "اسماعیل بن جعفر نے عبداللہ بن دینار سے روایت کی کہ انہوں نے ابن عمر رضی اللہ عنہ سے سنا ،  انہوں نے", "grades": "", "reference": "Book 21, Hadith 68", "international_number": "3869", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3870", "arabic": "وحَدَّثَنِيهِ  زُهَيْرُ بْنُ حَرْبٍ ، حَدَّثَنَا  عَبْدُ الرَّحْمَنِ ، عَنْ  سُفْيَانَ . ح وَحَدَّثَ", "bengali": "", "english": "In the hadith transmitted on the authority of Shu'ba it was stated that Ibn Umar (Allah be pleased with them) was asked what good condition implied. He said:When (the danger of) blight is no more", "french": "", "indonesian": "", "russian": "", "urdu": "سفیان اور شعبہ دونوں نے عبداللہ بن دینار سے اسی سند کے ساتھ حدیث بیان کی ،  شعبہ کی حدیث میں یہ اضاف", "grades": "", "reference": "Book 21, Hadith 69", "international_number": "3870", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3871", "arabic": "حَدَّثَنَا  يَحْيَي بْنُ يَحْيَي ، أَخْبَرَنَا  أَبُو خَيْثَمَةَ ، عَنْ  أَبِي الزُّبَيْرِ ، عَنْ  ج", "bengali": "", "english": "Jabir (Allah be pleased with him) reported that Allah's Messenger (ﷺ) forbade (or forbade us) the sale of fruits until they are ripe in a good condition", "french": "", "indonesian": "", "russian": "", "urdu": "ابوزبیر نے ہمیں حضرت جابر رضی اللہ عنہ سے حدیث بیان کی ،  انہوں نے کہا :  رسول اللہ صلی اللہ علیہ وس", "grades": "", "reference": "Book 21, Hadith 70", "international_number": "3871", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3872", "arabic": "حَدَّثَنَا  أَحْمَدُ بْنُ عُثْمَانَ النَّوْفَلِيُّ ، حَدَّثَنَا  أَبُو عَاصِمٍ . ح حَدَّثَنِي  مُحَم", "bengali": "", "english": "Jabir b. Abdullah (Allah be pleased with them) reported Allah's Messenger (ﷺ) forbidding the sale of fruit until its good condition is obvious", "french": "", "indonesian": "", "russian": "", "urdu": "عمرو بن دینار نے حدیث بیان کی کہ انہوں نے حضرت جابر بن عبداللہ رضی اللہ عنہ سے سنا وہ کہہ رہے تھے :", "grades": "", "reference": "Book 21, Hadith 71", "international_number": "3872", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3873", "arabic": "حَدَّثَنَا  مُحَمَّدُ بْنُ الْمُثَنَّى ،  وَابْنُ بَشَّارٍ ، قَالَا: حَدَّثَنَا  مُحَمَّدُ بْنُ جَعْ", "bengali": "", "english": "Abu Bakhtari reported:I asked Ibn 'Abbas (Allah be pleased with them) about the sale of dates. He said: Allah's Messenger (ﷺ) forbade the sale of dates of the trees until one eats them or they are eaten (i. e. they are fit to be eaten) or until they are weighed (or measured). I said: What does it imply:\" Until it is weighed\"? Thereupon a person who was with him (Ibn Abbas) said: Until he is able to keep it with him (after plucking them)", "french": "", "indonesian": "", "russian": "", "urdu": "ابو بختری سے روایت ہے ،  انہوں نے کہا :  میں نے حضرت ابن عباس رضی اللہ عنہ سے کھجور کی بیع کے بارے م", "grades": "", "reference": "Book 21, Hadith 72", "international_number": "3873", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3874", "arabic": "حَدَّثَنِي  أَبُو كُرَيْبٍ مُحَمَّدُ بْنُ الْعَلَاءِ ، حَدَّثَنَا  مُحَمَّدُ بْنُ فُضَيْلٍ ، عَنْ  أ", "bengali": "", "english": "Abu Huraira (Allah be pleased with him) reported Allah's Messenger (ﷺ) as saying:Do not sell the fruits until their good condition becomes evident", "french": "", "indonesian": "", "russian": "", "urdu": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ،  انہوں نے کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :", "grades": "", "reference": "Book 21, Hadith 73", "international_number": "3874", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3875", "arabic": "حَدَّثَنَا  يَحْيَي بْنُ يَحْيَي ، أَخْبَرَنَا  سُفْيَانُ بْنُ عُيَيْنَةَ ، عَنْ  الزُّهْرِيِّ . ح و", "bengali": "", "english": "Ibn Umar (Allah be pleased with them) reported Allah's Apostle (ﷺ) forbidding the sale of fruits until their good condition becomes evident and the purchase of dates for dates", "french": "", "indonesian": "", "russian": "", "urdu": "ہمیں یحییٰ بن یحییٰ نے حدیث بیان کی ،  کہا :  ہمیں سفیان بن عیینہ نے زہری سے خبر دی ،  نیز ہمیں ابن", "grades": "", "reference": "Book 21, Hadith 74", "international_number": "3875", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3876", "arabic": "قَالَ  ابْنُ عُمَرَ : وَحَدَّثَنَا  زَيْدُ بْنُ ثَابِتٍ ، أَنَّ رَسُولَ اللَّهِ صَلَّى اللَّهُ عَلَي", "bengali": "", "english": "Zaid b. Thabit (Allah be pleased with him) said that Allah's Messenger (ﷺ) gave a concession in case of the sale known as al-araya, there is an addition of the word an tuba'a in the hadith transmitted by Ibn Numair", "french": "", "indonesian": "", "russian": "", "urdu": "ابن عمر رضی اللہ عنہ نے کہا :  ہمیں زید بن ثابت نے حدیث بیان کی کہ رسول اللہ صلی اللہ علیہ وسلم نے ب", "grades": "", "reference": "Book 21, Hadith 75", "international_number": "3876", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3877", "arabic": "وحَدَّثَنِي  أَبُو الطَّاهِرِ ،  وَحَرْمَلَةُ ، وَاللَّفْظُ لِحَرْمَلَةَ، قَالَا: أَخْبَرَنَا  ابْنُ", "bengali": "", "english": "Abu Huraira (Allah be pleased with him) reported Allah's Messenger (ﷺ) as saying:Do not buy the fruit until their condition is clear, and do not buy the fresh dates. A hadith like this has been reported by Ibn 'Umar through another chain of transmitters", "french": "", "indonesian": "", "russian": "", "urdu": "ابن شہاب سے روایت ہے ،  انہوں نے کہا :  مجھے سعید بن مسیب اور ابوسلمہ بن عبدالرحمٰن نے حدیث بیان کی", "grades": "", "reference": "Book 21, Hadith 76", "international_number": "3877", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3878", "arabic": "وَحَدَّثَنِي وَحَدَّثَنِي  مُحَمَّدُ بْنُ رَافِعٍ ، حَدَّثَنَا  حُجَيْنُ بْنُ الْمُثَنَّى ، حَدَّثَن", "bengali": "", "english": "Sa'id b. al-Musayyib said that Allah's Messenger (ﷺ) forbade the transaction of Af Muzabana and Muhaqala. Muzabana means that fresh dates on the trees should be sold against dry dates. Muhaqala implies that the wheat in the ear should be sold against the wheat and getting the land on rent for the wheat (produced in it). He (the narrator) said that the Prophet (ﷺ) had aid:Do not sell fresh fruits on the trees until their good condition becomes manifest, and do not sell fresh dates on the trees against dry dates. Salim said: Abdullah informed me on the authority of Zaid b. Thabit, Allah's Messenger (ﷺ) having given concession afterwards in case of ariyya transactions by which dry dates can be exchanged with fresh dates, but he did not permit it in other cases", "french": "", "indonesian": "", "russian": "", "urdu": "ابن شہاب نے سعید بن مسیب سے روایت کی کہ رسول اللہ صلی اللہ علیہ وسلم نے مزابنہ اور محاقلہ کی بیع سے", "grades": "", "reference": "Book 21, Hadith 77", "international_number": "3878", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3879", "arabic": "حَدَّثَنَا  يَحْيَى بْنُ يَحْيَى ، قَالَ: قَرَأْتُ عَلَى  مَالِكٍ ، عَنْ  نَافِعٍ ، عَنْ  ابْنِ عُمَ", "bengali": "", "english": "Zaid b. Thabit (Allah be pleased with him) reported Allah's Messenger (may peace he upon him) having given concession in case of 'ariyya for selling dry dates (with) fresh dates after measuring them out", "french": "", "indonesian": "", "russian": "", "urdu": "امام مالک نے نافع سے ،  انہوں نے ابن عمر رضی اللہ عنہ سے ،  انہوں نے حضرت زید بن ثابت رضی اللہ عنہ س", "grades": "", "reference": "Book 21, Hadith 78", "international_number": "3879", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3880", "arabic": "وحَدَّثَنَا  يَحْيَى بْنُ يَحْيَى ، أَخْبَرَنَا  سُلَيْمَانُ بْنُ بِلَالٍ ، عَنْ  يَحْيَى بْنِ سَعِي", "bengali": "", "english": "Zaid b. Thabit reported that Allah's Messenger (ﷺ) give concession in case of 'ariyya transactions according to which the members of the household give dry dates according to a measure and then eat fresh dates (in exchange for it)", "french": "", "indonesian": "", "russian": "", "urdu": "سلیمان بن بلال نے ہمیں یحییٰ بن سعید سے خبر دی کہا :  مجھے نافع نے خبر دی کہ انہوں نے حضرت عبداللہ ب", "grades": "", "reference": "Book 21, Hadith 79", "international_number": "3880", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3881", "arabic": "وحَدَّثَنَاه  مُحَمَّدُ بْنُ الْمُثَنَّى ، حَدَّثَنَا  عَبْدُ الْوَهَّابِ ، قَال: سَمِعْتُ  يَحْيَى", "bengali": "", "english": "A hadith like this has been narrated on the authority of Nafi' with the same chain of transmitters", "french": "", "indonesian": "", "russian": "", "urdu": "عبدالوہاب نے ہمیں کہا کہ میں نے یحییٰ بن سعید سے سنا وہ کہہ رہے تھے :  مجھے نافع نے اسی سند سے اسی ک", "grades": "", "reference": "Book 21, Hadith 80", "international_number": "3881", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3882", "arabic": "وحَدَّثَنَاه  يَحْيَى بْنُ يَحْيَى ، أَخْبَرَنَا  هُشَيْمٌ ، عَنْ  يَحْيَى بْنِ سَعِيدٍ ، بِهَذَا ال", "bengali": "", "english": "Yahya b. Sa'id reported this hadith with the same chain of transmitters but with this change:'Ariyya implies that date-palm trees should be donated to the people and then they sell it with a measure of dry dates", "french": "", "indonesian": "", "russian": "", "urdu": "ہشیم نے ہمیں یحییٰ بن سعید سے اسی سند کے ساتھ خبر دی ،  البتہ انہوں نے کہا :  عریہ سے وہ کھجور کا در", "grades": "", "reference": "Book 21, Hadith 81", "international_number": "3882", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3883", "arabic": "وحَدَّثَنَا  مُحَمَّدُ بْنُ رُمْحِ بْنِ الْمُهَاجِرِ ، حَدَّثَنَا  اللَّيْثُ ، عَنْ  يَحْيَى بْنِ سَ", "bengali": "", "english": "Zaid b Thabit (Allah be pleased with him) reported that Allah's Messenger (ﷺ) gave concession in case of al-'ariyya transactions (for exchanging dates) for dates with measure. Yahya said:'Ariyya implies that a person should buy fresh dates on the tree for his family to eat against a measure of dry dates", "french": "", "indonesian": "", "russian": "", "urdu": "لیث نے ہمیں یحییٰ بن سعید سے خبر دی ،  انہوں نے نافع سے ،  انہوں نے حضرت عبداللہ بن عمر رضی اللہ عنہ", "grades": "", "reference": "Book 21, Hadith 82", "international_number": "3883", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3884", "arabic": "وحَدَّثَنَا  ابْنُ نُمَيْرٍ ، حَدَّثَنَا  أَبِي ، حَدَّثَنَا  عُبَيْدُ اللَّهِ ، حَدَّثَنِي  نَافِعٌ", "bengali": "", "english": "Zaid b. Thabit (Allah be pleased with him) reported Allah's Messenger (ﷺ) granting concession in case of 'ariyya transactions and that implies selling of (dry dates for fresh dates) according to a measure", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن نمیر نے ہمیں حدیث بیان کی ،  کہا :  ہمیں عبیداللہ نے حدیث سنائی ،  انہوں نے کہا :  مجھے ن", "grades": "", "reference": "Book 21, Hadith 83", "international_number": "3884", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3885", "arabic": "وحَدَّثَنَاه  ابْنُ الْمُثَنَّى ، حَدَّثَنَا  يَحْيَى بْنُ سَعِيدٍ ، عَنْ  عُبَيْدِ اللَّهِ، بِهَذَا", "bengali": "", "english": "Ubaidullah reported this hadith with a slight change of words on the same authority (as quoted above)", "french": "", "indonesian": "", "russian": "", "urdu": "یحییٰ بن سعید نے عبیداللہ سے اسی سند کے ساتھ حدیث روایت کی ،  اور  ( فروخت کر دیا جائے کی بجائے )", "grades": "", "reference": "Book 21, Hadith 84", "international_number": "3885", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3886", "arabic": "وحَدَّثَنَا  أَبُو الرَّبِيعِ ،  وَأَبُو كَامِلٍ ، قَالَا: حَدَّثَنَا  حَمَّادٌ . ح وحَدَّثَنِيهِ  ع", "bengali": "", "english": "Nafi, reported this hadith with the same chain of transmitters stating that Allah's Messengtr (ﷺ) granted concession in case of 'ariyya transactions (for exchange of the same commodity) with measure", "french": "", "indonesian": "", "russian": "", "urdu": "ایوب نے نافع سے اسی سند کے ساتھ روایت کی کہ رسول اللہ صلی اللہ علیہ وسلم نے عرایا کی بیع میں اس کے ا", "grades": "", "reference": "Book 21, Hadith 85", "international_number": "3886", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3887", "arabic": "وحَدَّثَنَا  عَبْدُ اللَّهِ بْنُ مَسْلَمَةَ الْقَعْنَبِيُّ ، حَدَّثَنَا  سُلَيْمَانُ يَعْنِي ابْنَ ب", "bengali": "", "english": "Bashair b. Yasir reported on the authority of some of the Companions of Allah's Messenger (ﷺ) among the members of his family among whom one was Sahl b. Abu Hathma that Allah's Messenger (ﷺ) forbade buying of fresh dates against dry dates and that it is Riba and this is Muzabana, but he made an exemption of 'ariyya (donations) of a tree or two in which case the members of a family sell dry dates and buy fresh dates for eating them", "french": "", "indonesian": "", "russian": "", "urdu": "سلیمان بن بلال نے ہمیں یحییٰ بن سعید سے حدیث بیان کی ،  انہوں نے بُشیر بن یسار سے ،  انہوں نے اپنے گ", "grades": "", "reference": "Book 21, Hadith 86", "international_number": "3887", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3888", "arabic": "وحَدَّثَنَا  قُتَيْبَةُ بْنُ سَعِيدٍ ، حَدَّثَنَا  لَيْثٌ . ح وَحَدَّثَنَا  ابْنُ رُمْحٍ ، أَخْبَرَن", "bengali": "", "english": "Bushair b. Yasar reported on the authority of some of the Companion of Allah's Messenger (ﷺ) that he exempted the transactions, of 'ariyya (from the direct exchange of one kind) after measuring the dry dates (in exchange for fresh dates)", "french": "", "indonesian": "", "russian": "", "urdu": "لیث نے ہمیں یحییٰ بن سعید سے خبر دی ،  انہوں نے بُشیر بن یسار سے اور انہوں نے اللہ کے رسول صلی اللہ", "grades": "", "reference": "Book 21, Hadith 87", "international_number": "3888", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3889", "arabic": "وحَدَّثَنَا  مُحَمَّدُ بْنُ الْمُثَنَّى ،  وَإِسْحَاقُ بْنُ إِبْرَاهِيمَ ،  وَابْنُ أَبِي عُمَرَ ، ج", "bengali": "", "english": "Bushair b. Yasir reported on the authority of some of the Companions of Allah's Messenger (may peace be upon hinn) from among the members of his family that he forbade (the direct exchange of a commodity having different qualities) but with the change that Ishaq and Ibn al-Muthanna used the word Zabn in place of Riba and Ibn Abu 'Umar used the word Riba (interest)", "french": "", "indonesian": "", "russian": "", "urdu": "محمد بن مثنیٰ ،  اسحاق بن ابراہیم اور ابن ابی عمر سب نے  ( عبدالوہاب )  ثقفی سے روایت کی ،  انہوں نے", "grades": "", "reference": "Book 21, Hadith 88", "international_number": "3889", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3890", "arabic": "وحَدَّثَنَاه  عَمْرٌو النَّاقِدُ ،  وَابْنُ نُمَيْرٍ ، قَالَا: حَدَّثَنَا  سُفْيَانُ بْنُ عُيَيْنَةَ", "bengali": "", "english": "A hadith like this has been narrated on the authority of Sahl b. Abu Hathma", "french": "", "indonesian": "", "russian": "", "urdu": "سفیان بن عیینہ نے ہمیں یحییٰ بن سعید سے حدیث بیان کی ،  انہوں نے بشیر بن یسار سے ،  انہوں نے سہل بن", "grades": "", "reference": "Book 21, Hadith 89", "international_number": "3890", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3891", "arabic": "حَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ،  وَحَسَنٌ الْحُلْوَانِيُّ ، قَالَا: حَدَّثَنَا  أَبُو", "bengali": "", "english": "Sahl b. Abu Hathma reported Allah's Messenger (ﷺ) having forbidden Muzabana, i. e. exchange of fresh dates with dry dates. except in case of those to whom donations of some trees have been made. It is for them that concession has been given", "french": "", "indonesian": "", "russian": "", "urdu": "ولید بن کثیر نے کہا :  مجھے بنو حارثہ کے مولیٰ بشیر بن یسار نے حدیث بیان کی کہ رافع بن خدیج اور سہل", "grades": "", "reference": "Book 21, Hadith 90", "international_number": "3891", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3892", "arabic": "حَدَّثَنَا  عَبْدُ اللَّهِ بْنُ مَسْلَمَةَ بْنِ قَعْنَبٍ ، حَدَّثَنَا  مَالِكٌ . ح وحَدَّثَنَا  يَحْ", "bengali": "", "english": "Abu Huraira (Allah be pleased with him) reported Allah's Messenger (ﷺ) having given exemption of 'ariyya transactions measuring less than five wasqs or up to five wasqs (the narrator Dawud is in doubt whether it was five or less than five)", "french": "", "indonesian": "", "russian": "", "urdu": "یحییٰ بن یحییٰ نے کہا :  میں نے امام مالک سے پوچھا :  کیا آپ کو داود بن حصین نے ابن ابی احمد کے آزاد", "grades": "", "reference": "Book 21, Hadith 91", "international_number": "3892", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3893", "arabic": "حَدَّثَنَا  يَحْيَى بْنُ يَحْيَى التَّمِيمِيُّ ، قَالَ: قَرَأْتُ عَلَى  مَالِكٍ ، عَنْ  نَافِعٍ ، عَ", "bengali": "", "english": "Ibn Umar (Allah be pleased them) reported Allah's Messenger (ﷺ) having forbidden Muzabana, and Muzabana implies the selling of fresh dates for dry dates by measuring them out and the selling of raisins by measure for grapes", "french": "", "indonesian": "", "russian": "", "urdu": "امام مالک نے نافع سے ،  انہوں نے حضرت ابن عمر رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ علیہ وس", "grades": "", "reference": "Book 21, Hadith 92", "international_number": "3893", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3894", "arabic": "حَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ،  وَمُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ ، قَال", "bengali": "", "english": "Abdullah (b. Umar) reported that Allah's Apostle (ﷺ) forbade Muzabana, i. e. buying of fresh dates (on) the trees for dry dates by measure, and the buying of grapes for raisins by measure and the selling of field of corn for corn by measure", "french": "", "indonesian": "", "russian": "", "urdu": "محمد بن بشیر نے کہا :  ہمیں عبیداللہ نے نافع سے حدیث بیان کی کہ حضرت عبداللہ  ( بن عمر رضی اللہ عنہ", "grades": "", "reference": "Book 21, Hadith 93", "international_number": "3894", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3895", "arabic": "وحَدَّثَنَاه  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، حَدَّثَنَا  ابْنُ أَبِي زَائِدَةَ ، عَنْ  عُبَيْدِ", "bengali": "", "english": "A hadith like this has been narrated on the authority of 'Ubaidullah with the same chain of transmitters", "french": "", "indonesian": "", "russian": "", "urdu": "ابن ابی زائدہ نے عبیداللہ سے اسی سند کے ساتھ اسی کے مانند روایت کی", "grades": "", "reference": "Book 21, Hadith 94", "international_number": "3895", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3896", "arabic": "حَدَّثَنِي  يَحْيَى بْنُ مَعِينٍ ،  وَهَارُونُ بْنُ عَبْدِ اللَّهِ ،  وَحُسَيْنُ بْنُ عِيسَى ، قَالُ", "bengali": "", "english": "Ibn 'Umar (Allah be pleased with them) reported Allah's Messenger (ﷺ) having forbidden Muzabana, and Muzabana is the selling of dry dates by measure for fresh dates and the selling of raisins by measure for grapes and selling of all Ports of fruits on the basis of calculation", "french": "", "indonesian": "", "russian": "", "urdu": "ابو اسامہ نے ہم سے بیان کیا ،  کہا :  ہمیں عبیداللہ نے نافع سے حدیث بیان کی ،  انہوں نے حضرت ابن عمر", "grades": "", "reference": "Book 21, Hadith 95", "international_number": "3896", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3897", "arabic": "حَدَّثَنِي  عَلِيُّ بْنُ حُجْرٍ السَّعْدِيُّ ،  وَزُهَيْرُ بْنُ حَرْبٍ ، قَالَا: حَدَّثَنَا  إِسْمَا", "bengali": "", "english": "Ibn 'Umar (Allah be pleased with them) reported Allah's Messenger (ﷺ) having forbidden Muzabana, and Muzabana implies the selling of dry dates for fresh dates on the tree with a definite measure (making it clear) that in case it increases, it belongs to me and if it is less, it is my responsibility", "french": "", "indonesian": "", "russian": "", "urdu": "اسماعیل بن ابراہیم نے ہمیں ایوب سے حدیث بیان کی ،  انہوں نے نافع سے ،  انہوں نے حضرت ابن عمر رضی الل", "grades": "", "reference": "Book 21, Hadith 96", "international_number": "3897", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3898", "arabic": "وحَدَّثَنَاه  أَبُو الرَّبِيعِ ،  وَأَبُو كَامِلٍ ، قَالَا: حَدَّثَنَا  حَمَّادٌ ، حَدَّثَنَا  أَيُّ", "bengali": "", "english": "A hadith like this has been transmitted on the authority of Ayyub", "french": "", "indonesian": "", "russian": "", "urdu": "حماد نے ایوب سے اسی سند کے ساتھ اسی کے ہم معنی حدیث بیان کی", "grades": "", "reference": "Book 21, Hadith 97", "international_number": "3898", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3899", "arabic": "حَدَّثَنَا  قُتَيْبَةُ بْنُ سَعِيدٍ ، حَدَّثَنَا  لَيْثٌ . ح وَحَدَّثَنِي  مُحَمَّدُ بْنُ رُمْحٍ ، أ", "bengali": "", "english": "Abdullah (b. Umar) (Allah be pleased with them) reported Allah's Messenger (ﷺ) having forbidden Mazabana, and it implies that one should sell the fresh fruits of his orchard (for dry fruits) or, if it is fresh dates, for dry dates with a measure, or if it is grapes for raisins or if it is corn in the field for dry corn with a measure He (the Holy Prophet) in fact forbade all such transactions. Qutaiba has narrated it with a slight variation of words", "french": "", "indonesian": "", "russian": "", "urdu": "قتیبہ بن سعید اور محمد بن رُمح نے لیث سے حدیث بیان کی ،  انہوں نے نافع سے ،  انہوں نے حضرت عبداللہ ر", "grades": "", "reference": "Book 21, Hadith 98", "international_number": "3899", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3900", "arabic": "وحَدَّثَنِيهِ  أَبُو الطَّاهِرِ ، أَخْبَرَنَا  ابْنُ وَهْبٍ ، حَدَّثَنِي  يُونُسُ . ح وحَدَّثَنِي  ا", "bengali": "", "english": "This hadith has been narrated on the authority of Nafi with another chain of transmitters", "french": "", "indonesian": "", "russian": "", "urdu": "یونس ،  ضحاک اور موسیٰ بن عقبہ سب نے نافع سے اسی سند کے ساتھ ان  ( عبیداللہ ،  ایوب اور لیث )  کی حد", "grades": "", "reference": "Book 21, Hadith 99", "international_number": "3900", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3901", "arabic": "حَدَّثَنَا  يَحْيَى بْنُ يَحْيَى ، قَالَ: قَرَأْتُ عَلَى  مَالِكٍ ، عَنْ  نَافِعٍ ، عَنْ  ابْنِ عُمَ", "bengali": "", "english": "Ibn Umar (Allah be pleased with them) reported Allah's Messenger (ﷺ) as saying:If anyone buys palm-trees after they have been fecundated the fruit belongs to the seller unless the buyer makes a proviso", "french": "", "indonesian": "", "russian": "", "urdu": "یحییٰ بن یحییٰ نے کہا :  میں نے امام مالک کے سامنے قراءت کی ،  انہوں نے نافع سے اور انہوں نے حضرت اب", "grades": "", "reference": "Book 21, Hadith 100", "international_number": "3901", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3902", "arabic": "حَدَّثَنَا  مُحَمَّدُ بْنُ الْمُثَنَّى ، حَدَّثَنَا  يَحْيَى بْنُ سَعِيدٍ . ح وحَدَّثَنَا  ابْنُ نُم", "bengali": "", "english": "Nafi reported on the authority of Ibn Umar (Allah be pleased with them) that the Messenger of Allah (ﷺ) said:Whichever tree is bought with its roots, and if it is fecundatedits fruit would belong to one who has grafted it except when the provision is laid down by the buyer", "french": "", "indonesian": "", "russian": "", "urdu": "عبیداللہ نے ہمیں نافع سے حدیث بیان کی اور انہوں نے حضرت ابن عمر رضی اللہ عنہ سے روایت کی کہ رسول الل", "grades": "", "reference": "Book 21, Hadith 101", "international_number": "3902", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3903", "arabic": "وحَدَّثَنَا  قُتَيْبَةُ بْنُ سَعِيدٍ ، حَدَّثَنَا  لَيْثٌ . ح وحَدَّثَنَا  ابْنُ رُمْحٍ ، أَخْبَرَنَ", "bengali": "", "english": "Ibn Umar (Allah be pleased with them) reported Allah's Apostle (ﷺ) as saying:Whosoever grafts the tree and then sells its roots, its fruit will belong to one who grafts it except when provision is laid down by the buyer", "french": "", "indonesian": "", "russian": "", "urdu": "لیث نے ہمیں نافع سے ،  انہوں نے حضرت ابن عمر رضی اللہ عنہ سے روایت کی کہ نبی صلی اللہ علیہ وسلم نے ف", "grades": "", "reference": "Book 21, Hadith 102", "international_number": "3903", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3904", "arabic": "وحَدَّثَنَاه  أَبُو الرَّبِيعِ ،  وَأَبُو كَامِلٍ ، قَالَا: حَدَّثَنَا  حَمَّادٌ . ح وحَدَّثَنِيهِ", "bengali": "", "english": "This hadith has been narrated on the authority of Nafi, with the same chain of transmitters", "french": "", "indonesian": "", "russian": "", "urdu": "ایوب نے نافع سے اسی سند کے ساتھ اسی طرح روایت کی", "grades": "", "reference": "Book 21, Hadith 103", "international_number": "3904", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3905", "arabic": "حَدَّثَنَا  يَحْيَى بْنُ يَحْيَى ،  وَمُحَمَّدُ بْنُ رُمْحٍ ، قَالَا: أَخْبَرَنَا  اللَّيْثُ . ح وحَ", "bengali": "", "english": "Abdullah b. Umar (Allah be pleased with them) reported Allah's Massenger (ﷺ) as saying:He who buys a tree after it has been fecundated, its fruit belongs to one who sells it except when the provision has been laid down by the buyer (that it will belong to him), and he who buys a slave, his property belongs to one who sells him except when a provision has been laid down by the buyer (that it will be transferred to him with the slave)", "french": "", "indonesian": "", "russian": "", "urdu": "لیث نے ہمیں ابن شہاب سے خبر دی ،  انہوں نے سالم بن عبداللہ بن عمر سے اور انہوں نے حضرت عبداللہ بن عم", "grades": "", "reference": "Book 21, Hadith 104", "international_number": "3905", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3906", "arabic": "وحَدَّثَنَاه  يَحْيَى بْنُ يَحْيَى ،  وَأَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ،  وَزُهَيْرُ بْنُ حَرْبٍ ،", "bengali": "", "english": "A hadith like this has been narrated on the authority of al Zuhri", "french": "", "indonesian": "", "russian": "", "urdu": "سفیان بن عیینہ نے زہری سے اسی سند کے ساتھ اسی کے مانند روایت کی", "grades": "", "reference": "Book 21, Hadith 105", "international_number": "3906", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3907", "arabic": "وحَدَّثَنِي  حَرْمَلَةُ بْنُ يَحْيَى ، أَخْبَرَنَا  ابْنُ وَهْبٍ ، أَخْبَرَنِي  يُونُسُ ، عَنْ  ابْن", "bengali": "", "english": "Ibn Umar reported on the authority of his father as Allah's Apostle (ﷺ) saying so", "french": "", "indonesian": "", "russian": "", "urdu": "یونس نے مجھے ابن شہاب سے خبر دی ،  کہا :  مجھے سالم بن عبداللہ بن عمر نے حدیث بیان کی کہ ان کے والد", "grades": "", "reference": "Book 21, Hadith 106", "international_number": "3907", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3908", "arabic": "حَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ،  وَمُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ ،  وَز", "bengali": "", "english": "Jabir b. Abdullah (Allah be pleased with them) reported that Allah's Messenger (ﷺ) had forbidden Muhaqala. and Muzabana, Mukhibara and the sale of fruits until their good condition becomes clear, and (he commanded) that (commodities) should not be sold but for the dinar and dirham except in case of araya", "french": "", "indonesian": "", "russian": "", "urdu": "سفیان بن عیینہ نے ہمیں ابن جریج سے حدیث بیان کی ،  انہوں نے عطاء سے اور انہوں نے حضرت جابر بن عبدالل", "grades": "", "reference": "Book 21, Hadith 107", "international_number": "3908", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3909", "arabic": "وحَدَّثَنَا  عَبْدُ بْنُ حُمَيْدٍ ، أَخْبَرَنَا  أَبُو عَاصِمٍ ، أَخْبَرَنَا  ابْنُ جُرَيْجٍ ، عَنْ", "bengali": "", "english": "Jabir b. 'Abdullah (Allah be pleased with them) reported that Allah's Messenger (ﷺ) forbade the types of sales as described before", "french": "", "indonesian": "", "russian": "", "urdu": "ابوعاصم نے ہمیں خبر دی ،  کہا :  ہمیں ابن جریج نے عطاء اور ابوزبیر سے خبر دی ،  ان دونوں نے حضرت جاب", "grades": "", "reference": "Book 21, Hadith 108", "international_number": "3909", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3910", "arabic": "حَدَّثَنَا  إِسْحَاقُ بْنُ إِبْرَاهِيمَ الْحَنْظَلِيُّ ، أَخْبَرَنَا  مَخْلَدُ بْنُ يَزِيدَ الْجَزَر", "bengali": "", "english": "Jabir b. 'Abdullah (Allah be pleased with them) reported that Allah's Messenger (ﷺ) forbade Mukhabara and Muhaqala, and Muzabana, and the sale of the fruit until it is fit for eating, and its sale but with dirham and dinar. Exception is made in case of 'araya. Ata' said:Jabir explained (these terms) for us. As for Mukhabara it is this that a wasteland is given by a person to another and he makes an investment in it and then gets a share in the produce. According to him (Jabir), Muzabana is the sell of fresh dates on the tree for dry dates with a measure, and Muhaqala in agriculture implies that one should sell the standing crop for grains with a measure", "french": "", "indonesian": "", "russian": "", "urdu": "مخلد بن یزید جزری نے ہمیں خبر دی ،  کہا :  ہمیں ابن جریج نے حدیث سنائی ،  انہوں نے کہا :  مجھے عطاء", "grades": "", "reference": "Book 21, Hadith 109", "international_number": "3910", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3911", "arabic": "حَدَّثَنَا  إِسْحَاقُ بْنُ إِبْرَاهِيمَ ، وَمُحَمَّدُ بْنُ أَحْمَدَ بْنِ أَبِي خَلَفٍ، كِلَاهُمَا، ع", "bengali": "", "english": "Jabir b. Abdullah (Allah be pleased with them) reported Allah's Messenger (ﷺ) forbidding Muhaqala, and Muzabana, and Mukhabara, and the buying of date-palm until its fruit is ripened (ripening means that its colour becomes red or yellow, or it is fit for being eaten). And Muhaqala implies that crops in the field are bought for grains according to a customary measure. Muzabana implies that date-palm should be sold for dry dates by measuring them with wisqs, and al-Mukhabara is (a share), maybe one-third or one-fourth (in produce) or something like it. Zaid (one of the narrators) said to Ata' b. Abu Rabah (the other narrator):Did You bear Jabir b. Abdullah (Allah be pleased with them) making a mention of it that he had heard it directly from Allah's Messenger (ﷺ)? He said: Yes", "french": "", "indonesian": "", "russian": "", "urdu": "زید بن ابی انیسہ سے روایت ہے ،  انہوں نے کہا :  ہم سے ابوولید مکی نے حدیث بیان کی جبکہ وہ عطاء بن اب", "grades": "", "reference": "Book 21, Hadith 110", "international_number": "3911", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3912", "arabic": "وحَدَّثَنَا  عَبْدُ اللَّهِ بْنُ هَاشِمٍ ، حَدَّثَنَا  بَهْزٌ ، حَدَّثَنَا  سَلِيمُ بْنُ حَيَّانَ ،", "bengali": "", "english": "Jabir b. Abdullah (Allah be pleased with them) reported Allah's Messenger (ﷺ) forbidding Muzabana and Muhaqala, and Mukhabara, and the sale of fruits until they are ripe. I (the narrator) said to Sa'id (the other narrator):What does ripening imply? He said: It meant that they become red or become yellow and are fit for eating", "french": "", "indonesian": "", "russian": "", "urdu": "سلیم بن حیان نے ہمیں حدیث بیان کی ،  کہا :  ہمیں سعید بن میناء نے حضرت جابر بن عبداللہ رضی اللہ عنہ", "grades": "", "reference": "Book 21, Hadith 111", "international_number": "3912", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3913", "arabic": "حَدَّثَنَا  عُبَيْدُ اللَّهِ بْنُ عُمَرَ الْقَوَارِيرِيُّ ،  وَمُحَمَّدُ بْنُ عُبَيْدٍ الْغُبَرِيُّ", "bengali": "", "english": "Jabir b. Abdullah (Allah be pleased with them) reported Allah's Messenger (ﷺ) forbidding Muhaqala and Muzabana and Mu'awama and Mukhabara. (One of the narrators) 'said:Sale years ahead is Mu'awama, and making exceptional but he made an exemption of araya", "french": "", "indonesian": "", "russian": "", "urdu": "حماد بن زید نے ہمیں حدیث بیان کی ،  کہا :  ہمیں ایوب نے ابوزبیر اور سعید بن میناء سے حدیث بیان کی ،", "grades": "", "reference": "Book 21, Hadith 112", "international_number": "3913", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3914", "arabic": "وحَدَّثَنَاه  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ،  وَعَلِيُّ بْنُ حُجْرٍ ، قَالَا: حَدَّثَنَا  إِسْمَ", "bengali": "", "english": "A hadith like this has been narrated on the authority of Jabir (Allah be pleased with him) from Allah's Apostle (ﷺ). but he made no mention of transactions years (ahead) implying Mu'awama", "french": "", "indonesian": "", "russian": "", "urdu": "اسماعیل بن علیہ نے ہمیں ایوب سے حدیث بیان کی ،  انہوں نے ابوزبیر سے ،  انہوں نے حضرت جابر بن عبداللہ", "grades": "", "reference": "Book 21, Hadith 113", "international_number": "3914", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3915", "arabic": "وحَدَّثَنَا  إِسْحَاقُ بْنُ مَنْصُورٍ ، حَدَّثَنَا  عُبَيْدُ اللَّهِ بْنُ عَبْدِ الْمَجِيدِ ، حَدَّث", "bengali": "", "english": "Jabir b. Abdullah (Allah be pleased with them) reported that Allah's Messenger (ﷺ) forbade leasing of land, and selling ahead for years and selling of fruits before they become ripe", "french": "", "indonesian": "", "russian": "", "urdu": "رباح بن ابی معروف نے ہمیں حدیث بیان کی ، انہوں نے کہا :  میں نے عطاء سے سنا ،  انہوں نے حضرت جابر بن", "grades": "", "reference": "Book 21, Hadith 114", "international_number": "3915", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3916", "arabic": "وحَدَّثَنِي  أَبُو كَامِلٍ الْجَحْدَرِيُّ ، حَدَّثَنَا  حَمَّادٌ يَعْنِي ابْنَ زَيْدٍ ، عَنْ  مَطَرٍ", "bengali": "", "english": "Jabir b. Abdullah (Allah be pleased with them) reported Allah's Messenger (ﷺ) having forbidden the renting of land", "french": "", "indonesian": "", "russian": "", "urdu": "حماد بن زید نے ہمیں مطروراق سے حدیث بیان کی ،  انہوں نے عطاء سے اور انہوں نے حضرت جابر بن عبداللہ رض", "grades": "", "reference": "Book 21, Hadith 115", "international_number": "3916", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3917", "arabic": "وحَدَّثَنَا  عَبْدُ بْنُ حُمَيْدٍ ، حَدَّثَنَا  مُحَمَّدُ بْنُ الْفَضْلِ لَقَبُهُ عَارِمٌ وَهُوَ أَب", "bengali": "", "english": "Jabir b. Abdullah (Allah be pleased with them) reported Allah's Messenger (ﷺ) as saying:He who has land should cultivate it himself, but if he does not cultivate it himself, then he should let his brother cultivate it", "french": "", "indonesian": "", "russian": "", "urdu": "مہدی بن میمون نے ہمیں حدیث بیان کی ،  کہا :  ہمیں مطروراق نے عطاء سے حدیث بیان کی ،  انہوں نے حضرت ج", "grades": "", "reference": "Book 21, Hadith 116", "international_number": "3917", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3918", "arabic": "حَدَّثَنَا  الْحَكَمُ بْنُ مُوسَى ، حَدَّثَنَا  هِقْلٌ يَعْنِي ابْنَ زِيَادٍ ، عَنْ  الْأَوْزَاعِيِّ", "bengali": "", "english": "Jabir b. Abdullah (Allah be pleased with them) reported some of the Companions of Allah's Messenger (ﷺ) had surplus of land. Thereupon Allah's Messenger (ﷺ) said:He, who has surplus land (in his possession) should cultivate it, or he should lend it to his brother for benefit, but if he refuses to accept it, he should retain it", "french": "", "indonesian": "", "russian": "", "urdu": "اوزاعی نے عطاء سے اور انہوں نے حضرت جابر بن عبداللہ رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  رسول", "grades": "", "reference": "Book 21, Hadith 117", "international_number": "3918", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3919", "arabic": "وحَدَّثَنِي  مُحَمَّدُ بْنُ حَاتِمٍ ، حَدَّثَنَا  مُعَلَّى بْنُ مَنْصُورٍ الرَّازِيُّ ، حَدَّثَنَا", "bengali": "", "english": "Jabir b. Abdullah (Allah be pleased with them) reported Allah's Messenger (ﷺ) having forbidden taking of rent or share of land", "french": "", "indonesian": "", "russian": "", "urdu": "بکیر بن اخنس نے عطاء سے اور انہوں نے حضرت جابر بن عبداللہ رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :", "grades": "", "reference": "Book 21, Hadith 118", "international_number": "3919", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3920", "arabic": "حَدَّثَنَا  ابْنُ نُمَيْرٍ ، حَدَّثَنَا  أَبِي ، حَدَّثَنَا  عَبْدُ الْمَلِكِ ، عَنْ  عَطَاءٍ ، عَنْ", "bengali": "", "english": "Jabir (Allah be pleased with him) reported Allah's Messenger (ﷺ) as saying:He who has land should cultivate it, but if he does not find it possible to cultivate it, or finds himself helpless to do so, he should lend it to his Muslim brother, but he should not accept rent from him", "french": "", "indonesian": "", "russian": "", "urdu": "عبدالملک نے ہمیں عطاء سے حدیث بیان کی اور انہوں نے حضرت جابر رضی اللہ عنہ سے روایت کی ،  انہوں نے کہ", "grades": "", "reference": "Book 21, Hadith 119", "international_number": "3920", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3921", "arabic": "وحَدَّثَنَا  شَيْبَانُ بْنُ فَرُّوخَ ، حَدَّثَنَا  هَمَّامٌ ، قَالَ: سَأَلَ سُلَيْمَانُ بْنُ مُوسَى", "bengali": "", "english": "Sulaiman b. Musa asked Ata':Did Jabir b. 'Abdullah (Allah be pleased with them) reported Allah's Apostle (ﷺ) as saying:\" He who has land should cultivate it himself, or let his brother cultivate it, and should not give on rent\"? He said: Yes", "french": "", "indonesian": "", "russian": "", "urdu": "ہمام نے حدیث بیان کی ،  کہا :  سلیمان بن موسیٰ نے عطاء سے سوال کیا اور کہا :  کیا آپ کو حضرت جابر بن", "grades": "", "reference": "Book 21, Hadith 120", "international_number": "3921", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3922", "arabic": "حَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، حَدَّثَنَا  سُفْيَانُ ، عَنْ  عَمْرٍو ، عَنْ  جَابِرٍ", "bengali": "", "english": "Jabir (Allah be pleased with him) reported Allah's Apostle (ﷺ) having forbidden Mukhabara", "french": "", "indonesian": "", "russian": "", "urdu": "عمرو  ( بن دینار )  نے حضرت جابر رضی اللہ عنہ سے روایت کی کہ نبی صلی اللہ علیہ وسلم نے مخابرہ  ( غلط", "grades": "", "reference": "Book 21, Hadith 121", "international_number": "3922", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3923", "arabic": "وحَدَّثَنِي  حَجَّاجُ بْنُ الشَّاعِرِ ، حَدَّثَنَا  عُبَيْدُ اللَّهِ بْنُ عَبْدِ الْمَجِيدِ ، حَدَّث", "bengali": "", "english": "Jabir b. Abdullah (Allah be pleased with them) heard Allah's Messenger (ﷺ) say:He who has surplus of land should either cultivate it himself, or let his brother cultivate it, an should not sell it. I (the narrator) said to Sa'id: What does his statement\" do not sell it\" mean? Does it imply\" rent\"? He said: Yes", "french": "", "indonesian": "", "russian": "", "urdu": "سعید بن میناء نے ہمیں حدیث بیان کی ،  انہوں نے کہا :  میں نے حضرت جابر بن عبداللہ رضی اللہ عنہ سے سن", "grades": "", "reference": "Book 21, Hadith 122", "international_number": "3923", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3924", "arabic": "حَدَّثَنَا  أَحْمَدُ بْنُ يُونُسَ ، حَدَّثَنَا  زُهَيْرٌ ، حَدَّثَنَا  أَبُو الزُّبَيْرِ ، عَنْ  جَا", "bengali": "", "english": "Jabir b. 'Abdullah reported:We used to cultivate land on rent during the lifetime of Allah's Apostle (ﷺ) and we got a share out of the grain left in the ears after threshing them and something unspecified. Allah's Messenger (ﷺ) said: He who has land should cultivate it or let his brother till it, otherwise he should leave it", "french": "", "indonesian": "", "russian": "", "urdu": "زہیر نے ہمیں حدیث بیان کی ،  کہا :  ابوزبیر نے ہمیں حضرت جابر رضی اللہ عنہ سے حدیث بیان کی ،  انہوں", "grades": "", "reference": "Book 21, Hadith 123", "international_number": "3924", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3925", "arabic": "حَدَّثَنِي  أَبُو الطَّاهِرِ ،  وَأَحْمَدُ بْنُ عِيسَى ، جميعا عَنْ  ابْنِ وَهْبٍ ، قَالَ ابْنُ عِيس", "bengali": "", "english": "Jabir b. Abdullah (Allah be pleased with them) reported:We used to get land (on rent) during the lifetime of Allah's Messeuge, (ﷺ) with a share of one-third or one-fourth (of the produce from the land irrigated) with the help of canals. Thereupon Allah's Messenger (ﷺ) stood up (to address) and said: HRe who has land should cultivate it, and if he does not cultivate it, he should lend it to his brother, and if he does not lend it to his brother, he should then retain it", "french": "", "indonesian": "", "russian": "", "urdu": "ہشام بن سعد نے مجھے حدیث بیان کی کہ انہیں ابوزبیر مکی نے حدیث بیان کی ،  انہوں نے کہا :  میں نے حضرت", "grades": "", "reference": "Book 21, Hadith 124", "international_number": "3925", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3926", "arabic": "حَدَّثَنَا  مُحَمَّدُ بْنُ الْمُثَنَّى ، حَدَّثَنَا  يَحْيَى بْنُ حَمَّادٍ ، حَدَّثَنَا  أَبُو عَوَا", "bengali": "", "english": "Jabir (Allah he pleased with him) reported:I heard Allah's Apostle (ﷺ) as saying: He who has (surplus) land should donate it (to others), or lend it", "french": "", "indonesian": "", "russian": "", "urdu": "ابو عوانہ نے ہمیں سلیمان  ( اعمش )  سے حدیث بیان کی ،  کہا :  ہمیں ابوسفیان  ( طلحہ بن نافع )  نے حض", "grades": "", "reference": "Book 21, Hadith 125", "international_number": "3926", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3927", "arabic": "وحَدَّثَنِيهِ  حَجَّاجُ بْنُ الشَّاعِرِ ، حَدَّثَنَا  أَبُو الْجَوَّابِ ، حَدَّثَنَا  عَمَّارُ بْنُ", "bengali": "", "english": "This hadith has been narrated on the authority of A'mash with the same chain of transmitters, but with a slight change of words", "french": "", "indonesian": "", "russian": "", "urdu": "عمار بن رُزَیق نے اعمش سے اسی سند کے ساتھ یہی حدیث بیان کی ،  البتہ انہوں نے کہا :   \" وہ اسے کاشت ک", "grades": "", "reference": "Book 21, Hadith 126", "international_number": "3927", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3928", "arabic": "وحَدَّثَنِي  هَارُونُ بْنُ سَعِيدٍ الْأَيْلِيُّ ، حَدَّثَنَا  ابْنُ وَهْبٍ ، أَخْبَرَنِي  عَمْرٌو وَ", "bengali": "", "english": "Jabir b. `Abdullah (Allah be pleased with them) reportedthat Allah's Messenger (ﷺ) had forbidden renting of land. Bukair (one of the narrators) said:Nafi` reported to me that he heard Ibn `Umar (Allah be pleased with them) saying: We usedto give land on rent; we then abandoned this practice when we heard the hadith of Rafi` b. Khadij", "french": "", "indonesian": "", "russian": "", "urdu": "بکیر نے حدیث بیان کی کہ انہیں عبداللہ بن ابی سلمہ نے نعمان بن ابی عیاش سے حدیث بیان کی اور انہوں نے", "grades": "", "reference": "Book 21, Hadith 127", "international_number": "3928", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3929", "arabic": "وحَدَّثَنَاه  يَحْيَى بْنُ يَحْيَى ، أَخْبَرَنَا  أَبُو خَيْثَمَةَ ، عَنْ  أَبِي الزُّبَيْرِ ، عَنْ", "bengali": "", "english": "Jabir (Allah be pleased with him) reported Allah's Messenger (ﷺ) forbidding the selling (renting of) uncultivated land for two years or three", "french": "", "indonesian": "", "russian": "", "urdu": "ابوزبیر نے حضرت جابر رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  رسول اللہ صلی اللہ علیہ وسلم نے خال", "grades": "", "reference": "Book 21, Hadith 128", "international_number": "3929", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3930", "arabic": "وحَدَّثَنَا  سَعِيدُ بْنُ مَنْصُورٍ ،  وَأَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ،  وَعَمْرٌو النَّاقِدُ ،", "bengali": "", "english": "Jabir (Allah be pleased with him) reported Allah's Apostle (ﷺ) forbidding selling of (produce) in advance for two years, and in the narmtion of Ibu Abd Shaiba (the words are):\" Selling of the fruits (on the tree) in advance for two years", "french": "", "indonesian": "", "russian": "", "urdu": "سعید بن منصور ،  ابوبکر بن ابی شیبہ ،  عمرو ناقد اور زہیر بن حرب نے کہا :  ہمیں سفیان بن عیینہ نے حم", "grades": "", "reference": "Book 21, Hadith 129", "international_number": "3930", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3931", "arabic": "حَدَّثَنَا  حَسَنُ بْنُ عَلِيٍّ الْحُلْوَانِيُّ ، حَدَّثَنَا  أَبُو تَوْبَةَ ، حَدَّثَنَا  مُعَاوِيَ", "bengali": "", "english": "Abu Huraira (Allah be pleased with him) reported Allah's Messenger (ﷺ) as saying:He who has land should cultivate it or lend it to his brother, but if he refuses, he should retain his land", "french": "", "indonesian": "", "russian": "", "urdu": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ،  انہوں نے کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :", "grades": "", "reference": "Book 21, Hadith 130", "international_number": "3931", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3932", "arabic": "وحَدَّثَنَا  الْحَسَنُ الْحُلْوَانِيُّ ، حَدَّثَنَا  أَبُو تَوْبَةَ ، حَدَّثَنَا  مُعَاوِيَةُ ، عَنْ", "bengali": "", "english": "Jabir b. Abdullah (Allah be pleased with them) reported:I heard Allah's Messenger (ﷺ) forbidding Muzabana, and Huqul. Jabir b. Abdullah (Allah be pleased with them) said: Muzabana means the selling of fruits for dry dates and Huqul is the renting of land", "french": "", "indonesian": "", "russian": "", "urdu": "حضرت جابر بن عبداللہ رضی اللہ عنہ نے خبر دی کہ انہوں نے رسول اللہ صلی اللہ علیہ وسلم سے سنا ،  آپ مز", "grades": "", "reference": "Book 21, Hadith 131", "international_number": "3932", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3933", "arabic": "حَدَّثَنَا  قُتَيْبَةُ بْنُ سَعِيدٍ ، حَدَّثَنَا  يَعْقُوبُ يَعْنِي ابْنَ عَبْدِ الرَّحْمَنِ الْقَار", "bengali": "", "english": "Abu Huraira (Allah be pleased with him) reported Allah's Messenger (ﷺ) forbidding Muhaqala and Muzabana", "french": "", "indonesian": "", "russian": "", "urdu": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ،  انہوں نے کہا :  رسول اللہ صلی اللہ علیہ وسلم نے محاقلہ اور", "grades": "", "reference": "Book 21, Hadith 132", "international_number": "3933", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3934", "arabic": "وحَدَّثَنِي  أَبُو الطَّاهِرِ ، أَخْبَرَنَا  ابْنُ وَهْبٍ ، أَخْبَرَنِي  مَالِكُ بْنُ أَنَسٍ ، عَنْ", "bengali": "", "english": "Abu Sa'id al-Khudri (Allah be pleased with him) reported Allah's Messenger (ﷺ) having forbidden Mazabana and Muhaqala. Muzibana means the buying of fruits on the trees and Muhaqala is the renting of land", "french": "", "indonesian": "", "russian": "", "urdu": "حضرت ابوسعید خدری رضی اللہ عنہ کہتے ہیں :  رسول اللہ صلی اللہ علیہ وسلم نے مزابنہ اور محاقلہ سے منع", "grades": "", "reference": "Book 21, Hadith 133", "international_number": "3934", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3935", "arabic": "حَدَّثَنَا  يَحْيَى بْنُ يَحْيَى ،  وَأَبُو الرَّبِيعِ الْعَتَكِيُّ ، قَالَ أَبُو الرَّبِيعِ: حدثنا،", "bengali": "", "english": "Zaid b. Amr reported:I heard Ibn Umar (Allah be pleased with them) say: We did not see any harm in renting of the land, but as the first year was over Rafi' alleged Allah's Apostle (ﷺ) having forbidden that", "french": "", "indonesian": "", "russian": "", "urdu": "حماد بن زید نے ہمیں عمرو  ( بن دینار )  سے خبر دی ،  انہوں نے کہا :  میں نے حضرت ابن عمر رضی اللہ عن", "grades": "", "reference": "Book 21, Hadith 134", "international_number": "3935", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3936", "arabic": "وحَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، حَدَّثَنَا  سُفْيَانُ . ح وحَدَّثَنِي  عَلِيُّ بْنُ", "bengali": "", "english": "This hadith has been narrated on the authority of Amr b. Dinar with the same chain of transmitters but (in) the hadith transmitted on the authority of 'Uyainah (the words are):\" We abandoned it (renting) on account of that", "french": "", "indonesian": "", "russian": "", "urdu": "سفیان  ( بن عیینہ )  ،  ایوب اور سفیان  ( ثوری )  سب نے عمرو بن دینار سے اسی سند کے ساتھ اسی کے مانن", "grades": "", "reference": "Book 21, Hadith 135", "international_number": "3936", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3937", "arabic": "وحَدَّثَنِي وحَدَّثَنِي  عَلِيُّ بْنُ حُجْرٍ ، حَدَّثَنَا  إِسْمَاعِيلُ ، عَنْ  أَيُّوبَ ، عَنْ  أَب", "bengali": "", "english": "Ibn 'Umar (Allah be pleased with them) reported:Rafi forbade us from benefitting from our land (in the form of rent)", "french": "", "indonesian": "", "russian": "", "urdu": "مجاہد سے روایت ہے ،  انہوں نے کہا :  حضرت ابن عمر رضی اللہ عنہ نے کہا :  رافع رضی اللہ عنہ نے ہماری", "grades": "", "reference": "Book 21, Hadith 136", "international_number": "3937", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3938", "arabic": "وحَدَّثَنَا  يَحْيَى بْنُ يَحْيَى ، أَخْبَرَنَا  يَزِيدُ بْنُ زُرَيْعٍ ، عَنْ  أَيُّوبَ ، عَنْ  نَاف", "bengali": "", "english": "Nafi reported that Ibn Umar (Allah be pleased with them) rented his land during the lifetime of Allah's Messenger (ﷺ) and during the caliphate of Abu Bakr and that of Umar and that of Uthman (Allah be pleased with them) and during the early period of Muawiya's caliphate until at the end of Muawiya's reign, it reached him (Ibn 'Umar) that Rafi b. Khadij (Allah be pleased with him) narratted (a hadith) in which (there was a decree) of prohibition by Allah's Apostle (ﷺ). He (Ibn 'Umar) went to him (Rafi b. Khadij) and I was with him and he asked him, whereupon he said:Allah's Messenger (ﷺ) used to forbid the renting of land. So Ibn Umar (Allah be pleased with them) abandoned it, and subsequently whenever he was asked about it, he said: Rafi b. Khadij (Allah be pleased with him) alleged that Allah's Messenger (ﷺ) forbade it", "french": "", "indonesian": "", "russian": "", "urdu": "یزید بن زریع نے ہمیں ایوب سے خبر دی اور انہوں نے نافع سے روایت کی کہ رسول اللہ صلی اللہ علیہ وسلم کے", "grades": "", "reference": "Book 21, Hadith 137", "international_number": "3938", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3939", "arabic": "وَحَدَّثَنَا  أَبُو الرَّبِيعِ ،  وَأَبُو كَامِلٍ ، قَالَا: حَدَّثَنَا  حَمَّادٌ . ح وحَدَّثَنِي  عَ", "bengali": "", "english": "This hadith has been narrated on the authority of Ayyub and he made an addition in the hadith narrated by Ibn Ulayya in which he said:Ibn Umar abandoned it afterwards and he did not rent it (the land)", "french": "", "indonesian": "", "russian": "", "urdu": "حماد بن زید اور اسماعیل  ( ابن علیہ )  دونوں نے ایوب سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی او", "grades": "", "reference": "Book 21, Hadith 138", "international_number": "3939", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3940", "arabic": "وحَدَّثَنَا  ابْنُ نُمَيْرٍ ، حَدَّثَنَا  أَبِي ، حَدَّثَنَا  عُبَيْدُ اللَّهِ ، عَنْ  نَافِعٍ ، قَا", "bengali": "", "english": "Nafi reported:I went to Rafi b. Khadij in the company of Ibn 'Umar (All be pleased with them) until he (Ibn 'Umar) came to him at Balat (a place near Prophet's Mosque at Medina) and he (Rafi b. Khadij) informed him that Allah's Messenger (ﷺ) had forbidden the renting of land", "french": "", "indonesian": "", "russian": "", "urdu": "عبیداللہ نے ہمیں نافع سے حدیث بیان کی ،  انہوں نے کہا :  میں حضرت ابن عمر رضی اللہ عنہ کے ساتھ حضرت", "grades": "", "reference": "Book 21, Hadith 139", "international_number": "3940", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3941", "arabic": "وحَدَّثَنِي  ابْنُ أَبِي خَلَفٍ ،  وَحَجَّاجُ بْنُ الشَّاعِرِ ، قَالَا: حَدَّثَنَا  زَكَرِيَّاءُ بْن", "bengali": "", "english": "Nafi, reported from Ibn Umar (Allah be pleated with them) that he came to Rafi and he narrated this hadith from Allah's Apostle (ﷺ)", "french": "", "indonesian": "", "russian": "", "urdu": "حکم نے نافع سے اور انہوں نے حضرت ابن عمر رضی اللہ عنہ سے روایت کی کہ وہ حضرت رافع رضی اللہ عنہ کے پا", "grades": "", "reference": "Book 21, Hadith 140", "international_number": "3941", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3942", "arabic": "حَدَّثَنَا  مُحَمَّدُ بْنُ الْمُثَنَّى ، حَدَّثَنَا  حُسَيْنٌ يَعْنِي ابْنَ حَسَنِ بْنِ يَسَارٍ ، حَ", "bengali": "", "english": "Nafi, reported that Ibn Umar (Allah be pleased with them) used to rent the land, and that he was conveyed the hadith transmitted on the authority of Rafi b. Khadij. He (the narrator) said:He then went to him along with me. He (Rafi) narrated from some of his uncles in which it was mentioned that Allah's Apostle (ﷺ) forbade the renting of land. Ibn 'Umar (Allah be pleased with them) then abandoned this practice of renting", "french": "", "indonesian": "", "russian": "", "urdu": "حسین بن حسن بن یسار نے ہمیں حدیث بیان کی ،  کہا :  ہمیں ابن عون نے نافع سے حدیث بیان کی کہ حضرت ابن", "grades": "", "reference": "Book 21, Hadith 141", "international_number": "3942", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3943", "arabic": "وحَدَّثَنِيهِ  مُحَمَّدُ بْنُ حَاتِمٍ ، حَدَّثَنَا  يَزِيدُ بْنُ هَارُونَ ، حَدَّثَنَا  ابْنُ عَوْنٍ", "bengali": "", "english": "This hadith has been narrated through another chain of transmitters", "french": "", "indonesian": "", "russian": "", "urdu": "یزید بن ہارون نے کہا :  ہمیں ابن عون نے اسی سند کے ساتھ حدیث بیان کی اور کہا :  انہوں نے اپنے بعض چچ", "grades": "", "reference": "Book 21, Hadith 142", "international_number": "3943", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3944", "arabic": "وَحَدَّثَنِي  عَبْدُ الْمَلِكِ بْنُ شُعَيْبِ بْنِ اللَّيْثِ بْنِ سَعْدٍ ، حَدَّثَنِي  أَبِي ، عَنْ", "bengali": "", "english": "Salim b. Abdullah reported that AbduUah b. Umar (Allah be pleased with them) used to give land on rent until (this news) reached him that Rafi b. Khadij Ansari used to forbid the renting of land. Abdullah met him and said:Ibn Khadij, what is this that you narrate from Allah's Messenger (ﷺ) pertaining to renting of land? Rafi b. Khadij said to Abdullah: I heard it from two uncles of mine and they had participated in the Battle of Badr who narrated to the members of the family that Allah's Messenger (ﷺ) forbade the renting of land. Abdullah said: I knew it that the land was rented during the lifetime of Allah's Messenger (ﷺ). Abdullah then apprehended that Allah's Messenger (ﷺ) might have said something new in this connection (in regard to prohibition of renting) which I failed to know. So he abandoned the renting of land", "french": "", "indonesian": "", "russian": "", "urdu": "سالم بن عبداللہ نے خبر دی کہ حضرت عبداللہ بن عمر رضی اللہ عنہ اپنی زمینیں کرائے پر دیتے تھے حتی کہ ا", "grades": "", "reference": "Book 21, Hadith 143", "international_number": "3944", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3945", "arabic": "وحَدَّثَنِي  عَلِيُّ بْنُ حُجْرٍ السَّعْدِيُّ ،  وَيَعْقُوبُ بْنُ إِبْرَاهِيمَ ، قَالَا: حَدَّثَنَا", "bengali": "", "english": "Rafi b. Khadij (Allah be pleased with him) reported:We used to give on rent land during the lifetime of Allah's Messenger (ﷺ). We rented it on the share of one-third or one-fourth of the (produce) along with a definite quantity of corn. One day a person from among my uncles came to us and said: Allah's Messenger (ﷺ) forbade us this act which was a source of benefit to us, but the obedience to Allah and to His Messenger (ﷺ) is more beneficial to us. He forbade us that we should rent land with one-third or one-fourth of (the produce) and the corn of a measure, and he commanded the owner of land that he should cultivate it or let it be cultivated by other (persons) but he showed disapproval of renting it or anything besides it", "french": "", "indonesian": "", "russian": "", "urdu": "اسماعیل بن علیہ نے ہمیں ایوب سے حدیث بیان کی ،  انہوں نے یعلیٰ بن حکیم سے ،  انہوں نے سلیمان بن یسار", "grades": "", "reference": "Book 21, Hadith 144", "international_number": "3945", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3946", "arabic": "وحَدَّثَنَاه  يَحْيَى بْنُ يَحْيَى ، أَخْبَرَنَا  حَمَّادُ بْنُ زَيْدٍ ، عَنْ  أَيُّوبَ ، قَالَ: كَت", "bengali": "", "english": "Rafi b. Khadij (Allah be pleased with him) reported:We used to give land on rent, and we rented it on one-third or one-fourth share. The rest of the hadith is the same", "french": "", "indonesian": "", "russian": "", "urdu": "حماد بن زید نے ہمیں ایوب سے خبر دی ،  انہوں نے کہا :  یعلیٰ بن حکیم نے میری طرف لکھا ،  انہوں نے کہا", "grades": "", "reference": "Book 21, Hadith 145", "international_number": "3946", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3947", "arabic": "وحَدَّثَنَا  يَحْيَى بْنُ حَبِيبٍ ، حَدَّثَنَا  خَالِدُ بْنُ الْحَارِثِ . ح وحَدَّثَنَا  عَمْرُو بْن", "bengali": "", "english": "Another chain narrated the same as the above hadith", "french": "", "indonesian": "", "russian": "", "urdu": "ابن ابی عروبہ نے یعلیٰ بن حکیم سے اسی سند کے ساتھ اسی کے مانند روایت بیان کی", "grades": "", "reference": "Book 21, Hadith 146", "international_number": "3947", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3948", "arabic": "وحَدَّثَنِيهِ  أَبُو الطَّاهِرِ ، أَخْبَرَنَا  ابْنُ وَهْبٍ ، أَخْبَرَنِي  جَرِيرُ بْنُ حَازِمٍ ، عَ", "bengali": "", "english": "This hadith has been narrated on the authority of Rafi' b. Khadij with the same chain of transmitters, but in it no mention is made of some of his uncles", "french": "", "indonesian": "", "russian": "", "urdu": "جریر بن حازم نے یعلیٰ بن حکیم کی اسی سند کے ساتھ روایت کی ،  انہوں نے  ( سلیمان کے واسطے سے )  رافع", "grades": "", "reference": "Book 21, Hadith 147", "international_number": "3948", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3949", "arabic": "حَدَّثَنِي  إِسْحَاقُ بْنُ مَنْصُورٍ ، أَخْبَرَنَا  أَبُو مُسْهِرٍ ، حَدَّثَنِي  يَحْيَى بْنُ حَمْزَ", "bengali": "", "english": "Rafi (Allah be pleased with him) reported that Zuhair b. Rafi (who was his uncle) came to me and said:Allah's Messenger (ﷺ) forbade a practice which was useful for us. I said: What is this? (I believe) that whatrver Allah's Messenger (ﷺ) says is absolutely true. He (Zuhair) said that he (the Holy Prophet) asked me: What do you do with your cultivable lands? I said: Allah's Messenger, we rent those irrigated by canals for dry dates or barley. He said: Don't do that. Cultivate them or let them be cultivated (by others) or retain them yourself", "french": "", "indonesian": "", "russian": "", "urdu": "ابوعمرو اوزاعی نے مجھے رافع بن خدیج رضی اللہ عنہ کے آزاد کردہ غلام ابونجاشی سے حدیث بیان کی اور انہو", "grades": "", "reference": "Book 21, Hadith 148", "international_number": "3949", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3950", "arabic": "حَدَّثَنَا  مُحَمَّدُ بْنُ حَاتِمٍ ، حَدَّثَنَا  عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ ، عَنْ  عِكْرِمَة", "bengali": "", "english": "This hadith has been transmitted on the authority of Rafi from the Prophet (ﷺ) about this, but he did not make mention of his uncle Zuhair", "french": "", "indonesian": "", "russian": "", "urdu": "عکرمہ بن عمار نے ابونجاشی سے ،  انہوں نے حضرت رافع رضی اللہ عنہ سے اور انہوں نے نبی صلی اللہ علیہ وس", "grades": "", "reference": "Book 21, Hadith 149", "international_number": "3950", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3951", "arabic": "حَدَّثَنَا  يَحْيَى بْنُ يَحْيَى ، قَالَ: قَرَأْتُ عَلَى  مَالِكٍ ، عَنْ  رَبِيعَةَ بْنِ أَبِي عَبْد", "bengali": "", "english": "Hanzala b. Qais reported that he asked Rafi b. Khadij (Allah be pleased with him) about renting of land, whereupon he said:Allah's Messenger (ﷺ) forbade the renting of land. I said: Is it forbidden (even if it is paid) in gold (dinar) and silver (dirham)? Thereupon he said: If it is paid in gold and silver, there is no harm in it", "french": "", "indonesian": "", "russian": "", "urdu": "امام مالک نے ربیعہ بن ابی عبدالرحمٰن سے اور انہوں نے حنظلہ بن قیس سے روایت کی کہ انہوں نے حضرت رافع", "grades": "", "reference": "Book 21, Hadith 150", "international_number": "3951", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3952", "arabic": "حَدَّثَنَا حَدَّثَنَا  إِسْحَاقُ ، أَخْبَرَنَا  عِيسَى بْنُ يُونُسَ ، حَدَّثَنَا  الْأَوْزَاعِيُّ ،", "bengali": "", "english": "Hanzala b. Qais al-Ansri reported:I asked Rafi' b. Khadij about the renting of land for gold and silver, whereupon he said: There is no harm in it for the people let out land situated near canals and at the ends of the streamlets or portion of fields. (But it so happened) that at times this was destroyed and that was saved. whereas (on other occasions) this portion was saved and the other was destroyed and thus no rent was payable to the people (who let out lands) but for this one (which was saved). It was due to this that he (the Holy Prophet) prohibited it. But if there is something definite and reliable (e. g. money). there is no harm in it", "french": "", "indonesian": "", "russian": "", "urdu": "اوزاعی نے ہمیں ربیعہ بن ابی عبدالرحمٰن سے حدیث بیان کی ،  کہا :  مجھے حنظلہ بن قیس انصاری نے حدیث سن", "grades": "", "reference": "Book 21, Hadith 151", "international_number": "3952", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3953", "arabic": "حَدَّثَنَا حَدَّثَنَا  عَمْرٌو النَّاقِدُ ، حَدَّثَنَا  سُفْيَانُ بْنُ عُيَيْنَةَ ، عَنْ  يَحْيَى بْ", "bengali": "", "english": "Hanzala reported that he heard Rafi' b. Khadij (Allah be pleased with him) say:We were the major agriculturists of the Ansar and so we let out land (saying): The produce of this (part of land) would be ours and (the produce) of that would be theirs. But it so happened that at times this (land) gave harvest, but the other one produced nothing. So he (the Holy Prophet) forbade this. But so far as the payment in silver (dirham, a coin) is concerned, he did not forbid", "french": "", "indonesian": "", "russian": "", "urdu": "سفیان بن عیینہ نے ہمیں یحییٰ بن سعید سے حدیث بیان کی ،  انہوں نے حنظلہ زُرَقی سے روایت کی کہ انہوں ن", "grades": "", "reference": "Book 21, Hadith 152", "international_number": "3953", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3954", "arabic": "حَدَّثَنَا  أَبُو الرَّبِيعِ ، حَدَّثَنَا  حَمَّادٌ . ح وحَدَّثَنَا  ابْنُ الْمُثَنَّى ، حَدَّثَنَا", "bengali": "", "english": "This hadith has been narrated on the authority of Yahya b. Sa'id with the same chain of transmitters", "french": "", "indonesian": "", "russian": "", "urdu": "حماد اور یزید بن ہارون نے یحییٰ بن سعید سے اسی سند کے ساتھ اسی کے ہم معنی حدیث بیان کی", "grades": "", "reference": "Book 21, Hadith 153", "international_number": "3954", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3955", "arabic": "حَدَّثَنَا  يَحْيَى بْنُ يَحْيَى ، أَخْبَرَنَا  عَبْدُ الْوَاحِدِ بْنُ زِيَادٍ . ح وَحَدَّثَنَا  أَب", "bengali": "", "english": "Abdullah b. al Sa'ib reported:I asked Abdullah b. Ma'qil about Muzara'a (cultivating land on share basis in the produce). He said: Thabit b. Dahhak informed me that Allah's Messenger (ﷺ) forbade Muzara'a as Ibn Abu Shaiba forbade it with a slight change of words. He (the narrator) said: I asked Ibn Ma'qil but he did not name 'Abdullah", "french": "", "indonesian": "", "russian": "", "urdu": "یحییٰ بن یحییٰ نے کہا :  ہمیں عبدالواحد بن زیاد نے خبر دی ،  نیز ابوبکر بن ابی شیبہ نے کہا :  ہمیں ع", "grades": "", "reference": "Book 21, Hadith 154", "international_number": "3955", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3956", "arabic": "حَدَّثَنَا  إِسْحَاقُ بْنُ مَنْصُورٍ ، أَخْبَرَنَا  يَحْيَى بْنُ حَمَّادٍ ، أَخْبَرَنَا  أَبُو عَوَا", "bengali": "", "english": "Abdullah b. al-Sa'ib reported:We visited 'Abdullah b. Ma'qil and asked him about sharing of crops, whereupon he said: Thabit alleged that Allah's Messenger (ﷺ) forbade Muzara'a and commanded leasing it out on rent (for money) and said: There is no harm in it", "french": "", "indonesian": "", "russian": "", "urdu": "ابوعوانہ نے ہمیں سلیمان شیبانی سے خبر دی ،  انہوں نے عبداللہ بن سائب سے روایت کی ،  انہوں نے کہا :", "grades": "", "reference": "Book 21, Hadith 155", "international_number": "3956", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3957", "arabic": "حَدَّثَنَا  يَحْيَى بْنُ يَحْيَى ، أَخْبَرَنَا  حَمَّادُ بْنُ زَيْدٍ ، عَنْ  عَمْرٍو ، أَنَّ مُجَاهِ", "bengali": "", "english": "Mujahid said to Tiwus:Come along with me to Ibn Rafi b. Khadij in order to listen from him the hadith transmitted on the authority of his father (pertaining to the renting of land) from Allah's Apostle (ﷺ). He (Tawus) scolded him and said: By Allah, it I were to know that Allah's Messenger (ﷺ) had forbidden it, I would have never done it. But it has been narrated to me by one who has better knowledge of it amongst them (and he meant Ibn 'Abbas) that Allah's Messenger (ﷺ) said: It is better if a person lends, his land to his brother (for cultivation) than that he gets recognised rent on it", "french": "", "indonesian": "", "russian": "", "urdu": "حماد بن زید نے ہمیں عمرو  ( بن دینار )  سے خبر دی کہ مجاہد نے طاوس سے کہا :  ہمارے ساتھ حضرت رافع بن", "grades": "", "reference": "Book 21, Hadith 156", "international_number": "3957", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3958", "arabic": "وحَدَّثَنَا  ابْنُ أَبِي عُمَرَ ، حَدَّثَنَا  سُفْيَانُ ، عَنْ  عَمْرٍو ،  وَابْنُ طَاوُسٍ ، عَنْ  ط", "bengali": "", "english": "Tawus reported that he let out his land on rent, whereupon Amr said:I said to him: Abu Abd al-Rahrman, I wish if you abandon this renting of land, for they alleged that Allah's Apostle (ﷺ) forbade Mukhabara. He siad: Amr, one who has informed me has the best knowledge of it among them (he meant Ibn Abbas). (He said) that Allah's Apostle (ﷺ) did not prohibit it altogether, but said: Lending of land by one among you to his brother is better for him than getting a specified amount of produce from it", "french": "", "indonesian": "", "russian": "", "urdu": "سفیان نے ہمیں عمرو اور ابن طاوس سے حدیث بیان کی اور انہوں نے طاوس سے روایت کی کہ وہ  ( نقدی کے عوض )", "grades": "", "reference": "Book 21, Hadith 157", "international_number": "3958", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3959", "arabic": "حَدَّثَنَا  ابْنُ أَبِي عُمَرَ ، حَدَّثَنَا  الثَّقَفِيُّ ، عَنْ  أَيُّوبَ . ح وحَدَّثَنَا  أَبُو بَ", "bengali": "", "english": "A hadith like this has been transmitted on the authority of Ibn Abbas (Allah be pleased with them)", "french": "", "indonesian": "", "russian": "", "urdu": "ایوب ،  سفیان ،  ابن جریج اور شعبہ سب نے عمرو بن دینار سے ،  انہوں نے طاوس سے ،  انہوں نے حضرت ابن ع", "grades": "", "reference": "Book 21, Hadith 158", "international_number": "3959", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3960", "arabic": "وحَدَّثَنِي  عَبْدُ بْنُ حُمَيْدٍ ،  وَمُحَمَّدُ بْنُ رَافِعٍ ، قَالَ عبدَ: أَخْبَرَنَا، وَقَالَ ابْ", "bengali": "", "english": "Ibn Abbas (Allah be pleased with them) reported Allah's Apostle (ﷺ) as saying:If one among you lets out land to his brother, that is better for him than if he receives such and such (the definite thing). Ibn 'Abbis (Allah be pleased with them) said: It is Haql, and in the parlance of the Ansr it is Muhaqala", "french": "", "indonesian": "", "russian": "", "urdu": "معمر نے ابن طاوس سے ،  انہوں نے اپنے والد سے اور انہوں نے حضرت ابن عباس رضی اللہ عنہ سے روایت کی کہ", "grades": "", "reference": "Book 21, Hadith 159", "international_number": "3960", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
{"hadithnumber": "3961", "arabic": "وحَدَّثَنَا  عَبْدُ اللَّهِ بْنُ عَبْدِ الرَّحْمَنِ الدَّارِمِيُّ ، أَخْبَرَنَا  عَبْدُ اللَّهِ بْنُ", "bengali": "", "english": "Ibn Abbas (Allah be pleased with them) reported Allah's Apostle (ﷺ) as saying:He who has land, it is better for him that he should let it out to his brother", "french": "", "indonesian": "", "russian": "", "urdu": "عبدالملک بن زید نے طاوس سے ،  انہوں نے حضرت ابن عباس رضی اللہ عنہ سے اور انہوں نے نبی صلی اللہ علیہ", "grades": "", "reference": "Book 21, Hadith 160", "international_number": "3961", "narrator_chain": "", "chapter_intro": "The Book of Transactions"}
