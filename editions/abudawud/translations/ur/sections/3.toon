{"hadithnumber": "1161", "text": "عبداللہ بن زید بن عاصم رضی اللہ عنہ روایت کرتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم لوگوں کے ساتھ نم"}
{"hadithnumber": "1162", "text": "ابن شہاب زہری کہتے ہیں کہ  مجھے عباد بن تمیم مازنی نے خبر دی ہے کہ انہوں نے اپنے چچا  ( عبداللہ بن ز"}
{"hadithnumber": "1163", "text": "اس طریق سے بھی محمد بن مسلم (ابن شہاب زہری) سے سابقہ سند سے یہی حدیث مروی ہے  اس میں راوی نے نماز کا"}
{"hadithnumber": "1164", "text": "عبداللہ بن زید رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے نماز استسقا پڑھی، آپ صلی ال"}
{"hadithnumber": "1165", "text": "ہشام بن اسحاق بن عبداللہ بن کنانہ کہتے ہیں کہ  میرے والد نے مجھے خبر دی ہے کہ مجھے ولید بن عتبہ نے"}
{"hadithnumber": "1166", "text": "عبداللہ بن زید رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم عید گاہ کی طرف بارش طلب کرن"}
{"hadithnumber": "1167", "text": "عبداللہ بن زید مازنی رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم عید گاہ کی طرف نکلے،"}
{"hadithnumber": "1168", "text": "عمیر مولیٰ آبی اللحم رضی اللہ عنہ سے روایت ہے کہ  انہوں نے نبی اکرم صلی اللہ علیہ وسلم کو زوراء کے ق"}
{"hadithnumber": "1169", "text": "انس رضی اللہ عنہ وہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم استسقا کے علاوہ کسی دعا میں  ( اتنا )"}
{"hadithnumber": "1170", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم استسقا میں اس طرح دعا کرتے تھے، یعنی آپ صل"}
{"hadithnumber": "1171", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم استسقا میں اس طرح دعا کرتے تھے، یعنی آپ صل"}
{"hadithnumber": "1172", "text": "محمد بن ابراہیم (تیمی) کہتے ہیں  مجھے اس شخص نے خبر دی ہے جس نے نبی اکرم صلی اللہ علیہ وسلم کو دیکھا"}
{"hadithnumber": "1173", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  لوگوں نے رسول اللہ صلی اللہ علیہ وسلم سے بارش نہ ہونے ک"}
{"hadithnumber": "1174", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے زمانے میں اہل مدینہ قحط میں مبتلا ہوئے"}
{"hadithnumber": "1175", "text": "شریک بن عبداللہ بن ابی نمر سے روایت ہے کہ  انہوں نے انس رضی اللہ عنہ کو کہتے ہوئے سنا، پھر راوی نے ع"}
{"hadithnumber": "1176", "text": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم جب بارش کے لیے دعا مانگتے ت"}
{"hadithnumber": "1177", "text": "عبید بن عمیر سے روایت ہے کہ  مجھے اس شخص نے خبر دی ہے جس کو میں سچا جانتا ہوں  ( عطا کہتے ہیں کہ میر"}
{"hadithnumber": "1178", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے زمانے میں سورج گرہن لگا،"}
{"hadithnumber": "1179", "text": "جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے عہد میں سخت گرمی کے دن میں سورج گرہن"}
{"hadithnumber": "1180", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کی زندگی میں سورج گرہن لگا"}
{"hadithnumber": "1181", "text": "عبداللہ بن عباس رضی اللہ عنہما بیان کرتے تھے کہ  رسول اللہ صلی اللہ علیہ وسلم نے سورج گرہن کی نماز پ"}
{"hadithnumber": "1182", "text": "ابی بن کعب رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے زمانہ میں سورج گرہن لگا اور نبی"}
{"hadithnumber": "1183", "text": "عبداللہ بن عباس رضی اللہ عنہما نبی اکرم صلی اللہ علیہ وسلم سے روایت کرتے ہیں کہ  آپ نے سورج گرہن کی"}
{"hadithnumber": "1184", "text": "اسود بن قیس کہتے ہیں کہ ثعلبہ بن عباد عبدی (جو اہل بصرہ میں سے ہیں) نے بیان کیا ہے کہ  وہ ایک دن سمر"}
{"hadithnumber": "1185", "text": "قبیصہ بن مخارق ہلالی رضی اللہ عنہ کہتے ہیں  رسول اللہ صلی اللہ علیہ وسلم کے زمانہ میں سورج گرہن لگا"}
{"hadithnumber": "1186", "text": "ہلال بن عامر سے روایت ہے کہ  قبیصہ ہلالی نے ان سے بیان کیا ہے کہ سورج میں گرہن لگا، پھر انہوں نے موس"}
{"hadithnumber": "1187", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے زمانہ میں سورج گرہن لگا"}
{"hadithnumber": "1188", "text": "ام المؤمنین عائشہ رضی اللہ عنہا فرماتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے لمبی قرآت کی اور اس م"}
{"hadithnumber": "1189", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  سورج گرہن لگا تو رسول اللہ صلی اللہ علیہ وسلم نے گرہن کی"}
{"hadithnumber": "1190", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  سورج گرہن لگا تو رسول اللہ صلی اللہ علیہ وسلم نے ایک شخ"}
{"hadithnumber": "1191", "text": "ام المؤمنین عائشہ رضی اللہ عنہا فرماتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  سورج اور چاند"}
{"hadithnumber": "1192", "text": "اسماء رضی اللہ عنہا کہتی ہیں کہ نبی اکرم  نبی اکرم صلی اللہ علیہ وسلم نماز کسوف میں غلام آزاد کرنے ک"}
{"hadithnumber": "1193", "text": "نعمان بن بشیر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے زمانہ میں سورج گرہن لگا تو آ"}
{"hadithnumber": "1194", "text": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے زمانہ میں سورج گرہن لگا،"}
{"hadithnumber": "1195", "text": "عبدالرحمٰن بن سمرہ رضی اللہ عنہ کہتے ہیں  میں رسول اللہ صلی اللہ علیہ وسلم کی زندگی میں تیر اندازی ک"}
{"hadithnumber": "1196", "text": "نضر کہتے ہیں کہ مجھ سے میرے والد نے بیان کیا کہ  انس بن مالک رضی اللہ عنہ کے زمانہ میں تاریکی چھا گئ"}
{"hadithnumber": "1197", "text": "عکرمہ کہتے ہیں کہ ابن عباس رضی اللہ عنہما سے کہا گیا کہ  نبی اکرم صلی اللہ علیہ وسلم کی فلاں بیوی کا"}
