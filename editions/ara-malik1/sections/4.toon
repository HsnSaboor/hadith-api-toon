metadata:
  section_id: 4
  section_name: Forgetfulness in Prayer
  hadith_first: 222
  hadith_last: 224
  arabic_first: 222
  arabic_last: 224

hadiths[3]{hadithnumber,text,reference_book,reference_hadith}:
222,"حدثني يحيى، عن مالك، عن ابن شهاب، عن ابي سلمة بن عبد الرحمن بن عوف، عن ابي هريرة، ان رسول الله صلى الله عليه وسلم قال "" ان احدكم اذا قام يصلي جاءه الشيطان فلبس عليه حتى لا يدري كم صلى فاذا وجد ذلك احدكم فليسجد سجدتين وهو جالس",4,1
223,"وحدثني عن مالك، انه بلغه ان رسول الله صلى الله عليه وسلم قال "" اني لانسى او انسى لاسن",4,2
224,وحدثني عن مالك، انه بلغه ان رجلا، سال القاسم بن محمد فقال اني اهم في صلاتي فيكثر ذلك على . فقال القاسم بن محمد امض في صلاتك فانه لن يذهب عنك حتى تنصرف وانت تقول ما اتممت صلاتي,4,3
