{"hadithnumber": "1548", "text": "ابوالبختری سعید بن فیروز سے روایت ہے کہ  مسلمانوں کے ایک لشکر نے جس کے امیر سلمان فارسی تھے، فارس کے"}
{"hadithnumber": "1549", "text": "عصام مزنی رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم جب کوئی لشکر یا سریہ بھیجتے تو ان س"}
{"hadithnumber": "1550", "text": "انس رضی الله عنہ سے روایت ہے کہ  جب رسول اللہ صلی اللہ علیہ وسلم خیبر روانہ ہوئے تو وہاں رات کو پہنچ"}
{"hadithnumber": "1551", "text": "ابوطلحہ رضی الله عنہ سے روایت ہے کہ  جب نبی اکرم صلی اللہ علیہ وسلم کسی قوم پر غالب آتے تو ان کے می"}
{"hadithnumber": "1552", "text": "عبداللہ بن عمر رضی الله عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے بنو نضیر کے کھجوروں کے"}
{"hadithnumber": "1553", "text": "ابوامامہ رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”اللہ تعالیٰ نے مجھے ان"}
{"hadithnumber": "1554", "text": "عبداللہ بن عمر رضی الله عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے مال غنیمت کی تقسیم میں"}
{"hadithnumber": "1555", "text": "عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”سب سے بہترین سا"}
{"hadithnumber": "1556", "text": "یزید بن ہرمز سے روایت ہے کہ  نجدہ بن عامر حروری نے ابن عباس رضی الله عنہما کے پاس یہ سوال لکھ کر بھی"}
{"hadithnumber": "1557", "text": "عمیر مولیٰ ابی اللحم رضی الله عنہما کہتے ہیں کہ  میں اپنے مالکان کے ساتھ غزوہ خیبر میں شریک ہوا، انہ"}
{"hadithnumber": "1558", "text": "ام المؤمنین عائشہ رضی الله عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم بدر کے لیے نکلے، جب آپ حرۃ"}
{"hadithnumber": "1559", "text": "ابوموسیٰ اشعری رضی الله عنہ کہتے ہیں کہ  میں اشعری قبیلہ کی ایک جماعت کے ساتھ رسول اللہ صلی اللہ علی"}
{"hadithnumber": "1560", "text": "ابوثعلبہ خشنی رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم سے مجوس کی ہانڈیوں کے بارے میں"}
{"hadithnumber": "1561", "text": "عبادہ بن صامت رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم سریہ کے شروع میں جانے پر چوتھائی"}
{"hadithnumber": "1561", "text": "عبادہ بن صامت رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم سریہ کے شروع میں جانے پر چوتھائی"}
{"hadithnumber": "1562", "text": "ابوقتادہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جو کسی کافر کو قتل کرے ا"}
{"hadithnumber": "1563", "text": "ابوسعید خدری رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے تقسیم سے پہلے مال غنیمت کی خر"}
{"hadithnumber": "1564", "text": "عرباض بن ساریہ رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے  ( حاملہ )  قیدی عورتوں"}
{"hadithnumber": "1565", "text": "ہلب رضی الله عنہ کہتے ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم سے نصاریٰ کے کھانا کے بارے میں سوال"}
{"hadithnumber": "1566", "text": "ابوایوب انصاری رضی الله عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا: ”جس نے م"}
{"hadithnumber": "1567", "text": "علی رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جبرائیل نے میرے پاس آ کر"}
{"hadithnumber": "1568", "text": "عمران بن حصین رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے مشرکین کے ایک قیدی مرد کے"}
{"hadithnumber": "1569", "text": "عبداللہ بن عمر رضی الله عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم کے کسی غزوے میں ایک عورت"}
{"hadithnumber": "1570", "text": "صعب بن جثامہ رضی الله عنہ کہتے ہیں کہ  میں نے عرض کیا: اللہ کے رسول! ہمارے گھوڑوں نے مشرکین کی عورتو"}
{"hadithnumber": "1571", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ہمیں ایک لشکر میں بھیجا اور فرمای"}
{"hadithnumber": "1572", "text": "ثوبان رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جو مر گیا اور تین چیزوں یعن"}
{"hadithnumber": "1573", "text": "ثوبان رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس کے جسم سے روح نکلی اور و"}
{"hadithnumber": "1574", "text": "عمر بن خطاب رضی الله عنہ کہتے ہیں کہ  عرض کیا گیا: اللہ کے رسول! فلاں آدمی شہید ہو گیا، آپ نے فرمای"}
{"hadithnumber": "1575", "text": "انس رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ام سلیم اور ان کے ہمراہ رہنے والی انصار ک"}
{"hadithnumber": "1576", "text": "علی رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم کے لیے فارس کے بادشاہ کسریٰ نے آپ کے لی"}
{"hadithnumber": "1577", "text": "عیاض بن حمار رضی الله عنہ کہتے ہیں کہ  انہوں نے  ( اسلام لانے سے قبل )  نبی اکرم صلی اللہ علیہ وسلم"}
{"hadithnumber": "1578", "text": "ابوبکرہ رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کے پاس ایک خبر آئی، آپ اس سے خوش ہوئے"}
{"hadithnumber": "1579", "text": "ابوہریرہ رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”مسلمان عورت کسی کو پنا"}
{"hadithnumber": "1580", "text": "سلیم بن عامر کہتے ہیں کہ  معاویہ رضی الله عنہ اور اہل روم کے درمیان  ( کچھ مدت تک کے لیے )  عہد و پی"}
{"hadithnumber": "1581", "text": "عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا ہے: ”بی"}
{"hadithnumber": "1582", "text": "جابر رضی الله عنہ کہتے ہیں کہ  غزوہ احزاب میں سعد بن معاذ رضی الله عنہ کو تیر لگا، کفار نے ان کی رگ"}
{"hadithnumber": "1583", "text": "سمرہ بن جندب رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”مشرکین کے مردوں کو ق"}
{"hadithnumber": "1584", "text": "عطیہ قرظی رضی الله عنہ کہتے ہیں کہ  ہمیں قریظہ کے دن نبی اکرم صلی اللہ علیہ وسلم کے سامنے پیش کیا گی"}
{"hadithnumber": "1585", "text": "عبداللہ بن عمرو رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے اپنے خطبہ میں فرمایا: ”ج"}
{"hadithnumber": "1586", "text": "بجالہ بن عبدہ کہتے ہیں کہ  میں مقام مناذر میں جزء بن معاویہ کا منشی تھا، ہمارے پاس عمر رضی الله عنہ"}
{"hadithnumber": "1587", "text": "بجالہ بن عبدہ سے روایت ہے کہ  عمر رضی الله عنہ مجوس سے جزیہ نہیں لیتے تھے یہاں تک کہ عبدالرحمٰن بن ع"}
{"hadithnumber": "1588", "text": "سائب بن یزید رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے بحرین کے مجوسیوں سے، اور عمر"}
{"hadithnumber": "1589", "text": "عقبہ بن عامر رضی الله عنہ کہتے ہیں کہ  میں نے عرض کیا: اللہ کے رسول! ہم ایسے لوگوں کے پاس سے گزرتے ہ"}
{"hadithnumber": "1590", "text": "عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فتح مکہ کے دن فرمایا: ”ف"}
{"hadithnumber": "1591", "text": "جابر بن عبداللہ رضی الله عنہما سے  آیت کریمہ: «لقد رضي الله عن المؤمنين إذ يبايعونك تحت الشجرة» ”ال"}
{"hadithnumber": "1592", "text": "یزید بن ابی عبیداللہ کہتے ہیں کہ  میں نے سلمہ بن الاکوع رضی الله عنہ سے پوچھا: حدیبیہ کے دن آپ لوگوں"}
{"hadithnumber": "1593", "text": "عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  ہم لوگ رسول اللہ صلی اللہ علیہ وسلم سے سمع و طاعت  ( یعنی"}
{"hadithnumber": "1594", "text": "جابر بن عبداللہ رضی الله عنہ کہتے ہیں کہ  ہم نے رسول اللہ صلی اللہ علیہ وسلم سے موت پر بیعت نہیں کی"}
{"hadithnumber": "1595", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”تین آدمیوں سے قیامت کے"}
{"hadithnumber": "1596", "text": "جابر رضی الله عنہ کہتے ہیں کہ  ایک غلام آیا، اس نے رسول اللہ صلی اللہ علیہ وسلم سے ہجرت پر بیعت کی،"}
{"hadithnumber": "1597", "text": "امیمہ بنت رقیقہ رضی الله عنہا کہتی ہیں کہ  میں نے کئی عورتوں کے ساتھ رسول اللہ صلی اللہ علیہ وسلم سے"}
{"hadithnumber": "1598", "text": "براء رضی الله عنہ کہتے ہیں کہ  ہم لوگ کہا کرتے تھے کہ غزوہ بدر کے دن بدری لوگ تعداد میں طالوت کے سات"}
{"hadithnumber": "1599", "text": "عبداللہ بن عباس رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے وفد عبدالقیس سے فرمایا"}
{"hadithnumber": "1600", "text": "رافع بن خدیج رضی الله عنہ کہتے ہیں کہ  ہم لوگ ایک سفر میں رسول اللہ صلی اللہ علیہ وسلم کے ہمراہ تھے،"}
{"hadithnumber": "1601", "text": "انس رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جو لوٹ پاٹ مچائے وہ ہم میں سے"}
{"hadithnumber": "1602", "text": "ابوہریرہ رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”یہود و نصاریٰ کو سلام"}
{"hadithnumber": "1603", "text": "عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”یہود میں سے کوئی"}
{"hadithnumber": "1604", "text": "جریر بن عبداللہ رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے قبیلہ خثعم کی طرف ایک س"}
{"hadithnumber": "1605", "text": "عبدہ نے یہ حدیث بطریق: «إسمعيل بن أبي خالد عن قيس ابن أبي عن النبي صلى الله عليه وسلم»  ( مرسلاً )"}
{"hadithnumber": "1606", "text": "عمر بن خطاب رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اگر میں زندہ رہا ت"}
{"hadithnumber": "1607", "text": "عمر بن خطاب رضی الله عنہ سے روایت ہے کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا: ”میں ج"}
{"hadithnumber": "1608", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  فاطمہ رضی الله عنہا نے ابوبکر رضی الله عنہ کے پاس آ کر کہا: آپ ک"}
{"hadithnumber": "1609", "text": "ابوہریرہ رضی الله عنہ سے روایت ہے کہ  فاطمہ رضی الله عنہا ابوبکر اور عمر رضی الله عنہما کے پاس رسول"}
{"hadithnumber": "1610", "text": "مالک بن اوس بن حدثان کہتے ہیں کہ  میں عمر بن خطاب رضی الله عنہ کے پاس گیا، اسی دوران ان کے پاس عثمان"}
{"hadithnumber": "1611", "text": "حارث بن مالک بن برصاء رضی الله عنہ کہتے ہیں کہ  فتح مکہ کے دن میں نے نبی اکرم صلی اللہ علیہ وسلم کو"}
{"hadithnumber": "1612", "text": "نعمان بن مقرن رضی الله عنہ کہتے ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم کے ساتھ جہاد کیا، جب فجر"}
{"hadithnumber": "1613", "text": "معقل بن یسار رضی الله عنہ سے روایت ہے کہ  بن خطاب نے نعمان بن مقرن رضی الله عنہ کو ہرمز ان کے پاس بھ"}
{"hadithnumber": "1614", "text": "عبداللہ بن مسعود رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”بدفالی شرک ہے“ ۱"}
{"hadithnumber": "1615", "text": "انس رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”ایک کی بیماری دوسرے کو لگ"}
{"hadithnumber": "1616", "text": "انس بن مالک رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کو یہ سننا اچھا لگتا تھا کہ جب کسی"}
{"hadithnumber": "1617", "text": "بریدہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم جب کسی لشکر پر امیر مقرر کرتے تو اسے خا"}
{"hadithnumber": "1618", "text": "انس رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نماز فجر کے وقت ہی حملہ کرتے تھے، اگر آپ ا"}
