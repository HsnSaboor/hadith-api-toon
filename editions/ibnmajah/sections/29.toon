3314,حَدَّثَنَا أَبُو مُصْعَبٍ،‏‏‏‏ حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ زَيْدِ بْنِ أَسْلَمَ،‏‏‏‏ عَنْ أَب,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۷۳۸، ومصباح الزجاجة:۱۱۴۱)، وقد أخرجہ: مسند احمد (۲/۹۷),3314,,Chapters on Food
3315,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ،‏‏‏‏ حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِيَةَ،‏‏‏‏ حَدَّثَنَا عِيسَى ب,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۶۱۸، ومصباح الزجاجة:۱۱۴۲),3315,,Chapters on Food
3316,حَدَّثَنَا أَحْمَدُ بْنُ أَبِي الْحَوَارِيِّ،‏‏‏‏ حَدَّثَنَا مَرْوَانُ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الأشربة والأطعمة ۳۰ (۲۰۵۱)، سنن الترمذی/الأطعمة ۳۵ (۱۸۴۰)،(تحفة الأشراف:۱۶۹۴۳)، وقد أخرجہ: سنن الدارمی/الأطعمة ۱۸ (۲۰۹۳),3316,,Chapters on Food
3317,حَدَّثَنَا جُبَارَةُ بْنُ الْمُغَلِّسِ،‏‏‏‏ حَدَّثَنَا قَيْسُ بْنُ الرَّبِيعِ،‏‏‏‏ عَنْ مُحَارِبِ بْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الأطعمة ۴۰ (۳۸۲۰)، سنن الترمذی/الأطعمة ۳۵ (۱۸۴۲)،(تحفة الأشراف:۲۵۷۹)، وقد أخرجہ: صحیح مسلم/الأشربة الأطعمة ۳۰ (۲۰۵۲)، سنن النسائی/الأیمان والنذور ۲۰ (۳۸۲۷)، مسند احمد (۳/۳۰۴،۳۷۱،۳۸۹،۳۹۰، سنن الدارمی/الأطعمة ۱۸ (۲۰۹۲),3317,,Chapters on Food
3318,حَدَّثَنَا الْعَبَّاسُ بْنُ عُثْمَانَ الدِّمَشْقِيُّ،‏‏‏‏ حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ،‏‏‏‏ ح,Al-Albani: Mawdu; Muhammad Fouad Abd al-Baqi: Mawdu; Shuaib Al Arnaut: Mawdu; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۸۳۲۱، ومصباح الزجاجة:۱۱۴۳),3318,,Chapters on Food
3319,حَدَّثَنَا الْحُسَيْنُ بْنُ مَهْدِيٍّ،‏‏‏‏ حَدَّثَنَا عَبْدُ الرَّزَّاقِ،‏‏‏‏ أَنْبَأَنَا مَعْمَرٌ،‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن الترمذی/الأطعمة ۴۳ (۱۸۵۱)،(تحفة الأشراف:۱۰۳۹۲)، وقد أخرخہ: مسند احمد (۳/۴۹۷),3319,,Chapters on Food
3320,حَدَّثَنَا عُقْبَةُ بْنُ مُكْرَمٍ،‏‏‏‏ حَدَّثَنَا صَفْوَانُ بْنُ عِيسَى،‏‏‏‏ حَدَّثَنَا عَبْدُ اللَّ,Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۴۳۳۸، ومصباح الزجاجة:۱۱۴۴),3320,,Chapters on Food
3321,حَدَّثَنَا أَبُو كُرَيْبٍ،‏‏‏‏ حَدَّثَنَا زَيْدُ بْنُ الْحُبَابِ،‏‏‏‏ عَنْ جَعْفَرِ بْنِ بُرْدٍ الرّ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۷۹۸۱، ومصباح الزجاجة:۱۱۴۵)، وقد أخرجہ: مسند احمد (۶/۱۴۵),3321,,Chapters on Food
3322,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ،‏‏‏‏ حَدَّثَنَا إِسْمَاعِيل بْنُ عَيَّاشٍ،‏‏‏‏ حَدَّثَنَا ابْنُ جُر,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۸۵۹)، وقد أخرجہ: سنن ابی داود/الأشربة ۲۱ (۳۷۳۰)، سنن الترمذی/الدعوات ۵۵ (۳۴۵۱),3322,,Chapters on Food
3323,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ وَعَبْدُ الرَّحْمَنِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الطلاق ۸ (۵۲۶۷)، الأطعمة ۳۲ (۵۴۳۱)، الأشربة ۱۰ (۵۵۹۹)،۱۵ (۵۶۱۴)، الطب ۴ (۵۶۸۲)، الحیل ۱۲ (۶۹۷۲)، صحیح مسلم/الطلاق ۳ (۱۴۷۴)، سنن ابی داود/الأشربة ۱۱ (۳۷۱۵)، سنن الترمذی/الأطعمة ۲۹ (۱۸۳۱)،(تحفة الأشراف:۱۶۷۹۶)، وقد أخرجہ: مسند احمد (۶/۵۹)، سنن الدارمی/الأطعمة ۳۴ (۲۱۱۹),3323,,Chapters on Food
3324,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ،‏‏‏‏ حَدَّثَنَا يُونُسُ بْنُ بُكَيْرٍ،‏‏‏‏ حَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۷۳۳۹),3324,,Chapters on Food
3325,حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ،‏‏‏‏ وَإِسْمَاعِيل بْنُ مُوسَى،‏‏‏‏ قَالَا:‏‏‏‏ حَدّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الأطعمة ۳۹ (۵۴۴۰)، صحیح مسلم/الأشربة ۲۳ (۲۰۴۳)، سنن ابی داود/الأطعمة ۴۵ (۳۸۳۵)، سنن الترمذی/الأطعمة ۳۷ (۱۸۴۴)،(تحفة الأشراف:۵۲۱۹)، وقد أخرجہ: مسند احمد (۱/۲۰۳)، سنن الدارمی/الأطعمة ۲۴ (۲۱۰۲),3325,,Chapters on Food
3326,حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ،‏‏‏‏ وَعَمْرُو بْنُ رَافِعٍ،‏‏‏‏ قَالَا:‏‏‏‏ حَدَّثَنَا يَعْقُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۷۹۲، ومصباح الزجاجة:۱۱۴۶),3326,,Chapters on Food
3327,ثَنَا أَحْمَدُ بْنُ أَبِي الْحَوَارِيِّ الدِّمَشْقِيُّ،‏‏‏‏ حَدَّثَنَا مَرْوَانُ بْنُ مُحَمَّدٍ،‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الأشربة ۲۶ (۲۰۴۶)، سنن ابی داود/الأطعمة ۴۲ (۳۸۳۱)، سنن الترمذی/الأطعمة ۱۷ (۱۸۱۵)،(تحفة الأشراف:۱۶۹۴۲)، وقد أخرجہ: سنن الدارمی/الأطعمة ۲۶ (۲۱۰۵),3327,,Chapters on Food
3328,حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ الدِّمَشْقِيُّ،‏‏‏‏ حَدَّثَنَا ابْنُ أَبِي فُدَيْكٍ،,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۵۸۹۵، ومصباح الزجاجة:۱۱۴۷),3328,,Chapters on Food
3329,حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ،‏‏‏‏ وَيَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ،‏‏‏‏ قَالَا:‏‏‏‏ ح,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۸۵ (۱۳۷۳)،(تحفة الأشراف:۱۲۷۰۷)، وقد أخرجہ: سنن الترمذی/الدعوات ۵۴ (۳۴۵۴)، موطا امام مالک/الجامع ۱ (۲)، مسند احمد (۱/۱۱۶،۱۶۹،۱۸۳،۲/۱۲۴،۱۲۶،۳۳۰،۳/۳۵،۴۷)، سنن الدارمی/الأطعمة ۳۲ (۲۱۱۶),3329,,Chapters on Food
3330,حَدَّثَنَا أَبُو بِشْرٍ بَكْرُ بْنُ خَلَفٍ،‏‏‏‏ حَدَّثَنَا يَحْيَى بْنُ مُحَمَّدِ بْنِ قَيْسٍ الْمَد,Al-Albani: Mawdu; Muhammad Fouad Abd al-Baqi: Mawdu; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۷۳۳۴، ومصباح الزجاجة:۱۱۴۸),3330,,Chapters on Food
3331,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ،‏‏‏‏ حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ،‏‏‏‏ حَدَّثَنَا,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/المظالم ۱۴ (۲۴۵۵)، الشرکة ۴ (۲۴۸۹)، صحیح مسلم/الأشربة ۲۵ (۲۰۴۵)، سنن ابی داود/الأطعمة ۴۴ (۳۸۳۴)، سنن الترمذی/الأطعمة ۱۶ (۱۸۱۴)،(تحفة الأشراف:۶۶۶۷)، وقد أخرجہ: مسند احمد (۲/۷،۴۴،۳۶،۶۰،۷۴،۸۱،۱۰۳،۱۳۱)، سنن الدارمی/الأطعمة ۲۵ (۲۱۰۳),3331,,Chapters on Food
3332,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ،‏‏‏‏ حَدَّثَنَا أَبُو دَاوُدَ،‏‏‏‏ حَدَّثَنَا أَبُو عَامِرٍ الْخَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۴۵۲، ومصباح الزجاجة:۱۱۴۹)، وقد أخرجہ: مسند احمد (۱/۱۹۹),3332,,Chapters on Food
3333,حَدَّثَنَا أَبُو بِشْرٍ بَكْرُ بْنُ خَلَفٍ،‏‏‏‏ حَدَّثَنَا أَبُو قُتَيْبَةَ،‏‏‏‏ عَنْ هَمَّامٍ،‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الأطعمة ۴۳ (۳۸۳۲،۳۸۳۳)،(تحفة الأشراف:۲۱۵),3333,,Chapters on Food
3334,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ،‏‏‏‏ حَدَّثَنَا صَدَقَةُ بْنُ خَالِدٍ،‏‏‏‏ حَدَّثَنِي ابْنُ جَابِرٍ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۱۹، ومصباح الزجاجة:۱۱۵۰)، وقد أخرجہ: سنن ابی داود/الأطعمة ۴۵ (۳۸۳۷),3334,,Chapters on Food
3335,حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ،‏‏‏‏ وَسُوَيْدُ بْنُ سَعِيدٍ،‏‏‏‏ قَالَا:‏‏‏‏ حَدَّثَنَا عَبْد,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih Sahih Bukhari,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۷۳۱، ومصباح الزجاجة:۱۱۵۱)، وقد أخرجہ: صحیح البخاری/الأطعمة ۲۲ (۵۴۱۰)، سنن الترمذی/الزہد ۳۸ (۲۳۶۴)، مسند احمد (۵/۳۳۲،۶/۷۱),3335,,Chapters on Food
3336,حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ،‏‏‏‏ حَدَّثَنَا ابْنُ وَهْبٍ،‏‏‏‏ أَخْبَرَنِي عَمْرُ,Al-Albani: Hasan Isnaad; Muhammad Fouad Abd al-Baqi: Hasan Isnaad; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۸۳۰۳، ومصباح الزجاجة:۱۱۵۲),3336,,Chapters on Food
3337,حَدَّثَنَا الْعَبَّاسُ بْنُ الْوَلِيدِ الدِّمَشْقِيُّ،‏‏‏‏ حَدَّثَنَا مُحَمَّدُ بْنُ عُثْمَانَ أَبُو,Al-Albani: Daif Isnaad; Muhammad Fouad Abd al-Baqi: Daif Isnaad; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۶۷),3337,,Chapters on Food
3338,حَدَّثَنَا أَبُو عُمَيْرٍ عِيسَى بْنُ مُحَمَّدٍ النَّحَّاسُ الرَّمْلِيُّ،‏‏‏‏ حَدَّثَنَا ضَمْرَةُ بْ,Al-Albani: Daif Isnaad; Muhammad Fouad Abd al-Baqi: Daif Isnaad; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۴۲۰۵، ومصباح الزجاجة:۱۱۵۳),3338,,Chapters on Food
3339,حَدَّثَنَا إِسْحَاق بْنُ مَنْصُورٍ،‏‏‏‏ وَأَحْمَدُ بْنُ سَعِيدٍ الدَّارِمِيُّ،‏‏‏‏ قَالَا:‏‏‏‏ حَدَّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «صحیح البخاری/الأطعمة ۲۶ (۵۳۸۵)،(تحفة الأشراف:۱۴۰۶)، وقد أخرجہ: مسند احمد (۳/۱۲۸،۱۳۴،۲۵۰),3339,,Chapters on Food
3340,حَدَّثَنَا عَبْدُ الْوَهَّابِ بْنُ الضَّحَّاكِ السُّلَمِيُّ أَبُو الْحَارِثِ،‏‏‏‏ حَدَّثَنَا إِسْمَا,Al-Albani: Mawdu; Muhammad Fouad Abd al-Baqi: Munkar; Shuaib Al Arnaut: Mawdu; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۸۷۵، ومصباح الزجاجة:۱۱۵۴),3340,,Chapters on Food
3341,حَدَّثَنَا هَدِيَّةُ بْنُ عَبْدِ الْوَهَّابِ،‏‏‏‏ حَدَّثَنَا الْفَضْلُ بْنُ مُوسَى السِّينَانِيُّ،‏‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الأطعمة ۳۸ (۳۸۱۸)،(تحفة الأشراف:۷۵۵۱),3341,,Chapters on Food
3342,حَدَّثَنَا أَحْمَدُ بْنُ عَبْدَةَ،‏‏‏‏ حَدَّثَنَا عُثْمَانُ بْنُ عَبْدِ الرَّحْمَنِ،‏‏‏‏ حَدَّثَنَا,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۳۱)، وقد أخرجہ: صحیح البخاری/الأطعمة ۶ (۵۳۸۱)، صحیح مسلم/الأشربة ۲۰ (۲۰۴۰)، سنن الترمذی/المناقب ۶ (۳۶۳۰)، موطا امام مالک/صفة النبی صفة ۱۰ (۱۹)، مسند احمد (۱/۱۵۹،۱۹۸،۳/۱۱،۱۴۷،۱۶۳،۲۱۸),3342,,Chapters on Food
3343,حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ،‏‏‏‏ حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِيَةَ،‏‏‏‏ عَنْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الزہد ۱ (۲۹۷۶)، سنن الترمذی/الزہد ۳۸ (۲۳۵۸)،(تحفة الأشراف:۱۳۴۴۰)، وقد أخرجہ: صحیح البخاری/الأطعمة ۱ (۵۳۷۴)، مسند احمد (۲/۴۳۴),3343,,Chapters on Food
3344,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى،‏‏‏‏ حَدَّثَنَا مُعَاوِيَةُ بْنُ عَمْرٍو،‏‏‏‏ حَدَّثَنَا زَائِدَةُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الأطعمة ۲۳ (۵۴۱۶)،۲۷ (۵۴۲۳)، الأضاحي ۱۶ (۵۵۷۰)،(تحفة الأشراف:۱۵۹۸۶)، وقد أخرجہ: صحیح مسلم/الزہد ۱ (۲۹۷۰)، سنن الترمذی/الأضاحي ۱۴ (۱۵۱۰)، سنن النسائی/الضحایا ۳۶ (۴۴۳۷)، مسند احمد (۶/۱۰۲،۲۰۹،۲۷۷),3344,,Chapters on Food
3345,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ حَدَّثَنَا أَبُو أُسَامَةَ،‏‏‏‏ حَدَّثَنَا هِشَامُ بْنُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الخمس ۳ (۳۰۹۷)، الرقاق ۱۶ (۶۴۵۴)، صحیح مسلم/الزہد (۲۹۷۰)،(تحفة الأشراف:۱۵۹۸۶)، وقد أخرجہ: مسند احمد (۶/۱۰۸،۲۷۷),3345,,Chapters on Food
3346,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ،‏‏‏‏ حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ،‏‏‏‏ حَدَّثَنَا شُعْبَةُ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الزہد ۱ (۲۹۷۰)، سنن الترمذی/الزہد ۳۸ (۲۳۵۷)، الشمائل (۱۴۳)،(تحفة الأشراف:۱۴۰۱۴)، وقد أخرجہ: مسند احمد (۲/۹۸،۴۳۴،۴/۴۴۲،۶/۱۲۸،۱۵۶،۱۸۷،۲۵۵،۲۷۷),3346,,Chapters on Food
3347,حَدَّثَنَا عَبْدُ اللَّهِ بْنُ مُعَاوِيَةَ الْجُمَحِيُّ،‏‏‏‏ حَدَّثَنَا ثَابِتُ بْنُ يَزِيدَ،‏‏‏‏ عَ,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن الترمذی/الزہد ۳۸ (۲۳۵۷)،(تحفة الأشراف:۱۶۰۱۴)، وقد أخرجہ: صحیح مسلم/الرقاق (۲۹۷۰),3347,,Chapters on Food
3348,حَدَّثَنَا يَحْيَى بْنُ عُثْمَانَ بْنِ سَعِيدِ بْنِ كَثِيرِ بْنِ دِينَارٍ الْحِمْصِيُّ،‏‏‏‏ حَدَّثَن,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۴۲، ومصباح الزجاجة:۱۱۵۵),3348,,Chapters on Food
3349,حَدَّثَنَا هِشَامُ بْنُ عَبْدِ الْمَلِكِ الْحِمْصِيُّ،‏‏‏‏ حَدَّثَنَا مُحَمَّدُ بْنُ حَرْبٍ،‏‏‏‏ حَد,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۵۷۸)، وقد أخرجہ: سنن الترمذی/الزہد ۴۷ (۲۳۸۰)، مسند احمد (۴/۱۳۲),3349,,Chapters on Food
3350,حَدَّثَنَا عَمْرُو بْنُ رَافِعٍ،‏‏‏‏ حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ عَبْدِ اللَّهِ أَبُو يَحْيَى،,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Sanad Daif; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/القیامة ۳۷ (۲۴۷۸)،(تحفة الأشراف:۸۵۶۳),3350,,Chapters on Food
3351,حَدَّثَنَا دَاوُدُ بْنُ سُلَيْمَانَ الْعَسْكَرِيُّ،‏‏‏‏ وَمُحَمَّدُ بْنُ الصَّبَّاحِ،‏‏‏‏ قَالَا:‏‏‏,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۵۰۶، ومصباح الزجاجة:۱۱۵۶),3351,,Chapters on Food
3352,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ،‏‏‏‏ وَسُوَيْدُ بْنُ سَعِيدٍ،‏‏‏‏ وَيَحْيَى بْنُ عُثْمَانَ بْنِ سَع,Al-Albani: Mawdu; Muhammad Fouad Abd al-Baqi: Mawdu; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۴۳، ومصباح الزجاجة:۱۱۵۷),3352,,Chapters on Food
3353,حَدَّثَنَا إِبْرَاهِيمُ بْنُ مُحَمَّدِ بْنِ يُوسُفَ الْفِرْيَابِيُّ،‏‏‏‏ حَدَّثَنَا وَسَّاجُ بْنُ عُ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۶۶۸۴، ومصباح الزجاجة:۱۱۵۸),3353,,Chapters on Food
3354,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا إِسْحَاق بْنُ مَنْصُورٍ،‏‏‏‏ حَدَّثَنَا,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۴۲۹۶، ومصباح الزجاجة:۱۱۵۹)، وقد أخرجہ: سنن ابی داود/الصلاة ۳۶۷ (۱۵۴۷)، سنن النسائی/الاستعاذة ۱۹ (۵۴۷۱),3354,,Chapters on Food
3355,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ الرَّقِّيُّ،‏‏‏‏ حَدَّثَنَا إِبْرَاهِيمُ بْنُ عَبْدِ السَّل,Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Sanad Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۰۵۲، ومصباح الزجاجة:۱۱۶۰),3355,,Chapters on Food
3356,حَدَّثَنَا جُبَارَةُ بْنُ الْمُغَلِّسِ،‏‏‏‏ حَدَّثَنَا كَثِيرُ بْنُ سُلَيْمٍ،‏‏‏‏ عَنْ أَنَسِ بْنِ م,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۴۴۷، ومصباح الزجاجة:۱۱۶۱),3356,,Chapters on Food
3357,حَدَّثَنَا جُبَارَةُ بْنُ الْمُغَلِّسِ،‏‏‏‏ حَدَّثَنَا الْمُحَارِبِيُّ،‏‏‏‏ حَدَّثَنَا عَبْدُ الرَّح,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۶۹۱، ومصباح الزجاجة:۱۱۶۲),3357,,Chapters on Food
3358,حَدَّثَنَا عَلِيُّ بْنُ مَيْمُونٍ الرَّقِّيُّ،‏‏‏‏ حَدَّثَنَا عُثْمَانُ بْنُ عَبْدِ الرَّحْمَنِ،‏‏‏‏,Al-Albani: Mawdu; Muhammad Fouad Abd al-Baqi: Mawdu; Shuaib Al Arnaut: Mawdu; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۴۱۸۹، ومصباح الزجاجة:۱۱۶۳),3358,,Chapters on Food
3359,حَدَّثَنَا أَبُو كُرَيْبٍ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ هِشَامٍ الدَّسْتُوَائِيِّ،‏‏‏‏ عَنْ قَتَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن النسائی/الزینة من المجتبیٰ ۵۷ (۵۳۵۳)،(تحفة الأشراف:۱۰۱۱۷),3359,,Chapters on Food
3360,حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ عَبْدِ اللَّهِ الْجَزَرِيُّ،‏‏‏‏ حَدَّثَنَا عَفَّانُ بْنُ مُسْلِم,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: سنن ابی داود/الأطعمة ۸ (۳۷۵۵)،(تحفة الأشراف:۴۴۸۳)، وقد أخرجہ: مسند احمد (۵/۲۲۰،۲۲۱،۲۲۲),3360,,Chapters on Food
3361,حَدَّثَنَا أَبُو كُرَيْبٍ،‏‏‏‏ حَدَّثَنَا يَحْيَى بْنُ عَبْدِ الرَّحْمَنِ الْأَرْحَبِيُّ،‏‏‏‏ حَدَّث,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۵۷۹، ومصباح الزجاجة:۱۱۶۴)، وقد أخرجہ: مسند احمد (۵/۲۲۰،۲۲۱،۲۲۲),3361,,Chapters on Food
3362,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ،‏‏‏‏ حَدَّثَنَا عُثْمَانُ بْنُ عُمَرَ،‏‏‏‏ حَدَّثَنَا أَبُو عَامِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/البر ۴۲ (۲۶۲۵)، سنن الترمذی/الأطعمة ۳۰ (۱۸۳۳)،(تحفة الأشراف:۱۱۹۵۱)، وقد أخرجہ: مسند احمد (۵/۱۶۱،۱۷۱)، سنن الدارمی/الأطعمة ۳۷ (۲۱۲۴),3362,,Chapters on Food
3363,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا إِسْمَاعِيل بْنُ عُلَيَّةَ،‏‏‏‏ عَنْ سَع,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «صحیح مسلم/المساجد ۱۷ (۵۶۷)،(تحفة الأشراف:۱۰۶۴۶)، وقد أخرجہ: مسند احمد (۱/۱۵،۴۹،۲۶،۲۷،۴۸،۴/۱۹،۲۶،۲۷،۴۸),3363,,Chapters on Food
3364,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ،‏‏‏‏ عَنْ عُبَ,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Sahih,takhreej: «سنن الترمذی/الأطعمة ۱۴ (۱۸۱۰)،(تحفة الأشراف:۱۸۳۰۴)، وقد أخرجہ: مسند احمد (۶/۴۳۳،۴۶۲)، سنن الدارمی/الأطعمة ۲۱ (۲۰۹۸),3364,,Chapters on Food
3365,حَدَّثَنَا حَرْمَلَةُ بْنُ يَحْيَى،‏‏‏‏ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ،‏‏‏‏ أَنْبَأَنَا أَبُو,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۸۷)، وقد أخرجہ: صحیح البخاری/الأذان ۱۶۰ (۸۵۴،۸۵۵)، الأطعمة ۴۹ (۵۴۵۲)، الاعتصام ۲۴ (۷۳۵۹)، صحیح مسلم/المساجد ۱۷ (۵۶۴)، سنن ابی داود/الأطعمة ۴۱ (۳۸۲۲)، سنن الترمذی/الأطعمة ۱۳ (۱۸۰۶)، سنن النسائی/المساجد ۱۶ (۷۰۸)، مسند احمد (۳/۳۷۴،۳۸۷),3365,,Chapters on Food
3366,حَدَّثَنَا حَرْمَلَةُ بْنُ يُحْيَى،‏‏‏‏ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ،‏‏‏‏ أَخْبَرَنِي ابْنُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۹۲۵، ومصباح الزجاجة:۱۱۶۵),3366,,Chapters on Food
3367,حَدَّثَنَا إِسْمَاعِيل بْنُ مُوسَى السُّدِّيُّ،‏‏‏‏ حَدَّثَنَا سَيْفُ بْنُ هَارُونَ،‏‏‏‏ عَنْ سُلَيْ,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/اللباس ۶ (۱۷۲۶)،(تحفة الأشراف:۴۴۹۶),3367,,Chapters on Food
3368,حَدَّثَنَا عَمْرُو بْنُ عُثْمَانَ بْنِ سَعِيدِ بْنِ كَثِيرِ بْنِ دِينَارٍ الْحِمْصِيُّ،‏‏‏‏ حَدَّثَن,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Sanad Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۶۳۳، ومصباح الزجاجة:۱۱۶۶),3368,,Chapters on Food
3369,حَدَّثَنَا إِسْمَاعِيل بْنُ مُحَمَّدٍ الطَّلْحِيُّ،‏‏‏‏ حَدَّثَنَا نُقَيْبُ بْنُ حَاجِبٍ،‏‏‏‏ عَنْ أ,Al-Albani: Daif Isnaad; Muhammad Fouad Abd al-Baqi: Daif Isnaad; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۰۰۴، ومصباح الزجاجة:۱۱۶۷),3369,,Chapters on Food
3370,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ،‏‏‏‏ حَدَّثَنَا كَثِيرُ بْنُ هِشَامٍ،‏‏‏‏ حَدَّثَنَا جَعْفَرُ بْن,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۸۱۰)، وقد أخرجہ: سنن ابی داود/الأطعمة ۱۹ (۳۷۷۴)، مسند احمد (۳/۴۳۰،۵/۴۲۶),3370,,Chapters on Food
