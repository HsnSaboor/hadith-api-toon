{"hadithnumber": "348", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ایک مد سے وضو، اور ایک صاع"}
{"hadithnumber": "349", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  ہم لوگ رسول اللہ صلی اللہ علیہ وسلم کے ساتھ نکلے، ہمارا"}
{"hadithnumber": "350", "text": "عروۃ سے روایت ہے کہ  فاطمہ بنت قیس رضی اللہ عنہا جو قریش کی شاخ قبیلہ بنو اسد کی ایک خاتون ہیں رسول"}
{"hadithnumber": "351", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جب حیض آئے ت"}
{"hadithnumber": "352", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  ام حبیبہ بنت جحش رضی اللہ عنہا نے رسول اللہ صلی اللہ عل"}
{"hadithnumber": "353", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  ام حبیبہ رضی اللہ عنہا نے رسول اللہ صلی اللہ علیہ وسلم"}
{"hadithnumber": "354", "text": "ام المؤمنین ام سلمہ رضی اللہ عنہا کہتی ہیں کہ  ایک عورت نے نبی اکرم صلی اللہ علیہ وسلم سے پوچھا: مجھ"}
{"hadithnumber": "355", "text": "ام المؤمنین ام سلمہ رضی اللہ عنہا سے روایت ہے کہ  ایک عورت کو رسول اللہ صلی اللہ علیہ وسلم کے زمانے"}
{"hadithnumber": "356", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  ام حبیبہ بنت جحش رضی اللہ عنہا جو عبدالرحمٰن بن عوف رضی"}
{"hadithnumber": "357", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  جحش کی بیٹی  ( ام حبیبہ )  کو سات سال تک استحاضہ کا"}
{"hadithnumber": "358", "text": "فاطمہ بنت ابی حبیش رضی اللہ عنہا نے بیان کیا کہ  وہ رسول اللہ صلی اللہ علیہ وسلم کے پاس آئیں اور آپ"}
{"hadithnumber": "359", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  فاطمہ بنت ابی حبیش رضی اللہ عنہا رسول اللہ صلی اللہ علی"}
{"hadithnumber": "360", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  ایک مستحاضہ عورت سے نبی اکرم صلی اللہ علیہ وسلم کے ز"}
{"hadithnumber": "361", "text": "زینب بنت جحش رضی اللہ عنہا کہتی ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم سے عرض کیا: میں مستحاضہ ہ"}
{"hadithnumber": "362", "text": "فاطمہ بنت ابی حبیش رضی اللہ عنہا کہتی ہیں کہ  انہیں استحاضہ آتا تھا تو رسول اللہ صلی اللہ علیہ وسلم"}
{"hadithnumber": "363", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  فاطمہ بنت ابی حبیش رضی اللہ عنہا کو استحاضہ کا خون آ"}
{"hadithnumber": "364", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  فاطمہ بنت ابی حبیش رضی اللہ عنہا مستحاضہ ہوئیں، تو انہو"}
{"hadithnumber": "365", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  فاطمہ بنت ابی حبیش رضی اللہ عنہا رسول اللہ صلی اللہ"}
{"hadithnumber": "366", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  فاطمہ بنت ابی حبیش رضی اللہ عنہا نے رسول اللہ صلی اللہ"}
{"hadithnumber": "367", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  بنت ابی حبیش رضی اللہ عنہا نے عرض کیا: اللہ کے رسول!"}
{"hadithnumber": "368", "text": "ام عطیہ رضی اللہ عنہا (نسیبہ) کہتی ہیں کہ  ہم لوگ زردی اور مٹیالا پن کو کچھ نہیں شمار کرتے تھے ۱؎۔"}
{"hadithnumber": "369", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  یہود کی عورتیں جب حائضہ ہو جاتیں تھی تو وہ ان کے ساتھ نہ کھاتے پیتے او"}
{"hadithnumber": "370", "text": "عبداللہ بن عباس رضی اللہ عنہم نبی اکرم صلی اللہ علیہ وسلم سے روایت کرتے ہیں کہ  جو آدمی اپنی بیوی کے"}
{"hadithnumber": "371", "text": "ام المؤمنین ام سلمہ رضی اللہ عنہا کہتی ہیں کہ  میں رسول اللہ صلی اللہ علیہ وسلم کے ساتھ لیٹی ہوئی تھ"}
{"hadithnumber": "372", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  میں اور رسول اللہ صلی اللہ علیہ وسلم دونوں ایک ہی کپڑے"}
{"hadithnumber": "373", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ہم بیویوں میں سے کسی کو جب"}
{"hadithnumber": "374", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  ہم سے کوئی جب حائضہ ہوتی تو رسول اللہ صلی اللہ علیہ وسل"}
{"hadithnumber": "375", "text": "جمیع بن عمیر کہتے ہیں:  میں اپنی ماں اور خالہ کے ساتھ ام المؤمنین عائشہ رضی اللہ عنہا کے پاس آیا، تو"}
{"hadithnumber": "376", "text": "ام المؤمنین میمونہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم اپنی حائضہ بیوی سے چمٹتے"}
{"hadithnumber": "377", "text": "شریح کہتے ہیں کہ  انہوں نے ام المؤمنین عائشہ رضی اللہ عنہا سے دریافت کیا: کیا عورت اپنے شوہر کے ساتھ"}
{"hadithnumber": "378", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم اپنا منہ اسی جگہ رکھتے تھے"}
{"hadithnumber": "379", "text": "شریح کہتے ہیں کہ  میں نے ام المؤمنین عائشہ رضی اللہ عنہا کو کہتے ہوئے سنا کہ رسول اللہ صلی اللہ علیہ"}
{"hadithnumber": "380", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  میں پیالہ سے پانی پیتی اور میں حائضہ ہوتی، پھر اسے نبی"}
{"hadithnumber": "381", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کا سر ہم  ( بیویوں )  میں"}
{"hadithnumber": "382", "text": "معاذہ عدویہ کہتی ہیں کہ  ایک عورت نے ام المؤمنین عائشہ رضی اللہ عنہا سے دریافت کیا: کیا حائضہ اپنی ن"}
{"hadithnumber": "383", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم مسجد میں تھے کہ اسی دوران آپ صلی الل"}
{"hadithnumber": "384", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  مجھ سے رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مجھے مس"}
{"hadithnumber": "384", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  مجھ سے رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مجھے مس"}
{"hadithnumber": "385", "text": "المؤمنین میمونہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ہم میں سے کسی کی گود میں اپن"}
{"hadithnumber": "386", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  وہ رسول اللہ صلی اللہ علیہ وسلم کے سر میں کنگھی کرتی"}
{"hadithnumber": "387", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم اپنا سر میرے قریب کر دیتے"}
{"hadithnumber": "388", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم اپنا سر مسجد سے نکالتے"}
{"hadithnumber": "389", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  میں رسول اللہ صلی اللہ علیہ وسلم کے سر میں کنگھی کرتی،"}
{"hadithnumber": "390", "text": "حفصہ (حفصہ بنت سیرین) کہتی ہیں کہ  ام عطیہ جب بھی رسول اللہ صلی اللہ علیہ وسلم کا ذکر کرتیں تو کہتیں"}
{"hadithnumber": "391", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم سے عرض کیا: ام"}
{"hadithnumber": "392", "text": "جابر بن عبداللہ رضی اللہ عنہم اسماء بنت عمیس رضی اللہ عنہا کے واقعہ کے بارے میں بیان کرتے ہیں کہ  جب"}
{"hadithnumber": "393", "text": "سمرہ رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کے ساتھ ام کعب رضی اللہ عنہا کی ن"}
{"hadithnumber": "394", "text": "فاطمہ بنت منذر اسماء بنت ابوبکر رضی اللہ عنہا سے روایت کرتی ہیں (جو ان کے زیر پرورش تھیں) کہ  ایک عو"}
{"hadithnumber": "395", "text": "ام قیس بنت محصن رضی اللہ عنہا کہتی ہیں کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم سے کپڑے میں حیض کا"}
