{"hadithnumber": "2175", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول صلی اللہ علیہ وسلم نے فرمایا:  جو شخص کسی عورت کو اس کے شوہر"}
{"hadithnumber": "2176", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  عورت اپنی بہن کی طلاق کا"}
{"hadithnumber": "2177", "text": "محارب کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ تعالیٰ کے نزدیک حلال چیزوں میں طلاق"}
{"hadithnumber": "2178", "text": "عبداللہ بن عمر رضی اللہ عنہما نبی اکرم صلی اللہ علیہ وسلم سے روایت کرتے ہیں  عبداللہ بن عمر رضی اللہ"}
{"hadithnumber": "2179", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم کے زمانے میں اپن"}
{"hadithnumber": "2180", "text": "نافع سے روایت ہے کہ  ابن عمر رضی اللہ عنہما نے اپنی ایک عورت کو حالت حیض میں ایک طلاق دے دی، آگے مال"}
{"hadithnumber": "2181", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  انہوں نے اپنی بیوی کو حالت حیض میں طلاق دے دی تو عمر ر"}
{"hadithnumber": "2182", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  انہوں نے اپنی بیوی کو حالت حیض میں طلاق دے دی، عمر رضی"}
{"hadithnumber": "2183", "text": "ابن سیرین کہتے ہیں کہ  مجھے یونس بن جبیر نے خبر دی کہ انہوں نے ابن عمر رضی اللہ عنہما سے دریافت کیا"}
{"hadithnumber": "2184", "text": "محمد بن سیرین کہتے ہیں کہ  مجھے یونس بن جبیر نے بتایا کہ میں نے عبداللہ بن عمر رضی اللہ عنہما سے مسئ"}
{"hadithnumber": "2185", "text": "ابن جریج کہتے ہیں کہ ہمیں ابوالزبیر نے خبر دی ہے کہ  انہوں نے عروہ کے غلام عبدالرحمٰن بن ایمن کو ابن"}
{"hadithnumber": "2186", "text": "مطرف بن عبداللہ سے روایت ہے کہ  عمران بن حصین رضی اللہ عنہما سے اس شخص کے بارے میں پوچھا گیا جو اپنی"}
{"hadithnumber": "2187", "text": "بنی نوفل کے غلام ابوحسن نے ابن عباس رضی اللہ عنہما سے  اس غلام کے بارے میں فتویٰ پوچھا جس کے نکاح می"}
{"hadithnumber": "2188", "text": "عثمان بن عمر کہتے ہیں کہ  ہمیں علی نے خبر دی ہے آگے سابقہ سند سے اسی مفہوم کی روایت مذکور ہے لیکن عن"}
{"hadithnumber": "2189", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  لونڈی کی طلا"}
{"hadithnumber": "2190", "text": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  طلاق صر"}
{"hadithnumber": "2191", "text": "اس سند سے بھی عبداللہ بن عمرو رضی اللہ عنہما سے اسی مفہوم کی روایت مروی ہے  اس میں اتنا اضافہ ہے:  ج"}
{"hadithnumber": "2192", "text": "اس سند سے بھی عبداللہ بن عمرو رضی اللہ عنہما سے یہی روایت آئی ہے  اس میں اتنا اضافہ ہے کہ  وہی نذر م"}
{"hadithnumber": "2193", "text": "محمد بن عبید بن ابوصالح (جو ایلیاء میں رہتے تھے) کہتے ہیں کہ  میں عدی بن عدی کندی کے ساتھ نکلا یہاں"}
{"hadithnumber": "2194", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تین چیزیں ایسی ہیں کہ"}
{"hadithnumber": "2195", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں  اللہ تعالیٰ کا فرمان ہے «والمطلقات يتربصن بأنفسهن ثلاثة قرو"}
{"hadithnumber": "2196", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رکانہ اور اس کے بھائیوں کے والد عبد یزید نے رکانہ کی ماں"}
{"hadithnumber": "2197", "text": "مجاہد کہتے ہیں: میں ابن عباس رضی اللہ عنہما کے پاس تھا کہ  ایک آدمی آیا اور ان سے کہنے لگا کہ اس نے"}
{"hadithnumber": "2198", "text": "ابوداؤد کہتے ہیں: ابن عباس رضی اللہ عنہما کا قول اگلی والی حدیث میں ہے جسے محمد بن ایاس نے روایت کیا"}
{"hadithnumber": "2199", "text": "طاؤس سے روایت ہے کہ  ایک صاحب جنہیں ابوصہبا کہا جاتا تھا ابن عباس رضی اللہ عنہما سے کثرت سے سوال کرت"}
{"hadithnumber": "2200", "text": "طاؤس سے روایت ہے کہ  ابوصہباء نے ابن عباس رضی اللہ عنہما سے پوچھا: کیا آپ کو معلوم ہے کہ رسول اللہ ص"}
{"hadithnumber": "2201", "text": "علقمہ بن وقاص لیثی کہتے ہیں کہ  میں نے عمر بن خطاب رضی اللہ عنہ کو کہتے سنا کہ رسول اللہ صلی اللہ عل"}
{"hadithnumber": "2202", "text": "عبداللہ بن کعب بن مالک (جو کہ اپنے والد کعب رضی اللہ عنہ کے نابینا ہو جانے کے بعد ان کے قائد تھے) کہ"}
{"hadithnumber": "2203", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ہمیں  ( اپنے عقد میں رہ"}
{"hadithnumber": "2204", "text": "حماد بن زید کہتے ہیں کہ  میں نے ایوب سے پوچھا: کیا آپ کو معلوم ہے کہ کسی اور نے بھی «أمرك بيدك» کے س"}
{"hadithnumber": "2205", "text": "حسن سے  «أمرك بيدك» کے سلسلہ میں مروی ہے کہ اس سے تین طلاق واقع ہو گی ۱؎۔"}
{"hadithnumber": "2206", "text": "نافع بن عجیر بن عبد یزید بن رکانہ سے روایت ہے کہ  رکانہ بن عبد یزید نے اپنی بیوی سہیمہ کو طلاق بتہ ۱"}
{"hadithnumber": "2207", "text": "اس سند سے بھی  رکانہ بن عبد یزید سے یہی حدیث مرفوعاً مروی ہے۔"}
{"hadithnumber": "2208", "text": "رکانہ بن عبد یزید رضی اللہ عنہ سے روایت ہے کہ  انہوں نے اپنی بیوی کو طلاق بتہ دے دی پھر رسول اللہ صل"}
{"hadithnumber": "2209", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  اللہ تعالیٰ نے میری ام"}
{"hadithnumber": "2210", "text": "ابوتمیمہ ہجیمی سے روایت ہے کہ  ایک شخص نے اپنی بیوی کو اے چھوٹی بہن! کہہ کر پکارا تو رسول اللہ صلی ا"}
{"hadithnumber": "2211", "text": "ابو تمیمہ سے روایت ہے، وہ اپنی قوم کے ایک شخص سے روایت کرتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے ا"}
{"hadithnumber": "2212", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  ابراہیم علیہ السلام نے"}
{"hadithnumber": "2213", "text": "سلمہ بن صخر بیاضی رضی اللہ عنہ کہتے ہیں کہ  کہ لوگوں کے مقابلے میں میں کچھ زیادہ ہی عورتوں کا شوقین"}
{"hadithnumber": "2214", "text": "خویلہ بنت مالک بن ثعلبہ رضی اللہ عنہا کہتی ہیں کہ  میرے شوہر اوس بن صامت نے مجھ سے ظہار کر لیا تو می"}
{"hadithnumber": "2215", "text": "اس سند سے بھی ابن اسحاق سے اسی طرح کی روایت منقول ہے لیکن اس میں ہے کہ  «عرق» ایسی زنبیل ہے جس میں ت"}
{"hadithnumber": "2216", "text": "ابوسلمہ بن عبدالرحمٰن بن عوف زہری کہتے ہیں کہ  «عرق» سے مراد ایسی زنبیل ہے جس میں پندرہ صاع کھجوریں"}
{"hadithnumber": "2217", "text": "لیمان بن یسار سے یہی حدیث مروی ہے  اس میں ہے: آپ صلی اللہ علیہ وسلم کے پاس کھجوریں آئیں تو آپ نے وہ"}
{"hadithnumber": "2218", "text": "عبادہ بن صامت رضی اللہ عنہ کے بھائی اوس رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے"}
{"hadithnumber": "2219", "text": "ہشام بن عروہ سے روایت ہے کہ  جمیلہ رضی اللہ عنہا اوس بن صامت رضی اللہ عنہ کے نکاح میں تھیں، اور وہ ع"}
{"hadithnumber": "2220", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے بھی  اسی کے مثل مروی ہے۔"}
{"hadithnumber": "2221", "text": "عکرمہ سے روایت ہے کہ  ایک شخص نے اپنی بیوی سے ظہار کر لیا، پھر کفارہ ادا کرنے سے پہلے ہی وہ اس سے صح"}
{"hadithnumber": "2222", "text": "عکرمہ سے روایت ہے کہ  ایک شخص نے اپنی بیوی سے ظہار کر لیا، پھر اس نے چاندنی میں اس کی پنڈلی کی چمک د"}
{"hadithnumber": "2223", "text": "اس سند سے ابن عباس رضی اللہ عنہما سے مرفوعاً اسی طرح روایت ہے  لیکن اس میں پنڈلی کا ذکر نہیں ہے۔"}
{"hadithnumber": "2224", "text": "اس سند سے بھی عکرمہ سے  سے سفیان کی حدیث  ( نمبر: ۲۲۲۱ )  کی طرح روایت ہے۔"}
{"hadithnumber": "2225", "text": "ابوداؤد کہتے ہیں: میں نے محمد بن عیسیٰ کو اسے بیان کرتے سنا ہے، وہ کہتے ہیں  ہم سے معتمر نے بیان کیا"}
{"hadithnumber": "2226", "text": "ثوبان رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس عورت نے اپنے شوہر سے بغی"}
{"hadithnumber": "2227", "text": "حبیبہ بنت سہل انصاریہ رضی اللہ عنہا سے روایت ہے کہ  وہ ثابت بن قیس بن شماس رضی اللہ عنہ کے نکاح میں"}
{"hadithnumber": "2228", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  حبیبہ بنت سہل رضی اللہ عنہا ثابت بن قیس بن شماس رضی"}
{"hadithnumber": "2229", "text": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  ثابت بن قیس رضی اللہ عنہ کی بیوی نے ان سے خلع کر لیا"}
{"hadithnumber": "2230", "text": "عبداللہ بن عمر رضی اللہ عنہما سے مروی ہے کہ  خلع کرانے والی عورت کی عدت ایک حیض ہے۔"}
{"hadithnumber": "2231", "text": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  مغیث رضی اللہ عنہ ایک غلام تھے وہ کہنے لگے: اللہ کے ر"}
{"hadithnumber": "2232", "text": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  بریرہ رضی اللہ عنہا کے شوہر ایک کالے کلوٹے غلام تھے ج"}
{"hadithnumber": "2233", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے بریرہ کے قصہ میں روایت ہے کہ  اس کا شوہر غلام تھا، رسول اللہ صلی"}
{"hadithnumber": "2234", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے بریرہ کو اختیار دیا"}
{"hadithnumber": "2235", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  جس وقت بریرہ رضی اللہ عنہا آزاد ہوئی اس وقت اس کا شو"}
{"hadithnumber": "2236", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  بریرہ رضی اللہ عنہا آزاد کی گئی اس وقت وہ آل ابواحمد"}
{"hadithnumber": "2237", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  انہوں نے اپنے لونڈی غلام کے ایک جوڑے کو آزاد کرنا چا"}
{"hadithnumber": "2238", "text": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم کے زمانے میں ایک شخص مسل"}
{"hadithnumber": "2239", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے زمانے میں ایک عورت مسلما"}
{"hadithnumber": "2240", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے اپنی صاحبزادی زینب رضی ا"}
{"hadithnumber": "2241", "text": "حارث بن قیس اسدی رضی اللہ عنہ کہتے ہیں  میں نے اسلام قبول کیا، میرے پاس آٹھ بیویاں تھیں تو میں نے اس"}
{"hadithnumber": "2242", "text": "اس سند سے بھی قیس بن حارث رضی اللہ عنہ سے  اسی مفہوم کی حدیث مروی ہے۔"}
{"hadithnumber": "2243", "text": "فیروز رضی اللہ عنہ کہتے ہیں کہ  میں نے عرض کیا: اللہ کے رسول! میں نے اسلام قبول کر لیا ہے اور میرے ن"}
{"hadithnumber": "2244", "text": "رافع بن سنان رضی اللہ عنہ سے روایت ہے کہ  انہوں نے اسلام قبول کر لیا، لیکن ان کی بیوی نے اسلام قبول"}
{"hadithnumber": "2245", "text": "سہل بن سعد ساعدی رضی اللہ عنہما سے روایت ہے کہ  عویمر بن اشقر عجلانی، عاصم بن عدی رضی اللہ عنہ سے آ"}
{"hadithnumber": "2246", "text": "سہل رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے عاصم بن عدی رضی اللہ عنہ سے فرمایا:"}
{"hadithnumber": "2247", "text": "سہل بن سعد ساعدی رضی اللہ عنہ کہتے ہیں کہ  میں ان دونوں کے لعان میں نبی اکرم صلی اللہ علیہ وسلم کے پ"}
{"hadithnumber": "2248", "text": "لعان والی حدیث میں سہل بن سعد رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اس"}
{"hadithnumber": "2249", "text": "اس سند سے بھی سہل بن سعد ساعدی رضی اللہ عنہ سے یہی حدیث مروی ہے  اس میں ہے: تو اسے یعنی لڑکے کو اس ک"}
{"hadithnumber": "2250", "text": "اس سند سے بھی سہل بن سعد رضی اللہ عنہما سے یہی حدیث مروی ہے  اس میں ہے: انہوں  ( عاصم بن عدی )  نے ر"}
{"hadithnumber": "2251", "text": "سہل بن سعد رضی اللہ عنہما کہتے ہیں کہ  میں رسول اللہ صلی اللہ علیہ وسلم کے عہد میں دونوں لعان کرنے و"}
{"hadithnumber": "2252", "text": "اس سند سے سہل بن سعد رضی اللہ عنہما سے یہی حدیث مروی ہے  اس میں ہے کہ:  وہ عورت حاملہ تھی اور اس نے"}
{"hadithnumber": "2253", "text": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  میں  ( ایک دفعہ )  جمعہ کی رات مسجد میں تھا کہ اچانک انصا"}
{"hadithnumber": "2254", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  ہلال بن امیہ رضی اللہ عنہ نے رسول اللہ صلی اللہ علیہ وسل"}
{"hadithnumber": "2255", "text": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے جس وقت دونوں کو لعان ک"}
{"hadithnumber": "2256", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  ہلال بن امیہ رضی اللہ عنہ  ( جو کہ ان تین اشخاص میں سے ا"}
{"hadithnumber": "2257", "text": "سعید بن جبیر کہتے ہیں: میں نے ابن عمر رضی اللہ عنہما کو کہتے سنا کہ  رسول اللہ صلی اللہ علیہ وسلم نے"}
{"hadithnumber": "2258", "text": "سعید بن جبیر کہتے ہیں کہ میں نے ابن عمر رضی اللہ عنہما سے جو کہا کہ  ایک شخص اپنی عورت کو تہمت لگائے"}
{"hadithnumber": "2259", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے زمانے میں ایک شخص نے اپنی"}
{"hadithnumber": "2260", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کے پاس بنی فزارہ کا ایک شخص آیا اور ک"}
{"hadithnumber": "2261", "text": "اس سند سے بھی زہری سے اسی مفہوم کی حدیث مروی ہے  لیکن اس میں یہ ہے کہ یہ کہہ کر اس کا مقصد اپنے سے ب"}
{"hadithnumber": "2262", "text": "اس سند سے بھی ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  ایک دیہاتی رسول اللہ صلی اللہ علیہ وسلم کی خدمت"}
{"hadithnumber": "2263", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  جس وقت آیت لعان نازل ہوئی انہوں نے رسول اللہ صلی اللہ علیہ وسل"}
{"hadithnumber": "2264", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اسلام میں اجرت"}
{"hadithnumber": "2265", "text": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فیصلہ فرمایا کہ"}
{"hadithnumber": "2266", "text": "اس سند سے بھی محمد بن راشد سے اسی مفہوم کی روایت منقول ہے  لیکن اس میں یہ الفاظ زائد ہیں کہ وہ ولد ا"}
{"hadithnumber": "2267", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم میرے پاس  ( مسدد اور ابن س"}
{"hadithnumber": "2268", "text": "اس سند سے بھی زہری نے اسی طریق سے اسی مفہوم کی روایت بیان کی ہے اس میں ہے کہ  ام المؤمنین عائشہ رضی"}
{"hadithnumber": "2269", "text": "زید بن ارقم رضی اللہ عنہ کہتے ہیں کہ  میں نبی اکرم صلی اللہ علیہ وسلم کے پاس بیٹھا ہوا تھا اتنے میں"}
{"hadithnumber": "2270", "text": "زید بن ارقم رضی اللہ عنہ کہتے ہیں کہ  علی رضی اللہ عنہ کے پاس یمن میں تین آدمی  ( ایک لڑکے کے لیے جھ"}
{"hadithnumber": "2271", "text": "خلیل یا ابن خلیل کہتے ہیں کہ  علی بن ابی طالب رضی اللہ عنہ کے پاس ایک عورت کا مقدمہ لایا گیا جس نے ت"}
{"hadithnumber": "2272", "text": "محمد بن مسلم بن شہاب کہتے ہیں کہ عروہ بن زبیر نے مجھے خبر دی ہے کہ  ام المؤمنین عائشہ رضی اللہ عنہا"}
{"hadithnumber": "2273", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  سعد بن ابی وقاص اور عبد بن زمعہ رضی اللہ عنہما دونوں"}
{"hadithnumber": "2274", "text": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  ایک شخص کھڑا ہوا اور کہنے لگا: اللہ کے رسول! فلاں میرا ب"}
{"hadithnumber": "2275", "text": "رباح کہتے ہیں کہ  میرے گھر والوں نے اپنی ایک رومی لونڈی سے میرا نکاح کر دیا، میں نے اس سے جماع کیا ت"}
{"hadithnumber": "2276", "text": "عبداللہ بن عمرو رضی اللہ عنہما سے روایت ہے کہ  ایک عورت نے رسول اللہ صلی اللہ علیہ وسلم سے عرض کیا:"}
{"hadithnumber": "2277", "text": "ہلال بن اسامہ سے روایت ہے کہ  ابومیمونہ سلمی جو اہل مدینہ کے مولی اور ایک سچے آدمی ہیں کا بیان ہے کہ"}
{"hadithnumber": "2278", "text": "علی رضی اللہ عنہ کہتے ہیں کہ  زید بن حارثہ رضی اللہ عنہ مکہ گئے تو حمزہ رضی اللہ عنہ کی صاحبزادی کو"}
{"hadithnumber": "2279", "text": "عبدالرحمٰن بن ابی لیلی سے یہی حدیث مروی ہے لیکن پوری نہیں ہے  اس میں ہے کہ:  آپ صلی اللہ علیہ وسلم ن"}
{"hadithnumber": "2280", "text": "علی رضی اللہ عنہ کہتے ہیں کہ  جب ہم مکہ سے نکلے تو ہمارے پیچھے پیچھے حمزہ کی لڑکی چچا چچا پکارتی آ گ"}
{"hadithnumber": "2281", "text": "اسماء بنت یزید بن سکن انصاریہ رضی اللہ عنہا سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم کے زمانے می"}
{"hadithnumber": "2282", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  اللہ تعالیٰ نے ارشاد فرمایا: «والمطلقات يتربصن بأنفسهن ث"}
{"hadithnumber": "2283", "text": "عمر رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے ام المؤمنین حفصہ رضی اللہ عنہا کو ط"}
{"hadithnumber": "2284", "text": "ابوسلمہ بن عبدالرحمٰن فاطمہ بنت قیس رضی اللہ عنہا کے بارے میں روایت کرتے ہیں کہ  ابوعمرو بن حفص رضی"}
{"hadithnumber": "2285", "text": "یحییٰ بن ابی کثیر کہتے ہیں کہ  ابوسلمہ بن عبدالرحمٰن نے مجھ سے بیان کیا کہ فاطمہ بنت قیس رضی اللہ عن"}
{"hadithnumber": "2286", "text": "ابوسلمہ بن عبدالرحمٰن بن عوف الزہری کہتے ہیں کہ  مجھ سے فاطمہ بنت قیس رضی اللہ عنہا نے بیان کیا کہ ا"}
{"hadithnumber": "2287", "text": "فاطمہ بنت قیس رضی اللہ عنہا کہتی ہیں کہ  میں قبیلہ بنی مخروم کے ایک شخص کے نکاح میں تھی اس نے مجھے ط"}
{"hadithnumber": "2288", "text": "فاطمہ بنت قیس رضی اللہ عنہا سے روایت ہے کہ  ان کے شوہر نے انہیں تین طلاق دے دی تو رسول اللہ صلی اللہ"}
{"hadithnumber": "2289", "text": "ابوسلمہ بن عبدالرحمٰن بن عوف الزہری کہتے ہیں کہ فاطمہ بنت قیس رضی اللہ عنہا نے انہیں خبر دی کہ  وہ ا"}
{"hadithnumber": "2290", "text": "عبیداللہ بن عبداللہ بن عتبہ کہتے ہیں کہ  مروان نے فاطمہ بنت قیس رضی اللہ عنہا کو بلوایا، اور ان سے پ"}
{"hadithnumber": "2291", "text": "ابواسحاق کہتے ہیں کہ  میں اسود کے ساتھ جامع مسجد میں تھا تو انہوں نے کہا: فاطمہ بنت قیس رضی اللہ عنہ"}
{"hadithnumber": "2292", "text": "عروہ کہتے ہیں کہ  ام المؤمنین عائشہ رضی اللہ عنہا فاطمہ بنت قیس رضی اللہ عنہا کی حدیث پر سخت نکیر کر"}
{"hadithnumber": "2293", "text": "عروہ بن زبیر سے روایت ہے کہ  ام المؤمنین عائشہ رضی اللہ عنہا سے فاطمہ  ( فاطمہ بنت قیس )  رضی اللہ ع"}
{"hadithnumber": "2294", "text": "سلیمان بن یسار سے بھی فاطمہ رضی اللہ عنہا کے گھر سے نکلنے کا قصہ مروی ہے  وہ کہتے ہیں: یہ بد خلقی کی"}
{"hadithnumber": "2295", "text": "حییٰ بن سعید قاسم بن محمد اور سلیمان بن یسار سے روایت کرتے ہیں کہ  انہوں نے ان دونوں کو ذکر کرتے ہوئ"}
{"hadithnumber": "2296", "text": "میمون بن مہران کہتے ہیں کہ میں مدینہ آیا تو سعید بن مسیب کے پاس گیا اور میں نے کہا کہ  فاطمہ بنت قیس"}
{"hadithnumber": "2297", "text": "جابر رضی اللہ عنہ کہتے ہیں کہ  میری خالہ کو تین طلاقیں دی گئیں، وہ اپنی کھجوریں توڑنے نکلیں، راستے م"}
{"hadithnumber": "2298", "text": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  اللہ کا فرمان «والذين يتوفون منكم ويذرون أزواجا وصية"}
{"hadithnumber": "2299", "text": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  اللہ کا فرمان «والذين يتوفون منكم ويذرون أزواجا وصية"}
{"hadithnumber": "2300", "text": "حمید بن نافع کہتے ہیں کہ  زینب بنت ابی سلمہ رضی اللہ عنہما نے انہیں ان تینوں حدیثوں کی خبر دی کہ جب"}
{"hadithnumber": "2301", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں  «غير إخراج»  ( سورة البقرہ: ۲۴۰ )  والی آیت جس میں عورت کو"}
{"hadithnumber": "2302", "text": "ام عطیہ رضی اللہ عنہا سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  عورت کسی پر بھی تین دن"}
{"hadithnumber": "2303", "text": "ام عطیہ رضی اللہ عنہا سے یہی حدیث مرفوعاً مروی ہے  لیکن ان دونوں راویوں کی حدیثوں میں پوری مشابہت نہ"}
{"hadithnumber": "2304", "text": "ام المؤمنین ام سلمہ رضی اللہ عنہا کہتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جس عورت کا شو"}
{"hadithnumber": "2305", "text": "ام حکیم بنت اسید اپنی والدہ سے روایت کرتی ہیں کہ  ان کے شوہر کا انتقال ہو گیا، ان کی آنکھوں میں تکلی"}
{"hadithnumber": "2306", "text": "ابن شہاب زہری سے روایت ہے کہ  مجھ سے عبیداللہ بن عبداللہ بن عتبہ نے بیان کیا کہ ان کے والد نے عمر بن"}
{"hadithnumber": "2307", "text": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  جو بھی چاہے مجھ سے اس بات پر لعان ۱؎ کر لے کہ چھوٹی سورۃ"}
{"hadithnumber": "2308", "text": "عمرو بن العاص رضی اللہ عنہ کہتے ہیں کہ   ( ہمارے نبی کریم صلی اللہ علیہ وسلم کی )  سنت کو ہم پر گڈمڈ"}
{"hadithnumber": "2309", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم سے اس شخص کے بارے میں مسئل"}
{"hadithnumber": "2310", "text": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  میں نے عرض کیا: اللہ کے رسول! کون سا گناہ سب سے بڑا ہے؟ آ"}
{"hadithnumber": "2311", "text": "ابوالزبیر کہتے ہیں کہ انہوں نے جابر بن عبداللہ رضی اللہ عنہما کو کہتے سنا کہ  ایک انصاری شخص کی مسکی"}
{"hadithnumber": "2312", "text": "سیلمان تیمی سے روایت ہے کہ  آیت کریمہ: «ومن يكرههن فإن الله من بعد إكراههن غفور رحيم»  ( النور: ۳۳ )"}
