{"hadithnumber": "1806", "text": "ہم سے عبداللہ بن یوسف نے بیان کیا، کہا کہ ہم کو امام مالک نے خبر دی، انہیں نافع نے کہ  عبداللہ بن عم"}
{"hadithnumber": "1807", "text": "ہم سے عبداللہ بن محمد بن اسماء نے بیان کیا، کہا ہم سے جویریہ نے نافع سے بیان کیا، انہیں عبیداللہ بن"}
{"hadithnumber": "1808", "text": "ہم سے موسیٰ بن اسماعیل نے بیان کیا، کہا ہم سے جویریہ نے بیان کیا  ان سے نافع نے کہ عبداللہ رضی اللہ"}
{"hadithnumber": "1809", "text": "ہم سے محمد نے بیان کیا، کہا کہ ہم سے یحییٰ بن صالح نے بیان کیا، ان سے معاویہ بن سلام نے بیان کیا، ان"}
{"hadithnumber": "1810", "text": "ہم سے احمد بن محمد نے بیان کیا، کہا ہم کو عبداللہ نے خبر دی، کہا کہ ہم کو یونس نے خبر دی، ان سے زہری"}
{"hadithnumber": "1811", "text": "ہم سے محمود نے بیان کیا، کہا ہم کو عبدالرزاق نے خبر دی، کہا کہ ہم کو معمر نے خبر دی، انہیں زہری نے،"}
{"hadithnumber": "1812", "text": "ہم سے محمد بن عبدالرحیم نے بیان کیا، انہوں نے کہا کہ ہم کو ابوبدر شجاع بن ولید نے خبر دی، انہوں نے ک"}
{"hadithnumber": "1813", "text": "ہم سے اسماعیل نے بیان کیا، انہوں نے کہا کہ مجھ سے امام مالک نے بیان کیا، ان سے نافع نے بیان کیا کہ"}
{"hadithnumber": "1814", "text": "ہم سے عبداللہ بن یوسف نے بیان کیا، انہوں نے کہا کہ ہم کو امام مالک نے خبر دی، انہیں حمید بن قیس نے،"}
{"hadithnumber": "1815", "text": "ہم سے ابونعیم نے بیان کیا، انہوں نے کہا کہ مجھ سے مجاہد نے بیان کیا، انہوں نے کہا کہ میں نے عبدالرحم"}
{"hadithnumber": "1816", "text": "ہم سے ابوالولید نے بیان کیا، کہا کہ ہم سے شعبہ نے بیان کیا، ان سے عبدالرحمٰن بن اصبہانی نے، ان سے عب"}
{"hadithnumber": "1817", "text": "ہم سے اسحاق نے بیان کیا، کہا ہم سے روح نے بیان کیا، ان سے شبل بن عباد نے بیان کیا، ان سے ابن ابی نجی"}
{"hadithnumber": "1818", "text": "اور محمد بن یوسف سے روایت ہے کہ ہم کو ورقاء نے بیان کیا، ان سے ابن ابی نجیح نے بیان کیا، ان سے مجاہد"}
{"hadithnumber": "1819", "text": "ہم سے سلیمان بن حرب نے بیان کیا، کہا ہم سے شعبہ نے بیان کیا، ان سے منصور نے، ان سے ابوحازم نے اور ان"}
{"hadithnumber": "1820", "text": "ہم سے محمد بن یوسف نے بیان کیا، کہا ہم سے سفیان ثوری نے بیان کیا، ان سے منصور نے، ان سے ابوحازم نے ا"}
