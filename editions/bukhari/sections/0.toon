hadiths[count]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}:
299,حَدَّثَنَا قَبِيصَةُ ، قَالَ : حَدَّثَنَا سُفْيَانُ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاهِيمَ ، عَنِ الْأ,,"Book 0, Hadith 0",299,,
300,وَكَانَ يَأْمُرُنِي فَأَتَّزِرُ فَيُبَاشِرُنِي وَأَنَا حَائِضٌ .,,"Book 0, Hadith 0",300,,
329,حَدَّثَنَا مُعَلَّى بْنُ أَسَدٍ ، قَالَ : حَدَّثَنَا وُهَيْبٌ ، عَنْ عَبْدِ اللَّهِ بْنِ طَاوُسٍ ، ع,,"Book 0, Hadith 0",329,,
395,حَدَّثَنَا الْحُمَيْدِيُّ ، قَالَ : حَدَّثَنَا سُفْيَانُ ، قَالَ : حَدَّثَنَا عَمْرُو بْنُ دِينَارٍ,,"Book 0, Hadith 0",395,,
408,حَدَّثَنَا مُوسَى بْنُ إِسْمَاعِيلَ ، قَالَ : أَخْبَرَنَا إِبْرَاهِيمُ بْنُ سَعْدٍ ، أَخْبَرَنَا ابْ,,"Book 0, Hadith 0",408,,
410,حَدَّثَنَا يَحْيَى بْنُ بُكَيْرٍ ، قَالَ : حَدَّثَنَا اللَّيْثُ ، عَنْ عُقَيْلٍ ، عَنِ ابْنِ شِهَابٍ,,"Book 0, Hadith 0",410,,
435,حَدَّثَنَا أَبُو الْيَمَانِ ، قَالَ : أَخْبَرَنَا شُعَيْبٌ ، عَنِ الزُّهْرِيِّ ، أَخْبَرَنِي عُبَيْد,,"Book 0, Hadith 0",435,,
454,حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ عَبْدِ اللَّهِ ، قَالَ : حَدَّثَنَا إِبْرَاهِيمُ بْنُ سَعْدٍ ، عَن,,"Book 0, Hadith 0",454,,
478,حَدَّثَنَا حَامِدُ بْنُ عُمَرَ ، عَنْ بِشْرٍ حَدَّثَنَا عَاصِمٌ ، حَدَّثَنَا وَاقِدٌ ، عَنِ أَبِيهِ,,"Book 0, Hadith 0",478,,
521,حَدَّثَنَا عَبْدُ اللَّهِ بْنُ مَسْلَمَةَ ، قَالَ : قَرَأْتُ عَلَى مَالِكٍ ، عَنِ ابْنِ شِهَابٍ ، أَ,,"Book 0, Hadith 0",521,,
533,حَدَّثَنَا أَيُّوبُ بْنُ سُلَيْمَانَ ، قَالَ : حَدَّثَنَا أَبُو بَكْرٍ ، عَنْ سُلَيْمَانَ ، قَالَ صَ,,"Book 0, Hadith 0",533,,
536,حَدَّثَنَا عَلِيُّ بْنُ عَبْدِ اللَّهِ ، قَالَ : حَدَّثَنَا سُفْيَانُ ، قَالَ : حَفِظْنَاهُ مِنْ الز,,"Book 0, Hadith 0",536,,
570,حَدَّثَنَا مَحْمُودٌ يَعْنِي ، قَالَ : أَخْبَرَنَا عَبْدُ الرَّزَّاقِ ، قَالَ : أَخْبَرَنِي ابْنُ جُ,,"Book 0, Hadith 0",570,,
582,حَدَّثَنَا مُسَدَّدٌ ، قَالَ : حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ ، عَنْ هِشَامٍ ، قَالَ : أَخْبَرَنِي,,"Book 0, Hadith 0",582,,
622,حَدَّثَنَا إِسْحَاقُ ، قَالَ : أَخْبَرَنَا أَبُو أُسَامَةَ ، قَالَ : عُبَيْدُ اللَّهِ حَدَّثَنَا ، ع,,"Book 0, Hadith 0",622,,
652,حَدَّثَنَا قُتَيْبَةُ ، عَنْ مَالِكٍ ، عَنْ سُمَيٍّ مَوْلَى أَبِي بَكْرِ ، عَنْ أَبِي صَالِحٍ السَّم,,"Book 0, Hadith 0",652,,
653,ثُمَّ قَالَ : الشُّهَدَاءُ خَمْسَةٌ الْمَطْعُونُ وَالْمَبْطُونُ وَالْغَرِيقُ وَصَاحِبُ الْهَدْمِ وَا,,"Book 0, Hadith 0",653,,
655,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ حَوْشَبٍ ، قَالَ : حَدَّثَنَا عَبْدُ الْوَهَّابِ ، قَا,,"Book 0, Hadith 0",655,,
720,حَدَّثَنَا أَبُو عَاصِمٍ ، عَنْ مَالِكٍ ، عَنْ سُمَيٍّ ، عَنْ أَبِي صَالِحٍ ، عَنْ أَبِي هُرَيْرَةَ,,"Book 0, Hadith 0",720,,
818,حَدَّثَنَا أَبُو النُّعْمَانِ ، قَالَ : حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ ، عَنْ أَيُّوبَ ، عَنْ أَبِي,,"Book 0, Hadith 0",818,,
832,حَدَّثَنَا أَبُو الْيَمَانِ ، قَالَ : أَخْبَرَنَا شُعَيْبٌ ، عَنِ الزُّهْرِيِّ ، قَالَ : أَخْبَرَنَا,,"Book 0, Hadith 0",832,,
839,حَدَّثَنَا عَبْدَانُ ، قَالَ : أَخْبَرَنَا عَبْدُ اللَّهِ ، قَالَ : أَخْبَرَنَا مَعْمَرٌ ، عَنِ الزّ,,"Book 0, Hadith 0",839,,
849,حَدَّثَنَا أَبُو الْوَلِيدِ ، حَدَّثَنَا إِبْرَاهِيمُ بْنُ سَعْدٍ ، حَدَّثَنَا الزُّهْرِيُّ ، عَنْ ه,,"Book 0, Hadith 0",849,,
896,حَدَّثَنَا مُسْلِمُ بْنُ إِبْرَاهِيمَ ، قَالَ : حَدَّثَنَا وُهَيْبٌ ، قَالَ : حَدَّثَنَا ابْنُ طَاوُ,,"Book 0, Hadith 0",896,,
949,حَدَّثَنَا أَحْمَدُ بْنُ عِيسَى ، قَالَ : حَدَّثَنَا ابْنُ وَهْبٍ ، قَالَ : أَخْبَرَنَا عَمْرٌو ، أَ,,"Book 0, Hadith 0",949,,
958,حَدَّثَنَا إِبْرَاهِيمُ بْنُ مُوسَى ، قَالَ : أَخْبَرَنَا هِشَامٌ ، أَنَّ ابْنَ جُرَيْجٍ أَخْبَرَهُم,,"Book 0, Hadith 0",958,,
959,قَالَ قَالَ وَأَخْبَرَنِي عَطَاءٌ ، أَنَّ ابْنَ عَبَّاسٍ أَرْسَلَ إِلَى ابْنِ الزُّبَيْرِ فِي أَوَّل,,"Book 0, Hadith 0",959,,
960,وأَخْبَرَنِي عَطَاءٌ ، عَنْ ابْنِ عَبَّاسٍ ، وَعَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ ، قَالَا :    لَمْ ي,,"Book 0, Hadith 0",960,,
987,حَدَّثَنَا يَحْيَى بْنُ بُكَيْرٍ ، قَالَ : حَدَّثَنَا اللَّيْثُ ، عَنْ عُقَيْلٍ ، عَنِ ابْنِ شِهَابٍ,,"Book 0, Hadith 0",987,,
1008,حَدَّثَنَا عَمْرُو بْنُ عَلِيٍّ ، قَالَ : حَدَّثَنَا أَبُو قُتَيْبَةَ ، قَالَ : حَدَّثَنَا عَبْدُ ال,,"Book 0, Hadith 0",1008,,
1049,حَدَّثَنَا عَبْدُ اللَّهِ بْنُ مَسْلَمَةَ ، عَنْ مَالِكٍ ، عَنْ يَحْيَى بْنِ سَعِيدٍ ، عَنْ عَمْرَةَ,,"Book 0, Hadith 0",1049,,
1055,حَدَّثَنَا إِسْمَاعِيلُ ، قَالَ : حَدَّثَنِي مَالِكٌ ، عَنْ يَحْيَى بْنِ سَعِيدٍ ، عَنْ عَمْرَةَ بِن,,"Book 0, Hadith 0",1055,,
1065,حَدَّثَنَا مُحَمَّدُ بْنُ مِهْرَانَ ، قَالَ : حَدَّثَنَا الْوَلِيدُ ، قَالَ : أَخْبَرَنَا ابْنُ نَمِ,,"Book 0, Hadith 0",1065,,
1091,حَدَّثَنَا أَبُو الْيَمَانِ ، قَالَ : أَخْبَرَنَا شُعَيْبٌ ، عَنْ الزُّهْرِيِّ ، قَالَ : أَخْبَرَنِي,,"Book 0, Hadith 0",1091,,
1121,"حَدَّثَنَا عَبْدُ اللَّهِ بْنُ مُحَمَّدٍ , قَالَ : حَدَّثَنَا هِشَامٌ , قَالَ : أَخْبَرَنَا مَعْمَرٌ",,"Book 0, Hadith 0",1121,,
1156,"حَدَّثَنَا أَبُو النُّعْمَانِ , حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ ، عَنْ أَيُّوبَ ، عَنْ نَافِعٍ ، عَن",,"Book 0, Hadith 0",1156,,
1157,فَقَصَّتْ حَفْصَةُ عَلَى النَّبِيِّ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ إِحْدَى رُؤْيَايَ ، فَقَالَ ال,,"Book 0, Hadith 0",1157,,
1172,"حَدَّثَنَا مُسَدَّدٌ , قَالَ : حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ ، عَنْ عُبَيْدِ اللَّهِ , قَالَ : أَخ",,"Book 0, Hadith 0",1172,,
1180,"حَدَّثَنَا سُلَيْمَانُ بْنُ حَرْبٍ , قَالَ : حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ ، عَنْ أَيُّوبَ ، عَنْ",,"Book 0, Hadith 0",1180,,
1186,فَزَعَمَ مَحْمُودٌ أَنَّهُ سَمِعَ عِتْبَانَ بْنَ مَالِكٍ الْأَنْصارِيَّ رَضِيَ اللَّهُ عَنْهُ ، وَكَ,,"Book 0, Hadith 0",1186,,
1191,حَدَّثَنَا يَعْقُوبُ بْنُ إِبْرَاهِيمَ هُوَ الدَّوْرَقِيُّ ، حَدَّثَنَا ابْنُ عُلَيَّةَ ، أَخْبَرَنَ,,"Book 0, Hadith 0",1191,,
1241,"حَدَّثَنَا بِشْرُ بْنُ مُحَمَّدٍ ، أَخْبَرَنَا عَبْدُ اللَّهِ , قَالَ : أَخْبَرَنِي مَعْمَرٌ وَيُونُ",,"Book 0, Hadith 0",1241,,
1249,حَدَّثَنَا مُسْلِمٌ ، حَدَّثَنَا شُعْبَةُ ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ الْأَصْبَهَانِيِّ ، ع,,"Book 0, Hadith 0",1249,,
1258,حَدَّثَنَا حَامِدُ بْنُ عُمَرَ ، حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ ، عَنْ أَيُّوبَ ، عَنْ مُحَمَّدٍ ،,,"Book 0, Hadith 0",1258,,
1281,حَدَّثَنَا إِسْمَاعِيلُ ، حَدَّثَنِي مَالِكٌ ، عَنْ عَبْدِ اللَّهِ بْنِ أَبِي بَكْرِ بْنِ مُحَمَّدِ,,"Book 0, Hadith 0",1281,,
1286,"حَدَّثَنَا عَبْدَانُ ، حَدَّثَنَا عَبْدُ اللَّهِ ، أَخْبَرَنَا ابْنُ جُرَيْجٍ , قَالَ : أَخْبَرَنِي",,"Book 0, Hadith 0",1286,,
1287,"فَقَالَ ابْنُ عَبَّاسٍ رَضِيَ اللَّهُ عَنْهُمَا : قَدْ كَانَ عُمَرُ رَضِيَ اللَّهُ عَنْهُ , يَقُولُ",,"Book 0, Hadith 0",1287,,
1312,"حَدَّثَنَا آدَمُ ، حَدَّثَنَا شُعْبَةُ ، حَدَّثَنَا عَمْرُو بْنُ مُرَّةَ , قَالَ : سَمِعْتُ عَبْدَ ا",,"Book 0, Hadith 0",1312,,
1323,"حدثنا ابو النعمان ، حدثنا جرير بن حازم , قال : سمعت نافعا , يقول : حدث ابن عمر ، ان ابا هريرة رضي ال",,"Book 0, Hadith 0",1323,,
1327,"حَدَّثَنَا يَحْيَى بْنُ بُكَيْرٍ , حَدَّثَنَا اللَّيْثُ ، عَنْ عُقَيْلٍ ، عَنِ ابْنِ شِهَابٍ ، عَنْ",,"Book 0, Hadith 0",1327,,
1347,حَدَّثَنَا مُحَمَّدُ بْنُ مُقَاتِلٍ ، أَخْبَرَنَا عَبْدُ اللَّهِ ، أَخْبَرَنَا لَيْثُ بْنُ سَعْدٍ ،,,"Book 0, Hadith 0",1347,,
1354,"حَدَّثَنَا عَبْدَانُ ، أَخْبَرَنَا عَبْدُ اللَّهِ ، عَنِ يُونُسَ ، عَنِ الزُّهْرِيِّ , قَالَ : أَخْب",,"Book 0, Hadith 0",1354,,
1363,حَدَّثَنَا مُسَدَّدٌ ، حَدَّثَنَا يَزِيدُ بْنُ زُرَيْعٍ ، حَدَّثَنَا خَالِدٌ ، عَنْ أَبِي قِلَابَةَ,,"Book 0, Hadith 0",1363,,
1399,حَدَّثَنَا أَبُو الْيَمَانِ الْحَكَمُ بْنُ نَافِعٍ ، أَخْبَرَنَا شُعَيْبُ بْنُ أَبِي حَمْزَةَ ، عَنِ,,"Book 0, Hadith 0",1399,,
1407,"حَدَّثَنَا عَيَّاشٌ , حَدَّثَنَا عَبْدُ الْأَعْلَى ، حَدَّثَنَا الْجُرَيْرِيُّ ، عَنْ أَبِي الْعَلَا",,"Book 0, Hadith 0",1407,,
1427,حَدَّثَنَا مُوسَى بْنُ إِسْمَاعِيلَ ، حَدَّثَنَا وُهَيْبٌ ، حَدَّثَنَا هِشَامٌ ، عَنْ أَبِيهِ ، عَنْ,,"Book 0, Hadith 0",1427,,
1456,حَدَّثَنَا أَبُو الْيَمَانِ ، أَخْبَرَنَا شُعَيْبٌ ، عَنِ الزُّهْرِيِّ . ح وَقَالَ اللَّيْثُ : حَدَّ,,"Book 0, Hadith 0",1456,,
1474,حَدَّثَنَا يَحْيَى بْنُ بُكَيْرٍ ، حَدَّثَنَا اللَّيْثُ ، عَنْ عُبَيْدِ اللَّهِ بْنِ أَبِي جَعْفَرٍ,,"Book 0, Hadith 0",1474,,
1481,حَدَّثَنَا سَهْلُ بْنُ بَكَّارٍ ، حَدَّثَنَا وُهَيْبٌ ، عَنْ عَمْرِو بْنِ يَحْيَى ، عَنْ عَبَّاسٍ ال,,"Book 0, Hadith 0",1481,,
1537,حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ ، حَدَّثَنَا سُفْيَانُ ، عَنْ مَنْصُورٍ ، عَنْ سَعِيدِ بْنِ جُبَيْ,,"Book 0, Hadith 0",1537,,
1543,حَدَّثَنَا عَبْدُ اللَّهِ بْنُ مُحَمَّدٍ ، حَدَّثَنَا وَهْبُ بْنُ جَرِيرٍ ، حَدَّثَنَا أَبِي ، عَنْ,,"Book 0, Hadith 0",1543,,
1614,حَدَّثَنَا أَصْبَغُ ، عَنِ ابْنِ وَهْبٍ ، أَخْبَرَنِي عَمْرٌو ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَ,,"Book 0, Hadith 0",1614,,
1623,حَدَّثَنَا قُتَيْبَةُ بْنُ سَعِيدٍ ، حَدَّثَنَا سُفْيَانُ ، عَنْ عَمْرٍو ،    سَأَلْنَا ابْنَ عُمَرَ,,"Book 0, Hadith 0",1623,,
1630,حَدَّثَنِي الْحَسَنُ بْنُ مُحَمَّدٍ هُوَ الزَّعْفَرَانِيُّ ، حَدَّثَنَا عَبِيدَةُ بْنُ حُمَيْدٍ ، حَ,,"Book 0, Hadith 0",1630,,
1641,حَدَّثَنَا أَحْمَدُ بْنُ عِيسَى ، حَدَّثَنَا ابْنُ وَهْبٍ ، قال : أَخْبَرَنِي عَمْرُو بْنُ الْحَارِث,,"Book 0, Hadith 0",1641,,
1645,حَدَّثَنَا عَلِيُّ بْنُ عَبْدِ اللَّهِ ، حَدَّثَنَا سُفْيَانُ ، عَنْ عَمْرِو بْنِ دِينَارٍ ، قال : س,,"Book 0, Hadith 0",1645,,
1669,حَدَّثَنَا قُتَيْبَةُ ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ جَعْفَرٍ ، عَنْ مُحَمَّدِ بْنِ أَبِي حَرْمَلَةَ,,"Book 0, Hadith 0",1669,,
1687,حَدَّثَنَا زُهَيْرُ بْنُ حَرْبٍ ، حَدَّثَنَا وَهْبُ بْنُ جَرِيرٍ ، حَدَّثَنَا أَبِي ، عَنْ يُونُسَ ا,,"Book 0, Hadith 0",1687,,
