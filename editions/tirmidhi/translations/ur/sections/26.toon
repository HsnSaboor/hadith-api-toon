{"hadithnumber": "1864", "text": "عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا: ”ہ"}
{"hadithnumber": "1865", "text": "جابر بن عبداللہ رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس چیز کی زیاد"}
{"hadithnumber": "1866", "text": "ام المؤمنین عائشہ رضی الله عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”ہر نشہ آور چی"}
{"hadithnumber": "1867", "text": "طاؤس سے روایت ہے کہ  ایک آدمی ابن عمر رضی الله عنہما کے پاس آیا اور پوچھا: کیا رسول اللہ صلی اللہ"}
{"hadithnumber": "1868", "text": "زاذان کہتے ہیں کہ  میں نے ابن عمر رضی الله عنہما سے ان برتنوں کے متعلق پوچھا جن سے آپ نے منع فرمایا"}
{"hadithnumber": "1869", "text": "بریدہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”میں نے تمہیں  ( اس سے پہلے"}
{"hadithnumber": "1870", "text": "جابر بن عبداللہ رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے  ( ان )  برتنوں  ( کے اس"}
{"hadithnumber": "1871", "text": "ام المؤمنین عائشہ رضی الله عنہا کہتی ہیں کہ  ہم لوگ رسول اللہ صلی اللہ علیہ وسلم کے لیے مشک میں نبیذ"}
{"hadithnumber": "1872", "text": "نعمان بن بشیر رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”گیہوں، جو، کھجور،"}
{"hadithnumber": "1873", "text": "اس سند سے  اسی جیسی حدیث بیان کی۔"}
{"hadithnumber": "1874", "text": "عمر رضی الله عنہ کہتے ہیں کہ  شراب گیہوں سے بنائی جاتی ہے، پھر انہوں نے پوری حدیث بیان کی۔ \\r\\n\\r\\nامام"}
{"hadithnumber": "1875", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”شراب ان دو درختوں: کھجور"}
{"hadithnumber": "1876", "text": "جابر بن عبداللہ رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے «گدر»  ( ادھ پکی )  کھجو"}
{"hadithnumber": "1877", "text": "ابو سعید خدری رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے «گدر»  ( ادھ پکی )  کھجور"}
{"hadithnumber": "1878", "text": "ابن ابی لیلیٰ بیان کرتے ہیں کہ  حذیفہ رضی الله عنہ نے ایک آدمی سے پانی طلب کیا تو اس نے انہیں چاندی"}
{"hadithnumber": "1879", "text": "انس رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے کھڑے ہو کر پینے سے منع فرمایا، پوچھا"}
{"hadithnumber": "1880", "text": "عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  ہم لوگ رسول اللہ صلی اللہ علیہ وسلم کے زمانہ میں چلتے ہوئ"}
{"hadithnumber": "1881", "text": "جارود بن معلی رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے کھڑے ہو کر پینے سے منع فرم"}
{"hadithnumber": "1882", "text": "عبداللہ بن عباس رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے کھڑے ہو کر زمزم کا پان"}
{"hadithnumber": "1883", "text": "عبداللہ بن عمرو رضی الله عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو کھڑے ہو کر اور بیٹھ"}
{"hadithnumber": "1884", "text": "انس بن مالک رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم برتن سے تین سانس میں پانی پیتے"}
{"hadithnumber": "1884", "text": "انس بن مالک رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم برتن سے تین سانس میں پانی پیتے"}
{"hadithnumber": "1885", "text": "عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اونٹ کی طرح ایک"}
{"hadithnumber": "1886", "text": "عبداللہ بن عباس رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم جب پیتے تھے تو دو سانس می"}
{"hadithnumber": "1887", "text": "ابو سعید خدری رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے پینے کی چیز میں پھونکنے سے"}
{"hadithnumber": "1888", "text": "عبداللہ بن عباس رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے برتن میں سانس لینے اور"}
{"hadithnumber": "1889", "text": "ابوقتادہ رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جب تم میں سے کوئی پان"}
{"hadithnumber": "1890", "text": "ابو سعید خدری رضی الله عنہ سے مرفوعاً روایت ہے کہ   ( رسول اللہ صلی اللہ علیہ وسلم نے )  مشکیزوں سے"}
{"hadithnumber": "1891", "text": "عبداللہ بن انیس رضی الله عنہ کہتے ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم کو دیکھا، آپ ایک لٹکی ہ"}
{"hadithnumber": "1892", "text": "کبشہ رضی الله عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم میرے گھر تشریف لائے، آپ نے ایک لٹکی ہوئ"}
{"hadithnumber": "1893", "text": "انس بن مالک رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم کی خدمت میں دودھ پیش کیا گیا جس"}
