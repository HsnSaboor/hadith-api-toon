hadiths[count]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}:
3172,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَهِشَامُ بْنُ عَمَّارٍ، قَالاَ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ زِيَادِ بْنِ عِلاَقَةَ، عَنْ أُسَامَةَ بْنِ شَرِيكٍ، قَالَ شَهِدْتُ الأَعْرَابَ يَسْأَلُونَ النَّبِيَّ ـ صلى الله عليه وسلم ـ أَعَلَيْنَا حَرَجٌ فِي كَذَا أَعَلَيْنَا حَرَجٌ فِي كَذَا فَقَالَ لَهُمْ ‏""‏ عِبَادَ اللَّهِ وَضَعَ اللَّهُ الْحَرَجَ إِلاَّ مَنِ اقْتَرَضَ مِنْ عِرْضِ أَخِيهِ شَيْئًا فَذَاكَ الَّذِي حَرَجٌ ‏""‏ ‏.‏ فَقَالُوا يَا رَسُولَ اللَّهِ هَلْ عَلَيْنَا جُنَاحٌ أَنْ نَتَدَاوَى قَالَ ‏""‏ تَدَاوَوْا عِبَادَ اللَّهِ فَإِنَّ اللَّهَ سُبْحَانَهُ لَمْ يَضَعْ دَاءً إِلاَّ وَضَعَ مَعَهُ شِفَاءً إِلاَّ الْهَرَمَ ‏""‏ ‏.‏ قَالُوا يَا رَسُولَ اللَّهِ مَا خَيْرُ مَا أُعْطِيَ الْعَبْدُ قَالَ ‏""‏ خُلُقٌ حَسَنٌ ‏""‏ ‏.‏",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۹۰۵، ومصباح الزجاجة:۱۰۹۸)، وقد أخرجہ: مسند احمد (۲/۱۰۸),3172,It was\nnarrated that Usamah bin Sharik said:,Chapters on Medicine
3173,"حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، أَنْبَأَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ الزُّهْرِيِّ، عَنِ ابْنِ أَبِي خِزَامَةَ، عَنْ أَبِي خِزَامَةَ، قَالَ سُئِلَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ أَرَأَيْتَ أَدْوِيَةً نَتَدَاوَى بِهَا وَرُقًى نَسْتَرْقِي بِهَا وَتُقًى نَتَّقِيهَا هَلْ تَرُدُّ مِنْ قَدَرِ اللَّهِ شَيْئًا قَالَ ‏ ‏ هِيَ مِنْ قَدَرِ اللَّهِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الأضاحي ۱۳ (۲۸۱۸)،(تحفة الأشراف:۶۱۱۱)، وقد أخرجہ: سنن النسائی/الضحایا ۴۰ (۴۴۴۸),,It was\nnarrated that Abu Khizamah said:,Chapters on Medicine
3174,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، حَدَّثَنَا سُفْيَانُ، عَنْ عَطَاءِ بْنِ السَّائِبِ، عَنْ أَبِي عَبْدِ الرَّحْمَنِ، عَنْ عَبْدِ اللَّهِ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ مَا أَنْزَلَ اللَّهُ دَاءً إِلاَّ أَنْزَلَ لَهُ دَوَاءً ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۷۰۲۷)، وقد أخرجہ: صحیح البخاری/البیوع ۵ (۲۰۵۷)، الصید ۲۱ (۵۵۰۷)، التوحید ۱۳ (۷۳۹۸)، صحیح مسلم/الأضاحي ۵ (۱۹۷۱)، سنن ابی داود/الأضاحي ۱۹ (۲۸۲۹)، سنن النسائی/الضحایا ۳۸ (۴۴۴۱)، موطا امام مالک/الذبائح ۱ (۱)، سنن الدارمی/الأضاحي ۱۴ (۲۰۱۹),,It was\nnarrated from ‘Abdullah that the Prophet (ﷺ) said:,Chapters on Medicine
3175,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَإِبْرَاهِيمُ بْنُ سَعِيدٍ الْجَوْهَرِيُّ، قَالاَ حَدَّثَنَا أَبُو أَحْمَدَ، عَنْ عُمَرَ بْنِ سَعِيدِ بْنِ أَبِي حُسَيْنٍ، حَدَّثَنَا عَطَاءٌ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَا أَنْزَلَ اللَّهُ دَاءً إِلاَّ أَنْزَلَ لَهُ شِفَاءً ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الضحایا ۱۷ (۲۸۲۲)، سنن النسائی/الصید ۲۵ (۴۳۱۸)، الضحایا ۱۹ (۴۴۰۴)،(تحفة الأشراف:۱۱۲۲۴)، وقد أخرجہ: مسند احمد (۲/۱۲،۷۶،۸۰),,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Medicine
3176,"حَدَّثَنَا الْحَسَنُ بْنُ عَلِيٍّ الْخَلاَّلُ، حَدَّثَنَا صَفْوَانُ بْنُ هُبَيْرَةَ، حَدَّثَنَا أَبُو مَكِينٍ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ عَادَ رَجُلاً فَقَالَ لَهُ ‏""‏ مَا تَشْتَهِي ‏""‏ ‏.‏ فَقَالَ أَشْتَهِي خُبْزَ بُرٍّ ‏.‏ فَقَالَ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏""‏ مَنْ كَانَ عِنْدَهُ خُبْزُ بُرٍّ فَلْيَبْعَثْ إِلَى أَخِيهِ ‏""‏ ‏.‏ ثُمَّ قَالَ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏""‏ إِذَا اشْتَهَى مَرِيضُ أَحَدِكُمْ شَيْئًا فَلْيُطْعِمْهُ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih Lighairihi; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن النسائی/الضحایا ۱۷ (۴۴۰۵)،۲۳ (۴۴۱۲)،(تحفة الأشراف:۳۷۱۸)، وقد أخرجہ: مسند احمد (۴/۱۸۴),3176,It was\nnarrated from Ibn ‘Abbas that the Prophet (ﷺ) visited a man\n(who\nwas sick) and said to him:,Chapters on Medicine
3177,"حَدَّثَنَا سُفْيَانُ بْنُ وَكِيعٍ، حَدَّثَنَا أَبُو يَحْيَى الْحِمَّانِيُّ، عَنِ الأَعْمَشِ، عَنْ يَزِيدَ الرَّقَاشِيِّ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ دَخَلَ النَّبِيُّ ـ صلى الله عليه وسلم ـ عَلَى مَرِيضٍ يَعُودُهُ قَالَ ‏ ‏ أَتَشْتَهِي شَيْئًا أَتَشْتَهِي كَعْكًا ‏""""‏ ‏.‏ قَالَ نَعَمْ ‏.‏ فَطَلَبُوا لَهُ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Hasan,takhreej: «سنن ابی داود/الضحایا ۱۵ (۲۸۲۴)، سنن النسائی/الذبائح ۲۰ (۴۳۰۹)، الضحایا ۱۸ (۴۴۰۶)،(تحفة الأشراف:۹۸۷۵)، وقد أخرجہ: مسند احمد (۴/۲۵۶،۲۵۸),,It was\nnarrated that Anas bin Malik said:,Chapters on Medicine
3178,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يُونُسُ بْنُ مُحَمَّدٍ، حَدَّثَنَا فُلَيْحُ بْنُ سُلَيْمَانَ، عَنْ أَيُّوبَ بْنِ عَبْدِ الرَّحْمَنِ بْنِ عَبْدِ اللَّهِ بْنِ أَبِي صَعْصَعَةَ، ح وَحَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا أَبُو عَامِرٍ، وَأَبُو دَاوُدَ قَالاَ حَدَّثَنَا فُلَيْحُ بْنُ سُلَيْمَانَ، عَنْ أَيُّوبَ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ يَعْقُوبَ بْنِ أَبِي يَعْقُوبَ، عَنْ أُمِّ الْمُنْذِرِ بِنْتِ قَيْسٍ الأَنْصَارِيَّةِ، قَالَتْ دَخَلَ عَلَيْنَا رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ وَمَعَهُ عَلِيُّ بْنُ أَبِي طَالِبٍ وَعَلِيٌّ نَاقِهٌ مِنْ مَرَضٍ وَلَنَا دَوَالِي مُعَلَّقَةٌ وَكَانَ النَّبِيُّ ـ صلى الله عليه وسلم ـ يَأْكُلُ مِنْهَا فَتَنَاوَلَ عَلِيٌّ لِيَأْكُلَ فَقَالَ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏""‏ مَهْ يَا عَلِيُّ إِنَّكَ نَاقِهٌ ‏""‏ ‏.‏ قَالَتْ فَصَنَعْتُ لِلنَّبِيِّ ـ صلى الله عليه وسلم ـ سِلْقًا وَشَعِيرًا فَقَالَ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏""‏ يَا عَلِيُّ مِنْ هَذَا فَأَصِبْ فَإِنَّهُ أَنْفَعُ لَكَ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الشرکة ۳ (۲۴۸۸)،۱۶ (۲۵۰۷)، الجہاد ۱۹۱ (۳۰۷۵)، الذبائح ۱۵ (۵۴۹۸)،۱۸ (۵۵۰۳)،۲۰ (۵۵۰۶)،۲۳ (۵۵۰۹)،۳۶ (۵۵۴۳)،۳۷ (۵۵۴۴)، صحیح مسلم/الاضاحی ۴ (۱۹۶۸)، سنن ابی داود/الأضاحي ۱۵ (۲۸۲۱)، سنن الترمذی/الصید ۱۹ (۱۴۹۲)، سنن النسائی/الذبائح ۱۷ (۴۳۰۲)، الضحایا ۱۵ (۴۳۹۶)،۲۶ (۴۴۱۴)،(تحفة الأشراف:۳۵۶۱)، وقد أخرجہ: مسند احمد (۳/۴۶۳،۴۶۴،۴/۱۴۰،۱۴۲),3178,It was\nnarrated that Umm Mundhir bint Qais Ansariyyah said:,Chapters on Medicine
3179,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ عَبْدِ الْوَهَّابِ، حَدَّثَنَا مُوسَى بْنُ إِسْمَاعِيلَ، حَدَّثَنَا ابْنُ الْمُبَارَكِ، عَنْ عَبْدِ الْحَمِيدِ بْنِ صَيْفِيٍّ، - مِنْ وَلَدِ صُهَيْبٍ - عَنْ أَبِيهِ، عَنْ جَدِّهِ، صُهَيْبٍ قَالَ قَدِمْتُ عَلَى النَّبِيِّ ـ صلى الله عليه وسلم ـ وَبَيْنَ يَدَيْهِ خُبْزٌ وَتَمْرٌ فَقَالَ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏""‏ ادْنُ فَكُلْ ‏""‏ ‏.‏ فَأَخَذْتُ آكُلُ مِنَ التَّمْرِ فَقَالَ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏""‏ تَأْكُلُ تَمْرًا وَبِكَ رَمَدٌ ‏""‏ ‏.‏ قَالَ فَقُلْتُ إِنِّي أَمْضُغُ مِنْ نَاحِيَةٍ أُخْرَى ‏.‏ فَتَبَسَّمَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن ابی داود/الطہارة ۷۳ (۱۸۵)،(تحفة الأشراف:۴۱۵۸),3179,It was\nnarrated that Suhaib said:,Chapters on Medicine
3180,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا بَكْرُ بْنُ يُونُسَ بْنِ بُكَيْرٍ، عَنْ مُوسَى بْنِ عَلِيِّ بْنِ رَبَاحٍ، عَنْ أَبِيهِ، عَنْ عُقْبَةَ بْنِ عَامِرٍ الْجُهَنِيِّ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لاَ تُكْرِهُوا مَرْضَاكُمْ عَلَى الطَّعَامِ وَالشَّرَابِ فَإِنَّ اللَّهَ يُطْعِمُهُمْ وَيَسْقِيهِمْ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۳۴۶۲)، وقد أخرجہ: صحیح مسلم/الأشربة ۲۰ (۲۰۳۸)، سنن الترمذی/الزہد ۳۹ (۲۳۶۹),,It was\nnarrated from ‘Uqbah bin ‘Amir Al-Juhani that the Messenger of\nAllah (ﷺ) said:,Chapters on Medicine
3181,"حَدَّثَنَا إِبْرَاهِيمُ بْنُ سَعِيدٍ الْجَوْهَرِيُّ، حَدَّثَنَا إِسْمَاعِيلُ ابْنُ عُلَيَّةَ، حَدَّثَنَا مُحَمَّدُ بْنُ السَّائِبِ بْنِ بَرَكَةَ، عَنْ أُمِّهِ، عَنْ عَائِشَةَ، قَالَتْ كَانَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ إِذَا أَخَذَ أَهْلَهُ الْوَعْكُ أَمَرَ بِالْحَسَاءِ ‏.‏ قَالَتْ وَكَانَ يَقُولُ ‏ ‏ إِنَّهُ لَيَرْتُو فُؤَادَ الْحَزِينِ وَيَسْرُو عَنْ فُؤَادِ السَّقِيمِ كَمَا تَسْرُو إِحْدَاكُنَّ الْوَسَخَ عَنْ وَجْهِهَا بِالْمَاءِ ‏""""‏ ‏.‏""",Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۶۲۷، ومصباح الزجاجة:۱۱۰۰),,It was\nnarrated that ‘Aishah said:,Chapters on Medicine
3182,"حَدَّثَنَا عَلِيُّ بْنُ أَبِي الْخَصِيبِ، حَدَّثَنَا وَكِيعٌ، عَنْ أَيْمَنَ بْنِ نَابِلٍ، عَنِ امْرَأَةٍ، مِنْ قُرَيْشٍ يُقَالَ لَهَا كَلْثَمُ عَنْ عَائِشَةَ، قَالَتْ قَالَ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏ ‏ عَلَيْكُمْ بِالْبَغِيضِ النَّافِعِ التَّلْبِينَةِ ‏""""‏ ‏.‏ يَعْنِي الْحَسَاءَ ‏.‏ قَالَتْ وَكَانَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ إِذَا اشْتَكَى أَحَدٌ مِنْ أَهْلِهِ لَمْ تَزَلِ الْبُرْمَةُ عَلَى النَّارِ حَتَّى يَنْتَهِيَ أَحَدُ طَرَفَيْهِ ‏.‏ يَعْنِي يَبْرَأُ أَوْ يَمُوتُ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الوکالة ۴ (۲۳۰۴)، الذبائح ۱۸ (۵۵۰۱،۵۵۰۲)،۱۹ (۵۵۰۴،۵۵۰۵)،(تحفة الأشراف:۱۱۱۳۴)، وقد أخرجہ: مسند احمد (۲/۷۶،۳/۴۵۴،۶/۳۸۶),,It was\nnarrated from ‘Aishah that the Prophet (ﷺ) said:,Chapters on Medicine
3183,"حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، وَمُحَمَّدُ بْنُ الْحَارِثِ الْمِصْرِيَّانِ، قَالاَ حَدَّثَنَا اللَّيْثُ بْنُ سَعْدٍ، عَنْ عُقَيْلٍ، عَنِ ابْنِ شِهَابٍ، أَخْبَرَنِي أَبُو سَلَمَةَ بْنُ عَبْدِ الرَّحْمَنِ، وَسَعِيدُ بْنُ الْمُسَيَّبِ، أَنَّ أَبَا هُرَيْرَةَ، أَخْبَرَهُمَا أَنَّهُ، سَمِعَ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ إِنَّ فِي الْحَبَّةِ السَّوْدَاءِ شِفَاءً مِنْ كُلِّ دَاءٍ إِلاَّ السَّامَ ‏""""‏ ‏.‏ وَالسَّامُ الْمَوْتُ ‏.‏ وَالْحَبَّةُ السَّوْدَاءُ الشُّونِيزُ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «انظر حدیث رقم:(۳۱۳۷)،(تحفة الأشراف:۳۵۱۶),,Abu\nHurairah narrated that he heard the Messenger of Allah (ﷺ) say:,Chapters on Medicine
3184,"حَدَّثَنَا أَبُو سَلَمَةَ، يَحْيَى بْنُ خَلَفٍ حَدَّثَنَا أَبُو عَاصِمٍ، عَنْ عُثْمَانَ بْنِ عَبْدِ الْمَلِكِ، قَالَ سَمِعْتُ سَالِمَ بْنَ عَبْدِ اللَّهِ، يُحَدِّثُ عَنْ أَبِيهِ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ عَلَيْكُمْ بِهَذِهِ الْحَبَّةِ السَّوْدَاءِ فَإِنَّ فِيهَا شِفَاءً مِنْ كُلِّ دَاءٍ إِلاَّ السَّامَ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الأضاحي ۱۶ (۲۸۲۵)، سنن الترمذی/الصید ۱۳ (۱۴۸۱)، سنن النسائی/الضحایا ۲۴ (۴۴۱۳)،(تحفة الأشراف:۱۵۶۹۴)، وقد أخرجہ: مسند احمد (۴/۳۳۴)، سنن الدارمی/الأضاحي ۱۲ (۲۰۱۵),,It was\nnarrated that ‘Uthman bin ‘Abdul-Malik said:,Chapters on Medicine
3185,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عُبَيْدُ اللَّهِ، أَنْبَأَنَا إِسْرَائِيلُ، عَنْ مَنْصُورٍ، عَنْ خَالِدِ بْنِ سَعْدٍ، قَالَ خَرَجْنَا وَمَعَنَا غَالِبُ بْنُ أَبْجَرَ فَمَرِضَ فِي الطَّرِيقِ فَقَدِمْنَا الْمَدِينَةَ وَهُوَ مَرِيضٌ فَعَادَهُ ابْنُ أَبِي عَتِيقٍ وَقَالَ لَنَا عَلَيْكُمْ بِهَذِهِ الْحَبَّةِ السَّوْدَاءِ فَخُذُوا مِنْهَا خَمْسًا أَوْ سَبْعًا فَاسْحَقُوهَا ثُمَّ اقْطُرُوهَا فِي أَنْفِهِ بِقَطَرَاتِ زَيْتٍ فِي هَذَا الْجَانِبِ وَفِي هَذَا الْجَانِبِ فَإِنَّ عَائِشَةَ حَدَّثَتْهُمْ أَنَّهَا سَمِعَتْ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏""‏ إِنَّ هَذِهِ الْحَبَّةَ السَّوْدَاءَ شِفَاءٌ مِنْ كُلِّ دَاءٍ إِلاَّ أَنْ يَكُونَ السَّامُ ‏""‏ ‏.‏ قُلْتُ وَمَا السَّامُ قَالَ ‏""‏ الْمَوْتُ ‏""‏ ‏.‏",Al-Albani: Very Daif Isnaad; Muhammad Fouad Abd al-Baqi: Very Daif Isnaad; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۲۹۴، ومصباح الزجاجة:۱۱۰۱),3185,It was\nnarrated that Khalid bin Sa’d said:,Chapters on Medicine
3186,"حَدَّثَنَا مَحْمُودُ بْنُ خِدَاشٍ، حَدَّثَنَا سَعِيدُ بْنُ زَكَرِيَّاءَ الْقُرَشِيُّ، حَدَّثَنَا الزُّبَيْرُ بْنُ سَعِيدٍ الْهَاشِمِيُّ، عَنْ عَبْدِ الْحَمِيدِ بْنِ سَالِمٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ لَعِقَ الْعَسَلَ ثَلاَثَ غَدَوَاتٍ كُلَّ شَهْرٍ لَمْ يُصِبْهُ عَظِيمٌ مِنَ الْبَلاَءِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الصید ۲۵ (۵۵۱۳)، صحیح مسلم/الصید ۱۲ (۱۹۵۶)، سنن ابی داود/الأضاحي ۱۲ (۲۸۱۶)، سنن النسائی/الضحایا ۴۰ (۴۴۴۴)،(تحفة الأشراف:۱۶۴۰)، وقد أخرجہ: مسند احمد (۳/۱۱۷،۱۷۱،۱۹۱),,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Medicine
3187,"حَدَّثَنَا أَبُو بِشْرٍ، بَكْرُ بْنُ خَلَفٍ حَدَّثَنَا عُمَرُ بْنُ سَهْلٍ، حَدَّثَنَا أَبُو حَمْزَةَ الْعَطَّارُ، عَنِ الْحَسَنِ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، قَالَ أُهْدِيَ لِلنَّبِيِّ ـ صلى الله عليه وسلم ـ عَسَلٌ فَقَسَمَ بَيْنَنَا لُعْقَةً لُعْقَةً فَأَخَذْتُ لُعْقَتِي ثُمَّ قُلْتُ يَا رَسُولَ اللَّهِ أَزْدَادُ أُخْرَى قَالَ ‏ ‏ نَعَمْ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن الترمذی/الصید ۹ (۱۴۷۵)،(تحفة الأشراف:۶۱۱۲)، وقد أخرجہ: صحیح مسلم/الصید ۱۲ (۱۹۵۷)، سنن النسائی/الضحایا ۴۰ (۴۴۴۸)، مسند احمد (۱/۲۱۶،۲۷۳،۲۸۰،۲۸۵،۲۹۷،۳۴۰،۳۴۵),,It was\nnarrated that Jabir bin ‘Abdullah said:,Chapters on Medicine
3188,"حَدَّثَنَا عَلِيُّ بْنُ سَلَمَةَ، حَدَّثَنَا زَيْدُ بْنُ الْحُبَابِ، حَدَّثَنَا سُفْيَانُ، عَنْ أَبِي إِسْحَاقَ، عَنْ أَبِي الأَحْوَصِ، عَنْ عَبْدِ اللَّهِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ عَلَيْكُمْ بِالشِّفَاءَيْنِ الْعَسَلِ وَالْقُرْآنِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الصید ۱۲ (۱۹۵۹)،(تحفة الأشراف:۲۸۳۱)، وقد أخرجہ: مسند احمد (۳/۳۱۸،۳۳۹،۵/۴۲۲،۴۲۳),,It was\nnarrated from ‘Abdullah that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Medicine
3189,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ، حَدَّثَنَا الأَعْمَشُ، عَنْ جَعْفَرِ بْنِ إِيَاسٍ، عَنْ شَهْرِ بْنِ حَوْشَبٍ، عَنْ أَبِي سَعِيدٍ، وَجَابِرٍ، قَالاَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ الْكَمْأَةُ مِنَ الْمَنِّ وَمَاؤُهَا شِفَاءٌ لِلْعَيْنِ وَالْعَجْوَةُ مِنَ الْجَنَّةِ وَهِي شِفَاءٌ مِنَ الْجَنَّةَ ‏""""‏ ‏.‏ حَدَّثَنَا عَلِيُّ بْنُ مَيْمُونٍ، وَمُحَمَّدُ بْنُ عَبْدِ اللَّهِ الرَّقِّيَّانِ، قَالاَ حَدَّثَنَا سَعِيدُ بْنُ مَسْلَمَةَ بْنِ هِشَامٍ، عَنِ الأَعْمَشِ، عَنْ جَعْفَرِ بْنِ إِيَاسٍ، عَنْ أَبِي نَضْرَةَ، عَنْ أَبِي سَعِيدٍ الْخُدْرِيِّ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ مِثْلَهُ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الجہاد ۵۲ (۳۷۸۵)، سنن الترمذی/الأطعمة ۲۴ (۱۸۲۴)،(تحفة الأشراف:۷۳۸۷)، وقد أخرجہ: مسند احمد (۱/۲۱۹،۲۲۶،۲۴۱،۲۵۳،۳۲۱),,It was\nnarrated from Abu Sa`eed and Jabir that the Messenger of Allah\n(ﷺ) said:,Chapters on Medicine
3190,"حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، أَنْبَأَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عَبْدِ الْمَلِكِ بْنِ عُمَيْرٍ، سَمِعَ عَمْرَو بْنَ حُرَيْثٍ، يَقُولُ سَمِعْتُ سَعِيدَ بْنَ زَيْدِ بْنِ عَمْرِو بْنِ نُفَيْلٍ، يُحَدِّثُ عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ أَنَّ ‏ ‏ الْكَمْأَةُ مِنَ الْمَنِّ الَّذِي أَنْزَلَ اللَّهُ عَلَى بَنِي إِسْرَائِيلَ وَمَاؤُهَا شِفَاءٌ لِلْعَيْنِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الصید ۲۴ (۵۵۱۰ و ۵۵۱۱)،۲۷ (۵۵۱۹)، صحیح مسلم/الصید ۶ (۱۹۴۲)، سنن النسائی/الضحایا ۲۲ (۴۴۱۱)،۳۲ (۴۴۲۵،۴۴۲۶)،(تحفة الأشراف:۱۵۷۴۶)، وقد أخرجہ: مسند احمد (۶/۳۴۵،۳۴۶،۳۵۳)، سنن الدارمی/الأضاحي ۲۲ (۲۰۳۵),,‘Amr\nbin Huraith said:,Chapters on Medicine
3191,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا أَبُو عَبْدِ الصَّمَدِ، حَدَّثَنَا مَطَرٌ الْوَرَّاقُ، عَنْ شَهْرِ بْنِ حَوْشَبٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ كُنَّا نَتَحَدَّثُ عِنْدَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ فَذَكَرْنَا الْكَمْأَةَ فَقَالُوا هِيَ جُدَرِيُّ الأَرْضِ ‏.‏ فَنُمِيَ الْحَدِيثُ إِلَى رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ فَقَالَ ‏ ‏ الْكَمْأَةُ مِنَ الْمَنِّ وَالْعَجْوَةُ مِنَ الْجَنَّةِ وَهِيَ شِفَاءٌ مِنَ السَّمِّ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الصید ۶ (۱۹۴۱)، سنن النسائی/الذبائح ۲۹ (۴۳۳۲)،(تحفة الأشراف:۲۸۱۰)، وقد أخرجہ: صحیح البخاری/المغازي ۳۸ (۴۲۱۹)، الصید ۲۷ (۵۵۲۰)،۲۸ (۵۵۲۴)، سنن ابی داود/الأطعمة ۲۶ (۳۷۸۸)،۳۴ (۳۸۰۸)، سنن الترمذی/الأطعمة ۵ (۱۷۹۳)، مسند احمد (۳/۳۲۲،۳۵۶،۳۶۱،۳۶۲،۳۸۵)، سنن الدارمی/الأضاحي ۲۲ (۲۰۳۶),,It was\nnarrated that Abu Hurairah said:,Chapters on Medicine
3192,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، حَدَّثَنَا الْمُشْمَعِلُّ بْنُ إِيَاسٍ الْمُزَنِيُّ، حَدَّثَنِي عَمْرُو بْنُ سُلَيْمٍ، قَالَ سَمِعْتُ رَافِعَ بْنَ عَمْرٍو الْمُزَنِيَّ، قَالَ سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ الْعَجْوَةُ وَالصَّخْرَةُ مِنَ الْجَنَّةِ ‏""""‏ ‏.‏ قَالَ عَبْدُ الرَّحْمَنِ حَفِظْتُ الصَّخْرَةَ مِنْ فِيهِ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/المغازي ۳۸ (۴۲۲۰)، الصید ۲۸ (۱۹۳۷)، صحیح مسلم/الصید ۵ (۴۳۷)، سنن النسائی/الصید ۳۱ (۴۳۴۴)،(تحفة الأشراف:۵۱۶۴)، وقد أخرجہ: مسند احمد (۴/۳۵۵،۳۵۶،۳۵۷،۳۸۱),,Rafi’\nbin ‘Amr Al-Muzani said:,Chapters on Medicine
3193,"حَدَّثَنَا إِبْرَاهِيمُ بْنُ مُحَمَّدِ بْنِ يُوسُفَ بْنِ سَرْجٍ الْفِرْيَابِيُّ، حَدَّثَنَا عَمْرُو بْنُ بَكْرٍ السَّكْسَكِيُّ، حَدَّثَنَا إِبْرَاهِيمُ بْنُ أَبِي عَبْلَةَ، قَالَ سَمِعْتُ أَبَا أُبَىٍّ ابْنَ أُمِّ حَرَامٍ، وَكَانَ، قَدْ صَلَّى مَعَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ الْقِبْلَتَيْنِ يَقُولُ سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏""‏ عَلَيْكُمْ بِالسَّنَى وَالسَّنُّوتِ فَإِنَّ فِيهِمَا شِفَاءً مِنْ كُلِّ دَاءٍ إِلاَّ السَّامَ ‏.‏ قِيلَ يَا رَسُولَ اللَّهِ وَمَا السَّامُ قَالَ ‏""‏ الْمَوْتُ ‏""‏ ‏.‏ قَالَ عَمْرٌو قَالَ ابْنُ أَبِي عَبْلَةَ السَّنُّوتُ الشِّبِتُّ ‏.‏ وَقَالَ آخَرُونَ بَلْ هُوَ الْعَسَلُ الَّذِي يَكُونُ فِي زِقَاقِ السَّمْنِ وَهُوَ قَوْلُ الشَّاعِرِ هُمُ السَّمْنُ بِالسَّنُّوتِ لاَ أَلْسَ فِيهِمُ وَهُمْ يَمْنَعُونَ جَارَهُمْ أَنْ يُقَرَّدَا",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۵۵۴، ومصباح الزجاجة:۱۱۰۲)، وقد أخرجہ: مسند احمد (۴/۸۹،۱۳۲),3193,Ibrahim\nbin Abu ‘Ablah said:,Chapters on Medicine
3194,"حَدَّثَنَا جَعْفَرُ بْنُ مُسَافِرٍ، حَدَّثَنَا السَّرِيُّ بْنُ مِسْكِينٍ، حَدَّثَنَا ذُؤَادُ بْنُ عُلْبَةَ، عَنْ لَيْثٍ، عَنْ مُجَاهِدٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ هَجَّرَ النَّبِيُّ ـ صلى الله عليه وسلم ـ فَهَجَّرْتُ فَصَلَّيْتُ ثُمَّ جَلَسْتُ فَالْتَفَتَ إِلَىَّ النَّبِيُّ ـ صلى الله عليه وسلم ـ فَقَالَ ‏""‏ اشِكَمَتْ دَرْدْ ‏""‏ ‏.‏ قُلْتُ نَعَمْ يَا رَسُولَ اللَّهِ ‏.‏ قَالَ ‏""‏ قُمْ فَصَلِّ فَإِنَّ فِي الصَّلاَةِ شِفَاءً ‏""‏ ‏.‏ قَالَ أَبُو الْحَسَنِ الْقَطَّانُ حَدَّثَنَا إِبْرَاهِيمُ بْنُ نَصْرٍ، حَدَّثَنَا أَبُو سَلَمَةَ، حَدَّثَنَا ذُؤَادُ بْنُ عُلْبَةَ، فَذَكَرَ نَحْوَهُ وَقَالَ فِيهِ اشِكَمَتْ دَرْدْ ‏.‏ يَعْنِي تَشْتَكِي بَطْنَكَ بِالْفَارِسِيَّةِ ‏.‏ قَالَ أَبُو عَبْدِ اللَّهِ حَدَّثَ بِهِ رَجُلٌ لأَهْلِهِ فَاسْتَعْدَوْا عَلَيْهِ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/المغازي ۳۸ (۴۲۲۶)، الصید ۲۸ (۵۵۲۵،۵۵۲۶)، صحیح مسلم/الصید ۵ (۱۹۳۸)، سنن النسائی/الصید والذبائح ۳۱ (۴۳۴۳)،(تحفة الأشراف:۱۷۷۰)، وقد أخرجہ: مسند احمد (۴/۲۹۷),,It was\nnarrated that Abu Hurairah said:,Chapters on Medicine
3195,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا وَكِيعٌ، عَنْ يُونُسَ بْنِ أَبِي إِسْحَاقَ، عَنْ مُجَاهِدٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنِ الدَّوَاءِ الْخَبِيثِ ‏.‏ يَعْنِي السُّمَّ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/المظالم ۳۲ (۲۴۷۷)، صحیح مسلم/الجہاد ۴۳ (۱۸۰۲)،(تحفة الأشراف:۴۵۴۲)، وقد أخرجہ: مسند احمد (۴/۴۸،۵۰),3195,It was\nnarrated that Abu Hurairah said:,Chapters on Medicine
3196,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا وَكِيعٌ، عَنِ الأَعْمَشِ، عَنْ أَبِي صَالِحٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ شَرِبَ سُمًّا فَقَتَلَ نَفْسَهُ فَهُوَ يَتَحَسَّاهُ فِي نَارِ جَهَنَّمَ خَالِدًا مُخَلَّدًا فِيهَا أَبَدًا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الجہاد ۱۳۰ (۲۹۹۱)، المغازي ۳۸ (۴۱۹۸)، الذبائح ۲۸ (۵۵۲۸)، سنن النسائی/الطہارة ۵۵ (۶۹)، الصیدوالذبائح ۳۱ (۴۳۴۵)،(تحفة الأشراف:۱۴۵۷)، وقد أخرجہ: صحیح مسلم/الصید ۶ (۱۹۴۱)، مسند احمد (۳/۱۱۱،۱۲۱،۱۶۴)، سنن الدارمی/الأضاحي ۲۱ (۲۰۳۴),,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Medicine
3197,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو أُسَامَةَ، عَنْ عَبْدِ الْحَمِيدِ بْنِ جَعْفَرٍ، عَنْ زُرْعَةَ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ مَوْلًى، لِمَعْمَرٍ التَّيْمِيِّ عَنْ مَعْمَرٍ التَّيْمِيِّ، عَنْ أَسْمَاءَ بِنْتِ عُمَيْسٍ، قَالَتْ قَالَ لِي رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏""‏ بِمَاذَا كُنْتِ تَسْتَمْشِينَ ‏""‏ ‏.‏ قُلْتُ بِالشُّبْرُمِ قَالَ ‏""‏ حَارٌّ جَارٌّ ‏""‏ ‏.‏ ثُمَّ اسْتَمْشَيْتُ بِالسَّنَى ‏.‏ فَقَالَ ‏""‏ لَوْ كَانَ شَىْءٌ يَشْفِي مِنَ الْمَوْتِ كَانَ السَّنَى وَالسَّنَى شِفَاءٌ مِنَ الْمَوْتِ ‏""‏ ‏.‏",Al-Albani: Sahih Isnaad; Muhammad Fouad Abd al-Baqi: Sahih Isnaad; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن النسائی/الصید ۲۹ (۴۳۳۵)،(تحفة الأشراف:۲۴۳۰),3197,It was\nnarrated that Asma’ bint ‘Umais said:,Chapters on Medicine
3198,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَمُحَمَّدُ بْنُ الصَّبَّاحِ، قَالاَ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ الزُّهْرِيِّ، عَنْ عُبَيْدِ اللَّهِ بْنِ عَبْدِ اللَّهِ، عَنْ أُمِّ قَيْسٍ بِنْتِ مِحْصَنٍ، قَالَتْ دَخَلْتُ بِابْنٍ لِي عَلَى النَّبِيِّ ـ صلى الله عليه وسلم ـ وَقَدْ أَعْلَقْتُ عَلَيْهِ مِنَ الْعُذْرَةِ فَقَالَ ‏ ‏ عَلاَمَ تَدْغَرْنَ أَوْلاَدَكُنَّ بِهَذَا الْعِلاَقِ عَلَيْكُمْ بِهَذَا الْعُودِ الْهِنْدِيِّ فَإِنَّ فِيهِ سَبْعَةَ أَشْفِيَةٍ يُسْعَطُ بِهِ مِنَ الْعُذْرَةِ وَيُلَدُّ بِهِ مِنْ ذَاتِ الْجَنْبِ ‏""""‏ ‏.‏ حَدَّثَنَا أَحْمَدُ بْنُ عَمْرِو بْنِ السَّرْحِ الْمِصْرِيُّ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، أَنْبَأَنَا يُونُسُ، عَنِ ابْنِ شِهَابٍ، عَنْ عُبَيْدِ اللَّهِ، عَنْ أُمِّ قَيْسٍ بِنْتِ مِحْصَنٍ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ بِنَحْوِهِ ‏.‏ قَالَ يُونُسُ أَعْلَقْتُ يَعْنِي غَمَزْتُ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الأطعمة ۲۶ (۳۷۹۰)، سنن النسائی/الذبائح ۳۰ (۴۳۳۶)،(تحفة الأشراف:۳۵۰۵)، وقد أخرجہ: مسند احمد (۴/۸۹،۹۰),,It was\nnarrated that Umm Qais bint Mihsan said:,Chapters on Medicine
3199,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، وَرَاشِدُ بْنُ سَعِيدٍ الرَّمْلِيُّ، قَالاَ حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، حَدَّثَنَا هِشَامُ بْنُ حَسَّانَ، حَدَّثَنَا أَنَسُ بْنُ سِيرِينَ، أَنَّهُ سَمِعَ أَنَسَ بْنَ مَالِكٍ، يَقُولُ سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ شِفَاءُ عِرْقِ النَّسَا أَلْيَةُ شَاةٍ أَعْرَابِيَّةٍ تُذَابُ ثُمَّ تُجَزَّأُ ثَلاَثَةَ أَجْزَاءٍ ثُمَّ يُشْرَبُ عَلَى الرِّيقِ فِي كُلِّ يَوْمٍ جُزْءٌ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: سنن ابی داود/الأضاحي ۱۸ (۲۸۲۷)، سنن الترمذی/الأطعمة ۲ (۱۴۷۶)،(تحفة الأشراف:۳۹۸۶)، وقد أخرجہ: مسند احمد (۲/۳۱،۳۹،۵۳),,Anas bin\nMalik said:,Chapters on Medicine
3200,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، وَمُحَمَّدُ بْنُ الصَّبَّاحِ، قَالاَ حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ أَبِي حَازِمٍ، عَنْ أَبِيهِ، عَنْ سَهْلِ بْنِ سَعْدٍ السَّاعِدِيِّ، قَالَ جُرِحَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ يَوْمَ أُحُدٍ وَكُسِرَتْ رَبَاعِيَتُهُ وَهُشِمَتِ الْبَيْضَةُ عَلَى رَأْسِهِ فَكَانَتْ فَاطِمَةُ تَغْسِلُ الدَّمَ عَنْهُ وَعَلِيٌّ يَسْكُبُ عَلَيْهِ الْمَاءَ بِالْمِجَنِّ فَلَمَّا رَأَتْ فَاطِمَةُ أَنَّ الْمَاءَ لاَ يَزِيدُ الدَّمَ إِلاَّ كَثْرَةً أَخَذَتْ قِطْعَةَ حَصِيرٍ فَأَحْرَقَتْهَا حَتَّى إِذَا صَارَ رَمَادًا أَلْزَمَتْهُ الْجُرْحَ فَاسْتَمْسَكَ الدَّمُ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «صحیح مسلم/الطہارة ۲۷ (۲۸۰)، سنن ابی داود/الطہارة ۳۷ (۷۴)، سنن النسائی/الطہارة ۵۳ (۶۷)، المیاہ ۷ (۳۳۷،۳۳۸)،(تحفة الأشراف:۹۶۶۵)، وقد أخرجہ: مسند احمد (۴/۸۶،۵/۵۶)، سنن الدارمی/الصید ۲ (۲۰۴۹),3200,It was\nnarrated that Sahl bin Sa’d As-Sa’idi said:,Chapters on Medicine
3201,حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ، حَدَّثَنَا ابْنُ أَبِي فُدَيْكٍ، عَنْ عَبْدِ الْمُهَيْمِنِ بْنِ عَبَّاسِ بْنِ سَهْلِ بْنِ سَعْدٍ السَّاعِدِيِّ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، قَالَ إِنِّي لأَعْرِفُ يَوْمَ أُحُدٍ مَنْ جَرَحَ وَجْهَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ وَمَنْ كَانَ يُرْقِئُ الْكَلْمَ مِنْ وَجْهِ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ وَيُدَاوِيهِ وَمَنْ يَحْمِلُ الْمَاءَ فِي الْمِجَنِّ وَبِمَا دُووِيَ بِهِ الْكَلْمُ حَتَّى رَقَأَ ‏.‏ قَالَ أَمَّا مَنْ كَانَ يَحْمِلُ الْمَاءَ فِي الْمِجَنِّ فَعَلِيٌّ وَأَمَّا مَنْ كَانَ يُدَاوِي الْكَلْمَ فَفَاطِمَةُ أَحْرَقَتْ لَهُ حِينَ لَمْ يَرْقَأْ قِطْعَةَ حَصِيرٍ خَلَقٍ فَوَضَعَتْ رَمَادَهُ عَلَيْهِ فَرَقَأَ الْكَلْمُ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: انظر ما قبلہ,3201,"It was\nnarrated from ‘Abdul-Muhaimin bin ‘Abbas bin Sahl bin Sa’d\nAs-\nSa’idi, from his father, that his grandfather said:",Chapters on Medicine
3202,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، وَرَاشِدُ بْنُ سَعِيدٍ الرَّمْلِيُّ، قَالاَ حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، حَدَّثَنَا ابْنُ جُرَيْجٍ، عَنْ عَمْرِو بْنِ شُعَيْبٍ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ تَطَبَّبَ وَلَمْ يُعْلَمْ مِنْهُ طِبٌّ قَبْلَ ذَلِكَ فَهُوَ ضَامِنٌ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/بدء الخلق ۱۷ (۳۳۲۳)، صحیح مسلم/المساقاة ۱۰ (۱۵۷۰)، سنن النسائی/الصید والذبائح ۹ (۴۲۸۲)،(تحفة الأشراف:۸۳۴۹)، وقد أخرجہ: سنن الترمذی/الصید ۱۷ (۱۴۸۷)، موطا امام مالک/لإستئذان ۵ (۱۴)، مسند احمد (۲/۲۲،۲۳،۱۱۳،۱۳۲،۱۴۶)، سنن الدارمی/الصید ۳ (۲۰۵۰),,"It was\nnarrated from ‘Amr bin Shu’aib, from his father, that his\ngrandfather said:",Chapters on Medicine
3203,حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ عَبْدِ الْوَهَّابِ، حَدَّثَنَا يَعْقُوبُ بْنُ إِسْحَاقَ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَيْمُونٍ، حَدَّثَنِي أَبِي، عَنْ زَيْدِ بْنِ أَرْقَمَ، قَالَ نَعَتَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ مِنْ ذَاتِ الْجَنْبِ وَرْسًا وَقُسْطًا وَزَيْتًا يُلَدُّ بِهِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن النسائی/الصید ۹ (۴۲۸۳)،(تحفة الأشراف:۷۰۰۲),3203,It was\nnarrated that Zaid bin Arqam said:,Chapters on Medicine
3204,"حَدَّثَنَا أَبُو طَاهِرٍ، أَحْمَدُ بْنُ عَمْرِو بْنِ السَّرْحِ الْمِصْرِيُّ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، أَنْبَأَنَا يُونُسُ، وَابْنُ، سَمْعَانَ عَنِ ابْنِ شِهَابٍ، عَنْ عُبَيْدِ اللَّهِ بْنِ عَبْدِ اللَّهِ بْنِ عُتْبَةَ، عَنْ أُمِّ قَيْسٍ بِنْتِ مِحْصَنٍ، قَالَتْ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏""‏ عَلَيْكُمْ بِالْعُودِ الْهِنْدِيِّ - يَعْنِي بِهِ الْكُسْتَ - فَإِنَّ فِيهِ سَبْعَةَ أَشْفِيَةٍ مِنْهَا ذَاتُ الْجَنْبِ ‏""‏ ‏.‏ قَالَ ابْنُ سَمْعَانَ فِي الْحَدِيثِ ‏""‏ فَإِنَّ فِيهِ شِفَاءً مِنْ سَبْعَةِ أَدْوَاءٍ مِنْهَا ذَاتُ الْجَنْبِ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/المساقاة ۱۰ (۱۵۷۵)،(تحفة الأشراف:۱۵۳۹۰)، وقد أخرجہ: صحیح البخاری/الحرث ۳ (۲۳۲۳)، بدء الخلق ۱۷ (۳۳۲۴)، سنن ابی داود/الصید ۱ (۲۸۴۴)، سنن الترمذی/الصید ۱۷ (۱۴۹۰)، سنن النسائی/الصید ۱۴ (۴۲۹۴)، مسند احمد (۲/۲۶۷،۳۴۵),3204,Umm Qais\nbint Mihsan said:,Chapters on Medicine
3205,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا وَكِيعٌ، عَنْ مُوسَى بْنِ عُبَيْدَةَ، عَنْ عَلْقَمَةَ بْنِ مَرْثَدٍ، عَنْ حَفْصِ بْنِ عُبَيْدِ اللَّهِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ ذُكِرَتِ الْحُمَّى عِنْدَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ فَسَبَّهَا رَجُلٌ فَقَالَ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏ ‏ لاَ تَسُبَّهَا فَإِنَّهَا تَنْفِي الذُّنُوبَ كَمَا تَنْفِي النَّارُ خَبَثَ الْحَدِيدِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الصید ا (۲۸۴۵مختصراً)، سنن الترمذی/الأحکام ۳ (۱۴۸۶مختصراً) سنن النسائی/الصید ۱۰ (۴۳۸۵)،(تحفة الأشراف:۹۶۴۹)، وقد أخرجہ: مسند احمد (۴/۸۵،۸۶،۵/۵۴،۵۶،۵۷، سنن الدارمی/الصید ۲ (۲۰۴۹),,It was\nnarrated that Abu Hurairah said:,Chapters on Medicine
3206,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو أُسَامَةَ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ يَزِيدَ، عَنْ إِسْمَاعِيلَ بْنِ عُبَيْدِ اللَّهِ، عَنْ أَبِي صَالِحٍ الأَشْعَرِيِّ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ أَنَّهُ عَادَ مَرِيضًا وَمَعَهُ أَبُو هُرَيْرَةَ مِنْ وَعْكٍ كَانَ بِهِ فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ أَبْشِرْ فَإِنَّ اللَّهَ يَقُولُ هِيَ نَارِي أُسَلِّطُهَا عَلَى عَبْدِيَ الْمُؤْمِنِ فِي الدُّنْيَا لِتَكُونَ حَظَّهُ مِنَ النَّارِ فِي الآخِرَةِ ‏""""‏ ‏.‏""",Al-Albani: Sahih Hadith; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحرث ۳ (۲۳۲۳)، بدء الخلق ۱۷ (۳۳۲۵)، صحیح مسلم/المساقاة ۱۰ (۱۵۷۶)، سنن النسائی/الصید ۱۲ (۴۲۹۰)،(تحفة الأشراف:۴۴۷۶)، وقد أخرجہ: موطا امام مالک/الإستئذان ۵ (۱۲)، مسند احمد (۵/۲۱۹،۲۲۰)، سنن الدارمی/الصید ۲ (۲۰۴۸),,"It was\nnarrated from Abu Hurairah that the Prophet (ﷺ) visited a\nsick\nperson, due to an illness that he was suffering from and Abu\nHurairah\nwas with him. The Messenger of Allah (ﷺ) said:",Chapters on Medicine
3207,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ إِنَّ الْحُمَّى مِنْ فَيْحِ جَهَنَّمَ فَابْرُدُوهَا بِالْمَاءِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الصید ۴ (۵۴۷۸)،۱۰ (۵۴۸۸)،۱۴ (۵۴۹۶)، صحیح مسلم/الصید ۱ (۱۹۳۰)، سنن ابی داود/الصید ۲ (۲۸۵۵)، سنن الترمذی/والسیر ۱۱ (۱۵۶۰)، سنن النسائی/الصید ۴ (۴۲۷۱)،(تحفة الأشرف:۱۱۸۷۵)، وقد أخرجہ: مسند احمد (۴/۱۹۳،۱۹۴،۱۹۵)، سنن الدارمی/السیر ۵۶ (۲۵۴۱),,It was\nnarrated from ‘Aishah that the Prophet (ﷺ) said:,Chapters on Medicine
3208,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ أَنَّهُ قَالَ ‏ ‏ إِنَّ شِدَّةَ الْحُمَّى مِنْ فَيْحِ جَهَنَّمَ فَابْرُدُوهَا بِالْمَاءِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الوضو ۳۳ (۱۷۵)، البیوع ۳ (۲۰۵۴)، الصید ۱ (۵۴۷۵)،۲ (۵۴۷۶)،۳ (۵۴۷۷)،۷ (۵۴۸۳)،۹ (۵۴۸۴)،۱۰ (۵۴۸۵)، صحیح مسلم/الصید ۱ (۱۹۲۹)، سنن ابی داود/الصید ۲ (۲۸۴۸)،(تحفة الأشراف:۹۸۵۵)، وقد أخرجہ: سنن الترمذی/الصید ۱ (۱۴۵۶)، سنن النسائی/الصید ۲ (۴۲۶۹)، مسند احمد (۴/۲۵۶،۲۵۷،۲۵۸،۳۷۷،۳۷۹،۳۸۰)، سنن الدارمی/الصید ۱ (۲۰۴۵),,It was\nnarrated from Ibn ‘Umar that the Prophet (ﷺ) said:,Chapters on Medicine
3209,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا مُصْعَبُ بْنُ الْمِقْدَامِ، حَدَّثَنَا إِسْرَائِيلُ، عَنْ سَعِيدِ بْنِ مَسْرُوقٍ، عَنْ عَبَايَةَ بْنِ رِفَاعَةَ، عَنْ رَافِعِ بْنِ خَدِيجٍ، قَالَ سَمِعْتُ النَّبِيَّ ـ صلى الله عليه وسلم ـ يَقُولُ ‏""‏ الْحُمَّى مِنْ فَيْحِ جَهَنَّمَ فَابْرُدُوهَا بِالْمَاءِ ‏""‏ ‏.‏ فَدَخَلَ عَلَى ابْنٍ لِعَمَّارٍ فَقَالَ ‏""‏ اكْشِفِ الْبَاسْ رَبَّ النَّاسْ إِلَهَ النَّاسْ ‏""‏ ‏.‏",Al-Albani: Daif Isnaad; Muhammad Fouad Abd al-Baqi: Daif Isnaad; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۲۷۱، ومصباح الزجاجة:۱۱۰۳)، وقد أخرجہ: سنن الترمذی/الصید ۲ (۱۴۶۶),3209,It was\nnarrated that Rafi’ bin Khadij said:,Chapters on Medicine
3210,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدَةُ بْنُ سُلَيْمَانَ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ فَاطِمَةَ بِنْتِ الْمُنْذِرِ، عَنْ أَسْمَاءَ بِنْتِ أَبِي بَكْرٍ، أَنَّهَا كَانَتْ تُؤْتَى بِالْمَرْأَةِ الْمَوْعُوكَةِ فَتَدْعُو بِالْمَاءِ فَتَصُبُّهُ فِي جَيْبِهَا وَتَقُولُ إِنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ ‏""‏ ابْرُدُوهَا بِالْمَاءِ ‏""‏ ‏.‏ وَقَالَ ‏""‏ إِنَّهَا مِنْ فَيْحِ جَهَنَّمَ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «صحیح مسلم/الصلاة ۵۰ (۵۱۰)، سنن ابی داود/الصلاة ۱۱۱ (۷۰۲)، سنن الترمذی/الصلاة ۱۳۷ (۳۳۸)، سنن النسائی/القبلة ۷ (۷۵۱)،(تحفة الأشراف:۱۱۹۳۹)، وقد أخرجہ: مسند احمد (۵/۱۴۹،۱۵۱،۱۵۵،۱۵۸،۱۶۰،۱۶۱)، سنن الدارمی/الصلاة ۱۲۸ (۱۴۵۴),3210,"It was\nnarrated from Asma’ bint Abu Bakr that a woman suffering from\nfever\nwould be brought to her, and she would call for water and pour\nit\nonto the neck of her garment. She said:",Chapters on Medicine
3211,"حَدَّثَنَا أَبُو سَلَمَةَ، يَحْيَى بْنُ خَلَفٍ حَدَّثَنَا عَبْدُ الأَعْلَى، عَنْ سَعِيدٍ، عَنْ قَتَادَةَ، عَنِ الْحَسَنِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ الْحُمَّى كِيرٌ مِنْ كِيرِ جَهَنَّمَ فَنَحُّوهَا عَنْكُمْ بِالْمَاءِ الْبَارِدِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۸۶۷),,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Medicine
3212,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَسْوَدُ بْنُ عَامِرٍ، حَدَّثَنَا حَمَّادُ بْنُ سَلَمَةَ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو، عَنْ أَبِي سَلَمَةَ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ إِنْ كَانَ فِي شَىْءٍ مِمَّا تَدَاوَوْنَ بِهِ خَيْرٌ فَالْحِجَامَةُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد ابن ماجة بھذاالسیاق (تحفة الأشراف:۹۸۶۸، ومصباح الزجاجة:۱۱۰۴)، قد أخرجہ: صحیح البخاری/البیوع ۳ (۲۰۵۴)، الذبائح ۳ (۵۴۷۷)، صحیح مسلم/الصید ۱ (۱۹۲۹)، سنن ابی داود/الصید ۲ (۲۸۴۷)، سنن الترمذی/الصید ۱ (۱۴۶۵)،۳ (۱۴۶۷)، سنن النسائی/الصید ۳ (۴۲۷۰)، مسند احمد (۴،۲۵۶،۲۵۸،۳۸۰)، سنن الدارمی/الصید ۱ (۲۰۴۶),,It was\nnarrated from Abu Hurairah that the Prophet (ﷺ) said:,Chapters on Medicine
3213,"حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ، حَدَّثَنَا زِيَادُ بْنُ الرَّبِيعِ، حَدَّثَنَا عَبَّادُ بْنُ مَنْصُورٍ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ مَا مَرَرْتُ لَيْلَةَ أُسْرِيَ بِي بِمَلإٍ مِنَ الْمَلاَئِكَةِ إِلاَّ كُلُّهُمْ يَقُولُ لِي عَلَيْكَ يَا مُحَمَّدُ بِالْحِجَامَةِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/ الذبائح ۸ (۵۴۸۴)، صحیح مسلم/الصید ۱ (۱۹۲۹)، سنن ابی داود/الصید ۲ (۲۸۴۹،۲۸۵۰)، سنن الترمذی/الصید ۳ (۱۴۶۹)، سنن النسائی/الصید ۱ (۴۲۶۸)،۶ (۴۲۷۳)،۸ (۴۲۷۹)،۱۸ (۴۳۰۳)،(تحفة الأشراف:۹۸۶۲),,It was\nnarrated from Ibn ‘Abbas that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Medicine
3214,"حَدَّثَنَا أَبُو بِشْرٍ، بَكْرُ بْنُ خَلَفٍ حَدَّثَنَا عَبْدُ الأَعْلَى، حَدَّثَنَا عَبَّادُ بْنُ مَنْصُورٍ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ نِعْمَ الْعَبْدُ الْحَجَّامُ يَذْهَبُ بِالدَّمِ وَيُخِفُّ الصُّلْبَ وَيَجْلُو الْبَصَرَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الصید ۱ (۵۴۷۵)، صحیح مسلم/الصید ۱ (۱۹۲۹)، سنن الترمذی/الصید ۷ (۱۴۷۱)،(تحفة الأشراف:۹۸۶۰)، وقد أخرجہ: مسند احمد (۴/۲۵۶،۳۷۹، سنن الدارمی/الصید ۱ (۲۰۴۵),,It was\nnarrated that Ibn ‘Abbas said:,Chapters on Medicine
3215,"حَدَّثَنَا جُبَارَةُ بْنُ الْمُغَلِّسِ، حَدَّثَنَا كَثِيرُ بْنُ سُلَيْمٍ، سَمِعْتُ أَنَسَ بْنَ مَالِكٍ، يَقُولُ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَا مَرَرْتُ لَيْلَةَ أُسْرِيَ بِي بِمَلإٍ إِلاَّ قَالُوا يَا مُحَمَّدُ مُرْ أُمَّتَكَ بِالْحِجَامَةِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الصید ۳ (۵۴۷۷)، التوحید ۱۳ (۷۳۹۷)، صحیح مسلم/الصید ۱ (۱۹۲۹)، سنن الترمذی/الصید ا (۱۴۶۵)، سنن النسائی/الصید ۳ (۴۲۷۰)،(تحفة الأشراف:۹۸۷۸)، وقد أخرجہ: مسند احمد (۴/۲۵۶،۲۵۸،۳۷۷،۳۸۰),,Anas bin\nMalik said:,Chapters on Medicine
3216,حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ الْمِصْرِيُّ، أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، أَنَّ أُمَّ سَلَمَةَ، زَوْجَ النَّبِيِّ ـ صلى الله عليه وسلم ـ اسْتَأْذَنَتْ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ فِي الْحِجَامَةِ فَأَمَرَ النَّبِيُّ ـ صلى الله عليه وسلم ـ أَبَا طَيْبَةَ أَنْ يَحْجُمَهَا ‏.‏ وَقَالَ حَسِبْتُ أَنَّهُ كَانَ أَخَاهَا مِنَ الرَّضَاعَةِ أَوْ غُلاَمًا لَمْ يَحْتَلِمْ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۷۳۷، ومصباح الزجاجة:۱۱۰۵),3216,,Chapters on Medicine
3217,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ، حَدَّثَنَا سُلَيْمَانُ بْنُ بِلاَلٍ، حَدَّثَنِي عَلْقَمَةُ بْنُ أَبِي عَلْقَمَةَ، قَالَ سَمِعْتُ عَبْدَ الرَّحْمَنِ الأَعْرَجَ، قَالَ سَمِعْتُ عَبْدَ اللَّهِ ابْنَ بُحَيْنَةَ، يَقُولُ احْتَجَمَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ بِلَحْىِ جَمَلٍ وَهُوَ مُحْرِمٌ وَسْطَ رَأْسِهِ ‏.‏,Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۰۶۰، ومصباح الزجاجة:۱۱۰۶),3217,‘Abdur-Rahman Al-A’raj said:,Chapters on Medicine
3218,حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ، عَنْ سَعْدٍ الإِسْكَافِ، عَنِ الأَصْبَغِ بْنِ نُبَاتَةَ، عَنْ عَلِيٍّ، قَالَ نَزَلَ جِبْرِيلُ عَلَى النَّبِيِّ ـ صلى الله عليه وسلم ـ بِحِجَامَةِ الأَخْدَعَيْنِ وَالْكَاهِلِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۷۳۸، ومصباح الزجاجة:۱۱۰۷)، وقد أخرجہ: مسند احمد (۲/۹۷),3218,It was\nnarrated that ‘Ali said:,Chapters on Medicine
3219,حَدَّثَنَا عَلِيُّ بْنُ أَبِي الْخَصِيبِ، حَدَّثَنَا وَكِيعٌ، عَنْ جَرِيرِ بْنِ حَازِمٍ، عَنْ قَتَادَةَ، عَنْ أَنَسٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ احْتَجَمَ فِي الأَخْدَعَيْنِ وَعَلَى الْكَاهِلِ ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الأطعمة ۳۵ (۳۸۱۳،۳۸۱۴)،(تحفة الأشراف:۴۴۹۵),3219,,Chapters on Medicine
3220,"حَدَّثَنَا مُحَمَّدُ بْنُ الْمُصَفَّى الْحِمْصِيُّ، حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، حَدَّثَنَا ابْنُ ثَوْبَانَ، عَنْ أَبِيهِ، عَنْ أَبِي كَبْشَةَ الأَنْمَارِيِّ، أَنَّهُ حَدَّثَهُ أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ كَانَ يَحْتَجِمُ عَلَى هَامَتِهِ وَبَيْنَ كَتِفَيْهِ وَيَقُولُ ‏ ‏ مَنْ أَهْرَاقَ مِنْهُ هَذِهِ الدِّمَاءَ فَلاَ يَضُرُّهُ أَنْ لاَ يَتَدَاوَى بِشَىْءٍ لِشَىْءٍ ‏""""‏ ‏.‏""",Al-Albani: Daif Isnaad; Muhammad Fouad Abd al-Baqi: Daif Isnaad; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۶۴، ومصباح الزجاجة:۱۱۰۸),,"It was\nnarrated from Abu Kabshah Al-Anmari that the Prophet (ﷺ)\nused to be\ncupped on his head and between his shoulders, and he said:",Chapters on Medicine
3221,حَدَّثَنَا مُحَمَّدُ بْنُ طَرِيفٍ، حَدَّثَنَا وَكِيعٌ، عَنِ الأَعْمَشِ، عَنْ أَبِي سُفْيَانَ، عَنْ جَابِرٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ سَقَطَ مِنْ فَرَسِهِ عَلَى جِذْعٍ فَانْفَكَّتْ قَدَمُهُ ‏.‏ قَالَ وَكِيعٌ يَعْنِي أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ احْتَجَمَ عَلَيْهَا مِنْ وَثْءٍ ‏.‏,Al-Albani: Mawdu; Muhammad Fouad Abd al-Baqi: Mawdu; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۴۵۱،۲۵۸۵)، ومصباح الزجاجة:۱۱۰۹، وقد أخرجہ: سنن الترمذی/الأطعمة ۲۳ (۱۸۲۳),3221,It was\nnarrated from Jabir that the Prophet (ﷺ) fell from his horse onto\nthe truck of a palm tree and dislocated his foot.\n(One of the narrators) Waki’ said:,Chapters on Medicine
3222,"حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، حَدَّثَنَا عُثْمَانُ بْنُ مَطَرٍ، عَنْ زَكَرِيَّا بْنِ مَيْسَرَةَ، عَنِ النَّهَّاسِ بْنِ قَهْمٍ، عَنْ أَنَسِ بْنِ مَالِكٍ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ مَنْ أَرَادَ الْحِجَامَةَ فَلْيَتَحَرَّ سَبْعَةَ عَشَرَ أَوْ تِسْعَةَ عَشَرَ أَوْ إِحْدَى وَعِشْرِينَ وَلاَ يَتَبَيَّغْ بِأَحَدِكُمُ الدَّمُ فَيَقْتُلَهُ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/المناسک ۴۲ (۱۸۵۴)، سنن الترمذی/الحج ۲۷ (۸۵۰)،(تحفة الأشراف:۱۴۸۳۲)، وقد أخرجہ: مسند احمد (۲/۳۰۶،۳۶۴،۳۷۴،۴۰۷),,It was\nnarrated from Anas bin Malik that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Medicine
3223,"حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، حَدَّثَنَا عُثْمَانُ بْنُ مَطَرٍ، عَنِ الْحَسَنِ بْنِ أَبِي جَعْفَرٍ، عَنْ مُحَمَّدِ بْنِ جُحَادَةَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ يَا نَافِعُ قَدْ تَبَيَّغَ بِيَ الدَّمُ فَالْتَمِسْ لِي حَجَّامًا وَاجْعَلْهُ رَفِيقًا إِنِ اسْتَطَعْتَ وَلاَ تَجْعَلْهُ شَيْخًا كَبِيرًا وَلاَ صَبِيًّا صَغِيرًا فَإِنِّي سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ الْحِجَامَةُ عَلَى الرِّيقِ أَمْثَلُ وَفِيهِ شِفَاءٌ وَبَرَكَةٌ وَتَزِيدُ فِي الْعَقْلِ وَفِي الْحِفْظِ فَاحْتَجِمُوا عَلَى بَرَكَةِ اللَّهِ يَوْمَ الْخَمِيسِ وَاجْتَنِبُوا الْحِجَامَةَ يَوْمَ الأَرْبِعَاءِ وَالْجُمُعَةِ وَالسَّبْتِ وَيَوْمَ الأَحَدِ تَحَرِّيًا وَاحْتَجِمُوا يَوْمَ الاِثْنَيْنِ وَالثُّلاَثَاءِ فَإِنَّهُ الْيَوْمُ الَّذِي عَافَى اللَّهُ فِيهِ أَيُّوبَ مِنَ الْبَلاَءِ وَضَرَبَهُ بِالْبَلاَءِ يَوْمَ الأَرْبِعَاءِ فَإِنَّهُ لاَ يَبْدُو جُذَامٌ وَلاَ بَرَصٌ إِلاَّ يَوْمَ الأَرْبِعَاءِ أَوْ لَيْلَةَ الأَرْبِعَاءِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۹۴۴، ومصباح الزجاجة:۱۱۱۰),,It was\nnarrated that Ibn ‘Umar said:,Chapters on Medicine
3224,"حَدَّثَنَا مُحَمَّدُ بْنُ الْمُصَفَّى الْحِمْصِيُّ، حَدَّثَنَا عُثْمَانُ بْنُ عَبْدِ الرَّحْمَنِ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ عِصْمَةَ، عَنْ سَعِيدِ بْنِ مَيْمُونٍ، عَنْ نَافِعٍ، قَالَ قَالَ ابْنُ عُمَرَ يَا نَافِعُ تَبَيَّغَ بِيَ الدَّمُ فَأْتِنِي بِحَجَّامٍ وَاجْعَلْهُ شَابًّا وَلاَ تَجْعَلْهُ شَيْخًا وَلاَ صَبِيًّا ‏.‏ قَالَ وَقَالَ ابْنُ عُمَرَ سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ الْحِجَامَةُ عَلَى الرِّيقِ أَمْثَلُ وَهِيَ تَزِيدُ فِي الْعَقْلِ وَتَزِيدُ فِي الْحِفْظِ وَتَزِيدُ الْحَافِظَ حِفْظًا فَمَنْ كَانَ مُحْتَجِمًا فَيَوْمَ الْخَمِيسِ عَلَى اسْمِ اللَّهِ وَاجْتَنِبُوا الْحِجَامَةَ يَوْمَ الْجُمُعَةِ وَيَوْمَ السَّبْتِ وَيَوْمَ الأَحَدِ وَاحْتَجِمُوا يَوْمَ الاِثْنَيْنِ وَالثُّلاَثَاءِ وَاجْتَنِبُوا الْحِجَامَةَ يَوْمَ الأَرْبِعَاءِ فَإِنَّهُ الْيَوْمُ الَّذِي أُصِيبَ فِيهِ أَيُّوبُ بِالْبَلاَءِ وَمَا يَبْدُو جُذَامٌ وَلاَ بَرَصٌ إِلاَّ فِي يَوْمِ الأَرْبِعَاءِ أَوْ لَيْلَةِ الأَرْبِعَاءِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الأدب ۱۶۴ (۵۲۶۷)،(تحفة الأشراف:۵۸۵۰)، وقد أخرجہ: مسند احمد (۱/۳۳۲،۳۴۷)، سنن الدارمی/الأضاحي ۲۶ (۲۱۴۲),,It was\nnarrated that Nafi’ said:,Chapters on Medicine
3225,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا إِسْمَاعِيلُ ابْنُ عُلَيَّةَ، عَنْ لَيْثٍ، عَنْ مُجَاهِدٍ، عَنْ عَقَّارِ بْنِ الْمُغِيرَةِ، عَنْ أَبِيهِ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ مَنِ اكْتَوَى أَوِ اسْتَرْقَى فَقَدْ بَرِئَ مِنَ التَّوَكُّلِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الجہاد ۱۵۳ (۳۰۱۹)، بدء الخلق ۱۶ (۳۳۱۹)، صحیح مسلم/السلام ۳۹ (۲۲۴۱)، سنن ابی داود/الأدب ۱۷۶ (۵۲۶۶)، سنن النسائی/الصید والذبائح ۳۸ (۴۳۶۳)،(تحفة الأشراف:۱۳۳۱۹،۱۵۳۰۷)، وقد أخرجہ: مسند احمد (۲/۴۰۳),,It was\nnarrated from ‘Aqqar bin Al-Mughirah from his father that the\nProphet (ﷺ) said:,Chapters on Medicine
3226,حَدَّثَنَا عَمْرُو بْنُ رَافِعٍ، حَدَّثَنَا هُشَيْمٌ، عَنْ مَنْصُورٍ، وَيُونُسَ، عَنِ الْحَسَنِ، عَنْ عِمْرَانَ بْنِ الْحُصَيْنِ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنِ الْكَىِّ فَاكْتَوَيْتُ فَمَا أَفْلَحْتُ وَلاَ أَنْجَحْتُ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «صحیح البخاری/الذبائح ۵ (۵۴۷۹)، الأدب ۱۲۲ (۶۲۲۰)، صحیح مسلم/الصید ۵۴ (۱۹۵۴)، سنن ابی داود/الأدب ۱۶۸ (۵۲۷۰)،(تحفة الأشراف:۹۶۵۷)، وقد أخرجہ: مسند احمد (۴/۸۴،۵/۵۴)، سنن الدارمی/المقدمة ۴۰ (۴۵۴),3226,It was\nnarrated that ‘Imran bin Husain said:,Chapters on Medicine
3227,"حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا مَرْوَانُ بْنُ شُجَاعٍ، حَدَّثَنَا سَالِمٌ الأَفْطَسُ، عَنْ سَعِيدِ بْنِ جُبَيْرٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ ‏ ‏ الشِّفَاءُ فِي ثَلاَثٍ شَرْبَةِ عَسَلٍ وَشَرْطَةِ مِحْجَمٍ وَكَيَّةٍ بِنَارٍ وَأَنْهَى أُمَّتِي عَنِ الْكَىِّ ‏""""‏ ‏.‏ رَفَعَهُ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/التفسیر ۵ (۴۸۴۱)، الأدب ۱۲۲ (۶۲۲۰)، صحیح مسلم/الصید ۱۰ (۱۹۵۴)، سنن ابی داود/الأدب ۱۷۸ (۵۲۷۰)،(تحفة الأشراف:۹۶۶۳)، وقد أخرجہ: سنن النسائی/القسامة ۳۳ (۴۸۱۹)، مسند احمد (۴/۸۶،۵/۴۶،۵۴،۵۵،۵۶،۵۷),,It was\nnarrated that Ibn ‘Abbas said:,Chapters on Medicine
3228,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَمُحَمَّدُ بْنُ بَشَّارٍ، قَالاَ حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، غُنْدَرٌ حَدَّثَنَا شُعْبَةُ، ح وَحَدَّثَنَا أَحْمَدُ بْنُ سَعِيدٍ الدَّارِمِيُّ، حَدَّثَنَا النَّضْرُ بْنُ شُمَيْلٍ، حَدَّثَنَا شُعْبَةُ، حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الرَّحْمَنِ بْنِ سَعْدِ بْنِ زُرَارَةَ الأَنْصَارِيُّ، قَالَ سَمِعْتُ عَمِّي، يَحْيَى - وَمَا أَدْرَكْتُ رَجُلاً مِنَّا بِهِ شَبِيهًا يُحَدِّثُ النَّاسَ أَنَّ سَعْدَ بْنَ زُرَارَةَ - وَهُوَ جَدُّ مُحَمَّدٍ مِنْ قِبَلِ أُمِّهِ أَنَّهُ أَخَذَهُ وَجَعٌ فِي حَلْقِهِ يُقَالُ لَهُ الذُّبْحَةُ فَقَالَ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏""‏ لأُبْلِغَنَّ أَوْ لأُبْلِيَنَّ فِي أَبِي أُمَامَةَ عُذْرًا ‏""‏ ‏.‏ فَكَوَاهُ بِيَدِهِ فَمَاتَ فَقَالَ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏""‏ مِيتَةَ سُوءٍ لِلْيَهُودِ يَقُولُونَ أَفَلاَ دَفَعَ عَنْ صَاحِبِهِ ‏.‏ وَمَا أَمْلِكُ لَهُ وَلاَ لِنَفْسِي شَيْئًا ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/بدء الخلق ۱۵ (۳۳۰۷)، أحادیث الأنبیاء ۸ (۳۳۵۹)، صحیح مسلم/السلام ۳۸ (۲۲۳۷)، سنن النسائی/الحج ۱۱۵ (۲۸۸۸)،(تحفة الأشراف:۱۸۳۲۹)، وقد أخرجہ: مسند احمد (۶/۴۲۱،۴۶۲)، سنن الدارمی/الأضاحی ۲۷ (۲۰۴۳),3228,Muhammad\nbin ‘Abdur-Rahman bin Sa’d bin Zurarah Al-Ansari said:,Chapters on Medicine
3229,حَدَّثَنَا عَمْرُو بْنُ رَافِعٍ، حَدَّثَنَا مُحَمَّدُ بْنُ عُبَيْدٍ الطَّنَافِسِيُّ، عَنِ الأَعْمَشِ، عَنْ أَبِي سُفْيَانَ، عَنْ جَابِرٍ، قَالَ مَرِضَ أُبَىُّ بْنُ كَعْبٍ مَرَضًا فَأَرْسَلَ إِلَيْهِ النَّبِيُّ طَبِيبًا فَكَوَاهُ عَلَى أَكْحَلِهِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «تفرد بہ ابن ماجہ:(تحفةالأشراف:۱۲۷۳۱)، وقد أخرجہ: صحیح مسلم/السلام ۳۸ (۲۲۴۰)، سنن ابی داود/الأدب ۱۷۵ (۵۲۶۳)، سنن الترمذی/الأحکام ۱ (۱۴۸۲)، مسند احمد (۲/۳۵۵),3229,It was\nnarrated that Jabir said:,Chapters on Medicine
3230,حَدَّثَنَا عَلِيُّ بْنُ أَبِي الْخَصِيبِ، حَدَّثَنَا وَكِيعٌ، عَنْ سُفْيَانَ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ كَوَى سَعْدَ بْنَ مُعَاذٍ فِي أَكْحَلِهِ مَرَّتَيْنِ ‏.‏,Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/جزاء الصید ۷ (۱۸۳۱)، بدء الخلق ۱۵ (۳۳۰۶)، صحیح مسلم/السلام ۳۸ (۲۲۴۰)، سنن النسائی/الحج ۱۱۵ (۲۸۸۹)،(تحفة الأشراف:۱۶۶۹۶)، وقد أخرجہ: مسند احمد (۶/۸۷،۱۵۵،۲۷۱،۲۷۹),3230,,Chapters on Medicine
3231,"حَدَّثَنَا أَبُو سَلَمَةَ، يَحْيَى بْنُ خَلَفٍ حَدَّثَنَا أَبُو عَاصِمٍ، حَدَّثَنِي عُثْمَانُ بْنُ عَبْدِ الْمَلِكِ، قَالَ سَمِعْتُ سَالِمَ بْنَ عَبْدِ اللَّهِ، يُحَدِّثُ عَنْ أَبِيهِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ عَلَيْكُمْ بِالإِثْمِدِ فَإِنَّهُ يَجْلُو الْبَصَرَ وَيُنْبِتُ الشَّعَرَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۷۸۴۳، ومصباح الزجاجة:۱۱۱۱)، وقد أخرجہ: مسند احمد (۶/۸۳،۱۰۹),,Salim\nbin ‘Abdullah narrated that his father said:,Chapters on Medicine
3232,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ سُلَيْمَانَ، عَنْ إِسْمَاعِيلَ بْنِ مُسْلِمٍ، عَنْ مُحَمَّدِ بْنِ الْمُنْكَدِرِ، عَنْ جَابِرٍ، قَالَ سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ عَلَيْكُمْ بِالإِثْمِدِ عِنْدَ النَّوْمِ فَإِنَّهُ يَجْلُو الْبَصَرَ وَيُنْبِتُ الشَّعَرَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الصید ۲۹ (۵۵۳۰)، الطب ۵۷ (۵۷۸۰)، صحیح مسلم/الصید ۳ (۱۹۳۲)، سنن ابی داود/الاطعمة ۳۳ (۳۸۰۲)، سنن الترمذی/الصید ۱۱ (۱۴۷۷)، سنن النسائی/الصید ۲۸ (۴۳۳۰)،(تحفة الأشراف:۱۱۸۷۴)، وقد أخرجہ: موطا امام مالک/الصید ۴ (۱۳)، مسند احمد (۴/۱۹۳،۱۹۴)، سنن الدارمی/الأضاحي ۱۸ (۲۰۲۳),,It was\nnarrated that Jabir said:,Chapters on Medicine
3233,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَحْيَى بْنُ آدَمَ، عَنْ سُفْيَانَ، عَنِ ابْنِ خُثَيْمٍ، عَنْ سَعِيدِ بْنِ جُبَيْرٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ خَيْرُ أَكْحَالِكُمُ الإِثْمِدُ يَجْلُو الْبَصَرَ وَيُنْبِتُ الشَّعَرَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «سنن النسائی/الصید ۲۸ (۴۳۲۹)،(تحفة الأشراف:۱۴۱۳۲)، وقد أخرجہ: موطا امام مالک/الصید ۴ (۱۴)، صحیح مسلم/الصید ۳ (۱۹۳۳)، سنن الترمذی/الصید ۳ (۱۴۶۷)، مسند احمد (۲/۴۱۸),,It was\nnarrated from Ibn ‘Abbas that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Medicine
3234,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ عُمَرَ، حَدَّثَنَا عَبْدُ الْمَلِكِ بْنُ الصَّبَّاحِ، عَنْ ثَوْرِ بْنِ يَزِيدَ، عَنْ حُصَيْنٍ الْحِمْيَرِيِّ، عَنْ أَبِي سَعْدِ الْخَيْرِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ مَنِ اكْتَحَلَ فَلْيُوتِرْ مَنْ فَعَلَ فَقَدْ أَحْسَنَ وَمَنْ لاَ فَلاَ حَرَجَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الأطعمة ۳۳ (۳۸۰۵)، سنن النسائی/الصید ۳۳ (۴۳۵۳)،(تحفة الأشراف:۵۶۳۹)، وقد أخرجہ: صحیح مسلم/الصید ۳ (۱۹۳۴)، مسند احمد (۱/۲۴۴)، سنن الدارمی/الأضاحی ۱۸ (۲۰۲۵),,It was\nnarrated from Abu Hurairah that the Prophet (ﷺ) said:,Chapters on Medicine
3235,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، عَنْ عَبَّادِ بْنِ مَنْصُورٍ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ كَانَتْ لِلنَّبِيِّ ـ صلى الله عليه وسلم ـ مُكْحُلَةٌ يَكْتَحِلُ مِنْهَا ثَلاَثًا فِي كُلِّ عَيْنٍ ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۵۳۳، ومصباح الزجاجة:۱۱۱۲)، وقد أخرجہ: سنن الترمذی/الأطعمة ۴ (۱۷۹۲)، مقتصراً علی الجملة الأخیرة),3235,It was\nnarrated that Ibn ‘Abbas said:,Chapters on Medicine
3236,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَفَّانُ، حَدَّثَنَا حَمَّادُ بْنُ سَلَمَةَ، أَنْبَأَنَا سِمَاكُ بْنُ حَرْبٍ، عَنْ عَلْقَمَةَ بْنِ وَائِلٍ الْحَضْرَمِيِّ، عَنْ طَارِقِ بْنِ سُوَيْدٍ الْحَضْرَمِيِّ، قَالَ قُلْتُ يَا رَسُولَ اللَّهِ إِنَّ بِأَرْضِنَا أَعْنَابًا نَعْتَصِرُهَا فَنَشْرَبُ مِنْهَا قَالَ ‏""‏ لاَ ‏""‏ ‏.‏ فَرَاجَعْتُهُ قُلْتُ إِنَّا نَسْتَشْفِي بِهِ لِلْمَرِيضِ ‏.‏ قَالَ ‏""‏ إِنَّ ذَلِكَ لَيْسَ بِشِفَاءٍ وَلَكِنَّهُ دَاءٌ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الأطعمة ۳۲ (۳۸۰۱)، سنن الترمذی/الحج ۲۸ (۸۵۱)، الأطعمة ۴ (۱۷۹۲)، سنن النسائی/الحج ۸۹ (۲۸۳۹)، الصید ۲۷ (۴۳۲۸)،(تحفة الأشراف:۲۳۸۱)، وقد أخرجہ: مسند احمد (۳/۲۹۷،۳۱۸)، سنن الدارمی/المناسک۹۰ (۱۹۸۴),3236,It was\nnarrated that Tariq bin Suwaid Al-Hadrami said:,Chapters on Medicine
3237,"حَدَّثَنَا مُحَمَّدُ بْنُ عُبَيْدِ بْنِ عُتْبَةَ بْنِ عَبْدِ الرَّحْمَنِ الْكِنْدِيُّ، حَدَّثَنَا عَلِيُّ بْنُ ثَابِتٍ، حَدَّثَنَا سَعَّادُ بْنُ سُلَيْمَانَ، عَنْ أَبِي إِسْحَاقَ، عَنِ الْحَارِثِ، عَنْ عَلِيٍّ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ خَيْرُ الدَّوَاءِ الْقُرْآنُ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/الأطعمة ۴ (۱۷۹۲)،(تحفة الأشراف:۳۵۳۳),,It was\nnarrated from ‘Ali that the Messenger of Allah (ﷺ) said:,Chapters on Medicine
3238,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا زَيْدُ بْنُ الْحُبَابِ، حَدَّثَنَا فَائِدٌ، مَوْلَى عُبَيْدِ اللَّهِ بْنِ عَلِيِّ بْنِ أَبِي رَافِعٍ حَدَّثَنِي مَوْلاَىَ، عُبَيْدُ اللَّهِ حَدَّثَتْنِي جَدَّتِي، سَلْمَى أُمُّ رَافِعٍ مَوْلاَةُ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَتْ كَانَ لاَ يُصِيبُ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَرْحَةٌ وَلاَ شَوْكَةٌ إِلاَّ وَضَعَ عَلَيْهِ الْحِنَّاءَ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الأطعمة ۲۸ (۳۷۹۵)، سنن النسائی/الصید والذبائح ۲۶ (۴۳۲۵)،(تحفة الأشراف:۲۰۶۹)، وقد أخرجہ: مسند احمد (۴/۲۲۰)، سنن الدارمی/الصید ۸ (۲۰۵۹),3238,"Salma\nUmm Rafi’, the freed slave woman of the Messenger of Allah\n(ﷺ),\nsaid:",Chapters on Medicine
3239,"حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ، حَدَّثَنَا عَبْدُ الْوَهَّابِ، حَدَّثَنَا حُمَيْدٌ، عَنْ أَنَسٍ، أَنَّ نَاسًا، مِنْ عُرَيْنَةَ قَدِمُوا عَلَى رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ فَاجْتَوَوُا الْمَدِينَةَ فَقَالَ ـ صلى الله عليه وسلم ـ ‏ ‏ لَوْ خَرَجْتُمْ إِلَى ذَوْدٍ لَنَا فَشَرِبْتُمْ مِنْ أَلْبَانِهَا وَأَبْوَالِهَا ‏""""‏ ‏.‏ فَفَعَلُوا ‏.‏""",Al-Albani: Daif Isnaad; Muhammad Fouad Abd al-Baqi: Daif Isnaad; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۲۷۳، ومصباح الزجاجة:۱۱۱۳),,It was\nnarrated from Anas that some people from ‘Urainah came to the\nMessenger of Allah (ﷺ) but they were averse to the climate of\nAl-\nMadinah. He (ﷺ) said:,Chapters on Medicine
3240,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، عَنِ ابْنِ أَبِي ذِئْبٍ، عَنْ سَعِيدِ بْنِ خَالِدٍ، عَنْ أَبِي سَلَمَةَ، حَدَّثَنِي أَبُو سَعِيدٍ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ فِي أَحَدِ جَنَاحَىِ الذُّبَابِ سُمٌّ وَفِي الآخَرِ شِفَاءٌ فَإِذَا وَقَعَ فِي الطَّعَامِ فَامْقُلُوهُ فِيهِ فَإِنَّهُ يُقَدِّمُ السُّمَّ وَيُؤَخِّرُ الشِّفَاءَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الصید والذبائح ۷ (۱۹۵۱)،(تحفة الأشراف:۴۳۱۵)، وقد أخرجہ: مسند احمد (۳/۵،۱۹،۶۶),,Abu\nSa’eed narrated that the Messenger of Allah (ﷺ) said:,Chapters on Medicine
3241,"حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، حَدَّثَنَا مُسْلِمُ بْنُ خَالِدٍ، عَنْ عُتْبَةَ بْنِ مُسْلِمٍ، عَنْ عُبَيْدِ بْنِ حُنَيْنٍ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ إِذَا وَقَعَ الذُّبَابُ فِي شَرَابِكُمْ فَلْيَغْمِسْهُ فِيهِ ثُمَّ لْيَطْرَحْهُ فَإِنَّ فِي أَحَدِ جَنَاحَيْهِ دَاءً وَفِي الآخَرِ شِفَاءً ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الأطعمة ۱۰ (۵۳۹۱)،۱۴ (۵۴۰۰)، الذبائح ۳۳ (۵۵۳۷)، صحیح مسلم/الذبائح ۷ (۱۹۴۶)، سنن ابی داود/الأطعمة ۲۸ (۳۷۹۴)، سنن النسائی/الصید و الذبائح ۲۶ (۴۳۲۱)،(تحفة الأشراف:۳۵۰۴)، وقد أخرجہ: موطا امام مالک/الإستئذان ۴ (۱۰)، مسند احمد (۴/۸۸،۸۹)، سنن الدارمی/الصید ۸ (۲۰۶۰),,It was\nnarrated from Abu Hurairah that the Prophet (ﷺ) said:,Chapters on Medicine
3242,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا مُعَاوِيَةُ بْنُ هِشَامٍ، حَدَّثَنَا عَمَّارُ بْنُ رُزَيْقٍ، عَنْ عَبْدِ اللَّهِ بْنِ عِيسَى، عَنْ أُمَيَّةَ بْنِ هِنْدٍ، عَنْ عَبْدِ اللَّهِ بْنِ عَامِرِ بْنِ رَبِيعَةَ، عَنْ أَبِيهِ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ الْعَيْنُ حَقٌّ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۱۷۸)، وقد أخرجہ: صحیح البخاری/الصید ۳۳ اتم منہ (۵۵۳۶)، صحیح مسلم/الصید ۷ اتم منہ (۱۹۴۳)، سنن الترمذی/الأطعمة ۳ (۱۷۹۰)، موطا امام مالک/الإستئذان ۴ (۱۱)، مسند احمد (۲/۹،۱۰،۳۳،۴۱،۴۶،۶۰،۶۲،۷۴،۱۱۵)، سنن الدارمی/الصید ۸ (۲۰۵۸),,"It was\nnarrated from ‘Abdullah bin ‘Amir bin Rabi’ah, from his\nfather,\nthat the Prophet (ﷺ) said:",Chapters on Medicine
3243,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا إِسْمَاعِيلُ ابْنُ عُلَيَّةَ، عَنِ الْجُرَيْرِيِّ، عَنْ مُضَارِبِ بْنِ حَزْنٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ الْعَيْنُ حَقٌّ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الہبة ۵ (۲۵۷۲)، الصید ۱۰ (۵۴۸۹)،۳۲ (۵۵۳۵)، صحیح مسلم/الصید ۹ (۱۹۵۳)، سنن ابی داود/الأطعمة ۲۷ (۳۷۹۱)، سنن الترمذی/الأطعمة ۲ (۱۷۹۰)، سنن النسائی/الصید ۲۵ (۴۳۱۷)،(تحفة الأشراف:۱۶۲۹)، وقد أخرجہ: مسند احمد (۳/۱۱۸،۱۷۱،۲۹۱)، سنن الدارمی/الصید ۷ (۲۰۵۶),,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Medicine
3244,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا أَبُو هِشَامٍ الْمَخْزُومِيُّ، حَدَّثَنَا وُهَيْبٌ، عَنْ أَبِي وَاقِدٍ، عَنْ أَبِي سَلَمَةَ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ عَائِشَةَ، قَالَتْ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ اسْتَعِيذُوا بِاللَّهِ فَإِنَّ الْعَيْنَ حَقٌّ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الضحایا ۱۵ (۲۸۲۲)، سنن النسائی/الصید و الذبائح ۲۵ (۴۳۱۸)،(تحفة الأشراف:۱۱۲۲۴)، وقد أخرجہ: مسند احمد (۳/۴۷۱)، سنن الدارمی/الصید ۷ (۲۰۵۷),,It was\nnarrated from ‘Aishah that the Messenger of Allah (ﷺ) said:,Chapters on Medicine
3245,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا سُفْيَانُ، عَنِ الزُّهْرِيِّ، عَنْ أَبِي أُمَامَةَ بْنِ سَهْلِ بْنِ حُنَيْفٍ، قَالَ مَرَّ عَامِرُ بْنُ رَبِيعَةَ بِسَهْلِ بْنِ حُنَيْفٍ وَهُوَ يَغْتَسِلُ فَقَالَ لَمْ أَرَ كَالْيَوْمِ وَلاَ جِلْدَ مُخَبَّأَةٍ ‏.‏ فَمَا لَبِثَ أَنْ لُبِطَ بِهِ فَأُتِيَ بِهِ النَّبِيَّ ـ صلى الله عليه وسلم ـ فَقِيلَ لَهُ أَدْرِكْ سَهْلاً صَرِيعًا ‏.‏ قَالَ ‏""‏ مَنْ تَتَّهِمُونَ بِهِ ‏""‏ ‏.‏ قَالُوا عَامِرَ بْنَ رَبِيعَةَ ‏.‏ قَالَ ‏""‏ عَلاَمَ يَقْتُلُ أَحَدُكُمْ أَخَاهُ إِذَا رَأَى أَحَدُكُمْ مِنْ أَخِيهِ مَا يُعْجِبُهُ فَلْيَدْعُ لَهُ بِالْبَرَكَةِ ‏""‏ ‏.‏ ثُمَّ دَعَا بِمَاءٍ فَأَمَرَ عَامِرًا أَنْ يَتَوَضَّأَ فَيَغْسِلَ وَجْهَهُ وَيَدَيْهِ إِلَى الْمِرْفَقَيْنِ وَرُكْبَتَيْهِ وَدَاخِلَةَ إِزَارِهِ وَأَمَرَهُ أَنْ يَصُبَّ عَلَيْهِ ‏.‏ قَالَ سُفْيَانُ قَالَ مَعْمَرٌ عَنِ الزُّهْرِيِّ وَأَمَرَهُ أَنْ يَكْفَأَ الإِنَاءَ مِنْ خَلْفِهِ ‏.‏",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۵۳۳، ومصباح الزجاجة:۱۱۱۴),3245,It was\nnarrated that Abu Umamah bin Sahl bin Hunaif said:,Chapters on Medicine
3246,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عَمْرِو بْنِ دِينَارٍ، عَنْ عُرْوَةَ بْنِ عَامِرٍ، عَنْ عُبَيْدِ بْنِ رِفَاعَةَ الزُّرَقِيِّ، قَالَ قَالَتْ أَسْمَاءُ يَا رَسُولَ اللَّهِ إِنَّ بَنِي جَعْفَرٍ تُصِيبُهُمُ الْعَيْنُ فَأَسْتَرْقِي لَهُمْ قَالَ ‏ ‏ نَعَمْ فَلَوْ كَانَ شَىْءٌ سَابَقَ الْقَدَرَ سَبَقَتْهُ الْعَيْنُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الطہارة ۴۱ (۸۳)، سنن الترمذی/الطہارة ۵۲ (۶۹)، سنن النسائی/الطہارة ۴۷ (۵۹)، الصید ۳۵ (۴۳۶۱)،(تحفة الأشراف:۱۴۶۱۸)، وقد أخرجہ: موطا امام مالک/الطہارة ۳ (۱۲)، مسند احمد (۲/۳۷،۳۶۱،۳۷۳)، سنن الدارمی/الطہارة ۵۲ (۷۵۵),,It was\nnarrated that ‘Ubaid bin Rifa’ah Az-Zuraqi said:,Chapters on Medicine
3247,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا سَعِيدُ بْنُ سُلَيْمَانَ، عَنْ عَبَّادٍ، عَنِ الْجُرَيْرِيِّ، عَنْ أَبِي نَضْرَةَ، عَنْ أَبِي سَعِيدٍ، قَالَ كَانَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ يَتَعَوَّذُ مِنْ عَيْنِ الْجَانِّ وَأَعْيُنِ الإِنْسِ فَلَمَّا نَزَلَتِ الْمُعَوِّذَتَانِ أَخَذَهُمَا وَتَرَكَ مَا سِوَى ذَلِكَ ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الأطعمة ۳۶ (۳۸۱۵)،(تحفة الأشراف:۲۶۵۷),3247,It was\nnarrated that Abu Sa’eed said:,Chapters on Medicine
3248,حَدَّثَنَا عَلِيُّ بْنُ أَبِي الْخَصِيبِ، حَدَّثَنَا وَكِيعٌ، عَنْ سُفْيَانَ، وَمِسْعَرٍ، عَنْ مَعْبَدِ بْنِ خَالِدٍ، عَنْ عَبْدِ اللَّهِ بْنِ شَدَّادٍ، عَنْ عَائِشَةَ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ أَمَرَهَا أَنْ تَسْتَرْقِيَ مِنَ الْعَيْنِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۳۲۶، ومصباح الزجاجة:۱۱۱۵),3248,,Chapters on Medicine
3249,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا إِسْحَاقُ بْنُ سُلَيْمَانَ، عَنْ أَبِي جَعْفَرٍ الرَّازِيِّ، عَنْ حُصَيْنٍ، عَنِ الشَّعْبِيِّ، عَنْ بُرَيْدَةَ بْنِ الْحُصَيْبِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لاَ رُقْيَةَ إِلاَّ مِنْ عَيْنٍ أَوْ حُمَةٍ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفردبہ ابن ماجہ،(تحفة الأشراف:۱۷۴۹۸، ومصباح الزجاجة:۱۱۱۶)، وقد أخرجہ: مسند احمد (۶/۲۰۹،۲۳۸),,It was\nnarrated from Buraidah that the Messenger of Allah (ﷺ) said:,Chapters on Medicine
3250,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ إِدْرِيسَ، عَنْ مُحَمَّدِ بْنِ عُمَارَةَ، عَنْ أَبِي بَكْرِ بْنِ مُحَمَّدٍ، أَنَّ خَالِدَةَ بِنْتَ أَنَسٍ أُمَّ بَنِي حَزْمٍ السَّاعِدِيَّةَ، جَاءَتْ إِلَى النَّبِيِّ ـ صلى الله عليه وسلم ـ فَعَرَضَتْ عَلَيْهِ الرُّقَى فَأَمَرَهَا بِهَا ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/البیوع ۶۴ (۳۴۸۰)، سنن الترمذی/البیوع ۴۹ (۱۲۸۰)،(تحفة الأشراف:۲۸۹۴),3250,,Chapters on Medicine
3251,"حَدَّثَنَا عَلِيُّ بْنُ أَبِي الْخَصِيبِ، حَدَّثَنَا يَحْيَى بْنُ عِيسَى، عَنِ الأَعْمَشِ، عَنْ أَبِي سُفْيَانَ، عَنْ جَابِرٍ، قَالَ كَانَ أَهْلُ بَيْتٍ مِنَ الأَنْصَارِ يُقَالُ لَهُمْ آلُ عَمْرِو بْنِ حَزْمٍ يَرْقُونَ مِنَ الْحُمَةِ وَكَانَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ قَدْ نَهَى عَنِ الرُّقَى فَأَتَوْهُ فَقَالُوا يَا رَسُولَ اللَّهِ إِنَّكَ قَدْ نَهَيْتَ عَنِ الرُّقَى وَإِنَّا نَرْقِي مِنَ الْحُمَةِ ‏.‏ فَقَالَ لَهُمُ ‏""‏ اعْرِضُوا عَلَىَّ ‏""‏ ‏.‏ فَعَرَضُوهَا عَلَيْهِ فَقَالَ ‏""‏ لاَ بَأْسَ بِهَذِهِ هَذِهِ مَوَاثِيقُ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «أنظرحدیث رقم:۱۳۳۴،(تحفة الأشراف:۵۳۳۱),3251,It was\nnarrated that Jabir said:,Chapters on Medicine
3252,حَدَّثَنَا عَبْدَةُ بْنُ عَبْدِ اللَّهِ، حَدَّثَنَا مُعَاوِيَةُ بْنُ هِشَامٍ، حَدَّثَنَا سُفْيَانُ، عَنْ عَاصِمٍ، عَنْ يُوسُفَ بْنِ عَبْدِ اللَّهِ بْنِ الْحَارِثِ، عَنْ أَنَسٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ رَخَّصَ فِي الرُّقْيَةِ مِنَ الْحُمَةِ وَالْعَيْنِ وَالنَّمْلَةِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۶۷۰، ومصباح الزجاجة:۱۱۱۷)، وقد أخرجہ: مسند احمد (۲/۱۵۶),3252,,Chapters on Medicine
3253,حَدَّثَنَا عُثْمَانُ بْنُ أَبِي شَيْبَةَ، وَهَنَّادُ بْنُ السَّرِيِّ، قَالاَ حَدَّثَنَا أَبُو الأَحْوَصِ، عَنْ مُغِيرَةَ، عَنْ إِبْرَاهِيمَ، عَنِ الأَسْوَدِ، عَنْ عَائِشَةَ، قَالَتْ رَخَّصَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ فِي الرُّقْيَةِ مِنَ الْحَيَّةِ وَالْعَقْرَبِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الإیمان ۶ (۱۲)،۲۰ (۲۸)، الاستئذان ۹ (۶۲۳۶)، صحیح مسلم/الإیمان ۱۴ (۳۹)، سنن ابی داود/الأدب ۱۴۲ (۵۱۹۴)، سنن النسائی/الإیمان ۱۲ (۵۰۰۳)،(تحفة الأشراف:۸۹۲۷)، وقد أخرجہ: مسند احمد (۲/۱۵۶),3253,It was\nnarrated that ‘Aishah said:,Chapters on Medicine
3254,"حَدَّثَنَا إِسْمَاعِيلُ بْنُ بَهْرَامَ، حَدَّثَنَا عُبَيْدُ اللَّهِ الأَشْجَعِيُّ، عَنْ سُفْيَانَ، عَنْ سُهَيْلِ بْنِ أَبِي صَالِحٍ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ لَدَغَتْ عَقْرَبٌ رَجُلاً فَلَمْ يَنَمْ لَيْلَتَهُ فَقِيلَ لِلنَّبِيِّ ـ صلى الله عليه وسلم ـ إِنَّ فُلاَنًا لَدَغَتْهُ عَقْرَبٌ فَلَمْ يَنَمْ لَيْلَتَهُ ‏.‏ فَقَالَ ‏ ‏ أَمَا إِنَّهُ لَوْ قَالَ حِينَ أَمْسَى أَعُوذُ بِكَلِمَاتِ اللَّهِ التَّامَّاتِ مِنْ شَرِّ مَا خَلَقَ - مَا ضَرَّهُ لَدْغُ عَقْرَبٍ حَتَّى يُصْبِحَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الأشربة ۳۳ (۲۰۵۹)،(تحفة الأشراف:۲۸۲۸)، وقد أخرجہ: سنن الترمذی/الأطعمة ۲۱ (۱۸۲۰)، مسند احمد (۲/۴۰۷،۳/۳۰۱،۳۰۵،۳۸۲)، سنن الدارمی/الأطعمة ۱۴،۲۰۸۷),,It was\nnarrated that Abu Hurairah said:,Chapters on Medicine
3255,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَفَّانُ، حَدَّثَنَا عَبْدُ الْوَاحِدِ بْنُ زِيَادٍ، حَدَّثَنَا عُثْمَانُ بْنُ حَكِيمٍ، حَدَّثَنِي أَبُو بَكْرِ بْنُ عَمْرِو بْنِ حَزْمٍ، عَنْ عَمْرِو بْنِ حَزْمٍ، قَالَ عَرَضْتُ النَّهْشَةَ مِنَ الْحَيَّةِ عَلَى رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ فَأَمَرَ بِهَا ‏.‏,Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۵۳۵، ومصباح الزجاجة:۱۱۱۸),3255,It was\nnarrated that ‘Amr bin Hazm said:,Chapters on Medicine
3256,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا جَرِيرٌ، عَنْ مَنْصُورٍ، عَنْ أَبِي الضُّحَى، عَنْ مَسْرُوقٍ، عَنْ عَائِشَةَ، قَالَتْ كَانَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ إِذَا أَتَى الْمَرِيضَ فَدَعَا لَهُ قَالَ ‏ ‏ أَذْهِبِ الْبَاسْ رَبَّ النَّاسْ وَاشْفِ أَنْتَ الشَّافِي لاَ شِفَاءَ إِلاَّ شِفَاؤُكَ شِفَاءً لاَ يُغَادِرُ سَقَمًا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الأطعمة ۱۲ (۵۳۷۶،۵۳۹۷)،(تحفة الأشراف:۱۳۴۱۲)، وقد أخرجہ: صحیح مسلم/الأشربة ۳۴ (۲۰۶۲،۲۰۶۳)، سنن الترمذی/الأطعمة ۲۰ (۱۸۱۸،۱۸۱۹)، موطا امام مالک/صفة النبی صلی اللہ علیہ وسلم ۶ (۹)، مسند احمد (۲/۲۱،۴۳،۷۴،۱۴۵،۲۵۷،۴۱۵،۴۳۵،۴۳۷،۴۵۵،۳/۳۳۳،۳۴۶،۳۵۷،۳۹۲،۴/۳۳۶،۵/۳۷۰،۶/۳۳۵،۳۹۷)، سنن الدارمی/الأطعمة ۱۳ (۲۰۸۶),,It was\nnarrated that ‘Aishah said:,Chapters on Medicine
3257,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا سُفْيَانُ، عَنْ عَبْدِ رَبِّهِ، عَنْ عَمْرَةَ، عَنْ عَائِشَةَ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ كَانَ مِمَّا يَقُولُ لِلْمَرِيضِ بِبُزَاقِهِ بِإِصْبَعِهِ ‏ ‏ بِسْمِ اللَّهِ بِتُرْبَةِ أَرْضِنَا بِرِيقَةِ بَعْضِنَا لِيُشْفَى سَقِيمُنَا بِإِذْنِ رَبِّنَا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الأشربة ۳۴ (۲۰۶۰)،(تحفة الأشراف:۷۹۵۰)، وقد أخرجہ: صحیح البخاری/الأطعمة ۱۲ (۵۳۹۴،۵۳۹۵)، سنن الترمذی/الأطعمة ۲۰ (۱۸۱۸)، مسند احمد (۲/۲۱)، سنن الدارمی/الأطعمة ۱۳ (۲۰۸۴),,"It was\nnarrated from ‘Aishah that one of the things that the Prophet\n(ﷺ)\nused to say for the sick person, with saliva on his finger\n(dipped in\ndust), was:",Chapters on Medicine
3258,"حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا يَحْيَى بْنُ أَبِي بُكَيْرٍ، حَدَّثَنَا زُهَيْرُ بْنُ مُحَمَّدٍ، عَنْ يَزِيدَ بْنِ خُصَيْفَةَ، عَنْ عَمْرِو بْنِ عَبْدِ اللَّهِ بْنِ كَعْبٍ، عَنْ نَافِعِ بْنِ جُبَيْرٍ، عَنْ عُثْمَانَ بْنِ أَبِي الْعَاصِ الثَّقَفِيِّ، أَنَّهُ قَالَ قَدِمْتُ عَلَى النَّبِيِّ ـ صلى الله عليه وسلم ـ وَبِي وَجَعٌ قَدْ كَادَ يُبْطِلُنِي فَقَالَ لِيَ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏ ‏ اجْعَلْ يَدَكَ الْيُمْنَى عَلَيْهِ وَقُلْ بِسْمِ اللَّهِ أَعُوذُ بِعِزَّةِ اللَّهِ وَقُدْرَتِهِ مِنْ شَرِّ مَا أَجِدُ وَأُحَاذِرُ سَبْعَ مَرَّاتٍ ‏""""‏ ‏.‏ فَقُلْتُ ذَلِكَ فَشَفَانِيَ اللَّهُ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الأشربة ۳۴ (۲۰۶۱)،(تحقة الأشراف:۹۰۵۰)، وقد أخرجہ: سنن الترمذی/الأطعمة ۲۰ (۱۸۱۸),,It was\nnarrated that ‘Uthman bin Abul-‘As Thaqafi said:,Chapters on Medicine
3259,"حَدَّثَنَا بِشْرُ بْنُ هِلاَلٍ الصَّوَّافُ، حَدَّثَنَا عَبْدُ الْوَارِثِ، عَنْ عَبْدِ الْعَزِيزِ بْنِ صُهَيْبٍ، عَنْ أَبِي نَضْرَةَ، عَنْ أَبِي سَعِيدٍ، أَنَّ جِبْرَائِيلَ، أَتَى النَّبِيَّ ـ صلى الله عليه وسلم ـ فَقَالَ يَا مُحَمَّدُ اشْتَكَيْتَ قَالَ ‏ ‏ نَعَمْ ‏""""‏ ‏.‏ قَالَ بِسْمِ اللَّهِ أَرْقِيكَ مِنْ كُلِّ شَىْءٍ يُؤْذِيكَ مِنْ شَرِّ كُلِّ نَفْسٍ أَوْ عَيْنٍ أَوْ حَاسِدٍ اللَّهُ يَشْفِيكَ بِسْمِ اللَّهِ أَرْقِيكَ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/المناقب ۲۳ (۳۵۶۴)، الأطعمة ۲۱ (۵۴۰۹)، صحیح مسلم/الأشربة ۳۵ (۲۰۶۴)، سنن ابی داود/الأطعمة ۱۴ (۳۷۶۳)، سنن الترمذی/البروالصلة ۸۴ (۲۰۳۱)،(تحفة الأشراف:۱۳۴۰۳)، وقد أخرجہ: مسند احمد (۲/۴۷۴،۴۷۹،۴۸۱),,It was\nnarrated from Abu Sa’eed that Jibra’il came to the Prophet\n(ﷺ)\nand said:,Chapters on Medicine
3260,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، وَحَفْصُ بْنُ عُمَرَ، قَالاَ حَدَّثَنَا عَبْدُ الرَّحْمَنِ، حَدَّثَنَا سُفْيَانُ، عَنْ عَاصِمِ بْنِ عُبَيْدِ اللَّهِ، عَنْ زِيَادِ بْنِ ثُوَيْبٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ جَاءَ النَّبِيُّ ـ صلى الله عليه وسلم ـ يَعُودُنِي فَقَالَ لِي ‏""‏ أَلاَ أَرْقِيكَ بِرُقْيَةٍ جَاءَنِي بِهَا جِبْرَائِيلُ ‏""‏ ‏.‏ قُلْتُ بِأَبِي وَأُمِّي بَلَى يَا رَسُولَ اللَّهِ ‏.‏ قَالَ ‏""‏ بِسْمِ اللَّهِ أَرْقِيكَ وَاللَّهُ يَشْفِيكَ مِنْ كُلِّ دَاءٍ فِيكَ مِنْ شَرِّ النَّفَّاثَاتِ فِي الْعُقَدِ وَمِنْ شَرِّ حَاسِدٍ إِذَا حَسَدَ ‏""‏ ‏.‏ ثَلاَثَ مَرَّاتٍ ‏.‏",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۴۴۵، ومصباح الزجاجة:۱۱۱۹),3260,It was\nnarrated that Abu Hurairah said:,Chapters on Medicine
3261,"حَدَّثَنَا مُحَمَّدُ بْنُ سُلَيْمَانَ بْنِ هِشَامٍ الْبَغْدَادِيُّ، حَدَّثَنَا وَكِيعٌ، ح وَحَدَّثَنَا أَبُو بَكْرِ بْنُ خَلاَّدٍ الْبَاهِلِيُّ، حَدَّثَنَا أَبُو عَامِرٍ، قَالاَ حَدَّثَنَا سُفْيَانُ، عَنْ مَنْصُورٍ، عَنْ مِنْهَالٍ، عَنْ سَعِيدِ بْنِ جُبَيْرٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ كَانَ النَّبِيُّ ـ صلى الله عليه وسلم ـ يُعَوِّذُ الْحَسَنَ وَالْحُسَيْنَ يَقُولُ ‏""‏ أَعُوذُ بِكَلِمَاتِ اللَّهِ التَّامَّةِ مِنْ كُلِّ شَيْطَانٍ وَهَامَّةٍ وَمِنْ كُلِّ عَيْنٍ لاَمَّةٍ ‏""‏ ‏.‏ قَالَ ‏""‏ وَكَانَ أَبُونَا إِبْرَاهِيمُ يَعُوِّذُ بِهَا إِسْمَاعِيلَ وَإِسْحَاقَ ‏""‏ ‏.‏ أَوْ قَالَ ‏""‏ إِسْمَاعِيلَ وَيَعْقُوبَ ‏""‏ ‏.‏ وَهَذَا حَدِيثُ وَكِيعٍ ‏.‏",Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۴۲۲۹، ومصباح الزجاجة:۱۱۲۰),3261,It was\nnarrated that Ibn ‘Abbas said:,Chapters on Medicine
3262,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا أَبُو عَامِرٍ، حَدَّثَنَا إِبْرَاهِيمُ الأَشْهَلِيُّ، عَنْ دَاوُدَ بْنِ حُصَيْنٍ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ كَانَ يُعَلِّمُهُمْ مِنَ الْحُمَّى وَمِنَ الأَوْجَاعِ كُلِّهَا أَنْ يَقُولُوا ‏""‏ بِسْمِ اللَّهِ الْكَبِيرِ أَعُوذُ بِاللَّهِ الْعَظِيمِ مِنْ شَرِّ عِرْقٍ نَعَّارٍ وَمِنْ شَرِّ حَرِّ النَّارِ ‏""‏ ‏.‏ قَالَ أَبُو عَامِرٍ أَنَا أُخَالِفُ النَّاسَ فِي هَذَا أَقُولُ يَعَّارٍ ‏.‏ حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ الدِّمَشْقِيُّ، حَدَّثَنَا ابْنُ أَبِي فُدَيْكٍ، أَخْبَرَنِي إِبْرَاهِيمُ بْنُ إِسْمَاعِيلَ بْنِ أَبِي حَبِيبَةَ الأَشْهَلِيُّ، عَنْ دَاوُدَ بْنِ الْحُصَيْنِ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ نَحْوَهُ وَقَالَ ‏""""‏ مِنْ شَرِّ عِرْقٍ نَعَّارٍ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الأطعمة ۱۳ (۵۳۹۸،۵۳۹۹)، سنن ابی داود/الأطعمة ۱۷ (۳۷۶۹)، سنن الترمذی/الاطعمة ۲۸ (۱۸۳۰)،(تحفة الأشراف:۱۱۸۰۱)، وقد أخرجہ: مسند احمد (۴/۳۰۸،۳۰۹)، سنن الدارمی/الأطعمة ۳۱ (۲۱۱۵),,"It was\nnarrated from Ibn ‘Abbas that, for fever and all kinds of\npain, the\nProphet (ﷺ) used to teach them to say:",Chapters on Medicine
3263,حَدَّثَنَا عَمْرُو بْنُ عُثْمَانَ بْنِ سَعِيدِ بْنِ كَثِيرِ بْنِ دِينَارٍ الْحِمْصِيُّ، حَدَّثَنَا أَبِي، عَنِ ابْنِ ثَوْبَانَ، عَنْ عُمَيْرٍ، أَنَّهُ سَمِعَ جُنَادَةَ بْنَ أَبِي أُمَيَّةَ، قَالَ سَمِعْتُ عُبَادَةَ بْنَ الصَّامِتِ، يَقُولُ أَتَى جِبْرَائِيلُ عَلَيْهِ السَّلاَمُ النَّبِيَّ ـ صلى الله عليه وسلم ـ وَهُوَ يُوعَكُ فَقَالَ بِسْمِ اللَّهِ أَرْقِيكَ مِنْ كُلِّ شَىْءٍ يُؤْذِيكَ مِنْ حَسَدِ حَاسِدٍ وَمِنْ كُلِّ عَيْنٍ اللَّهُ يَشْفِيكَ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۲۰۲، ومصباح الزجاجة:۱۱۲۱)، وقد أخرج بعضہ: سنن ابی داود/الأطعمة ۱۸ (۳۷۷۳),3263,It was\nnarrated from ‘Umair that he heard Junadah bin Abu Umayyah\nsay:,Chapters on Medicine
3264,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مَيْمُونٍ الرَّقِّيُّ، وَسَهْلُ بْنُ أَبِي سَهْلٍ، قَالُوا حَدَّثَنَا وَكِيعٌ، عَنْ مَالِكِ بْنِ أَنَسٍ، عَنِ الزُّهْرِيِّ، عَنْ عُرْوَةَ، عَنْ عَائِشَةَ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ كَانَ يَنْفِثُ فِي الرُّقْيَةِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۶۲۶۷، ومصباح الزجاجة:۱۱۲۲)، وقد أخر جہ: سنن ابی داود/الأطعمة ۱۶ (۳۷۶۷)، سنن الترمذی/الأطعمة ۴۷ (۱۸۵۸)، مسند احمد (۶/۱۴۳،۲۰۷،۲۴۶،۲۶۵)، سنن الدارمی/الأطعمة ۱ (۲۰۶۳),3264,,Chapters on Medicine
3265,حَدَّثَنَا سَهْلُ بْنُ أَبِي سَهْلٍ، قَالَ حَدَّثَنَا مَعْنُ بْنُ عِيسَى، ح وَحَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا بِشْرُ بْنُ عُمَرَ، قَالاَ حَدَّثَنَا مَالِكٌ، عَنِ ابْنِ شِهَابٍ، عَنْ عُرْوَةَ، عَنْ عَائِشَةَ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ كَانَ إِذَا اشْتَكَى يَقْرَأُ عَلَى نَفْسِهِ الْمُعَوِّذَاتِ وَيَنْفِثُ فَلَمَّا اشْتَدَّ وَجَعُهُ كُنْتُ أَقْرَأُ عَلَيْهِ وَأَمْسَحُ بِيَدِهِ رَجَاءَ بَرَكَتِهَا ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Hasan,takhreej: «سنن الترمذی/الأطعمة ۴۷ (۱۸۵۷)،(تحفة الأشراف:۱۰۶۸۵)، وقد أخرجہ: صحیح البخاری/الأطعمة ۲ (۵۳۷۶)، صحیح مسلم/الأشربة ۱۳ (۲۰۲۲)، سنن ابی داود/الأطعمة ۲۰ (۳۷۷۷)، موطا امام مالک/صفة النبیﷺ ۱۰ (۳۲)، مسند احمد (۴/۲۷)، سنن الدارمی/الأطعمة ۱ (۲۰۶۲),3265,It was\nnarrated from ‘Aishah:,Chapters on Medicine
3266,"حَدَّثَنَا أَيُّوبُ بْنُ مُحَمَّدٍ الرَّقِّيُّ، حَدَّثَنَا مُعَمَّرُ بْنُ سُلَيْمَانَ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ بِشْرٍ، عَنِ الأَعْمَشِ، عَنْ عَمْرِو بْنِ مُرَّةَ، عَنْ يَحْيَى بْنِ الْجَزَّارِ، عَنِ ابْنِ أُخْتِ، زَيْنَبَ امْرَأَةِ عَبْدِ اللَّهِ عَنْ زَيْنَبَ، قَالَتْ كَانَتْ عَجُوزٌ تَدْخُلُ عَلَيْنَا تَرْقِي مِنَ الْحُمْرَةِ وَكَانَ لَنَا سَرِيرٌ طَوِيلُ الْقَوَائِمِ وَكَانَ عَبْدُ اللَّهِ إِذَا دَخَلَ تَنَحْنَحَ وَصَوَّتَ فَدَخَلَ يَوْمًا فَلَمَّا سَمِعَتْ صَوْتَهُ احْتَجَبَتْ مِنْهُ فَجَاءَ فَجَلَسَ إِلَى جَانِبِي فَمَسَّنِي فَوَجَدَ مَسَّ خَيْطٍ فَقَالَ مَا هَذَا فَقُلْتُ رُقًى لِي فِيهِ مِنَ الْحُمْرَةِ فَجَذَبَهُ وَقَطَعَهُ فَرَمَى بِهِ وَقَالَ لَقَدْ أَصْبَحَ آلُ عَبْدِ اللَّهِ أَغْنِيَاءَ عَنِ الشِّرْكِ سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏""‏ إِنَّ الرُّقَى وَالتَّمَائِمَ وَالتِّوَلَةَ شِرْكٌ ‏""‏ ‏.‏ قُلْتُ فَإِنِّي خَرَجْتُ يَوْمًا فَأَبْصَرَنِي فُلاَنٌ فَدَمَعَتْ عَيْنِي الَّتِي تَلِيهِ فَإِذَا رَقَيْتُهَا سَكَنَتْ دَمْعَتُهَا وَإِذَا تَرَكْتُهَا دَمَعَتْ ‏.‏ قَالَ ذَاكِ الشَّيْطَانُ إِذَا أَطَعْتِيهِ تَرَكَكِ وَإِذَا عَصَيْتِيهِ طَعَنَ بِإِصْبَعِهِ فِي عَيْنِكِ وَلَكِنْ لَوْ فَعَلْتِ كَمَا فَعَلَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ كَانَ خَيْرًا لَكِ وَأَجْدَرَ أَنْ تَشْفِينَ تَنْضَحِينَ فِي عَيْنِكِ الْمَاءَ وَتَقُولِينَ ‏""‏ أَذْهِبِ الْبَاسْ رَبَّ النَّاسْ اشْفِ أَنْتَ الشَّافِي لاَ شِفَاءَ إِلاَّ شِفَاؤُكَ شِفَاءً لاَ يُغَادِرُ سَقَمًا ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۵۴۲۰، ومصباح الزجاجة:۱۱۲۳)، وقد أخرجہ: مسند احمد (۲/۳۴۹),3266,It was\nnarrated that Zainab said:,Chapters on Medicine
3267,"حَدَّثَنَا عَلِيُّ بْنُ أَبِي الْخَصِيبِ، حَدَّثَنَا وَكِيعٌ، عَنْ مُبَارَكٍ، عَنِ الْحَسَنِ، عَنْ عِمْرَانَ بْنِ الْحُصَيْنِ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ رَأَى رَجُلاً فِي يَدِهِ حَلْقَةٌ مِنْ صُفْرٍ فَقَالَ ‏""‏ مَا هَذِهِ الْحَلْقَةُ ‏""‏ ‏.‏ قَالَ هَذِهِ مِنَ الْوَاهِنَةِ ‏.‏ قَالَ ‏""‏ انْزِعْهَا فَإِنَّهَا لاَ تَزِيدُكَ إِلاَّ وَهْنًا ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الأطعمة ۲ (۵۳۷۶)، صحیح مسلم/الإشربة ۱۳ (۲۰۲۲)، سنن النسائی/الیوم و اللیلة (۲۷۸،۲۷۹،۲۸۰)،(تحفة الأشراف:۱۰۶۸۸)، وقد أخرجہ: موطا امام مالک/صفة النبیﷺ ۱۰ (۳۲)، مسند احمد (۴/ ۲۶)، سنن الدارمی/الأطمة ۱ (۲۰۶۲),3267,It was\nnarrated from ‘Imran bin Husain that the Prophet (ﷺ) saw a\nman\nwith a brass ring on his hand. He said:,Chapters on Medicine
3268,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ سُلَيْمَانَ، عَنْ يَزِيدَ بْنِ أَبِي زِيَادٍ، عَنْ سُلَيْمَانَ بْنِ عَمْرِو بْنِ الأَحْوَصِ، عَنْ أُمِّ جُنْدَبٍ، قَالَتْ رَأَيْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ رَمَى جَمْرَةَ الْعَقَبَةِ مِنْ بَطْنِ الْوَادِي يَوْمَ النَّحْرِ ثُمَّ انْصَرَفَ وَتَبِعَتْهُ امْرَأَةٌ مِنْ خَثْعَمٍ وَمَعَهَا صَبِيٌّ لَهَا بِهِ بَلاَءٌ لاَ يَتَكَلَّمُ فَقَالَتْ يَا رَسُولَ اللَّهِ إِنَّ هَذَا ابْنِي وَبَقِيَّةُ أَهْلِي وَإِنَّ بِهِ بَلاَءً لاَ يَتَكَلَّمُ ‏.‏ فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏""‏ ائْتُونِي بِشَىْءٍ مِنْ مَاءٍ ‏""‏ ‏.‏ فَأُتِيَ بِمَاءٍ فَغَسَلَ يَدَيْهِ وَمَضْمَضَ فَاهُ ثُمَّ أَعْطَاهَا فَقَالَ ‏""‏ اسْقِيهِ مِنْهُ وَصُبِّي عَلَيْهِ مِنْهُ وَاسْتَشْفِي اللَّهَ لَهُ ‏""‏ ‏.‏ قَالَتْ فَلَقِيتُ الْمَرْأَةَ فَقُلْتُ لَوْ وَهَبْتِ لِي مِنْهُ ‏.‏ فَقَالَتْ إِنَّمَا هُوَ لِهَذَا الْمُبْتَلَى ‏.‏ قَالَتْ فَلَقِيتُ الْمَرْأَةَ مِنَ الْحَوْلِ فَسَأَلْتُهَا عَنِ الْغُلاَمِ فَقَالَتْ بَرَأَ وَعَقَلَ عَقْلاً لَيْسَ كَعُقُولِ النَّاسِ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الأشربة ۱۳ (۲۰۱۹)، اللباس ۲۰ (۲۰۹۹)،(تحفة الأشراف:۲۹۱۷)، وقد أخرجہ: سنن ابی داود/اللباس ۴۴ (۴۱۳۷)، موطا امام مالک/صفة النبیﷺ ۴ (۵)، مسند احمد (۳/۳۳۴،۳۴۹),3268,It was\nnarrated that Umm Jundub said:,Chapters on Medicine
3269,حَدَّثَنَا مُحَمَّدُ بْنُ عُبَيْدِ بْنِ عُتْبَةَ بْنِ عَبْدِ الرَّحْمَنِ الْكِنْدِيُّ حَدَّثَنَا عَلِيُّ بْنُ ثَابِتٍ حَدَّثَنَا مُعَّادُ بْنُ سُلَيْمَانَ عَنْ أَبِي إِسْحَقَ عَنْ الْحَارِثِ عَنْ عَلِيٍّ رَضِيَ اللَّهُ عَنْهُ قَالَ قَالَ رَسُولُ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ خَيْرُ الدَّوَاءِ الْقُرْآنُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «حدیث جابر تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۴۶۷)، وحدیث ابن عباس أخرجہ: صحیح البخاری/الأطعمة ۵۲ (۵۴۵۶)، صحیح مسلم/الأشربة ۱۸ (۲۰۳۱)،(تحفة الأشراف:۵۹۴۲)، وقد أخرجہ: سنن ابی داود/الأطعمة ۵۲ (۳۸۴۷)، مسند احمد (۱/۲۹۳،۳۴۶،۳۷۰)، سنن الدارمی/الأطعمة ۶ (۲۰۶۹),3269,It was\nnarrated from ‘Ali that the Messenger of Allah (ﷺ) said:,Chapters on Medicine
3270,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدَةُ بْنُ سُلَيْمَانَ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، قَالَتْ أَمَرَ النَّبِيُّ ـ صلى الله عليه وسلم ـ بِقَتْلِ ذِي الطُّفْيَتَيْنِ فَإِنَّهُ يَلْتَمِسُ الْبَصَرَ وَيُصِيبُ الْحَبَلَ ‏.‏ يَعْنِي حَيَّةً خَبِيثَةً ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الأشربة ۱۸ (۲۰۳۳)،(تحفة الأشراف:۲۷۴۵)، وقد أخرجہ: مسند احمد (۳/۳۰۱،۳۳۱،۳۳۷،۳۶۵،۳۹۳),3270,It was\nnarrated that ‘Aishah said:,Chapters on Medicine
3271,"حَدَّثَنَا أَحْمَدُ بْنُ عَمْرِو بْنِ السَّرْحِ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، أَخْبَرَنِي يُونُسُ، عَنِ ابْنِ شِهَابٍ، عَنْ سَالِمٍ، عَنْ أَبِيهِ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ اقْتُلُوا الْحَيَّاتِ وَاقْتُلُوا ذَا الطُّفْيَتَيْنِ وَالأَبْتَرَ فَإِنَّهُمَا يَلْتَمِسَانِ الْبَصَرَ وَيُسْقِطَانِ الْحَبَلَ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: سنن الترمذی/الأطعمة ۱۱ (۱۸۰۴)،(تحفة الأشراف:۱۱۵۸۸)، وقد أخرجہ: مسند احمد (۵/۷۶)، سنن الدارمی/الأطمة ۷ (۲۰۷۰),,"it was\nnarrated from Salim, from his father, that the Messenger of\nAllah\n(ﷺ) said:",Chapters on Medicine
3272,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا عَبْدَةُ بْنُ سُلَيْمَانَ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو، عَنْ أَبِي سَلَمَةَ، عَنْ أَبِي هُرَيْرَةَ، قَالَ كَانَ النَّبِيُّ ـ صلى الله عليه وسلم ـ يُعْجِبُهُ الْفَأْلُ الْحَسَنُ وَيَكْرَهُ الطِّيَرَةَ ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «أنظر ما قبلہ,3272,It was\nnarrated that Abu Hurairah said:,Chapters on Medicine
3273,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، أَنْبَأَنَا شُعْبَةُ، عَنْ قَتَادَةَ، عَنْ أَنَسٍ، قَالَ قَالَ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏ ‏ لاَ عَدْوَى وَلاَ طِيَرَةَ وَأُحِبُّ الْفَأْلَ الصَّالِحَ ‏""""‏ ‏.‏""",Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۳۲۷، ومصباح الزجاجة:۱۱۲۴),,It was\nnarrated that Anas said:,Chapters on Medicine
3274,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا وَكِيعٌ، عَنْ سُفْيَانَ، عَنْ سَلَمَةَ، عَنْ عِيسَى بْنِ عَاصِمٍ، عَنْ زِرٍّ، عَنْ عَبْدِ اللَّهِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ الطِّيَرَةُ شِرْكٌ وَمَا مِنَّا إِلاَّ وَلَكِنَّ اللَّهَ يُذْهِبُهُ بِالتَّوَكُّلِ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/الأطعمة ۴۱ (۱۸۴۸)،(تحفة الأشراف:۱۰۰۱۶),,It was\nnarrated from ‘Abdullah that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Medicine
3275,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو الأَحْوَصِ، عَنْ سِمَاكٍ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لاَ عَدْوَى وَلاَ طِيَرَةَ وَلاَ هَامَةَ وَلاَ صَفَرَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الأطعمة ۱۸ (۳۷۷۳)،(تحفة الأشراف:۵۱۹۹),,It was\nnarrated from Ibn ‘Abbas that the Messenger of Allah (ﷺ) said:,Chapters on Medicine
3276,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا وَكِيعٌ، عَنْ أَبِي جَنَابٍ، عَنْ أَبِيهِ، عَنِ ابْنِ عُمَرَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏""‏ لاَ عَدْوَى وَلاَ طِيَرَةَ وَلاَ هَامَةَ ‏""‏ ‏.‏ فَقَامَ إِلَيْهِ رَجُلٌ فَقَالَ يَا رَسُولَ اللَّهِ الْبَعِيرُ يَكُونُ بِهِ الْجَرَبُ فَتَجْرَبُ بِهِ الإِبِلُ ‏.‏ قَالَ ‏""‏ ذَلِكَ الْقَدَرُ فَمَنْ أَجْرَبَ الأَوَّلَ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۷۴۳، ومصباح الزجاجة:۱۱۲۵)، وقد أخرجہ: مسند احمد (۳/۴۹۰),3276,Ibn\n‘Umar said:,Chapters on Medicine
3277,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو، عَنْ أَبِي سَلَمَةَ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لاَ يُورِدُ الْمُمْرِضُ عَلَى الْمُصِحِّ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الأطعمة ۱۸ (۳۷۷۲)، سنن الترمذی/الأطعمة ۱۲ (۱۸۰۵)،(تحفة الأشراف:۵۵۶۶)، وقد أخرجہ: مسند احمد (۱/۲۷۰،۳۰۰،۳۴۳،۳۴۳،۳۴۵،۳۶۴)، سنن الدارمی/الأطعمة ۱۶ (۲۰۹۰),,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Medicine
3278,"حَدَّثَنَا أَبُو بَكْرٍ، وَمُجَاهِدُ بْنُ مُوسَى، وَمُحَمَّدُ بْنُ خَلَفٍ الْعَسْقَلاَنِيُّ، قَالُوا حَدَّثَنَا يُونُسُ بْنُ مُحَمَّدٍ، حَدَّثَنَا مُفَضَّلُ بْنُ فَضَالَةَ، عَنْ حَبِيبِ بْنِ الشَّهِيدِ، عَنْ مُحَمَّدِ بْنِ الْمُنْكَدِرِ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ أَخَذَ بِيَدِ رَجُلٍ مَجْذُومٍ فَأَدْخَلَهَا مَعَهُ فِي الْقَصْعَةِ ثُمَّ قَالَ ‏ ‏ كُلْ ثِقَةً بِاللَّهِ وَتَوَكُّلاً عَلَى اللَّهِ ‏""""‏ ‏.‏""",Al-Albani: Daif Isnaad; Muhammad Fouad Abd al-Baqi: Daif Isnaad; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۴۶۹، ومصباح الزجاجة:۱۱۲۶)، وقد أخرجہ: سنن الدارمی/الأطعمة ۸ (۲۰۷۲),,"It was\nnarrated from Jabir bin ‘Abdullah that the Messenger of Allah\n(ﷺ)\ntook the hand of a leper and made him eat with him, and said:",Chapters on Medicine
3279,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نَافِعٍ، عَنِ ابْنِ أَبِي الزِّنَادِ، ح وَحَدَّثَنَا عَلِيُّ بْنُ أَبِي الْخَصِيبِ، حَدَّثَنَا وَكِيعٌ، عَنْ عَبْدِ اللَّهِ بْنِ سَعِيدِ بْنِ أَبِي هِنْدٍ، جَمِيعًا عَنْ مُحَمَّدِ بْنِ عَبْدِ اللَّهِ بْنِ عَمْرِو بْنِ عُثْمَانَ، عَنْ أُمِّهِ، فَاطِمَةَ بِنْتِ الْحُسَيْنِ عَنِ ابْنِ عَبَّاسٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ لاَ تُدِيمُوا النَّظَرَ إِلَى الْمَجْذُومِينَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الأشربة ۱۸ (۲۰۳۳)، سنن الترمذی/الأطعمة ۱۱ (۱۸۰۲)،(تحفة الأشراف:۲۳۰۵)، وقد أخرجہ: مسند احمد (۳/۳۱۵),,It was\nnarrated from Ibn ‘Abbas that the Prophet (ﷺ) said:,Chapters on Medicine
3280,"حَدَّثَنَا عَمْرُو بْنُ رَافِعٍ، حَدَّثَنَا هُشَيْمٌ، عَنْ يَعْلَى بْنِ عَطَاءٍ، عَنْ رَجُلٍ، مِنْ آلِ الشَّرِيدِ يُقَالُ لَهُ عَمْرٌو عَنْ أَبِيهِ قَالَ كَانَ فِي وَفْدِ ثَقِيفٍ رَجُلٌ مَجْذُومٌ فَأَرْسَلَ إِلَيْهِ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏ ‏ ارْجِعْ فَقَدْ بَايَعْنَاكَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الأنبیاء ۳۲ (۳۴۱۱)،۴۶ (۳۴۳۳)، فضائل الصحابة ۳۰ (۴۷۶۹)، الأطعمة ۲۵ (۵۴۱۸)، صحیح مسلم/فضائل الصحابة ۱۲ (۲۴۳۱)، سنن الترمذی/الأطعمة ۳۱ (۱۸۳۴)، سنن النسائی/عشرة النساء ۳ (۳۳۹۹)،(تحفة الأشراف:۹۰۲۹)، وقد أخرجہ: مسند احمد (۴/۳۹۴،۴۰۹),,"It was\nnarrated from a man from the family of Sharid whose name was\n‘Amr,\nthat his father said:",Chapters on Medicine
3281,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، عَنْ هِشَامٍ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، قَالَتْ سَحَرَ النَّبِيَّ ـ صلى الله عليه وسلم ـ يَهُودِيٌّ مِنْ يَهُودِ بَنِي زُرَيْقٍ يُقَالُ لَهُ لَبِيدُ بْنُ الأَعْصَمِ حَتَّى كَانَ النَّبِيُّ ـ صلى الله عليه وسلم ـ يُخَيَّلُ إِلَيْهِ أَنَّهُ يَفْعَلُ الشَّىْءَ وَلاَ يَفْعَلُهُ ‏.‏ قَالَتْ حَتَّى إِذَا كَانَ ذَاتَ يَوْمٍ أَوْ كَانَ ذَاتَ لَيْلَةٍ دَعَا رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ثُمَّ دَعَا ثُمَّ دَعَا ثُمَّ قَالَ ‏""‏ يَا عَائِشَةُ أَشَعَرْتِ أَنَّ اللَّهَ قَدْ أَفْتَانِي فِيمَا اسْتَفْتَيْتُهُ فِيهِ جَاءَنِي رَجُلاَنِ فَجَلَسَ أَحَدُهُمَا عِنْدَ رَأْسِي وَالآخَرُ عِنْدَ رِجْلِي فَقَالَ الَّذِي عِنْدَ رَأْسِي لِلَّذِي عِنْدَ رِجْلِي أَوِ الَّذِي عِنْدَ رِجْلِي لِلَّذِي عِنْدَ رَأْسِي مَا وَجَعُ الرَّجُلِ قَالَ مَطْبُوبٌ ‏.‏ قَالَ مَنْ طَبَّهُ قَالَ لَبِيدُ بْنُ الأَعْصَمِ ‏.‏ قَالَ فِي أَىِّ شَىْءٍ قَالَ فِي مُشْطٍ وَمُشَاطَةٍ وَجُفِّ طَلْعَةِ ذَكَرٍ ‏.‏ قَالَ وَأَيْنَ هُوَ قَالَ فِي بِئْرِ ذِي أَرْوَانَ ‏""‏ ‏.‏ قَالَتْ فَأَتَاهُ النَّبِيُّ ـ صلى الله عليه وسلم ـ فِي أُنَاسٍ مِنْ أَصْحَابِهِ ثُمَّ جَاءَ فَقَالَ ‏""‏ وَاللَّهِ يَا عَائِشَةُ لَكَأَنَّ مَاءَهَا نُقَاعَةُ الْحِنَّاءِ وَلَكَأَنَّ نَخْلَهَا رُءُوسُ الشَّيَاطِينِ ‏""‏ ‏.‏ قَالَتْ قُلْتُ يَا رَسُولَ اللَّهِ أَفَلاَ أَحْرَقْتَهُ قَالَ ‏""‏ لاَ أَمَّا أَنَا فَقَدْ عَافَانِيَ اللَّهُ وَكَرِهْتُ أَنْ أُثِيرَ عَلَى النَّاسِ مِنْهُ شَرًّا ‏""‏ ‏.‏ فَأَمَرَ بِهَا فَدُفِنَتْ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/فضائل الصحابة ۳۰ (۳۷۷۰)، صحیح مسلم/فضائل الصحابة ۱۳ (۲۴۴۶)، سنن الترمذی/المناقب ۶۲ (۳۸۸۷)،(تحفة الأشراف:۹۷۰)، وقد أخرجہ: مسند احمد (۳/۱۵۶،۲۶۴)، سنن الدارمی/الأطعمة ۲۹ (۲۱۱۳),3281,It was\nnarrated that ‘Aishah said:,Chapters on Medicine
3282,"حَدَّثَنَا يَحْيَى بْنُ عُثْمَانَ بْنِ سَعِيدِ بْنِ كَثِيرِ بْنِ دِينَارٍ الْحِمْصِيُّ، حَدَّثَنَا بَقِيَّةُ، حَدَّثَنَا أَبُو بَكْرٍ الْعَنْسِيُّ، عَنْ يَزِيدَ بْنِ أَبِي حَبِيبٍ، وَمُحَمَّدِ بْنِ يَزِيدَ الْمِصْرِيَّيْنِ، قَالاَ حَدَّثَنَا نَافِعٌ، عَنِ ابْنِ عُمَرَ، قَالَ قَالَتْ أُمُّ سَلَمَةَ يَا رَسُولَ اللَّهِ لاَ يَزَالُ يُصِيبُكَ كُلَّ عَامٍ وَجَعٌ مِنَ الشَّاةِ الْمَسْمُومَةِ الَّتِي أَكَلْتَ ‏.‏ قَالَ ‏ ‏ مَا أَصَابَنِي شَىْءٌ مِنْهَا إِلاَّ وَهُوَ مَكْتُوبٌ عَلَىَّ وَآدَمُ فِي طِينَتِهِ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الأطعمة ۵۳ (۵۴۵۷)،(تحفة الأشراف:۲۲۵۱)، وقد أخرجہ: سنن ابی داود/الطہارة ۷۵ (۱۹۱)، سنن الترمذی/الطہارة ۵۹ (۸۰),,It was\nnarrated from Ibn ‘Umar that Umm Salamah said:,Chapters on Medicine
3283,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَفَّانُ، حَدَّثَنَا وُهَيْبٌ، حَدَّثَنَا مُحَمَّدُ بْنُ عَجْلاَنَ، عَنْ يَعْقُوبَ بْنِ عَبْدِ اللَّهِ بْنِ الأَشَجِّ، عَنْ سَعِيدِ بْنِ الْمُسَيَّبِ، عَنْ سَعْدِ بْنِ مَالِكٍ، عَنْ خَوْلَةَ بِنْتِ حَكِيمٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ لَوْ أَنَّ أَحَدَكُمْ إِذَا نَزَلَ مَنْزِلاً قَالَ أَعُوذُ بِكَلِمَاتِ اللَّهِ التَّامَّةِ مِنْ شَرِّ مَا خَلَقَ - لَمْ يَضُرَّهُ فِي ذَلِكَ الْمَنْزِلِ شَىْءٌ حَتَّى يَرْتَحِلَ مِنْهُ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/الدعوات ۵۷ (۳۴۵۷)،(تحفة الأشراف:۴۴۴۲)، وقد أخرجہ: سنن ابی داود/الأطعمة ۵۳ (۳۸۵۰)، مسند احمد (۳/۳۲،۹۸),,It was\nnarrated from Khawlah bint Hakim that the Prophet (ﷺ) said:,Chapters on Medicine
3284,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ الأَنْصَارِيُّ، حَدَّثَنِي عُيَيْنَةُ بْنُ عَبْدِ الرَّحْمَنِ، حَدَّثَنِي أَبِي، عَنْ عُثْمَانَ بْنِ أَبِي الْعَاصِ، قَالَ لَمَّا اسْتَعْمَلَنِي رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَلَى الطَّائِفِ جَعَلَ يَعْرِضُ لِي شَىْءٌ فِي صَلاَتِي حَتَّى مَا أَدْرِي مَا أُصَلِّي فَلَمَّا رَأَيْتُ ذَلِكَ رَحَلْتُ إِلَى رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ فَقَالَ ‏""‏ ابْنُ أَبِي الْعَاصِ ‏""‏ ‏.‏ قُلْتُ نَعَمْ يَا رَسُولَ اللَّهِ ‏.‏ قَالَ ‏""‏ مَا جَاءَ بِكَ ‏""‏ ‏.‏ قُلْتُ يَا رَسُولَ اللَّهِ عَرَضَ لِي شَىْءٌ فِي صَلاَتِي حَتَّى مَا أَدْرِي مَا أُصَلِّي ‏.‏ قَالَ ‏""‏ ذَاكَ الشَّيْطَانُ ادْنُهْ ‏""‏ ‏.‏ فَدَنَوْتُ مِنْهُ فَجَلَسْتُ عَلَى صُدُورِ قَدَمَىَّ ‏.‏ قَالَ فَضَرَبَ صَدْرِي بِيَدِهِ وَتَفَلَ فِي فَمِي وَقَالَ ‏""‏ اخْرُجْ عَدُوَّ اللَّهِ ‏""‏ ‏.‏ فَفَعَلَ ذَلِكَ ثَلاَثَ مَرَّاتٍ ثُمَّ قَالَ ‏""‏ الْحَقْ بِعَمَلِكَ ‏""‏ ‏.‏ قَالَ فَقَالَ عُثْمَانُ فَلَعَمْرِي مَا أَحْسِبُهُ خَالَطَنِي بَعْدُ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الأطعمة ۵۴ (۵۴۵۸)، سنن ابی داود/الأطعمة ۵۳ (۳۸۴۹)، سنن الترمذی/الدعوات ۵۷ (۳۴۵۶)،(تحفة الأشراف:۴۸۵۶)، وقد أخرجہ: مسند احمد (۵/۲۵۲،۲۵۶،۲۶۱،۲۶۷)، سنن الدارمی/الأطعمة ۳ (۲۰۶۶),3284,It was\nnarrated that ‘Uthman bin Abul-‘As said:,Chapters on Medicine
3285,"حَدَّثَنَا هَارُونُ بْنُ حَيَّانَ، حَدَّثَنَا إِبْرَاهِيمُ بْنُ مُوسَى، أَنْبَأَنَا عَبْدَةُ بْنُ سُلَيْمَانَ، حَدَّثَنَا أَبُو جَنَابٍ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِي لَيْلَى، عَنْ أَبِيهِ أَبِي لَيْلَى، قَالَ كُنْتُ جَالِسًا عِنْدَ النَّبِيِّ ـ صلى الله عليه وسلم ـ إِذْ جَاءَهُ أَعْرَابِيٌّ فَقَالَ إِنَّ لِي أَخًا وَجِعًا ‏.‏ قَالَ ‏""‏ مَا وَجَعُ أَخِيكَ ‏""‏ ‏.‏ قَالَ بِهِ لَمَمٌ ‏.‏ قَالَ ‏""‏ اذْهَبْ فَأْتِنِي بِهِ ‏""‏ ‏.‏ قَالَ فَذَهَبَ فَجَاءَ بِهِ فَأَجْلَسَهُ بَيْنَ يَدَيْهِ فَسَمِعْتُهُ عَوَّذَهُ بِفَاتِحَةِ الْكِتَابِ وَأَرْبَعِ آيَاتٍ مِنْ أَوَّلِ الْبَقَرَةِ وَآيَتَيْنِ مِنْ وَسَطِهَا وَإِلَهُكُمْ إِلَهٌ وَاحِدٌ وَآيَةِ الْكُرْسِيِّ وَثَلاَثِ آيَاتٍ مِنْ خَاتِمَتِهَا وَآيَةٍ مِنْ آلِ عِمْرَانَ - أَحْسِبُهُ قَالَ ‏{شَهِدَ اللَّهُ أَنَّهُ لاَ إِلَهَ إِلاَّ هُوَ}‏ - وَآيَةٍ مِنَ الأَعْرَافِ ‏{إِنَّ رَبَّكُمُ اللَّهُ الَّذِي خَلَقَ}‏ الآيَةَ وَآيَةٍ مِنَ الْمُؤْمِنِينَ ‏{وَمَنْ يَدْعُ مَعَ اللَّهِ إِلهًا آخَرَ لاَ بُرْهَانَ لَهُ بِهِ }‏ وَآيَةٍ مِنَ الْجِنِّ ‏{وَأَنَّهُ تَعَالَى جَدُّ رِبِّنَا مَا اتَّخَذَ صَاحِبَةً وَلاَ وَلَدًا}‏ وَعَشْرِ آيَاتٍ مِنْ أَوَّلِ الصَّافَّاتِ وَثَلاَثِ آيَاتٍ مِنْ آخِرِ الْحَشْرِ وَ ‏{قُلْ هُوَ اللَّهُ أَحَدٌ }‏ وَالْمُعَوِّذَتَيْنِ ‏.‏ فَقَامَ الأَعْرَابِيُّ قَدْ بَرَأَ لَيْسَ بِهِ بَأْسٌ ‏.‏",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/اللباس ۱ (۴۰۲۳)، سنن الترمذی/الدعوات ۵۶ (۳۴۵۸)،(تحفة الأشراف:۱۱۲۹۷)، وقد أخرجہ: مسند احمد (۳/۴۳۹),3285,It was\nnarrated from ‘Abdur-Rahman bin Abi Laila that his father Abu\nLaila\nsaid:,Chapters on Medicine
3436,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ وَهِشَامُ ابْنُ عَمَّارٍ،‏‏‏‏ قَالَا، ‏‏‏‏‏‏حَدَّثَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۷، ومصباح الزجاجة:۱۲۷)، وقد أخرجہ: سنن ابی داود/الطب ۱ (۳۸۵۵)، سنن الترمذی/الطب ۲ (۲۰۳۸)، مسند احمد (۴/۲۷۸),3436,,Chapters on Medicine
3437,حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ،‏‏‏‏ أَنْبَأَنَا سُفْيَانُ بْنُ عُيَيْنَةَ،‏‏‏‏ عَنْ الزُّهْرِ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/الطب ۲۱ (۲۰۶۵)،(تحفة الأشراف:۱۱۸۹۸)، وقد أخرجہ: مسند احمد (۳/۴۲۱),3437,,Chapters on Medicine
3438,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ،‏‏‏‏ حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ،‏‏‏‏ حَدَّثَنَا,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۳۳۳، ومصباح الزجاجة:۱۱۹۱)، وقد أخرجہ: مسند احمد (۱/۷۷،۴۱۳،۴۴۳،۴۴۶،۴۵۳),3438,,Chapters on Medicine
3439,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ وَإِبْرَاهِيمُ بْنُ سَعِيدٍ الْجَوْهَرِيُّ،‏‏‏‏ قَا,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الطب ۱ (۵۶۷۸)،(تحفة الأشراف:۱۴۱۹۷),3439,,Chapters on Medicine
3440,حَدَّثَنَا الْحَسَنُ بْنُ عَلِيٍّ الْخَلَّالُ،‏‏‏‏ حَدَّثَنَا صَفْوَانُ بْنُ هُبَيْرَةَ،‏‏‏‏ حَدَّثَ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «أنظر حدیث رقم:۱۴۳۹،(تحفة الأشراف:۶۲۲۴، ومصباح الزجاجة:۱۱۹۲),3440,,Chapters on Medicine
3441,حَدَّثَنَا سُفْيَانُ بْنُ وَكِيعٍ،‏‏‏‏ حَدَّثَنَا أَبُو يَحْيَى الْحِمَّانِيُّ،‏‏‏‏ عَنْ الْأَعْمَشِ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «انظر حدیث رقم:۱۴۴۰ (مصباح الزجاجة:۱۱۹۳),3441,,Chapters on Medicine
3442,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا يُونُسُ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا ف,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الطب ۲ (۳۸۵۶)، سنن الترمذی/الطب ۱ (۲۰۳۷)،(تحفة الأشراف:۱۸۳۶۲)، وقد أخرجہ: مسند احمد (۶/۳۶۳،۳۶۴),3442,,Chapters on Medicine
3443,حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ عَبْدِ الْوَهَّابِ،‏‏‏‏ قَالَ:‏‏‏‏ حَدَّثَنَا مُوسَى بْنُ إِسْمَا,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۹۶۴، ومصباح الزجاجة:۱۱۹۴)، وقد أخرجہ: مسند احمد (۴/۶۱),3443,,Chapters on Medicine
3444,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ،‏‏‏‏ حَدَّثَنَا بَكْرُ بْنُ يُونُسَ بْنِ بُكَ,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan Lighairihi; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/الطب ۴ (۲۰۴۰)،(تحفة الأشراف:۹۹۴۳، ومصباح الزجاجة:۱۱۹۵),3444,,Chapters on Medicine
3445,حَدَّثَنَا إِبْرَاهِيمُ بْنُ سَعِيدٍ الْجَوْهَرِيُّ،‏‏‏‏ حَدَّثَنَا إِسْمَاعِيل بْنُ عُلَيَّةَ،‏‏‏‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: سنن الترمذی/الطب ۳ (۲۰۳۹)،(تحفة الأشراف:۱۷۹۹۰)، وقد أخرجہ: مسند احمد (۶/۳۲),3445,,Chapters on Medicine
3446,حَدَّثَنَا عَلِيُّ بْنُ أَبِي الْخَصِيبِ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ أَيْمَنَ بْنِ نَابِلٍ،‏‏‏,Al-Albani: Daif Isnaad; Muhammad Fouad Abd al-Baqi: Daif Isnaad; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۷۹۸۷، ومصباح الزجاجة:۱۱۹۶)، وقد أخرجہ: مسند احمد (۶/۷۹،۱۳۸،۱۵۲،۲۴۲),3446,,Chapters on Medicine
3447,حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ،‏‏‏‏ وَمُحَمَّدُ بْنُ الْحَارِثِ الْمِصْرِيَّانِ،‏‏‏‏ قَالَا:‏‏‏‏ ح,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الطب ۷ (۵۶۸۸)، صحیح مسلم/السلام ۲۹ (۲۲۱۵)،(تحفة الأشراف:۱۳۲۱۰)، وقد أخرجہ: سنن الترمذی/الطب ۵ (۲۰۴۱)، مسند احمد (۲/۴۲۳،۶/۱۴۶),3447,,Chapters on Medicine
3448,حَدَّثَنَا أَبُو سَلَمَةَ يَحْيَى بْنُ خَلَفٍ،‏‏‏‏ حَدَّثَنَا أَبُو عَاصِمٍ،‏‏‏‏ عَنْ عُثْمَانَ بْنِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۷۷۲، ومصباح الزجاجة:۱۱۹۷),3448,,Chapters on Medicine
3449,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عُبَيْدُ اللَّهِ،‏‏‏‏ أَنْبَأَنَا إِسْرَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الطب ۷ (۵۶۸۷)،(تحفة الأشراف:۱۶۲۶۸)، وقد أخرجہ: مسند احمد (۶/۱۳۸),3449,,Chapters on Medicine
3450,حَدَّثَنَا مَحْمُودُ بْنُ خِدَاشٍ،‏‏‏‏ حَدَّثَنَا سَعِيدُ بْنُ زَكَرِيَّاءَ الْقُرَشِيُّ،‏‏‏‏ حَدَّث,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۳۵۸۸، ومصباح الزجاجة:۱۱۹۸),3450,,Chapters on Medicine
3451,حَدَّثَنَا أَبُو بِشْرٍ بَكْرُ بْنُ خَلَفٍ،‏‏‏‏ حَدَّثَنَا عُمَرُ بْنُ سَهْلٍ،‏‏‏‏ حَدَّثَنَا أَبُو,Al-Albani: Daif Isnaad; Muhammad Fouad Abd al-Baqi: Daif Isnaad; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۲۲۸، ومصباح الزجاجة:۱۱۹۹),3451,,Chapters on Medicine
3452,حَدَّثَنَا عَلِيُّ بْنُ سَلَمَةَ،‏‏‏‏ حَدَّثَنَا زَيْدُ بْنُ الْحُبَابِ،‏‏‏‏ حَدَّثَنَا سُفْيَانُ،‏‏,Al-Albani: Sahih Muquf; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Sahih Muquf; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۵۲۶، ومصباح الزجاجة:۱۲۰۰),3452,,Chapters on Medicine
3453,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ،‏‏‏‏ حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ،‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۲۸۱،۲۲۸۲،۴۰۷۴،۴۰۷۵، ومصباح الزجاجة:۱۲۰۱)، وقد أخرجہ: مسند احمد (۳/۴۸),3453,,Chapters on Medicine
3454,حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ،‏‏‏‏ أَنْبَأَنَا سُفْيَانُ بْنُ عُيَيْنَةَ،‏‏‏‏ عَنْ عَبْدِ ال,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الطب ۲۰ (۵۷۰۸)، صحیح مسلم/الأشربة ۲۸ (۲۰۴۹)، سنن الترمذی/الطب ۲۲ (۲۰۶۷)،(تحفة الأشراف:۴۴۶۵)، وقد أخرجہ: مسند احمد (۱/۱۸۷،۱۸۸),3454,,Chapters on Medicine
3455,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ،‏‏‏‏ حَدَّثَنَا أَبُو عَبْدِ الصَّمَدِ،‏‏‏‏ حَدَّثَنَا مَطَرٌ الْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن الترمذی/الطب ۲۲ (۲۰۶۸)،(تحفة الأشراف:۱۳۴۹۶)، وقد أخرجہ: مسند احمد (۲/۳۰۱،۳۰۵،۳۵۶،۳۵۷،۴۲۱،۴۸۸،۴۹۰،۵۱۱)، سنن الدارمی/الرقاق ۱۱۵ (۲۸۸۲),3455,,Chapters on Medicine
3456,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ،‏‏‏‏ حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ،‏‏‏‏ حَدَّثَنَا,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۵۹۸، ومصباح الزجاجة:۱۲۰۳)، وقد أخرجہ: مسند احمد (۳/۴۲۶،۵/۳۱،۶۵),3456,,Chapters on Medicine
3457,حَدَّثَنَا إِبْرَاهِيمُ بْنُ مُحَمَّدِ بْنِ يُوسُفَ بْنِ سَرْحٍ الْفِرْيَابِيُّ،‏‏‏‏ حَدَّثَنَا عَمْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۸۵۸، ومصباح الزجاجة:۱۲۰۴),3457,,Chapters on Medicine
3458,حَدَّثَنَا جَعْفَرُ بْنُ مُسَافِرٍ،‏‏‏‏ حَدَّثَنَا السَّرِيُّ بْنُ مِسْكِينٍ،‏‏‏‏ حَدَّثَنَا ذَوَّاد,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۴۳۵۱، ومصباح الزجاجة:۱۲۰۵)، وقد أخرجہ: مسند احمد (۲/۳۹۰،۴۰۳),3458,,Chapters on Medicine
3459,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ يُونُسَ بْنِ أَبِي إِس,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن ابی داود/الطب ۱۰ (۳۸۷۰)، سنن الترمذی/الطب ۷ (۲۰۷۵)،(تحفة الأشراف:۱۴۳۴۶)، وقد أخرجہ: مسند احمد (۲/۳۰۵،۴۴۶،۴۷۸),3459,,Chapters on Medicine
3460,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ الْأَعْمَشِ،‏‏‏‏ عَنْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الإیمان ۴۷ (۱۷۵)، سنن الترمذی/الطب ۷ (۲۰۴۴)،(تحفة الأشراف:۱۲۴۶۶)، وقد أخرجہ: صحیح البخاری/الطب ۵۶ (۵۷۷۸)، سنن ابی داود/الطب ۱۱ (۳۸۷۲)، سنن النسائی/الجنائز ۶۸ (۱۹۷۶)، مسند احمد (۲/۲۵۴،۴۷۸،۴۸۸)، سنن الدارمی/الدیات ۱۰ (۲۴۰۷),3460,,Chapters on Medicine
3461,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا أَبُو أُسَامَةَ،‏‏‏‏ عَنْ عَبْدِ الْحَمِ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/الطب ۳۰ (۲۰۸۱)،(تحفة الأشراف:۱۵۷۵۹)، وقد أخرجہ: مسند احمد (۶/۳۶۹),3461,,Chapters on Medicine
3462,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَة،‏‏‏‏ وَمُحَمَّدُ بْنُ الصَّبَّاحِ قَالَا:‏‏‏‏ حَدَّثَنَا,Al-Albani: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الطب ۱۰ (۵۶۹۲)،۲۱ (۵۷۱۳)،۲۳ (۵۷۱۵)،۲۶ (۵۷۱۸)، صحیح مسلم/السلام ۲۸ (۲۲۱۴)، سنن ابی داود/الطب ۱۳ (۳۸۷۷)،(تحفة الأشراف:۱۸۳۴۳)، وقد أخرجہ: مسند احمد (۶/۳۵۵،۳۵۶),3462,,Chapters on Medicine
3463,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ،‏‏‏‏ وَرَاشِدُ بْنُ سَعِيدٍ الرَّمْلِيُّ،‏‏‏‏ قَالَا:‏‏‏‏ حَدَّثَنَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۳۹، ومصباح الزجاجة:۱۲۰۷)، وقد أخرجہ: مسند احمد (۳/۲۱۹),3463,,Chapters on Medicine
3464,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ،‏‏‏‏ وَمُحَمَّدُ بْنُ الصَّبَّاحِ،‏‏‏‏ قَالَا:‏‏‏‏ حَدَّثَنَا عَبْد,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الوضوء ۷۳ (۲۴۳)، الجہاد ۸۵ (۲۹۱۱)، الطب/۲۷ (۵۷۲۲)، صحیح مسلم/الجہاد ۳۷ (۱۷۹۰)، سنن الترمذی/الطب ۳۴ (۲۰۸۵)،(تحفة الأشراف:۴۷۰۶),3464,,Chapters on Medicine
3465,حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ،‏‏‏‏ حَدَّثَنَا ابْنُ أَبِي فُدَيْكٍ،‏‏‏‏ عَنْ عَبْد,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih Lighairihi; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۸۰۳),3465,,Chapters on Medicine
3466,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ،‏‏‏‏ وَرَاشِدُ بْنُ سَعِيدٍ الرَّمْلِيُّ،‏‏‏‏ قَالَا:‏‏‏‏ حَدَّثَنَ,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan Lighairihi; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الدیات ۲۵ (۴۵۸۶)، سنن النسائی/القسامة ۳۴ (۴۸۳۴)،(تحفة الأشراف:۸۷۴۶),3466,,Chapters on Medicine
3467,حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ عَبْدِ الْوَهَّابِ،‏‏‏‏ حَدَّثَنَا يَعْقُوبُ بْنُ إِسْحَاق،‏‏‏‏ ح,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/الطب ۲۸ (۲۰۷۸،۲۰۷۹)،(تحفة الأشراف:۳۶۸۴)، وقد أخرجہ: مسند احمد (۴/۳۶۹،۳۷۲),3467,,Chapters on Medicine
3468,حَدَّثَنَا أَبُو طَاهِرٍ أَحْمَدُ بْنُ عَمْرِو بْنِ السَّرْحِ الْمِصْرِيُّ،‏‏‏‏ حَدَّثَنَا عَبْدُ ال,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الطب ۲۱ (۵۷۱۳)، صحیح مسلم/السلام ۲۸ (۲۲۱۴)، سنن ابی داود/الطب ۱۳ (۳۸۷۷)،(تحفة الأشراف:۱۸۳۴۳)، وقد أخرجہ: مسند احمد (۶/۳۵۵،۳۵۶),3468,,Chapters on Medicine
