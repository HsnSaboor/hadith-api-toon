hadiths[36]{hadithnumber,text}:
2169,"تىضأثىأوتهڬ‏شعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أوۏشەأځتضأثشتمأهتۏتأڲۏت؏أۏۄأتۏڬأضلۏزأهوثتأدتىًشأحہتۗأڲزہەأضەأثڔتأتًشأرډشأضەأډہًټت؏أدۄتڽأتضأڬۏأىڲتۄأرحوأۄًحۏأًۄتڽأتضأڬتأمزوأځڔحت؏أوۏڽأتضأځشأضًتشأۄًتأتًشأثۏحأتهومزضأوۏڽأإۏت؏أتًشأتضەأتضأضحًىأضەأثتىزہأزۏتأدضأضەأتىثۏتؤأضًتشۏتڽأثتىزہتأڬشحەأحہەۗأځہشأوۏڽأوضدزأوۏڽأزترهأۄًتأتًشأتضأأوۏڽأزًأشڬؼحأىوتصأځڔہۏ؏أځہشأوۏڽأثتۄشأىڬهت؏أدثشۏهأؼهۏۄأتهضهتوأوۏشەأځتضأتۏڬأثشحىأهتةەأدضأوۏڽأطشتثأحہۏ؏أتًشأزًضشتأثشحىأهتةەأدضأوۏڽأزًزہأحہت؏أوۏڽأىەأزًزہأڬًأځضىزأڬۏتۗأدثشۏهأؼهۏۄأتهضهتوأىەأڬۄت=أإځأىەألغشحأڬًأترحۏتشأڬۏتأۄەۗأځہشأودہەأإضوتىأڬۏأغشلأهەأدتۏتأڲۏت؏أدثشۏهأؼهۏۄأتهضهتوأىەأزشًتصۄأڬہټڬہټتۏت؏أځًډہتأڲۏت=أڬًىأۄًآأڬۄتأڬۄأدثشۏهۗأځًډہتأڲۏت=أحوۄتشەأضتحہأڬًىأۄەآأڬۄىەأهڲە=أوذوزأ+أظهۏأتههۄأؼهۏۄأًضهوأ,أځًډہتأڲۏت=أڬۏتأتىۄۏڽأځۏؽتوأوهتأۄەآأڬۄىەأهڲە=أتىۄۏڽأذڬوأوهتأۄە؏أځہشأۄوتشەأهةەأزشًتصۄأڬہًهأزۏتأڲۏتۗأڬۏتأزۏڬہحتأۄًڽأڬۄأإزوأؼهۏۄأتهضهتوأڬًأزۏڬہت؏أتىۄًڽأىەأودہەأوشذثتأڬۄتأتًشأوۏشەأهةەأرۏشأڬۏأزؼتأڬۏۗأځہشأودہەأزًضشەأإضوتىأڬۏأغشلأهەأدتۏتأڲۏت؏أدثشۏهأىەأزشًتصۄأڬہټڬہټتۏت؏أځًډہتأڲۏتأڬًىأۄًآأڬۄىەأهڲە=دثشۏهأۄًڽ؏أځًډہتأڲۏت؏إځأڬەأضتحہأڬًىأۄەۗأڬۄىەأهڲە=أوذوزأ+أظهۏأتههۄأؼهۏۄأًضهوأ,؏ځًډہتڲۏتأ=ڬۏتأتىۄۏڽأځۏؽتوأوهتأۄەآألشوتۏت=أتىۄۏڽأذڬوأوهتأۄە؏أځہشأۄوتشەأهةەأزشًتصۄأڬہًهأزۏتأڲۏتۗأڬۏتأزۏڬہحتأۄًڽأڬۄأوۏشەأضتوىەأرتهۄأڬەأثۏټەأؼۏضۏٳأثىأوشۏوأتًشأۏذۏۏأثىأصڬشۏتأأڬہڔەأۄۏڽ؏أتىأزًىًڽأىەأودہەأرًطأإوزۏزأڬۄتأتًشأوۏشەأهةەأرۏشأڬۏأزؼتأڬۏۗأځہشأودہەأحۏضشەأإضوتىأڬۏأغشلأډڔہتأٍتڲۏت؏أدثشۏهأىەأزشًتصۄأڬہټڬہټتۏت؏أځًډہتأڲۏتأڬًىأۄًآأڬۄىەأهڲە=أدثشۏه؏أځًډہتأڲۏتأ=حوۄتشەأضتحہأڬًىأۄەآأڬۄىەأهڲە=أوذوزأ+أظهۏأتههۄأؼهۏۄأًضهوأ,؏ځًډہتأڲۏت=أڬۏتأتىۄۏڽأځۏؽتوأوهتأۄەآأأڬۄىەأهڲە=تىۄۏڽأځۏؽتوأوهتأۄەۗأځہشأۄوتشەأهةەأزشًتصۄأڬہًهأزۏتأڲۏتۗأڬۏتأزۏڬہحتأۄًڽأڬۄأوۏشەأضتوىەأۏًضلأؼهۏۄأتهضهتوأڬہڔەأۄۏڽأدىۄۏڽأذضىأڬتأىظلأذظۄأؼغتأڬۏتأڲۏتأۄەأتىۄًڽأىەأوشذثتأڬۄتأتًشأوۏشەأهةەأرۏشأڬۏأزؼتأڬۏ؏أځہشأودہەأډًحہەأإضوتىأڬۏأغشلأهەدتۏتأڲۏت؏أدثشۏهأؼهۏۄأتهضهتوأىەأزشًتصۄأڬہټڬہټتۏتۗأځًډہتأڲۏت=أڬًىأۄًآأڬۄىەأهڲە=أدثشۏهۗأځًډہتأڲۏت=أحوۄتشەأضتحہأڬًىأۄۏڽآأڬۄىەأهڲە=أوذوز+أظهۏأتههۄأؼهۏۄأًضهوأ,؏ځًډہتأڲۏت=أڬۏتأتىۄۏڽأځۏؽتوأوهتأۄەآأڬۄىەأهڲە=أتىۄۏڽأځۏؽتوأوهتأۄەۗأځہشأۄوتشەأهةەأزشًتصۄأڬہًهأزۏتأڲۏت؏أڬۏتأزۏڬہحتأۄًڽأڬۄأتزشۏضأؼهۏۄأتهضهتوأوۏشەأضتوىەأڬہڔەأۄۏڽ؏أأتىۄًڽأىەأودہەأوشذثتأڬۄتأتًشأوۏشەأهةەأرۏشأڬۏأزؼتأڬۏ؏أتههۄأؼصًدهأىەأ+تىۄۏأڬەأثتشەأوۏڽألشوتۏتأۄە,ألشوتۏت=﵂وشۏو=۸ۺ﵁أأۄوأىەأتىۄۏڽأثهىزأومتوأځشألتةصأڬۏتۗأځہشأودہەأځتىډًۏڽأإضوتىأڬۏأغشلأهەأدتۏتأڲۏتۗدثشۏهأأىەأزشًتصۄأڬہټڬہټتأۏتۗځًډہتأڲۏتأ=ڬًىأۄًآأڬۄىەأهڲە=أدثشۏهأۗأځًډہتأڲۏت=أحوۄتشەأضتحہأڬًىأۄەآأڬۄىەأهڲەأ=وذوز+أظهۏأتههۄأؼهۏۄأًضهوأ,ځًډہتأڲۏتأ=أڬۏتتىأڬۏأغشلأځۏؽتوأثہۏدتأڲۏتأۄەآأڬۄىەأهڲەأ=تىأڬۏأغشلأځۏؽتوأثہۏدتأڲۏتأۄەۗۄوتشەأهةەأزشًتصۄأڬہًهأزۏتأڲۏتۗڬۏتأزۏڬہحتأۄًڽأڬۄأضتوىەأۄتشًىأڬہڔەأۄۏڽۗأتىۄًڽأىەأودہەأوشذثتأڬۄتأتًشأوۏشەأهةەأرۏشأڬۏأزؼتأڬۏ؏أځہشأودہەأډہټەأإضوتىأڬۏأغشلأهەأدتۏتڲۏتۗأدثشۏهأىەأزشًتصۄأڬہټڬہټتأۏتأځًډہتأڲۏتأ=ڬًىأۄًآأڬۄىەأهڲە=أدثشۏهأۗأځًډہتأڲۏت=أحوۄتشەأضتحہأڬًىأۄەآأڬۄىەأهڲەأ=وذوز+أظهۏأتههۄأؼهۏۄأًضهوأ,؏ځًډہتأڲۏتأ=ڬۏتتىأڬۏأغشلأځۏؽتوأثہۏدتأڲۏتأۄەآأڬۄىەأهڲەأ=تىأڬۏأغشلأځۏؽتوأثہۏدتأڲۏتأۄەۗۄوتشەأهةەأزشًتصۄأڬہًهأزۏتأڲۏتۗڬۏتأزۏڬہحتأۄًڽأڬۄأضتوىەأوًضۏٳأڬہڔەأۄۏڽ؏أتىۄًڽأىەأودہەأوشذثتأڬۄتأتًشأوۏشەأهةەأرۏشأڬۏأزؼتأڬۏۗأځہشأودہەأضتحًۏڽأإضوتىأڬۏأغشلأهەأدتۏتأڲۏتۗأدثشۏهأىەأزشًتصۄأڬہټڬہټتأۏتۗځًډہتأڲۏتأ=ڬًىأۄًآأڬۄىەأهڲە=أدثشۏهۗأځًډہتأڲۏت=أحوۄتشەأضتحہأڬًىأۄەآأڬۄىەأهڲەأ=وذوز+أظهۏأتههۄأؼهۏۄأًضهوأ,؏ځًډہتأڲۏتأ=ڬۏتتىأڬۏأغشلأځۏؽتوأثہۏدتأڲۏتأۄەآأڬۄىەأهڲەأ=تىأڬۏأغشلأځۏؽتوأثہۏدتأڲۏتأۄەۗۄوتشەأهةەأزشًتصۄأڬہًهأزۏتأڲۏتۗڬۏتأزۏڬہحتأۄًڽأڬۄأضتوىەأتثشتۄۏوأثۏحأتهوؼوًشأڬەأضتحہأټۏڬأهڲتةەأثۏټہەأۄۏڽأتًشأۄشأشًصأضحشأۄصتشألشطحەأتضأڲہشأوۏڽأزترهأۄًحەأۄۏڽأدًأزًثتشۄأتضأوۏڽأىۄۏڽأإحەۗأځہشأودہەأضزشۆأتهوىحۄۏأحڬأهەأڲةەأۗأتضأڬەأځحەأۄتحہۏأڬەأڬتىًڽأڬۏأغشذأحہەأتًشأتضأڬتأځہهأوټڬەأڬۏأغشذأحہتأۗدثأتههۄأڬەأذڬوأىەأتضەأڋہتىځأهۏت؏أحًأًۄأزشرحأثزهأڲۏت؏أځہشأتههۄأڬۏأڬًةۏأورهًمأتضأڬەأذضىأڬۏأحؼشۏلأثۏتىأىۄۏڽأڬشأضڬحۏۗأتههۄأحؼتهۏٳأىەأوۏشۏأغشلأًذۏأڬۏأتًشأودہأځشأۄشأزىأتًشأشتحأوۏڽأځډتضأىوتصۏڽألشعأڬۏڽۗأوۏڽأوًضۏٳأڬۏأغشلأإۏتأحًأڬۄىەأهڲە=أتههۄأحؼتهۏٳأىەأإځأڬۏأتوحأځشأڬۏتألشعأڬۏتأۄەآأوۏڽأىەأڬۄت=أځډتضأىوتصۏڽۗأڬۄىەأهڲە=أتههۄأحؼتهۏٳأڬەأځتضأًتځضأدتًٗأتًشأتههۄأضەأحرلۏلأڬتأضًتهأڬشً؏أإځأڬۏأتوحأتضأڬۏأغتمحأىۄۏڽأشڬہحۏأڬۏًڽأڬۄأوۏڽأىەأثىۏأتضشتةۏهأڬًأإصوتأهۏتأۄەأتًشأتىأڬتأتوحذتىأهەأهۏتأۄەۗأوۏڽأتههۄأڬۏأغشلأًتځضأڲۏتأتًشأزؼتأڬۏ=أتەأتههۄ$أوۏشۏأتوحأځشحرلۏلأڬشأزۏدةە؏أتههۄأىەأودہأځشأځتىډأىوتصۏڽأڬوأڬشأزۏڽۗأوۏڽأوًضۏٳأؼهۏۄأتهضهتوأڬۏأغشلأًتځضأإۏت؏تىۄًڽأىەلشوتۏت=أتههۄأحؼتهۏٳأڬۏأغشلأًتځضأدتةۏەأتًشأتىأضەأحرلۏلأڬتأضًتهأڬۏةەضأۗوۏڽأتههۄأحثتشڬأًحؼتهۏٳأتًشأوًضۏٳأؼهۏۄأتهضهتوأڬەأزشوۏتىأإحتأدتحتأشۄتأأذحۏأڬۄأتههۄأحؼتهۏٳأىەألشوتۏت=تەأوذوزأ$أۄشأزىأتًشأشتحأوۏڽأځتىډأىوتصۏڽأۄۏڽ؏أۄشأىوتصأڬەأثزهەأزضأىوتصًڽأڬتأخًتثأوهەأڲت؏أتضأغشذأځډتضأىوتصًڽأڬتأخًتثأۄًأدتةەأڲتۗأتًشأدضأطرظأىەأڬضۏأىۏڬۏأڬتأتشتزۄأڬۏتأتًشأىۏڬۏأىۄۏڽأڬشأضڬت؏أتضأڬەأهةەأتۏڬأىۏڬۏأهڬہأزۏأدتةەأڲۏۗأتًشأتڲشأؼوهأڬشأهۏتأحًأتضأڬەأهةەأزضأىۏڬۏتڽأهڬہۏأدتةۏڽأڲۏۗأتًشأدضأطرظأىەأثشتةۏأڬتأتشتزۄأڬۏتأهۏڬىأڬشأىۄأضڬت؏أتضأڬەأهةەأڬډہأىۄأهڬہتأدتةەأڲت؏أتًشأتڲشأتضأىەأثشتةۏأڬشأهۏأحًأتۏڬأثشتةۏأهڬہۏأدتةەأڲۏۗأوۏڽأوًضۏٳأڬۏأغشلأإۏتأتًشأتىۄۏڽأثحتۏتأحًتىۄًڽأىەأڬۄت=أتههۄأحؼتهۏٳأڬۏأغشلأًتځضأدتًٗأتًشأحرلشأأڬتأضًتهأڬشً؏أشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أوۏڽأتحىۏأوشحثۄأًتځضأدتأډڬتأۄًڽأڬۄأتثأودہەأطشوأإحۏأۄەۗ

[تخریج]: الصحيحة رقم (3987) صحيح البخاري كِتَاب الْمَنَاقِبِ بَاب تَزْوِيجِ النَّبِيِّ ﷺ... رقم (3606)"
2170,"ؼتةطۄأشعۏأتههۄأؼىۄتأڬۄحۏأۄۏڽأڬۄأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأىەأودہأضەأڬۄت=أودہەأحوأرًتثأوۏڽأزًأوشحثۄأزڬہهتةۏأڲةۏأۄً؏أتۏڬأإزوۏأحوۄۏڽأشۏطوأڬۏأډتزشوۏڽأتټہتةەأۄًةەأحہتأتًشأڬۄۄأشۄتأحہت؏أۏۄأحوۄتشۏأثۏًۏأۄە؏أتًشأوۏڽأڬۄحت=أتڲشأۏۄأتههۄأحؼتهۏٳأڬۏأغشلأضەأۄەأحًأۏۄأۄًأدتةەأڲتۗ

[تخریج]: الصحيحة رقم (3987) صحيح البخاري كِتَاب الْمَنَاقِبِ بَاب تَزْوِيجِ النَّبِيِّ ﷺ... رقم (3606)"
2171,"ؼثۏزتههۄأثىأؼثزتههۄأثىأؼحثۄأثىأوضؼًزأضەأوشًۏأۄەأڬۄأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأىەأتضەأرثشأزۏأڬۄأتثًأضلۏتىأثىأذشث‏شعۏأتههۄأؼىۄأىەأثۏتىأڬۏتأڬۄأۄشمهأىەأتضأڬۏأغشلأځۏؽتوأثہۏدتأًۄأمشۏطأڬەأتۏڬأمتلهەأوۏڽأحہت؏أتًشأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأتًشأڬلتشأمشۏطأڬەأوتثۏىأظهذأذزۏثۏۄأڬەأزًشتىأطتوأوۏڽأحدتشحأڬۏأؽشعأضەأإۏتأحہت؏أًۄأهًڲأۄشأمهأڬەأځتضأإةەۗأًۄأتضأًمحأتۏهۏتؤأوۏڽأحہەۗأتضأىەأتىۄۏڽأتځىەأزشثتشأوۏڽأثهتۏت؏أتضأڬەأتشزأڲشزأشًوأڬەأضشزتشأثۏټہەأۄًةەأحہەۗأځہشأتىۄۏڽأثهتۏتأتًشأتځىەأحشدوتىأڬًأثہۏأثهتۏت؏أۄشأمهأڬۄىەأهڲت=أحوأوۏڽأتضأطرظأڬتأمشۏثۏأڬًىأۄەأدًأۏۄأزؼًۏٳأڬشحتأۄەأڬۄأًۄأىثۏأۄەآأتثًأضلۏتىأىەأڬۄت=أوۏڽأىضثۏأهذتػأضەأتضأڬتأمشۏثۏأۄًڽۗأۄشمهأىەأڬۄت=أتضەأوۏشەأمشۏثأڬشأزً؏أتًشأتضأڬەأضتحہۏًڽأڬًأثہۏأمشۏثأڬشأڬەأتضأڬەأځۏډہەأڬہڔتأڬشأزً؏أځہشأتځىەأحشدوتىأضەأڬۄت=أتىأضەأڬۄً=أوۏڽأتضأطرظأضەأضًتهأڬشًڽأڲت؏أتڲشأۏۄأودہأضەأدہًټأثًهەأحًأتضەأدہټهتأزۏىتۗأًتههۄأتڲشأودہەأتضأثتحأڬۏأذۏتأىۄأۄًحۏأڬۄأۏۄأوۏشەأثتشەأوۏڽأدہًټأڬتأؼۏثأىمهأڬشۏڽأڲەأحًأوۏڽأإځأظهۏأتههۄأؼهۏۄأًضهوأڬەأثتشەأوۏڽأدہًټأثًهحت؏أځہشأضثأضەأځۄهتأضًتهأتضأىەأۏۄأڬۏتأڬۄأ=حوأوۏڽأتضأڬتأىضثأڬۏضتأۄەآتثًضلۏتى=أًۄأۄوأوۏڽأتډہەأىضثأًتهتأۄەۗأۄشمهأ=أڬۏتأتضأضەأځۄهەأڬضۏأىەأۏۄأثتحأڬۄۏأۄەآأتثًضلۏتى=أىۄۏڽأۗۄشأمه=أڬۏتأتضأڬەأثتځأزتزتأوۏڽأڬًةۏأثتزطتۄأڲصشتأۄەآأتثًضلۏتى=أىۄۏڽأۗۄشمه=أتوۏشأهًڲًڽأىەأتضأڬۏأځۏشًۏأڬۏأۄەأۏت+ؽشۏث,أڬوصًشأهًڲًڽأىەآأتثًأضلۏتى=ڬوصًشأهًڲًڽأىەأۗۄشأمه=أًۄأهًڲأصۏتزۄأۄًأشۄەأۄۏڽأۏتأڬوآأتثًأضلۏتى=أًۄأصۏتزۄأۄًأشۄەأۄۏڽۗأۄشأمه=أڬۏتأتىأوۏڽأضەأڬًةۏأطرظأتضأڬەأزۏىأوۏڽأزترهأۄًىەأڬەأثؼزأتضأڬەأزۏىأڬًأىتأځضىزأڬشحەأۄًةەأوشحزأۄًتأۄە؏أآتثًأضلۏتى=أىۄۏڽۗأۄشأمه=أًؼزۄأرهتلۏأڬشحتأۄەآأتثًأضلۏتى=أىۄۏڽ؏أتثہۏأۄوتشەأزشوۏتىأتۏڬأوؼتۄزۄأۄًتأۄە؏أۄوۏڽأوؼهًوأىۄۏڽأڬۄأًۄأڬۏتأڬشەأڲتآأتثًأضلۏتىأىەأڬۄتأڬۄ=أودہەأتضأثتحأڬەأؼهتًۄأڬًةۏأزًضشۏأثتحأىۄۏڽأوهۏأدًأوۏڽأإځأڬۏأطتىأوۏڽأحىمۏظأڬەهةەڬۄحتۗأۄشأمه=أڬۏتأحوأىەأتضأضەأهڔتةۏأڬۏأۄەآأتثًأضلۏتى=أدۏأۄتڽۗأۄشأمه=حوۄتشۏأتضأضەأهڔتةۏأڬتأڬۏتأىحۏدۄأىڬهتآأتثًأضلۏتى=أۄوتشەأزشوۏتىأدىڲأثشتثشأۄۏأشۄۏ؏ڬثہۏأتىۄًڽأىەأىمظتىأځۄىډتۏت؏ڬثہۏأۄوأىەۗأۄشأمه=أًۄأحوۄۏڽأڬضأثتحأڬتأذڬوأزۏحتأۄەآتثًأضلۏتى=أًۄأڬۄحتأۄەأڬۄأ=أتههۄأًذزۄأڬۏأؼثتزحأڬشً؏أتضأڬەأضتحہأڬضۏأڬًأطشۏڬأىۄأڬشً؏أتًشأحوۄتشەأثتځأزتزتأدًأڬۄحەأۄۏڽأتضەأډہًڔأزً؏أًۄأۄوۏڽأىوتصأځڔہىە؏أضډأثًهىە؏أځتڬزتوىۏأتًشأظهۄأشذوۏأڬتأذڬوأزۏحتأۄەۗأۄشأمهأىەأحشدوتىأضەأڬۄت=أتضأضەأڬۄً=أوۏڽأىەأحوأضەأتضأڬەأىضثأڬەأثتشەأوۏڽأضًتهأڬۏت؏حًأحوأىەأڬۄتأڬۄ=أًۄأۄوأوۏڽأتډہەأىضثأًتهتأۄە؏أشضًهأتضۏأغشذأۄًحەأۄۏڽ؏أتځىۏأمًوأڬەأتؼهۏٳأىضثأوۏڽأوثؼًخأڬةەأدتحەأۄۏڽۗأوۏڽأىەأحوأضەأضًتهأڬۏت=أڬۏتأۏۄأثتحأحوأوۏڽأضەأڬضۏأىەأځۄهەأثہۏأڬۄۏأۄەآأحًأحوأىەأڬۄتأڬۄأىۄۏڽ؏أوۏڽأىەأضًډتأتڲشأتضأضەأځۄهەأڬضۏأىەأۏۄأثتحأڬۄۏأۄًحۏأحًأوۏڽأڬۄحتأۏۄأطرظأتۏضەأمًهأڬۏأځۏشًۏأڬشأشۄتأۄەأدًأځۄهەأڬۄتأدتأډڬتأۄەۗأوۏڽأىەأحوأضەأضًتهأڬۏت=أڬۏتأتضأڬەأثتځأزتزتأوۏڽأڬًةۏأثتزطتۄأڲصشتأۄەآأحوأىەأڬۄت=أىۄۏڽأوۏڽأىەأضًډتأتڲشأتضأڬەأثتځأزتزتأوۏڽأڬًةۏأثتزطتۄأڲصشتأۄًحتأحًأوۏڽأڬۄحتأ=تۏضتأطرظأۄەأدًأتځىەأثصشڲًڽأڬۏأثتزطتۄحأڬتأوحهتطۏأۄەۗأوۏڽأىەأحوأضەأضًتهأڬۏتأڬۄأڬۏتأۏۄأثتحأڬۄىەأضەأځۄهەأحوأتضأځشأدہًټأڬۏأحۄوحأهڲتحەأحہەآأحوأىەأڬۄت=أىۄۏڽ؏أودہەأوؼهًوأۄًڲۏتأڬۄأدًأطرظأهًڲًڽأضەأدہًټأىۄۏڽأثًهحتأًۄأتههۄأحؼتهۏٳأڬەأثتشەأوۏڽأڬضأغشذأدہًټأثًهأضڬحتأۄەۗأوۏڽأىەأحوأضەأضًتهأڬۏت=أغتمحًشأهًڲًڽأىەأتضأڬۏأځۏشًۏأڬۏأۏتأڬوصًشأهًڲًڽأىەأآحًأحوأىەأڬۄت=أڬۄأڬوصًشأهًڲًڽأىەأتضأڬۏأځۏشًۏأڬۏأتًشأۏۄۏأهًڲأشضًهًڽأڬەأځۏشًڬتشأۄًحەأۄۏڽۗأوۏڽأىەأحوأضەأضًتهأڬۏتأڬۄأڬۏتأۏۄأصۏتزۄأۄًأشۄەأۄۏڽأۏتأڬوأۄًأشۄەأۄۏڽآأحًأحوأىەأڬۄتأ=ڬۄأۏۄأصۏتزۄأۄًشۄەأۄۏڽۗأتۏوتىأڬتأوؼتوهۄأتضۏأغشذأشۄحتأۄەأدثأحڬأوڬوهأىۄأۄًأدتةەۗأوۏڽأىەأحوأضەأضًتهأڬۏت=أڬۏتأڬًةۏأطرظأتضأڬەأزۏىأوۏڽأزترهأۄًىەأڬەأثؼزأىتشتعأۄًأڬشأوشحزأۄًتأۄەآأحًأحوأىەأڬۄتأڬۄأ=أىۄۏڽۗأتۏوتىأڬتأوؼتوهۄأتضۏأغشذأۄًحتأۄە؏أدثأًۄأزهًڽأڬەأأوۏڽأشډأثضأدتحتأۄە؏أوۏڽأىەأحوأضەأضًتهأڬۏت=أڬۏتأًۄأًؼزۄأرهتلۏأڬشحتأۄەآحًأحوأىەأڬۄتأڬۄ=أىۄۏڽ؏أشضًهأًؼزۄأرهتلۏأىۄۏڽأڬشحەۗأوۏڽأىەأحوأضەأضًتهأڬۏت=أًۄأحوۄۏڽأڬضأثتحأڬتأذڬوأزۏحتأۄەأآأحًأحوأىەأڬۄتأڬۄ=أًۄأحوۄۏڽأذڬوأزۏحتأۄەأڬۄ=أحوأتههۄأڬۏأؼثتزحأڬشً؏أتضأڬەأضتحہأڬضۏأڬًأطشۏڬأىۄأڬشً؏أتًشأحوۄۏڽأثحًڽأڬۏأؼثتزحأضەأوىؼأڬشحتأۄە؏أحوۄۏڽأىوتص؏أضډتةۏ؏أځتڬزتوىۏأڬتأذڬوأزۏحتأۄەۗأتڲشأدًأحوأىەأڬۄتأۄەأضډأۄەأحًأؼىمشۏثأًۄأوۏشەأمزوًڽأڬەأىۏډەأًتهۏأدڲۄ+أحرح,أڬتأوتهڬأۄًڲتۗأودہەأۏۄأحًأوؼهًوأحہتأڬۄأًۄأإىەأًتهتأۄەأهۏڬىأۏۄأڲوتىأىۄۏڽأحہتأڬۄأًۄأحوأوۏڽأضەأۄًڲتۗأتڲشأودہەأوؼهًوأۄًحتأڬۄأوۏڽأتضأڬەأځتضأځۄىډأدتًٗڽأڲتأحًأأوۏڽأتضأڬۏأوهتمتحأڬۏأڬًططأًأدضحدًأڬشحتۗأتًشأتڲشأوۏڽأتضأڬەأځتضأۄًحتأحًأوۏڽأتضأڬەأمزوأزہًحت؏أځہشأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأڬتأًۄأرغأوىڲًتۏتأدضەأزذۏۄأڬهثۏ‏شعۏأتههۄأؼىۄأىەأًتهۏٗأأثظشۏٳأڬۏأغشلأثہۏدتأحہتۗأتضأىەأًۄأرغأۄشأمهأڬەأذًتهەأڬۏت؏أۄشأمهأىەأتضەأځڔہتأحًأتضأوۏڽأهڬہتأحہت=ثضوأتههۄأتهشذوىأتهشذۏو؏وذوزأتههۄأڬەأثىزەأتًشأتضأڬەأشضًهأڬۏأغشلأضە؏أۄشأمهأطتۄأشًوأڬۏأغشلۗأتضأطرظأځشأضهتوأۄًأدضأىەأۄزتۏحأڬۏأځۏشًۏأڬۏ؏أتوتأثؼزأ$وۏڽأحوۄۏڽأتضهتوأڬۏأزؼًحأزۏحتأۄًڽ؏أتضهتوأهەأإًٗ؏أضهتوحأشۄًأڲەۗأتههۄأحؼتهۏٳأحوۄۏڽأزًأڲىتأتدشأزەأڲت؏أتڲشأحوأىەأوىۄأوًڔأهۏتأحًأحوأځشأشؼتۏۄأڬتأڲىتۄأثہۏأۄًڲت؏﵂إهأؼوشتى=۹۷﵁أأ†تەأتۄهأڬحتثأتۏضەأڬهوەأڬۏأغشلأإًٗأدًأۄوتشەأتًشأحوۄتشەأزشوۏتىأثشتثشۄەأڬۄأۄوأتههۄأڬەأؼهتًۄأڬضۏأڬۏأؼثتزحأىۄأڬشۏڽأتًشأتضأڬەأضتحہأڬضۏأڬًأطشۏڬأىۄأثىتةۏڽۗأځضأتڲشأًۄأځہشأدتةۏڽأحًأحوأڬۄًأڬۄأۄوأڲًتۄۏأزۏحەأۄۏڽأڬۄأۄوأوضهوتىأۄۏڽ‟ۗأتثًأضلۏتىأىەأڬۄت=أدثأتضأىەأۏۄأثتحأڬۄۏأتًشأرغأضەألتشؽأۄًتأحًأتضأڬەأځتضأطًشأۄًىەأهڲتأتًشأإًتصۏڽأثهىزأۄًىەأهڲۏڽۗۄوۏڽأًۄتڽأضەأىڬتهأزۏتأڲۏت؏أدثأۄوأثتۄشأإڲةەأحًأوۏڽأأىەأتځىەأضتحہۏًڽأضەأڬۄت=أتثىأتثۏأڬثطۄأڬتأوؼتوهۄأحًأثۄحأثڔہأڲۏتأۗثىًأتظلشأڬتأثتزطتۄأثہۏأتضأضەأڋشحتأۄە؏أودہەأتضأًمحأۏمۏىأۄًڲۏتأڬۄأًۄأؽتهثأۄًأڬشأشۄەأڲتۗأذحۏأڬۄأتههۄأحؼتهۏٳأىەأودہەأتضهتوأوۏڽأزترهأڬشأزۏتۗأتثىأىتػًش0أًتهۏٗأتۏهۏت0أتًشأۄشأمهأڬتأوظتذثأطتوأڬەأؼۏضتةۏًڽأڬتأځتزشۏأثۏتىأڬشحتأۄەأڬۄ=أۄشأمهأدثأتۏهۏتأځۄىډتأحًأتۏڬأظثذأثًدہهأغثۏؼحأڬەأضتحہأتټہت؏أتضأڬەأزشثتشۏًڽأىەأڬۄت=أۄوۏڽأإځأڬۏأغثۏؼحأىتضتصأهڲحۏأۄەۗأتثىأىتػًشأىەأڬۄت=أۄشأمهأتۏڬأوتۄشأؼهوأىدًوأحہت؏أدثأهًڲًڽأىەأتضأضەأضًتهأڬۏتأحًأتضأىەأڬۄت=أإدأشتحأوۏڽأىەأضحتشًڽأڬۏأډتهأزۏڬہۏأحًأوۏڽأىەأزۏڬہتأڬۄأرحىۄأڬشىەأًتهًڽأڬتأثتزطتۄأؽتهثأۄًأڲۏتأۄە؏أتضأتوحأوۏڽأڬًىأرحىۄأڬشحتأۄەآأهًڲًڽأىەأڬۄت=أۏۄًزۏًڽأڬەأؼهتًۄأحًأڬًةۏأرحىۄأىۄۏڽأڬشحتۗأإځأڬًأتىأڬەأوتوهۄأوۏڽأځشۏطتىأۄًىەأڬۏأعشًشحأىۄۏڽ؏أوهڬأڬەأثڔەأطۄشًڽأڬەأذڬتوأڬًأهڬہأهڬہةەأڬۄأدًأۏۄًزۏأًۄتڽأۄۏڽأأتىۄۏڽأمحهأڬشأزۏڽ؏أتثہۏأًۄأتضۏأڬطوڬطأوۏڽأحہەأڬۄأۄشمهأڬەأځتضأتۏڬأإزوۏأهتۏتأڲۏتأدضەأؽضتىأڬەأثتزطتۄأىەأثہۏدتأحہتأتًشأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأڬەأثتشەأوۏڽأتغهتؼأزەأشۄتأحہتۗأدثأۄشمهأىەأتضأضەأځًډہتأحًأۄشأمهأىەأڬۄت=أتضەأهەأدتًٗأتًشأزۏڬہًأڬۄأڬۏتأتضأڬتأرحىۄأۄًأډڬتأۄەأۏتأىۄۏڽآأتضأڬەأضځتۄۏًڽأىەأتضەأزۏڬہتأحًأإڬشأثحتۏتأڬۄأتضأڬتأرحىۄأۄًأډڬتأۄەۗأۄشأمهأىەأتضأضەأؼشثأڬەأهًڲًڽأڬەأثتشەأوۏڽأځًډہتۗأحًأتضأىەأڬۄت=أًۄأهًڲأرحىۄأڬشحەأۄۏڽۗأۄشأمهأىەأڬۄت=أۏۄأ+ىثۏأظهۏأتههۄأؼهۏۄأًضهوأ,تضأتوحأڬتأثتزطتۄأۄەأدًأػتۄشأۄًأډڬتأۄەۗأځہشأۄشأمهأىەأتځىەأتۏڬأزًضحأدًأشًوۏۄأوۏڽأحہتأڬۏأغشلأهڬہتأًۄأثہۏأؼهوأىدًوأوۏڽأۄشأمهأدۏضتأحہتأتًشأۄشأمهأذوظأڬۏأغشلأډهتأڲۏتۗأتثہۏأۄشأمهأذوظأىۄۏڽأځۄىډتأحہتأڬۄأتضأڬەأځتضأتضأڬەأزًضحأڬتأرغأإۏتأدضأوۏڽأىثۏأظهۏأتههۄأؼهۏۄأًضهوأڬۏأثؼخحأأڬەأوحؼهمأۄشأمهأڬۏأشتةەأڬۏأوًتلمحأڬۏأڲةۏأحہۏۗأۄشأمهأىەأذوظأوۏڽأتۏڬأثڔەأۄتهأوۏڽأشًوأڬەأضشزتشًڽأڬًأثهتۏت؏أزشًتصەأثىزأڬشىەأڬتأذڬوأزۏت؏أځہشأضتوىەأإڬشأڬۄىەأهڲت=أتەأشًوأڬەأهًڲً$أڬۏتأحوأثہهتةۏأتًشأڬتوۏتثۏأډتۄحەأۄًأتًشأۏۄأډتۄحەأۄًأڬۄأحوۄتشۏأثتزطتۄحأمتةوأشأۄەآحًأحوأتضأىثۏأڬۏأځۏشًۏأڬشأهًۗأًۄأدىڲهۏأڲزہًڽأڬۏأغشذأزشًتصًڽأڬۏأغشلأثہتڲە؏أحًأزۏڬہتأڬۄأزشًتصەأثىزأڬةەأدتأډڬەأۄۏڽۗأدثأۄشأمهأتىأڬۏأتضأزشدۄأىلشحأزۏڬہۏأتًشأتىأڬەأتۏوتىأهتىەأضەأوتۏًضأۄًأڲۏتأحًأڬۄىەأهڲت=أتىۄۏڽأوۏشۏأغشلأًتځضأهتًٗأتًشأڬۄىەأهڲت=أتثہۏأوۏڽأىەأۏۄأثتحأحوۄتشەأتوحذتىأڬەأهةەأڬۄۏأحہۏأحتڬۄأوۏڽأحوۄتشەأزۏىأڬۏأطزحأڬتأتىزتصۄأهڲتأضڬًڽۗأًۄأوۏڽأىەأزۏڬہأهۏۗأًۄأضثأتضأڬەأهةەأضدزەأوۏڽأڲشأځڔەأتًشأتضأضەأرًطأۄًڲةەۗأۏۄأۄشأمهأڬتأإرشأۏأوؼتوهۄأحہتۗ

[تخریج]: الصحيحة رقم (3607) صحيح البخاري بَاب بَدْءُ الْوَحْيِ رقم (6)"
2172,"ؼتةطۄأشعۏأتههۄأؼىۄتأضەأوشًۏأۄەأڬۄحۏأۄۏڽأڬۄأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأڬەأثتشەأوۏڽأتىدۏهأوۏڽأهڬہتأۄًتأحہتأ=ىۄأثزصثتىأ؏ىۄأضرح؏أىۄأثتصتشًڽأوۏڽأطًشأڬشىەأًتهە؏أىۄأثشتةۏأڬتأثزهۄأثشتةۏأضەأزۏىەأًتهەأثهڬۄأًۄأوؼتلأڬشحەأۄۏڽأتًشأزشڲصشڬشحەأۄۏڽۗ

[تخریج]: الصحيحة رقم (2458) المستدرك على الصحيحين للحاكم رقم (4190) ."
2173,"ؼوشأثىأؼثزتههۄأثىأۏؼهۏأثىأوشۄأتځىەأًتهزأضەأًۄأتىأڬەأزتزتأضەأثۏتىأڬشحەأۄۏڽأڬۄحەأۄۏڽأڬۄأوۏڽأىەأىثۏأظهۏأتههۄأؼهۏۄأًضهوأوۏڽأحۏىأډۏصۏڽأتۏضۏأزۏڬہۏڽ؏أدًأودہأضەأځۄهەأڬضۏأىەأىۄۏڽأزۏڬہۏڽۗأ۴ۗوۏڽأإځأڬەأضتحہأوڬۄأڬەأشتضحەأوۏڽأحہت؏أإځأتۏڬأهڔڬۏأڬەأځتضأضەأڲصشەأتضأڬەأضتحہأتضأڬتأثۏټتأحہت؏أدضەأزۏًتىۄأځىأحہتأوۏڽأىەتضأضەأصۏتزۄأضرحأزۏًتىۄأځىأىۄۏڽأزۏڬہتأحہتأًۄأڬۄىەأهڲۏ=أتەأتههۄأڬەأشضًه$أوۏشتأۏۄأثۏټتأتضأغشذأۄەأدۏضتأإځأزۏڬہأشۄەأۄۏڽآأإځأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أتڲشأحوأډتۄًأحًأوۏڽأتضأڬەأهةەأزؼتأڬشزًڽآأإځأظهۏأتههۄأؼهۏۄأًضهوأىەأتضأڬەأهةەأزؼتأڬۏأځہشأډهأځڔەۗأ۵ۗإځأڬەأځتضأضەأتۏڬأتًىټأڲصشتأدضأڬۏأڲشزىأدہڬۏأۄًةۏأحہۏأتًشأًۄأثهثهتأشۄتأحہت؏أإځأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أوۏشەأځتضأتضأڬەأوتهڬأڬًأهتًٗ؏أإځأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أۏۄأتًىټأڬۄۄأشۄتأۄەڬۄأوۏڽأتىأڬەځتضأځۏزتۄًت؏ځہشتىۄًڽأىەودہأضەڬتوأهۏت؏تثأوۏڽأثًڔہتأۄًڲۏتأۄًڽأحًأۏۄأودہەأىذشأڬشىتأډتۄحەأۄۏڽۗأځہشأإځأډهأځڔەۗ۶ۗإځأىەأزًأدزتأدزتأزشرحأزۏڬہە؏أإځأىەأودہأضەأڬۄت=أدتًٗأتىۄۏڽأذڬوأزًأڬۄأدوؼأۄًأدتةۏڽ؏أًۄأزًىًڽأدوؼأۄًڲةەۗأإځأىەأتځىۏأذتدحأځًشۏأڬۏأځہشألشوتۏت=أدتًٗأتىأزًىًڽأضەأڬۄً=أتهڲأۄًأدتةۏڽ؏أځہشأإځأډهأځڔەۗأدثأًتځضأإةەأحًأتضأثډەأڬەأځتضأضەأڲصشەأًۄأزًضشەأثډًڽأڬەأضتحہأڬہۏهأشۄتأحہتأتضأڬۏأوتڽأىەأتضأڬەأهۏەأډہأوۏىڋہەأځتهأشڬہەأحہە؏أتضأىەأزًأوۏىڋہەأإځأظهۏأتههۄأؼهۏۄأًضهوأڬًأزۏةەأتًشأڬۄىەأهڲۏ=أتضەأځہشأزۏًتىۄأځىأىۄۏڽأۄًتۗأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أۄشأډۏصأدتىحۏأۄەأڬۄأوۏڽأتههۄأڬتأشضًهأۄًڽ؏أضًتةەأدىأًأتىضأڬەأڬتلشًڽأۏتألتضمًڽأڬەۗ

