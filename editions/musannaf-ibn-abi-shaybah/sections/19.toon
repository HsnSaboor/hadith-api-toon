hadiths[699]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}:
25113,"( حَدَّثَنَا إِسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ یَحْیَی بْنِ أَبِی إِسْحَاقَ ، قَالَ : رَأَیْتُ عَلَی أَنَسِ بْنِ مَالِکٍ مِطْرَفَ خَزٍّ ، وَرَأَیْتُ عَلَی الْقَاسِمِ مِطْرَفَ خَزٍّ ، وَرَأَیْتُ عَلَی عُبَیْدِ اللہِ بْنِ عَبْدِ اللہِ خَزًّا۔",,,25113
25114,"حَدَّثَنَا أَبُو الأَحْوَص ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْعَیْزَارِ بْنِ حُرَیْثٍ ، قَالَ : رَأَیْتُ الْحُسَیْنَ بْنَ عَلِیٍّ وَعَلَیْہِ کِسَائُ خَزٍّ ، وَکَانَ یُخَضِّبُ بِالْحِنَّائِ وَالْکَتَمِ۔",,,25114
25115,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، قَالَ : رَأَیْتُ عَلَی عَبْدِ اللہِ بْنِ أَبِی أَوْفَی مِطْرَفَ خَزٍّ۔",,,25115
25116,"حَدَّثَنَا وَکِیعٌ ، عَنْ عُیَیْنَۃَ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِیہِ ، قَالَ : کَانَ لأَبِی بَکْرَۃَ مِطْرَفُ خَزٍّ سَدَاہُ حَرِیرٌ ، فَکَانَ یَلْبَسُہُ۔",,,25116
25117,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ أَبِی بْنِ زِیَادٍ ، قَالَ : رَأَیْتُ عَلَی عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی مِطْرَفَ خَزٍّ فَلَبِسَہُ حَتَّی تَقَطَّعَ ، ثُمَّ نَقَضَہُ مَرَّۃً أُخْرَی۔",,,25117
25118,حَدَّثَنَا عَبْدَۃُ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ؛ أَنَّہُ کَانَ لَہَا کِسَائُ خَزٍّ ، فَکَسَتْہُ ابْنَ الزُّبَیْرِ۔,,,25118
25119,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ إِسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، قَالَ : رَأَیْتُ الأَحْنَفَ بْنَ قَیْسٍ عَلَی بَغْلَۃٍ ، وَرَأَیْتُ عَلَیْہِ عِمَامَۃَ خَزٍّ ، وَمِطْرَفَ خَزٍّ۔",,,25119
25120,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ إِسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، قَالَ : رَأَیْتُ عَلَی قَیْسِ بْنِ أَبِی حَازِمٍ ، وَشُبَیْلِ بْنِ عَوْفٍ ، وَالشَّعْبِیِّ ؛ مَطَارِفَ الْخَزِّ ، وَرَأَیْتُ عَلَی شُرَیْحٍ مِطْرَفَ خَزٍّ ، وَبُرْنُسَ خَزٍّ۔",,,25120
25121,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ عِمْرَانَ الْقَطَّانِ ، قَالَ : أَخْبَرَنِی عَمَّارٌ ، قَالَ : رَأَیْتُ عَلَی أَبِی قَتَادَۃَ مِطْرَفَ خَزٍّ ، وَرَأَیْتُ عَلَی أَبِی ہُرَیْرَۃَ مِطْرَفَ خَزٍّ ، وَرَأَیْتُ عَلَی ابْنِ عَبَّاسٍ مَا لاَ أُحْصِی۔",,,25121
25122,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الْوَلِیدِ بْنِ جُمَیْعٍ ، قَالَ : رَأَیْتُ عَلَی أَبِی عُبَیْدَۃَ بْنِ عَبْدِ اللہِ بُرْنُسَ خَزٍّ۔",,,25122
25123,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، قَالَ : رَأَیْتُ عَلَی عَبْدِ اللہِ بْنِ الزُّبَیْرِ ، وَعُرْوَۃَ بْنِ الزُّبَیْرِ ، وَعَلَی أَبِی بَکْرِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ الْحَارِثِ بْنِ ہِشَامٍ أَکْسِیَۃَ خَزٍّ۔",,,25123
25124,"حَدَّثَنَا عَبْدَۃُ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، قَالَ : رَأَیْتُ عَلَی الْقَاسِمِ ، وَأَبِی جَعْفَرٍ جُبَّتَیْنِ مِنْ خَزٍّ ، وَجُبَّۃُ أَبِی جَعْفَرٍ مِنْ خَزِّ أَدْکَنَ۔",,,25124
25125,"حَدَّثَنَا ابْنُ نُمَیْرٍ، عَنِ الأَجْلَحِ، عَنْ حَبِیبٍ، قَالَ: کَانَ لِعَلِیِّ بْنِ الْحُسَیْنِ کِسَائُ خَزٍّ ، یَلْبَسُہُ کُلَّ جُمُعَۃٍ۔",,,25125
25126,"حَدَّثَنَا وَکِیعٌ ، عَنْ عُیَیْنَۃَ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ عَلِیِّ بْنِ زَیْدٍ ، قَالَ : جَلَسْتُ إِلَی سَعِیدِ بْنِ الْمُسَیَّبِ وَعَلَیَّ جُبَّۃُ خَزٍّ ، فَأَخَذَ بِکُمِّ جُبَّتِی وَقَالَ : مَا أَجْوَدَ جُبَّتَکَ ہَذِہِ ، قَالَ : قُلْتُ : وَمَا تُغْنِی وَقَدْ أَفْسَدُوہَا عَلَیَّ ، قَالَ: وَمَنْ أَفْسَدَہَا؟ قُلْتُ: سَالِمٌ ، قَالَ: إِذَا صَلُحَ قَلْبُک فَالْبَسْ مَا بَدَا لَکَ ، قَالَ : فَذَکَرْتُ قَوْلَہُمَا لِلْحَسَنِ، فَقَالَ : إِنَّ مِنْ صَلاَحِ الْقَلْبِ تَرْکَ الْخَزِّ۔",,,25126
25127,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، سَأَلْتُہُ ، قُلْتُ : کَانُوا یَلْبَسُونَ الْخَزَّ ؟ قَالَ : کَانُوا یَلْبَسُونَہُ وَیَکْرَہُونَہُ ، وَیَرْجُونَ رَحْمَۃَ اللہِ۔",,,25127
25128,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ، عَنِ الشَّیْبَانِیِّ، قَالَ: رَأَیْتُ مُحَمَّدَ بْنَ عَلِیٍّ بِعَرَفَاتٍ، وَعَلَیْہِ مِطْرَفٌ مِنْ خَزٍّ أَصْفَرَ۔",,,25128
25129,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ صَفْوَانَ بْنِ عَبْدِ اللہِ ، قَالَ : اسْتَأْذَنَ سَعْدٌ عَلَی ابْنِ عَامِرٍ ، وَتَحْتَہُ مَرَافِقُ مِنْ حَرِیرٍ ، فَأَمَرَ بِہَا فَرُفِعَتْ ، فَلَمَّا دَخَلَ سَعْدٌ دَخَلَ وَعَلَیْہِ مِطْرَفٌ مِنْ خَزٍّ ، فَقَالَ لَہُ : اسْتَأْذَنْتَ عَلَیَّ وَتَحْتِی مَرَافِقُ مِنْ حَرِیرٍ ، فَأَمَرْت بِہَا فَرُفِعَتْ ، فَقَالَ لَہُ سَعْدٌ : نِعْمَ الرَّجُلُ أَنْتَ إِنْ لَمْ تَکُنْ مِمَنْ قَالَ اللَّہُ : {أَذْہَبْتُمْ طَیِّبَاتِکُمْ فِی حَیَاتِکُمُ الدُّنْیَا} وَاللَّہ لأَنْ أَضْطَجِعَ عَلَی جَمْرِ الْغَضَی أَحَبَّ إِلَیَّ مِنْ أَنْ أَضْطَجِعَ عَلَیْہَا ، قَالَ : فَہَذَا عَلَیْک شَطْرُہُ حَرِیرٌ وَشَطْرُہُ خَزٌّ ، قَالَ : إِنَّمَا یَلِی جِلْدِی مِنْہُ الْخَزُّ۔",,,25129
25130,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنِی شُعْبَۃُ ، عَنْ مُحَمَّدِ بْنِ زِیَادٍ ، قَالَ : رَأَیْتُ عَلَی أَبِی ہُرَیْرَۃَ مِطْرَفَ خَزٍّ قَدْ ثَنَاہُ۔",,,25130
25131,حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ حَکِیمِ بْنِ جُبَیْرٍ ، عَنْ خَیْثَمَۃَ ؛ أَنَّ ثَلاَثَۃَ عَشَرَ مِنْ أَصْحَابِ مُحَمَّدٍ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانُوا یَلْبَسُونَ خَزًّا۔,,,25131
25132,"حَدَّثَنَا وَکِیعٌ ، عَنْ عُثْمَانَ بْنِ أَبِی ہِنْدٍ ، قَالَ : رَأَیْتُ عَلَی أَبِی عُبَیْدَۃَ مِطْرَفَ خَزٍّ ، وَرَأَیْتُ عَلَی عُمَرَ بْنِ عَبْدِ الْعَزِیزِ مِطْرَفَ خَزٍّ أَبْیَضَ۔",,,25132
25133,"حَدَّثَنَا إِسْمَاعِیلُ بْنُ عُلَیَّۃَ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ صُہَیْبٍ ، عَنْ أَنَسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ لَبِسَ الْحَرِیرَ فِی الدُّنْیَا لَمْ یَلْبَسْہُ فِی الآخِرَۃِ۔ (بخاری 5832۔ مسلم 21)",,,25133
25134,"حَدَّثَنَا أَبُو الأَحْوَص ، عَنْ أَبِی إِسْحَاقَ ، عَنْ ہُبَیْرَۃَ ، قَالَ : أُہْدِیَ لِرَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حُلَّۃٌ مِنْ حَرِیرٍ ، فَأَہْدَاہَا لِعَلِیٍّ فَلَبِسَہَا عَلِیٌّ ، فَلَمَّا رَآہَا النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إِنِّی أَکْرَہُ لَکَ مَا أَکْرَہُ لِنَفْسِی ، اجْعَلْہَا خُمُرًا بَیْنَ النِّسَائِ۔",,,25134
25135,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، وَابْنُ نُمَیْرٍ ، وَأَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنْ سَعِیدِ بْنِ أَبِی ہِنْدٍ ، عَنْ أَبِی مُوسَی ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْحَرِیرُ وَالذَّہَبُ حَرَامٌ عَلَی ذُکُورِ أُمَّتِی ، حِلٌّ لإِنَاثِہِمْ۔ (ترمذی 1720۔ احمد 4/392)",,,25135
25136,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ أَشْعَثَ بْنِ أَبِی الشَّعْثَائِ ، عَنْ مُعَاوِیَۃَ بْنِ سُوَیْد ، عَنِ الْبَرَائِ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الدِّیبَاجِ وَالْحَرِیرِ وَالإِسْتَبْرَقِ۔",,,25136
25137,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنْ أَبِی فَاخِتَۃَ ، قَالَ : حدَّثَنِی ہُبَیْرَۃُ بْنُ یَرِیمٍ ، عَنْ عَلِیٍّ ؛ أَنَّہُ أُہْدِیَ إِلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حُلَّۃٌ مُسَیَّرَۃٌ بِحَرِیرٍ إِمَّا سَدَاہَا ، أَوْ لُحْمَتُہَا ، فَأَرْسَلَ بِہَا إِلَیَّ ، فَأَتَیْتُہُ فَقُلْتُ: یَا رَسُولَ اللہِ ، مَا أَصْنَعُ بِہَا، أَلْبَسُہَا؟ قَالَ: لاَ ، إِنِّی لاَ أَرْضَی لَکَ مَا أَکْرَہُ لِنَفْسِی، وَلَکِنِ اجْعَلْہَا خُمُرًا بَیْنَ الْفَوَاطِمِ۔ (ابن ماجہ 3596)",,,25137
25138,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، عَنْ حُذَیْفَۃَ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَانَا أَنْ نَلْبَسَ الْحَرِیرَ وَالدِّیبَاجَ ، وَقَالَ : ہُوَ لَہُمْ فِی الدُّنْیَا ، وَلَکُمْ فِی الآخِرَۃِ۔\n\n(مسلم 1637۔ نسائی 9615)",,,25138
25139,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنْ أَبِی فَاخِتَۃَ ، قَالَ : حدَّثَنِی جَعْدَۃُ بْنُ ہُبَیْرَۃَ ، عَنْ عَلِیٍّ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ بِنَحْوِ حَدِیثِ عَبْدِ الرَّحِیمِ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنْ أَبِی فَاخِتَۃَ۔",,,25139
25140,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، عَنْ حُذَیْفَۃَ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ لبْسِ الْحَرِیرِ وَالذَّہَبِ ، وَقَالَ : ہُوَ لَہُمْ فِی الدُّنْیَا ، وَلَنَا فِی الآخِرَۃِ۔\n\n(بخاری 5831۔ مسلم 1637)",,,25140
25141,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ؛ أَنَّ ابْنَ عُمَرَ أَخْبَرَہُ ، أَنَّ عُمَرَ بْنَ الْخَطَّابَ رَأَی حُلَّۃً سِیَرَائَ مِنْ حَرِیرٍ ، فَقَالَ : یَا رَسُولَ اللہِ ، لَوِ ابْتَعْتَ ہَذِہِ الْحُلَّۃَ لِلْوَفْدِ وَلِیَوْمِ الْجُمُعَۃِ ؟ فَقَالَ : إِنَّمَا یَلْبَسُ ہَذِہِ مَنْ لاَ خَلاَقَ لَہُ فِی الآخِرَۃِ۔ (بخاری 886۔ مسلم 1638)",,,25141
25142,"حَدَّثَنَا مُحَمَّدُ بْنُ عُبَیْدٍ ، وَیَزِیدُ بْنُ ہَارُونَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ یَزِیدَ بْنِ أَبِی حَبِیبٍ ، عَنْ مَرْثَدَ بْنِ عَبْدِ اللہِ الْیَزَنِیِّ ، عَنْ عُقْبَۃَ بْنِ عَامِرٍ الْجُہَنِیِّ ، قَالَ : صَلَّی بِنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْمَغْرِبَ وَعَلَیْہِ فَرُّوجٌ ، یَعْنِی قَبَائً مِنْ حَرِیرٍ ، فَلَمَّا قَضَی صَلاَتَہُ نَزَعَہُ نَزْعًا عَنِیفًا ، فَقُلْتُ : یَا رَسُولَ اللہِ ، صَلَّیْتَ وَہُوَ عَلَیْک ، قَالَ : إِنَّ ہَذَا لاَ یَنْبَغِی لِلْمُتَّقِینَ۔ (بخاری 375۔ مسلم 23)",,,25142
25143,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ عَاصِمٍ ، عَنْ أَبِی عُثْمَانَ ، عَنْ عُمَرَ ؛ أَنَّہُ کَانَ یَنْہَی عَنِ الْحَرِیرِ وَالدِّیبَاجِ إِلاَّ مَا کَانَ ہَکَذَا ، ثُمَّ وَأَشَارَ بِإِصْبعِہِ ، ثُمَّ الثَّانِیَۃِ ، ثُمَّ الثَّالِثَۃِ ، ثُمَّ الرَّابِعَۃِ وَقَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَنْہَانَا عَنْہُ۔ (بخاری 5828۔ مسلم 1642)",,,25143
25144,"حَدَّثَنَا ابْنُ فُضَیْلٍ، عَنِ الأَعْمَشِ، عَنْ عَبْدِ اللہِ بْنِ مُرَّۃَ، عَنْ أَبِی کَنَفٍ، قَالَ: انْطَلَقْتُ مَعَ عَبْدِ اللہِ حَتَّی أَتَیْتُ دَارَہُ ، فَأَتَاہُ بَنُونَ لَہُ عَلَیْہِمْ قُمُصُ حَرِیرٍ فَخَرَقَہَا ، وَقَالَ : انْطَلِقُوا إِلَی أُمِّکُمْ فَلْتُلْبِسکُمْ غَیْرَ ہَذَا۔",,,25144
25145,"حَدَّثَنَا وَکِیعٌ ، عَنْ فُضَیْلِ بْنِ غَزْوَانَ ، عَنِ الْمُہَاجِرِ بْنِ شَمَّاسٍ ، عَنْ عَمِّہِ ، قَالَ : رَأَی ابْنُ مَسْعُودٍ ابْنًا لَہُ عَلَیْہِ قَمِیصٌ مِنْ حَرِیرٍ ، فَشَقَّہُ ، وَقَالَ : إِنَّمَا ہَذَا لِلنِّسَائِ۔",,,25145
25146,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ سُلَیْمَانَ بْنِ أَبِی الْمُغِیرَۃِ الْعَبْسِیِّ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : قدِمَ حُذَیْفَۃُ بْنُ الْیَمَانِ مِنْ سَفَرٍ ، وَقَدْ کُسِیَ وَلَدُہُ الْحَرِیرَ ، فَنَزَعَ مِنْہُ مَا کَانَ عَلَی ذُکُورِ وَلَدِہِ ، وَتَرَکَ مِنْہُ مَا کَانَ عَلَی بَنَاتِہِ۔",,,25146
25147,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ سَعْدِ بْنِ إِبْرَاہِیمَ ، عَن أَبِیہِ ، قَالَ : دَخَلَ عَبْدُ الرَّحْمَنِ بْنُ عَوْفٍ وَمَعَہُ ابْنٌ لَہُ عَلَی عُمَرَ ، عَلَیْہِ قَمِیصُ حَرِیرٍ ، فَشَقَّ الْقَمِیصَ۔",,,25147
25148,"حَدَّثَنَا عُبَیْد بْنُ سَعِیدٍ، عَنْ شُعْبَۃَ ، عَنْ خَلِیفَۃَ بْنِ کَعْبٍ؛ أَنَّہُ ، قَالَ: سَمِعْتُ عَبْدَ اللہِ بْنَ الزُّبَیْرِ یَخْطُبُ، قَالَ: قَالَ: أَلاَ لاَ تُلْبِسُوا نِسَائَ کُمُ الْحَرِیرَ، فَإِنِّی سَمِعْت عُمَرَ بْنَ الْخَطَّابِ یَقُولُ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تَلْبَسُوا الْحَرِیرَ ، فَإِنَّہُ مَنْ لَبِسَہُ فِی الدُّنْیَا لَمْ یَلْبَسْہُ فِی الآخِرَۃِ۔ (بخاری 5834۔ مسلم 1641)",,,25148
25149,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ یَزِیدَ بْنِ أَبِی حَبِیبٍ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ أَبِی الصَّعْبَۃِ ، عَنْ أَبِی أَفْلَحَ الْہَمْدَانِیِّ ، عَنْ عَبْدِ اللہِ بْنِ زُرَیْرٍ الْغَافِقِیِّ سَمِعْہ یَقُولُ : سَمِعْتُ عَلِیَّ بْنَ أَبِی طَالِبٍ یَقُولُ : أَخَذَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَرِیرًا بِشِمَالِہِ وَذَہَبًا بِیَمِینِہِ ، ثُمَّ رَفَعَ بِہِمَا یَدَیْہِ فَقَالَ: إِنَّ ہَذَیْنِ حَرَامٌ عَلَی ذُکُورِ أُمَّتِی ، حِلٌّ لإِنَاثِہِمْ۔ (ابوداؤد 4054۔ احمد 1/115)",,,25149
25150,"حَدَّثَنَا عَفَّانُ ، قَالَ: أَخْبَرَنَا حَمَّادُ بْنُ سَلَمَۃَ ، قَالَ: أَخْبَرَنَا أَنَس بْنُ سِیرِینَ ، عَنْ أَبِی مِجْلَزٍ ، عَنْ حَفْصَۃَ؛ أَنَّ عُطَارِدَ بْنَ حَاجِبٍ جَائَ بِثَوْبِ دِیبَاجٍ کَسَاہُ إِیَّاہُ کِسْرَی ، فَقَالَ عُمَرُ : أَلاَ أَشْتَرِیہِ لَکَ یَا رَسُولَ اللہِ ؟ قَالَ : إِنَّمَا یَلْبَسُہُ مَنْ لاَ خَلاَقَ لَہُ۔ (بخاری 886۔ احمد 6/288)",,,25150
25151,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ أَبِی التَّیَّاحِ ، عَنْ حَفْصٍ اللَّیْثِیِّ ، عَنْ عِمْرَانَ بْنِ حُصَیْنٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی عَنِ الْحَنْتَمِ ، وَالتَّخَتُّمِ بِالذَّہَبِ ، وَالْحَرِیرِ۔",,,25151
25152,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنِ الإِفْرِیقِیِّ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ رَافِعٍ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ، قَالَ: خَرَجَ عَلَیْنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَفِی إِحْدَی یَدَیْہِ ثَوْبٌ مِنْ حَرِیرٍ ، وَفِی الأُخْرَی ذَہَبٌ، فَقَالَ : إِنَّ ہَذَیْنِ مُحَرَّمٌ عَلَی ذُکُورِ أُمَّتِی ، حِلٌّ لإِنَاثِہِمْ۔ (ابن ماجہ 3597۔ طبرانی 126)",,,25152
25153,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللہِ الأَسَدِیُّ ، عَنْ عُمَرَ بْنِ سَعِیدِ بْنِ أَبِی حُسَیْنٍ ، عَنْ عَلِیِّ بْنِ عَبْدِ اللہِ بْنِ عَلِیٍّ، قَالَ : أَخْبَرَنِی أَبِی ، أَنَّہُ سَمِعَ مُعَاوِیَۃَ وَہُوَ عَلَی الْمِنْبَرِ ، یَقُولُ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ لُبْسِ الْحَرِیرِ وَالذَّہَبِ۔ (احمد 4/96)",,,25153
25154,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ حُمَیْدٍ ، قَالَ : سُئِلَ أَنَسٌ عَنِ الْحَرِیرِ ؟ فَقَالَ : نَعُوذُ بِاللَّہِ مِنْ شَرِّہِ ، کُنَّا نَسْمَعُ أَنَّہُ مَنْ لَبِسَہُ فِی الدُّنْیَا ، لَمْ یَلْبَسْہُ فِی الآخِرَۃِ۔",,,25154
25155,حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، عَنْ طَاوُوسٍ ؛ أَنَّہُ کَانَ یَکْرَہُ لُبْسَ الْحَرِیرِ۔,,,25155
25156,حَدَّثَنَا مُعْتَمِرٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ کَانَ یَکْرَہُ قَلِیلَ الْحَرِیرِ وَکَثِیرَہُ۔,,,25156
25157,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ حُصَیْنٍ ، قَالَ : کَتَبَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ : لاَ تَلْبَسُوا مِنَ الْحَرِیرِ إِلاَّ مَا کَانَ سَدَاہُ قُطْنًا ، أَوْ کَتَّانًا۔",,,25157
25158,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَبْدِ الْمَلِکِ بْن مَیْسَرَۃَ ، عَنْ زَیْدِ بْنِ وَہْبٍ ، عَنْ عَلِیٍّ ، قَالَ : کَسَانِی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حُلَّۃً سِیَرَائَ فَرَحْتُ فِیہَا ، فَرَأَیْت الْغَضَبَ فِی وَجْہِہِ ، قَالَ : فَشَقَقْتہَا بَیْنَ نِسَائِی۔ (بخاری 5840۔ 9607)",,,25158
25159,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ دَاوُدَ السَّرَّاجِ ، عَنْ أَبِی سَعِیدٍ ، قَالَ : مَنْ لَبِسَ الْحَرِیرَ فِی الدُّنْیَا ، لَمْ یَلْبَسْہُ فِی الآخِرَۃِ۔",,,25159
25160,"حَدَّثَنَا رَیْحَانُ بْنُ سَعِیدٍ ، عَنْ مَرْزُوقِ بْنِ عَمْرٍو ، قَالَ : قَالَ أَبُو فَرْقَدٍ : رَأَیْتُ عَلَی تَجَافِیفِ أَبِی مُوسَی الدِّیبَاجَ وَالْحَرِیرَ۔",,,25160
25161,"حَدَّثَنَا حَفْصٌ ، عَنْ ہِشَامٍ ، قَالَ : کَانَ لأَبِی یَلْمَقُ مِنْ دِیبَاجٍ یَلْبَسُہُ فِی الْحَرْبِ۔",,,25161
25162,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ بَأْسَ بِہِ إِذَا کَانَ جُبَّۃً ، أَوْ سِلاَحًا۔",,,25162
25163,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ بَأْسَ بِلُبْسِ الْحَرِیرِ فِی الْحَرْبِ۔",,,25163
25164,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا سَعِیدٌ ، عَنْ قَتَادَۃَ ؛ أَنَّ أَنَسَ بْنَ مَالِکٍ أَنْبَأَہُمْ : أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَخَّصَ لِلزُّبَیْرِ بْنِ الْعَوَّامِ ، وَلِعَبْدِ الرَّحْمَنِ بْنِ عَوْفٍ فِی قَمِیصَیْنِ مِنْ حَرِیرٍ ، مِنْ وَجَعٍ کَانَ بِہِمَا ، حِکَّۃٍ۔ (بخاری 2919۔ مسلم 1646)",,,25164
25165,"حَدَّثَنَا مُحَمَّدُ بْنُ مُصْعَبٍ ، عَنِ الأَوْزَاعِیِّ ، عَنِ الْوَلِیدِ بْنِ ہِشَامٍ ، قَالَ : کَتَبْتُ إِلَی ابْنِ مُحَیرِیز أَسْأَلُہُ عَنْ لُبْسِ الْیَلاَمِقِ وَالْحَرِیرِ فِی دَار الْحَرْبِ ؟ قَالَ : فَکَتَبَ : أَنْ کُنْ أَشَدَّ مَا کُنْتُ کَرَاہِیَۃً لِمَا تُکْرَہُ عِنْدَ الْقِتَالِ ، حِینَ تُعَرِّضُ نَفْسَک لِلشَّہَادَۃِ۔",,,25165
25166,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی مَکِینٍ ، عَنْ عِکْرِمَۃَ ؛ أَنَّہُ کَرِہَہُ فِی الْحَرْبِ ، وَقَالَ : أَرْجَی مَا یَکُونُ لِلشَّہَادَۃِ۔",,,25166
25167,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : سَأَلْتُ مُحَمَّدًا عَنْ لُبْسِ الدِّیبَاجِ فِی الْحَرْبِ ؟ فَقَالَ: مِنْ أَیْنَ کَانُوا یَجِدُونَ الدِّیبَاجَ ؟",,,25167
25168,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنِ الشَّعْبِیِّ ، عَنْ سُوَیْد بْنِ غَفَلَۃً ، قَالَ : شَہِدْنَا الْیَرْمُوکَ ، قَالَ : فَاسْتَقْبَلَنَا عُمَرُ وَعَلَیْنَا الدِّیبَاجُ وَالْحَرِیرُ ، فَأَمَرَ بِرَمْیِنَا بِالْحِجَارَۃِ ، قَالَ : فَقُلْنَا : مَا بَلَغَہُ عَنَّا ؟ قَالَ : فَنَزَعْنَاہُ وَقُلْنَا : کَرِہَ زِیَّنَا ، فَلَمَّا اسْتَقْبَلْنَاہُ رَحَّبَ بِنَا ، وَقَالَ : إِنَّکُمْ جِئْتُمُونِی فِی زِیِّ أَہْلِ الشِّرْکِ ، إِنَّ اللَّہَ لَمْ یَرْضَ لِمَنْ قَبْلَکُمُ الدِّیبَاجَ ، وَلاَ الْحَرِیرَ۔",,,25168
25169,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ أَنَسٍ ، قَالَ : رَأَیْتُ عَلَی زَیْنَبَ بِنْتِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَمِیصَ حَرِیرٍ سِیَرَائَ۔ (ابن ماجہ 3598۔ نسائی 9576)",,,25169
25170,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ ثَابِتِ بْنِ زَیْدٍ ، قَالَ : حَدَّثَتْنِی حَمَادَۃُ ، عَنْ أُنَیْسَۃَ بِنْتِ زَیْدٍ ؛ أَنَّ أَبَاہَا دَخَلَ عَلَیْہَا فِی بَیْتِہَا وَعَلَیْہَا قَمِیصٌ مِنْ حَرِیرٍ ، فَخَرَجَ وَہُوَ مُغْضَبٌ۔",,,25170
25171,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنِ الشَّعْبِیِّ ، عَنْ سُوَیْد بْنِ غَفَلَۃَ ، عَنْ عُمَرَ ؛ أَنَّہُ قَالَ : لاَ یَصْلُحُ مِنْہُ إِلاَّ ہَکَذَا ؛ إِصْبَعًا ، أَوْ إِصْبَعَیْنِ ، أَوْ ثَلاَثَۃً ، أَوْ أَرْبَعَۃً۔",,,25171
25172,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مَنْصُورٍ ، عَنْ حَبِیبٍ ، عَنْ زِرٍّ ، قَالَ : قَالَ عُمَرُ : لاَ تَلْبَسُوا مِنَ الْحَرِیرِ إِلاَّ إِصْبَعَیْنِ ، أَوْ ثَلاَثۃ۔",,,25172
25173,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ الْحَذَّائِ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ لَمْ یَکُنْ یَرَی بِالأَعْلاَمِ بَأْسًا۔,,,25173
25174,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُغِیرَۃَ بْنِ زِیَادٍ ، عَنْ أَبِی عُمَرَ مَوْلَی أَسْمَائَ ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ اشْتَرَی عِمَامَۃً لَہَا عَلَمٌ ، فَدَعَا بِالجَمَلیْنِ فَقَصَّہُ ، فَذَکَرْتُ ذَلِکَ لَہَا ، فَقَالَتْ : بُؤْسًا لِعَبْدِ اللہِ ، یَا جَارِیَۃُ ، ہَاتِی جُبَّۃَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَجَائَتْ بِجُبَّۃٍ مَکْفُوفَۃِ الْکُمَّیْنِ وَالْجَیْبِ وَالْفَرْجَیْنِ بِالدِّیبَاجِ۔\n\n(مسلم 1641۔ ابوداؤد 4051)",,,25174
25175,"حَدَّثَنَا جَرِیرٌ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : کَانَتْ لِرَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ جُبَّۃٌ طَیَالِسَۃٌ ، عَلَیْہَا لَبِنَۃُ دِیبَاجٍ کِسْرَوَانِیٍّ ، کَانَ یَلْبَسُہَا۔",,,25175
25176,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانُوا یَکْرَہُونَ أَنْ یَلْبِسُوا الثَّوْبَ سَدَاہُ حَرِیرٌ ، أَوْ لُحْمَتُہُ ، وَلاَ یَرَوْنَ بِالأَعْلاَمِ بَأْسًا۔",,,25176
25177,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانَ یَلْبَسُ طَیْلَسَانًا مُدَبَّجًا۔",,,25177
25178,"حَدَّثَنَا عَبْدُ اللہِ بْنُ دَاوُد ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، قَالَ : کَانَ لأَبِی بَرَّکَانٌ فِیہِ عَلَمُ أَرْبَعُ أَصَابِعَ دِیبَاجٍ۔",,,25178
25179,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ أَبِی صَخْرَۃَ ، قَالَ : رَأَیْتُ عَلَی الأَسْوَدِ بْنِ ہِلاَلٍ طَیْلَسَانًا مُدَبَّجًا طُولاً۔",,,25179
25180,"حَدَّثَنَا وَکِیعٌ، عَنْ مِسْعَرٍ، عَنْ ثَابِتِ بْنِ عُبَیْدٍ، قَالَ: رَأَیْتُ عَلَی عَبْدِ اللہِ بْنِ یَزِیدَ طَیْلَسَانًا مُدَبَّجًا مُدَحرجًا۔",,,25180
25181,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہَمَّامٍ ، عَنْ قَتَادَۃَ ، عَنْ إِسْمَاعِیلَ بْنِ عِمْرَانَ الْعَبْدِیِّ ، قَالَ : رَأَیْتُ عَلَی سَعِیدِ بْنِ الْمُسَیَّبِ طَیْلَسَانًا مُدَبَّجًا۔",,,25181
25182,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : رَأَیْتُ عَلَی الْقَاسِمِ عِمَامَۃً عَلَمُہَا حَرِیرٌ أَبْیَضُ۔",,,25182
25183,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْمَاعِیلَ بْنِ عَبْدِ الْمَلِکِ ، قَالَ : رَأَیْتُ عَلَی أَبِی جَعْفَرٍ رِدَائً سَابِرِیًّا مُعَلَّمًا۔",,,25183
25184,"حَدَّثَنَا عَبْدُالرَّحِیمِ، عَنْ سَعِیدٍ مَوْلَی حُذَیْفَۃَ، قَالَ: رَأَیْتُ عَلَی عَبْدِاللہِ بْنِ مِعْقَلٍ طَیْلَسَانًا فِیہِ أَزْرَارُ دِیبَاجٍ۔",,,25184
25185,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، وَوَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ وَبَرَۃَ ، قَالَ : سَمِعْتُ ابْنَ عُمَرَ یَقُولُ : اجْتَنِبُوا مَا خَالَطَ الْحَرِیرُ مِنَ الثِّیَابِ۔",,,25185
25186,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، وَأَبُو دَاوُد الْحَفْرِی ، عَنْ مِسْعَرٍ ، عَنْ وَبَرَۃَ ، عَنِ الشَّعْبِیِّ ، عَنْ سُوَیْد بْنِ غَفَلَۃَ ، عَنْ عُمَرَ ، قَالَ : لاَ یَصْلُحُ مِنَ الْحَرِیرِ إِلاَّ مَا کَانَ فِی تَکْفِیفٍ ، أَوْ تَزْرِیرٍ۔",,,25186
25187,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ إِسْمَاعِیلَ بْنِ سُمَیْعٍ ، عَنْ مُسْلِمٍ الْبَطِینِ ، عَنْ أَبِی عَمْرٍو الشَّیْبَانِیِّ ، قَالَ : جَائَ شَیْخٌ فَسَلَّمَ عَلَی عَلِیٍّ ، وَعَلَیْہِ جُبَّۃٌ مِنْ طَیَالِسَۃٍ فِی مُقَدَّمِہَا دِیبَاجٌ ، فَقَالَ عَلِیٌّ : مَا ہَذَا النَّتِنُ تَحْتَ لِحْیَتِکَ ؟ فَنَظَرَ الشَّیْخُ یَمِینًا وَشِمَالاً ، فَقَالَ : مَا أَرَی شَیْئًا ، قَالَ : یَقُولُ الرَّجُلُ : إِنَّمَا یَعْنِی الدِّیبَاجَ ، قَالَ : یَقُولُ الرَّجُلُ : إِذَنْ نُلْقِیہِ ، وَلاَ نَعُودُ۔",,,25187
25188,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ عَبْدِ اللہِ بْنِ مُرَّۃَ ، عَنْ حُذَیْفَۃَ ؛ أَنَّہُ رَأَی رَجُلاً عَلَیْہِ طَیْلَسَانٌ عَلَیْہِ أَزْرَارُ دِیبَاجٍ ، فَقَالَ : مُتَقَلِّدٌ قَلاَئِدَ الشَّیْطَانِ۔",,,25188
25189,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَمُحَمَّدٍ ؛ أَنَّہُمَا کَرِہَا الْعَلَمَ فِی الثَّوْبِ۔,,,25189
25190,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا الأَعْمَشُ ، عَنْ مُجَاہِدٍ؛ أَنَّ ابْنَ عُمَرَ اشْتَرَی عِمَامَۃً فَرَأَی فِیہَا عَلَمًا فَقَطَعَہُ۔",,,25190
25191,حَدَّثَنَا وَکِیعٌ ، عَنِ الْحَکَمِ بْنِ عَطِیَّۃَ ، عَنِ النَّضْرِ بْنِ عَبْدِ اللہِ ؛ أَنَّ قَیْسَ بْنَ عُبَادٍ وَفَدَ إِلَی مُعَاوِیَۃَ فَکَسَاہُ رَیْطَۃً ، فَفَتَّقَ عَلَمَہَا وَارْتَدَی بِہَا۔,,,25191
25192,"حَدَّثَنَا وَکِیعٌ، عَنْ مُوسَی بْنِ عُبَیْدٍ، عَنْ خَالِدِ بْنِ یَسَارٍ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ، قَالَ: کُنَّا نَقْطَعُ الأَعْلاَمَ۔",,,25192
25193,حَدَّثَنَا حَفْصٌ، عَنْ دَاوُدَ بْنِ أَبِی ہِنْدٍ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ؛ أَنَّہُ کَانَ یَکْسُو بَنَاتَہِ خُمْرَ الْقَزِّ وَنِسَائَہُ۔,,,25193
25194,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : قُلْتُ لِسَالِمٍ : الرَّجُلُ یَکْسُو أَہْلَہُ الْقَزَّ ، وَالْخُمُرَ ، وَالثِّیَابَ ، فَقَالَ : قَدْ کُنْتُ لاَ أَکْسُوہُنَّ إِیَّاہُ ، فَمَا زالوا بِی حَتَّی کَسَوْتُہنَّ إِیَّاہُ ، وَإِنْ لَمْ تَکْسُہُ ، فَہُوَ وَاللَّہِ خَیْرٌ۔",,,25194
25195,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَمُحَمَّدٍ ؛ أَنَّہُمَا کَانَا یَکْرَہَانِ الْقَزَّ وَالإِبْرَیْسَمَ۔,,,25195
25196,"حَدَّثَنَا مِسْعَرٌ ، عَنْ عَطِیَّۃَ ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ أَخَذَ مُلاَئَۃً سَابِرِیَّۃً ، أَوْ رَقِیقَۃً ، فَجَمَعَہَا بِیَدِہِ ، ثُمَّ رَمَی بِہَا۔",,,25196
25197,حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ؛ أَنَّہُ کَانَ یَکْرَہُ لُبْسَ الثَّوْبِ السَّابِرِیِّ الرَّقِیقِ۔,,,25197
25198,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عُبَیْد ، قَالَ : رَأَیْتُ عَلَی الْقَاسِمِ رِدَائً شَطوِیًّا لَہُ عَلَمٌ۔",,,25198
25199,"حَدَّثَنَا أَبُو بَکر ، قَالَ : قَالَ ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ ، عَنْ أُنیَسٍ أَبِی الْعُرْیَانِ ، قَالَ : رَأَیْتُ عَلَی الْحَسَنِ بْنِ مُحَمَّدِ بْنِ عَلِیٍّ قَمِیصًا رَقِیقًا ، وَعِمَامَۃً رَقِیقَۃً۔",,,25199
25200,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ أَبِی حَیَّانَ ، عَنْ حَبِیبٍ ، قَالَ : رَأَیْتُ عَلَی ابْنِ عَبَّاس قَمِیصًا سَابِرِیًّا رَقِیقًا ، اسْتُشِفَّ إِزَارُہُ مِنْ رِقَّتِہِ۔",,,25200
25201,"حَدَّثَنَا الْفَضْلُ ، قَالَ : حدَّثَنَا أَبُو إِسْرَائِیلَ ، قَالَ : کَانَ الْحَکَمُ یَعْتَمُّ بِعِمَامَۃِ سَابِرِیٍّ۔",,,25201
25202,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْمَاعِیلَ بْنِ عبد المَلِکَ ، قَالَ : رَأَیْتُ عَلَی أَبِی جَعفَرٍ رِدَائً سَابِرِیًّا مُعَلَمًا۔",,,25202
25203,حَدَّثَنَا الْحَسَنُ بْنُ مُوسَی ، عَنْ شَیْبَانَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ؛ أَنَّہُ کَانَ یَکْرَہُ الثِّیَابَ الرِّقَاقَ۔,,,25203
25204,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَفْلَحَ ، قَالَ : رَأَیْتُ عَلَی الْقَاسِمِ رِدَائً رَقِیقًا۔",,,25204
25205,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَطَائٍ ، قَالَ : الْحَرِیرُ أَحَبُّ إلَیَّ مِنَ السَّابِرِیِّ۔",,,25205
25206,حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ الرَّحْمَنِ الْخَیَّاطِ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ کَانَ لَہُ رِدَائٌ رَقِیقٌ۔,,,25206
25207,"حَدَّثَنَا شَرِیکٌ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْبَرَائِ ، قَالَ : مَا رَأَیْتُ أَجْمَلَ مِنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مُرَجِّلاً فِی حُلَّۃٍ حَمْرَائَ۔ (بخاری 3551۔ مسلم 92)",,,25207
25208,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ إِسْحَاقَ ، قَالَ : حدَّثَنِی أَبِی ، قَالَ : رَأَیْتُ نَافِعَ بْنَ جُبَیْرٍ بِالْعَرْجِ، وَعَلَیْہِ مُعَصْفَرٌ۔",,,25208
25209,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ الْعَوَّامِ ، قَالَ : رَأَیْتُ عَلَی إبْرَاہِیمَ التَّیْمِیِّ ، وَإِبْرَاہِیمَ النَّخَعِیِّ عَلَی کُلِّ وَاحِدٍ مِنْہُمَا مِلْحَفَۃً حَمْرَائَ۔",,,25209
25210,حَدَّثَنَا عُبَیْدُاللہِ بْنُ مُوسَی، عَنْ عَمْرِو بْنِ عُثْمَانَ، عَنْ مُوسَی بْنِ طَلْحَۃَ؛ أَنَّ طَلْحَۃَ کَانَ یَلْبَسُ الْمُعَصْفَرَ۔,,,25210
25211,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَمْرِو بْنِ عُثْمَانَ ، قَالَ : رَأَیْتُ عَلَی أَبِی جَعْفَرٍ مِلْحَفَۃً حَمْرَائَ۔",,,25211
25212,"حَدَّثَنَا وَکِیعٌ ، عَنِ الْعَلاَئِ بْنِ عَبْدِ الْکَرِیمِ ، قَالَ : رَأَیْتُ عَلَی إِبْرَاہِیمَ ثَوْبًا مُعَصْفَرًا۔",,,25212
25213,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ : کَانَ لاَ یَرَی بَأْسًا بِلُبْسِ الرَّجُلِ الثَّوْبَ الْمَصْبُوغَ بِالْعُصْفُرِ أَوِ الزَّعْفَرَانِ۔",,,25213
25214,"حَدَّثَنَا وَکِیعٌ ، عَنْ مَالِکِ بْنِ مِغْوَلٍ ، قَالَ : رَأَیْتُ عَلَی الشَّعْبِیِّ مِلْحَفَۃً حَمْرَائَ۔",,,25214
25215,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ زَیْدٍ ، عَنْ عَاصِمِ بْنِ بَہْدَلَۃَ ، قَالَ : أَدْرَکْتُ أَقْوَامًا کَانُوا یَتَّخِذُونَ ہَذَا اللَّیْلَ جَمَلاً یَلْبَسُونَ الْمُعَصْفَرَ ، مِنْہُمْ ؛ زِرٌّ ، وَأَبُو وَائِلٍ۔",,,25215
25216,"حَدَّثَنَا وَکِیعٌ ، عَنْ نَصْرِ بْنِ أَوْسٍ ، قَالَ : رَأَیْتُ عَلَی عَلِیِّ بْنِ الْحُسَیْنِ مِلْحَفَۃً حَمْرَائَ۔",,,25216
25217,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَسَنٍ ، عَنْ جَابِر ، عَنْ أَبِی جَعْفَرٍ قَالَ : إِنَّا آلُ مُحَمَّدٍ نَلْبَسُ الْمُعَصْفَرَ۔",,,25217
25218,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ ، عَنْ مُحَمَّدٍ ، قَالَ : کَانَ الْمُعَصْفَرُ لِبَاسَ الْعَرَبِ ، وَلاَ أَعْلَمُ شَیْئًا ہَدَمَہُ فِی الإِسْلاَمِ ، وَکَانَ لاَ یَرَی بِہِ بَأْسًا۔",,,25218
25219,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، أَنَّہُ کَانَ یُصْبَغُ لَہُ الثَّوْبُ بِدِینَارٍ فَیَلْبَسُہُ۔,,,25219
25220,"حَدَّثَنَا إِسْحَاقُ بْنُ سُلَیْمَانَ الرَّازِیُّ ، عَنْ سَلَمَۃَ بْنِ بُخْتٍ ، قَالَ : رَأَیْتُ عَلَی أَبِی جَعْفَرٍ الْمُعَصْفَرَاتِ ، أَوِ الْمُعَصْفَرَ ، وَرَأَیْتُ عَلَیْہِ رَدْعًا مِنَ الْخَلُوقِ۔",,,25220
25221,"حَدَّثَنَا مُعَاوِیَۃَ بْنُ ہِشَامٍ، قَالَ: حدَّثَنَا سُفْیَانُ، عَنْ أَبِیہِ، قَالَ: رَأَیْتُ عَلَی إبْرَاہِیمَ مِلْحَفَۃً حَمْرَائَ مُشَبَّعَۃً۔",,,25221
25222,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، قَالَ : حدَّثَنِی حُسَیْنُ بْنُ وَاقِدٍ ، قَالَ : حَدَّثَنِی عَبْدُ اللہِ بْنُ بُرَیْدَۃَ ، عَنْ أَبِیہِ ، قَالَ: کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَخْطُبُنَا ، فَأَقْبَلَ الْحَسَنُ وَالْحُسَیْنُ عَلَیْہِمَا قَمِیصَانِ أَحْمَرَانِ۔\n\n(ابوداؤد 1102۔ ترمذی 3774)",,,25222
25223,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ مُبَارَکٍ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ مُحَمَّدِ بْنِ إِبْرَاہِیمَ ، عَنْ خَالِدِ بْنِ مَعْدَانَ ، عَنْ جُبَیْر بن نُفَیْر الْحَضْرَمِیِّ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ، قَالَ : رَآنِی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَعَلَیَّ ثَوْبٌ مُعَصْفَرٌ فَقَالَ : أَلْقِہَا ، فَإِنَّہَا ثِیَابُ الْکُفَّارِ۔ (مسلم 27۔ احمد 2/207)",,,25223
25224,"حَدَّثَنَا وَکِیعٌ ، عَنْ أُسَامَۃَ بْنِ زَیْدٍ ، عَنْ عَبْدِ اللہِ بْنِ حُنَیْنٍ ، قَالَ : سَمِعْتُ عَلِیًّا یَقُولُ : نَہَانِی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَلاَ أَقُولُ نَہَاکُمْ ، عَنْ لُبْسِ الْمُعَصْفَرِ۔ (مسلم 1649۔ ابوداؤد 4041)",,,25224
25225,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی بَکْرِ بْنِ حَفْصٍ ، عَن ابنِ حُنَیْنٍ ، عَنِ ابْنِ عَبَّاسٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لاَ تَلْبَسُوا ثَوْبًا أَحْمَرَ متَورِّدًا۔",,,25225
25226,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا مُحَمَّدٌ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، قَالَ : أَقْبَلْنَا مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِنْ ثَنِیَّۃِ أَذَاخِرَ ، فَالْتَفَتَ إِلَیَّ وَعَلَیَّ رَیْطَۃٌ مُضَرَّجَۃٌ بِالْعُصْفُرِ ، فَقَالَ : مَا ہَذِہِ ؟ فَعَرَفْتُ مَا کَرِہَ ، فَأَتَیْتُ أَہْلِی وَہُمْ یَسْجُرُونَ تَنُّورَہُمْ ، فَقَذَفْتُہَا فِیہِ ، ثُمَّ أَتَیْتُہُ مِنَ الْغَدِ فَقَالَ : یَا عَبْدَ اللہِ ، مَا فَعَلَتِ الرَّیْطَۃُ ؟ فَأَخْبَرْتُہُ فَقَالَ : أَلاَ کَسَوْتَہَا بَعْضَ أَہْلِکَ ، فَإِنَّہُ لاَ بَأْسَ بِذَلِکَ لِلنِّسَائِ۔",,,25226
25227,"حَدَّثَنَا عَلِیٌّ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنِ الْحَسَنِ بْنِ سُہَیْلٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الْقَسِّیَّۃِ وَالْمُفَدَّمِ ، قَالَ یَزِیدُ : قُلْتُ لِلْحَسَنِ : مَا الْمُفَدَّمُ ؟ قَالَ : الْمُشَبَّعُ بِالْعُصْفُرِ۔ (بزار 476)",,,25227
25228,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ تَمِیمٍ الْخُزَاعِیِّ ، قَالَ : حدَّثَتْنَا عَجُوزٌ لَنَا ، قَالَتْ : کُنْتُ أَرَی عُمَرَ إِذَا رَأَی عَلَی رَجُلٍ ثَوْبًا مُعَصْفَرًا ضَرَبَہُ ، وَقَالَ : ذَرُوا ہَذِہِ الْبَرَّاقَاتِ لِلنِّسَائِ۔",,,25228
25229,حَدَّثَنَا وَکِیعٌ ، عَنْ فُضَیْلٍ ، عَنْ نَافِعٍ ؛ أَنَّ ابْنِ عُمَرَ رَأَی عَلَی ابْنٍ لَہُ مُعَصْفَرًا ، فَنَہَاہُ۔,,,25229
25230,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُوسٍ ، وَمُجَاہِدٍ ؛ أَنَّہُمْ کَانُوا یَکْرَہُونَ التَّضْرِیجَ فَمَا فَوْقَہُ لِلرِّجَالِ۔,,,25230
25231,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ؛ أَنَّہُ کَانَ یَکْرَہُ الْمُعَصْفَرَ لِلرِّجَالِ۔,,,25231
25232,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللہِ الأَسَدِیُّ ، عَنْ عُبَیْدِ اللہِ بْنِ عَبْدِ اللہِ بْنِ مَوْہَبٍ ، قَالَ : حدَّثَنِی عَمِّی ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنْ عُثْمَانَ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الْمُعَصْفَرِ۔",,,25232
25233,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّہُ کَانَ یَدْخُلُ مَعَ عَلْقَمَۃَ وَالأَسْوَدِ عَلَی أَزْوَاجِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَیَرَاہُنَّ فِی اللُّحُفِ الْحُمْرِ ، قَالَ : وَکَانَ إِبْرَاہِیمُ لاَ یَرَی بِالْمُعَصْفَرِ بَأْسًا۔",,,25233
25234,حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنْ لَیْثٍ، عَنْ عَطَائٍ، وَطَاوُوسٍ، وَمُجَاہِدٍ؛ أَنَّہُمْ کَانُوا لاَ یَرَوْنَ بَأْسًا بِالْحُمْرَۃِ لِلنِّسَائِ۔,,,25234
25235,"حَدَّثَنَا عَبْدُ الْوَہَّابِ ، عَنْ أَیُّوبَ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، قَالَ : رَأَیْتُ عَلَی أُمِّ سَلَمَۃَ دِرْعًا وَمِلْحَفَۃً مُشْبَعَتَیْنِ بِالْعُصْفُرِ۔",,,25235
25236,حَدَّثَنَا عَبْدُاللہِ بْنُ نُمَیْرٍ، عَنْ یَحْیَی بْنِ سَعِیدٍ، عَنِ الْقَاسِمِ؛ أَنَّ عَائِشَۃَ کَانَتْ تَلْبَسُ الثِّیَابَ الْمُعَصْفَرَۃَ، وَہِیَ مُحْرِمَۃٌ۔,,,25236
25237,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنِ الْقَاسِمِ ؛ أَنَّ عَائِشَۃَ کَانَتْ تَلْبَسُ الثِّیَابَ الْمُوَرَّدَۃَ بِالْعُصْفُرِ ، وَہِیَ مُحْرِمَۃٌ۔,,,25237
25238,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ تَمِیمٍ الْخُزَاعِیِّ ، قَالَ : حدَّثَتْنَا عَجُوزٌ ، قَالَتْ : قَالَ عُمَرُ : ذَرُوا ہَذِہِ الْبَرَّاقَاتِ لِلنِّسَائِ۔",,,25238
25239,حَدَّثَنَا غُنْدَرٌ ، عَنْ ہِشَامٍ ، عَنْ فَاطِمَۃَ بِنْتِ الْمُنْذِرِ ؛ أَنَّ أَسْمَائَ کَانَتْ تَلْبَسُ الْمُعَصْفَرَ وَہِیَ مُحْرِمَۃٌ۔,,,25239
25240,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ أَنَّہُ رَأَی بَعْضَ أَزْوَاجِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ تَطُوفُ بِالْبَیْتِ ، وَعَلَیْہَا ثِیَابٌ مُعَصْفَرَۃٌ۔,,,25240
25241,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا بِالْمُعَصْفَرِ لِلنِّسَائِ۔,,,25241
25242,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا إِسْمَاعِیلُ ، عَنْ أُخْتِہِ سُکَیْنَۃَ ، قَالَتْ : دَخَلْتُ مَعَ أُمِّی عَلَی عَائِشَۃَ ، فَرَأَیْتُ عَلَیْہَا دِرْعًا أَحْمَرَ وَخِمَارًا أَسْوَدَ۔",,,25242
25243,حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ ، عَنْ سَعِیدٍ ، عَنْ یَحْیَی بْنِ عَبْدِ اللہِ بْنِ مَالِکٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَصْبُغُ ثِیَابَہُ بِالزَّعْفَرَانِ ، حَتَّی الْعِمَامَۃَ۔ (ابوداؤد 4061۔ احمد 2/126),,,25243
25244,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنْ عُمَرَ بْنِ جَاوَانٍ ، عَنِ الأَحْنَفِ بْنِ قَیْسٍ ، قَالَ : جَائَ عُثْمَانُ وَعَلَیْہِ مَلِیَّۃٌ لَہُ صَفْرَائُ ، قَدْ قَنَّعَ بِہَا رَأْسَہُ۔ (حاکم 361)",,,25244
25245,حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ التَّیْمِیِّ ، عَنْ عَمْرِو بْنِ مَیْمُونَ ؛ أَنَّ عُمَرَ کَانَ عَلَیْہِ یَوْمَ أُصِیبَ ثَوْبٌ أَصْفَرُ۔,,,25245
25246,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی ظَبْیَانَ ، قَالَ : رَأَیْتُ عَلَی عَلِیٍّ قَمِیصًا وَإِزَارًا أَصْفَرَ۔",,,25246
25247,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ رَجُلٍ مِنْ وَلَدِ الزُّبَیْرِ ، یُقَالَ لَہُ : عَبَّادُ بْنُ حَمْزَۃَ ؛ أَنَّ الزُّبَیْرَ بْنَ الْعَوَّامِ کَانَتْ عَلَیْہِ عِمَامَۃٌ صَفْرَائُ مُعْتَجِرًا بِہَا ، فَنَزَلَتِ الْمَلاَئِکَۃُ وَعَلَیْہِمْ عَمَائِمُ صُفْرٌ۔",,,25247
25248,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، قَالَ : رَأَیْتُ عَلَی ابْنِ الْحَنَفِیَّۃِ مِطْرَفًا أَصْفَرَ۔",,,25248
25249,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ إِسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، قَالَ : رَأَیْتُ عَلَی مُصْعَبِ بْنِ سَعْدٍ إِزَارًا أَصْفَرَ، وَہُوَ یَجْلِسُ مَعَ الْمَسَاکِینِ۔",,,25249
25250,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی ظَبْیَانَ ، قَالَ : رَأَیْتُ عَلَی عَلِیٍّ إِزَارًا أَصْفَرَ ، وَخَمِیصَۃً۔",,,25250
25251,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَمْرِو بْنِ مَرْزُوقٍ ، قَالَ : رَأَیْتُ عَلَی إِبْرَاہِیمَ إِزَارًا أَصْفَرَ۔",,,25251
25252,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَنَشِ بْنِ الْحَارِثِ ، قَالَ : رَأَیْتُ عَلَی إِبْرَاہِیمَ رِدَائً أَصْفَرَ ، وَثَوْبًا أَصْفَرَ۔",,,25252
25253,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ مَالِکِ بْنِ مِغْوَلٍ ، عَنْ أُکَیْلٍ ، قَالَ : مَا رَأَیْتُ إِبْرَاہِیمَ فِی صَیْفٍ قَطُّ ، إِلاَّ وَعَلَیْہِ مِلْحَفَۃٌ صَفْرَائُ ، وَإِزَارٌ أَصْفَرُ۔",,,25253
25254,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، حَدَّثَنَا مَالِکُ بْنُ مِغْوَلٍ ، قَالَ : رَأَیْتُ حَمَّادًا یُصَلِّی وَعَلَیْہِ إِزَارٌ أَصْفَرُ۔",,,25254
25255,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، قَالَ : رَأَیْتُ عَلَی عَبْدِ اللہِ بْنِ الْحَسَنِ مِلْحَفَۃً صَفْرَائَ ، یَحْتَبِی بِہَا فِی الْمَسْجِدِ الْحَرَامِ۔",,,25255
25256,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ مُحَمَّدِ بْنِ شُرَحْبِیلَ ، عَنْ قَیْسِ بْنِ سَعْدٍ ، قَالَ : أَتَانَا النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَوَضَعْنَا لَہُ مَائً یَتَبَرَّدُ بِہِ ، فَاغْتَسَلَ ، ثُمَّ أَتَیْتُہُ بِمِلْحَفَۃٍ صَفْرَائَ ، فَرَأَیْتُ أَثَرَ الْوَرْسِ عَلَی عُکَنِہِ۔ (ابوداؤد 5143۔ احمد 3/421)",,,25256
25257,"حَدَّثَنَا ہُشَیم ، عَنْ یَسَارٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : سُئِلَ عَنِ الْفِرَائِ ؟ فَقَالَ : أَحَبَّہَا إِلَیَّ أَلْیَنُہَا۔",,,25257
25258,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : رَأَیْتُ عَلَی إِبْرَاہِیمَ مُسْتُقَۃَ فِرَائٍ۔",,,25258
25259,"حَدَّثَنَا وَکِیعٌ ، عَنِ أَبِی کِبْرَان ، قَالَ : رَأَیْتُ عَلَی الضَّحَّاک مُسْتُقَۃَ فِرَائٍ۔",,,25259
25260,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا ابْنُ عَوْنٍ ، عَنْ مُجَاہِدٍ ، قَالَ : أَبْصَرَ ابْنُ عُمَرَ عَلَی رَجُلٍ فَرْوًا فَأَعْجَبَہُ لِینُہُ ، فَقَالَ : لَوْ أَعْلَمُ ہَذَا ذُکِّیَ لَسَرَّنِی أَنْ یَکُونَ لِی مِنْہُ ثَوْبٌ۔",,,25260
25261,"حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ ثَابِتٍ ، قَالَ : کُنْتُ جَالِسًا مَعَ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی، فَأَتَاہُ رَجُلٌ ذُو ضَفْرَیْنِ ضَخْمٌ ، فَقَالَ لَہُ : یَا أَبَا عِیسَی ، قَالَ لَہُ : نَعَمْ ، قَالَ لَہُ : حَدِّثْنِی مَا سَمِعْتَ فِی الْفِرَائِ ، فَقَالَ : سَمِعْتُ أَبِی یَقُولُ : کُنْتُ جَالِسًا عِنْدَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَأَتَاہُ رَجُلٌ فَقَالَ : یَا رَسُولَ اللہِ ، أُصَلِّی فِی الْفِرَائِ ؟ قَالَ : فَأَیْنَ الدِّبَاغُ ؟۔ (احمد 4/348)",,,25261
25262,حَدَّثَنَا الثَّقَفِیُّ، عَنْ أَیُّوبَ، عَنْ مُحَمَّدٍ، وَنَافِعٍ؛ أَنَّ عَائِشَۃَ أَمَرَتْ إِنْسَانًا مِنْ أَہْلِہَا إِذَا صَلَّی أَنْ یَضَعَ فَرْوَہُ۔,,,25262
25263,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنِ ابْنِ جَبْرٍ ، قَالَ : رَأَیْتُ عَلَی سَعِیدِ بْنِ جُبَیْرٍ مُسْتَقَۃَ فِرَائٍ فَقَالَ : مَا لَبِسْتُہَا إلاَّ لِتُرَی عَلَیَّ ، أَوْ لأُسْأَلَ عَنْہَا۔",,,25263
25264,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّہُ قَالَ فِی الْفِرَائِ مِنْ جُلُودِ الْمَیْتَۃِ : لَوَدِدْتُ أَنَّ عِنْدِی مِنْہَا فَرْوًا فَأَلْبَسُہُ۔",,,25264
25265,"حَدَّثَنَا یُونُسُ بْنُ مُحَمَّدٍ ، عَنْ سَلاَّمِ بْنِ أَبِی مُطِیعٍ ، قَالَ : حدَّثَنِی أَبُو حَصِین ، عَنِ الشَّعْبِیِّ ، قَالَ : خَرَجْتُ مَعَ أَبِی وَائِلٍ حَتَّی أَتَیْنَا الْفَرَّائِینَ ، فَاشْتَرَی فَرْوًا فَقَالَ صَاحِبُ الْفَرْوِ : أَمَا إنِّی أَزِیدُک یَا أَبَا وَائِلٍ ، إِنَّہُ ذُکِّیَ ، فَقَالَ: مَا یَسُرُّنِی أَنِّی اشْتَرَیْتُ الَّذِی قُلْتُ بِقِیرَاطٍ ۔ قَالَ أَبُو حَصِین : وَکَانَ إِبْرَاہِیمُ یَقُولُ ذَلِکَ، وَکَانَ سَعِیدُ بْنُ جُبَیْرٍ یَقُولُ ذَلِکَ۔",,,25265
25266,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، عْن عَبْدِ الرَّحْمَنِ بْنِ وَعْلَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : سَمِعْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : أَیُّمَا إِہَابٍ دُبِغَ ، فَقَدْ طَہُرَ۔ (مسلم 278۔ ابوداؤد 4120)",,,25266
25267,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ لَیْثٍ ، عَنْ شَہْرِ بْنِ حَوْشَبٍ ، عَنْ سَلْمَانَ ، قَالَ : کَانَ لِبَعْضِ أُمَّہَاتِ الْمُؤْمِنِینَ شَاۃٌ ، فَمَاتَتْ فَمَرَّ عَلَیْہَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقَالَ : مَا ضَرَّ أَہْلَہَا لَوِ انْتَفَعُوا بِإِہَابِہَا۔ (ابن ماجہ 3611)",,,25267
25268,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عُبَیْدِ اللہِ ، عَنِ ابْنِ عَبَّاسٍ ، عَنْ مَیْمُونَۃَ ؛ أَنَّ شَاۃً لِمَوْلاَۃِ مَیْمُونَۃَ مُرَّ بِہَا قَدْ أُعْطِیَتْہَا مِنَ الصَّدَقَۃِ مَیْتَۃً ، فَقَالَ : ہَلاَّ أَخَذُوا إِہَابَہَا فَدَبَغُوہُ ، فَانْتَفَعُوا بِہِ ؟ قَالُوا : یَا رَسُولَ اللہِ : إِنَّہَا مَیْتَۃٌ ؟ قَالَ : إِنَّمَا حُرِّمَ أَکْلُہَا۔ (مسلم 276۔ ابوداؤد 4117)",,,25268
25269,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا إِسْمَاعِیلُ ، عَنِ الشَّعْبِیِّ ، قَالَ : أَخْبَرَنَا عِکْرِمَۃُ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ شَاۃً لِسَوْدَۃَ بِنْتِ زَمْعَۃَ مَاتَتْ ، قَالَتْ : فَدَبَغْنَا جِلْدَہَا ، فَکُنَّا نَنْبِذُ فِیہِ حَتَّی صَارَ شَنًّا۔ (بخاری 6686)",,,25269
25270,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَنْبَأَنا أَبُو بِشْرٍ ، عَنْ عِکْرِمَۃَ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَرَّ بِشَاۃٍ لِسَوْدَۃَ بِنْتِ زَمْعَۃَ ، فَقَالَ : أَلاَ انْتَفَعُوا بِإِہَابِہَا ، فَإِنَّ دَبْغَہَا طَہُورُہَا۔",,,25270
25271,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ مُحَمَّدِ بْنِ إِسْمَاعِیلَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : دِبَاغُہَا طَہُورُہَا۔",,,25271
25272,"حَدَّثَنَا خَالِدٌ ، عَنْ مَالِکِ بْنِ أَنَسٍ ، عَنْ یَزِیدَ بْنِ قُسَیْطٍ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ أُمِّہِ ، عَنْ عَائِشَۃَ ، قَالَتْ : أَمَرَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یُسْتَمْتَعَ بِجُلُودِ الْمَیْتَۃِ۔\n\n(ابوداؤد 4121۔ ابن ماجہ 3612)",,,25272
25273,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَرَّ بِشَاۃٍ لِمَوْلاَۃٍ لِمَیْمُونَۃَ مَیْتَۃٍ ، فَقَالَ : ہَلاَّ انْتَفَعُوا بِإِہَابِہَا۔ (مسلم 104۔ احمد 1/277)",,,25273
25274,"حَدَّثَنَا عُبَیْدُ اللہِ ، قَالَ : أَخْبَرَنَا ابْنُ جُرَیْجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، عَنْ مَیْمُونَۃَ ، قَالَتْ : مَاتَتْ شَاۃٌ لإِحْدَی نِسَائِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَلاَّ انْتَفَعْتُمْ بِإِہَابِہَا۔\n\n(مسلم 103۔ احمد 1/277)",,,25274
25275,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا إِسْمَاعِیلُ ، عَنْ قَیْسِ بْنِ أَبِی حَازِمٍ ، قَالَ : حدِّثْتُ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَرَّ بِشَاۃٍ مَیْتَۃٍ ، فَقَالَ : مَا ضَرَّ أَہْلَہَا لَوِ انْتَفَعُوا بِإِہَابِہَا۔",,,25275
25276,حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ صَدَقَۃَ ، عَنْ جَدِّہِ ریَاحِ بْنِ الْحَارِثِ ، عَنِ ابْنِ مَسْعُودٍ ، قَالَ ذَکَاتُہُ دِبَاغُہُ۔,,,25276
25277,"حَدَّثَنَا أَبُو خَالِدٍ ، وَلَیْسَ بِالأَحْمَرِ ، عَنْ ہِشَامٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، عَنْ جَوْنِ بْنِ قَتَادَۃَ ، عَنْ سَلَمَۃَ بْنِ مُحَبِّقٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : ذَکَاۃُ الْجُلُودِ دِبَاغُہَا۔\n\n(احمد 3/476۔ دارقطنی 12)",,,25277
25278,"حَدَّثَنَا عُبَیْدُ اللہِ ، قَالَ : حدَّثَنَا ہَمَّامٌ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، عَنْ جَوْنِ بْنِ قَتَادَۃَ ، عَنْ سَلَمَۃَ بْنِ مُحَبِّقٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، بِمِثْلِہِ۔ (ابوداؤد 4122۔ احمد 5/6)",,,25278
25279,حَدَّثَنَا ہُشَیْمٌ ، عَنِ مَنْصُور ، عَنِ الْحَسَنِ ، عَنْ جَوْنِ بْنِ قَتَادَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، بِمِثْلِہِ ، وَلَم یَذکُرْ مَنْصُورٌ سَلَمَۃَ بْنَ مُحَبِّقٍ۔,,,25279
25280,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ الْمُغِیرَۃِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانَ یُقَالُ : دِبَاغُ الْمَیْتَۃِ طَہُورُہَا۔",,,25280
25281,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، عَنِ ابْنِ مَسْعُودٍ ، أَنَّہُ سُئِلَ عَنِ الْحَرِیرِ وَالذَّہَبِ لِلنِّسَائِ ؟ فَقَالَ : إِنَّمَا ہُنَّ لُعَبُکُمْ ، فَزَیِّنُوہُنَّ بِمَا شِئْتُمْ۔",,,25281
25282,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَلْقَمَۃَ بْنِ مَرْثَدٍ ، عَنْ مُجَاہِدٍ ، قَالَ : أُرَخِّصُ لِلنِّسَائِ فِی الْحَرِیرِ وَالذَّہَبِ ، ثُمَّ قَرَأَ : (أَوَمَنْ یُنَشَّأُ فِی الْحِلْیَۃِ وَہُوَ فِی الْخِصَامِ غَیْرُ مُبِینٍ)۔",,,25282
25283,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مِسْعَرٌ ، عَنِ أَبِی عَوْنٍ ، عَنْ أَبِی صَالِحٍ الْحَنَفِیِّ ، عَنْ عَلِیٍّ ؛ أَنَّ أُکَیْدِرَ دُوْمَۃَ أَہْدَی إِلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ثَوْبَ حَرِیرٍ ، فَأَعْطَاہُ عَلِیًّا فَقَالَ : شَقَّقْہُ خُمُرًا بَیْنَ النِّسْوَۃِ۔\n\n(مسلم 18۔ ابوداؤد 4040)",,,25283
25284,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنْ سَعِیدِ بْنِ أَبِی ہِنْدٍ ، عَنْ أَبِی مُوسَی ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی الْحَرِیرِ وَالذَّہَبِ : حَرَامٌ عَلَی ذُکُورِ أُمَّتِی ، حِلٌّ لإِنَاثِہِمْ۔",,,25284
25285,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ مَعْمَرٍ أَخْبَرَہُ ، عَنِ الزُّہْرِیِّ ، عَنْ أَنَسٍ ، قَالَ : رَأَیْتُ عَلَی زَیْنَبَ بِنْتِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَمِیصَ حَرِیرٍ سِیَرَائَ۔",,,25285
25286,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مَعْقِلُ بْنُ عُبَیْدِ اللہِ ، عَنْ مَیْمُونِ بْنِ مِہْرَانَ ، قَالَ : لاَ بَأْسَ بِالْحَرِیرِ وَالدِّیبَاجِ لِلنِّسَائِ ، إِنَّمَا یُکْرَہُ لَہُنَّ مَا یَصِفُ ، أَوْ یَشِفُّ۔",,,25286
25287,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إِسْرَائِیلُ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : إِنِّی لأَکْسُوَ بَنَاتِی الْحَرِیرَ ، وَأُحَلِّیَہُنَّ الذَّہَبَ۔",,,25287
25288,"حَدَّثَنَا إِسْمَاعِیلُ بْنُ إِبْرَاہِیمَ ، عَن أَیُّوبَ ، عَنْ أَبِی یَزِیدَ الْمُزَنِیِّ ، قَالَ : کَانَ عُمَرُ یَنْہَی النِّسَائَ عَنْ لُبْسِ الْقَبَاطِیِّ ، فَقَالُوا : إِنَّہُ لاَ یَشِفُّ ، فَقَالَ : إِلاَّ یَشِفَّ فَإِنَّہُ یَصِفُ۔",,,25288
25289,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی صَالِحٍ ، قَالَ عُمَرُ : لاَ تُلْبِسُوا نِسَائَکُمُ الْقَبَاطِیَّ ، فَإِنَّہُ إِلاَّ یَشِفَّ یَصِفُ۔",,,25289
25290,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ کَانَ یَکْرَہُ لِلنِّسَائِ لُبْسَ الْقَبَاطِیِّ ، وَقَالَ: إِنَّہُ إِلاَّ یَشِفَّ یَصِفُ۔",,,25290
25291,"حَدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَنْ نَافِعٍ ، قَالَ : کَسَا ابْنُ عُمَرَ مَوْلًی لَہُ یَوْمًا مِنْ قَبَاطِیِّ مِصْرَ ، فَانْطَلَقَ بِہِ فَبَعَثَ ابْنُ عُمَرَ فَدَعَاہُ ، فَقَالَ : مَا تُرِیدُ أَنْ تَصْنَعَ ؟ فَقَالَ : أُرِیدُ أَنْ أَجْعَلَہُ دِرْعًا لِصَاحِبَتِیَّ ، فَقَالَ ابْنُ عُمَرَ : إِنْ لَمْ یَکُنْ یَشِفُّ فَإِنَّہُ یَصِفُ۔",,,25291
25292,"حَدَّثَنَا عَبْدُ الْوَہَّابِ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ ، عَنْ دِقْرۃَ ، عَنْ عَائِشَۃَ ، قَالَتْ : إِنَّا لاَ نَلْبَسُ الثِّیَابَ الَّتِی فِیہَا الصَّلِیبُ۔",,,25292
25293,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، عَنْ أَبِی الْجَحَّافِ ، قَالَ : سَأَلْتُ أَبَا جَعْفَرٍ عَنْ تَابُوتٍ لِی فِیہِ تَمَاثِیلُ ؟ فَقَالَ : حَدَّثَنِی مَنْ رَأَی عُمَرَ یُحَرِّقُ ثَوْبًا فِیہِ صَلِیبٌ ، یَنْزِعُ الصَّلِیبَ مِنْہُ۔",,,25293
25294,حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَأَی عَلَی بَعْضِ أَزْوَاجِہِ سِتْرًا فِیہِ صَلِیبٌ ، فَأَمَرَ بِہِ فقضب۔,,,25294
25295,"حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، عَنْ ثَابِتِ بْنِ عَدِّیٍّ ، قَالَ : مَا رَأَیْتُ ابْنَ عُمَرَ ، وَابْنَ عَبَّاسٍ زَارِّینَ عَلَیْہِمَا قَمِیصَہُمَا قَطُّ۔",,,25295
25296,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عُبَیْدِ اللہِ بْنِ الْعَیْزَارِ ، عَنْ سَعِیدٍ الْمَدَنِی ، قَالَ : کُنْتُ مَعَ أَبِی ہُرَیْرَۃَ فِی جِنَازَۃٍ ، فَرَأَیْتُہُ مُصْفَرَّ اللِّحْیَۃِ ، مُحَلَّلَ الأَزْرَارِ۔",,,25296
25297,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنِ ، عَنْ زُہَیْرٍ ، عَنْ عُرْوَۃَ بْنِ عَبْدِ اللہِ بْنِ قُشَیْرٍ ، قَالَ : حدَّثَنِی مُعَاوِیَۃُ بْنُ قُرَّۃَ ، عَنْ أَبِیہِ ، قَالَ : أَتَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَبَایَعْتُہُ ، وَإِنَّ قَمِیصَہُ لَمُطْلَقٌ ، قَالَ عُرْوَۃُ : فَمَا رَأَیْتُ مُعَاوِیَۃَ ، وَلاَ ابْنَہُ فِی شِتَائٍ ، وَلاَ حَرٍّ إِلاَّ مُطْلَقَۃً أَزْرَارُہُمَا۔ (ترمذی 58۔ ابوداؤد 4079)",,,25297
25298,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ، عَنْ عَبْدِاللہِ بْنِ یَزِیدَ، قَالَ: مَا رَأَیْتُ سَعِیدَ بْنَ الْمُسَیَّبِ شَادًا عَلَیہِ إِِزارہ قَطُّ۔",,,25298
25299,"حَدَّثَنَا وَکِیعٌ ، عَنْ أُسَامَۃَ ، قَالَ : مَا رَأَیْتُ سَالِمًا زَارًّا عَلَیْہِ۔",,,25299
25300,"حَدَّثَنَا وَکِیعٌ ، عَنْ فِطْرٍ ، قَالَ : رَأَیْتُ سَالِمًا مُحَلَّلًا أَزْرَارُہُ۔",,,25300
25301,"حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ ، قَالَ : حدَّثَنَا الرَّبِیعُ بْنُ الْمُنْذِرِ ، عَنْ أَبِیہِ ؛ أَنَّہُ رَأَی عَلَی مُحَمَّدِ بْنِ الْحَنَفِیَّۃِ حَبْرَۃً مُحَلَّلَۃَ الأَزْرَارِ ، وَکَانَ لَہُ بُرْنُسُ خَزٍّ۔",,,25301
25302,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِلاَلِ بْنِ مَیْمُون ، قَالَ : مَا رَأَیْتُ سَعِیدَ بْنَ الْمُسَیَّبِ مُحَلَّلاً أَزْرَارُہُ۔",,,25302
25303,حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، وَجَرِیرٌ ، عَنِ الرُّکَیْنِ ، عَنِ الْقَاسِمِ بْنِ حَسَّانَ ، عَنْ عَمِّہِ عَبْدِ الرَّحْمَنِ بْنِ حَرْمَلَۃَ، عَنِ ابْنِ مَسْعُودٍ، أَنَّ نَبِیَّ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی عَنْ جَرِّ الإِزَارِ۔(ابویعلی 5129۔ احمد 320),,,25303
25304,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ جَبَلَۃَ ، وَمُحَارِبِ بْنِ دِثَارٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ جَرَّ ثَوْبَہُ مِنَ مَخِیْلۃٍ ، لَمْ یَنْظُرِ اللَّہُ إِلَیْہِ یَوْمَ الْقِیَامَۃِ۔\n\n(بخاری 5791۔ مسلم 1652)",,,25304
25305,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إِنَّ الَّذِی یَجُرُّ ثَوْبَہُ مِنَ الْخُیَلاَئِ ، لاَ یَنْظُرُ اللَّہُ إِلَیْہِ یَوْمَ الْقِیَامَۃِ۔ (مسلم 1651۔ احمد 2/55)",,,25305
25306,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ عَطِیَّۃَ ، عَنْ أَبِی سَعِیدٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ جَرَّ إِزَارَہُ مِنَ الْخُیَلاَئِ ، لَمْ یَنْظُرِ اللَّہُ إِلَیْہِ یَوْمَ الْقِیَامَۃِ ، قَالَ : فَلَقِیتُ ابْنَ عُمَرَ بِالْبَلاَطِ ، قَالَ : فَذَکَرْتُ لَہُ حَدِیثَ أَبِی سَعِیدٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : فَأَشَارَ إِلَی أُذُنَیْہِ : سَمِعَتْہُ أُذُنَایَ ، وَوَعَاہُ قَلْبِی۔ (ابن ماجہ 3570)",,,25306
25307,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : مَرَّ بِأَبِی ہُرَیْرَۃَ فَتًی مِنْ قُرَیْشٍ وَہُوَ یَجُرُّ سَبَلَہُ ، فَقَالَ : یَا ابْنُ أَخِی ، إِنِّی سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : مَنْ جَرَّ ثَوْبَہُ مِنَ الْخُیَلاَئِ ، لَمْ یَنْظُرِ اللَّہُ إِلَیْہِ یَوْمَ الْقِیَامَۃِ۔ (ابن ماجہ 3571۔ احمد 2/503)",,,25307
25308,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، قَالَ : أَخْبَرَنَا شَیْبَان ، عَنْ أَشْعَثَ بْنِ أَبِی الشَّعْثَائِ ، قَالَ : حَدَّثَنَا سَعِیدُ بْنُ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنَّ اللَّہَ لاَ یَنْظُرُ إِلَی مُسْبِلٍ۔ (احمد 1/322۔ طبرانی 12413)",,,25308
25309,"حَدَّثَنَا مُعَاوِیَۃَ بْنُ ہِشَامٍ ، عَنْ شَیْبَانَ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ ، أَنَّہُ سَمِعَ عَبْدَ اللہِ بْنَ عُمَرَ یَقُولُ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَنْظُرُ اللَّہُ إِلَی الَّذِی یَجُرُّ إِزَارَہُ خُیَلاَئَ۔\n\n(احمد 2/69)",,,25309
25310,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَلِیِّ بْنِ مُدْرِکٍ ، عَنْ أَبِی زُرْعَۃَ ، عَنْ خَرَشَۃَ بْنِ الْحُرِّ ، عَنْ أَبِی ذَرٍّ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : ثَلاَثَۃٌ لاَ یُکَلِّمُہُمُ اللَّہُ یَوْمَ الْقِیَامَۃِ ، وَلاَ یَنْظُرُ إِلَیْہِمْ ، وَلاَ یُزَکِّیہِمْ ، وَلَہُمْ عَذَابٌ أَلِیمٌ ؛ الْمُسْبِلُ ، وَالْمَنَّانُ ، وَالْمُنْفِقُ سِلْعَتَہُ بِالْحَلِفِ الْکَاذِبِ۔ (مسلم 102۔ ابوداؤد 4084)",,,25310
25311,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنْ مُجَاہِدٍ ، قَالَ : کَانَ یُقَالُ : مَنْ مَسَّ إِزَارُہُ کَعْبَیْہِ لَمْ تُقْبَلْ لَہُ صَلاَۃٌ، قَالَ : وَقَالَ ذِِرٌّ : مَنْ مَسَّ إِزَارُہُ الأَرْضَ لَمْ تُقْبَلْ لَہُ صَلاَۃٌ۔",,,25311
25312,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ إِبْرَاہِیمَ ، عَنِ ابْنِ مَسْعُودٍ ، قَالَ : دَخَلَ شَابٌّ عَلَی عُمَرَ ، فَجَعَلَ الشَّابُّ یُثْنِی عَلَیْہِ ، قَالَ : فَرَآہُ عُمَرُ یَجُرُّ إِزَارَہُ ، قَالَ : فَقَالَ لَہُ : یَا ابْنَ أَخِی ، ارْفَعْ إِزَارَک ، فَإِنَّہُ أَتْقَی لِرَبِّکَ وَأَنْقَی لِثَوْبِکَ ، قَالَ : فَکَانَ عَبْدُ اللہِ یَقُولُ : یَا عَجَبًا لِعُمَرَ أَنْ رَأَی حَقَّ اللہِ عَلَیْہِ ، فَلَمْ یَمْنَعْہُ مَا ہُوَ فِیہِ أَنْ تَکَلَّمَ بِہِ۔",,,25312
25313,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ أَبِی وَائِلٍ ، عَنِ ابْنِ مَسْعُودٍ ؛ أَنَّہُ کَانَ یُسْبِلُ إِزَارَہُ ، فَقِیلَ لَہُ ، فَقَالَ : إِنِّی رَجُلٌ حَمِشُ السَّاقَیْنِ۔",,,25313
25314,"حَدَّثَنَا جَرِیرٌ، عَنْ أَبِی سِنَانٍ، عَنْ عَبْدِاللہِ بْنِ أَبِی الْہُذَیْلِ، قَالَ: سَأَلَ أَبُوبَکْرٍ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ مَوْضِعِ الإِزَارِ ؟ فَقَالَ : مُسْتَدَقَّ السَّاقِ ، لاَ خَیْرَ فِیمَا أَسْفَلَ مِنْ ذَلِکَ ، وَلاَ خَیْرَ فِیمَا فَوْقَ ذَلِکَ۔",,,25314
25315,"حَدَّثَنَا أَبُو الأَحْوَص ، عَنْ أَبِی إِسْحَاقَ ، عَنْ مُسْلِمِ بْنِ نُذَیْرٍ ، عَنْ حُذَیْفَۃَ ، قَالَ : أَخَذَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِأَسْفَلِ عَضَلَۃِ سَاقِی ، أَوْ سَاقِہِ ، فَقَالَ : ہَذَا مَوْضِعُ الإِزَارِ ، فَإِنْ أَبَیْتَ فَأَسْفَلَ ، فَإِنْ أَبَیْتَ فَأَسْفَلَ ، فَإِنْ أَبَیْتَ فَلاَ حَقَّ للإِزَارِ فِی الْکَعْبَیْنِ۔ (ترمذی 1783۔ ابن ماجہ 3572)",,,25315
25316,"حَدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، قَالَ : سَمِعْتُ أَبَا نَبِیہٍ یَقُولُ : سَمِعْتُ عَائِشَۃَ تَقُولُ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَا تَحْتَ الْکَعْبِ مِنَ الإِزَارِ فِی النَّارِ۔ (احمد 6/59)",,,25316
25317,"حَدَّثَنَا أَبُو الأَحْوَص ، عَنْ أَبِی یَعْفُورَ ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ وَإِنَّ إزَارَہُ إِلَی نِصْفِ سَاقَیْہِ ، أَوْ قَرِیبٍ مِنْ نِصْفِ سَاقَیْہِ۔",,,25317
25318,"حَدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنِ الْعَلاَئِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ یَعْقُوبَ ، عَنْ أَبِیہِ ، عَنْ أَبِی سَعِیدٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِزْرَۃُ الْمُؤْمِنِ إِلَی نِصْفِ السَّاقِ ، فَمَا کَانَ إِلَی الْکَعْبِ فَلاَ بَأْسَ ، وَمَا کَانَ تَحْتَ الْکَعْبِ فَفِی النَّارِ۔ (ابوداؤد 4090۔ احمد 3/30)",,,25318
25319,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ أَبِی غِفَارٍ ، عَنْ أَبِی تَمِیمَۃَ الْہُجَیْمِیِّ ، عَنْ أَبِی جُرَیٍّ الْہُجَیْمِیِّ ، قَالَ : أَتَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقُلْتُ : عَلَیْکَ السَّلاَمُ یَا رَسُولَ اللہِ ، قَالَ: لاَ تَقُلْ: عَلَیْک السَّلاَمُ؟ فَإِنَّ عَلَیْک السَّلاَمُ تَحِیَّۃُ الْمَوتَی ، قَالَ : قُلْتُ : یَا رَسُولَ اللہِ ، زِدْنِی ، قَالَ : الإِزَارُ إِلَی نِصْفِ السَّاقِ ، فَإِن أَبَیتَ فَإِلَی الْکَعْبِین ، وَإِیَّاکَ وَالْمَخِیلَۃَ ، فَإِنَّ اللہ لاَ یُحِب الْمَخِیلَۃَ۔ (ابوداؤد 4081۔ ترمذی 2721)",,,25319
25320,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیِّ ، عن جَعْفَرٍ ، قَالَ : کَانَ مَیْمُونٌ یُشَمِّرُ إِزَارَہُ إِلَی أَنْصَافِ سَاقَیْہِ۔",,,25320
25321,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا وُہَیْبٌ ، قَالَ : حَدَّثَنَا دَاوُد بْنُ أَبِی ہِنْدٍ ، عَنْ أَبِی قَزَعَۃَ ، عَنِ الأَسْقَعِ بْنِ الأَسْلَعِ ، عَنْ سَمُرَۃََ بْنِ جُنْدَبٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : مَا أَسْفَلَ مِنَ الْکَعْبَیْنِ مِنَ الإِزَارِ فِی النَّارِ۔ (احمد 5/9)",,,25321
25322,حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی مَکِینٍ ، عَنْ خَالِدٍ ، عَنْ أَبِی أُمَیَّۃَ ؛ أَنَّ عَلِیًّا اتَّزَرَ ، فَلَحِقَ إِزَارُہُ بِرُکْبَتَیْہِ۔,,,25322
25323,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : مَوْضِعُ الإِزَارِ مُسْتَدَقُّ السَّاقِ۔",,,25323
25324,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ حُمَیْدٍ ، عَنْ أَنَسٍ ، قَالَ : الإِزَارُ إِلَی نِصْفِ السَّاقِ ، أَوْ إِلَی الْکَعْبَیْنِ ، لاَ خَیْرَ فِیمَا ہُوَ أَسْفَلُ مِنْ ذَلِکَ۔",,,25324
25325,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : کَانُوا یَکْرَہُونَ الإِزَارَ فَوْقَ نِصْفِ السَّاقِ۔",,,25325
25326,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ سُلَیْمَانَ بْنِ مُسْہِرٍ ، عَنْ خَرَشَۃَ ؛ أَنَّ عُمَرَ دَعَا بِشَفْرَۃٍ فَرَفَعَ إِزَارَ رَجُلٍ عَنْ کَعْبَیْہِ ، ثُمَّ قَطَعَ مَا کَانَ أَسْفَلَ مِنْ ذَلِکَ ، قَالَ : فَکَأَنِّی أَنْظُرُ إِلَی ذَبَاذِبِہِ تَسِیلُ عَلَی عَقِبَیْہِ۔",,,25326
25327,"حَدَّثَنَا إِسْحَاقُ بْنُ سُلَیْمَانَ ، عَنْ أَبِی سِنَانٍ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : رَأَیْتُ نَاسًا مِنْ أَصْحَابِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَأْتَزِرُونَ عَلَی أَنْصَافِ سُوقِہِمْ ، فَذَکَرَ أُسَامَۃَ بْنَ زَیْدٍ ، وَابْنَ عُمَرَ ، وَزَیْدَ بْنَ أَرْقَمَ ، وَالْبَرَائَ بْنَ عَازِبٍ۔",,,25327
25328,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ مُحَمَّدِ بْنِ أَبِی یَحْیَی ، عَنْ عِکْرِمَۃَ ، قَالَ : رَأَیْتُ ابْنَ عَبَّاسٍ یَأْتَزِرُ فَیُرْسِلُ إِزَارَہُ مِنْ بَیْنِ یَدَیْہِ ، حَتَّی تَقَعَ حَاشِیَتُہْمَا عَلَی ظَہْرِ قَدَمَیْہِ ، وَیَرْفَعُہُمَا مِنْ مُؤَخَّرِہِ۔\n\n(ابوداؤد 4093۔ نسائی 9681)",,,25328
25329,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا أَبُو سُلَیْمَانَ الْمُکْتِبُ ، عَنْ أَبِیہِ ، قَالَ : رَأَیْتُ عَلِیًّا عَلَیْہِ إِزَارٌ نَجْرَانِیٌّ إِلَی أَنْصَافِ سَاقَیْہِ۔",,,25329
25330,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُوسَی بْنِ دِہْقَانٍ ، قَالَ : رَأَیْتُ أَبَا سَعِیدٍ ، وَابْنَ عُمَرَ أُزْرُہُمَا إِلَی أَنْصَافِ سُوقِہِمَا۔",,,25330
25331,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، قَالَ : أَخْبَرَنَا مُوسَی بْنُ عُبَیْدَۃَ ، عَنْ إیَاسِ بْنِ سَلَمَۃَ ، عَنْ أَبِیہِ ؛ أَنَّ عُثْمَانَ بْنَ عَفَّانَ کَانَ إِزَارُہُ إِلَی نِصْفِ سَاقَیْہِ ، قَالَ : فَقِیلَ لَہُ فِی ذَلِکَ ؟ فَقَالَ : ہَذِہِ إِزَرَۃُ حَبِیبِی ، یَعْنِی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔ (ترمذی 121۔ بزار 353)",,,25331
25332,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا شَرِیکٌ ، عَنْ عَبْدِ الْمَلِکِ بْنِ عُمَیْرٍ ، عَنْ حُصَیْنِ بْنِ قَبِیصَۃَ ، عَنِ الْمُغِیرَۃِ بْنِ شُعْبَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : یَا سُفْیَانُ بْنُ سَہْلٍ ، لاَ تُسْبِلْ ، فَإِنَّ اللَّہَ لاَ یُحِبُّ الْمُسْبِلِینَ۔ (احمد 4/246۔ ابن حبان 5442)",,,25332
25333,"حَدَّثَنَا عَبْدُ الْوَہَّابِ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ ، عَنْ أُسَیْرِ بْنِ جَابِرٍ : کَانَ یَکْرَہُ الْخِفَافَ وَالنِّعَالَ الَّتِی لَمْ تُذَکَّ۔",,,25333
25334,حَدَّثَنَا الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ ؛ أَنَّ عَائِشَۃَ کَانَتْ تَکْرَہُ الْفِرَائَ الَّتِی لَمْ تُذَکَّ۔,,,25334
25335,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ أَشْعَثَ ، عَنْ مُحَمَّدٍ ، قَالَ : کَانَ مِمَّنْ یَکْرَہُ الصَّلاَۃَ فِیمَا لَمْ یُذَکَّ ؛ عُمَرُ ، وَابْنُ عُمَرَ ، وَعِمْرَانُ بْنُ حُصَیْنٍ ، وَعَائِشَۃُ ، وَأُسَیْرُ بْنُ جَابِرٍ۔",,,25335
25336,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، عَنْ عَمْرِو بْنِ مُہَاجِرٍ ، قَالَ : کَانَتْ قُمُصُ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ وَثِیَابُہُ مَا بَیْنَ الْکَعْبِ وَالشِّرَاکِ۔",,,25336
25337,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنِ ابْنِ أَبِی رَوَّادٍ ، عَنْ سَالِمٍ ، عَنْ أَبِیہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : الإِسْبَالُ فِی الإِزَارِ ، وَالْقَمِیصِ ، وَالْعِمَامَۃِ ، مَنْ جَرَّ مِنْہَا شَیْئًا خُیَلاَئَ ، لَمْ یَنْظُرِ اللَّہُ إِلَیْہِ یَوْمَ الْقِیَامَۃِ۔\n\n(ابوداؤد 4091۔ ابن ماجہ 3576)",,,25337
25338,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ عَبْدِ الْمَلِکِ بْنِ أَبِی سُلَیْمَانَ ، عَنْ سُلَیْمَانَ الأَحْوَلِ ، عَنْ مُجَاہِدٍ ، قَالَ : جَرُّ الْقَمِیصِ وَالإِزَارِ سَوَائٌ۔",,,25338
25339,"حَدَّثَنَا یَزِیدُ ، قَالَ : أَخْبَرَنَا إِسْمَاعِیلُ ، عَنْ شُعَیْبِ بْنِ یَسَارٍ ، قَالَ : ذَکَرُوا عِنْدَ عِکْرِمَۃَ جَرَّ الْقَمِیصِ وَالإِزَارِ ، فَقَالَ : ہُوَ وَاللَّہِ شَرٌّ وَأَشَرُّ۔",,,25339
25340,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ أَبِی ہَاشِمٍ ، عَنْ طَاوُوسٍ ، قَالَ : کَانَ قَمِیصُہُ فَوْقَ الإِزَارِ ، وَالرِّدَائُ فَوْقَ الْقَمِیصِ۔",,,25340
25341,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ دَاوُدَ بْنِ قَیْسٍ ، قَالَ : رَأَیْتُ الْقَاسِمَ قَمِیصُہُ إِلَی الْکَعْبِ۔",,,25341
25342,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ أَبِی عَوَانَۃَ ، عَنْ مُغِیرَۃَ ، قَالَ : کَانَ إِبْرَاہِیمُ قَمِیصُہُ عَلَی ظَہْرِ الْقَدَمِ۔",,,25342
25343,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُحَمَّدِ بْنِ عُمَیْرٍ ، قَالَ : رَأَیْتُ قَمِیصَ سَالِمٍ مُشَمَّرًا فَوْقَ الْکَعْبَیْنِ ، فَقَالَ : إنِّی رَأَیْتُ ابْنَ عُمَرَ کَانَ قَمِیصُہُ ہَکَذَا۔",,,25343
25344,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ جَعْفَرِ ، عَنْ عَلِیٍّ ، قَالَ : ابْتَاعَ عَلِیٌّ قَمِیصًا سُنْبُلاَنِیًّا بِأَرْبَعَۃِ دَرَاہِمَ ، وَدَعَا الْخَیَّاطَ ، فَمَدَّ کُمَّ الْقَمِیصِ ، وَأَمَرَہُ أَنْ یَقْطَعَ مَا خَلْفَ أَصَابِعِہِ۔",,,25344
25345,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، قَالَ : أَخْبَرَنَا سَعِیدٌ الْجُرَیْرِیُّ ، عَنْ أَبِی عُثْمَانَ النَّہْدِیِّ ؛ أَنَّ عُمَرَ بْنَ الْخَطَّابِ دَعَا بِشَفْرَۃٍ لِیَقْطَعَ کُمَّ قَمِیصِ عُتْبَۃَ بْنِ فَرْقَدَ مِنْ أَطْرَافِ أَصَابِعِہِ ، وَکَانَ عَلَیْہِ قَمِیصٌ سُنْبُلاَنِیٌّ ، فَقَالَ : أَنَا أَکْفِیکَہُ یَا أَمِیرَ الْمُؤْمِنِینَ ، إِنِّی أَسْتَحِی أَنْ تَقْطَعَہُ عِنْدَ النَّاسِ ، فَتَرَکَہُ۔",,,25345
25346,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الأَجْلَحِ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی الْہُذَیْلِ ، قَالَ : رَأَیْتُ عَلِیًّا عَلَیْہِ قَمِیصٌ مَدَریٌّ ، أَوْ رَازِقِیٌّ ، إِذَا أَرْسَلَہُ بَلَغَ نِصْفَ سَاقَیْہِ ، وَإِذَا مَدَّہُ لَمْ یُجَاوِزْ ظُفْرَیْہِ۔",,,25346
25347,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی الْبُحْتُرِیِّ ، قَالَ : رَأَیْتُ أَنَسَ بْنَ مَالِکٍ وَکُمُّ قَمِیصِہِ إِلَی الرَّصْغِ۔",,,25347
25348,"حَدَّثَنَا وَکِیعٌ، عَنْ مُوسَی الْمُعَلِّمِ، عَنْ بُدَیْلٍ الْعُقَیْلِیِّ، قَالَ: کَانَ کُمُّ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إِلَی الرَّصْغِ۔\n\n(ابوداؤد 4023۔ ترمذی 1765)",,,25348
25349,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ مُحَمَّدِ بْنِ أَبِی یَحْیَی ، قَالَ : حدَّثَنِی أَبُو الْعَلاَئِ ، قَالَ : رَأَیْتُ عَلِیًّا یَأْتَزِرُ فَوْقَ السُّرَّۃِ۔",,,25349
25350,"حَدَّثَنَا وَکِیعٌ ، عَنْ قُدَامَۃَ بْنِ مُوسَی ، عَنْ أَبِیہِ ، قَالَ : صَلَّیْتُ إِلَی جَنْبِ ابْنِ عُمَرَ ، وَقَدِ اتَّزَرَ فَوْقَ السُّرَّۃِ ، فَجَذَبَہُ حَتَّی جَعَلَہُ أَسْفَلَ مِنْہَا۔",,,25350
25351,حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ، عَنْ ہِشَامٍ، عَنِ الْحَسَنِ، وَابْنِ سِیرِینَ؛ أَنَّہُمَا کَانَا یَتَّزِرَانِ إِلَی أَسْفَلَ مِنَ السُّرَّۃِ۔,,,25351
25352,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ اللہِ بْنِ سَعِیدٍ ، قَالَ : رَأَیْتُ عَلَی عَلِیِّ بْنِ الْحُسَیْنِ قَلَنْسُوَۃً بَیْضَائَ مضرَّبۃ۔",,,25352
25353,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ ہِشَامٍ ، قَالَ : رَأَیْتُ عَلَی ابْنِ الزُّبَیْرِ قَلَنْسُوَۃً لَہَا رفٌّ ، کَانَ یَسْتَظِلُّ بِہَا إِذَا طَافَ بِالْبَیْتِ۔",,,25353
25354,حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ ، قَالَ ، رَأَیْتُ عَلَی إِبْرَاہِیمَ قَلَنْسُوَۃً مَکْفُوفَۃً بِثَعَالِبَ ، أَوْ سُمُورٍ۔,,,25354
25355,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ الأَجْلَحِ ، قَالَ : رَأَیْتُ عَلَی الضَّحَّاکِ قَلَنْسُوَۃَ ثَعَالِبَ۔",,,25355
25356,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ أَشْعَثَ ، عَنْ أَبِیہِ ؛ أَنَّ أَبَا مُوسَی خَرَجَ مِنَ الْخَلاَئِ ، وَعَلَیْہِ قَلَنْسُوَۃٌ ، فَمَسَحَ عَلَیْہَا۔,,,25356
25357,"حَدَّثَنَا عَبْدَۃُ ، عَنْ مِسْعَرٍ ، عَنْ عُثْمَانَ بْنِ الْمُغِیرَۃِ ، عَنْ عَلِیِّ بْنِ رَبِیعَۃَ ، قَالَ : رَأَیْتُ عَلِیًّا یَتَّزِرُ ، فَرَأَیْتُ عَلَیْہِ تُبَّانًا۔",,,25357
25358,"حَدَّثَنَا عَبْدَۃُ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنِ الْقَاسِمِ ، قَالَ : کَانَتْ عَائِشَۃُ إِذَا خَرَجَتْ حَاجَّۃً ، أَوْ مُعْتَمِرَۃً أَخْرَجَتْ مَعَہَا عَبِیدَہَا یُرَحِّلُونَ ہَوْدَجَہَا ، فَکَانُوا یُشعرُونَ بِأَرْجُلِہِمْ إِلَی بَطْنِ الْبَغْلَۃِ ، فَأَمَرَتْہُمْ أَنْ یَلْبَسُوا التَّبَّابِینَ۔",,,25358
25359,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی الْہَیْثُمِ قَالَ : قَالَ سَلْمَانُ : نِعْمَ الثَّوْبُ التُّبَّانُ۔",,,25359
25360,"حَدَّثَنَا أَسْبَاطٌ ، عَنِ الْعَلاَئِ بْنِ حَبِیبٍ ، قَالَ : رُئِی عَلَی عَمَّارِ بْنِ یَاسِرٍ تُبَّانٌ وَہُوَ بِعَرَفَاتٍ۔",,,25360
25361,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، قَالَ : کَانَ أَبِی یَلْبَس تُبَّانًا تَحْتَ الإِزَار۔",,,25361
25362,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، قَالَ : رَأَیْتُ أَبَا صَادِقٍ یَتَّزر ، فَرَأَیْتُ تَحْتَ إِزَارِہِ تُبَّانًا۔",,,25362
25363,"حَدَّثَنَا وَکِیعٌ ، عَنْ طَلْحَۃَ بْنِ یَحْیَی ، قَالَ : رَأَیْتُ عَلَی عَلِیِّ بْنِ رَبِیعَۃَ الْوَالِبِی تُبَّانًا ، قَالَ : کَانَ الشَّیْخُ ، یَعْنِی عَلِیًّا ، یَلْبَسُہُ۔",,,25363
25364,حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ؛ أَنَّہَا کَانَتْ تَأْمُرُ غِلْمَانَہَا بِلُبْسِ التَّبَّابِینَ وَہُمْ مُحْرِمُونَ۔,,,25364
25365,"حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ ثَابِتٍ ، عَنْ أَنَسٍ ، قَالَ : کَانَ أَبُو مُوسَی إِذَا نَامَ لَبِسَ تُبَّانًا ، مَخَافَۃَ أَنْ تَبْدُوَ عَوْرَتُہُ۔",,,25365
25366,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ الْجُرَیْرِیِّ ، عَنْ أَبِی عُثْمَانَ ، قَالَ : کَتَبَ عُمَرُ إِلَی أَبِی مُوسَی : أَنَ قَطِّعُوا الرّکُبَ، وَانْزُوا عَلَی الْخَیْلِ نَزْوًا ، وَأَلْقُوا الْخِفَافَ ، وَاحتذُوا النِّعَالَ ، وَأَلْقُوا السَّرَاوِیلاَتِ ، وَاتَّزِرُوا ، وَارْمُوا الأَغْرَاضَ، وَعَلَیْکُمْ بِاللِّبْسَۃِ الْمُعَدِّیَۃِ ، وَإِیَّاکُمْ وَہَدْیَ الْعَجَمِ ، فَإِنَّ شَرَّ الْہَدْیِ ، ہَدْیُ الْعَجَمِ۔",,,25366
25367,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سِمَاکِ بْنِ حَرْبٍ ، عَنْ سُوَیْد بْنِ قَیْسٍ ، قَالَ : أَتَانَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَسَاوَمَنَا سَرَاوِیلَ۔",,,25367
25368,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُعَاذِ بْنِ الْعَلاَئِ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، قَالَ : خَطَبَنَا عَلِیٌّ بِالْکُوفَۃِ وَعَلَیْہِ سَرَاوِیلُ۔",,,25368
25369,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَفْصِ بْنِ أَبِی مَنْصُورٍ ، قَالَ : رَأَیْتُ عَلَی الشَّعْبِیِّ سَرَاوِیلَ۔",,,25369
25370,"حَدَّثَنَا وَکِیعٌ ، عَنْ مَہْدِیٍّ ، قَالَ : کَانَ الْحَسَنُ إِذَا کَانَ الشِّتَائُ لَبِسَ سَرَاوِیلَ حِبَرَۃٍ ، وَقَبَائَ حِبَرَۃٍ۔",,,25370
25371,"حَدَّثَنَا وَکِیعٌ، عَنْ عِمْرَانَ، عَنْ أَبِی مِجْلَزٍ، قَالَ: جَائَ کِتَابُ عُمَرَ: أَنْ أَلْقُوا السَّرَاوِیلاَتِ، وَالْبَسُوا الأُزُرَ۔",,,25371
25372,"حَدَّثَنَا جَرِیرُ بْنُ حَازِمٍ ، عَنْ وَاصِلٍ مَوْلَی أَبِی عُیَیْنَۃَ ، قَالَ : إِنَّ اللَّہَ تَعَالَی أَوْحَی إِلَی إِبْرَاہِیمَ : إِنَّکَ أَکْرَمُ الْخَلْقِ عَلَیَّ ، فَإِذَا صَلَّیْتَ فَلاَ تَری الأَرْضُ عَوْرَتَکَ ، وَاتَّخِذْ سَرَاوِیلاً۔",,,25372
25373,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ أَبِی خَلْدَۃَ ، قَالَ : رَأَیْتُ أَبَا الْعَالِیَۃِ عَلَیْہِ سَرَاوِیلُ ، قَالَ : فَقُلْتُ لَہُ ؟ قَالَ : إِنَّہَا مِنْ لِبَاسِ الرِّجَالِ۔",,,25373
25374,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا ہَمَّامٌ ، عَنْ قَتَادَۃَ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : کُلُوا وَاشْرَبُوا وَتَصَدَّقُوا ، وَالْبَسُوا مَا لَمْ یُخَالِطْہُ إِسْرَافٌ ، وَلاَ مَخِیلَۃٌ۔ (ابن ماجہ 3605۔ احمد 2/181)",,,25374
25375,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ إِبْرَاہِیمَ بْنِ مَیْسَرَۃَ ، عَنْ طَاوُوسٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : کُلْ مَا شِئْتَ ، وَالْبَسْ مَا شِئْتَ ، مَا أَخْطَأَتْک خُلَّتَانِ : سَرَفٌ ، أَوْ مَخِیلَۃٌ۔",,,25375
25376,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ؛ فِی قَوْلِہِ تَعْالَی : { وَالَّذِینَ إِذَا أَنْفَقُوا لَمْ یُسْرِفُوا وَلَمْ یَقْتُرُوا وَکَانَ بَیْنَ ذَلِکَ قَوَامًا } قَالَ : لاَ تُجِیعُہُمْ ، وَلاَ تُعَرِّیہِمْ ، وَلاَ تُنْفِقُ نَفَقَۃً یَقُولُ النَّاسُ : إِنَّک أَسْرَفْتَ فِیہَا۔",,,25376
25377,"حَدَّثَنَا وَکِیعٌ ، عَنْ شَرِیکٍ ، عَنْ عُثْمَانَ الْحَاطِبِیِّ ، قَالَ : أَخْبَرَنِی مَنْ رَأَی عَلَی عُثْمَانَ ثَوْبًا قُوہِیًّا۔",,,25377
25378,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ إِسْمَاعِیلَ بْنِ سُمَیْعٍ ، عَنْ أَبِی رَزِینٍ ، قَالَ : خَرَجَ عَلِیُّ بْنُ أَبِی طَالِبٍ وَعَلَیْہِ قَمِیصٌ مِنْ قَہْزٍ ، وَعَلَیْہِ بُرْدان قِطْرِیَان۔",,,25378
25379,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ صَالِحٍ ، عَنْ عَطَائٍ أَبِی مُحَمَّدٍ ، قَالَ : رَأَیْتُ عَلَی عَلِیٍّ قَمِیصًا مِنْ ہَذِہِ الْکَرَابِیسِ غَیْرَ غَسِیلٍ۔",,,25379
25380,"( حَدَّثَنَا وَکِیعٌ ، عَنْ مَیمُون أَبِی القَاسِم قَالَ : رَأَیْتُ عَلَی عَطَاء قَمِیصًا زُطِّیًّا۔",,,25380
25381,"حَدَّثَنَا وَکِیعٌ ، عَنْ خَالِدٍ أَبِی الْعَلاَئِ ، قَالَ : رَأَیْتُ عَلَی الْحَسَنِ قَمِیصًا زَطِیًّا۔",,,25381
25382,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، قَالَ : رَأَیْتُ عَلَیْہِ قَمِیصًا غَلِیظًا۔",,,25382
25383,"حَدَّثَنَا وَکِیعٌ ، عَنْ سَعِیدِ بْنِ السَّائِبِ الطَّائِفِیِّ ، عَنْ مُحَمَّدِ بْنِ السَّائِبِ بْن أَبِی ہِنْدیۃَ ، عَنْ أَبِیہِ ، قَالَ : رَأَیْتُ عَلَی عُمَرَ ثَوْبَیْنِ قِطْرِیَّیْنِ۔",,,25383
25384,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُطَیْرِ بْنِ ثَعْلَبَۃَ ، عَنْ أَبِی النَّوَارِ ، قَالَ : رَأَیْتُ عَلِیًّا اشْتَرَی قَمِیصَیْنِ غَلِیظَیْنِ خیَّر قَنْبر أَحَدَہمَا۔",,,25384
25385,"حَدَّثَنَا وَکِیعٌ ، عَنْ سَعِیدِ بْنِ عُبَیْدٍ ، عَنْ عَلِیِّ بْنِ رَبِیعَۃَ ، قَالَ : رَأَیْتُ عَلَی عَلِیٍّ ثَوْبَیْنِ قِطْرِیَّیْنِ۔",,,25385
25386,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ مَنْصُورٍ، عَنْ إِبْرَاہِیمَ، قَالَ: کَانَ مَنْ قَبْلَکُمْ أَسْفَقَ ثِیَابًا، وَأَشْفَقَ قُلُوبًا۔",,,25386
25387,"حَدَّثَنَا یَزِیدُ ، عَنِ الْجُرَیْرِیِّ ، عَنْ أَبِی طَلْحَۃَ ، قَالَ : خَرَجَ طَلْحَۃُ بْنُ عُبَیْدِ اللہِ وَعَلَیْہِ ثَوْبَانِ مُمَصَّرَانِ۔",,,25387
25388,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ ، عَنْ أُمِّ سَلَمَۃَ ، قَالَتْ : سُئِلَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : کَمْ تَجُرُّ الْمَرْأَۃُ مِنْ ذَیْلِہَا ؟ قَالَ : شِبْرًا ، قَالَتْ : إِذًا یَنْکَشِفُ عَنْہُا ؟ قَالَ : فَذِرَاعًا ، لاَ تَزِیدُ عَلَیْہِ۔ (ابوداؤد 4115۔ احمد 2/55)",,,25388
25389,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ زَیْدٍ الْعَمِّیِّ ، عَنْ أَبِی الصِّدِّیقِ ، عنِ ابْنِ عُمَرَ ؛ أَنَّ أَزْوَاجَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رُخِّصَ لَہُنَّ فِی الذَّیْلِ شِبْرًا ، فَکُنَّ یَأْتِینَنَا فَنَذْرَعُ لَہُنَّ بِالْقَصَبِ ذِرَاعًا۔\n\n(ابوداؤد 4116۔ احمد 2/18)",,,25389
25390,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ شَبَّرَ لِفَاطِمَۃَ شِبْرًا ، ثُمَّ قَالَ : ہَذَا قَدْرُ ذَیْلِکِ۔",,,25390
25391,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ أَبِی الْمُہَزِّمِ ، عَنْ أَبِی ہُرَیْرَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ لِفَاطِمَۃَ ، أَوْ لأُمِّ سَلَمَۃَ : ذَیْلُکِ ذِرَاعٌ۔ (ابن ماجہ 3583۔ احمد 2/263)",,,25391
25392,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : حَدَّثَنَا إِسْمَاعِیلُ بْنُ أَبِی خَالِدٍ ، عَنْ یُونُسَ بْنِ أَبِی خَالِدٍ ، قَالَ : کَانَ یُؤْمَرُ أَنْ تَجْعَلَ الْمَرْأَۃُ ذَیْلَہَا ذِرَاعًا۔",,,25392
25393,"حَدَّثَنَا ہُشَیْمٌ، عَنِ ابْنِ عَوْنٍ، عَنِ ابْنِ سِیرِینَ ، قَالَ: کَانُوا لاَ یَرَوْنَ بَأْسًا بِصُوفِ الْمَیْتَۃِ ، وَشَعْرِ الْوَبَرِ۔",,,25393
25394,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَبْدِ الْخَالِقِ ، عَنْ حَمَّادٍ فِی صُوفِ الْمَیْتَۃِ : إِذَا غُسِلَ فَہُوَ ذَکَاتُہُ۔",,,25394
25395,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا ہِشَامٌ ، عَنِ الْحَسَنِ ، وَمُحَمَّدٍ ؛ أَنَّہُمَا کَانَا لاَ یَرَیَانِ بَأْسًا بِصُوفِ الْمَیْتَۃِ أَنْ یُنْتَفَعَ بِہِ ، وَقَالَ الْحَسَنُ : یُغْسَلُ۔",,,25395
25396,"حَدَّثَنَا یَزِیدُ ، قَالَ : أَخْبَرَنَا ابْنُ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : کَانُوا لاَ یَرَوْنَ بِالصُّوفِ ،وَالشَّعْرِ ، وَالْمِرْعِزَّی ، وَالْوَبَرِ بَأْسًا ، إِنَّمَا کَانُوا یَکْرَہُونَ الصَّلاَۃَ فِی الْجِلْدِ۔",,,25396
25397,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ عِمْرَانَ الْقَطَّانِ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ؛ فِی الرِّیشِ ، وَالْعَقِبِ ، وَالصُّوفِ ، وَالْعِظَامِ مِنَ الْمَیْتَۃِ ، قَالَ : إِذَا غُسِلَ فَہُوَ طَہُورُہُ۔",,,25397
25398,حَدَّثَنَا ہُشَیمٌ ، عَنْ مُغِیرَۃَ ، عَنِ الشَّعْبِیِّ ؛ أَنَّ بَنَاتِ حُسَیْنِ بْنِ عَلِیٍّ کُنَّ یَلْبَسْنَ الْقُمُصَ ، فَإِذَا بَلَغْنَ وَتَزَوَّجْنَ ، یَلْبِسْنَ الدُّرُوعَ۔,,,25398
25399,"حَدَّثَنَا عَبْدُ الرَّزَّاقِ ، عَنْ مَعْمَرٍ ، عَنْ حَمَّادٍ ، قَالَ : لاَ بَأْسَ بِرِیشِ الْمَیْتَۃِ۔",,,25399
25400,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ سُلَیْمَانَ بْنِ مَیْسَرَۃَ ، عَنْ طَارِقِ بْنِ شِہَابٍ ، عَنْ رَافِعِ بْنِ أَبِی رَافِعٍ ، قَالَ : رَأَیْتُ أَبَا بَکْرٍ وَکَانَ لَہُ کِسَائٌ فَدَکِیٌّ یَخُلُّہُ عَلَیْہِ إِذَا رَکِبَ ، وَنَلْبَسُہُ أَنَا وَہُوَ إِذَا نَزَلْنَا ، وَہُوَ الْکِسَائُ الَّذِی عَیَّرَتْہُ بِہِ ہَوَازِنُ ، قَالُوا : ذَا الْخَلاَلُ نُبَایع بَعْدَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,25400
25401,"حَدَّثَنَا عُبَیْدُ اللہِ ، قَالَ : أَخْبَرَنَا إِسْرَائِیلُ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَمْرِو بْنِ مَیْمُونٍ ، قَالَ : حَجَّ أَبُو مُوسَی عَلَی جَمَلٍ أَحْمَرَ مُلَبَّدًا رَأْسُہُ ، عَلَیْہِ عَبَائَۃٌ لَہُ۔",,,25401
25402,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : کَانَتْ لأَزْوَاجِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَکْسِیَۃٌ تُسَمَّی الْمُرُوطَ غَیْرُ وَاسِعَۃٍ وَاللَّہِ ، وَلاَ لَیِّنَۃٍ۔",,,25402
25403,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : أَخْبَرَنَا سُلَیْمَانُ بْنُ الْمُغِیرَۃَ ، عَنْ حُمَیْدِ بْنِ ہِلاَلٍ ، عَنْ أَبِی بُرْدَۃَ ، قَالَ : دَخَلْتُ عَلَی عَائِشَۃَ فَأَخْرَجَتْ إِلَیَّ إِزَارًا غَلِیظًا مِنَ الَّتِی تُصْنَعُ بِالْیَمَنِ ، وَکِسَائً مِنْ ہَذِہِ الأَکْسِیَۃِ الَّتِی تَدْعُونَہَا الْمُلَبَّدَۃَ ، فَأَقْسَمَتْ : لَقُبِضَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِیہِمَا۔ (بخاری 3108۔ مسلم 35)",,,25403
25404,"حَدَّثَنَا الْحَسَنُ بْنُ مُوسَی ، عَنْ شَیْبَانَ ، عَنْ قَتَادَۃَ ، عَنْ أَبِی بُرْدَۃَ ، عَنْ أَبِیہِ ، قَالَ : فَقَالَ لِی : یَا بُنَیَّ ، لَوْ شَہِدْتنَا وَنَحْنُ مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إِذَا أَصَابَتْنَا السَّمَائُ ، لَحَسِبْتَ أَنَّ رِیِحَنَا رِیحُ الضَّأْنِ۔ (ابوداؤد 4030۔ ترمذی 2479)",,,25404
25405,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ عَبْدِ اللہِ بْنِ خِرَاشٍ ، قَالَ : رَأَیْتُ أَبَا ذَرٍّ وَکَانَ یَجْلِسُ عَلَی قِطْعَۃِ الْمِسْحِ وَالْجُوَالِقِ۔",,,25405
25406,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ عَبَّادٍ بْنِ عَبَّادٍ الْمَازِنِیِّ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ : قرَسَ أَصْحَابَ ابْنِ مَسْعُودٍ الْبَرْدُ ، قَالَ: فَجَعَلَ الرَّجُلُ یَسْتَحْیِی أَنْ یَجِیئَ فِی الْکِسَائِ الدَّونِ، أَوِ الثَّوْبِ الدَّونِ، قَالَ فَأَصْبَحَ أَبُو عَبْدِ الرَّحْمَنِ فِی عَبَائَۃ ، ثُمَّ أَصْبَحَ فِیہَا ، ثُمَّ أَصْبَحَ فِیہَا فِی الْیَوْمِ الثَّالِثِ ، فَجَعَلَ النَّاسُ یَتَرَاجَعُونَ۔",,,25406
25407,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ہِشَامُ بْنُ الْغَازِ ، عَنْ عُبَادَۃَ بْنِ نُسَیٍّ ، عَنْ سَلْمَانَ ؛ أَنَّہُ کَانَ لَہُ حُبًا مِنْ عَبَائٍ، وَہُوَ أَمِیرُ النَّاسِ۔",,,25407
25408,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إِدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنْ مُجَاہِدٍ ، عَنْ عُبَیْدِ بْنِ عُمَیْرٍ ، قَالَ : کَانَ عِیسَی بْنُ مَرْیَمَ یَلْبَسُ الشَّعْرَ۔",,,25408
25409,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ سَعِید ، عَنْ مُغِیرَۃَ ، قَالَ : کَانَ إِبْرَاہِیمُ لاَ یَرَی بَأْسًا أَنْ یَلْبَسَ الرَّجُلُ الثَّوْبَ بِخَمْسِینَ دِرْہَمًا ، یَعْنِی الطَّیْلَسَانَ۔",,,25409
25410,"حَدَّثَنَا جَرِیرٌ ، عَنْ إِبْرَاہِیمَ بْنِ مُحَمَّدِ بْنِ الْمُنْتَشِرِ ، عَنْ أَبِیہِ ، عَنْ مَسْرُوقٍ ، قَالَ : کَانَ لاَ یُغَالِی بِثَوْبٍ، إِلاَّ بِطَیْلَسَانَ۔",,,25410
25411,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہَمَّامٍ ، عَنْ قَتَادَۃَ ، عَنْ مُحَمَّدٍ ، قَالَ : کَانَ لِتَمِیمٍ رِدَائٌ اشْتَرَاہُ بِأَلْفٍ ، یُصَلِّی فِیہِ۔",,,25411
25412,"حَدَّثَنَا وَکِیعٌ ، عَنْ عُثْمَانَ بْنِ وَاقِدٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : کَانَ عُمَرُ یَکْسُو الرَّجُلَ مِنْ أَصْحَابِ مُحَمَّد صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الحلۃ بِتِسْعِ مِئَۃٍ۔",,,25412
25413,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ إِبْرَاہِیمَ بْنِ مُحَمَّدِ بْن الْمُنْتَشِرِ ، قَالَ : کَانَ مَسْرُوقٌ لاَ یُغَالِی بِثَوْبٍ ، إِلاَّ بِطَیْلَسَانَ۔",,,25413
25414,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ إِبْرَاہِیمَ بْنِ مُحَمَّدِ بْنِ الْمُنْتَشِرِ ، قَالَ : کَانَ مَسْرُوقٌ یَلْبَسُ الْکَتَّانَ تَحْتَ الْقُطْنِ۔",,,25414
25415,"حَدَّثَنَا وَکِیعٌ ، عَنْ قُرَّۃَ بْنِ خَالِدٍ ، قَالَ : قُلْتُ لاِبْنِ سِیرِینَ : مَا کَانَ لِبَاسُ أَبِی ہُرَیْرَۃَ ؟ قَالَ : مِثْلَ ثَوْبَیَّ ہَذَیْنِ ، وَعَلَیْہِ ثَوْبَانِ کَتَّانٍ مُمَشَّقَانِ ، فَتَمَخَّطَ مَرَّۃً ، فَقَالَ : بَخٍ ، بَخٍ ، یَتَمَخَّطُ أَبُو ہُرَیْرَۃَ فِی الْکَتَّانِ۔",,,25415
25416,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ مُحَمَّدِ بْنِ زِیَادٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِذَا انْتَعَلَ أَحَدُکُمْ فَلْیَبْدَأْ بِالْیُمْنَی ، وَإِذَا خَلَعَ فَلْیَبْدَأْ بِالْیُسْرَی۔ (مسلم 1660۔ احمد 2/233)",,,25416
25417,حَدَّثَنَا حَفْصٌ، عَنْ اللَّیْثِ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ؛ أَنَّہُ کَانَ إِذَا انْتَعَلَ بَدَأَ بِالْیُمْنَی، وَإِذَا خَلَعَ بَدَأَ بِالْیُسْرَی۔,,,25417
25418,حَدَّثَنَا الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ ؛ أَنَّہُ کَانَ یَسْتَحِبُّ إِذَا لَبِسَ ، أَنْ یَبْدَأَ بِالْیُمْنَی ، وَإِذَا خَلَعَ أَنْ یَبْدَأَ بِالْیُسْرَی۔,,,25418
25419,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : إِذَا لَبِسْتَ فَابْدَأْ بِالْیُمْنَی ، وَإِذَا خَلَعْتَ فَابْدَأْ بِالْیُسْرَی۔",,,25419
25420,"حَدَّثَنَا حَفْصٌ ، عَنْ عَبْدِ الْمَلِکِ ، عَنِ ابْنِ عَمٍّ لِعُبَیْدِ بْنِ عُمَیْرٍ ، قَالَ : کَانَ عُبَیْدُ بْنُ عُمَیْرٍ یَبْدَأُ فَیَخْلَعُ الْیُسْرَی ، ثُمَّ یَخْلَعُ الْیُمْنَی فَیَجْعَلُہَا عَلَی الْیُسْرَی۔",,,25420
25421,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إِدْرِیسَ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ سَعِیدِ بْنِ أَبِی سَعِیدٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَمْشِ أَحَدُکُمْ فِی نَعْلٍ وَاحِدَۃٍ ، وَلاَ فِی خُفٍّ وَاحِدَۃٍ ، لِیَخْلَعْہُمَا جَمِیعًا ، أَوْ لِیَمْشِ فِیہِمَا جَمِیعًا۔ (بخاری 5855۔ مسلم 1660)",,,25421
25422,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی رَزِینٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : خَرَجَ إِلَیْنَا یَضْرِبُ بِیَدِہِ عَلَی جَبْہَتِہِ ، ثُمَّ قَالَ : إِنَّکُمْ تُحَدِّثُونَ أَنِّی أَکْذِبُ عَلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أَشْہَدُ لَسَمِعْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : إِذَا انْقَطَعَ شِسْعُ أَحَدِکُمْ فَلاَ یَمْشِی فِی الأُخْرَی حَتَّی یُصْلِحَہَا۔\n\n(بخاری 956۔ مسلم 69)",,,25422
25423,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ؛ فِی الَّذِی یَمْشِی فِی نَعْلٍ وَاحِدَۃٍ ، قَالَ : یَکْرَہُونَہُ ، وَیَقُولُونَ : لاَ ، وَلاَ خُطْوَۃً۔",,,25423
25424,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِبْرَاہِیمَ بن طَہْمَانَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : لاَ تَمْشِ فِی النَّعْلِ الْوَاحِدَۃِ۔",,,25424
25425,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ قَالَ : إِذَا انْقَطَعَ شِسْعُ أَحَدِکُمْ ، فَلاَ یَمْشِی فِی النَّعْلِ الْوَاحِدَۃِ۔",,,25425
25426,"حَدَّثَنَا أَبُو دَاوُدَ الْحَفَرِی ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الْمَلِکِ ، قَالَ : رَأَیْتُ سَعِیدَ بْنَ جُبَیْرٍ انْقَطَعَ شِسْعُہُ ، فَخَلَعَ نَعْلَہُ حَتَّی أَصْلَحَہُ۔",,,25426
25427,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنْ رَجُلٍ مِنْ مُزَیْنَۃَ ، قَالَ : رَأَیْتُ عَلِیًّا یَمْشِی فِی نَعْلٍ وَاحِدَۃٍ بِالْمَدَائِنِ ، کَانَ یُصْلِحُ شِسْعَہُ۔",,,25427
25428,حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ یَمْشِیَ فِی نَعْلٍ وَاحِدَۃٍ إِذَا انْقَطَعَ شِسْعُہُ ، مَا بَیْنَہُ وَبَیْنَ أَنْ یُصْلِحَ شِسْعَہُ۔,,,25428
25429,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، عَنْ أَبِیہِ ؛ أَنَّ عَائِشَۃَ کَانَتْ تَمْشِی فِی خُفٍّ وَاحِدَۃٍ ، وَتَقُولُ : لأَحنِقَنَّ أَبَا ہُرَیْرَۃَ۔",,,25429
25430,حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ زَیْدِ بْنِ مُحَمَّدٍ ؛ أَنَّہُ رَأَی سَالِمَ بْنَ عَبْدِ اللہِ یَمْشِی فِی نَعْلٍ وَاحِدَۃٍ۔,,,25430
25431,"حَدَّثَنَا مُعَاذُ بن مُعَاذٌ، عَنِ ابْنِ عَوْنٍ، قَالَ: ذُکِرَ عِنْدَ مُحَمَّدٍ انْتِعَالُ الرَّجُلِ قَائِمًا، فَقَالَ: لاَ أَعْلَمُ بِہِ بَأْسًا۔",,,25431
25432,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ عُقْبَۃَ ، قَالَ : رَأَیْتُ إِبْرَاہِیمَ یُدْخِلُ رِجْلَیْہِ فِی نَعْلَیْہِ وَہُوَ قَائِمٌ۔",,,25432
25433,"حَدَّثَنَا وَکِیعٌ ، عَنِ سُفیَان ، عَنِ الأَعْمَشِ ، قَالَ : رَأَیْتُ یَحیَی بن وَثَّاب یَنْتَعِلُ قَائِمًا۔",,,25433
25434,"حَدَّثَنَا حَفْصٌ ، عَنْ عَمْرٍو ، قَالَ : رَأَیْتُ الْحَسَنَ یَنْتَعِلُ قَائِمًا۔",,,25434
25435,"بَلَّغَنِی عَن حَفْصٍ ، عَنِ الأَعْمَشِ ، قَالَ : بَلَغَنَا أَنَّ عَلِیًّا انْتَعَلَ قَائِمًا۔",,,25435
25436,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ؛ أَنَّہُ کُرِہَ أَنْ یَنْتَعِلَ الرَّجُلُ قَائِمًا۔ (ابن ماجہ 3618),,,25436
25437,حَدَّثَنَا حَفْصٌ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّ نَعْلَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ لَہَا قِبَالاَنِ ، وَنَعْلُ أَبِی بَکْرٍ ، وَعُمَرَ۔ (ترمذی 86۔ بزار 2961),,,25437
25438,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہَمَّامٍ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسٍ ، قَالَ : کَانَ لِنَعْلِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قِبَالاَنِ۔ (ابن ماجہ 3615۔ احمد 3/122)",,,25438
25439,"حَدَّثَنَا شَرِیکٌ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : رَأَیْتُ نَعْلَ ابْنِ عُمَرَ لَہَا قِبَالاَنِ۔",,,25439
25440,"حَدَّثَنَا شَرِیکٌ، عَنْ جَابِر، عَنْ أَبِی جَعْفَرٍ، قَالَ: کَانَ حَذْوُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مُخَصَّرَتَیْنِ مُعَقِّبَتَیْنِ۔ (ابن سعد 478)",,,25440
25441,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ خَالِدٍ ، عَنْ عَبْدِ اللہِ بْنِ الْحَارِثِ ، قَالَ : کَانَتْ نَعْلُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لَہَا شِرَاکَانِ ، قِبَالاَنِ ، مُثْنِیٌّ شِرَاکُہُمَا۔ (ترمذی 76۔ ابن سعد 478)",,,25441
25442,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا الْحَسَنُ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، قَالَ : رَأَیْتُ نَعْلَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی الْمَدِینَۃِ مُخَصَّرَۃً ، مُلَسَّنَۃً ، لَہَا عَقِبٌ خَارِجٌ۔ (ابن سعد 478)",,,25442
25443,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنَ ؛ سَمِعَ عَامِرَ بْنَ عَبْدِ اللہِ بْنِ الزُّبَیْرِ ، قَالَ : حدَّثَتْنِی رَیْحَانَۃُ ؛ أَنَّ أَہْلَہَا أَرْسَلُوہَا وَمَعَہَا صَبِیٌّ عَلَیْہِ أَجْرَاسٌ ، فَقَالَ : أَخْبِرِی أَہْلَکِ أَنَّ ہَذَا یَتْبَعُہُ الشَّیْطَانُ۔",,,25443
25444,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، قَالَ : أَتَیْتُ عَبْدَ الرَّحْمَن بْنَ أَبِی لَیْلَی وَمَعِیَ تِبْرٌ ، فَقَالَ : أَتُرِیدُ أَنْ تُحَلِّیَ بِہِ مُصْحَفًا ؟ قُلْتُ : لاَ ، قَالَ : تُحَلِّیَ بِہِ سَیْفًا ؟ قَالَ : قُلْتُ : أُحَلِّیَ بِہِ ابْنَتِی ، قَالَ : ہَلْ عَسَیْتَ أَنْ تَجْعَلَہَا أَجْرَاسًا ؟ فَإِنَّہَا تُکْرَہُ۔",,,25444
25445,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ شُعْبَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ حَنَشٍ ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ وَأُتِیَ بِصَبِیٍّ عَلَیْہِ أَوْضَاحٌ ، فَجَعَلَ یُہَازِلُہُ۔",,,25445
25446,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : أُدْخِلَتْ عَلَی عَائِشَۃَ صَبِیَّۃٌ عَلَیْہَا جَلاَجِلُ ، فَقَالَتْ : مَا لِی أَرَاکِ مُنَفِّرَۃَ الْمَلاَئِکَۃِ ؟ أَخْرِجُوہَا عَنِّی۔",,,25446
25447,"حَدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : نُبِّئْتُ أَنَّ مُحَمَّدًا کَانَ یَقْطَعُ الْجَلاَجِلَ الَّتِی تَکُونُ عَلَی الصِّبْیَانِ۔",,,25447
25448,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، قَالَ : حَلَّی إِبْرَاہِیمُ بِنْتَیْنِ لَہُ صَغِیرَتَیْنِ جَلاَجِلَ مِنْ ذَہَبٍ یُصَوِّتْنَ۔",,,25448
25449,"حَدَّثَنَا أَصْحَابُنَا ، عَنْ حَفْصٍ ، عَنْ طَلْحَۃَ بْنِ یَحْیَی ، قَالَ : دَخَلْتُ عَلَی عُمَرَ بْنِ عَبْدِ الْعَزِیزِ فَرَأَیْتُ ابْنَتَیْنِ لَہُ ، وَعَلَیْہِمَا أَوْضَاحٌ۔",,,25449
25450,حَدَّثَنَا وَکِیعٌ ، عَنْ مُسَاوِرٍ ، عَنْ جَعْفَرِ بْنِ عَمْرِو بْنِ حُرَیْثٍ ، عَنْ أَبِیہِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ خَطَبَ وَعَلَیْہِ عِمَامَۃٌ سَوْدَائُ۔ (احمد 4/307۔ ابن سعد 455),,,25450
25451,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ ثَابِتِ بْنِ عُبَیْدٍ ، عَنْ أَبِی جَعْفَرٍ الأَنْصَارِیِّ ، قَالَ : رَأَیْتُ عَلَی عَلِیٍّ عِمَامَۃً سَوْدَائَ یَوْمَ قُتِلَ عُثْمَانُ۔",,,25451
25452,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ دَخَلَ مَکَّۃَ وَعَلَیْہِ عِمَامَۃٌ سَوْدَائُ۔ (ترمذی 1735۔ ابوداؤد 4073)",,,25452
25453,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا أَبُو الْعَنْبَسِ عَمْرُو بْنُ مَرْوَانَ ، عَنْ أَبِیہِ ، قَالَ : رَأَیْتُ عَلَی عَلِیٍّ عِمَامَۃً سَوْدَائَ ، قَدْ أَرْخَی طَرَفَہَا مِنْ خَلْفِہِ۔",,,25453
25454,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی الْفَضْلِ ، عَنِ الْحَسَنِ ، قَالَ : کَانَتْ عِمَامَۃُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سَوْدَائَ۔",,,25454
25455,"حَدَّثَنَا وَکِیعٌ ، عَنْ سَلَمَۃَ بْنِ وَرْدَانَ ، قَالَ : رَأَیْتُ عَلَی أَنَسٍ عِمَامَۃً سَوْدَائَ عَلَی غَیْرِ قَلَنْسُوَۃٍ ، قَدْ أَرْخَاہَا مِنْ خَلْفِہِ۔",,,25455
25456,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا عَاصِمُ بن مُحَمَّد ، عَنْ أَبِیہِ ، قَالَ : رَأَیْتُ ابْنَ الزُّبَیْرِ اعْتَمَّ بِعِمَامَۃٍ سَوْدَائَ ، قَدْ أَرْخَاہَا مِنْ خَلْفِہِ نَحْوًا مِنْ ذِرَاعٍ۔",,,25456
25457,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عُثْمَانُ بْنُ أَبِی ہِنْدٍ ، قَالَ : رَأَیْتُ عَلَی أَبِی عُبَیْدۃ عِمَامَۃً سَوْدَائَ۔",,,25457
25458,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ سِمَاکٍ ، عَنْ مِلْحَانَ بْنِ ثَرْوَانَ ، قَالَ : رَأَیْتُ عَلَی عَمَّارٍ عِمَامَۃً سَوْدَائَ۔",,,25458
25459,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا دِینَارُ أَبُو عُمَر ، قَالَ : رَأَیْتُ عَلَی الْحَسَنِ عِمَامَۃً سَوْدَائَ۔",,,25459
25460,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الْحَسَنُ بْنُ صَالِحٍ ، عَنْ جَابِرٍ ، قَالَ : أَخْبَرَنِی مَنْ رَأَی عَلِیًّا قَدِ اعْتَمَّ بِعِمَامَۃٍ سَوْدَائَ ، قَدْ أَرْخَاہَا مِنْ بَیْنِ یَدَیْہِ وَمِنْ خَلْفِہِ۔",,,25460
25461,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا مَالِکُ بْنُ مِغْوَلٍ ، عَنْ أَبِی صَخْرَۃَ ، قَالَ : رَأَیْتُ عَلَی عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ عِصَابَۃً سَوْدَائَ۔",,,25461
25462,"حَدَّثَنَا جَرِیرٌ ، عَنْ یَعْقُوبَ ، عَنْ جَعْفَرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : کَانَتْ عِمَامَۃُ جِبْرِیلَ یَوْمَ غَرِقَ فِرْعَوْنُ سَوْدَائَ۔",,,25462
25463,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ عَبْدِ الْوَاحِدِ بْنِ أَیْمَنَ ، قَالَ : رَأَیْتُ عَلَی ابْنِ الْحَنَفِیَّۃِ عِمَامَۃً سَوْدَائَ۔",,,25463
25464,"حَدَّثَنَا الْبَکْرَاوِیُّ ، عَنْ أَبِی عِیسَی ، عَنْ أَبِیہِ زِیَادٍ ، قَالَ : قَدِمَ شَیْخٌ ، یُقَالَ لَہُ : سَالِمٌ ، قَالَ : رَأَیْتُ عَلَی أَبِی الدَّرْدَائِ عِمَامَۃً سَوْدَائَ۔",,,25464
25465,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إِسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، قَالَ : رَأَیْتُ عَلَی الأَسْوَدِ عِمَامَۃً سَوْدَائَ۔",,,25465
25466,"حَدَّثَنَا عُبَیْد اللہِ ، قَالَ : أَخْبَرَنَا مُوسَی بْنُ عُبَیْدَۃَ ، عَنْ عَبْدِ اللہِ بْنِ دِینَارٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ دَخَلَ مَکَّۃَ یَوْمَ الْفَتْحِ وَعَلَیْہِ شِقۃ سَوْدَائَ۔ (ابن ماجہ 3586)",,,25466
25467,"حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ ، قَالَ : حدَّثَنَا شَرِیکٌ ، قَالَ : حَدَّثَنَا حَزَنٌ الْخَثْعَمِیُّ ، قَالَ : رَأَیْتُ عَلَی الْبَرَائِ عِمَامَۃً سَوْدَائَ۔",,,25467
25468,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللہِ الأَسَدِیُّ ، عَنْ شَرِیکٍ ، عَنْ مُخَارِقٍ ، عَنْ عَطَائٍ ، قَالَ : رَأَیْتُ عَلَی عَبْدِ الرَّحْمَنِ بْنِ عَوْفٍ عِمَامَۃً سَوْدَائَ۔",,,25468
25469,"حَدَّثَنَا مَعَنٌ ، عَنْ حُسَیْنِ بْنِ یُونُسَ ، قَالَ : رَأَیْتُ عَلَی وَاثِلَۃَ عِمَامَۃً سَوْدَائَ۔",,,25469
25470,"حَدَّثَنَا شَاذَانُ ، قَالَ : حدَّثَنَا شَرِیکٌ ، عَنْ عَاصِمٍ ، عَنْ أَبِی رَزِینٍ ، قَالَ : خَطَبَنَا الْحَسَنُ بْنُ عَلِیٍّ یَوْمَ الْجُمُعَۃِ وَعَلَیْہِ عِمَامَۃٌ سَوْدَائُ۔",,,25470
25471,"حَدَّثَنَا شَبَابَۃُ ، عَنْ سُلَیْمَانَ بْنِ الْمُغِیرَۃِ ، قَالَ : رَأَیْتُ أَبَا نَضْرَۃَ وَعَلَیْہِ عِمَامَۃٌ سَوْدَائُ۔",,,25471
25472,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الْحَسَنُ بْنُ صَالِحٍ ، عَنْ أَبِیہِ ، قَالَ : رَأَیْتُ عَلَی الشَّعْبِیِّ عِمَامَۃً بَیْضَائَ ، قَدْ أَرْخَی طَرَفَہَا وَلَمْ یُرْسِلْہُ۔",,,25472
25473,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إِسْمَاعِیلُ بْنُ عَبْدِ الْمَلِکِ ، قَالَ : رَأَیْتُ عَلَی سَعِیدِ بْنِ جُبَیْرٍ عِمَامَۃً بَیْضَائَ۔",,,25473
25474,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ إِسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، قَالَ : رَأَیْتُ الأَحْنَفَ وَاقِفًا عَلَی بَغْلَۃٍ ، وَرَأَیْتُ عَلَیْہِ عِمَامَۃَ خَزٍّ۔",,,25474
25475,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ السَّلاَمِ بْنِ شَدَّادٍ أَبِی طَالُوتَ ، قَالَ : رَأَیْتُ عَلَی أَنَسِ بْنِ مَالِکٍ عِمَامَۃَ خَزٍّ۔",,,25475
25476,حَدَّثَنَا عَبَّادٌ ، عَنِ ابْنِ عَوْنٍ۔,,,25476
25477,"حَدَّثَنَا أَبُو أُسَامَۃَ، قَالَ: أَخْبَرَنَا عُبَیْدُ اللہِ بْنُ عُمَرَ، عَنْ نَافِعٍ، قَالَ: کَانَ ابْنُ عُمَرَ یَعْتَمُّ، وَیُرْخِیہَا بَیْنَ کَتِفَیْہِ۔\n\nقَالَ عُبَیْدُاللہِ: أَخْبَرَنَا أَشْیَاخُنَا أَنَّہُمْ رَأَوْا أَصْحَابَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَعْتَمُّونَ وَیُرْخُونَہَا بَیْنَ أَکْتَافِہِمْ۔",,,25477
25478,"حَدَّثَنَا عَبْدَۃ ، عَنْ ہِشَامٍ ، قَالَ : رَأَیْتُ ابْنَ الزُّبَیْرِ مُعْتَمًّا ، قَدْ أَرْخَی طَرَفَیِ الْعِمَامَۃِ بَیْنَ یَدَیْہِ۔",,,25478
25479,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی الْعَنْبَسِ عَمْرِو بْنِ مَرْوَانَ ، عَنْ أَبِیہِ ، قَالَ : رَأَیْتُ عَلَی عَلِیٍّ رضی اللَّہُ عَنْہُ عِمَامَۃً قَدْ أَرْخَی طَرَفَہَا۔",,,25479
25480,"حَدَّثَنَا وَکِیعٌ ، عَنْ سَلَمَۃَ بْنِ وَرْدَانَ ، قَالَ : رَأَیْتُ عَلَی أَنَسٍ عِمَامَۃً قَدْ أَرْخَاہَا مِنْ خَلْفِہِ۔",,,25480
25481,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُسَاوِرٍ ، قَالَ : حدَّثَنِی جَعْفَرُ بْنُ عَمْرِو بْنِ حُرَیْثٍ ، عَنْ أَبِیہِ ، قَالَ : کَأَنِّی أَنْظُرُ إِلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَعَلَیْہِ عِمَامَۃٌ سَوْدَائُ ، قَدْ أَرْخَی طَرَفَیْہَا بَیْنَ کَتِفَیْہِ۔\n\n(مسلم 453۔ ابوداؤد 4074)",,,25481
25482,"حَدَّثَنَا شَرِیکٌ ، عَنْ مُحَمَّدِ بْنِ قَیْسٍ ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ مُعْتَمًّا قَدْ أَرْخَی الْعِمَامَۃَ مِنْ بَیْنِ یَدَیْہِ وَمِنْ خَلْفِہِ ، وَلاَ أَدْرِی أَیّہمَا أَطْوَلُ۔",,,25482
25483,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوزَعی ، عَن مَکْحُول ، قَالَ : رَأَیْتُہ یَعتَمُّ وَلاَ یَرخِی طَرْفَ العمَامَۃ۔",,,25483
25484,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْمَاعِیلَ ، قَالَ : رَأَیْتُ عَلَی شُرَیْحٍ عِمَامَۃً قَدْ أَرْخَاہَا مِنْ خَلْفِہِ۔",,,25484
25485,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا عُبَیْدُ اللہِ بْنُ عُمَرَ ، عَنْ سَالِمٍ ، وَالْقَاسِمِ ؛ کَانَا یُرْخِیَانِ عَمَائِمَہُمْ بَیْنَ أَکْتَافِہِمْ۔",,,25485
25486,"حَدَّثَنَا شَبَابَۃُ ، عَنْ سُلَیْمَانَ بْنِ الْمُغِیرَۃِ ، قَالَ : رَأَیْتُ أَبَا نَضْرَۃَ یَعْتَمُّ بِعِمَامَۃٍ سَوْدَائَ قَدْ أَرْخَاہَا مِنْ تَحْت عنقِہِ۔",,,25486
25487,"حَدَّثَنَا شَبَابَۃُ ، عَنْ سُلَیْمَانَ ، قَالَ : رَأَیْتُ الْحَسَنَ یَعْتَمُّ بِعِمَامَۃٍ سَوْدَائَ قَدْ أَرْخَی طَرَفَہَا خَلْفَہُ۔",,,25487
25488,"حَدَّثَنَا شَرِیکٌ ، عَنْ إِسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، قَالَ : رَأَیْتُ شُرَیْحًا یَعْتَمُّ بِکَوْرٍ وَاحِدٍ۔",,,25488
25489,"حَدَّثَنَا سُلَیْمَانُ بْنُ حَرْبٍ ، قَالَ : حدَّثَنَا جَرِیرُ بْنُ حَازِمٍ ، عَنْ یَعْلَی بْنِ حَکِیمٍ ، عَنْ سُلَیْمَانَ بْنِ أَبِی عَبْدِ اللہِ ، قَالَ : أَدْرَکْتُ الْمُہَاجِرِینَ الأَوَّلِینَ یَعْتَمُّونَ بِعَمَائِمَ کَرَابِیسَ سُودٍ ، وَبِیضٍ ، وَحُمْرٍ ، وَخُضْرٍ ، وَصُفْرٍ ، یَضَعُ أَحَدُہُم الْعِمَامَۃَ عَلَی رَأْسِہِ ، وَیَضَعُ الْقَلَنْسُوَۃَ فَوْقَہَا ، ثُمَّ یُدِیرُ الْعِمَامَۃَ ہَکَذَا ، یَعْنِی عَلَی کَوْرِہِ ، لاَ یُخْرِجُہَا مِنْ تَحْتِ ذَقَنِہِ۔",,,25489
25490,"حَدَّثَنَا شَرِیکٌ، عَنِ الأَعْمَشِ، عَنْ ثَابِتِ بْنِ عُبَیْدٍ، قَالَ: رَأَیْتُ زَیْدَ بْنَ ثَابِتٍ وَعَلَیْہِ إِزَارٌ، وَرِدَائٌ، وَعِمَامَۃٌ۔",,,25490
25491,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ سُفْیَانَ ، عَنْ مَعْمَرٍ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أُسَامَۃَ بن زید ؛ کَانَ یَکْرَہُ أَنْ یَعْتَمَّ إِلاَّ أَنْ یَجْعَلَ تَحْتَ لِحْیَتِہِ وَحَلْقِہِ مِنَ الْعِمَامَۃِ۔,,,25491
25492,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ زَیْدِ بْنِ جُبَیْرٍ ؛ رَأَیْتُ عَلَی عَبْدِ اللہِ بْنِ الزُّبَیْرِ بُرْطَلَۃً۔",,,25492
25493,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، قَالَ : رَأَیْتُ عَلَی ابْنِ الزُّبَیْرِ قَلَنْسُوَۃً لَہَا رَفٌّ ، یَعْنِی بُرْطَلَۃً۔",,,25493
25494,"حَدَّثَنَا وَکِیعٌ ، عَنْ عِیسَی بْنِ طَہْمَانَ ، قَالَ : رَأَیْتُ عَلَی أَنَسِ بْنِ مَالِکٍ بُرْنُسًا۔",,,25494
25495,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْمَاعِیلَ ، قَالَ : رَأَیْتُ عَلَی شُرَیْحٍ بُرْنُسًا۔",,,25495
25496,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی شِہَابٍ ، قَالَ : رَأَیْتُ عَلَی سَعِیدِ بْنِ جُبَیْرٍ بُرْنُسًا۔",,,25496
25497,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ حَبِیبٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ (ح) وَعَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالاَ : الْبَسِ الثَّعَالِبَ ، وَلاَ تُصَلِّ فِیہَا۔",,,25497
25498,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سَدیْرٍ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : کَانَ لِعَلِیِّ بْنِ حُسَیْنٍ سَبَنْجُونَۃُ ثَعَالِبَ۔",,,25498
25499,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ الأَجْلَحِ ، قَالَ : رَأَیْتُ عَلَی الضَّحَّاکِ قَلَنْسُوَۃَ ثَعَالِبَ۔",,,25499
25500,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ ، قَالَ : رَأَیْتُ عَلَی إِبْرَاہِیمَ قَلَنْسُوَۃً مَکْفُوفَۃً بِثَعَالِبَ ، أَوْ سُمُورٍ۔",,,25500
25501,"حَدَّثَنَا ابْنُ عُیینۃ ، عَنِ الزُّہْرِیِّ ؛ سَمِعَ أَبَا سَلَمَۃَ ، وَسُلَیْمَانَ بْنَ یَسَارٍ یُخْبِرَانِ عَنْ أَبِی ہُرَیْرَۃَ ، یَبْلُغُ بِہِ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، قَالَ: إِنَّ الْیَہُودَ وَالنَّصَارَی لاَ یَصْبِغُونَ فَخَالِفُوہُمْ۔ (مسلم 80۔ ابن ماجہ 3621)",,,25501
25502,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : جِیئَ بِأَبِی قُحَافَۃَ یَوْمَ الْفَتْحِ إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَکَأَنَّ رَأْسَہُ ثَغَامَۃٌ فَقَالَ : اذْہَبُوا بِہِ إلَی بَعْضِ نِسَائِہِ فَلْیُغَیِّرُوہُ ، وَجَنِّبُوہُ السَّوَادَ۔\n\n(مسلم 1663۔ ابوداؤد 4201)",,,25502
25503,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ الأَجْلَحِ ، عَنْ عَبْدِ اللہِ بْنِ بُرَیْدَۃَ ، عَنْ أَبِی الأَسْوَدِ الدُّؤَلِیِّ ، عَنْ أَبِی ذَرٍّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ أَحْسَنَ مَا غَیَّرْتُمْ بِہِ الشَّیْبَ الْحِنَّائُ وَالْکَتَمُ۔\n\n(ترمذی 1753۔ احمد 5/150)",,,25503
25504,"حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ طَلْحَۃَ ، عَنْ حُمَیْدِ بْنِ وَہْبٍ ، عَنْ طَاوُوسٍ ، أَوِ ابْنِ طَاوُوسٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : مَرَّ عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجُلٌ قَدْ خَضَّبَ بِالْحِنَّائِ فَقَالَ : مَا أَحْسَنَ ہَذَا ، ثُمَّ مَرَّ عَلَیْہِ آخَرُ قَدْ خَضَّبَ بِالْحِنَّائِ وَالْکَتَمِ فَقَالَ : ہَذَا أَحْسَنُ مِنْ ہَذَا ، قَالَ : ثُمَّ مَرَّ عَلَیْہِ آخَرُ خَضَّبَ بِصُفْرَۃٍ ، قَالَ : ہَذَا أَحْسَنُ مِنْ ہَذَا کُلِّہِ ، قَالَ : وَکَانَ طَاوُوسٌ یُصَفِّرُ۔\n\n(ابوداؤد 4208۔ ابن سعد 440)",,,25504
25505,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ ثَابِتِ بْنِ عُبَیْدٍ ، عَنْ أَبِی جَعْفَرٍ الأَنْصَارِیِّ ، قَالَ : رَأَیْتُ أَبَا بَکْرٍ لِکَأَنَّ رَأْسَہُ وَلِحْیَتَہُ کَأَنَّہُمَا جَمْرُ الْغَضَی۔",,,25505
25506,"حَدَّثَنَا حَفْصٌ ، عَنِ الأَشْعَث ، عَنِ الْحَسَنِ ، قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَفْضَلُ مَا غَیَّرْتُمْ بِہِ الشَّیْبَ الْحِنَّائُ وَالْکَتَمُ۔",,,25506
25507,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، قَالَ : رَأَیْتُ ابْنَ الْحَنَفِیَّۃِ وَإِنَّ رَأْسَہُ وَلِحْیَتَہُ قَانِیَتَانِ قَدْ خَضَّبَہُمَا بِالْحِنَّائِ وَالْکَتَمِ۔",,,25507
25508,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، قَالَ : رَأَیْتُ عَبْدَ اللہِ بْنَ أَبِی أَوْفَی لَہُ ظُفْرَانِ مَصْبُوغَانِ بِالْحِنَّائِ۔",,,25508
25509,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، قَالَ : رَأَیْتُ أَنَسًا یُخَضِّبُ بِالْحِنَّائِ۔",,,25509
25510,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ ، قَالَ : قُلْتُ لأَبِی جَعْفَرٍ : ہَلْ خَضَّبَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ قَالَ : قَدْ مَسَّ شَیْئًا مِنَ الْحِنَّائِ وَالْکَتَمِ۔",,,25510
25511,"حَدَّثَنَا یُونُسُ بْنُ مُحَمَّدٍ ، قَالَ : حدَّثَنَا سَلاَّمُ بْنُ أَبِی مُطِیعٍ ، عَنْ عثْمَانَ بْنِ مَوْہَبٍ ، قَالَ : دَخَلْتُ عَلَی أُمِّ سَلَمَۃَ فَأَخْرَجَتْ إلَیَّ شَعْرًا مِنْ شَعْرِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَخْضُوبًا بِالْحِنَّائِ وَالْکَتَمِ۔\n\n(ابن ماجہ 2623۔ ابن سعد 437)",,,25511
25512,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابن نَابِل قَالَ : رَأَیت طَاووسًا یُخَضِّبُ بِالْحِنَّائِ۔",,,25512
25513,"حَدَّثَنَا ابْنُ فَضْلٍ ، عَنْ حُصَیْنٍ ، عَنْ مُغِیرَۃَ بْنِ شُبَیْلٍ ، عَنْ قَیْسِ بْنِ أَبِی حَازِمٍ ، قَالَ : کَانَ أَبُو بَکْرٍ یَخْرُجُ إلَیْنَا ، وَکَأَنَّ لِحْیَتَہُ ضِرَامُ عَرْفَجٍ مِنَ الْحِنَّائِ وَالْکَتَمِ۔",,,25513
25514,"حَدَّثَنَا شَرِیکٌ ، عَنْ سُلَیْمَانَ الْمُقْعَد ، عَنْ عَامِرٍ ، قَالَ : إنَّمَا خَضَّبَ عَلِیٌّ مَرَّۃً۔",,,25514
25515,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا إسْمَاعِیلُ ، قَالَ : رَأَیْتُ أَنَسَ بْنَ مَالِکٍ ، وَعَبْدَ اللہِ بْنَ أَبِی أَوْفَی وَخِضَابُہُمَا أَحْمَرَ۔",,,25515
25516,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْعَیْزَارِ بْنِ حُرَیْثٍ ، قَالَ : کَانَ الْحُسَیْنُ بْنُ عَلِیٍّ یُخَضِّبُ بِالْحِنَّائِ وَالْکَتَمِ۔",,,25516
25517,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا عُثْمَانُ بْنُ حَکِیمٍ ، قَالَ : رَأَیْتُ عِنْدَ آلِ أَبِی عُبَیْدَۃَ بْنِ عَبْدِ اللہِ بْنِ زَمْعَۃَ شَعَرَاتٍ مِنْ شَعْرِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَصْبُوغًا بِالْحِنَّائِ۔ (ابن سعد 437)",,,25517
25518,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ أَخْبَرَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ مُحَمَّدِ بْنِ إِبْرَاہِیمَ ، عَن أَبِی سَلَمَۃَ بْنِ عَبْدِ الرَّحْمَنِ بْنِ عَوْفٍ ، أَنَّ عَبْدَ الرَّحْمَن بْنِ الأَسْوَدِ بْنِ عَبْدِ یَغُوثَ وَکَانَ جَلِیسًا لَہُمْ وَکَانَ أَبْیَضَ الرَّأْسِ وَاللِّحْیَۃِ ، فَغَدَا عَلَیْہِمْ ذَاتَ یَوْمٍ وَقَدْ حَمَّرَہَا فَقَالَ لَہُ : الْقَوْمُ : ہَذَا أَحْسَنُ ، فَقَالَ : إنَّ أُمِّی عَائِشَۃَ أَرْسَلَتْ إلَیَّ الْبَارِحَۃَ جَارِیَتَہَا فَأَقْسَمَتْ عَلَیَّ لاَصْبُغَنَّ ، وَأَخْبَرَتْنِی ، أَنَّ أَبَا بَکْرٍ کَانَ یَصْبُغُ۔",,,25518
25519,"حَدَّثَنَا عُبَیْدُ اللہِ، قَالَ: أَخْبَرَنَا حَسَنٌ، عَنْ سِمَاکٍ، عَنْ عِکْرِمَۃَ، قَالَ: رَأَیْتُ، ثُمُودَ فَرَأَیْتُ مُخَضَّبَۃً لِحَاہُمْ۔",,,25519
25520,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ رُفَیْعٍ ، عَنْ قَیْسٍ مَوْلَی خَبَّابٍ ، قَالَ : دَخَلْتُ عَلَی الْحَسَنِ وَالْحُسَیْنِ وَہُمَا یُخَضِّبَانِ بِالسَّوَادِ۔",,,25520
25521,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَمْرِو بْنِ عُثْمَانَ ، قَالَ : رَأَیْتُ مُوسَی بْنَ طَلْحَۃَ یَخْتَضِبُ بِالْوَسْمَۃِ۔",,,25521
25522,"حَدَّثَنَا وَکِیعٌ ، عَنْ عُبَبْداللہِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ مَوْہَبٍ، قَالَ: رَأَیْتُ نَافِعَ بْنَ جُبَیْرٍ یَخْتَضِبُ بِالسَّوَادِ۔",,,25522
25523,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ یُونس ، عَنِ الحَسن أَنَّہ کَان لاَ یَرَی بَأْسًا بِالخِضَاب بِالسَّوَادِ۔,,,25523
25524,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَانُوا یَسْأَلُونَ مُحَمَّدًا ، عَنِ الْخِضَابِ بِالسَّوَادِ فَقَالَ : لاَ أَعْلَمُ بِہِ بَأْسًا۔",,,25524
25525,حَدَّثَنَا وَکِیعٌ، وَابْنُ مَہْدِیٍّ، عَنْ سُفْیَانَ، عَنْ سَعْدِ بْنِ إِبْرَاہِیمَ، عَن أَبِی سَلَمَۃَ، أَنَّہُ کَانَ یُخَضِّبُ بِالسَّوَادِ۔,,,25525
25526,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ بِالْوَسْمَۃِ ، إنَّمَا ہِیَ بَقْلَۃٌ۔",,,25526
25527,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ إسْرَائِیلَ ، عَنْ عَبْدِ الأَعْلَی ، قَالَ : سَأَلْتُ ابْنَ الْحَنَفِیَّۃِ ، عَنِ الْخِضَابِ بِالْوَسْمَۃِ فَقَالَ : ہِیَ خِضَابُنَا أَہْلَ الْبَیْتِ۔",,,25527
25528,"حَدَّثَنَا حَفْصٌ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، قَالَ : کَانَ أَبُو جَعْفَرٍ یَخْتَضِبُ بِثُلُثَیْ حِنَّائٍ وَثُلُثِ وَسْمَۃٍ۔",,,25528
25529,"حَدَّثَنَا شَبَابَۃُ ، قَالَ : حدَّثَنَا لَیْثُ بْنُ سَعْدٍ ، قَالَ : حَدَّثَنَا أَبُو عُشَانَۃَ الْمَعَافِرِیُّ ، قَالَ : رَأَیْتُ عُقْبَۃَ بْنَ عَامِرٍ یُخَضِّبُ بِالسَّوَادِ وَیَقُولُ : نُسَوِّدُ أَعْلاَہَا وَتَأْبَی أُصُولُہَا۔ (ابن سعد 343)",,,25529
25530,"حَدَّثَنَا الْمُقْرِئ، عَنْ سَعِیدِ بْنِ أَبِی أَیُّوبَ، قَالَ: حَدَّثَنِی یَزِیدَ بْنِ أَبِی حَبِیبٍ، أَنَّ أَبَا الخَیر حَدَّثَہُ، عَنْ عُقْبَۃَ بْنِ عَامِرٍ أَنَّہُ کَانَ یَصبغ شعر رَأسہ بِشَجرۃ یُقَال لہَا : الصَبِیب کَأَشَد السواد۔ (بخاری 166۔ مسلم 25)",,,25530
25531,"حَدَّثَنَا ابْنُ یَمَانٍ، عَنْ عَلِیِّ بْنِ صَالِحٍ، عَنْ عَبْدِ الأَعْلَی، عَنِ ابْنِ الْحَنَفِیَّۃِ، قَالَ: کَانَ یَخْتَضِبُ بِالْوَسْمَۃِ۔",,,25531
25532,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَبْدِ الْمَلِکِ ، قَالَ : سُئِلَ عَطَائٌ ، عَنِ الْخِضَابِ بِالْوَسْمَۃِ فَقَالَ : ہُوَ مِمَّا أَحْدَثَ النَّاسُ ، قَدْ رَأَیْت نَفَرًا مِنْ أَصْحَابِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَمَا رَأَیْت أَحَدًا مِنْہُمْ یَخْتَضِبُ بِالْوَسْمَۃِ ، مَا کَانُوا یُخَضِّبُونَ إلاَّ بِالْحِنَّائِ وَالْکَتَمِ وَہَذِہِ الصُّفْرَۃِ۔",,,25532
25533,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی رَبَاحٍ ، عَنْ مُجَاہِدٍ ، أَنَّہُ کَرِہَ الْخِضَابَ بِالسَّوَادِ وَقَالَ : أَوَّلُ مَنْ خَضَّبَ بِہِ فِرْعَوْنُ۔",,,25533
25534,حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ سُفْیَانَ ، عَنْ قَیْسِ بْنِ مُسْلِمٍ ، عَنْ مُجَاہِدٍ ، أَنَّہُ کَرِہَ الْخِضَابَ بِالسَّوَادِ۔,,,25534
25535,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ، أَنَّہُ کَرِہَ الْخِضَابَ بِالْوَسْمَۃِ وَقَالَ : خَضَّبَ أَبُو بَکْرٍ بِالْحِنَّائِ وَالْکَتَمِ۔",,,25535
25536,"حَدَّثَنَا عَبِیْدَۃُ ، عَنْ صَاعِد بْنِ مُسْلِمٍ ، قَالَ : سُئِلَ الشَّعْبِیُّ ، عَنِ الْخِضَابِ بِالْوَسْمَۃِ فَکَرِہَہُ۔",,,25536
25537,"حَدَّثَنَا مُلاَزِمُ بْنُ عَمْرٍو، عَنْ مُوسَی بْنِ نَجْدَۃَ ، عَنْ جَدِّہِ زَیْدِ بْنِ عَبْدِ الرَّحْمَنِ ، قَالَ: سَأَلْتُ أَبَا ہُرَیْرَۃَ: مَا تَرَی فِی الْخِضَابِ بِالْوَسْمَۃِ ؟ فَقَالَ : لاَ یَجِدُ الْمُخْتَضِبُ بِہَا رِیحَ الْجَنَّۃِ۔",,,25537
25538,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ زَیْدٍ ، عَنْ أَیُّوبَ ، قَالَ : سَمِعْتُ سَعِیدَ بْنَ جُبَیْرٍ وَسُئِلَ ، عَنِ الْخِضَابِ بِالْوَسْمَۃِ فَکَرِہَہُ فَقَالَ : یَکْسُو اللَّہُ الْعَبْدَ فِی وَجْہِہِ النُّورَ ، ثُمَّ یُطْفِئُہُ بِالسَّوَادِ۔",,,25538
25539,"حَدَّثَنَا ابْنُ یَمَانٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ فِی الْخِضَابِ بِالْوَسْمَۃِ فَقَالَ : ہُوَ مُحْدَثٌ۔",,,25539
25540,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ سَعْدٍ ، قَالَ : رَأَیْتُ عُثْمَانَ بْنَ عَفَّانَ وَہُوَ یَبْنِی الزَّوْرَائَ عَلَی بَغْلَۃٍ شَہْبَائَ مُصَفِّرًا لِحْیَتَہُ۔",,,25540
25541,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عُبَیْدِ اللہِ بْنِ الْعَیْزَارِ ، عَنْ سَعِیدٍ الْمُدَنِیّ ، قَالَ : کُنْتُ مَعَ أَبِی ہُرَیْرَۃَ فِی جِنَازَۃٍ وَکَانَ مُصَفِّرًا لِلحْیَۃ۔",,,25541
25542,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِلاَلٍ ، قَالَ : حدَّثَنِی سَوَادَۃُ بْنُ حَنْظَلَۃَ ، قَالَ : رَأَیْتُ عَلِیًّا أَصْفَرَ اللِّحْیَۃِ۔",,,25542
25543,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، قَالَ : رَأَیْتُ زَیْدَ بْنَ وَہْبٍ یُصَفِّرُ لِحْیَتَہُ۔",,,25543
25544,"حَدَّثَنَا غُنْدَرٌ مُحَمَّدِ بْنِ جَعْفَرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : رَأَیْتُ ابْنَ عَبَّاسٍ ، وَابْنَ عُمَرَ یُصَفِّرَانِ لِحَاہُمَا۔",,,25544
25545,حَدَّثَنَا وَکِیعٌ ، عَنِ الْعُمَرِیِّ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ یُصَفِّرُ لِحْیَتَہُ۔,,,25545
25546,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ حَمَّادٍ ، عَنْ أَبِی غَالِبٍ ، قَالَ : رَأَیْتُ أَبَا أُمَامَۃَ یُصَفِّرُ۔",,,25546
25547,"حَدَّثَنَا إِسْحَاقُ بْنُ سُلَیْمَانَ ، عَنْ جَرِیرٍ ، قَالَ : رَأَیْتُ عَبْدَ اللہِ بْنَ بُسْرٍ یُصَفِّرُ لِحْیَتَہُ وَرَأْسَہُ۔",,,25547
25548,"حَدَّثَنَا أبُو خَالِدٍ ، عَنْ یَزِیدَ مَوْلَی سَلَمَۃَ ، قَالَ : رَأَیْتُ سَلَمَۃَ یُصَفِّرُ لِحْیَتَہُ۔",,,25548
25549,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، عَنْ إسْمَاعِیلَ ، قَالَ : رَأَیْتُ قَیْسًا یُصَفِّرُ لِحْیَتَہُ ، وَرَأَیْت شُبَیْلَ بْنَ عَوْفٍ یُصَفِّرُ لِحْیَتَہُ ، وَکَانَ مِنْ أَہْلِ الطَّیَالِسَۃِ۔",,,25549
25550,"حَدَّثَنَا وَکِیعٌ ، عَنْ خَالِدِ بْنِ دِینَارٍ ، قَالَ : رَأَیْتُ أَنَسًا وَأَبَا الْعَالِیَۃِ وَأَبَا السِّوَارِ یُصَفِّرُونَ لِحَاہُمْ۔",,,25550
25551,"حَدَّثَنَا وَکِیعٌ ، عَنْ فِطْرٍ ، قَالَ : رَأَیْتُ أَبَا وَائِلَ وَالْقَاسِمَ ، وَعَطَائً یُصَفِّرُونَ لِحَاہُمْ۔",,,25551
25552,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ دَاوُدَ أَبِی الْیَمَانِ ، قَالَ : رَأَیْتُ عَبْدَ اللہِ بْنَ أَبِی أَوْفَی یُصَفِّرُ لِحْیَتَہُ۔",,,25552
25553,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ سَعِیدِ بْنِ أَبِی سَعِیدٍ ؛ أَنَّ ابْنَ جُرَیْجٍ سَأَلَ ابْنَ عُمَرَ ، قَالَ : رَأَیْتُکَ تُصَفِّرُ لِحْیَتَکَ بِالْوَرْسِ ؟ فَقَالَ ابْنُ عُمَرَ : أَمَّا تَصْفِیر لِحْیَتِی ، فَإِنِّی رَأَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَفِّرُ لِحْیَتَہُ۔",,,25553
25554,"حَدَّثَنَا الْمُحَارِبِیُّ ، عَنْ عَبْدِ الْمَلِکِ بْنِ عُمَیْرٍ ، قَالَ : رَأَیْتُ الْمُغِیرَۃَ بْنَ شُعْبَۃَ یُخَضِّبُ بِالصُّفْرَۃِ ، وَرَأَیْتُ جَرِیرَ بْنَ عَبْدِ اللہِ یُخَضِّبُ بِالصُّفْرَۃِ وَالزَّعْفَرَانِ۔",,,25554
25555,"حَدَّثَنَا الْمُحَارِبِیُّ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، قَالَ : رَأَیْتُ الأَسْوَدَ ، وَابْن الأَسْوَدِ یُصَفِّرَانِ لِحَاہُمَا۔",,,25555
25556,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنِ الْمُسْتَمِرِّ بْنِ الرَّیَّانِ ، عَنْ أَبِی الْجَوْزَائِ ؛ أَنَّہُ کَانَ یُصَفِّرُ لِحْیَتَہُ ، وَأَنَّ أَبَا نَضْرَۃَ کَانَ یُصَفِّرُ لِحْیَتَہُ۔,,,25556
25557,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَنْ عِیسَی بْنِ طَہْمَانَ ، قَالَ : رَأَیْتُ أَنَسًا یُصَفِّرُ لِحْیَتَہُ۔",,,25557
25558,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنِ ابْنِ الْغِسِّیلِ، عَنْ عَاصِمِ بْنِ عُمَرَ بْنِ قَتَادَۃَ ، قَالَ: أَتَانَا جَابِرُ بْنُ عَبْدِ اللہِ، وَقَدْ أُصِیبَ بَصَرُہُ ، مُصَفِّرًا لِحْیَتَہُ وَرَأْسَہُ بِالْوَرْسِ۔",,,25558
25559,"حَدَّثَنَا الْفَضْلُ ، قَالَ : حدَّثَنَا ابْنُ الْغِسِّیلِ ، قَالَ : رَأَیْتُ سَہْلَ بْنَ سَعْدٍ مُصَفِّرَ اللِّحْیَۃِ ، لَہُ جُمَیْمَۃٌ۔",,,25559
25560,"حَدَّثَنَا عَبَیْد اللہِ ، عَنْ سِمَاکٍ ، قَالَ : رَأَیْتُ جَابِرَ بْنَ سَمُرَۃَ یُصَفِّرُ لِحْیَتَہُ۔",,,25560
25561,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ شُعْبَۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، عَنْ عُتَیٍّ التَّمِیمِیِّ ، قَالَ : رَأَیْتُ أَبیَّ أَبْیَضَ الرَّأْسِ وَاللِّحْیَۃِ۔",,,25561
25562,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ ، قَالَ : رَأَیْتُ عَلِیًّا أَبْیَضَ الرَّأْسِ وَاللِّحْیَۃِ ، قَدْ مَلأَتْ مَا بَیْنَ مَنْکِبَیْہِ۔",,,25562
25563,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، قَالَ : حدَّثَنَا أَبُو عَامِرٍ صَالِحُ بْنُ رُسْتُمَ ، قَالَ : حَدَّثَنَا حُمَیْدُ بْنُ ہِلاَلٍ ، قَالَ : حَدَّثَنِی الأَحْنَفُ بْنُ قَیْسٍ ، قَالَ : قَدِمْتُ الْمَدِینَۃَ فَدَخَلْتُ مَسْجِدَہَا ، فَبَیْنَا أَنَا أُصَلِّی إِذْ دَخَلَ رَجُلٌ طَوِیلٌ آدَمَ ، أَبْیَضَ اللِّحْیَۃِ وَالرَّأْسُ مَحْلُوقٌ یُشْبِہُ بَعْضُہُ بَعْضًا ، فَخَرَجْتُ فَاتَّبَعْتہ ، قُلْتُ : مَنْ ہَذَا ؟ قَالُوا : أَبُو ذَرٍّ۔",,,25563
25564,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنِ الْمُسْتَمِرِّ ، قَالَ : رَأَیْتُ جَابِرَ بْنَ زَیْدٍ أَبْیَضَ اللِّحْیَۃِ۔",,,25564
25565,"حَدَّثَنَا الْفَضْلُ ، عَنْ فِطْرٍ ، قَالَ : رَأَیْتُ مُجَاہِدًا شَدِیدَ بَیَاضِ الرَّأْسِ وَاللِّحْیَۃِ ، وَرَأَیْتُ سَعِیدَ بْنَ جُبَیْرٍ أَبْیَضَ اللِّحْیَۃِ۔",,,25565
25566,"حَدَّثَنَا شَرِیکٌ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : رَأَیْتُ عَلِیًّا أَصْلَعَ ، أَبْیَضَ الرَّأْسِ وَاللِّحْیَۃِ۔",,,25566
25567,"حَدَّثَنَا شَرِیکٌ ، عَنِ سَدِیر بْنِ الصَّیْرَفِیِّ ، عَنْ أَبِیہِ ، قَالَ : رَأَیْتُ عَلِیًّا أَبْیَضَ الرَّأْسِ وَاللِّحْیَۃِ۔",,,25567
25568,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ أَبِی سُلَیْمَانَ أَبِی مَوْدُودٍ ، قَالَ : رَأَیْتُ السَّائِبَ بْنَ یَزِیدَ أَبْیَضَ الرَّأْسِ وَاللِّحْیَۃِ۔",,,25568
25569,"حَدَّثَنَا شَبَابَۃُ ، عَنْ خَالِدِ بْنِ أَبِی عُثْمَانَ ، قَالَ : رَأَیْتُ سَعِیدَ بْنَ جُبَیْرٍ أَبْیَضَ اللِّحْیَۃِ ، وَرَأَیْتُ طَاوُوسًا أَبْیَضَ اللِّحْیَۃِ۔",,,25569
25570,"حَدَّثَنَا إِسْحَاقُ بْنُ سُلَیْمَانَ ، عَنْ حَرِیزٍ ، عَنْ عَبْدِ اللہِ بْنِ بُسْرٍ السُّلَمِیِّ ، قَالَ : أَتَیْنَاہُ وَنَحْنُ غِلْمَانٌ ، فَلَمْ نَدْرِ عَنْ أَیِّ شَیْئٍ نَسْأَلُہُ ، فَقُلْتُ لَہُ ، أَوْ قَالَ لَہُ بَعْضُنَا : رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ شَابًّا ، أَوْ شَیْخًا ؟ قَالَ : کَانَ فِی عَنْفَقَتِہِ شَعَرَاتٌ بِیضٌ۔ (بخاری 3546۔ احمد 187)",,,25570
25571,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ زُہَیْرٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی جُحَیْفَۃَ ، قَالَ : رَأَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ہَذِہِ مِنْہُ بَیْضَائَ ، یَعْنِی عَنْفَقَتَہُ۔ (مسلم 1822۔ ابن ماجہ 3628)",,,25571
25572,"حَدَّثَنَا الْمُطَّلِبُ بْنُ زِیَادٍ، عَنِ السُّدِّیِّ، قَالَ: رَأَیْتُ الْحُسَیْنَ بْنَ عَلِیٍّ وَجُمَّتُہُ خَارِجَۃٌ مِنْ تَحْتِ عِمَامَتِہِ۔",,,25572
25573,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، قَالَ : قَالَتْ أُمُّ ہَانِئٍ : دَخَلَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَکَّۃَ وَلَہُ أَرْبَعُ غَدَائِرَ ، تَعْنِی ضَفَائِرَ۔ (ترمذی 1781۔ ابوداؤد 4188)",,,25573
25574,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ ، وَجَابِرًا ، وَلِکُلِّ وَاحِدٍ مِنْہُمَا جُمَّۃٌ۔",,,25574
25575,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ ہُبَیْرَۃَ ، قَالَ : کَانَ لِعَبْدِ اللہِ شَعْرٌ یَضَعُہُ عَلَی أُذُنَیْہِ۔",,,25575
25576,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا أَفْلَحُ ، قَالَ : رَأَیْتُ لِلْقَاسِمِ جُمَّۃً۔",,,25576
25577,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : کَانَ لِعُبَیْدِ بْنِ عُمَیْرٍ خُصْلَتَانِ۔",,,25577
25578,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ یَحْیَی بْنِ عَبْدِ اللہِ بْنِ أَبِی قَتَادَۃَ ، قَالَ : مَازَحَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَبَا قَتَادَۃَ ، قَالَ : لأََجُزَّنَّ جُمَّتَکَ ، قَالَ : لَکَ مَکَانَہَا أَسِیرٌ ، فَقَالَ لَہُ بَعْدَ ذَلِکَ : أَکْرِمْہَا ، فَکَانَ یَتَّخِذُ لَہَا بَعْدَ ذَلِکَ السَّکَّ۔ (طبرانی 675)",,,25578
25579,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنِ الْحَسَنِ بْنِ زَیْدٍ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ فِی رَأْسِ الْحَسَنِ بْنِ عَلِیٍّ ذُؤَابَۃٌ ، وَأَنَّ الْحُسَیْنَ بْنِ عَلِیٍّ جَبَذَہُ بِہَا حَتَّی أَدْمَاہُ ، أَوْ أَقْرَحَہُ۔,,,25579
25580,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنِ ابْنِ إِسْحَاقَ ، عَنْ عُبَیْدِ اللہِ بْنِ الْمُغِیرَۃِ بْنِ مُعَیْقِیبٍ ، قَالَ : وَکَانَ تَفَقَّہ ، قَالَ : حَدَّثَنِی مَنْ لاَ أَتَّہِمُ مِنْ أَہْلِی أَنَّہُ رَأَی مُعَیْقِیبًا مُرْسِلاً نَاصِیَتَہُ بَیْنَ عَیْنَیْہِ ، وَرَأَی سَعْدَ بْنَ مَالِکٍ کَذَلِکَ۔",,,25580
25581,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَنْ إِبْرَاہِیمَ بْنِ سَعْدٍ ، عَنِ الزُّہْرِیِّ ، عَنْ عُبَیْدِ اللہِ بْنِ عَبْدِ اللہِ ، عَنِ ابْنِ عَبَّاسٍ، قَالَ : کَانَ أَہْلُ الْکِتَابِ یَسْدُلُونَ أَشْعَارَہُمْ ، وَکَانَ الْمُشْرِکُونَ یُفَرِّقُونَ رُؤُوسَہُمْ ، وَکَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُحِبُّ مُوَافَقَۃَ أَہْلِ الْکِتَابِ فِیمَا لَمْ یُؤْمَرْ بِہِ ، قَالَ : فَسَدَلَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَاصِیَتَہُ ، ثُمَّ فَرَقَ بَعْدُ۔ (بخاری 3558۔ مسلم 91)",,,25581
25582,"حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ بْنِ سَعْدٍ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ یَحْیَی بْنِ عَبَّادٍ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، قَالَتْ : کُنْتُ أَفْرُقُ خَلْفَ یَافُوخِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، ثُمَّ أسْدُلُ نَاصِیَتَہُ۔\n\n(ابوداؤد 4186۔ ابن ماجہ 3633)",,,25582
25583,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا جَرِیرُ بْنُ حَازِمٍ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسٍ ، قَالَ : کَانَ شَعْرُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ شَعْرَاً رَجِلاً بَیْنَ أُذُنَیْہِ وَمَنْکِبَیْہِ۔ (بخاری 5905۔ مسلم 1819)",,,25583
25584,"حَدَّثَنَا شَرِیکٌ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْبَرَائِ ، قَالَ : مَا رَأَیْتُ أَجْمَلَ مِنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مُتَرَجِّلاً فِی حُلَّۃٍ حَمْرَائَ۔",,,25584
25585,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، عَنْ عَلِیِّ بْنِ صَالِحٍ ، قَالَ : حدَّثَنِی إِیَادُ بْنُ لَقِیطٍ ، عَنْ أَبِی رِمْثَۃَ ، قَالَ : أَقْبَلْتُ فَرَأَیْتُ رَجُلاً جَالِسًا فِی ظِلِّ الْکَعْبَۃِ ، فَقَالَ أَبِی : تَدْرِی مَنْ ہَذَا ؟ ہَذَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَلَمَّا انْتَہَیْنَا إِلَیْہِ إِذَا رَجُلٌ ذُو وَفْرَۃٍ ، وَبِہِ رَدْعٌ ، عَلَیْہِ ثَوْبَانِ أَخْضَرَانِ۔ (احمد 4/163)",,,25585
25586,"حَدَّثَنَا الْفَضْلُ ، عَنْ عَبْدِ الْوَاحِدِ بْنِ أَیْمَنَ ، قَالَ : رَأَیْتُ ابْنَ الزُّبَیْرِ وَلَہُ جُمَّۃٌ إِلَی الْعَنَقِ ، وَکَانَ یَفْرُقُ۔",,,25586
25587,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ الْوَاحِدِ بْنِ أَیْمَنَ ، قَالَ : رَأَیْتُ عُبَیْدَ بْنَ عُمَیْرٍ ، وَابْنَ الْحَنَفِیَّۃِ لِکُلِّ وَاحِدٍ مِنْہُمَا جُمَّۃٌ۔",,,25587
25588,"حَدَّثَنَا وَکِیعٌ ، عَنْ فِطْرٍ ، عَنْ حَبِیبٍ ، قَالَ : رَأَیْتُ ابْنَ عَبَّاسٍ وَلَہُ جُمَّۃٌ۔",,,25588
25589,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَحْوَص بْنِ حَکِیمٍ ، عَنْ رَاشِدِ بْنِ سَعْدٍ ، قَالَ : أَمَرَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِالْفَرْقِ ، وَنَہَی عَنِ السَّکِینَۃ۔",,,25589
25590,"حَدَّثَنَا الْفَضْلُ ، عَنْ فِطْرٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ ہُبَیْرَۃَ ، قَالَ : کُنَّا جُلُوسًا عِنْدَ عَلِیٍّ فَدَعَا ابْنًا لَہُ ، یُقَالَ لَہُ : عُثْمَانُ ، فَجَائَ غُلاَمٌ لَہُ ذُؤَابَۃٌ۔",,,25590
25591,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ رَضِیِّ بْنِ أَبِی عَقِیلٍ ، عَنْ أَبِیہِ ، قَالَ : کُنَّا عَلَی بَابِ ابْنِ الْحَنَفِیَّۃِ ، فَخَرَجَ ابْنٌ لَہُ ذُؤَابَۃٌ۔",,,25591
25592,"حدَّثَنَا مَالِکٌ ، قَالَ : حدَّثَنَا زُہَیْرٌ ، قَالَ : حَدَّثَنَا عُمَارَۃُ بْنُ غَزِیَّۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، قَالَ زُہَیْرٌ : یُرَی عُمَارَۃُ ، أَنَّہُ عَنْ أَبِیہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنَّ الشَّعَرَ الْحَسَنَ ، أَوِ الْجَمِیلَ مِنْ کِسْوَۃِ اللہِ ، فَأَکْرِمُوہُ ، قَالَ : وَکَانَ یَکْرَہُ إِزَالَتَہُ ، زَعَمَ زُہَیْرٌ أَنَّہُ التَّضْییْعُ۔",,,25592
25593,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، قَالَ : رَأَیْتُ لاِبْنِ عُمَرَ جُمَّۃً مَفْرُوقَۃً ، تَضْرِبُ مَنْکِبَیْہِ۔",,,25593
25594,"حَدَّثَنَا مَالِکٌ ، عَنْ کَامِلٍ ، عَنْ حَبِیبٍ ، قَالَ : کَأَنِّی أَنْظُرُ إِلَی ابْنِ عَبَّاسٍ ، وَلَہُ جُمَّۃٌ فیْنانۃ۔",,,25594
25595,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ أَخِیہِ عِیسَی ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِذَا لَبِسَ أَحَدُکُمْ ثَوْبًا جَدِیدًا فَلْیَقُلْ : الْحَمْدُ لِلَّہِ الَّذِی کَسَانِی مَا أُوَارِی بِہِ عَوْرَتِی ، وَأَتَجَمَّلُ بِہِ فِی النَّاسِ۔",,,25595
25596,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا أَصْبَغُ بْنُ زَیْدٍ ، قَالَ : حدَّثَنَا أَبُو الْعَلاَئِ ، عَنْ أَبِی أُمَامَۃَ ، قَالَ : لَبِسَ عُمَرُ بْنُ الْخَطَّابِ ثَوْبًا جَدِیدًا ، فَقَالَ : الْحَمْدُ لِلَّہِ الَّذِی کَسَانِی مَا أُوَارِی بِہِ عَوْرَتِی ، وَأَتَجَمَّلُ بِہِ فِی حَیَاتِی ، ثُمَّ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : مَنْ لَبِسَ ثَوْبًا جَدِیدًا ، فَقَالَ : الْحَمْدُ لِلَّہِ الَّذِی کَسَانِی مَا أُوَارِی بِہِ عَوْرَتِی ، وَأُجَمِّلُ بِہِ فِی حَیَاتِی ، ثُمَّ عَمَدَ إِلَی الثَّوْبِ الَّذِی أَخْلَقَ ، أَوْ قَالَ : أَلْقَی فَتَصَدَّقَ بِہِ ، کَانَ فِی کَنَفِ اللہِ ، وَفِی حِفْظِ اللہِ ، وَفِی سَتْرِ اللہِ حَیًّا وَمَیِّتًا ، قَالَہَا ثَلاَثًا۔\n\n(ترمذی 3560۔ حاکم 193)",,,25596
25597,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إِدْرِیسَ ، عَنْ أَبِی الأَشْہَبِ ، عَنْ رَجُلٍ مِنْ مُزَیْنَۃَ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَأَی عَلَی عُمَرَ ثَوْبًا غَسِیلاً ، فَقَالَ : أَجَدِیدٌ ثَوْبُک ہَذَا ؟ قَالَ : غَسِیلٌ یَا رَسُولَ اللہِ ، قَالَ : فَقَالَ لَہُ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : اِلْبَسْ جَدِیدًا ، وَعِشْ حَمِیدًا ، وَتَوَفَّ شَہِیدًا ، یُعْطِکَ اللَّہُ قُرَّۃَ عَیْنٍ فِی الدُّنْیَا وَالآخِرَۃِ۔ (ابن سعد 329۔ مسندہ 986)",,,25597
25598,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ أَبِی وَہْبٍ ، عَنْ مَنْصُورٍ ، عَنْ سَالِمِ بْنِ أَبِی الْجَعْدِ ، قَالَ : إِذَا لَبِسَ الإِنْسَانُ الثَّوبَ الْجَدِیدَ ، فَقَالَ : اللَّہُمَّ اجْعَلْہَا ثِیَابًا مُبَارَکَۃً نَشْکُرُ فِیہَا نِعْمَتَکَ ، وَنُحْسِن فِیہَا عِبَادَتَکَ ، وَنَعْمَلُ فِیہَا بِطَاعَتِکَ ، لَمْ یُجَاوِزْ تَرْقُوَتَہُ حَتَّی یُغْفَرَ لَہُ۔",,,25598
25599,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ الْجُرَیْرِیِّ ، عَنْ أَبِی نَضْرَۃَ ، قَالَ : کَانَ أَصْحَابُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إِذَا رَأَوْا عَلَی أَحَدِہِمُ الثَّوْبَ الْجَدِیدَ ، قَالُوا : تُبْلِی ، وَیُخْلِفُ اللَّہُ عَلَیْک۔",,,25599
25600,"حَدَّثَنَا ابن عُلَیۃ ، عن الْجُرَیْرِیُّ ، عَنْ أَبِی نَضْرَۃَ ، قَالَ : إِنَّمَا نَعِیشُ فِی الْخَلَف۔",,,25600
25601,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا مِسْعَرٌ ، قَالَ : حَدَّثَنَا عَوْنُ بْنُ عَبْدِ اللہِ ، قَالَ : لَبِسَ رَجُلٌ ثَوْبًا جَدِیدًا فَحَمِدَ اللَّہَ ، فَأُدْخِلَ الْجَنَّۃَ ، أَوْ غُفِرَ لَہُ ، قَالَ : فَقَالَ رَجُلٌ : لاَ أَرْجِعُ إِلَی أَہْلِی حَتَّی أَلْبَسَ ثَوْبًا جَدِیدًا ، وَأَحْمَدَ اللَّہَ عَلَیْہِ۔",,,25601
25602,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ أُسَامَۃَ ، قَالَ : کَانَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ إِذَا کَانَ یَوْمَ الْجُمُعَۃِ ، بَعَثَ الأَحْرَاسَ فَیَأْخُذُونَ بِأَبْوَابِ الْمَسْجِدِ ، فَلاَ یَجِدُونَ رَجُلاً مُوَفَّرَ شَیء مِنَ الشَّعْرِ إِلاَّ جَزُّوہُ۔",,,25602
25603,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، وَسُفْیَانُ بْنُ عُقْبَۃَ ، عَنْ سُفْیَانَ ، عَنْ عَاصِمِ بن کُلَیْبٍ ، عَنْ أَبِیہِ ، عَنْ وَائِلِ بْنِ حُجْرٍ ، قَالَ : رَآنِی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَلِی شَعْرٌ طَوِیلٌ ، فَقَالَ : ذُبَابٌ ، ذُبَابٌ ، فَانْطَلَقْتُ فَأَخَذْتُہُ ، فَرَآنِی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : إِنِّی لَمْ أَعْنِکَ ، وَہَذَا أَحْسَنُ۔\n\n(ابوداؤد 4187۔ ابن ماجہ 3636)",,,25603
25604,"حَدَّثَنَا ابن مُبَارَکٌ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ قُدَامَۃَ ، قَالَ : دَخَلَ رَجُلٌ عَلَی ابْنِ سِیرِینَ ، وَعَلَیْہِ شَعْرٌ طَوِیلٌ، فَقَالَ : ہَذَا یُکْرَہُ ، ثُمَّ دَخَلَ عَلَیْہِ مِنَ الْغَدِ وَقَدِ اسْتَأْصَلَہُ ، فَقَالَ : ہَذَا یُکْرَہُ۔",,,25604
25605,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ، عَنْ أَیُّوبَ بْنِ مُوسَی، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ: اتَّخَذَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ خَاتَمًا مِنْ وَرِقٍ ، ثُمَّ نَقَشَ عَلَیْہِ ؛ مُحَمَّدٌ رَسُولُ اللہِ ، ثُمَّ قَالَ : لاَ یَنْقُشْ أَحَدٌ عَلَی نَقْشِ خَاتَمِی ہَذَا۔\n\n(بخاری 5866۔ مسلم 55)",,,25605
25606,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ صُہَیْبٍ ، عَنْ أَنَسٍ ، قَالَ : اصْطَنَعَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ خَاتَمًا ، فَقَالَ : إِنَّا قَدِ اصْطَنَعْنَا خَاتَمًا ، وَنَقَشْنَا فِیہِ نَقْشًا ، فَلاَ یَنْقُشْ عَلَیْہِ أَحَدٌ۔\n\n(بخاری 5874۔ مسلم 2092)",,,25606
25607,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ مُوسَی بْنِ عَبْدِ اللہِ بْنِ یزَیْد ، عَنْ أُمِّہِ ، عَنْ حُذَیْفَۃَ ، قَالَتْ : کَانَ فِی خَاتَمِہِ کُرْکِیَّانِ مُتَقَابِلاَنِ بَیْنَہُمَا مَکْتُوبٌ : الْحَمْدُ لِلَّہِ۔",,,25607
25608,"حَدَّثَنَا مُعَاذٌ ، عَنْ أَشْعَثَ ، عَنْ مُحَمَّدٍ ، وَالْحَسَنِ ، قَالاَ : کَانَ نَقْشُ خَاتَمِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مُحَمَّدٌ رَسُولُ اللہِ۔",,,25608
25609,"حَدَّثَنَا مُعَاذٌ ، عَنْ أَشْعَثَ ، عَنْ مُحَمَّدٍ ، قَالَ : کَانَ نَقْشُ خَاتَمِ أَنَسٍ أَسَدٌ رَابِضٌ حَوْلَہُ فرََائسٌ۔",,,25609
25610,حَدَّثَنَا مُعَاذٌ ، عَنْ أَشْعَثَ ، عَنْ مُحَمَّدٍ ؛ أَنَّہُ کَانَ نَقْشُ خَاتَمِ الأَشْعَرِیِّ أَسَدٌ بَیْنَ رَجُلَیْنِ۔,,,25610
25611,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا إِبْرَاہِیمُ بْنُ عَطَائٍ ، عَنْ أَبِیہِ ، قَالَ : کَانَ خَاتَمُ عِمْرَانَ بْنِ حُصَیْنٍ نَقْشُہُ تِمْثَالُ رَجُلٍ مُتَقَلِّد سَیْفًا ، قَالَ إِبْرَاہِیمُ : فَرَأَیْتہ أَنَا فِی خَاتَمٍ عِنْدَنَا فِی طِینٍ فَقَالَ أَبِی : ہَذَا خَاتَمُ عِمْرَانَ بْنِ حُصَیْنٍ۔",,,25611
25612,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ أَبِیہِ ، قَالَ : کَانَ فِی خَاتَمِ أَبِی عُبَیْدَۃَ بْنِ الْجَرَّاحِ الْخُمُس لِلَّہِ۔",,,25612
25613,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنْ مُجَاہِدٍ ، قَالَ : کَانَ فِی خَاتَمِ أَبِی عُبَیْدَۃَ بْنِ الْجَرَّاحِ الْحَمْدُ لِلَّہِ۔",,,25613
25614,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنْ مُجَاہِدٍ ، قَالَ : کَانَ خَاتَمُ عَبْدِ اللہِ بْنُ عُمَرَ عَبْدُ اللہِ بْنُ عُمَرَ۔",,,25614
25615,"حَدَّثَنَا عَبِیدَۃُ بْنُ حُمَیْدٍ، عَنْ مَنْصُورٍ، عَنْ إِبْرَاہِیمَ قَالَ: کَانَ فِی خَاتَمِ أَبِی عُبَیْدَۃَ بْنِ الْجَرَّاحِ الْحَمْدُ لِلَّہِ۔",,,25615
25616,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنْ مُجَاہِدٍ ، قَالَ : کَانَ نَقْشُ خَاتَمِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مُحَمَّدٌ رَسُولُ اللہِ۔",,,25616
25617,"حَدَّثَنَا جَرِیرٌ ، عَنْ إِبْرَاہِیمَ بْنِ مُحَمَّدِ بْنِ الْمُنْتَشِرِ ، عَنْ أَبِیہِ ، قَالَ : کَانَ نَقْشُ خَاتَمِ مَسْرُوقٍ بِسْمِ اللہِ الرَّحْمَن الرَّحِیمِ۔",,,25617
25618,"حَدَّثَنَا عَبِیدَۃُ بْنُ حُمَیْدٍ ، عَنْ مَنْصُورٍ ، قَالَ : کَانَ نَقْشُ خَاتَمِ إِبْرَاہِیمَ یَا اللہ ، وَلَہُ ذُبَابٌ۔",,,25618
25619,"حَدَّثَنَا حَفْصٌ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، قَالَ : کَانَ فِی خَاتَمِ أَبِی الْعِزَّۃُ لِلَّہِ جَمِیعًا۔",,,25619
25620,"حَدَّثَنَا مُعَاذٌ ، عَنْ أَشْعَثَ ، عَنْ مُحَمَّدٍ ، قَالَ : کَانَ نَقْشُ خَاتَمِ عُبَیْدِ اللہِ بْنِ زِیَادٍ تَدْرِجَۃً۔",,,25620
25621,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَانَ نَقْشُ خَاتَمِ مُحَمَّدٍ کُنْیَتَہُ۔",,,25621
25622,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنِ ابْنِ عَوْنٍ ، عَنِ الْحَسَنِ ، قَالَ : کَانَ نَقْشُ خَاتَمِہِ خُطُوطًا ، قَالَ ابْنُ أَبِی عَدِیٍّ : وَجَدْتُہُ مَکْتُوبًا عِنْدِی۔",,,25622
25623,"حَدَّثَنَا عُبَیْدُ اللہِ ، عَنْ حَنْظَلَۃَ ، قَالَ : رَأَیْتُ عَلَی الْقَاسِمِ ، وَسَالِمٍ خَاتَمَیْنِ فِی خَاتَمِ الْقَاسِمِ اسْمُہُ ، وَفِی خَاتَمِ سَالِمٍ اسْمُہُ۔",,,25623
25624,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ ، عَنْ مُحَمَّدٍ ؛ أَنَّہُ لَمْ یَکُنْ یَرَی بَأْسًا أَنْ یَکْتُبَ الرَّجُلُ فِی خَاتَمِہِ حَسْبِی اللَّہُ ، وَنَحْوَ ہَذَا۔,,,25624
25625,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا أَبُو عَوَانَۃَ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسٍ ؛ أَنَّ عُمَرَ قَالَ : لاَ تَنْقُشُوا وَلاَ تَکْتُبُوا فِی خَوَاتِمِکُمْ بِالْعَرَبِیَّۃِ۔",,,25625
25626,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : کَانَ فِی خَاتَمِ عَلِیٍّ اللَّہُ الْمَلِکُ۔",,,25626
25627,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانَ خَاتَمُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِنْ فِضَّۃٍ فِیہِ : مُحَمَّدٌ رَسُولُ اللہِ۔",,,25627
25628,حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ أَنَّہُ کَانَ یَکْرَہُ أَنْ یَکْتَبَ الآیَۃَ کُلَّہَا فِی الْخَاتَمِ ، وَلاَ یَرَی بِالْخَاتَمِ فِیہِ ذِکْرُ اللہِ بَأْسًا۔,,,25628
25629,حَدَّثَنَا أَبُو الأَحْوَص ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، أَنَّہُ کَرِہَ أَنْ یُنْقَشَ فِی الْخَاتَمِ الآیَۃُ التَّامَّۃُ۔,,,25629
25630,"حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، قَالَ : کَانَ فِی خَاتَمِ حَسَنٍ وَحُسَیْنٍ ذِکْرُ اللہِ ، قَالَ جَعْفَرٌ : وَکَانَ فِی خَاتَمِ أَبِی الْعِزَّۃُ لِلَّہِ جَمِیعًا۔",,,25630
25631,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ صَدَقَۃَ بْنِ یَسَارٍ ، قَالَ : قُلْتُ لِسَعِیدِ بْنِ الْمُسَیَّبِ : مَا أَکْتُبُ فِی خَاتَمِی ؟ قَالَ : اُکْتُبْ فِیہِ ذِکْرَ اللہِ ، وَقُلْ : أَمَرَنِی بِہِ سَعِیدٌ۔",,,25631
25632,"حَدَّثَنَا جَرِیرٌ ، عَنْ إِبْرَاہِیمَ بْنِ مُحَمَّدِ بْنِ الْمُنْتَشِرِ ، عَنْ أَبِیہِ ، قَالَ : کَانَ نَقْشُ خَاتَمِ مَسْرُوقٍ بِسْمِ اللہِ الرَّحْمَن الرَّحِیمِ۔",,,25632
25633,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ إِسْرَائِیلَ ، عَنْ عَبْدِ اللہِ بْنِ الْمُخْتَارِ ، قَالَ : سَمِعْتُ الْحَسَنَ یَقُولُ : لاَ بَأْسَ أَنْ یُنْقَشَ فِی الْخَاتَمِ الآیَۃُ کُلُّہَا۔",,,25633
25634,حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنْ حُرَیْثٍ ، عَنِ الشَّعْبِیِّ ؛ أَنَّہُ کَرِہَ أَنْ تُنْقَشَ الآیَۃُ فِی الْخَاتَمِ۔,,,25634
25635,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ أَیُّوبَ بْنِ مُوسَی ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : اتَّخَذَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ خَاتَمًا مِنْ وَرِقٍ۔",,,25635
25636,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ حَبِیبٍ ، عَنْ طَاوُوسٍ ، قَالَ : کَانَ لِرَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ خَاتَمٌ مِنْ فِضَّۃٍ فِی یَدِہِ ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَکُمْ نَظْرَۃٌ وَلِہَذَا نَظْرَۃٌ ، لَقَدْ عَنَانِی ہَذَا الْیَوْمَ ، فَنَزَعَہُ فَأَعْطَاہُ رَجُلاً۔ (ابن سعد 470)",,,25636
25637,"حَدَّثَنَا عُثْمَانُ بْنُ عُمَرَ ، عَنْ یُونُسَ ، عَنِ الزُّہْرِیِّ ، عَنْ أَنَسٍ ، قَالَ : کَانَ فِی خَاتَمِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِضَّۃٌ ، وَکَانَ فَصُّہُ حَبَشِیًّا۔ (بخاری 5868۔ مسلم 62)",,,25637
25638,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : اتَّخَذَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ خَاتَمًا مِنْ وَرِقٍ ، فَکَانَ فِی یَدِہِ ، ثُمَّ کَانَ فِی یَدِ أَبِی بَکْرٍ مِنْ بَعْدِہِ ، ثُمَّ کَانَ فِی یَدِ عُمَرَ ، ثُمَّ کَانَ فِی یَدِ عُثْمَانَ ، حَتَّی وَقَعَ مِنْہُ فِی بِئْرِ أَرِیسَ ، وَکَانَ نَقْشُہُ مُحَمَّدٌ رَسُولُ اللہِ۔ (بخاری 5873۔ احمد 2/22)",,,25638
25639,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : أَخْبَرَنِی مَنْ رَأَی عَلَی عَبْدِ اللہِ خَاتَمًا مِنْ حَدِیدٍ۔",,,25639
25640,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، قَالَ : رَأَیْتُ عَلَی إِبْرَاہِیمَ خَاتَمَ حَدِیدٍ۔",,,25640
25641,"حَدَّثَنَا یَزِیدُ ، قَالَ : أَخْبَرَنَا مُحَمَّدُ بْنُ رَاشِدٍ ، قَالَ : حَدَّثَنَا مَکْحُولٌ ، قَالَ : کَانَ خَاتَمُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَدِیدًا مَلْوِیًّا ، عَلَیْہِ فِضَّۃٌ ، بَادی۔ (ابن سعد 473)",,,25641
25642,"حَدَّثَنَا یَزِیدُ ، عَنْ ہِشَامٍ ، قَالَ : سُئِلَ مُحَمَّدٌ عَنْ خَاتَمِ الْحَدِیدِ ؟ فَقَالَ : لاَ بَأْسَ ، إِلاَّ أَنْ یُکْرَہَ رِیحُہُ۔",,,25642
25643,"حَدَّثَنَا شَرِیکٌ ، عَنْ مَنْصُورٍ قَالَ : رَأَیْتُ عَلَی إِبْرَاہِیمَ خَاتَمًا مِنْ حَدِیدٍ ، قَالَ : فَقُلْتُ لَہُ ، قَالَ : کَانَ خَاتَمُ عَبْدِ اللہِ مِنْ حَدِیدٍ۔",,,25643
25644,حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ طَارِقٍ، عَنْ حَکِیمِ بْنِ جَابِرٍ؛ أَنَّ عُمَرَ رَأَی عَلَی رَجُلٍ خَاتَمَ حَدِیدٍ فَکَرِہَہُ۔,,,25644
25645,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ حَکِیمِ بْنِ الدَّیْلَمِ ، قَالَ : سَمِعْتُ الضَّحَّاکَ ، قَالَ : سُئِلَ عَطَائٌ عَنْ خَاتَمٍ مِنْ فِضَّۃٍ ، فَصُّہُ حَدِیدٌ ؟ فَکَرِہَہُ۔",,,25645
25646,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنْ أَبِی سَعدٍ ، عَنْ أبِی الْکَنُودِ ، قَالَ : أُصِیبَ عَظِیمٌ مِنْ عُظَمَائِہِمْ یَوْمَ مَہْرَانَ ، فَأُصبتُ عَلَیْہِ خَاتَمًا فَلَبِسْتُہُ ، فَرَآہُ عَلَیَّ ابْنُ مَسْعُودٍ ،فَتَنَاوَلَہُ فَوَضَعَہُ بَیْنَ ضِرْسَیْنِ مِنْ أَضْرَاسِہِ فَکَسرہُ ، ثُمَّ رَمَی بِہِ إِلَیَّ ، ثُمَّ قَالَ : إِنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَانَا عَنْ خَاتَمِ الذَّہَبِ۔ (طیالسی 386۔ احمد 1/377)",,,25646
25647,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ یَزِید ، عَنِ الْحَسَن بن سُہَیْلٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَن خَاتَمِ الذَّہَبِ۔ (احمد 99)",,,25647
25648,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ أَشْعَثَ بْنِ أَبِی الشَّعْثَائِ ، عَنْ مُعَاوِیَۃَ بْنِ سُوَیْد ، عَنِ الْبَرَائِ، قَالَ : نَہَانَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ التَّخَتُّمِ بِالذَّہَبِ۔",,,25648
25649,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ یَحْیَی بْنِ عَبَّادِ بْنِ عَبْدِ اللہِ بْنِ الزُّبَیْرِ ، عَنْ أَبِیْہِ عَبَّادِ بْنِ عَبْدِ اللہِ بْنِ الزُّبَیْرِ ، عَنْ عَائِشَۃَ أُمِّ الْمُؤْمِنِینَ ، قَالَتْ : أَہْدَی النَّجَاشِیُّ إِلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حلیۃ فِیہَا خَاتَمٌ مِنْ ذَہَبٍ فِیہِ فَصٌّ حَبَشِیٌّ ، فَأَخَذَہُ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِعُودٍ وَإِنَّہُ لَمُعْرِضٌ عَنْہُ ، أَوْ بِبَعْضِ أَصَابِعِہِ ، وَإِنَّہُ لَمُعْرِضٌ عَنْہُ ، ثُمَّ دَعَا ابْنَۃِ ابْنَتِہِ أُمَامَۃَ بِنْتِ أَبِی الْعَاصِ ، فَقَالَ : تَحَلِّی بِہَذَا یَا بُنَیَّۃُ۔ (ابوداؤد 4232۔ احمد 6/119)",,,25649
25650,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الأَجْلَحِ ، عَنْ یَزِیدَ بْنِ الأَصَمِّ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : کَانَ فِی إِصْبَعِی خَاتَمٌ مِنْ ذَہَبٍ فَتَنَاوَلَہُ عُمَرُ بْنُ الْخَطَّابِ ، فَرَأَیْتُ أَنَّہُ إِنَّمَا یَنْظُرُ إِلَیْہِ ، فَأَرْخَیْتُ یَدَیَّ ، فَأَخَذَہُ فَخَذَفَ بِہِ ، فَلَمْ أَسْأَلْہُ عَنْہُ وَلَمْ أَطْلُبْہُ۔",,,25650
25651,"حَدَّثَنَا حَاتِمٌ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَتَخَتَّمُ بِخَاتَمٍ مِنْ ذَہَبٍ ، فَخَرَجَ عَلَی النَّاسِ فَطَفِقُوا یَنْظُرُونَ إِلَیْہِ ، فَوَضَعَ یَدَہُ الْیُمْنَی عَلَی خِنْصَرِہِ ، ثُمَّ رَجَعَ إِلَی الْبَیْتِ فَرَمَی بِہِ۔",,,25651
25652,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ عُمَرَ بْنِ سَعِیدِ بْنِ أَبِی حُسَیْنٍ ، قَالَ : أَخْبَرَتْنِی أُمِّی ، عَنْ أَبِی ، قَالَ: دَخَلْتُ عَلَی أُمِّ سَلَمَۃَ وَأَنَا غُلاَمٌ وَعَلَیَّ خَاتَمٌ مِنْ ذَہَبٍ ، فَقَالَتْ : یَا جَارِیَۃُ ، نَاوِلِینِیہِ ، فَنَاوَلَتْہَا إِیَّاہُ ، فَقَالَتْ: اذْہَبِی بِہِ إِلَی أَہْلِہِ وَاصْنَعِی خَاتَمًا مِنْ وَرِقٍ ، فَقُلْتُ : لاَ حَاجَۃَ لأَہْلِی فِیہِ ، قَالَتْ : فَتَصَدَّقِی بِہِ ، وَاصْنَعِی لَہُ خَاتَمًا مِنْ وَرِقٍ۔",,,25652
25653,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، قَالَ : رَأَی عَبْدُ اللہِ فِی یَدِ خَبَّابٍ خَاتَمًا مِنْ ذَہَبٍ ، فَقَالَ : أَمَا آنَ لِہَذَا أَنْ یُطْرَحَ بَعْدُ ؟ فَقَالَ : بَلَی ، لاَ تَرَاہُ عَلَیَّ بَعْدَہَا۔",,,25653
25654,"حَدَّثَنَا عُبید اللہِ ، عَنْ أُسَامَۃَ ، عَنْ مَکْحُولٍ ، عَنْ عَوْفِ بْنِ مَالِکٍ ، قَالَ : أَتَیْتُ عُمَرَ وَفِی یَدِی خَاتَمٌ مِنْ ذَہَبٍ ، فَضَرَبَ یَدَیَّ بِعَصًا کَانَتْ مَعَہُ۔",,,25654
25655,"حَدَّثَنَا جَرِیرٌ ، عَنْ عَبْدِ الْمَلِکِ ، قَالَ : رَأَی سَعِیدُ بْنُ جُبَیْرٍ عَلَی شَابٍّ مِنَ الأَنْصَارِ خَاتَمًا مِنْ ذَہَبٍ ، فَقَالَ لَہُ : أَمَا لَکَ أُخْتٌ ؟ قَالَ : بَلَی ، قَالَ : فَأَعْطِہِ إِیَّاہَا۔",,,25655
25656,حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّہُ کَرِہَ خَاتَمَ الذَّہَبِ۔,,,25656
25657,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ حُمَیْدٍ ، عَنْ عُقْبَۃَ بْنِ وَسَّاجٍ ، قَالَ : سَأَلْتُ ابْنَ عُمَرَ عَنِ الذَّہَبِ ؟ قَالَ : کُنَّا نَکْرَہُہُ لِلرِّجَالِ۔",,,25657
25658,حَدَّثَنَا وَکِیعٌ ، عَنْ مَالِکٍ بْنِ أَنَسٍ ؛ أنَّہُ کَرِہَ خَاتَمَ الذَّہَبِ۔,,,25658
25659,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ، عَنْ عَاصِمٍ، عَنِ ابْنِ سِیرِینَ، قَالَ: رَأَی عُمَرُ فِی یَدِ رَجُلٍ خَاتَمًا مِنْ ذَہَبٍ، فَنَہَاہُ عَنْہُ۔",,,25659
25660,"حَدَّثَنَا أَبُو بَکْرٍ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : رَأَیْتُ عَلَی الْبَرَائِ خَاتَمًا مِنْ ذَہَبٍ۔",,,25660
25661,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ مُوسَی بْنِ عَبْدِ اللہِ بْنِ یَزِیدَ ، عَنْ أُمِّہِ ، عَنْ حُذَیْفَۃَ ، قَالَتْ : کَانَ فِی یَدِہِ خَاتَمٌ مِنْ ذَہَبٍ فِیہِ یَاقُوتَۃٌ۔",,,25661
25662,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللہِ الأَسَدِیُّ ، عَنْ إِسْرَائِیلَ ، عَنْ أَبِی حَصِینٍ ، عَنْ مُصْعَبِ بْنِ سَعْدٍ، عَنْ سَعْدٍ؛ أَنَّہُ کَانَ یَلْبَسُ خَاتَمًا مِنْ ذَہَبٍ۔,,,25662
25663,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُحَمَّدِ بْنِ إِسْمَاعِیلَ ، قَالَ : حَدَّثَنِی مَنْ رَأَی طَلْحَۃَ بْنَ عُبَیْدِ اللہِ ، وَسَعْدًا ، وَذَکَرَ سِتَّۃً ، أَوْ سَبْعَۃً عَلَیْہِم خَوَاتِیمَ الذَّہَبِ۔",,,25663
25664,"حَدَّثَنَا ہُِشَیمٌ ، عَنِ الْعَوَّامِ ، عَنْ إِبْرَاہِیمَ التَّیْمِیِّ ، قَالَ : کَانُوا یُرَخِّصُونَ لِلْغُلاَمِ فِی خَاتَمِ الذَّہَبِ ، فَإِذَا کَبُرَ أَلْقَاہُ ، أَوْ قَالَ : طَرَحَہُ۔",,,25664
25665,"حَدَّثَنَا عُبَیْدُ اللہِ ، قَالَ : أَخْبَرَنَا الْحَسَنُ بْنُ صَالِحٍ ، عَنْ سِمَاکٍ ، قَالَ : رَأَیْتُ عَلَی جَابِرِ بْنِ سَمُرَۃَ خَاتَمًا مِنْ ذَہَبٍ ، وَرَأَیْتُ عَلَی عِکْرِمَۃَ خَاتَمَ ذَہَبٍ۔",,,25665
25666,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ مَالِکِ بْنِ مِغْوَلٍ ، عَنْ أَبِی السَّفَرِ ، قَالَ : رَأَیْتُ عَلَی الْبَرَائِ خَاتَمَ ذَہَبٍ۔",,,25666
25667,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ مِسْعَرٍ ، عَنْ ثَابِتِ بْنِ عُبَیْدٍ ، قَالَ : رَأَیْتُ عَلَی عَبْدِ اللہِ بْنِ یَزِیدَ خَاتَمًا مِنْ ذَہَبٍ۔",,,25667
25668,"حَدَّثَنَا ابْنُ دُکَیْنٍ ، قَالَ : حدَّثَنَا ابْنُ الْغَسِیلِ ، قَالَ : حَدَّثَنَا حَمْزَۃُ بْنُ أَبِی أُسَیْدَ ، وَالزُّبَیْرُ بْنُ الْمُنْذِرِ بْنِ أَبِی أُسَیْدَ ، قَالاَ : نَزَعْنَا مِنْ یَدِ أَبِی أُسَیْدٍ خَاتَمَ ذَہَبٍ حِینَ مَاتَ ، وَکَانَ بَدْرِیًّا۔",,,25668
25669,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ أَبِی الْقَاسِمِ الأَزْدِیِّ ، قَالَ : سَأَلْتُ أنَسَ بْنَ مَالِکٍ : أَتَخَتَّمُ بِخَاتَمٍ مِنْ ذَہَبٍ ؟ فَقَالَ : نَعَمْ ، وَإِنْ شِئْتَ مِنْ فِضَّۃٍ ، لاَ یَضُرُّکَ ، وَلَکِنْ لاَ تَطْعَمْ فِی إِنَائِ ذَہَبٍ ، وَلاَ فِضَّۃٍ۔",,,25669
25670,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانَ یَجْعَلُ فَصَّہُ مِمَّا یَلِی کَفَّہُ۔",,,25670
25671,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ أَیُّوبَ بْنِ مُوسَی ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَجْعَلُ فَصَّہُ مِمَّا یَلِی بَطْنَ کَفِّہِ۔,,,25671
25672,"حَدَّثَنَا حَفْصٌ ، عَنْ ابن أَبِی رَوَّادٍ ، قَالَ : کَانَ عِکْرِمَۃُ إِذَا دَخَلَ الْخَلاَئَ جَعَلَ فَصَّہُ مِمَّا یَلِی بَطْنَ کَفِّہِ۔",,,25672
25673,"حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِیلَ، عَنْ جَعْفَرٍ، عَنْ أَبِیہِ، قَالَ: کَانَ الْحَسَنُ وَالْحُسَیْنُ یَتَخَتَّمَانِ فِی یَسَارِہِمَا۔ (ترمذی 1743)",,,25673
25674,حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ سُلَیْمَانَ بْنِ بِلاَلٍ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ؛ أَنَّ أَبَا بَکْرٍ ، وَعُمَرَ ، وَعُثْمَانَ تَخَتَّمُوا فِی یَسَارِہِمْ۔,,,25674
25675,"حَدَّثَنَا عَبْدَۃُ ، عَنْ عُبَیْدِ اللہِ ، قَالَ : رَأَیْتُ الْقَاسِمَ ، وَسَالِمًا یَتَخَتَّمَانِ فِی یَسَارِہِمَا۔",,,25675
25676,"حَدَّثَنَا حَفْصٌ ، عَنْ إِسْمَاعِیلَ ، قَالَ : رَأَیْتُ عَلَی إِبْرَاہِیمَ خَاتَمًا فِی یَسَارِہِ۔",,,25676
25677,حَدَّثَنَا عَبْدَۃُ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَتَخَتَّمُ فِی یَسَارِہِ۔,,,25677
25678,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، قَالَ : رَأَیْتُ خَاتَمَ إِبْرَاہِیمَ فِی یَسَارِہِ۔",,,25678
25679,حَدَّثَنَا وَکِیعٌ ، عَنِ الصَّلْتِ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَأَبَا بَکْرٍ ، وَعُمَرَ ، وَعُثْمَانَ کَانُوا یَتَخَتَّمُونَ فِی شَمَائِلِہِمْ۔,,,25679
25680,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْمَاعِیلَ الأَزْرَقِ ، قَالَ : رَأَیْتُ خَاتَمَ عَمْرِو بْنِ حُرَیْثٍ فِی یَسَارِہِ۔",,,25680
25681,حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ ہِشَامِ بْنِ سَعْدٍ ، عَنْ جَعْفَرِ بْنِ عبْدِ اللہِ بْنِ جَعْفَرٍ ؛ أَنَّ جَعْفَرِ بْنِ أَبِی طَالِبٍ تَخَتَّمَ فِی یَمِینِہِ۔ (ابن سعد 36),,,25681
25682,"حَدَّثَنَا مَعَنْ ، عَنِ الْمُخْتَارِ بْنِ سَعْدٍ ، قَالَ : رَأَیْتُ مُحَمَّدَ بْنَ عَلِیٍّ یَتَخَتَّمُ فِی یَمِینِہِ۔",,,25682
25683,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنِ الصَّلْتِ بْنِ عَبْدِ اللہِ بْنِ نَوْفَلٍ ، قَالَ : رَأَیْتُ ابْنَ عَبَّاسٍ وَخَاتَمُہُ فِی یَمِینِہِ ، وَلاَ أَحْسَبُ إِلاَ أَنَّہُ ذَکَرَ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَذَلِکَ کَانَ یَلْبَسُہُ۔\n\n(ترمذی 1742۔ ابوداؤد 4226)",,,25683
25684,حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ إِبْرَاہِیمَ بْنِ الْفَضْلِ ، عَنْ عَبْدِ اللہِ بْنِ مُحَمَّدِ بْنِ عَقِیلٍ ، عَنْ عَبْدِ اللہِ بْنِ جَعْفَرٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَتَخَتَّمُ فِی یَمِینِہِ۔ (ابن ماجہ 3647۔ ابویعلی 6794),,,25684
25685,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، قَالَ : أَخْبَرَنِی ابْنُ أَبِی رَافِعٍ مَوْلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ أَنَّ عَبْدَ اللہِ بْنَ جَعْفَرٍ کَانَ یَتَخَتَّمُ فِی یَمِینِہِ ، وَزَعَم أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَتَخَتَّمُ فِی یَمِینِہِ۔ (ترمذی 1744۔ احمد 1/205)",,,25685
25686,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا دَلْہَمُ بْنُ صَالِحٍ الْکِنْدِیُّ ، عَنْ حُجَیْرِ بْنِ عَبْدِ اللہِ الْکِنْدِیِّ ، عَنِ ابْنِ بُرَیْدَۃَ، عَنْ أَبِیہِ ؛ أَنَّ النَّجَاشِیَّ أَہْدَی إِلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ خُفَّیْنِ سَاذَجَیْنِ أَسْوَدَیْنِ ، فَلَبِسَہُمَا۔",,,25686
25687,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سَوَادَۃُ بْنُ أَبِی الأَسْوَدِ ، عَنْ أَبِیہِ ، عَنْ عَبْدِ اللہِ بْنِ عُمَرَ ، قَالَ : عَلَیْکُمْ بِہَذِہِ الْخِفَافِ السُّودِ فَالْبَسُوہَا ، فَہُو أَجْدَرُ أَنْ تَمْسَحُوا عَلَیْہَا۔",,,25687
25688,"حَدَّثَنَا شَرِیکٌ ، عَنْ عُرْوَۃَ بن عَبْدِ اللہِ بْنِ قُشِیرٍ ، قَالَ : سَمِعْتُ أَبَا جَعْفَرٍ یَقُولُ : کَانَ قَائِمُ سَیْفِ عُمَرَ فِضَّۃً ، فَقُلْتُ : أَمِیرُ الْمُؤْمِنِینَ ؟ قَالَ : أَمِیرُ الْمُؤْمِنِینَ۔",,,25688
25689,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ہِشَامٌ الدَّسْتَوَائِیُّ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ أَبِی الْحَسَنِ ، قَالَ : کَانَت قَبِیعَۃُ سَیْفِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِنْ فِضَّۃٍ۔ (ترمذی 1691۔ ابوداؤد 2577)",,,25689
25690,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ قَالَ : کَانَ سَیْفُ الزُّبَیْرِ مُحَلًّی بِالْفِضَّۃِ۔",,,25690
25691,"حَدَّثَنَا ابْنُ نُمَیْرٍ، قَالَ: حدَّثَنَا عُثْمَانُ بْنُ حَکِیمٍ، قَالَ: رَأَیْتُ فِی قَائِمِ سَیْفِ سَہْلِ بْنِ حُنَیْفٍ مِسْمَارَ ذَہَبٍ۔",,,25691
25692,"حَدَّثَنَا وَکِیعٌ ، قَالَ: حدَّثَنَا ابْنُ مِغْوَلٍ ، عَنْ نَافِعٍ ، قَالَ: کَانَ سَیْفُ عُمَرَ مُحَلًّی ، فَقُلْتُ لَہُ : عُمَرُ حَلاَہُ؟ قَالَ : قَدْ رَأَیْتُ ابْنَ عُمَرَ یَتَقَلَّدُہُ۔",,,25692
25693,"حَدَّثَنَا وَکِیعٌ ، حدَّثَنَا أَبُو الْعُمَیسِ ، عَنِ الْقَاسِمِ ، قَالَ : کَانَ سَیْفُ عَبْدِ اللہِ مُحَلًّی۔",,,25693
25694,"حَدَّثَنَا أَبُو نُعَیْمٍ، عَنْ قُرَّۃَ بْنِ خَالِدٍ، عَنْ أَبِی وَحْشِیَّۃَ الصَّیْقَلِ، قَالَ: دَعَانِی مُصْعَبٌ فَأَخْرَجَ إِلَیَّ سَیْفَیْنِ، فَقَالَ: أَیُّ ہَذَیْنِ خَیْرٌ؟ فَقُلْتُ: ہَذَا ، وَعَلَی قَائِمِہِ حَبَّۃٌ مِنْ فِضَّۃٍ ، فَقَالَ النَّاسُ: ہَذَا سَیْفُ أَبِی بَکْرٍ الصِّدِّیقِ۔",,,25694
25695,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ أَبِی بَکْرِ بْنِ عَبْدِ اللہِ ، قَالَ : رَأَیْتُ عَلَی مَکْحُولٍ سَیْفًا مُحَلًّی۔",,,25695
25696,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شَرِیکٌ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : کَانَ سَیْف مَسْرُوقٍ مُحَلًّی۔",,,25696
25697,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إِسْرَائِیلُ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : أَخْرَجَ إِلَیْنَا عَلِیُّ بْنُ الْحُسَیْنِ سَیْفَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَإِذَا قَبِیعَتُہُ وَالْحَلَقَتَانِ اللَّتَانِ فِیہِمَا الْحَمَائِلُ فِضَّۃٌ ، قَالَ : فَسَأَلْتُہُ ، فَإِذَا ہُوَ قَدْ نُحِلَ ، کَانَ سَیْفُ مُنَبِّہِ بْنِ الْحَجَّاجِ السَّہْمِیِّ ، اتَّخَذَہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لِنَفْسِہِ یَوْمَ بَدْرٍ ، قَالَ : وَأَخْرَجَ إِلَیْنَا دِرْعَہُ فَإِذَا ہِیَ یَمَانِیَّۃٌ رَقِیقَۃٌ ذَاتُ زُرَافِینَ ، فَإِذَا عُلِّقَتْ بِزُرَافِینِہَا شُمِّرَتْ ، وَإِذَا أُرْسِلَتْ مَسَّتِ الأَرْضَ۔ (ابن سعد 486)",,,25697
25698,"قَالَ أَبُو نُعَیْمٍ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : لاَ بَأْسَ أَنْ یُحَلَّی السَّیْفُ۔",,,25698
25699,"حَدَّثَنَا وَکِیعٌ، عَنْ شَرِیکٍ ، عَنْ مُخَارِقٍ ، عَنْ طَارِقٍ، قَالَ: خَطَبَنَا عَلِیٌّ وَعَلَیْہِ سَیْفٌ حِلْیَتُہُ مِنْ حَدِیدٍ۔",,,25699
25700,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، عَنِ ابْنِ حَبِیبٍ الْمُحَارِبِیِّ ، عَنْ أَبِی أُمَامَۃَ الْبَاہِلِیِّ صَاحِبِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لَقَدِ افْتَتَحَ الْفُتُوحَ أَقْوَامٌ مَا کَانَتْ حِلْیَۃَ سُیُوفِہِمُ الذَّہَبُ ، وَلاَ الْفِضَّۃُ ، إِنَّمَا کَانَتْ حِلْیَتَہَا الْعَلاَبِیُّ ، وَالآنُکُ ، وَالْحَدِیدُ۔ (بخاری 2909۔ ابن ماجہ 2807)",,,25700
25701,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عُبَیْدِ اللہِ ، عَنِ ابْنِ عَبَّاسٍ ، عَنْ أَبِی طَلْحَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لاَ تَدْخُلُ الْمَلاَئِکَۃُ بَیْتًا فِیہِ کَلْبٌ ، وَلاَ صُورَۃٌ۔ (بخاری 3322۔ مسلم 1665)",,,25701
25702,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَلِیِّ بْنِ مُدْرِکٍ ، عَنْ أَبِی زُرْعَۃَ ، عَنْ عَبْدِ اللہِ بْنِ نُجَیٍّ ، عَنْ أَبِیہِ ، عَنْ عَلِیٍّ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : الْمَلاَئِکَۃُ لاَ تَدْخُلُ بَیْتًا فِیہِ کَلْبٌ ، وَلاَ صُورَۃٌ۔\n\n(ابوداؤد 229۔ احمد 1/80)",,,25702
25703,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ أَبِی سَلَمَۃَ ، عَنْ عَائِشَۃَ ، قَالَتْ : وَاعَدَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ جِبْرِیلُ سَاعَۃً یَأْتِیہِ فِیہَا ، فَرَاثَ عَلَیْہِ ، فَخَرَجَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَإِذَا ہُوَ بِجِبْرِیلَ قَائِمًا عَلَی الْبَابِ ، فَقَالَ لَہُ : مَا مَنَعَک أَنْ تَدْخُلَ ؟ قَالَ : إِنَّ فِی الْبَیْتِ کَلْبًا ، وَإِنَّا لاَ نَدْخُلُ بَیْتًا فِیہِ صُورَۃٌ ، وَلاَ کَلْبٌ۔",,,25703
25704,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ مُوسَی بْنُ عُبَیْدَۃَ ، عَنْ أَبَانَ بْنِ صَالِحٍ ، عَنِ الْقَعْقَاعِ بْنِ حَکِیمٍ ، عَنْ سَلْمَی أُمِّ رَافِعٍ ، عَنْ أَبِی رَافِعٍ قَالَ : أَتَی جِبْرِیلُ یَسْتَأْذِنُ عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَأَذِنَ لَہُ ، فَأَبْطَأَ عَلَیْہِ ، فَأَخَذَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رِدَائَہُ ، فَقَامَ إِلَیْہِ وَہُوَ بِالْبَابِ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : قَدْ أَذِنَّا لَکَ ، قَالَ : أَجَلْ ، وَلَکِنَّا لاَ نَدْخُلُ بَیْتًا فِیہِ کَلْبٌ ، وَلاَ صُورَۃٌ۔ (طبرانی 972)",,,25704
25705,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ عَدِیٍّ ، عَنْ خَالِدِ بْنِ سَعْدٍ ، قَالَ : دُعِی أَبُو مَسْعُودٍ إِلَی طَعَامٍ ، فَرَأَی فِی الْبَیْتِ صُورَۃً ، فَلَمْ یَدْخُلْ حَتَّی کُسِرَتْ۔",,,25705
25706,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، عَنْ أَسْلَمَ ، قَالَ : لَمَّا قَدِمَ عُمَرُ الشَّامَ أَتَاہُ رَجُلٌ مِنَ الدَّہَّاقِینَ ، فَقَالَ : إِنِّی قَدْ صَنَعْت لَکَ طَعَامًا فَأُحِبُّ أَنْ تَجِیئَ ، فَیَرَی أَہْلُ عَمَلِی کَرَامَتِی عَلَیْک ، وَمَنْزِلَتِی عِنْدَکَ ، أَوْ کَمَا قَالَ ، فَقَالَ : إِنَّا لاَ نَدْخُلُ ہَذِہِ الْکَنَائِسَ ، أَوْ قَالَ : ہَذِہِ الْبِیَعَ ، الَّتِی فِیہَا ہذہ الصُّوَرُ۔",,,25706
25707,حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ عَلِیٍّ ؛ أَنَّہُ کَرِہَ الصُّوَرَ فِی الْبُیُوتِ۔,,,25707
25708,"حَدَّثَنَا أَبُو نُعَیْمٍ ، عَنْ سُفْیَانَ ، عَنْ مُسْلِمِ بْنِ أَبِی مَرْیَمَ ، عْن أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : لاَ تَدْخُلُ الْمَلاَئِکَۃُ بَیْتًا فِیہِ صُورَۃٌ۔ (مسلم 1672۔ احمد 2/305)",,,25708
25709,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، قَالَ : أَخْبَرَنَا أُسَامَۃُ بْنُ زَیْدِ بْنِ أَسْلَمَ ، قَالَ : حدَّثَنِی أَبِی ؛ أَنَّہُ بَنَی عَلَی أَخِیہِ ، فَدَخَلَ ابْنُ عُمَرَ فَرَأَی صُورَۃً فِی الْبَیْتِ فَمَحَاہَا ، أَوْ حَکَّہَا ، ثُمَّ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : لاَ تَدْخُلُ الْمَلاَئِکَۃُ بَیْتًا فِیہِ کَلْبٌ ، وَلاَ صُورَۃٌ۔ (بخاری 3227)",,,25709
25710,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ حُسَیْنِ بْنِ وَاقِدٍ ، عَنِ ابن بُرْیدَۃَ ، عَنْ أَبِیہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تَدْخُلُ الْمَلاَئِکَۃُ بَیْتًا فِیہِ کَلْبٌ۔",,,25710
25711,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، عَنْ مَکْحُولٍ ، قَالَ : کَانَ فِی تُرْسِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَبْشٌ مُصَوَّرٌ ، فَشَقَّ ذَلِکَ عَلَیْہِ ، فَأَصْبَحَ وَقَدْ ذَہَبَ اللَّہُ بِہِ۔ (ابن سعد 489)",,,25711
25712,"حَدَّثَنَا شَبَابَۃُ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الْحَارِثِ ، عَنْ کُرَیْبٍ مَوْلَی ابْنِ عَبَّاسٍ ، عَنْ أُسَامَۃَ ، قَالَ : دَخَلَتُ وَعَلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْکَآبَۃُ ، فَقُلْتُ : مَا لَکَ یَا رَسُولَ اللہِ ؟ قَالَ : إِنَّ جِبْرِیلَ وَعَدَنِی أَنْ یَأْتِیَنِی ، فَلَمْ یَأْتِنِی مُنْذُ ثَلاَثٍ ، فَجَازَ کَلْبٌ ، قَالَ أُسَامَۃُ : فَوَضَعْتُ یَدِی عَلَی رَأْسِی وَصِحْتُ ، فَجَعَلَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : مَا لَکَ یَا أُسَامَۃُ ؟ قُلْتُ : جَازَ کَلْبٌ ، فَأَمَرَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِقَتْلِہِ ، فَقُتِلَ ، فَأَتَاہُ جِبْرِیلُ فَہَشَّ إِلَیْہِ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَا لَکَ أَبْطَأْتَ وَقَدْ کُنْتَ إِذَا وَعَدْتنِی لَمْ تُخْلِفْنِی ؟ فَقَالَ : إِنَّا لاَ نَدْخُلُ بَیْتًا فِیہِ کَلْبٌ ، وَلاَ تَصَاوِیرُ۔",,,25712
25713,حَدَّثَنَا عَبْدَۃُ ، عَنِ ابْنِ إِسْحَاقَ ، عَنْ أَبِی جَعْفَرٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ لاَ یَدْخُلُ بَیْتًا فِیہِ صُورَۃٌ ، وَأَن عَلِیًّا کَانَ لاَ یَدْخُلُ بَیْتًا فِیہِ صُورَۃٌ۔,,,25713
25714,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ أَبِیہِ ، قَالَ : سَمِعْتُ الْحَسَنَ یَقُولُ : أَوَ لَمْ یَکُنْ أَصْحَابُ مُحَمَّدٍ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَدْخُلُونَ الْخَانَاتِ فِیہَا التَّصَاوِیرُ ؟۔",,,25714
25715,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی الضُّحَی ، قَالَ : دَخَلْتُ مَعَ مَسْرُوقٍ صُفَّۃً فِیہَا تَمَاثِیلُ ، فَنَظَرَ إِلَی تِمْثَالٍ مِنْہَا فَقَالَ : مَا ہَذَا ؟ قَالُوا : تِمْثَالُ مَرْیَمَ۔",,,25715
25716,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، قَالَ : کَانَ فِی بَیْتِ إِبْرَاہِیمَ تَابُوتٌ فِیہِ تَمَاثِیلُ۔",,,25716
25717,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ بِالتِّمْثَالِ فِی حِلْیَۃِ السَّیْفِ ، وَلاَ بَأْسَ بِہَا فِی سَمَائِ الْبَیْتِ ، إِنَّمَا یُکْرَہُ مِنْہَا مَا نُصب نَصَبًا ، یَعْنِی الصُّورَۃَ۔",,,25717
25718,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنِ الْقَاسِمِ ، عَنْ عَائِشَۃَ ، قَالَتْ : دَخَلَ عَلَیَّ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَقَدِ اسْتَتَرْتُ بِقِرَامٍ فِیہِ تَمَاثِیلُ ، فَلَمَّا رَآہُ تَغَیَّرَ لَوْنُہُ وَہَتَکَہُ بِیَدِہِ ، ثُمَّ قَالَ : إِنَّ أَشَدَّ النَّاسِ عَذَابًا یَوْمَ الْقِیَامَۃِ الَّذِی یُشَبِّہُونَ بِخَلْقِ اللہِ۔ (بخاری 6109۔ مسلم 91)",,,25718
25719,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، وَوَکِیع ، عَنِ الأَعْمَشِ ، عَنْ أَبِی الضُّحَی ، عَنْ مَسْرُوقٍ ، عَنْ عَبْدِ اللہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنَّ أَشَدَّ النَّاسِ عَذَابًا یَوْمَ الْقِیَامَۃِ الْمُصَوِّرُونَ۔ (بخاری 5950۔ مسلم 98)",,,25719
25720,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : یُعَذَّبُ الْمُصَوِّرُونَ یَوْمَ الْقِیَامَۃِ ، وَیُقَالُ لَہُمْ : أَحْیُوا مَا خَلَقْتُمْ۔ (بخاری 5951۔ مسلم 9786)",,,25720
25721,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عُمَارَۃَ ، عَنْ أَبِی زُرْعَۃَ ، قَالَ : دَخَلْتُ مَعَ أَبِی ہُرَیْرَۃَ دَارَ مَرْوَانَ ، فَرَأَی فِیہَا تَصَاوِیرَ ، فَقَالَ : سَمِعْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : یَقُولُ اللَّہُ : وَمَنْ أَظْلَمُ مِمَّنْ ذَہَبَ یَخْلُقُ خَلْقًا کَخَلْقِی ؟ فَلْیَخْلُقُوا حَبَّۃً ، وَلْیَخْلُقُوا ذَرَّۃً ، وَلْیَخْلُقُوا شَعِیرَۃً ، قَالَ : ثُمَّ دَعَا بِوَضُوئٍ فَتَوَضَّأَ۔\n\n(بخاری 7559۔ مسلم 1671)",,,25721
25722,"حَدَّثَنَا شَبَابَۃُ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ مِہْرَانَ ، عَنْ عُمَیْرٍ مَوْلَی ابْنِ عَبَّاسٍ ، عَنْ أُسَامَۃَ ، قَالَ : دَخَلْتُ مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْکَعْبَۃَ ، فَرَأَی فِی الْبَیْتِ صُورَۃً ، فَأَمَرَنِی فَأَتَیْتہ بِدَلْوٍ مِنَ الْمَائِ ، فَجَعَلَ یَضْرِبُ تِلْکَ الصُّورَۃَ ، وَیَقُولُ : قَاتَلَ اللَّہُ قَوْمًا یُصَوِّرُونَ مَا لاَ یَخْلُقُونَ۔ (ابوداؤد 623)",,,25722
25723,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ سَعِیدٍ ، عَنِ النَّضْرِ بْنِ أَنَسِ بْنِ مَالِکٍ ، قَالَ : کُنْتُ جَالِسًا عِنْدَ ابْنِ عَبَّاسٍ فَجَعَلَ یُفْتِی ، وَلاَ یَقُولُ قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَتَّی سَأَلَہُ رَجُلٌ ،فَقَالَ : إِنِّی رَجُلٌ أُصَوِّرُ ہَذِہِ الصُّوَرَ ؟ فَقَالَ لَہُ ابْنُ عَبَّاسٍ : اُدْنُہُ ، فَدَنَا الرَّجُلُ ، فَقَالَ ابْنُ عَبَّاسٍ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : مَنْ صَوَّرَ صُورَۃً فِی الدُّنْیَا کُلِّفَ أَنْ یَنْفُخَ فِیہَا الرُّوحَ یَوْمَ الْقِیَامَۃِ ، وَلَیْسَ بِنَافِخٍ۔ (بخاری 5963۔ مسلم 1671)",,,25723
25724,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سَلَمَۃَ أَبِی بِشْرٍ ، عَنْ عِکْرِمَۃَ ؛ فِی قَوْلِہِ : (إِنَّ الَّذِینَ یُؤْذُونَ اللَّہَ وَرَسُولَہُ) قَالَ : أَصْحَابُ التَّصَاوِیرِ۔",,,25724
25725,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عَطَائِ بْنِ یَزِیدَ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی عَنْ بَیْعَتَیْنِ ، وَعَنْ لِبْسَتَیْنِ ؛ فَأَمَّا الْبَیْعَتَانِ : فَالْمُلاَمَسَۃُ ، وَالْمُنَابَذَۃُ ، وَأَمَّا اللِّبْسَتَانِ : فَاشْتِمَالُ الصَّمَّائِ، وَالاِحْتِبَائُ فِی الثَّوْبِ الْوَاحِدِ، لَیْسَ عَلَی فَرْجِہِ مِنْہُ شَیْئٌ۔(ابوداؤد 3370۔ بخاری 2147)",,,25725
25726,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، وَأَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ خَبِیبِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ حَفْصِ بْنِ عَاصِمٍ ، عَنْ أَبِی ہُرَیْرَۃَ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی عَنْ لِبْسَتَیْنِ : عَنِ اشْتِمَالِ الصَّمَّائِ ، وَعَنِ الاِحْتِبَائِ فِی ثَوْبٍ وَاحِدٍ ، مُفْضِیًا بِفَرْجِکَ إِلَی السَّمَائِ۔ (بخاری 584۔ ابن ماجہ 3560)",,,25726
25727,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، وَأَبُو أُسَامَۃَ ، عَنْ سَعدِ بْنِ سَعِیدٍ ، عَنْ عَمْرَۃَ ، عَنْ عَائِشَۃَ ، قَالَتْ ، نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ لِبْسَتَیْنِ ؛ اشْتِمَالِ الصَّمَّائِ ، وَالاِحْتِبَائِ فِی ثَوْبٍ وَاحِدٍ وَأَنْتَ مُفْضٍ بِفَرْجِک۔\n\n(ابن ماجہ 3561)",,,25727
25728,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، قَالَ : أَخْبَرَنَا عُبَیْدُ اللہِ بْنُ عَبْدِ اللہِ أَبُو الْمُنِیبِ الْعَتَکِیُّ ، قَالَ : حدَّثَنَا عَبْدُ اللہِ بْنُ بُرَیْدَۃَ ، عَنْ أَبِیہِ ، عَنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ أَنَّہُ نَہَی عَنْ لِبْسَتَیْنِ ،وَعَنْ مَجْلِسَیْنِ ، أَمَّا اللِّبْسَتَانِ: فَتُصَلِّی فِی السَّرَاوِیلِ لَیْسَ عَلَیْک شَیْئٌ غَیْرُہُ ، وَالرَّجُلُ یُصَلِّی فِی الثَّوْبِ الْوَاحِدِ لاَ یَتَوَشَّحُ بِہِ، وَالْمَجْلسَانِ : یَحْتَبِی بِالثَّوْبِ الْوَاحِدِ فَتُبْصَرُ عَوْرَتُہُ ، وَیَجْلِسُ بَیْنَ الظِّلِّ وَالشَّمْسِ۔ (ابوداؤد 637)",,,25728
25729,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، قَالَ : حدَّثَنَا جَعْفَرُ بْنُ بُرْقَانَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ ، عَنْ أَبِیہِ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ لِبْسَتَیْنِ ؛ الصَّمَّائُ : وَہُوَ أَنْ یَلْتَحِفَ فِی الثَّوْبِ الْوَاحِدِ ، یَرْفَعُ جَانِبَہُ عَنْ مَنْکبِیہِ ، لَیْسَ عَلَیْہِ ثَوْبٌ غَیْرُہُ ، أَوْ یَحْتَبِی الرَّجُلُ بِالثَّوْبِ الْوَاحِدِ ، لَیْسَ بَیْنَ فَرْجِہِ وَبَیْنَ السَّمَائِ شَیْئٌ، یَعْنِی سِتْرًا۔ (نسائی 9748)",,,25729
25730,حَدَّثَنَا ابْنُ نُمَیْرٍ ، وَأَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لَعَنَ الْوَاصِلَۃَ وَالْمُسْتَوْصِلَۃ ، وَالْوَاشِمَۃَ وَالْمُسْتَوْشِمَۃ۔ (بخاری 5937۔ مسلم 119),,,25730
25731,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ بْنِ جَابِرٍ ، قَالَ: حدَّثَنَا الْقَاسِمُ، وَمَکْحُولٌ، عَنْ أَبِی أُمَامَۃَ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لَعَنَ یَوْمَ خَیْبَرَ الْوَاصِلَۃَ وَالْمَوْصُولَۃَ ،وَالْوَاشِمَۃَ وَالْمَوْشُومَۃَ ، وَالْخَامِشَۃَ وَجْہَہَا ، وَالشَّاقَّۃَ جَیْبَہَا۔",,,25731
25732,"حَدَّثَنَا عَبْدَۃُ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ فَاطِمَۃَ ، عَنْ أَسْمَائَ ، قَالَتْ : جَائَتِ امْرَأَۃٌ إِلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَتْ : إِنَّ ابْنَتِی عُرَیِّسٌ ، وَقَدْ أَصَابَتْہَا الْحَصْبَۃُ ، فَتَمَرَّقَ شَعْرُہَا ، أَفَأَصِلُ لَہَا فِیہِ ؟ فَقَالَ لَہَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَعَنَ اللَّہُ الْوَاصِلَۃَ وَالْمُسْتَوْصِلَۃ۔ (بخاری 5936۔ مسلم 1676)",,,25732
25733,"حَدَّثَنَا أَبُو نُعَیْمٍ ، عَنْ سُفْیَانَ ، عَنْ أَبِی قَیْسٍ ، عَنْ ہُزَیْلٍ ، عَنْ عَبْدِ اللہِ ، قَالَ : لَعَنَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْوَاشِمَۃَ وَالْمَوْشُومَۃَ ، وَالْوَاصِلَۃَ وَالْمَوْصُولَۃَ۔ (ترمذی 1120۔ احمد 1/448)",,,25733
25734,حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، عَنْ أَبِی أُسَامَۃَ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لَعَنَ الْوَاشِمَۃَ وَالْمُسْتَوْشِمَۃ ، وَالْوَاصِلَۃَ وَالْمَوْصُولَۃَ۔ (احمد 1/251),,,25734
25735,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا مُجَالِدٌ ، عَنِ الشَّعْبِیِّ ، عَنِ ابْنِ عَبْدِ اللہِ ، عَنْ عَلِیٍّ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لَعَنَ الْوَاشِمَۃَ وَالْمَوْشُومَۃَ۔",,,25735
25736,"حَدَّثَنَا حَفْصٌ ، عَنْ رَزِینٍ ، قَالَ : سَمِعْتُ فَاطِمَۃَ بِنْتَ عَلِیِّ بْنِ أَبِی طَالِبٍ تَقُولُ : لَعَنَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَاصِلَۃَ الشَّعْرِ بِالشَّعْرِ۔",,,25736
25737,"حَدَّثَنَا یَحْیَی بْنُ أَبِی بُکَیْرٍ ، عَنْ شُعْبَۃَ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، قَالَ : سَمِعْتُ الْحَسَنَ بْنَ مُسْلِمٍ یُحَدِّثُ عَنْ صَفِیَّۃَ بِنْتِ شَیْبَۃَ ، عَنْ عَائِشَۃَ ؛ أَنَّ جَارِیَۃً مِنَ الأَنْصَارِ تَزَوَّجَتْ ، وَأَنَّہَا مَرِضَتْ فَتَمَرَّطَ شَعْرُہَا ، فَأَرَادُوا أَنْ یَصِلُوہُ ، فَسَأَلُوا رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ ذَلِکَ ؟ فَلَعَنَ الْوَاصِلَۃَ وَالْمُسْتَوْصِلَۃ۔\n\n(مسلم 1677۔ احمد 6/111)",,,25737
25738,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : قدِمَ مُعَاوِیَۃُ الْمَدِینَۃَ ، فَخَطَبَنَا وَأَخْرَجَ کُبَّۃً مِنْ شَعْرٍ ، فَقَالَ : مَا کُنْتُ أَرَی أَنَّ أَحَدًا یَفْعَلُہُ إِلاَّ الْیَہُودَ ، إِنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَلَغَہُ فَسَمَّاہُ الزُّورَ۔ (بخاری 3488۔ مسلم 1680)",,,25738
25739,حَدَّثَنَا أَبُو أُسَامَۃَ، عَنْ عُثْمَانَ بْنِ غِیَاثٍ، عَنْ عِکْرِمَۃَ؛ أَنَّہُ کَرِہَ الْعِقْصَۃَ الَّتِی تَجْعَلُہَا النِّسَائُ فِی رُؤُوسِہِنَّ۔,,,25739
25740,"حَدَّثَنَا یُونُسُ بْنُ مُحَمَّدٍ ، قَالَ : حدَّثَنَا فُلَیْحٌ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، عَنْ عَطَائِ بْنِ یَسَارٍ ، عَنْ أَبِی ہُرَیْرَۃَ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لَعَنَ اللَّہُ الْوَاصِلَۃَ وَالْمُسْتَوْصِلَۃ ،وَالْوَاشِمَۃَ وَالْمُسْتَوْشِمَۃ۔\n\n(احمد 2/339)",,,25740
25741,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ بِالْعَقْصَۃِ تُوضَعُ وَضْعًا۔",,,25741
25742,حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی عَقِیلٍ ، عَنْ بُہَیَّۃَ ، عَنْ عَائِشَۃَ ؛ أَنَّہَا نَہَتْ عَنِ الْوَصْلِ فِی الشَّعْرِ۔,,,25742
25743,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی حَنِیفَۃَ ، عَنِ الْہَیْثُمَّ ، عَنْ أَبی ثَوْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ بَأْسَ بِالْوِصَالِ إِذَا کَانَ صُوفًا۔",,,25743
25744,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ؛ رَأَی عَلَی رَحْلِ ابْنِ عُمَرَ قَطِیفَۃً قَیْصَرَانِیَّۃً۔,,,25744
25745,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ سَعْدِ بْنِ إِبْرَاہِیمَ ، عَن سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : لَعَنَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أَوْ قَبَّحَ اللَّہُ ، کُلَّ رَحْلٍ أَُحَیْمِرَ۔",,,25745
25746,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ وَاصِلٍ ، عَنِ الْمَعْرُورِ ، عَنْ حُذَیْفَۃَ ؛ أَنَّ عُمَرَ رَأَی امْرَأَۃً عَلَی رَحْلِہَا سُیور حُمْر ، قَالَ : فَأَمَرَنِی أَنْ أَقْطَعَہَا ، قَالَ : فَقُلْتُ : إِنَّہَا خَشَبٌ ، فَتَرَکَہَا۔",,,25746
25747,حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّ ابْنَ مَسْعُودٍ اسْتَعَارَ دَابَّۃً ، فَأُتِیَ بِہَا عَلَیْہَا صُفَّۃُ أُرْجُوَانٍ ، فَنَزَعَہَا ثُمَّ رَکِبَ۔,,,25747
25748,حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ ہَارُونَ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّ الأَشْعَرِیَّ أُتِیَ بِدَابَّۃٍ عَلَیْہَا صُفَّۃُ أُرْجُوَانٍ ، فَأَمَرَ أَنْ تُنْزَعَ۔,,,25748
25749,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ الْوَلِیدِ بْنِ کَثِیرٍ ، عَنْ مُحَمَّدِ بْنِ عَمْرو بْنِ عَطَائٍ ، عَنْ رَجُلٍ مِنْ بَنِی حَارِثَۃَ ، عَنْ رَافِعِ بْنِ خَدِیجٍ ، قَالَ : خَرَجْنَا مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَرَأَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَوَاحِلَنَا وَعَلَی إِبِلِنَا أَکْسِیَۃً فِیہَا خُیُوطُ عِہْنٍ حُمْرٌ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَلاَ أَرَی ہَذِہِ الْحُمْرَۃَ قَدْ عَلَتْکُمْ ؟ فَقُمْنَا سِرَاعًا لِقَوْلِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، حَتَّی نَفَرَ بَعْضُ إِبِلِنَا، قَالَ : فَأَخَذْنَا الأَکْسِیَۃَ فَنَزَعْنَاہَا مِنْہَا۔ (ابوداؤد 4067۔ احمد 3/463)",,,25749
25750,"حَدَّثَنَا أَبُو الأَحْوَص ، عَنْ أَبِی إِسْحَاقَ ، عَنْ ہُبَیْرَۃَ ، عَنْ عَلِیٍّ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ خَاتَمِ الذَّہَبِ ، وَعَنِ الْمِیثَرَۃِ ، یَعْنِی الْحَمْرَائَ۔ (ترمذی 2808۔ ابوداؤد 4048)",,,25750
25751,"حَدَّثَنَا عَلِیُّ بْنُ حُصَیْنٍ ، قَالَ : أَخْبَرَنَا الْمَاجِشُونُ عَبْدُ الْعَزِیزِ بْنُ عَبْدِ اللہِ ، عَنْ یَعْقُوبَ بْنِ عُتْبَۃَ بْنِ الْمُغِیرَۃِ بْنِ الأَخْنَسِ ، قَالَ : رَأَیْتُ السَّائِبَ ابْنَ أُخْتِ نَمِرٍ یَرْکَبُ بِالْمِیثَرَۃِ الْحَمْرَائِ۔",,,25751
25752,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، قَالَ : حدَّثَنِی یَحْیَی بْنُ أَیُّوبَ ، قَالَ : أَخْبَرَنِی عَیَّاشُ بْنُ عَبَّاسٍ الْحِمْیَرِیُّ ، عَنْ أَبِی الْحُصَیْنِ الْحَجْرِیِّ الْہَیْثُم ، عَنْ عَامِرٍ الْحَجْرِیِّ ، قَالَ : سَمِعْتُ أَبَا رَیْحَانَۃَ صَاحِبَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَنْہَی عَنْ رُکُوبِ النُّمُورِ۔",,,25752
25753,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی الْمُعْتَمِرِ ، عَنِ ابْنِ سِیرِینَ ، عَنْ مُعَاوِیَۃَ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی عَنْ رُکُوبِ الْخَزِّ وَالنُّمُورِ۔\n\nقَالَ ابْنُ سِیرِینَ : وَکَانَ مُعَاوِیَۃُ لاَ یُتَّہَمُ فِی الْحَدِیثِ عَلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔\n\n(ابوداؤد 4126۔ ابن ماجہ 3656)",,,25753
25754,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ، عَنِ حَجَّاجِ، عَنْ أَبِی الزُّبَیْرِ، عَنْ جَابِرٍ، قَالَ: لاَ بَأْسَ بِجُلُودِ النُّمُورِ إِذَا دُبِغَتْ۔",,,25754
25755,حَدَّثَنَا عَبْدَۃُ ، عَنْ ہِشَامٍ ؛ أَنَّ أَبَاہُ کَانَ یَکُونُ عَلَی سُرُوجِہِ النُّمُورُ ، أَوْ جُلُودُ السِّبَاعِ۔,,,25755
25756,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : ذُکِرَ عِنْدَ مُحَمَّدٍ جُلُودُ النُّمُورِ ، فَقَالَ : إِنَّمَا یُکْرَہُ أَنْ یُصَلَّی عَلَیْہَا ، وَکَانَ مُحَمَّدٌ لاَ یَرَی بَأْسًا بِالرُّکُوبِ عَلَیْہَا ، وَقَالَ : مَا أَعْلَمُ أَحَدًا تَرَکَ ہَذِہِ الْجُلُودَ تَأَثُّمًا۔",,,25756
25757,"حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنْ عَلِیِّ بْنِ الْحَکَمِ، قَالَ: سَأَلْتُ الْحَکَمَ عْن جُلُودِ النُّمُورِ؟ فَقَالَ: تُکْرَہُ جُلُودُ السِّبَاعِ۔",,,25757
25758,حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنِ الْحَجَّاجِ ، عَنِ الْحَکَمِ ؛ أَنَّ عُمَرَ کَتَبَ إِلَی أَہْلِ الشَّامِ یَنْہَاہُمْ أَنْ یَرْکَبُوا عَلَی جُلُودِ السِّبَاعِ۔,,,25758
25759,حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّ ابْنَ مَسْعُودٍ اسْتَعَارَ دَابَّۃً ، فَأُتِیَ بِہَا عَلَیْہَا صُفَّۃُ نُمُورٍ ، فَنَزَعَہَا ثُمَّ رَکِبَ۔,,,25759
25760,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَکِیمِ بْنِ جُبَیْرٍ ، عَنْ عَلِیِّ بْنِ حُسَیْنٍ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یُسْتَرَ الْجَدْرُ۔ (بیہقی 272)",,,25760
25761,"حَدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنْ فُضَیْلِ بْنِ غَزْوَانَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : بَلَغَ عُمَرَ أَنَّ ابْنًا لَہُ سَتَرَ حِیطَانَہُ ، فَقَالَ : وَاللَّہِ لَئِنْ کَانَ کَذَلِکَ لأَحْرِقَنَّ بَیْتَہُ۔",,,25761
25762,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ إِسْحَاقَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمِ بْنِ عَبْدِ اللہِ ، قَالَ : أَعْرَسْتُ فِی عَہْدِ أَبِی فَآذَنَ أَبِی النَّاسَ ، وَکَانَ فِیمَنْ آذَنَ أَبُو أَیُّوبَ ، وَقَدْ سَتَرْتُ بَیْتِی بِجُنَادِیٍّ أَخْضَرَ ، فَجَائَ أَبُو أَیُّوبَ فَدَخَلَ وَأَبِی قَائِمٌ یَنْظُرُ ، فَإِذَا الْبَیْتُ مُسْتَر بِجُنَادِیٍّ أَخْضَرَ ، فَقَالَ : أَی عَبْدَ اللہِ ، تَسْتُرُونَ الْجُدُرَ ؟ فَقَالَ أَبِی ، وَاسْتَحْیَی : غَلَبَنَا النِّسَائُ یَا أَبَا أَیُّوبَ ، قَالَ : مَنْ أَخْشَی أَنْ یَغْلِبَہُ النِّسَائُ فَلاَ أَخْشَی أَنْ یَغْلِبَنَّکَ ، لاَ أَطْعَمُ لَکَ طَعَامًا ، وَلاَ أَدْخُلُ لَکَ بَیْتًا ، ثُمَّ خَرَجَ۔ (بیہقی 272)",,,25762
25763,حَدَّثَنَا حَفْصٌ ، عَنْ مَیْمُونَ أَبِی عَبْدِ اللہِ ، عَنِ الضَّحَّاکِ بْنِ مُزَاحِمٍ ؛ أَنَّہُ کَرِہَ رُکُوبَ النِّسَائِ السُّرُوجَ۔,,,25763
25764,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَاصِمٍ ، قَالَ : کَانُوا یَکْرَہُونَ مَرْکَبَ الرَّجُلِ لِلْمَرْأَۃِ ، وَمَرْکَبَ الْمَرْأَۃِ لِلرَّجُلِ۔",,,25764
25765,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : کَانُوا یَکْرَہُونَ زِیَّ الرِّجَالِ لِلنِّسَائِ ، وَزِیَّ النِّسَائِ لِلرِّجَالِ۔",,,25765
25766,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ أُمِّ شَبِیبٍ ، عَنْ أُمِّ عُمَرَ ؛ أَنَّ امْرَأَۃَ الزُّبَیْرِ قَالَتْ : سَمِعْتُ عُمَرَ یَقُولُ: یَا مَعْشَرَ النِّسَائِ، أخْفِینَ الْحِنَّائَ، وَارْفَعْنَ الْحُجَز، وَسَمِعْتُہُ یَقُولُ: أُنْشِدُ اللَّہَ امْرَأَۃً تُصَلِّی فِی الْحُجَزِ۔",,,25766
25767,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہَمَّامٍ ، قَالَ : سَأَلْتُ ، أَوْ سَمِعْتُ ، أَوْ سُئِلَ عَنْ شِسْعِ الْحَدِیدِ ؟فَقَالَ : لاَ بَأْسَ بِہِ۔",,,25767
25768,"حَدَّثَنَا شَبَابَۃُ ، قَالَ : حدَّثَنَا الْمُغِیرَۃُ بْنُ مُسْلِمٍ ، عَنْ عَبْدِ اللہِ بْنِ بُرَیْدَۃَ ، قَالَ : کَتَبَ عُمَرُ إِلَی أَبِی مُوسَی الأَشْعَرِیِّ : إِیَّاکَ وَہَذِہِ الرَّکْبَ الْحَدِیدَ۔",,,25768
25769,"حَدَّثَنَا وَکِیعٌ ، عَنْ طُعْمَۃَ الْجَعْفَرِیِّ ، قَالَ : رَأَیْتُ مُوسَی بْنَ طَلْحَۃَ قَدْ شَدَّ أَسْنَانَہُ بِالذَّہَبِ۔",,,25769
25770,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی، عَنْ ثَابِتِ بْنِ قَیْسٍ، قَالَ: رَأَیْتُ نَافِعَ بْنَ جُبَیْرٍ مَرْبُوطَۃً أَسْنَانُہُ بِخُرْصَانِ الذَّہَب۔",,,25770
25771,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حُمَیْدٍ ؛ أَنَّ الْحَسَنَ شَدَّ أَسْنَانَہُ بِذَہَبٍ۔,,,25771
25772,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ جَعْفَرِ بْنِ حَیَّانَ ، عَنْ حَمَّادٍ ، قَالَ : رَأَیْتُ الْمُغِیرَۃَ بْنَ عَبْدِ اللہِ یَرْبِطُ أَسْنَانَہُ بِذَہَبٍ ، قَالَ : فَسَأَلْتُ إِبْرَاہِیمَ ؟ فَقَالَ : لاَ بَأْسَ بِہِ۔",,,25772
25773,"حَدَّثَنَا ابْنُ مُبَارَکٍ، عَنْ جَعْفَرِ بْنِ حَیَّانَ ، قَالَ: حدَّثَنِی ابْنُ طَرَفَۃَ بْنِ عَرْفَجَۃَ ؛ بِأنَّ جَدَّہُ أُصِیبَ أَنْفُہُ یَوْمَ الْکُلاَبِ، فَاتَّخَذَ أَنْفًا مِنْ وَرِقٍ فَأَنْتَنَ عَلَیْہِ، فَأَمَرَہ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یَتَّخِذَ أَنْفًا مِنْ ذَہَبٍ۔ (ابوداؤد 4229۔ ترمذی 1770)",,,25773
25774,"حَدَّثَنَا یَزِیدُ ، قَالَ : أَخْبَرَنَا حَمَّادٌ ، قَالَ : رَأَیْتُ ثَابِتًا الْبُنَانِیَّ مَشْدُودَ الأَسْنَانِ بِذَہَبٍ۔",,,25774
25775,"حَدَّثَنَا إِسْمَاعِیلُ بْنُ إِبْرَاہِیمَ ، عَن لَیْثٍ ، عَنِ الْمُہَاجِرِ ، قَالَ : قَالَ ابْنُ عُمَرَ : مَنْ لَبِسَ رِدَائَ شُہْرَۃٍ ، أَوْ ثَوْبَ شُہْرَۃٍ أَلْبَسَہُ اللَّہُ نَارًا یَوْمَ الْقِیَامَۃِ۔ (ابوداؤد 4025۔ ابن ماجہ 3607)",,,25775
25776,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنِ الْحُصَیْنِ ، قَالَ : کَانَ زُبَیْدٌ الْیَامِیُّ یَلْبَسُ بُرْنُسًا ، قَالَ : فَسَمِعْتُ إِبْرَاہِیمَ عَابَہُ عَلَیْہِ ، قَالَ : فَقُلْتُ لَہُ : إِنَّ النَّاسَ قَدْ کَانُوا یَلْبَسُونَہَا ، قَالَ : أَجَلْ ، وَلَکِنْ قَدْ فَنِیَ مَنْ کَانَ یَلْبَسُہَا ، فَإِنْ لَبِسَہَا أَحَدٌ الْیَوْمَ شَہَرُوہُ وَأَشَارُوا إِلَیْہِ بِالأَصَابِعِ۔",,,25776
25777,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ لَیْثٍ ، عَنْ شَہْرٍ ، عَنْ أَبِی الدَّرْدَائِ ، قَالَ : مَنْ رَکِبَ مَشْہُورًا مِنَ الدَّوَابِّ ، أَوْ لَبِسَ مَشْہُورًا مِنَ الثِّیَابِ ، أَعْرَضَ اللَّہُ عَنْہُ مَا دَامَ عَلَیْہِ ، وَإِنْ کَانَ عَلَیْہِ کَرِیمًا۔",,,25777
25778,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ لَیْثٍ ، عَن مُہَاجِرٍ أَبِی الْحَسَنِ ، عَنِ ابْنِ عُمَرَ ، قَالَ : مَنْ لَبِسَ شُہْرَۃً مِنَ الثِّیَابِ أَلْبَسَہُ اللَّہُ ذِلَّۃً۔",,,25778
25779,"حَدَّثَنَا شَبَابَۃُ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ عَبْدِ اللہِ بْنِ دِینَارٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الْقَزَعِ۔ (بخاری 5921۔ ابن ماجہ 3638)",,,25779
25780,"حَدَّثَنَا وَکِیعٌ ، وَابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ الْحَسَنِ ، قَالَ : سَمِعْتُ أُمِّی فَاطِمَۃَ بِنْتَ الْحُسَیْنِ تَنْہَی عَنِ الْقَزَعِ۔",,,25780
25781,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ عُمَرَ بْنِ نَافِعٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الْقَزَعِ ، وَالْقَزَعُ : أَنْ یُحْلَقَ مِنْ رَأْسِ الصَّبِیِّ مَوْضِعٌ وَیُتْرَکَ مَوْضِعٌ۔\n\n(بخاری 5920۔ مسلم 1675)",,,25781
25782,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ أَبِی سَلاَّمٍ ، قَالَ : دَخَلْتُ عَلَی عَائِشَۃَ وَفِی رَأْسِی قَزَعٌ ، فَأَمَرَتْ بِہِ فَجُزَّ ، أَوْ حُلِقَ۔",,,25782
25783,"حَدَّثَنَا صَفْوَانُ بْنُ عِیسَی ، عَنْ عَبْدِ الأَعْلَی بْنِ عَبْدِ اللہِ بْنِ أَبِی فَرْوَۃَ ، قَالَ : سَأَلْتُ سَعِیدَ بْنَ الْمُسَیَّبِ ، قُلْتُ : رَجُلٌ فِی خَاتَمِہِ مِثْلُ رَأْسِ الطَّیْرِ ؟ فَقَالَ : یَا ابْنَ أَخِی ، مَا عَلِمْنَا أَحَدًا مِنْ أَصْحَابِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ تَخَتَّمَ لاَ أَبُو بَکْرٍ ، وَلاَ عُمَرَ ، وَلاَ فُلاَنًا ، وَلاَ فُلاَنًا حَتَّی عَدَّ نَاسًا مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَأَعَدْتُ عَلَیْہِ مِرَارًا فَکَأَنَّہُ یَکْرَہُ الْخَاتَمَ۔",,,25783
25784,"حَدَّثَنَا عَفَّانُ، قَالَ: حدَّثَنَا ہَمَّامُ، عَنْ لَیْثٍ، عَنْ عَطَائٍ، وَطَاوُوسٍ، وَمُجَاہِدٍ؛ أَنَّہُمْ کَانُوا لاَ یَتَخَتَّمُونَ۔",,,25784
25785,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنِ الْحَکَمِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی، عَنْ عَبْدِ اللہِ بْنِ عُکَیْمٍ ، قَالَ: أَتَانَا کِتَابُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَنْ لاَ تَنْتَفِعُوا مِنَ الْمَیْتَۃِ بِإِہَابٍ ، وَلاَ عَصَبٍ۔\n\n(ابن ماجہ 3613۔ احمد 4/310)",,,25785
25786,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الْحَکَمِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، عَنْ عَبْدِ اللہِ بْنِ عُکَیْمٍ ، قَالَ : أَتَانَا کِتَابُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَنَحْنُ بِجُہَیْنَۃَ : لاَ تَنْتَفِعُوا مِنَ الْمَیْتَۃِ بِإِہَابٍ ، وَلاَ عَصَبٍ۔ (ترمذی 1729۔ ابن ماجہ 3613)",,,25786
25787,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، عَنْ عَبْدِ اللہِ بْنِ عُکَیْمٍ ، قَالَ : أَتَانَا کِتَابُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَأَنَا غُلاَمٌ : أَنْ لاَ تَنْتَفِعُوا بِإِہَابِ مَیْتَۃٍ ، وَلاَ عَصَبٍ۔\n\n(ابوداؤد 4124۔ ابن ماجہ 3613)",,,25787
25788,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ ، وَحَمَّادًا عَنْ شَعْرِ الْخِنْزِیرِ ، یُعْمَلُ بِہِ ؟ فَکَرِہَاہُ۔",,,25788
25789,حَدَّثَنَا حَفْصٌ ، عَنْ أَبِی الْحَسَنِ ، عَنْ أَبِی جَعْفَرٍ (ح) وَعَنْ إِسْمَاعِیلَ ، عَنِ الْحَسَنِ ؛ أَنَّہُمَا رَخَّصَا فِی شَعْرِ الْخِنْزِیرِ یُخْرَزُ بِہِ۔,,,25789
25790,حَدَّثَنَا وَکِیعٌ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّہُ کَانَ لاَ یَلْبَسُ خُفًّا خُرِزَ بِشَعْرِ خِنْزِیرٍ۔,,,25790
25791,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ شُعْبَۃَ ، عَنْ شَیْخٍ مِنْ أَہْلِ وَاسِطَ ، قَالَ : سَأَلْتُ أَبَا عِیَاضٍ عَنْ شَعْرِ الْخِنْزِیرِ ، یُوضَعُ عَلَی جُرْحِ الدَّابَّۃِ ؟ فَکَرِہَہُ۔",,,25791
25792,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ عَاصِمٍ ، عَنْ أَبِی بُرْدَۃَ ، عَنْ عَلِیٍّ ، قَالَ : نَہَانَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ نَتَخَتَّمَ فِی ہَذِہِ ، وَہَذِہِ ، یَعْنِی السَّبَّابَۃَ وَالْوُسْطَی۔ (مسلم 64۔ ترمذی 1786)",,,25792
25793,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، قَالَ : کَانَ إِبْرَاہِیمُ یَکْرَہُہُ۔",,,25793
25794,"حَدَّثَنَا وَکِیعٌ، عَنْ أُسَامَۃَ بْنِ زَیْدٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، عنْ أَبِیْہِ ، عَنْ عَائِشَۃَ ، قَالَتْ: سَتَرْتُ سَہْوَۃً لِی ، تعْنِی الدَّاخِلَ ، بِسِتر فِیہِ تَصَاوِیرُ ، فَلَمَّا قَدِمَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ہَتَکَہُ ، فَجَعَلْتُ مِنْہُ مِنْبَذَتَیْنِ ، فَرَأَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مُتَّکِئًا عَلَی إِحْدَاہُمَا۔ (مسلم 92۔ ابن ماجہ 3653)",,,25794
25795,"حَدَّثَنَا حَفْصٌ ، عَنِ الْجَعْدِ رَجُلٍ مِنْ أَہْلِ الْمَدِینَۃِ ، قَالَ : حَدَّثَتْنِی ابْنَۃُ سَعْدٍ ؛ أَنَّ أَبَاہَا جَائَ مِنْ فَارِسَ بِوَسَائِدَ فِیہَا تَمَاثِیلُ ، فَکُنَّا نَبْسُطُہَا۔",,,25795
25796,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، قَالَ : رَأَیْتُ سَالِمَ بْنَ عَبْدِ اللہِ مُتَّکِئًا عَلَی وِسَادَۃٍ حَمْرَائَ فِیہَا تَمَاثِیلُ ، فَقُلْتُ لَہُ ؟ فَقَالَ : إِنَّمَا یُکْرَہُ ہَذَا لِمَنْ یَنْصِبُہُ وَیَصْنَعُہُ۔",,,25796
25797,حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یَتَّکِیئُ عَلَی الْمَرَافِقِ فِیہَا التَّمَاثِیلُ ؛ الطَّیْرُ وَالرِّجَالُ۔,,,25797
25798,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَلْقَمَۃَ ، عَنْ مُحَمَّدِ بْنِ سِیرِینَ ، قَالَ : نُبِّئْتُ عَنْ حِطَّانَ بْنِ عَبْدِ اللہِ ، قَالَ : أَتَی عَلَیَّ صَاحِبٌ لِی فَنَادَانِی فَأَشْرَفْت عَلَیْہِ ، فَقَالَ : قُرِئَ عَلَیْنَا کِتَابُ أَمِیرِ الْمُؤْمِنِینَ ، یَعْزِمُ عَلَی مَنْ کَانَ فِی بَیْتِہِ سِتْرٌ مَنْصُوبٌ فِیہِ تَصَاوِیرُ لِمَا وَضَعَہُ ، فَکَرِہْتُ أَنْ أَبِیْتَ عَاصِیًا ، فَقُمْنَا إِلَی قِرَامٍ لَنَا فَوَضَعْتُہُ ، قَالَ مُحَمَّدٌ : وَکَانُوا لاَ یَرَوْنَ مَا وُطِئَ وَبُسِطَ مِنَ التَّصَاوِیرِ مِثْلُ الَّذِی نُصِبَ۔",,,25798
25799,"حَدَّثَنَا إِسْمَاعِیلُ ، عَنْ أَیُّوبَ ، عَنْ عِکْرِمَۃَ ، قَالَ : کَانَ یُقَالُ فِی التَّصَاوِیرِِ فِی الوَسَاِئد وَالبُسُطِ التِی تُوطَأَ : ہُوَ ذل لَہَا۔",,,25799
25800,"حَدَّثَنَا أَبُو مُعَاوِیَۃ ، عَنْ عَاصِم ، عَنْ عِکْرِمَۃَ ، قَالَ : کَانُوا یَکْرَہُونَ مَا نُصِبَ مِنَ التَّمَاثِیلِ نَصْبًا ، وَلاَ یَرَوْنَ بَأْسًا بِمَا وَطِئَتِ الأَقْدَامُ۔",,,25800
25801,حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا بِمَا وُطِئَ مِنَ التَّصَاوِیرِ۔,,,25801
25802,حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ؛ أَنَّہُ کَانَ یَکْرَہُ أَنْ یُصَوَّرَ الشَّجَرُ الْمُثَمَّرُ۔,,,25802
25803,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَانَ فِی مَجْلِسِ مُحَمَّدٍ وَسَائِدُ فِیہَا تَمَاثِیلُ عَصَافِیرَ ، فَکَانَ أُنَاسٌ یَقُولُونَ فِی ذَلِکَ ، فَقَالَ مُحَمَّدٌ : إِنَّ ہَؤُلاَئِ قَدْ أَکْثَرُوا ، فَلَوْ حَوَّلْتُمُوہَا۔",,,25803
25804,"حَدَّثَنَا ابْنُ یَمَانٍ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ، عَنْ عِکْرِمَۃَ بْنِ خَالِدٍ، قَالَ: لاَ بَأْسَ بِالصُّورَۃِ إِذَا کَانَتْ تُوطَأُ۔",,,25804
25805,"حَدَّثَنَا ابْنُ یَمَانٍ ، عَنِ الرَّبِیعِ بْنِ الْمُنْذِرِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : لاَ بَأْسَ بِالصُّورَۃِ إِذَا کَانَتْ تُوطَأُ۔",,,25805
25806,حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ فِی التَّمَاثِیلِ ، مَا کَانَ مَبْسُوطًا یُوطَأُ وَیُبْسَطُ فَلاَ بَأْسَ بِہِ ، وَمَا کَانَ یُنْصَبُ فَإِنِّی أَکْرَہُہَا۔,,,25806
25807,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ؛ أَنَّہُ کَانَ یَکْرَہُ التَّصَاوِیرَ ، مَا نُصِبَ مِنْہَا وَمَا بُسِطَ۔,,,25807
25808,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ عِکْرِمَۃَ ، قَالَ : إِنَّمَا الصُّورَۃُ الرَّأْسُ ، فَإِذَا قُطِعَ فَلاَ بَأْسَ۔",,,25808
25809,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سَلَمَۃَ أَبِی بِشْرٍ ، عَنْ عِکْرِمَۃَ ؛ قَوْلِہِ : {الَّذِینَ یُؤْذُونَ اللَّہَ وَرَسُولَہُ} قَالَ : أَصْحَابُ التَّصَاوِیرِ۔",,,25809
25810,"حَدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : دَخَلْتُ عَلَی الْقَاسِمِ وَہُوَ بِأَعْلَی مَکَّۃَ فِی بَیْتِہِ ، فَرَأَیْتُ فِی بَیْتِہِ حَجَلَۃً فِیہَا تَصَاوِیرُ ؛ الْقُنْدُسِ وَالْعَنْقَائِ۔",,,25810
25811,"حَدَّثَنَا الْحَسَنُ بْنُ مُوسَی ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، عَنْ سَالِمِ بْنِ عَبْدِ اللہِ ، قَالَ : کَانُوا لاَ یَرَوْنَ بِمَا وُطِئَ مِنَ التَّصَاوِیرِ بَأْسًا۔",,,25811
