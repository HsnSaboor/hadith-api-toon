{"metadata":{"name":"Sunan Ibn Majah","section":{"34":"Supplication"},"section_detail":{"34":{"hadithnumber_first":3827,"hadithnumber_last":3892,"arabicnumber_first":3827,"arabicnumber_last":3892}}},"hadiths":[{"hadithnumber":3890,"arabicnumber":3890,"text":"Rapporté par ‘Aishah : Quand le Messager d’Allah (ﷺ) voyait la pluie, il disait : « Allahumma aj’alhu sayyiban hani’an (Ô Allah, fais-en une pluie bienfaisante). »","grades":[{"name":"Al-Albani","grade":"Sahih"},{"name":"Muhammad Fouad Abd al-Baqi","grade":"Sahih"},{"name":"Shuaib Al Arnaut","grade":"Sahih"},{"name":"Zubair Ali Zai","grade":"Sahih Bukhari"}],"reference":{"book":34,"hadith":64}}]}