hadiths[19]{hadithnumber,text}:
2377,"ضۏٔزىتأتثىأؼثتضأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأتۏڬأؼًشحأىەأذدأڬۏأىسشأوتىۏأتًشأًۄأوشأڲةۏأتضأڬتأثہتةۏأشضًهأتههۄأ﷽أڬەأځتضأڲۏتأتًشأتضأڬەأوحؼهمأځًډہتأحًأشضًهأتههۄأ﷽أىەأتضەألشوتۏتأ=““أتڲشأتضأځشأمشعأۄًأحًأتضەأحًأتزتأڬشحتأآأتضأىەأڬۄتأ=أدۏأۄتڽأ‛أإځأىەألشوتۏتأ=““أىسشأځًشۏأڬشًأ‛أۏۄأځًشۏأڬةەأدتىەأڬۏأصۏتزۄأوضحذمأۄەأۗ‛‛

[تخریج]: !صحیح البخاری،کتاب الأیمان والنذر،باب من مات علیہ نذر(6699)"
2378,"ضۏٔزىتأؼوشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأوۏڽأىەأڬۄتأ=أۏتأشضًهأتههۄأ﷽أ$أوۏڽأىەأدتۄهۏحأوۏڽأىسشأوتىۏأحہۏأځہشأتضهتوأمثًهأڬشأهۏتأإځأىەألشوتۏتأ=““أتځىۏأىسشأځًشۏأڬشًأۗ‛‛

[تخریج]: @متفق علیہ: البخاری،کتاب الایمان والنذور،باب اذا نذر أوحلف أن لایکلم انسانا فی الجاہلیۃ (6697) ومسلم، کتاب الأیمان، باب نذر الکافر،وما یفعل فیہ اذا اسلم(4269-4268)"
2379,"ضۏٔزىتأؼمثۄأثىأؼتوشأدۄىۏأڬۄحەأۄۏڽأ=أوۏشۏأثۄىأىەأتههۄأڬەأهةەأځۏزهأتًشأىىڲەأضشأذدأڬۏأىسشأوتىۏأ‛أوۏڽأىەأتضأڬتأشضًهأتههۄأ﷽أضەأسڬشأڬۏتأۗأإځأىەألشوتۏتأ=““أتځىۏأثۄىأضەأڬۄًأًۄأډتزشأتًڔہەأتًشأضًتشۏأڬشەأتًشأحۏىأزىأشًصۄأشڬہەأۗ‛‛

[تخریج]: !متفق علیہ: البخاری،کتاب جزاء الصید،باب من نذر المشی الی الکعبۃ(1866(ومسلم،کتاب النذر،باب من نذر أن یمشی الی الکعبۃ(4227-4226)"
2380,"ضۏٔزىتأتثىأؼثتضأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأ‛أؼمثۄأڬۏأثۄىأىەأثۏحأتههۄأڬۏأغشلأځۏزهأدتىەأڬۏأىسشأوتىۏأۗأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أتههۄأحؼتهۏٳأڬًأحوۄتشۏأثۄىأڬۏأىسشأڬۏأڬًةۏأعشًشحأىۄۏڽأًۄأضًتشۏأڬشەأتًشأ+أڬلتشٔۄأڬەأغًشأځشأ,أمشثتىۏأڬشەأۗ‛‛

[تخریج]: @صحیح: ابوداؤد،کتاب الأیمان والنذور،باب من رأی علیہ کفارۃ اذا کان فی معصیۃ (3297-3296 -3295) والبیہقی،کتاب النذور،باب الہدی فیہا رکب10/79واخرجہ احمد1/239"
2381,"ضۏٔزىتأتثًۄشۏشۄأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەأڬضۏأثًڔہەأڬًأزۏڬہتأدًأتځىەأثۏټًڽأڬەأضتحہأدتأشۄتأحہتأۗأإځأىەألشوتۏتأ=““أتضأڬتأڬۏتأذتهأۄەأآأتضأڬەأثۏټًڽأىەأڬۄتأ=أتضأىەأډهىەأڬۏأىسشأوتىۏأحہۏأ‛أإځأىەألشوتۏتأ=““أضًتشأۄًأدتاأڬۏًىڬۄأتههۄأحوۄتشۏأىسشأضەأحدہأضەأثەأځشًتۄأۄەأۗ‛‛

[تخریج]: ! صحیح مسلم،کتاب النذور،باب من نذر أن قلشی الی الکعبۃ(4224)وابن ماجہ،کتاب الکفارات ، باب من نذر أن یحج ماشیا(2135)"
2382,"ضۏٔزىتأؼوشتىأثىأذظۏىأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أتههۄأڬۏأىتلشوتىۏأڬۏأىسشأځًشۏأىۄۏڽأڬشىۏأډتۄةەأۗأتًشأىۄأۄۏأًۄأىسشأدضأڬتأتثىأإزوأ+أتضأڬەأترحۏتشأوۏڽأىۄأۄًأ,أۗ‛‛

[تخریج]: @صحیح مسلم،کتاب النذور،باب لاوفاء لنذر فی معصیۃاللہ ولا فیہا لا یملک العبد(4221)وابن ماجہ،کتاب الکفارات،باب النذر فی المعصیۃ(2124)"
2383,"ضۏٔزۄأؼتةطۄأشعۏأتههۄأؼىۄتأڬۄحۏأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أدضأىەأتههۄأڬۏأتغتؼحأڬۏأىسشأوتىۏأتضأڬۏأتغتؼحأڬشىەأتًشأدضأىەأتههۄأڬۏأىتلشوتىۏأڬۏأىسشأوتىۏأًۄأتضأڬۏأىتلشوتىۏأىۄأڬشەأۗ‛‛

[تخریج]: #صحیح البخاری،کتاب الأیمان والنذور،باب النذور،باب ماجاء فی النذر فی معصیۃ(3289)والنسائی کتاب الأیمان والنذور،باب النذر فی المعصیۃ (3812)"
2384,"ضۏٔزىتأدتثشأثىأؼثزتههۄأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬضۏأإزوۏأىەأڬۄتأ=أتەأتههۄأڬەأشضًهأ$أوۏڽأىەأىسشأوتىۏأحہۏأتڲشأتههۄأىەأإځأڬًألحذأزۏأحًأوۏڽأثۏحأتهومزضأوۏڽأىوتصأځڔہًڽأڲتأۗأإځأىەألشوتۏتأ=““أۏۄۏڽأىوتصأځڔہأهًأۗ‛‛أتضأىەأحۏىأزلؼۄأتضەأزہشتۏتأحًأىثۏأ﷽أىەألشوتۏتأ=““أحدہەأترحۏتشأۄەأۗ‛‛

[تخریج]: !صحیح : اخرجہ الحاکم4/305-304والبیہقی فی النذور،باب من لم یرو جوب بالنذر10/82"
2385,"ضۏٔزىتأتثىأؼوشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أىسشأضەأڬډہأثزهحتأىۄۏڽأۄەأ‛أتضأضەأظشلأثرۏهأإزوۏأڬتأوتهأىڬتهتأدتحتأۄەأۗ‛‛

[تخریج]: @متفق علیہ: البخاری،کتاب القدر،باب إلقاء العبد النذر الی القدر(6608)ومسلم،کتاب النذر،باب النہی عند النذر وأنہ لا یرد شیئًا (4212) وابن ماجہ ، کتاب الکفارات با النہی عن النذر (2122)"
2386,"ضۏٔزىتأتثىأؼوشأشعۏأتههۄأؼىۄوتأڬۄحەأۄۏڽأشضًهأتههۄأ﷽أىەأؼوشأثىأرغتثأشعۏأتههۄأؼىۄأڬًأزۏڬہتأڬۄأًۄأتۏڬأمتلهۄأوۏڽأډهأشۄەأحہەأتًشأًۄأتځىەأًتهزأڬۏأمضوأڬہتأشۄەأحہەأۗأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أتههۄأحؼتهۏٳأحوۄۏڽأتځىەأثتځًڽأڬۏأمضوۏڽأڬہتىەأضەأوىؼأڬشحتأۄەأۗأدًأطرظأمضوأڬہتةەأًۄأتههۄأڬۏأمضوأڬہتةەأۏتأرتوًطأشۄەأۗ‛‛

[تخریج]: ! متفق علیہ :البخاری،کتاب الأدب،باب من لم یریا کفار من قال ذلک متأولا اوجاہلا(6108)ومسلم،کتاب الأیمان،باب النہی عن الحلف بغیر اللہ تعالیٰ(4233)"
2387,"ضۏٔزىتأتثىأؼوشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأىثۏأ﷽أىەألشوتۏتأ=““أدضأىەأڬضۏأوؼتوهۄأځشأمضوأڬہتةۏأتًشأتىأطتؤأتههۄأڬۄتأًۄأورحتشأۄًأڲۏتأۗ‛‛

[تخریج]: @صحیح: ابن حبان (4339) اخرجہ ابوداؤد،کتاب الأیمان،باب الاستشناء فی الیمین(1531)والنسائی،فی الکتاب الأیمان ، باب من حلف فاستشنیٰ(3702)"
2388,"ضۏٔزىتأتثىأؼوشأشعۏأتههۄأؼىۄوتأڬۄحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أدضأىەأمضوأڬہتةۏأځہشأتىأطتؤأتههۄأڬۄتأًۄأورحتشأۄًأ‛أتڲشأډتۄەأحًأڬشەأډتۄەأحًأىۄأڬشەأۗ‛‛

[تخریج]: #صحیح: تخریج گزر چکی ہے۔"
2389,"ضۏٔزىتأتثىأؼثتضأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأىثۏأ﷽أىەأتثًثڬشأضەألشوتۏتأ=““أمضوأىۄأڬہتاأ‛أتثًثڬشأڬۄحەأۄۏڽأ=أۏۄأهوثۏأذزۏخأۄەأۗ

[تخریج]: !اسنادہ صغیف: لیکن حدیث متفق علیہ ہے یہ حدیث(2202)نمبر حدیث کے تحت مکمل گزر چکی ہے۔"
2390,"ضۏٔزىتأؼوشًأشعۏأتههۄأؼىۄأدًأوشۄأڬەأثۏټەأۄۏڽأثۏتىأڬشحەأۄۏڽأڬۄأوۏڽأىەأدوتدوأڬەأصوتىۄأوۏڽأؼثزتههۄأثىأؼوشًأشعۏأتههۄأؼىۄأضەأضىتأًۄأثۏتىأڬشحەأحہەأۗأتۏڬأطرظأىەأؼزۏأثىأذتحوأضەأضًتهأڬۏتأ+أڬډہأوتىڲتأ,أ؏أتىۄًڽأىەأمضوأڬہتةۏأڬۄأًۄأتضەأڬډہأىۄأزۏڽأڲەأځہشأڬۄتأ=أتڲشأوۏڽأىەأشضًهأتههۄأ﷽أضەأۏۄأىۄأضىتأۄًحتأڬۄأًۄألشوتحەأحہەأ=““أدًأطرظأڬضۏأثتحأځشأمضوأڬہتةەأځہشأڬضۏأتًشأڬتوأوۏڽأتضەأثہهتةۏأىػشأإةەأحًأثہهتةۏأًتهتأڬتوأڬشەأۗأتًشأمضوأڬتأڬلتشۄأتزتأڬشەأۗ‛‛أ+أحًأوۏڽأحوۄۏڽأىۄأزۏحتأ

[تخریج]: @ صحیح مسلم،کتاب الأیمان،باب ندب من حلف یمینافر أی غیرہا خیراً منہا…(1651)والنسائی،کتاب الأیمان،باب الکفارۃ بعد الحنث(3794)"
2391,"ضۏٔزىتأؼثزتهشذوىأثىأضوشۄأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أتەأؼثزتهشذوىأثىأضوشۄأشعۏأتههۄأؼىۄأ$أحوأتوتشحأوحأوتىڲًأتڲشأحوۄۏڽأوتىڲىەأضەأزۏأدتةەأڲۏأحًأحوأځشأډہًڔأزۏأدتةەأڲۏأتًشأتڲشأثىأوتىڲەأزۏأڲةۏأحًأحوۄتشۏأوززأڬۏأدتةەأڲۏأ‛أتًشأدثأحوأمضوأڬہتاأځہشأڬضۏأتًشأثتحأوۏڽأثہهتةۏأىػشأإةەأحًأتځىۏأمضوأڬتأڬلتشۄأزًأتًشأثۄحشأڬتوأڬشًأۗ‛‛

[تخریج]: !متفق علیہ: البخاری،کتاب کفارات الأیمان،باب الکفارۃ بعد الحنث وبعدہ(6722)ومسلم،کتاب الأیمان،باب ندب من حلف یمینا(4258-4257)"
2392,"ضۏٔزىتأؼثزتهشذوىأثىأضوشۄأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=أځہشأځۄهۏأذزۏخأڬۏأغشذأسڬشأڬۏتأۗ

[تخریج]: @متفق علیہ: سابقہ حدیث ہی مکرر آئی ہے۔"
2393,"طشۏزأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأوۏڽأىثۏأ﷽أڬەأځتضأإۏتأۗأتًشأڬۄتأ=أوۏشۏأًتهزۄأڬەأسوۄأتۏڬأؽهتوأۏتأهًىڋۏأإصتزأڬشىتأۄەأ‛أوۏشەأځتضأضۏتۄأشىڲأڬۏأذثطۏأهًىڋۏأۄەأڬۏتأًۄأڬلتۏحأڬشأدتةەأڲۏأآألشوتۏتأ=أتضەأثهتاأځہشألشوتۏتأ=““أڬۏتأحًأڲًتۄۏأزۏحۏأۄەأڬۄأتههۄأڬەأؼهتًۄأڬًةۏأوؼثًزأىۄۏڽأ‛أتضأىەأڬۄتأ=““أدۏأۄتڽأۗ‛‛أإځأىەألشوتۏتأ=““أۏۄأوًوىۄأۄەأتضەأإصتزأڬشأزًأۗ‛‛

[تخریج]: # اسنادہ حسن : محمد بن عمرو کی وجہ سے،صحیح ابن حبان(189)"
2394,"ضۏٔزىتأتثًۄشۏشۄأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأ‛أشضًهأتههۄأ﷽أىەألشوتۏتأ=““أحوۄتشۏأتضأمضوأڬتأۏمۏىأۄًأڲتأدضأڬۏأحوۄتشەأضتحہۏأىەأحظزۏمأڬۏأۗ‛‛

[تخریج]: ! صحیح مسلم،کتاب الأیمان،باب یمین الحالف علی نیۃ المستحلف(4260-4259)والترمذی،کتاب الأحکام، باب ماجاء أن الیمین علی ما یصدقہ صاحبہ(1354)وابن ماجہ،کتاب الکفارات،باب من وری فی یمینہ (6120)"
2395,"ضۏٔزىتأتثىأؼوشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأشضًهأتههۄأ﷽أتضأغشذأمضوأڬہتحەأحہەأ=““أزهًڽأڬًأځہۏشىەأًتهەأڬۏأمضوأ$‛‛أ+أًتههۄأتٗؼهوأثتهظًتثأ

[تخریج]: @ صحیح البخاری،کتاب الأیمان والنذور،باب کیف کانت یمین النبی صلعم(6628)ابوداؤد،کتاب الأیمان والنذور،باب ماجاء فی یمین النبی صلعم ماکانت؟(3263)"
