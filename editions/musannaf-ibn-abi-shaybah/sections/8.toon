hadiths[508]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}:
12272,"حدَّثَنَا أَبُو عَبْدِ الرَّحْمَنِ بَقِیُّ بْنُ مَخْلَدٍ ، قَالَ : حدَّثَنَا أَبُو بَکْرٍ عَبْدُ اللہِ بْنُ مُحَمَّدِ بْنِ أَبِی شَیْبَۃَ ، قَالَ : حدَّثَنَا إسْمَاعِیلُ بْنُ إبْرَاہِیمَ بْنِ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ، عَنْ أَبِی الْمُہَلَّبِ ، عَنْ عِمْرَانَ بْنِ الْحُصَیْنِ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ نَذْرَ فِی مَعْصِیَۃِ اللہِ ، وَلاَ فِیمَا لاَ یَمْلِکُ الْعَبْدُ۔\n\n(ابوداؤد 300۔ احمد 4/433)",,,12272,,
12273,عَبْدُ اللہِ بْنُ نُمَیْرٍ ، وَأَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ طَلْحَۃَ بْنِ عَبْدِ الْمَلِکِ ، عَنِ الْقَاسِمِ بْنِ مُحَمَّدٍ ، عَنْ عَائِشَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ مَنْ نَذَرَ أَنْ یُطِیعَ اللَّہَ فَلْیُطِعْہُ ، وَمَنْ نَذَرَ أَنْ یَعْصِیَ اللَّہَ ، فَلاَ یَعْصِہِ۔ (بخاری 6696۔ ابوداؤد 3282),,,12273,,
12274,"حدَّثَنَا عَبْدُ اللہِ بْنُ مُبَارَکٍ ، عَنْ مَعْمَرٍ ، عَنْ زَیْدِ بْنِ رُفَیْعٍ ، عَنْ أَبِی عُبَیْدَۃَ ، قَالَ : قَالَ عَبْدُ اللہِ : إنَّ النَّذْرَ لاَ یُقَدِّمُ شَیْئًا ، وَلاَ یُؤَخِّرُہُ ، وَلَکِنَّ اللَّہَ یَسْتَخْرِجُ بِہِ مِنَ الْبَخِیلِ ، فَلاَ وَفَائَ بِالنَّذْرِ فِی مَعْصِیَۃٍ۔",,,12274,,
12275,"حدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنِ الدَّالاَنِیِّ ، عَنْ أَبِی سُفْیَانَ ، عَنْ جَابِرٍ ، قَالَ : لاَ وَفَائَ لِنَذْرٍ فِی مَعْصِیَۃٍ۔ (عبدالرزاق 15823۔ احمد 297)",,,12275,,
12276,"حدَّثَنَا مُحَمَّد بْنُ فُضَیْلٍ ، عَنِ النُّعْمَانِ بْنِ قَیْسٍ ، عَنْ خَالَتِہِ مُلَیْکَۃَ ، عَنْ عَبِیدَۃَ ، قَالَتْ : سَأَلْتُہُ عَنِ النَّذْرِ ، فَقَالَ : مَا کَانَ مِنْ نَذْرٍ ہُوَ فِی شَیْئٍ مِنْ طَاعَۃِ اللہِ فَأَمْضُوہُ ، وَمَا کَانَ مِنْ نَذْرٍ فِی شَیْئٍ مِنْ طَاعَۃِ الشَّیْطَانِ فَلاَ تُجِیزُوہُ۔",,,12276,,
12277,"حدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنِ الشَّعْبِیِّ ، عَنْ مَسْرُوقٍ ، قَالَ : النَّذْرُ نَذْرَانِ ، فَنَذْرُ اللہِ وَنَذْرُ الشَّیْطَانِ ، فَمَا کَانَ لِلَّہِ فَفِیہِ الْوَفَائُ وَالْکَفَّارَۃُ ، وَمَا کَانَ لِلشَّیْطَانِ فَلاَ وَفَائَ فِیہِ ، وَلاَ کَفَّارَۃَ۔",,,12277,,
12278,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ وَحَمَّادٌ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، قَالَ : النَّذْرُ نَذْرَانِ فَمَا کَانَ لِلَّہِ فَفِ بِہِ ، وَمَا کَانَ فِی مَعْصِیَۃٍ ، فَلاَ تَفِ بہ ، وَعَلَیْکَ الْکَفَّارَۃُ۔",,,12278,,
12279,"حدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ، عَن عِمَارَۃَ بْنِ الْقَعْقَاعِ، عَنْ إبْرَاہِیمَ، قَالَ: لاَ نَذْرَ فِی مَعْصِیَۃٍ ، کَفِّرْ یَمِینَک۔",,,12279,,
12280,"حدَّثَنَا أَبُو بَکْرٍ بْنُ عَیَّاشٍ ، عَنْ أَبِی حَصِینٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : جَائَ رَجُلٌ إلَی ابْنِ عَبَّاسٍ ، فَقَالَ : إنِّی نَذَرْت أَنْ أَقُومَ عَلَی قُعَیْقِعَانَ عُرْیَانًا إلَی اللَّیْلِ ، فَقَالَ : أَرَادَ الشَّیْطَانُ أَنْ یُبْدِیَ عَوْرَتَکَ ، وَأَنْ یَضْحَکَ النَّاسَ بِکَ ، الْبَسْ ثِیَابَک وَصَلِّ عِنْدَ الْحِجْرِ رَکْعَتَیْنِ۔",,,12280,,
12281,"حدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا أَبَانُ الْعَطَّارُ ، قَالَ : حدَّثَنَا یَحْیَی بْنُ أَبِی کَثِیرٍ ، عَنْ أَبِی قِلاَبَۃَ ، عَنْ ثَابِتِ بْنِ الضَّحَّاکِ الأَنْصَارِیِّ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لَیْسَ عَلَی رَجُلٍ نَذْرٌ فِیمَا لاَ یَمْلِکُ۔\n\n(بخاری 6047۔ مسلم 174)",,,12281,,
12282,"حدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ شُعْبَۃَ ، عَنْ ثَابِتٍ ، قَالَ : سَأَلْتُ ابْنَ عُمَرَ عَنْ نَذْرِ الْمَعْصِیَۃِ فِیہِ وَفَائٌ ؟ قَالَ : لاَ۔",,,12282,,
12283,"حدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ بَیَانٍ ، عَنْ قَیْسٍ ، قَالَ : دَخَلَ أَبُو بَکْرٍ عَلَی امْرَأَۃٍ مِنْ أَحْمَسَ مُصْمِتَۃٍ فِی خبائہا ، فَجَعَلَتْ تُشِیرُ إلَیْہِ ، وَلاَ تُکَلِّمُہُ ، فَقَالَ : مَا لَہَا لاَ تَتَکَلَّمُ ؟ فَقَالُوا : أَنَّہَا نَذَرَتْ أَنْ تَحُجَّ مُصْمِتَۃً ، فَقَالَ : تَکَلَّمِی فَإِنَّ ہَذَا لاَ یَحِلُّ لَکَ إنَّمَا ہَذَا مِنْ عَمَلِ الْجَاہِلِیَّۃِ۔",,,12283,,
12284,"شَبَابَۃُ بْنُ سَوَّارٍ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی الحویرثۃ ، أَوْ عَنِ أبی الْجُوَیْرِیَۃِ ، الشَّکُّ مِنْ أَبِی بَکْرٍ ، قَالَ : سَمِعْتُ عَبْدَ اللہِ بْنَ بَدْرٍ یَذْکُرُ عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لاَ نَذْرَ فِی مَعْصِیَۃٍ۔",,,12284,,
12285,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ أَبِی فَرْوَۃَ یَزِیدَ بْنِ سِنَانٍ ، عَنْ عُرْوَۃَ بْنِ رُوَیْمٍ ، عَنْ أَبِی ثَعْلَبَۃَ الْخُشَنِیِّ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لاَ وَفَائَ لِنَذْرٍ فِی مَعْصِیَۃٍ۔",,,12285,,
12286,"حدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ مَنْصُورٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ رضی اللَّہُ عَنْہُما ؛ فِی الرَّجُلِ یَحْلِفُ بِالنَّذْرِ وَالْحَرَامِ ، قَالَ : لَمْ یَأْلُ أَنْ یُغَلِّظَ عَلَی نَفْسِہِ ، یَعْتِقُ رَقَبَۃً ، أَوْ یَصُومُ شَہْرَیْنِ ، أَوْ یُطْعِمُ سِتِّینَ مِسْکِینًا ، قَالَ : فَسَأَلْت إبْرَاہِیمَ وَمُجَاہِدًا ، فَقَالا : إِنْ لَمْ یَجِدْ أَطْعَمَ عَشَرَۃَ مَسَاکِینَ۔",,,12286,,
12287,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، قَالَ : سَمِعْتُ ابْنَ الزُّبَیْرِ یَقُولُ : أَوْفُوا بِالنُّذُورِ۔",,,12287,,
12288,"حدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ مَعْمَرٍ ، عَنْ زَیْدِ بْنِ رُفَیْعٍ ، عَنْ أَبِی عُبَیْدَۃَ ، عَنْ عَبْدِ اللہِ ، قَالَ : لاَ وَفَائَ لِنَذْرٍ فِی مَعْصِیَۃِ اللہِ ، وَکَفَّارَتُہُ کَفَّارَۃُ یَمِینٍ۔",,,12288,,
12289,"حدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ یَزِیدَ الدَّالاَنِیِّ ، عَنْ أَبِی سُفْیَانَ ، عَنْ جَابِرٍ ، قَالَ : کفاریہ کَفَّارَۃُ یَمِینٍ۔",,,12289,,
12290,"حدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : سُئِلَ عَنْ رَجُلٍ نَذَرَ أَنْ لاَ یَدْخُلَ عَلَی أُخْتِہِ أَوْ أَخِیہِ ، فَقَالَ : یَدْخُلُ وَیَتَصَدَّقُ عَلَی عَشَرَۃِ مَسَاکِینَ۔",,,12290,,
12291,"حدَّثَنَا وَکِیعٌ ، عَنْ مُوسَی الْمُعَلِّمِ ، عَنْ جَابِرِ بْنِ زَیْدٍ ، قَالَ : النَّذْرُ یَمِینٌ۔",,,12291,,
12292,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ : النَّذْرُ یَمِینٌ۔",,,12292,,
12293,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، وَوَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : إنَّ قَوْمًا یَقُولُونَ : النَّذْرُ یَمِینٌ مُغَلَّظَۃٌ ، إنَّمَا ہِیَ یَمِینٌ یُکَفِّرُہَا۔",,,12293,,
12294,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، قَالَ : النَّذْرُ یَمِینٌ۔",,,12294,,
12295,"حدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ مُحَمَّدٍ الْحَنْظَلِیِّ ، عَنْ أَبِیہِ ، عَنْ عِمْرَانَ بْنِ الْحُصَیْنِ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ وَفَائَ لنذر فِی غَضَبٍ ، وَکَفَّارَتُہُ کَفَّارَۃُ یَمِینٍ۔ (طیالسی 839)",,,12295,,
12296,حدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ مُحَمَّدِ بْنُ الزبیر الحنظلی ، عَنْ عِمْرَانَ بْنِ الحُصَیْنِ مِثْلَہُ۔,,,12296,,
12297,"حدَّثَنَا مُعْتَمِرٌ قُلْتُ لِابْنِ الزُّبَیْرِ: حَدَّثَکَہُ مَنْ سَمِعَہُ مِنْ عِمْرَانَ، قَالَ: لاَ وَلَکِنْ حَدَّثَنِیہِ رَجُلٌ، عَنْ عِمْرَانَ۔",,,12297,,
12298,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مِسعَر ، عَنْ أَبِی حَصِینٍ ، عَنْ عَبْدِ اللہِ بْنِ معقل ، قَالَ : النَّذْرُ الْیَمِینُ الْغَلْظَائُ۔",,,12298,,
12299,"حدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ أَشْعَثَ عن سَوَّارٍ ، عَنِ الْحَسَنِ ، قَالَ : کَفَّارَۃُ النَّذْرِ إذَا کَانَ فِی مَعْصِیَۃٍ ، إطْعَامُ عَشَرَۃِ مَسَاکِینَ۔",,,12299,,
12300,"عَبْدُ الرَّحِیمِ ، عَنْ أَشْعَثَ بْنِ سَوَّارٍ ، عَنْ طَلْحَۃَ الْیَامِیِّ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : مَنْ حَلَفَ بِنَذْرٍ عَلَی یَمِینٍ فَحَنِثَ ، فَعَلَیْہِ کَفَّارَۃُ یَمِینٍ مُغَلَّظَۃٌ۔",,,12300,,
12301,"حدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ دَاوُدَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : إذَا قَالَ الرَّجُلُ : عَلَیَّ نَذْرٌ : فَلَمْ یَمْضِ بِالْیَمِینِ فَسَکَتَ ، فَعَلَیْہِ نَذْرٌ۔",,,12301,,
12302,"حدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، عَنْ قَیْسٍ ، قَالَ : النَّذْرُ شَیْئٌ یُسْتَخْرَجُ بِہِ مِنَ الْبَخِیلِ۔",,,12302,,
12303,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : قَالَ ابْنُ عَبَّاسٍ : النَّذْرُ یَمِینٌ مُغَلَّظَۃٌ۔",,,12303,,
12304,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَطَائٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : النَّذْرُ إذَا لَمْ یُسَمَّ أَغْلَظُ الْیَمِینِ ، وَعَلَیْہِ أَغْلَظُ الْکَفَّارَات۔",,,12304,,
12305,"حدَّثَنَا ابْنِ فُضَیْلٍ ، عَنْ لَیث ، عَنِ الْحَکَمِ ، عَنِ ابْنِ معقل ، عَنْ عَبْدِ اللہِ بْنِ مَسْعُودٍ ، قَالَ : مَنْ جَعَلَ لِلَّہِ عَلَیْہِ نَذْرًا لَمْ یُسَمِّ ، فَعَلَیْہِ نَسَمَۃٌ۔",,,12305,,
12306,"حدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : إذَا قَالَ : عَلَیَّ نَذْرٌ ، وَلَمْ یُسَمِّہِ ، فَعَلَیْہِ کَفَّارَۃُ التی تلیہ ثم التی تلیہ ثم التی تلیہ۔",,,12306,,
12307,"حدَّثَنَا أَبُو بَکْرٍ بْنُ عَیَّاشٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَفَّارَۃُ النَّذْرِ غَیْرُ الْمُسَمَّی ، کَفَّارَۃُ الْیَمِینِ۔",,,12307,,
12308,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ، عَنْ دَاوُدَ بْنِ أَبِی ہِنْدٍ ، عَنِ ابْنِ الْمُسَیَّبِ ، قَالَ: إذَا قَالَ: عَلَیَّ نَذْرٌ فَعَلَیْہِ نَذْرٌ",,,12308,,
12309,"قَالَ جَابِرُ بْنُ زَیْدٍ : إذَا قَالَ : عَلَیَّ نَذْرٌ ، فَإِنْ سَمَّی فَہُوَ مَا سَمَّی وَإِنْ نَوَی فہو مَا نَوَی ، فَإِنْ لَمْ یَکُنْ سَمَّی شَیْئًا صَامَ یَوْمًا ، أَوْ صَلَّی رَکْعَتَیْنِ۔",,,12309,,
12310,"حدَّثَنَا عَبْدَۃُ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إِذَا قَالَ عَلَیَّ نَذْرٌ ، وَلَمْ یُسَمِّ ، فَہِیَ یَمِینٌ مُغَلَّظَۃٌ ، یُحَرِّرُ رَقَبَۃً ، أَوْ یَصُومُ شَہْرَیْنِ ، أَوْ یُطْعِمُ سِتِّینَ مِسْکِینًا ، قَالَ : وَقَالَ الْحَسَنُ : ہِیَ یَمِینٌ یُکَفِّرُہَا۔",,,12310,,
12311,"حدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ رَافِعٍ ، عَنْ خَالِدِ بْنِ یَزِیدَ ، عَنْ عُقْبَۃَ بْنِ عَامِرٍ رضی اللَّہُ عَنْہُ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ نَذَرَ نَذْرًا فَلَمْ یُسَمِّہِ ، فَعَلَیْہِ کَفَّارَۃُ یَمِینٍ۔\n\n(مسلم 13۔ ابوداؤد 3316)",,,12311,,
12312,"حدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ وَحَمَّادٍ ، قَالَ : سَأَلْتُہمَا عَنْ رَجُلٍ جَعَلَ عَلَیْہِ نَذْرًا لَمْ یُسَمِّہِ ، قَالاَ: عَلَیْہِ الْکَفَّارَۃُ۔",,,12312,,
12313,"وَکِیعٌ ، عَنْ عَبْدِ اللہِ بْنِ سَعِیدِ بْنِ أَبِی ہِنْدٍ ، عَنْ بُکَیْرِ بْنِ عَبْدِ اللہِ بْنِ الأَشَجِّ ، عَنْ کُرَیْبٍ ، عَنِ ابْنِ عَبَّاسٍ رضی اللَّہُ عَنْہُما ، قَالَ : النُّذُورُ أَرْبَعَۃٌ : مَنْ نَذَرَ نَذْرًا لَمْ یُسَمِّہِ فَکَفَّارَتُہُ کَفَّارَۃُ یَمِینٍ ، وَمَنْ نَذَرَ فِی مَعْصِیَۃٍ ، فَکَفَّارَتُہُ کَفَّارَۃُ یَمِینٍ ، وَمَنْ نَذَرَ نَذْرًا فِیمَا لاَ یُطِیقُ ، فَکَفَّارَتُہُ کَفَّارَۃُ یَمِینٍ ، وَمَنْ نَذَرَ نَذْرًا فِیمَا یُطِیقُ ، فَلْیُوفِ بِنَذْرِہِ۔ (ابوداؤد 3315۔ دارقطنی 2)",,,12313,,
12314,"حدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ خُصَیْفٍ ، عَنْ عِکْرِمَۃَ فِی النَّذْرِ لاَ یُسَمِّی کَفَّارَۃً ، قَالَ : یَمِینٌ مُغَلَّظَۃٌ۔",,,12314,,
12315,"حدَّثَنَا وَکِیعُ بْنُ الْجَرَّاحِ ، عَنِ ابْنِ عَوْنٍ ، عَنْ زِیَادِ بْنِ جُبَیْرٍ ، قَالَ : جَائَ رَجُلٌ إلَی ابْنِ عُمَرَ ، فَسَأَلَہُ ، عَنْ رَجُلٍ نَذَرَ أَنْ یَصُومَ یَوْمًا فَوَافَقَ یَوْمَ فِطْرٍ ، أَوْ أَضْحَی ، فَقَالَ ابْنُ عُمَرَ : أَمَرَ اللَّہُ وَفَائَ النَّذْرِ ، وَنَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، عَنْ صَوْمِ ہَذَا الْیَوْمِ۔",,,12315,,
12316,"حدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ نَذَرَ أَنْ یَصُومَ یوم الاِثْنَیْنِ وَالْخَمِیسَ ، فَأَتَی عَلَی ذَلِکَ یَوْمُ فِطْرٍ ، أَوْ أَضْحَی ، قَالَ : یُفْطِرُ وَیَصُومُ یَوْمًا مَکَانَہُ۔",,,12316,,
12317,"حدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ ِإِبْرَاہِیمَ قَالَ : یَصُومُ یَوْمًا مَکَانَہُ ، وَیُکَفِّرُ یَمِینَہُ۔",,,12317,,
12318,"حدَّثَنَا عُقْبَۃُ بْنُ خَالِدٍ السَّکُونِیُّ ، عَنْ شُعْبَۃَ ، عَنْ خَالَتِہِ ، أَنَّہَا جَعَلَتْ عَلَیْہَا أَنْ تصُومَ کُلَّ جُمُعَۃٍ فَوَافَقَ ذَلِکَ الْیَوْمُ یَوْمَ فِطْرٍ ، أَوْ أَضْحَی ، فَسَأَلَتْ جَابِرَ بْنَ زَیْدٍ ، فَقَالَ : أَطْعِمِی مِسْکِینًا۔",,,12318,,
12319,"حدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ وَحَمَّادًا ، عَنِ امْرَأَۃٍ نَذَرَتْ أَنْ تَصُومَ کُلَّ جُمُعَۃٍ فَوَافَقَ ذَلِکَ الْیَوْمُ یَوْمَ فِطْرٍ ، أَوْ أَضْحَی ، فَقَالاَ : تَقْضِی یَوْمًا مَکَانَہُ وَتُکَفِّرُہُ۔",,,12319,,
12320,"حدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ سُلَیْمَانَ بْنِ أَبِی دَاوُد ، قَالَ : سُئِلَ عَطَائُ بْنُ أَبِی رَبَاحٍ ، عَنْ رَجُلٍ جَعَلَ عَلَیْہِ صِیَامَ شَہْرَیْنِ مُتَتَابِعَیْنِ ، فَیُدْرِکُہُ أَضْحَی ، أَوْ فِطْرٌ ، فَقَالَ : یُفْطِرُ ، ثُمَّ یَبْنِی عَلَی صِیَامِہِ۔",,,12320,,
12321,"حدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ عَبْدِ اللہِ بْنِ سَلِمَۃَ ، عَنْ عَلِیٍّ ، قَالَ : کَفَّارَۃُ الْیَمِینِ إطْعَامُ عَشَرَۃِ مَسَاکِینَ ، کُلُّ مِسْکِینٍ نِصْفُ صَاعٍ۔",,,12321,,
12322,"حدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ وَأَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ حَجَّاجٍ عَنْ حَوْطٍ عَمَّنْ حَدَّثَہُ عَنْ عَائِشَۃَ قَالَتْ : إنَّا نُطْعِمُ نِصْفَ صَاعٍ مِنْ بُرٍّ ، أَوْ صَاعًا مِنْ تَمْرٍ فِی کَفَّارَۃِ الْیَمِینِ۔",,,12322,,
12323,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ الأَعْمَشِ ، عَنْ شَقِیقٍ ، عَنْ یَسَارِ بْنِ نُمَیْرٍ ، قَالَ : قَالَ لِی عُمَرُ : إنِّی أَحْلِفُ أَلاَّ أُعْطِی أَقْوَامًا شَیْئًا ، ثُمَّ یَبْدُو لِی فَأُعْطِیہِمْ ، فَإِذَا فَعَلْتُ ذَلِکَ فَأَطْعِمْ عَنِّی عَشَرَۃَ مَسَاکِینَ ، بَیْنَ کُلِّ مِسْکِینَیْنِ صَاعٌ مِنْ بُرٍّ ، أَوْ صَاعٌ مِنْ تَمْرٍ لِکُلِّ مِسْکِینٍ",,,12323,,
12324,"حدَّثَنَا عبد الرحیم بن سلیمان عَنْ سَعِیدِ ، عَنْ قَتَادَۃَ ، عن ابْنِ الْمُسَیَّبِ فِی کَفَّارَۃِ الْیَمِینِ ، قَالَ : مُدَّانِ لِکُلِّ مِسْکِینٍ۔",,,12324,,
12325,"حدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَفَّارَۃُ الْیَمِینِ وَالظِّہَارِ نِصْفُ صَاعٍ لِکُلِّ مِسْکِینٍ۔",,,12325,,
12326,"حدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : کل کَفَّارَۃ فِی ظِہَارٍ ، أَوْ غَیْرِہِ ، فَفِیہِ نِصْفُ صَاعٍ مِنْ بُرٍّ کَفَّارَتُہُ۔",,,12326,,
12327,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عَوْفٍ ، عَنْ مُحَمَّدٍ ، قَالَ : کَفَّارَۃُ الْیَمِینِ : مدان ، أَوْ أَکْلَۃٌ مَأْدُومَۃٌ۔",,,12327,,
12328,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : قُلْتُ : أَجْمَعُہُمْ ؟ قَالَ : لاَ ، أَعْطِہِمْ مُدًّین مُدًّا لِطَعَامِہِمْ وَمُدًّا لإِدَامِہِمْ۔",,,12328,,
12329,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ ، عَنْ أَبِی قِلاَبَۃَ ، أَنَّہُ قَالَ فِی إطْعَامِ الْمَسَاکِینِ فِی کَفَّارَۃِ الظِّہَارِ قَالَ : لِکُلِّ مِسْکِینٍ مُدُّ حِنْطَۃٍ وَمُدُّ تَمْرٍ۔",,,12329,,
12330,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، قَالَ : لِکُلِّ مِسْکِینٍ مُدًّا مِنْ حِنْطَۃٍ۔",,,12330,,
12331,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُثْمَانَ بْنِ غِیَاثٍ ، قَالَ : سَأَلْتُ جَابِرَ بْنَ زَیْدٍ عَنْ کَفَّارَۃِ الْیَمِینِ ، قَالَ : إطْعَامُ عَشَرَۃِ مَسَاکِینَ ، مَکُّوکٌ مَکُّوکٌ لِکُلِّ إنْسَانٍ۔",,,12331,,
12332,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنِ الشَّعْبِیِّ فِی کَفَّارَۃِ الْیَمِینِ : مَکُّوکٌ طَعَامُہُ وَمَکُّوکٌ إدَامُہُ۔",,,12332,,
12333,"حدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ طَلْحَۃَ ، عَنْ یَسَارِ بْنِ نُمَیْرٍ ، قَالَ: قَالَ: إنِّی أَلِی مِنْ أَمْرِ الْمُسْلِمِینَ، فَإِذَا رَأَیْتَنِی قَدْ حَلَفْتُ عَلَی یَمِینٍ لَمْ أُمْضِہَا ، فَأَطْعِمْ عَنِّی عَشَرَۃَ مَسَاکِینَ لِکُلِّ مِسْکِینٍ نِصْفُ صَاعٍ مِنْ بُرٍّ ، أَوْ صَاعٌ مِنْ شَعِیرٍ ، أَوْ صَاعٌ مِنْ تَمْرٍ۔",,,12333,,
12334,"حدَّثَنَا ابْنُ فُضَیْلٍ، وَابْنُ إدْرِیسَ، عَنْ دَاوُدَ، عَنْ عِکْرِمَۃَ، عَنِ ابْنِ عَبَّاسٍ فِی کَفَّارَۃِ الْیَمِینِ: مُدٌّ رَیْعُہُ إدَامُہُ۔",,,12334,,
12335,"حدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ أَبِی سَلَمَۃَ ، عَنْ زَیْدِ بْنِ ثَابِتٍ ، قَالَ : مُدٌّ مِنْ حِنْطَۃٍ لِکُلِّ مِسْکِینٍ۔",,,12335,,
12336,حدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ إذَا حَنِثَ أَطْعَمَ عَشَرَۃَ مَسَاکِینَ ، لِکُلِّ مِسْکِینٍ مُدٌّ مِنْ حِنْطَۃٍ بِالْمُدِّ الأَوَّلِ۔,,,12336,,
12337,"حدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : مُدٌّ۔",,,12337,,
12338,حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ وَیزِیْدُ بْنُ ہَارُونَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ ، قَالَ فِی کَفَّارَۃِ الْیَمِینِ مُدٌّ مِنْ بُرٍّ۔,,,12338,,
12339,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عُبَیْدِ اللہِ ، عَنِ الْقَاسِمِ وَسَالِمٍ فِی کَفَّارَۃِ الْیَمِینِ ، قَالاَ : مُدٌّ لِکُلِّ مِسْکِینٍ۔",,,12339,,
12340,"حدَّثَنَا عَبْدُ الْوَہَّابِ بْنُ عَطَائٍ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو، عَنْ أَبِی سَلَمَۃَ فِی إطْعَامِ الْمِسَاکِینِ: مُدٌّ مِنْ قَمْحٍ۔",,,12340,,
12341,"حدَّثَنَا حدَّثَنَا وَکِیعٌ ، عَنْ مَالِکِ بْنِ مِغْوَلٍ ، عَنْ عَطَائٍ ، قَالَ : مُدٌّ۔",,,12341,,
12342,"حدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : وَجْبَۃٌ وَاحِدَۃٌ۔",,,12342,,
12343,"حدَّثَنَا الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنِ ابْنِ سِیرِینَ ، أَنَّہُ قَالَ فِی کَفَّارَۃِ الْمَسَاکِینِ : یَجْمَعُہُمْ مَرَّۃً فَیُشْبِعُہُمْ۔",,,12343,,
12344,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ سَعِیدِ بْنِ یَزِیدَ أبی مَسْلَمَۃَ ، قَالَ : سَأَلْتُ جَابِرَ بْنَ زَیْدٍ ، عَنْ إطْعَامِ الْمِسْکِینِ فِی کَفَّارَۃِ الْیَمِینِ ، فَقَالَ : أَکْلَۃٌ ، قُلْتُ : إنَّ الْحَسَنَ یَقُولُ : مَکُّوکٌ ، فَقُلْت : مَا تَرَی فِی مَکُّوکِ بُرٍ ؟ فَقَالَ : إنَّ مَکُّوکَ بُرٍّ لاَ یُجْزِئُ۔",,,12344,,
12345,"حدَّثَنَا مُعْتَمِرٌ ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ، قَالَ فِی کَفَّارَۃِ الْیَمِینِ : یُطْعِمُ عَشَرَۃَ مَسَاکِینَ کَمَا قَالَ اللَّہُ تَعَالَی حَتَّی یُشْبِعَہُمْ۔",,,12345,,
12346,"حدَّثَنَا یَحْیَی بْنُ إِسْحَاقَ ، قَالَ : حدَّثَنِی یَحْیَی بْنُ أَیُّوبَ ، عَنْ حمید ؛ أَنَّ أَنَسًا مَرِضَ قَبْلَ أَنْ یَمُوتَ ، فَلَمْ یَسْتَطِعْ أَنْ یَصُومَ ، فَکَانَ یَجْمَعُ ثَلاَثِینَ مِسْکِینًا ، فَیُطْعِمُہُمْ خُبْزًا وَلَحْمًا أَکْلَۃً وَاحِدَۃً۔",,,12346,,
12347,"حدَّثَنَا مُعْتَمِرٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی کَفَّارَۃِ الْیَمِینِ ، فَقَالَ : یُطْعِمُ خُبْزًا وَلَحْمًا مَرَّۃً وَاحِدَۃً حَتَّی یُشْبِعَہُم۔",,,12347,,
12348,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، قَالَ : یُغَدِّیہِمْ وَیُعَشِّیہِمْ۔",,,12348,,
12349,"حدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ عَبْدِ الْعَزِیزِ ، عَنِ الشَّعْبِیِّ ، قَالَ : غَدَائٌ وَعَشَائٌ۔",,,12349,,
12350,"حدَّثَنَا غُنْدَرٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : لِامْرَأَۃٍ أَنْتِ عَلَیَّ کَظَہْرِ امْرَأَۃِ فُلاَنٍ ، فَلَیْسَ بِشَیْئٍ۔",,,12350,,
12351,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حبیب ، عَنْ عَمْرِو بْنِ ہرْمٍ ، قَالَ : سُئِلَ جَابِرُ بْنُ زَیْدٍ عَنْ رَجُلٍ ، قَالَ : لِامْرَأَتِہِ : أَنْتِ عَلَیَّ کَبَطْنِ أُمِّی ، قَالَ : الْبَطْنُ وَالظَّہْرُ بِمَنْزِلَۃٍ وَاحِدَۃٍ فِی الظِّہار۔",,,12351,,
12352,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : سَأَلْتُہ ، عَنِ امْرَأَۃٍ ثَقِیلَۃِ الرَّأْسِ نَامَتْ وَمَعَہَا ابْنُہَا فَأَصْبَحَ مَیِّتًا ، قَالَ : أَطْیَبُ لِنَفْسِہَا أَنْ تُکَفِّرَ بِعِتْقِ رَقَبَۃٍ ، أَوْ تَصُومَ شَہْرَیْنِ مُتَتَابِعَیْنِ قُلْتُ : فَإِنْ حَاضَتْ قَالَ : ذَلِکَ مَا لاَ بُدَّ لِلنِّسَائِ مِنْہُ تَقْضِی أَیَّامَ حَیْضِہَا إذَا فَرَغَتْ۔",,,12352,,
12353,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : إذَا قَتَلَتِ الْمَرْأَۃُ نَفْسًا خَطَأً فَصَامَتْ ، ثُمَّ حَاضَتْ قَضَتْ یَوْمًا مَکَانَہُ۔",,,12353,,
12354,"حدَّثَنَا أَبُو عَبْدِ الرَّحْمَنِ الْمُقْرِی ، قَالَ : حدَّثَنَا سَعِیدُ بْنُ أَبِی أَیُّوبَ ، قَالَ : حدَّثَنَا یَزِیدُ بْنُ أَبِی حَبِیبٍ ، عَنِ ابْنِ شِہَابٍ ، عَنِ ابْنِ الْمُسَیَّبِ ، قَالَ : أَمَّا الْمَرْأَۃُ فَتَصُومُ ، فَإِذَا حَاضَتْ تُتِمُّ مَا بَقِیَ۔",,,12354,,
12355,"حدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ فِی امْرَأَۃٍ جَعَلَتْ عَلَیْہَا أَنْ تَعْتَکِفَ فَأَدْرَکَہَا الْحَیْضُ ، قَال : تَقْضِی مَا حَاضَتْ مِنْ عِدَّۃِ أَیَّامٍ أُخَر۔",,,12355,,
12356,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا صَامَتِ الْمَرْأَۃُ فِی کَفَّارَۃِ الْیَمِینِ ثَلاَثَۃَ أَیَّامٍ ، فَحَاضَتْ قَبْلَ أَنْ تُتِمَّ صَوْمَہَا فَلْتَسْتَقْبِلْ صَوْمَ ثَلاَثَۃِ أَیَّامٍ۔",,,12356,,
12357,"حدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ حَلَفَ بِسُورَۃٍ مِنَ الْقُرْآنِ فَعَلَیْہِ بِکُلِّ آیَۃٍ مِنْہَا یَمِینُ صَبْرٍ ، فَمَنْ شَائَ بَرَّ وَمَنْ شَائَ فَجَرَ۔",,,12357,,
12358,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ عَبْدِ اللہِ ، عَنْ أَبِی کَنَفٍ ، قَالَ : کُنْتُ أَمْشِی مَعَ عَبْدِ اللہِ فِی سُوقِ الرقِق فَسَمِعَ رَجُلاً یَحْلِفُ : کَلاَّ وَسُورَۃِ الْبَقَرَۃِ ، فَقَالَ عَبْدُ اللہِ : أَمَا إنَّ عَلَیْہِ بِکُلِّ آیَۃٍ مِنْہَا یَمِین۔",,,12358,,
12359,"حدَّثَنَا ابْنُ فُضَیْلٍ ، وَوَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی سِنَانٍ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی الْہُذَیْلِ ، عَنْ عَبْدِ اللہِ بْنِ حَنظَلَۃَ ، عَنْ عَبْدِ اللہِ قَالَ : مَنْ حَلَفَ بِسُورَۃٍ مِنَ الْقُرْآنِ فَعَلَیْہِ بِکُلِّ آیَۃٍ مِنْہَا یَمِین۔",,,12359,,
12360,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَبِی سِنَانٍ ، عَنْ سَہل بْنِ مِنْجَابٍ قَالَ : مَنْ حَلَفَ بِسُورَۃٍ مِنَ الْقُرْآنِ لَقِیَ اللَّہَ بِعَدَدِ آیِہَا خَطَایَا۔",,,12360,,
12361,"حدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : مَنْ حَلَفَ بِسُورَۃٍ مِنَ الْقُرْآنِ فَعَلَیْہِ بِکُلِّ آیَۃٍ مِنْہَا یَمِینٌ ، وَمَنْ کَفَرَ بِآیَۃٍ مِنْہُ کَفَرَ بِہِ کُلِّہِ۔",,,12361,,
12362,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : قَالَ عَبْدُ اللہِ : مَنْ حَلَفَ بِالْقُرْآنِ فَعَلَیْہِ بِکُلِّ آیَۃٍ یَمِینٌ۔",,,12362,,
12363,"حدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ کَانَ یَقُولُ : مَنْ کَانَتْ عَلَیْہِ رَقَبَۃٌ ، فَاشْتَرَی نَسَمَۃً ، قَالَ : إذَا أَنْفَذَہَا مِنْ عَمَلٍ إلَی عَمَلٍ أَجْزَأَہُ ، وَلاَ یُجْزِئہ مَنْ لاَ یَعْمَلُ فَأَمَّا الَّذِی یَعْمَلُ فَالأَعْوَرُ وَنَحْوُہُ ، وَأَمَّا الَّذِی لاَ یَعْمَلُ فَالأَعْمَی وَالْمُقْعَدُ۔",,,12363,,
12364,"حدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ : أَنَّہُ کَانَ یَکْرَہُ الأَعْرَجَ وَالْمُخَبَّلَ فِی الرَّقَبَۃِ الْوَاجِبَۃِ۔",,,12364,,
12365,"حدَّثَنَا مُحَمَّدُ بْنُ مَرْوَانَ ، عَنْ عُمَارَۃَ ، عَنْ عِکْرِمَۃَ ، قَالَ : سَأَلَہُ رَجُلٌ أَیُجْزِئُ فِی عِتْقِ الرَّقَبَۃِ الْوَاجِبَۃِ الأَعْوَرُ ؟ فَقَالَ : رُبَّ أَعْوَرَ ثُمَّ ثم دَارَ فَقَالَ : یُجْزِئُ الأَعْرَجَ قَالَ : فَقَالَ : السَّاعَۃ تجیء بِالْمُقْعَدِ۔",,,12365,,
12366,"حدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : یُجْزِئُ الأَعْوَرُ۔",,,12366,,
12367,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، قَالَ : الْمَجْنُونُ لاَ یُجْزِئُ فِی الَّذِی عَلَیْہِ الرَّقَبَۃُ۔",,,12367,,
12368,"حدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : أَیَجُوزُ فِی قَتْلِ النَّفْسِ رَقَبَۃٌ مُؤْمِنَۃٌ غَیْرُ سَوِیَّۃٍ وَہُوَ یَنْتَفِعُ بِہَا أَعْرَجُ ، أَوْ أَشَلُّ ؟ فَأَبَی وَاسْتَحَبَّ السَّوِیَّۃَ۔",,,12368,,
12369,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : یُجْزِئُ الأَعْمَی فِی الْکَفَّارَۃِ۔",,,12369,,
12370,"حدَّثَنَا حَفْصٌ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ، قَالَ : سَأَلْتُہ عَنِ الأَعْمَی وَالْمُقْعَدِ ، فَقَالَ : لاَ یُجْزِئُ۔",,,12370,,
12371,"حدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ وَالشَّعْبِیِّ أَنَّہُمَا قَالاَ : لاَ یُجْزِئُ فِی شَیْئٍ مِنَ الْوَاجِبِ وَلَدُ الزِّنَا۔",,,12371,,
12372,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، قَالَ : تُوُفِّیَ رَجُلٌ مِنْ أَہْلِی فَأَوْصَی بِنَسَمَۃٍ ، فَوَجَدْت نَسَمَۃً قَدْ تَزَوَّجَ أَبُوہُ أُمَّہُ بِغَیْرِ إذْنِ مَوْلاَہُ ، فَسَأَلْت عَطَائً ، فَقَالَ : أَکْرَہُ ذَلِکَ۔",,,12372,,
12373,"حدَّثَنَا ہُشَیْمٌ ، عَنْ فُلانِ بن عَمْرٍو قَالَ : سَأَلْتُ أَبَا جَعْفَرٍ ، عَنْ عِتْقِ وَلَدِ الزِّنَا فِی کَفَّارَۃِ الْیَمِینِ ، فَقَالَ: یُجْزِئُ۔",,,12373,,
12374,"حدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، أَنَّہُ کَانَ یَقُولُ : یُجْزِئُ فِی الْوَاجِبِ ، وَلاَ یَفْضُلُہُ الَّذِی لرِشدۃٍ إلاَّ بِتَقْوًی۔",,,12374,,
12375,"حدَّثَنَا وَکِیعٌ ، وَابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ طَاوُوسٍ ، قَالَ : یُجْزِئُ وَلَدُ الزِّنَا فِی الرَّقَبَۃِ۔",,,12375,,
12376,"حدَّثَنَا أَبُو بَکْرٍ بْنُ عَیَّاشٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ یُجْزِئُ مِنَ الرَّقَبَۃِ الْوَاجِبَۃِ۔",,,12376,,
12377,"حدَّثَنَا حَفْصٌ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، وَعَبْدُ اللہِ بْنُ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ أَبِی سَعِیدٍ : أَتَتِ امْرَأَۃٌ أَبَا ہُرَیْرَۃَ ، فَسَأَلَتْہُ عَنِ ابْنِ جَارِیَۃٍ لَہَا مِنْ غَیْرِ رِشْدَۃٍ وَعَلَیْہَا رَقَبَۃٌ ، أَیُجْزِئُہَا ؟ قَالَ : نَعَمْ۔",,,12377,,
12378,حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، أَنَّہُ کَانَ لاَ یَرَی عِتْقَ الْکَافِرِ فِی شَیْئٍ مِنَ الْکَفَّارَاتِ۔,,,12378,,
12379,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ طَاوُوسٍ ، قَالَ : یُجْزِئُ الْیَہُودِیُّ وَالنَّصْرَانِیُّ فِی کَفَّارَۃِ الْیَمِینِ",,,12379,,
12380,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ یُجْزِئُ عِتْقُ أَہْلِ الْکُفْرِ",,,12380,,
12381,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ یُجْزِئُ الْیَہُودِیُّ وَالنَّصْرَانِیُّ فِی الرَّقَبَۃِ الْوَاجِبَۃِ۔",,,12381,,
12382,حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، أَنَّہُ کَانَ یَرَی عِتْقَ الْمُدَبَّرِ فِی الْکَفَّارَاتِ کُلِّہا۔,,,12382,,
12383,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنْ طَاوُوس : قَالَ : یُجْزِئُ عِتْقُ الْمُدَبَّرِ فِی الْکَفَّارَۃِ۔",,,12383,,
12384,"حدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : تُجْزِئُ الْمُدَبَّرَۃ۔",,,12384,,
12385,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : لاَ یُجْزِئُ الْمُعْتَقُ عَنْ دُبُرِ فِی الْکَفَّارَۃِ۔",,,12385,,
12386,"حدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ مُہَاجِرِ بْنِ شَمَّاسٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : أَمَّا الْمُدَبَّرَۃُ فَلاَ تُجْزِئُ۔",,,12386,,
12387,"حدَّثَنَا وَکِیعٌ ، عَنْ عُمَرَ بْنِ بَشِیرٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : لاَ یُجْزِئُ الْمُدَبَّرُ۔",,,12387,,
12388,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ أَبِی حَنِیفَۃَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ قَالَ : أَمَّا الْمُدَبَّرُ فَلاَ یُجْزِئُ۔",,,12388,,
12389,"حدَّثَنَا إسْمَاعِیلُ بْنُ إِبْرَاہِیمَ ، عَن لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ : تُجْزِئُ أُمُّ الْوَلَدِ فِی الظِّہَارِ۔",,,12389,,
12390,"حدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ مُہَاجِرِ بْنِ شَمَّاسٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : تُجْزِئُ أُمُّ الْوَلَدِ فِی الظِّہَارِ۔",,,12390,,
12391,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : تُجْزِئُ فِی الظِّہَارِ۔",,,12391,,
12392,حدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ یُونُسَ ، عَنِ ہِشَامٍ,,,12392,,
12393,"وابْنُ إدْرِیسَ، عَنْ ہِشَامٍ، عَنِ الْحَسَنِ، وعَنْ اللَیْثٍ، عَنْ طَاوُوسٍ، قَالَ: لاَ تُجْزِئُ أُمُّ الْوَلَدِ فِی الظِّہَارِ۔",,,12393,,
12394,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : لاَ تُجْزِئُ أُمُّ الْوَلَدِ فِی الْکَفَّارَۃِ۔",,,12394,,
12395,"حدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : لاَ تُجْزِئُ أُمُّ الْوَلَدِ فِی الظِّہَارِ۔",,,12395,,
12396,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : کَانَ لاَ یَرَی عِتْقَ أُمِّ الْوَلَدِ فِی شَیْئٍ مِنَ الْکَفَّارَاتِ۔",,,12396,,
12397,"حدَّثَنَا أَبُو قطَن ، عَنْ شُعْبَۃَ ، عَنْ حَمَّادٍ فِی أُمِّ الْوَلَدِ فِی کَفَّارَۃِ الظِّہَارِ ، قَالَ : لاَ تُجْزِئہ ، وَقَالَ : الْحَکَمُ: غَیْرُہَا أَحَبُّ إلَیَّ مِنْہَا ، وَأَرْجُو۔",,,12397,,
12398,"حدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ وَالشَّعْبِیِّ ، قَالاَ : لاَ تُجْزِئُ أُمُّ الْوَلَدِ مِنَ الرَّقَبَۃِ۔",,,12398,,
12399,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، عَنْ عَلِیٍّ ، قَالَ : تُجْزِئُ أُمُّ الْوَلَدِ مِنَ الرَّقَبَۃِ۔",,,12399,,
12400,"حدَّثَنَا عُمَرُ بْنُ أَیُّوبَ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنْ مَیْمُونٍ ، أَنَّ رَجُلاً کَانَ عَلَیْہِ نَسَمَۃٌ فَأَرَادَ أَنْ یُعْتِقَ وَلَدَ مُکَاتَبَۃٍ لَہُمْ ، فَقَالَ : لاَ أَعْتِقْ غَیْرَہُ۔",,,12400,,
12401,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ أَبِی حَنِیفَۃَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ یُجْزِئُ فِی ألظِّہَارِ ، وَلاَ التَّحْرِیرِ ، وَلاَ الْقَتْلِ وَلَدُ مُکَاتَبَۃٍ۔",,,12401,,
12402,"حدَّثَنَا ہُشَیْمُ بْنُ بَشِیرٍ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، وَمُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، وَحَجَّاجٍ ، عَنْ عَطَائٍ ، أَنَّہُمْ قَالُوا : فِیمَنْ أَصَابَ جَنِینًا : إنَّ عَلَیْہِ عِتْقَ رَقَبَۃٍ مَعَ الْغُرَّۃِ۔",,,12402,,
12403,"غُنْدَرٌ، عَنْ شُعْبَۃَ، عَنِ الْحَکَمِ، قَالَ: سَمِعْتُہُ یَقُولُ: إذَا ضُرِبَتِ الْمَرْأَۃُ وَأَلْقَتْ جَنِینًا، قَالَ: صَاحِبُہُ یُعْتِقُ۔",,,12403,,
12404,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، وَوَکِیعٌ ، عَنْ عُمَر بْنِ ذَرٍّ ، عَنْ مُجَاہِدٍ : أَنَّ رَجُلاً مَسَحَ بَطْنَ امْرَأَۃٍ ، فَأَلْقَتْ جَنِینًا ، فَأَمَرَہُ عُمَرُ بْنُ الْخَطَّابِ أَنْ یُعْتِقَ۔",,,12404,,
12405,"عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ عَلَیْہِ إطْعَامُ مَسَاکِینَ فِی کَفَّارَۃِ الظِّہَارِ فَأَطْعَمَ عَشَرَۃً، ثُمَّ أَرَادَ أَنْ یُعِیدَ عَلَیْہِمْ حَتَّی یَسْتَکْمِلَ ، قَالَ : لاَ ، حَتَّی یُطْعِمَ سِتِّینَ مِسْکِینًا۔",,,12405,,
12406,حدَّثَنَا مُحَمَّدُ بْنُ عُبَیْدٍ ، عَنْ یَعْقُوبَ ، عَنْ قَیْسٍ ، عَنِ الشَّعْبِیِّ بِنَحْوِہِ۔,,,12406,,
12407,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ ، عَنْ أَبِیہِ ، قَالَ سَمِعَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عُمَرَ وہو یَقُولُ : وَأَبِی وَأَبِی ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ اللَّہَ یَنْہَاکُمْ أَنْ تَحْلِفُوا بِآبَائِکُمْ ، فَقَالَ : عُمَرُ : وَاللَّہِ لاَ حَلَفْت بِہَا لاَ ذَاکِرًا ، وَلاَ آثِرًا۔ (بخاری 6647۔ مسلم 2)",,,12407,,
12408,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ إسْمَاعِیلَ بْنِ أُمَیَّۃَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : أَدْرَکَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عُمَرَ فِی بَعْضِ أَسْفَارِہِ وَہُوَ یَقُولُ : وَأَبِی ، وَأَبِی ، فَقَالَ : إنَّ اللَّہَ یَنْہَاکُمْ أَنْ تَحْلِفُوا بِآبَائِکُمْ ، مَنْ حَلَفَ فَلْیَحْلِفْ بِاللَّہِ ، أَوْ لِیَسْکُتْ۔ (ابوداؤد 3244۔ ترمذی 1534)",,,12408,,
12409,"عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ سَمُرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تَحْلِفُوا بِآبَائِکُمْ ، وَلاَ بِالطَّوَاغِیتِ۔ (مسلم 6۔ احمد 5/62)",,,12409,,
12410,"حدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ سِمَاکٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : قَالَ عُمَرُ : حَدَّثْت قَوْمًا حَدِیثًا ، فَقُلْت : لاَ وَأَبِی ، فَقَالَ رَجُلٌ مِنْ خَلْفِی : لاَ تَحْلِفُوا بِآبَائِکُمْ ، قَالَ : فَالْتَفَتُّ ، فَإِذَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : لَوْ أَنَّ أَحَدَکُمْ حَلَفَ بِالْمَسِیحِ لَہَلَکَ ، وَالْمَسِیحُ خَیْرٌ مِنْ آبَائِکُمْ۔ (عبدالرزاق 15925)",,,12410,,
12411,"حدَّثَنَا عَمْرُو بْنُ طَلْحَۃَ ، عَنْ أَسْبَاطِ بْنِ نَصْرٍ ، عَنْ سِمَاکٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، عَنْ عُمَرَ ، أَنَّہُ قَالَ : حلَفْت بِأَبِی ، فَإِذَا رَجُلٌ مِنْ خَلْفِی یَقُولُ : لاَ تَحْلِفُوا بِآبَائِکُمْ ، فَالْتَفَتُّ فَإِذَا ہُوَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔ (احمد 19)",,,12411,,
12412,"حدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ سَعْدِ بْنِ عُبَیْدَۃَ ، قَالَ : کُنَّا مَعَ ابن عُمَرَ فِی حَلْقَۃٍ ، فَسَمِعَ رَجُلاً یَقُول : لاَ ، وَأَبِی ، فَرَمَاہُ بِالْحَصَی ، وَقَالَ : إِنَّہَا کَانَتْ یَمِین عمر ، فَنَہَاہ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْہَا، وَقَالَ : إِنَّہَا شِرْکٌ۔ (احمد 2/58۔ طحاوی 825)",,,12412,,
12413,"حدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ مَیْسَرَۃَ ، عَنِ الحسن بْنِ مُحَمَّدٍ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لیس منا مَنْ حَلَفَ بِغَیْر اللہِ ، أو قَالَ بِغَیْر الإسلام۔",,,12413,,
12414,"حدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ وَبَرۃَ ، قَالَ : قَالَ عَبْدُ اللہِ : لأَنْ أَحْلِفَ بِاللَّہِ کَاذِبًا أَحَبُّ إلَیَّ مِنْ أَنْ أَحْلِفَ بِغَیْرِہِ وَأَنَا صَادِقٌ۔",,,12414,,
12415,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : مَرَّ عُمَرُ بِالزُّبَیْرِ وَہُوَ یَقُولُ : لاَ وَالْکَعْبَۃِ ، فَرَفَعَ عَلَیْہِ الدِّرَّۃَ ، وَقَالَ : الْکَعْبَۃُ لاَ أُمَّ لَکَ تُطْعِمُک وَتَسْقِیک؟۔",,,12415,,
12416,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الْعَلاَئِ بْنِ الْمُسَیَّبِ ، عَنْ أَبِیہِ ، قَالَ : قَالَ کَعْبٌ : إنَّکُمْ تُشْرِکُونَ ، قَالُوا : وَکَیْفَ یَا أَبَا إِسْحَاقَ ؟ قَالَ : یَحْلِف الرَّجُلُ لاَ وَأَبِی ، لاَ وَأَبِیک ، لاَ لَعَمْرِی ، لاَ وَحَیَاتِکَ ، لاَ وَحُرْمَۃِ الْمَسْجِدِ ، لاَ وَالإِسْلاَمِ ، وَأَشْبَاہِہِ مِنَ الْقَوْلِ۔",,,12416,,
12417,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : لَقَدْ أَدْرَکْت النَّاسَ ، وَلَوْ أَنَّ رَجُلاً رَکِبَ رَاحِلَتَہُ لاَنْضَاہَا قَبْل أَنْ یَسْمَعَ رَجُلاً یَحْلِفُ بِغَیْرِ اللہِ۔",,,12417,,
12418,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ ابْنِ عَوْنٍ ، عَنِ الحسن ، قَالَ : لاَ تَحْلِفُوا بِآبَائِکُمْ ، وَلاَ بِالطَّوَاغِیتِ۔",,,12418,,
12419,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ أَبِی عَوَانَۃَ ، عَنْ إسْمَاعِیلَ بْنِ ہِشَامٍ ، عَنِ الْقَاسِمِ بْنِ مُخَیْمِرَۃَ ، قَالَ : مَا أُبَالِی حَلَفْت بِحَیَاۃِ رَجُلٍ ، أَوْ بِالصَّلیبِ۔",,,12419,,
12420,"حدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ کَرِہَ أَنْ یَقُولَ : لاَ وَحَیَاتِک۔",,,12420,,
12421,"حدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنْ مَیْمُونٍ ، قَالَ : سَمِعْتُہُ یَقُولُ : إنَّ اللَّہَ تَعَالَی یُقْسِمُ بِمَا شَائَ مِنْ خَلْقِہِ ، وَلَیْسَ لأَحَدٍ أَنْ یُقْسِمَ إلاَّ بِاللَّہِ ، وَمَنْ أَقْسَمَ باللہ فَلاَ یَکْذِبُ۔",,,12421,,
12422,"حدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ ، قَالَ : حدَّثَنَا عَبْدُ اللہِ بْنُ جَعْفَرٍ ، عَنْ أُمِّ بَکْرٍ بِنْتِ الْمِسْوَرِ ، أَنَّ الْمِسْوَرَ سَمِعَ ابْنًا لَہُ وَہُوَ یَقُولُ : أَشْرَکْت بِاَللَّہِ ، أَوْ کَفَرْت بِاللَّہِ فَضَرَبَہُ ، ثُمَّ قَالَ : قُلْ : اَسْتَغْفِرُ اللَّہَ آمَنْت بِاللَّہِ ، ثَلاَثًا۔",,,12422,,
12423,"حدَّثَنَا عُبَیْدُ اللہِ ، قَالَ أَخْبَرَنَا إسْرَائِیلُ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ مُصْعَبِ بْنِ سَعْدٍ ، عَنْ أبِیہِ ، أَنَّہُ قَالَ : حَلَفْت بِاللاَّتِ وَالْعُزَّی ، فَأَتَیْت النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقُلْت : إنِّی حَلَفْت بِاللاَّتِ وَالْعُزَّی ، قَالَ : قُلْ : لاَ إلَہَ إلاَّ اللَّہُ ، ثَلاَثًا ، وَانْفُثْ عَنْ شِمَالِکَ ثَلاَثًا ، وَتَعَوَّذْ بِاللَّہِ مِنَ الشَّیْطَانِ ، ثُمَّ لاَ تَعُدْ۔\n\n(ابن ماجہ 2097۔ احمد 186)",,,12423,,
12424,"حدَّثَنَا ابْنُ عُلَیَّۃَ، عَنْ عُیَیْنَۃَ بْنِ عَبْدِالرَّحْمَنِ، عَنْ أَبِیہِ، قَالَ: کَانَتْ یَمِینُ عُثْمَانَ بْنِ أَبِی الْعَاصِ: لَعَمْرِی۔",,,12424,,
12425,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : نبئت أن أَبَا السَّوَّارِ الْعَدَوِیَّ ، قَالَ : إذَا سَمِعْتُمُونِی أقول : لاَہَا اللہِ إذًا ، أوْ لَعَمْرِی ، فَذَکِّرُونِی۔",,,12425,,
12426,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : إذَا قَالَ الرَّجُلُ : لَعَمْرِی لاَ أَفْعَلُ کَذَا کَذَا ، إِنْ حَنِثَ فَعَلَیْہِ الْکَفَّارَۃُ۔",,,12426,,
12427,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : لَعَمْرِی لَغْوٌ۔",,,12427,,
12428,"حدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ کَرِہَ أَنْ یَقُولَ : لَعَمْرِی۔",,,12428,,
12429,"حدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنِ الْعَلاَئِ ، عَنْ أَبِیہِ ، قَالَ : قَالَ کَعْبٌ : إنَّکُمْ تُشْرِکُونَ ، قَالُوا : وَکَیْفَ یَا أَبَا إِسْحَاقَ ؟ قَالَ : یَقُولُ أَحَدُکُمْ : لاَ ولَعَمْرِی ، لاَ وَحَیَاتِک۔",,,12429,,
12430,"حدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا قِیلَ لِلرَّجُلِ حَلَفْت أن لاَ تَفْعَلْ کَذَا وَکَذَا ؟ فَیَقُولُ : نَعَمْ ، وَلَمْ یَحْلِفْ ، قَالَ : عَلَیْہِ کَفَّارَۃُ یَمِینٍ۔",,,12430,,
12431,"حدَّثَنَا أبُو أُسَامَۃَ ، عَنْ ہُشَام ، عَنِ الْحَسَنِ ، قَالَ : إذَا قَالَ : عَلَیَّ یَمِینٌ ، ثُمَّ حَنِثَ فَعَلَیْہِ الْکَفَّارَۃُ۔",,,12431,,
12432,"حدَّثَنَا غنْدَرٌ، عَنْ شُعْبَۃَ ، عَنْ حَمَّادٍ، قَالَ: إذَا قَالَ: قَدْ حَلَفْت ، وَلَمْ یَکُنْ حَلَفَ ، فَلَیْسَ عَلَیْہِ الکَفَّارَۃ۔",,,12432,,
12433,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا قَالَ : الرَّجُلُ حَلَفْت ، وَلَمْ یَحْلِفْ فَقَدْ کَذَبَ وَحَلَفَ ، وَإذَا قَالَ : قَد حَلَفْت وَکَذَبْت ، فَقَدْ کَذَبَ۔",,,12433,,
12434,"حدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ رُفَیْعٍ ، عَنْ تَمِیمِ بْنِ طُرْفَۃَ ، عَنْ عَدِیِّ بْنِ حَاتِمٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ حَلَفَ عَلَی یَمِینٍ فَرَأَی خَیْرًا مِنْہَا فَلْیَدَعْ یَمِینَہُ ، وَلْیَأْتِ الَّذِی ہُوَ خَیْرٌ ، وَلْیُکَفِّرْ یَمِینَہُ۔ (مسلم 1272۔ احمد 4/256)",,,12434,,
12435,"حدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا مِسْعَرٌ ، قَالَ : حدَّثَنَا عَلِیُّ بْنُ زَیْدِ بْنِ جُدْعَانَ ، قَالَ : حدَّثَنَا الْحَسَنُ ، قَالَ : حدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ سَمُرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا حَلَفْت عَلَی یَمِینٍ ، فَرَأَیْت مَا ہُوَ خَیْرٌ مِنْہَا فَاْتِ الَّذِی ہُوَ خَیْرٌ وَکَفِّرْ یَمِینَک۔ (بخاری 6622۔ ابوداؤد 3271)",,,12435,,
12436,"حدَّثَنَا أبُو الأَحْوَص ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أُذَیْنَۃَ ، عَنْ أَبِیہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ حَلَفَ عَلَی یَمِینٍ فَرَأَی مَا ہُوَ خَیْرٌ مِنْہَا فَلْیَأْتِ الَّذِی ہُوَ خَیْرٌ وَلْیُکَفِّرْ عَنْ یَمِینِہِ۔ (طبرانی 873۔ طیالسی 1370)",,,12436,,
12437,"حدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ رضی اللَّہُ عَنْہَا ، قَالَتْ : إنَّ أَبَا بَکْرٍ کَانَ لاَ یَحْلِفُ عَلَی یَمِینٍ فَیَحْنَثُ فِیہَا ، حَتَّی نَزَلَتْ کَفَّارَۃُ الْیَمِینِ ، قَالَ : لاَ أَحْلِفُ عَلَی یَمِینٍ فَأَرَی غَیْرَہَا خَیْرًا مِنْہَا إلاَّ أَتَیْتُ الَّذِی ہُوَ خَیْرٌ ، وَکَفَّرْت یَمِینِی۔",,,12437,,
12438,"حدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنِ الْقَاسِمِ ، قَالَ : کَانَ أَبُو بَکْرٍ رضی اللَّہُ عَنْہُ إذَا حَلَفَ لَمْ یَحْنَثْ حَتَّی نَزَلَتْ ہَذِہِ الآیَۃُ : {لاَ یُؤَاخِذُکُمَ اللَّہُ بِاللَّغْوِ فِی أَیْمَانِکُمْ} ، فَکَانَ إذَا حَلَفَ عَلَی یَمِینٍ ، فَرَأَی غَیْرَہَا خَیْرًا مِنْہَا أَتَی الَّذِی ہُوَ خَیْرٌ وَکَفَّرَ عَنْ یَمِینِہِ۔",,,12438,,
12439,"حدَّثَنَا أبو أسامۃ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : کَانُوا یَقُولُونَ : مَنْ حَلَفَ عَلَی یَمِینٍ فَرَأَی مَا ہُوَ خَیْرٌ مِنْہَا فَلْیَدَعْ یَمِینَہُ وَلْیَأْتِ الَّذِی ہُوَ خَیْرٌ ، وَلْیُکَفِّرْ عَنْ یَمِینِہِ۔",,,12439,,
12440,"حدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : قُلْتُ : حَلَفْت عَلَی أَمْرٍ غَیْرُہُ خَیْرٌ مِنْہُ أدعہ وأُکَفِّرُ یَمِینِی ؟ قَالَ : نَعَمْ۔",,,12440,,
12441,"حدَّثَنَا الفَضْلُ بْنُ دُکَیْنٍ ، عَنْ شَرِیکٍ ، عَنْ أَبِی حَصِینٍ ، عَنْ قَبِیصَۃَ بْنِ جَابِرٍ ، قَالَ : سَمِعْتُ عُمَرَ یَقُولُ : مَنْ حَلَفَ عَلَی یَمِینٍ فَرَأَی خَیْرًا مِنْہَا فَلْیَأْتِ الَّذِی ہُوَ خَیْرٌ وَلْیُکَفِّرْ عَنْ یَمِینِہِ۔",,,12441,,
12442,"حدَّثَنَا أبُو دَاوُد الطَّیَالِسِیُّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عَاصِمِ بْنِ الْمُنْذِرِ ، قَالَ : سَأَلْتُ عُبَیْدَ بْنَ عُمَیْرٍ ، عَنْ رَجُلٍ نَذَرَ أَنْ لاَ یَدْخُلَ عَلَی خَالَتِہِ ، قَالَ : یَدْخُلُ عَلَیْہَا وَیُکَفِّرُ یَمِینَہُ۔",,,12442,,
12443,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنْ مُسْلِمٍ ، عَنْ مَسْرُوقٍ ، قَالَ أُتِیَ عَبْدُ اللہِ بِضَرْعٍ وَنَحْنُ عِنْدَہُ فَاعْتَزَلَ رَجُلٌ مِنَ الْقَوْمِ ، فَقَالَ عَبْدُ اللہِ : ادْنُ ، فَقَالَ لَہُ : الرَّجُلُ : إنِّی حَلَفْت أَنْ لاَ آکُلَ ضَرْعَ نَاقَۃٍ ، فَقَالَ: ادْنُ فَکُلْ۔",,,12443,,
12444,حدَّثَنَا حَفْصٌ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ رضی اللَّہُ عَنْہ ، أَنَّہُ کَانَ یُکَفِّرُ قَبْلَ أَنْ یَحْنَثَ۔,,,12444,,
12445,حدَّثَنَا مُعْتَمِرٌ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدِ أن مَسْلَمَۃَ بن مَخَلَّد وَسَلْمَانَ کَانَا یَرَیَانِ أَنْ یُکَفِّرَ قَبْلَ أَنْ یَحْنَثَ۔,,,12445,,
12446,حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ ، أَنَّ أَبَا الدَّرْدَائِ رضی اللَّہُ عَنْہُ دَعَا غُلاَمًا لَہُ فَأَعْتَقَہُ ، ثُمَّ حَنِثَ فَصَنَعَ الَّذِی حَلَفَ عَلَیْہِ۔,,,12446,,
12447,حدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، أَنَّہُ کَانَ یُکَفِّرُ قَبْلَ أَنْ یَحْنَثَ۔,,,12447,,
12448,حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ أَنَّہُ کَانَ یُکَفِّرُ قَبْلَ أَنْ یَحْنَثَ۔,,,12448,,
12449,"حدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَانَ مُحَمَّدٌ یُکَفِّرُ قَبْلَ أَنْ یَحْنَثَ ، وَکَانَ الْحَسَنُ یَقُولُ : یَحْنَثُ ، ثُمَّ یُکَفِّرُ۔",,,12449,,
12450,"حدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَبْدِ اللہِ بْنِ کَثِیرٍ ، أَنَّہُ سَمِعَ رَجُلاً سَأَلَ جَابِرَ بْنَ زَیْدٍ ، قَالَ : حلَفْت عَلَی یَمِینٍ غَیْرُہَا خَیْرٌ مِنْہَا ، قَالَ : کَفِّرْ یَمِینَک وَاعْمِد إلی الَّذِی ہُوَ خَیْرٌ۔",,,12450,,
12451,"حدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنْ أَبِی مَالِکٍ ، قَالَ : یَمِینٌ لاَ تُکَفَّرُ ، الرَّجُلُ یَحْلِفُ عَلَی الْکَذِبِ یَتَعَمَّدُہُ ، فَذَلِکَ إلَی اللہِ ، إِنْ شَائَ عَذَّبَہُ ، وَإِنْ شَائَ غَفَرَ لَہُ۔",,,12451,,
12452,"حدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ وَحَمَّادٍ ؛ فِی الرَّجُلِ یَحْلِفُ عَلَی الشَّیْئِ یَتَعَمَّدُہُ ، قَالَ حَمَّادٌ : لَیْسَ لِہَذَا کَفَّارَۃٌ ، وَقَالَ : الْحَکَمُ : الْکَفَّارَۃُ خَیْرٌ۔",,,12452,,
12453,"حدَّثَنَا حَفْصٌ ، عَنِ الْحَجَّاجِ ، عَنِ الْحَکَمِ ، عَنْ إبْرَاہِیمَ ؛ فِی الرَّجُلِ یَحْلِفُ عَلَی الشَّیْئِ عِنْدَہُ ، وَلاَ یَدْرِی ثم یدری أَنَّہُ عِنْدَہُ ، قَالَ : یُکَفِّرُ یَمِینَہُ ، قَالَ : وَقَالَ عَطَائٌ وَالْحَکَمُ فِی التی لاَ تُکَفَّرُ : کَفِّرْ۔",,,12453,,
12454,"حدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : الأَیْمَانُ أَرْبَعَۃٌ ، فَیَمِینَانِ یُکَفَّرَانِ وَیَمِینَانِ لاَ یُکَفَّرَانِ: وَاللَّہِ لاَ أفْعَلُ وَاللَّہِ لأَفْعَلَنَّ ، قَالَ : فَہُمَا تُکَفَّرَانِ ، وَاللہِ مَا فَعَلْتُہُ وَاللہِ لَقَدْ فَعَلْتُ ، فَلاَ تُکَفَّرَانِ۔",,,12454,,
12455,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، وَوَکِیعٌ ، عَنِ الْعُمَرِیِّ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : الْقَسَمُ یَمِینٌ۔",,,12455,,
12456,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ مُجَاہِدٍ ، قَالَ : الْقَسَمُ یَمِینٌ ، ثُمَّ قَرَأَ : { وَأَقْسَمُوا بِاللَّہِ جَہْدَ أَیْمَانِہِمْ }۔",,,12456,,
12457,"حدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : أَقْسَمْت یَمِینٌ۔",,,12457,,
12458,"حدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ عَطَائٍ ، عَنْ أَبِی الْبَخْتَرِیِّ ، قَالَ : أَقْسَمَ رَجُلٌ أَنْ لاَ یَشْرَبَ مِنْ لَبَنِ شَاۃِ امْرَأَتِہِ ، قَالَ عَبْدُ اللہِ : أَطْیَبُ لِنَفْسِہِ أَنْ یُکَفِّرَ یَمِینَہُ۔",,,12458,,
12459,"حدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ فِی رَجُلٍ أَقْسَمَ عَلَی رَجُلٍ فَأَحْنَثَہُ ، قَالَ : أَحَبُّ إلَیَّ أَنْ یُکَفِّرَ یَمِینَہُ۔",,,12459,,
12460,"حدَّثَنَا ہُشَیْمٌ ، عَنْ عَوْفٍ ، عَنْ أَبِی الْمِنْہَالِ ، أَنَّ رَجُلاً أَقْسَمَ عَلَی رَجُلٍ فَأَحْنَثَہُ ، قَالَ أَبُو العَالیۃ : کَفِر یَمیِنک۔",,,12460,,
12461,"حدَّثَنَا ہُشَیْمٌ ، عَنْ مَنْصُورٍ ، عَنِ الحَسَن قَال : کَان لاَ یَری عَلَیہ کَفَّارَۃٌ إِذَا أَقْسَمَ عَلَی غَیرہ فَأَحْنَثَہُ قَالَ : إلاَّ أَنْ یُقْسِمَ ہُوَ ، فَإِذَا أَقْسَمَ ہُوَ فَحَنِثَ فَعَلَیْہِ الْکَفَّارَۃُ۔",,,12461,,
12462,"حدَّثَنَا یَحْیَی ، عَنْ عَبْدِ الْمَلِکِ بْنِ أَبِی غَنِیَّۃَ ، عَنِ الْحَکَمِ ، قَالَ : الْقَسَمُ یَمِینٌ۔",,,12462,,
12463,"حدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ شَرِیکٍ ، عَنْ عَبْدِ اللہِ بْنِ الْحَارِثِ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : الْقَسَمُ یَمِینٌ۔",,,12463,,
12464,"حدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عَاصِمٍ ، عَنْ بَکْرٍ ، قَالَ : إذَا أَقْسَمَ الرَّجُلُ عَلَی الرَّجُلِ فَأَحْنَثَہُ فَالإِثْم عَلَی الَّذِی أَحْنَثَہُ ، لأَنَّہُ إنَّمَا أَقْسَمَ عَلَیْہِ ثقۃً بِہِ۔",,,12464,,
12465,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، وَعُبَیْدُ اللہِ ، عَنْ شَیْبَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، قَالَ : الْقَسَمُ یَمِینٌ۔",,,12465,,
12466,"حدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ إبْرَاہِیمَ بْنِ مُہَاجِرٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا قَالَ الرَّجُلُ : أَقْسَمْت عَلَیْک ، فَلَیْسَ بِشَیْئٍ ، فَإذَا قَالَ : أُقْسِمُ عَلَیْکَ بِاللَّہِ ، فَہِیَ کَفَّارَۃُ یَمِینٍ۔",,,12466,,
12467,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : سَمِعْتُہُ یَقُولُ : لاَ یَکُونُ الْقَسَمُ یَمِینًا حَتَّی یَقُولَ : أُقْسِمُ بِاللَّہِ۔",,,12467,,
12468,"حدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : إذَا قَالَ الرَّجُلُ : أَقْسَمْت ، أَوْ أشہد ، وَلَمْ یَقُلْ : بِاللَّہِ ، فَلَیْسَ بِشَیْئٍ۔",,,12468,,
12469,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : إذَا قَالَ : الرَّجُلُ أَقْسَمْت ، أَوْ أَشْہَدُ أو أَحْلِفُ ، فَلَیْسَ بِیَمِینٍ حَتَّی یَقُولَ : بِاللَّہِ۔",,,12469,,
12470,"حدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیل ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، وَعَنْ رَجُلٍ ، عَنِ ابْنِ الْحَنَفِیَّۃِ ، قَالاَ : إذَا قَالَ الرَّجُلُ : أَقْسَمْت فَلَیْسَ بِیَمِینٍ حَتَّی یَقُولَ : بِاللَّہِ۔",,,12470,,
12471,"حدَّثَنَا مُعْتَمِرٌ ، عَنْ لَیْثٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ یَزِیدَ بْنِ إبْرَاہِیمَ التَّیْمِیِّ ، قَالَ : إذَا قَالَ الرَّجُلُ : لِلَّہِ عَلَیَّ، أَوْ عَلَیہ حَجَّۃٌ فَسَوَائٌ ، وَإذَا قَالَ : لِلَّہِ عَلَیَّ نَذْرٌ ، أَوْ عَلَیہ نَذْرٌ فَسَوَائٌ ، وَإذَا قَالَ : أَقْسَمْت بِاللَّہِ ، أَوْ أُقْسِمُ سَوَائٌ۔",,,12471,,
12472,"حدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ مُحَمَّدِ بْنِ طَلْحَۃَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ قَالَ : سَوَائٌ عَلَی الرَّجُلِ أَنْ یَقُولَ : أُقْسِمُ ، أَوْ أُقْسِمُ بِاللَّہِ عَلَیَّ حَجَّۃٌ ، أَوْ َعلَیَّ حَجَّۃٌ لِِلَّہِ ، أَوْ عَلَیَّ نَذْرٌ ، أَوْ عَلَیَّ نَذْرٌ لِلَّہِ۔",,,12472,,
12473,"حدَّثَنَا أَبُو أسَامَۃُ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ فِی الرَّجُلِ یَقُولُ : عَلَیَّ الْمَشْیُ إلَی الْکَعْبَۃِ ، قَالَ : ہَذَا نَذْرٌ فَلیَمْشِ۔",,,12473,,
12474,"حدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنْ محمد بْنِ ہِلاَلٍ سَمِعَ سَعِیدَ بْنَ الْمُسَیَّبِ یَقُولُ : مَنْ قَالَ عَلَیَّ الْمَشْیُ إلَی الْکَعْبَۃِ ، فَلَیْسَ بِشَیْئٍ إلاَّ أَنْ یَقُولَ : عَلَیَّ نَذْرُ مَشْیٍ۔",,,12474,,
12475,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، قَالَ : جَعَلَ رَجُلٌ مِنَّا عَلَیْہِ الْمَشْیَ إلَی بَیْتِ اللہِ فِی شَیْئٍ فَأَتَی الْقَاسِمَ فَسَأَلَہُ عَنْ ذَلِکَ ، فَقَالَ : یَمْشِی إلَی الْبَیْتِ۔",,,12475,,
12476,"حدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ مَالِکِ بْنِ مِغْوَلٍ ، قَالَ : سَأَلْتُ عَطَائً ، عَنْ رَجُلٍ ، قَالَ : لِلَّہِ عَلَیَّ یَمِینٌ ، قَالَ : یُکَفِّرُہَا۔",,,12476,,
12477,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، قَالَ : کَانَ ابْنُ عُمَرَ إذَا حَلَفَ أَطْعَمَ مُدًّا وَإِنْ وَکَّد أَعْتَقَ ، قَالَ: فَقُلْت لِنَافِعٍ : مَا التَّوْکِیدُ ؟ قَالَ : یُرَدِّدُ الْیَمِینَ فِی الشَّیْئِ الْوَاحِدِ۔",,,12477,,
12478,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا ہِشَامٌ الدَستَوائی ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا قَالَ الرَّجُلُ لِلرَّجُلِ وَلَہُ عَلَیْہِ مَالٌ : إِنْ لَمْ تَقْضِنِی یَوْمَ کَذَا وَکَذَا فَہُوَ عَلَیْک صَدَقَۃٌ ، فَلَیْسَ بِشَیْئٍ ، وَإن قَالَ : وَإِنْ لَمْ تُعْطِنِی إلَی یَوْمِ کَذَا وَکَذَا فَہُوَ فِی الْمَسَاکِینِ صَدَقَۃٌ ، فَہُوَ کَمَا قَالَ۔",,,12478,,
12479,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ مَنْصُورِ بن عَبْدِ الرَّحْمَنِ ، عَنْ أُمِّہِ ، أَنَّہَا سَأَلَتْ عَائِشَۃَ رضی اللَّہُ عَنْہُا مَا یُکَفِّرُ قَوْلَ الإِنْسَانِ : کُلُّ مَالِی فِی سَبِیلِ اللہِ ، أَوْ فِی رتَاجِ الْکَعْبَۃِ ، فَقَالَتْ : یُکَفِّرُہَا مَا یُکَفِّرُ الْیَمِینَ۔",,,12479,,
12480,"حدَّثَنَا عَبْدُ الرَّحِیمِ ووَکِیعٌ ، عَنْ مِسْعَرٍ ، قَالَ : سَمِعْتُ ہُبَیْرَۃَ یُحَدِّثُ الْحَکَمَ بْنَ عُتَیْبَۃَ مُنْذُ ثَلاَثِینَ سَنَۃً، قَالَ إنَّ امْرَأَۃً مِنَّا جَعَلَتْ دَارَہَا ہَدِیَّۃً فَأَمَرَہَا ابْنُ عَبَّاسٍ تُہْدِی ثَمَنَہَا۔",,,12480,,
12481,"حدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ فِی الرَّجُلِ یُہْدِی دَارَہُ إلَی بَیْتِ اللہِ ، قَالَ : یَبِیعُہَا وَیَبْعَثُ ثَمَنَہَا إلَی مَکَّۃَ ، أَوْ یَنْطَلِقُ یَتَصَدَّقُ بِہِ بِمَکَّۃَ ، أَوْ یَشْتَرِی ذَبَائِحَ فَیَذْبَحُہَا بِمَکَّۃَ ، وَیَتَصَدَّقُ بِہَا۔",,,12481,,
12482,"حدَّثَنَا أبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ فِی الرَّجُلِ یَقُولُ لِمَمْلُوکِہِ : ہُوَ ہَدِیَّۃٌ ، قَالَ : یُہْدِی قِیمَتَہُ۔",,,12482,,
12483,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَلِیِّ بْنِ عَتِیقٍ فِی رَجُلٍ أَہْدَی مَمْلُوکَہُ وَمَمْلُوکَتَہُ ، قَالَ الشَّعْبِیُّ : یُہْدِی قِیمَتَہُمَا وَقَالَ عَطَائٌ : یُہْدِی کَبْشًا۔",,,12483,,
12484,"حدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، قَالَ : سَأَلْتُ عَطَائً عَنِ الرَّجُلِ یَقُولُ : ہُوَ یُہْدِی غُلاَمَہُ ، قَالَ : یُہْدِی کَبْشًا مَکَانَہُ۔",,,12484,,
12485,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَامِعِ بْنِ أَبِی رَاشِدٍ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یُہْدِی دَارَہُ ، قَالَ : کَفَّارَۃُ یَمِینٍ۔",,,12485,,
12486,"حدَّثَنَا دَاوُد بْنُ کَثِیرٍ الْجُزرِیِّ ، عَنْ طَارِقِ بن أَبِی مُرَّۃَ ، قَالَ : حلفت لِامْرَأَتِی فِی جَارِیَۃٍ لَہَا إِنْ أَنَا وَطِئْتہَا فَہِیَ ہَدِیَّۃٌ إلَی بَیْتِ اللہِ فَوَطِئْتہَا ، فَسَأَلْت سَعِیدَ بْنَ جُبَیْرٍ ، فَقَالَ : اشْتَرِ بِثَمَنِہَا بُدْنًا ، ثُمَّ انْحَرْہَا۔",,,12486,,
12487,"حدَّثَنَا حمید بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنٍ ، عَنْ مُطَرِّفٍ ، عَنِ الْحَکَمِ ؛ فِی الرَّجُلِ یُہْدِی الدَّارَ ، قَالَ : یُہْدِی قِیمَتَہَا۔",,,12487,,
12488,"حدَّثَنَا کثیر بْنُ ہِشَامٍ ، عَنْ فُرَات ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ عِکْرِمَۃَ ، قَالَ إذَا قَالَ لِشَیْئٍ : ہُوَ عَلَیْہِ ہَدْیٌ، فَکَفَّارَۃُ یَمِینٍ ہُوَ مِنْ خَطَرَاتِ الشَّیْطَانِ۔",,,12488,,
12489,"حدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا قَالَ : ہُوَ یُہْدِی سَارِیَۃً مِنْ سَوَارِی الْمَسْجِدِ ، یُہْدِی قِیمَتَہَا ، أَوْ ، ثَمَنَہَا ، فَإِنْ لَمْ یَجِدْ أَہْدَی مَا بَلَغَ مَالَہُ وَکَفَّرَ یَمِینِہِ۔",,,12489,,
12490,حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ کَانَ یَسْتَحِبُّ إذَا أَہْدَی الرَّجُلُ الشَّیْئَ أَنْ یُمْضِیَہُ۔,,,12490,,
12491,"حدَّثَنَا أبُو عَامِرٍ الْعَقَدِیُّ ، عَنْ مُحَمَّدِ بْنِ قَیْسٍ ، قَالَ : قُلْتُ لِسَعِیدِ بْنِ الْمُسَیَّبِ : أَنَا أَمْشِی بِرِدَائِی ہَذَا حَتَّی أَسِیرَ بِہِ إلَی الْکَعْبَۃِ إِنْ کَلَّمت صَاحِبًا لِی ، قَالَ : فَنَدِمْت ؟ قُلْتُ نَعَمْ ، قَالَ : اذْہَبْ فَالْبَسْ ثَوْبَک ، فَمَا أَغْنَی الْکَعْبَۃَ ، عَنْ ثَوْبِکَ وَعَنْک ، وَقل : سَعِید أَمَرَنِی فَأَتَیْت الْقَاسِمَ بْنَ مُحَمَّدٍ ، فَقَالَ لِی مِثْلَ مَا قَالَ سَعِیدٌ ، فَلَمَّا خَرَجْت مِنْ عِنْدِہِ أَدْرَکَنِی رَسُولُہُ فَقَالُ : عِنْدَک دِرْہَمٌ ؟ قُلْتُ : نَعَمْ ، قَالَ : تَصَدَّقْ بِہِ ، وََقُل : أَمَرَنِی بِہِ الْقَاسِمُ۔",,,12491,,
12492,"حدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنِ الْعَلاَئِ بْنِ الْمُسَیَّبِ ، عَنْ حَمَّاد ، عَنْ إبْرَاہِیمَ فِی رَجُلٍ ، قَالَ : ہُوَ یُہْدِی الْفُرَاتَ وَمَا سَمَّی ، قَالَ : یُہْدِی مَا یَمْلِکُ۔",,,12492,,
12493,"حدَّثَنَا حَفْصٌ ، عَنِ الْعَلاَئِ بْنِ الْمُسَیَّبِ ، عَنْ عَطَائٍ ، قَالَ : کَفَّارَۃُ یَمِینٍ۔",,,12493,,
12494,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ لَیث ، عَنْ طَاوُوس ، وَعَطَائٍ ، وَمُجَاہِدٍ ، قَالُوا : مَا کَانَ من ہَدْیٍ إلَی الْبَیْتِ فَلْیَشْتَرِ بِہِ بُدْنًا فَیَتَصَدَّقْ بِہَا۔",,,12494,,
12495,"حدَّثَنَا عَبْدُ الرَّحِیمِ، عَنِ الْعَلاَئِ بْنِ الْمُسَیَّبِ، قَالَ: سَأَلْتُ عَطَائً عَنْ سبعۃ دَرَاہِمَ بَعَثَتْ بِہَا امْرَأَتُہُ ہَدِیَّۃً إلَی الْبَیْتِ، قَالَ عَطَائٌ: إنَّ بَیْتَکُمْ ہَذَا غَنِیٌّ عَنْ دَرَاہِمِکُمْ، وَلَکِنْ أَعْطُوہَا فُقَرَائَ کُمْ، إنَّمَا الْبُدْنُ ہَدَایَا الْبَیْتِ۔",,,12495,,
12496,"حدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، عَنْ قَیْسٍ ، أَنَّ امْرَأَۃً ، قَالَتْ : کُنْت عِنْدَ عَائِشَۃَ أُمِّ الْمُؤْمِنِینَ فَأَتَتْہَا امْرَأَۃٌ، بحُلِیٍّ فَقَالَتْ : إنِّی جِئْت بِہَذَا ہَدِیَّۃً إلَی الْکَعْبَۃِ ، فَقَالَتْ لَہَا عَائِشَۃُ : لَوْ أَعْطَیْتہ فِی سَبِیلِ اللہِ وَالْیَتَامَی وَالْمَسَاکِینِ ، إنَّ ہَذَا الْبَیْتَ یُعْطَی وَیُنْفَقُ عَلَیْہِ مِنْ مَالِ اللہِ۔",,,12496,,
12497,"حدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ أَبِی الْعَنْبَسِ ، عَنِ الْقَاسِمِ ، عَنْ عَائِشَۃَ ، قَالَتْ : لأَنْ أَتَصَدَّقَ بِخَاتَمِی ہَذَا أَحَبُّ إلَیَّ مِنْ أَنْ أُہْدِیَ إلَی الْکَعْبَۃِ أَلْفًا۔",,,12497,,
12498,"حدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ، عَنْ ہِشَامٍ، عَنِ الْقَاسِمِ بْنِ مُحَمَّدٍ، قَالَ: سَمِعْتُہُ یَقُولُ: لأَنْ أَتَصَدَّقَ بِدِرْہَمٍ أَحَبُّ إلَیَّ مِنْ أَنْ أُہْدِیَ إلَی البَیْتِ مِئَۃ أَلْفِ دِرْہَمٍ ، وَلَوْ سَالَ عَلَیَّ وَادِی مَالٍ مَا أَہْدَیْت إلَی الْبَیْتِ مِنْہُ دِرْہَمًا۔",,,12498,,
12499,"حدَّثَنَا مَحْبُوبٌ الْقَوَارِیرِیُّ ، عَنْ مَالِکِ بنِ حَبِیبٍ ، عَنْ سَالِمٍ ، قَالَ : سَأَلَہُ رَجُلٌ عَنْ ہَدِیَّۃِ الْکَعْبَۃِ ، فَقَالَ : إنَّ الْکَعْبَۃَ لَغَنِیَّۃٌ عَنْ ہَدِیَّتِکَ ، أُنْظُر إنْسَانًا فَقِیرًا أَو مِسْکِینًا فَأَطعِمہ کِسرَۃ۔",,,12499,,
12500,حدَّثَنَا مُعَمَّرُ بْنُ سُلَیْمَانَ الرَّقِّیُّ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی إِسْحَاقَ ، عنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، أَنَّہُ کَانَ لاَ یُفَرِّقُ صِیَامَ الْیَمِینِ الثَّلاَثَۃِ أَیَّامٍ۔,,,12500,,
12501,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : سَأَلْتُ إِبْرَاہِیمَ عَن صِیَامِ الثَّلاَثَۃِ أَیَّامٍ فِی کَفَّارَۃِ الْیَمِینِ ، قَالَ فِی قِرَائَتِنَا : {فَصِیَامُ ثَلاَثَۃِ أَیَّامٍ مُتَتَابِعَاتٍ}",,,12501,,
12502,"حدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : کُلُّ صِیَامٍ فِی الْقُرْآنِ مُتَتَابِعٌ إلاَّ قَضَائَ رَمَضَانَ۔",,,12502,,
12503,"حدَّثَنَا وَکِیعٌ ، عَنْ أَبِی جَعْفَرٍ ، عَنِ الرَّبِیعِ ، عَنْ أَبِی الْعَالِیَۃِ ، قَالَ : کَانَ أُبَی یَقْرَؤُہَا : {فَصِیَامُ ثَلاَثَۃِ أَیَّامٍ مُتَتَابِعَاتٍ}۔",,,12503,,
12504,"حدَّثَنَا وَکِیعٌ، عَنْ سُفیان، عَنْ جابر، عَنْ عامر قَالَ: فی قراء ۃ عبداللہ: {فَصِیَامُ ثَلاَثَۃِ أَیَّامٍ مُتَتَابِعَاتٍ}",,,12504,,
12505,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، أَنَّہُ کَانَ یَقُولُ فِی صَوْمِ کَفَّارَۃِ الْیَمِینِ : یَصُومُہُ مُتَتَابِعًا ، فَإِنْ أَفْطَرَ مِنْ عُذْرٍ قَضَی یَوْمًا مَکَانَ یَوْمٍ۔",,,12505,,
12506,"حدَّثَنَا حمید بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ زُہَیْرٍ ، عَنْ لَیْثٍ ، عَنْ عَطَاء ، وطَاوُوس ، وَمُجَاہِدٍ ، قَالُوا : مَا کَانَ سِوَی رَمَضَانَ فَلاَ إلاَّ مُتَتَابِعًا۔",,,12506,,
12507,"حدَّثَنَا شَرِیکُ بْنُ عَبْدِ اللہِ ، عَنْ خُصَیْفٍ ، عَنْ مِقْسَمٍ ، عَنِ ابْنِ عَبَّاسٍ یَرْفَعُہُ ، قَالَ : أَتَاہُ رَجُلٌ ، فَقَالَ : إنِّی وَقَعْت عَلَی امْرَأَتِی وَہِیَ حَائِضٌ ، فَقَالَ : تَصَدَّقْ بِنِصْفِ دِینَارٍ۔ (ابوداؤد 270۔ بیہقی 316)",,,12507,,
12508,"حدَّثَنَا ہُشَیْمٌ، عَنْ حَجَّاجٍ، عَنْ عَبْدِالْکَرِیمِ، عَنْ مِقْسَمٍ ، عَنِ ابْنِ عَبَّاسٍ یَرْفَعُہُ : یَتَصَدَّقُ بِنِصْفِ دِینَارٍ۔",,,12508,,
12509,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ عَبْدِ الْحَمِیدِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ مِقْسَمٍ ، عَنِ ابْنِ عَبَّاسٍ رضی اللَّہُ عَنْہُما ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ یَتَصَدَّقُ بِدِینَارٍ ، أَوْ نِصْفِ دِینَارٍ۔\n\n(ابوداؤد 268۔ نسائی 282)",,,12509,,
12510,"حدَّثَنَا مُعْتَمِرٌ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ، قَالَ : أَتَی رَجُلٌ أَبَا بَکْرٍ ، فَقَالَ : إنِّی رَأَیْت فِی النَّوْمِ کَأَنِّی أَبُولُ دَمًا ، فَقَالَ : أَرَاک تَأْتِی الْمَرْأَۃَ وَہِیَ حَائِضٌ ، قَالَ : نَعَمْ ، قَالَ : اتَّقِ اللَّہَ ، وَلاَ تَعُدْ۔",,,12510,,
12511,"حدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، عَنِ الْحَکَمِ ، عَنْ مِقْسَمٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ فِی الرَّجُلِ یَقَعُ عَلَی امْرَأَتِہِ وَہِیَ حَائِضٌ ، قَالَ : یَتَصَدَّقُ بِدِینَارٍ ، أَوْ نِصْفِ دِینَارٍ۔",,,12511,,
12512,"حدَّثَنَا ابْنُ الْمُبَارَکِ ، عَنْ یَعْقُوبَ ، عَنْ مُحَمَّدِ بْنِ زَیْدٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : یَسْتَغْفِرُ اللَّہَ۔",,,12512,,
12513,"حدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ فِی الرَّجُلِ یَأْتِی امْرَأَتَہُ وَہِیَ حَائِضُ ، قَالَ : ذَنْبٌ أَتَاہُ ، یَسْتَغْفِرُ اللَّہَ مِنْہُ۔",,,12513,,
12514,"حدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا إسْمَاعِیلُ ، عَنِ الشَّعْبِیِّ مِثْلَ ذَلِکَ۔",,,12514,,
12515,"حدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : یَسْتَغْفِرُ اللَّہَ ، قَالَ : وَکَانَ الْحَسَنُ یَرَی عَلَیْہِ مَا یَرَی عَلَی الْمُظَاہِرِ۔",,,12515,,
12516,"حدَّثَنَا ہُشَیْمٌ ، عَنْ مَنْصُورٍ ، عَنِ الْحَسَنِ ، أَنَّہُ کَانَ یَقُولُ : مَنْ وَطِئَ امْرَأَتَہُ وَہِیَ حَائِضٌ ، نَرَی عَلَیْہِ مَا عَلَی الْمُظَاہِرِ۔",,,12516,,
12517,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، عَنْ أَبِیہِ ؛ فِی الرَّجُلِ یَأْتِی امْرَأَتَہُ وَہِیَ حَائِضٌ ، قَالَ : یَعْتَذِرُ ، ویَتُوبُ إلَی اللہِ۔",,,12517,,
12518,"حدَّثَنَا ابْنُ أَبِی زَائِدَۃَ ، عَنْ مُثَنًّی ، عَنْ عَطَائٍ ، قَالَ : یَسْتَغْفِرُ اللَّہَ۔",,,12518,,
12519,"حدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا ابْنُ أَبِی لَیْلَی ، عَنْ عَطَائٍ ، قَالَ : قُلْتُ لِابْنِ عَبَّاسٍ : الرَّجُلُ یَقَعُ عَلَی امْرَأَتِہِ وَہِیَ حَائِضٌ ، قَالَ : یَتَصَدَّقُ بِدِینَارٍ۔",,,12519,,
12520,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : لَیْسَ عَلَیْہِ شَیْئٌ ، وَلَکِنْ لاَ یَعُدْ۔",,,12520,,
12521,"حدَّثَنَا غنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ حَمَّادٍ ، قَالَ : ذَنْبٌ یَسْتَغْفِرُ اللَّہَ مِنْہُ۔",,,12521,,
12522,"حدَّثَنَا حمید بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِی بِشْرٍ الحُبلی ، عَنْ أَبِی حُرَّۃَ ، أَنَّ عُمَرَ سَأَلَ عَلِیًّا مَا تَرَی فِی رَجُلٍ وَقَعَ عَلَی امْرَأَتِہِ وَہِیَ حَائِضٌ ؟ قَالَ : لَیْسَ عَلَیْہِ کَفَّارَۃٌ إلاَّ أَنْ یَتُوبَ۔",,,12522,,
12523,"حدَّثَنَا أبُو الأَحْوَص ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ فِی رَجُلٍ حَلَفَ أَنْ لاَ یَصِلَ رَحِمَہُ ، قَالَ : یَصِلُ رَحِمَہُ وَیُکَفِّرُ یَمِینَہُ ، قَالَ : وَقَالَ الشَّعْبِیُّ : یَصِلُ رَحِمَہُ ، وَلاَ یُکَفِّرُ یَمِینَہُ ، وَلَوْ أَمَرْتہ أَنْ یُکَفِّرَ یَمِینَہُ ، أَمَرْتہ أَنْ یُتِمَّ عَلَی قَوْلِہِ۔",,,12523,,
12524,"حدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ کَثِیرِ بْنِ نَبَاتَۃَ سَمِعَہُ یُحَدِّثُ ، أَنَّ أَخَوَیْنِ کَانَا شَرِیکَیْنِ ، وَأَنَّ أَحَدَہُمَا أَرَادَ مُفَارَقَۃَ أَخِیہِ ، فَقَالَ : کل مَمْلُوکٌ لَہُ حُرٌّ ، أَوْ عَتِیقٌ إِنْ لَمْ یُفَارِقْ أَخَاہُ وَإِنَّ أُمَّہُ أَمَرَتْہُ أَنْ لاَ یُفَارِقَ أَخَاہُ ، فَسَأَلْت الْحَسَنَ ، أَوْ سُئِلَ وَہُوَ یَسْمَعُ ذَلِکَ ، فَقَالَ : لِیُکَفِّرْ یَمِینَہُ وَیَصِلْ رَحِمَہُ ویُشَارِکُ أَخَاہُ ، أَوْ کَمَا قَالَ : قَالَ أَبُو الْعَلاَئِ کَثِیرٌ : فَحَدَّثت بِہِ الْحَکَمُ بْنُ أَبَانَ ، فَقَالَ : ہَذَا قَوْلُ طَاوُوس۔",,,12524,,
12525,"حدَّثَنَا مُحَمَّدُ بْنُ عُبَیْدٍ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ فِی رَجُلٍ حَلَفَ أن لاَ یُکَلِّمُ أَبَاہُ وَأَخَاہُ شَہْرَیْنِ ، قَالَ : یلطفہ وَیَدْخُلُ عَلَیْہِ ، وَلاَ یُکَلِّمُہُ۔",,,12525,,
12526,"حدَّثَنَا عَبْدُ اللہِ بْنُ مُبَارَکٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، وَعَنِ الرَّبِیعِ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یَأْتِی امْرَأَتَہُ وَہِیَ تَقْضِی شَہْرَ رَمَضَانَ ، قَالاََ : لَیْسَ عَلَیْہِ شَیْئٌ۔",,,12526,,
12527,"حدَّثَنَا عُمَرُ بْنُ أَیُّوبَ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنْ مَیْمُونٍ ، عَنْ شُرَیْحٍ ، أَنَّ رَجُلاً اسْتَوْدَعَہُ مَالاً وَکَانَ لِلسُّلْطَانِ عِنْدَ ذَلِکَ الرَّجُلِ بُغْیَۃٌ ، فَقَالَ لِشُرَیْحٍ : إنَّا نَسْتَحْلِفُک ، قَالَ : کُنْتُ أَدْفَعُ ، عَنْ مَالِہِ مَا اسْتَطَعْت مَا لَمَ اضطَرَّ إلَی الْیَمِینِ۔",,,12527,,
12528,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یَسْتَحْلِفُہُ السُّلْطَانُ عَلَی أَنْ یَدُلَّ عَلَی رَجُلٍ مُسْلِمٍ ، أَوْ عَلَی مَالِہِ ، فَقَالَ : یَحْلِفُ وَیُکَفِّرُ یَمِینَہُ۔",,,12528,,
12529,حدَّثَنَا عَبْدُ اللہِ بْنُ مُبَارَکٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَبْدِ اللہِ بْنِ عُبَیْدِ بْنِ عُمَیْرٍ ، عَنْ أَبِیہِ ، أَنَّہُ کَانَ یُحَلِّلُ یَمِینَہُ بِضَرْبٍ دُونَ ضَرْبٍ ، أَوْ ضَرْبٍ أَدْنَی مِنْ ضَرْبٍ۔,,,12529,,
12530,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ سُلَیْمَانَ الأَحْوَلِ ، عَنْ أَبِی مَعْبَدٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : مَنْ حَلَفَ عَلَی مِلْکِ یَمِینِہِ لَیَضْرِبَنَّہُ فَکَفَّارَتُہُ تَرْکُہُ وَلَہُ مِنَ الْکَفَّارَۃِ حَسنَہُ۔",,,12530,,
12531,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ قَیْسِ بْنِ سَعْدٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ فِی رَجُلٍ نَذَرَ أَنْ یَضْرِبَ غُلاَمَہُ ثَلاَثِینَ سَوْطًا ، أَوْ أَکْثَرَ ، قَالَ : یَجْمَعُہَا فَیَضْرِبُہُ ضَرْبَۃً وَاحِدَۃً۔",,,12531,,
12532,"حدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ أَبِی حَنِیفَۃَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ فِی الْمُظَاہِرِ جَامَعَ فِی آخِرِ اللَّیْلِ ، أَوِ النَّہَارِ ، قَالَ : یَسْتَقْبِلُ الصَّوْمَ۔",,,12532,,
12533,"حدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنِ ابن رَبَاحٍ، عَنْ مُجَاہِدٍ فِی رَجُلٍ حَلَفَ بِالإِحْرَامِ، قَالَ: لَیْسَ عَلَیْہِ شَیْئٌ۔",,,12533,,
12534,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الْمِنْہَالِ ، عَنْ أَبِی وَائِلٍ ، قَالَ : کفارۃ یَمِینٍ۔",,,12534,,
12535,"مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ حَسَّانَ بْنِ أَبِی یَحْیَی ، قَالَ : سَمِعْتُ عِکْرِمَۃَ وَسَأَلَہُ رَجُلٌ ، فَقَالَ : إنِّی حَلَفْت لِامْرَأَتِی بِعَشْرِ حِجَجٍ إِنْ أَنَا وَطِئْت جَارِیَۃً لِی ، فَقَالَ : عِکْرِمَۃُ : لَوْ وفیت بِہَا کَانَتْ لِلشیْطَانِ ، اذْہَبْ فَإِنَّمَا ہِیَ یمین تُکَفِّرُہَا۔",,,12535,,
12536,"حدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا سَعِیدٌ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ وَجَابِرِ بْنِ زَیْدٍ ، قَالاَ : إذَا قَالَ : ہُوَ مُحْرِمٌ بِحَجَّۃٍ کَفَّرَ یَمِینَہُ۔",,,12536,,
12537,"حدَّثَنَا الْمُحَارِبِیُّ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ؛ فِی رَجُلٍ ، قَالَ: عَلَیْہِ أَلْفُ حَجَّۃٍ ، قَالَ : عَلَیْہِ کَفَّارَۃُ یَمِینٍ۔",,,12537,,
12538,"حدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا زُہَیْرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ فِی الرَّجُلِ یَقُولُ : ہُوَ مُحْرِمٌ بِأَلْفِ حَجَّۃٍ ، یَحُجُّ مَا اسْتَطَاعَ۔",,,12538,,
12539,"حدَّثَنَا عَبْدُ اللہِ بْنُ مُحَمَّدٍ ، قَالَ :\n حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ یَکْرَہُ أَنْ یَقُولَ : وَإِنِّی سَآتِیک وَاللَّہِ حَیْثُ کَانَ ، قَالَ : فَإِنَّ اللَّہُ بِکُلِّ مَکَان۔",,,12539,,
12540,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، أَنَّ ابْنَ عُمَرَ کَانَ یَکْرَہُ أَنْ یَسْمَعَ الرَّجُلَ یَقُولُ : لاَ وَاللَّہِ حَیْثُ کَانَ ، فَإِنَّہُ بِکُلِّ مَکَان۔",,,12540,,
12541,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سُفْیَانَ ، عَنْ زَیْدِ بْنِ جُبَیْرٍ ، عَنْ أَبِی الْبَخْتَرِیِّ ، أَنَّہُ کَرِہَ أَنْ یَقُولَ : لاَ یَأْتِی شانئک۔",,,12541,,
12542,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ زَیْدِ بْنِ جُبَیْرٍ ، عَنْ أَبِی الْبَخْتَرِیِّ ، قَالَ : لاَ یَقُلْ أَحَدُکُمْ بِأَبِی رَبی، فَإِنَّہُ لاَ یَفْدِیہِ بِشَیْئٍ۔",,,12542,,
12543,"حدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ مُبَارَکٍ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ رَجُلٍ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو فِی رَجُلٍ نَذَرَ أَنْ یَزُمَّ أَنْفَہُ ، قَالَ : یُکَفِّرُ عَنْ یَمِینِہِ۔",,,12543,,
12544,"حدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی جَمْرَۃَ الضُّبَعِیِّ ، أَنَّ رَجُلاً مِنْ بَنِی سُلَیْمٍ نَذَرَ أَنْ یَزُمَّ أَنْفَہُ ، فَقَالَ : ابْنُ عَبَّاسٍ ، النَّذْرُ نَذْرَانِ ، فَمَا کَانَ لِلَّہِ فَفِیہِ الْوَفَائُ ، وَمَا کَانَ لِلشَّیْطَانِ فَفِیہِ الْکَفَّارَۃُ ، أَطْلِقْ زِمَامَک وَکَفِّرْ یَمِینَک۔",,,12544,,
12545,"حدَّثَنَا أبُو أُسَامَۃَ ، عَنْ عُثْمَانَ بْنِ غِیَاثٍ ، قَالَ : سَأَلْتُ جَابِرَ بْنَ زَیْدٍ ، عَنْ رَجُلٍ نَذَرَ أَنْ یَجْعَلَ فِی أَنْفِہِ حَلَقَۃً مِنْ ذَہَبٍ ؟ قَالَ : لاَ یَزَالُ عَاصِیًا مَا دَامَتْ عَلَیْہِ ، فَمُرْہُ فَلْیُکَفِّرْ یَمِینَہُ۔",,,12545,,
12546,"حدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ أَشْعَثَ بْنِ سَوَّارٍ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یَجْعَلُ عَلَی أَنْفِہِ أَنْ یَزُمَّہَا وَیَحُجَّ مَاشِیًا ، قَالَ : قدْ نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الْمُثْلَۃِ ، انْزِعْ ہَذَا وَحُجَّ رَاکِبًا وَانْحَرْ بَدَنَۃً۔",,,12546,,
12547,"حدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ؟ قَالَ : لاَ زِمَامَ ، وَلاَ خِزَامَ ، وَلاَ نِیَاحَۃَ ، یَعْنِی فِی الإِسْلاَمِ۔",,,12547,,
12548,"حدَّثَنَا أبُو خَالِدٍ الأَحْمَرِِ ، وَابْنُ فُضَیْلٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عُبَیْدِ اللہِ بْنِ زَحْرٍ ، عَنْ أَبِی سَعِیدٍ الرُّعَیْنِیِّ ، عَنْ عَبْدِ اللہِ بْنِ مَالِکٍ ، عَنْ عُقْبَۃَ بْنِ عَامِرٍ الْجُہَنِیِّ ، قَالَ : نَذَرَتْ أُخْتِی أَنْ تَمْشِیَ حَافِیَۃً إلَی بَیْتِ اللہِ غَیْرَ مُخْتَمِرَۃٍ ، فَسَأَلَتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : مُرْ أُخْتَکَ فَلْتَخْتَمِرْ وَلْتَرْکَبْ وَلْتَصُمْ ثَلاَثَۃَ أَیَّامٍ۔ (بخاری 1866۔ مسلم 1264)",,,12548,,
12549,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا حُمَیْدٌ ، عَنْ ثَابِتٍ ، عَنْ أَنَسٍ ، قَالَ رَأَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجُلاً یُہَادَی بَیْنَ ابْنَیْہِ ، فَقَالَ : مَا ہَذَا ؟ فَقَالُوا : نَذَرَ أَنْ یَمْشِیَ إلَی بَیْتِ اللہِ ، فَقَالَ : إنَّ اللَّہَ لَغَنِیٌّ ، عَنْ تَعْذِیبِ ہَذَا نَفْسَہُ ، ثُمَّ أَمَرَہُ فَرَکِبَ۔ (بخاری 1865۔ مسلم 9)",,,12549,,
12550,"حدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، وَعَنْ مَالِکِ بْنِ أَنَسٍ ، عَنْ عُرْوَۃَ بْنِ أُذَیْنَۃَ ، قَالَ عُبَیْدُ اللہِ جَدّتَہُ ، وَقَالَ : مَالِکٌ : إنَّ أُمَّہُ جَعَلَتْ عَلَیْہَا الْمَشْیَ فَمَشَتْ حَتَّی انْتَہَتْ إلَی السُّقْیَا ، ثُمَّ عَجَزَتْ فَمَا مَشَتْ ، فَسَأَلْت ابْنَ عُمَرَ ، فَقَالَ : مُرُوہَا أَنْ تَعُودَ مِنَ الْعَامِ الْمُقْبِلِ فَتَمْشِیَ مِنْ حَیْثُ عَجَزَتْ۔",,,12550,,
12551,"حدَّثَنَا ابْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا إسْمَاعِیلُ بْنُ أَبِی خَالِدٍ ، عَنِ الشَّعْبِیِّ ، أَنَّہُ سُئِلَ عَنْ رَجُلٍ نَذَرَ أَنْ یَمْشِیَ إلَی الْکَعْبَۃِ ، فَمَشَی نِصْفَ الطَّرِیقِ وَرَکِبَ نِصْفَہُ قَالَ : فَقَالَ عامر : قَالَ ابْنُ عَبَّاسٍ : یَرْکَبُ مَا مَشَی وَیَمْشِی مَا رَکِبَ مِنْ قَابِلٍ ، وَیُہْدِی بَدَنَۃً۔",,,12551,,
12552,"حدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، عَنْ عَلِیٍّ ، قَالَ : من قَالَ عَلَیْہِ الْمَشْیُ إِنْ شَائَ رَکِبَ وَأَہْدَی۔",,,12552,,
12553,"حدَّثَنَا عَبْدُ الرَّحِیمِ ، وَأَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنْ عَلِیٍّ ؛ فِی الرَّجُلِ یَجْعَلُ عَلَیْہِ الْمَشْیَ إلَی بَیْتِ اللہِ ، قَالَ عَبْدُ الرَّحِیمِ : یَرْکَبُ وَیُہْرِیقُ دَمًا ، وَقَالَ : أَبُو خَالِدٍ : یُہْدِی بَدَنَۃً۔",,,12553,,
12554,"حدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنِ الأَجْلَحِ ، عَنْ عَمْرِو بْنِ سَعِیدٍ الْبَجَلِیِّ ، قَالَ : کُنْتُ تَحْتَ مِنْبَرِ ابْنِ الزُّبَیْرِ وَہُوَ عَلَیْہِ ، فَجَائَ رَجُلٌ ، وَقَالَ : یَا أَمِیرَ الْمُؤْمِنِینَ إنِّی نَذَرْت أَنْ أَحُجَّ مَاشِیًا ، حَتَّی إذَا کَانَ کَذَا وَکَذَا ومَشَیْت خَشِیت أَنْ یَفُوتَنِی الْحَجُّ ، رَکِبْت ، قَالَ : لاَ خَطَأَ عَلَیْک ، ارْجِعْ عَامَ قَابِلٍ فَامْشِ مَا رَکِبْت وَارْکَبْ مَا مَشَیْت۔",,,12554,,
12555,"حدَّثَنَا أبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ نَذَرَ أَنْ یَحُجَّ مَاشِیًا ، قَالَ : یَمْشِی ، فَإِنَ انْقَطَعَ رَکِبَ وَأَہْدَی بَدَنَۃً۔",,,12555,,
12556,"حدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، قَالَ : سَمِعْتُ الْقَاسِمَ وَسُئِلَ عَنْ رَجُلٍ حَلَفَ أَنْ یَمْشِیَ إلَی الْبَیْتِ ، فَمَشَی ، فَعَیِیَ فَرَکِبَ ، قَالَ : إذَا کَانَ قَابِلٌ فَلْیَمْشِ مَا رَکِبَ وَلیَرْکَبْ مَا مَشَی ، قَالَ : وَسَمِعْت یَزِیدَ بْنَ عَبْدِ اللہِ بْنِ قُسَیْطٍ یَقُولُ : یَرْکَبُ وَیُہْدِی بَدَنَۃً۔",,,12556,,
12557,"حدَّثَنَا عَبِیدَۃُ بْنُ حُمَیْدٍ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ فِی رَجُلٍ یَکُونُ عَلَیْہِ مَشْیٌ إلَی الْبَیْتِ ، فَیَمْشِی ، ثُمَّ یُعَیِّی ، قَالَ : یَرْکَبُ ، فَإِذَا کَانَ قَابِلٌ رَکِبَ مَا مَشَی ، وَمَشَی مَا رَکِبَ۔",,,12557,,
12558,"حدَّثَنَا أبُو أُسَامَۃَ ، قَالَ : حدَّثَنَا عُبَیْدُ اللہِ بْنُ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ فِی الرَّجُلِ یَقُولُ عَلَیَّ الْمَشْیُ إلَی الْکَعْبَۃِ ، قَالَ : ہَذَا نَذْرٌ ، فَلْیَمْشِ۔",,,12558,,
12559,"حدَّثَنَا حمَّادُ بْنُ خَالِدٍ الْخَیَّاطُ ، عَنْ مُحَمَّدِ بْنِ ہِلاَلٍ سَمِعَ سَعِیدَ بْنَ الْمُسَیَّبِ یَقُولُ : مَنْ قَالَ عَلَیَّ الْمَشْیُ إلَی بَیْتِ اللہِ ، فَلَیْسَ بِشَیْئٍ إلاَّ أَنْ یَقُولَ : عَلَیَّ نَذْرُ مَشْیٍ إلَی الْکَعْبَۃِ۔",,,12559,,
12560,"حدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، قَالَ : جَعَلَ رَجُلٌ مِنَّا عَلَیْہِ الْمَشْیَ إلَی الْبَیْتِ فی شَیء فَأَتَی الْقَاسِمَ فَسَأَلَہُ عَنْ ذَلِکَ ، فَقَالَ : یَمْشِی إلَی الْبَیْتِ۔",,,12560,,
12561,"حدَّثَنَا مُعْتَمِرٌ ، عَنْ لَیْثٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ یَزِیدَ أبی إبْرَاہِیمَ التَّیْمِیِّ ، قَالَ : إذَا قَالَ الرَّجُلُ : لِلَّہِ عَلَیَّ ، أَوْ عَلَیْہِ حَجَّۃٌ فَسَوَائٌ ، وَإذَا قَالَ : لِلَّہِ عَلَیَّ نَذْرٌ ، أو عَلَیَّ للہ ، فَسَوَائٌ۔",,,12561,,
12562,"حدَّثَنَا عُمَرُ بْنُ أَیُّوبَ ، عَنْ عُمَرَ بْنِ زَیْدٍ ، قَالَ : جَائَ رَجُلاَنِ إلَی الْقَاسِمِ فَسَأَلاَہُ وَأَنَا أَسْمَعُ ، عَنْ رَجُلٍ جَعَلَ عَلَیْہِ الْمَشْیَ إلَی بَیْتِ اللہِ ، قَالَ : فَقَالَ الْقَاسِمُ : أَنَذْرٌ ؟ قَالَ : لاَ قَالَ : فَلْیُکَفِّرْ یَمِینَہُ۔",,,12562,,
12563,"حدَّثَنَا حفص ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، عَنْ عُمَرَ رضی اللَّہُ عَنْہُ ، قَالَ : نَذَرْت نَذْرًا فِی الْجَاہِلِیَّۃِ ، ثُمَّ أَسْلَمْت ، فَسَأَلْت النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَأَمَرَنِی أَنْ أُوفِی نَذْرِی۔\n\n(بخاری 2042۔ ابوداؤد 3318)",,,12563,,
12564,"حدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ قَالَ : کُلُّ یَمِینٍ حلف بہا ہی للہ برۃ یوفی بہا فی الإسلام۔",,,12564,,
12565,"حدَّثَنَا حَفْص ، عَنْ لَیْثٍ ، عَنْ طَاوُوس فِی رَجُلٍ نَذَرَ فِی الْجَاہِلِیَّۃِ ، ثُمَّ أَسْلَمَ ، قَالَ : یُوفِی بنذْرِہِ۔",,,12565,,
12566,"حدَّثَنَا وَکِیعٌ ، عَنِ الْہُذَلِیِّ ، أَنَّ امْرَأَۃً نَذَرَتْ أَنْ تُسْرج فِی بَیْعَۃٍ وَہِیَ نَصْرَانِیَّۃٌ ، فَأَسْلَمَتْ فَأَرَادَتْ أَنْ تُوْفِیَ بنذْرِہَا ، قَالَ الْحَسَنُ وَقَتَادَۃُ : تُسْرج فِی مَسَاجِدِ الْمُسْلِمِینَ ، وَقَالَ ابْنُ سِیرِینَ : لَیْسَ عَلَیْہَا شَیْئٌ ، فَعَرَضْت أَقَاوِیلَہُمْ عَلَی الشَّعْبِیِّ ، فَقَالَ : أَصَابَ الأَصَمُّ وَأَخْطَأَ صَاحِبَاکَ ، ہَدَمَ الإِسْلاَمُ مَا کَانَ قَبْلَہُ۔",,,12566,,
12567,"حدَّثَنَا غنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَبْدِ اللہِ بْنِ مُرَّۃَ ، عَنِ ابْنِ عُمَرَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أَنَّہُ نَہَی عَنِ النَّذْرِ ، وَقَالَ : أَنَّہُ لاَ یَأْتِی بِخَیْرٍ ، وَإِنَّمَا یُسْتَخْرَجُ بِہِ مِنَ الْبَخِیلِ۔ (بخاری 6608۔ مسلم 2)",,,12567,,
12568,"حدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ عَبْدِ اللہِ بْنِ سَعِیدٍ ، عَنْ جَدِّہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إیَّاکُمْ وَالنَّذْرَ ، فَإِنَّ اللَّہَ لاَ یُنْعِمُ نِعْمَۃً عَلَی الرُّشَا ، وَإِنَّمَا ہُوَ شَیْئٌ یُسْتَخْرَجُ بِہِ مِنَ الْبَخِیلِ۔ (بخاری 6694۔ ابوداؤد 3281)",,,12568,,
12569,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنَ ، عَنْ مُحَمَّدِ بْنِ قَیْسٍ ، عَنْ أَبِیہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، أَنَّہُ قَالَ : لاَ أَنْذِرُ نَذْرًا أَبَدًا۔",,,12569,,
12570,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : إذَا قَتَلَ الْمُسْلِمُ الذِّمِّیَّ فَلَیْسَ عَلَیْہِ کَفَّارَۃٌ۔",,,12570,,
12571,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عن قیس ، عَنِ الشَّعْبِیِّ فِی الْمُسْلِمِ یَقْتُلُ الذِّمِّیَّ خَطَأً ، قَالَ : کَفَّارَتُہُمَا سَوَائٌ۔",,,12571,,
12572,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا دَاوُد بْنُ أَبِی ہِنْدٍ ، عَنِ الشَّعْبِیِّ ، قَالَ: مَرَّتْ رُفْقَۃٌ مِنْ أَہْلِ الشَّامِ، فَاشْتَرَوْا جَارِیَۃً فَأَعْتَقُوہَا ، فَطَرَحَتْ طُنًّا مِنْ قَصَبٍ عَلَی صَبِیٍّ فَقَتَلَتْہُ ، فَأُتِیَ بِہَا مَسْرُوقٌ ، فَقَالَ : الْتَمِسُوا أَوْلِیَائَہَا ، فَلَمْ یَجِدُوا أَحَدًا ، فَنَظَرَ سَاعَۃً وَتَفَکَّرَ ، وَقَالَ : قَالَ اللَّہُ : {فَمَنْ لَمْ یَجِدْ فَصِیَامُ شَہْرَیْنِ مُتَتَابِعَیْنِ} اذْہَبِی فَصُومِی شَہْرَیْنِ مُتَتَابِعَیْنِ ، وَلاَ شَیْئَ لَہُمْ عَلَیْک۔",,,12572,,
12573,"حدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : طَرَحَتْ جَارِیَۃٌ طُنًّا مِنْ قَصَبٍ عَلَی صَبِیٍّ فَقَتَلَتْہُ ، فَأُتِیَ مَسْرُوقٌ فی ذَلِکَ ، فَقَالَ : ہَلْ یعلم لَہَا مِنْ مَوَالٍ ؟ قَالُوا : لاَ نَدْرِی مَنْ مَوَالِیہَا ، قَالَ : فَہَلْ لَہَا مَالٌ ؟ قَالُوا : مَا یعْلَمُ لَہَا مَالاً ، قَالَ : فَمُرُوہَا أَنْ تَصُومَ شَہْرَیْنِ مُتَتَابِعَیْنِ۔",,,12573,,
12574,"حدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا زَکَرِیَّا بْنُ أَبِی زَائِدَۃَ ، عَنِ الشَّعْبِیِّ ، قَالَ : سُئِلَ مَسْرُوقٌ ، عَنْ ہَذِہِ الآیَۃِ : {وَمَنْ قَتَلَ مُؤْمِنًا خَطَأً فَتَحْرِیرُ رَقَبَۃٍ مُؤْمِنَۃٍ وَدِیَۃٌ مُّسَلَّمَۃٌ إلَی أَہْلِہِ} {فَمَنْ لَمْ یَجِدْ فَصِیَامُ شَہْرَیْنِ مُتَتَابِعَیْنِ} : فَسُئِلَ عَنْ صِیَامِ شَہْرَیْنِ عَنِ الرَّقَبَۃِ وَحْدَہَا ، أَوْ عَنِ الدِّیَۃِ وَالرَّقَبَۃِ ، فَقَالَ : مَنْ لَمْ یَجِدْ فَہُوَ عن الدِّیَۃِ وَالرَّقَبَۃِ۔",,,12574,,
12575,"حدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ الْفَزَارِیُّ ، عَنْ عَبْدِ اللہِ بْنِ عَبْدِ الرَّحْمَانِ الطَّائِفِیِّ ، عَنْ مَیْمُونَۃَ بِنْتِ کَرَدْمِ الْیَسَارِیَّۃِ ، أَنَّ أَبَاہَا لَقِیَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہِیَ رَدِیفَۃٌ لَہُ ، فَسَأَلَہُ ، فَقَالَ : إنِّی نَذَرْت أَنْ أَنْحَرَ بِبُوَانَۃَ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : ہَلْ بِہَا وَثَنٌ ؟ قَالَتْ : قَالَ أَبِی : لاَ ، فَقَالَ لَہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : فَأَوْفِ نَذْرِکَ حَیْثُ نذَرْتَ۔ (ابوداؤد 3302۔ احمد 6/366)",,,12575,,
12576,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حَبِیبٍ الْمُعَلِّمِ ، عَنْ عَطَائٍ ، عَنْ جَابِرٍ ، أَنَّ رَجُلاً نَذَرَ أَنْ یُصَلِّیَ فِی بَیْتِ الْمَقْدِسِ ، فَسَأَلَ عَنْ ذَلِکَ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ لَہُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلِّ ہُنَا ، یَعْنِی فِی الْمَسْجِدِ الْحَرَامِ ، فَأَعَادَ عَلَیْہِ ثَلاَثًا ، فَقَالَ : صَلِّ حَیْثُ قلت۔\n(ابوداؤد 3298۔ احمد 3/363",,,12576,,
12577,"حدَّثَنَا حفْصٌ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ : سُئِلَ عَنْ رَجُلٍ نَذَرَ أَنْ یَأْتِیَ بَیْتَ الْمَقْدِسِ ، فَقَالَ : إِنْ عَدَلَہُ إلَی الْمَسْجِدِ الْحَرَامِ کَانَ أَوْفَی۔",,,12577,,
12578,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ فِی رَجُلٍ نَذَرَ أَنْ یَحُجَّ إلَی الْمَدَائِنِ، قَالَ : لِیُکَفِّرْ عَنْ یَمِینِہِ ، وَلاَ یَذْہَبْ إلَی الْمَدَائِنِ۔",,,12578,,
12579,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ فِی رَجُلٍ نَذَرَ أَنْ یَمْشِیَ إلَی الرُّسْتَاقِ ، قَالَ : یَمْشِی۔",,,12579,,
12580,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ عَبْدِ الْمَلِکِ بْنِ أَبِی سُلَیْمَانَ ، قَالَ : سُئِلَ عَطَائٌ ، عَنْ رَجُلٍ جَعَلَ عَلَیْہِ أَنْ یُصَلِّیَ فِی مَسْجِدِ إیلِیَائَ کَذَا وَکَذَا رَکْعَۃً ، قَالَ : لِیُصَلِّ عَدَدَ ذَلِکَ فِی الْمَسْجِدِ الْحَرَامِ ، فَإِنَّہُ یُجْزِئُ عَنْہُ ، وَالصَّلاَۃُ فِی الْمَسْجِدِ الْحَرَامِ أَفْضَلُ۔",,,12580,,
12581,"حدَّثَنَا أبُو أُسَامَۃَ ، عَنِ أَشْعَث ، عَنِ الْحَسَنِ ؛ فِی امْرَأَۃٍ نَذَرَتْ أَنْ تَأْتِیَ مَکَانًا قَدْ سَمتہُ ، قَالَ : لِتَنْظُرَ قَدْرَ نَفَقَتِہَا ، فَتَصَدَّقَ بہ ، وَلاَ تَأْتِیہِ۔",,,12581,,
12582,"حدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ مَرْوَانَ بْنِ مَاہَانَ التَّیْمِیِّ ، قَالَ : سَمِعْتُ الشَّعْبِیَّ وَسُئِلَ عَنِ امْرَأَۃٍ نَذَرَتْ أَنْ تَنْحَرَ بَقَرَۃً ، أَلَہَا أَنْ تَبِیعَ جِلْدَہَا ؟ فَقَالَ : نَعَمْ ، فَقَالَ ابْنُ أَشْوَعَ : لَکِنِّی لَسْت أَدْرِی ذَلِکَ ، فَقَالَ الشَّعْبِیُّ : لَوْ قُلْتُ لَحْمُہَا لَمْ یَکُنْ بِہِ بَأْسٌ ، إنَّمَا نَذَرَتْ دَمَہَا فَقَدْ أَہْرَقَتْ دَمَہَا۔",,,12582,,
12583,"حدَّثَنَا شَرِیکٌ ، عَنْ أَبِی ہِلاَلٍ ، قَالَ : نَذَرَتْ أُمِّی إِنْ رَأَتْ فِی وَجْہِی شَعَرَۃً أَنْ تَنْحَرَ بَدَنَۃً ، أَوْ قَالَ : ہَدْیًا ، قَالَ : وَکَانَ الْحَیُّ یَذْبَحُونَ الْبَقَرَۃَ ، قَالَ : فَأَتَیْت شُرَیْحًا فَسَأَلْتُہُ فَسَوَّی بَیْنَہُمَا۔",,,12583,,
12584,"حدَّثَنَا مُحَمَّدُ بْنُ عُبَیْدٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ فِی رَجُلٍ جَعَلَ عَلَیْہِ بَدَنَۃً لِلْمَسَاکِینِ ، قَالَ : یُجْزِیہِ بَقَرَۃٌ",,,12584,,
12585,"حدَّثَنَا عَبْدُ الْعَزِیزِ بْنُ مُحَمَّدٍ الدَّرَاوَرْدِیُّ ، عَنْ مُوسَی بْنِ مَعبَد ، أَنَّہُ کَانَ عَلَی امْرَأَۃٍ مِنْ أَہْلِہِ اعْتِکَافَ شَہْر فِی الْمَسْجِدِ ، فَاعْتَکَفَتْ تِسْعَۃً وَعِشْرِینَ یَوْمًا ، ثُمَّ حَاضَتْ فَرَجَعَتْ إلَی أَہْلِہَا ، ثُمَّ طَہُرَتْ فَوَقَعَ عَلَیْہَا زَوْجُہَا ، قَالَ : فَجِئْت سَالِمًا وَالْقَاسِمَ ، فَقَالا : اذْہَبْ إلَی سَعِیدِ بْنِ الْمُسَیَّبِ ، ثُمَّ ائْتِنَا ، قَالَ : فَذَہَبْت إلَی سَعِیدٍ فَسَأَلْتُہُ ، فَقَالَ : خانا حَدًّا مِنْ حُدُودِ اللہِ ، وَأَخْطَاَ السُّنَّۃَ ، وَعَلَیْہَا أَنْ تَسْتَأْنِفَ ، قَالَ : فَرَجَعْت إلَی الْقَاسِمِ وَسَالِمٍ فَأَخْبَرْتُہُمَا بِمَا قَالَ : فَقَالاَ : ذَلِکَ رَأْیُنَا۔",,,12585,,
12586,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی نَجِیحٍ، عَنْ مُجَاہِدٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: إذَا جَامَعَ الْمُعْتَکِفُ أَبْطَلَ اعْتِکَافَہُ وَاسْتَأْنَفَ۔",,,12586,,
12587,"حدَّثَنَا وَکِیعٌ ، عَنْ شَرِیکٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ بُکَیْرِ بْنِ الأَخْنَسِ ، عَنْ مُجَاہِدٍ فِی الْمُعْتَکِفِ إذَا جَامَعَ ، قَالَ : یَتَصَدَّقُ بِدِینَارَیْنِ",,,12587,,
12588,"حدَّثَنَا أبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ غَشِیَ امْرَأَتَہُ وَہُوَ مُعْتَکِفٌ : أَنَّہُ بِمَنْزِلَۃِ الَّذِی غَشِیَ فِی رَمَضَانَ ، عَلَیْہِ مَا عَلَی الَّذِی غَشِیَ فِی رَمَضَانَ۔",,,12588,,
12589,"حدَّثَنَا حفْصٌ ، عَنْ أَشْعَثَ ، عَنْ عَطَائٍ ، قَالَ : یَقْضِی اعْتِکَافَہُ۔",,,12589,,
12590,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَلْقَمَۃَ بْنِ مَرْثَدٍ ، عَنِ الضَّحَّاکِ ، قَالَ : کَانُوا یُجَامِعُونَ وَہُمْ مُعْتَکِفُونَ، حَتَّی نَزَلَتْ : {وَلاَ تُبَاشِرُوہُنَّ وَأَنْتُمْ عَاکِفُونَ فِی الْمَسَاجِدِ}۔",,,12590,,
12591,"حدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : مَنْ أَصَابَ امْرَأَتَہُ وَہُوَ مُعْتَکِفٌ فَعَلَیْہِ مِن الْکَفَّارَۃِ مِثْلُ مَا عَلَی الَّذِی یُصِیبُ فِی رَمَضَانَ۔",,,12591,,
12592,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا جَامَعَ الْمُعْتَکِفُ اسْتَقْبَلَ۔",,,12592,,
12593,"حدَّثَنَا ابْنُ مُسْہِرٍ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنِ الشَّعْبِیِّ فِی امْرَأَۃٍ نَذَرَتْ أَنْ تَعْتَکِفَ خَمْسِینَ یَوْمًا ، فَاعْتَکَفَتْ أَرْبَعِینَ یَوْمًا ، ثُمَّ جَائَ زَوْجُہَا فَأَرْسَلَ إلَیْہَا ، فَأَتَتْہُ ، قَالَ : تُتِمُّ مَا بَقِیَ۔",,,12593,,
12594,"حدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یَغْشَی امْرَأَتَہُ وَہُوَ مُعْتَکِف ، قَالَ : یُحَرِّرُ مُحَرَّرًا۔",,,12594,,
12595,"حدَّثَنَا حفص ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : کُلُّ شَیْئٍ فِی الْقُرْآنِ : أَوْ أَوْ فَہُوَ فِیہِ مُخَیَّرٌ ، وَکُلُّ شَیْئٍ فِیہِ : (فَمَنْ لَمْ یَجِدْ) فَالَّذِی یَلِیہِ ، فَإِنْ لَمْ یَجِدْ فَالَّذِی یَلِیہِ۔",,,12595,,
12596,حدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ دَاوُدَ بْنِ أَبِی ہِنْدٍ ، عَنْ عِکْرِمَۃَ مِثْلَہُ۔,,,12596,,
12597,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ الْمَسْعُودِیِّ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : مَا کَانَ فِی الْقُرْآنِ : أَوْ أَوْ فَصَاحِبُہُ مُخَیَّرٌ۔",,,12597,,
12598,"حدَّثَنَا مُحَمَّدُ بْنُ یَزِیدَ ، عَنْ أَیُّوبَ أَبِی الْعَلاَئِ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ؛ فِی رَجُلَیْنِ قَتَلاَ قَتِیلاً جَمِیعًا، قَالَ : عَلَیْہِمَا کَفَّارَتَانِ۔",,,12598,,
12599,"حدَّثَنَا مُحَمَّدُ بْنُ یَزِیدَ ، عَنْ أَیُّوبَ أَبِی الْعَلاَئِ ، عَنْ أَبِی ہَاشِمٍ ، عَنْ عُمَرَ رضی اللَّہُ عَنْہُ ، قَالَ : عَلَیْہِمَا کَفَّارَۃٌ وَاحِدَۃٌ",,,12599,,
12600,"حدَّثَنَا أبُو دَاوُد ، عَنْ شُعْبَۃَ ، عَنْ مُغِیرَۃَ ، عَنِ الشَّعْبِیِّ ، قَالَ : أَلاَ تَرَی لَوْ أَنَّ قَوْمًا قَتَلُوا رَجُلاً اشْتَرَکُوا فِی قَتْلِہِ ، کان عَلَی کُلِّ وَاحِدٍ مِنْہُمْ کَفَّارَۃٌ۔",,,12600,,
12601,"حدَّثَنَا أبُو دَاوُد ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنِ الشَّعْبِیِّ ، قَالَ : لَوْ أَنَّ قَوْمًا اجْتَمَعُوا عَلَی قَتْلِ رَجُلٍ کَانَ عَلَی کُلِّ وَاحِدٍ مِنْہُمْ کَفَّارَۃٌ ، یَعْنِی خَطَأً ، قَالَ : وَکَانَ الْحَکَمُ یَرَی ذَلِکَ۔",,,12601,,
12602,"ابْنُ نُمَیْرٍ ، عَنْ أَبِی حَنِیفَۃَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا قَتَلَ الْقَوْمُ الرَّجُلَ فَعَلَی کُلِّ وَاحِدٍ مِنْہُمُ التَّحْرِیرُ۔",,,12602,,
12603,"حدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللہِ الأَسَدِیُّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ بُرْدٍ أَبِی الْعَلاَئِ ، عَنْ مَکْحُولٍ فِی الْقَوْمِ یَقْتُلُونَ الرَّجُلَ ، قَالَ : عَلَی کُلِّ رَجُلٍ مِنْہُمْ کَفَّارَۃٌ ، وَعَلَیْہِمْ جَمِیعًا الدِّیَۃُ۔",,,12603,,
12604,"حدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ الْعَبْدِیُّ ، عَنْ مِسْعَرٍ ، عَنْ عُبَیْدِ بْنِ الْحَسَنِ ، عَنِ ابْنِ مَعْقِلٍ ، قَالَ : کَانَ عَلَی عَائِشَۃَ رَقَبَۃٌ ، أَوْ نَسَمَۃٌ تُعْتِقُہَا مِنْ وَلَدِ إسْمَاعِیلَ ، قَالَ : فَقَدِمَ بسَبْی مِنَ الْیَمَنِ ، قَالَ مِسْعَرٌ : أَرَاہُ مِنْ قَبِیلَۃٍ، یُقَالُ لَہَا : خَوْلاَنُ ، قَالَ : فَنَہَاہَا أَنْ تُعْتِقَ مِنْہُمْ ، قَالَ : فَقَدِمَ بسَبْی مِنْ مُضَرَ ، أَرَاہُ ، قَالَ : مِنْ بَنِی الْعَنْبَرِ ، فَأَمَرَہَا أَنْ تُعْتِقَ مِنْہُمْ۔",,,12604,,
12605,"حدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ زَکَرِیَّا بْنِ أَبِی زَائِدَۃَ ، قَالَ : سُئِلَ عَامِرٌ ، عَنْ رَجُلٍ جَعَلَ عَلَیْہِ مُحَرَّرِینَ مِنْ وَلَدِ إسْمَاعِیلَ إِنْ دَخَلَ بَیْتَ فُلاَنٍ ، فَدَخَلَہُ ، قَالَ : لَیْسَ لَہَا کَفَّارَۃٌ ، قَالَ : الرَّجُلُ : فإنِّی لاَ أَجِدُہُمَا قَالَ : فصُمْ أَرْبَعَۃَ أَشْہُرٍ مُتَتَابِعَاتٍ ، عَنْ کُلِّ رَقَبَۃٍ شَہْرَیْنِ لَعَلَّہُ أَنْ یُکَفِّرَ شَیْئًا۔",,,12605,,
12606,"حدَّثَنَا أبُو مُعَاوِیَۃَ، عَنِ الأَعْمَشِ، عَنْ أَبِی ظَبْیَانَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: الْحِینُ قَدْ یَکُونُ غَدْوَۃً وَعَشِیَّۃً۔",,,12606,,
12607,"حدَّثَنَا أبُو الأَحْوَص، عَنْ عَطَائِ بْنِ السَّائِبِ، عَنْ رَجُلٍ مِنْہُمْ ، قَالَ: سَأَلْتُ ابْنَ عبَّاسٍ، قُلْتُ: إنِّی حَلَفْت أن لاَ أُکَلِّمَ رَجُلاً حِینًا ، قَالَ : فَقَرَأَ ابْنُ عَبَّاسٍ : {تُؤْتِی أُکُلَہَا کُلَّ حِینٍ بِإِذْنِ رَبِّہَا} ، قَالَ : الْحِینُ سَنَۃٌ۔",,,12607,,
12608,"حدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ دَاوُدَ ، عَنْ عِکْرِمَۃَ ، قَالَ : الْحِینُ سِتَّۃُ أَشْہُرٍ۔",,,12608,,
12609,"حَدَّثَنَا إسْمَاعِیلُ بْنُ إبْرَاہِیمَ ، عَنْ أَیُّوبَ ، عَنْ عِکْرِمَۃَ ، قَالَ : الْحِینُ سِتَّۃُ أَشْہُرٍ۔",,,12609,,
12610,"حدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ حَرْمَلَۃَ ، قَالَ : سَمِعْتُ سَعِیدَ بْنَ الْمُسَیَّبِ وَسَأَلَہُ رَجُلٌ ، فَقَالَ : إنِّی حَلَفْت عَلَی امْرَأَتِی أَنْ لاَ تَدْخُلَ علی أَہْلِہَا حِینًا ، فَقَالَ : الْحِینُ مَا بَیْنَ أَنْ تَطْلُعَ النَّخْلُ إلَی أَنْ تُثْمِرَ ، وَمَا بَیْنَ أَنْ تُثْمِرَ إلَی أَنْ تُطْلعَ ، فَقَالَ لَہُ سَعِیدٌ : {ضَرَبَ اللَّہُ مَثَلاً کَلِمَۃً} إلَی قَوْلِہِ : {تُؤْتِی أُکُلَہَا کُلَّ حِینٍ بِإِذْنِ رَبِّہَا}۔",,,12610,,
12611,"حدَّثَنَا غنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ وَحَمَّادًا عَنْ رَجُلٍ حَلَفَ أَنْ لاَ یُکَلِّمَ رَجُلاً حِینًا ، فَقَالاَ : الْحِینُ سَنَۃٌ۔",,,12611,,
12612,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ طَارِق ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : الْحِینُ سِتَّۃُ أَشْہُرٍ۔",,,12612,,
12613,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ مُحَمَّدِ بْنِ مُسْلِمٍ ، عَنْ إبْرَاہِیمَ بْنِ مَیْسَرَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ: الْحِینُ شَہْرَانِ ، إن النَّخْلَۃَ تُطْعِمُ السَّنَۃَ کُلَّہَا إلاَّ شَہْرَیْنِ۔",,,12613,,
12614,"حدَّثَنَا مُعَاوِیَۃُ بْنُ عَمْرٍو ، عَنْ زَائِدَۃَ ، عَنْ إبْرَاہِیمَ بْنِ مُہَاجِرٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : الْحِینُ سِتَّۃُ أَشْہُرٍ۔",,,12614,,
12615,"حدَّثَنَا وَکِیعٌ ، عَنْ عِکْرِمَۃَ بْنِ عَمَّارٍ ، عَنْ عَاصِمِ بْنِ شُمَیْخٍ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا اجْتَہَدَ فِی الْیَمِینِ ، قَالَ : لاَ وَالَّذِی نَفْسُ أَبِی الْقَاسِمِ بِیَدِہِ۔\n\n(ابوداؤد 3259۔ احمد 3/48)",,,12615,,
12616,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُوسَی بْنِ عُقْبَۃَ ، عَنْ سَالِمٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : کَانَتْ یَمِینُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الّتِی یَحْلِفُ عَلَیْہَا : لاَ وَمُقَلِّبِ الْقُلُوبِ۔ (بخاری 7391۔ ابوداؤد 3258",,,12616,,
12617,"حدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنْ مُحَمَّدِ بْنِ ہِلاَلٍ ، عَنْ أَبِیہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : کَانَتْ یَمِینُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ وَأَسْتَغْفِرُ اللَّہَ۔ (ابوداؤد 3260۔ احمد 2/288)",,,12617,,
12618,"حدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، عَنْ أَبِیہِ ، قَالَ : کُنْتُ جَالِسًا مَعَ ابْنِ مَسْعُودٍ فَوْقَ بَیْتِہِ ، فَوَجَبَتِ الشَّمْسُ ، فَقَالَ عَبْدُ اللہِ : ہَذَا وَالَّذِی لاَ إلَہَ غَیْرُہُ حِینَ أَفْطَرَ الصَّائِمُ",,,12618,,
12619,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ أَبِی الْمِنْہَالِ ، عَنْ عَبَّادِ بْنِ عَبْدِ اللہِ ، قَالَ : کَانَ عَلِیٌّ رضی اللَّہُ عَنْہُ یَخْطُبُ ، فَقَالَ : لاَ وَالَّذِی فَلَقَ الْحَبَّۃَ وَبَرَأَ النَّسَمَۃَ۔",,,12619,,
12620,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ یَحْیَی بْنِ جَعْدَۃَ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ، قَالَ : سَمِعْتُ أَبَا ہُرَیْرَۃَ یَقُولُ : لاَ وَرَبِّ ہَذِہِ الْکَعْبَۃِ۔",,,12620,,
12621,"حدَّثَنَا شَرِیکٌ ، عَنْ عَبْدِ الْمَلِکِ بْنِ عُمَیْرٍ ، عَنْ زِیَادِ الْحَارِثِیِّ ، قَالَ : قَالَ رَجُلٌ لأَبِی ہُرَیْرَۃَ : أَنْتَ الَّذِی تَنْہَی عَنْ صَوْمِ یَوْمِ الْجُمُعَۃِ ؟ فَقَالَ : لاَ وَرَبِّ ہَذِہِ الْحُرْمَۃِ ، أَوْ ہَذِہِ الْبِنْیَۃِ۔",,,12621,,
12622,"حدَّثَنَا حفْصٌ وَأَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، عَنْ عَبْدِ اللہِ ، أَنَّہُ قَالَ : وَالَّذِی لاَ إلَہَ غَیْرُہُ۔",,,12622,,
12623,"حدَّثَنَا أبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ خَیْثَمَۃَ ، عَنْ مَسْرُوقٍ ، أَنَّ عَائِشَۃَ ، قَالَتْ فِی شَیْئٍ حَلَفْت عَلَیْہِ: لاَ وَالَّذِی آمَنَ بِہِ الْمُؤْمِنُونَ وَکَفَرَ بِہِ الْکَافِرُونَ۔ (ابن سعد 82",,,12623,,
12624,"حدَّثَنَا مُحَمَّدُ بْنُ مُصْعَبٍ ، عَنِ الأَوْزَاعِیِّ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ ہِلاَلِ بْنِ أَبِی مَیْمُونَۃَ ، عَنْ عَطَائِ بْنِ یَسَارٍ ، عَنْ رِفَاعَۃَ الْجُہَنِیِّ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا حَلَف ، قَالَ : وَالَّذِی نَفْسُ مُحَمَّدٍ بِیَدِہِ۔ (احمد 16)",,,12624,,
12625,"حدَّثَنَا رَوْحُ بْنُ عُبَادَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی أَبُو الزُّبَیْرِ ، أَنَّہُ سَمِعَ سَعِیدَ بْنَ جُبَیْرٍ قَالَ : قَالَ ابْنُ عَبَّاسٍ : إِنْ فَائَ کَفَّرَ ، وَإِنْ لَمْ یَفْعَلْ فَہِیَ وَاحِدَۃٌ وَہِیَ أَحَقُّ بِنَفْسِہَا۔",,,12625,,
12626,"حدَّثَنَا أبُو دَاوُد الطَّیَالِسِیُّ ، عَنْ ہَارُونَ بْنِ إبْرَاہِیمَ ، عَنِ ابْنِ سِیرِینَ ، عَنْ عَبْدِ اللہِ بْنِ جُبَیْرٍ ، أَنَّ زَیَادًا أَبْصَرَ أَبَا مُوسَی کَئِیبًا ، فَقَالَ لَہُ : مَا لَکَ ؟ فَذَکَرَ أَنَّہُ آلَی مِنِ امْرَأَتِہِ ، فَأَمَرَہُ أَنْ یُکَفِّرَ ، فَفَعَلَ۔",,,12626,,
12627,"حدَّثَنَا غنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، عَن أَبِی الشَّعْثَائِ ، عَنْ عَلْقَمَۃَ ، وَأَصْحَابُ عَبْدِ اللہِ ، أَنَّہُمْ قَالُوا : ؛ فِی الرَّجُلِ إذَا آلَی مِنِ امْرَأَتِہِ ، ثُمَّ أَتَاہَا قَبْلَ أَنْ تَبَرَّ یَمِینَہُ ، قَالَ : یُکَفِّرُ یَمِینَہُ۔",,,12627,,
12628,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ شُعْبَۃَ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، عَن أَبِی الشَّعْثَائِ ، عَنْ عَلْقَمَۃَ ، قَالَ : إذَا فَائَ المُولَی کَفَّرَ۔",,,12628,,
12629,"حدَّثَنَا الثَّقَفِیُّ، عَنْ خَالِدٍ، عَنْ مُحَمَّدِ بْنِ سِیرِینَ، قَالَ: إذَا آلَی الرَّجُلُ مِنِ امْرَأَتِہِ، ثُمَّ فَائَ فَعَلَیْہِ الْکَفَّارَۃُ۔",,,12629,,
12630,حدَّثَنَا أبُو دَاوُد ، عَنْ زَمْعَۃَ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، أَنَّہُ کَانَ لاَ یَرَی عَلَیْہِ الْکَفَّارَۃَ فِی یَمِینِہِ۔,,,12630,,
12631,"ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ أنہ کَانَ یَقُولُ : فَیؤُہُ کَفَّارَۃ۔",,,12631,,
12632,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ فِی الَّذِی یُولِی مِنِ امْرَأَتِہِ فَیَفِیئُ ، قَالَ : کَانَ بَعْضُہُمْ یَقُولُ : فَیؤُہُ کَفَّارَۃ۔",,,12632,,
12633,"حدَّثَنَا غنْدَرٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یَحْلِفُ أن لاَ یَقْرَبُ امْرَأَتَہُ عَشَرَۃَ أَیَّامٍ ، ثُمَّ قَرُبَہَا قَبْلَ الْعَشَرَۃِ ، قَالَ : لاَ کَفَّارَۃَ عَلَیْہِ۔",,,12633,,
12634,"حدَّثَنَا ہُشَیْمٌ، عَنْ یُونُسَ، عَنِ الْحَسَنِ؛ فِی رَجُلٍ جَعَلَ عَلَیْہِ صَوْمَ شَہْرٍ، قَالَ: إن سَمَّی شَہْرًا مَعْلُومًا فَلْیَصُمْہُ وَلْیُتَابِعْ ، وَإِذَا لَمْ یُسَمِّ شَہْرًا مَعْلُومًا ، أو لَمْ یَنْوِہِ فَلْیَسْتَقْبِلِ الأَیَّامَ ، فَلْیَصُمْ ثَلاَثِینَ یَوْمًا ، وَإِنْ صَامَ عَلَی الْہِلاَلِ ، وَأَفْطَرَ عَلَی رُؤْیَتِہِ فَکَانَتْ تِسْعَۃً وَعِشْرِینَ یَوْمًا أَجْزَأَہُ ذَلِکَ ، وَإِنْ فَرَّقَ إذًا اسْتَقْبَلَ الأَیَّامَ۔",,,12634,,
12635,"حدَّثَنَا الثَّقَفِیُّ ، عَنْ خَالِدٍ ، عَنْ أَبِی قِلاَبَۃَ ؛ فِی الرَّجُلِ یَجْعَلُ عَلَیْہِ صَوْمَ شَہْرٍ ، قَالَ : ہُوَ أَعْلَمُ بِمَا جَعَلَ، وَجَعَلہ یَمِینَہُ۔",,,12635,,
12636,"حدَّثَنَا ابن نُمَیرٍ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، وَعَنْ حَمَّاد ، عَنْ إبْرَاہِیمَ ، قَالاَ : إذَا جَعَلَ الرَّجُلُ عَلَیْہِ صَوْمَ شَہْرٍ ، وَلَمْ یُسَمِّ شَہْرًا مِنَ الشُّہُورِ ، قَالَ : إِنْ شَائَ تَابَعَ ، وَإِنْ شَائَ فَرَّقَ۔",,,12636,,
12637,"حدَّثَنَا کثیر بْنُ ہِشَامٍ ، عَنْ جَعْفَرٍ ، عَنْ مَیْمُونٍ ، قَالَ : النَّذْرُ فِی الصِّیَامِ مُتَتَابِعٌ۔",,,12637,,
12638,"حدَّثَنَا حفْصٌ ، عَنْ حَجَّاجٍ ، قَالَ : سَأَلْتُ عَطَائً ، وَحَدَّثَنِی مَنْ سَأَلَ إِبْرَاہِیمَ ، عَن رَجُلٍ نَذَرَ أَنْ یَصُومَ شَہْرًا ، قالا یَصُوم ثَلاَثِینَ ، یَعْنِی مُتَفَرِّقًا۔",,,12638,,
12639,"حدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ، قَالَ : کَانَ لاَ یَرَی بَأْسًا أَنْ یُطْعِمَ مِسْکِینًا وَاحِدًا عَشْرَ مَرَّاتٍ فِی کَفَّارَۃِ الْیَمِینِ۔",,,12639,,
12640,"حدَّثَنَا حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : لاَ یُجْزِئُ فِی کَفَّارَۃِ الْیَمِینِ إلاَّ إطْعَامُ عَشَرَۃِ مَسَاکِینَ۔",,,12640,,
12641,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنِ الشَّعْبِیِّ ؛ فِی الرَّجُلِ لاَ یَجِدُ مَسَاکِینَ مُسْلِمِینَ ، فَیُعْطِی الْیَہُودَ وَالنَّصَارَی ، فَقَالَ الشَّعْبِیُّ : یُجْزِیہِ ، وَقَالَ الْحَکَمُ : لاَ یُجْزِیہِ ، وَقَالَ إبْرَاہِیمُ : فَإِنِّی أَرْجُو إذَا لَمْ یَجِدْ غَیْرَہُمْ یُجْزِیہِ۔",,,12641,,
12642,"حدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ ہِشَامٍ عَمَّنْ حَدَّثَہُ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا کَانَتْ لَہُ عِشْرُونَ کَفَّرَ۔",,,12642,,
12643,حدَّثَنَا مُعْتَمِرٌ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَابْنِ سِیرِینَ أَنَّہُمَا کَانَا لاَ یُوَقِّتَانِ فِی ذَلِکَ شَیْئًا۔,,,12643,,
12644,"حدَّثَنَا مُعْتَمِرٌ ، قَالَ : قُلْتُ لِمَعْمَرٍ : ؛ الرَّجُلُ یَحْلِفُ وَلَیْسَ عِنْدَہُ مِنَ الطَّعَامِ إلاَّ مَا یُکَفِّرُ ، قَالَ : کَانَ قَتَادَۃُ یَقُولُ : یَصُومُ ثَلاَثَۃَ أَیَّامٍ۔",,,12644,,
12645,"حدَّثَنَا عَفَّانُ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ فِی الرَّجُلِ یَحْلِفُ وَلَیْسَ لَہُ إلاَّ ثَلاَثَۃُ دَرَاہِمَ فَیَحْنَثُ ، قَالَ : یُکَفِّرُ۔",,,12645,,
12646,"حدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِی ، عَنْ سَعِیدٍ ، عَنْ فَرْقَدٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا کَانَ لَہُ عِشْرُونَ دِرْہَمًا فَعَلَیْہِ الْکَفَّارَۃُ۔",,,12646,,
12647,حدَّثَنَا ابْنُ أَبِی زَائِدَۃَ ، عَنْ سُفْیَانَ ، عَنْ سَعِیدٍ بْنِ أَبِی عَرُوبَۃَ ، عَنْ فَرْقَدٍ ، عَنْ إبْرَاہِیمَ مِثْلَہُ۔,,,12647,,
12648,"حدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ کَانَ یَقُولُ : إذَا حَلَفَ عَلَی اللَّبَنِ فَلاَ یَأْکُلَ الزُّبْدَ ، فَإِنَّہُ مِنَ اللَّبَنِ ، وَإِذَا حَلَفَ عَلَی الزُّبْدِ فَلْیَأْکُلِ اللَّبَنَ ، وَإِذَا حَلَفَ عَلَی اللَّحْمِ فَلاَ یَأْکُلُ الشَّحْمَ ، وَإِذَا حَلَفَ عَلَی الشَّحْمِ فَلْیَأْکُلِ اللَّحْمَ۔",,,12648,,
12649,"حدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، قَالَ : کَانَ أَصْحَابُنَا یَقُولُونَ : إذَا حَلَفَ عَلَی اللَّبَنِ فَلاَ یَأْکُلُ مِنَ السَّمْنِ ، وَلاَ مِنَ الْجُبْنِ ، وَإِذَا حَلَفَ عَلَی السَّمْنِ وَالْجُبْنِ أَکَلَ مِنَ اللَّبَنِ۔",,,12649,,
12650,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ سُئِلَ عَنْ رَجُلٍ ، قَالَ: لِامْرَأَتِہِ ، إِنْ أَکَلَ لَحْمًا فَامْرَأَتُہُ طَالِقٌ فَأَکَلَ سَمَکًا ، قَالَ : ہِیَ طَالِقٌ ، قَالَ اللَّہُ تَعَالَی : {تَأْکُلُونَ لَحْمًا طَرِیًّا}۔",,,12650,,
12651,"حدَّثَنَا عُمَرُ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : یَحْنَثُ ، قَالَ اللَّہُ تَعَالَی : {تَأْکُلُونَ لَحْمًا طَرِیًّا}۔",,,12651,,
12652,"حدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ دَاوُدَ بْنِ أَبِی ہِنْدٍ ، عَنْ عَامِرٍ ، قَالَ : سَأَلَ رَجُلٌ ابْنَ عَبَّاسٍ ، عَنْ رَجُلٍ نَذَرَ أَنْ یَنْحَرَ ابْنَہُ ، قَالَ : یَنْحَرُ مِئَۃ مِنَ الإِبِلِ کَمَا فَدَی بِہَا عَبْدُ الْمُطَّلِبِ ابْنَہُ ، قَالَ : وقال غَیْرُہُ : کَبْشًا کَمَا فَدَی إبْرَاہِیمُ ابْنَہُ إِسْحَاقَ ، فَسَأَلْت مَسْرُوقًا ، فَقَالَ : ہَذَا مِنْ خَطوَاتِ الشَّیْطَانِ ، لاَ کَفَّارَۃَ فِیہِ۔",,,12652,,
12653,"حدَّثَنَا عَبَّادٌ ، عَنْ خَالِدٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ فِی الرَّجُلِ یَقُولُ : ہُوَ یَنْحَرُ ابْنَہُ ، قَالَ : کَبْشٌ کَمَا فَدَی إبْرَاہِیمُ إِسْحَاقَ۔",,,12653,,
12654,"حدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنِ الْقَاسِمِ ، قَالَ : کُنْتُ عِنْدَ ابْنِ عَبَّاسٍ ، فَجَائَتْہُ امْرَأَۃٌ ، فَقَالَتْ : إنِّی نَذَرْت أَنْ أَنْحَرَ ابْنِی ، فَقَالَ : ابْنُ عَبَّاسٍ : لاَ تَنْحَرِی ابْنَک وَکَفِّرِی عَنْ یَمِینِکِ ، قَالَ : فَقَالَ رَجُلٌ عِنْدَ ابْنِ عَبَّاسٍ : إِنَّہُ لاَ وَفَائَ لِنَذْرٍ فِی مَعْصِیَۃٍ ، فَقَالَ : ابْنُ عَبَّاسٍ : أَلَیْسَ قَدْ قَالَ : اللَّہُ فِی الظِّہَارِ : {إنَّہُمْ لَیَقُولُونَ مُنْکَرًا مِنَ الْقَوْلِ وَزُورًا} ثَمَّ قَالَ فِیہِ مِنَ الْکَفَّارَۃِ مَا سَمِعْت۔",,,12654,,
12655,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنِ الْحَکَمِ ، عَنْ عَلِیٍّ فِی رَجُلٍ نَذَرَ أَنْ یَنْحَرَ ابْنَہُ ، قَالَ : یُہْدِی دِیَتَہُ۔",,,12655,,
12656,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ فِرَاسٍ ، عَنِ الشَّعْبِیِّ ، قَالَ: إذَا قَالَ: ہُوَ یَنْحَرُ ولدہُ ، قَالَ یُحِجُّہُ۔",,,12656,,
12657,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ عَطَائٍ ، قَالَ : إذَا قَالَ : ہُوَ یَنْحَرُہُ فَبَدَنَۃٌ۔",,,12657,,
12658,"حدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ مُبَارَکٍ ، عَنْ یَحْیَی ، عَنْ عِکْرِمَۃَ فِی رَجُلٍ نَذَرَ أَنْ یَنْحَرَ ابْنَہُ ، قَالَ : یَذْبَحُ کَبْشًا فَیَتَصَدَّقُ بِلَحْمِہِ ، ثُمَّ قَالَ : لَقَدْ کَانَ لَکُمْ فِی إبْرَاہِیمَ أُسْوَۃٌ حَسَنَۃٌ۔",,,12658,,
12659,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الْحَسَنِ ، عَنْ إبْرَاہِیمَ فِی رَجُلٍ نَذَرَ أَنْ یَنْحَرَ ابْنَہُ ، قَالَ : یُحِجُّہُ وَیَنْحَرُ بَدَنَۃً۔",,,12659,,
12660,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنِ ابْنِ عَبَّاسٍ ؛ فِی الرَّجُلِ یَقُولُ : ہُوَ یَنْحَرُ ابْنَہُ ، قَالَ : یُہْدِی دِیَتَہُ ، أَوْ کَبْشًا۔",,,12660,,
12661,"حدَّثَنَا أبُو أُسَامَۃَ ، عَنْ أَبِی غِفَارِ الْمُثَنَّی بن سَعِید ، قَالَ : سَأَلْتُ جَابِرَ بْنَ زَیْدٍ ، عَنْ رَجُلٍ ، قَالَ لِرَجُلٍ ہُوَ یُہْدِیک إِنْ لَمْ یَسْرِ أَہْلُک ، قَالَ : یُہْدِی کَبْشًا۔",,,12661,,
12662,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ عَطَائٍ ، قَالَ : إذَا قَالَ : ہُوَ یُہْدِی ابْنَہُ ، فَکَبْشٌ۔",,,12662,,
12663,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إِنْ قَالَ : ہُوَ یُہْدِی ابْنَہُ فَکَبْشٌ۔",,,12663,,
12664,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا قَالَ : ہُوَ یُہْدِیہِ حَافِیًا رَاجِلاً ، قَالَ : یُحِجُّہُ ، وَیَمْشِی ہُوَ حَافِیًا ، وَلاَ یَرْکَبُ وَلَکِنْ یَحْمِلُ الَّذِی حَلَفَ عَلَیْہِ۔",,,12664,,
12665,"حدَّثَنَا عَبْدُ الرَّحِیمِ ، وَوَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنِ الْحَکَمِ ، عَنْ عَلِیٍّ ؛ فِی الرَّجُلِ یَقُولُ لِلرَّجُلِ أَنَا أُہْدِیک ، وَقَالَ وَکِیعٌ : قَالَ لاِبْنِہِ ، قَالَ : یُہْدِی دِیَتَہُ۔",,,12665,,
12666,"عَبْدُ الرَّحْمَنِ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : یُحِجُّہُ۔",,,12666,,
12667,"حدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ أَشعَث ، عَنْ حَمَّاد ، عَنْ إبْرَاہِیمَ ، قَالَ : عَلَیْہِ أَنْ یُحِجَّہُ۔",,,12667,,
12668,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ إسْمَاعِیلَ بْنِ أُمَیَّۃَ ، عَنْ عُثْمَانَ بْنِ حَاضِرٍ ، عَنِ ابْنِ عَبَّاسٍ، وَابْنِ عُمَرَ، قَالاَ : یُہْدِی جَزُورًا۔",,,12668,,
12669,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سِمَاکٍ ، عَنْ مُحَمَّدِ بْنِ الْمُنْتَشِرِ ، عَنْ مَسْرُوقٍ ، قَالَ : یُہْدِی کَبْشًا۔",,,12669,,
12670,"حدَّثَنَا عَبَّادٌ ، عَنْ سُفْیَانَ بْنِ حُسَیْنٍ ، قَالَ : سَأَلْتُ الْحَسَنَ ، وَابْنَ سِیرِینَ ، عَنْ رَجُلٍ ظَاہَرَ مِنَ امْرَأَتِہِ ، وَلَمْ یُکَفِّرْ وتَہَاوَن بِذَلِکَ ، قَالاَ : تَسْتَعْدِی عَلَیْہِ۔",,,12670,,
12671,"حدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، قَالَ : إذَا قَالَ الْمُظَاہِرُ : لاَ حَاجَۃَ لِی بِہَا لَمْ یُتْرَکْ حَتَّی یُطَلِّقَ ، أَوْ یُکَفِّرَ۔",,,12671,,
12672,حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ فِی امْرَأَۃٍ جَعَلَتْ عَلَی نَفْسِہَا أوْ نَذَرَتْ أَنْ تصَلِّیَ فِی خَمْسِینَ مَسْجِدًا وَأَنْ تَصَدَّقَ مِنْ خَمْسِینَ بَیْتًا وَأَنْ تَصَدَّقَ بِہِ ، فَأَمَرَہَا أَنْ لاَ تَصَدَّقَ فَإِنَّہَا مَعْصِیَۃٌ تُکَفِّرُ یَمِینَہَا وَتُصَلِّی فِی خَمْسِینَ مَسْجِدًا لأَنَّ الصَّلاَۃَ مِنْ طَاعَۃِ اللہِ۔,,,12672,,
12673,"حدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی امْرَأَۃٍ نَذَرَتْ عَلَیْہَا أَنْ تُصَلِّیَ إلَی کُلِّ سَارِیَۃٍ مِنْ سِوَارِی مَسْجِدِ الْبَصْرَۃِ ، قَالَ : تُصَلِّی بِعَدَدِ سِوَارِی الْمَسْجِدِ فِی مَقَامٍ وَاحِدٍ۔",,,12673,,
12674,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ أَبِی الْبَخْتَرِیِّ ، عَنِ مُرَّۃَ ، قَالَ : دَخَلْت الْمَسْجِدَ وَأَنَا أُحَدِّثُ نَفْسِی أَنْ أُصَلِّیَ عِنْدَ کُلِّ أُسْطُوَانَۃٍ رَکْعَتَیْنِ ، وَرَجُلٌ یَرْمُقُنِی لاَ أَشْعُرُ بِہِ ، فَلَمَّا جَلَسْت نَظَرْت فَإِذَا عَبْدُ اللہِ جَالِسًا ، فَأَتَیْتُہُ فَجَلَسْت إلَیْہِ ، فَإِذَا الرَّجُلُ الَّذِی یَرْمُقُنِی عِنْدَہُ ، قَالَ : وَلاَ یَشْعُرُ بِمَکَانِی قَالَ: یَا أَبَا عَبْدِ الرَّحْمَنِ ، إنَّ رَجُلاً دَخَلَ الْمَسْجِدَ فَجَعَلَ یُصَلِّی عِنْدَ کُلِّ أُسْطُوَانَۃٍ رَکْعَتَیْنِ ، فَقَالَ : لَوْ عَلِمَ ، أَنَّ اللَّہَ عِنْدَ الأُسْطُوَانَۃٍ لَمْ یَتَحَوَّلْ حَتَّی یَقْضِیَ صَلاَتَہُ ، قَالَ : فَتَرَکْت بَقِیَّۃَ مَا أَرَدْت أَنْ أُصَلِّیَ۔",,,12674,,
12675,حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ بُرْدٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ أَعْتَقَ وَلَدَ الزِّنَا وَأُمَّہُ۔,,,12675,,
12676,حدَّثَنَا ابْنُ نُمَیْرٍ ، عن عُبَیْدُ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ أَعْتَقَ وَلَدَ زِنَا وَأُمَّہُ۔,,,12676,,
12677,"أبُو أُسَامَۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : کَانَ لاَ یَرَی بِعِتْقِ وَلَدِ الزِّنَا بَأْسًا۔",,,12677,,
12678,"وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ فِی عِتْقِ وَلَدِ الزِّنَا ، قَالَ لَہُ : مَا احْتَسَبَ۔",,,12678,,
12679,"حدَّثَنَا أَسْبَاطٌ ، عَنْ عَبْدِ الْمَلِکِ ، قَالَ : سُئِلَ عَطَائٌ عَنْ عِتْقِ وَلَدِ الزِّنَا أَعْتِقُہُ ؟ قَالَ : نَعَمْ عِتْقُہُ حَسَنٌ۔",,,12679,,
12680,"حدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ ، عَنْ یَزِیدَ بْنِ أَبِی حَرِیزٍ ، عَنْ مَرْیَمَ بِنْتِ أَبِی یَزِیدَ ، عَنْ أُمِّ نُجَیْدٍ ، أَنَّہَا سَأَلَتْ أَبَا أُمَامَۃَ ، عَنْ وَلَدِ الزِّنَا تُعْتِقُہُ ، قَالَ : ہُوَ کَالدِّرْہَمِ الزَّائِفِ ، تَصَدَّقِی بِہِ۔",,,12680,,
12681,"حدَّثَنَا وَکِیعٌ ، عَنْ ثَوْرِ الشَّامِیِّ ، عَنْ عُمَر بن عَبْدِ الرَّحْمَنِ بْنِ سَعْدٍ ، قَالَ : جَائَ رَجُلٌ إلَی ابْنِ عَبَّاسٍ ، فَقَالَ : إنَّ لِی غُلاَمَیْنِ ، أَحَدُہُمَا رَشْدَۃٌ وَالآخَرُ غِیَّۃٌ وَإِنِّی أُرِیدُ أَنْ أُعْتِقَ أَحَدَہُمَا ، فَأَیُّہُمَا تَرَی أَنْ أُعْتِقَ ؟ قَالَ : انظر أَکْثَرُہُمَا ثَمَنًا فوجدوا ولد وَلَدَ الزِّنا أکثرہما ثمنا فأمرہم بہ۔",,,12681,,
12682,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ فِرَاسٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : أَعْتِقْ أَکْثَرَہُمَا ثَمَنًا۔",,,12682,,
12683,حدَّثَنَا وَکِیعٌ ، قَالَ حدَّثَنَا ہِشَامٌ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، أَنَّہَا سُئِلَتْ ، عَنْ وَلَدِ الزِّنَا ، فَقَالَتْ ، لَیْسَ عَلَیْہِ مِنْ خَطِیئَۃِ أَبَوَیْہِ شَیْئٌ ، {لاَ تَزِرُ وَازِرَۃٌ وِزْرَ أُخْرَی}۔,,,12683,,
12684,"حدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عِیسَی الْخَبَّاطُ ، قَالَ : سَمِعْتُ الشَّعْبِیَّ یَقُولُ : وَلَدُ الزِّنَا خَیْرُ الثَّلاَثَۃِ ، إنَّمَا ہذا شَیْئٌ قَالَہُ کَعْبٌ ہُوَ شَرُّ الثَّلاَثَۃِ",,,12684,,
12685,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، أَنَّ عُمَرَ ، قَالَ : لأَنْ أَحْمِلَ عَلَی نَعْلَیْنِ فِی سَبِیلِ اللہِ أَحَبُّ إلَیَّ مِنْ أَنْ أُعْتِقَ وَلَدَ زِنًا۔",,,12685,,
12686,حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ ، عَنْ مُجَاہِدٍ ، عَنْ عَائِشَۃَ ، قَالَتْ ، لأَنْ أَتَصَدَّقَ بِثَلاَثَۃِ نَوَیَاتٍ ، أَوْ أُمَتِّعَ بِسَوْطٍ فِی سَبِیلِ اللہِ أَحَبُّ إلَیَّ مِنْ أَنْ أُعْتِقَ وَلَدَ الزِّنَا۔,,,12686,,
12687,حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُجَاہِدٍ ، قَالَ أَعْتَقَ الْعَبَّاسُ بَعْضَ رَقِیقِہِ فِی مَرَضِہِ ، فَرَدَّ ابْنُ عَبَّاسٍ مِنْہُمَا اثْنَیْنِ کَانُوا یَرَوْنَ أَنَّہُمَا أَوْلاَدُ زِنًا۔,,,12687,,
12688,حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، أَنَّ عَمْرَو بْنَ الْعَاصِ أَعْتَقَ رَقِیقَہُ فِی مَرَضِہِ ، فَرَدَّ عَبْدُ اللہِ بْنُ عَمْرٍو مِنْہُمْ سِتَّۃً کَانُوا یَرَوْنَ أَنَّہُمَا أَوْلاَدُ الزِّنَا۔,,,12688,,
12689,حدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ عَبْدِ الأَعْلَی ، عَنِ ابْنِ الْحَنَفِیَّۃِ ، عَنْ عَلِیٍّ ، أَنَّہُ کَرِہَ عِتْقَ وَلَدِ الزِّنَا۔,,,12689,,
12690,"حدَّثَنَا شَرِیکٌ ، عَنْ أَبِی ہِلاَلٍ ، عَنْ أُسَّقٍ ، قَالَ : کُنْتُ مَمْلُوکًا لِعُمَرَ ، فَکَانَ یَعْرِضُ عَلَیْہِ الإِسْلاَمَ وَیَقُولُ : {لاَ إکْرَاہَ فِی الدِّینِ} فَلَمَّا حُضِرَ أَعْتَقَہ۔",,,12690,,
12691,حدَّثَنَا شَرِیکٌ ، عَنْ عُبَیْدَۃَ ، عَنْ عَامِرٍ ، أَنَّ عُمَرَ أَعْتَقَ یَہُودِیًّا ، أَوْ نَصْرَانِیًّا۔,,,12691,,
12692,حدَّثَنَا شَرِیکٌ ، عَنْ عُبَیْدَۃَ ، عَنْ إبْرَاہِیمَ ، أَنَّ عَلِیًّا أَعْتَقَ نَصْرَانِیًّا ، أَوْ یَہُودِیًّا۔,,,12692,,
12693,حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ برد ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ أَعْتَقَ غُلاَمًا لَہُ نَصْرَانِیًّا کَانَ وَہَبَہُ لِبَعْضِ أَہْلِہِ ، فَرَجَعَ إلَیْہِ فِی مِیرَاثٍ فَأَعْتَقَہُ۔,,,12693,,
12694,حدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ أَعْتَقَ غُلاَمًا لَہُ نَصْرَانِیًّا۔,,,12694,,
12695,حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، أَنَّہُ کَرِہَ أَنْ یُعْتَقَ النَّصْرَانِیُّ۔,,,12695,,
12696,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ یَعْلَی بْنِ عَطَائٍ عَمَّنْ سَمِعَ أَبَا ہُرَیْرَۃَ یَقُولُ : إنَّمَا الصَّوْمُ فِی کَفَّارَۃِ الْیَمِینِ عَلَی مَنْ لَمْ یَجِدْ۔",,,12696,,
12697,"حدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ إسْمَاعِیلَ ، عَنِ الْحَسَنِ ، وَابْنِ سِیرِینَ ، قَالاَ : إذَا وَجَدْت فَلاَ تَصُمْ۔",,,12697,,
12698,حدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ إبْرَاہِیمَ بْنِ مُہَاجِرٍ ، عَنْ عَامِرِ بْنِ مُصْعَبٍ ، أَنَّ عَائِشَۃَ اعْتَکَفَتْ عَنْ أَخِیہَا بَعْدَ مَا مَاتَ۔,,,12698,,
12699,"حدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، قَالَ : سُئِلَ طَاوُوس ، عَنِ امْرَأَۃٍ مَاتَتْ وَعَلَیْہَا أَنْ تَعْتَکِفَ سَنَۃً فِی الْمَسْجِدِ الْحَرَامِ ، وَلَہَا أَرْبَعَۃُ بَنُونَ کُلُّہُمْ یُحِبُّ أَنْ یَقْضِیَ عَنْہَا ، قَالَ طَاوُوس : اعْتَکِفُوا ، أَرْبَعَتُکُمْ فِی الْمَسْجِدِ الْحَرَامِ ثَلاَثَۃَ أَشْہُرٍ وَصُومُوا۔",,,12699,,
12700,"حدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عُبَیْدِ اللہ بن عَبْدِ اللہِ بْنِ عُتْبَۃَ ، أَنَّ امْرَأَۃً نَذَرَتْ أَنْ تَعْتَکِفَ عَشَرَۃَ أَیَّامٍ ، فَمَاتَتْ وَلَمْ تَعْتَکِفْ ، فَقَالَ : ابْنُ عَبَّاسٍ : اعْتَکِفْ عَنْ أُمِّک۔",,,12700,,
12701,"حدَّثَنَا وَکِیعٌ ، عَنِ الْحَکَمِ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ یُقْضَی ، عَنْ مَیِّتٍ اعْتِکَافٌ۔",,,12701,,
12702,"حدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ أَبِیہِ ، قَالَ : کَانَ طَاوُوس یَقُولُ فِی النَّذْرِ عَلَی الْمَیِّتِ : یَقْضِیہِ وَرَثَتُہُ بَیْنَہُمْ : إِنْ کَانَ عَلَی رَجُلٍ صَوْمُ سَنَۃٍ إِنْ شَاؤُوا صَامُوا کُلُّ إنْسَانٍ ثَلاَثَۃَ أَشْہُرٍ۔",,,12702,,
12703,عن ابْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، أَنَّہُ کَرِہَ أَنْ یُطْعِمَ الرَّجُلُ مِنْ لَحْمِ أُضْحِیَّتِہِ الْمَسَاکِینَ فِی کَفَّارَۃِ الْیَمِینِ۔,,,12703,,
12704,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا قَالَ الرَّجُلُ لِلرَّجُلِ ہُوَ یُہْدِیہِ عَلَی أشْفَارِ عَیْنَیْہِ ، قَالَ : یُحِجُّہُ ، وَیَنْحَرُ بَدَنَۃً۔",,,12704,,
12705,"جَرِیرٌ ، عَنْ مُطَرِّفٍ ، عَنِ الشَّعْبِیِّ سُئِلَ عَنِ امْرَأَۃٍ أَہْدَتْ کُلَّ شَیْئٍ تَأْکُلُہُ من شیء تصنعہ خَادِمہَا ، قَالَ : لَہَا مِنْہَا بد تَبِیعُہَا۔",,,12705,,
12706,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ فِی الرَّجُلِ یُفْطِرُ أَیَّامًا فِی رَمَضَانَ ، قَالَ : عَلَیْہِ فِی کُلِّ یَوْمٍ کَفَّارَۃٌ۔",,,12706,,
12707,"ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ حُمَیْدِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : أَتَی رَجُلٌ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : ہَلَکْت ، فَقَالَ : وَمَا أَہْلَکَک ؟ قَالَ : وَقَعْت عَلَی امْرَأَتِی فِی رَمَضَانَ ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَعْتِقْ رَقَبَۃً ، قَالَ : لاَ أَجِدُہَا ، فَقَالَ : صُمْ شَہْرَیْنِ مُتَتَابِعَیْنِ ، قَالَ : لاَ أَقْوَی ، قَالَ : فَأَطْعِمْ سِتِّینَ مِسْکِینًا ، قَالَ : لاَ أَجِدُ ، فَقَالَ : اجْلِسْ فَجَلَسَ فَبَیْنَمَا ہُوَ کَذَلِکَ إذْ أُتِیَ بِعَرْقٍ فِیہِ تَمْرٌ ، فَقَالَ لَہُ : النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : اذْہَبْ فَتَصَدَّقْ بِہِ ، فَقَالَ : یَا رَسُولَ اللہِ وَالَّذِی بَعَثَک بِالْحَقِّ مَا بَیْنَ لاَبَتَیْہَا أَہْلُ بَیْتٍ أَحْوَجُ إلَیْہِ مِنَّا ، قَالَ : فَضَحِکَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَتَّی بَدَتْ أَنْیَابُہُ ، ثُمَّ قَالَ : انْطَلِقْ فَأَطْعِمْہُ عِیَالَک۔",,,12707,,
12708,"حدَّثَنَا أبُو خَالِدٍ الأَحمر ، عَنِ ابْنِ عَجْلاَنَ ، عَنِ الْمُطَّلِبِ بْنِ السَّائِبِ بْنِ أَبِی وَدَاعَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : جَائَ رَجُلٌ إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : إنِّی أَفْطَرْت یَوْمًا مِنْ رَمَضَانَ ، فَقَالَ لَہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : تَصَدَّقْ وَاسْتَغْفِرِ اللَّہَ وَصُمْ یَوْمًا مَکَانَہُ۔",,,12708,,
12709,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَبِیبِ بْنِ أَبِی ثَابِتٍ ، عَنِ ابْنِ الْمُطَوِّسِ ، عَنِ الْمُطَوِّسِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ أَفْطَرَ یَوْمًا مِنْ رَمَضَانَ مِنْ غَیْرِ رُخْصَۃٍ لَمْ یُجْزِہِ صِیَامُ الدَّہْرِ۔ (ترمذی 723۔ ابن ماجہ 1672)",,,12709,,
12710,"حدَّثَنَا أبُو خَالِدٍ ، عَنْ أَشْعَثَ ، عَنِ الْمُغِیرَۃِ بْنِ عَبْدِ اللہِ الْیَشْکُرِیِّ ، عَنْ عَبْدِ اللہِ بْنِ الْحَارِثِ قَالَ : قَالَ عَبْد اللہِ : مَنْ أَفْطَرَ یَوْمًا مِنْ رَمَضَانَ مُتَعَمِّدًا مِنْ غَیْرِ سَفَرٍ ، وَلاَ مَرَضٍ لَمْ یَقْضِہِ أَبَدًا وَإِنْ صَامَ الدَّہْرَ کُلَّہُ۔",,,12710,,
12711,"حدَّثَنَا أبُو مُعَاوِیَۃَ ، عَنْ عُمَرَ بْنِ یَعْلَی الثَّقَفِیِّ ، عَنْ عَرْفَجَۃَ ، عَنْ عَلِیٍّ ، قَالَ : مَنْ أَفْطَرَ یَوْمًا مِنْ رَمَضَانَ مُتَعَمِّدًا لَمْ یَقْضِہِ أَبَدًا طُولَ الدَّہْرِ۔",,,12711,,
12712,"حدَّثَنَا شَرِیکٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، وَعَنِ ابْنِ أَبِی خَالِدٍ ، عَنْ عَامِرٍ فِی الَّذِی یُفْطِرُ یَوْمًا مِنْ رَمَضَانَ متعمدا ، قَالاَ : یَسْتَغْفِرُ اللَّہَ وَیَتُوبُ إلَیْہِ ، وَلاَ یَعُدْ وَیَقْضِی یَوْمًا مَکَانَہُ۔",,,12712,,
12713,"حدَّثَنَا وَکِیعٌ ، عَنْ ہِشِامٍ ، عَنْ قَتَادَۃَ ، عَنِ ابْنِ الْمُسَیَّبِ ؛ فِی الرَّجُلِ یُفْطِرُ یَوْمًا مِنْ رَمَضَانَ مُتَعَمِّدًا ، قَالَ : عَلَیْہِ صِیَامُ شَہْرٍ۔",,,12713,,
12714,"وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : عَلَیْہِ صِیَامُ ثَلاَثَۃِ آلاَفِ یَوْمٍ۔",,,12714,,
12715,"حدَّثَنَا الثَّقَفِیُّ ، عَنْ خَالِدٍ الْحَذَّائِ ، قَالَ : قَالَ عَاصِمٌ : سَأَلْت جَابِرَ بْنَ زَیْدٍ أَبَا الشَّعْثَائَ فَقُلْت : أَبَلَغَکَ فِی مَنْ أَفْطَرَ یَوْمًا مِنْ رَمَضَانَ ، مَاذَا عَلَیْہِ ؟ قَالَ : لاَ وَلَکِنْ لِیَصُمْ یَوْمًا مَکَانَہُ وَیَصْنَعُ مِنْ ذَلِکَ مَعْرُوفًا۔",,,12715,,
12716,"حدَّثَنَا أبُو خَالِدٍ ، عَنْ أَشْعَثَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : یَتُوبُ وَیَسْتَغْفِرُ وَیَصُومُ یَوْمًا مَکَانَہُ۔",,,12716,,
12717,"حدَّثَنَا عَبْدَۃُ ، عَنْ سَعِیدٍ ، عَنْ یَعْلَی بْنِ حَکِیمٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ فِی رَجُلٍ أَفْطَرَ یَوْمًا مِنْ رَمَضَانَ مُتَعَمِّدًا ، قَالَ : یَسْتَغْفِرُ اللَّہَ مِنْ ذَلِکَ وَیَتُوبُ إلَیْہِ وَیَقْضِی یَوْمًا مَکَانَہُ۔",,,12717,,
12718,"حدَّثَنَا وَکِیعٌ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، عَنْ یَعْلَی بْنِ حَکِیمٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : قُلْتُ لَہُ : رَجُلٌ أَفْطَرَ یَوْمًا مِنْ رَمَضَانَ مُتَعَمِّدًا مَا کَفَّارَتُہُ ؟ قَالَ : مَا أَدْرِی مَا کَفَّارَتُہُ ، ذَنْبٌ أَصَابَہُ ، یَسْتَغْفِرُ اللَّہَ وَیَقْضِی یَوْمًا مَکَانَہُ۔",,,12718,,
12719,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : یَقْضِی یَوْمًا مَکَانَہُ وَیَسْتَغْفِرُ اللَّہَ۔",,,12719,,
12720,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، عَنْ مُحَمَّدِ بْنِ جَعْفَرِ بْنِ الزُّبَیْرِ ، عَنْ عَبَّادِ بْنِ عَبْدِ اللہِ بْنِ الزُّبَیْرِ ، عَنْ عَائِشَۃَ ، قَالَتْ : أَتَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجُلٌ ، فَذَکَرَ أَنَّہُ احْتَرَقَ ، فَسَأَلَہُ عَنْ أَمْرِہِ ، فَذَکَرَ أَنَّہُ وَقَعَ عَلَی امْرَأَتِہِ فِی رَمَضَانَ ، فَأُتِیَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِمِکْتَلٍ یُدْعَی الْعَرَقُ فِیہِ تَمْرٌ ، فَقَالَ : أَیْنَ الْمُحْتَرِقُ ؟ فَقَامَ الرَّجُلُ ، فَقَالَ : تَصَدَّقْ بِہَذَا۔",,,12720,,
12721,"حدَّثَنَا وَکِیعٌ ، عَنْ سَلاَّمِ بْنِ مِسْکِینٍ ، أَنَّہُ سَأَلَ جَابِرَ بْنَ زَیْدٍ وَالْحَسَنَ ، عَنِ امْرَأَۃٍ جَعَلْت عَلَیْہَا ہَدْیًا ، فَقَالَ جَابِرُ بْنُ زَیْدٍ : إِنْ کَانَتْ مُوسِرَۃً فَبَقَرَۃٌ ، وَإِنْ کَانَتْ مُعْسِرَۃً فَشَاۃٌ ، وَقَالَ الْحَسَنُ : کَفَّارَۃُ یَمِینٍ تَصُومُ ثَلاَثَۃَ أَیَّامٍ۔",,,12721,,
12722,حدَّثَنَا ابْنُ عُلَیَّۃَ، عَنْ یُونُسَ، عَنِ الْحَسَنِ، أَنَّہُ قَالَ؛ فِی الرَّجُلِ یَقُولُ عَلَیَّ ہَدْیٌ، أَوْ علَیَّ نَذْرٌ، قَالَ یَمِینٌ۔,,,12722,,
12723,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سَلَمَۃَ أَبِی بِشرٍ ، عَنْ عِکْرِمَۃَ ؛ فِی الرَّجُلِ یَحْلِفُ بِالبدن وَالْہَدْیِ ، قَالَ : مِنْ خطوَاتِ الشّیطَانِ۔",,,12723,,
12724,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ قَیْسِ بْنِ سَعْدٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ فِی رَجُلٍ قَالَ عَلَیَّ ہَدْیٌ ، قَالَ : لاَ أَقَلُّ مِنْ شَاۃٍ۔",,,12724,,
12725,"حدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ وَحَمَّادٍ ، قَالاَ ، إذَا قَالَ : عَلَیَّ ہَدْیٌ ، وَلَمْ یُسَمِّ شَیئًا قَالاَ : یَمِینٌ۔",,,12725,,
12726,"حدَّثَنَا عَبد الوہاب ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ قَالَ : إذَا قَالَ عَلَیَّ ہَدْیٌ ، وَلَمْ یُسَمِّ فَلْیُہْدِ مَا شَائَ وَلَوْ کُبَّۃ مِنْ غَزْلٍ۔",,,12726,,
12727,"حدَّثَنَا مُحَمَّدُ بْنُ یَزِیدَ ، عَنْ أَیُّوبَ أَبِی الْعَلاَئِ ، عَنْ قَتَادَۃَ ، قَالَ : أَتَتِ امْرَأَۃٌ شُرَیْحًا ، فَقَالَتْ : إنِّی نَذَرْت أَنْ أَعْتَکِفَ فِی الْمَسْجِدِ ، وَإنَّ السُّلْطَانَ منعَنی ، قَالَ : فَکَفِّرِی عَنْ یَمِینِک۔",,,12727,,
12728,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَبِیبٍ ، عَنْ عَمْرِو بْنِ ہَرِمٍ ، قَالَ : سُئِلَ جَابِرُ بْنُ زَیْدٍ ، عَنِ امْرَأَۃٍ جَعَلَتْ عَلَیْہَا أَنْ تَعْتَکِفَ شَہْرًا فِی الْمَسْجِدِ الْجَامِعِ ، فَطلب إلیہا أمر لاَ تَسْتَطِیعُ أَنْ تَظْہرَ ، قَالَ : تَعْتَکِفُ فِی مَسْجِدٍ تأمن بِہِ۔",,,12728,,
12729,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ فِی الرَّجُلِ یُسْتَحْلَفُ بِالطَّلاَقِ فَیَحْلِفُ ، قَالَ : الْیَمِینُ عَلَی مَا اسْتَحْلَفَہُ الذی یَستَحْلِفہ ، وَلَیْسَ نِیَّۃُ الْحَالِفِ بِشَیْئٍ۔",,,12729,,
12730,"حدَّثَنَا مُعْتَمِرٌ ، عَنْ عِمْرَانَ ، عَنِ الْحَسَنِ ، قَالَ : مَنْ حَلَفَ لِرَجُلٍ عَلَی یَمِینٍ یَرَی أنہا لَیْسَتْ بِیَمِینٍ فَہِیَ یَمِینٌ عَاقِدَۃٌ۔",,,12730,,
12731,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ، عَنْ أَبِی الْعَلاَئِ، عَنْ أَبِی ہَاشِمٍ، عَنْ إبْرَاہِیمَ، قَالَ: الْیَمِینُ عَلَی نِیَّۃِ الْمُسْتَحْلِفِ۔",,,12731,,
12732,"حدَّثَنَا یَزِیدُ ، قَالَ : حدَّثَنَا ہُشَیْمٌ ، قَالَ : حدَّثَنَا عَبَّادُ بْنُ أَبِی صَالِحٍ ، عَنْ أَبِیہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : الْیَمِینُ عَلَی نِیَّۃِ الْمُسْتَحْلِفِ۔ (مسلم 22۔ ابوداؤد 3250)",,,12732,,
12733,"حدَّثَنَا یَزِیدُ ، قَالَ حدَّثَنَا أَبُو مَعْشَرٍ ، عَنْ مُوسَی بْنِ عُقْبَۃَ ، عَنِ ابْنِ فَغْوَائِ ، قَالَ : قَالَ عُمَرُ ، یَمِینُک عَلَی مَا صَدَّقک صَاحِبُک۔",,,12733,,
12734,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا کَانَ مَظْلُومًا فَلَہُ أَنْ یُوَرِّکَ بِیَمِینٍ ، فَإِنْ کَانَ ظَالِمًا فَلَیْسَ لَہُ أَنْ یُوَرِّکَ۔",,,12734,,
12735,"حدَّثَنَا حفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، عَنْ إبْرَاہِیمَ ، قَالَ: إذَا قَالَ: لَمْ أَحْلِفْ ، قَالَ: یَمِینٌ یُکَفِّرُہَا۔",,,12735,,
12736,"حدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، قَالَ : کَانَ إبْرَاہِیمُ فِی أَصْحَابِ الْمَلاَء ، فَسُئِلَ عَنْ رَجُلٍ جَعَلَ عَلَیْہِ الْمَشْیَ إلَی الْکَعْبَۃِ إِنْ دَخَلَ عَلَی ابنہ فاحْتَمَلَہُ أَصْحَابُہُ فَأَدْخَلُوہُ ، فَقَالَ إبْرَاہِیمُ بِیَدِہِ احْتَمَلُوہُ فَأَدْخَلُوہُ ، لْیَمْشِ۔",,,12736,,
12737,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عُبَیْدِ اللہِ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّ سَعْدَ بْنَ عُبَادَۃَ اسْتَفْتَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی نَذْرٍ کَانَ عَلَی أُمِّہِ تُوُفِّیَتْ قَبْلَ أَنْ تَقْضِیَہُ ، فَقَالَ : اقْضِہِ عَنْہَا۔",,,12737,,
12738,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَلِیِّ بْنِ الْحَکَمِ الْبُنَانِیِّ ، عَنْ مَیْمُونٍ ، عَنِ ابْنِ عَبَّاسٍ رضی اللَّہُ عَنْہُما سُئِلَ عَنْ رَجُلٍ مَاتَ وَعَلَیْہِ نَذْرٌ ، فَقَالَ : یُصَامُ عَنْہُ النَّذْرُ۔",,,12738,,
12739,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی حَصِینٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ مَرَّۃً ، عَنِ ابْنِ عَبَّاسٍ : إذَا مَاتَ وَعَلَیْہِ نَذْرٌ قَضَی عَنْہُ وَلِیُّہُ۔",,,12739,,
12740,"حدَّثَنَا ابْنُ مَہْدِیٍّ، عَنْ سُفْیَانَ، عَنْ أَبِیہِ، عَنْ إبْرَاہِیمَ فِی رَجُلٍ مَاتَ وَعَلَیْہِ نَذْرُ صَوْمٍ، قَالَ: یُطْعَمُ عَنْہُ۔",,,12740,,
12741,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ نَذَرَ أَنْ یَصُومَ ، فَمَاتَ قَبْلَ أَنْ یَصُومَ ، قَالَ : کَانَ یُعْجِبُہُ أَنْ یُقْضَی عَنْہُ الصَّوْمُ صَوْمًا۔",,,12741,,
12742,"حدَّثَنَا مُعْتَمِرٌ ، عَنْ أَبِیہِ ، عَنْ طَاوُوس فِی النَّذْرِ عَلَی الْمَیِّتِ ، قَالَ : یَقْضِیہِ وَرَثَتُہُ بَیْنَہُمْ ، إِنْ کَانَ عَلَی رَجُلٍ صَوْمُ سَنَۃٍ ، إِنْ شَائَ صَامَ کُلُّ إنْسَانٍ منہم ثَلاَثَۃَ أَشْہُرٍ۔",,,12742,,
12743,"حدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ مُحَمَّدِ بْنِ کُرَیْبٍ ، عَنْ کُرَیْبٍ ، عَنِ ابْنِ عَبَّاسٍ رضی اللَّہُ عَنْہُما ، عَنْ سِنَانِ بْنِ عَبْدِ اللہِ الْجُہَنِیِّ ، أَنَّہُ حَدَّثَتْہُ عَمَّتُہُ ، أَنَّہَا أَتَتِ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَتْ : یَا رَسُولَ اللہِ ، تُوُفِّیَتْ أُمِّی وَعَلَیْہَا مَشْیٌ إلَی الْکَعْبَۃِ نَذْرٌ ، فَقَالَ : ہَلْ تَسْتَطِیعِینَ أَنْ تَمْشِیَ عَنْہَا ؟ فَقَالَتْ : نَعَمْ ، فَقَالَ : فَامْشِ عَنْ أُمِّکَ ، فَقَالَتْ : أَیُجْزِئُ ذَلِکَ عَنْہَا ؟ فَقَالَ : نعم ، أَرَأَیْت لَوْ کَانَ عَلَیْہَا دَیْنٌ فَقَضَیْتہ ، ہَلْ کَانَ یُقْبَلُ مِنْک؟ قَالَتْ: نَعَمْ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : اللَّہُ أَحَقُّ بِذَلِکَ۔ (بخاری 2336)",,,12743,,
12744,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ اللہِ بن عَطَاء ، عَنِ ابْنِ بُرَیْدَۃَ ، عَنْ أَبِیہِ ، قَالَ : کُنْتُ جَالِسًا عِنْدَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذْ جَائَتْہُ امْرَأَۃٌ ، فَقَالَتْ : إنہ کَانَ عَلَی أُمِّی صَوْمُ شَہْرَیْنِ ، أَفَیُجْزِی عَنْہَا أَنْ نَصُومَ عنہَا؟ قَالَ : نَعَمْ۔",,,12744,,
12745,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنْ أَبِی مَالِکٍ ، قَالَ : الْیَمِینُ الَّتِی لاَ تُکَفَّرُ : الرَّجُلُ یَحْلِفُ لِلرَّجُلِ عَلَی مَالِ رَجُلٍ مُسْلِمٍ فَیَقْتَطِعُہُ ظَالِمًا وَہُوَ فِیہِ کَاذِبٌ۔",,,12745,,
12746,"حدَّثَنَا أبُو أُسَامَۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ إبْرَاہِیمَ ، وَمُحَمَّدٍ ، وَالْحَسَنِ فِی قَوْلِہِ : {إنَّ الَّذِینَ یَشْتَرُونَ بِعَہْدِ اللہِ وَأَیْمَانِہِمْ ثَمَنًا قَلِیلاً} ، قَالُوا : ہُوَ الرَّجُلُ یَقْتَطِعُ مَالَ الرَّجُلِ بِیَمِینِہِ۔",,,12746,,
12747,"حدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، وَسَعِیدِ بْنِ الْمُسَیَّبِ ، وَعَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ، قَالُوا : إذا ظَاہَرَ مِنْہَا ظِہَارًا ، وَلَمْ یَدْخُلْ فِیہ ؛ إِنْ غَشِیتُکِ ، فَلاَ حَدَّ فِی ذَلِکَ وَلاَ وَقْتَ ، إذَا کَفَّرَ غَشِیَہَا۔",,,12747,,
12748,"حدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ مُحَمَّدِ بْنِ کُرَیْبٍ ، عَنْ کُرَیْبٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : سَمِعْتُہُ وَعِنْدَہُ الْمِسْوَرُ بْنُ مَخْرَمَۃَ ، وَعَبْدُ اللہِ بْنُ شَدَّادِ بْنِ الْہَادِ ، وَنَافِعُ بْنُ جُبَیْرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : ثَلاَثَۃٌ لاَ یَمِینَ فِیہِنَّ : لاَ یَمِینَ لِلْوَلَدِ عَلَی وَالِدِہِ ، وَلا لِلْمَرْأَۃِ عَلَی زَوْجِہَا ، وَلاَ لِلْعَبْدِ عَلَی سَیِّدِہِ۔",,,12748,,
12749,"حدَّثَنَا زَیْدُ بْنُ حُبَابِ ، عَنِ ابْنِ لَہِیعَۃَ ، عَنْ خَالِدِ بْنِ أَبِی عِمْرَانَ ، قَالَ : سَأَلْتُ الْقَاسِمَ وَسَالِمًا ، عَنْ رَجُلٍ ظَاہَرَ مِنْ أَمَتِہِ فَلَمْ یَجِدْ مَا یُعْتِقُ ، أَیُعْتِقُہَا ؟ قَالاَ : نَعَمْ۔",,,12749,,
12750,حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ فِی الظِّہَارِ مِنَ الأَمَۃِ إذَا لَمْ یَجِدْ مَا یُعْتِقُ ، وَلَمْ یَسْتَطِعَ الصَّوْمَ فَأَرَادَ أَنْ یَتَزَوَّجَہَا جَعَلَ عِتْقَہَا مَہْرَہَا ، فَکَانَ عِتْقُہَا کَفَّارَۃَ الظِّہَارِ ، وَکَانَتِ امْرَأَتَہُ۔,,,12750,,
12751,"حدَّثَنَا أبُو خَالِدٍ ، عَنْ شُعْبَۃَ ، عَنْ مُغِیرَۃَ ؛ فِی الرَّجُلِ یُظَاہِرُ مِنْ أَمَتِہِ ، قَالَ : یُجْزِیئہ أَنْ یُعْتِقَہَا۔",,,12751,,
12752,"حدَّثَنَا الْحَسَنُ بْنُ مُوسَی ، عَنْ شَیْبَانَ ، عَنْ لَیْثٍ ، عَنْ طَاوُوس ؛ فِی الرَّجُلِ یُظَاہِرُ مِنْ أُمِّ وَلَدِہِ ، وَلاَ یَجِدُ مَا یُکَفِّرُ ، قَالَ : یُعْتِقُہَا فَیَکُونُ عِتْقُہَا کَفَّارَۃً لِیَمِینِہِ۔",,,12752,,
12753,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، وَالْحَسَنِ ؛ فِی الرَّجُلِ یُحَرِّمُ فِی الْغَضَبِ ، قَالَ : مِنْ نَزَعَاتِ الشَّیْطَانِ ، یُطْعِمُ عَشَرَۃَ مَسَاکِینَ ، وَإِنْ کَانَ فِی طَاعَۃِ اللہِ فَلیَفِ۔",,,12753,,
12754,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ فِرَاسٍ ، عَنْ أَبِی صَالِحٍ ، عَنْ زَاذَانَ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ أَعْتَقَ عَبْدًا لَہُ ، ثُمَّ أَخَذَ مِنَ الأَرْضِ شَیْئًا ، فَقَالَ : مَا لِی مِنْ أَجْرِہِ مِثْلَ ہَذَا ، سَمِعْت النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : مَنْ لَطَمَ خَادِمًا لَہُ فَکَفَّارَتُہُ عِتْقُہُ۔ (احمد 25۔ مسلم 1279)",,,12754,,
12755,"حدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنْ ہِلاَلِ بْنِ یَِسَافٍ ، قَالَ : عَجِلَ شَیْخٌ فَلَطَمَ خَادِمًا لَہُ ، فَقَالَ : سُوَیْد بْنُ مُقَرِّنٍ : أَعَجَزَ عَلَیْک إلاَّ حُرُّ وَجْہِہَا ؟ لَقَدْ رَأَیْتُنِی سَابِعَ سَبْعَۃٍ مِنْ بَنِی مُقَرِّنٍ مَا لَنَا خَادِمٌ إلاَّ وَاحِدَۃً لَطَمَہَا أَصْغَرُنَا ، فَأَمَرَنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ نُعْتِقَہَا۔ (ابوداؤد 5123۔ مسلم 33)",,,12755,,
12756,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ بَشَّارِ بْنِ کِدَامٍ السُّلَمِیِّ ، عَنْ مُحَمَّدِ بْنِ زَیْدٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْحَلِفُ حِنْثٌ ، أَوْ نَدَمٌ۔ (بخاری 1930۔ ابن حبان 4356)",,,12756,,
12757,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمِ بْنِ مُحَمَّدٍ ، عَنْ أَبِیہِ ، قَالَ : قَالَ عُمَرُ : إنَّ الْیَمِینَ مَأْثمۃٌ ، أَوْ مَنْدَمَۃٌ۔",,,12757,,
12758,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ أَبِی عَوَانَۃَ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُوس ، وَمُجَاہِدٍ ؛ فِی الرَّجُلِ یَقُولُ عَلَیَّ غَضَبُ اللہِ ، قَال : لَیْسَ عَلَیْہِ کَفَّارَۃٌ ، ہُوَ أَشَدُّ مِنْ ذَلِکَ۔",,,12758,,
12759,"حدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ جَابِرٍ، عَنْ عَامِرٍ ؛ فِی الرَّجُلِ یَقُولُ : قطَعَ اللَّہُ ظَہْرِی ، قَطَعَ اللَّہُ صُلْبِی، قَالَ : لَیْسَ عَلَیْہِ شَیْئٌ۔",,,12759,,
12760,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنِ الْحَکَمِ ، قَالَ : یُکَفِّرُ۔",,,12760,,
12761,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ رَجُلٍ ، عَنْ طَاوُوسٍ ، قَالَ : یُکَفِّرُ۔",,,12761,,
12762,"حدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یَغْشَی امْرَأَتَہُ وَیَأْکُلُ فِی رَمَضَانَ فِی یَوْمٍ وَاحِدٍ ، قَالَ : کَفَّارَۃٌ وَاحِدَۃٌ یُحَرِّرُ مُحَرَّرًا۔",,,12762,,
12763,"حدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، قَالَ : الْمُظَاہِرُ یُکَفِّرُ وَإِنْ بَرَّ۔",,,12763,,
12764,"حدَّثَنَا الضَّحَّاکُ، عَنِ ابْنِ جُرَیْجٍ، عَنْ عَطَائٍ، قَالَ: إذَا بَرَّ الْمُظَاہِرُ لَمْ یُکَفِّرْ، وَقَالَ: الضَّحَّاکُ: وَبِہِ نَقُولُ۔",,,12764,,
12765,"حدَّثَنَا وَکِیعٌ ، عَنْ أَسْلَمَ مَوْلَی عَنْبَسَۃَ ، أَنَّہُ قَالَ : سَأَلْتُ سَعِیدَ بْنَ الْمُسَیَّبِ عَنِ امْرَأَۃٍ حَلَفَتْ لاَ تَشْرَبُ مِنْ لَبَنِ عَنْزٍ لِزَوْجِہَا ، فَشَرِبَتْ ، قَالَ : لَیْسَ عَلَیْہَا شَیْئٌ ، لَیْسَ فِی الطَّعَامِ وَالشَّرَابِ یَمِینٌ۔",,,12765,,
12766,"حدَّثَنَا جَعْفَرٌ ، عَنِ ابْنِ عَوْنٍ ، عَنْ أَبِی الْعُمَیْسِ ، عَنْ قَیْسِ بْنِ مُسْلِمٍ ، عَنْ طَارِقِ بْنِ شِہَابٍ ، قَالَ : کَانَ رَجُلٌ لَہُ أَعَنْزٌ ، فَحَلَفَ أَنْ لاَ یَشْرَبَ مِنْ أَلْبَانَّہَا ، فَلَمَّا رَأَتِ امْرَأَتُہُ ذَلِکَ حَلَفَتْ أَنْ لاَ تَشْرَبَ مِنْ أَلْبَانَّہَا ، فَجافَوُا الأَعَنْزَ وَضَیَّعُوہُنَّ ، فَأَتَی عَبْدَ اللہِ فَذَکَرَ لَہُ ذَلِکَ ، فَقَالَ : إنَّمَا ذَا مِنَ الشَّیْطَانِ ارْجِعَا إلَی أَحْسَنِ مَا کُنْتُمَا عَلَیْہِ وَاشْرَبَا۔",,,12766,,
12767,"حدَّثَنَا جَرِیرٌ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ رُفَیْعٍ ، عَنْ مُجَاہِدٍ ، قَالَ : کَانَ لِرَجُلٍ مِنَ الأَنْصَارِ ضَیْفٌ ، فَأَبْطَأَ عَنْ أَہْلِہِ ، فَقَالَ : عَشَّیْتُمْ ضیفی ، قَالُوا : لاَ ، قَالَ : لاَ وَاللَّہِ لاَ أَطْعَمُ اللَّیْلَۃَ مِنْ عَشَائِکُمْ ، فَقَالَتِ امْرَأَتُہُ : إذًا وَاللَّہِ لاَ أَطْعَمُہُ ، قَالَ : فَقَالَ الضَّیْفُ : وَأنا وَاللَّہِ لاَ أَطْعَمُہُ أَیْضًا ، قَالَ : فَقَالَ : یَبِیتُ ضَیْفِی بِغَیْرِ طَعَامٍ ، قَرِّبُوا طَعَامَکُمْ ، فَأَکَلُوا مَعَہُ ، فَلَمَّا أَصْبَحَ غَدَا إلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَأَخْبَرَہُ بِذَلِکَ ، فَقَالَ : أَطَعْت اللَّہَ وَعَصَیْت الشَّیْطَانَ۔",,,12767,,
12768,"حدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حدَّثَنَا جَرِیرُ بْنُ حَازِمٍ ، حَدَّثَنِی یَعْلَی بْنُ حَکِیمٍ ، عَنِ الزُّبَیْرِ بْنِ الْخِرِّیتِ ، عَنْ عِکْرِمَۃَ ، قَالَ : مَا أفتیت بِرَأْیِی شَیْئًا قطُّ غیر ہَذِہِ ، سَأَلَتْنِی امْرَأَۃٌ نَذَرَتْ أَنْ تَطُوفَ بِالْبَیْتِ عَلَی أَرْبَعِ قَوَائِمَ، فَقُلْت لَہَا : طُوفِی لِکُلِّ قَائِمَۃٍ سَبْعًا۔",,,12768,,
12769,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : سَمِعْتُ عَطَائً وَسُئِلَ عَنِ امْرَأَۃٍ حَلَفَتْ بِعِتْقِ جَارِیَتِہَا أَنْ لاَ تُکَلِّمَ جَارَتَہَا أَرْبَعَ سِنِینَ ، فَمَاتَتْ جَارِیَتُہَا ، وَأَحَبَّتْ أَنْ تُکَلِّمَ جَارَتَہَا ، قَالَ : تُکَلِّمُہَا وَتَصَدَّقُ بِشَیْئٍ ، وَقَالَ : ابْنُ أَبِی مُلَیْکَۃَ : لاَ أَرَی عَلَیْہَا حِنْثًا۔",,,12769,,
12770,"حدَّثَنَا ابْنُ یَمَانٍ، عَنْ سُفْیَانَ، عَنْ جابر، عَنْ عَامِرٍ؛ فِی الرَّجُلِ یَقُولُ: أَلْقَانِی اللَّہُ فِی النَّارِ، قَالَ: یُکَفِّرُ۔",,,12770,,
12771,"حدَّثَنَا ابْنُ یَمَانٍ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنِ الْحَکَمِ ، وَطَاوُوس ، قَالاَ : لاَ یُکَفِّرُ",,,12771,,
12772,"حدَّثَنَا عُبَیْدُ اللہِ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ؛ فِی الرَّجُلِ یَحْلِفُ أن لاَ یَأْکُلُ مِنْ ہَذَا الطَّعَامِ فَیَبِیعُہُ ، قَالَ : یَأْکُلُ ثَمَنَہُ وَیَشْتَرِی بِہِ۔",,,12772,,
12773,"حدَّثَنَا عُبَیْدُ اللہِ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ حَمَّاد ، عَنْ إِبرَہیم قَالَ : لاَ یَبِیعُہُ وَلاَ یَشْتَرِی بِہِ طَعَامًا فَیَأْکُلُہُ۔",,,12773,,
12774,"حدَّثَنَا أبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ سَالِمِ بْنِ أَبِی الْجَعْدِ ، عَنْ شُرَحْبِیلَ بْنِ السِّمْطِ ، قَالَ : قلْنَا لِکَعْبِ بْنِ مُرَّۃَ : یَا کَعْب بْنِ مُرَّۃَ ، حدَّثَنَا عَنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَاحْذَرْ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : مَنْ أَعْتَقَ امْرَئًا مُسْلِمًا کَانَ فَکَاکُہُ مِنَ النَّارِ، یُجْزِی بِکُلُّ عَظْمٍ مِنْہُ عَظْمًا مِنْہُ ، وَمَنْ أَعْتَقَ امْرَأَتَیْنِ مُسْلِمَتَیْنِ کَانَتَا فَکَاکُہُ مِنَ النَّارِ ، یُجْزِی بکل عظمین مِنْہُمَا عَظْمٌ مِنْہُ۔ (نسائی 2881۔ احمد 4/235)",,,12774,,
12775,"حدَّثَنَا یُونُسُ بْنُ مُحَمَّدٍ ، عَنْ لَیْثِ بْنِ سَعْدٍ ، عَنْ یَزِیدَ بْنِ عَبْدِ اللہِ ، عَنْ عُمَرَ بْنِ عَلِیِّ بْنِ حُسَیْنٍ ، عَنْ سَعِیدِ بْنِ مَرْجَانَۃَ ، قَالَ : سَمِعْتُہُ یُحَدِّثُ عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : مَنْ أَعْتَقَ رَقَبَۃً مُؤْمِنَۃً أَعْتَقَ اللَّہُ بِکُلِّ عُضْوٍ مِنْہُ عُضْوًا مِنَ النَّارِ حَتَّی یُعْتِقَ فَرْجَہُ بِفَرْجِہِ۔\n\n(بخاری 2517۔ مسلم 1147)",,,12775,,
12776,"حدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، قَالَ : حدَّثَنَا الْحَکَمُ بْنُ عَبْدِ الرَّحْمَنِ ابْنِ أَبِی نُعْمٍ ، قَالَ : حَدَّثَتْنِی فَاطِمَۃُ بِنْتُ عَلِیٍّ ، قَالَتْ : قَالَ : أَبِی عَنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ أَعْتَقَ نَسَمَۃً مُسْلِمَۃً ، أَوْ مُؤْمِنَۃً وَقَی اللَّہُ بِکُلِّ عُضْوٍ مِنْہُ عُضْوًا مِنَ النَّارِ۔ (نسائی 4877)",,,12776,,
12777,"حدَّثَنَا عَبْدَۃُ ، عَنْ صَالِحِ بْنِ حَیٍّ ، عَنِ الشَّعْبِیِّ ، عَنْ أَبِی بُرْدَۃَ ، عَنْ أَبِی مُوسَی ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ کَانَتْ لَہُ جَارِیَۃٌ فَأَدَّبَہَا فَأَحْسَنَ تَأْدِیبَہَا ، وَعَلَّمَہَا فَأَحْسَنَ تَعْلِیمَہَا ، ثُمَّ أَعْتَقَہَا وَتَزَوَّجَہَا فَلَہُ أَجْرَانِ۔ (بخاری 2544۔ ابوداؤد 2046)",,,12777,,
12778,"حدَّثَنَا عَبْدَۃُ ، عَنْ عبد الملک ، عَنْ عَطَائٍ ؛ فِی امْرَأَۃٍ نَذَرَتْ أَنْ تَعْتَکِفَ شَہْرَیْنِ ، فَجَعَلَتْ تقطع ، قَالَ : إذَا أَکْمَلَتِ الْعِدَّۃَ أَجْزَأَ عَنْہَا۔",,,12778,,
12779,"حدَّثَنَا أبُو خَالِدٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عَمْرِو بْنِ عَبْدِ اللہِ الأَنْصَارِیِّ ، أَنَّ رَجُلاً نَذَرَ أَنْ یَنْحَرَ بَدَنَۃً ، فَأَتَی عَبْدَ اللہِ بْنَ مُحَمَّدِ بْنِ عَلِیٍّ ، فَقَالَ : الْبُدْنُ مِنَ الإِبِلِ ، وَلاَ تُنْحَرُ إلاَّ بِمَکَّۃَ ، إلاَّ إِنْ نَوَی مَنْحَرًا فَحَیْثُ نَوَی ، فَإِنْ لَمْ یَجِدْ فَسَبْعٌ مِنَ الْغَنَمِ ، قَالَ : وَسَأَلْت سَالِمًا فَقَالَ مِثْلَ ذَلِکَ\n\nقَالَ : وَسَأَلْت سَعِیدَ بْنَ الْمُسَیَّبِ ، فَقَالَ : مِثْلَ ذَلِکَ ، إلاَّ إِنَّہُ قَالَ : فَإِنْ لَمْ یَجِدْ فَعَشَرَۃٌ مِنَ الْغَنَمِ ، قَالَ : وَسَأَلْت خَارِجَۃَ بْنَ زَیْدٍ وَأَخْبَرتہُ بِمَا قَالَ الْقَوْمُ ، فَقَالَ : مَا أَدْرَکْت أَصْحَابَنَا یَعُدُّونَہَا إلاَّ سَبْعًا مِنَ الْغَنَمِ۔",,,12779,,
