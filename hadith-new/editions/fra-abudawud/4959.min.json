{"metadata":{"name":"Sunan Abu Dawud","section":{"43":"General Behavior (Kitab Al-Adab)"},"section_detail":{"43":{"hadithnumber_first":4773,"hadithnumber_last":5274,"arabicnumber_first":4773,"arabicnumber_last":5274}}},"hadiths":[{"hadithnumber":4959,"arabicnumber":4959,"text":"Rapporté par Samurah رضي الله عنه : Le Messager d’Allah ﷺ a interdit de donner quatre noms à nos esclaves : Aflah (heureux), Yasar (richesse), Naf‘ (bénéfique) et Rabah (profit)","grades":[{"name":"Al-Albani","grade":"Sahih"},{"name":"Muhammad Muhyi Al-Din Abdul Hamid","grade":"Sahih"},{"name":"Zubair Ali Zai","grade":"Sahih Muslim (2136)"}],"reference":{"book":43,"hadith":187}}]}