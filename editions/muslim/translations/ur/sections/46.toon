{"hadithnumber": "6723", "text": "عبداللہ بن نمیر ہمدانی ،  ابومعاویہ اور وکیع نے ہمیں حدیث بیان کی ،  انہوں نے کہا :  ہمیں اعمش نے زی"}
{"hadithnumber": "6724", "text": "عثمان بن ابی شیبہ اور اسحٰق بن ابراہیم نے ہمیں حدیث بیان کی ،  دونوں نے جریر بن عبدالحمید سے روایت ک"}
{"hadithnumber": "6725", "text": "عمرو بن دینار نے ابوطفیل  ( عامر بن واثلہ رضی اللہ عنہ )  سے ،  انہوں نے حذیفہ بن اسید رضی اللہ عنہ"}
{"hadithnumber": "6726", "text": "عمرو بن حارث نے ابوزبیر علی سے روایت کی کہ حضرت عامر بن واثلہ رضی اللہ عنہ نے انہیں حدیث بیان کی ،"}
{"hadithnumber": "6727", "text": "ابن جریج نے کہا :  مجھے ابوزبیر نے خبر دی کہ ابوطفیل رضی اللہ عنہ نے انہیں بتایا کہ انہوں نے حضرت عب"}
{"hadithnumber": "6728", "text": "یحییٰ بن ابوبکیر نے کہا :  ہمیں ابوخیثمہ زہیر نے حدیث بیان کی ،  انہوں نے کہا :  مجھے عبداللہ بن عطا"}
{"hadithnumber": "6729", "text": "کلثوم نے ابوطفیل رضی اللہ عنہ سے ،  انہوں نے رسول اللہ صلی اللہ علیہ وسلم کے صحابی حضرت حذیفہ بن اسی"}
{"hadithnumber": "6730", "text": "عبیداللہ بن ابی بکر نے حضرت انس بن مالک رضی اللہ عنہ سے روایت کی ،  انہوں نے یہ حدیث مرفوعا بیان کی"}
{"hadithnumber": "6731", "text": ")   جریر نے ہمیں منصور سے حدیث بیان کی ۔  انہون نے سعید بن عبیدہ سے ،  انہوں نے ابوعبدالرحمٰن سے اور"}
{"hadithnumber": "6732", "text": "ابوبکر بن ابی شیبہ اور ہناد بن سری نے ہمیں حدیث بیان کی ،  انہوں نے کہا :  ہمیں ابو احوص نے منصور سے"}
{"hadithnumber": "6733", "text": "وکیع ،  عبداللہ بن نمیر اور ابومعاویہ نے کہا :  ہمیں اعمش نے سعد بن عبیدہ سے حدیث بیان کی ،  انہوں ن"}
{"hadithnumber": "6734", "text": "ہمیں شعبہ نے منصور اور اعمش سے حدیث بیان کی ،  ان دونوں نے سعد بن عبیدہ سے سنا ،  وہ ابوعبدالرحمٰن س"}
{"hadithnumber": "6735", "text": "ابوخیثمہ زہیر  ( بن حرب )  نے ابوزبیر سے ،  انہوں نے حضرت جابر رضی اللہ عنہ سے روایت کی ،  کہا :  حض"}
{"hadithnumber": "6736", "text": "عمرو بن حارث نے ابوزبیر سے ،  انہوں نے حضرت جابر بن عبداللہ رضی اللہ عنہ سے اور انہوں نے نبی صلی الل"}
{"hadithnumber": "6737", "text": "حماد بن زید نے یزید ضبعی سے روایت کی ،  کہا :  ہمیں مطرف نے حضرت عمران بن حصین رضی اللہ عنہ سے حدیث"}
{"hadithnumber": "6738", "text": "عبدالوارث ،  ابن علیہ ،  جعفر بن سلیمان اور شعبہ سب نے یزید رشک سے اسی سند کے ساتھ حماد کی حدیث کے ہ"}
{"hadithnumber": "6739", "text": "یحییٰ بن یعمر نے ابو اسود دیلی سے روایت کی ،  کہا :  حضرت عمران بن حصین رضی اللہ عنہ نے مجھ سے کہا :"}
{"hadithnumber": "6740", "text": "علاء کے والد  ( عبدالرحمٰن )  نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ علیہ و"}
{"hadithnumber": "6741", "text": "حضرت سہل بن سعد ساعدی رضی اللہ عنہ سے روایت ہے کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   \" ایک ش"}
{"hadithnumber": "6742", "text": "محمد بن حاتم ،  ابراہیم بن دینار ،  ابن ابی عمر مکی اور احمد بن عبدہ ضبی نے ہمیں ابن عیینہ سے حدیث ب"}
{"hadithnumber": "6743", "text": "ابوزناد نے اعرج سے ،  انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ علیہ وسل"}
{"hadithnumber": "6744", "text": "حارث بن ابی ذباب نے یزید بن ہرمز اور عبدالرحمٰن اعرج سے روایت کی ،  ان دونوں نے کہا :  ہم نے حضرت اب"}
{"hadithnumber": "6745", "text": "حمید بن عبدالرحمٰن نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم"}
{"hadithnumber": "6746", "text": "ابوسلمہ اور ہمام بن منبہ نے حضرت ابوہریرہ رضی اللہ عنہ سے اور انہوں نے نبی صلی اللہ علیہ وسلم سے ان"}
{"hadithnumber": "6747", "text": "محمد بن سیرین نے ابوہریرہ رضی اللہ عنہ سے اور انہوں نے رسول اللہ صلی اللہ علیہ وسلم سے ان سب کی حدیث"}
{"hadithnumber": "6748", "text": "ابن وہب نے ہمیں حدیث بیان کی ،  کہا :  مجھے ابوہانی خولانی نے ابو عبدالرحمٰن حبلی سے خبر دی ،  انہوں"}
{"hadithnumber": "6749", "text": "حیوہ اور نافع بن یزید نے ابوہانی سے اسی سند کے ساتھ اسی حدیث کے مانند حدیث بیان کی مگر ان دونوں نے ی"}
{"hadithnumber": "6750", "text": "حیوہ نے ہمیں حدیث بیان کی ،  انہوں نے کہا :  مجھے ابوہانی نے بتایا ،  انہوں نے ابوعبدالرحمٰن حبلی سے"}
{"hadithnumber": "6751", "text": "عمرو بن مسلم نے طاوس سے روایت کی ،  انہوں نے کہا :  میں نے رسول اللہ صلی اللہ علیہ وسلم کے متعدد صحا"}
{"hadithnumber": "6752", "text": "محمد بن عباد بن جعفر مخزومی نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  کہا :  مشرکین قریش تقدیر کے"}
{"hadithnumber": "6753", "text": "اسحٰق بن ابراہیم اور عبد بن حمید نے ہمیں حدیث بیان کی  ۔  ۔  الفاظ اسحٰق کے ہیں  ۔  ۔  دونوں نے کہا"}
{"hadithnumber": "6754", "text": "ابوصالح نے حضرت ابوہریرہ رضی اللہ عنہ سے اور انہوں نے نبی صلی اللہ علیہ وسلم سے روایت کی کہ آپ نے فر"}
{"hadithnumber": "6755", "text": "زُبیدی نے زہری سے روایت کی ،  انہوں نے کہا :  مجھے سعید بن مسیب نے حضرت ابوہریرہ رضی اللہ عنہ سے خبر"}
{"hadithnumber": "6756", "text": "معمر نے زہری سے اسی سند کے ساتھ روایت کی اور کہا :   \" جس طرح ایک  ( مادہ )  جانور بچے کو جنم دیتی ہ"}
{"hadithnumber": "6757", "text": "یونس بن یزید نے ابن شہاب سے روایت کی ،  انہیں ابوسلمہ بن عبدالرحمٰن نے بتایا کہ حضرت ابوہریرہ رضی ال"}
{"hadithnumber": "6758", "text": "جریر نے اعمش سے ،  انہوں نے ابوصالح سے اور انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  کہا :"}
{"hadithnumber": "6759", "text": "ابوبکر بن ابی شیبہ اور ابوکریب نے ہمیں حدیث بیان کی ،  دونوں نے کہا :  ہمیں ابومعاویہ نے حدیث بیان ک"}
{"hadithnumber": "6760", "text": "معمر نے ہمیں ہمام بن منبہ سے حدیث بیان کی ،  کہا :  یہ احادیث ہیں جو حضرت ابوہریرہ رضی اللہ عنہ نے ہ"}
{"hadithnumber": "6761", "text": "علاء کے والد عبدالرحمٰن نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ علیہ وسلم نے"}
{"hadithnumber": "6762", "text": "ابن ابی ذئب اور یونس نے ابن شہاب سے روایت کی ،  انہوں نے عطاء بن یزید سے اور انہوں نے حضرت ابوہریرہ"}
{"hadithnumber": "6763", "text": "معمر ،  شعیب اور معقل بن عبیداللہ نے زہری سے یونس اور ابن ابی ذئب کی سند کے ساتھ ان دونوں کی حدیث کے"}
{"hadithnumber": "6764", "text": "اعرج نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم سے مشرکین کے ب"}
{"hadithnumber": "6765", "text": "سعید بن جبیر نے حضرت ابن عباس رضی اللہ عنہ سے روایت کی ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم سے مشر"}
{"hadithnumber": "6766", "text": "سعید بن جبیر نے حضرت ابن عباس رضی اللہ عنہ سے اور انہوں نے حضرت ابی بن کعب رضی اللہ عنہ سے روایت کی"}
{"hadithnumber": "6767", "text": "فضیل بن عمرو نے عائشہ بنت طلحہ سے اور انہوں نے ام المومنین حضرت عائشہ صدیقہ رضی اللہ عنہا سے روایت ک"}
{"hadithnumber": "6768", "text": "وکیع نے طلحہ بن یحییٰ سے ،  انہوں نے اپنی پھوپھی عائشہ بنت طلحہ سے اور انہوں نے ام المومنین حضرت عائ"}
{"hadithnumber": "6769", "text": "اسماعیل بن زکریا اور سفیان ثوری نے طلحہ بن یحییٰ سے وکیع کی حدیث کے مانند اسی کی سند کے ساتھ روایت ک"}
{"hadithnumber": "6770", "text": "وکیع نے ہمیں معمر سے حدیث بیان کی ،  انہوں نے علقمہ بن مرثد سے ،  انہوں نے مغیرہ بن عبداللہ یشکری سے"}
{"hadithnumber": "6771", "text": "ابن بشر نے مسعر سے اسی سند کے ساتھ خبر دی ،  مگر ابن بشر اور وکیع دونوں سے ان کی  ( روایت کردہ )  حد"}
{"hadithnumber": "6772", "text": "عبدالرزاق نے کہا :  ہمیں ثوری نے علقمہ بن مرثد سے خبر دی ،  انہوں نے مغیرہ بن عبداللہ یشکری سے ،  ان"}
{"hadithnumber": "6773", "text": "ابوداود سلیمان بن معبد نے کہا :  ہمیں حسین بن حفص نے حدیث بیان کی ،  انہوں نے کہا :  ہمیں سفیان نے ا"}
{"hadithnumber": "6774", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   \" طاقت و"}
