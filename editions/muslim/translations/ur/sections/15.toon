{"hadithnumber": "3096", "text": "عمر بن حسین نے عبد اللہ بن ابی سلمہ سے انھوں نے عبد اللہ بن عبد اللہ بن عمر رضی اللہ تعالیٰ عنہ   سے"}
{"hadithnumber": "3097", "text": "یحییٰ بن یحییٰ نے ہمیں حدیث سنا ئی کہا :  میں نے امام مالک کے سامنے قراءت کی کہ محمد بن ابی بکر ثقفی"}
{"hadithnumber": "3098", "text": "موسیٰ بن عقبہ نے کہا  :  مجھے محمد بن ابی بکر نے حدیث بیان کی کہا :  میں نے عرفہ کی صبح حضرت انس بن"}
{"hadithnumber": "3099", "text": "یحییٰ بن یحییٰ نے ہمیں حدیث سنائی  ، کہا  :  میں نے امام مالک کے سامنے قراءت کی کہ موسیٰ بن عقبہ سے"}
{"hadithnumber": "3100", "text": "یحییٰ بن سعید نے زبیر کے مولیٰ موسیٰ بن عقبہ سے اسی سند سے روایت کی کہ حضرت اسامہ بن زید رضی اللہ تع"}
{"hadithnumber": "3101", "text": "عبد اللہ بن مبا رک نے ابراہیم بن عقبہ سے انھوں نے کریب مولیٰ ابن عباس رضی اللہ تعالیٰ عنہ   سے روایت"}
{"hadithnumber": "3102", "text": "ابو خیثمہ زہیر نے ہم سے حدیث بیان کی ،  ( کہا :   ) ہمیں ابراہیم بن عقبہ نے حدیث بیان کی ، کہا : مجھ"}
{"hadithnumber": "3103", "text": "محمد بن عقبہ نے کریب سےاور انھوں نے اسامہ بن زید سے روایت کی کہ جب رسول اللہ  صلی اللہ علیہ وسلم  اس"}
{"hadithnumber": "3104", "text": "عطاء مولیٰ بن سبا ع نے حضرت اسامہ بن زید  رضی اللہ تعالیٰ عنہ  سے روایت کی ۔ کہ رسول اللہ  صلی اللہ"}
{"hadithnumber": "3105", "text": "حضرت ابن عباس  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ رسول اللہ صلی اللہ علیہ وسلم  عرفہ سے لوٹے اور اس"}
{"hadithnumber": "3106", "text": "ہمیں حماد بن زید نے حدیث بیان کی ،  ( کہا :  ) ہمیں ہشام نے اپنے والد ( عروہ )  سے حدیث بیا ن کی ، ا"}
{"hadithnumber": "3107", "text": "ابو بکر بن ابی شیبہ نے ہمیں یہ حدیث سنائی  ( کہا :  )  ہمیں عبدہ بن سلیمان  ، عبداللہ بن نمیر اور حم"}
{"hadithnumber": "3110", "text": "سالم بن عبداللہ نے حضرت ابن عمر  رضی اللہ تعالیٰ عنہ  سے روایت کی کہ رسول اللہ  صلی اللہ علیہ وسلم"}
{"hadithnumber": "3111", "text": "عبیداللہ بن عبداللہ بن عمر نے خبر دی کہ ان کے والد نے کہا : رسول اللہ  صلی اللہ علیہ وسلم نے مزدلفہ"}
{"hadithnumber": "3112", "text": "عبدالرحمان بن مہدی نے کہا :  ہمیں شعبہ نے حکم اور سلمہ بن کہیل سے حدیث بیان کی ، انھوں نے سعید بن جب"}
{"hadithnumber": "3113", "text": "وکیع نے کہا : ہمیں شعبہ نے اسی سند کے ساتھ حدیث بیان کی اور کہا : آپ نے وہ دونوں نمازیں ایک ہی اقامت"}
{"hadithnumber": "3114", "text": "۔  ( سفیان )  ثوری نے سلمہ بن کہیل سے  ، انھوں نے سعید بن جبیر سے اور انھوں نے ابن عمر  رضی اللہ تعا"}
{"hadithnumber": "3115", "text": "ابو اسحاق سے روایت ہے  ، انھوں نے کہا : سعید بن جبیر نے کہا : ہم حضرت ابن عمر  رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "3116", "text": "ابو معاویہ نے اعمش سے خبر دی ، انھوں نے عمارہ سے ، انھوں نے عبدالرحمان بن یزید سے اور انھوں نے حضرت"}
{"hadithnumber": "3117", "text": "جریر نے اعمش سے اسی سند کے ساتھ یہ حدیث بیان کی  ، اور کہا :  ( فجر کی نماز )  اس کے (  معمول کے )"}
{"hadithnumber": "3118", "text": "فلح ، یعنی ابن حمید نے قاسم سے اور انھوں نے حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے روایت کی ، انھوں ن"}
