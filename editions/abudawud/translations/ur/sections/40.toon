{"hadithnumber": "4351", "text": "عکرمہ سے روایت ہے کہ  علی رضی اللہ عنہ نے کچھ لوگوں کو جو اسلام سے پھر گئے تھے آگ میں جلوا دیا، ابن"}
{"hadithnumber": "4352", "text": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  کسی مسلمان آدمی"}
{"hadithnumber": "4353", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  کسی مسلمان شخص"}
{"hadithnumber": "4354", "text": "ابوموسیٰ اشعری رضی اللہ عنہ کہتے ہیں  میں نبی اکرم صلی اللہ علیہ وسلم کے پاس آیا، میرے ساتھ قبیلہ اش"}
{"hadithnumber": "4355", "text": "ابوموسیٰ اشعری رضی اللہ عنہ کہتے ہیں کہ  میرے پاس معاذ رضی اللہ عنہ آئے، میں یمن میں تھا، ایک یہودی"}
{"hadithnumber": "4356", "text": "اس سند سے بھی ابوبردہ رضی اللہ عنہ سے یہی واقعہ مروی ہے، وہ کہتے ہیں  ابوموسیٰ رضی اللہ عنہ کے پاس ا"}
{"hadithnumber": "4357", "text": "قاسم سے بھی یہی واقعہ مروی ہے اس میں ہے کہ  جب تک اس کی گردن مار نہیں دی گئی وہ سواری سے نیچے نہیں ا"}
{"hadithnumber": "4358", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  عبداللہ بن سعد بن ابی سرح ۱؎ رسول اللہ صلی اللہ علیہ وسل"}
{"hadithnumber": "4359", "text": "سعد رضی اللہ عنہ کہتے ہیں کہ  جب مکہ فتح ہوا تو عبداللہ بن سعد بن ابی سرح عثمان بن عفان رضی اللہ عنہ"}
{"hadithnumber": "4360", "text": "جریر رضی اللہ عنہ کہتے ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا:  جب غلام دارال"}
{"hadithnumber": "4361", "text": "عبداللہ بن عباس رضی اللہ عنہما کا بیان ہے کہ  ایک نابینا شخص کے پاس ایک ام ولد تھی جو نبی اکرم صلی ا"}
{"hadithnumber": "4362", "text": "علی رضی اللہ عنہ کہتے ہیں کہ  ایک یہودی عورت نبی اکرم صلی اللہ علیہ وسلم کو گالیاں دیتی اور آپ کی ہج"}
{"hadithnumber": "4363", "text": "ابوبرزہ رضی اللہ عنہ کہتے ہیں کہ  میں ابوبکر رضی اللہ عنہ کے پاس تھا، وہ ایک شخص پر ناراض ہوئے اور ب"}
{"hadithnumber": "4364", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  قبیلہ عکل، یا قبیلہ عرینہ کے کچھ لوگ رسول اللہ صلی اللہ علیہ و"}
{"hadithnumber": "4365", "text": "اس سند سے بھی ایوب سے یہی حدیث مروی ہے اس میں ہے  آپ صلی اللہ علیہ وسلم نے سلائیوں کو گرم کرنے کا حک"}
{"hadithnumber": "4366", "text": "انس بن مالک رضی اللہ عنہ سے بھی یہی حدیث مروی ہے اس میں ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے ان کے"}
{"hadithnumber": "4367", "text": "انس بن مالک رضی اللہ عنہ سے بھی یہی حدیث مروی ہے اس میں انس کہتے ہیں کہ  میں نے ان میں سے ایک شخص کو"}
{"hadithnumber": "4368", "text": "اس سند سے بھی انس بن مالک سے یہی حدیث انہیں جیسے الفاظ سے مروی ہے  اس میں یہ اضافہ ہے  پھر آپ نے مثل"}
{"hadithnumber": "4369", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  کچھ لوگوں نے نبی اکرم صلی اللہ علیہ وسلم کے اونٹوں کو لوٹ"}
{"hadithnumber": "4370", "text": "ابوالزناد سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے جب ان لوگوں کے  ( ہاتھ پاؤں )  کاٹے جنہوں"}
{"hadithnumber": "4371", "text": "محمد بن سیرین کہتے ہیں کہ  یہ حدود کے نازل کئے جانے سے پہلے کی ہے یعنی انس رضی اللہ عنہ کی روایت۔"}
{"hadithnumber": "4372", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  آیت کریمہ «إنما جزاء الذين يحاربون الله ورسوله ويسعون في"}
{"hadithnumber": "4373", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  قریش کو ایک مخزومی عورت جس نے چوری کی تھی کے معاملہ نے"}
{"hadithnumber": "4374", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  ایک مخزومی عورت سامان مانگ کر لے جایا کرتی اور واپسی کے"}
{"hadithnumber": "4375", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  صاحب حیثیت اور"}
{"hadithnumber": "4376", "text": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  حدو"}
{"hadithnumber": "4377", "text": "نعیم بن ہزال اسلمی رضی اللہ عنہ روایت کرتے ہیں کہ  ماعز رضی اللہ عنہ نبی اکرم صلی اللہ علیہ وسلم کے"}
{"hadithnumber": "4378", "text": "ابن المنکدر سے روایت ہے کہ  ہزال رضی اللہ عنہ نے ماعز رضی اللہ عنہ سے کہا تھا کہ وہ نبی اکرم صلی الل"}
{"hadithnumber": "4379", "text": "وائل رضی اللہ عنہ کہتے ہیں کہ  ایک عورت رسول اللہ صلی اللہ علیہ وسلم کے زمانہ میں نماز پڑھنے کے اراد"}
{"hadithnumber": "4380", "text": "ابوامیہ مخزومی رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم کے پاس ایک چور لایا گیا جس ن"}
{"hadithnumber": "4381", "text": "ابوامامہ رضی اللہ عنہ کا بیان ہے کہ  ایک شخص نبی اکرم صلی اللہ علیہ وسلم کے پاس آیا اور عرض کیا: الل"}
{"hadithnumber": "4382", "text": "ازہر بن عبداللہ حرازی کا بیان ہے کہ  کلاع کے کچھ لوگوں کا مال چرایا گیا تو انہوں نے کچھ کپڑا بننے وا"}
{"hadithnumber": "4383", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم چوتھائی دینار یا اس سے زائد"}
{"hadithnumber": "4384", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  چور کا ہاتھ"}
{"hadithnumber": "4385", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک ڈھال میں جس کی قیمت ت"}
