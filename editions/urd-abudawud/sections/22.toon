hadiths[84]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
3242,"عمران بن حصین رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جو کسی دباؤ میں آ ",,,,,3242
3243,"عبداللہ (عبداللہ بن مسعود) رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو کسی",,,,,3243
3244,اشعث بن قیس رضی اللہ عنہ کہتے ہیں کہ  یمن کی ایک زمین کے سلسلے میں کندہ کے ایک آدمی اور حضر موت کے ا,,,,,3244
3245,وائل بن حجر حضرمی رضی اللہ عنہ کہتے ہیں کہ  حضر موت کا ایک شخص اور کندہ کا ایک شخص دونوں رسول اللہ ص,,,,,3245
3246,"جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص میرے منب",,,,,3246
3247,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو کوئی قسم کھائے اور اپ",,,,,3247
3248,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم اپنے باپ دادا کی قسم ",,,,,3248
3249,عمر بن خطاب رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے انہیں اس حال میں پایا کہ وہ ای,,,,,3249
3250,عمر رضی اللہ عنہ کہتے ہیں کہ  مجھے رسول صلی اللہ علیہ وسلم نے  ( غیر اللہ کی قسم کھاتے ہوئے )  سنا، ,,,,,3250
3251,سعد بن عبیدہ کہتے ہیں  عبداللہ بن عمر رضی اللہ عنہما نے ایک شخص کو کعبہ کی قسم کھاتے ہوئے سنا تو ابن,,,,,3251
3252,مالک بن ابی عامر کہتے ہیں کہ  طلحہ بن عبیداللہ رضی اللہ عنہ نے سنا  ( یعنی اعرابی کے واقعہ میں )  نب,,,,,3252
3253,"بریدہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو امانت کی قسم کھائے وہ ہم",,,,,3253
3254,عطاء سے یمین لغو کے بارے میں روایت ہے، وہ کہتے ہیں کہ  ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ ر,,,,,3254
3255,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تمہاری قسم کا اعتبار اسی",,,,,3255
3256,سوید بن حنظلہ رضی اللہ عنہ کہتے ہیں  ہم نکلے، رسول اللہ صلی اللہ علیہ وسلم کے پاس جانے کا ارادہ کر ر,,,,,3256
3257,ثابت بن ضحاک رضی اللہ عنہ نے خبر دی کہ  انہوں نے درخت کے نیچے رسول اللہ صلی اللہ علیہ وسلم سے بیعت ک,,,,,3257
3258,"بریدہ رضی اللہ عنہ کہتے ہیں  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص قسم کھائے اور کہے میں ا",,,,,3258
3259,یوسف بن عبداللہ بن سلام کہتے ہیں  میں نے نبی اکرم صلی اللہ علیہ وسلم کو دیکھا آپ نے روٹی کے ٹکڑے پر ,,,,,3259
3260,اس سند سے بھی  یوسف بن عبداللہ بن سلام سے اسی کے مثل مروی ہے۔,,,,,3260
3261,"عبداللہ بن عمر رضی اللہ عنہما سے مرفوعاً روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جس نے ",,,,,3261
3262,"عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے قسم کھائی ",,,,,3262
3263,"عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں  رسول اللہ صلی اللہ علیہ وسلم اکثر اس طرح قسم کھاتے تھے: «لا،",,,,,3263
3264,"ابو سعید خدری رضی اللہ عنہ کہتے ہیں  جب رسول اللہ صلی اللہ علیہ وسلم زور دے کر قسم کھاتے تو فرماتے: ",,,,,3264
3265,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم جب قسم کھاتے تو فرماتے: «لا، ‏‏‏‏ وأ",,,,,3265
3266,عاصم بن لقیط کہتے ہیں کہ  لقیط بن عامر رضی اللہ عنہ نبی اکرم صلی اللہ علیہ وسلم کے پاس ایک وفد لے کر,,,,,3266
3267,عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  ابوبکر رضی اللہ عنہ نے نبی اکرم صلی اللہ علیہ وسلم کو قس,,,,,3267
3268,عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  ابوہریرہ رضی اللہ عنہ بیان کر رہے تھے کہ ایک شخص رسول ال,,,,,3268
3269,عبداللہ بن عباس رضی اللہ عنہما نے نبی اکرم صلی اللہ علیہ وسلم سے یہی حدیث روایت کی ہے  لیکن اس میں ا,,,,,3269
3270,عبدالرحمٰن بن ابوبکر رضی اللہ عنہما کہتے ہیں کہ  ہمارے یہاں ہمارے کچھ مہمان آئے، اور ابوبکر رضی اللہ,,,,,3270
3271,اس سند سے بھی عبدالرحمٰن بن ابوبکر رضی اللہ عنہما سے یہ حدیث اسی طرح مروی ہے اور اس میں مزید یہ ہے ک,,,,,3271
3272,سعید بن مسیب سے روایت ہے کہ  انصار کے دو بھائیوں میں میراث کی تقسیم کا معاملہ تھا، ان میں کے ایک نے ,,,,,3272
3273,"عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  صرف ان چیزوں می",,,,,3273
3274,"عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  نذر او",,,,,3274
3275,عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  دو آدمی اپنا جھگڑا لے کر نبی اکرم صلی اللہ علیہ وسلم کے ,,,,,3275
3276,"ابوموسیٰ اشعری رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  قسم اللہ کی میں کسی",,,,,3276
3277,"عبدالرحمٰن بن سمرہ رضی اللہ عنہ کہتے ہیں کہ  مجھ سے نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  عبدالرحم",,,,,3277
3278,"اس سند سے بھی عبدالرحمٰن بن سمرہ رضی اللہ عنہ سے اسی طرح مروی ہے  اس میں ہے:  تو قسم کا کفارہ ادا کر",,,,,3278
3279,عبدالرحمٰن بن حرملہ کہتے ہیں کہ  ام حبیب بنت ذؤیب بن قیس مزنیہ قبیلہ بنو اسلم کے ایک شخص کے نکاح میں,,,,,3279
3280,محمد بن محمد بن خلاد ابوعمر کا بیان ہے کہ  میرے پاس ایک مکوک ۱؎ تھا اسے مکوک خالد کہا جاتا تھا، وہ ہ,,,,,3280
3281,امیہ بن خالد کہتے ہیں  جب خالد قسری گورنر مقرر ہوئے تو انہوں نے صاع کو دو چند کر دیا تو ایک صاع  ( ۱,,,,,3281
3282,"معاویہ بن حکم سلمی کہتے ہیں کہ  میں نے عرض کیا: اللہ کے رسول! میری ایک لونڈی ہے میں نے اسے ایک تھپڑ ",,,,,3282
3283,شرید سے روایت ہے کہ  ان کی والدہ نے انہیں اپنی طرف سے ایک مومنہ لونڈی آزاد کر دینے کی وصیت کی تو وہ ,,,,,3283
3284,ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کے پاس ایک شخص ایک کالی لونڈی لے کر آ,,,,,3284
3285,"عکرمہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  قسم اللہ کی، میں قریش سے جہاد کروں گا، ق",,,,,3285
3286,"عکرمہ سے مرفوعاً روایت ہے کہ  آپ صلی اللہ علیہ وسلم نے فرمایا:  قسم اللہ کی میں قریش سے جہاد کروں گا",,,,,3286
3287,عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نذر سے منع فرماتے تھے، اور ف,,,,,3287
3288,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:   ( اللہ تعالیٰ کہتا ہے: ",,,,,3288
3289,"ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو اللہ کی اطا",,,,,3289
3290,"ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  معصیت کی نذر نہ",,,,,3290
3291,اس سند سے بھی ابن شہاب سے اسی مفہوم کی حدیث اسی طریق سے مروی ہے۔ ابوداؤد کہتے ہیں  میں نے احمد بن شب,,,,,3291
3292,"ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  معصیت کی نذر نہیں",,,,,3292
3293,عقبہ بن عامر رضی اللہ عنہ نے خبر دی کہ  انہوں نے نبی اکرم صلی اللہ علیہ وسلم سے اپنی ایک بہن کے بارے,,,,,3293
3294,"عبدالرزاق کہتے ہیں: ہم سے ابن جریج نے بیان کیا ہے کہ  یحییٰ بن سعید نے مجھے لکھا کہ مجھے بنو ضمرہ کے",,,,,3294
3295,عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  ایک شخص نبی اکرم صلی اللہ علیہ وسلم کے پاس آیا اور اس نے,,,,,3295
3296,عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  عقبہ بن عامر رضی اللہ عنہ کی بہن نے پیدل بیت اللہ جانے ک,,,,,3296
3297,عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کو جب خبر ملی کہ عقبہ بن عام,,,,,3297
3298,عکرمہ سے روایت ہے کہ  عقبہ بن عامر رضی اللہ عنہ کی بہن، آگے وہی باتیں ہیں جو ہشام کی حدیث میں ہے لیک,,,,,3298
3299,عقبہ بن عامر جہنی رضی اللہ عنہ کہتے ہیں  میری بہن نے بیت اللہ پیدل جانے کی نذر مانی اور مجھے حکم دیا,,,,,3299
3300,عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم خطبہ دے رہے تھے کہ اسی دوران,,,,,3300
3301,انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک شخص کو اپنے دونوں بیٹوں کے,,,,,3301
3302,عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کعبہ کا طواف کرتے ہوئے ایک ا,,,,,3302
3303,عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  عقبہ بن عامر رضی اللہ عنہ کی بہن نے پیدل حج کرنے کی نذر ,,,,,3303
3304,"عقبہ بن عامر جہنی رضی اللہ عنہ کہتے ہیں کہ  انہوں نے نبی اکرم صلی اللہ علیہ وسلم سے کہا: میری بہن نے",,,,,3304
3305,"جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  فتح مکہ کے دن ایک شخص کھڑا ہوا اور کہنے لگا: اللہ کے رسو",,,,,3305
3306,عمر بن عبدالرحمٰن بن عوف نے بعض صحابہ رسول صلی اللہ علیہ وسلم سے یہی حدیث روایت کی ہے لیکن اس میں ات,,,,,3306
3307,عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  سعد بن عبادہ رضی اللہ عنہ نے رسول اللہ صلی اللہ علیہ وسل,,,,,3307
3308,عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  ایک عورت بحری سفر پر نکلی اس نے نذر مانی کہ اگر وہ بخیری,,,,,3308
3309,"بریدہ رضی اللہ عنہ کہتے ہیں کہ  ایک عورت رسول اللہ صلی اللہ علیہ وسلم کے پاس آئی اور اس نے عرض کیا: ",,,,,3309
3310,عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  ایک عورت نبی اکرم صلی اللہ علیہ وسلم کے پاس آئی اور اس ن,,,,,3310
3311,"ام المؤمنین عائشہ رضی اللہ عنہا فرماتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جو مر جائے او",,,,,3311
3312,عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کے پاس ایک عورت آئی اور اس ن,,,,,3312
3313,ابوقلابہ کہتے ہیں کہ مجھ سے ثابت بن ضحاک نے بیان کیا ہے، وہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسل,,,,,3313
3314,میمونہ بنت کردم کہتی ہیں کہ  میں اپنے والد کے ساتھ حجۃ الوداع میں نکلی، تو میں نے رسول اللہ صلی اللہ,,,,,3314
3315,میمونہ اپنے والد کردم بن سفیان سے  اسی جیسی لیکن اس سے قدرے اختصار کے ساتھ روایت کرتی ہیں آپ نے پوچھ,,,,,3315
3316,عمران بن حصین رضی اللہ عنہما کہتے ہیں کہ  عضباء ۱؎ بنو عقیل کے ایک شخص کی تھی، حاجیوں کی سواریوں میں,,,,,3316
3317,"کعب بن مالک رضی اللہ عنہ کہتے ہیں کہ  میں نے عرض کیا: اللہ کے رسول! میری توبہ یہ ہے کہ میں اپنے سارے",,,,,3317
3318,کعب بن مالک رضی اللہ عنہ کہتے ہیں  جب ان کی توبہ قبول ہو گئی تو انہوں نے رسول اللہ صلی اللہ علیہ وسل,,,,,3318
3319,کعب بن مالک رضی اللہ عنہ کہتے ہیں  انہوں نے یا ابولبابہ رضی اللہ عنہ نے یا کسی اور نے جسے اللہ نے چا,,,,,3319
3320,"زہری کہتے ہیں: مجھے ابن کعب بن مالک نے خبر دی ہے، وہ کہتے ہیں کہ  یہ ابولبابہ رضی اللہ عنہ تھے پھر ا",,,,,3320
3321,"کعب بن مالک رضی اللہ عنہ سے اسی قصہ میں روایت ہے، وہ کہتے ہیں  میں نے عرض کیا: اللہ کے رسول! میری تو",,,,,3321
3322,"عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص غیر نامز",,,,,3322
