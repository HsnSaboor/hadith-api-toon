{"hadithnumber": "1670", "arabic": "حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ، حَدَّثَنَا الْمُعْتَمِرُ بْنُ سُلَيْمَانَ، عَنْ أَبِي", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 23, Hadith 1", "international_number": "1670", "narrator_chain": ""}
{"hadithnumber": "1671", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، عَنْ سُفْيَانَ، وَشُعْبَةَ، عَن", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 23, Hadith 2", "international_number": "1671", "narrator_chain": ""}
{"hadithnumber": "1672", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى النَّيْسَابُورِيُّ، حَدَّثَنَا الْحَجَّاجُ بْنُ مُحَمَّدٍ، حَدَّثَ", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 23, Hadith 3", "international_number": "1672", "narrator_chain": ""}
{"hadithnumber": "1673", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ عَبْدَةَ الضَّبِّيُّ الْبَصْرِيُّ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَ", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Bukhari'}", "reference": "Book 23, Hadith 4", "international_number": "1673", "narrator_chain": ""}
{"hadithnumber": "1674", "arabic": "حَدَّثَنَا إِسْحَاق بْنُ مُوسَى الْأَنْصَارِيُّ، حَدَّثَنَا مَعْنٌ، حَدَّثَنَا مَالِكٌ، عَنْ عَبْدِ", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Hasan'},{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 23, Hadith 5", "international_number": "1674", "narrator_chain": ""}
{"hadithnumber": "1675", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، وَنَصْرُ بْنُ عَلِيٍّ، قَالَا:‏‏‏‏ حَدَّثَنَا سُفْيَانُ بْنُ عُيَي", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 23, Hadith 6", "international_number": "1675", "narrator_chain": ""}
{"hadithnumber": "1676", "arabic": "حَدَّثَنَا حَدَّثَنَا مَحْمُودُ بْنُ غَيْلَانَ، حَدَّثَنَا وَهْبُ بْنُ جَرِيرٍ، وَأَبُو دَاوُدَ الطّ", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 23, Hadith 7", "international_number": "1676", "narrator_chain": ""}
{"hadithnumber": "1677", "arabic": "حَدَّثَنَا حَدَّثَنَا مُحَمَّدُ بْنُ حُمَيْدٍ الرَّازِيُّ، حَدَّثَنَا سَلَمَةُ بْنُ الْفَضْلِ، عَنْ", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Daif Isnaad'},{'name': 'Al-Albani', 'grade': 'Daif Isnaad'},{'name': 'Bashar Awad Maarouf', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 23, Hadith 8", "international_number": "1677", "narrator_chain": ""}
{"hadithnumber": "1678", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، أَنْبَأَنَا إِسْمَاعِيل بْنُ أَب", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 23, Hadith 9", "international_number": "1678", "narrator_chain": ""}
{"hadithnumber": "1679", "arabic": "حَدَّثَنَا حَدَّثَنَا مُحَمَّدُ بْنُ عُمَرَ بْنِ الْوَلِيدِ الْكِنْدِيُّ الْكُوفِيُّ، وَأَبُو كُرَيْ", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Hasan'},{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 23, Hadith 10", "international_number": "1679", "narrator_chain": ""}
{"hadithnumber": "1680", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا يَحْيَى بْنُ زَكَرِيَّا بْنِ أَبِي زَائِدَةَ، حَدَّثَنَ", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 23, Hadith 11", "international_number": "1680", "narrator_chain": ""}
{"hadithnumber": "1681", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ رَافِعٍ، حَدَّثَنَا يَحْيَى بْنُ إِسْحَاق وَهُوَ السَّالِحَانِيُّ، حَدَّثَ", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Hasan'},{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 23, Hadith 12", "international_number": "1681", "narrator_chain": ""}
{"hadithnumber": "1682", "arabic": "حَدَّثَنَا مَحْمُودُ بْنُ غَيْلَانَ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا سُفْيَانُ، عَنْ أَبِي إِسْحَاق،", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 23, Hadith 13", "international_number": "1682", "narrator_chain": ""}
{"hadithnumber": "1683", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ شُجَاعٍ الْبَغْدَادِيُّ، حَدَّثَنَا أَبُو عُبَيْدَةَ الْحَدَّادُ، عَنْ عُث", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Daif'},{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Bashar Awad Maarouf', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 23, Hadith 14", "international_number": "1683", "narrator_chain": ""}
{"hadithnumber": "1684", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ مُحَمَّدِ بْنِ مُوسَى، أَنْبَأَنَا عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ، أَنْبَ", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 23, Hadith 15", "international_number": "1684", "narrator_chain": ""}
{"hadithnumber": "1685", "arabic": "حَدَّثَنَا مَحْمُودُ بْنُ غَيْلَانَ، حَدَّثَنَا أَبُو دَاوُدَ الطَّيَالِسِيُّ، قَالَ:‏‏‏‏ أَنْبَأَنَ", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 23, Hadith 16", "international_number": "1685", "narrator_chain": ""}
{"hadithnumber": "1686", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، وَابْنُ أَبِي عَدِيٍّ، وأبو", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 23, Hadith 17", "international_number": "1686", "narrator_chain": ""}
{"hadithnumber": "1687", "arabic": "حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ، عَنْ ثَابِتٍ، عَنْ أَنَسٍ، قَالَ:‏‏‏‏ كَانَ", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 23, Hadith 18", "international_number": "1687", "narrator_chain": ""}
{"hadithnumber": "1688", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، حَدَّثَنَا سُفْيَانُ الثَّوْرِي", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 23, Hadith 19", "international_number": "1688", "narrator_chain": ""}
{"hadithnumber": "1689", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عُمَرَ بْنِ عَلِيٍّ الْمُقَدَّمِيُّ الْبَصْرِيُّ، حَدَّثَنِي أَبِي، عَنْ س", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih Isnaad'},{'name': 'Al-Albani', 'grade': 'Sahih Isnaad'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 23, Hadith 20", "international_number": "1689", "narrator_chain": ""}
{"hadithnumber": "1690", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ صُدْرَانَ أَبُو جَعْفَرٍ الْبَصْرِيُّ، حَدَّثَنَا طَالِبُ بْنُ حُجَيْرٍ، ع", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Daif'},{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 23, Hadith 21", "international_number": "1690", "narrator_chain": ""}
{"hadithnumber": "1691", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا وَهْبُ بْنُ جَرِيرِ بْنِ حَازِمٍ، حَدَّثَنَا أَبِي، ع", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 23, Hadith 22", "international_number": "1691", "narrator_chain": ""}
{"hadithnumber": "1692", "arabic": "حَدَّثَنَا أَبُو سَعِيدٍ الْأَشَجُّ، حَدَّثَنَا يُونُسُ بْنُ بُكَيْرٍ، عَنْ مُحَمَّدِ بْنِ إِسْحَاق،", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Hasan'},{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 23, Hadith 23", "international_number": "1692", "narrator_chain": ""}
{"hadithnumber": "1693", "arabic": "حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، عَنْ ابْنِ شِهَابٍ، عَنْ أَنَسِ بْنِ مَالِكٍ،", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 23, Hadith 24", "international_number": "1693", "narrator_chain": ""}
{"hadithnumber": "1694", "arabic": "حَدَّثَنَا هَنَّادٌ، حَدَّثَنَا عَبْثَرُ بْنُ الْقَاسِمِ، عَنْ حُصَيْنٍ، عَنْ الشَّعْبِيِّ، عَنْ عُر", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Bukhari And Muslim'}", "reference": "Book 23, Hadith 25", "international_number": "1694", "narrator_chain": ""}
{"hadithnumber": "1695", "arabic": "حَدَّثَنَا عَبْدُ اللَّهِ بْنُ الصَّبَّاحِ الْهَاشِمِيُّ الْبَصْرِيُّ، ‏‏‏‏‏‏حَدَّثَنَا يَزِيدُ بْنُ", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Hasan Sahih'},{'name': 'Al-Albani', 'grade': 'Hasan Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 23, Hadith 26", "international_number": "1695", "narrator_chain": ""}
{"hadithnumber": "1696", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ مُحَمَّدٍ، أَخْبَرَنَا عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ، أَخْبَرَنَا ابْنُ", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 23, Hadith 27", "international_number": "1696", "narrator_chain": ""}
{"hadithnumber": "1697", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا وَهْبُ بْنُ جَرِيرٍ، حَدَّثَنَا أَبِي، عَنْ يَحْيَى ب", "grades": "{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 23, Hadith 28", "international_number": "1697", "narrator_chain": ""}
{"hadithnumber": "1698", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، حَدَّثَنَا سُفْيَانُ، قَالَ:‏‏‏", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Bukhari And Muslim'}", "reference": "Book 23, Hadith 29", "international_number": "1698", "narrator_chain": ""}
{"hadithnumber": "1699", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ وَزِيرٍ الْوَاسِطِيُّ، حَدَّثَنَا إِسْحَاق بْنُ يُوسُفَ الْأَزْرَقُ، عَنْ", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 23, Hadith 30", "international_number": "1699", "narrator_chain": ""}
{"hadithnumber": "1700", "arabic": "حَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا وَكِيعٌ، عَنْ ابْنِ أَبِي ذِئْبٍ، عَنْ نَافِعِ بْنِ أَبِي نَاف", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 23, Hadith 31", "international_number": "1700", "narrator_chain": ""}
{"hadithnumber": "1701", "arabic": "حَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا إِسْمَاعِيل بْنُ إِبْرَاهِيمَ، حَدَّثَنَا أَبُو جَهْضَمٍ مُوسَ", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih Isnaad'},{'name': 'Al-Albani', 'grade': 'Sahih Isnaad'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 23, Hadith 32", "international_number": "1701", "narrator_chain": ""}
{"hadithnumber": "1702", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ مُحَمَّدِ بْنِ مُوسَى، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ، قَالَ:‏", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 23, Hadith 33", "international_number": "1702", "narrator_chain": ""}
{"hadithnumber": "1703", "arabic": "حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ، عَنْ سُهَيْلِ بْنِ أَبِي صَالِحٍ", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 23, Hadith 34", "international_number": "1703", "narrator_chain": ""}
{"hadithnumber": "1704", "arabic": "حَدَّثَنَا عَبْدُ اللَّهِ بْنُ أَبِي زِيَادٍ، حَدَّثَنَا الْأَحْوَصُ بْنُ الْجَوَّابِ أَبُو الْجَوَّ", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Daif Isnaad'},{'name': 'Al-Albani', 'grade': 'Daif Isnaad'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 23, Hadith 35", "international_number": "1704", "narrator_chain": ""}
{"hadithnumber": "1705", "arabic": "حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا اللَّيْثُ، عَنْ نَافِعٍ، عَنْ ابْنِ عُمَرَ، عَنِ النَّبِيِّ صَلَّى", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'}", "reference": "Book 23, Hadith 36", "international_number": "1705", "narrator_chain": ""}
{"hadithnumber": "1706", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى النَّيْسَابُورِيُّ، حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ، حَدَّثَنَا", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 23, Hadith 38", "international_number": "1706", "narrator_chain": ""}
{"hadithnumber": "1707", "arabic": "حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا اللَّيْثُ، عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ نَافِعٍ، عَنْ ا", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Bukhari And Muslim'}", "reference": "Book 23, Hadith 39", "international_number": "1707", "narrator_chain": ""}
{"hadithnumber": "1708", "arabic": "حَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا يَحْيَى بْنُ آدَمَ، عَنْ قُطْبَةَ بْنِ عَبْدِ الْعَزِيزِ، عَنْ", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Daif'},{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 23, Hadith 40", "international_number": "1708", "narrator_chain": ""}
{"hadithnumber": "1709", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، عَنْ سُفْيَانَ،", "grades": "", "reference": "Book 23, Hadith 41", "international_number": "1709", "narrator_chain": ""}
{"hadithnumber": "1710", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا رَوْحُ بْنُ عُبَادَةَ، عَنْ ابْنِ جُرَيْجٍ، عَنْ أَبِي", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 23, Hadith 43", "international_number": "1710", "narrator_chain": ""}
{"hadithnumber": "1711", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الْوَزِيرِ الْوَاسِطِيُّ، حَدَّثَنَا إِسْحَاق بْنُ يُوسُفَ الْأَزْرَقُ، عَ", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'}", "reference": "Book 23, Hadith 44", "international_number": "1711", "narrator_chain": ""}
{"hadithnumber": "1712", "arabic": "حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا اللَّيْثُ، عَنْ سَعِيدِ بْنِ أَبِي سَعِيدٍ الْمَقْبُرِيِّ، عَنْ عَ", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 23, Hadith 46", "international_number": "1712", "narrator_chain": ""}
{"hadithnumber": "1713", "arabic": "حَدَّثَنَا أَزْهَرُ بْنُ مَرْوَانَ الْبَصْرِيُّ، حَدَّثَنَا عَبْدُ الْوَارِثِ بْنُ سَعِيدٍ، عَنْ أَي", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 23, Hadith 47", "international_number": "1713", "narrator_chain": ""}
{"hadithnumber": "1714", "arabic": "حَدَّثَنَا هَنَّادٌ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، عَنْ الْأَعْمَشِ، عَنْ عَمْرِو بْنِ مُرَّةَ، عَنْ", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Daif'},{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 23, Hadith 48", "international_number": "1714", "narrator_chain": ""}
{"hadithnumber": "1715", "arabic": "حَدَّثَنَا مَحْمُودُ بْنُ غَيْلَانَ، حَدَّثَنَا أَبُو أَحْمَدَ، حَدَّثَنَا سُفْيَانُ، عَنْ ابْنِ أَب", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Daif Isnaad'},{'name': 'Al-Albani', 'grade': 'Daif Isnaad'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 23, Hadith 49", "international_number": "1715", "narrator_chain": ""}
{"hadithnumber": "1716", "arabic": "حَدَّثَنَا ابْنُ أَبِي عُمَرَ، حَدَّثَنَا سُفْيَانُ، عَنْ يَزِيدَ بْنِ أَبِي زِيَادٍ، عَنْ عَبْدِ ال", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Daif'},{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 23, Hadith 50", "international_number": "1716", "narrator_chain": ""}
{"hadithnumber": "1717", "arabic": "حَدَّثَنَا مَحْمُودُ بْنُ غَيْلَانَ، حَدَّثَنَا أَبُو دَاوُدَ، أَخْبَرَنَا شُعْبَةُ، عَنْ الْأَسْوَد", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 23, Hadith 51", "international_number": "1717", "narrator_chain": ""}
{"hadithnumber": "1718", "arabic": "حَدَّثَنَا حَدَّثَنَا ابْنُ أَبِي عُمَرَ، وَسَعِيدُ بْنُ عَبْدِ الرَّحْمَنِ الْمَخْزُومِيُّ، قَالَا:", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 23, Hadith 52", "international_number": "1718", "narrator_chain": ""}
{"hadithnumber": "1719", "arabic": "حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ، حَدَّثَنَا الْمُعْتَمِرُ بْنُ سُلَيْمَانَ، عَنْ أَبِيهِ، عَنْ أَبِي إِسْحَاقَ، عَنِ الْبَرَاءِ بْنِ عَازِبٍ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏\"‏ ائْتُونِي بِالْكَتِفِ أَوِ اللَّوْحِ ‏\"‏ ‏.‏ فَكَتَبَ ‏:‏ ‏(‏ لاَ يَسْتَوِي الْقَاعِدُونَ مِنَ الْمُؤْمِنِينَ ‏)‏ وَعَمْرُو بْنُ أُمِّ مَكْتُومٍ خَلْفَ ظَهْرِهِ فَقَالَ هَلْ لِي مِنْ رُخْصَةٍ فَنَزَلَتْ ‏:‏ ‏(‏ غَيْرُ أُولِي الضَّرَرِ ‏)‏ ‏.‏ وَفِي الْبَابِ عَنِ ابْنِ عَبَّاسٍ وَجَابِرٍ وَزَيْدِ بْنِ ثَابِتٍ ‏.‏ وَهَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ وَهُوَ حَدِيثٌ غَرِيبٌ مِنْ حَدِيثِ سُلَيْمَانَ التَّيْمِيِّ عَنْ أَبِي إِسْحَاقَ ‏.‏ وَقَدْ رَوَى شُعْبَةُ وَالثَّوْرِيُّ عَنْ أَبِي إِسْحَاقَ هَذَا الْحَدِيثَ ‏.", "grades": "", "reference": "", "international_number": "1719", "narrator_chain": "Narrated Al-Bara' bin 'Azib:"}
{"hadithnumber": "1720", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، عَنْ سُفْيَانَ، وَشُعْبَةَ، عَنْ حَبِيبِ بْنِ أَبِي ثَابِتٍ، عَنْ أَبِي الْعَبَّاسِ، عَنْ عَبْدِ اللَّهِ بْنِ عَمْرٍو، قَالَ جَاءَ رَجُلٌ إِلَى النَّبِيِّ صلى الله عليه وسلم يَسْتَأْذِنُهُ فِي الْجِهَادِ فَقَالَ ‏\"‏ أَلَكَ وَالِدَانِ ‏\"‏ ‏.‏ قَالَ نَعَمْ ‏.‏ قَالَ ‏\"‏ فَفِيهِمَا فَجَاهِدْ ‏\"‏ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنِ ابْنِ عَبَّاسٍ ‏.‏ وَهَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَأَبُو الْعَبَّاسِ هُوَ الشَّاعِرُ الأَعْمَى الْمَكِّيُّ وَاسْمُهُ السَّائِبُ بْنُ فَرُّوخَ ‏.‏", "grades": "", "reference": "", "international_number": "1720", "narrator_chain": "Narrated 'Abdullah bin 'Umar:"}
{"hadithnumber": "1721", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى النَّيْسَابُورِيُّ، حَدَّثَنَا الْحَجَّاجُ بْنُ مُحَمَّدٍ، حَدَّثَنَا ابْنُ جُرَيْجٍ، فِي قَوْلِهِِ ‏:‏ ‏(‏أطِيعُوا اللَّهَ وَأَطِيعُوا الرَّسُولَ وَأُولِي الأَمْرِ مِنْكُمْ ‏)‏ قَالَ عَبْدُ اللَّهِ بْنُ حُذَافَةَ بْنِ قَيْسِ بْنِ عَدِيٍّ السَّهْمِيُّ بَعَثَهُ رَسُولُ اللَّهِ صلى الله عليه وسلم عَلَى سَرِيَّةٍ ‏.‏ أَخْبَرَنِيهِ يَعْلَى بْنُ مُسْلِمٍ عَنْ سَعِيدِ بْنِ جُبَيْرٍ عَنِ ابْنِ عَبَّاسٍ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ غَرِيبٌ لاَ نَعْرِفُهُ إِلاَّ مِنْ حَدِيثِ ابْنِ جُرَيْجٍ ‏.‏", "grades": "", "reference": "", "international_number": "1721", "narrator_chain": "Narrated Al-Hajjaj bin Muhammad:"}
{"hadithnumber": "1722", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ عَبْدَةَ الضَّبِّيُّ الْبَصْرِيُّ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عَاصِمِ بْنِ مُحَمَّدٍ، عَنْ أَبِيهِ، عَنِ ابْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ لَوْ أَنَّ النَّاسَ يَعْلَمُونَ مَا أَعْلَمُ مِنَ الْوَحْدَةِ مَا سَرَى رَاكِبٌ بِلَيْلٍ ‏\"\"‏ ‏.‏ يَعْنِي وَحْدَهُ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Narrated Ibn 'Umar:"}
{"hadithnumber": "1723", "arabic": "حَدَّثَنَا إِسْحَاقُ بْنُ مُوسَى الأَنْصَارِيُّ، حَدَّثَنَا مَعْنٌ، حَدَّثَنَا مَالِكٌ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ حَرْمَلَةَ، عَنْ عَمْرِو بْنِ شُعَيْبٍ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ الرَّاكِبُ شَيْطَانٌ وَالرَّاكِبَانِ شَيْطَانَانِ وَالثَّلاَثَةُ رَكْبٌ ‏\"\"‏ ‏.‏ قَالَ أَبُو عِيسَى حَدِيثُ ابْنِ عُمَرَ حَدِيثٌ حَسَنٌ صَحِيحٌ لاَ نَعْرِفُهُ إِلاَّ مِنْ هَذَا الْوَجْهِ مِنْ حَدِيثِ عَاصِمٍ وَهُوَ ابْنُ مُحَمَّدِ بْنِ زَيْدِ بْنِ عَبْدِ اللَّهِ بْنِ عُمَرَ وَحَدِيثُ عَبْدِ اللَّهِ بْنِ عَمْرٍو حَدِيثٌ حَسَنٌ ‏.‏ قَالَ مُحَمَّدٌ هُوَ ثِقَةٌ صَدُوقٌ وَعَاصِمُ بْنُ عُمَرَ الْعُمَرِيُّ ضَعِيفٌ فِي الْحَدِيثِ لاَ أَرْوِي عَنْهُ شَيْئًا ‏.‏ وَحَدِيثُ عَبْدِ اللَّهِ بْنِ عَمْرٍو حَدِيثٌ حَسَنٌ", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Narrated 'Amr bin Shu'aib:"}
{"hadithnumber": "1724", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، وَنَصْرُ بْنُ عَلِيٍّ، قَالاَ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عَمْرِو بْنِ دِينَارٍ، سَمِعَ جَابِرَ بْنَ عَبْدِ اللَّهِ، يَقُولُ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ الْحَرْبُ خُدْعَةٌ ‏\"\"‏ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ عَلِيٍّ وَزَيْدِ بْنِ ثَابِتٍ وَعَائِشَةَ وَابْنِ عَبَّاسٍ وَأَبِي هُرَيْرَةَ وَأَسْمَاءَ بِنْتِ يَزِيدَ بْنِ السَّكَنِ وَكَعْبِ بْنِ مَالِكٍ وَأَنَسِ بْنِ مَالِكٍ ‏.‏ وَهَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Narrated Jabir bin ‘Abdullah :"}
{"hadithnumber": "1725", "arabic": "حَدَّثَنَا مَحْمُودُ بْنُ غَيْلاَنَ، حَدَّثَنَا وَهْبُ بْنُ جَرِيرٍ، وَأَبُو دَاوُدَ الطَّيَالِسِيُّ قَالاَ حَدَّثَنَا شُعْبَةُ، عَنْ أَبِي إِسْحَاقَ، قَالَ كُنْتُ إِلَى جَنْبِ زَيْدِ بْنِ أَرْقَمَ فَقِيلَ لَهُ كَمْ غَزَا النَّبِيُّ صلى الله عليه وسلم مِنْ غَزْوَةٍ قَالَ تِسْعَ عَشْرَةَ ‏.‏ فَقُلْتُ كَمْ غَزَوْتَ أَنْتَ مَعَهُ قَالَ سَبْعَ عَشْرَةَ ‏.‏ قُلْتُ أَيَّتُهُنَّ كَانَ أَوَّلَ قَالَ ذَاتُ الْعُشَيْرَاءِ أَوِ الْعُسَيْرَاءِ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏", "grades": "", "reference": "", "international_number": "1725", "narrator_chain": "Narrated Abu Ishaq:"}
{"hadithnumber": "1726", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ حُمَيْدٍ الرَّازِيُّ، حَدَّثَنَا سَلَمَةُ بْنُ الْفَضْلِ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَوْفٍ، قَالَ عَبَّأَنَا النَّبِيُّ صلى الله عليه وسلم بِبَدْرٍ لَيْلاً ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ أَبِي أَيُّوبَ ‏.‏ وَهَذَا حَدِيثٌ غَرِيبٌ لاَ نَعْرِفُهُ إِلاَّ مِنْ هَذَا الْوَجْهِ ‏.‏ وَسَأَلْتُ مُحَمَّدَ بْنَ إِسْمَاعِيلَ عَنْ هَذَا الْحَدِيثِ فَلَمْ يَعْرِفْهُ وَقَالَ مُحَمَّدُ بْنُ إِسْحَاقَ سَمِعَ مِنْ عِكْرِمَةَ ‏.‏ وَحِينَ رَأَيْتُهُ كَانَ حَسَنَ الرَّأْىِ فِي مُحَمَّدِ بْنِ حُمَيْدٍ الرَّازِيِّ ثُمَّ ضَعَّفَهُ بَعْدُ ‏.‏", "grades": "", "reference": "", "international_number": "1726", "narrator_chain": "Narrated 'Abdur-Rahman bin 'Awf:"}
{"hadithnumber": "1727", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، أَنْبَأَنَا إِسْمَاعِيلُ بْنُ أَبِي خَالِدٍ، عَنِ ابْنِ أَبِي أَوْفَى، قَالَ سَمِعْتُهُ يَقُولُ يَعْنِي النَّبِيَّ صلى الله عليه وسلم يَدْعُو عَلَى الأَحْزَابِ فَقَالَ ‏ ‏ اللَّهُمَّ مُنْزِلَ الْكِتَابِ سَرِيعَ الْحِسَابِ اهْزِمِ الأَحْزَابَ اللَّهُمَّ اهْزِمْهُمْ وَزَلْزِلْهُمْ ‏\"\"‏ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنِ ابْنِ مَسْعُودٍ ‏.‏ وَهَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Narrated Ibn Abi Awfa:"}
{"hadithnumber": "1728", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عُمَرَ بْنِ الْوَلِيدِ الْكِنْدِيُّ الْكُوفِيُّ، وَأَبُو كُرَيْبٍ وَمُحَمَّدُ بْنُ رَافِعٍ قَالُوا حَدَّثَنَا يَحْيَى بْنُ آدَمَ، عَنْ شَرِيكٍ، عَنْ عَمَّارٍ يَعْنِي الدُّهْنِيَّ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، أَنَّ النَّبِيَّ صلى الله عليه وسلم دَخَلَ مَكَّةَ وَلِوَاؤُهُ أَبْيَضُ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ غَرِيبٌ لاَ نَعْرِفُهُ إِلاَّ مِنْ حَدِيثِ يَحْيَى بْنِ آدَمَ عَنْ شَرِيكٍ ‏.‏ قَالَ وَسَأَلْتُ مُحَمَّدًا عَنْ هَذَا الْحَدِيثِ فَلَمْ يَعْرِفْهُ إِلاَّ مِنْ حَدِيثِ يَحْيَى بْنِ آدَمَ عَنْ شَرِيكٍ وَقَالَ حَدَّثَنَا غَيْرُ وَاحِدٍ عَنْ شَرِيكٍ عَنْ عَمَّارٍ عَنْ أَبِي الزُّبَيْرِ عَنْ جَابِرٍ أَنَّ النَّبِيَّ صلى الله عليه وسلم دَخَلَ مَكَّةَ وَعَلَيْهِ عِمَامَةٌ سَوْدَاءُ ‏.‏ قَالَ مُحَمَّدٌ وَالْحَدِيثُ هُوَ هَذَا ‏.‏ قَالَ أَبُو عِيسَى وَالدُّهْنُ بَطْنٌ مِنْ بَجِيلَةَ وَعَمَّارٌ الدُّهْنِيُّ هُوَ عَمَّارُ بْنُ مُعَاوِيَةَ الدُّهْنِيُّ وَيُكْنَى أَبَا مُعَاوِيَةَ وَهُوَ كُوفِيٌّ وَهُوَ ثِقَةٌ عِنْدَ أَهْلِ الْحَدِيثِ ‏.‏", "grades": "", "reference": "", "international_number": "1728", "narrator_chain": "Narrated Jabir:"}
{"hadithnumber": "1729", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا يَحْيَى بْنُ زَكَرِيَّا بْنِ أَبِي زَائِدَةَ، حَدَّثَنَا أَبُو يَعْقُوبَ الثَّقَفِيُّ، حَدَّثَنَا يُونُسُ بْنُ عُبَيْدٍ، مَوْلَى مُحَمَّدِ بْنِ الْقَاسِمِ قَالَ بَعَثَنِي مُحَمَّدُ بْنُ الْقَاسِمِ إِلَى الْبَرَاءِ بْنِ عَازِبٍ أَسْأَلُهُ عَنْ رَايَةِ، رَسُولِ اللَّهِ صلى الله عليه وسلم فَقَالَ كَانَتْ سَوْدَاءَ مُرَبَّعَةً مِنْ نَمِرَةٍ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ عَلِيٍّ وَالْحَارِثِ بْنِ حَسَّانَ وَابْنِ عَبَّاسٍ ‏.‏ قَالَ أَبُو عِيسَى وَهَذَا حَدِيثٌ حَسَنٌ غَرِيبٌ لاَ نَعْرِفُهُ إِلاَّ مِنْ حَدِيثِ ابْنِ أَبِي زَائِدَةَ ‏.‏ وَأَبُو يَعْقُوبَ الثَّقَفِيُّ اسْمُهُ إِسْحَاقُ بْنُ إِبْرَاهِيمَ وَرَوَى عَنْهُ أَيْضًا عُبَيْدُ اللَّهِ بْنُ مُوسَى ‏.‏", "grades": "", "reference": "", "international_number": "1729", "narrator_chain": "Narrated Yunus bin 'Ubaid:"}
{"hadithnumber": "1730", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ رَافِعٍ، حَدَّثَنَا يَحْيَى بْنُ إِسْحَاقَ، وَهُوَ السَّالِحَانِيُّ حَدَّثَنَا يَزِيدُ بْنُ حَيَّانَ، قَالَ سَمِعْتُ أَبَا مِجْلَزٍ، لاَحِقَ بْنَ حُمَيْدٍ يُحَدِّثُ عَنِ ابْنِ عَبَّاسٍ، قَالَ كَانَتْ رَايَةُ رَسُولِ اللَّهِ صلى الله عليه وسلم سَوْدَاءَ وَلِوَاؤُهُ أَبْيَضَ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ غَرِيبٌ مِنْ هَذَا الْوَجْهِ مِنْ حَدِيثِ ابْنِ عَبَّاسٍ ‏.‏", "grades": "", "reference": "", "international_number": "1730", "narrator_chain": "Narrated Ibn 'Abbas:"}
{"hadithnumber": "1731", "arabic": "حَدَّثَنَا مَحْمُودُ بْنُ غَيْلاَنَ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا سُفْيَانُ، عَنْ أَبِي إِسْحَاقَ، عَنِ الْمُهَلَّبِ بْنِ أَبِي صُفْرَةَ، عَمَّنْ سَمِعَ النَّبِيَّ صلى الله عليه وسلم يَقُولُ ‏ ‏ إِنْ بَيَّتَكُمُ الْعَدُوُّ فَقُولُوا‏:‏ حم لاَ يُنْصَرُونَ ‏\"\"‏ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ سَلَمَةَ بْنِ الأَكْوَعِ ‏.‏ وَهَكَذَا رَوَى بَعْضُهُمْ عَنْ أَبِي إِسْحَاقَ مِثْلَ رِوَايَةِ الثَّوْرِيِّ وَرُوِيَ عَنْهُ عَنِ الْمُهَلَّبِ بْنِ أَبِي صُفْرَةَ عَنِ النَّبِيِّ صلى الله عليه وسلم مُرْسَلاً ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Narrated Al-Muhallab bin Abi Sufrah:"}
{"hadithnumber": "1732", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ شُجَاعٍ الْبَغْدَادِيُّ، حَدَّثَنَا أَبُو عُبَيْدَةَ الْحَدَّادُ، عَنْ عُثْمَانَ بْنِ سَعْدٍ، عَنِ ابْنِ سِيرِينَ، قَالَ صَنَعْتُ سَيْفِي عَلَى سَيْفِ سَمُرَةَ بْنِ جُنْدَبٍ وَزَعَمَ سَمُرَةُ أَنَّهُ صَنَعَ سَيْفَهُ عَلَى سَيْفِ رَسُولِ اللَّهِ صلى الله عليه وسلم وَكَانَ حَنَفِيًّا ‏.‏ قَالَ أَبُو عِيسَى هَذَ حَدِيثٌ غَرِيبٌ لاَ نَعْرِفُهُ إِلاَّ مِنْ هَذَا الْوَجْهِ ‏.‏ وَقَدْ تَكَلَّمَ يَحْيَى بْنُ سَعِيدٍ الْقَطَّانُ فِي عُثْمَانَ بْنِ سَعْدٍ الْكَاتِبِ وَضَعَّفَهُ مِنْ قِبَلِ حِفْظِهِ ‏.‏", "grades": "", "reference": "", "international_number": "1732", "narrator_chain": "Narrated 'Uthman bin Sa'd:"}
{"hadithnumber": "1733", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ مُحَمَّدِ بْنِ مُوسَى، أَنْبَأَنَا عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ، أَنْبَأَنَا سَعِيدُ بْنُ عَبْدِ الْعَزِيزِ، عَنْ عَطِيَّةَ بْنِ قَيْسٍ، عَنْ قَزَعَةَ، عَنْ أَبِي سَعِيدٍ الْخُدْرِيِّ، قَالَ لَمَّا بَلَغَ النَّبِيُّ صلى الله عليه وسلم عَامَ الْفَتْحِ مَرَّ الظَّهْرَانِ فَآذَنَنَا بِلِقَاءِ الْعَدُوِّ فَأَمَرَنَا بِالْفِطْرِ فَأَفْطَرْنَا أَجْمَعُونَ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَفِي الْبَابِ عَنْ عُمَرَ ‏.‏", "grades": "", "reference": "", "international_number": "1733", "narrator_chain": "Narrated Abu Sa’id Al Khudri :"}
{"hadithnumber": "1734", "arabic": "حَدَّثَنَا مَحْمُودُ بْنُ غَيْلاَنَ، حَدَّثَنَا أَبُو دَاوُدَ الطَّيَالِسِيُّ، قَالَ أَنْبَأَنَا شُعْبَةُ، عَنْ قَتَادَةَ، حَدَّثَنَا أَنَسُ بْنُ مَالِكٍ، قَالَ رَكِبَ النَّبِيُّ صلى الله عليه وسلم فَرَسًا لأَبِي طَلْحَةَ يُقَالُ لَهُ مَنْدُوبٌ فَقَالَ ‏ ‏ مَا كَانَ مِنْ فَزَعٍ وَإِنْ وَجَدْنَاهُ لَبَحْرًا ‏\"\"‏ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنِ ابْنِ عَمْرِو بْنِ الْعَاصِ ‏.‏ وَهَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Narrated Anas bin Malik:"}
{"hadithnumber": "1735", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، وَابْنُ أَبِي عَدِيٍّ، وَأَبُو دَاوُدَ قَالُوا حَدَّثَنَا شُعْبَةُ، عَنْ قَتَادَةَ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ كَانَ فَزَعٌ بِالْمَدِينَةِ فَاسْتَعَارَ رَسُولُ اللَّهِ صلى الله عليه وسلم فَرَسًا لَنَا يُقَالُ لَهُ مَنْدُوبٌ فَقَالَ ‏ ‏ مَا رَأَيْنَا مِنْ فَزَعٍ وَإِنْ وَجَدْنَاهُ لَبَحْرًا ‏\"\"‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Narrated Anas bin Malik:"}
{"hadithnumber": "1736", "arabic": "حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ، عَنْ ثَابِتٍ، عَنْ أَنَسٍ، قَالَ كَانَ النَّبِيُّ صلى الله عليه وسلم مِنْ أَجْرَإِ النَّاسِ وَأَجْوَدِ النَّاسِ وَأَشْجَعِ النَّاسِ ‏.‏ قَالَ وَقَدْ فَزِعَ أَهْلُ الْمَدِينَةِ لَيْلَةً سَمِعُوا صَوْتًا قَالَ فَتَلَقَّاهُمُ النَّبِيُّ صلى الله عليه وسلم عَلَى فَرَسٍ لأَبِي طَلْحَةَ عُرْىٍ وَهُوَ مُتَقَلِّدٌ سَيْفَهُ فَقَالَ ‏\"‏ لَمْ تُرَاعُوا لَمْ تُرَاعُوا ‏\"‏ ‏.‏ فَقَالَ النَّبِيُّ صلى الله عليه وسلم ‏\"‏ وَجَدْتُهُ بَحْرًا ‏\"‏ ‏.‏ يَعْنِي الْفَرَسَ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ صَحِيحٌ ‏.‏", "grades": "", "reference": "", "international_number": "1736", "narrator_chain": "Narrated Anas:"}
{"hadithnumber": "1737", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، حَدَّثَنَا سُفْيَانُ الثَّوْرِيُّ، حَدَّثَنَا أَبُو إِسْحَاقَ، عَنِ الْبَرَاءِ بْنِ عَازِبٍ، قَالَ قَالَ لَنَا رَجُلٌ أَفَرَرْتُمْ عَنْ رَسُولِ اللَّهِ صلى الله عليه وسلم يَا أَبَا عُمَارَةَ قَالَ لاَ وَاللَّهِ مَا وَلَّى رَسُولُ اللَّهِ صلى الله عليه وسلم وَلَكِنْ وَلَّى سَرَعَانُ النَّاسِ تَلَقَّتْهُمْ هَوَازِنُ بِالنَّبْلِ وَرَسُولُ اللَّهِ صلى الله عليه وسلم عَلَى بَغْلَتِهِ وَأَبُو سُفْيَانَ بْنُ الْحَارِثِ بْنِ عَبْدِ الْمُطَّلِبِ آخِذٌ بِلِجَامِهَا وَرَسُولُ اللَّهِ صلى الله عليه وسلم يَقُولُ ‏ ‏ أَنَا النَّبِيُّ لاَ كَذِبْ أَنَا ابْنُ عَبْدِ الْمُطَّلِبْ ‏\"\"‏ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ عَلِيٍّ وَابْنِ عُمَرَ ‏.‏ وَهَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Narrated Abu Ishaq:"}
{"hadithnumber": "1738", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عُمَرَ بْنِ عَلِيٍّ الْمُقَدَّمِيُّ الْبَصْرِيُّ، حَدَّثَنِي أَبِي، عَنْ سُفْيَانَ بْنِ حُسَيْنٍ، عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ لَقَدْ رَأَيْتُنَا يَوْمَ حُنَيْنٍ وَإِنَّ الْفِئَتَيْنِ لَمُوَلِّيَتَيْنِ وَمَا مَعَ رَسُولِ اللَّهِ صلى الله عليه وسلم مِائَةُ رَجُلٍ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ غَرِيبٌ لاَ نَعْرِفُهُ مِنْ حَدِيثِ عُبَيْدِ اللَّهِ إِلاَّ مِنْ هَذَا الْوَجْهِ ‏.‏", "grades": "", "reference": "", "international_number": "1738", "narrator_chain": "Narrated Ibn 'Umar:"}
{"hadithnumber": "1739", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ صُدْرَانَ أَبُو جَعْفَرٍ الْبَصْرِيُّ، حَدَّثَنَا طَالِبُ بْنُ حُجَيْرٍ، عَنْ هُودِ بْنِ عَبْدِ اللَّهِ بْنِ سَعْدٍ، عَنْ جَدِّهِ، مَزِيدَةَ قَالَ دَخَلَ رَسُولُ اللَّهِ صلى الله عليه وسلم يَوْمَ الْفَتْحِ وَعَلَى سَيْفِهِ ذَهَبٌ وَفِضَّةٌ ‏.‏ قَالَ طَالِبٌ فَسَأَلْتُهُ عَنِ الْفِضَّةِ فَقَالَ كَانَتْ قَبِيعَةُ السَّيْفِ فِضَّةً ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ أَنَسٍ ‏.‏ وَهَذَا حَدِيثٌ غَرِيبٌ ‏.‏ وَجَدُّ هُودٍ اسْمُهُ مَزِيدَةُ الْعَصَرِيُّ ‏.‏", "grades": "", "reference": "", "international_number": "1739", "narrator_chain": "Narrated Talib bin Hujair:"}
{"hadithnumber": "1740", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا وَهْبُ بْنُ جَرِيرِ بْنِ حَازِمٍ، حَدَّثَنَا أَبِي، عَنْ قَتَادَةَ، عَنْ أَنَسٍ، قَالَ كَانَتْ قَبِيعَةُ سَيْفِ رَسُولِ اللَّهِ صلى الله عليه وسلم مِنْ فِضَّةٍ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ غَرِيبٌ ‏.‏ وَهَكَذَا رُوِيَ عَنْ هَمَّامٍ عَنْ قَتَادَةَ عَنْ أَنَسٍ وَقَدْ رَوَى بَعْضُهُمْ عَنْ قَتَادَةَ عَنْ سَعِيدِ بْنِ أَبِي الْحَسَنِ قَالَ كَانَتْ قَبِيعَةُ سَيْفِ رَسُولِ اللَّهِ صلى الله عليه وسلم مِنْ فِضَّةٍ ‏.‏", "grades": "", "reference": "", "international_number": "1740", "narrator_chain": "Narrated Anas:"}
{"hadithnumber": "1741", "arabic": "حَدَّثَنَا أَبُو سَعِيدٍ الأَشَجُّ، حَدَّثَنَا يُونُسُ بْنُ بُكَيْرٍ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ، عَنْ يَحْيَى بْنِ عَبَّادِ بْنِ عَبْدِ اللَّهِ بْنِ الزُّبَيْرِ، عَنْ أَبِيهِ، عَنْ جَدِّهِ عَبْدِ اللَّهِ بْنِ الزُّبَيْرِ، عَنِ الزُّبَيْرِ بْنِ الْعَوَّامِ، قَالَ كَانَ عَلَى النَّبِيِّ صلى الله عليه وسلم دِرْعَانِ يَوْمَ أُحُدٍ فَنَهَضَ إِلَى الصَّخْرَةِ فَلَمْ يَسْتَطِعْ فَأَقْعَدَ طَلْحَةَ تَحْتَهُ فَصَعِدَ النَّبِيُّ صلى الله عليه وسلم عَلَيْهِ حَتَّى اسْتَوَى عَلَى الصَّخْرَةِ فَقَالَ سَمِعْتُ النَّبِيَّ صلى الله عليه وسلم يَقُولُ ‏ ‏ أَوْجَبَ طَلْحَةُ ‏\"\"‏ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ صَفْوَانَ بْنِ أُمَيَّةَ وَالسَّائِبِ بْنِ يَزِيدَ ‏.‏ وَهَذَا حَدِيثٌ حَسَنٌ غَرِيبٌ لاَ نَعْرِفُهُ إِلاَّ مِنْ حَدِيثِ مُحَمَّدِ بْنِ إِسْحَاقَ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Narrated Az-Zubair bin Al-'Awwam:"}
{"hadithnumber": "1742", "arabic": "حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، عَنِ ابْنِ شِهَابٍ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ دَخَلَ النَّبِيُّ صلى الله عليه وسلم عَامَ الْفَتْحِ وَعَلَى رَأْسِهِ الْمِغْفَرُ فَقِيلَ لَهُ ابْنُ خَطَلٍ مُتَعَلِّقٌ بِأَسْتَارِ الْكَعْبَةِ ‏.‏ فَقَالَ ‏ ‏ اقْتُلُوهُ ‏\"\"‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ غَرِيبٌ لاَ نَعْرِفُ كَبِيرَ أَحَدٍ رَوَاهُ غَيْرَ مَالِكٍ عَنِ الزُّهْرِيِّ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Narrated Anas bin Malik:"}
{"hadithnumber": "1743", "arabic": "حَدَّثَنَا هَنَّادٌ، حَدَّثَنَا عَبْثَرُ بْنُ الْقَاسِمِ، عَنْ حُصَيْنٍ، عَنِ الشَّعْبِيِّ، عَنْ عُرْوَةَ الْبَارِقِيِّ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ الْخَيْرُ مَعْقُودٌ فِي نَوَاصِي الْخَيْلِ إِلَى يَوْمِ الْقِيَامَةِ الأَجْرُ وَالْمَغْنَمُ ‏\"\"‏ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنِ ابْنِ عُمَرَ وَأَبِي سَعِيدٍ وَجَرِيرٍ وَأَبِي هُرَيْرَةَ وَأَسْمَاءَ بِنْتِ يَزِيدَ وَالْمُغِيرَةِ بْنِ شُعْبَةَ وَجَابِرٍ ‏.‏ قَالَ أَبُو عِيسَى وَهَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَعُرْوَةُ هُوَ ابْنُ أَبِي الْجَعْدِ الْبَارِقِيُّ وَيُقَالُ هُوَ عُرْوَةُ بْنُ الْجَعْدِ ‏.‏ قَالَ أَحْمَدُ بْنُ حَنْبَلٍ وَفِقْهُ هَذَا الْحَدِيثِ أَنَّ الْجِهَادَ مَعَ كُلِّ إِمَامٍ إِلَى يَوْمِ الْقِيَامَةِ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Narrated 'Urwah Al-Bariqi:"}
{"hadithnumber": "1744", "arabic": "حَدَّثَنَا عَبْدُ اللَّهِ بْنُ الصَّبَّاحِ الْهَاشِمِيُّ الْبَصْرِيُّ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، أَخْبَرَنَا شَيْبَانُ يَعْنِي ابْنَ عَبْدِ الرَّحْمَنِ، حَدَّثَنَا عِيسَى بْنُ عَلِيِّ بْنِ عَبْدِ اللَّهِ بْنِ عَبَّاسٍ، عَنْ أَبِيهِ، عَنِ ابْنِ عَبَّاسٍ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ يُمْنُ الْخَيْلِ فِي الشُّقْرِ ‏\"\"‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ غَرِيبٌ لاَ نَعْرِفُهُ إِلاَّ مِنْ هَذَا الْوَجْهِ مِنْ حَدِيثِ شَيْبَانَ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Narrated Ibn 'Abbas:"}
{"hadithnumber": "1745", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ مُحَمَّدٍ، أَخْبَرَنَا عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ، أَخْبَرَنَا ابْنُ لَهِيعَةَ، عَنْ يَزِيدَ بْنِ أَبِي حَبِيبٍ، عَنْ عُلَىِّ بْنِ رَبَاحٍ، عَنْ أَبِي قَتَادَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ خَيْرُ الْخَيْلِ الأَدْهَمُ الأَقْرَحُ الأَرْثَمُ ثُمَّ الأَقْرَحُ الْمُحَجَّلُ طَلْقُ الْيَمِينِ فَإِنْ لَمْ يَكُنْ أَدْهَمَ فَكُمَيْتٌ عَلَى هَذِهِ الشِّيَةِ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Narrated Abu Qatadah:"}
{"hadithnumber": "1746", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا وَهْبُ بْنُ جَرِيرٍ، حَدَّثَنَا أَبِي، عَنْ يَحْيَى بْنِ أَيُّوبَ، عَنْ يَزِيدَ بْنِ أَبِي حَبِيبٍ، بِهَذَا الإِسْنَادِ نَحْوَهُ بِمَعْنَاهُ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ غَرِيبٌ صَحِيحٌ ‏.‏", "grades": "", "reference": "", "international_number": "1746", "narrator_chain": "Another chain with similar meaning.\\n\\n\\n[Abu 'Eisa said:"}
{"hadithnumber": "1747", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، حَدَّثَنَا سُفْيَانُ، قَالَ حَدَّثَنِي سَلْمُ بْنُ عَبْدِ الرَّحْمَنِ النَّخَعِيُّ، عَنْ أَبِي زُرْعَةَ بْنِ عَمْرِو بْنِ جَرِيرٍ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم أَنَّهُ كَرِهَ الشِّكَالَ مِنَ الْخَيْلِ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَقَدْ رَوَاهُ شُعْبَةُ عَنْ عَبْدِ اللَّهِ بْنِ يَزِيدَ الْخَثْعَمِيِّ عَنْ أَبِي زُرْعَةَ عَنْ أَبِي هُرَيْرَةَ عَنِ النَّبِيِّ صلى الله عليه وسلم نَحْوَهُ ‏.‏ وَأَبُو زُرْعَةَ بْنُ عَمْرِو بْنِ جَرِيرٍ اسْمُهُ هَرِمٌ ‏.‏ حَدَّثَنَا مُحَمَّدُ بْنُ حُمَيْدٍ الرَّازِيُّ حَدَّثَنَا جَرِيرٌ عَنْ عُمَارَةَ بْنِ الْقَعْقَاعِ قَالَ قَالَ لِي إِبْرَاهِيمُ النَّخَعِيُّ إِذَا حَدَّثْتَنِي فَحَدِّثْنِي عَنْ أَبِي زُرْعَةَ فَإِنَّهُ حَدَّثَنِي مَرَّةً بِحَدِيثٍ ثُمَّ سَأَلْتُهُ بَعْدَ ذَلِكَ بِسِنِينَ فَمَا أَخْرَمَ مِنْهُ حَرْفًا ‏.‏", "grades": "", "reference": "", "international_number": "1747", "narrator_chain": "Narrated Abu Hurairah:"}
{"hadithnumber": "1748", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ وَزِيرٍ الْوَاسِطِيُّ، حَدَّثَنَا إِسْحَاقُ بْنُ يُوسُفَ الأَزْرَقُ، عَنْ سُفْيَانَ، عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم أَجْرَى الْمُضَمَّرَ مِنَ الْخَيْلِ مِنَ الْحَفْيَاءِ إِلَى ثَنِيَّةِ الْوَدَاعِ وَبَيْنَهُمَا سِتَّةُ أَمْيَالٍ وَمَا لَمْ يُضَمَّرْ مِنَ الْخَيْلِ مِنْ ثَنِيَّةِ الْوَدَاعِ إِلَى مَسْجِدِ بَنِي زُرَيْقٍ وَبَيْنَهُمَا مِيلٌ وَكُنْتُ فِيمَنْ أَجْرَى فَوَثَبَ بِي فَرَسِي جِدَارًا ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ أَبِي هُرَيْرَةَ وَجَابِرٍ وَعَائِشَةَ وَأَنَسٍ ‏.‏ وَهَذَا حَدِيثٌ صَحِيحٌ حَسَنٌ غَرِيبٌ مِنْ حَدِيثِ الثَّوْرِيِّ ‏.‏", "grades": "", "reference": "", "international_number": "1748", "narrator_chain": "Narrated Ibn 'Umar:"}
{"hadithnumber": "1749", "arabic": "حَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا وَكِيعٌ، عَنِ ابْنِ أَبِي ذِئْبٍ، عَنْ نَافِعِ بْنِ أَبِي نَافِعٍ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ لاَ سَبَقَ إِلاَّ فِي نَصْلٍ أَوْ خُفٍّ أَوْ حَافِرٍ ‏\"\"‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Narrated Abu Hurairah:"}
{"hadithnumber": "1750", "arabic": "حَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ إِبْرَاهِيمَ، حَدَّثَنَا أَبُو جَهْضَمٍ، مُوسَى بْنُ سَالِمٍ عَنْ عَبْدِ اللَّهِ بْنِ عُبَيْدِ اللَّهِ بْنِ عَبَّاسٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ كَانَ رَسُولُ اللَّهِ صلى الله عليه وسلم عَبْدًا مَأْمُورًا مَا اخْتَصَّنَا دُونَ النَّاسِ بِشَيْءٍ إِلاَّ بِثَلاَثٍ أَمَرَنَا أَنْ نُسْبِغَ الْوُضُوءَ وَأَنْ لاَ نَأْكُلَ الصَّدَقَةَ وَأَنْ لاَ نُنْزِيَ حِمَارًا عَلَى فَرَسٍ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ عَلِيٍّ ‏.‏ وَهَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَرَوَى سُفْيَانُ الثَّوْرِيُّ هَذَا عَنْ أَبِي جَهْضَمٍ فَقَالَ عَنْ عُبَيْدِ اللَّهِ بْنِ عَبْدِ اللَّهِ بْنِ عَبَّاسٍ عَنِ ابْنِ عَبَّاسٍ ‏.‏ قَالَ وَسَمِعْتُ مُحَمَّدًا يَقُولُ حَدِيثُ الثَّوْرِيِّ غَيْرُ مَحْفُوظٍ وَوَهِمَ فِيهِ الثَّوْرِيُّ وَالصَّحِيحُ مَا رَوَى إِسْمَاعِيلُ ابْنُ عُلَيَّةَ وَعَبْدُ الْوَارِثِ بْنُ سَعِيدٍ عَنْ أَبِي جَهْضَمٍ عَنْ عَبْدِ اللَّهِ بْنِ عُبَيْدِ اللَّهِ بْنِ عَبَّاسٍ عَنِ ابْنِ عَبَّاسٍ ‏.‏", "grades": "", "reference": "", "international_number": "1750", "narrator_chain": "Narrated Ibn 'Abbas:"}
{"hadithnumber": "1751", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ مُحَمَّدِ بْنِ مُوسَى، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ، قَالَ أَخْبَرَنَا عَبْدُ الرَّحْمَنِ بْنُ يَزِيدَ بْنِ جَابِرٍ، حَدَّثَنَا زَيْدُ بْنُ أَرْطَاةَ، عَنْ جُبَيْرِ بْنِ نُفَيْرٍ، عَنْ أَبِي الدَّرْدَاءِ، قَالَ سَمِعْتُ النَّبِيَّ صلى الله عليه وسلم يَقُولُ ‏ ‏ ابْغُونِي ضُعَفَاءَكُمْ فَإِنَّمَا تُرْزَقُونَ وَتُنْصَرُونَ بِضُعَفَائِكُمْ ‏\"\"‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Narrated Abu Ad-Darda':"}
{"hadithnumber": "1752", "arabic": "حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ، عَنْ سُهَيْلِ بْنِ أَبِي صَالِحٍ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ لاَ تَصْحَبُ الْمَلاَئِكَةُ رُفْقَةً فِيهَا كَلْبٌ وَلاَ جَرَسٌ ‏\"\"‏ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ عُمَرَ وَعَائِشَةَ وَأُمِّ حَبِيبَةَ وَأُمِّ سَلَمَةَ ‏.‏ وَهَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Narrated Abu Hurairah:"}
{"hadithnumber": "1753", "arabic": "حَدَّثَنَا عَبْدُ اللَّهِ بْنُ أَبِي زِيَادٍ، حَدَّثَنَا الأَحْوَصُ بْنُ الْجَوَّابِ أَبُو الْجَوَّابِ، عَنْ يُونُسَ بْنِ أَبِي إِسْحَاقَ، عَنْ أَبِي إِسْحَاقَ، عَنِ الْبَرَاءِ، أَنَّ النَّبِيَّ صلى الله عليه وسلم بَعَثَ جَيْشَيْنِ وَأَمَّرَ عَلَى أَحَدِهِمَا عَلِيَّ بْنَ أَبِي طَالِبٍ وَعَلَى الآخَرِ خَالِدَ بْنَ الْوَلِيدِ وَقَالَ ‏\"‏ إِذَا كَانَ الْقِتَالُ فَعَلِيٌّ ‏\"‏ ‏.‏ قَالَ فَافْتَتَحَ عَلِيٌّ حِصْنًا فَأَخَذَ مِنْهُ جَارِيَةً فَكَتَبَ مَعِي خَالِدُ بْنُ الْوَلِيدِ إِلَى النَّبِيِّ صلى الله عليه وسلم يَشِي بِهِ فَقَدِمْتُ عَلَى النَّبِيِّ صلى الله عليه وسلم فَقَرَأَ الْكِتَابَ فَتَغَيَّرَ لَوْنُهُ ثُمَّ قَالَ ‏\"‏ مَا تَرَى فِي رَجُلٍ يُحِبُّ اللَّهَ وَرَسُولَهُ وَيُحِبُّهُ اللَّهُ وَرَسُولُهُ ‏\"‏ ‏.‏ قَالَ قُلْتُ أَعُوذُ بِاللَّهِ مِنْ غَضَبِ اللَّهِ وَغَضَبِ رَسُولِهِ وَإِنَّمَا أَنَا رَسُولٌ ‏.‏ فَسَكَتَ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنِ ابْنِ عُمَرَ ‏.‏ وَهَذَا حَدِيثٌ حَسَنٌ غَرِيبٌ لاَ نَعْرِفُهُ إِلاَّ مِنْ حَدِيثِ الأَحْوَصِ بْنِ جَوَّابٍ ‏.‏ مَعْنَى قَوْلِهِ يَشِي بِهِ يَعْنِي النَّمِيمَةَ ‏.‏", "grades": "", "reference": "", "international_number": "1753", "narrator_chain": "Narrated Al-Bara' :"}
{"hadithnumber": "1754", "arabic": "حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا اللَّيْثُ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ أَلاَ كُلُّكُمْ رَاعٍ وَكُلُّكُمْ مَسْئُولٌ عَنْ رَعِيَّتِهِ فَالأَمِيرُ الَّذِي عَلَى النَّاسِ رَاعٍ وَمَسْئُولٌ عَنْ رَعِيَّتِهِ وَالرَّجُلُ رَاعٍ عَلَى أَهْلِ بَيْتِهِ وَهُوَ مَسْئُولٌ عَنْهُمْ وَالْمَرْأَةُ رَاعِيَةٌ عَلَى بَيْتِ بَعْلِهَا وَهِيَ مَسْئُولَةٌ عَنْهُ وَالْعَبْدُ رَاعٍ عَلَى مَالِ سَيِّدِهِ وَهُوَ مَسْئُولٌ عَنْهُ أَلاَ فَكُلُّكُمْ رَاعٍ وَكُلُّكُمْ مَسْئُولٌ عَنْ رَعِيَّتِهِ ‏\"\"‏ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ أَبِي هُرَيْرَةَ وَأَنَسٍ وَأَبِي مُوسَى ‏.‏ وَحَدِيثُ أَبِي مُوسَى غَيْرُ مَحْفُوظٍ وَحَدِيثُ أَنَسٍ غَيْرُ مَحْفُوظٍ وَحَدِيثُ ابْنِ عُمَرَ حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Narrated Ibn 'Umar:"}
{"hadithnumber": "1755", "arabic": "قَالَ حَكَاهُ إِبْرَاهِيمُ بْنُ بَشَّارٍ الرَّمَادِيُّ عَنْ سُفْيَانَ بْنِ عُيَيْنَةَ، عَنْ بُرَيْدِ بْنِ عَبْدِ اللَّهِ بْنِ أَبِي بُرْدَةَ، عَنْ أَبِي بُرْدَةَ، عَنْ أَبِي مُوسَى، عَنِ النَّبِيِّ صلى الله عليه وسلم ‏.‏ أَخْبَرَنِي بِذَلِكَ، مُحَمَّدٌ عَنْ إِبْرَاهِيمَ بْنِ بَشَّارٍ، ‏.‏ قَالَ وَرَوَى غَيْرُ، وَاحِدٍ، عَنْ سُفْيَانَ، عَنْ بُرَيْدٍ، عَنْ أَبِي بُرْدَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم مُرْسَلاً وَهَذَا أَصَحُّ ‏.‏ قَالَ مُحَمَّدٌ وَرَوَى إِسْحَاقُ بْنُ إِبْرَاهِيمَ عَنْ مُعَاذِ بْنِ هِشَامٍ عَنْ أَبِيهِ عَنْ قَتَادَةَ عَنْ أَنَسٍ عَنِ النَّبِيِّ صلى الله عليه وسلم ‏ ‏ إِنَّ اللَّهَ سَائِلٌ كُلَّ رَاعٍ عَمَّا اسْتَرْعَاهُ ‏\"\"‏ ‏.‏ قَالَ سَمِعْتُ مُحَمَّدًا يَقُولُ هَذَا غَيْرُ مَحْفُوظٍ وَإِنَّمَا الصَّحِيحُ عَنْ مُعَاذِ بْنِ هِشَامٍ عَنْ أَبِيهِ عَنْ قَتَادَةَ عَنِ الْحَسَنِ عَنِ النَّبِيِّ صلى الله عليه وسلم مُرْسَلاً ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Ibrahim bin Bash-shar Ar-Ramadi reported it from Sufyan bin 'Uyainah, from Buraid bin 'Abdullah bin Abu Burdah, from Abu Burdah, from Abu Musa, from the Prophet (ﷺ).\\n\\n\\nMuhammad informed me of that, from Ibrahim bin Bash-Shar . Muhammad said:"}
{"hadithnumber": "1756", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى النَّيْسَابُورِيُّ، حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ، حَدَّثَنَا يُونُسُ بْنُ أَبِي إِسْحَاقَ، عَنِ الْعَيْزَارِ بْنِ حُرَيْثٍ، عَنْ أُمِّ الْحُصَيْنِ الأَحْمَسِيَّةِ، قَالَتْ سَمِعْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم يَخْطُبُ فِي حَجَّةِ الْوَدَاعِ وَعَلَيْهِ بُرْدٌ قَدِ الْتَفَعَ بِهِ مِنْ تَحْتِ إِبْطِهِ قَالَتْ فَأَنَا أَنْظُرُ إِلَى عَضَلَةِ عَضُدِهِ تَرْتَجُّ سَمِعْتُهُ يَقُولُ ‏ ‏ يَا أَيُّهَا النَّاسُ اتَّقُوا اللَّهَ وَإِنْ أُمِّرَ عَلَيْكُمْ عَبْدٌ حَبَشِيٌّ مُجَدَّعٌ فَاسْمَعُوا لَهُ وَأَطِيعُوا مَا أَقَامَ لَكُمْ كِتَابَ اللَّهِ ‏\"\"‏ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ أَبِي هُرَيْرَةَ وَعِرْبَاضِ بْنِ سَارِيَةَ ‏.‏ وَهَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ وَقَدْ رُوِيَ مِنْ غَيْرِ وَجْهٍ عَنْ أُمِّ حُصَيْنٍ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Narrated Umm Al-Husain Al-Ahmasiyyah:"}
{"hadithnumber": "1757", "arabic": "حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا اللَّيْثُ، عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ السَّمْعُ وَالطَّاعَةُ عَلَى الْمَرْءِ الْمُسْلِمِ فِيمَا أَحَبَّ وَكَرِهَ مَا لَمْ يُؤْمَرْ بِمَعْصِيَةٍ فَإِنْ أُمِرَ بِمَعْصِيَةٍ فَلاَ سَمْعَ عَلَيْهِ وَلاَ طَاعَةَ ‏\"\"‏ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ عَلِيٍّ وَعِمْرَانَ بْنِ حُصَيْنٍ وَالْحَكَمِ بْنِ عَمْرٍو الْغِفَارِيِّ ‏.‏ وَهَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Narrated Ibn 'Umar:"}
{"hadithnumber": "1758", "arabic": "حَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا يَحْيَى بْنُ آدَمَ، عَنْ قُطْبَةَ بْنِ عَبْدِ الْعَزِيزِ، عَنِ الأَعْمَشِ، عَنْ أَبِي يَحْيَى، عَنْ مُجَاهِدٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم عَنِ التَّحْرِيشِ بَيْنَ الْبَهَائِمِ ‏.‏", "grades": "", "reference": "", "international_number": "1758", "narrator_chain": "Narrated Abu Yahya:"}
{"hadithnumber": "1759", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، عَنْ سُفْيَانَ، عَنِ الأَعْمَشِ، عَنْ أَبِي يَحْيَى، عَنْ مُجَاهِدٍ، أَنَّ النَّبِيَّ صلى الله عليه وسلم نَهَى عَنِ التَّحْرِيشِ بَيْنَ الْبَهَائِمِ ‏.‏ وَلَمْ يَذْكُرْ فِيهِ عَنِ ابْنِ عَبَّاسٍ ‏.‏ وَيُقَالُ هَذَا أَصَحُّ مِنْ حَدِيثِ قُطْبَةَ ‏.‏", "grades": "", "reference": "", "international_number": "1759", "narrator_chain": "Abu Yahya reported from Mujahid:"}
{"hadithnumber": "1760", "arabic": "وَرَوَى شَرِيكٌ، هَذَا الْحَدِيثَ عَنِ الأَعْمَشِ، عَنْ مُجَاهِدٍ، عَنِ ابْنِ عَبَّاسٍ، عَنِ النَّبِيِّ صلى الله عليه وسلم نَحْوَهُ وَلَمْ يَذْكُرْ فِيهِ عَنْ أَبِي يَحْيَى ‏.‏ حَدَّثَنَا بِذَلِكَ أَبُو كُرَيْبٍ عَنْ يَحْيَى بْنِ آدَمَ عَنْ شَرِيكٍ ‏.‏ وَرَوَى أَبُو مُعَاوِيَةَ عَنِ الأَعْمَشِ عَنْ مُجَاهِدٍ عَنِ النَّبِيِّ صلى الله عليه وسلم نَحْوَهُ ‏.‏ وَأَبُو يَحْيَى هُوَ الْقَتَّاتُ الْكُوفِيُّ وَيُقَالُ اسْمُهُ زَاذَانُ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ طَلْحَةَ وَجَابِرٍ وَأَبِي سَعِيدٍ وَعِكْرَاشِ بْنِ ذُؤَيْبٍ ‏.‏", "grades": "", "reference": "", "international_number": "1760", "narrator_chain": "Sharik narrated this Hadith from Al-A'mash, from Mujahid, from Ibn 'Abbas, from the Prophet (ﷺ) similarly, but he did not mention \"from Abu Yahya\" in it. This was narrated to us by Abu Kuraib from Yahya bin Adam, from Sharik. Abu Mu'awiyah reported it from Al-A'mash, from Mujahid, from the Prophet (ﷺ) similarly. And Abu Yahya is Al-Qattat Al-Kufi, and it is said that his name is Zadhan.\\n\\n\\n[Abu 'Eisa said:"}
{"hadithnumber": "1761", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا رَوْحُ بْنُ عُبَادَةَ، عَنِ ابْنِ جُرَيْجٍ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، أَنَّ النَّبِيَّ صلى الله عليه وسلم نَهَى عَنِ الْوَسْمِ فِي الْوَجْهِ وَالضَّرْبِ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏", "grades": "", "reference": "", "international_number": "1761", "narrator_chain": "Narrated Jabir:"}
{"hadithnumber": "1762", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الْوَزِيرِ الْوَاسِطِيُّ، حَدَّثَنَا إِسْحَاقُ بْنُ يُوسُفَ الأَزْرَقُ، عَنْ سُفْيَانَ، عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ عُرِضْتُ عَلَى رَسُولِ اللَّهِ صلى الله عليه وسلم فِي جَيْشٍ وَأَنَا ابْنُ أَرْبَعَ عَشَرَةَ فَلَمْ يَقْبَلْنِي ثُمَّ عُرِضْتُ عَلَيْهِ مِنْ قَابِلٍ فِي جَيْشٍ وَأَنَا ابْنُ خَمْسَ عَشَرَةَ فَقَبِلَنِي ‏.‏ قَالَ نَافِعٌ فَحَدَّثْتُ بِهَذَا الْحَدِيثِ عُمَرَ بْنَ عَبْدِ الْعَزِيزِ فَقَالَ هَذَا حَدُّ مَا بَيْنَ الصَّغِيرِ وَالْكَبِيرِ ‏.‏ ثُمَّ كَتَبَ أَنْ يُفْرَضَ لِمَنْ بَلَغَ الْخَمْسَ عَشَرَةَ ‏.‏", "grades": "", "reference": "", "international_number": "1762", "narrator_chain": "Narrated Nafi:"}
{"hadithnumber": "1763", "arabic": "حَدَّثَنَا ابْنُ أَبِي عُمَرَ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عُبَيْدِ اللَّهِ، نَحْوَهُ بِمَعْنَاهُ إِلاَّ أَنَّهُ قَالَ قَالَ عُمَرُ بْنُ عَبْدِ الْعَزِيزِ هَذَا حَدُّ مَا بَيْنَ الذُّرِّيَّةِ وَالْمُقَاتِلَةِ ‏.‏ وَلَمْ يَذْكُرْ أَنَّهُ كَتَبَ أَنْ يُفْرَضَ ‏.‏ قَالَ أَبُو عِيسَى حَدِيثُ إِسْحَاقَ بْنِ يُوسُفَ حَدِيثٌ حَسَنٌ صَحِيحٌ غَرِيبٌ مِنْ حَدِيثِ سُفْيَانَ الثَّوْرِيِّ ‏.‏", "grades": "", "reference": "", "international_number": "1763", "narrator_chain": "Another chain with similar, but he (Nafi') said:"}
{"hadithnumber": "1764", "arabic": "حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا اللَّيْثُ، عَنْ سَعِيدِ بْنِ أَبِي سَعِيدٍ الْمَقْبُرِيِّ، عَنْ عَبْدِ اللَّهِ بْنِ أَبِي قَتَادَةَ، عَنْ أَبِيهِ، أَنَّهُ سَمِعَهُ يُحَدِّثُ، عَنْ رَسُولِ اللَّهِ صلى الله عليه وسلم أَنَّهُ قَامَ فِيهِمْ فَذَكَرَ لَهُمْ أَنَّ الْجِهَادَ فِي سَبِيلِ اللَّهِ وَالإِيمَانَ بِاللَّهِ أَفْضَلُ الأَعْمَالِ فَقَامَ رَجُلٌ فَقَالَ يَا رَسُولَ اللَّهِ أَرَأَيْتَ إِنْ قُتِلْتُ فِي سَبِيلِ اللَّهِ أَيُكَفِّرُ عَنِّي خَطَايَاىَ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ نَعَمْ إِنْ قُتِلْتَ فِي سَبِيلِ اللَّهِ وَأَنْتَ صَابِرٌ مُحْتَسِبٌ مُقْبِلٌ غَيْرُ مُدْبِرٍ ‏\"‏ ‏.‏ ثُمَّ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ كَيْفَ قُلْتَ ‏\"‏ ‏.‏ قُلْتُ أَرَأَيْتَ إِنْ قُتِلْتُ فِي سَبِيلِ اللَّهِ أَيُكَفِّرُ عَنِّي خَطَايَاىَ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ نَعَمْ وَأَنْتَ صَابِرٌ مُحْتَسِبٌ مُقْبِلٌ غَيْرُ مُدْبِرٍ إِلاَّ الدَّيْنَ فَإِنَّ جِبْرِيلَ قَالَ لِي ذَلِكَ ‏\"‏ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ أَنَسٍ وَمُحَمَّدِ بْنِ جَحْشٍ وَأَبِي هُرَيْرَةَ ‏.‏ وَهَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَرَوَى بَعْضُهُمْ هَذَا الْحَدِيثَ عَنْ سَعِيدٍ الْمَقْبُرِيِّ عَنْ أَبِي هُرَيْرَةَ عَنِ النَّبِيِّ صلى الله عليه وسلم نَحْوَ هَذَا وَرَوَى يَحْيَى بْنُ سَعِيدٍ الأَنْصَارِيُّ وَغَيْرُ وَاحِدٍ نَحْوَ هَذَا عَنْ سَعِيدٍ الْمَقْبُرِيِّ عَنْ عَبْدِ اللَّهِ بْنِ أَبِي قَتَادَةَ عَنْ أَبِيهِ عَنِ النَّبِيِّ صلى الله عليه وسلم ‏.‏ وَهَذَا أَصَحُّ مِنْ حَدِيثِ سَعِيدٍ الْمَقْبُرِيِّ عَنْ أَبِي هُرَيْرَةَ ‏.‏", "grades": "", "reference": "", "international_number": "1764", "narrator_chain": "Narrated 'Abdullah bin Abi Qatadah:"}
{"hadithnumber": "1765", "arabic": "حَدَّثَنَا أَزْهَرُ بْنُ مَرْوَانَ الْبَصْرِيُّ، حَدَّثَنَا عَبْدُ الْوَارِثِ بْنُ سَعِيدٍ، عَنْ أَيُّوبَ، عَنْ حُمَيْدِ بْنِ هِلاَلٍ، عَنْ أَبِي الدَّهْمَاءِ، عَنْ هِشَامِ بْنِ عَامِرٍ، قَالَ شُكِيَ إِلَى رَسُولِ اللَّهِ صلى الله عليه وسلم الْجِرَاحَاتُ يَوْمَ أُحُدٍ فَقَالَ ‏ ‏ احْفِرُوا وَأَوْسِعُوا وَأَحْسِنُوا وَادْفِنُوا الاِثْنَيْنِ وَالثَّلاَثَةَ فِي قَبْرٍ وَاحِدٍ وَقَدِّمُوا أَكْثَرَهُمْ قُرْآنًا ‏\"\"‏ ‏.‏ فَمَاتَ أَبِي فَقُدِّمَ بَيْنَ يَدَىْ رَجُلَيْنِ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ خَبَّابٍ وَجَابِرٍ وَأَنَسٍ ‏.‏ وَهَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَرَوَى سُفْيَانُ الثَّوْرِيُّ وَغَيْرُهُ هَذَا الْحَدِيثَ عَنْ أَيُّوبَ عَنْ حُمَيْدِ بْنِ هِلاَلٍ عَنْ هِشَامِ بْنِ عَامِرٍ ‏.‏ وَأَبُو الدَّهْمَاءِ اسْمُهُ قِرْفَةُ بْنُ بُهَيْسٍ أَوْ بَيْهَسٍ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Narrated Hisham bin 'Amr:"}
{"hadithnumber": "1766", "arabic": "حَدَّثَنَا هَنَّادٌ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، عَنِ الأَعْمَشِ، عَنْ عَمْرِو بْنِ مُرَّةَ، عَنْ أَبِي عُبَيْدَةَ، عَنْ عَبْدِ اللَّهِ، قَالَ لَمَّا كَانَ يَوْمُ بَدْرٍ وَجِيءَ بِالأُسَارَى قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَا تَقُولُونَ فِي هَؤُلاَءِ الأُسَارَى ‏\"\"‏ ‏.‏ فَذَكَرَ قِصَّةً فِي هَذَا الْحَدِيثِ طَوِيلَةً ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ عُمَرَ وَأَبِي أَيُّوبَ وَأَنَسٍ وَأَبِي هُرَيْرَةَ ‏.‏ وَهَذَا حَدِيثٌ حَسَنٌ وَأَبُو عُبَيْدَةَ لَمْ يَسْمَعْ مِنْ أَبِيهِ ‏.‏ وَيُرْوَى عَنْ أَبِي هُرَيْرَةَ قَالَ مَا رَأَيْتُ أَحَدًا أَكْثَرَ مَشُورَةً لأَصْحَابِهِ مِنْ رَسُولِ اللَّهِ صلى الله عليه وسلم ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Narrated Abu 'Ubaidah:"}
{"hadithnumber": "1767", "arabic": "حَدَّثَنَا مَحْمُودُ بْنُ غَيْلاَنَ، حَدَّثَنَا أَبُو أَحْمَدَ، حَدَّثَنَا سُفْيَانُ، عَنِ ابْنِ أَبِي لَيْلَى، عَنِ الْحَكَمِ، عَنْ مِقْسَمٍ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ الْمُشْرِكِينَ، أَرَادُوا أَنْ يَشْتَرُوا، جَسَدَ رَجُلٍ مِنَ الْمُشْرِكِينَ فَأَبَى النَّبِيُّ صلى الله عليه وسلم أَنْ يَبِيعَهُمْ إِيَّاهُ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ غَرِيبٌ لاَ نَعْرِفُهُ إِلاَّ مِنْ حَدِيثِ الْحَكَمِ ‏.‏ وَرَوَاهُ الْحَجَّاجُ بْنُ أَرْطَاةَ أَيْضًا عَنِ الْحَكَمِ ‏.‏ وَقَالَ أَحْمَدُ بْنُ الْحَسَنِ سَمِعْتُ أَحْمَدَ بْنَ حَنْبَلٍ يَقُولُ ابْنُ أَبِي لَيْلَى لاَ يُحْتَجُّ بِحَدِيثِهِ ‏.‏ وَقَالَ مُحَمَّدُ بْنُ إِسْمَاعِيلَ ابْنُ أَبِي لَيْلَى صَدُوقٌ وَلَكِنْ لاَ يُعْرَفُ صَحِيحُ حَدِيثِهِ مِنْ سَقِيمِهِ وَلاَ أَرْوِي عَنْهُ شَيْئًا ‏.‏ وَابْنُ أَبِي لَيْلَى صَدُوقٌ فَقِيهٌ وَإِنَّمَا يَهِمُ فِي الإِسْنَادِ ‏.‏ حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ قَالَ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ دَاوُدَ عَنْ سُفْيَانَ الثَّوْرِيِّ قَالَ فُقَهَاؤُنَا ابْنُ أَبِي لَيْلَى وَعَبْدُ اللَّهِ بْنُ شُبْرُمَةَ ‏.‏", "grades": "", "reference": "", "international_number": "1767", "narrator_chain": "Narrated Ibn 'Abbas:"}
{"hadithnumber": "1768", "arabic": "حَدَّثَنَا ابْنُ أَبِي عُمَرَ، حَدَّثَنَا سُفْيَانُ، عَنْ يَزِيدَ بْنِ أَبِي زِيَادٍ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِي لَيْلَى، عَنِ ابْنِ عُمَرَ، قَالَ بَعَثَنَا رَسُولُ اللَّهِ صلى الله عليه وسلم فِي سَرِيَّةٍ فَحَاصَ النَّاسُ حَيْصَةً فَقَدِمْنَا الْمَدِينَةَ فَاخْتَبَيْنَا بِهَا وَقُلْنَا هَلَكْنَا ثُمَّ أَتَيْنَا رَسُولَ اللَّهِ صلى الله عليه وسلم فَقُلْنَا يَا رَسُولَ اللَّهِ نَحْنُ الْفَرَّارُونَ ‏.‏ قَالَ ‏\"‏ بَلْ أَنْتُمُ الْعَكَّارُونَ وَأَنَا فِئَتُكُمْ ‏\"‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ لاَ نَعْرِفُهُ إِلاَّ مِنْ حَدِيثِ يَزِيدَ بْنِ أَبِي زِيَادٍ ‏.‏ وَمَعْنَى قَوْلِهِ فَحَاصَ النَّاسُ حَيْصَةً يَعْنِي أَنَّهُمْ فَرُّوا مِنَ الْقِتَالِ ‏.‏ وَمَعْنَى قَوْلِهِ ‏\"‏ بَلْ أَنْتُمُ الْعَكَّارُونَ ‏\"‏ ‏.‏ وَالْعَكَّارُ الَّذِي يَفِرُّ إِلَى إِمَامِهِ لِيَنْصُرَهُ لَيْسَ يُرِيدُ الْفِرَارَ مِنَ الزَّحْفِ ‏.‏", "grades": "", "reference": "", "international_number": "1768", "narrator_chain": "Narrated Ibn 'Umar:"}
{"hadithnumber": "1769", "arabic": "حَدَّثَنَا مَحْمُودُ بْنُ غَيْلاَنَ، حَدَّثَنَا أَبُو دَاوُدَ، أَخْبَرَنَا شُعْبَةُ، عَنِ الأَسْوَدِ بْنِ قَيْسٍ، قَالَ سَمِعْتُ نُبَيْحًا الْعَنَزِيَّ، يُحَدِّثُ عَنْ جَابِرٍ، قَالَ لَمَّا كَانَ يَوْمُ أُحُدٍ جَاءَتْ عَمَّتِي بِأَبِي لِتَدْفِنَهُ فِي مَقَابِرِنَا فَنَادَى مُنَادِي رَسُولِ اللَّهِ صلى الله عليه وسلم رُدُّوا الْقَتْلَى إِلَى مَضَاجِعِهِمْ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ قَالَ أَبُو عِيسَى وَنُبَيْحٌ ثِقَةٌ ‏.‏", "grades": "", "reference": "", "international_number": "1769", "narrator_chain": "Narrated Jabir bin ‘Abdullah :"}
{"hadithnumber": "1770", "arabic": "حَدَّثَنَا ابْنُ أَبِي عُمَرَ، وَسَعِيدُ بْنُ عَبْدِ الرَّحْمَنِ الْمَخْزُومِيُّ، قَالاَ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ الزُّهْرِيِّ، عَنِ السَّائِبِ بْنِ يَزِيدَ، قَالَ لَمَّا قَدِمَ رَسُولُ اللَّهِ صلى الله عليه وسلم مِنْ تَبُوكَ خَرَجَ النَّاسُ يَتَلَقَّوْنَهُ إِلَى ثَنِيَّةِ الْوَدَاعِ ‏.‏ قَالَ السَّائِبُ فَخَرَجْتُ مَعَ النَّاسِ وَأَنَا غُلاَمٌ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏", "grades": "", "reference": "", "international_number": "1770", "narrator_chain": "Narrated As-Sa'ib bin Yazid:"}
{"hadithnumber": "1771", "arabic": "حَدَّثَنَا ابْنُ أَبِي عُمَرَ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عَمْرِو بْنِ دِينَارٍ، عَنِ ابْنِ شِهَابٍ، عَنْ مَالِكِ بْنِ أَوْسِ بْنِ الْحَدَثَانِ، قَالَ سَمِعْتُ عُمَرَ بْنَ الْخَطَّابِ، يَقُولُ كَانَتْ أَمْوَالُ بَنِي النَّضِيرِ مِمَّا أَفَاءَ اللَّهُ عَلَى رَسُولِهِ مِمَّا لَمْ يُوجِفِ الْمُسْلِمُونَ عَلَيْهِ بِخَيْلٍ وَلاَ رِكَابٍ وَكَانَتْ لِرَسُولِ اللَّهِ صلى الله عليه وسلم خَالِصًا وَكَانَ رَسُولُ اللَّهِ صلى الله عليه وسلم يَعْزِلُ نَفَقَةَ أَهْلِهِ سَنَةً ثُمَّ يَجْعَلُ مَا بَقِيَ فِي الْكُرَاعِ وَالسِّلاَحِ عُدَّةً فِي سَبِيلِ اللَّهِ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَرَوَى سُفْيَانُ بْنُ عُيَيْنَةَ هَذَا الْحَدِيثَ عَنْ مَعْمَرٍ عَنِ ابْنِ شِهَابٍ ‏.‏", "grades": "", "reference": "", "international_number": "1771", "narrator_chain": "Narrated 'Umar bin Al-Khattab:"}
