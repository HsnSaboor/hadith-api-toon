{"hadithnumber": "2788", "text": "مخنف بن سلیم رضی اللہ عنہ کہتے ہیں کہ  ہم  ( حجۃ الوداع کے موقع پر )  رسول اللہ صلی اللہ علیہ وسلم ک"}
{"hadithnumber": "2789", "text": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  اضحی کے"}
{"hadithnumber": "2790", "text": "حنش کہتے ہیں کہ  میں نے علی رضی اللہ عنہ کو دو دنبے قربانی کرتے دیکھا تو میں نے ان سے پوچھا: یہ کیا"}
{"hadithnumber": "2791", "text": "ام المؤمنین ام سلمہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس کے پاس قر"}
{"hadithnumber": "2792", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے سینگ دار مینڈھا لانے کا"}
{"hadithnumber": "2793", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے اپنے ہاتھ سے سات اونٹ کھڑے کر کے نحر کئ"}
{"hadithnumber": "2794", "text": "انس رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے سینگ دار ابلق دنبوں کی قربانی کی، اپ"}
{"hadithnumber": "2795", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے قربانی کے دن سینگ دار ابل"}
{"hadithnumber": "2796", "text": "ابوسعید رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم سینگ دار فربہ دنبہ کی قربانی کرتے تھے"}
{"hadithnumber": "2797", "text": "جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  صرف مسنہ ۱؎ ہی ذبح کرو، مسنہ"}
{"hadithnumber": "2798", "text": "زید بن خالد جہنی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے صحابہ کرام میں قربانی کے"}
{"hadithnumber": "2799", "text": "کلیب کہتے ہیں کہ  ہم مجاشع نامی بنی سلیم کے ایک صحابی رسول کے ساتھ تھے اس وقت بکریاں مہنگی ہو گئیں ت"}
{"hadithnumber": "2800", "text": "براء بن عازب رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے دسویں ذی الحجہ کو نماز عید"}
{"hadithnumber": "2801", "text": "براء بن عازب رضی اللہ عنہما کہتے ہیں کہ  میرے ابوبردہ نامی ایک ماموں نے نماز سے پہلے قربانی کر لی تو"}
{"hadithnumber": "2802", "text": "عبید بن فیروز کہتے ہیں کہ  میں نے براء بن عازب رضی اللہ عنہما سے پوچھا کہ: کون سا جانور قربانی میں د"}
{"hadithnumber": "2803", "text": "یزید ذومصر کہتے ہیں کہ  میں عتبہ بن عبد سلمی کے پاس آیا اور ان سے کہا: ابوالولید! میں قربانی کے لیے"}
{"hadithnumber": "2804", "text": "علی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ہم کو حکم دیا کہ قربانی کے جانور کی آن"}
{"hadithnumber": "2805", "text": "علی رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے «عضباء»  ( یعنی سینگ ٹوٹے کان کٹے جانور"}
{"hadithnumber": "2806", "text": "قتادہ کہتے ہیں  میں نے سعید بن مسیب سے پوچھا: «اعضب»  ( یا «عضباء» )  کیا ہے؟ انہوں نے کہا:  ( جس کی"}
{"hadithnumber": "2807", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  ہم رسول اللہ صلی اللہ علیہ وسلم کے زمانہ میں حج تمتع کرت"}
{"hadithnumber": "2808", "text": "جابر بن عبداللہ رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  گائے سات کی ط"}
{"hadithnumber": "2809", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  ہم نے حدیبیہ میں رسول اللہ صلی اللہ علیہ وسلم کے ساتھ سا"}
{"hadithnumber": "2810", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  میں عید الاضحی میں رسول اللہ صلی اللہ علیہ وسلم کے ساتھ"}
{"hadithnumber": "2811", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم اپنی قربانی عید گاہ میں ذب"}
{"hadithnumber": "2812", "text": "عمرہ بنت عبدالرحمٰن کہتی ہیں کہ  میں نے ام المؤمنین عائشہ رضی اللہ عنہا کو کہتے ہوئے سنا کہ رسول الل"}
{"hadithnumber": "2813", "text": "نبیشہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ہم نے تم لوگوں کو تین دن کے"}
{"hadithnumber": "2814", "text": "ثوبان رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے  ( سفر میں )  قربانی کی اور کہا:  ثو"}
{"hadithnumber": "2815", "text": "شداد بن اوس رضی اللہ عنہ کہتے ہیں کہ  دو خصلتیں ایسی ہیں جنہیں میں نے رسول اللہ صلی اللہ علیہ وسلم س"}
{"hadithnumber": "2816", "text": "ہشام بن زید کہتے ہیں کہ  میں انس رضی اللہ عنہ کے ساتھ حکم بن ایوب کے پاس گیا، تو وہاں چند نوجوانوں ی"}
{"hadithnumber": "2817", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  اللہ تعالیٰ نے جو یہ فرمایا ہے کہ «فكلوا مما ذكر اسم الل"}
{"hadithnumber": "2818", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  اللہ عزوجل نے جو یہ فرمایا ہے: «وإن الشياطين ليوحون إلى"}
{"hadithnumber": "2819", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  یہود نبی اکرم صلی اللہ علیہ وسلم کے پاس آئے اور کہنے لگے"}
{"hadithnumber": "2820", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ان جانوروں کے کھانے سے م"}
{"hadithnumber": "2821", "text": "رافع بن خدیج رضی اللہ عنہ کہتے ہیں کہ  میں رسول اللہ صلی اللہ علیہ وسلم کے پاس آیا اور عرض کیا: اللہ"}
{"hadithnumber": "2822", "text": "محمد بن صفوان یا صفوان بن محمد کہتے ہیں  میں نے دو خرگوش شکار کئے اور انہیں ایک سفید  ( دھار دار )"}
{"hadithnumber": "2823", "text": "بنو حارثہ کے ایک شخص سے روایت ہے کہ  وہ احد پہاڑ کے دروں میں سے ایک درے پر اونٹنی چرا رہا تھا، تو وہ"}
{"hadithnumber": "2824", "text": "عدی بن حاتم رضی اللہ عنہ کہتے ہیں  میں نے پوچھا: اللہ کے رسول! اگر ہم میں سے کسی کو کوئی شکار مل جائ"}
{"hadithnumber": "2825", "text": "ابوالعشراء اسامہ کے والد مالک بن قہطم رضی اللہ عنہ سے روایت ہے کہ  انہوں نے عرض کیا: اللہ کے رسول! ک"}
{"hadithnumber": "2826", "text": "عبداللہ بن عباس اور ابوہریرہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے «شريطة الشي"}
{"hadithnumber": "2827", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم سے اس بچے کے بارے میں پو"}
{"hadithnumber": "2828", "text": "جابر بن عبداللہ رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  پیٹ کے بچے ک"}
{"hadithnumber": "2829", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  لوگوں نے عرض کیا: اللہ کے رسول! کچھ لوگ ہیں جو جاہلیت س"}
{"hadithnumber": "2830", "text": "نبیشہ رضی اللہ عنہ کہتے ہیں کہ  ایک شخص نے رسول اللہ صلی اللہ علیہ وسلم کو پکار کر کہا: ہم جاہلیت می"}
{"hadithnumber": "2831", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:   ( اسلام میں )  نہ «فرع»"}
{"hadithnumber": "2832", "text": "سعید بن مسیب کہتے ہیں  «فرع» پہلوٹے بچے کو کہتے ہیں جس کی پیدائش پر اسے ذبح کر دیا کرتے تھے۔"}
{"hadithnumber": "2833", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں  رسول اللہ صلی اللہ علیہ وسلم نے ہمیں ہر پچاس بکری میں سے ا"}
{"hadithnumber": "2834", "text": "ام کرز کعبیہ رضی اللہ عنہا کہتی ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم سے سنا آپ فرماتے تھے:"}
{"hadithnumber": "2835", "text": "ام کرز رضی اللہ عنہا کہتی ہیں  میں نے نبی اکرم صلی اللہ علیہ وسلم کو فرماتے سنا:  پرندوں کو ان کے گھ"}
{"hadithnumber": "2836", "text": "ام کرز رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:   ( عقیقے میں )  لڑکے کی ط"}
{"hadithnumber": "2837", "text": "سمرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ہر لڑکا اپنے عقیقہ کے بدلے م"}
{"hadithnumber": "2838", "text": "سمرہ بن جندب رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ہر لڑکا اپنے عقیقہ ک"}
{"hadithnumber": "2839", "text": "سلمان بن عامر ضبی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  لڑکے کی پیدائش"}
{"hadithnumber": "2840", "text": "حسن سے روایت ہے، وہ کہتے تھے  تکلیف اور نجاست دور کرنے سے مراد سر مونڈنا ہے۔"}
{"hadithnumber": "2841", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے حسن اور حسین کی طرف سے ا"}
{"hadithnumber": "2842", "text": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم سے عقیقہ کے متعلق پوچھا گیا"}
{"hadithnumber": "2843", "text": "بریدہ رضی اللہ عنہ کہتے ہیں  زمانہ جاہلیت میں جب ہم میں سے کسی کے ہاں لڑکا پیدا ہوتا تو وہ ایک بکری"}
