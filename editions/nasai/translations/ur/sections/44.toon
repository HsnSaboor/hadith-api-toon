{"hadithnumber": "4677", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے پچھنا لگانے کی کمائی سے، کتے کی ق"}
{"hadithnumber": "4678", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے نر کو مادہ پر چھوڑنے کی اجرت"}
{"hadithnumber": "4679", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے کتے کی قیمت سے اور نر کو مادہ پر"}
{"hadithnumber": "4680", "text": "ابوہریرہ رضی اللہ عنہ روایت کرتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جو شخص  ( سامان خر"}
{"hadithnumber": "4681", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے ایسے شخص کے بارے میں جو مفلس ہو"}
{"hadithnumber": "4682", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے زمانے میں ایک شخص کے پھلوں پ"}
{"hadithnumber": "4683", "text": "اسید بن حضیر بن سماک رضی اللہ عنہ بیان کرتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فیصلہ کیا کہ اگر"}
{"hadithnumber": "4684", "text": "بنی حارثہ کے ایک فرد اسید بن حضیر انصاری رضی اللہ عنہ کہتے ہیں کہ  وہ یمامہ کے گورنر تھے، مروان نے ا"}
{"hadithnumber": "4685", "text": "سمرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”آدمی اپنے سامان کا زیادہ"}
{"hadithnumber": "4686", "text": "سمرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”کسی عورت کی شادی دو ولیوں"}
{"hadithnumber": "4687", "text": "عبداللہ بن ابی ربیعہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے مجھ سے چالیس ہزار قرض"}
{"hadithnumber": "4688", "text": "محمد بن جحش رضی اللہ عنہ کہتے ہیں کہ  ہم رسول اللہ صلی اللہ علیہ وسلم کے پاس بیٹھے ہوئے تھے، آپ نے ا"}
{"hadithnumber": "4689", "text": "سمرہ رضی اللہ عنہ کہتے ہیں کہ  ہم لوگ ایک جنازے میں نبی اکرم صلی اللہ علیہ وسلم کے ساتھ تھے، آپ نے ت"}
{"hadithnumber": "4690", "text": "عمران بن حذیفہ کہتے ہیں کہ  ام المؤمنین میمونہ رضی اللہ عنہا قرض لیا کرتی تھیں اور کثرت سے لیا کرتی"}
{"hadithnumber": "4691", "text": "عبیداللہ بن عبداللہ بن عتبہ سے روایت ہے کہ  ام المؤمنین میمونہ رضی اللہ عنہا نے قرض لیا، ان سے کہا گ"}
