hadiths[34]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
3893,"انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  نیک آدمی کا اچھا خوا",,,,,3893
3894,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  مومن کا خواب نبوت کا چھیا",,,,,3894
3895,"ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  نیک مسلمان کا خواب ن",,,,,3895
3896,"ام کرز کعبیہ رضی اللہ عنہا کہتی ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  نبوت ختم",,,,,3896
3897,"عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اچھا خواب نبوت ک",,,,,3897
3898,"عبادہ بن صامت رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم سے اللہ تعالیٰ کے فرمان:",,,,,3898
3899,عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے اپنے مرض الموت میں  ( حج,,,,,3899
3900,"عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جس نے مجھے خواب م",,,,,3900
3901,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے مجھے خواب میں دیکھ",,,,,3901
3902,"جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے مجھے خواب میں دیکھا یق",,,,,3902
3903,"ابوسعید خدری رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جس نے مجھے خواب میں د",,,,,3903
3904,"ابوحجیفہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے مجھے خواب میں دیکھ",,,,,3904
3905,"عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے مجھے خواب",,,,,3905
3906,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  خواب تین طرح کا ہوتا ہے: ",,,,,3906
3907,"عوف بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  خواب تین طرح کے ہوتے ",,,,,3907
3908,"جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں سے کو",,,,,3908
3909,"ابوقتادہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  سچا خواب اللہ کی طرف سے ",,,,,3909
3910,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں سے کوئی ناپسند",,,,,3910
3911,ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کی خدمت میں ایک شخص حاضر ہوا، اور عرض,,,,,3911
3912,جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم خطبہ دے رہے تھے کہ ایک شخص آپ کی خدمت می,,,,,3912
3913,"جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں سے کوئی شخص شیطانی",,,,,3913
3914,"ابورزین رضی اللہ عنہ کہتے ہیں کہ  انہوں نے نبی اکرم صلی اللہ علیہ وسلم کو فرماتے سنا:  خواب کی جب تک",,,,,3914
3915,"انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم خواب کی تعبیر اس ک",,,,,3915
3916,"عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص جھوٹا خو",,,,,3916
3917,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب قیامت قریب آ جائے گی",,,,,3917
3918,عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کی خدمت میں ایک شخص آیا، اس,,,,,3918
3919,عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  میں رسول اللہ صلی اللہ علیہ وسلم کے زمانہ میں ایک نوجوان ,,,,,3919
3920,خرشہ بن حرر رضی اللہ عنہ کہتے ہیں کہ  جب میں مدینہ آیا تو مسجد نبوی میں چند بوڑھوں کے پاس آ کر بیٹ,,,,,3920
3921,"ابوموسیٰ اشعری رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  میں نے خواب میں دیک",,,,,3921
3922,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  میں نے خواب میں سونے کے ",,,,,3922
3923,"قابوس کہتے ہیں کہ  ام الفضل رضی اللہ عنہا نے عرض کیا: اللہ کے رسول! میں نے خواب میں دیکھا ہے کہ آپ ک",,,,,3923
3924,عبداللہ بن عمر رضی اللہ عنہما نبی اکرم صلی اللہ علیہ وسلم کے خواب کے متعلق روایت کرتے ہیں کہ  آپ نے ,,,,,3924
3925,طلحہ بن عبیداللہ رضی اللہ عنہ سے روایت ہے کہ  دور دراز کے دو شخص رسول اللہ صلی اللہ علیہ وسلم کی خدم,,,,,3925
3926,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  میں خواب میں گلے میں زنج",,,,,3926
