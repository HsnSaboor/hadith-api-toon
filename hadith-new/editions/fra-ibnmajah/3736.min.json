{"metadata":{"name":"Sunan Ibn Majah","section":{"33":"Etiquette"},"section_detail":{"33":{"hadithnumber_first":3657,"hadithnumber_last":3826,"arabicnumber_first":3657,"arabicnumber_last":3826}}},"hadiths":[{"hadithnumber":3736,"arabicnumber":3736,"text":"Rapporté par Jabir : Le Messager d’Allah (ﷺ) a dit : \"Appelez-vous par mon nom mais ne vous donnez pas ma Kunya","grades":[{"name":"Al-Albani","grade":"Sahih"},{"name":"Muhammad Fouad Abd al-Baqi","grade":"Sahih"},{"name":"Shuaib Al Arnaut","grade":"Sahih"},{"name":"Zubair Ali Zai","grade":"Sahih"}],"reference":{"book":33,"hadith":80}}]}