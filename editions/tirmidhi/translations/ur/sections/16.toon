{"hadithnumber": "1399", "text": "سراقہ بن مالک بن جعشم رضی الله عنہ کہتے ہیں کہ  میں رسول اللہ صلی اللہ علیہ وسلم کے پاس آیا،  ( تو"}
{"hadithnumber": "1400", "text": "عمر بن خطاب رضی الله عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا: ”باپ سے بیٹ"}
{"hadithnumber": "1401", "text": "عبداللہ بن عباس رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”مسجدوں میں حد"}
{"hadithnumber": "1402", "text": "عبداللہ بن مسعود رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”کسی مسلمان شخص ک"}
{"hadithnumber": "1403", "text": "ابوہریرہ رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”خبردار! جس نے کسی ایسے"}
{"hadithnumber": "1404", "text": "عبداللہ بن عباس رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے قبیلہ عامر کے دو آدمی"}
{"hadithnumber": "1405", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  جب اللہ نے اپنے رسول کے لیے مکہ کو فتح کر دیا تو آپ صلی اللہ علیہ"}
{"hadithnumber": "1406", "text": "ابوشریح کعبی رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”مکہ کو اللہ نے حر"}
{"hadithnumber": "1407", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے زمانے میں ایک آدمی قتل کر دیا گی"}
{"hadithnumber": "1408", "text": "بریدہ رضی الله عنہ کہتے ہیں کہ  جب رسول اللہ صلی اللہ علیہ وسلم کسی لشکر پر امیر مقرر کر کے بھیجتے ت"}
{"hadithnumber": "1409", "text": "شداد بن اوس رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”بیشک اللہ نے ہر کام"}
{"hadithnumber": "1410", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے «جنين»  ( حمل )  کی دیت میں «غرة»"}
{"hadithnumber": "1411", "text": "مغیرہ بن شعبہ رضی الله عنہ کہتے ہیں کہ  دو عورتیں سوکن تھیں، ان میں سے ایک نے دوسری کو پتھر یا خیمے"}
{"hadithnumber": "1412", "text": "ابوجحیفہ کہتے ہیں کہ  میں نے علی رضی الله عنہ سے پوچھا کیا ۱؎: امیر المؤمنین! کیا آپ کے پاس کاغذ میں"}
{"hadithnumber": "1413", "text": "عبداللہ بن عمرو رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”مسلمان کافر کے"}
{"hadithnumber": "1414", "text": "سمرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جو اپنے غلام کو قتل کرے گا ہ"}
{"hadithnumber": "1415", "text": "سعید بن مسیب سے روایت ہے کہ  عمر رضی الله عنہ کہتے تھے: دیت کی ادائیگی عاقلہ ۱؎ پر ہے، اور بیوی اپنے"}
{"hadithnumber": "1416", "text": "عمران بن حصین رضی الله عنہ کہتے ہیں کہ  ایک آدمی نے ایک آدمی کا ہاتھ کاٹ کھایا، اس نے اپنا ہاتھ کھ"}
{"hadithnumber": "1417", "text": "معاویہ بن حیدہ قشیری رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے ایک آدمی کو تہمت ۱؎ ک"}
{"hadithnumber": "1418", "text": "سعید بن زید رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جو اپنے مال کی حفاظ"}
{"hadithnumber": "1419", "text": "عبداللہ بن عمرو رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جو اپنے مال ک"}
{"hadithnumber": "1420", "text": "عبداللہ بن عمرو رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس آدمی کا مال"}
{"hadithnumber": "1421", "text": "سعید بن زید رضی الله عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا: ”جو اپ"}
{"hadithnumber": "1422", "text": "سہل بن ابو حثمہ اور رافع بن خدیج رضی الله عنہما کہتے ہیں کہ  عبداللہ بن سہل بن زید اور محیصہ بن مسعو"}
