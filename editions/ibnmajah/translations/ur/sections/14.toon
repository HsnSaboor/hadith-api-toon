{"hadithnumber": "2375", "text": "نعمان بن بشیر رضی اللہ عنہما کہتے ہیں کہ  ان کے والد انہیں لے کر نبی اکرم صلی اللہ علیہ وسلم کی خدمت"}
{"hadithnumber": "2376", "text": "نعمان بن بشیر رضی اللہ عنہما کہتے ہیں کہ  ان کے والد نے ان کو ایک غلام دیا، اور نبی اکرم صلی اللہ عل"}
{"hadithnumber": "2377", "text": "عبداللہ بن عباس اور عبداللہ بن عمر رضی اللہ عنہم کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:"}
{"hadithnumber": "2378", "text": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ہبہ کر"}
{"hadithnumber": "2379", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  عمریٰ کوئی چیز نہیں ہے،"}
{"hadithnumber": "2380", "text": "جابر رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  جس نے کسی کو بطور"}
{"hadithnumber": "2381", "text": "زید بن ثابت رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے عمریٰ وارث کو دلا دیا۔"}
{"hadithnumber": "2382", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  رقبیٰ کوئی چیز ن"}
{"hadithnumber": "2383", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  عمریٰ اس شخص کا"}
{"hadithnumber": "2384", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اس شخص کی مثال جو ہبہ کر"}
{"hadithnumber": "2385", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ہبہ کر کے واپس"}
{"hadithnumber": "2386", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  ہبہ کر کے اسے واپ"}
{"hadithnumber": "2387", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ہبہ کرنے والا اپنی ہبہ ک"}
{"hadithnumber": "2388", "text": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے اپنے ایک خطبہ م"}
{"hadithnumber": "2389", "text": "کعب بن مالک رضی اللہ عنہ کی اہلیہ خیرۃ رضی اللہ عنہا کہتی ہیں کہ  وہ رسول اللہ صلی اللہ علیہ وسلم کی"}
