{"hadithnumber": "5691", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں  جسے بھلا معلوم ہو کہ وہ اللہ اور اس کے رسول کی حرام کی ہوئی"}
{"hadithnumber": "5692", "text": "عبدالرحمٰن کہتے ہیں کہ  ایک شخص نے ابن عباس رضی اللہ عنہما سے کہا: میں اہل خراسان میں سے ایک فرد ہوں"}
{"hadithnumber": "5693", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  گدر  ( ادھ کچی )  کھجور کی نبیذ اگرچہ وہ خالص ہو پھر بھی"}
{"hadithnumber": "5694", "text": "ابوجمرہ کہتے ہیں کہ  میں ابن عباس رضی اللہ عنہما اور عربی سے ناواقف لوگوں کے درمیان ترجمہ کر رہا تھا"}
{"hadithnumber": "5695", "text": "ابوجمرہ نصر بیان کرتے ہیں کہ  میں نے ابن عباس رضی اللہ عنہما سے کہا: میری دادی میرے لیے ایک گھڑے میں"}
{"hadithnumber": "5696", "text": "قیس بن وہبان کہتے ہیں کہ  میں نے ابن عباس رضی اللہ عنہما سے سوال کیا: میرے پاس ایک گھڑا ہے، میں اس م"}
{"hadithnumber": "5697", "text": "عبدالملک بن نافع کہتے ہیں کہ  ابن عمر رضی اللہ عنہما نے کہا: میں نے ایک شخص کو دیکھا، وہ رسول اللہ ص"}
{"hadithnumber": "5698", "text": "اس سند سے بھی  ابن عمر رضی اللہ عنہما نبی اکرم صلی اللہ علیہ وسلم سے اسی طرح روایت کرتے ہیں۔ ابوعبدا"}
{"hadithnumber": "5699", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  ایک شخص نے ان سے مشروبات کے بارے میں پوچھا تو انہوں نے"}
{"hadithnumber": "5700", "text": "زید بن جبیر کہتے ہیں کہ  میں نے ابن عمر رضی اللہ عنہما سے مشروبات کے بارے میں پوچھا تو انہوں نے کہا:"}
{"hadithnumber": "5701", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  نشہ لانے والی چیز خواہ کم ہو  ( جو نشہ نہ لائے )  یا زیاد"}
{"hadithnumber": "5702", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  ہر نشہ لانے والی چیز حرام ہے اور ہر نشہ لانے والی چیز خمر"}
{"hadithnumber": "5703", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اللہ تعالیٰ نے ش"}
{"hadithnumber": "5704", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”ہر نشہ لانے والی"}
{"hadithnumber": "5705", "text": "رقیہ بنت عمرو بن سعید کہتی ہیں کہ  میں ابن عمر رضی اللہ عنہما کی پرورش میں تھی، ان کے لیے کشمش بھگوئ"}
{"hadithnumber": "5706", "text": "ابومسعود رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کعبے کے پاس پیاسے ہو گئے، تو آپ نے پا"}
{"hadithnumber": "5707", "text": "خالد بن حسین کہتے ہیں کہ  میں نے ابوہریرہ رضی اللہ عنہ کو کہتے ہوئے سنا: مجھے معلوم ہوا کہ رسول اللہ"}
{"hadithnumber": "5708", "text": "ابورافع سے روایت ہے کہ  عمر بن خطاب رضی اللہ عنہ نے کہا: جب تمہیں نبیذ میں تیزی آ جانے کا اندیشہ ہو،"}
{"hadithnumber": "5709", "text": "سعید بن مسیب کہتے ہیں کہ  ثقیف کے لوگوں نے عمر رضی اللہ عنہ کے پاس ایک مشروب رکھا، انہوں نے منگایا ا"}
{"hadithnumber": "5710", "text": "عتبہ بن فرقد کہتے ہیں کہ  نبیذ جسے عمر بن خطاب رضی اللہ عنہ پیا کرتے تھے، وہ سرکہ ہوتا تھا ۱؎۔ اس کی"}
{"hadithnumber": "5711", "text": "سائب بن یزید سے روایت ہے کہ  عمر بن خطاب رضی اللہ عنہ ان کی طرف نکلے اور بولے: مجھے فلاں سے کسی شراب"}
{"hadithnumber": "5712", "text": "جابر رضی اللہ عنہ سے روایت ہے کہ  جیشان کا ایک شخص  ( جیشان یمن کا ایک قبیلہ ہے )  آیا اور رسول اللہ"}
{"hadithnumber": "5713", "text": "نعمان بن بشیر رضی اللہ عنہما کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا: ”ح"}
{"hadithnumber": "5714", "text": "ابوالحوراء سعدی کہتے ہیں کہ  میں نے حسن بن علی رضی اللہ عنہما سے کہا کہ آپ کو رسول اللہ صلی اللہ علی"}
{"hadithnumber": "5715", "text": "طاؤس سے روایت ہے کہ  وہ ناپسند کرتے تھے کہ انگور کسی ایسے کے ہاتھ بیچا جائے جو اس کی نبیذ بناتا ہو"}
{"hadithnumber": "5716", "text": "مصعب بن سعد رضی اللہ عنہ کہتے ہیں کہ  سعد کے انگور کے باغ تھے اور ان میں بہت انگور ہوتے تھے۔ اس  ( ب"}
{"hadithnumber": "5717", "text": "ابن سیرین کہتے ہیں کہ  رس اس کے ہاتھ بیچو جو اس کا طلاء بنائے اور شراب نہ بنائے۔"}
{"hadithnumber": "5718", "text": "سوید بن غفلہ کہتے ہیں کہ  عمر بن خطاب رضی اللہ عنہ نے اپنے کسی عامل  ( گورنر )  کو لکھا: مسلمانوں کو"}
{"hadithnumber": "5719", "text": "عامر بن عبداللہ کہتے ہیں کہ  میں نے ابوموسیٰ اشعری کے نام عمر بن خطاب رضی اللہ عنہ کا خط پڑھا: امابع"}
{"hadithnumber": "5720", "text": "عبداللہ بن یزید خطمی کہتے ہیں کہ  عمر بن خطاب رضی اللہ عنہ نے ہمیں لکھا: امابعد، اپنے مشروبات کو اس"}
{"hadithnumber": "5721", "text": "عامر شعبی کہتے ہیں کہ  علی رضی اللہ عنہ لوگوں کو اتنا گاڑھا طلاء پلاتے کہ اگر اس میں مکھی گر جائے تو"}
{"hadithnumber": "5722", "text": "داود کہتے ہیں کہ  میں نے سعید بن المسیب سے پوچھا: وہ کون سا مشروب ہے جسے عمر رضی اللہ عنہ نے حلال قر"}
{"hadithnumber": "5723", "text": "سعید بن مسیب سے روایت ہے کہ  ابو الدرداء رضی اللہ عنہ ایسا مشروب پیتے جو دو تہائی جل کر ختم ہو گیا ہ"}
{"hadithnumber": "5724", "text": "ابوموسیٰ اشعری رضی اللہ عنہ سے روایت ہے کہ  وہ ایسا طلاء پیتے تھے جس کا دو تہائی جل کر ختم ہو گیا ہو"}
{"hadithnumber": "5725", "text": "سعید بن مسیب سے روایت ہے کہ  ایک اعرابی نے ان سے اس مشروب کے بارے میں پوچھا جو پکا کر آدھا رہ گیا ہو"}
{"hadithnumber": "5726", "text": "سعید بن مسیب کہتے ہیں کہ  جب طلاء جل کر ایک تہائی رہ جائے تو اسے پینے میں کوئی حرج نہیں۔"}
{"hadithnumber": "5727", "text": "ابورجاء کہتے ہیں کہ  میں نے حسن  ( حسن بصری )  سے اس طلاء کے بارے میں پوچھا جو جل کر نصف رہ گیا ہو،"}
{"hadithnumber": "5728", "text": "بشیر بن مہاجر کہتے ہیں کہ  میں نے حسن  ( حسن بصری )  سے پوچھا: شیرہ  ( رس )  کس قدر پکایا جائے۔ انہو"}
{"hadithnumber": "5729", "text": "انس بن سیرین کہتے ہیں کہ  میں نے انس بن مالک رضی اللہ عنہ کو کہتے ہوئے سنا: نوح علیہ السلام سے شیطان"}
{"hadithnumber": "5730", "text": "عبدالملک بن طفیل جزری کہتے ہیں کہ  عمر بن عبدالعزیز نے ہمیں لکھا: طلاء مت پیو، جب تک کہ اس کا دو تہا"}
{"hadithnumber": "5731", "text": "مکحول کہتے ہیں  ہر نشہ لانے والی چیز حرام ہے۔"}
{"hadithnumber": "5732", "text": "ابوثابت ثعلبی کہتے ہیں کہ  میں ابن عباس رضی اللہ عنہما کے پاس تھا اتنے میں ایک شخص آیا اور ان سے رس"}
{"hadithnumber": "5733", "text": "عطاء بیان کرتے ہیں کہ  میں نے ابن عباس رضی اللہ عنہما کو یہ کہتے ہوئے سنا: ”اللہ کی قسم! آگ کسی  ( ح"}
{"hadithnumber": "5734", "text": "سعید بن مسیب کہتے ہیں کہ  شیرہ  ( رس )  پیو، جب تک کہ اس میں جھاگ نہ آ جائے۔"}
{"hadithnumber": "5735", "text": "ہشام بن عائذ اسدی کہتے ہیں کہ  میں نے ابراہیم نخعی سے شیرے  ( رس )  کے بارے میں پوچھا تو انہوں نے کہ"}
{"hadithnumber": "5736", "text": "عطا سے شیرے (رس) کے بارے میں کہتے ہیں  پیو، جب تک اس میں جھاگ نہ آ جائے۔"}
{"hadithnumber": "5737", "text": "شعبی کہتے ہیں کہ  اسے  ( رس )  تین دن تک پیو سوائے اس کے کہ اس میں جھاگ آ جائے۔"}
{"hadithnumber": "5738", "text": "عبداللہ دیلمی کے والد فیروز رضی اللہ عنہ کہتے ہیں کہ  میں رسول اللہ صلی اللہ علیہ وسلم کے پاس آیا، م"}
{"hadithnumber": "5739", "text": "فیروز دیلمی رضی اللہ عنہ کہتے ہیں کہ  ہم نے عرض کیا: اللہ کے رسول! ہمارے انگور کے باغات ہیں ہم ان کا"}
{"hadithnumber": "5740", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے لیے نبیذ تیار کی جاتی تھ"}
{"hadithnumber": "5741", "text": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم کے لیے کشمش بھگوئی جاتی"}
{"hadithnumber": "5742", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے لیے رات کو کشمش کی نبیذ"}
{"hadithnumber": "5743", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  ان کے لیے مشکیزے میں کشمش صبح کو بھگوئی جاتی، پھر وہ ا"}
{"hadithnumber": "5744", "text": "بسام کہتے ہیں کہ  میں نے ابو جعفر سے نبیذ کے بارے میں پوچھا، تو انہوں نے کہا: علی بن حسین کے لیے رات"}
{"hadithnumber": "5745", "text": "عبداللہ بن المبارک کہتے ہیں کہ  میں نے سفیان سے سنا: ان سے نبیذ کے بارے میں سوال کیا گیا؟ انہوں نے ک"}
{"hadithnumber": "5746", "text": "ابوعثمان (جو ابوعثمان نہدی نہیں ہیں) سے روایت ہے کہ  ام الفضل نے انس بن مالک رضی اللہ عنہ سے گھڑے کی"}
{"hadithnumber": "5747", "text": "سعید بن مسیب سے روایت ہے کہ  وہ مکروہ سمجھتے تھے کہ نبیذ کے تل چھٹ کو نبیذ میں ملایا جائے تاکہ تل چھ"}
{"hadithnumber": "5748", "text": "سعید بن مسیب سے روایت ہے کہ  انہوں نے نبیذ کے بارے میں کہا: نبیذ کی شراب اس کی تل چھٹ ہے۔"}
{"hadithnumber": "5749", "text": "سعید بن مسیب کہتے ہیں کہ  خمر کا نام خمر اس لیے پڑا کہ وہ کچھ دیر رکھ چھوڑا جاتا ہے یہاں تک کہ وہ نت"}
{"hadithnumber": "5750", "text": "ابراہیم نخعی کہتے ہیں کہ  لوگوں کا خیال تھا کہ جو شخص کوئی مشروب پیے اور اس سے نشہ آ جائے تو اس کے ل"}
{"hadithnumber": "5751", "text": "ابراہیم نخعی کہتے ہیں کہ  پختہ  ( پکا ہوا )  شیرہ پینے میں کوئی حرج نہیں۔"}
{"hadithnumber": "5752", "text": "ابومسکین کہتے ہیں کہ  میں نے ابراہیم نخعی سے پوچھا: ہم لوگ خمر  ( شراب )  یا طلاء کا تل چھٹ لیتے ہیں"}
{"hadithnumber": "5753", "text": "ابن شبرمہ کہتے ہیں کہ  اللہ تعالیٰ ابراہیم نخعی پر رحم کرے، لوگ نبیذ کے سلسلے میں سختی کرتے ہیں اور"}
{"hadithnumber": "5754", "text": "ابواسامہ کہتے ہیں کہ  میں نے عبداللہ بن مبارک کو کہتے ہوئے سنا: میں نے کسی سے نشہ لانے والی چیز کی ر"}
{"hadithnumber": "5755", "text": "عبیداللہ بن سعید بیان کرتے ہیں کہ  میں نے ابواسامہ کو کہتے ہوئے سنا: میں نے کسی شخص کو عبداللہ بن مب"}
{"hadithnumber": "5756", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  ام سلیم رضی اللہ عنہا کے پاس لکڑی کا ایک پیالا تھا، جس کے بارے"}
{"hadithnumber": "5757", "text": "عبدالرحمٰن بن ابزیٰ کہتے ہیں کہ  میں نے ابی بن کعب رضی اللہ عنہ سے نبیذ کے بارے میں پوچھا؟ انہوں نے"}
{"hadithnumber": "5758", "text": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  لوگوں نے کئی مشروبات ایجاد کر لی ہیں، مجھے نہیں معلوم وہ"}
