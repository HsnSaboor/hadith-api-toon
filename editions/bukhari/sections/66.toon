5043,حَدَّثَنَا أَبُو النُّعْمَانِ ، حَدَّثَنَا مَهْدِيُّ بْنُ مَيْمُونٍ ، حَدَّثَنَا وَاصِلٌ ، عَنْ أَبِ,Default: Sahih,takhreej: وقوله تعالى ‏ {‏ ورتل القرآن ترتيلا‏}‏ وقوله ‏ {‏ وقرآنا فرقناه لتقرأه على الناس على مكث‏}‏ وما يكره أن يهذ كهذ الشعر‏.‏ ‏ {‏ يفرق‏}‏ يفصل‏.‏ قال ابن عباس ‏ {‏ فرقناه‏}‏ فصلناه‏.‏,5043,,Virtues of the Qur'an
5044,حَدَّثَنَا قُتَيْبَةُ بْنُ سَعِيدٍ ، حَدَّثَنَا جَرِيرٌ ، عَنْ مُوسَى بْنِ أَبِي عَائِشَةَ ، عَنْ سَ,Default: Sahih,"Book 66, Hadith 68",5044,,Virtues of the Qur'an
5045,حَدَّثَنَا مُسْلِمُ بْنُ إِبْرَاهِيمَ ، حَدَّثَنَا جَرِيرُ بْنُ حَازِمٍ الْأَزْدِيُّ ، حَدَّثَنَا قَ,Default: Sahih,"Book 66, Hadith 69",5045,,Virtues of the Qur'an
5046,حَدَّثَنَا عَمْرُو بْنُ عَاصِمٍ ، حَدَّثَنَا هَمَّامٌ ، عَنْ قَتَادَةَ ، قَالَ : سُئِلَ أَنَسٌ :,Default: Sahih,"Book 66, Hadith 70",5046,,Virtues of the Qur'an
5047,حَدَّثَنَا آدَمُ بْنُ أَبِي إِيَاسٍ ، حَدَّثَنَا شُعْبَةُ ، حَدَّثَنَا أَبُو إِيَاسٍ ، قَالَ : سَمِع,Default: Sahih,"Book 66, Hadith 71",5047,,Virtues of the Qur'an
5048,حَدَّثَنَا مُحَمَّدُ بْنُ خَلَفٍ أَبُو بَكْرٍ ، حَدَّثَنَا أَبُو يَحْيَى الْحِمَّانِيُّ ، حَدَّثَنَا,Default: Sahih,"Book 66, Hadith 72",5048,,Virtues of the Qur'an
5049,حَدَّثَنَا عُمَرُ بْنُ حَفْصِ بْنِ غِيَاثٍ ، حَدَّثَنَا أَبِي ، عَنْ الْأَعْمَشِ ، قَالَ : حَدَّثَنِ,Default: Sahih,"Book 66, Hadith 73",5049,,Virtues of the Qur'an
5050,حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ ، حَدَّثَنَا سُفْيَانُ ، عَنْ الْأَعْمَشِ ، عَنْ إِبْرَاهِيمَ ، عَ,Default: Sahih,"Book 66, Hadith 74",5050,,Virtues of the Qur'an
5051,حَدَّثَنَا عَلِيٌّ ، حَدَّثَنَا سُفْيَانُ ، قَالَ لِي ابْنُ شُبْرُمَةَ :    نَظَرْتُ كَمْ يَكْفِي ال,Default: Sahih,takhreej: وقول الله تعالى ‏ {‏ فاقرءوا ما تيسر منه‏}‏,5051,,Virtues of the Qur'an
5052,حَدَّثَنَا مُوسَى ، حَدَّثَنَا أَبُو عَوَانَةَ ، عَنْ مُغِيرَةَ ، عَنْ مُجَاهِدٍ ، عَنْ عَبْدِ اللَّ,Default: Sahih,"Book 66, Hadith 77",5052,,Virtues of the Qur'an
5053,حَدَّثَنَا سَعْدُ بْنُ حَفْصٍ ، حَدَّثَنَا شَيْبَانُ ، عَنْ يَحْيَى ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الر,Default: Sahih,"Book 66, Hadith 78",5053,,Virtues of the Qur'an
5054,حَدَّثَنِي إِسْحَاقُ ، أَخْبَرَنَا عُبَيْدُ اللَّهِ بْنُ مُوسَى ، عَنْ شَيْبَانَ ، عَنْ يَحْيَى ، عَ,Default: Sahih,"Book 66, Hadith 79",5054,,Virtues of the Qur'an
5055,حَدَّثَنَا صَدَقَةُ ، أَخْبَرَنَا يَحْيَى ، عَنْ سُفْيَانَ ، عَنْ سُلَيْمَانَ ، عَنْ إِبْرَاهِيمَ ،,Default: Sahih,"Book 66, Hadith 80",5055,,Virtues of the Qur'an
5056,حَدَّثَنَا قَيْسُ بْنُ حَفْصٍ ، حَدَّثَنَا عَبْدُ الْوَاحِدِ ، حَدَّثَنَا الْأَعْمَشُ ، عَنْ إِبْرَا,Default: Sahih,"Book 66, Hadith 81",5056,,Virtues of the Qur'an
5057,حَدَّثَنَا مُحَمَّدُ بْنُ كَثِيرٍ ، أَخْبَرَنَا سُفْيَانُ ، حَدَّثَنَا الْأَعْمَشُ ، عَنْ خَيْثَمَةَ,Default: Sahih,"Book 66, Hadith 82",5057,,Virtues of the Qur'an
5058,حَدَّثَنَا عَبْدُ اللَّهِ بْنُ يُوسُفَ ، أَخْبَرَنَا مَالِكٌ ، عَنْ يَحْيَى بْنِ سَعِيدٍ ، عَنْ مُحَ,Default: Sahih,"Book 66, Hadith 83",5058,,Virtues of the Qur'an
5059,حَدَّثَنَا مُسَدَّدٌ ، حَدَّثَنَا يَحْيَى ، عَنْ شُعْبَةَ ، عَنْ قَتَادَةَ ، عَنْ أَنَسِ بْنِ مَالِك,Default: Sahih,"Book 66, Hadith 84",5059,,Virtues of the Qur'an
5060,حَدَّثَنَا أَبُو النُّعْمَانِ ، حَدَّثَنَا حَمَّادٌ ، عَنْ أَبِي عِمْرَانَ الْجَوْنِيِّ ، عَنْ جُنْد,Default: Sahih,"Book 66, Hadith 85",5060,,Virtues of the Qur'an
5061,حَدَّثَنَا عَمْرُو بْنُ عَلِيٍّ ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ ، حَدَّثَنَا سَلَّامُ,Default: Sahih,"Book 66, Hadith 86",5061,,Virtues of the Qur'an
5062,حَدَّثَنَا سُلَيْمَانُ بْنُ حَرْبٍ حَدَّثَنَا شُعْبَةُ عَنْ عَبْدِ الْمَلِكِ بْنِ مَيْسَرَةَ عَنْ ال,Default: Sahih,"Book 66, Hadith 87",5062,,Virtues of the Qur'an
