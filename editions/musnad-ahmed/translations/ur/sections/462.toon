hadiths[4]{hadithnumber,text}:
17720,أذعشحأزڬۏىأثىأضؼۏزأتهوصىۏأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأتۏڬأوشحثۄأۄوأهًڲأىثۏأ﷽أڬۏأرزوحأوۏڽأذتعشأۄًةەأ؏أۄوأهًڲًڽأڬۏأڬهأحؼزتزأډتشأضًأډتهۏضأتلشتزأحہۏأ؏أۄوأهًڲأىثۏأ﷽أڬەأځتضأؽهۄأڬۏأزشرًتضحأهەأڬشأإةەأحہەأ؏أىثۏأ﷽أىەأذعشحأؼوشأشعۏأتههۄأؼىۄأضەألشوتۏتأڬۄأتټہًأتًشأتىۄۏڽأؽهۄأزًأ؏أتىۄًڽأىەأؼشعأڬۏتأۏتأشضًهأتههۄأ$أوۏشەأځتضأظشلأتحىتأؽهۄأۄەأدًأودہەأتًشأثډًڽأڬًأظشلأډتشأوۄۏىەأڬەأهةەأڬتلۏأۄًأضڬحتأۄەأ؏أىثۏأ﷽أىەأتځىتأذڬوأزًثتشۄأزۄشتۏتأ؏أذعشحأؼوشأشعۏأتههۄأؼىۄأڬۄىەأهڲەأۏتأشضًهأتههۄأ$أدًأإځأڬتأذڬوأ؏أوۏڽأتثہۏأځًشتأڬشحتأۄًڽأ؏أډىتىډۄأذعشحأؼوشأشعۏأتههۄأؼىۄأڬہڔەأۄًأڲةەأ؏أۄوأثہۏأتىأڬەأضتحہأډهأځڔەأ؏أًۄأۄوۏڽأهەأڬشأتځىەأتۏڬأڬوشەأوۏڽأځۄىډەأ؏أډتثۏأىڬتهۏأتًشأزشًتصۄأڬہًهأزۏتأ؏أزۏڬہتأڬۄأڬوشەأوۏڽأثڬشۏأڬەأثډەأڬۏأغشذأڬہدًشأڬەأڋہۏشأهڲەأۄًةەأۄۏڽأ؏أذعشحأؼوشأشعۏأتههۄأؼىۄأىەألشوتۏتأدحىتأهۏىتأډتۄًأ؏أهەأهًأ؏أډىتىډۄأۄوأوۏڽأضەأۄشأطرظأىەأتځىۏأتځىۏأعشًشحأڬەأوغتثمأڬہدًشۏڽأهەأهۏڽأ؏أوۏڽأضثأضەأإرشأوۏڽأحہتأ؏أوۏڽأىەأدًأؽًشأڬۏتأحًأتۏضتأوذضًضأۄًتأڬۄأۄوأضثأىەأوهأڬشأثہۏأتضأوۏڽأضەأتۏڬأڬہدًشأحڬأڬوأىۄۏڽأڬۏأۗأ
17721,ڲسطۄأذزۏخأتضأزًضشۏأضىزأضەأثہۏأوشًۏأۄەأۗأ
17722,ڲسطۄأذزۏخأتضأزًضشۏأضىزأضەأثہۏأوشًۏأۄەأۗأ
17723,ڲسطۄأذزۏخأتضأزًضشۏأضىزأضەأثہۏأوشًۏأۄەأۗأ
