{"hadithnumber": "1730", "text": "عطاء بن یسار رحمہ اللہ سے روایت ہے کہ رسول اللہ ﷺ مسجد میں ( تشریف فرما ) تھے کہ ( اتنے میں ) ایک آد"}
{"hadithnumber": "1731", "text": "ابوسلمہ بن عبدالرحمن رحمہ اللہ سے روایت ہے کہ بے شک عبدالرحمن بن اسود بن عبدِ یغوث رحمہ اللہ جو کہ ا"}
{"hadithnumber": "1732", "text": "یحیی بن سعید رحمہ اللہ سے روایت ہے ، کہتے ہیں کہ مجھے یہ خبر پہنچی کہ حضرت خالد بن ولید رضی اللہ عنہ"}
{"hadithnumber": "1733", "text": "یحیی بن سعید رحمہ اللہ سے روایت ہے ، کہتے ہیں کہ رسول اللہ ﷺ کو ( جس رات ) معراج پر لے جایا گیا ، آپ"}
{"hadithnumber": "1734", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ بے شک ( بنوخزاعہ کی ایک شاخ ) اسلم قبیلے کے ایک شخص نے عرض"}
{"hadithnumber": "1735", "text": "کعب احبار رحمہ اللہ ( جو اسلام لانے سے قبل یہودی عالم تھے ) سے روایت ہے ، کہتے ہیں کہ اگر وہ کلمات ن"}
{"hadithnumber": "1736", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ، کہتے ہیں کہ رسول اللہ ﷺ نے فرمایا :’’ یقیناً اللہ تبارک و ت"}
{"hadithnumber": "1737", "text": "حضرت ابوسعید خدری رضی اللہ عنہ یا حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ، کہتے ہیں کہ بلاشبہ رسول ا"}
{"hadithnumber": "1738", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ یقیناً رسول اللہ ﷺ نے فرمایا :’’ جب اللہ تعالیٰ کسی بندے س"}
{"hadithnumber": "1739", "text": "ابوادریس خولانی رحمہ اللہ سے روایت ہے ، اس نے کہا : میں دمشق کی مسجد میں داخل ہوا تو اچانک ( وہاں )"}
{"hadithnumber": "1740", "text": "حضرت ابن عباس رضی اللہ عنہما سے روایت ہے ، وہ کہا کرتے تھے کہ میانہ روی ، نرمی اور اچھی ہیت و صورت ن"}
{"hadithnumber": "1741", "text": "حضرت انس بن مالک رضی اللہ عنہ سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ نے فرمایا :’’ نیک آدمی کا اچھا خواب"}
{"hadithnumber": "1742", "text": "حضرت ابوہریرہ رضی اللہ عنہ نے بھی رسول اللہ ﷺ سے اس طرح روایت بیان کی ہے ۔"}
{"hadithnumber": "1743", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ جب فجر کی نماز سے فارغ ہوتے تو فرماتے :"}
{"hadithnumber": "1744", "text": "عطاء بن یسار رحمہ اللہ سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ نے فرمایا :’’ میرے اور نبوت میں سے مبشرات ک"}
{"hadithnumber": "1745", "text": "حضرت ابو قتادہ بن ربعی رضی اللہ عنہ سے روایت ہے ، کہتے ہیں کہ میں نے رسول اللہ ﷺ کو یہ فرماتے ہوئے س"}
{"hadithnumber": "1746", "text": "ہشام بن عروہ رحمہ اللہ اپنے والد ( عروہ بن زبیر رضی اللہ عنہ ) سے روایت کرتے ہیں کہ بلاشبہ وہ اس آیت"}
