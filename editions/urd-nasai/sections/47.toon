hadiths[55]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
4985,ابن محیریز کہتے ہیں کہ  میں نے فضالہ بن عبید رضی اللہ عنہ سے چور کا ہاتھ کاٹ کر اس کی گردن میں لٹکان,,,,,4985
4986,"عبدالرحمٰن بن محیریز کہتے ہیں کہ  میں نے فضالہ بن عبید رضی اللہ عنہ سے کہا: کیا چور کا ہاتھ کاٹ کر ا",,,,,4986
4987,"عبدالرحمٰن بن عوف رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جب حد قائم ہ",,,,,4987
4988,"ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم سے پوچھا گیا: سب سے بہتر عمل کون ",,,,,4988
4989,"عبداللہ بن حبشی خثعمی رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم سے پوچھا گیا: کون سا ",,,,,4989
4990,"انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”تین چیزیں جس میں ہوں ",,,,,4990
4991,"انس بن مالک روایت کرتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”تین چیزیں جس میں ہوں گی وہ ای",,,,,4991
4992,"انس رضی اللہ عنہ روایت کرتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”تین چیزیں جس میں پائی جا",,,,,4992
4993,عمر بن خطاب رضی اللہ عنہ بیان کرتے ہیں کہ  ایک دن ہم رسول اللہ صلی اللہ علیہ وسلم کے پاس بیٹھے ہوئے ,,,,,4993
4994,ابوہریرہ اور ابوذر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم صحابہ کے درمیان اس طرح ب,,,,,4994
4995,سعد بن ابی وقاص رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے کچھ لوگوں کو عطیہ دیا اور ا,,,,,4995
4996,سعد رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے مال تقسیم کیا تو کچھ لوگوں کو دیا ا,,,,,4996
4997,بشر بن سحیم رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے انہیں حکم دیا کہ ایام تشریق ,,,,,4997
4998,"ابوہریرہ رضی اللہ عنہ روایت کرتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”مسلمان وہ ہے، جس ک",,,,,4998
4999,"عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا: ",,,,,4999
5000,"انس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جو ہمارے جیسی نماز پڑھے، ہمار",,,,,5000
5001,"ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جب کوئی بندہ اسلام ",,,,,5001
5002,"ابوموسیٰ اشعری رضی اللہ عنہ کہتے ہیں کہ  میں نے عرض کیا: اللہ کے رسول! کون سا اسلام بہتر ہے؟ آپ نے ف",,,,,5002
5003,"عبداللہ بن عمرو رضی اللہ عنہما سے روایت ہے کہ  ایک شخص نے رسول اللہ صلی اللہ علیہ وسلم سے پوچھا: کون",,,,,5003
5004,"عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  ایک شخص نے ان سے کہا: کیا آپ جہاد نہیں کریں گے؟ انہوں ",,,,,5004
5005,عبادہ بن صامت رضی اللہ عنہ کہتے ہیں کہ  ہم لوگ ایک مجلس میں نبی اکرم صلی اللہ علیہ وسلم کے پاس تھے ت,,,,,5005
5006,"انس بن مالک رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”مجھے حکم دیا گیا ہ",,,,,5006
5007,"ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”ایمان کی ستر سے زائد ش",,,,,5007
5008,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”ایمان کی ستر سے زائد شاخ",,,,,5008
5009,"ابوہریرہ رضی اللہ عنہ روایت کرتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”حیاء  ( شرم )  ایما",,,,,5009
5010,"نبی اکرم صلی اللہ علیہ وسلم کے ایک صحابی کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”عمار ",,,,,5010
5011,"ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو سنا، آپ نے فرمایا: ”ت",,,,,5011
5012,"ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا: ”جس ",,,,,5012
5013,"ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”تم میں سے کسی کا دن",,,,,5013
5014,"ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”ایک مرتبہ میں سو رہ",,,,,5014
5015,"طارق بن شہاب کہتے ہیں کہ  یہود کا ایک یہودی عمر بن خطاب رضی اللہ عنہ کے پاس آ کر بولا: امیر المؤمنین",,,,,5015
5016,"انس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”تم میں سے کوئی مومن نہیں ہو س",,,,,5016
5017,"انس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”تم میں سے کوئی مومن نہیں ہو س",,,,,5017
5018,"ابوہریرہ رضی اللہ عنہ روایت کرتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اس ذات کی قسم، جس ",,,,,5018
5019,"انس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”تم میں سے کوئی مومن نہیں ہو س",,,,,5019
5020,"انس رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اس ذات کی قسم، جس کے ہاتھ ",,,,,5020
5021,علی رضی اللہ عنہ کہتے ہیں کہ  نبی امّی صلی اللہ علیہ وسلم نے سے مجھ سے عہد کیا کہ ”تم سے صرف مومن ہی,,,,,5021
5022,"انس رضی اللہ عنہ روایت کرتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”انصار سے محبت ایمان کی ن",,,,,5022
5023,"عبداللہ بن عمرو رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جس میں چار چی",,,,,5023
5024,"ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”نفاق کی تین علامتیں  ",,,,,5024
5025,علی رضی اللہ عنہ کہتے ہیں کہ  مجھ سے رسول اللہ صلی اللہ علیہ وسلم نے عہد کیا کہ ”مجھ سے محبت صرف موم,,,,,5025
5026,"عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  تین باتیں جس شخص میں ہوں، وہ منافق ہے: جب بات چیت کرے تو ",,,,,5026
5027,"ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے ایمان کے ساتھ ث",,,,,5027
5028,"ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جو شخص رمضان کے مہینے ",,,,,5028
5029,"ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جس نے رمضان کے مہینے م",,,,,5029
5030,"ابوہریرہ رضی اللہ عنہ بیان کرتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے رمضان میں ایم",,,,,5030
5031,طلحہ بن عبیداللہ رضی اللہ عنہ سے روایت ہے کہ  اہل نجد میں سے ایک شخص رسول اللہ صلی اللہ علیہ وسلم کے,,,,,5031
5032,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا: ”اللہ تعا",,,,,5032
5033,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اللہ تعالیٰ نے ضمانت لی ",,,,,5033
5034,عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے پاس بنی عبدقیس کا وفد آی,,,,,5034
5035,"ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جو کسی مسلمان کے جنازے",,,,,5035
5036,عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم کا ایک شخص کے پاس سے گزر ,,,,,5036
5037,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”یہ دین آسان ہے اور جو دی",,,,,5037
5038,ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم ان کے پاس آئے، ان کے پاس,,,,,5038
5039,"ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”وہ زمانہ قریب ہے جب",,,,,5039
