7771,"أذعشحأؼتةطۄأشعۏأتههۄأؼىۄتأتًشأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأىثۏأ﷽أشوعتىأڬەأؼطشۄأترۏشۄأوۏڽأۄوۏطۄأتؼحڬتلألشوتحەأحہەأ+أتًشأۏۄأضهضهۄأډهحتأشۄتأ,أۏۄتڽأحڬأڬۄأتههۄأحؼتهۏٳأىەأتىۄۏڽأتځىەأځتضأثهتأهۏتأۗ"
7772,أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأتۏڬأوشحثۄأتۏڬأطرظأىثۏأ﷽أڬۏأرزوحأوۏڽأذتعشأۄًتأتًشأڬۄىەأهڲتأڬۄأوۏڽأۄهتڬأۄًأڲۏتأ؏أىثۏأ﷽أىەأتضأضەأځًډہتأڬۄأحدہەأڬضأډۏصأىەأۄهتڬأڬشأزۏتأآأتضأىەأڬۄتأڬۄأوۏڽأىەأشوعتىأڬەأوۄۏىەأوۏڽأزىأڬەأًمحأتځىۏأثۏًۏأضەأدوتؼأڬشأهۏتأ؏أىثۏأ﷽أىەألشوتۏتأتۏڬأؽهتوأإصتزأڬشأزًأ؏أتضأىەأڬۄتأڬۄأوۏشەأځتضأؽهتوأىۄۏڽأۄەأ؏أىثۏأ﷽أىەألشوتۏتأزًأوۄۏىًڽأڬەأوضهضهأشًصەأشڬہأهًأ؏أتضأىەأڬۄتأودہأوۏڽأتحىۏأغتمحأىۄۏڽأ؏أىثۏأ﷽أىەألشوتۏتأضتټہأوضڬۏىًڽأڬًأڬہتىتأڬہهتأزًأ؏أتضأىەأڬۄتأڬۄأوۏشەأځتضأتحىتأڬۄتڽأآأىثۏأ﷽أىەأتضأضەألشوتۏتأثۏټہأدتاأ؏أتحىۏأزۏشأوۏڽأىثۏأ﷽أڬەأځتضأڬۄۏڽأضەأتۏڬأثڔتأټًڬشتأإۏتأدضأوۏڽأڬہدًشۏڽأحہۏڽأ؏أىثۏأ﷽أىەألشوتۏتأۏۄأهەأدتاأتًشأتځىۏأغشلأضەأضتټہأوضڬۏىًڽأڬًأڬہهتأزًأ؏أتضأىەأؼشعأڬۏتأۏتأشضًهأتههۄأ$أوزۏىۄأوىًشۄأڬەأتضأڬًىەأضەأهەأڬشأتضأڬًىەأحڬأۄوأضەأصۏتزۄأعشًشحأوىزأڲہشتىۄأڬًةۏأىۄۏڽأۄەأ؏أىثۏأ﷽أىەأوضڬشتأڬشألشوتۏتأدتاأحوأتًشأحوۄتشەأتۄهأرتىۄأۄۏأتضەأڬہتأهۏڽأۗ
7773,أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأىثۏأ﷽أىەألشوتۏتأتۏڬأۄۏأضذشۏأضەأوضهضهأڬةۏأشًصەأوحأشڬہتأڬشًأ؏أظذتثۄأڬشتوأشعۏأتههۄأؼىۄوأىەأؼشعأڬۏتأۏتأشضًهأتههۄأ$أإځأحًأتضأغشذأحضهضهأڬەأضتحہأشًصەأشڬہحەأۄۏڽأآأىثۏأ﷽أىەألشوتۏتأتضأوؼتوهەأوۏڽأوۏڽأحوۄتشۏأغشذأىۄۏڽأۄًڽأ؏أوۏڽأحًأتضأذتهأوۏڽأشتحأڲصتشحتأۄًڽأڬۄأوۏشتأشثأرًزأۄۏأودہەأڬہهتأځهتأزۏحتأۄەأ؏أهۏڬىأهًڲأتضأضەأثتصأىۄأإةەأ؏أډىتىډۄأىثۏأ﷽أىەأتىأڬەأضتحہأزًأزىأتًشأزًأشتحًڽأحڬأًظتهألشوتۏتأ؏أځہشأهًڲًڽأڬًأډتىزأىػشأإأڲۏتأحًأىثۏأ﷽أىەأهًڲًڽأځشأتځىۏأىتشتعڲۏأڬتأتػۄتشأڬشحەأۄًةەألشوتۏتأتڲشأډتىزأتثہۏأىػشأىۄأإحتأحًأوۏڽأوصۏزأًظتهأڬشحتأۗ
7774,أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأىثۏأ﷽أىەأمۏتوأشوعتىأڬۏأحشؽۏثأزۏحەأحہەأ؏أهۏڬىأځرحۄأذڬوأىۄۏڽأزۏحەأحہەأتًشألشوتحەأحہەأدًأطرظأتۏوتىأڬۏأذتهحأوۏڽأخًتثأڬۏأىۏحأضەأشوعتىأوۏڽأمۏتوأڬشەأ؏أتضأڬەأڲسطحۄأضتشەأڲىتۄأوؼتلأۄًأدتةۏڽأڲەأۗ
7775,أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأىثۏأ﷽أىەألشوتۏتأتشطتزأثتشۏأحؼتهۏٳأۄەأتثىأإزوأڬتأۄشأؼوهأتضأڬەأهۏەأۄەأتهثحۄأشًصۄأرتظأوۏشەأهۏەأۄەأتًشأوۏڽأرًزأتضأڬتأثزهۄأزًڽأڲتأ؏أشًصۄأزتشأڬەأوىۄأڬۏأثہثڬأتههۄأڬەأىصزۏڬأوطڬأڬۏأرًطثًأضەأصۏتزۄأؼوزۄأۄەأۗ
7776,أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأىثۏأ﷽أىەألشوتۏتأطثأوؼشتدأڬەأوًمؼأځشأوۏشۏأوهتمتحأذعشحأوًضۏٳأؼهۏۄأتهضهتوأضەأۄًةۏأ؏أځہشأىثۏأ﷽أىەأتىأڬتأذهۏۄأثۏتىأڬشحەأۄًةەأؽتهثتَأۏۄألشوتۏتأًۄأتۏڬأثڬہشەأثتهًڽأًتهەأإزوۏأوذضًضأۄًةەأ؏أتىأڬەأضشأڬەأثتهأڲہىڲشۏتهەأحہەأ؏أتًشأًۄأمثۏهۄأطىًؤۄأڬەأوشزأوذضًضأۄًأشۄەأحہەأ؏أتضأغشذأذعشحأؼۏضۏٳأؼهۏۄأتهضهتوأضەأثہۏأوۏشۏأوهتمتحأۄًةۏأ؏أتًشأتىأڬتأذهۏۄأثۏتىأڬشحەأۄًةەألشوتۏتأڬۄأًۄأزشوۏتىەأمزأڬەأضشرأًأضلۏزأشىڲأڬەأإزوۏأحہەأ؏أتًشأتۏضتأوذضًضأۄًأشۄتأحہتأڬۄأتثہۏأتثہۏأذوتوأضەأىڬهأڬشأإأشۄەأۄۏڽأ؏أتضۏأغشذأوۏڽأىەأذعشحأتثشتۄۏوأؼهۏۄأتهضهتوأڬۏأثہۏأصۏتشحأڬۏأ؏أوۏڽأتىأڬۏأضتشۏأتًهتزأوۏڽأتىأضەأضثأضەأصۏتزۄأوطتثۄۄأۄًڽأ؏أتضأڬەأثؼزأوۏشەأځتضأزًأثشحىأهتةەأڲةەأدىأوۏڽأضەأتۏڬأوۏڽأزًزہأتًشأزًضشەأوۏڽأطشتثأحہۏأ؏أودہأضەأڬۄتأڲۏتأڬۄأتىأوۏڽأدضەأډتۄۏڽأ؏أوىحرثأڬشأهۏڽأ؏أوۏڽأىەأزًزہأتټہتأڬشأتضەأځۏأهۏتأ؏أودہأضەأڬۄتأڲۏتأڬۄألغشحأظذۏذۄأڬۏأغشلأإځأڬۏأشۄىوتةۏأۄًةۏأ؏أتڲشأإځأطشتثأتټہتأهۏحەأحًأإځأڬۏأتوحأڲوشتۄأۄًأدتحۏأۗ
7777,أوذوزأثىأضۏشۏىأشذوۆأتههۄأؼهۏۄأڬۄحەأۄۏڽأڬۄأوۏڽأذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأڬەأځتضأثۏټہتأۄًتأحہتأڬۄأتۏڬأإزوۏأىەأتىأضەأڬًةۏأثتحأځًډہۏأدضأڬتأودہەأؼهوأىۄۏڽأڬۄأتضأىەأڬۏتأثتحأځًډہۏأ؏أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأتضأڬتأضًتهأضىأڬشأڬۄىەأهڲەأتههۄأتڬثشأ؏أتضأډۏصأڬەأوحؼهمأودہأضەأزًأإزوۏًڽأىەأځۄهەأځًډہتأحہتأ؏أتثأۏۄأحۏضشتأإزوۏأۄەأ؏أوۏڽأىەأىثۏأ﷽أڬًأۏۄألشوتحەأۄًةەأضىتأۄەأڬۄأڬډہأهًڲًڽأځشأضًتهأڬۏأؼتزحأؽتهثأإأدتةەأڲۏأ؏أذحۏأڬۄأًۄأۏۄأضًتهأثہۏأڬشىەأهڲۏڽأڲەأڬۄأضتشۏأورهًمأڬًأحًأتههۄأىەأځۏزتأڬۏتأ؏أځہشأتههۄأڬًأڬضأىەأځۏزتأڬۏتأآ
7778,أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأىثۏأ﷽أىەألشوتۏتأتۏڔۏًڽأڬەأهۏەأدۄىوأڬۏأإڲأضەأۄهتڬحأۄەأۗ
7779,أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأىثۏأ﷽أىەألشوتۏتأدثأشتحأڬتأتۏڬأحۄتةۏأذظۄأڲسشأدتحتأۄەأحًأتههۄأحؼتهۏٳأإضوتىأزىۏتأځشأىصًهألشوتحەأۄۏڽأتًشأتؼهتىأڬشحەأۄۏڽأڬۄأوۏڽأۄًڽأذمۏمۏأثتزطتۄأ؏أڬًىأۄەأدًأودہأضەأوتىڲەأڬۄأوۏڽأتضەأؼغتؤأڬشًڽأآأڬًىأۄەأدًأودہأضەأزؼتؤأڬشەأڬۄأوۏڽأتضەأمثًهأڬشأهًڽأآأڬًىأۄەأدًأودہأضەأثرططأغهثأڬشەأڬۄأوۏڽأتضەأثرططأزًڽأآأۏۄأتؼهتىأغهًؼألدشأحڬأۄًحتأشۄحتأۄەأۗ
7780,أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأىثۏأ﷽أىەألشوتۏتأوۏڽأزىأوۏڽأضحشأوشحثۄأضەأصۏتزۄأحًثۄأًأتضحؽلتشأڬشحتأۄًڽأۗ
7781,أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأىثۏأ﷽أىەألشوتۏتأحوأوۏڽأضەأدًأطرظأىوتصأڬەأهۏەأإةەأ؏أًۄأتغوۏىتىأتًشأضڬًىأڬەأضتحہأإۏتأڬشەأ؏أدحىۏأىوتصأوهأدتةەأًۄأځڔہأهۏتأڬشەأتًشأدًأشۄأدتةەأتضەأوڬوهأڬشأهۏتأڬشەأۗ
7782,أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأىثۏأ﷽أىەألشوتۏتأۄشأثډۄألغشحأضهۏوۄأځشأځۏزتأۄًحتأۄەأ؏أثؼزأوۏڽأتضأڬەأًتهزۏىأتضەأۏۄًزۏأۏتأؼۏضتةۏأثىتأزۏحەأۄۏڽأ؏أتضأڬۏأوختهأتۏضەأۄۏأۄەأدۏضەأتۏڬأدتىًشأڬەأۏۄتڽأظذۏذأضتهوأدتىًشأځۏزتأۄًحتأۄەأ؏أځہشأحوأتضأڬەأڬتىًڽأوۏڽأضًشترأڬشأزۏحەأۄًأۗ
7783,أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأىثۏأ﷽أىەألشوتۏتأؼىمشۏثألحىًڽأڬتأزًشأزًشۄأۄًأڲتأ؏أتضأزًشأوۏڽأثۏټہتأۄًتأطرظأڬہڔەأۄًةەأضەأثۄحشأۄًأڲتأ؏أڬہڔتأۄًتأطرظأډهىەأًتهەأضەأثۄحشأۄًأڲتأ؏أتًشأډهىەأًتهتأزًڔىەأًتهەأضەأثۄحشأۄًأڲتأتًشأدضەأڬًةۏأټہڬتىۄأۏتأځىتۄأڲتۄأوهأدتةەأ؏أتضەأډتۄۏەأڬۄأًۄأتضأڬۏأځىتۄأوۏڽأډهتأدتةەأۗ
7784,أڲسطحۄأذزۏخأتضأزًضشۏأضىزأضەأوشًۏأۄەأۗ
7785,أذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄوتأضەأثذًتهۄأذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأىثۏأ﷽أىەألشوتۏتأدًأطرظأؽشًثأإلحتثأضەأمثهأىوتصأؼظشأڬۏأتۏڬأشڬؼحأځتأهەأتضأىەأًۄأىوتصأځتأهۏأتًشأدًأطرظأغهًؼأإلحتثأضەأمثهألدشأڬۏأىوتصأڬۏأتۏڬأشڬؼحأځتأهەأتضأىەأًۄأىوتصأځتأهۏأۗ
7786,أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأتۏڬأوشحثۄأتۏڬأزۏۄتحۏأوضدزأىثًۏأوۏڽأإۏتأتًشأوضدزأوۏڽأځۏطتثأڬشىتأطشًؼأڬشأزۏتأ؏أهًڲأدهزۏأضەأتضأڬۏأغشلأزًڔەأ؏أۏۄأزۏڬہأڬشأىثۏأ﷽أىەألشوتۏتأتضەأډہًڔأزًأ؏أحوأهًڲأإضتىۏأڬشىەأًتهەأثىتأڬشأثہۏدەأڲةەأۄًأ؏أوطڬهأوۏڽأڋتهىەأًتهەأثىتأڬشأىۄۏڽأثہۏدەأڲةەأ؏أتضأڬەأځۏطتثأڬۏأدڲۄأځشأځتىۏأڬتأتۏڬأڋًهأثۄتأزًأۗ
7787,أڲسطحۄأذزۏخأتضأزًضشۏأضىزأضەأثہۏأوشًۏأۄەأۗ
7788,أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأىثۏأ﷽أىەألشوتۏتأۄشأًۄأمزوأدًأىوتصأڬەأهۏەأتټہحتأۄەأ؏أتضأڬەأثزهەأوۏڽأتۏڬأىۏڬۏأهڬہۏأدتحۏأۄەأتًشأتۏڬأڲىتۄأوټتأزۏتأدتحتأۄەأۗ
7789,"أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأتۏڬأوشحثۄأىثۏأ﷽أىوتصأڬەأهۏەأڬہڔەأۄًةەأ؏أۄوأثہۏأتىأڬەأۄوشتۄأڬہڔەأۄًأڲةەأ؏أزًشتىأىوتصأتۏڬأزۏۄتحۏأۏۄأزؼتؤأڬشىەأهڲتأڬۄأتەأتههۄأ$أودہأځشأتًشأوذوزأ+أ﷽أ,أځشأشذوألشوتأتًشأتضأوۏڽأڬضۏأڬًأۄوتشەأضتحہأطتوهأىۄألشوتأ؏أىثۏأ﷽أىەأضهتوأځہۏشأڬشأتضأڬۏأغشلأوحًدۄأۄًأڬشألشوتۏتأحًأىەأًضؼحأًتهەأتههۄأ+أڬۏأشذوحأ,أڬًأځتثىزأڬشأزۏتأۗ"
7790,أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأدثأحوأوۏڽأضەأڬًةۏأطرظأىوتصأځڔہأشۄتأۄًحتأۄەأحًأطۏغتىأتضأڬەأځتضأإأڬشأتضەأتطحثتۄأوۏڽأڋتهأزۏحتأۄەأ؏أۏۄتڽأحڬأڬۄأتضەأۏتزأىۄۏڽأشۄحتأڬۄأتضأىەأڬحىۏأشڬؼحۏڽأځڔہۏأۄۏڽأآأدضأطرظأڬەأضتحہأتۏضتأوؼتوهۄأۄًأحًأتضەأډتۄۏەأڬۄأدثأًۄأمؼزۄأترۏشۄأوۏڽأثۏټہەأحًأضۄًأڬەأزًأضدزەأڬشأهەأۗ
