أؼثتزحأڬشأڬشأڬەأتىأڬۏأذتهحأۏۄأۄًأڲةۏأحہۏأ+أهڲحتأحہتأڬۄأ,أتىأڬەأثزىأضەأشًذأىڬهأډڬۏأۄەأۗأۏۄأهًڲأضتشتأزىأشًصەأضەأڲصتشحەأتًشأشتحأڬًأمۏتوأڬشحەأ؏أضذشۏأڬەأًمحأتىأڬًأدًأوۏضشأإحتأًۄۏأڬہتأهۏحەأۄۏڽأۗأۄوأتىأهًڲًڽأڬەأځتضأدتأڬشأثۏټہأڲەأ؏أڬضتىأ+أڬەأثۏټەأ
أىەأتځىەأشتۄىوتأڬۏأحؼشۏلأًأخىتؤأڬۏأۗأځہشأًۄأهًڲأإځضأوۏڽأثتحأډۏحأڬشىەأهڲەأ؏أتىۄًڽأىەأتههۄأحؼتهۏٳأڬۏأذوزأًأخىتؤأڬۏأ؏أضتثمۄأتىثۏتؤأًأشضهأڬۏأحؼشۏلأڬۏأۗأثتحأډهحەأډهحەأذعشحأؼۏضۏٳأؼهۏۄأتهضهتوأحڬأځۄىډۏأ؏أتضأضهضهەأوۏڽأتىأڬەأىػشۏتحأۏۄأحہەأڬۄأتههۄأحؼتهۏٳأىەأذعشحأؼۏضۏٳأؼهۏۄأتهضهتوأڬًأشضًهأثىتأڬشأثہۏدتأ؏أتًشأتىأڬًأۏۄأترحۏتشأزۏتأڬۄأًۄأوتزشأصتزأتىزہًڽأڬًأ؏أڬًۄڔۏًڽأڬًأطلتأزۏڽأ؏أځشىزۄأثىتةۏڽأ؏أوشزًڽأڬًأصىزۄأڬشۏڽأۗأتىأڬۏأمًوأوۏڽأضەأڬډہأهًڲًڽأىەأتىأڬۏأحؼهۏوتحأڬتأتىڬتشأڬۏتأتًشأڬډہأهًڲًڽأىەأتىأڬۏأتحثتؼأڬۏأۗأًۄأحًأتههۄأحؼتهۏٳأڬەأثىزەأتًشأتضأڬەأشضًهأحہەأۗأتههۄأحؼتهۏٳأىەأتىأڬەأسشۏؼەأتځىۏأورهًمأڬًأإصوتۏتأحہتأ؏أتًشأتىأهًڲًڽأىەأتضأضەأځۄهەأودہەأۏۄأڬۄتأحہتأڬۄأتەأهڔڬەأ$أثەأطڬأحوۄتشتأتۏڬأشثأۄەأ؏أتًشأحدہەأإرشحأوۏڽأثہۏأدتىتأۄەأ؏أحۏشەأضتوىەأدىحأتًشأزًصرأزًىًڽأۄۏڽأ؏أحوأتىأڬۏأغشلأثڔہأشۄەأۄًأ؏أتًشأۏۄأدًأهًڲأإڲأڬۏأځًدتأڬشحەأۄۏڽأ؏أۏۄأڬتلشأتًشأڲوشتۄأۄۏڽأۗأتههۄأحؼتهۏٳأتىأڬەأؼوهأضەأشتعۏأىۄۏڽأۄەأۗأتًشأىۄأۏۄأضډەأزۏىأځشأۄۏڽأۗأدثأتضأهڔڬەأ+أڬضتىأڬەأثۏټەأ,أڬەأدتىەأڬتأًمحأۄًتأحًأًۄأتټہأڬشأډهأزۏتأ؏أوۏڽأثہۏأتضأڬەأۄوشتۄأډهتأڲۏتأ؏أتڲهەأزىأزًثتشۄأۄوأتىأهًڲًڽأڬەأځتضأڲةەأ؏أتضأزىأثہۏأتىۄًڽأىەأثۄحأتډہۏأتًشأىۏڬأثتحۏڽأڬۏڽأۗأوۏڽأىەأتىأڬۏأودهضأڬًأترحۏتشأڬشأهۏتأ؏أتىأهًڲًڽأىەأودہەأڬۄتأ=أتەأضهوتىأ$أحوأتثہۏأډہًټەأثډەأۄًأ؏أحوأۄوتشۏأغشذأ+أوطمحأًتهۏأ
أؼثتزحأىۄۏڽأڬشأځتاأڲەأ؏أحوأ+أشتحأڬتأڬډہأذظۄأ,أؼثتزحأڬشأهۏتأڬشًأتًشأ+أثتمۏأًمحأ
