{"hadithnumber": "742", "text": "انس بن مالک رضی اللہ عنہ سے روایت ہے کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم کو گدھے پر نماز پڑھتے"}
{"hadithnumber": "743", "text": "براء بن عازب رضی اللہ عنہم کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم مدینہ تشریف لائے تو آپ نے سولہ"}
{"hadithnumber": "744", "text": "عبداللہ بن عمر رضی اللہ عنہم کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم سفر میں اپنی سواری پر نماز پڑ"}
{"hadithnumber": "745", "text": "عبداللہ بن عمر رضی اللہ عنہم کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم سواری پر نماز پڑھتے خواہ وہ ک"}
{"hadithnumber": "746", "text": "عبداللہ بن عمر رضی اللہ عنہم کہتے ہیں کہ  لوگ مسجد قباء میں فجر کی نماز پڑھ رہے تھے کہ اسی دوران ایک"}
{"hadithnumber": "747", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم سے غزوہ تبوک میں نمازی کے"}
{"hadithnumber": "748", "text": "عبداللہ بن عمر رضی اللہ عنہم کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم  ( اپنے سامنے )  نیزہ گاڑتے تھ"}
{"hadithnumber": "749", "text": "سہل بن ابو حثمہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں سے کوئی"}
{"hadithnumber": "750", "text": "عبداللہ بن عمر رضی اللہ عنہم سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم، اسامہ بن زید، بلال اور عث"}
{"hadithnumber": "751", "text": "ابوذر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں سے کوئی کھڑا ہو ک"}
{"hadithnumber": "752", "text": "قتادہ کہتے ہیں کہ  میں نے جابر بن زید سے پوچھا: کون سی چیز نماز کو باطل کر دیتی ہے؟ تو انہوں نے کہا:"}
{"hadithnumber": "753", "text": "عبداللہ بن عباس رضی اللہ عنہم کہتے ہیں:  میں اور فضل دونوں اپنی ایک گدھی پر سوار ہو کر آئے، اور رسول"}
{"hadithnumber": "754", "text": "فضل بن عباس رضی اللہ عنہم کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ہمارے ایک بادیہ میں عباس رضی الل"}
{"hadithnumber": "755", "text": "عبداللہ بن عباس رضی اللہ عنہم بیان کرتے ہیں کہ  وہ اور بنی ہاشم کا ایک لڑکا دونوں رسول اللہ صلی اللہ"}
{"hadithnumber": "756", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  میں رسول اللہ صلی اللہ علیہ وسلم کے سامنے تھی، آپ نماز"}
{"hadithnumber": "757", "text": "بسر بن سعید سے روایت ہے کہ  زید بن خالد نے انہیں ابوجہیم رضی اللہ عنہ کے پاس بھیجا، وہ ان سے پوچھ رہ"}
{"hadithnumber": "758", "text": "ابو سعید خدری رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں سے کوئ"}
{"hadithnumber": "759", "text": "مطلب بن ابی وداعۃ سہمی رضی اللہ عنہ کہتے ہیں:  میں نے رسول اللہ صلی اللہ علیہ وسلم کو دیکھا کہ آپ نے"}
{"hadithnumber": "760", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں:  رسول اللہ صلی اللہ علیہ وسلم رات کو نماز پڑھتے تھے، اور م"}
{"hadithnumber": "761", "text": "ابومرثد غنوی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  نہ تم قبروں کی طرف"}
{"hadithnumber": "762", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  میرے گھر ایک کپڑا تھا جس میں تصویریں تھیں، میں نے اسے گ"}
{"hadithnumber": "763", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے پاس ایک چٹائی تھی جسے آ"}
{"hadithnumber": "764", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  ایک سائل نے رسول اللہ صلی اللہ علیہ وسلم سے ایک کپڑے میں نماز"}
{"hadithnumber": "765", "text": "عمر بن ابوسلمہ رضی اللہ عنہ سے روایت ہے کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم کو ام المؤمنین ام"}
{"hadithnumber": "766", "text": "سلمہ بن الاکوع رضی اللہ عنہ کہتے ہیں کہ  میں نے عرض کیا: اللہ کے رسول! میں شکار پر جاتا ہوں اور میرے"}
{"hadithnumber": "767", "text": "سہل بن سعد رضی اللہ عنہ کہتے ہیں کہ  کچھ لوگ رسول اللہ صلی اللہ علیہ وسلم کے ساتھ بچوں کی طرح اپنا ت"}
{"hadithnumber": "768", "text": "عمرو بن سلمہ رضی اللہ عنہ کہتے ہیں کہ  جب میرے قبیلہ کے لوگ نبی اکرم صلی اللہ علیہ وسلم کے پاس سے لو"}
{"hadithnumber": "769", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم رات کو نماز پڑھتے تھے، اور"}
{"hadithnumber": "770", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم میں سے کوئی ایک کپڑے"}
{"hadithnumber": "771", "text": "عقبہ بن عامر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کو ایک ریشمی قباء ہدیے میں دی گئ"}
{"hadithnumber": "772", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک چادر میں نماز پڑ"}
{"hadithnumber": "773", "text": "ابوحجیفہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم ایک سرخ جوڑے میں نکلے، اور آپ نے"}
{"hadithnumber": "774", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  میں اور رسول اکرم ابوالقاسم صلی اللہ علیہ وسلم دونوں جس"}
{"hadithnumber": "775", "text": "ہمام کہتے ہیں کہ میں نے جریر رضی اللہ عنہ کو دیکھا کہ  انہوں نے پیشاب کیا پھر پانی منگایا، اور وضو ک"}
{"hadithnumber": "776", "text": "ابوسلمہ (ان کا نام سعید بن یزید بصریٰ ہے اور وہ ثقہ ہیں) کہتے ہیں کہ  میں نے انس بن مالک رضی اللہ عن"}
