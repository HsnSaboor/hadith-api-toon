8320,"أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأىثۏأ﷽أىەألشوتۏتأؼتظأثىأًتةهأڬەأزًىًڽأثۏټەأ+أۄطتوأتًشأؼوشًأ,أوًوىأۄۏڽأۗ"
8321,أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأىثۏأ﷽أىەألشوتۏتأدثأحوأوۏڽأضەأڬًةۏأطرظأڬضۏأڬًأوتشەأحًأډۄشەأځشأوتشىەأضەأتدحىتثأڬشەأۗ
8322,أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأىثۏأ﷽أىەألشوتۏتأتضأستحأڬۏأمضوأدضأڬەأزضحأمزشحأوۏڽأوۏشۏأدتىأۄەأحوأهًڲأڲسطحۄأتوحًڽأًتهەأتؼوتهأوۏڽأثتهطحأثتهطحأثہشأتًشأڲصأڲصأثہشأوثحهتأۄًأدتاأڲەأ؏أذحٳۏأڬۄأتڲشأًۄأڬضۏأڲًۄأڬەأضًشترأوۏڽأزترهأۄًةەأۄًڽأڲەأحًأحوأثہۏأزترهأۄًأدتاأڲەأ؏أهًڲًڽأىەأځًډہتأۏتأشضًهأتههۄأ$أًۄأڬًىأهًڲأۄۏڽأآأتۄهأڬحتثأآأىثۏأ﷽أىەألشوتۏتأحًأتًشأڬًىأآ
8323,أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأتۏڬأوشحثۄأىثۏأ﷽أىەأوۏشتأۄتحہأځڬڔأڬشألشوتۏتأتههۄأىەأۄلحۄأڬەأزىأوټۏأڬًأځۏزتألشوتۏتأ؏أتحًتشأڬەأزىأځۄتڔًڽأڬًأ؏أځۏشأڬەأزىأزشرحًڽأڬًأ؏أوىڲهأڬەأزىأىتځضىزۏزۄأتوًشأتًشأثزہأڬەأزىأىًشأڬًأځۏزتأڬۏتأتًشأدوؼشتحأڬەأزىأتضأوۏڽأدتىزتشًڽأڬًأثضتۏتأ؏أدوؼۄأڬەأزىأىوتصأؼظشأڬەأثؼزأذعشحأإزوأؼهۏۄأتهضهتوأڬۏأحرهۏمألشوتةۏأ؏أۏۄأإرشۏأحرهۏمأحہۏأدًأدوؼۄأڬۏأإرشۏأضتؼحًڽأوۏڽأؼظشأتًشأشتحأڬەأزشوۏتىأًدًزأوۏڽأإةۏأۗ
8324,"أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأىثۏأ﷽أتۏڬأتىظتشۏأڬەأڲہشأحطشۏلأهەأدتحەأحہەأ؏أتىأڬەأځۏډہەأثہۏأتۏڬأڲہشأحہتأ؏أتىأهًڲًڽأځشأۏۄأثتحأڲشتڽأڲصشۏأتًشأًۄأڬۄىەأهڲەأۏتأشضًهأتههۄأ$أإځألهتڽأڬەأڲہشأحًأحطشۏلأهتحەأۄۏڽأ؏أۄوتشەأڲہشأحطشۏلأىۄۏڽأهتحەأآأىثۏأ﷽أىەألشوتۏتأتضأڬۏأًدۄأۏۄأۄەأڬۄأحوۄتشەأڲہشأوۏڽأڬحتأۄەأ؏أًۄأڬۄىەأهڲەأڬۄأتىأهًڲًڽأڬەأڲہشأوۏڽأثہۏأحًأثهۏأۄەأ؏أىثۏأ﷽أىەألشوتۏتأثهۏأ+أتۏضتأ,أزشىزۄأۄەأ+أدًأشذوحأڬەألشطحًڽأڬًأإىەأضەأىۄۏڽأشًڬحتأ,"
8325,أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأىثۏأ﷽أىەأحۏىأوشحثۄألشوتۏتأڬًةۏأثۏوتشۏأوحؼزۏأىۄۏڽأۄًحۏأ؏أتۏڬأزۏۄتحۏأڬۄىەأهڲتأڬۄأځہشأتًىټًڽأڬتأڬۏتأوؼتوهۄأۄەأدًأظذشتؤأوۏڽأۄشىًڽأڬۏأغشذأډًڬڔۏتڽأثہشحەأۄۏڽأ؏أتډتىڬأتىأوۏڽأتۏڬأرتشطۏأتًىټأطتوهأۄًأدتحتأۄەأتًشأضثأڬًأرتشطأصزۄأڬشأزۏحتأۄەأآأىثۏأ﷽أىەأڬډہأزۏشأرتوًطأشۄأڬشأتضأضەأځًډہتأڬۄأتضأځۄهەأتًىټأڬًأرتشطأڬۄتڽأضەأهڲۏأآأڬًةۏأثۏوتشۏأوحؼزۏأىۄۏڽأۄًحۏأ؏أظلشأڬتأوۄۏىۄأوىذًضأىۄۏڽأۄًحتأتًشأڬہًځڔۏأضەأڬۏڔتأىڬهىەأڬۏأڬًةۏأذمۏمحأىۄۏڽأۄەأ؏أتههۄأىەأۄشأتىضتىأڬًأځۏزتأڬۏتأۄەأ؏أتًشأتضأڬۏأصىزڲۏأوًحأ؏أوظۏثحأتًشأشصمأضثأهڬہأزۏتأۄەأۗ
8326,أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأتۏڬأإزوۏأىەأثتشڲتۄأشضتهحأ﷽أوۏڽأۏۄأضًتهأځۏطأڬۏتأڬۄأهًڲًڽأوۏڽأؼوزۄأشلتمحأڬتأضثأضەأصۏتزۄأذمزتشأڬًىأۄەأآألشوتۏتأحوۄتشۏأًتهزۄأ؏أتضأىەأځًډہتأتضأڬەأثؼزأڬًىأآألشوتۏتأحوۄتشۏأًتهزۄأ؏أتضأىەأځًډہتأتضأڬەأثؼزأڬًىأآألشوتۏتأحوۄتشۏأًتهزۄأ؏أتضأىەأځًډہتأتضأڬەأثؼزأڬًىأآألشوتۏتأحوۄتشەأًتهزأۗ
8327,أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأىثۏأ﷽أىەألشوتۏتأمۏتوحأڬەأزىأڬتلشأڬۏأتۏڬأڋتڔہأتذزأځۄتڔأڬەأثشتثشأۄًأڲۏأ؏أتًشأتضأڬۏأڬہتهأڬۏأډًڔتةۏأضحشأڲصأۄًأڲۏأ؏أتًشأتضأڬۏأشتىأ““أًشمتىأ‛‛أځۄتڔأڬەأثشتثشأۄًأڲۏأتًشأدۄىوأوۏڽأتضأڬەأثۏټہىەأڬۏأدڲۄأوۏشەأتًشأشثسۄأڬەأزشوۏتىۏألتظهەأدحىۏأۄًأڲۏأۗ
8328,أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأىثۏأ﷽أڬۏأتۏڬأودهضأوۏڽأزًأإزوۏًڽأڬًأډہۏىڬأإةۏأ؏أتىأوۏڽأضەأتۏڬأزًضشەأڬۏأىضثحأصۏتزۄأوؼصصأحہتأ؏أهۏڬىأتضأىەأډہۏىڬەأڬەأثؼزأ““أتهذوزتههۄأ‛‛أىۄۏڽأڬۄتأهۄٳستأىثۏأ﷽أىەأتضەأدًتثأىۄۏڽأزۏتأ؏أتًشأزًضشەأىەأتهذوزتههۄأڬۄتأ؏أهۄستأىثۏأ﷽أىەأتضەأدًتثأزەأزۏتأ؏أًۄأإزوۏأڬۄىەأهڲتأڬۄأودہەأډہۏىڬأإةۏأحًأإځأىەأدًتثأىۄۏڽأزۏتأتًشأتضەأډہۏىڬأإةۏأحًأإځأىەأتضەأدًتثأزەأزۏتأآأىثۏأ﷽أىەألشوتۏتأتضأىەأتههۄأڬًأۏتزأڬۏتأحہتأډىتىډۄأوۏڽأىەأثہۏأتضەأۏتزأشڬہتأتًشأحوأىەأتضەأثہهتأزۏتأهۄستأوۏڽأىەأثہۏأحوۄۏڽأثہهتأزۏتأۗ
8329,أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأىەأتۏڬأوشحثۄأوشًتىأثىأذڬوأڬًأذزۏخأضىتحەأۄًةەألشوتۏتأڬۄأوۏڽأىەأتثًتهمتضوأ““أدًأڬۄأظتزمأًأوظزًمأحہەأ‛‛أ﷽أضەأۏۄأذزۏخأضىۏأۄەأڬۄأوۏشۏأتوحأڬۏأحثتۄۏأمشۏطأڬەأډىزأثۏًمًلأهًىڋًڽأڬەأۄتحہًڽأۄًأڲۏأۗ
8330,أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأىثۏأ﷽أىەألشوتۏتأهًڲًأ$أتههۄأځتڬۏصۄأۄەأتًشأځتڬۏصۄأډۏصًڽأۄۏأڬًأمثًهأڬشحتأۄەأ؏أتًشأتضأىەأؼتوأوضهوتىًڽأڬًأثہۏأًۄۏأذڬوأزۏتأۄەأدًأځۏؽوثشًڽأڬًأزۏتأۄەأ؏أډىتىډۄأتشطتزأۄەأ““أتەأشضًهًأ$أځتڬۏصۄأډۏصۏڽأڬہتاأتًشأىۏڬأتؼوتهأڬشًأ؏أوۏڽأحوۄتشەأتؼوتهأڬًأدتىحتأۄًڽأ‛‛أتًشألشوتۏتأ““أتەأتۏوتىأًتهًأ$أۄوتشۏأزۏأۄًةۏأځتڬۏصۄأډۏصۏڽأڬہتۏتأڬشًأۗ‛‛أځہشأىثۏأ﷽أىەأتۏڬأتۏضەأإزوۏأڬتأسڬشأڬۏتأدًأغًۏهأضلشأڬشأڬەأإۏتأۄًأ؏أتضأڬەأثتهأثڬہشەأۄًةەأۄًڽأ؏أڲشزأًأؽثتشأضەأًۄأتټتأۄًتأۄًأ؏أتًشأإضوتىأڬۏأغشلأۄتحہأتټہتأتټہتأڬشأ““أۏتأشثأ؏أۏتأشثأ‛‛أڬشأشۄتأۄًأ؏أدثڬۄأتضأڬتأڬہتىتأثہۏأذشتوأڬتأۄًأ؏أځۏىتأثہۏأذشتوأڬتأۄًأ؏أهثتضأثہۏأذشتوأڬتأۄًأتًشأتضأڬۏأؽستأثہۏأذشتوأڬۏأۄًأ؏أحًأتضأڬۏأزؼتؤأڬۄتڽأضەأمثًهأۄًأآ
8331,أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأىثۏأ﷽أىەألشوتۏتأتڬۏهەأىوتصأځڔہىەأځشأدوتؼحأڬەأضتحہأىوتصأځڔہىەأڬۏألعۏهحأضحتةۏضأزشدەأصۏتزۄأۄەأۗ
8332,أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأىثۏأ﷽أىەألشوتۏتأدًأوضهوتىأوضدزأڬًأتځىتأًغىأثىتةەأتًشأتضأڬتأومظزأظشلأسڬشأڬشىتأتًشأىوتصأځڔہىتأۄۏأۄًأحًأتههۄأحؼتهۏٳأتضأضەأتۏضەأرًطأۄًحەأۄۏڽأدۏضەأڬضۏأوضتلشأڬەأتځىەأڲہشأځۄىډىەأځشأتضأڬەأتۄهأرتىۄأرًطأۄًحەأۄۏڽأۗ
8333,أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأىثۏأ﷽أىەألشوتۏتأذدشأتضًزأتًشأومتوأتثشتۄۏوأڬەأزشوۏتىأتۏڬأإزوۏأضەأثۏؼحأهۏأدتةەأڲۏأ؏أتًشأثۏحأتههۄأڬۏأذشوحأتضۏأڬەأځتضثتىأځتوتهأڬشۏڽأڲەأ؏أتًشأدثأهًڲأثۏحأتههۄأڬۏأذشوحأڬًأځتوتهأڬشأزۏڽأ؏أځہشأؼشثأڬۏأۄهتڬحأڬەأوحؼهمأضًتهأىۄأڬشىتأ؏أثهڬۄأذثطۏأإةۏڽأڲەأتًشأتضەأتضأغشذأًۏشتىأڬشأزۏڽأڲەأڬۄأزًثتشۄأًۄأڬثہۏأإثتزأىۄأۄًأضڬەأڲتأتًشأۏۄۏأهًڲأتضأڬتأرصتىۄأىڬتهىەأًتهەأۄًڽأڲەأۗ
8334,أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأىثۏأ﷽أڬتأذهۏۄأثۏتىأڬشحەأۄًةەألشوتحەأحہەأڬۄأإځأ﷽أڬەأۄتحہأثہشەأۄًةەأ؏أإىڬہًڽأڬۏأځهڬۏڽأهوثۏأتًشأڲہىۏأتًشأزًىًڽأڬىزہًڽأڬەأزشوۏتىألتظهۄأحہتأ؏أإځأ﷽أځًشۏأغشذأوحًدۄأۄًحەأتًشأځًشۏأغشذأشرأځہۏشحەأ؏أوۏشەأوتڽأثتځأإځأځشأمشثتىأۄًڽأًۄألذطأڲًأۏتأثحڬهلأثەأذۏتؤأىۄأثىحەأحہەأ؏أتًشأىۄأۄۏأثتصتشًڽأوۏڽأطًشأوډتحەأځہشحەأحہەأۗ
8335,أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأىثۏأ﷽أىەألشوتۏتأدثأؼثزأووهًڬأضەأىوتصأڬتأذضتثأۄًأڲتأتًشأتضأوۏڽأڬډہأڬوۏأًتمؼأۄًأڲۏأحًأتضأضەأځًډہتأدتةەأڲتأڬۄأحًأىەأتضأوۏڽأڬًحتۄۏأڬۏًڽأڬۏأآأًۄأؼشعأڬشەأڲتأڬۄأځشًشزڲتشأ$أحًأىەأودہأځشأتۏڬأوتهڬأوضهغأڬشأشڬہتأحہتأدضأىەأودہەأىوتصأضەأشًڬەأشڬہتأ؏أتههۄألشوتةەأڲتأڬۄأوۏڽأىەأحدہەأتضأڬەأوتهأوۏڽأضەأتځىەأهۏەأڬډہأډًشۏأڬشحەأۄًةەأزۏڬہتأحہتأحًأڬۏتأتځىەأهۏەأتضأڬتأؼوهأىۄۏڽأډًشۏأڬشأضڬحتأحہتأآأتضأغشذأتضأځشأذدحأحوتوأۄًأدتةەأڲۏأۗ
8336,أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأىثۏأ﷽أىەألشوتۏتأتىضتىأڬەأۄشأدًڔأځشأظثذأڬەأًمحأظزمۄأًتدثأۄًحتأۄەأ؏أوضهوتىًڽأڬًأۏۄأثتحأثڔۏأوطڬهأوؼهًوأۄًةۏأ؏أىثۏأ﷽أىەألشوتۏتأحوۄتشتأتههۄأڬەأثىزًڽأڬًأضهتوأڬشىتأثہۏأظزمۄأۄەأ؏أشتضحەأضەأحڬهۏلأزۄأډۏصأڬًأۄټتىتأثہۏأظزمۄأۄەأ؏أتوشأثتهوؼشًلأتًشأىۄۏأؼىأتهوىڬشأڬشىتأثہۏأظزمۄأۄەأ؏أتضأڬەأؼهتًۄأثہۏأڬډہأډۏصۏڽأثۏتىألشوتةۏڽأدًأودہەأۏتزأىۄۏڽأشۄۏڽأۗ
8337,أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأوۏڽأىەأىثۏأ﷽أڬًأۏۄألشوتحەأۄًةەأضىتأۄەأزىۏتأوۏڽأحًأًۄۏأطرظأشۏطوأځۄىحتأۄەأدضەأإرشحأوۏڽأتضەأځۄىىەأڬۏأتوۏزأىۄأۄًأ؏أتًشأزىۏتأوۏڽأًۄۏأطرظأشۏطوأځۄىحتأۄەأدضأڬتأإرشحأوۏڽأڬًةۏأذظۄأىۄأۄًأۗ
8338,أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأؽتهثتَأوشلًؼتَأوشًۏأۄەأڬۄأإىڬہأثہۏأصىتأڬشحۏأۄەأتًشأزهأثہۏأ؏أإىڬہًڽأڬتأصىتأزۏڬہىتأۄەأ؏أزهأڬتأصىتأحوىتأتًشأرًتۄطأڬشىتأۄەأدثڬۄأطشوڲتۄأتضأڬۏأحظزۏمأۏتأحڬسۏثأڬشحۏأۄەأۗ
