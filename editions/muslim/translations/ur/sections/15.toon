{"hadithnumber": "2871", "text": "ابو عوانہ نے زید بن جبیر سے حدیث سنا ئی کہا ایک شخص نے ابن عمر رضی اللہ تعالیٰ عنہ  سے پو چھا  :  ای"}
{"hadithnumber": "2872", "text": "مالک نے نافع سے انھوں نے ابن عمر رضی اللہ تعالیٰ عنہ  سے روایت کی کہ اللہ کے رسول اللہ  صلی اللہ علی"}
{"hadithnumber": "2873", "text": "ابن جریج نے کہا  :  میں نے نافع سے پو چھا  :  آپ نے ابن عمر رضی اللہ تعالیٰ عنہ  سے کیا سنا وہ احرا"}
{"hadithnumber": "2874", "text": "لیث بن سعد اور جریر یعنی ابن حا زم نے نا فع سے اسی طرح عبید اللہ ایوب اور یحییٰ بن سعید ان تینوں نے"}
{"hadithnumber": "2875", "text": "محمد بن اسحا ق  نے نافع اور عبید اللہ بن عبد اللہ سے خبر دی انھوں نے ابن عمر رضی اللہ تعالیٰ عنہ  سے"}
{"hadithnumber": "2876", "text": "یحییٰ بن یحییٰ  ، یحییٰ بن ایو ب قتیبہ اور ابن حجر نے اسما عیل بن جعفر سے حدیث بیان کی کہا :  عبد ال"}
{"hadithnumber": "2877", "text": "مجھے عبید اللہ بن عمر قواریری اور ابو ربیع نے حدیث بیان کی  ( دونوں نے کہا  )  ہمیں حما د بن زید نے"}
{"hadithnumber": "2878", "text": "ابن علیہ نے ایوب سے اسی سند کے ساتھ اسی کے مانند روایت کی ۔"}
{"hadithnumber": "2879", "text": "ابن عون نے مجا ہد سے انھوں نے عبد الرحمٰن بن ابی لیلیٰ سے انھوں نے کعب بن عجرہ  رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "2880", "text": "سیف  ( بن سلیمان  )  نے کہا  :  میں نے مجا ہد سے سنا وہ کہہ رہے تھے کہ مجھے عبد الرحمٰن بن ابی لیلیٰ"}
{"hadithnumber": "2881", "text": "ابن ابی نجیح ایوب حمید اور عبد الکریم نے مجا ہد سے انھوں نے ابن ابی لیلیٰ سے انھوں نے کعب بن عجرہ رض"}
{"hadithnumber": "2882", "text": "ابو قلا بہ نے عبد الرحمٰن بن ابی لیلیٰ سے انھوں نے کعب بن عجرہ رضی اللہ تعالیٰ عنہ  سے روایت کی کہ ا"}
{"hadithnumber": "2883", "text": "شعبہ نے عبد الرحمٰن بن اصبہانی سے حدیث بیان کی انھوں نے عبد اللہ بن معقل سے انھوں نے کہا  :  میں کعب"}
{"hadithnumber": "2884", "text": "زکریا بن ابی زائد ہ سے روایت ہے کہا  :  ہمیں عبدالرحٰمن بن اصبہانی نے حدیث بیان کی انھوں نے کہا مجھے"}
{"hadithnumber": "2885", "text": "حضرت ابن عباس رضی اللہ تعالیٰ عنہ  سے روا یت ہے کہ نبی  صلی اللہ علیہ وسلم  نے احرام کی حا لت میں سی"}
{"hadithnumber": "2886", "text": "حضرت ابن بحسینہ رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ نبی  صلی اللہ علیہ وسلم  نے مکہ کے را ستے ہیں اح"}
{"hadithnumber": "2887", "text": "سفیان بن عیینہ نے حدیث بیان کی  ( کہا  )  ہمیں ایوب بن مو سیٰ نے نبیہ بن وہب سے حدیث بیان کی انھوں ن"}
{"hadithnumber": "2888", "text": "ہمیں عبد الصمد بن عبد الوارث نے خبر دی کہا :  مجھ سے میرے والد نے حدیث بیان کی کہا  :  ہم سے  ایوب ب"}
{"hadithnumber": "2889", "text": "سفیان بن عیینہ اور مالک بن انس نے زید بن اسلم سے انھوں نے ابرا ہیم بن عبد اللہ بن حنین سے انھوں نے ا"}
{"hadithnumber": "2890", "text": "ہم سے ابن جریج نے حدیث بیان کی کہا مجھے زید بن اسلم نے اسی سند کے ساتھ خبر دی اور کہا کہ ابواء ایوب"}
{"hadithnumber": "2891", "text": "سفیان بن عیینہ نے عمرو (  بن دینا ر  )  سے  ( انھوں نے )  سعید بن جبیر سے انھوں نے ابن عباس رضی اللہ"}
{"hadithnumber": "2894", "text": "ہمیں عیسیٰ بن یو نس نے خبر دی کہا  : ابن جریج نے کہا  :  مجھے عمرو بن دینا ر نے سعید بن جبیر سے خبر"}
{"hadithnumber": "2895", "text": "محمد بن بکر برسانی نے کہا  :  ہمیں ابن جریج نے عمرو بن دینار سے خبر دی کہ انھیں سعید بن جبیر نے ابن"}
{"hadithnumber": "2896", "text": "سفیان ثوری نے عمرو بن دینار سے انھوں نے سعید بن جبیر سے انھوں نے ابن عباس رضی اللہ تعالیٰ عنہ  سے رو"}
{"hadithnumber": "2897", "text": "ہمیں ابو بشر نے حدیث سنائی کہا  :  ہمیں سعید بن جبیر نے حدیث بیان کی انھوں نے حضر ت ابن عباس رضی الل"}
{"hadithnumber": "2898", "text": "ابو عوانہ نے ابو بشر سے حدیث  سنائی انھوں نے سعید بن جبیر سے انھوں نے حضرت ابن عباس رضی اللہ تعالیٰ"}
{"hadithnumber": "2899", "text": "شعبہ نے کہا  :  میں نے ابو بشر  سے سنا وہ سعید بن جبیر سے حدیث بیان کر رہے تھے انھوں نے ابن عباس رضی"}
{"hadithnumber": "2900", "text": "ابو زبیر نے کہا میں نے سعید بن جبیر کو کہتے ہو ئے سنا کہ ابن عباس رضی اللہ تعالیٰ عنہ  نے کہا  :  ای"}
{"hadithnumber": "2901", "text": "منصور نے سعید بن جبیر سے انھوں نے حضرت ابن عباس رضی اللہ تعالیٰ عنہ  سے روایت کی کہا نبی  صلی اللہ ع"}
{"hadithnumber": "2902", "text": "ابو اسامہ نے ہشام سے انھوں نے اپنے والد  ( عروہ بن زبیر  )  سے انھوں نے حضر عائشہ رضی اللہ تعالیٰ عن"}
{"hadithnumber": "2903", "text": "زہری نے عروہ سے انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے روایت کی انھوں نے کہا  :  نبی  صلی الل"}
{"hadithnumber": "2904", "text": "معمر نے ہشام بن عروہ سے انھوں نے اپنے والد  ( عروہ بن زبیر )  سے انھوں نے حضرت عائشہ رضی اللہ تعالیٰ"}
{"hadithnumber": "2905", "text": "ابو زبیر نے طاوس کو اور ابن عباس رضی اللہ تعالیٰ عنہ  کے آزاد کردہ غلام عکرمہ کو ابن عباس رضی اللہ ت"}
{"hadithnumber": "2906", "text": "عمرو بن ہرم نے سعید بن جبیر اور عکرمہ سے انھوں نے حضرت ابن عباس رضی اللہ تعالیٰ عنہ  سے روایت کی ضبا"}
{"hadithnumber": "2907", "text": "ہمیں اسحاق بن ابرا ہیم ابو ایوب غیلا نی اور احمد بن خراش نے حدیث بیان کی  ۔  ۔  ۔ اسھاق نے کہا  :  ہ"}
{"hadithnumber": "2908", "text": "حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے روایت ہے انھوں نے بیان کیا کہ ذوالحلیفہ کے مقام پر واقع )  درخت"}
{"hadithnumber": "2909", "text": "جعفر  ( صادق  ) نے اپنے والد محمد  ( باقر بن علی زین العابدین بن حسین بن علی  رضی اللہ تعالیٰ عنہ  )"}
{"hadithnumber": "2910", "text": "مالک نے ابن شہاب سے انھوں نے عروہ سے انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے روایت کی  ، انھوں"}
{"hadithnumber": "2911", "text": "عقیل بن خالد نے ابن شہاب سے انھوں نے عروہ بن زبیر سے انھوں نے رسول اللہ  صلی اللہ علیہ وسلم  کی زوجہ"}
{"hadithnumber": "2912", "text": "معمر نے زہری سے انھوں نے عروہ سے انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے روایت کی انھوں نے کہا"}
{"hadithnumber": "2913", "text": "سفیان نے زہری سے انھوں نے عروہ سے انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے روایت کی انھوں نے کہ"}
{"hadithnumber": "2914", "text": "عبدہ بن سلمیان نے ہشام سے انھوں نے اپنے والد ( عرو  )  \\n\\nسے انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عنہا"}
{"hadithnumber": "2915", "text": "ابن نمیر نے ہشام سے سابقہ سند کے ساتھ روایت کی حضرت عائشہ رضی اللہ تعالیٰ عنہا   نے کہا  :  ہم رسول"}
{"hadithnumber": "2916", "text": "وکیع نے ہشام سے سابقہ سند کے ساتھ حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے روایت کی انھوں نے کہا  : ہم"}
{"hadithnumber": "2917", "text": "محمد بن عبد الرحمٰن بن نوفل نے عروہ سے انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے روایت کی انھوں"}
{"hadithnumber": "2918", "text": "قاسم نے اپنے والد  ( محمد بن ابی بکر )  سے انھوں نے حضرت عائشہ  رضی اللہ تعالیٰ عنہا  سے حدیث بیان ک"}
{"hadithnumber": "2919", "text": "عبد الرحمٰن ابن سلمہ ماجثون نے عبد الرحمٰن بن قاسم سے انھوں نے اپنے والد  ( قاسم  )  سے انھوں نے حضر"}
{"hadithnumber": "2920", "text": "حماد  ( بن سلمہ )  نے عبد الرحمٰن سے حدیث بیان کی انھوں نے اپنے والد  ( قاسم  )  سے انھوں نے حضرت عا"}
{"hadithnumber": "2921", "text": "مالک نے عبد الرحمٰن بن قاسم سے انھوں نے اپنے والد  ( قاسم  )  سے انھوں نے حضرت عائشہ رضی اللہ تعالیٰ"}
{"hadithnumber": "2922", "text": "افلح بن حمید نے قاسم سے انھوں نے عائشہ رضی اللہ تعالیٰ عنہا   سے روایت کی انھوں نے کہا :  ہم حج کا ت"}
{"hadithnumber": "2923", "text": "عبید اللہ بن عمرنے قاسم بن محمد سے حدیث بیان کی  ، انھوں نے ام المومنین حضرت عائشہ رضی اللہ تعالیٰ ع"}
{"hadithnumber": "2924", "text": "قاسم بن محمد سے روایت ہے کہ حضرت عائشہ  رضی اللہ تعالیٰ عنہا   ( صرف  )  حج کےلئے آئیں تھیں"}
{"hadithnumber": "2925", "text": "یحییٰ بن سعید نے عمرہ سے روایت کی  ،  انھوں نے کہا  :  میں نے حضرت عائشہ رضی اللہ تعالیٰ عنہا  سے سن"}
{"hadithnumber": "2926", "text": "عبد الوہاب اور سفیان بن عیینہ نے یحییٰ سے اسی سند کے ساتھ اسی طرح حدیث بیان کی  ،"}
{"hadithnumber": "2927", "text": "ابرا ہیم نے اسود اور قاسم سے ان دونوں نے ام المومنین  رضی اللہ تعالیٰ عنہا   سے روایت کی ،  ام الموم"}
{"hadithnumber": "2928", "text": "ابن ابی عدی نے ابن عون سے حدیث بیان کی  ، انھوں نے قاسم اور ابرا ہیم سے روایت کی  ( ابن عون نے  ) کہ"}
{"hadithnumber": "2929", "text": "منصور نے ابرا ہیم سے ، انھوں نے اسود سے انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے حدیث بیان کی"}
{"hadithnumber": "2930", "text": "اعمش نے ابرا ہیم  سے ،  انھوں نے اس3ود کے واسطے سے حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے روایت کی ،"}
{"hadithnumber": "2931", "text": "محمد بن جعفر  ( غندر )  نے کہا  :  ہمیں شعبہ نے حکم سے حدیث بیان کی  ، انھوں نے  ( زین العابدین  )"}
{"hadithnumber": "2932", "text": "عبید اللہ بن معاذ نے کہا  :  مجھے میرے والد نے شعبہ سے باقی ماندہ سابقہ سند کے ساتھ حدیث بیان کی  ،"}
{"hadithnumber": "2933", "text": "طاوس نے سیدہ عائشہ رضی اللہ تعالیٰ عنہا   سے روایت کی کہ انھوں نے عمرے کا تلبیہ پکارا تھا مکہ پہنچیں"}
{"hadithnumber": "2934", "text": "مجا ہد نے حضرت عا ئشہ سے روایت کی کہ انھیں مقام سرف سے ایام شروع ہو ئے پھر وہ عرفہ میں جا کر پاک ہو"}
{"hadithnumber": "2935", "text": "صفیہ بنت شیبہ نے بیان کیا  ، کہا حضرت عائشہ رضی اللہ تعالیٰ عنہا   نے عرض کی  :  اے اللہ کے رسول  صل"}
{"hadithnumber": "2936", "text": "عمرو بن اوس نے خبر دی کہ عبد الرحمٰن بن ابی بکر رضی اللہ تعالیٰ عنہ  نے انھیں کہا کہ نبی  صلی اللہ ع"}
{"hadithnumber": "2937", "text": "قتیبہ نے کہا  :  ہم سے لیث نے حدیث بیان کی ، انھوں نے ابو زبیر سے انھوں نے حضرت جا بر رضی اللہ تعالی"}
{"hadithnumber": "2938", "text": "ابن جریج نے خبر دی کہا :  مجھے ابو زبیر نے خبر دی  ، انھوں نے جا بر بن عبد اللہ  رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "2939", "text": "مطر نے ابو زبیر سے  ،  انھوں نے جا بر بن عبد اللہ رضی اللہ تعالیٰ عنہ  سے روایت کی کہ نبی  صلی اللہ"}
{"hadithnumber": "2940", "text": "زہیر اور ابو خیثمہ نے ابو زبیر سے  ،  انھوں نے جا بر  رضی اللہ تعالیٰ عنہ  سے روایت کی کہا  :  ہم رس"}
{"hadithnumber": "2941", "text": "ابن جریج سے روایت ہے  ( کہا :   )   مجھے ابو زبیر نے جا بربن عبد اللہ  رضی اللہ تعالیٰ عنہ  سے خبر د"}
{"hadithnumber": "2942", "text": "یحییٰ بن سعید اور عبد بن حمید نے محمد بن بکر کے واسطے سے ابن جریج سے حدیث بیان کی  ، کہا  :  مجھے اب"}
{"hadithnumber": "2943", "text": "ابن جریج نے کہا  : مجھے عطا ء نے خبر دی کہ میں نے اپنے متعدد فقاء کے ساتھ جا بر بن عبداللہ  رضی اللہ"}
{"hadithnumber": "2944", "text": "عبد الملک بن ابی سلیمان نے عطا ء سے انھوں نے جابر بن عبداللہ  رضی اللہ تعالیٰ عنہ  سے روایت کی کہا"}
{"hadithnumber": "2945", "text": "موسیٰ بن نافع نے کہا :  میں عمرے کی نیت سے یو م ترویہ  ( آٹھ ذوالحجہ  )  سے چار دن پہلے مکہ پہنچا لو"}
{"hadithnumber": "2946", "text": "ابو بشر نے عطاء بن ابی رباح سے انھوں نے جا بر بن عبد اللہ  رضی اللہ تعالیٰ عنہ سے روایت  کی کہا  :"}
{"hadithnumber": "2947", "text": "شعبہ نے کہا : میں نے قتادہ سے سنا ، وہ ابو نضرہ سے حدیث بیان کررہے تھے ، کہا : ابن عباس رضی اللہ تعا"}
{"hadithnumber": "2948", "text": "ہمیں ہمام نے حدیث سنائی ، انھوں نے کہا : ہمیں قتادہ  نے اسی  ( مذکورہ بالا )  سندسے حدیث بیا ن کی  ،"}
{"hadithnumber": "2949", "text": "مجاہد نے جابر بن عبداللہ  رضی اللہ تعالیٰ عنہ  سے حدیث بیا ن کی ، کہا : ہم رسول اللہ صلی اللہ علیہ و"}
{"hadithnumber": "2950", "text": "ہم سے حاتم بن اسماعیل مدنی نے جعفر  ( الصادق  )  بن محمد  ( الباقرؒ ) سے ، انھوں نےاپنے والد سے ر وا"}
{"hadithnumber": "2951", "text": "عمر بن حفص بن غیاث نے بیان کیا : مجھے میرے والد ( حفص بن غیاث )  نے حدیث بیان کی ،  ( کہا :  )  ہمیں"}
{"hadithnumber": "2952", "text": "حضرت جعفر ؒ نے اسی سند کے ساتھ حدیث بیان کی ،  ( کہا :  ) مجھے میرے والد نے جابر  رضی اللہ تعالیٰ عن"}
{"hadithnumber": "2953", "text": "سفیان ( ثوری )  نے جعفر بن محمد سے ، انھوں نے اپنے والد سے ، انھوں نے سابقہ سند کے ساتھ جابر بن عبدا"}
{"hadithnumber": "2954", "text": "ام المؤمنین عائشہ صدیقہ رضی اللہ عنہا سے روایت ہے کہ انہوں نے کہا کہ قریش اور وہ لوگ جو قریش کے دین"}
{"hadithnumber": "2955", "text": "ابو اسامہ نے کہا ، ہمیں ہشام نے اپنے والد سے بیان کیا ، کہا : حمس ( کہلانے والے قبائل )  کے علاوہ عر"}
{"hadithnumber": "2956", "text": "حمد بن جبیر بن معطم نے اپنے والد حضرت جبیر بن معطم  رضی اللہ تعالیٰ عنہ  سے حدیث بیان کی ، انھوں نے"}
{"hadithnumber": "2957", "text": "سیدنا ابوموسیٰ رضی اللہ عنہ کہتے ہیں کہ میں رسول اللہ صلی اللہ علیہ وسلم کے پاس آیا ،  اور آپ صلی ال"}
{"hadithnumber": "2958", "text": "معاذ بن معاذ نے کہا : ہمیں شعبہ نے اسی سندسے اسی کے مانند حدیث بیان کی ۔"}
{"hadithnumber": "2959", "text": "سفیان ثوری نے قیس ( بن مسلم )  سے  ، انھوں نے طارق بن شہاب سے ، انھوں نے حضرت ابو موسیٰ  رضی اللہ تع"}
{"hadithnumber": "2960", "text": "ابو عمیس نے ہمیں قیس بن مسلم سے خبر دی ، انھوں نے طارق بن شہاب سے  ، انھوں نے حضرت ابو موسیٰ اشعری ر"}
{"hadithnumber": "2961", "text": "ابراہیم بن ابی موسیٰ نے حضرت موسیٰ اشعری  رضی اللہ تعالیٰ عنہ  سے روایت کی کہ وہ حج تمتع  ( کرنے )"}
{"hadithnumber": "2962", "text": "محمد بن جعفر نے کہا : ہمیں شعبہ نے قتادہ سے حدیث بیان کی ، کہا : عبداللہ بن شقیق نے بیان کیا : عثمان"}
{"hadithnumber": "2963", "text": "خالد ، یعنی ابن حارث نے ہمیں حدیث بیان کی ، ہمیں شعبہ نے اسی سند کے ساتھ اسی ( مذکورہ بالا حدیث )  ک"}
{"hadithnumber": "2964", "text": "عمرو بن مرہ نے سعید بن مسیب سے روایت کی ، کہا :  ( ایک مرتبہ )  مقام عسفان پر حضرت علی رضی اللہ تعال"}
{"hadithnumber": "2965", "text": "اعمش نے ابراہیم تیمی سے ، انھوں نے اپنے والد ( یزید بن شریک )  سے  ، انھوں نے حضرت ابوذر رضی اللہ تع"}
{"hadithnumber": "2966", "text": "عیاش عامری نے ابراہیم تیمی سے ، انھوں نے اپنے والد ( یزید بن شریک )  سے ، انھوں نے ابو زر رضی اللہ ت"}
{"hadithnumber": "2967", "text": "زبید نے ابراہیم تیمی سے ، انھوں نے اپنے والد سے روایت کی  ، کہا : ابوذر رضی اللہ تعالیٰ عنہ  نے فرما"}
{"hadithnumber": "2968", "text": "ہمیں قتیبہ نے حدیث بیان کی ،  ( کہا :  ) ہمیں جریر نے بیان سے ، انھوں نے عبدالرحمان بن ابی شعشاء سے"}
{"hadithnumber": "2969", "text": "مروان بن معاویہ نے کہا : ہمیں سلیمان تیمی نے غنیم بن قیس سے خبر دی ، انھوں نے کہا : میں نے سعد بن اب"}
{"hadithnumber": "2970", "text": "یحییٰ بن سعید نے سلیمان تیمی سے اسی سند کے ساتھ روایت کی اور اپنی روایت میں کہا : ان کی مرادحضرت معا"}
{"hadithnumber": "2971", "text": "سفیان اورشعبہ دونوں نے سلیمان تیمی سے اسی سندکے ساتھ ان دونوں ( مروان اور یحییٰ )  کی حدیث کی طرح حد"}
{"hadithnumber": "2972", "text": "ہمیں اسماعیل بن ابراہیم نے حدیث بیا ن کی ،  ( کہا :  ) ہمیں جریری نے حدیث سنائی ، انھوں نے ابو العلا"}
{"hadithnumber": "2973", "text": "اسحاق بن ابراہیم اور محمد بن حاتم دونوں نے وکیع سے یہ حدیث بیا ن کی ( کہا :  )  ہمیں سفیان نے جریری"}
{"hadithnumber": "2974", "text": "ہمیں معاذ نے حدیث بیان کی ،  ( کہا :  )  ہمیں شعبہ نے حمید بن ہلال سے ، انھوں نے مطرف سے رویت کی ، ا"}
{"hadithnumber": "2975", "text": "محمد بن جعفر نے ہمیں حدیث بیان کی ،  ( کہا ) ہمیں شعبہ نے حدیث سنائی  ، انھوں نے حمید بن ہلال سے روا"}
{"hadithnumber": "2976", "text": "قتادہ نے مطرف سے روایت کی ،  کہا  :  جس مرض میں عمرا ن بن حصین رضی اللہ تعالیٰ عنہ  کی وفا ت ہو ئی"}
{"hadithnumber": "2977", "text": "ہمیں سعید بن ابی عروبہ نے قتادہ سے حدیث بیان کی  ، انھوں نے مطرف بن عبد اللہ بن شخیر سے انھوں نے عمر"}
{"hadithnumber": "2980", "text": "بشر بن مفضل نے ہمیں حدیث بیان کی  ،  ( کہاJ ہمیں عمرا ن بن مسلم نے ابو رجاء سے روایت کی ،  کہ عمرا ن"}
{"hadithnumber": "2981", "text": "یحییٰ بن سعید نے ہمیں عمرا ن قصیر سے حدیث سنا ئی  ( انھوں نے کہا  :  )  ہمیں ابو رجاء نے عمرا ن بن ح"}
{"hadithnumber": "2982", "text": "سالم بن عبد اللہ سے روایت ہے کہ عبد اللہ بن عمر رضی اللہ تعالیٰ عنہ  نے کہا  : حجۃ الوداع کے موقع پر"}
{"hadithnumber": "2983", "text": "ابن شہاب نے عروہ بن زبیر سے روایت کی کہ رسول اللہ  صلی اللہ علیہ وسلم کی زوجہ ام المومنین حضرت عائشہ"}
{"hadithnumber": "2984", "text": "یحییٰ بن یحییٰ نے کہا  :  میں نے امام مالک کے سامنے پڑھا  ، انھوں نے نافع سے روایت کی ،  انھوں نے عب"}
{"hadithnumber": "2985", "text": "خالد بن مخلد نے مالک سے ، انھوں نے نافع سے انھوں نے ابن عمر رضی اللہ تعالیٰ عنہ  سے ، انھوں نے حضرت"}
{"hadithnumber": "2986", "text": "عبید اللہ نے کہا  : مجھے نافع نے ابن عمر رضی اللہ تعالیٰ عنہ  سے انھوں نے حضرت حفصہ رضی اللہ تعالیٰ"}
{"hadithnumber": "2987", "text": "عبید اللہ نے نافع سے انھوں نے ابن عمر رضی اللہ تعالیٰ عنہ  سے روایت کی کہ حضرت حفصہ  رضی اللہ تعالیٰ"}
{"hadithnumber": "2988", "text": "ابن جریج نے نافع سے انھوں نے ابن عمر رضی اللہ تعالیٰ عنہ  سے روایت کی ،  انھوں نے کہا  :  مجھے حضرت"}
{"hadithnumber": "2989", "text": "یحییٰ بن یحییٰ نے کہا  :  میں نے امام مالک کے سامنے  ( حدیث کی )  قراءت کی ،  انھوں نے نافع سے روایت"}
{"hadithnumber": "2990", "text": "عبید اللہ سے روایت ہے کہا :  مجھے نافع نے حدیث بیان کی کہ جس سال حجاج بن یوسف نے حضرت ابن زبیر  رضی"}
{"hadithnumber": "2991", "text": "ابن نمیر نے ہمیں حدیث سنائی ،  ( کہا :  )  ہمیں میرے والد ( عبداللہ )  نے عبیداللہ سے ،  انھوں نے نا"}
{"hadithnumber": "2992", "text": "محمد بن رمح اورقتیبہ نے لیث سے ، انھوں نے نافع سے روایت کی کہ جس سال حجاج بن یوسف ، ابن سال  حضرت اب"}
{"hadithnumber": "2993", "text": "ایوب نے نافع سے ، انھوں نے ابن عمر  رضی اللہ تعالیٰ عنہ  سے یہی قصہ روایت کیا ہے ، البتہ انھوں نے نب"}
{"hadithnumber": "2994", "text": "یحییٰ بن ایوب اور عبداللہ بن عون ہلالی نے حدیث بیان کی ،  ( کہا :  )  ہمیں عباد بن عباد مہلبی نے حدی"}
{"hadithnumber": "2995", "text": "حمید نے بکر سے حدیث بیان کی ، انھوں نے حضرت انس رضی اللہ تعالیٰ عنہ  سے روایت کی ، انھوں نے کہا : می"}
{"hadithnumber": "2996", "text": "حبیب  بن شہید نے بکر بن عبداللہ سے روایت کی ،  ( کہا :  )  ہمیں حضرت انس رضی اللہ تعالیٰ عنہ  نے حدی"}
{"hadithnumber": "2997", "text": "اسماعیل بن ابی خالد نے وبرہ سے روایت کی  ، کہا :  میں حضرت ابن عمر  رضی اللہ تعالیٰ عنہ  کے پاس بیٹھ"}
{"hadithnumber": "2998", "text": "بیان نے وبرہ سے روایت کی  ، کہا : ایک شخص نے سیدنا ابن عمر رضی اللہ تعالیٰ عنہ  سے سوال کیا : میں نے"}
{"hadithnumber": "2999", "text": "سفیان بن عینیہ نے عمرو بن دینار سے حدیث بیان کی   ، کہا : ہم نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے"}
{"hadithnumber": "3000", "text": "حماد بن زید اور ابن جریج دونوں نے عمرو بن دینار کے واسطے سے حضرت ابن عمر رضی اللہ تعالیٰ عنہ   سے ،"}
{"hadithnumber": "3001", "text": "محمد بن عبدالرحمان سے روایت ہے کہ ایک عراقی شخص نے ان سے کہا : میری  طرف سے عروہ بن زبیر رضی اللہ تع"}
{"hadithnumber": "3002", "text": "ابن جریج نے کہا : مجھے منصور بن عبدالرحمان نے اپنی والدہ صفیہ بنت شیبہ سے حدیث بیان کی ، انھوں نے حض"}
{"hadithnumber": "3003", "text": "وہیب نے کہا : ہمیں منصور بن عبدالرحمان نے اپنی والدہ ( صفیہ بنت شیبہ )  سے ، انھوں نے حضرت اسماء رضی"}
{"hadithnumber": "3004", "text": "ہمیں ہارون بن سعید ایلی اور احمد بن عیسیٰ نے حدیث بیان کی ، کہا : ہمیں ابن وہب نے حدیث بیا ن کی ،  ("}
{"hadithnumber": "3005", "text": "شعبہ نے مسلم قری سے روایت کی ، انھوں نے کہا : میں نے حضرت ابن عباس  رضی اللہ تعالیٰ عنہ  سے حج تمتع"}
{"hadithnumber": "3006", "text": "عبدالرحمان اور محمد بن جعفر دونوں نے اسی سند کے ساتھ شعبہ سے روایت کی ، ان میں سے عبدالرحمان کی حدیث"}
{"hadithnumber": "3007", "text": "معاذ ( بن معاذ )  نے ہمیں شعبہ سے حدیث سنائی ،  ( کہا :  )  مسلم قریؒ نے ہمیں حدیث سنائی ، انھوں نے"}
{"hadithnumber": "3008", "text": "محمد ، یعنی ابن جعفر نے ہمیں حدیث بیان کی ،  ( کہا :  )  ہمیں شعبہ نے اسی سند کے ساتھ حدیث سنائی ، ا"}
{"hadithnumber": "3009", "text": "عبداللہ بن طاوس نے اپنے والد طاوس بن کیسان سے ، انھوں نےحضرت ابن عباس  رضی اللہ تعالیٰ عنہ  سے روایت"}
{"hadithnumber": "3010", "text": "نصر بن علی جحضمی نے ہمیں حدیث سنائی ،  ( کہا :  )  میرے والد نے ہمیں حدیث سنائی ،  ( کہا :  )  شعبہ"}
{"hadithnumber": "3011", "text": "یہی حدیث روح  ، ابو شہاب اور یحییٰ بن کثیر ان تمام نے شعبہ سے اسی سند سے روایت کی ،  روح اور یحییٰ ب"}
{"hadithnumber": "3012", "text": "ہمیں وہیب نے حدیث سنا ئی  ،  ( کہا ) ہمیں ایو ب نے حدیث سنا ئی انھوں نے ابو عالیہ برا ء سے انھوں نے"}
{"hadithnumber": "3013", "text": "معمر نے ہمیں ہمیں خبردی انھوں نے ایوب سے انھوں نے ابو عالیہ سے انھوں نے ابن عباس رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "3014", "text": "محمد بن جعفر نے اور عبید اللہ بن معاذ نے اپنے والد کے واسطے سے حدیث بیان کی ۔  ۔  ۔ لفظ عبید اللہ کے"}
{"hadithnumber": "3015", "text": "ابو حمزہ ضبعی نے کہا  :  میں نے حج تمتع  ( کا ارادہ )  کیا تو  (  متعدد )  لوگوں نے مجھے اس سے روکا"}
{"hadithnumber": "3016", "text": "شعبہ نے قتادہ سے انھوں نے ابو حسان سے انھوں نے ابن عباس رضی اللہ تعالیٰ عنہ  سے روایت کی فر ما یا  :"}
{"hadithnumber": "3017", "text": "معاذ بن ہشام نے کہا  :  مجھے میرے والد  ( ہشام بن ابی عبد اللہ صاحب الدستوائی  )  نے قتادہ سے اسی سن"}
{"hadithnumber": "3018", "text": "شعبہ نے قتادہ سے حدیث بیان کی  ، کہا :  میں نے ابو حسان اعرج سے سنا ،  انھوں نے کہا بنو حجیم  کے ایک"}
{"hadithnumber": "3019", "text": "ہمام بن یحییٰ نے قتادہ سے ،  انھوں ے ابو حسان سے حدیث بیان کی ،  کہا ابن عباس رضی اللہ تعالیٰ عنہ  س"}
{"hadithnumber": "3020", "text": "ابن جریج نے کہا  :  مجھے عطا ء نے خبر دی کہ حضرت ابن عباس رضی اللہ تعالیٰ عنہ  فر مایا کرتے تھے  :"}
{"hadithnumber": "3021", "text": "ہشام بن حجیر نے طاوس سے روایت کی  ، کہا :  حضرت ابن عباس رضی اللہ تعالیٰ عنہ  نے ذکر کیا کہ مجھے معا"}
{"hadithnumber": "3022", "text": "حسن بن مسلم نے طاوس سے انھوں نے ابن عباس رضی اللہ تعالیٰ عنہ  سے روایت کی کہ حضرت معاویہ ابی سفیان ر"}
{"hadithnumber": "3024", "text": "وہیب بن خا لد نے داود سے انھوں نے ابو نضرہ سے انھوں نے جابر اور ابو خدری رضی اللہ تعالیٰ عنہ  سے حدی"}
{"hadithnumber": "3025", "text": "ابو نضر ہ سے روایت ہے کہا :  میں جابر بن عبد اللہ  رضی اللہ تعالیٰ عنہ  کی  خدمت میں موجود تھا کہ ای"}
{"hadithnumber": "3026", "text": "( عبد الرحمٰن  )  بن مہدی نے ہمیں حدیث سنا ئی  ( کہا )  مجھے سلیم بن حیا ن نے مروان اصغر سے حدیث سنا"}
{"hadithnumber": "3027", "text": "عبد الصمد اور بہزدونوں نے کہا  :  ہمیں سلیم بن حیان نے اسی سند کے ساتھ اسی کی طرح حدیث بیان کی  ،  ا"}
{"hadithnumber": "3030", "text": "سفیان بن عیینہ نے ہمیں حدیث بیان کی ،   ( کہا  )  مجھے زہری نے حنظلہ اسلمی کے واسطے سے حدیث بیان کی"}
{"hadithnumber": "3031", "text": "لیث نے ابن شہاب سے اسی سند کے ساتھ اسی کے مانند روایت بیان کی ،  ( اس میں ہے کہ آپ  صلی اللہ علیہ وس"}
{"hadithnumber": "3032", "text": "یو نس نے مجھے ابن شہاب سے خبر دی انھوں نے حنظلہ بن علی اسلمی سے روایت کی کہ انھوں نے ابو ہریرہ رضی ا"}
{"hadithnumber": "3033", "text": "ہذاب بن خالد نے ہمیں حدیث سنا ئی  ( کہا )  ہمیں ہمام نے حدیث بیان کی  ، انھوں نے کہا )  ہمیں قتادہ ن"}
{"hadithnumber": "3034", "text": "محمد بن مثنیٰ نے ہمیں حدیث بیان کی  ،  ( کہا :  )  مجھے عبد الصمد نے حدیث سنا ئی  ( کہا  )  ہمیں ہما"}
{"hadithnumber": "3035", "text": "ابو اسحاق سے روایت ہے کہا  :  میں نے زید بن را قم  رضی اللہ تعالیٰ عنہ  سے پو چھا  :  آپ نے رسول الل"}
