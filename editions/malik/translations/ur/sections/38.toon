{"hadithnumber": "1464", "text": "امام مالک رحمہ اللہ نے ابن شہاب رحمہ اللہ کو یہ کہتے ہوئے سنا کہ حضرت عمر بن خطاب رضی اللہ عنہ کے دو"}
{"hadithnumber": "1465", "text": "سعید بن عمرو بن شُرَحْبیل بن سعید بن سعد بن عبادہ رحمہ اللہ اپنے والد ( عمرو رحمہ اللہ ) سے اور وہ ا"}
{"hadithnumber": "1466", "text": "سیدہ عائشہ رضی اللہ عنہا زوجہ پیغمبر ﷺ سے روایت ہے کہ ایک آدمی نے رسول اللہ ﷺ سے عرض کیا : بے شک میر"}
{"hadithnumber": "1467", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ انصار کے خاندان بنوحارث بن خزرج کے ایک شخص ( حضرت عبداللہ بن"}
{"hadithnumber": "1468", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ بے شک رسول اللہ ﷺ نے فرمایا :’’ کسی ایسے مسلمان کے"}
{"hadithnumber": "1469", "text": "عمرو بن سلیم زرقی سے روایت ہے کہ بے شک عمر بن خطاب رضی اللہ عنہ سے کہا گیا کہ یقیناً یہاں ( مدینہ می"}
{"hadithnumber": "1470", "text": "ابوبکر بن حزم رحمہ اللہ سے روایت ہے کہ غسّان قبیلے کے ایک لڑکے کو مدینہ منورہ میں موت کا وقت آ گیا ،"}
{"hadithnumber": "1471", "text": "حضرت سعد بن ابی وقاص رضی اللہ عنہ سے روایت ہے ، کہتے ہیں کہ رسول اللہ ﷺ حجۃ الوداع والے سال میرے پاس"}
{"hadithnumber": "1472", "text": "ہشام بن عروہ رحمہ اللہ اپنے والد ( عروہ بن زبیر رضی اللہ عنہ ) سے روایت کرتے ہیں کہ بے شک سیدہ ام سل"}
{"hadithnumber": "1473", "text": "قاسم بن محمد رحمہ اللہ ( بن ابی بکر رضی اللہ عنہ ) سے روایت ہے ، کہتے ہیں : حضرت عمر بن خطاب رضی الل"}
{"hadithnumber": "1474", "text": "یحیی بن سعید رحمہ اللہ سے روایت ہے کہ بے شک ( ملکِ شام کے قاضی ) حضرت ابودرداء رضی اللہ عنہ نے حضرت"}
{"hadithnumber": "1475", "text": "عمر بن عبدالرحمن بن دلاف مزنی رحمہ اللہ سے روایت ہے ( وہ اپنے والد سے روایت کرتے ہیں ) کہ بیشک جہینہ"}
{"hadithnumber": "1476", "text": "سعید بن مسیب رحمہ اللہ سے روایت ہے کہ بے شک حضرت عثمان بن عفان رضی اللہ عنہ نے فرمایا : جس شخص نے اپ"}
{"hadithnumber": "1477", "text": "یحیی بن سعید رحمہ اللہ سے روایت ہے ، انھیں یہ خبر پہنچی کہ بیشک حضرت معاویہ بن ابی سفیان رضی اللہ عن"}
{"hadithnumber": "1478", "text": "قبیصہ بن ذؤیب رحمہ اللہ سے روایت ہے کہ بے شک حضرت عمر بن خطاب رضی اللہ عنہ نے دادے کے لیے وہ مقرر ح"}
{"hadithnumber": "1479", "text": "سلیمان بن یسار رحمہ اللہ سے روایت ہے ، انھوں نے کہا : حضرت عمر بن خطاب ، حضرت عثمان بن عفّان اور حضر"}
{"hadithnumber": "1480", "text": "قبیصہ بن ذؤیب رحمہ اللہ سے روایت ہے کہ ایک جدہ ( ماں کی ماں یعنی نانی ) حضرت ابوبکر صدیق رضی اللہ ع"}
{"hadithnumber": "1481", "text": "قاسم بن محمد رحمہ اللہ ( بن ابی بکر صدیق رضی اللہ عنہ ) سے روایت ہے کہ دو جدہ ( نانی اور دادی ) حضرت"}
{"hadithnumber": "1482", "text": "عبدربہ بن سعید رحمہ اللہ سے روایت ہے کہ بے شک ابوبکر بن عبدالرحمن بن حارث بن ہشام رحمہ اللہ ( جو کہ"}
{"hadithnumber": "1483", "text": "زید بن اسلم رحمہ اللہ سے روایت ہے کہ بیشک حضرت عمر بن خطاب رضی اللہ عنہ نے رسول اللہ ﷺ سے کلالہ کے م"}
{"hadithnumber": "1484", "text": "قریش کے ایک مولیٰ ( یعنی آزاد کردہ غلام یا حلیف ) سے روایت ہے جو کہ قدیم ( عمر رسیدہ اور بزرگ ) تھا"}
{"hadithnumber": "1485", "text": "محمد بن ابی بکر بن حزم رحمہ اللہ سے روایت ہے ، انھوں نے اپنے والد ( ابوبکر بن محمد بن عمرو بن حزم رح"}
{"hadithnumber": "1486", "text": "حضرت اسامہ بن زید رضی اللہ عنہ سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ نے فرمایا :’’ مسلمان شخص کافر کا وا"}
{"hadithnumber": "1487", "text": "علی ( زین العابدین رحمہ اللہ ) بن حسین رضی اللہ عنہ بن علی رضی اللہ عنہ بن ابی طالب سے روایت ہے کہ ب"}
{"hadithnumber": "1488", "text": "سلیمان بن یسار رحمہ اللہ سے روایت ہے کہ بے شک محمد بن اشعث رحمہ اللہ نے انھیں خبر دی کہ ان کی ایک عی"}
