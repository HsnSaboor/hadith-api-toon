{"hadithnumber": "1867", "text": "ہم سے ابوالنعمان نے بیان کیا، ان سے ثابت بن یزید نے بیان کیا، ان سے ابوعبدالرحمٰن احول عاصم نے بیان"}
{"hadithnumber": "1868", "text": "ہم سے ابومعمر نے بیان کیا، کہا ہم سے عبدالوارث نے بیان کیا، ان سے ابوالتیاح نے اور ان سے انس رضی الل"}
{"hadithnumber": "1869", "text": "ہم سے اسماعیل بن عبداللہ نے بیان کیا، کہا کہ مجھ سے میرے بھائی عبدالحمید نے بیان کیا، ان سے سلیمان ب"}
{"hadithnumber": "1870", "text": "ہم سے محمد بن بشار نے بیان کیا، کہا کہ ہم سے عبدالرحمٰن بن مہدی نے بیان کیا، ان سے سفیان ثوری نے، ان"}
{"hadithnumber": "1871", "text": "ہم سے عبداللہ بن یوسف نے بیان کیا، کہا ہمیں امام مالک رحمہ اللہ نے خبر دی، انہیں یحییٰ بن سعید نے، ا"}
{"hadithnumber": "1872", "text": "ہم سے خالد بن مخلد نے بیان کیا، کہا کہ ہم سے سلیمان بن بلال نے بیان کیا، کہا کہ مجھ سے عمرو بن یحییٰ"}
{"hadithnumber": "1873", "text": "ہم سے عبداللہ بن یوسف نے بیان کیا، کہا کہ ہمیں امام مالک نے خبر دی، انہیں ابن شہاب زہری نے، انہیں سع"}
{"hadithnumber": "1874", "text": "ہم سے ابوالیمان نے بیان کیا، کہا ہمیں شعیب نے خبر دی، ان سے زہری نے بیان کیا، کہا کہ مجھے سعید بن مس"}
{"hadithnumber": "1875", "text": "ہم سے عبداللہ بن یوسف نے بیان کیا، انہوں نے کہا ہمیں امام مالک نے خبر دی، انہیں ہشام بن عروہ نے، انہ"}
{"hadithnumber": "1876", "text": "ہم سے ابراہیم بن المنذر نے بیان کیا، انہوں نے کہا کہ ہم سے انس بن عیاض نے بیان کیا، انہوں نے کہا کہ"}
{"hadithnumber": "1877", "text": "ہم سے حسین بن حرث نے بیان کیا، کہا ہمیں فضل بن موسیٰ نے خبر دی، انہیں جعید بن عبدالرحمٰن نے اور ان س"}
{"hadithnumber": "1878", "text": "ہم سے علی بن عبداللہ مدینی نے بیان کیا، کہا ہم سے سفیان بن عیینہ نے بیان کیا، ان سے ابن شہاب زہری نے"}
{"hadithnumber": "1879", "text": "ہم سے عبدالعزیز بن عبداللہ نے بیان کیا، کہا کہ مجھ سے ابراہیم بن سعد نے بیان کیا، ان سے ان کے والد ن"}
{"hadithnumber": "1880", "text": "ہم سے اسماعیل نے بیان کیا، انہوں نے کہا کہ مجھے سے امام مالک نے بیان کیا، ان سے نعیم بن عبداللہ المج"}
{"hadithnumber": "1881", "text": "ہم سے ابراہیم بن المنذر نے بیان کیا، ان سے ولید نے بیان کیا، ان سے ابوعمرو اوزاعی نے بیان کیا، ان سے"}
{"hadithnumber": "1882", "text": "ہم سے یحییٰ بن بکیر نے بیان کیا، انہوں نے کہا کہ ہم سے لیث بن سعد نے بیان کیا، ان سے عقیل نے، ان سے"}
{"hadithnumber": "1883", "text": "ہم سے عمرو بن عباس نے بیان کیا، کہا ہم سے عبدالرحمٰن نے بیان کیا، ان سے سفیان نے بیان کیا، ان سے محم"}
{"hadithnumber": "1884", "text": "ہم سے سلیمان بن حرب نے بیان کیا، کہا ہم سے شعبہ نے بیان کیا، ان سے عدی بن ثابت نے، ان سے عبداللہ بن"}
{"hadithnumber": "1885", "text": "ہم سے عبداللہ بن محمد مسندی نے بیان کیا، انہوں نے کہا ہم سے وہب بن جریر نے بیان کیا، ان سے ان کے وال"}
{"hadithnumber": "1886", "text": "ہم سے قتیبہ نے بیان کیا، کہا ہم سے اسماعیل بن جعفر نے بیان کیا، ان سے حمید نے اور ان سے انس رضی اللہ"}
{"hadithnumber": "1887", "text": "ہم سے محمد بن سلام بیکندی نے بیان کیا، کہا کہ ہمیں مروان بن معاویہ فزاری نے خبر دی، انہیں حمید طویل"}
{"hadithnumber": "1888", "text": "ہم سے مسدد نے بیان کیا، ان سے یحییٰ قطان نے بیان کیا، ان سے عبیداللہ بن عمر نے بیان کیا کہ مجھ سے خب"}
