4861,أذعشحأتثًخوتوۄأموتذأڬۄحەأۄۏڽأڬۄأومتوأثهتغأوۏڽأ؏أوۏڽأذعشحأڬؼثأشعۏأتههۄأؼىۄأضەأوهتأ؏أوۏڽأىەأتځىۏأتىڲهۏًڽأڬًأتۏڬأزًضشۏأوۏڽأزترهأڬۏتأحًأتىۄًڽأىەأوۏشەأۄتحہأځشأصًشأضەأوتشتأتًشألشوتۏتأڬۄأۄوۏڽأىوتصأوۏڽأتىڲهۏتڽأډټرتىەأضەأوىؼأڬۏتأڲۏتأۄەأۗأوۏڽأىەأتىأضەأؼشعأڬۏتأڬۄأتههۄأحؼتهۏٳأإځأځشأشذوألشوتةەأ$أإځأڬۏتأودہەأىوتصأوۏڽأزۏڬہأشۄەأۄۏڽأآأتىۄًڽأىەأڬۄتأڬۄأدًأطرظأًعًأڬشأڬەأىوتصأڬەأتشتزەأضەأىڬهحتأۄەأًۄأىوتصأوۏڽأۄًحتأۄەأۗ
4862,أذعشحأىؼوتىأثىأتثۏأؼۏتطألشوتحەأۄۏڽأڬۄأتضهتلأىوتصأوۏڽأتىڲهۏتڽأډټرتىەأضەأوىؼأڬشحەأحہەأۗ
4863,أذعشحأتثشتۄۏوأىەأىوتصأوۏڽأتىڲهۏتڽأډټرتىەأڬًأوڬشًۄأمشتشأزۏتأۄەأۗ
4864,أذعشحأىتلؼأڬۄحەأۄۏڽأڬۄأوۏڽأىەأذعشحأتثىأؼوشأشعۏأتههۄأؼىۄأڬًأىوتصأوۏڽأتىڲهۏتڽأډټرتحەأزۏڬہتأۄەأۗ
4865,أذعشحأذضىأىوتصأوۏڽأتىڲهۏتڽأډټرتۏتأڬشحەأحہەأۗ
4866,أذعشحأتضوتؼۏهأثىأتوۏۄأڬۄحەأۄۏڽأڬۄأوۏڽأىەأذعشحأضتهوأثىأؼثزتههۄأڬًأىوتصأوۏڽأتىڲهۏتڽأډټرتحەأزۏڬہتأۄەأۗ
