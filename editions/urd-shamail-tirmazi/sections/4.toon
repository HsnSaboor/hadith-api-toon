metadata:
  section_id: 4
  section_name: رسول اللہ صلی اللہ علیہ وسلم کے مبارک بالوں کا بیان
  hadith_first: 24
  hadith_last: 31

hadiths[8]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
24,’’ سیدنا انس بن مالک رضی اللہ عنہ سے مروی ہے، وہ فرماتے ہیں کہ رسول اللہ صلی اللہ علیہ وسلم کے بال آپ صلی اللہ علیہ وسلم کے کانوں کے نصف تک تھے۔ ‘‘,,,24,,رسول اللہ صلی اللہ علیہ وسلم کے مبارک بالوں کا بیان
25,’’اُمّ المؤمنین سیدہ عائشہ رضی اللہ عنہا سے مروی ہے، وہ فرماتی ہیں کہ میں اور رسول اللہ صلی اللہ علیہ وسلم ایک برتن سے اکٹھے غسل کرتے تھے اور آپ صلی اللہ علیہ وسلم کے بال مبارک جمہ سے کچھ اوپر اور وفرہ سے کم تھے۔ ‘‘,,,25,,رسول اللہ صلی اللہ علیہ وسلم کے مبارک بالوں کا بیان
26,"’’ سیدنا براء بن عازب رضی اللہ عنہ سے مروی ہے، وہ فرماتے ہیں : رسول اللہ صلی اللہ علیہ وسلم وجود و خلقت کے اعتبار سے میانے قدوالے تھے، آپ صلی اللہ علیہ وسلم کے دونوں کندھوں کے درمیان کچھ دوری تھی، اور آپ صلی اللہ علیہ وسلم کے مبارک جمّہ بال کانوں کی لو پر پڑتے تھے۔ ‘‘",,,26,,رسول اللہ صلی اللہ علیہ وسلم کے مبارک بالوں کا بیان
27,"’’ سیدنا قتادہ رحمہ اللہ فرماتے ہیں : میں نے سیدنا انس رضی اللہ عنہ سے پوچھا کہ نبی اکرم صلی اللہ علیہ وسلم کے بال مبارک کیسے تھے؟ انہوں نے فرمایا: آپ صلی اللہ علیہ وسلم کے بال مبارک نہ توبہت زیادہ گنگھریالے تھے، اور نہ ہی بالکل سیدھے تھے، آپ صلی اللہ علیہ وسلم کے بال مبارک کانوں کی لوتک پہنچتے تھے۔ ‘‘",,,27,,رسول اللہ صلی اللہ علیہ وسلم کے مبارک بالوں کا بیان
28,’’ سیدہ ام ہانی رضی اللہ عنہا سے مروی ہے وہ فرماتی ہیں کہ نبی اکرم صلی اللہ علیہ وسلم ایک دفعہ مکہ معظمہ میں تشریف لائے تو آپ صلی اللہ علیہ وسلم کے مبارک بالوں کے چار گیسو تھے۔ ‘‘,,,28,,رسول اللہ صلی اللہ علیہ وسلم کے مبارک بالوں کا بیان
29,’’ سیدنا انس رضی اللہ عنہ سے مروی ہے کہ رسول اللہ صلی اللہ علیہ وسلم کے بال کانوں کے نصف حصوں تک تھے۔ ‘‘,,,29,,رسول اللہ صلی اللہ علیہ وسلم کے مبارک بالوں کا بیان
30,’’ سیدنا ابن عباس رضی اللہ عنہما  سے مروی ہے کہ یقیناً رسول اللہ صلی اللہ علیہ وسلم اپنے بالوں کولٹکایا کرتے تھے، اور مشرکین اپنے بالوں میں مانگ نکالتے تھے، جبکہ اہل کتاب اپنے سر کے بالوں کو لٹکاتے، اس لیے کہ جس کام میں آپ صلی اللہ علیہ وسلم کو کوئی حکم نہ دیا جاتا اس میں آپ صلی اللہ علیہ وسلم اہل کتاب کی موافقت پسند فرماتے تھے، پھر نبی اکرم صلی اللہ علیہ وسلم نے بھی سر میں مانگ نکالنی شروع کر دی۔ ‘‘,,,30,,رسول اللہ صلی اللہ علیہ وسلم کے مبارک بالوں کا بیان
31,"’’ سیدہ ام ھانی رضی اللہ عنہا سے مروی ہے، وہ فرماتی ہیں : میں نے رسول اللہ صلی اللہ علیہ وسلم کو دیکھا آپ صلی اللہ علیہ وسلم کے بال چار گیسوؤں میں بٹے ہوئے تھے۔ ‘‘",,,31,,رسول اللہ صلی اللہ علیہ وسلم کے مبارک بالوں کا بیان
