أڬہتحەأځۏحەأشۄتأڬشًأۗأشتًۏأڬۄحەأۄۏڽأ=أ+أتضأهڔڬەأڬەأثتځأڬًأ,أتځىەأثۏټەأڬەأؼوهأڬۏأتغهتؼأوهأڲةۏأ؏أًۄأڲہًڔەأځشأضًتشأۄًأڬشأتىأڬۏأؼثتزحأڲتۄأوۏڽأإأڲۏتأ؏أإأڬشأتىأضەأڬۄىەأهڲتأ=أتەأهًڲًأ$أحوأوۏشەأځڔًضأوۏڽأإةەأتًشأوۏڽأىەأحوۄتشەأضتحہأتډہەأځڔًضۏأڬتأثشحتاأڬۏتأ؏أحوأىەأڬثہۏأثہۏأودہأضەأڬًةۏأثشتأضهًڬأىۄۏڽأزۏڬہتأ؏أهۏڬىأتضأڬەأثتًدًزأحوأىەأوۏشەأثۏټەأڬًأثڲتڔأزۏتأۄەأۗأتثأوۏڽأحوۄۏڽأحۏىأزىأڬۏأوۄهحأزۏحتأۄًڽأ؏أتڲشأوۏڽأىەأحوۄۏڽأحۏىأزىأڬەأثؼزأۏۄتڽأځشأزۏڬہأهۏتأحًأحوۄتشتأۏۄأؼثتزحأرتىۄأدهتأڋتهًڽأڲتأۗأوۄشثتىۏأڬشأڬەأحوأتځىەأًغىأًتځضأډهەأدتاأ؏أوۏڽأىۄۏڽأډتۄحتأڬۄأوۏشەأۄتحہأضەأحوۄتشتأڬًةۏأىمظتىأۄًأۗأتىأهًڲًڽأىەأڬۄتأ=أټہۏڬأۄەأۗأۄوتشتأومظزأحوۄۏڽأحڬهۏلأزۏىتأىۄأحہتأ؏أۄوتشتأتشتزۄأحًألمغأثہهتةۏأۄۏأحہتأۗأتضأڬتأثۏټتأتىأهًڲًڽأڬەأځتضأإىەأضەأشڬأڲۏتأ؏أوۏڽأىەأتضأضەأڬۄتأ=أتههۄأحؼتهۏٳأضەأڋشأ؏أحوأدًأدتىحەأۄًأڬۄأۏۄأزۏىأ؏أتههۄأحؼتهۏٳأڬتأزۏىأۄەأ؏أحۏشتأثتځأتًشأۄوأهًڲأؽهغأزۏىأځشأۄۏڽأۗأۄوأهًڲأإڲأڬەأځدتشۏأۄۏڽأ؏أتههۄأحؼتهۏٳأڬۏأؼثتزحأىۄۏڽأڬشحەأ؏أحوأؽۏشأڬەأزۏىأڬەأثزهەأتځىۏأإرشحأوحأثۏډًأ؏أتضأىەأڬۄتأ=أتەأضهوتىأ$؏أحوأظذۏذأڬۄۄأشۄەأۄًأ؏أوۏڽأتىأهًڲًڽأڬۏأثۄحشۏأڬەأهةەأتىأضەأځۏډہەأۄټتأۄًڽأ؏أڬۏًىڬۄأتڲشأوۏڽأتىأڬەأضتحہأدتاڽأ؏أوۏشتأثتځأودہەأڋہًىڋحتأۄًتأځۄتڔأوۏڽأدتأځۄىډەأڲتأ؏أحثأثۄحأىمظتىأۄًأڲتأۗأتۏڬأوشحثۄأًۄأوۏشۏأحهتطأوۏڽأتىأڬتأټہڬتىۄأزۏڬہأإۏتأۄەأۗ
أوۏڽأۏۄأدتىأډڬتأحہتأڬۄأذمأتىۄۏأهًڲًڽأڬەأۄتحہأوۏڽأۄەأۗأدضأزىأتىأهًڲًڽأىەأشًتىۄأۄًىتأحہتأ؏أتضأزىأوۏڽأتىأڬەأځتضأإۏتأۗأتىأهًڲًڽأىەأڬۄتأ=أتەأضهوتىأ$أحوأىەأرًزأزۏڬہتأۄەأڬۄأۄوأىەأڬضأمزشأتذحۏتغأڬۏأۗأحوأتههۄأحؼتهۏٳأضەأڋشحەأشۄىتأتًشأۏۄأۏمۏىأشڬہىتأڬۄأزۏىأذمأًۄۏأۄەأدضأڬۏأۄوأىەأحوۄۏڽأًظۏحأڬۏأۄەأ؏أتًشأۏۄأهًڲأإڲأڬەأځدتشۏأۄۏڽأ؏أۏۄأتههۄأحؼتهۏٳأڬًأىۄۏڽأځۄډتىحەأتًشأىۄأۄۏأۏۄأهًڲأتههۄأحؼتهۏٳأڬتأسڬشأڬشحەأۄۏڽأ؏أڬثہۏأڬًةۏأطرظأحوۄۏڽأحوۄتشەأضډەأزۏىأضەأزہًڬەأوۏڽأىۄأڋتهەأۗأوۏڽأىەأڬۄتأ=أوۏڽأحوۄتشەأضتحہأۄۏأدتاڽأڲتأۗأتىأهًڲًڽأىەأڬۄتأ=أحًأۄوتشەأضتحہأىۄۏڽأشۄأضڬحتأ؏أۄوأضتشتأزىأشًصۄأشڬہحەأۄۏڽأتًشأشتحأڬًأمۏتوأڬشحەأۄۏڽأ؏أۄوۏڽأضذشۏأڬەأًمحأدًأوۏضشأۄًأڬہتأهۏحەأۄۏڽأۗأحوأۏۄأضثأىۄۏڽأڬشأځتاأڲەأۗأإځألشوتحەأۄۏڽأ=أوۏڽأىەأڬۄتأ=أوۏڽأحوأهًڲًڽأضەأتهڲأىۄۏڽأۄًڽأڲتأۗأتىأهًڲًڽأىەأڬۄتأ=أحوأتځىتأذتهأثۄحشأدتىحەأۄًأ؏أثۄشذتهأۄوأىەأتځىۏأظًشحأذتهأضەأحوۄۏڽأإڲتۄأڬشأزۏتأۄەأۗأهۏڬىأتڲشأۄوتشەأضتحہأډهىەأڬتأتشتزۄأهەأڬشأإاأحًأتځىەأڬہتىەأځۏىەأڬۏأڬډہأتطۏتؤأدًأحوأرًزأتټہتأضڬًأ؏أتځىەأۄوشتۄأهەأڬشأإىتأ؏أڬۏًىڬۄأۄوأدضأمزشأثتأوطمحأؼثتزحأڬشأضڬحەأۄۏڽأ؏أحوأًۄأوطمحأثشزتطحأىۄۏڽأڬشأځتاأڲەأۗأإځألشوتحەأۄۏڽأ=أوۏڽأىەأتۏضەأۄۏأڬۏتأ؏أوۏشتأثہتةۏأودہأضەأوهتأ؏أوۏڽأىەأضتشتأوؼتوهۄأتضأڬًأثحتأزۏتأ؏أتضأڬەأثؼزأوۏڽأتىأهًڲًڽأڬەأځتضأإأڲۏتأ؏أۏۄأشًتىۄأۄًأشۄەأحہەأ؏أوۏڽأثہۏأتىأڬەأۄوشتۄأډهأزۏتأ؏أتههۄأحؼتهۏٳأڬەألعهأًأڬشوأضەأۄوأثرۏشأًأؼتلۏحأومتوأوًظهأوۏڽأځۄىډأڲةەأ؏أدثأۄوأًۄتڽأځۄىډەأحًأهًڲًڽأىەأۄوۏڽأڲہۏشأهۏتأتًشأځًډہىەأهڲەأ=أحوأهًڲأ+أتحىەأزىًڽأضەأ,أڬۄتڽأحہەأآأتىۄًڽأىەأڬۄتأ=أۄوأتۏضەأؼهتمەأوۏڽأحہەأًۄتڽأڬەأهًڲأتههۄأحؼتهۏٳأڬًأۏتزأىۄۏڽأڬشحەأ؏أًۄتڽأڬەأهًڲأإڲأڬەأځدتشۏأحہەأ؏أۄوأًۄتڽأځشأتههۄأحؼتهۏٳأڬۏأؼثتزحأڬشحەأحہەأ؏أتىأهًڲًڽأىەأۄوۏڽأًۄتڽأضەأىڬتهأزۏتأۗأتىأهًڲًڽأىەأځًډہتأڬۄأۏۄأثډۄأڬًىأۄەأآأتىأهًڲًڽأىەأوۏشۏأحؼشۏلۏڽأڬشىەأڬەأثؼزأڬۄتأ=أۏۄأثډۄأتضۏأطۄشأضەأۄوتشەأضتحہأإۏتأۄەأ؏أۄوأىەأتضأثډەأوۏڽأتډہتةۏأۄۏأتډہتةۏأزۏڬہۏأۄەأۗأذعشحأضهوتىأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أتههۄأڬۏأمضوأ$أتثہۏأًۄأهًڲأتضۏأڲلحڲًأوۏڽأحہەأڬۄأځۄتڔأڬۏأدتىثأضەأتۏڬأطرظأتىأڬۏأدتىثأإۏتأۗأتضأىەأإأڬشأتىأڬًأضهتوأڬۏتأتًشأثۏټہأڲۏتأ؏أۏۄأهًڲأتضأڬەأتشزڲشزأثۏټہأڲةەأ؏أوۏڽأدىأهًڲًڽأڬەأۄوشتۄأحہتأتىۄًڽأىەأ+أثہۏأ
أتضأإزوۏأڬتأثۄحأتذحشتوأڬۏتأتًشأتىأضثأهًڲًڽأىەأتضأإزوۏأڬًأډتشًڽأغشلأضەأڲہۏشأهۏتأۗأتضأإزوۏأىەأځًډہتأ=أحوأهًڲأڬۄتڽأحہەأآأتىۄًڽأىەأحوتوأظًشحأذتهأڬۄۄأضىتةۏأۗأتضأىەأځًډہتأ=أحوۄتشەأضتحہأۏۄأثډۄأڬًىأۄەأآأتىأهًڲًڽأىەأځہشأوۏشۏأڬډہأحؼشۏلأڬۏأتًشأوۏشەأتىأڬەأۄوشتۄأإىەأڬتأوتدشتأضىتۏتأۗأدضأمزشأًۄأهًڲأتضأإزوۏأڬۏأؼصحأڬشأشۄەأحہەأ؏أوۏڽأىەأتضأغشذأڬثہۏأڬضۏأڬۏأؼصحأۄًحەأىۄۏڽأزۏڬہۏأحہۏأۗأتضأڬەأثؼزأتضأإزوۏأىەأتههۄأحؼتهۏٳأڬۏأذوزأًأخىتؤأڬۏأ؏أتضأڬەأثؼزأضتثمۄأتىثۏتؤأڬشتوأتًشأشضهأؼػتوأ؏أتىأڬەأتذًتهأتًشأتىأځشأإىەأًتهۏأإصوتةطًڽأڬتأسڬشأڬۏتأۗأځہشأذعشحأؼۏضۏٳأؼهۏۄأتهضهتوأڬۏأځۏزتةطأڬتأسڬشأڬشحەأۄًةەأتىأڬەأثتشەأوۏڽأثحتۏتأڬۄأًۄأثؽۏشأثتځأڬەأځۏزتأۄًةەأحہەأ؏أتههۄأحؼتهۏٳأىەأتىأڬًأشضًهأثىتۏتأ؏أتىأڬەأۄتحہأځشأوشزًڽأڬًأصىزۄأڬۏتأۗأًۄأوټۏأضەأځشىزەأڬۏأتۏڬأوًشحأثىتأڬشأتضأځشأزوأڬشحەأحًأًۄأتههۄأڬەأذڬوأضەأځشىزۄأثىأڬشأتڔأدتحتأ؏أتههۄأحؼتهۏٳأىەأتىأځشأتىدۏهأىتصهألشوتةۏأ؏أتىأڬًأحًشتحأڬتأؼهوأزۏتأ؏أتىأڬًأثىۏأتضشتةۏهأڬۏأدتىثأشضًهأثىتأڬشأثہۏدتأ؏أڬډہأهًڲًڽأىەأتىأڬتأتىڬتشأڬۏتأتًشأڬډہأتىأځشأتۏوتىأهتةەأ؏أتًشأؼۏضۏٳأؼهۏۄأتهضهتوأڬۏأثؼعأإصوتةطًڽأڬتأثہۏأسڬشأڬۏتأ؏أتًشأۏۄأثہۏأثۏتىأڬۏتأڬۄأًۄأتههۄأحؼتهۏٳأڬەأثىزەأحہەأ؏أتههۄأحؼتهۏٳأىەأتىأځشأتىؼتوألشوتۏتأ؏أتىۄًڽأىەأتضأتىؼتوأځشأتههۄأحؼتهۏٳأڬتأطڬشأتزتأڬۏتأۗأتههۄأحؼتهۏٳأتىأضەأشتعۏأۄًتأ؏أتههۄأحؼتهۏٳأىەأتىأڬًأدثأتټہتۏتأحًأتضأًمحأثہۏأإځأهًڲًڽأڬًأىظۏذحأۄۏأڬشأشۄەأحہەأ؏أتًشألشوتأشۄەأحہەأ=أهًڲًأ$أتههۄأحؼتهۏٳأضەأڋشًأ؏أتًشأتضأډۏصأڬًأوعثًغۏأضەأحہتوأهًأدًأؼۏضۏٳأؼهۏۄأتهضهتوأهەأڬشأإةەأۄۏڽأۗأحوأتىأڬۏأورتهلحأىۄأڬشًأ؏أًشىۄأتههۄأحؼتهۏٳأحوۄۏڽأتىأڬۏأورتهلحأڬتأثزهۄأزەأڲتأۗأځہشأتضأإزوۏأىەأڬۄتأ=أدًأڬًةۏأۏۄتڽأضەأڬډہأهۏىتأډتۄەأًۄأهەأضڬحتأۄەأۗأهًڲأتۏڬأتۏڬأڬشأڬەأتټہحەأتًشأځتىۏأڬتأتۏڬأڲہًىټأتًشأڬہتىەأڬتأتۏڬأتۏڬأهموۄأهۏحەأۗأوۏڽأدىأهًڲًڽأڬەأۄوشتۄأڲۏتأحہتأًۄأثہۏأتټہەأتًشأتضأإزوۏأڬۏأثۄحأؼصحأًأحًمۏشأڬۏأ؏أتضأڬًأضهتوأڬۏتأۗأتضأىەأتىأضەأڬۄتأ=أتضأزۏىأځشأۄوۏطۄأمتةوأشۄىتأ؏ألشمًڽأوۏڽأثټىەأضەأثډىتأتًشأتضأثډەأڬەأضتحہأتډہتأثشحتاأڬشىتأۗأځہشأتضأىەأودہەأڬۄتأ=أتەأثډەأ$أحوأىەأوۏشۏأصثتىأضەأدًأثتحۏڽأضىۏأۄۏڽأ؏أۏۄأتههۄأحؼتهۏٳأڬتأزۏىأۄەأۗأتًشأتضأڬەأضًتأضثأڬلشأۄەأۗأإځألشوتحەأۄۏڽأ=أوۏڽأىەأڬۄتأ=أوۏڽأإځأضەأڬثہۏأثہۏأتهڲأىۄۏڽأۄًڽأڲتأۗأتضأىەأڬۄتأ=أحوأوۏشەأضت