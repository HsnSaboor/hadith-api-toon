{"hadithnumber": "2777", "text": "جابر رضی اللہ عنہ نبی اکرم صلی اللہ علیہ وسلم سے روایت کرتے ہیں  آپ نے فرمایا:  سفر سے گھر واپس آنے"}
{"hadithnumber": "2778", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  ہم نبی اکرم صلی اللہ علیہ وسلم کے ساتھ سفر میں تھے، جب ہ"}
{"hadithnumber": "2779", "text": "سائب بن یزید رضی اللہ عنہ کہتے ہیں کہ  جب نبی اکرم صلی اللہ علیہ وسلم غزوہ تبوک سے مدینہ آئے تو لوگو"}
{"hadithnumber": "2780", "text": "انس بن مالک رضی اللہ عنہ سے روایت ہے کہ  قبیلہ اسلم کا ایک جوان نے عرض کیا: اللہ کے رسول! میں جہاد ک"}
{"hadithnumber": "2781", "text": "کعب بن مالک رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم سفر سے دن ہی میں آتے،  ( حسن کہ"}
{"hadithnumber": "2782", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم جس وقت حجۃ الوداع سے واپس"}
{"hadithnumber": "2783", "text": "ابوسعید خدری رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:   «قسامہ» سے بچو"}
{"hadithnumber": "2784", "text": "عطاء بن یسار نے نبی اکرم صلی اللہ علیہ وسلم سے اسی طرح کی حدیث روایت کی ہے، اس میں ہے کہ  آپ نے فرما"}
{"hadithnumber": "2785", "text": "عبیداللہ بن سلمان نے بیان کیا ہے کہ  ایک صحابی نے ان سے کہا کہ جب ہم نے خیبر فتح کیا تو لوگوں نے اپن"}
{"hadithnumber": "2786", "text": "ذوالجوشن ابوشمر ضبابی رضی اللہ عنہ کہتے ہیں کہ  میں نبی اکرم صلی اللہ علیہ وسلم کے اہل بدر سے فارغ ہ"}
{"hadithnumber": "2787", "text": "سمرہ بن جندب رضی اللہ عنہ کہتے ہیں  «أما بعد» ، رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص مشرک"}
