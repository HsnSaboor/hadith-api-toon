{"metadata":{"name":"Sunan Ibn Majah","section":{"7":"Fasting"},"section_detail":{"7":{"hadithnumber_first":1638,"hadithnumber_last":1782,"arabicnumber_first":1638,"arabicnumber_last":1782}}},"hadiths":[{"hadithnumber":1718,"arabicnumber":1718,"text":"Rapporté par Abu Hurairah : Le Messager d’Allah (ﷺ) a dit : “Celui qui jeûne un jour pour Allah, Allah éloignera son visage du Feu d’une distance de soixante-dix automnes (années).”","grades":[{"name":"Al-Albani","grade":"Sahih"},{"name":"Muhammad Fouad Abd al-Baqi","grade":"Sahih"},{"name":"Shuaib Al Arnaut","grade":"Daif"},{"name":"Zubair Ali Zai","grade":"Daif"}],"reference":{"book":7,"hadith":81}}]}