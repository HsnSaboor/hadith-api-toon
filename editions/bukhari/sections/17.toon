hadiths[26]{hadithnumber,arabic,bengali,english,french,indonesian,russian,urdu,grades,reference,international_number,narrator_chain,chapter_intro}:
1036,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، قَالَ حَدَّثَنَا غُنْدَرٌ، قَالَ حَدَّثَنَا شُعْبَةُ، عَنْ أَبِي إِسْحَاقَ، قَالَ سَمِعْتُ الأَسْوَدَ، عَنْ عَبْدِ اللَّهِ ـ رضى الله عنه ـ قَالَ قَرَأَ النَّبِيُّ صلى الله عليه وسلم النَّجْمَ بِمَكَّةَ فَسَجَدَ فِيهَا، وَسَجَدَ مَنْ مَعَهُ، غَيْرَ شَيْخٍ أَخَذَ كَفًّا مِنْ حَصًى أَوْ تُرَابٍ فَرَفَعَهُ إِلَى جَبْهَتِهِ وَقَالَ يَكْفِينِي هَذَا‏.‏ فَرَأَيْتُهُ بَعْدَ ذَلِكَ قُتِلَ كَافِرًا‏.‏,,"{'narrator': 'Narrated `Abdullah bin Mas`ud:', 'text': 'The Prophet (ﷺ) recited Suratan-Najm (103) at Mecca and prostrated while reciting it and those who were \nwith him did the same except an old man who took a handful of small stones or earth and lifted it to \nhis forehead and said, ""This is sufficient for me."" Later on, I saw him killed as a non-believer.'}",,,,ہم سے ابوالیمان حکم بن نافع نے بیان کیا، کہا کہ ہمیں شعیب نے خبر دی، کہا کہ ہم سے ابوالزناد (عبداللہ,,,1036,,Prostration During Recital of Qur'an
1037,حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ، حَدَّثَنَا سُفْيَانُ، عَنْ سَعْدِ بْنِ إِبْرَاهِيمَ، عَنْ عَبْدِ الرَّحْمَنِ، عَنْ أَبِي هُرَيْرَةَ ـ رضى الله عنه ـ قَالَ كَانَ النَّبِيُّ صلى الله عليه وسلم يَقْرَأُ فِي الْجُمُعَةِ فِي صَلاَةِ الْفَجْرِ ‏{‏الم * تَنْزِيلُ‏}‏ السَّجْدَةَ وَ‏{‏هَلْ أَتَى عَلَى الإِنْسَانِ‏}‏,,"{'narrator': 'Narrated Abu Huraira:', 'text': 'On Fridays the Prophet (ﷺ) used to recite Alif Lam Mim Tanzil-As-Sajda (in the first rak`a) and Hal \nata `alal-insani i.e. Surat ad-Dahr (LXXVI) (in the second rak`a), in the Fajr prayer.'}",,,,مجھ سے محمد بن مثنی نے بیان کیا، انہوں نے کہا کہ ہم سے حسین بن حسن نے بیان کیا، انہوں نے کہا کہ ہم س,,,1037,,Prostration During Recital of Qur'an
1038,حَدَّثَنَا سُلَيْمَانُ بْنُ حَرْبٍ، وَأَبُو النُّعْمَانِ، قَالاَ حَدَّثَنَا حَمَّادٌ، عَنْ أَيُّوبَ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ ـ رضى الله عنهما ـ قَالَ ‏{‏ص‏}‏ لَيْسَ مِنْ عَزَائِمِ السُّجُودِ، وَقَدْ رَأَيْتُ النَّبِيَّ صلى الله عليه وسلم يَسْجُدُ فِيهَا‏.‏,,"{'narrator': 'Narrated Ibn `Abbas:', 'text': 'The prostration of Sa`d is not a compulsory one but I saw the Prophet (ﷺ) prostrating while reciting it.'}",,,,ہم سے اسماعیل بن ایوب نے بیان کیا، انہوں نے کہا کہ مجھ سے امام مالک نے بیان کیا، انہوں نے صالح بن کی,,,1038,,Prostration During Recital of Qur'an
1039,حَدَّثَنَا حَفْصُ بْنُ عُمَرَ، قَالَ حَدَّثَنَا شُعْبَةُ، عَنْ أَبِي إِسْحَاقَ، عَنِ الأَسْوَدِ، عَنْ عَبْدِ اللَّهِ ـ رضى الله عنه ـ أَنَّ النَّبِيَّ صلى الله عليه وسلم قَرَأَ سُورَةَ النَّجْمِ فَسَجَدَ بِهَا، فَمَا بَقِيَ أَحَدٌ مِنَ الْقَوْمِ إِلاَّ سَجَدَ، فَأَخَذَ رَجُلٌ مِنَ الْقَوْمِ كَفًّا مِنْ حَصًى أَوْ تُرَابٍ، فَرَفَعَهُ إِلَى وَجْهِهِ وَقَالَ يَكْفِينِي هَذَا، فَلَقَدْ رَأَيْتُهُ بَعْدُ قُتِلَ كَافِرًا‏.‏,,"{'narrator': 'Narrated `Abdullah bin Mas`ud:', 'text': 'The Prophet (ﷺ) recited Surat-an-Najm (53) and prostrated while reciting it and all the people prostrated and a man amongst the people took a handful of stones or earth and raised it to his face and said, ""This is sufficient for me. Later on I saw him killed as a non-believer.""'}",,,,ہم سے محمد بن یوسف فریابی نے بیان کیا، انہوں نے کہا کہ ہم سے سفیان ثوری نے بیان کیا، انہوں نے کہا کہ,,,1039,,Prostration During Recital of Qur'an
1040,حَدَّثَنَا مُسَدَّدٌ، قَالَ حَدَّثَنَا عَبْدُ الْوَارِثِ، قَالَ حَدَّثَنَا أَيُّوبُ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ ـ رضى الله عنهما أَنَّ النَّبِيَّ صلى الله عليه وسلم سَجَدَ بِالنَّجْمِ وَسَجَدَ مَعَهُ الْمُسْلِمُونَ وَالْمُشْرِكُونَ وَالْجِنُّ وَالإِنْسُ‏.‏ وَرَوَاهُ ابْنُ طَهْمَانَ عَنْ أَيُّوبَ‏.‏,,"{'narrator': 'Narrated Ibn `Abbas:', 'text': 'The Prophet (ﷺ) I prostrated while reciting An-Najm and with him prostrated the Muslims, the pagans, the \njinns, and all human beings.'}",,,,ہم سے عمرو بن عون نے بیان کیا، انہوں نے کہا کہ ہم سے خالد بن عبداللہ نے یونس سے بیان کیا، ان سے امام,,,1040,,Prostration During Recital of Qur'an
1041,حَدَّثَنَا سُلَيْمَانُ بْنُ دَاوُدَ أَبُو الرَّبِيعِ، قَالَ حَدَّثَنَا إِسْمَاعِيلُ بْنُ جَعْفَرٍ، قَالَ أَخْبَرَنَا يَزِيدُ بْنُ خُصَيْفَةَ، عَنِ ابْنِ قُسَيْطٍ، عَنْ عَطَاءِ بْنِ يَسَارٍ، أَنَّهُ أَخْبَرَهُ، أَنَّهُ، سَأَلَ زَيْدَ بْنَ ثَابِتٍ ـ رضى الله عنه ـ فَزَعَمَ أَنَّهُ قَرَأَ عَلَى النَّبِيِّ صلى الله عليه وسلم ‏{‏وَالنَّجْمِ‏}‏ فَلَمْ يَسْجُدْ فِيهَا‏.‏,,"{'narrator': ""Narrated `Ata' bin Yasar:"", 'text': 'I asked Zaid bin Thabit about prostration on which he said that he had recited An-Najm before the \nProphet, yet he (the Prophet) had not performed a prostration.'}",,,,ہم سے شہاب بن عباد نے بیان کیا، انہوں نے کہا کہ ہمیں ابراہیم بن حمید نے خبر دی، انہیں اسماعیل بن ابی,,,1041,,Prostration During Recital of Qur'an
1042,حَدَّثَنَا آدَمُ بْنُ أَبِي إِيَاسٍ، قَالَ حَدَّثَنَا ابْنُ أَبِي ذِئْبٍ، قَالَ حَدَّثَنَا يَزِيدُ بْنُ عَبْدِ اللَّهِ بْنِ قُسَيْطٍ، عَنْ عَطَاءِ بْنِ يَسَارٍ، عَنْ زَيْدِ بْنِ ثَابِتٍ، قَالَ قَرَأْتُ عَلَى النَّبِيِّ صلى الله عليه وسلم ‏{‏وَالنَّجْمِ‏}‏ فَلَمْ يَسْجُدْ فِيهَا‏.‏,,"{'narrator': 'Narrated Zaid bin Thabit:', 'text': 'I recited An-Najm before the Prophet, yet he did not perform a prostration.'}",,,,ہم سے اصبغ بن فرح نے بیان کیا، انہوں نے کہا کہ مجھے عبداللہ بن وہب نے خبر دی، انہوں نے کہا کہ مجھے ع,,,1042,,Prostration During Recital of Qur'an
1043,حَدَّثَنَا مُسْلِمٌ، وَمُعَاذُ بْنُ فَضَالَةَ، قَالاَ أَخْبَرَنَا هِشَامٌ، عَنْ يَحْيَى، عَنْ أَبِي سَلَمَةَ، قَالَ رَأَيْتُ أَبَا هُرَيْرَةَ ـ رضى الله عنه ـ قَرَأَ ‏{‏إِذَا السَّمَاءُ انْشَقَّتْ‏}‏ فَسَجَدَ بِهَا فَقُلْتُ يَا أَبَا هُرَيْرَةَ، أَلَمْ أَرَكَ تَسْجُدُ قَالَ لَوْ لَمْ أَرَ النَّبِيَّ صلى الله عليه وسلم يَسْجُدُ لَمْ أَسْجُدْ‏.‏,,"{'narrator': 'Narrated Abu Salma:', 'text': 'I saw Abu Huraira reciting Idha-Sama\' un-Shaqqat and he prostrated during its recitation. I asked Abu \nHuraira, ""Didn\'t I see you prostrating?"" Abu Huraira said, ""Had I not seen the Prophet (ﷺ) prostrating, I \nwould not have prostrated.""'}",,,,ہم سے عبداللہ بن محمد مسندی نے بیان کیا، انہوں نے کہا کہ ہم سے ہاشم بن قاسم نے بیان کیا، انہوں نے کہ,,,1043,,Prostration During Recital of Qur'an
1044,حَدَّثَنَا مُسَدَّدٌ، قَالَ حَدَّثَنَا يَحْيَى، عَنْ عُبَيْدِ اللَّهِ، قَالَ حَدَّثَنِي نَافِعٌ، عَنِ ابْنِ عُمَرَ ـ رضى الله عنهما ـ قَالَ كَانَ النَّبِيُّ صلى الله عليه وسلم يَقْرَأُ عَلَيْنَا السُّورَةَ فِيهَا السَّجْدَةُ، فَيَسْجُدُ وَنَسْجُدُ، حَتَّى مَا يَجِدُ أَحَدُنَا مَوْضِعَ جَبْهَتِهِ‏.‏,,"{'narrator': 'Narrated Ibn `Umar:', 'text': 'When the Prophet (ﷺ) recited a Sura that contained the prostration he would prostrate and we would do \nthe same and some of us (because of the heavy rush) could not find a place for prostration.'}",,,,ہم سے عبداللہ بن مسلمہ قعنبی نے بیان کیا، ان سے امام مالک نے بیان کیا، ان سے ہشام بن عروہ نے بیان کی,,,1044,,Prostration During Recital of Qur'an
1045,حَدَّثَنَا بِشْرُ بْنُ آدَمَ، قَالَ حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ، قَالَ أَخْبَرَنَا عُبَيْدُ اللَّهِ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ كَانَ النَّبِيُّ صلى الله عليه وسلم يَقْرَأُ السَّجْدَةَ وَنَحْنُ عِنْدَهُ فَيَسْجُدُ وَنَسْجُدُ مَعَهُ فَنَزْدَحِمُ حَتَّى مَا يَجِدُ أَحَدُنَا لِجَبْهَتِهِ مَوْضِعًا يَسْجُدُ عَلَيْهِ‏.‏,,"{'narrator': 'Narrated Ibn `Umar:', 'text': 'When the Prophet (ﷺ) recited Surat As-Sajda and we were with him, he would prostrate and we also \nwould prostrate with him and some of us (because of the heavy rush) would not find a place (for our \nforeheads) to prostrate on.'}",,,,ہم سے اسحاق بن منصور نے بیان کیا، انہوں نے کہا کہ ہمیں یحییٰ بن صالح نے خبر دی، انہوں نے کہا کہ ہم س,,,1045,,Prostration During Recital of Qur'an
1046,حَدَّثَنَا إِبْرَاهِيمُ بْنُ مُوسَى، قَالَ أَخْبَرَنَا هِشَامُ بْنُ يُوسُفَ، أَنَّ ابْنَ جُرَيْجٍ، أَخْبَرَهُمْ قَالَ أَخْبَرَنِي أَبُو بَكْرِ بْنُ أَبِي مُلَيْكَةَ، عَنْ عُثْمَانَ بْنِ عَبْدِ الرَّحْمَنِ التَّيْمِيِّ، عَنْ رَبِيعَةَ بْنِ عَبْدِ اللَّهِ بْنِ الْهُدَيْرِ التَّيْمِيِّ ـ قَالَ أَبُو بَكْرٍ وَكَانَ رَبِيعَةُ مِنْ خِيَارِ النَّاسِ عَمَّا حَضَرَ رَبِيعَةُ مِنْ عُمَرَ بْنِ الْخَطَّابِ ـ رضى الله عنه ـ قَرَأَ يَوْمَ الْجُمُعَةِ عَلَى الْمِنْبَرِ بِسُورَةِ النَّحْلِ حَتَّى إِذَا جَاءَ السَّجْدَةَ نَزَلَ فَسَجَدَ وَسَجَدَ النَّاسُ، حَتَّى إِذَا كَانَتِ الْجُمُعَةُ الْقَابِلَةُ قَرَأَ بِهَا حَتَّى إِذَا جَاءَ السَّجْدَةَ قَالَ يَا أَيُّهَا النَّاسُ إِنَّا نَمُرُّ بِالسُّجُودِ فَمَنْ سَجَدَ فَقَدْ أَصَابَ، وَمَنْ لَمْ يَسْجُدْ فَلاَ إِثْمَ عَلَيْهِ‏.‏ وَلَمْ يَسْجُدْ عُمَرُ ـ رضى الله عنه‏.‏ وَزَادَ نَافِعٌ عَنِ ابْنِ عُمَرَ ـ رضى الله عنهما إِنَّ اللَّهَ لَمْ يَفْرِضِ السُّجُودَ إِلاَّ أَنْ نَشَاءَ‏.‏,,"{'narrator': 'Narrated Rabi`a:', 'text': '`Umar bin Al-Khattab recited Surat-an-Nahl on a Friday on the pulpit and when he reached the verse \nof Sajda he got down from the pulpit and prostrated and the people also prostrated. The next Friday \n`Umar bin Al-Khattab recited the same Sura and when he reached the verse of Sajda he said, ""O \npeople! When we recite the verses of Sajda (during the sermon) whoever prostrates does the right \nthing, yet it is no sin for the one who does not prostrate."" And `Umar did not prostrate (that day). \nAdded Ibn `Umar ""Allah has not made the prostration of recitation compulsory but if we wish we can \ndo it.""'}",,,,ہم سے یحییٰ بن بکیر نے بیان کیا، انہوں نے کہا کہ مجھ سے لیث بن سعد نے بیان کیا، ان سے عقیل نے بیان ک,,,1046,,Prostration During Recital of Qur'an
1047,حَدَّثَنَا مُسَدَّدٌ، قَالَ حَدَّثَنَا مُعْتَمِرٌ، قَالَ سَمِعْتُ أَبِي قَالَ، حَدَّثَنِي بَكْرٌ، عَنْ أَبِي رَافِعٍ، قَالَ صَلَّيْتُ مَعَ أَبِي هُرَيْرَةَ الْعَتَمَةَ فَقَرَأَ ‏{‏إِذَا السَّمَاءُ انْشَقَّتْ‏}‏ فَسَجَدَ فَقُلْتُ مَا هَذِهِ قَالَ سَجَدْتُ بِهَا خَلْفَ أَبِي الْقَاسِمِ صلى الله عليه وسلم فَلاَ أَزَالُ أَسْجُدُ فِيهَا حَتَّى أَلْقَاهُ‏.‏,,"{'narrator': 'Narrated Abu Rafi`:', 'text': 'I offered the `Isha\' prayer behind Abu Huraira and he recited Idhas-Sama\' Un-Shaqqat, and prostrated. \nI said, ""What is this?"" Abu Huraira said, ""I prostrated behind Abul-Qasim and I will do the same till I \nmeet him.""'}",,,,ہم سے سعید بن عفیر نے بیان کیا، انہوں نے کہا کہ ہم سے لیث بن سعد نے بیان کیا، انہوں نے کہا کہ مجھ سے,,,1047,,Prostration During Recital of Qur'an
1048,حَدَّثَنَا صَدَقَةُ، قَالَ أَخْبَرَنَا يَحْيَى، عَنْ عُبَيْدِ اللَّهِ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ ـ رضى الله عنهما ـ قَالَ كَانَ النَّبِيُّ صلى الله عليه وسلم يَقْرَأُ السُّورَةَ الَّتِي فِيهَا السَّجْدَةُ فَيَسْجُدُ وَنَسْجُدُ حَتَّى مَا يَجِدُ أَحَدُنَا مَكَانًا لِمَوْضِعِ جَبْهَتِهِ‏.‏,,"{'narrator': 'Narrated Ibn `Umar.:', 'text': 'Whenever the Prophet (ﷺ) recited the Sura which contained the prostration of recitation he used to \nprostrate and then, we, too, would prostrate and some of us did not find a place for prostration.'}",,,,ہم سے قتیبہ بن سعید نے بیان کیا، کہا کہ ہم سے حماد بن زید نے بیان کیا، ان سے یونس بن عبید نے، ان سے,,,1048,,Prostration During Recital of Qur'an
1067,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ ، قَالَ : حَدَّثَنَا غُنْدَرٌ ، قَالَ : حَدَّثَنَا شُعْبَةُ ، عَن",,"Narrated `Abdullah bin Mas`ud:The Prophet (ﷺ) recited Surat an-Najm (53) at Mecca and prostrated while reciting it and those who were with him did the same except an old man who took a handful of small stones or earth and lifted it to his forehead and said, ""This is sufficient for me."" Later on, I saw him killed as a non-believer",,,,ہم سے محمد بن بشار نے بیان کیا، کہا کہ ہم سے غندر محمد بن جعفر نے بیان کیا کہا کہ ہم سے شعبہ نے بیان,,"Book 17, Hadith 1",1067,,Prostration During Recital of Qur'an
1068,حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ ، حَدَّثَنَا سُفْيَانُ ، عَنْ سَعْدِ بْنِ إِبْرَاهِيمَ ، عَنْ عَبْ,,"Narrated Abu Huraira:On Fridays the Prophet (ﷺ) used to recite Alif Lam Mim Tanzil-As-Sajda (in the first rak`a) and Hal ata `alal-insani i.e. Surat ad-Dahr (LXXVI) (in the second rak`a), in the Fajr prayer",,,,ہم سے محمد بن یوسف فریابی نے بیان کیا، انہوں نے کہا کہ ہم سے سفیان ثوری نے بیان کیا، انہوں نے سعد بن,,"Book 17, Hadith 2",1068,,Prostration During Recital of Qur'an
1069,"حَدَّثَنَا سُلَيْمَانُ بْنُ حَرْبٍ ، وَأَبُو النُّعْمَانِ ، قَالَا : حَدَّثَنَا حَمَّادُ ، عَنْ أَيّ",,"Narrated Ibn `Abbas:The prostration of Sa`d is not a compulsory one but I saw the Prophet (ﷺ) prostrating while reciting it",,,,ہم سے سلیمان بن حرب اور ابوالنعمان بن فضل نے بیان کیا، ان دونوں نے کہا کہ ہم سے حماد بن زید نے بیان,,"Book 17, Hadith 3",1069,,Prostration During Recital of Qur'an
1070,"حَدَّثَنَا حَفْصُ بْنُ عُمَرَ ، قَالَ : حَدَّثَنَا شُعْبَةُ ، عَنْ أَبِي إِسْحَاقَ ، عَنْ الْأَسْوَد",,"Narrated `Abdullah bin Mas`ud:The Prophet (ﷺ) recited Surat-an-Najm (53) and prostrated while reciting it and all the people prostrated and a man amongst the people took a handful of stones or earth and raised it to his face and said, ""This is sufficient for me."" Later on I saw him killed as a non-believer",,,,ہم سے حفص بن عمر نے بیان کیا، کہا کہ ہم سے شعبہ نے، ابواسحاق سے بیان کیا، ان سے اسود نے، ان سے عبدال,,"Book 17, Hadith 4",1070,,Prostration During Recital of Qur'an
1071,"حَدَّثَنَا مُسَدَّدٌ ، قَالَ : حَدَّثَنَا عَبْدُ الْوَارِثِ ، قَالَ : حَدَّثَنَا أَيُّوبُ ، عَنْ عِك",,"Narrated Ibn `Abbas:The Prophet (ﷺ) prostrated while reciting An-Najm and with him prostrated the Muslims, the pagans, the jinns, and all human beings",,,,ہم سے مسدد بن مسرہد نے بیان کیا، کہا کہ ہم سے عبدالوارث نے بیان کیا، کہا ہم سے ایوب سختیانی نے بیان,,"Book 17, Hadith 5",1071,,Prostration During Recital of Qur'an
1072,"حدثنا سليمان بن داود ابو الربيع ، قال : حدثنا إسماعيل بن جعفر ، قال : اخبرنا يزيد بن خصيفة ، عن ابن",,"Narrated `Ata' bin Yasar:I asked Zaid bin Thabit about prostration on which he said that he had recited An-Najm before the Prophet, yet he (the Prophet) had not performed a prostration",,,,ہم سے سلیمان بن داؤد ابوالربیع نے بیان کیا، انہوں نے کہا کہ ہم سے اسماعیل بن جعفر نے بیان کیا، کہا ک,,"Book 17, Hadith 6",1072,,Prostration During Recital of Qur'an
1073,"حَدَّثَنَا آدَمُ بْنُ أَبِي إِيَاسٍ ، قَالَ : حَدَّثَنَا ابْنُ أَبِي ذِئْبٍ ، قَالَ : حَدَّثَنَا يَز",,"Narrated Zaid bin Thabit:I recited An-Najm before the Prophet, yet he did not perform a prostration",,,,ہم سے آدم بن ابی ایاس نے بیان کیا، کہا کہ ہم سے ابن ابی ذئب نے بیان کیا، کہا کہ ہم سے یزید بن عبدالل,,"Book 17, Hadith 7",1073,,Prostration During Recital of Qur'an
1074,"حَدَّثَنَا مُسْلِمُ بْنُ إِبْرَاهِيمَ ، وَمُعَاذُ بْنُ فَضَالَةَ ، قَالَا : أَخْبَرَنَا هِشَامٌ ، عَ",,"Narrated Abu Salama:I saw Abu Huraira reciting Idha-Sama' un-Shaqqat and he prostrated during its recitation. I asked Abu Huraira, ""Didn't I see you prostrating?"" Abu Huraira said, ""Had I not seen the Prophet (ﷺ) prostrating, I would not have prostrated",,,,ہم سے مسلم بن ابراہیم اور معاذ بن فضالہ نے بیان کیا، انہوں نے کہا کہ ہم سے ہشام بن ابی عبداللہ دستوا,,"Book 17, Hadith 8",1074,,Prostration During Recital of Qur'an
1075,"حَدَّثَنَا مُسَدَّدٌ ، قَالَ : حَدَّثَنَا يَحْيَى ، حَدَّثَنَا عُبَيْدُ اللَّهِ ، قَالَ : حَدَّثَنِي",,"Narrated Ibn `Umar:When the Prophet (ﷺ) recited a Sura that contained the prostration he would prostrate and we would do the same and some of us (because of the heavy rush) could not find a place for prostration",,,,ہم سے مسدد بن مسرہد نے بیان کیا، کہا کہ ہم سے یحییٰ بن سعید قطان نے بیان کیا، کہا کہ ہم سے عبیداللہ,,"Book 17, Hadith 9",1075,,Prostration During Recital of Qur'an
1076,"حَدَّثَنَا بِشْرُ بْنُ آدَمَ ، قَالَ : حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ ، قَالَ : أَخْبَرَنَا عُبَيْ",,"Narrated Ibn `Umar:When the Prophet (ﷺ) recited Surat As-Sajda and we were with him, he would prostrate and we also would prostrate with him and some of us (because of the heavy rush) would not find a place (for our foreheads) to prostrate on",,,,ہم سے بشر بن آدم نے بیان کیا، کہا کہ ہم سے علی بن مسہر نے بیان کیا، کہا کہ ہمیں عبیداللہ عمری نے خبر,,"Book 17, Hadith 10",1076,,Prostration During Recital of Qur'an
1077,"حَدَّثَنَا إِبْرَاهِيمُ بْنُ مُوسَى ، قَالَ : أَخْبَرَنَا هِشَامُ بْنُ يُوسُفَ ، أَنَّ ابْنَ جُرَيْج",,"Narrated Rabi`a:`Umar bin Al-Khattab recited Surat-an-Nahl on a Friday on the pulpit and when he reached the verse of Sajda he got down from the pulpit and prostrated and the people also prostrated. The next Friday `Umar bin Al-Khattab recited the same Sura and when he reached the verse of Sajda he said, ""O people! When we recite the verses of Sajda (during the sermon) whoever prostrates does the right thing, yet it is no sin for the one who does not prostrate."" And `Umar did not prostrate (that day). Added Ibn `Umar ""Allah has not made the prostration of recitation compulsory but if we wish we can do it",,,,ہم سے ابراہیم بن موسیٰ نے بیان کیا، انہوں نے کہا کہ ہمیں ہشام بن یوسف نے خبر دی اور انہیں ابن جریج ن,,"Book 17, Hadith 11",1077,,Prostration During Recital of Qur'an
1078,"حَدَّثَنَا مُسَدَّدٌ ، قَالَ : حَدَّثَنَا مُعْتَمِرٌ ، قَالَ : سَمِعْتُ أَبِي ، قَالَ : حَدَّثَنِي ب",,"Narrated Abu Rafi`:I offered the `Isha' prayer behind Abu Huraira and he recited Idhas-Sama' Un-Shaqqat, and prostrated. I said, ""What is this?"" Abu Huraira said, ""I prostrated behind Abul-Qasim and I will do the same till I meet him",,,,ہم سے مسدد بن مسرہد نے بیان کیا، کہا کہ ہم سے معتمر بن سلیمان نے بیان کیا، کہا کہ میں نے اپنے باپ سے,,"Book 17, Hadith 12",1078,,Prostration During Recital of Qur'an
1079,"حَدَّثَنَا صَدَقَةُ بْنُ الْفَضْلِ ، قَالَ : أَخْبَرَنَا يَحْيَى بْنُ سَعِيدٍ ، عَنْ عُبَيْدِ اللَّه",,"Narrated Ibn `Umar.:Whenever the Prophet (ﷺ) recited the Sura which contained the prostration of recitation he used to prostrate and then we too, would prostrate and some of us did not find a place for prostration",,,,ہم سے صدقہ بن فضل نے بیان کیا، ان سے یحییٰ بن سعیدقطان نے بیان کیا، ان سے عبیداللہ نے، ان سے نافع نے,,"Book 17, Hadith 13",1079,,Prostration During Recital of Qur'an
