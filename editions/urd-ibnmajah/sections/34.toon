hadiths[66]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
3827,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص اللہ تعالیٰ سے دع",,,,,3827
3828,"نعمان بن بشیر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  بیشک دعا ہی عبادت",,,,,3828
3829,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  اللہ تعالیٰ کے نزدیک دعا ",,,,,3829
3830,عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم اپنی دعا میں یہ پڑھا کرتے,,,,,3830
3831,ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  فاطمہ رضی اللہ عنہا نبی اکرم صلی اللہ علیہ وسلم کی خدمت میں ایک خ,,,,,3831
3832,"عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم یہ دعا مانگا کرتے تھے: «اللهم",,,,,3832
3833,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم یہ دعا مانگا کرتے تھے: «اللهم انفعني",,,,,3833
3834,"انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم اکثر یہ دعا مانگا کرتے تھے: «الله",,,,,3834
3835,"ابوبکر صدیق رضی اللہ عنہ کہتے ہیں کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم سے عرض کیا: مجھے کوئی ای",,,,,3835
3836,ابوامامہ باہلی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم عصا  ( چھڑی )  پر ٹیک لگائے ہم,,,,,3836
3837,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم یہ دعا فرمایا کرتے تھے: «اللهم إني أ",,,,,3837
3838,ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم ان کلمات کے ذریعہ دعا کی,,,,,3838
3839,فروہ بن نوفل رضی اللہ عنہ کہتے ہیں کہ  میں نے ام المؤمنین عائشہ رضی اللہ عنہما سے سوال کیا کہ رسول ا,,,,,3839
3840,عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم جیسے قرآن کی سورت سکھاتے ا,,,,,3840
3841,ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  میں نے ایک رات رسول اللہ صلی اللہ علیہ وسلم کو بستر پر ,,,,,3841
3842,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم اللہ سے فقیری، مال کی",,,,,3842
3843,"جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم اللہ تعالیٰ سے اس علم کا ",,,,,3843
3844,عمر رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم بزدلی، بخیلی، ارذل عمر  ( انتہائی بڑھاپا ),,,,,3844
3845,طارق رضی اللہ عنہ سے روایت ہے کہ  انہوں نے نبی اکرم صلی اللہ علیہ وسلم سے سنا  ( اس وقت کہ جب )  ایک,,,,,3845
3846,"ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے انہیں یہ دعا سکھائی: «ا",,,,,3846
3847,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک شخص سے پوچھا:  تم نماز میں کی",,,,,3847
3848,"انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے پاس ایک شخص آیا اور کہنے لگا:",,,,,3848
3849,1 اوسط بن اسماعیل بجلی سے روایت ہے کہ  جب نبی اکرم صلی اللہ علیہ وسلم کی وفات ہوئی، تو انہوں نے ابوب,,,,,3849
