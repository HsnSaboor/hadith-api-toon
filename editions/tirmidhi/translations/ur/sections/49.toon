{"hadithnumber": "3908", "text": "عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اے اللہ! قریش ک"}
{"hadithnumber": "3909", "text": "انس رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: «اللهم اغفر للأنصار ولأبناء"}
{"hadithnumber": "3910", "text": "انس بن مالک کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”کیا میں تمہیں انصار کے بہتر گھروں"}
{"hadithnumber": "3911", "text": "ابواسید ساعدی رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”انصار کے گھروں میں"}
{"hadithnumber": "3912", "text": "جابر بن عبداللہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”انصار کے گھروں می"}
{"hadithnumber": "3913", "text": "جابر عبداللہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”انصار میں سب سے بہتر"}
{"hadithnumber": "3914", "text": "علی رضی الله عنہ کہتے ہیں کہ  ہم رسول اللہ صلی اللہ علیہ وسلم کے ساتھ نکلے یہاں تک کہ جب ہم حرہ سقیا"}
{"hadithnumber": "3915", "text": "علی اور ابوہریرہ رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”میرے گھر اور م"}
{"hadithnumber": "3916", "text": "ابوہریرہ رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”میرے گھر اور میرے منبر"}
{"hadithnumber": "3917", "text": "عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جو مدینہ میں مر"}
{"hadithnumber": "3918", "text": "عبداللہ بن عمر رضی الله عنہما سے روایت ہے کہ  ان کی ایک آزاد کردہ لونڈی ان کے پاس آئی اور ان سے کہ"}
{"hadithnumber": "3919", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اسلام کے شہروں میں ویران"}
{"hadithnumber": "3920", "text": "جابر رضی الله عنہ سے روایت ہے کہ  ایک اعرابی نے رسول اللہ صلی اللہ علیہ وسلم سے اسلام پر بیعت کی، پھ"}
{"hadithnumber": "3921", "text": "ابوہریرہ رضی الله عنہ کہتے تھے کہ  اگر میں مدینہ میں ہرنوں کو چرتے دیکھوں تو انہیں نہ ڈراؤں اس لیے"}
{"hadithnumber": "3922", "text": "انس بن مالک رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم کو احد پہاڑ نظر آیا تو آپ نے"}
{"hadithnumber": "3923", "text": "جریر بن عبداللہ رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”اللہ نے میری طر"}
{"hadithnumber": "3924", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”مدینہ کی تنگی معیشت اور"}
