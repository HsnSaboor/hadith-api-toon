hadiths[3372]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}:
12780,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ سُلَیْمَانُ بْنُ حَیَّانَ ، عَنْ عَمْرِو بْنِ قَیْسٍ ، عَنْ عَاصِمٍ ، عَنْ شَقِیقٍ ، عَنْ عَبْدِ اللہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : تَابِعُوا بَیْنَ الْحَجِّ وَالْعُمْرَۃِ ، فَإِنَّہُمَا یَنْفِیَانِ الْفَقْرَ وَالذُّنُوبَ ، کَمَا یَنْفِی الْکِیرُ خَبَثَ الْحَدِیدِ وَالذَّہَبِ وَالْفِضَّۃِ ، وَلَیْسَ لِحَجَّۃٍ مَبْرُورَۃٍ جزائٌ إلاَّ الْجَنَّۃُ۔\n\n(ترمذی 810۔ احمد 1/387)",,,12780,,
12781,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَاصِمِ بْنِ عُبَیْدِ اللہِ ، عَنْ عَبْدِ اللہِ بْنِ عَامِرِ بْنِ رَبِیعَۃَ ، عَنْ عُمَرَ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : تَابِعُوا بَیْنَ الْحَجِّ وَالْعُمْرَۃِ ، فَإِنَّہُمَا یَنْفِیَانِ الْفَقْرَ وَالذُّنُوبَ کَمَا یَنْفِی الْکِیرُ خَبَثَ الْحَدِیدِ۔ (ابن ماجہ 2887۔ احمد 1/25)",,,12781,,
12782,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ سُمَیٍّ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْعُمْرَۃُ إلَی الْعُمْرَۃِ کَفَّارَۃٌ لِمَا بَیْنَہُمَا ، وَالْحَجُّ الْمَبْرُورُ لَیْسَ لَہُ جَزَائٌ إِلاَّ الْجَنَّۃُ۔\n\n(بخاری 1773۔ مسلم 983)",,,12782,,
12783,"حدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مِسْعَرٌ ، وَسُفْیَانُ ، عَنْ مَنْصُورٍ ، عَنْ أَبِی حَازِمٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ حَجَّ فَلَمْ یَرْفُثْ ، وَلَمْ یَفْسُقْ رَجَعَ کَمَا وَلَدَتْہُ أُمُّہُ۔\n\n(بخاری 1820۔ ترمذی 811)",,,12783,,
12784,"حدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ أَبِی الضُّحَی ؛ أَخْبَرَہُ شَیْخٌ فِی ہَذَا الْمَسْجِدِ ؛ أَنَّ عُمَرَ خَطَبَہُمْ عِنْدَ بَابِ الْکَعْبَۃِ ، وَقَالَ : مَا مِنْ أَحَدٍ یَجِیئُ إلَی ہَذَا الْبَیْتِ ، لاَ یَنْہَزُہُ غَیْرُ صَلاَۃٍ فِیہِ حَتَّی یَسْتَلِمَ الْحَجَرَ ، إِلاَّ کُفِّرَ عَنْہُ مَا کَانَ قَبْلَ ذَلِکَ۔",,,12784,,
12785,"حدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ أَبِی الضُّحَی ، عَنْ شَیْخٍ ، قَالَ ، قَالَ عُمَرُ بْنُ الْخَطَّابِ : مَنْ حَجَّ ہَذَا الْبَیْتَ لاَ یُرِیدُ غَیْرَہُ ، خَرَجَ مِنْ ذُنُوبِہِ کَیَوْمِ وَلَدَتْہُ أُمُّہُ۔",,,12785,,
12786,"حدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنْ أَبِی صَالِحٍ ، قَالَ : کَانَتِ امْرَأَۃٌ مِنَ الْمُہَاجِرَاتِ تَحُجُّ ، فَإِذَا رَجَعَتْ مَرَّتْ عَلَی عُمَرَ ، فَیَقُولُ لَہَا : أَنْقبْتِ ؟ فَتَقُولُ : نَعَمْ ، فَیَقُولُ لَہَا : اسْتَأْنِفِی الْعَمَلَ۔",,,12786,,
12787,"حدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ مُجَاہِدٍ ، قَالَ : بَیْنَمَا عُمَرُ جَالِسًا عِنْدَ الْبَیْتِ إذْ قَدِمَ رِجَالٌ مِنَ الْعِرَاقِ حُجَّاجًا ، فَطَافُوا بِالْبَیْتِ ، وَسَعَوْا بَیْنَ الصَّفَا وَالْمَرْوَۃِ ، فَدَعَاہُمْ عُمَرُ ، فَقَالَ : أَنْہَزَکُمْ إلَیْہِ غَیْرُہُ ؟ فَقَالُوا : لاَ ، فَقَالَ : أَنْقبْتُمْ ؟ قَالُوا : نَعَمْ ، فَقَالَ : أَدْبَرْتُمْ ؟ قَالُوا : نَعَمْ ، قَالَ : إِمَّا لاَ ، فَاسْتَأْنِفُوا الْعَمَلَ۔",,,12787,,
12788,"حدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ حَبِیبٍ ؛ أَنَّ قَوْمًا مَرُّوا بِأَبِی ذَرٍّ بِالرَّبَذَۃِ ، فَقَالَ لَہُم : مَا أَنْصَبکُمْ إِلاَّ الْحَجُّ ؟ اسْتَأْنِفُوا الْعَمَلَ۔",,,12788,,
12789,حدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ؛ أَنَّ ابْنَ مَسْعُودٍ قَالَ ذَلِکَ لِقَوْمٍ۔,,,12789,,
12790,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ حَجَّاجٍ ، عَنْ حُسَیْنٍ ، عَنْ کَعْبٍ ، قَالَ : رَأَی قَوْمًا مِنَ الْحَاجِّ ، فَقَالَ : لَوْ یَعْلَمُ ہَؤُلاَئِ مَا لَہُمْ بَعْدَ الْمَغْفِرَۃِ ، لَقَرَّتْ عُیُونُہُمْ۔",,,12790,,
12791,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ حَبِیبِ بْنِ الزُّبَیْرِ ، قَالَ : قُلْتُ لِعَطَائٍ : أَبَلَغَکَ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : اسْتَقْبِلُوا الْعَمَلَ بَعْدَ الْحَجِّ ؟ قَالَ : لاَ ، وَلَکِنْ عُثْمَانَ ، وَأَبُو ذَرٍّ۔",,,12791,,
12792,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ، عَنْ مَنْصُورٍ، عَنْ مُجَاہِدٍ ، عَنْ عَبْدِ اللہِ بْنِ ضَمْرَۃَ ، عَنْ کَعْبٍ ، قَالَ: إذَا کَبَّرَ الْحَاجُّ ، وَالْمُعْتَمِرُ ، وَالْغَازِی ، کَبَّرَ الرَّبْو الَّذِی یَلِیہ ، ثم الَّذِی یَلِیہِ ، ثم الَّذِی یَلِیہِ، حَتَّی یَنْقَطِعَ فِی الأُفُقِ۔",,,12792,,
12793,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا مُحَمَّدُ بْنُ عَمْرٍو ، عَنْ مِرْدَاسَ بْنِ عَبْدِ الرَّحْمَنِ اللَّیْثِیِّ ، قَالَ : دَخَلْنَا عَلَی عَبْدِ اللہِ بْنِ عَمْرٍو فَحدَّثَنَا ، قَالَ : مَا مِنْ أَحَدٍ یُہِلُّ إِلاَّ قَالَ اللَّہُ لَہُ : أَبْشِرْ ، فَقَالَ مِرْدَاسُ : یَا أَبَا مُحَمَّدٍ ، فَوَاللَّہِ مَا یُبَشِّرُ اللَّہُ إِلاَّ بِالْجَنَّۃِ ، قَالَ : مَنْ أَنْتَ یَا ابْنَ أَخِی ؟ قَالَ : أَنَا مِرْدَاسُ ، قَالَ : قد کَانَ خِیَارُنَا یَتَتَابَعُونَ عَلَی ذَلِکَ۔",,,12793,,
12794,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ أُسَامَۃَ بْنِ سَعِیدٍ ، عَنْ مُوسَی بْنِ سَعْدٍ ، قَالَ : قَالَ عُمَرُ : تَلَقَّوُا الْحُجَّاجَ، وَالْعُمَّارَ ، وَالْغُزَاۃَ ، فَلْیَدْعُوا لَکُمْ قَبْلَ أَنْ یَتَدَنَّسُوا۔",,,12794,,
12795,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، عَنْ عَبْدِ اللہِ بْنِ ضَمْرَۃَ السَّلُولِیِّ ، عَنْ کَعْبٍ ، قَالَ : الْحَاجُّ ، وَالْمُعْتَمِرُ ، وَالْمُجَاہِدُ فِی سَبِیلِ اللہِ وَفْدُ اللہِ ، سَأَلُوا فَأُعْطُوا ، وَدَعَوْا فَأُجِیبُوا۔",,,12795,,
12796,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ أَبِیہِ ، عَنْ أَبِی یَعْلَی ؛ أَنَّ الْحُسَیْنَ بْنَ عَلِیٍّ لَقِیَ قَوْمًا حُجَّاجًا ، فَقَالُوا : إنَّا نُرِیدُ مَکَّۃَ ، فَقَالَ : إنَّکُمْ مِنْ وَفْدِ اللہِ ، فَإِذَا قَدِمْتُمْ مَکَّۃَ فَاجْمَعُوا حَاجَاتِکُمْ ، فَسَلُوہَا اللَّہَ",,,12796,,
12797,"حدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ عَبْدِ الْمَلِکِ ، عَنْ حَبِیبِ بْنِ أبِی ثَابِتٍ ، قَالَ : کُنَّا نَتَلَقَّی الْحَاجَّ بِالْقَادِسِیَّۃِ ، فَنُصَافِحُہُمْ قَبْلَ أَنْ یُقَارِفُوا۔",,,12797,,
12798,"حدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ حَبِیبِ بْنِ أَبِی عَمْرَۃَ ، عَنْ عَائِشَۃَ ابْنَۃِ طَلْحَۃَ ، عَنْ عَائِشَۃَ ،\n\nقَالَتْ : قُلْتُ یَا رَسُولَ اللہِ ، عَلَی النِّسَائِ جِہَادٌ ؟ قَالَ : نَعَمْ ، جِہَادٌ لاَ قِتَالَ فِیہِ : الْحَجُّ وَالْعُمْرَۃُ۔\n\n(بخاری 2875۔ احمد 6/165)",,,12798,,
12799,"حدَّثَنَا وَکِیعٌ ، عَنِ الْقَاسِمِ بْنِ الْفَضْلِ ، عَنْ أَبِی جَعْفَرٍ ، عَنْ أُمِّ سَلَمَۃَ ، قَالَتْ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْحَجُّ جِہَادُ کُلِّ ضَعِیفٍ۔ (احمد 6/303۔ طیالسی 1599)",,,12799,,
12800,"حدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : قَالَ عُمَرُ : یُغْفَرُ لِلْحَاجِّ ، وَلِمَنِ اسْتَغْفَرَ لَہُ الْحَاجُّ ، بَقِیَّۃَ ذِی الْحِجَّۃِ ، وَالْمُحَرَّمِ ، وَصَفَرًا ، وَعَشْرًا مِنْ شَہْرِ رَبِیعِ الأَوَّلِ۔",,,12800,,
12801,"حدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنْ مُجَاہِدٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : اللَّہُمَّ اغْفِرْ لِلْحَاجِّ ، وَلِمَنِ اسْتَغْفَرَ لَہُ الْحَاجُّ۔ (حاکم 441)",,,12801,,
12802,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : الْحَاجُّ وَفْدُ اللہِ ، وَالْحَاجُّ وَافِدُ أَہْلِہِ۔ (ابن ماجہ 2893۔ ابن حبان 4613",,,12802,,
12803,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا ہَمَّامٌ ، عَنْ قَتَادَۃَ ، عَنْ مُحَمَّدِ بْنِ عَبَّادٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : النَّفَقَۃُ فِی الْحَجِّ کَالنَّفَقَۃِ فِی سَبِیلِ اللہِ ، الدِّرْہَمُ بِسَبْعِ مِئَۃٍ۔ (احمد 5/354)",,,12803,,
12804,"حدَّثَنَا شَرِیکٌ ، عَنْ عَاصِمِ بْنِ عُبَیْدِ اللہِ ، عَنْ عَبْدِ اللہِ بْنِ عَامِرِ بْنِ رَبِیعَۃَ ، عَنْ أَبِیہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : تَابِعُوا بَیْنَ الْحَجِّ وَالْعُمْرَۃِ ، فَإِنَّہُمَا یَنْفِیَانِ الذُّنُوبَ والْفَقْرَ ، کَمَا یَنْفِی الْکِیرُ خَبَثَ الْحَدِیدِ۔ (احمد 1/25)",,,12804,,
12805,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ ابْنِ سُوقَۃَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : مَا أَتَی ہَذَا الْبَیْتَ طَالِبٌ حَاجَۃً لِدِینٍ ، أَوْ دُنْیَا ، إِلاَّ رَجَعَ بِحَاجَتِہِ۔",,,12805,,
12806,"حدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ عَبْدِ اللہِ بْنِ عُبَیْدِ بْنِ عُمَیْرٍ ، عَنْ أَبِیہِ ، عَنِ ابْنِ عُمَرَ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : مَنْ طَافَ بِالْبَیْتِ لَمْ یَرْفَعْ قَدَمًا ، وَلَمْ یَضَعْ أُخْرَی ، إِلاَّ کُتِبَتْ لَہُ بَہَا حَسَنَۃٌ ، وَحُطَّتْ عَنْہُ بَہَا خَطِیئَۃٌ ، وَرُفِعَتْ لَہُ بِہَا دَرَجَۃٌ ، وَسَمِعْتُہُ یَقُولُ : مَنْ أَحْصَی سُبُوعًا کَانَ کَعَدْلِ رَقَبَۃٍ۔ (ترمذی 959۔ احمد 2/95)",,,12806,,
12807,"حدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ حُرَیْثِ بْنِ السَّائِبِ ، عَنْ مُحَمَّدِ بْنِ الْمُنْکَدِرِ ، عَنْ أَبِیہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ طَافَ بِالْبَیْتِ سُبُوعًا لَمْ یَلْغُ فِیہِ ، کَانَ کَعَدْلِ رَقَبَۃٍ یُعْتِقُہَا۔\n\n(طبرانی 845۔ حاکم 457)",,,12807,,
12808,"حدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ الرُّؤَاسِیُّ ، عَنِ الْحَسَنِ بْنِ صَالِحٍ ، عَنْ مُطَرِّفٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ عَبْدِ اللہِ بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : مَنْ طَافَ بِالْبَیْتِ خَمْسِینَ سُبُوعًا ، خَرَجَ مِنَ الذُّنُوبِ کَیَوْمِ وَلَدَتْہُ أُمُّہُ۔",,,12808,,
12809,"حدَّثَنَا أَبُو الأَحْوَصِِ ، عَنِ الْعَلاَئِ بْنِ الْمُسَیَّبِ ، عَنْ عَطَائٍ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو قَالَ : مَنْ طَافَ بِالْبَیْتِ سُبُوعًا ، وَصَلَّی رَکْعَتَیْنِ ، کَانَ مِثْلَ یَوْمِ وَلَدَتْہُ أُمُّہُ۔",,,12809,,
12810,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ، قَالَ : مَنْ طَافَ الْبَیْتَ کَانَ کَعَدْلِ رَقَبَۃٍ۔",,,12810,,
12811,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَبْدِ الْمَلِکِ بْنِ أَبِی سُلَیْمَانَ ، عَنْ رَجُلٍ قَدْ سَمَّاہُ ، قَالَ : قَالَ أَبُو سَعِیدٍ : لأَنْ أَطُوفَ بِالْبَیْتِ طَوَافًا ، أَحَبُّ إلَیَّ مِنْ أَنْ أَعْتِقَ طَہْمَانَ۔",,,12811,,
12812,حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ أَبِی سُلَیْمَانَ ، عَنْ مَوْلًی لأَبِی سَعِیدٍ ، عَنْ أَبِی سَعِیدٍ ؛ بِمِثْلِ حَدِیثِ أَبِی مُعَاوِیَۃَ۔,,,12812,,
12813,"قَالَ ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ مُجَاہِدٍ ، قَالَ : طَوَافٌ ، أَوِ الطَّوَافُ أَفْضَلُ مِنْ عُمْرَۃٍ بَعْدَ الْحَجِّ۔",,,12813,,
12814,حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّ ابْنَ عَامِرٍ أَحْرَمَ مِنْ خُرَاسَانَ۔,,,12814,,
12815,"حدَّثَنَا وَکِیعٌ ، عَنْ عُیَیْنَۃَ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِیہِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَمْرِو بْنِ الْعَاصِ ، قَالَ : حجَجْتُ مَرَّۃً ، فَوَافَقْتُ عُثْمَانَ بْنَ أَبِی الْعَاصِ ، فَأَحْرَمَ مِنَ الْمَنْجَشانیۃ ، وَہِیَ قَرِیبَۃٌ مِنَ الْبَصْرَۃِ۔",,,12815,,
12816,"حدَّثَنَا أَزْہَرُ السَّمَّانُ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ: خَرَجْنَا إلَی مَکَّۃَ وَمَعَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ، فَأَحْرَمْنَا مِنَ الدَّارَاتِ۔",,,12816,,
12817,حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ أَیُّوبَ ، عَنِ ابْنِ سِیرِینَ ؛ أَنْ مُسْلِمَ بْنَ یَسَارٍ أَحْرَمَ مِنَ الضَّرِیَّۃ۔,,,12817,,
12818,حدَّثَنَا ابْنُ عُلیۃ، عَنِ ابْنِ أَبِی عَرُوبَۃَ، عَنْ قَتَادَۃَ، عَنِ الْحَسَنِ؛ أَنَّ عِمْرَانَ بْنَ الْحُصَیْنِ، أَحْرَمَ مِن الْبَصْرَۃِ۔,,,12818,,
12819,حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ أَحْرَمَ مِنْ بَیْتِ الْمَقْدِسِ۔,,,12819,,
12820,حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ سُوقَۃَ ، عَنْ رَجُلٍ لَمْ یُسَمِّہِ ؛ أَنَّ أبَا مَسْعُودٍ أَحْرَمَ مِنَ السِّیْلِحِینَ۔,,,12820,,
12821,"حدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یُحِبُّونَ لِلرَّجُلِ أَوَّلَ مَا یَحُجُّ أَنْ یُہِلَّ مِنْ بَیْتِہِ۔",,,12821,,
12822,حدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ سُفْیَانَ ، عَنِ الْحَسَنِ بْنِ عَمْرٍو الْفُقَیْمِیِّ ، عَنْ حَمْزَۃَ الْقُرَشِیِّ ، عَنْ أَبِیہِ ؛ أَنَّ ابْنَ عَبَّاسٍ أَحْرَمَ مِنَ الشَّامِ فِی بَرْدٍ شَدِیدٍ۔,,,12822,,
12823,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ ہِلاَلِ بْنِ خَبَّابٍ ، عَنْ أَبِیہِ ، قَالَ : خَرَجْت مَعَ سَعِیدِ بْنِ جُبَیْرٍ مُحْرِمًا مِنَ الْکُوفَۃِ۔",,,12823,,
12824,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ خَیْثَمَۃَ ، عَنِ الْحَارِثِ بْنِ قَیْسٍ ، قَالَ : خَرَجْت فِی نَفَرٍ مِنْ أَصْحَابِ عَبْدِ اللہِ نُرِیدُ مَکَّۃَ ، فَلَمَّا خَرَجْنَا مِنَ الْبُیُوتِ حَضَرَتِ الصَّلاَۃُ ، فَصَلَّوْا رَکْعَتَیْنِ ، ثُمَّ أَہَلُّوا فَأَہْلَلْتُ مَعَہُمْ ، وَلَمْ أََکُنْ أُرِیدُ ، وَلَکِنِّی کَرِہْتُ الْخِلاَفَ۔",,,12824,,
12825,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ الأَسْوَدُ یُحْرِمُ مِنْ بَیْتِہِ۔",,,12825,,
12826,"حدَّثَنَا وَکِیعٌ ، عَنِ الْحَکَمِ بْنِ عَطِیَّۃَ ، قَالَ : أَخْبَرَنِی مَنْ رَأَی قَیْسَ بْنَ عُبَادٍ أَحْرَمَ مِنْ مِرْبَدِ الْبَصْرَۃِ۔",,,12826,,
12827,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ عَلْقَمَۃُ إذَا خَرَجَ حَاجًّا ، أَحْرَمَ مِنَ النَّجَفِ وَقَصَرَ ، وَکَانَ الأَسْوَدُ یُحْرِمُ مِنَ الْقَادِسِیَّۃِ۔",,,12827,,
12828,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی الْجُوَیْرِیَۃِ ، قَالَ : رَأَیْتُ الأَسْوَدَ أَحْرَمَ مِنْ بَاجُمَیْرَی ، قَرْیَۃٍ مِنْ قُرَی السَّوَادِ۔",,,12828,,
12829,"حدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، قَالَ : رَأَیْتُ الأَسْوَدَ أَحْرَمَ مِنَ الْکُوفَۃِ۔",,,12829,,
12830,"حدَّثَنَا وَکِیعٌ ، عَنْ عُمَارَۃَ بْنِ زَاذَانَ ، عَنْ مَکْحُولٍ الأَزْدِیِّ ، قَالَ : قُلْتُ لابْنِ عُمَرَ : الرَّجُلُ یُحْرِمُ مِنْ سَمَرْقَنْدَ ، وَمِنَ الْبَصْرَۃِ ، وَمِنَ الْکُوفَۃِ ، فَقَالَ : یَا لَیْتَنَا نَنْفَلِتُ مِنَ الْوَقْتِ الَّذِی وُقِّتَ لَنَا۔",,,12830,,
12831,"حدَّثَنَا وَکِیعٌ ، عَنْ أَبِی الْعُمَیْسِ ، قَالَ : خَرَجْتُ مَعَ الْقَاسِمِ ، فَأَحْرَمَ مِنَ الرَّبَذَۃِ۔",,,12831,,
12832,حدَّثَنَا وَکِیعٌ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، عَنِ ابن أَبِی لَیْلَی ؛ أَنَّ عَلِیًّا أحْرَمَ مِنَ الْمَدِینَۃِ۔,,,12832,,
12833,"حدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَشْعَثَ بْنِ أَبِی الشَّعْثَائِ ، قَالَ : رَأَیْتُ الْحَارِثَ بْنَ سُوَیْد التَّیْمِیَّ ، وَعَمْرَو بْنَ مَیْمُونٍ أَحْرَمَا مِنَ الْکُوفَۃِ۔",,,12833,,
12834,"حدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ عَبْدِ اللہِ بْنِ سَلِمَۃَ ؛ أَنَّ عَلِیًّا سُئِلَ عَنْ قَوْلِ اللہِ عَزَّ وَجَلَّ : (وَأَتِمُّوا الْحَجَّ وَالْعُمْرَۃَ لِلَّہِ) قَالَ : أَنْ تُحْرِمَ مِنْ دُوَیْرَۃِ أَہْلِک۔",,,12834,,
12835,"حدَّثَنَا وَکِیعٌ ، عَنْ ثَوْرٍ ، عَنْ سُلَیْمَانَ بْنِ مُوسَی ، عَنْ طَاوُوسٍ ، قَالَ : إِتْمَامُہُمَا إفْرَادُہُمَا ، مُؤْتَنِفَتَانِ مِنْ أَہْلِک۔",,,12835,,
12836,حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ، عَنِ الْحَسَنِ بْنِ عَمْرٍو، عَنْ أَبی حَمْزَۃَ الْقُرَشِیّ ، عَنْ أَبِیہِ ، عَنِ ابْنِ عَبَّاسٍ؛ أَنَّہُ أَحْرَمَ مِنَ الشَّامِ فِی شِتَائٍ شَدِیدٍ۔,,,12836,,
12837,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ سُلَیْمَانَ بْنِ سُحَیْمٍ ، عَنْ أُمِّ حَکِیمٍ بِنْتِ أُمَیَّۃَ ، عَنْ أُمِّ سَلَمَۃَ ، قَالَتْ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : مَنْ أَہَلَّ بِعُمْرَۃٍ مِنْ بَیْتِ الْمَقْدِسِ غُفِرَ لَہُ۔\n\n(ابوداؤد 1738۔ احمد 6/299)",,,12837,,
12838,حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّ ابْنَ عَامِرٍ أَحْرَمَ مِنْ خُرَاسَانَ ، فَعَابَ ذَلِکَ عَلَیْہِ عُثْمَانُ بْنُ عَفَّانَ وَغَیْرُہُ ، وَکَرِہُوہ۔,,,12838,,
12839,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ التَّیْمِیِّ ، عَنْ أَبِیہِ ، عَنْ أَبِی ذَرٍّ ، قَالَ : اِسْتَمْتِعُوا بِثِیَابِکُمْ ، فَإِنَّ رِکَابَکُمْ لاَ تُغْنِی عَنْکُمْ مِنَ اللہِ شَیْئًا۔",,,12839,,
12840,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ عَلْقَمَۃُ یَسْتَمْتِعُ مِنْ ثِیَابِہِ۔",,,12840,,
12841,"حدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنْ شَیْخٍ یُقَالُ لَہُ : مُسْلِمٌ ؛ أَنَّ عُمَرَ رَأَی رَجُلاً قَدْ أَحْرَمَ مِنْ قَطْرٍ سَیِّئَ الْہَیْئَۃِ ، فَقَالَ : اُنْظُرُوا إلَی مَا صَنَعَ ہَذَا بِنَفْسِہِ ، وَقَدْ یَسَّرَ اللَّہُ عَلَیْہِ۔",,,12841,,
12842,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ؛ أَنَّ عِمْرَانَ بْنَ حُصَیْنٍ أَحْرَمَ مِنَ الْبَصْرَۃِ ، فَقَدِمَ عَلَی عُمَرَ ، فَأَغْلَظَ لَہُ وَقَالَ : یَتَحَدَّثُ النَّاسُ أَنَّ رَجُلاً مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَحْرَمَ مِنْ مِصْرَ مِنَ الأَمْصَارِ۔",,,12842,,
12843,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنِ مُسْلِمٍ أَبِی سَلْمَانَ؛ أَنَّ رَجُلاً أَحْرَمَ مِنَ الْکُوفَۃِ ، فَرَآہُ عُمَرُ سَیِّئَ الْہَیْئَۃِ ، فَأَخَذَ بِیَدِہِ وَجَعَلَ یَدُورُ بِہِ فِی الْحِلَقِ ، وَیَقُولُ : اُنْظُرُوا إلَی مَا صَنَعَ ہَذَا بِنَفْسِہِ ، وَقَدْ وَسَّعَ اللَّہُ عَلَیْہِ۔",,,12843,,
12844,"حدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مِسْکِینُ أَبُو ہُرَیْرَۃَ ، قَالَ : سَمِعْتُ مُجَاہِدًا وَسَأَلَہُ رَجُلٌ : أَیُّہُمَا أَفْضَلُ أُحْرِمُ مِنْ بَیْتِی ، أَوْ مِنْ مَسْجِدِ قَوْمِی ، أَوْ مِنْ مَسْجِدِ مِصْرِی ، أَوْ مِنَ الْوَقْتِ ؟ فَقَالَ مُجَاہِدٌ : إنِّی لأَحْرِمُ یَوْمَ التَّرْوِیَۃِ ، فَأَخَافُ أَنْ لاَ أُحِلَّ حَتَّی أُحْرِجَ إِحْرَامِی۔",,,12844,,
12845,"حدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إذَا قلّد الْہَدْیُ ،وَصَاحِبُہُ یُرِیدُ الْعُمْرَۃَ ، أَوِ الْحَجَّ فَقَدْ أَحْرَمَ۔",,,12845,,
12846,"حدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا قلّد الْہَدْیَُ ، وَصَاحِبُہُ یُرِیدُ الإِحْرَامَ ، فَقَدْ وَجَبَ الإِحْرَامُ۔",,,12846,,
12847,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : رَأَیْتُ رَجُلاً بِالْقَادِسِیَّۃِ قَدْ قَلَّدَ ہَدْیَہُ ، وَعَلَیْہِ قبَاؤہُ وَعِمَامَتُہُ ، فَأَمَرْتُہُ أَنْ یَنْزِعَ عِمَامَتَہُ ، وَقَالَ : إنَّ الرَّجُلَ إذَا قَلَّدَ ، أَوْ جَلَّلَ فَقَدْ أَحْرَمَ۔",,,12847,,
12848,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ أَبِی الشَّعْثَائِ ، قَالَ : إذَا قَلَّدَ الْحَاجُّ أَحْرَمَ۔",,,12848,,
12849,"حدَّثَنَا أَبُو خَالِدٍ ، عَنْ الْحَجَّاجِ ، عَنْ عَطَائٍ ، وَابْنِ الأَسْوَدِ ، قَالاَ : لَیْسَ لَہُ أَنْ یُقَلِّدَ ، وَلاَ یُحْرِمَ ، إِلاَّ أَنْ یَشَائَ یَوْمًا ، أَوْ یَوْمَیْنِ۔",,,12849,,
12850,"حدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنِ ابْنِ عَوْنٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : رَأَی رَجُلاً قَدْ قَلَّدَ ، فَقَالَ : أَمَّا ہَذَا فَقَدْ أَحْرَمَ۔",,,12850,,
12851,"حدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، وَعَطَائٌ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : مَنْ جَلَّلَ ، أَوْ قَلَّدَ فَقَدْ وَجَبَ عَلَیْہِ الإِحْرَامُ۔",,,12851,,
12852,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَبِیبِ بْن أَبِی ثَابِتٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : مَنْ قَلَّدَ ، أَوْ جَلَّلَ ، أَوْ أَشْعَرَ ، فَقَدْ أَحْرَمَ۔",,,12852,,
12853,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، وَسُلَیْمَانَ بْنِ یَسَارٍ قَالاَ : خَرَجَ سَعْدُ بْنُ قَیْسٍ ، حَتَّی إذَا کَانَ بِذِی الْحُلَیْفَۃِ وَامْرَأَتُہُ تُرَجِّلُہُ ، إذَا ہُوَ بِبَدَنَتِہِ قَدْ قُلِّدَتْ ، فَنَزَعَ رَأْسَہُ مِنْ یَدِ الْمَرْأَۃِ ، وَقَالَ : مَنْ قَلَّدَ ہَذِہِ الْبُدْنَ تَمَّ عَلَی إحْرَامِہِ۔",,,12853,,
12854,"حدَّثَنَا مُعْتَمِرٌ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وطَاوُوسٍ ، وَمُجَاہِدٍ ، قَالُوا : إذَا قَلَّدَ ہَدْیَہُ ، أَوْ جَلَّلَہُ وَہُوَ یُرِیدُ الإِحْرَامَ ، فَقَدْ أَحْرَمَ۔",,,12854,,
12855,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ حَبِیبِ بْنِ أَبِی ثَابِتٍ ، عَنْ مَیْمُونِ بْنِ أبی شَبِیبٍ قَالَ : إذَا قَلَّدَ ، أَوْ جَلَّلَ، أَوْ أَشْعَرَ فَقَدْ أَحْرَمَ۔",,,12855,,
12856,"حدَّثَنَا غُنْدَرٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ سُئِلَ عَنِ الرَّجُلِ یُشْعِرُ الْہَدْیَ ؟ فَقَالَ : إذا أَشْعَرَ الْہَدْیَ، وَقَلَّدَ فِی أَشْہُرِ الْحَجِّ ، فَقَدْ وَجَبَ عَلَیْہِ الْحَجُّ ، وَإِنْ فَعَلَ ذَلِکَ فِی غَیْرِ أَشْہُرِ الْحَجِّ لَمْ یجِبْ عَلَیْہِ۔",,,12856,,
12857,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ حَمَّادًا عَنِ الرَّجُلِ یُقَلِّدُ بَدَنَتَہُ ؟ قَالَ : إِنْ شَائَ لَمْ یُحْرِمْ۔",,,12857,,
12858,"حدَّثَنَا ابْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا عُبَیْدُ اللہِ بْنُ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : مَنْ قَلَّدَ فَقَدْ أَحْرَمَ۔",,,12858,,
12859,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عَنْ عَائِشَۃَ ، قَالَتْ : کُنْت أَفْتِلُ الْقَلاَئِدَ لِہَدْیِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَیُقَلِّدُ ہَدْیَہُ ، ثُمَّ یَبْعَثُ بِہِ ، ثُمَّ یُقِیمُ ، لاَ یَجْتَنِبُ شَیْئًا مِمَّا یَجْتَنِبُ الْمُحْرِمُ۔ (بخاری1702۔ مسلم 365)",,,12859,,
12860,حدَّثَنَا غُنْدَرٌ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسٍ ؛ أَنَّہُ کَانَ یَبْعَثُ بِالْہَدْیِ ، ثُمَّ لاَ یُمْسِکُ عَنْ شَیْئٍ مِمَّا کَانَ یُمْسِکُ عَنْہُ الْمُحْرِمُ۔,,,12860,,
12861,"حدَّثَنَا غُنْدَرٌ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : مَنْ بَعَثَ بِہَدْیِہِ ، فَإِنَّہُ لاَ یُمْسِکُ عَنْ شَیْئٍ مِمَّا یُمْسِکُ عَنْہُ الْمُحْرِمُ ، إِلاَّ لَیْلَۃَ جَمْعٍ ، فَإِنَّہُ یُمْسِکُ عَنِ النِّسَائِ۔",,,12861,,
12862,"حدَّثَنَا غُنْدَرٌ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یُفْتِی بِذَلِکَ ، وَیَقُولُ : لاَ یُمْسِکُ عَنْ شَیْئٍ مِمَّا یُمْسِکُ عَنْہُ الْمُحْرِمُ۔",,,12862,,
12863,"حدَّثَنَا ابْنُ عُیَیْنَۃَ، عَنْ یَحْیَی بْنِ سَعِیدٍ، عَنْ عَمْرَۃَ، عَنْ عَائِشَۃَ، قَالَتْ: إنَّمَا یُحْرِمُ مَنْ أَہَلَّ، وَمَنْ لَبَّی۔",,,12863,,
12864,"حدَّثَنَا ابْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، قَالَ : بَعَثَ مَعِیْ عَبْدُ اللہِ بِہَدْیِہِ ، وَلَمْ یُحْرِمْ۔",,,12864,,
12865,حدَّثَنَا غُنْدَرٌ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، عَنْ عَبْدِ اللہِ ؛ أَنَّہُ کَانَ یَبْعَثُ بِالْہَدْیِ ، وَلاَ یُمْسِکُ عَمَّا یُمْسِکُ عَنْہُ الْمُحْرِمُ۔,,,12865,,
12866,"حدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ جَعْفَرِ بْنِ مُحَمَّدٍ ، عَنْ أَبِیہِ ؛ أَنَّ عُمَرَ ، وَعَلِیًّا ، وَابْنَ عَبَّاسٍ ، کَانُوا یَقُولُونَ فِی الرَّجُلِ یُرْسِلُ بِبَدَنَتِہِ : إِنَّہُ یُمْسِکُ عَمَّا یُمْسِکُ عَنْہُ الْمُحْرِمُ ، لَیْسَ أَنْ لاَ یُلَبِّی ، قَالَ جَعْفَرٌ : یُوَاعِدُہُمْ یَوْمًا ، فَإِذَا کَانَ ذَلِکَ الْیَوْمُ الَّذِی یُوَاعِدُہُمْ أَنْ یُشْعِرَ ، أَمْسَکَ عَمَّا یُمْسِکُ عَنْہُ الْمُحْرِمُ۔",,,12866,,
12867,حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ؛ أَنَّ ابْنَ عُمَرَ کَانَ إذَا بَعَثَ بِالْہَدْیِ ، یُمْسِکُ عَمَّا یُمْسِکُ عَنْہُ الْمُحْرِمُ ، غَیْرَ أَنْ لاَ یُلَبِّیَ۔,,,12867,,
12868,"حدَّثَنَا الثَّقَفِیُّ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، قَالَ : أَخْبَرَنِی مُحَمَّدُ بْنُ إبْرَاہِیمَ ، أَنَّ رَبِیعَۃَ بْنَ عَبْدِ اللہِ بْنِ الْہَدِیرِ أَخْبَرَہُ ؛ أَنَّہُ رَأَی ابْنَ عَبَّاسٍ وَہُوَ أَمِیرٌ عَلَی الْبَصْرَۃِ ، فِی زَمَانِ عَلِیِّ بْنِ أَبِی طَالِبٍ ، مُتَجَرِّدًا عَلَی مِنْبَرِ الْبَصْرَۃِ ، فَسَأَلَ النَّاسَ عَنْہُ ؟ فَقَالوا : إِنَّہُ أَمَرَ بِہَدْیِہِ أَنْ یُقَلَّدَ ، فَلِذَلِکَ تَجَرَّدَ ، فَلَقِیتُ ابْنَ الزُّبَیْرِ ، فَذَکَرْتُ ذَلِکَ لَہُ ، فَقَالَ : بِدْعَۃٌ وَرَبِّ الْکَعْبَۃِ۔",,,12868,,
12869,"حدَّثَنَا عَبْدُ الأَعْلَی بْنُ عَبْدِ الأَعْلَی، عَنْ ہِشَامٍ، عَنْ مُحَمَّدٍ، قَالَ: إذَا بَعَثَ الرَّجُلُ بِالْہَدْیِ، أَمَرَ الَّذِی یَبْعَثُ بِہِ مَعَہُ أَنْ یُقَلِّدَ یَوْمَ کَذَا وَکَذَا مِنْ ذَلِکَ الْیَوْمِ ، ثُمَّ یُمْسِکُ عَنِ أَشیَائٍ مِمَّا یُمْسِکُ عَنْہَا الْمُحْرِمُ۔",,,12869,,
12870,"حدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ قَتَادَۃَ ، عَنْ مُعَاذََۃَ ، عَنْ عَائِشَۃَ ، قَالَتْ : حَلَّتِ الْعُمْرَۃُ الدَّہْرَ ، إِلاَّ ثَلاَثَۃَ أَیَّامٍ؛ یَوْمَ النَّحْرِ ، وَیَوْمَیْنِ مِنْ أَیَّامِ التَّشْرِیقِ۔",,,12870,,
12871,"حدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ؛ أَنَّہُ سُئِلَ عَنِ الْعُمْرَۃِ ؟ فَقَالَ : إذَا مَضَتْ أَیَّامُ التَّشْرِیقِ ، فَاعْتَمِرْ مَتَی شِئْتَ إلَی قَابِلٍ۔",,,12871,,
12872,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، قَالَ : قَالَ عَلِیٌّ : فِی کُلِّ شَہْرٍ عُمْرَۃٌ ، وَقَالَ سَعِیدُ بْنُ جُبَیْرٍ : فِی کُلِّ سَنَۃٍ عُمْرَۃٌ۔",,,12872,,
12873,"حدَّثَنَا عَبَّادٌ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ عِکْرِمَۃَ ، قَالَ : اعْتَمِرْ مَا أَمْکَنَکَ الْمُوسَی۔",,,12873,,
12874,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی حُسَیْنٍ ، عَنْ بَعْضِ وَلَدِ أَنَسِ بْنِ مَالِکٍ ، قَالَ : کَانَ أَنَسُ بْنُ مَالِکٍ یَعْتَمِرُ ہَاہنَا بِمَکَّۃَ ، وَکُلَّمَا حَمَّمَ رَأْسُہُ خَرَجَ فَاعْتَمَرَ۔",,,12874,,
12875,حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَعْتَمِرُ فِی کُلِّ سَنَۃٍ عُمْرَۃً ، إِلاَّ عَامَ الْقِتَالِ ، فَإِنَّہُ اعْتَمَرَ فِی شَوَّالٍ وَفِی رَجَبٍ۔,,,12875,,
12876,"حدَّثَنَا أَزْہَرُ السَّمَّانُ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : کَانَ لاَ یَرَی الْعُمْرَۃَ إِلاَّ فِی السَّنَۃِ مَرَّۃً۔",,,12876,,
12877,حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ، عَنِ ابْنِ جُرَیْجٍ، عَنْ صَدَقَۃَ، عَنِ الْقَاسِمِ؛ أَنَّہُ کَرِہَ أَنْ یُعْتَمَرَ فِی کُلِّ شَہْرٍ مَرَّتَیْنِ۔,,,12877,,
12878,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : مَا کَانُوا یَعْتَمِرُونَ فِی السَّنَۃِ ، إِلاَّ مَرَّۃً۔",,,12878,,
12879,"حدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ حَجَّاجٍ، قَالَ: سَأَلْتُ عَطَائً عَنِ الْعُمْرَۃِ فِی الشَّہْرِ مَرَّتَیْنِ؟ قَالَ: لاَ بَأْسَ۔",,,12879,,
12880,"حدَّثَنَا حَفْصٌ ، عَنْ عَمْرٍو قَالَ : کَانَ الْحَسَنُ لاَ یَرَی الْعُمْرَۃَ إِلاَّ فِی کُلِّ سَنَۃٍ۔",,,12880,,
12881,"حدَّثَنَا شَرِیکٌ ، عَنْ إبْرَاہِیمَ بْنِ مُہَاجِرٍ ، عَنْ مُجَاہِدٍ ، قَالَ : رَأَی ابْنُ عَبَّاسٍ رَجُلاً وَہُوَ یَسُبُّ امْرَأَتَہُ ، فَقَالَ : مَا لَکَ ؟ فَقَالَ : إنِّی أَمْذَیْتُ ، أَوْ أَمْنَیْتُ ، فَقَالَ ابْنُ عَبَّاسٍ : لاَ تََسُبَّہَا ، وَأَہْرِقْ لِذَلِکَ دَمًا۔",,,12881,,
12882,"حدَّثَنَا جَرِیرٌ، عَنْ أَبَانَ بْنِ تَغْلِبَ، عَنِ الْحَکَمِ، قَالَ: أَقْبَلَ رَجُلٌ مِنْ أَہْلِ الطَّائِفِ مُحْرِمًا بِحَجَّۃٍ ، فَرَأَی نِسْوَۃً فِی بُسْتَانٍ ، فَأَدَامَ النَّظَرَ إلَیْہِنَّ حَتَّی أَمْذَی ، فَسَأَلَ سَعِیدَ بْنَ جُبَیْرٍ ؟ فَقَالَ : أَہْرِقْ دَمًا ، وَتِمَّ حَجَّکَ۔",,,12882,,
12883,"حدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ، عَنْ ہُبَیْرَۃَ الضَّبِّیِّ، قَالَ: خَرَجْتُ إلَی مَکَّۃَ وَمَعِی امْرَأَتِی، فَحَدَّثْتہَا فَأَمْذَیْتُ، فَسَأَلْتُ عَطَائً ؟ فَقَالَ : شَاۃ۔",,,12883,,
12884,"حدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ یَفْسُدُ الْحَجُّ حَتَّی یَلْتَقِیَ الْخِتَانَانِ ، فَإِذَا الْتَقَی الْخِتَانَانِ فَسَدَ الْحَجُّ وَوَجَبَ الْغُرْمُ۔",,,12884,,
12885,"حدَّثَنَا أَبُو الأَحْوَصِِ، عَنْ زَیْدِ بْنِ جُبَیْرٍ، قَالَ: کُنْتُ عِنْدَ ابْنِ عُمَرَ قَاعِدًا، فَأَتَتْہُ امْرَأَۃٌ، فَقَالَتْ: إنِّی نَذَرْت أَنْ أَحُجَّ ، وَلَمْ أَحُجَّ قَبْلَ ہَذِہِ الْحَجَّۃِ قَطُّ ؟ قَالَ : ہَذِہِ حَجَّۃُ الإِسْلاَمِ ، فَالْتَمِسِی مَا تُوفِیَنَ بِہِ عَنْ نَذْرِک۔",,,12885,,
12886,"حدَّثَنَا حَفْصٌ ، عَنْ ہِشَامٍ ، عَنْ وَاصِلٍ مَوْلَی أَبِی عُیَیْنَۃَ ، قَالَ : حدَّثَنِی شَیْخٌ سَمِعَ ابْنَ عَبَّاسٍ ، وَأَتَتْہُ امْرَأَۃٌ ، فَقَالَتْ : إنِّی نَذَرْت أَنْ أَحُجَّ ، وَلَمْ أَحُجَّ حَجَّۃَ الإِسْلاَمِ ، فَقَالَ ابْنُ عَبَّاسٍ : قَضَیْتِہِمَا وَرَبِّ الْکَعْبَۃِ۔",,,12886,,
12887,"حدَّثَنَا عَبْدُ الْوَہَّابِ ، عَنْ خَالِدٍ ، عَنْ عِکْرِمَۃَ ؛ أَنَّ رَجُلاً نَذَرَ أَنْ یَحُجَّ ، وَلَمْ یَحُجَّ ، قَالَ : یُجْزِئُ عَنْہُ الْفَرِیضَۃَ وَالنَّذْرَ۔",,,12887,,
12888,"حدَّثَنَا الْمُحَارِبِیُّ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ؛ فِی رَجُلٍ کَانَتْ عَلَیْہِ یَمِینٌ فِی الْحَجِّ ، وَلَمْ یَحُجَّ حَجَّۃَ الإِسْلاَمِ ، فَیُسِّرلَہُ الْحَجُّ ، قَالَ : یُجْزِئُ مِنْہُمَا ، فَإِنْ قَدَرَ عَلَی شَیْئٍ فَلْیَحُجَّ۔",,,12888,,
12889,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی الرَّبِیعِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ (ح) وَعَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالاَ: یُجْزِئُہُ حَجَّۃُ الإِسْلاَمِ مِنْ حَجِّہِ وَنَذْرِہِ۔",,,12889,,
12890,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : قَالَ لَہُ رَجُلٌ : إنَّ عَلَیَّ نَذْرًا بِالْحَجِّ ، وَلَمْ أَحُجَّ حَجَّۃَ الإِسْلاَمِ ، فَبِأَیِّہِمَا أَبْدَأُ ؟ قَالَ : ابْدَأْ بِحَجَّۃِ الإِسْلاَمِ۔",,,12890,,
12891,"حدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی سُلَیْمَانَ ، قَالَ : سَمِعْتُ أَنْسَاً یَقُولُ فِی رَجُلٍ نَذَرَ أَنْ یَحُجَّ ، وَلَمْ یَحُجَّ حَجَّۃَ الإِسْلاَمِ ، قَالَ : یَبْدَأُ بِالْفَرِیضَۃِ۔",,,12891,,
12892,حدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ خُصَیْفٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَحْرَمَ دُبُرَ الصَّلاَۃِ۔,,,12892,,
12893,حدَّثَنَا حَفْصٌ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَحْرَمَ فِی دُبُرِ صَلاَۃِ الظُّہْرِ ، وَکَانَ الْحَسَنُ یَسْتَحِبُّ أَنْ یُحْرِمَ دُبُرَ الظُّہْرِ ، فَإِنْ لَمْ یَفْعَلْ فَفِی دُبُرِ صَلاَۃِ الْعَصْرِ۔,,,12893,,
12894,"حدَّثَنَا أَبُو خَالِدٍ، عَنِ ابْنِ جُرَیْجٍ، عَنِ ابْنِ سَابِطٍ، قَالَ: کَانَ سلَفُکَ یَسْتَحِبُّ التَّلْبِیَۃَ فِی أَرْبَعَۃِ مَوَاضِعَ؛ فِی دُبُرِ الصَّلاَۃِ ، وَإِذَا ہَبَطُوا وَادِیًا ، أَوْ عَلَوْہُ ، وَعِنْدَ انْضِمَامِ الرِّفَاقِ۔",,,12894,,
12895,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : تُسْتَحَبُّ التَّلْبِیَۃُ فِی مَوَاطِنَ ؛ فِی دُبُرِ الصَّلاَۃِ الْمَکْتُوبَۃِ، وَحِینَ تَصْعَدُ شَرَفًا ، وَحِینَ تَہْبِطُ وَادِیًا ، وَکُلَّمَا اسْتَوَی بِکَ بَعِیرُکَ قَائِمًا ، وَکُلَّمَا لَقِیتَ رُفْقَۃً۔",,,12895,,
12896,حدَّثَنَا شَرِیکٌ، عَنْ جَابِرٍ، عَنْ عَبْدِالرَّحْمَنِ بْنِ الأَسْوَد، عَنْ أَبِیہِ؛ أَنَّہُ کَانَ یُحْرِمُ فِی دُبُرِ الصَّلاَۃِ الْمَکْتُوبَۃِ۔,,,12896,,
12897,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ خَیْثَمَۃَ ، قَالَ : کَانُوا یَسْتَحِبُّونَ التَّلْبِیَۃَ عِنْدَ سِتٍّ ؛ دُبُرَ الصَّلاَۃِ، وَإِذَا اسْتَقَلَّتْ بِالرَّجُلِ رَاحِلَتُہُ ، وَإِذَا صَعِدَ شَرَفًا ، وَإِذَا ہَبَطَ وَادِیًا ، وَإِذَا لَقِیَ بَعْضُہُمْ بَعْضًا۔",,,12897,,
12898,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَبْدِ الْمَلِکِ ، قَالَ : سَأَلْتُ عَطَائً عَنِ التَّلْبِیَۃِ ، إذَا أَرَادَ الرَّجُلُ یُحْرِمُ ؟ قَالَ : إِنْ شِئْتَ فَفِی دُبُرِ الصَّلاَۃِ ، وَإِنْ شِئْتَ فَإِذَا انْبَعَثَتْ بِکَ النَّاقَۃُ تَبْدَأُ حِینَ تَرْکَبُ ، فَتَقُولُ : {سُبْحَانَ الَّذِی سَخَّرَ لَنَا ہَذَا ، وَمَا کُنَّا لَہُ مُقْرِنِینَ}۔",,,12898,,
12899,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ حَیَّانَ ، عَنْ أَبِی الشَّعْثَائِ جَابِرِ بْنِ زَیْدٍ ، قَالَ : إِنْ کَانَ بَعْضُہُمْ لَیُحْرِمُ وَہُوَ رَاکِبٌ ، وَإِنْ کَانَ بَعْضُہُمْ لَیُحْرِمُ وَہُوَ یَأْکُلُ۔",,,12899,,
12900,"حدَّثَنَا أَبُو عَامِرٍ الْعَقَدِیُّ ، عَنْ أَفْلَحَ ، قَالَ : کَانَ الْقَاسِمُ یُلَبِّی دُبُرَ کُلِّ صَلاَۃٍ ؛ تَطَوُّعٍ وَفَرِیضَۃٍ۔",,,12900,,
12901,"حدَّثَنَا عَبْدُ السَّلاَمِ بْنِ حَرْبٍ ، عَنْ أَیُّوبَ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ فِی الْمُحْرِمِ یَنْکَسِرُ ظُفُرُہُ ، قَالَ : إِنْ آذَاکَ فَارْمِ بِہِ عَنْکَ۔",,,12901,,
12902,"حدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : إِن کَانَت شَظِیّۃً فَہُوَ یَقْلِمُہَا۔",,,12902,,
12903,"حدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ خَالِدٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إذَا انْکَسَرَ ظُفُرُ الْمُحْرِمِ فَلْیَقُصَّہُ۔",,,12903,,
12904,"حدَّثَنَا جَرِیرٌ ، عَنْ یَزِیدَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : إذَا انْکَسَرَ ظُفُرُ الْمُحْرِمِ أَلْقَاہُ۔",,,12904,,
12905,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ اللہِ بْنِ أَبِی مَرْیَمَ ، قَالَ : اِشْتَکَیْتُ ظُفُرِی وَأَنَا مُحْرِمٌ ، فَآذَانِی فَقَطَعْتُہُ ، فَسَأَلْتُ سَعِیدَ بْنَ جُبَیْرٍ ، فَقَالَ : آذَاکَ ؟ فَقُلْتُ : نَعَمْ ، فَقَالَ : فَاقْطَعْہُ یَا ابْنَ أَخِی ، {یُرِیدُ اللَّہُ بِکُمُ الْیُسْرَ وَلاَ یُرِیدُ بِکُمُ الْعُسْرَ}۔",,,12905,,
12906,حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَعَطَائٍ ؛ فِی الْمُحْرِم إذَا انْکَسَرَ ظُفُرُہُ قَلَمَہُ مِنْ حَیْثُ انْکَسَرَ ، وَلَیْسَ عَلَیْہِ شَیْئٌ ، فَإِنْ قَلَمَہُ مِنْ غیر أَنْ یَنْکَسِرَ فَعَلَیْہِ دَمٌ۔,,,12906,,
12907,"حدَّثَنَا أَبُو دَاوُدَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حَمَّادٍ ، قَالَ : یَنْزِعُ الْمُحْرِمُ ظُفُرَہُ۔",,,12907,,
12908,"حدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : الْمُحْرِمُ یَبْجِسُ الْقُرْحَۃَ ، وَیَقطَعُ الظُّفُرَ ، وَیَقطَعُ اللَّحْمَ النَّاتِیء ، وَیَنْزِِعُ الضِّرْسَ ، وَیُدَاوِی الْقُرْحَۃَ۔",,,12908,,
12909,"حدَّثَنَا عَبَّادُ بْنُ العَوَّامِ ، عَنْ أَبِی حَنِیفَۃَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ؛ فِی الْمُحْرِمِ : یَبُطُّ الْجُرْحَ ، وَیَعْصِرُ الْقُرْحَۃَ ، وَیَقُصُّ الظُّفُرَ إذَا انْکَسَرَ ، وَیَجْبُرُ الْکَسْرَ۔",,,12909,,
12910,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : لاَ بَأْسَ أَنْ یَقْطَعَ الْمُحْرِمُ الْجِلْدَۃَ۔",,,12910,,
12911,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : لاَ بَأْسَ بِالسِّوَاکِ لِلْمُحْرِمِ۔",,,12911,,
12912,"حدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُوسٍ ، وَمُجَاہِدٍ ، قَالَ : کَانُوا یَسْتَحِبُّونَ السِّوَاکَ لِلْمُحْرِمِ۔",,,12912,,
12913,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَعَطَائٍ ، قَالاَ : لاَ بَأْسَ بِالسِّوَاکِ لِلْمُحْرِمِ۔",,,12913,,
12914,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : لاَ بَأْسَ أَنْ یَسْتَاکَ الْمُحْرِمُ۔",,,12914,,
12915,"حدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ، عَنْ أَبِی بَکْرٍ، قَالَ: قُلْتُ لِعِکْرِمَۃَ: ہَلْ یَسْتَاکُ الْمُحْرِمُ؟ قَالَ: نَعَمْ، السِّوَاکُ طَہَارَۃٌ۔",,,12915,,
12916,حدَّثَنَا وَکِیعٌ ، عَنِ ابن نافع ، عَنْ أَبِیِہِ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَسْتَاکَ وَہُوَ مُحْرِمٌ۔,,,12916,,
12917,"حدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، قَالَ : سَأَلْتُ مُحَمَّدَ بْنَ عَلِیٍّ ، وَعَامِرًا ، وَعَطَائً ، وَطَاوُوسًا ، وَمُجَاہِدًا ، وَسَالِمًا ، وَالْقَاسِمَ ، وَعَبْدَ الرَّحْمَنِ بْنَ الأَسْوَدِ ؟ فَلَمْ یَرَوْا بِہِ بَأْسًا۔",,,12917,,
12918,"حدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، وَمُجَاہِدٍ قَالاَ : إذَا اشْتَکَی الْمُحْرِمُ ضِرْسَہُ نَزَعَہُ ، وَإِذَا انْکَسَرَ نَزَعَہُ ۔ قَالَ مَنْصُورٌ : وَلاَ شَیْئَ عَلَیْہِ۔",,,12918,,
12919,"حدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : إِنِ اشْتَکَی الْمُحْرِمُ ضِرْسَہُ نَزَعَہُ إِنْ شَائَ۔",,,12919,,
12920,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَمَّنْ أَخْبَرَہُ عَنِ ابْنِ عَبَّاسٍ ، قَالَ : الْمُحْرِمُ یَنْزِعُ ضِرْسَہُ ، وَیُدَاوِی الْقُرْحَۃَ۔",,,12920,,
12921,"حدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ عَنْبَسَۃَ قَاضِی الرَّیِّ ، عَنِ ابْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ؛ فِی مُحْرِمٍ نَزَعَ ضِرْسَہُ ، قَالَ : عَلَیْہِ دَمٌ۔",,,12921,,
12922,"حدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : یَنْزِعُ الضِّرْسَ ، یَعْنِی الْمُحْرِمَ۔",,,12922,,
12923,"حدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ النُّعْمَانِ بْنِ مَالِکٍ ، قَالَ : تَمَتَّعْتُ فَأَتَیْتُ ابْنَ عَبَّاسٍ ، فَقُلْتُ لَہُ : إنِّی تَمَتَّعْتُ ، فَقَالَ : {مَا اسْتَیْسَرَ مِنَ الْہَدْیِ} ، فَقُلْتُ : شَاۃٌ ؟ فَقَالَ : شَاۃٌ۔",,,12923,,
12924,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ النُّعْمَانِ بْنِ قَیْسٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : {مَا اسْتَیْسَرَ مِنَ الْہَدْیِ} ، شَاۃٌ۔",,,12924,,
12925,"حدَّثَنَا یَحْیَی بْنُ سُلَیْمٍ الطَّائِفِیُّ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ (ح) وَعَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : {مَا اسْتَیْسَرَ مِنَ الْہَدْیِ} ، مَا بَیْنَ الرُّخْصِ إلَی الْغَلاَئِ۔",,,12925,,
12926,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : {مَا اسْتَیْسَرَ مِنَ الْہَدْیِ} : شَاۃٌ۔",,,12926,,
12927,"حدَّثَنَا ہُشَیْمٌ ، قَالَ : سَمِعْتُ الزُّہْرِیَّ ، وَسُئِلَ عَنْ {مَا اسْتَیْسَرَ مِنَ الْہَدْیِ} ؟ فَقَالَ : کَانَ ابْنُ عُمَرَ یَقُولُ : مِنَ الإِبِلِ وَالْبَقَرِ ، وَکَانَ ابْنُ عَبَّاسٍ یَقُولُ : مِنَ الْغَنَمِ۔",,,12927,,
12928,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، قَالَ : شَاۃٌ۔",,,12928,,
12929,"حدَّثَنَا عَبْدُاللہِ بْنُ نُمَیْرٍ، عَنْ إسْمَاعِیلَ، عَنْ وَبَرَۃَ، عَنِ ابْنِ عُمَرَ، قَالَ: إذَا قَرَنَ الرَّجُلُ الْحَجَّ وَالْعُمْرَۃَ، فَعَلَیْہِ بَدَنَۃٌ ، فَقِیلَ لَہُ : إنَّ ابْنَ مَسْعُودٍ کَانَ یَقُولُ : شَاۃٌ ؟ فَقَالَ ابْنُ عُمَرَ : الصِّیَامُ أَحَبُّ إلَیَّ مِنْ شَاۃٍ۔",,,12929,,
12930,"حدَّثَنَا عَبْدَۃُ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنِ الْقَاسِمِ ؛ أَنَّ عَائِشَۃَ ، وَابْنَ عُمَرَ کَانَا یَقُولاَنِ : الْہَدْیُ مِنَ الإِبِلِ وَالْبَقَرِ۔",,,12930,,
12931,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ أَبِی مَالِکٍ الأَشْجَعِی ، عَنْ مُحَمَّدٍ عُبَیْدِ بْنِ أَوسٍ ، عَنِ ابْنِ الزُّبَیْرِ ، قَالَ : ذَاتُ جَوفٍ مِنْ إبِلٍ ، أَوْ بَقَرٍ۔",,,12931,,
12932,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ ، قَالَ : قدْ تُسْتَیْسِرُ الْجَزُورُ وَالْبَقَرَۃُ۔",,,12932,,
12933,"حدَّثَنَا وَکِیعٌ ، عَنْ دَلْہَم بْنِ صَالِحٍ ، عَنْ أَبِی جَعْفَرٍ قَالَ : شَاۃٌ۔",,,12933,,
12934,"حدَّثَنَا وَکِیعٌ ، عَنِ البَخْتَری بْنِ الْمُخَتَارِ ، قَالَ : سَمِعْتُ عَطَائً یَقُولُ : شاۃ۔",,,12934,,
12935,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ، عَنْ أَبِی مَالِکٍ الأَشْجَعِیِّ ، قَالَ: سَمِعْتُ الشَّعْبِیَّ یَقُولُ: تُجْزِئُ شَاۃٌ فِی التَّمَتُّعِ۔",,,12935,,
12936,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَبِیبِ بْنِ أَبِی ثَابِتٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : {مَا اسْتَیْسَرَ مِنَ الْہَدْیِ} شَاۃٌ۔",,,12936,,
12937,"حدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ وَبَرَۃَ بن عَبْدِ الرَّحْمَنِ قَالَ : أَتَیْتُ ابْنَ عُمَرَ ، فَقُلْتُ : إنَّ عَلَیَّ ہَدْیًا ، فَمَا تَأْمُرُنِی ؟ فَقَالَ : بَدَنَۃً مِنَ الْبَقَرِ ، وَإِلاَّ فَإِنَّ صَوْمَ ثَلاَثَۃِ أَیَّامٍ ، وَسَبْعَۃٍ إذَا رَجَعْتَ إلَی أَہْلِکَ أَحَبُّ إلَیَّ مِنْ شَاۃٍ۔",,,12937,,
12938,"حدَّثَنَا حَفْصٌ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ عَلِیٍّ ، قَالَ : {مَا اسْتَیْسَرَ مِنَ الْہَدْیِ} : شَاۃٌ۔",,,12938,,
12939,"حدَّثَنَا أَبُو خَالِدٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ الْقَاسِمِ ؛ أَنَّ عَائِشَۃَ ، وَابْنَ عُمَرَ لَمْ یَکُونَا یَرَیَانِ {مَا اسْتَیْسَرَ مِنَ الْہَدْیِ} إِلاَّ مِنَ الإِبِلِ وَالْبَقَرِ ، وَکَانَ ابْنُ عَبَّاسٍ یَقُولُ : {مَا اسْتَیْسَرَ مِنَ الْہَدْیِ} شَاۃٌ۔",,,12939,,
12940,"حدَّثَنَا یَعْلَی ، وَابْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، عَنْ جَابِرٍ ، قَالَ : کُنَّا نَتَمَتَّعُ مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَنَذْبَحُ الْبَقَرَۃَ عَنْ سَبْعَۃٍ۔ (مسلم 355۔ ابوداؤد 2800)",,,12940,,
12941,"حدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : یُجْزِئُ الْمُتَمَتِّعَ أَنْ یُشَارَکَ فِی دَمٍ۔",,,12941,,
12942,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، قَالَ : تُجْزِئُ النَّاقَۃُ وَالْبَقَرَۃُ عَنْ سَبْعَۃٍ مُتَمَتِّعِینَ۔",,,12942,,
12943,"حدَّثَنَا أَبُو خَالِدٍ، عَنْ حَجَّاجٍ، عَنْ عَطَائٍ، قَالَ: یَشْتَرِکُ الْمَحْصُورُونَ وَالْمُتَمَتِّعُونَ فِی الْبَدَنَۃِ، عَنْ سَبْعَۃٍ۔",,,12943,,
12944,حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَعَطَائٍ ؛ أَنَّہُمَا کَانَا لاَ یَرَیَانِ بَأْسًا لِلْمُتَمَتِّعِ أَنْ یَدْخُلَ فِی شِرْکٍ فِی جَزُورٍ ، أَوْ بَقَرَۃٍ۔,,,12944,,
12945,"حدَّثَنَا غُنْدَرٌ، عَنْ شُعْبَۃَ، قَالَ: سَأَلْتُ الْحَکَمَ، وَحَمَّادًا عَنِ الْقَوْمِ یَشْتَرِکُونَ فِی الْہَدْیِ؟ فَکَرِہَا ذَلِکَ۔",,,12945,,
12946,"حدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، وَلَیْثٌ ، عَنْ مُجَاہِدٍ ؛ فِی الرَّجُلِ یَجْمَعُ بَیْنَ الْعُمْرَۃِ وَالْحَجِّ فَیُحْصَرُ ، قَالَ: یَبْعَثُ بِہَدْیٍ یَحِلُّ بِہِ ، ثُمَّ یَجِیئُ مِنْ قَابِلٍ بِمَا کَانَ أَہَلَّ بِہِ۔",,,12946,,
12947,"حدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، وَسَعِیدِ بْنِ جُبَیْرٍ قَالاَ : عَلَیْہِ عُمْرَتَانِ وَحَجَّۃٌ۔",,,12947,,
12948,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ حَمَّادٍ ؛ فِی رَجُلٍ أَہَلَّ بِعُمْرَۃٍ وَحَجَّۃٍ فَأُحْصِرَ ، قَالَ : یَبْعَثُ بِالْہَدْیِ ، فَإِذَا بَلَغَ الْہَدْیُ مَحِلَّہُ حَلَّ ۔ قَالَ : وَعَلَیْہِ حَجَّۃٌ وَعُمْرَتَانِ ، وَقَالَ الْحَکَمُ : عَلَیْہِ حَجَّۃٌ وَثَلاَثُ عُمَرَ۔",,,12948,,
12949,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : ہَدْیَانِ۔",,,12949,,
12950,حدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، مِثْلَہُ۔,,,12950,,
12951,"حدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، وَمَنْصُورٌ ، عَنْ مُجَاہِدٍ ، قَالَ : یَبْعَثُ بِہَدْیٍ وَیَحِلُّ بِہِ۔",,,12951,,
12952,"حدَّثَنَا ہُشَیْمٌ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : عَلَیْہِ ہَدْیٌ۔",,,12952,,
12953,"حدَّثَنَا مُعْتَمِرٌ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، وَعَطَائٍ قَالاَ : إذَا جَمَعَ بَیْنَ عُمْرَۃٍ وَحَجٍّ فَحَبَسَہُ مَرَضٌ ، أَجْزَأَہُ لَہُمَا ہَدْیٌ وَاحِدٌ۔",,,12953,,
12954,"حدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ کَانَ یَقُولُ : مَنْ أَدْرَکَہُ الْمَسَائُ بِمِنًی ، وَہُوَ فِی الْیَوْمِ الثَّانِی مِنْ أَیَّامِ التَّشْرِیقِ ، فَلاَ یَنْفِرُ حَتَّی الْغَدِ مِنَ الْیَوْمِ الثَّالِثِ۔",,,12954,,
12955,حدَّثَنَا ہُشَیْمٌ ، عَنْ مَنْصُورٍ ، وَیُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَقُولُ ذَلِکَ۔,,,12955,,
12956,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، عَنْ جَابِرِ بْنِ زَیْدٍ ، أَنَّہُ کَانَ یَقُولُ : لاَ یَنْفِرُ حَتَّی یَکُونَ مِنَ الْغَدِ۔",,,12956,,
12957,"حدَّثَنَا ہُشَیْمٌ ، عَنْ عَبْدِ الْمَلِکِ ، وَحَجَّاجٍ ، عَنْ عَطَائٍ ، أَنَّہُ کَانَ یَقُولُ : یَنْفِرُ مَا لَمْ تَغِبِ الشَّمْسُ۔",,,12957,,
12958,"حدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، قَالَ : مَنْ أَمْسَی بِمِنًی یَوْمَ النَّفْرِ الأَوَّلِ ، وَہُوَ یُرِیدُ النَّفْرَ فِی ذَلِکَ الْیَوْمِ ، فَلاَ یَنْفِرُ حَتَّی الْغَدِ۔",,,12958,,
12959,"حدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حدَّثَنَا عُبَیْدُ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : إذَا أَدْرَکَہُ الْمَسَائُ فِی الْیَوْمِ الثَّانِی ، فَلاَ یَنْفِرُ حَتَّی الْغَدِ وَتَزُولَ الشَّمْسُ۔",,,12959,,
12960,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ طَاوُوسٍ ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: الطَّوَافُ بِالْبَیْتِ صَلاَۃٌ، وَلَکِنَّ اللَّہَ تَعَالَی أَحَلَّ فِیہِ الْمَنْطِقَ ، فَمَنْ نَطَقَ فَلاَ یَنْطِقُ إِلاَّ بِخَیْرٍ۔",,,12960,,
12961,حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ أَبِی سُلَیْمَانَ ، عَنْ مَوْلًی لأَبِی سَعِیدٍ ، عَنْ أَبِی سَعِیدٍ ، أَنَّہُ کَانَ یَأْمُرُ بَنِیہِ إذَا طَافُوا أَنْ لاَ یَلْغَوْا فِی طَوَافِہِمْ ، وَلاَ یَہْجُروا ، وَلاَ یَقْضُوا حَاجَۃً ، وَلاَ یُکَلِّمُوا أَحَدًا حَتَّی یَقْضُوا طَوَافَہُمْ إنِ اسْتَطَاعُوا۔,,,12961,,
12962,"حدَّثَنَا أَبُو سَعْدٍ مُحَمَّدِ بْنِ مَیْسَرَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : طُفْتُ وَرَائَ ابْنِ عُمَرَ ، وَابْنِ عَبَّاسٍ ، فَلَمْ أَسْمَعْ وَاحِدًا مِنْہُمَا یَتَکَلَّمُ فِی الطَّوَافِ۔",,,12962,,
12963,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : الطَّوَافُ بِالْبَیْتِ صَلاَۃٌ ، فَأَقِلُّوا الْکَلاَمَ فِیہِ۔",,,12963,,
12964,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ إِبْرَاہِیمَ بْنِ نَافِعٍ ، قَالَ : طُفْتُ مَعَ طَاوُوسٍ ، فَلَمْ أَسْمَعْہُ یَبْدَأُ إنْسَانًا بِالْکَلاَمِ ، إِلاَّ أَنْ یُکَلِّمَہُ فَیُجِیبَہُ۔",,,12964,,
12965,"حدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ مُوسَی بْنِ أَبِی الْفُرَاتِ ، قَالَ : قَالَ طَاوُوسٌ : إنِّی لأَعُدَّہَا غَنِیمَۃً ، أَنْ أَطُوفَ بِالْبَیْتِ سُبُوعًا لاَ یُکَلِّمُنِی أَحَدٌ۔",,,12965,,
12966,"حدَّثَنَا جَرِیرٌ ، عَنِ الشَّیْبَانِیِّ ، قَالَ : کُنْتُ أَطُوفُ مَعَ سَعِیدِ بْنِ جُبَیْرٍ ، وَہُوَ یُحَدِّثُنِی۔",,,12966,,
12967,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، قَالَ : کَانَ شُرَیْحٌ یَطُوفُ بِالْبَیْتِ فَسَأَلَہُ رَجُلٌ ، فَأَفْتَاہُ۔",,,12967,,
12968,"حدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ أَبِی سُلَیْمَانَ ، قَالَ : رَأَیْتُ سَعِیدَ بْنَ جُبَیْرٍ یَطُوفُ بِالْبَیْتِ ، یُحَدِّثُ أَصْحَابَہُ وَیُفْتِی۔",,,12968,,
12969,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، قَالَ : کَانَ مُجَاہِدٌ ، وَسَعِیدُ بْنُ جُبَیْرٍ ، وَعَلِیُّ بْنُ عَبْدِ اللہِ بْنِ الْعَبَّاسِ ، وَالْحُسَیْنُ بْنُ الْحَسَنِ ، وَأَبُو جَعْفَرٍ یَتَکَلَّمُونَ وَہُمْ یَطُوفُونَ بِالْبَیْتِ ، وَبَیْنَ الصَّفَا وَالْمَرْوَۃِ۔",,,12969,,
12970,"حدَّثَنَا عَائِذُ بْنُ حَبِیبٍ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ أَبِی الزُّبَیْرِ، عَنْ طَاوُوسٍ ، قَالَ: لَمَّا تَفَرَّقَ أَبُو مُوسَی وَعَمْرُو بْنُ الْعَاصِ عَنِ الْحُکُومَۃِ ، قَدِمَ أَبُو مُوسَی مُعْتَمِرًا ، فَکُنْتُ أَطُوفُ أَنَا وَہُوَ بِالْبَیْتِ إذَا عَرَضَ لَہُ رَجُلٌ ، فَقَالَ : یَا أَبَا مُوسَی ، ہَذِہِ الْفِتْنَۃُ الَّتِی کَانَتْ تُذْکَرُ ؟ قَالَ : مَا ہَذِہِ إِلاَّ حَیْصَۃٌ مِنْ حَیْصَاتِ الْفِتَنِ۔",,,12970,,
12971,"حدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنِ النَّضْرِ بْنِ مَعْبَدٍ ، قَالَ : رَأَیْتُ أَبَا قِلاَبَۃَ یَتَکَلَّمُ فِی الطَّوَافِ۔",,,12971,,
12972,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، قَالَ : لَقِیتُ أَبَا مَسْعُودٍ فَسَأَلْتُہُ وَہُوَ یَطُوفُ بِالْبَیْتِ ؟ فَقَالَ لِی ، ثُمَّ ذَکَرَ حَدِیثًا۔",,,12972,,
12973,"حدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ ، عَنْ عَلِیٍّ ، قَالَ : إذَا قَبَّلَ الْمُحْرِمُ امْرَأَتَہُ فَعَلَیْہِ دَمٌ۔",,,12973,,
12974,"حدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، قَالَ : عَلَیْہِ دَمٌ۔",,,12974,,
12975,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ مَعْمَرٍ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ قَالَ : عَلَیْہِ دَمٌ۔",,,12975,,
12976,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : عَلَیْہِ دَمٌ۔",,,12976,,
12977,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : عَلَیْہِ دَمٌ۔",,,12977,,
12978,"حدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ؛ فِی الْمُحْرِمِ یُقَبِّلُ امْرَأَتَہُ ، أَوْ یَغْمِزُ امْرَأَتَہُ لِشَہْوَۃٍ ، قَالَ : عَلَیْہِ دَمٌ۔",,,12978,,
12979,"حدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ ہِشَامٍ ، عَنْ عَطَائٍ ، قَالَ : إذَا قَبَّلَ ، أَوْ غَمَزَ فَعَلَیْہِ دَمٌ۔",,,12979,,
12980,"حدَّثَنَا عَبَّادُ ، عَنْ أَشْعَثَ ، عَنْ عَطَائٍ : مِثْلَہُ ، وَزَادَ فِیِہِ أَوْ جَرَّدَ۔",,,12980,,
12981,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : یَسْتَغْفِرُ اللَّہَ۔",,,12981,,
12982,"حدَّثَنَا شَبَابَۃُ ، عَنْ شُعْبَۃَ ، عَنْ مَنْصُورٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : عَلَیْہِ دَمٌ۔",,,12982,,
12983,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ خُثَیْمٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : عَلَیْہِ دَمٌ۔",,,12983,,
12984,"حدَّثَنَا أَبُو عَامِرٍ الْعَقَدِیُّ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : عَلَیْہِ دَمٌ۔",,,12984,,
12985,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ ہِشَامٍ ، عَنْ قَتَادَۃَ ، قَالَ : عَلَیْہِ دَمٌ۔",,,12985,,
12986,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ شَیْبَانَ ، عَنْ جَابِرٍ ، عَنِ الشَّعْبِیِّ ، وَعَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ قَالاَ : عَلَیْہِ دَمٌ۔",,,12986,,
12987,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ عِکْرِمَۃَ ، قَالَ : إذَا لَمَسَ الْمُحْرِمُ ، أَوْ غَمَزَ امْرَأَتَہُ ، فَعَلَیْہِ کَفَّارَۃٌ یَتَصَدَّقُ بِہَا۔",,,12987,,
12988,حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ فِی اللَّمْسَۃِ وَالْجَسَّۃِ مِنْ وَرَائِ الثَّوْبِ لَیْسَ فِیہَا شَیْئٌ ، وَفِی جَسَّاتٍ وَمَسَّاتٍ دَمٌ۔,,,12988,,
12989,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ سُئِلَ عَنْ رَجُلٍ بَاشَرَ وَہُوَ مُحْرِمٌ ؟ قَالَ : عَلَیْہِ بَدَنَۃٌ ، قُلْتُ : فَإِنْ أَنْزَلَ الْمَائَ الأَعْظَمَ ؟ قَالَ : کَانَ الْحَسَنُ یَقُولُ : ہُوَ بِمَنْزِلَۃِ الْمُجَامِعِ ، عَلَیْہِ الْحَجُّ مِنْ قَابِلٍ۔",,,12989,,
12990,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ غَیْلاَنَ بْنِ جَرِیرٍ ، قَالَ : کُنْتُ أَنَا وَحَکِیمُ بْنُ الدُّرَیْمِ ، فَأَتَانَا رَجُلٌ ، فَقَالَ : إنِّی وَضَعْتُ یَدِی مِنَ امْرَأَتِی مَوْضِعًا ، فَلَمْ أَرْفَعْہَا حَتَّی أَجْنَبْتُ ، فَقُلْنَا : مَا لَنَا بِہَا عِلْمٌ ، فَانْطَلِقُوا بِنَا إلَی عَلِیِّ بْنِ عَبْدِ اللہِ الْبَارِقِیِّ ، فَأَتَیْنَاہُ فَسَأَلْنَاہُ ؟ فَقَالَ : مَا لِی بِہَذَا عِلْمٌ ، فَبَیْنَا نَحْنُ کَذَلِکَ ، إذَا نَحْنُ بِجَابِرِ بْنِ زَیْدٍ ، فَقُلْتُ : ذَاکَ أَبُو الشَّعْثَائِ ، اِئْتِہِ فَسَلْہُ ، ثُمَّ ارْجِعْ إلَیْنَا فَأَخْبِرْنَا ، فَأَتَاہُ فَسَأَلَہُ ، ثُمَّ رَجَعَ إلَیْنَا ، یُعْرَفُ فِی وَجْہِہِ الْبِشْرُ ، فَقَالَ : إِنَّہُ اسْتَکْتَمَنِی ، فَظَنَنَّا أَنَّہُ أَمَرَہُ بِدَمٍ۔",,,12990,,
12991,"حدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَعَطَائٍ ؛ فِی رَجُلٍ یَلْمِسُ امْرَأَتَہُ فَیُنْزِلُ ، قَالاَ : عَلَیْہِ بَدَنَۃٌ ، وَالْحَجُّ مِنْ قَابِلٍ۔",,,12991,,
12992,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ فِی مُحْرِمٍ بَاشَرَ حَتَّی أَنْزَلَ ، قَالَ : أَرَاہُ قَدْ وَجَبَ عَلَیْہِ مَا وَجَبَ عَلَی الْمُجَامِعِ۔",,,12992,,
12993,"حدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ بَأْسَ بِالْمِرْآۃِ لِلْمُحْرِمِ۔",,,12993,,
12994,"حدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ بَأْسَ أَنْ یَنْظُرَ فِیہَا ، یُمِیطُ عَنْہُ الأَذَی۔",,,12994,,
12995,حدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ لَمْ یَرَ بَأْسًا أَنْ یَنْظُرَ الْمُحْرِمُ فِی الْمِرْآۃِ۔,,,12995,,
12996,"حدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَمَّنْ حَدَّثَہُ عَنِ ابْنِ عَبَّاسٍ (ح) وَعَنْ حَجَّاجٍ ، عَنْ عَطَائٍ قَالاَ : لاَ بَأْسَ بِہِ۔",,,12996,,
12997,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرِو بْنِ مُسْلِمٍ ، عَنْ طَاوُوسٍ ، وَعِکْرِمَۃَ قَالاَ : لاَ بَأْسَ أَنْ یَنْظُرَ الْمُحْرِمُ فِی الْمِرْآۃِ۔",,,12997,,
12998,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : لاَ بَأْسَ أَنْ یَنْظُرَ الْمُحْرِمُ فِی الْمِرْآۃِ۔",,,12998,,
12999,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، قَالَ : حدَّثَنَا الزُّبَیْرُ بْنُ خِرِّیتٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : کَانَ ابْنُ عَبَّاسٍ لاَ یَرَی بَأْسًا لِلْمُحْرِمِ أَنْ یَحْلِقَ عَنِ الشَّجَّۃِ ، وَأَنْ یَنْظُرَ فِی الْمِرْآۃِ۔",,,12999,,
13000,"حدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ : لاَ یَنْظُرُ الْمُحْرِمُ فِی الْمِرْآۃِ ، وَلاَ یَدْعُو عَلَی أَحَدٍ وَإِنْ ظَلَمَہُ۔",,,13000,,
13001,حدَّثَنَا أَبُو عَامِرٍ الْعَقَدِیُّ ، عَنْ أَفْلَحَ ، عَنِ الْقَاسِمِ ، أَنَّہُ کَرِہَ أَنْ یَنْظُرَ الْمُحْرِمُ فِی الْمِرْآۃِ۔,,,13001,,
13002,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، عْن إبْرَاہِیمَ بْنِ عَبْدِ اللہِ بْنِ حُنَیْنٍ ، عَنْ أَبِیہِ ، قَالَ : اخْتَلَفَ ابْنُ عَبَّاسٍ وَالْمِسْوَرُ بْنُ مَخْرَمَۃَ فِی الْمُحْرِمِ یَغْسِلُ رَأْسَہُ ، قَالَ : فَأَرْسَلُونِی إلَی أَبِی أَیُّوبَ ، فَأَتَیْتُہُ وَہُوَ بَیْنَ قَرْنَیِ الْبِئْرِ یَغْتَسِلُ ، فَقُلْتُ : إنَّ ابْنَ أَخِیکَ ابْنَ عَبَّاسٍ أَرْسَلَنِی إلَیْکَ یَقُولُ : کَیْفَ رَأَیْتَ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَغْسِلُ رَأْسَہُ وَہُوَ مُحْرِمٌ ؟ فَأَخَذَ مِنَ الْمَائِ فَصَبَّہُ عَلَی رَأْسِہِ ، ثُمَّ أَقْبَلَ وَأَدْبَرَ ، ثُمَّ قَالَ: ہَکَذَا رَأَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَغْسِلُ رَأْسَہُ وَہُوَ مُحْرِمٌ ، فَرَجَعْتُ إلَیْہِمَا فَأَخْبَرْتُہُمَا بِقَوْلِہِ، فَقَالَ الْمِسْوَرُ : لاَ أُخَالِفُکَ أَبَدًا۔",,,13002,,
13003,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : قَالَ لِی عُمَرُ : تَعَالَ حَتَّی أُبَاقِیَک فِی الْمَائِ أَیُّنَا أَصْبَرُ ؟ وَنَحْنُ مُحْرِمُونَ۔ (بخاری 1840۔ ابوداؤد 1836)",,,13003,,
13004,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الْعَبَّاسِ بْنِ عَبْدِ اللہِ بْنِ مَعْبَدٍ ، عَنْ أَبِیہِ ، قَالَ : خَرَجْت مَعَ خَالَتِی مَیْمُونَۃَ فَلَبَّدْتُ بِعَسَلٍ رَأْسِی ، أَوْ بِغَرائٍ وَأَنَا مُحْرِمٌ ، فَشَقَّ عَلَیَّ فَسَأَلْتُہَا ؟ فَقَالَتْ : اغْمِسْ رَأْسَک فِی الْمَائِ مِرَارًا۔",,,13004,,
13005,"حدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ مُسْلِمٍ الْقُرِّیِّ ، قَالَ : قُلْتُ لابْنِ عَبَّاسٍ : أَصُبّ عَلَی رَأْسِی الْمَائَ وَأَنَا مُحْرِمٌ ؟ قَالَ : لاَ بَأْسَ بِہِ ، إنَّ اللَّہَ تَعَالَی یَقُولُ : (إنَّ اللَّہَ یُحِبُّ التَّوَّابِینَ وَیُحِبُّ الْمُتَطَہِّرِینَ)۔",,,13005,,
13006,"حدَّثَنَا جَرِیرٌ ، عَنْ عَطَائٍ ، عَنْ مُجَاہِدٍ ، قَالَ : لاَ بَأْسَ أَنْ یَغْتَسِلَ الْمُحْرِمُ فِی الْمَائِ۔",,,13006,,
13007,"حدَّثَنَا عَبَّادٌ ، عَنِ الْعَلاَئِ بْنِ الْمُسَیَّبِ ، عَنْ أَبِی أُمَامَۃَ التَّیْمِیِّ ، قَالَ : سَأَلْتُ ابْنَ عُمَرَ أَیَغْتَسِلُ الْمُحْرِمُ؟ فَقَالَ : وَہَلْ یَزِیدُہُ ذَلِکَ إِلاَّ شَعَثًا۔",,,13007,,
13008,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، قَالَ : لاَ بَأْسَ أَنْ یَغْسِلَ الْمُحْرِمُ رَأْسَہُ وَیَتَغَطَّسَ فِیہِ۔",,,13008,,
13009,"حدَّثَنَا غُنْدَرٌ ، عَنْ عُثْمَانَ بْنِ غِیَاثٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : الْمُحْرِمُ یَغْتَسِلُ بِالْمَائِ إِنْ شَائَ۔",,,13009,,
13010,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ أَنْ یَغْتَسِلَ الْمُحْرِمُ بِالْمَائِ مِنْ غَیْرِ جَنَابَۃٍ۔",,,13010,,
13011,"حدَّثَنَا عَبْدَۃُ، عَنْ عُبیْدِ اللہِ بْنِ عُمَرَ، قَالَ: صَبَبْتُ عَلَی سَالِمٍ مَائً وَہُوَ مُحْرِمٌ، فَنَہَانِی أَنْ أَصُبَّ عَلَی رَأْسِہِ۔",,,13011,,
13012,"حدَّثَنَا أبو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَن ، قَالَ : لاَ بَأْسَ أَنْ یَغْتَسِلَ الْمُحْرِمُ مِنْ غَیْرِ جَنَابَۃٍ۔",,,13012,,
13013,"حدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : کُنَّا نَکُونُ بِالْخَلِیجِ مِنَ الْبَحْرِ بِالْجُحْفَۃِ ، فَنَتَغَامَسُ فِیہِ ، وَعُمَرُ یَنْظُرُ إلَیْنَا ، فَمَا یَعِیبُ ذَلِکَ عَلَیْنَا وَنَحْنُ مُحْرِمُونَ۔",,,13013,,
13014,حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنْ حُسَیْنٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَخَّصَ فِی الثَّوْبِ الْمَصْبُوغِ لِلْمُحْرِمِ مَا لَمْ یَکُنْ لَہُ نَفْضٌ ، وَلاَ رَدْعٌ۔ (احمد 1/362۔ ابویعلی 2572),,,13014,,
13015,"حدَّثَنَا شَرِیکٌ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : أَحْرَمَ عَقِیلُ بْنُ أَبِی طَالِبٍ فِی ثَوْبَیْنِ وَرْدِیَّیْنِ ، فَرَآہُ عُمَرُ ، فَقَالَ : مَا ہَذَا ؟ فَقَالَ لَہُ عَلِیٌّ : إنَّ أَحَدًا لاَ یُعْلِمُنَا بِالسُّنَّۃِ۔",,,13015,,
13016,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ زِیَادِ بْنِ سَعْدٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : لاَ بَأْسَ بِالْمُضَرَّجِ لِلْمُحْرِمِ۔",,,13016,,
13017,حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنِ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، عَنْ أَبِیہِ أَنَّہُ کَانَ یَلْبَسُ الثِّیابَ الْمُوَرَّدَۃَ ، وَہُوَ مُحْرِمٌ۔,,,13017,,
13018,"حدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنْ عَبْدِ اللہِ بْنِ عُمَرَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، عَنْ عَبْدِ اللہِ بن عَبْدِ اللہِ ، قَالَ : کَانَ الْفِتْیَانُ یُحْرِمُونَ مَعَ ابْنِ عُمَرَ فِی الْمُوَرَّدَۃِ فَلاَ یَنْہَاہُمْ ، وَلاَ یُنْکِرُ عَلَیْہِمْ۔",,,13018,,
13019,"حدَّثَنَا یَحْیَی بْنُ یَمَانٍ، عَنْ سُفْیَانَ، عَنْ یَزِیدَ، عَنْ مِقْسَمٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: لاَ بَأْسَ بِالْمُوَرَّدَۃِ لِلْمُحْرِمِ۔",,,13019,,
13020,"حدَّثَنَا وَکِیعٌ ، عَنْ عُمَرَ بْنِ مُحَمَّدٍ ، قَالَ : رَأَیْتُ عَلَی سَالِمٍ ثَوْبًا مُوَرَّدًا ، یَعْنِی وَہُوَ مُحْرِمٌ۔",,,13020,,
13021,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، رَفَعَہُ ، قَالَ : لاَ یَلْبَسُ الْمُحْرِمُ ثَوْبٌ مَسَّہُ وَرْسٌ، وَلاَ زَعْفَرَانٌ۔ (بخاری 5794۔ احمد 2/4)",,,13021,,
13022,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، عَن عَائِشَۃَ ، قَالَتْ : یُکْرَہُ الثَّوْبُ الْمَصْبُوغُ بِالزَّعْفَرَانِ أَوْ الْمُشْبَعَۃِ بِالْعُصْفُرِ لِلرِّجَالِ وَالنِّسَائِ ، إِلاَّ أَنْ یَکُونَ ثَوْبًا غَسِیلاً۔",,,13022,,
13023,حدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ وَبَرَۃَ ، عَنِ ابْنِ عُمَرَ ، أَنَّ عُمَرَ نَہَی أَنْ یُحْرِمَ الْمُحْرِمُ فِی الثَّوْبِ الْمَصْبُوغِ بِالْوَرْسِ وَالزَّعْفَرَانِ۔,,,13023,,
13024,حدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وطَاوُوس ، وَمُجَاہِدٍ ؛ أَنَّہُمْ کَرِہُوا الْعُرُوقَ لِلْمُحْرِمِ۔,,,13024,,
13025,حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ أَنَّہُ کَرِہَ الْمُعَصْفَرَ لِلْمُحْرِمِ۔,,,13025,,
13026,حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَکْرَہُ أَنْ یُحْرِمَ الرَّجُلُ فِی الْمُعَصْفَرِ۔,,,13026,,
13027,"حدَّثَنَا بَکَّارُ بْنُ عَبْدِ اللہِ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، قَالَ : رَأَیْتُ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ یَتْبَعُ النَّاسَ فِی الْمَنَازِلِ ، یَنْہَاہُمْ عَنِ الْمُعَصْفَرِ۔",,,13027,,
13028,حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ أَنّہ کَرِہَ أَنْ یُحْرِمَ الرَّجُلُ فِی الْمُعَصْفَرَتَیْنِ۔,,,13028,,
13029,"حدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ الرُّؤَاسِیُّ ، عَنْ أَبِیہِ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : إذَا لَمْ یَکُنْ فِی الثَّوْبِ الْمُعَصْفَرِ طِیبٌ فَلاَ بَأْسَ بِہِ لِلْمُحْرِمِ أَنْ یَلْبَسَہُ۔",,,13029,,
13030,"حدَّثَنَا حُمَیْدٌ ، عَنْ أَبِیہِ ، عَنْ أَبِی الزُّبَیْرِ ، قَالَ : کُنْتُ عِنْدَ ابْنِ عُمَرَ فَأَتَاہُ رَجُلٌ عَلَیْہِ ثَوْبَانِ مُعَصْفَرَانِ وَہُوَ مُحْرِمٌ ، فَقَالَ : فِی ہَذَیْنِ عَلَیَّ بَأْسٌ ؟ قَالَ : فِیہِمَا طِیبٌ ؟ قَالَ : لاَ ، قَالَ : فَلاَ بَأْسَ بِہِ۔",,,13030,,
13031,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ إِسْحَاقَ ، قَالَ : حدَّثَنِی أَبِی ، قَالَ : رَأَیْتُ نَافِعَ بْنَ جُبَیْرٍ بِالْعَرَجِ عَلَیْہِ مُعَصْفَرٌ وَہُوَ مُحْرِمٌ ، فَقَالَ لَہُ عَمِّی إِسْحَاقُ : مَا ہَذَا ؟ قَالَ : إِنَّہُ لاَ یَنْفُضُ ، أَوْ إِنَّہَا لاَ تَنفضُ۔",,,13031,,
13032,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ بَأْسَ بِہِ۔",,,13032,,
13033,حدَّثَنَا عَبْدَۃُ ، عَنْ ہِشَامٍ ، عَنْ فَاطِمَۃَ ابْنَۃِ الْمُنْذِرِ ؛ أَنَّ أَسْمَائَ کَانَتْ تَلْبَسُ الْمُعَصْفَرَ وَہِیَ مُحْرِمَۃٌ,,,13033,,
13034,"حدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ یَزِیدَ الْفَقِیرِ ، قَالَ : سَافَرْتُ مَعَ أُمِّ سَلَمَۃَ زَوْجِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَکَانَ بَعْضُ مَنْ مَعَہَا تَلْبَسُ الْمُعَصْفَرَ۔",,,13034,,
13035,حدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، أَنَّ نِسَائَ عَبْدِ اللہِ بْنِ عُمَرَ وَبَنَاتِہِ کُنَّ یَلْبَسْنَ الْحُلِیَّ وَالْمُعَصْفَرَاتِ ، وَہُنَّ مُحْرِمَاتٍ۔,,,13035,,
13036,"حدَّثَنَا أبو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَد ، عَنْ عَائِشَۃَ ، قَالَتْ : تَلْبَسُ الْمُحْرِمَۃُ مَا شَائَتْ ، إِلاَّ الْمَہْرُودَ بِالْعُصْفُرِ۔",,,13036,,
13037,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ الْجَعْدِ ، قَالَ : حدَّثَتْنِی عَائِشَۃُ ابْنَۃُ سعْدٍ ؛ أَنَّ سَعْدًا کَانَ یَقُولُ لِبَنَاتِہِ : ثِیَابُکُنَّ الَّتِی تُحْرِمْنَ فِیہَا ہی الْمُصَبَّغَاتُ ، إذَا أَحْرَمْتُنَّ فَضَعْنَہَا فِی حُجُورِکُنَّ۔",,,13037,,
13038,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، عَن عَائِشَۃَ ، قَالَتْ : تُکْرَہ الْمُشْبَعَۃُ بِالْعُصْفُرِ لِلنِّسَائِ",,,13038,,
13039,حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ کَرِہَ الْمَہْرُودَ لِلْمُحْرِمَۃِ۔,,,13039,,
13040,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ سُفْیَانَ مَوْلَی عَبْدِ اللہِ بْنِ إیَاسٍ ، قَالَ : رَأَیْتُ أَصْحَابَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُحْرِمُونَ فِی الثَّوْبَیْنِ الأَبْیَضَیْنِ والْمُمَشَّقَیْنِ۔",,,13040,,
13041,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ کَثِیرِ بْنِ جُمْہَان ، قَالَ : أَتَی رَجُلٌ ابْنَ عُمَرَ ، فَقَالَ : یَا أَبَا عَبْدِ الرَّحْمَنِ ، أَتَنْہَی النَّاسَ عَنِ الْمَصْبُوغِ وَتَلْبَسُہُ ؟ قَالَ : وَیْحَکَ إنَّمَا ھُوَ بالِمَدَرِ۔",,,13041,,
13042,"حدَّثَنَا مُحَمَّدُ بْنُ عُبَیْدٍ، عَنْ یَعْقوبِ بْنِ قَیْسٍ، قَالَ: رَأَیْتُ عَلَی طَاوُوسٍ ثَوْبَیْنِ مُمَشَّقَیْنِ بِمَغْرۃٍ وَہُوَ مُحْرِمٌ۔",,,13042,,
13043,"حدَّثَنَا وَکِیعٌ، عَنْ حَرَامِ بْنِ ہِشَامٍ، قَالَ: رَأَیْتُ عَلَی عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ثَوْبَیْنِ مُمَشَّقَیْنِ ، وَہُوَ مُحْرِمٌ۔",,,13043,,
13044,"حدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَدِیِّ بْنِ ثَابِتٍ ، قَالَ : کَانَ نَفَرٌ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَبْدَؤُونَ بِالْمَدِینَۃِ وَیَقُولُونَ : نُہِلُّ مِنْ حَیْثُ أَہَلَّ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,13044,,
13045,"حدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ إبْرَاہِیمَ بْنِ مُہَاجِرٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا أَنْتَ حَجَجْتَ ، وَلَمْ تَحُجَّ قَطُّ ، فَابْدَأْ بِمَکَّۃَ ، ثُمَّ تَمُرُّ عَلَی الْمَدِینَۃِ إِنْ شِئْتَ۔",,,13045,,
13046,"حدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مُحَمَّدٍ الْمُحَارِبی ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : إذَا أَرَدْتَ الْحَجَّ وَالْعُمْرَۃَ فَابْدَأْ بِمَکَّۃَ ، وَاجْعَلْ کُلَّ شَیْئٍ لَہَا تَبَعًا۔",,,13046,,
13047,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَد ؛ أَنَّہُ کَانَ یَسْتَحِبُّ أَنْ یَبْدَأَ بِمَکَّۃَ، وَیَقُولُ : أُحِبُّ أَنْ تَکُونُ نَفَقَتِی وَوَجْہِی إلَی مَکَّۃَ۔",,,13047,,
13048,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ الزِّبْرِقَانِ ، قَالَ : کُنَّا بِمَکَّۃَ فَأَرَدْنَا أَنْ نَأْتِیَ الْمَدِینَۃَ ، فَذَکَرْنَا ذَلِکَ لِسَعِیدِ بْنِ جُبَیْرٍ ، فَقَالَ : لَطَوَافٌ وَاحِدٌ بِہَذَا الْبَیْتِ أَحَبُّ إلَیَّ مِنْ إتْیَانِ الْمَدِینَۃِ ثَمَانَ مَرَّاتٍ۔",,,13048,,
13049,"حدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ إسْرَائِیلَ ، عَنْ ثُوَیْرٍ ، عَنْ أَبِیہِ ، قَالَ : خَرَجْتُ مَعَ عَلْقَمَۃَ ، وَالأَسْوَد ، وَعَمْرِو بْنِ مَیْمُونٍ فَبَدَؤُوا بِالْمَدِینَۃِ قَبْلَ مَکَّۃَ۔",,,13049,,
13050,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَد ، عَنْ عَائِشَۃَ ، قَالَتْ : أَہْدَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَرَّۃً غَنَمًا إلَی الْبَیْتِ ، فَقَلَّدَہَا۔ (بخاری 1701۔ مسلم 958)",,,13050,,
13051,حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، وَالأَعْمَش ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَد ، عَنْ عَائِشَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، مِثْلَہُ۔ (بخاری 1703۔ ابوداؤد 1752),,,13051,,
13052,"حدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی بِشْرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : الْغَنَمُ لاَ تُقَلَّدُ ، وَلاَ تُشْعَرُ۔",,,13052,,
13053,"حدَّثَنَا ابْنُ أَبِی عَدِیٍّ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ مُحَمَّدِ بْنِ إبْرَاہِیمَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لَقَدْ رَأَیْتُ الْغَنَمَ یُؤْتَی بِہَا مُقَلَّدَۃً۔",,,13053,,
13054,"حدَّثَنَا وَکِیعٌ ، عَنْ بَسَّامٍ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : رَأَیْتُ الْکِبَاشَ مُقَلَّدَۃً۔",,,13054,,
13055,حدَّثَنَا وَکِیعٌ ، عَنْ عُمَرَ بْنِ ذَرٍّ ، عَنْ عَطَائٍ ؛ أَنَّ عَائِشَۃَ کَانَتْ تُقَلِّدُ الْغَنَمَ۔,,,13055,,
13056,حدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حُمَیْدٍ الطَّوِیلِ ، عَنْ عَبْدِ اللہِ بْنِ عُبَیْدِ بْنِ عُمَیْرٍ اللَّیْثِیِّ ؛ أَنَّ الشَّاۃَ کَانَتْ تُقَلَّدُ۔,,,13056,,
13057,"حدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ، عَنْ صَالِحِ بْنِ فَرْوَۃَ، عَنِ ابْنِ عُمَرَ، قَالَ: الشَّاۃُ لاَ تُقَلَّدُ۔",,,13057,,
13058,"حدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَنْ بُرْدٍ ، عَنْ عَطَائٍ ، قَالَ : رَأَیْتُ أُنَاسًا مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَسُوقُونَ الْغَنَمَ مُقَلَّدَۃً۔",,,13058,,
13059,"حدَّثَنَا أبُو أُسَامَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ بْنِ جَابِرٍ ، عَنْ مَکْحُولٍ ، قَالَ : إذَا أَصَابَتِ الْمُحْرِمَ جَنَابَۃٌ، فَلْیَصُبَّ الْمَائَ عَلَی رَأْسِہِ صَبًّا ، وَلاَ یَعْرُکْہُ۔",,,13059,,
13060,"حدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ حَبِیبٍ ، عَنْ عَطَائٍ فِی الْمُحْرِمِ إذَا اغْتَسَلَ ، قَالَ : یُشَرِّبُ الْمَائَ رَأْسَہُ، وَلاَ یَدْلُکُہُ۔",,,13060,,
13061,حدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ یَغْسِلَ الْمُحْرِمُ رَأْسَہُ ، وَیَکْرَہُ أَنْ یَشُدَّ دَلْکَ رَأْسِہِ۔,,,13061,,
13062,حدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یَصُبُّ الْمَائَ عَلَی رَأْسِہِ وَلاَ یَحُکُّہُ ، یَمْسَحُ یَدَہُ عَلَیْہِ مَسْحًا۔,,,13062,,
13063,"حدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ عَبْدِ الأَعْلَی ، قَالَ : رَأَیْتُ سَعِیدَ بْنَ جُبَیْرٍ یَصُبُّ عَلَی رَأْسِہِ الْمَائَ وَہُوَ مُحْرِمٌ ، وَلاَ یَحُکُّہُ۔",,,13063,,
13064,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، وَعَبَّادُ بْنُ الْعَوَّامِ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْمِسْوَرِ بْنِ مَخْرَمَۃَ ، قَالَ : تَجْمَعُ الْمُحْرِمَۃُ شَعْرَہَا أَثْلاَثًا ، فَتَأْخُذُ ثُلُثَہُ۔",,,13064,,
13065,"حدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ لَیْثٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : تَجْمَعُ الْمُحْرِمَۃُ شَعْرَہَا ، ثُمَّ تَأْخُذُ مِنْہُ قَدْرَ أُنْمُلَۃٍ۔",,,13065,,
13066,"حدَّثَنَا عَبَّادٌ ، عَنِ الْحَجَّاجِ ، قَالَ : سَأَلْتُ عَطَائً عَنْ تَقْصِیرِ الْمَرْأَۃِ ؟ فَقَالَ : تَأْخُذُ مِنْ جَوَانِبِہَا شَیْئًا ، إنَّمَا ہُوَ تَحْلِیلٌ۔",,,13066,,
13067,"حدَّثَنَا عَبْدُ الأَعْلَی، عَنْ ہِشَامٍ، عَنْ حَفْصَۃَ ابْنَۃِ سِیرِینَ؛ فِی تَقْصِیرِ الْمَرْأَۃِ مِنْ شَعْرِہَا، قَالَتْ: إِنَّہُ یُعْجِبُنِی أَنْ لاَ تُکْثِرَ الْمَرْأَۃُ الشَّابَّۃُ ، وَأَمَّا الَّتِی قَدْ وَلَّتْ فَإِنْ شَائَتْ أَخَذَتْ أَکْثَرَ ، فَإِنْ فَعَلَتْ فَلاَ تَزِیدُ عَلَی الرُّبْعِ۔",,,13067,,
13068,"حدَّثَنَا غُنْدَرٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ فِی الْمُحْرِمَۃِ کَیْفَ تُقَصِّرُ ؟ قَالَ : تَأْخُذُ مِنْ نَاصِیَتِہَا۔",,,13068,,
13069,"حدَّثَنَا أَبُو خَالِدٍ عَبْدُ الْعَزِیزِ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، قَالَ : سَأَلْتُ الْحَکَمَ کَمْ تَقُصُّ الْمَرْأَۃُ ؟ قَالَ : لَیْسَ فِیہِ شَیْئٌ مُؤقَّتٌ۔",,,13069,,
13070,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : تُقَصِّرُ مِنْ شَعْرِہَا الْقَصِیرِ وَالطَّوِیلِ۔",,,13070,,
13071,"حدَّثَنَا وَکِیعٌ ، عَنْ عُقْبَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : سَأَلْتُ عَنِ الصَّرُورَۃِ کَمْ تُقَصِّرُ مِنْ شَعْرِہَا ؟ قَالَ : مثِلَ ہَذَا ، وَوَضَعَ إبْہَامَہُ عَلَی الْمِفْصَلِ الثَّانِی۔",,,13071,,
13072,"حدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ، عَنْ عُقْبَۃَ بْنِ أَبِی صَالِحٍ، قَالَ: سَأَلْتُ سَعِیدَ بْنَ جُبَیْرٍ عَنْہُ؟ فَقَالَ: النِّسَائُ أَعْلَمُ۔",,,13072,,
13073,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : تُقَصِّرُ الْمَرْأَۃُ مِنْ شَعْرِہَا قَدْرَ أُنْمُلَۃٍ۔",,,13073,,
13074,"حدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : سَأَلْتُہُ : الْحَلْقُ لِلنِّسَائِ أَفْضَلُ ، أَوِ التَّقْصِیرُ ؟ قَالَ : لاَ ، بَلِ التَّقْصِیرُ ، قَصَّرَ أَزْوَاجُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,13074,,
13075,"حدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ مَنْصُورٍ، عَنْ إبْرَاہِیمَ، قَالَ: تَأْخُذُ الْمَرْأَۃُ مِنْ شَعْرِہَا؛ مِنْ قَصِیرِہِ وَطَوِیلِہِ۔",,,13075,,
13076,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُوسَی بْنِ عُقْبَۃَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : یَتَدَاوَی الْمُحْرِمُ بِأَیِّ دَوَائٍ شَائَ ، إِلاَّ دَوَائً فِیہِ طِیبٌ۔",,,13076,,
13077,"حدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الضَّحَّاکِ ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: إذَا تَشَقَّقَتْ یَدَا الْمُحْرِمِ، أَوْ رِجْلاَہُ فَلْیَدْہِنْہُمَا بِالزَّیْتِ ، أَوْ بِالسَّمْنِ۔",,,13077,,
13078,"حدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ أَشْعَثَ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : یَتَدَاوَی الْمُحْرِمُ بِمَا یَأْکُلُ۔",,,13078,,
13079,"حدَّثَنَا أَبُو مُعَاوِیَۃَ، وَوَکِیعٌ، عَنِ الأَعْمَشِ، عَنْ خَیْثَمَۃَ قَالَ: رَأَیتُ الأَسْوَدَ یَصْہَرُ رِجْلَہُ بِالشَّحْمِ وَہُوَ مُحْرِمٌ۔",,,13079,,
13080,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ أَشْعَثَ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : یَتَدَاوَی الْمُحْرِمُ بِمَا یَأْکُلُ۔",,,13080,,
13081,"حدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ أَشْعَثَ بْنِ أَبِی الشَّعْثَائِ ، قَالَ : حدَّثَنِی مَنْ سَمِعَ أَبَا ذَرٍّ یَقُولُ : لاَ بَأْسَ أَنْ یَتَدَاوَی الْمُحْرِمُ بِمَا یَأْکُلُ۔",,,13081,,
13082,حدَّثَنَا عَفَّانَ ، عَنْ شُعْبَۃَ ، عَنْ أَشْعَثَ بْنِ أَبِی الشَّعْثَائِ ، عَنْ مُرَّۃَ بْنِ خَالِدٍ ، عَنْ أَبِی ذَرٍّ ، بِنَحْوٍ مِنْ حَدِیثِ مِسْعَرٍ۔,,,13082,,
13083,"حدَّثَنَا مُعْتَمِرٌ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُوسٍ ؛ أَنَّہُمَا کَانَا لاَ یَرَیَانِ بَأْسًا أَنْ یُدَاوِیَ الْمُحْرِمُ شِقَاقَہُ بِالسَّمْنِ وَالزَّیْتِ ، وَقَالَ مُجَاہِدٌ : إِنْ تَدَاوَی بِوَاحِدٍ مِنْہُمَا فَعَلَیْہِ دَمٌ۔",,,13083,,
13084,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُغِیثٍ الْبَجَلِیِّ ، قَالَ : أَصَابَنِی شُقَاقٌ وَأَنَا مُحْرِمٌ ، فَسَأَلْتُ أَبَا جَعْفَرٍ ؟ فَقَالَ : اِدْہِنْہُ بِمَا کُنْتَ تَأْکُلُ۔",,,13084,,
13085,"حدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ حَمَّادٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : یَدْہُنُ الْمُحْرِمُ شِقَاقَہُ بِمَا یَأْکُلُ۔",,,13085,,
13086,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ بِالشَّحْمِ لِلْمُحْرِمِ۔",,,13086,,
13087,"حدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ، عَنِ النَّضْرِ بْنِ قَیْسٍ ، قَالَ: صُرِعَتِ امْرَأَتِی وَہِیَ مُحْرِمَۃٌ ، فَسَأَلْتُ الْقَاسِمَ؟ فَلَمْ یُرَخِّصْ لَہَا ، إِلاَّ فِی الزَّیْتِ الَّذِی یُصَبُّ عَلَی رَأْسِہَا۔",,,13087,,
13088,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مَنْصُورٍ ، عَنْ جَابِرِ بْنِ زَیْدٍ ، قَالَ : لاَ بَأْسَ بِالزَّیْتِ لِلْمُحْرِمِ۔",,,13088,,
13089,"حدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ ، وَعَامِرٍ ، وَعَطَائٍ قَالُوا : لاَ بَأْسَ أَنْ یَتَدَاوِیَ الْمُحْرِمُ بِالْمُرْدَاسَنْجِ ، مَا لَمْ یَکُنْ فِیہِ طِیبٌ۔",,,13089,,
13090,"حدَّثَنَا عَبْدُ الْوَہَّابِ بْنُ عَطَائٍ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَتَبْتُ إلَی نَافِعٍ أَسْأَلُہُ عَنِ الْمُحْرِمِ یَتَدَاوَی ؟ فَکَتَبَ إلَیَّ : نَعَمْ ، دَوَائٌ لَیْسَ فِیہِ طِیبٌ۔",,,13090,,
13091,"حدَّثَنَا جَرِیرٌ ، عَنْ یَزِیدَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : إذَا انْکَسَرَ ظُفُرُ الْمُحْرِمِ أَلْقَاہُ ، وَلاَ بَأْسَ أَنْ یَجْعَلَ عَلَیْہِ الْمَرَارَۃَ",,,13091,,
13092,"حدَّثَنَا عَبَّادٌ ، عَنْ أَبِی حَنِیفَۃَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : یَتَدَاوَی الْمُحْرِمُ بِمَا أَحَبَّ ، مَا لَمْ یَکُنْ فِی شَیْئٍ مِنْ أَدْوِیَتہِِ طِیبٌ۔",,,13092,,
13093,حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ (ح) وَعَنْ ہِشَامِ بْنِ حَسَّانَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ؛ أَنَّہُمَا کَانَا لاَ یَرَیَانِ بَأْسًا أَنْ یُدَاوِیَ الْمُحْرِمُ جِرَاحَاتِہِ بِالسَّمْنِ وَالزَّیْتِ۔,,,13093,,
13094,حدَّثَنَا الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَرِہَ أَنْ یُدَاوِیَ الْمُحْرِمُ یَدَہُ بِالدَّسَمِ۔,,,13094,,
13095,"حدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ یَزِیدَ ، عَنْ مُجَاہِدٍ ، قَالَ : لاَ یَتَدَاوَی الْمُحْرِمُ إِلاَّ بِدَوَائٍ لَیْسَ فِیہِ طِیب۔",,,13095,,
13096,حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، أَخْبَرَہُ عَمْرُو بْنُ أَوْسٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی بَکْرٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَمَرَہُ أَنْ یُرْدِفَ عَائِشَۃَ ، فَیُعْمِرَہَا مِنَ التَّنْعِیمِ۔ (بخاری 1784۔ مسلم 135),,,13096,,
13097,"حدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ فِی الرَّجُلِ یُرِیدُ الْعُمْرَۃَ مِنْ مَکَّۃَ ، مِنْ أَیْنَ یُہِلُّ ؟ قَالَ : مِنَ التَّنْعِیمِ ، وَمِنْہَا أَہَلَّ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,13097,,
13098,حدَّثَنَا عَبْدَۃُ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ؛ أَنَّ عَائِشَۃَ کَانَتْ تَکُونُ بِمَکَّۃَ ، فَإِذَا أَرَادَتْ أَنْ تَعْتَمِرَ خَرَجَتْ إلَی الْجُحْفَۃِ ، فَأَحْرَمَتْ مِنْہَا۔,,,13098,,
13099,حدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ؛ أَنَّ ابْنَ عُمَرَ ، وَابْنَ الزُّبَیْرِ خَرَجَا مِنْ مَکَّۃَ ، حَتَّی أَتَیَا ذَا الْحُلَیْفَۃِ ، فَأَحْرَمَا وَلَمْ یَدْخُلاَ الْمَدِینَۃَ۔,,,13099,,
13100,"حدَّثَنَا وَکِیعٌ ، عَنْ سُلَیْمَانَ ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنِ الْحَسَنِ الْعُرَنِیِّ ، عَنِ ابْنِ أُذَیْنَۃَ ، عَنْ أَبِیہِ ؛ أَنَّ رَجُلاً أَتَی عُمَرَ فَسَأَلَہُ عَنِ الْعُمْرَۃِ ؟ فَقَالَ : یَا أَمِیرَ الْمُؤْمِنِینَ ، مَا اَتَیْتُکَ حَتَّی رَکِبْتُ الإِبِلَ ، وَالْخَیْلَ ، وَالسُّفُنَ فَمِنْ أَیْنَ أُہِلُّ ؟ قَالَ : ائْتِ عَلِیًّا فَاسْأَلْہُ ، فَأَتَی عَلِیًّا فَسَأَلَہُ ؟ فَقَالَ : مِنْ حَیْثُ أَبْدَأْتَ ، فَرَجَعَ إلَیْہِ فَأَخْبَرَہُ ، فَقَالَ : مَا أَجِدُ لَکَ إِلاَّ مَا قَالَ عَلِیٌّ۔",,,13100,,
13101,"حدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنِ یحیی بْنِ الْجَزَّارِ ، وَعَنِ ابْنِ أذینۃ ، قَالَ : سُئِلَ عُمَرُ عَنِ الْعُمْرَۃِ وَہُوَ بِمَکَّۃَ ، مِنْ أَیْنَ أَعْتَمِرُ ؟ فَقَالَ : ائْتِ عَلِیَّ بْنَ أَبِی طَالِبٍ فَاسْأَلْہُ ، فَقَالَ : فَأَتَیْتُہُ ، فَقَالَ : مِنْ حِینَ أَبْدَأْتَ، یَعْنِی مِنْ مِیقَاتِ أَرْضِہِ، قَالَ: فَأَتَی عُمَرَ فَأَخْبَرَہُ ، فَقَالَ: مَا أَجِدُ لَکَ إِلاَّ مَا قَالَ عَلِیُّ بْنُ أَبِی طَالِبٍ۔",,,13101,,
13102,"حدَّثَنَا أَبُو الأَحْوَصِِ، عَنْ أَبِی الْحَارِثِ التَّیمِیِّ، قَالَ: تَمَتَّعْتُ فَلَقِیتُ ابْنَ عَبَّاسٍ، فَقُلْتُ: إنِّی تَمَتَّعْتُ وَأَنَا أُرِیدُ أَنْ أُہِلَّ بِالْحَجِّ، فَمِنْ أَیْنَ أُہِلُّ بِالْحَجِّ؟ قَالَ: مِنْ حَیْثُ شِئْتَ، قُلْتُ: مِنَ الْمَسْجِدِ؟ قَالَ: مِنَ الْمَسْجِدِ۔",,,13102,,
13103,"حدَّثَنَا مُعْتَمِرٌ ، عَنْ أَبِی مَعْنٍ ، قَالَ : قُلْتُ لِجَابِرِ بْنِ زَیْدٍ وَأَنَا بِمَکَّۃَ : مِنْ أَیْنَ أُحْرِمُ ؟ فَقَالَ : إِنْ شِئْتَ مِنْ خَلْفِ الْمَقَامِ ، وَإِنْ شِئْتَ فَمِنْ رَحْلِکَ۔",,,13103,,
13104,حدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ ہِشَامٍ ؛ أَنَّ الْقَاسِمَ ، وَسَالِمًا کَانَا بِمَکَّۃَ ، فَأَرَادَا أَنْ یَعْتَمِرَا ، فَخَرَجَا حَتَّی أَہَلاَّ مِنْ ذِی الْحُلَیْفَۃِ۔,,,13104,,
13105,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ ہَمَّامٍ ، قَالَ : سُئِلَ الْحَسَنُ عَنْ رَجُلٍ قَدِمَ مَکَّۃَ مُعْتَمِرًا ، ثُمَّ أَرَادَ أَنْ یَحُجَّ عَنْ أُمِّہِ ؟ فَقَالَ : یَخْرُجُ إلَی وَقْتِہِ ، وَقَالَ عَطَائٌ : یُحْرِمُ مِنْ مَکَّۃَ۔",,,13105,,
13106,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ دَاوُدَ بْنِ أَبِی ہِنْدٍ ، قَالَ : کُنْتُ قَاطِنًا بِمَکَّۃَ ، فَسَأَلْتُ مُجَاہِدًا : مِنْ أَیْنَ أُحْرِمُ ؟ قَالَ : مِنْ حَیْثُ شِئْتَ ، قُلْتُ : مِنْ ذَاتِ عِرْقٍ ، فَإِنَّہَا حَدُّنَا ؟ قَالَ : إذَا کُنْتَ بِمَکَّۃَ فَأَحْرِمْ مِنْ حَیْثُ شِئْتَ ، وَإِذَا جِئْتَ مِنْ بَلَدٍ آخَرَ فَلاَ تُجَاوِزِ الْحَدَّ حَتَّی تُحْرِمَ ، فَإِنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَدْ أَحْرَمَ مِنَ الْجِعْرَانَۃِ ، وَہُوَ مُقْبِلٌ مِنَ الطَّائِفِ۔",,,13106,,
13107,"حدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ مُسْلِمٍ الْقَرِّیِّ ، قَالَ : قُلْتُ لابْنِ عَبَّاسٍ : إنَّ أُمِّی حَجَّتْ وَلَمْ تَعْتَمِرْ ، فَمِنْ أَیْنَ أَعْتَمِرُ عَنْہَا ؟ قَالَ : مِنْ وَجْہِکَ الَّذِی جِئْتَ منہ۔",,,13107,,
13108,"حدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ مُحَمَّدِ بْنِ سُوقَۃَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ سَمِعْتُہُ یَقُولُ : {وَأَتِمُّوا الْحَجَّ وَالْعُمْرَۃَ لِلَّہِ} فَسَأَلَہُ رَجُلٌ : مَا تَمَامُ الْعُمْرَۃِ ؟ فَقَالَ : أَنْ تَعْتَمِرَ مِنْ حَیْثُ أَبْدَأْتَ۔",,,13108,,
13109,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، عَنْ عَائِشَۃَ ، أَنَّہَا سُئِلَتْ : عَلَی النِّسَائِ رَمَلٌ ؟ فَقَالَتْ : أَلَیْسَ لَکُنَّ بِنَا أُسْوَۃٌ ؟ لَیْسَ عَلَیْکُنَّ رَمَلٌ بِالْبَیْتِ ، وَلاَ بَیْنَ الصَّفَا وَالْمَرْوَۃِ۔",,,13109,,
13110,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعِ ، عَنِ ابْنِ عُمَرَ ، قَالَ : لَیْسَ عَلَی النِّسَائِ رَمَلٌ بِالْبَیْتِ ، وَلاَ بَیْنَ الصَّفَا وَالْمَرْوَۃِ۔",,,13110,,
13111,"حدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لَیْسَ عَلَی النِّسَائِ رَمَلٌ۔",,,13111,,
13112,"حدَّثَنَا عَبْدَۃُ، عَنْ عَبْدِ الْمَلِکِ، عَنْ عَطَائٍ، قَالَ: لَیْسَ عَلَی النِّسَائِ رَمَلٌ بِالْبَیْتِ، وَلاَ بَیْنَ الصَّفَا وَالْمَرْوَۃِ۔",,,13112,,
13113,"حدَّثَنَا أَبُو أُسَامَۃَ، عَنْ ہِشَامٍ، عَنِ الْحَسَنِ، وَعَطَائٍ، قَالَ: لَیْسَ عَلَی النِّسَائِ رَمَلٌ، وَلاَ بَیْنَ الصَّفَا وَالْمَرْوَۃِ۔",,,13113,,
13114,"حدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ مُغِیرَۃَ، عَنْ إبْرَاہِیمَ، قَالَ: الْمَرْأَۃُ تَقُصُّ، لَیْسَ عَلَی النِّسَائِ حَلْقٌ، وَلاَ رَمَلٌ۔",,,13114,,
13115,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو قَالَ : أَخْبَرَنِی جَابِرُ بْنُ زَیْدٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَکَحَ وَہُوَ مُحْرِمٌ۔ (بخاری 5114۔ مسلم 47)",,,13115,,
13116,"حدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : تَزَوَّجَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَیْمُونَۃَ وَہُوَ مُحْرِمٌ۔ (بخاری 1837۔ نسائی 3201)",,,13116,,
13117,حدَّثَنَا وَکِیعٌ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَبْدِ اللہِ ؛ أَنَّہُ لَمْ یَکُنْ یَرَی بِتَزْوِیجِ الْمُحْرِمِ بَأْسًا۔,,,13117,,
13118,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِیہِ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ أَنْ یَتَزَوَّجَ الْمُحْرِمُ۔",,,13118,,
13119,"حدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ مُحَمَّدِ بْنِ مُسْلِمٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، عَنْ أَبِیہِ ، قَالَ : لاَ بَأْسَ أَنْ یَتَزَوَّجَ الْمُحْرِمُ۔",,,13119,,
13120,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ ، وَحَمَّادًا عَنِ الْمُحْرِمِ یَتَزَوَّجُ ؟ قَالاَ : لاَ بَأْسَ بِہ۔",,,13120,,
13121,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ مَالِکٍ ، عَنْ عَطَائٍ ، قَالَ : یَتَزَوَّجُ ، لاَ أَرَی بِہِ بَأْسًا۔",,,13121,,
13122,"حدَّثَنَا عَائِذُ بْنُ حَبِیبٍ ، وَعَبْدُ الْوَہَّابِ بْنُ عَطَائٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، وَیَعْلَی بْنِ حَکِیمٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ بَأْسَ بِہ۔",,,13122,,
13123,"حدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ بِہِ۔",,,13123,,
13124,حدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنٍ ، عَنْ مُغِیرَۃَ ، عَنْ شَبَّاکٍ ، عَنْ أَبِی الضُّحَی ، عَنْ مَسْرُوقٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ تَزَوَّجَ وَہُوَ مُحْرِمٌ۔,,,13124,,
13125,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ أَیُّوبَ بْنِ مُوسَی ، عَنْ نُبَیہِ بْنِ وَہْبٍ ؛ أَنَّ عُمَرَ بْنَ عُبَیْدِ اللہِ بْنِ مَعْمَرٍ أَرَادَ أَنْ یَنْکِحَ وَہُوَ مُحْرِمٌ ، فَأَرْسَلَ إلَی أَبَانَ بْنِ عُثْمَانَ یَسْأَلُہُ ؟ فَقَالَ أَبَانُ : إِنَّ عُثْمَانَ حَدَّثَ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : الْمُحْرِمُ لاَ یَنْکِحُ ، وَلاَ یَخْطُبُ۔ (مسلم 1031۔ ابوداؤد 1837)",,,13125,,
13126,"حدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ حَمَّادِ بْنِ زَیْدٍ ، عَنْ مَطَرٍ ، عَنْ رَبِیعَۃَ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ ، عَنْ أَبِی رَافِعٍ ، قَالَ : تَزَوَّجَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَیْمُونَۃَ وَہُوَ حلال ، وَکُنْتُ الرَّسُولَ فِیمَا بَیْنَہُمَا۔\n\n(ترمذی 841۔ ابن حبان 4130)",,,13126,,
13127,حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنِ الزُّہْرِیِّ ، عَنْ یَزِیدَ بْنِ الأَصَمِّ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَکَحَ وَہُو حَلاَلٌ۔,,,13127,,
13128,"حدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا جَرِیرُ بْنُ حَازِمٍ ، قَالَ : حدَّثَنَا أَبُو فَزَارَۃَ ، عَنْ یَزِیدَ بْنِ الأَصَمِّ ، قَالَ: حَدَّثَتْنَا مَیْمُونَۃُ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ تَزَوَّجَہَا وَہُوَ حَلاَلٌ۔ (مسلم 481۔ ترمذی 845)",,,13128,,
13129,"حدَّثَنَا حَاتِمٍ بْنُ إسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، أَنَّ عُمَرَ ، وَعَلِیًّا قَالاَ : الْمُحْرِمُ لاَ یَنْکِحُ ، وَلاَ یُنْکِحُ ، فَإِنْ نَکَحَ فَنِکَاحُہُ بَاطِلٌ۔",,,13129,,
13130,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ أَیُّوبَ بْنِ مُوسَی ، عَنْ نَافِعٍ ، أَنَّ عُمَرَ ، وابْنَ عُمَرَ ، قَالَ أَحَدُہُمَا : لاَ یَنْکِحُ ، وَلاَ یَخْطُبُ ، وَقَالَ الآخَرُ : لاَ یَنْکِحُ۔",,,13130,,
13131,"حدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : لاَ یُزَوِّجُ الْمُحْرِمُ ، وَلاَ یَتَزَوَّجُ۔",,,13131,,
13132,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ سعد بن إبْرَاہِیمَ ، قَالَ : کَتَبَ یَزِیدُ بْنُ عَبْدِ الْمَلِکِ إلَی أَہْلِ الْمَدِینَۃِ یَسْأَلُہُمْ عَنِ الْمُحْرِمِ یَتَزَوَّجُ ؟ قَالَ : یُفَرَّقُ بَیْنَہُمَا۔",,,13132,,
13133,"حدَّثَنَا وَکِیعٌ ، عَنْ قُدَامَۃَ بْنِ مُوسَی ، قَالَ : زَوَّجَنِی أَہْلِی وَأَنَا مُحْرِمٌ ، فَأَرْسَلْنَا إلَی سَعِیدِ بْنِ الْمُسَیَّبِ، فَقَالَ : الْمُحْرِمُ لاَ یَنْکِحُ ، وَلاَ یُنْکِحُ۔",,,13133,,
13134,"حدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ سَعْدٍ ، عَنْ عَطَائٍ الْخُرَاسَانِیِّ ، قَالَ : قُلْتُ لِسَعِیدِ بْنِ الْمُسَیَّبِ : إنَّ عِکْرِمَۃَ یَقُولُ : تَزَوَّجَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ مُحْرِمٌ ، فَقَالَ : کَذَبَ۔",,,13134,,
13135,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : الْمُحْرِمُ لاَ یَتَزَوَّجُ ، وَلاَ یُزَوَّج۔",,,13135,,
13136,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ عِکْرِمَۃَ ، قَالَ : لاَ یَصُومُ الْمُتَمَتِّعُ إِلاَّ فِی الْعَشْرِ۔",,,13136,,
13137,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، قَالَ : یَصُومُ الْمُتَمَتِّعُ إِنْ شَائَ یَوْمًا مِنْ شَوَّالٍ ، وَإِنْ شَائَ یَوْمًا مِنْ ذِی الْقَعْدَۃِ ، قَالَ : وَقَالَ طَاوُوس ، وَعَطَائٌ : لاَ یَصُومُ الْمُتَمَتِّعُ إِلاَّ فِی الْعَشْرِ۔",,,13137,,
13138,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ الْقَطَّانُ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : لاَ یَصُومُ الْمُتَمَتِّعُ إِلاَّ وَہُوَ مُحْرِمٌ ، لاَ یَقْضِی عَنْہُ إِلاَّ ذَلِکَ ، قُلْتُ : یَصُومَہا مِنْ شَوَّالٍ ؟ قَالَ : لاَ ، إِلاَّ مُحْرِمًا۔",,,13138,,
13139,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ لَیْثٍ ، عَنْ طَاوُوس ، وَعَطَائٍ قَالاَ : لاَ یَصُومُ الثَّلاَثَۃَ إِلاَّ فِی الْعَشْرِ ، وَقَالَ مُجَاہِدٌ : لاَ بَأْسَ أَنْ یَصُومَہَا فِی أَشْہُرِ الْحَجِّ۔",,,13139,,
13140,"حدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ عِکْرِمَۃَ ، قَالَ : إِنْ خَشِیَ أَنْ لاَ یُدْرِکَ الصَّوْمَ بِمَکَّۃَ ، صَامَ فِی الطَّرِیقِ یَوْمًا ، أَوِ اثْنَیْنِ۔",,,13140,,
13141,"حدَّثَنَا ابْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : کَانَ یَقُولُ فِی الَّذِی یَکُونُ فِی الطَّرِیقِ : إِنْ خَشِیَ أَنْ لاَ یَقْدَمَ إِلاَّ یَوْمَ عَرَفَۃَ ، صَامَ فِی الطَّرِیقِ ثَلاَثَۃَ أَیَّامٍ۔",,,13141,,
13142,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إذَا لَمْ یَصُمِ الْمُتَمَتِّعُ فَعَلَیْہِ الْہَدْیُ۔",,,13142,,
13143,"حدَّثَنَا حَفْصٌ، وَابْنُ عُلَیَّۃَ، عَنْ لَیْثٍ، عَنْ عَطَائٍ، وَطَاوُوسٍ، وَمُجَاہِدٍ قَالُوا: إذَا فَاتَہُ الصَّوْمُ فَعَلَیْہِ الْہَدْیُ۔",,,13143,,
13144,"حدَّثَنَا ابْنُ أَبِی زَائِدَۃَ ، عَنْ حَجَّاجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّ رَجُلاً أَتَی عُمَرَ مُتَمَتِّعًا قَدْ فَاتَہُ الصَّوْمُ فِی الْعَشْرِ ، فَقَالَ لَہُ : اذْبَحْ شَاۃً ، قَالَ : لَیْسَ عِنْدِی ، قَالَ : سَلْ قَوْمَکَ ، قَالَ : لَیْسَ ہَاہُنَا أَحَدٌ مِنْ قَوْمِی ، قَالَ : أَعْطِہِ یَا مُعَیْقِیبَ ثَمَنَ شَاۃٍ۔",,,13144,,
13145,حدَّثَنَا حَفْصٌ ، وَأَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ حَجَّاجٍ ، عَنْ عَمْرِو بن شعیب ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ عُمَرَ ، بِنَحْوٍ مِنْہُ۔,,,13145,,
13146,"حدَّثَنَا حَفْصٌ ، وَأَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، وَحَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ بُدَّ مِنْ دَمٍ ، وَلَوْ یَبِیعُ ثَوْبَہُ۔",,,13146,,
13147,"حدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، قَالَ : لاَ بُدَّ مِنْ دَمٍ ، وَلَوْ یُتَصَدَّقُ۔",,,13147,,
13148,"حدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی بِشْرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : لاَ بُدَّ مِنْ دَمٍ ، وَلَوْ یَبِیعُ ثَوْبَہُ۔",,,13148,,
13149,"حدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ عَلِیٍّ ، قَالَ : إِنْ فَاتَہُ الصَّوْمُ فِی الْعَشْرِ تَسَحَّرَ لَیْلَۃَ الْحَصْبَۃِ ، فَصَامَ ثَلاَثَۃَ أَیَّامٍ ، وَسَبْعَۃً إذَا رَجَعَ۔",,,13149,,
13150,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : مَنْ فَاتَہُ ثَلاَثَۃُ أَیَّامٍ فِی الْحَجِّ ، فَلْیَصُمْ أَیَّامَ التَّشْرِیقِ ، فَإِنَّہُنَّ مِنَ الْحَجِّ۔",,,13150,,
13151,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عُرْوَۃَ ، أَوْ عَمْرَۃَ ، عَنْ عَائِشَۃَ قَالَتْ : کَانَتْ تُرَخِّصُ لِلْمُتَمَتِّعِ أَنْ یَصُومَ أَیَّامَ التَّشْرِیقِ ، إذَا لَمْ یَصُمِ الْعَشْرَ۔",,,13151,,
13152,"حدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : الْمُتَمَتِّعُ إذَا فَاتَہُ الصَّوْمُ أَیَّامَ الْعَشْرِ ، أَطْعَمَ عَنِ الثَّلاَثَۃِ وَصَامَ السَّبْعَۃَ إذَا رَجَعَ۔",,,13152,,
13153,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَبْدِ اللہِ بْنِ عِیسَی ، قَالَ : سَمِعْتُہُ یُحَدِّثُ عَنِ الزُّہْرِیِّ ، عَنْ عُرْوَۃَ ، عَنْ عَائِشَۃَ (ح) وَعَنْ سَالِمٍ، عَنِ ابْنِ عُمَرَ قَالاَ: لَمْ یُرَخَّصْ فِی أَیَّامِ التَّشْرِیقِ أَنْ یُصَمْنَ، إِلاَّ لِمَنْ لَمْ یَجِدِ الْہَدْیَ۔",,,13153,,
13154,"حدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : {وَسَبْعَۃٍ إذَا رَجَعْتُمْ} قَالَ : إِنْ شَائَ صَامَہَا فِی الطَّرِیقِ ، وَإِنْ شَائَ بِمَکَّۃَ۔",,,13154,,
13155,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ الْقَطَّانُ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ فِی صِیَامِ السَّبْعَۃِ الأَیَّامِ ، قَالَ : إِنْ شَائَ صَامَ فِی الطَّرِیقِ ، وَإِنْ شَائَ إذَا رَجَعَ إلَی أَہْلِہِ۔",,,13155,,
13156,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : صُمِ السَّبْعَۃَ إِنْ شِئْتَ فِی الطَّرِیقِ ، وَإِنْ شِئْتَ إذَا رَجَعْتَ إلَی أَہْلِکَ ، وَلاَ تُفَرِّقْ بَیْنَہُنَّ۔",,,13156,,
13157,"حدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، قَالَ : إِنْ شَائَ صَامَ فِی الطَّرِیقِ ، وَإِنْ شَائَ إذَا رَجع۔",,,13157,,
13158,"حدَّثَنَا وَکِیعٌ ، عَنْ إبْرَاہِیمَ بْنِ مَرْثَدٍ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ طَاوُوس ؛ {وَسَبْعَۃٍ إذَا رَجَعْتُمْ} قَالَ : إِنْ شَائَ فَرَّقَ۔",,,13158,,
13159,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : مَنِ اعْتَمَرَ فِی شَوَّالٍ ، أَوْ فِی ذِی الْقَعْدَۃِ ، ثُمَّ أَقَامَ حَتَّی یَحُجَّ ، فَہُوَ مُتَمَتِّعٌ ، عَلَیْہِ مَا اسْتَیْسَرَ مِنَ الْہَدْیِ ، فَمَنْ لَمْ یَجِدْ فَصِیَامُ ثَلاَثَۃِ أَیَّامٍ فِی الْحَجِّ ، وَسَبْعَۃٍ إذَا رَجَعَ إلَی أَہْلِہِ۔",,,13159,,
13160,"حدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : کَانَ یُرَی عَلَی الْمُتَمَتِّعِ بَدَنَۃً ؛ بَعِیرًا ، أَوْ بَقَرَۃً ، فَإِنْ لَمْ یَجِدْ صَامَ ثَلاَثَۃَ أَیَّامٍ ، وَسَبْعَۃً إذَا رَجَعَ۔",,,13160,,
13161,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : مَنِ اعْتَمَرَ فِی أَشْہُرِ الْحَجِّ ، ثُمَّ رَجَعَ فَلَیْسَ بِمُتَمَتِّعٍ ، ذَاکَ مَنْ أَقَامَ وَلَمْ یَرْجِعْ۔",,,13161,,
13162,حدَّثَنَا حَفْصٌ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ مِثْلَہُ۔,,,13162,,
13163,"حدَّثَنَا وَکِیعٌ ، عَنِ الْعُمَرِیِّ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ عُمَرُ : إذَا اعْتَمَرَ فِی أَشْہُرِ الْحَجِّ ثُمَّ أَقَامَ فَہُوَ مُتَمَتِّعٌ ، فَإِنْ رَجَعَ فَلَیْسَ بِمُتَمَتِّعٍ۔",,,13163,,
13164,"حدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُسٍ ، وَمُجَاہِدٍ ، قَالُوا : إِنْ خَرَجَ فِی أَشْہُرِ الْحَجِّ ثُمَّ أَقَامَ فَہُوَ مُتَمَتِّعٌ۔",,,13164,,
13165,"حدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، وَعَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : مَنِ اعْتَمَرَ فِی أَشْہُرِ الْحَجِّ ، ثُمَّ رَجَعَ إلَی بَلَدِہِ ، ثُمَّ حَجَّ مِنْ عَامِہِ فَلَیْسَ بِمُتَمَتِّعٍ ، إنَّمَا الْمُتَمَتِّعُ مَنْ أَقَامَ وَلَمْ یَرْجِعْ۔",,,13165,,
13166,"حدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، قَالَ : سَأَلْتُ إبْرَاہِیمَ ، قَالَ : قُلْتُ : الَّذِینَ یَعْتَمِرُونَ فِی رَجَبٍ ثُمَّ یُقِیمُونَ حَتَّی یَحُجُّوا ، أَمُتَمَتِّعُونَ ہُمْ ؟ قَالَ : لاَ ، إنَّمَا الْمُتَمَتِّعُ مَنْ أَہَلَّ بِالْعُمْرَۃِ فِی أَشْہُرِ الْحَجِّ ، ثُمَّ أَقَامَ حَتَّی یَحُجَّ، فَذَلِکَ مُتَمَتِّعٌ وَعَلَیْہِ الْہَدْیُ ، أَوِ الصَّوْمُ إِنْ لَمْ یَجِدْ۔",,,13166,,
13167,"حدَّثَنَا ہُشَیْمٌ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : إذَا اعْتَمَرَ فِی أَشْہُرِ الْحَجِّ ثُمَّ أَقَامَ فَہُوَ مُتَمَتِّعٌ۔",,,13167,,
13168,حدَّثَنَا ہُشَیْمٌ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ مِثْلَہُ۔,,,13168,,
13169,حدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی بِشْرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ مِثْلَہُ۔,,,13169,,
13170,"حدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی بِشْرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : إِنْ أَقَامَ فَعَلَیْہِ ہَدْیٌ۔",,,13170,,
13171,"حدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : کَانَ أَصْحَابُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا اعْتَمَرُوا فِی أَشْہُرِ الْحَجِّ ، ثُمَّ لَمْ یَحُجُّوا مِنْ عَامِہِمْ ذَلِکَ لَمْ یُہْدُوا۔",,,13171,,
13172,"حدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ سَیْفِ بْنِ أَبِی سُلَیْمَانَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ یَزِیدَ الْفَقِیرِ ؛ أَنَّ قَوْمًا مِنْ أَہْلِ الْکُوفَۃِ تَمَتَّعُوا ثُمَّ خَرَجُوا إلَی الْمَدِینَۃِ ، فَأَقْبَلُوا مِنْہَا بِحَجٍّ ، فَسَأَلُوا ابْنَ عَبَّاسٍ ؟ فَقَالَ : أَنْتُمْ مُتَمَتِّعُونَ۔",,,13172,,
13173,"حدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : عَلَیْہِ الْہَدْیُ أَقَامَ ، أَوْ لَمْ یَقُمْ۔",,,13173,,
13174,"حدَّثَنَا حَفْصٌ، عَنْ أَشْعَثَ، عَنِ الْحَسَنِ، قَالَ: مَنِ اعْتَمَرَ فِی أَشْہُرِ الْحَجِّ، ثُمَّ حَجَّ فِی عَامِہِ فَہُوَ مُتَمَتِّعٌ۔",,,13174,,
13175,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَد ، عَنْ أُمِّ الْمُؤْمِنِینَ (ح) وَعَنِ الْقَاسِمِ ، عَنْ أُمِّ الْمُؤْمِنِینَ ، قَالَتْ : یَا رَسُولَ اللہِ ، یَصْدُرُ النَّاسُ بِنُسُکَیْنِ وَأَصْدُرُ بِنُسُکٍ وَاحِدٍ ؟ قَالَ : انْتَظِرِی ، فَإِذَا طَہُرْتِ ، فَاخْرُجِی إلَی التَّنْعِیمِ فَأَہِلِّی مِنْہُ ، ثُمَّ الْقَیْنَا عِنْدَ کَذَا وَکَذَا ، وَلَکِنَّہَا عَلَی قَدْرِ نَصَبِکِ ، أَوْ قَالَ : نَفَقَتِکِ ، أَوْ کَمَا قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔ (مسلم 867۔ احمد 6/43)",,,13175,,
13176,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الْوَلِیدِ بْنِ ہِشَامٍ الْمُعَیْطِیِّ ، قَالَ : سَأَلْتُ أُمَّ الدَّرْدَائِ عَنِ الْعُمْرَۃِ بَعْدَ الْحَجِّ ؟ فَأَمَرَتْنِی بِہَا۔",,,13176,,
13177,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ؛ أَنَّہُ سُئِلَ عَنِ الْعُمْرَۃِ بَعْدَ أَیَّامِ التَّشْرِیقِ ؟ فَلَمْ یَرَ بِہَا بَأْسًا ، وَقَالَ : لَیْسَ فِیہَا ہَدْیٌ۔",,,13177,,
13178,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : سُئِلَ عُمَرُ عَنِ الْعُمْرَۃِ بَعْدَ الْحَجِّ ؟ فَقَالَ : ہِیَ خَیْرٌ مِنْ لاَ شَیْئَ ۔ وَسُئِلَتْ عَائِشَۃُ ؟ فَقَالَتْ : عَلَی قَدْرِ النَّفَقَۃِ وَالْمَشَقَّۃِ ۔ وَسُئِلَ عَلِیٌّ ؟ فَقَالَ : ہِیَ خَیْرٌ مِنْ مِثْقَالِ ذَرَّۃٍ۔",,,13178,,
13179,"حدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : کَانَتْ عَائِشَۃُ تَعْتَمِرُ فِی آخِرِ ذِی الْحِجَّۃِ۔",,,13179,,
13180,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، قَالَ : سَأَلْتُ سَعِیدَ بْنَ جُبَیْرٍ عَنِ الْعُمْرَۃِ بَعْدَ الْحَجِّ بِسِتَّۃِ أَیَّامٍ ؟ فَقَالَ : اعْتَمِرْ إِنْ شِئْتَ۔",,,13180,,
13181,"حدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ الرُّؤَاسِیُّ ، عَنْ أَبِیہِ ، عَنْ جَعْفَرِ بْنِ نَجِیحٍ ، قَالَ : سَأَلَ رَجُلٌ طَاوُوسًا ، فَقَالَ : إِنِّی تَعَجَّلْتُ فِی یَوْمَیْنِ ، أَفَأَعْتَمِرُ ؟ قَالَ : نَعَمْ۔",,,13181,,
13182,"حدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی یَعْفُورٍ ، قَالَ : سَأَلْنَا ابْنَ عُمَرَ عَنِ الْعُمْرَۃِ بَعْدَ الْحَجِّ ؟ فَقَالَ : إنَّ أنَاسًا یَفْعَلُونَ ذَلِکَ ، وَلأَنْ أَعْتَمِرَ فِی غَیْرِ ذِی الْحِجَّۃِ ، أَحَبُّ إلَیَّ مِنْ أَنْ أَعْتَمِرَ فِی ذِی الْحِجَّۃِ۔",,,13182,,
13183,"حدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ خُصَیْفٍ ، عَنْ عَطَائٍ ، وَطَاوُوسٍ ، وَمُجَاہِدٍ ، قَالُوا : لاَ عُمْرَۃَ إِلاَّ عُمْرَۃٌ ابْتَدَأْتَہَا مِنْ أَہْلِکَ ، وَلاَ عُمْرَۃَ إلاَّ بَعْدَ الصَّدَرِ۔\n\nوَقَالَ سَعِیدُ بْنُ جُبَیْرٍ : إِنْ رَجَعَ إلَی مِیقَاتِ أَہْلِہِ فَاعْتَمَرَ ، رَجَوْتُ أَنْ تَکُونَ عُمْرَۃً۔",,,13183,,
13184,"حدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُوسٍ ، وَمُجَاہِدٍ ؛ أَنَّہُمْ کَرِہُوا الْعُمْرَۃَ بَعْدَ الْحَجِّ ، وَقَالُوا : لاَ تُجْزِیء ، وَلاَ تَفِی ، وَقَالُوا : الطَّوَافُ بِالْبَیْتِ وَالصَّلاَۃُ أَفْضَلُ۔",,,13184,,
13185,"حدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ عُمَارَۃَ بْنِ عُمَیْرٍ ، عَنْ أَبِی بَکْرِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ الْحَارِثِ بْنِ ہِشَامٍ ؛ أَنَّ أَبَا مَعْقِلٍ أَتَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : یَا رَسُولَ اللہِ ، إنَّ أُمَّ مَعْقِلٍ جَعَلَتْ عَلَیْہَا أَنْ تَحُجَّ فَلَمْ یَتَیَسَّرْ لَہَا ، فَقَالَ : تَعْتَمِرُ فِی رَمَضَانَ۔ (نسائی 4328)",,,13185,,
13186,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ عِیسَی بْنِ مَعْقِلٍ بْنِ أَبِی مَعْقِلٍ الأَسَدِیِّ ، عَنْ یُوسُفَ بْنِ عَبْدِ اللہِ بْنِ سَلاَمٍ ، عَنْ جَدَّتِہِ أُمِّ مَعْقِلٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : اعْتَمِرِی فِی رَمَضَانَ ، فَإِنَّہَا حَجَّۃٌ۔ (ابوداؤد 1982۔ دارمی 1860)",,,13186,,
13187,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ مُحَمَّدِ بْنِ الْمُنْکَدِرِ ، عَنْ یُوسُفَ بْنِ عَبْدِ اللہِ بْنِ سَلاَمٍ ، سَمِعَ رَجُلاً مِنَ الأَنْصَارِ یَقُولُ : إِنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ لَہُ وَلامْرَأَتِہِ : اعْتَمِرَا فِی رَمَضَانَ ، فَإِنَّ عُمْرَۃً لَکُمَا فِی رَمَضَانَ تَعْدِلُ حَجَّۃً۔ (احمد 4/35)",,,13187,,
13188,"حدَّثَنَا وَکِیعٌ ، وَیَحْیَی بْنُ آَدَمَ ، عَنْ سُفْیَانَ ، عَنْ بَیَانٍ ، وَجَابِرٍ ، عَنِ الشَّعْبِیِّ ، عَنْ وَہْبِ بْنِ خَنْبَشٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : عَمْرَۃٌ فِی رَمَضَانَ تَعْدِلُ حَجَّۃً۔ (احمد 177۔ ابن ماجہ 2991)",,,13188,,
13189,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : عُمْرَۃٌ فِی رَمَضَانَ تَعْدِلُ حَجَّۃً۔ (بخاری 1782۔ مسلم 917)",,,13189,,
13190,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ، قَالَ : سَأَلْتُُہُ قُلْتُ : ہَذَا الْحَجُّ الأَکْبَرُ ، فَمَا الْحَجُّ الأَصْغَرُ؟ قَالَ : عُمْرَۃٌ فِی رَمَضَانَ۔",,,13190,,
13191,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ خُثَیْمٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، وَمُجَاہِدٍ ، قَالَ : کَانَا یَعْتَمِرَانِ فِی شَہْرِ رَمَضَانَ مِنَ الْجِعْرَانَۃِ۔",,,13191,,
13192,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ أَبِی سُلَیْمَانَ : قَالَ : خَرَجْتُ أَنَا وَعَطَائٌ فِی رَمَضَانَ ، فَأَحْرَمْنَا مِنَ الْجِعْرَانَۃِ۔",,,13192,,
13193,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ یَحْیَی بْنِ عَبَّادِ بْنِ عَبْدِ اللہِ بْنِ الزُّبَیْرِ ، عَنْ أَبِی بَکْرِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ الْحَارِثِ بْنِ ہِشَامٍ ، قَالَ : کَانَ أبو بَکْرِ بْنُ عَبْدِ الرَّحْمَنِ لاَ یَعْتَمِرُ إِلاَّ فِی رَمَضَانَ۔",,,13193,,
13194,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ قَیْسِ بْنِ مُسْلِمٍ ، عَنْ طَارِقِ بْنِ شِہَابٍ ، قَالَ : سُئِلَ عَبْدُ اللہ عَنِ الْعُمْرَۃِ فِی أَشْہُرِ الْحَجِّ ؟ فَقَالَ عَبْدُ اللہ : (الْحَجُّ أَشْہُرٌ مَعْلُومَاتٌ) لَیْسَ فِیہِنَّ عُمْرَۃٌ۔",,,13194,,
13195,"حدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : سُئِلَ عَلْقَمَۃُ عَنِ الْعُمْرَۃِ فِی أَشْہُرِ الْحَجِّ ؟ فَقَالَ : وَیَفْعَلُ ذَلِکَ أَحَدٌ ؟۔",,,13195,,
13196,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : قُلْتُ لِلْقَاسِمِ بْنِ مُحَمَّدٍ : نَہَی عُمَرُ عَنِ الْعُمْرَۃِ فِی أَشْہُرِ الْحَجِّ ؟ فَتَلَکَّأَ ، وَقَالَ : نَہَی عُثْمَانُ عَنْہَا۔",,,13196,,
13197,"حدَّثَنَا وَکِیعٌ، عَنِ ابْنِ أَبِی رَوَّادٍ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ: قَالَ عُمَرَ: افْصِلُوا بَیْنَ حَجِّکُمْ وَعُمْرَتِکُمْ، اجْعَلُوا الْحَجَّ فِی أَشْہُرِ الْحَجِّ، وَاجْعَلُوا الْعُمْرَۃَ فِی غَیْرِ أَشْہُرِ الْحَجِّ، أَتَمُّ لِحَجِّکُمْ وَلِعُمْرَتِکُمْ۔",,,13197,,
13198,"حدَّثَنَا وَکِیعٌ ، عَنْ یَزِیدَ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : مَا أَعْلَمُہُمْ یَخْتَلِفُونَ أَنَّ الْعُمْرَۃَ فِی غَیْرِ أَشْہُرِ الْحَجِّ أَفْضَلُ۔",,,13198,,
13199,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : سُئِلَ الْقَاسِمُ عَنِ الْعُمْرَۃِ فِی أَشْہُرِ الْحَجِّ ؟ فَقَالَ : کَانُوا لاَ یَرَوْنَہَا تَامَّۃً۔",,,13199,,
13200,"حدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ، عَنْ جَعْفَرٍ، عَنْ مَیْمُونٍ؛ أَنَّہُ قَالَ: اعْتَمَرْتُ مِنْ بَلَدِی ہَذَا فِی غَیْرِ أَشْہُرِ الْحَجِّ۔",,,13200,,
13201,"حدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ حَرْمَلَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : سَمِعْتُہُ یَقُولُ : اعْتَمَرَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عُمُرًا ثَلاَثَاً ، کُلَّہَا فِی ذِی الْقَعْدَۃِ۔",,,13201,,
13202,"حدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ أَبِی مَعَنٍ ، قَالَ : رَأَیْتُ جَابِرَ بْنَ زَیْدٍ ، وَأَبَا الْعَالِیَۃِ اعْتَمَرَا فِی الْعَشْرِ۔",,,13202,,
13203,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ الْجُرَیرِیِّ ، عَنْ یَزِیدَ ، عَنْ أَخِیہِ ، قَالَ : قَالَ لِی عِمْرَانُ بْنُ حُصَیْنٍ ؛ اِعْلَمْ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَدَ أَعْمَرَ طَائِفَۃً مِنْ أَہْلِہِ فِی عَشْر ذِی الْحِجَّۃِ ، فَلَمْ یُنْہَ عَنْہُ ، وَلَمْ یَنْزِلْ نَسْخُہُ ، قَالَ فِی ذَلِکَ قَائِلٌ مَا شَائَ۔ (مسلم 165۔ ابن ماجہ 2978)",,,13203,,
13204,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنِ الأَعْمَشِ ، عَنْ مُجَاہِدٍ ، عَنْ عَائِشَۃَ قَالَتْ : مَا اعْتَمَرَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عُمْرَۃً إِلاَّ شَہِدْتُہَا ، وَمَا اعْتَمَرَ إِلاَّ فِی ذِی الْقَعْدَۃِ۔",,,13204,,
13205,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ صَدَقَۃَ بْنِ یَسَارٍ ، قَالَ : سَمِعْتُ ابْنَ عُمَرَ یَقُولُ : الْعُمْرَۃُ فِی الْعَشْرِ أَحَبُّ إلَیَّ مِنَ الْعُمْرَۃِ بَعْدَ الْحَجِّ۔",,,13205,,
13206,حدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ جَابِرٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَتَی إلی الْبَیْتِ فَصَلَّی بِمَکَّۃَ الظُّہْرَ ، یَعْنِی یَوْمَ النَّحْرِ۔ (مسلم 110۔ ابوداؤد 1900),,,13206,,
13207,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ إِسْمَاعِیلَ ، عَنْ وَبَرَۃَ ، قَالَ : کَانَ الأَسْوَدُ إذَا رَمَی الْجَمْرَۃَ یَوْمَ النَّحْرِ زَارَ الْبَیْتَ مِنْ یَوْمِہِ ، ثُمَّ رَجَعَ إلَی مَنْزِلِہِ مِنْ یَوْمِہِ ، حَتَّی یَنْفِرَ مَعَ النَّاسِ إذَا نَفَرُوا۔",,,13207,,
13208,"حدَّثَنَا أَزْہَرُ السَّمَّانُ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَانَ مُحَمَّدٌ یَسْتَحِبُّ أَنْ یَأْتِیَ الْبَیْتَ یَوْمَ النَّحْرِ قَبْلَ الْعَصْرِ فَیَطُوفَ بِہِ۔",,,13208,,
13209,"حدَّثَنَا بِشْرُ بْنُ الْمُفَضَّلِ ، عَنْ عَبْدِ اللہِ بْنِ عُثْمَانَ بْنِ خُثَیْمَ قَالَ : أَفَضْتُ مَعَ سَعِیدِ بْنِ جُبَیْرٍ عَشِیَّۃَ النَّحْرِ۔",,,13209,,
13210,حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَنْحَرُ ہَدْیَہُ خَلْفَ الْعَقَبَۃِ ، ثُمَّ یَحْلِقُ رَأْسَہُ ، ثُمَّ یُفِیضُ کَمَا ہُوَ إلَی الْبَیْتِ ، قَبْلَ أَنْ یَرْجِعَ إلَی أَہْلِہِ۔,,,13210,,
13211,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ أَبِی الْعُمَیْسِ ، عَنْ عَمْرِو بْنِ عَمْرٍو أَبِی الزَّعْرَائِ ، قَالَ : سَافَرْتُ مَعَ أَبِی الأَحْوَصِ ، فَلَمَّا کَانَ یَوْمُ النَّحْرِ رَمَی الْجَمْرَۃَ وَحَلَقَ ، وَأَفَاضَ إلَی الْبَیْتِ ، وَلَمْ یُضَحِّ۔",,,13211,,
13212,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ مُحَمَّدِ بْنِ سُوقَۃَ ، قَالَ : کَانَ الأَسْوَدُ إذَا جَائَ مِنْ مِنًی رَمَی وَحَلَقَ ، ثُمَّ زَارَ الْبَیْتَ ، وَلاَ یُضَحِّی۔",,,13212,,
13213,حُدِّثْتُ عَنِ ابْنِ مُبَارَکٍ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی قِلاَبَۃَ ، وَجَابِرِ بْنِ زَیْدٍ ؛ أَنَّہُمَا زَارَا الْبَیْتَ یَوْمَ النَّحْرِ۔,,,13213,,
13214,حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ عَائِشَۃَ ، وَابْنِ عَبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ زَارَ الْبَیْتَ لَیْلاً۔ (ابوداؤد 1993۔ احمد 1/288),,,13214,,
13215,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، قَالَ : حدَّثَنَا دَاوُد بْنُ شَابُورَ ، عَنْ مُحَمَّدِ بْنِ الْمُنْکَدِرِ ، قَالَ : لَمْ یَکُنْ یُفِیضُ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إِلاَّ مَنْ کَانَ مِنْہُمْ تَکُونُ مَعَہُ امْرَأَۃٌ۔",,,13215,,
13216,حدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ مَیْسَرَۃَ ، عَنْ طَاوُوسٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَخَّرَ الزِّیَارَۃَ إلَی اللَّیْلِ۔,,,13216,,
13217,"حدَّثَنَا وَکِیعٌ ، عَنْ أَفْلَحَ ، عَنْ أَبِیہِ : قَالَ : کُنَّا مَعَ أَبِی أَیُّوبَ نَفَرًا مِنَ الأَنْصَارِ ، فَمَا زَارَ مِنَّا أَحَدٌ الْبَیْتَ حَتَّی کَانَ فِی النَّفْرِ الآخِرِ ، إِلاَّ رَجُلٌ کَانَ مَعَہُ أَہْلُہُ فَتَعَجَّلَ بِہِمْ۔",,,13217,,
13218,"حدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، وَأَشْعَثَ ، عَنْ عَطَائٍ ، قَالَ : لاَ بَأْسَ أَنْ تُؤَخِّرَ الزِّیَارَۃَ إلَی یَوْمِ النَّفْرِ۔",,,13218,,
13219,"حدَّثَنَا عَبْدُ الأَعْلَی بْنُ عَبْدِ الأَعْلَی ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، قَالَ : رَأَیْتُ الْقَاسِمَ بْنَ مُحَمَّدٍ بِمِنًی مُعْتَمًّا مُتَقَمِّصًا ، وَکَانَ لاَ یُفِیضُ حَتَّی یَنْفِرَ فِی آخِرِ أَیَّامِ التَّشْرِیقِ۔",,,13219,,
13220,حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ لاَ یَأْتِی مَکَّۃَ إِلاَّ حِینَ یُفِیضُ۔,,,13220,,
13221,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُحَمَّدِ بْنِ سُوقَۃَ ، عَنْ رَجُلٍ ، عَنْ عَلِیٍّ ؛ أَنَّہُ کَانَ یَأْتِی بَعْدَ النَّحْرِ یَوْمًا ، فَقِیلَ لَہُ : ہُوَ نَائِمٌ ، وَمَا زَارَ الْبَیْتَ بَعْدُ۔",,,13221,,
13222,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ أَنْ یُؤَخِّرَہ إلَی الْغَدِ۔",,,13222,,
13223,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنِ الرَّبِیعِ بْنِ سَعْدٍ ، قَالَ : لَقِیتُ أَبَا جَعْفَرٍ الْغَدَ مِنْ یَوْمِ النَّحْرِ ، فَقُلْتُ : إِنِّی لَمْ أَزُرِ الْبَیْتَ بعدُ ، فَقَالَ : وَأَنَا إِنَّمَا زُرْتُ الْیَوْمَ۔",,,13223,,
13224,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، قَالَ : سَمِعْتُ عَمْرَو بْنَ دِینَارٍ یَقُولُ بَعْدَ أَیَّامٍ : مَا زُرْتُ بَعْدُ۔",,,13224,,
13225,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ طَاوُوسٍ ، قَالَ : لَمْ أَعْقِلْ أَبِی یُفِیضُ إِلاَّ لَیْلاً۔",,,13225,,
13226,"حدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ أَنْ یَزُورَ الْبَیْتَ لَیْلاً زِیَارَۃَ یَوْمِ النَّحْرِ ، وَلَکِنْ لاَ یَبِیتَنَّ بِمَکَّۃَ۔",,,13226,,
13227,"حدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، وَحَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا تَرَکَہُ حَتَّی تَمْضِی تِلْکَ الأَیَّامُ ، أَہْرَاقَ لِذَلِکَ دَمًا۔",,,13227,,
13228,"حدَّثَنَا وَکِیعٌ ، عَنْ شَرِیکٍ ، عَنْ یَزِیدَ ، عَنْ مُجَاہِدٍ ، قَالَ : لاَ بَأْسَ أَنْ یُؤَخِّرَ الزِّیَارَۃَ إلَی یَوْمِ النَّحْرِ۔",,,13228,,
13229,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ، وَابْنُ عُلَیَّۃَ ، عَنْ حَجَّاجِ بْنِ أَبِی عُثْمَانَ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ عِکْرِمَۃَ، عَنِ الْحَجَّاجِ بْنِ عَمْرٍو الأَنْصَارِیِّ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : مَنْ حَجَّ فَکُسِرَ، أَوْ عَرَجَ حَلَّ ، وَعَلَیْہِ الْحَجُّ ، فَذَکَرْتُ ذَلِکَ لأَبِی ہُرَیْرَۃَ ، وَابْنِ عَبَّاسٍ ، فَقَالاَ : صَدَقَ۔\n\n(ترمذی 940۔ ابوداؤد 1857)",,,13229,,
13230,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : أَمَرَ اللَّہُ تَعَالَی بِالْقِصَاصِ ، أَفَیَأْخُذُ مِنْکُمَ الْعُدْوَانَ ؟ حَجَّۃٌ بِحَجَّۃٍ ، وَعُمْرَۃٌ بِعُمْرَۃٍ۔",,,13230,,
13231,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عِکْرِمَۃَ ، قَالَ : إذَا أَہَلَّ الرَّجُلُ بِالْحَجِّ فَأُحْصِرَ ، فَلیَبْعَثْ بِہَدْیِہِ ، فَإِنْ مَضَی جَعَلَہَا عُمْرَۃً ، وَعَلَیْہِ الْحَجُّ مِنْ قَابِلٍ ، وَلاَ ہَدْیَ عَلَیْہِ ، وَإِنْ ہُوَ أَخَّرَ ذَلِکَ حَتَّی یَحُجَّ ، فَعَلَیْہِ حَجَّۃٌ وَعُمْرَۃٌ ، وَمَا اسْتَیْسَرَ مِنَ الْہَدْیِ ، فَمَنْ لَمْ یَجِدْ فَصِیَامُ ثَلاَثَۃِ أَیَّامٍ فِی الْحَجِّ ، آخِرُہَا یَوْمُ عَرَفَۃَ۔",,,13231,,
13232,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : سَأَلَنِی عَنْ ذَلِکَ سَعِیدُ بْنُ جُبَیْرٍ ؟ فَأَخْبَرْتُہُ ، فَقَالَ بِیَدِہِ ہَکَذَا وَعَقَدَ ثَلاَثِینَ ، ہَکَذَا قَالَ ابْنُ عَبَّاسٍ۔",,,13232,,
13233,"حدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ إِسْحَاقَ بْنِ سُوَیْد ، قَالَ : سَمِعْتُ عَبْدَ اللہِ بْنَ الزُّبَیْرِ یَخْطُبُ ، فَقَالَ : یَا أَیُّہَا النَّاسُ ، وَاللَّہِ مَا الْمُتَمَتِّعُ بِالْعُمْرَۃِ إلَی الْحَجِّ کَمَا تَقُولُونَ ، وَلَکِنْ إنَّمَا الْمُتَمَتِّعُ بِالْعُمْرَۃِ إلَی الْحَجِّ ؛ أَنْ یُہِلَّ الرَّجُلُ فَیُحْصَرُ إمَّا مَرَضٌ ، أَوْ أَمْرٌ یَحْبِسُہُ حَتَّی تَذْہَبَ أَیَّامُ الْحَجِّ ، فَیَقْدَمُ فَیَجْعَلُہَا عُمْرَۃً وَیَتَمَتَّعُ بِحَجَّۃٍ إلَی الْعَامِ الْمُقْبِلِ ، وَیُہْدِی وَیَحُجُّ ، فَہَذَا الْمُتَمَتِّعُ بِالْعُمْرَۃِ إلَی الْحَجِّ۔",,,13233,,
13234,"حدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، وحُمَیْدٍ ، عَنِ الْحَسَنِ قَالَ : عَلَیْہِ حَجَّۃٌ وَعُمْرَۃٌ۔",,,13234,,
13235,حدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ مِثْلَہُ۔,,,13235,,
13236,"حدَّثَنَا ہُشَیْمٌ ، عن ابن شُبْرُمۃ ، عَنِ الشَّعْبِی ، قَالَ : عَلَیْہِ الْحَجُّ۔",,,13236,,
13237,"حدَّثَنَا ہُشَیْمٌ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : إِنْ کَانَ حَجَّ فَعَلَیْہِ أَنْ یَصِلَ إلَی الْبَیْتِ بِحَجٍّ ، أَوْ عُمْرَۃٍ، وَإِنْ کَانَ لَمْ یَحُجَّ فَعَلَیْہِ الْحَجُّ۔",,,13237,,
13238,"حدَّثَنَا ابْنُ أَبِی عَدِیٍّ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَانَ مُحَمَّدٌ یَقُولُ : إذَا افْترَضَ الرَّجُلُ الْحَجَّ فَأَصَابَہُ حَصْرٌ، فَإِنَّہُ یَبْعَثُ بِہَدْیِہِ ، فَإِذَا بَلَغَ الْہَدْیُ مَحِلَّہُ ، حَلَّ مِنْ أَشْیَائَ وَحَرُمَ مِنْ أُخْرَی ، فَإِذَا کَانَ عَامُ قَابِلٍ أَہَلَّ بِالْحَجِّ وَالْعُمْرَۃِ ، فَإِنْ جَمَعَ بَیْنَہُمَا فَعَلَیْہِ الْہَدْیُ ، وَإِنْ شَائَ أَقَامَ حَتَّی یَبْرَأَ ، فَیَمْضِی مِنْ وَجْہِہِ فَیَطُوفُ بِالْبَیْتِ ، فَیُلْقِی عَنْہُ الْعُمْرَۃَ ، وَعَلَیْہِ الْحَجُّ مِنْ قَابِلٍ۔",,,13238,,
13239,"حدَّثَنَا ابْنُ أَبِی عَدِیٍّ، عَنِ ابْنِ عَوْنٍ، قَالَ: سَأَلْتُ الْقَاسِمَ، وَسَالِمًا عَنِ الْمُحْصَرِ؟ فَقَالاَ: نَحْوَ قَوْلِ مُحَمَّدٍ۔",,,13239,,
13240,"حدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سُلَیْمَانَ بن یسار ؛ أَنَّ مَعْبَدَ بْنَ حُزَابَۃَ الْمَخْزُومِیَّ صُرِعَ بِطَرِیقِ مَکَّۃَ ، فَخَرَجَ ابْنُہُ إلَی الْمَائِ الَّذِی صُرِعَ عَلَیْہِ أَبُوہُ ، فَوَجَدَ ابْنَ عَبَّاسٍ ، وَابْنَ عُمَرَ ، وَمَرْوَانَ بْنَ الْحَکَمِ ، فَکلُّہُمْ ذَکَرَ لَہُ مَصْرَعَ أَبِیہِ وَالَّذِی أَصَابَہُ ، وَکُلُّہُمْ قَالَ : یَتَدَاوَی بِالذِی یُصْلِحُہُ ، فَإِذَا صَحَّ اعْتَمَرَ فَفَسَخَ عَنْہُ حِرْمَ الْحَجِّ ، فَإِذَا أَدْرَکَہُ الْحَجُّ فَعَلَیْہِ الْحَجُّ ، وَمَا اسْتَیْسَرَ مِنَ الْہَدْیِ۔",,,13240,,
13241,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ عُمَارَۃَ بْنِ عُمَیْرٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، قَالَ : خَرَجْنَا عُمَّارًا حَتَّی إذَا کُنَّا بِذَاتِ الشُّقُوقِ ، لُدِغَ صَاحِبٌ لَنَا ، فَاعْتَرَضْنَا الطَّرِیقَ نَسْأَلَ مَا نصنعُ بِہِ ؟ فَإِذَا ابْنُ مَسْعُودٍ فِی رَکْبٍ ، فَقُلْنَا : لُدِغَ صَاحِبٌ لَنَا ؟ فَقَالَ : اجْعَلُوا بَیْنَکُمْ وَبَیْنَ صَاحِبِکُمْ یَوْمَ أَمَارَۃٍ ، وَلْیُرْسِلْ بِالْہَدْیِ ، فَإِذَا نُحِرَ الْہَدْیُ فَلْیُحِلَّ ، وَعَلَیْہِ الْعُمْرَۃُ۔",,,13241,,
13242,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ أَبِی الْعَلاَئِ بْنِ الشِّخِّیرِ ، قَالَ : خَرَجْتُ مُعْتَمِرًا ، فَلَمَّا کُنْتُ بِبَعْضِ الطَّرِیقِ صُرِعْتُ عَنْ رَاحِلَتِی ، فَانْکَسَرَتْ رِجْلِی ، فَأَرْسَلْتُ إلَی ابْنِ عَبَّاسٍ ، وَابْنِ عُمَرَ مَنْ یَسْأَلُہُمَا ، فَقَالاَ : إنَّ الْعُمْرَۃَ لَیْسَ لَہَا وَقْتٌ کَوَقْتِ الْحَجِّ ، لاَ یَحِلَّ حَتَّی یَطُوفَ بِالْبَیْتِ ، فَأَقَمْتُ بِالدَّثِیْنۃ خَمْسَۃَ أَشْہُرٍ ، أَوْ ثَمَانیَۃَ أَشْہُرٍ۔",,,13242,,
13243,"حدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ حَنْظَلَۃَ ، عَنْ طَاوُوس ؛ فِی الْمُحْرِمِ بِعُمْرَۃٍ اعْتُرِضَ لَہُ ، قَالَ : یَبْعَثُ بِہَدْیٍ ، ثُمَّ یَحْسِبُ کَمْ یَسِیرُ ، ثُمَّ یَحْتَاطُ بِأَیَّامٍ ، ثُمَّ یَحِلُّ۔",,,13243,,
13244,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ یَزِیدَ بْنِ یَزِیدَ بْنِ جَابِرٍ ، قَالَ : سَأَلْتُ مُجَاہِدًا عَنِ الْمُحْرِمِ یُوَاقِعُ امْرَأَتَہُ ؟ فَقَالَ: کَانَ ذَلِکَ عَلَی عَہْدِ عُمَرَ بْنِ الْخَطَّابِ ، فَقَالَ : یَقْضِیَانِ حَجَّہُمَا ، وَاللَّہُ أَعْلَمُ بِحَجِّہِمَا ، ثُمَّ یَرْجِعَانِ حَلاَلاً کُلُّ وَاحِدٍ مِنْہُمَا لِصَاحِبِہِ ، فَإِذَا کَانَ مِنْ قَابِلٍ حَجَّا وَأَہْدَیَا ، وَتَفَرَّقَا مِنَ الْمَکَانِ الَّذِی أَصَابَہَا۔",,,13244,,
13245,"حدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ رُفَیْعٍ ، عَنْ عَبْدِ اللہِ بْنِ وَہْبَانَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : جَائَ رَجُلٌ إلَی ابْنِ عَبَّاسٍ ، فَقَالَ : إِنِّی وَقَعْتُ عَلَی امْرَأَتِی وَأَنَا مُحْرِمٌ ، فَقَالَ : اللَّہُ أَعْلَمُ بِحَجِّکُمَا ، امْضِیَا لِوَجْہِکُمَا ، وَعَلَیْکُمَا الْحَجُّ مِنْ قَابِلٍ ، فَإِذَا انْتَہَیْتَ إلَی الْمَکَانِ الَّذِی وَاقَعْتَ فِیہِ فَتَفَرَّقَا ، ثُمَّ لاَ تَجْتَمِعَا حَتَّی تَقْضِیَا حَجَّکُمَا۔",,,13245,,
13246,"حدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، عَنْ عَلِیٍّ ، قَالَ : عَلَی کُلِّ وَاحِدٍ مِنْہُمَا بَدَنَۃٌ ، فَإِذَا حَجَّا مِنْ قَابِلٍ تَفَرَّقَا مِنَ الْمَکَانِ الَّذِی أَصَابَہَا۔",,,13246,,
13247,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : حدَّثَنِی سَعِیدُ بْنُ خُرْشِید ؛ أَنَّ رَجُلاً اسْتَفْتَی جَابِرَ بْنَ زَیْدٍ ، وَالْحَسَنَ بْنَ مُحَمَّدٍ عَنْ رَجُلٍ وَامْرَأَتِہِ أَہَلاَّ بِالْحَجِّ ، ثُمَّ وَقَعَ عَلَیْہَا ، فَقَالاَ : یُتِمَّانِ حَجَّہُمَا ، وَعَلَیْہِمَا الْحَجُّ مِنْ قَابِلٍ ، وَإِنْ کَانَا ذَا مَیْسَرَۃٍ أَہْدَی جَزُورًا۔",,,13247,,
13248,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، قَالَ : أَتَی رَجُلٌ عَبْد اللہ بْن عَمْرٍو فَسَأَلَہُ عَنْ مُحْرِمٍ وَقَعَ بِامْرَأَتِہِ ؟ فَأَشَارَ لَہُ إلَی عَبْدِ اللہِ بْنِ عُمَرَ فَلَمْ یَعْرِفْہُ الرَّجُلُ ، قَالَ شُعَیْبٌ : فَذَہَبْتُ مَعَہُ ، فَسَأَلَہُ ؟ فَقَالَ : بَطَلَ حَجُّہُ ، قَالَ : فَیَقْعُدُ ؟ قَالَ : لاَ ، بَلْ یَخْرُجُ مَعَ النَّاسِ فَیَصْنَعُ مَا یَصْنَعُونَ، فَإِذَا أَدْرَکَہُ قَابِلٌ حَجَّ وَأَہْدَی ، فَرَجَعَا إلَی عَبْدِ اللہِ بْنِ عَمْرٍو فَأَخْبَرَاہُ ، فَأَرْسَلَنَا إلَی ابْنِ عَبَّاسٍ ، قَالَ شُعَیْبٌ : فَذَہَبْتُ إلَی ابْنِ عَبَّاسٍ مَعَہُ ، فَسَأَلَہُ ؟ فَقَالَ لَہُ : مِثْلَ مَا قَالَ ابْنُ عُمْر ، فَرَجَعَ إلَیْہِ فَأَخْبَرَہُ ، فَقَالَ لَہُ الرَّجُلُ : مَا تَقُولُ أَنْتَ ؟ فَقَالَ : مِثْلَ مَا قَالاَ۔",,,13248,,
13249,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : یَمْضِیَانِ لِوَجْہِہِمَا ، وَیَقْضِیَانِ حَجَّہُمَا ، وَیَرْجِعَانِ حَیْثُ أَحَبَّا ، فَإِذَا کَانَ قَابِلٌ أَہَلاَّ مِنْ حَیْثُ کَانَا أَہَلاَّ لِحَجِّہِمَا الَّذِی أَفْسَدَا ، وَأَہْدَیَا وَتَفَرَّقَا",,,13249,,
13250,"حدَّثَنَا محمد بْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، وَعَطَائٍ ، قَالاَ : یَتِمَّانِ عَلَی حَجِّہِمَا ، وَعَلَی کُلِّ وَاحِدٍ مِنْہُمَا دَمٌ ، وَإِنْ کَانَ وَاحِدًا أَجْزَأَہُمَا ، وَعَلَیْہِمَا الْحَجُّ مِنْ قَابِلٍ ، وَلاَ یَتَفَرَّقَانِ",,,13250,,
13251,حدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ لاَ یَعْرِفُ التَّفْرِیقَ فِی الرَّجُلِ إذَا وَاقَعَ وَہُوَ مُحْرِمٌ۔,,,13251,,
13252,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، وَحَمَّادٍ قَالاَ : یَقْضِیَانِ نُسُکَہُمَا وَعَلَیْہِمَا ہَدْیٌ ہَدْیٌ ، وَیَحُجَّانِ مِنْ قَابِلٍ ، فَإِذَا أَتَیَا الْمَکَانَ الَّذِی وَقَعَ بِہَا لَمْ یَجْتَمِعَا حَتَّی یَحِلاَّ۔",,,13252,,
13253,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الزُّبَیْرِ بْنِ عَدِیٍّ ، عَنْ إبْرَاہِیمَ ، قَالَ : عَلَی کُلِّ وَاحِدٍ مِنْہُمَا بَدَنَۃٌ۔",,,13253,,
13254,"حدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ أَبِیہِ ، عَنْ حَمَّادٍ، عَنْ إِبْرَاہِیمَ، عَن عَلْقَمَۃَ، قَالَ: یُہْرِیقُ کُلُّ وَاحِدٍ مِنْہُمَا دَمًا۔",,,13254,,
13255,"حدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ: بَیْنَہُمَا بَدَنَۃٌ ، وَقَالَ سُفْیَانُ : شَاۃٌ تُجْزِیئ۔",,,13255,,
13256,"حدَّثَنَا وَکِیعٌ ، عَنْ عُمَرَ بْنِ ذَرٍّ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : عَلَی کُلِّ وَاحِدٍ مِنْہُمَا ہَدْیٌ۔",,,13256,,
13257,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : عَلَی کُلِّ وَاحِدٍ مِنْہُمَا شَاۃٌ۔",,,13257,,
13258,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ دَاوُدَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : یُہْدِیَانِ ہَدْیًا من عَامِہِمَا۔",,,13258,,
13259,"حدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، عَنْ عَلِیٍّ ، قَالَ : عَلَی کُلِّ وَاحِدٍ مِنْہُمَا بَدَنَۃٌ۔",,,13259,,
13260,"حدَّثَنَا ابْنُ فُضَیْلٍ، عَنْ لَیْثٍ، عَنْ مُجَاہِدٍ، وَعَطَائٍ قَالاَ: یُہْرِیقُ کُلُّ وَاحِدٍ مِنْہُمَا دَمًا، إِنْ کَانَ وَاحِدًا أَجْزَأَہُمَا۔",,,13260,,
13261,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، وَحَمَّادٍ قَالاَ : عَلَیْہِمَا ہَدْیٌ ہَدْیٌ فِیْہِ۔",,,13261,,
13262,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ قَالَ : یُحْرِمَانِ مِنَ الْمَکَانِ الَّذِی أَحْدَثَا فِیہِ۔",,,13262,,
13263,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، وَعَطَائٍ ، قَالاَ : یُحْرِمَانِ مِنَ الْمَکَانِ الَّذِی أَحْرَمَا۔",,,13263,,
13264,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : إِذَا کَانَ قَابِلاً أَہَلاَّ مِنْ حَیْثُ کَانَا أَہَلاَّ بِحَجِّہِمَا الَّذِی أَفْسَدَا۔",,,13264,,
13265,"حدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، قَالَ : أَرْسَلَ مُجَاہِدٌ ، وَسَعِیدُ بْنُ جُبَیْرٍ إلَی عَطَائٍ یَسْأَلاَنِہِ عَنِ الطَّعَامِ لِلْمُحْرِمِ فِیہِ الزَّعْفَرَانُ ؟ فَکَرِہَہُ ، فَقَالاَ : تَأثُرہُ عَنْ أَحَدٍ ؟ فَقَالَ : لاَ ، فَأَکَلا وَلَمْ یَنْظُرَا إلَی قَوْلِہِ۔",,,13265,,
13266,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ خُصَیْفٍ ، قَالَ : سَأَلْتُ مُجَاہِدًا ، وَعَطَائً عَنِ الْخُشْکَنَانَجِ وَالْخَبِیصِ الأَصْفَرِ ؟ فَکَرِہَاہُ ، قَالَ : فَسَأَلْتُ سَعِیدَ بْنَ جُبَیْرٍ ، فَقَالَ : تَدَّہِنُ بِالزَّیْتِ وَأَنْتَ مُحْرِمٌ ؟ قَالَ : قُلْتُ : لاَ ، قَالَ : فَتَدَّہِنُ بالسمن وَأَنْتَ مُحْرِمٌ ؟ قُلْتُ : لاَ ، قَالَ : فَإِنَّ الْخُشْکَنَانَجَ قَدْ طُبِخَ بِالنَّارِ۔",,,13266,,
13267,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، عَنْ جَابِرِ بْنِ زَیْدٍ ، قَالَ : لاَ بَأْسَ بِالْخُشْکَنَانَجِ الْمُعَصْفَرِ لِلْمُحْرِمِ۔",,,13267,,
13268,حدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ لاَ یَرَی بِالْخَبِیصِ الأَصْفَرِ وَالْخُشْکَنَانَجِ الأَصْفَرِ بَأْسًا ، إذَا مَسَّتْہُ النَّارُ۔,,,13268,,
13269,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ طَاوُوسٍ ، وَعَطَائٍ ؛ أَنَّہُمَا کَانَا لاَ یَرَیَانِ بَأْسًا بِالْخَبِیصِ الأَصْفَرِ لِلْمُحْرِمِ، وَیَقُولاَنِ : مَا مَسَّتْہُ النَّارُ فَلاَ بَأْسَ بِہِ۔",,,13269,,
13270,"حدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ : لاَ بَأْسَ أَنْ یَأْکُلَ الْمُحْرِمُ الطَّعَامَ فِیہِ الزَّعْفَرَانُ۔",,,13270,,
13271,حدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ الْحَکَمِ ؛ أَنَّہُ کَانَ لاَ یَرَی بِالْخَبِیصِ الأَصْفَرِ وَالْخُشْکَنَانَجِ الأَصْفَرِ بَأْسًا لِلْمُحْرِمِ۔,,,13271,,
13272,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ الأَعْمَشِ ، قَالَ : ذُکِرَ لإِبْرَاہِیمَ أَنَّ الْمُغِیرَۃَ یَکْرَہُ أَنْ یَأْکُلَ الْخُشْکَنَانَجَ الأَصْفَرَ فِی الإِحْرَامِ ، فَکَانَ إبْرَاہِیمُ یَعْجَبُ مِنْہُ۔",,,13272,,
13273,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَد ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یَأْکُلُ الْخُشْکَنَانَجَ الأَصْفَرَ وَہُوَ مُحْرِمٌ ۔ قَالَ : وَکَانَ أَبُو جَعْفَرٍ لاَ یَرَی بِالطَّعَامِ فِیہِ الزَّعْفَرَانُ بَأْسًا۔",,,13273,,
13274,حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَلِیِّ بْنِ بَذِیمَۃَ ، عَنْ رَجُلٍ ، عَنْ عُرْوَۃَ بْنِ الزُّبَیْرِ ؛ أَنَّہُ کَرِہَہُ ، ثُمَّ لَمْ یَرَ بِہِ بَأْسًا۔,,,13274,,
13275,حدَّثَنَا الْمُحَارِبِیُّ ، عَنْ لَیْثٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ لَمْ یَکُنْ یَرَی بَأْسًا بِالْخُشْکَنَانَجِ الأَصْفَرِ لِلْمُحْرِمِ۔,,,13275,,
13276,حدَّثَنَا وَکِیعٌ ، عَنْ أَفْلَحَ ، عَنِ الْقَاسِمِ ؛ أَنَّہُ کَرِہَہُ۔,,,13276,,
13277,حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ؛ مِثْلَہُ۔,,,13277,,
13278,حدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ مُحَمَّدِ بْنِ مُسْلِمٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَرِہَ الزَّعْفَرَانَ عَلَی الطَّعَامِ لِلْمُحْرِمِ۔,,,13278,,
13279,حدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ (ح) وَعَنِ الْحَکَمِ بْنِ عُتَیْبَۃَ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُمَا کَانَا لاَ یَرَیَانِ بَأْسًا بِأَکْلِ الْمُحْرِمِ الْمِلْحَ الَّذِی فِیہِ الزَّعْفَرَانُ۔,,,13279,,
13280,"حدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : لاَ بأس بالْمِلْحِ الأَصْفَرِ لِلْمُحْرِمِ۔",,,13280,,
13281,حدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُوسٍ ؛ أَنَّہُمَا کَانَا یَکْرَہَانِ الْمِلْحَ الأَصْفَرَ لِلْمُحْرِمِ۔,,,13281,,
13282,"حدَّثَنَا وَکِیعٌ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، قَالَ : سَأَلْتُ جَعْفَرًا عَنِ الْمِلْحِ الأَصْفَرِ لِلْمُحْرِمِ ؟ فَکَرِہَہُ",,,13282,,
13283,"حدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی بِشْرٍ ، قَالَ : کُنْتُ عِنْدَ سَعِیدِ بْنِ الْمُسَیَّبِ ، فَقَالَ لَہُ رَجُلٌ : إنِّی أُرِیدُ أَنْ أُحْرِمَ وَمَعِی ثَوْبٌ مَصْبُوغٌ بِالزَّعْفَرَانِ ، فَغَسَلْتُہُ حَتَّی ذَہَبَ لَوْنُ الزَّعْفَرَانِ ، فَقَالَ سَعِیدٌ : مَعَکَ ثَوْبٌ غَیْرُہُ ؟ قَالَ: لاَ ، قَالَ : فَأَحْرِمْ فِیہِ۔",,,13283,,
13284,"حدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی بِشْرٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : یَغْسِلُہُ وَیُحْرِمُ فِیہِ۔",,,13284,,
13285,"حدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ مُطَرِّفٍ ، عَنْ صَالِحِ بْنِ جُبَیْرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : أَتَیْتُہُ فِی مِلْحَفَۃٍ مَصْبُوغَۃٍ بِالزَّعْفَرَانِ مُشْبَعۃٍ ، فَقُلْتُ : أُحْرِمُ فِی ہَذِہِ ؟ فَقَالَ : اغْسِلْہَا وَأَحْرِمْ فِیہَا۔",,,13285,,
13286,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ إِسْحَاقَ ، مَوْلَی آلِ عُمَرَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : لاَ بَأْسَ أَنْ یُحْرِمَ فِی الثَّوْبِ الْمَصْبُوغِ بِالزَّعْفَرَانِ ، إذَا غَسَلَہُ۔",,,13286,,
13287,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ بَأْسَ أَنْ یُحْرِمَ الرَّجُلُ فِی الثَّوْبِ قَدْ صُبِغَ بِالزَّعْفَرَانِ ، ثُمَّ غُسِلَ ، لَیْسَ لَہُ نَفْضٌ ، وَلاَ رَدْعٌ۔",,,13287,,
13288,"حدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ؛ فِی الثَّوْبِ الْمَصْبُوغِ بِالْوَرْسِ وَالزَّعْفَرَانِ ، قَالَ : إذَا غُسِلَ ذَلِکَ مِنْہُ فَذَہَبَ لَمْ یَرَہُ شَیْئًا أَنْ یَلْبَسَہُ الْمُحْرِمُ۔",,,13288,,
13289,حدَّثَنَا عَبْدَۃُ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ؛ مِثْلَہُ۔,,,13289,,
13290,"حدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ عَبْدِ الأَعْلَی ، عَنِ ابْنِ الْحَنَفِیَّۃِ ، قَالَ : اغْسِلْہُ وَأَحْرِمْ فِیہِ۔",,,13290,,
13291,حدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ ہِشَامٍ ؛ أَنَّ عَبْدَ اللہِ بْنَ عُرْوَۃَ سَأَلَ عُرْوَۃَ عَنِ الثَّوْبِ الْمَصْبُوغِ ، إِذَا غُسِلَ حَتَّی یَذْہَبَ لَوْنُہُ ؟ فنہاہ عَنْہُ۔,,,13291,,
13292,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، عَن عَائِشَۃَ قَالَتْ : یُکْرَہُ لِلْمُحْرِمِ الثَّوْبُ الْمَصْبُوغُ بِالزَّعْفَرَانِ ، وَالْمُشْبَعَۃُ بِالْعُصْفُرِ لِلرِّجَالِ وَالنِّسَائِ ، إِلاَّ أَنْ یَکُونَ ثَوْبًا غَسِیلاً۔",,,13292,,
13293,"حدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، عَنْ سُفْیَانَ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ : إذَا غُسِلَ الثَّوْبُ الْمَصْبُوغُ ، وَذَہَبَ رِیحُہُ ، قَالَ : لاَ بَأْسَ أَنْ یُحْرِمَ فِیہِ۔",,,13293,,
13294,"حدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی بِشْرٍ ، عَنْ جَابِرِ بْنِ زَیْدٍ ، قَالَ : سَأَلْتُُہُ عَنِ الْقَمْلَۃِ أَجِدُہَا عَلَی وَجْہِی وَأَنَا مُحْرِمٌ ؟ فَقَالَ : أَلْقِہَا عَنْ وَجْہِکَ ، فَلَیْسَ لَہَا فِیہِ نَصِیبٌ۔",,,13294,,
13295,"حدَّثَنَا حَفْصٌ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ : جَائَتِ امْرَأَۃٌ إلَی ابْنِ عُمَرَ فَسَأَلَتْہُ ، فَقَالَتْ : إِنِّی وَجَدْتُ قَمْلَۃً فَأَلْقَیْتُہَا ، أَوْ قَتَلْتُہَا ؟ قَالَ : مَا الْقَمْلَۃُ مِنَ الصَّیْدِ۔",,,13295,,
13296,"حدَّثَنَا أَبُو الأَحْوَصِِ ، عَنِ الْعَلاَئِ بْنِ الْمُسَیَّبِ ، قَالَ : قَالَ رَجُلٌ لِعَطَائٍ : أَطْرَحُ الْقَمْلَۃَ تَدِبُّ عَلَیَّ ؟ قَالَ: نَعَمْ ، قَالَ : فَأَتَقَمَّلُ ؟ قَالَ : یُکْرَہُ أَنْ تُقَمِّلَ ثِیَابَکَ وَأَنْتَ مُحْرِمٌ ، قَالَ : قُلْتُ : الْقُرَادُ وَالْقَمْلَۃُ تَدِبُّ عَلَیَّ؟ قَالَ : انْبِذْ عَنْکَ مَا لَیْسَ مِنْکَ۔",,,13296,,
13297,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عُیَیْنَۃَ بْنِ عَبْدِ الرَّحْمَنِ ، قَالَ : سُئِلَ عِکْرِمَۃُ بْنُ خَالِدٍ الْمَخْزُومِیُّ عَنِ الْمُحْرِمِ یَرَی الْقَمْلَۃَ فِی ثَوْبِہِ ؟ قَالَ : یَأْخُذُہَا أَخْذًا رَفِیقًا ، فَیَضَعُہَا عَلَی الأَرْضِ وَلاَ یَتَفَلَّی۔",,,13297,,
13298,"حدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ الْغَازِ ، عَنْ عَطَائٍ ، قَالَ : یُلْقِی الْمُحْرِمُ عنْہُ الْقَمْلَۃَ إِنْ شَائَ۔",,,13298,,
13299,"حدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ أَبِیہِ ، قَالَ : عَلِقَ بِی قُرَادٌ وَأَنَا مُحْرِمٌ ، فَقُلْتُ لِطَلْقِ بْنِ حَبِیبٍ ؟ فَقَالَ : اطْرَحْہُ ، أَبعدَ اللہُ الْقُرَادَ۔",,,13299,,
13300,"حدَّثَنَا ابْنُ مُسْہِرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : طَافَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِالْبَیْتِ فِی حَجَّۃِ الْوَدَاعِ عَلَی رَاحِلَتِہِ ، یَسْتَلِمُ الْحَجَرَ بِمِحْجَنِہِ۔ (مسلم 255۔ ابوداؤد 1875)",,,13300,,
13301,حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ الْحَذَّائِ ، عَنْ عِکْرِمَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ طَافَ بِالْبَیْتِ عَلَی بَعِیرٍ ، فَکَانَ إذَا أَتَی عَلَی الْحَجَرِ الأَسْوَد أَشَارَ إلَیْہِ۔,,,13301,,
13302,"حدَّثَنَا عَبْدَۃُ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ؛ أَنَّ أُمَّ سَلَمَۃَ قَالَتْ : یَا رَسُولَ اللہِ ، مَا طُفْتُ طَوَافَ الْخُرُوجِ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِذَا أُقِیمَتِ الصَّلاَۃُ فَطُوفِی عَلَی بَعِیرِکَ مِنْ وَرَائِ النَّاسِ۔\n\n(بخاری 1619۔ ابوداؤد 1877)",,,13302,,
13303,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : جَائَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَقَدِ اشْتَکَی ، فَطَافَ بِالْبَیْتِ عَلَی بَعِیرٍ وَمَعَہُ مِحْجَنٌ ، کُلَّمَا مَرَّ عَلَی الْحَجَرِ اسْتَلَمَہُ ، فَلَمَّا فَرَغَ مِنْ طَوَافِہِ أَنَاخَ ، ثُمَّ صَلَّی رَکْعَتَیْنِ۔ (بخاری 1612۔ ابوداؤد 1872)",,,13303,,
13304,"حدَّثَنَا وَکِیعٌ ، عَنْ مَعْرُوفٍ الْمَکِّیِّ ، قَالَ : سَمِعْتُ أَبَا الطُّفَیْلِ وَأَنَا غُلاَمٌ یَقُول : رَأَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَطُوفُ بِالْبَیْتِ عَلَی رَاحِلَتِہِ۔ (مسلم 927۔ ابوداؤد 1874)",,,13304,,
13305,"حدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ طَافَ بِالْبَیْتِ عَلَی رَاحِلَتِہِ ، یَسْتَلِمُ الْحَجَرَ بِمِحْجَنِہِ ، وَبَیْنَ الصَّفَا وَالْمَرْوَۃِ ، فَقُلْتُ لِعَطَائٍ: مَا أَرَادَ إلَی ذَلِکَ؟ قَالَ: التَّوْسِعَۃَ عَلَی أُمَّتِہِ۔",,,13305,,
13306,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، قَالَ : کَانَ أَبِی إِذَا رَآہُمْ یَطُوفُونَ بِالْبَیْتِ عَلَی الدَّوَابِّ نَہَاہُمْ۔",,,13306,,
13307,حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَمَّادٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سَعَی عَلَی رَاحِلَتِہِ بَیْنَ الصَّفَا وَالْمَرْوَۃِ۔,,,13307,,
13308,"حدَّثَنَا وَکِیعٌ ، عَنْ قَیْسِ بْنِ عَبْدِ اللہِ ، عَنْ أَبِی إدْرِیسَ ، قَالَ : رَأَیْتُ عَائِشَۃَ تَسْعَی بَیْنَ الصَّفَا وَالْمَرْوَۃِ عَلَی بَغْلٍ۔",,,13308,,
13309,"حدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنِ الأَحْوَصِ ، قَالَ : رَأَیْتُ أَنَسًا یَطُوفُ بَیْنَ الصَّفَا وَالْمَرْوَۃِ عَلَی حِمَارٍ۔",,,13309,,
13310,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنِ الرَّبِیعِ بْنِ سَعد ، قَالَ ، سَأَلْتُ أَبَا جَعْفَرٍ عَنِ الطَّوَافِ بَیْنَ الصَّفَا وَالْمَرْوَۃِ ؟ فَقَالَ : طَافَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَاکِبًا وَأَنَا أَطُوفُ رَاکِبًا ، فَطُفْتُ أَنَا وَہُوَ رَاکِبَیْنِ۔",,,13310,,
13311,حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَعَطَائٍ ؛ أَنَّہُمَا کَانَا یَکْرَہَانِ رُکُوبَ الرِّجَالِ وَالنِّسَائِ بَیْنَ الصَّفَا وَالْمَرْوَۃِ ، إِلاَّ مِنْ عُذْرٍ۔,,,13311,,
13312,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ خَارِجَۃَ بْنِ الْحَارِثِ ، قَالَ : رَأَیْتُ عِرَاکَ بْنَ مَالِکٍ یَطُوفُ بَیْنَ الصَّفَا وَالْمَرْوَۃِ عَلَی حِمَارٍ۔",,,13312,,
13313,"حدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ یَزِیدَ الشَّیْبَانِیِّ ، قَالَ : رَأَیْتُ مُجَاہِدًا ، وَعَطَائً یَسْعَیَانِ بَیْنَ الصَّفَا وَالْمَرْوَۃِ عَلَی دَابَّتَیْنِ۔",,,13313,,
13314,"حدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، قَالَ : کَانَ أَبِی إذَا رَآہُمْ وَ ہُمْ یَسْعَوْنَ بَیْنَ الصَّفَا وَالْمَرْوَۃِ رُکْبَانًا ، قَالَ : قَدْ خَابَ ہَؤُلاَئِ وَخَسِرُوا۔",,,13314,,
13315,حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ زَمْعَۃَ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ؛ أَنَّہُ کان یَکْرَہُ الرُّکُوبَ بَیْنَ الصَّفَا وَالْمَرْوَۃِ إِلاَّ مِنْ ضَرُورَۃٍ۔,,,13315,,
13316,"حدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی یَعْفُورٍ ، قَالَ : خَطَبَنَا رَجُلٌ مِنْ خُزَاعَۃَ ، کَانَ أَمِیرًا عَلَی الْحَجِّ بِمَکَّۃَ ، فَقَالَ : أَیُّہَا النَّاسُ ، إِنَّ عُمَرَ کَانَ رَجُلاً شَدِیدًا ، وَإِنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ لَہُ : یَا عُمَرُ ، إنَّکَ رَجُلٌ شَدِیدٌ تُؤْذِی الضَّعِیفَ ، فَإِذَا طُفْتَ بِالْبَیْتِ فَرَأَیْتَ مِنَ الْحَجَرِ خَلْوَۃً فَادْنُ مِنْہُ ، وَإِلاَّ فَکَبِّرْ وَہَلِّلْ وَامْضِ۔ (احمد 1/28۔ بیہقی 80)",,,13316,,
13317,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إذَا حَاذَیْتَ بِہِ ، فَکَبِّرْ وَادْعُ وَصَلِّ عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,13317,,
13318,"حدَّثَنَا حَفْصٌ ، عَنْ عَاصِمٍ ، قَالَ : رَأَیْتُ أَنَسَ بْنَ مَالِکٍ یَطُوفُ بِالْبَیْتِ ، حَتَّی إذَا حَاذَی بِالْحَجَرِ نَظَرَ إلَیْہِ وَالْتَفَتَ إلَیْہِ ، فَکَبَّرَ نَحْوَہُ۔",,,13318,,
13319,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَاصِمٍ ، قَالَ : رَأَیْتُ أَنَسًا یَسْتَقْبِلُ الأَرْکَانَ بِالتَّکْبِیرِ۔",,,13319,,
13320,"حدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، قَالَ : کَانَ أَبِی إذَا غُلِبَ اسْتَقْبَلَہُ وَکَبَّرَ وَمَضَی۔",,,13320,,
13321,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَبْدِ الْمَلِکِ ، قَالَ : رَأَیْتُ سَعِیدَ بْنَ جُبَیْرٍ حِینَ اسْتَفْتَحَ الطَّوَافَ اسْتَقْبَلَ الْحَجَرَ وَلَمْ یَمَسَّہُ ، وَرَفَعَ یَدَیْہِ وَکَبَّرَ ، فَسَأَلْتُ عَطَائً ؟ فَقَالَ : کَبِّرْ ، وَلاَ تَرْفَعْ یَدَیْکَ بِالتَّکْبِیرِ۔",,,13321,,
13322,"حدَّثَنَا وَکِیعٌ ، عَنْ مُحَمَّدِ بْنِ برْجَان ، قَالَ : رَأَیْتُ مُجَاہِدًا إذَا مَرَّ بِالْحَجَرِ نَظَرَ إلَیْہِ فَکَبَّرَ۔",,,13322,,
13323,"حدَّثَنَا ابْنُ فُضَیْلٍ ، وَوَکِیعٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ : قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لِعَبْدِ الرَّحْمَنِ بْنِ عَوْفٍ : مَا صَنَعْتَ ؟ قَالَ : اسْتَلَمْتُ وَتَرَکْتُ ، قَالَ : أَصَبْتَ۔ (حاکم 307۔ ابن حبان 3823)",,,13323,,
13324,"حدَّثَنَا وَکِیعٌ، عَنْ طَلْحَۃَ بْنِ یَحْیَی، عَنِ الْقَاسِمِ، قَالَ: رَأَیْتُ ابْنَ عُمَرَ زَاحَمَ عَلَی الْحَجَرِ حَتَّی دَمِیَ مَنْخِرُہُ۔",,,13324,,
13325,"حدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : طُفْتُ مَعَہُ ، فَکَانَ لاَ یُزَاحِمُ عَلَی الْحَجَرِ۔",,,13325,,
13326,"حدَّثَنَا أَبُو سَعدٍ مُحَمَّدُ بْنُ مُیَسَّر ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : إذَا کَانَ عَلَی الْحَجَرِ زِحَامٌ ، فَلاَ تُؤْذِیَنَّ وَلا تُؤْذَیَنَّ ، وَابْعُدْ مِنْہُ۔",,,13326,,
13327,"حدَّثَنَا وَکِیعٌ ، عَنِ الْمُخْتَارِ بن عَمْرٍو ، عَنْ جَابِرِ بْنِ زَیْدٍ ، قَالَ : لاَ یُزَاحَمُ عَلَی الْحَجَرِ۔",,,13327,,
13328,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : کَانَ یَکْرَہُ أَنْ تُزَاحِمَ عَلَی الْحَجَرِ، تُؤْذِی مُسْلِمًا ، أَوْ یُؤْذِیکَ۔",,,13328,,
13329,حدَّثَنَا عُبَیْدُ اللہِ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَطَائٍ ، وَمُجَاہِدٍ ، وَمُحَمَّدِ بْنِ عَلِیٍّ ، وَسَالِمٍ ، وَالْقَاسِمِ ؛ أَنَّہُمْ لَمْ یَکُونُوا یُزَاحِمُونَ عَلَی الْحَجَرِ ، وَکَانُوا یُقِیمُونَ سَاعَۃً مُسْتَقْبَلَہ۔,,,13329,,
13330,"حدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ سَعْدِ بْنِ عُبَیْدٍ الطَّائِیِّ ، قَالَ : رَأَیْتُ الْحَسَنَ أَتَی الْحَجَرَ فَرَأَی زِحَامًا فَلَمْ یَسْتَلِمْہُ ، فَدَعَا ، ثُمَّ أَتَی الْمَقَامَ فَصَلَّی عِنْدَہُ رَکْعَتَیْنِ۔",,,13330,,
13331,حدَّثَنَا وَکِیعٌ ، عَنْ أَبِی الْعَوَّامِ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ کَانَ یَسْتَلِمُہُ وَلاَ یُزَاحِمُ علیہ ، وَکَانَ ابْنُ عُمَرَ یَفْعَلُہُ۔,,,13331,,
13332,"حدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، وَحَجَّاجٍ ، وَعَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : سَمِعْتُ ابْنَ عَبَّاسٍ یَقُولُ: یَا أَیُّہَا النَّاسُ ، إنَّ دُخُولَکُمُ الْبَیْتَ لَیْسَ مِنْ حَجِّکُمْ فِی شَیْئٍ۔",,,13332,,
13333,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ فِی الْحَاجِّ ، قَالَ : إِنْ شَائَ دَخَلَ الْکَعْبَۃَ ، وَإِنْ شَائَ لَمْ یَدْخُلْہَا، وَقَالَ : إِنْ دَخَلَہَا فَحَسَنٌ ، وَإِنْ لَمْ یَدْخُلْہَا فَلاَ بَأْسَ ، وَإِنْ دَخَلْتَہَا فَتَیَامِن إلَی السَّارِیَۃِ الْوُسْطَی فَصَلِّ عِنْدَہَا۔",,,13333,,
13334,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الْعَلاَئِ ، عَنْ خَیْثَمَۃَ ؛ أَنَّہُ سُئِلَ عَنْ دُخُولِ الْبَیْتِ ؟ فَقَالَ : لاَ یَضُرُّک وَاللَّہِ أَنْ لاَ تَدْخُلَہُ۔",,,13334,,
13335,"حدَّثَنَا وَکِیعٌ ، عَنْ وَاقِدٍ ، عَنْ عَطَائٍ ، قَالَ : إِنْ شِئْتَ فَلاَ تَدْخُلْہُ۔",,,13335,,
13336,"حدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : مَنْ دَخَلَ الْبَیْتَ دَخَلَ فِی حَسَنَۃٍ ، وَخَرَجَ مِنْ سَیِّئَۃٍ ، وَخَرَجَ مَغْفُورًا لَہُ۔",,,13336,,
13337,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عُرْوَۃَ ، عَنْ عَائِشَۃَ ، قَالَتْ : حَاضَتْ صَفِیَّۃُ بَعْدَ مَا أَفَاضَتْ، فَأُخْبِرَ بِذَلِکَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : أَحَابِسَتُنَا ہِیَ ؟ قُلْتُ : قَدْ طَافَتْ ثُمَّ حَاضَتْ بَعْدَ ذَلِکَ ، قَالَ : فَلْتَنْفِرْ۔ (مسلم 383۔ ابوداؤد 1996)",,,13337,,
13338,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ بِمِثْلِہِ ، إِلاَّ أَنَّہُ قَالَ : فَلاَ إِذَنْ۔\n\n(بخاری 1757۔ مسلم 384)",,,13338,,
13339,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَد ، عَنْ عَائِشَۃَ قَالَتْ : ذَکَرَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَفِیَّۃَ فَقُلْنَا : إِنَّہَا قَدْ حَاضَتْ ، فَقَالَ : عَقْرَی حَلْقَی ، مَا أُرَاہَا إِلاَّ حَابِسَتَنَا قَالَتْ: قُلْتُ : إِنَّہَا قَدْ طَافَتْ یَوْمَ النَّحْرِ ، قَالَ : فَلاَ إِذَنْ ، مُرُوہَا فَلْتَنْفِرْ۔ (مسلم 965۔ نسائی 4189)",,,13339,,
13340,"حدَّثَنَا جَرِیرٌ ، عَنْ أَبِی فَرْوَۃَ ، قَالَ : سَأَلْتُ القَاسِمَ بْنَ مُحَمَّدٍ ، عَنِ امْرَأَۃٍ زَارَتِ الْبَیْتَ یَوْمَ النَّحْرِ ، ثُمَّ حَاضَتْ قَبْلَ النَّفْرِ ؟ فَقَالَ : یَرْحَمُ اللَّہُ عُمَرَ ، کَانَ أَصْحَابُ مُحَمَّدٍ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُونَ : قَدْ فَرَغَتْ إِلاَّ عُمَرَ ، فَإِنَّہُ کَانَ یَقُولُ : یَکُونُ آخِرَ عَہْدِہَا بِالْبَیْتِ۔",,,13340,,
13341,"حدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ مَیْسَرَۃَ ، عَنْ طَاوُوسٍ ، قَالَ : مَا رَأَیْتُ ابْنَ عَبَّاسٍ خَالَفَہُ أَحَدٌ فِی شَیْئٍ فَتَرَکَہُ ، حَتَّی یُقَرِّرَہُ ، فَخَالَفَہُ جَابِرُ بْنُ عَبْدِ اللہِ فِی الْمَرْأَۃِ تَطُوفُ ثُمَّ تَحِیضُ ، فَقَالَ ابْنُ عَبَّاسٍ : تَنْفِرُ ، فَأَرْسَلُوا إلَی امْرَأَۃٍ کَانَ أَصَابَہَا ذَلِکَ فَوَافَقَتِ ابْنَ عَبَّاسٍ۔",,,13341,,
13342,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ یَعْلَی بْنِ عَطَائٍ ، قَالَ : سَمِعْتُ الْقَاسِمَ بْنَ رَبِیعَۃَ ، قَالَ : سَأَلْتُ سَعْدَ بْنَ مَالِکٍ عَنِ امْرَأَۃٍ حَاضَتْ بَعْدَ الطَّوَافِ بِالْبَیْتِ یَوْمَ النَّحْرِ ؟ قَالَ : تَصْدُرُ۔",,,13342,,
13343,حدَّثَنَا جَرِیرٌ ، عَنِ ابْنِ شُبْرُمَۃَ ، عَنْ سَالِمِ بْنِ عَبْدِ اللہِ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یُقِیمُ عَلَی الْحَائِضِ ، إِنْ کَانَتْ طَافَتْ طَوَافَ یَوْمِ النَّحْرِ سَبْعَۃَ أَیَّامٍ ، حَتَّی تَطُوفَ طَوَافَ یَوْمِ النَّفْرِ۔,,,13343,,
13344,"حدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ یَزِیدَ بْنِ ہَانِیئٍ ؛ أَنَّ امْرَأَۃً طَافَتْ ثُمَّ حَاضَتْ یَوْمَ النَّحْرِ بَعْدَمَا طَافَتْ ، فَسُئِلَ الْحَسَنُ بْنُ عَلِیٍّ ؟ فَقَالَ : تَنْفِرُ۔",,,13344,,
13345,"حدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا أَبُو عَوَانَۃَ ، عَنْ یَعْلَی بْنِ عَطَائٍ ، عَنِ الْوَلِیدِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنِ الْحَارِثِ بْنِ عَبْدِ اللہِ بْنِ أَوْسٍ الثَّقَفِیِّ ، قَالَ : سَأَلْتُ عُمَرَ بْنَ الْخَطَّابِ عَنِ الْمَرْأَۃِ تَطُوفُ بِالْبَیْتِ ثُمَّ تَحِیضُ ؟ فَقَالَ : لِیَکُنْ آخِرُ عَہْدِہَا بِالْبَیْتِ ، فَقَالَ الْحَارِثُ : کَذَلِکَ أَفْتَانِی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ عُمَرُ : أُرِبْتَ عَنْ یَدَیْکَ ، سَأَلْتنِی عَنْ شَیْئٍ سَأَلْتَ عَنْہُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، کَیْمَا أُخَالِفَہُ۔\n\n(ترمذی 946۔ ابوداؤد 1997)",,,13345,,
13346,"حدَّثَنَا زِیَادُ بْنُ الرَّبِیعِ الْیُحْمِدِیُّ ، عَنْ صَالِحٍ الدَّہَّانِ ، قَالَ : قَالَ جَابِرُ بْنُ زَیْدٍ : الصَّوْمُ وَالصَّلاَۃُ یُجْہِدَانِ الْبَدَنَ ، وَلاَ یُجْہِدَانِ الْمَالَ ، وَالصَّدَقَۃُ تُجْہِدُ الْمَالَ ، وَلاَ تُجْہِدُ الْبَدَنَ ، وَإِنِّی لاَ أَعْلَمُ شَیْئًا أَجْہَدَ لِلْمَالِ وَالْبَدَنِ مِنْ ہَذَا الْوَجْہِ ، یَعْنِی الْحَجَّ۔",,,13346,,
13347,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی مِسْکِینٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یَرَوْنَ أَنَّـہُ إِذَا حَجَّ مِرَارًا ، أَنَّ الصَّدَقَۃَ أَفْضَلُ۔",,,13347,,
13348,"حدَّثَنَا وَکِیعٌ ، عَنِ الْحَکَمِ بْنِ عَطِیَّۃَ ، قَالَ : سَأَلْتُ الْحَجَّاجَ عَنْ رَجُلٍ قَضَی مَنَاسِکَ الْحَجِّ ، أَیَحُجُّ ، أَوْ یُعْتِقُ ؟ قَالَ : لاَ ، بَلْ یُعْتِقُ۔",,,13348,,
13349,"حدَّثَنَا وَہْبُ بْنُ إسْمَاعِیلَ الأَسَدِیُّ ، عَنْ سَعِیدِ بْنِ عُبَیْدٍ الطَّائِیِّ ، عَنِ الشَّعْبِیِّ ، قَالَ : جَائَہُ بَعْضُ جِیرَانِہِ ، فَقَالَ : إنِّی قَدْ تَہَیَّأْتُ لِلْخُرُوجِ ، وَلِی جِیرَانٌ مُحْتَاجُونَ مُتَعَفِّفُونَ ، فَمَا تَرَی لِی ؟ أَجْعَلُ کِرَائِی وَجَہَازِی فِیہِمْ ، أَوْ أَمْضِی لِوَجْہِی لِلْحَجِّ ؟ فَقَالَ : وَاللَّہِ ، إِنَّ الصَّدَقَۃَ لَعَظِیمٌ أَجْرُہَا ، وَمَا یَعْدِلُ عِنْدِی مَوْقِفٌ مِنَ تِلْکَ الْمَوَاقِفِ شَیْئًا مِنَ الأَشْیَائِ۔",,,13349,,
13350,"حدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ قَالَ : مَا أَنْفَقَ النَّاسُ مِنْ نَفَقَۃٍ أَعْظَمَ أَجْرًا مِنْ دَمٍ یُہَرَاقُ یَوْمَ النَّحْرِ ، إِلاَّ رَحِمٌ مُحْتَاجَۃٌ یَصِلُہَا۔",,,13350,,
13351,"حدَّثَنَا الْمُحَارِبی ، عَنْ لَیْثٍ ، عَنْ حَبِیبٍ ، عَنْ حُسَیْنِ بْنِ عَلِیٍّ ، قَالَ : لأَنْ أَقُوتَ أَہْلَ بَیْتٍ بِالْمَدِینَۃِ صَاعًا کُلَّ یَوْمٍ ، أَوْ صَاعَیْنِ شَہْرًا ، أَحَبُّ إلَیَّ مِنْ حَجَّۃٍ فِی إثْرِ حَجَّۃٍ۔",,,13351,,
13352,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ ، قَالَ : مَا عَمِلَ النَّاسُ بَعْدَ الْفَرِیضَۃِ أَحَبُّ إلَیَّ مِنْ إطْعَامِ مِسْکِینٍ۔",,,13352,,
13353,"حدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطَائٍ (ح) وَعَنْ عَبْدِ الْکَرِیمِ ، عَنْ مُعَاذِ بْنِ سَعْوَۃَ ، عَنْ سِنَانِ بْنِ سَلَمَۃَ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : الْہَدْیُ التَّطَوُّعُ لاَ یُؤْکَلُ مِنْہُ ، فَإِنْ أَکَلَ غَرِمَ۔ (احمد 7)",,,13353,,
13354,"حدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ مُحَمَّدِ بْنِ ذَکْوَانَ ، عَنِ الشَّعْبِیِّ ، عَنْ عَلِیٍّ ، وَعَبْدِ اللہِ قَالاَ : إِنْ أَکَلَ مِنْہُ غَرِمَ۔",,,13354,,
13355,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، عَنْ عُمَرَ ، قَالَ : مَنْ أَہْدَی ہَدْیًا تَطَوُّعًا ، فَعَطِبَ نَحَرَہُ دُونَ الْحَرَمِ ، وَلَمْ یَأْکُلْ مِنْہُ ، فَإِنْ أَکَلَ فَعَلَیْہِ الْبَدَلُ۔",,,13355,,
13356,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، قَالَ : بَعَثَ مَعِی عَبْدُ اللہِ بِہَدْیِہِ ، قَالَ : وَأَمَرَنِی إِذَا نَحَرْتُہُ أَنْ أَتَصَدَّقَ بِثُلُثٍ ، وَآکُلَ ثُلُثًا ، وَأَبْعَثَ إلَی أَہْلِ أَخِیہِ عُتْبَۃ بِثُلُثٍ۔",,,13356,,
13357,حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ فِی الْبَدَنَۃِ لَیْسَ عَلَیْہِ شَیْئٌ فِی التَّطَوُّعِ ، إِلاَّ أَنْ یَأْمُرَ فِیہَا بِأَمْرٍ ، أَوْ یَأْکُلَ ، أَوْ یُطْعِمَ ، فَإِنْ فَعَلَ أَبْدَلَ۔,,,13357,,
13358,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ جَابِرِ بْنِ زَیْدٍ ، قَالَ : إذَا أَکَلْتَ مِنْ ہَدْیِ التَّطَوُّعِ غَرِمْتَ۔",,,13358,,
13359,"حدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، قَالَ : کَانَ مَعِی ہَدْیٌ صَدَقَۃٌ لِلْمَسَاکِینِ ، فَأَمَرَنِی أَنْ آکُلَ مِنْہُ وَأَدَّخِرَ۔",,,13359,,
13360,"حدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا لاَ یَأْکُلُونَ مِنْ شَیْئٍ جَعَلُوہُ لِلَّہِ ، ثُمَّ رُخِّصَ لَہُمْ أَنْ یَأْکُلُوا مِنَ الْہَدْیِ وَالأَضَاحِیِّ وَأَشْبَاہِہِ۔",,,13360,,
13361,"حدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوسٍ ، وَمُجَاہِدٍ ؛ أَنَّہُمْ قَالُوا : لاَ یُؤْکَلُ مِنَ الْفِدْیَۃِ ، وَلاَ مِنْ جَزَائِ الصَّیْدِ۔",,,13361,,
13362,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ یَقُولُ : إذَا عَطِبَتِ الْبَدَنَۃُ ، أَوْ کُسِرَتْ أَکَلَ مِنْہَا صَاحِبُہَا وَأَطْعَمَ ، وَلَمْ یُبَدِّلْہَا ، إِلاَّ أَنْ تَکُونَ نَذْرًا ، أَوْ جَزَائَ صَیْدٍ۔",,,13362,,
13363,"حدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : مَا کَانَ مِنْ جَزَائِ صَیْدٍ ، أَوْ نُسُکٍ ، أَوْ نَذْرٍ لِلْمَسَاکِینِ ، فَإِنَّہُ لاَ یَأْکُلُ مِنْہُ۔",,,13363,,
13364,"حدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ یَأْکُلُ مِنْ جَزَائِ الصَّیْدِ۔",,,13364,,
13365,"حدَّثَنَا شَرِیکٌ ، عَنْ سَالِمٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : لاَ یُؤْکَلُ مِنَ النَّذْرِ ، وَلاَ مِنَ الْکَفَّارَۃِ ، وَلاَ مِمَّا جُعِلَ لِلْمَسَاکِینِ۔",,,13365,,
13366,"حدَّثَنَا شَرِیکٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، قَالَ : قَالَ عَلِیٌّ : لاَ یُؤْکَلُ مِنَ النَّذْرِ ، وَلاَ مِنْ جَزَائِ الصَّیْدِ ، وَلاَ مِمَّا جُعِلَ لِلْمَسَاکِینِ۔",,,13366,,
13367,"حدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ قَیْسِ بْنِ سَعْدٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ یَأْکُلُ مِنْ جَزَائِ الصَّیْدِ۔",,,13367,,
13368,حدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ قَتَادَۃَ ، عَنْ أَبِی حَسَّانَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَشْعَرَ الْہَدْیَ فِی السَّنَامِ الأَیْمَنِ ، مَاطَ عَنْہُ الدَّمَ۔ (مسلم 205۔ ترمذی 906),,,13368,,
13369,حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عُرْوَۃَ ، عَنِ الْمِسْوَرِ بْنِ مَخْرَمَۃَ ، وَمَرْوَانَ بْنِ الْحَکَمِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَامَ الْحُدَیْبِیَۃِ قَلَّدَ الْہَدْیَ وَأَشْعَرَہُ۔ (بخاری 1694۔ احمد 4/323),,,13369,,
13370,"حدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُوسٍ ، وَمُجَاہِدٍ قَالُوا : لَیْسَ الإِشْعَارُ بِوَاجِبٍ۔",,,13370,,
13371,"حدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُوسٍ ، وَمُجَاہِدٍ قَالُوا : أَشْعِرِ الْہَدْیَ إِنْ شِئْتَ ، وَإِنْ شِئْتَ فَلاَ تُشْعِرہُ۔",,,13371,,
13372,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَد ، عَنْ عائِشَۃَ ؛ أَنَّہُ أَرْسَلَ إلَیْہَا أَیُشْعَرُ ، یَعْنِی الْبَدَنَۃَ ؟ فَقَالَتْ : إِنْ شِئْتَ ، إنَّمَا تُشْعَرُ لِیُعْلَمَ أَنَّہَا بَدَنَۃٌ۔",,,13372,,
13373,"حدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : لاَ ہَدْیَ إِلاَّ مَا قُلِّدَ وَأُشْعِرَ وَوَقَفَ بِہِ بِعَرَفَۃَ۔",,,13373,,
13374,"حدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، وَعَبْدِ الرَّحْمَنِ بْنِ الأَسْوَد أَنَّہُمَا قَالاَ : یُجَلِّلُ ، ثُمَّ یُشْعِرُ۔",,,13374,,
13375,"حدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنْ أَفْلَحَ ، عَنِ الْقَاسِمِ ، عَنْ عَائِشَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَشْعَرَ۔\n\n(بخاری 1696۔ مسلم 957)",,,13375,,
13376,"حدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی بِشْرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : الإِبِلُ تُقَلَّدُ وَتُشْعَرُ ، وَالْبَقَرُ تُقَلَّدُ وَلاَ تُشْعَرُ ، وَالْغَنَمُ لاَ تُقَلَّدُ وَلاَ تُشْعَرُ۔",,,13376,,
13377,"حدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ قَیْسِ بْنِ سَعْدٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إِنْ شِئْتَ فَأَشْعِرِ الْہَدْیَ ، وَإِنْ شِئْتَ فَلاَ تُشْعِرْ ۔",,,13377,,
13378,حدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی بِشْرٍ ، عَنْ عَطَائٍ (ح) وَیُوسُفَ بْنِ مَاہَکٍ ، وَمَنْصُورٍ ، عَنْ عَطَائٍ ؛ أَنَّ رَجُلاً أَغْلَقَ بَابَہُ عَلَی حَمَامَۃٍ وَفَرْخَیْہَا ، ثُمَّ انْطَلَقَ إلَی عَرَفَاتٍ وَمِنًی ، فَرَجَعَ وَقَدْ مُوِّتَتْ ، فَأَتَی ابْنَ عُمَرَ فَذَکَرَ ذَلِکَ لَہُ ، فَجَعَلَ عَلَیْہِ ثَلاَثًا مِنَ الْغَنَمِ ، وَحَکَمَ مَعَہُ رَجُلٌ۔,,,13378,,
13379,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، قَالَ : نَزَلْنَا مَنْزِلاً ، فَأَغْلَقْنَا بَابَ الْمَنْزِلِ عَلَی حَمَامَۃٍ فَمَاتَتْ ، فَسَأَلْنَا عَطَائً ؟ فَقَالَ : فِیہَا شَاۃٌ۔",,,13379,,
13380,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : عَلَیْہِ شَاۃٌ۔",,,13380,,
13381,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ أَشْعَثَ ، عَنْ عَطَائٍ ، قَالَ : مَنْ قَتَلَ حَمَامَۃً مِنْ حَمَامِ مَکَّۃَ فَعَلَیْہِ شَاۃٌ۔",,,13381,,
13382,"حدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : عَلَیْہِ شَاۃٌ۔",,,13382,,
13383,"حدَّثَنَا وَکِیعٌ ، عَنْ سَلَمَۃَ بْنِ مُحْرِزٍ ، قَالَ : أَغْلَقْتُ بَابِی بِمَکَّۃَ ثُمَّ فَتَحْتُہُ ، فَإِذَا طَیْرَانِ قَدْ مَاتَا ، فَسَأَلْتُ طَاوُوسًا ؟ فَقَالَ : اذْبَحْ شَاتَیْنِ۔",,,13383,,
13384,"حدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ فِی طَیْرِ الْحَرَمِ : شَاۃٌ شَاۃٌ۔",,,13384,,
13385,"حدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطَائٍ ؛ فِی الدّبْسِیِّ وَالْقُمْرِیِّ وَالأَخْضَرِ : شَاۃٌ شَاۃٌ۔",,,13385,,
13386,حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ شَیْخٍ مِنْ أَہْلِ مَکَّۃَ ؛ أَنَّ حَمَامًا کَانَ عَلَی الْبَیْتِ ، فَخَرَّ عَلَی یَدِ عُمَرَ ، فَأَشَارَ بِیَدِہِ ، فَطَارَ فَوَقَعَ عَلَی بَعْضِ بُیُوتِ أَہْلِ مَکَّۃَ ، فَجَائَتْ حَیَّۃٌ فَأَکَلَتْہُ ، فَحَکَمَ عُمَرُ عَلَی نَفْسِہِ شَاۃً۔,,,13386,,
13387,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ الْقَطَّانُ ، عَنْ مُحَمَّدِ بْنِ أَبِی یَحْیَی ، عَنْ صَالِحِ بْنِ الْمَہْدِیِّ ، أَنَّ أَبَاہُ أَخْبَرَہُ ، قَالَ : حجَجْتُ مَعَ عُثْمَانَ فَقَدِمْنَا بِمَکَّۃَ ، فَفَرَشْتُ لَہُ فِی بَیْتٍ فَرَقَدَ ، فَجَائَتْ حَمَامَۃٌ فَوَقَعَتْ فِی کُوَّۃٍ عَلَی فِرَاشِہِ ، فَجَعَلَتْ تَبْحَثُ بِرِجْلَیْہَا ، فَخَشِیتُ أَنْ تَنْثُرَ عَلَی فِرَاشِہِ فَیَسْتَیْقِظَ ، فَأَطَرْتُہَا فَوَقَعَتْ فِی کُوَّۃٍ أُخْرَی ، فَخَرَجَتْ حَیَّۃٌ فَقَتَلَتْہَا ، فَلَمَّا اسْتَیْقَظَ عُثْمَانُ أَخْبَرْتُہُ ، فَقَالَ : أَدِّ عَنْکَ شَاۃً ، فَقُلْتُ : إنَّمَا أَطَرْتُہَا مِنْ أَجْلِکَ ، قَالَ : وَعَنِّی شَاۃً۔",,,13387,,
13388,"حدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَطَائٍ ، قَالَ : أَوَّلُ مَنْ فَدَی طَیْرَ الْحَرَمِ بِشَاۃٍ عُثْمَانُ۔",,,13388,,
13389,حدَّثَنَا عَبْدَۃُ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّہُ کَانَ یَقُولُ فِی حَمَامِ الْحَرَمِ إذَا قُتِلَ بِمَکَّۃَ ، فَفِیہِ شَاۃٌ۔,,,13389,,
13390,"حدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، وَحَمَّادٍ قَالاَ : سَأَلْنَا إِبْرَاہِیمَ عَن رَجُلٍ أَخَذَ بِیَدِہِ فَرْخًا ، وَہُوَ مُحْرِمٌ ، فَأَرَادَ أَنْ یَرُدَّہُ فَمَاتَ ؟ فَقَالَ : ہُوَ ضَامِنٌ۔",,,13390,,
13391,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ خُصَیْفٍ ، عَنْ مِقْسَمٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : (لاَ رَفَثَ) الْجِمَاعُ (وَلاَ فُسُوقَ) الْمَعَاصِی (وَلاَ جِدَالَ فِی الْحَجِّ) قَالَ : تُمَارِی صَاحِبَک حَتَّی تُغْضِبَہُ۔",,,13391,,
13392,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ؛ {وَلاَ جِدَالَ فِی الْحَجِّ} قَالَ : قدْ صَارَ الْحَجُّ فِی ذِی الْحِجَّۃِ لاَ شَہْرَ یُنْسَأُ ، وَلاَ شَکَّ فِی الْحَجِّ ، لأَنَّ أَہْلَ الْجَاہِلِیَّۃِ کَانُوا یُحِطُّونَ فَیَحُجُّونَ فِی غَیْرِ ذِی الْحِجَّۃِ۔",,,13392,,
13393,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ جَابِرِ بْنِ زَیْدٍ ، قَالَ : {لاَ جِدَالَ فِی الْحَجِّ} قَالَ : لَیْسَ لَکَ أَنْ تُمَارِیَ صَاحِبَک حَتَّی تُغْضِبَہُ۔",,,13393,,
13394,"حدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : الرَّفَثُ إتْیَانُ النِّسَائِ ، وَالْفُسُوقُ السِّبَابُ ، وَالْجِدَالُ الْمُمَارَاۃُ أَنْ تُمَارِیَ صَاحِبَک۔",,,13394,,
13395,"حدَّثَنَا وَکِیعٌ ، عَنْ حُسَیْنِ بْنِ عُقَیْلٍ ، عَنِ الضَّحَّاکِ ، قَالَ : الرَّفَثُ الْجِمَاعُ ، وَالْفُسُوقُ الْمَعَاصِی ، وَالْجِدَالُ أَنْ تُجَادِلَ صَاحِبَک حَتَّی تُغْضِبَہُ",,,13395,,
13396,"حدَّثَنَا وَکِیعٌ ، عَنْ نَضْرٍ ، عَنْ عِکْرِمَۃَ ، قَالَ: الرَّفَثُ الْجِمَاعُ، وَالْفُسُوقُ الْمَعَاصِی، وَالْجِدَالُ الْمِرَائُ۔",,,13396,,
13397,"حدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ عَاصِمٍ، عَنْ بَکْرٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: الرَّفَثُ الْجِمَاعُ، وَلَکِنَّ اللَّہَ کَنَّی۔",,,13397,,
13398,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : الرَّفَثُ الْغِشْیَانُ ، وَالْفُسُوقُ السِّبَابُ ، وَالْجِدَالُ الاخْتِلاَفُ فِی الْحَجِّ۔",,,13398,,
13399,"حدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَنْ وُہَیبٍ ، عَنْ مُوسَی بْنِ عُقْبَۃَ ؛ أنَّہُ سَأَلَ عَطَائَ بْنَ یَسَارٍ عَنْ قَوْلِہِ : (فَلاَ رَفَثَ وَلاَ فُسُوقَ وَلاَ جِدَالَ فِی الْحَجِّ) ؟ قَالَ : الرَّفَثُ وِقَاعُ النِّسَائِ ، وَالْفُسُوقُ الْمَعَاصِی ، وَالْجِدَالُ السِّبَابُ۔",,,13399,,
13400,"حدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : الرَّفَثُ : الجماع ، وَالْفُسُوقُ الْمَعَاصِی ، وَالْجِدَالُ أَنْ تُجَادِلَ صَاحِبَک حَتَّی تُغْضِبَہُ وَیُغْضِبَک۔",,,13400,,
13401,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ رُفَیْعٍ ، عَنْ مُجَاہِدٍ : (وَلاَ جِدَالَ فِی الْحَجِّ) قَالَ : قَدِ اسْتَقَامَ أَمْرُ الْحَجِّ۔",,,13401,,
13402,"حدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ أَبِی خَالِدٍ الْوَالِبِیِّ ، عَنِ النُّعْمَانِ بْنِ عَمْرِو بْنِ مُقَرِّنٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : سِبَابُ الْمُؤْمِنِ فُسُوقٌ ، وَقِتَالُہُ کُفْرٌ۔ (طبرانی 80)",,,13402,,
13403,حدَّثَنَا عَبیدَۃُ بْنِ حُمَیْدٍ ، عَنْ مَنْصُورٍ ، عَنْ أَبِی خَالِدٍ الْوَالِبِیِّ ، عَنْ النُّعْمَانِ بْنِ عَمْرِو بْنِ مُقَرِّنٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، بِنَحْوِہِ۔,,,13403,,
13404,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ شَرِیکٍ ، عَنْ إبْرَاہِیمَ بْنِ مُہَاجِرٍ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : الرَّفَثُ الْجِمَاعُ ، وَالْفُسُوقُ السِّبَابُ ، وَالْجِدَالُ الْمِرَائُ أَنْ تُمَارِیَ صَاحِبَک حَتَّی تُغْضِبَہُ۔",,,13404,,
13405,"حدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ رُفَیْعٍ ، عَنْ مُجَاہِدٍ ، قَالَ : الرَّفَثُ الْجِمَاعُ ، وَالْفُسُوقُ الْمَعَاصِی ، وَالْجِدَالُ الْمِرَائُ۔",,,13405,,
13406,"حدَّثَنَا شَبَابَۃُ ، عَنْ وَرْقَائَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ؛ (فَلاَ رَفَثَ) قَالَ : جِمَاعُ النِّسَائِ۔",,,13406,,
13407,"حدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ أَبِیہِ ، قَالَ : حدَّثَنَا أَبُو عَمْرٍو الشَّیْبَانِیُّ ، قَالَ : سَمِعْتُ عَبْدَ اللہِ بْنَ مَسْعُودٍ یَقُولُ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: سِبَابُ الْمُؤْمِنِ فُسُوقٌ، وَقِتَالُہُ کُفْرٌ۔ (ابویعلی 4970)",,,13407,,
13408,حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مَنْصُورٍ ، عَنْ أَبِی وَائِلٍ ، عَنْ عَبْدِ اللہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، بِنَحْوِ حَدِیثِ مُعْتَمِرٍ۔ (بخاری 48۔ مسلم 116),,,13408,,
13409,"حدَّثَنَا مُحَمَّدُ بْنُ الْحَسَنِ الأَسَدِیُّ ، قَالَ : حدَّثَنَا أَبُو ہِلاَلٍ ، عَنِ ابْنِ سِیرِینَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : سِبَابُ الْمُؤْمِنِ فُسُوقٌ ، وَقِتَالُہُ کُفْرٌ۔ (نسائی 3567۔ احمد 1/178)",,,13409,,
13410,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ عَبْدِ اللہِ بْنِ بَابَاہُ ، عَنْ جُبَیْرِ بْنِ مُطْعِمٍ ، أنَّ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : یَا بَنِی عَبْدِ مَنَافٍ لاَ تَمْنَعُوا أَحَدًا طَافَ بِہَذَا الْبَیْتِ وَصَلَّی ، أَیَّ سَاعَۃٍ مِنْ لَیْلٍ ، أَوْ نَہَارٍ۔ (ترمذی 686۔ ابوداؤد 1889)",,,13410,,
13411,"حدَّثَنَا أَبُو الأَحْوَصِِ، عَنْ لَیْثٍ، عَنْ عَطَائٍ، قَالَ: رَأَیْتُ ابْنَ عُمَرَ، وَابْنَ عَبَّاسٍ طَافَا بَعْدَ الْعَصْرِ وَصَلَّیَا۔",,,13411,,
13412,"حدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَطَائٍ ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ طَافَ بِالْبَیْتِ بَعْدَ الْفَجْرِ ، وَصَلَّی الرَّکْعَتَیْنِ قَبْلَ طُلُوعِ الشَّمْسِ۔",,,13412,,
13413,حدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ أبی شُعْبَۃَ ؛ أَنَّہُ رَأَی الْحَسَنَ ، وَالْحُسَیْنَ قَدِمَا مَکَّۃَ ، فَطَافَا بِالْبَیْتِ بَعْدَ الْعَصْرِ وَصَلَّیَا۔,,,13413,,
13414,حدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ التَّیْمِیُّ ، عَنْ لَیْثٍ ؛ أَنَّ الْحَسَنَ ، وَعَطَائً ، وَمُجَاہِدًا کَانُوا یَطُوفُونَ بِالْبَیْتِ بَعْدَ الْعَصْرِ ، وَیُصَلُّونَ فِی دُبُرِ طَوَافِہِمْ۔,,,13414,,
13415,"حدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ سُلَیْمِ بْنِ حَیَّانَ ، قَالَ : سَأَلْتُ عِکْرِمَۃَ بْنَ خَالِدٍ عَنْہُ ؟ فَقَالَ : لاَ بَأْسَ۔",,,13415,,
13416,حدَّثَنَا أَبُو دَاوُدَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ؛ أَنَّہُ لَمْ یَرَ بَأْسًا بِالطَّوَافِ بَعْدَ الْفَجْرِ وَبَعْدَ الْعَصْرِ وَالصَّلاَۃِ۔,,,13416,,
13417,حدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنِ الْوَلِیدِ بْنِ جُمَیْعٍ ، عَنْ أَبِی الطُّفَیْلِ ؛ أَنَّہُ کَانَ یَطُوفُ بِالْبَیْتِ بَعْدَ الْعَصْرِ ، وَیُصَلِّی حَتَّی تَصْفَرُّ الشَّمْسُ۔,,,13417,,
13418,"حدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنِ الأَجْلَحِ ، عَنْ عَطَائٍ ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ ، وَابْنَ الزُّبَیْرِ طَافَا بِالْبَیْتِ بَعْدَ صَلاَۃِ الْفَجْرِ ، ثُمَّ صَلَّیَا رَکْعَتَیْنِ قَبْلَ طُلُوعِ الشَّمْسِ۔",,,13418,,
13419,"حدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ مَیْسَرَۃَ ، عَنْ طَاوُوسٍ ، قَالَ : طُفْ وَصَلِّ بَعْدَ الْعَصْرِ وَبَعْدَ الْفَجْرِ مَا کُنْتَ فِی وَقْتٍ۔",,,13419,,
13420,"حدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ عَبْدِ اللہِ بْنِ مُسْلِمٍ ، عَنْ عَمْرِو بْنِ عَبْدِ اللہِ بْنِ عُرْوَۃَ بْنِ الزُّبَیْرِ ؛ أَنَّ ثَابِتَ بْنَ عَبْدِ اللہِ بْنِ الزُّبَیْرِ طَافَ بِالْبَیْتِ سَبْعًا بَعْدَ صَلاَۃِ الصُّبْحِ ، فَجَلَسَ وَلَمْ یُصَلِّ ، فَجَائَہُ أَبُوہُ عَبْدُ اللہِ بْنُ الزُّبَیْرِ ، فَقَالَ : یَا بُنَیَّ ، إِذَا کُنْتَ طَائِفًا فَصَلِّ ، وَإِنْ لَمْ تُصَلِّ فَلاَ تَطُفْ۔",,,13420,,
13421,"حدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ إبْرَاہِیمَ بْنِ طَہْمَانَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ عَبْدِ اللہِ بْنِ بَابَاہُ ، قَالَ : رَأَیْتُ أَبَا الدَّرْدَائِ طَافَ بَعْدَ الْعَصْرِ وَصَلَّی رَکْعَتَیْنِ ، فَقِیلَ لَہُ ؟ فَقَالَ : إِنَّہَا لَیْسَتْ کَسَائِرِہَا مِنَ الْبُلْدَانِ۔",,,13421,,
13422,"حدَّثَنَا عَبْدُ الأَعْلَی بْنُ عَبْدِ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنْ عَطَائٍ ، قَالَ : کَانَ الْمِسْوَرُ بْنُ مَخْرَمَۃَ یَطُوفُ بَعْدَ الْغَدَاۃِ ثَلاَثَۃَ أَسَابِیعَ ، فَإِذَا طَلَعَتِ الشَّمْسُ صَلَّی لِکُلِّ سُبُوعٍ رَکْعَتَیْنِ ، وَبَعْدَ الْعَصْرِ یَفْعَلُ ذَلِکَ ، فَإِذَا غَابَتِ الشَّمْسُ صَلَّی لِکُلِّ سُبُوعٍ رَکْعَتَیْنِ۔",,,13422,,
13423,"حدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، قَالَ : رَأَیْتُ سَعِیدَ بْنَ جُبَیْرٍ ، وَمُجَاہِدًا یَطُوفَانِ بِالْبَیْتِ حَتَّی تَصْفَارَّ الشَّمْسُ ، وَیَجْلِسَانِ۔",,,13423,,
13424,"حدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، عَنْ عَائِشَۃَ ، أَنَّہَا قَالَتْ : إذَا أَرَدْتَ الطَّوَافَ بِالْبَیْتِ بَعْدَ صَلاَۃِ الْفَجْرِ ، أَوْ بَعْدَ صَلاَۃِ الْعَصْرِ فَطُفْ وَأَخِّرِ الصَّلاَۃَ حَتَّی تَغِیبَ الشَّمْسُ أَوْ حَتَّی تَطْلُعَ ، فَصَلِّ لِکُلِّ أُسْبُوعٍ رَکْعَتَیْنِ۔",,,13424,,
13425,حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ سَعدِ بْنِ إِبْرَاہِیمَ ، عَن نَصْرِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ جَدِّہِ مُعَاذٍ الْقُرَشِیِّ ؛ أَنَّہُ طَافَ بِالْبَیْتِ مَعَ مُعَاذِ بْنِ عَفْرَائَ بَعْدَ الْفَجْرِ وَبَعْدَ الْعَصْرِ فَلَمْ یُصَلِّ۔,,,13425,,
13426,"حدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطَائٍ ، قَالَ : طَافَ عُمَرُ بْنُ الْخَطَّابِ بَعْدَ الْفَجْرِ ، ثُمَّ رَکِبَ حَتَّی إذَا أَتَی ذَاتَ طُوَی نَزَلَ ، فَلَمَّا طَلَعَتِ الشَّمْسُ وَارْتَفَعَتْ صَلَّی رَکْعَتَیْنِ ، ثُمَّ قَالَ : رَکْعَتَان مَکَانَ رَکْعَتَیْنِ۔",,,13426,,
13427,"حدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ أَبِیہِ ، قَالَ : صَلَّیْنَا الصُّبْحَ ثُمَّ جَلَسْنَا نَنْتَظِرُ بِالطَّوَافِ ، قَالَ : فَطَافَ أَبُو سَعِیدٍ الْخُدْرِیِّ ، ثُمَّ جَلَسَ وَلَمْ یُصَلِّ۔",,,13427,,
13428,"حدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : رُبَّمَا أَخَذْتُ النَّمْلَۃَ بِعَرَفَۃَ قَدْ عَضَّتْ بَطْنِی ، فَأَقْطَعُ رَأْسَہَا وَیَبْقَی سَائِرُہَا فِی بَطْنِی۔",,,13428,,
13429,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ الْعَلاَئِ بْنِ الْمُسَیَّبِ ، عَنِ الْوَلِیدِ الْبَجَلِیِّ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ فِی مُحْرِمٍ أَصَابَ ذَرًّا کَثِیرًا ، قَالَ : یَتَصَدَّقُ۔",,,13429,,
13430,"حدَّثَنَا حَفْصٌ ، عَنْ عَبْدِ الْمَلِکِ ، قَالَ : سُئِلَ عَطَائٌ عَنْ رَجُلٍ قَتَلَ ذَرًّا کَثِیرًا ، لاَ یَدْرِی مَا یُحَدِّدُہُ ، قَالَ: یَتَصَدَّقُ بِتَمْرٍ کَثِیرٍ۔",,,13430,,
13431,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : سَمِعْتُ طَاوُوسًا وَسَأَلَہُ رَجُلٌ ، قَالَ : أَہْلَلْتُ فَقَتَلْتُ ذَرًّا کَثِیرًا ؟ قَالَ : تَصَدَّقْ بِقَبَضَاتٍ مِنْ قَمْحٍ۔",,,13431,,
13432,"حدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطَائٍ ؛ فِی النَّمْلِ یَقْتُلُہُ الْمُحْرِمُ ؟ قَالَ : یُطْعِمُ شَیْئًا۔",,,13432,,
13433,"حدَّثَنَا وَکِیعٌ ، عَنْ إبْرَاہِیمَ بْنِ نَافِعٍ ، قَالَ : سَأَلْتُ طَاوُوسًا عَنْ قَتْلِ الذَّرِّ فِی الْحَرَمِ ؟ فَقَالَ : إذَا آذَاکَ فَلاَ بَأْسَ بِہِ۔",,,13433,,
13434,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، قَالَ : سَأَلْتُ الْقَاسِمَ ، وَمُجَاہِدًا ، وَسَالِمًا ، وَعَطَائً ، وَطَاوُوسًا عَنِ النَّمْلِ وَالْجَنَادِبِ وَالْعِظَائِ ؟ فَقَالُوا : إِنْ کَانَ خَطَأً فَلَیْسَ عَلَیْہِ شَیْئٌ ، وَإِنْ کَانَ عَمْدًا فَفِیہِ کَفٌّ مِنْ طَعَامٍ ، وَقَالَ عَامِرٌ : ہُوَ کَفٌّ مِنْ طَعَامٍ خَطَأً کَانَ ، أَمْ عَمْدًا۔",,,13434,,
13435,"حدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنِ الْحَسَنِ بْنِ عَمْرٍو ، عَنْ أَبِی أُمَامَۃَ ، قَالَ : سَأَلْتُ ابْنَ عُمَرَ ، قَالَ : قُلْتُ: أَقْتُلُ الْبَعُوضَ ؟ قَالَ : وَمَا عَلَیْک ؟۔",,,13435,,
13436,"حدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ عُبَیْدِ اللہِ بْنِ أَبِی زِیَادٍ ، قَالَ : رَأَیْتُ سَالِمًا قَتَلَ بَعُوضَۃً بِمَکَّۃَ ، فَقُلْتُ لَہُ؟ فَقَالَ : إِنَّہُ قَدْ أُمِرَ بِقَتْلِ الْحَیَّۃِ وَالْعَقْرَبِ ، قُلْتُ : إِنَّہُمَا عَدُوٌّ ، قَالَ : فَہَذِہِ عَدُوٌّ۔",,,13436,,
13437,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ بَأْسَ أَنْ یَقْتُلَ الذُّبَابَ وَالْبَعُوضَ۔",,,13437,,
13438,"حدَّثَنَا جَرِیرٌ ، عَنْ مَرْزُوقٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ فِی مُحْرِمٍ قَتَلَ ذُبَابًا ، قَالَ : لَیْسَ عَلَیْہِ شَیْئٌ۔",,,13438,,
13439,حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ أَیُّوبَ بْنِ مُوسَی ، عَنْ نُبَیْہ بْنِ وَہْبٍ ، عَنْ أَبَانَ بْنِ عُثْمَانَ ، أَنَّہُ أَخْبَرَہُ ؛ أَنَّ عُثْمَانَ حَدَّثَ ، عَنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ فِی الرَّجُلِ إذَا اشْتَکَی عَیْنُہُ وَہُوَ مُحْرِمٌ ، ضَمَّدَہُمَا بِالصَّبِرِ۔ (ترمذی 952۔ ابوداؤد 1834),,,13439,,
13440,حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ أَیُّوبَ بْنِ مُوسَی ، عَنْ نَافِعٍ ، عَنِ ابن عُمَرَ ، أَنَّہُ فَعَلَہُ۔,,,13440,,
13441,حدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، وَوَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ إذَا اشْتَکَی عَیْنُہُ وَہُوَ مُحْرِمٌ ، أَقْطَرَ فِیہَا الصَّبِرَ إقْطَارًا۔,,,13441,,
13442,"حدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ (ح) وَعَبْدُ الرَّحْمَن بْنُ مَہْدِیٍّ ، عَنْ شُعْبَۃَ ، کِلاَہُمَا عَنْ جَابِرٍ ، عَنْ عَامِرٍ، عَنْ عَلْقَمَۃَ ، قَالَ : لاَ بَأْسَ أَنْ یَکْتَحِلَ الْمُحْرِمُ بِالصَّبِرِ۔",,,13442,,
13443,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنْ شُمَیْسَۃَ الأَزْدِیَّۃِ ، قَالَتْ : دَخَلْتُ عَلَی عَائِشَۃَ وَأَنَا مُحْرِمَۃٌ ، وَأَنَا أَشْتَکِی عَیْنِی ، فَقَالَتْ : ہَلُمِّی أُکَحِّلْکِ وَمَعَہَا مَحَارَۃٌ فِیہَا صَبِرٌ ، فَأَبَیْتُ عَلَیْہَا ، فَنَدِمْتُ بَعْدُ ، أَنْ لاَ أَکُونَ تَرَکْتُہَا۔",,,13443,,
13444,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ ہِلاَلِ بْنِ مَیْمُونٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : لاَ بَأْسَ بِہِ۔",,,13444,,
13445,"حدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ الْغَازِ ، عَنْ عَطَائٍ ، قَالَ : إذَا اشْتَکَی الْمُحْرِمُ عَیْنَیْہِ فَلْیُکَحِّلْہُمَا بِالصَّبِرِ وَالْحُضَضِ ، وَلاَ یَکْتَحِلْ بِکُحْلٍ فِیہِ طِیبٌ۔",,,13445,,
13446,"حدَّثَنَا غَسَّانُ بْنُ مُضَرَ ، عَنْ سَعِیدِ بْنِ زَیدٍ ، قَالَ : جَائَ رَجُلٌ إلَی الْحَسَنِ ، فَقَالَ : یَا أَبَا سَعِیدٍ ، بِمَ یَکْتَحِلُ الْمُحْرِمُ ؟ وَجَابِرُ بْنُ زَیْدٍ إلَی جَنْبِہِ ، قَالَ : فَسَکَتَ الْحَسَنُ ، وَقَالَ جَابِرٌ : یَکْتَحِلُ بِالْعَسَلِ ، فَلَمْ یُنْکِرْ ذَلِکَ الْحَسَنُ۔",,,13446,,
13447,"حدَّثَنَا مُحَمَّدُ بْنُ یَزِیدَ، عَنْ أَبِی الْعَلاَئِ، عَنْ قَتَادَۃَ، وَأَبِی ہَاشِمٍ قَالاَ: یَکْتَحِلُ بِالصَّبِرِ وَالْحُضَضِ والْمُرِّ۔",,,13447,,
13448,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ؛ أَنَّہُ کَانَ یَکْرَہُ الْکُحْلَ الأَسْوَد لِلْمُحْرِمِ ، قَالَ : فَذَکَرْتُ ذَلِکَ لإِبْرَاہِیمَ ، فَقَالَ : یَکْتَحِلُ بِالذَّرُورِ الأَحْمَر۔",,,13448,,
13449,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَمَّارٍ ، قَالَ : رَأَی سَعِیدُ بْنُ جُبَیْرٍ مُحْرِمًا ، قَدْ عَصَّبَ رَأْسَہُ بِسَیْرٍ فَقَطَعَہُ۔",,,13449,,
13450,"حدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِیہِ ، عَنْ أَبِی الزُّبَیْرِ ، عَنِ ابْنِ عُمَرَ ، قَالَ : لاَ یَعْصِّبُ الْمُحْرِمُ رَأْسَہُ بِسَیْرٍ ، وَلاَ خِرْقَۃٍ۔",,,13450,,
13451,"حدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ أَنَّہُ سُئِلَ عَنِ الْمُحْرِمِ یُصَدَّعُ ، قَالَ : یَعْصِبُ رَأْسَہُ إِنْ شَائَ۔",,,13451,,
13452,"حدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَسَارٍ ، قَالَ : رَأَیْتُ ابْنَ عَبَّاسٍ زَمَانَ نَجْدِہِ ، قَدْ شَدَّ شَعْرَہُ بِشِرَاکٍ ، وَہُوَ مُحْرِمٌ۔",,,13452,,
13453,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ یَعْقُوبَ بْنِ خَالِدٍ ، قَالَ : حدَّثَنِی أَبُو أَسْمَائَ مَوْلَی عَبْدِ اللہِ بْنِ جَعْفَرٍ ، قَالَ : خَرَجَ الْحُسَیْنُ بْنُ عَلِیٍّ حَاجًّا فَاشْتَکَی بِبَعْضِ الطَّرِیقِ ، فَأَشَارَ إلَی رَأْسِہِ ، فَقَالُوا لِعَلِیٍّ : إنَّ الْحُسَیْنَ یُشِیرُ إلَی رَأْسِہِ ، فَأَمَرَ بِجَزُورٍ یَتَصَدَّقُ بِہَا عَلَی أَہْلِ الْمَائِ ، وَحَلَقَہُ۔",,,13453,,
13454,"حدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، قَالَ : اجْعَلِ الْفِدْیَۃَ حَیْثُ شِئْتَ۔",,,13454,,
13455,"حدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ : مَا کَانَ دَمٌ ، أَوْ صَدَقَۃٌ ، أَوْ جَزَائُ صَیْدٍ فَبِمَکَّۃَ ، وَالصَّوْمُ حَیْثُ شِئْتَ۔",,,13455,,
13456,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : مَا کَانَ مِنْ دَمٍ فَبِمَکَّۃَ ، وَمَا کَانَ مِنْ صِیَامٍ ، أَوْ صَدَقَۃٍ فَحَیْثُ شِئْتَ۔",,,13456,,
13457,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَعَطَائٍ قَالاَ: کُلُّ دَمٍ وَاجِبٍ فَلَیْسَ لَہُ أَنْ یَذْبَحَہُ إِلاَّ بِمَکَّۃَ۔",,,13457,,
13458,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، وَحَمَّادٍ ، عَنْ إبْرَاہِیمَ (ح) وَعَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : مَا کَانَ مِنْ جَزَائٍ فَبِمَکَّۃَ ، وَالصَّدَقَۃُ وَالصِّیَامُ حَیْثُ شِئْتَ۔",,,13458,,
13459,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ عَبْدِ الْمَلِکِ ، وَأَشْعَثَ ، عَنْ عَطَائٍ ، قَالَ : الدَّمُ بِمَکَّۃَ۔",,,13459,,
13460,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، قَالَ : إِذَا اسْتَکْرَہَ الْمُحْرِمُ امْرَأَتَہُ وَہِیَ مُحْرِمَۃٌ فَعَلَیْہِ بَدَنَتَانِ ؛ بَدَنَۃٌ عَنْہُ وَبَدَنَۃٌ عَنْہَا ، وَإِنْ طَاوَعَتْہُ فَعَلَی کُلِّ وَاحِدٍ مِنْہُمَا بَدَنَۃٌ وَالْحَجُّ مِنْ قَابِلٍ۔",,,13460,,
13461,"حدَّثَنَا عَبْدُالأَعْلَی، عَنْ ہِشَامٍ، عَنِ الْحَسَنِ، وَعَطَائٍ قَالاَ فِی الْمُحْرِمِ: إِذَا اسْتَکْرَہَ امْرَأَتَہُ فَعَلَیْہِ کَفَّارَتُہَا، فَإِنْ طَاوَعَتْہُ فَعَلَی کُلِّ وَاحِدٍ مِنْہُمَا کَفَّارَۃٌ۔",,,13461,,
13462,"حدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ؛ فِی الْمُحْرِمَۃِ یَسْتَکْرِہُہَا زَوْجُہَا حَتَّی یُوَاقِعَ ، قَالَ : یُحِجُّہَا مِنْ مَالِہِ۔",,,13462,,
13463,"حدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ حُمَیْدٍ ، قَالَ : سَأَلْتُ السَّائِبَ : مَاذَا سَمِعْتَ فِی سُکْنَی مَکَّۃَ ؟ فَقَالَ : سَمِعْتُ الْعَلاَئَ بْنَ الْحَضْرَمِیِّ یَقُولُ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : ثَلاَثٌ لِلْمُہَاجِرِ بَعْدَ الصَّدَرِ۔ (مسلم 444۔ احمد 52)",,,13463,,
13464,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، قَالَ : سَمِعْتُ عَامِرًا یَقُولُ : مَا جَاوَرَ أَحَدٌ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَکَانَ عَامِرٌ یَقُولُ : مَا الْجِوَارُ ؟۔",,,13464,,
13465,"حدَّثَنَا أَبُو مُعَاوِیَۃَ، عَنِ الأَعْمَشِ، عَنْ أَبِی سُفْیَانَ، قَالَ: جَاوَرْتُ مَعَ جَابِرِ بْنِ عَبْدِاللہِ بِمَکَّۃَ سِتَّۃَ أَشْہُرٍ۔",,,13465,,
13466,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : جَاوَرَ عِنْدَنَا جَابِرُ بْنُ عَبْدِ اللہِ ، وَابْنُ عُمَرَ ، وَابْنُ عَبَّاسٍ ، وَأَبُو ہُرَیْرَۃَ ، وَأَبُو سَعِیدٍ الْخُدْرِیِّ۔",,,13466,,
13467,"حدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، عَنِ ابن الزُّبَیْرِ ، قَالَ : کَانَ یُقِیمُ بِمَکَّۃَ السَّنَتَیْنِ۔",,,13467,,
13468,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ، عَنْ عَبْدِالْمَلِکِ، قَالَ: جَاوَرْتُ بِمَکَّۃَ، وَثَمَّ عَلِیُّ بْنُ الْحُسَیْنِ، وَسَعِیدُ بْنُ ج",,,13468,,
13469,"حدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : أَتَیْتُ أَنَا ، وَعُبَیْدُ بْنُ عُمَیْرٍ اللَّیْثِیُّ عَائِشَۃَ وَہِیَ مُجَاوِرَۃٌ بِثَبِیرٍ ، قَالَ : وَکَانَ عَلَیْہَا نَذْرٌ أَنْ تُجَاوِرَ شَہْرًا ، قَالَ : وَکَانَ عَبْدُ الرَّحْمَنِ أَخُوہَا یَمْنَعُہَا مِنْ ذَلِکَ وَیَقُولُ : جِوَارُ الْبَیْتِ وَطَوَافٌ بِہِ أَحَبُّ إلَیَّ وَأَفْضَلُ ، قَالَ : فَلَمَّا مَاتَ عَبْدُ الرَّحْمَنِ خَرَجَتْ۔",,,13469,,
13470,"حدَّثَنَا وَکِیعٌ، عَنْ عُمَرَ بْنِ أَبِی مَعْرُوفٍ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ، قَالَ: قَالَ عُمَرُ: لاَ تُقِیمُوا بَعْدَ النَّفْرِ إلاَّ ثَلاَثًا۔",,,13470,,
13471,"حدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ إسْمَاعِیلَ ، قَالَ : کَانَ الشَّعْبِیُّ إذَا سُئِلَ عَنِ الْجُوَارِ جَائَ بِکِتَابِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إلَی خُزَاعَۃَ : إنِّی قَدْ أَخَذْتُ بِمَنْ ہَاجَرَ مِنْکُمْ کَمَا أَخَذْت لِنَفْسِی ، وَلَوْ کَانَ بِأَرْضِہِ غَیرَ سَاکِنِ مَکَّۃَ ، إِلاَّ حَاجًّا ، أَوْ مُعْتَمِرًا۔ (ابن سعد 272)",,,13471,,
13472,"حدَّثَنَا وَکِیعٌ ، عَنْ عِیسَی ، عَنِ الشَّعْبِیِّ ، عَنْ عَبْدِ اللہ قَالَ : مَکَّۃُ لَیْسَتْ بِدَارِ إقَامَۃٍ ، وَلاَ مُکْثٍ۔",,,13472,,
13473,"حدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ، عَنِ الأَجْلَحِ، عَنْ عَامِرٍ، قَالَ: لاَ یَصْلُحُ لِلْمُہَاجِرِ أَنْ یُجَاوِرَ فَوْقَ ثَلاَثَۃِ أَیَّامٍ بِمَکَّۃَ۔",,,13473,,
13474,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ خُصَیْفٍ ، قَالَ : أَخَذْتُ مِنْ شَارِبِ مُحَمَّدِ بْنِ مَرْوَانَ وَأَنَا مُحْرِمٌ ، فَسَأَلْتُ سَعِیدَ بْنَ جُبَیْرٍ ؟ فَأَمَرَنِی أَنْ أَتَصَدَّقَ بِدِرْہَمٍ۔",,,13474,,
13475,"حدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ فِی حَرَامٍ قَصَّ شَارِبَ حَلاَلٍ ؟ قَالَ : یَتَصَدَّقُ بِدِرْہَمٍ۔",,,13475,,
13476,"حدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، قَالَ : کَانَ الْحَسَنُ یَکْرَہُ أَنْ یَأْخُذَ الْمُحْرِمُ مِنْ رَأْسِ الْحَلاَلِ، یَعْنِی مِنْ شَعْرِہِ أَوْ یَقْلِمَہُ۔",,,13476,,
13477,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، قَالَ : أَخْبَرَنِی مَنْ رَأَی بَعْضَ أَصْحَابِنَا حَرَامًا یقصِّر عَنْ جَابِرِ بْنِ زَیْدٍ یُحَلِّلُہُ۔",,,13477,,
13478,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ عِکْرِمَۃَ ، قَالَ : الْمَرْأَۃُ الْمُحْرِمَۃُ تُمَشِّطُ الْمَرْأَۃَ الْحَلاَلَ ، إنَّمَا تَقْتُلُ قَمْلَ غَیْرِہَا۔",,,13478,,
13479,"حدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ إبْرَاہِیمَ بْنِ مُہَاجِرٍ ، عَنْ مُجَاہِدٍ ، عَنْ مَوْلاَہُ السَّائِبِ بْنِ عَبْدِ اللہِ ، قَالَتْ : کَانَ السَّائِبُ بْنُ عَبْدِ اللہِ یَأْمُرُنِی أَنْ أَشْرَبَ مِنْ سِقَایَۃِ آلِ عَبَّاسٍ ، وَیَقُولُ : إِنَّہُ مِنْ تَمَامِ الْحَجِّ۔",,,13479,,
13480,"حدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ قَالَ : اشْرَبْ مِنْ سِقَایَۃِ آلِ عَبَّاسٍ ، وَقَدْ شَرِبَ مِنْہَا الْمُسْلِمُونَ ، وَہُوَ سُنَّۃٌ۔",,,13480,,
13481,"حدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنْ مُجَاہِدٍ ، قَالَ : قَالَ لِی مَوْلَی بَنِی عَبْدِ اللہِ بْنِ السَّائِبِ : اشْرَبْ مِنْ سِقَایَۃِ آلِ عَبَّاسٍ ، وَقَدْ شَرِبَ مِنْہَا الْمُسْلِمُونَ۔",,,13481,,
13482,"حدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنِ الرَّبِیعِ بْنِ سَعْدٍ ، قَالَ : رَأَیْتُ أَبَا جَعْفَرٍ طَافَ بِالْبَیْتِ ، ثُمَّ أَتَی زَمْزَمَ ، فَأُتِیَ بِنَبِیذٍ مِنْ نَبِیذِ السِّقَایَۃِ فَشَرِبَ نِصْفًا ، وَأَعْطَی جَعْفَرًا نِصْفًا۔",,,13482,,
13483,"حدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ حُمَیْدٍ ، عَنْ بَکْرِ بْنِ عَبْدِ اللہِ الْمُزَنِیّ ، قَالَ : أَحَبَّ لِلرَّجُلِ أَنْ یَشْرَبَ مِنْ نَبِیذِ السِّقَایَۃِ۔",,,13483,,
13484,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُحَمَّدِ بْنِ أَبِی إسْمَاعِیلَ ، قَالَ : خَرَجَ سَعِیدُ بْنُ جُبَیْرٍ مِنْ مِنًی بِالْہَجِیرِ ، فَطَافَ أُسْبُوعًا بِالْبَیْتِ وَصَلَّی رَکْعَتَیْنِ ، ثُمَّ أَتَی السِّقَایَۃَ ، فَسَقَانَا مُحَمَّدُ بْنُ عَلِیٍّ نَبِیذًا ، فَشَرِبَ مِنْہُ سَعِیدُ بْنُ جُبَیْرٍ وَسَقَانِی۔",,,13484,,
13485,"حدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، عَنْ إبْرَاہِیمَ بْنِ عَبْدِ الأَعْلَی ، عَنْ سُوَیْد بْنِ غَفَلَۃَ ، قَالَ : اشْرَبْ مِنْ نَبِیذِ السِّقَایَۃِ۔",,,13485,,
13486,"حدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ صَالِحٍ ، عَنْ رَجُلٍ ، عَنْ مُجَاہِدٍ ، قَالَ : شَرِبْتُ مَعَہُ مِنْ نَبِیذِ السِّقَایَۃِ نَبِیذٍ صُدِّعْتُ مِنْہُ۔",,,13486,,
13487,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : لَمْ أَرَ ابْنَ عُمَرَ فِیمَا کَانَ یُفِیضُ شَرِبَ مِنَ النَّبِیذِ قَطُّ۔",,,13487,,
13488,حدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ خَالِدِ بْنِ أَبِی بَکْرٍ ؛ أَنَّہُ حَجَّ مَعَ سَالِمٍ مَا لاَ یُحْصَی ، فَلَمْ یَرَہُ شَرِبَ مِنْ نَبِیذِ السِّقَایَۃِ۔,,,13488,,
13489,"حدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ جَابِرٍ ؛ أَنَّ ألنَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَتَی بَنِی عَبْدِ الْمُطَّلِبِ وَہُمْ یَنْزِعُونَ عَلَی زَمْزَمَ ، فَقَالَ : انْزِعُوا بَنِی عَبْدِ الْمُطَّلِبِ ، فَلَوْلاَ أَنْ یَغْلِبَکُمُ النَّاسُ عَلَی سِقَایَتِکُمْ لَنَزَعْتُ مَعَکُمْ ، فَنَاوَلُوہُ دَلْوًا فَشَرِبَ مِنْہُ۔",,,13489,,
13490,"حدَّثَنَا بِشْرُ بْنُ الْمُفَضَّلِ ، عَنْ عَبْدِ اللہِ بْنِ عُثْمَان بْنِ خُثَیْمٍ قَالَ : أَفَضْتُ مَعَ سَعِیدِ بْنِ جُبَیْرٍ ، فَأَتَی حَوْضًا فِیہِ مَائُ زَمْزَمَ ، فَغَرَفَ بِیَدِہِ فَشَرِبَ مِنْہُ۔",,,13490,,
13491,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، قَالَ : کَانُوا یَسْتَحِبُّونَ إذَا وَدَّعُوا الْبَیْتَ ، أَنْ یَأْتُوا زَمْزَمَ فَیَشْرَبُوا مِنْہَا۔",,,13491,,
13492,"حدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ حُمَیْدٍ ، عَنْ بَکْرٍ ، قَالَ : أحبَّ لِلرَّجُلِ أَنْ یَشْرَبَ ، وَأَنْ یَسْتَقِی مِنْ زَمْزَمَ إنِ اسْتَطَاعَ۔",,,13492,,
13493,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ نَافِعٍ ، قَالَ : لَمْ أَرَ عَبْدَ اللہِ بْنَ عُمَرَ فِیمَنْ کَانَ یُفِیضُ یَشْرَبُ مِنْ زَمْزَمَ قَطُّ۔",,,13493,,
13494,حدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ خَالِدِ بْنِ أَبِی بَکْرٍ ؛ أَنَّہُ لَمْ یَرَ سَالِمًا یَشْرَبُ مِنْ مَائِ زَمْزَمَ۔,,,13494,,
13495,حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ اعْتَمَرَ عام الْقِتَالَ فِی شَوَّالٍ وَرَجَبٍ۔,,,13495,,
13496,"حدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : کَانَتْ عَائِشَۃُ تَعْتَمِرُ فِی آخِرِ ذِی الْحِجَّۃِ ، وَتَعْتَمِرُ مِنَ الْمَدِینَۃِ فِی رَجَبٍ ، تُہِلُّ مِنْ ذِی الْحُلَیْفَۃِ۔",,,13496,,
13497,"حدَّثَنَا أَبُو خَالِدٍ ، عَنْ مُحَمَّدِ بْنِ سُوقَۃَ ، قَالَ : کَانَ الأَسْوَدُ یَعْتَمِرُ فِی رَجَبٍ ثُمَّ یَرْجِعُ۔",,,13497,,
13498,"حدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، قَالَ : سَمِعْتُ یَحْیَی بْنَ عَبْدِ الرَّحْمَنِ یُحَدِّثُ ، عَنْ أَبِیہِ ؛ أَنَّہُ اعْتَمَرَ مَعَ عُثْمَانَ فِی رَجَبٍ۔",,,13498,,
13499,"حدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَنْ یَعْلَی بْنِ الْحَارِثِ ، قَالَ : سَمِعْتُ أَبَا إِسْحَاقَ وَسُئِلَ عَنْ عُمْرَۃِ رَمَضَانَ ؟ فَقَالَ : أَدْرَکْتُ أَصْحَابَ عَبْدِ اللہِ لاَ یَعْدِلُونَ بِعُمْرَۃِ رَجَبٍ ، ثُمَّ یَسْتَقْبِلُونَ الْحَجَّ۔",,,13499,,
13500,"حدَّثَنَا أَبُو عَامِرٍ الْعَقَدِیُّ ، عَنْ أَفْلَحَ ، قَالَ : کَانَ الْقَاسِمُ یَعْتَمِرُ فِی رَجَبٍ۔",,,13500,,
13501,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ یَحْیَی بْنِ عَبْدِ الرَّحْمَنِ بْنِ حَاطِبٍ ، عَنْ أَبِیہِ ، قَالَ : اعْتَمَرْتُ مَعَ عُمَرَ وَعُثْمَانَ فِی رَجَبٍ۔",,,13501,,
13502,"حدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، قَالَ : حدَّثَنَا عَمَّارُ بْنُ رُزَیْقٍ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عَنْ عَائِشَۃَ ، قَالَتْ : أَدْلَجَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لَیْلَۃَ النَّفْرِ مِنَ الْبَطْحَائِ إِدْلاَجًا۔\n\n(ابن ماجہ 3068۔ احمد 6/78)",,,13502,,
13503,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ صَالِحِ بْنِ کَیْسَانَ ، قَالَ : سَمِعْتُ سُلَیْمَانَ بْنَ یَسَارٍ یَقُولُ : إنَّ أَبَا رَافِعٍ کَانَ عَلَی ثَقَلِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : أَنَا جِئْتُ فَضَرَبْتُ قُبَّتَہُ بِالأَبْطَحِ ، فَجَائَ فَنَزَلَ۔\n\n(مسلم 342۔ ابوداؤد 2002)",,,13503,,
13504,حدَّثَنَا جَرِیرٌ، عَنْ مَنْصُورٍ، عَنْ إبْرَاہِیمَ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَامَ نَوْمَۃً بِالأَبْطَحِ، ثُمَّ أَدْلَجَ۔,,,13504,,
13505,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ وَاصِلٍ ، عَنِ الْمَعْرُورِ بْنِ سُوَیْد ، قَالَ : قَالَ عُمَرُ : یَا آلَ خُزَیْمَۃَ ، حَصِّبُوا لَیْلَۃَ النَّفْرِ۔",,,13505,,
13506,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ الْعَلاَئِ بْنِ الْمُسَیَّبِ ، قَالَ : حدَّثَنَا عَمْرُو بْنُ مُرَّۃَ ، قَالَ : نَزَلَ الأَسْوَدُ بِالأَبْطَحِ ، قَالَ : فَسَمِعَ رُغَائً ، قَالَ : فَنَظَرَ مَا ہُوَ ؟ فَإِذَا ہُوَ ابْنُ عُمَرَ یَرْتَحِلُ۔",,,13506,,
13507,"حدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ یَزِیدَ ، قَالَ : جِئْتُ مَعَ سَعِیدِ بْنِ جُبَیْرٍ ، فَلَمَّا نَفَرْنَا أَتَیْنَا الأَبْطَحَ حِینَ أَقْبَلْنَا مِنْ مِنًی۔",,,13507,,
13508,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا انْتَہَی إِلَی الأَبْطَحِ فَلْیَضَعْ رَحْلَہُ ، ثُمَّ لِیَزُرِ الْبَیْتَ وَیَضْطَجِعْ فِیہِ ہُنَیْہَۃً ، ثُمَّ لِیَنْفِرْ۔",,,13508,,
13509,حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ ابْنِ طَاوُوس ؛ أَنَّ أَبَاہُ کَانَ یُحَصِّبُ فِی شِعْبِ الْخَوْزِ۔,,,13509,,
13510,حدَّثَنَا وَکِیعٌ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، عَنْ عَمْرِو بْنِ دِینَارٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَأَبَا بَکْرٍ وَعُمَرَ کَانُوا یُحَصِّبُونَ۔ (مسلم 951۔ ترمذی 921),,,13510,,
13511,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لَیْسَ التَّحْصِیبُ بِشَیْئٍ ، إِنَّمَا ہُوَ مَنْزِلٌ نَزَلَہُ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔ (بخاری 1766۔ مسلم 952)",,,13511,,
13512,"حدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ کَانَ لاَ یَنْزِلُ الأَبْطَحَ ، وَقَالَ : إنَّمَا فَعَلَہُ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لأَنَّہُ انْتَظَرَ عَائِشَۃَ۔ (احمد 1/351)",,,13512,,
13513,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ عُرْوَۃَ ، عَنْ عَائِشَۃَ قَالَتْ : إنَّمَا نَزَلَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الأَبْطَحَ لأَنَّہُ أَسْمَحُ لِخُرُوجِہِ ، وَإِنَّہُ لَیْسَ بِسُنَّۃٍ۔ (بخاری 1765۔ ابوداؤد 2001)",,,13513,,
13514,حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، نَحْوَہُ۔,,,13514,,
13515,حدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ، عَنْ لَیْثٍ؛ أَنَّ عَطَائً، وَطَاوُسًا، وَمُجَاہِدًا، وَسَعِیدَ بْنَ جُبَیْرٍ کَانُوا لاَیُحَصِّبُونَ۔,,,13515,,
13516,حدَّثَنَا عَبْدَۃُ بْنِ سُلَیْمَانَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ فَاطِمَۃَ ؛ أَنَّ أَسْمَائَ کَانَتْ لاَ تُحَصِّبُ۔,,,13516,,
13517,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ : إنَّمَا الْحَصْبَۃُ فِی السَّمَائِ۔",,,13517,,
13518,حدَّثَنَا وَکِیعٌ ، عَنْ عُمَرَ بْنِ ذَرٍّ ، عَنْ مُجَاہِدٍ ؛ أَنَّہُ أَنْکَرَہُ۔,,,13518,,
13519,حدَّثَنَا عَبْدَۃُ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ؛ أَنَّ أَبَاہُ کَانَ لاَ یُحَصِّبُ۔,,,13519,,
13520,حدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ خَرَجَ إلَی الصَّفَا مِنْ بَابِ بَنِی مَخْزُومٍ۔,,,13520,,
13521,"حدَّثَنَا أَبُو خَالِدٍ ، عَنْ حُمَیْدٍ ، عَنْ بَکْرٍ ، قَالَ : کَانَ ابْنُ عُمَرَ إِذَا قَدِمَ فَطَافَ بِالْبَیْتِ وَصَلَّی رَکْعَتَیْنِ ، خَرَجَ إلَی الصَّفَا مِنَ الْبَابِ الَّذِی یَلِی السِّقَایَۃَ۔",,,13521,,
13522,"حدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : کَانَ لاَ یَرَی بَأْسًا مِنْ أَیِّ أَبْوَابِ الْمَسْجِدِ خَرَجَ إلَی الصَّفَا۔",,,13522,,
13523,"حدَّثَنَا أَبُو خَالِدٍ، عَنْ حَجَّاجٍ، عَنْ عَطَائٍ، قَالَ: إذَا صَلَّیْتَ فَاخْرُجْ مِنْ أَیِّ الأَبْوَابِ شِئْتَ، یَعْنِی إلَی الصَّفَا۔",,,13523,,
13524,"حدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : إذَا طُفْتَ بِالْبَیْتِ فَلَمْ تَدْرِ أَأَتْمَمْتَ ، أَمْ لَمْ تُتِمْ ، فَأَتِمَّ مَا شَکَکْتَ ، فَإِنَّ اللَّہَ لاَ یُعَذِّبُ عَلَی الزِّیَادَۃِ۔",,,13524,,
13525,"حدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : إذَا شَکَّ الرَّجُلُ فِی الطَّوَافِ فَلَمْ یَدْرِ أَطَافَ ، أَمْ لَمْ یَطُفْہُ ؟ فَلْیَسْتَقْبِلْ۔",,,13525,,
13526,"حدَّثَنَا وَکِیعٌ ، عَنْ عِمْرَانَ بْنِ حُدَیْرٍ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ : رَمَیْتُ الْجِمَارَ فَلَمْ أَدْرِ بِکَمْ رَمَیْتُ ؟ فَسَأَلْتُ ابْنَ عُمَرَ فَلَمْ یُجِبْنِی ، فَمَرَّ بِی ابْنُ الْحَنَفِیَّۃِ فَسَأَلْتُہُ ؟ فَقَالَ : یَا عَبْدَ اللہِ ، لَیْسَ شَیْئٌ أَعْظَمَ عَلَیْنَا مِنَ الصَّلاَۃِ ، وَإِذَا نَسِیَ أَحَدُنَا أَعَادَ ، فَأَخْبَرْتُ ابْنَ عُمَرَ ، فَقَالَ : إنَّہُمْ أَہْلُ بَیْتٍ مُفَہَّمُونَ۔",,,13526,,
13527,"حدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنِ الْحَکَمِ ، عَنْ مِقْسَمٍ، عَنِ ابْنِ عَبَّاسٍ؛ {فَجَزَائٌ مِثْلُ مَا قَتَلَ مِنَ النَّعَمِ} إلَی قَوْلِہِ : {أَوْ عَدْلُ ذَلِکَ صِیَامًا} قَالَ : إذَا أَصَابَ الْمُحْرِمُ الصَّیْدَ حُکِمَ عَلَیْہِ بِجَزَائِہِ مِنَ النَّعَمِ ، فَإِنْ لَمْ یَجِدْ نَظَرَ کَمْ ثَمَنُہُ ، ثُمَّ قَوَّمَ ثَمَنَہُ طَعَامًا ، فَصَامَ مَکَانَ کُلِّ نِصْفِ صَاعٍ یَوْمًا ، {أَوْ کَفَّارَۃٌ طَعَامُ مَسَاکِینَ ، أَوْ عَدْلُ ذَلِکَ صِیَامًا} قَالَ : إنَّمَا أُرِیدَ بِالطَّعَامِ الصِّیَامَ ، إِنَّہُ إذَا وَجَدَ الطَّعَامَ وَجَدَ جَزَائَہُ۔",,,13527,,
13528,"حدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ؛ فِی قَوْلِہِ تَعَالَی : (وَمَنْ قَتَلَہُ مِنْکُمْ مُتَعَمِّدًا فَجَزَائٌ مِثْلُ مَا قَتَلَ مِنَ النَّعَمِ یَحْکُمُ بِہِ ذَوَا عَدْلٍ مِنْکُمْ ہَدْیًا بَالِغَ الْکَعْبَۃِ) فَإِنْ لَمْ یَجِدْ قُوِّمَ عَلَیْہِ طَعَامٌ ، ثُمَّ قِیلَ لَہُ : صُمْ لِکُلِّ نِصْفِ صَاعٍ یَوْمًا۔",,,13528,,
13529,"حدَّثَنَا عَائِذُ بْنُ حَبِیبٍ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، وَمُجَاہِدٍ ، وَإِبْرَاہِیمَ ؛ أَنَّہُمْ قَالُوا : إذَا أَصَابَ الْمُحْرِمُ الصَّیْدَ فَعَلَیْہِ ثَمَنُہُ فَاشْتَرَی دَمًا ، فَإِنْ لَمْ یَجِدْ دَمًا قَوَّمَ طَعَامًا فَتَصَدَّقَ عَلَی کُلِّ مِسْکِینٍ نِصْفَ صَاعٍ ، فَإِنْ لَمْ یَجِدْ صَامَ لِکُلِّ صَاعٍ یَوْمَیْنِ۔",,,13529,,
13530,"حدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، قَالَ : ذَکَرَ مَیْمُونُ بْنُ مِہْرَانَ فِی قَتْلِ الرَّجُلِ الصَّیْدَ وَہُوَ مُحْرِمٌ ، قَالَ : {جَزَائٌ مِثْلُ مَا قَتَلَ مِنَ النَّعَمِ یَحْکُمُ بِہِ ذَوَا عَدْلٍ مِنْکُمْ ہَدْیًا بَالِغَ الْکَعْبَۃِ} إِنْ وَجَدَ الرَّجُلُ جَزَائَ الصَّیْدِ أَہْدَی ، وَإِنْ لَمْ یَجِدْ فقیمۃ ثَمَنِہِ ، فَیَجْعَلُہُ طَعَامًا یَتَصَدَّقُ بِہِ عَلَی الْمَسَاکِینِ ، فَإِنْ لَمْ یَجِدْ صَامَ عَنْ طَعَامِ کُلِّ مِسْکِینٍ یَوْمًا۔",,,13530,,
13531,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ مِقْسِمٍ قَالَ : یُقَوَّم عَلَیْہِ دَرَاہِمَ ، ثُمَّ یُقَوَّم بِالدَّرَاہِمِ الطَّعَامَ ، ثُمَّ یَصُومُ لِکُلِّ نِصْفِ صَاعٍ یَوْمًا۔",,,13531,,
13532,"حدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ عِکْرِمَۃَ ، قَالَ : کَانَتْ ہَذِہِ الآیَۃُ نَزَلَتْ : {لَیْسَ عَلَیْکُمْ جُنَاحٌ أَنْ تَبْتَغُوا فَضْلاً مِنْ رَّبِّکُمْ} قَالَ : فِی مَوَاسِمِ الْحَجِّ۔",,,13532,,
13533,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنِ ابْنِ عَبَّاسٍ ۔(ح) وَعَنْ عُبَیْدِ اللہِ بْنِ أَبِی یَزِیدَ ، عَنِ ابْنِ الزُّبَیْرِ ؛ (لَیْسَ عَلَیْکُمْ جُنَاحٌ أَنْ تَبْتَغُوا فَضْلاً مِنْ رَبِّکُمْ) قَالَ : فِی مَوَاسِمِ الْحَجِّ۔",,,13533,,
13534,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی أُمَیْمَۃَ ؛ أَنَّہُ سَأَلَ ابْنَ عُمَرَ عَنِ الرَّجُلِ یَحُجُّ ، وَیَحْمِلُ مَعَہُ تِجَارَۃً ؟ فَقَالَ ابْنُ عُمَرَ : لاَ بَأْسَ بِہِ ، وَتَلاَ ہَذِہِ الآیَۃَ : {یَبْتَغُونَ فَضْلاً مِنْ رَبِّہِمْ وَرِضْوَانًا}۔",,,13534,,
13535,"حدَّثَنَا غُنْدَرٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ یَحُجَّ الرَّجُلُ وَمَعَہُ تِجَارَۃٌ۔قَالَ : وَقَالَ مُحَمَّدٌ : إِنَّ اللہ قَادِرٌ عَلَی أَنْ یَجْمَعَہُمَا لَہُ جَمِیعًا۔",,,13535,,
13536,"حدَّثَنَا وَکِیعٌ ، عَنْ عُمَرَ بْنِ ذَرٍّ ، عَنْ مُجَاہِدٍ ، قَالَ : کَانُوا لاَ یَتَّجِرُونَ حَتَّی نَزَلَتْ : {لَیْسَ عَلَیْکُمْ جُنَاحٌ أَنْ تَبْتَغُوا فَضْلاً مِنْ رَبِّکُمْ}۔",,,13536,,
13537,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدٍ ، عَنْ مُجَاہِدٍ ، عَنْ ابْنِ عَبَّاسٍ، قَالَ : {لَیْسَ عَلَیْکُمْ جُنَاحٌ أَنْ تَبْتَغُوا فَضْلاً مِنْ رَبِّکُمْ} قَالَ : کَانُوا لاَ یَبِیعُونَ وَلاَ یَشْتَرُونَ فِی أَیَّامِ مِنًی ، فَأَنْزَلَ اللَّہُ تَعَالَی : {لَیْسَ عَلَیْکُمْ جُنَاحٌ أَنْ تَبْتَغُوا فَضْلاً مِنْ رَبِّکُمْ}۔",,,13537,,
13538,حدَّثَنَا شَبَابَۃُ ، عَنْ وَرْقَائَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ؛ (لَیْسَ عَلَیْکُمْ جُنَاحٌ أَنْ تَبْتَغُوا فَضْلاً مِنْ رَبِّکُمْ) التِّجَارَۃُ فِی الْمَوَاسِمِ أُحِلَّتْ لَہُمْ ، کَانُوا لاَ یَتَبَایَعُونَ فِی الْجَاہِلِیَّۃِ بِعَرَفَۃَ ، وَلاَ مِنًی۔,,,13538,,
13539,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطَائٍ ، قَالَ : سَمِعَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجُلاً یَقُولُ: لَبَّیْکَ عَنْ شُبْرُمَۃَ ، فَقَالَ : إِنْ کُنْتَ حَجَجْتَ فَلَبِّ عَنْ شُبْرُمَۃَ ، وَإِلاَّ فَلَبِّ عَنْ نَفْسِکَ۔ (دارقطنی 156)",,,13539,,
13540,"حدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا سَعِیدٌ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، بِنَحْوِہِ۔ (ابوداؤد 1807۔ ابن ماجہ 2903)",,,13540,,
13541,"حدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ؛ أَنَّ ابْنَ عَبَّاسٍ سَمِعَ رَجُلاً یَقُولُ : لَبَّیْکَ عَنْ شُبْرُمَۃَ ، قَالَ : وَیْحَکَ ، وَمَا شُبْرُمَۃُ ؟ فَذَکَرَ رَجُلاً بَیْنَہُ وَبَیْنَہُ قَرَابَۃٌ ، قَالَ : حَجَجْتَ قَطُّ ؟ قَالَ : لاَ ، قَالَ : فَاجْعَلْ ہَذِہِ عَنْکَ۔",,,13541,,
13542,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا حُمَیْدُ بْنُ الأَسْوَدِ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ؛ أَنَّ عَلِیًّا کَانَ لاَ یَرَی بَأْسًا أَنْ یَحُجَّ الصَّرُورَۃُ عَنِ الرَّجُلِ۔",,,13542,,
13543,"حدَّثَنَا وَکِیعٌ ، عَنْ عُمَرَ بْنِ ذَرٍّ ، عَنْ مُجَاہِدٍ ؛ فِی الرَّجُلِ یَحُجُّ عَنِ الرَّجُلِ وَلَمْ یَکُنْ حَجَّ قَطُّ ؟ قَالَ : یُجْزِء عَنْہُ وَعَنْ صَاحِبِہِ الأَوَّلِ ۔ قَالَ أَبُو بَکْرٍ : الصَّرُورَۃُ الَّذِی لَمْ یَحُجَّ قَطُّ۔",,,13543,,
13544,حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ، عَنْ ہِشَامٍ، عَنِ الْحَسَنِ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ یَحُجَّ الصَّرُورَۃُ عَنِ الرَّجُلِ۔,,,13544,,
13545,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ دَاوُدَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : إنَّ اللَّہَ لَوَاسِعٌ لَہُمَا جَمِیعًا۔",,,13545,,
13546,"حدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ؛ فِی الرَّجُلِ یَکُونُ مُحْرِمًا بِحَجَّۃٍ وَعُمْرَۃٍ ، وَامْرَأَتُہُ مُحْرِمَۃٌ بِحَجَّۃٍ وَعُمْرَۃٍ فَیَقَعُ عَلَیْہَا ، قَالَ : یَمْضِیَانِ لِحَجِّہِمَا وَلِعُمْرَتِہِمَا ، وَیُہْرِیقُ کُلُّ وَاحِدٍ مِنْہُمَا دَمًا ، وَعَلَیْہِمَا عمْرَۃٌ وَالْحَجُّ مِنْ قَابِلٍ ، وَلاَ یَمُرَّانِ بِالْمَکَانِ الَّذِی أَصَابَا فِیہِ مَا أَصَابَا۔",,,13546,,
13547,"حدَّثَنَا سَہْلُ بْنُ یُوسُفَ، عَنْ عَمْرٍو، عَنِ الْحَسَنِ؛ فِی الَّذِی یَقَعُ بِأَہْلِہِ وَقَدْ أَہَلَّ بِہِمَا، قَالَ: عَلَیْہِ بَدَنَتَانِ۔",,,13547,,
13548,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ، عَنِ ابْنِ جُرَیْجٍ، عَنْ عَطَائٍ ، قَالَ: الْقَارِنُ وَغَیْرُ الْقَارِنِ سَوَائٌ فِی جَزَائِ الصَّیْدِ۔",,,13548,,
13549,"حدَّثَنَا ہُشَیْمٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطَائٍ ؛ أَنَّہُ سُئِلَ عَنِ الْمُحْرِمِ یُوَاقِعُ ، ثُمَّ یَعُودُ ؟ قَالَ : عَلَیْہِ ہَدْیٌ وَاحِدٌ۔",,,13549,,
13550,"حدَّثَنَا ابْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ فِی مُحْرِمٍ غَشِیَ امْرَأَتَہُ مِرَارًا ، قَالَ : إذَا فَعَلَ ذَلِکَ قَبْلَ أَنْ یَنْسُکَ وَیَعْلَمَ مَا عَلَیْہِ ، فَعَلَیْہِ ہَدْیٌ وَاحِدٌ۔",,,13550,,
13551,"حدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ، عَنِ ابْنِ أَبِی نَجِیحٍ، عَنْ أَبِیہِ، قَالَ: سُئِلَ ابْنُ عُمَرَ عَنْ صَوْمِ یَوْمِ عَرَفَۃَ؟ فَقَالَ: حجَجْتُ مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَلَمْ یَصُمْہُ، وَحَجَجْتُ مَعَ أَبِی بَکْرٍ فَلَمْ یَصُمْہُ، وَحَجَجْتُ مَعَ عُمَرَ فَلَمْ یَصُمْہُ ، وَحَجَجْتُ مَعَ عُثْمَانَ فَلَمْ یَصُمْہُ ، وَأَنَا لاَ أَصُومُہُ ، وَلاَ آمُرُ بِہِ ، وَلاَ أَنْہَی عَنْہُ۔\n\n(ترمذی 751۔ ابن حبان 3604)",,,13551,,
13552,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، عَنِ الْفَضْلِ بْنِ عَبَّاسٍ قَالَ : دَعَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِلَبَنٍ یَوْمَ عَرَفَۃَ مِنْ رَحْلِ أُمِّ الْفَضْلِ ، فَشَرِبَ مِنْہُ وَہُوَ بِالْمَوْقِفِ۔",,,13552,,
13553,حدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، عَنِ الْفَضْلِ بْنِ عَبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ شَرِبَ یَوْمَ عَرَفَۃَ۔ (ابویعلی 6697۔ طبرانی 18),,,13553,,
13554,"حدَّثَنَا إسْمَاعِیلُ بْنُ إِبْرَاہِیمَ ، عَن أَیُّوبَ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : أَفْطَرَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِعَرَفَۃَ ، وَبَعَثَتْ إِلَیْہِ أُمُّ الْفَضْلِ بِلَبَنٍ فَشَرِبَہُ۔ (ترمذی 750۔ نسائی 2820)",,,13554,,
13555,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، قَالَ : لاَ أَدْرِی سَمِعْتُہُ مِنْ سَعِیدِ بْنِ جُبَیْرٍ ، أَوْ حُدِّثْتُ عَنْہُ ، قَالَ : أَتَیْتُ عَلَی ابْنِ عَبَّاسٍ بِعَرَفَۃَ وَہُوَ یَأْکُلُ رُمَّانًا ، وَقَالَ : أَفْطَرَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِعَرَفَۃَ ، وَسَقَتْہُ أُمُّ الْفَضْلِ لَبَنًا فَشَرِبَہُ ، وَقَالَ : لَعَنَ اللَّہُ فُلاَنًا ، عَمَدُوا إلَی أَیَّامِ الْحَجِّ فَمَحَوْا زِینَتَہُ ، وَقَالَ : زِینَۃُ الْحَجِّ التَّلْبِیَۃُ۔\n\n(نسائی 2815۔ احمد 1/349)",,,13555,,
13556,"حدَّثَنَا وَکِیعٌ ، عَنْ حَوْشَبِ بْنِ عَقِیلٍ ، قَالَ : حدَّثَنِی مَہْدِیٌّ الْعَبْدِیُّ ، عَنْ عِکْرِمَۃَ ، قَالَ : دَخَلْتُ إلَی أَبِی ہُرَیْرَۃَ فِی بَیْتِہِ فَسَأَلْتُہُ عَنْ صَوْمِ یَوْمِ عَرَفَۃَ بِعَرَفَاتٍ ؟ فَقَالَ أَبُو ہُرَیْرَۃَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ صَوْمِ یَوْمِ عَرَفَۃَ بِعَرَفَاتٍ۔ (ابوداؤد 2432۔ احمد 2/304)",,,13556,,
13557,"حدَّثَنَا وَکِیعٌ ، عَنْ مُوسَی بْنِ عُلَیٍّ ، عَنْ أَبِیہِ ، عَنْ عُقْبَۃَ بْنِ عَامِرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : یَوْمُ عَرَفَۃَ وَیَوْمُ النَّحْرِ وَأَیَّامُ مِنَی أَیَّامُ أَکْلٍ وَشُرْبٍ۔",,,13557,,
13558,"حدَّثَنَا إسْمَاعِیلُ بْنُ إِبْرَاہِیمَ ، عَن یَحْیَی بْنِ أَبِی إِسْحَاقَ ، قَالَ : سَأَلْتُ سَعِیدَ بْنَ الْمُسَیَّبِ عَنْ صَوْمِ یَوْمِ عَرَفَۃَ ؟ فَقَالَ : کَانَ عَبْدُ اللہِ بْنُ عُمَرَ لاَ یَصُومُہُ۔",,,13558,,
13559,"حدَّثَنَا وَکِیعٌ ، عَنْ مُحَمَّدِ بْنِ شَرِیکٍ ، عَنْ سُلَیْمَانَ الأَحْوَلِ ، قَالَ : ذَکَرْتُ لِطَاوُوسٍ صَوْمَ عَرَفَۃَ أَنَّہُ یَعْدِلُ بِصَوْمِ سَنَتَیْنِ ؟ فَقَالَ : أَیْنَ کَانَ أَبُو بَکْرٍ ، وَعُمَرُ عَنْ ذَلِکَ ؟۔",,,13559,,
13560,"حدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ سَالِمٍ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ؛ أَنَّہُ أَفْطَرَ یَوْمَ عَرَفَۃَ، وَقَالَ: أَتَقَوَّی عَلَی الدُّعَائِ۔",,,13560,,
13561,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ، عَنِ ابْنِ جُرَیْجٍ، عَنْ عَطَائٍ، عَنْ عُبَیْدِ بْنِ عُمَیْرٍ، قَالَ: رَأَیْتُ عُمَرَ شَرِبَ یَوْمَ عَرَفَۃَ۔",,,13561,,
13562,"حدَّثَنَا یَحْیَی بْنُ مُحَمَّدِ بْنِ الْبَہِیِّ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ ، وَابْنَ الزُّبَیْرِ یَتَعَاوَرَانِ إدَاوَۃً عَشِیَّۃَ عَرَفَۃَ ، یَشْرَبَانِ مِنْہَا۔",,,13562,,
13563,حدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَکْرَہُ صَوْمَ یَوْمَ عَرَفَۃَ إذَا کَانَ بِمَکَّۃَ۔,,,13563,,
13564,حدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنْ عَبْدِ اللہِ بْنِ عُبَیْدِ بْنِ عُمَیْرٍ ؛ أَنَّہُ أَمَرَہُ أَبُوہُ عُبَیْدُ بْنُ عُمَیْرٍ أَنْ یُفْطِرَ یَوْمَ عَرَفَۃَ۔,,,13564,,
13565,"حدَّثَنَا وَکِیعٌ ، عَنْ عُمَارَۃَ بْنِ زَاذَانَ ، قَالَ : سَأَلْتُ سَالِمًا عَنْ صَوْمِ یَوْمِ عَرَفَۃَ ؟ فَقَالَ : لَمْ یَصُمْہُ عُمَرُ ، وَلاَ أَحَدٌ مِنْ آلِ عُمَرَ ، یَا بُنَیَّ۔",,,13565,,
13566,حدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی قَیْسٍ ، عَنْ ہُزَیْلٍ ، عَنْ مَسْرُوقٍ ، عَنْ عَائِشَۃَ ؛ أَنَّہَا کَانَتْ تَصُومُ یَوْمَ عَرَفَۃَ۔,,,13566,,
13567,حدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یَصُومُ عَرَفَۃَ۔,,,13567,,
13568,حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنِ الْقَاسِمِ ، عَنْ عَائِشَۃَ ؛ أَنَّہَا کَانَتْ تَدْعُو بِشَرَابٍ فَتُفْطِرُ ، ثُمَّ تُفِیضُ۔,,,13568,,
13569,حدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ، عَنْ مِسْعَرٍ، عَنْ عَبْدِاللہِ بْنِ شَرِیکٍ، عَنِ ابْنِ عُمَرَ؛ أَنَّہُ کَانَ یُفْطِرُ قَبْلَ أَنْ یُفِیضَ۔,,,13569,,
13570,حدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنِ ابْنِ الزُّبَیْرِ ؛ أَنَّہُ کَانَ إذَا أَرَادَ أَنْ یُفِیضَ دَعَا بِإِنَائٍ ، ثُمَّ شَرِبَ ، ثُمَّ أَفَاضَ۔,,,13570,,
13571,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنِ الْقَاسِمِ ، قَالَ : کَانَتْ عَائِشَۃُ لاَ تُفِیضُ حَتَّی یَبْیَضَّ مَا بَیْنَہَا وَبَیْنَ النَّاسِ مِنَ الأَرْضِ۔",,,13571,,
13572,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : یَقِفُ الإِنْسَان عَشِیَّۃَ عَرَفَۃَ بَعْدَ مَا یَدْفَعُ الإِمَامُ ، حَتَّی یَذْہَبَ زِحَامُ النَّاسِ ؟ قَالَ : لاَ بَأْسَ بِہِ۔",,,13572,,
13573,"حدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ أَبِی حُرَّۃَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ سُئِلَ عَنْ رَجُلٍ وَقَفَ مَعَ الإِمَامِ ، أَیَحْبِسُ رَاحِلَتَہُ وَقَدْ نَفَرَ الإِمَامُ حَتَّی یَذْہَبَ الزِّحَامُ ؟ قَالَ : لاَ بَأْسَ بِہِ۔",,,13573,,
13574,حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَتَی جَمْرَۃَ الْعَقَبَۃِ فَرَمَاہَا ، وَلَمْ یَقِفْ عِنْدَہَا۔ (احمد 2/190),,,13574,,
13575,حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ یَرْمِی الْجَمْرَتَیْنِ وَیَقِفُ عِنْدَہُمَا ، وَلاَ یَقِفُ عِنْدَ الثَّالِثَۃِ۔,,,13575,,
13576,"حدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ ہَارُونَ بْنِ أَبِی عَائِشَۃَ ، عَنْ عَدِیِّ بْنِ عَدِیِّ ، عَنْ سَلْمَانَ بْنِ رَبِیعَۃَ ، قَالَ : نَظَرْنَا عُمَرَ فَأَتَی الْجَمْرَۃَ الثَّالِثَۃَ فَرَمَاہَا ، وَلَمْ یَقِفْ عِنْدَہَا۔",,,13576,,
13577,حدَّثَنَا وَکِیعٌ ، عَنْ شَرِیکٍ ، عَنْ مُجَاہِدٍ بْنِ رَاشِدٍ ، عَنْ سَعِیدِ بْنُ جُبَیْر ؛ أَنَّہ لَمْ یَقِفْ عِنْدَہَا۔,,,13577,,
13578,"حدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، وَابْنُ فُضَیْلٍ ، وَعَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنْ سُلَیْمَانَ بْنِ عَمْرِو بْنِ الأَحْوَص ، عَنْ أُمِّہِ ، قَالَتْ : رَأَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَوْمَ النَّحْرِ أَتَی جَمْرَۃَ الْعَقَبَۃِ فَرَمَاہَا ، ثُمَّ انْصَرَفَ ، وَقَالَ بَعْضُہُمْ : لَمْ یَقِفْ ۔ زَادَ ابْنُ مُسْہِرٍ : فَرَمَاہَا سَبْعَ حَصَیَاتٍ ، یُکَبِّرُ مَعَ کُلِّ حَصَاۃٍ۔ (ابوداؤد 1961۔ ابن ماجہ 3028)",,,13578,,
13579,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ یُقَامُ یَوْمَ النَّفْرِ عِنْدَ الْجِمَارِ۔",,,13579,,
13580,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، قَالَ : یُقَامُ عِنْدَہَا قِیَامًا خَفِیفًا۔",,,13580,,
13581,"حدَّثَنَا أَبُو عَامِرٍ الْعَقَدِیُّ، عَنْ أَفْلَحَ ، قَالَ: رَأَیْتُ الْقَاسِمَ یَقُومُ عِنْدَ الْجِمَارِ یَوْمَ النَّفْرِ ، فَیَدْعُو وَیُخَفِّفُ، وَقَدْ کَانَ قَبْلَ ذَلِکَ یُطِیلُ۔",,,13581,,
13582,"حدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، قَالَ : قیلَ لِعَبْدِ اللہِ : إِنَّ أُنَاسًا یَرْمُونَ الْجَمْرَۃَ مِنْ فَوْقِہَا ، فَاسْتَبْطَنَ الْوَادِیَ ثُمَّ قَالَ : مِنْ ہَاہُنَا ، وَالَّذِی لاَ إلَہَ غَیْرُہُ رَمَی الَّذِی أُنْزِلَتْ عَلَیْہِ سُورَۃُ الْبَقَرَۃِ۔ (بخاری 1747۔ مسلم 307)",,,13582,,
13583,"حدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَمْرِو بْنِ مَیْمُونٍ ، قَالَ : حجَجْتُ مَعَ عُمَرَ سَنَتَیْنِ ، إحْدَاہُمَا فِی السَّنَۃِ الَّتِی أُصِیبَ فِیہَا ، کُلُّ ذَلِکَ یُلَبِّی حَتَّی یَرْمِیَ جَمْرَۃَ الْعَقَبَۃِ مِنْ بَطْنِ الْوَادِی۔",,,13583,,
13584,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : إذَا رَمَیْتَ الْجَمْرَۃَ فَتَقَدَّمَ إلَی بَطْنِ الْمَسِیلِ۔",,,13584,,
13585,"حدَّثَنَا أَزْہَرُ السَّمَّانُ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : رَأَیْتُ الْقَاسِمَ اسْتَبْطَنَ الْوَادِیَ۔",,,13585,,
13586,"حدَّثَنَا عَبْدُ الأَعْلَی، عَنْ ہِشَامٍ، عَنِ الْحَسَنِ، وَعَطَائٍ، قَالا: کَانَ أَحَبَّ إلَیْہِمَا أَنْ یَرْمِیَاہَا مِنْ بَطْنِ الْوَادِی۔",,,13586,,
13587,"حدَّثَنَا ابْنُ مُسْہِرٍ ، وَابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنْ سُلَیْمَانَ بْنِ عَمْرِو بْنِ الأَحْوَصِ ، عَنْ أُمِّہِ، قَالَتْ : رَأَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَمَی جَمْرَۃَ الْعَقَبَۃِ مِنْ بَطْنِ الْوَادِی۔",,,13587,,
13588,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ حَجَّاجٍ ، عَنْ وَبَرَۃَ ، عَنِ الأَسْوَدِ ، قَالَ : رَأَیْتُ عُمَرَ بْنَ الْخَطَّابِ یَرْمِی جَمْرَۃَ الْعَقَبَۃِ مِنْ فَوْقِہَا۔",,,13588,,
13589,"حدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : کَیْفَ أَرْمِی الْجَمْرَتَیْنِ الْقُصْوَیَیْنِ ؟ قَالَ : اعلُہمَا عُلْوًا ، ثُمَّ تَفْرَعُہُمَا۔",,,13589,,
13590,حدَّثَنَا وَکِیعٌ ، عَنْ عُمَرَ شَیْخٍ مِنْ أَہْلِ الْبَصْرَۃِ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَرْمِی الْجَمْرَۃَ مِنْ فَوْقِہَا۔,,,13590,,
13591,حدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ الرُّؤَاسِیُّ ، عَنْ زُہَیْرٍ ، عَنِ الْحَسَنِ بْنِ الْحُرِّ ، عَنِ الْحَکَمِ ، عَنْ إِبْرَاہِیمَ، عَن أَصْحَابِ عَبْدِ اللہِ ؛ أَنَّہُمْ کَانُوا یَرْمُونَ الْجَمْرَتَیْنِ الأُوْلَیَیْنِ مِنْ فَوْقِہَا ، یَرْمُونَ أَعْلَی شَیْئٍ مِنْہُمَا۔,,,13591,,
13592,"حدَّثَنَا وَکِیعٌ، عَنْ مَالِکِ بْنِ أَنَسٍ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ، عَنْ أَبِیہِ، قَالَ: اِرْمِہمَا مِنْ حَیْثُ تَیَسَّرَ۔",,,13592,,
13593,"حدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، قَالَ : رَأَیْتُ الْقَاسِمَ ، وَسَالِمًا ، وَنَافِعًا یَرْمُونَ مِنَ الشَّجَرَۃِ ، فَأَمَّا الْقَاسِمُ فَکَانَ یَقُومُ بَیْنَہَا وَبَیْنَ مَکَّۃَ ، یَجْعَلُ مَکَّۃَ خَلْفَ ظَہْرِہِ مُسْتَقْبِلَہَا ، وَأَمَّا سَالِمٌ وَنَافِعٌ فَکَانَا یَقُومَانِ أَدْنَی مِنْ مَقَامِہِ۔",,,13593,,
13594,"حدَّثَنَا وَکِیعٌ ، عَنِ الْبَرَائِ بْنِ سُلَیْمٍ ، قَالَ : سَأَلْتُ الْحَکَمَ أَیْنَ أَرْمِی مِنَ الْجَمْرَۃِ ؟ قَالَ : أَصْلَہَا۔",,,13594,,
13595,"حدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : رَأَیْتُ الْقَاسِمَ اسْتَقْبَلَہَا وَرَمَی سَاقَہَا۔",,,13595,,
13596,حدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یَبْدَأُ فَیَرْمِی رَأْسَ الْجَمْرَۃِ الأُولَی ، وَیَرْمِی الوسطی یَرْمِی رَأْسَہَا ، وَیَرْمِی الْعَقَبَۃَ حَیْثُ دَنَا مِنْہُ۔,,,13596,,
13597,"حدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، قَالَ : إذَا جَاوَزَ الشَّجَرَۃَ رَمَی جَمْرَۃَ الْعَقَبَۃِ مِنْ تَحْتِ غُصْنٍ مِنْ أَغْصَانِہَا۔",,,13597,,
13598,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ؛ أّنَّہُ کَانَ یَقُولُ فِی الْمَرْأَۃِ إذَا حَاضَتْ بَعْدَ مَا تَطُوفُ بِالْبَیْتِ أَشْوَاطًا : فَإِنَّہَا تُقِیمُ حَتَّی تَطْہُرَ وَتَسْتَقْبِلَ الطَّوَافَ۔",,,13598,,
13599,"حدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، قَالَ : إذَا طَافَتِ الْمَرْأَۃُ ثَلاَثَۃَ أَطْوَافٍ فَصَاعِدًا ثُمَّ حَاضَتْ ، أَجْزَأَ عَنْہَا۔",,,13599,,
13600,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ قَالَ فِی الْمَرْأَۃِ تَطُوفُ ثَلاَثَۃَ أَشْوَاطٍ ثُمَّ تَحِیضُ، قَالَ : تَعْتَدُّ بِہِ۔",,,13600,,
13601,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ حَجَّاجٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ إِیَاسٍ ، قَالَ : سَأَلْتُ إِبْرَاہِیمَ عَن رَجُلٍ طَافَ بِالْبَیْتِ ، فَبَقِیَ عَلَیْہِ مِنْ طَوَافِہِ فَأَحْدَثَ ، أَوِ امْرَأَۃٍ طَافَتْ فَحَاضَتْ ، وَقَدْ بَقِیَ عَلَیْہَا مِنْ طَوَافِہَا ، مِنْ أَیْنَ تَسْتَقْبِلُ ؟ قَالَ : مِنْ حَیْثُ حَاضَتْ۔",,,13601,,
13602,"حدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : تَسْتَقْبِلُ الطَّوَافَ أَحَبَّ إلَیَّ ، وَإِنْ فَعَلَتْ فَلاَ بَأْسَ بِہِ۔",,,13602,,
13603,حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ کَانَ یَنْتِفُ مِنْ عَیْنَیْہِ الشَّعَرَ وَہُوَ مُحْرِمٌ۔,,,13603,,
13604,"حدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُوسٍ ، وَمُجَاہِدٍ ؛ أَنَّہُمْ قَالُوا فِی الْمُحْرِمِ : إذَا نَتَفَ إبِطَہُ ، أَوْ قَلَّمَ أَظْفَارَہُ فَإِنَّ عَلَیْہِ الْفِدْیَۃَ۔",,,13604,,
13605,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، رَفَعَہُ ، قَالَ : مَنْ کَانَ أَہْلُہُ دُونَ الْمِیقَاتِ أَہَلَّ مِنْ حَیْثُ یُنْشِیئُ ، حَتَّی یَأْتِیَ ذَلِکَ عَلَی أَہْلِ مَکَّۃَ۔",,,13605,,
13606,"حدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ طَاوُوس ، وَعَطَائٍ ، وَمُجَاہِدٍ قَالُوا : إِنْ کَانَ أَہْلُہُ بَیْنَ الْوَقْتِ وَبَیْنَ مَکَّۃَ ، أَہَلَّ مِنْ أَہْلِہِ۔",,,13606,,
13607,حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، أَنَّہُ کَانَ لاَ یَرَی بَأْسًا إذَا کَانَ أَہْلُہُ دُونَ الْمِیقَاتِ أَنْ یُحْرِمَ مِنْ أَہْلِہِ۔,,,13607,,
13608,"حدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : إِنْ کَانَ أَہْلُہُ دُونَ الْمِیقَاتِ أَہَلَّ مِنْ حَیْثُ یُنْشِیئُ۔",,,13608,,
13609,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا نَسِیَ الرَّجُلُ أَنْ یَرْمِیَ جَمْرَۃَ الْعَقَبَۃِ یَوْمَ النَّحْرِ حَتَّی یُمْسِیَ ، رَمَاہَا مِنَ الْغَدِ ، وَأَہْرَاقَ لِذَلِکَ دَمًا۔",,,13609,,
13610,"حدَّثَنَا جَرِیرٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، أَنَّہُ کَانَ یَقُولُ : إذَا تَرَکَ جَمْرَۃَ الْعَقَبَۃِ إلَی اللَّیْلِ مُتَعَمِّدًا ، فَعَلَیْہِ دَمٌ ، وَقَالَ : یَرْمِی مِنَ الْغَدِ۔",,,13610,,
13611,"حدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ ، وَحَمَّادًا عَنْ رَجُلٍ نَسِیَ حَصَاۃً ، أَوْ حَصَاتَیْنِ ، أَوْ جَمْرَۃً ، أَوْ جَمْرَتَیْنِ ؟ قَالاَ : یُہْرِیقُ دَمًا۔",,,13611,,
13612,"حدَّثَنَا أَبُو أُسَامَۃَ، عَنْ أَشْعَثَ، عَنِ الْحَسَنِ؛ فِی الرَّجُلِ یَتْرُکُ رَمْیَ جَمْرَۃٍ وَاحِدَۃٍ ، قَالَ: یُطْعِمُ مِسْکِینًا۔",,,13612,,
13613,"حدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ عُمَرَ بْنِ عَامِرٍ ، عَنْ قَتَادَۃَ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ قَالَ : مَا أُبَالِی رَمَیْتُ الْجِمَارَ بِسِتٍّ ، أَوْ سَبْعٍ۔وَقَالَ ابْنُ عَبَّاسٍ : رَمَیْنَا فِی الْجَاہِلِیَّۃِ بِسَبْعٍ ، وَفِی الإِسْلاَمِ بِسَبْعٍ۔",,,13613,,
13614,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ زِیَادِ بْنِ سَعْدٍ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ؛ فِیمَنْ رَمَی سِتًّا ، قَالَ طَاوُوسٌ: یَتَصَدَّقُ بِشَیْئٍ۔",,,13614,,
13615,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ زِیَادِ بْنِ سَعْدٍ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، قَالَ : لَیْسَ عَلَیْہِ شَیْئٌ۔",,,13615,,
13616,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، قَالَ : سَأَلْتُ عَطَائً عَنْ رَجُلٍ رَمَی بِخَمْسِ حَصَیَاتٍ ؟ قَالَ : یَرْمِی بِمَا بَقِیَ ، إِلاَّ أَنْ تَکُونَ ذَہَبَتْ أَیَّامُ التَّشْرِیقِ ، فإِن کَانَ ذَہَبَتْ أَیَّامُ التَّشْرِیقِ أَہْرَاقَ لِذَلِکَ دَمًا۔",,,13616,,
13617,"حدَّثَنَا غُنْدَرٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یَرْمِی الْجِمَارَ بِسِتٍّ ، قَالَ : یَسْتَأْنِفُ۔",,,13617,,
13618,حدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنِ ابْنِ الأَسْوَدِ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یَکْرَہُ أَنْ یَرْمِیَ بِحَصَی قَدْ رُمِیَ بِہِ۔,,,13618,,
13619,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : ارْمِ إِنْ شِئْتَ بِمَا رُمِیَ بِہِ مَرَّۃً۔",,,13619,,
13620,"حدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ عُمَرَ بْنِ عَامِرٍ ، عَنْ قَتَادَۃَ ، قَالَ : کَانَ یَکْرَہُ ، أَوْ یُکْرَہُ ، أَنْ یَرْمِیَ بِحَصَی بِالْجِمَارِ الَّذِی قَدْ رُمِیَ بِہِ۔",,,13620,,
13621,"حدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : قُلْتُ : سَقَطَتْ حَصَاۃٌ ، أَوْ حَصَیَاتٌ ؟ قَالَ : خُذْہَا مِنْ تَحْتِ رِجْلَیْک۔",,,13621,,
13622,"حدَّثَنَا مَحْبُوبٌ الْقَوَارِیرِیُّ ، عَنْ عَبْدِ اللہِ بْنِ عَامِرٍ الأَسْلَمِیِّ ، عنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : لَمَّا بَلَغْنَا وَادِیَ مُحَسِّرٍ ، قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : خُذُوا حَصَی الْجِمَارِ مِنْ وَادِی مُحَسِّرٍ۔",,,13622,,
13623,"حدَّثَنَا ابْنُ فُضَیْلٍ، عَنْ عَطَائِ بْنِ السَّائِبِ، عَنْ مُجَاہِدٍ، قَالَ: کَانَ یُحْمَلُ الْحَصَی مِنَ الْمُزْدَلِفَۃِ لِرَمْیِ الْجِمَارِ۔",,,13623,,
13624,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ إسْمَاعِیلَ بْنِ عَبْدِ الْمَلِکِ ، قَالَ : قَالَ لَنَا سَعِیدُ بْنُ جُبَیْرٍ : خُذُوا الْحَصَی مِنْ حَیْثُ شِئْتُمْ۔",,,13624,,
13625,"حدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنْ مُحَمَّدٍ ، قَالَ : الَّذِی یَرْمِی یَأْخُذُ الْحَصَی مِنْ جَمْعٍ۔",,,13625,,
13626,"حدَّثَنَا وَکِیعٌ ، عَنْ سَعِیدِ بْنِ عَبْدِ الْعَزِیزِ ، عَنْ مَکْحُولٍ ، قَالَ : خُذْہُ مِنَ الْمُزْدَلِفَۃِ۔",,,13626,,
13627,حدَّثَنَا ابْنُ مَہْدِیٍّ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ، عَنْ حُمَیْدٍ، عَنْ بَکْرٍ؛ أَنَّہُ کَانَ یَحْمِلُ حَصَی الْجِمَارِ مِنَ الْمُزْدَلِفَۃِ۔,,,13627,,
13628,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : خُذْہُ مِنْ حَیْثُ شِئْتَ۔",,,13628,,
13629,حدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ أَفْلَحَ ، عَنِ الْقَاسِمِ ؛ أَنَّہُ کَانَ یَأْخُذُ حَصَی الْجِمَارِ مِنَ الْمُزْدَلِفَۃِ۔,,,13629,,
13630,"حدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، قَالَ : کُنَّا نَلْتَقِطُ لِلأَسْوَدِ حَصَی وَنَحْنُ مُنْطَلِقُونَ إلَی عَرَفَاتٍ۔",,,13630,,
13631,"حدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، عَنْ أَبِیہِ ، قَالَ : أَفَضْتُ مَعَ عَبْدِ اللہِ ، فَلَمَّا انْتَہَیْنَا إلَی الْجَمْرَۃِ ، قَالَ : اُلْقُطْ لِی ، فَنَاوَلْتُہُ سَبْعَ حَصَیَاتٍ۔",,,13631,,
13632,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : خُذْ حَصَی الْجِمَارِ مِنْ حَیْثُ شِئْتَ۔",,,13632,,
13633,"حدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ عَوْفٍ ، عَنْ زِیَادِ بْنِ الْحُصَیْنِ، قَالَ: حدَّثَنَا أَبُو الْعَالِیَۃِ ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: قَالَ لِی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ غَدَاۃَ الْعَقَبَۃِ : اُلْقُطْ لِی حَصَیَاتٍ ، قَالَ : فَلَقَطْتُ لَہُ حَصَیَاتٍ مِثْلَ حَصَی الْخَذْفِ ، فَقَالَ : بِمِثْلِ ہَؤُلاَئِ فَارْمُوا۔ (نسائی 4065۔ احمد 1/347)",,,13633,,
13634,"حدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُلَبِّی فَیَقُولُ : لَبَّیْکَ اللَّہُمَّ لَبَّیْکَ ، لَبَّیْکَ لاَ شَرِیکَ لَکَ لَبَّیْکَ ، إِنَّ الْحَمْدَ وَالنِّعْمَۃَ لَکَ وَالْمُلْکَ ، لاَ شَرِیکَ لَکَ۔ (بخاری 1549۔ ابوداؤد 1808)",,,13634,,
13635,حدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ عُبَیْدِ اللہِ ، وَیَحْیَی بْنِ سَعِیدٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، مِثْلَہُ۔ (مسلم 842),,,13635,,
13636,"حدَّثَنَا حَفْصٌ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ جَابِرٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَہَلَّ بِالتَّوْحِیدِ : لَبَّیْکَ اللَّہُمَّ لَبَّیْکَ ، لَبَّیْکَ لاَ شَرِیکَ لَکَ لَبَّیْکَ ، إنَّ الْحَمْدَ وَالنِّعْمَۃَ لَکَ وَالْمُلْکَ ، لاَ شَرِیکَ لَک۔",,,13636,,
13637,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، وَابْنُ نُمَیْرٍ ، عَنِ الأَعْمَشِ ، عَنْ عُمَارَۃَ ، عَنْ أَبِی عَطِیَّۃَ ، عَنْ عَائِشَۃَ ، قَالَتْ: حفِظْت مِنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَمَا کَانَ یُلَبِّی : لَبَّیْکَ اللَّہُمَّ لَبَّیْکَ ، لَبَّیْکَ لاَ شَرِیکَ لَکَ لَبَّیْکَ ، إنَّ الْحَمْدَ وَالنِّعْمَۃَ لَکَ۔ (بخاری 1550۔ احمد 6/230)",,,13637,,
13638,"حدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ زُہَیْرٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الضَّحَّاکِ ، عَنِ ابْنِ عَبَّاسٍ ؛ فِی التَّلْبِیَۃِ بِمِثْلِ ہَذَا ، یَعْنِی مِثْلَ قَوْلِ جَابِرٍ عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : انْتَہِ إِلَیْہَا ، فَإِنَّہَا تَلْبِیَۃُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,13638,,
13639,"حدَّثَنَا یُونُسُ بْنُ مُحَمَّدٍ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ زَیْدٍ ، عَنْ أَبَانَ بْنِ تَغْلِبَ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ عَبْدِ الرَّحْمَنِ بن یزید قَالَ : کَانَ عَبْدُ اللہِ یَقُولُ فِی تَلْبِیَتِہِ : لَبَّیْکَ اللَّہُمَّ لَبَّیْکَ ، لَبَّیْکَ لاَ شَرِیکَ لَکَ لَبَّیْکَ ، إنَّ الْحَمْدَ وَالنِّعْمَۃَ لَکَ وَالْمُلْکَ ، وَیَقُولُ ہَکَذَا کَانَتْ تَلْبِیَۃُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔\n\n(مسلم 270۔ احمد 1/410)",,,13639,,
13640,"حدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی سَلَمَۃَ ، قَالَ : سَمِعَ سَعْدُ بْنُ أَبِی وَقَّاصٍ رَجُلاً یَقُولُ : لَبَّیْکَ ذَا الْمَعَارِجِ ، فَقَالَ : سَعْدٌ : لَبَّیْکَ ذَا الْمَعَارِجِ ، إِنَّہُ ذُو الْمَعَارِجِ ، وَلَمْ نَکُنْ نَقُولُ ہَذَا عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔ (احمد 1/172۔ ابویعلی 720)",,,13640,,
13641,"حدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ أَبِی سَلَمَۃَ ، عَنْ عَبْدِ اللہِ بْنِ الْفَضْلِ ، عَنِ الأَعْرَجِ ، عَنْ أَبِی ہُرَیْرَۃَ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ فِی تَلْبِیَتِہِ : لَبَّیْکَ إلَہَ الْحَقِ لَبَّیْکَ۔ \n\n(احمد 2/776۔ طیالسی 2377)",,,13641,,
13642,"حدَّثَنَا أَبُو خَالِدٍ ، عَنِ الأَعْمَشِ ، عَنْ عُمَارَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، قَالَ : کَانَ عَبْدُ اللہِ یُعَلِّمُنَا ہَذِہِ التَّلْبِیَۃَ : لَبَّیْکَ اللَّہُمَّ لَبَّیْکَ ، لَبَّیْکَ لاَ شَرِیکَ لَکَ لَبَّیْکَ ، إنَّ الْحَمْدَ وَالنِّعْمَۃَ لَکَ۔",,,13642,,
13643,"حدَّثَنَا أَبُو خَالِدٍ ، عَنِ الأَعْمَشِ ، عَنْ خَیْثَمَۃَ ، قَالَ : کَانُوا یَقُولُونَ ہَذِہِ الثَّلاَث ، قَالَ : وَکَانَ الأَسْوَدُ یَقُولُہَا ، وَیَزِیدُ : وَالْمُلْکَ ، لاَشَرِیک لَک۔",,,13643,,
13644,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، قَالَ : أَفَاضَ عُمَرُ عَشِیَّۃَ یَوْمِ عَرَفَۃَ عَلَی جَمَلٍ أَحْمَرَ ، وَقَدْ قَصُرَ رَأْسُ رَاحِلَتِہِ حَتَّی کَادَتْ تُصِیبُ وَاسِطَۃَ الرَّحْلِ ، قَالَ : وَہُوَ یُلَبِّی بِثَلاَثٍ ؛ لَبَّیْکَ اللَّہُمَّ لَبَّیْکَ ، لَبَّیْکَ لاَشَرِیکَ لَکَ لَبَّیْکَ ، إِنَّ الْحَمْدَ وَالنِّعْمَۃَ لَکَ ، وَکَانَ یَسِیرُ الْعَنَقَ ، وَإِذَا مَرَّ بِحَبْلٍ مِنَ الْحِبَالِ رَفَعَ یَدَیْہِ فَکَبَّرَ۔",,,13644,,
13645,"حدَّثَنَا عَبْدَۃُ ، وَأَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، عَنِ الْمِسْوَرِ بْنِ مَخْرَمَۃَ ، قَالَ : کَانَتْ تَلْبِیَۃُ عُمَرَ : لَبَّیْکَ اللَّہُمَّ لَبَّیْکَ ، لَبَّیْکَ لاَشَرِیکَ لَکَ لَبَّیْکَ ، إِنَّ الْحَمْدَ وَالنِّعْمَۃَ لَکَ وَالْمُلْکَ ، لاَشَرِیکَ لَکَ لَبَّیْکَ، مَرْغُوبًا ، وَمَرْہُوبًا إِلَیْکَ ، لَبَّیْکَ ذَا النَّعْمَائِ وَالْفَضْلِ الْحَسَنِ۔\n\nقَالَ عَبْدَۃُ : قَالَ ہِشَامٌ : یُبْدِئُ ذَلِکَ وَیُعِیدُہُ۔\n\nزَادَ أَبُو خَالِدٍ الأحمر : قَالَ : وَکَانَ أَبِی - یَعْنِی ہِشَامًا عَنْ أَبِیہِ - یُلَبِّی کَذَلِکَ إِلاَّ أَنَّ أَبَا خَالِدٍ لَمْ یَقُلْ : یُبْدِئُ ذَلِکَ وَیُعِیدُہُ۔",,,13645,,
13646,"حدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، قَالَ : کَانَ ابْنُ عُمَرَ یَزِیدُ مِنْ عِنْدِہِ : لَبَّیْکَ وَالرَّغْبَائُ إلَیْک وَالْعَمَلُ ، لَبَّیْکَ۔",,,13646,,
13647,"حدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ یَحْیَی ، وَعُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : تَلَقَّفْتُہُنََّ مِنْ فِی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: لَبَّیْکَ اللَّہُمَّ لَبَّیْکَ، لَبَّیْکَ لاَ شَرِیکَ لَکَ لَبَّیْکَ ، إِنَّ الْحَمْدَ وَالنِّعْمَۃَ لَکَ وَالْمُلْکَ، لاَشَرِیکَ لَکَ ، قَالَ : وَکَانَ ابْنُ عُمَرَ یَزِیدُ : وَالرَّغْبَائُ إلَیْکَ وَالْعَمَلُ ، لَبَّیْکَ وَسَعْدَیْکَ۔",,,13647,,
13648,"حدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عَنْ عَائِشَۃَ ، قَالَتْ : لَکَأَنِّی أَنْظُرُ إلَی وَبِیصِ الطِّیبِ مِنْ رَأْسِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَہُوَ محرم۔ (بخاری 271۔ مسلم 847)",,,13648,,
13649,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عَنْ عَائِشَۃَ ، قَالَتْ : کَأَنِّی أَنْظُرُ إلَی وَبِیصِ الطِّیبِ فِی مَفَارِقِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَہُوَ یُہِلُّ۔ (مسلم 848)",,,13649,,
13650,حدَّثَنَا شَرِیکٌ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الأَسْوَدِ ، عَنْ عَائِشَۃَ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَتَطَیَّبُ قَبْلَ أَنْ یُحْرِمَ ، فَیُرَی أَثَرُ الطِّیبِ فِی مَفْرِقِہِ بَعْدَ ذَلِکَ بِثَلاَثٍ۔ (نسائی 3683۔ ابن ماجہ 2928),,,13650,,
13651,حدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الأَسْوَدِ ، عَنْ عَائِشَۃَ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ إذَا أَرَادَ أَنْ یُحْرِمَ ادَّہَنَ بِأَطْیَبِ دُہْنٍ یَجِدُہُ، حَتَّی أَرَی وَبِیصَہُ فِی لِحْیَتِہِ وَرَأْسِہِ۔ (نسائی 3680),,,13651,,
13652,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عُثْمَانَ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، قَالَ : سَأَلْتُ عَائِشَۃَ : بِأَیِّ شَیْئٍ طَیَّبْتِ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ قَالَتْ : بِأَطْیَبِ الطِّیبِ ، وَقَالَتْ : عِنْدَ إِحْلاَلِہِ قَبْلَ أَنْ یُحْرِمَ۔\n\n(بخاری 5930۔ مسلم 37)",,,13652,,
13653,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عَنْ عَائِشَۃَ قَالَتْ : رَأَیْتُ بَصِیصَ الطِّیبِ فِی مَفَارِقِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَعْدَ ثَلاَثٍ ، وَہُوَ مُحْرِمٌ۔ (نسائی 3682)",,,13653,,
13654,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ؛ بَسَطَتْ یَدَیْہَا وَقَالَتْ : طَیَّبْتُہُ بِیَدَیَّ ہَاتَیْنِ مُحْرَمہ حِینَ أَحْرَمَ ، وَمَحِلَّہ قَبْلَ أَنْ یَطُوفَ بِالْبَیْتِ۔ (بخاری 1539۔ ترمذی 917)",,,13654,,
13655,حدَّثَنَا شَرِیکٌ ، عَنْ عَمَّارٍ ، عَنْ مُسْلِمٍ الْبَطِینِ ؛ أَنَّ الْحُسَیْنَ بْنَ عَلِیٍّ کَانَ إذَا أَحْرَمَ ادَّہَنَ بِالزَّیْتِ ، وَدَہَنَ أَصْحَابَہُ بِالطِّیبِ أوْ بِدُہْنِ الطِّیبَ۔,,,13655,,
13656,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہَاشِمِ بْنِ ہَاشِمٍ ، عَنْ عَائِشَۃَ ابْنَۃِ سَعْدٍ ، قَالَتْ : کَانَ سَعْدٌ یَتَطَیَّبُ عِنْدَ الإِحْرَامِ بِالذَّرِیرَۃِ۔",,,13656,,
13657,"حدَّثَنَا وَکِیعٌ ، عَنْ مُحَمَّدِ بْنِ قَیْسٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : کَانَ عَبْدُ اللہِ بْنُ جَعْفَرٍ یَمُوثُ الْمِسْکَ ، ثُمَّ یَجْعَلُہُ عَلَی یَافُوخِہِ قَبْلَ أَنْ یُحْرِمَ۔",,,13657,,
13658,حدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ صَالِحٍ ، عَنْ کَثِیرِ بْنِ سَامٍ ، عَنِ ابْنِ الْحَنَفِیَّۃِ ؛ أَنَّہُ کَانَ یُغَلِّفُ رَأْسَہُ بِالْغَالِیَۃِ الْجَیِّدَۃِ ، إِذَا أَرَادَ أَنْ یُحْرِمَ۔,,,13658,,
13659,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ أُسَامَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، عَنْ أُمِّہِ قَالَتْ : رَأَیْتُ عَائِشَۃَ تَنْکُتُ فِی مَفَارِقِہَا الطیِّبَ قَبْلَ أَنْ تُحْرِمَ ، ثُمَّ تُحْرِمُ۔",,,13659,,
13660,حدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنْ مُسْلِمِ بْنِ أَبِی مَرْیَمَ ، عْن عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، أَنَّہُ کَانَ یَدَّہِنُ بِالسَّلِیخَۃِ عِنْدَ الإِحْرَامِ۔,,,13660,,
13661,"حدَّثَنَا حَمَّادُ بْنُ مَسْعَدَۃَ ، عَنْ عِیسَی بْنِ حَفْصٍ ، عَنْ عُثْمَانَ بْنِ عُرْوَۃَ ، قَالَ : کَانَ عُرْوَۃُ یُجَمِّرُ ثِیَابَہُ عِشائً ، فَلاَ یَزَالُ حَتَّی یَرُوحَ فِیہَا الْمَسْجِدَ وَیُحْرِمَ فِیہَا ، قَالَ : وَکَانَ یَرَی لِحَانَا تَقْطُرُ مِنَ الْغَالِیَۃِ وَنَحْنُ مُحْرِمُونَ ، فَلاَ یُنْکِرُ ذَلِکَ عَلَیْنَا۔",,,13661,,
13662,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی الضُّحَی ، قَالَ : رَأَیْتُ عَبْدَ اللہِ بْنَ الزُّبَیْرِ وَفِی رَأْسِہِ وَلِحْیَتِہِ مِنَ الطِّیبِ وَہُوَ مُحْرِمٌ ، مَا لَوْ کَانَ لِرَجُلٍ لاَتَّخَذَ مِنْہُ رَأْسَ مَالٍ۔",,,13662,,
13663,حدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ؛ أَنَّ ابْنَ الزُّبَیْرِ کَانَ یَدَّہِنُ عِنْدَ إحْرَامِہِ بِالْغَالِیَۃِ الْجَیِّدَۃِ۔,,,13663,,
13664,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، قَالَ : کَانَ أَبِی یَتَطَیَّبُ عِنْدَ الإِحْرَامِ بِالذَّرِیرَۃِ وَالْبَانِ۔",,,13664,,
13665,حدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ؛ أَنَّ ابْنَ عَبَّاسٍ کَانَ لاَ یَرَی بَأْسًا بِالطَّیِّبِ عِنْدَ إحْرَامِہِ، وَیَوْمَ النَّحْرِ قَبْلَ أَنْ یَزُورَ۔,,,13665,,
13666,"حدَّثَنَا وَکِیعٌ ، عَنْ عُیَیْنَۃَ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِیہِ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إنِّی لأصَغْصِغُہُ فِی رَأْسِی قَبْلَ أَنْ أُحْرِمَ، وَأَحَبَّ بَقَائَہُ ، وَقَالَ ابْنُ الزُّبَیْرِ: لاَ أَرَی بِہِ بَأْسًا ، وَقَالَ ابْنُ عُمَرَ : لاَ آمُرُ بِہِ ، وَلاَ أَنْہَی عَنْہُ۔",,,13666,,
13667,"حدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : یدَّہنُ الرَّجُلُ بِکُلِّ شَیْئٍ عِنْدَ الإِحْرَامِ ، إِلاَّ الْمُؤَنَّثَ ، الْمُؤَنَّث السَّاہِرَیۃُ وَالْمَلاَبُ۔",,,13667,,
13668,"حدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ أَبِی الضُّحَی ، عَنْ مَسْرُوقٍ ، عَنْ عَائِشَۃَ ، قَالَتْ : کَأَنِّی أَنْظُرُ إلَی وَبِیصِ الطِّیبِ فِی مَفَارِقِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَہُوَ یُلَبِّی۔ (مسلم 41۔ احمد 207)",,,13668,,
13669,"حدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، قَالَتْ : کُنْتُ أُطَیِّبُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عِنْدَ إحْرَامِہِ ، بِأَطْیَبِ مَا أَجِدُ۔ (احمد 6/207۔ ابن حبان 3772)",,,13669,,
13670,"حدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ عَمْرٍو ، عَنْ أَبِیہِ ، عَنْ عَلْقَمَۃَ ، عَنْ عَائِشَۃَ ، قَالَتْ : طَیَّبْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لِحرمہِ حِینَ أَحْرَمَ ، وَلِحِلِّہِ حِینَ حَلَّ ، قَبْلَ أَنْ یَطُوفَ بِالْبَیْتِ۔",,,13670,,
13671,حدَّثَنَا أَبُو أُسَامَۃَ ، وَوَکِیعٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنِ ابْنِ الزُّبَیْرِ ؛ أَنَّہُ کَانَ یَتَطَیَّبُ بِالْغَالِیَۃِ الْجَیِّدَۃِ عِنْدَ إحْرَامِہِ۔,,,13671,,
13672,حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، أَنَّ عَلْقَمَۃَ ، وَالأَسْوَدَ کَانَا یَحُجَّانِ مَعَ عَبْدِ اللہِ بْنِ الْحَارِثِ أَخِی الأَشْتَرِ ، فَکَانَ یَکْفِیہِمْ نَفَقَتَہُمْ۔,,,13672,,
13673,"حدَّثَنَا الْبَکْرَاوِیُّ ، عَنْ إسْمَاعِیلَ ، قَالَ : حدَّثَنَا مُحَمَّدٌ ، قَالَ : کَانَ أَصْحَابُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَحُجُّ بَعْضُہُمْ بِبَعْضٍ ، فَیُجْزِئُ ذَلِکَ عَنْہُمْ۔",,,13673,,
13674,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، عَنْ أَسْلَمَ مَوْلَی عُمَرَ ؛ أَنَّ عُمَرَ وَجَدَ رِیحَ طِیبٍ وَہُوَ بِذِی الْحُلَیْفَۃِ ، فَقَالَ : مِمَّنْ ہَذَا ؟ فَقَالَ مُعَاوِیَۃُ : مِنِّی ، فَقَالَ : أَمِنْکَ لَعَمْرِی ؟ قَالَ : یَا أَمِیرَ الْمُؤْمِنِینَ ، لاَ تَعْجَلْ عَلَیَّ ، فَإِنَّ أُمَّ حَبِیبَۃَ طَیَّبَتْنِی وَأَقْسَمَتْ عَلَیَّ ، قَالَ : وَأَنَا أُقْسِمُ عَلَیْک لَتَرْجِعَنَّ إلَیْہَا ، فَلْتَغْسِلَنَّہُ عَنْکَ کَمَا طَیَّبَتْکَ ، قَالَ : فَرَجَعَ إلَیْہَا حَتَّی لَحِقَہُمْ بِبَعْضِ الطَّرِیقِ۔",,,13674,,
13675,حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنِ الزُّہْرِیِّ ؛ أَنَّ عُمَرَ دَعَا بِثَوْبٍ ، فَأُتِیَ بِثَوْبٍ فِیہِ رِیحُ طِیْبٍ فَرَدَّہُ۔,,,13675,,
13676,حدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ سَعْدِ بْنِ إِبْرَاہِیمَ ، عَن أَبِیہِ ؛ أَنَّ إبْرَاہِیمَ رَأَی رَجُلاً قَدْ تَطَیَّبَ عِنْدَ الإِحْرَامِ ، فَأَمَرَہُ أَنْ یَغْسِلَ رَأْسَہُ بِطِینٍ۔,,,13676,,
13677,"حدَّثَنَا وَکِیعٌ ، عَنْ عُیَیْنَۃَ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِیہِ ، قَالَ : حجَجْتُ مَرَّۃً فَوَافَقْتُ عَبْدَ الرَّحْمَن بْنَ عَمْرِو بْنَ الْعَاصِ ، فَلَمَّا کَانَ عِنْدَ الإِحْرَامِ أَصَبْنَا شَیْئًا مِنَ الطِّیبِ ، فَقَالَ لِی عَبْدُ الرَّحْمَنِ : وَدِدْتُ أَنَّکَ لَمْ تَفْعَلْ ، إنِّی حَجَجْتُ مَرَّۃً مَعَ عُثْمَانَ بْنِ أَبِی الْعَاصِ فَأَحْرَمَ مِنَ المَنْجَشانیۃ ، وَہِیَ قَرِیبَۃٌ مِنَ الْبَصْرَۃِ ، وَقَالَ لَنَا : عَلَیْکُمْ بِہَذَا الطِّینِ الأَبْیَضِ ، فَاغْسِلُوا بِہِ رُؤُوسَکُمْ عِنْدَ الإِحْرَامِ۔",,,13677,,
13678,حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنْ مُحَمَّدٍ ؛ أَنَّہُ کَانَ یَکْرَہُ أَنْ یَتَطَیَّبَ الرَّجُلُ عِنْدَ إحْرَامِہِ۔,,,13678,,
13679,حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ مِثْلَ ذَلِکَ ، وَیُحِبُّ أَنْ یَجِیئَ أَشْعَثَ أَغْبَرَ۔,,,13679,,
13680,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ الْقَطَّانُ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ أَنَّہُ کَرِہَ الطِّیبَ عِنْدَ الإِحْرَامِ ، وَقَالَ : إِنْ کَانَ بِہِ شَیْئٌ مِنْہُ فَلْیَغْسِلْہُ وَلِیُنْقِہِ۔",,,13680,,
13681,حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ بُرْدٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ إذَا أَرَادَ أَنْ یُحْرِمَ تَرَکَ إجْمَارَ ثِیَابِہِ قَبْلَ ذَلِکَ بِخَمْسۃَ عَشَرَ۔,,,13681,,
13682,حدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ أَنَّہُ کَانَ یَکْرَہُ لِلْمُحْرِمِ حِینَ یُحْرِمُ أَنْ یَدَّہِنَ بِدُہْنٍ فِیہِ مِسْکٌ ، أَوْ أَفْوَاہٌ ، أَوْ عَبِیرٍ۔,,,13682,,
13683,حدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ عَبْدِ الْمَلِکِ ، أَنَّ سَعِیدَ بْنَ جُبَیْرٍ کَانَ یَتَّقِی الطِّیبَ إذَا أَرَادَ أَنْ یُحْرِمَ۔,,,13683,,
13684,"حدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مِسْعَرٌ ، عَنْ وَبَرَۃَ ، عَنِ ابْنِ عُمَرَ ، قَالَ : وَجَدَ عُمَرُ بْنُ الْخَطَّابِ رِیحًا عِنْدَ الإِحْرَامِ ، فَتَوَعَّدَ صَاحِبَہَا ، فَرَجَعَ مُعَاوِیَۃُ فَأَلْقَی مِلْحَفَۃً کَانَتْ عَلَیْہِ ، یَعْنِی مُطَیَّبَۃً۔",,,13684,,
13685,"حدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مِسْعَرٌ ، وَسُفْیَانُ ، عَنْ إبْرَاہِیمَ بْنِ مُحَمَّدِ بْنِ الْمُنْتَشِرِ ، عَنْ أَبِیہِ ، قَالَ : سَمِعْتُ ابْنَ عُمَرَ یَقُولُ : لأَنْ أُصْبِحَ ، یَعْنِی مَطْلِیًا بِقَطِرَانٍ أَحَبَّ إلَیَّ مِنْ أَنْ أُصْبِحَ مُحْرِمًا ، أَنْضَخُ طِیبًا۔",,,13685,,
13686,"حدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ قَیْسٍ ، عَنْ بُشَیْرِ بْنِ یَسَارٍ الأَنْصَارِیِّ ، قَالَ : لَمَّا أَحْرَمُوا وَجَدَ عُمَرُ رِیحَ طِیبٍ ، فَقَالَ : مِمَّنْ ہَذَہِ الرِّیحُ ؟ فَقَالَ الْبَرَائُ بْنُ عَازِبٍ : مِنِّی ، یَا أَمِیرَ الْمُؤْمِنِینَ ، قَالَ : قَدْ عَلِمْنَا أَنَّ امْرَأَتَکَ عَطِرَۃٌ ، أَوْ عَطَّارَۃٌ ، إِنَّمَا الْحَاجُّ الأَذْفَرُ الأَغْبَرُ۔",,,13686,,
13687,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ حَجَّاجٍ ، قَالَ : سَأَلْتُ عَطَائً عَنِ الرَّجُلِ یُصِیبُہُ مِنْ طِیبِ الْکَعْبَۃِ ؟ فَقَالَ : لاَ یَضُرُّہُ۔",,,13687,,
13688,"حدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ صَالِحِ بْنِ حَیَّانَ ، قَالَ : رَأَیْتُ أَنَسَ بْنَ مَالِکٍ أَصَابَ ثَوْبَہُ مِنْ خَلُوقِ الْکَعْبَۃِ وَہُوَ مُحْرِمٌ ، فَلَمْ یَغْسِلْہُ۔",,,13688,,
13689,"حدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ خَارِجًا مِنَ الْکَعْبَۃِ ، وَقَدْ تَلَطَّخَ صَدْرُہُ مِنْ طِیبِہَا۔",,,13689,,
13690,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، قَالَ : رَأَیْتُ فِی ثَوْبِ عَمْرِو بْنِ شُعَیْبٍ رَدْعًا مِنْ خَلُوقِ الْکَعْبَۃِ ، فَقُلْتُ لَہُ : مَا ہَذَا فِی ثَوْبِکَ وَأَنْتَ مُحْرِمٌ ؟ فَقَالَ : إنَّ ہَذَا لاَ یُکْرَہُ ہَاہُنَا ، إنَّمَا سُمِّیَتْ بَکَّۃُ لأَنَّ النَّاسَ یَتَبَاکَّوْنَ بِہَا۔",,,13690,,
13691,"حدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، وَوَکِیعٌ ، عَنْ طَلْحَۃَ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ یَدْخُلُ مَکَّۃَ أَحَدٌ بِغَیْرِ إحْرَامٍ ، إِِلاَّ الْحَطَّابُونَ وَالعَمَّالونَ وَأَصْحَابُ مَنَافِعِہَا۔",,,13691,,
13692,"حدَّثَنَا وَکِیعٌ، عَنْ إسْرَائِیلَ، عَنْ ثَوْرٍ، عَنْ أَبِی جَعْفَرٍ، عَنْ عَلِیٍّ، قَالَ: لاَ تَدْخُلُہَا إِلاَّ بِإِحْرَامٍ، یَعْنِی مَکَّۃَ۔",,,13692,,
13693,حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَکْرَہُ أَنْ یَدْخُلَ مَکَّۃَ بِغَیْرِ إحْرَامٍ۔,,,13693,,
13694,"حدَّثَنَا غُنْدَرٌ، عَنْ شُعْبَۃَ، عَنْ مُغِیرَۃَ، عَنْ إبْرَاہِیمَ، قَالَ: کَانُوا یُحِبُّونَ أَنْ لاَ یَدْخُلُوا مَکَّۃَ إِلاَّ مُحْرِمِینَ۔",,,13694,,
13695,"حدَّثَنَا حَفْصٌ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : لَیْسَ لأَحَدٍ أَنْ یَدْخُلَ مَکَّۃَ إِلاَّ بِإِحْرَامٍ ، وَکَانَ عَبْدُ الْمَلِکِ یُرَخِّصُ فِیہِ لِلْحَطَّابِینَ۔",,,13695,,
13696,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ ، وَحَمَّادًا عَنِ الرَّجُلِ یَدْخُلُ مَکَّۃَ بِغَیْرِ إحْرَامٍ ؟ فَکَرِہَہُ الْحَکَمُ ، وَلَمْ یَرَ بِہِ حَمَّادٌ بَأْسًا۔",,,13696,,
13697,حدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ ہِشَامِ بْنِ حُجَیرٍ ، عَنْ طَاوُوسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لَمْ یَدْخُلْ مَکَّۃَ قَطُّ إِلاَّ مُحْرِمًا ، إِلاَّ یَوْمَ فَتْحِ مَکَّۃَ۔,,,13697,,
13698,"حدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : لاَ تَدْخُلُ مَکَّۃَ إِلاَّ مُحْرِمًا۔",,,13698,,
13699,"حدَّثَنَا أَبُو عَامِرٍ الْعَقَدِیُّ ، عَنْ أَفْلَحَ ، عَنِ الْقَاسِمِ ، قَالَ : لاَ تَدْخُلُ مَکَّۃَ إِلاَّ مُحْرِمًا۔",,,13699,,
13700,حدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ أَقَامَ بِمَکَّۃَ ، ثُمَّ خَرَجَ یُرِیدُ الْمَدِینَۃَ ، حَتَّی إذَا کَانَ بِقَدِیدٍ بَلَغَہُ أَنَّ جَیْشًا مِنْ جُیُوشِ الْفِتْنَۃِ دَخَلُوا الْمَدِینَۃَ ، فَکَرِہَ أَنْ یَدْخُلَ عَلَیْہِمْ ، فَرَجَعَ إلَی مَکَّۃَ فَدَخَلَہَا بِغَیْرِ إحْرَامٍ۔,,,13700,,
13701,"حدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، قَالَ : خَرَجَ أَبِی ، وَعَمْرُو بْنُ دِینَارٍ إلَی أَرْضِہِمَا خَارِجًا مِنَ الْحَرَمِ ، ثُمَّ دَخَلاَ مَکَّۃَ بِغَیْرِ إحْرَامٍ۔",,,13701,,
13702,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ مَالِکِ بْنِ أَنَسٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : لاَ بَأْسَ بِہِ۔",,,13702,,
13703,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : طَافَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی حَجَّتِہِ أُسْبُوعًا وَصَلَّی رَکْعَتَیْنِ ، وَکَذَلِکَ فَعَلَ فِی عُمَرِہِ ، قَالَ : فَإِنْ طَافَ رَجُلٌ فَلاَ أُحِبُّ أَنْ یَزِیدَ عَلَی رَکْعَتَیْنِ ، فَإِنْ زَادَ فَلاَ بَأْسَ بِہِ ، وَإِنْ وَجَدَ الْکَعْبَۃَ مَفْتُوحَۃً فَلاَ یَدْخُلُہَا حَتَّی یَطُوفَ بَیْنَ الصَّفَا وَالْمَرْوَۃِ۔",,,13703,,
13704,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : حدَّثَنَا سَلیْم بْنُ حَیَّانَ ، قَالَ : حدَّثَنَا مُوسَی بْنُ قَطَنٍ ، عَنْ مَیَّۃَ بِنْتِ مُحْرِزٍ ، قَالَتْ : سَمِعْت عُمَرَ بْنَ الْخَطَّابِ یَقُولُ : أَحِجُّوا ہَذِہِ الذُّرِّیَّۃَ ، وَلاَ تَأْکُلُوا أَرْزَاقَہَا ، وَتَدَعُوا أَرْبَاقِہَا فِی أَعْنَاقِہَا۔",,,13704,,
13705,"حدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، عَنْ عَطَائٍ ، قَالَ : لَیْسَ عَلَی الرَّجُلِ أَنْ یَحُجَّ بِامْرَأَتِہِ إِلاَّ أَنْ یَشَائَ ۔ قَالَ الأَوْزَاعِیُّ : قَالَ یَحْیَی بْنُ أَبِی کَثِیرٍ : ہُوَ عَلَیْہِ إِنْ کَانَتْ لَمْ تَحُجَّ ، قَالَ مَکْحُولٌ : عَلَیْکُمْ إحْجَاجُ نِسَائِکُمْ۔",,,13705,,
13706,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُسْنِد فِی الصَّفَا وَالْمَرْوَۃِ ، یَقُومُ عِنْدَ الْمَرْوَۃِ الْبَیْضَائِ۔",,,13706,,
13707,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ أَبِیہِ ، قَالَ : أَخْبَرَنِی مَنْ رَأَی عُثْمَانَ بْنَ عَفَّانَ وَاقِفًا عِنْدَ الْحَوْضِ الأَسْفَلِ مِنَ الصَّفَا۔",,,13707,,
13708,حدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنِ ابْنِ سَابِطٍ ؛ أَنَّ عُمَرَ کَانَ یَجْعَلُ الْذی کَأَنَّہُ مَبْرَکُ بَعِیرٍ عَلَی فَخِذِہِ الأَیْمَنِ ، یَعْنِی فِی الْمَرْوَۃِ۔,,,13708,,
13709,حدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ؛ أَنَّ أَبَاہُ کَانَ یَقُومُ عِنْدَ الْمَرْوَۃِ عِنْدَ الْذی کَأَنَّہُ مَبْرَکُ بَعِیرٍ ، وَفِی الصَّفَا فِی الْمَکَانِ الْمُنْحَفِرِ۔,,,13709,,
13710,حدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عِکْرِمَۃَ ؛ أَنَّہُ کَانَ یَقُومُ دُونَ الْذی کَأَنَّہُ مَبْرَکُ بَعِیرٍ ، وَیَقُومُ مِنَ الصَّفَا أَسْفَلَ مِنَ الْمَکَانِ الْمُنْحَفِرِ۔,,,13710,,
13711,"حدَّثَنَا حُمَیْدِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ حُسَیْنِ بْنِ عُقَیْلٍ ، عَنِ الضَّحَّاکِ ، قَالَ : یَصْعَدُ عَلَی الصَّفَا حَتَّی یَنْظُرَ إلَی الْبَیْتِ۔",,,13711,,
13712,"حدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ رَبَاحِ بْنِ أَبِی مَعْرُوفٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ کَرِہَ قِیَامَ الرَّجُلِ عَلَی بَابِ الْمَسْجِدِ ، إِذَا أَرَادَ الانْصِرَافَ إلَی أَہْلِہِ مُنْحَرِفًا نَحْوَ الْکَعْبَۃِ ، یَنْظُرُ إلَیْہَا وَیَدْعُو ، وَقَالَ : الْیَہُودُ یَفْعَلُونَ ذَلِکَ۔",,,13712,,
13713,"حدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنْ مُجَاہِدٍ ، قَالَ : سَمِعْتُہُ وَرَأَی رَجُلاً یَلْتَفِتُ إلَی الْکَعْبَۃِ عِنْدَ بَابِ الْمَسْجِدِ فَنَہَاہُ ، وَقَالَ : الْیَہُودُ یَفْعَلُونَ ہَذَا۔",,,13713,,
13714,حدَّثَنَا وَکِیعٌ ، عَنِ الْعُمَرِیِّ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یُقَلِّدُ وَیُشْعِرُ بِذِی الْحُلَیْفَۃِ۔,,,13714,,
13715,"حدَّثَنَا أَبُو أُسَامَۃَ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ، قَالَ: کَانَ أَبِیٌّ یَقُولُ: إذَا أَہْدَی الرَّجُلُ ہَدْیًا أَشْعَرَہُ حَیْثُ یُحْرِمُ۔",,,13715,,
13716,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یُشْعِرُونَ یَوْمَ التَّرْوِیَۃِ ، وَقَبْلُ ذَلِکَ۔",,,13716,,
13717,حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنِ ابْنِ الأَسْوَدِ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یُشْعِرُ بَدَنَتَہُ بِعَرَفَۃَ۔,,,13717,,
13718,"حدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ، عَنْ زُہَیْرٍ، عَنْ جَابِرٍ، عَنْ أَبِی جَعْفَرٍ، قَالَ: أَحَبُّ إلَیَّ أَنْ أُشْعِرَ بِعَرَفَاتٍ۔",,,13718,,
13719,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، وَابْنِ الأَسْوَدِ ؛ أَنَّہُمَا قَالاَ : یُشْعِرُ ، ثُمَّ یُحْرِمُ",,,13719,,
13720,"حدَّثَنَا یَحْیَی بْنُ یَعْلَی ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنْ مُجَاہِدٍ ، قَالَ : لاَ یُشْعِرُ البُدْنَ حَتَّی یُحْرِمَ",,,13720,,
13721,"حدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ مُطَرِّفٍ ، عَنْ فُضَیْلٍ ، عن إبْرَاہِیمَ ، قَالَ : إذَا قَالَ : یَوْمَ یَفْعَلُ کَذَا وَکَذَا فَہُوَ مُحْرِمٌ بِحَجَّۃٍ ، قَالَ : إِنْ حَنِثَ فَہُوَ مُحْرِمٌ ، وَإِنْ قَالَ : إِنْ فَعَلْتُ کَذَا وَکَذَا فَأَنَا مُحْرِمٌ بِحَجَّۃٍ ، فَدَخَلَ شَوَّالٌ فَہُوَ مُحْرِمٌ",,,13721,,
13722,"حدَّثَنَا حَفْصٌ ، عَنْ مُجَالِدٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : إذَا قَالَ : إِنْ فَعَلْتُ کَذَا وَکَذَا فَأَنَا مُحْرِمٌ بِحَجَّۃٍ ، قَالَ: یَحُجُّ مَعَ النَّاسِ",,,13722,,
13723,حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی حَصِینٍ ، عَنِ الشَّعْبِیِّ ؛ نَحْوًا مِنْ حَدِیثِ مُجَالِدٍ۔,,,13723,,
13724,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحُکْمِ ؛ فِی الرَّجُلِ یَقُولُ : یَوْمَ یَفْعَلُ کَذَا وَکَذَا فَہُوَ یَوْمَئِذٍ مُحْرِمٌ بِحَجَّۃٍ ، فَإِنْ حَنِثَ فَہُوَ یَوْمَئِذٍ مُحْرِمٌ بِحَجَّۃٍ ، وَإِنْ قَالَ : إِنْ لَمْ أَفْعَلْ کَذَا وَکَذَا فَأَنَا مُحْرِمٌ بِحَجَّۃٍ ، قَالَ : إِذَا حَجَّ مَعَ النَّاسِ أَجْزَأَ عَنْہُ۔",,,13724,,
13725,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ قَالَ : تَکْفِیہ مَرَّۃً وَاحِدَۃً یَقُولُ : لَبَّیْکَ عَنْ فُلاَنٍ۔",,,13725,,
13726,حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنْ عَطَائٍ ؛ مِثْلَ ذَلِکَ۔,,,13726,,
13727,"حدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : کَانُوا یَرَوْنَ أَنَّ الْمَغْفِرَۃَ تَنْزِلُ عِنْدَ الدَّفْعَۃِ مِنْ عَرَفَۃَ۔",,,13727,,
13728,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَعَطَائٍ ؛ أَنَّہُمَا قَالاَ : إِذَا حَجَّ الرَّجُلُ عَنِ الرَّجُلِ فَنَسِیَ أَنْ یُسَمِّیَہُ ، فَقَدْ أَجْزَأَ عَنْہُ الْحَجُّ ، فَإِنَّ اللَّہَ تعالی قَدْ عَلِمَ عَمَّنْ حَجَّ۔",,,13728,,
13729,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَمَلَ فِی عُمْرَۃٍ ، وَأَبُو بَکْرٍ ، وَعُمَرَ ، وَعُثْمَانَ ، وَالْخُلَفَائُ کَذَلِکَ ، وَقَالَ عَطَائٌ : رَمَلَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی حَجَّتِہِ۔",,,13729,,
13730,"حدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، قَالَ : نُبِّئْت عَنِ الْقَاسِمِ ، وَسَالِمٍ أَنَّہُمَا کَانَا یَقُولاَنِ : أَہْلُ مَکَّۃَ إِذَا خَرَجُوا إلَی مِنًی قَصَرُوا ، قَالَ : وَکَانَ عَطَائٌ ، وَالزُّہْرِیُّ یَقُولاَنِ : یُتِمُّونَ۔",,,13730,,
13731,حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ إِسْمَاعِیلَ بْنِ أُمَیَّۃَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عمَرَ ؛ أَنَّہُ کَانَ یُقِیمُ بِمَکَّۃَ ، فَإِذَا خَرَجَ إلَی مِنًی قَصَرَ,,,13731,,
13732,"حدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ حَنْظَلَۃَ ، قَالَ : سَأَلْتُ الْقَاسِمَ عَنِ الصَّلاَۃِ مَعَ الإِمَامِ بِعَرَفَۃَ ؟ فَقَالَ : صَلِّ بِصَلاَتِہِ ، فَقُلْتُ : إِنِّی مَکِّیٌّ ، قَالَ : قَدْ عَرَفْتُ ، قَالَ : وَسَأَلْتُ سَالِمًا ، وَطَاوُسًا ، فَقَالاَ مِثْلَ ذَلِکَ",,,13732,,
13733,"حدَّثَنَا عُبَیْدُ اللہِ ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنْ مُجَاہِدٍ ، وَعَطَائٍ ؛ قَالاَ : لَیْسَ عَلَی أَہْلِ مَکَّۃَ قَصْرُ صَلاَۃٍ فِی الْحَجِّ",,,13733,,
13734,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ إِحْصَارَ إِلاَّ مَنْ حَبَسَہُ عَدُوٍّ ، قَالَ : وَقَالَ أَبِی : لَیْسَ الْیَوْمَ إحْصَارٌ۔",,,13734,,
13735,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ، عَنِ ابْنِ جُرَیْجٍ، عَنْ عَطَائٍ، قَالَ: لاَ إحْصَارَ إِلاَّ مِنْ مَرَضٍ، أَوْ عَدُوٍّ، أَوْ أَمْرٍ حَابِسٍ۔",,,13735,,
13736,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُوسَی بْنِ عُقْبَۃَ ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ: لاَ إحْصَارَ إِلاَّ مِنْ عَدُوٍّ۔",,,13736,,
13737,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، قَالَ : کُلُّ شَیْئٍ حَبَسَ الْمُحْرِمَ فَہُوَ إحْصَارٌ۔",,,13737,,
13738,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ابْنِ إِسْحَاقَ ، عَنِ الزُّہْرِیِّ قَالَ : لاَ إِحْصَارَ إِلاَّ مِنَ الحرب۔",,,13738,,
13739,"حدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ إِسْحَاقَ بْنِ سُوَیْد ، قَالَ : سَمِعْتُ ابْنَ الزُّبَیْرِ ، قَالَ : إنَّمَا التَّمَتُّعُ بِالْعُمْرَۃِ إلَی الْحَجِّ ، أَنْ یُہِلَّ الرَّجُلُ بِالْحَجِّ فَیَحْصُرُہُ إمَّا مَرَضٌ ، أَوْ عَدوٌ ، أَوْ أَمْرٌ یَحْبِسُہُ۔",,,13739,,
13740,حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ سَابِطٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَأَصْحَابَہُ کَانُوا یَعْقِلُونَ یَدَ الْبَدَنَۃِ الْیُسْرَی ، وَیَنْحَرُونَہَا قَائِمَۃً عَلَی مَا بَقِیَ مِنْ قَوَائِمِہَا۔ (ابوداؤد 1764),,,13740,,
13741,حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ، عَنْ حَجَّاجٍ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ؛ أَنَّہُ کَانَ یَنْحَرُہَا وَہِیَ مَعْقُولَۃٌ یَدُہَا الْیُمْنَی۔,,,13741,,
13742,"حدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : اِعْقِلْ أَیَّ الْیَدَیْنِ شِئْتَ۔",,,13742,,
13743,حدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ؛ أَنَّہُ کَانَ یَعْقِلُ الْیُسْرَی۔,,,13743,,
13744,"حدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ فِی الْبَدَنَۃِ کَیْفَ تُنْحَرُ ؟ قَالَ : تَعْقِلُ یَدَہَا الْیُسْرَی ، وَتَنْحرُہَا مِنْ قِبَلِ یَدِہَا الْیُمْنَی۔",,,13744,,
13745,حدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ مُجَاہِدٍ ؛ أَنَّہُ کَانَ یَعْقِلُ یَدَہَا الْیُسْرَی إذَا أَرَادَ أَنْ یَنْحَرَہَا۔,,,13745,,
13746,حدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ لاَ یَخْرُجُ مِنَ الْمَسْجِدِ حَتَّی یَسْتَلِمَ ، کَانَ فِی طَوَافٍ ، أَوْ فی غَیْرِ طَوَافٍ۔,,,13746,,
13747,"حدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ أبیہ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کُلَّمَا دَخَلْتَ الْمَسْجِدَ الْحَرَامَ طُفْتَ بِالْبَیْتِ ، أَوْ لَمْ تَطُفْ فَاسْتَلِمَ الْحَجَرَ حِینَ تُرِیدُ أَنْ تَخْرُجَ مِنَ الْمَسْجِدِ ، أَوِ اسْتَقْبِلْہُ فَکَبِّرْ وَادْعُ اللَّہَ۔",,,13747,,
13748,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی حَفْصَۃَ ، قَالَ : طُفْتُ مَعَ سَعِیدِ بْنِ جُبَیْرٍ فَکَانَ إِذَا مَرَّ بِالْحَجَرِ الْتَفَتَ إلَیْہِ ، وَلَمْ یَسْتَلِمْہُ۔",,,13748,,
13749,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ إبْرَاہِیمَ بْنِ نَافِعٍ ، قَالَ : طُفْتُ مَعَ طَاوُوسٍ فَرُبَّمَا لَمْ یَسْتَلِمْ شَیْئًا مِنَ الأَرْکَانِ ، حَتَّی یَنْصَرِفَ۔",,,13749,,
13750,حدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ سَعْدِ بْنِ إِبْرَاہِیمَ ، عَن أَبِیہِ ؛ أَنَّہُ کَانَ یَطُوفُ بِالْبَیْتِ ، وَلاَ یَسْتَلِمُ۔,,,13750,,
13751,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، وَیَزِیدُ ، عَنْ حُمَیْدٍ ، عَنْ أَنَسٍ ، قَالَ : رَأَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجُلاً یُہَادَی بَیْنَ رَجُلَیْنِ - وَقَالَ یَزِیدُ : بَیْنَ ابْنَیْہِ - فَقَالَ : مَا ہَذَا ؟ فَقَالُوا : نَذَرَ أَنْ یَمْشِیَ ، فَقَالَ : إِنَّ اللَّہَ عَزَّ وَجَلَّ عَنْ تَعْذِیبِ ہَذَا لَغَنِیٌّ ، مُرُوہُ فَلْیَرْکَبْ ۔ إِِلاَ أَنَّ یَزِیدَ قَالَ : عَنْ حُمَیْدٍ ، عَنْ ثَابِتٍ ، عَنْ أَنَسٍ۔\n\n(ترمذی 1537)",,,13751,,
13752,"حدَّثَنَا أَبُو خَالِدٍ ، وَابْنُ فُضَیْلٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عُبَیْدِ اللہِ بْنِ زَحْرٍ ، عَنْ أَبِی سَعِیدٍ الرُّعَیْنِیِّ ، عَنْ عَبْدِ اللہِ بْنِ مَالِکٍ ، عَنْ عُقْبَۃَ بْنِ عَامِرٍ الْجُہَنِیِّ ، قَالَ : نَذَرَتْ أُخْتِی أَنْ تَمْشِیَ إلَی بَیْتِ اللہِ حَافِیَۃً غَیْرَ مُخْتَمِرَۃٍ ، فَسَأَلْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ فَقَالَ : مُرْ أُخْتَکَ فَلْتَخْتَمِرْ وَلْتَرْکَبْ ، وَلْتَصُمْ ثَلاَثَۃَ أَیَّامٍ۔\n\n(ترمذی 1544۔ ابوداؤد 3286)",,,13752,,
13753,"حدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنْ عَلِیٍّ (ح) وَعَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، عَنْ عَلِیٍّ ، قَالَ : إِذَا جَعَلَ عَلَیْہِ الْمَشْیَ فَلَمْ یَسْتَطِعْ ، فَلْیُہْدِ بَدَنَۃً وَلِیَرْکَبْ۔",,,13753,,
13754,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ إِسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنِ الشَّعْبِیِّ ، عَنِ ابْنِ عَبَّاسٍ ؛ فِی رَجُلٍ مَشَی نِصْفَ الطَّرِیقِ فِی نَذْرٍ ، ثُمَّ رَکِبَ ، قَالَ : یَجیء مِن قَابِلٍ فَیَرْکَبُ مَا مَشَی ، وَیَمْشِی مَا رَکِبَ ، وَیَنْحَرُ بَدَنَۃً۔",,,13754,,
13755,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ نَذَرَ أَنْ یَحُجَّ مَاشِیًا ، قَالَ : یَمْشِی حَتَّی إِذَا أَعْیَا رَکِبَ ، وَأَہْدَی۔",,,13755,,
13756,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : یَمْشِی ، فَإِنَ انْقَطَعَ رَکِبَ ، وَأَہْدَی بَدَنَۃً۔",,,13756,,
13757,"حدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنِ الأَجْلَحِ ، عَنْ عَمْرِو بْنِ سَعِیدٍ الْبَجَلِی ، قَالَ : کُنْتُ تَحْتَ مِنْبَرِ ابْنِ الزُّبَیْرِ وَہُوَ عَلَیْہِ ، فَجَائَ رَجُلٌ ، فَقَالَ : یَا أَمِیرَ الْمُؤْمِنِینَ ، إنِّی نَذَرْت أَنْ أَحُجَّ مَاشِیًا ، حَتَّی إذَا کَانَ کَذَا وَکَذَا خَشِیتُ أَنْ یَفُوتَنِی الْحَجُّ فَرَکِبْت ، قَالَ: لاَ خَطَأَ عَلَیْکَ، ارْجِعْ عَامَ قَابِلٍ فَامْشِ مَا رَکِبْتَ ، وَارْکَبْ مَا مَشَیْت۔",,,13757,,
13758,"حدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ خُصَیْفٍ ، عَنْ عَطَائٍ ؛ فِی رَجُلٍ جَعَلَ عَلَیْہِ الْمَشْیَ فَمَشَی بَعْضَ الطَّرِیقِ ، وَرَکِبَ بعضًا ، فَقَالَ : یَنْظُرُ مَا رَکِبَ ، ثُمَّ یُقَوِّمُ جَزَائَہُ ، فَإِنْ بَلَغَ بَدَنَۃً اشْتَرَاہَا وَأَہْدَاہَا ، قَالَ : فَإِنْ لَمْ یَبْلُغْ تَصَدَّقَ بِہِ عَلَی الْمَسَاکِینِ۔",,,13758,,
13759,"حدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، قَالَ : سَمِعْتُ یَزِیدَ بْنَ عَبْدِ اللہِ بْنِ قُسَیْطٍ یَقُولُ : یَرْکَبُ وَیُہْدِی بَدَنَۃً ، وَقَالَ الْقَاسِمُ : إذَا کَانَ قَابِلُ فَلْیَمْشِ مَا رَکِبَ۔",,,13759,,
13760,"حدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، وَمَالِکِ بْنِ أَنَسٍ ، عَنْ عُرْوَۃَ بْنِ أُذَیْنَۃَ ، قَالَ مَالِکٌ : جَدَّتُہُ، وَقَالَ عُبَیْدُ اللہِ : أُمَّہُ ، جَعَلَتْ عَلَیْہَا الْمَشْیَ ، فَمَشَتْ حَتَّی إذَا انْتَہَتْ إلَی السُّقْیَا عَجَزَتْ ، فَسُئل ابْنَ عُمَرَ؟ فَقَالَ : مُرُوہَا أَنْ تَعُودَ مِنَ الْعَامِ الْمُقْبِلِ ، فَتَمْشِی مِنْ حَیْثُ عَجَزَتْ۔",,,13760,,
13761,"حدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنْ حَبِیبِ بْنِ أَبِی مَرْزُوقٍ ، عَنْ عَطَائٍ ، قَالَ : أَیُّمَا امْرَأَۃٍ جَعَلَتْ عَلَیْہَا الْمَشْیَ إلَی الْبَیْتِ فَلَمْ تَسْتَطِعْ ، فَلْتَرْکَبْ وَلِتُہْدِ بَدَنَۃً۔",,,13761,,
13762,حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ حَجَّاجٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ أَنَّہُ لَمْ یَرَ بَأْسًا إذَا أَقْبَلَ مِنْ عَرَفَاتٍ ، أَنْ یَأْخُذَ غَیْرَ طَرِیقِ مِنًی شِمَالاً ، وَیَمِینًا۔,,,13762,,
13763,حدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، أَوِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ یَأْخُذَ غَیْرَ طَرِیقِ مِنًی، إذَا أَفَاضَ مِنْ عَرَفَاتٍ ، طَرِیقِ ضَبٍّ۔,,,13763,,
13764,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَعَطَائٍ ؛ أَنَّہُمَا قَالاَ : فِی ثَلاَثِ شَعَرَاتٍ دَمٌ ، النَّاسِی وَالْمُتَعَمِّدُ سَوَائٌ۔",,,13764,,
13765,"حدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : یَنْزِعُ جِلاَلَہَا لاَ تَتَمَرَّغُ فِیہِ ، یَعْنِی الْبُدْنَ۔",,,13765,,
13766,حدَّثَنَا أَبُو خَالِدٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ لاَ یَنْحَرُہَا وَعَلَیْہَا جِلاَلُہَا۔,,,13766,,
13767,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ مُجَاہِدٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، عَنْ عَلِیٍّ ، قَالَ : أَمَرَنِی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ أَقُومَ عَلَی بُدْنِہِ ، وَأَمَرَنِی أَنْ لاَ أُعْطِیَ الْجَازِرَ مِنْہَا شَیْئًا ، وَقَالَ : نَحْنُ نُعْطِیہِ مِنْ عِنْدِنَا۔ (بخاری 1716۔ مسلم 954)",,,13767,,
13768,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنْ مِقْسَمٍ ، قَالَ : لاَ تُعْطِ مَسْکَ الْہَدْیِ الْجَزَّارُ ، وَإِنْ وَجَدْت بِہِ شَاۃً فَاشْتَرِ بِہِ شَاۃً ، فَاذْبَحْہَا۔",,,13768,,
13769,"حدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ بَأْسَ أَنْ یُعْطَی مَسْکَ الْہَدْیِ الْجَزَّارُ۔",,,13769,,
13770,"حدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حُمَیْدٍ الطَّوِیلِ ، عَنْ عَبْدِ اللہِ بْنِ عُبَیْدِ بْنِ عُمَیْرٍ ، قَالَ : لاَ بَأْسَ أَنْ یُعْطَی الْجَزَّارُ جِلْدَہَا۔",,,13770,,
13771,"حدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ سَیْفٍ ، قَالَ : بَلَغَنِی عَنْ مُجَاہِدٍ ، قَالَ : لاَ یُعْطَی الْجَزَّارُ مِنْہَا شَیْئًا۔",,,13771,,
13772,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ سُلَیْمَانَ بْنِ أَبِی مُسْلِمٍ ، عَنْ طَاوُوسٍ ، قَالَ بَعْضُ أَصْحَابِنَا : ہُوَ عَنِ ابْنِ عَبَّاسٍ ، قَالَ : کَانَ النَّاسُ یَنْصَرِفُونَ کُلَّ وَجْہٍ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَنْفِرُ أَحَدٌ حَتَّی یَکُونَ آخِرُ عَہْدِہِ بِالْبَیْتِ۔ (مسلم 963۔ ابوداؤد 1995)",,,13772,,
13773,حدَّثَنَا حَفْصٌ، عَنْ لَیْثٍ، عَنْ طَاوُوس، وَعَطَائٍ؛ أَنَّ عُمَرَ کَانَ یَرُدُّ مَنْ خَرَجَ، وَلَمْ یَکُنْ آخِرَ عَہْدِہِ بِالْبَیْتِ۔,,,13773,,
13774,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، عَنْ عُمَرَ ، قَالَ : لاَ یَنْفِرُ أَحَدٌ حَتَّی یَطُوفَ بِالْبَیْتِ ، فَإِنَّ آخِرَ النُّسُکِ الطَّوَافُ بِالْبَیْتِ۔",,,13774,,
13775,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : أُمِرَ النَّاسُ أَنْ یَکُونَ آخِرَ عَہْدِہِمْ بِالْبَیْتِ ، وَخُفِّفَ عَنِ الْحُیَّضِ۔ (مسلم 380)",,,13775,,
13776,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ طَاوُوسٍ ، قَالَ : کَانُوا یَنْفِرُونَ مِنْ مِنًی ، فَقِیلَ لَہُمْ : یَکُونُ آخِرَ عَہْدِکُمْ بِالْبَیْتِ ، وَرُخِّصَ لِلْحُیَّضِ۔",,,13776,,
13777,"حدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ کِلاَبِ بْنِ عَلِیّ ، عَنْ مَنْصُورِ بْنِ أَبِی سُلَیْمَانَ ، عَنِ ابْنِ أَخِی جُبَیْرِ بْنِ مُطْعِمٍ ، عَنْ جُبَیْرِ بْنِ مُطْعِمٍ ، قَالَ : قامَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَلَی الْمَرْوَۃِ وَبِیَدِہِ مشِقَصٌّ ، یُقَصِّرُ بِہِ مِنْ شَعْرِہِ وَہُوَ یَقُولُ : دَخَلَتِ الْعُمْرَۃُ فِی الْحَجِّ إلَی یَوْمِ الْقِیَامَۃِ ، لاَ صَرُورَۃَ فِی الإِسْلاَمِ ، وَتُثَجُّ الإِبِلُ ثَجًّا ، وَعُجُّوا بِالتَّکْبِیرِ عَجًّا۔",,,13777,,
13778,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : أَحَلَّ أَصْحَابُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَقَصَّرُوا ، وَلَمْ یَحْلِقُوا۔",,,13778,,
13779,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، قَالَ : کُنْتُ أَحُجُّ مَعَ أَبِی وَأَعْتَمِرُ وَلِی جُمَّۃٌ إلَی مَنْکِبِی، فَمَا أَمَرَنِی بِحَلْقِہَا قَطُّ فَکُنْت أُقَصِّرُ۔",,,13779,,
13780,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا حَجَّ الرَّجُلُ أَوَّلَ حَجَّۃٍ ، حَلَقَ وَإِنْ حَجَّ مَرَّۃً أُخْرَی ، إِنْ شَائَ حَلَقَ ، وَإِنْ شَائَ قَصَّرَ ، وَالْحَلْقُ أَفْضَلُ ، وَإِذَا اعْتَمَرَ الرَّجُلُ وَلَمْ یَحُجَّ قَطُّ ، فَإِنْ شَائَ حَلَقَ ، وَإِنْ شَائَ قَصَّرَ ، فَإِنْ کَانَ مُتَمَتِّعًا قَصَّرَ ثُمَّ حَلَقَ۔",,,13780,,
13781,"حدَّثَنَا عَبْدُ الْوَہَّابِ ، عَنْ حَبِیبٍ الْمُعَلِّمِ ، عَنْ عطاء ؛ سُئِلَ عَنِ الصَّرُورَۃِ : أَیَحْلِقُ ، أَوْ یُقَصِّرُ ؟ قَالَ : أَیُّ ذَلِکَ شَائَ ، إِنْ شَائَ حَلَقَ ، وَإِنْ شَائَ قَصَّرَ۔",,,13781,,
13782,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ فِی الَّذِی لَمْ یَحُجَّ قَطُّ : إِنْ شَائَ حَلَقَ ، وَإِنْ شَائَ قَصَّرَ۔",,,13782,,
13783,حدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنْ مُحَمَّدٍ ؛ أَنَّ عَلْقَمَۃَ ، وَالأَسْوَدَ حَجَّا ، أَوْ حَجَّ أَحَدُہُمَا ، أَوِ اعْتَمَرَ الآخَرُ ، فَحَلَقَ أَحَدُہُمَا وَقَصَّرَ الآخَرُ۔,,,13783,,
13784,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یُحِبُّونَ أَنْ یَحْلِقُوا فِی أَوَّلِ حَجَّۃٍ ، وَأَوَّلِ عُمْرَۃٍ۔",,,13784,,
13785,حدَّثَنَا وَکِیعٌ ، عَنْ حَسَن ، عَنْ جَعْفَرٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَلَقَ فِی عُمْرَۃٍ۔,,,13785,,
13786,"حدَّثَنَا بِشْرُ بْنُ الْمُفَضَّلِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ إِسْحَاقَ ، عَنْ أَبِیہِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَمْرِو بْنِ سَہْلٍ ، قَالَ : قدْ رَأَیْتُ عُثْمَانَ یَقْدَمُ مَکَّۃَ وَنَحْنُ مَعَہُ ، فَمَا یُحِلُّ بِہَا عُقْدَۃً حَتَّی یَخْرُجَ ، فَمَا یَزِیدُ عَلَی أَنْ یَطُوفَ بِالْبَیْتِ ، وَیَسْعَی بَیْنَ الصَّفَا وَالْمَرْوَۃِ ، وَیَحْلِقَ رَأْسَہُ۔",,,13786,,
13787,حدَّثَنَا وَکِیعٌ ، عَنْ أَفْلَحَ ، عَنِ الْقَاسِمِ ؛ أَنَّہُ حَلَقَ فِی عُمْرَۃٍ۔,,,13787,,
13788,"حدَّثَنَا جَرِیرٌ، عَنْ مُغِیرَۃَ، عَنْ إبْرَاہِیمَ، قَالَ: إِذَا اعْتَمَرَ وَلَمْ یَحُجَّ قَطُّ، فَإِنْ شَائَ قَصَّرَ، وَإِنْ شَائَ حَلَقَ۔",,,13788,,
13789,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یَسْتَحِبُّونَ لِلرَّجُلِ أَوَّلَ مَا یَحُجُّ أَنْ یَحْلِقَ ، وَأَوَّلَ مَا یَعْتَمِرُ أَنْ یَحْلِقَ۔",,,13789,,
13790,"حدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عُمَارَۃَ بْنِ الْقَعْقَاعِ ، عَنْ أَبِی زُرْعَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : اللَّہُمَّ اغْفِرْ لِلْمُحَلِّقِینَ ، قَالُوا : یَا رَسُولَ اللہِ ، وَلِلْمُقَصِّرِینَ ؟ قَالَ : اللَّہُمَّ اغْفِرْ لِلْمُحَلِّقِینَ ثَلاَثًا ، فَقَالُوا : یَا رَسُولَ اللہِ ، وَلِلمُقَصِّرِینَ ؟ قَالَ : وَلِلمُقَصِّرِینَ۔ (بخاری 1728۔ مسلم 320)",,,13790,,
13791,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ إبْرَاہِیمَ بْنِ مَیْسَرَۃَ ، عَنْ وَہْبِ بْنِ عَبْدِ اللہِ ، أَرَاہُ عَنْ أَبِیہِ ، قَالَ : کُنْتُ مَعَ أَبِی فَرَأَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ بِیَدِہِ : یَرْحَمُ اللَّہُ الْمُحَلِّقِینَ ، فَقَالَ رَجُلٌ : یَا رَسُولَ اللہِ ، وَالْمُقَصِّرِینَ ؟ قَالَ فِی الثَّالِثَۃِ : وَالْمُقَصِّرِینَ۔ (احمد 6/393۔ حمیدی 931)",,,13791,,
13792,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : حدَّثَنَا ہِشَامٌ الدَّسْتَوَائِیُّ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ أَبِی إِبْرَاہِیمَ ، عَن أَبِی سَعِیدٍ الْخُدْرِیِّ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ نَحْوَہُ۔ (احمد 3/20۔ طیالسی 2224)",,,13792,,
13793,"حدَّثَنَا یَزِیدُ ، قَالَ : أَخْبَرَنَا مُحَمَّدُ بْنُ إِسْحَاقَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : اللَّہُمَّ اغْفِرْ لِلْمُحَلِّقِینَ ، قَالَہَا ثَلاَثًا ، قَالَ : فَقَالُوا : یَا رَسُولَ اللہِ ، مَا بَالُ الْمُحَلِّقِینَ ظَاہَرْتَ لَہُمُ التَّرَحُّمَ ؟ قَالَ : إِنَّہُمْ لَمْ یَشُکُّوا۔ (ابن ماجہ 3045۔ احمد 1/353)",,,13793,,
13794,"أَخْبَرَنَا أَبُو أُسَامَۃُ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : یَرْحَمُ اللَّہُ الْمُحَلِّقِینَ ، قَالُوا : یَا رَسُولَ اللہِ ، وَالْمُقَصِّرِینَ ؟ قَالَ فِی الثَّالِثَۃِ : وَالْمُقَصِّرِینَ۔\n\n(بخاری 1727۔ مسلم 316)",,,13794,,
13795,"حدَّثَنَا وَکِیعٌ ، وَأَبُو دَاوُد الطَّیَالِسِیُّ ، عَنْ شُعْبَۃَ ، عَنْ یَحْیَی بْنِ الْحُصَیْنِ ، عَنْ جَدَّتِہِ ؛ أَنَّہَا سَمِعَتِ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ دَعَا لِلْمُحَلِّقِینَ ثَلاَثًا ، وَلِلْمُقَصِّرِینَ مَرَّۃً ۔ وَلَمْ یَقُلْ وَکِیعٌ : فِی حَجَّۃِ الْوَدَاعِ۔\n\n(مسلم 946۔ احمد 4/70)",,,13795,,
13796,"حدَّثَنَا عُبَیْدُ اللہِ ، قَالَ : أَخْبَرَنَا إسْرَائِیلُ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ حُبْشِی بْنِ جُنَادَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : اللَّہُمَّ اغْفِرْ لِلْمُحَلِّقِینَ ، قَالُوا : یَا رَسُولَ اللہِ وَلِلْمُقَصِّرِینَ ؟ قَالَ : اللَّہُمَّ اغْفِرْ لِلْمُحَلِّقِینَ ، قَالُوا : یَا رَسُولَ اللہِ ، وَلِلْمُقَصِّرِینَ ؟ قَالَ : اغْفِرْ لِلْمُقَصِّرِینَ۔ (احمد 4/165۔ طبرانی 3510)",,,13796,,
13797,"حدَّثَنَا یُونُسُ بْنُ مُحَمَّدٍ ، قَالَ: حدَّثَنَا أَوْسُ بْنُ عُبَیْدُ اللہِ ، عَنْ بُرَیْد بْنِ أَبِی مَرْیَمَ، عَنْ مَالِکِ بْنِ رَبِیعَۃَ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : اللَّہُمَّ اغْفِرْ لِلْمُحَلِّقِینَ ثَلاَثًا ، قَالُوا: یَا رَسُولَ اللہِ ، وَالْمُقَصِّرِینَ؟ قَالَ: وَالْمُقَصِّرِینَ۔ وَکُنْتُ یَوْمَئِذٍ مَحْلُوقَ الرَّأْسِ، فَمَا سَرَّنِی بِحَلْقِ رَأْسِی حُمْرُ النَّعَمِ، أَوْ قَالَ: خَطَرٌ عَظِیمٌ۔حدَّثَنَا أَبُو مُحَمَّدٍ عَبْدُ اللہِ بْنُ یُونُسَ ، قَالَ : حدَّثَنَا أَبُو عَبْدِ الرَّحْمَنِ بَقِیُّ بْنُ مَخْلَدٍ ، قَالَ : حدَّثَنَا أَبُو بَکْرٍ عَبْدُ اللہِ بْنُ مُحَمَّدِ بْنُ أَبِی شَیْبَۃَ الْعَبْسِیُّ ، قَالَ : (احمد 4/177۔ طبرانی 604)",,,13797,,
13798,"حدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : مَنِ اعْتَمَرَ بَعْدَ الْحَجِّ أَجْرَی عَلَی رَأْسِہِ الْمُوسَی۔",,,13798,,
13799,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، وَوَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی الضُّحَی ، عَنْ مَسْرُوقٍ ؛ أَنَّہُ سُئِلَ عَنْ رَجُلٍ اعْتَمَرَ فَحَلَقَ ، ثُمَّ حَجَّ ؟ قَالَ : یُمِرُّ عَلَی رَأْسِہِ الْمُوسَی۔",,,13799,,
13800,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَیَّاشٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : یُمِرُّ عَلَی رَأْسِہِ الْمُوسَی",,,13800,,
13801,"حدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : سَمِعْتُہُ سُئِلَ عَنِ الَّذِی یَعْتَمِرُ بَعْدَ الْحَجِّ؟ قَالَ : یُمِرُّ عَلَی رَأْسِہِ الْمُوسَی۔",,,13801,,
13802,"حدَّثَنَا حَفْصٌ ، عَنْ مُثَنَّی ، عَنْ عَطَائٍ ؛ فِی الشَّیْخِ الْکَبِیرِ یَحُجُّ وَہُوَ أَصْلَعُ ؟ قَالَ : یُمِرُّ الْمُوسَی عَلَی رَأْسِہِ۔",,,13802,,
13803,"حدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ نَافِعٍ ، عَنْ أَبِیہِ ، قَالَ : کَانَ ابْنُ عُمَرَ رَجُلاً أَصْلَعَ ، فَکَانَ إذَا حَجَّ ، أَوِ اعْتَمَرَ أَمَرَّ عَلَی رَأْسِہِ الْمُوسَی۔",,,13803,,
13804,"حدَّثَنَا وَکِیعٌ ، عَنْ شَرِیکٍ ، عَنْ إبْرَاہِیمَ بْنِ الْمُہَاجِرِ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عُمَرَ ؛ {الْحَجُّ أَشْہُرٌ مَعْلُومَاتٌ} قَالَ : شَوَّالُ ، وَذُو الْقَعْدَۃِ ، وَعَشْرٌ مِنْ ذِی الْحِجَّۃِ۔",,,13804,,
13805,"حدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : شَوَّالُ ، وَذُو الْقَعْدَۃِ ، وَذُو الْحِجَّۃِ۔",,,13805,,
13806,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابن طَاوُوسٍ ، عَنْ أَبِیہِ ، قَالَ : شَوَّالُ ، وَذُو الْقَعْدَۃِ ، وَذُو الْحِجَّۃِ۔",,,13806,,
13807,حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سُفْیَانَ ، عَنْ خُصَیْفٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ مِثْلَہُ,,,13807,,
13808,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنِ ہِشَامٍ ، عَنْ الْحَسَن ، قَالَ : شَوَّالُ ، وَذُو الْقَعْدَۃِ ، وَصَدْرُ ذِی الْحِجَّۃِ۔",,,13808,,
13809,حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنْ مُحَمَّد ؛ مِثْلَہُ۔,,,13809,,
13810,"حدَّثَنَا وَکِیعٌ ، عَنْ شَرِیکٌ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : قَالَ عَبْدُ اللہِ : {الْحَجُّ أَشْہُرٌ مَعْلُومَاتٌ} قَالَ : شَوَّالُ ، وَذُو الْقَعْدَۃِ ، وَعَشْرُ ذِی الْحِجَّۃِ۔",,,13810,,
13811,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ فِی قَوْلِہِ تَعَالَی : {الْحَجُّ أَشْہُرٌ مَعْلُومَاتٌ} قَالَ : شَوَّالُ، وَذُو الْقَعْدَۃِ ، وَذُو الْحِجَّۃِ۔",,,13811,,
13812,"حدَّثَنَا وَکِیعٌ ، عَنْ حُسَیْنِ بْنِ عُقَیْلٍ ، عَنِ الضَّحَّاکِ ؛ (الْحَجُّ أَشْہُرٌ مَعْلُومَاتٌ) قَالَ : شَوَّالُ ، وَذُو الْقَعْدَۃِ ، وَذُو الْحِجَّۃِ۔",,,13812,,
13813,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : شَوَّالُ ، وَذُو الْقَعْدَۃِ ، وَعَشْرُ ذِی الْحِجَّۃِ۔",,,13813,,
13814,"حدَّثَنَا وَکِیعٌ ، وَیَحْیَی بْنُ آدَمَ ، عَنْ شَرِیکٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الضَّحَّاکِ ، عَنِ ابْنِ عَبَّاسٍ ؛ {الْحَجُّ أَشْہُرٌ مَعْلُومَاتٌ} قَالَ : شَوَّالُ ، وَذُو الْقَعْدَۃِ ، وَعَشْرُ ذِی الْحِجَّۃِ۔",,,13814,,
13815,"حدَّثَنَا وَکِیعٌ ، عَنْ بَیْہَسِ بْنِ فَہْدَانِ ، عَنْ أَبِی شَیْخٍ الْہُنَائِیِّ ، قَالَ : سَأَلْتُ ابْنَ عُمَرَ عَنْ قَوْلِہِ تَعَالَی : {الْحَجُّ أَشْہُرٌ مَعْلُومَاتٌ} ؟ قَالَ : شَوَّالُ ، وَذُو الْقَعْدَۃِ ، وَذُو الْحِجَّۃِ۔",,,13815,,
13816,"حدَّثَنَا شَرِیکٌ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ ابْنِ عَبَّاسٍ : (فَمَنْ فَرَضَ فِیہِنَّ الْحَجَّ) قَالَ : التَّلْبِیَۃَ۔",,,13816,,
13817,"حدَّثَنَا وَکِیعٌ ، عَنْ حُسَیْنِ بْنِ عُقَیْلٍ ، عَنِ الضَّحَّاکِ ؛ قَالَ : الإِحْرَامَ",,,13817,,
13818,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ ابْنِ جُرَیْجٍ، عَنْ عَطَائٍ؛ {فَمَنْ فَرَضَ فِیہِنَّ الْحَجَّ} قَالَ: مَنْ أَہَلَّ فِیہِنَّ بِالْحَجِّ۔",,,13818,,
13819,"حدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنِ الْعَلاَئِ بْنِ الْمُسَیَّبِ ، عَنْ عَطَائٍ ، قَالَ : الْفَرْضُ التَّلْبِیَۃُ۔",,,13819,,
13820,"حدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : الإِہْلاَلُ فَرِیضَۃُ الْحَجِّ۔",,,13820,,
13821,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ {فَمَنْ فَرَضَ فِیہِنَّ الْحَجَّ} قَالَ : التَّلْبِیَۃُ",,,13821,,
13822,"حدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ زَمْعَۃَ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ؛ {فَمَنْ فَرَضَ فِیہِنَّ الْحَجَّ} قَالَ: التَّلْبِیَۃُ۔",,,13822,,
13823,"حدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَنْ شَرِیکٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الأحوص ، عَنْ عَبْدِ اللہِ ؛ (فَمَنْ فَرَضَ فِیہِنَّ الْحَجَّ) قَالَ : التَّلْبِیَۃُ۔",,,13823,,
13824,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ {فَمَنْ فَرَضَ فِیہِنَّ الْحَجَّ} قَالَ : الإِہْلاَلُ۔",,,13824,,
13825,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ سَعِید بن مَرْزُبَان ، عَنْ أَبِی عَوْنِ ، عَنِ ابْنِ الزُّبَیْر ؛ (فَمَنْ فَرَضَ فِیہِنَّ الْحَجَّ) قَالَ : الإِہْلاَلُ۔",,,13825,,
13826,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ مُحَمَّدِ بْنِ الْمُنْکَدِرِ ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ ، قَالَ : أَتَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجُلٌ ، فَقَالَ : یَا رَسُولَ اللہِ ، أَخْبِرْنِی عَنِ الْعُمْرَۃِ ، وَاجِبَۃٌ ہِیَ ؟ قَالَ : لاَ ، وَأَنْ تَعْتَمِرَ خَیْرٌ لَک۔ (ترمذی 931۔ احمد 3/316)",,,13826,,
13827,"حدَّثَنَا جَرِیرٌ ، عَنْ مُعَاوِیَۃَ بْنِ إِسْحَاقَ ، عَنْ أَبِی صَالِحٍ مَاہَانَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْحَجُّ جِہَادٌ ، وَالْعُمْرَۃُ تَطَوُّعٌ۔ (طبرانی 11)",,,13827,,
13828,"حدَّثَنَا ابْنُ إدْرِیسَ ، وَأَبُو أُسَامَۃَ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : قَالَ عَبْدُ اللہِ : الْحَجُّ فَرِیضَۃٌ ، وَالْعُمْرَۃُ تَطَوُّعٌ۔",,,13828,,
13829,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ عَبْدِ الْمَلِکِ ، عَنِ الشَّعْبِیِّ ، قَالَ : ہِیَ تَطَوُّعٌ۔",,,13829,,
13830,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ حَمَّادًا عَنِ الْعُمْرَۃِ ، وَاجِبَۃٌ ہِیَ ؟ قَالَ : قَدْ اُخْتُلِفَ فِیہَا۔",,,13830,,
13831,"حدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : الْعُمْرَۃُ سُنَّۃٌ ، وَلَیْسَتْ بِفَرِیضَۃٍ۔",,,13831,,
13832,"حدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ عَوْنٍ ، عَنِ الشَّعْبِیِّ ؛ أَنَّہُ قَرَأَہَا {وَأَتِمُّوا الْحَجَّ} ، ثُمَّ قَطَعَ ، ثُمَّ قَالَ : {وَالْعُمْرَۃُ لِلَّہِ}۔",,,13832,,
13833,"حدَّثَنَا عَبْدُاللہِ بْنُ إدْرِیسَ، عَنْ لَیْثٍ، عَنْ عَطَائٍ، وَطَاوُوسٍ، وَمُجَاہِدٍ؛ قَالُوا: الْحَجُّ وَالْعُمْرَۃُ فَرِیضَتَانِ۔",,,13833,,
13834,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُوسٍ ، وَمُجَاہِدٍ ؛ قَالُوا : وَاجِبَۃٌ۔",,,13834,,
13835,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : لَیْسَ مِنْ خَلْقِ اللہِ تَعَالَی أَحَدٌ إِلاَّ وَعَلَیْہِ حَجَّۃٌ وَعُمْرَۃٌ ، وَاجِبَتَانِ۔",,,13835,,
13836,"حدَّثَنَا أَبُو خَالِدٍ ، عَنْ عَبْدِ الْمَلِکِ ، قَالَ : سُئِلَ سَعِیدُ بْنُ جُبَیْرٍ عَنِ الْعُمْرَۃِ ، وَاجِبَۃٌ ہِیَ ؟ قَالَ : نَعَمْ۔",,,13836,,
13837,"حدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : سُئِلَ سَعِیدُ بْنُ جُبَیْرٍ ، وَعَلِیُّ بْنُ حُسَیْنٍ ، عَنِ الْعُمْرَۃِ ، أَوَاجِبَۃٌ ہِیَ ؟ فَتَلَوْا ہَذِہِ الآیَۃَ : {وَأَتِمُّوا الْحَجَّ وَالْعُمْرَۃَ}۔",,,13837,,
13838,"حدَّثَنَا أَبُو خَالِدٍ ، عَنْ دَاوُدَ ، قَالَ : سَأَلْتُ عَطَائً ، قُلْتُ : الْعُمْرَۃُ فَرِیضَۃٌ ؟ قَالَ : نَعَمْ۔",,,13838,,
13839,"حدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ، وَوَکِیعٌ ، عَنْ فُضَیْلِ بْنِ غَزْوَانَ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ: الْعُمْرَۃُ، الْحَجّۃُ الصُغْرَی۔",,,13839,,
13840,"حدَّثَنَا عَبْدُ الْوَہَّابِ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ ، عَنْ زَیْدِ بْنِ ثَابِتٍ ؛ فِی الَّذِی یَعْتَمِرُ قَبْلَ أَنْ یَحُجَّ ، قَالَ : نُسُکَانِ لِلَّہِ عَلَیْک ، لاَ یَضُرُّک بِأَیِّہِمَا بَدَأْتَ۔",,,13840,,
13841,"حدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ مَسْرُوقٍ ، قَالَ : أُمِرْتُم بِإِقَامَۃِ الْحَجِّ وَالْعُمْرَۃِ۔",,,13841,,
13842,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، وَابْنِ سِیرِینَ ؛ قَالاَ : الْحَجُّ وَالْعُمْرَۃُ فَرِیضَتَانِ۔",,,13842,,
13843,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، وَمُحَمَّدٍ ، قَالاَ : الْعُمْرَۃُ وَاجِبَۃٌ۔",,,13843,,
13844,"حدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : سَأَلْتُ عَبْدَ اللہِ بْنَ شَدَّادٍ عَنِ الْحَجِّ الأَکْبَرِ ؟ فَقَالَ : الْحَجُّ الأَکْبَرُ یوم النحر ، والْحَجُّ الأَصْغَرُ الْعُمْرَۃُ۔",,,13844,,
13845,"حدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا سُفْیَانُ، عَنْ مَنْصُورٍ، عَنْ مُجَاہِدٍ، قَالَ: کَانَ یُقَالُ: الْعُمْرَۃُ ہِیَ الْحَجَّۃُ الصُّغْرَی۔",,,13845,,
13846,"حدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ التَّیْمِیِّ ، عَنْ حَیَّانَ بْنِ عُمَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : نُسُکَانِ لِلَّہِ عَلَیْک ، وَلاَ یَضُرُّک بِأَیِّہِمَا بَدَأْت۔",,,13846,,
13847,"حدَّثَنَا یَحْیَی بْنِ یَعْلَی ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، قَالَ : الْعُمْرَۃُ الْحَجُّ الأَصْغَرُ۔",,,13847,,
13848,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ أَشْعَثَ ، قَالَ : کَانَ الْحَسَنُ یَقُولُ : تُجْزِء الْمُتْعَۃُ مِنَ العُمْرَۃٍ۔",,,13848,,
13849,"حدَّثَنَا أَبُو خَالِدٍ ، عَنْ دَاوُدَ ، قَالَ : قُلْتُ لِعَطَائٍ : ہَلْ یُجْزِء عَنَّا مِمَّا افْتُرِضَ عَلَیْنَا مِنْہَا ، یَعْنِی الْعُمْرَۃَ ، التَّمَتُّعُ ؟ قَالَ : نَعَمْ۔",,,13849,,
13850,"حدَّثَنَا وَکِیعٌ ، قَالَ: حدَّثَنَا سُفْیَانُ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُوسٍ ، وَمُجَاہِدٍ؛ قَالُوا: الْعُمْرَۃُ وَاجِبَۃٌ، وَتُجْزِء مِنْہَا الْمُتْعَۃُ۔",,,13850,,
13851,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، وَابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، قَالَ : مَنْ أَدْرَکَ عَرَفَۃَ قَبْلَ أَنْ یَطْلُعَ الْفَجْرُ فَقَدْ أَدْرَکَ الْحَجَّ ، وَمَنْ فَاتَتْہُ عَرَفَۃُ فَاتَہُ الْحَجُّ۔",,,13851,,
13852,حدَّثَنَا حَفْصٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ مِثْلَہُ۔ (دارقطنی 21),,,13852,,
13853,"حدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، وَابْنِ الزُّبَیْرِ قَالاَ : مَنْ وَطِئَ عَرَفَۃَ بِلَیْلٍ ، فَقَدْ أَدْرَکَ الْحَجَّ۔",,,13853,,
13854,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حُسَیْنِ بْنِ عَبْدِ اللہِ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : مَنْ وَقَفَ بِعَرَفَاتٍ بِلَیْلٍ فَقَدْ أَدْرَکَ الْحَجَّ ، إِنَ اتَّقَی وَبَرَّ۔",,,13854,,
13855,"حدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ حُمَیْدٍ ، عَنْ بَکْرِ بْنِ عَبْدِ اللہِ ، عَنْ سَالِمِ بْنِ عَبْدِ اللہِ بْنِ عُمَرَ ، قَالَ : إذَا وَقَفَ الرَّجُلُ بِعَرَفَۃَ بِلَیْلٍ فَقَدْ تَمَّ حَجُّہُ ، وَإِنْ لَمْ یُدْرِکِ النَّاسَ بِجَمْعٍ۔",,,13855,,
13856,"حدَّثَنَا غُنْدَرٌ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، وَسُلَیْمَانَ بْنِ یَسَارٍ ، وَعَطَائِ بْنِ أَبِی رَبَاحٍ، وَسَالِمِ بْنِ عَبْدِاللہِ؛ قَالُوا: إذَا وَقَفَ بِلَیْلٍ بِعَرَفَاتٍ فَقَدْ أَدْرَکَ الْحَجَّ، وَإِنْ لَمْ یُدْرِکِ النَّاسَ بِجَمْعٍ۔",,,13856,,
13857,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ بَکْرٍ ، عَنْ سَالِمٍ ، قَالَ : مَنْ وَقَفَ بِعَرَفَۃَ بِلَیْلٍ فَقَدْ أَدْرَکَ الْحَجَّ ، وَإِنْ لَمْ یُدْرِکَ النَّاسَ بِجَمْعٍ۔",,,13857,,
13858,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، قَالَ : مَنْ وَقَفَ بِعَرَفَۃَ بِلَیْلٍ قَبْلَ أَنْ یَطْلُعَ الْفَجْرُ فَقَدْ أَدْرَکَ الْحَجَّ ، وَمَنْ لاَ فَقَدْ فَاتَہُ ، فَلْیَطُفْ بِالْبَیْتِ وَلْیَسْعَ بَیْنَ الصَّفَا وَالْمَرْوَۃِ ، وَیَحْلِقُ رَأْسَہُ ، وَیُحِلُّ ، وَیَحُجُّ مِنَ الْعَامِ الْمُقْبِلِ وَیُہْدِی ، فَإِنْ لَمْ یَجِدْ فَصِیَامُ ثَلاَثَۃِ أَیَّامٍ فِی الْحَجِّ وَسَبْعَۃٍ إذَا رَجَعَ۔",,,13858,,
13859,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَعَطَائٍ ؛ أَنَّہُمَا قَالاَ : إذَا وَقَفَ الرَّجُلُ بِعَرَفَاتٍ قَبْلَ طُلُوعِ الْفَجْرِ لَیْلَۃَ النَّحْرِ ، فَقَدْ أَدْرَکَ الْحَجَّ ، وَإِنْ لَمْ یُدْرِکِ النَّاسَ بِجَمْعٍ۔",,,13859,,
13860,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : مَنْ فَاتَتْہُ عَرَفَۃُ ، أَوْ جَمْعٌ فَاتَہُ الْحَجُّ۔",,,13860,,
13861,"حدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : مَنْ أَدْرَکَ عَرَفَۃَ قَبْلَ طُلُوعِ الْفَجْرِ، فَقَدْ أَدْرَکَ الْحَجَّ۔",,,13861,,
13862,"حدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنِ الشَّعْبِیِّ ، عَنْ عُرْوَۃَ بْنِ مُضَرِّسٍ الطَّائِیِّ ؛ أَنَّہُ حَجَّ عَلَی عَہْدِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَلَمْ یُدْرِکِ النَّاسَ إِلاَّ وَہُمْ بِجَمْعٍ ، قَالَ : فَأَتَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقُلْتُ : یَا رَسُولَ اللہِ ، أَتْعَبْتُ نَفْسِی وَأَنْضَیْتُ رَاحِلَتِی ، وَاللَّہِ مَا تَرَکْتُ حَبْلاً مِنَ الْحِبَالِ إِلاَّ وَقَد وَقَفْت عَلَیْہِ ، فَہَلْ لِی مِنْ حَجٍّ ؟ فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ صَلَّی مَعَنَا ہَذِہِ الصَّلاَۃَ ، وَقَدْ أفَاضَ قَبْلَ ذَلِکَ مِنْ عَرَفَاتٍ لَیْلاً ، أَوْ نَہَارًا ، فَقَدْ قَضَی تَفَثَہُ وَتَمَّ حَجُّہُ۔ (ترمذی 891۔ ابوداؤد 1945)",,,13862,,
13863,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ بُکَیْرِ بْنِ عَطَائٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَعْمُرَ ، قَالَ : سَمِعْتُہُ یَقُولُ : سَمِعْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ وَاقِفٌ بِعَرَفَۃَ ، وَأَتَاہُ نَاسٌ مِنْ أَہْلِ مَکَّۃَ فَقَالُوا : یَا رَسُولَ اللہِ ، کَیْفَ الْحَجُّ ؟ قَالَ : الْحَجُّ عَرَفَۃُ ، فَمَنْ جَائَ قَبْلَ طُلُوعِ الْفَجْرِ لَیْلَۃَ جَمْعٍ فَقَدْ تَمَّ حَجُّہُ ، مِنًی ثَلاَثَۃُ أَیَّامٍ ، فَمَنْ تَعَجَّلَ فِی یَوْمَیْنِ فَلاَ إِثْمَ عَلَیْہِ ، وَمَنْ تَأَخَّرَ فَلاَ إِثْمَ عَلَیْہِ ، ثُمَّ أَرْدَفَ رَجُلاً خَلْفَہُ یُنَادِی بہِنَّ۔\n\n(ترمذی 889۔ ابوداؤد 1944)",,,13863,,
13864,"حدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عَنْ عُمَرَ ، وَزَیْدٍ ؛ قَالاَ : فِی الرَّجُلِ یَفُوتُہُ الْحَجُّ : یُحِلُّ بِعُمْرَۃٍ ، وَعَلَیْہِ الْحَجُّ مِنْ قَابِلٍ۔",,,13864,,
13865,"حدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطَائٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : مَنْ لَمْ یُدْرِکْ فَعَلَیْہِ دَمٌ ، وَیَجْعَلُہَا عُمْرَۃً ، وَعَلَیْہِ الْحَجُّ مِنْ قَابِلٍ۔",,,13865,,
13866,حدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ مِثْلَہُ۔,,,13866,,
13867,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ؛ فِی الَّذِی یَفُوتُہُ الْحَجُّ ، قَالَ : تَعُودُ حَجَّتُہُ عُمْرَۃً",,,13867,,
13868,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ حَنْظَلَۃَ ، عَنِ الْقَاسِمِ ؛ فِی الَّذِی یَفُوتُہُ الْحَجُّ ، قَالَ : یَجْعَلُہَا عُمْرَۃً ، وَعَلَیْہِ الْحَجُّ مِنَ الْعَامِ التَّابِعِ وَیُہْدِی ، فَإِنْ لَمْ یَجِدْ صَامَ ثَلاَثَۃَ أَیَّامٍ فِی الْحَجِّ ،وَسَبْعَۃً إذَا رَجَعَ۔",,,13868,,
13869,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْہَیْثُمِ ، عَنْ طلحۃ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہ قَالَ : إذَا فَاتَہ الْحَجُّ جَعَلَہا عُمْرَۃً، وَعَلَیْہِ الْہَدْیُ أَحَبُّ إِلَیَّ۔",,,13869,,
13870,"حدَّثَنَا عَبْدُ الأَعْلَی بْنُ عَبْدِ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : یَجْعَلُہَا عُمْرَۃً ، وَعَلَیْہِ الْہَدْیُ والْحَجّ من قابل",,,13870,,
13871,"حدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عَنْ عُمَرَ ، قَالَ : یُحِلُّ بِعُمْرَۃٍ ، وَعَلَیْہِ الْحَجُّ مِنْ قَابِلٍ۔",,,13871,,
13872,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الْحَسَنِ بْنِ عَمْرٍو ، عَنْ مِہْرَانٍ أَبِی صَفْوَانَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ أَرَاْدَ مِنْکُمُ الْحَجَّ فَلْیَتَعَجَّلْ۔ (ابوداؤد 1729۔ احمد 1/225)",,,13872,,
13873,"حدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، قَالَ : کَانَ حَبِیبٌ وَأَصْحَابُہُ یَتَأَخَّرُونَ حَتَّی یَدْخُلَ مِنْ ذِی الْقَعْدَۃِ مَا شَائَ اللَّہُ ، فَکَرِہَ ذَلِکَ إبْرَاہِیمُ۔",,,13873,,
13874,"حدَّثَنَا إِسْحَاقُ بْنُ سُلَیْمَانَ الرَّازِیّ ، عَنْ أَبِی سِنَانٍ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، قَالَ : کَانَ طَاوُوس یَقْدُمُ فِی أَوَّلِ النَّاسِ ، وَیَنْفِرُ فِی آخِرِ النَّاسِ۔",,,13874,,
13875,"حدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَانَ مُحَمَّدٌ لاَ یَرَی بَأْسًا أَنْ یَشْتَرِیَ الرَّجُلُ الْبَعِیرَ یَتَعَجَّلُ عَلَیْہِ۔",,,13875,,
13876,"حدَّثَنَا أَبُو أُسَامَۃَ، عَنْ بُرَیْدِ بْنِ عَبْدِ اللہِ، عَنْ جَدِّہِ أَبِی بُرْدَۃَ ، قَالَ: أَہْلَلْتُ ہِلالَ ذِی الْحِجَّۃِ بِالْکُوفَۃِ، ثُمَّ وَافَیْتُ النَّاسَ بِالْمَوْقِفِ عَشِیَّۃَ عَرَفَۃَ ، فَلَمْ یَعِبْ ذَلِکَ أَبُو مُوسَی۔",,,13876,,
13877,حدَّثَنَا وَکِیعٌ ، عَنْ مُحَمَّدِ بْنِ بُرْجَانٍ ، عَنْ جَابِرِ بْنِ زَیْدٍ ؛ أَنَّہُ سَارَ مِنَ الْبَصْرَۃِ إلَی مَکَّۃَ فِی اثْنَتَیْ عَشَرَۃ ، أَوْ ثَلاَثَ عَشْرَۃَ ۔ الشَّکُّ مِنِّی۔,,,13877,,
13878,"حدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ عَاصِمٍ ، عَنِ الْمُسَیَّبِ ، قَالَ : سَارَ إلَیْنَا عَبْدُ اللہِ مِنَ الْمَدِینَۃِ حِینَ قُتِلَ عُمَرُ فِی سَبْعٍ۔",,,13878,,
13879,حدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ سَارَ مِنْ مَکَّۃَ إلَی الْمَدِینَۃِ فِی ثَلاَثٍ ، حِینَ اُسْتُصْرِخَ عَلَی صَفِیَّۃَ۔,,,13879,,
13880,"حدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : تَمَتَّعَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَأَبُو بَکْرٍ ، وَعُمَرُ ، وَعُثْمَانُ ، وَأَوَّلُ مَنْ نَہَی عَنْہَا مُعَاوِیَۃُ۔ (ترمذی 822۔ احمد 1/292)",,,13880,,
13881,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سُفْیَانَ ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنْ طَاوُوسٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : سَمِعْتُ عُمَرَ یَقُولُ : لَوِ اعْتَمَرْت ، ثُمَّ اعْتَمَرْت ، ثُمَّ حَجَجْت ، لَتَمَتَّعْت۔",,,13881,,
13882,"حدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ، عَنْ عُمَرَ بْنِ ذَرٍّ، عَنْ مُجَاہِدٍ، قَالَ: کَانَ ابْنُ عُمَرَ، وَابْنُ عَبَّاسٍ یَقْدَمَانِ مُتَمَتِّعَیْنِ۔",,,13882,,
13883,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ، عَنِ التَّیْمِیِّ، عَنْ غُنَیْمِ بْنِ قَیْسٍ، قَالَ: سَأَلْتُ سَعْدًا عَنِ الْمُتْعَۃِ، أَوْ عَنِ الْجَمْعِ بَیْنَہُمَا ؟ فَقَالَ : فَعَلْنَا ہَذَا ، وَہَذَا کَافِرٌ بِرَبِّ الْکَعْبَۃِ ، أَوْ بِرَبِّ الْعَرْشِ ۔ یَعْنِی مُعَاوِیَۃَ۔ (مسلم 898)",,,13883,,
13884,"حدَّثَنَا معتمر بن سُلَیْمَانَ ، عَنْ أَبِی مَعْنٍ ، قَالَ : سمِعْتُ ابْنَ عَمَرَ ، وَابْنَ الزُّبَیْرِ ، وَجَابِرَ بْنَ زَیْدٍ ، وَأَبَا الْعَالِیَۃِ ، وَالْحَسَنَ یَأْمُرُونَ بِمُتْعَۃِ الْحَجِّ۔",,,13884,,
13885,"حدَّثَنَا أَبُو خَالِدٍ ، عَنِ الْعَوَّامِ ، عَنْ طَاوُوسٍ ، قَالَ : إِنَّ تَمَامَ الْحَجِّ الْعُمْرَۃُ قَبْلَہُ۔",,,13885,,
13886,"حدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ شُعَیْبِ بْنِ الْحَبْحَابِ ، قَالَ : أَمَرَنِی أَبُو الْعَالِیَۃِ بِمُتْعَۃِ الْحَجِّ۔",,,13886,,
13887,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ خَالِدِ بْنِ دِینَارٍ ، قَالَ : سَمِعْتُ عَطَائً یَأْمُرُ بِمُتْعَۃِ الْحَجِّ۔",,,13887,,
13888,"حدَّثَنَا وَکِیعٌ ، عَنْ عُثْمَانَ بْنِ أَبِی الْحَکَمِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : أَیْنَ أَنْتَ مِنَ الْمُتْعَۃِ ؟ تَجْعَلُ غُرْزَتَیْنِ فِی غُرْزَۃٍ۔",,,13888,,
13889,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ ، قَالَ : قَالَ مُجَاہِدٌ : لَوْ حَجَجْت مِنْ أَرْضِکَ ہَذِہِ ، یَعْنِی الْکُوفَۃَ ، سَبْعِینَ حَجَّۃً ، لَجَعَلْت مَعَ کُلِّ حَجَّۃٍ عُمْرَۃً ، قَالَ : فَقُلْتُ : أَقْرِنُ ؟ قَالَ : لاَ ، قَالَ : اجْعَلْہَا عُمْرَۃً بَتْلاً۔",,,13889,,
13890,"حدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : کَانَ یَرَاہَا قَبْلَ أَنْ یَحُجَّ ، وَلَوْ حَجَّ الرَّجُلُ عِشْرِینَ مَرَّۃً۔",,,13890,,
13891,"حدَّثَنَا یَعْلَی ، عَنْ أَبِی بِسْطَامٍ ، عَنِ الضَّحَّاکِ ، قَالَ : لَوْ حَجَجْتُ ثَمَانِینَ حَجَّۃً ، لَجَعَلْتُ مَعَ کُلِّ حَجَّۃٍ مُتْعَۃً۔",,,13891,,
13892,"حدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ، عَنْ لَیْثٍ، عَنْ مُجَاہِدٍ، قَالَ: حجَجْتُ أَرْبَعِینَ حَجَّۃً، مَا خَرَجْت إِلاَّ مُتَمَتِّعًا۔",,,13892,,
13893,"حدَّثَنَا عَبْدُ الْوَہَّابِ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ مَالِکِ بْنِ دِینَارٍ ، قَالَ : سَأَلْتُ ثَمَانیَۃَ نَفَرٍ عَنِ الْمُتْعَۃِ ؟ فَکُلُّہُمْ أَمَرَنِی بِہَا ، الْحَسَنُ ، وَعَطَائٌ ، وَطَاوُوسٌ ، وَجَابِرُ بْنُ زَیْدٍ ، وَسَالِمُ بْنُ عَبْدِ اللہِ ، وَعِکْرِمَۃُ ، وَمُجَاہِدٌ ، وَالْقَاسِمُ۔",,,13893,,
13894,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ التَّیْمِیِّ ، عَنْ أَبِیہِ ، عَنْ أَبِی ذَرٍّ ، قَالَ : کَانَتِ الْمُتْعَۃُ لأَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ خَاصَّۃً۔ (مسلم 160۔ ابن ماجہ 2985)",,,13894,,
13895,"حدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ عَیَّاشِ الْعَامِرِیِّ ، عَنْ إبْرَاہِیمَ التَّیْمِیِّ ، عَنْ أَبِیہِ ، عَنْ أَبِی ذَرٍّ ، قَالَ : کَانَتْ لَنَا رخصۃ ، یَعْنِی الْمُتْعَۃَ فِی الْحَجِّ۔",,,13895,,
13896,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی الضُّحَی ، قَالَ : سَأَلْتُ عَلْقَمَۃَ عَنِ الْمُتْعَۃِ فِی الْحَجِّ؟ فَقَالَ : مَا شَعَرْتُ أَن أَحَدًا یَفْعَلُہَا",,,13896,,
13897,"حدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَنْ یُونُسَ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّہُ کَانَ لاَ یَرَی الْمُتْعَۃَ قَبْلَ الْحَجِّ ، وَیَقُولُ : ابْدَأْ بِالْحَجِّ وَاعْتَمِرْ۔",,,13897,,
13898,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامِ بْنِ حَسَّانٍ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، قَالَ : إنَّمَا الْمُتْعَۃُ لِلْمُحْصَرِ، وَتَلاَ ہَذِہِ الآیَۃَ : {فَإِذَا أَمِنْتُمْ فَمَنْ تَمَتَّعَ بِالْعُمْرَۃِ إلَی الْحَجِّ فَمَا اسْتَیْسَرَ مِنَ الْہَدْیِ}۔",,,13898,,
13899,حدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ مُزَاحِمِ بْنِ أَبِی مُزَاحِمٍ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ عَبْدِ اللہِ بْنِ خَالِدِ بْنِ أُسَیْدٍ ، عَنْ مُحَرِّشٍ الْکَعْبِیِّ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ اعْتَمَرَ مِنَ الْجِعْرَانَۃِ ، ثم أصبح بِالْجِعْرَانَۃِ کَبَائِتٍ۔ (ترمذی 935۔ نسائی 3846),,,13899,,
13900,حدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنِ الشَّعْبِیِّ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَقَامَ فِی عُمْرَتِہِ ثَلاَثًا۔,,,13900,,
13901,"حدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ شَیْخٍ مِنْ بَنِی غِفَارٍ مِنْ أَہْلِ مَکَّۃَ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی حَیَّۃَ ، قَالَ : کَانَ أَبُو ذَرٍّ إذَا دَخَلَ مَکَّۃَ لَمْ یَقُمْ بِہَا إِلاَّ ثَلاَثًا ، حَتَّی یَخْرُجَ ، یَعْنِی لِحَجٍّ ، أَوْ بِعُمْرَۃٍ۔",,,13901,,
13902,"حدَّثَنَا بِشْرُ بْنُ الْمُفَضَّلِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ إِسْحَاقَ ، عَنْ أَبِیہِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَمْرِو بْنِ سَہلٍ ، قَالَ : لَقَدْ رَأَیْت عُثْمَانَ یَقْدُمُ مَکَّۃَ وَنَحْنُ مَعَہُ ، فَمَا یَحِلُّ بِہَا عُقْدَۃً حَتَّی یَخْرُجَ ، مَا یَزِیدُ عَلَی أَنْ یَطُوفَ بِالْبَیْتِ ، وَبَیْنَ الصَّفَا وَالْمَرْوَۃِ۔",,,13902,,
13903,حدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَانَ یَسْتَحِبُّ أَنْ یُقِیمَ الْمُحْرِمُ ثَلاَثًا۔,,,13903,,
13904,حدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ مِثْلَہُ۔,,,13904,,
13905,حدَّثَنَا ہُشَیْمٌ ، عَنْ حُمَیْدٍ ، عَنْ یَعْلَی بْنِ حَکِیمٍ ؛ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ قَدِمَ لَیْلاً وَہُوَ مُعْتَمِرٌ ، فَقَضَی عُمْرَتَہُ مِنْ لَیْلَتِہِ ، ثُمَّ نَفَرَ قَبْلَ أَنْ یُصْبِحَ۔,,,13905,,
13906,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : کَانُوا یَسْتَحِبُّونَ أَنْ یُقِیمُوا فِی الْعُمْرَۃِ ثَلاَثًا۔",,,13906,,
13907,"حدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ جَعْفَرِ بْنِ سُلَیْمَانَ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، قَالَ : کَانَ أَصْحَابُ عَبْدِ اللہِ یُقِیمُونَ مُعْتَمِرِینَ ، فَیَقْضُونَ الطَّوَافَ ، ثُمَّ یَخْرُجُونَ مِنْ لَیْلَتِہِمْ۔",,,13907,,
13908,"حدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ إسْمَاعِیلَ بْنِ عَبْدِ الْمَلِکِ ، قَالَ : رَأَیْتُ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ یَقْدُمُ حَاجًّا ، أَوْ مُعْتَمِرًا فَلاَ یُقِیمُ إِلاَّ ثَلاَثًا حَتَّی یَخْرُجَ۔",,,13908,,
13909,"حدَّثَنَا الْفَضْلُ ، عَنْ أَفْلَحَ ، قَالَ : أَقَمْتُ مَعَ الْقَاسِمِ بْنِ مُحَمَّدٍ فِی الْعُمْرَۃِ ثَلاَثًا۔",,,13909,,
13910,حدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ أَفْلَحَ ، عَنْ أَبِیہِ ؛ أَنَّ عُمَرَ أَقَامَ فِی الْعُمْرَۃِ ثَلاَث لیال۔,,,13910,,
13911,"حدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ عَبْدِ اللہِ بْنِ عُمَرَ ، قَالَ : سَمِعْتُ مَشْیَخَتَنَا یَذْکُرُونَ أَنَّ عَاصِمَ بْنَ عُمَرَ بْنِ الْخَطَّابِ کَانَ یَأْتِی مَکَّۃَ مُعْتَمِرًا ، فَلاَ یَحِلُّ رَحْلَہُ حَتَّی یَرْجِعَ۔",,,13911,,
13912,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ إِسْمَاعِیلَ بْنِ أُمَیَّۃَ ، عَنْ مُزَاحِمِ بْنِ أَبِی مُزَاحِمٍ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ عَبْدِ اللہِ بْنِ خَالِدِ بْنِ أُسَیْدٍ ، عَنْ مُحَرِّشٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ اعْتَمَرَ مِنَ الْجِعْرَانَۃِ ، ثُمَّ أَصْبَحَ بِہَا کَبَائِتٍ۔ قَالَ : وَرَأَیْتُ ظَہْرَہُ کَأَنَّہُ سَبِیکَۃُ فِضَّۃٍ۔",,,13912,,
13913,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ : لاَ تُرْکَبُ الْبَدَنَۃُ إِلاَّ مَزْمُومَۃً ، أَوْ مَخْطُومَۃً ، أَوْ مَخْشُوشَۃً۔",,,13913,,
13914,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : تُقَطَّرُ وَتُخْطِمُ إذَا خَافَ عَلَیْہَا أَنْ تَہْلکَ۔",,,13914,,
13915,حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنِ ابْنِ الأَسْوَدِ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یَخْطِمُ بَدَنَتَہُ ، وَکَانَ ابْنُ الزُّبَیْرِ یَفْعَلُ ذَلِکَ۔,,,13915,,
13916,"حدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : اخْطِمِ الْبَدَنَۃَ وَاضْرِبْہَا۔",,,13916,,
13917,حدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ ثُوَیْرٍ ، عَنْ أَبِیہِ ؛ أَنَّ عَلْقَمَۃَ ، وَالأَسْوَدَ ، وَعَمْرَو بْنَ مَیْمُونٍ کَانُوا لاَ یَزُمُّونَ رَوَاحِلَہُمْ,,,13917,,
13918,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَأَبَا بَکْرٍ ، وَعُمَرَ ، کَانُوا یَمْشُونَ إلَی الْجِمَارِ ۔ قَالَ : وَکَانَ عَلِیُّ بْنُ حُسَیْنٍ یَمْشِی إلَیْہَا۔",,,13918,,
13919,حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ، عَنِ ابْنِ جُرَیْجٍ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ؛ أَنَّہُ کَانَ یَمْشِی إلَیْہَا مُقْبِلاً وَمُدْبِرًا۔,,,13919,,
13920,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : أَدْرَکْتُ النَّاسَ یَمْشُونَ مُقْبِلِینَ وَمُدْبِرِینَ۔",,,13920,,
13921,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُحَمَّدِ بْنِ الْمُنْکَدِرِ ، قَالَ : رَأَیْتُ ابْنَ الزُّبَیْرِ یَرْمِی الْجِمَارَ مَاشِیًا۔",,,13921,,
13922,"حدَّثَنَا مَعْنُ بْنُ عِیسَی، عَنْ عُبِیدَۃَ ابْنَۃِ نَابِلٍ، قَالَتْ: رَأَیْت عَائِشَۃَ ابنۃ سَعْدٍ تَرْمِی الْجِمَارَ وَہِیَ مَاشِیَۃٌ۔",,,13922,,
13923,حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَرْمِی الْجِمَارَ مَاشِیًا ، ذَاہِبًا وَرَاجِعًا۔,,,13923,,
13924,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : لَمْ یَکُنْ یُوجِبُ الْمَشْیَ إلَیْہَا ، وَکَانَ یَقُولُ: وَلَمْ یَرْکَبْ وَہُوَ صَحِیحٌ؟!",,,13924,,
13925,حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ إبْرَاہِیمَ بْنِ نَافِعٍ ، عَنْ عَطَائٍ ، عَنْ جَابِرٍ ؛ أَنَّہُ کَانَ لاَ یَرْکَبُ إلَی الْجِمَارِ ، إِلاَّ مِنْ ضَرُورَۃٍ۔,,,13925,,
13926,"حدَّثَنَا وَکِیعٌ ، عَنْ سَعِیدِ بْنِ السَّائِبِ ، عَنْ مُحَمَّدِ بْنِ السَّائِبِ ، عَنْ أَبِیہِ ، قَالَ : رَأَیْتُ عُمَرَ بْنَ الْخَطَّابِ رَأَی رَجُلاً یَقُودُ بِامْرَأَتِہِ عَلَی بَعِیرٍ یَرْمِی الْجَمْرَۃَ ، قَالَ : فَعَلاَہُ بِالدِّرَّۃِ ، إنْکَارًا لِرُکُوبِہَا",,,13926,,
13927,"حدَّثَنَا وَکِیعٌ ، عَنْ أَیْمَنَ بْنِ نَابِلٍ ، عَنْ قُدَامَۃَ بْنِ عَبْدِ اللہِ ، قَالَ : رَأَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَمَی جَمْرَۃَ الْعَقَبَۃِ یَوْمَ النَّحْرِ عَلَی نَاقَۃٍ لَہُ صَہْبَائَ ، لاَ ضَرْبَ ، وَلاَ طَرْدَ ، وَلاَ إلَیْکَ إلَیْکَ۔\n\n(ترمذی 903۔ احمد 3/412)",,,13927,,
13928,حدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنْ مِقْسَمٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَمَی الْجَمْرَۃَ عَلَی رَاحِلَتِہِ۔ (ترمذی 899),,,13928,,
13929,"حدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ الْفَزَارِیُّ ، عَنْ أَبِی مَالِکٍ الأَشْجَعِیِّ ، قَالَ : رَأَیْتُ ابْنَ الْحَنَفِیَّۃِ یَرْمِی الْجِمَارَ عَلَی بِرْذَوْنٍ۔",,,13929,,
13930,"حدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ ہَارُونَ بْنِ أَبِی إِبْرَاہِیمَ ، عَن عَطَائٍ ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ وَاقِفًا عِنْدَ الْجَمْرَۃِ عَلَی حِمَارٍ۔",,,13930,,
13931,"حدَّثَنَا وَکِیعٌ، عَنْ إبْرَاہِیمَ بْنِ نَافِعٍ، عَنِ ابْنِ أَبِی نَجِیحٍ، عَنْ عَطَائٍ، قَالَ: رُکُوبُ یَوْمَیْنِ، وَمَشْیُ یَوْمَیْنِ۔",,,13931,,
13932,"حدَّثَنَا ابْنُ نُمَیْرٍ، عَنْ حَجَّاجٍ، قَالَ: رَأَیتُ عَطَائً یَرْمِی الْجَمْرَۃَ عَلَی دَابَّۃٍ، فَقُلْتُ لَہُ؟ فَقَالَ: إِنِّی شَیْخٌ کَبِیرٌ۔",,,13932,,
13933,حدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ إبْرَاہِیمَ بْنِ نافع ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ؛ أَنََّہُ کَانَ یَرْمِی الْجَمْرَۃَ وَہُوَ رَاکِبٌ۔,,,13933,,
13934,"حدَّثَنَا عَبْدُ الْوَہَّابِ بْنُ عَطَائٍ ، عَنْ عَبَایَۃَ ، قَالَ : رَأَیْتُ سَالِمًا یَرْمِی الْجِمَارَ وَہُوَ عَلَی حِمَارٍ",,,13934,,
13935,"حدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ أَفْلَحَ ، عَنِ الْقَاسِمِ ، قَالَ : کَانَ یَجِیئُ فَیَرْمِی الْجَمْرَۃَ یَوْمَ النَّحْرِ ، وَہُوَ رَاکِبٌ۔",,,13935,,
13936,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، قَالَ : حدَّثَنَا عَمْرٌو ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : کُنْتُ مِمَّنْ قَدَّمَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی ضَعَفَۃِ أَہْلِہِ۔ (مسلم 303۔ ابن ماجہ 3026)",,,13936,,
13937,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، قَالَ : أَخْبَرَنَا عُبَیْدُ اللہِ بْنُ أَبِی یَزِیدَ ؛ أَنَّہُ سَمِعَ ابْنَ عَبَّاسٍ یَقُولُ : أَنَا مِمَّنْ قَدَّمَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی ضَعَفَۃِ أَہْلِہِ۔ (بخاری 1678۔ ابوداؤد 1934)",,,13937,,
13938,"حدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، وَسُفْیَانَ ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنِ الْحَسَنِ الْعُرَنِیِّ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ: قدَّمَنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أُغَیْلِمَۃَ بَنِی عَبْدِ الْمُطَّلِبِ عَلَی حُمُرَاتٍ مِنْ جَمْعٍ ، وَجَعَلَ یَلْطَحُ أَفْخَاذَنَا وَیَقُولُ : أُبَیْنِیَّ ، لاَ تَرْمُوا الْجَمْرَۃَ حَتَّی تَطْلُعَ الشَّمْسُ۔\n\nزَادَ سُفْیَانُ فِیہِ : وَلاَ إِخَالُ أَحَدًا یَرْمِیہَا حَتَّی تَطْلُعَ الشَّمْسُ۔ (ابوداؤد 1935۔ طحاوی 217)",,,13938,,
13939,حدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَمَرَ أُمَّ سَلَمَۃَ أَنْ تُوَافِیَہُ صَلاَۃَ الصُّبْحِ بِمِنًی۔,,,13939,,
13940,"حدَّثَنَا وَکِیعٌ ، عَنِ الْمَسْعُودِیِّ ، عَنِ الْحَکَمِ ، عَنْ مِقْسَمٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَدَّمَ ضَعَفَۃَ أَہْلِہِ ، وَقَالَ : لاَ تَرْمُوا الْجَمْرَۃَ حَتَّی تَطْلُعَ الشَّمْسُ۔ (ترمذی 893۔ احمد 1/344)",,,13940,,
13941,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، قَالَ : حدَّثَنَا عَمْرُو بْنُ دِینَارٍ ، عَنْ سَالِمِ بْنِ شَوَّالٍ ، عَنْ أُمِّ حَبِیبَۃَ قَالَتْ : کُنَّا نَفْعَلُہُ عَلَی عَہْدِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔ (مسلم 299۔ احمد 426)",,,13941,,
13942,"حدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ الشَّوَّالِ ، قَالَ : قَالَ عَبْدُ اللہِ بن عُمَرَ ؛ إنَّمَا جَمْعٌ مَنْزِلٌ تَرْتَحِلُ مِنْہُ مَتی شِئْتَ۔",,,13942,,
13943,حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ عَبْدِ اللہِ مَوْلَی أَسْمَائَ ؛ أَنَّہَا کَانَتْ تُصَلِّی الصُّبْحَ بِمِنًی۔,,,13943,,
13944,حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سَعْدِ بْنِ إِبْرَاہِیمَ ، عَن حُمَیْدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ عَوْفٍ ؛ أَنَّ عَبْدَ الرَّحْمَن بْنَ عَوْفٍ کَانَ یُعَجِّلُ النِّسَائَ وَالصِّبْیَانَ مِنْ جَمْعٍ بِلَیْلٍ۔,,,13944,,
13945,"حدَّثَنَا وَکِیعٌ ، عَنْ عُبَیْدِ اللہِ بْنِ أَبِی زِیَادٍ ، عَنْ عَطَائٍ ، عَنْ عَائِشَۃَ ؛ أَنَّہَا کَانَتْ تُقَدِّمُ ضَعَفَۃَ أَہْلِہَا مِنْ جَمْعٍ بِلَیْلٍ ، قَالَ عَطَائٌ : وَإنِّی لأَفْعَلُہُ۔",,,13945,,
13946,حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَانَ یُرَخِّصُ لِلْکَبِیرِ وَالْمَرِیضِ أَنْ یُفِیضُوا مِنْ جَمْعٍ بِلَیْلٍ، وَلَکِنْ لاَ یَرْمِی جَمْرَۃَ الْعَقَبَۃِ حَتَّی تَطْلُعَ الشَّمْسُ۔,,,13946,,
13947,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنْ عَطَائٍ ، قَالَ : رُخِّصَ لِلْمَرِیضِ وَالْحُبْلَی وَمَنْ کَانَتْ بِہِ عِلَّۃٌ أَنْ یُفِیضُوا مِنْ جَمْعٍ بِلَیْلٍ ، وَلاَ یَرْمُوا الْجِمَارَ حَتَّی تَطْلُعَ الشَّمْسُ۔",,,13947,,
13948,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنْ عَبْدِ اللہِ بْنِ عَبْدِ اللہِ ، قَالَ : کَانَ ابْنُ عُمَرَ یَبْعَثُ بِصِبْیَانِہِ لَیْلَۃَ الْمُزْدَلِفَۃِ ، فَیُصَلُّوانَ الصُّبْحَ بِمِنًی ، وَیَرْمُوانَ الْجَمْرَۃَ قَبْلَ أَنْ یَأْتِیَ النَّاسُ۔",,,13948,,
13949,حدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ أَبِی الزِّناد ؛ أَنَّ ابْنَ عَوْفٍ کَانَ یُصَلِّی بِأُمَّہَاتِ الْمُؤْمِنِینَ الْفَجْرَ بِمِنًی۔,,,13949,,
13950,"حدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا زَکَرِیَّا بْنُ أَبِی زَائِدَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَصْبَہَانِیِّ ، قَالَ : حدَّثَنَا ابْنُ مَعْقِلٍ ، قَالَ : حدَّثَنِی کَعْبُ بْنُ عُجْرَۃَ ، قَالَ : قَالَ لِی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَکَانَ ہَوَامُّ رَأْسِہِ آذَیْنَہُ ، قَالَ لِی : اذْبَحْ شَاۃً نُسُکًا ، أَوْ صُمْ ثَلاَثَۃَ أَیَّامٍ ، أَوْ أَطْعِمْ سِتَّۃَ مَسَاکِینَ ، بَیْنَ کُلِّ مِسْکِینَیْنِ صَاعٌ مِنْ تَمْرٍ۔ (بخاری 1816۔ مسلم 85)",,,13950,,
13951,"حدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، وَمُجَاہِدٍ ؛ فِی قَوْلِہِ تَعَالَی : {فَفِدْیَۃٌ مِنْ صِیَامٍ ، أَوْ صَدَقَۃٍ ، أَوْ نُسُکٍ} قَالاَ : الصِّیَامُ ثَلاَثَۃُ أَیَّامٍ ، وَالصَّدَقَۃُ ثَلاَثَۃُ آصُعٍ ، وَالنُّسُکُ شَاۃٌ۔",,,13951,,
13952,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : الْفِدْیَۃُ صِیَامُ عَشَرَۃِ أَیَّامٍ ،وَالصَّدَقَۃُ عَشَرَۃُ مَسَاکِینَ ، وَالنُّسُکُ ذَبِیحَۃٌ۔",,,13952,,
13953,"حدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ : الصِّیَامُ ثَلاَثَۃُ أَیَّامٍ ، وَالصَّدَقَۃُ سِتَّۃُ مَسَاکِینَ ، وَالنُّسُکُ شَاۃٌ۔",,,13953,,
13954,حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ مِثْلَہُ۔,,,13954,,
13955,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، قَالَ : الصِّیَامُ ثَلاَثَۃُ أَیَّامٍ ، وَالصَّدَقَۃُ ثَلاَثَۃُ آصُعٍ بَیْنَ سِتَّۃِ مَسَاکِینَ ، وَالنُّسُکُ شَاۃٌ۔",,,13955,,
13956,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : سَأَلَنِی سَعِیدُ بْنُ جُبَیْرٍ فَأَخْبَرْتُہُ ، فَقَالَ : ہَکَذَا قَالَ ابْنُ عَبَّاسٍ۔",,,13956,,
13957,"حدَّثَنَا أَبُو مُعَاوِیَۃَ، عَنِ الأَعْمَشِ، عَنْ إبْرَاہِیمَ، قَالَ: حدَّثَتْہُ سَعِیدَ بْنَ جُبَیْرٍ، فَقَالَ: ہَکَذَا قَالَ ابْنُ عَبَّاسٍ",,,13957,,
13958,"حدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ طَاوُوسٍ ، قَالَ : صِیَامٌ ثَلاَثَۃُ أَیَّامٍ ، وَنُسُکٌ شَاۃٌ ، وَصَدَقَۃٌ سِتَّۃُ مَسَاکِینَ۔",,,13958,,
13959,حدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ سُفْیَانَ ، عَنِ السُّدِّیِّ ، عَنْ أَبِی مَالِکٍ ؛ مِثْلَہُ۔,,,13959,,
13960,"حدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنْ عِکْرِمَۃَ ، قَالَ : سَمِعْتُہُ یَقُولُ فِیمَنْ حَجَّ فَأَصَابَہُ مَرَضٌ ، أَوْ أَذًی مِنْ رَأْسِہِ : فَعَلَیْہِ صِیَامُ عَشَرَۃِ أَیَّامٍ ، أَوْ إطْعَامُ عَشَرَۃِ مَسَاکِینَ ، أَوْ نُسُکُ شَاۃٍ۔",,,13960,,
13961,"حدَّثَنَا وَکِیعٌ ، عَنْ مُغِیرَۃَ بْنِ زِیَادٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : الْمُلْتَزَمُ مَا بَیْنَ الرُّکْنِ وَالْبَابِ۔",,,13961,,
13962,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ، عَنِ الشَّیْبَانِیِّ، قَالَ: رَأَیْتُ عَمْرَو بْنَ مَیْمُونٍ وَہُوَ مُلْتَزِمٌ مَا بَیْنَ الرُّکْنِ وَالْبَابِ۔",,,13962,,
13963,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، قَالَ : کَانُوا یَلْتَزِمُونَ مَا بَیْنَ الرُّکْنِ وَالْبَابِ ، وَیَدْعُونَ۔",,,13963,,
13964,"حدَّثَنَا رَوْحُ بْنُ عُبَادَۃَ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ الْعَدَنِیِّ ، قَالَ : رَأَیْتُ عِکْرِمَۃَ بْنَ خَالِدٍ ، وَأَبَا جَعْفَرٍ، وَعِکْرِمَۃَ مَوْلَی ابْنِ عَبَّاسٍ یَلْتَزِمُونَ مَا بَیْنَ الرُّکْنِ وَبَابِ الْکَعْبَۃِ ، وَرَأَیْتُہُمْ یَلْتَزِمُونَ مَا تَحْتَ الْمِیزَابِ فِی الْحِجْرِ۔",,,13964,,
13965,"حدَّثَنَا أَبُو یَحْیَی الرَّازِیّ إِسْحَاقُ بْنُ سُلَیْمَانَ ، عَنْ حَنْظَلَۃَ ، قَالَ : رَأَیْتُ سَالِمًا ، وَعَطَائً ، وَطَاوُسًا یَلْتَزِمُونَ مَا بَیْنَ الرُّکْنِ وَالْبَابِ۔",,,13965,,
13966,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : رَأَیْتُ عَمْرَو بْنَ مَیْمُونٍ یَلْتَزِمُ دُبُرَ الْکَعْبَۃِ۔",,,13966,,
13967,حدَّثَنَا وَکِیعٌ، عَنْ نَافِعِ بْنِ عُمَرَ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ، عَنْ عُمَرَ بْنِ عَبْدِالْعَزِیزِ؛ أَنَّہُ أَتَی دُبَرَ الْکَعْبَۃِ یَسْتَعِیذُ۔,,,13967,,
13968,"حدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ مُحَمَّدِ بْنِ صَالِحٍ ، قَالَ : رَأَیْتُ الْقَاسِمَ یَلْتَزِمُ جَانِب الْکَعْبَۃِ۔",,,13968,,
13969,"حدَّثَنَا أَبُو یَحْیَی الرَّازِیّ ، عَنْ حَنْظَلَۃَ ، قَالَ : رَأَیْتُ الْقَاسِمَ یَتَعَوَّذُ فِی دُبُرِ الْکَعْبَۃِ ،وَیَقُولُ : اللَّہُمَّ إنِّی أَعُوذُ بِکَ مِنْ بَأْسِکَ ، وَنِقْمَتِکَ ، وَسُلْطَانِک۔",,,13969,,
13970,"حدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ ثَابِتِ بْنِ قَیْسٍ ، قَالَ : رَأَیْتُ نَافِعَ بْنَ جُبَیْرٍ یَلْتَزِمُ مَا بَیْنَ الْبَابِ وَالْحَجَرِ ، وَخَلْفَ الْکَعْبَۃِ ، کُلاَّ قَدْ رَأَیْتُہُ یَفْعَل۔",,,13970,,
13971,"حدَّثَنَا مَعن بْنُ عِیسَی ، عَنْ خَالِدِ بْنِ أَبِی بَکْرٍ ، قَالَ : رَأَیْتُ عُبَیْدَ اللہِ بْنَ عَبْدِ اللہِ یَلْتَزِمُ خَلْفَ الْکَعْبَۃِ مِمَّا یَلِی الْمَغْرِبَ ، یُلْصِقُ بِہَا صَدْرَہُ۔",,,13971,,
13972,"حدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنٍ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : رَأَیْتُ عَمْرَو بْنَ مَیْمُونٍ قَدِ الْتَزَمَ الْکَعْبَۃَ ، وَأَلْصَقَ بَطْنَہُ مِنْ مُؤَخِّرِہَا ، مِنَ الْجَانِبِ الَّذِی یَلِی الرُّکْنَ الْیَمَانِیَّ۔",,,13972,,
13973,حدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ؛ أَنَّ أَبَاہُ کَانَ یَلْتَزِمُ دُبُرَ الْکَعْبَۃِ۔,,,13973,,
13974,"حدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنِ الأَعْمَشِ ، قَالَ : رَأَیْتُ أَبَا بَکْرِ بْنَ عَبْدِ الرَّحْمَنِ یَلْتَزِمُ مُؤَخِّرَ الْکَعْبَۃِ۔",,,13974,,
13975,"حدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ فِی الرَّجُلِ یَصُومُ فِی الْمُتْعَۃَ ، ثُمَّ یَجِدُ الْہَدْیَ قَبْلَ أَنْ یُتِمَّ صَوْمَہُ ، قَالَ : یَتْرُکُ الصَّوْمَ۔",,,13975,,
13976,حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ؛ فِی رَجُلٍ صَامَ الثَّلاَثَۃَ الأَیَّام فِی الْحَجِّ ، ثُمَّ أَیْسَرَ وَہُوَ بِمَکَّۃَ ، أَنَّ عَلَیْہِ الْہَدْیَ,,,13976,,
13977,"حدَّثَنَا وَکِیعٌ ، عَنْ شَرِیکٍ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، وَعِکْرِمَۃَ ؛ قَالاَ : إذَا أَیْسَرَ قَبْلَ أَنْ یَحْلِقَ فَلْیَذْبَحْ",,,13977,,
13978,"حدَّثَنَا ابْنُ أَبِی رَوَّادٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ مُجَاہِدٍ ؛ أَنَّہُ کَانَ یَقُولُ فِی فِدْیَۃِ الصِّیَامِ : {أَوْ صَدَقَۃٍ ، أَوْ نُسُکٍ} ، فِی یُسْرِہِ ذَلِکَ ، فِی حَجِّہ وَعُمْرَتِہِ۔",,,13978,,
13979,"حدَّثَنَا ابْنُ أَبِی رَوَّادٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ سُلَیْمَانَ بْنِ مُوسَی ، قَالَ : إِنْ کَانَ فِی الْحَجِّ فَحَتَّی یُحِلَّ ، وَإِنْ کَانَ فِی الْعُمْرَۃِ فَحَتَّی یَطُوفَ بِالْبَیْتِ۔",,,13979,,
13980,"حدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ إسْمَاعِیلَ بْنِ مُسْلِمٍ ، عَنْ عَطَائٍ ، وَابْنِ سِیرِینَ ، وَالْحَسَنِ قَالُوا: إذَا صُمْتَ فِی مُتْعَۃِ الْحَجِّ ، ثُمَّ وَجَدْتَ قَبْلَ أَنْ تَفْرُغَ مِنْ صِیَامِکَ فَکَفِّرْ ، وَإِنْ وَجَدْتَ وَقَدْ فَرَغْتَ مِنْ صِیَامِکَ ، فَلَیْسَ عَلَیْک کَفَّارَۃٌ۔",,,13980,,
13981,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ حَاتِمِ بْنِ أَبِی صَغِیرَۃَ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، قَالَ : سَمِعْتُ ابْنَ الزُّبَیْرِ یَقُولُ : لَقَدْ کَانَ ہَذَا الْبَیْتُ یَحُجُّہُ سَبْعُ مِئَۃٍ مِنْ بَنِی إسْرَائِیلَ ، یَضَعُونَ نِعَالَہُمْ بِالتَّنْعِیمِ ، وَیَدْخُلُونَ حُفَاۃً ، تَعْظِیمًا لِلْبَیْتِ۔ (فاکھیی 267)",,,13981,,
13982,"حدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : کَانُوا یَکْرَہُونَ أَنْ یَدْخُلُوا الْبَیْتَ بِالْخُفِّ ، وَالنَّعْلِ ، وَالْقَصَبِ ، تَعْظِیمًا لِلْبَیْتِ۔",,,13982,,
13983,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ شَرِیکٍ ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ یَطُوفُ وَعَلَیْہِ نَعْلاَہُ ، وَرَأَیْتُ ابْنَ الزُّبَیْرِ لاَ یَفْعَلُہُ۔",,,13983,,
13984,"حدَّثَنَا وَکِیعٌ، عَنْ إسْرَائِیلَ، عَنْ جَابِرٍ، قَالَ: رَأَیْتُ طَاوُوسًا ، وَمُجَاہِدًا ، وَعَطَائً ؛یَطُوفُونَ فِی نِعَالِہِمْ۔",,,13984,,
13985,"حدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرِ ، عَنْ مُصْعَبِ بْنِ شَیْبَۃَ ، عَنِ ابْنِ الزُّبَیْرِ ، قَالَ : کَانَتِ الأُمَّۃُ مِنْ بَنِی إسْرَائِیلَ إذَا أَتَوْا ذَا طُوًی خَلَعُوا نِعَالَہُمْ۔",,,13985,,
13986,"حدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ مُجَاہِدٍ ، قَالَ : کَانَتِ الأَنْبِیَائُ إذَا أَتَتْ عَلَم الْحَرَمِ نَزَعُوا نِعَالَہُمْ۔",,,13986,,
13987,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنِ الْحَسَنِ الْعُرَنِیِّ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إذَا رَمَیْتُمَ الْجَمْرَۃَ فَقَدْ حَلَّ لَکُمْ کُلُّ شَیْئٍ إِلاَّ النِّسَائُ ، وَقَالَ : أَمَّا أَنَا فَقَدْ رَأَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مُضَمِّخاً رَأْسَہُ بِالْمِسْکِ ، أَفَطِیبٌ ذَلِکَ ، أَمْ لاَ ؟۔ (احمد 1/369۔ ابویعلی 2688)",,,13987,,
13988,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إذَا رَمَی الْجَمْرَۃَ وَذَبَحَ وَحَلَقَ ، حَلَّ لَہُ کُلُّ شَیْئٍ إِلاَّ النِّسَائَ۔",,,13988,,
13989,حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی بَکْرِ بْنِ عَبْدِ اللہِ بْنِ أَبِی الْجَہْمِ ، عَنْ عَمْرَۃَ ، عَنْ عَائِشَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ مِثْلَہُ۔ (ابوداؤد 1972۔ احمد 6/143),,,13989,,
13990,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ ابْنِ الْمُنْکَدِرِ ، سَمِعَ ابْنَ الزُّبَیْرِ یَقُولُ : إذَا رَمَیْتَ الْجَمْرَۃَ مِنْ یَوْمِ النَّحْرِ ، فَقَدْ حَلَّ لَکَ مَا وَرَائَ النِّسَائِ۔",,,13990,,
13991,"حدَّثَنَا وَکِیعٌ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ، عَنْ أَبِیہِ، عَنْ عَائِشَۃَ، قَالَتْ: إذَا رَمَی حَلَّ لَہُ کُلُّ شَیْئٍ إِلاَّ النِّسَائَ۔",,,13991,,
13992,"حدَّثَنَا جَرِیرٌ ، قَالَ : حدَّثَنَا مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا حَلَقَ المُحْرِمُ حَلَّ لَہُ کُلُّ شَیْئٍ إِلاَّ النِّسَائَ ، حَتَّی یَطُوفَ بِالْبَیْتِ ، فَإِذَا طَافَ بِالْبَیْتِ حَلَّ لَہُ النِّسَائُ۔",,,13992,,
13993,"حدَّثَنَا وَکِیعٌ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، قَالَ : إذَا رَمَی الْجَمْرَۃَ حلَّ لَہُ کُلُّ شَیْئٍ ، إِلاَّ النِّسَائَ۔",,,13993,,
13994,"حدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ أَشْعَثَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، وَعُمَر ؛ أَنَّہُما قَالاَ : إذَا نَحَرَ الرَّجُلُ وَحَلَقَ ، حَلَّ لَہُ کُلُّ شَیْئٍ إِلاَّ النِّسَائَ وَالطِّیبَ۔",,,13994,,
13995,"حدَّثَنَا وَکِیعٌ ، عَنْ نَافِعِ بْنِ عُمَرَ ، عَنْ عَطَائٍ ، قَالَ : إذَا رَمَی الْجَمْرَۃَ حَلَّ لَہُ کُلُّ شَیْئٍ ، إِلاَّ النِّسَائَ۔",,,13995,,
13996,"حدَّثَنَا ابْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : إذَا رَمَی جَمْرَۃَ الْعَقَبَۃِ حَلَّ لَہُ کُلُّ شَیْئٍ ، إِلاَّ الطِّیبَ ، وَالنِّسَائَ ، وَالصَّیْدَ۔",,,13996,,
13997,"حدَّثَنَا حَفْصٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطَائٍ ، قَالَ : إذَا قَضَیْتُمَ الْمَنَاسِکَ کُلَّہَا فَقَدْ حَلَّ لَکُمْ کُلُّ شَیْئٍ ، إِلاَّ النِّسَائَ ، وَالصَّیْدَ۔",,,13997,,
13998,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ سُلَیْمَانَ ، قَالَ : قبَّلْتُ امْرَأَتِی بَعْدَ مَا رَمَیْتُ الْجَمْرَۃَ فَسَأَلْتُ عَطَائً ؟ فَأَمَرَنِی أَنْ أَذْبَحَ شَاۃً۔",,,13998,,
13999,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنِ الْقَاسِمِ ، عَنِ ابْنِ الزُّبَیْرِ ، قَالَ : إذَا رَمَی الْجَمْرَۃَ حَلَّ لَہُ کُلُّ شَیْئٍ ، إِلاَّ النِّسَائَ۔",,,13999,,
14000,حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْحَکَمِ ، عَنْ مِقْسَمٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَہْدَی فِی بُدْنِہِ جَمَلاً لأَبِی جَہْلٍ بُرَّتُہُ مِنْ فِضَّۃٍ۔ (ابن ماجہ 3100۔ احمد 1/234),,,14000,,
14001,"حدَّثَنَا عُبَیْدُ اللہِ ، قَالَ : أَخْبَرَنَا مُوسَی بْنُ عُبَیْدَۃَ ، عَنْ إیَاسِ بْنِ سَلَمَۃَ ، عَنْ أَبِیہِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ فِی بُدْنِہِ جَمَل۔ (ابن ماجہ 3101)",,,14001,,
14002,"حدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ زَیْدِ بْنِ جُبَیر ، قَالَ : سَأَلَ رَجُلٌ ابْنَ عُمَرَ : مَا تَرَی فِی بَدَنَۃٍ ، أَنْحَرُ مَکَانَہَا جَمَلاً ؟ قَالَ : مَا رَأَیْتُ أَحَدًا فَعَلَ ذَلِکَ ، وَلأَنْ أَنْحَرَ أُنْثَی أَحَبُّ إلَیَّ۔",,,14002,,
14003,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ یَحْیَی بْنِ یَحْیَی الْغَسَّانِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ، قَالَ : لاَ بَأْسَ بِالْہَدْیِ الذَّکَرِ مِنَ الإِبِلِ۔",,,14003,,
14004,"حدَّثَنَا إسْمَاعِیلُ بْنُ إِبْرَاہِیمَ ، عَن أَیُّوبَ ، عَنْ نَافِعٍ ، قَالَ : مَا رَأَیْتُ أَحَدًا أَہْدَی جَمَلاً إِلاَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ ، فَإِنَّہُ أَہْدَی بُخْتِیًّا۔",,,14004,,
14005,"حدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : تُہْدَی الإِنَاثُ وَالذُّکُورُ ، وَالإِنَاثُ أَحَبُّ إلَیَّ۔",,,14005,,
14006,"حدَّثَنَا وَکِیعٌ ، عَنْ مَالِکِ بْنِ أَنَسٍ ، قَالَ : حدَّثَنِی أَبُو جَعْفَرٍ مَوْلَی ابْنِ عَیَّاشٍ ، قَالَ : رَأَیْتُ ابْنَ عَیَّاشٍ أَہْدَی مَرَّۃَ بَدَنَتَیْنِ ، إِحْدَاہُمَا بُخْتِیَّۃٌ۔",,,14006,,
14007,حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ أَبِی سُلَیْمَانَ ، عَنْ مَوْلًی لِابْنِ عُمَرَ ؛ أَنَّ ابْنَ عُمَرَ أَہْدَی بُخْتِیَّۃً۔,,,14007,,
14008,حدَّثَنَا وَکِیعٌ ، عَنْ زَمْعَۃَ ، عَنْ سَلَمَۃَ بْنِ وَہْرَامٍ ، عَنْ طَاوُوسٍ ، أَنَّہُ أَہْدَی عَنْ مُتْعَتِہِ جَمَلاً۔,,,14008,,
14009,"حدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ رَبَاحِ بْنِ أَبِی مَعْرُوفٍ ، قَالَ : قیلَ لِعَطَائٍ : إنَّ عِکْرِمَۃَ بْنَ خَالِدٍ أَہْدَی جَمَلاً ، قَالَ عَطَائٌ : وَمَا بَأْسُ ذَلِکَ۔",,,14009,,
14010,"حدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : کَانَ فِیمَا أَہْدَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ جَمَلٌ لأَبِی جَہْلٍ فِی أَنْفِہِ بُرَّۃٌ مِنْ فِضَّۃٍ۔ (ترمذی 815۔ ابوداؤد 1746)",,,14010,,
14011,حدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مُحَمَّدٍ الْمُحَارِبِیُّ ، عَنْ لَیْثٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ أَہْدَی جَمَلاً۔,,,14011,,
14012,"حدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : عُمْرَتُہُ فِی الشَّہْرِ الَّذِی یُحِلُّ فِیہِ۔",,,14012,,
14013,"حدَّثَنَا إِسْحَاقُ الأَزْرَقُ ، عَنْ مُثَنَّی ، عَنْ طاوُوسٍ قَالَ : عُمْرَتُہُ فِی الشَّہْرِ الَّذِی دَخَلَ فِیِہِ الْحَرَمَ۔",,,14013,,
14014,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مَطَرٍ ، عَنِ الْحَسَنِ ، وَعَطَائٍ ، وَالْحَکَمِ ؛ قَالُوا : مَنِ اعْتَمَرَ فِی شَہْرٍ ، ثُمَّ طَافَ فِی شَہْرٍ آخَرَ ، فَعُمْرَتُہُ فِی الشَّہْرِ الَّذِی طَافَ فِیہِ۔",,,14014,,
14015,"حدَّثَنَا غُنْدَرٌ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ؛ أَنَّہُ قَالَ : عُمْرَتُہُ فِی الشَّہْرِ الَّذِی أَحْرَمَ فِیہِ۔",,,14015,,
14016,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : عُمْرَتُہُ فِی الشَّہْرِ الَّذِی یُہلُّ فِیہِ۔",,,14016,,
14017,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ رَجُلٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : عُمْرَتُہُ فِی الشَّہْرِ الَّذِی أَحْرَمَ فِیہِ۔",,,14017,,
14018,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا ہِشَامٌ ، قَالَ : حَدَّثَتْنَا حَفْصَۃُ بِنْتُ سِیرِینَ قَالَتْ : خَرَجْتُ أَنَا وَإِخْوَتِی ، فَأَہْلَلْنَا فِی رَمَضَانَ بِالْعُمْرَۃِ ، فَعَرَضَ لَنَا حَبْس حَتَّی دَخَلَ شَوَّالُ ، فَسَأَلْنَا أَہْلَ مَکَّۃَ ؟ فَکُلُّہُمْ قَالَ لِی: ہِیَ مُتْعَۃٌ۔",,,14018,,
14019,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ قَالَ : عُمْرَتُہُ فِی الشَّہْرِ الَّذِی أَحْرَمَ فِیہِ۔",,,14019,,
14020,"حدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : یُشْہَدُ بِالْمَرِیضِ الْمَنَاسِکُ کُلُّہَا ، وَیُطَافُ بِہِ عَلَی مَحْمَلٍ ، فَإِذَا رَمَی الْجِمَارَ وُضِعَ فِی کَفِّہِ ، ثُمَّ رُمِیَ بِہِ مِنْ کَفِّہِ۔",,,14020,,
14021,") حدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، قَالَ : یُرْمَی عَنْہُ۔",,,14021,,
14022,"حدَّثَنَا مُعْتَمِرٌ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ : الْمَرِیضُ یُرْمَی عَنْہُ ، وَیُطَافُ عَنْہُ۔",,,14022,,
14023,"حدَّثَنَا أَبُو أُسَامَۃَ ، عن ہِشَامٍ ، عَنِ الْحَسَنِ ، وَعَطَائٍ ؛ قَالاَ : یُرْمَی عَنْہُ۔",,,14023,,
14024,"حدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ الْجَبَّارِ بْنِ وَرْدٍ ، قَالَ : أَرْسَلَنِی أَبِی إلَی مُجَاہِدٍ وَہُوَ مَرِیضٌ أَسْأَلُہُ عَنْ رَمْیِ الْجِمَارِ ؟ قَالَ : یَرْمِی عَنہ أَوْلَی أَہْلِہِ بِہِ۔",,,14024,,
14025,"حدَّثَنَا شَرِیکٌ ، عَنْ إبْرَاہِیمَ بْنِ الْمُہَاجِرِ ، عَنْ عَطَائٍ ؛ قَالَ : یَسْتَأْجِرُ الْمَرِیضُ مَنْ یَطُوفُ عَنْہُ۔",,,14025,,
14026,"حدَّثَنَا وَکِیعٌ ، عَنْ حَنْظَلَۃَ ، قَالَ : سُئِلَ طَاوُوس عَنِ امْرَأَۃٍ مَرِیضَۃٍ ؟ قَالَ : یَرْمِی عَنْہَا بَعْضُ أَہْلِہَا۔",,,14026,,
14027,"حدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ أَشْعَثَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : حجَجْنَا مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَمَعَنَا النِّسَائُ وَالصِّبْیَانُ ، فَلَبَّیْنَا عَنِ الصِّبْیَانِ وَرَمَیْنَا عَنْہُمْ۔ (احمد 3/314۔ بیہقی 156)",,,14027,,
14028,"حدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، قَالَ : رَأَیْتُ ابْنًا لِعَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، فَقُلْتُ : کَیْفَ تَصْنَعُونَ بِہَذَا ؟ فَقَالُوا : نَضَعُ الْحَصَاۃَ فِی کَفِّہِ ، فَإِنْ عَجَزَ رُمِیَ عَنْہُ۔",,,14028,,
14029,"حدَّثَنَا عَبْدُ الأَعْلَی بْنِ عَبْدِ الأَعْلَی ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : کَانَ یَحُجُّ بِصِبْیَانِہِ فَمَنِ اسْتَطَاعَ مِنْہُمْ أَنْ یَرْمِیَ رَمَی ، وَمَنْ لَمْ یَسْتَطِعْ رَمَی عَنْہُ۔",,,14029,,
14030,"حدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ حَبِیبٍ الْمُعَلِّمِ ، عَنْ عَطَائٍ قَالَ : أَفَیُرْمَی عَنْہُ الْجِمَارَ ؟ قَالَ : نَعَمْ۔",,,14030,,
14031,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ، عَنْ عَبْدِ الْمَلِکَ، عَنْ عَطَائٍ ؛ فِی الصَّبِیِّ یُحْرِمُ ، قَالَ: یُلَبِّی عَنْہُ وَالِدُہُ ، أَوْ وَلِیُّہُ۔",,,14031,,
14032,حدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ قَتَادَۃَ ، عَنْ أَبِی حَسَّانٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَشْعَرَ الْہَدْیَ فِی السَّنَامِ الأَیْمَنِ ، وَأَمَاطَ عَنْہُ الدَّمَ۔,,,14032,,
14033,حدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ إذَا أَرَادَ أَنْ یُشْعِرَ الْبَدَنَۃَ أَشْعَرَہَا مِنَ الْجَانِبِ الأَیْمَنِ۔,,,14033,,
14034,حدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ إذَا کَانَتْ بَدَنَۃٌ وَاحِدَۃٌ أَشْعَرَہَا فِی شِقِّہَا الأَیْسَرِ بِیَدِہِ الْیُمْنَی ، وَإِذَا کَانَتْ بَدَنَتَیْنِ أَشْعَرَ إحْدَاہُمَا فِی الشِّقِّ الأَیْمَنِ ، وَالأُخْرَی فِی الأَیْسَرِ۔,,,14034,,
14035,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سَالِمٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ أَنَّہُ قَالَ : یُشْعِرُ فِی الأَیْمَنِ۔",,,14035,,
14036,حدَّثَنَا إِسْحَاقُ بْنُ سُلَیْمَانَ الرَّازِیّ ، عَنْ أَفْلَحَ ، عَنِ الْقَاسِمِ ؛ أَنَّہُ کَانَ یُشْعِرُ فِی الأَیْمَنِ۔,,,14036,,
14037,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ؛ أَنَّہُ قَالَ : أَشْعِرہَا مِنْ حَیْثُ شِئْتَ۔",,,14037,,
14038,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ عِکْرِمَۃَ ، قَالَ : کَانَ أُنَاسٌ یَقْدُمُونَ مَکَّۃَ بِغَیْرِ زَادٍ ، فَنَزَلَتْ : {وَتَزَوَّدُوا فَإِنَّ خَیْرَ الزَّادِ التَّقْوَی}۔",,,14038,,
14039,"حدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ الْمَلِکِ بْنِ عَطَائٍ الْبَکَّائِیِّ ، قَالَ : سَأَلْتُ الشَّعْبِیَّ عَنْ قَوْلِہِ تَعَالَی : {وَتَزَوَّدُوا فَإِنَّ خَیْرَ الزَّادِ التَّقْوَی}؟ قَالَ : الطَّعَامُ ، وَالطَّعَامُ یَوْمَئِذٍ قَلِیلٌ ، قُلْتُ : وَمَا الطَّعَامُ ؟ قَالَ : السَّوِیقُ وَالتَّمْرُ۔",,,14039,,
14040,"حدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنِ ابْنِ سُوقَۃَ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ؛ {وَتَزَوَّدُوا} قَالَ: الْخُشْکِنَانْجُ وَالسَّوِیقُ۔",,,14040,,
14041,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مُغِیرَۃَ ، عَنِ الشَّعْبِیِّ ، قَالَ : کَانَ نَاسٌ مِنْ أَہْلِ الْیَمَنِ إذَا حَجُّوا لَمْ یَتَزَوَّدُوا ، حَتَّی یَبْلُغُوا عَقَبَۃَ کَذَا وَکَذَا ، فَنَزَلَتْ : {وَتَزَوَّدُوا فَإِنَّ خَیْرَ الزَّادِ التَّقْوَی}۔",,,14041,,
14042,"حدَّثَنَا وَکِیعٌ ، عَنْ عُمَرَ بْنِ ذَرٍّ ، عَنْ مُجَاہِدٍ ، قَالَ : کَانُوا لاَ یَتَزَوَّدُونَ فِی حَجِّہِمْ حَتَّی نَزَلَتْ : {وَتَزَوَّدُوا فَإِنَّ خَیْرَ الزَّادِ التَّقْوَی} فَتَزَوَّدُوا الطَّعَامَ۔",,,14042,,
14043,حدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ؛ أَنَّ عُمَرَ بْنَ الْخَطَّابِ أَمَرَ الصُّبَیَّ بْنَ مَعْبَدٍ حَیْثُ ، أَوْ حِینَ قَرَنَ أَنْ یَذْبَحَ کَبْشًا۔,,,14043,,
14044,"حدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : الشَّاۃُ تُجْزِئُ عَنِ الْقَارِنِ مِنْ ہَدْیِہِ وَأُضحَاہُ۔",,,14044,,
14045,"حدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ عَلِیٍّ ، عَنْ عِکْرِمَۃَ ، قَالَ : یُجْزِئُ ہَدْیَہُ مِنْ أُضْحِیَّتِہِ۔",,,14045,,
14046,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ لَیْثٍ ، قَالَ : سُئِلَ طَاوُوس عَنِ امْرَأَۃٍ تَمَتَّعَتْ فَلَمْ تَذْبَحْ وَضَحَّتْ ؟ قَالَ : تُجْزِئْہَا۔",,,14046,,
14047,"حدَّثَنَا غُنْدَرٌ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ عُمَرَ بْنِ عبْدِ الْعَزِیزِ ؛ أَنَّہُ کَانَ یَأْمُرُ بِالْمُتْعَۃِ وَیَحُثُّ عَلَیْہَا وَیَقُولُ : تُجْزِیئُ عَنْہُ شَاۃٌ۔",,,14047,,
14048,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنِ الزُّہْرِیِّ ، قَالَ : مَنْ أُحْصِرَ بِالْحَرْبِ نَحَرَ مِنْ حَیْثُ حُبِسَ ، وَحَلَّ مِنَ النِّسَائِ وَمِنْ کُلِّ شَیْئٍ ، کَمَا صَنَعَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,14048,,
14049,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، وَأَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ؛ فِی الْمُحْصَرِ ، قَالَ: یَبْعَثُ بِہَدْیِہِ ، فَإِذَا ذُبِحَ حَلَّ۔",,,14049,,
14050,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : سَأَلَنِی سَعِیدُ بْنُ جُبَیْرٍ عَنْ ہَذا ؟ فَأَخْبَرْتُہُ، فَقَالَ : بِیَدِہِ : ہَکَذَا قَالَ ابْنُ عَبَّاسٍ۔",,,14050,,
14051,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامِ بْنِ حَسَّانٍ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ؛ قَالَ فِی الْمُحْصَرِ : إِذَا رَجَعَ لاَ یَحِلُّ مِنْہُ إِلاَّ رَأْسُہُ۔",,,14051,,
14052,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنْ عَطَائٍ ، قَالَ : قدْ حَلَّ مِنْ کُلِّ شَیْئٍ ، فَہُوَ بِمَنْزِلَۃِ الْحَلاَلِ۔",,,14052,,
14053,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ عُمَارَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، عَنْ عَبْدِ اللہِ ، قَالَ : إذَا نُحِرَ ہَدْیُہُ حَلَّ۔",,,14053,,
14054,"حدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، عَنْ أَبِیہِ ؛ أَنَّ رَجُلاً مِنْ وَہْبِیل أُحْصِرَ ، فَقَالَ عَبْدُ اللہِ : إذَا ذُبِحَ ہَدْیُہُ حَلَّ مِنْ کُلِّ شَیْئٍ۔",,,14054,,
14055,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ فِی الْمُحْصَرِ ، قَالَ : یَبْعَثُ بِالْہَدْیِ ، فَإِذَا نُحِرَ حَلَّ ، وَعَلَیْہِ حَجٌّ مِنْ قَابِلٍ۔",,,14055,,
14056,"حدَّثَنَا ابْنُ أَبِی عَدِیٍّ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : کَانَ یَقُولُ : إذَا فَرَضَ الرَّجُلُ الْحَجَّ فَأَصَابَہُ حَصْرٌ ، فَإِنَّہُ یَبْعَثُ بِہَدْیِہِ ، فَإِذَا بَلَغَ الْہَدْیُ مَحِلَّہُ ، فَإِنَّہُ إِنْ شَائَ رَجَعَ وَحَلَّ مِنْ أَشْیَائَ وَحَرُمَ مِنْ أُخْرَی۔",,,14056,,
14057,"حدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : سَأَلْتُ سَالِمًا ، وَالْقَاسِمَ عَنِ الْمُحْصَرِ ؟ فَقَالاَ فِیہِ قَوْلَ مُحَمَّدٍ۔",,,14057,,
14058,"حدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : إِذَا ذُبِحَ ہَدْیُ الْمُحْصَرِ حَلَّ لَہُ کُلُّ شَیْئٍ۔",,,14058,,
14059,"حدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، عَنْ عَلْقَمَۃَ ، وَالأَسْوَدِ ؛ أَنَّہُمَا قَالاَ : إِنَّ مِنْ تَمَامِ الْحَجِّ أَنْ یَشْہَدَ الصَّلاَتَیْنِ مَعَ الإِمَامِ بِعَرَفَۃَ۔",,,14059,,
14060,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یَسْتَحِبُّونَ أَنْ یُصَلُّوا الصَّلاَتَیْنِ ؛ الظُّہْرَ ، وَالْعَصْرَ مَعَ الإِمَامِ بِعَرَفَۃَ۔",,,14060,,
14061,حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنِ ابْنِ الأَسْوَدِ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یُصَلِّی الصَّلاَتَیْنِ مَعَ الإِمَامِ بِعَرَفَۃَ ، الظُّہْرَ وَالْعَصْرَ۔,,,14061,,
14062,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، عَنْ عَمْرِو بْنِ عَبْدِ اللہِ بْنِ صَفْوَانَ ، عَنْ یَزِیدَ بْنِ شَیْبَانَ، قَالَ: کُنَّا وُقُوفًا فِی مَکَان بَعِیدٍ، نُبَاعِدُہُ مِنَ الْمَوْقِفِ، فَأَتَانَا ابْنُ مِرْبَعٍ، فَقَالَ: إنِّی رَسُولُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إلَیْکُمْ یَقُولُ: کُونُوا عَلَی مَشَاعِرِکُمْ، فَإِنَّکُمَ عَلَی إرْثٍ مِنْ إرْثِ إبْرَاہِیمَ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔\n\n(ترمذی 883۔ ابوداؤد 1914)",,,14062,,
14063,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ الْمُنْکَدِرِ ، وَزَیْدِ بْنِ أَسْلَمَ ؛ قَالاَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : عَرَفَۃُ کُلُّہَا مَوْقِفٌ ، وَارْتَفِعُوا عَنْ بَطْنِ عُرَنَۃَ۔ (احمد 4/82۔ بزار 3443)",,,14063,,
14064,"حدَّثَنَا وَکِیعٌ ، عَنْ أُسَامَۃَ ، عَنْ عَطَائٍ ، عَنْ جَابِرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : عَرَفَۃُ کُلُّہَا مَوْقِفٌ۔ (ابوداؤد 1932۔ دارمی 1879)",,,14064,,
14065,"حدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ؛ سَمِعَہُ یَقُولُ : عَرَفَۃُ کُلُّہَا مَوْقِفٌ ، فَمَنْ شَائَ بَلَغَ مَوْقِفَ الإِمَامِ ، وَمَنْ شَائَ فَدُونَہُ۔",,,14065,,
14066,"حدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنِ ابْنِ الزُّبَیْرِ، قَالَ: عَرَفَۃُ کُلُّہَا مَوْقِفٌ، إِلاَّ بَطْنَ عُرَنَۃَ۔",,,14066,,
14067,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الْکَرِیمِ ، قَالَ : حدَّثَنِی مَنْ رَأَی ابْنَ عَبَّاسٍ وَاقِفًا عِنْدَ الْحِیَاضِ ، یَعْنِی بِعَرَفَۃَ۔",,,14067,,
14068,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامِ بْنِ حَسَّانٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ قَالَ : عَرَفَۃُ کُلُّہَا مَوْقِفٌ ، إِلاَّ بَطْنَ عُرَنَۃَ۔",,,14068,,
14069,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یُحِبُّونَ أَنْ یَقِفَ الرَّجُلُ قَرِیبًا مِنَ الإِمَامِ ، قَالَ عَبْدُ اللہِ بْنُ عُمَرَ : یَا أَیُّہَا النَّاسُ ، لاَ تَقْتُلُوا أَنْفُسَکُمْ ، فَإِنَّ کُلَّ مَا ہَاہُنَا مَوْقِفٌ۔",,,14069,,
14070,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ مُحَمَّدِ بْنِ الْمُنْکَدِرِ ، سَمِعَ سَعِیدَ بْنَ عَبْدِ الرَّحْمَنِ بْنَ یَرْبُوعٍ یُخْبِرُ ، عَنْ جُبَیِْرِ بْنِ الْحُوَیْرِثِ ، سَمِعْتُ أَبَا بَکْرٍ وَہُوَ وَاقِفٌ عَلَی قُزَحٍ وَہُوَ یَقُولُ: یَا أَیُّہَا النَّاسُ ، أَصْبِحُوا، أَصْبِحُوا، ثُمَّ دَفَعَ ، فَکَأَنِّی أَنْظُرُ إلَی فَخِذِہِ قَدِ انْکَشَفَت مِمَّا یُحَرِّشُ بَعِیرَہُ بِمِحْجَنِہِ۔",,,14070,,
14071,"حدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، عَنِ ابْنِ الزُّبَیْرِ ، قَالَ : الْمُزْدَلِفَۃُ کُلُّہَا مَوْقِفٌ ، إِلاَّ بَطْنَ مُحَسِّرٍ۔",,,14071,,
14072,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ قَالَ : جَمْعٌ کُلُّہَا مَوْقِفٌ ، إِلاَّ بَطْنَ مُحَسِّرٍ۔",,,14072,,
14073,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ نَافِعٍ ، قَالَ : قُلْتُ لَہُ : أَیْنَ کَانَ ابْنُ عُمَرَ یَقِفُ مِنْ جَمْعٍ ؟ قَالَ : کَانَ لاَ یَنْتَہِی یَتَخَلَّصُ حَتَّی یَقِفَ عَلَی قُزَحٍ۔",,,14073,,
14074,"حدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : سَأَلْتُ عَطَائً : أَیْنَ مِنًی ؟ فَقَالَ : مَا بَیْنَ الْعَقَبَۃِ إلَی مُحَسِّرٍ، فَمَا أُحِبُّ أَنْ یَنْزِلَ أَحَدٌ إِلاَّ فِیمَا بَیْنَ الْعَقَبَۃِ إلَی مُحَسِّرٍ۔",,,14074,,
14075,"حدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حُسَیْنِ بْنِ عُقَیْلٍ ، عَنِ الضَّحَّاکِ ، قَالَ : قِفْ خَلْفَ الْمَشْعَرِ الْحَرَامِ، فَإِنْ لَمْ تَقْدِرْ ، فَإِذَا حَاذَیْتَ بِہِ ذَکَرْتَ اللَّہَ وَدَعَوْتہ ، فَإِنَّہُ تَعَالَی قَالَ : {اُذْکُرُوا اللَّہَ عِنْدَ الْمَشْعَرِ الْحَرَامِ}۔",,,14075,,
14076,"حدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حُسَینٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یَسْتَحِبُّونَ أَنْ یَقِفُوا بِالْمُزْدَلِفَۃِ ، حِیَالَ الْجَبَلِ۔",,,14076,,
14077,حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ ضَحَّی بِالْمَدِینَۃِ ، وَحَلَقَ رَأْسَہُ۔,,,14077,,
14078,"حدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ مُحَمَّدِ بْنِ أَبِی إسْمَاعِیلَ ، عَنْ إبْرَاہِیمَ ، قَالَ : سَمِعْتُہُ یَقُولُ : لَیْسَ الْحَلْقُ إِلاَّ بِمَکَّۃَ۔",,,14078,,
14079,حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ نَافِعٍ ، أَوْ عَبْدِ اللہِ بْنِ أَبِی سَلَمَۃَ ؛ أَنَّ ابْنَ عُمَرَ کَانَ إذَا لَمْ یَحُجَّ حَلَقَ رَأْسَہُ۔,,,14079,,
14080,حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ؛ أَنَّ الْحَسَنَ کَانَ یَحْلِقُ رَأْسَہُ یَوْمَ النَّحْرِ بِالْبَصْرَۃِ۔,,,14080,,
14081,"حدَّثَنَا ابْنُ أَبِی عَدِیٍّ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : قُلْتُ لِمُحَمَّدٍ : کَانُوا یَسْتَحِبُّونَ أَنْ یَأْخُذَ الرَّجُلُ مِنْ شَعْرِہِ یَوْمَ النَّحْرِ ؟ قَالَ : نَعَمْ۔",,,14081,,
14082,حدَّثَنَا حَاتِم بْنُ إسْمَاعِیلَ، عَنْ جَعْفَرٍ، عَنْ أَبِیہِ، عَنْ جَابِرٍ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سَاقَ مِئَۃ بَدَنَۃٍ۔,,,14082,,
14083,حدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّ الأَشْعَرِیَّ أَہْدَی بُدْنًا مُجَلَّلَۃً۔,,,14083,,
14084,حدَّثَنَا وَکِیعٌ ، عَنْ أَفْلَحَ ، عَنِ الْقَاسِمِ ؛ أَنَّہُ أَہْدَی بَدَنَۃً۔,,,14084,,
14085,حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنِ الْقَاسِمِ ؛ أَنَّ ابْنَ الزُّبَیْرِ سَاقَ عَشْرَ بَدَنَاتٍ۔,,,14085,,
14086,حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ دِینَارٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یُہْدِی فِی الْحَجِّ بَدَنَتَیْنِ ، وَفِی الْعُمْرَۃِ بَدَنَۃً۔,,,14086,,
14087,"حدَّثَنَا وَکِیعٌ ، عَنْ مَالِکِ بْنِ أَنَسٍ ، عَنْ أَبِی جَعْفَرٍ مَوْلَی ابْنِ عَیَّاشٍ ، قَالَ : رَأَیْتُ عَبْدَ اللہِ بْنَ عَیَّاشٍ أَہْدَی مَرَّۃً بَدَنَتَیْنِ ، إحْدَاہُمَا بُخْتِیَّۃٌ۔",,,14087,,
14088,حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، عَنْ أَبِیہِ ؛ أَنَّہُ أَہْدَی بَدَنَۃً۔,,,14088,,
14089,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنْ سُلَیْمَانَ بْنِ عَمْرِو بْنِ الأَحْوَص الأَزْدِیِّ ، عَنْ أُمِّہِ، قَالَتْ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : لاَ یَقْتُلُ بَعْضُکُمْ بَعْضًا ، وَإِذَا رَمَیْتُمُ الْجَمْرَۃَ فَارْمُوا بِمِثْلِ حَصَی الْخَذْفِ۔ (ابوداؤد 1961۔ احمد 5/376)",,,14089,,
14090,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، رَفَعَہُ ، قَالَ : ارْمُوہَا بِمِثْلِ حَصَی الْخَذْفِ۔\n\n(ترمذی 886۔ احمد 3/301)",,,14090,,
14091,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ حُمَیْدٍ الأَعْرَجِ ، عَنْ مُحَمَّدِ بْنِ إِبْرَاہِیمَ ، عَن رَجُلٍ مِنْ قَوْمِہِ ، قَالَ : سَمِعْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُعَلِّمُ النَّاسَ مَنَاسِکَہُمْ ، قَالَ : ثُمَّ قَالَ : ارْمُوا الْجَمْرَۃَ بِمِثْلِ حَصَی الْخَذْفِ۔ (ابوداؤد 1952۔ احمد 4/61)",,,14091,,
14092,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جابر ، قَالَ : ارْمُوا الْجَمْرَۃَ بِمِثْلِ حَصَی الْخَذْفِ۔",,,14092,,
14093,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ ، قَالَ : کُنَّا نَلْتَقِطُ حَصَی الْخَذْفِ۔",,,14093,,
14094,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : سَأَلْتُ عَطَائً عَنْ حَصَی رَمْیِ الْجِمَارِ ؟ قَالَ : کَانَ یُقَالُ: حَصًی بَیْنَ الْحَصَاتَیْنِ ، قَالَ : قُلْتُ : مَا ہُوَ ؟ قَالَ : حَصَی الَّذِی یُخْذَفُ بِہِ۔",,,14094,,
14095,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ عُبَیْدِ بْنِ عُمَیْرٍ ، قَالَ : الْحَصَی الَّذِی تُرْمَی بِہِ الْجِمَارُ مِثْلُ حَصَی الْخَذْفِ۔",,,14095,,
14096,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ أَبِی مَعْبَدٍ ، عَنِ ابْنِ عَبَّاسٍ ، عَنِ الْفَضْلِ بْنِ عَبَّاسٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : ارْمُوا الْجَمْرَۃَ بِمِثْلِ حَصَی الْخَذْفِ۔\n\n(مسلم 268۔ دارمی 1891)",,,14096,,
14097,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَوْفٍ ، عَنْ زِیَادِ بْنِ الْحُصَیْنِ ، قَالَ : حدَّثَنِی أَبُو الْعَالِیَۃِ عَنِ ابْنِ عَبَّاسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ غَدَاۃَ الْعَقَبَۃِ : اُلْقُطْ لِی حَصًی ، قَالَ : فَلَقَطْتُ لَہُ حَصَیَاتٍ ، ہُنَّ حَصَی الْخَذْفِ ، قَالَ : فَقَالَ : بِمِثْلِ ہَذَا فَارْمُوا : ثُمَّ قَالَ : إیَّاکُمْ وَالْغُلُوَّ فِی الدِّینِ۔",,,14097,,
14098,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَمْرِو بْنِ یَحْیَی بْنِ قِمْطَۃَ ، عَنْ سَالِمٍ ، قَالَ : تُجْزِئُ الْمَکْتُوبَۃُ مِنْ رَکْعَتَیِ الطَّوَافِ۔",,,14098,,
14099,"حدَّثَنَا غُنْدَرٌ ، عَنْ مَعْمَرٍ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ ، قَالَ : تُجْزِئُ الْمَکْتُوبَۃُ مِنْ رَکْعَتَیِ الطَّوَافِ۔",,,14099,,
14100,"حدَّثَنَا وَکِیعٌ ، عَنْ شَرِیکٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : تُجْزِئُ الْمَکْتُوبَۃُ مِنْ رَکْعَتَیِ الطَّوَافِ۔",,,14100,,
14101,"حدَّثَنَا شَرِیکٌ ، عَنْ عَبْدِ الْمَلِکِ ، قَالَ : طُفْتُ بِالْبَیْتِ وَحَضَرْتُ الْمَکْتُوبَۃَ ، فَأَرَدْتُ أَنْ أُصَلِّیَ رَکْعَتَیْنِ، وَثَمَّ أُنَاسٌ جُلُوسٌ ، فَأَتَیْتُ حَلْقَۃً فَسَأَلْتُہُمْ ؟ فَقَالَ لِی شَیْخٌ : أَمَا تَرْضَی بِابْنِ عُمَرَ ؟ رَأَیْتُہُ یَفْعَلُہُ۔",,,14101,,
14102,"حدَّثَنَا وَکِیعٌ ، عَنْ عُمَرَ بْنِ ذَرٍّ ، عَنْ مُجَاہِدٍ (ح) وَعَنْ إسْمَاعِیلَ بْنِ عبْدِ الْمَلِکِ ، عَنْ عَطَائٍ (ح) وَعَنْ مِسْعَرٍ ، عَنْ وَبَرَۃَ ، عَنِ ابْنِ الأَسْوَدِ (ح) وَعَنْ سُفْیَانَ ، عَنْ رَجُلٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ قَالُوا : تُجْزِئُ الْمَکْتُوبَۃُ مِنْ رَکْعَتَیِ الطَّوَافِ۔",,,14102,,
14103,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ، قَالَ : مَضَتِ السُّنَّۃُ أَنَّ مَعَ کُلِّ سُبُوعٍ رَکْعَتَیْنِ ، لاَ یُجْزِئُ مِنْہُمَا تَطَوُّعٌ ، وَلاَ فَرِیضَۃٌ۔",,,14103,,
14104,"حدثنا ابْنُ یَمَانٍ، عَنْ لَیْثٍ، عَنْ عَطَائٍ، وَطَاوُوسٍ، وَمُجَاہِدٍ، قَالُوا: تُجْزِئُ الْمَکْتُوبَۃُ مِنْ رَکْعَتَیِ الطَّوَافِ۔",,,14104,,
14105,"حدَّثَنَا عَبْدُاللہِ بْنُ نُمَیْرٍ، عَنْ عَبْدِالْمَلِکِ بْنِ أَبِی سُلَیْمَانَ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ أَنَّہُ کَانَ یَکْرَہُ أَنْ یُؤْخَذَ مِنْ طِیبِ الْکَعْبَۃِ شَیْئٌ یُسْتَشْفَی بِہِ ، وَکَانَ إذَا رَأَی الْخَادِمَ تَأْخُذُ مِنْہ قَفَدَہَا قَفْدۃً لاَ یَأْلُو أَنْ یُوَجِعَہَا۔\n\nقَالَ عَطَائٌ : کَانَ أَحَدُنَا إذَا أَرَادَ أَنْ یَسْتَشْفِیَ بِہِ ، جَائَ بِطِیبٍ مِنْ عِنْدِہِ یَمْسَحُ بِہِ الْحَجَرَ ، ثُمَّ أَخَذَہُ۔",,,14105,,
14106,"حدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ یُحَتُّ الْخَلُوقُ مِنَ الْبَیْتِ ، إِلاَّ أَنْ یُوہَبَ لَہُ۔",,,14106,,
14107,"حدَّثَنَا وَکِیعٌ ، عَنْ عُمَرَ بْنِ ذَرٍّ ، قَالَ : سَأَلْتُ مُجَاہِدًا ، وَعَطَائً عَنِ الْمُحْرِمِ یَتَوَضَّأُ فَتَقَعُ الشَّعَرَاتُ ؟ فَقَالاَ : لَیْسَ عَلَیْہِ شَیْئٌ۔",,,14107,,
14108,"حدَّثَنَا وَکِیعٌ ، عَنْ عِکْرِمَۃَ بْنِ عَمَّارٍ ، قَالَ : سَمِعْتُ سَالِمًا وَسَأَلَہُ رَجُلٌ عَنْ رَجُلٍ مَسَّ لِحْیَتَہُ فَوَقَعَتْ مِنْہَا شَعَرَاتٌ ؟ قَالَ : أُفّ ، أُفّ۔",,,14108,,
14109,"حدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ مُحَمَّدِ بْنِ عَلِیٍّ ، وابْنِ الأَسْوَدِ ؛ فِی الرَّجُلِ یَتَوَضَّأُ فَیَمْسَح لِحْیَتَہُ فَتَقَعُ الشَّعَرَاتُ ؟ فَقَالاَ : لَیْسَ عَلَیْہِ شَیْئٌ۔",,,14109,,
14110,"حدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ یَزِیدَ ، عَنْ مُجَاہِدٍ ، عَنْ عَبْدِ اللہِ بْنِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَا مِنْ أَیَّامٍ أَحَبَّ إلَی اللہِ فِیہِنَّ الْعَمَلُ مِنْ ہَذِہِ الأَیَّامِ ، أَیَّامِ الْعَشْرِ ، فَأَکْثِرُوا فِیہِنَّ التَّکْبِیرَ وَالتَّہْلِیلَ وَالتَّحْمِیدَ۔ (احمد 75۔ بیہقی 3475)",,,14110,,
14111,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مِسْکِینٍ عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : سَمِعْتُ مُجَاہِدًا ، وَکَبَّرَ رَجُلٌ أَیَّامَ الْعَشْرِ ، فَقَالَ مُجَاہِدٌ : أَفَلاَ رَفَعَ صَوْتَہُ ، فَلَقَدْ أَدْرَکْتُہُمْ وَإِنَّ الرَّجُلَ لَیُکَبِّرُ فِی الْمَسْجِدِ فَیَرْتَجُّ بِہَا أَہْلُ الْمَسْجِدِ ، ثُمَّ یَخْرُجُ الصَّوْتُ إلَی أَہْلِ الْوَادِی حَتَّی یَبْلُغَ الأَبْطُحَ، فَیَرْتَجُّ بِہَا أَہْلُ الأَبْطُحِ، وَإِنَّمَا أَصْلُہَا مِنْ رَجُلٍ وَاحِدٍ۔",,,14111,,
14112,"حدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ ، وَحَمَّادًا عَنِ التَّکْبِیرِ أَیَّامَ الْعَشْرِ ؟ فَقَالاَ : مُحْدَثٌ۔",,,14112,,
14113,حدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یَقْدَمُ مَکَّۃَ فَیَطُوفُ ، ثُمَّ یَرْجِعُ فَیُقِیلُ ، فَإِذَا کَانَ بِالْعَشِیِّ رَاحَ فَطَافَ بَیْنَ الصَّفَا وَالْمَرْوَۃِ۔,,,14113,,
14114,حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ عُبَیْدِ اللہ ، عَنِ الْقَاسِمِ ؛ مِثْلَہُ۔,,,14114,,
14115,"حدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ زَیْدٍ ، عَنْ أَیُّوبَ ، عَنْ مُجَاہِدٍ ، قَالَ : لاَ بَأْسَ إذَا طَافَ أَنْ یُؤَخِّرَ السَّعْیَ حَتَّی یُبْرِدَ۔",,,14115,,
14116,"حدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ مِسْعَرٍ ، قَالَ : أَخْبَرَنِی إِسْحَاقُ مَوْلًی لِقُرَیْشٍ ، قَالَ : قَدِمَ عَلَیْنَا سَعِیدُ بْنُ جُبَیْرٍ فَطَافَ بِالْبَیْتِ سَبْعًا ، وَصَلَّی رَکْعَتَیْنِ ، ثُمَّ أَخَّرَ السَّعْیَ بَیْنَ الصَّفَا وَالْمَرْوَۃِ إلَی الْعَشِی۔",,,14116,,
14117,حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَکْرَہُ أَنْ یُفَرِّقَ بَیْنَ الطَّوَافِ وَالسَّعْیِ۔,,,14117,,
14118,"حدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : لاَ یَعْتَدُّ بِہِ ، یَطُوفُ بِالْبَیْتِ ، ثُمَّ یَطُوفُ بَیْنَ الصَّفَا وَالْمَرْوَۃِ ، فَإِنْ لَمْ یَفْعَلْ حَتَّی یَمْسی ، قَالَ : قَدْ قَضَی مَا عَلَیْہِ ، وَلاَ شَیْئَ عَلَیْہِ۔",,,14118,,
14119,"حدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ فِی رَجُلٍ بَدَأَ بِالصَّفَا وَالْمَرْوَۃِ قَبْلَ الْبَیْتِ ، قَالَ : یُعِیدُ۔",,,14119,,
14120,"حدَّثَنَا زَیْدُ بْنُ حُبَابٍ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، قَالَ : رَأَیْتُ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ مُحْرِمًا وَعَلَیْہِ حُلَّۃُ حِبَرَۃٍ۔",,,14120,,
14121,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : یُحْرِمُ فِیمَا شَائَ ، إِنْ شَائَ ثَوْبَیْنِ أَبْیَضَیْنِ ، وَإِنْ شَائَ فِی ثَوْبَیْنِ غَسِیلَیْنِ ، وَإِنْ شَائَ فِی ثَوْبیْ حِبَرَۃٍ۔",,,14121,,
14122,"حدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا عُبَیْدُ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَسْعَی فِی بَطْنِ الْمَسِیلِ ، إِذَا طَافَ بَیْنَ الصَّفَا وَالْمَرْوَۃِ ۔ وَکَانَ ابْنُ عُمَرَ یَفْعَلُ ذَلِکَ۔\n\n(بخاری 1617۔ دارمی 1841)",,,14122,,
14123,"حدَّثَنَا ابْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : یَسْعَی الرَّجُلُ بَیْنَ الصَّفَا وَالْمَرْوَۃِ فِی بَطْنِ الْمَسِیلِ ، وَلاَ یَشُدَّ السَّعْیَ۔",,,14123,,
14124,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ حُمَیْدٍ ، عَنْ بَکْرٍ ، قَالَ : سَعَیْتُ مَعَ ابْنِ عُمَرَ فِی بَطْنِ الْمَسِیلِ۔",,,14124,,
14125,"حدَّثَنَا جَرِیرُ بْنُ عَبْدِ الحمِید ، عَنْ لَیْثٍ، عَنْ عَطَائٍ، قَالَ: إِنْ شَائَ سَعَی فِی الْوَادِی، وَإِنْ شَائَ لَمْ یَسْعَ۔",,,14125,,
14126,حدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یَسْعَی فِی بَطْنِ الْمَسِیلِ وَحْدَہُ۔,,,14126,,
14127,حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَبْدِ اللہِ ؛ أَنَّہُ کَانَ یَسْعَی فِی الْمَسِیلِ۔,,,14127,,
14128,حدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ؛ أَنَّ الزُّبَیْرَ کَانَ یُوکی مَا بَیْنَ الصَّفَا وَالْمَرْوَۃِ سَعْیًا۔,,,14128,,
14129,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنْ مُجَاہِدٍ ، وَعَطَائٍ ، قَالَ : رَأَیْتُہمَا یَسْعَیَانِ مِنْ خَوْخَۃِ بَنِی عَبَّادٍ إلَی زُقَاقِ بَنِی أَبِی حُسَیْنٍ ، فَقُلْتُ لِمُجَاہِدٍ ؟ فَقَالَ : ہَذَا بَطْنُ الْمَسِیلِ الأَوَّلُ ، وَلَکِنَّ النَّاسَ انْتَقَصُوا مِنْہُ۔",,,14129,,
14130,"حدَّثَنَا الثَّقَفِیُّ ، عَنْ حَبِیبٍ الْمُعَلِّمِ ، عَنْ عَطَائٍ ؛ فِی رَجُلٍ طَافَ فَکَانَ مِنْ طَوَافِہِ دُخُولٌ فِی الْحِجْرِ ، قَالَ : لاَ یَعْتَدُّ بِمَا کَانَ مِنْ دُخُولِ الْحِجْرِ۔",,,14130,,
14131,حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ أَبِیہِ ؛ أَنَّہُ رَأَی سَالِمًا یَطُوفُ وَمَعَہُ ہِشَامٌ ، فَأَرَادَ ہِشَامٌ أَنْ یَدْخُلَ الْحِجْرَ فَمَنَعَہُ سَالِمٌ۔,,,14131,,
14132,"حدَّثَنَا ابْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ طَافَ الطَّوَافَ الْوَاجِبَ ،فَجَعَلَ یَجْتَازُ فِی الْحِجْرِ ، قَالَ : یُعِیدُ الطَّوَافَ ، فَإِنْ کَانَ حَلَّ وَغَشِیَ النِّسَائَ أَہْرَقَ لِذَلِکَ دَمًا۔",,,14132,,
14133,حدَّثَنَا حَفْصُ بن غَیَاثٍ ، عَنْ حَجَّاجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ؛ أَنَّ عُمَرَ جَمَّعَ بِمِنًی۔,,,14133,,
14134,"حدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : رَأَیْتُ النَّاسَ یُجَمِّعُونَ بِمِنًی وَیَدْعُونَ۔",,,14134,,
14135,"حدَّثَنَا حَفْصٌ، عَنْ عَبْدِالْمَلِکِ، عَنْ عَطَائٍ، قَالَ: سَمِعْتُہُ وَسُئِلَ عَلَی أَہْلِ مِنًی جُمُعَۃٌ؟ قَالَ: إنَّمَا ہُمْ سَفَرٌ۔",,,14135,,
14136,"حدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ، عَنْ خَالِدِ بْنِ أَبِی عُثْمَانَ، قَالَ: شَہِدْتُ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ لاَ یَجْمِّعُ بِمِنًی۔",,,14136,,
14137,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَبْدِ اللہِ بْنِ کَثِیرٍ ، قَالَ : رَأَیْتُ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ یَوْمَ الصَّدَرِ وَوَافَقَ یَوْمَ جُمُعَۃٍ، فَأَقَامَ فَخَطَبَ بِالأَرْضِ قِبَلَ الْبَیْتِ، ثُمَّ تَکَلَّمَ بِکَلِمَاتٍ، ثُمَّ صَلَّی الْجُمُعَۃَ رَکْعَتَیْنِ۔",,,14137,,
14138,"حدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ؛ أَنَّ عُمَرَ بْنَ الْخَطَّابِ صَلَّی بِالْحَصْبَۃِ الْجُمُعَۃَ ، وَلَمْ یُجَمِّعْ بِہَا ، وَجَمَّعَ أَہْلُ الْبَلَدِ ، قَالَ ابْنُ أَبِی ذِئْبٍ : جَعَلَہَا ظُہْرًا۔",,,14138,,
14139,"حدَّثَنَا وَکِیعٌ ، عَنْ إبْرَاہِیمَ بْنِ یَزِیدَ ، عَنْ عَوْنِ بْنِ عَبْدِ اللہِ ، قَالَ : قَالَ عَبْدُ اللہِ : لَیْسَ عَلَی الْمُسْلِمِینَ جُمُعَۃٌ فِی سَفَرِہِمْ ، وَلاَ وَیَوْمَ نَفْرِہِمْ۔",,,14139,,
14140,"حدَّثَنَا حَفْصٌ ، عَنْ عَبْدِ الْمَلِکِ بْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، فِی الرَّجُلِ یَقْطَعُ مِنْ شَجَرِ الْحَرَمِ ، قَالَ : فِی الْقَضِیبِ دِرْہَمٌ ، وَفِی الدَّوْحَۃِ بَقَرَۃ۔",,,14140,,
14141,"حدَّثَنَا عَبْدُ الْوَہَّابِ بْنُ عَطَائٍ ، عَنْ إسْمَاعِیلَ بْنِ مُسْلِمٍ ، عَنِ الْحَارِثِ ، وَحَمَّادٍ ؛ قَالاَ : فِی الَّذِی یَعْضُدُ مِنْ شَجَرِ الْحَرَمِ ، قَالاَ : عَلَیْہِ قِیمَتُہُ۔",,,14141,,
14142,"حدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ قَالَ : لاَ بَأْسَ بِالْغِنَائِ ، وَالْحُدَائِ ، وَالشِّعْرِ لِلْمُحْرِمِ مَا لَمْ یَکُنْ فُحْشًا۔",,,14142,,
14143,"حدَّثَنَا جَرِیرٌ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، قَالَ : کَانَ عُمَرُ یَأْمُرُ رَجُلاً فَیَحْدُو۔",,,14143,,
14144,"حدَّثَنَا وَکِیعٌ ، عَنْ مُحَمَّدِ بْنِ الْقَاسِمِ ، قَالَ : سَمِعْتُ الْحَسَنَ وَسُئِلَ عَنِ الْحُدَائِ ؟ قَالَ : کَانَ الْمُسْلِمُونَ یَفْعَلُونَہُ۔",,,14144,,
14145,"حدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ إبْرَاہِیمَ بْنِ عَبْدِ الأَعْلَی ، قَالَ : کَانَ سُوَیْد بْنُ غَفَلَۃَ یَأْمُرُ غُلاَمًا لَہُ فَیَحْدُو لَنَا۔",,,14145,,
14146,"حدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ حَسَنِ بْنِ أَبِی جَعْفَرٍ ، عَنْ یَزِیدَ الأَعْرَجِ ، قَالَ : سَمِعْتُ مُوَرِّقاً یَحْدُو فِی طَرِیقِ مَکَّۃَ وَہُوَ یَقُولُ : لَوْ تَکَلَّمْنَ لاَشْتَکَیْنَ رَاشِدًا۔",,,14146,,
14147,"حدَّثَنَا وَکِیعٌ ، عَنْ أُسَامَۃَ بْنِ زَیْدِ ، عْن زَیْدِ بْنِ أَسْلَمَ ، عْن أَبِیہِ ، قَالَ : سَمِعَ عُمَرُ بْنُ الْخَطَّابِ رَجُلاً بِفَلاَۃٍ مِنَ الأَرْضِ وَہُوَ یَحْدُو بِغِنَائِ الرُّکْبَانِ ، فَقَالَ عُمَرُ : إنَّ ہَذَا مِنْ زَادِ الرَّاکِبِ۔",,,14147,,
14148,"حدَّثَنَا عَبَّادُ بْنُ عَوَّامِ ، عَنْ حُصَیْنٍ ، عَنْ مُجَاہِدٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لَقِیَ قَوْمًا فِیہِمْ حَادٍ یَحْدُو ، فَلَمَّا رَأَوُا النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سَکَتَ حَادِیہُمْ ، فَقَالَ : مَنِ الْقَوْمُ ؟ فَقَالُوا : مِنْ مُضَرَ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : وَأَنا مِنْ مُضَرَ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَا شَأْنُ حَادِیکُمْ لاَ یَحْدُو ؟ فَقَالُوا : یَا رَسُولَ اللہِ ، إنَّا أَوَّلُ الْعَرَبِ حُدَائً ، قَالَ : وَمِمَّ ذَلِکَ ؟ قَالُوا : إنَّ رَجُلاً مِنَّا وَسَمَّوْہُ لَہُ ، عزَبَ عَنْ إبِلِہِ فِی أَیَّامِ الرَّبِیعِ ، فَبَعَثَ غُلاَمًا لَہُ مَعَ الإِبِلِ ، قَالَ : فَأَبْطَأَ الْغُلاَمُ ، فَضَرَبَہُ بِعَصًا عَلَی یَدِہِ ، وَانْطَلَقَ الْغُلاَمُ وَہُوَ یَقُولُ : یَا یَدَاہُ ، یَا یَدَاہُ ، قَالَ : فَتَحَرَّکَتِ الإِبِلُ لِذَلِکَ وَنَشِطَتْ ، قَالَ : فَقَالَ لَہُ : أَمْسِکْ ، أَمْسِکْ ، قَالَ : فَافْتَتَحَ النَّاسُ الْحُدَائَ۔ (بیہقی 228۔ بزار 2113)",,,14148,,
14149,"حدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : لاَ تَسْتَلِمِ الْحَجَرَ عَنْ یَمِینِہِ ، وَلاَ عَنْ شِمَالِہِ ، وَلَکِنِ اسْتَقْبِلْہُ اسْتِقْبَالاً۔",,,14149,,
14150,"حدَّثَنَا وَکِیعٌ ، عَنْ ربَاحِ بْنِ أَبِی مَعْرُوفٍ ، قَالَ : حدَّثَنِی مَنْ رَأَی مُجَاہِدًا یَدُورُ حَتَّی یَسْتَقْبِلَ الْحَجَرَ مِنْ وَجْہِہِ۔",,,14150,,
14151,"حدَّثَنَا وَکِیعٌ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، عَنْ عَبْدِ اللہِ بْنِ عُبَیْدِ بْنِ عُمَیْرٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی عَمَّارٍ ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ ، قَالَ : جَعَلَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی الضَّبُعِ کَبْشًا یُصِیبُہُ الْمُحْرِمُ ، وَجَعَلَہُ مِنَ الصَّیْدِ۔ (ابوداؤد 3795۔ ترمذی 851)",,,14151,,
14152,"حدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ سِمَاکٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : قتَلَ رَجُلٌ ضَبُعًا وَہُوَ مُحْرِمٌ ، فَأَتَی عَلِیًّا فَسَأَلَہُ ؟ فَجَعَلَ فِیہِ کَبْشًا۔",,,14152,,
14153,حدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، عَنْ عَلِیٍّ ؛فِی الضَّبُعِ إذَا عَدَا عَلَی الْمُحْرِمِ فَلیَقْتُلْہُ ، فَإِنْ قَتَلَہُ مِنْ غَیْرِ أَنْ یَعْدُوَ عَلَیْہِ ، فَفِیہِ شَاۃٌ مُسِنَّۃٌ۔,,,14153,,
14154,حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنِ أَبِی الزبیر ، عَنْ جَابِرِ ، عَنْ عُمَرَ ؛ مِثْلَہُ۔,,,14154,,
14155,حدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، عَنْ عَلِیٍّ ؛ فِی الضَّبُعِ إذَا لَمْ یَعْدُ کَبْشٌ، وَقَالَ عَطَائٌ مِثْلَ ذَلِکَ۔,,,14155,,
14156,"حدَّثَنَا وَکِیعٌ، عَنْ شُعْبَۃَ، عَنْ سِمَاکٍ، عَنْ عِکْرِمَۃَ، عَنِ ابْنِ عَبَّاسٍ؛ أَنَّ مَرْوَانَ سَأَلَہُ؟ فَقَالَ: فِیہِ کَبْشٌ۔",,,14156,,
14157,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : لَیْسَ فِی شَیْئٍ مِنَ الْجِمَارِ دَمٌ ، إِلاَّ فِی جَمْرَۃِ الْعَقَبَۃِ ، إِنْ قَدَّمَ شَیْئًا قَبْلَہَا ، ہِیَ قَبْلَہُ۔",,,14157,,
14158,"حدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یَرْمِی جَمْرَۃً قَبْلَ الأُخْرَی الَّتِی یَنْبَغِی أَنْ یَبْدَأَ بِہَا ، قَالَ : لَیْسَ عَلَیْہِ شَیْئٌ فِیہَا۔",,,14158,,
14159,حدَّثَنَا ابْنُ فُضَیْلٍ، عَنْ یَزِیدَ، عَنْ مُجَاہِدٍ، عَنِ ابْنِ عَبَّاسٍ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَخَّصَ فِی الإِذْخِرِ,,,14159,,
14160,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سُفْیَانَ ، عَنْ یَزِیدَ ، عَنْ مُجَاہِدٍ ، قَالَ : لاَ بَأْسَ بِمَا سَقَطَ مِنْ شَجَرِ الْحَرَمِ أَنْ یُلْتَقَطَ۔",,,14160,,
14161,"حدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، وَابْنِ الأَسْوَدِ ؛ قَالاَ : لاَ بَأْسَ بِمَا سَقَطَ مِنْ شَجَرِ الْحَرَمِ۔",,,14161,,
14162,حدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ جَابِرٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَتَی عَرَفَاتٍ حَتی إذَا زَاغَتِ الشَّمْسُ أَمَرَ بِالْقَصْوَائِ فَرُحِلَتْ لَہُ ، فَأَتَی بَطْنَ الْوَادِی فَخَطَبَ النَّاسَ۔,,,14162,,
14163,"حدَّثَنَا ابْنُ أَبِی زَائِدَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أُخْبِرْتُ عَنْ مُحَمَّدِ بْنِ قَیْسِ بْنِ الْمُطَّلِبِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ خَطَبَ بِعَرَفَۃَ۔ (طبرانی 28)",,,14163,,
14164,حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ الزُّہْرِیِّ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَخْطُبُ یَوْمَ النَّحْرِ ، فَشُغِلَت الأُمَرَائُ فَأَخَّرُوہُ إلَی الْغَدِ۔,,,14164,,
14165,"حدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنْ سُفْیَانَ ، عَنْ مُحَمَّدِ بْنِ طَارِقٍ ، عَنْ مُجَاہِدٍ ، قَالَ : خَطَبَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَوْمَ النَّحْرِ النَّاسَ بَیْنَ الْجَمْرَتَیْنِ أَیَّامَ التَّشْرِیقِ۔",,,14165,,
14166,حدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ؛ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ خَطَبَہُمْ قَبْلَ التَّرْوِیَۃِ بِیَوْمٍ ضُحًی ، وَأَنَّ ابْنَ الزُّبَیْرِ کَانَ یَخْطُبُ الْعَشْرَ کُلَّہَا۔,,,14166,,
14167,"حدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ مُحَمَّدِ بْنِ عِجْلاَنَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، قَالَ : رَأَیْتُ أَبِی صَعِدَ إلَی ابْنِ الزُّبَیْرِ بِعَرَفَۃَ وَہُوَ عَلَی الْمِنْبَرِ ، فَلَمَّا نَزَلَ لَبَّی ابْنُ الزُّبَیْرِ ، فَقُلْتُ لأَبِی : مَا قُلْتَ لَہُ ؟ قَالَ : قُلْتُ لَہُ : سَمِعْت عُمَرَ یُلَبِّی ہَاہُنَا عَلَی الْمِنْبَرِ۔",,,14167,,
14168,"حدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی الضُّحَی ، عَنْ مَسْرُوقٍ ، قَالَ : خَطَبَہُمُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَوْمَ النَّحْرِ۔",,,14168,,
14169,"حدَّثَنَا أَبُو مُحَمَّدٍ عَبْدُ اللہِ بْنُ یُونُسَ ، قَالَ : حدَّثَنَا أَبُو عَبْدِ الرَّحْمَنِ بَقِیُّ بْنُ مَخْلَدٍ ، قَالَ : حدَّثَنَا أَبُو بَکْرٍ عَبْدُ اللہِ بْنُ مُحَمَّدِ بْنِ أَبِی شَیْبَۃَ ، قَالَ :\n حدَّثَنَا إسْمَاعِیلُ بْنُ إِبْرَاہِیمَ ، عَنْ عَلِیِّ بْنِ زَیْدِ بْنِ جُدْعَانَ ، عَنْ أَبِی نَضْرَۃَ ، عَنْ عِمْرَانَ بْنِ حُصَیْنٍ ، قَالَ : حَجَجْتُ مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَلَمْ یُصَلِّ إِلاَّ رَکْعَتَیْنِ حَتَّی رَجَعَ إلَی الْمَدِینَۃِ ، وَحَجَجْتُ مَعَ أَبِی بَکْرٍ فَلَمْ یُصَلِّ إِلاَّ رَکْعَتَیْنِ حَتَّی رَجَعَ إلَی الْمَدِینَۃِ ، وَحَجَجْتُ مَعَ عُمَرَ حَجَّاتٍ ، فَلَمْ یُصَلِّ إِلاَّ رَکْعَتَیْنِ حَتَّی رَجَعَ إلَی الْمَدِینَۃِ ، وَحَجَّ عُثْمَانُ سَبْعَ سِنِینَ مِنْ إمَارَتِہِ لاَ یُصَلِّی إِلاَّ رَکْعَتَیْنِ ، ثُمَّ صَلاَّہَا بِمِنًی أَرْبَعًا۔",,,14169,,
14170,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : صَلَّی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَکْعَتَیْن ، وَأَبُو بَکْرٍ بَعْدَہُ ، وَعُمَرُ بَعْدَ أَبِی بَکْرٍ ، وَعُثْمَانُ صَدْرًا مِنْ خِلاَفَتِہِ ، ثُمَّ إِنَّ عُثْمَانَ صَلَّی بَعْدُ أَرْبَعًا ، فَکَانَ ابْنُ عُمَرَ إذَا صَلَّی مَعَ الإِمَامِ صَلَّی أَرْبَعًا ، وَإِذَا صَلاَہَا وَحْدَہُ صَلاَہَا رَکْعَتَیْنِ۔\n\n(بخاری 1082۔ مسلم 17",,,14170,,
14171,"حدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : أَخْبَرَنِی حَارِثَۃُ بْنُ وَہْبٍ ، قَالَ : صَلَّیْتُ مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِمِنًی أَکْثَرَ مَا کَانَ النَّاسُ ، وَآمنہ رَکْعَتَیْنِ۔",,,14171,,
14172,"حدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ ، عَنْ لَیْثِ بْنِ سَعْدٍ ، عَنْ بُکَیْرِ بْنِ الأَشَجِّ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ اللہِ بْنِ أَبِی سُلَیْمٍ، عَنْ أَنَسٍ ، قَالَ : صَلَّیْتُ مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِمِنًی رَکْعَتَیْنِ ، وَمَعَ أَبِی بَکْرٍ ، وَمَعَ عُمَرَ ، وَمَعَ عُثْمَانَ صَدْرًا مِنْ إمَارَتِہِ۔ (احمد 3/144۔ ابویعلی 4255)",,,14172,,
14173,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَوْنِ بْنِ أَبِی جُحَیْفَۃَ ، عَنْ أَبِیہِ ، قَالَ : صَلَّیْتُ مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِمِنًی رَکْعَتَیْنِ۔",,,14173,,
14174,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، قَالَ : صَلَّی عُثْمَانَ بِمِنًی أَرْبَعَ رَکَعَاتٍ ، فَقَالَ عَبْدُ اللہِ : صَلَّیْتُ مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِمِنًی رَکْعَتَیْنِ ، وَمَعَ أَبِی بَکْرٍ رَکْعَتَیْنِ ، وَمَعَ عُمَرَ رَکْعَتَیْنِ ، ثُمَّ تَفَرَّقَتْ بِکُمَ الطُّرُقُ ، وَلَوَدِدْتُ أَنَّ لِی مِنْ أَرْبَعِ رَکَعَاتٍ رَکْعَتَیْنِ مُتَقَبَّلَتَیْنِ ۔ قَالَ الأَعْمَش : فَحَدَّثَنِی مُعَاوِیَۃُ بْنُ قُرَّۃَ ، أَنَّ عَبْدَ اللہِ صَلَّی بَعْدُ أَرْبَعًا ، فَقِیلَ لَہُ : عِبْتَ عَلَی عُثْمَانَ ، ثُمَّ تُصَلِی أَرْبَعًا ، قَالَ : فَقَالَ عَبْدُ اللہِ : الْخِلاَفُ شَرّ۔",,,14174,,
14175,"حدَّثَنَا جَرِیرٌ ، وَہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، قَالَ : صَحِبَنَا رَجُلٌ مِنْ أَہْلِ الْیَمَامَۃِ ، فَحدَّثَنَا ؛أَنَّہُ رَأَی ابْنَ عُمَرَ صَلَّی خَلْفَ ابْنِ الزُّبَیْرِ بِمِنًی رَکْعَتَیْنِ ، قَالَ : وَرَأَیْتُہُ صَلَّی خَلْفَ الْحَجَّاجِ أَرْبَعًا۔",,,14175,,
14176,"حدَّثَنَا وَکِیعٌ ، عَنْ حَنْظَلَۃَ ، عَنِ الْقَاسِمِ ، وَسَالِمٍ ، وَطَاوُوسٍ ؛ قَالُوا : اقصُر بِمِنًی۔",,,14176,,
14177,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : الصَّلَوَاتُ بِمِنًی رَکْعَتَانِ ، أَیَّامَ التَّشْرِیقِ۔",,,14177,,
14178,"حدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ خُصَیْفٍ ، عَنْ مُجَاہِدٍ ، قَالَ : قَالَ ابْنُ عَبَّاسٍ ، قَالَ الْفَضْلُ بْنُ عَبَّاسٍ : کُنْتُ رِدْفَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَمَا زِلْتُ أَسْمَعُہُ یُلَبِّی حَتَّی رَمَی جَمْرَۃَ الْعَقَبَۃِ ، فَلَمَّا رَمَاہَا قَطَعَ۔\n\n(بخاری 1685۔ مسلم 266)",,,14178,,
14179,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، قَالَ : حدَّثَنِی أَبَانُ بْنُ صَالِحٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : دَفَعْتُ مَعَ حُسَیْنٍ بْنِ عَلِیِّ مِنَ الْمُزْدَلِفَۃِ ، فَلَمْ أَزَلْ أَسْمَعُہُ یُلَبِّی یَقُولُ : لَبَّیْکَ حَتَّی انْتَہَی إلَی الْجَمْرَۃِ ، فَقُلْتُ لَہُ : مَا ہَذَا الإِہْلاَلُ ، یَا أَبَا عَبْدِ اللہِ ؟ ، قَالَ : سَمِعْتُ أَبِی عَلِیَّ بْنَ أَبِی طَالِبٍ یُہِلُّ حَتَّی انْتَہَی إلَی الْجَمْرَۃِ ، وَحَدَّثَنِی : أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَہَلَّ حَتَّی انْتَہَی إلَیْہَا۔ (احمد 1/114۔ بزار 500)",,,14179,,
14180,"حدَّثَنَا صَفْوَانُ بْنُ عِیسَی ، عَنِ الْحَارِثِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ أَبِی ذُبَابٍ ، عَنْ مُجَاہِدٍ ، عَنْ عَبْدِ اللہِ بْنِ سَخْبَرَۃَ ، عَنْ عَبْدِ اللہِ ، قَالَ : خَرجْتُ مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَمَا تَرَکَ التَّلْبِیَۃَ حَتَّی أَتَی الْعَقَبَۃَ إِلاَّ أَنْ یَخْلِطَہَا بِتَکْبِیرٍ ، أَوْ تَہْلِیلٍ۔ (احمد 1/417۔ ابن خزیمۃ 2806)",,,14180,,
14181,حدَّثَنَا حَفْصٌ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ عَلِیِّ بْنِ حُسَیْنٍ ، عَنِ ابْنِ عَبَّاسٍ ، عَنِ الْفَضْلِ بْنِ عَبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لَمْ یَزَلْ یُلَبِّی حَتَّی رَمَی جَمْرَۃَ الْعَقَبَۃِ ، فَرَمَاہَا بِسَبْعِ حَصَیَاتٍ ، یُکَبِّرُ مَعَ کُلِّ حَصَاۃٍ۔ (ابن خزیمۃ 2887۔ طبرانی 672),,,14181,,
14182,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لَبَّی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَتَّی رَمَی جَمْرَۃَ الْعَقَبَۃِ۔ (طبرانی 10990)",,,14182,,
14183,"حدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَمْرِو بْنِ مَیْمُونٍ ، قَالَ : حجَجْتُ مَعَ عُمَرَ سَنَتَیْنِ ، إحْدَاہُمَا فِی السَّنَۃِ الَّتِی أُصِیبَ فِیہَا ، کُلُّ ذَلِکَ یُلَبِّی حَتَّی رَمَی جَمْرَۃَ الْعَقَبَۃِ مِنْ بَطْنِ الْوَادِی۔",,,14183,,
14184,"حدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ ہِلاَلِ بْنِ خَبَّابِ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ عُمَرَ لَبَّی حَتَّی رَمَی الْعَقَبَۃَ ، وَأَنَّ ابْنَ عَبَّاسٍ کَانَ یُلَبِّی حَتَّی یَرْمِیَ جَمْرَۃَ الْعَقَبَۃِ ، وَقَالَ : إنَّمَا نَفْتَتِح الْحِلَّ الآنَ۔",,,14184,,
14185,حدَّثَنَا شَرِیکٌ ، عَنْ عَامِرِ بْنِ شَقِیقٍ ، عَنْ أَبِی وَائِلٍ ، عَنْ عَبْدِ اللہِ ؛ أَنَّہُ لَبَّی حَتَّی رَمَی جَمْرَۃَ الْعَقَبَۃِ۔,,,14185,,
14186,"حدَّثَنَا حَفْصٌ ، وَوَکِیعٌ ، وَمَرْوَانُ بْنُ مُعَاوِیَۃَ ، وَعَلِیُّ بْنُ ہَاشِمٍ ، عَنْ مُحَمَّدِ بْنِ شَرِیکٍ ، عَنْ عَطَائٍ ، قَالَ : کَانَ عَلِیٌّ یُلَبِّی ، یَقْطَعُ التَّلْبِیَۃَ إذَا رَمَی جَمْرَۃَ الْعَقَبَۃِ۔",,,14186,,
14187,حدَّثَنَا ابْنِ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ، عَنْ عَبْدِ اللہِ ، أِنَّہُ کَانَ لاَ یَتْرُکُ التَّلْبِیَۃَ حَتَّی یَرْمِیَ جَمْرَۃَ الْعَقَبَۃِ۔,,,14187,,
14188,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ الْحَسَنِ ، عَنْ عِکْرِمَۃَ ؛ قَالَ : أَرْسَلَنِی ابْنُ عَبَّاسٍ مَعَ حُسَیْنِ بْنِ عَلِیٍّ ، فَلَبَّی حَتَّی رَمَی جَمْرَۃَ الْعَقَبَۃِ۔",,,14188,,
14189,"حدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ حَرْمَلَۃَ ، قَالَ : قَالَ سَعِیدُ بْنُ الْمُسَیَّبِ : الإِہْلاَلُ فِی الْحَجِّ حَتَّی تَرُوحَ إلَی الْمَوْقِفِ عَشِیَّۃَ عَرَفَۃَ۔",,,14189,,
14190,"حدَّثَنَا وَکِیعٌ ، عَنْ أَفْلَحَ ، قَالَ : رَأَیْتُ الْقَاسِمَ یَقْطَعُ التَّلْبِیَۃَ إذَا رَاحَ إلَی الْمَوْقِفِ ، قَالَ : وَکَانَتْ عَائِشَۃُ تَفْعَلُہُ۔",,,14190,,
14191,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، قَالَ : کَانَ لاَ یَقْطَعُ التَّلْبِیَۃَ فِی الْحَجِّ ، حَتَّی یَرُوحَ إلَی عَرَفَاتٍ۔",,,14191,,
14192,"حدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : کَانَ ابْنُ عُمَرَ یُمْسِکُ عَنِ التَّلْبِیَۃِ فِی الْحَجِّ إذَا دَخَلَ الْحَرَمَ ، فَإِذَا طَافَ بِالْبَیْتِ لَبَّی۔",,,14192,,
14193,حدَّثَنَا غُنْدَرٌ ، عَنْ سَعِیدِ بْنِ أَبِی عَرُوبَۃَ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ،وَالأَسْوَدِ ، عَنْ عَبْدِ اللہِ ؛ أَنَّہُ کَانَ لاَ یَقْطَعُ التَّلْبِیَۃَ حَتَّی یَرْمِیَ جَمْرَۃَ الْعَقَبَۃِ فِی أَوَّلِ حَصَاۃٍ۔,,,14193,,
14194,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، قَالَ : سَأَلَ أَبِی عِکْرِمَۃَ وَأَنَا أَسْمَعُ عَنِ الإِہْلاَلِ مَتَی یَنْقَطِعُ ؟ فَسَمِعْتُہُ یَقُولُ : أَہَلَّ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَتَّی رَمَی الْجَمْرَۃَ ، وَأَبُو بَکْرٍ ، وَعُمَرُ۔",,,14194,,
14195,حدَّثَنَا عَبْدُ الرَّحْمَنِ بْنِ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ عَامِرِ بْنِ شَقِیقٍ ، عَنْ أَبِی وَائِلٍ ، عَنْ عَبْدِ اللہِ ؛ أَنَّہُ لَبَّی حَتَّی رَمَی جَمْرَۃَ الْعَقَبَۃِ ، وَقَطَعَ بِأَوَّلِ حَصَاۃٍ۔,,,14195,,
14196,حدَّثَنَا ہُشَیْمٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، رَفَعَہُ ؛ أَنَّہُ کَانَ یُمْسِکُ عَنِ التَّلْبِیَۃِ فِی الْعُمْرَۃِ إذَا اسْتَلَمَ الْحَجَرَ۔ (ابوداؤد 1813۔ ترمذی 919),,,14196,,
14197,"حدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا حَسَنٌ وَزُہَیْرٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لَبَّی فِی الْعُمْرَۃِ حَتَّی اسْتَلَمَ الْحَجَرَ۔",,,14197,,
14198,"حدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، قَالَ : اعْتَمَرَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ثَلاَثَ عُمَرَ ، کُلَّ ذَلِکَ لاَ یَقْطَعُ التَّلْبِیَۃَ حَتَّی یَسْتَلِمَ الْحَجَرَ۔ (احمد 2/180)",,,14198,,
14199,"حدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی بِشْرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ قَالَ : الْمُعْتَمِرُ یُمْسِکُ عَنِ التَّلْبِیَۃِ إذَا اسْتَلَمَ الْحَجَرَ ، وَالْحَاجُّ إذَا رَمَی الْجَمْرَۃَ۔",,,14199,,
14200,"حدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، وَعَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : کَانَ ابْنُ عَبَّاسٍ یُلَبِّی فِی الْعُمْرَۃِ حَتَّی یَسْتَلِمَ الْحَجَرَ ، وَکَانَ ابْنُ عُمَرَ یَقْطَعُ إذَا دَخَلَ الْحَرَمَ۔",,,14200,,
14201,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : حتَّی یَسْتَلِمَ الْحَجَرَ ۔ وَقَالَ عَطَائٌ : یَقْطَعُ إذَا دَخَلَ الْقَرْیَۃَ۔",,,14201,,
14202,حدَّثَنَا غُنْدَرٌ ، عَنْ سَعِیدِ بْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، وَمُجَاہِدٍ؛ أَنَّہُمَا کَانَا إذَا أَہَلاَّ بِعُمْرَۃٍ لَمْ یُمْسِکَا عَنِ التَّلْبِیَۃِ حَتَّی یَسْتَلِمَا الْحَجَرَ۔,,,14202,,
14203,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی عَبْدُ الْحَمِیدِ بْنُ جُبَیْرِ بْنِ شَیْبَۃَ ، قَالَ : رَأَیْتُ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ ، وَأَبَانَ بْنَ عُثْمَانَ یُلَبِّیَانِ بِذِی طُوَی فِی الْعُمْرَۃِ۔",,,14203,,
14204,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : یَقْطَعُ إذَا دَخَلَ الْحَرَمَ۔",,,14204,,
14205,"حدَّثَنَا وَکِیعٌ ، عَنْ أَفْلَحَ ، عَنِ الْقَاسِمِ ، قَالَ : یَقْطَعُ إذَا رَأَی عُرُوشَ مَکَّۃَ۔",,,14205,,
14206,"حدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، قَالَ : لاَ یَقْطَعَ الْمُعْتَمِرُ حَتَّی یَسْتَلِمَ الْحَجَرَ۔",,,14206,,
14207,حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنِ ابْنِ الأَسْوَدِ ، عَنْ أَبِیہِ ، مِثْلَہُ۔,,,14207,,
14208,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، قَالَ : کَانَ یَقْطَعُ التَّلْبِیَۃَ فِی الْعُمْرَۃِ إذَا دَخَلَ الْحَرَمَ۔",,,14208,,
14209,"حدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ حَرْمَلَۃَ ، قَالَ : قَالَ سَعِیدُ بْنُ الْمُسَیَّبِ : الإِہْلاَلُ فِی الْعُمْرَۃِ حَتَّی یَنْظُرَ إلَی عُرُوشِ مَکَّۃَ۔",,,14209,,
14210,"حدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، قَالَ : یَقْطَعُ إذَا رَأَی بُیُوتَ مَکَّۃَ۔",,,14210,,
14211,"حدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، قَالَ : کَانَ أَصْحَابُ عَبْدِ اللہِ یُلَبُّونَ فِی الْعُمْرَۃِ حَتَّی یَسْتَلِمُوا الْحَجَرَ۔",,,14211,,
14212,"حدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ مَعْمَرٍ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، قَالَ : یَقْطَعُ فِی الْعُمْرَۃِ إذَا اسْتَلَمَ الْحَجَرَ۔",,,14212,,
14213,"حدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، عَنْ أَبِیہِ ، قَالَ : أَفَضْتُ مَعَ عَبْدِ اللہِ ، فَرَمَی سَبْعَ حَصَیَاتٍ یُکَبِّرُ مَعَ کُلِّ حَصَاۃٍ ، وَاسْتَبْطَنَ الْوَادِیَ حَتَّی إذَا فَرَغَ ، قَالَ : اللَّہُمَّ اجْعَلْہُ حَجًّا مَبْرُورًا وَذَنْبًا مَغْفُورًا ۔ ثُمَّ قَالَ : ہَکَذَا رَأَیْتُ الَّذِی أُنْزِلَ عَلَیْہِ سُورَۃُ الْبَقَرَۃِ صَنَعَ۔(بیہقی 129۔ احمد 1/427)",,,14213,,
14214,"حدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْہَیْثُمِ بْنِ حَنَشٍ ، قَالَ : سَمِعْتُ ابْنَ عُمَرَ حِینَ رَمَی الْجِمَارَ یَقُولُ : اللَّہُمَّ اجْعَلْہُ حَجًّا مَبْرُورًا وَذَنْبًا مَغْفُورًا۔",,,14214,,
14215,"حدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ قَالَ : لَیْسَ عَلَی الْوُقُوفِ عِنْدَ الْجَمْرَتَیْنِ دُعَائٌ مُوَقَّتٌ ، فَادْعُ بِمَا شِئْتَ۔",,,14215,,
14216,"حدَّثَنَا ابْنُ أَبِی عَدِیٍّ، عَنْ أَشْعَثَ، قَالَ: کَانَ الْحَسَنُ یَقُولُ: یَدْعُو عِنْدَ الْجِمَارِ کُلِّہَا ، وَلاَ یُوَقِّتُ شَیْئًا۔",,,14216,,
14217,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَہُ ، قَالَ : قُلْتُ لإِبْرَاہِیمَ : مَا أَقُولُ إذَا رَمَیْتُ الْجَمْرَۃَ ؟ قَالَ : قُلْ : اللَّہُمَّ اجْعَلْہُ حَجًّا مَبْرُورًا وَذَنْبًا مَغْفُورًا ، قَالَ : قُلْتُ : أَقُولُہُ مَعَ کُلِّ حَصَاۃٍ ؟ قَالَ : نَعَمْ إِنْ شِئْتَ۔",,,14217,,
14218,"حدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : فِی الْجَمْرَۃِ شَیْئٌ مُوَقَّتٌ لاَ یُزَادُ عَلَیْہِ ؟ قَالَ : لاَ ، إِلاَّ قَوْلُ جَابِرٍ۔",,,14218,,
14219,"حدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ أَبِی حَصِینٍ ، قَالَ : رَأَیْتُ سَعِیدَ بْنَ جُبَیْرٍ ، وَحَبِیبَ بْنَ أَبِی ثَابِتٍ ، وَرَجُلاً مِنْ قُرَیْشٍ بَعْدَ مَا أَفَاضَ الإِمَامُ عَشِیَّۃَ عَرَفَۃَ ، فَقَامَ سَعِیدُ بْنُ جُبَیْرٍ فَأَذَّنَ ، وَأَمَّ الْقُرَشِیَّ بَعْدَ مَا أَفَاضَ الإِمَامُ۔",,,14219,,
14220,حدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی شَرْقِیٍّ ، عَنْ أَبِی عُثْمَانَ النَّہْدِیِّ ؛ أَنَّہُ صَلَّی مَعَ عُمَرَ سَنَتَیْنِ الْمَغْرِبَ دُونَ جَمْعٍ۔,,,14220,,
14221,حدَّثَنَا وَکِیعٌ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، عَنْ عَبْدِ الأَعْلَی ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ صَلَّی دُونَ جَمْعٍ بِالأَجْبَالِ۔,,,14221,,
14222,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ؟ قَالَ : لاَ صَلاَۃَ إِلاَّ بِجَمْعٍ۔",,,14222,,
14223,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ خَالِدِ بْنِ أَبِی عُثْمَانَ ، قَالَ : رَأَیْتُ أَبَانَ بْنَ عُثْمَانَ صَلَّی الْمَغْرِبَ فِی الشِّعْبِ قَبْلَ أَنْ یَأْتِیَ جَمْعًا۔",,,14223,,
14224,"حدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ؟ قَالَ : لاَ أَعْلَمُ الصَّلاَۃَ لَیْلَۃَ جَمْعٍ إِلاَّ بِجَمْعٍ۔",,,14224,,
14225,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنِ السَّکَنِ بْنِ الْمُغِیرَۃِ ، قَالَ : صَلَّی بِنَا سَالِمٌ الْمَغْرِبَ قَبْلَ أَنْ یَأْتِیَ جَمْعًا۔",,,14225,,
14226,"حدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : لاَ تُصَلَّی الْمَغْرِبُ إِلاَّ بِجَمْعٍ ، إِلاَّ أَنْ تُخْطِئَ طَرِیقًا ، أَوْ تُضِلَّ رَاحِلَتَک۔",,,14226,,
14227,"حدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : أَرَأَیْتَ إِنْ صَلاَّہُمَا بِالطَّرِیقِ ؟ قَالَ : لاَ بَأْسَ ، قُلْتُ : أَرَأَیْتَ إِنْ صَلَّی الْمَغْرِبَ فِی الطَّرِیقِ ، وَالْعِشَائَ بِجَمْعٍ ؟ قَالَ : لاَ بَأْسَ۔",,,14227,,
14228,"حدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، قَالَ : کَانَ عمَرُ بْنُ عَبْدِ الْعَزِیزِ وَاقِفًا بِعَرَفَۃَ ، فَقَالَ : أَیُّہَا النَّاسُ ، قَدْ جِئْتُمْ مِنَ الْقَرِیبِ وَالْبَعِیدِ ، وَإِنَّکُمْ وَفْدٌ غَیْرُ وَاحِدٍ ، وَإِنَّ السَّابِقَ لَیْسَ الَّذِی تَسْبِقُ دَابَّتُہُ ، وَلاَ بَعِیرُہُ ، وَإِنَّ السَّابِقَ مَنْ غَفَرَ اللَّہُ لَہُ ذَنْبَہُ ۔ فَنَادَاہُ رَجُلٌ : أَیْنَ أُصَلِّی الْمَغْرِبَ ؟ قَالَ : أَیْنَ أَدْرَکْتَ مِنْ وَادِیکَ ہَذَا۔",,,14228,,
14229,حدَّثَنَا عَائِذُ بْنُ حَبِیبٍ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، أَنَّہُ کَانَ إذَا أَفَاضَ مِنْ عَرَفَاتٍ رُبَّمَا صَلَّی فِی الشِّعْبِ الأَیْسَرِ عَلَی الْجَبَلِ۔,,,14229,,
14230,"حدَّثَنَا ابْنُ أَبِی عَدِیٍّ، عَنْ أَشْعَثَ، عَنِ الْحَسَنِ ، قَالَ: یُکْرَہُ أَنْ یُصَلِّیَ دُونَ جَمْعٍ ، فَإِنْ فَعَلَ أَجْزَأَ عَنْہُ۔",,,14230,,
14231,حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ زَمْعَۃَ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، أَنَّہُ کَانَ یَکْرَہُ الصَّلاَۃَ دُونَ الْمُزْدَلِفَۃِ ، إِلاَّ مِنْ ضَرُورَۃٍ۔,,,14231,,
14232,"حدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ إبْرَاہِیمَ بْنِ عُقْبَۃَ ، عَنْ کُرَیْبٍ ، قَالَ : أَخْبَرَنِی أُسَامَۃُ بْنُ زَیْدٍ ، قَالَ : أَفَضْتُ مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِنْ عَرَفَاتٍ، فَلَمَّا کَانَ بِبَعْضِ الطَّرِیقِ قُلْتُ: الصَّلاَۃَ، فَقَالَ: الصَّلاَۃُ أَمَامَکَ۔\n\n(بخاری 139۔ ابوداؤد 1920)",,,14232,,
14233,حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عَنْ عُمَرَ ؛ أَنَّہُ صَلاَّہُمَا بِجَمْعٍ۔,,,14233,,
14234,حدَّثَنَا حَفْصٌ ، عَنِ ابْنِ أَبِی رَوَّادٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ إذَا فَاتَتْہُ الصَّلاَۃُ مَعَ الإِمَامِ بِعَرَفَۃَ، جَمَعَ بَیْنَ الظُّہْرِ وَالْعَصْرِ فِی رَحْلِہِ۔,,,14234,,
14235,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا صَلَّیْت فِی رَحْلِکَ بِعَرَفَۃَ ، فَصَلِّ کُلَّ وَاحِدَۃٍ مِنْہُمَا لِوَقْتِہَا ، وَاجْعَلْ لِکُلِّ وَاحِدَۃٍ مِنْہُمَا أَذَانًا وَإِقَامَۃً۔",,,14235,,
14236,"حدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، قَالَ : إذَا صَلَّیْتَ فِی رَحْلِکَ ، فَإِنْ شِئْتَ فَاجْمَعْ بَیْنَہُمَا ، وَإِنْ شِئْتَ فَصَلِّ کُلَّ وَاحِدَۃٍ مِنْہُمَا لِوَقْتِہَا۔",,,14236,,
14237,"حدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، قَالَ : مَا صَلَّی أَبِی قَطُّ مَعَ الإِمَامِ بِعَرَفَۃَ، وَکَانَ یَجْمَعُ بَیْنَہُمَا ، وَکَانَ یَتَطَوَّعُ بَیْنَہُمَا ، وَکَانَ یَفْعَلُ ذَلِکَ مِنَ الْجَنَدِ حَتَّی یَأْتِیَ مَکَّۃَ۔",,,14237,,
14238,"حدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : تُصَلَّی کُلُّ صَلاَۃٍ لِوَقْتِہَا۔",,,14238,,
14239,حدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ عَدِیِّ بْنِ ثَابِتٍ ، عَنْ عَبْدِ اللہِ بْنِ یَزِیدَ ، عَنْ أَبِی أَیُّوبَ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ جَمَعَ بَیْنَ الْمَغْرِبِ وَالْعِشَائِ بِالْمُزْدَلِفَۃِ۔ (احمد 5/418۔ دارمی 1883),,,14239,,
14240,"حدَّثَنَا شَرِیکٌ ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ جَمَعَ بَیْنَ الصَّلاَتَیْنِ بِجَمْعٍ ، ثُمَّ قَالَ : رَأَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَعَلَہُ۔ (بخاری 1673۔ ابوداؤد 1921)",,,14240,,
14241,"حدَّثَنَا سَلاَّمُ أَبُو الأَحْوَصِ ، عَنْ سِمَاکٍ ، عَنِ النُّعْمَانِ بْنِ حُمَیْدٍ ، قَالَ : رَأَیْتُ عُمَرَ بْنَ الْخَطَّابِ جَمَعَ الْمَغْرِبَ وَالْعِشَائَ بِجَمْعٍ۔",,,14241,,
14242,"حدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ، وَأَبُو الأَحْوَص، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، قَالَ : صَلَّیْتُ مَعَ عَبْدِ اللہِ الْمَغْرِبَ بِجَمْعٍ ، بِأَذَانٍ وَإِقَامَۃٍ ، ثُمَّ أَتَیْنَا بِعَشَائٍ فَتَعَشَّیْنَا ، ثُمَّ صَلَّی بِنَا الْعِشَائَ بِأَذَانٍ وَإِقَامَۃٍ۔\n\nزَادَ فِیہِ أَبُو بَکْرِ بْنُ عَیَّاشٍ : قَالَ أَبُو إِسْحَاقَ : فَلَقِیتُ أَبَا جَعْفَرٍ فَأَخْبَرْتُہُ ، فَقَالَ : وَکَذَلِکَ یَفْعَلُ أَہْلُ الْبَیْتِ۔",,,14242,,
14243,"حدَّثَنَا ابْنُ أَبِی عَدِیٍّ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَمُحَمَّدِ ، قَالاَ : مِنَ السُّنَّۃِ أَنْ یُجْمَعَ بَیْنَہُمَا۔",,,14243,,
14244,حدَّثَنَا عَائِذُ بْنُ حَبِیبٍ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، أَنَّہُ کَانَ إذَا أَفَاضَ مِنْ عَرَفَاتٍ إنَّمَا یُصَلِّی فِی الشِّعْبِ الأَیْسَرِ ، وَعَلَی الْجَبَلِ ، وَأَنَّہُ کَانَ یَجْمَعُ بَیْنَ الْمَغْرِبِ وَالْعِشَائِ الآخِرَۃَ۔,,,14244,,
14245,"حدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ حُسَیْنِ بْنِ عُقَیْلٍ ، عَنِ الضَّحَّاکِ ، قَالَ : یُجْمَعُ بَیْنَہُمَا بِجَمْعٍ۔",,,14245,,
14246,حدَّثَنَا وَکِیعٌ ، عَنْ شَرِیکٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی جَعْفَرٍ ؛ أَنَّ عَلِیًّا جَمَعَ بَیْنَہُمَا بِجَمْعٍ۔,,,14246,,
14247,"حدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ ، قَالَ : صَلَّی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْمَغْرِبَ وَالْعِشَائَ بِأَذَانٍ وَاحِدٍ وَإِقَامَتَیْنِ ، وَلَمْ یُسَبِّحْ بَیْنَہُمَا۔",,,14247,,
14248,"حدَّثَنَا ابْنُ مُسْہِرٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَدِیِّ بْنِ ثَابِتٍ ، عَنْ عَبْدِ اللہِ بْنِ یَزِیدَ ، عَنْ أَبِی أَیُّوبَ ، قَالَ: صَلَّی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِالْمُزْدَلِفَۃِ الْمَغْرِبَ وَالْعِشَائَ بِإِقَامَۃٍ۔\n\n(طبرانی 3871۔ احمد 5/421)",,,14248,,
14249,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : قَالَ سَعِیدُ بْنُ جُبَیْرٍ : أَفَضْنَا مَعَ ابْنِ عُمَرَ حَتَّی أَتَیْنَا جَمْعًا ، فَصَلَّی بِنَا الْمَغْرِبَ وَالْعِشَائَ بِإِقَامَۃٍ وَاحِدَۃٍ ، ثُمَّ انْصَرَفَ ، فَقَالَ : ہَکذَا صَلَّی بِنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی ہَذَا الْمَکَانِ۔ (مسلم 291۔ ابوداؤد 1926)",,,14249,,
14250,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : صَلَّیْتُ مَعَہُ الْمَغْرِبَ وَالْعِشَائَ بِإِقَامَۃٍ وَاحِدَۃٍ ، وَقَالَ : فَعَلْتُہُ مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,14250,,
14251,"حدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : اتَّفَقَ عَلِیٌّ ، وَعَبْدُ اللہِ أَنَّ کُلَّ صَلاَۃٍ تُجْمَعُ بِأَذَانٍ وَإِقَامَۃٍ۔",,,14251,,
14252,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُحَمَّدِ بْن أَبِی إسْمَاعِیلَ ، قَالَ : صَلَّیْتُ بِجَمْعٍ مَعَ سَعِیدِ بْنِ جُبَیْرٍ الْمَغْرِبَ وَالْعِشَائَ بِإِقَامَۃٍ وَاحِدَۃٍ۔",,,14252,,
14253,حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ أَنَسِ بْنِ سِیرِینَ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ صَلَّی الصَّلاَتَیْنِ بِجَمْعٍ بِإِقَامَۃٍ وَاحِدَۃٍ۔,,,14253,,
14254,حدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ سِمَاک، عَنِ النُّعْمَان بْنِ حُمَیْدٍ؛ أَنَّ عُمَرَ صَلَّی الْمَغْرِبَ وَالْعِشَائَ بِإِقَامَۃٍ,,,14254,,
14255,حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ؛ أَنَّ الأَسْوَدَ أَقَامَ الصَّلاَۃَ وَصَلَّی الْمَغْرِبَ بِالْمُزْدَلِفَۃِ ، ثُمَّ تَعَشَّی ، ثُمَّ صَلَّی الْعِشَائَ۔,,,14255,,
14256,"حدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ مِسْعَرٍ ، عَنْ عَبْدِ الْکَرِیمِ ، قَالَ : صَلَّیْتُ خَلْفَ سَالِمٍ الْمَغْرِبَ وَالْعِشَائَ بِجَمْعٍ ، بِأَذَانٍ وَاحِدٍ وَإِقَامَتَیْنِ ، فَلَقِیتُ نَافِعًا فَقُلْتُ لَہُ : ہَکَذَا کَانَ یَصْنَعُ عَبْدُ اللہِ ؟ قَالَ : ہَکَذَا ، فَلَقِیتُ عَطَائً فَقُلْتُ : قَدْ کُنْتُ أَقُولُ لَہُمْ لاَ صَلاَۃَ إِلاَّ بِإِقَامَۃٍ۔",,,14256,,
14257,"حدَّثَنَا ہُشَیْمٌ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : عَلَیْہِ ہَدْیٌ آخَرُ۔",,,14257,,
14258,"حدَّثَنَا ہُشَیْمٌ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : عَلَیْہِ ہَدْیٌ آخَرُ۔",,,14258,,
14259,حدَّثَنَا ہُشَیْمٌ ، عَنْ حُمَیْدٍ ، عَنِ الْحَسَنِ ، أَنَّہُ کَانَ یَقُولُ ذَلِکَ۔,,,14259,,
14260,"حدَّثَنَا وَکِیعٌ ، عَنْ عُمَرَ بْنِ ذِرٍّ ، عَنْ مُجَاہِدٍ، قَالَ: إذَا حَلَقَ قَبْلَ أَنْ یَذْبَحَ ہَدْیَہُ، قَالَ: عَلَیْہِ ہَدْیٌ آخَرُ۔",,,14260,,
14261,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، قَالَ : علَیْہِ دَمٌ ، قَالَ الأَعْمَشُ : فَذَکَرْتُ ذَلِکَ لإِبْرَاہِیمَ ، فَقَالَ : حَدَّثَنِی سَعِیدُ بْنُ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، بِمِثْلِہِ۔",,,14261,,
14262,"حدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : یَذْبَحُ شَاۃً ، أَوْ یُطْعِمُ سِتَّۃَ مَسَاکِینَ ، أَوْ یَصُومُ ثَلاَثَۃَ أَیَّامٍ۔",,,14262,,
14263,"حدَّثَنَا جَرِیرٌ ، عَنْ صَدَقَۃَ بْنِ یَسَارٍ ، عَنْ عَبْدِ اللہِ بْنِ عُمَرَ ، قَالَ : وَقَّتَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لأَہْلِ الْمَدِینَۃِ ذَا الْحُلَیْفَۃِ ، وَلأَہْلِ الشَّامِ الْجُحْفَۃَ ، وَلأَہْلِ الْیَمَنِ یَلَمْلَمَ ، وَلأَہْلِ نَجْدٍ قَرْنًا ، فَقَالَ رَجُلٌ : فَلأَہْلِ الْعِرَاقِ ؟ قَالَ : لاَ عِرَاقَ یَوْمَئِذٍ۔ (بخاری 7344۔ احمد 2/140)",,,14263,,
14264,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : جَائَ رَجُلٌ ، فَقَالَ : یَا رَسُولَ اللہِ ، مِنْ أَیْنَ نُہِلُّ ؟ قَالَ : یُہِلُّ أَہْلُ الْمَدِینَۃِ مِنْ ذِی الْحُلَیْفَۃِ ، وَأَہْلُ الشَّامِ مِنَ الْجُحْفَۃِ ، وَأَہْلُ نَجْدٍ مِنْ قَرْنٍ ، فَقَالَ : ابْنُ عُمَرَ : وَیَقُولُونَ : وَأَہْلُ الْیَمَنِ مِنْ یَلَمْلَمَ۔ (بخاری 1525۔ ترمذی 831)",,,14264,,
14265,"حدَّثَنَا ابْنُ نُمَیْرٍ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ، عَنْ جَابِرٍ، قَالَ: وَقَّتَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لأَہْلِ الْمَدِینَۃِ ذَا الْحُلَیْفَۃِ ، وَلأَہْلِ الشَّامِ الْجُحْفَۃَ ، وَلأَہْلِ الْیَمَنِ یَلَمْلَمَ وَتِہَامَۃَ ، وَلأَہْلِ نَجْدٍ قَرْنًا ، وَلأَہْلِ الْعِرَاقِ ذَاتَ عِرْقٍ۔ (مسلم 840۔ احمد 3/333)",,,14265,,
14266,"حدَّثَنَا یَحْیَی بن آدم ، قَالَ : حدَّثَنَا وُہَیْبٌ ، قَالَ : حدَّثَنَا عَبْدُ اللَّہِ بْنُ طَاوُوس ، عَنْ أَبِیہِ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَقَّتَ لأَہْلِ الْمَدِینَۃِ ذَا الْحُلَیْفَۃِ ، وَلأَہْلِ الشَّامِ الْجُحْفَۃَ ، وَلأَہْلِ نَجْدٍ قَرْنَ الْمَنَازِلِ ، وَلأَہْلِ الْیَمَنِ یَلَمْلَمَ ، وَقَالَ : ہُنَّ لَہُمْ ، وَلِکُلِّ آتٍ أَتَی عَلَیْہِنَّ مِنْ غَیْرِہِمْ ، مِمَنْ أَرَادَ الْحَجَّ وَالْعُمْرَۃَ ، وَمَنْ کَانَ دُونَ ذَلِکَ فَمِنْ حَیْثُ أَنْشَأَ ، حَتَّی أَہْلُ مَکَّۃَ مِنْ مَکَّۃَ۔\n\n(بخاری 1526۔ ابوداؤد 1735)",,,14266,,
14267,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنْ مُحَمَّدِ بْنِ عَلِیٍّ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : وَقَّتَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لأَہْلِ الْمَشْرِقِ الْعَقِیقَ۔ (ترمذی 832۔ ابوداؤد 1737)",,,14267,,
14268,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : وَقَّتَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لأَہْلِ الْعِرَاقِ ذَاتَ عِرْقٍ۔",,,14268,,
14269,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ أَبِی کَثِیرٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : قُلْتُ لَہُ : مِنْ أَیْنَ نُہِلُّ ؟ قَالَ : مِنَ الْبَیْدَائِ ، مِنْہَا أَہَلَّ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لِحَجَّۃٍ ، وَمِنْہَا أَہَلَّ لِعُمْرَتِہِ۔",,,14269,,
14270,حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ، عَنْ عُبَیْدِاللہِ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ؛ أَنَّ عُمَرَ وَقَّتَ لأَہْلِ الْعِرَاقِ ذَاتَ عِرْقٍ۔,,,14270,,
14271,"حدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ عُمَرُ لأَہْلِ الْعِرَاقِ : اُنْظُرُوا حِذَائَ قَرْنٍ ، فَوَجَدُوا حِذَائَہَا ذَاتَ عِرْقٍ ، وَقَرْنٌ أَقْرَبُ إلَی مَکَّۃَ مِنْ ذَاتِ عِرْقٍ ، قَالَ : فَجَعَلَہُ لأَہْلِ الْعِرَاقِ۔",,,14271,,
14272,حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ لاَ یَدَعُ أَحَدًا مِنْ أَہْلِہِ یُجَاوِزُ الْعَقِیقَ ، إِلاَّ وَہُوَ مُحْرِمٌ۔,,,14272,,
14273,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : حُدَّ لِلنَّاسِ خَمْسَۃً : لأَہْلِ الْمَدِینَۃِ ذُو الْحُلَیْفَۃِ ، وَلأَہْلِ مَکَّۃَ التَّنْعِیمُ ، وَلأَہْلِ الشَّامِ الْجُحْفَۃُ ، وَلأَہْلِ الْیَمَنِ یَلَمْلَمُ ، وَلأَہْلِ نَجْدٍ قَرْنٌ ، أَوْ قَالَ : لأَہْلِ الْعِرَاقِ قَرْنٌ ، فَلَمَّا کَانَ بَعْدُ قَالُوا لابْنِ عَبَّاسٍ : لَیْسَ لَنَا طَرِیقٌ عَلَی قَرْنٍ ، قَالَ : إزَائَہُ ذَاتُ عِرْقٍ۔",,,14273,,
14274,حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عُمَارَۃَ بْنِ زَاذَانَ ، عَنْ ثَابِتٍ ، عَنْ أَنَسٍ ؛ أَنَّہُ کَانَ یُحْرِمُ مِنْ ذَاتِ عِرْقٍ ، وَلاَ یُکَلِّمُ أَحَدًا مِنَ النَّاسِ حَتَّی یَطُوفَ بِالْبَیْتِ ، إِلاَّ مَا لاَ بُدَّ مِنْہُ۔,,,14274,,
14275,"حدَّثَنَا وَکِیعٌ، عَنْ إسْرَائِیلَ، عَنْ ثُوَیْرٍ، قَالَ: حجَجْتُ مَعَ سَعِیدِ بْنِ جُبَیْرٍ، وَمُجَاہِدٍ فَأَحْرَمْنَا مِنَ الْعَقِیقِ۔",,,14275,,
14276,"حدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ إسْرَائِیلَ ، عَنْ إبْرَاہِیمَ بْنِ عَبْدِ الأَعْلَی ، عَنْ سُوَیْد بْنِ غَفَلَۃَ ، قَالَ : خَرَجْتُ مَعَ ابْنِ عُمَرَ فَأَحْرَمَ مِنْ ذَاتِ عِرْقٍ۔",,,14276,,
14277,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : سَمِعْتُ مَسْرُوقًا یَقُولُ : لأَہْلِ الْعِرَاقِ الْعَقِیقُ۔",,,14277,,
14278,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَاصِمٍ ، عَنْ أَنَسٍ ، قَالَ : إذَا خَرَجْتَ وَأَنْتَ تُرِیدُ الْحَجَّ فَلاَ تَقُلْ : إنِّی حَاجٌّ حَتَّی تُہِلَّ ، قَالَ : فَقُلْت : أَیُّ شَیْئٍ أَقُولُ ؟ قَالَ : قُلْ : إنِّی مُسَافِرٌ۔",,,14278,,
14279,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ الْعَلاَئِ بْنِ الْمُسَیَّبِ ، عَنْ خَیْثَمَۃَ ، قَالَ : قَالَ عَبْدُ اللہِ : مَنْ أَرَادَ ہَذَا الْوَجْہَ فَلاَ یَقُلْ إنِّی حَاجٌّ ، إِنَّمَا الْحَاجُّ الْمُحْرِمُ ، وَلْیَقُلْ إنِّی وَافِدٌ۔",,,14279,,
14280,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ فِی الرَّجُلِ یَحُجُّ فَیَبْدُو لَہُ أَنْ یَرْجِعَ قَبْلَ أَنْ یُحْرِمَ ، قَالَ : لاَ بَأْسَ أَنْ یَرْجِعَ قَبْلَ أَنْ یُحْرِمَ۔",,,14280,,
14281,"حدَّثَنَا یَحْیَی بْنُ عَبْدِ الْمَلِکِ بْنِ أَبِی غَنِیَّۃَ ، عَنْ أَبِیہِ ، عَنِ الْحَکَمِ ، قَالَ : إذَا خَرَجَ الرَّجُلُ إلَی مَکَّۃَ ثُمَّ بَدَا لَہُ أَنْ یَرْجِعَ ، رَجَعَ مَا لَمْ یُہِلَّ بِالْحَجِّ۔",,,14281,,
14282,"حدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاووُسٍ قَالاَ : إِنْ شَائَ تَمَّ ، وإنْ شَائَ رَجَعَ۔",,,14282,,
14283,"حدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ ہِلاَلِ بْنِ خَبَّابٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ ضُبَاعَۃَ ابْنَۃَ الزُّبَیْرِ بْنِ عَبْدِ الْمُطَّلِبِ أَتَتِ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَتْ : یَا رَسُولَ اللِہ ، إِنِّی أُرِیدُ الْحَجَّ ، أَفَأَشْتَرِطُ ؟ قَالَ : نَعَمْ اِشْتَرِطِی ، قَالَتْ : کَیْفَ أَقُولُ ؟ قَالَ : قُولِی : لَبَّیْکَ اللَّہُمَّ لَبَّیْکَ ، مَحِلِّی مِنَ الأَرْضِ حَیْثُ حَبَسْتَنِی۔ \n\n(مسلم 106۔ احمد 1/337)",,,14283,,
14284,"حدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : کَانَ عَطَائٌ یُلَبِّی وَلَیْسَ بِمُحْرِمٍ۔",,,14284,,
14285,"حدَّثَنَا ابْنُ مَہْدِیٍّ، عَنْ شُعْبَۃَ، عَنِ الْحَکَمِ؛ فِی الرَّجُلِ یُعَلِّمُ الرَّجُلَ التَّلْبِیَۃَ وَہُوَ حَلاَلٌ، قَالَ: لاَ بَأْسَ بِہِ۔",,,14285,,
14286,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ شُعْبَۃَ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ بِہِ۔",,,14286,,
14287,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ شُعْبَۃَ ، عَنْ أَیُّوبَ ، عَنْ مُجَاہِدٍ ، قَالَ : کَانَ أَہْلُونَا یُعَلِّمُونَا ذَلِکَ۔",,,14287,,
14288,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنِ الرَّبِیعِ ، عَنِ الْحَسَنِ ، وَعَطَائٍ قَالَ : کَانَا لاَ یَرَیَانِ بِہِ بَأْسًا۔",,,14288,,
14289,"حدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، وَابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، قَالَ : حدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ سَابِطٍ ، عَنْ عَیَّاشِ بْنِ أَبِی رَبِیعَۃَ الْمَخْزُومِیِّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تَزَالُ ہَذِہِ الأُمَّۃُ بِخَیْرٍ مَا عَظَّمُوا ہَذِہِ الْحُرْمَۃَ حَقَّ تَعْظِیمِہَا ، فَإِذَا ضَیَّعُوا ذَلِکَ ہَلَکُوا۔ (ابن ماجہ 3110۔ احمد 4/347)",,,14289,,
14290,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : ہَذِہِ حَرَمٌ - یَعْنِی مَکَّۃَ - حَرَّمَہا اللہ یَوْمَ خَلَقَ السَّمَاوَاتِ وَالأَرْضِ ، وَوَضَعَ ہَذَیْنِ الأَخْشَبَیْنِ لَم تَحِلَّ لأَحَدٍ قَبْلِی ، وَلاَ تَحِلُّ لأَحَدٍ بَعْدِی ، وَلَمْ تَحِلَّ لِی إلاَّ سَاعَۃً مِنْ نَہَارٍ ، وَلاَ یُخْضَدُ شَوْکُہَا ، وَلاَ یُنَفَّرُ صَیْدُہَا ، وَلاَ یُخْتَلَی خَلاَہَا ، وَلاَ تُرْفَعُ لُقَطَتُہَا إِلاَّ لِمُنْشِدٍ ، فَقَالَ الْعَبَّاسُ : یَا رَسُولَ اللہِ ، إِنَّ أَہْلَ مَکَّۃَ لاَ صَبْرَ لَہُمْ عَنِ الإِذْخِرِ ، لِقَیْنِہِم وَلِبِنَائِہِم ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِلاَّ الإِذْخِرَ۔\n\n(بخاری 1587۔ مسلم 986)",,,14290,,
14291,"حدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ طَلْقِ بْنِ حَبِیبٍ ، قَالَ : قَالَ عُمَرُ : یَا أَہْلَ مَکَّۃَ ، اتَّقُوا اللَّہَ فِی حَرَمِ اللہِ ، أَتَدْرُونَ مَنْ کَانَ سَاکِنَ ہَذَا الْبَلَدِ ؟ کَانَ بِہِ بَنُو فُلاَنٍ فَأَحَلُّوا حُرَمَہُ فَأُہْلِکُوا ، وَکَانَ بِہِ بَنُو فُلاَنٍ فَأَحَلُّوا حُرَمَہُ فَأُہْلِکُوا ، حَتَّی ذَکَرَ مَا شَائَ اللَّہُ مِنْ قَبَائِلِ الْعَرَبِ أَنْ یَذْکُرَ ، ثُمَّ قَالَ : لأَنْ أَعْمَلَ عَشْرَ خَطَایَا بِرُکْبۃِ ، أَحَبَّ إلَیَّ مِنْ أَنْ أَعْمَلَ ہَاہُنَا خَطِیئَۃً وَاحِدَۃً۔",,,14291,,
14292,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ السُّدِّیِّ ، عَنْ مُرَّۃَ ، عَنْ عَبْدِ اللہِ ، قَالَ : مَنْ ہَمَّ بِسَیِّئَۃٍ لَمْ تُکْتَبْ عَلَیْہِ حَتَّی یَعْمَلَہَا ، وَإِنْ ہَمَّ بِعَدَنٍ أَبْیَنَ أَنْ یَقْتُلَ عِنْدَ الْمَسْجِدِ الْحَرَامِ ، أَذَاقَہُ اللَّہُ مِنْ عَذَابٍ أَلِیمٍ ، ثُمَّ قَرَأَ : {وَمَنْ یُرِدْ فِیہِ بِإِلْحَادٍ بِظُلْمٍ}۔",,,14292,,
14293,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی سُلَیْمَانَ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو قَالَ : إنَّ الْحَرَمَ مُحَرَّمٌ فِی السَّمَاوَاتِ السَّبْعِ مِقْدَارُہُ مِنَ الأَرْضِ، وَإِنَّ الْبَیْتَ الْمُقَدَّسَ مُقَدَّسُ فِی السَّمَاوَاتِ السَّبْعِ مِقْدَارُہُ مِنَ الأَرْضِ۔",,,14293,,
14294,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنِ ابْنِ سَابِطٍ ، قَالَ : کَانَ النَّاسُ إذَا کَانَ الْمَوْسِمُ بِالْجَاہِلِیَّۃِ خَرَجُوا فَلَمْ یَبْقَ أَحَدٌ بِمَکَّۃَ ، وَإِنَّہُ تَخَلَّفَ رَجُلٌ سَارِقٌ فَعَمَدَ إلَی قِطْعَۃٍ مِنْ ذَہَبٍ فَوَضَعَہَا ، ثُمَّ دَخَلَ لِیَأْخُذَ أَیْضًا ، فَلَمَّا أَدْخَلَ رَأْسَہُ صَرَّہُ الْبَابُ ، فَوَجَدُوا رَأْسَہُ فِی الْبَیْتِ ، وَاسْتَہُ خَارِجًا ، فَأَلْقَوْہُ لِلْکِلاَبِ وَأَصْلَحُوا الْبَیْتَ۔",,,14294,,
14295,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ، أَنَّہُ کَانَ لَہُ فُسْطَاطَانِ ؛ أَحَدُہُمَا فِی الْحَرَمِ وَالآخَرُ فِی الْحِلِّ ، فَإِذَا أَرَادَ أَنْ یُصَلِّیَ صَلَّی فِی الَّذِی فِی الْحَرَمِ ، وَإِذَا کَانَتْ لَہُ الْحَاجَۃُ إلَی أَہْلِہِ ، جَائَ إلَی الَّذِی فِی الْحِلِّ ، فَقِیلَ لَہُ فِی ذَلِکَ ؟ فَقَالَ : إنَّ مَکَّۃَ مَکَّۃُ۔",,,14295,,
14296,"حدَّثَنَا عَبْدُ الْوَہَّابِ ، عَنْ خَالِدٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : قُلْتُ لَہُ : مَا لاَ یُنَفَّرُ صَیْدُہَا ؟ قَالَ : تُحَوِّلُہُ مِنَ الظِّلِّ إلَی الشَّمْسِ ، وَتَنْزِلُ مَکَانَہُ۔",,,14296,,
14297,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ زِیَادِ بْنِ سَعْدٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ سَمِعَ أَبَا ہُرَیْرَۃَ یَقُولُ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : یُخَرِّبُ الْکَعْبَۃَ ذُو السُّوَیْقَتَیْنِ مِنَ الْحَبَشَۃِ۔\n\n(بخاری 1591۔ مسلم 57)",,,14297,,
14298,"حدَّثَنَا إسْحَاقُ الأَزْرَقُ ، عَنْ ہِشَامِ بْنِ حَسَّانَ ، عَنْ حَفْصَۃَ ، عَنْ أَبِی الْعَالِیَۃِ ، عَنْ عَلِیِّ بْنِ أَبِی طَالِبٍ ، قَالَ : کَأَنِّی أَنْظُرُ إلَی رَجُلٍ مِنَ الْحَبَشِ ، أَصْلَعَ ، أَصْمَعَ ، حَمْشِ السَّاقَیْنِ ، جَالِسٌ عَلَیْہَا وَہُوَ یَہْدِمُہَا۔",,,14298,,
14299,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ سَمِعَ ابْنَ عَمْرٍو یَقُولُ : کَأَنِّی بِہِ أُصَیْلِعٌ ، أُفَیْدِعٌ ، قَائِمٌ عَلَیْہَا یَہْدِمُہَا بِمِسْحَاتِہِ ، فَلَمَّا ہَدَمَہَا ابْنُ الزُّبَیْرِ جَعَلْتُ أَنْظُرُ إِلَی صِفَۃِ ابْنِ عَمْرٍو فَلَمْ أَرَہَا۔\n\n(احمد 220)",,,14299,,
14300,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ دَاوُدَ بْنِ شَابُورَ ، عَنْ مُجَاہِدٍ ، قَالَ : لَمَّا أَجْمَعَ ابْنُ الزُّبَیْرِ عَلَی ہَدْمِہَا ، خَرَجْنَا إلَی مِنًی ثَلاَثًا نَنْتَظِرُ الْعَذَابَ۔",,,14300,,
14301,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنْ أَبِی صَادِقٍ ، عَنْ حَنشٍ الْکِنَانِیِّ ، عَنْ عَلِیمٍ الْکِنْدِیِّ ، عَنْ سَلْمَانَ ، قَالَ : لَیُحْرَقَنَّ ہَذَا الْبَیْتُ عَلَی یَدَیْ رَجُلٍ مِنْ آلِ الزُّبَیْرِ۔",,,14301,,
14302,"حدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ مُجَاہِدٍ ، قَالَ : لَمَّا ہُدِمَ الْبَیْتُ ، وُجِدَ فِیہِ صَخْرَۃٌ مَکْتُوبٌ فِیہَا : أَنَا اللَّہُ ذُو بَکَّۃَ ، صُغْتُہُ یَوْمَ صُغْتُ الشَّمْسَ وَالْقَمَرَ ، حَفَفْتُہُ بِسَبْعَۃِ أَمْلاَکٍ حُنَفَائَ ، بَارَکْتُ لأَہْلِہِ فِی السَّمْنِ وَالسَّمِینِ ، لاَ یَزُولُ حَتَّی یَزُولَ الأَخْشَبَانِ ، یَعْنِی الْجَبَلَیْنِ ، وَأَوَّلُ مَنْ یَحِلُّہَا أَہْلُہَا۔",,,14302,,
14303,"حدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سَلَمَۃُ بْنُ نُبَیْطٍ ، عَنِ الضَّحَّاکِ بْنِ مُزَاحِمٍ ، قَالَ : لَمَّا کُسِرَ الْبَیْتُ ، جَائَ سَیْلٌ فَقَلَبَ حَجَرًا مِنْ حِجَارَۃِ الْبَیْتِ ، فَإِذَا مَکْتُوبٌ فِیہِ : أَنَا اللَّہُ ذُو بَکَّۃَ ، صُغْتُہُ یَوْمَ صُغْتُ الْجَبَلَیْنِ ، بَنَیْتُہُ عَلَی وَجْہِ سَبْعَۃِ أَمْلاَکٍ حُنَفَائَ ، لَیْسُوا یَہُودًا ، وَلاَ نَصَارَی۔",,,14303,,
14304,"حدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا زَکَرِیَّا ، عَنْ عَامِرٍ ، قَالَ : حَدَّثَنِی مَنْ قَرَأَ کِتَابًا فِی بحتخہ فِی سَقْفِ الْبَیْتِ، أَوْ أَسْفَلَ مَقَامِ إبْرَاہِیمَ : أَنَا اللَّہُ ذُو بَکَّۃَ ، بَنَیْتُہُ عَلَی وُجُوہِ سَبْعَۃِ أَمْلاَکٍ حُنَفَائَ ، بَارَکْتُ لأَہْلِہِ فِی اللَّحْمِ وَالْمَائِ ، وَجَعَلْت رِزْقَ أَہْلِہِ مِنْ ثَلاَثَۃِ سُبُلٍ ، وَلاَ یَسْتَحِلَّ حُرْمَتَہُ أَوَّلُ مَنْ أَہَلَّہُ۔",,,14304,,
14305,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ سُلَیْمَانَ بْنِ مِینَائَ ، قَالَ : سَمِعْتُ عَبْدَ اللہِ بْنَ عَمْرٍو یَقُولُ : إذَا رَأَیْتُمْ قُرَیْشًا قَدْ ہَدَمُوا الْبَیْتَ ، ثُمَّ بَنُوہُ فَزَوَّقُوہُ ، فَإِنَ اسْتَطَعْتَ أَنْ تَمُوتَ فَمُتْ۔",,,14305,,
14306,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ یَعْلَی بْنِ عَطَائٍ ، عَنْ أَبِیہِ ، قَالَ : کُنْتُ آخُذًا بِلِجَامِ دَابَّۃِ عَبْدِ اللہِ بْنِ عَمْرٍو، فَقَالَ: کَیْفَ أَنْتُمْ إذَا ہَدَمْتُمْ ہَذَا الْبَیْتَ، فَلَمْ تَدَعُوا حَجَرًا عَلَی حَجَرٍ؟ قَالُوا: وَنَحْنُ عَلَی الإِسْلاَمِ؟ قَالَ: وَنَحْنُ عَلَی الإِسْلاَمِ ، قُلْتُ : ثُمَّ مَاذَا ؟ قَالَ : ثُمَّ یُبْنَی أَحْسَنَ مَا کَانَ ، فَإِذَا رَأَیْتَ مَکَّۃَ قَدْ بُعِجَتْ کَظَائِم ، وَرَأَیْتَ الْبِنَائَ یَعْلُو رُؤُوسَ الْجِبَالِ ، فَاعْلَمْ أَنَّ الأَمْرَ قَدْ أَظَلَّک۔",,,14306,,
14307,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حُمَیْدٍ ، عَنْ بَکْرِ بْنِ عَبْدِ اللہِ الْمُزَنِیّ ، عنْ عَبْدِ اللہِ بْنِ عَمْرٍو قَالَ : تَمَتَّعُوا مِنْ ہَذَا الْبَیْتِ قَبْلَ أَنْ یُرْفَعَ ، فَإِنَّہُ سَیُرْفَعُ وَیُہْدَمُ مَرَّتَیْنِ ، وَیُرْفَعُ فِی الثَّالِثَۃِ۔",,,14307,,
14308,"حدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ عَبْدِ الْمَلِکِ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، عَنْ عَائِشَۃَ ، قَالَتْ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَوْ کَانَ عِنْدَنَا سَعَۃٌ لَہَدَمْتُ الْکَعْبَۃَ ، وَلَبَنَیْتُہَا وَجَعَلْتُ لَہَا بَابَیْنِ ؛ بَابًا یَدْخُلُ مِنْہُ النَّاسُ ، وَبَابًا یَخْرُجُونَ مِنْہُ ، قَالَ : فَلَمَّا وَلِیَ ابْنُ الزُّبَیْرِ ہَدَمَہَا ، فَجَعَلَ لَہَا بَابَیْنِ ، فَکَانَتْ کَذَلِکَ ، فَلَمَّا ظَہَرَ الْحَجَّاجُ عَلَیْہِ ہَدَمَہَا وَأَعَادَ بِنَائَہَا الأَوَّلَ۔ (بخاری 1583۔ مسلم 968)",,,14308,,
14309,حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی بَکْرٍ ، عَنْ أَبِیہِ ، عَنْ أَبِی الْبَدَّاحِ بْنِ عَدِیٍّ ، عَنْ أَبِیہِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَخَّصَ لِلرِّعَائِ أَنْ یَرْمُوا یَوْمًا ، وَیَدَعُوا یَوْمًا۔ (ابوداؤد 1970۔ ابن ماجہ 3036),,,14309,,
14310,حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَخَّصَ لِلرِّعَائِ أَنْ یَرْمُوا لَیْلاً۔ (بیہقی 151),,,14310,,
14311,"حدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنْ عَطَائٍ ؛ أَنَّ عُمَرَ رَخَّصَ لِلرِّعَائِ أَنْ یَبِیتُوا عَنْ مِنًی ، قَالَ : فَذَکَرْتُ ذَلِکَ لِلزُّہْرِیِّ ؟ فَقَالَ : الرِّعَائُ یَرْمُونَ لَیْلاً ، وَلاَ یَبِیتُونَ۔",,,14311,,
14312,حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عُبَیدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَجْعَلُ رَمْیَ الْجِمَارِ نَوَائِبَ بَیْنَ رِعَائِ الإِبِلِ ، یَأْمُرُ الَّذِینَ عِنْدَہُ فَیَرْمُونَ إِذَا زَالَتِ الشَّمْسُ ، ثُمَّ یَذْہَبُونَ إلَی الإِبِلِ ، وَیَأْتِی الَّذِینَ فِی الإِبِلِ فَیَرْمُونَ ، ثُمَّ یَمْکُثُونَ حَتَّی یَرْمُوہَا مِنَ الْغَدِ إِذَا زَالَتِ الشَّمْسُ۔,,,14312,,
14313,"حدَّثَنَا شَرِیکٌ ، عَنْ مُحَمَّدِ بْنِ أَبِی إسْمَاعِیلَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : یَرْکَبُ الْمَاشِی إذَا رَمَی الْجَمْرَۃَ۔",,,14313,,
14314,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ، عَنْ عَمْرٍو، عَنِ الْحَسَنِ، قَالَ: لاَ یَرْکَبُ الْمَاشِی حَتَّی یَقْضِی الْمَنَاسِکَ کُلَّہَا۔",,,14314,,
14315,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ، قَالَ : لاَ یَرْکَبُ الْمَاشِی حَتَّی یَصْدُرَ۔",,,14315,,
14316,حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُثَنَّی ، عَنْ عَطَائٍ ؛ مِثْلَہُ۔,,,14316,,
14317,"حدَّثَنَا یَحْیَی بْنُ سُلَیْمٍ الطَّائِفِیُّ ، عَنْ عَبْدِ اللہِ بْنِ عُثْمَانَ ، قَالَ : سَمِعْتُ مُجَاہِدًا ، وَسَعِیدَ بْنَ جُبَیْرٍ یَقُولاَنِ : کُنَّا نَرَی عَبْدَ اللہِ بْنَ عَبَّاسٍ إِذَا رَمَی الْجَمْرَۃَ یَرْفَعُ یَدَیْہِ حَتَّی یُسَاوِیَ رَأْسَہُ ، وَیُرَی بَیَاضُ إبْطَیْہِ ، وَکَانَ حَصَاہُ مِثْلَ البُنْدُقَۃِ الْحَادِرَۃِ۔",,,14317,,
14318,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ خُثَیْمٍ ، عَنْ مُجَاہِدٍ ، قَالَ : إذَا رَمَی الْجَمْرَۃَ فَلْیَرْفَعْ یَدَیْہِ حَتَّی یُرَی بَیَاضُ إبْطَیْہِ۔",,,14318,,
14319,"حدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، قَالَ : أَخْبَرَنِی الْوَلِیدُ بْنُ دِینَارٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ إذَا رَمَی الْجَمْرَۃَ تَقَدَّمَ أَمَامَہَا ، فَدَعَا اللَّہَ وَرَفَعَ یَدَیْہِ وَرَفَعْنَا مَعَہُ ، فَمَا یَضَعُ یَدَیْہِ حَتَّی نَمَلَّ وَنَضَعَ أَیْدِینَا ، وَہُوَ کَمَا ہُوَ۔",,,14319,,
14320,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَطَائٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ قَالَ : تُرْفَعُ الأَیْدِی عِنْدَ الْجِمَارِ۔",,,14320,,
14321,"حدَّثَنَا وَکِیعٌ، عَنْ أَشْعَثَ، عَنْ نَافِعٍ، قاَلَ: کَانَ أَصْحَابُ عَبْدِاللہِ یَقُولُونَ: تُرْفَعُ الأَیْدِی عِنْدَ الْجَمْرَتَیْنِ۔",,,14321,,
14322,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْحَکَمِ ، عَنْ مِقْسَمٍ ، عَنِ ابْنِ عَبَّاسٍ (ح) وَعَنِ ابْنِ أَبِی لَیْلَی، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالاَ : تُرْفَعُ الأَیْدِی عِنْدَ الْجِمَارِ۔",,,14322,,
14323,"حدَّثَنَا ابْنُ الْمُبَارَکِ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یَحُجُّ فَیَمُوتُ قَبْلَ أَنْ یَقْضِیَ نُسُکَہُ ، قَالَ : یُقْضَی عَنْہُ مَا بَقِیَ مِنْ نُسُکِہِ۔",,,14323,,
14324,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ أَبِی نَہِیکٍ ، قَالَ : سَأَلْتُ طَاوُوسًا عَنِ امْرَأَۃٍ تُوُفِّیَتْ وَقَدْ بَقِیَ عَلَیْہَا مِنْ نُسُکِہَا ؟ قَالَ : یُقْضَی عَنْہَا ، وَسَأَلْتُ الْقَاسِمَ ؟ فَقَالَ : لاَ عِلْمَ لِی بِمَا قَالَ طَاوُوس ، قَالَ اللَّہُ : (لاَ تَزِرُ وَازِرَۃٌ وِزْرَ أُخْرَی)۔",,,14324,,
14325,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنْ أَبِی مَالِکٍ ، قَالَ : مَوْضِعُ الْبَیْتِ بَکَّۃُ ، وَمَا سِوَی ذَلِکَ مَکَّۃُ۔",,,14325,,
14326,"حدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، قَالَ : سَمِعْتُ عِکْرِمَۃَ یَقُولُ : بَکَّۃُ مَا حَوْلَ الْبَیْتِ ، وَمَکَّۃُ مَا وَرَائَ ذَلِکَ۔",,,14326,,
14327,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الأَسْوَدِ بْنِ قَیْسٍ ، عَنْ أَبِیہِ ، عَنِ ابْنِ الزُّبَیْرِ ، قَالَ : إنَّمَا سُمِّیَتْ بَکَّۃَ لأَنَّ النَّاسَ یَجِیؤُنَہَا مِنْ کُلِّ جَانِبٍ حُجَّاجًا۔",,,14327,,
14328,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَمَّادٍ ، قَالَ : سَمِعْتُ سَعِیدَ بْنَ جُبَیْرٍ وَسُئِلَ : لِمَ سُمِّیَتْ بَکَّۃَ ؟ قَالَ : لأَنَّہُمْ یَتَبَاکَّوْنَ فِیہَا۔",,,14328,,
14329,"حدَّثَنَا مُحَمَّدُ بْنُ مَیْمَونٍ ، عَنْ عَمْرِو بْنِ سَعِیدٍ ، قَالَ : إنَّمَا سُمِّیَتْ بَکَّۃَ لأَنَّ النَّاسَ یَتَبَاکَّوْنَ بِہَا۔",,,14329,,
14330,"حدَّثَنَا جَعْفَرُ بْنُ عَوْنٍ ، عَنْ مِسْعَرٍ ، عَنْ عُتْبَۃَ بْنِ قَیْسٍ ، عَنِ ابْنِ عمَرَ ، قَالَ : مَکَّۃَ بُکَّتْ بَکًا ، الذَّکَرُ فِیہَا کَالأُنْثَی۔",,,14330,,
14331,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنْ مُجَاہِدٍ ، قَالَ : إنَّمَا سُمِّیَتْ بَکَّۃَ لأَنَّ النَّاسَ یَبُکَّ بَعْضُہُمْ بَعْضًا ، وَإِنَّہُ یَحِلُّ فِیہَا مَا لاَ یَحِلُّ فِی غَیْرِہَا۔",,,14331,,
14332,"حدَّثَنَا وَکِیعٌ ، عَنْ فُضَیْلٍ ، عَنْ عَطِیَّۃَ ، قَالَ : بَکَّۃُ مَوْضِعُ الْبَیْتِ ، وَمَا حَوْلَہُ مَکَّۃُ۔",,,14332,,
14333,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی مِجْلَزٍ ؛ أَنَّ جِبْرِیلَ أَتَی بِإِبْرَاہِیمَ عَرَفَاتٍ، فَقَالَ: عَرَفْتَ؟ قَالَ : نَعَمْ ، قَالَ : فَمِنْ ثَمَّ سُمِّیَتْ عَرَفَاتٍ۔",,,14333,,
14334,"حدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : إنَّمَا سُمِّیَتْ عَرَفَاتٍ لأَنَّ جِبْرِیلَ کَانَ یُرِی إبْرَاہِیمَ الْمَنَاسِکَ فَیَقُولُ : عَرَفْتَ ؟ ثُمَّ یُرِیہِ فَیَقُولُ : عَرَفْتَ ؟ فَسُمِّیَتْ عَرَفَاتٍ۔",,,14334,,
14335,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ سُلَیْمَانَ بْنِ الْمُغِیرَۃِ ، عَنْ حُمَیْدِ بْنِ ہِلاَلٍ ، عَنْ عَبْدِ اللہِ بْنِ الصَّامِتِ ، عَنْ أَبِی ذَرٍّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنَّہَا مُبَارَکَۃٌ ، یَعْنِی زَمْزَمَ ، طَعَامُ مَنْ طَعِمَ۔",,,14335,,
14336,"حدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ قَالَ فِی مَائِ زَمْزَمَ : طَعَامُ مَنْ طَعِمَ ، وَشِفَائُ مَنْ سَقِمَ۔",,,14336,,
14337,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الْعَلاَئِ بْنِ أَبِی الْعَبَّاسِ ، عَنْ أَبِی الطُّفَیْلِ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : کُنَّا نُسَمِّی زَمْزَمَ شَبَّاعَۃً ، وَنَزْعُمُ أَنَّہَا نِعْمَ الْعَوْنُ عَلَی الْعِیَالِ۔",,,14337,,
14338,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، قَالَ : حدَّثَنِی رَجُلٌ مِنْ أَہْلِ الشَّامِ ، عَنْ کَعْبٍ ، قَالَ : سَمِعْتُہُ یَقُولُ : إنَّ فِی کِتَابِ اللہِ الْمُنَزَّلِ : أَنَّ مَائَ زَمْزَمَ طَعَامُ طُعْمٍ ، وَشِفَائُ سُقْمٍ۔",,,14338,,
14339,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سُفْیَانَ ، قَالَ : أَخْبَرَنَا أَبُو إِسْحَاقَ ، عَنْ قَیْسِ بْنِ کُرْکُمٍ ، قَالَ : سَأَلْتُ ابْنَ عَبَّاسٍ فَقُلْتُ : أَخْبِرْنِی عَنْ مَائِ زَمْزَمَ ؟ فَقَالَ : أُخْبِرُکَ بِعَلَمٍ ، لاَ تُنْزَحُ ، وَلاَ تُنْزَفُ ، وَلاَ تُذَمُّ طَعَامُ مَنْ طَعِمَ، وَشِفَائُ مَنْ سَقِمَ۔",,,14339,,
14340,"حدَّثَنَا سَعِیدُ بْنُ زَکَرِیَّا ، وَزَیْدُ بْنُ الْحُبَابِ ، عَنْ عَبْدِ اللہِ بْنِ الْمُؤَمَّلِ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَائُ زَمْزَمَ لِمَا شُرِبَ لَہُ۔ (احمد 3/357۔ بیہقی 148)",,,14340,,
14341,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عُمَرَ بْنِ أَبِی عُثْمَانَ ، عَنْ طَاوُوسٍ ، قَالَ : نِیَّتہ۔",,,14341,,
14342,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، وَحَفْصٌ ، عَنِ ابْنِ عَوْنٍ ، عَنِ القَاسِمِ قَالَ : نِیَّتِہِ۔",,,14342,,
14343,"حدَّثَنَا شَرِیکٌ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُوسٍ ، وَمُجَاہِدٍ (ح) وَعَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ (ح) وَعَنْ جَابِرٍ ، عَنْ عَامِرٍ ؛ قَالُوا : نِیَّتہ۔",,,14343,,
14344,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، قَالَ : انْطَلَقْتُ مُعْتَمِرًا فِی رَجَبَ ، فَأَرَدْتُ أَنْ أُہِلَّ بِعُمْرَۃٍ فَأَہْلَلْتُ بِالْحَجِّ ، فَسَأَلْتُ سَعِیدَ بْنَ جُبَیْرٍ عَنْ ذَلِکَ ؟ فَضَحِکَ ، وَقَالَ : لاَ شَیْئَ عَلَیْک ، وَقَالَ الْحَسَنُ مِثْلَ قَوْلِ سَعِیدِ بْنِ جُبَیْرٍ۔",,,14344,,
14345,"حدَّثَنَا أَبُو خَالِدٍ ، عَنْ أَشْعَثَ ، عَنْ عَطَائٍ ؛ فِی رَجُلٍ أَرَادَ الْعُمْرَۃَ فَلَبَّی بِالْحَجِّ ، قَالَ : لَیْسَ الْحَجُّ عَلَیْہِ بِوَاجِبٍ۔",,,14345,,
14346,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ، عَنِ ابْنِ جُرَیْجٍ، عَنِ الْحَسَنِ بْنِ مُسْلِمٍ، عَنْ طَاوُوسٍ؛ فِی الرَّجُلِ یَقْدَمُ مُعْتَمِرًا یَوْمَ عَرَفَۃَ ، فَیَطُوفُ بِالْبَیْتِ وَیَسْعَی بَیْنَ الصَّفَا وَالْمَرْوَۃِ ، قَالَ : لاَ یَأْتِ النِّسَائَ وَالنَّاسُ وُقُوفٌ بِعَرَفَۃَ۔",,,14346,,
14347,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجَ ، عَنْ عَطَائٍ ، قَالَ : لاَ بَأْسَ بِہِ۔",,,14347,,
14348,"حدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ سِمَاکٍ ، عَنْ خَالِدِ بْنِ عَرْعَرَۃَ ، عَنْ عَلِیٍّ ؛ أَنَّ إبْرَاہِیمَ عَلَیْہ السَلاَم قَالَ لابْنِہِ: ابْغِنِی حَجَرًا ، قَالَ : فَذَہَبَ ، ثُمَّ جَائَ وَقَدْ رَکِبَہُ ، فَقَالَ : مِنْ أَیْنَ ہَذَا ؟ قَالَ : جَائَنِی بِہِ مَنْ لَمْ یَتَّکِلْ عَلَی بِنَائِکَ ، جَائَنِی بِہِ جِبْرِیلُ مِنَ السَّمَائِ۔",,,14348,,
14349,"حدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : الْحَجَرُ مِنْ حِجَارَۃِ الْجَنَّۃِ ، وَلَوْلاَ مَا مَسَّہُ مِنْ أَنْجَاسِ أَہْلِ الْجَاہِلِیَّۃِ ، مَا مَسَّہُ مِنْ ذِی عَاہَۃٍ إِلاَّ بَرَأَ۔",,,14349,,
14350,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنْ مُجَاہِدٍ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو قَالَ : لَقَدْ نَزَلَ الْحَجَرُ مِنَ الْجَنَّۃِ، وَإِنَّہُ أَشَدُّ بَیَاضًا مِنَ الثَّلْجِ ، فَمَا سَوَّدَہُ إِلاَّ خَطَایَا بَنِی آدَمَ۔",,,14350,,
14351,"حدَّثَنَا عَبْدَۃُ ، عَنْ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، قَالَ : سُئِلَ کَعْبٌ عَنِ الْحَجَرِ الأَسْوَدِ ؟ فَقَالَ : حَجَرٌ مِنْ حِجَارَۃِ الْجَنَّۃِ۔",,,14351,,
14352,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ شُعْبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسٍ ، قَالَ : الْحَجَرُ مِنْ حِجَارَۃِ الْجَنَّۃِ۔",,,14352,,
14353,"حدَّثَنَا وَکِیعٌ ، عَنْ سَوَادَۃَ بْنِ أَبِی الأَسْوَدِ ، عَنْ أَبِیہِ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو قَالَ : حُجُّوا ہَذَا الْبَیْتَ ، وَاسْتَلِمُوا ہَذَا الْحَجَرَ ، فَوَاللَّہِ لَیُرْفَعَنَّ ، أَوْ لَیُصِیبَنَّہُ أَمْرٌ مِنَ السَّمَائِ ، إِنْ کَانَا لَحَجَرَیْنِ أُہْبِطَا مِنَ الْجَنَّۃِ ، فَرُفِعَ أَحَدُہُمَا وَسَیُرْفَعُ الآخَرُ ، وَإِنْ لَمْ یَکُنْ کَمَا قُلْتُ ، فَمَنْ مَرَّ عَلَی قَبْرِی فَلْیَقُلْ : ہَذَا قَبْرُ عَبْدِ اللہِ بْنِ عَمْرٍو الْکَذَّابِ۔",,,14353,,
14354,"حدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنْ زِیَادٍ مَوْلَی بَنِی مَخْزُومٍ ، قَالَ : لَوْلاَ مَا مَسَّ الْحَجَرَ مِنْ ذُنُوبِ بَنِی آدَمَ ، مَا مَسَّہُ مِنْ ذِی عَاہَۃٍ إِلاَّ بَرَأَ۔",,,14354,,
14355,"حدَّثَنَا حَفْصٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ {وَمَنْ یُعَظِّمْ شَعَائِرَ اللہِ فَإِنَّہَا مِنْ تَقْوَی الْقُلُوبِ} قَالَ : فِی الاسْتِئْذَانِ وَالاسْتِحْسَانِ وَالاسْتِعْظَامِ۔",,,14355,,
14356,"حدَّثَنَا یَزِید ، عَنْ دَاوُدَ بْنِ أَبِی ہِنْدٍ ، عَنْ مُحَمَّدِ بْنِ أَبِی مُوسَی ، قَالَ فِی قَوْلِہِ تَعَالَی : {وَمَنْ یُعَظِّمْ شَعَائِرَ اللہِ فَإِنَّہَا مِنْ تَقْوَی الْقُلُوبِ} قَالَ : الْوُقُوفُ بِعَرَفَۃَ مِنْ شَعَائِرِ اللہِ ، وَبجَمْعٍ مِنْ شَعَائِرِ اللہِ ، وَالْبُدْنُ مِنْ شَعَائِرِ اللہِ ، وَالْحَلْقُ مِنْ شَعَائِرِ اللہِ ، وَالرَّمْیُ مِنْ شَعَائِرِ اللہِ ، فَمَنْ یُعَظِّمْہَا فَإِنَّہَا مِنْ تَقْوَی الْقُلُوبِ۔",,,14356,,
14357,"حدَّثَنَا عَبْدُ الْوَہَّابِ ، عَنْ حَبِیبٍ الْمُعَلِّمِ ، عَنْ عَطَائٍ ؛ أَنَّہُ سُئِلَ عَنْ شَعَائِرِ اللہِ ؟ فَقَالَ : حرُمَاتُ اللہِ ، اجْتِنَابُ سَخَطِ اللہِ وَاتِّبَاعُ طَاعَتِہِ ، فَذَلِکَ شَعَائِرُ اللہِ۔",,,14357,,
14358,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ غَیْلاَنَ ، عَنِ الْحَکَمِ ، عَنْ مُجَاہِدٍ : (وَمَنْ یُعَظِّمْ شَعَائِرَ اللہِ) قَالَ : اسْتِعْظَامُہَا وَاسْتِحْسَانُہَا۔",,,14358,,
14359,حدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَنْزِلُ الأَبْطَحَ أَوَّلَ مَا یَقْدَمُ۔,,,14359,,
14360,حدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ عَبْدِ اللہِ بْنِ عُثْمَانَ بْنِ خُثیم ، عَنْ یُوسُفَ بْنِ مَاہَکٍ ، أَنَّ عَبْدَ اللہِ بْنَ السَّائِبِ حَدَّثَہُ ؛ أَنَّ عُمَرَ بْنَ الْخَطَّابِ قَدِمَ مَکَّۃَ فَنَزَلَ بِأَعْلَی مَکَّۃَ۔,,,14360,,
14361,حدَّثَنَا وَکِیعٌ ، عَنْ أَبِی الْعُمَیْسِ ، عَنِ الْقَاسِمِ ، بْنِ أَبِی بَزَّۃَ ، عَنْ أَبِی عُبَیْدَۃَ ، عَنْ عَبْدِ اللہِ بْنِ مَسْعُودٍ ؛ أَنَّہُ نَزَلَ دَارَ أُمِّ ہَانِیئٍ۔,,,14361,,
14362,حدَّثَنَا وَکِیعٌ ، عَنْ طَلْحَۃَ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ نَزَلَ دَارَ أُمِّ ہَانِیئٍ فِی شَہْرِ رَمَضَانَ۔,,,14362,,
14363,حدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، عَنْ أَبِیہِ ؛ أََنَّ عَائِشَۃَ کَانَتْ تَنْزِلُ بِمَکَّۃَ بِالأَبْطَحِ ، وَتُدْعَی إلَی الدُّورِ فَتَأْبَی۔,,,14363,,
14364,"حدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ : إذَا بَلَغَتِ الْبَدَنَۃُ الْحَرَمَ فَقَدْ وَفَّتْ۔",,,14364,,
14365,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : کُلُّ ہَدْیٍ دَخَلَ الْحَرَمَ فَقَدْ وَفَّی عَنْ صَاحِبِہِ ، إِلاَّ ہَدْیَ الْمُتْعَۃِ ، فَإِنَّہُ لاَ بُدَّ لَہُ مِنْ نَسِیکَۃٍ یَحِلُّ بِہَا یَوْمَ النَّحْرِ۔",,,14365,,
14366,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُوسٍ ، وَمُجَاہِدٍ أَنَّہُمْ قَالُوا : الْقَارِنُ وَالْمُتَمَتِّعُ ہَدْیُہُمَا وَطَوَافُہُمَا وَاحِدٌ۔",,,14366,,
14367,حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ، عَنْ حَجَّاجٍ، عَنْ أَبِی جَعْفَرٍ؛ أَنَّ ابْنَ عَبَّاسٍ، وَعَلِیَّ بْنَ حُسَیْنٍ کَانَا لاَ یَرْمُلاَنِ۔,,,14367,,
14368,"حدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : إِنْ شَائَ رَمَلَ ، وَإِنْ شَائَ لَمْ یَرْمُلْ ، قَالَ : وَکَانَ عَطَائٌ یَرَاہُ وَاسِعًا ، إِنْ شَائَ رَمَلَ ، وَإنْ شَائَ لَمْ یَرْمُلْ ، وَکَانَ الرَّمَلُ أَحَبَّ إلَیْہِ۔",,,14368,,
14369,"حدَّثَنَا ابْنُ مُبَارَکٍ، عَنْ سَعِیدِ بْنِ عَبْدِالْعَزِیزِ، عَنْ عَطَائٍ؛ فِی الرَّجُلِ یَنْسَی الرَّمَلَ، قَالَ: لَیْسَ عَلَیْہِ شَیْئٌ۔",,,14369,,
14370,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، قَالَ : کَانَ ابْنُ عُمَرَ لاَ یَرْمُلُ إذَا أَہَلَّ مِنْ مَکَّۃَ۔",,,14370,,
14371,"حدَّثَنَا حَفْصٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، قَالَ سَعِیدُ بْنُ جُبَیْرٍ : لاَ یَحِلُّ الْمُحْصَرُ إِلاَّ بِدَمٍ۔",,,14371,,
14372,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ رَجُلٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ یَحِلُّ الْمُحْصَرُ إِلاَّ بِدَمٍ۔",,,14372,,
14373,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : یَصُومُ عَشْرَۃَ أَیَّامٍ۔",,,14373,,
14374,"حدَّثَنَا وَکِیعٌ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ: لاَ یُرْفَعُ الصَّوْتُ بِالْقِرَائَ ۃِ عَشِیَّۃَ عَرَفَۃَ ، فِی الظُّہْرِ وَالْعَصْرِ۔",,,14374,,
14375,"حدَّثَنَا حَمَّادُ بْنُ مَسْعَدَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : حضَرْتُ إبْرَاہِیمَ بْنَ ہِشَامٍ یَوْمَ عَرَفَۃَ وَافَقَ یَوْمَ جُمُعَۃٍ، فَجَہَرَ بِالْقِرَائَ ۃِ ، فَقَالَ سَالِمٌ بِیَدِہِ ، أَیْ اُسْکُتْ۔",,,14375,,
14376,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، أَوْ طَاوُوسٍ قَالَ : لاَ یَجْہَرُ الإِمَامُ عَشِیَّۃَ عَرَفَۃَ، وَلَوْ وَافَقَ ذَلِکَ یَوْمَ جُمُعَۃٍ۔",,,14376,,
14377,"حدَّثَنَا ابْنُ مَہْدِی ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، مِثْلَہُ ، قَالَ : وَہُوَ رَأْیُ سُفْیَانَ۔",,,14377,,
14378,حدَّثَنَا زَیْدُ بْنُ حُبَابٍ، عَنْ لَیْثِ بْنِ سَعْدٍ، عَنِ الزُّہْرِیِّ؛ أَنَّ الإِمَامَ لاَ یَجْہَرُ فِی الظُّہْرِ وَالْعَصْرِ بِالْقِرَائَۃِ یَوْمَ عَرَفَۃَ۔,,,14378,,
14379,حدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ حَمَّادٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یُدْخِلُ غِلْمَانَہُ الْحَرَمَ بِغَیْرِ إحْرَامٍ ، یَنْتَفِعُ بِہِمْ۔,,,14379,,
14380,حدَّثَنَا عُمَرُ بْنُ عَلِیِّ بْنِ عَطَائِ بْنِ مُقَدَّمٍ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ؛ أَنَّ أَبَاہُ کَانَ یُدْخِلُ غِلْمَانَہُ الْحَرَمَ ، وَہُمْ غَیْرُ مُحْرِمِینَ۔,,,14380,,
14381,"حدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ یَمْنَعَ الرَّجُلُ غُلاَمَہُ مِنَ الإِحْرَامِ ، وَقَالَ ابْنُ سِیرِینَ : لاَ أَعْلَمُ ذَلِکَ مِنَ الإِحْسَانِ۔",,,14381,,
14382,"حدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ خَالِدِ بْنِ أَبِی بَکْرٍ ، قَالَ : رَأَیْتُ سَالِمًا یُخْرِجُ غِلْمَانَہُ إلَی الْحَجِّ ، فَلاَ یُحْرِمُونَ مِنْ ذِی الْحُلَیْفَۃِ ، یُحْرِمُونَ مِنْ أَمَامِ ذَلِکَ۔",,,14382,,
14383,"حدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ زَیْدِ بْنِ السَّائِبِ ، قَالَ : رَأَیْتُ خَارِجَۃَ بْنَ زَیْدٍ یُخْرِجُ غِلْمَانَہُ ، فَیُہِلُّونَ مَعَہُ مِنْ ذِی الْحُلَیْفَۃِ۔",,,14383,,
14384,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ تَعَجَّلَ فِی یَوْمَیْنِ فَأَصَابَ صَیْدًا ، قَالَ : کَانَ لاَ یَرَی عَلَیْہِ شَیْئًا۔",,,14384,,
14385,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ بیان ، عَنِ الشَّعْبِیِّ ؛ أَنَّہُ سُئِلَ عَنْ رَجُلٍ تَعَجَّلَ فِی یَوْمَیْنِ ، یَصْطَادُ ؟ قَالَ : إذَا خَرَجَ مِنَ الْحَرَمِ فَلاَ بَأْسَ۔",,,14385,,
14386,حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَبِیبِ بْنِ أَبِی ثَابِتٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ کَانَ یَرُدُّہُمْ إلَی الْمَوَاقِیتِ ؛ الَّذِینَ یَدْخُلُونَ مَکَّۃَ بِغَیْرِ إحْرَامٍ۔,,,14386,,
14387,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، قَالَ : کَتَبَ أَبُو الْخَلِیلِ إلَی سَعِیدِ بْنِ جُبَیْرٍ یُخْبِرُہُ : أَنَّہُ إنَّمَا یُہِلُّ مِنْ مَکَّۃَ مَنْ دَخَلَہَا بِغَیْرِ إحْرَامٍ۔",,,14387,,
14388,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، عَنْ جَابِرٍ ، قَالَ : بَصُرَ عَیْنِی رَأَیْتُ ابْنَ عَبَّاسٍ یَرُدُّہُمْ إلَی الْمَوَاقِیتِ۔",,,14388,,
14389,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرٍوَ قَالَ : مَرَّ جَابِرُ بْنُ زَیْدٍ بِامْرَأَۃٍ تَبْکِی ، فَقَالَ : مَا یُبْکِیک ؟ قَالَتْ : مَرَرْت بِمِیقَاتِی وَأَنَا حَائِضٌ فَجَاوَزْتُہُ ، وَلَمْ أُہِلَّ ، قَالَ : لِمَ ؟ قَالَتْ : نَہَوْنِی ، قَالَ : فَاخْرُجِی فَأَہِلِّی مِنْ مَکَان آخَرَ۔",,,14389,,
14390,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَبِیبٍ ، عَنْ إبْرَاہِیمَ ؛ فِی رَجُلٍ دَخَلَ مَکَّۃَ لاَ حَاجًّا ، وَلاَ مُعْتَمِرًا وَہُوَ یَخَافُ إِنْ خَرَجَ إلَی الْوَقْتِ أَنْ یَفُوتَہُ ، قَالَ : یُہِلُّ مِنْ مَکَانِہِ ، وَلَمْ یَذْکُرْ دَمًا۔",,,14390,,
14391,"حدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، عَنْ وَبَرَۃَ ، قَالَ : دَخَلَ رَجُلٌ مَکَّۃَ وَعَلَیْہِ ثِیَابُہُ ، وَحَضَرَ الْحَجُّ ، وَخَافَ إِنْ رَجَعَ أَنْ یَفُوتَہُ ، فَأَمَرَہُ ابْنُ الزُّبَیْرِ أَنْ یُہِلَّ مِنْ مَکَانِہِ ، فَإِذَا قَضَی الْحَجَّ خَرَجَ إلَی الْوَقْتِ فَأَہَلَّ بِعُمْرَۃٍ۔",,,14391,,
14392,"حدَّثَنَا غُنْدَرٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ سُئِلَ عَنْ رَجُلٍ جَہِلَ حَتَّی دَخَلَ مَکَّۃَ ، أَنَّہُ کَانَ عُظْمُ قَوْلہِ یُہِلُّ مِنْ مَکَانِہِ ، وَقَدْ قَالَ الْحَسَنُ : إِنَّمَا یَرْجِعُ إلَی حَدِّہِ لِیُہِلَّ مِنْہُ ، إِلاَّ أَنْ یَخْشَی الْفَوْتَ ، فَإِنْ خَشِیَ الْفَوْتَ أَہَلَّ مِنْ مَکَانِہِ وَمَضَی ، وَلاَ شَیْئَ عَلَیْہِ۔",,,14392,,
14393,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : یُہِلّ مِنْ مَکَانِہِ وَعَلَیْہِ دَمٌ۔",,,14393,,
14394,"حدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ عُمَرُ یَحُجُّ فَلاَ یَذْبَحُ شَیْئًا حَتَّی یَرْجِعَ۔",,,14394,,
14395,"حدَّثَنَا عَبْدَۃُ ، عَنْ عُثْمَانَ بْنِ حَکِیمٍ ، قَالَ : قَالَ نَافِعُ بْنُ جُبَیْرٍ : مَا ضَحَّیْتُ بِمَکَّۃَ قَطُّ۔",,,14395,,
14396,"حدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ أَصْحَابُنَا یَحُجُّونَ وَمَعَہُمُ الأَوْرَاقُ وَالذَّہَبُ ، فَمَا یَذْبَحُونَ شَیْئًا ، وَکَانُوا یَتْرُکُونَہُ مَخَافَۃَ أَنْ یَشْغَلَہُمْ عَنْ شَیْئٍ مِنَ الْمَنَاسِکِ۔",,,14396,,
14397,حدَّثَنَا وَکِیعٌ ، عَنْ أَفْلَحَ ، عَنِ الْقَاسِمِ ، عَنْ عَائِشَۃَ ؛ أَنَّہَا کَانَتْ تَحُجُّ فَلاَ تُضَحِّی عَنْ بَنِی أَخِیہَا۔,,,14397,,
14398,"حدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ أَبِی الدَّرْدَاء ، عَنْ مُجَاہِدٍ ، قَالَ: مَانُصَلِّی ہَاہُنَا، وَمَا یُضَحِّی یَوْمَ النَّحْرِ۔",,,14398,,
14399,حدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنْ وَبَرَۃَ ؛ أَنَّ الأَسْوَدَ ، وَعَبْدَ الرَّحْمَن بْنَ یَزِیدَ کَانَا یَحُجَّانِ ، وَلاَ یُضَحِّیَانِ۔,,,14399,,
14400,حدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، عَنْ بَیَانٍ ؛ أَنَّ عَلْقَمَۃَ کَانَ یَحُجُّ ، وَلاَ یُضَحِّی۔,,,14400,,
14401,"حدَّثَنَا وَکِیعٌ ، عَنْ أَبِی الْعُمَیْسِ ، عَنْ أَبِی الزَّعْرَائِ ، عَنْ أَبِی الأَحْوَص ؛ أَنَّہُ لَمْ یَکُنْ یُضَحِّی فِی الْحَجِّ ، فَلَمَّا کَانَ أَیَّامُ التَّشْرِیقِ ، قَالَ : اشْتَرُوا بَقَرَۃً فَقَدِّدُوہَا نَتَزَوَّدُہَا فِی سَفَرِنَا۔",,,14401,,
14402,"حدَّثَنَا وَکِیعٌ ، عَنْ أَبِی الْمُسْتَنِیرِ الْمُسْلِیِّ ، عَنْ وَبَرَۃَ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ شَیْخٍ مِنَ التَّیْمِ ، قَالَ : کُنَّا مَعَ سَعْدٍ بِمِنًی فَلَمْ یُضَحِّ ، ثُمَّ أَرْسَلَ إلَی جِیرَانٍ لَہُ : أَطْعِمُونَا مِنْ أُضْحِیَّتِکُمْ۔",,,14402,,
14403,حدَّثَنَا حَفْصٌ ، عَنْ کُلَیْبِ بْنِ وَائِلٍ ، عَنْ عَمِّہِ قَیْسٍ ، عَنْ سَعْدٍ ، بِنَحْوِہِ۔,,,14403,,
14404,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ صَالِحٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : حجَجْتُ ثَلاَثَ حِجَجٍ ، مَا أَہْرَقْتُ دَمًا۔",,,14404,,
14405,حدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ خَالِدٍ ؛ أَنَّہُ کَانَ یَکُونُ مَعَ سَالِمٍ فِی الْحَجِّ ، فَلاَ یُضَحِّی بِمِنًی۔,,,14405,,
14406,"حدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَطَائٍ ، وَمُجَاہِدٍ قَالاَ : قَالَ ابْنُ عَبَّاسٍ : مَنْ حَجَّ فَأَہْدَی ہَدْیًا ، رَجَعَ إلَی أَہْلِہِ بِحَجَّۃٍ وَعُمْرَۃٍ۔",,,14406,,
14407,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یَتْرُکُ الصَّفَا وَالْمَرْوَۃَ ، قَالَ : عَلَیْہِ دَمٌ۔",,,14407,,
14408,"حدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ؛ أَنَّ دَاوُد بْنَ أَبِی عَاصِمٍ قَدِمَ فَتَرَکَ الصَّفَا وَالْمَرْوَۃَ ، فَقَالَ عَطَائٌ : أَہْرِقْ دَمًا ، وَقَالَ طَاوُوس : اُدْخُلْ مُعْتَمِرًا۔",,,14408,,
14409,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ إِسْمَاعِیِل ، عَنْ قَیْسِ بْنِ سَعْدٍ ، عَنْ مُجَاہِدٍ (ح) وَعَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ قَالاَ : إِذَا نَسِیَ الطَّوَافَ بَیْنَ الصَّفَا وَالْمَرْوَۃِ وَہُوَ حَاجٌّ ، فَعَلَیْہِ الْحَجُّ ، فَإِنْ کَانَ مُعْتَمِرًا فَعَلَیْہِ الْعُمْرَۃُ ، وَلاَ یُجْزِئہِ إِلاَّ الطَّوَافُ بَیْنَہُمَا۔",,,14409,,
14410,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إِنْ شَائَ سَعَی بَیْنَ الصَّفَا وَالْمَرْوَۃِ ، وَإِنْ شَائَ لَمْ یَسْعَ۔",,,14410,,
14411,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ أَنَّہُ کَانَ لاَ یَرَی عَلَی مَنْ لَمْ یَسْعَ بَیْنَ الصَّفَا وَالْمَرْوَۃِ شَیْئًا ، قُلْتُ : قدْ تَرَکَ شَیْئًا مِنْ سُنَّۃِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لَیْسَ عَلَیْہِ ، وَکَانَ یُفْتِی فِی الْعَلاَنِیَۃِ بِدَمٍ۔",,,14411,,
14412,"حدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃ ، قَالَتْ : مَا أَتَمَّ اللَّہُ حَجَّ مَنْ لَمْ یَسْعَ بَیْنَ الصَّفَا وَالْمَرْوَۃِ ، ثُمَّ قَرَأَتْ : (إِنَّ الصَّفَا وَالْمَرْوَۃَ مِنْ شَعَائِرِ اللہِ)۔",,,14412,,
14413,"حدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ الْحَسَنِ بْنِ مُسْلِمٍ ، عَنْ صَفِیَّۃَ ابْنَۃِ شَیْبَۃَ ؛ أَنَّہَا سَمِعَتْ عَائِشَۃَ ، وَقِیلَ لَہَا : إِنَّ بَعْضَ بَنَاتِ أَخِیکِ یَکْرَہْنَ أَنْ یَلْبَسْنَ حُلِیَّہُنَّ وَہُنَّ مُحْرِمَاتٌ ، فَأَقْسَمَتْ عَلَیْہَا لَتَلْبَسِنَّ حُلِیَّہَا کُلَّہُ۔",,,14413,,
14414,حدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ؛ أَنَّ نِسَائَ عَبْدِ اللہِ بْنِ عُمَرَ وَبَنَاتِہِ کُنَّ یَلْبَسْنَ الْحُلِیَّ وَہُنَّ مُحْرِمَاتٌ۔,,,14414,,
14415,"حدَّثَنَا أَزْہَرُ السَّمَّانُ، عَنِ ابْنِ عَوْنٍ، عَنْ مُحَمَّدٍ، قَالَ: کَانُوا یَکْرَہُونَ التَّعَطُّلَ لِلْمَرْأَۃِ فِی الْحِلِّ وَالإِحْرَامِ۔",,,14415,,
14416,"حدَّثَنَا حَکَّامٌ الرَّازِیُّ ، عَنْ سَعِیدٍ الزُّبَیْدِیِّ ، قَالَ : سَأَلَتُ سَعِیدَ بْنَ جُبَیْرٍ عَنِ الْحُلِیِّ وَالْحَرِیرِ لِلْمُحْرِمَۃِ، أَتَلْبَسُہُ ؟ قَالَ : إِنْ کَانَتْ تَلْبَسُہُ وَہِیَ حَلاَلٌ ، فَلْتَلْبِسْہُ وَہِیَ مُحْرِمَۃٌ۔",,,14416,,
14417,"حدَّثَنَا غُنْدَرٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ سُئِلَ عَنِ الْمُحْرِمَۃِ ، مَا تُظْہِرُ مِنَ الْحُلِیِّ ؟ قَالَ : الْخَاتَمُ۔",,,14417,,
14418,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : تَلْبَسُ الْمُحْرِمَۃُ الْحُلِیَّ الْخَفِیَّ وَتُوَارِیہِ۔",,,14418,,
14419,"حدَّثَنَا وَکِیعٌ ، عَنْ شَرِیکٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، عَنِ الأَسْوَدِ ، وَعَلْقَمَۃَ قَالاَ : تَلْبَسُ الْمُحْرِمَۃُ مَا کَانَتْ تَلْبَسُ وَہِیَ مُحِلَّۃٌ ، مِنْ خَزِّہَا وَقَزِّہَا۔",,,14419,,
14420,"حدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ مَالِکِ بْنِ مِغْوَلٍ ، قَالَ : سَأَلْتُ ابْنَ الأَسْوَدِ : ما تَلْبَسُ الْمُحْرِمَۃُ مِنَ الْحُلِیِّ؟ فَقَالَ : مَا کَانَتْ تَلْبَسُ وَہِیَ مُحِلَّۃٌ۔",,,14420,,
14421,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : کَانَ یُکْرَہُ لِلْمُحْرِمَۃِ أَنْ تَلْبَسَ الْحُلِیَّ الْمَشْہُورَ ، قَالَ : قُلْتُ : فَالْعِقْدُ ؟ قَالَ : إِنْ کَانَ عِقْدًا مَشْہُورًا فَلاَ۔",,,14421,,
14422,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ ، عَنْ مُجَاہِدٍ ، قَالَ : لاَ تَتَزَیَّنُ الْمُحْرِمَۃُ ، وَلاَ تَکْتَحِلُ لِزِینَۃٍ۔",,,14422,,
14423,حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ عَطَائٍ ؛ أَنَّہُ کَرِہَ الْحُلِیَّ لِلْمُحْرِمَۃِ۔,,,14423,,
14424,"حدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : کَانَ یُکْرَہُ أَنْ تَلْبَسَ الْمُحْرِمَۃُ الْحُلِیَّ۔",,,14424,,
14425,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی الْہَیْثُمِ ، عَنْ إبْرَاہِیمَ ، قَالَ : سَأَلْتُُہُ عَنْہُ ، یَعْنِی الْخَاتَمَ لِلْمُحْرِم ؛ فَقَالَ : لاَ بَأْسَ ، قَدْ کُنَّا نَطُوفُ بِالْبَیْتِ وَہُوَ عَلَیْنَا ، نَحْفَظُ بِہِ الأُسْبُوعَ۔",,,14425,,
14426,"حدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ الْغَازِ ، عَنْ عَطَائٍ ، قَالَ : لاَ بَأْسَ بِالْخَاتَمِ لِلْمُحْرِمِ۔",,,14426,,
14427,"حدَّثَنَا وَکِیعٌ ، عَنْ شَرِیکٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ بَأْسَ بِالْخَاتَمِ لِلْمُحْرِمِ۔",,,14427,,
14428,"حدَّثَنَا وَکِیعٌ ، عَنْ شُعْبۃ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ؛ قَالَ : لاَ بَأْسَ بِالْخَاتَمِ لِلْمُحْرِمِ۔",,,14428,,
14429,"حدَّثَنَا الْمُحَارِبِیُّ ، عَنِ الْعَلاَئِ ، عَنْ عَطَائٍ ، قَالَ : لاَ بَأْسَ بِالْخَاتَمِ لِلْمُحْرِمِ۔",,,14429,,
14430,"حدَّثَنَا مَعْنُ بْنُ عِیسَی، عَنْ خَالِدِ بْنِ أَبِی بَکْرٍ ، قَالَ: رَأَیْتُ سَالِمَ بْنَ عَبْدِ اللہِ یَلْبَسُ خَاتَمَہُ وَہُوَ مُحْرِمٌ۔",,,14430,,
14431,"حدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ إسْمَاعِیلَ بْنِ عَبْدِ الْمَلِکِ ، قَالَ : رَأَیْتُ عَلَی سَعِیدِ بْنِ جُبَیْرٍ خَاتَمًا وَہُوَ مُحْرِمٌ ، وَعَلَی عَطَائٍ۔",,,14431,,
14432,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَطَائٍ ، قَالَ : لاَ بَأْسَ بِالْخَاتَمِ لِلْمُحْرِمِ۔",,,14432,,
14433,حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ عَلِیٍّ ؛ أَنَّہُ کَانَ یَکْرَہُ أَنْ تَلَثَّمَ الْمُحْرِمَۃُ تَلَثُمًا ، وَلاَ بَأْسَ أَنْ تُسْدِلَہُ عَلَی وَجْہِہَا ، وَیَکْرَہُ الْقُفَّازَیْنِ۔,,,14433,,
14434,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : تَلْبَسُ الْمُحْرِمَۃُ مَا شَائَتْ مِنَ الثِّیَابِ ، إِلاَّ الْبُرْقُعَ وَالْقُفَّازَیْنِ۔",,,14434,,
14435,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : تَلْبَسُ الْمُحْرِمَۃُ مَا شَائَتْ مِنَ الثِّیَابِ ، إِلاَّ الْبُرْقُعَ وَالْقُفَّازَیْنِ۔",,,14435,,
14436,"حدَّثَنَا عَبْدُ اللہِ بْنُ إِدْرِیسَ ، عَنْ یَزِیدَ ، عَنْ مُجَاہِدٍ ، قَالَ : تَلْبَسُ مَا شَائَتْ ، إِلاَّ الْبُرْقُعَ۔",,,14436,,
14437,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَعَطَائٍ ، قَالاَ : تَلْبَسُ الْقُفَّازَیْنِ وَالسَّرَاوِیلَ ، وَلاَ تَبَرْقَعُ وَلا تَلَثَّمُ ، وَتَلْبَسُ مَا شَائَتْ مِنَ الثِّیَابِ ، إِلاَّ ثَوْبًا یَنْفُضُ عَلَیْہَا وَرْسًا ، أَوْ زَعْفَرَانًا۔",,,14437,,
14438,حدَّثَنَا وَکِیعٌ ، عَنْ فُضَیْلِ بْنِ غَزْوَانَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَرِہَ الْبُرْقُعَ وَالْقُفَّازَیْنِ لِلْمُحْرِمَۃِ۔,,,14438,,
14439,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، وَعُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : لاَ تَلْبَسُ الْقُفَّازَیْنِ ، وَلاَ تَلْبَسُ ثَوْبًا مَسَّہُ وَرْسٌ ، وَلاَ زَعْفَرَانٌ۔",,,14439,,
14440,"حدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ زَمْعَۃَ ، عَنْ سَلَمَۃَ بْنِ وَہْرَام ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : تَلْبَسُ الْمُحْرِمَۃُ الْقُفَّازَیْنِ وَالسَّرَاوِیلَ۔",,,14440,,
14441,"حدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ ، وَحَمَّادًا عَنِ الْقُفَّازَیْنِ ؟ فَقَالاَ : لاَ بَأْسَ بِہِ۔",,,14441,,
14442,"حدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَنْہَی النِّسَائَ فِی الإِحْرَامِ عَنِ الْقُفَّازَیْنِ وَالنِّقَابِ ، وَمَا مَسَّہُ الْوَرْسُ وَالزَّعْفَرَانُ مِنَ الثِّیَابِ۔ (بخاری 1838۔ ابوداؤد 1822)",,,14442,,
14443,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَائِشَۃَ قَالَتْ : تَلْبَسُ الْمُحْرِمَۃُ مَا شَائَتْ مِنَ الثِّیَابِ ، إِلاَّ الْبُرْقُعَ وَالْقُفَّازَیْنِ ، وَلاَ تَتَنَقِّبُ۔",,,14443,,
14444,"حدَّثَنَا جَرِیرٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ عَلْقَمَۃُ یَخْنِسُ وَجْہَہُ فِی ثَوْبِہِ وَہُوَ مُحْرِمٌ۔",,,14444,,
14445,"حدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، قَالَ : لاَ بَأْسَ إِذَا آذَتْکَ الرِّیحُ وَأَنْتَ مُحْرِمٌ أَنْ تَرْفَعَ ثَوْبَک إلَی وَجْہِکَ ، وَلاَ بَأْسَ لِلْمَرْأَۃِ إِذَا آذَتْہَا الرِّیحُ أَنْ تَسْدُل ثَوْبَہَا علی وَجْہِہَا۔",,,14445,,
14446,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ ، عَنْ مُجَاہِدٍ ، عَنْ عَائِشَۃَ ، قَالَتْ : کُنَّا مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَنَحْنُ مُحْرِمُونَ ، فَإِذَا لَقِینَا الرَّکْبَ سَدَلْنَا ثِیَابَنَا مِنْ فَوْقِ رُؤُوسِنَا عَلَی وُجُوہِنَا ، فَإِذَا جَاوَزْنَا رَفَعْنَاہَا۔\n\n(ابوداؤد 1829۔ دارقطنی 262)",,,14446,,
14447,"حدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا آذَتِ الْمُحْرِمَ الرِّیحُ ، فَلاَ بَأْسَ أَنْ یَرْفَعَ ثَوْبَہُ مِنْ بَیْنِ یَدَیْہِ فیُغَطِّیَ بِہِ إلَی جَبْہَتِہِ۔",,,14447,,
14448,"حدَّثَنَا جَرِیرٌ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ طَاوُوسٍ ، قَالَ : لاَ بَأْسَ أَنْ تُغَطِّیَ وَجْہَکَ وَأَنْتَ مُحْرِمٌ ، وَأَنْفَکَ وَأَنْتَ مُحْرِمٌ إِلَی جَبِینِکَ۔",,,14448,,
14449,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : یَرْفَعُ الْمُحْرِمُ ثَوْبَہُ إِذَا کَانَ مُضْطَجِعًا إِلَی عَیْنَِیہِ، وَتَسْدُلُ الْمُحْرِمَۃُ ثَوْبَہَا عَلَی وَجْہِہَا۔",,,14449,,
14450,"حدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، وَیَزِیدُ بْنُ ہَارُونَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنِ الْقَاسِمِ ، عَنِ الْفُرَافِصَۃِ بْنِ عُمَیْرٍ ، قَالَ : رَأَیْتُ عُثْمَانَ مُغَطِّیًا وَجْہَہُ وَہُوَ مُحْرِمٌ۔",,,14450,,
14451,"حدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : یُغَشِّی وَجْہَہُ بِثَوْبِہِ إلَی شَعْرِ رَأْسِہِ ، وَأَشَارَ أَبُو الزُّبَیْرِ بِثَوْبِہِ حَتَّی رَأْسِہِ۔",,,14451,,
14452,"حدَّثَنَا عَلِی بْنُ مُسْہِرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : الْوَجْہُ فَمَا فَوْقَہُ مِنَ الرَّأْسِ ، فَلاَ یُخَمِّرُ أَحَدٌ الذَّقَنَ فَمَا فَوْقَہُ۔",,,14452,,
14453,حدَّثَنَا وَکِیعُ بْنُ الْجَرَّاحِ ، عَنْ إبْرَاہِیمَ بْنِ نَافِعٍ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ إِذَا نَامَ غَطَّی وَجْہَہُ إِلَی أَطْرَافِ شَعْرِہِ۔,,,14453,,
14454,حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، عَنِ الْقَاسِمِ ، عَنِ الْفُرَافِصَۃِ ؛ رَأَی عُثْمَانَ ، وَزَیْدًا ، وَمَرْوَانَ بْنَ الْحَکَمِ یُخَمِّرُونَ وُجُوہَہُمْ وَہُمْ مُحْرِمُونَ۔,,,14454,,
14455,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی بَکْرٍ ، عَنِ الْفُرَافِصَۃِ ، قَالَ : رَأَیْتُ عُثْمَانَ مُغَطِّیًا وَجْہَہُ بِثَوْبِہِ وَہُوَ مُحْرِمٌ۔",,,14455,,
14456,"حدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ سَالِمِ بْنِ مَاہَانَ ، قَالَ : کَانَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ یُرَخِّصُ لِلْمُحْرِمِ أَنْ یُغَطِّی شَفَتَیْہِ مَا دُونَ أَنْفِہِ۔",,,14456,,
14457,"حدَّثَنَا وَکِیعٌ، عَنْ مَعْقِلٍ، عَنْ عَطَائٍ، قَالَ: یُغَطِّی الْمُحْرِمُ وَجْہَہُ إلَی الْحَاجِبَیْنِ۔ وَقَالَ: ہُوَ قَوْلُ سُفْیَانَ۔",,,14457,,
14458,حدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ عُثْمَانَ بْنِ حَکِیمٍ ، عَنْ إبْرَاہِیمَ بْنِ مُحَمَّدِ بْنِ حَاطِبٍ ؛عَمَّنْ رَأَی عُثْمَانَ مُحْرِمًا مُغَطِّیًا وَجْہَہُ۔,,,14458,,
14459,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، عَنْ أَبِیہِ ، عَنِ الْفُرَافِصَۃِ ، قَالَ : رَأَیْتُ عُثْمَانَ ، وَزَیْدًا ، وَابْنَ الزُّبَیْرِ یُغَطُّونَ وُجُوہَہُمْ وَہُمْ مُحْرِمُونَ ، إِلَی قِصَاصِ الشَّعْرِ۔",,,14459,,
14460,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ رَأَی رَجُلاً مُحْرِمًا قَدِ اسْتَظَلَّ بِعُودٍ ، فَقَالَ : اِضْحَ لِمَنْ أَحْرَمْتَ لَہُ۔",,,14460,,
14461,"حدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عَبْدِ اللہِ بْنِ عَامِرٍ ، قَالَ : خَرَجْتُ مَعَ عُمَرَ فَمَا رَأَیْتُہُ مُضْطَرِبًا فُسْطَاطًا حَتَّی رَجَعَ ، قُلْتُ لَہُ ، أَوْ قِیلَ لَہُ : بِأَیِّ شَیْئٍ کَانَ یَسْتَظِلُّ ؟ قَالَ : کَانَ یَطْرَحُ النِّطَعَ عَلَی الشَّجَرَۃِ فَیَسْتَظِلُّ بِہِ۔",,,14461,,
14462,"حدَّثَنَا وَکِیعٌ ، عَنْ کَثِیرِ بْنِ زَیْدٍ ، عَنِ الْمُطَّلِبِ بْنِ عَبْدِ اللہِ بْنِ حَنْطَبٍ ، قَالَ : کَانَ أَصْحَابُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُضَحُّونَ إِذَا أَحْرَمُوا۔",,,14462,,
14463,"حدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ مُحَمَّدِ بْنِ أَبِی إِسْمَاعِیلَ ، عَنْ أَخِیہِ إِسْمَاعِیلَ بْنِ رَاشِدٍ ، قَالَ : حَجَجْنَا وَمَعَنَا عَمْرُو بْنُ مَیْمُونٍ ، فَأَصَابَنَا بَرْدٌ شَدِیدٌ ، فَکَانَ یُغَطِّی رَأْسَہُ وَنَحْنُ مُحْرِمُونَ۔",,,14463,,
14464,"حدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنِ الْعَلاَئِ بْنِ الْمُسَیَّبِ ، عَنْ عَطَائٍ ، وَعَنْ أَبِیہِ ، قَالاَ : یَسْتَظِلُّ الْمُحْرِمُ بِالْعُودِ وَبِیَدِہِ ، وَمِنَ الْحَرِّ وَالْبَرْدِ۔",,,14464,,
14465,"حدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، قَالَ : کَانَ أَبِی یَجْعَلُ الثَّوْبَ عَلَی الْمَحْمِلِ ، یَسْتَظِلُّ بِہِ۔",,,14465,,
14466,حدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ عِمْرَانَ الْقَطَّانِ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ؛ أَنَّہُ لَمْ یَرَ بَأْسًا أَنْ یَسْتَظِلَّ الْمُحْرِمُ مِنَ الشَّمْسِ۔,,,14466,,
14467,حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ عِمْرَانَ ، عَنْ أَبِی مَطَرٍ ، عَنْ أَبِی الْخَلِیلِ ؛ مِثْلَہُ۔,,,14467,,
14468,"حدَّثَنَا عُمَرُ بْنُ أَیُّوبَ ، عَنْ جَابِرِ بْنِ زَیْدِ بْنِ رِفَاعَۃَ ، قَالَ : رَأَیْتُ مُجَاہِدًا وَہُوَ مُحْرِمٌ ، وَعَلَی رَحْلِہِ کَہَیْئَۃِ الطَّاقِ۔",,,14468,,
14469,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنِ ابْنِ شَبِیبٍ ؛ أَنَّ عَائِشَۃَ سُئِلَتْ عَنِ الْمُحْرِمِ یُصِیبُہُ الْبَرْدُ ؟ فَقَالَتْ : یَقُولُ بِثَوْبِہِ ہَکَذَا ۔ وَرَفَعہُ فَوْقَ رَأْسِہِ۔",,,14469,,
14470,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ؛ بِمِِِثْلِہِ۔",,,14470,,
14471,"حدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ حَبِیبٍ الْمُعَلِّمِ ، عَنْ عَطَائٍ ؛ سُئِلَ عَنْ مُحْرِمٍ أَصَابَہُ مَطَرٌ فَغَطَّی رَأْسَہُ ؟ فَقَالَ : فِدْیَۃٌ مِنْ صِیَامٍ ، أَوْ صَدَقۃ ، أَوْ نُسُکٍ۔",,,14471,,
14472,"حدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ سُلَیْمَانَ ، قَالَ : سَمِعْتُ ذَرًّا یَسْأَلُ إِبْرَاہِیمَ عَنِ الْمُحْرِمِ تُصِیبُہُ السَّمَائُ ، کَیْفَ یَصْنَعُ ؟ قَالَ : یَرْفَعُ قِنَاعَہُ فَوْقَ رَأْسِہِ ، وَلاَ یُغَطِّی بہِ رَأْسَہُ۔",,,14472,,
14473,"حدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : أَوَّلُ مَنْ عَرَّفَ بِالْبَصْرَۃِ ابْنُ عَبَّاسٍ۔",,,14473,,
14474,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ مُوسَی بْنِ أَبِی عَائِشَۃَ ، قَالَ : رَأَیْتُ عَمْرَو بْنَ حُرَیْثٍ یَخْطُبُ یَوْمَ عَرَفَۃَ ، وَقدِ اجْتَمَعَ النَّاسُ إِلَیْہِ۔",,,14474,,
14475,"حدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنِ الأَعْمَشِ ، قَالَ : رَأَیْتُ أَبَا وَائِلٍ وَأَصْحَابَنَا یَجْلِسُونَ یَوْمَ عَرَفَۃَ ، فَیَتَحَدَّثُونَ کَمَا یَتَحَدَّثُونَ فِی سَائِرِ الأَیَّامِ۔",,,14475,,
14476,حدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِیلَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ حَرْمَلَۃَ ؛ أَنَّہُ رَأَی سَعِیدَ بْنَ الْمُسَیَّبِ عَشِیَّۃَ عَرَفَۃَ یُسْنِدُ ظَہْرَہُ إلَی الْمَقْصُورَۃِ ، وَیَسْتَقْبِلُ الشَّامَ حَتَّی تَغْرُبَ الشَّمْسُ۔,,,14476,,
14477,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ أَبِی عَوَانَۃَ ، عَنْ یُونُسَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی بَکْرَۃَ ، قَالَ : مَا کَانَ یَشْہَدُ الْمَسْجِدَ الْجَامِعَ عَشِیَّۃَ عَرَفَۃَ ، إِلاَّ مَنْ کَانَ یَشْہَدُہُ قَبْلَ ذَلِکَ۔",,,14477,,
14478,"حدَّثَنَا إِسْمَاعِیلُ بْنُ إبْرَاہِیمَ، عَنِ ابْنِ عَوْنٍ، قَالَ: کَانُوا یَسْأَلُونَ مُحَمَّدًا عَنْ إتْیَانِ الْمَسْجِدِ عَشِیَّۃَ عَرَفَۃَ؟ فَیَقُولُ: لاَ أَعْلَمُ بِہِ بَأْسًا، فَکَانَ یَقْعُدُ فِی مَنْزِلِہِ، فَکَانَ حَدِیثُہُ فِی تِلْکَ الْعَشِیَّۃِ حَدِیثَہُ فِی سَائِرِ الأَیَّامِ۔",,,14478,,
14479,"حدَّثَنَا ابْنُ مَہْدِی ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، وَحَمَّادٍ ، قَالَ : سَأَلْتُہمَا عَنِ الاجْتِمَاعِ عَشِیَّۃَ عَرَفَۃَ ؟ فَقَالاَ : مُحْدَثٌ۔",,,14479,,
14480,"حدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ سُئِلَ عَنِ التَّعْرِیفِ ؟ فَقَالَ : إِنَّمَا التَّعْرِیفُ بِمَکَّۃَ۔",,,14480,,
14481,"حدَّثَنَا وَکِیعٌ ، عَنْ بُکَیْرِ بْنِ عَامِرٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : الْمُعَرَّفُ بِمَکَّۃَ۔",,,14481,,
14482,"حدَّثَنَا وَکِیعٌ ، عَنِ ابن یَزِیدَ ، عَنِ الشعبی ، قَالَ : إِنَّمَا الْمُعَرَّفُ بِمَکَّۃَ۔",,,14482,,
14483,"حدَّثَنَا شَرِیکٌ ، عَنْ زُبَیْدٍ ، قَالَ : مَا کُنَّا نُعَرِّفُ إِلاَّ فِی مَسَاجِدِنَا۔",,,14483,,
14484,"حدَّثَنَا وَکِیعٌ ، عَنْ إِسْمَاعِیلَ الأَزْرَقِ ، عَنْ أَبِی عُمَرَ ، عَنِ ابْنِ الْحَنَفِیَّۃِ ، قَالَ : إِنَّمَا الْمُعَرَّفُ بِمَکَّۃَ۔",,,14484,,
14485,"حدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ عَبْدِ الْمَلِکِ بْنِ أَبْجَرَ ، عَنْ طَلْحَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إِنَّ أَحَقَّ مَا لَزِمَتِ الرِّجَالُ بُیُوتَہَا یَوْمَ عَرَفَۃَ۔",,,14485,,
14486,"حدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ سَوَّارٍ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ سِیرِینَ ، قَالَ : لَقَدْ رَأَیْتُنَا زَمَانَ زِیَادٍ وَمَا نُنْکِرُ عَشِیَّۃَ عَرَفَۃَ مِنْ سَائِرِ الْعَشِیَّاتِ",,,14486,,
14487,"حدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، وَالْحَکَمِ ، قَالاَ : الْمُعَرَّفُ بِدْعَۃٌ",,,14487,,
14488,حدَّثَنَا ہُشَیْمٌ ، عَنْ بَعْضِ أَصْحَابِہِ ، عَنِ الْحَسَنِ ، وَابْنِ سِیرِینَ ؛ أَنَّہُمَا کَانَا لاَ یَشْہَدَانِ الْمَسْجِدَ عَشِیَّۃَ عَرَفَۃَ۔,,,14488,,
14489,حدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ وَبَرَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَرِہَ زِیَارَۃَ الْبَیْتِ أَیَّامَ التَّشْرِیقِ ، یَعْنِی بَعْدَ الْوَاجِبِ۔,,,14489,,
14490,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا زُرْتَ الْبَیْتَ یَوْمَ النَّحْرِ ، فَلاَ تَعُدْ إلَیْہِ حَتَّی تَنْفِرَ۔",,,14490,,
14491,حدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ مُجَاہِدٍ ؛ أَنَّہُ کَرِہَ زِیَارَتَہُ أَیَّامَ التَّشْرِیقِ ، یَعْنِی بَعْدَ الْوَاجِبِ۔,,,14491,,
14492,حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُفِیضُ کُلَّ لَیْلَۃٍ,,,14492,,
14493,حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَأْتِی الْبَیْتَ أَیَّامَ التَّشْرِیقِ ، وَلَمْ یَکُنْ أَحَدٌ یَفْعَلُہُ,,,14493,,
14494,"حدَّثَنَا وَکِیعُ بْنُ الْجَرَّاحِ ، عَنْ مُغِیرَۃَ بْنِ زِیَادٍ ، عَنْ عَطَائٍ ، قَالَ : إِنْ زُرْتَ الْبَیْتَ أَیَّامَ التَّشْرِیقِ کُلَّ یَوْمٍ، فَہُوَ أَفْضَلُ۔",,,14494,,
14495,"حدَّثَنَا أَبُو خَالِدٍ ، وَأَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنِ الْحَسَنِ بْنِ سَعْدٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : أَخْبَرَنِی أَبُو طَلْحَۃَ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَرَنَ بَیْنَ الْحَجِّ وَالْعُمْرَۃِ۔ (احمد 4/28۔ ابویعلی 1412)",,,14495,,
14496,"حدَّثَنَا وَکِیعُ بْنُ الْجَرَّاحِ ، عَنِ الأَعْمَشِ ، عَنْ مُسْلِمٍ الْبَطِینِ ، عَنْ عَلِیِّ بْنِ حُسَیْنٍ ، عَنْ مَرْوَانَ بْنِ الْحَکَمِ ، قَالَ : کُنَّا نَسِیرُ مَعَ عُثْمَانَ ، فَسَمِعَ رَجُلاً یُلَبِّی بِہِمَا جَمِیعًا ، فَقَالَ عُثْمَانُ : مَنْ ہَذَا ؟ فَقَالُوا : عَلِیٌّ، قَالَ : فَأَتَاہُ عُثْمَانُ ، فَقَالَ : أَلَمْ تَعْلَمْ أَنِّی نَہَیْتُ عَنْ ہَذَا ؟ فَقَالَ : بَلَی ، وَلَکِنْ لَمْ أَکُنْ لأَدَعَ فِعْلَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لِقَوْلِکَ۔ (بخاری 1563۔ احمد 1/135)",,,14496,,
14497,"حدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ عَاصِمٍ ، عَنْ أَبِی وَائِلٍ ، قَالَ : خَرَجْنَا حُجَّاجًا وَمَعَنَا الصُّبَیُّ بْنُ مَعْبَدٍ ، قَالَ : فَأَحْرَمَ بِالْحَجِّ وَالْعُمْرَۃِ ، قَالَ : فَقَدِمْنَا عَلَی عُمَرَ فَذَکَرَ ذَلِکَ لَہُ ، فَقَالَ : ہُدِیتَ لِسُنَّۃِ نَبِیِّکَ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔ (ابوداؤد 1795۔ احمد 1/25)",,,14497,,
14498,حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَبْدَۃَ بْنِ أَبِی لُبَابَۃَ ، عَنْ شَقِیقِ بْنِ سَلَمَۃَ ، عَنِ الصُّبَیِّ بْنِ مَعْبَدٍ ، عَنْ عُمَرَ ؛ بِمِثْلِہِ۔ (ابن ماجہ 2970۔ احمد 1/25),,,14498,,
14499,حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ شَقِیقٍ ، عَنِ الصُّبَیِّ بْنِ مَعْبَدٍ ، عَنْ عُمَرَ ؛ بِمِثْلِہِ۔ (احمد 1/37۔ طیالسی 58),,,14499,,
14500,"حدَّثَنَا شَبَابَۃُ ، عَنْ لَیْثِ بْنِ سَعْدٍ ، عَنْ یَزِیدَ بْنِ أَبِی حَبِیبٍ ، عَنْ أَبِی عِمْرَانَ ، قَالَ : حجَجْتُ مَعَ مَوْلاَی ، فَدَخَلْتُ عَلَی أُمِّ سَلَمَۃَ ، فَقَالَتْ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : یَا آلَ مُحَمَّدٍ ، أَہِلَّوا بِعُمْرَۃٍ وَحَجٍّ۔ (احمد 6/297۔ ابویعلی 7011)",,,14500,,
14501,حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَرَنَ بَیْنَ الْحَجِّ وَالْعُمْرَۃِ ، وَطَافَ لَہمَا طَوَافًا وَاحِدًا۔ (ترمذی 947۔ احمد 3/381),,,14501,,
14502,"حدَّثَنَا شَبَابَۃُ ، عَنْ شُعْبَۃَ ، قَالَ : حدَّثَنِی حُمَیْدُ بْنُ ہِلاَلٍ ، قَالَ: سَمِعْتُ مُطَرِّفَ بْنَ عَبْدِ اللہِ یَقُولُ : حدَّثَنِی عِمْرَانُ بْنُ حُصَیْنٍ ، قَالَ : جَمَعَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَیْنَ الْحَجِّ وَالْعُمْرَۃِ ، ثُمَّ لَمْ یَنْہَ عَنْہُ ، وَلَمْ یَنْزِلْ کِتَابٌ یُحَرِّمْہ۔ (مسلم 168۔ احمد 4/428)",,,14502,,
14503,"حدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی أَسْمَائَ ، عَنْ أَنَسٍ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُلَبِّی بِہِمَا جَمِیعًا : لَبَّیْکَ بِحَجَّۃٍ وَعُمْرَۃٍ ، مَعًا۔ (بخاری 1551۔ ابوداؤد 1792)",,,14503,,
14504,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یَحْیَی بْنِ أَبِی إِسْحَاقَ ، عَنْ أَنَسٍ ؛ أَنَّہُ سَمِعَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : لَبَّیْکَ بِعُمْرَۃٍ وَحَجٍّ۔ (مسلم 214۔ ابوداؤد 1792",,,14504,,
14505,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ إِسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، قَالَ : سَمِعْتُ عَبْدَ اللہِ بْنَ أَبِی قَتَادَۃَ یَقُولُ : إِنَّمَا قَرَنَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لأَنَّہُ أُخْبِرَ أَنَّہُ لَیْسَ بِحَاجٍّ بَعْدَہَا۔",,,14505,,
14506,"حدَّثَنَا شَرِیکُ بْنُ عَبْدِ اللہِ ، عَنْ عَلِیِّ بْنِ زَیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : سَمِعْتُ أَصْحَابَ مُحَمَّدٍ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، یُلَبُّونَ بِعُمْرَۃٍ وَحَجَّۃٍ مَعًا",,,14506,,
14507,"حدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ کَثِیرِ بْنِ جُمْہَانَ ، قَالَ : خَرَجْنَا حُجَّاجًا وَمَعَنَا رَجُلٌ مِنْ أَہْلِ الْجَبَلِ لَمْ یَحُجَّ قَطُّ ، فَأَہَلَّ بِحَجَّۃٍ وَعُمْرَۃٍ ، فَعَابَ ذَلِکَ عَلَیْہِ أَصْحَابُنَا ، قَالَ : فَنَزَلْنَا قَرِیبًا مِنِ ابْنِ عُمَرَ ، قَالَ : فَقُلْنَا لَہُ : إِنَّ مَعَنَا رَجُلاً مِنْ أَہْلِ الْجَبَلِ لَمْ یَحُجَّ قَطُّ ، فَأَہَلَّ بِحَجَّۃٍ وَعُمْرَۃٍ ، فَعَابَ ذَلِکَ عَلَیْہِ أَصْحَابُنَا ، فَمَا کَفَّارَتہُ ؟ قَالَ : کَفَّارَتُہُ أَنْ یَرْجِعَ بِأَجْرَیْنِ وَتَرْجِعُونَ بِوَاحِدٍ۔",,,14507,,
14508,"حدَّثَنَا ابْنُ عُلَیَّۃَ، عَنْ حُمَیْدٍ، عَنْ أَنَسٍ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، قَالَ: لَبَّیْکَ بِعُمْرَۃٍ وَحَجَّۃٍ، مَعًا۔\n\n(ابوداؤد 1792۔ نسائی 3709)",,,14508,,
14509,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ حُمَیْدٍ ، وَمُصْعَب ، عَنْ أَنَسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لَبَّیْکَ بِعُمْرَۃٍ وَحَجَّۃٍ۔ (احمد 3/111۔ حمیدی 1215)",,,14509,,
14510,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، قَالَتْ : خَرَجْنَا مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لاَ نُرَی إِلاَّ الْحَجَّ۔ (بخاری 294۔ مسلم 119)",,,14510,,
14511,"حدَّثَنَا وَکِیعٌ ، عَنِ الأَفْلَحِ ، عَنِ الْقَاسِمِ ، عَنْ عَائِشَۃَ ، قَالَتْ : خَرَجْنَا مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مُہِلِّینَ بِالْحَجِّ۔ (بخاری 1560۔ احمد 6/207)",,,14511,,
14512,"حدَّثَنَا حَفْصٌ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : أَفْرَدَ أَصْحَابُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْحَجَّ بَعْدَہُ أَرْبَعِینَ سَنَۃً ، وَہُمْ کَانُوا لِسُنَّتِہِ أَشَدَّ اتِّبَاعًا ، أَبُو بَکْرٍ ، وَعُمَرُ ، وَعُثْمَانَ۔",,,14512,,
14513,"حدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، وَسُفْیَانُ ، عَنْ أَبِی حَصِینٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، عَنْ أَبِیہِ ؛ أَنَّ أَبَا بَکْرٍ ، وَعُمَرَ جَرَّدَا ، زَادَ سُفْیَانُ : وَعُثْمَانَ۔",,,14513,,
14514,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ شُعْبَۃَ ، عَنْ مُغِیرَۃَ ، قَالَ : أَفْرَدَ الْحَجَّ أَبُو بَکْرٍ ، وَعُمَرُ ، وَعُثْمَانَ ، وَعَلْقَمَۃُ ، وَالأَسْوَدُ۔",,,14514,,
14515,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، قَالَ : سَأَلَتُ سُلَیْمَانَ بْنَ یَسَارٍ عَنِ الْجَمْعِ بَیْنَ الْحَجِّ وَالْعُمْرَۃِ ؟ فَقَالَ : لاَ نُحِبُّ أَنْ نَخْلِطَ بِحَجِّنَا شَیْئًا۔",,,14515,,
14516,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنْ مُجَاہِدٍ ، قَالَ : قَالَ ابْنُ الزُّبَیْرِ : أَفْرِدُوا الْحَجَّ ، وَدَعُوْا قَوْلَ أَعْمَاکُمْ ہَذَا ، یَعْنِی ابْنَ عَبَّاسٍ۔",,,14516,,
14517,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّہُ کَرِہَ القِرَانَ وَالْمُتْعَۃَ ، وَقَالَ : التَّجْرِیدُ أَحَبُّ إِلَیَّ۔",,,14517,,
14518,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ صَالِحٍ الْعُکْلِیِّ ، عَنِ الشَّعْبِیِّ ، قَالَ : التَّجْرِیدُ أَحَبُّ إِلَیَّ۔",,,14518,,
14519,حدَّثَنَا أَبُو مُعَاوِیَۃَ، عَنْ عُبَیْدِ اللہِ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، عَنْ عُمَرَ؛ أَنَّہُ حَجّ خِلاَفَتَہُ کُلَّہَا یُفْرِدُ الْحَجَّ۔,,,14519,,
14520,"حدَّثَنَا إِسْمَاعِیلُ بْنُ إِبْرَاہِیمَ، عَن أَبِی حَمْزَۃَ، عَنْ إِبْرَاہِیمَ، عَنِ الأَسْوَدِ، قَالَ: قَالَ عَبْدُ اللہِ بْنُ مَسْعُودٍ: نُسُکَانِ أَحَبُّ إلَیَّ أَنْ یَکُونَ لِکُلِّ وَاحِدٍ مِنْہُمَا شَعَثٌ وَسَفَرٌ ، قَالَ : فَسَافَرَ الأَسْوَدُ ثَمَانِینَ مَا بَیْنَ حَجَّۃٍ وَعُمْرَۃٍ ، لَمْ یَجْمَعْ بَیْنَہُمَا ، وَسَافَرَ عَبْدُ الرَّحْمَنِ بْنُ الأَسْوَدِ سِتِّینَ مَا بَیْنَ حَجَّۃٍ وَعُمْرَۃٍ ، لَمْ یَجْمَعْ بَیْنَہُمَا۔",,,14520,,
14521,"حدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ مُحَمَّدِ بْنِ أَبِی إِسْمَاعِیلَ ، قَالَ : خَرَجْتُ مَعَ إِبْرَاہِیمَ وَمَعَنَا أَصْحَابٌ لَنَا، فَأَحْرَمُوا جَمِیعًا وَجَرَّدُوا الْحَجَّ۔",,,14521,,
14522,"حدَّثَنَا ہُشَیْمُ بْنُ بَشِیرٍ ، عَنْ مَنْصُورِ بْنِ زَاذَانَ ، عَنِ الْحَکَمِ ، عَنْ زِیَادِ بْنِ مَالِکٍ ؛ أَنَّ عَلِیًّا ، وَابْنَ مَسْعُودٍ ، قَالاَ فِی الْقَارِنِ : یَطُوفُ طَوَافَیْنِ۔",,,14522,,
14523,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنْ عَمْرِو بْنِ الأَسْوَدِ ، عَنِ الْحَسَنِ بْنِ عَلِیٍّ ، قَالَ : إِذَا قَرَنْتَ بَیْنَ الْحَجِّ وَالْعُمْرَۃِ ، فَطُفْ طَوَافَیْنِ ، وَاسْعَ سَعْیَیْنِ۔",,,14523,,
14524,"حدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ (ح) وَعَنْ إِسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ ، قَالاَ : یَطُوفُ طَوَافَیْنِ ، وَیَسْعَی سَعْیَیْنِ۔",,,14524,,
14525,"حدَّثَنَا حَفْصٌ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، عَنْ مُطَرِّفٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : الْقَارِنُ یَطُوفُ طَوَافَیْنِ ، وَیَسْعَی سَعْیَیْنِ۔",,,14525,,
14526,"حدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ جَابِرٍ، عَنْ عَبْدِالرَّحْمَنِ بْنِ الأَسْوَدِ، عَنْ أَبِیہِ، قَالَ: الْقَارِنُ یَطُوفُ طَوَافَیْنِ۔",,,14526,,
14527,"حدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ ، وَحَمَّادًا عَنِ الْقَارِنِ ؟ فَقَالاَ : یَطُوفُ طَوَافَیْنِ ، وَیَسْعَی سَعْیَیْنِ۔",,,14527,,
14528,"حدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدِ بْنِ أَبِی عَرُوبَۃَ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إِبْرَاہِیمَ ؛ فِی الْقَارِنِ ، قَالَ : طَوَافَانِ ، وَسَعْیَانِ۔",,,14528,,
14529,حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ طَافَ لَہُمَا طَوَافًا وَاحِدًا۔,,,14529,,
14530,"حدَّثَنَا یَحْیَی بْنُ أَبِی سَعِیدٍ ، عَنْ سُفْیَانَ ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنْ طَاوُوسٍ ، قَالَ : حَلَفَ لِی أَنَّہُ لَمْ یَطُفْ أَحَدٌ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لِلْحَجِّ وَالْعُمْرَۃِ ، إِلاَّ طَوَافًا وَاحِدًا۔",,,14530,,
14531,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : إِذَا جَمَعَ بَیْنَ الْحَجِّ وَالْعُمْرَۃِ فَطَوَافٌ وَاحِدٌ ، وَسَعْیٌ وَاحِدٌ ، وَإِذَا قَرَنَ فَطَوَافَانِ وَسَعْیَانِ۔",,,14531,,
14532,"حدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ حُمَیْدٍ ، عَنْ بَکْرِ بْنِ عَبْدِ اللہِ الْمُزَنِیّ ، عَنْ سَالِمٍ ، قَالَ : إِذَا جَمَعَ بَیْنَ الْحَجِّ وَالْعُمْرَۃِ ، فَعَلَیْہِ طَوَافٌ وَاحِدٌ ، وَسَعْیٌ وَاحِدٌ۔",,,14532,,
14533,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَطَائٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : یُجْزِئہ طَوَافٌ۔",,,14533,,
14534,"حدَّثَنَا ابْنُ أَبِی غَنِیۃ ، عَنْ عُمَرَ بْنِ ذَرٍّ ، عَنْ مُجَاہِدٍ ، قَالَ : إِذَا قَدِمْتَ قَارِنًا ، أَوْ مُتَمَتِّعًا فَیَکْفِیکَ سَعْیٌ وَاحِدٌ بَیْنَ الصَّفَا وَالْمَرْوَۃِ ، فَإِنْ کُنْتَ سَاعِیًا ثَانِیًا ، فَأَخِّرْ ذَلِکَ إِلَی یَوْمِ النَّحْرِ۔",,,14534,,
14535,حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ طَافَ لَہُمَا طَوَافًا وَاحِدًا۔,,,14535,,
14536,"حدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ (ح) وَعَنْ ہِشَامٍ ، عَنِ الْحَسَنِ قَالاَ : یَطُوفُ طَوَافًا۔",,,14536,,
14537,"حدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ (ح) وَعَنْ ہِشَامٍ عَنِ الْحَسَنِ قَالاَ : یَطُوفُ طَوَافًا۔",,,14537,,
14538,"حدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ ، وَعَطَائٍ ، وَطَاوُوسٍ قَالُوا : یَطُوفُ الْقَارِنُ طَوَافًا۔",,,14538,,
14539,حدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ؛ أَنَّ عَلِیًّا کَانَ یَنْہَی النِّسَائَ عَنِ النِّقَابِ وَہُنَّ حُرُمٌ ، وَلَکِنْ یُسْدِلْنَ الثَّوْبَ عَلَی وُجُوہِہِنَّ سَدْلاً۔,,,14539,,
14540,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، قَالَ : تَرُدُّ الْمَرْأَۃُ الْمُحْرِمَۃُ الثَّوْبَ عَلَی وَجْہِہَا ، وَلاَ تَنْتَقِبُ۔",,,14540,,
14541,"حدَّثَنَا أَبُو خَالِدٍ ، عَنْ یَحْیَی ، وَعُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ قَالَ : لاَ تَنْتَقِبُ الْمُحْرِمَۃُ۔",,,14541,,
14542,حدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ أُمِّ شَبِیبٍ ، عَنْ عَائِشَۃَ ؛ أَنَّہَا کَرِہَتِ النِّقَابَ لِلْمُحْرِمَۃِ وَالْکُحْلَ ، وَرَخَّصَتْ فِی الْخُفَّیْنِ۔,,,14542,,
14543,حدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَکْرَہُ لِلْمُحْرِمَۃِ النِّقَابَ وَالْقُفَّازَیْنِ۔,,,14543,,
14544,"حدَّثَنَا الْعَقَدِیُّ ، عَنْ أَفْلَحَ ، عَنِ الْقَاسِمِ ، قَالَ : لاَ تَنْتَقِبُ۔",,,14544,,
14545,"حدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ ، وَحَمَّادًا عَنِ النِّقَابِ لِلْمُحْرِمَۃِ ؟ فَکَرِہَاہُ وَقَالاَ : تُخْرِجُ وَجْہَہَا لِلَّہِ۔",,,14545,,
14546,"حدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : سَمِعْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَنْہَی عَنْہُ ، یَعْنِی النِّقَابَ۔",,,14546,,
14547,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، قَالَ : وَقَفَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عِنْدَ الْجَمْرَۃِ الثَّانِیَۃِ ، أَطْوَلَ مِمَّا وَقَفَ عِنْدَ الْجَمْرَۃِ الأُولَی ، ثُمَّ أَتَی جَمْرَۃَ الْعَقَبَۃِ فَرَمَاہَا ، وَلَمْ یَقِفْ عِنْدَہَا۔",,,14547,,
14548,"حدَّثَنَا یَحْیَی بْنُ سُلَیْمٍ الطَّائِفِیُّ ، عَنْ عَبْدِ اللہِ بْنِ عُثْمَانَ ، عَنْ مُحَمَّدِ بْنِ الأَسْوَدِ بْنِ خَلَفٍ ، قَالَ : أَدْرَکْتُ النَّاسَ یَتَزَوَّدُونَ الْمَائَ إِذَا ذَہَبُوا یَرْمُونَ الْجِمَارَ ، مِنْ طُولِ الْقِیَامِ عِنْدَ الْجَمْرَتَیْنِ۔",,,14548,,
14549,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَبْدِ اللہِ بْنِ عُثْمَانَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنْ ابْنِ عَبَّاسٍ ؛ أَنَّہُ وَقَفَ مَعَ ابْنِ عَبَّاسٍ قَدْرَ سُورَۃٍ مِنَ السَّبْعِ ، قَالَ : قُلْتُ : مِنَ النَّاسِ مَنْ یُبَطِء الْقِرَائَۃَ وَمِنْہُمْ مَنْ یُسْرِعُ ؟ قَالَ : مِثْلَ قِرَائَتِی ؟ قَالَ : قُلْتُ : أَنْتَ خَفِیفُ الْقِرَائَۃِ ، قَالَ : مِثْلَ قِرَائَتِی۔",,,14549,,
14550,"حدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی عَلِیٌّ الأَزْدِیُّ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : بِمِثْلِ حَدِیثِ عَبْدِ اللہِ إِیَّایَ۔",,,14550,,
14551,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ حَجَّاجٍ ، قَالَ : وَقَفْت مَعَ عَمْرِو بْنِ شُعَیْبٍ ، وَعَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ فَلَمْ یُطِیلاَ ، وَوَقَفْتُ مَعَ عَطَائٍ قَدْرَ سُورَۃِ الْحَجِّ۔",,,14551,,
14552,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُحَمَّدِ بْنِ أَبِی إسْمَاعِیلَ ، قَالَ : رَأَیْتُ سَعِیدَ بْنَ جُبَیْرٍ ، وَإِبْرَاہِیمَ ، وَطَاوُوسًا ، وَعَامِرَ بْنَ عَبْدِ اللہِ بْنِ الزُّبَیْرِ یُطِیلُونَ الْقِیَامَ عِنْدَ الْجِمَارِ۔",,,14552,,
14553,"حدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : کَانَ ابْنُ عُمَرَ یَقُومُ عِنْدَ الْجَمْرَتَیْنِ مِقْدَارَ مَا یَقْرَأُ الرَّجُلُ سُورَۃَ الْبَقَرَۃِ۔",,,14553,,
14554,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : کَانَ ابْنُ عُمَرَ یَقِفُ عِنْدَ الْجَمْرَۃِ مِقْدَارَ مَا یَقْرَأُ الرَّجُلُ سُورَۃَ الْبَقَرَۃِ۔",,,14554,,
14555,حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ؛ أَنَّ عَطَائً وَقَفَ عِنْدَالْجَمْرَۃِ مِقْدَارَ مَا یَقْرَأُ الرَّجُلُ السُّورَۃَ مِنَ الْمِئِینَ۔,,,14555,,
14556,حدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، وَابْنِ عُمَرَ ؛ أَنَّہُمَا کَرِہَا أَنْ یُخْرَجَ مِنْ تُرَابِ الْحَرَمِ إلَی الْحِلِّ ، أَوْ یُدْخَلَ مِنْ تُرَابِ الْحِلِّ إلَی الْحَرَمِ۔,,,14556,,
14557,"حدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مُوسَی بْنُ أَبِی الْفُرَاتِ الْمَکِّیُّ ، عَنْ أَبِیہِ ؛ أَنْ ابْنَ الزُّبَیْرِ لَمَّا ہَدَمَ الْکَعْبَۃَ فَبَنَاہَا ، کَرِہَ أَنْ یَبْنِیَ فِیہَا مِنْ تُرَابِ الْحِلِّ۔",,,14557,,
14558,حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ مُحَمَّدِ بْنِ مُسلِمٍ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، وَعَطَائٍ ؛ أَنَّہُمَا کَرِہَاہُ ، یَعنی أَنْ یُخْرَجَ بِتُرَابِ الْحَرَمِ إلَی الْحِلِّ۔,,,14558,,
14559,"حدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُوسٍ ، وَمُجَاہِدٍ قَالُوا : لاَ تَطُفْ بِالْبَیْتِ إِلاَّ وَأَنْتَ عَلَی وُضُوئٍ۔",,,14559,,
14560,حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ لاَ یَقْضِی شَیْئًا مِنَ الْمَنَاسِکِ إِلاَّ وَہُوَ مُتَوَضِّیئٌ۔,,,14560,,
14561,حدَّثَنَا ابْنُ مُبَارَکٍ ، عَنِ الرَّبِیعِ ، عَنْ عَطَائٍ ، وَالْحَسَنِ ؛ أَنَّہُمَا کَرِہَا أَنْ یَطُوفَ الرَّجُلُ عَلَی غَیْرِ طَہَارَۃٍ۔,,,14561,,
14562,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الحَکَم ، وَحَمَّادًا ، وَمَنْصُورًا ، وَسُلَیْمَانَ عَنِ الرَّجُلِ یَطُوفُ بِالْبَیْتِ عَلَی غَیْرِ طَہَارَۃٍ ؟ فَلَمْ یَرَوْا بِہِ بَأْسًا۔",,,14562,,
14563,حدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَابْنِ سِیرِینَ ؛ أَنَّہُمَا لَمْ یَرَیَا بَأْسًا أَنْ یَطُوفَ الرَّجُلُ بَیْنَ الصَّفَا وَالْمَرْوَۃِ عَلَی غَیْرِ وُضُوئٍ ، وَکَانَ الْوُضُوئُ أَحَبَّ إلَیْہِمَا۔,,,14563,,
14564,"حدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ عَلِیٍّ ، قَالَ : إذَا أَحْرَمَ الرَّجُلُ وَعَلَیْہِ قَمِیصٌ فَلاَ یَنْزِعُہُ مِنْ رَأْسِہِ ، یَشُقُّہُ ، ثُمَّ یَخْرُجُ مِنْہُ۔",,,14564,,
14565,"حدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ (ح) وَیُونُسَ ، عَنِ الْحَسَنِ (ح) وَمُغِیرَۃَ وَحُصَیْنٍ ، عَنِ الشَّعْبِیِّ قَالُوا : یَخْرِقُہُ۔",,,14565,,
14566,"حدَّثَنَا شَرِیکٌ ، عَنْ سَالِمٍ ، عَنْ سَعِیدٍ (ح) وَعَنْ سَعِیدِ بْنِ مَسْرُوقٍ ، عَنْ أَبِی صَالِحٍ قَالَ : إذَا أَحْرَمَ وَعَلَیْہِ قَمِیصٌ فَلْیَشُقَّہُ۔",,,14566,,
14567,"حدَّثَنَا وَکِیعٌ ، عَنْ شَرِیکٍ ، عَنْ عَاصِمٍ ، عَنْ وَاصِلٍ ، عَنْ أَبِی قَتَادَۃَ ، قَالَ : یَشُقُّہُ",,,14567,,
14568,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَاصِمٍ ، عَنْ أَبِی قِلاَبَۃَ ، قَالَ : یَخْلَعُہُ مِنْ قِبَلِ رِجْلَیْہِ۔",,,14568,,
14569,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، أَنَّہُ کَانَ یَقُولُ : مَنْ أَحْرَمَ وَعَلَیْہِ قَمِیصٌ فَلْیَنْزِعْہُ ، وَلاَ یَشُقَّہُ۔",,,14569,,
14570,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ عَطَائٍ ، قَالَ : یَنْزِعُہُ۔",,,14570,,
14571,"حدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ ہَمَّامٍ ، عَنْ عَطَائٍ ، عَنْ صَفْوَانَ بْنِ یَعْلَی ، عَنْ أَبِیہِ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : اخْلَعْہَا ، وَاصْنَعْ فِی عُمْرَتِکَ مَا کُنْت صَانِعًا فِی حَجِّکَ ، یَعْنِی جُبَّۃٌ کَانَتْ عَلَیْہِ۔\n\n(بخاری 1789۔ مسلم 10)",,,14571,,
14572,"حدَّثَنَا عَبْدَۃُ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : یَنْزِعُہُ۔",,,14572,,
14573,"حدَّثَنَا أَبُو مُحَمَّدٍ عَبْدُ اللہِ بْنُ یُونُسَ ، قَالَ : حدَّثَنَا أَبُو عَبْدِ الرَّحْمَنِ بَقِیُّ بْنُ مَخْلَدٍ ، قَالَ : حدَّثَنَا عَبْدُ اللہِ بْنُ مُحَمَّدِ بْنِ أَبِی شَیْبَۃَ ، قَالَ :حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَمَرَہَا ، وَکَانَتْ حَائِضًا : أَنْ تَقْضِیَ الْمَنَاسِکَ کُلَّہَا غَیْرَ أَنَّہَا لاَ تَطُوفُ بِالْبَیْتِ۔",,,14573,,
14574,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : تَقْضِی الْحَائِضُ الْمَنَاسِکَ کُلَّہَا ، إِلاَّ الطَّوَافَ بِالْبَیْتِ۔\n\n(ترمذی 945۔ احمد 6/137)",,,14574,,
14575,"حدَّثَنَا ابْنُ الْمُبَارَکِ ، عَنْ یَحْیَی بْنِ بِشْرٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : تَقْضِی الْحَائِضُ الْمَنَاسِکَ کُلَّہَا ، إِلاَّ الطَّوَافَ بِالْبَیْتِ ، وتَسْعَی بَیْنَ الصَّفَا وَالْمَرْوَۃِ۔",,,14575,,
14576,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : تَقْضِی الْحَائِضُ الْمَنَاسِکَ کُلَّہَا ، إِلاَّ الطَّوَافَ بِالْبَیْتِ وَبَیْنَ الصَّفَا وَالْمَرْوَۃِ۔",,,14576,,
14577,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَاصِمٍ ، قَالَ : قُلْتُ لأَبِی الْعَالِیَۃِ : تَقْرَأُ الْحَائِضُ الْقُرْآنَ ؟ قَالَ : لاَ تَقْرَأُ الْقُرْآنَ ، وَلاَ تُصَلِّی ، وَلاَ تَطُوفُ بِالْبَیْتِ ، وَلاَ بَیْنَ الصَّفَا وَالْمَرْوَۃِ ، وَقَالَ : الطَّوَافُ بَیْنَ الصَّفَا وَالْمَرْوَۃِ عَدْلُ الطَّوَافِ بِالْبَیْتِ۔",,,14577,,
14578,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُغِیرَۃ ، عَنْ إبْرَاہِیمَ ، قَالَ : تَقْضِی الْحَائِضُ الْمَنَاسِکَ کُلَّہَا ، غَیْرَ الطَّوَافِ۔",,,14578,,
14579,"حدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ أَبِی الْمُنِیبِ ، عَنْ جَابِرِ بْنِ زَیْدٍ ، قَالَ : تَقْضِی الْمَنَاسِکَ کُلَّہَا ، إِلاَّ الطَّوَافَ بِالْبَیْتِ۔",,,14579,,
14580,"حدَّثَنَا وَکِیعٌ ، عَنْ حُسَیْنِ بْنِ عُقَیْلٍ ، عَنِ الضَّحَّاکِ ، قَالَ : سَمِعْتُہُ یَقُولُ : تَقِفُ بِعَرَفَۃَ وَتَقْضِی الْمَنَاسِکَ کُلَّہَا ، إِلاَّ الطَّوَافَ بِالْبَیْتِ۔",,,14580,,
14581,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ یَزِیدَ بْنِ ہَانِیئٍ ، عَنْ حُسَیْنِ بْنِ عَلِیٍّ ، قَالَ : تَقْضِی الْحَائِضُ الْمَنَاسِکَ کُلَّہَا ، إِلاَّ الطَّوَافَ بِالْبَیْتِ۔",,,14581,,
14582,"حدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ طَارِقٍ ، قَالَ : طَافَتِ امْرَأَتِی وَصَلَّتْ رَکْعَتَیْنِ ، ثُمَّ حَاضَتْ قَبْلَ أَنْ تَطُوفَ بَیْنَ الصَّفَا وَالْمَرْوَۃِ ، فَأَمَرْتُہَا أَنْ تَطُوفَ بَیْنَ الصَّفَا وَالْمَرْوَۃِ ، فَسَمِعَتْنِی امْرَأَۃٌ وَأَنَا آمُرُہَا بِذَلِکَ ، فَقَالَتْ : نِعْمَ مَا أَمَرَتْہَا بِہِ ، کَانَتْ عَمَّتِی وَخَالَتِی عَائِشَۃُ ، وَأُمُّ سَلَمَۃَ ، زَوْجَتَا النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ تَقُولاَنِ : إذَا طَافَتِ الْمَرْأَۃُ بِالْبَیْتِ ، ثُمَّ صَلَّتْ رَکْعَتَیْنِ ، ثُمَّ حَاضَتْ ، فَلْتَطُفْ بَیْنَ الصَّفَا وَالْمَرْوَۃِ۔",,,14582,,
14583,"حدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : إذَا طَافَتْ بِالْبَیْتِ، ثُمَّ حَاضَتْ قَبْلَ أَنْ تَسْعَی بَیْنَ الصَّفَا وَالْمَرْوَۃِ ، فَلْتَسْعَ بَیْنَ الصَّفَا وَالْمَرْوَۃِ۔",,,14583,,
14584,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ حَجَّاجٍ ، قَالَ : سَأَلْتُ عَطَائً عَنِ امْرَأَۃٍ طَافَتْ بِالْبَیْتِ ، ثُمَّ حَاضَتْ ؟ قَالَ : تَسْعَی بَیْنَ الصَّفَا وَالْمَرْوَۃِ۔",,,14584,,
14585,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَعَطَائٍ قَالاَ : تَسْعَی بَیْنَ الصَّفَا وَالْمَرْوَۃِ۔",,,14585,,
14586,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ (ح) وَعَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، وَحَمَّادٍ قَالُوا : تَسْعَی بَیْنَ الصَّفَا وَالْمَرْوَۃِ۔",,,14586,,
14587,حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ إذَا أَتَی الْبَیْتَ یَوْمَ النَّحْرِ طَافَ طَوَافًا وَاحِدًا ، ثُمَّ أَتَی مَنْزِلَہُ ، فَقَالَ ، ثُمَّ أَتَی مِنًی وَلَمْ یَعُدْ إلَی الْبَیْتِ۔,,,14587,,
14588,حدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ لَمْ یَزِدْ یَوْمَ الزِّیَارَۃِ عَلَی طَوَافٍ وَاحِدٍ۔,,,14588,,
14589,"حدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یَسْتَحِبُّونَ أَنْ یَطُوفُوا یَوْمَ النَّحْرِ ثَلاَثَۃَ أَسَابِیعَ۔",,,14589,,
14590,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الْکَرِیمِ ، قَالَ : طُفْتُ مَعَ سَعِیدِ بْنِ جُبَیْرٍ یَوْمَ النَّحْرِ طَوَافًا وَاحِدًا۔",,,14590,,
14591,"حدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، قَالَ : خَرَجْتُ مَعَ الْحَسَنِ ، فَلَمَّا کَانَ یَوْمُ النَّحْرِ زُرْنَا الْبَیْتَ، فَطُفْنَا بِالْبَیْتِ طَوَافًا وَاحِدًا ، وَسَعَیْنَا بَیْنَ الصَّفَا وَالْمَرْوَۃِ ، ثُمَّ رَجَعْنَا إلَی مِنًی۔",,,14591,,
14592,حدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حَجَّاجٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ؛ أَنَّہُ کَانَ یَطُوفُ طَوَافًا وَاحِدًا یَوْمَ الزِّیَارَۃِ۔,,,14592,,
14593,"حدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ أَفْلَحَ ، قَالَ : زُرْتُ مَعَ الْقَاسِمِ الْبَیْتَ فِی آخِرِ السَّحَرِ ، فَطُفْنَا طَوَافًا وَاحِدًا لَمَّا أَصْبَحْنَا ، ثُمَّ رَجَعْنَا إلَی مِنًی۔",,,14593,,
14594,حدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ جَابِرٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی الظُّہْرَ بِعَرَفَاتٍ ، ثُمَّ صَلَّی الْعَصْرَ ، یَعْنِی بِعَرَفَۃَ ، وَلَمْ یُسَبِّحْ بَیْنَہُمَا شَیْئًا۔,,,14594,,
14595,حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عَنْ عُمَرَ ؛ أَنَّہُ جَمَعَ بَیْنَ الظُّہْرِ وَالْعَصْرِ بِعَرَفَاتٍ ، ثُمَّ وَقَفَ۔,,,14595,,
14596,"حدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، عَنْ عَلْقَمَۃَ وَالأَسْوَدِ قَالاَ : قَالَ عَبْدُ اللہِ : لاَ یُجْمَعْ بَیْنَ الصَّلاَتَیْنِ إِلاَّ بِعَرَفَۃَ ، الظُّہْرُ وَالْعَصْرُ۔",,,14596,,
14597,"حدَّثَنَا ابْنُ نُمَیْرٍ ، وَیَزِیدُ بْنُ ہَارُونَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنِ الْقَاسِمِ ، عَنِ ابْنِ الزُّبَیْرِ ، قَالَ : مِنْ سُنَّۃِ الْحَجِّ إذَا فَرَغَ مِنْ خُطْبَتِہِ نَزَلَ فَصَلَّی الظُّہْرَ وَالْعَصْرَ جَمِیعًا ، ثُمَّ یَقِفُ بِعَرَفَۃَ۔",,,14597,,
14598,"حدَّثَنَا عَبْدُ الأَعْلَی بْنُ عَبْدِ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَمُحَمَّدٍ قَالاَ : مِنَ السُّنَّۃِ أَنْ تُجْمِعَ بَیْنَہُمَا بِعَرَفَۃَ۔",,,14598,,
14599,"حدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ خَالِدِ بْنِ أَبِی بَکْرٍ ، قَالَ : صَلَّیْتُ خَلْفَ سَالِمٍ ، وَعُبَیْدِ اللہِ بِعَرَفَۃَ ، فَجَمَعَا بَیْنَ الصَّلاَتَیْنِ ، وَلَمْ یَجْہَرَا بِالْقِرَائَۃِ۔",,,14599,,
14600,"حدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ حُسَیْنِ بْنِ عُقَیْلٍ ، عَنِ الضَّحَّاکِ ، قَالَ : یُجْمَعُ بَیْنَ الظُّہْرِ وَالْعَصْرِ بِعَرَفَۃَ۔",,,14600,,
14601,"حدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، عَنْ أَبِیہِ ، قَالَ : یُؤَخِّرُ الإِمَامُ الظُّہْرَ یَوْمَ عَرَفَۃَ ، أَشَدَّ مَا یُؤَخِّرُہَا یَوْمًا مِنَ السَّنَۃِ ، وَیُعَجِّلُ الْعَصْرَ أَشَدَّ مَا یُعَجِّلُہَا یَوْمًا مِنَ السَّنَۃِ۔",,,14601,,
14602,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّہُ قَالَ : لاَ یَبِیتَنَّ أَحَدٌ مِنْ وَرَائِ الْعَقَبَۃِ لَیْلاً بِمِنًی أَیَّامَ التَّشْرِیقِ",,,14602,,
14603,حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ عُمَرَ کَانَ یَنْہَی أَنْ یَبِیتَ أَحَدٌ مِنْ وَرَائِ الْعَقَبَۃِ ، وَکَانَ یَأْمُرُہُمْ أَنْ یَدْخُلُوا مِنًی۔,,,14603,,
14604,حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَرِہَ أَنْ یَنَامَ أَحَدٌ أَیَّامَ مِنًی بِمَکَّۃَ۔,,,14604,,
14605,"حدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : لاَ بَأْسَ أَنْ یَکُونَ أَوَّلُ اللَّیْلِ بِمَکَّۃَ وَآخِرُہُ بِمِنًی ، وَلاَ بَأْسَ أَنْ یَکُونَ أَوَّلُ اللَّیْلِ بِمِنًی وَآخِرُہُ بِمَکَّۃَ۔",,,14605,,
14606,"حدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنِ حَسَنِ بْنِ عَبْدِ اللہِ الْمُزَنِیِّ ، قَالَ : سَمِعْتُ مُحَمَّدَ بْنَ کَعْبٍ یَقُولُ : مِنَ السُّنَّۃِ إذَا زُرْت الْبَیْتَ أَلاَّ تَبِیتَ إِلاَّ بِمِنًی۔",,,14606,,
14607,"حدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ یُوسُفَ بْنِ عَبْدِ اللہِ بْنِ الْحَارِثِ ، عَنْ أَبِی قِلاَبَۃَ ، قَالَ : اجْعَلُوا أَیَّامَ مِنًی بِمِنًی۔",,,14607,,
14608,"حدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ؛ أَنَّہُ قَالَ : لاَ یَبِیتَنَّ أَحَدٌ مِنْ وَرَائِ الْعَقَبَۃِ أَیَّامَ التَّشْرِیقِ۔",,,14608,,
14609,"حدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا بَاتَ دُونَ الْعَقَبَۃِ أَہْرَاقَ لِذَلِکَ دَمًا۔",,,14609,,
14610,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : سُئِلَ عَنِ الرَّجُلِ یَبِیتُ لَیَالِیَ مِنًی بِمَکَّۃَ ؟ قَالَ : یَتَصَدَّقُ بِدِرْہَمٍ ، أَوْ نَحْوِہِ۔",,,14610,,
14611,"حدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، قَالَ : أَخْبَرَنِی إبْرَاہِیمُ بْنُ نَافِعٍ ، قَالَ : أَخْبَرَنَا عَبْدُ اللہِ بْنُ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ؛ أَنَّہُ کَرِہَ أَنْ یَبِیتَ لَیْلَۃً تَامَّۃً عَنْ مِنًی۔",,,14611,,
14612,"حدَّثَنَا أَبُوبَکْرٍ الْحَنَفِیُّ، عَنْ بُکَیْرِ بْنِ مِسْمَارٍ، عَنْ سَالِمٍ، قَالَ: یَتَصَدَّقُ بِدِرْہَمٍ، یَعْنِی إذَا بَاتَ عَنْ مِنًی۔",,,14612,,
14613,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عمَرَ ؛ أَنَّ الْعَبَّاسَ بْنَ عَبْدِ الْمُطَّلِبِ اسْتَأْذَنَ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یَبِیتَ بِمَکَّۃَ لَیَالِیَ مِنًی ، فَأَذِنَ لَہُ مِنْ أَجْلِ سِقَایَتِہِ۔\n\n(بخاری 1745۔ ابوداؤد 1954)",,,14613,,
14614,"حدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، قَالَ : أَخْبَرَنَا إبْرَاہِیمُ بْنُ نَافِعٍ ، قَالَ : أَخْبَرَنَا عَمْرُو بْنُ دِینَارٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إذَا رَمَیْتَ الْجِمَارَ فَبِتْ حَیْثُ شِئْت۔",,,14614,,
14615,"حدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، قَالَ : أَخْبَرَنَا إبْرَاہِیمُ بْنُ نَافِعٍ ، قَالَ : حدَّثَنَا ابْنُ أَبِی نَجِیحٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ بَأْسَ أَنْ یَبِیتَ الرَّجُلُ بِمَکَّۃَ لَیَالِیَ مِنًی ، إِذَا کَانَ فِی ضَیْعَتِہِ۔",,,14615,,
14616,حدَّثَنَا وَکِیعٌ ، عَنْ مَالِکِ بْنِ أَنَسٍ ، عَنِ الزُّہْرِیِّ ، عَنِ أَنَسٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ دَخَلَ مَکَّۃَ وَعَلَیْہِ مِغْفَرٌ۔ (بخاری 1846۔ ابوداؤد 2678),,,14616,,
14617,"حدَّثَنَا ہُشَیْمُ بْنُ بَشِیرٍ ، عَنْ شَبِیبِ بْنِ حَوْشَبٍ ، عَنِ الْقَاسِمِ ، قَالَ : کَانَ أَصْحَابُ مُحَمَّدٍ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إِذَا أَحْرَمُوا حَمَلُوا مَعَہُمُ السُّیُوفَ فِی الْقُرُبِ۔",,,14617,,
14618,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : لَمْ یَکُونُوا یَکْرَہُونَ أَنْ یُسَافِرُوا بِالسُّیُوفِ فِی قُرُبِہَا ، وَہُمْ مُحْرِمُونَ۔",,,14618,,
14619,حدَّثَنَا شَرِیکٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ؛ أَنَّ أَبَاہُ کَانَ یَدْخُلُ الْحَرَمَ بِسَیْفٍ۔,,,14619,,
14620,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ بَأْسَ أَنْ یَتَقَلَّدَ الْمُحْرِمُ سَیْفَہُ إذَا خَافَ۔",,,14620,,
14621,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ یَدْخُلُ أَحَدٌ مَکَّۃَ بِسِلاَحٍ فِی حَجٍّ ، وَلاَ عُمْرَۃٍ۔",,,14621,,
14622,"حدَّثَنَا ابْنُ أَبِی زَائِدَۃَ ، عَنْ یَزِیدَ بْنِ إبْرَاہِیمَ ، قَالَ : أَحْسَبُ أَنِّی سَمِعْتُ قَیْسَ بْنَ سَعْدٍ یَقُولُ : قَالَ ابْنُ عُمَرَ : الْمُحْرِمُ لاَ یَحْمِلُ السِّلاَحُ۔",,,14622,,
14623,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، وَعَطَائٍ قَالاَ : لاَ یَدْخُلُ الْمُحْرِمُ بِسِلاَحٍ۔",,,14623,,
14624,"حدَّثَنَا وَکِیعٌ ، عَنْ فُضَیْلِ بْنِ مَرْزُوقٍ ، عَنْ عَطِیَّۃَ ، قَالَ : سَأَلْتُ مَوْلًی لابْنِ عُمَرَ عَنْ مَوْتِ ابْنِ عُمَرَ ؟ قَالَ : أَصَابَہُ رَجُلٌ مِنْ أَہْلِ الشَّامِ بِزُجٍّ ، فَدَخَلَ عَلَیْہِ الْحَجَّاجُ یَعُودُہُ ، فَقَالَ : لَوْ أَعْلَمُ مَنْ أَصَابَکَ لَفَعَلْتُ وَفَعَلْتُ ، قَالَ : أَنْتَ أَصَبْتنِی ، أَدْخَلْتَ السِّلاَحَ الْحَرَمَ۔",,,14624,,
14625,حدَّثَنَا أَبُو خَالِدٍ ، وَلَیْسَ بِالأَحْمَرِ ، عَنْ یُونُسَ بْنِ أَبِی إِسْحَاقَ ، عَنْ أَبِی السَّفَرِ ؛ أَنَّہُ دَخَلَ الْحَرَمَ وَعَلَیْہِ سَیْفٌ مُتَقَلِّدُہُ ، فَلَمَّا دَخَلَ نَزَعَہُ۔,,,14625,,
14626,"حدَّثَنَا وَکِیعٌ ، عَنِ الصَّلْتِ ، عَنْ عُقْبَۃَ بْنِ صَہْبَانَ ، قَالَ : رَأَیْتُ عُثْمَانَ بِالأَبْطَحِ ، وَإِنَّ فُسْطَاطَہُ مَضْرُوبٌ ، وَإِنَّ سَیْفَہُ مُعَلَّقٌ بِالْفُسْطَاطِ۔",,,14626,,
14627,"حدَّثَنَا وَکِیعٌ ، عَنْ عُیَیْنَۃَ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِیہِ ، قَالَ : کُنْتُ عِنْدَ ابْنِ عَبَّاسٍ فَأَتَاہُ رَجُلٌ ، فَقَالَ : إنِّی أَہْدَیْتُ بَدَنَۃً ، وَإِنِّی أَضْلَلْتہَا بِالطَّرِیقِ ، فَہَلْ تُجْزِئُ عَنِّی ؟ قَالَ : إِنْ کَانَتْ فِی نَذْرٍ ، أَوْ فِی کَفَّارَۃٍ فَوَافِ بِہَا الْبَیْتَ ، فَلاَ إِخَالُکَ وَافَیْتَ بِہَا ، وَإِنْ کَانَتْ تَطَوُّعًا أَجْزَأَتْ عَنْکَ ، قَالَ : قُلْتُ : فِیہِ وَلَوْ شَاۃً ؟ قَالَ : نَعَمْ۔",,,14627,,
14628,حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ؛ أَنَّ عُمَرَ قَضَی فِی الأَرْنَبِ جَفرَۃً۔,,,14628,,
14629,"حدَّثَنَا یَحْیَی بْنُ أَبِی زَائِدَۃَ ، عَنْ زَکَرِیَّا ، عَنِ الشَّعْبِیِّ ، قَالَ : فِی الأَرْنَبِ کَفٌّ مِنْ طَعَامٍ فَمَا دُونَہُ۔",,,14629,,
14630,"حدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ أَشْعَثَ ، عَنْ عَطَائٍ ، قَالَ : فِی الأَرْنَبِ شَاۃٌ۔",,,14630,,
14631,"حدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، قَالَ : حدَّثَنَا حُسَیْنُ بْنُ عَقِیلٍ ، عَنِ الضَّحَّاکِ ، قَالَ : فِی الأَرْنَبِ مَا دُونَ الْمُسِنَّۃِ۔",,,14631,,
14632,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ أَنَّ عُمَرَ ، وَعُثْمَانَ ، وَزَیْدَ بْنَ ثَابِتٍ ، وَابْنَ عَبَّاسٍ ، وَمُعَاوِیَۃَ ، قَالُوا : فِی النَّعَامَۃِ بَدَنَۃٌ۔",,,14632,,
14633,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاووُسٍ ، وَمُجَاہِدٍ ، قَالُوا : فِی النَّعَامَۃِ بَدَنَۃٌ۔",,,14633,,
14634,"حدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : فِی النَّعَامَۃِ بَدَنَۃٌ۔",,,14634,,
14635,"حدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، قَالَ : فِی النَّعَامَۃِ جَزُورٌ۔",,,14635,,
14636,"حدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : فِی النَّعَامَۃِ بَدَنَۃٌ۔",,,14636,,
14637,"حدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : فِی الْبَقَرَۃِ بَقَرَۃٌ۔",,,14637,,
14638,"حدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، قَالَ : إذَا أَصَابَ الْمُحْرِمُ بَقَرَۃَ الْوَحْشِ ، فَفِیہَا جَزُورٌ۔",,,14638,,
14639,"حدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطَائٍ ، قَالَ : فِی الْبَقَرَۃِ بَقَرَۃٌ۔",,,14639,,
14640,"حدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : فِی الْحِمَارِ بَدَنَۃٌ۔",,,14640,,
14641,"حدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطَائٍ ، وَطَاوُوسٍ ، وَمُجَاہِدٍ ، قَالُوا : فِی الْحِمَارِ بَقَرَۃٌ۔",,,14641,,
14642,"حدَّثَنَا ہُشَیْمُ بْنُ بَشِیرٍ ، عَنْ أَبِی بِشْرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ رَجُلاً کَانَ مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ مُحْرِمٌ ، فَوَقَصَتْہُ نَاقَتُہُ فَمَاتَ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : اِغْسِلُوہُ بِمَائٍ وَسِدْرٍ ، وَکَفِّنُوہُ فِی ثَوْبَیْہِ ، وَلاَ تُخَمِّرُوا رَأْسَہُ ، وَلاَ تُمِسُّوْہُ بِطِیبٍ ، فَإِنَّ اللَّہَ یَبْعَثُہُ یَوْمَ الْقِیَامَۃِ مُلَبِّدًا۔ (بخاری 1851۔ مسلم 99)",,,14642,,
14643,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لاَ تُخَمِّرُوا رَأْسَہُ ، فَإِنَّ اللَّہَ یَبْعَثُہُ یَوْمَ الْقِیَامَۃِ مُلَبِّیًا۔ (مسلم 98۔ ابوداؤد 3233)",,,14643,,
14644,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، أَنَّہُ سُئِلَ عَنِ الْمُحْرِمِ یُغَطَّی رَأْسُہُ إِذَا مَاتَ ، وَإِذَا کُفِّنَ ؟ قَالَ : قدْ غَطَّی ابْنُ عُمَرَ ، وَکَشَفَ غَیْرُہُ۔",,,14644,,
14645,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ، عَنِ ابْنِ جُرَیْجٍ، عَنِ ابْنِ طَاوُوس، عَنْ أَبِیہِ، قَالَ: یُغَیَّبُ رَأْسُ الْمُحْرِمِ إِذَا مَاتَ۔",,,14645,,
14646,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : إذَا مَاتَ الْمُحْرِمُ فَہُوَ حَلال۔",,,14646,,
14647,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُجَالِدٍ ، عَنِ عامر قَالَ : إذَا مَاتَ الْمُحْرِمُ فَقَدْ ذَہَبَ إِحْرَامُہُ۔",,,14647,,
14648,"حدَّثَنَا وَکِیعٌ ، عَنْ عُقْبَۃَ بْنِ أَبِی صَالِحٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَائِشَۃَ ، قَالَتْ : إِذَا مَاتَ الْمُحْرِمُ ذَہَبَ إِحْرَامُ صَاحِبِکُمْ۔",,,14648,,
14649,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عنْ عَائِشَۃَ ؛ أَنَّہَا سُئِلَتْ عَنِ الْمُحْرِمِ یَمُوتُ ؟ فَقَالَتْ : اصْنَعُوا بِہِ کَمَا تَصْنَعُونَ بِمَوْتَاکُمْ۔",,,14649,,
14650,"حدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَسَارٍ ، قَالَ : سَمِعْتُ عِکْرِمَۃَ ، وَسُئِلَ عَنِ الرَّجُلِ یَمُوتُ وَہُوَ مُحْرِمٌ ؟ قَالَ : قَدْ ذَہَبَ إِحْرَامُہُ ، یُکَفَّنُ کَمَا یُکَفَّنُ الْحَلاَلُ۔",,,14650,,
14651,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : خَمِّرُوا وُجُوہَکُمْ ، وَلاَ تَشَبَّہُوا بِالْیَہُودِ۔ (طبرانی 11۔ بیہقی 393)",,,14651,,
14652,"حدَّثَنَا عُبَیْدُ اللہِ، عَنْ إسْرَائِیلَ، عَنْ جَابِرٍ، عَنْ أَبِی جَعْفَرٍ، قَالَ فِی الْمُحْرِمِ: یُغَطَّی رَأْسُہُ، وَلاَ یُکْشَفُ۔",,,14652,,
14653,"حدَّثَنَا وَکِیعٌ ، عَنْ مَالِکِ بْنِ مِغْوَلٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ تُقَرِّبُوہُ طِیبًا۔",,,14653,,
14654,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، وَعَطَائٍ ؛ أَنَّ عَائِشَۃَ اشْتَرَتْ بَدَنَۃً فَأَضَلَّتْہَا ، فَاشْتَرَتْ مَکَانََہَا ، ثُمَّ وَجَدَتْہَا ، فَنَحَرَتْہُمَا جَمِیعًا ، ثُمَّ قَالَتْ : کَانَ فِی عِلْمِ اللہِ أَنْ أَنْحَرُہُمَا جَمِیعًا ۔ وَذَلِکَ فِی التَّطَوُّعِ۔",,,14654,,
14655,حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ؛ أَنَّ عَائِشَۃَ نَحَرَتْہُمَا جَمِیعًا۔,,,14655,,
14656,"حدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، عَنْ مَاعِزِ بْنِ مَالِکٍ ، أَوْ مَالِکِ بْنِ مَاعِزٍ الثَّقَفِیِّ ، قَالَ : سَاقَ أَبِی ہَدْیَیْنِ عَنْ نَفْسِہِ وَامْرَأَتِہِ وَابْنَتِہِ ، فَأَضَلَّہُمَا بِذِی الْمَجَازِ ، فَلَمَّا کَانَ یَوْمُ النَّحْرِ ذَکَرَ ذَلِکَ لِعُمَرَ ، فَقَالَ: تَرَبَّصَ الْیَوْمَ وَغَدًا وَبَعْدَ غَدٍ ، فَإِنَّمَا النَّحْرُ فِی ہَذِہِ الثَّلاَثَۃِ الأَیَّامِ ، فَإِنْ وَجَدْتَ ہَدْیَیْکَ فَانْحَرْہُمَا جَمِیعًا، فَإِنْ لَمْ تَجِدْہُمَا فَاشْتَرِ ہَدْیَیْنِ فِی الْیَوْمِ الثَّالِثِ ، فَانْحَرْہُمَا وَلاَ تُحِلَّ مِنْک حَرَامًا حَتَّی تَنْحَرَہُمَا ، أَوْ ہَدْیَیْنِ آخَرَیْنِ ، فَإِنْ نَحَرْتَ الْہَدْیَیْنِ اللَّذَیْنِ اشْتَرَیْتَ وَوَجَدْتَ الْہَدْیَیْنِ الضَّالَّیْنِ بَعْدُ فَانْحَرْہُمَا۔",,,14656,,
14657,"حدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ عَقِیلِ بْنِ طَلْحَۃَ ، عَنْ أَبِی الْخُصَیْبِ الْقَیْسِیِّ ؛ أَنَّہُ أَہْدَی عَنْ أُمِّہِ بَدَنَۃً فَأَضَلَّہَا ، فَاشْتَرَی مَکَانَہَا أُخْرَی ، فَقَلَّدَہَا ، ثُمَّ وَجَدَ الأُولَی ، فَسَأَلَ ابْنَ عُمَرَ ؟ فَقَالَ : انْحَرْہُمَا جَمِیعًا۔",,,14657,,
14658,"حدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ أَبِی طَالِبٍ الْحَجَّامِ ، وَکَانَ ثِقَۃً ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : یَنْحَرُہُمَا جَمِیعًا۔",,,14658,,
14659,حدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ؛ أَنَّہَا أَہْدَتْ بَدَنَتَیْنِ فَأَضَلَّتْہُمَا ، فَأَہْدَی لَہَا ابْنُ الزُّبَیْرِ بَدَنَتَیْنِ فَنَحَرَتْہُمَا ، ثُمَّ وَجَدَتِ الْبَدَنَتَیْنِ فَنَحَرَتْہُمَا۔,,,14659,,
14660,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ عَلِیِّ بْنِ نَافِعٍ ، قَالَ : سُقْتُ بَدَنَۃً فَأَضْلَلْتُہَا ، فَاشْتَرَیْتُ أُخْرَی فَنَحَرْتُہَا ، ثُمَّ وَجَدْتُ الأُولَی ، فَسَأَلْتُ عُرْوَۃَ بْنَ الزُّبَیْرِ ؟ فَقَالَ : انْحَرْہُمَا ، وَسَأَلْتُ عِکْرِمَۃَ ؟ فَقَالَ : نَاقَۃً مِنْ إِبِلِک۔",,,14660,,
14661,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، قَالَ : انْحَرِ الأُولَی۔",,,14661,,
14662,"حدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی بَکْرِ بْنِ أَبِی الْجَہْمِ ، قَالَ : سَأَلْتُ عَنْہُ قَبِیصَۃَ بْنَ ذُؤَیْبٍ ؟ فَقَالَ : انْحَرْہُمَا جَمِیعًا۔",,,14662,,
14663,"حدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ زَیْدٍ ، عَنْ کَثِیرِ بْنِ شِنْظِیرٍ ، عَنْ عَطَائٍ ، قَالَ : إِذَا کَانَتِ الأُولَی تَطَوُّعًا نَحَرَہُمَا جَمِیعًا ، وَإِذَا کَانَتْ وَاجِبَۃً صَنَعَ بِالأُخْرَی مَا شَائَ۔",,,14663,,
14664,"حدَّثَنَا أَبُو أُسَامَۃَ، عَنِ ہشام ، عَنِ الْحَسَنِ ، وَعَطَائٍ ؛ أَنَّہُمَا قَالاَ فِی رَجُلٍ أَضَلَّ بَدَنَتَہُ تَطَوُّعًا، فَاشْتَرَی أُخْرَی ، قَالاَ : إِنْ کَانَ قَلَّدَ الَّذِی اشْتَرَی نَحَرَہُمَا ، وَإِنْ کَانَ لَمْ یُقَلِّدْہَا بَاعَہَا إِنْ شَائَ۔",,,14664,,
14665,"حدَّثَنَا أَبُو الأَحْوَصِ سَلاَّ مُ بْنُ سُلَیْمٍ ، عَنْ لَیْثٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ سَابِطٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ مَاتَ وَلَمْ یَحُجَّ حَجَّۃَ الإِسْلاَمِ ، لَمْ یَمْنَعْہُ مَرَضٌ حَابِسٌ ، أَوْ حَاجَۃٌ ظَاہِرَۃٌ ، أَوْ سُلْطَانٌ جَائِرٌ ، فَلْیَمُتْ عَلَی أَیِّ حَالٍ شَائَ ، یَہُودِیًّا ، أَوْ نَصْرَانِیًّا۔ (دارمی 1785۔ بیہقی 334",,,14665,,
14666,"حدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : قَالَ الأَسْوَدُ لِرَجُلٍ مِنْہُمْ مُوسِرٍ : لَوْ مِتَّ وَلَمْ تَحُجَّ ، لَمْ أُصَلِّ عَلَیْکَ",,,14666,,
14667,"حدَّثَنَا وَکِیعُ بْنُ الْجَرَّاحِ، عَنْ سُفْیَانَ، عَنِ مُجَاہِدِ بْنِ رُومِیٍّ، وَکَانَ ثِقَۃً، قَالَ: سَأَلَتُ سَعِیدَ بْنَ جُبَیْرٍ، وَعَبْدَ الرَّحْمَن بْنِ أَبِی لَیْلَی ، وَعَبْدَ اللہِ بْنَ مَعْقِلٍ عَنْ رَجُلٍ مَاتَ وَلَمْ یَحُجَّ ، وَہُوَ مُوسِرٌ ؟ فَقَالَ سَعِیدٌ: النَّارَ ، النَّارَ ، وَقَالَ ابْنُ مَعْقِلٍ : مَاتَ وَہُوَ لِلَّہِ عَاصٍ ، وَقَالَ ابْنُ أَبِی لَیْلَی : إِنِّی لأَرْجُو إِنْ حَجَّ عَنْہُ وَلِیُّہُ",,,14667,,
14668,"حدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی الْمُعَلَّی ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : لَوْ کَانَ لِی جَارٌ مُوسِرٌ ، ثُمَّ مَاتَ وَلَمْ یَحُجَّ ، لَمْ أُصَلِّ عَلَیْہِ۔",,,14668,,
14669,"حدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ ثُوَیْرٍ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : مَنْ مَاتَ وَہُوَ مُوسِرٌ لَمْ یَحُجَّ ، جَائَ یَوْمَ الْقِیَامَۃِ وَبَیْنَ عَیْنَیْہِ مَکْتُوبٌ : کَافِرٌ۔",,,14669,,
14670,"حدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ عَدِیِّ بْنِ عَدِیٍّ ، عَنْ أَبِیہِ ، قَالَ : قَالَ عُمَرُ بْنُ الْخَطَّابِ : مَنْ مَاتَ وَہُوَ مُوسِرٌ لَمْ یَحُجَّ ، فَلْیَمُتْ عَلَی أَیِّ حَالٍ شَائَ ، یَہُودِیًّا ، أَوْ نَصْرَانِیًّا۔",,,14670,,
14671,حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ عَدِیِّ بْنِ عَدِیٍّ ، عَنِ الضَّحَّاکِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ عَرْزَمٍ ، عَنْ عُمَرَ ؛ بِمِثْلِہِ,,,14671,,
14672,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَمْرو بْنِ دِینَارٍ قَالَ : رَأَیْتُ ابْنَ الزُّبَیْرِ یُسْرِعُ فِی الطَّوَافِ",,,14672,,
14673,"حدَّثَنَا زَیْدُ بْنُ الْحُبَابِ، عَنْ إِسْمَاعِیلَ بْنِ عَبْدِالْمَلِکِ، قَالَ: رَأَیْتُ عُمَرَ بْنَ عَبْدِالْعَزِیزِ یُہَرْوِلُ فِی الطَّوَافِ۔",,,14673,,
14674,"حدَّثَنَا وَکِیعٌ ، عَنْ إِسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، قَالَ : رَأَیْتُ عَمْرَو بْنَ مَیْمُونٍ یَطُوفُ بِالْبَیْتِ یُسْرِعُ حَتَّی یَکَادَ یَسْعَی ، أَوْ یَشْتَدُّ۔",,,14674,,
14675,"حدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : طُفْتُ مَعَہُ بِالْبَیْتِ ، فَکَانَ یَمْشِی عَلَی ہِیْنَتِہِ قَلِیلاً قَلِیلاً ، وَلاَ یُزَاحِمُ عَلَی الْحَجَرِ۔",,,14675,,
14676,"حدَّثَنَا وَکِیعٌ ، عَنْ فِطْرٍ ، قَالَ : قَالَ لَنَا سَعِیدُ بْنُ جُبَیْرٍ وَنَحْنُ نَطُوفُ بِالْبَیْتِ : یَا مَعْشَرَ الشَّبَابِ اُرْمُلُوا، إسْرَعُوا۔",,,14676,,
14677,"حدَّثَنَا عُبَیْدُ اللہِ ، عَنْ حَنْظَلَۃَ ، عَنْ طَاوُوسٍ ، قَالَ : جَلَسْنَا لابْنِ عُمَرَ نَنْظُرُ کَیْفَ یَطُوفُ ، فَرَأَیْنَاہُ قَائِلاً ہَکَذَا ، قَدْ قَبَضَ عَلَی أَصَابِعِہِ وَہُوَ یَشْتَدُّ۔",,,14677,,
14678,"حدَّثَنَا جَرِیرٌ ، وَأَبُو الأَحْوَص ، عَنْ عَبْدِ الْعَزِیزِ بْنِ رُفَیْعٍ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی قَتَادَۃَ ، قَالَ : کَانَ أَبُو قَتَادَۃَ فِی نَفَرٍ مُحْرِمِینَ ، وَأَبُو قَتَادَۃَ مُحِلٌّ ، فَرَأَی أَصْحَابُہُ حِمَارًا وَحْشِیًّا ، فَلَمْ یُؤْذِنوہُ حَتَّی أَبْصَرَہُ ، فَاخْتَلَسَ مِنْ بَعْضِہِمْ سَوْطًا فَصَرَعَہُ ، فَأَکَلُوا وَحَمَلُوا مِنْہُ ، فَلَقُوا رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَسَأَلُوہُ عَنْہ ؟ فَقَالَ : ہَلْ أَشَارَ إلَیْہِ أَحَدٌ مِنْکُمْ ؟ قَالُوا : لاَ ، قَالَ : فَکُلُوا۔ (بخاری 1821۔ مسلم 63)",,,14678,,
14679,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ الْقَطَّانُ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ مُحَمَّدِ بْنِ الْمُنْکَدِرِ ، عَنْ مُعَاذِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِیہِ ، قَالَ : کُنَّا مَعَ طَلْحَۃَ بْنِ عُبَیْدِ اللہِ فِی الْحَجِّ وَنَحْنُ مُحْرِمُونَ ، قَالَ : فَأُہْدِیَ لَنَا طَائِرٌ ، وَطَلْحَۃُ نَائِمٌ ، قَالَ : فَمِنَّا مَنْ أَکَلَ ، وَمِنَّا مَنْ تَوَرَّعَ فَلَمْ یَأْکُلْہُ ، فَلَمَّا اسْتَیْقَظَ طَلْحَۃُ ذَکَرُوا ذَلِکَ لَہُ ، قَالَ : فَوَفَقَ مَنْ أَکَلَہُ ، وَقَالَ : أَکَلْنَاہ مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔ (مسلم 65۔ احمد 1/162)",,,14679,,
14680,حدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّ عُمَرَ بْنَ الْخَطَّابِ کَانَ لاَ یَرَی بَأْسًا بِلَحْمِ الطَّیْرِ إِذَا صِیدَ لِغَیْرِہِ ، یَعْنِی فِی الإِحْرَامِ۔,,,14680,,
14681,"حدَّثَنَا وَکِیعٌ ، عَنْ أُسَامَۃَ بْنِ زَیْدٍ ، عَنْ سَالِمٍ ، قَالَ : سَمِعْتُ أَبَا ہُرَیْرَۃَ ، یَقُولُ : لَمَّا قَدِمْتُ مِنَ الْبَحْرَیْنِ لَقِیَنِی قَوْمٌ مِنْ أَہْلِ الْعِرَاقِ ، فَسَأَلُونِی عَنِ الْحَلاَلِ یَصِیدُ الصَّیْدَ فَیَأْکُلُہُ الْحَرَامُ ؟ فَأَفْتَیْتُہمْ بِأَکْلِہِ ، فَقَدِمْتُ عَلَی عُمَرَ فَسَأَلْتُہُ عَنْ ذَلِکَ ؟ فَقَالَ : لَوْ أَفْتَیْتَہُمْ بِغَیْرِہِ مَا أَفْتَیْتَ أَحَدًا أَبَدًا۔",,,14681,,
14682,حدَّثَنَا وَکِیعٌ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ، عَنْ أَبِیہِ؛ أَنَّ الزُّبَیْرَ بْنَ الْعَوَّامِ کَانَ یَتَزَوَّدُ صَفِیفَ الْوَحْشِ وَہُوَ مُحْرِمٌ۔,,,14682,,
14683,حدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ (ح) وَعَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ أَنَّہُمَا لَمْ یَکُونَا یَرَیَانِ بَأْسًا بِأَکْلِ الْمُحْرِمِ مَا صَادَ الْحَلاَلُ ، إِذَا کَانَ لَمْ یَصِدْہُ مِنْ أَجْلِہِ ، أَوْ بِآلَتِہِ۔,,,14683,,
14684,"حدَّثَنَا وَکِیعٌ ، عَنْ یُونُسَ بْنِ أَبِی إِسْحَاقَ ، عَنْ أَبِیہِ ، عَنْ سَعْدِ بْنِ عِیَاضٍ ، قَالَ : سُئِلَ ابْنُ مَسْعُودٍ عَنْ قَوْمٍ مُحْرِمِینَ ، لَقُوا قَوْمًا حَلاَلاً مَعَہُمْ لَحْمُ صَیْدٍ ، فَإِمَّا بَاعُوہُمْ ، وَإِمَّا أَطْعَمُوہُمْ ؟ فَقَالَ : لاَ بَأْسَ۔",,,14684,,
14685,"حدَّثَنَا وَکِیعٌ، عَنْ قُرَّۃَ بن خالد، عَنْ یَزِیدَ بْنِ عَبْدِ اللہِ بْنِ الشِّخِّیرِ، قَالَ: قَالَ رَجُلٌ: اشْتَرَیْنَا رِجْلَ حِمَارٍ وَنَحْنُ مُحْرِمُونَ مِنْ قَوْمٍ حَلاَلٍ ، قَالَ : فَمَرَرْنَا بِأَبِی ذَرٍّ ، فَسَأَلْنَاہُ ؟ فَقَالَ : لاَ أَرَاکُمْ فَجَرتُمْ ، لاَ بَأْسَ بِہِ۔",,,14685,,
14686,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عُبَیْدِ اللہِ ، عَنِ ابْنِ عَبَّاسٍ ، عَنِ الصَّعْبِ بْنِ جَثَّامَۃَ ، قَالَ : أَہْدَیْتُ إِلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِالأَبْوَائِ ، أَوْ بِوَدَّانَ حِمَارَ وَحْشٍ وَہُوَ مُحْرِمٌ ، قَالَ : فَرَدَّہُ : وَقَالَ : إِنَّہُ لَیْسَ بِنَا رَدّ عَلَیْکَ ، وَلَکِنَّا حُرُمٌ۔ (بخاری 1825۔ مسلم 50)",,,14686,,
14687,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ حَبِیبٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : أَہْدَی الصَّعْبُ بْنُ جَثَّامَۃَ إِلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حِمَارَ وَحْشٍ وَہُوَ مُحْرِمٌ ، فَرَدَّہُ عَلَیْہِ ، وَقَالَ : لَوْلاَ أَنَّا مُحْرِمُونَ لَقَبِلْنَاہُ مِنْک۔ (مسلم 54۔ احمد 1/280)",,,14687,,
14688,حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَرِہَ طَرِیَّ الصَّیْدِ وَقَدِیدَہُ لِلْمُحْرِمِ۔,,,14688,,
14689,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : أَہْدَی الصَّعْبُ بْنُ جَثَّامَۃَ إِلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حِمَارَ وَحْشٍ ، فَقَالَ : رُدَّوہُ إِلَیْہِ ، إِنَّا مُحْرِمُونَ۔",,,14689,,
14690,حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ الْحَسَنِ بْنِ مُسْلِمٍ ، عَنْ طَاوُوسٍ ؛ أَنَّہُ کَانَ یَنْہَی الْحَرَامَ عْن أَکْلِ الصَّیْدِ وَشِیقَۃً ، أَو غَیْرَہَا۔,,,14690,,
14691,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرٍو ، عَنْ أَبِی الشَّعْثَائِ ؛ أَنَّہُ کَرِہَ أَکْلَہُ لِلْمُحْرِمِ ، وَیَتْلُو: {وَحُرِّمَ عَلَیْکُمْ صَیْدُ الْبَرِّ مَا دُمْتُمْ حُرُمًا}۔",,,14691,,
14692,"حدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، قَالَ : قَالَتْ : یَا ابْنَ أُخْتِی ، إِنَّمَا ہِیَ لَیَالٍ ، فَإِنْ تَخَلَّجَ فِی صَدْرِکَ شَیْئٌ فَدَعْہُ۔",,,14692,,
14693,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ طَاوُوسٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : ہِیَ مُبْہَمَۃٌ۔",,,14693,,
14694,حدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ سِمَاکٍ ، عَنْ مَعْبَدِ بْنِ صُبَیْحٍ ، عَنْ عَلِیٍّ ؛ أَنَّہُ کَرِہَہُ۔,,,14694,,
14695,حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ زِیاد ، عَنْ عَبْدِ اللہِ بْنِ الْحَارِثِ ؛ أَنَّ عُثْمَانَ أُہْدِیَتْ لَہُ حَجَلٌ وَہُوَ فِی بَعْضِ حَجَّاتِہِ وَہُوَ مُحْرِمٌ ، فَأَمَرَ بِہَا فَطُبِخَتْ ، فَجُعِلَتْ ثَرِیدًا ، فَأُتِیَ بِہَا فِی الْجِفَانِ وَنَحْنُ مُحْرِمُونَ ، فَأَکَلُوا کُلُّہُمْ إِلاَّ عَلِیًا۔,,,14695,,
14696,"حدَّثَنَا وَکِیعٌ، عَنْ إِسْمَاعِیلَ، قَالَ: سَأَلْتُ الشَّعْبِیَّ عَنْہُ؟ فَقَالَ: قَدَ اُخْتُلِفَ فِیہِ، وَلاَ تَأْکُلْ مِنْہُ أَحَبَّ إلَیَّ",,,14696,,
14697,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ طَاوُوسٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إِنِ اسْتَطَعْتَ أَنْ لاَ تَدْنُوَ مِنِ امْرَأَتِکَ وَأَنْتَ حَرَامٌ۔",,,14697,,
14698,حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یَأْمُرُ بِاعْتِزَالِہَا جِدًّا۔,,,14698,,
14699,"حدَّثَنَا حُسَین بن عَلِیّ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنْ حَبِیبِ بْنِ أَبِی مَرْزُوقٍ ، قَالَ : سَأَلْتُ عَنْہُ نَافِعًا ؟ فَقَالَ : لاَ بَأْسَ بِہِ۔",,,14699,,
14700,"حدَّثَنَا وَکِیعٌ، عَنْ شُعْبَۃَ، عَنْ أَبِی بِشْرٍ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ فِی الرَّجُلِ یَحْمِلُ امْرَأَتَہُ وَہُوَ مُحْرِمٌ، قَالَ : احْمِلْہَا وَاتَّقِ اللَّہَ۔",,,14700,,
14701,حدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی بِشْرٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ بِنَحْوِہِ۔,,,14701,,
14702,"حدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ جَابِرٍ، عَنْ عَامِرٍ، وَعَطَائٍ، قَالاَ: لاَ بَأْسَ أَنْ یَحْمِلَہَا، مَا لَمْ تَکُنْ مُلاَمَسَۃٌ۔",,,14702,,
14703,"حدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، وَعَطَائٍ ، قَالاَ : لاَ بَأْسَ أَنْ یَحْمِلَ الْمُحْرِمُ امْرَأَتَہُ ، مَا لَمْ یَلْزِقْ جِلْدَہُ بِجِلْدِہَا۔",,,14703,,
14704,"حدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ سِمَاکٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : سَأَلَ مَرْوَانُ بْنُ الْحَکَمِ ابْنَ عَبَّاسٍ وَنَحْنُ بِوَادِی الأَزْرَقِ ، فَقَالَ : الصَّیْدُ یَصِیدُہُ الْمُحْرِمُ ، لاَ یَجِدُ لَہُ نِدًّا مِنَ النَّعَمِ ؟ فَقَالَ ابْنُ عَبَّاسٍ : ثَمَنُہُ یُہْدَی إلَی مَکَّۃَ۔",,,14704,,
14705,"حدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا أَصَابَ الْمُحْرِمُ مِنَ الصَّیْدِ مَا لَمْ یَکُنْ فِیہِ ہَدْیٌ ، تَصَدَّقَ بِثَمَنِہِ۔",,,14705,,
14706,"حدَّثَنَا ابْنُ أَبِی زَائِدَۃَ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : مَا لَمْ یَبْلُغْ ہَدْیًا ،فَطَعَامٌ یَطْعَمُہُ۔",,,14706,,
14707,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ زِیَادِ بْنِ الْحُصَیْنِ ، عَنْ أَبِی الْعَالِیَۃِ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : تَمَثَّلَ بِہَذَا الْبَیْتَ وَہُوَ مُحْرِمٌ ، قَالَ :\n\nوَہُنَّ یَمْشِینَ بِنَا ہَمِیسًا ۔۔۔ إِنْ تَصْدُقَ الطَّیْرُ نَنِکَ لَمِیسَا۔\n\nقَالَ : فَقِیلَ لَہُ : تَقُول ہَذَا وَأَنْتَ مُحْرِمٌ ، فَقَالَ : إِنَّمَا الْفُحْشُ مَا وُوْجِہ بِہِ النِّسَائُ وَہُمْ مُحْرِمُونَ۔",,,14707,,
14708,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ الْحَسَنِ بْنِ مُسْلِمٍ ، عَنْ طَاوُوسٍ ؛ أَنَّہُ کَرِہَ الإِعْرَابَ لِلْمُحْرِمِ ، قُلْتُ : وَمَا الإِعْرَابُ ؟ قَالَ : أَنْ یَقُولَ : لَوْ أَحْلَلْت قَدْ أَصَبْتُکِ۔",,,14708,,
14709,حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ أَنَّہُ کَرِہَ التَّعْرِیبَ لِلْمُحْرِمِ۔,,,14709,,
14710,حدَّثَنَا وَکِیعٌ ، عَنْ مَعْقِلٍ ، عَنْ عَبْدِ اللہِ بْنِ عُبَیْدِ بْنِ عُمَیر ؛ أَنَّہُ کَرِہَ التَّعْرِیبَ لِلْمُحْرِمِ۔,,,14710,,
14711,"حدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ طَاوُوسٍ ؛ أَنَّ عَبْدَ اللہِ بْنَ الزُّبَیْرِ ، قَالَ : إِیَّاکُمْ وَالنِّسَائَ ، فَإِنَّ الإِعْرَابَ مِنَ الرَّفَثِ ، قَالَ طَاوُوس : فَأَخْبَرْتُ بِذَلِکَ ابْنَ عَبَّاسٍ ، فَقَالَ : صَدَقَ ابْنُ الزُّبَیْرِ۔",,,14711,,
14712,"حدَّثَنَا حَفص بْنُ غِیَاثٍ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لَیْسَ عَلَی الصَّفَا وَالْمَرْوَۃِ دُعَائٌ مُوَقَّتٌ ، فَادْعُ بِمَا شِئْتَ۔",,,14712,,
14713,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : لَمْ نَسْمَعْ عَلَی الصَّفَا وَالْمَرْوَۃِ دُعَائٌ مُوَقَّتًا۔",,,14713,,
14714,"حدَّثَنَا أَبُو عَامِرٍ الْعَقَدِیُّ ، عَنْ أَفْلَحَ ، عَنِ الْقَاسِمِ ، قَالَ : لَیْسَ عَلَیْہِمَا دُعَائٌ مُوَقَّتٌ ، فَادْعُ بِمَا شِئْتَ ، وَسَلْ مَا شِئْتَ۔",,,14714,,
14715,"حدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ مُعَاذِ بْنِ الْعَلاَئِ ، قَالَ : سَمِعْتُ عِکْرِمَۃَ بْنَ خَالِدٍ الْمَخْزُومِیَّ یَقُولُ : لاَ أَعْلَمُ عَلَی الصَّفَا وَالْمَرْوَۃِ دُعَائً مُوَقَّتًا۔",,,14715,,
14716,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ زَکَرِیَّا ، عَنِ الشَّعْبِیِّ ، عَنْ وَہْبِ بْنِ الأَجْدَعِ ؛ أَنَّہُ سَمِعَ عُمَرَ یَقُولُ : یَبْدَأُ بِالصَّفَا وَیَسْتَقْبِلُ الْبَیْتَ ، ثُمَّ یُکَبِّرُ سَبْعَ تَکْبِیرَاتٍ ، بَیْنَ کُلِّ تَکْبِیرَتَیْنِ ، حَمْدٌ للہِ وَصَلَاۃٌ عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَمَسْأَلۃٌ لِنَفْسِہِ ، وَعَلَی الْمَرْوَۃِ مِثْلَ ذَلِکَ۔",,,14716,,
14717,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عُبَیدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ إِذَا صَعِدَ عَلَی الصَّفَا اسْتَقْبَلَ الْبَیْتَ، ثُمَّ کَبَّرَ ثَلاَثًا ، ثُمَّ قَالَ : لاَ إِلَہَ إِلاَّ اللَّہُ وَحْدَہُ لاَ شَرِیکَ لَہُ ، لَہُ الْمُلْکُ وَلَہُ الْحَمْدُ ، وَہُوَ عَلَی کُلِّ شَیْئٍ قَدِیرٌ ، یَرْفَعُ بِہَا صَوْتَہُ ، ثُمَّ یَدْعُو قَلِیلاً ، ثُمَّ یَفْعَلُ ذَلِکَ عَلَی الْمَرْوَۃِ ، حَتَّی یَفْعَلَ ذَلِکَ سَبْعَ مَرَّاتٍ ، فَیَکُونَ التَّکْبِیرُ إِحُدَی وَعِشْرِینَ تَکْبِیرَۃً ، فَمَا یَکَادُ یَفْرُغُ حَتَّی یَشُقَّ عَلَیْنَا ، وَنَحْنُ شَبَابٌ۔",,,14717,,
14718,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ الأَصْبَغِ بْنِ زَیْدٍ ، عَنِ الْقَاسِمِ بْنِ أَبِی أَیُّوبَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، أَنَّہُ کَانَ یَقُولُ : یَقُومُ الرَّجُلُ عَلَی الصَّفَا وَالْمَرْوَۃِ قَدْرَ قِرَائَۃِ سُورَۃِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,14718,,
14719,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مُغِیرَۃَ ، قَالَ : قَالَ الْحَکَمُ لإِبْرَاہِیمَ : رَأَیْتُ أَبَا بَکْرِ بْنَ عَبْدِ الرَّحْمَنِ بْنِ الْحَارِثِ یَقُومُ عَلَی الصَّفَا قَدْرَ مَا یَقْرَأُ الرَّجُلُ عِشْرِینَ وَمِئَۃَ آیَۃٍ ، قَالَ : إِنَّہُ لَفَقِیہٌ۔",,,14719,,
14720,"حدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ جَابِرٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَدَأَ بِالصَّفَا ، فَرَقِی ، وَوَحَّدَ اللَّہَ وَکَبَّرَہُ ، وَقَالَ : لاَ إِلَہَ إِلاَّ اللَّہُ وَحْدَہُ لاَ شَرِیکَ لَہُ ، لَہُ الْمُلْکُ وَلَہُ الْحَمْدُ ، وَہُوَ عَلَی کُلِّ شَیْئٍ قَدِیرٌ ، لاَ إِلَہَ إِلاَّ اللَّہُ وَحْدَہُ ، أَنْجَزَ وَعْدَہُ ، وَنَصَرَ عَبْدَہُ ، وَہَزَمَ الأَحْزَابَ وَحْدَہُ ، ثُمَّ دَعَا بَیْنَ ذَلِکَ ، قَالَ مِثْلَ ذَلِکَ ثَلاَثَ مَرَّاتٍ ، ثُمَّ نَزَلَ إِلَی الْمَرْوَۃِ حَتَّی انْصَبَّتْ قَدَمَاہُ إِلَی بَطْنِ الْوَادِی ، حَتَّی إِذَا صَعِدْنَا مَشَی حَتَّی أَتَی الْمَرْوَۃَ ، فَفَعَلَ عَلَی الْمَرْوَۃِ کَمَا فَعَلَ عَلَی الصَّفَا۔",,,14720,,
14721,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ عَطَائٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : مَنْ ضَفَرَ ، أَوْ لَبَّدَ ، أَوْ عَقَصَ فَلْیَحْلِقْ، وَقَالَ ابْنُ عَبَّاسٍ : مَا نَوَی۔",,,14721,,
14722,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ الْعَبَّاسِ بْنِ عَبْدِ اللہِ ، عَنْ أَبِیہِ ، قَالَ : خَرَجْتُ مَعَ خَالَتِی مَیْمُونَۃَ فَلَبَّدْتُ رَأْسِی بِعَسَلٍ ، أَوْ بِغِرَائٍ فَتَنَشَّرَ ، فَشَقَّ عَلَیَّ وَأَنَا مُحْرِمٌ ، فَسَأَلْتُہَا ؟ فَقَالَتْ : اغْمِسْ رَأْسَکَ فِی مَائٍ مِرَارًا۔",,,14722,,
14723,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ عَلِیٍّ ، قَالَ : مَنْ لَبَّدَ ، أَوْ عَقَصَ ، أَوْ ضَفَرَ بسَیْرٍ ، فَقَدْ وَجَبَ عَلَیْہِ الْحَلْقُ۔",,,14723,,
14724,"حدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الأَزْرَقِ بْنِ قَیْسٍ ، عَنِ ابْنِ عُمَرَ ، عَنْ عُمَر ، قَالَ : مَنْ لَبَّدَ ، أَوْ ضَفَرَ ، أَوْ فَتَلَ فَلْیَحْلِقْ۔",,,14724,,
14725,"حدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَنْ عَوْفٍ ، عَنْ شَیْخٍ ، قَالَ : سَأَلْتُ عَنْہُ ، فَزَعَمُوا أَنَّہُ أَبُو الْمُہَلَّبِ ، قَالَ : مَنْ لَبَّدَ ، أَوْ ضَفَرَ فَقَدْ وَجَبَ عَلَیْہِ الْحَلْقُ۔",,,14725,,
14726,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانَ یُقَالُ : مَنْ لَبَّدَ ، أَوْ ضَفَرَ فَلْیَحْلِقْ۔",,,14726,,
14727,"حدَّثَنَا عُبَیْدُ اللہِ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، قَالَ : وَضَعْتُ عَلَی رَأْسِی طِینًا قَبْلَ أَنْ أُحْرِمَ ،فَلَقِیتُ ابْنَ الزُّبَیْرِ، فَقَالَ : أَمَّا عُمَرُ فَکَانَ یَرَی الْحَلْقَ عَلَی مَنْ لَبَّدَ ، وَأَمَّا أَنَا فَلاَ أَرَی إِلاَّ مَا نَوَیْتَ۔",,,14727,,
14728,"حدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إِبْرَاہِیمَ ؛ فِی الْمُحْرِمِ إِذَا احْتَاجَ إِلَی قَمِیصٍ یَلْبَسُہُ ، أَوْ حَلَقَ رَأْسَہُ ، أَوْ نَحْوِ ہَذَا مِمَّا لاَ یَحْتَاجُ إِلَیْہِ الْمُحْرِمُ ، مِمَّا لاَ یَنْبَغِی لَنَا أَنْ نَصْنَعَہُ ، قَالَ : إِنْ فَعَلَ ذَلِکَ جَمِیعًا مَعًا فَعَلَیْہِ دَمٌ وَاحِدٌ ، وَإِذَا فَرَّقَ فَلِکُلِّ شَیْئٍ مِنْ ذَلِکَ دَمٌ۔",,,14728,,
14729,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَعَطَائٍ ، قَالاَ : إِذَا جَمَعَ ذَلِکَ فِی سَاعَۃٍ فَعَلَیْہِ دَمٌ وَاحِدٌ ، وَإِنْ فَرَّقَ بَیْنَ ذَلِکَ ، فَلِکُلِّ وَاحِدٍ مِنْ ذَلِکَ دَمٌ۔",,,14729,,
14730,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، قَالَ : رَأَیْتُ الْقَاسِمَ یَتَطَوَّعُ بَیْنَ الظُّہْرِ وَالْعَصْرِ بِعَرَفَۃَ ، وَرَأَیْتُ سَالِمًا لاَ یَفْعَلُ۔",,,14730,,
14731,حدَّثَنَا أَبُو خَالِدٍ الأَحْمَر ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ لاَ یَتَطَوَّعُ بَیْنَہُمَا۔,,,14731,,
14732,"حدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ جَابِرٍ ، قَالَ : صَلَّی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الظُّہْرَ وَالْعَصْرَ بِعَرَفَۃَ ، وَلَمْ یُسَبِّحْ بَیْنَہُمَا۔",,,14732,,
14733,"حدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : صَلِّ بَیْنَ الظُّہْرِ وَالْعَصْرِ بِعَرَفَۃَ ، إِنْ شِئْتَ۔",,,14733,,
14734,"حدَّثَنَا ابْنُ أَبِی زَائِدَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ: مَنْ صَلَّی الصَّلاَتَیْنِ بِعَرَفَۃَ، لَمْ یَتَطَوَّعْ بَیْنَہُمَا۔",,,14734,,
14735,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ، قَالَ: إِنْ أَمْکَنَکَ الإِمَامُ أَنْ تَطَوَّعَ بَیْنَہُمَا ، فَتَطَوَّعْ۔",,,14735,,
14736,"حدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ أَنَس بن سِیرِین قَالَ : رَأَیْتُ ابن عُمَر لاَ یَتَطَوَّعُ بَیْنَ الظُّہْرِ وَالْعَصْرِ بِعَرَفَۃَ ، وَرَأَیتُ القَاسِم یَتَطَوَّع۔",,,14736,,
14737,حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یَتَطَوَّعُ بَیْنَ الظُّہْرِ وَالْعَصْرِ بِعَرَفَۃَ۔,,,14737,,
14738,"حدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنِ الصَّبَّاحِ بْنِ عَبْدِ اللہِ الْبَجَلِیِّ ، قَالَ : سَأَلْتُ أَنَسَ بْنَ مَالِکٍ عَنِ الْمُحْرِمِ ، ہَلْ یَذْبَحُ ؟ قَالَ : نَعَمْ۔",,,14738,,
14739,"حدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : یَذْبَحُ الْمُحْرِمُ کُلَّ شَیْئٍ ، إِلاَّ الصَّیْدَ",,,14739,,
14740,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، وَحَمَّادٍ ، عَنْ إبْرَاہِیمَ ۔ قَالَ : وَسَأَلْتُ عَطَائً ، فَقَالاَ : لاَ بَأْسَ أَنْ یَذْبَحَ الْمُحْرِمُ مَا لَیْسَ بِصَیْدٍ",,,14740,,
14741,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، قَالَ : سَأَلْتُہُ عَنْ ذَبِیحَۃِ الْمُحْرِمِ ؟ فَلَمْ یَرَ بِہَا بَأْسًا ، قَالَ : وَکَانَ الْحَکَمُ لاَ یَرَی بِہَا بَأْسًا۔",,,14741,,
14742,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : ذَبِیحَۃُ الْمُحْرِمِ مَیْتَۃٌ",,,14742,,
14743,"حدَّثَنَا یَعْقُوبُ بْنُ إِبْرَاہِیمَ ، عَن لَیْثٍ ، عَنْ عَطَائٍ ، قَالَ : ذَبِیحَۃُ الْمُحْرِم کَالْمَیْتَۃِ لاَ تُؤْکَلُ۔",,,14743,,
14744,"حدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ أَبِی مَاعِزٍ ، قَالَ : جَائَتِ امْرَأَۃٌ إِلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَتْ : یَا رَسُولَ اللہِ ، إِنِّی اُسْتُحِضْتُ ، قَالَ : دَعِی الصَّلاَۃَ أَیَّامَکِ الَّتِی ہِیَ أَیَّامُک ، ثُمَّ اغْتَسِلِی وَاحْتَشِی کُرْسُفًا ، وَطُوفِی بِالْبَیْتِ وَصَلِّی۔",,,14744,,
14745,"حدَّثَنَا جَرِیرٌ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ رُفَیْعٍ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عُمَرَ ؛ فِی الْمُسْتَحَاضَۃِ ، قَالَ : مُرْہَا فَلْتَغْتَسِلْ وَلْتَسْتَنْقِی بِجَہْدِہَا ، وَلْتَستنفِرْ بِثَوْبٍ نَظِیفٍ ، ثُمَّ لْتَطُفْ بِالْبَیْتِ۔",,,14745,,
14746,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ حُمَید ، عَنْ عَمَّارِ بْنِ أَبِی عَمَّارٍ مَوْلَی بَنِی ہَاشِمٍ ، قَالَ : جَاء ت امْرَأَۃٌ إِلَی ابْنِ عَبَّاسٍ ، فَقَالَتْ : تَطُوفُ الْمُسْتَحَاضَۃُ بِالْبَیْتِ ؟ فَقَالَ : تَقْعُدُ أَیَّامَ أَقْرَائِہَا ، ثُمَّ تَغْتَسِلْ وَتَطُوفُ بِالْبَیْتِ ، قَالَ : فَقَالَتْ : ہَلْ تَدْخُلُ الْکَعْبَۃَ ؟ قَالَ : فَقَالَ : اسْتَدْخِلِی وَاسْتَنْفِرِی ، وَادْخُلِی۔",,,14746,,
14747,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ اللہِ بْنِ مُسْلِمٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : سَأَلْتُُہُ : أَتُصَلِّی الْمُسْتَحَاضَۃُ ؟ قَالَ : نَعَمْ ، وَتَحُجُّ الْبَیْتَ وَإِنْ سَالَ عَلَی عَقِبَیْہَا۔",,,14747,,
14748,"حدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، وَالْحَسَنِ ؛ أَنَّہُمَا قَالاَ : تَقْضِی الْمَنَاسِکَ۔",,,14748,,
14749,"حدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : الْمُسْتَحَاضَۃُ تَطُوفُ بِالْبَیْتِ ، وَبَیْنَ الصَّفَا وَالْمَرْوَۃِ۔",,,14749,,
14750,حدَّثَنَا وَکِیعٌ، عَنْ ہَمَّامٍ ، عَنْ عَطَائٍ ، عَنِ امْرَأَۃٍ مِنْ أَہْلِ مَکَّۃَ ، عَنْ عَائِشَۃَ؛ أَنَّہَا طَافَتْ بِی مُسْتَحَاضَۃً۔,,,14750,,
14751,"حدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ أَشْعَثَ ، عَنْ عَطَائٍ ؛ قَالَ : تَجْلِسُ الْمُسْتَحَاضَۃُ اسْتِعْدَادَہَا الَّذِی کَانَتْ تَجْلِسُ فِیہِ ، ثُمَّ تَحْتَشِی وَتَغْتَسِلُ ، وَتَطُوفُ بِالْبَیْتِ وَتَنْفِرُ۔",,,14751,,
14752,"حدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِنَافِعٍ : مَتَی کَانَ ابْنُ عُمَرَ یَرُوحُ ؟ قَالَ : رَسُولُہُ عِنْدَ الإِمَامِ ، فَإِذَا رَاحَ ، رَاحَ ، عَجَّلَ ، أَوْ أَخَّرَ ، قَالَ : وَکَانَ لاَ یَخْرُجُ حَتَّی یَطُوفَ سبْعًا ، وَکَانَ یُحِبُّ أَنْ لاَ یُصَلِّیَ الظُّہْرَ إِلاَّ بِمِنًی ، قَالَ : وَأَخَّرَ الأَمِیُر مَرَّۃً ، فَصَلَّی دُونَ مِنًی۔",,,14752,,
14753,"حدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ رُفَیْعٍ ، قَالَ : رَأَیْتُ أَنَسًا رَاکِبًا حِمَارًا ، ذَاہِبًا إِلَی مِنًی یَوْمَ التَّرْوِیَۃِ ، فَقُلْتُ لَہُ : أَیْنَ صَلَّی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الظُّہْرَ فِی ہَذَا الْیَوْمِ ؟ قَالَ : اُنْظُرْ أَیْنَ یُصَلِّی أُمَرَاؤُکَ فَصَلِّ۔",,,14753,,
14754,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : یُصَلِّی الظُّہْرَ یَوْمَ التَّرْوِیَۃِ بِمَکَّۃَ ، ثُمَّ یَسِیرُ إلَی مِنًی فَیَبِیتُ بِہَا۔",,,14754,,
14755,حدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ جَابِرٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لَمَّا کَانَ یَوْمَ التَّرْوِیَۃِ تَوَجَّہَ إِلَی مِنًی ، فَصَلَّی بِہَا الظُّہْرَ وَالْعَصْرَ ، وَالْمَغْرِبَ وَالْعِشَائَ وَالصُّبْحَ۔,,,14755,,
14756,"حدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ الْخُرَاسَانِیِّ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : الرَّوَاحُ إِلَی مِنًی إِذَا زَاغَتِ الشَّمْسُ ، فَلْیَرُح الإِمَامُ۔",,,14756,,
14757,"حدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : صَلَّی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الظُّہْرَ یَوْمَ التَّرْوِیَۃِ بِمِنًی۔",,,14757,,
14758,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : کَانَتْ عَائِشَۃُ تَمْکُثُ بِمَکَّۃَ لَیْلَۃَ عَرَفَۃَ مُسْیَ یَوْمِ التَّرْوِیَۃِ ، عَامَّۃَ اللَّیْلِ۔",,,14758,,
14759,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ : صَلَّیْتُ مَعَہُ بِمَکَّۃَ الْعِشَائَ لَیْلَۃَ التَّرْوِیَۃِ۔",,,14759,,
14760,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنِ الْقَاسِمِ ، قَالَ : سَمِعْتُ ابْنَ الزُّبَیْرِ یَقُولُ : إِنَّ مِنْ سُنَّۃِ الْحَجِّ، أَنَّ الإِمَامَ یُصَلِّی بِمِنًی الظُّہْرَ وَالْعَصْرَ ، وَالْمَغْرِبَ وَالْعِشَائَ وَالْفَجْرَ ، ثُمَّ یَغْدُو۔",,,14760,,
14761,"حدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قَالَ عَطَائٌ : مَنْ شَائَ صَلَّی بِمَکَّۃَ الظُّہْرَ ، وَمَنْ شَائَ صَلَّی بِمِنًی۔",,,14761,,
14762,"حدَّثَنَا أَبُو خَالِدٍ ، عَنْ إِسْمَاعِیلَ بْنِ عَبْدِ الْمَلِکِ ، قَالَ : رَأَیْتُ سَعِیدَ بْنَ جُبَیْرٍ یَوْمَ التَّرْوِیَۃِ صَلَّی رَکْعَتَیْنِ فِی الْمَسْجِدِ الْحَرَامِ ، ثُمَّ خَرَجَ مِنْ مَکَّۃَ مَاشِیًا حَتَّی انْتَہَی إِلَی مِنًی ، فَصَلَّی بِہَا الظُّہْرَ وَالْعَصْرَ ، وَالْمَغْرِبَ وَالْعِشَائَ وَالْفَجْرَ",,,14762,,
14763,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ عَاصِمٍ ، عَنْ لاَحِقِ بْنِ حُمَیْدٍ ، قَالَ : صَلَّیْتُ الْفَجْرَ إِلَی جَنْبِ ابْنِ عُمَرَ ، وَرَاحِلَتُہُ مَوْقُوفَۃٌ ، فَلَمَّا نَظَرَ إِلَی الشَّمْسِ عَلَی قُلَّۃِ الْجَبَلِ رَکِبَ رَاحِلَتَہُ ، ثُمَّ غَدَا إِلَی عَرَفَاتٍ۔",,,14763,,
14764,"حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، قَالَ : أَخْبَرَنِی مَنْ رَأَی ابْنَ عَبَّاسٍ یَأْتِی عَرَفَۃَ بِسَحَرٍ۔",,,14764,,
14765,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ، قَالَ : أَمَّا إِبْرَاہِیمُ فَإِنَّہُ بَاتَ بِمِنًی ، حَتَّی إِذَا أَصْبَحَ وَطَلَعَ حَاجِبُ الشَّمْسِ سَارَ حَتَّی نَزَلَ مَنْزِلَہُ مِنْ عَرَفَۃَ۔ (ابن خزیمۃ 2803)",,,14765,,
14766,حدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ جَابِرٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی بِمِنًی الْفَجْرَ ، ثُمَّ مَکَثَ قَلِیلاً حَتَّی طَلَعَتِ الشَّمْسُ ، ثُمَّ سَارَ۔,,,14766,,
14767,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا صَلَّیْتَ الْفَجْرَ فَسِرْ إلَی عَرَفَاتٍ ،فَأنْزِلْ مَنَازِلَ النَّاسِ ، الأَرَاکَ وَغَیْرَہُ مِنْ مَنَازِلِہِمْ۔",,,14767,,
14768,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : رَأَیْتُ الأَئِمَّۃَ ، أَئِمَّۃَ الْمَوْسِمِ یَتَحَرَّوْنَ بِغُدُوِّہِمْ إِلَی عَرَفَاتٍ طُلُوعَ الشَّمْسِ ، وَلاَ أَرَاہُمْ تَحَرَّوْا بِہِ إِلاَّ فِعْلَ نَبِیِّہِمْ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,14768,,
14769,"حدَّثَنَا وَکِیعٌ ، عَنْ أَفْلَحَ ، قَالَ : صَلَّیْتُ مَعَ الْقَاسِمِ الْفَجْرَ بِمِنًی ، ثُمَّ مَکَثَ سَاعَۃً ، ثُمَّ ارْتَحَلَ۔",,,14769,,
14770,"حدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مُحَمَّدٍ الْمُحَارِبِیُّ ، عَنِ الْعَلاَئِ بْنِ الْمُسَیَّبِ ، عَنْ أَبِیہِ ، قَالَ : لاَ یَخْرُجُ مِنْ مِنًی إِلَی عَرَفَاتٍ حَتَّی یُصَلِّیَ بِمِنًی الْغَدَاۃَ۔",,,14770,,
14771,"حدَّثَنَا أَبُو خَالِدٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ اسْتَلَمَ الْحَجَرَ بِیَدِہِ وَقَبَّلَ یَدَہُ ، وَقَالَ: مَا تَرَکْتُہُ مُنْذُ رَأَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَفْعَلُہُ۔ (مسلم 246۔ بیہقی 75)",,,14771,,
14772,"حدَّثَنَا ابْنُ إِدْرِیسَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ ، وَأَبَا ہُرَیْرَۃ إِذَا اسْتَلَمُوا الرُّکْنَ، یَعْنِی الْحَجَرَ ، قَبَّلُوا أَیْدِیَہُمْ ۔ قَالَ : قُلْتُ لِعَطَائٍ : وَابْنَ عَبَّاسٍ ؟ قَالَ : وَابْنُ عَبَّاسٍ ، حَسِبْتَ کَثِیرًا ، قَالَ : وَقَالَ عَطَائٌ : لَمْ أَمْسَحِ الرُّکْنَ إِنْ لَمْ أُقَبِّلْ یَدِی ۔ قَالَ : وَقَالَ عَمْرُو بْنُ دِینَارٍ : یَجْفَی مَنْ مَسَحَ الرُّکْنَ، وَلَمْ یُقَبِّلْ یَدَہُ۔",,,14772,,
14773,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ مُحَمَّدِ بْنِ الْمُرْتَفِعِ ، قَالَ : رَأَیْتُ ابْنَ الزُّبَیْرِ ، وَعُمَرَ بْنَ عَبْدِ الْعَزِیزِ اسْتَلَمَا الْحَجَرَ ، فَأَمَّا أَحَدُہُمَا فَقَبَّلَ یَدَہُ ، وَالآخَرُ مَسَحَ بِہَا وَجْہَہُ۔",,,14773,,
14774,"حدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، وَأَبُو أُسَامَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، قَالَ : مَا رَأَیْتُ أَبِی اسْتَلَمَ الْحَجَرَ ، إِلاَّ قَبَّلَ یَدَہُ۔",,,14774,,
14775,"حدَّثَنَا ابْنُ فُضَیْلٍ، وَعَبْدَۃَ، عَنْ عَبْدِ الْمَلِکِ، قَالَ: رَأَیْتُ سَعِیدَ بْنَ جُبَیْرٍ یَمْسَحُ الْحَجَرَ ، ثُمَّ یُقَبِّلُ یَدَہُ۔",,,14775,,
14776,"حدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ عُبَیْدِ اللہِ بْنِ أَبِی زِیَادٍ ، قَالَ : رَأَیْتُ مُجَاہِدًا ، وَسَعِیدَ بْنَ جُبَیْرٍ ، وَعَطَائً؛ إِذَا اسْتَلَمُوا الرُّکْنَ الْیَمَانِیَّ ، قَبَّلُوا أَیْدِیَہُمْ۔",,,14776,,
14777,"حدَّثَنَا حُمَیْدُ بْنُ عَبْدِالرَّحْمَنِ، عَنْ حَسَنٍ، عَنْ طَارِقٍ، قَالَ: رَأَیْتُ عَلِیَّ بْنَ حُسَیْنٍ یَلْتَزِمُ الرُّکْنَ الْیَمَانِیَّ۔",,,14777,,
14778,"حدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، وَطَاوُسٍ ؛ فِی الرَّجُلِ یَنْسَی الرَّکْعَتَیْنِ اللَّتَیْنِ لِلطَّوَافِ الْوَاجِبِ ، قَالاَ : إِنْ صَلَّی بَعْدَہَا صَلاَۃً أَجْزَأَہُ ذَلِکَ ، وَإِنْ صَلَّی فِی أَدْنَی الْحَرَمِ وَأَقْصَاہُ أَجْزَأَہُ ، وَإِنْ لَمْ یُصَلِّ حَتَّی یَخْرُجَ مِنَ الْحَرَمِ أَہْرَاقَ دَمًا",,,14778,,
14779,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ فِی رَجُلٍ طَافَ بِالْبَیْتِ وَنَسِیَ أَنْ یُصَلِّیَ الرَّکْعَتَیْنِ حَتَّی مَضَی ، قَالَ : یُصَلِّیہِمَا إِذَا ذَکَرَ ، وَلَیْسَ عَلَیْہِ شَیْئٌ۔",,,14779,,
14780,"حدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ نَسِیَ رَکْعَتَیِ الطَّوَافِ ، قَالَ : یُصَلِّیہِمَا حَیْثُ مَا ذَکَرَہُمَا مَا لَمْ یَغْشَ النِّسَائَ۔",,,14780,,
14781,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ عَتَّابِ بْنِ زِیَادِ بْنِ وَرْقَائَ ، قَالَ : سَمِعْتُ سَعِیدَ بْنَ جُبَیْرٍ یَقُولُ لِلْحَلاَّقِ : اُبْلُغْ بِالْحَلْقِ إِلَی الْعَظْمَیْنِ۔",,,14781,,
14782,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَقُولُ لِلْحَلاَّقِ ، إِذَا حَلَقَ فِی الْحَجِّ وَالعمرۃ : اُبْلُغِ الْعَظْمَیْنِ۔",,,14782,,
14783,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ کَانَ یَقُولُ لِلْحَلاَقِ : ابْدَأْ بِالأَیْمَنِ ، وَابْلُغْ بِالْحَلْقِ الْعَظْمَیْنِ۔",,,14783,,
14784,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ مُحَمَّدِ بْنِ الْحَارِثِ بْنِ سُفْیَانَ ، عَنْ عَلِیٍّ الأَزْدِیِّ، قَالَ: نَحَرَ ابْنُ عُمَرَ وَحَلَقَ ، قَالَ : فَسَمِعْتُہُ یَقُولُ لِلْحَلاَقِ : اُبْلُغِ الْعَظْمَیْنِ ، قَالَ : فَقُلْتُ لِعَطَائٍ : سَمِعْتُہُ یَقُولُ فِی الْحَلْقِ ، اُبْلُغِ الْعَظْمَیْنِ ؟ ، قَالَ : سَمِعْتُہُمْ یَذْکُرُونَہُ ، وَلَمْ أَسْمَعْہُ مِنْ ثَبْتٍ۔",,,14784,,
14785,"حدَّثَنَا جُنَیْدٌ الْحَجَّامُ ، عَنْ مُخْتَارِ بْنِ مُنَیْحٍ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : اُبْلُغْ إِلَی الْعَظْمَیْنِ۔",,,14785,,
14786,"حدَّثَنَا وَکِیعٌ ، عَنْ طَلْحَۃَ ، عَنْ عَطَائٍ ، قَالَ : السُّنَّۃُ أَنْ یَبْلُغَ بِالْحَلْقِ إِلَی الْعَظْمَیْنِ۔",,,14786,,
14787,حدَّثَنَا حَفْصٌ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ، عَنْ أَنَسٍ ؛ أَنَّہُ رَأَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ لِلْحَلاَّقِ ہَکَذَا ، وَأَشَارَ بِیَدِہِ إِلَی الْجَانِبِ الأَیْمَنِ۔ (مسلم 325۔ ترمذی 912),,,14787,,
14788,"حدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرٍو ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ کَانَ یَقُولُ لِلْحَلاَّقِ : ابْدَأْ بِالأَیْمَنِ۔",,,14788,,
14789,"حدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، قَالَ : أَخْبَرَنِی الرَّجُلُ الَّذِی قَصَّرَ عَنْ نَافِعِ بْنِ عَلْقَمَۃَ فِی إِمَارَتِہِ ، قَالَ : فَقَالَ لِی : ابْدَأْ بِالشِّقِّ الأَیْسَرِ ، قَالَ : قُلْتُ : إِنِّی قَصَّرْتُ عَنِ ابْنِ عَبَّاسٍ ، قَالَ : ابْدَأْ بِالأَیْمَنِ ، قَالَ : امْضِ لِمَا أُمِرْتَ لَہُ۔",,,14789,,
14790,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنْ مِقْسَمٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَرْمِی الْجِمَارَ إِذَا زَالَتِ الشَّمْسُ۔ (ترمذی 898۔ احمد 1/248)",,,14790,,
14791,حدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَرْمِی الْجِمَارَ إِذَا زَاغت الشَّمْسُ۔,,,14791,,
14792,"حدَّثَنَا وَکِیعٌ ، عَنْ سَعِیدِ بْنِ السَّائِبِ ، عَنْ مُحَمَّدِ بْنِ السَّائِبِ ، عنْ أَبِیہِ ، قَالَ : رَأَیْتُ عُمَرَ یَخْرُجُ إِذَا زَالَتِ الشَّمْسُ یَرْمِی الْجِمَارَ",,,14792,,
14793,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ الْحَسَنِ بْنِ مُسْلِمٍ ، عَنِ ابْنِ طَاوُوس ، قَالَ : یَرْمِی الْجِمَارَ إِذَا طَلَعَتِ الشَّمْسُ۔",,,14793,,
14794,"حدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، قَالَ : رَأَیْتُ ابْنَ الزُّبَیْرِ ، وَعُبَیْدَ بْنَ عُمَیْرٍ یَرْمِیَانِ الْجِمَارَ بَعْدَ مَا زَالَتِ الشَّمْسُ",,,14794,,
14795,"حدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، قَالَ : رَمَقْتُ ابْنَ عَبَّاسٍ رَمَاہَا عِنْدَ الظَّہِیرَۃِ قَبْلَ أَنْ تَزُولَ۔",,,14795,,
14796,"حدَّثَنَا عَبْدُ اللہِ بْنُ إِدْرِیسَ ، عَنْ عَبْدِ اللہِ بْنِ عُثْمَانَ ، قَالَ : رَأَیْتُ سَعِیدَ بْنَ جُبَیْرٍ یَتَحَیَّنُ زَوَالَ الشَّمْسِ ، فَیَرْمِی الْجِمَارَ۔",,,14796,,
14797,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ مُحَمَّدِ بْنِ أَبِی إِسْمَاعِیلَ : قَالَ : رَأَیْتُ سَعِیدَ بْنَ جُبَیْرٍ ، وَطَاوُوسًا یَرْمِیَانِ الْجِمَارَ عِنْدَ زَوَالِ الشَّمْسِ ، وَیُطِیلاَنِ الْقِیَامَ",,,14797,,
14798,حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ مِثْلَہُ۔,,,14798,,
14799,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : سَمِعْتُ عَطَائً یَقُولُ : لاَ تُرْمَی الْجَمْرَۃُ حَتَّی تَزُولَ الشَّمْسُ ، فَعَاوَدْتُہُ فِی ذَلِکَ ، فَقَالَ ذَلِکَ۔",,,14799,,
14800,"حدَّثَنَا عَبْدُ اللہِ بْنُ إِدْرِیسَ ، وَأَبُو خَالِدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَمَی جَمْرَۃَ الْعَقَبَۃِ یَوْمَ النَّحْرِ ضُحًی ، وَأَمَّا بَعْدُ فَإِذَا زَالَتِ الشَّمْسُ۔\n\n(مسلم 314۔ ابوداؤد 511)",,,14800,,
14801,حدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ أَشْعَثَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ؛ مِثْلَہُ ، وَلَمْ یَرْفَعْہُ,,,14801,,
14802,"حدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مَنْصُورٍ ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنِ الْحَسَنِ الْعُرَنِیِّ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، أَوْ عَنِ الْحَسَنِ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : أَتَانَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِلَیْلٍ، فَرَحَّلَنَا عَلَی حُمُرَاتِ أُغَیْلِمَۃِ بَنِی عَبْدِ الْمُطَّلِبِ ، وَجَعَلَ یَلْطُخُ أَفْخَاذَنَا ، وَیَقُولُ : أُبَیْنِیَّ ، لاَ تَرْمُوا الْجَمْرَۃَ حَتَّی تَطْلُعَ الشَّمْسُ ، وَمَا أَحْسَبُ أَحَدًا یَرْمِیہَا حَتَّی تَطْلُعَ الشَّمْسُ ، وَکَانَ ابْنُ عَبَّاسٍ یَقُولُ : مَنْ أَفَاضَ مِنْ عُرْنَۃَ فَلاَ حَجَّ لَہُ",,,14802,,
14803,"حدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مُغِیرَۃَ ، عَنْ إبِْرَاہِیمَ ، قَالَ : لاَ تُرْمَی جَمْرَۃُ الْعَقَبَۃِ یَوْمَ النَّحْرِ ، حَتَّی تَطْلُعَ الشَّمْسُ۔",,,14803,,
14804,"حدَّثَنَا عَبْدُ الْعَزِیزِ بْنُ عَبْدِ الصَّمَدِ الْعَمِّیُّ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، قَالَ : رَأَیْتُ أَبَا جَعْفَرٍ رَمَی الْجَمْرَۃَ قَبْلَ طُلُوعِ الشَّمْسِ ، وَکَانَ عَطَائٌ ، وَطَاوُوسٌ ، وَمُجَاہِدٌ ، وَالنَّخَعِیُّ ، وَعَامِرٌ ، وَسَعِیدُ بْنُ جُبَیْرٍ یَرْمُونَ حِینَ یَقْدَمُونَ ، أَیَّ سَاعَۃٍ قَدِمُوا ، لاَ یَرَوْنَ بِہِ بَأْسًا۔",,,14804,,
14805,حدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ یَرْمِیَ الرَّجُلُ جَمْرَۃَ الْعَقَبَۃِ قَبْلَ أَنْ تَطْلُعَ الشَّمْسُ۔,,,14805,,
14806,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنِ الْقَاسِمِ ، عَنْ عَائِشَۃَ ، قَالَتْ : وَدِدْتُ أَنِّی کُنْت اسْتَأْذَنْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَمَا اسْتَأْذَنَتْہُ سَوْدَۃُ ، أَنْ تَأْتِیَ مِنًی بِلَیْلٍ وَتَرْمِیَ مِنْ قَبْلِ أَنْ یَأْتِیَ النَّاسُ ، فَأَذِنَ لَہَا ، وَکَانَتِ امْرَأَۃً ثَبِطَۃً ثَقِیلَۃً۔ (بخاری 1680۔ مسلم 295۔ احمد 6/98)",,,14806,,
14807,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ عَبْدِ اللہِ بْنِ عَبْدِ اللہِ ، قَالَ : کَانَ ابْنُ عُمَرَ یَبْعَثُ بِصِبْیَانِہِ لَیْلَۃَ الْمُزْدَلِفَۃِ فَیُصَلُّونَ الصُّبْحَ بِمِنًی ، وَیَرْمُونَ الْجَمْرَۃَ قَبْلَ أَنْ یَأْتِیَ النَّاسُ۔",,,14807,,
14808,حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ عَطَائٍ ، وَطَاوُوسٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ احْتَجَمَ وَہُوَ مُحْرِمٌ۔ (بخاری 1835۔ ابوداؤد 1831),,,14808,,
14809,حدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ؛ أَنَّ النَّبیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ احْتَجَمَ ، وَہُوَ مُحْرِمٌ ، مِنْ وَثْئٍ کَانَ بِہِ۔ (ابوداؤد 1831),,,14809,,
14810,حدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ یَزِیدَ ، عَنْ مِقْسِم ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ النَّبیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ احْتَجَمَ وَہُوَ مُحْرِمٌ۔ (ابوداؤد 2365۔ احمد 1/215),,,14810,,
14811,"حدَّثَنَا أَبُو الأَحْوَصِ ، عَنِ الْعَلاَئِ بْنِ الْمُسَیَّبِ ، قَالَ : قیلَ لِعَطَائٍ : یَحْتَجِمُ الْمُحْرِمُ ؟ فَقَالَ : نَعَمْ ، قَدْ فَعَلَ ذَلِکَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَلَکِنْ لاَ یَحْلِقُ شَعْرًا۔",,,14811,,
14812,"حدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ زَیْدٍ ، عَنْ عُبَیْدِ اللہِ بْنِ أَبِی یَزِیدَ ، عَنْ عُبَیْدِ بْنِ عُمَیْرٍ ، قَالَ : یَحْتَجِمُ الْمُحْرِمُ ، وَلاَ یَحْلِقُ شَعْرَہُ۔",,,14812,,
14813,"حدَّثَنَا إِسْحَاقُ بْنُ سُلَیْمَانَ الرَّازِیّ ، عَنْ حَنْظَلَۃَ ، قَالَ : سُئِلَ طَاوُوسُ : أَیَحْتَجِمُ الْمُحْرِمُ ؟ قَالَ : نَعَمْ ، إِذَا کَانَ وَجِعًا۔",,,14813,,
14814,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی الضُّحَی ، عَنْ مَسْرُوقٍ ، قَالَ : یَحْتَجِمُ الْمُحْرِمُ ، وَلاَ یَحْتَجِمُ الصَّائِمُ۔",,,14814,,
14815,حدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ ، عَنْ سُلَیْمَانَ بْنِ بِلاَلٍ ، عَنْ حُمَیْدٍ ، عَنْ أَنَسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ احْتَجَمَ وَہُوَ مُحْرِمٌ۔ (ابوداؤد 1833۔ احمد 3/267),,,14815,,
14816,حدَّثَنَا مُعَلَّی بْنُ مَنْصُورٍ ، عَنْ سُلَیْمَانَ بْنِ بِلاَلٍ ، عَنْ عَلْقَمَۃَ بْنِ أَبِی عَلْقَمَۃَ ، عَنِ الأَعْرَجِ ، عَنِ ابْنِ بُحَیْنَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ احْتَجَمَ وَہُوَ مُحْرِمٌ۔ (مسلم 88),,,14816,,
14817,حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ احْتَجَمَ وَہُوَ مُحْرِمٌ عَلَی ذُؤَابَتَیْہِ ، بِمَکَانٍ یُدْعَی لَحْیَی الْجَمَل۔,,,14817,,
14818,حدَّثَنَا ابْن أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، وَمُحَمَّدٍ ؛ أَنَّہُمَا کَرِہَا أَنْ یَحْتَجِمَ الْمُحْرِمُ,,,14818,,
14819,"حدَّثَنَا فُضَیْلُ بْنُ عِیَاضٍ، عَنْ ہِشَامٍ، عَنْ عِکْرِمَۃَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: لاَ بَأْسَ أَنْ یَشُمَّ الْمُحْرِمُ الرَّیْحَانَ",,,14819,,
14820,حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ کَانَ لاَ یَرَی بِہِ بَأْسًا,,,14820,,
14821,"حدَّثَنَا وَکِیعٌ ، عَنْ إِبرَہِیمَ بْنِ نَافِعٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ بَأْسَ أَنْ یَشُمَّ الْمُحْرِمُ الرَّیْحَانَ۔",,,14821,,
14822,حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ یُوسُفَ بْنِ مَاہِکٍ ، عَمَّنْ رَأَی مَعَ عَبْدِ اللہِ بْنِ عَامِرٍ بِعَرَفَۃَ فِی الْحَجِّ رَیْحَانًا ، وَہُوَ مُحْرِمٌ۔,,,14822,,
14823,"حدَّثَنَا یَحْیَی بْنُ أَبِی بُکَیْر ، قَالَ : حدَّثَنَا إِبْرَاہِیمُ بْنُ نَافِعٍ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، قَالَ : لاَ بَأْسَ أَنْ یَشُمَّ الْمُحْرِمُ الرَّیْحَانَ۔",,,14823,,
14824,"حدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ الْغَازِ ، عَنْ عَطَائٍ ، قَالَ : لاَ بَأْسَ أَنْ یَشُمَّ الْمُحْرِمُ الإِذْخِرَ۔",,,14824,,
14825,"حدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، عَنْ أَبِیہِ ، قَالَ : لاَ بَأْسَ أَنْ یَشُمَّ الْمُحْرِمُ طِیبَ نَبَاتِ الأَرْضِ ، وَبَعْر الظّباء",,,14825,,
14826,"حدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ ، وَعَطَائٍ ، قَالاَ : لاَ بَأْسَ أَنْ یَشُمَّ الْمُحْرِمُ طِیبَ نَبَاتِ الأَرْضِ۔",,,14826,,
14827,حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ کَانَ یَکْرَہُ شَمَّ الرَّیْحَانِ لِلْمُحْرِمِ۔,,,14827,,
14828,"حدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی الزُّبَیْرِ ، قَالَ : سَأَلْتُ جَابِرًا : یَشُمُّ الْمُحْرِمُ الرَّیْحَانِ وَالطِّیبَ ؟ فَقَالَ : لاَ۔",,,14828,,
14829,"حدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنِ الْعَلاَئِ ، عَنِ الْحَکَمِ ، قَالَ : لاَ یَشُمُّ الْمُحْرِمُ الشِّیحَ ، وَلاَ الْقَیْصُومَ۔",,,14829,,
14830,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : إِذَا شَمَّ الْمُحْرِمُ رَیْحَانًا ، أَوْ مَسَّ طِیبًا أَہْرَاقَ لِذَلِکَ دَمًا۔",,,14830,,
14831,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : فِی الطِّیبِ الْفِدْیَۃُ ، وَفِی الصَّیْدِ الْجَزَائُ۔",,,14831,,
14832,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : إِذَا شَمَّ الْمُحْرِمُ طِیبًا ،کَفَّرَ۔",,,14832,,
14833,"حدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : إِذَا وَضَعَ الْمُحْرِمُ عَلَی شَیْئٍ مِنْہُ دُہْنًا فِیہِ طِیبٌ ، فَعَلَیْہِ الْکَفَّارَۃُ۔",,,14833,,
14834,"حدَّثَنَا شَرِیکٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، وَعَطَائٍ ، قَالاَ : لاَ بَأْسَ أَنْ یَتَدَاوَی الْمُحْرِمُ بِالْحِنَّائِ ، وَکَرِہَا أَنْ یَخْتَضِبَ بِہَا۔",,,14834,,
14835,"حدَّثَنَا وَکِیعً، عَنْ شَرِیکٌ، عَنْ عَبْدِالْکَرِیمِ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ، قَالَ: لاَ بَأْسَ أَنْ یَتَدَاوَی الْمُحْرِمُ بِالْحِنَّائِ۔",,,14835,,
14836,"حدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنِ الْعَلاَئِ بْنِ الْمُسَیَّبِ ، عَنْ حَمَّادٍ ، قَالَ : لاَ یَخْتَضِبُ الْمُحْرِمُ بِالْحِنَّائِ ، وَلاَ یَتَوَضَّأُ بِدسبسان۔",,,14836,,
14837,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنْ مِقْسَمٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : مِنَ السُّنَّۃِ أَنْ لاَ یُہِلَّ بِالْحَجِّ ، إِلاَّ فِی أَشْہُرِ الْحَجِّ۔",,,14837,,
14838,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : لاَ یُحْرِمُ بِالْحَجِّ ، إِلاَّ فِی أَشْہُرِ الْحَجِّ۔",,,14838,,
14839,"حدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُوسٍ ، وَمُجَاہِدٍ ؛ قَالُوا : لاَ یُحْرِمُ بِالْحَجِّ ، إِلاَّ فِی أَشْہُرِ الْحَجِّ",,,14839,,
14840,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ خُصَیْفٍ ، قَالَ : قدِمَ رَجُلٌ مِنْ أَہْلِ خُرَاسَانَ ، قَدْ أَحْرَمَ بِالْحَجِّ فِی غَیْرِ أَشْہُرِ الْحَجِّ ، فَقَالَ لَہُ عَطَائٌ : اجْعَلْہَا عُمْرَۃً ، فَإِنَّہُ لَیْسَ لَکَ حَجٌّ ، فَإِنَّ اللَّہَ تَعَالَی یَقُولُ : {الْحَجُّ أَشْہُرٌ مَعْلُومَاتٌ فَمَنْ فَرَضَ فِیہِنَّ الْحَجَّ}۔",,,14840,,
14841,"حدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی رَوَّادٍ ، عَنْ عَطَائٍ ، قَالَ : قدِمَ رَجُلٌ مُہِلاَّ بِالْحَجِّ فِی غَیْرِ أَشْہُرِ الْحَجِّ ، فَأَمَرَہُ عَطَائٌ أَنْ یَجْعَلَہَا عُمْرَۃً۔",,,14841,,
14842,"حدَّثَنَا شَرِیکٌ ، وَہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ؛ فِی رَجُلٍ أَہَلَّ بِالْحَجِّ فِی غَیْرِ أَشْہُرِ الْحَجِّ ، قَالَ شَرِیکٌ : یَمْضِی ، وَقَالَ ہُشَیْمٌ : یَلْزَمُہُ۔",,,14842,,
14843,"حدَّثَنَا شَرِیکٌ ، عَنْ یَزِیدَ الدَّالاَنِیِّ ، عَنِ الشَّعْبِیِّ ، قَالَ : یَحِلُّ ، أَوْ یُہِلَّ بِعُمْرَۃٍ۔",,,14843,,
14844,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : کَانَ ابْنُ أَبِی نُعْمٍ یُہِلُّ بِالْحَجِّ فِی غَیْرِ أَشْہُرِ الْحَجِّ، فَقَالَ عَمْرُو بْنُ مَیْمُونٍ : لَوْ أَدْرَکَ ہَذَا أَصْحَابُ مُحَمَّدٍ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لَرَجَمُوہُ۔",,,14844,,
14845,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ؛ أَنَّ أَبَا الْحَکَمِ الْبَجَلِیَّ کَانَ یُہِلُّ بِالْحَجِّ فِی غَیْرِ أَشْہُرِ الْحَجِّ ، قَالَ : فَلَقِیَہُ عِکْرِمَۃُ ، فَقَالَ : أَنْتَ رَجُلُ سُوئٍ۔",,,14845,,
14846,حدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُوسٍ ، وَمُجَاہِدٍ ؛ أَنَّہُمْ کَانُوا لاَ یَرَوْنَ بَأْسًا أَنْ یَشْرَبَ الرَّجُلُ وَہُوَ یَطُوفُ بِالْبَیْتِ۔,,,14846,,
14847,"حدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عِکْرِمَۃَ بْنِ خَالِدٍ ، عَنْ رَجُلٍ مِنْ آلِ الْوَدَاعِ ، قَالَ : اسْتَسْقَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ یَطُوفُ بِالْبَیْتِ ، فَقَالَ رَجُلٌ : أَلاَ نَسْقِیکَ مِنْ شَرَابٍ نَصْنَعُہُ ؟ فَأَتَاہُ بِإِنَائٍ فِیہِ نَبِیذُ زَبِیبٍ ، فَقَالَ : أَلاَ أَکْفَأْتَ عَلَیْہِ إنَائً ، أَوْ عَرَضْتَ عَلَیْہِ عُودًا ؟ ثُمَّ شَرِبَ مِنْہُ فَقَطَّبَ ، ثُمَّ دَعَا بِمَائٍ فَصَبَّہُ فِیہِ فَشَرِبَ ؟ وَسَقَی أَصْحَابَہُ۔",,,14847,,
14848,"حدَّثَنَا وَکِیعٌ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ اللہِ، عَنْ عَطَائٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: لاَ بَأْسَ بِالشُّرْبِ فِی الطَّوَافِ",,,14848,,
14849,حدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ خَالِدِ بْنِ سعْدٍ ، عَنْ أَبِی مَسْعُودٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ اسْتَسْقَی وَہُوَ یَطُوفُ بِالْبَیْتِ ، فَأُتِیَ بِذَنُوبٍ مِنْ نَبِیذِ السِّقَایَۃِ فَشَرِبَہ۔,,,14849,,
14850,"حدَّثَنَا یَحْیَی بْنُ زَکَرِیَّا بْنِ أَبِی زَائِدَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : إِنْ دَلَّ حَرَامٌ حَلاَلاً عَلَی صَیْدٍ فَلَمْ یَأْخُذْہُ ، فَلْیَسْتَغْفِرِ اللَّہَ۔",,,14850,,
14851,"حدَّثَنَا ابْنُ أَبِی زَائِدَۃَ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : لَیْسَ عَلَیْہِ شَیْئٌ۔",,,14851,,
14852,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، قَالَ : قَالَ عُمَرُ : لِیَکُنْ آخِرُ عَہْدِکُمْ بِالْبَیْتِ ، وَلِیَکُنْ آخِرُ عَہْدِکُمْ مِنَ الْبَیتِ بِالْحَجَرِ۔",,,14852,,
14853,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، قَالَ : قُلْتُ لإِبْرَاہِیمَ : بِأَیِّ شَیْئٍ یَکُونُ آخِرُ عَہْدِی مِنَ الْبَیْتِ ؟ قَالَ : فَقَالَ : بِالْحَجَرِ۔",,,14853,,
14854,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، قَالَ : کَانُوا یَسْتَحِبُّونَ إِذَا وَدَّعُوا ، أَنْ یَکُونَ آخِرُ عَہْدِہِمْ بِالْحَجَرِ۔",,,14854,,
14855,"حدَّثَنَا جَرِیرٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، قَالَ : إِذَا اضْطُرَّ الْمُحْرِمُ إِلَی لُبْسِ الْخُفَّیْنِ ، خَرَقَ ظُہُورَہُمَا وَتَرَکَ فِیہِمَا قَدْرَ مَا تَسْتَمْسِکُ رِجْلاَہُ۔",,,14855,,
14856,"حدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا اضْطُرَّ الْمُحْرِمُ إِلَی الْخُفَّیْنِ ،خَرَقَہُمَا وَتَرَکَ فِیہِمَا قَدْرَ الشِّرَاکِ ، وَیَقْطَعُہُمَا مِنْ قِبَلِ کَعْبَیْہِ۔",,,14856,,
14857,"حدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرِ بْن بُرْقَانَ ، قَالَ : قَالَ نَافِعٌ : یَقْطَعُ الْخُفَّیْنِ أَسْفَلَ مِنَ الْکَعْبَیْنِ۔",,,14857,,
14858,"حدَّثَنَا غُنْدَرٌ ، عَنْ عُثْمَانَ بْنِ غِیَاثٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : یَتَخَفَّفُ إِذَا لَمْ یَجِدْ نَعْلَیْنِ ، قَالَ : قُلْتُ : أَیَشُقُّہُمَا ؟ قَالَ : إِنَّ اللَّہَ لاَ یُحِبُّ الْفَسَادَ۔",,,14858,,
14859,حدَّثَنَا غُنْدَرٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کان یُرَخِّصُ لِلْمُحْرِمِ أَنْ یَلْبَسَ خُفَّیْنِ ،لَیْسَا بِمَقْطُوعَیْنِ۔,,,14859,,
14860,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إِنْ لَمْ یَجِدْ نَعْلَیْنِ لَبِسَ الْخُفَّیْنِ أَسْفَلَ مِنَ الْکَعْبَیْنِ۔ (بخاری 5794۔ ابوداؤد 1821)",,,14860,,
14861,حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا بِالْمُطَلَّقَاتِ ثَلاَثًا ، وَالْمُتَوَفَّی عَنْہُنَّ أَزْوَاجُہُنَّ أَن یَحْجُجْنَ فِی عِدَّتِہِنَّ۔,,,14861,,
14862,حدَّثَنَا وَکِیعٌ ، عَنْ أُسَامَۃَ ، عَنِ الْقَاسِمِ (ح) وَعَنْ جَرِیرِ بْنِ حَازِمٍ ، عَنْ عَطَائٍ ؛ أَنَّ عَائِشَۃَ أَحَجَّتْ أُمَّ کُلْثُومٍ فِی عِدَّتِہَا۔,,,14862,,
14863,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : لاَ بَأْسَ أَنْ تَحُجَّ فِی عِدَّتِہَا۔",,,14863,,
14864,"حدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ حَبِیبٍ الْمُعَلِّمِ ، قَالَ : سَأَلْتُ عَطَائً عَنِ الْمُطَلَّقَۃِ ثَلاَثًا ، وَالْمُتَوَفَّی عَنْہَا ، تَحُجَّانِ فِی عِدَّتِہِمَا ؟ فَقَالَ : نَعَمْ ، قَالَ حَبِیبٌ : وَکَانَ الْحَسَنُ یَقُولُ ذَلِکَ۔",,,14864,,
14865,حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَبِیبٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ (ح) وَعَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّ عُمَرَ رَدَّ نِسْوَۃً حَاجَّاتٍ ، أَوْ مُعْتَمِرَاتٍ ، خَرَجْنَ فِی عِدَّتِہِنَّ۔,,,14865,,
14866,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی الْمِقْدَامِ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : الْمُتَوَفَّی عَنْہَا ، وَالْمُطَلَّقَۃُ ثَلاَثًا ، لاَ تَحُجُّ ، وَلاَ تَعْتَمِرُ ، وَلاَ تَلْبَسُ مُجَسِّدًا",,,14866,,
14867,حدَّثَنَا ابْنُ إِدْرِیسَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ حُمَیْدٍ الأَعْرَجِ ، عَنْ مُجَاہِدٍ ؛ أَنَّ عُمَرَ ،وَعُثْمَانَ رَدَّا نِسْوَۃً حَاجَّاتٍ وَمُعْتَمِرَاتٍ ، حَتَّی اعْتَدَدْنَ فِی بُیُوتِہِنَّ۔,,,14867,,
14868,"حدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ؛ فِی صَبِیٍّ أَصَابَ حَمَامَۃً مِنْ حَمَامِ الْحَرَمِ، فَقَالَ : اذْبَحْ عَنِ ابْنِکَ شَاۃً",,,14868,,
14869,"حدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ أَبِیہِ ، قَالَ : قدِمْنَا وَنَحْنُ غِلْمَانٌ مَعَ حَفْصِ بْنِ عَاصِمٍ ، فَأَخَذْنَا فَرْخًا بِمَکَّۃَ فِی مَنْزِلِنَا ، فَلَعِبنَا وَعَبَثْنا بِہِ حَتَّی قَتَلْنَاہُ ، فَقَالَتْ لَہُ أمْرَأَتُہُ عَائِشَۃُ ابْنَۃُ مُطِیعُ بْنُ الأَسْوَدِ ، فَأَمَرَ بِکَبْشٍ فَذُبِحَ ، فَتَصَدَّقَ بِہِ۔",,,14869,,
14870,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، قَالَ : عَبَثَ بَعْضُ بَنِی عُرْوَۃَ بِفَرْخٍ مِنْ حَمَامِ مَکَّۃَ ، فَأَمَرَ أَبِی بِشَاۃٍ فَذُبِحَتْ ، ثُمَّ تَصَدَّقَ بِہَا۔",,,14870,,
14871,"حدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ، قَالَ : إِنْ أَصَابَ شَیْئًا مِنَ الصَّیْدِ ، یَعْنِی الصَّبِیَّ ، کَانَ عَلَی الَّذِی یَحُجُّ بِہِ۔",,,14871,,
14872,"حدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : قُلْتُ لَہُ : {وَالْبُدْنَ جَعَلْنَاہَا لَکُمْ مِنْ شَعَائِرِ اللہِ} مَا الْبَدَنَۃُ ؟ قَالَ : الْبَعِیرُ وَالْبَقَرَۃُ۔",,,14872,,
14873,"حدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَمَّنْ سَمِعَ سَعِیدَ بْنَ الْمُسَیَّبِ یَقُولُ : الْبَعِیرُ وَالْبَقَرَۃُ۔",,,14873,,
14874,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، قَالَ : لاَ تَکُونُ الْبُدْنُ إِلاَّ مِنَ الإِبِلِ۔",,,14874,,
14875,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : قَالَ الْقَاسِمُ بْنُ مُحَمَّدٍ : إِنَّ الشَّاۃَ لَنْ تَعْدُوَ أَنْ تَکُونَ نَسِیکَۃ ، وَإِنَّ الْبَقَرَۃَ مِنَ الْبُدْنِ",,,14875,,
14876,"حدَّثَنَا وَکِیعٌ ، عَنْ أَبِیہِ ، عَنْ عَبْدِ الْکَرِیمِ ، قَالَ : اخْتَلَفَ عَطَائٌ ، وَالْحَکَمُ ، فَقَالَ عَطَائٌ : ہِیَ مِنَ الإِبِلِ وَالْبَقَرِ ، وَقَالَ الْحَکَمُ : ہِیَ مِنَ الإِبِلِ",,,14876,,
14877,"حدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ زَیْدٍ ، عَنْ سُلَیْمَانَ بْنِ یَعْقُوبَ ، عَنْ أَبِیہِ ، قَالَ : مَاتَ رَجُلٌ مِنَ الْحَیِّ وَأَوْصَی أَنْ یُنْحَرَ عَنْہُ بَدَنَۃٌ ، فَسَأَلْتُ ابْنَ عَبَّاسٍ عَنِ الْبَقَرَۃِ ؟ فَقَالَ : تُجْزِء ، قَالَ : قُلْتُ : مِنْ أَیٍّ قَوْمٍ أَنْتَ ؟ قَالَ : قُلْتُ : مِنْ بَنِی رَبَاحٍ ، قَالَ : وَأَنَّی لِبَنِی رَبَاحٍ الْبَقَرُ ؟ إِنَّمَا الْبَقَرُ لِلأَزْدِ ، وَعَبْدِ الْقَیسِ۔",,,14877,,
14878,"حدَّثَنَا وَکِیعٌ ، عَنِ الأَوْزَاعِیِّ ، عَنْ رَجُلٍ لَمْ یَکُنْ یُسَمِّیہِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَوْفٍ ؛ أَنَّہُ کَانَ یَطُوفُ مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ لَہُ : کَمْ تَعُدُّ ؟ ثُمَّ قَالَ : إِنَّمَا سَأَلْتُکَ لِتَحْفَظَ۔",,,14878,,
14879,"حدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ صَالِحِ بْنِ دِرْہَمٍ ، قَالَ : سَمِعْتُ عبْدَ اللہِ بْنَ عُمَرَ ، وَسُئِلَ عَنِ السَّعْیِ بَیْنَ الصَّفَا وَالْمَرْوَۃِ ؟ فَقَالَ ابْنُ عُمَرَ لِلسَّائِلِ : افْتَتِحْ بِالصَّفَا وَاخْتُمْ بِالْمَرْوَۃِ ، فَإِنْ خَشِیتَ أَنْ لاَ تُحْصِیَ ، فَخُذْ مَعَک أَحْجَارًا ، أَوْ حَصَیَاتٍ ، فَأَلْقَ بِالصَّفَا وَاحِدَۃً وَبِالْمَرْوَۃِ أُخْرَی۔",,,14879,,
14880,حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی بِشْرٍ ؛ أَنَّ سَعِیدَ بْنَ جُبَیْرٍ رَأَی امْرَأَۃً تَطُوفُ بِیَدِہَا حَصَیَاتٌ تَعُدُّ الطَّوَافَ ، فَضَرَبَ یَدَہَا,,,14880,,
14881,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی الْہَیْثُمِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کُنَّا نَطُوفُ وَعَلَیْنَا خَوَاتِمُنَا ، نَحْفَظُ بِہَا الأَسْبَاعَ۔",,,14881,,
14882,"حدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ إِبْرَاہِیمَ بْنِ أَبِی حَبِیبَۃَ ، عَنْ دَاوُدَ بْنِ الْحُصَیْنِ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ تَرْفَعُ الْمَرْأَۃُ صَوْتَہَا بِالتَّلْبِیَۃِ",,,14882,,
14883,حدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ أَبِی الْجُوَیْرِیَۃِ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ؛ مِثْلَہُ۔,,,14883,,
14884,"حدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ تَجْہَرُ الْمَرْأَۃُ بِالتَّلْبِیَۃِ۔",,,14884,,
14885,"حدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، عَنْ أَبِیہِ ، قَالَ : خَرَجَ مُعَاوِیَۃُ لَیْلَۃَ النَّفْرِ فَسَمِعَ صَوْتَ تَلْبِیَۃٍ ، فَقَالَ : مَنْ ہَذَا ؟ قَالُوا : عَائِشَۃُ ، اعْتَمَرَتْ مِنَ التَّنْعِیمِ ، فَذُکِرَ ذَلِکَ لِعَائِشَۃَ ، فَقَالَتْ : لَوْ سَأَلَنِی لأَخْبَرْتُہُ۔",,,14885,,
14886,"حدَّثَنَا عُمَرُ ، عَنْ عِیسَی بْنِ أَبِی عِیسَی ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : لَیْسَ عَلَی النِّسَائِ أَنْ یَرْفَعْنَ أَصْوَاتَہُنَّ بِالتَّلْبِیَۃِ۔",,,14886,,
14887,"حدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ یَزِیدَ بْنِ عَبْدِ الْمَلِکِ ، عَنِ الْمُغِیرَۃِ بْنِ نَوْفَلٍ ، عَنْ عَبْدِ الرَّحْمَنِ الأَعْرَجِ ، قَالَ : سُئِلَ أُبَیّ بْنُ کَعْبٍ : ہَلْ یُزَرِّرُ الْمُحْرِمُ عَلَیْہِ طَیْلَسَانًا ؟ قَالَ : لاَ۔",,,14887,,
14888,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَمِعْتُ قَتَادَۃَ یُحَدِّثُ عَنْ یُونُسَ بْنِ جُبَیْرٍ ؛ فِی الطَّیْلَسَانِ الْمُزَرَّرِ لِلْمُحْرِمِ ، قَالَ : یَنْزِعُ أَزْرَارَہُ۔",,,14888,,
14889,"حدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ مُحَمَّدِ بْنِ أَبِی إِسْمَاعِیلَ ، قَالَ : سُئِلَ سَعِیدُ بْنُ جُبَیْرٍ عَنِ الطَّیْلَسَانِ ، یَزرَّہُ الْمُحْرِمُ ؟ فَقَالَ : لاَ تَزْرُرْہُ عَلَیْکَ ، وَلاَ بَأْسَ بِالطَّیْلَسَانِ",,,14889,,
14890,"حدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ، عَنِ ابْنِ سُوقَۃَ، قَالَ: رَأَی عَلَیَّ سَعِیدُ بْنُ جُبَیْرٍ طَیْلَسَانًا، کَأَنَّ فِیہِ أَزْرَارَ دِیبَاجٍ نَزَعْتُہَا ، فَقَالَ : لِمَ نَزَعْتَہَا ؟ فَقُلْتُ لَہُ : قَالَ لِی أَصْحَابِی : أَتَلْبَسُ ہَذَا وَأَنْتَ مُحْرِمٌ ، فَقَالَ : وَمَا یَضُرُّک۔",,,14890,,
14891,حدَّثَنَا مُحَمَّدُ بْنُ سَوَّائٍ ، عَنْ سَعِیدِ بْنِ أَبِی عَرُوبَۃَ ، عَنْ بُرْدٍ ، عَنْ عَطَائٍ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا بِالطَّیْلَسَانِ لِلْمُحْرِمِ ، مَا لَمْ یَزُرَّہُ عَلَیْہِ۔,,,14891,,
14892,حدَّثَنَا مُحَمَّدُ بْنُ سَوَّائٍ ، عَنْ سَعِیدٍ ؛ أَنَّ الْحَسَنَ کَانَ لاَ یَرَی بِہِ بَأْسًا۔,,,14892,,
14893,حدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یُحْرِمُ فِی الطَّیْلَسَانِ ، أَزْرَارُہُ الدِّیبَاجُ ، وَلاَ یَزُرُّہُ عَلَیْہِ۔,,,14893,,
14894,"حدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ؛ فِی الْمُحْرِمِ یَلْبَسُ الطَّیْلَسَانَ ، قَالَ : یَلْبَسُہُ ، وَلاَ یَزُرُّہُ عَلَیْہِ۔",,,14894,,
14895,حدَّثَنَا وَکِیعٌ ، عَنْ عُمَرَ بْنِ ذَرٍّ ، عَنْ أَبِیہِ ؛ أَنْ سَعِیدِ بْنِ جُبَیْرٍ کَانَ یُحْرِمُ فِی الطَّیْلَسَانِ المُدَبجِ ، وَأَنَّ أَبِی کَانَ یَفْعَلُہُ۔,,,14895,,
14896,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : یُحْرِمُ فِی الطَّیْلَسَانِ ، وَلاَ یَزُرُّہُ عَلَیْہِ۔",,,14896,,
14897,"حدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : لاَ بَأْسَ أَنْ یُحْرِمَ فِیہِ ، وَلاَ یَزُرَّہُ عَلَیْہِ۔",,,14897,,
14898,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ مُجَاہِدٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَکَّۃُ حَرَمٌ حَرَّمَہَا اللَّہُ تَعَالَی ، لاَ یَحِلَّ بَیْعُ رِبَاعِہَا ، وَلاَ إِجَارَۃُ بُیُوتِہَا۔",,,14898,,
14899,"حدَّثَنَا شَرِیکٌ ، عَنْ إِبْرَاہِیمَ بْنِ الْمُہَاجِرِ ، عَنْ مُجَاہِدٍ ، قَالَ : بُیُوتُ مَکَّۃَ لاَ تَحِلُّ إِجَارَتُہَا۔",,,14899,,
14900,حدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ؛ أَنَّہُ کَانَ یَکْرَہُ أُجُورَ بُیُوتِ مَکَّۃَ۔,,,14900,,
14901,"حدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ لَیْثٍ ، عَنِ الْقَاسِمِ، قَالَ: مَنْ أَکَلَ شَیْئًا مِنْ کِرَائِ مَکَّۃَ ، فَإِنَّمَا یَأْکُلُ نَارًا",,,14901,,
14902,"حدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَنَا قَرَأْتُ کِتَابَ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ عَلَی النَّاسِ بِمَکَّۃَ ، یَنْہَاہُمْ عَنْ کِرَائِ بُیُوتِ مَکَّۃَ وَدُورِہَا",,,14902,,
14903,"حدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ عُبَیْدِ اللہِ بْنِ أَبِی زِیَادٍ ، عَنِ أَبِی نَجِیحٍ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو قَالَ : الَّذِینَ یَأْکُلُونَ أُجُورَ بُیُوتِ مَکَّۃَ إنَّمَا یَأْکُلُونَ فِی بُطُونِہِمْ نَارًا۔",,,14903,,
14904,"حدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : کَانَ عُمَرُ یَمْنَعُ أَہْلَ مَکَّۃَ أَنْ یَجْعَلُوا لَہَا أَبْوَابًا ، حَتَّی یَنْزِلَ الْحَاجُّ فِی عَرَصَاتِ الدُّورِ",,,14904,,
14905,"حدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، قَالَ : لَمْ یَکُنْ لِلدُّورِ بِمَکَّۃَ أَبْوَابٌ ، کَانَ أَہْلُ مِصْرَ وَأَہْلُ الْعِرَاقِ یَأْتُونَ بِفُطْرَاتِہِمْ فَیَدْخُلُونَ دُورَ مَکَّۃَ",,,14905,,
14906,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ ہِشَامٍ بن حُجَیْرٍ ، قَالَ : کَانَ لِی بَیْتٌ بِمَکَّۃَ فَکُنْتُ أَکْرِیہِ ، فَسَأَلْتُ طَاوُوسًا ؟ فَأَمَرَنِی أَنْ آکُلَہُ۔",,,14906,,
14907,"حدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ عُمَرَ بْنِ سَعِیدِ بْنِ أَبِی حُسَیْنٍ ، قَالَ : أَخْبَرَنِی مَنْ سَمِعَ مُجَاہِدًا یَقُولُ : لاَ أَرَی بِکِرَائِ بُیُوتِ مَکَّۃَ بَأْسًا ، إِلاَّ أَنْ یَتَکَارَی رَجُلٌ فَیَتَرَبَّحَ۔",,,14907,,
14908,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ سَوَّارٍ ، عَنِ الْوَلِیدِ بْنِ أَبِی ہِشَامٍ ، قَالَ : قَالَ عُثْمَانُ : رِبَاعِی الَّتِی بِمَکَّۃَ یَسْکُنُہَا بَنِیَّ ، وَیُسْکِنُونَہَا مَنْ أَحَبَّوا",,,14908,,
14909,"حدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، وَعَطَائٍ ، وَطَاوُوسٍ ، قَالَ : کَانُوا یَکْرَہُونَ أَنْ یَبِیعُوا شَیْئًا مِنْ رِبَاعِ مَکَّۃَ۔",,,14909,,
14910,"حدَّثَنَا شَرِیکٌ ، عَنْ إِبْرَاہِیمَ بْنِ مُہَاجِرٍ ، عَنْ مُجَاہِدٍ ، قَالَ : لاَ یَحِلُّ بَیْعُ رِبَاعِہَا۔",,,14910,,
14911,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ مُجَاہِدٍ ، رَفَعَہُ ، قَالَ : لاَ یَحِلُّ بَیْعُ رِبَاعِہَا۔",,,14911,,
14912,"حدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ عُمَرَ بْنِ سَعِیدِ بْنِ أَبِی حُسَیْنٍ ، عَنْ عُثْمَانَ بْنِ أَبِی سُلَیْمَانَ ، عَنْ عَلْقَمَۃَ بْنِ نَضْلَۃَ ، قَالَ : کَانَتْ رِبَاعُ مَکَّۃَ فِی زَمَانِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَزَمَانِ أَبِی بَکْرٍ ، وَعُمَرَ تُسَمَّی السَّوَائِبُ ، مَنِ احْتَاجَ سَکَنَ ، وَمَنِ اسْتَغْنَی أَسْکَنَ۔ (ابن ماجہ 3107",,,14912,,
14913,"حدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ اعْتَمَرَ عَامَ الْفَتْحِ مِنَ الْجِعْرَانَۃِ ، فَلَمَّا فَرَغَ مِنْ عُمْرَتِہِ اسْتَخْلَفَ أَبَا بَکْرٍ عَلَی مَکَّۃَ ، وَأَمَرَہُ أَنْ یُعَلِّمَ النَّاسَ الْمَنَاسِکَ ، وَأَنْ یُؤَذِّنَ فِی النَّاسِ : مَنْ حَجَّ الْعَامَ فَہُوَ آمِنٌ ، وَلاَ یَحُجُّ بَعْدَ الْعَامِ مُشْرِکٌ ، وَلاَ یَطُوفُ بِالْبَیْتِ عُرْیَانٌ",,,14913,,
14914,"حدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ سَالِمِ بْنِ أَبِی الْجَعْدِ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : جَائَ أَعْرَابِیٌّ إِلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : السَّلاَمُ عَلَیْک یَا غُلاَمَ بَنِی عَبْدِ الْمُطَّلِبِ ، فَقَالَ : وَعَلَیْکَ ، فَقَالَ : إِنِّی رَجُلٌ مِنْ أَخْوَالِکَ مِنْ بَنِی سَعْدِ بْنِ بَکْرٍ ، وَإِنِّی رَسُولُ قَوْمِی إِلَیْک وَوَافِدُہُمْ ، وَإِنِّی سَائِلُکَ فَمُشْتَدَّۃٌ مَسْأَلَتِی إِیَّاکَ ، وَمُنَاشِدُکَ فَمُشْتَدَّۃٌ مُنَاشَدَتِی إِیَّاکَ ، قَالَ : خُذْ عَنْکَ یَا أَخَا بَنِی سَعْدٍ ، قَالَ : فَإِنَّا وَجَدْنَا فِی کِتَابِکَ ، وَأَمَرَتْنَا رُسُلُکَ أَنْ نَحُجَّ الْبَیْتَ الْعَتِیقَ ، فَأُنْشِدُکَ ، أَہُوَ أَمَرَکَ بِذَلِکَ ؟ قَالَ : نَعَمْ۔\n\n(دارمی 651۔ بیہقی 4)",,,14914,,
14915,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ مُحَارِبٍ ، عَنِ ابْنِ بُرَیْدَۃَ ، قَالَ : وَرَدْنَا الْمَدِینَۃَ ، فَأَتَیْنَا عَبْدَ اللہِ بْنَ عُمَرَ ، فَقَالَ : کُنَّا عِنْدَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَأَتَاہُ رَجُلٌ جَیِّدُ الثِّیَابِ ، طَیِّبُ الرِّیحِ، حَسَنُ الْوَجْہِ ، فَقَالَ : السَّلاَمُ عَلَیْک یَا رَسُولَ اللہِ ، فَقَالَ : وَعَلَیْک ، فَقَالَ : یَا رَسُولَ اللہِ ، أَدْنُو مِنْک ؟ فَقَالَ: اُدْنُہْ ، فَدَنَا دَنْوَۃً ، فَقُلْنَا : مَا رَأَیْنَا کَالْیَوْمِ قَطُّ رَجُلاً أَحْسَنَ ثَوْبًا ، وَلاَ أَطْیَبَ رِیحًا ، وَلاَ أَحْسَنَ وَجْہًا، وَلاَ أَشَدَّ تَوْقِیرًا لِرَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، ثُمَّ قَالَ : یَا رَسُولَ اللہِ ، أَدْنُو مِنْکَ ؟ قَالَ : نَعَمْ ، فَدَنَا دَنْوَۃً ، فَقُلْنَا مِثْلَ مَقَالَتِنَا ، ثُمَّ قَالَ لَہُ الثَّالِثَۃَ : أَدْنُو مِنْکَ یَا رَسُولَ اللہِ ؟ قَالَ : نَعَمْ ، حَتَّی أَلْزَقَ رُکْبَتَیْہِ بِرُکْبَۃِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : قَالَ : یَا رَسُولَ ، مَا الإِسْلاَمُ ؟ قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : تُقِیمُ الصَّلاَۃَ ، وَتُؤْتِی الزَّکَاۃَ ، وَتَصُومُ رَمَضَانَ ، وَتَحُجُّ الْبَیْتَ ، وَتَغْتَسِلُ مِنَ الْجَنَابَۃِ ، قَالَ : صَدَقْتَ ، فَقُلْنَا : مَا رَأَیْنَا کَالْیَوْمِ قَطُّ رَجُلاً ، وَاللَّہِ لَکَأَنَّہُ یُعَلِّمُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔ (احمد 1/53)",,,14915,,
14916,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ رَجُلاً أَتَاہُ ، فَقَالَ : یَا أَبَا عَبَّاسٍ ، أَبْدَأُ بِالصَّفَا قَبْلَ الْمَرْوَۃِ ، أَوْ بِالْمَرْوَۃِ قَبْلَ الصَّفَا ؟ أَوْ أُصَلِّی قَبْلَ أَنْ أَطُوفَ ، أَوْ أَطُوفَ قَبْلَ أَنْ أُصَلِّیَ ؟ أَوْ أَذْبَحَ قَبْلَ أَنْ أَحْلِقَ ، أَوْ أَحْلِقَ قَبْلَ أَنْ أَذْبَحَ ؟ فَقَالَ ابْنُ عَبَّاسٍ : خُذْ ذَلِکَ مِنْ قِبَلِ الْقُرْآنِ ، فَإِنَّہُ أَجْدَرُ أَنْ تُحْفَظَ ، قَالَ اللَّہُ تَعَالَی : (إِنَّ الصَّفَا وَالْمَرْوَۃَ مِنْ شَعَائِرِ اللہِ) فَالصَّفَا قَبْلَ الْمَرْوَۃِ ، وَقَالَ تَبَارَکَ وَتَعَالَی : (وَلاَ تَحْلِقُوا رُؤُوسَکُمْ حَتَّی یَبْلُغَ الْہَدْیُ مَحِلَّہُ) فَقَالَ : بِالذَّبْحِ قَبْلَ الْحَلْقِ ، وَقَالَ : (طَہِّرَا بَیْتِی لِلطَّائِفِینَ وَالْعَاکِفِینَ وَالرُّکَّعِ السُّجُودِ) ، فَالطَّوَافُ قَبْلَ الصَّلاَۃِ۔",,,14916,,
14917,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ زَکَرِیَّا ، عَنْ أَبِی إِسْحَاقَ ، عَنْ زَیْدِ بْنِ یُثَیْعٍ ، عَنْ عَلِیٍّ ، قَالَ : بَعَثَنِی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حِینَ أُنْزِلَتْ بَرَائَۃٌ بِأَرْبَعٍ : أَنْ لاَ یَطُوفَ بِالْبَیْتِ عُرْیَانٌ ، وَلاَ یَقْرَبَ الْمَسْجِدَ مُشْرِکٌ بَعْدَ عَامِہِمْ ہَذَا ، وَمَنْ کَانَ بَیْنَہُ وَبَیْنَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَہْدٌ فَہُوَ إِلَی مُدَّتِہِ ، وَلاَ یَدْخُلُ الْجَنَّۃَ إِلاَّ نَفْسٌ مُسْلِمَۃٌ۔ (احمد 1/79۔ حاکم 178)",,,14917,,
14918,"حدَّثَنَا وَکِیعٌ ، عَنْ حُسَیْنِ بْنِ عُقَیْلٍ ، قَالَ : أََمْلَی عَلَیَّ الضَّحَّاکُ مَنَاسِکَ الْحَجِّ۔",,,14918,,
14919,"حدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ حُسَیْنِ بْنِ عُقَیْلٍ ، قَالَ : أََمْلَی عَلَیَّ الضَّحَّاکُ مَنَاسِکَ الْحَجِّ۔",,,14919,,
14920,"حدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَتَی جِبْرِیلُ إِبْرَاہِیمَ عَلَیْہِمَا السَّلاَم ، فَرَاحَ بِہِ إِلَی مِنًی ، فَصَلَّی بِہِ الصَّلَوَاتِ جَمِیعًا ، ثُمَّ صَلَّی بِہِ الْفَجْرَ ، ثُمَّ غَدَا بِہِ إِلَی عَرَفَۃَ ، فَنَزَلَ بِہِ حَیْثُ یَنْزِلُ النَّاسُ ، ثُمَّ صَلَّی بِہِ الصَّلاَتَیْنِ جَمِیعًا ، ثُمَّ أَتَی بِہِ الْمَوْقِفَ ، حَتَّی إِذَا کَانَ کَأَعْجَلِ مَا یُصَلِّی الإِنْسَانُ الْمَغْرِبَ أَفَاضَ بِہِ ، فَأَتَی جَمْعًا فَصَلَّی بِہِ الصَّلاَتَیْنِ جَمِیعًا ، ثُمَّ بَاتَ بِہَا حَتَّی إِذَا کَانَ کَأَعْجَلِ مَا یُصَلِّی أَحَدٌ مِنَ النَّاسِ الْفَجْرَ صَلَّی بِہِ ، ثُمَّ وَقَفَ حَتَّی إِذَا کَانَ کَأَبْطَأِ مَا یُصَلِّی أَحَدٌ مِنَ النَّاسِ الْفَجْرَ ، أَفَاضَ بِہِ إِلَی مِنًی ، فَرَمَی الْجَمْرَۃَ ، ثُمَّ ذَبَحَ وَحَلَقَ ، ثُمَّ أَفَاضَ بِہِ ، ثُمَّ أَوْحَی اللَّہُ تَعَالَی بَعْدُ إِلَی نَبِیِّہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : {أَنِ اتَّبِعْ مِلَّۃَ إِبْرَاہِیمَ حَنِیفًا}۔ (ابن خزیمۃ 2804)",,,14920,,
14921,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی مِجْلَزٍ ؛ فِی قولہ تعالی : {وَإِذْ یَرْفَعُ إبْرَاہِیمُ الْقَوَاعِدَ مِنَ الْبَیْتِ وَإِسْمَاعِیلُ} قَالَ : لَمَّا فَرَغَ مِنَ البَیتِ جَائَہُ جِبْرِیلُ عَلَیْہِ السَلاَم ، فَأَرَاہُ الطَّوَافَ بِالْبَیْتِ ، وَأَحْسَبُہُ قَالَ : وَالصَّفَا وَالْمَرْوَۃَ ، ثُمَّ انْطَلَقَا إِلَی الْعَقَبَۃِ فَعَرَضَ لَہُمَا الشَّیْطَانُ ، قَالَ : فَأَخَذَ جِبْرِیلُ عَلَیْہِ السَلاَم سَبْعَ حَصَیَاتٍ ، وَأَعْطَی إبْرَاہِیمَ عَلَیْہِ السَلاَم سَبْعَ حَصَیَاتٍ ،فَرَمَی وَکَبَّرَ ، وَقَالَ لإِبْرَاہِیمَ : اِرْمِ وَکَبِّرْ ، قَالَ : فَرَمَیَا وَکَبَّرَا مَعَ کُلِّ رَمْیَۃٍ ، حَتَّی أَفَلَ الشَّیْطَانُ ، ثُمَّ انْطَلَقَا إِلَی الْجَمْرَۃِ الْوُسْطَی ، فَعَرَضَ لَہُمَا الشَّیْطَانُ ، فَأَخَذَ جِبْرِیلُ عَلَیْہِ السَلاَم سَبْعَ حَصَیَاتٍ ، وَأَعْطَی إِبْرَاہِیمَ عَلَیْہِ السَلاَم سَبْعَ حَصَیَاتٍ ، فَرَمَیَا وَکَبَّرَا مَعَ کُلِّ رَمْیَۃٍ حَتَّی أَفَلَ الشَّیْطَانُ ۔ ثُمَّ أَتَیَا الْجَمْرَۃَ الْقُصْوَی ، قَالَ : فَعَرَضَ لَہُمَا الشَّیْطَانُ ، قَالَ : فَأَخَذَ جِبْرِیلُ عَلَیْہِ السَلاَم سَبْعَ حَصَیَاتٍ ، وَأَعْطَی إبْرَاہِیمَ عَلَیْہِ السَلاَم سَبْعَ حَصَیَاتٍ ، وَقَالَ : اِرْمِ وَکَبِّرْ ، فَرَمَیَا وَکَبَّرَا مَعَ کُلِّ رَمْیَۃٍ ، حَتَّی أَفَلَ الشَیطَان ۔ ثُمَّ أَتَی بِہِ إِلیَ مِنًی ، فَقَالَ : ہَاہُنَا یَحْلِقُ النَّاسُ رُؤُوسَہُمْ ، ثُمَّ أَتَی بِہِ جَمْعًا ، فَقَالَ : ہَاہُنَا یَجْمَعُ النَّاسُ الصَّلاَۃَ ، ثُمَّ أَتَی بِہِ عَرَفَاتٍ ، فَقَالَ : عَرَفْتَ ؟ قَالَ : نَعَمْ ، قَالَ : فَمِنْ ثُمَّ سُمِّیَتْ عَرَفَاتٍ",,,14921,,
14922,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا دَاوُد بْنُ أَبِی ہِنْدٍ ، عَنْ مُحَمَّدِ بْنِ أَبی مُوسَی ؛ فِی قَوْلِہِ تَعَالَی : {وَمَنْ یُعَظِّمْ شَعَائِرَ اللہِ فَإِنَّہَا مِنْ تَقْوَی الْقُلُوبِ} ، قَالَ : الْوُقُوفُ بِعَرَفَۃَ مِنْ شَعَائِرِ اللہِ ، وَبِجَمْع مِنْ شَعَائِرِ اللہِ ، وَالْجِمَارُ مِنْ شَعَائِرِ اللہِ ، وَالْبُدْنُ مِنْ شَعَائِرِ اللہِ ، وَالْحَلْقُ مِنْ شَعَائِرِ اللہِ ، فَمَنْ یُعَظِّمْہَا فَإِنَّہَا مِنْ تَقْوَی الْقُلُوبِ ۔ قَالَ : وَفِی قَوْلِہِ تَعَالَی : {لَکُمْ فِیہَا مَنَافِعُ إِلَی أَجَلٍ مُسَمًّی} ، قَالَ : لَکُمْ فِی کُلِّ مَشْعَرٍ مَنَافِعُ ، إِلَی أَنْ تَخْرُجُوا مِنْہُ إِلَی غَیْرِہِ ، فَالأَجَلُ الْمُسَمَّی : الْخُرُوجُ مِنْہُ إِلَی غَیْرِہِ ، {ثُمَّ مَحِلُّہَا إِلَی الْبَیْتِ الْعَتِیقِ} قَالَ : مَحِلُّ ہَذِہِ الشَّعَائِرِ کُلِّہَا ، الطَّوَافُ بِالْبَیْتِ۔",,,14922,,
14923,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ؛ {وَاتَّخِذُوا مِنْ مَّقَامِ إِبْرَاہِیمَ مُصَلًّی} قَالَ : ہُوَ الْحَجُّ کُلُّہُ۔",,,14923,,
14924,"حدَّثَنَا إِسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ : کَانَ مَعَ ابْنِ عُمَرَ ، فَلَمَّا طَلَعَتِ الشَّمْسُ أَمَرَ بِرَاحِلَتِہِ فَرُحِلَتْ وَارْتَحَلَ مِنْ مِنًی فَسَارَ ، قَالَ : فَإِنْ کَانَ لأَعْجَبُنَا إِلَیْہِ أَسْفَہُنَا ، رَجُلٌ کَانَ یُحَدِّثُہُ عَنِ النِّسَائِ وَیُضْحِکُہُ ، قَالَ : فَلَمَّا صَلَّی الْعَصْرَ وَقَفَ بِعَرَفَۃَ ، فَجَعَلَ یَرْفَعُ یَدَیْہِ ، أَو قَالَ : یَمُدُّ ، قَالَ : وَلاَ أَدْرِی لَعَلَّہُ قَدْ قَالَ : دُونَ أُذُنَیْہِ ، وَجَعَلَ یَقُولُ : اللَّہُ أَکْبَرُ وَلِلَّہِ الْحَمْدُ ، اللَّہُ أَکْبَرُ وَلِلَّہِ الْحَمْدُ ، اللَّہُ أَکْبَرُ وَلِلَّہِ الْحَمْدُ ، لاَ إلَہَ إِلاَّ اللَّہُ وَحْدَہُ ، لَہُ الْمُلْکُ وَلَہُ الْحَمْدُ ، اللَّہُمَّ اہْدِنِی بِالْہُدَی ، وَقِنِی بِالتَّقْوَی ، وَاغْفِرْ لِی فِی الآخِرَۃِ وَالأُولَی ، ثُمَّ یَرُدُّ یَدَیْہِ فَیَسْکُتُ کَقَدْرِ مَا کَانَ إِنْسَانٌ قَارِئًا بِفَاتِحَۃِ الْکِتَابِ ، ثُمَّ یَعُودُ فَیَرْفَعُ یَدَیْہِ وَیَقُولُ مِثْلَ ذَلِکَ ، فَلَمْ یَزَلْ یَفْعَلُ ذَلِکَ حَتَّی أَفَاضَ ۔ قَالَ : فَکَانَ سَیْرُہُ إِذَا رَأَی سَعَۃً الْعَنَقَ ، وَإِذَا رَأَی مَضِیقًا أَمْسَکَ ، وَإِذَا أَتَی جَبَلاً مِنْ تِلْکَ الْجِبَالِ وَقَفَ عِنْدَ کُلِّ جَبَلٍ مِنْہَا کَقَدْرِ مَا أَقُولُ ، أَوْ یَقُولُ الْقَائِلُ : وَقِفَتْ یَدَاہَا وَلَمْ تَقِفْ رِجْلاَہَا ، قَالَ : ثُمَّ نَزَلَ مَنْزِلَہُ بِالطَّرِیقِ ، فَانْطَلَقَ وَاتَّبَعْتُہُ فَقُلْتُ : لَعَلَّہُ یَفْعَلُ شَیْئًا مِنَ السُّنَّۃِ ، فَقَالَ : إِنَّمَا أَذْہَبُ حَیْثُ تَعْلَمُ ، فَجَائَ فَتَوَضَّأَ عَلَی رِسْلِہِ ، ثُمَّ رَکِبَ ، وَلَمْ یُصَلِّ حَتَّی أَتَی جَمْعًا ، فَأَقَامَ فَصَلَّی الْمَغْرِبَ ، ثُمَّ انْفَتَلَ إِلَیْنَا ، فَقَالَ : الصَّلاَۃُ جَامِعَۃٌ ، وَلَمْ یَتَجَوَّزْ بَیْنَہُمَا بِشَیْئٍ ۔ قُلتُ : وَلَمْ یَکُن بَیْنَہُمَا إِقَامَۃً إِلاَّ قَولَہُ : الصَّلاَۃُ جَامِعَۃٌ ؟ أَو قَالَ : أَذَانٌ إِلاَّ ذَاکَ ؟ قَالَ : لاَ ۔ ثُمَّ صَلَّی الْعِشَائَ رَکْعَتَیْنِ ، فَصَلَّی خَمْسَ رَکَعَاتٍ لِلْمَغْرِبِ وَالْعِشَائِ ، لَمْ یَتَطَوَّعْ ، أَوْ قَالَ : لَمْ یَتَجَوَّزْ بَیْنَہُمَا بِشَیْئٍ ، ثُمَّ دَعَا بِطَعَامٍ ، فَقَالَ : مَنْ کَانَ یَسْمَعُ صَوْتَنَا فَلْیَأْتِنَا ، قَالَ : کَأَنَّہُ یَرَی أَنَّ ذَاکَ کَذَاک یَنْبَغِی ، ثُمَّ بَاتُوا ، ثُمَّ صَلَّی بِنَا الصُّبْحَ بِسَوَادٍ ، وَلَیْسَ فِی السَّمَائِ نَجْمٌ أَعْرِفُہُ إِلاَ أَرَاہُ ، وَقَرَأَ بِـ : (عَبَسَ وَتَوَلَّی) وَلَمْ یَقْنُتْ قَبْلَ الرُّکُوعِ ، وَلاَ بَعْدَہُ ، ثُمَّ وَقَفَ فَذَکَرَ مِنْ دُعَائِہِ فِی ہَذَا الْمَوْقِفِ کَمَا فَعَلَ فِی مَوْقِفِہِ بِالأَمْسِ ، ثُمَّ أَفَاضَ سَیْرَہُ ، إِذَا رَأَی سَعَۃً الْعَنَقَ ، وَإِذَا رَأَی مَضِیقًا أَمْسَکَ ۔ قَالَ : وَکَانَ ابْنُ عَبَّاسٍ أَخْبَرَنِی أَنَّ الْوَادِی الَّذِی بَیْنَ یَدَیْہِ مِنًی الَّذِی یُدْعَی مُحَسِّرًا یُوضَعُ ۔ فَلَمَّا أَتَی عَلَیْہِ رَکَضَ بِرِجْلِہِ ، فَعَرَفْتُ أَنَّہُ أَرَادَ أَنْ یُوضِعَ فَأَعْیَتْہُ رَاحِلَتُہُ فَأَوْضَعْتُہُ ، فَرَمَی الْجَمْرَۃَ ، فَلَمَّا کَانَ الْغَدُ رَمَی الْجَمْرَۃَ ، قَالَ : أَحْسَبُہُ قَالَ لِی : بِہَاجِرَۃٍ ، ثُمَّ تَقَدَّمَ حَتَّی کَانَ بَیْنَہُمَا وَبَیْنَ الْوُسْطَی ، فَذَکَرَ مِنْ دُعَائِہِ مِثْلَ دُعَائِہِ فِی الْمَوْقِفَیْنِ ، إِلاَّ أَنَّہُ زَادَ : وَأَصْلِحْ لِی، أَو قَالَ : وَأَتْمِمْ لَنَا مَنَاسِکَنَا ، قَالَ : وَکَانَ قِیَامُہُ کَقَدْرِ مَا کَانَ إِنْسَانٌ فِیمَا یُرَی قَارِئًا سُورَۃَ یُوسُفَ ، ثُمَّ رَمَی الْجَمْرَۃَ الْوُسْطَی ، ثُمَّ تَقَدَّمَ فَذَکَرَ مِنْ دُعَائِہِ نَحْوَ ذَاکَ ، وَمِنْ قِیَامِہِ نَحْوَ ذَلِکَ ۔ قَالَ : فَقُلْتُ لِسَالِمٍ ، أَوْ نَافِعٍ : ہَلْ کَانَ یَقُولُ فِی سُکُوتِہِ شَیْئًا ؟ قَالَ : أَمَّا مِنَ السُّنَّۃِ ، فَلاَ۔",,,14924,,
14925,"حدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، قَالَ : دَخَلْنَا عَلَی جَابِرِ بْنِ عَبْدِ اللہِ ، فَسَأَلَ عَنْ الْقَوْمِ حَتَّی انْتَہَی إِلَیَّ ، فَقُلْتُ: أَنَا مُحَمَّدُ بْنُ عَلِیِّ بْنِ حُسَیْنٍ، فَأَہْوَی بِیَدِہِ إِلَی رَأْسِی ، فَنَزَعَ زِرِّی الأَعْلَی، ثُمَّ نَزَعَ زِرِّی الأَسْفَلَ ، ثُمَّ وَضَع کَفَّہُ بَیْنَ ثَدْیَیَّ ، وَأَنَا یَوْمئِذٍ غُلاَمٌ شَابٌّ ، فَقَالَ : مَرْحَبًا بِکَ یَا ابْنَ أَخِی ، سَلْ عَمَّ شِئْتَ ؟ فَسَأَلْتُہُ وَہُوَ أَعْمَی ، وَجَائَ وَقْتُ الصَّلاَۃِ ، فَقَامَ فِی نِسَاجَۃٍ مُلْتَحِفًا بِہَا ، کُلَّمَا وَضَعَہَا عَلَی مَنْکِبِہِ رَجَعَ طَرَفَاہَا إِلَیْہِ ، مِنْ صِغَرِہَا ، وَرِدَاؤُہُ إِلَی جَنْبِہِ عَلَی الْمِشْجَبِ ، فَصَلَّی بِنَا ، فَقُلْتُ : أَخْبِرْنِی عَنْ حَجَّۃِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ فَقَالَ : بِیَدِہِ ، فَعَقَدَ تِسْعًا ، فَقَالَ : إِنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَکَثَ تِسْعَ سِنِینَ لَمْ یَحُجَّ ، ثُمَّ أَذَّنَ فِی النَّاسِ فِی الْعَاشِرَۃِ : أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَاجًّ ، فَقَدِمَ الْمَدِینَۃَ بَشَرٌ کَثِیرٌ کُلُّہُمْ یَلْتَمِسُ أَنْ یَأْتَمَّ بِرَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَیَعْمَلَ مِثْلَ عَمَلِہِ ، فَخَرَجْنَا مَعَہُ حَتَّی أَتَیْنَا ذَا الْحُلَیْفَۃَ ، فَوَلَدَتْ أَسْمَائُ بِنْتُ عُمَیْسٍ مُحَمَّدَ بْنَ أَبِی بَکْرٍ ، فَأَرْسَلَتْ إِلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی الْمَسْجِدِ ، کَیْفَ أَصْنَعُ ؟ فَقَالَ : اغْتَسِلِی ، وَاسْتَنْفِرِی بِثَوْبٍ ، وَأَحْرِمِی فَصَلَّی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی الْمَسْجِدِ ، فَرَکِبَ الْقَصْوَائَ حَتَّی إِذَا اسْتَوَتْ بِہِ رَاحِلَتَہُ عَلَی الْبَیْدَائِ ، نَظَرْتُ إِلَی مَدَّی بَصَرِی مِنْ بَیْنِ یَدَیْہِ مِنْ رَاکِبٍ وَمَاشٍ ، وَعَنْ یَمِینِہِ مِثْلُ ذَلِکَ ، وَعَنْ یَسَارِہِ مِثْلُ ذَلِکَ ، وَمِنْ خَلْفِہِ مِثْلُ ذَلِکَ ، وَرَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَیْنَ أَظْہُرِنَا وَعَلَیْہِ یَنْزِلُ الْقُرْآنُ ، وَہُوَ یَعْرِفُ تَأْوِیلَہُ ، فَمَا عَمِلَ بِہِ مِنْ شَیْئٍ عَمِلْنَا بِہِ ، فَأَہَلَّ بِالتَّوْحِیدِ : لَبَّیْکَ اللَّہُمَّ لَبَّیْکَ ، لَبَّیْکَ لاَ شَرِیکَ لَکَ لَبَّیْکَ ، إِنَّ الْحَمْدَ وَالنِّعْمَۃَ لَکَ وَالْمُلْکَ ، لاَ شَرِیکَ لَکَ ، وَأَہَلَّ النَّاسُ بِہَذَا الَّذِی یُہِلُّونَ بِہِ ، فَلَمْ یَرُدَّ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَلَیْہِمْ شَیْئًا مِنْہُ ، وَلَزِمَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ تَلْبِیَتَہُ۔ وَقَالَ جَابِرٌ : لَسْنَا نَنْوِی إِلاَّ الْحَجَّ ، لَسْنَا نَعْرِفُ الْعُمْرَۃَ ، حَتَّی إِذَا أَتَیْنَا الْبَیْتَ مَعَہُ اسْتَلَمَ الرُّکْنَ فَرَمَلَ ثَلاَثًا، وَمَشَی أَرْبَعًا ، ثُمَّ نَفَدَ إِلَی مَقَامِ إِبْرَاہِیمَ ، فَقَرَأَ : {وَاِتَّخِذُوا مِنْ مَقَامِ إِبْرَاہِیمَ مُصَلًّی} فَجَعَلَ الْمَقَامَ بَیْنَہُ وَبَیْنَ الْبَیْتِ ، فَکَانَ أَبِی یَقُولُ : وَلاَ أَعْلَمُہُ ذَکَرَہُ إِلاَّ عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، کَانَ یَقْرَأُ فِی الرَّکْعَتَیْنِ : {قُلْ ہُوَ اللَّہُ أَحَدٌ} وَ{قُلْ یَا أَیُّہَا الْکَافِرُونَ} ، ثُمَّ رَجَعَ إِلَی الرُّکْنِ فَاسْتَلَمَہُ ، ثُمَّ خَرَجَ مِنَ الْبَابِ إِلَی الصَّفَا ، فَلَمَّا دَنَا مِنَ الصَّفَا قَرَأَ : {إِنَّ الصَّفَا وَالْمَرْوَۃَ مِنْ شَعَائِرِ اللہِ} أَبْدَأُ بِمَا بَدَأَ اللَّہُ بِہِ ، فَبَدَأَ بِالصَّفَا فَرَقِی عَلَیْہِ حَتَّی رَأَی الْبَیْتَ ، فَاسْتَقْبَلَ الْبَیْتَ ، وَوَحَّدَ اللَّہَ وَکَبَّرَہُ ، وَقَالَ : لاَ إلَہَ إِلاَّ اللَّہُ وَحْدَہُ لاَ شَرِیکَ لَہُ ، لَہُ الْمُلْکُ وَلَہُ الْحَمْدُ ، وَہُوَ عَلَی کُلِّ شَیْئٍ قَدِیرٌ ، لاَ إلَہَ إِلاَّ اللَّہُ وَحْدَہُ ، أَنْجَزَ وَعدَہُ ، وَنَصَرَ عَبْدَہُ ، وَہَزَمَ الأَحْزَابَ وَحْدَہُ ، ثُمَّ دَعَا بَیْنَ ذَلِکَ ، ثُمَّ قَالَ مِثْلَ ذَلِکَ ، ثَلاَثَ مَرَّاتٍ ۔\n\nثُمَّ نَزَلَ إِلَی الْمَرْوَۃِ حتَّی انْصَبَّتْ قَدَمَاہُ إِلَی بَطْنِ الْوَادِی ، حَتَّی إِذَا صَعِدْنَا مَشَی حَتَّی أَتَی الْمَرْوَۃَ ، فَفَعَلَ عَلَی الْمَرْوَۃِ کَمَا فَعَلَ عَلَی الصَّفَا ، حَتَّی إِذَا کَانَ آخِرُ طَوَافِہِ عَلَی الْمَرْوَۃِ ، قَالَ : إِنِّی لَوِ اسْتَقْبَلْتُ مِنْ أَمْرِی مَا اسْتَدْبَرْتُ لَمْ أَسُقَ الْہَدْیَ ، وَجَعَلْتُہَا عُمْرَۃً ، فَمَنْ کَانَ مِنْکُمْ لَیْسَ مَعَہُ ہَدْیٌ فَلْیَحِلَّ وَلْیَجْعَلْہَا عُمْرَۃً ، فَقَامَ سُرَاقَۃُ بْنُ جُعْشُمٍ ، فَقَالَ : یَا رَسُولَ اللہِ ، أَلِعَامِنَا ہَذَا ، أَمْ لأَبَدٍ ؟ فَشَبَّکَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَصَابِعَہُ وَاحِدَۃً فِی الأُخْرَی ، وَقَالَ : دَخَلَتِ الْعُمْرَۃُ فِی الْحَجِّ ، مَرَّتَیْنِ ، لاَ ، بَلْ لأَبَدٍ أَبَدٍ ۔ وَقَدِمَ عَلِیٌّ مِنَ الْیَمَنِ بِبُدْنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَوَجَدَ فَاطِمَۃَ مِمَّنْ حَلَّ ، وَلَبِسَتْ ثِیَابًا صَبِیغًا ، وَاکْتَحَلَتْ ، فَأَنْکَرَ ذَلِکَ عَلَیْہَا ، فَقَالَتْ : أَبِی أَمَرَنِی بِہَذَا ، قَالَ : فَکَانَ عَلِیٌّ یَقُولُ بِالْعِرَاقِ : فَذَہَبْتُ إِلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مُحَرِّشًا عَلَی فَاطِمَۃَ لِلَّذِی صَنَعَتْ ، مُسْتَفْتِیًا لِرَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِیمَا ذَکَرَتْ عَنْہُ ، قَالَ : فَأَخْبَرْتُہُ أَنِّی أَنْکَرْتُ ذَلِکَ عَلَیْہَا ، فَقَالَ : صَدَقَتْ صَدَقَتْ ، قَالَ : مَا قُلْتَ حِینَ فَرَضْتَ الْحَجَّ ؟ قَالَ : قُلْتُ : اللَّہُمَّ إِنِّی أُہِلُّ بِمَا أَہَلَّ بِہِ رَسُولُک صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : فَإِنَّ مَعِی الْہَدْیَ فَلاَ تَحِلَّ ، قَالَ : فَکَانَ جَمَاعَۃُ الْہَدْیِ الَّذِی قَدِمَ بِہِ عَلِیُّ مِنَ الْیَمَنِ ، وَالَّذِی أَتَی بِہِ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِئَۃ ، قَالَ : فَحَلَّ النَّاسُ کُلُّہُمْ وَقَصَّرُوا إِلاَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَمَنْ کَانَ مَعَہُ ہَدْیٌ ۔ فَلَمَّا کَانَ یَوْمُ التَّرْوِیَۃِ تَوَجَّہُوا إِلَی مِنًی فَأَہَلُّوا بِالْحَجِّ ، وَرَکِبَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَصَلَّی بِہَا الظُّہْرَ وَالْعَصْرَ ، وَالْمَغْرِبَ وَالْعِشَائَ وَالصُّبْحَ ، ثُمَّ مَکَثَ قَلِیلاً حَتَّی طَلَعَتِ الشَّمْسُ ، وَأَمَرَ بِقُبَّۃٍ مِنْ شَعْرٍ فَضُرِبَتْ لَہُ بِنَمِرَۃَ ، فَسَارَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَلاَ تَشُکَّ قُرَیْشٌ ، إِلاَّ أَنَّہُ وَاقِفٌ عِنْدَ الْمَشْعَرِ الْحَرَامِ ، کَمَا کَانَتْ قُرَیْشٌ تَصْنَعُ فِی الْجَاہِلِیَّۃِ ، فَأَجَازَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَتَّی أَتَی عَرَفَۃَ فَوَجَدَ الْقُبَّۃَ قَدْ ضُرِبَتْ لَہُ بِنَمِرَۃَ ، فَنَزَلَ بِہَا حَتَّی إِذَا زَاغَتِ الشَّمْسُ أَمَرَ بِالْقَصْوَائِ فَرُحِلَتْ لَہُ ، فَأَتَی بَطْنَ الْوَادِی فَخَطَبَ النَّاسَ ، وَقَالَ : إِنَّ دِمَائَکُمْ وَأَمْوَالَکُمْ حَرَامٌ عَلَیْکُمْ ، کَحُرْمَۃِ یَوْمِکُمْ ہَذَا ، فِی شَہْرِکُمْ ہَذَا ، فِی بَلَدِکُمْ ہَذَا ، أَلاَ کُلَّ شَیْئٍ مِنْ أَمْرِ الْجَاہِلِیَّۃِ تَحْتَ قَدَمیَّ مَوْضُوعٌ ، وَدِمَائُ الْجَاہِلِیَّۃِ مَوْضُوعَۃٌ ، وَإِنَّ أَوَّلَ دَمٍ أَضَعُ مِنْ دِمَائِنَا دَمُ ابْنِ رَبِیعَۃَ بْنِ الْحَارِثِ ، کَانَ مُسْتَرْضِعًا فِی بَنِی سَعْدٍ ، فَقَتَلَتْہُ ہُذَیْلٌ ، وَرِبَا أَہْلِ الْجَاہِلِیَّۃِ مَوْضُوعٌ ، وَأَوَّلُ رِبَاً أَضَعُ رِبَانَا ، رِبَا عَبَّاسِ بْنِ عَبْدِ الْمُطَّلِبِ ، فَإِنَّہُ مَوْضُوعٌ کُلُّہُ ، فَاتَّقُوا اللَّہَ فِی النِّسَائِ ، فَإِنَّکُمْ أَخَذْتُمُوہُنَّ بِأَمر اللہِ ، وَاسْتَحْلَلْتُمْ فُرُوجَہُنَّ بِکَلِمَۃِ اللہِ ، وَلَکُمْ عَلَیْہِنَّ أَنْ لاَ یُوطِئْنَ فُرُشَکُمْ أَحَدًا تَکْرَہُونَہُ ، فَإِنْ فَعَلْنَ ذَلِکَ فَاضْرِبُوہُنَّ ضَرْبًا غَیْرَ مُبَرِّحٍ ، وَلَہُنَّ عَلَیْکُمْ رِزْقُہُنَّ وَکِسْوَتُہُنَّ بِالْمَعْرُوفِ ، وَقَدْ تَرَکْتُ فِیکُمْ مَا لَنْ تَضِلُّوا بَعْدَہُ إِنَ اعْتَصَمْتُمْ بِہِ ؛ کِتَابُ اللہِ ، وَأَنْتُمْ تُسْأَلُونَ عَنِّی ، فَمَا أَنْتُمْ قَائِلُونَ ؟ قَالُوا : نَشْہَدُ أَنْ قَدْ بَلَّغْتَ وَأَدَّیْتَ وَنَصَحْتَ ، فَقَالَ : بِإِصْبَعِہِ السَّبَّابَۃِ ، یَرْفَعُہَا إِلَی السَّمَائِ وَیَنْکُتُہَا إِلَی النَّاسِ : اللَّہُمَّ اشْہَدْ ، اللَّہُمَّ اشْہَدْ ، ثَلاَثَ مَرَّاتٍ ، ثُمَّ أَذَّنَ ، ثُمَّ أَقَامَ فَصَّلی الظُّہْرَ ، ثُمَّ أَقَامَ فَصَّلی الْعَصْرَ ، وَلَمْ یُصَلِّ بَیْنَہُمَا شَیْئًا ۔ ثُمَّ رَکِبَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَتَّی أَتَی الْمَوْقِفَ ، فَجَعَلَ بَطْنَ نَاقَتِہِ الْقَصْوَائَ إِلَی الصَّخَرَاتِ ، وَجَعَلَ حَبْلَ الْمُشَاۃِ بَیْنَ یَدَیْہِ ، وَاسْتَقْبَلَ الْقِبْلَۃَ ، فَلَمْ یَزَلْ وَاقِفًا حَتَّی غَرَبَتِ الشَّمْسُ ، وَذَہَبَتِ الصُّفْرَۃُ قَلِیلاً حَتَّی غَابَ الْقُرْصُ ، وَأَرْدَفَ أُسَامَۃَ خَلْفَہُ ، وَدَفَعَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَقَدْ شَنَقَ لِلْقَصْوَائِ الزِّمَامَ ، حَتَّی إِنَّ رَأْسَہَا لَیُصِیبُ مَوْرِکَ رَحْلِہِ ، وَیَقُولُ بِیَدِہِ الْیُمْنَی : أَیُّہَا النَّاسُ ، السَّکِینَۃَ السَّکِینَۃَ ، کُلَّمَا أَتَی حَبْلاً مِنَ الْحِبَالِ أَرْخَی لَہَا قَلِیلاً ، حَتَّی تَصْعَدَہ ۔\n\nحَتَّی أَتَی الْمُزْدَلِفَۃَ فَصَلَّی بِہَا الْمَغْرِبَ وَالْعِشَائَ بِأَذَانٍ وَاحِدٍ وَإِقَامَتَیْنِ ، وَلَمْ یُسَبِّحْ بَیْنَہُمَا شَیْئًا ، ثُمَّ اضْطَجَعَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَتَّی طَلَعَ الْفَجْرُ ، وَصَلَّی حِینَ تَبَیَّنَ لَہُ الصُّبْحُ بِأَذَانٍ وَإِقَامَۃٍ ، ثُمَّ رَکِبَ الْقَصْوَائَ حَتَّی أَتَی الْمَشْعَرَ الْحَرَامَ ، فَاسْتَقْبَلَ الْقِبْلَۃَ ، فَدَعَاہُ وَکَبَّرَہُ وَہَلَّلَہُ وَوَحَّدَہُ ، فَلَمْ یَزَلْ وَاقِفًا حَتَّی أَسْفَرَ جِدًّا ، فَدَفَعَ قَبْلَ أَنْ تَطْلُعَ الشَّمْسُ ، وَأَرْدَفَ الْفَضْلَ بْنَ عَبَّاسٍ وَکَانَ رَجُلاً حَسَنَ الشَّعْرِ ، أَبْیَضَ وَسِیمًا ۔ فَلَمَّا دَفَعَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَرَّتْ ظُعُنٌ یَجْرِینَ ، فَطَفِقَ الْفَضْلُ یَنْظُرُ إِلَیْہِنَّ ، فَوَضَعَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَدَہُ عَلَی وَجْہِہِ ، فَحَوَّلَ الْفَضْلُ وَجْہَہُ إلَی الشِّقِّ الآخَرِ یَنْظُرُ ، فَحَوَّلَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَدَہُ مِنَ الشِّقِّ الآخَرِ عَلَی وَجْہِ الْفَضْلِ ، فَصْرِفُ وَجْہَہُ مِنَ الشِّقِّ الآخَرِ یَنْظُرُ ، حَتَّی أَتَی مُحَسِّراً فَحَرَّکَ قَلِیلاً ، ثُمَّ سَلَکَ الطَّرِیقَ الْوُسْطَی الَّتِی تُخْرِجُ إِلَی الْجَمْرَۃِ الْکُبْرَی، حَتَّی أَتَی الْجَمْرَۃَ الَّتِی عِنْدَ الشَّجَرَۃِ فَرَمَاہَا بِسَبْعِ حَصَیَاتٍ ، یُکَبِّرُ مَعَ کُلِّ حَصَاۃٍ مِنْہَا ، مِثْلِ حَصَی الْخَذْفِ ، رَمَی مِنْ بَطْنِ الْوَادِی ، ثُمَّ انْصَرَفَ إِلَی الْمَنْحَرِ ، فَنَحَرَ ثَلاَثًا وَسِتِّینَ بِیَدِہِ ، ثُمَّ أَعْطَی عَلِیًّا فَنَحَرَ مَا غَبَرَ مِنْہَا ، وَأَشْرَکَہُ فِی ہَدْیِہِ ، وَأَمَرَ مِنْ کُلِّ بَدَنَۃٍ بِبَضْعَۃٍ فَجُعِلَتْ فِی قِدْرٍ ، فَطُبِخَتْ ، فَأَکَلاَ مِنْ لَحْمِہَا وَشَرِبَا مِنْ مَرَقِہَا ۔ ثُمَّ رَکِبَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَأَفَاضَ إِلَی الْبَیْتِ ، فَصَلَّی بِمَکَّۃَ الظُّہْرَ ، فَأَتَی بَنِی عَبْدِ الْمُطَّلِبِ یَسْقُونَ عَلَی زَمْزَمَ ، فَقَالَ : انْزِعُوا بَنِی عَبْدِ الْمُطَّلِبِ ، فَلَوْلاَ أَنْ یَغْلِبَکُمَ النَّاسُ عَلَی سِقَایَتِکُمْ لَنَزَعْتُ مَعَکُمْ ، فَنَاوَلُوہُ دَلْوًا فَشَرِبَ مِنْہُ۔",,,14925,,
14926,"حدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ مَسْرُوقٍ ، قَالَ : أُمِرْتُمْ فِی الْکِتَابِ بِإِقَامَۃِ أَرْبَعٍ ؛ بِإِقَامَۃِ الصَّلاَۃِ ، وَإِیتَائِ الزَّکَاۃِ ، وَإِقَامَۃِ الْحَجِّ ، وَالْعُمْرَۃِ۔",,,14926,,
14927,"حدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ أَنَّہُ سُئِلَ عَنِ الدَّجَاجَۃِ السِّنْدِیَّۃِ یُخْرَجُ بِہَا مِنَ الْحَرَمِ ؟ فَقَالاَ : لاَ ، ہِیَ صَیْدٌ۔",,,14927,,
14928,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ أَنَّ أَزْوَاجَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کُنَّ یَطُفْنَ مَعَ الرِّجَالِ ، قَالَ عَطَائٌ : وَقَالَتِ امْرَأَۃٌ لِعَائِشَۃَ : تَعَالَیْ إِلَی الْحَجَرِ فَاسْتَلِمِیہِ ، قَالَتْ : انفُذی عَنْکِ",,,14928,,
14929,حدَّثَنَا رَوْحُ بْنُ عُبَادَۃَ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ یَحْتَشَّ الْمُحْرِمُ,,,14929,,
14930,"حدَّثَنَا رَوْحُ بْنُ عُبَادَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ بَأْسَ بِہِ",,,14930,,
14931,"حدَّثَنَا أَبُو أُسَامَۃُ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : کَانَ یَقُولُ فِیمَنِ اضْطُرَّ إِلَی مَیْتَۃٍ وَصَیْدٍ : یَأْکُلُ الْمَیْتَۃَ ، وَلاَ یَأْکُلُ الصَّیْدَ ، وَلاَ یَعْرِضُ لَہُ ، یَعْنِی الْمُحْرِمَ۔",,,14931,,
14932,"حدَّثَنَا ہُشَیْمٌ ، عَنِ الحَجَّاجِ ، عَنْ عَطَائٍ ، قَالَ : یُلَبَّی عَنِ الأَخْرَسِ وَالصَّبِیِّ",,,14932,,
14933,"حدَّثَنَا حَفْصٌ ، عَنْ عَمْرٍو ، وَہِشَامٍ ، عَنِ الْحَسَنِ ؛ فِی امْرَأَۃٍ قَدِمَتْ مُعْتَمِرَۃً وَہِیَ حَائِضٌ ، قَالَ : تُہِلُّ بِالْحَجِّ عَلَی عُمْرَتِہَا ، وَتَمْضِی إِلَی عَرَفَاتٍ وَہِیَ قَارِنٌ",,,14933,,
14934,حدَّثَنَا حَفْصٌ ، عَنْ ہِشَامٍ ، عَنْ عَطَائٍ ؛ مِثْلَہُ۔,,,14934,,
14935,"حدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ إِبْرَاہِیمَ بْنِ نَافِعٍ ، عَنْ طَاوُوسٍ ، قَالَ : سَمِعْتُہُ سُئِلَ عَنْ رَجُلٍ أَرَادَ أَنْ یُلَبِّیَ فَکَبَّرَ ؟ قَالَ : یُجْزِئْہُ۔",,,14935,,
14936,"حدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : یَرْجِعُ۔",,,14936,,
14937,"حدَّثَنَا مُعَاوِیَۃُ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : یُجْزِئْہُ۔",,,14937,,
14938,"حدَّثَنَا عَبْدُ الْعَزِیزِ الْعَمِّیُّ ، قَالَ : سُئِلَ مَطَرٌ ، وَأَنَا أَسْمَعُ عَنِ امْرَأَۃٍ اسْتَأْذَنَتْ زَوْجَہَا فِی الْحَجِّ فَلَمْ یَأْذَنْ لَہَا ، فَاسْتَأْذَنَتْہُ أَنْ تَزُورَ فَأَذِنَ لَہَا ، فَضَمَّتْ عَلَیْہَا ثِیَابًا لَہَا بَیضَائَ وَصَرَخَتْ بِالْحَجِّ ؟ قَالَ : فَأَتَوُا الْحَسَنَ فَسَأَلُوہُ ؟ فَقَالَ الْحَسَنُ : اللَّکَعَۃُ لَیْسَ لَہَا ذَاکَ ، قَالَ مَطَرٌ : وَسُئِلَ قَتَادَۃُ ؟ فَقَالَ : ہِیَ مُحْرِمَۃٌ ، قَالَ مَطَرٌ : فَانْطَلَقَتُ إِلَی مَکَّۃَ فَسَأَلَتُ الْحَکَمَ بْنَ عُتَیْبَۃَ ؟ فَقَالَ : ہِیَ مُحْرِمَۃٌ ، قَالَ مَطَرٌ : فَأَمَرْتُ رَجُلاً فَسَأَلَ عَطَائَ بْنَ أَبِی رَبَاحٍ ؟ فَقَالَ : لاَ ، وَلاَ نِعْمَۃُ عَیْنٍ ، لَیْسَ لَہَا ذَلِکَ",,,14938,,
14939,"حدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا أَبُو عَوَانَۃَ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا کَانَتِ الْفَرِیضَۃُ ، وَکَانَ لَہَا مَحْرَمٌ ، فَلاَ بَأْسَ أَنْ تَخْرُجَ ، وَلاَ تَسْتَأْذِنَ زَوْجَہَا۔",,,14939,,
14940,"حدَّثَنَا فُضَیْلُ بْنُ عِیَاضٍ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ فِی الْمَرْأَۃِ الَّتِی لَمْ تَحُجَّ ، قَالَ : تَسْتَأْذِنُ زَوْجَہَا ، فَإِنْ أَذِنَ لَہَا فَذَاکَ أَحَبَّ إِلَیَّ ، وَإِنْ لَمْ یَأْذَنْ لَہَا خَرَجَتْ مَعَ ذِی مَحْرَمٍ ، فَإِنَّ ذَلِکَ فَرِیضَۃٌ مِنْ فَرَائِضِ اللہِ تَعَالَی لَیْسَ لَہُ فِیہَا طَاعَۃٌ۔",,,14940,,
14941,"حدَّثَنَا ابْنُ مَہْدِیٍّ، عَنْ سُفْیَانَ، عَنِ الزُّبَیْرِ بْنِ عَدِیٍّ، عَنْ إِبْرَاہِیمَ ، قَالَ: مَا کَانَ أَصْحَابُنَا یَعْتَنِقُونَ الْبَیْتَ۔",,,14941,,
14942,حدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، عَنْ سُفْیَانُ ، عَنْ رَجُلٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہ کان لاَ یَعْتَنِقُ الْبَیْتَ۔,,,14942,,
14943,حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ إِبْرَاہِیمَ بْنِ عَبْدِ الأَعْلَی ، عَنْ سُوَیْد بْنِ غَفَلَۃَ ؛ أَنَّ عُمَرَ الْتَزَمَ الْحَجَرَ وَقَبَّلَہُ,,,14943,,
14944,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، قَالَ : سَأَلْتُ جَابِرَ بْنَ عَبْدِ اللہِ عَنْ رَجُلٍ اعْتَمَرَ فَطَافَ بِالْبَیْتِ ، ثُمَّ أَرَادَ أَنْ یَقَعَ عَلَی أَہْلِہِ ، قَبْلَ أَنْ یَطُوفَ بَیْنَ الصَّفَا وَالْمَرْوَۃِ ؟ فَقَالَ : لاَ ، حَتَّی یَطُوفَ بَیْنَ الصَّفَا وَالْمَرْوَۃِ۔",,,14944,,
14945,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَنَسِ بْنِ سَعْدٍ ؛ أَنَّ رَجلاً اسْتَفْتَی سَعِیدَ بْنَ جُبَیرٍ قَالَ : حَجَجْتُ وَامْرَأَتِی ، فَوَقَعْتُ بِہَا قَبْلَ أَنْ أَُقَصِّرَ ؟ فَقَالَ سَعِیدٌ : أَہْرِقْ دَمًا۔",,,14945,,
14946,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْحَکَمِ ، عَنْ مِقْسَمٍ ، أَو سَعِیدِ بْنِ جُبَیرٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ قَالَ : فِی امْرَأَۃٍ وَقَعَ عَلِیہَا زَوجُہَا ، وَقَد قَصَّرَتِ الْمَرْأَۃُ ، وَلَمْ یُقَصِّرِ الرَّجُلُ ، قَالَ : عَلَیہ دَمٌ",,,14946,,
14947,"حدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی بِشْرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : جَائَ رَجُلٌ إِلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : إِنَّ أُخْتِی مَاتَتْ وَلَمْ تَحُجَّ ، أَفَأَحُجُّ عَنْہَا ؟ قَالَ : أَرَأَیْتَ لَوْ کَانَ عَلَیْہَا دَیْنٌ فَقَضَیْتَہُ ؟ وَاللَّہُ أَحَقُّ بِالْوَفَائِ وَالْقَضَائِ۔ (بخاری 6699۔ احمد 1/239)",,,14947,,
14948,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، عَنْ رَجُلٍ یُقَالُ لَہُ : یُوسُفُ ، عَنِ ابْنِ الزُّبَیْرِ ؛ قَالَ : أَتَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجُلٌ ، فَقَالَ : یَا رَسُولَ اللہِ ، إِنَّ أَبِی مَاتَ وَلَمْ یَحُجَّ ، أَفَأَحُجُّ عَنْہُ ؟ قَالَ : أَنْتَ أَکْبَرُ وَلَدِہ ؟ قَالَ : نَعَمْ ، قَالَ : فَحُجَّ عَنِ أَبِیکَ ، أَرَأَیْتَ لَوْ کَانَ عَلَی أَبِیکَ دَیْنٌ قَضَیْتَہُ ؟\n\n(نسائی 3624۔ احمد 4/3 )",,,14948,,
14949,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَسْلَمَ ، عْن عَطَائٍ ، قَالَ : یُحَجُّ عَنِ الْمَیِّتِ ، وَإِنْ لَمْ یُوصِ بِہِ۔",,,14949,,
14950,"حدَّثَنَا أَبُو مُحَمَّدٍ عَبْدُ اللہِ بْنُ یُونُسَ ، قَالَ : حدَّثَنَا أَبُو عَبْدِ الرَّحْمَنِ بَقِیُّ بْنُ مَخْلَدٍ ، قَالَ : حدَّثَنَا أَبُو بَکْرٍ عَبْدُ اللہِ بْنُ مُحَمَّدِ بْنِ أَبِی شَیْبَۃَ الْعَبْسِیُّ ، قَالَ :\n حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، عَنْ ضُبَاعَۃَ ، قَالَتْ : دَخَلَ عَلَیَّ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَأَنَا أَشْتَکِی ، فَقَالَ : مَا تُرِیدِینَ ، أَتَحُجِّینَ الْعَامَ ؟ قَالَتْ : إِنِّی لَمُعْتَلَّۃٌ یَا رَسُولَ اللہِ ، قَالَ : حُجِّی وَقُولِی : مَحِلِّی مِنَ الأَرْضِ حَیْثُ حَبَسْتنِی۔ (مسلم 104۔ ابن ماجہ 2937)\n\n(",,,14950,,
14951,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَطَائِ ، عَنْ مَیْسَرَۃَ ، عَنْ عَلِیٍّ ؛ أَنَّہُ کَانَ یَقُولُ : اللَّہُمَّ حَجَّۃً إِنْ تَیَسَّرَتْ ، أَوْ عُمْرَۃً ، إِنْ أَرَادَ الْعُمْرَۃَ ، وَإِلاَّ فَلاَ حَرَجَ۔",,,14951,,
14952,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا سُفْیَانُ بْنُ حُسَیْنٍ ، عَنْ أَبِی بِشْرٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ دَخَلَ عَلَی ضُبَاعَۃَ ابْنَۃِ الزُّبَیْرِ وَہِیَ تُرِیدُ الْحَجَّ ، فَقَالَ لَہَا : اشْتَرِطِی عِنْدَ إِحْرَامِکَ : وَمَحِلِّی حَیْثُ حَبَسْتنِی ، فَإِنَّ ذَلِکَ لَک۔ (مسلم 106۔ ابن ماجہ 2938)",,,14952,,
14953,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، أَنَّہَا قَالَتْ : إذَا حَجَجْتَ فَاشْتَرِطْ قُلْ : اللَّہُمَّ الْحَجَّ عَمَدْتُ ، وَإِیَّاہُ أَرَدْتُ ، فَإِنْ تَیَسَّرَ الْحَجُّ فَہُوَ الْحَجُّ ، فَإِنْ حُبِسْتُ فَعُمْرَۃٌ۔",,,14953,,
14954,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، قَالَ : رَأَیْتَہُ وَضَعَ رِجْلَہُ فِی الْغَرْزِ ، ثُمَّ قَالَ : اللَّہُمَّ إنِّی أُرِیدُ حَجَّۃً إِنْ تَیَسَّرَتْ ، وَإِلاَّ فَعُمْرَۃٌ إِنْ تَیَسَّرَتْ۔",,,14954,,
14955,"حدَّثَنَا سَلاَّمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ الأَسْوَدُ تُقَادُ لَہُ رَاحِلَتُہُ ، فَإِذَا أَتَی جَبَّانَۃً عرْزَمَ وَأَرَادَ أَنْ یَرْکَبَ ، قَالَ : اللَّہُمَّ حَجَّۃً إِنْ تَیَسَّرَتْ ، وَإِلاَّ عُمْرَۃً إِنْ تَیَسَّرَتْ ، ثُمَّ یُلَبِّی بِالْحَجِّ۔",,,14955,,
14956,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، قَالَ : کَانَ أَبِی لاَ یَرَی الاشْتِرَاطَ فِی الْحَجِّ شَیْئًا۔",,,14956,,
14957,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ (ح) وَسَلاَّمٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا لاَ یَشْتَرِطُونَ ، وَلاَ یَرَوْنَ الشَّرْطَ فِیہِ شَیْئًا ، قَالَ سَلاَّمٌ فِی حَدِیثِہِ : لَوْ أَنَّ رَجُلاً اُبْتُلِیَ۔",,,14957,,
14958,"حدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : رَأَی عُثْمَانُ رَجُلاً وَاقِفًا بِعَرَفَۃَ ، فَقَالَ لَہُ : اشْتَرَطْتَ ، قَالَ : نَعَمْ۔",,,14958,,
14959,حدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ سَعِیدِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنِ ابْنِ سِیرِینَ ، عَنْ عَبْدِ اللہِ بْنِ عُتْبَۃَ ، عَنْ عُثْمَانَ ، نَحْوَہُ۔,,,14959,,
14960,"حدَّثَنَا وَکِیعٌ ، عَنْ رَبِیعِ بْنِ صَبِیحٍ ، عَنِ الْحَسَنِ ، وَعَطَائٍ ؛ فِی الْمُحْرِمِ یَشْتَرِطُ ، قَالاَ : لَہُ شَرْطُہُ۔",,,14960,,
14961,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ عُمَارَۃَ ؛ أَنَّ شُرَیْحًا کَانَ یَشْتَرِطُ فِی الْحَجِّ فَیَقُولُ : إنَّکَ قَدْ عَرَفْتَ نِیَّتِی وَمَا أُرِیدُ ، فَإِنْ کَانَ أَمْرًا أُتَمِّمْہُ فَہُوَ أَحَبَّ إلَیَّ ، وَإِنْ کَانَ غَیْرَ ذَلِکَ فَلاَ حَرَجَ۔قَالَ أَبُو بَکْرٍ : بَلَغَنِی أَنَّ أَبَا مُعَاوِیَۃَ رَجَعَ عَنْ ہَذَا الْحَدِیثِ۔",,,14961,,
14962,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَبِیبِ بْنِ أَبِی ثَابِتٍ ، عَنْ طَاوُوسٍ ، قَالَ : الاشْتِرَاطُ فِی الْحَجِّ لَیْسَ بِشَیْئٍ۔",,,14962,,
14963,"حدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ ہِلاَلِ بْنِ خَبَّابٍ ، قَالَ : قُلْتُ لِسَعِیدِ بْنِ جُبَیْرٍ : أَرَأَیْتَ الاشْتِرَاطَ فِی الْحَجِّ ؟ قَالَ : إنَّمَا الاشْتِرَاطُ فِی الْحَجِّ فِیمَا بَیْنَ النَّاسِ۔",,,14963,,
14964,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، وَحَمَّادٍ ؛ فِی الاشْتِرَاطِ ، قَالاَ : لَیْسَ بِشَیْئٍ۔",,,14964,,
14965,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ شُعْبَۃَ ، عَنْ إبْرَاہِیمَ بْنِ مُہَاجِرٍ ، عَنْ إبْرَاہِیمَ التَّیْمِیِّ ، قَالَ : کَانَ عَلْقَمَۃُ یَشْتَرِطُ فِی الْحَجِّ ، وَلاَ یَرَاہُ شَیْئًا۔",,,14965,,
14966,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ دَاوُدَ بْنِ أَبِی ہِنْدَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : الْمُسْتَثْنِی وَغَیْرُ الْمُسْتَثْنِی سَوَائٌ۔",,,14966,,
14967,"حدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ ہِلاَلِ بْنِ خَبَّابٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ دَخَلَ عَلَی ضُبَاعَۃَ ، فَقَالَ : لَہَا : مَا تُرِیدِینَ الْحَجَّ الْعَامَ ؟ قَالَتْ : یَا رَسُولَ اللہِ ، إِنِّی عُلَیْلَۃٌ ، قَالَ : حُجِّی وَاشْتَرِطِی قَالَتْ : کَیْفَ أَقُولُ ؟ قَالَ : قُولِی : لَبَّیْکَ اللَّہُمَّ لَبَّیْکَ ، مَحِلِّی مِنَ الأَرْضِ حَیْثُ حَبَسْتنِی۔\n\n(ابوداؤد 1773۔ ترمذی 941)",,,14967,,
14968,"حدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ أَبِی إِسْحَاقَ، عَنْ عُمَیْرَۃ بْنِ زِیَادٍ، عَنْ عَبْدِاللہِ، قَالَ: إذَا حَجَجْتَ فَاشْتَرِطْ۔",,,14968,,
14969,حدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنْ مُحَمَّدِ بْنِ ہِلاَلٍ ، عَنْ أَبِیہِ ، عَنْ أَبِی بَکْرِ بْنِ عَبْدِ اللہِ الْحَارِثِ ؛ أَنَّہُ کَانَ یَشْتَرِطُ فِی الْعُمْرَۃِ۔,,,14969,,
14970,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَعَطَائٍ قَالاَ : فِی الْعَبْدِ یُعْتَقُ بَعْدَ مَا یَنْفِرُ النَّاسُ مِنْ عَرَفَاتٍ ، أَوْ قَالَ یَحْتَلِمُ الْغُلاَمُ ، أَوْ تَحِیضُ الْجَارِیَۃُ ، أَوْ بِجَمْعٍ ، فَرَجَعُوا إلَی عَرَفَاتٍ ، فَوَقَفُوا قَبْلَ طُلُوعِ الْفَجْرِ ، فَقَدْ أَجْزَأَتْ عَنْہُمْ حَجَّۃُ الإِسْلاَمِ۔",,,14970,,
14971,"حدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یَحُجُّ عَنِ الرَّجُلِ فَیَفْضُلُ مَعَہُ ، قَالَ : یُعْلِمُہُمْ ، فَإِنْ سَلَّمُوہُ وَإِلاَّ رَدَّہُ۔",,,14971,,
14972,"حدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ مُحَمَّدِ بْنِ عَبَّادِ بْنِ جَعْفَرٍ ، قَالَ : رَأَیْتُ ابْنَ عَبَّاسٍ جَائَ یَوْمَ التَّرْوِیَۃِ فَقَبَّلَ الْحَجَرَ ، ثُمَّ سَجَدَ عَلَیْہِ ، فَعَلَ ذَلِکَ ثَلاَثًا۔",,,14972,,
14973,حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حُسَیْنِ بْنِ عَبْدِ اللہِ ، عَنْ عِکْرِمَۃَ ؛ أَنَّ ابْنَ عَبَّاسٍ سَجَدَ عَلَیْہِ۔,,,14973,,
14974,حدَّثَنَا وَکِیعٌ ، عَنْ حَنْظَلَۃَ ، عَنْ طَاوُوسٍ ؛ أَنَّ عُمَرَ سَجَدَ عَلَیْہِ۔,,,14974,,
14975,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَابِسِ بْنِ رَبِیعَۃَ ، قَالَ : رَأَیْتُ عُمَرَ بْنَ الْخَطَّابِ اسْتَلَمَ الْحَجَرَ وَقَبَّلَہُ ، وَقَالَ : لَوْلاَ أَنِّی رَأَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُقَبِّلُک مَا قَبَّلْتُکَ۔\n\n(بخاری 1605۔ ابوداؤد 1868)",,,14975,,
14976,حدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَنْظَلَۃَ ، عَنْ طَاوُوسٍ ؛ أَنَّ عُمَرَ قَبَّلَ الْحَجَرَ ثَلاَثًا وَسَجَدَ عَلَیْہِ لِکُلِّ قُبْلَۃٍ ، وَذُکِرَ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَعَلَہُ۔,,,14976,,
14977,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عِصَامٍ ، عَنْ عَبْدِ اللہِ بْنِ سَرْجَسٍ ، قَالَ : رَأَیْتُ الأُصَیْلَعَ عُمَرَ قَبَّلَ الْحَجَرَ ، وَقَالَ : إنِّی لأَعْلَمُ أَنَّکَ حَجَرٌ لاَ تَضُرُّ وَلاَ تَنْفَعُ ، وَلَوْلاَ أَنِّی رَأَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُقَبِّلُکَ مَا قَبَّلْتُکَ۔ (احمد 35۔ مسلم 250)",,,14977,,
14978,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ إبْرَاہِیمَ بْنِ عَبْدِ الأَعْلَی ، عَنْ سُوَیْدِ بْنِ غَفَلَۃَ ، قَالَ : رَأَیْتُ عُمَرَ بْنَ الْخَطَّابِ قَبَّلَ الْحَجَرَ وَالْتَزَمَہُ ، وَقَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِکَ حَفِیًّا۔ \n\n(مسلم 926۔ احمد 54)",,,14978,,
14979,"حدَّثَنَا وَکِیعٌ ، عَنْ حَنْظَلَۃَ ، قَالَ : رَأَیْتُ طَاوُوسًا فَعَلَہُ ، یَعْنِی سَجَدَ عَلَیْہِ۔",,,14979,,
14980,"حدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنِ السُّدِّیِّ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ، قَالَ: مَا بَیْنَ جَبَلَیْ مُزْدَلِفَۃَ فَہُوَ الْمَشْعَرُ الْحَرَامُ",,,14980,,
14981,"حدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، قَالَ : لَمْ أَجِدْ أَحَدًا یُخْبِرُنِی عَنِ الْمَشْعَرِ الْحَرَامِ",,,14981,,
14982,"حدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَمْرِو بْنِ مَیْمُونٍ ، قَالَ : سَأَلْتُ عَبْدَ اللہِ بْنَ عَمرو عَنِ الْمَشْعَرِ الْحَرَامِ ؟ فَسَکَتَ حَتَّی إذَا تَہَبَّطَتْ أَیْدِی رَوَاحِلِنَا بِالْمُزْدَلِفَۃِ ، قَالَ : أَیْنَ السَّائِلُ عَنِ الْمَشْعَرِ الْحَرَامِ ؟ ہَذَا الْمَشْعَرُ الْحَرَامُ۔",,,14982,,
14983,"حدَّثَنَا إِسْحَاقُ الأَزْرَقُ ، عَنْ مُثَنًّی ، عَنْ عَطَائٍ ؛ فِی قَوْلِہِ : (الْمَشْعَرِ الْحَرَامِ) ، قَالَ : ہُوَ قُزَحٌ ، ہُوَ الْمُزْدَلِفَۃُ کُلُّہَا۔",,,14983,,
14984,"حدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ : النَّظَرُ إلَی الْبَیْتِ عِبَادَۃٌ ، وَالطَّوَافُ بِالْبَیْتِ صَلاَۃٌ",,,14984,,
14985,"حدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : النَّظَرُ إلَی الْبَیْتِ عِبَادَۃٌ۔",,,14985,,
14986,"حدَّثَنَا وَکِیعٌ ، وَعُبَیْدِ اللہِ ، عَنْ أَبَانَ بْنِ عَبْدِ اللہِ الْبَجَلِیِّ ، عَنْ عَطَائٍ ، قَالَ : النَّظَرُ إلَی الْبَیْتِ عِبَادَۃٌ۔",,,14986,,
14987,"حدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، قَالَ : أَخْبَرَنِی أَبُو نُعَیْمٍ النَّخَعِیُّ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، قَالَ : النَّظَرُ إلَی الْبَیْتِ عِبَادَۃٌ۔",,,14987,,
14988,حدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مُحَمَّدٍ الْمُحَارِبِیُّ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُوسٍ ، وَمُجَاہِدٍ ؛ کَانُوا یَکْرَہُونَ أَنْ یَدْخُلَ الْبَیْتَ رَجُلٌ عَلَیْہِ حِذَائٌ۔,,,14988,,
14989,"حدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ ، عَنْ بَکْرِ بْنِ عَبْدِ اللہِ بْنِ الْمُزَنِیِّ ؛ أَنَّ عَطَائً وَطَاوُسًا ، وَمُجَاہِدًا قَالُوا فِی الْمُحْرِمِ یُصِیبُ الْقَطَاۃَ ، قَالُوا : فِیہَا شَاۃٌ",,,14989,,
14990,"حدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حدَّثَنَا عُبَیْدُ اللہِ بْنُ عُمَرَ ، قَالَ : سَأَلَ رَجُلٌ سَالِمًا ، وَالْقَاسِمَ عْن قَطَاۃٍ أَصَابَہَا وَہُوَ مُحْرِمٌ ؟ فَقَالَ أَحَدُہُمَا : یَتَصَدَّقُ بِنِصْفِ مُدٍّ ، وَقَالَ الآخَرُ : نِصْفُ مُدٍّ خَیْرٌ مِنْ قَطَاۃٍ۔",,,14990,,
14991,"حدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنْ عَبْدِ اللہِ بْنِ مُؤَمَّلٍ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، عَنِ ابْنِ عُمَرَ ، وَابْنِ عَبَّاسٍ ؛ فِی مُحْرِمٍ قَتَلَ قَطَاۃً ، فَقَالاَ : ثُلُثَا مُدٍّ ، وَثُلُثَا مُدٍّ أَجْزَأَُ فِی بَطْنِ مِسْکینٍ مِنْ قَطَاۃٍ۔",,,14991,,
14992,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ صَالِحٍ الْفَزَارِیِّ ، عَنْ عِکْرِمَۃَ بْنِ خَالِدٍ ؛ سُئِلَ عَنْ مُحْرِمٍ قَتَلَ قَطَاۃً ؟ قَالَ : یَتَصَدَّقُ بِمُدٍّ۔",,,14992,,
14993,"حدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ أَبِی ذِئْبٍ ، عَنْ خَالِہِ الْحَارِثِ ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أُمِّ سَلَمَۃَ قَالَتْ : إذَا دَخَلَتِ الْعَشْرُ فَلاَ یَأْخُذْ مِنْ شَعْرِہِ ، وَلاَ مِنْ أَظْفَارِہِ۔",,,14993,,
14994,"حدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ حَرْمَلَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّہُ قَالَ : مَنْ کَانَ یُرِیدُ أَنْ یُضَحِّیَ فَلاَ یَأْخُذْ مِنْ شَعْرِہِ ، وَلاَ مِنْ أَظْفَارِہِ شَیْئًا إِذَا أَہَلَّ ذُو الْحِجَّۃِ۔",,,14994,,
14995,"حدَّثَنَا شَرِیکٌ ، عَنِ الأَحْلاَفِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّہُ کَرِہَ أَنْ یَأْخُذَ مِنْ شَعْرِہِ إذَا أَرَادَ الْحَجَّ ، قَالَ : فَسَأَلْتُ عِکْرِمَۃَ ؟ قَالَ : أَفَلاَ یَدَعُ النِّسَائَ ؟۔",,,14995,,
14996,حدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ أَنَّہُ کَرِہَ أَنْ یَأْخُذَ مِنْ شَعْرِہِ إذَا تَقَارَبَ الْحَجُّ۔,,,14996,,
14997,"حدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ إِسْحَاقَ بْنِ یَحْیَی ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : مَنْ أَرَادَ الْحَجَّ فَلاَ یَأْخُذْ مِنْ شَعْرِہِ شَیْئًا۔",,,14997,,
14998,"حدَّثَنَا وَکِیعٌ ، عَنْ مُحَمَّدِ بْنِ شَرِیکٍ ، عَنْ عَطَائٍ ؛ أَنَّہُ سُئِلَ عَنِ الرَّجُلِ یَأْخُذُ مِنْ شَعْرِہِ وَہُوَ یُرِیدُ الْحَجَّ ؟ قَالَ : لاَ بَأْسَ بِہِ۔",,,14998,,
14999,حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ أَبِی بَکْرِ بْنِ سَالِمٍ ، عَنْ سَالِمٍ ؛ أَنَّہُ کَانَ یَجُزُّ رَأْسَہُ فِی النِّصْفِ مِنْ شَعْبَانَ ، ثُمَّ یَخْرُجُ حَاجًّا۔,,,14999,,
15000,حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یُحِبُّ فِی الْعَشْرِ أَنْ یَکُفَّ عَنْ شَعْرِہِ وَأَظْفَارِہِ ، وَکَانَ لاَ یَرَی بِالتَّنَوُّرِ بَأْسًا۔,,,15000,,
15001,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، قَالَ : سَأَلْتُ عِکْرِمَۃَ ، وَسَالِمًا ، وَعَطَائً ،وَطَاوُوسًا ، وَالْقَاسِمَ ؟ فَقَالُوا : لاَ بَأْسَ بِہِ۔",,,15001,,
15002,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُحَمَّدِ بْنِ أَبِی إِسْمَاعِیلَ ، قَالَ : حدَّثَتْنِی أُمِّی عَنْ جَدَّتِہَا ؛ أَنَّہَا سَمِعَتْ أُمَّ سَلَمَۃَ أُمَّ الْمُؤْمِنِینَ تَقُولُ : مَنْ کَانَ یُضَحِّی عَنْہُ ، فَہَلَّ ہِلاَلُ ذِی الْحِجَّۃِ فَلاَ یَأْخُذْ مِنْ شَعْرِہِ شَیْئًا حَتَّی یُضَحِّیَ ، فَذَکَرْتُ ذَلِکَ لإِبْرَاہِیمَ ؟ فَقَالَ : مَا سَمِعْتُ بِہَذَا۔",,,15002,,
15003,"حدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانُوا یَسْتَحِبُّونَ تَوْفِیرَ الشَّعْرِ ، إِذَا أَرَادُوا أَنْ یُحْرِمُوا۔",,,15003,,
15004,"حدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ أَبِی ذِئْبٍ ، عَنْ عُثْمَانَ بْنِ عُبَیْدِ اللہِ بْنِ أَبِی رَافِعٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ ہُرْمُزَ الأَعْرَجِ ؛ أَنَّ عُمَرَ بْنَ الْخَطَّابِ أَخَذَ مِنْ رَأْسِ رَجُلٍ مِنْ قُرَیْشٍ ، یُقَالُ لَہُ : مُحَمَّدُ بْنُ أَبِی رَبِیعَۃَ ، کَانَ ذَا شَعْرٍ ، بِالشَّجَرَۃِ قَبْلَ أَنْ یُحْرِمَ۔",,,15004,,
15005,"حدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ أَبِی ذِئْبٍ ، عَنْ یَزِیدَ بْنِ عَبْدِ اللہِ بْنِ قُسَیْطٍ ، عَنْ أَبِی بَکْرِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ الْحَارِثِ بْنِ ہِشَامٍ ، وَعَطَائِ بْنِ یَسَارٍ ، وَأَبِی بَکْرِ بْنِ سُلَیْمَانَ بْنِ أَبِی حثَمَۃَ ؛ قَالُوا : لاَ بَأْسَ أَنْ یَأْخُذَ الرَّجُلُ مِنْ شَعْرِہِ وَأَظْفَارِہِ فِی الْعَشْرِ۔",,,15005,,
15006,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَطَائٍ قَالَ : لاَ بَأْسَ بِالتَّنَوُّرِ فِی الْعَشْرِ۔",,,15006,,
15007,حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ؛ أَنَّ جَابِرَ بْنَ زَیْدٍ اطَّلی فِی الْعَشْرِ۔,,,15007,,
15008,"حدَّثَنَا وَکِیعٌ ، عَنْ مُحَمَّدِ بْنِ شَرِیکٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ بَأْسَ بِالتَّنَوُّرِ فِی الْعَشْرِ۔",,,15008,,
15009,حدَّثَنَا ابْنُ یَمَانٍ، عَنْ مَعْمَرٍ، عَنْ قَتَادَۃَ، عَنِ ابْنِ الْمُسَیَّبِ؛ أَنَّہُ کَانَ یَسْتَحِبُّ تَوْفِیرَ الشَّعْرِ عِنْدَالإِحْرَامِ۔,,,15009,,
15010,"حدَّثَنَا إِسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ سَعِیدِ بْنِ یُوسُفَ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ عِکْرِمَۃَ مَوْلَی ابْنِ عَبَّاسٍ، قَالَ: غَیَّرَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ثَوبَیْہِ بِالتَّنْعِیمِ وَہُوَ مُحْرِمٌ۔ (ابوداؤد 157۔ طبرانی 11510)",,,15010,,
15011,"حدَّثَنَا جَرِیرٌ، عَنْ مُغِیرَۃَ، عَنْ إِبْرَاہِیمَ، قَالَ: یُغَیِّرُ الْمُحْرِمُ مِنْ ثِیَابِہِ مَا شَائَ، بَعْدَ أَنْ یَلْبَسَ ثِیَابَ الْمُحْرِمِ۔",,,15011,,
15012,"حدَّثَنَا وَکِیعٌ ، عَنِ الصَّبَّاحِ بْنِ ثَابِتٍ ، قَالَ : سَأَلْتُ سَعِیدَ بْنَ جُبَیْرٍ : أَیَبِیعُ الْمُحْرِمُ ثِیَابَہُ ؟ قَالَ : نَعَمْ۔",,,15012,,
15013,حدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الصَّبَّاحِ ، عَنْ سَعِیدٍ ؛ بِنَحْوِہِ۔,,,15013,,
15014,حدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ (ح) وَیُونُسَ ، عَنِ الْحَسَنِ ، وَحَجَّاجٍ ، وَعَبْدِ الْمَلِکِ، وَعَطَائٍ؛ أَنَّہُمْ لَمْ یَرَوْا بَأْسًا أَنْ یُبَدِّلَ الْمُحْرِمُ ثِیَابَہُ ، أَوْ مَا سِوَی ذَلِکَ۔,,,15014,,
15015,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ زَمْعَۃَ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، قَالَ : لِلْمُحْرِمِ أَنْ یُبَدِّلَ مِنَ الثِّیَابِ مَا شَائَ۔",,,15015,,
15016,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ دَخَلَ حَمَّامَ الْجُحْفَۃِ وَہُوَ مُحْرِمٌ ، قَالَ: إِنَّ اللَّہَ لاَ یَصْنَعُ بِأَوْسَاخِکُمْ شَیْئًا۔",,,15016,,
15017,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَکْرَہُ أَنْ یَدْخُلَ الْمُحْرِمُ الْحَمَّامَ ، وَیَقُولُ : إِنَّہُ لَفِی شُغُلٍ مِنْ دُخُولِ الْحَمَّامِ",,,15017,,
15018,حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ؛ أَنَّہُ کَرِہَ لِلْمُحْرِمِ أَنْ یَدْخُلَ الْحَمَّامَ,,,15018,,
15019,حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، عَنْ عَائِشَۃَ ؛ أَنَّہَا کَانَتْ لاَ تَرَی بَأْسًا أَنْ یَطُوفَ الرَّجُلُ ثَلاَثَۃَ أَسْبَاعٍ ، أَوْ خَمْسَۃً ، ثُمَّ یُصَلِّیَ,,,15019,,
15020,حدَّثَنَا ابْنُ إِدْرِیسَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، عَنْ عَائِشَۃَ ؛ أَنَّہَا کَانَتْ تَقْرُنُ بَیْنَ الأَسَابِیعِ,,,15020,,
15021,"حدَّثَنَا أَبُو بَکْرٍ ، عَنِْ لَیْثٍ ، عَنْ عَطَائٍ ، عَنْ عَائِشَۃَ ، قَالَتْ : لاَ بَأْسَ أَنْ یَطُوفَ الرَّجُلُ ثَلاَثَۃَ أَسْبَاعٍ ، أَوْ خَمْسَۃً ، ثُمَّ یُصَلِّیَ رَکْعَتَیْنِ۔",,,15021,,
15022,حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ؛ أَنَّہُ قَرَنَ مَرَّۃً۔,,,15022,,
15023,"حدَّثَنَا وَکِیعٌ ، عَنْ عُمَرَ بْنِ ذَرٍّ ، عَنْ مُجَاہِدٍ ؛ أَنَّہُ أَنْکَرَہُ ، وَقَالَ : مَا فَعَلَہُ أَحَدٌ إِلاَّ رَجُلٌ مِنْ قُرَیْشٍ ، الْمِسْوَرُ بْنُ مَخْرَمَۃَ۔",,,15023,,
15024,حدَّثَنَا عُبَیْدُ اللہِ ، عَنْ حَنْظَلَۃَ ، عَنْ طَاوُوسٍ ؛ أَنَّہُ طَافَ ثَلاَثَۃَ أَسْبَاعٍ ، ثُمَّ صَلَّی سِتَّ رَکَعَاتٍ۔,,,15024,,
15025,حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ أَنَّ طَاوُوسًا ، وَالْمِسْوَرَ بْنَ مَخْرَمَۃَ کَانَا یَقْرِنَانِ بَیْنَ الأَسَابِیعِ ، وَکَانَ عَطَائٌ لاَ یَرَی بِذَلِکَ بَأْسًا۔,,,15025,,
15026,"حدَّثَنَا حَفْصٌ ، عَنْ عَبْدِ الْمَلِکِ ، قَالَ : جَاوَرْتُ بِمَکَّۃَ وَثَمَّ سعِیدُ بْنُ جُبَیْرٍ ، وَعَلِیُّ بْنُ حُسَیْنٍ ، فَطَافَ عَلِیُّ بْنُ حُسَیْنٍ ثَلاَثَۃَ أَسَابِیعَ ، وَصَلَّی لِکُلِّ سُبُوعٍ رَکْعَتَیْنِ ، ثُمَّ أَتَی الْحَجَرَ فَاسْتَلَمَہُ ، وَکَانَ سَعِیدُ بْنُ جُبَیْرٍ یَفْعَلُہُ بِالنَّہَارِ۔",,,15026,,
15027,"حدَّثَنَا حَفْصٌ، عَنْ عَبْدِ اللہِ بْنِ مُسْلِمٍ ، قَالَ : ذَکَرُوا عِنْدَ الْقَاسِمِ أَنَّ عَائِشَۃَ کَانَتْ تَقْرِنُ بَیْنَ الأَسَابِیعِ، فَقَالَ : اتَّقُوا اللَّہَ ، وَلاَ تَقُولُوا عَلَی أُمِّ الْمُؤْمِنِینَ مَا لَمْ تَکُنْ تَفْعَلُ۔",,,15027,,
15028,"حدَّثَنَا یَحْیَی بْنُ سُلَیْمٍ ، عَنْ إسْمَاعِیلَ بْنِ أُمَیَّۃَ ، عَنِ الزُّہْرِیِّ ، قَالَ : مَضَتِ السُّنَّۃُ أَنَّ مَعَ کُلِّ سُبُوعٍ رَکْعَتَیْنِ۔",,,15028,,
15029,"حدَّثَنَا مَعْنٌ ، عَنْ خَالِدِ بْنِ أَبِی بَکْرٍ ، قَالَ : رَأَیْتُ الْقَاسِمَ بْنَ مُحَمَّدٍ ، وَسَالِمًا ، وَعُبَیْدَ اللہِ بْنَ عَبْدِ اللہِ یُصَلُّونَ عِنْدَ کُلِّ سُبُوعٍ رَکْعَتَیْنِ ، وَلاَ یَقْرِنُونَ بَیْنَ السَّبُوعِ۔",,,15029,,
15030,"حدَّثَنَا مَعْنٌ ، عَنْ زَیْدِ بْنِ السَّائِبِ ، قَالَ : رَأَیْتُ خَارِجَۃَ بْنَ زَیْدٍ یُصَلِّی عِنْدَ کُلِّ سُبُوعٍ رَکْعَتَیْنِ۔",,,15030,,
15031,حدَّثَنَا مَعْنٌ ، عَنْ مَالِکِ بْنِ أَنَسٍ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ لاَ یَقْرِنُ بَیْنَ السَّبُوعِ ، وَیُصَلِّی لِکُلِّ أُسْبُوعٍ رَکْعَتَیْنِ۔,,,15031,,
15032,"حدَّثَنَا مَعْنُ بْنُ عِیسَی، عَنْ ثَابِتِ بْنِ قَیْسٍ، قَالَ: رَأَیْتُ عِرَاکَ بْنَ مَالِکٍ یُصَلِّی عِنْدَ کُلِّ سُبُوعٍ رَکْعَتَیْنِ۔",,,15032,,
15033,"حدَّثَنَا حَفْصٌ، عَنْ عَمْرٍو، عَنِ الْحَسَنِ، قَالَ: لِکُلِّ سُبُوعٍ رَکْعَتَانِ، لاَ یُجْزِئُ مِنْہُمَا تَطَوُّعٌ، وَلاَ فَرِیضَۃٌ۔",,,15033,,
15034,"حدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، قَالَ : سُئِلَ عَطَائٌ عَنِ الصَّیْدِ یُؤْخَذُ فِی الْحِلِّ ، فَیُذْبَحُ فِی الْحَرَمِ ؟ فَقَالَ : کَانَ الْحَسَنُ بْنُ عَلِیٍّ ، وَعَائِشَۃُ ، وَابْنُ عُمَرَ یَکْرَہُونَہُ۔",,,15034,,
15035,حدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُوسٍ ؛ أَنَّہُمَا کَانَ یَکْرَہَانِ أَنْ یُدْخَلَ الصَّیْدُ الْحَرَمَ ، ثُمَّ یُذْبَحَ فِیہِ۔,,,15035,,
15036,"حدَّثَنَا أَبُو دَاوُدَ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ؛ أَنَّہُ لَمْ یَرَ بَأْسًا بِالصَّیْدِ یَصْطَادُہُ الْحَلاَلُ فِی الْحِلِّ ، أَنْ یَأْکُلَہُ الْحَلاَلُ فِی الْحَرَمِ ، قَالَ : کَانَ ابْنُ عَبَّاسٍ یَکْرَہُہُ۔",,,15036,,
15037,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ (ح) وَعَنْ لَیْثٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ بَأْسَ بِالْہَدْیِ إذَا عَطِبَ أَنْ یَبِیعَہُ وَیَسْتَعِینَ بِثَمَنِہِ فِی ہَدْیٍ آخَرَ۔",,,15037,,
15038,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ؛ أَنَّہُ قَالَ فِی رَجُلٍ لَبَّی بِعُمْرَۃٍ ، ثُمَّ وَقَعَ بِامْرَأَتِہِ قَبْلَ أَنْ یَقْضِیَ عُمْرَتَہُ ، قَالَ : یُعِیدُ عُمْرَۃً ، وَیُہْدِی بَدَنَۃً۔",,,15038,,
15039,"حدَّثَنَا مُحَمَّدُ بْنُ یَزِیدَ ، عَنْ أَبِی الْعَلاَئِ ، عَنْ قَتَادَۃَ ؛ فِی رَجُلٍ أَہَلَّ بِعُمْرَۃٍ ، ثُمَّ وَقَعَ بِأَہْلِہِ قَبْلَ أَنْ یَطُوفَ بِالْبَیْتِ ، قَالَ : یَرْجِعُ إِلَی حَیْثُ أَحْرَمَ ، فَیُحْرِمُ مِنْ ثَمَّ ، وَیُہْرِیقُ دَمًا۔",,,15039,,
15040,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا وَاقَعَ الْمُحْرِمُ بِعُمْرَۃٍ امْرَأَتَہُ ، وَہِیَ مُحْرِمَۃٌ بِعُمْرَۃٍ ، قَالَ : یُہْدِی فِی کُلِّ وَاحِدٍ مِنْہُمَا ہَدْیًا ، وَیَمْضِیَانِ لِعُمْرَتِہِمَا۔",,,15040,,
15041,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ قَتَادَۃَ ؛ أَنَّہُ سُئِلَ عَنْ رَجُلٍ أَہَلَّ بِعُمْرَۃٍ ، ثُمَّ غَشِیَ امْرَأَتَہُ قَبْلَ أَنْ یَصِلَ إلَی الْبَیْتِ ؟ أَنَّہُ قَالَ : یَرْجِعَانِ إلَی حَدِّہِمَا فَیُہِلاَنِ بِعُمْرَۃٍ ، وَیَتَفَرَّقَانِ حَتَّی یَقْضِیَا الْعُمْرَۃَ ، وَعَلَیْہِمَا ہَدْیَانِ۔",,,15041,,
15042,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَعَطَائٍ قَالاَ : عَلَیْہِ أَنْ یَرْجِعَ إلَی الْوَقْتِ ، فَیُہِلَّ بِعُمْرَۃٍ وَیُہْرِیقَ دَمًا۔",,,15042,,
15043,حدَّثَنَا شَرِیکٌ ، عَنْ عَمَّارٍ ، عَنْ مُسْلِمٍ الْبَطِینِ ؛ أَنَّ الْحُسَیْنَ بْنَ عَلِیٍّ کَانَ إذَا أَحْرَمَ ادَّہَنَ بِالزَّیْتِ ، وَدَہَنَ أَصْحَابَہُ بِالطِّیبِ ، أَوْ بِدُہْنِ الطِّیبِ۔,,,15043,,
15044,حدَّثَنَا وَکِیعٌ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ بَعْضِ أَصْحَابِہِ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَدَّہِنُ بِالزَّیْتِ قَبْلَ أَنْ یُحْرِمَ۔,,,15044,,
15045,"حدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مَنْصُورٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَدَّہِنُ بِالزَّیْتِ عِنْدَ الإِحْرَامِ۔",,,15045,,
15046,"حدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا قَیْسٌ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ؛ أَنَّہُ کَانَ یَدَّہِنُ عِنْدَ الإِحْرَامِ مِنَ الدَّبَّۃِ ، یَعْنِی بِالزَّیْتِ۔",,,15046,,
15047,"حدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ فَرْقَدٍ السَّبَخِیِّ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَدَّہِنُ بِالزَّیْتِ عِنْدَ الإِحْرَامِ ، غَیْرَ الْمُقَتَّتِ یَعْنِی المُطَیَّبَ۔ (احمد 29۔ ابن خزیمۃ 2652)",,,15047,,
15048,"حدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : خَمْسٌ مِنَ الدَّوَابِّ ، لاَ جُنَاحَ عَلَی مَنْ قَتَلَہُنَّ وَہُوَ حَرَامٌ ؛ الْفَأْرَۃُ ، وَالْعَقْرَبُ ، وَالْغُرَابُ، وَالْحِدَأَۃُ ، وَالْکَلْبُ الْعَقُورُ۔ (بخاری 1826۔ مسلم 76)",,,15048,,
15049,"حدَّثَنَا سَلاَّمٌ أَبُو الأَحْوَصِ ، عَنْ زَیْدِ بْنِ جُبَیْرٍ ، قَالَ : سَأَلَ رَجُلٌ ابْنَ عُمَرَ : مَا یَقْتُلُ الْمُحْرِمُ مِنَ الدَّوَابِّ ؟ فَقَالَ : حَدَّثَتْنِی إِحْدَی نِسْوَۃِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، عَنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، أَنَّہُ أَمَرَ بِقَتْلِ الْفَأْرَۃِ ، وَالْعَقْرَبِ ، وَالْکَلْبِ الْعَقُورِ ، وَالْحِدَأَۃِ ، وَالْغُرَابِ۔ (بخاری 1827۔ مسلم 75)",,,15049,,
15050,"حدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ حَرْمَلَۃَ ، قَالَ : قَالَ سَعِیدُ بْنُ الْمُسَیَّبِ : خَمْسٌ یَقْتُلُہُنَّ الْمُحْرِمُ ؛ الْعَقْرَبَ ، وَالْحَیَّۃَ ، وَالذِّئْبَ ، وَالْغُرَابَ ، وَالْکَلْبَ۔",,,15050,,
15051,"حدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، قَالَ : حدَّثَنَا عِمْرَانُ بْنُ حُدَیْرٍ ، عَنْ مِنْقَرٍ أَبِی بَشَامَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ بَأْسَ بِقَتْلِ الأَفْعَی ، وَرَمْیِ الْحِدَإِ۔قَالَ أَبُو عَبْدِ الرَّحْمَنِ : وَوَجَدْتُ فِی مَکَانٍ آخَرَ : بِشْرٍ أَبِی بشَامَۃَ ، بِہَذَا الإِسْنَادِ ، وَقَالَ : یَعْنِی الْمُحْرِمَ۔",,,15051,,
15052,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَمَّادٍ ، قَالَ : سَأَلْتُ إِبْرَاہِیمَ : یَقْتُلُ الْمُحْرِمُ الْفَأْرَۃَ ؟ قَالَ : لاَ۔",,,15052,,
15053,"حدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ عَوْنٍ ، عَنِ الْقَاسِمِ ، قَالَ : یَقْتُلُ الْفُوَیْسِقَۃَ۔",,,15053,,
15054,"حدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، وَعَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالاَ : لاَ یَقْتُلُ الْمُحْرِمُ مِنَ السِّبَاعِ إِلاَّ مَا عَدَا عَلَیْہِ۔",,,15054,,
15055,"حدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : کُلُّ عَدُوٍّ عَدَا عَلَیْکَ فَاقْتُلْہُ وَأَنْتَ مُحْرِمٌ۔",,,15055,,
15056,"حدَّثَنَا سَلاَّمٌ ، عَنْ مُخَارِقِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ طَارِقِ بْنِ شِہَابٍ ، قَالَ : مَرَرْتُ بِحَیَّاتٍ وَأَنَا مُحْرِمٌ ، فَقَتَلْتُہُنَّ بِعَصًا کَانَتْ مَعِی ، فَلَمَّا أَتَیْتُ عُمَرَ سَأَلْتُہُ عَنْ قَتْلِہِنَّ ؟ فَقَالَ : اُقْتُلْہُنَّ ، فَإِنَّہُنَّ عَدُوٌّ۔",,,15056,,
15057,"حدَّثَنَا ابْنُ عُیَیْنَۃَ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : سُئِلَ عُمَرُ عَنْ قَتْلِ الْحَیَّۃِ وَہُوَ مُحْرِمٌ؟ فَقَالَ : اُقْتُلُوہُنَّ۔",,,15057,,
15058,"حدَّثَنَا وَکِیعٌ ، عَنْ أُسَامَۃَ ، عَنْ نَافِعٍ ، قَالَ : کُنَّا مَعَ ابْنِ عُمَرَ وَنَحْنُ مُحْرِمُونَ فَرَأَیْنَا حَیَّۃً ، فَبَدَرَنَا سَالِمٌ فَقَتَلَہَا۔",,,15058,,
15059,حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، عَنْ عَلِیٍّ ؛ فِی الضَّبُعِ إِذَا عَدَا عَلَی الْمُحْرِمِ فَلْیَقْتُلْہُ ، فَإِنْ قَتَلَہُ مِنْ قَبْلِ أَنْ یَعْدُوَ عَلَیْہِ ، فَعَلَیْہِ شَاۃٌ مُسِنَّۃٌ۔,,,15059,,
15060,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنِ ابْنِ أَبِی نُعْمٍ ، عَنْ أَبِی سَعِیدٍ ؛ أَنَّہُ قَالَ : یَقْتُلُ الْمُحْرِمُ الْحَیَّۃَ ، وَالْعَقْرَبَ ، وَالسَّبُعَ الْعَادِی ، وَالْکَلْبَ الْعَقُورَ ، وَالْفَأْرَۃَ الْفُوَیْسِقَۃَ ، فَقِیلَ لَہُ : لِمَ قِیلَ الْفُوَیْسِقَۃُ ؟ فَقَالَ : لأَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ اسْتَیْقَظَ بِہَا ، وَقَدْ أَخَذَتْ فَتِیلَۃً تُحْرِقُ بِہَا الْبَیْتَ۔",,,15060,,
15061,"حدَّثَنَا مَحْبُوبٌ ، عَنْ بُکَیْرِ بْنِ عَامِرٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : یَقْتُلُ الْمُحْرِمُ الْفَأْرَۃَ ،وَالْغُرَابَ الْعَقْعَقَ۔",,,15061,,
15062,"حدَّثَنَا ابْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا ہِشَامٌ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، قَالَتْ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لِیَقْتُلِ الْمُحْرِمُ الْفَأْرَۃَ ، وَالْعَقْرَبَ ، وَالْحِدَأَ ، وَالْغُرَابَ ، وَالْکَلْبَ الْعَقُورَ۔\n\n(مسلم 857۔ احمد 6/231)",,,15062,,
15063,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ عَائِشَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ بِنَحْوِہِ ، وَزَادَتْ : وَیَقْتُلُ الْحَیَّۃَ۔ (مسلم 67۔ احمد 97)",,,15063,,
15064,"حدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ حَنْظَلَۃَ ، عَنِ الْقَاسِمِ ، عَنْ عَائِشَۃَ ، قَالَتْ : سَمِعْتُہُ یَقُولُ : خَمْسٌ فَوَاسِقُ ، فَاقْتُلُوہُنَّ فِی الْحَرَمِ ؛ الْحِدَأَ ، وَالْغُرَابَ ، وَالْکَلْبَ ، وَالْفَأْرَۃَ ، وَالْعَقْرَبَ۔ (مسلم 66۔ احمد 6/209)",,,15064,,
15065,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حَنْظَلَۃَ ، عَنِ الْقَاسِمِ ، قَالَ : سَمِعْتُ ابْنَ عُمَرَ یَقُولُ : لاَ جُنَاحَ عَلَیْکُمْ أَنْ تَقْتُلُوہُنَّ وَأَنْتُمْ حُرُمٌ۔",,,15065,,
15066,"حدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، عَنْ إِبْرَاہِیمَ بْنِ عَبْدِ الأَعْلَی ، عَنْ سُوَیْد بْنِ غَفَلَۃَ ، قَالَ : أَمَرَنَا عُمَرُ بِقَتْلِ الْحَیَّۃِ ، وَالزَّنْبُورِ وَنَحْنُ مُحْرِمُونَ۔",,,15066,,
15067,"حدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنْ طَاوُوسٍ ، قَالَ : لاَ عَلَیْکَ أَنْ لاَ تُسَمِّیَ حَجًّا ، وَلاَ عُمْرَۃً ، تَکْفِیکَ النِّیَّۃُ۔",,,15067,,
15068,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا أَرَدْتَ أَنْ تُحْرِمَ ، فَلاَ تَقُلْ شَیْئًا ، إِنَّمَا عَلَیْکَ مَا عَقَدْتَ عَلَیْہِ نِیَّتَکَ مِنْ حَجٍّ ، أَوْ عُمْرَۃٍ۔",,,15068,,
15069,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : تَکْفِیکَ النِّیَّۃُ فِی الْحَجِّ وَالْعُمْرَۃِ ، إِذَا أَرَدْتَ أَنْ تُحْرِمَ۔",,,15069,,
15070,"حدَّثَنَا شَرِیکٌ ، عَنْ سَالِمٍ ، عَنْ سَعِیدٍ ، قَالَ : حجَجْتُ مَعَ نَاسٍ مِنْ أَصْحَابِ عَبْدِ اللہِ ، فَلَمْ یَکُونُوا یُسَمُّونَ حَتَّی یُشَارِفُوا۔",,,15070,,
15071,"حدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ عَطَائٍ ، قَالَ : تُجْزِئُہُ النِّیَّۃُ۔",,,15071,,
15072,"حدَّثَنَا غُنْدَرٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ سُئل عَن رَجُلٍ فَرَضَ الْحَجَّ وَالْعُمْرَۃَ ، غَیر أَنَّہُ لاَ یَتَکَلَّمُ بِہِمَا ؟ أَنَّہُ قَالَ : مَا أَرَادَ وَنَوَی ، وَکَانَ یَأْمُرُہُ أَن یُسَمِّی۔",,,15072,,
15073,"حدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا سُفْیَانُ، عَنْ إِسْحَاقَ، مَوْلَی آلِ عُمَرَ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ، قَالَ: تَکْفِیہِ النِّیَّۃُ۔",,,15073,,
15074,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : تَکْفِیہِ النِّیَّۃُ۔",,,15074,,
15075,"حدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، وَشَہْرٍ ، قَالاَ : لاَ بَأْسَ أَنْ یَغْسِلَ الْمُحْرِمُ ثِیَابَہُ ، وَیَأْمُرَ بِہَا ، وَیَکْرَہَانِ أَنْ یَغْسِلَہَا ہُوَ۔",,,15075,,
15076,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ بَأْسَ أَنْ یَغْتَسِلَ الْمُحْرِمُ ، وَیَغْسِلَ ثِیَابَہُ۔",,,15076,,
15077,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ أَنْ یَغْتَسِلَ الْمُحْرِمُ مِنْ غَیْرِ جَنَابَۃٍ ، وَیَغْسِلَ ثِیَابَہُ۔",,,15077,,
15078,"حدَّثَنَا وَکِیعٌ ، عَنْ طَلحَۃَ ، عن عَطَائٍ ، قَالَ : لاَ بَأْسَ أَنْ یَغْسِلَ الْمُحْرِمُ ثِیَابَہُ۔",,,15078,,
15079,"حدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ مَنْصُورٍ ، عَنِ سَالِم ، عَنِ ابْنِ عُمَرَ ، قَالَ: إِنَّ اللَّہَ لاَ یَصْنَعُ بِدَرَنِکَ شَیْئًا۔",,,15079,,
15080,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ، قَالَ: لاَ بَأْسَ أَنْ یَغْتَسِلَ الْمُحْرِمُ، وَیَغْسِلَ ثِیَابَہُ۔",,,15080,,
15081,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ قَالَ : أَیَغْسِلُ الْمُحْرِمُ ثِیَابَہُ ؟ قَالَ : نَعَمْ۔",,,15081,,
15082,"حدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : یَکْتَحِلُ الْمُحْرِمُ بِأَیِّ کُحْلٍ شَائَ ، مَا لَمْ یَکُنْ فِیہِ طِیبٌ۔",,,15082,,
15083,حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ عَائِشَۃَ ابْنَۃِ طَلْحَۃَ ، عَنْ عَائِشَۃَ أُمِّ الْمُؤْمِنِینَ ؛ أَنَّہَا کَرِہَتْ لِلْمُحْرِمَۃِ أَنْ تَکْتَحِلَ بِالإِثْمِدِ۔,,,15083,,
15084,"حدَّثَنَا سَلاَّمٌ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الضَّحَّاکِ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إِذَا رَمِدَ الْمُحْرِمُ فَلْیَکْتَحِلْ ، وَلاَ یَکْتَحِلُ بِشَیْئٍ فِیہِ طِیبٌ۔",,,15084,,
15085,"حدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، قَالَ : قُلْتُ لِمُجَاہِدٍ : أَتَکْتَحِلُ الْمُحْرِمَۃُ بِالإِثْمِدِ ؟ قَالَ : لاَ ، قُلْتُ : إِنَّہُ لَیْسَ فِیہِ طِیبٌ ، قَالَ : إِنَّہُ فِیہِ زِینَۃٌ۔",,,15085,,
15086,"حدَّثَنَا مُحَمَّدُ بْنُ عُبَیْدٍ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الْعَزِیزِ ، عَنْ جَابِرِ بْنِ زَیْدٍ ، قَالَ : تَلْبَسُ الْمُحْرِمَۃُ مَا شَائَتْ مِنَ الثِّیَابِ ، مِنْ شَرْقِیہَا وَغَرْبِیہَا ، وَلاَ تَکْتَحِلُ بِالإِثْمِدِ۔",,,15086,,
15087,"حدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الْعَزِیزِ ، قَالَ سَأَلَتُ جَابِرَ بْنَ زَیْدٍ عَنِ الْمُحْرِمَۃ تَکْتَحِلُ بِالإِثْمِدِ ؟ فَکَرِہَہُ۔",,,15087,,
15088,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، قَالَ : حدَّثَنَا یَزِیدُ بْنُ إِبْرَاہِیمَ ، عَن قَتَادَۃَ ، قَالَ سَأَلَتِ امْرَأَۃٌ عَبْدَ الرَّحْمَن بْنَ أَبِی بَکْرٍ ، وَابْنَ عُمَرَ ، عَنِ امْرَأَۃٍ مُحْرِمَۃٍ اکْتَحَلَتْ بِالإِثْمِدِ ؟ فَأَمَرَہَا عَبْدُ الرَّحْمَنِ بْنُ أَبِی بَکْرٍ أَنْ تُہْرِیقَ دَمًا۔",,,15088,,
15089,"حدَّثَنَا ابْنُ فُضَیْلٍ، عَنْ یَزِیدَ، عَنْ مُجَاہِدٍ، قَالَ: لاَ تَکْتَحِلُ إِلاَّ مِنْ رَمَدٍ ، وَلاَ تَکْتَحِلُ بِکُحْلٍ فِیہِ طِیْبٌ۔",,,15089,,
15090,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ فِی الرَّجُلِ یَبْلُغُ الْوَقْتَ وَہُوَ مُغْمَی عَلَیْہِ ، قَالَ : یُلَبَّی عَنْہُ۔",,,15090,,
15091,"حدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : یُہَلُّ عَنْہُ ، یَعْنِی الْمُغْمَی عَلَیْہِ۔",,,15091,,
15092,حدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ؛ أَنَّ عَلِیًّا رَأَی مَعَ بَعْضِ أَصْحَابِہِ دَاجِنًا مِنَ الصَّیْدِ وَہُمْ مُحْرِمُونَ ، فَلَمْ یَأْمُرْہُمْ بِإِرْسَالِہِ۔,,,15092,,
15093,"حدَّثَنَا أَبُوبَکْرِ بْنُ عَیَّاشٍ، عَنْ لَیْثٍ، عَنْ مُجَاہِدٍ، قَالَ: إذَا أَحْرَمْتَ وَمَعَک شَیْئٌ مِنَ الصَّیْدِ، فَخَلِّ سَبِیلَہُ۔",,,15093,,
15094,"حدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنْ عَبْدِ اللہِ بْنِ الْحَارِثِ ، قَالَ : کُنَّا نَحُجُّ وَنَتْرُکُ عِنْدَ أَہْلِینَا أَشْیَائً مِنَ الصَّیْدِ ، مَا نُرْسِلُہَا۔",,,15094,,
15095,"حدَّثَنَا حَفْصٌ ، قَالَ : سَأَلْتُ ابْنَ جُرَیْجٍ : مَا کَانَ عَطَائٌ یَقُولُ فِی الرَّجُلِ یَخْرُجُ ، وَقَدْ خَلَّفَ فِی مَنْزِلِہِ شَیْئًا مِنَ الصَّیْدِ ، فَیُصِیبُہُ شَیْئٌ ؟ قَالَ : یَضْمَنُ۔",,,15095,,
15096,"حدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ یَزِیدَ ، عَنْ حَسَنِ بْنِ مُسْلِمٍ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إذَا أَحْرَمَ وَبِیَدِہِ شَیْئٌ مِنَ الصَّیْدِ ، فَلْیُرْسِلْہُ۔",,,15096,,
15097,"حدَّثَنَا عَبْدَۃُ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا أَحْرَمَ وَفِی یَدِہِ طَیْرٌ فَلْیُرْسِلْہُ۔",,,15097,,
15098,"حدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنْ إسْمَاعِیلَ ، عَنِ الْحَسَنِ ، قَالَ : الصَّبِیُّ إِنْ حَجَّ ، وَالْمَمْلُوکُ إِنْ حَجَّ ، وَالأَعْرَابِیُّ إِنْ حَجَّ ، ثُمَّ ہَاجَرَ الأَعْرَابِیُّ ، وَاحْتَلَمَ الصَّبِیُّ ، وَأُعْتِقَ الْعَبْدُ ، فَعَلَیْہِمُ الْحَجُّ۔",,,15098,,
15099,"حدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنْ إسْمَاعِیلَ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إِنْ حَجَّ الْمَمْلُوکُ کَذَا وَکَذَا ، ثُمَّ أُعْتِقَ فَعَلَیْہِ الْحَجُّ۔",,,15099,,
15100,"حدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنْ إسْمَاعِیلَ ، عَنْ عَطَائٍ ، قَالَ : الصَّبِیُّ وَالْعَبْدُ عَلَیْہِمَا الْحَجُّ ، وَالأَعْرَابِیُّ یُجْزِیہِ حَجَّہُ ، لأَنَّ الْحَجَّ مَکْتُوبٌ عَلَیْہِ حَیْثُ کَانَ ، وَمَنْ حَجَّ مِنَ الأَعْرَابِ۔",,,15100,,
15101,"حدَّثَنَا وَکِیعٌ ، عَنْ یُونُسَ بْنِ أَبِی إِسْحَاقَ ، قَالَ : سَمِعْتُ شَیْخًا یُحَدِّثُ أَبَا إِسْحَاقَ ، عَنْ مُحَمَّدِ بْنِ کَعْبٍ الْقُرَظِیِّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنِّی أُرِیدُ أَنْ أُجَدِّدَ فِی صُدُورِ الْمُؤْمِنِینَ ، أَیُّمَا صَبِیٍّ حَجَّ بِہِ أَہْلُہُ ، ثُمَّ مَاتَ أَجْزَأَ عَنْہُ ، وَإِنْ أَدْرَکَ فَعَلَیْہِ الْحَجُّ ، وَأَیُّمَا مَمْلُوکٍ حَجَّ بِہِ أَہْلُہُ ، ثُمَّ مَاتَ أَجْزَأَ عَنْہُ ، وَإِنْ أُعْتِقَ فَعَلَیْہِ الْحَجُّ۔ (ابوداؤد 134)",,,15101,,
15102,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ إبْرَاہِیمَ ، وَمُحَمَّد ، ابْنَی عُقْبَۃ ، عَنْ کُرَیْبٍ ؛ أَنَّ امْرَأَۃً قَامَتْ إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِصَبِیٍّ ، فَقَالَتْ : یَا رَسُولَ اللہِ ، أَلِہَذَا حَجٌّ ؟ قَالَ : نَعَمْ ، وَلَکِ أَجْرٌ۔",,,15102,,
15103,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : الأَعْرَابِیُّ یُجْزِئُ عَنْہُ حَجُّہُ۔",,,15103,,
15104,"حدَّثَنَا وَکِیعٌ ، عَنِ الْمَسْعُودِیِّ ، عَنِ الْقَاسِمِ بْنِ عَبْدِ الرَّحْمَنِ ، قَالَ : کَانَ یُقَالُ : حُجُّوا بِہِمْ صِغَارًا ، فَإِنْ مَاتُوا کَانُوا قَدْ حَجُّوا ، وَإِنْ عَاشُوا حَجُّوا۔",,,15104,,
15105,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی ظَبْیَانَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ احْفَظُوا عَنِّی ، وَلاَ تَقُولُوا : قَالَ ابْنُ عَبَّاسٍ : أَیُّمَا عَبْدٍ حَجَّ بِہِ أَہْلُہُ ، ثُمَّ أُعْتِقَ فَعَلَیْہِ الْحَجُّ ، وَأَیُّمَا صَبِیٍّ حَجَّ بِہِ أَہْلُہُ صَبِیًّا ، ثُمَّ أَدْرَکَ فَعَلَیْہِ حَجَّۃُ الرّجُلِ ، وَأَیُّمَا أَعْرَابِیٍّ حَجَّ أَعْرَابِیًّا ، ثُمَّ ہَاجَرَ فَعَلَیْہِ حَجَّۃُ الْمُہَاجِر۔ (ابن خزیمۃ 3050)",,,15105,,
15106,"حدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنْ عَبْدِ الْمَلِکِ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : کَانُوا یَرَوْنَ أَنَّ الْمَرْأَۃَ إِذَا حَجَّتْ وَفِی بَطْنِہَا وَلَدٌ ، أَنَّ لَہُ حَجًّا۔",,,15106,,
15107,"حدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ إبْرَاہِیمَ بْنِ نَافِعٍ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، قَالَ : إذَا حَجَّ وَہُوَ أَعْرَابِیٌّ أَجْزَأَتْ عَنْہُ مِنْ حَجَّۃِ الإِسْلاَمِ۔",,,15107,,
15108,"حدَّثَنَا ابْنُ عُیَیْنَۃَ، عَنْ إبْرَاہِیمَ بْنِ عُقْبَۃَ ، عَنْ کُرَیْبٍ ، عَنِ ابْنِ عَبَّاسٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، قَالَ: لَقِیَ رَکْبًا بِالرَّوْحَائِ ، فَقَالَ : مَنِ الْقَوْمُ ؟ قَالُوا : الْمُسْلِمُونَ ، قَالُوا : مَنْ أَنْتَ ؟ قَالَ : رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَرَفَعَتِ امْرَأَۃٌ صَبِیًّا ، فَقَالَتْ : أَلِہَذَا حَجٌّ ؟ قَالَ : نَعَمْ ، وَلَکِ أَجْرٌ۔\n\n(مسلم 409۔ ابوداؤد 1733)",,,15108,,
15109,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، قَالَ : یُجْزِئُ عَنِ الصَّغِیرِ حَجُّہُ حَتَّی یَکْبُرَ۔",,,15109,,
15110,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : یُصْنَعُ بِالصَّبِیِّ فِی الإِحْرَامِ مَا یُصْنَعُ بِالرَّجُلِ ، وَیُتَّقَی عَلَیْہِ الطِّیبُ ، وَیُطَافُ بِہِ ، وَیُشْہَدُ بِہِ الْمَنَاسِکَ ، وَیُلَبَّی عَنْہُ۔",,,15110,,
15111,"حدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، مِثْلَہُ ، إِلاَّ اَنَّہُ قَالَ : لاَ یُصَلَّی عَنْہُ ، وَإِنْ شَاؤُوا قَمَّصُوہُ ، وَإِنْ شَاؤُوا لَمْ یُقَمِّصُوہُ۔",,,15111,,
15112,حدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ صَالِحٍ ، عَنْ أَبِی إِسْحَاقَ ؛ أَنَّ أَبَا بَکْرٍ طَافَ بِابْنِ الزُّبَیْرِ فِی خِرْقَۃٍ۔,,,15112,,
15113,حدَّثَنَا وَکِیعٌ ، عَنِ الْعُمَرِیِّ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ (ح) وَعَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ؛ أَنَّہُمَا کَانَا یُجَرِّدَانِ الصِّبْیَانَ فِی الْحَجِّ ، وَیَطُوفَانِ بِہِمْ بَیْنَ الصَّفَا وَالْمَرْوَۃِ۔,,,15113,,
15114,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : یُجَنَّبُ الصَّبِیُّ فِی الإِحْرَامِ مَا یَجْتَنِبُ الْکَبِیرُ مِنَ الزِّینَۃِ وَالطِّیبِ۔",,,15114,,
15115,"حدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : حجَجْنَا مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَلَبَّیْنَا عَنِ الْوِلْدَانِ۔",,,15115,,
15116,حدَّثَنَا وَکِیعٌ ، عَنْ أَبِی الْعُمَیْسِ ، عَنِ الْقَاسِمِ ؛ أَنَّہُ کَانَ یُحْرِمُ بِالصِّبْیَانِ ، وَیُجَرِّدُہُمْ عِنْدَ الإِہْلاَلِِ۔,,,15116,,
15117,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، قَالَ : کَانَ عُرْوَۃُ یَحُجُّ بِصِبْیَانِہِ ، وَیُجَرِّدُہُمْ عِنْدَ الإِحْرَامِ۔",,,15117,,
15118,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، وَوَکِیعٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَمَلَ مِنَ الْحَجَرِ إلَی الْحَجَرِ ثَلاَثًا ، وَمَشَی سَائِرَ ذَلِکَ ، إِلاَّ أَنَّ وَکِیعًا لَمْ یَقُلْ : سَائِرَ ذَلِکَ۔",,,15118,,
15119,حدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ سُفْیَانَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عَبْدِ اللہِ بْنِ عَامِرِ بْنِ رَبِیعَۃَ ؛ أَنَّ عُمَرَ بْنَ الْخَطَّابِ رَمَلَ مَا بَیْنَ الْحَجَرِ إلَی الْحَجَرِ۔,,,15119,,
15120,حدَّثَنَا وَکِیعٌ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ ہِشَامٍ ؛ أَنَّ عُرْوَۃَ رَمَلَ مِنَ الْحَجَرِ إلَی الْحَجَرِ۔,,,15120,,
15121,حدَّثَنَا وَکِیعٌ ، عَنْ سَعِیدِ بْنِ عَبْدِ الْعَزِیزِ ، عَنْ مَکْحُولٍ ؛ أَنَّہُ رَمَلَ مِنَ الْحَجَرِ إلَی الْحَجَرِ۔,,,15121,,
15122,"حدَّثَنَا وَکِیعٌ ، عَنْ أَفْلَحَ ، قَالَ : دَخَلْتُ مَعَ الْقَاسِمِ فَرَمَلَ ثَلاَثًا ، وَمَشَی مَا بَیْنَ الرُّکْنَیْنِ۔",,,15122,,
15123,"حدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ إذَا قَدِمَ مَکَّۃَ فِی حَجَّۃٍ ، أَوْ عُمْرَۃٍ رَمَلَ بِالْبَیْتِ ثَلاَثَۃَ أَطْوَافٍ ، وَمَشَی أَرْبَعًا ، وَیَقُولُ : ہَکَذَا رَأَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَفْعَلُ۔ (بخاری 1617۔ مسلم 231)",,,15123,,
15124,حدَّثَنَا وَکِیعٌ ، عَنْ أَبِی حَنِیفَۃَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ رَمَلَ مِنَ الْحَجَرِ إلَی الْحَجَرِ۔,,,15124,,
15125,حدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ جَابِرٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَمَلَ ثَلاَثًا، وَمَشَی أَرْبَعًا۔,,,15125,,
15126,حدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ سُفْیَانَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عَبْدِ اللہِ بْنِ عَامِرِ بْنِ رَبِیعَۃَ ؛ أَنَّ عُمَرَ بْنَ الْخَطَّابِ رَمَلَ مَا بَیْنَ الْحَجَرِ إلَی الْحَجَرِ۔,,,15126,,
15127,حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ أَبِی وَائِلٍ ، عَنْ مَسْرُوقٍ ، عَنْ عَبْدِ اللہِ ، أَنَّہُ رَمَلَ ثَلاَثًا وَمَشَی أَرْبَعًا۔,,,15127,,
15128,"حدَّثَنَا وَکِیعٌ ، عَنْ فِطْرٍ ، عَنِ الْحَسَنِ بْنِ مُسْلِمٍ بْنِ یَنَّاق ، قَالَ : کُنْتُ أَرْمُلُ الثَّلاَثَۃَ مِنَ الْحَجَرِ إلَی الْحَجَرِ، فَأَتَی أَشْیَاخُنَا وَقَالُوا: اِمْشِ مَا بَیْنَ الرُّکْنَیْنِ، مِنْہُمْ سَعِیدُ بْنُ جُبَیْرٍ، وَطَاوُوسٌ، وَمُجَاہِدٌ، وَعَطَائٌ۔",,,15128,,
15129,حدَّثَنَا إِسْحَاقُ الأَزْرَقُ ، عَنْ مُثَنَّی ، عَنْ طَاوُوسٍ ؛ أَنَّہُ کَانَ یَرْمُلُ مِنَ الْحَجَرِ إلَی الْحَجَرِ۔,,,15129,,
15130,"حدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ ، قَالَ : حدَّثَنَا مَالِکُ بْنُ أَنَسٍ ، عَنْ جَعْفَرِ بْنِ مُحَمَّدٍ ، عَنْ أَبِیہِ ، عَنْ جَابِرٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَمَلَ مِنَ الْحَجَرِ إلَی الْحَجَرِ۔ (مسلم 886۔ احمد 3/340)",,,15130,,
15131,"حدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ (ح) وَعَنْ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ قَالاَ : مَنْ تَرَکَ طَوَافَ الصَّدْرِ فَعَلَیْہِ دَمٌ۔",,,15131,,
15132,"حدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُوسٍ قَالاَ : کَانَ عُمَرُ یَرُدُّ مَنْ خَرَجَ وَلَمْ یَکُنْ آخِرُ عَہْدِہِ بِالْبَیْتِ۔",,,15132,,
15133,"حدَّثَنَا أَبُو دَاوُدَ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، وَحَمَّادٍ قَالاَ : مَنْ نَفَرَ وَلَمْ یُوَدِّعْ ، فَعَلَیْہِ دَمٌ۔",,,15133,,
15134,حدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا إذَا رَمَی الْجَمْرَۃَ أَنْ یَغْسِلَ بِالْخِطْمِیِّ قَبْلَ أَنْ یَحْلِقَہُ۔,,,15134,,
15135,"حدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، قَالَ : إذَا حَلَّ لَکَ الْحَلْقُ ، فَاغْسِلْ رَأْسَک بِمَا شِئْتَ۔",,,15135,,
15136,"حدَّثَنَا وَکِیعٌ، عَنْ إسْرَائِیلَ، عَنْ جَابِرٍ، عَنْ أَبِی جَعْفَرٍ، قَالَ: لاَ بَأْسَ أَنْ یَغْسِلَ الْمُحْرِمُ رَأْسَہُ قَبْلَ أَنْ یَحْلِقَ۔",,,15136,,
15137,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُوسٍ ، وَمُجَاہِدٍ ، قَالَ : سَأَلْتُُہُمْ : أَغْسِلُ رَأْسِی قَبْلَ أَنْ أَحْلِقَ ، إِنْ شَقَّ عَلَیَّ الْحَلْقُ ؟ قَالُوا : نَعَمْ ، وَإِنْ شِئْتَ غَسَلْتَہُ بِالْخِطْمِیِّ۔",,,15137,,
15138,حدَّثَنَا حَمَّادُ بْنُ مَسْعَدَۃَ ، عَنْ أَبِی الأَشْہَبِ جَعْفَرِ بْنِ حَیَّانٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَکْرَہُ أَنْ یَغْسِلَ الرَّجُلُ رَأْسَہُ بِالْخِطْمِیِّ قَبْلَ أَنْ یَحْلِقَہُ۔,,,15138,,
15139,حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ؛ أَنَّہُ کَرِہَ أَنْ تَغْسِلَ الْمَرْأَۃُ رَأْسَہَا بِالْخِطْمِیِّ ، یَعْنِی إذَا أَرَادَتْ أَنْ تُقَصِّرَ۔,,,15139,,
15140,"حدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَغْسِلُ رَأْسَہُ بِالْخِطْمِیِّ قَبْلَ أَنْ یَحْلِقَہُ ، قَالَ : وَکَانَ عَطَائٌ یَکْرَہُہُ۔",,,15140,,
15141,"حدَّثَنَا سَلاَّمٌ أَبُو الأَحْوَصِ ، عَنِ الْعَلاَئِ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ عِکْرِمَۃَ ، قَالَ : قَالَ رَجُلٌ لابْنِ عَبَّاسٍ : أَیَرْکَبُ الرَّجُلُ الْبَدَنَۃَ ؟ قَالَ : غَیْرَ مُثْقِلٍ ، قَالَ : فَیَحْلُبُہَا ؟ قَالَ : غَیْرَ مُجْہِدٍ۔",,,15141,,
15142,"حدَّثَنَا أَبُو مَالِکٍ الْجَنْبِیُّ عَمْرُو بْنُ ہَاشِمٍ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَلِیٍّ ، قَالَ : یَرْکَبُ الرَّجُلُ بَدَنَتَہُ بِالْمَعْرُوفِ۔",,,15142,,
15143,"حدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : إذَا احْتَاجَ الرَّجُلُ إلَی الْبَدَنَۃِ فَلْیَرْکَبْہَا۔",,,15143,,
15144,"حدَّثَنَا وَکِیعٌ ، عَنْ شَرِیکٍ ، عَنْ عَبْدِ الْکَرِیمُ ، عَنْ عِکْرِمَۃَ ؛ فِی الْبَدَنَۃِ ، قَالَ : اِرْکَبْہَا غَیْرَ قَادِحٍ۔",,,15144,,
15145,"حدَّثَنَا أَبُو خَالِدٍ ، عَنْ حُمَیْدٍ ، قَالَ : رَأَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجُلاً یَسُوقُ بَدَنَۃً ، فَقَالَ : ارْکَبْہَا ، قَالَ : إِنَّہَا بَدَنَۃً ، قَالَ : ارْکَبْہَا۔",,,15145,,
15146,"حدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : ارْکَبُوا الْہَدْیَ بِالْمَعْرُوفِ ، حَتَّی تَجِدُوا ظَہْرًا۔ (مسلم 961۔ ابوداؤد 1758)",,,15146,,
15147,"حدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنِ الْقَاسِمِ ، عَنْ مُجَاہِدٍ ؛ {لَکُمْ فِیہَا مَنَافِعُ إلَی أَجَلٍ مُّسَمًّی} ، قَالَ : فِی أَلْبَاَنَّہَا وَظُہُورِہَا ، وَفِی أَوْبَارِہَا حَتَّی تُسَمَّی بُدْنًا ، فَإِذَا سُمِّیَتْ بُدْنًا فَمَحِلُّہَا إلَی الْبَیْتِ الْعَتِیقِ۔",,,15147,,
15148,"حدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : یَرْکَبُہَا وَیَحْمِلُ عَلَیْہَا۔",,,15148,,
15149,"حدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ حُمَیْدٍ ، عَنْ أَنَسٍ ، قَالَ : ارْکَبْہَا ، قَالَ : إِنَّہَا بَدَنَۃٌ ، قَالَ : ارْکَبْہَا غَیْرَ مَفْدُوحَۃٍ۔",,,15149,,
15150,"حدَّثَنَا عَبْدُ الصَّمَدِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، قَالَ فِی الْبَدَنَۃِ ، قَالَ : إِذَا احْتَاجَ إِلَیْہَا سَائِقُہَا رَکِبَہَا غَیْرَ فَادِحٍ ، وَیَشْرَبُ فَضْلَ رَیّ وَلَدِہَا۔",,,15150,,
15151,حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ فِی الْبَدَنَۃِ إِنْ احْتَجْتَ إِلَی ظَہْرِہَا رَکِبْتَ ، وَحَمَلْتَ عَلَیْہَا بِالْمَعْرُوفِ۔,,,15151,,
15152,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی الزِّنَادِ ، عَنِ الأَعْرَجِ ، عَنْ أَبِی ہُرَیْرَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَأَی رَجُلاً یَسُوقُ بَدَنَۃً ، فَقَالَ : ارْکَبْہَا ، قَالَ : إِنَّہَا بَدَنَۃٌ ، قَالَ : وَإِنْ کَانَتْ بَدَنَۃً۔\n\n(بخاری 1689۔ ابوداؤد 1757)",,,15152,,
15153,"حدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ بُکَیْرِ بْنِ الأَخْنَسِ ، عَنْ أَنَسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَأَی رَجُلاً یَسُوقُ بَدَنَۃً ، أَوْ ہَدِیَّۃً ، فَقَالَ : ارْکَبْہَا ، قَالَ : إِنَّہَا بَدَنَۃٌ ، أَوْ ہَدِیَّۃٌ ، قَالَ : وَإِنْ کَانَتْ۔\n\n(مسلم 374۔ احمد 3/167)",,,15153,,
15154,"حدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنْ عَجْلاَنَ مَوْلَی الْمُشْمَعِلِ ، عَنْ أَبِی ہُرَیْرَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَأَی رَجُلاً یَسُوقُ بَدَنَۃً ، فَقَالَ : ارْکَبْہَا ، قَالَ : إِنَّہَا بَدَنَۃٌ ، قَالَ ارْکَبْہَا وَیْحَکَ ، أَوْ وَیْلَکَ۔",,,15154,,
15155,"حدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ مُجَاہِدٍ ۔(ح) وَعَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ، قَالَ: إِنِ احْتَاجَ إِلَی اللَّبَنِ شَرِبَ، وَإِنِ احْتَاجَ إِلَی الرُّکُوبِ رَکِبَ، وَإِنِ احْتَاجَ إِلَی الصُّوفِ أَخَذَ۔",,,15155,,
15156,حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ عَطَائٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَخَّصَ لَہُمْ أَنْ یَرْکَبُوہَا ، إِذَا احْتَاجُوا إِلَیْہَا۔,,,15156,,
15157,"حدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : لاَ تَرْکَبِ الْبَدَنَۃَ ، وَلاَ تَحْمِلْ عَلَیْہَا إِلاَّ مِنْ أَمْرٍ لاَ تَجِدُ مِنْہُ بُدًّا ، وَلاَ تَشْرَبْ مِنْ لَبَنِہَا إِلاَّ أَنْ تُرْمِلَ۔",,,15157,,
15158,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الْکَنُودِ ، عَنْ عَبْدِ اللہِ ؛ فِی الرَّجُلِ یَعْتِقُ أَمَتَہُ وَیَتَزَوَّجُہَا ، قَالَ : ہُوَ کَالرَّاکِبِ بَدَنَتَہُ۔",,,15158,,
15159,"حدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : ارْکَبْہَا۔\n\n(بخاری 1690۔ احمد 3/231)",,,15159,,
15160,"حدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : سُئِلَ ابْنُ عُمَرَ عَنِ الرَّجُلِ یَعْتِقُ أَمَتَہُ ، ثُمَّ یَتَزَوَّجُہَا ؟ قَالَ: ہُوَ کَالرَّاکِبِ بَدَنَتَہُ۔",,,15160,,
15161,"حدَّثَنَا إِسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ (ح) وَعَنْ أَیُّوبَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ فِی رَجُلٍ وَقَعَ عَلَی امْرَأَتِہِ قَبْلَ أَنْ یَزُورَ الْبَیْتَ ، قَالَ : عَلَیْہِ دَمٌ۔",,,15161,,
15162,"حدَّثَنَا وَکِیعٌ ، عَنْ دَاوُدَ ، عَنْ أَبِی الضُّحَی ، عَنْ عَلْقَمَۃَ ، قَالَ : إِذَا وَاقَعَ قَبْلَ أَنْ یَزُورَ فَعَلَیْہِ بَدَنَۃٌ۔",,,15162,,
15163,"حدَّثَنَا سَلاَّمٌ ، عَنْ خُصَیْفٍ ، عَنْ مُجَاہِدٍ ، وَعَطَائٍ ؛ فِی الرَّجُلِ یَقْضِی الْمَنَاسِکَ کُلَّہَا إِلاَّ الطَّوَافَ بِالْبَیْتِ ، ثُمَّ وَقَعَ عَلَی أَہْلِہِ ، قَالاَ : عَلَیْہِ بَدَنَۃٌ ، وَتَمَّ حَجَّہُ۔",,,15163,,
15164,"حدَّثَنَا أَبُو مُعَاوِیَۃَ، عَنِ الأَعْمَشِ، عَنْ إِبْرَاہِیمَ، قَالَ: إِذَا وَاقَعَ قَبْلَ أَنْ یَزُورَ، فَعَلَیْہِ بَدَنَۃٌ، وَالْحَجُّ مِنْ قَابِلٍ۔",,,15164,,
15165,"حدَّثَنَا ابْنُ فُضَیْلٍ ، وَسَلاَّمٌ ، عَنْ لَیْثٍ ، عَنْ حُمَیْدٍ ، قَالَ : جَائَ رَجُلٌ إِلَی ابْنِ عُمَرَ ، فَقَالَ : یَا أَبَا عَبْدِ الرَّحْمَن ، رَجُلٌ جَاہِلٌ بِالسُّنَّۃِ ، بَعِیدُ الشُّقَّۃِ ، قَلِیلُ ذَاتِ الْیَدِ ، قَضَیْتُ الْمَنَاسِکَ کُلَّہَا ، غَیْرَ أَنِّی لَمْ أَزُرِ الْبَیْتَ حَتَّی وَقَعْتُ عَلَی امْرَأَتِی ، فَقَالَ : بَدَنَۃٌ ، وَحَجٌّ مِنْ قَابِلٍ ، فَأَعَادَ عَلَیْہِ ثَلاَثَ مَرَّاتٍ ، کُلُّ ذَلِکَ یَقُولُ : بَدَنَۃٌ ، وَحَجٌّ مِنْ قَابِلٍ۔",,,15165,,
15166,"حدَّثَنَا وَکِیعٌ ، عَنْ إِسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ ؛ فِی الَّذِی یَقَعُ عَلَی امْرَأَتِہِ قَبْلَ أَنْ یَزُورَ الْبَیْتَ ، قَالَ : عَلَیْہِ بَدَنَۃٌ۔",,,15166,,
15167,"حدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ رُفَیْعٍ ، عَنْ عَطَائٍ ، قَالَ : سُئِلَ ابْنُ عَبَّاسٍ عَنْ رَجُلٍ وَقَعَ عَلَی امْرَأَتِہِ قَبْلَ أَنْ یَزُورَ الْبَیْتَ ؟ قَالَ : عَلَیْہِ وَعَلَی امْرَأَتِہِ بَدَنَۃٌ۔",,,15167,,
15168,"حدَّثَنَا وَکِیعٌ، عَنْ حَسَنٍ، عَنْ جَابِرٍ، عَنْ أَبِی جَعْفَرٍ قَالَ: إِذَا وَاقَعَ قَبْلَ أَنْ یَزُورَ، فَعَلَیْہِ الْحَجَّ مِنْ قَابِلٍ۔",,,15168,,
15169,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : عَلَیْہِ الْحَجُّ ، وَیُہْدِی۔",,,15169,,
15170,"حدَّثَنَا أَبُو نُعَیْمٍ ، عَنِ ابْنِ أَبِی غَنِیَّۃَ ، عَنْ یَحْیَی بْنِ سَالِمٍ ، قَالَ : دَخَلْتُ أَنَا وَرَجُلٌ مِنْ بَنِی نَاجِیَۃَ عَلَی ابْنِ الْحَنَفِیَّۃِ ، فَقَالَ : رَجُلٌ قَضَی الْمَنَاسِکَ کُلَّہَا ، فَلَمَّا کَانَ یَوْمَ النَّحْرِ وَقَعَ عَلَی أَہْلِہِ قَبْلَ أَنْ یَزُورَ ، قَالَ : عَلَیْہِ بَدَنَۃٌ ، وَمَا قَالَ : عَلَیْہِ الْحَجُّ مِنْ قَابِلٍ۔",,,15170,,
15171,"حدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ أَبِیہِ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ؛ فِی الْمُحْرِمِ یُوَاقِعُ قَبْلَ أَنْ یَطُوفَ بِالْبَیْتِ ، قَالَ : یُتِمَّانِ حَجَّہُمَا ، وَیُہْرِیقُ کُلُّ وَاحِدٍ مِنْہُمَا دَمًا ، وَعَلَیْہِمَا الْحَجُّ مِنْ قَابِلٍ۔",,,15171,,
15172,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : یُہْرِیقُ دَمًا ، وَعَلَیْہِ الْحَجُّ مِنْ قَابِلٍ۔",,,15172,,
15173,"حدَّثَنَا وَکِیعٌ ، عَنْ سَعِیدٍ ، عَنْ أَبِی بِشْرٍ ، عَنْ عَلِیِّ بْنِ عَبْدِ اللہِ الْبَارِقِیِّ ، عَنِ ابْنِ عُمَرَ ، قَالَ : عَلَیْہِ الْحَجُّ مِنْ قَابِلٍ ، قُلْتُ : وَإِنْ حَجَّ مِنْ عُمَانَ ؟ قَالَ : وَإِنْ حَجَّ مِنْ عُمَانَ۔",,,15173,,
15174,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ عِکْرِمَۃَ ، وَعَطَائٍ ؛ أَنَّہُمَا قَالاَ فِی الرَّجُلِ یَقَعُ عَلَی امْرَأَتِہِ قَبْلَ أَنْ یَزُورَ الْبَیْتَ ، قَالاَ : عَلَیْہِ بَدَنَۃٌ۔",,,15174,,
15175,"حدَّثَنَا وَکِیعٌ ، عَنْ مَالِکٍ ، عَنْ عَطَائٍ ، قَالَ : جَزُورٌ ، وَقَدْ تَمَّ حَجُّہُ۔",,,15175,,
15176,"حدَّثَنَا وَکِیعٌ ، عَنْ عُمَرَ بْنِ ذَرٍّ ، عَنْ عَطَائٍ ، قَالَ : لاَ تُقْمَلْ وَأَنْتَ مُحْرِمٌ۔",,,15176,,
15177,"حدَّثَنَا وَکِیعٌ ، عَنْ أَفْلَحَ ، عَنِ الْقَاسِمِ ، قَالَ : یَحُکُّ رَأْسَہُ بِبَطْنِ أَنَامِلِہِ۔",,,15177,,
15178,"حدَّثَنَا عَبْدُ السَّلاَمُ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ أَنْ یَحُکَّ الْمُحْرِمُ رَأْسَہُ حَکًّا رَفِیقًا۔",,,15178,,
15179,"حدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ عَمْرِو بْنِ مَیْمُونٍ ، عَنْ أَبِیہِ ، عَنْ عَبْدِ اللہِ بْنِ عُمَرَ ، قَالَ : سَأَلَنِی رَجُلٌ : أَحُکُّ رَأْسِی وَأَنَا مُحْرِمٌ ؟ قَالَ : إِنْ شِئْتَ ، قَالَ : إِنِّی حَکَکْتُہُ فَوَقَعَتْ مِنْہُ قَمْلَۃٌ ، فَطَلَبْتہَا فَلَمْ أَجِدْہَا ، قَالَ : ضَالَّۃٌ لاَ تُوجَدُ۔",,,15179,,
15180,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عُیَیْنَۃَ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِیہِ ؛ أَنَّ رَجُلاً قَالَ لابْنِ عَبَّاسٍ وَہُوَ فِی الْحَجِّ وَہُوَ مُحْرِمٌ : أَحُکُّ رَأْسِی وَأَنَا مُحْرِمٌ ؟ فَجَمَعَ ابْنُ عَبَّاسٍ یَدَیْہِ جَمِیعًا ، فَحَکَّ بِہِمَا رَأْسَہُ ، وَقَالَ : أَمَّا أَنَا فَأَقُولُ ہَکذَا ، فَقَالَ لَہُ الرَّجُلُ : أَرَأَیْتَ إِنْ قَتَلْتُ قَمْلَۃً ؟ فَقَالَ : بَعُدْتَ ، وَمَا الْقَمْلَۃُ مَانِعَتِی مِنْ حَکِّ رَأْسِی ، وَمَا نُہِیتُمْ إِلاَّ عَنِ الصَّیْدِ۔",,,15180,,
15181,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی الزُّبَیْرِ ؛ أَنَّہُ سَمِعَ جَابِرَ بْنَ عَبْدِ اللہِ یَقُولُ : بِبَطْنِ أَنَامِلِہِ ، یَقُولُ فِی حَکِّ الْمُحْرِمِ رَأْسَہُ ، قَالَ : وَأَخْبَرَنِی مَنْ رَأَی عُمَرَ یَحُکَّ حَکًّا۔",,,15181,,
15182,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ فِی الْمُحْرِمِ یَحُکُّ رَأْسَہُ ، قَالَ : نَعَمْ ، یَحُکُّہُ بِأَنَامِلِہِ۔",,,15182,,
15183,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ إِبْرَاہِیمَ بْنِ مُہَاجِرٍ ، قَالَ : قُلْتُ لَہُ : سَمِعْتَ إِبْرَاہِیمَ لاَ یَرَی بَأْسًا أَنْ یَحُکَّ الْمُحْرِمُ رَأْسَہُ ؟ قَالَ : نَعَمْ۔",,,15183,,
15184,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ یَحُکُّ رَأْسَہُ وَہُوَ مُحْرِمٌ ، فَتَفَطَّنْتُ فَإِذَا ہُوَ یَحُکُّہُ بِأَنَامِلِہِ۔",,,15184,,
15185,"حدَّثَنَا وَکِیعٌ، عَنْ مِسْعَرٍ، عَنْ أَبِی إِسْحَاقَ، عَنْ عُبَیْدِ بْنِ عُمَیْرٍ، قَالَ: لاَ بَأْسَ أَنْ یَحُکَّ رَأْسَہُ وَہُوَ مُحْرِمٌ۔",,,15185,,
15186,"حدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ عَطَائٍ ، قَالَ : یَحُکَّہُ حَکًّا خَفِیفًا۔",,,15186,,
15187,"حدَّثَنَا فُضَیْلُ بْنُ عِیَاضٍ ، عَنْ لَیْثٍ ، عَنْ صَدَقَۃَ ، عَنْ جَابِرِ بْنِ زَیْدٍ ؛ فِی رَجُلٍ حَلَقَ قَبْلَ أَنْ یَنْحَرَ ، قَالَ: عَلَیْہِ الْفِدْیَۃُ ، قَالَ : فَسَأَلْتُ مُجَاہِدًا ، وَطَاوُوسًا ؟ فَقَالاَ : لَیْسَ عَلَیْہِ شَیْئٌ۔",,,15187,,
15188,"حدَّثَنَا سَلاَّمٌ ، عَنْ إِبْرَاہِیمَ بْنِ مُہَاجِرٍ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : مَنْ قَدَّمَ شَیْئًا مِنْ حَجِّہِ ، أَوْ أَخَّرَہُ ، فَلْیُہْرِقْ لِذَلِکَ دَمًا۔",,,15188,,
15189,"حدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : مَنْ قَدَّمَ مِنْ حَجِّہِ شَیْئًا قَبْلَ شَیْئٍ ، أَوْ حَلَقَ قَبْلَ أَنْ یَذْبَحَ ، فَعَلَیْہِ دَمٌ یُہْرِیقُہُ۔",,,15189,,
15190,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا حَلَقَ قَبْلَ أَنْ یَذْبَحَ ، أَہْرَاقَ لِذَلِکَ دَمًا ، ثُمَّ قَرَأَ : {وَلاَ تَحْلِقُوا رُؤُوسَکُمْ حَتَّی یَبْلُغَ الْہَدْیُ مَحِلَّہُ}۔",,,15190,,
15191,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانَ یُقَالُ : مَنْ أَحْدَثَ فِی حَجِّہِ شَیْئًا لاَ یَنْبَغِی ، ذَبَحَ لِذَلِکَ ذَبِیحَۃً۔",,,15191,,
15192,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطَائٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ قَدَّمَ مِنْ حَجِّہِ شَیْئًا مَکَانَ شَیْئٍ ، فَلاَ حَرَجَ۔",,,15192,,
15193,"حدَّثَنَا وَکِیعٌ ، عَنْ أُسَامَۃَ ، عَنْ عَطَائٍ ، عَنْ جَابِرٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ مِِِِِثْلَہُ۔\n\n(ابوداؤد 1932۔ احمد 3/326)",,,15193,,
15194,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عِیسَی بْنِ طَلْحَۃَ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ؛ إِنْ شَائَ اللَّہُ ، قَالَ : أَتَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجُلٌ ، فَقَالَ : حَلَقْتُ قَبْلَ أَنْ أَذْبَحَ ؟ قَالَ : فَاذْبَحْ وَلاَ حَرَجَ ، قَالَ : ذَبَحْتُ قَبْلَ أَنْ أَرْمِیَ ؟ قَالَ : اِرْمِ وَلاَ حَرَجَ۔ (بخاری 83۔ ترمذی 916)",,,15194,,
15195,"حدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَیَّاشٍ ، عَنْ زَیْدِ بْنِ عَلِیٍّ ، عَنْ أَبِیہِ ، عَنْ عُبَیْدِ اللہِ بْنِ أَبِی رَافِعٍ، عَنْ عَلِیٍّ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ أَنَّ رَجُلاً أَتَاہُ ، فَقَالَ : أَفَضْتُ قَبْلَ أَنْ أَحْلِقَ، قَالَ : فَاحْلِقْ ، أَوْ قَصِّرْ وَلاَ حَرَجَ۔ (ترمذی 885۔ احمد 1/76)",,,15195,,
15196,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ خَالِدٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ رَجُلاً سَأَلَ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : رَمَیْتُ بَعْدَ مَا أَمْسَیْتُ ؟ قَالَ : لاَ حَرَجَ ، وَقَالَ : حَلَقْتُ قَبْلَ أَنْ أَنْحَرَ ؟ قَالَ : لاَ حَرَجَ۔\n\n(بخاری 1735۔ ابوداؤد 1976)",,,15196,,
15197,"حدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ زِیَادِ بْنِ عِلاَقَۃَ ، عَنْ أُسَامَۃَ بْنِ شَرِیکٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سُئِلَ عَنْ رَجُلٍ حَلَقَ قَبْلَ أَنْ یَذْبَحَ ؟ قَالَ : لاَ حَرَجَ۔ (ابوداؤد 2008)",,,15197,,
15198,"حدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا وُہَیْبٌ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سُئِلَ عَنِ الرَّجُلِ یَذْبَحُ قَبْلَ أَنْ یَحْلِقَ ؟ فَقَالَ : لاَ حَرَجَ۔ (بخاری 1734۔ مسلم 950)",,,15198,,
15199,"حدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ قَیْسِ بْنِ سَعْدٍ ، عَنْ عَطَائٍ ، عَنْ جَابِرٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سُئِلَ عَنِ التَّقْدِیمِ وَالتَّأْخِیرِ فِی الْحَجِّ ؟ فَقَالَ : لاَ حَرَجَ۔ (نسائی 4105۔ احمد 3/385)",,,15199,,
15200,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ جَمِیلِ بْنِ زَیْدٍ ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ طَافَ بِالْبَیْتِ ثَلاَثَۃَ أَطْوَافٍ ، ثُمَّ قَعَدَ یَسْتَرِیحُ ، وَغُلاَمٌ لَہُ یَرُوِّحُ عَلَیْنَا ، ثُمَّ قَامَ فَبَنَی عَلَی طَوَافِہِ۔",,,15200,,
15201,"حدَّثَنَا مُحَمَّدُ بْنُ مُیَسَّرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : أَسْتَرِیحُ فِی الطَّوَافِ فَأَجْلِسُ ؟ قَالَ : نَعَمْ۔",,,15201,,
15202,حدَّثَنَا ابْنُ إِدْرِیسَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ یَسْتَرِیحَ الرَّجُلُ فِی سَعْیِہِ ، إِذَا طَافَ بَیْنَ الصَّفَا وَالْمَرْوَۃِ مِنْ حَصْرٍ۔,,,15202,,
15203,"حدَّثَنَا وَکِیعٌ ، عَنْ شَرِیکٍ ، عَنْ عَبْدِ الْکَرِیمِ الْجَزَرِیِّ ، عَنْ عَطَائٍ ، قَالَ : لاَ بَأْسَ أَنْ یَسْتَرِیحَ الرَّجُلُ بَیْنَ الصَّفَا وَالْمَرْوَۃِ۔",,,15203,,
15204,"حدَّثَنَا وَکِیعٌ ، عَنْ شَرِیکٍ ، عَنْ أَبِی الْعَالِیَۃِ الْوَاسِطِیِّ ، قَالَ : رَأَیْتُ الْحَسَنَ یَسْتَرِیحُ بَیْنَہُمَا ، فَذَکَرْتُہُ لِمُجَاہِدٍ ، فَکَرِہَہُ۔",,,15204,,
15205,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : عَرَّفَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِالْبُدْنِ الَّتِی کَانَ أَہْدَی۔",,,15205,,
15206,"حدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : لاَ ہَدْیَ إِلاَّ مَا قُلِّدَ وَأُشْعِرَ ، وَوُقِفَ بِہِ بِعَرَفَۃَ۔",,,15206,,
15207,"حدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، قَالَ : حجَجْتُ مَعَ الأَسْوَدِ وَمَعَہُ ہَدْیٌ کَثِیرٌ ، فَدَخَلَ عَلَی عَائِشَۃَ فَسَأَلَہَا ؟ فَرَأَیْتُہُ خَلْفَہُ بِمِنًی لَمْ یُعَرِّف بِہِ۔",,,15207,,
15208,"حدَّثَنَا وَکِیعٌ ، عَنْ أَفْلَحَ ، قَالَ : رَأَیْتُ الْقَاسِمَ یَسُوقُ بَدَنَتَہُ إِلَی الْمَوْقِفِ۔",,,15208,,
15209,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، قَالَ: أَرْسَلَ إِلَی عَائِشَۃَ ، فَسَأَلَہَا: أَیُعَرِّفُ بِالْبَدَنَۃِ ؟ قَالَ : فَقَالَتْ : نَعَمْ ، قَالَ : فَقَالَ : أَتُشْعَرُ ؟ قَالَ : فَقَالَتْ : إِنْ شِئْتَ ، إِنَّمَا أُشْعِرَتْ لِیُعْلَمَ أَنَّہَا بَدَنَۃٌ۔",,,15209,,
15210,"حدَّثَنَا وَکِیعٌ ، عَنْ رَبَاحِ بْنِ أَبِی مَعْرُوفٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : مَنْ شَائَ عَرَّفَ ، وَمَنْ شَائَ لَمْ یُعَرِّفْ ، إِنَّمَا کَانُوا یُعَرِّفُونَ مَخَافَۃَ السَّرَقِ۔",,,15210,,
15211,"حدَّثَنَا غُنْدَرٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ تَرَکَ بَدَنَتَہُ بِمِنًی فَلَمْ یُعَرِّفْ بِہَا ، قَالَ : یُجْزِئُہُ ، وَکَانَ یُعْجِبُہُ أَنْ یُعَرِّفَ بِہَا۔",,,15211,,
15212,"حدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَلْقَمَۃَ ، قَالَ : بَعَثَ مَعِی عَبْدُ اللہِ بِہَدْیِہِ ، فَقَالَ : إِذَا کَانَ عَشِیَّۃَ عَرَفَۃَ فَعَرِّفْ بِہِ۔",,,15212,,
15213,"حدَّثَنَا أَبُو نُعَیْمٍ ، عَنْ حُسَیْنِ بْنِ عُقَیْلٍ ، عَنِ الضَّحَّاکِ ، قَالَ : مَنْ أَہْدَی ہَدْیًا فَکَانَ مَعَہُ عَرَّفَ بِہِ۔",,,15213,,
15214,"حدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ عُمَرَ بْنِ مُحَمَّدٍ ، عَنْ سَالِمٍ ، قَالَ : أَحْرَمَ ابْنُ عُمَرَ بِعُمْرَۃٍ ، ثُمَّ سَارَ سَاعَۃً، ثُمَّ قَالَ : مَا الْحَجُّ وَالْعُمْرَۃُ إِلاَّ سَوَائٌ ، أُشْہِدُکُمْ أَنِّی قَدْ أَوْجَبْتُ مَعَہَا حَجَّۃً۔",,,15214,,
15215,"حدَّثَنَا حُمَیْدٌ ، عَنْ حَسَنٍ ، عَنْ لَیْثٍ ، عَنِ الْقَاسِمِ بْنِ نَافِعٍ ، عَنْ جَابِرٍ ، قَالَ : قَالَ لَہُ رَجُلٌ : إِنِّی جَرَّدْتُ الْحَجَّ ، أَفَأَضُمُّ إِلَیْہِ عُمْرَۃً ؟ قَالَ : نَعَمْ ، وَاذْبَحْ کَبْشًا۔",,,15215,,
15216,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ إِسْمَاعِیلَ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : یُضِیفُ الْحَجَّ إِلَی الْعُمْرَۃِ ، وَلاَ یُضِیفُ الْعُمْرَۃَ إِلَی الْحَجِّ۔",,,15216,,
15217,"حدَّثَنَا حُمَیْدٌ ، عَنْ حَسَنٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ (ح) وَعَنْ عَطَائٍ ، وَطَاوُوسٍ ، أَوْ أَحَدِہِمَا ؛ فِی رَجُلٍ أَہَلَّ بِالْحَجِّ ، قَالاَ : إِنْ شَائَ جَعَلَ مَعَہُ عُمْرَۃً ، فَکَانَ قَارِنًا ، وَأَہْدَی ہَدْیًا۔",,,15217,,
15218,حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، وَعَطَائٍ ، وَنَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لَمَّا قَدِمَ مَکَّۃَ اسْتَلَمَ الْحَجَرَ الأَسْوَدَ وَالرُّکْنَ الْیَمَانِیَ ، وَلَمْ یَسْتَلِمْ غَیْرَہُمَا مِنَ الأَرْکَانِ۔ (طبرانی 12),,,15218,,
15219,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : أَدْرَکْتُ مَشْیَخَتَنَا ؛ ابْنَ عَبَّاسٍ ، وَجَابِرًا ، وَأَبَا ہُرَیْرَۃَ، وَعُبَیْدَ بْنَ عُمَیْرٍ ، لاَ یَسْتَلِمُونَ إِلاَّ الْحَجَرَ الأَسْوَدَ وَالرُّکْنَ ، لاَ یَسْتَلِمُونَ غَیْرَہُمَا مِنَ الأَرْکَانِ۔",,,15219,,
15220,"حدَّثَنَا أَبُو نُعَیْمٍ ، عَنْ إِسْرَائِیلَ ، عَنْ إِبْرَاہِیمَ بْنِ عَبْدِ الأَعْلَی ، قَالَ : رَأَیْتُ سُوَیْد بْنَ غَفَلَۃَ یَسْتَلِمُ أَرْکَانَ الْبَیْتِ کُلَّہَا۔",,,15220,,
15221,"حدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطَائٍ ، عَنْ یَعْلَی بْنِ أُمَیَّۃَ ، قَالَ : لَمَّا أَنْ حَجَّ عُمَرُ اسْتَلَمَ الرُّکْنَ ، وَکَانَ یَعْلَی بْنُ أُمَیَّۃَ یَسْتَلِمُ الأَرْکَانَ کُلَّہَا ، فَقَالَ لَہُ عُمَرُ : یَا یَعْلَی ، مَا تَفْعَلُ ؟ قَالَ : أَسْتَلِمُہَا کُلَّہَا، لأَنَّہُ لَیْسَ شَیْئٌ مِنَ الْبَیْتِ یُہْجَرُ ، قَالَ : فَقَالَ عُمَرُ : أَمَا رَأَیْتَ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لَمْ یَسْتَلِمْ مِنْہَا إِلاَّ الْحَجَرَ ؟ قَالَ : بَلَی ، قَالَ : فَمَا لَکَ بِہِ أُسْوَۃً ؟ قَالَ : بَلَی۔ (طبرانی 5049)",,,15221,,
15222,"حدَّثَنَا عُبَیْدُ اللہِ ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنْ مُجَاہِدٍ ، قَالَ : کَانَ قَلَّ مَا یَتْرُکُ الْحَجَرَ الأَسْوَدَ وَالرُّکْنَ الْیَمَانِیَ ، إِلاَّ اسْتَلَمَہُمَا فِی الْوِتْرِ مِنْ طَوَافِہِ۔",,,15222,,
15223,"حدَّثَنَا عُبَیْدُ اللہِ ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنْ مُجَاہِدٍ ، قَالَ : الرُّکْنَانِ اللَّذَانِ یَلِیَانِ الْحَجَرَ لاَ یُسْتَلَمَانِ۔",,,15223,,
15224,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنِ ابْنِ إِسْحَاقَ ، عَنْ یَحْیَی بْنِ عَبَّادِ بْنِ عَبْدِ اللہِ ، عَنْ أَبِیہِ ؛ أَنَّہُ رَأَی مُعَاوِیَۃَ یَطُوفُ بِالْبَیْتِ فَاسْتَلَمَ الأَرْکَانَ کُلَّہَا ، وَقَالَ : إِنَّہُ لَیْسَ مِنْہُ شَیْئٌ مَہْجُورٌ۔",,,15224,,
15225,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنِ ابْنِ إِسْحَاقَ ، عَنْ یَحْیَی بْنِ عَبَّادٍ ، عَنْ أَبِیہِ ؛ أَنَّہُ رَأَی ابْنَ الزُّبَیْرِ فَعَلَہُ ، وَقَالَ : إِنَّہُ لَیْسَ مِنْہُ شَیْء مَہْجُورٌ۔",,,15225,,
15226,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، عَنْ جَابِرِ بْنِ زَیْدٍ ، قَالَ : لاَ یُتَّقَی مِنَ الْبَیْتِ شَیْئٌ۔",,,15226,,
15227,حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یَسْتَلِمُ الأَرْکَانَ کُلَّہَا ، یَخْتِمُ بِہَا ، وَیَلْزَقُ بَطْنَہُ وَظَہْرَہُ وَجَنْبَیْہِ بِالْبَیْتِ۔,,,15227,,
15228,حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ مَنْصُورٍ ، عَنْ أَبِی وَائِلٍ ، عَنْ مَسْرُوقٍ ، عَنْ عَبْدِ اللہِ ؛ أَنَّہُ رَجَعَ إِلَی الْحَجَرِ فَاسْتَلَمَہُ ، یَعْنِی بَعْدَ الرَّکْعَتَیْنِ۔,,,15228,,
15229,"حدَّثَنَا حَاتِمٌ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ جَابِرٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَمَلَ ثَلاَثًا ، وَمَشَی أَرْبَعًا ، ثُمَّ أَتَی مَقَامَ إِبْرَاہِیمَ فَقَرَأَ : {وَاتَّخِذُوا مِنْ مَقَامِ إِبْرَاہِیمَ مُصَلًّی} فَجَعَلَ الْمَقَامَ بَیْنَہُ وَبَیْنَ الْبَیْتِ ، ثُمَّ رَجَعَ إِلَی الرُّکْنِ فَاسْتَلَمَہُ۔",,,15229,,
15230,حدَّثَنَا وَکِیعٌ ، عَنِ الْعُمَرِیِّ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ إِذَا صَلَّی الرَّکْعَتَیْنِ رَجَعَ إِلَی الْحَجَرِ فَاسْتَلَمَہُ ، أَوِ اسْتَقْبَلَہُ ، فَکَبَّرَ ، ثُمَّ خَرَجَ إِلَی الصَّفَا۔,,,15230,,
15231,"حدَّثَنَا وَکِیعٌ ، عَنْ أَفْلَحَ ، عَنِ الْقَاسِمِ ، قَالَ : رَأَیْتُہُ یَفْعَلُ ذَلِکَ۔",,,15231,,
15232,"حدَّثَنَا حُمَیْدٌ ، عَنْ حُسَیْنِ بْنِ عُقَیْلٍ ، عَنِ الضَّحَّاکِ ، قَالَ : إِذَا أَتَیْتَ الْبَیْتَ فَاسْتَلِمِ الْحَجَرَ إِنْ قَدَرْتَ عَلَیْہِ ، وَذَکَرْتَ اللَّہَ ، وَصَلَّیْتَ عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، ثُمَّ تُصَلِّی عِنْدَ الْمَقَامِ رَکْعَتَیْنِ ، أَوْ مَا شَائَ اللَّہُ ، ثُمَّ تَمْضِی تُجَاہَ وَجْہِکَ فَتَسْتَلِمُ الْحَجَرَ ، وَإِلاَّ فَاسْتَقْبِلْہُ وَذَکَرْتَ اللَّہَ ، ثُمَّ تَخْرُجُ إِلَی الصَّفَا۔",,,15232,,
15233,حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عُبَیدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَعُودُ إِلَی الْحَجَرِ فَیَسْتَلِمُہُ ، ثُمَّ یَخْرُجُ إِلَی الصَّفَا۔,,,15233,,
15234,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ اللہِ بْنِ أَبِی سَارَۃَ ، قَالَ : رَأَیْتُ سَالِمًا طَافَ بِالْبَیْتِ ، ثُمَّ صَلَّی رَکْعَتَیْنِ خَلْفَ الْمَقَامِ ، ثُمَّ عَادَ إِلَی الْحَجَرِ فَاسْتَلَمَہُ ، ثُمَّ خَرَجَ إِلَی الصَّفَا۔",,,15234,,
15235,"حدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : إِنْ شِئْتَ فَارْجِعْ إِلَی الْحَجَرِ بَعْدَ الرَّکْعَتَیْنِ ، وَإِنْ شِئْتَ فَلاَ تَرْجِعْ إِلَیْہِ۔",,,15235,,
15236,"حدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ سِمَاکٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : جَائَتِ امْرَأَۃٌ إِلَی ابْنِ عَبَّاسٍ ، فَقَالَتْ : إِنَّ أُمِّی مَاتَتْ وَعَلَیْہَا حَجَّۃٌ ، فَأَقْضِیہَا عَنْہَا ؟ فَقَالَ ابْنُ عَبَّاسٍ : ہَلْ کَانَ عَلَی أُمِّکَ دَیْنٌ ؟ قَالَتْ : نَعَمْ : قَالَ : فَکَیْفَ صَنَعْتِ ؟ قَالَتْ : قَضَیْتُہُ عَنْہَا ، قَالَ ابْنُ عَبَّاسٍ : فَاللَّہُ خَیْرُ غُرَمَائِکِ۔",,,15236,,
15237,"حدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ النُّعْمَانِ بْنِ سَالِمٍ ، عَنْ عَمْرِو بْنِ أَوْسٍ ، عَنْ أَبِی رَزِینٍ الْعُقَیْلِیِّ ؛ أَنَّہُ أَتَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : یَا رَسُولَ اللہِ ، إِنَّ أَبِی شَیْخٌ کَبِیرٌ ، لاَ یَسْتَطِیعُ الْحَجَّ وَالْعُمْرَۃَ ، وَلاَ الظَّعْنَ ، قَالَ : حُجَّ عَنْ أَبِیکَ وَاعْتَمِرْ۔ (ترمذی 930۔ احمد 4/11)",,,15237,,
15238,"حدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ سِمَاکٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : جَائَ رَجُلٌ إِلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : یَا رَسُولَ اللہِ ، إِنَّ أَبِی شَیْخٌ کَبِیرٌ لاَ یَسْتَطِیعُ الْحَجَّ ، أَفَأَحُجُّ عَنْہُ ؟ قَالَ : نَعَمْ ، فَحُجَّ عَنْ أَبِیکَ۔",,,15238,,
15239,"حدَّثَنَا حَفْصٌ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ عَلِیٍّ ، قَالَ فِی الشَّیْخِ الْکَبِیرِ ، قَالَ : یُجَہِّزُ رَجُلاً بِنَفَقَتِہِ ، فَیَحُجُّ عَنْہُ۔",,,15239,,
15240,حدَّثَنَا عَبْدَۃُ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ؛ أَنَّ ابْنَ الزُّبَیْرِ کَانَ یُقِیمُ بِمَکَّۃَ السِّنِینَ ، یُہِلُّ بِالْحَجِّ لِہِلاَلِ ذِی الْحِجَّۃِ۔,,,15240,,
15241,"حدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطَائٍ ، قَالَ : قُلْتُ لابْنِ عُمَرَ : قَدْ رُئِیَ الْہِلاَلُ ، فَأَہَلَّ مَکَانِہِ ہِلاَلُ ذِی الْحِجَّۃِ ، فَلَمَّا کَانَ فِی الْعَامِ الْمُقْبِلِ ، قِیلَ لَہُ : قَدْ رُئِیَ الْہِلاَلُ ، وَہُوَ فِی الْبَیْتِ ، فَنَزَعَ ثَوْبًا کَانَ عَلَیْہِ ، ثُمَّ أَہَلَّ ، فَلَمَّا کَانَ الْعَامُ الثَّالِثُ ، قِیلَ لَہُ : قَدْ رُئِیَ الْہِلاَلُ ، فَقَالَ : مَا أَنَا إِلاَّ رَجُلٌ مِنْ أَصْحَابِی ، أَصْنَعُ کَمَا یَصْنَعُونَ ، فَأَقَامَ حَلاَلاً حَتَّی کَانَ یَوْمُ التَّرْوِیَۃِ۔",,,15241,,
15242,"حدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، عَنْ أَبِیہِ ، قَالَ : قَالَ عُمَرُ: یَا أَہْلَ مَکَّۃَ ، مَا لِی اَرَاکُمْ مُدَّہِنِینَ ، وَالْحَاجَّ شُعْثًا غُبْرًا ؟ إِذَا رَأَیْتُمْ ہِلاَلَ ذِی الْحِجَّۃِ فَأَہِلُّوا۔",,,15242,,
15243,حدَّثَنَا أَبُونُعَیْمٍ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ، عَنْ قُزْعَۃَ الْبَاہِلِیِّ، عَنِ الْحَسَنِ؛ أَنَّہُ أَہَلَّ بِمَکَّۃَ حِینَ رَأَی الْہِلاَلَ۔,,,15243,,
15244,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنْ عَطَائٍ ، قَالَ : قدِمَ ابْنُ عُمَرَ فَطَافَ ، ثُمَّ سَعَی ، ثُمَّ أَحَلَّ ، فَمَکَثَ أَرْبَعًا ، أَوْ خَمْسًا ، ثُمَّ أَہَلَّ بِالْحَجِّ فِی الْعَشْرِ ، ثُمَّ جَائَ مَرَّۃً أُخْرَی فَأَقَامَ حَلاَلاً ، حَتَّی إِذَا کَانَ یَوْمُ التَّرْوِیَۃِ ، أَہَلَّ بِالْحَجِّ حِینَ انْبَعَثَ بِہِ بَعِیرُہُ مُنْطَلِقًا إِلَی مِنًی ۔ قَالَ عطَائٌ : وَہُوَ أَحَبُّ إلَیْنَا۔",,,15244,,
15245,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَان ، عَنْ أَسْلَمَ ، عْن عَطَائٍ (ح) وَعَنِ عَطَائِ بْنِ السَّائِب ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : یُہِلُّ یَوْمَ التَّرْوِیَۃِ۔",,,15245,,
15246,حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی حَصِینٍ ، عَنْ مُجَاہِدٍ ؛ أَنَّ إِہْلاَلَ ابْنِ عُمَرَ کَانَ آخِرَہُمَا یَوْمَ التَّرْوِیَۃِ۔,,,15246,,
15247,حدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ رُبَّمَا طَافَ ، ثُمَّ صَلَّی الرَّکْعَتَیْنِ فِی جَوْفِ الْبَیْتِ۔,,,15247,,
15248,"حدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ مُوسَی بْنِ عُقْبَۃَ ، عَنْ سَالِمٍ ، قَالَ : رَأَیْتُہُ یَطُوفُ ، ثُمَّ یَدْخُلُ الْبَیْتَ ، فَیُصَلِّی الرَّکْعَتَیْنِ۔",,,15248,,
15249,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ جَعْفَرِ بْنِ مُحَمَّدٍ ، عَنْ أَبِیہِ ، قَالَ : سُئِلَ أَبِی عَنِ الصَّلاَۃِ فِی الْکَعْبَۃِ ؟ فَقَالَ: صَلَّیْتُ مَعَ أَبِی ، حُسَیْنُ بْنِ عَلِیٍّ فِی الْکَعْبَۃِ۔",,,15249,,
15250,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ دَخَلَ الْکَعْبَۃَ ، وَأُسَامَۃُ بْنُ زَیْدٍ ، وَبِلالٌ ، وَعُثْمَانَ بْنُ طَلْحَۃَ ، فَمَکَثَ فِی الْبَیْتِ فَأَطَالَ ، ثُمَّ دَخَلَ ابْنُ عُمَرَ فِی إِثرِہِ أَوَّلَ النَّاسِ ، فَسَأَلْتُ بِلاَلاً : أَیْنَ صَلَّی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ قَالَ : بَیْنَ الْعَمُودَیْنِ الْمُقَدَّمَیْنِ ، قَالَ : وَنَسِیتُ أَنْ أَسْأَلَہُ کَمْ صَلَّی ؟۔ (مسلم 391۔ ابوداؤد 2018)",,,15250,,
15251,"حدَّثَنَا الْحَسَنُ بْنُ مُوسَی ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ عُثْمَانَ بْنِ طَلْحَۃَ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی الرَّکْعَتَیْنِ وجَاہَک حِینَ تَدْخُلَ۔(احمد 3/410۔ طیالسی 1365)",,,15251,,
15252,حدَّثَنَا ابْنُ مُسْہِرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یُصَلِّی یَوْمَ الصَّدَرِ الظُّہْرَ وَالْعَصْرَ ، وَالْمَغْرِبَ وَالْعِشَائَ بِالْحَصْبۃ ، حَتَّی یَأْتِیَ مِنْ آخِرِ اللَّیْلِ الْبَیْتَ۔,,,15252,,
15253,حدَّثَنَا جَرِیرٌ ، عَنْ مُجَاہِدِ بْنِ رَاشِدٍ ، عَنْ سَعِیدِ بْنُ جُبَیْرٍ (ح) وَعَنْ عَطَائٍ ، عَنْ مُجَاہِدٍ ؛ أَنَّہُمَا صَلَّیَا الظُّہْرَ یَوْمَ النَّفْرِ ، وَرَائَ الْعَقَبَۃِ۔,,,15253,,
15254,حدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ؛ أَنَّ أَبَاہُ کَانَ یُصَلِّی الظُّہْرَ یَوْمَ النَّفْرِ بِمَکَّۃَ۔,,,15254,,
15255,"حدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ، عَنِ ابْنِ أَبِی لَیْلَی، عَنْ عَوْنِ بْنِ أَبِی جُحَیْفَۃَ، عَنْ أَبِیہِ، قَالَ: رَأَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَوْمَ النَّفْرِ بِالأَبْطَحِ ، فَأَذَّنَ بِلاَلٌ الظُّہْرَ ، ثُمَّ صَلَّی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,15255,,
15256,"حدَّثَنَا أَبُو مُعَاوِیَۃَ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ: مِنَ السُّنَّۃِ أَنْ یُصَلِّیَ الإِمَامُ یَوْمَ النَّفْرِ الظُّہْرَ بِالأَبْطَحِ۔",,,15256,,
15257,حدَّثَنَا عَبْدَۃُ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُصَلِّی إِلَی سُقْعِ الْبَیْتِ ، لَیْسَ بَیْنَہُ وَبَیْنَ الطَّوَافِ شَیْئٌ ، ثُمَّ أَبُو بَکْرٍ مِنْ بَعْدِہِ ، ثُمَّ عُمَرُ ، ثُمَّ إِنَّ عُمَرَ رَدَّہُ بَعْدُ إِلَی الْمِیقَاتِ۔,,,15257,,
15258,"حدَّثَنَا حَاتِمٌ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ جَابِرٍ، یَرْفَعُہُ ، قَالَ: إِنَّہُ أَتَی الْبَیْتَ فَاسْتَلَمَ الرُّکْنَ ، فَرَمَلَ ثَلاَثًا، وَمَشَی أَرْبَعًا ، ثُمَّ تَقَدَّمَ إِلَی مَقَامِ إِبْرَاہِیمَ فَقَرَأَ : {وَاِتَّخِذُوا مِنْ مَقَامِ إِبْرَاہِیمَ مُصَلًّی} ، فَجَعَلَ الْمَقَامَ بَیْنَہُ وَبَیْنَ الْبَیْتِ۔",,,15258,,
15259,"حدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : قرَأَ عَلْقَمَۃُ الْقُرْآنَ فِی لَیْلَۃٍ ، ثُمَّ طَافَ بِالْبَیْتِ أُسْبُوعًا ، ثُمَّ أَتَی الْمَقَامَ فَصَلَّی عِنْدَہُ۔",,,15259,,
15260,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لَمْ یُرَخَّصْ فِی تَرْکِ الصَّلاَۃِ عِنْدَ الْمَقَامِ ، فَإِنْ لَمْ تَقْدِرْ عَلَیْہِ زَاحَمْتَ عَلَیْہِ حَتَّی تَقْدِرَ عَلَیْہِ ، أَوْ بِحِذَائہ ، وَلاَ بَأْسَ أَنْ یَکُونَ بَیْنَکَ وَبَیْنَہُ رِجَالٌ یُصَلُّونَ بَعْدَ أَنْ تَکُونَ بِحِیَالِہِ۔",,,15260,,
15261,حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یُعْجِبُہُ أَنْ یُصَلِّیَ رَکْعَتَیِ الطَّوَافِ خَلْفَ الْمَقَامِ ، وَلاَ یَرَی بَأْسًا إِنْ لَمْ یَفْعَلْ۔,,,15261,,
15262,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ زَکَرِیَّا بْنِ أَبِی زَائِدَۃَ ، عَنْ عَامِرٍ ؛ أَنَّہُ سَمِعَ وَہْبَ بْنَ الأَجْدَعِ ، أَنَّہُ سَمِعَ عُمَرَ قَالَ : إِذَا قَدِمَ الرَّجُلُ حَاجًّا فَلْیَطُفْ بِالْبَیْتِ سَبْعًا ، ثُمَّ یُصَلِّ عِنْدَ الْمَقَامِ رَکْعَتَیْنِ۔",,,15262,,
15263,"حدَّثَنَا عَبْدَۃُ ، عَنْ صَالِحِ بْنِ حَیَّانَ ، قَالَ : طُفْتُ مَعَ أَنَسِ بْنِ مَالِکٍ الطَّوَافَ الأَوَّلَ ، فَلَمَّا فَرَغَ رَکَعَ رَکْعَتَیْنِ عِنْدَ الْمَقَامِ۔",,,15263,,
15264,حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ إِذَا فَرَغَ مِنْ طَوَافِہِ ، أَتَی الْمَقَامَ فَصَلَّی عِنْدَہُ رَکْعَتَیْنِ۔,,,15264,,
15265,"حدَّثَنَا حُمَیْدٌ ، عَنْ حُسَیْنِ بْنِ عُقَیْلٍ ، عَنِ الضَّحَّاکِ ، قَالَ : یُصَلِّی عِنْدَ الْمَقَامِ رَکْعَتَیْنِ ، أَوْ مَا شَائَ اللَّہُ۔",,,15265,,
15266,حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ مَنْصُورٍ ، عَنْ أَبِی وَائِلٍ ، عَنْ مَسْرُوقٍ ، عَنْ عَبْدِ اللہِ ؛ أَنَّہُ طَافَ ، ثُمَّ أَتَی الْمَقَامَ، فَصَلَّی عِنْدَہُ رَکْعَتَیْنِ۔,,,15266,,
15267,"حدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : صَلِّ رَکْعَتَیِ الطَّوَافِ فِی بَیْتک إِنْ شِئْتَ۔",,,15267,,
15268,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ أَبِی عَمَّارٍ ، قَالَ : رَأَیْتُ ابْنَ الزُّبَیْرِ طَافَ بِالْبَیْتِ ، ثُمَّ جَائَ یُصَلِّی وَالطَّوَافُ بَیْنَہُ وَبَیْنَ الْقِبْلَۃِ۔",,,15268,,
15269,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ کَثِیرِ بْنِ کَثِیرٍ ، عَمَّنْ حَدَّثَہُ ، عَنْ جَدِّہِ ؛ أَنَّہُ رَأَی رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّی مِمَّا یَلِی بَابَ بَنِی سَہْمٍ ، لَیْسَ بَیْنَہُ وَبَیْنَ الطَّوَافِ سُتْرَۃٌ ، وَالنَّاسُ یَمُرُّونَ بَیْنَ یَدَیْہِ۔\n\n(احمد 6/399۔ ابویعلی 7137)",,,15269,,
15270,حدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ کَثِیرِ بْنِ کَثِیرٍ ، عَنْ أَبِیہِ ، عَنِ الْمُطَّلِبِ بْنِ أَبِی وَدَاعَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ بِمثل حَدِیثِ ابْنِ عُیَیْنَۃَ۔ (احمد 399۔ طبرانی 687),,,15270,,
15271,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ بُکَیْرِ بْنِ عُتَیْقٍ ، قَالَ : سَمِعْتُ سَعِیدَ بْنَ جُبَیْرٍ یَقُولُ : الطَّوَافُ لِلْغُرَبَائِ أَحَبُّ إلَیَّ مِنَ الصَّلاَۃِ۔",,,15271,,
15272,"حدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی بَکْرِ بْنِ أَبِی مُوسَی ، قَالَ : سُئِلَ ابْنُ عَبَّاسٍ عَنِ الطَّوَافِ أَفْضَلُ، أَمِ الصَّلاَۃُ ؟ فَقَالَ : أَمَّا أَہْلُ مَکَّۃَ فَالصَّلاَۃُ ، وَأَمَّا أَہْلُ الأَمْصَارِ فَالطَّوَافُ۔",,,15272,,
15273,"حدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، قَالَ : سَأَلْتُ عَطَائً ؟ فَقَالَ : أَمَّا أَنْتُمْ فَالطَّوَافُ ، وَأَمَّا أَہْلُ مَکَّۃَ فَالصَّلاَۃُ۔",,,15273,,
15274,"حدَّثَنَا وَکِیعٌ ، عَنْ عُمَرَ بْنِ ذَرٍّ ، قَالَ : سَمِعْتُ مُجَاہِدًا یَقُولُ : الصَّلاَۃُ لأَہْلِ مَکَّۃَ أَفْضَلُ۔",,,15274,,
15275,"حدَّثَنَا جَرِیرٌ ، عَنْ عُمَرَ بْنِ ذَرٍّ ، قَالَ : سَمِعْتُ مُجَاہِدًا یَقُولُ : الصَّلاَۃُ لأَہْلِ مَکَّۃَ أَفْضَلُ ، وَالطَّوَافُ لأَہْلِ الآفَاقِ أَفْضَلُ۔",,,15275,,
15276,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ زَمْعَۃَ ، عَنِ ابْنِ طَاوُوس ، قَالَ : قُلْتُ لَہُ : ہَلْ کَانَ أَبُوکَ یَرْفَعُ صَوْتَہُ بِالتَّلْبِیَۃِ ؟ قَالَ : بَیْنَ ذَلِکَ۔",,,15276,,
15277,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، عَنْ مَکْحُولٍ ، قَالَ : التَّلْبِیَۃُ شِعَارُ الْحَجِّ ، فَأَکْثِرُوا مِنَ التَّلْبِیَۃِ عِنْدَ کُلِّ شَرَفٍ ، وَفِی کُلِّ حِینٍ ، وَأَکْثِرُوا مِنَ التَّلْبِیَۃِ وَأَظْہِرُوہَا۔",,,15277,,
15278,"حدَّثَنَا أَبُو نُعَیْمٍ ، عَنْ حَسَنِ بْنِ فُرَاتٍ ، قَالَ : قَالَ لَنَا ابْنُ أَبِی مُلَیْکَۃَ : أَمُحْرِمُونَ أَنْتُمْ ؟ قُلْنَا : نَعَمْ ، قَالَ : فَلَبُّوا۔",,,15278,,
15279,"حدَّثَنَا ابْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ فِی الَّذِی یُلَبِّی ، قَالَ : یُسْمِعُ مَنْ یَلِیہِ۔",,,15279,,
15280,"حدَّثَنَا الثَّقَفِیُّ، عَنْ أَیُّوبَ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ، قَالَ: سُئِلَ ابْنُ عَبَّاسٍ: مَا بَرُّ الْحَجِّ؟ قَالَ: الْعَجُّ ، وَالثَّجَّ۔",,,15280,,
15281,"حدَّثَنَا سَہْلُ بْنُ یُوسُفَ، عَنْ حُمَیْدٍ، عَنْ بَکْرٍ، قَالَ: کُنْتُ مَعَ ابْنِ عُمَرَ فَلَبَّی حَتَّی أَسْمَعَ مَا بَیْنَ الْجَبَلَیْنِ۔",,,15281,,
15282,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ یَعْقُوبَ بْنِ زَیْدٍ ، قَالَ : کَانَ أَصْحَابُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لاَ یَبْلُغُونَ الرَّوْحَائَ ، حَتَّی تُبَحَّ أَصْوَاتُہُمْ مِنْ شِدَّۃِ تَلْبِیَتِہِمْ۔",,,15282,,
15283,حدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ حِزَامِ بْنِ ہِشَامٍ ، عَنْ أَبِیہِ ؛ أَنَّ عُمَرَ کَانَ یُلَبِّی عَلَی الصَّفَا وَالْمَرْوَۃِ ، وَیَشْتَدَّ صَوْتَہُ ، وَیُعْرَفُ صَوْتُہُ بِاللَّیْلِ ، وَلاَ یُرَی وَجْہُہُ۔,,,15283,,
15284,"حدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی بَکْرٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ أَبِی بَکْرٍ ، عَنْ خَلاَّدِ بْنِ السَّائِبِ ، عَنْ أَبِیہِ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : جَائَنِی جِبْرِیلُ فَأَمَرَنِی أَنْ آمُرَ أَصْحَابِی یَرْفَعُونَ أَصْوَاتَہُمْ بِالإِہْلاَلِ۔ (ترمذی 829۔ احمد 4/55)",,,15284,,
15285,"حدَّثَنَا أَبُو نُعَیْمٍ ، عَنْ إِسْرَائِیلَ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ رُفَیْعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : ارْفَعُوا أَصْوَاتَکُمْ بِالتَّلْبِیَۃِ ۔ وَعَنِ ابْنِ الزُّبَیْرِ ، مِثْلُ ذَلِکَ۔",,,15285,,
15286,"حدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی لَبِیدٍ ، عَنِ الْمُطَّلِبِ بْنِ عَبْدِ اللہِ بْنِ حَنْطَبٍ ، عَنْ خَلاَّدِ بْنِ السَّائِبِ ، عَنْ زَیْدِ بْنِ خَالِدٍ الْجُہَنِیِّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : جَائَنِی جِبْرِیلُ عَلَیْہِ السَّلاَمُ ، فَقَالَ : مُرْ أَصْحَابَکَ یَرْفَعُوا أَصْوَاتَہُمْ بِالتَّلْبِیَۃِ ، فَإِنَّہَا شِعَارُ الْحَجِّ۔\n\n(احمد 5/192۔ ابن حبان 3803)",,,15286,,
15287,"حدَّثَنَا وَکِیعٌ ، عَنْ إِبْرَاہِیمَ بْنِ یَزِیدَ ، عَنْ مُحَمَّدِ بْنِ عَبَّادِ بْنِ جَعْفَرٍ الْمَخْزُومِیِّ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَفْضَلُ الْحَجِّ : الْعَجُّ وَالثَّجُّ۔\n\nالْعَجُّ : الْعَجِیجُ بِالتَّلْبِیَۃِ ، وَالثَّجُّ : نَحْرُ الْبُدْنِ۔ (ترمذی 2998)",,,15287,,
15288,"حدَّثَنَا وَکِیعٌ ، عَنْ کَثِیرِ بْنِ زَیدٍ ، عَنِ الْمُطَّلِبِ بْنِ عَبْدِ اللہِ ، قَالَ : کَانَ أَصْحَابُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَرْفَعُونَ أَصْوَاتَہُمْ بِالتَّلْبِیَۃِ ، حَتَّی تُبَحَّ أَصْوَاتُہُمْ ، وَکَانُوا یَضْحَونَ لِلشَّمْسِ إِذَا أَحْرَمُوا۔",,,15288,,
15289,"حدَّثَنَا الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، قَالَ: رَأَیْتُ سَعِیدَ بْنَ جُبَیْرٍ یُوقِظُ أَنَاسًا مِنْ أَہْلِ الْیَمَنِ فِی الْمَسْجِدِ وَیَقُولُ: قُومُوا لَبُّوا ، فَإِنَّ زِینَۃَ الْحَجِّ التَّلْبِیَۃُ۔",,,15289,,
15290,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانَ یُقَالُ : زِینَۃُ الْحَجِّ التَّلْبِیَۃُ۔",,,15290,,
15291,"حدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ ، عَنْ مَنْصُورِ بْنِ أَبِی الأَسْوَدِ ، عَنِ الأَعْمَشِ ، عَنِ الْمُسَیَّبِ بْنِ رَافِعٍ ، قَالَ : کَانَ ابْنُ الزُّبَیْرِ یَقُولُ : التَّلْبِیَۃُ زِینَۃُ الْحَجِّ۔",,,15291,,
15292,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : شِعَارُ الْحَجِّ التَّلْبِیَۃُ",,,15292,,
15293,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَعَطَائٍ ، قَالاَ : لَیْسَ عَلَی أَہْلِ مَکَّۃَ رَمَلٌ ، وَلاَ عَلَی مَنْ أَہَلَّ مِنْہَا ، إِلاَّ أَنْ یَجِیئَ أَحَدٌ مِنْ أَہْلِ مَکَّۃَ مِنْ خَارِجٍ۔",,,15293,,
15294,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، قَالَ : کَانَ ابْنُ عُمَرَ لاَ یَرْمُلُ إِذَا أَہَلَّ مِنْ مَکَّۃَ۔",,,15294,,
15295,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حُمَیْدٍ ، قَالَ : أَہْلَلْنَا أَنَا وَبَکْرٌ مِنْ مَکَّۃَ ، فَطُفْنَا بِالْبَیْتِ وَرَمَلْنَا۔",,,15295,,
15296,"حدَّثَنَا الثَّقَفِیُّ ، عَنْ حَبِیبٍ ، قَالَ : سُئِلَ عَطَائٌ عَنِ الْمُجَاوِرِ إِذَا أہَلَّ مِنْ مَکَّۃَ ، ہَلْ یَسْعَی الأَشْوَاطَ الثَّلاَثَۃَ ؟ قَالَ : إِنَّہُمْ یَسْعَوْنَ ، فَأَمَّا ابْنُ عَبَّاسٍ ، فَإِنَّہُ قَالَ : إِنَّمَا ذَلِکَ عَلَی أَہْلِ الآفَاقِ۔",,,15296,,
15297,"حدَّثَنَا زَیْدُ بْنُ حُبَابٍ، عَنْ حَرْبِ بْنِ سُرَیْجٍ، أَوْ شُرَیْحٍ، عَنْ أَبِی جَعْفَرٍ، قَالَ: لَیْسَ عَلَی أَہْلِ مَکَّۃَ رَمَلٌ۔",,,15297,,
15298,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، قَالَ : لاَ رَمَلَ یَوْمَ النَّحْرِ۔",,,15298,,
15299,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ خُثَیْمٍ ، عَنْ مُجَاہِدٍ ، قَالَ : رَأَیْتُہُ یَرْمُلُ یَوْمَ النَّحْرِ۔",,,15299,,
15300,"حدَّثَنَا ابْنُ أَبِی عَدِیٍّ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : لَیْسَ فِی طَوَافِ النَّحْرِ رَمَلٌ۔",,,15300,,
15301,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ إِسْمَاعِیلَ ، عَنْ وَبَرَۃَ بن عَبْدِ الرَّحْمَنِ ، قَالَ : ذُکِرَ لابْنِ عُمَرَ التَّلْبِیَۃُ یَوْمَ عَرَفَۃَ ، فَقَالَ : التَّکْبِیرُ أَحَبُّ إلَیَّ۔",,,15301,,
15302,"حدَّثَنَا أَبُو نُعَیْمٍ، عَنْ مَعْمَرٍ، عَنْ أَبِی جَعْفَرٍ، أَنَّہُ قَالَ: اِقْطَعِ التَّلْبِیَۃَ إِذَا انْطَلَقْتَ إِلَی عَرَفَۃَ، وَکَبِّرْ وَہَلِّلْ۔",,,15302,,
15303,"حدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، قَالَ : کُنْتُ مَعَ ابْنِ مَسْعُودٍ بِعَرَفَۃَ فَلَبَّی ، فَقَالَ رَجُلٌ : مَنْ ہَذَا الْمُلَبِّی ، فِی ہَذَا الْیَوْمِ ؟ فَالْتَفَتَ إِلَیْہِ ابْنُ مَسْعُودٍ ، فَقَالَ : لَبَّیْکَ عَدَدَ التُّرَابِ لَبَّیْکَ۔",,,15303,,
15304,"حدَّثَنَا ابْنُ فُضَیْلٍ ، وَحَفْصٌ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عَبْدِ اللہ بْنِ أَبِی سَلَمَۃَ ، عَنِ ابْنِ عُمَرَ ، قَالَ : غَدَوْنَا مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِنْ مِنًی إِلَی عَرَفَاتٍ ، فَمِنَّا الْمُکَبِّرُ وَمِنَّا الْمُلَبِّی۔\n\n(ابوداؤد 1812۔ احمد 2/22)",,,15304,,
15305,"حدَّثَنَا وَکِیعٌ ، عَنْ زِیَادِ بْنِ أَبِی مُسْلِمٍ ، قَالَ : سَمِعْتُ أَبَا الْعَالِیَۃِ ، قَالَ : سَمِعْتُ ابْنَ عَبَّاسٍ بِعَرَفَۃَ یَقُولُ: لَبَّیْکَ اللَّہُمَّ لَبَّیْکَ۔",,,15305,,
15306,"حدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ حَبِیبٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عنِ ابْنِ عَبَّاسٍ ، قَالَ : ذُکِرَ لَہُ أَنَّ مُعَاوِیَۃَ نَہَی عَنِ التَّلْبِیَۃِ ، فَجَائَ حَتَّی أَخَذَ بِعَمُودَیِ الْفُسْطَاطِ ، ثُمَّ لَبَّی ، ثُمَّ قَالَ : عَلِمَ أَنَّ عَلِیًّا کَانَ یُلَبِّی فِی ہَذَا الْیَوْمِ ، فَأَحَبَّ أَنْ یُخَالِفَہُ",,,15306,,
15307,"حدَّثَنَا وَکِیعٌ ، عَنْ إِسْمَاعِیلَ ، عَنْ إِبْرَاہِیمَ ، لَبَّی ابْنُ مَسْعُودٍ بِعَرَفَۃَ ، فَقِیلَ : مَنْ ہَذَا الْمُلَبِّی ؟ فَقِیلَ : ابْنُ مَسْعُودٍ ، فَسَکَتُوا۔",,,15307,,
15308,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ دَاوُدَ ، عَنْ عِکْرِمَۃَ بْنِ خَالِدٍ ، قَالَ : لَبَّی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ وَاقِفٌ بِعَرَفَاتٍ۔",,,15308,,
15309,"حدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی یَعْفُورٍ ، قَالَ : کُنْتُ أَسِیرُ مَعَ ابْنِ عُمَرَ ، وَابْنِ الْحَنَفِیَّۃِ مِنْ مِنًی إِلَی عَرَفَاتٍ ، فَکَانَ ابْنُ عُمَرَ یُکَبِّرُ ، وَکَانَ ابْنُ الْحَنَفِیَّۃِ یُلَبِّی۔",,,15309,,
15310,"حدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ مَالِکِ بْنِ أَنَسٍ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ أَبی بَکْرٍ الثَّقَفِیِّ ، قَالَ : سَأَلْتُ أَنَسًا : کَیْفَ کُنْتُمْ تَصْنَعُونَ مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ قَالَ : کَانَ یُلَبِّی الْمُلَبِّی فَلاَ یُنْکَرُ عَلَیْہِ ، وَیُکَبِّرُ الْمُکَبِّرُ فَلاَ یُنْکَرُ عَلَیْہِ۔ (بخاری 970۔ مسلم 933)",,,15310,,
15311,حدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ إِسْمَاعِیلَ بْنِ عَبْدِ الْمَلِکِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، وَعَطَائٍ ؛ أَنَّہُمَا کَانَ یُصَلِّیَانِ فِی الْمَسْجِدِ الْحَرَامِ ، وَیُلَبِّیَانِ بِالْحَجِّ إِذَا خَرَجَا مِنَ الْمَسْجِدِ ، وَیُؤَخِّرَانِ الطَّوَافَ۔,,,15311,,
15312,"حدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ عَبْدِ اللہِ بْنِ الْمُؤَمَّلِ ، قَالَ : رَأَیْتُ ابْنَ أَبِی مُلَیْکَۃَ طَافَ بِالْبَیْتِ وَبَیْنَ الصَّفَا وَالْمَرْوَۃِ ، قَبْلَ أَنْ یَخْرُجَ إِلَی مِنًی۔",,,15312,,
15313,"حدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ أَبِی سُفْیَانَ ، قَالَ : سَأَلْتُ سَالِمًا عَنِ الرَّجُلِ یُحْرِمُ بِالْحَجِّ یَطُوفُ قَبْلَ أَنْ یَخْرُجَ، أَوْ بَعْدَ مَا یَرْجِعُ ؟ قَالَ : ہُوَ مِثْلُ الدَّیْنِ ، مَا عَجَّلْتَ فَہُوَ خَیْرٌ۔",,,15313,,
15314,"حدَّثَنَا ابْنُ مَہْدِیٍّ، عَنْ مُحَمَّدِ بْنِ عَبْدِ اللہِ، قَالَ: سَأَلْتُ الْقَاسِمَ بْنَ مُحَمَّدٍ عَنْہُ؟ فَقَالَ: کُلَّ ذَلِکَ حَسَنٌ۔",,,15314,,
15315,"حدَّثَنَا عَبْدُ الْوَہَّابِ ، عَنْ حَبِیبٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ کَانَ یَقُولُ : الطَّوَافُ بَیْنَ الصَّفَا وَالْمَرْوَۃِ لأَہْلِ مَکَّۃَ ، بَعْدَ أَنْ یَرْجِعُوا مِنْ مِنًی۔",,,15315,,
15316,حدَّثَنَا حَفْصٌ ، عَنْ جَعْفَرِ بْنِ مُحَمَّدٍ ، عَنْ أَبِیہِ ، عَنْ عَلِیِّ بْنِ حُسَیْنٍ ، عَنِ ابْنِ عَبَّاسٍ ، عَنِ الْفَضْلِ بْنِ عَبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لَمْ یَزَلْ یُلَبِّی حَتَّی رَمَی جَمْرَۃَ الْعَقَبَۃِ ، فَرَمَاہَا بِسَبْعِ حَصَیَاتٍ ، یُکَبِّرُ مَعَ کُلِّ حَصَاۃٍ۔,,,15316,,
15317,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِِبْرَاہِیمَ ، عَن عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، قَالَ : رَمَی عَبْدُ اللہِ جَمْرَۃَ الْعَقَبَۃِ مِنْ بَطْنِ الْوَادِی ، یُکَبِّرُ مَعَ کُلِّ حَصَاۃٍ۔",,,15317,,
15318,"حدَّثَنَا مَحْبُوبٌ ، عَنْ أَبِی سَعِیدٍ الْخُلْقَانِیِّ ، قَالَ : رَأَیْتُ سَالِمَ بْنَ عَبْدِ اللَّہُ یَرْمِی جَمْرَۃَ الْعَقَبَۃِ مِنْ بَطْنِ الْوَادِی ، یُکَبِّرُ مَعَ کُلِّ حَصَاۃٍ تَکْبِیرَۃً۔",,,15318,,
15319,"حدَّثَنَا أَبُو عَاصِمٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ فِی رَجُلٍ وَقَعَتْ مِنْہُ حَصَاتَانِ عِنْدَ الْجَمْرَۃِ ، قَالَ : یُکَبِّرُ مَعَ کُلِّ وَاحِدَۃٍ مِنْہُمَا تَکْبِیرَۃً۔",,,15319,,
15320,حدَّثَنَا أَبُو عَاصِمٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یُکَبِّرُ مَعَ کُلِّ حَصَاۃٍ تَکْبِیرَۃً۔,,,15320,,
15321,حدَّثَنَا ابْنُ مُسْہِرٍ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنْ سُلَیْمَانَ بْنِ عَمْرِو بْنِ الأَحْوَص ، عَنْ أُمِّہِ ؛ أَنَّہَا رَأَتِ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ اسْتَبْطَنَ الْوَادِیَ ، فَرَمَی الْجَمْرَۃَ بِسَبْعِ حَصَیَاتٍ ، یُکَبِّرُ مَعَ کُلِّ حَصَاۃٍ۔,,,15321,,
15322,حدَّثَنَا غُنْدَرٌ، عَنْ شُعْبَۃَ، عَنْ یَحْیَی بْنِ سَعِیدٍ، عَنِ الْقَاسِمِ؛ أَنَّہُ رَمَی جَمْرَۃَ الْعَقَبَۃِ، وَکَبَّرَ مَعَ کُلِّ حَصَاۃٍ۔,,,15322,,
15323,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی مِجْلَزٍ ، أَنَّ جِبْرِیلَ عَلَیْہِ السَّلاَمُ أَعْطَی إبْرَاہِیمَ سَبْعَ حَصَیَاتٍ ، ثُمَّ انْطَلَقَا إلَی الْعَقَبَۃِ ، فَعَرَضَ لَہُمَا الشَّیْطَانُ ، فَقَالَ لَہُ : ارْمِ وَکَبِّرْ ، قَالَ : فَرَمَیَا وَکَبَّرَا مَعَ کُلِّ رَمْیَۃٍ ، حَتَّی أَفَلَ الشَّیْطَانُ ، ثُمَّ صَنَعَ مِثْلَ ذَلِکَ فِی الْجَمْرَتَیْنِ الأُخْریَیْنِ۔",,,15323,,
15324,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : لَمْ یَکُنْ یُرَخِّصُ فِی تَرْکِ افْتِتَاحِ الْحَجَرِ الأَسْوَدِ ، وَیَخْتِمُ بِہِ فِی أَوَّلِ طَوَافٍ یَطُوفُہُ یَوْمَ النَّحْرِ وَیَوْمَ النَّفْرِ۔",,,15324,,
15325,حدَّثَنَا أَبُو أُسَامَۃَ، عَنْ ہِشَامٍ، عَنِ الْحَسَنِ؛ أَنَّہُ کَانَ یُعْجِبُہُ أَنْ یَسْتَلِمَ الْحَجَرَ حِینَ یَفْتَتِحُ، وَحِینَ یَخْتِمُ۔,,,15325,,
15326,حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ أَنَّہُ کَانَ یَأْتِی الْحَجَرَ الأَسْوَدَ فَیَخْتِمُ بِہِ ، ثُمَّ یَأْتِی أَہْلَہُ۔,,,15326,,
15327,"حدَّثَنَا عُبَیْدُ اللہِ ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، قَالَ : سَمِعْتُ ابْنَ سَابِطٍ یَقُولُ لِرَجُلٍ قَامَ یَطُوفُ ، وَأَرَادَ أَنْ یَسْتَلِمَ الرُّکْنَ الْیَمَانِی یَبْدَأُ بِہِ ، فَقَالَ ابْنُ سَابِطٍ : لاَ تَبْدَأَنَّ مِنْ أَوَّل مِنَ الأَسْوَدِ ، إذَا بَدَأْتَ فِی طَوَافِکَ۔",,,15327,,
15328,"حدَّثَنَا حُمَیْدٌ ، عَنْ حُسَیْنِ بْنِ عُقَیْلٍ ، عَنِ الضَّحَّاکِ ، أَنَّہُ قَالَ : تَسْتَلِمُ فِی کُلِّ مَرَّۃٍ إِنْ قَدَرْت عَلَیْہِ ، وَإِلاَّ افْتَتَحْت بِہِ وَخَتَمْت۔",,,15328,,
15329,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : إنِ اسْتَطَعْتَ أَنْ تَسْتَلِمَ فِی کُلِّ طَوْفَۃٍ فَاسْتَلِمْہُ ، وَإِلاَّ فَإِذَا مَرَرْت بِہِ فَاسْتَقْبِلْہُ وَکَبِّر ، وَإِنْ شِئْتَ فَاسْتَفْتِحْ بِہِ وَاخْتِمْ۔",,,15329,,
15330,"حدَّثَنَا وَکِیعٌ ، عَنْ ہِلاَلِ بْنِ أَبِی مَیْمُونَۃَ ، قَالَ : رَأَیْتُ أَنَسًا یَطُوفُ فَإِذَا انْتَہَی إلَی الْحَجَرِ کَبَّرَ ، وَیَفْتَتِحُ بِہِ وَیَخْتِمُ بِہِ۔",,,15330,,
15331,حدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَدَأَ بِالْحَجَرِ الأَسْوَدِ ، وَرَمَلَ مِنَ الْحَجَرِ إلَی الْحَجَرِ۔,,,15331,,
15332,"حدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ أَفْلَحَ ، عَنِ الْقَاسِمِ بْنِ مُحَمَّدٍ ، عَنْ عَائِشَۃَ قَالَتْ : آذَنَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِالرَّحِیلِ ، فَمَرَرْنَا بِالْبَیْتِ ، فَطَافَ بِہِ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ثُمَّ خَرَجَ قَبْلَ أَنْ یُصْبِحَ۔",,,15332,,
15333,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا انْتَہَی الرَّجُلُ إِلَی الأَبْطَحِ فَلْیَضَعْ رَحْلَہُ ، ثُمَّ لْیَزُرِ الْبَیْتَ ، فَلْیَرْتَحِلْ عَنْہَا ، إِنْ شَائَ لَیْلاً ، وَإِنْ شَائَ نَہَارًا ، بَعْدَ أَنْ یَنْزِلَ فِیہِ وَیَضَعَ نَعْلَہُ۔",,,15333,,
15334,"حدَّثَنَا أَبُو مُطِیعٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : یَفْرُغُ مِنْ کُلِّ شَیْئٍ لَہُ ، فَإِذَا لَمْ یَبْقَ لَہُ إِلاَّ الرُّکُوبُ رَکِبَ ، ثُمَّ طَافَ بِالْبَیْتِ ، ثُمَّ مَضَی۔",,,15334,,
15335,"حدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یَکْرَہُونَ أَنْ یَبْنُوا حَوْلَ الْکَعْبَۃِ بِنَائً ، یُشْرِفُ عَلَیْہَا",,,15335,,
15336,"حدَّثَنَا أَبُو خَالِدٍ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، قَالَ : کَانُوا یَکْرَہُونَ أَنْ یَبْنُوا بِنَائً عِنْدَ الصَّفَا وَالْمَرْوَۃِ وَیُطِیلُوہُ ، کَیْ یَبْدُوَ لَہُمُ الْبَیْتُ۔",,,15336,,
15337,"حدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، قَالَ : سَمِعْتُ عَبْدَ اللہِ بْنَ أَبِی أَوْفَی ، وَسَعِیدَ بْنَ جُبَیْرٍ یَقُولاَنِ : الْحَجُّ الأَکْبَرُ یَوْمُ النَّحْرِ۔",,,15337,,
15338,"حدَّثَنَا وَکِیعٌ ، عَنْ عُمَرَ بْنِ الْوَلِیدِ الشَّنِّیِّ ، عَنْ شِہَابِ بْنِ عَبَّادٍ الْعَصَرِی ، عَنْ أَبِیہِ ، قَالَ : قَالَ عُمَرُ : الْحَجُّ الأَکْبَرُ یَوْمُ عَرَفَۃَ ، فَذَکَرْتُہُ لِسَعِیدِ بْنِ الْمُسَیَّبِ ، فَقَالَ : أُخْبِرک عَنِ ابْنِ عُمَرَ ، أَنَّ عُمَرَ قَالَ : الْحَجُّ الأَکْبَرُ یَوْمُ عَرَفَۃَ۔",,,15338,,
15339,"حدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : سَأَلْتُ مُحَمَّدًا عَنْ یَوْمِ الْحَجِّ الأَکْبَرِ ؟ فَقَالَ : کَانَ یَوْمًا وَافَقَ فِیہِ حَجَّ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَحَجَّ أَہْلِ الْمِلَلِ۔",,,15339,,
15340,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : سَأَلْتُ عَبْدَ اللہِ بْنَ شَدَّادٍ عَنِ الْحَجِّ الأَکْبَرِ ؟ فَقَالَ : الْحَجُّ الأَکْبَرُ یَوْمُ النَّحْرِ۔",,,15340,,
15341,"حدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : یَوْمُ الْحَجُّ الأَکْبَرِ یَوْمُ النَّحْرِ۔",,,15341,,
15342,"حدَّثَنَا وَکِیعٌ ، عَنْ سَعِیدٍ ، عَنِ الْحَکَمِ ، عَنْ یَحْیَی بْنِ الْجَزَّارِ ، عَنْ عَلِیٍّ ؛ أَنَّہُ لَقِیَہُ رَجُلٌ یَوْمَ النَّحْرِ ، فَأَخَذَ بِلِجَامِہِ فَسَأَلَہُ عَنِ الْحَجِّ الأَکْبَرِ ؟ فَقَالَ : ہُوَ ہَذَا الْیَوْمُ۔",,,15342,,
15343,"حدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ عَبْدِ اللہِ بْنِ سِنَانٍ ، قَالَ : حدَّثَنَا الْمُغِیرَۃُ بْنُ شُعْبَۃَ ، عَلَی بَعِیرٍ ، فَقَالَ : ہَذَا یَوْمُ النَّحْرِ ، وَہَذَا یَوْمُ الأَضْحَی ، وَہَذَا یَوْمُ الْحَجِّ الأَکْبَرِ۔",,,15343,,
15344,"حدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : الْحَجُّ الأَکْبَرُ یَوْمٌ یُہْرَاقُ فِیہِ الدَّمُ ، وَیَحِلَّ فِیہِ الْحَرَامُ۔",,,15344,,
15345,"حدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، وَسُفْیَانَ ، عَنْ عَبْدِ الْمَلِکِ بْنِ عُمَیْرٍ ، وَعَیَّاشٍ الْعَامِرِیِّ ، أَنَّہُمَا سَمِعَا ابْنَ أَبِی أَوْفَی یَقُولُ : الْحَجُّ الأَکْبَرُ یَوْمُ النَّحْرِ۔",,,15345,,
15346,"حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ سِمَاکٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : الْحَجُّ الأَکْبَرُ یَوْمُ النَّحْرِ۔",,,15346,,
15347,"حدَّثَنَا عُبَیْدُ اللہِ ، عَنْ إسْرَائِیلَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی جُحَیْفَۃَ ، قَالَ : الْحَجُّ الأَکْبَرُ یَوْمُ النَّحْرِ",,,15347,,
15348,"حدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ یَزِیدَ بْنِ الأَصَمِّ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : سَأَلَہُ رَجُلٌ ، فَقَالَ : إنَّ أَبِی مَاتَ وَلَمْ یَحُجَّ قَطُّ ، أَفَأَحُجُّ عَنْہُ ؟ قَالَ : نَعَمْ ، فَإِنَّک إِنْ لَمْ تَزِدْہُ خَیْرًا ، لَمْ تَزِدْہُ شَرًّا۔",,,15348,,
15349,"حدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ طَارِقٍ ، قَالَ : کُنْتُ جَالِسًا عِنْدَ سَعِیدِ بْنِ الْمُسَیَّبِ فَأَتَاہُ رَجُلٌ ، فَقَالَ : إِنَّ أَبِی کَانَ کَثِیرَ الْجِہَادِ وَلَمْ یَحُجَّ ، أَفَأَحُجُّ عَنْہُ ؟ فَقَالَ لَہُ سَعِیدٌ : قَدْ کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَخَّصَ لِرَجُلٍ حَجَّ عَنْ أَبِیہِ ، وَہَلْ ہُوَ إِلاَّ دَیْنٌ",,,15349,,
15350,"حدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ قُدَامَۃَ بْنِ عَبْدِ اللہِ الرُّؤَاسِیِّ ، قَالَ : سَأَلْتُ سَعِیدَ بْنَ جُبَیْرٍ عَنْ أَخٍ لِی مَاتَ وَلَمْ یَحُجَّ قَطُّ ، أَفَأَحُجُّ عَنْہُ ؟ قَالَ : ہَلْ کَانَ تَرَکَ مِنْ وَلَدٍ ؟ قَالَ : قُلْتُ : لاَ ، إِلاَّ صَبِیًّا صَغِیرًا ، قَالَ : حُجَّ عَنْہُ ، فَإِنَّہُ لَوْ وَجَدَ رَسُولاً لَاَرْسَلَ إِلَیْک أَنْ عَجِّلْ بِہَا ، قُلْتُ : أَحُجُّ عَنْہُ مِنْ مَالِی ، أَوْ مِنْ مَالِہِ ؟ قَالَ : لاَ، بَلْ مِنْ مَالِہِ ۔ وَسَأَلْتُ إبْرَاہِیمَ عَنْہُ ؟ فَقَالَ : حُجَّ عَنْہُ ۔ قَالَ : وَسَأَلْتُ الضَّحَّاکَ ؟ فَقَالَ : حُجَّ عَنْہُ ، فَإِنَّ ذَلِکَ مُجْزِئٌ عَنْہُ ، وَحُجَّ مِنْ مَالِہِ۔",,,15350,,
15351,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، عَنْ رَجُلٍ یُقَالُ لَہُ : یُوسُفُ ، کَانَ یَکُونُ مَعَ ابْنِ الزُّبَیْرِ ، عَنْ عَبْدِ اللہِ بْنِ الزُّبَیْرِ ، قَالَ : جَائَ رَجُلٌ إِلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : یَا رَسُولَ اللہِ ، إِنَّ أَبِی مَاتَ وَلَمْ یَحُجَّ ، أَفَأَحُجُّ عَنْہُ ؟ قَالَ : أَنْتَ أَکْبَرُ وَلَدِہِ ؟ قَالَ : نَعَمْ ، قَالَ : فَحُجَّ عَنْ أَبِیکَ ، أَفَرَأَیْت لَوْ کَانَ عَلَی أَبِیکَ دَیْنٌ ، فَقَضَیْتَہُ ؟",,,15351,,
15352,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَسْلَمَ الْمُنْقِرِیِّ ، عَنْ عَطَائٍ ، قَالَ : یُحَجُّ عَنِ الْمَیِّتِ ، وَإِنْ لَمْ یُوصِ۔",,,15352,,
15353,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : لاَ یَحُجُّ أَحَدٌ عَنْ أَحَدٍ، وَلاَ یَصمُ أَحَدٌ عَنْ أَحَدٍ۔",,,15353,,
15354,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ یَحُجُّ أَحَدٌ عَنْ أَحَدٍ۔",,,15354,,
15355,"حدَّثَنَا وَکِیعٌ ، عَنْ أَفْلَحَ ، عَنِ الْقَاسِمِ ، قَالَ : لاَ یَحُجُّ أَحَدٌ عَنْ أَحَدٍ۔",,,15355,,
15356,"حدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنِ الْحَکَمِ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ یُقْضَی عَنِ الْمَیِّتِ حَجٌّ۔",,,15356,,
15357,"حدَّثَنَا وَکِیعٌ ، عَنِ الْعُمَرِیِّ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : لَوْ کُنْتُ أَنَا تَصَدَّقْت عَنْہُ ، وَأَہْدَیْت",,,15357,,
15358,"حدَّثَنَا جرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَن زِیَادِ بْنِ لَبِیدٍ ، قَالَ : قَالَ شُرَیْحٌ : إِذَا أَہْلَلْتَ بِعُمْرَۃٍ وَحَجَّۃٍ ، ثُمَّ قَدِمْتَ مَکَّۃَ ، فَلاَ یَحِلَّنَّ مِنْکَ حَرَامٌ إِلَی یَوْمِ النَّحْرِ ، فَإِنَّہُمْ سَیَقُولُونَ لَکَ : إِذَا طُفْتَ لِعُمْرَتِکَ وَحَجَّتِکَ فَأَحِلَّ ، فَلاَ تُطِعْہُمْ فِی ذَلِکَ۔",,,15358,,
15359,حدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ؛ أَنَّ الْحُسَیْنَ بْنَ عَلِیٍّ ، وَشُرَیْحًا قَرَنَا فَلَمْ یَحِلَّ وَاحِدٌ مِنْہُمَا إِحْرَامًا إِلَی یَوْمِ النَّحْرِ,,,15359,,
15360,"حدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ مَنْصُورٍ ، عَنْ مَالِکِ بْنِ الْحَارِثِ ، عَنْ أَبِی نَصْرٍ ؛ أَنَّ عَلِیًّا ، قَالَ لَہُ : لَبِّ بِہِمَا جَمِیعًا ، فَإِذَا قَدِمْتَ مَکَّۃَ ، فَطُفْ لَہُمَا طَوَافَیْنِ ؛ طَوَافًا لِعُمْرَتِکَ ، وَطَوَافًا لِحَجَّتِکَ ، وَلاَ تُحِلَّنَّ مِنْکَ حَرَامًا دُونَ یَوْمِ النَّحْرِ۔",,,15360,,
15361,"حدَّثَنَا حَاتِمٌ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ جَابِرٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ لِعَلِیٍّ : مَا قُلْتَ حِینَ فَرَضْتَ الْحَجَّ ؟ قَالَ : قُلْتُ : اللَّہُمَّ إِنِّی أُہِلُّ بِمَا أَہَلَّ بِہِ رَسُولُکَ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : فَإِنَّ مَعِی الْہَدْیَ ، فَلاَ یَحِلُّ مِنْکَ حَرَامٌ ، قَالَ : فَحَلَّ النَّاسُ کُلُّہُمْ وَقَصَّرُوا ، إِلاَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَمَنْ کَانَ مَعَہُ ہَدْیٌ",,,15361,,
15362,حدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، عَنْ عُرْوَۃَ ؛ أَنَّ أَبَا بَکْرٍ وَعُمَرَ کَانَا یَقْدُمَانِ وَہُمَا مُہِلاَّنِ بِالْحَجِّ ، فَلاَ یَحِلُّ مِنْہُمَا حَرَامًا إِلَی یَوْمِ النَّحْرِ۔,,,15362,,
15363,"حدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : مَنْ أَحْرَمَ بِالْحَجِّ وَالْعُمْرَۃِ جَمِیعًا کَفَاہُ طَوَافٌ وَاحِدٌ ، وَلَمْ یَحِلَّ حَتَّی یَقْضِیَ حَجَّتَہُ ، وَیَحِلَّ مِنْہُمَا جَمِیعًا۔",,,15363,,
15364,"حدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ ہِلاَلٍ ، عَنْ أَبِی شُعْبَۃَ ، قَالَ : کُنْتُ بِجَنْبِ ابْنِ عُمَرَ بِعَرَفَۃَ ، وَإِنَّ رُکْبَتِی لَتَمَسُّ رُکْبَتَہُ ، أَوْ فَخِذِی تَمَسُّ فَخِذَہُ ، فَمَا سَمِعْتُہُ یَزِیدُ عَلَی ہَؤُلاَئِ الْکَلِمَاتِ ؛ لاَ إلَہَ لاَ اللَّہُ وَحْدَہُ لاَ شَرِیکَ لَہُ ، لَہُ الْمُلْکُ وَلَہُ الْحَمْدُ وَہُوَ عَلَی کُلِّ شَیْئٍ قَدِیرٌ ، حَتَّی أَفَاضَ مِنْ عَرَفَۃَ إلَی جَمْعٍ۔",,,15364,,
15365,"حدَّثَنَا حُمَیْدٌ ، عَنْ سَعِیدِ بْنِ السَّائِبِ ، عَنْ دَاوُدَ بْنِ أَبِی عاصِمٍ ، قَالَ : وَقَفْت مَعَ سَالِمِ بْنِ عَبْدِ اللہِ بِعَرَفَۃَ ، أَنْظُرُ کَیْفَ یَصْنَعُ ؟ ، فَکَانَ فِی الذِّکْرِ وَالدُّعَائِ حَتَّی أَفَاضَ النَّاسُ۔",,,15365,,
15366,"حدَّثَنَا وَکِیعٌ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ أَخِیہِ ، عَنْ عَلِیٍّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَکْثَرُ دُعَائِی ، وَدُعَائِ الأَنْبِیَائِ قَبْلِی بِعَرَفَۃَ ؛ لاَ إلَہَ إِلاَّ اللَّہُ وَحْدَہُ لاَ شَرِیکَ لَہُ ، لَہُ الْمُلْکُ وَلَہُ الْحَمْدُ ، وَہُوَ عَلَی کُلِّ شَیْئٍ قَدِیرٌ ، اللَّہُمَّ اجْعَلْ فِی قَلْبِی نُورًا ، وَفِی سَمْعِی نُورًا ، وَفِی بَصَرِی نُورًا ، اللَّہُمَّ اشْرَحْ لِی صَدْرِی ، وَیَسِّرْ لِی أَمْرِی ، وَأَعُوذُ بِکَ مِنْ وَسْوَاسِ الصَّدْرِ ، وَشَتَاتِ الأَمْرِ ، وَفِتْنَۃِ الْقَبْرِ ، اللَّہُمَّ إنِّی أَعُوذُ بِکَ مِنْ شَرِّ مَا یَلِجُ فِی اللَّیْلِ ، وَشَرِّ مَا یَلِجُ فِی النَّہَارِ ، وَشَرِّ مَا تَہُبُّ بِہِ الرِّیَاحُ۔\n\n(ترمذی 352۔ ابن خزیمۃ 2841)",,,15366,,
15367,"حدَّثَنَا وَکِیعٌ ، عَنِ النَّضْرِ بْنِ عَرَبِیٍّ ، عَنِ ابْنِ أَبِی حُسَیْنٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: أَکْثَرُ دُعَائِی وَدُعَائِ الأَنْبِیَائِ قَبْلِی بِعَرَفَۃَ ؛ لاَ إلَہَ إِلاَّ اللَّہُ وَحْدَہُ لاَ شَرِیکَ لَہُ ، لَہُ الْمُلْکُ وَلَہُ الْحَمْدُ ، بِیَدِہِ الْخَیْرُ ، یُحْیِی وَیُمِیتُ ، وَہُوَ عَلَی کُلِّ شَیْئٍ قَدِیرٌ",,,15367,,
15368,"حدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ رَجُلٍ ، عَنِ ابْنِ الْحَنَفِیَّۃِ ، قَالَ : قُلْتُ لَہُ : مَا أَفْضَلُ مَا نَقُولُ فِی حَجِّنَا ؟ قَالَ : لاَ إلَہَ إِلاَّ اللَّہُ ، وَاللَّہُ أَکْبَرُ۔",,,15368,,
15369,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ صَدَقَۃَ بْنِ یَسَارٍ ، قَالَ : سَأَلْتُ مُجَاہِدًا عَنْ قِرَائَۃِ الْقُرْآنِ ، أَفْضَلُ یَوْمَ عَرَفَۃَ ، أَوِ الذِّکْرِ ؟ قَالَ : لاَ ، بَلْ قِرَائَۃُ الْقُرْآنِ۔",,,15369,,
15370,"حدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ شَتْرٍ ، قَالَ : قُلْتُ لابْنِ الْحَنَفِیَّۃِ : مَا أَفْضَلُ مَا نَقُولُ فِی حَجِّنَا ؟ قَالَ : لاَ إلَہَ إِلاَّ اللَّہُ ، وَاللَّہُ أَکْبَرُ۔",,,15370,,
15371,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الْعَلاَئِ بْنِ الْمُسَیَّبِ ، عَنْ رَجُلٍ ، مِنْ بَکْرِ بْنِ وَائِلٍ ، قَالَ : سَأَلْتُ ابْنَ عُمَرَ ، قُلْتُ : إنَّا نُکْرِی فِی ہَذَا الْوَجْہِ للْحَجِّ ، وَإِنَّ أُنَاسًا یَزْعُمُونَ أَنْ لاَ حَجَّ لَنَا ، قَالَ : أَلَسْتُمْ تُلَبُّونَ ، وَتَطُوفُونَ بِالْبَیْتِ وَبَیْنَ الصَّفَا وَالْمَرْوَۃِ ، وَتَرْمُونَ الْجِمَارَ ، وَتَقِفُونَ بِالْمَوْقِفِ ؟ قَالُوا : بَلَی ، قَالَ : فَإِنَّکُمْ حُجَّاجٌ ، قَدْ جَائَ رَجُلٌ إِلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَسَأَلَہُ عَنْ مِثْلِ الَّذِی سَأَلْتَنِی عَنْہُ فَلَمْ یُجِبْہُ حَتَّی نَزَلَتْ ہَذِہِ الآیَۃُ : {لَیْسَ عَلَیْکُمْ جُنَاحٌ أَنْ تَبْتَغُوا فَضْلاً مِنْ رَبِّکُمْ} فَدَعَاہُ فَقَرَأَہَا عَلَیْہِ ، ثُمَّ قَالَ : إِنَّکُمْ حُجَّاجٌ۔\n\n(ابوداؤد 1730۔ احمد 2/155)",,,15371,,
15372,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنْ مُسْلِمٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : أَتَاہُ رَجُلٌ ، فَقَالَ : إِنِّی أَکْرَیْتُ نَفْسِی مِنْ قَوْمٍ ، وَوَضَعْتُ عَنْہُمْ مِنْ أَجْرِی مِنْ أَجْلِ الْحَجِّ ، فَہَلْ یُجْزِئُ ذَلِکَ عَنِّی ؟ فَقَالَ ابْنُ عَبَّاسٍ : ہَذَا مِنَ الَّذِینَ قَالَ اللَّہُ تَعَالَی : {أُولَئِکَ لَہُمْ نَصِیبٌ مِمَّا کَسَبُوا وَاللَّہُ سَرِیعُ الْحِسَابِ}",,,15372,,
15373,"حدَّثَنَا غُنْدَرٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ سُئِلَ عَنِ الأَجِیرِ یُؤَاجِرُ نَفْسَہُ إِلَی مَکَّۃَ ، ثُمَّ یُوسِرُ ، قَالَ : یُجْزِئُ عَنْہُ۔",,,15373,,
15374,"حدَّثَنَا وَکِیعٌ ، عَنْ شَرِیکٍ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُوسٍ ، وَمُجَاہِدٍ ؛ فِی التَّاجِرِ وَالْکَرِیِّ ، قَالُوا : یُجْزِئُہُمَا۔",,,15374,,
15375,"حدَّثَنَا وَکِیعٌ ، عَنِ الْحَسَنِ أَبِی طَالُوتَ ، عَنْ أَبِی السَّلِیلِ ، عَنِ ابْنِ عُمَرَ ؛ فِی الرَّجُلِ یُکْرِی نَفْسَہُ فِی الْحَجِّ ، قَالَ : یُجْزِئُہُ۔",,,15375,,
15376,"حدَّثَنَا أَبُو نُعَیْمٍ ، عَنْ عُمَرَ بْنِ ذَرٍّ ، قَالَ : سَأَلْتُ مُجَاہِدًا عَنِ التَّاجِرِ ، وَالْکَرِیِّ ، وَالأَجِیرِ ؟ قَالَ : لاَ یُنْتَقَصُ الْکَرِیُّ مِنْ حَجِّہِ ، وَلاَ التَّاجِرُ مِنْ حَجِّہِ ، وَلاَ الأَجِیرُ مِنْ حَجِّہِ۔",,,15376,,
15377,"حدَّثَنَا أَبُو نُعَیْمٍ ، وَوَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : سَمِعْتُہُ وَسَأَلَہُ أَعْرَابِیٌّ ، فَقَالَ : إِنِّی أَکْرَیْتُ إِبِلاً وَأَنَا أُرِیدُ الْحَجَّ ، أَیُجْزِئُنِی ؟ قَالَ : لاَ ، وَلاَ کَرَامَۃَ۔",,,15377,,
15378,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : لاَ یُجْزِئُہُ۔",,,15378,,
15379,"حدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ الْجُرَیْرِیِّ ، عَنْ أَبِی السَّلِیلِ ، قَالَ : قُلْتُ لِسَعِیدِ بْنِ الْمُسَیَّبِ : إِنَّ أُنَاسًا یَزْعُمُونَ، أَوْ مَنْ زَعَمَ مِنْہُمْ ، أَنَّ الْکَرِیَّ لاَ حَجَّ لَہُ ؟ قَالَ : بَلْ لَہُ حَجٌّ حَسَنٌ جَمِیلٌ ، إِنِ اتَّقَی اللَّہَ ، وَأَدَّی الأَمَانَۃَ ، وَأَحْسَنَ الصَّحَابَۃَ۔",,,15379,,
15380,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ عَلِیٍّ فِی قَوْلِہِ تعالی : {فَصِیَامُ ثَلاَثَۃِ أَیَّامٍ فِی الْحَجِّ} ، قَالَ : صُمْ قَبْلَ التَّرْوِیَۃِ بِیَوْمٍ ، وَیَوْمَ التَّرْوِیَۃِ ، وَیَوْمَ عَرَفَۃَ ، فَإِنْ فَاتَہُ الصَّوْمُ تَسَحَّرَ لَیْلَۃَ الْحَصبۃِ فَصَامُ ثَلاَثَۃَ أَیَّامٍ ، وَسَبْعَۃً إذَا رَجَعَ۔",,,15380,,
15381,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، وَعِیَاضٌ ، وَجَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، وَمُجَاہِدٍ ، قَالاَ : آخِرُہَا یَوْمُ عَرَفَۃَ۔",,,15381,,
15382,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ حَجَّاجٍ ، قَالَ : سَمِعْتُ أَبَا جَعْفَرٍ یَقُولُ : آخِرُہَا یَوْمُ عَرَفَۃَ۔",,,15382,,
15383,"حَدَّثَنَا ابْنُ مُبَارَکٍ، عَنْ حَجَّاجٍ، عَنْ عَطَائٍ، قَالَ: إِنْ شَائَ صَامَ أَوَّلَ الْعَشْرِ وَوَسَطَہَا، وَآخِرَہَا یَوْمَ عَرَفَۃَ۔",,,15383,,
15384,حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ حَجَّاجٍ ، عَنْ حبیب ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، مِثْلَ قَوْلِ عَطَائٍ۔,,,15384,,
15385,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ حَجَّاجٍ ، عَنِ الْقَاسِمِ بْنِ نَافِعٍ ، عَنْ مُجَاہِدٍ ، قَالَ : آخِرُہَا یَوْمُ عَرَفَۃَ۔",,,15385,,
15386,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنِ حَجَّاجٍ ، قَالَ : انْطَلَقْت أَنَا وَالْحَکَمُ إلَی أَبِی الْوَلِیدِ فَأَخْبَرَنَا ، أَنَّہُ سَمِعَ ابْنَ عُمَرَ یَقُولُ : آخِرُہَا یَوْمُ عَرَفَۃَ۔",,,15386,,
15387,"حَدَّثَنَا ابْنُ مُسْہِرٍ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ فِی قَوْلِہِ تعالی : {فَصِیَامُ ثَلاَثَۃِ أَیَّامٍ فِی الْحَجِّ} قَالَ : قَبْلَ التَّرْوِیَۃِ یَوْمًا وَآخِرُہَا یَوْمُ عَرَفَۃَ۔",,,15387,,
15388,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ مِثْلَہُ۔,,,15388,,
15389,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ ، عَنْ مُجَاہِدٍ ، قَالَ : مَنْ لَمْ یَصُمْ قَبْلَ التَّرْوِیَۃِ بِیَوْمٍ ، ویَوْمَ التَّرْوِیَۃِ ، وَیَوْمَ عَرَفَۃَ ، فَاتَہُ الصَّوْمُ۔",,,15389,,
15390,"حَدَّثَنَا وَکِیعٌ ، عَنْ یُونُسَ بْنِ أَبِی إِسْحَاقَ ، عَنْ وَبَرَۃَ ، عَنِ ابْنِ عُمَرَ وَعُبَیْدِ بْنِ عُمَیْرٍ ، قَالَ ابْنُ عُمَرَ : قبْلَ یَوْمِ التَّرْوِیَۃِ بِیَوْمٍ ، وَیَوْمَ التَّرْوِیَۃِ ، وَیَوْمَ عَرَفَۃَ ، وَقَالَ : عُبَیْدُ بْنُ عُمَیْرٍ : یَصُومُ أَیَّامَ التَّشْرِیقِ۔",,,15390,,
15391,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ إبْرَاہِیمَ بْنِ مَیْسَرَۃَ ، عَنْ طَاوُوسٍ ، وَابْنِ طَاوُوس ، عَنْ أَبِیہِ : یَجْعَلُ الْمُتَمَتِّعُ آخِرَ صَوْمِہِ یَوْمَ عَرَفَۃَ",,,15391,,
15392,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ : {فَصِیَامُ ثَلاَثَۃِ أَیَّامٍ فِی الْحَجِّ} آخِرُہَا یَوْمُ عَرَفَۃَ۔",,,15392,,
15393,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ وَحَفْصٌ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، قَالَ : آخِرُہَا یَوْمُ عَرَفَۃَ۔",,,15393,,
15394,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : یُحْمَلُ الْمَرِیضُ إلَی الْجِمَارِ ، فَإِنَ اسْتَطَاعَ أَنْ یَرْمِیَ فَلْیَرْمِ ، وَإِنْ لَمْ یَسْتَطِعْ فَلْیُوضَعَ الْحَصَی فِی کَفِّہِ ، ثُمَّ یُرْمَی بِہَا مِنْ کَفِّہِ۔",,,15394,,
15395,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : یُشْہَدُ بِالْمَرِیضِ الْمَنَاسِکُ کُلُّہَا ، وَیُطَافُ بِہِ عَلَی مَحْمِلٍ فَإِذَا رَمَی الْجِمَارَ وُضِعَ فِی کَفِّہِ ، ثُمَّ رُمِیَ بِہِ مِنْ کَفِّہِ۔",,,15395,,
15396,"حَدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، قَالَ : یُرْمَی عَنْہُ۔",,,15396,,
15397,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : لاَ تَحُجُّ الْمَرْأَۃُ إِلاَّ مَعَ ذِی مَحْرَمٍ",,,15397,,
15398,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ ابْنِ سِیرِینَ ، أنہ قَالَ : تَخْرُجُ فِی رُفْقَۃٍ فِیہَا رِجَالٌ وَنِسَائٌ۔",,,15398,,
15399,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ قَالَ : تَحُجُّ مع رُفْقَۃٍ فِیہَا رِجَالٌ وَنِسَائٌ وَتَتَّخِذُ سُلَّمًا تَصْعَدُ عَلَیْہِ ، وَلاَ یَقْرَبُہَا الْکَرِی۔",,,15399,,
15400,"حَدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ یَحْیَی بْنِ عَبَّادٍ أَبِی ہُبَیْرَۃَ ، قَالَ : کَتَبَتِ امْرَأَۃٌ مِنْ أَہْلِ الرَّیِّ إلَی إبْرَاہِیمَ ، إِنَّہَا مُوسِرَۃٌ وَلَیْسَ لَہَا بَعْلٌ ، وَلاَ مَحْرَمٌ ، وَلَمْ تَحُجَّ قَطُّ ، فَکَتَبَ إلَیْہَا إبْرَاہِیمُ : إنَّ ہَذَا مِنَ السَّبِیلِ الَّذِی ، قَالَ اللَّہُ وَلَیْسَ لَکِ مَحْرَمٌ ، فَلاَ تَحُجِّی إِلاَّ مَعَ بَعْلٍ ، أَوْ مَحْرَمٍ۔",,,15400,,
15401,"حَدَّثَنَا جَرِیرٌ ، عَنِ ابْنِ شُبْرُمَۃَ ، قَالَ : کَانَ الْحَسَنُ بْنُ أَبِی الْحَسَنِ یُرَخِّصُ لِلْمَرْأَۃِ الَّتِی لَمْ تَحُجَّ قَطُّ أَنْ تَحُجَّ مَعَ الْمَرْأَۃِ الَّتِی مَعَہَا مَحْرَمٌ۔",,,15401,,
15402,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی سَعِیدٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تُسَافِرُ الْمَرْأَۃُ سَفَرًا یَکُونُ ثَلاَثَۃَ أَیَّامٍ فصاعدًا إِلاَّ مَعَ أمہا ، أَوِ ابْنِہَا ، أو أَبِیہَا ، أَوْ أَخِیہَا ، أَوْ زَوْجِہَا ، أَوْ ذِی مَحْرَمٍ۔ (ابوداؤد 1723۔ ترمذی 1169)",,,15402,,
15403,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، أَنَّہُ سُئِلَ عَنِ الْمَرْأَۃِ تُرِیدُ الْحَجَّ وَزَوْجُہَا غَائِبٌ بِخُرَاسَانَ ، فَقَالَ : إذَا کَانَتِ الْفَرِیضَۃُ وَکَانَ لَہَا مَحْرَمٌ فَلاَ بَأْسَ۔",,,15403,,
15404,"حَدَّثَنَا حُمَیْدٌ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ : لاَ تَحُجُّ الْمَرْأَۃُ إِلاَّ مَعَ زَوْجٍ ، أَوْ ذِی مَحْرَمٍ۔",,,15404,,
15405,"حَدَّثَنَا حُمَیْدٍ ، عَنْ حَسَنٍ ، عَنْ عَلِیِّ بْنِ عَبْدِ الأَعْلَی ، قَالَ : سُئِلَ عکْرِمَۃُ ، عَنِ الْمَرْأَۃِ تَحُجُّ مَعَ غَیْرِ ذِی مَحْرَمٍ ، أَوْ زَوْجٍ ، فَقَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ تُسَافِرَ الْمَرْأَۃُ فَوْقَ ثَلاَثَۃٍ إِلاَّ مَعَ ذِی مَحْرَمٍ ، فَکَیْفَ تَصْنَعُ بأُستہا۔",,,15405,,
15406,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لاَ تُسَافِرُ امْرَأَۃٌ فَوْقَ ثَلاَثَۃٍ إِلاَّ مَعَ ذِی مَحْرَمٍ۔ (بخاری 1087۔ مسلم 713)",,,15406,,
15407,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ أَبِی مَعْبَدٍ ، قَالَ : سَمِعْتُ ابْنَ عَبَّاسٍ یَقُولُ سَمِعْت النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَخْطُبُ یَقُولُ : لاَ تُسَافِرُ امْرَأَۃٌ إِلاَّ مَعَ ذِی مَحْرَمٍ فَقَامَ رَجُلٌ ، فَقَالَ : یَا رَسُولَ اللہِ إنَّ امْرَأَتِی خَرَجَتْ حَاجَّۃً وَإِنِّی أُکتتبتُ فِی غَزْوَۃِ کَذَا وَکَذَا ، فَقَالَ : انْطَلِقْ فَحُجَّ مَعَ امْرَأَتِکَ۔\n\n(بخاری 3006۔ مسلم 978",,,15407,,
15408,"حَدَّثَنَا وَکِیعٌ ، عَنْ یُونُسَ ، عَنِ الزُّہْرِیِّ ، قَالَ : ذُکِرَ عِنْدَ عَائِشَۃَ الْمَرْأَۃُ لاَ تُسَافِرُ إِلاَّ مَعَ ذِی مَحْرَمٍ ، فَقَالَتْ عَائِشَۃُ : لَیْسَ کُلُّ النِّسَائِ یَجِدُ مَحْرَمًا۔",,,15408,,
15409,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنْ سَعِیدٍ الْمَقْبُرِیِّ ، عَنْ أَبِیہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تُسَافِرُ امْرَأَۃٌ مَسِیرَۃَ یَوْمٍ تَامٍّ إِلاَّ مَعَ ذِی مَحْرَمٍ۔ (بخاری 1088۔ مسلم 977)",,,15409,,
15410,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ لَیْثٍ ، قَالَ : ذُکِرَ لِعُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، امْرَأَۃٌ سَافَرَتْ مَعَ عَبْدِہَا فَکَرِہَ ذَلِکَ ، فَقِیلَ لَہُ : إِنَّہُ أَخُوہَا مِنَ الرَّضَاعَۃِ ، فَلَمْ یَرَ بِہِ بَأْسًا۔",,,15410,,
15411,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ یَعْقُوبَ ، عَنْ عَطَائٍ فِی الرَّجُلِ یُہِلُّ بِحَجَّتَیْنِ ، قَالَ : ہُوَ مُتَمَتِّعٌ۔",,,15411,,
15412,"حَدَّثَنَا رَوْحُ بْنُ عُبَادَۃَ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : عَلَیْہِ حَجَّۃٌ وَعُمْرَۃٌ",,,15412,,
15413,"حَدَّثَنَا جَرِیرٌ ، عَنِ الرُّکَیْنِ ، قَالَ : سَمِعْتُ ابْنَ عُمَرَ یَقُولُ لابْنِ الزُّبَیْرِ حِینَ سَقَطَتِ الشَّمْسُ : أَفِضْ۔",,,15413,,
15414,حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ، أَنَّ جِبْرِیلَ جَائَ إلَی إبْرَاہِیمَ فَوَقَفَ بِعَرَفَاتٍ حَتَّی إذَا کَانَ کَأَعْجَلِ مَا یُصَلِّی أَحَدٌ الْمَغْرِبَ دَفَعَ بِہِ۔,,,15414,,
15415,حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِنَحْوِہِ۔,,,15415,,
15416,"حَدَّثَنَا یَحْیَی بْنُ أَبِی زَائِدَۃَ، عَنِ ابْنِ جُرَیْجٍ، قَالَ: أُخْبِرْت، عَنْ مُحَمَّدِ بْنِ قَیْسِ بْنِ مَخْرَمَۃَ بْنِ الْمُطَّلِبِ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ خَطَبَ بِعَرَفَۃَ ، فَقَالَ : أَمَّا بَعْدُ ، فَإِنَّ ہَذَا یَوْمُ الْحَجِّ الأَکْبَرِ ، وَإِنَّ أَہْلَ الْجَاہِلِیَّۃِ وَالأَوْثَانِ کَانُوا یَدْفَعُونَ فِی ہَذَا الْیَوْمِ قَبْلَ غُرُوبِ الشَّمْسِ حِینَ تُعتمُّ بِہَا الْجِبَالُ کَأَنَّہَا عَمَائِمُ الرِّجَالِ فِی وُجُوہِہِمْ ، وَإِنَّا نَدْفَعُ بَعْدَ غُرُوبِہَا ، فَلاَ تُعَجِّلُونَنَا ، ہَدْیُنَا مُخَالِفٌ ہَدْیَ أَہْلِ الشِّرْکِ وَالأَوْثَانِ۔",,,15416,,
15417,حَدَّثَنَا ابْنُ أَبِی زَائِدَۃَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنِ الْقَاسِمِ أَنَّہُ سَمِعَ ابْنَ الزُّبَیْرِ یَقُولُ دَفْع الإِمَامُ مِنْ عَرَفَۃَ إذَا غَرَبَتِ الشَّمْسُ۔,,,15417,,
15418,"حَدَّثَنَا ابْنُ أَبِی زَائِدَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ نَافِعٍ ، قَالَ : کَانَ ابْنُ عُمَرَ یَرَی الدَّفْعَۃَ مِنْ عَرَفَۃَ إذَا تَبَیَّنَ اللَّیْلُ وَأَفْطَرَ الصَّائِمُ۔",,,15418,,
15419,"حَدَّثَنَا ابْنُ أَبِی زَائِدَۃَ ، عَنْ أَبِیہِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، قَالَ : وَقَفْت مَعَ عَبْدِ اللہِ وَعَلَی النَّاسِ عُثْمَانَ ، حَتَّی إذَا غَرَبَتِ الشَّمْسُ ، قَالَ : لَوْ أَنَّ أَمِیرَ الْمُؤْمِنِینَ أَفَاضَ السَّاعَۃَ أَصَابَ السُّنَّۃَ ، فَمَا کَانَ کَلاَمُہُ بِأَسْرَعَ مِنْ أَنْ أَفَاضَ۔",,,15419,,
15420,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یَسْتَحِبُّونَ إذَا دَخَلُوا مَکَّۃَ أَنْ لاَّ یَخْرُجُوا حَتَّی یَخْتِمُوا الْقُرْآنَ۔",,,15420,,
15421,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : کَانَ یُعْجِبُہُمْ إذَا قَدِمُوا مَکَّۃَ بِحَجٍّ ، أَوْ عُمْرَۃٍ أَلاَّ یَخْرُجُوا حَتَّی یَقْرَؤُوا مَا مَعَہُمْ مِنَ الْقُرْآنِ۔",,,15421,,
15422,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ الْقَطَّانُ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ : کَانَ یُحَبُّ ، أَوْ یَسْتَحِبُّ إذَا قَدِمَ شَیْئًا مِنْ ہَذِہِ الْمَسَاجِدِ ، أَنْ لاَ یَخْرُجَ حَتَّی یَقْرَأَ الْقُرْآنَ ، بِالْمَسْجِدِ الْحَرَامِ وَمَسْجِدِ الْمَدِینَۃِ ، وَمَسْجِدِ بَیْتِ الْمَقْدِسِ۔",,,15422,,
15423,حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، أَنَّہُ قَرَأَہُ یَعْنِی الْقُرْآنَ حَیْثُ قَدِمَ مَکَّۃَ۔,,,15423,,
15424,"حَدَّثَنَا عَبَّاد بن العوام ، عَنْ یَحْیَی الْبَکَّائِ ، قَالَ : سَمِعَ : ابْنُ عُمَرَ رَجُلاً یَقْرَأُ وَہُوَ یَطُوفُ بِالْبَیْتِ فَنَہَاہُ۔",,,15424,,
15425,"حَدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : کَانَ یَکْرَہُ الْقِرَائَۃُ فِی العَشْر فِی الطَّوَافِ ، وَلَکِنْ یَذْکُرُ اللَّہَ وَیَحْمَدُہُ وَیُکَبِّرُہُ۔",,,15425,,
15426,"حَدَّثَنَا فُضَیْلُ بْنُ عِیَاضٍ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَعَطَائٍ ، قَالاَ : الْقِرَائَۃُ فِی الطَّوَافِ مُحْدَثٌ۔",,,15426,,
15427,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِبْرَاہِیمَ بن نَافِعٍ ، قَالَ : طُفْت مَعَ سَعِیدِ بْنِ جُبَیْرٍ وَکَانَ لاَ یَفْتُرُ مِنْ ذِکْرِ اللہِ۔",,,15427,,
15428,"حَدَّثَنَا حَفْصٌ، عَنْ حَجَّاجٍ، قَالَ: سَأَلْتُ عَطَائً، عَنِ الْقِرَائَۃِ فِی الطَّوَافِ حَوْلَ الْبَیْتِ، فَلَمْ یَرَ بِہَا بَأْسًا",,,15428,,
15429,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، قَالَ : رَأَیْتُ أَصْحَابَنَا یَقْرَؤُونَ عَلَی مُجَاہِدٍ فِی الطَّوَافِ۔",,,15429,,
15430,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، أَنَّہُ کَانَ یَکْرَہُ القراء ۃ فِی الطَّوَافِ,,,15430,,
15431,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی مِجْلَزٍ ، أَنَّہُ کَانَ مَعَ ابْنِ عُمَرَ ، فَأَتَی جَمْعًا فَصَلَّی الْمَغْرِبَ ، ثُمَّ الْتَفَتَ إلَیْنَا ، فَقَالَ : الصَّلاَۃُ جَامِعَۃٌ ، وَلَمْ یَتَجَوَّزْ بَیْنَہُمَا۔",,,15431,,
15432,"حَدَّثَنَا غُنْدَرٌ، عَنْ شُعْبَۃَ، عَنِ الْحَکَمِ، عَنْ إِبْرَاہِیمَ، عَن عَبْدِ الرَّحْمَنِ بْنِ یَزِید، قَالَ: حجَجْت مَعَ عَبْدِ اللہِ ، فَلَمَّا أَتَی جَمْعًا أَذَّنَ وَأَقَامَ فَصَلَّی الْمَغْرِبَ ثَلاَثًا ، ثُمَّ تَعَشَّی ، ثُمَّ أَذَّنَ وَأَقَامَ فَصَلَّی الْعِشَائَ رَکْعَتَیْنِ۔",,,15432,,
15433,حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، عَنْ أَبِیہِ ، أَنَّ عُمَرَ صَنَعَ مِثْلَ صَنِیعِ ابْنِ مَسْعُودٍ۔,,,15433,,
15434,حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ ذِئْبٍ ، عَنْ إِبْرَاہِیمَ ، عَن سَالِمٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ جَمَعَ بَیْنَہُمَا بِجَمْعٍ ، وَلَمْ یَتَطَوَّعْ بَیْنَہُمَا۔ (ابوداؤد 1921۔ مالک 196),,,15434,,
15435,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : دَخَلَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْبَیْتَ وَعُثْمَانَ بْنُ طَلْحَۃَ وَبِلاَلٌ ، فَأَجَافُوا عَلَیْہِمُ الْبَابَ طَوِیلاً ، ثُمَّ فَتَحُوا ، فَکُنْت أَوَّلَ النَّاسِ دخل فَلَقِیت بِلاَلاً ، فَقُلْتُ : أَیْنَ صَلَّی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ قَالَ : بَیْنَ الْعَمُودَیْنِ الْمُقَدَّمَیْنِ۔",,,15435,,
15436,"حَدَّثَنَا عَبْدَۃُ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی فِی الْبَیْتِ تُجَاہَہُ حِینَ دَخَلَہُ۔\n\n(مسلم 391۔ ابن خزیمۃ 3017)",,,15436,,
15437,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : قُلْتُ لَہُ : أُصَلِّی فِی نَوَاحِی الْبَیْتِ ؟ قَالَ : نَعَمْ ، صَلِّ فِی أَیِّ نَوَاحِیہِ شِئْت۔",,,15437,,
15438,حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنْ مُجَاہِدٍ ، عَنْ صَفْوَانَ ، أَوِ ابْنِ صَفْوَانَ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی فِی الْبَیْتِ رَکْعَتَیْنِ حِینَ دَخَلَہُ۔,,,15438,,
15439,حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ فِی بَیْضِ النَّعَامِ دِرْہَمٌ فِی کُلِّ بَیْضَۃٍ۔,,,15439,,
15440,حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ، قَالَ فِی بَیْضِ النَّعَامِ قِیمَتُہُ۔,,,15440,,
15441,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ خُصَیْفٍ ، عَنْ أَبِی عُبَیْدَۃَ ، عَنْ عَبْدِ اللہِ ، قَالَ : فِی بَیْضِ النَّعَامِ قِیمَتُہُ۔",,,15441,,
15442,حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ فِی بَیْضِ النَّعَامِ قِیمَتُہُ۔,,,15442,,
15443,"حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَبْدِ اللہِ بْنِ ذَکْوَانَ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سُئِلَ عَنْ مُحْرِمٍ أَصَابَ بَیْضَ نَعَامٍ ، قَالَ : فَرَأَی عَلَیْہِ فِی کُلِّ بَیْضَۃٍ صِیَامُ یَوْمٍ ، أَوْ إطْعَامُ مِسْکِینٍ۔",,,15443,,
15444,حَدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی الزناد ، عَنْ عَائِشَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِنَحْوٍ مِنْ حَدِیثِ حَفْصٍ ، عَنِ ابْنِ جُرَیْجٍ۔,,,15444,,
15445,حَدَّثَنَا وَکِیعٌ ، وَابْنُ نُمَیْرٍ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عُمَرَ ، قَالَ فِی بَیْضِ النَّعَامِ قِیمَتُہُ۔,,,15445,,
15446,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ طَلْحَۃَ بْنِ عُبَیْدِ اللہِ ، قَالَ : سَأَلْتُ طَاوُوسًا ، عَنْ بَیْضِ الْحَجَلِ یُصِیبُہُ الْمُحْرِمُ ، قَالَ فِیہِ قِیمَتُہُ۔",,,15446,,
15447,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ ، أَنَّہُ قَالَ فِی بَیْضِ النَّعَامِ أَشَارَ بِہِ رَجُلٌ حَرَامٌ لِحَلاَلٍ : صِیَامُ یَوْمٍ ، أَوْ إطْعَامُ مِسْکِینٍ۔",,,15447,,
15448,حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ فِی کُلِّ بَیْضَتَیْنِ دِرْہَمٌ وَفِی کُلِّ بَیْضَۃٍ نِصْفُ دِرْہَمٍ۔,,,15448,,
15449,حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، عَنْ عُمَرَ ، أَنَّہُ قَالَ فِی الْبَیْضِ قِیمَتُہُ۔,,,15449,,
15450,"حَدَّثَنَا عَبْدَۃُ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ مَطَرٍ الْوَرَّاقِ ، عَنْ مُعَاوِیَۃَ بْنِ قُرَّۃَ ، أَنَّ رَجُلاً أَوْطَأَ بَعِیرَہُ بَیْضَ نَعَامٍ فَسَأَلَ عَلِیًّا ، فَقَالَ : عَلَیْک لِکُلِّ بَیْضَۃٍ ضرَابُ نَاقَتِہِ ، أَوْ جَنِین نَاقَۃِ ، فَانْطَلَقَ إلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَأَخْبَرَہُ بِمَا قَالَ : فَقَالَ : قَدْ قَالَ : مَا سَمِعْت ، وَعَلَیْکَ فِی کُلِّ بَیْضَۃٍ صِیَامُ یَوْمٍ ، أَوْ طَعَامُ مِسْکِینٍ۔ (احمد 5/58۔ بیہقی 207)",,,15450,,
15451,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ، قَالَ : ثَمَنُہُ۔",,,15451,,
15452,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ أَشْعَثَ ، عَنْ مُحَمَّدٍ ، قَالَ : صِیَامُ یَوْمٍ ، أَوْ طَعَامُ مِسْکِینٍ۔",,,15452,,
15453,"حَدَّثَنَا عَبْدَۃُ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ لاَحِقِ بْنِ حُمَیْدٍ ، عَنْ أَبِی عُبَیْدَۃَ ، أَنَّ ابْنَ مَسْعُودٍ ، قَالَ فِی ذَلِکَ : عَلَیْک لِکُلِّ بَیْضَۃٍ صِیَامُ یَوْمٍ ، أَوْ طَعَامُ مِسْکِینٍ۔",,,15453,,
15454,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : سألتُ الْحَکَمَ ، عَنْ بَیْضِ حَمَامِ الْحَرَمِ ، فَقَالَ : فِی بَیْضَۃٍ مُدٌّ مِنْ طَعَامٍ۔",,,15454,,
15455,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ أَیُّوبَ السَّخْتِیَانِیِّ ، عَنْ عِکْرِمَۃَ ، أَنَّ رَجُلاً جَائَ إلَیْہِ فَسَأَلَہُ ، عَنْ رَجُلٍ ذَبَحَ وَلَدَ بَدَنَتِہِ ، قَالَ : عَلَیْہِ دَمٌ۔",,,15455,,
15456,"حَدَّثَنَا أَبُو الْحَسَینِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ مُجَاہِدٍ ، قَالَ : عَلَیْہِ دَمٌ۔",,,15456,,
15457,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ فِی الْبَدَنَۃِ تُنْتِجُ ، قَالَ : یَحْمِلُہُ عَلَیْہَا ، فَإِنْ ذَبَحَہُ وَأَکَلَہُ ذَبَحَ مَکَانَہُ کَبْشًا۔",,,15457,,
15458,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ یَحْمِلُ وَلَدَ الْبَدَنَۃِ عَلَیْہَا۔,,,15458,,
15459,"حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : وَلَدُ الْبَدَنَۃِ یُنْحَرُ مَعَ أُمِّہِ۔",,,15459,,
15460,"حَدَّثَنَا ابنُ فُضَیْل ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ یَقُولُ : إذَا ذُبِحَتِ الْبَدَنَۃُ ذُبِحَ وَلَدُہَا مَعَہَا۔",,,15460,,
15461,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ فِی رَجُلٍ سَاقَ بَدَنَتَہُ فَوَضَعَتْ فِی الطَّرِیقِ فَلَمْ یَسْتَطِعْ أَنْ یَحْمِلَہُ ، قَالَ : یَصْنَعُ بِہِ مَا شَائَ ، فَإِذَا دَخَلَ مَکَّۃَ ذَبَحَ مَکَانَہُ کَبْشًا۔",,,15461,,
15462,"حَدَّثَنَا ابْنُ أَبِی زَائِدَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : ہَلْ تَبْرَحُ مَوْقِفًا بِعَرَفَۃَ قَبْلَ الإِمَامِ ؟ قَالَ : لاَ۔",,,15462,,
15463,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ خُثَیْمٍ ، عَنْ یُوسُفَ بْنِ مَاہَکٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ دَفَعَ قَبْلَ الإِمَامِ۔,,,15463,,
15464,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ إبْرَاہِیمَ بْنِ عَبْدِ الأَعْلَی ، قَالَ : أَفَاضَ صَاحِبٌ لَنَا قَبْلَ الإِمَامِ فَسَأَلْت مُجَاہِدًا ، فَقَالَ : یُہَرِیقُ دَمًا۔",,,15464,,
15465,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : إذَا أَفَاضَ قَبْلَ الإِمَامِ فَعَلَیْہِ دَمٌ۔",,,15465,,
15466,"حَدَّثَنَا سَلاَّمٌ أَبُو الأَحْوَصِ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ فِی رَجُلٍ مَرَّ بِجَمْعٍ وَہُوَ لاَ یَرَی ، أَنَّ بِہَا مَوْقِفًا حَتَّی أَتَی مِنًی ، قَالَ : یُہَرِیقُ لِذَلِکَ دَمًا۔",,,15466,,
15467,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ فِی مَنْ جَہِلَ أَنْ یَبِیتَ بِجَمْعٍ ، قَالَ : یُہَرِیقُ دَمًا۔",,,15467,,
15468,"حَدَّثَنَا حَفْصٌ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عَطَائٍ ، قَالَ سَمِعْتُہُ یَقُولُ : مَنْ رَہِقَ ، عَنْ جَمْعٍ فَلَمْ یَنْزِلْہَا أَہْرَاقَ لِذَلِکَ دَمًا۔",,,15468,,
15469,"حَدَّثَنَا ابْنُ مَہْدِیٍّ، عَنْ سُفْیَانَ، عَنِ ابْنِ أَبِی السَّفَرِ، عَنِ الشَّعْبِیِّ، قَالَ: مَنْ لَمْ یَقِفْ بِجَمْعٍ جَعَلَہَا عُمْرَۃً۔",,,15469,,
15470,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ، عَنْ عَمْرٍو، عَنِ الْحَسَنِ، قَالَ: مَنْ لَمْ یَقِفْ بِجَمْعٍ، فَلاَ حَجَّ لَہُ، وَیَحُجُّ مِنْ قَابِلٍ۔",,,15470,,
15471,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : جَزَائً وَاحِدًا۔",,,15471,,
15472,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنِ الشَّعْبِیِّ ، قَالَ : جَزَائً ا وَاحِدًا۔",,,15472,,
15473,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، قَالَ : إنِ اشْتَرَکُوا فَلَمْ یَفْدِہِ أَصْحَابُہُ فَعَلَیْہِ الْفِدَائُ کُلُّہُ۔",,,15473,,
15474,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُوس ، وَمُجَاہِدٍ ، قَالُوا : جَزَائًا وَاحِدًا ، وَقَالَ : مُجَاہِدٌ : إِنْ أَکَلُوا مِنْہُ فَعَلَی کُلِّ وَاحِدٍ مِنْہُمْ جَزَائٌ۔",,,15474,,
15475,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ سَالمٍ ، عَنْ سَعِیدٍ ، قَالَ : عَلَی کُلِّ وَاحِدٍ مِنْہُمْ جَزَائٌ۔",,,15475,,
15476,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ مُغِیرَۃَ ، عَنِ الشَّعْبِیِّ ، قَالَ : عَلَی کُلِّ وَاحِدٍ مِنْہُمْ جَزَائً ا۔",,,15476,,
15477,"حَدَّثَنَا جَرِیرٌ عَنْ مُغِیرَۃَ ، وَابْنِ شُبْرُمَۃَ عَنِ الشَّعْبِیِّ ، قَالَ: إذَا اشْتَرَکُوا ، فَعَلَی کُلِّ وَاحِدٍ مِنْہُمْ جَزَائٌ۔",,,15477,,
15478,حَدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، قَالَ إِنْ أَکَلاَ مِنْہُ فَعَلَی کُلِّ وَاحِدٍ مِنْہُمَا جَزَائً ا ، وَإِنْ لَمْ یَأْکُلاَ فَعَلَیْہِمَا جَزَائٌ وَاحِدٌ۔,,,15478,,
15479,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، قَالَ : سَأَلْتُ أَبَا جَعْفَرٍ ، وَعَطَائٍ ، عَنِ الْقَوْمِ یَشْتَرِکُونَ فِی الصَّیْدِ وَہُمْ مُحْرِمُونَ ، فَقَالَ : جَزَائٌ وَاحِدٌ۔",,,15479,,
15480,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، قَالَ : إذَا اشْتَرَکَ الرَّجُلاَنِ فِی الصَّیْدِ فَکَفَّارَۃٌ وَاحِدَۃٌ، وَإِنْ أَکَلاَ فَعَلَی کُلِّ وَاحِدٍ مِنْہُمَا جَزَائٌ۔",,,15480,,
15481,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ یُونس ، عَنِ الحَسَن ، قَالَ : عَلَی کُلِّ إِنسَان مِنْہُم جَزَائٌ۔",,,15481,,
15482,"حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَمَّنْ حَدَّثَہُ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ سُئِلَ عَنْ قَوْمٍ مِنَ الْمُشَاۃِ قَتَلُوا صَیْدًا ، قَالَ : عَلَیْہِمْ جَزَائٌ وَاحِدٌ۔",,,15482,,
15483,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : کَانَ یَقُولُ إذَا أَصَابَ اثْنَانِ صَیْدًا فَحُکُومَۃٌ وَاحِدَۃٌ عَلَیْہِمَا۔",,,15483,,
15484,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ شُبْرُمَۃَ ، عَنِ الشَّعْبِیِّ ، قَالَ : عَلَی کُلِّ إنْسَانٍ مِنْہُمْ جَزَائٌ ، وَقَالَ : حَمَّادٌ : یُجْزِئُہُمَا جَزَائٌ وَاحِدٌ ، قَالَ : فَأَخْبَرْت الْحَارِثَ بِالَّذِی قَالَ الشَّعْبِیُّ ، قَالَ : الْقَوْلُ مَا قَالَ حَمَّادُ۔",,,15484,,
15485,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ فِی کُلِّ شَیْئٍ مِنَ الصَّیْدِ حُکُومَۃُ ذَوَی عَدْلٍ۔,,,15485,,
15486,"حَدَّثَنَا ابْنُ أَبِی غنیۃ ، عَنْ أَبِیہِ ، عَنْ حَمَّادٍ ، قَالَ : کُلُّ شَیْئٍ یَصِیبہُ الْمُحْرِمُ مِنَ الصَّیْدِ فَفِیہِ حُکُومَۃُ ذَوَی عَدْلٍ۔",,,15486,,
15487,حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ یَذْبَحُ بِمِنًی ، وَلاَ یُصَلِّی الرَّکْعَتَیْنِ۔,,,15487,,
15488,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ قَالَ : سَأَلَتْ عَطَائً ، قُلْتُ : إنَّ عَبْدَ الْکَرِیمِ ، قَالَ لِی ، بِمِنًی : لاَ تَذْبَحْ حَتَّی تُصَلِّی ، قَالَ : لَیْسَ ذَلِکَ عَلَی أَہْلِ مِنًی إنَّمَا عَلَی أَہْلِ الآفَاقِ ، وَسَأَلْت مُجَاہِدًا ، فَقَالَ لِی مِثْلَ ذَلِکَ۔",,,15488,,
15489,"حَدَّثَنَا حَفْصٌ ، عَنْ عَبْدِ الْمَلِکِ ، قَالَ : سَأَلْتُ عَطَائً قُلْتُ ، قَالَ لِی قَائِلٌ : صَلِّ الرَّکْعَتَیْنِ قَبْلَ أَنْ تَذْبَحَ ، فَقَالَ : لَیْسَ ذَلِکَ عَلَی أَہْلِ مِنًی ، إنَّمَا صَلاَتُہُمْ مَوْقِفُہُمْ بِجَمْعٍ۔",,,15489,,
15490,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ مُجَاہِدٍ ، وَطَاوُوس ، وَعَطَائٍ وَسَالِمٍ وَالْقَاسِمِ ، قَالُوا : لاَ صَلاَۃَ بِمِنًی یَوْمَ النَّحْرِ۔",,,15490,,
15491,حَدَّثَنَا حُمَیْدٌ ، عَنْ قَیْسٍ ، عَنْ جَابِرٍ ، عَنْ طَلْحَۃَ بْنِ عَبْدِ اللہِ ، عَنْ إبْرَاہِیمِ ، وَعَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ أَنَّہُمَا صَلَّیَا بِمِنًی یَوْمَ النَّحْرِ رَکْعَتَیْنِ قَبْلَ أَنْ یَنْحَرَا۔,,,15491,,
15492,حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنِ الْمُثَنَّی ، عَنْ عَمْرِو بْنِ شعیب ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ الرَّکْعَتَانِ وَاجِبَتَانِ عَلَی مَنْ نَحَرَ قَبْلَ أَنْ یَنْحَرَ ، وَمَنْ لَمْ یَنْحَرْ فَعَلَیْہِ أَنْ یَشْہَدَ منًی ، وَزَعَمَ أَنَّہُ لاَ یَسْجُدُ قَبْلَہُمَا فِی فِطْرٍ ، وَلاَ أَضْحَی۔,,,15492,,
15493,"حَدَّثَنَا عَبْدُ الأَعْلَی بن عبد الأعلی ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ حَکِیمِ بْنِ حکِیمٍ ، عَنْ مَسْعُودِ بْنِ الْحَکَمِ ، عَنْ أُمِّہِ ، قَالَتْ : کَأَنِّی أَنْظُرُ إلَی عَلِیٍّ عَلَی بَغْلَۃِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَیَّامَ مِنًی وَہُوَ یُنَادِی : أَلاَ إِنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : إنَّہَا لَیْسَتْ بِأَیَّامِ صِیَامٍ ، إنَّہَا أَیَّامُ أَکْلٍ وَشُرْبٍ۔\n\n(احمد 92۔ ابن خزیمۃ 2147)",,,15493,,
15494,"حَدَّثَنَا سَلاَّمٌ ، عَنْ إِبْرَاہِیمَ ، عَن أَبِی الشَّعْثَائِ ، قَالَ : کُنَّا جُلُوسًا مَعَ عَبْدِ اللہِ بْنِ عُمَرَ بِمِنًی ، فَأُتِینَا بِطَعَامٍ فَتَنَحَّی ابْنٌ لَہُ ، فَقَالَ : إنِّی صَائِمٌ ، فَقَالَ : اطْعَمْ فَإِنَّہَا أَیَّامُ أَکْلٍ وَشُرْبٍ ، قَالَ فَأَفْطَرَ۔",,,15494,,
15495,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : أَیَّامُ التَّشْرِیقِ أَیَّامُ طُعْمٍ وَذِکْرٍ۔",,,15495,,
15496,"حَدَّثَنَا حَفْصٌ وَجَرِیرٌ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، قَالَ : سَأَلْتُ إِبْرَاہِیمَ ، عَن صَوْمِ أَیَّامِ التَّشْرِیقِ ، فَقَالَ : قَالَ مَسْرُوقٌ : ہُنَّ أَیَّامُ أَکْلٍ وَشُرْبٍ۔",,,15496,,
15497,حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَعَثَ بُدَیْلَ بْنَ وَرْقَاء الْخُزَاعِیَّ عَلَی جَمَلٍ أَوْرَقَ یُنَادِی أَیَّامَ مِنًی ، إِنَّہَا أَیَّامُ أَکْلٍ وَشُرْبٍ۔ (طبرانی 423),,,15497,,
15498,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، قَالَ : حدَّثَنِی رَجُلٌ مِنَ الأَنْصَارِ مِنْ أَصْحَابِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ بَعَثَنِی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَیَّامَ التَّشْرِیقُ فَأَمَرَنِی أُنَادِیَ فِی النَّاسِ ، إِنَّہَا أَیَّامُ أَکْلٍ وَشُرْبٍ۔",,,15498,,
15499,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَبِیبِ بْنِ أَبِی ثَابِتٍ ، عَنْ نَافِعِ بْنِ جُبَیْرٍ ، عَنْ بِشْرِ بْنِ سُحَیْمٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ خَطَبَ أَیَّامَ التَّشْرِیقِ ، فَقَالَ : إِنَّہُ لاَ یَدْخُلُ الْجَنَّۃَ إِلاَّ نَفْسٌ مُؤْمِنَۃٌ ، وَإِنَّ ہَذِہِ الأَیَّامَ أَیَّامُ أَکْلٍ وَشُرْبٍ۔ (احمد 4/335۔ دارمی 1766)",,,15499,,
15500,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ مُنْذِرِ بْنِ جَہْمٍ ، عَنْ عُمَرَ بْنِ خَلْدَۃَ الأَنْصَارِیِّ ، عَنْ أُمِّہِ ، قَالَتْ : بَعَثَ النبی صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَلِیًّا أَیَّامَ التَّشْرِیقِ یُنَادِی ، إِنَّہَا أَیَّامُ أَکْلٍ وَشُرْبٍ وَبِعَالٍ۔\n\n(عبد بن حمید 1562)",,,15500,,
15501,"حَدَّثَنَا عَبْدَۃُ ، عَنْ عَبْدِ الْمَلِکِ ، عن عطاء قَالَ : کُنَّا نَصُومُ أَیَّامَ التَّشْرِیقِ بِمِنًی ، ثُمَّ نُہِینَا عَنْہَا۔",,,15501,,
15502,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی بَکْرٍ وَسَالِمٍ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ ، عَنْ عَبْدِ اللہِ بْنِ حُذَافَۃَ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَمَرَہُ یُنَادِی أَیَّامَ التَّشْرِیقِ ، إِنَّہَا أَیَّامُ أَکْلٍ وَشُرْبٍ۔\n\n(نسائی 2876۔ احمد 3/450)",,,15502,,
15503,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَیَّامُ التَّشْرِیقِ أَیَّامُ أَکْلٍ وَشُرْبٍ۔ (ابن ماجہ 1719۔ احمد 2/229)",,,15503,,
15504,"حَدَّثَنَا عَبْدِ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنْ مُحَمَّدِ بن أَبِی الْمَلِیحِ ، قَالَ : أَیَّامُ التَّشْرِیقِ أَیَّامُ أَکْلٍ وَشُرْبٍ۔",,,15504,,
15505,"حَدَّثَنَا وَکِیعٍ ، عَنْ مُوسَی بْنِ عُلَیٍّ ، عَنْ أَبیہ ، عَنْ عُقْبَۃَ بْنِ عَامِرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : یَوْمُ عَرَفَۃَ وَیَوْمُ النَّحْرِ وَأَیَّامُ التَّشْرِیقِ عِیدُ أَہْلِ الإِسْلاَمِ وہن أَیَّامُ أَکْلٍ وَشُرْبٍ۔",,,15505,,
15506,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ الْحَمِیدِ بْنِ جَعْفَرٍ ، عَنْ رَجُلٍ ، یُقَالَ لَہُ : عِیسَی ، أَنَّ عَلِیًّا رَخَّصَ لِلْمُحْرِمِ أَنْ یُقَرِّدَ بَعِیرَہُ۔",,,15506,,
15507,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ مُجَاہِدٍ ، أَوْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ بَأْسَ أَنْ یُقَرِّدَ الْمُحْرِمُ بَعِیرَہُ۔",,,15507,,
15508,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ أَنْ یُقَرِّدَ الْمُحْرِمُ بَعِیرَہُ۔",,,15508,,
15509,"حَدَّثَنَا عَبَّادٌ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ مُحَمَّدِ بْنِ إِبْرَاہِیمَ ، عَن رَبِیعَۃَ بْنِ عَبْدِ اللہِ بْنِ ہُدَیْر ، قَالَ : رَأَیْتُ عُمَرَ بْنَ الْخَطَّابِ یُقَرِّدُ بَعِیرَہُ بِالسُّقْیَا وَہُوَ مُحْرِمٌ وَیَجْعَلُہُ فِی الطِّینِ۔",,,15509,,
15510,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، قَالَ : سَأَلْتُ عَطَائً ، عَنِ الرَّجُلِ یُقَرِّدُ بَعِیرَہُ وَیُلْقِی عَنْہُ الدُّودَ ویحلمہ ، فَقَالَ : قَرِّدْ ، وَحَلِّمْ ، وَأَلْقِ الدُّودَ ، عَنْ بَعِیرِکَ۔",,,15510,,
15511,"حَدَّثَنَا سَلاَّمٌ ، عَنِ الْعَلاَئِ بْنِ الْمُسَیَّبِ ، قَالَ : قَالَ رَجُلٌ لِعَطَائٍ : أُقَرِّدُ بَعِیرِی وَأَنَا مُحْرِمٌ ؟ قَالَ : نَعَمْ ، قَدْ فَعَلَ ذَلِکَ ابْنُ عُمَرَ۔",,,15511,,
15512,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ أَبِی الدَّرْدَائِ سألت : مُجَاہِدٌ ، عَنِ الْمُحْرِمِ یُقَرِّدُ بَعِیرَہُ ؟ قَالَ : لاَ بَأْسَ۔",,,15512,,
15513,حَدَّثَنَا وَکِیعٌ ، عَنْ أَفْلَحَ ، عَنِ الْقَاسِمِ ، أَنَّہُ کَرِہَ أَنْ یُقَرِّدَ بَعِیرَہُ۔,,,15513,,
15514,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عِکْرِمَۃَ ، أَنَّہُ یَکْرَہُ أَنْ یُقَرِّدَ الْبَعِیرَ ، فَقَالَ ابْنُ عَبَّاسٍ : انْحَرْہَا ، قَالَ : فَنَحَرَہَا ، فَقَالَ : کَمْ قَتَلْت فِی جِلْدِہَا مِنْ قُرَادٍ ، أَوْ حَمْنَانَۃٍ۔",,,15514,,
15515,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عُمَرَ ، عَنْ أَبِی الشَّعْثَائِ : الْمُحْرِمُ یُقَرِّدُ بَعِیرَہُ وَیَطْلِیہِ بِالْقَطِرَانِ۔",,,15515,,
15516,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ وَیَزِیدُ بْنُ ہَارُونَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ، عَنْ عِکْرِمَۃَ، عَنِ ابْنِ عَبَّاسٍ؟ قَالَ: لاَ بَأْسَ بِہِ۔",,,15516,,
15517,"حَدَّثَنَا رَوْحُ بْنُ عُبَادَۃَ ، عَنْ زَکَرِیَّا بْنِ إِسْحَاقَ ، قَالَ : حدَّثَنَا أَبُو الزُّبَیْرِ ، أَنَّہُ سَمِعَ جَابِرَ بْنَ عَبْدِ اللہِ یَقُولُ : لاَ بَأْسَ أَنْ یُقَرِّدَ الْمُحْرِمُ بَعِیرَہُ۔",,,15517,,
15518,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنِ ابْنِ حَرْمَلَۃَ ، قَالَ : قتَلْت قُرَادًا ، أَوْ حُنْظُبًا وَأَنَا مُحْرِمٌ ، فَقَالَ ابْنُ سَعِیدٍ: تَصَدَّقْ بتَمْرَۃٍ ، قَالَ : تَمْرَۃٌ خَیْرٌ مِنْہَا۔",,,15518,,
15519,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عُبَیْدِ اللہِ ، عَنِ الْقَاسِمِ ، قَالَ : سَأَلْتُ رَجُلاً ، عَنِ الْقُرَادِ یُصِیبُہُ الْمُحْرِمُ ، فَقَالَ : تَمْرَۃٌ خَیْرٌ مِنْ قُرَادٍ ، بَلْ نِصْفُ تَمْرَۃٍ ، بَلْ نَوَاۃٌ خَیْرٌ مِنْ قُرَادٍ۔",,,15519,,
15520,حَدَّثَنَا عَبْدَۃُ ، عَنْ صَاعِدِ بْنِ مُسْلِمٍ ، عَنِ الشَّعْبِیِّ فِی الْمُحْرِمِ یَقْتُلُ الْقُرَادَ ، قَالَ یُطْعِمُ کَفًّا مِنْ طَعَامِ حِنْطَۃٍ ، أَوْ دَقِیقٍ ، أَوْ تَمْرٍ۔,,,15520,,
15521,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی مَسْلَمَۃَ ، قَالَ : سَمِعْتُ عِکْرِمَۃَ ، سئل ، عَنْ مُحْرِمٍ قَتَلَ حَلَمَۃً ، قَالَ یَتَصَدَّقُ بِکِسْرَۃٍ۔",,,15521,,
15522,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ یَحْکُمُ عَلَیْہِ فِی الْخَطَأِ وَالْعَمْدِ۔,,,15522,,
15523,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْن جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ یُحْکَمُ عَلَیْہِ فِی الْخَطَأِ وَالْعَمْدِ۔,,,15523,,
15524,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ عَمْرو بْنِ مُرَّۃَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : إنَّمَا جُعِلَ الْجَزَائُ فِی الْعَمْدِ ، وَلَکِنْ غُلِّظَ عَلَیْہِمْ فِی الْخَطَأِ کَی یَتَّقُوا۔",,,15524,,
15525,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : الْعَمْدُ وَالْخَطَأُ فِی الصَّیْدِ سَوَائٌ ، یُحْکَمُ عَلَیْہِ۔",,,15525,,
15526,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنِ الْحَکَمِ ، أَنَّ عُمَرَ کَانَ کَتَبَ یحکم عَلَیْہِ فِی الْخَطَأِ وَالْعَمْدِ۔,,,15526,,
15527,حَدَّثَنَا محبوب الْقَوَارِیرِیُّ ، عَنْ إبْرَاہِیمَ بْنِ طَہْمَانَ ، عَنْ جَابِرٍ ، عَنِ الْحَکَمِ ، عَنْ عُمَرَ مِثْلَہُ۔,,,15527,,
15528,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، قَالَ نُبِّئْت ، عَنْ مُجَاہِدٍ ، أَنَّہُ قَالَ : لاَ یُحْکَمُ عَلَی مَنْ أَصَابَ الصَّیْدَ مُتَعَمِّدًا ، إنَّمَا یُحْکَمُ عَلَی مَنْ أَصَابَ خَطَأً وَنُبِّئْت ، عَنْ طَاوُوسٍ ، أَنَّہُ قَالَ : لاَ یُحْکَمُ عَلَی مَنْ أَصَابَہُ خَطَأً ، إنَّمَا یُحْکَمُ عَلَی مَنْ أَصَابَہُ مُتَعَمِّدًا۔",,,15528,,
15529,"حَدَّثَنَا ابْنُ یَمَانٍ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ سَالِمٍ وَالْقَاسِمِ ، وَعَطَائٍ ، وَطَاوُوس ، وَمُجَاہِدٍ ، قَالُوا : إذَا أَصَابَ الْجَنَادِبَ وَالْعظَاء لَمْ یُحْکَمْ عَلَیْہِ خَطَأً ، وَإِنْ أَصَابَہُ مُتَعَمِّدًا حُکِمَ عَلَیْہِ۔",,,15529,,
15530,"حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنْ حُسَیْنٍ، عَنْ قَتَادَۃَ، عَنْ أَبِی مَدَیْنَۃَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: لَیْسَ عَلَیْہِ فِی الْخَطَأِ شَیْئٌ۔",,,15530,,
15531,"حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : الْخَطَأُ وَالْعَمْدُ فِی الصَّیْدِ سَوَائٌ ، یُحْکَمُ عَلَیْہِ۔",,,15531,,
15532,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ یُونِس ، عن الحسن قَالَ : یُحْکَمُ عَلَیْہِ فِی الْخَطَأِ وَالْعَمْدِ۔",,,15532,,
15533,"حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ ہِشَامٍ ، قَالَ : رَأَیْتُ الْحَسَنَ یَتَعَجَّلُ إلَی مِنًی قَبْلَ النَّاسِ بِیَوْمٍ ، وَرَأَیْت ہِشَامًا یَتَعَجَّلُ۔",,,15533,,
15534,"حَدَّثَنَا حَفْصٌ، عَنْ حَجَّاجٍ، قَالَ: سَأَلْتُ عَطَائً، عَنِ التَّعَجُّلِ إلَی مِنًی قَبْلَ التَّرْوِیَۃِ بِیَوْمٍ، فَلَمْ یَرَ بِذَلِکَ بَأْسًا۔",,,15534,,
15535,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبَانَ بْنِ عَبْدِ اللہِ ، قَالَ : سَأَلْتُ عَطَائً ، فَقَالَ : مِثْلَ ذَلِکَ۔",,,15535,,
15536,"حَدَّثَنَا معَنْ بْنُ عِیسَی ، عَنْ خَالِدِ بْنِ أَبِی بَکْرٍ ، قَالَ : کُنْتُ أکون مَعَ سَالِمٍ ، وَمَعَ عَبْدِ اللہِ بْنِ عُبَیْدِ اللہِ فَلَمْ أَرَہُمَا غَسَلاَ حَصَی الْجِمَارِ",,,15536,,
15537,"حَدَّثَنَا عَبْدُالرَّزَّاقِ، عَنْ مَعْمَرٍ، قَالَ سَأَلَتِ الزُّہْرِیَّ أَغْسِلُ حصَی الْجِمَارِ؟ قَالَ: لاَ إِلاَّ أَنْ یَکُونَ فِیہِ قَذَرٌ",,,15537,,
15538,"حَدَّثَنَا الْعَقَدِیُّ عَبْدُ الْمَلِکِ بْنُ عَمْرٍو ، عَنْ أَفْلَحَ ، قَالَ : کَانَ الْقَاسِمُ یَغْسِلُ حَصَی الْجِمَارِ وَیَأْخُذُہُ کَمَا ہُوَ فَیَرْمِی بِہِ۔",,,15538,,
15539,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ مُوَرِّعِ بْنِ مُوسَی ، سَمِعَ شَیْخًا یُحَدِّثُ ، أَنَّہُ رَأَی سَعِیدَ بْنَ جُبَیْرٍ غَسَلَ حَصَی الْجِمَارِ۔,,,15539,,
15540,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : سَأَلْتُ عَطَائً ، فَقَالَ : لاَ تَغْسِلْہُ۔",,,15540,,
15541,حَدَّثَنَا وَکِیعٌ ، عَنْ زَمْعَۃَ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، أَنَّہُ کَانَ یَغْسِلُ حَصَی الْجِمَارِ۔,,,15541,,
15542,"حَدَّثَنَا معَنْ بْنُ عِیسَی ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، عَنْ أَبَانَ بْنِ عُثْمَانَ ، قَالَ : وَاللَّہِ ، إنَّ الصَّلاَۃَ لَتُقْضَی فَکَیْفَ لاَ یُقْضَی الرَّمْیُ۔",,,15542,,
15543,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : دَعَا النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِنَاقَتِہ بِالْبَیْدَائِ فَرَکِبَہَا ، فَلَمَّا انْبَعَثَتْ بِہِ رَاحِلَتُہُ لَبَّی۔",,,15543,,
15544,"حَدَّثَنَا معَنْ ، عَنْ خَالِدِ بْنِ أَبِی بَکْرٍ ، قَالَ : رَأَیْتُ الْقَاسِمَ بْنَ مُحَمَّدٍ أَہَلَّ حِینَ انْبَعَثَتْ بِہِ رَاحِلَتُہُ مِنْ فِنَائِ مَسْجِدِ ذِی الْحُلَیْفَۃِ۔",,,15544,,
15545,حَدَّثَنَا معَنْ ، عَنْ خَالِدٍ ، أَنَّہُ رَأَی سَالِمًا فَعَلَ مِثْلَ ذَلِکَ۔,,,15545,,
15546,حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی فِی مَسْجِدِ ذِی الْحُلَیْفَۃِ ، فَلَمَّا اسْتَوَتْ بِہِ رَاحِلَتُہُ بِفِنَائِ الْمَسْجِدِ أَہَلَّ۔ (مالک 29),,,15546,,
15547,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : کَانَ إذَا انْبَعَثَتْ بِہِ رَاحِلَتُہُ لَبَّی، وَکَانَتْ عَائِشَۃُ لاَ تُلَبِّی حَتَّی تَأْتِیَ الْبَیْدَائَ۔ (بخاری 1553۔ مسلم 27)",,,15547,,
15548,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ خَیْثَمَۃَ ، قَالَ : کَانُوا یُحِبُّونَ التَّلْبِیَۃَ إذَا اسْتَوَی بَعِیرُہُ بِہِ قَائِمًا۔",,,15548,,
15549,حَدَّثَنَا حُمَیْدٌ ، عَنْ حَسَنٍ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنْ رَجَائٍ ، أنَّ عَلْقَمَۃَ کَانَ إذَا جَلَسَ عَلَی الرَّاحِلَۃِ أَخَذَ فِی التَّلْبِیَۃِ فَتَنْبَعِثُ بِہِ وَہُوَ یُلَبِّی۔,,,15549,,
15550,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا وَضَعَ رِجْلَہُ فِی الْغَرْزِ وَانْبَعَثَتْ بِہِ رَاحِلَتُہُ قَائِمَۃً أَہَلَّ مِنْ ذِی الْحُلَیْفَۃِ۔",,,15550,,
15551,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، أَنَّہُ کَرِہَ أَنْ تُرْمَی الْجِمَارُ لَیْلاً۔,,,15551,,
15552,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، أَنَّہُ کَرِہَ رَمْیَ الْجِمَارِ بِاللَّیْلِ۔,,,15552,,
15553,حَدَّثَنَا مُحَمَّدُ بْنُ عُبَیْدٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، أن أُمِّ سَلَمَۃَ ابْنَۃِ الْمُخْتَارِ کَانَتْ تَحْتَ ابْنٍ لِعَبْدِ اللہِ بْنِ عُمَرَ فَوَلَدَتْ بِالْمُزْدَلِفَۃِ فَتَخَلَّفَتْ مَعَہَا صَفِیَّۃُ ، فَلَمْ تَضَعْ لَیْلَتَہَا تِلْکَ وَمِنَ الْغَدِ ، ثُمَّ جَائَتَا مِنًی مِنَ اللَّیْلِ فَرَمَتَا الْجَمْرَۃَ فَلَمْ یُنْکِرْ ذَلِکَ عَلَیْہِمَا عَبْدُ اللہِ ، وَلَمْ یَأْمُرْہُمْ أَنْ تقضیا شَیْئًا۔,,,15553,,
15554,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : لاَ تُرْمَی الْجِمَارُ بِاللَّیْلِ",,,15554,,
15555,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ سَابِطٍ ، قَالَ : کَانَ أَصْحَابُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقْدَمُونَ حُجَّاجًا فَیَرعَونَ ظَہْرَہُمْ فَیَجِیئُونَ فَیَرْمُونَ بِاللَّیْلِ۔",,,15555,,
15556,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرٍو قَالَ : أَخْبَرَنِی مَنْ رَأَی بَعْضَ أَزْوَاجِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ تَرْمِی مَغْربَان الشَّمْسُ غَرَبَتِ الشَّمْسُ ، أَوْ لَمْ تَغْرُبْ",,,15556,,
15557,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُوس ، قَالَ : الْکَرِیُّ إذَا لَمْ یَجِدْ رَاعِیًا ، وَالرَّجُلُ إذَا کَانَ نَاسِیًا یَرْمِیَانِ الْجِمَارَ بِاللَّیْلِ۔",,,15557,,
15558,"حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : الرِّعَائُ یَرْمُونَ لَیْلاً ، وَلاَ یَبِیتُونَ۔",,,15558,,
15559,حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ جَابِرٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لَمْ یَزَلْ وَاقِفًا بِالْمُزْدَلِفَۃِ حَتَّی أَسْفَرَ جِدًّا ، فَدَفَعَ قَبْلَ أَنْ تَطْلُعَ الشَّمْسُ۔,,,15559,,
15560,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ مُحَمَّدِ بْنِ الْمُنْکَدِرِ سَمِعَ سَعِیدَ بْنَ عَبْدِ الرَّحْمَنِ بْنِ یَرْبُوعٍ یُخْبِرُ ، عَنْ جُبَیْرِ بْنِ الْحُوَیْرِثِ سَمِعَ أَبَا بَکْرٍ وَہُوَ وَاقِفٌ عَلَی قُزَحٍ وَہُوَ یَقُولُ : أَیُّہَا النَّاسُ أَصْبِحُوا ، أَیُّہَا النَّاسُ أَصْبِحُوا ، ثُمَّ دَفَعَ فَکَأَنِّی أَنْظُرُ إلَی فَخِذِہِ قَدَ انْکَشَفَتْ مِمَّا یُحَرِّشُ بَعِیرَہُ بِمِحْجَنِہِ۔",,,15560,,
15561,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، عَنْ أَبِی الشَّعْثَائِ ، قَالَ : وَقْتُ الدَّفْعَۃِ مِنَ الْمُزْدَلِفَۃِ کَقَدْرِ صَلاَۃِ الْقَوْمِ مِنَ الْمُصْبِحِینَ بِصَلاَۃِ الصُّبْحِ حِینَ تُبْصِرُ الإِبِلُ مَوَاضِعَ أَخْفَافِہَا۔",,,15561,,
15562,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، قَالَ : کَانَ أَہْلُ الْجَاہِلِیَّۃِ یَدْفَعُونَ مِنْ عَرَفَاتٍ قَبْلَ غُرُوبِ الشَّمْسِ ومن المزدلفۃ بعد طلوعہا فَأَخَّرَ اللَّہُ ہَذِہِ وَقَدَّمَ ہَذِہِ ، أَخَّرَ الَّتِی مِنْ عَرَفَۃَ إلَی غُرُوبِ الشَّمْسِ ، وَقَدَّمَ الَّتِی مِنْ مُزْدَلِفَۃَ قَبْلَ طُلُوعِ الشَّمْسِ۔",,,15562,,
15563,"حَدَّثَنَا وَکِیعٌ ، عَنِ الْعُمَرِیِّ ، عَنْ نَافِعٍ ، قَالَ وَقَفَ ابْنُ الزُّبَیْرِ بِجَمْعٍ فأسفر ، فَقَالَ ابْنُ عُمَرَ : طُلُوعُ الشَّمْسِ تنتظر أَفِعْلَ الْجَاہِلِیَّۃِ ؟ فَدَفَعَ ابْنُ عُمَرَ ، وَدَفَعَ النَّاسُ بِدَفْعَتِہِ۔",,,15563,,
15564,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، أَنَّ عَبْدَ اللہِ أَفَاضَ مِنْ جَمْعٍ مِقْدَارَ صَلاَۃِ الْمُسْفِرِینَ بِصَلاَۃِ الْغَدَاۃِ۔,,,15564,,
15565,"حَدَّثَنَا ابْنُ نُمَیْرٍ وَیَزِیدُ بْنُ ہَارُونَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنِ الْقَاسِمِ ، قَالَ : سَمِعْتُ ابْنُ الزُّبَیْرِ یَقُولُ : إنَّ مِنْ سُنَّۃِ الْحَجِّ أَنْ یُصَلِّیَ ، ثُمَّ یَقِفَ بِالْمُزْدَلِفَۃِ بَعْدَ أَنْ یُصَلِّیَ الصُّبْحَ إذَا بَرَقَ الْفَجْرُ ، فَإِذَا أَسْفَرَ دَفَعَ۔",,,15565,,
15566,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ قَالَ : قبْلَ طُلُوعِ الشَّمْسِ۔",,,15566,,
15567,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ، عَنِ ابْنِ جُرَیْجٍ، عَنْ عَمرو، عَنِ ابْنُ الزُّبَیْرِ قَالَ: الدفعۃ مِن جمع طُلُوعِ الشَّمْسِ۔",,,15567,,
15568,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابن طَاوُوسٍ ، عَنْ أَبِیہِ ، قَالَ : قبْلَ طُلُوعِ الشَّمْسِ۔",,,15568,,
15569,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ کَقَدْرِ صَلاَۃِ الصُّبْحِ لاَ مُعَجَّلَۃً، وَلاَ مُؤَخَّرَۃً۔,,,15569,,
15570,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ أَبِی زِیَادٍ ، عَنْ القَاسِمِ ، عَنْ عَائِشَۃَ ، قَالَتْ إنَّمَا جُعِلَ الطَّوَافُ بِالْبَیْتِ ، وَالسَّعْیُ بَیْنَ الصَّفَا وَالْمَرْوَۃِ لإِقَامَۃِ ذِکْرِ اللہِ۔,,,15570,,
15571,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عُبَیْدِ اللہِ بْنِ أَبِی زِیَادٍ ، عَنِ الْقَاسِمِ ، عَنْ عَائِشَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِمِثْلِہِ۔ (ابوداؤد 1883۔ احمد 6/139),,,15571,,
15572,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ سُلَیْمَانَ بْنِ الْمُغِیرَۃِ القیسی ، عَنِ ابْنِ أَبِی نُعْمٍ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ، قَالَ : مَا تُقُبِّلَ مِنْ حَصَی الْجِمَارِ رُفِعَ",,,15572,,
15573,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ فِطْرٍ ، عَنْ أَبِی الطُّفَیْلِ ، قَالَ : قُلْتُ لابْنِ عَبَّاسٍ رَمَی فِی الْجَاہِلِیَّۃِ وَالإِسْلاَمِ ، فَقَالَ : مَا تُقُبِّلَ مِنْہُ رُفِعَ ، وَلولاَ ذَلِکَ کَانَ أَعْظَمَ مِنْ ثَبِیرٍ۔",,,15573,,
15574,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، أَنَّہُ قَالَ فِی الْہَدْیِ الْوَاجِبِ : لاَ یَأْکُلُ مِنْہُ وَعَلَیْہِ الجَزَاء ، وَقَالَ فِی التَّطَوُّعِ : یَأْکُلُ مِنْہُ۔",,,15574,,
15575,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ فِی رَجُلٍ سَاقَ بَدَنَۃً فَعَطِبَتْ ، قَالَ : یَأْکُلُ وَیُطْعِمُ وَیَتَصَدَّقُ لأَنَّ عَلَیْہِ الْبَدَلَ۔",,,15575,,
15576,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، عَنْ عَبْدِ اللہِ ، قَالَ : إذَا سَاقَ ہَدْیًا وَاجِبًا فَعَطِبَ أَکَلَ وَأَطْعَمَ ، وَعَلَیْہِ الْبَدَلُ",,,15576,,
15577,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : کُلْ وَأَبْدِلْ إذَا عَطِبَ الْہَدْیُ ، وَإِنْ کَانَ وَاجِبًا۔",,,15577,,
15578,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَبِی التَّیَّاحِ ، عَنْ مُوسَی بْنِ سَلَمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَعَثَ بِثَمَانِ عَشْرَۃَ بَدَنَۃً مَعَ رَجُلٍ فَأَمَرَہُ فِیہَا بِأَمْرِہِ فَانْطَلَقَ ، ثُمَّ رَجَعَ ، فَقَالَ لَہُ : أَرَأَیْت إِنْ أَزْحَفَ عَلَیْنَا مِنْہَا شیء ؟ قَالَ : انْحَرْہَا ، ثُمَّ اغْمِسْ نَعْلَہَا فِی دَمِہَا وَاجْعَلْہَا عَلَی صَفْحَتِہَا ، وَلاَ تَأْکُلْ مِنْہَا أَنْتَ ، وَلاَ أَحَدٌ مِنْ أَہل رُفْقَتِکَ۔ (مسلم 962۔ ابوداؤد 1760)",,,15578,,
15579,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، عَنْ نَاجِیَۃَ الْخُزَاعِیِّ ، قَالَ : قُلْتُ یَا رَسُولَ اللہِ ، کَیْفَ أَصْنَعُ بِمَا عَطِبَ مِنَ الْبُدْنِ ؟ قَالَ : انْحَرْہُ وَاغْمِسْ نَعْلَہُ فِی دَمِہِ وَخَلِّ بَیْنَ النَّاسِ وَبَیْنَہُ فَلْیَأْکُلُوہُ۔ \n\n(ابن ماجہ 3106۔ احمد 4/334)",,,15579,,
15580,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشرٍ ، قَالَ : حدَّثَنَا سَعِیدُ بْنُ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ سِنَانِ بن سَلَمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّ ذُؤَیْبَ الْخُزَاعِیَّ حَدَّثَ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَبْعَثُ مَعَہُ بِالْبُدْنِ ، فَیَقُولُ : إذَا عَطِبَ مِنْہَا شَیْئٌ فَخَشِیت عَلَیْہِ مَوْتًا فَانْحَرْہَا ، ثُمَّ اغْمِسْ نَعْلَہَا فِی دَمِہَا ، ثُمَّ اضْرِبْ بِہَا عَلَی صَفْحَتِہَا ، وَلاَ تُطْعِمْ مِنْہَا أَحَدٌ مِنْ أَہْلِ رُفْقَتِکَ۔ (ابن ماجہ 3105۔ احمد 4/225)",,,15580,,
15581,"حَدَّثَنَا عَبْدَۃُ ، عَنْ عُبَیْدِ اللہِ بن عُمَرَ ، عَنْ نَافِعٍ ، قَالَ : بَعَثَ مَعِی عَبْدُ اللہِ بِبَدَنَۃٍ تَطَوُّعًا ، فَعَطِبَ فِی الطَّرِیقِ ، فَنَحَرْتہَا فَتَصَدَّقْت مِنْہَا بِطَائِفَۃٍ وَرَجَعْت إلَیْہِ بِبَعْضِہَا فَأَکَلَ ، وَلَمْ یُبْدِلْ۔",,,15581,,
15582,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، عَنْ عَبْدِ اللہِ ، قَالَ : إذَا سَاقَ ہَدْیًا تَطَوُّعًا فَعَطِبَ ؟ قَالَ : کُلْ وَأَطْعِمْ وَلَیْسَ عَلَیْکَ الْبَدَلُ۔",,,15582,,
15583,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : کُلْ مِنَ التَّطَوُّعِ وَالتَّمَتُّعِ وَہَدْیِ الإِحْصَارِ وَالنَّذْرِ إذَا لَمْ یُسَمَّ۔",,,15583,,
15584,"حَدَّثَنَا وَکِیعٌ ، عَنْ شَرِیکٍ ، عَنْ سالم ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : یُؤْکَلُ مِنَ التَّطَوُّعِ وَالتَّمَتُّعِ",,,15584,,
15585,"حَدَّثَنَا وَکِیعٌ ، عَنِ الرَّبِیعِ ، عَنْ قَیْسِ بْنِ سَعْدٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : الصَّدَقَۃُ تَطَوُّعًا ، وَالصَّلاَۃُ وَالصَّوْمُ وَالطَّوَافُ إِنْ شَائَ أَتَمَّ ، وَإِنْ شَائَ قَطَعَ۔",,,15585,,
15586,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ إسْمَاعِیلَ ، عَنِ الْحَسَنِ وَقَتَادَۃَ ، وَابْنِ سِیرِینَ فِی الرَّجُلِ یَفْتَتِحُ الطَّوَافَ تَطَوُّعًا ، ثُمَّ یَقْطَعُہُ ، قَالُوا : یَقْضِی طَوَافَہُ۔",,,15586,,
15587,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا حَضَرَتْ صَلاَۃٌ مَکْتُوبَۃٌ وَأَنْتَ تَطُوفُ بِالْبَیْتِ فَاقْطَعْ طَوَافَک ، ثُمَّ صَلِّ ، ثُمَّ اقْضِ مَا بَقِیَ مِنْ طَوَافِک۔",,,15587,,
15588,"حَدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُوس ، وَمُجَاہِدٍ ، قَالُوا : إِنْ شِئْتَ فَاقْضِ مَا بَقِیَ ، وَإِنْ شِئْتَ فَاسْتَقْبِلْ۔",,,15588,,
15589,حَدَّثَنَا وَکِیعٌ ، عَنْ حَنْظَلَۃَ ، عَنْ سَالِمٍ ، أَنَّہُ کَانَ یَطُوفُ بَیْنَ الصَّفَا وَالْمَرْوَۃِ فَأُقِیمَتِ الصَّلاَۃُ ، فَصَلَّی ، ثُمَّ رَجَعَ إلَی الصَّفَا وَالْمَرْوَۃِ فَأَتَمَّ مَا بَقِیَ,,,15589,,
15590,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ شَیْخٍ مِنْ أَہْلِ مَکَّۃَ ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ یَطُوفُ وَقَدْ أُقِیمَتِ الصَّلاَۃُ فَدَخَلَ فِی الصَّلاَۃِ ، فَلَمَّا قَضَی الصَّلاَۃَ بَنَی عَلَی طَوَافِہِ۔",,,15590,,
15591,حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّہُ بَنَی عَلَی مَا بَقِیَ۔,,,15591,,
15592,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنْ رَجُلٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، أَنَّہُ طَافَ خَمْسَۃَ أَشْوَاطٍ ، ثُمَّ أُقِیمَتِ الصَّلاَۃُ فَصَلَّی ، فَلَمَّا قَضَی صَلاَتَہُ بَنَی عَلَی مَا بَقِیَ مِنْ طَوَافِہِ ، وَصَلَّی رَکْعَتَیْنِ۔,,,15592,,
15593,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ إبْرَاہِیمَ بْنِ إسْمَاعِیلَ بْنِ دِرْہمٍ ، قَالَ بَعَثَنِی مُجَاہِدٌ فِی حَاجَۃٍ وَأَنَا أَطُوفُ مَعَہُ بِالْبَیْتِ ، فَقُلْتُ لَہُ : إنِّی لَمْ أُتِمَّ طَوَافِی ، قَالَ : تَرْجِعُ فَتُتِمُّ۔",,,15593,,
15594,"حَدَّثَنَا ابْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ تَعْرُضُ لَہُ الْحَاجَۃُ ، قَالَ : یَقْطَعُ طَوَافَہُ وَیَسْتَأْنِفُ۔",,,15594,,
15595,حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ مَیْسَرَۃَ ، عَنْ طَاوُوسٍ ، أَنَّہُ کَانَ یَقْدُمُ عَرَفَۃَ فَیُعَارِضُ إلَی عَرَفَۃَ ، وَلاَ یَأْتِی الْبَیْتَ۔,,,15595,,
15596,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ إسْمَاعِیلَ ، عَنِ الْحَسَنِ ، وَعَطَائٍ فِی الرَّجُلِ یَقْدُمُ مُفْرِدًا فَیَجِدُ النَّاسَ وُقُوفًا بِعَرَفَۃَ ، قَالاَ : یَقِفُ مَعَہُمْ ، فَإِذَا کَانَ یَوْمُ النَّحْرِ طَافَ طَوَافًا وَاحِدًا وَسَعَی بَیْنَ الصَّفَا وَالْمَرْوَۃِ ، فَأَجْزَأَہُ طَوَافُ الْقُدُومِ مِنْ طَوَافِ الزِّیَارَۃِ وَعَلَیْہِ طَوَافُ یَوْمِ النَّفْرِ حِینَ یُوَدِّعُ الْبَیْتَ۔",,,15596,,
15597,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ أَبِی جَعْفَرٍ ، أَنَّہُ ، سُئِلَ عَنِ الَّذِی یَقْرِنُ ، قَالَ : أَحَبُّ إلَیَّ أَنْ یَسُوقَ الْہَدْیَ مِنْ حَیْثُ أَحْرَمَ۔",,,15597,,
15598,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، أَنَّہُ سُئِلَ عَنْ رَجُلٍ قَرَنَ الْحَجَّ وَالْعُمْرَۃَ ، فَقَالَ : إِنْ شَائَ سَاقَ ، وَإِنْ شَائَ أَجْزَأَ عَنْہُ أَنْ یَبْتَاعَ مِنْ مَکَّۃَ شَاۃً",,,15598,,
15599,حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، أَنَّ شُرَیْحًا وَالْحُسَین بْنَ علِیٍّ قَرَنَا ، وَلَمْ یُہْدِیَا۔,,,15599,,
15600,"حَدَّثَنَا وَکِیعٌ ، عَنْ فِطْرٍ ، عَنِ الْحَکَمِ ، قَالَ : مَا یُعْجِبُنِی القِرَانُ ، إِلاَّ أَنْ یَسُوقَ ، وَالْمُتَمَتِّعُ تُجْزِئُہُ شَاۃٌ۔",,,15600,,
15601,"حَدَّثَنَا وَکِیعٌ ، عَنْ صَالِحٍ الْعُکْلِیِّ ، قَالَ : سَأَلْتُ الشَّعْبِیَّ ، عَنِ القِرَانِ ، فَقَالَ : حَسَنٌ ، وبینہما مَا اسْتَیْسَرَا ، وَسَأَلْتُہُ ، عَنِ التَّمَتُّعِ ، فَقَالَ : حَسَنٌ ، وبینہما مَا اسْتَیْسَرَا ، وَسَأَلْتُہُ ، عَنِ التَّجْرِیدِ ، فَقَالَ : حَسَنٌ ، قُلْتُ : أَیُّہُا أَعْجَبُ إلَیْک ؟ قَالَ : التَّجْرِیدُ۔",,,15601,,
15602,"حَدَّثَنَا وَکِیعٌ ، عَنْ فِطْرٍ ، عَنْ فُضَیْلٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : الْقَارِنُ وَالْمُتَمَتِّعُ تُجْزِئُہُمَا شَاۃٌ شَاۃٌ یَشْتَرِیَانِہِمَا مِنْ مَکَّۃَ۔",,,15602,,
15603,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : کَانَ أَحَبُّ الأَشْیَائِ إلَیْہِ أَنْ یُحْرِمَ الْقَارِنُ إذَا سَاقَ ، وَإِنْ لَمْ یَسُقْ فَلاَ یُعْجِبُہُ۔",,,15603,,
15604,"حَدَّثَنَا حُمَیْدٌ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، قَالَ : حدَّثَنَا بَعْضُ أَصْحَابِنَا ، أَنَّہُ سَأَلَ جَابِرَ بْنَ عَبْدِ اللہِ ألہ أَنْ یَقْرِنَ بَیْنَ حَجَّۃٍ وَعُمْرَۃٍ بِغَیْرِ ہَدْیٍ ، فَقَالَ : مَا رَأَیْت أَحَدًا مِنَّا فَعَلَ ذَلِکَ۔",,,15604,,
15605,حَدَّثَنَا وَکِیعٌ ، عَنْ شَرِیکٍ ، عَنْ جَابِرِ عن عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، عَنْ أَبِیہِ ، أَنَّہُ قَرَنَ وَاشْتَرَی ہَدْیَہُ مِنْ مَکَّۃَ,,,15605,,
15606,حَدَّثَنَا عَبْدُ الرَّزَّاقِ، عَنْ مَعْمَرٍ، عَنْ عَبْدِ الْکَرِیمِ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ، أَنَّہُ کَرِہَ أَنْ یَقْرِنَ إِلاَّ أَنْ یَسُوقَ,,,15606,,
15607,حَدَّثَنَا عَبْدُ الرَّزَّاقِ ، عَنْ مَعْمَرٍ ، عَنْ خُصَیْفٍ ، أَوْ عَلِیِّ بْنِ بَزِیمَۃَ ، عَنْ مُجَاہِدٍ بِنَحْوٍ مِنْہُ۔,,,15607,,
15608,حَدَّثَنَا وَکِیعٌ ، عَنْ مُحَمَّدِ بْنِ مُسْلِمٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، عَنْ أَبِیہِ ، أَنَّہُ کَرِہَ أَنْ یَرْمِیَ الْجِمَارَ عَلَی غَیْرِ وُضُوئٍ۔,,,15608,,
15609,حَدَّثَنَا وَکِیعٌ ، عَنْ مُحَمَّدِ بْنِ مُسْلِمٍ ، عَمَّنْ سَمِعَ عَطَائً یَکْرَہُ أَنْ یَرْمِیَ الْجِمَارَ عَلَی غَیْرِ وُضُوئٍ ، وَإِنْ فَعَلَ أَجْزَأَہُ۔,,,15609,,
15610,حَدَّثَنَا وَکِیعٌ ، عَنِ الْعُمَرِیِّ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ یَغْتَسِلُ إذَا رَمَی الجَمْرَۃَ۔,,,15610,,
15611,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ مُجَاہِدٍ ، قَالَ : کَانُوا یَغْتَسِلُونَ إذَا رَاحُوا إلَی الْجِمَارِ۔",,,15611,,
15612,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَطَائٍ ، أَنَّہُ کَرِہَ أَنْ یَرْمِیَ الْجِمَارَ عَلَی غَیْرِ وُضُوئٍ۔,,,15612,,
15613,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الْحَجَّاجِ ، عَنِ الْحَکَمِ ، قَالَ : کَانُوا یَغْتَسِلُونَ إذَا رَاحُوا لِلرَّمْیِ۔",,,15613,,
15614,حَدَّثَنَا وَکِیعٌ، عَنْ إسْرَائِیلَ، عَنْ جَابِرٍ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ، أَنَّہُ کَانَ یَغْتَسِلُ إذَا رَاحَ إلَی الْجِمَارِ۔,,,15614,,
15615,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، قَالَ : مَا رَأَیْت ابْنَ عُمَرَ أَرَادَ أَنْ یَرْمِیَ الْجِمَارَ إِلاَّ اغْتَسَلَ۔",,,15615,,
15616,"حَدَّثَنَا وَکِیعٌ ، عَنْ مَنْصُورِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ عَطَائٍ ، قَالَ : سَأَلْتُ ، عَنْ رَجُلٍ سَعَی بَیْنَ الصَّفَا وَالْمَرْوَۃِ أَرْبَعَۃ عَشَرَ مَرَّۃً ، قَالَ : یُعِیدُ۔",,,15616,,
15617,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ عَطَائٍ ، قَالَ : یُجْزِئُہُ",,,15617,,
15618,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ عَبْدِ اللہِ بْنِ سَعِیدٍ ، عَنْ مُجَاہِدٍ ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَسْتَلِمُ الرُّکْنَ الْیَمَانِیَ وَیَضَعُ خَدَّہُ عَلَیْہِ۔",,,15618,,
15619,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنِ الشَّیْبَانِیِّ ، قَالَ : رَأَیْتُ عَمْرَو بْنَ مَیْمُونٍ یَسْتَلِمُ الرُّکْنَ الْیَمَانِیَ وَیَضَعُ خَدَّہُ عَلَیْہِ۔",,,15619,,
15620,"حَدَّثَنَا ابْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : کَانَ یَقُولُ : مَنْ وَقَفَ بِعَرَفَۃَ اسْتَقْبَلَ الْبَیْتَ۔",,,15620,,
15621,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِنَافِعٍ ، کَانَ ابْنُ عُمَرَ یَسْتَقْبِلُ الْبَیْتَ فِی الْمَوْقِفِ یعمدہ ؟ قَالَ : نَعَمْ۔",,,15621,,
15622,حَدَّثَنَا حَاتِمٌ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ جَابِرٍ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَکِبَ حَتَّی أَتَی الْمَوْقِفَ فَجَعَلَ بطن نَاقَتِہِ الْقُصْوَاء إلَی الصَّخَرَاتِ ، وَجَعَلَ جَبَلَ الْمُشَاۃِ بَیْنَ یَدَیْہِ ، وَاسْتَقْبَلَ الْقِبْلَۃَ فَلَمْ یَزَلْ وَاقِفًا حَتَّی غَرَبَتِ الشَّمْسُ۔,,,15622,,
15623,حَدَّثَنَا وَکِیعٌ ، عَنِ الْمَسْعُودِیِّ ، عَنْ جَامِعِ بْنِ شَدَّادٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، أَنَّ عَبْدَ اللہِ لَمَّا أَتَی جَمْرَۃَ الْعَقَبَۃِ اسْتَبْطَنَ الْوَادِیَ ، وَاسْتَقْبَلَ الْکَعْبَۃَ وَجَعَلَہَا عَلَی حَاجِبِہِ الأَیْمَنِ ، ثُمَّ رَمَاہَا بِسَبْعِ حَصَیَاتٍ یُکَبِّرُ مَعَ کُلِّ حَصَاۃٍ۔,,,15623,,
15624,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ إِبْرَاہِیمَ ، عَن عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، أَنَّہُ حَجَّ مَعَ عَبْدِ اللہِ وَأَنَّہُ رَمَی الْجَمْرَ بِسَبْعِ حَصَیَاتٍ وَجَعَلَ الْبَیْتَ ، عَنْ یَسَارِہِ وَمِنًی ، عَنْ یَمِینِہِ ، ثُمَّ قَالَ : ہَذَا مَقَامُ الَّذِی أُنْزِلَتْ عَلَیْہِ سُورَۃُ الْبَقَرَۃِ۔ (بخاری 1747۔ مسلم 307)",,,15624,,
15625,حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُوس ، وَمُجَاہِدٍ ، وَسَعِیدِ بْنِ جُبَیْرٍ أَنَّہُمْ کَانُوا إذَا رَمَوُا الْجِمَارَ اسْتَقْبَلُوا الْبَیْتَ,,,15625,,
15626,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، قَالَ : رَأَیْتُ عَطَائً ، وَعَبْدَ الرَّحْمَن بْنَ الأَسْوَدِ وَعَمْرَو بْنَ دِینَارٍ یَقُومُونَ ، عَنْ یَسَارِ الْجَمْرَۃِ۔",,,15626,,
15627,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ الأَعْمَشِ ، عَنْ عُمَارَۃَ ، قَالَ : قَالَ عُمَرُ : مَنْ قَدَّمَ ثِقَلَہُ لَیْلَۃَ یَنْفِرُ فَلاَ حَجَّ لَہُ۔",,,15627,,
15628,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ أَبِیہِ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ قَالَ : إذَا أَنْتَ ارْتَحَلْت فَلاَ یَسْبِقُک ثِقَلُک، فَإِنَّ ذَلِکَ یُکْرَہُ۔",,,15628,,
15629,"حَدَّثَنَا أَبُو الْحُسَیْنِ، عَنْ شَرِیکٍ، عَنْ لَیْثٍ، عَنْ طَاوُوسٍ، قَالَ: إذَا حَلَّ لَکَ النَّفْرُ فَلاَ بَأْسَ أَنْ تُقَدِّمَ ثِقَلَک۔",,,15629,,
15630,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ إِبْرَاہِیمَ ، عَن عَمْرِو بْنِ شُرَحْبِیلَ ، عَنْ عُمَرَ ، قَالَ : مَنْ قَدَّمَ ثِقَلُہُ قَبْلَ النَّفْرِ فَلاَ حَجَّ لَہُ۔",,,15630,,
15631,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْحَکَمِ ، عَنْ أَبِی عُبَیْدَۃَ بْنِ عَمَّارِ بْنِ یَاسِرٍ ، عَنْ عَمَّارٍ ، قَالَ : إذَا حَلَّ لَکَ النَّفْرُ فَقَدِّمْ ثِقَلَک إِنْ شِئْت۔",,,15631,,
15632,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنِ ابْنِ طَاوُوس، عَنْ أَبِیہِ، قَالَ: إذَا خَرَجَ الْمَکِّیُّ إلَی وَقْتٍ فَتَمَتَّعَ فَعَلَیْہِ الْہَدْیُ۔",,,15632,,
15633,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ طَاوُوسٍ ، قَالَ عَلَیْہِ الْہَدْیُ ، وَقَالَ عَطَائٌ: لَیْسَ عَلَیْہِ شَیْئٌ۔",,,15633,,
15634,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَسَنٍ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُوس ، وَمُجَاہِدٍ ، قَالُوا : إذَا تَمَتَّعَ الْمَکِّیُّ فَلاَ ہَدْیَ عَلَیْہِ",,,15634,,
15635,"حَدَّثَنَا عَبْدَۃَ، عَنْ وِقَائِ بْنِ إیَاسٍ ، عَنْ قُرَیْشٍ ، عَنْ صَعْصَعَۃَ ، قَالَ: سَمِعْتُ رَجُلاً سَأَلَ ابْنَ عُمَرَ ، فَقَالَ: حَلَفْت ، أَوْ جُعِلَتْ عَلَیَّ بَدَنَۃٌ ، أَنْحَرُہَا بِأَرْضِ الَّتِی أَنَا بِہَا ؟ فَقَالَ : لاَ تَنْحَرْہَا دُونَ مَحَلِّ الْبُدْنِ ، فَقَالَ: الرَّجُلُ : إنَّمَا قُلْتُ أَنْحَرُہَا بِأَرْضِ الَّتِی أَنَا بِہَا ؟ فَأَبَی عَبْدُ اللہِ بْنُ عُمَرَ ، فَقَالَ : مَنْ شَائَ زَیَّنَ لَہُ الشَّیْطَانُ۔",,,15635,,
15636,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ وِقائٍ ، عَنْ سَعِیدِ بْنُ جُبَیْرٍ ، قَالَ ذَکَرْتُ لَہُ قَوْلَ ابْنِ عُمَرَ انْحَرْہَا بِمَکَّۃَ ، فَقَالَ : مَا شَعَرْت۔",,,15636,,
15637,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ وَإِسْمَاعِیلُ بْنُ سَالِمٍ ، عَنِ الشَّعْبِیِّ ، وَعَبْدُ الْمَلِکِ ، عَنْ عَطَائٍ، قَالُوا : مَنْ جُعِلَ عَلَیْہِ بَدَنَۃٌ فَبِمَکَّۃَ ، وَإذَا قَالَ : جَزُورٌ ، أَوْ بَقَرَۃٌ فَحَیْثُ شَائَ وحَیْثُ نَوَی۔",,,15637,,
15638,"حَدَّثَنَا سَلاَّمٌ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، قَالَ : إذَا جَعَلَ الرَّجُلُ عَلَیْہِ بَدَنَۃً فَلْیَنْحَرْہَا حَیْثُ سَمَّی ، فَإِنْ لَمْ یُسَمِّ فَلْیَنْحَرْہَا بِمَکَّۃَ۔",,,15638,,
15639,"حَدَّثَنَا مَحبُوبٌ الْقَوَارِیرِیُّ ، عَنْ مَالِکِ بْنِ حَبِیبٍ ، قَالَ : سَمِعْتُ سَالِمَ بْنَ عَبْدِ اللہِ وَسُئِلَ عَنِ الْبُدْنِ ، فَقَالَ : لاَ تفی بَدَنَۃٌ إِلاَّ بِہَذَا الْبَلَدِ یَعْنِی مَکَّۃَ۔",,,15639,,
15640,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِیہِ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، وَعِکْرِمَۃَ ، قَالاَ : لاَ مَحَلَّ لِلْبُدْنِ دُونَ الْبَیْتِ الْعَتِیقِ۔",,,15640,,
15641,"حَدَّثَنَا أَبُو نُعَیْمٍ ، عَنْ ہِشَامٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ فِی الرَّجُلِ یَجْعَلُ عَلَیْہِ بَدَنَۃً ، قَالَ : یَنْحَرُہَا حَیْثُ شَائَ ، وحَیْثُ نَوَی۔",,,15641,,
15642,"حَدَّثَنَا وَکِیعٌ ، عَنْ شَرِیکٍ ، عَنْ جَابِرٍ ، عَنْ جَہْمٍ الْبَکْرِیِّ ، أَنَّ رَجُلاً نَذَرَ أَنْ یَنْحَرَ بدنۃ بِالْکُوفَۃِ فَسَأَلَ ابْنَ مَسْعُودٍ ، فَقَالَ : انْحَرْہَا حَیْثُ شِئْت۔",,,15642,,
15643,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَبَلَۃَ ، قَالَ : سَمِعْتُ ابْنَ عُمَرَ یَقُولُ : مَنْ سَمَّی ، أَوْ نَذَرَ بَدَنَۃً فَلاَ مَحَلَّ لَہَا دُونَ الْبَیْتِ ، وَمَنْ سَمَّی جَزُورًا أوْ بَقَرَۃً فَحَیْثُ شَائَ۔",,,15643,,
15644,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، وَعَنْ أَنَسٍ ، عَنِ الْحَسَنِ ، قَالاَ : نِیَّتُہُ ؟۔",,,15644,,
15645,"حَدَّثَنَا عَبْدَۃُ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : مَنْ نَذَرَ بَدَنَۃً فَلاَ یَنْحَرْہَا إِلاَّ بِمِنًی ، أَوْ مَکَّۃَ ، وَمَنْ نَذَرَ جَزُورًا فَلْیَنْحَرْہَا حَیْثُ شَائَ۔",,,15645,,
15646,"حَدَّثَنَا غُنْدَرٌ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، وَالْحَسَنِ ، قَالاَ : إذَا قَالَ عَلَیَّ ہَدْیٌ فَبِمَکَّۃَ ، وَإذَا قَالَ : بَدَنَۃٌ ، فَحَیْثُ شَائَ۔",,,15646,,
15647,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرٍ ، عَنْ مَیْمُونٍ ، قَالَ : مَنْ جَعَلَ عَلَیْہِ بَدَنَۃً ، فَإِنَّہُ لاَ یَنْحَرُہَا إِلاَّ بِمَکَّۃَ ، وَمَنْ جَعَلَ عَلَیْہِ جَزُورًا نَحَرَہَا حَیْثُ شَائَ۔",,,15647,,
15648,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ أَبِی حنیفۃ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا أَہَلَّتْ بِعُمْرَۃٍ فَخَافَتْ فَوْتَ الْحَجِّ أَہَلَّتْ بِالْحَجِّ ، وَقَضَتِ الْعُمْرَۃَ ، وَعَلَیْہَا دَمٌ ، وَالْعُمْرَۃُ۔",,,15648,,
15649,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، وَعَطَائٍ ، قَالَ : سَأَلْتُہُمَا ، عَنِ امْرَأَۃٍ قَدِمَتْ مَکَّۃَ مُعْتَمِرَۃً ، فَحَاضَتْ فَخَشِیَتْ أَنْ یَفُوتَہَا الْحَجُّ ، فَقَالاَ : تُہِلُّ بِالْحَجِّ وَتَقْضِی۔",,,15649,,
15650,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ أَہَلَّ بِعُمْرَۃٍ فَجَائَ وَالنَّاسُ وُقُوفٌ بِعَرَفَۃَ ، فَقَالَ : إِنْ عَلِمَ ، أَنَّہُ یُدْرِکُ مَکَّۃَ أَتَاہَا فَحَلَّ مِنْ عُمْرَتِہِ ، وَإِلاَّ أَہَلَّ بِالْحَجِّ وَطَافَ طَوَافَیْنِ۔",,,15650,,
15651,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ زِیَادِ بْنِ سَعْدٍ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، قَالَ : تَکُونُ رَافِضَۃً لِلْعُمْرَۃِ ، وَعَلَیْہَا دَمٌ ، وَعُمْرَۃٌ مَکَانَہَا۔",,,15651,,
15652,حَدَّثَنَا وَکِیعٌ ، عَنْ قُرَّۃَ بْنِ خَالِدٍ ، عَنِ ابْنِ سِیرِینَ ، أَنَّہُ کَانَ یَسْتَحِبُّ عُمْرَۃَ الْمُحَرَّمِ۔,,,15652,,
15653,"حَدَّثَنَا إسْمَاعِیلُ بْنُ إِبْرَاہِیمَ ، عَن أَیُّوبَ ، قَالَ : قُلْتُ لِسَالِمِ بْنِ عَبْدِ اللہِ : عُمْرَۃُ الْمُحَرَّمِ أبت ہی ، قَالَ : نَعَمْ۔",,,15653,,
15654,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ، عَنِ ابْنِ عَوْنٍ، قَالَ: قُلْتُ لِلْقَاسِمِ: الْعُمْرَۃُ فِی الْمُحَرَّمِ؟ قَالَ: کَانُوا یَرَوْنَہَا تَامَّۃً۔",,,15654,,
15655,"حَدَّثَنَا عَبْدُ الْوَہَّابِ بْنُ عَطَائٍ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ أَیُّوبَ ، قَالَ : سَأَلْتُ سُلَیْمَانَ بْنَ یَسَارٍ وَسَالِمَ بْنَ عَبْدِ اللہِ ، عَنْ عُمْرَۃِ الْمُحَرَّمِ ، فَقَالاَ : تَامَّۃٌ تُقْضَی۔",,,15655,,
15656,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنِ التَّیْمِیِّ ، قَالَ : سُئِلَ طَاوُوس ، عَنْ عُمْرَۃِ الْمُحَرَّمِ ؟ فَقَالَ : لاَ وَرَبِّ ہَذِہِ مَا أَدْرِی مَا ہِیَ۔",,,15656,,
15657,حَدَّثَنَا وَکِیعُ بْنُ الْجَرَّاحِ ، عَنِ النَّہَّاسِ بْنِ قَہْمٍ ، عَنْ عَطَائٍ ، أَنَّہُ کَانَ یَسْتَحِبُّ أَنْ لاَ یَخْرُجَ مِنْ طَوَافِہِ إِلاَّ عَلَی وِتْرٍ۔,,,15657,,
15658,"حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ حَسَنِ بْنِ یَزِیدَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : طَوَافَانِ أَحَبُّ إلَیَّ مِنْ طَوَافٍ۔",,,15658,,
15659,حَدَّثَنَا وَکِیعٌ، عَنِ الْعُمَرِیِّ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّہُ کَانَ یَنْصَرِفُ اللَّیْلَ وَالنَّہَارَ عَلَی وِتْرٍ مِنْ طَوَافِہِ۔,,,15659,,
15660,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنْ عَطَائٍ ، أَنَّہُ کَانَ یُحِبُّ أَنْ یَنْصَرِفَ عَلَی وِتْرٍ مِنْ طَوَافِہِ ، وَکَانَ الْحَسَنُ یَقُولُ : عَشْرَۃٌ أَحَبُّ إلَیَّ مِنْ تِسْعَۃٍ ، وَثَمَانِیَۃٌ أَحَبُّ إلَیَّ مِنْ سَبْعَۃٍ۔",,,15660,,
15661,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الْحَسَنِ بْنِ یَزِیدَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، أَنَّہُ کَانَ یَقُولُ : طَوَافَانِ أَحَبُّ إلَیَّ مِنْ طَوَافٍ۔",,,15661,,
15662,"حَدَّثَنَا أَبُو سَعد ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، أَنَّ عَبْدَ الرَّحْمَن بْنَ أَبِی بَکْرٍ طَافَ فِی إمَارَۃِ سَعِیدٍ فَخَرَجَ إلَی الصَّلاَۃِ ، فَقَالَ عَبْدُ الرَّحْمَنِ : انْتَظِرْ حَتَّی أَنْصَرِفَ عَلَی وتر ، قَالَ فانتظرہ قَالَ فَانْصَرَفَ عَلَی ثَلاَثَۃِ أَطْوَافٍ ، ثُمَّ لَمْ یَعُدْ لِذَلِکَ السَّبْعِ۔",,,15662,,
15663,"حَدَّثَنَا عُمَر بْنُ ہَارُونَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : ثَلاَثَۃُ أَسْبَاعٍ أَحَبُّ إلَیَّ مِنْ أَرْبَعٍ۔",,,15663,,
15664,"حَدَّثَنَا عَبْدُ الأَعْلَی، عَنْ یُونُسَ، عَنِ الْحَسَنِ؛ فِی رَجُلٍ طَافَ بِالْبَیْتِ وَنَسِیَ أَنْ یَرْمُلَ، قَالَ: یُہَرِیقُ دَمًا۔",,,15664,,
15665,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنْ عَطَائٍ ، قَالَ : إِنْ نَسِیَ أَنْ یَرْمُلَ الثَلاَثَۃَ أَشْوَاطٍ رَمَلَ فِیمَا بَقِیَ ، وَإِنْ لَمْ یَبْقَ إِلاَّ شَوْطٌ وَاحِدٌ رَمَلَ فِیہِ ، وَلاَ شَیْئَ عَلَیْہِ ، فَإِنْ لَمْ یَرْمُلْ فِی شَیْئٍ مِنْہُنَّ فَلاَ شَیْئَ عَلَیْہِ۔",,,15665,,
15666,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : یُکْرَہُ أَنْ یُسْنِدَ الْإِنْسَان ظَہْرَہُ إلَی الْکَعْبَۃِ یَسْتَدْبِرُہَا۔",,,15666,,
15667,حَدَّثَنَا وَکِیعٌ ، عَنْ خَلِیفَۃَ بْنِ خَیَّاطٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ خَطَبَ وَہُوَ مُسْنِدٌ ظَہْرَہُ إلَی الْکَعْبَۃِ۔ (احمد 2/191),,,15667,,
15668,"حَدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ فِی قَوْلِہِ : {ذَلِکَ لِمَنْ لَمْ یَکُنْ أَہْلُہُ حَاضِرِی الْمَسْجِدِ الْحَرَامِ} قَالَ : لَیْسَ حَاضِرِی الْمَسْجِدِ الْحَرَامِ إِلاَّ أَہْلُ الْحَرَمِ۔",,,15668,,
15669,"حَدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، قَالَ : أَہْلُ فَخٍّ وَأَہْلُ ضَجَنَانَ وَأَہْلُ عَرَفَۃَ ہُمْ أَہْلُہُ۔",,,15669,,
15670,"حَدَّثَنَا أَبُو الأَحْوَصِ، عَنْ لَیْثٍ، عَنْ عَطَائٍ، قَالَ: إذَا اسْتَعْصَی عَلَیْک الْہَدْیُ حِینَ تُرِیدُ أَنْ تَنْحَرَہُ فَعَرْقِبْہُ۔",,,15670,,
15671,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، قَالَ : إذَا اسْتَعْصَتْ عَلَیْک الْبَدَنَۃُ فَعَرْقِبْہَا۔",,,15671,,
15672,"حَدَّثَنَا عَبْدُ اللہِ بْنُ الْمُبَارَکِ ، عَنْ عُثْمَانَ ، عَنْ مُجَاہِدٍ ، قَالَ : لاَ تُعَرْقَبُ الْبُدْنُ۔",,,15672,,
15673,"حَدَّثَنَا عَبْدُ اللہِ بْنُ الْمُبَارَکِ ، عَنْ أَفْلَحَ ، عَنِ الْقَاسِمِ ، قَالَ : لاَ تُعَرْقَبُ الْبُدْنُ۔",,,15673,,
15674,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، قَالَ : کَانَ أَبِی یَحْزمُ عَلَی بَطْنِہِ الثَّوْبَ ، وَلاَ یَعْقِدُہ وَہُوَ مُحْرِمٌ۔",,,15674,,
15675,"حَدَّثَنَا ابْنُ فُضَیْلٍ، عَنْ لَیْثٍ، عَنْ عَطَائٍ، وَطَاوُوس، قَالاَ: رَأَیْنَا ابْنَ عُمَرَ وَہُوَ مُحْرِمٌ وَقَدْ شَدَّ حَقْوَیْہِ بِعِمَامَۃٍ۔",,,15675,,
15676,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنْ مُسْلِمِ بْنِ جُنْدُبٍ ، قَالَ : سَمِعْتُ ابْنَ عُمَرَ یَقُولُ : لاَ تَعْقِدْ عَلَیْک شَیْئًا وَأَنْتَ مُحْرِمٌ۔",,,15676,,
15677,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : لاَ بَأْسَ أَنْ یَعْقِدَ عَلَی الْقَرْحَۃِ۔",,,15677,,
15678,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنْ صَالِحِ بْنِ أَبِی حَسَّانَ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَبْصَرَ رَجُلاً محتزما بِحَبْلٍ أَبْرَقَ وَہُوَ مُحْرِمٌ ، فَقَالَ : یَا صَاحِبَ الْحَبْلِ أَلْقِہِ۔ (ابوداؤد 158)",,,15678,,
15679,"حَدَّثَنَا الْعُکْلِیُّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عَطَائٍ الْخُرَاسَانِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : لاَ بَأْسَ أَنْ یَعْقِدَ الْمُحْرِمُ عَلَی الْجُرْحِ۔",,,15679,,
15680,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِبْرَاہِیمَ ، عَن عَطَائٍ ، قَالَ : لاَ بَأْسَ أَنْ یَعْصِبَ عَلَی الْجُرْحِ۔",,,15680,,
15681,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ بَأْسَ بِہِ۔",,,15681,,
15682,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، قَالَ : إذَا کُسِرَتْ یَدُ الْمُحْرِمِ ، وَإِذَا شُجَّ عَصَبَ عَلَیْہَا ، قَالَ مَنْصُور : وَلَیْسَ عَلَیْہِ شَیْئٌ۔",,,15682,,
15683,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ فِی الْمُحْرِمِ تَنْکَسِرُ یَدُہُ أَیُدَاوِیہَا ؟ قَالَ : نَعَمْ ، وَیَعْصِبُ عَلَیْہَا بِخِرْقَۃٍ۔",,,15683,,
15684,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، قَالَ : قلْت لِجَابِرِ بْنِ زَیْدٍ : یَنْحَلُّ إزَارِی بِعَرَفَۃَ فَأَعْقِدُہُ ؟ قَالَ : نَعَمْ۔",,,15684,,
15685,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ ہِشَامِ بْنِ حُجَیْرٍ ، قَالَ رَأَی طَاوُوس ابْنَ عُمَرَ یَطُوفُ وَقَدْ شَدَّ حَقْوَہُ بِعِمَامَۃٍ۔,,,15685,,
15686,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنِ الْقَاسِمِ ، عَنْ عَائِشَۃَ ، أَنَّہَا سُئِلَتْ ، عَنِ الْہِمْیَانِ لِلْمُحْرِمِ ، فَقَالَتْ : أَوْثِقْ نَفَقَتِکَ فِی حَقْوَیک۔",,,15686,,
15687,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، قَالَ : سَأَلْتُ أَبَا جَعْفَرٍ وَعَطَائً ، عَنِ الْہِمْیَانِ لِلْمُحْرِمِ ، فَقَالاَ : لاَ بَأْسَ بِہِ۔",,,15687,,
15688,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، قَالَ : لاَ بَأْسَ بِالمَنْطِقَۃ للِمُحْرِم۔",,,15688,,
15689,"حَدَّثَنَا وَکِیعٌ ، عَنْ عُمَرَ بْنِ مُحَمَّدٍ ، قَالَ : سَأَلْتُ سَالِمَ بْنَ عَبْدِ اللہِ ، عَنِ الْمِنْطَقَۃِ لِلْمُحْرِمِ ، فَقَالَ : لاَ بَأْسَ بِہَا وَرَأَیْت عَلَیْہِ ثَوْبًا مُوَرَّدًا۔",,,15689,,
15690,"حَدَّثَنَا حَفْصٌ ، عَنِ الْحَجَّاجِ ، عَنِ الْحَکَمِ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ ، وَإِنْ کَانَ عَرِیضًا۔",,,15690,,
15691,حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ یَحْیَی ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَرِہَہُ۔,,,15691,,
15692,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَفْلَحَ ، عَنِ الْقَاسِمِ ، قَالَ : لاَ بَأْسَ بِہِ۔",,,15692,,
15693,"حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ مُطَرِّفٍ ، عَنْ صَالِحِ بْنِ جُبَیْرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، أَنَّہُ سُئِلَ عَنِ الرَّجُلِ تَکُونُ مَعَہُ الدَّرَاہِمُ یَشُدُّہَا عَلَی حَقْوَیْہِ ، قَالَ : نَعَمْ ، وَلاَ یَشُدُّہَا عَلَی عَقْدِ الإِزَارِ۔",,,15693,,
15694,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، أَنَّہُ کَرِہَ الْہِمْیَانَ لِلْمُحْرِمِ۔,,,15694,,
15695,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی بکیر ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : لاَ بَأْسَ بِالْہِمْیَانِ لِلْمُحْرِمِ۔",,,15695,,
15696,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حُمَیْدٍ الأَعْرَجِ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ بَأْسَ بِہِ۔",,,15696,,
15697,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، قَالَ : یَلْبَسُ الْہِمْیَانَ : یَعْنِی الْمُحْرِمُ۔",,,15697,,
15698,حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، أَنَّ ابن الزُّبَیْرَ قَدِمَ حَاجًّا فَرَمَلَ فِی الثَلاَثَۃِ الأَطْوَافٍ حَتَّی رَأَیْت مِنْطَقَتہ عَلَی بَطْنِہِ انْقَطَعَتْ۔,,,15698,,
15699,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامِ بْنِ حَسَّانَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ یَلْبَسَ الْمُحْرِمُ الْہِمْیَانَ إِنْ کَانَ یُحْرِزُ فِیہِ نَفَقَتَہُ۔,,,15699,,
15700,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، قَالَ : سَأَلْتُ عَنْہُ مُحَمَّدَ بْنَ کَعْبٍ ، فَقَالَ : اخْتَلَفَ فِیہِ الْفُقَہَائُ ، فَإِنْ شَدَّدْتَ فَحَسَنٌ ، وَإِنْ رَخَّصْتَ فَحَسَنٌ۔",,,15700,,
15701,"حَدَّثَنَا حَفْصٌ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : لاَ بَأْسَ بِالْہِمْیَانِ لِلْمُحْرِمِ ، وَلَکِنْ لاَ یَعْقِدُ عَلَیْہِ السَّیْرَ وَلَکِنَّہ یَلُفُّہُ لَفًّا۔",,,15701,,
15702,"حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ خُصَیْفٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لاَ یُجَاوِزُ أَحَدٌ الْوَقْتَ إِلاَّ الْمُحْرِمُ۔",,,15702,,
15703,"حَدَّثَنَا شَرِیکٌ، عَنْ أَبِی إِسْحَاقَ، عَنْ عَطَائٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: لاَ یُجَاوِزْ أَحَدٌ ذَاتَ عِرْقٍ حَتَّی یُحْرِمَ۔",,,15703,,
15704,"حَدَّثَنَا ابْنُ فُضَیْلٍ، عَنْ دَاوُدَ، عَنْ مُجَاہِدٍ، أَنَّہُ قَالَ لہ: إذَا جِئْت مِنْ بَلَدٍ آخَرَ فَلاَ تُجَاوِزَ الْحَدَّ حَتَّی تُحْرِمَ۔",,,15704,,
15705,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنْ مُحَمَّدِ ، أَنَّہُ کَانَ یَقُولُ : لاَ یُجَاوِزَ الْوَقْتَ حَتَّی تُحْرِمَ۔",,,15705,,
15706,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، قَالَ : کَانَ عَطَائٌ یُرَخِّصُ فِی الْقَضِیبِ وَالسِّوَاکِ وَالسَّنَا مِنَ الْحَرَمِ۔",,,15706,,
15707,حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، أَنَّہُ کَرِہَہُ۔,,,15707,,
15708,"حَدَّثَنَا جریر ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : لاَ یَخْرُجُ الْمُحْرِمُ مِنَ الْحَرَمِ۔",,,15708,,
15709,"حَدَّثَنَا شَرِیکٌ ، عَنْ عَلِیِّ بْنِ بَذِیمَۃَ ، عَنْ مَوْلًی لابْنِ عَبَّاسٍ ، قَالَ : تَمَتَّعْت فَنَسِیت أَنْ أَنْحَرَ وَأَخَّرْت ہَدْیِی حَتَّی مَضَتِ الأَیَّامُ فَسَأَلْت ابْنَ عَبَّاسٍ ، فَقَالَ : اہْدِ ہَدْیًا لِہَدْیِکَ وَہَدْیًا لِمَا أَخَّرْت۔",,,15709,,
15710,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ زَیْدٍ ، عَنِ الصَّلْتِ بْنِ راشد ، قَالَ : سَأَلْتُ طَاوُوسًا ، عَنْ رَجُلٍ تَمَتَّعَ فَلَمْ یَصُمْ ، وَلَمْ یَذْبَحْ حَتَّی مَضَتِ الأَیَّامُ ، قَالَ : فَقَالَ : یَذْبَحُ ، قُلْتُ : لاَ یَجِدُ ، قَالَ : یَبِیعُ ثَوْبَہُ ، قُلْتُ : لاَ یَجِدُ ، قَالَ : فَلْیَسْتَسْلِفْ مِنْ أَصْحَابِہِ ، قُلْتُ : لاَ یُعْطُونَہُ ، قَالَ : کَذَبْت۔",,,15710,,
15711,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ زَیْدٍ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ عَطَائٍ ، وَسَعِیدِ بْنِ جُبَیْرٍ فِی الرَّجُلِ تَمَتَّعَ فَلَمْ یَذْبَحْ ، وَلَمْ یَصُمْ ، قَالَ فَقَالاَ : أَوْجَبَ عَلَیْہِ الدَّمَ۔",,,15711,,
15712,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثقفی عن حبیب ، قَالَ : سُئِلَ عَطَائٌ ، عَنِ الْعُمْرَۃِ فِی غَیْرِ أَشْہُرِ الْحَجِّ ، فِیہَا ہَدْیٌ وَاجِبٌ ؟ قَالَ : لَیْسَ فِیہَا ہَدْیٌ وَاجِبٌ ، وَقَدْ کَانُوا یُہْدُونَ ، وَقَدْ أَہْدَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حِینَ صَدَّہُ الْمُشْرِکُونَ فَہَلْ کَانَ أَحْرَمَ بِالْعُمْرَۃِ ؟ قَالَ : نَعَمْ وَصَالَحَہُمْ أَنْ یَأْتِیَہُمْ فِی الْعَامِ الْمُقْبِلِ ، وَقَدْ رَأَیْت مُعَاوِیَۃَ یَنْحَرُ جَزُورًا فِی الْعُمْرَۃِ فِی غَیْرِ أَشْہُرِ الْحَجِّ۔",,,15712,,
15713,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُوسَی بْنِ أَبِی کَثِیرٍ ، عن مجاہد ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لَمَّا أُحْصِرَ فَنَحَرَ الْہَدْیَ حَلَقَ رَأْسَہُ۔,,,15713,,
15714,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ حَرْمَلَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : یَقْتُلُ الْمُحْرِمُ الذِّئْبَ۔ (ابوداؤد 137۔ عبدالرزاق 8384)",,,15714,,
15715,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ حَرْمَلَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، أَنَّ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : یَقْتُلُ الْمُحْرِمُ الذِّئْبَ۔",,,15715,,
15716,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ وَبَرَۃَ ، عَنِ ابْنٍ عُمَرَ قَالَ : یَقْتُلُ الْمُحْرِمُ الذِّئْبَ۔",,,15716,,
15717,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سَالِمٍ ، عَنْ سَعِیدِ ، عَنْ وَبَرَۃَ، عَنِ ابْنِ عُمَرَ قَالَ: یَقْتُلُ الْمُحْرِمُ الذِّئْبَ",,,15717,,
15718,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ سَالِمٍ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ، قَالَ: اُطْرُدِ الذِّئْبَ، عَنْ رَحْلِکَ وَأَنْتَ مُحْرِمٌ۔",,,15718,,
15719,"حَدَّثَنَا حَاتِمٌ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ حَرْمَلَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : یَقْتُلُ الْمُحْرِمُ الذِّئْبَ۔",,,15719,,
15720,"حَدَّثَنَا ابن الْمُبَارَکِ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ قَبِیصَۃَ بْنِ ذُؤَیْبٍ ، قَالَ : یُقْتَلُ الذِّئْبُ فِی الْحَرَمِ۔",,,15720,,
15721,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ إسْمَاعِیلَ ، عَنِ الْحَسَنِ ، وَعَطَائٍ فِی الْمُحْرِمِ یَقْتُلُ الذِّئْبَ وَالأَسَدَ ، قَالاَ: اُقْتُلْہُ ، فَإِنَّہُ عَدُوٌّ۔",,,15721,,
15722,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ، عَنِ ابْنِ أَبِی ذِئْبٍ، عَنِ الزُّہْرِیِّ، عَنْ عُمَرَ، قَالَ: یَقْتُلُ الْمُحْرِمُ الذِّئْبَ وَالْحَیَّۃَ۔",,,15722,,
15723,"حَدَّثَنَا ابْنُ إدْرِیسُ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : اُقْتُلِ الذِّئْبَ وَکُلَّ عَدُوٍّ لَمْ یُذْکَرْ فِی الْکِتَابِ۔",,,15723,,
15724,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِبْرَاہِیمَ بْنِ نَافِعٍ ، أَنَّ امْرَأَۃً أَعْجَمِیَّۃً قَدِمَتْ فَقَضَتِ الْمَنَاسِکَ کُلَّہَا ، غَیْرَ أَنَّہَا لَمْ تُہِلَّ بِشَیْئٍ ، فَقَالَ عَطَائٌ : لاَ یُجْزِئُہَا۔\n\nوَقَالَ طَاوُوس : یُجْزِئُہَا ، قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : یَسِّرُوا ، وَلاَ تُعَسِّرُوا۔\n\n(بخاری 69۔ ابوداؤد 4802)",,,15724,,
15725,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ حُمَیْدٍ ، عَنْ بَکْرٍ ، أَنَّ رَجُلاً أَعْجَمِیًّا حَجَّ فَلَمْ یُسَمِّ حَجًّا ، وَلاَ عُمْرَۃً، وَقَالَ : أَنَا مَعَ النَّاسِ ، فَقَالَ : إنِّی لأَرْجُو أَنْ یَکُونَ قَدْ دَخَلَ فِی أَحْسَنِ مَا عَمِلُوا۔",,,15725,,
15726,حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ نَافِعٍ ، أَنَّ کَعْبًا أَہْدَی بَقَرَۃً مُقَلَّدَۃً۔,,,15726,,
15727,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی بِشْرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : الْبَقَرُ تُقَلَّدُ ، وَلاَ تُشْعَرُ۔",,,15727,,
15728,حَدَّثَنَا وَکِیعٌ ، عَنِ الْعُمَرِیِّ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ یُقَلِّدُ الْبَقَرَۃَ وَیُشْعِرُہَا فِی أَسْنِمَتِہَا ، فَإِنْ لَمْ یَکُنْ لَہَا سَنَامٌ فَمَوْضِعُہُ۔,,,15728,,
15729,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ خُصَیْفٍ ، عَنْ عَطَائٍ ، وَطَاوُوس ، وَمُجَاہِدٍ أَنَّہُمْ ، قَالُوا : لاَ عُمْرَۃَ إلاَّ عُمْرَۃٌ ابْتَدَأْتَہَا مِنْ أَہْلِکَ ، وَلاَ عُمْرَۃَ بَعْدَ الصَّدَرِ ، وَقَالَ سَعِیدُ بْنُ جُبَیْرٍ : إِنْ رَجَعَ إلَی مِیقَاتِ أَرضَۃٍ مُتَمَتِّعٌ رجوت أَنْ تَکُونَ عُمْرَۃً",,,15729,,
15730,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ ، قَالَ : کُنَّا نَبْلُغُ الْمَدِینَۃَ بِلُحُومِ الأَضَاحِیِّ۔",,,15730,,
15731,"حَدَّثَنَا ابْنُ مُسْہِرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ جَابِرٍ ، قَالَ : کُنَّا لاَ نَأْکُلُ مِنَ الْبُدْنِ إِلاَّ أَیَّامَ مِنًی ، فَرَخَّصَ لَنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : کُلُوا وَتَزَودوا فَأَکَلْنَا وَتَزَوَّدْنَا ، قَالَ : قُلْنَا لِعَطَائٍ : أَتَرَاہُ خُصَّ ہَدْیَ الْمُتْعَۃِ وَحْدَہُ ؟ قَالَ : لاَ وَلَکِنْ لاَ أَرَاہُ إِلاَّ الْہَدْیَ کُلَّہُ۔ (بخاری 2980۔ مسلم 30)",,,15731,,
15732,حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنْ نَافِعٍ ، أَنَّ ابْنَ عُمَرَ کَانَ لاَ یَأْکُلُ فَوْقَ ثَلاَثٍ۔,,,15732,,
15733,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی حَصِینٍ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ، عَنْ عَلِیٍّ ، أَنَّہُ قَالَ : لاَ یَأْکُلُ أَحَدٌ مِنْ أُضْحِیَّتِہِ فَوْقَ ثَلاَثٍ۔",,,15733,,
15734,"حَدَّثَنَا وَکِیعٌ ، عَنِ الْبَخْتَرِیِّ بْنِ الْمُخْتَارِ ، عَنِ ابْنِ معقل ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: کُنْت نَہَیْتُکُمْ ، عَنْ لُحُومِ الأَضَاحِیِّ فَکُلُوا وَتَزَوَّدُوا فِی أَسْفَارِکُمْ۔",,,15734,,
15735,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ عَطَائٍ ، عَنْ جَابِرٍ ، قَالَ : کُنَّا نَتَزَوَّدُہَا إلَی الْمَدِینَۃِ عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔ (بخاری 2980۔ مسلم 1562)",,,15735,,
15736,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : کُنَّا نَہْبِطُ بِہَا الأَمْصَارَ۔",,,15736,,
15737,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ إبْرَاہِیمَ بْنِ مَیْسَرَۃَ ، عَنْ أَنَسٍ ، قَالَ : کُنَّا نَذْبَحُ مَا شَائَ اللَّہُ مِنْ أَضَاحِینَا وَنَأْکُلُ بَقِیَّتَہَا بِالْبَصْرَۃِ۔",,,15737,,
15738,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یَحُجُّ ، عَنِ الرَّجُلِ الَّذِی لَمْ یَحُجَّ ، قَالَ : یُجْزِئُہُ۔",,,15738,,
15739,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ دَاوُدَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : إنَّ اللَّہَ لَوَاسِعٌ لَہُمَا جَمِیعًا۔",,,15739,,
15740,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یَحُجُّ ، عَنِ الرَّجُلِ ، قَالَ : یُرْجَی لَہُ مِثْلُ أَجْرِہِ۔",,,15740,,
15741,"حَدَّثَنَا وَکِیعٌ ، عَنْ نَافِعِ بْنِ عُمَرَ ، عَنْ سَعِیدِ بْنِ حَسَّانَ ، عَنِ ابْنِ عُمَرَ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَنْزِلُ وَادِیَ نَمِرَۃَ ، فَلَمَّا قَاتَلَ الْحَجَّاجُ ابْنَ الزُّبَیْرِ أَرْسَلَ إلَیَّ أَی سَاعَۃٍ کَانَ یَرُوحُ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی ہَذَا الْیَوْمِ ، فَقَالَ : إذَا کَانَ ذَلِکَ رُحْنَا ، فَأَرْسَلَ الْحَجَّاجُ رَجُلاً ، فَقَالَ : إذَا رَاحَ فَأَعْلِمْنِی ، فَأَرَادَ ابْنُ الزُّبَیْرِ أَنْ یَرُوحَ فَقَالُوا : لَمْ تَزِغِ الشَّمْسُ فَجَلَسَ ، ثُمَّ أَرَادَ أَنْ یَرُوحَ فَقَالُوا : لَمْ تَزِغِ الشَّمْسُ فَجَلَسَ ، فَلَمَّا ، قَالُوا : قَدْ زَاغَتْ ، رَاحَ۔ (احمد 25۔ ابوداؤد 1909)",,,15741,,
15742,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ طَلْقٍ ، قَالَ : قَالَ عُمَرُ لِزَیْدِ بْنِ صُوحَانَ أَیْنَ مَنْزِلُک بِمِنًی ؟ قَالَ فِی الشِّقِّ الأَیْسَرِ ، قَالَ : قَالَ ذَلِکَ مَنْزِلُ الدَّاجِ فَلا تَنْزِلْہُ ، قَالَ عَمْرو : وَمَنْزِلِی فِیہِ۔",,,15742,,
15743,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنْ حَفْصَۃَ بِنْتِ سِیرِینَ ، قَالَتْ : کَانُوا یَسْتَحِبُّونَ أَنْ یَنْزِلُوا الْجَانِبَ الأَیْمَنَ مِنْ مِنًی۔",,,15743,,
15744,حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَنْزِلُ الشِّقَّ الأَیْمَنَ مِنْ مِنًی۔,,,15744,,
15745,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَبْدِ اللہِ فِی قَوْلِہِ : {فَمَنْ تَعَجَّلَ فِی یَوْمَیْنِ فَلاَ إِثْمَ عَلَیْہِ} قَالَ : مَغْفُورٌ لَہُ {وَمَنْ تَأَخَّرَ فَلاَ إِثْمَ عَلَیْہِ} قَالَ : مَغْفُورٌ لَہُ۔",,,15745,,
15746,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْحَکَمِ ، عَنْ مِقْسَمٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : (فمَنْ تَعَجَّلَ فِی یَوْمَیْنِ فَلاَ إِثْمَ عَلَیْہِ وَمَنْ تَأَخَّرَ فَلاَ إِثْمَ عَلَیْہِ) قَالَ فِی تَعْجِیلِہِ ، قَالَ (وَمَنْ تَأَخَّرَ) ، قَالَ فِی تَأْخِیرِہِ۔",,,15746,,
15747,"حَدَّثَنَا وَکِیعٌ ، عَنْ سَوَادَۃُ بْنُ أَبِی الأَسْوَدِ ، عَنْ مُعَاوِیَۃَ بْنِ قُرَّۃَ، قَالَ: خَرَجَ مِنْ ذُنُوبِہِ کَیَوْمِ وَلَدَتْہُ أُمُّہُ۔",,,15747,,
15748,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْحَاقَ بْن یَحْیَی ، قَالَ : سَمِعْتُ مُجَاہِدًا یَقُولُ : {فمَنْ تَعَجَّلَ فِی یَوْمَیْنِ فَلاَ إِثْمَ عَلَیْہِ} قَالَ : إلَی قَابِلٍ {وَمَنْ تَأَخَّرَ فَلاَ إِثْمَ عَلَیْہِ} قَالَ : إلَی قَابِلٍ۔",,,15748,,
15749,"حَدَّثَنَا ابْنُ أُبَیٍّ عَدِیٌّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : کَانَ یَقُولُ : {فمَنْ تَعَجَّلَ فِی یَوْمَیْنِ فَلاَ إِثْمَ عَلَیْہِ وَمَنْ تَأَخَّرَ فَلاَ إِثْمَ عَلَیْہِ} قَالَ فِی تَعْجِیلِہِ۔",,,15749,,
15750,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : کَانَ لاَ یَرَی بَأْسًا إذَا طَافَ الرَّجُلُ بِالْبَیْتِ أَنْ یُثَنِّیَ ، ثُمَّ یُثَلِّثَ قَبْلَ أَنْ یَسْعَی بَیْنَ الصَّفَا وَالْمَرْوَۃِ۔",,,15750,,
15751,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، قَالَ : کَانَ إذَا اشْتَرَی بَدَنَۃً قَلَّدَہَا حَیْثُ ابْتَاعَہَا بِمَکَّۃَ ، أَوْ بِمِنًی۔",,,15751,,
15752,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یُقَلِّدُونَ یَوْمَ التَّرْوِیَۃِ وَقَبْلَ ذَلِکَ۔",,,15752,,
15753,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ نُسیر ، أَنَّ ابْنَ الزُّبَیْرِ رَأَی قَوْمًا یَمْسَحُونَ الْمَقَامَ ، فَقَالَ : لَمْ تُؤْمَرُوا بِہَذَا ، إنَّمَا أُمِرْتُمْ بِالصَّلاَۃِ عِنْدَہُ۔",,,15753,,
15754,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : لاَ تُقَبِّلَ الْمَقَامَ ، وَلاَ تَلْمِسْہُ۔",,,15754,,
15755,حَدَّثَنَا وَکِیعُ ، عَنْ ابن نَافِعٍ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، أَنَّہُ دَخَلَ فَلَمْ یُصَلِّ یَعْنِی فی الْبَیْتَ۔,,,15755,,
15756,حَدَّثَنَا وَکِیعٌ ، عَنْ ہَمَّامٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ دَخَلَ الْکَعْبَۃَ فَقَامَ عِنْدَ سَارِیَۃٍ فَدَعَا ، وَلَمْ یُصَلِّ۔ (بخاری 398۔ احمد 1/237),,,15756,,
15757,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ أَبِی الطُّفَیْلِ ، قَالَ : دَخَلْت مَعَ عَلِیٍّ ، وَالْحَسَنِ وَالْحُسَیْنِ ، وَابْنِ الْحَنَفِیَّۃِ الْکَعْبَۃَ فَلَمْ یُصَلُّوا فِیہَا۔",,,15757,,
15758,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ ، قَالَ : دَخَلْت مَعَ عُمَرَ بْنِ مُحَمَّدِ ابْنِ الْحَنَفِیَّۃِ الْبَیْتَ فَقَامَ فَدَعَا ، ثُمَّ اسْتَلَمَ الْبَیْتَ ، ثُمَّ خَرَجَ ، وَلَمْ یُصَلِّ",,,15758,,
15759,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عن ہشام ، عَنِ الْحَسَنِ ، وَعَطَائٍ فِی الْمُحْرِمِ أَشَارَ إلَی صَیْدٍ فَأَصَابَہُ مُحْرِمٌ ، قَالاَ : عَلَیْہِ الْجَزَائُ۔",,,15759,,
15760,حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ سَالِمٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ فِی الْمُشِیرِ والدال وَالْقَاتِلِ عَلَی کُلِّ إنْسَانٍ مِنْہُمْ جَزَائٌ۔,,,15760,,
15761,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : أَتَی رَجُلٌ ابْنَ عَبَّاسٍ ، فَقَالَ : إنِّی أَشَرْت بِظَبْیٍ وَأَنَا مُحْرِمٌ فَأَصِیدُ ، قَالَ : ضَمِنْت۔",,,15761,,
15762,"حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنْ لَیْثٍ، قَالَ: قَالَ رَجُلٌ لِطَاوُوس إنِّی أَشَرْت إلَی حَلاَلِ صَیْدٍ وَأَنَا مُحْرِمٌ؟ قَالَ: ضَمِنْت۔",,,15762,,
15763,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : لاَ یُشِیرُ الْمُحْرِمُ إلَی الصَیْدِ ، وَلاَ یَدُلُّ عَلَیْہِ۔",,,15763,,
15764,حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حَنْظَلَۃَ ، عَنْ طَاوُوسٍ مِثْلَہُ۔,,,15764,,
15765,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنٍ ، عَنْ فِرَاسٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : إذَا أَشَارَ الْمُحْرِمُ إلَی الصَّیْدِ فَعَنِتَ ، فَعَلَیْہِ الْکَفَّارَۃُ۔",,,15765,,
15766,"حَدَّثَنَا حُمَیْدٌ ، عَنْ حَسَنٍ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُوس ، وَمُجَاہِدٍ ، قَالُوا : إذَا أَمَرَ الْمُحْرِمُ الْحَلاَلَ بِقَتْلِ الصَّیْدِ فَعَلَیْہِ الْکَفَّارَۃُ۔",,,15766,,
15767,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ ، أَنَّ ہَبَّارًا رَجُلاً مِنْ أَہْلِ الشَّامِ ، قَالَ : قدِمْت عَلَی عُمَرَ بْنِ الْخَطَّابِ وَہُوَ یَنْحَرُ الْبُدْنَ فِی دَارِ المَنْحر۔",,,15767,,
15768,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : الْمَنْحَرُ بِمَکَّۃَ وَلَکِنَّہَا نُزِّہَتْ ، عَنِ الدِّمَائِ ، قَالَ : قُلْتُ لِعَطَائٍ : أَیْنَ تَنْحَرُ أَنْتَ ؟ قَالَ فِی رَحْلی۔",,,15768,,
15769,حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، عَنْ أَبِیہِ ، أَنَّہُ کَانَ یَنْحَرُ بَدَنَتَہُ فِی رَحْلِہِ۔,,,15769,,
15770,"حَدَّثَنَا خَالِدٌ بن الحَارِث ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ یَنْحَرُ فِی الْمَنْحَرِ ، قَالَ عُبَیْدُ اللہِ : مَنْحَرُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,15770,,
15771,حَدَّثَنَا خَالِدٌ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، أَنَّ سَالِمًا کَانَ یَنْحَرُ فِی أَہْلِہِ۔,,,15771,,
15772,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَعَطَائٍ ، قَالاَ : یَنْحَرُ الْبَدَنَۃُ حَیْثُ تَیَسَّرَ عَلَیْہِ مِنْ مِنًی۔",,,15772,,
15773,"حَدَّثَنَا وَکِیعُ ، عَنْ أُسَامَۃَ ، عَنْ عَطَائٍ ، عَنْ جابرٍ قَالَ : قَالَ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مِنًی کُلہا مَنحَر ، وکُل فِجَاج مَکَۃَ طَرِیق مَنحَر۔",,,15773,,
15774,"حَدَّثَنَا معْنُ بْنُ عِیسَی ، عَنْ مُخْتَارِ بْنِ سَعْدٍ ، قَالَ : رَأَیْتُ أَبَا جَعْفَرٍ نَحَرَ بَدَنَاتٍ بِمِنًی بِالْمَنْحَرِ ، وَلَمْ یُعَرِّفْ۔",,,15774,,
15775,"حَدَّثَنَا معَنْ بْنُ عِیسَی ، عَنْ زِیدَ بْنِ السَّائِبِ ، قَالَ : رَأَیْتُ خَارِجَۃَ بْنَ یَزِیدَ یَنْحَرُ فِی مَنْزِلِہِ بِمِنًی ، وَلَمْ یَنْحَرْ فِی الْمَنْحَرِ۔",,,15775,,
15776,"حَدَّثَنَا معَنْ بْنُ عِیسَی ، عَنْ خَالِدِ بْنِ أَبِی بَکْرٍ ، قَالَ : رَأَیْتُ عُبَیْدَ اللہِ بْنَ عَبْدِ اللہِ یَنْحَرُ فِی الْمَنْحَرِ۔",,,15776,,
15777,"حَدَّثَنَا أَبُو خَالِدٍ الأحمر ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّہُ کَانَ یَنْحَرُ بِمَکَّۃَ ، قَالَ : وَکَانَ ابْنُ عُمَرَ یَنْحَرُ بِمِنَی۔",,,15777,,
15778,"حَدَّثَنَا محمد بْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنِ ابْنِ سَابِط ، قَالَ : ذَبَحَ إبْرَاہِیمُ الْخَلِیلُ خَلْفَ الْعَقَبَۃِ۔",,,15778,,
15779,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ حَجَّاجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : أَیْنَ أَنْحَرُ ہَدْیِی بِأَعْلَی مَکَّۃَ ، وَفِی أَسْفَلِہَا ؟ قَالَ : نَعَمْ ، قُلْتُ : بِالأَبْطَحِ ؟ قَالَ : نَعَمْ ، قُلْتُ : فِی بَیْتِی ؟ قَالَ : نَعَمْ۔",,,15779,,
15780,حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ یَنْحَرُ ہَدْیَہُ خَلْفَ الْعَقَبَۃِ۔,,,15780,,
15781,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ: حدَّثَنَا سُفْیَانُ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْحَارِثِ بْنِ عَیَّاشٍ ، عَنْ زَیْدِ بْنِ عَلِیٍّ، عَنْ أَبِیہِ ، عَنْ عُبَیْدِ اللہِ بْنِ أَبِی رَافِعٍ ، عَنْ عَلِیٍّ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : مِنًی کُلُّہَا مَنْحَرٌ۔",,,15781,,
15782,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ فِی امْرَأَۃٍ نَسِیَتْ أَنْ تُقَصِّرَ حَتَّی خَرَجَتْ ، فَقَالَ عَبْدُ الرَّحْمَنِ بْنُ الأَسْوَدِ وَعَامِرٌ : تُقَصِّرُ وَتُہْرِیقُ دَمًا۔",,,15782,,
15783,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ فِی رَجُلٍ نَسِیَ أَنْ یَحْلِقَ ، أَوْ یُقَصِّرَ ، قَالَ : لَیْسَ عَلَیْہِ شَیْئٌ۔",,,15783,,
15784,"حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ سَالِمٍ وَالْقَاسِمِ ، وَعَطَائٍ ، وَطَاوُوس ، وَمُجَاہِدٍ فِی الْمَرْأَۃِ تَمُرُّ بِالْمَوْقِفِ رَاجِعَۃً مِنْ مَکَّۃَ فَلَمْ تُقَصِّرْ ، قَالُوا : لاَ یُؤَاخِذُہَا اللَّہُ بِالنِّسْیَانِ ، وَقَالَ ابْنُ الأَسْوَدِ وَالشَّعْبِیُّ : تُقَصِّرُ وَعَلَیْہَا دَمٌ ، وَتَمَّ حَجُّہَا۔",,,15784,,
15785,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدٍ ، عَنْ أَبِی ہُرَیْرَۃَ رْفَعَہُ ، قَالَ : لاَ تُشَدُّ الرِّحَالُ إِلاَّ إلَی ثَلاَثَۃِ مَسَاجِدَ : مَسْجِدِ الْحَرَامِ وَمَسْجِدِ الرَّسُولِ وَمَسْجِدِ الأَقْصَی۔",,,15785,,
15786,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ طَلْقٍ ، عَنْ قَزَعَۃَ ، قَالَ : سَأَلْتُ ابْنَ عُمَرَ آتِیَ الطُّورَ ؟ قَالَ : دَعِ الطُّورَ ، لاَ تَأْتِہِ ، وَقَالَ : لاَ تُشَدُّ الرِّحَالُ إِلاَّ إلَی ثَلاَثَۃِ مَسَاجِدَ۔",,,15786,,
15787,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ تُشَدُّ الرِّحَالُ إِلاَّ إلَی ثَلاَثَۃِ مَسَاجِدَ : الْمَسْجِدِ الْحَرَامِ وَمَسْجِدِ الرَّسُولِ وَبَیْتِ الْمَقْدِسِ۔",,,15787,,
15788,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : أَتَی رَجُلٌ عُمَرَ ، فَقَالَ : إنِّی أُرِیدُ بَیْتَ الْمَقْدِسِ ، فَقَالَ : اذْہَبْ فَتَجَہَّزْ فَإِذَا تَجَہَّزْت فَآذِنِّی ، فَلَمَّا تَجَہَّزَ أَتَاہُ ، قَالَ : اجْعَلْہَا عُمْرَۃً۔",,,15788,,
15789,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ سَعِیدٍ ، قَالَ : بَیْنَا عُمَرُ یَعْرِضُ إبل الصَّدَقَۃِ إذْ أَقْبَلَ رَاکِبَانِ ، فَقَالَ : مِنْ أَیْنَ ؟ فَقَالاَ : مِنْ بَیْتِ الْمَقْدِسِ ، فَعَلاَہُمَا عُمَرُ بِالدِّرَّۃِ ، قَالَ : حَجٌّ کَحَجِّ الْبَیْتِ۔",,,15789,,
15790,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ لَیْثٍ ، عَنْ شَہر ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ، قَالَ : لاَ تُشَدُّ الرِّحَالُ إِلاَّ إلَی ثَلاَثَۃِ مَسَاجِدَ : الْمَسْجِدِ الْحَرَامِ وَمَسْجِدِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَمَسْجِدِ الأَقْصَی۔",,,15790,,
15791,"حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ سُفْیَانَ ، عَنْ أَبِی سِنَانٍ ، عَنْ أَبِی الْہُذَیْلِ ، قَالَ : لاَ تَشُدُّوا الرِّحَالَ إِلاَّ إلَی الْبَیْتِ الْعَتِیقِ۔",,,15791,,
15792,"حَدَّثَنَا یَحْیَی بْنُ یَعْلَی ، عَنْ عَبْدِ الْمَلِکِ بْنِ عُمَیْرٍ ، عَنْ قَزَعَۃَ ، عَنْ أَبِی سَعِیدٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لاَ تُشَدُّ الرِّحَالُ إِلاَّ إلَی ثَلاَثَۃِ مَسَاجِدَ : مَسْجِدِ الْحَرَامِ وَمَسْجِدِ الرَّسُولِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَالمَسْجِدِ الأَقْصَی۔",,,15792,,
15793,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لاَ تَشُدُّوا الرِّحَالَ إِلاَّ إلَی ثَلاَثَۃِ مَسَاجِدَ : مَسْجِدِ الْحَرَامِ ، مَسْجِدِ الأَقْصَی ، وَمَسْجِدِی ہَذَا۔",,,15793,,
15794,حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ قَتَادَۃَ ، عَنْ أَبِی حَسَّانَ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَلَّدَ نَعْلَیْنِ۔ (ترمذی 906۔ ابوداؤد 1750),,,15794,,
15795,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، قَالَ : کَانَ ابْنُ عُمَرَ یَجْمَعُ نَعْلَہُ مِنَ السَّنَۃِ فَیُقَلِّدُہَا بُدْنَہُ ، فَإِذَا عَجَزَتِ اشْتَرَی نِعَالاً جُدُدًا فَقَلَّدَہَا۔",,,15795,,
15796,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ دِینَارٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ یُقَلِّدُ بَدَنَتَہُ نَعْلَیْنِ۔,,,15796,,
15797,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَاصِمٍ الأَحْوَلِ ، عَنْ أَبِی مَخْلَدٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قلَّدَہَا خُرَّابَۃَ أُذُنِ مَزَادَۃٍ۔",,,15797,,
15798,حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی رَوَّاد ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ قَلَّدَ مَرَّۃً زَوْجًا جَدِیدًا مَحْزُوًّا مُشَرَّکًا۔,,,15798,,
15799,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنْ أَبِی مجلز ، عَنِ ابْنِ عُمَرَ بِنَحْوٍ مِنْ حَدِیثِ سُفْیَانَ ، عَنْ عَاصِمٍ۔,,,15799,,
15800,حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الْحَارِثِ بْنِ عَبْدِ الرَّحْمَنِ ، أَنَّہُ أَخْبَرَہُ مَنْ رَأَی عُمَرَ یَغْتَسِلُ بِعَرَفَۃَ وَہُوَ یُلَبِّی۔,,,15800,,
15801,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، وَابْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنْ عُمَارَۃَ بْنِ عُمَیْرٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، عَنْ عَبْدِ اللہِ ، أَنَّہُ اغْتَسَلَ ، ثُمَّ رَاحَ إلَی عَرَفَۃَ۔,,,15801,,
15802,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ إذَا رَاحَ إلَی المعرَّف اغْتَسَلَ۔,,,15802,,
15803,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ ، قَالَ : اغْتَسَلَ مُجَاہِدٌ یَوْمَ عَرَفَۃَ وَأَنَا مَعَہُ۔",,,15803,,
15804,حَدَّثَنَا ابْنُ أَبِی زَائِدَۃَ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، أَنَّ أَبَاہُ کَانَ یَغْتَسِلُ یَوْمَ عَرَفَۃَ۔,,,15804,,
15805,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : امْضِ إلَی عَرَفَاتٍ ، فَإِذَا کَانَ عِنْدَ زَوَالِ الشَّمْسِ فَاغْتَسِلْ إِنْ وَجَدْت مَائً ، وَإِلاَّ فَتَوَضَّأْ۔",,,15805,,
15806,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ یَزِیدَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، قَالَ : الْغُسْلُ یَوْمَ عَرَفَۃَ۔",,,15806,,
15807,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ شَقِیقٍ ، قَالَ : کَانَ عَبْدُ اللہِ إذَا سَعَی فِی بَطْنِ الْوَادِی ، قَالَ : رَبِّ اغْفِرْ وَارْحَمْ إنَّک أَنْتَ الأَعَزُّ الأَکْرَمُ۔",,,15807,,
15808,حَدَّثَنَا أَبُو خَالِدٍ ، عَنِ الأَعْمَشِ ، عَنْ شَقِیقٍ ، عَنْ مَسْرُوقٍ ، عَنْ عَبْدِ اللہِ مِثْلَہُ۔,,,15808,,
15809,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الْعَلاَئِ بْنِ الْمُسَیَّبِ ، عَنْ أَبِیہِ ، قَالَ : کَانَ عُمَر إذَا مَرَّ بِالْوَادِی بَیْنَ الصَّفَا وَالْمَرْوَۃِ سَعَی فِیہِ حَتَّی یُجَاوِزَہُ وَیَقُولُ : رَبِّ اغْفِرْ وَارْحَمْ وَأَنْتَ الأَعَزُّ الأَکْرَمُ",,,15809,,
15810,"حَدَّثَنَا عَبْدَۃُ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، أَنَّ أَبَاہُ کَانَ یَقُولُ وَہُوَ یَسْعَی بَیْنَ الصَّفَا وَالْمَرْوَۃِ : اللَّہُمَّ إنَّ ہَذَا وَاحِدٌ إِنْ تَمَّا أَتَمَّہُ اللَّہُ وَقَدْ أَتَمَّا۔",,,15810,,
15811,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ بُدَیْلٍ ، عَنْ مَیْسَرَۃَ ، عَنْ صَفِیَّۃَ بِنْتِ شَیْبَۃَ ، عَنْ أُمِّ وَلَدِ شَیْبَۃَ، قَالَتْ: رَأَیْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَسْعَی بَیْنَ الصَّفَا وَالْمَرْوَۃِ وَہُوَ یَقُولُ : لاَ یُقْطَعُ الأَبْطَحُ إِلاَّ شَدًّا۔ (ابن ماجہ 2987۔ احمد 6/404)",,,15811,,
15812,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ یَقُولُ : رَبِّ اغْفِرْ وَارْحَمْ وَأَنْتَ الأَعَزُّ الأَکْرَمُ",,,15812,,
15813,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ یَقُولُ : رَبِّ اغْفِر وَارْحَمْ وَأَنْتَ الأَعَزُّ الأَکْرَمُ۔",,,15813,,
15814,"حَدَّثَنَا أَبُو خَالِدٍ، عَنْ الحَجَّاجِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ الہیثم بن حنشٍ، عَنِ ابْنِ عُمَرَ، أَنَّہُ کَانَ یَفْعَلُہُ۔\n\n(بیہقی 95)",,,15814,,
15815,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ یَدْخُلَ مَکَّۃَ لَیْلاً۔,,,15815,,
15816,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ یَضُرُّک دَخَلْت مَکَّۃَ لَیْلاً ، أَوْ نَہَارًا۔",,,15816,,
15817,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَفْلَحَ ، قَالَ : دَخَلْت مَکَّۃَ مَعَ الْقَاسِمِ لَیْلاً۔",,,15817,,
15818,"حَدَّثَنَا جَرِیرٌ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یُحِبُّونَ أَنْ یَخْرُجُوا مِنَ الْکُوفَۃِ لَیْلاً وَأَنْ یَدْخُلُوا مَکَّۃَ نَہَارًا۔",,,15818,,
15819,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، أَنَّہُ دَخَلَ مَکَّۃَ لَیْلاً۔,,,15819,,
15820,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حُصَن ، عَنْ سَالِمٍ أَنَّہُ دَخَلَ مَکَّۃَ نَہَارًا۔,,,15820,,
15821,حَدَّثَنَا وَکِیعٌ ، عَنِ الْعُمَرِیِّ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ دَخَلَ مَکَّۃَ نَہَارًا۔,,,15821,,
15822,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سَالِمٍ ، قَالَ : دَخَلْت مَعَ سَعِیدِ بْنِ جُبَیْرٍ مَکَّۃَ لَیْلاً۔",,,15822,,
15823,حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، أَنَّ أَبَاہُ کَانَ یَدْخُلُ مَکَّۃَ لَیْلاً۔,,,15823,,
15824,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حُمَیْدٍ ، قَالَ : سَأَلْتُ طَاوُوسًا ، عَنْ رَجُلٍ دَخَلَ مَکَّۃَ لَیْلاً ، فَقَالَ : أَوَلَیْسَ تِلْکَ الْغَنِیمَۃَ الْبَارِدَۃَ ؟ فَسَأَلْت الْقَاسِمَ وَعَطَائً ، عَنْ ذَلِکَ فَلَمْ یَرَیَا بِہِ بَأْسًا۔",,,15824,,
15825,وَحَدَّثَنِی یَعْلَی بْنُ حَکِیمٍ ، أَنَّ سَعِیدَ بْنَ جُبَیْرٍ قَدِمَ مَکَّۃَ لَیْلاً فَطَافَ فَمَا عَلِمْنَا بِہِ ، وَفَعَلَ ذَلِکَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ۔,,,15825,,
15826,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ مُحَمَّدِ بْنِ عَبَّادٍ ، عَنْ عَبْدِ اللہِ بْنِ السَّائِبِ ، قَالَ : کُنْتُ أُصَلِّی بِالنَّاسِ فِی رَمَضَانَ فَبَیْنَا أَنَا أُصَلِّی سَمِعْت تَکْبِیرَ عُمَرَ عَلَی بَابِ الْمَسْجِدِ قَدِمَ مُعْتَمِرًا فَدَخَلَ فَصَلَّی خَلْفِی۔",,,15826,,
15827,حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ مزاحم بْنِ أَبِی مُزَاحِمٍ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ عَبْدِ اللہِ بْنِ خَالِدِ بْنِ أَسِیدٍ ، عَنْ مُحَرِّشٍ الْکَعْبِیِّ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ اعْتَمَرَ مِنَ الْجِعْرَانَۃِ ، ثُمَّ أَصْبَحَ بِالْجِعْرَانَۃِ کَبَائِتٍ ، فَلَمَّا زَالَتِ الشَّمْسُ رَاحَ فِی بَطْنِ سَرَفٍ حَتَّی جَامَعَ الطَّرِیقَ۔,,,15827,,
15828,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ صَالِحِ بْنِ أَبِی الأَخْضَرِ ، عَنْ رَجُلٍ یُقَالَ لَہُ : خَالِدٌ ، عَنْ مَوْلاَۃٍ لَہُمْ ، عَنْ جَدَّتِہَا، أَنَّ الْحَسَنَ وَالْحُسَیْنَ قَدِمَا مَکَّۃَ لَیْلاً فَطَافَا ، ثُمَّ خَرَجَا۔",,,15828,,
15829,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ إسْمَاعِیلَ بْنِ أُمَیَّۃَ ، عَنْ مُزَاحِمِ بْنِ أَبِی مُزَاحِمٍ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ عَبْدِ اللہِ بْنِ خَالِدِ بْنِ أَسِیدٍ ، عَنْ مُحَرِّشٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ اعْتَمَرَ مِنَ الْجِعْرَانَۃِ ، ثُمَّ رَجَعَ إلَیْہَا کَبَائِتٍ ، قَالَ : وَرَأَیْت ظَہْرَہُ کَأَنَّہُ سَبِیکَۃُ فِضَّۃٍ۔",,,15829,,
15830,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، أَوْ مُجَاہِدٍ ، قَالَ : الْقَانِعُ الَّذِی یَقْنَعُ بِمَا بُعِثَ إلَیْہِ ، وَالْمُعْتَرُّ الَّذِی یَتَعَرَّضُ لَکَ یَسْأَلُک۔",,,15830,,
15831,"حَدَّثَنَا حَفْصٌ ، عَنْ عَاصِمٍ ، قَالَ : حدَّثَنِی مَنْ سَمِعَ ابْنَ عُمَرَ وَہُوَ بِمِنًی ، وَتَلاَ ہَذِہِ الآیَۃَ : {فَکُلُوا مِنْہَا وَأَطْعِمُوا الْقَانِعَ وَالْمُعْتَرَّ} قَالَ : قَالَ لِغُلاَمٍ لَہُ مَعَہُ : ہَذَا الْقَانِعُ الَّذِی یَقْنَعُ بِمَا آتَیْتہ۔",,,15831,,
15832,"حَدَّثَنَا ابْنُ فُضَیْلٍ، عَنْ خُصَیْفٍ، عَنْ مُجَاہِدٍ، قَالَ: الْقَانِعُ أَہْلُ مَکَّۃَ، وَالْمُعْتَرُّ الَّذِی یَعْتَرِیک فَیَسْأَلُک۔",,,15832,,
15833,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : الْقَانِعُ الَّذِی یَقْنَعُ إلَیْک ، وَالْمُعْتَرُّ الَّذِی یَعْتَرِیک یُرِیک نَفْسَہُ ، وَلاَ یَسْأَلُک۔",,,15833,,
15834,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، قَالَ : الْقَانِعُ السَّائِلُ وَالْمُعْتَرُّ : مُعْتَر البَدن۔",,,15834,,
15835,"حَدَّثَنَا مُحَمَّدُ بْنُ یَزِیدَ ، عَنْ أَیُّوبَ أَبِی الْعَلاَئِ ، عَنْ قَتَادَۃَ فِی رَجُلٍ رَمَی صَیْدًا فِی الْحِلِّ وَہُوَ فِی الْحَرَمِ ، أَوْ ہُوَ فِی الْحِلِّ ، وَالصَّیْدُ فِی الْحَرَمِ ؟ قَالَ : عَلَیْہِ فِدَاؤُہُ۔",,,15835,,
15836,"حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، سُئِلَ عَنِ الرَّجُلِ إذَا رَمَی الصَّیْدَ وَہُوَ فِی الْحَرَمِ فَخَرَجَ مِنَ الْحَرَمِ فَمَاتَ ، أَنَّہُ قَالَ : یَضْمَنُ ، وَإِذَا رَمَاہُ فِی الْحِلِّ وَالصَیدُ فِی الْحِلِّ ، ثُمَّ دَخَلَ الْحَرَمَ فَمَاتَ، أَنَّہُ قَالَ : لاَ یَضْمَنُ۔",,,15836,,
15837,"حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ ، عَنْ شُعْبَۃَ ، عَنْ حَمَّادٍ فِی رَجُلٍ رَمَی صَیْدًا فِی الْحِلِّ فَوَقَعَ فِی الْحَرَمِ فَمَاتَ، قَالَ : أَعْجَبُ إلَیَّ أَنْ لاَ یَأْکُلَہُ۔",,,15837,,
15838,"حَدَّثَنَا حَفص ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : إذَا أُصِیبَ الصَّیْدُ فِی الْحِلِّ فَدَخَلَ الْحَرَمَ فَمَاتَ ، فَقَالَ : لاَ یُؤْکَلُ لأَنَّہُ مَاتَ فِی الْحَرَمِ ، وَلاَ یُودَی لأَنَّہُ أُصِیبَ فِی الْحِلِّ۔",,,15838,,
15839,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، وَعَنْ أَشْعَثَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : إذَا رَمَی فِی الْحِلِّ وَأَصَابَ فِی الْحَرَمِ کَفَّرَ ، وَإِذَا رَمَی فِی الْحِلِّ وَأَصَابَ فِی الْحِلِّ کَفَّرَ۔",,,15839,,
15840,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ، عَنِ الأَعْمَشِ، عَنْ إبْرَاہِیمَ، قَالَ: خَرَجْت مَعَ عَلْقَمَۃَ إلَی مَکَّۃَ فَلَمْ یَغْتَسِلْ حَتَّی دَخَلَہَا۔",,,15840,,
15841,"حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ، عَنْ إسْمَاعِیلَ، عَنِ الْحَسَنِ، قَالَ: إِنْ شَائَ الْمُحْرِمُ اغْتَسَلَ، وَإِنْ شَائَ لَمْ یَغْتَسِلْ۔",,,15841,,
15842,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ سُفْیَانَ التَّمَّارِ ، عَنْ أَبِی صَالِحٍ ، قَالَ : یَغْتَسِلُ عِنْدَ الإِحْرَامِ وَیُصَلِّی رَکْعَتَیْنِ۔",,,15842,,
15843,"حَدَّثَنَا أَبُو نُعَیْمٍ، عَنْ سُفْیَانَ، عَنْ الزُّبَیْرِ بن عَدِیٍّ، عَنْ إبْرَاہِیمَ، قَالَ: کَانُوا إذَا أَرَادُوا أَنْ یُحْرِمُوا اغْتَسَلُوا۔",,,15843,,
15844,حَدَّثَنَا أَبُو نُعَیْمٍ ، عَنِ الرَّبِیعِ ، عَنْ عَطَائٍ ، أَنَّہُ کَانَ یُعْجِبُہُ أَن یَغْتَسِلُ عِنْدَ الإِحْرَامِ ، وَإِذَا دَخَلَ مَکَّۃَ۔,,,15844,,
15845,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یَسْتَحِبُّونَ إذَا أَرَادُوا أَنْ یُحْرِمُوا أَنْ یَغْتَسِلُوا۔",,,15845,,
15846,حَدَّثَنَا أَبُو أُسَامَۃَ، عَنْ عُبَیْدِ اللہِ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّہُ نَزَعَ قَمِیصَہُ عَامَ الْفِتْنَۃِ، ثُمَّ لَبَّی، وَلَمْ یَغْتَسِلْ۔,,,15846,,
15847,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ حُمَیْدٍ ، عنْ بَکْرِ ، عنْ ابْنِ عمر قَالَ : مِنَ السُّنَّۃِ أَنْ یَغْتَسِلَ الرَّجُلُ إذَا أَرَادَ أَنْ یُحْرِمَ۔ (ترمذی 830۔ ابن خزیمۃ 2595)",,,15847,,
15848,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ یَعْقُوبَ بْنِ قَیْسٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : إذَا أَحْرَمْتَ فَاغْتَسِلْ۔",,,15848,,
15849,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، أَنَّہُ کَانَ لاَ یَدَعُ الْغُسْلَ عِنْدَ الإِحْرَامِ وَیَأْمُرُ بِذَلِکَ۔,,,15849,,
15850,"حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : سَأَلْتُ نَافِعًا أَکَانَ ابْنُ عُمَرَ یَغْتَسِلُ عِنْدَ الإِحْرَامِ ؟ فَقَالَ : کَانَ رُبَّمَا یَغْتَسِلُ ، وَرُبَّمَا تَوَضَّأَ۔",,,15850,,
15851,حَدَّثَنَا وَکِیعٌ ، عَنْ أَفْلَحَ ، عَنِ الْقَاسِمِ ، أَنَّہُ اغْتَسَلَ حِینَ دَخَلَ مَکَّۃَ۔,,,15851,,
15852,"حَدَّثَنَا جَرِیرٌ ، عَنْ یَزِیدَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، قَالَ : الْغُسْلُ یَوْمَ دُخُولِ مَکَّۃَ۔",,,15852,,
15853,"حَدَّثَنَا جَرِیرٌ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ عَلْقَمَۃُ وَالأَسْوَدُ وَأَصْحَابُنَا إذَا انْتَہَوْا إلَی بِئْرِ مَیْمُونٍ اغْتَسَلُوا مِنْہَا وَلَبِسُوا أحسن ثِیَابَہُمْ۔",,,15853,,
15854,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ نَافِعٍ ، قَالَ : کَانَ ابْنُ عُمَرَ لاَ یَدْخُلُ مَکَّۃَ فِی حَجٍّ ، وَلاَ عُمْرَۃٍ حَتَّی یَغْتَسِلَ بِذِی طُوًی۔",,,15854,,
15855,حَدَّثَنَا عَبْدَۃُ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ یَغْتَسِلُ إذَا دَخَلَ مَکَّۃَ وَیَأْمُرُہُمْ بِذَلِکَ۔,,,15855,,
15856,"حَدَّثَنَا جَرِیرٌ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، قَالَ : کَانَ عَبْدُ الرَّحْمَنِ بْنُ الأَسْوَدِ یَرْمِی الْجِمَارَ یَوْمَ النَّفْرِ ، ثُمَّ یَرْجِعُ إلَی ثَقَلِہِ بِمِنًی۔",,,15856,,
15857,"حَدَّثَنَا أَسْبَاطٌ ، عَنْ أَبِی بَکْرٍ الْہُذَلِیِّ ، قَالَ : قُلْتُ لِلزُّہْرِیِّ : ہَلْ لِلرَّجُلِ أَنْ یَرْمِیَ جَمْرَۃَ الْعَقَبَۃِ ، ثُمَّ یَرْجِعَ إلَی مَنْزِلِہِ ، ثُمَّ یَسِیرَ إلَی مَکَّۃَ ؟ فَقَالَ : مَا کَانُوا یَرْجِعُونَ إلَی مَنَازِلِہِمْ إذَا رَمَوْا الْجَمْرَۃَ ، وَإِنْ رَجَعَ رَجُلٌ إلَی مَنْزِلِہِ لِمِرْفَقٍ ، أَوْ لِضَیْعَۃٍ ، أَوْ حَاجَۃٍ إنِّی لأَرْجُو أَنْ لاَ یَکُونَ بِہِ بَأْسٌ إِنْ شَائَ اللَّہُ۔",,,15857,,
15858,حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنِ ابْنِ أَبِیْ نَجِیحٍ، عَنْ مُجَاہِدٍ، عَنْ عَبْدِاللہِ فِی الضَّبِّ یُصِیبُہُ الْمُحْرِمُ جَفْنَۃٌ مِنْ طَعَامٍ۔,,,15858,,
15859,"حَدَّثَنَا سَلاَّمٌ ، عَنْ مُخَارِقٍ ، عَنْ طَارِقٍ ، قَالَ : خَرَجْنَا حُجَّاجًا حَتَّی إذَا کُنَّا بِبَعْضِ الطَّرِیقِ أَوْطَأَ رَجُلٌ مِنَّا ضَبًّا فَقَتَلَہُ وَہُوَ مُحْرِمٌ ، فَأَتَی عُمَرَ بْنَ الْخَطَّابِ لِیَحْکُمَ عَلَیْہِ ، فَقَالَ لَہُ : عُمَرُ : احْکُمْ مَعِی فَحَکَمَا فِیہِ جَدْیًا قَدْ جَمَعَ الْمَائَ وَالشَّجَرَ ، ثُمَّ قَالَ : عُمَرُ : یَحْکُمُ بِہِ ذَوَا عَدْلٍ مِنْکُمْ۔",,,15859,,
15860,حَدَّثَنَا أَسْبَاطٌ ، عَنْ مُطَرِّفٍ ، عَنْ عَطَائٍ ، قَالَ فِی الضَّبِّ شَاۃٌ۔,,,15860,,
15861,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، أَنَّ عُمَرَ قَضَی فِی الضَّبُعِ کَبْشًا۔,,,15861,,
15862,"حَدَّثَنَا شَبَابَۃُ عن ہشام بن الغاز، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ: مَنْ قَتَلَ ضَبُعًا وَہُوَ مُحْرِمٌ فَعَلَیْہِ الْفِدَائ",,,15862,,
15863,حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، عَنْ عَلِیٍّ فِی الضَّبُعِ إذَا عَدَا عَلَی الْمُحْرِمِ فَلْیَقْتُلْہُ ، فَإِنْ قَتَلَہُ من قَبْلِ أَنْ یَعْدُوَ عَلَیْہِ فَعَلَیْہِ شَاۃٌ مُسِنَّۃٌ۔,,,15863,,
15864,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ ابن أَبِی فَرْوَۃَ ، عَنْ عَطَائٍ ، قَالَ : یُعْقَل الضَّبُعُ فِی الْحَرَمِ۔",,,15864,,
15865,حَدَّثَنَا وَکِیعٌ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، عَنْ عَبْدِ اللہِ بْنِ عُبَیْدِ بْنِ عُمَیْرٍ ، عَنِ ابْنِ أبی عَمَّارٍ ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ جَعَلَ الضَّبُعَ مِنَ الصَّیْدِ ، وَجَعَلَ فِیہِ إذَا أَصَابَہُ الْمُحْرِمُ کَبْشًا۔,,,15865,,
15866,"حَدَّثَنَا وَکِیعٌ ، عَنْ عِمْرَانَ بْنِ حُدَیْرٍ ، عَنْ عِکْرِمَۃَ فِی الْمُحْرِمِ أَصَابَ جَرَادَۃً ، قَالَ : یَتَصَدَّقُ بِکِسْرَۃٍ۔",,,15866,,
15867,"حَدَّثَنَا ابْنُ أَبِی زَائِدَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ فِی الْجَرَادَۃِ : قبْضَۃٌ ، أَوْ لُقْمَۃٌ۔",,,15867,,
15868,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ عن إِبْرَاہِیمَ ، عَن کَعْبٍ ، أَنَّہُ مَرَّتْ بِہِ جَرَادَۃٌ فَضَرَبَہَا بِسَوْطِہِ فَأَخَذَہَا فَشَوَاہَا ، فَقَالُوا لَہُ ، فَقَالَ : ہَذَا خَطَأٌ ، وَأَنَا أَحْکُمُ عَلَی نَفْسِی فِی ہَذَا دِرْہَمًا ، فَأَتَی عُمَرَ ، فَقَالَ : إِنَّکُمْ أَہْلُ حِمْصَ أَکْثَرُ شَیْئٍ دَرَاہِمَ ، تَمْرَۃٌ خَیْرٌ مِنْ جَرَادَۃٍ۔",,,15868,,
15869,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عَنْ عُمَرَ بِمِثْلِہِ ، أَوْ نَحْوِہِ۔,,,15869,,
15870,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ شُعَیْبٍ ، عَنْ عَلِیِّ بْنِ عَبْدِ اللہِ الْبَارِقِیِّ ، قَالَ : کَانَ عبد اللہِ بْنُ عُمَرَ یَقُولُ فِی الْجَرَادَۃِ : قَبْضَۃٌ مِنْ طَعَامٍ۔",,,15870,,
15871,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرائیل ، عَنْ جَابِرٍ ، عَنْ مُحَمَّدِ بْنِ عَلِیٍّ ، وعَطَائٍ ، وَمُجَاہِدٍ ، وَطَاوُوسٍ أَنَّہُمْ ، قَالُوا : فِی الْجَنَادِبِ وَالْعَظَاء وَالْجَرَادِ وَالذَّرِّ : قَالُوا : إِنْ قَتَلَہُ عَمْدًا أَطْعَمَ شَیْئًا ، وَإِنْ کَانَ خَطَأً فَلَیْسَ عَلَیْہِ شَیْئٌ ، وَقَالَ : عَامِرٌ ، وَعَبْدُ الرحمن بْنُ الأَسْوَدِ : یُطْعِمُ شَیْئًا خَطَأً کَانَ ، أَوْ عَمْدًا۔",,,15871,,
15872,حَدَّثَنَا عَبْدَۃُ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ أَبِی سَلَمَۃَ ، أَنَّ مُحْرِمًا أَصَابَ جَرَادَۃً فَحَکَمَ عَلَیْہِ عَبْدُ اللہِ بْنُ عُمَرَ وَرَجُلٌ آخَرُ ، فَحَکَمَ عَلَیْہِ أَحَدُہُمَا تَمْرَۃً وَالآخَرُ کِسْرَۃً۔,,,15872,,
15873,"حَدَّثَنَا حَفْصٌ ، عَنْ جَعْفَرٍ ، عَنِ الْقَاسِمِ ، قَالَ : سُئِلَ ابْنُ عَبَّاسٍ ، عَنِ الْمُحْرِمِ یُصِیبُ الْجَرَادَۃَ ، فَقَالَ: تَمْرَۃٌ خَیْرٌ مِنْ جَرَادَۃٍ۔",,,15873,,
15874,"حَدَّثَنَا حُمَیْدٌ ، عَنْ حَسَنٍ ، عَنْ عَقِیلٍ ، عَنِ الضَّحَّاکِ قَالَ : فِی الْجَرَادَۃِ وَنَحْوِہَا ، وَمَا ہُوَ دُونَہَا قَبْضَۃٌ مِنْ طَعَامٍ۔",,,15874,,
15875,"حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ، عَنِ ابْنِ أَبِی ذِئْبٍ، عَنِ الزُّہْرِیِّ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ، قَالَ: قبْضَۃٌ مِنْ طَعَامٍ۔",,,15875,,
15876,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْحَکَمِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ فِی الْمُحْرِمِ یَقْتُلُ الْقَمْلَۃَ ، قَالَ : یَتَصَدَّقُ بِشَیْئٍ۔",,,15876,,
15877,"حَدَّثَنَا مُحَمَّدُ بْنُ یَزِیدَ ، عَنْ أَیُّوبَ أَبِی الْعَلاَئِ ، عَنْ قَتَادَۃَ ، وَأَبِیْ ہَاشِمٍ ، قَالاَ : یَتَصَدَّقُ بِشَیْئٍ۔",,,15877,,
15878,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحُرِّ بْنِ صَیَّاحٍ ، قَالَ : سَمِعْتُ ابْنَ عُمَر ، وَسُئِلَ عَنِ الْمُحْرِمِ یَقْتُلُ الْقَمْلَۃَ ، قَالَ : یَتَصَدَّقُ بِکِسْرَۃٍ ، أَوْ بِقَبْضَۃٍ مِنْ طَعَامٍ۔",,,15878,,
15879,"حَدَّثَنَا حَفْصٌ ، عَنْ عَبْدِ اللہِ بْنِ مُسْلِمٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ فِی قَوْلِہِ سَوَائَ نِالْعَاکِفُ فِیہِ وَالْبَادِ ، قَالَ : خَلْقُ اللہِ فِیہِ سَوَائٌ۔",,,15879,,
15880,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، قَالَ : أَہْلُ مَکَّۃَ وَغَیْرُہُمْ فِی الْمَنَازِلِ سَوَائٌ۔",,,15880,,
15881,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ بْنِ سَابِطٍ : {سَوَائَ نِالْعَاکِفُ فِیہِ وَالْبَادِ} قَالَ : الْبَادِی الَّذِی یَجِیئُ مِنَ الْحَجِّ وَالْمُقِیمُونَ سَوَائٌ فِی الْمَنَازِلِ یَنْزِلُونَ حَیْثُ شَاؤُوا لاَ یَخْرُجُ رَجُلٌ مِنْ بَیْتِہِ۔",,,15881,,
15882,"حَدَّثَنَا عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ قَالَ : النَاس فِی البَیت سَوَاء ۔",,,15882,,
15883,"حَدَّثَنَا ابْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : أَہْلُہُ وَغَیْرُہُ فِیہِ سَوَائٌ۔",,,15883,,
15884,حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ سَعْدِ بْنِ إبْرَاہِیمَ ، أَنَّ عَائِشَۃَ کَانَتْ تُسْرِعُ فِی وَادِی مُحَسِّرٍ۔,,,15884,,
15885,حَدَّثَنَا وَکِیعٌ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ زَید بْنِ عَبْدِ الرَّحْمَنِ ، أَنَّ ابْنَ عُمَرَ لَمَّا أَتَی وَادِیَ مُحَسِّرٍ ضَرَبَ رَاحِلَتَہُ۔,,,15885,,
15886,حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ عُمَارَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، أَنَّ عَبْدَ اللہِ بْنَ مَسْعُودٍ أَوْضَعَ فِی وَادِی مُحَسِّرٍ۔,,,15886,,
15887,حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ إسْمَاعِیلَ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّہُ لَمْ یَرَ بَأْسًا بِالإِیضَاعِ فِی وَادِی مُحَسِّرٍ وَکَرِہَہُ فِی جِبَالِ عَرَفَاتٍ۔,,,15887,,
15888,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عُمَرَ بْنِ ذَرٍّ ، عَنْ عَبْدِ الْمَلِکِ بْنِ الْحَارِثِ ، عَنْ عُقْبَۃَ مَوْلَی أَدْلَمَ بْنِ نَاعِمَۃَ الْحَضْرَمِیِّ ، أَنَّہُ دَفَعَ مَعَ الْحُسَیْنِ بْنِ عَلِیٍّ مِنْ جَمْعٍ فَلَمْ یَزِدْ عَلَی السَّیْرِ ، فَلَمَّا أَتَی وَادِیَ مُحَسِّرٍ ، قَالَ : اُرْجُزْ بِصَوْتِکَ وَارْکُضْ بِرِجْلِکَ وَاضْرِبْ بِسَوْطِکَ ، وَدَفَعَ فِی الْوَادِی حَتَّی اسْتَوَتْ بِہِ الأَرْضُ ، وَخَرَجَ مِنَ الْوَادِی۔",,,15888,,
15889,"حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، قَالَ : کَانَ عُمَرُ یُوضِعُ یَقُولُ :\n\nإلَیْکَ تَعْدُو قَلِقٌ وَضِینُہَا ۔۔۔ مُعْتَرِضٌ فِی بَطْنِہَا جَنِینُہَا\n\nمُخَالِفٌ دِینَ النَّصَارَی دِینُہَا\n\nقَالَ : وَکَانَ ابْنُ الزُّبَیْرِ یُوضِعُ أَشَدَّ الإِیضَاعِ۔",,,15889,,
15890,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ خَالِدِ بْنِ أَبِی عُثْمَانَ ، قَالَ : رَأَیْتُ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ یُوضِعُ فِی وَادِی مُحَسِّرٍ وَہُوَ عَلَی بِرْذَوْنٍ۔",,,15890,,
15891,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ مُعَاذٍ أَبِی الْعَلاَئِ ، قَالَ : رَأَیْتُ الْقَاسِمَ بْنَ مُحَمَّدٍ یُوضِعُ فِی وَادِی مُحَسِّرٍ",,,15891,,
15892,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَوْضَعَ فِی وَادِی مُحَسِّرٍ۔ (ترمذی 886۔ احمد 3/332),,,15892,,
15893,حَدَّثَنَا وَکِیعٌ ، عَنْ عُمَرَ بْنِ ذَرٍّ ، عَنْ مُجَاہِدٍ ، عَنْ أُسَامَۃَ بْنِ زَیْدٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَفَاضَ وَعَلَیْہِ السَّکِینَۃُ ، وَأَمَرَہُمْ بِالسَّکِینَۃِ ، وَأَوْضَعَ فِی وَادِی مُحَسِّرٍ۔ (احمد 5/208),,,15893,,
15894,حَدَّثَنَا حَفْصٌ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، عَنْ مِسْوَرِ بْنِ مَخْرَمَۃَ ، عَنْ عُمَرَ ، أَنَّہُ أَوْضَعَ فِی وَادِی مُحَسِّرٍ۔,,,15894,,
15895,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی مِجْلَزٍ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّہُ أَوْضَعَ فِی وَادِی مُحَسِّرٍ۔,,,15895,,
15896,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللہِ الأَسَدِیُّ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنِ الْمُسَیَّبِ بْنِ رَافِعٍ ، عَنْ عَبِیْدَۃَ ، أَنَّہُ أَوْضَعَ فِی وَادِی مُحَسِّرٍ۔,,,15896,,
15897,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، قَالَ : کَانَ أَبِی یَنْحَرُ بَدَنَتَہُ وَہِیَ قَائِمَۃٌ۔",,,15897,,
15898,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، وَعَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالاَ : الصَّوَافُّ عَلَی أَرْبَعَۃٍ ، وَالصَّوَافِنُ عَلَی ثَلاَثَۃٍ۔",,,15898,,
15899,"حَدَّثَنَا مُحَمَّدُ بْنُ عُبَیْدٍ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ ابْنُ عُمَرَ إذَا أَرَادَ أَنْ یَنْحَرَ ہَدْیَہُ عَقَلَہَا فَقَامَتْ عَلَی ثَلاَثٍ ، ثُمَّ نَحَرَہَا۔",,,15899,,
15900,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ أَیْمَنَ بْنِ نَابِلٍ أَبِی عِمْرَانَ ، قَالَ : سَأَلْتُ طَاوُوسًا ، عَنْ قَوْلِ اللہِ (صَوَاف) قَالَ : تُنْحَرُ قِیَامًا۔",,,15900,,
15901,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ عُثْمَانَ ، عَنْ مُجَاہِدٍ فِی قولہ تعالی : {وَالْبُدْنَ جَعَلْنَاہَا لَکُمْ مِنْ شَعَائِرِ اللہِ لَکُمْ فِیہَا خَیْرٌ فَاذْکُرُوا اسْمَ اللہِ عَلَیْہَا صَوَافَّ} قَالَ : إذَا نَحَرَہَا قِیَامًا۔",,,15901,,
15902,"حَدَّثَنَا وَکِیعٌ ، عَنْ نَافِعِ بْنِ عُمَرَ ، عَنْ عَمْرِو بْنِ دِینَارٍ، قَالَ: رَأَیْتُ ابْنَ عُمَرَ بَعْدَ مَا کَبِرَ یَنْحَرُہَا بَارِکَۃً۔",,,15902,,
15903,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : إِنْ شَائَ قِیَامًا ، وَإِنْ شَائَ بَارِکَۃً۔",,,15903,,
15904,حَدَّثَنَا وَکِیعٌ ، عَنْ أَفْلَحَ ، عَنِ الْقَاسِمِ ، أَنَّہُ نَحَرَہَا وَہِیَ قَائِمَۃٌ۔,,,15904,,
15905,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ ابن أَبِی مُلَیْکَۃَ ، عَنِ ابْنِ عَبَّاسٍ فِی آیَۃِ : {فَاذْکُرُوا اسْمَ اللہِ عَلَیْہَا صَوَافَّ} قَالَ : قِیَامٌ۔",,,15905,,
15906,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ أَشْعَثَ ، عَمَّنْ یَذْکُرُ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : رَأَی رَجُلاً یَنْحَرُ بَدَنَتَہُ بَارِکَۃً : فقال : قِیَامًا سُنَّۃُ مُحَمَّدٍ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,15906,,
15907,حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، أَنَّ ابْنَ عُمَرَ کَانَ یَنْحَرُہَا شَابًّا قِیَامًا ، فَلَمَّا کَبِرَ نَحَرَہَا وَہِیَ بَارِکَۃٌ۔,,,15907,,
15908,"حَدَّثَنَا ابْنُ إدْرِیسَ، عَنْ ہِشَامٍ، عَنِ الْحَسَنِ، قَالَ: یَنْحَرُہَا وَہِیَ بَارِکَۃٌ أَہْوَنُ عَلَیْہَا وَعَلَی مَنْ یَنْحَرُہَا۔",,,15908,,
15909,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنْ زِیَادِ بْنِ جُبَیْرٍ ، أَنَّ ابْنَ عُمَرَ أَتَی عَلَی رَجُلٍ قَدْ أَنَاخَ بَدَنَتَہُ ، فَقَالَ: انْحَرْہَا قِیَامًا سُنَّۃُ مُحَمَّدٍ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔ (بخاری 1713۔ ابوداؤد 1765)",,,15909,,
15910,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنْ زِیَادِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ نَحَرَ ثَلاَثَ بُدْنٍ لَہُ قِیَامًا۔,,,15910,,
15911,"حَدَّثَنَا شَبَابَۃُ ، قَالَ : حدَّثَنَا ورقَائُ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، قَالَ : رَأَیْتُ ابْنَ الزُّبَیْرِ یَنْحَرُہَا وَہِیَ قِیَامٌ مَعْقُولَۃٌ إحْدَی یَدَیْہَا۔",,,15911,,
15912,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنْ مُجَاہِدٍ ، قَالَ : الْحَلْقُ وَأَخْذٌ مِنَ الشَّوَارِبِ وَتَقْلِیمُ الأَظْفَارِ وَنَتْفُ الإِبْطِ۔",,,15912,,
15913,"حَدَّثَنَا الْعُکْلِیُّ ، عَنْ مُوسَی بْنِ عُقْبَۃَ ، عَنْ مُحَمَّدِ بْنِ کَعْبٍ الْقُرَظِیِّ ، قَالَ : التَّفَثُ : حَلْقُ الْعَانَۃِ ، وَنَتْف الإِبْطِ ، وَالأَخْذُ مِنَ الشَّارِبِ ، وَتَقْلِیمُ الأَظْفَارِ۔",,,15913,,
15914,"حَدَّثَنَا أَبُو خَالِدٍ ، عن حجاج ، عَنْ عَطَائٍ ، قَالَ : الْحَلْقُ وَالذَّبْحُ وَتَقْلِیمُ الأَظْفَارِ وَمَنَاسِکُ الْحَجِّ۔",,,15914,,
15915,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ أَشْعَثَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : مَا عَلَیْہِمْ فِی الْمَنَاسِکِ۔",,,15915,,
15916,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : الشَّعْرُ وَالظُّفْرُ۔",,,15916,,
15917,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : التَّفَثُ : الرَّمْیُ وَالذَّبْحُ وَالْحَلْقُ وَالتَّقْصِیرُ ، وَالأَخْذُ مِنَ الشَّارِبِ ، وَالأَظْفَارِ ، وَاللِّحْیَۃِ۔",,,15917,,
15918,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ سُفْیَانَ بْنِ حُسَیْنٍ ، عَنِ الزُّہْرِیِّ ، عَنْ أَبِی سِنَانٍ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّ الأَقْرَعَ بْنَ حَابِسٍ سَأَلَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : یَا رَسُولَ اللہِ ، الْحَجُّ فِی کُلِّ عَامٍ ، أَوْ مَرَّۃً وَاحِدَۃً؟ قَالَ : لاَ ، بَلْ مَرَّۃٌ ، فَمَنْ زَادَ فَتَطَوُّعٌ۔ (ابوداؤد 1718۔ دارمی 1789)",,,15918,,
15919,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عُبَیْدَۃَ ، قَالَ : حدَّثَنَا أَبِی ، عَنِ الأَعْمَشِ ، عَنْ أَبِی سُفْیَانَ ، عَنْ أَنَسٍ ، أَنَّ رَجُلاً سَأَلَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْحَجُّ فِی کُلِّ عَامٍ ، أَوْ مَرَّۃً ؟ فَقَالَ : مَرَّۃً ، أَوْ کَلاَمًا نَحْوَ ہَذَا۔\n\n(ابن ماجہ 2885)",,,15919,,
15920,"حَدَّثَنَا مُعَاذٌ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : کَانُوا یَرَوْنَ ، أَنَّ أَعْلَمَ النَّاسِ بِالْمَنَاسِکِ ابْنُ عَفَّانَ ، ثُمَّ بَعْدَہُ ابْنُ عُمَرَ۔",,,15920,,
15921,"حَدَّثَنَا الْفَضْلُ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ اللہِ بْنِ سَیْفٍ ، عَنْ عَائِشَۃَ ، أَنَّہَا قَالَتْ : ابْنُ عَبَّاسٍ أَعْلَمُ مَنْ بَقِیَ بِالْحَجِّ۔",,,15921,,
15922,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَسْلَمَ الْمُنْقِرِیِّ ، قَالَ : کُنْتُ جَالِسًا مَعَ أَبِی جَعْفَرٍ فَمَرَّ عَطَائٌ ، فَقَالَ أَبُو جَعْفَرٍ : مَا بَقِیَ مَا بَقِیَ عَلَی ظَہْرِ الأَرْضِ أَحَدٌ أَعْلَمُ بِمَنَاسِکَ الْحَجِّ مِنْ عَطَائٍ۔",,,15922,,
15923,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، قَالَ : مِنَ السُّنَّۃِ أَنْ تَصْعَدَ عَلَی الصَّفَا حَتَّی یَبْدُوَ لَکَ الْبَیْتُ فَتَسْتَقْبِلَہُ۔",,,15923,,
15924,"حَدَّثَنَا حُمَیْدٌ ، عَنْ حُسَیْنِ بْنِ عُقَیلٍ ، عَنِ الضَّحَّاکِ ، قَالَ : یَصْعَدُ عَلَی الصَّفَا حَتَّی یَسْتَقْبِلَ الْبَیْتَ۔",,,15924,,
15925,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ إذَا صَعِدَ عَلَی الصَّفَا اسْتَقْبَلَ الْبَیْتَ وَکَبَّرَ ثَلاَثًا ، وَقَالَ : لاَ إلَہَ إِلاَّ اللَّہُ وَحْدَہُ لاَ شَرِیکَ لَہُ ، لَہُ الْمُلْکُ وَلَہُ الْحَمْدُ وَہُوَ عَلَی کُلِّ شَیْئٍ قَدِیرٌ ، یَرْفَعُ بِہَا صَوْتَہُ ، ثُمَّ یَدْعُو طَوِیلاً۔",,,15925,,
15926,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا قَامَ عَلَی الصَّفَا قَامَ عَلَیْہِ مَقَامًا یَرَی مِنْہُ الْبَیْتَ۔",,,15926,,
15927,حَدَّثَنَا حَاتِمٌ، عَنْ جَعْفَرٍ، عَنْ أَبِیہِ، عَنْ جَابِرٍ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَقَیَ عَلَیْہِ حَتَّی رَأَی الْبَیْتَ۔,,,15927,,
15928,حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ ، عَنْ وَہَیب ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، أَنَّہُ کَانَ یَقِفُ عَلَی الصَّفَا وَالْمَرْوَۃِ حَیْثُ یَرَی الْبَیْتَ۔,,,15928,,
15929,حَدَّثَنَا زَیْدُ بْنُ الْحُبَاب ، عَنْ مُحَمَّدِ بْنِ عَبْدِ اللہِ ، أَنَّ سَالِمًا صَعِدَ الصَّفَا مَکَانًا یَرَی مِنْہُ الْبَیْتَ۔,,,15929,,
15930,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ عُثْمَانَ ، عَنْ مُجَاہِدٍ ، وَعَطَائٍ ، قَالاَ : لاَ یُحْرِمُ بِالْحَجِّ یَوْمَ التَّرْوِیَۃِ حَتَّی یَتَوَجَّہَ إلَی مِنًی۔",,,15930,,
15931,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ إسْمَاعِیلَ بْنِ عَبْدِ الْمَلِکِ ، قَالَ : خَرَجَ سَعِیدُ بْنُ جُبَیْرٍ یَوْمَ التَّرْوِیَۃِ مَاشِیًا وَخَرَجْت مَعَہُ ، فَدَخَلَ الْمَسْجِدَ فَصَلَّی رَکْعَتَیْنِ ، ثُمَّ خَرَجَ مِنَ الْمَسْجِدِ وَلَبَّی حِینَ تَوَجَّہَ۔",,,15931,,
15932,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، عَنِ ابْنِ کَیْسَانَ ، قَالَ : سَمِعْتُ ابْنَ عَبَّاسٍ یَقُولُ : لاَ یَضُرُّکُمْ یَا أَہْلَ مَکَّۃَ أَنْ لاَ تَعْتَمِرُوا ، فَإِنْ أَبَیْتُمْ فَاجْعَلُوا بَیْنَکُمْ وَبَیْنَ الْحَرَمِ بَطْنَ الْوَادِی۔",,,15932,,
15933,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : أَہْلُ مَکَّۃَ یَخْرُجُونَ لِلْعُمْرَۃِ وَیُہِلُّونَ بِالْحَجِّ مِنْ مَکَانِہِمْ۔",,,15933,,
15934,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ الْقَطَّانُ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ خَالِدِ بْنِ مُسْلِمٍ ، عَنْ سَالِمٍ ، قَالَ : لَوْ کُنْت مِنْ أَہْلِ مَکَّۃَ مَا اعْتَمَرْت۔",,,15934,,
15935,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ عُثْمَانَ ، عَنْ عَطَائٍ ، قَالَ : لَیْسَ عَلَی أَہْلِ مَکَّۃَ عُمْرَۃٌ ، إنَّمَا یَعْتَمِرُ مَنْ زَارَ الْبَیْتَ لِیَطُوفَ بِہِ وَأَہْلُ مَکَّۃَ یَطُوفُونَ مَتَی شَاؤُوا۔",,,15935,,
15936,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : لَیْسَ عَلَی أَہْلِ مَکَّۃَ عُمْرَۃٌ ، قَالَ ابْنُ عَبَّاسٍ : أَنْتُمْ یَا أَہْلَ مَکَّۃَ لاَ عُمْرَۃَ لَکُمْ إنَّمَا عُمْرَتُکُمَ الطَّوَافُ بِالْبَیْتِ فَمَنْ جَعَلَ بَیْنَہُ وَبَیْنَ الْحَرَمِ بَطْنَ ْوَادٍ فَلاَ یَدْخُلُ مَکَّۃَ إِلاَّ بِإِحْرَامٍ ، فَقَالَ: فَقُلْتُ لِعَطَائٍ: یُرِیدُ ابْنُ عَبَّاسٍ بطن وَادٍ مِنَ الْحِلِّ؟ قَالَ: بَطْنُ وَادٍ مِنَ الْحِلِّ۔",,,15936,,
15937,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَنْ وَہَیب ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، قَالَ : لَیْسَ عَلَی أَہْلِ مَکَّۃَ عُمْرَۃٌ۔",,,15937,,
15938,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ خُصَیْفٍ ، عَنْ مُجَاہِدٍ ، قَالَ : لَیْسَ عَلَی أَحَدٍ مِنْ أَہْلِ مَکَّۃَ مُتْعَۃٌ۔",,,15938,,
15939,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، قَالَ : لَیْسَ عَلَی أَہْلِ مَکَّۃَ مُتْعَۃٌ وَلَیْسَ عَلَیْہِمْ إحْصَارٌ ، إنَّمَا إحْصَارُہُمْ أَنْ یَطُوفُوا بِالْبَیْتِ۔",,,15939,,
15940,حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، قَالَ لَیْسَ عَلَی أَہْلِ مَکَّۃَ مُتْعَۃٌ۔,,,15940,,
15941,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ ہِشَامِ بْنِ حُجَیْرٍ ، عَنْ طَاوُوسٍ ، قَالَ : لَیْسَ عَلَی أَہْلِ مَکَّۃَ مُتْعَۃٌ ، ثُمَّ قَرَأَ : {ذَلِکَ لِمَنْ لَمْ یَکُنْ أَہْلُہُ حَاضِرِی الْمَسْجِدِ الْحَرَامِ} ، فَإِنْ فَعَلُوا ، ثُمَّ حَجُّوا فَعَلَیْہِمْ مِثْلُ مَا عَلَی النَّاسِ۔",,,15941,,
15942,"حَدَّثَنَا عُمَرُ بْنُ أَیُّوبَ الْمَوْصِلِیُّ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنْ مَیْمُونٍ ، قَالَ : لَیْسَ عَلَی أَہْلِ مَکَّۃَ ، وَلاَ مَنْ نَظَرَ إلَی مَکَّۃَ مُتْعَۃٌ۔",,,15942,,
15943,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، قَالَ : الْمُتْعَۃُ لِلنَّاسِ أَجْمَعِینَ إِلاَّ أَہْلَ مَکَّۃَ۔",,,15943,,
15944,"حَدَّثَنَا شَبَابَۃُ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : لَیْسَ عَلَی أَہْلِ مَکَّۃَ مُتْعَۃٌ ، وَلاَ إحْصَارٌ ، إنَّمَا یُغْشون حَتَّی یَقْضُوا حَجَّہُمْ۔",,,15944,,
15945,"حَدَّثَنَا عَبْدَۃُ ، عَنْ مُحَمَّدِ بْنِ سُوقَۃَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ فِی قَوْلِہِ {مَنَ اسْتَطَاعَ إلَیْہِ سَبِیلاً} قَالَ : مَنْ وَجَدَ زَادًا وَرَاحِلَۃً فَقَدْ وَجَبَ عَلَیْہِ الْحَجُّ۔",,,15945,,
15946,"حَدَّثَنَا وَکِیعٌ ، عَنْ إبْرَاہِیمَ بْنِ زَیْدٍ ، عَنْ مُحَمَّدِ بْنِ عَبَّادِ بْنِ جَعْفَرٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قامَ رَجُلٌ إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : یَا رَسُولَ اللہِ ، مَا یُوجِبُ الْحَجَّ ؟ قَالَ : زَادٌ وَرَاحِلَۃٌ ، قَالَ : یَا رَسُولَ اللہِ ، فَمَا الْحَاجُّ ؟ قَالَ : الشَّعِثُ التَّفِلُ ، قَالَ : فَقَالَ : یَا رَسُولَ اللہِ ، فَمَا أَفْضَلُ الْحَجِّ ؟ قَالَ : الْعَجُّ وَالثَّجُّ ، قَالَ : الْعَجُّ الْعَجِیجُ بِالتَّلْبِیَۃِ ، وَالثَّجُّ نَحْرُ الْبُدْنِ۔",,,15946,,
15947,"حَدَّثَنَا رَوْحُ بْنُ عُبَادَۃَ ، عَنْ زَکَرِیَّا بْنِ إِسْحَاقَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ : {مَنِ اسْتَطَاعَ إلَیْہِ سَبِیلاً} قَالَ : زَادٌ وَرَاحِلَۃٌ۔",,,15947,,
15948,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ خَالِدٍ أَبِی کَرِیمَۃَ ، عَنْ رَجُلٍ ، عَنِ ابْنِ الزُّبَیْرِ قَالَ : القوۃ عَلَی قَدْرِ الْقُوَّۃِ۔",,,15948,,
15949,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی جَنَابٍ ، عَنِ الضَّحَّاکِ ، عَنِ ابْنِ عَبَّاسٍ فِی قَوْلِہِ : {مَنِ اسْتَطَاعَ إلَیْہِ} قَالَ : الزَّادُ وَالْبَعِیرُ۔",,,15949,,
15950,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : الزَّادُ وَالرَّاحِلَۃُ۔(ابن جریر 16)",,,15950,,
15951,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِمِثْلِہِ۔,,,15951,,
15952,"حَدَّثَنَا أَبُو أُسَامَۃَ، عَنْ ہِشَامٍ، عَنِ الْحَسَنِ؛ فِی قَوْلِہِ: {مَنِ اسْتَطَاعَ إلَیْہِ سَبِیلاً} قَالَ: السَّبِیلُ: زَادٌ وَرَاحِلَۃٌ۔",,,15952,,
15953,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : قَالَ عُمَرُ : {مَنِ أسْتَطَاعَ إلَیْہِ سَبِیلاً} قَالَ : زَادٌ وَرَاحِلَۃٌ ، وَقَالَ ابْنُ عَبَّاسٍ : مَنْ وَجَدَ سَعَۃً ، وَلَمْ یُحَلْ بَیْنَہُ وبینہ ، وَقَالَ عَطَائٌ : سَبِیلاً کَمَا قَالَ اللَّہُ۔",,,15953,,
15954,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ دَاوُدَ ، عَنْ عَطَائٍ ، قَالَ : زَادٌ وَرَاحِلَۃٌ۔",,,15954,,
15955,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ سُوقَۃَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : زَادٌ وَرَاحِلَۃٌ۔",,,15955,,
15956,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ سُوقَۃَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، بِمِثْلِہِ۔,,,15956,,
15957,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ، عَنْ ہِشَامٍ، عَنِ الْحَسَنِ، قَالَ رَجُلٌ: یَا رَسُولَ اللہِ، مَا السَّبِیلُ إلَیْہِ؟ قَالَ: الزَّادُ وَالرَّاحِلَۃُ۔",,,15957,,
15958,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ رَجُلٍ ، یُقَالَ لَہُ : خَالِدٌ ، عَنِ ابْنِ الزُّبَیْرِ : {مَنِ اسْتَطَاعَ إلَیْہِ سَبِیلاً} قَالَ : عَلَی قَدْرِ الْقُوَّۃِ۔",,,15958,,
15959,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عِمْرَانُ بْنُ حُدَیْرٍ ، عَنِ النَّزَّالِ بْنِ عَمَّارٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : مَنْ مَلَکَ ثَلاَثَ مِئَۃِ دِرْہَمٍ وَجَبَ عَلَیْہِ الْحَجُّ وَحَرُمَ عَلَیْہِ نِکَاحُ الإِمَائِ۔",,,15959,,
15960,"حَدَّثَنَا سَعِیدُ بْنُ خُثیم ، عَنْ أَخِیہِ مَعْمَرِ بْنِ خُثیم ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : قُلْتُ لَہُ : یَرْحَمُک اللَّہُ {مَنِ اسْتَطَاعَ إلَیْہِ سَبِیلاً} فَمَا السَّبِیلُ ؟ قَالَ : أَنْ یَکُونَ لَکَ رَاحِلَۃٌ وبتات مِنْ زَادٍ تَمْشِی عُقْبَۃً وَتَرْکَبُ عُقْبَۃً۔",,,15960,,
15961,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ الْحَسَنِ بْنِ مُسْلِمٍ ، عَنْ طَاوُوسٍ ، فِی الرَّجُلِ یَقْدُمُ مَکَّۃَ یَوْمَ عَرَفَۃَ مُعْتَمِرًا فَیَطُوفُ بِالْبَیْتِ وَیَسْعَی بَیْنَ الصَّفَا وَالْمَرْوَۃِ ، قَالَ : لاَ یَأْتِی النِّسَائَ وَالنَّاسُ وُقُوفٌ بِعَرَفَۃَ۔",,,15961,,
15962,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ بَأْسَ بِہِ۔",,,15962,,
15963,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : تَلْبَسُ الْمُحْرِمَۃُ الْخُفَّیْنِ وَالسَّرَاوِیلَ۔",,,15963,,
15964,"حَدَّثَنَا یَعْلَی ، عَنْ عَبْدِ الْمَلِکِ ، قَالَ : سُئِلَ عَطَائٌ أَتَلْبَسُ الْمُحْرِمَۃُ السَّرَاوِیلَ ؟ قَالَ : نَعَمْ۔",,,15964,,
15965,"حَدَّثَنَا ابْنٌ نُمَیْرٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : لاَ بَأْسَ أَنْ تَلْبَسَ الْمُحْرِمَۃُ الْخُفَّیْنِ وَالسَّرَاوِیلَ۔",,,15965,,
15966,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ زَمْعَۃَ ، عَنْ سَلَمَۃَ بْنِ وَہْرَام ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : تَلْبَسُ الْمُحْرِمَۃُ السَّرَاوِیلَ۔",,,15966,,
15967,"حَدَّثَنَا الْعَقَدِیُّ ، عَنْ أَفْلَحَ ، عَنِ الْقَاسِمِ ، قَالَ : تَلْبَسُ الْمُحْرِمَۃُ الْخُفَّیْنِ والسَّرَاوِیلَ وَالْقُفَّازَیْنِ ، وَتُخَمِّرُ وَجْہَہَا کُلَّہُ۔",,,15967,,
15968,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَعَطَائٍ ، قَالاَ : تَلْبَسُ الْمُحْرِمَۃُ السَّرَاوِیلَ۔",,,15968,,
15969,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ یُرَخِّصُ فِی الْخُفَّیْنِ وَالسَّرَاوِیلِ لِلْمُحْرِمَۃِ ، قَالَ : وَکَانَتْ صَفِیَّۃُ تَلْبَسُ وَہِیَ مُحْرِمَۃٌ خُفَّیْنِ إلَی رُکْبَتَیْہَا۔",,,15969,,
15970,حَدَّثَنَا ابْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ تَلْبَسَ الْمُحْرِمَۃُ الْخُفَّیْنِ الْمَسُوقَیْنِ۔,,,15970,,
15971,"حَدَّثَنَا عَفَّانَ ، قَالَ : حدَّثَنَا عَبْدُ الْوَارِثِ ، قَالَ : حدَّثَنَا حُمَیْدٌ الأَعْرَجُ ، عَنْ مُجَاہِدٍ ، أَنَّ عَبْدَ اللہِ بْنَ عَمْرٍو ، وَعَبْدَ اللہِ بْنَ عَبَّاسٍ ، وَعَبْدَ اللہِ بْنَ عُمَرَ کَانُوا إذَا قَضَوْا طَوَافَہُمْ فَأَرَادُوا أَنْ یَخْرُجُوا اسْتَعَادُوا بَیْنَ الرُّکْنِ وَالْبَابِ ، أَوْ بَیْنَ الْحَجَرِ وَالْبَابِ۔",,,15971,,
15972,"حَدَّثَنَا صَفْوَانُ بْنُ عِیسَی ، عَنِ الْحَارِثِ بْنِ أَبِی ذُبَاب ، قَالَ : حدَّثَنِی عِکْرِمَۃُ ، قَالَ : کُلُّ صَیْدٍ یُصِیبُہُ الْمُحْرِمُ دُونَ الْحَمَامَۃِ فَفِیہِ ثَمَنُہُ۔",,,15972,,
15973,حَدَّثَنَا عَبْدُ الأَعْلَی، عَنْ ہِشَامٍ، عَنِ الْحَسَنِ، وَعَطَائٍ أَنَّہُمَا لَمْ یَرَیَا بَأْسًا أَنْ یَرْتَدِیَ الْمُحْرِمُ بِالْقَمِیصِ۔,,,15973,,
15974,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ یَکْرَہُ ذَلِکَ۔,,,15974,,
15975,"حَدَّثَنَا مُعْتَمِرٌ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی مجلز ، قَالَ : رَأَیْتُ ابْنَ عَبَّاسٍ یَرْمِی الْجِمَارَ وَہُوَ صَائِمٌ۔",,,15975,,
15976,حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، أَنَّہَا کَانَتْ تَصُومُ أَیَّامَ التَّشْرِیقِ۔,,,15976,,
15977,حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنِ الأَسْوَدِ ، أَنَّہُ کَانَ یَصُومُ أَیَّامَ التَّشْرِیقِ۔,,,15977,,
15978,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنِ الْجُرَیْرِیِّ ، عَنْ قَیْسِ بْنِ عَبَایَۃَ ، قَالَ : سَأَلْتُ ابْنَ عَبَّاسٍ ، عَنْ صِیَامِ الْیَوْمِ بَعْدَ النَّحْرِ ، فَقَالَ : صُمْ إِنْ شِئْت۔",,,15978,,
15979,حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، أَنَّہُ کَانَ یَصُومُ أَیَّامَ التَّشْرِیقِ۔,,,15979,,
15980,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ أَبِی الْحَسَنِ ، قَالَ : مَا مِنْ یَوْمٍ أَصُومُہُ أَحَبَّ إلَیَّ مِنْ صَوْمِ یَوْمِ الرُّؤُوسِ۔",,,15980,,
15981,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ زَیْدِ بْنِ جُبَیْرٍ ، قَالَ : سَأَلْتُ ابْنَ عُمَرَ مَا یَقْتُلُ الْمُحْرِمُ ؟ فَقَالَ : حَدَّثَتْنِی إحْدَی نِسْوَۃِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، عن رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنَّہُ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَمَرَ بِقَتْلِ الْغُرَابِ۔",,,15981,,
15982,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ عَلِیٍّ ، قَالَ : یَقْتُلُ الْمُحْرِمُ الْغُرَابَ۔",,,15982,,
15983,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنِ ابْنِ أَبِی عَمَّارٍ ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ یَرْمِی غُرَابًا ، عَنْ ظَہْرِ بَعِیرِہِ وَہُوَ مُحْرِمٌ۔",,,15983,,
15984,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنٍ ، عَنْ إِبْرَاہِیمَ بن عَبْدِ الأَعْلَی ، عَنْ سُوَیْد بْنِ غَفَلَۃَ ، قَالَ : أَمَرَنَا عُمَرُ بِقَتْلِ الْغُرَابِ وَالزُّنْبُورِ وَنَحْنُ مُحْرِمُونَ۔",,,15984,,
15985,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ آدَمَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : ارْجُمِ الْغُرَابَ وَأَنْتَ مُحْرِمٌ۔",,,15985,,
15986,"حَدَّثَنَا ابْنُ فُضَیْلٍ، عَنْ حُصَیْنٍ، قَالَ: سَأَلْتُ مُجَاہِدًا عَمَّا یَقْتُلُونَ فِی الْحَرَمِ، فَقَالَ: الْحَیَّۃُ وَیُرْمَی الْغُرَابُ۔",,,15986,,
15987,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ قَالَ : یَرْمِی الْمُحْرِمُ الْغُرَابَ۔",,,15987,,
15988,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : یُقْتَلُ الْغُرَابُ۔",,,15988,,
15989,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، قَالَتْ ، قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لِیَقْتُلَ الْمُحْرِمُ الْغُرَابَ۔",,,15989,,
15990,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی قَزَعَۃَ الْبَاہِلِیِّ ، عَنْ مُہَاجِرٍ الْمَکِّیِّ ، قَالَ : سَأَلَ رَجُلٌ جَابِرَ بْنَ عَبْدِ اللہِ أَیَرْفَعُ أَحَدُنَا یَدَیْہِ إذَا رَأَی الْبَیْتَ ؟ فَقَالَ : ذَاکَ صَنِیعُ یَہُودَ ، قَدْ حَجَجْنَا مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فلم نَفْعَلْ ذَلِکَ۔ (ابوداؤد 1865۔ دارمی 1920)",,,15990,,
15991,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی قَزَعَۃَ الْبَاہِلِیِّ ، عَنْ مُہَاجِرٍ الْمَکِّیِّ ، قَالَ : سُئِلَ جَابِرُ بْنُ عَبْدِ اللہِ ، أَیَرْفَعُ الرَّجُلُ یَدَیْہِ إذَا رَأَی الْبَیْتَ ؟ فَقَالَ : قَدْ حَجَجْنَا مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَکُنَّا نَفْعَلُہُ۔",,,15991,,
15992,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَطَائٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : تُرْفَعُ الأَیْدِی فِی سَبْعَۃِ مَوَاطِنَ ، إذَا رَأَی الْبَیْتَ ، وَعَلَی الصَّفَا وَالْمَرْوَۃِ وَفِی جَمْعٍ ، وَالْعَرَفَاتِ ، وَعِنْدَ الْجِمَارِ۔",,,15992,,
15993,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ الْمُنْکَدِرِ ، قَالَ : مَا أَمْعَرَ حَاجٌّ قَطُّ یَعْنِی مَا افْتَقَرَ۔",,,15993,,
15994,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، قَالَ : کَانَ أَصْحَابُ عَبْدِ اللہِ یَقُولُونَ : تُرْفَعُ الأَیْدِی فِی ثَمَانِیَۃِ مَوَاطِنَ عِنْدَ الْبَیْتِ ، وَعَلَی الصَّفَا وَالْمَرْوَۃِ ، وَبِعَرَفَۃَ ، وَبِالْمُزْدَلِفَۃِ ، وَعِنْدَ الْجَمْرَتَیْنِ۔",,,15994,,
15995,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنْ طَلْحَۃَ ، عَنْ إبْرَاہِیمَ وَخَیْثَمَۃَ ، قَالاَ : تُرْفَعُ فِی الصَّلاَۃِ ، وَعِنْدَ الْبَیْتِ ، وَعَلَی الصَّفَا وَالْمَرْوَۃِ وَبِالْمُزْدَلِفَۃِ۔",,,15995,,
15996,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْحَکَمِ ، عَنْ مِقْسَمٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ تُرْفَعُ الأَیْدِی إِلاَّ فِی سَبْعَۃِ مَوَاطِن : إذَا قُمْتَ إلَی الصَّلاَۃِ ، وَإِذَا جِئْتَ مِنْ بَلَدٍ ، وَإِذَا رَأَیْتَ الْبَیْتَ ، وَإِذَا قُمْتَ عَلَی الصَّفَا وَالْمَرْوَۃِ ، وَبِعَرَفَاتٍ ، وَبِجَمْعٍ ، وَعِنْدِ الْجِمَارِ۔",,,15996,,
15997,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، عَنِ الشَّعْبِیِّ ، قَالَ : أَوَّلُ مَا تدْخُلُ مَکَّۃَ ، فَإِذَا انْتَہَیْت إلَی الْحَجَرِ فَاحْمَدِ اللَّہَ عَلَی حُسْنِ تَیْسِیرِہِ وَبَلاَغِہِ۔",,,15997,,
15998,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْن سَعِیدٍ - یعنی : مُحَمَّدِ بْنِ سَعِیدٍ - ، عَنْ أَبیہ سَعِیدٍ أَنَّہُ کَانَ إذَا رَأَی الْبَیْتَ ، قَالَ : اللَّہُمَّ أَنْتَ السَّلاَمُ وَمِنْک السَّلاَمُ فَحَیِّنَا رَبَّنَا بِالسَّلاَمِ۔",,,15998,,
15999,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ رَجُلٍ مِنْ أَہْلِ الشَّامِ ، عَنْ مَکْحُولٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لَمَّا رَأَی الْبَیْتَ ، قَالَ : اللَّہُمَّ زِدْ ہَذَا الْبَیْتِ تَشْرِیفًا وَتَعْظِیمًا وَمَہَابَۃً ، وَزِدْ مَنْ حَجَّہُ ، أَوِ اعْتَمَرَہُ تَشْرِیفًا وَتَعْظِیمًا وَتَکْبِیرًا وَبِرًّا۔ (طبرانی 3053)",,,15999,,
16000,"حَدَّثَنَا وَکِیعٌ ، عَنِ الْعُمَرِیِّ ، عَنْ مُحَمَّدِ بْنِ سَعِیدٍ ، عَنْ أَبِیہِ ، أَنَّ عُمَرَ لَمَّا دَخَلَ الْبَیْتَ ، قَالَ : اللَّہُمَّ أَنْتَ السَّلاَمُ ، وَمِنْک السَّلاَمُ ، فَحَیِّنَا رَبَّنَا بِالسَّلاَمِ۔",,,16000,,
16001,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ یَحْیَی بْنِ مُحَمَّدِ بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، أَنَّہُ کَانَ إذَا دَخَلَ مَسْجِدَ الْکَعْبَۃِ وَنَظَرَ إلَی الْبَیْتِ ، قَالَ : اللَّہُمَّ أَنْتَ السَّلاَمُ وَمِنْک السَّلاَمُ فَحَیِّنَا رَبَّنَا بِالسَّلاَمِ۔",,,16001,,
16002,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ حُمَیْدِ بْنِ صَخْرٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّہُ قَالَ : إنِّہَا لَحَوْجَائُ فِی نَفْسِی أَنْ أَمُوتَ قَبْلَ أَنْ أَحُجَّ مَاشِیًا۔",,,16002,,
16003,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، أَنَّ إبْرَاہِیمَ وَإِسْمَاعِیلَ حَجَّا وَہُمَا مَاشِیَانِ۔,,,16003,,
16004,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، قَالَ : حجَّ الْحُسَیْنُ بْنُ عَلِیٍّ مَاشِیًا وَنَجَائِبُہُ تُقَادُ إلَی جَنْبِہِ ، قَالَ حَفْصٌ : أَحْسَبُہُ ، قَالَ : عَشْرًا۔",,,16004,,
16005,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ عُثْمَانَ بْنِ حَکِیمٍ ، قَالَ : رَأَیْتُ نَافِعَ بْنَ جُبَیْرٍ یَقْضِی مَنَاسِکَہُ عَلَی رِجْلَیْہِ وَیُعَرِّفُ عَلَی رِجْلَیْہِ۔",,,16005,,
16006,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ عَبْدِ الْمَلِکِ ، قَالَ : حجَجْت مَعَ سَعِیدِ بْنِ جُبَیْرٍ مَاشِیًا۔",,,16006,,
16007,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : سَأَلْتُ نَافِعًا حَجَّ ابْنُ عُمَرَ مَاشِیًا ؟ قَالَ : لاَ۔",,,16007,,
16008,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، قَالَ : کُلُّ مَا أَصَابَ الْمُحْرِمُ الصَّیْدَ نَاسِیًا حُکِمَ عَلَیْہِ۔",,,16008,,
16009,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : کُلَّمَا أَصَابَ الْمُحْرِمُ الصَّیْدَ حُکِمَ عَلَیْہِ۔",,,16009,,
16010,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ، عَنْ شُرَیْحٍ ، قَالَ : سَأَلَہُ رَجُلٌ ، فَقَالَ : إنِّی أَصَبْتُ صَیْدًا وَأَنَا مُحْرِمٌ ، فَقَالَ لَہُ شُرَیْحٌ : ہَلْ کُنْت أَصَبْت قَبْلَہُ ؟ قَالَ : لاَ قَالَ : لَوْ کُنْت فَعَلْت وَکَّلْتُک إلَی اللہِ تَعَالَی حَتَّی یَنْتَقِمَ مِنْک {وَاللَّہُ عَزِیزٌ ذُو انْتِقَامٍ} قَالَ دَاوُد : فَذَکَرْت ذَلِکَ لِسَعِیدِ بْنِ جُبَیْرٍ ، فَقَالَ : أَفَیَخْلُعُ یَحْکُمُ عَلَیْہِ ؟۔",,,16010,,
16011,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إذَا أَصَابَ مَرَّۃً حُکِمَ عَلَیْہِ ، ثُمَّ إِنْ عَادَ لَمْ یُحْکَمْ عَلَیْہِ ، ثُمَّ قَرَأَ : (وَمَنْ عَادَ فَیَنْتَقِمُ اللَّہُ مِنْہُ)۔",,,16011,,
16012,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یَحْیَی بْنِ أَبِی إِسْحَاقَ ، عَنْ أَنَسٍ ، أَنَّہُ سَمِعَ النبی صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُلَبِّی ، یَقُولُ : لَبَّیْکَ بِعُمْرَۃٍ وَحَجٍّ۔",,,16012,,
16013,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ بکیر بْنِ عَطَائٍ ، عَنْ حُرَیْثِ بْنِ سُلَیْمٍ ، قَالَ : سَمِعْتُ عَلِیًّا لَبَّی بِالْحَجِّ وَالْعُمْرَۃِ ، فَبَدأَ بِالْعُمْرَۃِ ، فَقَالَ لَہُ عُثْمَانَ : إنَّک مِمَّنْ یُنْظَرُ إلَیْہِ ، فَقَالَ لَہُ عَلِی: وَأَنتَ مِمَّن یُنْظَر إِلِیہِ۔",,,16013,,
16014,"حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنْ حُمَیْدٍ، عَنْ أَنَسٍ، أَنَّہُ سَمِعَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ: لَبَّیْکَ بِعُمْرَۃٍ وَحَجَّۃٍ۔",,,16014,,
16015,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، قَالَ : سَأَلْتُ إبْرَاہِیمَ وَمُجَاہِدًا ، عَنِ الرَّجُلِ یُلَبِّی بِالْحَجِّ وَالْعُمْرَۃِ ، فَقَالَ : مُجَاہِدٌ : یَبْدَأُ بِالْعُمْرَۃِ ، وَقَالَ : إبْرَاہِیمُ : تُجْزِئُہُ النِّیَّۃُ۔",,,16015,,
16016,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : إذَا اسْتَعَطَ الرَّجُلُ بِالْبَنَفْسَجِ فَعَلَیْہِ الْفِدْیَۃُ۔",,,16016,,
16017,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، عَنْ جَابِرِ بْنِ زَیْدٍ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ خَطَبَ ، فَقَالَ : إذَا لَمْ یَجِدِ الْمُحْرِمُ إزَارًا فَلْیَلْبَسْ سَرَاوِیلَ ، وَإِذَا لَمْ یَجِدْ نَعْلَیْنِ فَلْیَلْبَسِ الْخُفَّیْنِ۔\n\n(مسلم 835۔ بخاری 1740)",,,16017,,
16018,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ جَابِرِ بْنِ زَیْدٍ ، عَنِ ابْنِ عَبَّاسٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِمِثْلِہِ ، أَوْ نَحْوِہِ۔ (مسلم 835۔ احمد 1/221),,,16018,,
16019,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنِ عَمْرٍو ، عَنْ جَابِرِ بْنِ زَیْدٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : سَمِعْتُ النبی صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُہُ۔ (مسلم 825۔ ترمذی 834)",,,16019,,
16020,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّ رَجُلاً سَأَلَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَا یَلْبَسُ الْمُحْرِمُ مِنَ الثِّیَابِ ، أَوْ مَا یَتْرُکُ الْمُحْرِمُ ؟ فَقَالَ : لاَ یَلْبَسُ الْخُفَّیْنِ ، وَلاَ السَّرَاوِیلَ ، إِلاَّ أَنْ لاَ یَجِدَ نَعْلَیْنِ ، فَمَنْ لَمْ یَجِدْ نَعْلَیْنِ فَلْیَلْبَسِ الْخُفَّیْنِ وَلْیَقْطَعْہُمَا أَسْفَلَ مِنَ الْکَعْبَیْنِ",,,16020,,
16021,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، قَالَ : حدَّثَنَا زُہَیْرٌ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ لَمْ یَجِدْ نَعْلَیْنِ فَلْیَلْبَسِ الْخُفَّیْنِ ، وَمَنْ لَمْ یَجِدْ إزَارًا فَلْیَلْبَسِ السَّرَاوِیلَ۔\n\n(مسلم 836۔ احمد 3/323)",,,16021,,
16022,"حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنْ مُعَاوِیَۃَ بْنِ صَالِحٍ ، عَنْ یُونُسَ بْنِ سَیْفٍ ، عَنْ عُمَیْرِ بْنِ الأَسْوَدِ ، قَالَ : سَأَلْتُ عُمَرَ ، قُلْتُ : مَا تَقُولُ فِی الْخُفَّیْنِ لِلْمُحْرِمِ ، فَقَالَ : ہُمَا نَعْلاَ مَنْ لاَ نَعْلَ لَہُ۔",,,16022,,
16023,حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَلِیٍّ فِی الْمُحْرِمِ إذَا لَمْ یَجِدْ نَعْلَیْنِ لَبِسَ خُفَّیْنِ ، وَإِذَا لَمْ یَجِدْ إزَارًا لَبِسَ سَرَاوِیلَ۔,,,16023,,
16024,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إذَا لَمْ یَجِدِ الْمُحْرِمُ إزَارًا فَلْیَلْبَسْ سَرَاوِیلَ وَإِذَا لَمْ یَجِدْ نَعْلَیْنِ فَلْیَلْبَسِ الْخُفَّیْنِ۔",,,16024,,
16025,"حَدَّثَنَا حدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ حُمَید ، عَنْ بَکر قَالَ : إذَا لَمْ یَجِدَ الْمُحْرِمُ إزَارًا فَلْیَلْبَسْ سَرَاوِیلَ۔",,,16025,,
16026,"حَدَّثَنَا أَبُو بَکْرٍ ، قَالَ ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : لاَ بَأْسَ أَنْ یَلْبَسَ الْمُحْرِمُ سَرَاوِیلَ إذَا لَمْ یَجِدْ إزَارًا ، وَلاَ بَأْسَ أَنْ یَلْبَسَ خُفَّیْنِ إذَا لَمْ یَجِدْ نَعْلَیْنِ۔",,,16026,,
16027,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ جَابِرٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إنِّی لَوِ اسْتَقْبَلْت مِنْ أَمْرِی مَا اسْتَدْبَرْت ، لَمْ أَسُقِ الْہَدْیَ وَجَعَلْتہَا عُمْرَۃً ، فَمَنْ کَانَ مِنْکُمْ لَیْسَ مَعَہُ ہَدْیٌ فَلْیُحِلَّ ، وَلْیَجْعَلْہَا عُمْرَۃً فَقَامَ سُرَاقَۃُ ، فَقَالَ : یَا رَسُولَ اللہِ ألِعَامِنَا ہَذَا ، أَوْ لأَبَدٍ ؟ فَشَبَّکَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَصَابِعَہُ وَاحِدَۃً فِی الأُخْرَی ، وَقَالَ : دَخَلَتِ الْعُمْرَۃُ فِی الْحَجِّ لاَ بَلْ لأَبَدٍ أَبَدٍ۔",,,16027,,
16028,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : جَائَ النَّاسُ مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حُجَّاجًا فَأَمَرَہُمْ فَجَعَلُوہَا عُمْرَۃً ثُمَّ قَالَ : لَوْ أَنِّی اسْتَقْبَلْتُ مِنْ أَمْرِی مَا اسْتَدْبَرْتُ مَا فَعَلْتُ ذلک وَلَکِنْ دَخَلَتِ الْعُمْرَۃُ فِی الْحَجِّ إِلَی یَوْمِ الْقِیَامَۃِ ، ثُمَّ شَبَّکَ بَیْنَ أَصَابِعَہُ۔ (ابوداؤد 1789۔ ترمذی 932)",,,16028,,
16029,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حُمَیْدٌ ، عَنْ بَکْرٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : إِنَّمَا أَہَلَّ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِالْحَجِّ وَأَہْلَلْنَا مَعَہُ ، فَلَمَّا قَدِمناَ قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَنْ لَمْ یَکُنْ مَعَہ ہَدْیٌ فَلْیُحِلَّ وَکَانَ مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ہَدْیٌ فَلَمْ یَحِلَّ۔ (بخاری 4354۔ مسلم 185)",,,16029,,
16030,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ أَفْلَحَ ، عَنِ الْقَاسِمِ ، عَنْ عَائِشَۃَ ، قَالَتْ : خَرَجْنَا مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مُہِلِّینَ بِالْحَجِّ فِی أَشْہُرِ الْحَجِّ وَأَیَّامِ الْحَجِّ ، حَتَّی قَدِمْنَا سَرِفَ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لأَصْحَابِہِ : مَنْ لَمْ یَکُنْ مِنْکُمْ سَاقَ ہَدْیًا فَأَحَبَّ أَنْ یُہِلَّ مِنْ حَجِّہِ بِعُمْرَۃٍ فَلْیَفْعَلْ۔",,,16030,,
16031,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عَبَّاسٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أَنَّہُ قَالَ : ہَذِہِ عُمْرَۃٌ اسْتَمْتَعْنَا بِہَا ، فَمَنْ لَمْ یَکُنْ مَعَہُ ہَدْیٌ فَلْیَحِلَّ الْحِلَّ کُلَّہُ ، فَقَدْ دَخَلَتِ الْعُمْرَۃُ فِی الْحَجِّ إلَی یَوْمِ الْقِیَامَۃِ۔ (مسلم 203۔ ابوداؤد 1787)",,,16031,,
16032,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ التَّیْمِیِّ ، عَنْ أَبِیہِ ، عَنْ أَبِی ذَرٍّ ، قَالَ : کَانَتِ الْمُتْعَۃُ فِی الْحَجِّ لأَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ خَاصَّۃً۔",,,16032,,
16033,حَدَّثَنَا أبُو خَالِدٍ الأَحْمَرِِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنِ الْمُرَقِّعِ ، عَنْ أَبِی ذَرٍّ قَالَ لَیْسَ لأَحَدٍ أَنْ یُہِلَّ بِالْحَجِّ ثُمَّ یَجْعَلُہَا عُمْرَۃً إلا لِلرَّکْبِ الَّذِینَ کَانُوا مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔,,,16033,,
16034,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ ، عَنْ مُجَاہِدٍ ، قَالَ : قَالَ ابْنُ الزُّبَیْرِ : أَفْرِدُوا الْحَجَّ وَدَعُوا قَوْلَ أَعْمَاکُمْ ہَذَا ، فَبَلَغَ ذَلِکَ ابْنَ عَبَّاسٍ ، فَقَالَ : إنَّ الَّذِی عَمَی اللَّہُ قَلْبَہُ وَعَیْنَیْہِ لأَنْتَ ، أَلاَ تَسْأَلُ أُمَّکَ فَسَأَلَہَا ، فَقَالَتْ: قَدِمْنَا مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حُجَّاجًا فَأَمَرَنَا فَأَحْلَلْنَا الْحَلاَلَ کُلَّہُ حَتَّی تَسَطَّعَتِ الْمَجَامِرُ بَیْنَ الرِّجَالِ وَالنِّسَائِ۔ (احمد 6/344۔ طبرانی 244)",,,16034,,
16035,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : حدَّثَنَا عَبْدُ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ فِی حَمَامِ الْحَرَامِ : إذَا خَرَجْنَ مِنَ الْحَرَمِ فَصِدْہُنَّ إِنْ شِئْت۔",,,16035,,
16036,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، قَالَ : کَانَ لاَ یَرَی بَأْسًا بِصَیْدِ حَمَامِ الْحَرَمِ إذَا خَرَجْنَ مِنَ الْحَرَمِ۔",,,16036,,
16037,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُوس ، قَالاَ فِی الرَّجُلِ طَافَ ، ثَمَانیَۃَ أَشْوَاطٍ ، قَالَ : إِنْ ذَکَرَہَا قَبْلَ أَنْ یُصَلِّیَ رَکْعَتَیْنِ طَافَ سِتَّۃَ أَطْوَافٍ ، وَصَلَّی أَرْبَعَ رَکَعَاتٍ ، وَإِنْ ذَکَرَ بَعْدَ مَا یُصَلِّی رَکْعَتَیْنِ ، طَافَ سِتَّۃَ أَطْوَافٍ ، ثُمَّ صَلَّی رَکْعَتَیْنِ ، وَإِنْ شَائَ لَمْ یَعُتَدْ بِذَلِکَ۔",,,16037,,
16038,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : إذَا طَافَ بِالْبَیْتِ ، ثَمَانیَۃَ أَشْوَاطٍ صَلَّی رَکْعَتَیْنِ۔",,,16038,,
16039,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ مُحَمَّدِ بْنِ أَبِی إسْمَاعِیلَ السُّلَمِیِّ ، قَالَ : سُئِلَ سَعِیدُ بْنُ جُبَیْرٍ ، عَنِ التَمْرِ لِلْمُحْرِمِ ، فَقَالَ : وَمَا بَأْسُہُ ؟ قَالَ فِیہِ الدواب ، قَالَ : فَکُلِ التَّمْر ، وَلاَ تَأْکُلِ الدَّوَابَّ۔",,,16039,,
16040,حَدَّثَنَا حَفْصُ بْن غِیَاثٍ ، عَنِ الْعَلاَئِ بْنِ الْمُسَیَّبِ ، عَنِ الْحَکَمِ وَحَمَّادٍ فِی الْمُحْرِمِ یَتَوَشَّحُ ، کَرِہَہُ أَحَدُہُمَا وَلَمْ یَرَ الآخَرُ بِہِ بَأْسًا۔,,,16040,,
16041,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ سُئِلَ عَنْ رَجُلٍ طَافَ سِتًّا وَصَلَّی رَکْعَتَیْنِ ؟ قَالَ : یَطُوفُ طَوَافًا آخَرَ وَیُصَلِّی رَکْعَتَیْنِ۔",,,16041,,
16042,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ بِشْرِ بْنِ مَنْصُورٍ ، عَنْ شُعَیْبٍ ، قَالَ : سُئِلَ الْحَسَنُ ، عَنْ رَجُلٍ طَافَ سِتًّا ؟ قَالَ: یَطُوفُ طَوَافًا آخَرَ۔",,,16042,,
16043,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عُبَیْدٍ الْمُکْتِبِ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا اسْتَلَمْت الْحَجَرَ فَقُلْ : لاَ إلَہَ إِلاَّ اللَّہُ وَاللَّہُ أَکْبَرُ۔",,,16043,,
16044,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُوسَی بْنُ عُبَیْدَۃَ ، عَنْ وَہْبِ بْنِ وَہْبٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ عُمَرَ ، أَنَّہُ کَانَ یَقُولُ إذَا اسْتَلَمَ : آمَنْتُ بِاَللَّہِ وَکَفَرْتُ بِالطَّاغُوتِ۔",,,16044,,
16045,"حَدَّثَنَا وَکِیعٌ ، عَنِ الْمَسْعُودِیِّ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : کَانَ عَلِیٌّ إذَا اسْتَلَمَ الْحَجَرَ یَقُولُ : اللَّہُمَّ تَصْدِیقًا بِکِتَابِکَ وَسُنَّۃِ نَبِیِّک۔",,,16045,,
16046,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ الْمَسْعُودِیِّ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ مِثْلَ حَدِیثِ وَکِیعٍ ، عَنِ الْمَسْعُودِیِّ۔,,,16046,,
16047,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ زَیْدٍ ، عَنْ کَثِیرِ بْنِ شِنْظِیرٍ ، عَنْ عَطَائٍ ، قَالَ : إذَا اسْتَلَمْت الْحَجَرَ فَقَبِّلْ یَدَیْک ، وَلاَ تُصَوِّتْ بِالْقُبْلَۃِ۔",,,16047,,
16048,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ شُعْبَۃَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، أَنَّہُ کَانَ یَسْتَحِبُّ أَنْ لاَ یَکُونَ تَحْتَ الْجَوَالِیقِین شَیْئٌ۔,,,16048,,
16049,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ خَالِدٍ الأَعْوَرِ ، قَالَ : خَالَفَنِی ذَرٌّ الْہَمْدَانِیُّ فِی الْحَجِّ عَلَی الْمَحْمِلِ وَالْقَتَبِ أَیُّہُمَا أَفْضَلُ ؟ قَالَ ذَرٌّ : الْمَحْمِلُ ، قَالَ : فَسَأَلْت إبْرَاہِیمَ ، فَقَالَ : الْقَتَبُ۔",,,16049,,
16050,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إِسْحَاقُ بْنُ سَعِیدٍ الْقُرَشِیُّ ، عَنْ أَبِیہِ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ رَأَی رُفْقَۃً مِنْ أَہْلِ الْیَمَنِ ، رِحَالُہُمَ الأَدَم ، فَقَالَ : مَنْ أَحَبَّ أَنْ یَنْظُرَ إلَی أَشْبَہِ رُفْقَۃٍ بِأَصْحَابِ مُحَمَّدٍ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَلْیَنْظُرْ إلَی ہَؤُلاَئِ۔",,,16050,,
16051,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الْعُمَرِیُّ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ یَحُجُّ عَلَی رَحْلٍ۔",,,16051,,
16052,"حَدَّثَنَا وَکِیعٌ ، قَالَ: حدَّثَنَا فُضَیْلُ بْنُ عِیَاضٍ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ: حَجُّ الأَبْرَارِ عَلَی الرِّحَالِ۔",,,16052,,
16053,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا رَبِیعٌ ، عَنْ یَزِیدَ بْنِ أَبَانَ ، عَنْ أَنَسِ بْنِ مَالِکٍ ، قَالَ : حَجَّ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَلَی رَحْلٍ وَقَطِیفَۃٍ تَسْوی ، أَوْ قَالَ : لاَ تَسْوی إِلاَّ أَرْبَعَۃِ دَرَاہِمَ ، ثُمَّ قَالَ : اللَّہُمَّ حَجَّۃٌ لاَ رِیَائَ فِیہَا ، وَلاَ سُمْعَۃَ۔ (ترمذی 334۔ ابن ماجہ 2890)",,,16053,,
16054,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی سِنَانٍ ، عَنْ عَبْدِ اللہِ بْنِ الْحَارِثِ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَجَّ عَلَی رَحْلٍ فَاہْتَزَّ ، وَقَالَ : مَرَّۃً : فَاجْتَنَحَ ، فَقَالَ : لَبَّیْکَ إنَّ الْعَیْشَ عَیْشُ الآخِرَۃِ۔",,,16054,,
16055,"حَدَّثَنَا قُرَّۃُ بْنُ سُلَیْمَانَ ، عَنْ ہِشَامٍ ، عَنْ مُحَمَّدٍ ، قَالَ : کَانَ یُکْرَہُ الْحَجُّ عَلَی الْمَحْمِلِ فَیَقُولُ : إنَّمَا کَانَ النَّاسُ یَحُجُّونَ عَلَی الأَقْتَابِ وَالرِّحَالِ۔",,,16055,,
16056,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : إذَا وَدَّعَ فَلاَ یَعْمَلُ عَمَلاً حَتَّی یَخْرُجَ إلَی الأَبْطَحِ ، فَإِذَا خَرَجَ إلَی الأَبْطَحِ ، قَالَ : لاَ بَأْسَ أَنْ یُقِیمَ۔",,,16056,,
16057,حَدَّثَنَا وَکِیعٌ ، عَنْ إبْرَاہِیمَ بْنِ یَزِیدَ ، عَنِ الْوَلِیدِ بْنِ عَبْدِ اللہِ بْنِ أَبِی مُغِیثٍ ، أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ وَدَّعَ ، فَأَتَی رَجُلٌ مِنْ قُرَیْشٍ فَعَادَہُ ، فَأَعَادَ الْوَدَاعَ۔,,,16057,,
16058,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ رَجُلٍ لَمْ یَکُنْ یُسَمِّیہِ ، عَنْ عُمَرَ بْنِ عبْدِ الْعَزِیزِ ، أَنَّہُ وَدَّعَ ، فَکَتَبَ کِتَابًا فَأَعَادَ الْوَدَاعَ۔,,,16058,,
16059,"حَدَّثَنَا حَکَّامٌ الرَّازِیّ ، قَالَ : سَمِعْتُ رَجُلاً سَأَلَ حُمَیْدًا مَا کَانَ قَوْلُ الْحَسَن ، أَوْ رَأَیُ الْحَسَن فِی الرَّجُلِ إذَا وَدَّعَ ؟ قَالَ : کَانَ لاَ یَرَی بَأْسًا إذَا عَرَضَ لَہُ الشَّیئُ أَنْ یَشْتَرِیَہُ۔",,,16059,,
16060,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ ، أَنَّ أَبَا قِلاَبَۃَ ، لَقِیَ رَجُلاً قَدِمَ مِنَ الْعُمْرَۃِ ، فَقَالَ : بَرَّ الْعَمَلُ ، بَرَّ الْعَمَلُ۔",,,16060,,
16061,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ مَالِکٍ ، قَالَ : لَقِیَ طَلْحَۃُ حَمَّادًا ، فَقَالَ : بَرَّ نُسُکُکَ۔",,,16061,,
16062,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ لَیْثٍ ، عَمَّنْ سَمِعَ ابْنَ عُمَرَ یَقُولُ لِلْحَاجِّ إذَا قَدِمَ : تَقَبَّلَ اللَّہُ نُسُکَک ، وَأَعْظَمَ أَجْرَک ، وَأَخْلَفَ نَفَقَتَک۔",,,16062,,
16063,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ یَحْیَی بْنِ عُبَیْدٍ ، عَنْ أَبِیہِ ، عَنْ عَبْدِ اللہِ بْنِ السَّائِبِ ، قَالَ: سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ بَیْنَ الرُّکْنِ وَالْحَجَرِ : {رَبَّنَا آتِنَا فِی الدُّنْیَا حَسَنَۃً وَفِی الآخِرَۃِ حَسَنَۃً وَقِنَا عَذَابَ النَّارِ}۔ (ابوداؤد 1887۔ احمد 3/411)",,,16063,,
16064,"حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ عَطَائٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ، قَالَ: کَانَ مِنْ دُعَائِ ابْنِ عَبَّاسٍ الَّذِی لاَ یَدَعُ بَیْنَ الرُّکْنِ وَالْمَقَامِ أَنْ یَقُولَ: رَبِّ قَنِّعْنِی بِمَا رَزَقْتنِی ، وَبَارِکْ لی فِیہِ ، وَاخْلُفْ عَلَی کُلَّ غَائِبَۃٍ لِی بِخَیْرٍ۔\n\n(ابن خزیمۃ 2728)",,,16064,,
16065,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ عَجُوزٍ مِنْ أَہْلِ مَکَّۃَ ، قَالَتْ : قدْ أُصِیبَ ابْنُ عَفَّانَ وَأَنَا ابْنَۃُ أَرْبَعَ عَشْرَۃَ سَنَۃً ، قَالَتْ : وَلَقَدْ رَأَیْت الْبَیْتَ ، وَمَا عَلَیْہِ کِسْوَۃٌ ، إِلاَّ مَا یَکْسُوہُ النَّاسُ الْکِسَائُ الأَحْمَر یُطْرَحُ عَلَیْہِ ، وَالثَّوْبُ الأَبْیَضُ ، وَالْکِسَائُ الصُّوفُ ، وَمَا کُسِیَ مِنْ شَیْئٍ عُلِّقَ عَلَیْہِ ، وَلَقَدْ رَأَیْتُہُ ، وَمَا عَلَیْہِ ذَہَبٌ ، وَلاَ فِضَّۃٌ ، قَالَ مُحَمَّدٌ : إنَّ الْبَیْتَ لَمْ یَکُنْ یُکْسَی عَلَی عَہْدِ أَبِی بَکْرٍ ، وَلاَ عُمَرَ ، وَإِنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ کَساہُ الْوَصَائِلَ وَالْقَبَاطِیَّ ، وَالْوَصَائِلُ ثِیَابٌ یَمَانِیَّۃٌ۔",,,16065,,
16066,"حَدَّثَنَا سُرَیْجُ بْنُ النُّعْمَانِ ، قَالَ : حدَّثَنَا فُلَیْحٌ ، عَنْ نَافِعٍ ، قَالَ : کَانَ ابْنُ عُمَرَ یُجَلِّلُ بُدْنَہُ قَبْلَ أَنْ تُکْسَی الْکَعْبَۃُ الجَلَل وَالأَنْمَاطَ وَالْقَبَاطِیَّ ، ثُمَّ یَنْزِعُہَا قَبْلَ أَنْ یَنْحَرَہَا فَیُرْسِلُ بِہَا إلَی خَزَنَۃِ الْکَعْبَۃِ کِسْوَۃَ لِلْکَعْبَۃِ ، فَلَمَّا کُسِیَتِ الْکَعْبَۃُ تَرَکَ ذَلِکَ۔",,,16066,,
16067,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَسَنٍ ، عَنْ لَیْثٍ ، قَالَ : کَانَ کِسْوَۃُ الْکَعْبَۃِ عَلَی عَہْدِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الأَنْطَاعَ وَالْمُسُوحَ۔",,,16067,,
16068,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا إذَا أَتَوُا الْمَرِیضَ لَمْ یَحُجَّ أَمَرُوہُ أَنْ یَنْحَرَ بَدَنَہُ۔",,,16068,,
16069,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یَسْتَحِبُّونَ إذَا لَمْ یَکُنْ حَجَّ أَنْ یُوصِیَ بِہَدْیٍ",,,16069,,
16070,حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ جَابِرٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَرَأَ فِی رَکْعَتَیِ الطَّوَافِ(قُلْ یَا أَیُّہَا الْکَافِرُونَ) وَ(قُلْ ہُوَ اللَّہُ أَحَدٌ) ۔ (ترمذی 869۔ احمد 3/320),,,16070,,
16071,حَدَّثَنَا وَکِیعٌ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ یَعْقُوبَ بْنِ زَیْدٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَرَأَ فِی رَکْعَتَیِ الطَّوَافِ (قُلْ یَا أَیُّہَا الْکَافِرُونَ) وَ(قُلْ ہُوَ اللَّہُ أَحَدٌ)۔,,,16071,,
16072,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَشْعَثَ ، عَنْ عَطَائٍ فِی الْمُحْرِمِ یُصِیبُ الْقِرْدَ ، قَالَ : یُحْکَمُ عَلَیْہِ",,,16072,,
16073,حَدَّثَنَا وَکِیعٌ ، عَنْ عُبَیْدِ اللہِ بْنِ أَبِی زِیَادٍ ، عَنِ الْقَاسِمِ بْنِ مُحَمَّدٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ دَخَلَ مَکَّۃَ مِنْ ثَنِیَّۃِ الْعُلْیَا,,,16073,,
16074,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ قَالَ : مَا أُبَالِی لَوْ دَخَلْت مِنْ أَسْفَلِ مَکَّۃَ",,,16074,,
16075,حَدَّثَنَا وَکِیعٌ ، عَنِ الْعُمَرِیِّ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَدْخُلُ مِنَ الثَّنِیَّۃِ الْعُلْیَا وَیَخْرُجُ مِنَ الثَّنِیَّۃِ السُّفْلَی۔ (بخاری 1576۔ مسلم 918),,,16075,,
16076,حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کان إذَا خَرَجَ خَرَجَ مِنْ طَرِیقٍ بِالشَّجَرَۃِ ، وَإِذَا دَخَلَ دَخَلَ مِنْ طَرِیقِ الْمُعَرَّسِ ، وَإِذَا دَخَلَ مَکَّۃَ دَخَلَ مِنَ الثَّنِیَّۃِ الْعُلْیَا ، وَإِذَا خَرَجَ خَرَجَ مِنَ الثَّنِیَّۃِ السُّفْلَی۔ (بخاری 1533۔ مسلم 918),,,16076,,
16077,"حَدَّثَنَا وَکِیعٌ ، عَنْ نَصْرِ بْنِ عَدِیٍّ ، قَالَ : سَمِعْتُ مُجَاہِدًا یَقُولُ : إنَّمَا سُمِّیَ الْبَیْتُ الْعَتِیقُ لأَنَّہُ أُعْتِقَ مِنَ الْجَبَابِرَۃِ ، فَلَیْسَ جَبَّارٌ یَدَّعِی أَنَّہُ لَہُ۔",,,16077,,
16078,"حَدَّثَنَا وَکِیعٌ ، وَغُنْدَرٌ وَشُعْبَۃُ ، عَنِ الْحَکَمِ ، عَنْ عِکْرِمَۃَ ، وَعَطَائٍ ، وَطَاوُوس : {فَاجْعَلْ أَفْئِدَۃً مِنَ النَّاسِ تَہْوِی إلَیْہِمْ} قَالُوا : تَہْوِی إلَیْہِ قُلُوبُہُمْ یَأْتُونَہُ یَعْنِی الْبَیْتَ۔",,,16078,,
16079,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ أَبِی الْہَیْثَمِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ : {جَعَلَ اللَّہُ الْکَعْبَۃَ الْبَیْتَ الْحَرَامَ قِیَامًا لِلنَّاسِ} قَالَ : شِدَّۃً لِدِینِہِمْ۔",,,16079,,
16080,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، قَالَ : إنَّمَا سُمِّیَتِ الْکَعْبَۃُ لأَنَّہَا مُرَبَّعَۃٌ ، وَإِنَّمَا سُمِّیَتِ الْبُدْنُ مِنْ أَجْلِ السَّمَّانَۃِ",,,16080,,
16081,"حَدَّثَنَا وَکِیعٌ ، عَنْ سفیان ، عَنْ غَالِبٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ : {وَإِذْ جَعَلْنَا الْبَیْتَ مَثَابَۃً لِلنَّاسِ} قَالَ: یَحُجُّونَ ، ثُمَّ یَعُودُونَ۔",,,16081,,
16082,"حَدَّثَنَا وَکِیعٌ ، عَنْ مَالِکِ بْنِ مِغْوَلٍ ، عَنْ عَطَائٍ ، قَالَ : یَحُجُّونَہُ ، وَلاَ یَقْضُونَ مِنْہُ وَطَرًا۔",,,16082,,
16083,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، قَالَ : لَوْلا أَنَّہُ قَالَ : {فَاجْعَلْ أَفْئِدَۃً مِنَ النَّاسِ} لاَزْدَحَمَتْ عَلَیْہِ فَارِسٌ وَالرُومٌ",,,16083,,
16084,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : إنَّمَا سُمِّیَتْ أَیَّامَ التَّشْرِیقِ إنَّہُمْ کَانُوا یَتَشَرَّقُونَ فِی الشَّمْسِ۔",,,16084,,
16085,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَسْلَمَ الْمُنْقِرِیِّ ، قَالَ : قُلْتُ لِعَطَائٍ : أَخْرُجُ إلَی الْمَدِینَۃِ أُہِلُّ بِعُمْرَۃٍ مِنْ مِیقَاتِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ قَالَ : طَوَافُک بِالْبَیْتِ أَحَبُّ إلَیَّ مِنْ سَفَرِکَ إلَی الْمَدِینَۃِ۔",,,16085,,
16086,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عَمْرُو بْنُ ذَرٍّ ، عَنْ مُجَاہِدٍ ، قَالَ : طَوَافُک بِالْبَیْتِ أَحَبُّ إلَیَّ مِنْ سَفَرِکَ إلَی الْمَدِینَۃِ",,,16086,,
16087,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ: الطَّوَافُ بِالْبَیْتِ أَحَبُّ إلَیَّ مِنَ الْخُرُوجِ إلَی الْعُمْرَۃِ۔",,,16087,,
16088,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : إنَّمَا سُمِّیَتِ الْمُتْعَۃَ لأَنَّہُمْ کَانُوا یَتَمَتَّعُونَ مِنَ النِّسَائِ وَالثِّیَابِ",,,16088,,
16089,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ: حدَّثَنَا سُفْیَانُ ، عَنْ عَبْدِ اللہِ بْنِ عُثْمَانَ ، عَنْ رَجُلٍ ، قَالَ: رَأَیْتُ شَیْبَۃَ یَأْخُذُ مَا وَقَعَ مِنْ کِسْوَۃِ الْکَعْبَۃِ فَیَضَعُہَا فِی الْفُقَرَائِ ، قَالَ سُفْیَانُ : لاَ بَأْسَ بِشِرَائِہَا مِنَ الْفُقَرَائِ إذَا أَعْطَاہُمْ إیَّاہُ۔",,,16089,,
16090,"حَدَّثَنَا شَاذَانُ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنِ الْحَکَمِ بْنِ عُتَیْبَۃَ ، قَالَ : کَانَ یُسْتَحَبُّ أو یستحب الْغُسْلُ أَیَّامَ التَّشْرِیقِ إذَا رَاحَ إلَی الْمَسْجِدِ ، أَوْ إلَی الْجِمَارِ۔",,,16090,,
16091,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : سَمِعْتُ سُفْیَانَ سُئِلَ عَمَّنْ أَسْلَمَ فَحَجَّ ، ثُمَّ ارْتَدَّ ، ثُمَّ رَجَعَ إلَی الإِسْلاَمِ وَجَبَ عَلَیْہِ الْحَجُّ أَمْ تُجْزِئُہُ تِلْکَ الْحَجَّۃُ ؟ قَالَ : إذَا ارْتَدَّ ہَدَمَ الْکُفْرُ کُلَّ شَیْئٍ کَانَ قَبْلَہُ ، فَعَلَیْہِ أَنْ یَحُجَّ ، وَلاَ یَعْتَدَّ بِذَلِکَ۔",,,16091,,
16092,"حَدَّثَنَا ابْنُ یَمَانٍ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، وَعَطَائٍ ، وَطَاوُوس ، قَالَ : جَلِّلْ أَیَّ لَوْنٍ شِئْت۔",,,16092,,
16093,حَدَّثَنَا ابْنُ یَمَانٍ ، عَنْ سُفْیَانَ ، عَنْ إسْمَاعِیلَ بْنِ أُمَیَّۃَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ جَلَّلَ بِنَمَطٍ۔,,,16093,,
16094,حَدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ یُجَلِّلُ بَدْنَہُ تِلْکَ الْجِلاَلِ الْعَوَالِ,,,16094,,
16095,"حَدَّثَنَا ابْنُ یَمَانٍ ، عَنْ سُفْیَانَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، أنَّ عَبْدِ الرَّحْمَنِ بْنِ عَوْفٍ : جَلَّلَ بِالْحِبَر۔",,,16095,,
16096,"حَدَّثَنَا وَکِیعٌ ، عَنْ إبْرَاہِیمَ بْنِ نَافِعٍ ، قَالَ : سَمِعْتُ الْحَسَنَ بْنَ مُسْلِمٍ سَأَلَ طَاوُوسًا ، عَنِ الْجُعَلِ وَالْوَزَغِ یَقْتُلُہُ الْمُحْرِمُ ؟ قَالَ : لاَ بَأْسَ بِہِ۔",,,16096,,
16097,"حَدَّثَنَا وَکِیعٌ، عَنْ إبْرَاہِیمَ، قَالَ: سَأَلْتُ عَطَائً، عَنِ الْوَزَغِ یُقْتَلُ فِی الْحَرَمِ؟ فَقَالَ: إذَا آذَاک فَلاَ بَأْسَ بِہِ۔",,,16097,,
16098,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : اُقْتُلُوا الْوَزَغَ فِی الْحِلِّ وَالْحَرَمِ۔",,,16098,,
16099,"حَدَّثَنَا وَکِیعٌ ، عَنْ شِبْلِ بْنِ عَبَّادٍ ، عَنْ قَیْسِ بْنِ سَعْدٍ ، عَنْ طَاوُوسٍ ، أَنَّہُ کَرِہَ السِّجْنَ بِمَکَّۃَ ، قَالَ : لاَ یَنْبَغِی لِبَیْتِ عَذَابٍ أَنْ یَکُونَ فِی بَیْتِ رَحْمَۃٍ۔",,,16099,,
16100,"حَدَّثَنَا وَکِیعٌ ، قَالَ : سَأَلْتُ سُفْیَانَ ، عَنْ رَجُلٍ نَسِیَ أَنْ یَطُوفَ الطَّوَافَ الْوَاجِبَ فَطَافَ طَوَافَ الصَّدَرِ، ثُمَّ نَفَرَ ؟ فَقَالَ : سُفْیَانُ : طَوَافُ الصَّدَرِ ہُوَ الْوَاجِبُ ، وَعَلَیْہِ دمٌ لِطَوَافِ الصَّدْرِ ، وَقَالَ : الْحَسَنُ بْنُ صَالِحٍ: لاَ یُجْزِئُہُ ، کَأَنَّہُ لَمْ یَطُفْ ، وَفِی قَارِنٍ قَدِمَ فَطَافَ لِلْحَجِّ قَبلَ العُمْرَۃَ قَالَ : یُجْعَل الطَّوَافَ الذِی طَافَہ للحَج ہُوَ لِلْعُمْرَۃِ وَعَلَیْہِ طَوَافُ الْحَجِّ ، وَقَالَ : الْحَسَنُ بْنُ صَالِحٍ : لاَ یُجْزِئُہُ۔",,,16100,,
16101,"سَمِعْتُ وَکِیعًا ، قَالَ : سَمِعْتُ سُفْیَانَ یَقُولُ : إذَا اجْتَمَعَ عَلَیْہِ السَّہْوُ وَالتَّلْبِیَۃُ وَالتَّکْبِیرُ یَبْدَأُ بِالسَّہْوِ ، ثُمَّ التَّلْبِیَۃِ ، ثُمَّ التَّکْبِیرِ",,,16101,,
16102,"حَدَّثَنَا حَفْصُ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، أَنَّہُ یَقُولُ : فِی الدَّجَاجَۃِ السَّنْدِیَّۃِ حُکُومَۃٌ۔",,,16102,,
16103,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ فِی الْمَمْلُوکِ یَتَمَتَّعُ ، قَالَ : یَذْبَحُ عَنْہُ مَوْلاَہُ شَاۃً۔",,,16103,,
16104,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ لَیْثٍ، قَالَ: رَآنِی عَطَائٌ، وَطَاوُوس وَمُجَاہِدٌ وَأَنَا أَطُوفُ حَوْلَ الْمَقَامِ فَنَہَوْنِی",,,16104,,
16105,"حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ مَالِکِ بْنِ دِینَارٍ ، عَنْ مُجَاہِدٍ ، قَالَ : رَأَیْتُہُ وَبِیَدِہِ سَعْفَۃٌ وَہُوَ یَطْرُدُ بِہَا حَمَامَ مَکَّۃَ۔",,,16105,,
16106,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ یُونُسَ بْنِ مِسْمَارٍ ، قَالَ : رَأَیْتُ عَطَائً فَذَکَرَ نَحْوَہُ۔",,,16106,,
16107,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ عُبَیْدِ الْمُکْتِبِ ، عَنْ مُجَاہِدٍ فِی الصَّیْدِ یُدْخَلُ بِہِ الْحَرَمَ فَیُذْبَحُ فِیہِ، قَالَ : لاَ بَأْسَ بِہِ۔",,,16107,,
16108,"حَدَّثَنَا الْمُحَارِبِیُّ ، عَنْ مُحَمَّدِ بْنِ سُوقَۃَ ، عَنْ عِکْرِمَۃَ ، قَالَ : یُکْتَبُ حَاجُّ بَیْتِ اللہِ فِی لَیْلَۃِ الْقَدْرِ بِأَسْمَائِہِمْ وَأَسْمَائِ آبَائِہِمْ ، فَمَا یُغَادَرُ مِنْہُمْ أَحَدٌ ، وَلاَ یُزَادُ فِیہِمْ أَحَدٌ۔",,,16108,,
16109,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : لاَ بَأْسَ أَنْ یُلَبِّیَ الْجُنُبُ۔",,,16109,,
16110,"حَدَّثَنَا ابْنُ أَبِی زَائِدَۃَ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ قَالَ : لَبِّ عَلَی کُلِّ حَالٍ۔",,,16110,,
16111,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ مُجَاہِدٍ ، قَالَ : لاَ بَأْسَ أَنْ تُہْدَی الْبَدَنَۃُ ذَاتُ الدَّرِّ۔",,,16111,,
16112,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : عَلَیْہِ الْجَزَائُ وَقِیمَۃُ مَا أَکَلَ إذَا أَعْطَی جَزَائً ، ثُمَّ أَکَلَ مِنْہُ۔",,,16112,,
16113,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ طَارِقِ بْنِ عَبْدِ الرَّحْمَنِ ، قَالَ : سَمِعْتُ ابْنَ أَبِی أَوْفَی یُسْأَلُ ، عَنِ الرَّجُلِ یَسْتَقْرِضُ وَیَحُجُّ ؟ قَالَ : یَسْتَرْزِقُ اللَّہَ ، وَلاَ یَحُجُّ۔",,,16113,,
16114,"حَدَّثَنَا مُعَاوِیَۃَ ، عَنْ مُحَمَّدِ بْنِ سُوقَۃَ ، عَنْ مُحَمَّدِ بْنِ الْمُنْکَدَرِ ، أَنَّہُ کَانَ یَسْتَقْرِضُ وَیَحُجُّ ، فَقِیلَ لَہُ : تَسْتَقْرِضُ وَتَحُجُّ ؟ فَقَالَ : إنَّ الْحَجَّ أَقْضَی لِلدَّیْنِ۔",,,16114,,
16115,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ سُوقَۃَ ، عَنْ مُحَمَّدِ بْنِ الْمُنْکَدَرِ ، قَالَ : الْحَجُّ أَقْضَی لِلدَّیْنِ۔",,,16115,,
16116,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ حَجَّاجٍ ، قَالَ : کَانَ الْحَکَمُ وَأَصْحَابُنَا یَقُولُونَ فِی الْمُحْرِمِ یَکُونُ بِہِ الْقُرُوحُ فِی جَسَدِہِ وَرَأْسِہِ فَیُدَاوِیہَا بِالطِّیبِ ؟ قَالُوا : فِیہِ کَفَّارَتَانِ ، کَفَّارَۃٌ فِی رَأْسِہِ وَکَفَّارَۃٌ فِی جَسَدِہِ۔",,,16116,,
16117,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، قَالَ : عَلَیْہِ کَفَّارَۃٌ وَاحِدَۃٌ۔",,,16117,,
16118,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، قَالَ : قَالَ عَلِیٌّ مَنِ اضْطُرَّ إلَی ثَوْبٍ وَہُوَ مُحْرِمٌ ، فَلَمْ یَکُنْ لَہُ إِلاَّ قَبَاء فَلْیُنَکِّسْہُ ، یَجْعَلُ أَعْلاَہُ أَسْفَلَہُ ، ثُمَّ لِیَلْبِسْہُ۔",,,16118,,
16119,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَمُجَاہِدٍ ، قَالاَ : لاَ یُدْخِلُ الْمُحْرِمُ مَنْکِبَیْہِ فِی الْقَبَاء ، وَلاَ بَأْسَ أَنْ یَرْتَدِیَ بِہِ۔",,,16119,,
16120,"حَدَّثَنَا جَرِیرٌ، عَنْ مُغِیرَۃَ، عَنْ إبْرَاہِیمَ ، قَالَ: لاَ یُدْخِلُ الْمُحْرِمُ مَنْکِبَیْہِ فِی الْقَبَائ، وَلاَ بَأْسَ أَنْ یَرْتَدِیَ بِہِ۔",,,16120,,
16121,حَدَّثَنَا مُعَاذٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ یَلْبَسَ الْمُحْرِمُ الْقَبَائَ ، مَا لم یُدْخِل مَنْکِبَیْہِ فِیہِ۔,,,16121,,
16122,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی مَسْلَمَۃَ ، قَالَ : سُئِلَ عِکْرِمَۃُ ، عَنْ مُحْرِمٍ لَبِسَ قَبَائً ، قَالَ : یَخْلَعُہُ۔",,,16122,,
16123,حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنِ الْوَلِیدِ بْنِ جُمَیْعٍ ، عَنْ أَبِی سَلَمَۃَ ، أَنَّ عُمَرَ بْنَ الْخَطَّابِ وَعَائِشَۃَ کَانَا إذَا قَدِمَا مَکَّۃَ لَمْ یَنْزِلاَ الْمَنْزِلَ الَّذِی ہَاجَرَا مِنْہُ۔,,,16123,,
16124,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ زَکَرِیَّا ، عَنْ سَعْدِ بْنِ إبْرَاہِیمَ ، قَالَ : کَانَ عَبْدُ الرَّحْمَنِ بْنُ عَوْفٍ إذَا قَدِمَ مَکَّۃَ حَاجًّا کَرِہَ أَنْ یَنْزِلَ بَیْتَہُ الَّذِی ہَاجَرَ مِنْہُ۔",,,16124,,
16125,حَدَّثَنَا وَکِیعٌ ، عَنْ عِکْرِمَۃَ بْنِ عَمَّارٍ ، عَنْ طَیْسَلَۃَ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ نَزَلَ الأَرَاکَ بِعَرَفَۃَ۔,,,16125,,
16126,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، عَنْ أَبِیہِ ، عَنِ ابْنِ مَسْعُودٍ ، أَنَّہُ نَزَلَ الأَرَاکَ۔,,,16126,,
16127,حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ جَابِرٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ضُرِبَتْ لَہُ القُبَّۃُ بِنَمِرَۃَ فَجَائَ فَنَزَلَ۔,,,16127,,
16128,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ رَجُلٍ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّہُ نَزَلَ الْحِیَاضَ بِعَرَفَۃَ۔,,,16128,,
16129,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، قَالَ : حدَّثَنِی أَبُو مَوْدُودٍ ، قَالَ : حَدَّثَنِی یَزِیدُ بْنُ عَبْدِ اللہ بْنِ قُسَیْطٍ ، قَالَ : رَأَیْتُ نَفَرًا مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا خَلاَ لَہُمَ الْمَسْجِدُ قَامُوا إِلَی رُمَّانَۃِ الْمِنْبَرِ الْقَرْعَاء فَمَسَحُوہَا وَدَعَوَا ، قَالَ : وَرَأَیْت یَزِیدَ یَفْعَلُ ذَلِکَ۔",,,16129,,
16130,حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ یَزِیدَ اللَّیْثِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، أَنَّہُ کَرِہَ أَنْ یَضَعَ یَدَہُ عَلَی الْمِنْبَرِ۔,,,16130,,
16131,"حَدَّثَنَا معَنْ بْنُ عِیسَی ، عَنْ ثَابِتِ بْنِ قَیْسٍ ، قَالَ : رَأَیْتُ أَبَا بَکْرٍ إذَا رَقِیَ عَلَی الْمِنْبَرِ خَلَعَ نَعْلَیْہِ۔",,,16131,,
16132,"حَدَّثَنَا مَعْنِ بْنِ عِیسَی ، عَنْ ماَلِکَ ، قَالَ : سُئِلَ الزُہَرِی ہَلْ تُقَلِّد المَرْأَۃُ أَوْ تُشْعِرُ ؟ قَالَ : لاَ بَأْسَ بِہِ۔",,,16132,,
16133,"حَدَّثَنَا معَنْ بْنُ عِیسَی ، عَنْ مُحَمَّدِ بْنِ ہِلاَلٍ ، قَالَ : رَأَیْتُ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ إذَا رَقِیَ مِنْبَرَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ خَلَعَ نَعْلَیْہِ۔",,,16133,,
16134,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مَہْدِیٍّ ، قَالَ : حدَّثَنِی شُعَیْبُ بْنُ الْحَبْحَابِ ، قَالَ : سَمِعْتُ الشَّعْبِیَّ یَقُولُ : إنَّمَا جَعَلَ اللَّہُ ہَذِہِ الْمَنَاسِکَ لِیُکَفِّرَ بِہَا خَطَایَا بَنِی آدَمَ۔",,,16134,,
16135,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ، عَنِ ابْنِ جُرَیْجٍ، عَنْ عَطَائٍ، قَالَ: قُلْتُ لَہُ: کَیْفَ یَدْفَعُ الْمَاشِی؟ قَالَ: کَیْف تَیَسَّرَ۔",,,16135,,
16136,حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ ، أَنَّہُ کَرِہَ لِلْمُحْرِمِ إذَا مَرَّ بِرِیحٍ مُنْتِنَۃٍ أَنْ یَضَعَ ثَوْبَہُ عَلَی أَنْفِہِ یُمْسِکُہُ۔,,,16136,,
16137,"حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ بَأْسَ بِہِ۔",,,16137,,
16138,"حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ، عَنْ إسْرَائِیلَ، عَنْ لَیْثٍ، عَنْ عَطَائٍ، وَطَاوُوس، وَمُجَاہِدٍ، قَالُوا: لاَ بَأْسَ بِہِ۔",,,16138,,
16139,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : رَجُلٌ رَمَی الْعَقَبَۃَ ، وَلَمْ یَحْلِقْ أَیَحْلِقُ النَّاسُ ؟ قَالَ: نَعَمْ۔",,,16139,,
16140,حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، أَنَّہُ کَرِہَ أَنْ یَبِیعَ شَعَرَہُ إذَا حَلَقَہُ یَعْنِی الْمُحْرِمَ۔,,,16140,,
16141,حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، قَالَ فِی کُلِّ ذَات کَرِشٍ شَاۃٌ۔,,,16141,,
16142,حَدَّثَنَا مُعْتَمِرٌ ، عَنِ ابْنِ عَوْنٍ ، عَنِ الْحَسَنِ ، قَالَ فِی کُلِّ ذَاتِ کَرِشٍ شَاۃٌ۔,,,16142,,
16143,"حَدَّثَنَا رَوْحُ بْنُ عُبَادَۃَ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ الْعَدَنِیِّ ، قَالَ : رَأَیْتُ مُحَمَّدَ بْنَ عَلِیٍّ یَرْمُلُ بَیْنَ الرُّکْنِ الْیَمَانِیِّ وَالْحَجَرِ وَہُوَ مُضْطَبِعٌ۔",,,16143,,
16144,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ یَعْلَی ، عَنْ أَبِیہِ ، قَالَ : رَأَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَطُوفُ بِالْبَیْتِ مُضْطَبِعًا۔ (ابوداؤد 1878۔ احمد 4/223)",,,16144,,
16145,حَدَّثَنَا قَبِیصَۃُ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَبْدِ الْحَمِیدِ ، عَنِ ابن یَعْلَی ، عَنْ أَبِیہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِثْلَہُ۔,,,16145,,
16146,حَدَّثَنَا قَبِیصَۃُ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ طَافَ بِالْبَیْتِ مُضْطَبِعًا۔,,,16146,,
16147,"حَدَّثَنَا وَکِیعٌ ، عَنْ عِمْرَانَ بْنِ حُدَیْرٍ ، عَنْ أَبِی مجلز فِی قَوْلہ : (حُرِّمَ عَلَیْکُمْ صَیْدُ الْبَرِّ مَا دُمْتُمْ حُرُمًا) قَالَ : مَا کَانَ یَعِیشُ فِی الْبَرِّ والبحر فَلاَ تَصِدْہُ ، وَمَا کَانَ یَعِیشُ فِی الْبَحْرِ فَذَاکَ۔",,,16147,,
16148,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ، عَنْ سَعِیدٍ التَّمَّارِ، قَالَ: رَأَیْتُ ابْنَ الْحَنَفِیَّۃِ جَالِسًا عَلَی حشیۃ حَمْرَائَ وَہُوَ مُحْرِمٌ۔",,,16148,,
16149,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : لاَ بَأْسَ أَنْ یَجْلِسَ عَلَی الْفِرَاشِ الْمَصْبُوغِ بِالزَّعْفَرَانِ وَہُوَ مُحْرِمٌ۔",,,16149,,
16150,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : لاَ بَأْسَ بِہِ۔",,,16150,,
16151,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، قَالَ : حدَّثَنَا ابْنُ عَوْنٍ ، قَالَ نُبِّئْت ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ یَکْرَہُ أَنْ یَجْلِسَ الْمُحْرِمُ عَلَی الْفِرَاشِ الْمَصْبُوغِ بِالزَّعْفَرَانِ۔",,,16151,,
