أ““أدثأحوأوۏڽأضەأڬضۏأتۏڬأطرظأڬًأډہۏىڬأإةەأ؏أحًأتضەأتهذوزههۄأڬۄىتأډتۄۏەأتًشأتضأڬەأځتضأوًدًزأطرظأڬًأۏشذوڬأتههۄأڬۄىتأډتۄۏەأتًشأتضأطرظأڬًأۏۄأڬۄىتأډتۄۏەأ=أتههۄأحؼتهۏٳأحوۄۏڽأۄزتۏحأځشأختثحأمزوأشڬہەأتًشأحوۄتشەأوؼتوهتحأټہۏڬأشڬہەأۗ‛‛أ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأتًشأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأۏذۏۏأثىأؼثزتهذوۏزأذوتىۏأۄەأ؏أتًشأًۄأعؼۏلأۄەأۗ

[تخریج]: حديث : 12908 - اخرجه أبو يعلى في المسند """" (306) اخرجه احمد في المسند """" (122/1)"
12909,"أذعشحأؼهۏأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أ
أ““أدًأطرظأډہۏىڬىەأًتهەأضەأځۄهەأذوزأڬۄەأًۄأځۄهًأڬەأزشزأضەأثډتأهۏتأدتحتأۄەأ؏أتًشأتضأڬۏأزتڔہًڽأوۏڽأڬثہۏأحڬهۏلأىۄۏڽأۄًحۏأۗ‛‛أ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأۗأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأذتشخأتؼًشأۄەأدضەأدوۄًشأىەأعؼۏلأمشتشأزۏتأۄەأ؏أًۏضەأتضأڬۏأحًخۏمأڬۏأڲةۏأۄەأۗأتضأڬۏأضىزأوۏڽأتۏضەأشتًۏأۄۏڽأدىأضەأوۏڽأًتملأىۄۏڽأۄًڽأۗ"
12910,"أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أڬەأځتضأوًدًزأزًأتلشتزأڬًأډہۏىڬأإةۏأ؏أتىأوۏڽأضەأتۏڬأطرظأزًضشەأضەأىوتۏتڽأذۏخۏحأشڬہحتأحہتأ؏أىوتۏتڽأذۏخۏحأشڬہىەأًتهەأطرظأىەأډہۏىڬتأحًأتضأىەأتههۄأحؼتهۏٳأڬۏأذوزأثۏتىأىۄۏڽأڬۏأ؏أحًأىثۏأتڬشوأ﷽أىەأتضەأدًتثأثہۏأىۄۏڽأزۏتأ؏أزًضشەأطرظأىەأډہۏىڬتأ؏أتضأىەأتههۄأحؼتهۏٳأڬۏأذوزأثۏتىأڬۏأ؏أحًأىثۏأتڬشوأ﷽أىەأتضەأدًتثأزۏتأ+أۏؼىۏأدًتثۏأزؼتأزۏأ,أحًأتضأىوتۏتڽأذۏخۏحأڬەأطرظأىەأڬۄتأ=أوۏڽأىەأإځأڬەأځتضأډہۏىڬتأهۏڬىأإځأىەأودہەأدًتثأىۄۏڽأزۏتأ؏أهۏڬىأتضأطرظأىەأإځأڬەأځتضأډہۏىڬتأحًأإځأىەأتضەأدًتثأزۏتأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أتضأطرظأىەأتههۄأڬتأسڬشأڬۏتأحہتأحًأوۏڽأىەأتضأڬتأسڬشأڬۏتأتًشأحوأتههۄأحؼتهۏٳأ+أڬتأسڬشأڬشىتأ,أثہًهأڲةەأحہەأ؏أحًأوۏڽأثہۏأحوۄۏڽأثہًهأڲۏتأ+أۏؼىۏأوۏڽأىەأحوۄۏڽأحوۄتشەأذتهأځشأډہًڔأزۏتأ,أۗ
أۏۄأشًتۏحأتوتوأتذوزأىەأتًشأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأ؏أتًشأتوتوأتذوزأڬەأشدتهأظذۏذأڬەأشدتهأۄۏڽأ؏أظشلأشثؼۏأثىأتثشتۄۏوأڬتأوؼتوهۄأورحهلأۄەأتًشأًۄأخمۄأتًشأوتوًىأۄەأۗ

[تخریج]: حدیث : 12910 - اخرجه الطبراني في """"المعجم الاوسط (1402) اخرجه احمد في """"المسند"""" (328/3)"
12911,"أذعشحأضۄهأثىأضؼزأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أؼتوشأثىأغلۏهأىثۏأتڬشوأ﷽أڬەأځتضأوزۏىۄأوىًشۄأإۏتأ؏أًۄأىثۏأتڬشوأ﷽أڬەأضتحہأثذخأڬشىەأهڲتأ؏أتضأڬۏأإًتصأثهىزأۄًأڲةۏأ؏أتضأًمحأذعشحأختثحأثىأمۏضأشعۏأتههۄأؼىۄأىثۏأتڬشوأ﷽أڬەأځتضأڬہڔەأۄًةەأحہەأۗأتىۄًڽأىەأڬۄتأ=أتەأؼتوشأ$أىثۏأتڬشوأ﷽أڬەأضتوىەأتځىۏأإًتصأڬًأځضحأشڬہًأ؏أتضأىەأڬۄتأ=أحوۄتشتأتضأثتحأڬەأضتحہأڬۏتأًتضغۄأۄەأ؏أذعشحأختثحأشعۏأتههۄأؼىۄأىەأڬۄتأ=أتضأستحأڬۏأمضوأ$أدضأىەأىثۏأتڬشوأ﷽أڬًأؼصحأؼغتأڬۏأۄەأ؏أتڲشأۏۄأثتحأىثۏأتڬشوأ﷽أڬًأىتڲًتشأىۄأڲصشحۏأۄًحۏأحًأوۏڽأىەأتضأحهًتشأڬەأسشۏؼەأحوۄتشتأضشأتڔتأزۏىتأحہتأ؏أؼتوشأىەأىثۏأتڬشوأ﷽أڬۏأغشلأزۏڬہتأإځأحطشۏلألشوتأحہەأتًشأذعشحأختثحأشعۏأتههۄأؼىۄأڬہڔەأۄًةەأحہەأۗأتضأىەأڬۄتأ=أتههۄأڬۏأمضوأ$أتەأختثحأتڲشأحوأتځىەأإځأڬًأوۏشەأومتثهەأوۏڽأځۏطأڬشًأ؏أحًأحوأعشًشأودہأضەأځہشأدتاأڲەأ؏أحًأذعشحأختثحأشعۏأتههۄأؼىۄأىەأڬۄتأ=أتههۄأڬۏأمضوأ$أتەأؼتوشأتڲشأحوأتځىەأإځأڬًأظشلأوۏشۏأصثتىأڬەأومتثهەأوۏڽأځۏطأڬشأزًأ؏أحًأحوۄۏڽأوۏشۏأصىزڲۏأثشۏأهڲەأڲۏأ؏أتضأًمحأؼتوشأثىأغلۏهأڬەأثہحۏدەأڬًأډہۏىڬأإةۏأ؏أتضأىەأتههۄأحؼتهۏٳأڬۏأذوزأثۏتىأڬۏأۗأىثۏأتڬشوأ﷽أىەأتضأڬًأډہۏىڬأڬتأدًتثأزۏتأ=أځہشأؼتوشأثىأغلۏهأڬًأډہۏىڬأإةۏأ؏أتضأىەأتههۄأحؼتهۏٳأڬۏأذوزأثۏتىأىۄۏڽأڬۏأ؏أحًأىثۏأتڬشوأ﷽أىەأتضەأدًتثأىۄۏڽأزۏتأ؏أحًأؼتوشأىەأڬۄتأ=أإځأىەأتضأثډەأڬًأدًتثأزۏزۏتأۄەأ؏أتًشأودہەأىۄۏڽأزۏتأ؏أحًأىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أتضأىەأتههۄأحؼتهۏٳأڬۏأذوزأثۏتىأڬۏأحہۏأۗ
أ+أؼهتوۄأۄۏخوۏألشوتحەأۄۏڽأ=أ,أوۏڽأۏۄأڬۄحتأۄًڽأتضأڬەأثؼزأشتًۏأىەأځًشۏأذزۏخأسڬشأڬۏأۄەأ؏أدًأغًۏهأذزۏخأڬەأغًشأځشأؽصًۄأثةشأوؼًىۄأوۏڽأوًدًزأۄەأۗأ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأۗأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأؼثزتهوۄۏوىأثىأؼثتضأۄەأتًشأًۄأعؼۏلأۄەأۗ

[تخریج]: حدیث : 12911 - اخرجه الطبراني في """" المعجم الكبير """" (7524)"
12912,"أذعشحأذسۏلۄأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أ
أ““أدثأڬًةۏأډہۏىڬىەأًتهتأډہۏىڬەأحًأحوأتضەأدًتثأزًأ؏أرًتۄأضتحأضوىزشًڽأضەأځتشأضەأزًأ؏أدًأطرظأډہۏىڬىەأًتهەأڬًأدًتثأزۏحتأۄەأتضأضەأستحأتهدىثأڬۏأثۏوتشۏأتًشأزتڔہًڽأتًشأڬتىأڬتأزشزأشرظحأۄًأدتحتأۄەأۗ‛‛أ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأۗأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأوذوزأثىأوذظىأؼڬتطۏأۄەأتًشأًۄأوحشًڬأۄەأۗ

[تخریج]: حدیث : 12912 - اخرجه الطبراني في """"المعجم الاوسط """" (700)"
12913,"ذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=
