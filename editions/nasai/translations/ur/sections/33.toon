{"hadithnumber": "3706", "text": "نعمان بن بشیر رضی الله عنہما سے روایت ہے کہ  ان کے والد نے انہیں ایک عطیہ دیا، تو ان کی ماں نے ان کے"}
{"hadithnumber": "3707", "text": "بشیر رضی الله عنہ سے روایت ہے کہ  انہوں نے اپنے بیٹے کو ایک غلام بطور عطیہ دیا، پھر وہ نبی اکرم صلی"}
{"hadithnumber": "3708", "text": "عروہ بن زبیر سے روایت ہے کہ  بشیر رضی اللہ عنہ نے نبی اکرم صلی اللہ علیہ وسلم کے پاس آ کر کہا: اللہ"}
{"hadithnumber": "3709", "text": "نعمان بن بشیر رضی الله عنہما کہتے ہیں کہ  ان کے والد انہیں اٹھا کر نبی اکرم صلی اللہ علیہ وسلم کے پا"}
{"hadithnumber": "3710", "text": "نعمان بن بشیر رضی الله عنہما سے روایت ہے کہ  ان کے والد انہیں ساتھ لے کر نبی اکرم صلی اللہ علیہ وسلم"}
{"hadithnumber": "3711", "text": "نعمان بن بشیر رضی الله عنہما سے روایت ہے کہ  ان کی ماں رواحہ کی بیٹی نے ان کے باپ سے مال میں سے بعض"}
{"hadithnumber": "3712", "text": "نعمان رضی الله عنہ کہتے ہیں کہ  میری ماں نے میرے والد سے مطالبہ کیا کہ میرے بیٹے کو کچھ عطیہ دو، تو"}
{"hadithnumber": "3713", "text": "عامر شعبی کہتے ہیں کہ  مجھے خبر دی گئی کہ بشیر بن سعد رضی اللہ عنہ رسول اللہ صلی اللہ علیہ وسلم کے پ"}
{"hadithnumber": "3714", "text": "عبداللہ بن عتبہ بن مسعود سے روایت ہے کہ  ایک شخص نے نبی اکرم صلی اللہ علیہ وسلم کے پاس آ کر عرض کیا:"}
{"hadithnumber": "3715", "text": "نعمان بن بشیر رضی الله عنہما کہتے ہیں کہ  میرے والد مجھے لے کر نبی اکرم صلی اللہ علیہ وسلم کے پاس گئ"}
{"hadithnumber": "3716", "text": "نعمان رضی الله عنہ نے دوران خطبہ کہا کہ  میرے والد مجھے رسول اللہ صلی اللہ علیہ وسلم کے پاس لے کر گئ"}
{"hadithnumber": "3717", "text": "نعمان بن بشیر رضی الله عنہما نے خطبہ دیتے ہوئے کہا کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا ہے: ”"}
{"hadithnumber": "3718", "text": "عبداللہ بن عمرو بن عاص رضی الله عنہما کہتے ہیں کہ  جب ہوازن کا وفد رسول اللہ صلی اللہ علیہ وسلم کے پ"}
{"hadithnumber": "3719", "text": "عبداللہ بن عمرو بن عاص رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”کوئی شخص"}
