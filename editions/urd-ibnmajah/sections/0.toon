hadiths[266]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
1,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  میں تمہیں جس چیز کا حکم ",,,,,1
2,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو چیز میں نے تمہیں نہ ب",,,,,2
3,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے میری اطاعت کی اس ن",,,,,3
4,ابو جعفر کہتے ہیں کہ  عبداللہ بن عمر رضی اللہ عنہما جب رسول اللہ صلی اللہ علیہ وسلم سے کوئی حدیث سنت,,,,,4
5,ابو الدرداء رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ہمارے پاس آئے، ہم اس وقت غربت و ,,,,,5
6,"قرہ بن ایاس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  میری امت میں سے ایک گ",,,,,6
7,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  میری امت میں ایک گروہ ہم",,,,,7
8,ابوعنبہ خولانی رضی اللہ عنہ سے روایت ہے کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم کے ساتھ دونوں قبلو,,,,,8
9,"شعیب کہتے ہیں کہ  معاویہ رضی اللہ عنہ خطبہ دینے کے لیے کھڑے ہوئے اور کہا: تمہارے علماء کہاں ہیں؟ تمہ",,,,,9
10,"ثوبان رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  میری امت میں سے ایک گروہ ہم",,,,,10
11,جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  ہم نبی اکرم صلی اللہ علیہ وسلم کے پاس تھے، آپ نے ایک لکی,,,,,11
12,"مقدام بن معدیکرب کندی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  قریب ہے کہ ",,,,,12
13,"ابورافع رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  میں تم میں سے کسی کو ہرگز",,,,,13
14,"ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس شخص نے ہمار",,,,,14
15,عبداللہ بن زبیر رضی اللہ عنہما کہتے ہیں کہ  ایک انصاری نے زبیر رضی اللہ عنہ سے رسول اللہ صلی اللہ عل,,,,,15
16,"عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم اللہ کی بندیو",,,,,16
17,عبداللہ بن مغفل رضی اللہ عنہ سے روایت ہے کہ  ان کا ایک بھتیجا ان کے بغل میں بیٹھا ہوا تھا، اس نے دو ,,,,,17
18,قبیصہ سے روایت ہے کہ  عبادہ بن صامت انصاری رضی اللہ عنہ نے  ( جو کہ عقبہ کی رات میں رسول اللہ صلی ال,,,,,18
19,عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  جب میں تم سے رسول اللہ صلی اللہ علیہ وسلم کی کوئی حدیث بی,,,,,19
20,علی بن ابی طالب رضی اللہ عنہ کہتے کہ  جب میں رسول اللہ صلی اللہ علیہ وسلم سے کوئی حدیث بیان کروں تو ,,,,,20
21,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  کہ نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  میں یہ ہرگز نہ پاؤں ک",,,,,21
22,"ابوسلمہ (ابوسلمہ ابن عبدالرحمٰن بن عوف) سے روایت ہے کہ  ابوہریرہ رضی اللہ عنہ نے ایک آدمی سے کہا: م",,,,,22
23,عمرو بن میمون کہتے ہیں کہ  میں بلا ناغہ ہر جمعرات کی شام کو عبداللہ بن مسعود رضی اللہ عنہ کے پاس جات,,,,,23
24,محمد بن سیرین کہتے ہیں کہ  انس بن مالک رضی اللہ عنہ جب رسول اللہ صلی اللہ علیہ وسلم سے کوئی حدیث بیا,,,,,24
25,عبدالرحمٰن بن ابی لیلیٰ کہتے ہیں کہ  ہم نے زید بن ارقم رضی اللہ عنہ سے کہا کہ ہم سے رسول اللہ صلی ال,,,,,25
26,"عبداللہ بن ابی السفر کہتے ہیں کہ  میں نے شعبی کو کہتے سنا: میں سال بھر ابن عمر رضی اللہ عنہما کی مجل",,,,,26
27,"طاؤس کہتے ہیں کہ  میں نے عبداللہ بن عباس رضی اللہ عنہما کو کہتے سنا: ہم تو بس حدیثیں یاد کرتے تھے او",,,,,27
28,قرظہ بن کعب کہتے ہیں کہ  ہمیں عمر بن خطاب رضی اللہ عنہ نے کوفہ بھیجا، اور ہمیں رخصت کرنے کے لیے آپ ہ,,,,,28
29,سائب بن یزید کہتے ہیں کہ  میں سعد بن مالک رضی اللہ عنہ کے ساتھ مدینہ سے مکہ تک گیا، لیکن راستے بھر م,,,,,29
30,"عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس شخص نے مجھ پر",,,,,30
31,"علی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مجھ پر جھوٹ نہ باندھو، اس لیے",,,,,31
32,"انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص میرے اوپر جھوٹ",,,,,32
33,"جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے میرے اوپر جان بوجھ کر ",,,,,33
34,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص گھڑ کر میری طرف ا",,,,,34
35,"ابوقتادۃ رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو اس منبر پر فرماتے سنا:  تم",,,,,35
36,"عبداللہ بن زبیر رضی اللہ عنہما کہتے ہیں کہ  میں نے زبیر بن عوام رضی اللہ عنہ سے کہا: کیا وجہ ہے کہ م",,,,,36
37,"ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص میرے اوپر جا",,,,,37
38,"علی رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جو شخص مجھ سے کوئی حدیث یہ جان",,,,,38
39,"سمرہ بن جندب رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جو شخص مجھ سے کوئی حد",,,,,39
40,"علی رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جس شخص نے مجھ سے کوئی حدیث یہ ",,,,,40
41,"مغیرہ بن شعبہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص کوئی حدیث یہ",,,,,41
42,عرباض بن ساریہ رضی اللہ عنہ کہتے ہیں کہ  ایک روز رسول اللہ صلی اللہ علیہ وسلم ہمارے درمیان کھڑے ہوئے,,,,,42
43,عرباض بن ساریہ رضی اللہ عنہ کہتے کہ  رسول اللہ صلی اللہ علیہ وسلم نے ہمیں ایسی نصیحت فرمائی جس سے ہم,,,,,43
44,عرباض بن ساریہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ہمیں نماز فجر پڑھائی، پھر ہ,,,,,44
45,جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم جب خطبہ دیتے تو آپ کی آنکھ,,,,,45
46,"عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  بس دو ہی چیزی",,,,,46
47,"ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے یہ آیت کریمہ تلاوت کی:",,,,,47
48,"ابوامامہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  کوئی قوم ہدایت پر رہنے ک",,,,,48
49,"حذیفہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ کسی بدعتی کا روزہ، نما",,,,,49
50,"عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ کسی بدعتی ",,,,,50
51,"انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے جھوٹ بولنا چھوڑ",,,,,51
52,"عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ ت",,,,,52
53,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جسے  ( بغیر تحقیق کے )  ",,,,,53
54,"عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  علم تین طرح کا ",,,,,54
55,"معاذ بن جبل رضی اللہ عنہ کہتے ہیں کہ  جب رسول اللہ صلی اللہ علیہ وسلم نے مجھ کو یمن بھیجا تو فرمایا:",,,,,55
56,عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے س,,,,,56
57,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ایمان کے ساٹھ یا ستر سے ",,,,,57
58,عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے ایک آدمی کو اپنے بھائی کو,,,,,58
59,"عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس شخص کے دل میں",,,,,59
60,"ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب اللہ تعالیٰ مومن",,,,,60
61,جندب بن عبداللہ رضی اللہ عنہ کہتے ہیں کہ  ہم نبی اکرم صلی اللہ علیہ وسلم کے ساتھ تھے، اور ہم طاقتور ,,,,,61
62,"عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اس امت کے دو گر",,,,,62
63,عمر بن الخطاب رضی اللہ عنہ کہتے ہیں کہ  ہم نبی اکرم صلی اللہ علیہ وسلم کے پاس بیٹھے ہوئے تھے کہ اچان,,,,,63
64,ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ایک دن لوگوں میں باہر بیٹھے تھے کہ ا,,,,,64
65,"علی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ایمان دل کی معرفت، زبان سے اق",,,,,65
66,"انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  کوئی شخص مومن نہیں ہو",,,,,66
67,"انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم میں سے کوئی شخص مو",,,,,67
68,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  قسم اس ذات کی! جس کے ہات",,,,,68
69,"عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مسلمان کو گالی د",,,,,69
