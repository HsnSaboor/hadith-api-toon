{"hadithnumber": "2025", "text": "ہم سے اسماعیل بن عبداللہ نے بیان کیا، انہوں نے کہا کہ مجھ سے ابن وہب نے بیان کیا، انہوں نے کہا کہ مج"}
{"hadithnumber": "2026", "text": "ہم سے عبداللہ بن یوسف تنیسی نے بیان کیا، انہوں نے کہا کہ ہم سے لیث بن سعد نے بیان کیا، ان سے عقیل نے"}
{"hadithnumber": "2027", "text": "ہم سے اسماعیل بن ابی اویس نے بیان کیا، انہوں نے کہا کہ مجھ سے امام مالک رحمہ اللہ نے بیان کیا، ان سے"}
{"hadithnumber": "2028", "text": "ہم سے محمد بن مثنیٰ نے بیان کیا، کہا کہ ہم سے یحییٰ بن سعید قطان نے بیان کیا، ان سے ہشام بن عروہ نے"}
{"hadithnumber": "2029", "text": "ہم سے قتیبہ نے بیان کیا، کہا کہ ہم سے لیث بن سعد نے بیان کیا، ان سے ابن شہاب نے، ان سے عروہ اور عمرہ"}
{"hadithnumber": "2031", "text": "اور آپ صلی اللہ علیہ وسلم معتکف ہوتے اور میں حائضہ ہوتی۔ اس کے باوجود آپ سر مبارک  ( مسجد سے )  باہر"}
{"hadithnumber": "2032", "text": "ہم سے مسدد نے بیان کیا، کہا کہ ہم سے یحییٰ بن سعید قطان نے بیان کیا، ان سے عبیداللہ عمری نے، انہیں ن"}
{"hadithnumber": "2033", "text": "ہم سے ابوالنعمان محمد بن فضل دوسی نے بیان کیا، کہا کہ ہم سے حماد بن زید نے بیان کیا، ان سے یحییٰ قطا"}
{"hadithnumber": "2034", "text": "ہم سے عبداللہ بن یوسف نے بیان کیا، انہوں نے کہا کہ ہم کو امام مالک نے خبر دی، انہیں یحییٰ بن سعید نے"}
{"hadithnumber": "2035", "text": "ہم سے ابوالیمان نے بیان کیا، کہا کہ ہم کو شعیب نے خبر دی، ان سے زہری نے بیان کیا کہ مجھے امام زین ال"}
{"hadithnumber": "2036", "text": "مجھ سے عبداللہ بن منیر نے بیان کیا، انہوں نے ہارون بن اسماعیل سے سنا، انہوں نے کہا کہ ہم سے علی بن م"}
{"hadithnumber": "2037", "text": "ہم سے قتیبہ نے بیان کیا، کہا کہ ہم سے یزید بن زریع نے بیان کیا، ان سے خالد نے، ان سے عکرمہ نے اور ان"}
{"hadithnumber": "2038", "text": "ہم سے سعید بن عفیر نے بیان کیا، کہا کہ مجھ سے لیث نے بیان کیا، ان سے عبدالرحمٰن بن خالد نے بیان کیا،"}
{"hadithnumber": "2039", "text": "ہم سے اسماعیل بن عبداللہ نے بیان کیا، انہوں نے کہا کہ مجھے میرے بھائی نے خبر دی، انہیں سلیمان نے، ان"}
{"hadithnumber": "2040", "text": "ہم سے عبدالرحمٰن بن بشر نے بیان کیا، کہا کہ ہم سے سفیان بن عیینہ نے بیان کیا، ان سے ابن جریج نے بیان"}
{"hadithnumber": "2041", "text": "ہم سے محمد بن سلام نے بیان کیا، کہا کہ ہم کو محمد بن فضیل بن غزوان نے خبر دی، انہیں یحییٰ بن سعید نے"}
{"hadithnumber": "2042", "text": "ہم سے اسماعیل بن عبداللہ نے بیان کیا، انہوں نے اپنے بھائی (عبدالحمید) سے، ان سے سلیمان نے، ان سے عبی"}
{"hadithnumber": "2043", "text": "ہم سے عبید بن اسماعیل نے بیان کیا، کہا کہ ہم سے ابواسامہ نے بیان کیا، ان سے عبیداللہ نے، ان سے نافع"}
{"hadithnumber": "2044", "text": "ہم سے عبداللہ بن ابی شبیہ نے بیان کیا، کہا کہ ہم سے ابوبکر بن عیاش نے بیان کیا، ان سے ابوحصین عثمان"}
{"hadithnumber": "2045", "text": "ہم سے محمد بن مقاتل ابوالحسن نے بیان کیا، انہوں نے کہا کہ ہم کو عبداللہ بن مبارک نے خبر دی، انہیں او"}
{"hadithnumber": "2046", "text": "ہم سے عبداللہ بن محمد مسندی نے بیان کیا، ان سے ہشام نے بیان کیا، انہیں معمر نے خبر دی، انہیں زہری نے"}
