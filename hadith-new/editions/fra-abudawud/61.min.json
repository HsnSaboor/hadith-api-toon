{"metadata":{"name":"Sunan Abu Dawud","section":{"1":"Purification (Kitab Al-Taharah)"},"section_detail":{"1":{"hadithnumber_first":1,"hadithnumber_last":390,"arabicnumber_first":1,"arabicnumber_last":390}}},"hadiths":[{"hadithnumber":61,"arabicnumber":61,"text":"Rapporté par Ali ibn Abu Talib رضي الله عنه : « La clé de la prière, c’est la purification ; elle commence par le takbir et se termine par le salut. »","grades":[{"name":"Al-Albani","grade":"Hasan Sahih"},{"name":"Muhammad Muhyi Al-Din Abdul Hamid","grade":"Hasan Sahih"},{"name":"Zubair Ali Zai","grade":"Hasan"}],"reference":{"book":1,"hadith":61}}]}