{"metadata":{"name":"Sunan Abu Dawud","section":{"1":"Purification (Kitab Al-Taharah)"},"section_detail":{"1":{"hadithnumber_first":1,"hadithnumber_last":390,"arabicnumber_first":1,"arabicnumber_last":390}}},"hadiths":[{"hadithnumber":205,"arabicnumber":205,"text":"Rapporté par Ali ibn Talq رضي الله عنه : Le Messager d’Allah ﷺ a dit : « Lorsque l’un d’entre vous émet un vent pendant la prière, il doit s’éloigner, refaire ses ablutions et recommencer la prière. »","grades":[{"name":"Al-Albani","grade":"Daif"},{"name":"Muhammad Muhyi Al-Din Abdul Hamid","grade":"Daif"},{"name":"Shuaib Al Arnaut","grade":"Hasan Lighairihi"},{"name":"Zubair Ali Zai","grade":"Isnaad Hasan"}],"reference":{"book":1,"hadith":205}}]}