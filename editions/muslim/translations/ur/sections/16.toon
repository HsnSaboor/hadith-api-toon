{"hadithnumber": "3475", "text": "حضرت عائشہ رضی اللہ عنہا فرماتی ہیں :  میں نے رسول اللہ صلی اللہ علیہ وسلم سے اس لڑکی کے بارے میں پو"}
{"hadithnumber": "3476", "text": "سعید بن منصور اور قتیبہ بن سعید نے کہا :  ہم سے امام مالک نے حدیث بیان کی ۔  یحییٰ بن یحییٰ نے کہا :"}
{"hadithnumber": "3477", "text": "قتیبہ بن سعید نے کہا :  ہمیں سفیان نے زیاد بن سعد سے حدیث بیان کی ،  انہوں نے عبداللہ بن فضل سے روای"}
{"hadithnumber": "3478", "text": "ابن ابی عمر نے ہمیں حدیث بیان کی ،  کہا :  ہمیں سفیان نے اسی سند کے ساتھ حدیث بیان کی اور کہا :   "}
{"hadithnumber": "3479", "text": "ابو اسامہ نے ہشام سے ،  انہوں نے اپنے والد  ( عروہ )  سے ،  انہوں نے حضرت عائشہ رضی اللہ عنہا سے روا"}
{"hadithnumber": "3480", "text": "ابو معاویہ اور عبدہ بن سلیمان نے ہشام سے  انھوں نے  اپنے والد  ( عروہ  )  سے انہوں نے حضرت عائشہ  رض"}
{"hadithnumber": "3481", "text": "زہری نے عروہ سے ،  انہوں نے حضرت عائشہ رضی اللہ عنہا سے روایت کی کہ نبی کریم صلی اللہ علیہ وسلم نے ا"}
{"hadithnumber": "3482", "text": "اسود نے حضرت عائشہ رضی اللہ عنہا سے روایت کی ،  انہوں نے کہا :  رسول اللہ صلی اللہ علیہ وسلم نے ان س"}
{"hadithnumber": "3483", "text": "وکیع نے ہمیں حدیث بیان کی ،  کہا :  ہمیں سفیان نے اسماعیل بن امیہ سے حدیث بیان کی ،  انہوں نے عبدالل"}
{"hadithnumber": "3484", "text": "عبداللہ بن نمیر نے کہا :  ہمیں سفیان نے اسی سند کے ساتھ  ( یہ )  حدیث بیان کی اور انہوں نے حضرت عائش"}
{"hadithnumber": "3485", "text": "سفیان نے ہمیں یزید بن کیسان سے حدیث بیان کی ،  انہوں نے ابوحازم سے ،  انہوں نے حضرت ابوہریرہ رضی الل"}
{"hadithnumber": "3486", "text": "مروان بن معاویہ فزاری نے حدیث بیان کی ،  کہا :  ہمیں یزید بن کیسان نے ابوحازم سے حدیث بیان کی ،  انہ"}
{"hadithnumber": "3487", "text": "یعقوب بن عبدالرحمٰن القاری اور عبدالعزیز بن ابی حازم نے ابوحازم سے ،  انہوں نے حضرت سہل بن سعد ساعدی"}
{"hadithnumber": "3488", "text": "حماد بن زید ،  سفیان بن عیینہ ،  دراوردی اور زائدہ سب نے ابوحازم سے ،  انہوں نے سہل بن سعد رضی اللہ"}
{"hadithnumber": "3489", "text": "ابوسلمہ بن عبدالرحمٰن سے روایت ہے ،  انہوں نے کہا :  میں نے رسول اللہ صلی اللہ علیہ وسلم کی اہلیہ ،"}
{"hadithnumber": "3490", "text": "ثابت نے حضرت انس بن مالک رضی اللہ  عنہ سے روایت کی کہ نبی اکرم صلی اللہ علیہ وسلم نے حضرت عبدالرحمٰن"}
{"hadithnumber": "3491", "text": "ابو عوانہ نے ہمیں قتادہ سے حدیث بیان کی ،  انہوں نے انس بن مالک رضی اللہ عنہ سے روایت کی کہ رسول الل"}
{"hadithnumber": "3492", "text": "وکیع نے ہمیں خبر دی ،  کہا :  ہمیں شعبہ نے قتادہ اور حُمید سے حدیث بیان کی ،  انہوں نے حضرت انس رضی"}
{"hadithnumber": "3493", "text": "ابوداود ،  وہب بن جریر اور شبابہ سب نے شعبہ سے حدیث بیان کی ،  انہوں نے حمید سے اسی سند کے ساتھ روای"}
{"hadithnumber": "3494", "text": "اسحاق بن ابراہیم اور محمد بن قدامہ نے کہا :  ہمیں نضر بن شُمَیل نے خبر دی ،  کہا :  ہمیں شعبہ نے حدی"}
{"hadithnumber": "3495", "text": "ابوداود نے ہمیں حدیث بیان کی ،  کہا :  ہمیں شعبہ نے ابوحمزہ سے حدیث بیان کی ۔  شعبہ نے کہا :  ان کا"}
{"hadithnumber": "3496", "text": "وہب نے کہا :  ہمیں شعبہ نے اسی سند کے ساتھ یہ حدیث بیان کی ،  مگر انہوں نے کہا :  حضرت عبدالرحم ن بن"}
{"hadithnumber": "3497", "text": "حضرت انسؓ سے روایت ہے کہ رسول اﷲ ﷺ نے جہاد کیا خیبر پر او رہم لوگوں نے وہاں نماز پڑھی صبح کی بہت اند"}
{"hadithnumber": "3498", "text": "حماد ،  یعنی ابن زید نے ثابت اور عبدالعزیز بن صہیب سے ،  انہوں نے حضرت انس رضی اللہ عنہ سے ۔  حماد ن"}
{"hadithnumber": "3500", "text": "حماد بن سلمہ نے ہمیں حدیث بیان کی ،  کہا :  ثابت نے ہمیں حضرت انس رضی اللہ عنہ سے حدیث سنائی ،  انہو"}
{"hadithnumber": "3501", "text": "سلیمان بن مغیرہ نے ہمیں ثابت سے حدیث بیان کی کہا :  حضرت انس رضی اللہ عنہ نے ہمیں حدیث بیان کی ،  ان"}
{"hadithnumber": "3502", "text": "محمد بن حاتم بن میمون نے مجھے حدیث بیان کی ،  کہا :  ہمیں بہز نے حدیث سنائی ،  نیز محمد بن رافع نے م"}
{"hadithnumber": "3503", "text": "ابوربیع زہرانی ،  ابو کامل فُضَیل بن حسین اور قتیبہ بن سعید نے ہمیں حدیث بیان کی ،  کہا :  ہمیں حماد"}
{"hadithnumber": "3504", "text": "عبدالعزیز بن صہیب سے روایت ہے ،  انہوں نے کہا :  میں نے حضرت انس رضی اللہ عنہ سے سنا وہ کہہ رہے تھے"}
{"hadithnumber": "3505", "text": "یحییٰ بن حبیب حارثی ،  عاصم بن نضر تیمی اور محمد بن عبدالاعلیٰ نے ہمیں حدیث بیان کی ،  سب نے معتمر س"}
{"hadithnumber": "3506", "text": "ابن شہاب نے کہا :   حضرت انس بن مالک رضی اللہ عنہ نے فرمایا :  پردے  ( کے احکام )  کو سب لوگوں سے زی"}
{"hadithnumber": "3507", "text": "جعفر بن سلیمان نے ہمیں ابوعثمان جعد سے حدیث بیان کی ،  انہوں نے حضرت انس بن مالک رضی اللہ عنہ سے روا"}
{"hadithnumber": "3508", "text": "معمر نے ہمیں ابوعثمان  ( جعد )  سے حدیث بیان کی ،  انہوں نے حضرت انس رضی اللہ عنہ سے روایت کی ،  انہ"}
{"hadithnumber": "3509", "text": "امام مالک نے نافع سے ،  انہوں نے حضرت ابن عمر رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  رسول اللہ"}
{"hadithnumber": "3510", "text": "خالد بن حارث نے ہمیں عبیداللہ  ( بن عمر بن حفص مدنی )  سے حدیث بیان کی ،  انہوں نے نافع سے ،  انہوں"}
{"hadithnumber": "3511", "text": "محمد بن عبداللہ بن نمیر کے والد نے کہا :  ہمیں عبیداللہ نے نافع سے حدیث بیان کی ،  انہوں نے حضرت ابن"}
{"hadithnumber": "3512", "text": "حماد نے ہمیں ایوب سے حدیث بیان کی ،  انہوں نے نافع سے ،  انہوں نے حضرت ابن عمر رضی اللہ عنہ سے روایت"}
{"hadithnumber": "3513", "text": "معمر نے ہمیں ایوب سے خبر دی ،  انہوں نے نافع سے روایت کی کہ حضرت ابن عمر رضی اللہ عنہ نبی صلی اللہ ع"}
{"hadithnumber": "3514", "text": "زُبیدی نے ہمیں نافع سے حدیث بیان کی ،  انہوں نے ابن عمر رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :"}
{"hadithnumber": "3515", "text": "اسماعیل بن اُمیہ نے ہمیں نافع سے حدیث بیان کی ،  انہوں نے عبداللہ بن عمر رضی اللہ عنہ سے روایت کی ،"}
{"hadithnumber": "3516", "text": "موسیٰ بن عقبہ نے نافع سے خبر دی ،  انہوں نے کہا :  میں نے عبداللہ بن عمر رضی اللہ عنہ سے سنا ،  وہ ک"}
{"hadithnumber": "3517", "text": "عمر بن محمد نے مجھے نافع سے حدیث بیان کی ،  انہوں نے حضرت ابن عمر رضی اللہ عنہ سے روایت کی کہ نبی صل"}
{"hadithnumber": "3518", "text": "محمد بن مثنیٰ نے ہمیں حدیث بیان کی ،  کہا :  ہمیں عبدالرحمٰن بن مہدی نے حدیث سنائی ،  نیز ہمیں محمد"}
{"hadithnumber": "3519", "text": "ابن جُریج نے ابوزبیر سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی"}
{"hadithnumber": "3520", "text": "ابن سیرین نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  رسول اللہ صلی اللہ علیہ وسلم"}
{"hadithnumber": "3521", "text": "امام مالک نے ابن شہاب سے ،  انہوں نے اعرج سے اور انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،"}
{"hadithnumber": "3522", "text": "سفیان  ( بن عیینہ )  نے ہمیں حدیث بیان کی ،  کہا :  میں نے امام زہری سے پوچھا :  جنابِ ابوبکر! یہ حد"}
{"hadithnumber": "3523", "text": "معمر نے زہری سے خبر دی ،  انہوں نے سعید بن مسیب سے اور اعرج سے ،  اور انہوں نے حضرت ابوہریرہ رضی الل"}
{"hadithnumber": "3524", "text": "ابوزناد نے اعرج سے ،  انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے اسی کے مانند حدیث روایت کی"}
{"hadithnumber": "3526", "text": "سفیان نے ہمیں زہری سے حدیث بیان کی ،  انہوں نے عروہ سے اور انہوں نے حضرت عائشہ رضی اللہ عنہا سے روای"}
{"hadithnumber": "3527", "text": "یونس نے ابن شہاب سے خبر دی ،  کہا :  مجھے عروہ بن زبیر نے حدیث بیان کی کہ نبی صلی اللہ علیہ وسلم کی"}
{"hadithnumber": "3528", "text": "معمر نے ہمیں زہری سے خبر دی ،  انہوں نے عروہ سے اور انہوں نے حضرت عائشہ رضی اللہ عنہا سے روایت کی کہ"}
{"hadithnumber": "3529", "text": "ابواسامہ نے ہمیں ہشام سے حدیث بیان کی ،  انہوں نے اپنے والد  ( عروہ بن زبیر )  سے اور انہوں نے حضرت"}
{"hadithnumber": "3530", "text": "ابن فُضَیل اور ابومعاویہ نے ہشام سے اسی سند کے ساتھ  ( یہی )  حدیث بیان کی"}
{"hadithnumber": "3531", "text": "علی بن مسہر نے عبیداللہ بن عمر  ( بن حفص عمری )  سے حدیث بیان کی ،  انہوں نے قاسم بن محمد سے ،  انہو"}
{"hadithnumber": "3532", "text": "عبداللہ بن نمیر اور یحییٰ بن سعید نے عبیداللہ سے اسی سند کے ساتھ اسی کے مانند روایت کی ،  اور عبیدال"}
{"hadithnumber": "3533", "text": "شعبہ نے ہمیں حدیث بیان کی ،  نیز ابن نمیر اور عبدالرزاق نے ثوری سے  ( اور ثوری اور شعبہ )  دونوں نے"}
{"hadithnumber": "3534", "text": "مضمون ‌وہی ‌ہے ‌مگر ‌شعبہ ‌كی ‌روایت ‌میں ‌بسم ‌اللہ ‌كا ‌لفظ ‌نہیں ‌اور ‌عبد ‌الرزاق ‌كی ‌روایت ‌می"}
{"hadithnumber": "3535", "text": "سفیان نے ہمیں ابن منکدر سے حدیث بیان کی ،  انہوں نے حضرت جابر رضی اللہ عنہ سے سنا وہ کہہ رہے تھے ،"}
{"hadithnumber": "3536", "text": "ابوحازم نے محمد بن منکدر سے ،  انہوں نے جابر بن عبداللہ رضی اللہ عنہ سے روایت کی کہ یہود کہا کرتے تھ"}
{"hadithnumber": "3537", "text": "قتیبہ بن سعید نے کہا :  ہمیں ابوعوانہ نے حدیث بیان کی ۔  عبدالوارث بن عبدالصمد نے کہا :  مجھے میرے و"}
{"hadithnumber": "3538", "text": "محمد بن جعفر نے ہمیں حدیث بیان کی ،  کہا :  ہمیں شعبہ نے حدیث بیان کی ،  کہا :  میں نے قتادہ سے سنا"}
{"hadithnumber": "3539", "text": "خالد بن حارث نے کہا :  ہمیں شعبہ نے اسی سند کے ساتھ یہی حدیث بیان کی ،  اور کہا :   \" یہاں تک کہ وہ"}
{"hadithnumber": "3540", "text": "یزید بن کیسان نے ابوحازم سے اور انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  کہا :  اللہ کے رس"}
{"hadithnumber": "3541", "text": "اعمش نے ابوحازم سے اور انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  رسول اللہ"}
{"hadithnumber": "3542", "text": "مروان بن معاویہ نے عمر بن حمزہ عمری سے حدیث بیان کی ،  کہا :  ہمیں عبدالرحمٰن بن سعد نے حدیث بیان کی"}
{"hadithnumber": "3543", "text": "محمد بن عبیداللہ بن نمیر اور ابوکریب نے کہا :  ہمیں ابواسامہ نے عمر بن حمزہ سے حدیث بیان کی ،  انہوں"}
{"hadithnumber": "3544", "text": "ربیعہ نے محمد بن یحییٰ بن حبان سے خبر دی ،  انہوں نے ابن مُحَریز سے روایت کی ،  انہوں نے کہا :  میں"}
{"hadithnumber": "3545", "text": "موسیٰ بن عقبہ نے محمد بن یحییٰ بن حبان سے اسی سند کے ساتھ ربیعہ کی حدیث کے ہم معنی حدیث بیان کی ،  م"}
{"hadithnumber": "3546", "text": "زہری نے ابن محریز سے اور انہوں نے ابوسعید خدری رضی اللہ عنہ سے روایت کی ،  انہوں نے ان  ( ابن محریز"}
{"hadithnumber": "3547", "text": "بشر بن مفضل نے کہا :  ہمیں شعبہ نے انس بن سیرین سے حدیث بیان کی ،  انہوں نے معبد بن سیرین سے ،  انہو"}
{"hadithnumber": "3548", "text": "محمد بن جعفر ،  خالد بن حارث ،  عبدالرحمٰن بن مہدی اور بہز ،  سب نے کہا :  ہمیں شعبہ نے انس بن سیرین"}
{"hadithnumber": "3549", "text": "ایوب نے ہمیں محمد  ( بن سیرین )  سے حدیث بیان کی ،  انہوں نے عبدالرحمٰن بن بشر بن مسعود سے روایت کی"}
{"hadithnumber": "3550", "text": "معاذ بن معاذ نے ہمیں حدیث بیان کی ،  کہا :  ہمیں ابن عون نے محمد  ( بن سیرین )  سے حدیث بیان کی ،  ا"}
{"hadithnumber": "3551", "text": "حماد بن زید نے ابن عون سے حدیث بیان کی ،  کہا :  میں نے حماد  ( بن سیرین )  کو ابراہیم کے واسطے سے ع"}
{"hadithnumber": "3552", "text": "ہشام نے ہمیں محمد  ( بن سیرین )  سے حدیث بیان کی ،  انہوں نے معبد بن سیرین سے روایت کی ،  کہا :  ہم"}
{"hadithnumber": "3553", "text": "قزعہ نے حضرت ابوسعید خدری رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  رسول اللہ صلی اللہ علیہ وسلم ک"}
{"hadithnumber": "3554", "text": "عبداللہ بن وہب نے ہمیں حدیث بیان کی ،  کہا :  مجھے معاویہ بن صالح نے علی بن ابو طلحہ سے خبر دی ،  ان"}
{"hadithnumber": "3555", "text": "ابوزبیر نے ہمیں حضرت جابر رضی اللہ عنہ سے خبر دی کہ ایک آدمی رسول اللہ صلی اللہ علیہ وسلم کے پاس آیا"}
{"hadithnumber": "3556", "text": "سفیان بن عیینہ نے ہمیں سعید بن حسان سے حدیث بیان کی ،  انہوں نے عروہ بن عیاض سے اور انہوں نے حضرت جا"}
{"hadithnumber": "3557", "text": "سفیان بن عیینہ نے ہمیں سعید بن حسان سے حدیث بیان کی ،  انہوں نے عروہ بن عیاض سے اور انہوں نے حضرت جا"}
{"hadithnumber": "3558", "text": "ابو احمد زبیری نے ہمیں حدیث بیان کی ،  کہا :  ہمیں مکہ کے قصہ گو سعید بن حسان نے حدیث بیان کی ،  کہا"}
{"hadithnumber": "3559", "text": "ہمیں ابوبکر بن ابی شیبہ اور اسحاق بن ابراہیم نے حدیث بیان کی ،   ( انہوں نے کہا )  ہمیں سفیان نے عمر"}
{"hadithnumber": "3560", "text": "معقل نے ہمیں عطاء سے حدیث بیان کی ،  انہوں نے کہا :  میں نے جابر رضی اللہ عنہ سے سنا ،  وہ کہہ رہے ت"}
{"hadithnumber": "3561", "text": "ابوزبیر نے حضرت جابر رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  ہم رسول اللہ صلی اللہ علیہ وسلم کے"}
{"hadithnumber": "3562", "text": "محمد بن جعفر نے ہمیں حدیث بیان کی ،  کہا :  ہمیں شعبہ نے یزید بن خُمَیر سے حدیث بیان کی ،  انہوں نے"}
{"hadithnumber": "3563", "text": "یزید بن ہارون اور ابوداؤد نے شعبہ سے اسی سند کے ساتھ یہ حدیث بیان کی"}
{"hadithnumber": "3564", "text": "جدامہ نے رسول اﷲ ﷺ سے سُنا کہ فرماتے تھے میں نے چاہا کہ غیلہ سے منع کردوں پھر مجھے یاد آیا کہ روم او"}
{"hadithnumber": "3565", "text": "عبیداللہ بن سعید اور محمد بن ابی عمر نے ہمیں حدیث بیان کی ،  ان دونوں نے کہا :  ہمیں مُقری نے حدیث ب"}
{"hadithnumber": "3566", "text": "یحییٰ بن ایوب نے ہمیں محمد بن عبدالرحمٰن بن نوفل قرشی سے حدیث بیان کی ،  انہوں نے عروہ سے ،  انہوں ن"}
{"hadithnumber": "3567", "text": "محمد بن عبداللہ بن نمیر اور زہیر بن حرب نے  ۔  ۔  الفاظ ابن نمیر کے ہیں  ۔  ۔  حدیث بیان کی ،  دونوں"}
