{"hadithnumber": "1404", "text": "حضرت جابر بن سمرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ نبی اکرم ﷺ ظہر کی نماز اس وقت پڑھتے تھے جب سو"}
{"hadithnumber": "1405", "text": "ابو احوص سلام بن سلیم نے ہمیں حدیث سنائی  ،  انھوں نے ابو اسحاق سے  ،  انھوں نے سعید بن وہب سے اور ا"}
{"hadithnumber": "1406", "text": ") زہیر نے کہا  :  ہمیں ابو اسحاق نے سعید بن وہب  سے حدیث سنائی اور انھوں نے حضرت خباب  ‌رضی ‌اللہ ‌ع"}
{"hadithnumber": "1407", "text": "حضرت انس بن مالک  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ ہم گرمی کی شدت میں رسول اللہ ﷺ کے ساتھ نماز پڑ"}
{"hadithnumber": "1408", "text": "قتیبہ بن سعید اور محمد بن رمح نے کہا  :  لیث نے ہمیں ابن شہاب سے  روایت کی  ،  انھوں نے حضرت انس بن"}
{"hadithnumber": "1409", "text": "عمرو نے ابن شہاب سے ،  انھوں نے حضرت انس بن مالک  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ رسول اللہ ﷺ عص"}
{"hadithnumber": "1410", "text": "امام مالک نے ابن شہاب سے  ،  انھوں نے حضرت انس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ ہم عصر کی نماز پ"}
{"hadithnumber": "1411", "text": "اسحاق بن عبداللہ بن ابی طلحہ نے حضرت اسن بن مالک  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ  ،  کہا ہم عصر"}
{"hadithnumber": "1412", "text": "علاء بن عبدالرحمان سے روایت ہے کہ وہ نماز ظہر سے فارغ ہو کر حضرت انس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  کے ہاں بص"}
{"hadithnumber": "1413", "text": "حضرت ابو اامامہ بن سہل  ‌رضی ‌اللہ ‌عنہ ‌ ‌ بیان کرتے ہیں  :  ہم نے عمر بن عبدالعزیز  رحمۃ اللہ علیہ"}
{"hadithnumber": "1414", "text": "عمرو بن سواد عامری  ،  محمد بن سلمہ مرادی اور احم د بن عیسیٰ نےہمیں حدیث بیان کی  ۔  اس سب کے الفاظ"}
{"hadithnumber": "1415", "text": "ہمیں ولید بن مسلم نےحدیث سنائی  ،  کہا  : اوزاعی نےہمیں حدیث بیان کی  ،  انھوں نے ابو نجاشی سے روایت"}
{"hadithnumber": "1416", "text": "اسحاق بن ابراہیم  نے کہا  : ہمیں عیسیٰ بن یونس اور شعیب بن اسحاق دمشقی نے خبر دی  ،  ان دونوں نے کہا"}
{"hadithnumber": "1417", "text": "نافع نے حضرت ابن عمر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ کہ رسول اللہ ﷺ نے فرمایا  :  ’’جس شخص کی ن"}
{"hadithnumber": "1418", "text": "ابو بکر بن ابی شبیہ اور عمرو الناقد نے کہا  :  ہمیں سفیان نے زہر سے  ،  انھوں نے سالم  سے اور انھوں"}
{"hadithnumber": "1419", "text": "عمرو بن حارث نے ابن شہاب سے  ،  انھوں نے سالم بن عبداللہ سے اور انھوں نے اپنے والد سے روایت کی کہ رس"}
{"hadithnumber": "1420", "text": "ابوسامہ نے ہمیں حدیث سنائی  ،  انھوں نے ہشام سے  ،  انھوں نے محمد سے  انھوں نے عبیدہ سے اور انھوں نے"}
{"hadithnumber": "1421", "text": "یحیی بن  سعید نے اور معتمر  بن سلیمان نے ہشام سے یہ حدیث  ( باقی ماندہ  ) اسی سند کے ساتھ روایت کی"}
{"hadithnumber": "1422", "text": "شعبہ نے کہے  :  ہمیں قتادہ سے سنا ،  وہ ابو حسان سے حدیث بیان کررہےتھے  ،  انھوں نے عبیدہ سے اور انھ"}
{"hadithnumber": "1423", "text": "سعید  نے قتادہ سے اسی سند کے ساتھ مذکورہ بالا روایت بیان کی اور انھوں نے بغیر شک کے  بیوتہم  و قبورہ"}
{"hadithnumber": "1424", "text": "یحییٰ بن جزار نے حضرت علی  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  کہا  :  رسول اللہ ﷺ نے غزوہ احزاب کے"}
{"hadithnumber": "1425", "text": "شتیر بن شکل نےحضرت علی  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سےروایت کی  ،  کہا  : رسول اللہ ﷺ نےاحزاب کے دن فرمایا"}
{"hadithnumber": "1426", "text": "حضرت عبداللہ  ( بن مسعود  )  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے  ،  انھوں نے کہا  :  مشرکوں نے  ( جنگ"}
{"hadithnumber": "1427", "text": "حضرت عائشہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  کے آزاد کردہ غلام ابو یونس سے روایت ہے  ،  کہا حضرت عائشہ رضی اللہ"}
{"hadithnumber": "1430", "text": "معاذ بن ہشام نے حدیث بیان کی  ،  کہا  : ہمیں میرے والد نے یحییٰ بن ابی کثیر سے حدیث سنائی  ،  انھوں"}
{"hadithnumber": "1431", "text": "علی بن مبارک نے یحییٰ بن ابی کثیر سے اسی سند کے ساتھ اسی کی مانند حدیث بیان کی"}
{"hadithnumber": "1432", "text": "ابو زناد نے اعراج سے  ،  انھوں نے حضرت  ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ رسول اللہ ﷺ ن"}
{"hadithnumber": "1433", "text": "ہمام بن منبہ نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے اور انھوں نے نبی اکرمﷺ سے روایت کی  ،  آپ نے"}
{"hadithnumber": "1434", "text": "زہیر بن حرب نے کہا  :  ہمیں مروان بن معاویہ فزاری نے حدیث سنائی  ، انھوں کہا  :  ہمیں اسماعیل بن  اب"}
{"hadithnumber": "1435", "text": "ابو بکر بن ابی شیبہ نےعبداللہ بن نمیر  ،  ابو اسامہ اور وکیع سے باقی ماندہ اسی سند کے ساتھ روایت کی"}
{"hadithnumber": "1436", "text": "( اسماعیل  ) ابن ابی خالد ،  مسعر اور بختری بن مختار نےیہ روایت ابو بکر بن عمارہ بن رویبہ سے سنی  ،"}
{"hadithnumber": "1437", "text": "عبدالملک بن عمیر نے حضرت عمارۃ بن رویبہ کے بیٹے سے اور انھوں نے اپنے والد سے روایت کی  ،  کہا  :  رس"}
{"hadithnumber": "1438", "text": "ہدّاب بن خالد ازدی نے کہا  :  ہمیں ہمام بن یحییٰ نے حدیث سنائی  ،  کہا  :  مجھے ابو جمرہ ضبعی نے ابو"}
{"hadithnumber": "1439", "text": "بشر بن سریّ اور عمر و بن عاصم دونوں نے کہا  :  ہم سے ہمام نے اسی سند کے ساتھ حدیث بیان کی اور انھوں"}
{"hadithnumber": "1440", "text": "حضرت سلمہ بن اکوع  ‌رضی ‌اللہ ‌عنہ ‌ ‌ سے روایت ہے کہ رسول اللہﷺ مغرب کی نماز اس وقت پڑھتے جب سورج"}
{"hadithnumber": "1441", "text": "ولید بن مسلم نے کہا  :  ہم سے اوزاعی نے حدیث بیان کی ،  کہا  :  ہم سے ابو نجاشی نے حدیث بیان کی  ،"}
{"hadithnumber": "1442", "text": "شعیب بن اسحاق دمشقی نے اوزاعی سے سابقہ سند کےساتھ رافع بن خدیج  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سےحدیث بیان کی"}
{"hadithnumber": "1443", "text": "عمرو بن سوّاد عامری اور حرملہ بن یحییٰ دونوں نے کہا  :  ہمیں ابن وہب نے خبر دی  ،  انھوں نے کہا  :"}
{"hadithnumber": "1444", "text": "عقیل نے ابن شہاب سے اسی سنج کے ساتھ مذکورہ بالا روایت بیان کی لیکن اس میں زہر ی کا قول  :  وذکرلی  ("}
{"hadithnumber": "1445", "text": "محمد بن بکر  ،  حجاج بن محمد اور عبدالرزاق  ۔  سب کے الفاظ باہم ملتے جلتے ہیں  ۔  سب نے کہا  :  ابن"}
{"hadithnumber": "1446", "text": "حکم نےنافع سے اور انھوں نے حضرت عبداللہ بن عمر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ ایک رات ہم عشاء"}
{"hadithnumber": "1447", "text": "ہمیں ابن جریج نے خبر دی  ،  کہا  :  مجھے نافع نے خبر دی  ،  انھوں نے کہا  :  ہم سے حضرت عبد اللہ بن"}
{"hadithnumber": "1448", "text": "ثابت سے روایت ہےکہ انھوں نے حضرت انس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے رسول اللہ ﷺ یک مہر  ( یا انگوٹھی  )  ک"}
{"hadithnumber": "1449", "text": "ابوزید سعید بن ربیع نے ہمیں حدیث بیان کی  ،  کہا  :  ہمیں قرہ بن خالد نے قتادہ سےحدیث سنائی  ،  انھو"}
{"hadithnumber": "1450", "text": "عبیداللہ بن عبدالمجید حنفی نے قرہ سے اسی سند کے ساتھ  ( یہی ) حدیث بیان کی اور یہ بیان نہ کیا  :  ’’"}
{"hadithnumber": "1451", "text": "حضرت ابو موسیٰ اشعری  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے  ،  انھوں نے کہا  :  میں اور میرے  ( وہ ) سات"}
{"hadithnumber": "1452", "text": "ابن جریج نے ہمیں خبر دی  ،  کہا  :  میں نے عطاء سے پوچھا  :  آپ کے نزدیک  کون سی گھڑی زیادہ پسندیدہ"}
{"hadithnumber": "1453", "text": "ابواحوص نے سماک سے  ،  انھوں نے حضرت جابر بن سمرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ  ،  کہا  :  ر"}
{"hadithnumber": "1454", "text": "قتیبہ بن سعید اور ابو کامل جحدری نے کہا  :  ہمیں ابو عوانہ نے سماک سے حدیث سنائی  ،  انھوں نے حضرت ج"}
{"hadithnumber": "1455", "text": "زہیر نے کہا : ہم سے سفیان بن عینہ نے ابو لبید سے  ،  انھوں نے ابو سلمہ سے اورانھوں نے حضرت  عبداللہ"}
{"hadithnumber": "1456", "text": "وکیع نے سفیان سے باقی ماندہ سابقہ سند کے ساتھ حضرت ابن عمر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  کہا"}
{"hadithnumber": "1457", "text": "سفیان بین عیینہ  نے زہری سے  ،  انھوں نے  عروہ سےاور انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عنہا سے روا"}
{"hadithnumber": "1458", "text": "یونس نے ابن شہاب سے باقی ماندہ سابقہ سند کے ساتھ نبی اکرم ﷺ کی زوجہ حضرت عائشہ رضی اللہ تعالیٰ عنہا"}
{"hadithnumber": "1459", "text": "نصر بن علی جہضمی اور اسحاق بن موسیٰ انصاری نے کہا  :  ہمیں معن نے مالک سے حدیث بیان کی  ،  انھوں نے"}
{"hadithnumber": "1460", "text": "محمد بن جعفر غندر نے ہمیں حدیث بیان کی  ،  کہا  :  ہمیں شعبہ نے حدیث سنائی  ،  انھوں نے سعد بن ابراہ"}
{"hadithnumber": "1461", "text": "معاذ عنبری نے شعبہ سے باقی ماندہ اسی سند کے ساتھ روایت کی کہ  حجاج نمازوں میں تاخیر کر دیتا تھا تو ہ"}
{"hadithnumber": "1462", "text": "خالد بن حارث نے ہمیں حدیث سنائی  ،  کہا  :  شعبہ نے ہمیں حدیث بیان کی  ،  کہا  :  مجھے سیار بن سلامہ"}
{"hadithnumber": "1463", "text": "معاذ عنبری نے شعبہ سے حدیث بیان کی اور انھوں نے سیار بن سلامہ سے روایت کی کہ میں نے ابو برزہ کو کہتے"}
{"hadithnumber": "1464", "text": "( شعبہ کے بجائے  ) حماد بن سلمہ نے ابو منہال  ( سیار بن سلامہ  ) سے روایت کی  ،  کہا  :  میں نے ابو"}
{"hadithnumber": "1465", "text": "خلف بن ہشام  ،  ابوربیع زہرانی اور ابو کامل جحدری نے حدیث بیان کی کی  ،  کہا ہمیں حماد بن زید نے حدی"}
{"hadithnumber": "1466", "text": "جعفر بن سلیمان نے ابو عمران جونس سے اسی سند کے ساتھ حضرت ابو ذر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،"}
{"hadithnumber": "1467", "text": "شعبہ نے ابو عمران سے باقی ماندہ سابقہ سند کے ساتھ حضرت ابو ذر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،"}
{"hadithnumber": "1468", "text": "بدیل سے روایت ہے  ،  انھوں نے کہا  :  میں نے ابو عالیہ سے سنا  ،  وہ عبداللہ بن صامت سے اور وہ حضرت"}
{"hadithnumber": "1469", "text": "ایوب نے ابو عالیہ برّاء  سے روایت کی  ،  کہا  :  ابن زیاد نے نماز میں تاخیر کر دی تو میرے پاس عبدالل"}
{"hadithnumber": "1470", "text": "ابو نعامہ نے عبداللہ بن صامت سےاور انھوں نے حضرت ابو ذر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  کہا  :"}
{"hadithnumber": "1471", "text": "مطر نے ابو عالیہ بّراء سے روایت  کی  ،  کہا  :  میں نے عبداللہ بن صامت سے پوچھا کہ ہم جمعہ کے دن حکم"}
{"hadithnumber": "1472", "text": "مالک نےابن شہاب  ( زہری  ) سے  ،  انھوں نے  سعید بن مسیب سے اور انھوں نے حضرت ابو ہریرہ  ‌رضی ‌اللہ"}
{"hadithnumber": "1473", "text": "عبدالاعلی نے معمر سے  ،  انھوں نے زہری سے  ،  اسی سند کے ساتھ حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  س"}
{"hadithnumber": "1474", "text": "شعیب نے زہری  سے روایت کی  ،  کہا  :  مجھے سعیداور ابو سلمہ نے خبر دی کہ حضرت ابو ہریرہ  ‌رضی ‌اللہ"}
{"hadithnumber": "1475", "text": "سلمان اغر نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  کہا  :  رسول اللہ ﷺ نے فرمایا  :"}
{"hadithnumber": "1476", "text": "عمر بن عطاء بن ابی خوار نے خبر دی کہ میں نے نافع بن جبیر بن مطعم کے پاس بیٹھا ہوا تھا کہ اس اثنا میں"}
{"hadithnumber": "1477", "text": "مالک نے نافع سے اورانھوں نے حضرت ابن عمر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ رسول اللہ ﷺنے فرمایا"}
{"hadithnumber": "1478", "text": "یحییٰ نے عبید اللہ سے حدیث بیان کی  ،  کہا  : مجھے نافع نے حضرت ابن عمر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے خبر"}
{"hadithnumber": "1479", "text": "ابو بکر بن ابی شیبہ نےہمیں حدیث سنائی  ،  کہا  :  ہمیں ابو اسامہ اور  ( محمد بن عبداللہ  ) ابن نمیر"}
{"hadithnumber": "1480", "text": "ضحاک نے نافع سے  ،  انھوں نے ابن عمر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے اور انھوں نے نبی اکرم ﷺ سے روایت کی  ،"}
{"hadithnumber": "1481", "text": "اعرج نےحضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ رسول اللہ ﷺنے کچھ لوگوں کو ایک نماز میں غ"}
{"hadithnumber": "1482", "text": "ابو صالح نےحضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  کہا  :  رسول اللہ ﷺ نے فرمایا  :  ’’"}
{"hadithnumber": "1483", "text": "ہمام بن منبہ سے روایت ہے  ،  کہا  :  یہ احادیث ہیں جو ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نےہمیں رسول ال"}
{"hadithnumber": "1484", "text": "یزید بن اصم نے ابو ہریرہ ﷺ سے اور انھوں نے نبی اکرم ﷺ سے اسی کی طرح حدیث روایت کی ہے"}
{"hadithnumber": "1485", "text": "حضرت عبداللہ بن مسعود ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ نبی ﷺ نے ان لوگوں سے جو جمعے سے پیچھے رہ ج"}
{"hadithnumber": "1486", "text": "حضرت ابوہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌ سے روایت ہے  ،  انھوں نے کہا  :  نبی اکرم ﷺ کی خدمت میں اکی نابین"}
{"hadithnumber": "1487", "text": "عبد الملک بن عمیر نے ابو احوص سے روایت کی  ،  کہا  :  حضرت عبداللہ  ( بن مسعود  ‌رضی ‌اللہ ‌عنہ ‌ ‌"}
{"hadithnumber": "1488", "text": "علی بن اقمر نے ابو احوص سے اور انھوں نے حضرت عبداللہ  ( بن مسعود  ‌رضی ‌اللہ ‌عنہ ‌ ‌  )  سے روایت ک"}
{"hadithnumber": "1489", "text": "ابراہیم بن مہاجر نے ابو شعثاء سے روایت کی  ،  کہا  :  ہم مسجد میں حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌"}
{"hadithnumber": "1490", "text": "اشعث بن ابی شعثاء محاربی نے اپنے والد سے روایت کی  ،  کہا  :  میں نے حضرت ابوہریرہ  ‌رضی ‌اللہ ‌عنہ"}
{"hadithnumber": "1491", "text": "عبدالواحد بن زیاد نے ہمیں حدیث سنائی  ،  کہا  :  ہم سے عثمان بن حکیم نے حدیث بیان کی  ،  کہا  :  ہمی"}
{"hadithnumber": "1492", "text": "سفیان نے ابو سہل عثمان بن حکیم سے اسی سند کے ساتھ اسی طرح روایت کی  ۔"}
{"hadithnumber": "1493", "text": "بشر  ،  یعنی ابن مفضل نے ہمیں حدیث سنائی  ،  انھوں نے خالد سے اور انھوں نے انس بن سیرین سے روایت کی"}
{"hadithnumber": "1494", "text": "اسماعیل نے خالد سے او ر انھوں نے انس بن سیرین سے روایت کی  ،  کہا  :  میں نے جندب  ( بن عبداللہ  ) ق"}
{"hadithnumber": "1495", "text": "یہی روایت حسن بصری نے جندب بن سفیان کے حوالے سے نبی ﷺ سے روایت کی  ( لیکن آخری فقرہ  ) فیکبہ فی نار"}
{"hadithnumber": "1496", "text": "یونس نے ابن شہاب سےروایت کی کہ محمود بن ربیع انصاری  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے ان سے بیان کیاکہ حضرت ع"}
{"hadithnumber": "1497", "text": "معمر نے زہر ی سے روایت کی  ،  کہا  :  مجھے محمود بن ربیع  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے عتبان بن مالک  ‌رض"}
{"hadithnumber": "1498", "text": "اوزاعی سے روایت ہے  ،  کہا  :  مجھے زہری نے حضرت محمود بن ربیع  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے حدیث سنائی"}
{"hadithnumber": "1499", "text": "اسحاق بن عبداللہ بن ابی طلحہ نےحضرت انس بن مالک  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ ان کی نانی ملیک"}
{"hadithnumber": "1500", "text": "ابو التیاح نےحضرت انس بن مالک   ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  کہا  :  رسول اللہ ﷺ تمام انسانو"}
{"hadithnumber": "1501", "text": "حضرت انس ‌رضی ‌اللہ ‌عنہ ‌ ‌ سےروایت کی ، کہا  : نبی ﷺ ہمارے ہاں تشریف لائے وہاں میرے ، میری والدہ ا"}
{"hadithnumber": "1502", "text": "معاذ عنبری نے کہا  :  ہمیں شعبہ نے عبداللہ بن مختار سے حدیث سنائی  ، انھوں نے موسیٰ بن انس سے سنا ،"}
{"hadithnumber": "1503", "text": "محمد بن جعفر اور عبدالرحمان بن مہدی نے شعبہ  سے اسی سند کے ساتھ یہی حریث بیان کی"}
{"hadithnumber": "1504", "text": "عبداللہ بن شداد سے روایت ہے ،  کہا : مجھے نبیﷺ کی زوجہ حضرت میمونہ رضی اللہ عنہا نے حدیث بیان کی ، ف"}
{"hadithnumber": "1505", "text": "حضرت جابر رضی اللہ عنہ سے روایت ہے ،  کہا :  ہمیں حضرت ابو سعید خرری رضی اللہ عنہ نے حدیث سنائی کہ و"}
{"hadithnumber": "1506", "text": "ابو معاویہ نے اعمش       سے حدیث بیان کی ،  انھوں نے ابو صالح سے اور انھوں نے حضرت ابو ہریرہ رضی الل"}
{"hadithnumber": "1507", "text": "عبثر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  ،   اسماعیل بن زکریا اور شعبہ ،  سب نے اعمش کی اسی سند کے ساتھ اس کے ہم م"}
{"hadithnumber": "1508", "text": "ابن سیرین نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ، کہا :  رسول اللہ ﷺنے فرمایا :   ‘  ‘ تم میں سے"}
{"hadithnumber": "1509", "text": "ابو رافع نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی کہ رسول اللہ ﷺ نے فرمایا :  ‘  ‘ بندہ مسلسل نماز"}
{"hadithnumber": "1510", "text": "ابو زناد نے اعرج سے اور انھوں نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی کہ رسول اللہ ﷺ نے فرمایا :"}
{"hadithnumber": "1511", "text": "ابن شہاب نے  ( عبدالرحمان )  بن ہرمز  ( اعرج ) سے اور انھوں نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت ک"}
{"hadithnumber": "1512", "text": "ہمام بن منبہ نے حضرت ابوہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌ رضی اللہ عنہ سے اور انھوں نے نبی ﷺ سے اسی کے مطاب"}
{"hadithnumber": "1513", "text": "عبداللہ بن براداشعری اور ابو کریب دونوں نے کہا :  ہم سے ابو اسامہ نے برید سے حدیث بیان کی ،  انھوں ن"}
{"hadithnumber": "1514", "text": "عبثر نے ہمیں خبر دی ، انھوں نے سلیمان تیمی سے  ، انھوں نے ابوعثمان نہدی سے اور انھوں نے حضرت ابی بن"}
{"hadithnumber": "1515", "text": "عتمر بن سلیمان اور جریر دونوں نے تیمی سے اسی سند کے ساتھ اسی کے مطابق روایت کی ۔"}
{"hadithnumber": "1516", "text": "عباد بن عباد نے ہمیں حدیث سنائی ، کہا :  ہمیں عاصم نے ابو عثمان سے حدیث سنائی  ، کہا :  انصار میں ای"}
{"hadithnumber": "1517", "text": "ابن عینیہ اور وکیع نے اپنے والد کے حوالے سے عاصم سے اسی سند کے ساتھ اسی طرح روایت کی ۔"}
{"hadithnumber": "1518", "text": "ابوزبیر نے ہمیں حدیث سنائی ، کہا :  میں نے حضرت جابر بن عبداللہ رضی اللہ عنہ سے سنا ، کہا :  ہمارے گ"}
{"hadithnumber": "1519", "text": "جریری نے ابونضرہ سے اور انھوں نے حضرت جابر بن عبداللہ رضی اللہ عنہا سے روایت کی ،  کہا :   ( رسول ال"}
{"hadithnumber": "1520", "text": "کہمس نے ابو نضرہ سے اور انھوں نے حضرت جابر بن عبداللہ رضی اللہ عنہا سے روایت کی ، کہا :  بنو سلمہ نے"}
{"hadithnumber": "1521", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ، کہا :  رسول اللہ ﷺ نے فرمایا :   ‘  ‘ جس نے اپنے گھر میں وض"}
{"hadithnumber": "1522", "text": "لیث اور بکر دونوں نے ہاد سے ، انھوں نے محمد بن ابراہیم سے ،  انھوں نے ابوہریرہ رضی اللہ عنہ سے روایت"}
{"hadithnumber": "1523", "text": "اعمش نے ابو سفیان  ( طلحہ بن نافع )  سے ،  انھوں نے حضرت جابر بن عبداللہ رضی اللہ عنہ سے روایت کی ،"}
{"hadithnumber": "1524", "text": "حضرت ابوہریرہ رضی اللہ عنہ نے نبی ﷺ سے روایت کی :   ‘  ‘ جو شخص دن کے پہلے حصے میں یا دن کے دوسرے حص"}
{"hadithnumber": "1525", "text": "ابو حثیمہ نے سماک بن حرب سے روایت کرتے ہوئے خبر دی ،  کہا :  میں نے حضرت جابر بن سمرہ رضی اللہ عنہ س"}
{"hadithnumber": "1526", "text": "سفیان اور زکریا دونوں نے سماک سے اور انھوں نے حضرت جابر بن سمرہ رضی اللہ عنہ سے روایت کی کہ نبی ﷺ جب"}
{"hadithnumber": "1527", "text": "ابواحوص اور شعبہ دونوں نے سماک سے اسی سند کے ساتھ یہی روایت بیان کی لیکن حسنا  ‘  ‘ اچھی طرح’’  ( سو"}
{"hadithnumber": "1528", "text": "حضرت ابوہریرہ رضی اللہ عنہٗ سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا :   ‘شہروں ‌میں ‌پیاری ‌جگہ ‌اللہ ‌"}
{"hadithnumber": "1529", "text": "ابوعوانہ نے ہمیں قتادہ سے حدیث سنائی ،  انھوں نے ابو نضرہ سے اور انھوں نے حضرت ابوسعید خدری رضی اللہ"}
{"hadithnumber": "1530", "text": "شعبہ ،  سعید بن ابی عروبہ اور معاذ  ( بن ہشام )  نے اپنے والد کے واسطے سے ،  سب نے قتادہ سے اپنے اپن"}
{"hadithnumber": "1531", "text": "قتادہ کے بجائے )  جریدی نے ابو نضرہ سے ،  انھوں نے حضرت ابوسعید رضی اللہ عنہ سے اور انھوں نے نبی ﷺ س"}
{"hadithnumber": "1532", "text": "ابوبکر بن ابی شیبہ اور ابوسعید اشج نے ابو خالد احمر سے  ،  انھوں نے اوس بن ضمعج سے اور انھوں نے حضرت"}
{"hadithnumber": "1533", "text": "ابو معاویہ ،  جریر ،  ابن فضیل اور سفیان سب نے اعمش سے اسی سند کے ساتھ اسی مانند روایت بیان کی ہے"}
{"hadithnumber": "1534", "text": "شعبہ نے اسماعیل بن رجاء سے روایت کی ،  کہا :  میں نے اوس بن ضمعج سے سنا ،  کہتے تھے :  میں نے حضرت ا"}
{"hadithnumber": "1535", "text": "اسماعیل بن ابراہیم  ( ابن علیہ )  نے ہمیں حدیث بیان کی ،  کہا :  ہم سے ایوب نے ابو قلابہ سے حدیث بیا"}
{"hadithnumber": "1536", "text": "حماد نے ایوب سے اسی سند کے ساتھ یہ حدیث بیان کی ۔"}
{"hadithnumber": "1537", "text": "اور یہی حدیث ہمیں ابن ابی عمر نے سنائی ،  کہا :  عبدالوہاب نے بھی ایوب سے ہمیں حدیث بیان کی ،  کہا :"}
{"hadithnumber": "1538", "text": "عبدالوہاب ثقفی نے خالد حذاء سے ،  انھوں نے ابو قلابہ سے اور انھوں نے حضرت مالک بن حویرث رضی اللہ عنہ"}
{"hadithnumber": "1539", "text": "حفص بن غیاث نے خالد حذاء سے اسی سند کے ساتھ روایت کی اور  ( اپنی روایت میں ) یہ اضافہ کیا کہ حذاء نے"}
{"hadithnumber": "1540", "text": "یونس بن یزید نے ابن شہاب سے روایت کرتے ہوئے خبر دی ،  کہا :  مجھے سعید بن مسیب اور ابو سلمہ بن عبدال"}
{"hadithnumber": "1541", "text": "ابن عینیہ نے زہری سے  ، انھوں نے سعید بن مسیب سے ،  انھوں نے حضرت ابوہریرہ رضی اللہ عنہ سے اور انھوں"}
{"hadithnumber": "1542", "text": "ہمیں اوزاعی نے یحییٰ بن ابی کثیر سے حدیث سنائی ،  انھوں نے ابو سلمہ سے روایت کی کہ حضرت ابوہریرہ رضی"}
{"hadithnumber": "1543", "text": "کہ حضرت ابوہریرہ رضی اللہ عنہ نے انھیں خبر دی کہ  (  ایک روز )  رسول اللہ ﷺ عشاء کی نماز پڑھ رہے تھے"}
{"hadithnumber": "1544", "text": "ابو سلمہ بن عبدالرحمان نے حضرت ابوہریرہ رضی اللہ عنہ کو یہ کہتے ہوئے سنا :  اللہ کی قسم! ضرور رسول ا"}
{"hadithnumber": "1545", "text": ")  اسحاق بن عبداللہ بن ابی طلحہ نے حضرت انس بن مالک رضی اللہ عنہ سے روایت کی ،  کہا :  رسول اللہ ﷺ ن"}
{"hadithnumber": "1546", "text": "محمد  ( بن سیرین )  سے روایت ہے ،  کہا :  میں نے حضرت انس بن مالک رضی اللہ عنہ سے پوچھا :  کیا رسول"}
{"hadithnumber": "1547", "text": "ابو مجلز نے حضرت انس رضی اللہ عنہ سے روایت کو کہ رسول اللہ ﷺ نے ایک مہینے تک صبح کی نماز میں رکوع کے"}
{"hadithnumber": "1548", "text": "انس بن سیرین نے حضرت انس بن مالک رضی اللہ عنہ سے روایت کی کہ رسول اللہ ﷺ نے ایک مہینے تک نماز فجر می"}
{"hadithnumber": "1549", "text": ")  ابو معاویہ نے عاصم سے اور انھوں نے حضرت انس رضی اللہ عنہ سے روایت کی ،  کہا :  میں نے ان  ( انس ر"}
{"hadithnumber": "1550", "text": "سفیان نے عاصم سے روایت کی ،  کہا :  میں نے انس رضی اللہ عنہ کو کہتے سنا ،  میں نے رسول اللہ ﷺ کو نہی"}
{"hadithnumber": "1551", "text": "حفص  ،  ابن فضیل  اور مروان سب نے عاصم سے  ،  انھوں نے حضرت انس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے اور انھوں ن"}
{"hadithnumber": "1552", "text": ")  شعبہ نے قتادہ سے اور انھوں نے حضرت انس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ نبی ﷺ نے ایک مہینے  ت"}
{"hadithnumber": "1553", "text": ")  موسیٰ بن انس نے   ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے اور انھوں نے نبی ﷺ سے اس طرح روایت کی ۔"}
{"hadithnumber": "1554", "text": "ہشام نے قتادہ کے حوالے سے حضرت انس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ رسول اللہ ﷺ نے ایک مہینے  تک"}
{"hadithnumber": "1555", "text": "شعبہ نے عمروہ بن مرہ سے روایت کی  ،  کہا  :  میں نے ابن ابی لیلی ٰ سے  سنا  ،  کہا  :  ہمیں حضرت  بر"}
{"hadithnumber": "1556", "text": "سفیان نے عمرو بن مرہ سے  ،  انھوں نے عبدالرحمن بن ابی لیلیٰ سے اور انھوں  نےحضرت براء  ‌رضی ‌اللہ ‌ع"}
{"hadithnumber": "1557", "text": "عمران بن ابی انس نے حنظلہ بن علی سے اور انھوں نے خفاف بن ایما ء غفاری  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت"}
{"hadithnumber": "1558", "text": "حارث بن خفاف سے روایت ہے  ،  انھوں نے کہا  :  حضرت خفاف بن ایما  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے کہا  :  رسو"}
{"hadithnumber": "1559", "text": "عمران کے بجائے ) عبدالرحمان بن حرملہ نے حنظلہ بن علی بن اسقع سے اور انھوں نے حضرت خفاف بن ایماء  ‌رض"}
{"hadithnumber": "1560", "text": ")  یونس نے ابن شہاب کے حوالے سے خبردی  ،  انھوں نے سعید بن مسیب سے اور انھوں نے حضرت ابوہریرہ  ‌رضی"}
{"hadithnumber": "1561", "text": "ابوہریرہ رضی اﷲ عنہ نے کہا کہ ایک شب ہم آخر رات میں نبی ﷺ کے ساتھ اترے اور نہ جاگے یہاں تک کہ سورج ن"}
{"hadithnumber": "1562", "text": "ثابت نے عبداللہ بن رباح سے اور انھوں نے حضرت ابو قتادہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سےر وایت کی  ،  کہا  :"}
{"hadithnumber": "1563", "text": "سلم  بن زریر عطاری نے کہا  : میں نے ابو رجاء عطاری سے سنا  ‘ وہ حضرت عمران بن حصین  ‌رضی ‌اللہ ‌عنہ"}
{"hadithnumber": "1564", "text": ") عوف بن ابی جمیلہ اعرابی نے ابو رجاء عطاری سے  ‘ انھوں نے حضرت عمران بن حصین ‌رضی ‌اللہ ‌عنہ ‌ ‌  س"}
{"hadithnumber": "1565", "text": "حضرت ابو قتادہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے  ‘ کہا  : رسول اللہ ﷺجب سفر میں ہوتے اور رات  ( کے"}
{"hadithnumber": "1566", "text": "ہمام نے ہمیں حدیث سنائی  ‘ کہا  : ہمیں قتادہ نے حضرت انس بن مالک  ‌رضی ‌اللہ ‌عنہ ‌ ‌ کے حوالے سے حد"}
{"hadithnumber": "1567", "text": "ابو عوانہ نے قتادہ سے  ‘ انھوں نے حضرت انس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے اور انھوں نے نبی ﷺسے یہ ( یہی حد"}
{"hadithnumber": "1568", "text": "سعید نے قتادہ سے اور انھوں نے حضرت انس بن مالک  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سےحدیث سنائی  ‘ کہا  : اللہ کے"}
{"hadithnumber": "1569", "text": "مثنیٰ نے قتادہ کے حوالے سے حضرت انس بن مالک  ‌رضی ‌اللہ ‌عنہ ‌ ‌ سے روایت کی  ‘ کہا : رسول اللہ ﷺنے"}
