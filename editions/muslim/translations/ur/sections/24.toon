{"hadithnumber": "4163", "text": "عبداللہ بن مسلمہ بن قعنب نے ہمیں حدیث بیان کی :  ہمیں مالک بن انس نے زید بن اسلم سے حدیث بیان کی ،"}
{"hadithnumber": "4164", "text": ")  عبدالرحمان بن مہدی نے ہمیں مالک بن انس سے اسی سند کے ساتھ  ( یہ )  حدیث بیان کی اور اضافہ کیا : ا"}
{"hadithnumber": "4165", "text": "روح بن قاسم نے ہمیں زید بن اسلم سے حدیث بیان کی ،  انہوں نے اپنے والد سے اور انہوں نے حضرت عمر رضی ا"}
{"hadithnumber": "4166", "text": "فیان نے زید بن اسلم سے اسی سند کے ساتھ  ( یہی )  حدیث بیان کی ،  البتہ مالک اور روح کی حدیث زیادہ مک"}
{"hadithnumber": "4167", "text": "امام مالک نے نافع سے ،  انہوں نے حضرت ابن عمر رضی اللہ عنہ سے روایت کی کہ حضرت عمر بن خطاب رضی اللہ"}
{"hadithnumber": "4168", "text": "لیث بن سعد اور عبیداللہ دونوں نے نافع سے ،  انہوں نے حضرت ابن عمر رضی اللہ عنہ سے اور انہوں نے نبی ص"}
{"hadithnumber": "4169", "text": "سالم نے حضرت ابن عمر رضی اللہ عنہ سے روایت کی کہ حضرت عمر رضی اللہ عنہ نے اللہ کی راہ میں سواری کے ل"}
{"hadithnumber": "4170", "text": "عیسیٰ بن یونس نے ہمیں خبر دی :  ہمیں اوزاعی نے ابوجعفر محمد بن علی سے حدیث بیان کی ،  انہوں نے ابن م"}
{"hadithnumber": "4171", "text": "ابن مبارک نے ہمیں اوزاعی سے خبر دی ،  انہوں نے کہا :  میں نے  ( ابوجعفر )  محمد بن  ( زین العابدین )"}
{"hadithnumber": "4172", "text": "یحییٰ بن ابی کثیر نے ہمیں حدیث بیان کی :  مجھے عبدالرحمان بن عمرو نے حدیث بیان کی کہ انہیں فاطمہ بنت"}
{"hadithnumber": "4173", "text": "بکیر سے روایت ہے کہ انہوں نے سعید بن مسیب سے سنا ،  وہ کہہ رہے تھے :  میں نے حضرت ابن عباس رضی اللہ"}
{"hadithnumber": "4174", "text": "شعبہ نے ہمیں حدیث بیان کی :  میں نے قتادہ سے سنا ،  وہ سعید بن مسیب سے حدیث بیان کر رہے تھے ،  انہوں"}
{"hadithnumber": "4175", "text": "سعید نے قتادہ سے اسی سند کے ساتھ اسی کے مانند روایت کی"}
{"hadithnumber": "4176", "text": "حضرت ابن عباس رضی اللہ عنہ نے رسول اللہ صلی اللہ علیہ وسلم سے روایت کی ،  آپ نے فرمایا :   \" اپنا ہب"}
{"hadithnumber": "4177", "text": "امام مالک نے ابن شہاب سے اور انہوں نے حمید بن عبدالرحمان اور محمد بن نعمان بن بشیر سے روایت کی ،  وہ"}
{"hadithnumber": "4178", "text": "ابراہیم بن سعد نے ہمیں ابن شہاب سے خبر دی ،  انہوں نے حمید بن عبدالرحمٰن اور محمد بن نعمان سے اور ان"}
{"hadithnumber": "4179", "text": ")  ابن عیینہ ،  لیث بن سعد ،  یونس اور معمر سب نے زہری سے اسی سند کے ساتھ حدیث بیان کی ،  البتہ یونس"}
{"hadithnumber": "4180", "text": "عروہ سے روایت ہے ،  انہوں نے کہا :  ہمیں حضرت نعمان بن بشیر رضی اللہ عنہ نے حدیث بیان کی ،  انہوں نے"}
{"hadithnumber": "4181", "text": "حصین نے شعبی سے ،  انہوں نے حضرت نعمان بن بشیر رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  میرے والد"}
{"hadithnumber": "4182", "text": "ابوحیان تیمی نے ہمیں شعبی سے حدیث بیان کی :  مجھے حضرت نعمان بن بشیر رضی اللہ عنہ نے حدیث بیان کی کہ"}
{"hadithnumber": "4183", "text": "اسماعیل نے ہمیں شعبی سے حدیث بیان کی ،  انہوں نے حضرت نعمان بن بشیر رضی اللہ عنہ سے روایت کی کہ رسول"}
{"hadithnumber": "4184", "text": "عاصم احول نے شعبی سے اور انہوں نے حضرت نعمان بن بشیر رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ"}
{"hadithnumber": "4185", "text": "داود بن ابی ہند نے شعبی سے اور انہوں نے حضرت نعمان بن بشیر رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا"}
{"hadithnumber": "4186", "text": "ابن عون نے ہمیں شعبی سے ،  انہوں نے حضرت نعمان بن بشیر رضی اللہ عنہ سے حدیث بیان کی ،  انہوں نے کہا"}
{"hadithnumber": "4187", "text": "حضرت جابر رضی اللہ عنہ سے روایت ہے ،  انہوں نے کہا :  حضرت بشیر رضی اللہ عنہ کی بیوی نے کہا :  میرے"}
{"hadithnumber": "4188", "text": "امام مالک نے ابن شہاب سے ، انہوں نے ابوسلمہ بن عبدالرحمان سے اور انہوں نے حضرت جابر بن عبداللہ رضی ا"}
{"hadithnumber": "4189", "text": "لیث نے ہمیں ابن شہاب سے حدیث بیان کی ،  انہوں نے ابوسلمہ سے اور انہوں نے حضرت جابر بن عبداللہ رضی ال"}
{"hadithnumber": "4190", "text": "ابن جریج نے ہمیں خبر دی :  مجھے ابن شہاب نے ابوسلمہ بن عبدالرحمان کی حدیث کی رو سے عمریٰ اور اس کے ط"}
{"hadithnumber": "4191", "text": "معمر نے ہمیں زہری رحمۃ اللہ علیہ سے خبر دی ،  انہوں نے ابوسلمہ سے اور انہوں نے حضرت جابر رضی اللہ عن"}
{"hadithnumber": "4192", "text": "ابن ابی ذئب نے ابن شہاب سے ،  انہوں نے ابوسلمہ بن عبدالرحمان سے اور انہوں نے حضرت جابر بن عبداللہ رض"}
{"hadithnumber": "4193", "text": "خالد بن حارث نے ہمیں حدیث بیان کی :  ہمیں ہشام نے یحییٰ بن ابی کثیر سے حدیث بیان کی :  ہمیں ابوسلمہ"}
{"hadithnumber": "4194", "text": "معاذ بن ہشام نے ہمیں حدیث بیان کی :  مجھے میرے والد نے یحییٰ بن ابی کثیر سے حدیث بیان کی :  ہمیں ابو"}
{"hadithnumber": "4195", "text": "احمد بن یونس نے ہمیں حدیث بیان کی :  ہمیں زہیر نے حدیث بیان کی :  ہمیں ابوزبیر نے حضرت جابر رضی اللہ"}
{"hadithnumber": "4196", "text": "نیز یحییٰ بن یحییٰ نے ہمیں حدیث بیان کی  ۔  ۔  الفاظ انہی کے ہیں  ۔  ۔  ہمیں ابوخثیمہ نے ابوزبیر سے"}
{"hadithnumber": "4197", "text": "حجاج بن ابوعثمان ،  سفیان اور ایوب سب نے ابوزبیر سے ،  انہوں نے حضرت جابر رضی اللہ عنہ سے اور انہوں"}
{"hadithnumber": "4198", "text": "ابن جریج نے ہمیں خبر دی ،  مجھے ابوزبیر نے حضرت جابر رضی اللہ عنہ سے خبر دی ،  انہوں نے کہا :  مدینہ"}
{"hadithnumber": "4199", "text": "سلیمان بن یسار سے روایت ہے کہ رسول اللہ صلی اللہ علیہ وسلم سے روایت کردہ حضرت جابر بن عبداللہ رضی ال"}
{"hadithnumber": "4200", "text": "شعبہ نے ہمیں حدیث بیان کی ،  کہا :  میں نے قتادہ سے سنا ،  وہ عطاء کے واسطے سے حضرت جابر بن عبداللہ"}
{"hadithnumber": "4201", "text": ")  سعید نے ہمیں قتادہ سے حدیث بیان کی ،  انہوں نے عطاء سے ،  انہوں نے حضرت جابر رضی اللہ عنہ سے اور"}
{"hadithnumber": "4202", "text": "شعبہ نے ہمیں قتادہ سے حدیث بیان کی ،  انہوں نے نضر بن انس سے ،  انہوں نے بشیر بن نہیک سے ،  انہوں نے"}
{"hadithnumber": "4203", "text": "سعید نے ہمیں قتادہ سے اسی سند کے ساتھ حدیث بیان کی ،  البتہ انہوں  ( قتادہ )  نے کہا :   \" اس کے خان"}
