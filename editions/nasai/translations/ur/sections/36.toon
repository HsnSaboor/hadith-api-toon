{"hadithnumber": "3939", "text": "نافع کا بیان ہے کہ  رافع بن خدیج رضی اللہ عنہ نے عبداللہ بن عمر رضی اللہ عنہما کو خبر دی کہ ہمارے چچ"}
{"hadithnumber": "3940", "text": "نافع سے روایت ہے کہ  ابن عمر رضی اللہ عنہما زمین کا کرایہ لیتے تھے، انہیں رافع بن خدیج رضی اللہ عنہ"}
{"hadithnumber": "3941", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  وہ زمین کا کرایہ لیتے تھے، یہاں تک کہ رافع رضی اللہ عن"}
{"hadithnumber": "3942", "text": "نافع سے روایت ہے کہ  ابن عمر رضی اللہ عنہما اپنے کھیت کرایہ پر اٹھاتے تھے، یہاں تک کہ معاویہ رضی الل"}
{"hadithnumber": "3943", "text": "نافع سے روایت ہے کہ  عبداللہ بن عمر رضی اللہ عنہما کھیتوں کو کرائیے پر دیتے تھے، ان سے کہا گیا کہ را"}
{"hadithnumber": "3944", "text": "نافع سے روایت ہے کہ  کہ ایک آدمی نے ابن عمر رضی اللہ عنہما کو بتایا کہ رافع بن خدیج رضی اللہ عنہ زمی"}
{"hadithnumber": "3945", "text": "نافع سے روایت ہے کہ  رافع بن خدیج رضی اللہ عنہ نے عبداللہ بن عمر رضی اللہ عنہما سے حدیث بیان کی کہ ر"}
{"hadithnumber": "3946", "text": "نافع کہتے ہیں کہ  ابن عمر رضی اللہ عنہما اپنی زمین کو اس میں پیدا ہونے والے غلہ کے بعض حصے کے بدلے ک"}
{"hadithnumber": "3947", "text": "رافع بن خدیج رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے زمین کرائے پر دینے سے منع"}
{"hadithnumber": "3948", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  ہم لوگ مخابرہ کرتے تھے اور اس میں کوئی حرج نہیں سمجھتے تھ"}
{"hadithnumber": "3949", "text": "ابن جریج کہتے ہیں کہ  میں نے عمرو بن دینار کو کہتے سنا: میں گواہی دیتا ہوں کہ میں نے ابن عمر رضی الل"}
{"hadithnumber": "3950", "text": "عمرو بن دینار کہتے ہیں کہ  میں نے ابن عمر رضی اللہ عنہما کو کہتے سنا: ہم مخابرہ میں کوئی حرج نہیں سم"}
{"hadithnumber": "3951", "text": "جابر بن عبداللہ رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے زمین کرائے پر دینے سے"}
{"hadithnumber": "3952", "text": "جابر رضی اللہ عنہ کہتے ہیں کہ  مجھے رسول اللہ صلی اللہ علیہ وسلم نے مخابرہ، محاقلہ اور مزابنہ سے منع"}
{"hadithnumber": "3953", "text": "عبداللہ بن عمر اور جابر رضی اللہ عنہم سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے پھل بیچنے سے م"}
{"hadithnumber": "3954", "text": "رافع بن خدیج رضی اللہ عنہ بیان کرتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ان سے فرمایا:  کیا تم اپ"}
{"hadithnumber": "3955", "text": "رافع بن خدیج رضی اللہ عنہ کہتے ہیں کہ  ہمارے پاس  ( ہمارے چچا )  ظہیر بن رافع رضی اللہ عنہ نے آ کر ک"}
{"hadithnumber": "3956", "text": "اسید بن رافع بن خدیج سے روایت ہے کہ  رافع کے بھائی نے اپنے قبیلے سے کہا: آج رسول اللہ صلی اللہ علیہ"}
{"hadithnumber": "3957", "text": "عبدالرحمٰن بن ہرمز کہتے ہیں کہ  میں نے اسید بن رافع بن خدیج انصاری کو بیان کرتے سنا کہ انہیں  ( یعنی"}
{"hadithnumber": "3958", "text": "عیسیٰ بن سہل بن رافع بن خدیج کہتے ہیں کہ  میں یتیم تھا اور اپنے دادا رافع بن خدیج رضی اللہ عنہ کی گو"}
{"hadithnumber": "3959", "text": "عروہ بن زبیر کہتے ہیں کہ  زید بن ثابت رضی اللہ عنہ نے کہا: اللہ تعالیٰ رافع بن خدیج رضی اللہ عنہ کی"}
{"hadithnumber": "3960", "text": "ابن عون کہتے ہیں کہ  محمد  ( محمد بن سیرین )  کہا کرتے تھے: میرے نزدیک زمین مضاربت کے مال کی طرح ہے،"}
{"hadithnumber": "3961", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے خیبر کے یہود کو خیبر کے"}
{"hadithnumber": "3962", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے یہود خیبر کو خیبر کے با"}
{"hadithnumber": "3963", "text": "نافع سے روایت ہے کہ عبداللہ بن عمر رضی اللہ عنہما کہا کرتے تھے کہ  رسول اللہ صلی اللہ علیہ وسلم کے ز"}
{"hadithnumber": "3964", "text": "عبدالرحمٰن بن اسود کہتے ہیں کہ  میرے دو چچا تہائی اور چوتھائی پر کھیتی کرتے تھے اور میرے والد ان کے"}
{"hadithnumber": "3965", "text": "عبداللہ بن عباس رضی اللہ عنہما فرماتے ہیں کہ  جو کچھ تم کرتے ہو اس میں سب سے بہتر یہ ہے کہ تم میں سے"}
