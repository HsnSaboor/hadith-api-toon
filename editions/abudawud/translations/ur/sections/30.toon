{"hadithnumber": "3904", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو کسی کاہن کے پاس آئے پ"}
{"hadithnumber": "3905", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے علم نجوم کا"}
{"hadithnumber": "3906", "text": "زید بن خالد جہنی رضی اللہ عنہ کہتے ہیں  رسول اللہ صلی اللہ علیہ وسلم نے حدیبیہ میں ہمیں نماز فجر بار"}
{"hadithnumber": "3907", "text": "قبیصہ بن وقاص رضی اللہ عنہ کہتے ہیں  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا:  رمل، ب"}
{"hadithnumber": "3908", "text": "عوف کہتے ہیں  «عيافة» سے مراد پرندہ اڑانا ہے اور «طرق» سے مراد وہ لکیریں ہیں جو زمین پر کھینچی جاتی"}
{"hadithnumber": "3909", "text": "معاویہ بن حکم سلمی رضی اللہ عنہ کہتے ہیں  میں نے عرض کیا: اللہ کے رسول! ہم میں کچھ لوگ ایسے ہیں جو خ"}
{"hadithnumber": "3910", "text": "عبداللہ بن مسعود رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے تین بار فرمایا:  بدشگو"}
{"hadithnumber": "3911", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  نہ کسی کو کسی کی بیماری"}
{"hadithnumber": "3912", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  نہ کسی کو کسی کی بیماری"}
{"hadithnumber": "3913", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  بھوت پریت کو کسی کو نقصا"}
{"hadithnumber": "3914", "text": "ابوداؤد کہتے ہیں  حارث بن مسکین پر پڑھا گیا، اور میں موجود تھا کہ اشہب نے آپ کو خبر دی ہے کہ امام ما"}
{"hadithnumber": "3915", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  نہ کسی کو کسی کی بیماری لگتی ہ"}
{"hadithnumber": "3916", "text": "بقیہ کہتے ہیں کہ  میں نے محمد بن راشد سے پوچھا کہ نبی اکرم صلی اللہ علیہ وسلم کے قول «هام» کے کیا مع"}
{"hadithnumber": "3917", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک بات سنی جو آپ کو بھلی لگی تو"}
{"hadithnumber": "3918", "text": "عطاء سے روایت ہے کہ لوگ کہتے تھے کہ  صفر ایک قسم کا درد ہے جو پیٹ میں ہوتا ہے تو میں نے پوچھا: ہامہ"}
{"hadithnumber": "3919", "text": "عروہ بن عامر قرشی کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے پاس طیرہ  ( بدشگونی )  کا ذکر کیا گیا"}
{"hadithnumber": "3920", "text": "بریدہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کسی چیز سے فال بد  ( بدشگونی )  نہیں لیت"}
{"hadithnumber": "3921", "text": "سعد بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم فرماتے تھے:  مردے کی روح جانور کی"}
{"hadithnumber": "3922", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  نحوست گھر، عورت"}
{"hadithnumber": "3923", "text": "فروہ بن مسیک رضی اللہ عنہ کہتے ہیں کہ  میں نے عرض کیا: اللہ کے رسول! ہمارے پاس ایک زمین ہے جسے ابین"}
{"hadithnumber": "3924", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  ایک شخص نے عرض کیا: اللہ کے رسول! ہم ایک گھر میں تھے تو اس میں"}
{"hadithnumber": "3925", "text": "جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک کوڑھی کا ہاتھ پکڑ کر اپنے ساتھ پی"}
