  section_name: The Mudabbar
  hadith_first: 1497
  hadith_last: 1499
  arabic_first: 1497
  arabic_last: 1499

hadiths[3]{hadithnumber,text,reference_book,reference_hadith}:
1497,,40,1
1498,"Yahia Ibn Sa'id a rapporté que Sa'id Ibn Al-Moussaiab disait: «Au cas où l'homme affranchit à date posthume, son esclave femelle, il peut cohabiter avec elle, sans qu'il ait le droit ni de la vendre ni de faire don d'elle; son enfant aussi jouit de la même situation que sa mère». Chapitre V Du sujet de la vente du moudabbar",40,2
1499,,40,3
