{"hadithnumber": "2844", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جو مویشی کی نگہبانی، یا ش"}
{"hadithnumber": "2845", "text": "عبداللہ بن مغفل رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اگر یہ بات نہ ہوت"}
{"hadithnumber": "2846", "text": "جابر رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے کتوں کے مارنے کا حکم دیا یہاں تک کہ کو"}
{"hadithnumber": "2847", "text": "عدی بن حاتم رضی اللہ عنہ کہتے ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم سے پوچھا کہ میں سدھائے ہوئے"}
{"hadithnumber": "2848", "text": "عدی بن حاتم رضی اللہ عنہ کہتے ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم سے پوچھا: ہم ان کتوں سے شکا"}
{"hadithnumber": "2849", "text": "عدی بن حاتم رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جب تم بسم اللہ کہہ کر"}
{"hadithnumber": "2850", "text": "عدی بن حاتم رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جب تمہارے تیر کا شکار"}
{"hadithnumber": "2851", "text": "عدی بن حاتم رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جس کتے یا باز کو تم سد"}
{"hadithnumber": "2852", "text": "ابوثعلبہ خشنی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے شکاری کتے کے سلسلہ میں فرمای"}
{"hadithnumber": "2853", "text": "عدی بن حاتم رضی اللہ عنہ کہتے ہیں کہ  میں نے کہا: اللہ کے رسول! ہم میں سے کوئی اپنے شکار کو تیر مارت"}
{"hadithnumber": "2854", "text": "عدی بن حاتم رضی اللہ عنہ کہتے ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم سے بے پر کے تیر کے بارے میں"}
{"hadithnumber": "2855", "text": "ابوثعلبہ خشنی رضی اللہ عنہ کہتے ہیں کہ  میں نے عرض کیا: اللہ کے رسول! میں سدھائے اور بےسدھائے ہوئے ک"}
{"hadithnumber": "2856", "text": "ابوثعلبہ خشنی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مجھ سے عرض کیا:  ابوثعلبہ! ج"}
{"hadithnumber": "2857", "text": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  ابوثعلبہ رضی اللہ عنہ نامی ایک دیہاتی نے کہا: ا"}
{"hadithnumber": "2858", "text": "ابوواقد لیثی رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  زندہ جانور کے بدن سے"}
{"hadithnumber": "2859", "text": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جو شخص صحراء"}
{"hadithnumber": "2860", "text": "ابوہریرہ رضی اللہ عنہ نے نبی اکرم صلی اللہ علیہ وسلم سے مسدد والی حدیث کے ہم معنی حدیث روایت کی ہے"}
{"hadithnumber": "2861", "text": "ابوثعلبہ خشنی رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جب تم کسی شکار کو"}
