hadiths[count]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}:
2936,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا شَبَابَةُ، حَدَّثَنَا شُعْبَةُ، عَنْ أَبِي التَّيَّاحِ، قَالَ سَمِعْتُ مُطَرِّفًا، يُحَدِّثُ عَنْ عَبْدِ اللَّهِ بْنِ مُغَفَّلٍ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ أَمَرَ بِقَتْلِ الْكِلاَبِ ثُمَّ قَالَ ‏ ‏ مَا لَهُمْ وَلِلْكِلاَبِ ‏""""‏ ‏.‏ ثُمَّ رَخَّصَ لَهُمْ فِي كَلْبِ الصَّيْدِ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۵۸۹۲، ومصباح الزجاجة:۱۰۳۳)، وقد أخرجہ: مسند احمد (۶/۳۴۹),,"It was\nnarrated from ‘Abdullah bin Mughaffal that the Messenger of\nAllah\n(ﷺ) commanded that dogs be killed, then he said:",Chapters on Hunting
2937,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا عُثْمَانُ بْنُ عُمَرَ، ح وَحَدَّثَنَا مُحَمَّدُ بْنُ الْوَلِيدِ، حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، قَالاَ حَدَّثَنَا شُعْبَةُ، عَنْ أَبِي التَّيَّاحِ، قَالَ سَمِعْتُ مُطَرِّفًا، عَنْ عَبْدِ اللَّهِ بْنِ مُغَفَّلٍ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ أَمَرَ بِقَتْلِ الْكِلاَبِ ثُمَّ قَالَ ‏ ‏ مَا لَهُمْ وَلِلْكِلاَبِ ‏""""‏ ‏.‏ ثُمَّ رَخَّصَ لَهُمْ فِي كَلْبِ الزَّرْعِ وَكَلْبِ الْعِينِ ‏.‏ قَالَ بُنْدَارٌ الْعِينُ حِيطَانُ الْمَدِينَةِ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۵۹۱۴، ومصباح الزجاجة:۱۰۳۴)، وقد أخرجہ: مسند احمد (۶/۳۶۰),,"It was\nnarrated from ‘Abdullah bin Mughaffal that the Messenger of\nAllah\n(ﷺ) commanded that dogs be killed, then he said:",Chapters on Hunting
2938,حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، أَنْبَأَنَا مَالِكُ بْنُ أَنَسٍ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ أَمَرَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ بِقَتْلِ الْكِلاَبِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۱۵ (۱۲۰۸)، سنن النسائی/الحج ۶۰ (۲۷۶۷)،(تحفة الأشراف:۵۷۵۴،۶۲۱۴)، وقد أخرجہ: سنن ابی داود/الحج ۲۲ (۱۷۷۶)، سنن الترمذی/الحج ۹۷ (۹۴۱)، مسند احمد (۱/۳۳۷،۳۵۲)، سنن الدارمی/المناسک ۱۵ (۱۸۵۲),2938,It was\nnarrated that Ibn ‘Umar said:,Chapters on Hunting
2939,حَدَّثَنَا أَبُو طَاهِرٍ، حَدَّثَنَا ابْنُ وَهْبٍ، أَخْبَرَنِي يُونُسُ، عَنِ ابْنِ شِهَابٍ، عَنْ سَالِمٍ، عَنْ أَبِيهِ، قَالَ سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ رَافِعًا صَوْتَهُ يَأْمُرُ بِقَتْلِ الْكِلاَبِ وَكَانَتِ الْكِلاَبُ تُقْتَلُ إِلاَّ كَلْبَ صَيْدٍ أَوْ مَاشِيَةٍ ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۹۵۷، ومصباح الزجاجة:۱۰۳۵),2939,It was\nnarrated from Salim that his father said:,Chapters on Hunting
2940,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، حَدَّثَنَا الأَوْزَاعِيُّ، حَدَّثَنِي يَحْيَى بْنُ أَبِي كَثِيرٍ، عَنْ أَبِي سَلَمَةَ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنِ اقْتَنَى كَلْبًا فَإِنَّهُ يَنْقُصُ مِنْ عَمَلِهِ كُلَّ يَوْمٍ قِيرَاطٌ إِلاَّ كَلْبَ حَرْثٍ أَوْ مَاشِيَةٍ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۱۱۴)، وقد أخرجہ: صحیح البخاری/الحج ۴۰ (۱۵۷۶)،۴۱ (۱۵۷۷)، صحیح مسلم/الحج ۳۷ (۱۲۵۷)، سنن ابی داود/الحج ۴۵ (۱۸۶۶)، سنن النسائی/الحج ۱۰۵ (۲۸۶۸)، مسند احمد (۲/۱۴،۱۹)، سنن الدارمی/المناسک ۸۱ (۱۹۶۹),,It was\nnarrated that Abu Hurairah said:,Chapters on Hunting
2941,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَحْمَدُ بْنُ عَبْدِ اللَّهِ، عَنْ أَبِي شِهَابٍ، حَدَّثَنِي يُونُسُ بْنُ عُبَيْدٍ، عَنِ الْحَسَنِ، عَنْ عَبْدِ اللَّهِ بْنِ مُغَفَّلٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لَوْلاَ أَنَّ الْكِلاَبَ أُمَّةٌ مِنَ الأُمَمِ لأَمَرْتُ بِقَتْلِهَا فَاقْتُلُوا مِنْهَا الأَسْوَدَ الْبَهِيمَ وَمَا مِنْ قَوْمٍ اتَّخَذُوا كَلْبًا إِلاَّ كَلْبَ مَاشِيَةٍ أَوْ كَلْبَ صَيْدٍ أَوْ كَلْبَ حَرْثٍ إِلاَّ نَقَصَ مِنْ أُجُورِهِمْ كُلَّ يَوْمٍ قِيرَاطَانِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن الترمذی/الحج ۳۱ (۸۵۴)،(تحفة الأشراف:۷۷۲۳)، وقد أخرجہ: صحیح البخاری/الصلاة ۸۹ (۴۸۴)، الحج ۱۴۸ (۱۵۷۳)،۱۴۹ (۱۵۷۴)، صحیح مسلم/الحج ۳۸ (۱۲۵۹)، سنن النسائی/الحج ۱۰۳ (۲۸۶۵)، مسند احمد (۲/۵۹،۷۸)، سنن الدارمی/المناسک ۸۰ (۱۹۶۸),,It was\nnarrated from ‘Abdullah bin Mughaffal that the Messenger of\nAllah\n(ﷺ) said:,Chapters on Hunting
2942,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ، حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، عَنْ يَزِيدَ بْنِ خُصَيْفَةَ، عَنِ السَّائِبِ بْنِ يَزِيدَ، عَنْ سُفْيَانَ بْنِ أَبِي زُهَيْرٍ، قَالَ سَمِعْتُ النَّبِيَّ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ مَنِ اقْتَنَى كَلْبًا لاَ يُغْنِي عَنْهُ زَرْعًا وَلاَ ضَرْعًا نَقَصَ مِنْ عَمَلِهِ كُلَّ يَوْمٍ قِيرَاطٌ ‏""""‏ ‏.‏ فَقِيلَ لَهُ أَنْتَ سَمِعْتَ مِنَ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ إِي وَرَبِّ هَذَا الْمَسْجِدِ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحج ۴۴ (۱۵۸۸)، الجہاد۱۸۰ (۳۰۵۸)، مناقب الأنصار ۳۹ (۴۲۸۲)، المغازي ۴۸ (۴۲۸۲)، التوحید ۳۱ (۷۴۷۹)، صحیح مسلم/الحج ۸۰ (۱۳۵۱)، سنن ابی داود/الفرائض ۱۰ (۲۹۰۹،۱۰ ۲۹)،(تحفة الأشراف:۱۱۴)، وقد أخرجہ: سنن الترمذی/الفرائض ۱۵ (۲۱۰۷)، موطا امام مالک/الفرائض ۱۳ (۱۰)، مسند احمد (۲/۲۳۷، سنن الدارمی/الفرائض ۲۹ (۳۰۲۶),,It was\nnarrated that Sufyan bin Abu Zuhair said:,Chapters on Hunting
2943,"حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، حَدَّثَنَا الضَّحَّاكُ بْنُ مَخْلَدٍ، حَدَّثَنَا حَيْوَةُ بْنُ شُرَيْحٍ، حَدَّثَنِي رَبِيعَةُ بْنُ يَزِيدَ، أَخْبَرَنِي أَبُو إِدْرِيسَ الْخَوْلاَنِيُّ، عَنْ أَبِي ثَعْلَبَةَ الْخُشَنِيِّ، قَالَ أَتَيْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ فَقُلْتُ يَا رَسُولَ اللَّهِ إِنَّا بِأَرْضِ أَهْلِ كِتَابٍ نَأْكُلُ فِي آنِيَتِهِمْ وَبِأَرْضِ صَيْدٍ أَصِيدُ بِقَوْسِي وَأَصِيدُ بِكَلْبِيَ الْمُعَلَّمِ وَأَصِيدُ بِكَلْبِيَ الَّذِي لَيْسَ بِمُعَلَّمٍ ‏.‏ قَالَ فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ أَمَّا مَا ذَكَرْتَ أَنَّكُمْ فِي أَرْضِ أَهْلِ كِتَابٍ فَلاَ تَأْكُلُوا فِي آنِيَتِهِمْ إِلاَّ أَنْ لاَ تَجِدُوا مِنْهَا بُدًّا فَإِنْ لَمْ تَجِدُوا مِنْهَا بُدًّا فَاغْسِلُوهَا وَكُلُوا فِيهَا وَأَمَّا مَا ذَكَرْتَ مِنْ أَمْرِ الصَّيْدِ فَمَا أَصَبْتَ بِقَوْسِكَ فَاذْكُرِ اسْمَ اللَّهِ وَكُلْ وَمَا صِدْتَ بِكَلْبِكَ الْمُعَلَّمِ فَاذْكُرِ اسْمَ اللَّهِ وَكُلْ وَمَا صِدْتَ بِكَلْبِكَ الَّذِي لَيْسَ بِمُعَلَّمٍ فَأَدْرَكْتَ ذَكَاتَهُ فَكُلْ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۴۱ (۱۲۷۰)،(تحفة الأشراف:۱۰۴۸۶)، وقد أخرجہ: صحیح البخاری/الحج ۵۰ (۱۵۹۷)،۵۷ (۱۶۰۵)،۶۰ (۱۶۱۰)، سنن ابی داود/الحج ۴۷ (۱۸۷۳)، سنن الترمذی/الحج ۳۷ (۸۶۰)، سنن النسائی/الحج ۱۴۷ (۲۹۴۰)، موطا امام مالک/الحج ۳۶ (۱۱۵)، مسند احمد (۱/۲۱،۲۶،۳۴،۳۵،۳۹،۴۶،۵۱،۵۳،۵۴)، سنن الدارمی/المناسک ۴۲ (۱۹۰۶),,It was\nnarrated that Abu Tha’labah Al-Khushani said:,Chapters on Hunting
2944,"حَدَّثَنَا عَلِيُّ بْنُ الْمُنْذِرِ، حَدَّثَنَا مُحَمَّدُ بْنُ فُضَيْلٍ، حَدَّثَنَا بَيَانُ بْنُ بِشْرٍ، عَنِ الشَّعْبِيِّ، عَنْ عَدِيِّ بْنِ حَاتِمٍ، قَالَ سَأَلْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ فَقُلْتُ إِنَّا قَوْمٌ نَصِيدُ بِهَذِهِ الْكِلاَبِ ‏.‏ قَالَ ‏ ‏ إِذَا أَرْسَلْتَ كِلاَبَكَ الْمُعَلَّمَةَ وَذَكَرْتَ اسْمَ اللَّهِ عَلَيْهَا فَكُلْ مَا أَمْسَكْنَ عَلَيْكَ وَإِنْ قَتَلْنَ إِلاَّ أَنْ يَأْكُلَ الْكَلْبُ فَإِنْ أَكَلَ الْكَلْبُ فَلاَ تَأْكُلْ فَإِنِّي أَخَافُ أَنْ يَكُونَ إِنَّمَا أَمْسَكَ عَلَى نَفْسِهِ وَإِنْ خَالَطَهَا كِلاَبٌ أُخَرُ فَلاَ تَأْكُلْ ‏""""‏ ‏.‏ قَالَ ابْنُ مَاجَهْ سَمِعْتُهُ - يَعْنِي عَلِيَّ بْنَ الْمُنْذِرِ - يَقُولُ حَجَجْتُ ثَمَانِيَةً وَخَمْسِينَ حِجَّةً أَكْثَرُهَا رَاجِلٌ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Hasan,takhreej: «سنن الترمذی/الحج ۱۱۳ (۹۶۱)،(تحفة الأشراف:۵۵۳۶)، وقد أخرجہ: مسند احمد (۱/۲۴۷،۲۶۶،۲۹۱،۳۰۷،۳۷۱)، سنن الدارمی/المناسک ۲۶ (۱۸۸۱),,It was\nnarrated that ‘Adi bin Hatim said:,Chapters on Hunting
2945,حَدَّثَنَا عَمْرُو بْنُ عَبْدِ اللَّهِ، حَدَّثَنَا وَكِيعٌ، عَنْ شَرِيكٍ، عَنْ حَجَّاجِ بْنِ أَرْطَاةَ، عَنِ الْقَاسِمِ بْنِ أَبِي بَزَّةَ، عَنْ سُلَيْمَانَ الْيَشْكُرِيِّ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، قَالَ نُهِينَا عَنْ صَيْدِ، كَلْبِهِمْ وَطَائِرِهِمْ يَعْنِي الْمَجُوسَ ‏.‏,Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۴۴۱، ومصباح الزجاجة:۱۰۳۶),2945,It was\nnarrated that Jabir bin ‘Abdullah said:,Chapters on Hunting
2946,"حَدَّثَنَا عَمْرُو بْنُ عَبْدِ اللَّهِ، حَدَّثَنَا وَكِيعٌ، عَنْ سُلَيْمَانَ بْنِ الْمُغِيرَةِ، عَنْ حُمَيْدِ بْنِ هِلاَلٍ، عَنْ عَبْدِ اللَّهِ بْنِ الصَّامِتِ، عَنْ أَبِي ذَرٍّ، قَالَ سَأَلْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ عَنِ الْكَلْبِ الأَسْوَدِ الْبَهِيمِ فَقَالَ ‏ ‏ شَيْطَانٌ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۴۰ (۱۲۶۸)، سنن النسائی/الحج ۱۵۷ (۲۹۵۲)،(تحفة الأشراف:۶۹۸۸)، وقد أخرجہ: صحیح البخاری/الحج ۵۹ (۱۶۱۱)، سنن ابی داود/الحج ۴۸ (۱۸۷۴)، مسند احمد (۲/۸۶،۱۱۴،۱۱۵)، سنن الدارمی/المناسک ۲۵ (۱۸۸۰),,It was\nnarrated that Abu Dharr said:,Chapters on Hunting
2947,"حَدَّثَنَا أَبُو عُمَيْرٍ، عِيسَى بْنُ مُحَمَّدٍ النَّحَّاسُ وَعِيسَى بْنُ يُونُسَ الرَّمْلِيُّ قَالاَ حَدَّثَنَا ضَمْرَةُ بْنُ رَبِيعَةَ، عَنِ الأَوْزَاعِيِّ، عَنْ يَحْيَى بْنِ سَعِيدٍ، عَنْ سَعِيدِ بْنِ الْمُسَيَّبِ، عَنْ أَبِي ثَعْلَبَةَ الْخُشَنِيِّ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ كُلْ مَا رَدَّتْ عَلَيْكَ قَوْسُكَ ‏""""‏ ‏.‏""",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الحج ۴۹ (۱۸۷۸)،(تحفة الأشراف:۱۵۹۰۹),,It was\nnarrated from Abu Tha’labah that the Prophet (ﷺ) said:,Chapters on Hunting
2948,"حَدَّثَنَا عَلِيُّ بْنُ الْمُنْذِرِ، حَدَّثَنَا مُحَمَّدُ بْنُ فُضَيْلٍ، حَدَّثَنَا مُجَالِدُ بْنُ سَعِيدٍ، عَنْ عَامِرٍ، عَنْ عَدِيِّ بْنِ حَاتِمٍ، قَالَ قُلْتُ يَا رَسُولَ اللَّهِ إِنَّا قَوْمٌ نَرْمِي ‏.‏ قَالَ ‏ ‏ إِذَا رَمَيْتَ وَخَزَقْتَ فَكُلْ مَا خَزَقْتَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحج ۵۸ (۱۶۰۷)،۶۱ (۱۶۱۲)،۶۲ (۱۶۱۳)،۷۴ (۱۶۳۲)، الطلاق ۲۴ (۵۲۹۳)، صحیح مسلم/الحج ۴۲ (۱۲۷۲)، سنن النسائی/المساجد ۲۱ (۷۱۴)، الحج ۱۵۹ (۲۹۵۷)،۱۶۰ (۲۹۵۸)،(تحفة الأشراف:۵۸۳۷)، وقد أخرجہ: سنن ابی داود/الحج ۴۹ (۱۸۷۷)، سنن الترمذی/الحج ۴۰ (۸۶۵)، مسند احمد (۱/۲۱۴،۲۳۷،۲۴۸،۳۰۴)، سنن الدارمی/المناسک ۲۶ (۱۸۸۱),,It was\nnarrated that ‘Adi bin Hatim said:,Chapters on Hunting
2949,"حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَنْبَأَنَا مَعْمَرٌ، عَنْ عَاصِمٍ، عَنِ الشَّعْبِيِّ، عَنْ عَدِيِّ بْنِ حَاتِمٍ، قَالَ قُلْتُ يَا رَسُولَ اللَّهِ أَرْمِي الصَّيْدَ فَيَغِيبُ عَنِّي لَيْلَةً قَالَ ‏ ‏ إِذَا وَجَدْتَ فِيهِ سَهْمَكَ وَلَمْ تَجِدْ فِيهِ شَيْئًا غَيْرَهُ فَكُلْهُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۳۹ (۱۲۶۵)، سنن ابی داود/الحج ۴۹ (۱۸۷۹)،(تحفة الأشراف:۵۰۵۱)، وقد أخرجہ: مسند احمد (۵/۴۵۴),,It was\nnarrated that ‘Adi bin Hatim said:,Chapters on Hunting
2950,"حَدَّثَنَا عَمْرُو بْنُ عَبْدِ اللَّهِ، حَدَّثَنَا وَكِيعٌ، ح وَحَدَّثَنَا عَلِيُّ بْنُ الْمُنْذِرِ، حَدَّثَنَا مُحَمَّدُ بْنُ فُضَيْلٍ، قَالاَ حَدَّثَنَا زَكَرِيَّا بْنُ أَبِي زَائِدَةَ، عَنْ عَامِرٍ، عَنْ عَدِيِّ بْنِ حَاتِمٍ، قَالَ سَأَلْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ عَنِ الصَّيْدِ بِالْمِعْرَاضِ ‏.‏ قَالَ ‏ ‏ مَا أَصَبْتَ بِحَدِّهِ فَكُلْ وَمَا أَصَبْتَ بِعَرْضِهِ فَهُوَ وَقِيذٌ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih Sahih Bukhari,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۷۹۷،۸۱۱۷، ومصباح الزجاجة:۱۰۳۷)، وقد أخرجہ: صحیح البخاری/الحج ۶۳ (۱۶۱۶)، صحیح مسلم/الحج ۳۹ (۱۲۶۲)، سنن ابی داود/الحج ۵۱ (۱۸۹۱)، سنن النسائی/الحج ۱۵۰ (۲۹۴۳)، موطا امام مالک/الحج ۳۴ (۸۰)، مسند احمد (۳/۱۳)، سنن الدارمی/المناسک ۲۷ (۱۸۸۳،۱۸۸۴),,It was\nnarrated that ‘Adi bin Hatim said:,Chapters on Hunting
2951,"حَدَّثَنَا عَمْرُو بْنُ عَبْدِ اللَّهِ، حَدَّثَنَا وَكِيعٌ، عَنْ أَبِيهِ، عَنْ مَنْصُورٍ، عَنْ إِبْرَاهِيمَ، عَنْ هَمَّامِ بْنِ الْحَارِثِ النَّخَعِيِّ، عَنْ عَدِيِّ بْنِ حَاتِمٍ، قَالَ سَأَلْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ عَنِ الْمِعْرَاضِ فَقَالَ ‏ ‏ لاَ تَأْكُلْ إِلاَّ أَنْ يَخْزِقَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۳۹ (۱۶۶۳)، سنن الترمذی/الحج ۳۳ (۸۵۶)، سنن النسائی/الحج ۱۵۴ (۲۹۴۷)،(تحفة الأشراف:۲۵۹۴)، وقد أخرجہ: سنن ابی داود/الحج ۵۱ (۱۸۹۱)، مسند احمد (۳/۳۲۰،۳۴۰،۳۹۴)، سنن الدارمی/المناسک ۲۷ (۱۸۸۲),,It was\nnarrated that ‘Adi bit Hatim said:,Chapters on Hunting
2952,"حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، حَدَّثَنَا مَعْنُ بْنُ عِيسَى، عَنْ هِشَامِ بْنِ سَعْدٍ، عَنْ زَيْدِ بْنِ أَسْلَمَ، عَنِ ابْنِ عُمَرَ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ مَا قُطِعَ مِنَ الْبَهِيمَةِ وَهِيَ حَيَّةٌ فَمَا قُطِعَ مِنْهَا فَهُوَ مَيْتَةٌ ‏""""‏ ‏.‏""",Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/المناسک ۵۱ (۱۸۸۷)،(تحفة الأشراف:۱۰۳۹۱)، وقد أخرجہ: مسند احمد (۱/۴۵),,It was\nnarrated from Ibn ‘Umar that the Prophet (ﷺ) said:,Chapters on Hunting
2953,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ عَيَّاشٍ، حَدَّثَنَا أَبُو بَكْرٍ الْهُذَلِيُّ، عَنْ شَهْرِ بْنِ حَوْشَبٍ، عَنْ تَمِيمٍ الدَّارِيِّ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ يَكُونُ فِي آخِرِ الزَّمَانِ قَوْمٌ يَجُبُّونَ أَسْنِمَةَ الإِبِلِ وَيَقْطَعُونَ أَذْنَابَ الْغَنَمِ أَلاَ فَمَا قُطِعَ مِنْ حَىٍّ فَهُوَ مَيِّتٌ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/المناسک ۵۱ (۱۸۹۰)، سنن الترمذی/الحج ۳۹ (۸۶۳)، سنن النسائی/الحج ۱۷۶ (۲۹۸۲)،(تحفة الأشراف:۵۷۷۷)، وقد أخرجہ: صحیح البخاری/الحج ۸۰ (۱۶۴۹)، المغازي ۴۳ (۴۲۵۷)، صحیح مسلم/الحج ۳۹ (۱۲۶۶)، مسند احمد (۱/۲۲۱،۲۵۵،۳۰۶،۳۱۰،۳۱۱،۳۷۳),,It was\nnarrated that Tamim Dari said:,Chapters on Hunting
2954,"حَدَّثَنَا أَبُو مُصْعَبٍ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ زَيْدِ بْنِ أَسْلَمَ، عَنْ أَبِيهِ، عَنْ عَبْدِ اللَّهِ بْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ أُحِلَّتْ لَنَا مَيْتَتَانِ الْحُوتُ وَالْجَرَادُ ‏""""‏ ‏.‏""",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/المناسک ۵۰ (۱۸۸۳)، سنن الترمذی/الحج ۳۶ (۸۵۹)،(تحفة الأشراف:۱۱۸۳۹)، وقد أخرجہ: مسند احمد (۴/۲۲۲،۲۲۳،۲۲۴)، سنن الدارمی/المناسک ۲۸ (۱۸۸۵),,It was\nnarrated from ‘Abdullah bin ‘Umar that the Messenger of Allah\n(ﷺ) said:,Chapters on Hunting
2955,"حَدَّثَنَا أَبُو بِشْرٍ، بَكْرُ بْنُ خَلَفٍ وَنَصْرُ بْنُ عَلِيٍّ قَالاَ حَدَّثَنَا زَكَرِيَّا بْنُ يَحْيَى بْنِ عُمَارَةَ، حَدَّثَنَا أَبُو الْعَوَّامِ، عَنْ أَبِي عُثْمَانَ النَّهْدِيِّ، عَنْ سَلْمَانَ، قَالَ سُئِلَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنِ الْجَرَادِ فَقَالَ ‏ ‏ أَكْثَرُ جُنُودِ اللَّهِ لاَ آكُلُهُ وَلاَ أُحَرِّمُهُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحج ۴۲ (۱۵۸۴)، أحادیث الأنبیاء ۱۰ (۳۳۶۸)، تفسیر البقرة ۱۰ (۴۴۸۴)، صحیح مسلم/الحج ۶۹ (۱۳۳۳)، سنن النسائی/الحج ۱۲۸ (۲۹۱۳)،(تحفة الأشراف:۱۶۰۰۵)، وقد أخرجہ: موطا امام مالک/الحج ۳۳ (۱۰۴)، سنن الدارمی/المناسک ۴۴ (۱۹۱۱),,It was\nnarrated that Salman said:,Chapters on Hunting
2956,حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ أَبِي سَعْدٍ الْبَقَّالِ، سَمِعَ أَنَسَ بْنَ مَالِكٍ، يَقُولُ كُنَّ أَزْوَاجُ النَّبِيِّ ـ صلى الله عليه وسلم ـ يَتَهَادَيْنَ الْجَرَادَ عَلَى الأَطْبَاقِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۳۳۱، ومصباح الزجاجة:۱۰۳۹)، وقد أخرجہ: سنن الترمذی/الحج ۱۱۱ (۹۵۹)، سنن النسائی/الحج ۱۳۴ (۲۹۲۲)، مسند احمد (۲/۳،۱۱،۹۵),2956,It was\nnarrated that Abu (Sa’eed) Baqqal heard Anas bin Malik say:,Chapters on Hunting
2957,"حَدَّثَنَا هَارُونُ بْنُ عَبْدِ اللَّهِ الْحَمَّالُ، حَدَّثَنَا هَاشِمُ بْنُ الْقَاسِمِ، حَدَّثَنَا زِيَادُ بْنُ عَبْدِ اللَّهِ بْنِ عُلاَثَةَ، عَنْ مُوسَى بْنِ مُحَمَّدِ بْنِ إِبْرَاهِيمَ، عَنْ أَبِيهِ، عَنْ جَابِرٍ، وَأَنَسِ بْنِ مَالِكٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ كَانَ إِذَا دَعَا عَلَى الْجَرَادِ قَالَ ‏""‏ اللَّهُمَّ أَهْلِكْ كِبَارَهُ وَاقْتُلْ صِغَارَهُ وَأَفْسِدْ بَيْضَهُ وَاقْطَعْ دَابِرَهُ وَخُذْ بِأَفْوَاهِهَا عَنْ مَعَايِشِنَا وَأَرْزَاقِنَا إِنَّكَ سَمِيعُ الدُّعَاءِ ‏""‏ ‏.‏ فَقَالَ رَجُلٌ يَا رَسُولَ اللَّهِ كَيْفَ تَدْعُو عَلَى جُنْدٍ مِنْ أَجْنَادِ اللَّهِ بِقَطْعِ دَابِرِهِ قَالَ ‏""‏ إِنَّ الْجَرَادَ نَثْرَةُ الْحُوتِ فِي الْبَحْرِ ‏""‏ ‏.‏ قَالَ هَاشِمٌ قَالَ زِيَادٌ فَحَدَّثَنِي مَنْ رَأَى الْحُوتَ يَنْثُرُهُ ‏.‏",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۴۱۷۴، ومصباح الزجاجة:۱۰۳۸),2957,"It was\nnarrated from Jabir and Anas bin Malik that whenever the\nMessenger of\nAllah (ﷺ) supplicated against the locusts, he said:",Chapters on Hunting
2958,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا حَمَّادُ بْنُ سَلَمَةَ، عَنْ أَبِي الْمُهَزِّمِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ خَرَجْنَا مَعَ النَّبِيِّ ـ صلى الله عليه وسلم ـ فِي حَجَّةٍ أَوْ عُمْرَةٍ فَاسْتَقْبَلَنَا رِجْلٌ مِنْ جَرَادٍ أَوْ ضَرْبٌ مِنْ جَرَادٍ فَجَعَلْنَا نَضْرِبُهُنَّ بِأَسْوَاطِنَا وَنِعَالِنَا فَقَالَ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏ ‏ كُلُوهُ فَإِنَّهُ مِنْ صَيْدِ الْبَحْرِ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الحج ۸۹ (۲۰۱۶)، سنن النسائی/القبلة ۹ (۷۵۹)، الحج ۱۶۲ (۲۹۶۲)،(تحفة الأشراف:۱۱۲۸۵)، وقد أخرجہ: مسند احمد (۶/۳۹۹),,It was\nnarrated that Abu Hurairah said:,Chapters on Hunting
2959,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، وَعَبْدُ الرَّحْمَنِ بْنُ عَبْدِ الْوَهَّابِ، قَالاَ حَدَّثَنَا أَبُو عَامِرٍ الْعَقَدِيُّ، حَدَّثَنَا إِبْرَاهِيمُ بْنُ الْفَضْلِ، عَنْ سَعِيدٍ الْمَقْبُرِيِّ، عَنْ أَبِي هُرَيْرَةَ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنْ قَتْلِ الصُّرَدِ وَالضِّفْدَعِ وَالنَّمْلَةِ وَالْهُدْهُدِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحج ۱۰۴ (۱۶۹۱)، صحیح مسلم/الحج ۲۸ (۱۲۳۴)، سنن النسائی/الحج ۱۴۲ (۲۹۳۳)،(تحفة الأشراف:۷۳۵۲)، وقد أخرجہ: سنن ابی داود/الحج ۲۴ (۱۸۰۵)، موطا امام مالک/الحج ۳۷ (۱۱۶)، مسند احمد (۲/۱۵،۸۵،۱۵۲،۳/۳۰۹)، سنن الدارمی/المناسک ۸۴ (۱۹۷۲),2959,It was\nnarrated that Abu Hurairah said:,Chapters on Hunting
2960,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَنْبَأَنَا مَعْمَرٌ، عَنِ الزُّهْرِيِّ، عَنْ عُبَيْدِ اللَّهِ بْنِ عَبْدِ اللَّهِ بْنِ عُتْبَةَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنْ قَتْلِ أَرْبَعٍ مِنَ الدَّوَابِّ النَّمْلَةِ وَالنَّحْلِ وَالْهُدْهُدِ وَالصُّرَدِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الحروف ۱ (۳۹۶۹)، سنن الترمذی/الحج ۳۸ (۸۵۶)، سنن النسائی/الحج ۱۶۳ (۲۹۶۴)،(تحفة الأشراف:۲۵۹۵)، وقد أخرجہ: صحیح مسلم/الحج ۱۵ (۱۲۶۳)، سنن الدارمی/المناسک ۳۴ (۱۸۹۲),2960,It was\nnarrated that Ibn ‘Abbas said:,Chapters on Hunting
2961,"حَدَّثَنَا أَحْمَدُ بْنُ عَمْرِو بْنِ السَّرْحِ، وَأَحْمَدُ بْنُ عِيسَى الْمِصْرِيَّانِ، قَالاَ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، أَخْبَرَنِي يُونُسُ، عَنِ ابْنِ شِهَابٍ، عَنْ سَعِيدِ بْنِ الْمُسَيَّبِ، وَأَبِي، سَلَمَةَ بْنِ عَبْدِ الرَّحْمَنِ عَنْ أَبِي هُرَيْرَةَ، عَنْ نَبِيِّ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ إِنَّ نَبِيًّا مِنَ الأَنْبِيَاءِ قَرَصَتْهُ نَمْلَةٌ فَأَمَرَ بِقَرْيَةِ النَّمْلِ فَأُحْرِقَتْ فَأَوْحَى اللَّهُ عَزَّ وَجَلَّ إِلَيْهِ فِي أَنْ قَرَصَتْكَ نَمْلَةٌ أَهْلَكْتَ أُمَّةً مِنَ الأُمَمِ تُسَبِّحُ ‏""""‏ ‏.‏ حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا أَبُو صَالِحٍ، حَدَّثَنِي اللَّيْثُ، عَنْ يُونُسَ، عَنِ ابْنِ شِهَابٍ، بِإِسْنَادِهِ نَحْوَهُ وَقَالَ قَرَصَتْ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الصلاة ۷۸ (۴۶۴)، الحج ۶۴ (۱۶۱۹)،۷۱ (۱۶۲۶)،۷۴ (۱۶۳۳)، تفسیرالطور ۱ (۴۸۵۳)، صحیح مسلم/الحج ۴۲ (۱۲۷۶)، سنن ابی داود/الحج ۴۹ (۱۸۸۲)، سنن النسائی/الحج ۱۳۸ (۲۹۲۸)،(تحفة الأشراف:۱۸۲۶۲)، وقد أخرجہ: موطا امام مالک/الحج ۴۰ (۱۲۳)، مسند احمد (۶/۲۹۰،۳۱۹),,It was\nnarrated from Abu Hurairah that the Prophet of Allah (ﷺ)\nsaid:,Chapters on Hunting
2962,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا إِسْمَاعِيلُ ابْنُ عُلَيَّةَ، عَنْ أَيُّوبَ، عَنْ سَعِيدِ بْنِ جُبَيْرٍ، أَنَّ قَرِيبًا، لِعَبْدِ اللَّهِ بْنِ مُغَفَّلٍ خَذَفَ فَنَهَاهُ وَقَالَ إِنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ نَهَى عَنِ الْخَذْفِ وَقَالَ ‏ ‏ إِنَّهَا لاَ تَصِيدُ صَيْدًا وَلاَ تَنْكَأُ عَدُوًّا وَلَكِنَّهَا تَكْسِرُ السِّنَّ وَتَفْقَأُ الْعَيْنَ ‏""""‏ ‏.‏ قَالَ فَعَادَ ‏.‏ فَقَالَ أُحَدِّثُكَ أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ نَهَى عَنْهُ ثُمَّ عُدْتَ لاَ أُكَلِّمُكَ أَبَدًا ‏.‏""",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: سنن ابی داود/المناسک ۵۵ (۱۸۹۹)،(تحفة الأشراف:۸۷۷۶),,It was\nnarrated from Sa’eed bin Jubair that a relative of ‘Abdullah\nbin\nMughaffal threw some small pebbles. He told him not to do that and\nsaid:,Chapters on Hunting
2963,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عُبَيْدُ بْنُ سَعِيدٍ، ح وَحَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، قَالاَ حَدَّثَنَا شُعْبَةُ، عَنْ قَتَادَةَ، عَنْ عُقْبَةَ بْنِ صُهْبَانَ، عَنْ عَبْدِ اللَّهِ بْنِ مُغَفَّلٍ، قَالَ نَهَى النَّبِيُّ ـ صلى الله عليه وسلم ـ عَنِ الْخَذْفِ وَقَالَ ‏ ‏ إِنَّهَا لاَ تَقْتُلُ الصَّيْدَ وَلاَ تَنْكِي الْعَدُوَّ وَلَكِنَّهَا تَفْقَأُ الْعَيْنَ وَتَكْسِرُ السِّنَّ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحیض ۱ (۲۹۴)، الأضاحي ۳ (۵۵۴۸)،۱۰ (۵۵۵۹)، صحیح مسلم/الحج ۱۷ (۱۲۱۱)، سنن ابی داود/الحج ۲۳ (۱۷۷۸)، سنن النسائی/الحج ۵۸ (۲۷۶۴)،(تحفة الأشراف:۱۷۴۸۲)، وقد أخرجہ: موطا امام مالک/الحج ۷۴ (۲۲۳)، مسند احمد (۳/۳۹۴)، سنن الدارمی/المناسک ۶۲ (۱۹۴۵),,It was\nnarrated that ‘Abdullah bin Mughaffal said:,Chapters on Hunting
2964,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عَبْدِ الْحَمِيدِ بْنِ جُبَيْرٍ، عَنْ سَعِيدِ بْنِ الْمُسَيَّبِ، عَنْ أُمِّ شَرِيكٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ أَمَرَهَا بِقَتْلِ الأَوْزَاغِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۱۷ (۱۲۱۱)، سنن ابی داود/الحج ۲۳ (۱۷۷۷)، سنن الترمذی/الحج ۱۰ (۸۲۰)، سنن النسائی/الحج ۴۸ (۲۷۱۶)،(تحفة الأشراف:۱۷۵۱۷)، وقد أخرجہ: موطا امام مالک/الحج ۱۱ (۳۷)، مسند احمد (۶/۲۴۳)، سنن الدارمی/المناسک ۱۶ (۱۸۵۳),2964,,Chapters on Hunting
2965,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الْمَلِكِ بْنِ أَبِي الشَّوَارِبِ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ الْمُخْتَارِ، حَدَّثَنَا سُهَيْلٌ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، عَنْ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ مَنْ قَتَلَ وَزَغًا فِي أَوَّلِ ضَرْبَةٍ فَلَهُ كَذَا وَكَذَا حَسَنَةً وَمَنْ قَتَلَهَا فِي الثَّانِيَةِ فَلَهُ كَذَا وَكَذَا - أَدْنَى مِنَ الأُولَى - وَمَنْ قَتَلَهَا فِي الضَّرْبَةِ الثَّالِثَةِ فَلَهُ كَذَا وَكَذَا حَسَنَةً - أَدْنَى مِنَ الَّذِي ذَكَرَهُ فِي الْمَرَّةِ الثَّانِيَةِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحج ۳۴ (۱۵۶۲)، المغازي ۷۸ (۴۴۰۸)، صحیح مسلم/الحج ۱۷ (۱۲۱۱)، سنن ابی داود/المناسک ۲۳ (۱۷۷۹،۱۷۸۰)، سنن النسائی/المناسک ۴۸ (۲۷۱۷)،(تحفة الأشراف:۱۶۳۸۹)، وقد أخرجہ: مسند احمد (۶/۳۶،۱۰۴،۱۰۷،۲۴۳),,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Hunting
2966,"حَدَّثَنَا أَحْمَدُ بْنُ عَمْرِو بْنِ السَّرْحِ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، أَخْبَرَنِي يُونُسُ، عَنِ ابْنِ شِهَابٍ، عَنْ عُرْوَةَ بْنِ الزُّبَيْرِ، عَنْ عَائِشَةَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ لِلْوَزَغِ ‏ ‏ الْفُوَيْسِقَةُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۶۳۸، ومصباح الزجاجة:۱۰۴۰),,It was\nnarrated from ‘Aishah that the Messenger of Allah (ﷺ) said\nconcerning house lizards:,Chapters on Hunting
2967,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يُونُسُ بْنُ مُحَمَّدٍ، عَنْ جَرِيرِ بْنِ حَازِمٍ، عَنْ نَافِعٍ، عَنْ سَائِبَةَ، - مَوْلاَةِ الْفَاكِهِ بْنِ الْمُغِيرَةِ - أَنَّهَا دَخَلَتْ عَلَى عَائِشَةَ فَرَأَتْ فِي بَيْتِهَا رُمْحًا مَوْضُوعًا فَقَالَتْ يَا أُمَّ الْمُؤْمِنِينَ مَا تَصْنَعِينَ بِهَذَا قَالَتْ نَقْتُلُ بِهِ هَذِهِ الأَوْزَاغَ فَإِنَّ نَبِيَّ اللَّهِ ـ صلى الله عليه وسلم ـ أَخْبَرَنَا أَنَّ إِبْرَاهِيمَ لَمَّا أُلْقِيَ فِي النَّارِ لَمْ تَكُنْ فِي الأَرْضِ دَابَّةٌ إِلاَّ أَطْفَأَتِ النَّارَ غَيْرَ الْوَزَغِ فَإِنَّهَا كَانَتْ تَنْفُخُ عَلَيْهِ فَأَمَرَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ بِقَتْلِهِ ‏.‏,Al-Albani: Daif Isnaad; Muhammad Fouad Abd al-Baqi: Daif Isnaad; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۰۶۸، ومصباح الزجاجة:۱۰۴۱),2967,"It was\nnarrated from Sa’ibah, the freed slave woman of Fakih bin\nMughirah,\nthat she entered upon ‘Aishah and saw a spear in her house.\nShe\nsaid:",Chapters on Hunting
2968,حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، أَنْبَأَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ الزُّهْرِيِّ، أَخْبَرَنِي أَبُو إِدْرِيسَ، عَنْ أَبِي ثَعْلَبَةَ الْخُشَنِيِّ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ نَهَى عَنْ أَكْلِ كُلِّ ذِي نَابٍ مِنَ السِّبَاعِ ‏.‏ قَالَ الزُّهْرِيُّ وَلَمْ أَسْمَعْ بِهَذَا حَتَّى دَخَلْتُ الشَّامَ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۳۴ (۱۲۵۱)، سنن ابی داود/الحج ۲۴ (۱۷۹۵)، سنن النسائی/الحج ۴۹ (۲۷۳۰)،(تحفة الأشراف:۱۶۵۳)، وقد أخرجہ: سنن الترمذی/الحج ۱۱ (۸۲۱)، مسند احمد (۳/۹۹،۲۸۲)، سنن الدارمی/المناسک ۷۸ (۱۹۶۵),2968,,Chapters on Hunting
2969,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا مُعَاوِيَةُ بْنُ هِشَامٍ، ح وَحَدَّثَنَا أَحْمَدُ بْنُ سِنَانٍ، وَإِسْحَاقُ بْنُ مَنْصُورٍ، قَالاَ حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، قَالاَ حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، عَنْ إِسْمَاعِيلَ بْنِ أَبِي حَكِيمٍ، عَنْ عَبِيدَةَ بْنِ سُفْيَانَ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ أَكْلُ كُلِّ ذِي نَابٍ مِنَ السِّبَاعِ حَرَامٌ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۲۴),,It was\nnarrated from Abu Hurairah that the Prophet (ﷺ) said:,Chapters on Hunting
2970,حَدَّثَنَا بَكْرُ بْنُ خَلَفٍ، حَدَّثَنَا ابْنُ أَبِي عَدِيٍّ، عَنْ سَعِيدٍ، عَنْ عَلِيِّ بْنِ الْحَكَمِ، عَنْ مَيْمُونِ بْنِ مِهْرَانَ، عَنْ سَعِيدِ بْنِ جُبَيْرٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ يَوْمَ خَيْبَرَ عَنْ أَكْلِ كُلِّ ذِي نَابٍ مِنَ السِّبَاعِ وَعَنْ كُلِّ ذِي مِخْلَبٍ مِنَ الطَّيْرِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن ابی داود/الحج ۲۴ (۱۷۹۸،۱۷۹۹)، سنن النسائی/الحج ۴۹ (۲۷۲۰،۲۷۷۱،۲۷۲۲)،(تحفة الأشراف:۱۰۴۶۶)، وقد أخرجہ: مسند احمد (۱/۱۴،۲۵،۳۴،۳۷،۵۳,2970,It was\nnarrated that Ibn ‘Abbas said:,Chapters on Hunting
2971,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَحْيَى بْنُ وَاضِحٍ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ، عَنْ عَبْدِ الْكَرِيمِ بْنِ أَبِي الْمُخَارِقِ، عَنْ حِبَّانَ بْنِ جَزْءٍ، عَنْ أَخِيهِ، خُزَيْمَةَ بْنِ جَزْءٍ قَالَ قُلْتُ يَا رَسُولَ اللَّهِ جِئْتُكَ لأَسْأَلَكَ عَنْ أَحْنَاشِ الأَرْضِ مَا تَقُولُ فِي الثَّعْلَبِ قَالَ ‏""‏ وَمَنْ يَأْكُلُ الثَّعْلَبَ ‏""‏ ‏.‏ قُلْتُ يَا رَسُولَ اللَّهِ مَا تَقُولُ فِي الذِّئْبِ قَالَ ‏""‏ وَيَأْكُلُ الذِّئْبَ أَحَدٌ فِيهِ خَيْرٌ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۷۸۰، ومصباح الزجاجة:۱۰۴۲)، وقد أخرجہ: مسند احمد (۴/۲۸،۲۹),2971,It was\nnarrated that Khuzaimah bin Jaz’ said:,Chapters on Hunting
2972,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، وَمُحَمَّدُ بْنُ الصَّبَّاحِ، قَالاَ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ رَجَاءٍ الْمَكِّيُّ، عَنْ إِسْمَاعِيلَ بْنِ أُمَيَّةَ، عَنْ عَبْدِ اللَّهِ بْنِ عُبَيْدِ بْنِ عُمَيْرٍ، عَنِ ابْنِ أَبِي عَمَّارٍ، - وَهُوَ عَبْدُ الرَّحْمَنِ - قَالَ سَأَلْتُ جَابِرَ بْنَ عَبْدِ اللَّهِ عَنِ الضَّبُعِ أَصَيْدٌ هُوَ قَالَ نَعَمْ ‏.‏ قُلْتُ آكُلُهَا قَالَ نَعَمْ ‏.‏ قُلْتُ أَشَىْءٌ سَمِعْتَ مِنْ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ نَعَمْ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۴۷۹، ومصباح الزجاجة:۱۰۴۳),2972,"It was\nnarrated that Ibn Abu ‘Ammar, who is ‘Abdur-Rahman, said:",Chapters on Hunting
2973,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَحْيَى بْنُ وَاضِحٍ، عَنِ ابْنِ إِسْحَاقَ، عَنْ عَبْدِ الْكَرِيمِ بْنِ أَبِي الْمُخَارِقِ، عَنْ حِبَّانَ بْنِ جَزْءٍ، عَنْ خُزَيْمَةَ بْنِ جَزْءٍ، قَالَ قُلْتُ يَا رَسُولَ اللَّهِ مَا تَقُولُ فِي الضَّبُعِ قَالَ ‏ ‏ وَمَنْ يَأْكُلُ الضَّبُعَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «تفردبہ ابن ماجہ،(تحفة الأشراف:۲۶۶۴)، وقد أخرجہ: مسند احمد (۳/۳۸۷),,It was\nnarrated that Khuzaimah bin Jaz’ said:,Chapters on Hunting
2974,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا مُحَمَّدُ بْنُ فُضَيْلٍ، عَنْ حُصَيْنٍ، عَنْ زَيْدِ بْنِ وَهْبٍ، عَنْ ثَابِتِ بْنِ يَزِيدَ الأَنْصَارِيِّ، قَالَ كُنَّا مَعَ النَّبِيِّ ـ صلى الله عليه وسلم ـ فَأَصَابَ النَّاسُ ضِبَابًا فَاشْتَوَوْهَا فَأَكَلُوا مِنْهَا فَأَصَبْتُ مِنْهَا ضَبًّا فَشَوَيْتُهُ ثُمَّ أَتَيْتُ بِهِ النَّبِيَّ ـ صلى الله عليه وسلم ـ فَأَخَذَ جَرِيدَةً فَجَعَلَ يَعُدُّ بِهَا أَصَابِعَهُ فَقَالَ ‏ ‏ إِنَّ أُمَّةً فِي بَنِي إِسْرَائِيلَ مُسِخَتْ دَوَابَّ فِي الأَرْضِ وَإِنِّي لاَ أَدْرِي لَعَلَّهَا هِيَ ‏""""‏ ‏.‏ فَقُلْتُ إِنَّ النَّاسَ قَدِ اشْتَوَوْهَا فَأَكَلُوهَا فَلَمْ يَأْكُلْ وَلَمْ يَنْهَ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۱۱۸، ومصباح الزجاجة:۱۰۴۴),,It was\nnarrated that Thabit bin Yazid Al-Ansari said:,Chapters on Hunting
2975,"حَدَّثَنَا أَبُو إِسْحَاقَ الْهَرَوِيُّ، إِبْرَاهِيمُ بْنُ عَبْدِ اللَّهِ بْنِ حَاتِمٍ حَدَّثَنَا إِسْمَاعِيلُ ابْنُ عُلَيَّةَ، عَنْ سَعِيدِ بْنِ أَبِي عَرُوبَةَ، عَنْ قَتَادَةَ، عَنْ سُلَيْمَانَ الْيَشْكُرِيِّ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ لَمْ يُحَرِّمِ الضَّبَّ وَلَكِنْ قَذِرَهُ وَإِنَّهُ لَطَعَامُ عَامَّةِ الرِّعَاءِ وَإِنَّ اللَّهَ عَزَّ وَجَلَّ لَيَنْفَعُ بِهِ غَيْرَ وَاحِدٍ وَلَوْ كَانَ عِنْدِي لأَكَلْتُهُ ‏.‏ حَدَّثَنَا أَبُو سَلَمَةَ، يَحْيَى بْنُ خَلَفٍ حَدَّثَنَا عَبْدُ الأَعْلَى، حَدَّثَنَا سَعِيدُ بْنُ أَبِي عَرُوبَةَ، عَنْ قَتَادَةَ، عَنْ سُلَيْمَانَ، عَنْ جَابِرٍ، عَنْ عُمَرَ بْنِ الْخَطَّابِ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ نَحْوَهُ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Muquf; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن الترمذی/الحج ۱۰۲ (۹۴۸)،(تحفة الأشراف:۸۰۲۹)، وقد أخرجہ: مسند احمد (۲/۶۷)، سنن الدارمی/النسک ۲۹ (۱۸۸۶),,It was\nnarrated from Jabir bin ‘Abdullah:,Chapters on Hunting
2976,"حَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ سُلَيْمَانَ، عَنْ دَاوُدَ بْنِ أَبِي هِنْدٍ، عَنْ أَبِي نَضْرَةَ، عَنْ أَبِي سَعِيدٍ الْخُدْرِيِّ، قَالَ نَادَى رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ رَجُلٌ مِنْ أَهْلِ الصُّفَّةِ حِينَ انْصَرَفَ مِنَ الصَّلاَةِ فَقَالَ يَا رَسُولَ اللَّهِ إِنَّ أَرْضَنَا أَرْضٌ مَضَبَّةٌ فَمَا تَرَى فِي الضِّبَابِ قَالَ ‏ ‏ بَلَغَنِي أَنَّهُ أُمَّةٌ مُسِخَتْ ‏""""‏ ‏.‏ فَلَمْ يَأْمُرْ بِهِ وَلَمْ يَنْهَ عَنْهُ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الحج ۱۶ (۱۵۳۴)، سنن ابی داود/الحج ۲۴ (۱۸۰۰)،(تحفة الأشراف:۱۰۵۱۳)، وقد أخرجہ: مسند احمد (۱/۲۴),,It was\nnarrated that Abu Sa’eed Al-Khudri said:,Chapters on Hunting
2977,"حَدَّثَنَا مُحَمَّدُ بْنُ الْمُصَفَّى الْحِمْصِيُّ، حَدَّثَنَا مُحَمَّدُ بْنُ حَرْبٍ، حَدَّثَنَا مُحَمَّدُ بْنُ الْوَلِيدِ الزُّبَيْدِيُّ، عَنِ الزُّهْرِيِّ، عَنْ أَبِي أُمَامَةَ بْنِ سَهْلِ بْنِ حُنَيْفٍ، عَنْ عَبْدِ اللَّهِ بْنِ عَبَّاسٍ، عَنْ خَالِدِ بْنِ الْوَلِيدِ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ أُتِيَ بِضَبٍّ مَشْوِيٍّ فَقُرِّبَ إِلَيْهِ فَأَهْوَى بِيَدِهِ لِيَأْكُلَ مِنْهُ فَقَالَ لَهُ مَنْ حَضَرَهُ يَا رَسُولَ اللَّهِ إِنَّهُ لَحْمُ ضَبٍّ ‏.‏ فَرَفَعَ يَدَهُ عَنْهُ فَقَالَ لَهُ خَالِدٌ يَا رَسُولَ اللَّهِ أَحَرَامٌ الضَّبُّ قَالَ ‏ ‏ لاَ وَلَكِنَّهُ لَمْ يَكُنْ بِأَرْضِي فَأَجِدُنِي أَعَافُهُ ‏""""‏ ‏.‏ قَالَ فَأَهْوَى خَالِدٌ إِلَى الضَّبِّ فَأَكَلَ مِنْهُ وَرَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ يَنْظُرُ إِلَيْهِ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۸۱۵، ومصباح الزجاجة:۱۰۴۵)، سنن النسائی/الحج ۷۷ (۲۸۰۸)، مسند احمد (۴/۱۷۵),,"It was\nnarrated from Khalid bin Walid that a grilled mastigure was\nbrought\nto the Messenger of Allah (ﷺ) and placed near him. He\nstretched out\nhis hand to eat (some of it), then those who were\npresent said:",Chapters on Hunting
2978,"حَدَّثَنَا مُحَمَّدُ بْنُ الْمُصَفَّى، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عَبْدِ اللَّهِ بْنِ دِينَارٍ، عَنِ ابْنِ عُمَرَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لاَ أُحَرِّمُ ‏""""‏ ‏.‏ يَعْنِي الضَّبَّ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۲۳ (۱۲۲۶)،(تحفة الأشراف:۱۰۸۵۶)، وقد أخرجہ: صحیح البخاری/الحج ۳۶ (۱۵۷۱)، تفسیر البقرة ۳۳ (۴۵۱۸)، سنن النسائی/الحج ۴۹ (۲۷۲۸)، مسند احمد (۴/۴۲۷،۴۲۸،۴۲۹،۴۳۴،۴۳۶،۴۳۸)، سنن الدارمی/النسک ۱۸ (۱۸۵۵),,It was\nnarrated from Ibn ‘Umar that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Hunting
2979,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، وَعَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، قَالاَ حَدَّثَنَا شُعْبَةُ، عَنْ هِشَامِ بْنِ زَيْدٍ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ مَرَرْنَا بِمَرِّ الظَّهْرَانِ فَأَنْفَجْنَا أَرْنَبًا فَسَعَوْا عَلَيْهَا فَلَغَبُوا فَسَعَيْتُ حَتَّى أَدْرَكْتُهَا فَأَتَيْتُ بِهَا أَبَا طَلْحَةَ فَذَبَحَهَا فَبَعَثَ بِعَجُزِهَا وَوَرِكِهَا إِلَى النَّبِيِّ ـ صلى الله عليه وسلم ـ فَقَبِلَهَا ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۲۲ (۱۲۲۱)، سنن النسائی/الحج ۵۰ (۲۷۳۶)،(تحفة الأشراف:۱۰۵۸۴)، وقد أخرجہ: مسند احمد (۱/۴۹)، سنن الدارمی/النسک ۱۸ (۱۸۵۶),2979,It was\nnarrated that Anas bin Malik said:,Chapters on Hunting
2980,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، أَنْبَأَنَا دَاوُدُ بْنُ أَبِي هِنْدٍ، عَنِ الشَّعْبِيِّ، عَنْ مُحَمَّدِ بْنِ صَفْوَانَ، أَنَّهُ مَرَّ عَلَى النَّبِيِّ ـ صلى الله عليه وسلم ـ بِأَرْنَبَيْنِ مُعَلِّقَهُمَا فَقَالَ يَا رَسُولَ اللَّهِ إِنِّي أَصَبْتُ هَذَيْنِ الأَرْنَبَيْنِ فَلَمْ أَجِدْ حَدِيدَةً أُذَكِّيهِمَا بِهَا فَذَكَّيْتُهُمَا بِمَرْوَةٍ أَفَآكُلُ قَالَ ‏ ‏ كُلْ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «سنن ابی داود/المناسک ۲۳ (۱۷۸۷)،(تحفة الأشراف:۲۴۲۶)، وقد أخرجہ: صحیح مسلم/الحج ۱۷ (۱۲۱۶)، سنن النسائی/الحج ۷۷ (۲۸۰۷),,it was\nnarrated from Muhammad bin Safwan that he passed by the\nProphet (ﷺ)\nwith two rabbits hanging down. He said:,Chapters on Hunting
2981,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَحْيَى بْنُ وَاضِحٍ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ، عَنْ عَبْدِ الْكَرِيمِ بْنِ أَبِي الْمُخَارِقِ، عَنْ حِبَّانَ بْنِ جَزْءٍ، عَنْ أَخِيهِ، خُزَيْمَةَ بْنِ جَزْءٍ قَالَ قُلْتُ يَا رَسُولَ اللَّهِ جِئْتُكَ لأَسْأَلَكَ عَنْ أَحْنَاشِ الأَرْضِ مَا تَقُولُ فِي الضَّبِّ قَالَ ‏""‏ لاَ آكُلُهُ وَلاَ أُحَرِّمُهُ ‏""‏ ‏.‏ قَالَ قُلْتُ فَإِنِّي آكُلُ مِمَّا لَمْ تُحَرِّمْ وَلِمَ يَا رَسُولَ اللَّهِ قَالَ ‏""‏ فُقِدَتْ أُمَّةٌ مِنَ الأُمَمِ وَرَأَيْتُ خَلْقًا رَابَنِي ‏""‏ ‏.‏ قُلْتُ يَا رَسُولَ اللَّهِ مَا تَقُولُ فِي الأَرْنَبِ قَالَ لاَ آكُلُهُ وَلاَ أُحَرِّمُهُ ‏""‏ ‏.‏ قُلْتُ فَإِنِّي آكُلُ مِمَّا لَمْ تُحَرِّمْ وَلِمَ يَا رَسُولَ اللَّهِ قَالَ ‏""‏ نُبِّئْتُ أَنَّهَا تَدْمَى ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحج ۳۴ (۱۵۶۱)،۱۱۵ (۱۷۰۹)،۱۲۴ (۱۷۲۰)، الجہاد ۱۰۵ (۲۹۵۲)، صحیح مسلم/الحج ۱۷ (۱۲۱۱)، سنن النسائی/الحج ۱۶ (۲۶۵۱)،۷۷ (۲۸۰۵،۲۸۰۶)،(تحفة الأشراف:۱۷۹۳۳)، وقد أخرجہ: سنن ابی داود/الحج ۲۳ (۱۷۸۱)، موطا امام مالک/الحج ۵۸ (۱۷۹)، مسند احمد (۶/۱۲۲،۲۶۶،۲۷۳),2981,It was\nnarrated that Khuzaimah bin Jaz’ said:,Chapters on Hunting
2982,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، حَدَّثَنِي صَفْوَانُ بْنُ سُلَيْمٍ، عَنْ سَعِيدِ بْنِ سَلَمَةَ، مِنْ آلِ ابْنِ الأَزْرَقِ أَنَّ الْمُغِيرَةَ بْنَ أَبِي بُرْدَةَ، - وَهُوَ مِنْ بَنِي عَبْدِ الدَّارِ - حَدَّثَهُ أَنَّهُ، سَمِعَ أَبَا هُرَيْرَةَ، يَقُولُ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ الْبَحْرُ الطَّهُورُ مَاؤُهُ الْحِلُّ مَيْتَتُهُ ‏""""‏ ‏.‏ قَالَ أَبُو عَبْدِ اللَّهِ بَلَغَنِي عَنْ أَبِي عُبَيْدَةَ الْجَوَادِ أَنَّهُ قَالَ هَذَا نِصْفُ الْعِلْمِ لأَنَّ الدُّنْيَا بَرٌّ وَبَحْرٌ فَقَدْ أَفْتَاكَ فِي الْبَحْرِ وَبَقِيَ الْبَرُّ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۹۰۷، ومصباح الزجاجة:۱۰۴۶)، وقد أخرجہ:(۴/۲۸۶),,"Mughirah\nbin Abu Burdah, who was of the tribe of Banu ‘Abd-Dar,\nnarrated\nthat he heard Abu Hurairah say:",Chapters on Hunting
2983,"حَدَّثَنَا أَحْمَدُ بْنُ عَبْدَةَ، حَدَّثَنَا يَحْيَى بْنُ سُلَيْمٍ الطَّائِفِيُّ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ أُمَيَّةَ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَا أَلْقَى الْبَحْرُ أَوْ جَزَرَ عَنْهُ فَكُلُوهُ وَمَا مَاتَ فِيهِ فَطَفَا فَلاَ تَأْكُلُوهُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۲۹ (۱۲۳۶)، سنن النسائی/الحج ۱۸۶ (۲۹۹۵)،(تحفة الأشراف:۱۵۷۳۹)، وقد أخرجہ: مسند احمد (۶/۳۵۱),,It was\nnarrated from Jabir bin ‘Abdullah that the Messenger of Allah\n(ﷺ)\nsaid:,Chapters on Hunting
2984,"حَدَّثَنَا أَحْمَدُ بْنُ الأَزْهَرِ النَّيْسَابُورِيُّ، حَدَّثَنَا الْهَيْثَمُ بْنُ جَمِيلٍ، حَدَّثَنَا شَرِيكٌ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ أَبِيهِ، عَنِ ابْنِ عُمَرَ، قَالَ مَنْ يَأْكُلُ الْغُرَابَ وَقَدْ سَمَّاهُ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ فَاسِقًا ‏""""‏ ‏.‏ وَاللَّهِ مَا هُوَ مِنَ الطَّيِّبَاتِ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الحج ۲۵ (۱۸۰۸)، سنن النسائی/الحج ۷۷ (۲۸۱۰)،(تحفة الأشراف:۲۰۲۷)، وقد أخرجہ: مسند احمد (۳/۴۶۹)، سنن الدارمی/المناسک ۳۷ (۱۸۹۷),,It was\nnarrated that Ibn ‘Umar said:,Chapters on Hunting
2985,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا الأَنْصَارِيُّ، حَدَّثَنَا الْمَسْعُودِيُّ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ الْقَاسِمِ بْنِ مُحَمَّدِ بْنِ أَبِي بَكْرٍ الصِّدِّيقِ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏""‏ الْحَيَّةُ فَاسِقَةٌ وَالْعَقْرَبُ فَاسِقَةٌ وَالْفَأْرَةُ فَاسِقَةٌ وَالْغُرَابُ فَاسِقٌ ‏""‏ ‏.‏ فَقِيلَ لِلْقَاسِمِ أَيُؤْكَلُ الْغُرَابُ قَالَ مَنْ يَأْكُلُهُ بَعْدَ قَوْلِ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ ‏""‏ فَاسِقٌ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۲۳ (۱۲۲۴)، موقوفاً، سنن النسائی/الحج ۷۷ (۲۸۱۱،۲۸۱۲،۲۸۱۳)،(تحفة الأشراف:۱۱۹۹۵),2985,It was\nnarrated from ‘Aishah that the Messenger of Allah (ﷺ) said:,Chapters on Hunting
2986,حَدَّثَنَا الْحُسَيْنُ بْنُ مَهْدِيٍّ، أَنْبَأَنَا عَبْدُ الرَّزَّاقِ، أَنْبَأَنَا عُمَرُ بْنُ زَيْدٍ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنْ أَكْلِ الْهِرَّةِ وَثَمَنِهَا‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «تفرد بہ ابن ماجہ:(تحفة الأشراف:۱۶۸۲۰)، وقد أخرجہ: صحیح البخاری/الحج ۷۹ (۱۶۴۳)، العمرة ۱۰ (۱۷۹۰)، تفسیر البقرة ۲۱ (۴۴۹۵)، تفسیر النجم ۳ (۴۸۶۱)، صحیح مسلم/الحج ۴۳ (۱۲۷۷)، سنن ابی داود/الحج ۵۶ (۱۹۰۱)، سنن الترمذی/تفسیر البقرة (۲۹۶۹)، سنن النسائی/الحج ۱۶۸ (۲۹۷۰)، موطا امام مالک/الحج ۴۲ (۱۲۹)، مسند احمد (۳/۱۴۴،۱۶۲،۲۲۷),2986,It was\nnarrated that Jabir said:,Chapters on Hunting
3200,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا شَبَابَةُ، ‏‏‏‏‏‏حَدَّثَنَا شُعْبَةُ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «صحیح مسلم/الطہارة ۲۷ (۲۸۰)، سنن ابی داود/الطہارة ۳۷ (۷۴)، سنن النسائی/الطہارة ۵۳ (۶۷)، المیاہ ۷ (۳۳۷،۳۳۸)،(تحفة الأشراف:۹۶۶۵)، وقد أخرجہ: مسند احمد (۴/۸۶،۵/۵۶)، سنن الدارمی/الصید ۲ (۲۰۴۹),3200,,Chapters on Hunting
3201,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا عُثْمَانُ بْنُ عُمَرَ، ‏‏‏‏‏‏ح وحَدَّثَنَا مُحَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: انظر ما قبلہ,3201,,Chapters on Hunting
3202,حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، ‏‏‏‏‏‏أَنْبَأَنَا مَالِكُ بْنُ أَنَسٍ، ‏‏‏‏‏‏عَنْ نَافِعٍ، ‏‏‏‏‏‏ع,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/بدء الخلق ۱۷ (۳۳۲۳)، صحیح مسلم/المساقاة ۱۰ (۱۵۷۰)، سنن النسائی/الصید والذبائح ۹ (۴۲۸۲)،(تحفة الأشراف:۸۳۴۹)، وقد أخرجہ: سنن الترمذی/الصید ۱۷ (۱۴۸۷)، موطا امام مالک/لإستئذان ۵ (۱۴)، مسند احمد (۲/۲۲،۲۳،۱۱۳،۱۳۲،۱۴۶)، سنن الدارمی/الصید ۳ (۲۰۵۰),3202,,Chapters on Hunting
3203,حَدَّثَنَا أَبُو طَاهِرٍ، ‏‏‏‏‏‏حَدَّثَنَا ابْنُ وَهْبٍ، ‏‏‏‏‏‏أَخْبَرَنِي يُونُسُ، ‏‏‏‏‏‏عَنْ ابْنِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن النسائی/الصید ۹ (۴۲۸۳)،(تحفة الأشراف:۷۰۰۲),3203,,Chapters on Hunting
3204,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، ‏‏‏‏‏‏حَدَّثَنَا الْأَو,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/المساقاة ۱۰ (۱۵۷۵)،(تحفة الأشراف:۱۵۳۹۰)، وقد أخرجہ: صحیح البخاری/الحرث ۳ (۲۳۲۳)، بدء الخلق ۱۷ (۳۳۲۴)، سنن ابی داود/الصید ۱ (۲۸۴۴)، سنن الترمذی/الصید ۱۷ (۱۴۹۰)، سنن النسائی/الصید ۱۴ (۴۲۹۴)، مسند احمد (۲/۲۶۷،۳۴۵),3204,,Chapters on Hunting
3205,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا أَحْمَدُ بْنُ عَبْدِ اللَّهِ، ‏‏‏‏‏‏عَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الصید ا (۲۸۴۵مختصراً)، سنن الترمذی/الأحکام ۳ (۱۴۸۶مختصراً) سنن النسائی/الصید ۱۰ (۴۳۸۵)،(تحفة الأشراف:۹۶۴۹)، وقد أخرجہ: مسند احمد (۴/۸۵،۸۶،۵/۵۴،۵۶،۵۷، سنن الدارمی/الصید ۲ (۲۰۴۹),3205,,Chapters on Hunting
3206,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ، ‏‏‏‏‏‏حَدَّثَنَ,Al-Albani: Sahih Hadith; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحرث ۳ (۲۳۲۳)، بدء الخلق ۱۷ (۳۳۲۵)، صحیح مسلم/المساقاة ۱۰ (۱۵۷۶)، سنن النسائی/الصید ۱۲ (۴۲۹۰)،(تحفة الأشراف:۴۴۷۶)، وقد أخرجہ: موطا امام مالک/الإستئذان ۵ (۱۲)، مسند احمد (۵/۲۱۹،۲۲۰)، سنن الدارمی/الصید ۲ (۲۰۴۸),3206,,Chapters on Hunting
3207,حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، ‏‏‏‏‏‏حَدَّثَنَا الضَّحَّاكُ بْنُ مَخْلَدٍ، ‏‏‏‏‏‏حَدَّثَنَا,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الصید ۴ (۵۴۷۸)،۱۰ (۵۴۸۸)،۱۴ (۵۴۹۶)، صحیح مسلم/الصید ۱ (۱۹۳۰)، سنن ابی داود/الصید ۲ (۲۸۵۵)، سنن الترمذی/والسیر ۱۱ (۱۵۶۰)، سنن النسائی/الصید ۴ (۴۲۷۱)،(تحفة الأشرف:۱۱۸۷۵)، وقد أخرجہ: مسند احمد (۴/۱۹۳،۱۹۴،۱۹۵)، سنن الدارمی/السیر ۵۶ (۲۵۴۱),3207,,Chapters on Hunting
3208,حَدَّثَنَا عَلِيُّ بْنُ الْمُنْذِرِ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ فُضَيْلٍ، ‏‏‏‏‏‏حَدَّثَنَا بَيَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الوضو ۳۳ (۱۷۵)، البیوع ۳ (۲۰۵۴)، الصید ۱ (۵۴۷۵)،۲ (۵۴۷۶)،۳ (۵۴۷۷)،۷ (۵۴۸۳)،۹ (۵۴۸۴)،۱۰ (۵۴۸۵)، صحیح مسلم/الصید ۱ (۱۹۲۹)، سنن ابی داود/الصید ۲ (۲۸۴۸)،(تحفة الأشراف:۹۸۵۵)، وقد أخرجہ: سنن الترمذی/الصید ۱ (۱۴۵۶)، سنن النسائی/الصید ۲ (۴۲۶۹)، مسند احمد (۴/۲۵۶،۲۵۷،۲۵۸،۳۷۷،۳۷۹،۳۸۰)، سنن الدارمی/الصید ۱ (۲۰۴۵),3208,,Chapters on Hunting
3209,حَدَّثَنَا عَمْرُو بْنُ عَبْدِ اللَّهِ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏عَنْ شَرِيكٍ، ‏‏‏‏‏‏عَنْ حَج,Al-Albani: Daif Isnaad; Muhammad Fouad Abd al-Baqi: Daif Isnaad; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۲۷۱، ومصباح الزجاجة:۱۱۰۳)، وقد أخرجہ: سنن الترمذی/الصید ۲ (۱۴۶۶),3209,,Chapters on Hunting
3210,حَدَّثَنَا عَمْرُو بْنُ عَبْدِ اللَّهِ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏عَنْ سُلَيْمَانَ بْنِ الْمُغ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «صحیح مسلم/الصلاة ۵۰ (۵۱۰)، سنن ابی داود/الصلاة ۱۱۱ (۷۰۲)، سنن الترمذی/الصلاة ۱۳۷ (۳۳۸)، سنن النسائی/القبلة ۷ (۷۵۱)،(تحفة الأشراف:۱۱۹۳۹)، وقد أخرجہ: مسند احمد (۵/۱۴۹،۱۵۱،۱۵۵،۱۵۸،۱۶۰،۱۶۱)، سنن الدارمی/الصلاة ۱۲۸ (۱۴۵۴),3210,,Chapters on Hunting
3211,حَدَّثَنَا أَبُو عُمَيْرٍ عِيسَى بْنُ مُحَمَّدٍ النَّحَّاسُ، ‏‏‏‏‏‏ وَعِيسَى بْنُ يُونُسَ الرَّمْلِي,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۸۶۷),3211,,Chapters on Hunting
3212,حَدَّثَنَا عَلِيُّ بْنُ الْمُنْذِرِ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ فُضَيْلٍ، ‏‏‏‏‏‏حَدَّثَنَا مُجَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد ابن ماجة بھذاالسیاق (تحفة الأشراف:۹۸۶۸، ومصباح الزجاجة:۱۱۰۴)، قد أخرجہ: صحیح البخاری/البیوع ۳ (۲۰۵۴)، الذبائح ۳ (۵۴۷۷)، صحیح مسلم/الصید ۱ (۱۹۲۹)، سنن ابی داود/الصید ۲ (۲۸۴۷)، سنن الترمذی/الصید ۱ (۱۴۶۵)،۳ (۱۴۶۷)، سنن النسائی/الصید ۳ (۴۲۷۰)، مسند احمد (۴،۲۵۶،۲۵۸،۳۸۰)، سنن الدارمی/الصید ۱ (۲۰۴۶),3212,,Chapters on Hunting
3213,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الرَّزَّاقِ، ‏‏‏‏‏‏أَنْبَأَنَا مَعْمَرٌ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/ الذبائح ۸ (۵۴۸۴)، صحیح مسلم/الصید ۱ (۱۹۲۹)، سنن ابی داود/الصید ۲ (۲۸۴۹،۲۸۵۰)، سنن الترمذی/الصید ۳ (۱۴۶۹)، سنن النسائی/الصید ۱ (۴۲۶۸)،۶ (۴۲۷۳)،۸ (۴۲۷۹)،۱۸ (۴۳۰۳)،(تحفة الأشراف:۹۸۶۲),3213,,Chapters on Hunting
3214,حَدَّثَنَا عَمْرُو بْنُ عَبْدِ اللَّهِ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏ح وحَدَّثَنَا عَلِيُّ بْنُ ا,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الصید ۱ (۵۴۷۵)، صحیح مسلم/الصید ۱ (۱۹۲۹)، سنن الترمذی/الصید ۷ (۱۴۷۱)،(تحفة الأشراف:۹۸۶۰)، وقد أخرجہ: مسند احمد (۴/۲۵۶،۳۷۹، سنن الدارمی/الصید ۱ (۲۰۴۵),3214,,Chapters on Hunting
3215,حَدَّثَنَا عَمْرُو بْنُ عَبْدِ اللَّهِ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏عَنْ أَبِيهِ، ‏‏‏‏‏‏عَنْ مَن,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الصید ۳ (۵۴۷۷)، التوحید ۱۳ (۷۳۹۷)، صحیح مسلم/الصید ۱ (۱۹۲۹)، سنن الترمذی/الصید ا (۱۴۶۵)، سنن النسائی/الصید ۳ (۴۲۷۰)،(تحفة الأشراف:۹۸۷۸)، وقد أخرجہ: مسند احمد (۴/۲۵۶،۲۵۸،۳۷۷،۳۸۰),3215,,Chapters on Hunting
3216,حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، ‏‏‏‏‏‏حَدَّثَنَا مَعْنُ بْنُ عِيسَى، ‏‏‏‏‏‏عَنْ هِش,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۷۳۷، ومصباح الزجاجة:۱۱۰۵),3216,,Chapters on Hunting
3217,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا إِسْمَاعِيل بْنُ عَيَّاشٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو,Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۰۶۰، ومصباح الزجاجة:۱۱۰۶),3217,,Chapters on Hunting
3218,حَدَّثَنَا أَبُو مُصْعَبٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ زَيْدِ بْنِ أَسْلَمَ، ‏‏‏‏‏‏عَنْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۷۳۸، ومصباح الزجاجة:۱۱۰۷)، وقد أخرجہ: مسند احمد (۲/۹۷),3218,,Chapters on Hunting
3219,حَدَّثَنَا أَبُو بِشْرٍ بَكْرُ بْنُ خَلَفٍ، ‏‏‏‏‏‏ وَنَصْرُ بْنُ عَلِيٍّ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَن,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الأطعمة ۳۵ (۳۸۱۳،۳۸۱۴)،(تحفة الأشراف:۴۴۹۵),3219,,Chapters on Hunting
3220,حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏عَنْ أَبِي سَعِي,Al-Albani: Daif Isnaad; Muhammad Fouad Abd al-Baqi: Daif Isnaad; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۶۴، ومصباح الزجاجة:۱۱۰۸),3220,,Chapters on Hunting
3221,حَدَّثَنَا هَارُونُ بْنُ عَبْدِ اللَّهِ الْحَمَّالُ، ‏‏‏‏‏‏حَدَّثَنَا هَاشِمُ بْنُ الْقَاسِمِ، ‏‏‏‏‏,Al-Albani: Mawdu; Muhammad Fouad Abd al-Baqi: Mawdu; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۴۵۱،۲۵۸۵)، ومصباح الزجاجة:۱۱۰۹، وقد أخرجہ: سنن الترمذی/الأطعمة ۲۳ (۱۸۲۳),3221,,Chapters on Hunting
3222,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏حَدَّثَنَا حَمَّادُ ابْنُ سَلَمَة,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/المناسک ۴۲ (۱۸۵۴)، سنن الترمذی/الحج ۲۷ (۸۵۰)،(تحفة الأشراف:۱۴۸۳۲)، وقد أخرجہ: مسند احمد (۲/۳۰۶،۳۶۴،۳۷۴،۴۰۷),3222,,Chapters on Hunting
3223,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، ‏‏‏‏‏‏ وَعَبْدُ الرَّحْمَنِ بْنُ عَبْدِ الْوَهَّابِ، ‏‏‏‏‏‏قَالَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۹۴۴، ومصباح الزجاجة:۱۱۱۰),3223,,Chapters on Hunting
3224,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الرَّزَّاقِ، ‏‏‏‏‏‏أَنْبَأَنَا مَعْمَرٌ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الأدب ۱۶۴ (۵۲۶۷)،(تحفة الأشراف:۵۸۵۰)، وقد أخرجہ: مسند احمد (۱/۳۳۲،۳۴۷)، سنن الدارمی/الأضاحي ۲۶ (۲۱۴۲),3224,,Chapters on Hunting
3225,حَدَّثَنَا أَحْمَدُ بْنُ عَمْرِو بْنِ السَّرْحِ، ‏‏‏‏‏‏ وَأَحْمَدُ بْنُ عِيسَى الْمِصْرِيَّانِ، ‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الجہاد ۱۵۳ (۳۰۱۹)، بدء الخلق ۱۶ (۳۳۱۹)، صحیح مسلم/السلام ۳۹ (۲۲۴۱)، سنن ابی داود/الأدب ۱۷۶ (۵۲۶۶)، سنن النسائی/الصید والذبائح ۳۸ (۴۳۶۳)،(تحفة الأشراف:۱۳۳۱۹،۱۵۳۰۷)، وقد أخرجہ: مسند احمد (۲/۴۰۳),3225,,Chapters on Hunting
3226,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا إِسْمَاعِيل ابْنُ عُلَيَّةَ، ‏‏‏‏‏‏عَن,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «صحیح البخاری/الذبائح ۵ (۵۴۷۹)، الأدب ۱۲۲ (۶۲۲۰)، صحیح مسلم/الصید ۵۴ (۱۹۵۴)، سنن ابی داود/الأدب ۱۶۸ (۵۲۷۰)،(تحفة الأشراف:۹۶۵۷)، وقد أخرجہ: مسند احمد (۴/۸۴،۵/۵۴)، سنن الدارمی/المقدمة ۴۰ (۴۵۴),3226,,Chapters on Hunting
3227,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا عُبَيْدُ بْنُ سَعِيدٍ، ‏‏‏‏‏‏ح وحَدَّث,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/التفسیر ۵ (۴۸۴۱)، الأدب ۱۲۲ (۶۲۲۰)، صحیح مسلم/الصید ۱۰ (۱۹۵۴)، سنن ابی داود/الأدب ۱۷۸ (۵۲۷۰)،(تحفة الأشراف:۹۶۶۳)، وقد أخرجہ: سنن النسائی/القسامة ۳۳ (۴۸۱۹)، مسند احمد (۴/۸۶،۵/۴۶،۵۴،۵۵،۵۶،۵۷),3227,,Chapters on Hunting
3228,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏عَنْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/بدء الخلق ۱۵ (۳۳۰۷)، أحادیث الأنبیاء ۸ (۳۳۵۹)، صحیح مسلم/السلام ۳۸ (۲۲۳۷)، سنن النسائی/الحج ۱۱۵ (۲۸۸۸)،(تحفة الأشراف:۱۸۳۲۹)، وقد أخرجہ: مسند احمد (۶/۴۲۱،۴۶۲)، سنن الدارمی/الأضاحی ۲۷ (۲۰۴۳),3228,,Chapters on Hunting
3229,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الْمَلِكِ بْنِ أَبِي الشَّوَارِبِ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْعَزِي,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «تفرد بہ ابن ماجہ:(تحفةالأشراف:۱۲۷۳۱)، وقد أخرجہ: صحیح مسلم/السلام ۳۸ (۲۲۴۰)، سنن ابی داود/الأدب ۱۷۵ (۵۲۶۳)، سنن الترمذی/الأحکام ۱ (۱۴۸۲)، مسند احمد (۲/۳۵۵),3229,,Chapters on Hunting
3230,حَدَّثَنَا أَحْمَدُ بْنُ عَمْرِو بْنِ السَّرْحِ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، ‏‏‏‏‏‏,Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/جزاء الصید ۷ (۱۸۳۱)، بدء الخلق ۱۵ (۳۳۰۶)، صحیح مسلم/السلام ۳۸ (۲۲۴۰)، سنن النسائی/الحج ۱۱۵ (۲۸۸۹)،(تحفة الأشراف:۱۶۶۹۶)، وقد أخرجہ: مسند احمد (۶/۸۷،۱۵۵،۲۷۱،۲۷۹),3230,,Chapters on Hunting
3231,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا يُونُسُ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏عَنْ جَر,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۷۸۴۳، ومصباح الزجاجة:۱۱۱۱)، وقد أخرجہ: مسند احمد (۶/۸۳،۱۰۹),3231,,Chapters on Hunting
3232,حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، ‏‏‏‏‏‏أَنْبَأَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏عَنْ الزُّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الصید ۲۹ (۵۵۳۰)، الطب ۵۷ (۵۷۸۰)، صحیح مسلم/الصید ۳ (۱۹۳۲)، سنن ابی داود/الاطعمة ۳۳ (۳۸۰۲)، سنن الترمذی/الصید ۱۱ (۱۴۷۷)، سنن النسائی/الصید ۲۸ (۴۳۳۰)،(تحفة الأشراف:۱۱۸۷۴)، وقد أخرجہ: موطا امام مالک/الصید ۴ (۱۳)، مسند احمد (۴/۱۹۳،۱۹۴)، سنن الدارمی/الأضاحي ۱۸ (۲۰۲۳),3232,,Chapters on Hunting
3233,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا مُعَاوِيَةُ بْنُ هِشَامٍ، ‏‏‏‏‏‏ح وحَد,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «سنن النسائی/الصید ۲۸ (۴۳۲۹)،(تحفة الأشراف:۱۴۱۳۲)، وقد أخرجہ: موطا امام مالک/الصید ۴ (۱۴)، صحیح مسلم/الصید ۳ (۱۹۳۳)، سنن الترمذی/الصید ۳ (۱۴۶۷)، مسند احمد (۲/۴۱۸),3233,,Chapters on Hunting
3234,حَدَّثَنَا بَكْرُ بْنُ خَلَفٍ، ‏‏‏‏‏‏حَدَّثَنَا ابْنُ أَبِي عَدِيٍّ، ‏‏‏‏‏‏عَنْ سَعِيدٍ، ‏‏‏‏‏‏عَنْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الأطعمة ۳۳ (۳۸۰۵)، سنن النسائی/الصید ۳۳ (۴۳۵۳)،(تحفة الأشراف:۵۶۳۹)، وقد أخرجہ: صحیح مسلم/الصید ۳ (۱۹۳۴)، مسند احمد (۱/۲۴۴)، سنن الدارمی/الأضاحی ۱۸ (۲۰۲۵),3234,,Chapters on Hunting
3235,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا يَحْيَى بْنُ وَاضِحٍ، ‏‏‏‏‏‏عَنْ مُحَم,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۵۳۳، ومصباح الزجاجة:۱۱۱۲)، وقد أخرجہ: سنن الترمذی/الأطعمة ۴ (۱۷۹۲)، مقتصراً علی الجملة الأخیرة),3235,,Chapters on Hunting
3236,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏ وَمُحَمَّدُ بْنُ الصَّبَّاحِ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَا,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الأطعمة ۳۲ (۳۸۰۱)، سنن الترمذی/الحج ۲۸ (۸۵۱)، الأطعمة ۴ (۱۷۹۲)، سنن النسائی/الحج ۸۹ (۲۸۳۹)، الصید ۲۷ (۴۳۲۸)،(تحفة الأشراف:۲۳۸۱)، وقد أخرجہ: مسند احمد (۳/۲۹۷،۳۱۸)، سنن الدارمی/المناسک۹۰ (۱۹۸۴),3236,,Chapters on Hunting
3237,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا يَحْيَى بْنُ وَاضِحٍ، ‏‏‏‏‏‏عَنْ ابْنِ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/الأطعمة ۴ (۱۷۹۲)،(تحفة الأشراف:۳۵۳۳),3237,,Chapters on Hunting
3238,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ فُضَيْلٍ، ‏‏‏‏‏‏عَنْ حُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الأطعمة ۲۸ (۳۷۹۵)، سنن النسائی/الصید والذبائح ۲۶ (۴۳۲۵)،(تحفة الأشراف:۲۰۶۹)، وقد أخرجہ: مسند احمد (۴/۲۲۰)، سنن الدارمی/الصید ۸ (۲۰۵۹),3238,,Chapters on Hunting
3239,حَدَّثَنَا أَبُو إِسْحَاق الْهَرَوِيُّ إِبْرَاهِيمُ بْنُ عَبْدِ اللَّهِ بْنِ حَاتِمٍ، ‏‏‏‏‏‏حَدَّثَن,Al-Albani: Daif Isnaad; Muhammad Fouad Abd al-Baqi: Daif Isnaad; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۲۷۳، ومصباح الزجاجة:۱۱۱۳),3239,,Chapters on Hunting
3240,حَدَّثَنَا أَبُو كُرَيْبٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ سُلَيْمَانَ، ‏‏‏‏‏‏عَنْ دَاوُدَ ب,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الصید والذبائح ۷ (۱۹۵۱)،(تحفة الأشراف:۴۳۱۵)، وقد أخرجہ: مسند احمد (۳/۵،۱۹،۶۶),3240,,Chapters on Hunting
3241,حَدَّثَنَا مُحَمَّدُ بْنُ الْمُصَفَّى الْحِمْصِيُّ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ حَرْبٍ، ‏‏‏‏‏‏حَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الأطعمة ۱۰ (۵۳۹۱)،۱۴ (۵۴۰۰)، الذبائح ۳۳ (۵۵۳۷)، صحیح مسلم/الذبائح ۷ (۱۹۴۶)، سنن ابی داود/الأطعمة ۲۸ (۳۷۹۴)، سنن النسائی/الصید و الذبائح ۲۶ (۴۳۲۱)،(تحفة الأشراف:۳۵۰۴)، وقد أخرجہ: موطا امام مالک/الإستئذان ۴ (۱۰)، مسند احمد (۴/۸۸،۸۹)، سنن الدارمی/الصید ۸ (۲۰۶۰),3241,,Chapters on Hunting
3242,حَدَّثَنَا مُحَمَّدُ بْنُ الْمُصَفَّى، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏عَنْ عَبْدِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۱۷۸)، وقد أخرجہ: صحیح البخاری/الصید ۳۳ اتم منہ (۵۵۳۶)، صحیح مسلم/الصید ۷ اتم منہ (۱۹۴۳)، سنن الترمذی/الأطعمة ۳ (۱۷۹۰)، موطا امام مالک/الإستئذان ۴ (۱۱)، مسند احمد (۲/۹،۱۰،۳۳،۴۱،۴۶،۶۰،۶۲،۷۴،۱۱۵)، سنن الدارمی/الصید ۸ (۲۰۵۸),3242,,Chapters on Hunting
3243,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، ‏‏‏‏‏‏ وَعَبْدُ الرَّح,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الہبة ۵ (۲۵۷۲)، الصید ۱۰ (۵۴۸۹)،۳۲ (۵۵۳۵)، صحیح مسلم/الصید ۹ (۱۹۵۳)، سنن ابی داود/الأطعمة ۲۷ (۳۷۹۱)، سنن الترمذی/الأطعمة ۲ (۱۷۹۰)، سنن النسائی/الصید ۲۵ (۴۳۱۷)،(تحفة الأشراف:۱۶۲۹)، وقد أخرجہ: مسند احمد (۳/۱۱۸،۱۷۱،۲۹۱)، سنن الدارمی/الصید ۷ (۲۰۵۶),3243,,Chapters on Hunting
3244,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، ‏‏‏‏‏‏أَنْبَأَن,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الضحایا ۱۵ (۲۸۲۲)، سنن النسائی/الصید و الذبائح ۲۵ (۴۳۱۸)،(تحفة الأشراف:۱۱۲۲۴)، وقد أخرجہ: مسند احمد (۳/۴۷۱)، سنن الدارمی/الصید ۷ (۲۰۵۷),3244,,Chapters on Hunting
3245,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا يَحْيَى بْنُ وَاضِحٍ، ‏‏‏‏‏‏عَنْ مُحَم,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۵۳۳، ومصباح الزجاجة:۱۱۱۴),3245,,Chapters on Hunting
3246,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، ‏‏‏‏‏‏حَدَّثَنِي صَفْوَانُ ب,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الطہارة ۴۱ (۸۳)، سنن الترمذی/الطہارة ۵۲ (۶۹)، سنن النسائی/الطہارة ۴۷ (۵۹)، الصید ۳۵ (۴۳۶۱)،(تحفة الأشراف:۱۴۶۱۸)، وقد أخرجہ: موطا امام مالک/الطہارة ۳ (۱۲)، مسند احمد (۲/۳۷،۳۶۱،۳۷۳)، سنن الدارمی/الطہارة ۵۲ (۷۵۵),3246,,Chapters on Hunting
3247,حَدَّثَنَا أَحْمَدُ بْنُ عَبْدَةَ، ‏‏‏‏‏‏حَدَّثَنَا يَحْيَى بْنُ سُلَيْمٍ الطَّائِفِيُّ، ‏‏‏‏‏‏حَدَّ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الأطعمة ۳۶ (۳۸۱۵)،(تحفة الأشراف:۲۶۵۷),3247,,Chapters on Hunting
3248,حَدَّثَنَا أَحْمَدُ بْنُ الْأَزْهَرِ النَّيْسَابُورِيُّ، ‏‏‏‏‏‏حَدَّثَنَا الْهَيْثَمُ بْنُ جَمِيلٍ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۳۲۶، ومصباح الزجاجة:۱۱۱۵),3248,,Chapters on Hunting
3249,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا الْأَنْصَارِيُّ، ‏‏‏‏‏‏حَدَّثَنَا الْمَسْعُودِي,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفردبہ ابن ماجہ،(تحفة الأشراف:۱۷۴۹۸، ومصباح الزجاجة:۱۱۱۶)، وقد أخرجہ: مسند احمد (۶/۲۰۹،۲۳۸),3249,,Chapters on Hunting
3250,حَدَّثَنَا الْحُسَيْنُ بْنُ مَهْدِيٍّ، ‏‏‏‏‏‏أَنْبَأَنَا عَبْدُ الرَّزَّاقِ، ‏‏‏‏‏‏أَنْبَأَنَا عُمَر,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/البیوع ۶۴ (۳۴۸۰)، سنن الترمذی/البیوع ۴۹ (۱۲۸۰)،(تحفة الأشراف:۲۸۹۴),3250,,Chapters on Hunting
