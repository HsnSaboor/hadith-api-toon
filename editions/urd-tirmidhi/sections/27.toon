hadiths[141]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
1897,معاویہ بن حیدہ قشیری رضی الله عنہ کہتے ہیں کہ  میں نے عرض کیا اللہ کے رسول! میں کس کے ساتھ نیک سلوک ,,,,,1897
1898,"عبداللہ بن مسعود رضی الله عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم سے پوچھا: اللہ کے رسو",,,,,1898
1899,"ابو الدرداء رضی الله عنہ کہتے ہیں کہ  ایک آدمی نے ان کے پاس آ کر کہا: میری ایک بیوی ہے، اور میری م",,,,,1899
1900,"عبداللہ بن عمرو رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”رب کی رضا والد ",,,,,1900
1901,"ابوبکرہ نفیع بن حارث رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”کیا میں تم ل",,,,,1901
1902,"۲- عبداللہ بن عمرو رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اپنے ماں باپ",,,,,1902
1903,"عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا: ”",,,,,1903
1904,"براء بن عازب رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”خالہ ماں کے درجہ",,,,,1904
1904,"براء بن عازب رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”خالہ ماں کے درجہ",,,,,1904
1904,"براء بن عازب رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”خالہ ماں کے درجہ",,,,,1904
1905,۲- اس سند سے  نبی اکرم صلی اللہ علیہ وسلم سے اسی جیسی حدیث مروی ہے، لیکن اس میں ابن عمر کے واسطہ کا ,,,,,1905
1906,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”تین دعائیں مقبول ہوتی ہی",,,,,1906
1907,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”کوئی لڑکا اپنے باپ کا اح",,,,,1907
1908,ابوسلمہ کہتے ہیں کہ  ابوالرداد لیثی بیمار ہو گئے، عبدالرحمٰن بن عوف رضی الله عنہ ان کی عیادت کو گئے،,,,,,1908
1909,"عبداللہ بن عمرو رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”صلہ رحمی کرنے و",,,,,1909
1910,"جبیر بن مطعم رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”رشتہ ناتا توڑنے والا",,,,,1910
1911,خولہ بنت حکیم رضی الله عنہا کہتی ہیں کہ  ایک دن رسول اللہ صلی اللہ علیہ وسلم گود میں اپنی بیٹی  ( فا,,,,,1911
1912,"ابو سعید خدری رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”تم میں سے کسی کے",,,,,1912
1913,"ام المؤمنین عائشہ رضی الله عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جو شخص لڑکیوں ",,,,,1913
1914,"انس بن مالک رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے دو لڑکیوں کی کف",,,,,1914
1915,ام المؤمنین عائشہ رضی الله عنہا کہتی ہیں کہ  میرے پاس ایک عورت آئی اور اس کے ساتھ اس کی دو بچیاں تھ,,,,,1915
1916,"ابو سعید خدری رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس کے پاس تین لڑکیا",,,,,1916
1917,"عبداللہ بن عباس رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جو شخص کسی مس",,,,,1917
1918,"سہل بن سعد رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”میں اور یتیم کی کفالت ",,,,,1918
1919,انس بن مالک رضی الله عنہ کہتے ہیں کہ  ایک بوڑھا آیا، وہ نبی اکرم صلی اللہ علیہ وسلم سے ملنا چاہتا ت,,,,,1919
1920,"عبداللہ بن عمر رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”وہ شخص ہم میں سے ن",,,,,1920
1921,"عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”وہ شخص ہم میں س",,,,,1921
1922,"جریر بن عبداللہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جو شخص لوگوں پر م",,,,,1922
1923,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  میں نے ابوالقاسم صلی اللہ علیہ وسلم کو فرماتے سنا: ”صرف بدبخت ہی ",,,,,1923
1924,"عبداللہ بن عمرو رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”رحم کرنے والوں پر",,,,,1924
1925,جریر بن عبداللہ رضی الله عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم سے نماز قائم کرنے، زکا,,,,,1925
1926,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے تین مرتبہ فرمایا: ”دین سراپا خیر ",,,,,1926
1927,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”ایک مسلمان دوسرے مسلمان ",,,,,1927
1928,"ابوموسیٰ اشعری رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”ایک مومن دوسرے موم",,,,,1928
1929,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”تم میں سے ہر آدمی اپنے ",,,,,1929
1930,"ابوہریرہ رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جس نے کسی مسلمان کی کو",,,,,1930
1931,"ابو الدرداء رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جو شخص اپنے بھائی ک",,,,,1931
1932,"ابوایوب انصاری رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”کسی مسلمان کے ل",,,,,1932
1933,انس رضی الله عنہ کہتے ہیں کہ  جب عبدالرحمٰن بن عوف رضی الله عنہ  ( ہجرت کر کے )  مدینہ آئے تو نبی ا,,,,,1933
1934,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  کسی نے کہا: اللہ کے رسول! غیبت کیا ہے؟ آپ نے فرمایا: ”اس انداز سے",,,,,1934
1935,"انس رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”آپس میں قطع تعلق نہ کرو، ایک",,,,,1935
1936,"عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”صرف دو آدمیوں پ",,,,,1936
1937,"جابر رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”شیطان اس بات سے مایوس ہو چکا ",,,,,1937
1938,"ام کلثوم بنت عقبہ رضی الله عنہا کہتی ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا:",,,,,1938
1939,"اسماء بنت یزید رضی الله عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”صرف تین جگہ پر جھ",,,,,1939
1940,"ابوصرمہ رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جو دوسرے کو نقصان پہنچ",,,,,1940
1941,"ابوبکر صدیق رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”وہ شخص ملعون  ( یعنی ",,,,,1941
1942,"ام المؤمنین عائشہ رضی الله عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”مجھے جبرائیل ع",,,,,1942
1943,مجاہد سے روایت ہے کہ  عبداللہ بن عمرو بن العاص رضی الله عنہما کے لیے ان کے گھر میں ایک بکری ذبح کی گ,,,,,1943
1944,"عبداللہ بن عمرو رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اللہ کے نزدیک س",,,,,1944
1945,"ابوذر رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”تمہارے خادم تمہارے بھائی ہی",,,,,1945
1946,"ابوبکر رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”وہ شخص جنت میں داخل نہیں",,,,,1946
1947,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  نبی التوبہ ۱؎ ابوالقاسم صلی اللہ علیہ وسلم نے فرمایا: ”جو شخص اپن",,,,,1947
1948,ابومسعود انصاری رضی الله عنہ کہتے ہیں کہ  میں اپنے غلام کو مار رہا تھا کہ پیچھے سے کسی کہنے والے کی ,,,,,1948
1949,عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کے پاس ایک آدمی نے آ کر پوچ,,,,,1949
1950,"ابو سعید خدری رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جب تم میں سے کوئی ا",,,,,1950
1951,"جابر بن سمرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اپنے لڑکے کو ادب سکھ",,,,,1951
1952,"عمرو بن سعید بن عاص کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”حسن ادب سے بہتر کسی باپ نے",,,,,1952
1953,ام المؤمنین عائشہ رضی الله عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ہدیہ قبول کرتے تھے اور اس ,,,,,1953
1954,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جو لوگوں کا شکر یہ ادا ن",,,,,1954
1955,"ابو سعید خدری رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے لوگوں کا شکر ",,,,,1955
1956,"ابوذر رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اپنے بھائی کے سامنے تمہارا ",,,,,1956
1957,"براء بن عازب رضی الله عنہما کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا: ”جس",,,,,1957
1958,"ابوہریرہ رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”ایک آدمی راستے پر چل ",,,,,1958
1959,"جابر بن عبداللہ رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جب کوئی آدمی",,,,,1959
1960,"اسماء بنت ابوبکر رضی الله عنہما کہتی ہیں کہ  میں نے عرض کیا: اللہ کے رسول! میرے گھر میں صرف زبیر کی ",,,,,1960
1961,"ابوہریرہ رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”سخی آدمی اللہ سے قریب",,,,,1961
1962,"ابو سعید خدری رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”مومن کے اندر دو خصل",,,,,1962
1963,"ابوبکر صدیق رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”دھوکہ باز، احسان جت",,,,,1963
1964,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”مومن بھولا بھالا اور شری",,,,,1964
1965,"ابومسعود انصاری رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”آدمی کا اپنے ب",,,,,1965
1966,"ثوبان رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”سب سے بہتر دینار وہ دینار",,,,,1966
1967,ابوشریح عدوی رضی الله عنہ کہتے ہیں کہ  جب رسول اللہ صلی اللہ علیہ وسلم یہ حدیث بیان فرما رہے تھے تو ,,,,,1967
1968,"ابوشریح کعبی رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”ضیافت  ( مہمان نو",,,,,1968
1969,"صفوان بن سلیم نبی اکرم صلی اللہ علیہ وسلم سے مرفوعاً روایت کرتے ہیں کہ  آپ نے فرمایا: ”بیوہ اور مسکی",,,,,1969
1970,"جابر بن عبداللہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”ہر بھلائی صدقہ ہے",,,,,1970
1971,"عبداللہ بن مسعود رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”سچ بولو، اس لیے ",,,,,1971
1972,"عبداللہ بن عمر رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جب بندہ جھوٹ ب",,,,,1972
1973,ام المؤمنین عائشہ رضی الله عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے نزدیک جھوٹ سے بڑھ کر کو,,,,,1973
1974,"انس رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس چیز میں بھی بےحیائی آتی ہ",,,,,1974
1975,"عبداللہ بن عمرو رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”تم میں سب سے بہ",,,,,1975
