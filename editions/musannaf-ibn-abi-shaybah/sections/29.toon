hadiths[617]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}:
31679,"حَدَّثَنَا أَبُو عَبْدِ الرَّحْمَنِ ، قَالَ : حَدَّثَنَا أَبُو بَکْرِ بْنُ أَبِی شَیْبَۃَ ، قَالَ :\n\n حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الأَحْوَصِ ، قَالَ : قَالَ عَبْدُ اللہِ : مَنْ تَعَلَّمَ الْقُرْآنَ فَلْیَتَعَلَّمِ الْفَرَائِضَ ، وَلاَ یَکُنْ کَرَجُلٍ لَقِیَہُ أَعْرَابِیٌّ فَقَالَ لَہُ : أَمُہَاجِرٌ أَنْتَ یَا عَبْدَ اللہِ ، فَیَقُولُ : نَعَمْ ، فَیَقُولُ : إنَّ بَعْضَ أَہْلِی مَاتَ وَتَرَکَ کَذَا وَکَذَا ، فَإِنْ ہُوَ عَلِمَہُ فَعِلْمٌ آتَاہُ اللَّہُ إِیَّاہُ ، وَإِنْ کَانَ لاَ یُحْسِنُ فَیَقُولُ : فَبِمَ تَفْضُلُونَا یَا مَعْشَرَ الْمُہَاجِرِینَ؟۔ (بیہقی 209)",,,31679
31680,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الأَحْوَصِ ، عَنْ عَبْدِ اللہِ ، بِنَحْوِہِ۔",,,31680
31681,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ وَوَکِیعٌ، عَنِ الأَعْمَشِ، عَنْ إبْرَاہِیمَ، قَالَ: قَالَ عُمَرُ: تَعَلَّمُوا الْفَرَائِضَ فَإِنَّہَا مِنْ دِینِکُمْ۔",,,31681
31682,"حَدَّثَنَا وَکِیعٌ ، عَنْ زِیَاد بْنِ أَبِی مُسْلِمٍ ، عَنْ صَالِحٍ أَبِی الْخَلِیلِ ، عَنْ أَبِی مُوسَی ، قَالَ : مَثَلُ الَّذِی یَقْرَأُ الْقُرْآنَ ، وَلاَ یُحْسِنُ الْفَرَائِضَ کَالْیَدَیْنِ بِلاَ رَأْسٍ۔",,,31682
31683,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ صَالِحٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ اللہِ بْنِ قَیْسٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : مَنْ قَرَأَ سُورَۃَ النِّسَائِ ، فَعَلِمَ مَا یَحْجُبُ مِمَّا لاَ یَحْجُبُ عَلِمَ الْفَرَائِضَ۔",,,31683
31684,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ مُسْلِمٍ ، عَنْ مَسْرُوقٍ : أَنَّہُ قِیلَ لَہُ : ہَلْ کَانَتْ عَائِشَۃُ تُحْسِنُ الْفَرَائِضَ ، فَقَالَ : إی وَالَّذِی نَفْسِی بِیَدِہِ ، لَقَدْ رَأَیْت مَشْیَخَۃَ أَصْحَابِ مُحَمَّدٍ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الأَکَابِرَ یَسْأَلُونَہَا ، عَنِ الْفَرَائِضِ ؟",,,31684
31685,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، قَالَ : مَا رَأَیْت أَحَدًا أَعْلَمَ بِفَرِیضَۃٍ ، وَلاَ أَعْلَمَ بِفِقْہٍ وَلاَ بِشِعْرٍ : مِنْ عَائِشَۃَ۔",,,31685
31686,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مُوسَی بْنُ عُلَیِّ بْنِ رَبَاحٍ ، عَنْ أَبِیہِ : أَنَّ عُمَرَ خَطَبَ النَّاسَ بِالْجَابِیَۃِ فَحَمِدَ اللَّہَ وَأَثْنَی عَلَیْہِ ، ثُمَّ قَالَ : مَنْ أَحَبَّ أَنْ یَسْأَلَ عَنِ الْقُرْآنِ فَلِیَأْتِ أُبَیَّ بْنَ کَعْبٍ ، وَمَنْ أَحَبَّ أَنْ یَسْأَلَ عَنِ الْفَرَائِضِ فَلِیَأْتِ زَیْدَ بْنَ ثَابِتٍ۔",,,31686
31687,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الْمَسْعُودِیُّ ، عَنِ الْقَاسِمِ بْنِ عَبْدِ الرَّحْمَنِ ، قَالَ : قَالَ عَبْدُ اللہِ : تَعَلَّمُوا الْقُرْآنَ وَالْفَرَائِضَ ، فَإِنَّہُ یُوشِکُ أَنْ یَفْتَقِرَ الرَّجُلُ إلَی عِلْمٍ کَانَ یَعْلَمُہُ ، أَوْ یَبْقَی فِی قَوْمٍ لاَ یَعْلَمُونَ۔",,,31687
31688,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللہِ الْعُقَیْلِیُّ ، عَنْ أَبِی سَلَمَۃَ الْحِمْصِیِّ ، عَنْ سُلَیْمَانَ بْنِ مُوسَی ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ أَبْطَلَ مِیرَاثًا فَرَضَہُ اللَّہُ فِی کِتَابِہِ أَبْطَلَ اللَّہُ مِیرَاثَہُ مِنَ الْجَنَّۃِ۔ (سعید بن منصور 285)",,,31688
31689,"حَدَّثَنَا زَیْدُ بْنُ حَبَّابٍ ، قَالَ : أَخْبَرَنَا أَبُو سِنَانٍ ، قَالَ : حَدَّثَنِی أَبُو إِسْحَاقَ ، عَنْ عَمْرِو بْنِ مَیْمُونً ، قَالَ: کَانُوا إذَا اخْتَلَفُوا فِی فَرِیضَۃٍ أَتَوْا عَائِشَۃَ فَأَخْبَرَتْہُمْ بِہَا۔",,,31689
31690,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ، عَنِ الأَعْمَشِ، عَنْ إبْرَاہِیمَ ، قَالَ: قُلْتُ لِعَلْقَمَۃَ: عَلِّمْنِی الْفَرَائِضَ، قَالَ: ائْتِ جِیرَانَک۔",,,31690
31691,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنْ مُوَرِّقٍ ، قَالَ : قَالَ عُمَرُ : تَعَلَّمُوا اللَّحْنَ وَالْفَرَائِضَ وَالسُّنَّۃَ کَمَا تَعَلَّمُونَ الْقُرْآنَ۔",,,31691
31692,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ سَعْدِ بْنِ إِبْرَاہِیمَ ، عَن مَعْبَدٍ الْجَہْنَیِّ ، عَنْ مُعَاوِیَۃَ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : مَنْ یُرِدَ اللَّہُ بِہِ خَیْرًا یُفَقِّہْہُ فِی الدِّینِ۔ (بخاری 71۔ مسلم 718)",,,31692
31693,"حَدَّثَنَا یَعْلَی ، عَنْ عُثْمَانَ بْنِ حَکِیمٍ ، عَنْ مُحَمَّدِ بْنِ کَعْبٍ الْقُرَظِیِّ ، قَالَ : سَمِعْتُ مُعَاوِیَۃَ ابْنَ أَبِی سُفْیَانَ یَخْطُبُ یَقُولُ : سَمِعْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ عَلَی ہَذِہِ الأَعْوَادِ ، اللَّہُمَّ لاَ مَانِعَ لِمَا أَعْطَیْت ، وَلاَ مُعْطِیَ لِمَا مَنَعْت ، مَنْ یُرِدَ اللَّہُ بِہِ خَیْرًا یُفَقِّہْہُ فِی الدِّینِ۔ (احمد 95۔ مالک 900)",,,31693
31694,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ تَمِیمِ بْنِ سَلَمَۃَ ، عَنْ أَبِی عُبَیْدَۃَ ، قَالَ : قَالَ عَبْدُ اللہِ : مَنْ یُرِدَ اللَّہُ بِہِ خَیْرًا یُفَقِّہْہُ فِی الدِّینِ۔",,,31694
31695,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی سُفْیَانَ ، عَنْ عُبَیْدِ بْنِ عُمَیْرٍ ، قَالَ : إذَا أَرَادَ اللَّہُ بِعَبْدٍ خَیْرًا فَقَّہَہُ فِی الدِّینِ وَأَلْہَمَہُ رُشْدَہُ۔",,,31695
31696,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ مُحَمَّدِ بْنِ کَعْبٍ ، قَالَ : إذَا أَرَادَ اللَّہُ بِعَبْدٍ خَیْرًا ، فَقَّہَہُ فِی الدِّینِ ، وَزَہَّدَہُ فِی الدُّنْیَا ، وَبَصَّرَہُ عَیْبَہُ ، فَمَنْ أُوتِیَہُنَّ فَقَدْ أُوتِیَ خَیْرَ الدُّنْیَا وَالآخِرَۃِ۔",,,31696
31697,"حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ، عَنْ أَبِی الْمُہَلَّبِ : أَنَّ عُثْمَانَ سُئِلَ عَنْہَا ، فَقَالَ : لِلْمَرْأَۃِ الرُّبْعُ ، وَلِلأُمِّ ثُلُثُ مَا بَقِیَ ، وَسَائِرُ ذَلِکَ لِلأَبِ۔",,,31697
31698,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ : أَنَّ زَیْدَ بْنَ ثَابِتٍ سُئِلَ عَنِ امْرَأَۃٍ وَأَبَوَیْنِ ، فَأَعْطَی الْمَرْأَۃَ الرُّبْعَ ، وَالأُمَّ ثُلُثَ مَا بَقِیَ ، وَمَا بَقِیَ لِلأَبِ۔",,,31698
31699,"حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الشَّعْبِیِّ ، عَنْ عَلِیٍّ : فِی امْرَأَۃٍ وَأَبَوَیْنِ ، قَالَ : الرُّبْعُ ، وَثُلُثُ مَا بَقِیَ۔",,,31699
31700,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : أُتِیَ عَبْدُ اللہِ فِی امْرَأَۃٍ وَأَبَوَیْنِ ، فَقَالَ : إنَّ عُمَرَ کَانَ إذَا سَلِکَ طَرِیقًا فَسَلِکْنَاہُ وَجَدْنَاہُ سَہْلا ، وَإنَّہُ أُتِیَ فِی امْرَأَۃٍ وَأَبَوَیْنِ فَجَعَلَہَا مِنْ أَرْبَعَۃٍ ، فَأَعْطَی الْمَرْأَۃَ الرُّبْعَ ، وَالأُمَّ ثُلُثَ مَا بَقِی ، وَأَعْطَی الأَبَ سَائِرَ ذَلِکَ۔",,,31700
31701,حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عَنْ عَبْدِ اللہِ ، عَنْ عُمَرَ ، بِمِثْلِہِ۔,,,31701
31702,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الشَّعْبِیِّ ، عَنْ عَلِیٍّ : فِی امْرَأَۃٍ وَأَبَوَیْنِ : لِلْمَرْأَۃِ الرُّبْعُ وَلِلأُمِّ ثُلُثُ مَا بَقِیَ ، وَمَا بَقِیَ فَلِلأَبِ۔",,,31702
31703,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، عَنْ عَبْدِ اللہِ ، عَنْ عُمَرَ ، بِمِثْلِہِ ، إلاَّ أَنَّہُ قَالَ : أُتِیَ فِی امْرَأَۃٍ وَأَبَوَیْنِ۔",,,31703
31704,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، عَنْ عَبْدِ اللہِ : أَنَّہُ قَالَ : کَانَ عُمَرُ إذَا سَلِکَ طَرِیقًا فَسَلِکْنَاہُ وَجَدْنَاہُ سَہْلا ، فَسُئِلَ عَنْ زَوْجَۃٍ وَأَبَوَیْنِ ، فَقَالَ : لِلزَّوْجَۃِ الرُّبْعُ ، وَلِلأُمِّ ثُلُثُ مَا بَقِیَ ، وَمَا بَقِیَ فَلِلأَبِ۔",,,31704
31705,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ أَبِیہِ ، عَنْ فُضَیْلٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : خَالَفَ ابْنُ عَبَّاسٍ أَہْلَ الصَّلاَۃِ فِی امْرَأَۃٍ وَأَبَوَیْنِ وَزَوْجٍ ، قَالَ : لِلأُمِّ الثُّلُثُ مِنْ جَمِیعِ الْمَالِ۔ (عبدالرزاق 19018۔ بیہقی 228)",,,31705
31706,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ أَیُّوبَ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : مَا یَمْنَعُہُمْ أَنْ یَجْعَلُوہَا مِنَ اثْنَیْ عَشَرَ سَہْمًا ، فَیُعْطُونَ الْمَرْأَۃَ ثَلاَثَۃَ أَسْہُمٍ وَلِلأُمِّ أَرْبَعَۃَ أَسْہُمٍ وَلِلأَبِ خَمْسَۃَ أَسْہُمٍ۔",,,31706
31707,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِیہِ ، عَنِ الْمُسَیَّبِ بْنِ رَافِعٍ ، قَالَ : قَالَ عَبْدُ اللہِ : مَا کَانَ اللَّہُ لِیَرَانِی أُفَضِّلُ أُمًّا عَلَی أَبٍ۔",,,31707
31708,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، قَالَ : قَالَ عَبْدُ اللہِ : إنَّ عُمَرَ کَانَ إذَا سَلِکَ طَرِیقًا فَسَلِکْنَاہُ وَجَدْنَاہُ سَہْلا ، وَأَنَّہُ أُتِیَ فِی امْرَأَۃٍ وَأَبَوَیْنِ ، فَجَعَلَ لِلْمَرْأَۃِ الرُّبْعُ ، وَلِلأُمِّ ثُلُثُ مَا بَقِیَ، وَمَا بَقِیَ لِلأَبِ۔",,,31708
31709,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنْ شَیْخٍ ، عَنِ ابْنِ الْحَنَفِیَّۃِ : فِی امْرَأَۃٍ وَأَبَوَیْنِ : لِلْمَرْأَۃِ الرُّبْعُ ، وَلِلأُمِّ ثُلُثُ مَا بَقِیَ۔\n\nقَالَ أَبُوبَکْرٍ: فَہَذِہِ مِنْ أَرْبَعَۃِ أَسْہُمٍ: لِلْمَرْأَۃِ سَہْمٌ وَہُوَ الرُّبْعُ، وَلِلأُمِّ ثُلُثُ مَا بَقِیَ وَہُوَ سَہْمٌ، وَلِلأَبِ سَہْمَانِ۔",,,31709
31710,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَصْبَہَانِیِّ ، عَنْ عِکْرِمَۃَ ، قَالَ : بَعَثَنِی ابْنُ عَبَّاسٍ إلَی زَیْدِ بْنِ ثَابِتٍ أَسْأَلُہُ عَنْ زَوْجٍ وَأَبَوَیْنِ ، فَقَالَ زَیْدٌ : لِلزَّوْجِ النِّصْفُ ، وَلِلأُمِّ ثُلُثُ مَا بَقِیَ وَہُوَ السُّدُسُ ، فَأَرْسَلِ إلَیْہِ ابْنُ عَبَّاسٍ : أَفِی کِتَابِ اللہِ تَجِدُ ہَذَا ؟ قَالَ : أَکْرَہُ أَنْ أُفَضِّلَ أُمًّا علَی أَبٍ ، وَکَانَ ابْنُ عَبَّاسٍ یُعْطِی الأُمَّ الثُّلُثَ مِنْ جَمِیعِ الْمَالِ۔",,,31710
31711,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ سُلَیْمَانَ ، قَالَ : کَانَ إبْرَاہِیمُ یَفْرِضُہَا کَمَا فَرَضَہَا زَیْدٌ۔",,,31711
31712,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ حَجَّاجٍ ، عَنْ شَیْخٍ ، عَنِ ابْن الْحَنَفِیَّۃِ: فِی زَوْجٍ وَأَبَوَیْنِ: لِلزَّوْجِ النِّصْفُ، وَلِلأُمِّ ثُلُثُ مَا بَقِی ، وَمَا بَقِیَ فَلِلأَبِ۔",,,31712
31713,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا مِنْدَلٌ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلِیٍّ وَزَیْدِ بْنِ ثَابِتٍ : فِی امْرَأَۃٍ وَأَبَوَیْنِ وَزَوْجٍ وَأَبَوَیْنِ ، قَالَ : قَالَ : لِلأُمِّ ثُلُثُ مَا بَقِیَ۔",,,31713
31714,"حَدَّثَنَا عَبْدَۃُ ، عَنِ الأَعْمَشِ : أَنَّ ابْنَ عَبَّاسٍ أَرْسَلِ إلَی زَیْدٍ یَسْأَلُہُ عَنْ زَوْجٍ وَأَبَوَیْنِ ؟ فَقَالَ زَیْدٌ : لِلزَّوْجِ النِّصْفُ ، وَلِلأُمِّ ثُلُثُ مَا بَقِیَ ، فَقَالَ ابْنُ عَبَّاسٍ : تَجِدُ لَہَا فِی کِتَابِ اللہِ ثُلُثَ مَا بَقِیَ ؟ فَقَالَ زَیْدٌ : ہَذَا رَأْیِی وَاللَّہُ أَعْلَمُ۔\n\nقَالَ أَبُو بَکْرٍ : ہَذِہِ سِتَّۃُ أَسْہُمٍ : لِلزَّوْجِ ثَلاَثَۃٌ ، وَلِلأُمِّ سَہْمٌ ، وَلِلأَبِ سَہْمَانِ۔",,,31714
31715,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَشْعَثَ بْنِ أَبِی الشَّعْثَائِ ، عَنِ الأَسْوَدِ بْنِ یَزِیدَ ، قَالَ : قضَی مُعَاذٌ بِالْیَمَنِ فِی ابْنَۃٍ وَأُخْتٍ لأَبٍ وَأَمٍّ : لِلأُخْتِ النِّصْفُ ، وَلِلاِبْنَۃِ النِّصْفُ۔",,,31715
31716,حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عَنْ مُعَاذٍ ، مِثْلَ ذَلِکَ۔,,,31716
31717,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن وَبَرَۃَ بْنِ عَبْدِ الرَّحْمَن ، عَنِ الأَسْوَدِ بْنِ یَزِیدَ ، قَالَ : کَانَ ابْنُ الزُّبَیْرِ لاَ یُعْطِی الأُخْتَ مَعَ الاِبْنَۃِ شَیْئًا حَتَّی حَدَّثْتہ أَنَّ مُعَاذًا قَضَی بِالْیَمَنِ فِی ابْنَۃٍ وَأُخْتٍ لأَبٍ وَأَمٍّ : لِلاِبْنَۃِ النِّصْفُ وَلِلأُخْتِ النِّصْفُ ، فَقَالَ : أَنْتَ رَسُولِی إلَی ابْنِ عُتْبَۃَ فَمُرْہُ بِذَلِکَ۔",,,31717
31718,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، قَالَ : حدَّثْت ابْنَ الزُّبَیْرِ بِقَوْلِ مُعَاذٍ ، فَقَالَ : أَنْتَ رَسُولِی إلَی ابْنِ عُتْبَۃَ فَمُرْہُ بِذَلِکَ۔",,,31718
31719,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، قَالَ : حدَّثَنِی یَحْیَی بْنُ أَیُّوبَ الْمِصْرِیُّ ، قَالَ : حَدَّثَنَا یَزِیدُ بْنُ أَبِی حَبِیبٍ ، عَنْ أَبِی سَلَمَۃَ : أَنَّ عُمَرَ جَعَلَ الْمَالَ بَیْنَ الاِبْنَۃِ وَالأُخْتِ نِصْفَیْنِ۔",,,31719
31720,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، قَالَ: حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی حَصِینٍ ، عَنْ عَبْدِ اللہِ بْنِ عُتْبَۃَ : فِی ابْنَۃٍ وَأُخْتٍ، قَالَ : النِّصْفُ ، وَالنِّصْفُ۔",,,31720
31721,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنِ ابْنِ سِیرِینَ ، عَنِ الأَسْوَدِ ، قَالَ : کَانَ ابْنُ الزُّبَیْرِ قَدْ ہَمَّ أَنْ یَمْنَعَ الأَخَوَاتِ مَعَ الْبَنَاتِ الْمِیرَاثَ فَحَدَّثْتہ أَنَّ مُعَاذًا قَضَی بِہِ فِینَا : وَرَّثَ ابْنَۃً وَأُخْتًا۔",,,31721
31722,"حَدَّثَنَا وَکِیعٌ، عَنْ إسْرَائِیلَ، عَنْ جَابِرٍ، عَنْ عَامِرٍ، قَالَ: کَانَ عَلِیٌّ وَابْنُ مَسْعُودٍ وَمُعَاذٌ یَقُولُونَ فِی ابْنَۃٍ وَأُخْتٍ: النِّصْفُ وَالنِّصْفُ، وَہُوَ قَوْلُ أَصْحَابِ مُحَمَّدٍ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إلاَّ ابْنَ الزُّبَیْرِ، وَابْنَ عَبَّاسٍ۔",,,31722
31723,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الْمُسَیَّبِ بْنِ رَافِعٍ ، قَالَ : کُنْتُ جَالِسًا عِنْدَ عَبْدِ اللہِ بْنِ عُتْبَۃَ وَقَدْ أَمَرَنِی أَنْ أُصْلِحَ بَیْنَ الاِبْنَۃِ وَالأُخْتِ فِی الْمِیرَاثِ ، وَقَدْ کَانَ ابْنُ الزُّبَیْرِ أَمَرَہُ أَنْ لاَ یُوَرِّثَ الأُخْتَ مَعَ الاِبْنَۃِ شَیْئًا ، فَإِنِّی لأُصْلِحُ بَیْنَہُمَا عِنْدَہُ إذَا جَائَ الأَسْوَدُ بْنُ یَزِیدَ ، فَقَالَ : إنِّی شَہِدْت مُعَاذًا بِالْیَمَنِ قَسَمَ الْمَالَ بَیْنَ الاِبْنَۃِ وَالأُخْتِ ، وَإِنِّی أَتَیْتُ ابْنَ الزُّبَیْرِ فَأَعْلَمْتہ ذَلِکَ ، فَأَمَرَنِی أَنْ آتِیَک فَأُعْلِمَک ذَلِکَ لِتَقْضِیَ بِہِ وَتَکْتُبَ بِہِ إلَیْہِ ، فَقَالَ : یَا أَسْوَدُ ، إنَّک عِنْدَنَا لَمُصَدَّقٌ فَأْتِہِ فَأَعْلِمْہُ ذَلِکَ فَلِیَقْضِ بِہِ۔\n\nقَالَ أَبُو بَکْرٍ : وَہَذِہِ مِنْ سَہْمَیْنِ : لِلاِبْنَۃِ سَہْمٌ وَلِلأُخْتِ سَہْمٌ۔",,,31723
31724,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی قَیْسٍ ، عَنْ ہُزَیْلِ بْنِ شُرَحْبِیلَ ، قَالَ : جَائَ رَجُلٌ إلَی أَبِی مُوسَی وَسَلْمَانَ بْنِ رَبِیعَۃَ فَسَأَلَہُمَا عَنِ ابْنَۃٍ ، وَابْنَۃِ ابْنٍ ، وَأُخْتٍ لأَبٍ وَأُمٍ ؟ فَقَالاَ : لِلاِبْنَۃِ النِّصْفُ ، وَمَا بَقِیَ لِلأُخْتِ ، وَائْتِ ابْنَ مَسْعُودٍ فَسَلْہُ ، فَإِنَّہُ سَیُتَابِعنَا ، قَالَ : فَأَتَی الرَّجُلُ ابْنَ مَسْعُودٍ فَسَأَلَہُ وَأَخْبَرَہُ بِمَا قَالاَ ، فَقَالَ : لَقَدْ ضَلَلْت إذًا وَمَا أَنَا مِنَ الْمُہْتَدِینَ ، وَلَکِنْ سَأَقْضِی بِمَا قَضَی بِہِ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: لِلاِبْنَۃِ النِّصْفُ ، وَلاِبْنَۃِ الاِبْنِ السُّدُسُ تَکْمِلَۃُ الثُّلُثَیْنِ ، وَمَا بَقِیَ فَلِلأُخْتِ۔",,,31724
31725,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی قَیْسٍ ، عَنْ ہُزَیْلٍ ، عَنْ عَبْدِ اللہِ ، قَالَ : قضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی ابْنَۃٍ ، وَابْنَۃِ ابْنٍ ، وَأُخْتٍ : أَعْطَی الْبِنْتِ النِّصْفَ ، وَابْنَۃَ الاِبْنِ السُّدُسَ تَکْمِلَۃَ الثُّلُثَیْنِ ، وَالأُخْتَ مَا بَقِیَ۔\n\nقَالَ أَبُو بَکْرٍ : وَہَذِہِ مِنْ سِتَّۃِ أَسْہُمٍ : لِلاِبْنَۃِ ثَلاَثَۃُ أَسْہُمٍ ، وَلاِبْنَۃِ الاِبْنِ سَہْمٌ ، وَلِلأُخْتِ سَہْمَانِ۔",,,31725
31726,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَعْبَدِ بْنِ خَالِدٍ ، عَنْ مَسْرُوقٍ ، عَنِ ابْنِ مَسْعُودٍ : أَنَّہُ کَانَ یَجْعَلُ لِلأَخَوَاتِ وَالْبَنَاتِ الثُّلُثَیْنِ ، وَیَجْعَلُ مَا بَقِیَ لِلذُّکُورِ دُونَ الإِنَاثِ ، وَأَنَّ عَائِشَۃَ شَرَّکَتْ بَیْنَہُمْ ، فَجَعَلَتْ مَا بَقِیَ بَعْدَ الثُّلُثَیْنِ {لِلذَّکَرِ مِثْلُ حَظِّ الأُنْثَیَیْنِ}۔",,,31726
31727,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، عَنْ حَکِیمِ بْنِ جَابِرٍ ، عَنْ زَیْدِ بْنِ ثَابِتٍ : أَنَّہُ قَالَ فِیہَا : ہَذَا مِنْ قَضَائِ أَہْلِ الْجَاہِلِیَّۃِ : یَرِثُ الرِّجَالُ دُونَ النِّسَائِ۔",,,31727
31728,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن مَسْرُوقٍ ، قَالَ : کَانَ یَأْخُذُ بِقَوْلِ عَبْدِ اللہِ فِی أَخَوَاتٍ لأُمٍّ وَأَبٍ ، وَإِخْوَۃٍ وَأَخَوَاتٍ لأَبٍ ، یَجْعَلُ مَا بَقِیَ عَلَی الثُّلُثَیْنِ لِلذِّکُور دُونَ الإِنَاثِ ، فَخَرَجَ خَرْجَۃً إلَی الْمَدِینَۃِ ، قَالَ : فَجَائَ وَہُوَ یَرَی أَنْ یُشَرِّکَ بَیْنَہُمْ ، قَالَ : فَقَالَ لَہُ عَلْقَمَۃُ : مَا رَدَّک عَنْ قَوْلِ عَبْدِ اللہِ ؟ أَلَقِیت أَحَدًا ہُوَ أَثْبَتُ فِی نَفْسِکَ مِنْہُ ؟ قَالَ : فَقَالَ : لاَ ، وَلَکِنْ لَقِیت زَیْدَ بْنَ ثَابِتٍ فَوَجَدْتہ مِنَ الرَّاسِخِینَ فِی الْعِلْمِ۔",,,31728
31729,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن مَسْرُوقٍ ، قَالَ : قدِمَ فَقَالَ لَہُ عَلْقَمَۃُ : مَا کَانَ ابْنُ مَسْعُودٍ بِثَبْتٍ ؟ فَقَالَ لَہُ مَسْرُوقٌ : کَلاَّ ، وَلَکِنْ رَأَیْت زَیْدَ بْنَ ثَابِتٍ وَأَہْلَ الْمَدِینَۃِ یُشَرِّکُونَ۔",,,31729
31730,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ بَسَّامٍ ، عَنْ فُضَیْلٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : لأُخْتَیْہِ لأَبِیہِ وَأُمِّہِ الثُّلُثَانِ ، وَلإِخْوَتِہِ لأَبِیہِ وَأَخَوَاتِہِ مَا بَقِیَ {لِلذَّکَرِ مِثْلُ حَظِّ الأُنْثَیَیْنِ} فِی قَوْلِ عَلِیٍّ وَزَیْدٍ ، وَفِی قَوْلِ عَبْدِ اللہِ : لأُخْتَیْہِ لأَبِیہِ وَأُمِّہِ الثُّلُثَانِ ، وَمَا بَقِیَ فَلِلذُّکُورِ مِنْ إخْوَتِہِ دُونَ إنَاثِہِمْ۔\n\nقَالَ أَبُو بَکْرٍ : وَہَذِہِ فِی الْقَوْلَیْنِ جَمِیعًا مِنْ ثَلاَثَۃِ أَسْہُمٍ : لِلأَخَوَاتِ وَالْبَنَاتِ الثُّلُثَانِ ، وَیَبْقَی الثُّلُثُ فَہُوَ بَیْنَ الإِخْوَۃِ وَالأَخَوَاتِ ، أَوْ بَیْنَ بَنَاتِ ابْنِہِ ، وَبَنِی ابْنِہِ ، لِلذَّکَرِ مِثْلُ حَظِّ الأُنْثَیَیْنِ۔",,,31730
31731,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ بَسَّامٍ ، عَنْ فُضَیْلٍ ، عَنْ إبْرَاہِیمَ : فِی رَجُلٍ تَرَکَ ابْنَتَیْہِ وَابْنَۃَ ابْنٍ ، وَابْنَ ابْنٍ أَسْفَلَ مِنْہَا : فَلاِبْنَتَیْہِ الثُّلُثَانِ ، وَمَا فَضَلَ لاِبْنِ ابْنِہِ ، یُرَدُّ عَلَی مَنْ فَوْقَہُ وَمَنْ مَعَہُ مِنَ الْبَنَاتِ ، فِی قَوْلِ عَلِیٍّ وَزَیْدٍ : {لِلذَّکَرِ مِثْلُ حَظِّ الأُنْثَیَیْنِ} وَلاَ یُرَدُّ عَلَی مَنْ أَسْفَلَ مِنْہُ ، وَفِی قَوْلِ عَبْدِ اللہِ : لاِبْنَتَیْہِ الثُّلُثَانِ ، وَلاِبْنِ ابْنِہِ مَا بَقِی ، لاَ یَردُّ عَلَی أُخْتِہِ شَیْئًا ، وَلاَ عَلَی مَنْ فَوْقَہُ مِنْ أَجْلِ أَنَّہُ اسْتَکْمَلَ الثُّلُثَیْنِ۔\n\nقَالَ أَبُو بَکْرٍ : فَہَذِہِ مِنْ تِسْعَۃٍ فِی قَوْلِ عَلِیٍّ وَزَیْدٍ : فَیَصِیرُ لِلاِبْنَتَیْنِ الثُّلُثَانِ : وَتَبْقَی ثَلاَثَۃُ أَسْہُمٍ : فَلاِبْنِ الاِبْنِ سَہْمَانِ ، وَلأُخْتِہِ سَہْمٌ ، وَفِی قَوْلِ عَبْدِ اللہِ : مِنْ ثَلاَثَۃٍ أَسْہُمٍ : لِلْبِنْتَیْنِ الثُّلُثَانِ سَہْمَانِ ، وَلاِبْنِ الاِبْنِ مَا بَقِیَ وَہُوَ سَہْمٌ۔",,,31731
31732,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ الأَعْمَشِ ، قَالَ : کَانَ عَبْدُ اللہِ یَقُولُ فِی ابْنَۃٍ ، وَابْنَۃِ ابْنٍ ، وَبَنِی ابْنٍ ، وَبَنِی أُخْتٍ لأَبٍ وَأُمٍّ ، وَأُخْتٍ وَإِخْوَۃٍ لأَبٍ : أَنَّ ابْنَ مَسْعُودٍ کَانَ یُعْطِی ہَذِہِ النِّصْفَ ، ثُمَّ یَنْظُرُ، فَإِنْ کَانَ إذَا قَاسَمَتِ الذُّکُورَ أَصَابَہَا أَکْثَرُ مِنَ السُّدُسِ ، لَمْ یُزِدْہَا عَلَی السُّدُسِ ، وَإِنْ أَصَابَہَا أَقَلُّ مِنَ السُّدُسِ قَاسَمَ بِہَا ، لَمْ یُلْزِمْہَا الضَّرَرُ ، وَکَانَ غَیْرُہُ مِنْ أَصْحَابِ مُحَمَّدٍ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : لِہَذِہِ النِّصْفُ ، وَمَا بَقِیَ فَلِلذَّکَرِ مِثْلُ حَظِّ الأُنْثَیَیْنِ۔\n\nقَالَ أَبُو بَکْرٍ : ہَذِہِ أَصْلُہَا مِنْ سِتَّۃِ أَسْہُمٍ۔",,,31732
31733,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنِ الشَّعْبِیِّ ، قَالَ : کَانَ عَلِیٌّ وَزَیْدٌ یَقُولاَنِ فِی بَنِی عَمٍّ أحَدُہُمْ أَخٌ لأُمٍّ : یُعْطِیَانِہِ السُّدُسَ ، وَمَا بَقِیَ بَیْنَہُ وَبَیْنَ بَنِی عَمِّہِ ، وَکَانَ عَبْدُ اللہِ یُعْطِیہ الْمَالَ کُلَّہُ۔",,,31733
31734,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : أُتِیَ فِی بَنِی عَمٍّ أَحَدُہُمْ أَخٌ لأُمٍّ ، وَکَانَ ابْنُ مَسْعُودٍ أَعْطَاہُ الْمَالَ کُلَّہُ ، فَقَالَ عَلِیٌّ : یَرْحَمُ اللَّہُ أَبَا عَبْدِ الرَّحْمَنِ ، إِنْ کَانَ لَفَقِیہًا ، لَوْ کُنْت أَنَا لأَعْطیْتُہُ السُّدُسَ ، وَکَانَ شَرِیکَہُمْ۔",,,31734
31735,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ خَالِدٍ الْحَذَّائِ ، عَنِ ابْنِ سِیرِینَ ، عَنْ شُرَیْحٍ : أَنَّہُ کَانَ یَقْضِی فِی بَنِی عَمٍّ أَحَدُہُمْ أَخٌ لأُمٍّ بِقَضَائِ عَبْدِ اللہِ۔",,,31735
31736,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ بَسَّامٍ ، عَنْ فُضَیْلٍ ، عَنْ إبْرَاہِیمَ : فِی امْرَأَۃٍ تَرَکَتْ بَنِی عَمِّہَا ، أَحَدُہُمْ أَخُوہَا لأُمِّہَا ، قَالَ : فَقَضَی فِیہَا عُمَرُ وَعَلِیٌّ وَزَیْدٌ : أَنَّ لأَخِیہَا مِنْ أُمِّہَا السُّدُسَ ، وَہُوَ شَرِیکُہُمْ بَعْدُ فِی الْمَالِ ، وَقَضَی فِیہَا عَبْدُ اللہِ : أَنَّ الْمَالَ لَہُ دُونَ بَنِی عَمِّہِ۔\n\nقَالَ أَبُو بَکْرٍ : فَہِیَ فِی قَوْلِ عُمَرَ وَعَلِیٍّ وَزَیْدٍ : مِنْ سِتَّۃِ أَسْہُمٍ ، وَہِیَ فِی قَوْلِ عَبْدِ اللہِ وَشُرَیْحٍ : مِنْ سَہْمٍ وَاحِدٍ وَہُوَ جَمِیعُ الْمَالِ۔",,,31736
31737,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ أَوْسٍ ، عَنْ حَکِیمِ بْنِ عِقَالٍ ، قَالَ : أُتِیَ عَلِیٌّ فِی ابْنَیْ عَمٍّ أَحَدُہُمَا زَوْجٌ، وَالآخَرُ أَخٌ لأُمٍّ ، فَقَالَ لِشُرَیْحٍ : قُلْ فِیہَا ، فَقَالَ شُرَیْحٌ : لِلزَّوْجِ النِّصْفُ ، وَمَا بَقِیَ فَلِلأَخِ ، فَقَالَ لَہُ عَلِیٌّ : رَأْیٌ ؟ قَالَ : کَذَلِکَ رَأَیْت ، فَأَعْطَی عَلِیٌّ الزَّوْجَ النِّصْفَ ، وَالأَخ السُّدُسَ ، وَجَعَلَ مَا بَقِیَ بَیْنَہُمَا۔",,,31737
31738,"حَدَّثَنَا یَحْیَی بْنُ زَکَرِیَّا بْنُ أَبِی زَائِدَۃَ ، عَنْ إسْرَائِیلَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ : فِی امْرَأَۃٍ تَرَکَتْ ثَلاَثَۃً بَنِی عَمٍّ أَحَدُہُمْ زَوْجُہَا ، وَالآخَرُ أَخُوہَا لأُمِّہَا ، فَقَالَ عَلِیٌّ وَزَیْدٌ : لِلزَّوْجِ النِّصْفُ ، وَلِلأَخِ مِنَ الأُمِّ السُّدُسُ ، وَمَا بَقِیَ فَہُوَ بَیْنَہُمْ سَوَائٌ ، وَقَالَ ابْنُ مَسْعُودٍ : لِلزَّوْجِ النِّصْفُ ، وَمَا بَقِیَ فَلِلأَخِ مِنَ الأُمِّ۔\n\nقَالَ أَبُو بَکْرٍ : وَہَذِہِ فِی قَوْلِ عَلِیٍّ وَزَیْدٍ مِنْ سِتَّۃِ : لِلزَّوْجِ النِّصْفُ ثَلاثَۃ ، وَلِلأَخِ لِلأُمِّ السُّدُسُ ، وَیَبْقَی سَہْمَانِ ، فَہُمَا بَیْنَہُمَا ، وَفِی قَوْلِ ابْنِ مَسْعُودٍ مِنْ سَہْمَیْنِ : لِلزَّوْجِ النِّصْفُ ، وَمَا بَقِیَ فَلِلأَخِ لِلأُمِّ۔",,,31738
31739,"حَدَّثَنَا یَحْیَی بْنُ زَکَرِیَّا ، عَنْ إسْرَائِیلَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ : فِی امْرَأَۃٍ تَرَکَتْ أَخَوَیْہَا لأُمِّہَا ، أَحَدُہُمَا ابْنُ عَمِّہَا، فَقَالَ عَلِیٌّ وَزَیْدٌ: الثُّلُثُ بَیْنَہُمَا، وَمَا بَقِیَ فَلاِبْنِ عَمِّہَا، وَقَالَ ابْنُ مَسْعُودٍ: الْمَالُ بَیْنَہُمَا۔\n\nقَالَ أَبُو بَکْرٍ : فَہَذِہِ فِی قَوْلِ عَلِیٍّ وَزَیْدٍ مِنْ ثَلاَثَۃِ أَسْہُمٍ ، وَفِی قَوْلِ ابْنِ مَسْعُودٍ مِنْ سَہْمَیْنِ۔",,,31739
31740,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إسْمَاعِیلُ بْنُ عَبْدِ الْمَلِکِ ، قَالَ : سَأَلْتُ سَعِیدَ بْنَ جُبَیْرٍ عَنْ أبْنَۃٍ وَابْنَیْ عَمٍّ أَحَدُہُمَا أَخٌ لأُمٍّ ؟ فَقَالَ : لِلاِبْنَۃِ النِّصْفُ ، وَمَا بَقِیَ فَلاِبْنِ الْعَمِّ الَّذِی لَیْسَ بِأَخٍ لأُمٍّ ، وَلاَ یَرِث أَخٌ لأُمٍّ مَعَ وَلَدٍ ، قَالَ : فَسَأَلْت عَطَائً ، فَقَالَ : أَخْطَأَ سَعِیدٌ ، لِلاِبْنَۃِ النِّصْفُ ، وَمَا بَقِیَ بَیْنَہُمَا نِصْفَیْنِ۔\n\nقَالَ : أَبُو بَکْرٍ : فَہَذِہِ فِی قَوْلِ سَعِیدِ بْنِ جُبَیْرٍ مِنْ سَہْمَیْنِ : لِلاِبْنَۃِ النِّصْفُ وَلاِبْنِ الْعَمِّ الَّذِی لَیْسَ بِأَخٍ لأُمٍّ النِّصْفُ ، وَفِی قَوْلِ عَطَائٍ مِنْ أَرْبَعَۃٍ : سَہْمَانِ لِلاِبْنَۃِ ، وَسَہْمَانِ بَیْنَہُمَا۔",,,31740
31741,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ بَسَّامٍ ، عَنْ فُضَیْلٍ ، عَنْ إبْرَاہِیمَ : فِی امْرَأَۃٍ تَرَکَتْ أَعْمَامَہَا أَحَدُہُمْ أَخُوہَا لأُمِّہَا ، فَقَضَی فِیہَا عَلِیٌّ وَزَیْدٌ : أَنَّ لأَخِیہَا لأُمِّہَا السُّدُسَ ، ثُمَّ ہُوَ شَرِیکُہُمْ بَعْدُ فِی الْمَالِ ، وَقَضَی فِیہَا ابْنُ مَسْعُودٍ : أَنَّ الْمَالَ کُلَّہُ لَہُ ، وَہَذَا نَسَب یَکُونُ فِی الشِّرْکِ ، ثُمَّ یُسلمُ أَہْلَہُ بَعْدُ۔\n\nقَالَ أَبُو بَکْرٍ: فَہَذِہِ فِی قَوْلِ عَلِیٍّ وَزَیْدٍ مِنْ سِتَّۃِ أَسْہُمٍ ، وَفِی قَوْلِ عَبْدِ اللہِ: مِنْ سَہْمٍ وَاحِدٍ لأَنَّہُ الْمَالُ کُلُّہُ۔",,,31741
31742,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ بَسَّامٍ ، عَنْ فُضَیْلٍ ، عَنْ إبْرَاہِیمَ : فِی امْرَأَۃٍ تَرَکَتْ إخْوَتَہَا لأُمِّہَا رِجَالاً وَنِسَائً، وَہُمْ بَنُو عَمِّہَا فِی الْعَصَبَۃِ ، قَالَ : یَقْتَسِمُونَ الثُّلُثَ بَیْنَہُمْ : الرِّجَالُ وَالنِّسَائُ فِیہِ سَوَائٌ ، وَالثُّلُثَانِ الْبَاقِیَانِ لِذُکُورِہِمْ خَالِصًا دُونَ النِّسَائِ فِی قَضَائِ أَصْحَابِ مُحَمَّدٍ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کُلِّہِمْ۔\n\nوَہَذِہِ فِی قَوْلِہِمْ جَمِیعًا مِنْ ثَلاَثَۃِ أَسْہُمٍ۔",,,31742
31743,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ بَسَّامٍ ، عَنْ فُضَیْلٍ ، عَنْ إبْرَاہِیمَ : فِی رَجُلٍ تَرَکَ ابْنَتَیْہِ وَبَنِی ابْنِہِ رِجَالاً وَنِسَائً : فَلاِبْنَتَیْہِ الثُّلُثَانِ ، وَمَا بَقِیَ فَلِلذُّکُورِ دُونَ الإِنَاثِ ، وَکَانَ عَبْدُ اللہِ لاَ یَزِیدُ الأَخَوَاتِ وَالْبَنَاتِ عَلَی الثُّلُثَیْنِ ، وَکَانَ عَلِیٌّ وَزَیْدٌ یُشَرِّکُونَ فِیمَا بَیْنَہُمْ ، فَمَا بَقِیَ {لِلذَّکَرِ مِثْلُ حَظِّ الأُنْثَیَیْنِ}۔\n\nقَالَ أَبُو بَکْرٍ : فَہَذِہِ مِنْ ثَلاَثَۃِ أَسْہُمٍ فِی قَوْلِہِمْ جَمِیعًا۔",,,31743
31744,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ مَعْمَرٍ ، عَنْ سِمَاکِ بْنِ الْفَضْلِ ، قَالَ : سَمِعْتُ وَہْبًا یُحَدِّثُ ، عَنِ الْحَکَمِ بْنِ مَسْعُودٍ ، قَالَ : شَہِدْت عُمَرَ أَشْرَکَ الإِخْوَۃَ مِنَ الأَبِ وَالأُمِّ مَعَ الإِخْوَۃِ مِنَ الأُمِّ فِی الثُّلُثِ ، فَقَالَ لَہُ رَجُلٌ : قَدْ قَضَیْت فِی ہَذَہ عَامَ الأَوَّلِ بِغَیْرِ ہَذَا ، قَالَ : وَکَیْفَ قَضَیْت ؟ قَالَ : جَعَلْتہ لِلإِخْوَۃِ لِلأُمِّ وَلَمْ تَجْعَلْ لِلإِخْوَۃِ مِنَ الأَبِ وَالأُمِّ شَیْئًا ، فَقَالَ : ذَلِکَ عَلَی مَا قَضَیْنَا ، وَہَذَا عَلَی مَا نَقْضِی۔ (عبدالرزاق 19005)",,,31744
31745,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ : أَنَّ عُمَرَ وَزَیْدًا وَابْنَ مَسْعُودٍ کَانُوا یُشَرِّکُونَ فِی زَوْجٍ وَأُمٍّ وَإِخْوَۃٍ لأُمٍّ وَأَبٍ وَأَخَوَاتٍ لأُمٍّ ، یُشَرِّکُونَ بَیْنَ الإِخْوَۃِ مِنَ الأَبِ وَالأُمِّ مَعَ الإِخْوَۃِ لِلأُمِّ فِی سَہْمٍ ، وَکَانُوا یَقُولُونَ : لَمْ یَزِدْہُمَ الأَبُ إلاَّ قُرْبًا ، وَیَجْعَلُونَ ذُکُورَہُمْ وَإِنَاثَہُمْ فِیہِ سَوَائً۔",,,31745
31746,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ بَسَّامٍ ، عَنْ فُضَیْلٍ ، عَنْ إبْرَاہِیمَ : فِی امْرَأَۃٍ تَرَکَتْ زَوْجَہَا وَأُمَّہَا وَإِخْوَتَہَا لأَبِیہَا وَأُمِّہَا وَإِخْوَتَہَا لأُمِّہَا : فَلِزَوْجِہَا النِّصْفُ ثَلاَثَۃُ أَسْہُمٍ ، وَلأُمِّہَا السُّدُسُ سَہْمٌ ، وَلاِِخْوَتِہَا لأُمِّہَا الثُّلُثُ سَہْمَانِ ، وَلَمْ یَجْعَلْ لاِِخْوَتِہَا لأَبِیہَا وَأُمِّہَا مِنَ الْمِیرَاثِ شَیْئًا فِی قَضَائِ عَلِی ، وَشَرَّک بَیْنَہُمْ عُمَرُ وَعَبْدُ اللہِ وَزَیْدُ بْنُ ثَابِتٍ : بَیْنَ الإِخْوَۃِ مِنَ الأَبِ وَالأُمِّ مَعَ بَنِی الأُمِّ فِی الثُّلُثِ الَّذِی وَرِثُوا ، غَیْرَ أَنَّہُمْ شَرَّکُوا ذُکُورَہُمْ وَإِنَاثَہُمْ فِیہِ سَوَائٌ۔",,,31746
31747,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سُلَیْمَانَ التَّیْمِیِّ ، عَنْ أَبِی مِجْلَزٍ : أَنَّ عُثْمَانَ شَرَّک بَیْنَہُمْ۔",,,31747
31748,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنِ ابْنِ الْمُنْتَشِرِ ، عَنْ شُرَیْحٍ وَمَسْرُوقٍ : أَنَّہُمَا شَرَّکَا الإِخْوَۃَ مِنَ الأَبِ وَالأُمِّ مَعَ الإِخْوَۃِ مِنَ الأُمِّ۔",,,31748
31749,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، بِمِثْلِہِ ، قَالَ : مَا زَادَہُمَ الأَبُ إلاَّ قُرْبًا۔",,,31749
31750,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، أَنَّہُ قَالَ : لأُمِّہَا السُّدُسُ ، وَلِزَوْجِہَا الشَّطْرُ ، وَالثُّلُثُ بَیْنَ الإِخْوَۃِ مِنَ الأُمِّ وَالإِخْوَۃِ مِنَ الأَبِ وَالأُمِّ۔",,,31750
31751,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عَبْدِ اللہِ بْنِ مُحَمَّدِ بْنِ عَقِیلٍ ، قَالَ : مَاتَتِ ابْنَۃٌ لِلْحَسَنِ بْنِ الْحَسَنِ وَتَرَکَتْ زَوْجَہَا وَأُمَّہَا وَإِخْوَتَہَا لأُمِّہَا وَإِخْوَتَہَا لأَبِیہَا وَأُمِّہَا ، فَارْتَفَعُوا إلَی عُمَرَ بْنِ عَبْدِ الْعَزِیزِ، فَأَعْطَی الزَّوْجَ النِّصْفَ ، وَالأُمَّ السُّدُسَ ، وَأَشْرَکَ بَیْنَ الإِخْوَۃِ مِنَ الأُمِّ وَالإِخْوَۃِ مِنَ الأَبِ وَالأُمِّ ، وَقَالَ لِلزَّوْجِ : أَمْسِکْ عَنْ أَتْرَابِکَ ، أَیَلْحَقُ بِہِمْ سَہْمٌ آخَرُ ، حَتَّی یُنْظر حُبْلَی ہِیَ أَمْ لاَ ؟۔",,,31751
31752,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ عَبْدُ اللہِ وَعُمَرُ یُشَرِّکَانِ ، قَالَ : وَکَانَ عَلِیٌّ لاَ یُشَرِّکُ۔\n\nقَالَ أَبُو بَکْرٍ : وَہَذِہِ مِنْ سِتَّۃِ أَسْہُمٍ : لِلزَّوْجِ النِّصْفُ ثَلاَثَۃُ أَسْہُمٍ ، وَلِلأُمِّ السُّدُسُ ، وَلِلإِخْوَۃِ مِنَ الأُمِّ الثُّلُثُ وَہُوَ سَہْمَانِ۔",,,31752
31753,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ عَبْدِ اللہِ بْنِ سَلِمَۃَ ، عَنْ عَلِیٍّ : أَنَّہُ کَانَ لاَ یُشَرِّکُ۔",,,31753
31754,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ : أَنَّہُ کَانَ لاَ یُشَرِّکُ۔",,,31754
31755,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ عَلِیٌّ لاَ یُشَرِّکُ۔",,,31755
31756,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی قَیْسٍ ، عَنْ ہُزَیْلٍ ، عَنْ عَبْدِ اللہِ : أَنَّہُ کَانَ لاَ یُشَرِّکُ ، وَیَقُولُ : تَنَاہَت السِّہَامُ۔",,,31756
31757,"حَدَّثَنَا مَعْشَرٌ ، عَنْ أَبِیہِ ، عَنْ أَبِی مِجْلَزٍ ، عَنْ عَلِیٍّ : أَنَّہُ کَانَ لاَ یُشَرِّکُ بَیْنَہُمْ۔",,,31757
31758,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الشَّعْبِیِّ ، عَنْ زَیْدِ بْنِ ثَابِتٍ : أَنَّہُ کَانَ لاَ یُشَرِّکُ۔",,,31758
31759,"حَدَّثَنَا عَبْدُ اللہِ بْنُ دَاوُد ، عَنْ عَلِیِّ بْنِ صَالِحٍ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ : أَنَّ عَلِیًّا وَأَبَا مُوسَی وَأُبَیًّا کَانُوا لاَ یُشَرِّکُونَ ، قَالَ وَکِیعٌ : وَلَیْسَ أَحَدٌ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إلاَّ اخْتَلَفُوا عَنْہُ فِی الشَّرِکَۃِ ، إلاَّ عَلِیٌّ فَإِنَّہُ کَانَ لاَ یُشَرِّکُ۔",,,31759
31760,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ عَاصِمٍ ، عَنْ زِرٍّ ، عَنْ عُمَرَ : أَنَّہُ قَسَمَ الْمَالَ بَیْنَ عَمَّۃٍ وَخَالَۃٍ۔",,,31760
31761,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ، عَنْ زِیَادٍ ، قَالَ : إنِّی لأَعْلَمُ مَا صَنَعَ عُمَرُ ، جَعَلَ الْعَمَّۃَ بِمَنْزِلَۃِ الأَبِ ، وَالْخَالَۃَ بِمَنْزِلَۃِ الأُمِّ۔",,,31761
31762,"حَدَّثَنَا وَکِیعٌ ، عَنْ یَزِیدَ بْنِ إبْرَاہِیمَ ، عَنِ الْحَسَنِ ، عَنْ عُمَرَ ، قَالَ : لِلْعَمَّۃِ الثُّلُثَانِ ، وَلِلْخَالَۃِ الثُّلُثُ۔",,,31762
31763,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سُلَیْمَانَ الْعَبْسِیِّ ، عَنْ رَجُلٍ ، عَنْ عَلِیٍّ : أَنَّہُ کَانَ یَقُولُ فِی الْعَمَّۃِ وَالْخَالَۃِ بِقَوْلِ عُمَرَ : لِلْعَمَّۃِ الثُّلُثَانِ ، وَلِلْخَالَۃِ الثُّلُثُ۔",,,31763
31764,حَدَّثَنَا وَکِیعٌ ، عَنْ یُونُسَ ، عَنِ الشَّعْبِیِّ ، عَنْ مَسْرُوقٍ ، أَنَّہُ کَانَ یُنَزِّلُ الْعَمَّۃَ بِمَنْزِلَۃِ الأَبِ ، وَالْخَالَۃَ بِمَنْزِلَۃِ الأُمِّ۔,,,31764
31765,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ عُمَرُ وَعَبْدُ اللہِ یُوَرِّثَانِ الْخَالَۃَ وَالْعَمَّۃَ إذَا لَمْ یَکُنْ غَیْرُہُمَا۔\n\nقَالَ إبْرَاہِیمُ : کَانُوا یَجْعَلُونَ الْعَمَّۃَ بِمَنْزِلَۃِ الأَبِ ، وَالْخَالَۃَ بِمَنْزِلَۃِ الأُمِّ۔",,,31765
31766,"حَدَّثَنَا وَکِیعٌ ، عَنْ عُمَرَ بْنِ بَشِیرٍ الْہَمْدَانِیِّ ، عَنِ الشَّعْبِیِّ ، عَنِ ابْنِ مَسْعُودٍ ، أَنَّہُ کَانَ یَقُولُ فِی الْخَالَۃِ وَالْعَمَّۃِ : لِلْعَمَّۃِ الثُّلُثَانِ ، وَلِلْخَالَۃِ الثُّلُثُ۔",,,31766
31767,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا سُفْیَانُ، عَنْ مَنْصُورٍ وَمُغِیرَۃ، عَنْ إبْرَاہِیمَ، قَالَ: کَانُوا یُوَرَّثُونَ بِقَدْرِ أَرْحَامِہِمْ۔",,,31767
31768,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیِّ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ : أَنَّ عُمَرَ وَرَّثَ الْخَالَۃَ وَالْعَمَّۃَ ، فَوَرَّثَ الْعَمَّۃَ الثُّلُثَیْنِ ، وَالْخَالَۃَ الثُّلُثَ۔",,,31768
31769,"حَدَّثَنَا سُوَیْد بْنُ عَمْرو ، قَالَ : حدَّثَنَا أَبُو عَوَانَۃَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : قَالَ ابْنُ مَسْعُودٍ : لِلْعَمَّۃِ الثُّلُثَانِ ، وَلِلْخَالَۃِ الثُّلُثُ۔",,,31769
31770,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ہِشَامُ بْنُ سَعْدٍ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، قَالَ : دُعِیَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إلَی جِنَازَۃِ رَجُلٍ مِنَ الأَنْصَارِ ، فَجَائَ عَلَی حِمَارٍ ، فَقَالَ : مَا تَرَکَ ؟ قَالُوا : تَرَکَ عَمَّۃً وَخَالَۃً ، قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : رَجُلٌ مَاتَ وَتَرَکَ عَمَّۃً وَخَالَۃً ، ثُمَّ سَارَ ، ثُمَّ قَالَ : رَجُلٌ مَاتَ وَتَرَکَ عَمَّۃً وَخَالَۃً ، ثُمَّ قَالَ : لَمْ أَجِدْ لَہُمَا شَیْئًا۔ (ابوداؤد 361۔ سعید بن منصور 163)",,,31770
31771,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ مَالِکِ بْنِ أَنَسٍ ، عَنْ مُحَمَّدِ بْنِ أَبِی بَکْرٍ ، قَالَ : قَالَ عُمَرُ : عَجَبًا لِلْعَمَّۃِ تُورثُ، وَلاَ تَرِثُ۔",,,31771
31772,"حَدَّثَنَا عَبْدَۃُ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ شَرِیکِ بْنِ عَبْدِ اللہِ بْنِ أَبِی نَمِرٍ ، قَالَ : سُئِلَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ مِیرَاثِ الْعَمَّۃِ وَالْخَالَۃِ وَہُوَ رَاکِبٌ ، فَسَکَتَ ، ثُمَّ سَارَ ہُنَیْہَۃً ، ثُمَّ قَالَ : حَدَّثَنِی جِبْرِیلُ أَنَّہُ لاَ مِیرَاثَ لَہُمَا۔",,,31772
31773,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ، عَنْ أَشْعَثَ، عَنِ الْحَسَنِ: أَنَّہُ کَانَ یَرَی الْمِیرَاثَ لِلْمَوَالِی دُونَ الْعَمَّۃِ وَالْخَالَۃِ۔",,,31773
31774,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْحَارِثِ بْنِ عَیَّاش بْنِ أَبِی رَبِیعَۃَ الزُّرَقِیِّ ، عَنْ حَکِیمِ بْنِ حَکِیمِ بْنِ عَبَّادِ بْنِ حُنَیْفٍ الأَنْصَارِیِّ ، عَنْ أَبِی أُمَامَۃَ بْنِ سَہْلِ بْنِ حُنَیْفٍ : أَنَّ رَجُلاً رَمَی رَجُلاً بِسَہْمٍ فَقَتَلَہُ وَلَیْسَ لَہُ وَارِثٌ إلاَّ خَالٌ ، فَکَتَبَ فِی ذَلِکَ أَبُو عُبَیْدَۃَ بْنُ الْجَرَّاحِ إلَی عُمَرَ ، فَکَتَبَ إلَیْہِ عُمَرُ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : اللَّہُ وَرَسُولُہُ مَوْلَی مَنْ لاَ مَوْلَی لَہُ ، وَالْخَالُ وَارِثُ مَنْ لاَ وَارِثَ لَہُ۔ (ترمذی 2103۔ ابن ماجہ 2737)",,,31774
31775,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ، عَنِ الأَعْمَشِ، عَنْ إبْرَاہِیمَ، قَالَ: وَرَّثَ عُمَرُ الْخَالَ الْمَالَ کُلَّہُ، قَالَ: کَانَ خَالاً وَمَوْلًی۔",,,31775
31776,"حَدَّثَنَا وَکِیعٌ، عَنِ الْحَکَمِ بْنِ عَطِیَّۃَ، عَنْ عَبْدِاللہِ بْنِ عُبَیْدِ بْنِ عُمَیْرٍ: أَنَّ عُمَرَ وَرَّثَ خَالاً وَمَوْلًی مِنْ مَوْلاَہُ۔",,,31776
31777,"حَدَّثَنَا شَبَابَۃُ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، قَالَ : حَدَّثَنَا بُدَیْلُ بْنُ مَیْسَرَۃَ الْعُقَیْلِیُّ ، عَنِ ابْنِ أَبِی طَلْحَۃَ ، عَنْ رَاشِدِ بْنِ سَعْدٍ ، عَنْ أَبِی عَامِرٍ الْہَوْزَنِیُّ ، عَنِ الْمِقْدَامِ رَجُلٌ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْخَالُ وَارِثُ مَنْ لاَ وَارِثَ لَہُ۔ (ابوداؤد 2891۔ ابن حبان 6035)",,,31777
31778,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا زَکَرِیَّا ، عَنْ عَامِرٍ ، قَالَ : سُئِلَ مَسْرُوقٌ عَنْ رَجُلٍ مَاتَ وَلَیْسَ لَہُ وَارِثٌ إلاَّ خَالُہُ وَابْنَۃُ أَخِیہ ؟ قَالَ : لِلْخَالِ نَصِیبُ أُخْتِہِ ، وَلاِبْنَۃِ الأَخِ نَصِیبُ أَبِیہَا۔",,,31778
31779,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ مُحَمَّدِ بْنِ یَحْیَی بْنِ حَبَّانَ ، عَنْ عَمِّہِ وَاسِعِ بْنِ حَبَّانَ، قَالَ : ہَلَکَ ابْنُ دَحْدَاحَۃَ وَکَانَ ذَا رَأْیٍ فِیہِمْ ، فَدَعَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَاصِمَ بْنَ عَدِیٍّ ، فَقَالَ : ہَلْ کَانَ لَہُ فِیکُمْ نَسَبٌ ؟ قَالَ : لاَ ، قَالَ : فَأَعْطَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِیرَاثَہُ ابْنَ أُخْتِہِ أَبَا لُبَابَۃَ بْنَ عَبْدِ الْمُنْذِرِ۔ (عبدالرزاق 19120)",,,31779
31780,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَنْ وُہَیْبٍ ، عَنِ ابْنِ طَاوس ، عَنْ أَبِیہِ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَلْحِقُوا الْفَرَائِضَ بِأَہْلِہَا فَمَا بَقِیَ فَہُوَ لأَوْلَی رَجُلٍ۔ (بخاری 6732۔ مسلم 1233)",,,31780
31781,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ رَجُلٍ مِنْ أَہْلِ الْمَدِینَۃِ ، عَنْ مُحَمَّدِ بْنِ یَحْیَی بْنِ حَبَّانَ ، عَنْ عَمِّہِ وَاسِعِ بْنِ حَبَّانَ ، قَالَ : کَانَ ثَابِتُ ابْنُ الدَّحْدَاحَ رَجُلاً أَتِیًّا - یَعْنِی : طَارِئًا - وَکَانَ فِی بَنِی أُنَیفٍ ، أَوْ فِی بَنِی الْعَجْلاَنِ ، فَمَاتَ وَلَمْ یَدَعْ وَارِثًا إلاَّ ابْنَ أُخْتِہِ أَبَا لُبَابَۃَ بْنَ عَبْدِ الْمُنْذِرِ ، فَأَعْطَاہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِیرَاثَہُ۔ (عبدالرزا ق19120)",,,31781
31782,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ الشَّیْبَانِیِّ ، عَنْ عُبَیْدِ بْنِ أَبِی الْجَعْدِ ، عَنْ عَبْدِ اللہِ بْنِ شَدَّادٍ ، قَالَ : تَدْرِی مَا ابْنَۃُ حَمْزَۃَ مِنِّی ہِیَ أُخْتِی لأُمِّی ، أَعْتَقَتْ رَجُلاً فَمَاتَ فَقُسِمَ مِیرَاثُہُ بَیْنَ ابْنَتِہِ وَبَیْنَہَا ، قَالَ : عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔ (سعید بن منصور 173)",,,31782
31783,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، عَنِ الْحَکَمِ ، عَنْ عَبْدِ اللہِ بْنِ شَدَّادٍ ، عَنِ ابْنَۃِ حَمْزَۃَ - قَالَ مُحَمَّدٌ : وَہِیَ أُخْتُ ابْنِ شَدَّادٍ لأُمِّہِ - قَالَتْ : مَاتَ مَوْلًی لِی وَتَرَکَ ابْنَتَہُ ، فَقَسَمَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَالَہُ بَیْنِی وَبَیْنَ ابْنَتِہِ ، فَجَعَلَ لِی النِّصْفَ وَلَہَا النِّصْفَ۔",,,31783
31784,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ عَبْدِ اللہِ بْنِ شَدَّادٍ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أعْطَی ابْنَۃَ حَمْزَۃَ النِّصْفَ وَابْنَتَہُ النِّصْفَ۔",,,31784
31785,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ الحَسَنِ بْنِ صَالِحٍ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ رُفَیْعٍ ، عَنْ أَبِی بُرْدَۃَ : أَنَّ رَجُلاً مَاتَ وَتَرَکَ ابْنَتَہُ وَمَوَالِیَہُ الَّذِینَ أَعْتَقُوہُ فَأَعْطَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ابْنَتَہُ النِّصْفَ وَمَوَالِیَہُ النِّصْفَ۔ (ابوداؤد 363۔ بیہقی 241)",,,31785
31786,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الْحَکَمِ ، عَنْ شَمُوسٍ الْکِنْدِیَّۃِ ، قَالَتْ : قاضَیْت إلَی عَلِیٍّ فِی أَبِی : مَاتَ وَلَمْ یَتْرُکْ غَیْرِی وَمَوْلاَہُ ، فَأَعْطَانِی النِّصْفَ وَمَوْلاَہُ النِّصْفَ۔",,,31786
31787,حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الْحَکَمِ ، عَنْ شَمُوسٍ ، عَنْ عَلِیٍّ ، بِمِثْلِہِ۔,,,31787
31788,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْحَکَمِ ، عَنْ أَبِی الْکَنُودِ ، عَنْ عَلِیٍّ : أَنَّہُ قَضَی فِی ابْنَۃٍ وَمَوْلًی ، أَعْطَی الْبِنْتَ النِّصْفَ ، وَالْمَوْلَی النِّصْفَ۔",,,31788
31789,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ : أَنَّ مَوْلًی لاِبْنَۃِ حَمْزَۃَ مَاتَ وَتَرَکَ ابْنَتَہُ وَابْنَۃَ حَمْزَۃَ ، فَأَعْطَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ابْنَۃَ حَمْزَۃَ النِّصْفَ ، وَابْنَتَہُ النِّصْفَ۔",,,31789
31790,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ عَبْدِ الرَّحْمَنِ الْمُحَارِبِیُّ ، عَنْ زَائِدَۃَ ، عَنْ أَبِی حَصِینٍ ، قَالَ : خَاصَمْت إلَی شُرَیْحٍ فِی مَوْلًی لَنَا مَاتَ وَتَرَکَ ابْنَتَیْہِ وَمَوَالِیَہُ ، فَأَعْطَی شُرَیْحٌ ابْنَتَیْہِ الثُّلُثَیْنِ ، وَأَعْطَی مَوْلاَہُ الثُّلُثَ۔",,,31790
31791,"حَدَّثَنَا عَبْدَۃُ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : ذُکِرَ عِنْدَہُ حَدِیثُ ابْنَۃِ حَمْزَۃَ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَعْطَاہَا النِّصْفَ ، فَقَالَ : إنَّمَا أَطْعَمَہَا إیَّاہُ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ طُعْمَۃً۔",,,31791
31792,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورِ بْنِ حَیَّانَ ، عَنْ عَبْدِ اللہِ بْنِ شَدَّادٍ : أَنَّ مَوْلًی لاِبْنَۃِ حَمْزَۃَ مَاتَ وَتَرَکَ ابْنَتَہُ وَابْنَۃَ حَمْزَۃَ ، فَأَعْطَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ابْنَتَہُ النِّصْفَ ، وَابْنَۃَ حَمْزَۃَ النِّصْفَ۔\n\nقَالَ أَبُو بَکْرٍ : وَہَذِہِ مِنْ سَہْمَیْنِ : لِلْبِنْتِ النِّصْفُ وَلِلْمَوْلَی النِّصْفُ۔ (طحاوی 401۔ بیہقی 241)",,,31792
31793,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الشَّعْبِیِّ۔ وَعَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ : أَنَّ عَلِیًّا کَانَ یَقُولُ فِی الْمَمْلُوکِینَ وَأَہْلِ الْکِتَابِ : لاَ یَحْجُبُونَ ، وَلاَ یَرِثُونَ۔",,,31793
31794,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ إِبْرَاہِیمَ ، عَنِ زَیْدِ بْنِ ثَابِتٍ قَالَ : لاَ یَحْجُبُونَ وَلاَ یَرِثُونَ۔",,,31794
31795,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ زَیْدٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ ، قَالَ عُمَرُ : لاَ یَحْجُبُ مَنْ لاَ یَرِثُ۔",,,31795
31796,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنْ أَبِی صَادِقٍ ، عَنْ عَلِیٍّ ، قَالَ : الْمَمْلُوکُونَ لاَ یَرِثُونَ ، وَلاَ یَحْجُبُونَ۔",,,31796
31797,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنْ أَبِی صَادِقٍ : أَنَّ رَجُلاً سَأَلَ عَلِیًّا عَنِ امْرَأَۃٍ مَاتَتْ وَتَرَکَتْ أُخْتُہَا وَأُمُّہَا مَمْلُوکَۃٌ ؟ فَقَالَ عَلِیٌّ : ہَلْ یُحِیطُ السُّدُسُ بِرَقَبَتِہَا ؟ فَقَالَ : لاَ ، فَقَالَ : دَعْنَا مِنْہَا سَائِرَ الْیَوْمِ۔",,,31797
31798,حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنْ أَبِی عَمْرٍو الشَّیْبَانِیِّ ، عَنْ شُرَیْحٍ ، أَنَّہُ أَعْطَی مِیرَاثَ رَجُلٍ - أَخُوہُ مَمْلُوکُ - بَنِی أَخِیہِ الأَحْرَارَ۔,,,31798
31799,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : یَرِثُہُ بَنُو أَخِیہِ الأَحْرَارُ۔",,,31799
31800,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ : فِی رَجُلٍ مَاتَ وَتَرَکَ أُمَّہُ مَمْلُوکَۃً ، وَجَدَّتَہُ حُرَّۃً ، قَالَ : الْمَالُ لِلْجَدَّۃِ۔",,,31800
31801,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ مَعْمَرٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَلِیٍّ وَزَیْدٍ : فِی الْمَمْلُوکِینَ وَالْمُشْرِکِینَ ، قَالاَ : لاَ یَحْجُبُونَ ، وَلاَ یَرِثُونَ۔",,,31801
31802,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ۔ وَعَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الشَّعْبِیِّ ، عَنِ ابْنِ مَسْعُودٍ : أَنَّہُ کَانَ یَحْجُبُ بِالْمَمْلُوکِینَ وَأَہْلِ الْکِتَابِ ، وَلاَ یُوَرِّثُہُمْ۔",,,31802
31803,"حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : قَالَ عَبْدُ اللہِ : إذَا مَاتَ الرَّجُلُ وَتَرَکَ أَبَاہُ ، أَوْ أَخَاہُ، أَو ابْنَہُ مَمْلُوکًا وَلَمْ یَتْرُکْ وَارِثًا فَإِنَّہُ یُشْتَرَی فَیُعْتَقُ ، ثُمَّ یُوَرَّثُ۔",,,31803
31804,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ أَشْعَثَ ، عَنْ مُحَمَّدٍ ، عَنِ ابْنِ مَسْعُودٍ : فِی رَجُلٍ مَاتَ وَتَرَکَ أَبَاہُ مَمْلُوکًا، قَالَ : یُشْتَرَی مِنْ مَالِہِ فَیُعْتَقُ ، ثُمَّ یُوَرَّثُ ، قَالَ : وَکَانَ الْحَسَنُ یَقُولُہُ۔",,,31804
31805,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سُفْیَانَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَبْدِ اللہِ ، بِمِثْلِہِ۔,,,31805
31806,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ فُضَیْلٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ عُمَرُ وَعَبْدُ اللہِ یُعْطِیَانِ الْمِیرَاثَ ذَوِی الأَرْحَامِ، قَالَ فُضَیْلٌ: فَقُلْتُ لإِبْرَاہِیمَ: فَعَلِیٌّ؟ قَالَ: کَانَ أَشَدَّہُمْ فِی ذَلِکَ: أَنْ یُعْطِیَ ذَوِی الأَرْحَامِ۔",,,31806
31807,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ وَعُمَرَ وَعَلِیٍّ ، وَعَبْدِ اللہِ ، بِمِثْلِہِ۔,,,31807
31808,"حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنْ مُعَاوِیَۃَ بْنِ صَالِحٍ ، عَنْ أَبِی الزَّاہِرِیَّۃِ - قَالَ أَبُو بَکْرٍ : أَظُنُّہُ ، عَنْ جُبَیْرِ بْنِ نُفَیْرٍ - قَالَ : کُنْتُ جَالِسًا عِنْدَ أَبِی الدَّرْدَائِ - وَکَانَ قَاضِیًا - فَأَتَاہُ رَجُلٌ ، فَقَالَ : إنَّ ابْنَ أُخْتِی مَاتَ وَلَمْ یَدَعْ وَارِثًا ، فَکَیْفَ تَرَی فِی مَالِہِ ؟ قَالَ : انْطَلِقْ فَاقْبِضْہُ۔",,,31808
31809,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَیَّانَ الْجُعْفِیِّ ، عَنْ سُوَیْد بْنِ غَفَلَۃً : أَنَّ عَلِیًّا أُتِیَ فِی ابْنَۃٍ وَامْرَأَۃٍ وَمَوَالِی ، فَأَعْطَی الاِبْنَۃَ النِّصْفَ ، وَالْمَرْأَۃَ الثُّمُنَ ، وَرَدَّ مَا بَقِیَ عَلَی الاِبْنَۃِ ، وَلَمْ یُعْطِ الْمَوَالِی شَیْئًا۔",,,31809
31810,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ مَیْسَرَۃَ ، عَنْ إبْرَاہِیمَ : أَنَّہُ أَنْکَرَ حَدِیثَ ابْنَۃِ حَمْزَۃَ ، وَقَالَ : إنَّمَا أَطْعَمَہَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ طُعْمَۃً۔",,,31810
31811,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، قَالَ : أَوْصَی مَوْلًی لِعَلْقَمَۃَ لأَہْلِ عَلْقَمَۃَ بِالثُّلُثِ ، وَأَعْطَی ابْنَ أَخِیہِ لأُمِّہِ الثُّلُثَیْنِ۔",,,31811
31812,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنِ الأَعْمَشِ ، عَنْ سَالِمٍ ، قَالَ : أُتِیَ عَلِیٌّ فِی رَجُلٍ تَرَکَ جَدَّتَہُ وَمَوَالِیَہُ ، فَأَعْطَی الْجَدَّۃَ الْمَالَ دُونَ الْمَوَالِی۔",,,31812
31813,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کُنْتُ أَمْشِی مَعَہُ فَأَدْرَکَتْہُ امْرَأَۃٌ عِنْدَ الصَّیَاقِلَۃِ ، قَالَتْ : إنَّ مَوْلاَتَکَ قَدْ مَاتَتْ فَخُذْ مِیرَاثَہَا ، قَالَ : ہُوَ لَک ، فَقَالَتْ : بَارَکَ اللَّہُ لَک فِیہِ ، قَالَ : أَمَا إِنَّہُ لَوْ کَانَ لِی لَمْ أَدَعْہُ لَک ، وَإِنَّہُ لَمُحْتَاجٌ یَوْمَئِذٍ إلَی تَوْرٍ یُصِیبہُ مِنْ مِیرَاثِہَا ، مِنْ خَمْسَۃِ دَرَاہِمَ ، فَقُلْتُ لَہُ : مَا ہَذِہِ مِنْہَا : قَالَ : ابْنَۃُ أُخْتِہَا لأُمِّہَا۔",,,31813
31814,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، قَالَ : أُتِیَ ابْنُ مَسْعُودٍ فِی أُمٍّ وَإِخْوَۃٍ لأُمٍّ ، فَأَعْطَی الإِخْوَۃَ لِلأُمِّ الثُّلُثَ ، وَأَعْطَی الأُمَّ سَائِرَ الْمَالِ ، وَقَالَ : الأُمُّ عَصَبَۃُ مَنْ لاَ عَصَبَۃَ لَہُ۔",,,31814
31815,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَن مَسْرُوقٍ ، قَالَ : أُتِیَ عَبْدُ اللہِ فِی أُمٍّ وَإِخْوَۃٍ لأُمٍ ، فَأَعْطَی الأُمَّ السُّدُسَ وَالإِخْوَۃَ الثُّلُثَ ، وَرَدَّ مَا بَقِیَ عَلَی الأُمِّ ، وَقَالَ : الأُمُّ عَصَبَۃُ مَنْ لاَ عَصَبَۃَ لَہُ، وَکَانَ ابْنُ مَسْعُودٍ لاَ یَرُدُّ عَلَی أُخْتٍ لأَبٍ مَعَ أُخْتٍ لأَبٍ وَأَمٍ، وَلاَ عَلَی ابْنَۃِ ابْنٍ مَعَ ابْنَۃِ صُلْبٍ۔",,,31815
31816,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ مُغِیرَۃَ وَالأَعْمَشِ ، عَنْ إبْرَاہِیمَ : أَنَّ عَلِیًّا کَانَ یَرُدُّ عَلَی کُلِّ ذِی سَہْمٍ إلاَّ الزَّوْجَ وَالْمَرْأَۃَ۔",,,31816
31817,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مَنْصُورٍ ، قَالَ : بَلَغَنِی عَنْ عَلِیٍّ أَنَّہُ کَانَ یَرُدُّ عَلَی کُلِّ ذِی سَہْمٍ إلاَّ الزَّوْجَ وَالْمَرْأَۃَ۔",,,31817
31818,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ : أَنَّ عَلِیًّا کَانَ یَرُدُّ عَلَی ذَوِی السِّہَامِ مِنْ ذَوِی الأَرْحَامِ۔",,,31818
31819,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ : أَنَّہُ ذُکِرَ عِنْدَہُ قَضَائً قَضَی بِہِ أَبُو عُبَیْدَۃَ بْنُ عَبْدِ اللہِ : أَنَّہُ أَعْطَی ابْنَۃً أِوْ أُخْتِاً الْمَالَ کُلَّہُ ، فَقَالَ الشَّعْبِیُّ : ہَذَا قَضَائُ عَبْدِ اللہِ۔",,,31819
31820,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ إسْمَاعِیلَ ، عَنْ عَامِرٍ ، عَنْ عَبْدِ اللہِ : أَنَّہُ کَانَ یَرُدُّ عَلَی الاِبْنَۃِ وَالأُخْتِ وَالأُمِّ إذَا لَمْ تَکُنْ عَصَبَۃٌ ، وَکَانَ زَیْدٌ لاَ یُعْطِیہِمْ إلاَّ نَصِیبَہُمْ۔",,,31820
31821,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ عَبْدُ اللہِ لاَ یَرُدُّ عَلَی سِتَّۃٍ : عَلَی زَوْجٍ ، وَلاَ امْرَأَۃٍ ، وَلاَ جَدَّۃٍ ، وَلاَ عَلَی أَخَوَاتٍ لأَبٍ مَعَ أَخَوَاتٍ لأَبٍ وَأَمٍ ، وَلاَ عَلَی بَنَاتِ ابْنٍ مَعَ بَنَاتِ صُلْبٍ ، وَلاَ عَلَی أُخْتٍ لأُمٍّ مَعَ أُمٍّ ، قَالَ إبْرَاہِیمُ : فَقُلْتُ لِعَلْقَمَۃَ یُرَدُّ عَلَی الأُخْوَۃِ مِنَ الأُمِّ مَعَ الْجَدَّۃِ ، قَالَ : إنْ شِئْت ، قَالَ : وَکَانَ عَلِیٌّ یَرُدُّ عَلَی جَمِیعِہِمْ إلاَّ الزَّوْجَ وَالْمَرْأَۃَ۔",,,31821
31822,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ عَبْدُ اللہِ لاَ یَرُدُّ عَلَی سِتَّۃٍ : لاَ یَرُدُّ عَلَی زَوْجٍ ، وَلاَ امْرَأَۃٍ ، وَلاَ جَدَّۃٍ ، وَلاَ عَلَی أُخْتٍ لأَبٍ مَعَ أُخْتٍ لأَبٍ وَأَمٍ ، وَلاَ عَلَی أُخْتٍ لأُمٍّ مَعَ أُمٍ ، وَلاَ عَلَی ابْنَۃِ ابْنٍ مَعَ ابْنَۃِ صُلْبٍ۔",,,31822
31823,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ، قَالَ : اُسْتُشْہِدَ سَالِمٌ مَوْلَی أَبِی حُذَیْفَۃَ ، قَالَ : فَأَعْطَی أَبُو بَکْرٍ ابْنَتَہُ النِّصْفَ وَأَعْطَی النِّصْفَ الثَّانِی فِی سَبِیلِ اللہِ۔",,,31823
31824,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ بَسَّامٍ ، عَنْ فُضَیْلِ بْنِ عَمْرٍو ، قَالَ : قَالَ إبْرَاہِیمُ : لَمْ یَکُنْ أَحَدٌ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَرُدُّ عَلَی الْمَرْأَۃِ وَالزَّوْجِ شَیْئًا ، قَالَ : وَکَانَ زَیْدٌ یُعْطِی کُلَّ ذِی فَرْضٍ فَرِیضَتَہُ، وَمَا بَقِیَ جَعَلَہُ فِی بَیْتِ الْمَالِ۔",,,31824
31825,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ عَبْدُ اللہِ لاَ یَرُدُّ عَلَی أُخْتٍ لأَبٍ مَعَ أُخْتٍ لأَبٍ وَأَمٍّ ، وَلاَ یَرُدُّ عَلَی ابْنَۃِ ابْنٍ مَعَ ابْنَۃٍ شَیْئًا ، وَلاَ عَلَی إخْوَۃٍ لأُمٍّ مَعَ أُمٍّ شَیْئًا ، وَلاَ عَلَی زَوْجٍ ، وَلاَ امْرَأَۃٍ۔",,,31825
31826,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ وَالأَعْمَشِ ، قَالاَ : لَمْ یَکُنْ أَحَدٌ یَرُدُّ عَلَی جَدَّۃٍ إلاَّ أَنْ یَکُونَ غَیْرَہَا۔",,,31826
31827,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، قَالَ : سَأَلْتُ الشَّعْبِیَّ عَنِ الْعَمَّۃِ : أَہِیَ أَحَقُّ بِالْمِیرَاثِ ، أَو ابْنَۃُ الأَخِ ؟ قَالَ : فَقَالَ لِی : وَأَنْتَ لاَ تَعْلَمُ ذَلِکَ ، قَالَ : قُلْتُ : ابْنَۃُ الأَخِ أَحَقُّ مِنَ الْعَمَّۃِ ، قَالَ أَبُو إِسْحَاقَ : وَشَہِدَ عَامِرٌ عَلَی مَسْرُوقٍ أَنَّہُ قَالَ : أَنْزِلُوہُمْ مَنَازِلَ آبَائِہِمْ۔",,,31827
31828,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا سُفْیَانُ، عَنِ الشَّیْبَانِیِّ، عَنِ الشَّعْبِیِّ، عَنِ مَسْرُوقٍ، قَالَ: أَنْزِلُوا ذَوِی الأَرْحَامِ مَنَازِلَ آبَائِہِمْ۔",,,31828
31829,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا سُفْیَانُ، عَنِ الشَّیْبَانِیِّ، عَنِ الشَّعْبِیِّ: فِی ابْنَۃِ أَخٍ وَعَمَّۃٍ، قَالَ: الْمَالُ لاِبْنَۃِ الأَخِ۔",,,31829
31830,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا حَسَنُ بْنُ صَالِحٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ إبْرَاہِیمَ ، قَالَ : الْمَالُ لِلْعَمَّۃِ۔",,,31830
31831,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا سُفْیَانُ، عَنْ مُغِیرَۃَ وَمَنْصُورٍ، عَنْ إبْرَاہِیمَ، قَالَ: کَانُوا یُوَرَّثُونَ بِقَدْرِ أَرْحَامِہِمْ۔",,,31831
31832,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنِ الشَّیْبَانِیِّ ، قَالَ : سَأَلْتُ الشَّعْبِیَّ عَنِ ابْنَۃِ أَخٍ وَعَمَّۃٍ أَیُّہُمَا أَحَقُّ بِالْمِیرَاثِ ؟ قَالَ : ابْنَۃُ الأَخِ ، قَالَ : أَنْزِلُوہُمْ مَنَازِلَ آبَائِہِمْ۔",,,31832
31833,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ مُغِیرَۃَ ، قَالَ : قَالَ إبْرَاہِیمُ : قَالَ عَلِیٌّ : لاَ یُضْرَبُ بِسَہْمِ مَنْ لاَ یَرِثُ۔",,,31833
31834,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ یُقَالَ : ذُو السَّہْمِ أَحَقُّ مِمَّنْ لاَ سَہْمَ لَہُ",,,31834
31835,"قَالَ وَکِیعٌ : وَقَالَ غَیْرُ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ : فِی رَجُلٍ مَاتَ وَتَرَکَ أُخْتَیْنِ لأَبٍ وَأُخْتَیْنِ لأَبٍ وَأَمٍّ ، قَالَ : کَانَ یُقَالَ : ذُو السَّہْمِ أَحَقُّ مِمَّنْ لاَ سَہْمَ لَہُ۔",,,31835
31836,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ بَسَّامٍ ، عَنْ فُضَیْلٍ ، عَنْ إبْرَاہِیمَ : فِی امْرَأَۃٍ مُسْلِمَۃٍ تَرَکَتْ زَوْجَہَا مُسْلِمًا وَإِخْوَتَہَا لأُمِّہَا مُسْلِمِینَ وَلَہَا ابْنٌ نَصْرَانِیٌّ ، أَوْ یَہُودِیٌّ ، أَوْ کَافِرٌ ، فَلِزَوْجِہَا النِّصْفُ ثَلاَثَۃُ أَسْہُمٍ وَلاِِخْوَتِہَا لأُمِّہَا الثُّلُثُ سَہْمَانِ ، وَمَا بَقِیَ فَلِذِی الْعَصَبَۃِ فِی قَوْلِ عَلِیٍّ وَزَیْدٍ ، وَلاَ یَرِثُ یَہُودِیٌّ ، وَلاَ نَصْرَانِیٌّ مُسْلِمًا، وَقَضَی فِیہَا عَبْدُ اللہِ : أَنَّ لِلزَّوْجِ الرُّبْعَ مِنْ أَجْلِ أَنَّ لَہَا وَلَدًا کَافِرًا ، وَہُمْ یَحْجِبُونَ فِی قَوْلِ عَبْدِ اللہِ ، وَلاَ یَرِثُونَ ، وَفِی قَوْلِ عَلِیٍّ وَزَیْدٍ : لاَ یَحْجُبُونَ وَلاَ یَرِثُونَ ، قَالَ أَبُو بَکْرٍ : فَہَذِہِ فِی قَوْلِ عَلِیٍّ وَزَیْدٍ مِنْ سِتَّۃِ أَسْہُمٍ ، وَفِی قَوْلِ عَبْدِ اللہِ بْنِ مَسْعُودٍ مِنْ أَرْبَعَۃٍ۔",,,31836
31837,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ بَسَّامٍ ، عَنْ فُضَیْلٍ ، قَالَ : قَالَ إبْرَاہِیمُ فِی امْرَأَۃٍ مُسْلِمَۃٍ تَرَکَتْ أُمَّہَا مُسْلِمَۃً وَلَہَا إخْوَۃٌ نَصَارَی أَوْ یَہُودٌ ، أَوْ کُفَّارٌ ، فَقَضَی عَبْدُ اللہِ : أَنَّ لَہَا مَعَہُمَ السُّدُسَ ، وَجَعَلَہُمْ یَحْجُبُونَ وَلاَ یَرِثُونَ ، وَقَضَی فِیہَا سَائِرُ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَنَّہُمْ لاَ یَحْجُبُونَ وَلاَ یَرِثُونَ۔\n\nقَالَ أَبُو بَکْرٍ : فَہِیَ فِیمَا قَضَی سَائِرُ أَصْحَابُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ غَیْرُ عَبْدِ اللہِ مِنْ أَرْبَعَۃِ أَسْہُمٍ ، فَہِیَ لِذِی الْعَصَبَۃِ ، وَہِیَ فِی قَضَائِ عَبْدِ اللہِ : مِنْ خَمْسَۃُ أَسْہُمٍ ، فَہِیَ لِذِی الْعَصَبَۃِ بِالرَّحِمِ۔\n\nقَالَ أَبُو بَکْرٍ : فَہَذِہِ فِی قَوْلِہِمْ جَمِیعًا مِنْ سِتَّۃِ أَسْہُمٍ ، إنْ کَانَ فِی قَوْلِ عَبْدِ اللہِ : فَلِلأُمِّ السُّدُسُ وَیَبْقَی خَمْسَۃٌ ، وَإِنْ کَانَ فِی قَوْلِ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : فَلِلأُمِّ الثُّلُثُ وَہُوَ سَہْمَانِ ، وَأَرْبَعَۃٌ لِسَائِرِ الْعَصَبَۃِ۔",,,31837
31838,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ بَسَّامٍ ، عَنْ فُضَیْلٍ ، قَالَ : قَالَ إبْرَاہِیمُ : فِی امْرَأَۃٍ تَرَکَتْ زَوْجَہَا وَإِخْوَتَہَا لأُمِّہَا أَحْرَارًا ، وَلَہَا ابْنٌ مَمْلُوکٌ : فَلِزَوْجِہَا النِّصْفُ ثَلاَثَۃُ أَسْہُمٍ ، وَلإِخْوَتِہَا لأُمِّہَا الثُّلُثُ سَہْمَانِ ، وَیَبْقَی السُّدُسُ فَہُوَ لِلْعَصَبَۃِ ، وَلاَ یَرِثُ ابْنُہَا الْمَمْلُوکُ شَیْئًا فِی قَضَائِ عَلِی۔\n\nوَقَضَی فِیہَا عَبْدُ اللہِ : أَنَّ لِزَوْجِہَا الرُّبْعَ سَہْم وَنِصْف ، وَأَنَّ ابْنَہَا یَحْجُبُ الإِخْوَۃَ مِنَ الأُمِّ إذَا کَانَ مَمْلُوکًا، وَلاَ یَرِثُ ابْنُہَا شَیْئًا وَیَحْجُبُ الزَّوْجَ ، وَأَنَّ الثَّلاَثَۃَ أَرْبَاعٍ الْبَاقِیَۃِ لِلْعَصَبَۃِ۔\n\nوَقَضَی فِیہَا زَیْدٌ : أَنَّ لِزَوْجِہَا النِّصْفَ ثَلاَثَۃَ أَسْہُمٍ ، وَأَنَّ لاِِخْوَتِہَا لأُمِّہَا الثُّلُثَ سَہْمَانِ ، وَمَا بَقِیَ فَہُوَ فِی بَیْتِ الْمَالِ إذَا لَمْ یَکُنْ ، وَلاَئٌ ، وَلاَ رَحِمٌ\n\nقَالَ أَبُو بَکْرٍ : فَہَذِہِ فِی قَوْلِ عَلِیٍّ وَزَیْدٍ مِنْ سِتَّۃِ أَسْہُمٍ ، وَفِی قَوْلِ عَبْدِ اللہِ بْنِ مَسْعُودٍ مِنْ أَرْبَعَۃِ أَسْہُمٍ۔",,,31838
31839,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ جُرَیْج ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : الْفَرَائِضُ لاَ تَعُولُ۔",,,31839
31840,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلِیٍّ وَعَبْدِ اللہِ وَزَیْدٍ : أَنَّہُمْ أَعَالُوا الْفَرِیضَۃَ۔",,,31840
31841,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ، عَنْ شُرَیْحٍ : فِی أُخْتَیْنِ لأَبٍ وَأَمٍّ ، وَأُخْتَیْنِ لأُمٍّ ، وَزَوْجٍ ، وَأَمٍّ ، قَالَ : مِنْ عَشَرَۃٍ ، لِلأُخْتَیْنِ مِنَ الأَبِ وَالأُمِّ أَرْبَعَۃٌ ، وَلِلأُخْتَیْنِ مِنَ الأُمّ سَہْمَانِ ، وَلِلزَّوْجِ ثَلاَثَۃُ أَسْہُمٍ ، وَلِلأُمِّ سَہْمٌ۔\n\nوَقَالَ وَکِیعٌ : وَالنَّاسُ عَلَی ہَذَا ، وَہَذِہِ قِسْمَۃُ ابْن الْفَرُّوخِ۔",,,31841
31842,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : یَحْجُبُنِی بَنُو بَنِیَّ دُونَ إخْوَتِی ، وَلاَ أَحْجُبُہُمْ دُونَ إخْوَتِہِمْ۔",,,31842
31843,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ بَسَّامٍ ، عَنْ فُضَیْلٍ ، عَنْ إبْرَاہِیمَ : فِی امْرَأَۃٍ تَرَکَتْ أُخْتَہَا لأُمِّہَا وَأُمَّہَا ، وَلاَ عَصَبَۃَ لَہَا ، فَلأُخْتِہَا مِنْ أُمِّہَا السُّدُسُ ، وَلأُمِّہَا خَمْسَۃُ أَسْدَاسٍ فِی قَضَائِ عَبْدِ اللہِ ، وَقَضَی فِیہَا زَیْدٌ : أَنَّ لأُخْتِہَا مِنْ أُمِّہَا السُّدُسَ ، وَلأُمِّہَا الثُّلُثَ ، وَیَجْعَلُ سَائِرَہُ فِی بَیْتِ الْمَالِ ، وَقَضَی فِیہَا عَلَیَّ : أَنَّ لَہُمَا الْمَالَ عَلَی قَدْرِ مَا وَرِثَا ، فَجَعَلَ لِلأُخْتِ مِنَ الأُمِّ الثُّلُثَ وَلِلأُمِّ الثُّلُثَیْنِ۔\n\nقَالَ أَبُو بَکْرٍ : فَہَذِہِ فِی قَوْلِ عَلِیٍّ مِنْ ثَلاَثَۃِ أَسْہُمٍ ، وَفِی قَوْلِ عَبْدِ اللہِ وَزَیْدٍ مِنْ سِتَّۃٍ۔",,,31843
31844,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ بَسَّامٍ ، عَنْ فُضَیْلٍ ، قَالَ : قَالَ إبْرَاہِیمُ فِی امْرَأَۃٍ تَرَکَتْ أُخْتَہَا لأَبِیہَا وَأُمَّہَا وَأُخْتَہَا مِنْ أَبِیہَا ، وَلاَ عَصَبَۃَ لَہَا غَیْرُہُمَا : فَلأُخْتِہَا لأَبِیہَا وَأُمِّہَا ثَلاَثَۃُ أَرْبَاعٍ ، وَلأُخْتِہَا مِنْ أَبِیہَا الرُّبْعُ فِی قَضَائِ عَلِی ، وَقَضَی عَبْدُ اللہِ : أَنَّ لِلأُخْتِ مِنَ الأَبِ وَالأُمِّ خَمْسَۃَ أَسْہُمٍ ، وَلِلأُخْتِ مِنَ الأَبِ السُّدُسُ ، وَقَضَی فِیہَا زَیْدٌ : أَنَّ لِلأُخْتِ لِلأَبِ وَالأُمِّ ثَلاَثَۃَ أَسْہُمٍ وَلِلأُخْتِ لِلأَبِ السُّدُسَ ، وَمَا بَقِیَ لِبَیْتِ الْمَالِ إذَا لَمْ یَکُنْ وَلاَئٌ وَلاَ عَصَبَۃٌ۔\n\nقَالَ أَبُو بَکْرٍ : فَہَذِہِ فِی قَوْلِ عَلِیٍّ مِنْ ثَلاَثَۃِ أَسْہُمٍ ، وَفِی قَوْلِ عَبْدِ اللہِ وَزَیْدٍ مِنْ سِتَّۃِ أَسْہُمٍ۔",,,31844
31845,"حَدَّثَنَا ابْنُ فُضَیْلٍ، عَنْ بَسَّامٍ ، عَنْ فُضَیْلٍ ، قَالَ : قَالَ إبْرَاہِیمُ فِی امْرَأَۃٍ تَرَکَتِ ابْنَتَہَا وَابْنَۃَ ابْنِہَا وَأُمَّہَا، وَلاَ عَصَبَۃَ لَہَا : فَلاِبْنَتِہَا ثَلاَثَۃُ أَخْمَاسٍ ، وَلاِبْنَۃِ ابْنِہَا خُمُسٌ ، وَلأُمِّہَا خُمُسٌ فِی قَضَائِ عَلِی ، وَقَضَی فِیہَا عَبْدُ اللہِ : أَنَّہَا مِنْ أَرْبَعَۃٍ وَعِشْرِینَ سَہْمًا : فَلاِبْنَۃِ الاِبْنِ مِنْ ذَلِکَ السُّدُسُ أَرْبَعَۃُ أَسْہُمٍ ، وَلِلأُمِّ رُبْعُ مَا بَقِیَ خَمْسَۃُ أَسْہُمٍ ، وَلِلاِبْنَۃِ ثَلاَثَۃُ أَرْبَاعِ عِشْرِینَ : خَمْسَۃَ عَشَرَ سَہْمًا ، وَقَضَی فِیہَا زَیْدٌ : لِلاِبْنَۃِ النِّصْفُ وَلاِبْنَۃِ الاِبْنِ السُّدُسُ وَلِلأُمِّ السُّدُسُ ، وَمَا بَقِیَ فَفِی بَیْتِ الْمَالِ إذَا لَمْ یَکُنْ وَلاَئٌ وَلاَ عَصَبَۃٌ۔",,,31845
31846,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ بَسَّامٍ ، عَنْ فُضَیْلٍ بْنِ عَمْرو ، قَالَ : قَالَ إبْرَاہِیمُ : یَرِثُ مِنَ النِّسَائِ سِتُّ نِسْوَۃٍ : الاِبْنَۃُ، وَابْنَۃُ الاِبْنِ، وَالأُمُّ، وَالْجَدَّۃُ، وَالأُخْتُ، وَالْمَرْأَۃُ، وَیَرِثُ النِّسَائُ مِنَ الرِّجَالِ سَبْعَۃَ نَفَرٍ: تَرِثُ أَبَاہَا، وَابْنَہَا، وَابْنَ ابْنِہَا، وَأَخَاہَا، وَزَوْجَہَا، وَجَدَّہَا، وَتَرِثُ مِنَ ابْنِ ابْنَتِہَا سُدُسًا إلاَّ أَنْ یَکُونَ لَہُ عَصَبَۃٌ غَیْرُہَا۔",,,31846
31847,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا مِنْدَلٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ: یَرِثُ الرَّجُلُ سِتُّ نِسْوَۃٍ: ابْنَتَہُ ، وَابْنَۃَ ابْنِہِ ، وَأُمَّہُ ، وَجَدَّتَہُ ، وَأُخْتَہ ، وَزَوْجَتَہُ ، وَتَرِثُ الْمَرْأَۃُ سَبْعَۃ نَفَرٍ : ابْنَہَا ، وَابْنَ ابْنِہَا ، وَأَبَاہَا ، وَجَدَّہَا ، وَزَوْجَہَا ، وَأَخَاہَا ، وَتَرِثُ مِنَ ابْنِ ابْنَتِہَا سُدُسًا ، وَلاَ یَرِثُ ہُوَ مِنْہَا شَیْئًا فِی قَوْلِہِمْ کُلِّہِمْ۔",,,31847
31848,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ النُّعْمَانِ بْنِ سَالِمٍ ، قَالَ : سَأَلْتُ ابْنَ عُمَرَ عَنِ ابْنِ ابْنَۃٍ : أَرَأَیْت رَجُلاً تَرَکَ ابْنِ ابْنَتہ ، أَیَرِثہُ ؟ قَالَ : لا۔",,,31848
31849,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَنْ مِنْدَلٍ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ إبْرَاہِیمَ ، قَالَ : فِی قَوْلِ عَلِیٍّ وَزَیْدٍ : ابْنُ الاِبْنِ یُرَدُّ عَلَی مَنْ تَحْتَہُ وَمَنْ فَوْقَہُ لِلذَّکَرِ مِثْلُ حَظِّ الأُنْثَیَیْنِ ، وَفِی قَوْلِ عَبْدِ اللہِ : إذَا اسْتَکْمَلَ الثُّلُثَیْنِ فَلَیْسَ لِبَنَاتِ الاِبْنِ شَیْئٌ۔",,,31849
31850,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا مِنْدَلٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ فِی قَوْلِ عَبْدِ اللہِ : لِلاِبْنَۃِ النِّصْفُ ، وَمَا بَقِیَ لِبَنِی الاِبْنِ وَبَنَاتِ الاِبْنِ : لِلذَّکَرِ مِثْلُ حَظِّ الأُنْثَیَیْنِ ، مَا لَمْ یَزِدْنَ بَنَاتُ الاِبْنِ عَلَی السُّدُسِ۔",,,31850
31851,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا مِنْدَلٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ یَرِثُ الإِخْوَۃُ مِنَ الأُمِّ مَعَ وَلَدٍ ، وَلاَ وَلَدَ ابْنٍ ذَکَرٍ وَلاَ أُنْثَی ، وَلاَ مَعَ أَبٍ ، وَلاَ مَعَ جَدٍّ۔",,,31851
31852,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ رَجُلٍ لَمْ یُسَمِّہِ ، قَالَ : مَا رَأَیْت رَجُلاً کَانَ أَحْسَبُ مِنْ عَلِیٍّ سُئِلَ عَنِ ابْنَتَیْنِ وَأَبَوَیْنِ وَامْرَأَۃٍ ، فَقَالَ : صَارَ ثَمَنُہَا تُسُعًا۔\n\nقَالَ أَبُو بَکْرٍ : فَہَذِہِ مِنْ سَبْعَۃٍ وَعِشْرِینَ سَہْمًا : لِلاِبْنَتَیْنِ سِتَّۃَ عَشَرَ ، وَلِلأَبَوَیْنِ ثَمَانِیَۃٌ وَلِلْمَرْأَۃِ ثَلاَثَۃٌ۔",,,31852
31853,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ خَالِدٍ ، عَنْ أَبِی نَضْرَۃَ ، عَنْ أَبِی سَعِیدٍ : أَنَّ أَبَا بَکْرٍ کَانَ یَرَی الْجَدَّ أَبًا۔",,,31853
31854,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ أَبِی بُرْدَۃَ ، عَنْ کُرْدُوسِ بْنِ عَبَّاسٍ الثَّعْلبِیِّ ، عَنْ أَبِی مُوسَی : أَنَّ أَبَا بَکْرٍ جَعَلَ الْجَدَّ أَبًا۔",,,31854
31855,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، قَالَ : قَالَ ابْنُ الزُّبَیْرِ : إنَّ الَّذِی قَالَ فِیہِ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَوْ کُنْت مُتَّخِذًا خَلِیلاً لاَتَّخَذْتہ خَلِیلاً جَعَلَ الْجَدَّ أَبًا۔ یَعْنِی : أَبَا بَکْرٍ۔\n\n(بخاری 3658۔ احمد 4)",,,31855
31856,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ فُرَاتٍ الْقَزَّازِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : کَتَبَ ابْنُ الزُّبَیْرِ إلَی عَبْدِ اللہِ بْنِ عُتْبَۃَ : إنَّ أَبَا بَکْرٍ کَانَ یَجْعَلُ الْجَدَّ أَبًا۔ (احمد 4۔ ابویعلی 6772)",,,31856
31857,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ خَالِدٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ مَعْقِلٍ ، قَالَ : کُنْتُ عِنْدَ ابْنِ عَبَّاسٍ فَسَأَلَہُ رَجُلٌ عَنِ الْجَدِّ ؟ فَقَالَ لَہُ ابْنُ عَبَّاسٍ : أَیُّ أَبٍ لَک أَکْبَرُ ؟ فَلَمْ یَدْرِ الرَّجُلُ مَا یَقُولُ ، فَقُلْتُ أَنَا : آدَم ، فَقَالَ ابْنُ عَبَّاسٍ : إنَّ اللَّہَ یَقُولُ : یَا بَنِی آدَمَ۔",,,31857
31858,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، عَنْ أَبِی بَکْرٍ وَابْنِ عَبَّاسٍ وَعُثْمَانَ : أَنَّہُمْ جَعَلُوا الْجَدَّ أَبًا۔",,,31858
31859,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ : أَنَّہُ جَعَلَہُ أَبًا۔",,,31859
31860,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ مَالِکِ بْنِ أَنَسٍ ، عَنِ الزُّہْرِیِّ ، عَنْ قَبِیصَۃَ بْنِ ذُؤَیْبٍ : أَنَّ عُمَرَ کَانَ یَفْرِضُ لِلْجَدِّ الَّذِی یَفْرِضُ لَہُ النَّاسُ الْیَوْمَ ، قُلْتُ لَہُ : یَعْنِی : قَوْلَ زَیْدِ بْنِ ثَابِتٍ ؟ قَالَ : نَعَمْ۔",,,31860
31861,"حَدَّثَنَا وَکِیعٌ ، عَنِ الرَّبِیعِ ، عَنْ عَطَائٍ ، عَنْ أَبِی بَکْرٍ ، قَالَ : الْجَدُّ بِمَنْزِلَۃِ الأَبِ مَا لَمْ یَکُنْ أَبٌ دُونَہُ ، وَابْنُ الاِبْنِ بِمَنْزِلِہِ الاِبْنِ مَا لَمْ یَکُنَ ابْنٌ دُونَہُ۔",,,31861
31862,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ إسْمَاعِیلَ بْنِ سُمَیْعٍ ، قَالَ : قَالَ رَجُلٌ لأَبِی وَائِلٍ : إنَّ أَبَا بُرْدَۃَ یَزْعُمُ أَنَّ أَبَا بَکْرٍ جَعَلَ الْجَدَّ أَبًا ؟ فَقَالَ : کَذَبَ ، لَوْ جَعَلَہُ أَبًا لَمَا خَالَفَہُ عُمَرُ۔",,,31862
31863,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : حدَّثَنَا ہِمَّامٌ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، عَنْ عِمْرَانَ بْنِ حُصَیْنٍ : أَنَّ رَجُلاً أَتَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : إنَّ ابْنَ ابْنِی مَاتَ فَمَا لِی مِنْ مِیرَاثِہِ ؟ قَالَ : لَکَ السُّدُسُ ، فَلَمَّا أَدْبَرَ دَعَاہُ ، قَالَ : لَک سُدُسٌ آخَرُ ، فَلَمَّا أَدْبَرَ دَعَاہُ ، قَالَ : إنَّ السُّدُسَ الآخَر طُعْمَۃٌ۔\n\n(ابوداؤد 2888۔ احمد 428)",,,31863
31864,"حَدَّثَنَا شَبَابَۃُ ، عَنْ یُونُسَ بْنِ أَبِی إِسْحَاقَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَمْرِو بْنِ مَیْمُونٍ ، عَنْ مَعْقِلِ بْنِ یَسَارٍ الْمُزَنِیّ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أُتِیَ بِفَرِیضَۃٍ فِیہَا جَدٌّ فَأَعْطَاہُ ثُلُثًا أَوْ سُدُسًا۔ (ابن ماجہ 6722۔ طبرانی 536)",,,31864
31865,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ : أَنَّ عُمَرَ ، قَالَ : مَنْ یَعْلَم قَضِیَّۃَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی الْجَدِّ ؟ فَقَالَ : مَعْقِلُ بْنُ یَسَارٍ الْمُزَنِیّ : فِینَا قَضَی بِہِ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : مَا ذَاک ؟ قَالَ : السُّدُسُ ، قَالَ : مَعَ مَنْ ؟ قَالَ لاَ أَدْرِی ، قَالَ : لاَ دَرَیْت ، فَمَا تُغْنِی إذًا۔",,,31865
31866,"حَدَّثَنَا قَبِیصَۃُ ، عَنْ سُفْیَانَ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، عْن عِیَاضٍ ، عَنْ أَبِی سَعِیدٍ ، قَالَ : کُنَّا نُوَرِّثُہُ عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔ یَعْنِی : الْجَدَّ۔ (ابویعلی 1090)",,,31866
31867,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ صَالِحٍ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ عَلِیٌّ لاَ یَزِیدُ الْجَدَّ مَعَ الْوَلَدِ عَلَی السُّدُسِ۔",,,31867
31868,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عُبَیْدِ بْنِ نُضَیْلَۃَ ، قَالَ : کَانَ عُمَرُ وَعَبْدُ اللہِ یُقَاسِمَانِ بِالْجَدِّ مَعَ الإِخْوَۃِ مَا بَیْنَہُ وَبَیْنَ أَنْ یَکُونَ السُّدُسُ خَیْرًا لَہُ مِنْ مُقَاسَمَتِہِمْ ، ثُمَّ إنَّ عُمَرَ کَتَبَ إلَی عَبْدِ اللہِ : مَا أَرَی إلاَّ أَنَّا قَدْ أَجْحَفْنَا بِالْجَدِّ ، فَإِذَا جَائَک کِتَابِی ہَذَا فَقَاسِمِ بِہِ مَعَ الإِخْوَۃِ مَا بَیْنَہُ وَبَیْنَ أَنْ یَکُونَ الثُّلُثُ خَیْرًا لَہُ مِنْ مُقَاسَمَتِہِمْ ، فَأَخَذَ بِہِ عَبْدُ اللہِ۔",,,31868
31869,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَبِی الْعَلاَئِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، قَالَ : کَانَ عَبْدُ اللہِ یُشَرِّکُ الْجَدَّ مَعَ الإِخْوَۃِ ، فَإِذَا کَثُرُوا وَفَّاہ الثُّلُثَ ، فَلَمَّا تُوُفِّیَ عَلْقَمَۃُ أَتَیْتُ عَبِیدَۃَ ، فَحَدَّثَنِی أَنَّ ابْنَ مَسْعُودٍ کَانَ یُشَرِّکُ الْجَدَّ مَعَ الإِخْوَۃِ ، فَإِذَا کَثُرُوا وَفَّاہُ السُّدُسَ ، فَرَجَعْت مِنْ عِنْدِہِ وَأَنَا خَاثِرٌ۔\n\nفَمَرَرْت بِعُبَیْدِ بْنِ نُضَیْلَۃَ فَقَالَ : مَا لِی أَرَاک خَاثِراً ؟ قَالَ : قُلْتُ : کَیْفَ لاَ أَکُونُ خَاثِرًا ، فَحَدَّثْتہ ، فَقَالَ : صَدَقَاک کِلاَہُمَا ، قُلْتُ : لِلَّہِ أَبُوک وَکَیْفَ صَدَقَانِی کِلاَہُمَا ، قَالَ : کَانَ رَأْیُ عَبْدِ اللہِ وَقِسْمَتُہُ أَنْ یُشَرِّکَہُ مَعَ الإِخْوَۃِ ، فَإِذَا کَثُرُوا وَفَّاہُ السُّدُسَ ، ثُمَّ وَفَدَ إلَی عُمَرَ فَوَجَدَہُ یُشَرِّکُہُ مَعَ الإِخْوَۃِ ، فَإِذَا کَثُرُوا وَفَّاہُ الثُّلُثَ ، فَتَرَکَ رَأْیَہُ وَتَابَعَ عُمَرَ۔",,,31869
31870,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ عَبْدِ اللہِ بْنِ سَلِمَۃَ ، عَنْ عَلِیٍّ : أَنَّہُ کَانَ یُقَاسِمُ بِالْجَدِّ الإِخْوَۃَ إلَی السُّدُسِ۔",,,31870
31871,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ أَبِی خَالِدٍ ، عَنِ الشَّعْبِیِّ ، عَنْ عَلِیٍّ : أَنَّہُ أُتِیَ فِی سِتَّۃِ إخْوَۃٍ وَجَدٍّ ، فَأَعْطَی الْجَدَّ السُّدُسَ۔",,,31871
31872,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ فِرَاسٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : کَتَبَ ابْنُ عَبَّاسٍ إلَی عَلِیٍّ یَسْأَلُہُ عَنْ سِتَّۃِ إخْوَۃٍ وَجَدٍّ ؟ فَکَتَبَ إلَیْہِ : أَنِ اجْعَلْہُ کَأَحَدِہِمْ ، وَامْحُ کِتَابِی۔",,,31872
31873,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ : أَنَّ زَیْدًا کَانَ یُقَاسِمُ بِالْجَدِّ مَعَ الإِخْوَۃِ مَا بَیْنَہُ وَبَیْنَ الثُّلُثِ۔",,,31873
31874,"حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عُمَرَ وَعَبْدِ اللہِ : أَنَّہُمَا کَانَا یُقَاسِمَانِ الْجَدَّ مَعَ الإِخْوَۃِ مَا بَیْنَہُ وَبَیْنَ الثُّلُثِ۔",,,31874
31875,"حَدَّثَنَا حَفْصٌ، عَنِ الأَعْمَشِ، عَنْ إبْرَاہِیمَ: أَنَّ عَلِیًّا کَانَ یُقَاسِمُ الْجَدَّ مَعَ الإِخْوَۃِ مَا بَیْنَہُ وَبَیْنَ السُّدُسِ۔",,,31875
31876,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَتَبَ عُمَرُ إلَی عَبْدِ اللہِ بْنِ مَسْعُودٍ : إنَّا قَدْ خَشِینَا أَنْ نَکُونَ قَدْ أَجْحَفْنَا بِالْجَدِّ ، فَأَعْطِہِ الثُّلُثَ مَعَ الإِخْوَۃِ۔",,,31876
31877,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ : أَنَّ زَیْدًا کَانَ یَقُول : یُقَاسَمُ الْجَدَّ مَعَ الْوَاحِدِ وَالاِثْنَیْنِ، فَإِذَا کَانُوا ثَلاَثَۃً کَانَ لَہُ ثُلُثُ جَمِیعِ الْمَالِ ، فَإِنْ کَانَ مَعَہُ فَرَائِضُ نُظِرَ لَہُ ، فَإِنْ کَانَ الثُّلُثُ خَیْرًا لَہُ أُعْطِیَہُ ، وَإِنْ کَانَتِ الْمُقَاسَمَۃُ خَیْرًا لَہُ قَاسَمَ ، وَلاَ یُنْتَقَصُ مِنْ سُدُسِ جَمِیعِ الْمَالِ۔",,,31877
31878,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ بَسَّامٍ ، عَنْ فُضَیْلٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ عَبْدُ اللہِ وَزَیْدٌ یَجْعَلاَنِ لِلْجَدِّ الثُّلُثَ وَلِلإِخْوَۃِ الثُّلُثَیْنِ ، وَفِی رَجُلٍ تَرَکَ أَرْبَعَۃَ إخْوَۃٍ لأَبِیہِ وَأُمِّہِ وَأُخْتَیْہِ لأَبِیہِ وَأُمِّہِ وَجَدِّہِ ، قَالَ : کَانَ عَلِیٌّ یَجْعَلُہَا أَسْہُمًا أَسْدَاسًا لِلْجَدِّ السُّدُسَ ، لَمْ یَکُنْ عَلِیٌّ یَجْعَلُ لِلْجَدِّ أَقَلَّ مِنَ السُّدُسِ مَعَ الإِخْوَۃِ ، وَمَا بَقِیَ فَلِلذَّکَرِ مِثْلُ حَظِّ الأُنْثَیَیْنِ ، وَکَانَ عَبْدُ اللہِ وَزَیْدٌ یُعْطِیَانِ الْجَدَّ الثُّلُثَ وَالإِخْوَۃَ الثُّلُثَیْنِ لِلذَّکَرِ مِثْلُ حَظِّ الأُنْثَیَیْنِ ، وَقَالَ فِی خَمْسَۃِ إخْوَۃٍ وَجَدٍّ ، قَالَ : فَلِلْجَدِّ فِی قَوْلِ عَلِیٍّ السُّدُسُ ، وَلِلإِخْوَۃِ خَمْسَۃُ أَسْدَاسٍ ، وَکَانَ عَبْدُ اللہِ وَزَیْدٌ یُعْطِیَانِ الْجَدَّ الثُّلُثَ ، وَالإِخْوَۃَ الثُّلُثَیْنِ۔",,,31878
31879,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، عَنْ مَسْرُوقٍ ، قَالَ : کَانَ ابْنُ مَسْعُودٍ لاَ یَزِیدُ الْجَدَّ عَلَی السُّدُسِ مَعَ الإِخْوَۃِ ، قَالَ : فَقُلْتُ لَہُ : شَہِدْت عُمَرَ بْنَ الْخَطَّابِ أَعْطَاہُ الثُّلُثَ مَعَ الإِخْوَۃِ ، فَأَعْطَاہُ الثُّلُثَ۔",,,31879
31880,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ دَاوُدَ ، عَنْ شَہْرِ بْنِ حَوْشَبٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ غَنْمٍ ، قَالَ : إنَّ أَوَّلَ جَدٍّ ورِّثَ فِی الإسْلاَمِ : عُمَرُ بْنُ الْخَطَّابِ ، فَأَرَادَ أَنْ یَحْتَازَ الْمَالَ ، فَقُلْتُ لَہُ : یَا أَمِیرَ الْمُؤْمِنِینَ ، إنَّہُمْ شَجَرَۃٌ دُونَک۔ یَعْنِی : بَنِی بَنِیہِ۔\n\nقَالَ أَبُو بَکْرٍ : فَہَذِہِ فِی قَوْلِ عُمَرَ ، وَعَبْدِ اللہِ وَزَیْدٍ مِنْ ثَلاَثَۃِ أَسْہُمٍ ، فَلِلْجَدِّ الثُّلُثُ ، وَمَا بَقِیَ فَلِلإِخْوَۃِ ، وَفِی قَوْلِ عَلِیٍّ مِنْ سِتَّۃِ أَسْہُمٍ : لِلْجَدِّ السُّدُسُ سَہْمٌ ، وَلِلإِخْوَۃِ خَمْسَۃُ أَسْہُمٍ۔",,,31880
31881,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَبْدِ اللہِ : فِی أُخْتٍ وَجَدٍّ : النِّصْفُ ، وَالنِّصْفُ۔",,,31881
31882,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ بَسَّامٍ ، عَنْ فُضَیْلٍ ، عَنْ إبْرَاہِیمَ : فِی رَجُلٍ تَرَکَ جَدَّہُ وَأَخَاہُ لأَبِیہِ وَأُمِّہِ : فَلِلْجَدِّ النِّصْفُ وَلأَخِیہِ النِّصْفُ فِی قَوْلِ عَلِیٍّ وَعَبْدِ اللہِ وَزَیْدٍ ، قَالُوا فِی رَجُلٍ تَرَکَ جَدَّہُ وَإِخْوَیہ لأَبِیہِ وَأُمِّہِ : فَلِلْجَدِّ الثُّلُثُ وَلِلإِخْوَۃِ الثُّلُثَانِ فِی قَوْلِہِمْ جَمِیعًا۔\n\nقَالَ أَبُو بَکْرٍ : فَہَذِہِ مِنْ سَہْمَیْنِ إذَا کَانَتْ أُخْتٌ ، أَوْ أَخٌ وَجَدٌّ ، فَلِلْجَدِّ النِّصْفُ ، وَلِلأُخْتِ - أَو الأَخِ - النِّصْفُ ، وَإِنْ کَانَا أَخَوَیْنِ فَلِلْجَدِّ الثُّلُثُ ، وَلِلأَخَوَیْنِ الثُّلُثَانِ۔",,,31882
31883,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ بَسَّامٍ ، عَنْ فُضَیْلٍ ، عَنْ إبْرَاہِیمَ : فِی رَجُلٍ تَرَکَ جَدَّہُ ، وَابْنَ أَخِیہِ لأَبِیہِ وَأُمِّہِ : فَلِلْجَدِّ الْمَالُ فِی قَضَائِ عَلِیٍّ ، وَعَبْدِ اللہِ وَزَیْدٍ۔\n\nفَہَذِہِ مِنْ سَہْمٍ وَاحِدٍ وَہُوَ الْمَالُ کُلُّہُ۔",,,31883
31884,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ بَسَّامٍ ، عَنْ فُضَیْلٍ ، عَنْ إبْرَاہِیمَ : فِی رَجُلٍ تَرَکَ جَدَّہُ وَأَخَاہُ لأَبِیہِ وَأُمِّہِ وَأَخَاہُ لأَبِیہِ : فَلِلْجَدِّ النِّصْفُ ، وَلأَخِیہِ لأَبِیہِ وَأُمِّہِ النِّصْفُ فِی قَوْلِ عَلِیٍّ وَعَبْدِ اللہِ ، وَکَانَ زَیْدٌ یُعْطِی الْجَدَّ الثُّلُثَ، وَالأَخَ مِنَ الأَبِ وَالأُمِّ الثُّلُثَیْنِ ، قَاسَمَ بِالأَخِ مِنَ الأَبِ مَعَ الأَخِ مِنَ الأَبِ وَالأُمِّ ، وَلاَ یَرِثُ شَیْئًا۔",,,31884
31885,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ عَبْدُ اللہِ یُقَاسِمُ بِالْجَدِّ الأُخْوَۃَ إلَی الثُّلُثِ ، وَیُعْطِی کُلَّ صَاحِبِ فَرِیضَۃٍ فَرِیضَتَہُ ، وَلاَ یُوَرِّثُ الأُخْوَۃَ مِنَ الأُمِّ مَعَ الْجَدِّ ، وَلاَ یُقَاسِمُ بِالأُخْوَۃِ لِلأَبِ الأُخْوَۃُ لِلأَبِ وَالأُمِّ مَعَ الْجَدِّ ، وَإِذَا کَانَتْ أُخْتٌ لأَبٍ وَأُمٌّ وَأُخْتٌ لأَبٍ وَجَدٌّ ، أَعْطَی الأُخْتَ مِنَ الأَبِ وَالأُمِّ النِّصْفَ ، وَالْجَدَّ النِّصْفَ۔\n\nوَکَانَ عَلِیٌّ یُقَاسِمُ بِالْجَدِّ الأُخْوَۃَ إلَی السُّدُسِ ، وَیُعْطِی کُلَّ صَاحِبِ فَرِیضَۃٍ فَرِیضَتَہُ ، وَلاَ یُوَرِّثُ الأخْوَۃَ مِنَ الأُمِّ مَعَ الْجَدِّ ، وَلاَ یَزِیدُ الْجَدَّ مَعَ الْوَلَدِ عَلَی السُّدُسِ إلاَّ أَنْ لاَ یَکُونَ غَیْرَہُ ، فَإِذَا کَانَتْ أُخْتٌ لأَبٍ وَأَمٍّ ، وَأَخٌ وَأُخْتٌ لأَبٍ ، وَجَدٌّ ، أَعْطَی الأُخْتَ مِنَ الأَبِ وَالأُمِّ النِّصْفَ ، وَقَاسَمَ بِالأَخِ وَالأُخْتِ الْجَدَّ\n\nقَالَ أَبُو بَکْرٍ : فَہَذِہِ فِی قَوْلِ عَلِیٍّ وَعَبْدِ اللہِ مِنْ سَہْمَیْنِ ، وَفِی قَوْلِ زَیْدٍ مِنْ ثَلاَثَۃِ أَسْہُمٍ۔",,,31885
31886,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ ، عَنْ مُحَمَّدِ بْنِ سِیرِینَ ، قَالَ : أَرَادَ عُبَیْدُ اللہِ بْنُ زِیَادٍ أَنْ یُوَرِّثَ الأُخْتَ مِنَ الأُمِّ مَعَ الْجَدِّ ، وَقَالَ : إنَّ عُمَرَ قَدْ وَرَّثَ الأُخْتَ مَعَہُ ، فَقَالَ عَبْدُ اللہِ بْنُ عُتْبَۃَ : إنِّی لَسْتُ بِسَبَئِیٍّ وَلاَ حَرُورِی ، فَاقْتَفِرِ الأَثَرَ ، فَإِنَّک لَنْ تُخْطِئَ فِی الطَّرِیقِ مَا دُمْت عَلَی الأَثَرِ۔",,,31886
31887,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إسْمَاعِیلُ ، عَنِ الشَّعْبِیِّ ، قَالَ : مَا وَرَّثَ أَحَدٌ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إخْوَۃً مِنْ أُمٍّ مَعَ جَدٍّ۔",,,31887
31888,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ زَیْدٌ لاَ یُوَرِّثُ أَخًا لأُمٍّ ، وَلاَ أُخْتًا لأُمٍّ مَعَ جَدٍّ شَیْئًا۔",,,31888
31889,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ عَلِیٌّ وَعَبْدُ اللہِ لاَ یُوَرِّثَانِ الإِخْوَۃَ مِنَ الأُمِّ مَعَ الْجَدِّ شَیْئًا۔\n\nقَالَ أَبُو بَکْرٍ : فَہَذِہِ مِنْ سَہْمٍ وَاحِدٍ لأَنَّ الْمَالَ کُلَّہُ لِلْجَدِّ۔",,,31889
31890,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ عَبْدُ اللہِ یَجْعَلُ الأَکْدَرِیَّۃَ مِنْ ثَمَانِیَۃٍ : لِلزَّوْجِ ثَلاَثَۃٌ ، وَثَلاَثَۃٌ لِلأُخْتِ ، وَسَہْمٌ لِلأُمِ ، وَسَہْمٌ لِلْجَدِّ۔ قَالَ : وَکَانَ عَلِیٌّ یَجْعَلُہَا مِنْ تِسْعَۃٍ : ثَلاَثَۃٌ لِلزَّوْجِ ، وَثَلاَثَۃٌ لِلأُخْتِ ، وَسَہْمَانِ لِلأُمِّ ، وَسَہْمٌ لِلْجَدِّ۔ وَکَانَ زَیْدٌ یَجْعَلُہَا مِنْ تِسْعَۃٍ : ثَلاَثَۃٌ لِلزَّوْجِ ، وَثَلاَثَۃٌ لِلأُخْتِ ، وَسَہْمَانِ لِلأُمِّ ، وَسَہْمٌ لِلْجَدِّ ، ثُمَّ یَضْرِبُہَا فِی ثَلاَثَۃٍ فَتَصِیرُ سَبْعَۃً وَعِشْرِینَ ، فَیُعْطِی الزَّوْجَ تِسْعَۃً ، وَالأُمَّ سِتَّۃً ، وَیَبْقَی اثْنَا عَشَرَ ، فَیُعْطِی الْجَدَّ ثَمَانِیَۃً ، وَیُعْطِی الأُخْتَ أَرْبَعَۃً۔",,,31890
31891,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ بَسَّامٍ ، عَنْ فُضَیْلٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَلِیٍّ وَعَبْدِ اللہِ وَزَیْدٍ بِمِثْلِ حَدِیثِ أَبِی مُعَاوِیَۃَ ، وَزَادَ فِیہِ : وَبَلَغَنِی عَنِ ابْنِ عَبَّاسٍ أَنَّہُ کَانَ یَجْعَلُ الْجَدَّ وَالِدًا ، لاَ یَرِثُ الإِخْوَۃَ مَعَہُ شَیْئًا ، وَیَجْعَلُ لِلزَّوْجِ النِّصْفَ وَلِلْجَدِّ السُّدُسَ : سَہْمٌ ، وَلِلأُمِّ الثُّلُثُ : سَہْمَانِ۔",,,31891
31892,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلِیٍّ وَعَبْدِ اللہِ وَزَیْدٍ ، مِثْلَ حَدِیثِ أَبِی مُعَاوِیَۃَ۔",,,31892
31893,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، قَالَ : قُلْتُ لِلأَعْمَشِ : لِمَ سُمِّیَت الأَکْدَرِیَّۃَ ؟ قَالَ : طَرَحَہَا عَبْدُ الْمَلِکِ بْنُ مَرْوَانَ عَلَی رَجُلٍ یُقَالَ لَہُ : الأَکْدَرُ ، کَانَ یَنْظُرُ فِی الْفَرَائِضِ ، فَأَخْطَأَ فِیہَا ، فَسَمَّاہَا الأَکْدَرِیَّۃَ۔\n\nقَالَ وَکِیعٌ : وَکُنَّا نَسْمَعُ قَبْلَ أَنْ یُفَسِّرَ سُفْیَانُ إنَّمَا سُمِّیَتِ الأَکْدَرِیَّۃَ ، لأَنَّ قَوْلَ زَیْدٍ تَکَدَّرَ فِیہَا ، لَمْ یُفَسِّر قَوْلَہُ۔",,,31893
31894,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَبْدِ الْوَاحِدِ ، عَنْ إسْمَاعِیلَ بْنِ رَجَائٍ ، عَنْ إبْرَاہِیمَ۔ وَعَنْ سُفْیَانَ ، عَمَّنْ سَمِعَ الشَّعْبِیَّ قَالَ فِی أُمٍّ ، وَأُخْتٍ لأَبٍ وَأَمٍّ ، وَجَدٍّ : إنَّ زَیْدَ بْنَ ثَابِتٍ قَالَ : مِنْ تِسْعَۃِ أَسْہُمٍ : لِلأُمِّ ثَلاَثَۃٌ ، وَلِلْجَدِّ أَرْبَعَۃٌ ، وَلِلأُخْتِ سَہْمَانِ۔ وَإِنَّ عَلِیًّا قَالَ : لِلأُخْتِ النِّصْفُ : ثَلاَثَۃٌ ، وَلِلأُمِّ الثُّلُثُ : سَہْمَانِ ، وَمَا بَقِیَ فَلِلْجَدِّ وَہُوَ سَہْمٌ۔ وَقَالَ ابْنُ مَسْعُودٍ : لِلأُخْتِ النِّصْفُ : ثَلاَثَۃٌ ، وَلِلأُمِّ السُّدُسُ : سَہْمٌ ، وَمَا بَقِیَ فَلِلْجَدِّ وَہُوَ سَہْمَانِ۔ وَقَالَ عُثْمَان : أَثْلاَثًا : ثُلُثٌ لِلأُمِ ، وَثُلُثٌ لِلأُخْتِ ، وَثُلُثٌ لِلْجَدِّ ، وَقَالَ ابْنُ عَبَّاسٍ : لِلأُمِّ الثُّلُثُ ، وَمَا بَقِیَ فَلِلْجَدِّ۔\n\nقَالَ وَکِیعٌ : وَقَالَ الشَّعْبِیُّ : سَأَلَنِی الْحَجَّاجُ بْنُ یُوسُفَ عنہا ؟ فَأَخْبَرْتہ بِأَقَاوِیلِہِمْ فَأَعْجَبَہُ قَوْلُ عَلِیٍّ ، فَقَالَ: قَوْلُ مَنْ ہَذَا ؟ فَقُلْتُ : قَوْلُ أَبِی تُرَابٍ ، فَفَطِنَ الْحَجَّاجُ ، فَقَالَ : إنَّا لَمْ نَعِبْ عَلَی عَلِیٍّ قَضَائِہِ ، إنَّمَا عِبْنَا کَذَا وَکَذَا۔",,,31894
31895,"حَدَّثَنَا ابْنِ فُضَیْلٌ ، عَنْ بَسَّامٍ ، عَنْ فُضَیْلٍ ، عَنْ إبْرَاہِیمَ : فِی امْرَأَۃٍ تَرَکَتْ أُخْتَہَا لأَبِیہَا وَأُمِّہَا ، وَجَدَّہَا ، وَأُمَّہَا ، فَلأُخْتِہَا لأَبِیہَا وَأُمِّہَا النِّصْفُ ، وَلأُمِّہَا الثُّلُثُ ، وَلِلْجَدِّ السُّدُسُ فِی قَوْلِ عَلِی۔\n\nوَکَانَ عَبْدُ اللہِ یَقُولُ : لِلأُمِّ السُّدُسُ ، وَلِلْجَدِّ الثُّلُثُ ، وَلِلأُخْتِ النِّصْفُ ، وَکَانَ عَبْدُ اللہِ یَقُولُ : لَمْ یَکُنِ اللَّہُ لِیَرَانِی أُفَضِّلُ أُمًّا عَلَی جَدٍّ فِی ہَذِہِ الْفَرِیضَۃِ وَلاَ فِی غَیْرِہَا مِنَ الْحُدُودِ۔\n\nوَکَانَ زَیْدٌ یُعْطِی الأُمَّ الثُّلُثَ ، وَالأُخْتَ ثُلُثَ مَا بَقِیَ ، قَسَمَہَا زَیْدٌ عَلَی تِسْعَۃِ أَسْہُمٍ : لِلأُمِّ الثُّلُثُ ثَلاَثَۃُ أَسْہُمٍ ، وَلِلأُخْتِ ثُلُثُ مَا بَقِیَ سَہْمَانِ ، وَلِلْجَدِّ أَرْبَعَۃُ أَسْہُمٍ۔\n\nوَکَانَ عُثْمَان یَجْعَلُہَا بَیْنَہُمْ أَثْلاَثًا : لِلأُمِّ الثُّلُثُ ، وَلِلأُخْتِ الثُّلُثُ ، وَلِلْجَدِّ الثُّلُثُ۔\n\nوَکَانَ ابْنُ عَبَّاسٍ یَقُولُ : الْجَدُّ بِمَنْزِلَۃِ الأَبِ۔",,,31895
31896,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ أَبِیہِ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، قَالَ : کَانَ عَبْدُ اللہِ یَقُولُ فِی أُخْتٍ وَأَمٍّ وَجَدٍّ : لِلأُخْتِ النِّصْفُ ، وَالنِّصْفُ الْبَاقِی بَیْنَ الْجَدِّ وَالأُمِّ۔",,,31896
31897,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَن عُمَرَ : فِی أُخْتٍ وَأَمٍّ وَجَدٍّ ، قَالَ : لِلأُخْتِ النِّصْفُ ، وَلِلأُمِّ السُّدُسُ ، وَمَا بَقِیَ فَلِلْجَدِّ۔\n\nقَالَ أَبُو بَکْرٍ : فَہَذِہِ فِی قَوْلِ عَلِیٍّ وَعَبْدِ اللہِ مِنْ سِتَّۃِ أَسْہُمٍ ، وَفِی قَوْلِ زَیْدِ بْنِ ثَابِتٍ مِنْ تِسْعَۃِ أَسْہُمٍ۔",,,31897
31898,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَبْدِ اللہِ : أَنَّہُ قَالَ فِی ابْنَۃٍ وَأُخْتٍ وَجَدٍّ : أَعْطَی الاِبْنَۃَ النِّصْفَ ، وَجَعَلَ مَا بَقِیَ بَیْنَ الْجَدِّ وَالأُخْتِ ، لَہُ نِصْفٌ ، وَلَہَا نِصْفٌ۔\n\nوَسُئِلَ عَنِ ابْنَۃٍ ، وَأُخْتَیْنِ ، وَجَدٍّ ، فَأَعْطَی الْبِنْتَ النِّصْفَ ، وَجَعَلَ مَا بَقِیَ بَیْنَ الْجَدِّ وَالأُخْتَیْنِ ، لَہُ نِصْفٌ وَلَہُمَا نِصْفٌ۔\n\nوَسُئِلَ عَنِ ابْنَۃٍ وَثَلاَثَۃِ أَخَوَاتٍ وَجَدٍّ ، فَأَعْطَی الْبِنْتَ النِّصْفَ ، وَجَعَلَ لِلْجَدِّ خُمُسَیْ مَا بَقِیَ وَأَعْطَی الأَخَوَاتِ خُمُسًا خُمُسًا۔",,,31898
31899,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَبِیدَۃَ : فِی ابْنَۃٍ وَأُخْتٍ وَجَدٍّ ، قَالَ : ہِیَ مِنْ أَرْبَعَۃٍ : سَہْمَانِ لِلْبِنْتِ ، وَسَہْمٌ لِلْجَدِّ ، وَسَہْمٌ لِلأُخْتِ ، قُلْتُ لَہُ : فَإِنْ کَانَتَا أُخْتَیْنِ ؟ قَالَ : جَعَلَہَا عَبِیدَۃُ مِنْ أَرْبَعَۃٍ : لِلْبِنْتِ سَہْمَانِ ، وَسَہْمٌ لِلْجَدِّ ، وَلِلأُخْتَیْنِ سَہْمٌ ، قُلْتُ لَہُ : فَإِنْ کُنَّ ثَلاَث أَخَوَاتٍ ؟ قَالَ : جَعَلَہَا مَسْرُوقٌ مِنْ عَشَرَۃٍ : لِلْبِنْتِ خَمْسَۃُ أَسْہُمٍ ، وَلِلْجَدِّ سَہْمَانِ ، وَلِکُلِّ وَاحِدَۃٍ مِنْہُنَّ سَہْمٌ سَہْمٌ۔",,,31899
31900,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن مَسْرُوقٍ : فِی بِنْتٍ وَثَلاَثِ أَخَوَاتٍ وَجَدٍّ ، قَالَ : مِنْ عَشَرَۃٍ : لِلْبِنْتِ النِّصْفُ خَمْسَۃُ أَسْہُمٍ ، وَلِلْجَدِّ سَہْمَانِ ، وَلِکُلِّ أُخْتٍ سَہْمٌ۔",,,31900
31901,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَبِیدَۃَ : فِی ابْنَۃٍ وَأُخْتٍ وَجَدٍّ ، قَالَ: مِنْ أَرْبَعَۃٍ سہْمَانِ : لِلإِبْنِۃِ النِّصْفُ ، وَسَہْمٌ لِلْجَدِّ ، وَسَہْمٌ لِلأُخْتِ۔",,,31901
31902,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَن مَسْرُوقٍ : فِی ابْنَۃٍ وَأُخْتَیْنِ وَجَدٍّ ، قَالَ : مِنْ ثَمَانِیَۃِ أَسْہُمٍ : لِلْبِنْتِ النِّصْفُ أَرْبَعَۃٌ ، وَلِلْجَدِّ سَہْمَانِ ، وَلِکُلِّ أُخْتٍ سَہْمٌ۔",,,31902
31903,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ بَسَّامٍ ، عَنْ فُضَیْلٍ ، عَنْ إبْرَاہِیمَ : فِی رَجُلٍ تَرَکَ ابْنَتَہُ وَأُخْتَہ لأَبِیہِ وَأُمِّہِ وَجَدًّا ، فَلاِبْنَتِہِ النِّصْفُ ، وَلِجَدِّہِ السُّدُسُ ، وَمَا بَقِیَ فَلأُخْتِہِ فِی قَوْلِ عَلِی ، لَمْ یَکُنْ یَزِیدُ الْجَدَّ مَعَ الْوَلَدِ عَلَی السُّدُسِ شَیْئًا ، وَفِی قَوْلِ عَبْدِ اللہِ لاِبْنَتِہِ النِّصْفُ ، وَمَا بَقِیَ فَبَیْنَ الأُخْتِ وَالْجَدِّ۔\n\nفَإِنْ کَانَتَا أُخْتَانِ فَمَا بَقِیَ بَیْنَ الْجَدِّ وَالأُخْتَیْنِ فِی قَوْلِ عَبْدِ اللہِ وَزَیْدٍ ، وَفِی قَوْلِ عَلِیٍّ : لِلْجَدِّ السُّدُسُ ، وَللأُخْتَیْہِ مَا بَقِی ، وَإِنْ کُنَّ ثَلاَثَ أَخَوَاتٍ مَعَ الاِبْنَۃِ وَالْجَدِّ ، فَلِلاِبْنَۃِ النِّصْفُ وَلِلْجَدِّ خُمُسَا مَا بَقِی ، وَلِلأَخَوَاتِ ثَلاَثَۃُ أَخْمَاسٍ فِی قَوْلِ عَبْدِ اللہِ وَزَیْدٍ۔\n\nقَالَ أَبُو بَکْرٍ : فَہَذِہِ فِی قَوْلِ عَلِیٍّ مِنْ سِتَّۃِ أَسْہُمٍ ، وَفِی قَوْلِ عَبْدِ اللہِ وَزَیْدٍ مِنْ عَشَرَۃِ أَسْہُمٍ : خَمْسَۃٌ لِلْبِنْتِ وَسَہْمَانِ لِلْجَدِّ وَلِلأَخَوَاتِ سَہْمٌ ، سَہْمٌ۔",,,31903
31904,"حَدَّثَنَا وَکِیعٌ ، عَنْ فِطْرٍ ، قَالَ : قُلْتُ لِلشَّعْبِیِّ : کَیْفَ قَوْلُ عَلِیٍّ فِی ابْنَۃٍ وَأُخْتٍ وَجَدٍّ ؟ قَالَ : مِنْ أَرْبَعَۃٍ ، قَالَ : قُلْتُ : إنَّمَا ہَذِہِ فِی قَوْلِ عَبْدِ اللہِ۔",,,31904
31905,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ بَسَّامٍ ، عَنْ فُضَیْلٍ ، قَالَ : قَالَ إبْرَاہِیمُ فِی امْرَأَۃٍ تَرَکَتْ زَوْجَہَا وَأُمَّہَا وَأَخَاہَا لأَبِیہَا وَجَدِّہَا : لِلزَّوْجِ النِّصْفُ ثَلاَثَۃُ أَسْہُمٍ ، وَلِلأُمِّ الثُّلُثُ سَہْمَانِ ، وَلِلْجَدِّ سَہْمٌ فِی قَوْلِ عَلِیٍّ وَزَیْدٍ ، وَفِی قَوْلِ عَبْدِ اللہِ : لِلزَّوْجِ النِّصْفُ ، وَلِلأُمِّ ثُلُثُ مَا بَقِیَ سَہْمٌ ، وَلِلْجَدِّ سَہْمٌ ، وَلِلأَخِ سَہْمٌ ، وَإِنْ کَانَا أَخَوَانِ أَوْ أَکْثَرَ مِنْ ذَلِکَ : فَلِلزَّوْجِ النِّصْفُ وَلِلأُمِّ سَہْمٌ ، وَلِلْجَدِّ سَہْمٌ ، وَبَقِیَ سَہْمٌ فَہُوَ لاِِخْوَتِہِ فِی قَوْلِ عَلِیٍّ وَزَیْدٍ وَعَبْدِ اللہِ۔",,,31905
31906,"حَدَّثَنَا وَکِیعٌ ، قَالَ: حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ: أَتَیْنَا شُرَیْحًا فَسَأَلْنَاہُ عَنْ زَوْجٍ ، وَأَمٍّ ، وَأَخٍ، وَجَدٍّ ؟ فَقَالَ : لِلْبَعْلِ الشَّطْرُ ، وَلِلأُمِّ الثُّلُثُ ، ثُمَّ سَکَتَ ، ثُمَّ قَالَ الَّذِی عَلَی رَأْسِہِ : أَنَّہُ لاَ یَقُولُ فِی الْجَدِّ شَیْئًا ، قَالَ : فَأَتَیْنَا عَبِیدَۃَ فَقَسَمَہَا مِنْ سِتَّۃٍ فِی قَوْلِ عَبْدِ اللہِ ، فَأَعْطَی الزَّوْجَ ثَلاَثَۃً ، وَالأُمَّ سَہْمًا ، وَالْجَدَّ سَہْمًا ، وَالأَخَ سَہْمًا۔\n\nفَہَذِہِ فِی قَوْلِہِمْ جَمِیعًا مِنْ سِتَّۃِ أَسْہُمٍ۔",,,31906
31907,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ بَسَّامٍ ، عَنْ فُضَیْلٍ ، عَنْ إبْرَاہِیمَ : فِی امْرَأَۃٍ تَرَکَتْ أُخْتَہَا لأَبِیہَا وَأُمِّہَا وَجَدَّہَا ، فَلأُخْتِہَا لأَبِیہَا وَأُمِّہَا النِّصْفُ فِی قَوْلِ عَلِیٍّ وَعَبْدِ اللہِ ، وَکَانَ زَیْدٌ یُعْطِی الأُخْتَ الثُّلُثَ وَالْجَدَّ الثُّلُثَیْنِ۔\n\nقَالَ أَبُو بَکْرٍ : فَہَذِہِ فِی قَوْلِ عَلِیٍّ وَعَبْدِ اللہِ مِنْ سَہْمَیْنِ ، وَفِی قَوْلِ زَیْدٍ : مِنْ ثَلاَثَۃِ أَسْہُمٍ۔",,,31907
31908,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ بَسَّامٍ ، عَنْ فُضَیْلٍ ، قَالَ : قَالَ إبْرَاہِیمُ : فِی رَجُلٍ تَرَکَ جَدَّہُ ، وَأُخْتَہ لأَبِیہِ وَأُمِّہِ، وَأَخَاہُ لأَبِیہِ ، فَلِلْجَدِّ فِی قَضَائِ زَیْدٍ الْخُمُسَانِ مِنْ عَشَرَۃٍ ، أَرْبَعَۃُ أَسْہُمٍ ، وَلأُخْتِہِ مِنْ أَبِیہِ وَأُمِّہِ النِّصْفُ ، خَمْسَۃٌ ، وَلأَخِیہِ لأَبِیہِ سَہْمٌ ، یَرُدُّ الأَخُ مِنَ الأَبِ فِی قَضَائِ زَیْدٍ عَلَی الأُخْت مِنَ الأَبِ وَالأُمِّ کَانَ لَہَا ثَلاَثَۃُ أَخْمَاسِ الْمَالِ فَأُعْطِیَتَ النِّصْفُ مِنْ أَجْلِ أَنَّ ثَلاَثَۃَ أَخْمَاسٍ أَکْثَرُ مِنَ النِّصْفِ ، وَلَیْسَ لِلأُخْتِ الْوَاحِدۃ وَإِنْ قَاسَمَہَا أَکْثَرَ مِنَ النِّصْفِ۔\n\nوَکَانَ ابْنُ مَسْعُودٍ یُعْطِی الأُخْتَ مِنَ الأَبِ وَالأُمِّ النِّصْفَ ، وَالْجَدَّ النِّصْفَ ، وَلاَ یَعْتَدُّ بِالأُخْوَۃِ مِنَ الأَبِ مَعَ الأخْوَۃِ مِنَ الأَبِ وَالأُمِ۔\n\nوَکَانَ عَلِیٌّ یَجْعَلُ لِلأُخْتِ مِنَ الأَبِ وَالأُمِّ النِّصْفَ ، وَیَقْسِمُ النِّصْفَ الْبَاقِی بَیْنَ الأُخْوَۃِ وَالْجَدِّ ، الْجَدُّ کَأَحَدِہِمْ مَا لَمْ یَکُنْ نَصِیبُ الْجَدِّ أَقَلَّ مِنَ السُّدُسِ ، إِنْ کَانَ أَخٌ وَاحِدٌ فَالنِّصْفُ الَّذِی بَقِیَ بَیْنَہُمَا ، وَإِنْ کَانَا أَخَوَیْنِ فَالنِّصْفُ بَیْنَہُمَا ، وَإِنْ کَانُوا ثَلاَثَۃٌ ، فَلِلْجَدِّ السُّدُسِ ، وَمَا بَقِیَ فَلِلأُخْوَۃِ۔\n\nقَالَ أَبُو بَکْرٍ : فَہَذِہِ فِی قَوْلِ زَیْدٍ مِنْ عَشَرَۃِ أَسْہُمٍ ، وَفِی قَوْلِ عَبْدِ اللہِ : مِنْ سَہْمَیْنِ ، وَکَانَ عَلِیٌّ یَجْعَلُہَا مِنْ سِتَّۃٍ إذَا کَثُرَ الأُخْوَۃُ۔",,,31908
31909,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ بَسَّامٍ ، عَنْ فُضَیْلٍ ، قَالَ : قَالَ إبْرَاہِیمُ : فِی امْرَأَۃٍ تَرَکَتْ أُمَّہَا ، وَأُخْتَہَا لأَبِیہَا وَأُمِّہَا ، وَأَخَاہَا لأَبِیہَا ، وَجَدَّہَا ، قَضَی فِیہَا زَیْدٌ : أَنَّ لِلأُمِّ السُّدُسَ ، وَلِلْجَدِّ خُمُسَا مَا بَقِی ، وَلِلأُخْتِ ثَلاَثَۃُ أَخْمَاسِ مَا بَقِی ، رَدَّ الأَخُ عَلَی أُخْتِہِ وَلَمْ یَرِثْ شَیْئًا ، وَقَضَی فِیہَا عَبْدُ اللہِ : أَنَّ لِلأُخْتِ ثَلاَثَۃُ أَسْہُمٍ ، وَلِلأُمِّ سَہْمٌ ، وَلِلْجَدِّ سَہْمٌ ، وَقَضَی فِیہَا عَلِیٌّ : أَنَّ لِلأُخْتِ مِنَ الأَبِ وَالأُمِّ ثَلاَثَۃُ أَسْہُمٍ ، وَلِلأُمِّ سَہْماً ، وَبَقِیَ سَہْمَانِ : لِلْجَدِّ سَہْمٌ ، وَلِلأَخِ سَہْمٌ۔\n\nفَہَذِہِ فِی قَوْلِ عَلِیٍّ وَزَیْدٍ مِنْ سِتَّۃِ أَسْہُمٍ ، وَفِی قَوْلِ عَبْدِ اللہِ مِنْ خَمْسَۃٍ۔",,,31909
31910,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ بَسَّامٍ ، عَنْ فُضَیْلٍ ، عَنْ إبْرَاہِیمَ ، قَالَ فِی امْرَأَۃٍ تَرَکَتْ زَوْجَہَا ، وَأُمَّہَا ، وَأَرْبَعَ أَخَوَاتٍ لَہَا مِنْ أَبِیہَا وَأُمَّہَا ، وَجَدَّہَا ، قضَی فِیہَا زَیْدٌ : أَنَّ لِلزَّوْجِ ثَلاَثَۃُ أَسْہُمٍ ، وَلِلأُمِّ سَہْماً ، وَلِلْجَدِّ سَہْمَاً، وَلِلأَخَوَاتِ سَہْمَاً ، وَقَضَی فِیہَا عَلِیٌّ وَعَبْدُ اللہِ عَلَی تِسْعَۃِ أَسْہُمٍ : لِلزَّوْجِ ثَلاَثَۃُ أَسْہُمٍ ، وَلِلأُمِّ سَہْمٌ، وَلِلْجَدِّ سَہْمٌ ، وَلِلأَخَوَاتِ أَرْبَعَۃُ أَسْہُمٍ۔\n\nقَالَ أَبُو بَکْرٍ : فَہَذِہِ فِی قَوْلِ زَیْدٍ مِنْ سِتَّۃِ أَسْہُمٍ ، وَفِی قَوْلِ عَلِیٍّ وَعَبْدِ اللہِ مِنْ تِسْعَۃِ أَسْہُمٍ۔",,,31910
31911,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا مُحَمَّدُ بْنُ سَالِمٍ ، عَنِ الشَّعْبِیِّ : فِی أُخْتٍ لأَمٍّ وأَبٍ ْ وَأَخٍ وَأُخْتٍ لأَبٍ ، وَجَدٍّ ، فِی قَوْلِ عَلِیٍّ : لِلأُخْتِ مِنَ الأَبِ وَالأُمِّ النِّصْفُ ، وَمَا بَقِیَ فَبَیْنَ الْجَدِّ وَالأُخْتِ وَالأَخِ مِنَ الأَبِ عَلَی الأَخْمَاسِ : لِلْجَدِّ خُمُسَانِ ، وَلِلأُخْتِ خُمُسٌ۔ وَفِی قَوْلِ عَبْدِ اللہِ : لِلأُخْتِ مِنَ الأَبِ وَالأُمِّ النِّصْفُ ، وَلِلْجَدِّ مَا بَقِی ، وَلَیْسَ لِلأَخِ وَالأُخْتِ مِنَ الأَبِ شَیْئٌ۔ وَفِی قَوْلِ زَیْدٍ : مِنْ ثَمَانیَۃَ عَشَرَ سَہْمًا : لِلْجَدِّ الثُّلُثُ سِتَّۃٌ ، وَلِلأَخِ مِنَ الأَبِ سِتَّۃٌ ، وَلِلأُخْتِ مِنَ الأَبِ ثَلاَثَۃٌ\n\nوَلِلأُخْتِ مِنَ الأَبِ وَالأُمِّ ثَلاَثَۃٌ ، ثُمَّ تَرُدُّ الأُخْتُ وَالأَخُ مِنَ الأَبِ عَلَی الأُخْتِ مِنَ الأَبِ وَالأُمِّ سِتَّۃَ أَسْہُمٍ ، فَاسْتَکْمَلَتِ النِّصْفَ تِسْعَۃً ، وَبَقِیَ لَہُمَا ثَلاَثَۃُ أَسْہُمٍ : لِلأَخِ سَہْمَانِ وَلِلأُخْتِ سَہْمٌ۔\n\nوَفِی أُخْتَینِ لأَبٍ وَأُم ، وَأَخٍ لأَبٍ ، وَجَدٍّ فِی قَوْلِ عَلِیٍّ : لِلأُخْتَیْنِ مِنَ الأَبِ وَالأُمِّ الثُّلُثَانِ ، وَمَا بَقِیَ فَبَیْنَ الْجَدِّ وَالأَخِ ، وَفِی قَوْلِ عَبْدِ اللہِ : لِلأُخْتَیْنِ مِنَ الأَبِ وَالأُمِّ الثُّلُثَانِ ، وَلِلْجَدِّ مَا بَقِی ، وَلَیْسَ لِلأَخِ مِنَ الأَبِ شَیْئٌ۔ وَفِی قَوْلِ زَیْدٍ : ہِیَ ثَلاَثَۃُ أَسْہُمٍ : لِلْجَدِّ سَہْمٌ ، وَلِلأَخِ سَہْمٌ وَلِلأُخْتَیْنِ سَہْمٌ ، ثُمَّ یَرُدُّ الأَخُ مِنَ الأَبِ عَلَی الأُخْتَیْنِ مِنَ الأَبِ وَالأُمِّ سَہْمَہُما ، فَتَسْتَکْمِلاَنِ الثُّلُثَیْنِ ، وَلَمْ یَبْقَ لَہُ شَیْئٌ۔\n\nوَفِی أُخْتَیْنِ لأَبٍ وَأَمٍّ ، وَأُخْتٍ لأَبٍ ، وَجَدٍّ ، فِی\n\nقَوْلِ عَلِیٍّ ، وَعَبْدِ اللہِ : لِلأُخْتَیْنِ لِلأَبِ وَالأُمِّ الثُّلُثَانِ ، وَمَا بَقِیَ لِلْجَدِّ ، وَلَیْسَ لِلأُخْتِ مِنَ الأَبِ شَیْئٌ وَفِی قَوْلِ زَیْدٍ : مِنْ خَمْسَۃِ أَسْہُمٍ : لِلْجَدِّ سَہْمَانِ ، وَلِلأُخْتَیْنِ مِنَ الأَبِ وَالأُمِّ سَہْمَانِ ، وَلِلأُخْتِ مِنَ الأَبِ سَہْمٌ ، ثُمَّ تَرُدُّ الأُخْتُ مِنَ الأَبِ عَلَی الأُخْتَیْنِ مِنَ الأَبِ وَالأُمِّ سَہْمَہُمَا ، وَلَمْ یَبْقَ لَہَا شَیْئٌ۔\n\nوَفِی أُخْتَیْنِ لأَبٍ وَأَمٍّ ، وَأَخٍ وَأُخْتٍ لأَبٍ ، وَجَدٍّ فِی قَوْلِ عَلِیٍّ : لِلأُخْتَیْنِ مِنَ الأَبِ وَالأُمِّ الثُّلُثَانِ ، وَلِلْجَدِّ السُّدُسُ ، وَمَا بَقِیَ فَبَیْنَ الأُخْتِ وَالأَخِ مِنَ الأَبِ لِلذَّکَرِ مِثْلُ حَظِّ الأُنْثَیَیْنِ ، وَفِی قَوْلِ عَبْدِ اللہِ : لِلأُخْتَیْنِ مِنَ الأَبِ وَالأُمِّ الثُّلُثَانِ ، وَلِلْجَدِّ مَا بَقِی ، وَلَیْسَ لِلأَخِ وَالأُخْتِ مِنَ الأَبِ شَیْئٌ وَفِی قَوْلِ زَیْدٍ : مِنْ خَمْسَۃَ عَشَرَ سَہْمًا : لِلْجَدِّ الثُّلُثُ خَمْسَۃُ أَسْہُمٍ ، وَلِلأَخِ مِنَ الأَبِ أَرْبَعَۃٌ ، وَلِلأُخْتِ مِنَ الأَبِ سَہْمَانِ وَلِلأُخْتَیْنِ مِنَ الأَبِ وَالأُمِّ أَرْبَعَۃُ أَسْہُمٍ ، ثُمَّ یَرُدُّ الأَخُ وَالأُخْتُ مِنَ الأَبِ عَلَی الأُخْتَیْنِ مِنَ الأَبِ وَالأُمِّ نَصِیبَہُمَا ، یَسْتَکْمِلاَنِ الثُّلُثَین وَلَمْ یَبْقَ لَہُمَا شَیْئٌ۔\n\nوَفِی أُخْتَیْنِ لأَبٍ وَأَمٍّ ، وَأُخْتَیْنِ لأَبٍ ، وَجَدٍّ فِی قَوْلِ عَلِیٍّ وَعَبْدِ اللہِ : لِلأُخْتَیْنِ مِنَ الأَبِ وَالأُمِّ الثُّلُثَانِ ، وَلِلْجَدِّ مَا بَقِی ، وَلَیْسَ لِلأُخْتَیْنِ مِنَ الأَبِ شَیْئٌ۔ وَفِی قَوْلِ زَیْدٍ : مِنْ سِتَّۃِ أَسْہُمٍ : لِلْجَدِّ سَہْمَانِ ، وَلِلأُخْتَیْنِ مِنَ الأَبِ وَالأُمِّ سَہْمَانِ ، وَلِلأُخْتَیْنِ مِنَ الأَبِ سَہْمَانِ ، ثُمَّ تَرُدُّ الأُخْتَانِ مِنَ الأَبِ عَلَی الأُخْتَیْنِ مِنَ الأَبِ وَالأُمِّ سَہْمَیْہِمَا ، فَیَسْتَکْمِلاَنِ الثُّلُثَیْنِ ، وَلَمْ یَبْقَ لَہُمَا شَیْئٌ۔\n\nوَفِی أُخْتٍ لأَبٍ وَأَمٍّ ، وَثَلاَثِ أَخَوَاتٍ لأَبٍ ، وَجَدِّہِ : فِی قَوْلِ عَلِیٍّ وَعَبْدِ اللہِ : لِلأُخْتِ مِنَ الأَبِ وَالأُمِّ النِّصْفُ ، وَلِلأَخَوَاتِ مِنْ الأَبِ السُّدُسُ تَکْمِلَۃَ الثُّلُثَیْنِ ، وَلِلْجَدِّ مَا بَقِی ، وَفِی قَوْلِ زَیْدٍ : ثَمَانیَۃَ عَشَرَ سَہْمًا : لِلْجَدِّ الثُّلُثُ سِتَّۃٌ ، وَلِلأُخْتِ مِنَ الأَبِ وَالأُمِّ ثَلاَثَۃُ أَسْہُمٍ ، وَلِلأَخَوَاتِ مِنَ الأَبِ تِسْعَۃُ أَسْہُمٍ ، ثُمَّ تَرُدُّ الأَخَوَاتُ مِنَ الأَبِ عَلَی الأُخْتِ مِنَ الأَبِ وَالأُمِّ سِتَّۃَ أَسْہُمٍ ، فَاسْتَکْمَلَتِ النِّصْفَ تِسْعَۃً ، وَبَقِیَ لَہُنَّ سَہْمٌ سَہْمٌ۔\n\nوَفِی أُخْتَیْنِ لأَبٍ وَأَمٍّ ، وَأَخٍ ، وَأُخْتَیْنِ لأَبٍ ، وَجَدٍّ : فِی قَوْلِ عَلِیٍّ : لِلأُخْتَیْنِ مِنَ الأَبِ وَالأُمِّ الثُّلُثَانِ ، وَلِلْجَدِّ السُّدُسُ ، وَمَا بَقِیَ فَبَیْنَ الأَخِ وَالأُخْتَیْنِ مِنَ الأَبِ لِلذَّکَرِ مِثْلُ حَظِّ الأُنْثَیَیْنِ ، وَفِی قَوْلِ عَبْدِ اللہِ : لِلأُخْتَیْنِ مِنَ الأَبِ وَالأُمِّ الثُّلُثَانِ ، وَلِلْجَدِّ مَا بَقِی ، وَلَیْسَ لِلأَخِ وَالأُخْتَیْنِ مِنَ الأَبِ شَیْئٌ۔\n\nوَفِی أُمٍّ وَأُخْتٍ وَجَدٍّ فِی قَوْلِ عَلِیٍّ : لِلأُخْتِ النِّصْفُ ، وَلِلأُمِّ ثُلُث مَا بَقِی ، وَلِلْجَدِّ مَا بَقِیَ۔\n\nوَفِی قَوْلِ زَیْدٍ : مِنْ تِسْعَۃِ أَسْہُمٍ : لِلأُمِّ الثُّلُثُ ثَلاَثَۃٌ ، وَلِلْجَدِّ أَرْبَعَۃٌ ، وَلِلأُخْتِ سَہْمَانِ ، جَعَلَہُ مَعَہُمَا بِمَنْزِلَۃِ الأَخِ ، وَفِی قَوْلِ عُثْمَانَ: لِلأُمِّ الثُّلُثُ ، وَلِلْجَدِّ الثُّلُثُ ، وَلِلأُخْتِ الثُّلُثُ ، وَفِی قَوْلِ ابْنِ عَبَّاسٍ: لِلأُمِّ الثُّلُثُ، وَلِلْجَدِّ مَا بَقِی ، لَیْسَ لِلأُخْتِ شَیْئٌ ، لَمْ یَکُنْ یُوَرِّثُ أَخًا وَأُخْتًا مَعَ جَدٍّ شَیْئًا۔",,,31911
31912,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ زَیْدٌ یُشَرِّکُ الْجَدَّ إِلَی الثُّلُثِ مَعَ الإِخْوَۃِ وَالأَخَوَاتِ ، فَإِذَا بَلَغَ الثُّلُثَ أَعْطَاہُ الثُّلُثَ ، وَکَانَ لِلأُخْوَۃِ وَالأَخَوَاتِ مَا بَقِی ، وَلاَ للأَخٍ لأُمٍّ ، وَلاَ للأُخْتٍ لأُمٍّ مَعَ جَدٍّ شَیْئٌ ، وَیُقَاسِمُ الأُخْوَۃَ مِنَ الأَبِ الإِخْوَۃَ مِنَ الأَبِ وَالأُمِّ ، وَلاَ یُوَرِّثُہُمْ شَیْئًا ، فَإِذَا کَانَ أَخٌ لأَبٍ وَأَمٍّ وَجَدٍّ ، أَعْطَی الْجَدَّ النِّصْفَ ، وَإِذَا کَانَا أَخَوَیْنِ أَعْطَاہُ الثُّلُثَ ، فَإِنْ زَادُوا أَعْطَاہُ الثُّلُثَ ، وَکَانَ لِلإِخْوَۃِ مَا بَقِی وَإِذَا کَانَتْ أُخْتٌ وَجَدٌّ أَعْطَاہُ مَعَ الأُخْتِ الثُّلُثَیْنِ ، وَلِلأُخْتِ الثُّلُثَ ، وَإِذَا کَانَتَا أُخْتَیْنِ أَعْطَاہُمَا النِّصْفَ ، وَلَہُ النِّصْفَ مَا دَامَتِ الْمُقَاسَمَۃُ خَیْرًا لَہُ ، فَإِنْ لَحِقَتْ فَرَائِضُ امْرَأَۃٍ وَ أُمٍّ وَزَوْجٍ أَعْطَی أَہْلَ الْفَرَائِضِ فَرَائِضَہُمْ ، وَمَا بَقِیَ قَاسَمَ الإِخْوَۃُ وَالأَخَوَاتُ ، فَإِنْ کَانَ ثُلُثُ مَا بَقِیَ خَیْرًا لَہُ مِنَ الْمُقَاسَمَۃِ أَعْطَاہُ ثُلُثَ مَا بَقِی ، وَإِنْ کَانَتِ الْمُقَاسَمَۃُ خَیْرًا لَہُ أَعْطَاہُ الْمُقَاسَمَۃَ ، وَإِنْ کَانَ سُدُسُ جَمِیعِ الْمَالِ خَیْرًا لَہُ مِنَ الْمُقَاسَمَۃِ أَعْطَاہُ السُّدُسَ ، وَإِنْ کَانَتِ الْمُقَاسَمَۃُ خَیْرًا لَہُ مِنْ سُدُسِ جَمِیعِ الْمَالِ أَعْطَاہُ الْمُقَاسَمَۃَ۔",,,31912
31913,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ إِبْرَاہِیمَ ، عَن عُمَرَ وَعَبْدِ اللہِ : أَنَّہُمَا کَانَا لاَ یُفَضِّلاَنِ أُمًّا عَلَی جَدٍّ۔",,,31913
31914,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ عَبْدِ اللہِ بْنِ سَلِمَۃَ ، عَنْ عَبِیدَۃَ ، قَالَ : إنِّی لأُحِیلُ الْجَدَّ عَلَی مِئَتَیْ قَضِیَّۃٍ۔",,,31914
31915,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ أَیُّوب ، عَنِ ابْنِ سِیرِینَ ، عَنْ عَبِیدَۃَ ، قَالَ : حَفِظْت عَن عُمَرَ مِئَۃَ قَضِیَّۃٍ فِی الْجَدِّ مُخْتَلِفَۃٍ۔",,,31915
31916,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عُبَیْدِ بْنِ عَمْرٍو الْخَارِفِیِّ : أَنَّ رَجُلاً سَأَلَ عَلِیًّا عَنْ فَرِیضَۃٍ ؟ فَقَالَ : ہَاتِ إنْ لَمْ یَکُنْ فِیہَا جَدٌّ۔",,,31916
31917,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَیُّوبَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنْ رَجُلٍ مِنْ مُرَادٍ ، قَالَ : سَمِعْتُ عَلِیًّا یَقُولُ : مَنْ أَحَبَّ أَنْ یَتَقَحَّمَ جَرَاثِیمَ جَہَنَّمَ فَلْیَقْضِ بَیْنَ الْجَدِّ وَالإِخْوَۃِ۔",,,31917
31918,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : أَتَیْنَا شُرَیْحًا فَسَأَلْنَاہُ ؟ فَقَالَ الَّذِی عَلَی رَأْسِہِ : إنَّہُ لاَ یَقُولُ فِی الْجَدِّ شَیْئًا۔",,,31918
31919,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إسْمَاعِیلُ ، عَنِ الشَّعْبِیِّ ، قَالَ : خُذْ فِی أَمْرِ الْجَدِّ بِمَا اجْتَمَعَ عَلَیْہِ النَّاسُ۔ یَعْنِی : قَوْلَ زَیْدٍ۔",,,31919
31920,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدٍ : أَنَّ عُمَرَ کَتَبَ فِی أَمْرِ الْجَدِّ وَالْکَلاَلَۃِ فِی کَتِفٍ ، ثُمَّ طَفِقَ یَسْتَخِیرُ رَبَّہُ ، فَلَمَّا طُعِنْ دَعَا بِالْکَتِفِ فَمَحَاہَا ، ثُمَّ قَالَ : إنِّی کُنْت کَتَبْت کِتَابًا فِی الْجَدِّ وَالْکَلاَلَۃِ ، وَإِنِّی قَدْ رَأَیْت أَنْ أَرُدَّکُمْ عَلَی مَا کُنْتُمْ عَلَیْہِ ، فَلَمْ یَدْرُوا مَا کَانَ فِی الْکَتِفِ۔",,,31920
31921,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ سَعِیدٍ ، قَالَ : حدَّثَنِی رَجُلٌ مِنْ مُرَادٍ ، عَنْ عَلِیٍّ ، قَالَ : مَنْ أَحَبَّ أَنْ یَتَقَحَّمَ فِی جَرَاثِیمِ جَہَنَّمَ فَلْیَقْضِ بَیْنَ الإِخْوَۃِ وَالْجَدِّ۔",,,31921
31922,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ قَبِیصَۃَ ، قَالَ : جَائَتِ الْجَدَّۃُ بِالأُمِّ وَابْنِ الاِبْنِ بَعْدَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إلَی أَبِی بَکْرٍ ، فَقَالَتْ : إنَّ ابْنَ ابْنِی وَابْنَ ابْنَتِی مَاتَ ، وَقَدْ أُخْبِرْتُ أَنَّ لِی حَقًّا ، فَقَالَ أَبُو بَکْرٍ : مَا أَجِدُ لَکِ فِی کِتَابِ اللہِ مِنْ حَقٍّ ، وَمَا سَمِعْت فِیکِ شَیْئًا مِنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَسَأَسْأَلُ النَّاسَ ، قَالَ : فَشَہِدَ الْمُغِیرَۃُ بْنُ شُعْبَۃَ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَعْطَاہَا السُّدُسَ ، فَقَالَ : مَنْ یَشْہَدُ مَعَک ؟ قَالَ : مُحَمَّدُ بْنُ مَسْلَمَۃَ ، فَشَہِدَ فَأَعْطَاہَا السُّدُسَ ، وَجَائَتِ الْجَدَّۃُ الَّتِی تُخَالِفُہَا إلَی عُمَرَ ، فَأَعْطَاہَا السُّدُسَ ، فَقَالَ : إذَا اجْتَمَعْتُمَا فَہُوَ بَیْنَکُمَا۔\n\nزَادَ مَعْمَرٌ : وَأَیُّکُمَا انْفَرَدَتْ بِہِ فَہُوَ لَہَا۔ (ترمذی 2100)",,,31922
31923,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، قَالَ : حدَّثَنَا شَرِیکٌ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، عَنِ ابْنِ عَبَّاسٍ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَعْطَی الْجَدَّۃَ السُّدُسَ۔ (ابن ماجہ 2725۔ سعید بن منصور 83)",,,31923
31924,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ أَبِی الْمُنِیبِ عُبَیْدِ اللہِ بْنِ عَبْدِ اللہِ ، قَالَ : حدَّثَنِی ابْنُ بُرَیْدَۃَ ، عَنْ أَبِیہِ : أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَطْعَمَ الْجَدَّۃَ السُّدُسَ إذَا لَمْ یَکُنْ ابنٌ۔ (ابوداؤد 2887۔ دارقطنی 74)",,,31924
31925,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : أَخْبَرَنَا ابْنُ عُمَیْرٍ ، عَنْ أَیُّوبَ ، عَنْ رَجُلٍ ، عَنْ طَاوُوسٍ ، قَالَ : الْجَدَّۃُ بِمَنْزِلَۃِ الأُمِ ، تَرِثُ مَا تَرِثُ الأُمُّ۔",,,31925
31926,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : أَطْعَمَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ثَلاَثَ جَدَّاتٍ ، قَالَ : قُلْتُ لإِبْرَاہِیمَ : مَنْ ؟ قَالَ : جَدَّتَا أَبِیہِ : أُمّ أُمّہِ ، وَأُمّ أَبِیہِ ،وَجَدَّتِہِ أُمّ أُمّہِ۔\n\n(ابوداؤد 355۔ دارمی 2935)",,,31926
31927,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ، قَالَ : یَرِثُ مِنَ الْجَدَّاتِ ثَلاَثَۃٌ ، وَأَقْعَدُ الْجَدَّاتِ فِی النَّسَبِ أَحَقُّہُنَّ بِالسُّدُسِ۔",,,31927
31928,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ دَاوُدَ ، عَنْ عَامِرٍ ، قَالَ : إذَا اجْتَمَعَ أَرْبَعُ جَدَّاتٍ لَمْ تَرِثَ أُمُّ أَبِی الأُمِّ۔",,,31928
31929,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ إبْرَاہِیمَ ، عَنِ ابْنِ مَسْعُودٍ ، قَالَ : یَرِثُ ثَلاَثُ جَدَّاتٍ : جَدَّتَانِ مِنْ قِبَلِ الأُمِّ ، وَجَدَّۃَّ مِنْ قِبَلِ الأَبِ۔",,,31929
31930,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ لَیْثٍ ، عَنْ طَاووسٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : تَرِثُ الْجَدَّاتُ الأَرْبَعُ جَمِیعًا۔",,,31930
31931,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ سَہْمٍ الْفَرَائِِضِیِّ ، قَالَ : کَانَ جَابِرُ بْنُ زَیْدٍ یُوَرِّثُ أَرْبَعَ جَدَّاتٍ۔",,,31931
31932,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ : سُئِلَ عَنْ أَرْبَعِ جَدَّاتٍ ؟ فَقَالَ : یَرِثُ مِنْہُنَّ ثَلاَثٌ ، وَتُلْغی أُمَّ أَبِی الأُمِّ۔",,,31932
31933,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنْ مُحَمَّدٍ : أَنَّہُ کَانَ یُوَرِّثُ تِسْعَ جَدَّاتٍ وَیَقُولُ : إذَا کَانَتْ إحْدَی الْجَدَّاتِ أَقْرَبَ فَہُوَ لَہَا دُونَہُنَّ۔",,,31933
31934,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ : أَنَّہُ کَانَ یُوَرِّثُ ثَلاَثَ جَدَّاتٍ وَیَقُولُ : أَیَّتُہُنَّ کَانَتْ أَقْرَبَ فَہُوَ لَہَا دُونَ الأُخْرَی ، فَإِذَا اسْتَوَتَا فَہُوَ بَیْنَہُمَا۔",,,31934
31935,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ مَنْصُورٍ ، قَالَ : قَالَ إبْرَاہِیمُ : جَعَلَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَیْنَ جَدَّۃٍ مِنْ قِبَلِ أُمِّہِ ، وَجَدَّتَیْنِ مِنْ قِبَلِ أَبِیہِ السُّدُسَ ، قَالَ زَائِدَۃُ : قُلْتُ لِمَنْصُورٍ : الَّتِی مِنْ قِبَلِ أَبِیہِ: أُمُّ أَبِیہِ ، وَأُمّ أُمِّہِ ؟ قَالَ : نَعَمْ۔",,,31935
31936,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ مَنْصُورٍ ، قَالَ : قَالَ إبْرَاہِیمُ : إذَا کَانَتِ الْجَدَّاتُ مِنْ نَحْوٍ وَاحِدٍ ، بَعْضُہُنَّ أَقْرَبُ سَقَطَتِ الْقُصْوَی۔",,,31936
31937,"حَدَّثَنَا ابْنُ فُضَیْلٍ، عَنْ بَسَّامٍ، عَنْ فُضَیْلٍ، قَالَ: قَالَ إبْرَاہِیمُ: تَرِثُ الْجَدَّاتُ السُّدُسَ، فَإِنْ کَانَتْ وَاحِدَۃً أَو اثْنَتَیْنِ أَوْ ثَلاَثًا فَبَیْنَہُنَّ سَہْمٌ فِی قَوْلِ عَلِیٍّ وَزَیْدٍ ، وَإذَا اجْتَمَعْن ثَلاَثُ جَدَّاتٍ ہُنَّ إلَی الْمَیِّتِ شرعٌ سَوَائٌ قَالَ: بَیْنَہُنَّ سَہْمٌ تَکُونُ جَدَّۃُ الأُمِّ ، وَجَدَّۃٌ بَنِی الأَبِ : أُمَّ أَبِیہِ ، وَأَمَّ أُمِّہِ ، وَفِی قَوْلِ عَبْدِ اللہِ : إذَا اجْتَمَعْن ثَلاَثُ جَدَّاتٍ کَانَ بَیْنَہُنَّ السُّدُسُ ، وَإِنْ کَانَ بَعْضُہُنَّ أَقْرَبَ نَسَبًا لَمْ یَکُنْ بَعْضُہُنَّ أُمَّہَاتِ بَعْضٍ۔",,,31937
31938,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، عَنْ مَسْرُوقٍ ، قَالَ : جِئْنَ أَرْبَعُ جَدَّاتٍ یَتَسَاوَقْنَ إلَی مَسْرُوقٍ فَوَرَّثَ ثَلاَثًا ، وَطَرَحَ أُمَّ أَبِی الأُمِّ۔",,,31938
31939,"حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ، عَنْ أَبِی الْمُہَلَّبِ : أَنَّ جَدَّتَیْنِ أَتَتَا شُرَیْحًا ، فَجَعَلَ السُّدُسَ بَیْنَہُمَا۔",,,31939
31940,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : کَانَ عَبْدُ اللہِ یُوَرِّثُ الْجَدَّاتِ وَإِنْ کُنَّ عَشْرًا ، وَیَقُولُ : إنَّمَا ہُوَ سَہْمٌ أَطْعَمَہُ إیَّاہُنَّ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔ (عبدالرزاق 19093)",,,31940
31941,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَشْعَثِ ، عَنِ الشَّعْبِیِّ ، قَالَ : جَائَتْ أَرْبَعُ جَدَّاتٍ یَتَسَاوَقْنَ إلَی مَسْرُوقٍ ، فَوَرَّثَ ثَلاَثًا ، وَطَرَحَ وَاحِدَۃً : أُمَّ أَبِی الأُمِّ۔",,,31941
31942,"حَدَّثَنَا یَعْلَی ، عَنْ یَحْیَی ، عَنِ الْقَاسِمِ ، قَالَ : تُوُفِّیَ رَجُلٌ وَتَرَکَ جَدَّتَیْہِ : أُمَّ أُمِّہِ ، وَأَمَّ أَبِیہِ ، فَوَرَّثَ أَبُو بَکْرٍ أُمَّ أُمِّہِ ، وَتَرَکَ الأُخْرَی ، فَقَالَ رَجُلٌ مِنَ الأَنْصَارِ : لَقَدْ تَرَکْت امْرَأَۃً لَوْ أَنَّ الْجَدَّتَیْنِ مَاتَتَا وَابْنُہُمَا حَیٌّ مَا وَرِثَ مِنَ الَّتِی وَرَّثْتہَا مِنْہُ شَیْئًا ، وَوَرِثَ الَّتِی تَرَکَتَ : أَمَّ أَبِیہِ ! فَوَرَّثَہَا أَبُو بَکْرٍ ، فَشَرَّکَ بَیْنَہُمَا فِی السُّدُسِ۔ (سعید بن منصور 82)",,,31942
31943,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ أَبِی الزِّنَادِ : سَمِعْت خَارِجَۃَ بْنَ زَیْدٍ وَسُلَیْمَانَ بْنَ یَسَارٍ وَطَلْحَۃَ بْنَ عَبْدِ اللہِ بْنِ عَوْفٍ یَقُولُونَ : إذَا کَانَتِ الْجَدَّۃُ الَّتِی مِنْ قِبَلِ الأُمِّ أَقْرَبَ فَہِیَ أَحَقُّ بِہِ۔",,,31943
31944,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا بَشِیرٌ ، عَنْ عَبْدِ اللہِ بْنِ ذَکْوَانَ ، عَنْ خَارِجَۃَ بْنِ زَیْدٍ ، قَالَ : إذَا کَانَتِ الْجَدَّۃُ مِنْ قِبَلِ الأُمِّ أَقْعَدَ مِنَ الْجَدَّۃِ الَّتِی مِنْ قِبَلِ الأَبِ کَانَ السُّدُسُ لَہَا ، وَإِذَا کَانَتِ الْجَدَّۃُ مِنْ قِبَلِ الأَبِ أَقْعَدَ مِنَ الْجَدَّۃِ مِنْ قِبَلِ الأُمِّ کَانَ بَیْنَہُمَا السُّدُسُ۔",,,31944
31945,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا فِطْرٌ ، عَنْ شَیْخٍ مِنْ أَہْلِ الْمَدِینَۃِ ، عَنْ خَارِجَۃَ بْنِ زَیْدٍ ، عَنْ زَیْدِ بْنِ ثَابِتٍ ، قَالَ : إذَا کَانَتِ الْجَدَّۃُ مِنْ قِبَلِ الأُمِّ ہِیَ أَقْعَدَ مِنَ الْجَدَّۃِ مِنْ قِبَلِ الأَبِ کَانَ لَہَا السُّدُسُ ، وَإِذَا کَانَتِ الْجَدَّۃُ مِنْ قِبَلِ الأَبِ أَقْعَدُ مِنَ الْجَدَّۃِ مِنْ قِبَلِ الأُمِّ کَانَ السُّدُسُ بَیْنَہُمَا۔",,,31945
31946,"حَدَّثَنَا حَفْصٌ بْنِ غِیَاثٍ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، عَنْ عَلِیٍّ وَزَیْدٍ ، قَالاَ فِی الْجَدَّاتِ : السَّہْمُ لِذَوِی الْقُرْبَی مِنْہُنَّ۔",,,31946
31947,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ خَالِدٍ ، عَنْ مُحَمَّدٍ ، قَالَ : الْجَدَّتَانِ : أَیُّہُمَا أَقْرَبُ فَلَہَا الْمِیرَاثُ۔",,,31947
31948,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ حُمَیْدٍ ، عَنْ عَمَّارٍ مَوْلَی بَنِی ہَاشِمٍ ، عَنْ زَیْدِ بْنِ ثَابِتٍ : فِی الْجَدَّاتِ إذَا کَانَتِ الْجَدَّۃُ أَقْرَبَ فَہِیَ أَحَقُّ۔",,,31948
31949,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا أَبُو عَوَانَۃَ ، عَنْ سُلَیْمَان الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، قَالَ : قَالَ عَبْدُ اللہِ : لاَ تَحْجُبُ الْجَدَّاتِ إلاَّ الأُمُّ۔",,,31949
31950,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ إبْرَاہِیمَ بْنِ مَیْسَرَۃَ : سَمِعَ سَعِیدُ بْنُ الْمُسَیَّبِ : أَنَّ عُمَرَ وَرَّثَ جَدَّۃَ رَجُلٍ مِنْ ثَقِیفٍ مَعَ ابْنِہَا۔",,,31950
31951,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنْ أَبِی عَمْرٍو الشَّیْبَانِیِّ ، قَالَ : کَانَ عَبْدُ اللہِ یُوَرِّثُ الْجَدَّۃَ مَعَ ابْنِہَا وَابْنُہَا حَیٌّ۔",,,31951
31952,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ سَلَمَۃَ بْنِ عَلْقَمَۃَ ، عَنْ حُمَیْدِ بْنِ ہِلاَلٍ ، عَنْ أَبِی الدَّہْمَائِ ، قَالَ : قَالَ عِمْرَانُ بْنُ حُصَیْنٍ : تَرِثُ الْجَدَّۃُ وَابْنُہَا حَیٌّ۔",,,31952
31953,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَطْعَمَ جَدَّۃً مِنَ ابْنِہَا السُّدُسَ ، فَکَانَتْ أَوَّلَ جَدَّۃٍ وَرِثَتْ فِی الإسْلاَمِ۔ (عبدالرزاق 19093)q",,,31953
31954,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ حُمَیْدِ بْنِ عَبْدِ الرَّحْمَنِ الْحِمْیَرِیِّ ، عَنْ أَبِیہِ ، قَالَ : مَاتَ ابْنٌ لِحَسَکَۃَ الْحَنْظَلِیُّ وَتَرَکَ حَسْکَۃَ وَأَمَّ حَسْکَۃَ ، فَکَتَبَ فِیہَا أَبُو مُوسَی إلَی عُمَرَ بْنِ الْخَطَّابِ ، فَکَتَبَ إلَیْہِ عُمَرُ : أَنْ وَرِّثْہَا مَعَ ابْنِہَا السُّدُسَ۔",,,31954
31955,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ وَہَمَّامٍ ، عَنْ أَنَسِ بْنِ سِیرِینَ ، عَنْ شُرَیْحٍ : أَنَّہُ وَرَّثَ جَدَّۃً مَعَ ابْنِہَا۔\n\n(عبدالرزاق 19095)",,,31955
31956,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ : أَنَّہُ کَانَ یُوَرِّثُ الْجَدَّۃَ وَابْنُہَا حَیٌّ۔",,,31956
31957,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ أَشْعَثَ ، عَنْ مُحَمَّدٍ : أَنَّہُ کَانَ یُوَرِّثُ الْجَدَّۃَ مَعَ ابْنِہَا ، وَابْنُہَا حَیٌّ۔",,,31957
31958,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنْ مُحَمَّدٍ ، أَنَّہُ قَالَ : أَوَّلُ جَدَّۃٍ أُطْعِمَتِ السُّدُسُ فِی الإسْلاَمِ جَدَّۃٌ أُطْعِمَتْہُ وَابْنُہَا حَیٌّ۔",,,31958
31959,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ أَنَسِ بْنِ سِیرِینَ ، عَنْ شُرَیْحٍ : أَنَّہُ وَرَّثَ جَدَّتَیْنِ : أُمَّ أُمٍّ ، وَأُمَّ أَبٍ ، وَابْنَہُمَا حَیٌّ۔",,,31959
31960,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِاللہِ الزُّبَیْرِیُّ، عَنْ سُفْیَانَ، عَنْ ہِشَامٍ، عَنْ أَبِیہِ: أَنَّہُ کَانَ یُوَرِّثُ الْجَدَّۃَ وَابْنُہَا حَیٌّ۔",,,31960
31961,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ زَیْدِ بْنِ ثَابِتٍ ، قَالَ : مَنَعَہَا ابْنُہَا الْمِیرَاثَ۔",,,31961
31962,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ : أَنَّ عُثْمَانَ کَانَ لاَ یُوَرِّثُ الْجَدَّۃَ أُمَّ الأَبِ وَابْنُہَا حَیٌّ ، قَالَ الزُّہْرِیُّ : وَتُوُفِّیَ ابْنُ الزُّبَیْرِ فَلَمْ یُوَرِّثْ۔",,,31962
31963,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ بَسَّامٍ ، عَنْ فُضَیْلٍ ، قَالَ : قَالَ إبْرَاہِیمُ : لاَ تَرِثُ الْجَدَّۃُ مَعَ ابْنِہَا إذَا کَانَ حَیًّا ، فِی قَوْلِ عَلِیٍّ وَزَیْدٍ۔\n\nقَالَ أَبُو بَکْرٍ : سَمِعْت وَکِیعًا یَقُولُ : النَّاسُ عَلَی ہَذَا۔",,,31963
31964,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : لَمْ یُوَرِّثْ أَحَدٌ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْجَدَّۃَ مَعَ ابْنِہَا إلاَّ ابْنُ مَسْعُودٍ۔",,,31964
31965,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ : أَنَّ زَیْدًا لَمْ یَکُن یَجْعَلْ لِلْجَدَّۃِ مَعَ ابْنِہَا مِیرَاثًا۔",,,31965
31966,"حَدَّثَنَا یَزِیدُ ، عَنْ مُحَمَّدِ بْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ، عَنْ عَلِیٍّ وَزَیْدٍ : أَنَّہُمَا لَمْ یَکُونَا یَجْعَلاَنِ لِلْجَدَّۃِ مَعَ ابْنِہَا مِیرَاثًا۔",,,31966
31967,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، عَنْ مَکْحُولٍ ، قَالَ : ابْنُ الْمُلاعَنَۃ تَرِثُ أُمُّہُ مِیرَاثَہُ کُلَّہُ۔",,,31967
31968,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : کَانَ یَقُولُ : لِلْمُلاَعِنَۃِ مِیرَاثُ وَلَدِہَا کُلُّہُ۔",,,31968
31969,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ عُمَر بْنِ عَامِرٍ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَبْدِ اللہِ ، قَالَ فِی وَلَدِ الْمُلاعَنَۃ : مِیرَاثُہُ کُلُّہُ لأُمِّہِ ، فَإِنْ لَمْ یَکُنْ لَہُ أُمٌّ فَہُوَ لِعَصَبَتِہِ۔\n\nوَقَالَ إبْرَاہِیمُ : مِیرَاثُہُ کُلُّہُ لأُمِّہِ ، وَیَعْقِلُ عَنْہُ عَصَبَتُہَا ، وَکَذَلِکَ وَلَدُ الزِّنَا وَوَلَدُ النَّصْرَانِیِّ وَأُمُّہُ مُسْلِمَۃٌ۔",,,31969
31970,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَبْدِ اللہِ : فِی ابْنِ الْمُلاعَنَۃ : مِیرَاثُہُ لأُمِّہِ ، فَإِنْ کَانَتْ أُمُّہُ قَدْ مَاتَتْ یَرِثُہُ وَرَثَتُہَا۔",,,31970
31971,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، عَنْ مُطَرِّفٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : یَرِثُ ابْنُ الْمُلاعَنَۃ أُمَّہُ ، فَإِذَا مَاتَ وَرِثَہُ مَنْ کَانَ یَرِثُ أُمَّہُ۔",,,31971
31972,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ: حدَّثَنَا سَعِیدٌ ، عَنْ قَتَادَۃَ، عَنْ عَبْدِ اللہِ ، قَالَ: مِیرَاثُ ابْنِ الْمُلاعَنَۃ لأُمِّہِ۔",,,31972
31973,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا سَعِیدٌ ، عَنْ قَتَادَۃَ ، عَنْ عَلِیٍّ وَزَیْدٍ : فِی ابْنِ الْمُلاعَنَۃ ، قَالاَ : الثُّلُثُ لأُمِّہِ ، وَمَا بَقِیَ فِی بَیْتِ الْمَالِ۔",,,31973
31974,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، عَنِ الزُّہْرِیِّ ، قَالَ : تَرِثُہُ مِیرَاثَہَا ، وَبَقِیَّتُہُ فِی بَیْتِ الْمَالِ۔",,,31974
31975,"حَدَّثَنَا مَعْن بْنُ عِیسَی ، عَنْ مَالِکِ بْنِ أَنَسٍ ، عَنْ عُرْوَۃَ : فِی ابْنِ الْمُلاعَنَۃ وَوَلَدِ الزِّنَا إذَا مَاتَ : وَرِثَتْہُ أُمُّہُ حَقَّہَا فِی کِتَابِ اللہِ وَإِخْوَتُہُ لأُمِّہِ حُقُوقَہُمْ ، وَکَانَ مَا بَقِیَ لِلْمُسْلِمِینَ۔",,,31975
31976,حدَّثَنَا عِیسَی ، عَنْ مَالِکٍ ، أَنَّہُ بَلَغَہُ عَنْ سُلَیْمَانَ بْنِ یَسَارٍ ، مِثْلَ ذَلِکَ۔,,,31976
31977,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ، قَالَ : مَارَأْیُ إبْرَاہِیمَ بْنِ یَزِیدَ فِی ابْنِ الْمُلاعَنَۃ ؟ فَقُلْتُ : یَلْحَقُ بِأُمِّہِ ، وَقَالَ إبْرَاہِیمُ : یَلْحَقُ بِأَبِیہِ ، فَأَتَیْنَا عَبْدَ اللہِ بْنَ ہُرْمُزَ ، فَکَتَبَ لَنَا إلَی الْمَدِینَۃِ إلَی أَہْلِ الْبَیْتِ الَّذِی کَانَ ذَلِکَ فِیہِمْ ، فَجَائَ جَوَابُ کِتَابِہِمْ : أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَلْحَقَہُ بِأُمِّہِ۔\n\n(عبدالرزاق 12486)",,,31977
31978,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ دَاوُدَ بْنِ أَبِی ہِنْدٍ ، عَنْ عَبْدِ اللہِ بْنِ عُبَیْدِ بْنِ عُمَیْرٍ ، قَالَ : کَتَبْت إلَی أَخٍ لِی فِی بَنِی زُرَیْقٍ : لِمَنْ قَضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِابْنِ الْمُلاعَنَۃ ؟ فَکَتَبَ إلَیَّ : أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَضَی بِہِ لأُمِّہِ ، ہِیَ بِمَنْزِلَۃِ أَبِیہِ وَمَنْزِلَۃِ أُمِّہِ۔\n\n(ابوداؤد 362۔ عبدالرزاق 12477)",,,31978
31979,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ أَبِی لَیْلَی ، عَنِ الشَّعْبِیِّ ، عَنْ عَلِیٍّ وَعَبْدِ اللہِ ، أَنَّہُمَا قَالاَ فِی ابْنِ الْمُلاعَنْۃ : عَصَبَتُہُ عَصَبَۃُ أُمِّہِ۔",,,31979
31980,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مُوسَی بْنُ عُبَیْدَۃَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : ابْنُ الْمُلاعَنَۃ عَصَبَتُہُ عَصَبَۃُ أُمِّہِ یَرِثُہُمْ وَیَرِثُونَہُ۔",,,31980
31981,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : ابْنُ الْمُلاعَنَۃ عَصَبَتُہُ عَصَبَۃُ أُمِّہِ ، یَرِثُونَہُ وَیَعْقِلُونَ عَنْہُ۔",,,31981
31982,"حَدَّثَنَا أَسْبَاطُ ، عَنْ مُطَرِّفٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : یَرِثُہُ أَقْرَبُ النَّاسِ إِلَی أُمِّہِ۔",,,31982
31983,"حَدَّثَنَا شَبَابَۃُ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنِ الْحَکَمِ وَحَمَّادٍ ، قَالاَ : ابْنُ الْمُلاعَنْۃ یَرِثُہُ مَنْ یَرِثُ أُمَّہُ۔",,,31983
31984,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا حَمْزَۃُ الزَّیَّاتُ ، عَنْ رَجُلٍ یُقَالَ لَہُ : عُمَرُ ، عَنِ الشَّعْبِیِّ : فِی ابْنِ مُلاعَنَۃٍ مَاتَ وَتَرَکَ خَالَہُ وَخَالَتَہُ ، قَالَ : الْمَالُ لِلْخَالِ۔",,,31984
31985,"حدَّثَنَا وَکِیعٌ ، قَالَ : قَالَ حَمْزَۃُ : وَکَانَ ابْنُ أَبِی لَیْلَی یَقُولُ : لِلْخَالِ الثُّلُثَانِ وَلِلْخَالَۃِ الثُّلُثُ۔",,,31985
31986,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا حَسَنُ بْنُ صَالِحٍ ، عَمَّنْ سَمِعَ الشَّعْبِیَّ یَقُولُ : فِی ابْنِ مُلاَعَنَۃٍ مَاتَ وَتَرَکَ ابْنَ أَخِیہِ وَجَدَّہُ أَبَا أُمِّہِ ، قَالَ : الْمَالُ لابْنِ الأَخِ۔",,,31986
31987,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ عَمَّنْ سَمِعَ الشَّعْبِیَّ ، عَنْ عَلِیٍّ وَعَبْدِ اللہِ ، أَنَّہُمَا قَالاَ فِی ابْنِ مُلأَعَنْۃٍ مَاتَ وَتَرَکَ أُمَّہُ وَأَخَاہُ لأُمِّہِ ، قَالَ : کَانَ عَلِیٌّ یَقُولُ : لِلأُمِّ الثُّلُثُ ، وَلِلأَخِ السُّدُسُ ، وَیَرُدُّ مَا بَقِیَ عَلَیْہِمَا الثُّلُثَانِ وَالثُّلُثُ ، وَکَانَ ابْنُ مَسْعُودٍ یَقُولُ : لِلأُمِّ الثُّلُثُ ، وَلِلأَخِ السُّدُسُ ، وَیَرُدُّ مَا بَقِیَ عَلَی الأُمِّ\n\nقَالَ أَبُو بَکْرٍ : فَہَذِہِ مِنْ قَوْلِہِمْ جَمِیعًا تَصِیرُ مِنْ سِتَّۃٍ۔",,,31987
31988,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ أَبِی الْمِنْہَالِ ، عَنْ إیَاسِ بْنِ عَبْدٍ ، الْمُزَنِیّ : أَنَّہُ سُئِلَ عَنْ أُنَاسٍ سَقَطَ عَلَیْہِمْ بَیْتٌ فَمَاتُوا جَمِیعًا ؟ فَوَرِثَ بَعْضُہُمْ مِنْ بَعْضٍ۔",,,31988
31989,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، قَالَ : أَخْبَرَنِی قَطَنُ بْنُ عَبْدِ اللہِ الضَّبِّیُّ : أَنَّ امْرَأَۃً رَکِبَتِ الْفُرَاتِ وَمَعَہَا ابْنٌ لَہَا فَغَرِقَا جَمِیعًا ، فَلَمْ یُدْرَ أَیُّہُمَا مَاتَ قَبْلَ صَاحِبِہِ فَأَتَیْنَا شُرَیْحًا فَأَخْبَرْنَاہُ بِذَلِکَ ، فَقَالَ : وَرِثُوا کُلَّ وَاحِدٍ مِنْہُمَا مِنْ صَاحِبِہِ ، وَلاَ تَرُدُّوا عَلَی وَاحِدٍ مِنْہُمَا مِمَّا وَرِثَ مِنْ صَاحِبِہِ شَیْئًا۔",,,31989
31990,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی الزَّعْرَائِ عَمْرِو بْنِ عَمْرٍو الْجُشَمِیِّ ، عَنْ عَبْدِ اللہِ بْنِ عُتْبَۃَ - وَکَانَ قَاضِیًا لابْنِ الزُّبَیْرِ - : أَنَّہُ وَرَّثَ الْغَرْقَی بَعْضَہُمْ مِنْ بَعْضٍ۔",,,31990
31991,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ سِمَاکٍ ، عَنْ رَجُلٍ ، عَنْ عُمَرَ ، أَنَّہُ وَرَّثَ قَوْمًا غَرِقُوا بَعْضَہُمْ مِنْ بَعْضٍ۔",,,31991
31992,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی حُصَینٍ : أَنَّ قَوْمًا غَرِقُوا عَلَی جِسْرِ مَنْبِجٍ ، فَوَرَّثَ عُمَرُ بَعْضَہُمْ مِنْ بَعْضٍ ، قَالَ سُفْیَانُ لأَبِی حُصَیْنٍ : مِنَ الشَّعْبِیِّ سَمِعْتہ ، قَالَ : نَعَمْ۔",,,31992
31993,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الشَّعْبِیِّ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ : أَنَّ أَہْلَ بَیْتٍ غَرِقُوا فِی سَفِینَۃٍ ، فَوَرَّثَ عَلِیٌّ بَعْضَہُمْ مِنْ بَعْضٍ۔",,,31993
31994,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ أَبِی لَیْلَی ، عَنِ الشَّعْبِیِّ ، عَنْ عَبِیدَۃَ : أَنَّ قَوْمًا وَقَعَ عَلَیْہِمْ بَیْتٌ ، أَوْ مَاتُوا فِی طَاعُونٍ ، فَوَرَّثَ عُمَرُ بَعْضَہُمْ مِنْ بَعْضٍ۔",,,31994
31995,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ حُرَیسِ الْبَجَلِیِّ ، عَنْ أَبِیہِ : أَنَّ رَجُلاً وَابْنَہُ - أَوْ أَخَوَیْنِ - قُتِلاَ یَوْمَ صِفِّینَ جَمِیعًا ، لاَ یُدْرَی أَیُّہُمَا قُتِلَ أَوَّلاً ، قَالَ : فَوَرَّثَ عَلِیٌّ کُلَّ وَاحِدٍ مِنْہُمَا صَاحِبَہُ۔\n\n(عبدالرزاق 19152۔ دارمی 3048)",,,31995
31996,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ رَجُلٍ ، عَنْ قَبِیصَۃَ بْنِ ذُؤَیْبٍ : أَنَّ طَاعُونًا وَقَعَ بِالشَّامِ ، فَکَانَ أَہْلُ الْبَیْتِ یَمُوتُونَ جَمِیعًا ، فَکَتَبَ عُمَرُ أَنْ یُوَرَّثُ الأَعْلَی مِنَ الأَسْفَلِ ، وَإِذَا لَمْ یَکُونُوا کَذَلِکَ وَرَّثَ ہَذَا مِنْ ذَا ، وَہَذَا مِنْ ذَا۔\n\nقَالَ سَعِیدٌ : الأَعْلَی مِنَ الأَسْفَلِ : کَانَ الْمَیِّتُ مِنْہُمْ یَمُوتُ وَقَدْ وَضَعَ یَدُہُ عَلَی آخَرَ إلَی جَنْبِہِ۔",,,31996
31997,حَدَّثَنَا عَبْدَۃُ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ عَلِیٍّ ، مِثْلَہُ۔,,,31997
31998,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ مَنْصُورٍ ، قَالَ إبْرَاہِیمُ : فِی الْقَوْمِ یَمُوتُونَ لاَ یُدْرَی أَیُّہُمْ مَاتَ قَبْلُ ، قَالَ : یُوَرَّثُ بَعْضُہُمْ مِنْ بَعْضٍ۔\n\nقَالَ مَنْصُورٌ : لاَ یَضُرُّک بِأَیِّہِمْ بَدَأْت إذَا وَرَّثْت بَعْضَہُمْ مِنْ بَعْضٍ۔",,,31998
31999,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ دَاوُدَ بْنِ أَبِی ہِنْدٍ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ : أَنَّہُ کَانَ یُوَرِّثُ الأَحْیَائَ مِنَ الأَمْوَاتِ ، وَلاَ یُوَرِّثُ الْغَرْقَی بَعْضَہُمْ مِنْ بَعْضٍ۔",,,31999
32000,"حَدَّثَنَا عَبْدَۃُ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، قَالَ : کَانَ فِی کِتَابِ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ : یَرِثُ کُلُّ إنْسَانٍ وَارِثُہُ مِنَ النَّاسِ۔",,,32000
32001,"حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : أَتَتْہُ امْرَأَۃٌ فَقَالَتْ : إنَّ أَخِی وَابْنَ أَخِی خَرَجَا فِی سَفِینَۃٍ فَغَرِقَا ، فَلَمْ یُوَرِّثْہُمَا شَیْئًا۔",,,32001
32002,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا حُسَیْنٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ یَرِثُ وَاحِدٌ مِنْہُمَا مِمَّا وَرِثَ مِنْ صَاحِبِہِ شَیْئًا۔",,,32002
32003,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ فِی الَّذِینَ یَمُوتُونَ جَمِیعًا ، لاَ یُدْرَی أیُّہُمْ مَاتَ قَبْلَ صَاحِبِہِ ، قَالَ : لاَ یُوَرَّثُ بَعْضُہُمْ مِنْ بَعْضٍ۔",,,32003
32004,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنْ جَہْمٍ ، عَنْ إبْرَاہِیمَ : أَنَّ عَلِیًّا وَرَّثَ ثَلاَثَۃً غَرِقُوا فِی سَفِینَۃٍ بَعْضَہُمْ مِنْ بَعْضٍ وَأُمُّہُمْ حَیَّۃٌ ، فَوَرَّثَ أُمَّہُمُ السُّدُسَ مِنْ صُلْبِ کُلِّ وَاحِدٍ مِنْہُمْ ، ثُمَّ وَرَّثَہَا الثُّلُثَ بِمَا وَرِثَ کُلُّ وَاحِدٍ مِنْ صَاحِبِہِ ، وَجَعَلَ مَا بَقِیَ لِلْعَصَبَۃِ۔",,,32004
32005,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ مُحَمَّدِ بْنِ سَالِمٍ ، عَنْ إبْرَاہِیمَ وَالشَّعْبِیِّ : أَنَّہُ سَمِعَہُمَا یُفَسِّرَانِ قَوْلَہُمْ : یُوَرَّثُ بَعْضُہُمْ مِنْ بَعْضٍ ، قَالاَ : إذَا مَاتَ أَحَدُہُمَا وَتَرَکَ مَالا ، وَلَمْ یَتْرُکَ الآخَرُ شَیْئًا ، وَرِثَ وَرَثَۃُ الَّذِی لَمْ یَتْرُکْ شَیْئًا مِیرَاثَ صَاحِبِ الْمَالِ ، وَلَمْ یَکُنْ لِوَرَثَۃِ صَاحِبِ الْمَالِ شَیْئٌ۔",,,32005
32006,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : مِیرَاثُ اللَّقِیطِ بِمَنْزِلَۃِ اللُّقَطَۃِ۔",,,32006
32007,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنِ الْحَارِثِ بْنِ حَصِیرَۃ ، عَنْ زَیْدِ بْنِ وَہْبٍ ، قَالَ : لَمَّا رَجَمَ عَلِیٌّ الْمَرْأَۃَ ، قَالَ لاَہْلِہَا : ہَذَا ابْنُکُمْ تَرِثُونَہُ ، وَیَرِثُکُمْ ، وَإِنْ جَنَی جِنَایَۃً فَعَلَیْکُمْ۔",,,32007
32008,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ مُحَمَّدِ بْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ، عَنْ عَلِیٍّ وَعَبْدِ اللہِ : فِی ابْنِ الْمُلاعَنَۃ : أُمُّہُ عَصَبَتُہُ وَعَصَبَتُہَا عَصَبَتُہُ وَوَلَدُ الزِّنَا بِمَنْزِلَتِہِ۔",,,32008
32009,"حَدَّثَنَا عَبَّادُ ، عَنْ عُمَرَ بْنِ عَامِرٍ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : مِیرَاثُہُ کُلُّہُ لأُمِّہِ - یَعْنِی : ابْنَ الْمُلاعَنَۃ - ، وَیَعْقِلُ عَنْہُ عَصَبَتُہَا ، وَکَذَلِکَ وَلَدُ الزِّنَا ، وَوَلَدُ النَّصْرَانِیِّ وَأُمُّہُ مُسْلِمَۃٌ۔",,,32009
32010,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : وَلَدُ الْمُلاعَنَۃ وَوَلَدُ الزِّنَا : یَتَوَارَثَانِ مِنْ قِبَلِ الأُمِّ۔",,,32010
32011,"حَدَّثَنَا حَفْصٌ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ، قَالَ : وَلَدُ الزِّنَا بِمَنْزِلَۃِ ابْنِ الْمُلاعَنَۃ ، أَو ابْنُ الْمُلاعَنَۃ بِمَنْزِلَۃِ وَلَدِ الزِّنَا۔",,,32011
32012,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَشْعَثِ ، عَنِ الشَّعْبِیِّ ، قَالَ : کَتَبَ ہِشَامُ بْنُ ہُبَیْرَۃَ إلَی شُرَیْحٍ یَسْأَلُہُ عَنْ مِیرَاثِ وَلَدِ الزِّنَا ؟ فَکَتَبَ إلَیْہِ : ارْفَعْہُ إلَی السُّلْطَانِ فَلْیَلِ حُزُونَتَہُ وَسُہُولَتَہُ۔",,,32012
32013,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ، عَنْ إبْرَاہِیمَ، عَنِ الْحَسَنِ بْنِ الْحُرّ، عَنِ الْحَکَمِ، قَالَ: وَلَدُ الزِّنَا وَوَلَدُ الْمُتَلاعَنْینَ تَرِثُہُمَا أُمُّہُمَا وَأَخْوَالُہُمَا۔",,,32013
32014,"حَدَّثَنَا ہُشَیْمٌ، عَنْ مُغِیرَۃَ، عَنْ شِبَاکٍ، عَنِ الشَّعْبِیِّ ، عَنْ عَلِیٍّ: فِی الْخُنْثَی ، قَالَ: یُوَرَّثُ مِنْ قِبَلِ مَبَالِہِ۔",,,32014
32015,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الْحَسَنُ بْنُ کَثِیرٍ الأَحْمَسِیُّ ، عَنْ أَبِیہِ : أَنَّ مُعَاوِیَۃَ أُتِیَ فِی خُنْثَی فَأَرْسَلِہُمْ إلَی عَلِیّ ، فَقَالَ : یُوَرَّثُ مِنْ حَیْثُ یَبُولُ۔",,,32015
32016,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ جَابِرِ بْنِ زَیْدٍ وَالْحَسَنِ : فِی الْخُنْثَی ، قَالاَ : یُوَرَّثُ مِنْ مَبَالِہِ۔\n\nقَالَ قَتَادَۃُ : فَذَکَرْتُ ذَلِکَ لِسَعِیدِ بْنِ الْمُسَیَّبِ ، فَقَالَ : نَعَمْ ، وَإِنْ بَالَ مِنْہُمَا جَمِیعًا فَمِنْ أَیِّہِمَا سَبَقَ۔",,,32016
32017,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عُمَرُ بْنُ بَشِیرٍ الْہَمْدَانِیُّ ، عَنِ الشَّعْبِیِّ : فِی مَوْلُودٍ وُلِدَ لَیْسَ لَہُ مَا لِلذَّکَرِ ، وَلاَ مَا لِلأُنْثَی ، یَبُولُ منْ سُرَّتِہِ ! قَالَ : لَہُ نِصْفُ حَظِّ الأُنْثَی وَنِصْفُ حَظِّ الذَّکَرِ۔",,,32017
32018,"حَدَّثَنَا رَوْحُ بْنُ عُبَادَۃَ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ الْعَدَنِیِّ ، عَنْ أَبِی جَعْفَرٍ : فِی الْخُنْثَی یُوَرَّثُ مِنْ مَبَالِہِ ، وَإِنْ بَالَ مِنْہُمَا جَمِیعًا فَمِنْ أَیِّہِمَا سَبَقَ۔",,,32018
32019,"حَدَّثَنَا جَرِیرٌ، عَنْ لَیْثٍ، عَنْ حَمَّادٍ، عَنْ إبْرَاہِیمَ، قَالَ: لَمْ یَکُنْ أَبُوبَکْرٍ وَعُمَرُ وَعُثْمَان یُوَرِّثُونَ الْحَمِیلَ۔",,,32019
32020,"حَدَّثَنَا حَفْصٌ ، عَنْ أَبِی طَلْقٍ ، عَنْ أَبِیہِ ، قَالَ : أَدْرَکْت الْحُمَلاَئَ فِی زَمَانِ عَلِیٍّ وَعُثْمَانَ لاَ یُوَرَّثُونَ۔",,,32020
32021,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ وَابْنِ سِیرِینَ ، قَالاَ : مَا یُوَرَّثُ الْحَمِیلُ إلاَّ بِبَیِّنَۃٍ۔",,,32021
32022,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عَلِیُّ بْنُ الْمُبَارَکِ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ ثَوْبَانَ : أَنَّ عُمَرَ کَتَبَ : أَنْ لاَ یُوَرَّثُ بِوِلاَدَۃِ الشِّرْکِ۔",,,32022
32023,"حَدَّثَنَا ابْنُ نُمَیْرٍ، قَالَ: حدَّثَنَا مُجَالِدٌ، عَنِ الشَّعْبِیِّ، قَالَ: کُتِبَ إلَی شُرَیْحٍ أَنْ لاَ یُوَرَّثَ حَمِیلٌ إلاَّ بِبَیِّنَۃٍ۔",,,32023
32024,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : ذُکِرَ لِمُحَمَّدٍ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ کَتَبَ فِی الْحُمَلاَئِ: لاَ یُوَرَّثُونَ إلاَّ بِشَہَادَۃِ الشُّہُودِ ، قَالَ : فَقَالَ مُحَمَّدٌ : قَدْ تَوَارَثَ الْمُہَاجِرُونَ وَالأَنْصَارُ بِنَسَبِہِمَ الَّذِی کَانَ فِی الْجَاہِلِیَّۃِ ، فَأَنَا أُنْکِرُ أَنْ یَکُونَ عُمَرُ کَتَبَ بِہَذَا۔",,,32024
32025,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یَتَوَارَثُونَ بِالأَرْحَامِ الَّتِی یَتَوَاصَلُونَ بِہَا۔",,,32025
32026,"حَدَّثَنَا جَرِیرٌ ، عَنِ الأَعْمَشِ ، عَنْ إیَاسِ بْنِ عَبَّاسٍ ، عَنْ شَیْخٍ مِنْ قَوْمِہِ : أَنَّ أَبَا سُلَیْمَانَ غَرِقَ أَخٌ لَہُ یُقَالَ لَہُ : رَاشِدٌ ، فَاخْتَصَمَ فِیہِ بَنُو زَبِیدٍ وَبَنُو أَسَدٍ ، فَارْتَفَعُوا إلَی مَسْرُوقٍ ، فَقَالَ : مَسْرُوقٌ لِبَنِی أَسَدٍ : أَتَشْہَدُونَ أَنَّہُ کَانَ یَحْرُمُ عَنْہُ مَا یَحْرُمُ الأَخَ مِنْ أُخْتِہِ ، فَشَہِدُوا بِذَلِکَ ، فَأَعْطَی أَبَا سُلَیْمَانَ مِیرَاثَہُ۔",,,32026
32027,"حَدَّثَنَا وَکِیعٌ ، قَالَ سَمِعْت الأَعْمَشَ ، قَالَ : کَانَ أَبِی حَمِیلاً فَمَاتَ أَخُوہُ ، فَوَرَّثَہُ مَسْرُوقٌ مِنْہُ۔",,,32027
32028,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : قَالَ عُمَرُ : کُلّ نَسَبٍ یُتَوَصَل عَلَیْہِ فِی الإسْلاَمِ فَہُوَ وَارِثٌ مَوْرُوثٌ۔",,,32028
32029,"حَدَّثَنَا ابْنُ إدْرِیسَ، عَنْ أَشْعَثَ، عَنِ الشَّعْبِیِّ، قَالَ: إذَا کَانَ نَسَبًا مَعْرُوفًا مَوْصُولاً وَرِثَ۔ یَعْنِی: الْحَمِیلَ۔",,,32029
32030,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ وَحَمَّادًا عَنِ الْحَمِیلِ ؟ فَقَالاَ : لاَ یَرِثُ إلاَّ بِبَیِّنَۃٍ۔",,,32030
32031,"حَدَّثَنَا عَبْدُالرَّحِیمِ بْنُ عَبْدِالرَّحْمَنِ الْمُحَارِبِیُّ، قَالَ: حدَّثَنَا زَائِدَۃُ بْنُ قُدَامَۃَ، قَالَ: حَدَّثَنَا أَشْعَثُ بْنُ أَبِی الشَّعْثَائِ، قَالَ: أَقَرَّتِ امْرَأَۃٌ مِنْ مُحَارِبٍ جَلِیبَۃٌ بِنَسَبِ أَخٍ لَہَا جَلِیبٌ، فَوَرَّثَہُ عَبْدُالرَّحْمَنِ بْن عُتْبَۃَ مِنْ أُخْتِہِ۔",,,32031
32032,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الْحَکَمُ بْنُ عَطِیَّۃَ ، قَالَ : سَأَلْتُ الْحَسَنَ عَنِ الْحَمِیلِ یُقِیمُ الْبَیِّنَۃَ أَنَّہُ أَخُوہُ ، قَالَ : یَرِثُہُ فِی کِتَابِ اللہِ {وَأُولُو الأَرْحَامِ بَعْضُہُمْ أَوْلَی بِبَعْضٍ فِی کِتَابِ اللہِ}۔",,,32032
32033,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الْوَلِیدِ بْنِ جُمَیْعٍ ، عَنِ الْقَاسِمِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ عَبْدِ اللہِ ، قَالَ : إذَا ارْتَدَّ الْمُرْتَدُّ وَرِثَہُ وَلَدُہُ۔",,,32033
32034,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی عَمْرٍو الشَّیْبَانِیِّ ، عَنْ عَلِیٍّ : أَنَّہُ أُتِیَ بِمسْتورِد الْعِجْلِیّ وَقَدِ ارْتَدَ ، فَعَرَضَ عَلَیْہِ الإسْلاَمَ فَأَبَی فَقَتَلَہُ وَجَعَلَ مِیرَاثَہُ بَیْنَ وَرَثَتِہِ مِنَ الْمُسْلِمِینَ۔\n\n(عبدالرزاق 19296۔ دارمی 3075)",,,32034
32035,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ، عَنْ حَجَّاجٍ، عَنِ الْحَکَمِ، عَنْ عَلِیٍّ: فِی مِیرَاثِ الْمُرْتَدِّ: لِوَرَثَتِہِ مِنَ الْمُسْلِمِینَ۔",,,32035
32036,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، قَالَ : کَتَبَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ : فِی مِیرَاثِ الْمُرْتَدِّ ، أَنَّہُ لِوَرَثَتِہِ مِنَ الْمُسْلِمِینَ ، وَلَیْسَ لأَہْلِ ۔۔ شَیْئٌ۔",,,32036
32037,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ، عَنْ سَعِیدٍ، عَنْ قَتَادَۃَ، عَنِ الْحَسَنِ، قَالَ: یُقْتَلُ، وَمِیرَاثُہُ لِوَرَثَتِہِ مِنَ الْمُسْلِمِینَ۔",,,32037
32038,"حَدَّثَنَا حَفْصٌ ، عَنْ عَمْرو ، عَنِ الْحَسَنِ ، قَالَ : جُعِلَ مِیرَاثُ الْمُرْتَدِّ لِوَرَثَتِہِ۔",,,32038
32039,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مُوسَی بْنِ أَبِی کَثِیرٍ قَالَ : سَأَلْتُ سَعِیدَ بْنَ الْمُسَیَّبِ عَنْ مِیرَاثِ الْمُرْتَدِّ ، ہَلْ یُوصَلُ ؟ قَالَ : مَا یُوصَلُ ؟ قُلْتُ : یَرِثُہُ بَنُوہُ ، قَالَ نَرِثُہُمْ لاَ یَرِثُونَنَا۔",,,32039
32040,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مِسْعَرٌ ، عَنْ أَبِی الصَّبَّاحِ مُوسَی بْنِ أَبِی کَثِیرٍ ، قَالَ : سَمِعْتُ سَعِیدَ بْنَ الْمُسَیَّبِ یَقُولُ : الْمُرْتَدُّونَ نَرِثُہُمْ ، وَلاَ یَرِثُونَنَا۔",,,32040
32041,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ وَالْحَکَمِ ، قَالاَ : یُقَسَّمُ مِیرَاثُہُ بَیْنَ امْرَأَتِہِ وَبَیْنَ وَرَثَتِہِ مِنَ الْمُسْلِمِینَ۔",,,32041
32042,"حَدَّثَنَا وَکِیعٌ ، قَالَ : سَمِعْتُ سُفْیَانَ یَقُولُ : إذَا لَحِقَ بِدَارِ الْحَرْبِ ، ثُمَّ رَجَعَ قَبْلَ أَنْ یُقَسَّمَ مِیرَاثُہُ ، أَوْ یَعْتِقَ الْحَاکِمُ أُمَّہَاتِ أَوْلاَدِہِ وَمُدَبَّرَتَہُ فَہُوَ أَحَقُّ بِہِمْ۔",,,32042
32043,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ، قَالَ : کَانَ الْمُسْلِمُونَ یُطَیِّبُونَ لأَہْلِ الْمُرْتَدِّ مِیرَاثَہُ۔ یَعْنِی : إذَا قُتِلَ۔",,,32043
32044,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ : أَنَّ قَتَادَۃَ - رَجُلاً مِنْ بَنِی مُدْلِجٍ - قَتَلَ ابْنَہُ ، فَأَخَذَ بِہِ عُمَرُ بْنُ الْخَطَّابِ مِئَۃ مِنَ الإِبِلِ : ثَلاَثِینَ حِقَّۃً ، وَثَلاَثِینَ جَذَعَۃً ، وَأَرْبَعِینَ خَلِفَۃً ، وَقَالَ لاَبِی الْمَقْتُولِ: سَمِعْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ: لَیْسَ لِقَاتِلٍ مِیرَاثٌ۔(ابن ماجہ 2646۔ مالک 867)",,,32044
32045,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، قَالَ : قَالَ عُمَرُ : لاَ یَرِثُ الْقَاتِلُ۔",,,32045
32046,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ، عَنْ مُطَرِّفٍ، عَنِ الشَّعْبِیِّ ، قَالَ: قَالَ عُمَرُ: لاَ یَرِثُ الْقَاتِلُ عَمْدًا ، وَلاَ خَطَأً۔",,,32046
32047,"حَدَّثَنَا عَبَّادٌ ، عَنْ حَجَّاجٍ ، عَنْ حَبِیبٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ : أَنَّ رَجُلاً قَتَلَ أَخَاہُ خَطَا ، فَسُئِلَ عَنْ ذَلِکَ ابْنُ عَبَّاسٍ ؟ فَلَمْ یُوَرِّثْہُ ، وَقَالَ : لاَ یَرِثُ قَاتِلٌ شَیْئًا۔",,,32047
32048,"حَدَّثَنَا شَبَابَۃُ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : قضَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَرِثُ قَاتِلٌ مَنْ قَتَلِ قَرِیبِہِ شَیْئًا مِنَ الدِّیَۃِ عَمْدًا أَوْ خَطَأً۔\n\nوَقَالَ الزُّہْرِیُّ الْقَاتِلُ لاَ یَرِثُ مِنْ دِیَۃ مَنْ قُتِلَ شَیْئًا وَإِنْ کَانَ وَلَدًا ، أَوْ وَالِدًا ، وَلَکِنْ یَرِثُ مِنْ مَالِہِ ، لأَنَّ اللَّہَ قَدْ عَلِمَ أَنَّ النَّاسَ یَقْتُلُ بَعْضُہُمْ بَعْضًا ، وَلاَ یَنْبَغِی لأَحَدٍ أَنْ یَقْطَعَ الْمَوَارِیثَ الَّتِی فَرَضَہَا۔",,,32048
32049,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَسَنٍ ، عَنْ أَبِیہِ ، عَنْ أَبِی عَمْرٍو الْعَبْدِیِّ ، عَنْ عَلِیٍّ ، قَالَ : لاَ یَرِثُ الْقَاتِلُ۔",,,32049
32050,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ یَرِثُ الْقَاتِلُ مِنَ دِیَۃٍ مَنْ قُتِلَ شَیْئًا۔",,,32050
32051,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانُ، عَنْ مَنْصُورٍ، عَنْ إِبْرَاہِیمَ قَالَ: لاَ یَرِثُ الْقَاتِلُ مِنَ الدِّیَۃ ولاَ مِنَ الْمَالُ شَیْئًا۔",,,32051
32052,"حَدَّثَنَا إبْرَاہِیمُ بْنُ صَدَقَۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ : أَنَّہُ کَانَ لاَ یُوَرِّثُ الْقَاتِلَ وَیَرَی ، أَنَّہُ یَحْجبُ۔",,,32052
32053,"حَدَّثَنَا حَمَّادُ بْنُ مَسْعَدَۃَ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، قَالَ : سَأَلْتُ ابْنَ شِہَابٍ عَنِ الْقَاتِلِ یَرِثُ شَیْئًا ؟ قَالَ : فَقَالَ سَعِیدُ بْنُ الْمُسَیَّبِ : مَضَتِ السُّنَّۃُ أَنَّ الْقَاتِلَ لاَ یَرِثُ شَیْئًا۔",,,32053
32054,"حَدَّثَنَا حَمَّادُ بْنُ مَسْعَدَۃَ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنْ عَبْدِ الْوَاحِدِ بْنِ أَبِی عَوْنٍ ، قَالَ : قَالَ مُحَمَّدُ بْنُ جُبَیْرٍ: الْقَاتِلُ عَمْدًا لاَ یَرِثُ مِنَ الدِّیَۃِ ، وَلاَ مِنْ غَیْرِہَا شَیْئًا ، وَالْقَاتِلُ خَطَأً لاَ یَرِثُ مِنَ الدِّیَۃِ شَیْئًا وَیَرِثُ مِنْ غَیْرِہَا إنْ کَانَ۔",,,32054
32055,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عُرْوَۃَ ، قَالَ : لاَ یَرِثُ الْقَاتِلُ۔",,,32055
32056,"حَدَّثَنَا حَاتِمٌ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، قَالَ : لاَ یَرِثُ قَاتِلٌ شَیْئًا۔",,,32056
32057,"حَدَّثَنَا ابْنُ أَبِی غَنِیَّۃَ ، عَنْ أَبِیہِ ، عَنِ الْحَکَمِ ، قَالَ : إذَا قَتَلَ الرَّجُلُ ابْنَہُ ، أَوْ أَخَاہُ لَمْ یَرِثْہُ ، وَوَرِثَہُ أَقْرَبُ النَّاسِ بَعْدَہُ۔",,,32057
32058,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : إنْ قَتَلَہُ خَطَأً وَرِثَہُ مِنْ مَالِہِ ، وَلَمْ یَرِثْ مِنْ دِیَتِہِ ، وَإِنْ قَتَلَہُ عَمْدًا لَمْ یَرِثْ مِنْ مَالِہِ ، وَلاَ مِنْ دِیَتِہِ۔",,,32058
32059,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : إذَا قَتَلَ وَلِیَّہُ خَطَأً وَرِثَ مِنْ مَالِہِ ، وَلَمْ یَرِثْ مِنْ دِیَتِہِ ، وَإِنْ قَتَلَہُ عَمْدًا لَمْ یَرِثْ مِنْ مَالِہِ ، وَلاَ مِنْ دِیَتِہِ۔",,,32059
32060,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عَلِیُّ بْنُ مُبَارَکٍ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ عَلِیٍّ : فِی رَجُلٍ قَتَلَ أُمَّہُ قَالَ : إنْ کَانَ خَطَأً وَرِثَ ، وَإِنْ کَانَ عَمْدًا لَمْ یَرِثْ۔\n\nقَالَ وَکِیعٌ : لاَ یَرِثُ قَاتِلُ عَمْدٍ وَلاَ خَطَأٍ مِنَ الدِّیَۃِ ، وَلاَ مِنَ الْمَالِ۔",,,32060
32061,"حَدَّثَنَا یَحْیَی بْنُ یَعْلَی ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ یَرِثُ الْقَاتِلُ۔",,,32061
32062,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ مَنْصُورٍ، عَنْ إبْرَاہِیمَ ، قَالَ: لاَ یَرِثُ الْقَاتِلُ شَیْئًا مِنْ دِیَتِہِ ، وَلاَ مِنْ مَالِہِ۔",,,32062
32063,"حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ سُفْیَانَ ، عَنْ رَجُلٍ ، عَنِ الْقَاسِمِ ، قَالَ : لاَ یَرِثُ الْقَاتِلُ۔",,,32063
32064,"حَدَّثَنَا یَحْیَی بْنُ یَمَانِ ، عَنْ سُفْیَانَ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ : لاَ یَرِثُ الْقَاتِلُ۔",,,32064
32065,"حَدَّثَنَا رَوْحُ بْنُ عُبَادَۃَ ، عَنْ مُحَمَّدِ بْنِ أَبِی حَفْصَۃَ ، قَالَ : حدَّثَنِی ابْنُ شِہَابٍ ، عَنْ عَلِیِّ بْنِ حُسَیْنٍ : أَنَّہُ کَانَ لاَ یُوَرِّثُ وَلَدَ الزِّنَا وَإِنَ ادَّعَاہُ الرَّجُلُ۔",,,32065
32066,"حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ طَاوُوس ، قَالَ : قُلْتُ لَہُ : مَا کَانَ أَبُوک یَقُولُ فِی وَلَدِ الزِّنَا یَعْتِقُہُ مَوَالِیہِ ، أَوْ سَادَتُہُ فَیَسْتَلْحِقُہُ أَبُوہُ وَقَدْ عَلِمَ مَوَالِیہِ أَنَّہُ ابْنُہُ ؟ قَالَ : کَانَ یَقُولُ : لاَ یَرِثُ۔",,,32066
32067,"حَدَّثَنَا الضَّحَّاکُ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، أَنَّہُ قَالَ : یَرِثُہُ إذَا عَرَفَ مَوَالِیہِ أَنَّہُ ابْنُہُ ، وَإِنْ أَنْکَرَہ مَوَالِیہِ وَخَاصَمُوہُ لَمْ یَرِثْ۔",,,32067
32068,"حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: مَنْ عَہَرَ بِامْرَأَۃٍ حُرَّۃٍ، أَوْ أَمَۃِ قَوْمٍ، فَإِنَّہُ لاَ یَرِثُ وَلاَ یُورَثُ۔ (ابن حبان 5996۔ عبدالرزاق 13851)",,,32068
32069,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنْ مُحَمَّدٍ فِی ابْنٍ ۔۔۔۔ مَوَلَّدَ مِنَ الزِّنَی ، قَالَ : لاَ یُلْحَقُ بِہِ۔",,,32069
32070,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ شِبَاکٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ یَرِثُ وَلَدُ الزِّنَا ، إنَّمَا یَرِثُ مَنْ لاَ یُقَامُ عَلَی أَبِیہِ الْحَدُّ ، وَتُمَلَّک أُمَّہُ بِنِکَاحٍ ، أَوْ شِرَائٍ۔",,,32070
32071,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَنْ زُہَیْرٍ ، عَنِ الْحَسَنِ بْنِ الْحُرِّ ، عَنِ الْحَکَمِ ، قَالَ : حدَّثَنِی أَنَّ وَلَدَ الزِّنَا لاَ یَرِثُہُ الَّذِی یَدَّعِیہِ ، وَلاَ یَرِثُہُ الْمَوْلُودُ۔",,,32071
32072,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : یَرِثُ بِأَدْنَی النَّسَبَیْنِ۔",,,32072
32073,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ : فِی رَجُلٍ تَرَکَ ابْنَتَہُ وَہِیَ أُخْتُہُ وَہِیَ امْرَأتُہُ ، قَالَ : تَرِثُ بِأَدْنَی قَرَابَتِہَا ، قَالَ : وَقَالَ قَتَادَۃُ : لَہَا الْمَالُ کُلُّہُ۔",,,32073
32074,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : لاَ یَرِثُ الْمَجُوسِیُّ إلاَّ بِوَجْہٍ وَاحِدٍ۔",,,32074
32075,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَمَّنْ سَمِعَ الشَّعْبِیَّ ، عَنْ عَلِیٍّ وَعَبْدِ اللہِ : أَنَّہُمَا کَانَا یُوَرِّثَانِ الْمَجُوسِیَّ مِنَ الْوَجْہَیْنِ۔",,,32075
32076,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، قَالَ : سَأَلْتُ حَمَّادًا عَنْ مِیرَاثِ الْمَجُوسِیِّ ؟ قَالَ : یَرِثُونَ مِنَ الْوَجْہِ الَّذِی یَحِلُّ۔",,,32076
32077,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ : فِی مَجُوسِیٍّ تَزَوَّجَ ابْنَتَہُ فَأَصَابَ مِنْہَا ابْنَتَیْنِ ، ثُمَّ مَاتَتْ إحْدَاہُمَا بَعْدَ مَوْتِ الأَبِ ، قَالَ : لأُخْتِہَا لأَبِیہَا وَلأُمِّہَا النِّصْفُ ، وَلأُخْتِہَا لأَبِیہَا وَہِیَ أُمُّہَا السُّدُسُ تَکْمِلَۃً الثُّلُثَیْنِ ، حُجِبَتْ نَفْسہا بِنَفْسِہَا۔",,,32077
32078,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی بِشْرٍ ، عَنْ عَطَائٍ : أَنَّ رَجُلاً أَعْتَقَ غُلاَمًا لَہُ سَائِبَۃً ، فَمَاتَ وَتَرَکَ مَالا ، فَسُئِلَ ابْنُ مَسْعُودٍ ؟ فَقَالَ : إنَّ أَہْلَ الإسْلاَمِ لاَ یُسَیِّبُونَ ، إنَّمَا کَانَتْ یُسَیِّبُ أَہْلُ الْجَاہِلِیَّۃِ ، أَنْتَ مَوْلاَہُ وَوَلِیُّ نِعْمَتِہِ وَأَوْلَی النَّاسِ بِمِیرَاثِہِ ، وَإلاَّ فَأرِنِہِ ہَا ہُنَا وَرَثَۃٌ کَثِیرٌ۔ یَعْنِی : بَیْت الْمَالِ۔",,,32078
32079,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : أُتِیَ ابْنُ مَسْعُودٍ بِمَالِ مَوْلیً لأُنَاسٍ أَعْتَقُوہُ سَائِبَۃً، فَقَالَ لِمَوَالِیہِ : ہَذَا مَالُ مَوْلاَکُمْ قَالُوا : لاَ حَاجَۃَ لَنَا بِہِ ، إنَّا کُنَّا أَعْتَقْنَاہُ سَائِبَۃً ، فَقَالَ ابْنُ مَسْعُودٍ : إنَّ فِی أَمْوَالِ الْمُسْلِمِینَ لَہُ مَوْضِعًا۔",,,32079
32080,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی عُثْمَانَ ، قَالَ : قَالَ عُمَرُ : السَّائِبَۃُ وَالصَّدَقَۃُ لِیَوْمِہِمَا۔",,,32080
32081,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ التَّیْمِیِّ ، عَنْ بَکْرِ بْنِ عَبْدِ اللہِ الْمُزَنِیّ : أَنَّ ابْنَ عُمَرَ أُتِیَ بِثَلاَثِینَ أَلْفًا ، قَالَ : أَحْسَبُہُ قَالَ : أَعْتَقْتہ سَائِبَۃً ، فَأَمَرَ أَنْ یُشْتَرَی بِہِ رِقَابٌ۔",,,32081
32082,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا زَکَرِیَّا ، عَنْ عَامِرٍ فِی رَجُلٍ أَعْتَقَ غُلاَمًا لَہُ سَائِبَۃً ، قَالَ : الْمِیرَاثُ لِمَوْلاَہُ۔",,,32082
32083,"حَدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَنْ یُونُسَ ، قَالَ : سُئِلَ الْحَسَنُ عَنْ مِیرَاثِ السَّائِبَۃِ ؟ فَقَالَ : کُلُّ عَتیقٍ سَائِبَۃٌ۔",,,32083
32084,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : لاَ أَعْلَمُ مِیرَاثَ السَّائِبَۃِ إلاَّ لِمَوَالِیہِ إلاَّ أَنَّ ۔۔۔",,,32084
32085,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنْ أَبِی عَمْرٍو الشَّیْبَانِیِّ ، قَالَ : قَالَ عَبْدُ اللہِ : السَّائِبَۃُ یَضَعُ مَالَہُ حَیْثُ شَائَ۔",,,32085
32086,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا بِسْطَامُ بْنُ مُسْلِمٍ ، عَنْ عَطَائِ بْنِ أَبِی رَبَاحٍ : أَنَّ طَارِقَ بْنِ الْمرقَّع أَعْتَقَ غُلاَمًا لَہُ لِلَّہِ ، فَمَاتَ وَتَرَکَ مَالا ، فَعُرِضَ عَلَی مَوْلاَہُ طَارِقٍ ، فَقَالَ : شَیْئٌ جَعَلْتہ لِلَّہِ ، فَلَسْت بِعَائِدٍ فِیہِ ، فَکُتِبَ فِی ذَلِکَ إلَی عُمَرَ ، فَکَتَبَ عُمَرُ : أَنِ اعْرِضُوا الْمَالَ عَلَی طَارِقٍ ، فَإِنْ قَبِلَہُ وَإِلاَّ فَاشْتَرَوْا بِہِ رَقِیقًا فَأَعْتِقُوہُمْ ، قَالَ : فَبَلَغَ خَمْسَۃَ عَشَرَ رَأْسًا۔",,,32086
32087,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنْ مُحَمَّدٍ : أَنَّ امْرَأَۃً مِنَ الأَنْصَارِ أَعْتَقَتْ سَالِمًا سَائِبَۃً ، ثُمَّ قَالَتْ لَہُ : وَالِ مَنْ شِئْت ، فَوَالَی أَبَا حُذَیْفَۃَ بْنَ عُتْبَۃَ ، فَأُصِیبَ یَوْمَ الْیَمَامَۃِ ، فَدُفِعَ مَالَہُ إلَی الَّتِی أَعْتَقَتْہُ۔",,,32087
32088,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عَلِیِّ بْنِ حُسَیْنٍ ، عَنْ عَمْرِو بْنِ عُثْمَانَ ، عَنْ أُسَامَۃَ بْنِ زَیْدٍ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَتَوَارَثُ الْمِلَّتَانِ الْمُخْتَلِفَتَانِ۔ \n\n(ابوداؤد 2903۔ احمد 178)",,,32088
32089,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ وَشُعْبَۃُ ، عَنْ قَیْسِ بْنِ مُسْلِمٍ ، عَنْ طَارِقِ بْنِ شِہَابٍ : أَنَّ الأَشْعَثَ بْنَ قَیْسٍ مَاتَتْ عَمَّۃٌ لَہُ مُشْرِکَۃٌ یَہُودِیَّۃٌ ، فَلَمْ یُوَرِّثْہُ عُمَرُ مِنْہَا ، وَقَالَ : یَرِثُہَا أَہْلُ دِینِہَا۔",,,32089
32090,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ اللہِ بْنِ مَعْقِلٍ : أَنَّ عَمَّۃً لِلأَشْعَثِ بْنِ قَیْسٍ مَاتَتْ وَہِیَ یَہُودِیَّۃٌ ، فَلَمْ یُوَرِّثْہُ عُمَرُ مِنْہَا شَیْئًا ، وَقَالَ : یَرِثُہَا أَہْلُ دِینِہَا۔",,,32090
32091,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إسْمَاعِیلُ بْنُ أَبِی خَالِدٍ ، عَنْ عَامِرٍ ، عَنْ عُمَرَ ، قَالَ : یَرِثُہَا أَہْلُ دِینِہَا ، کُلُّ مِلَّۃٍ تَتْبَعُ مِلَّتَہَا۔",,,32091
32092,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا جَعْفَرُ بْنُ بُرْقَانَ ، عَنْ مَیْمُونِ بْنِ مِہْرَانَ ، قَالَ : أَرْسَلَ إلَیَّ الْعُرْسُ بْنُ قَیْسٍ الْکِندِیُّ فَسَأَلَنِی عَنْ أَخَوَیْنِ نَصْرَانِیَّیْنِ أَسْلَمَ أَحَدُہُمَا وَمَاتَ الآخَرُ وَتَرَکَ مَالا ؟ فَقُلْتُ : کَانَ مُعَاوِیَۃُ یَقُولُ: لَوْ کَانَ نَصْرَانِیًّا وَرِثَہُ ، فَلَمْ یَزِدْہُ الإسْلاَمُ إلاَّ شِدَّۃً ، قَالَ الْعرسُ بْنُ قَیْسٍ : أبَی ذَلِکَ عَلَیْنَا عُمَرُ بْنُ الْخَطَّابِ فِی عَمَّۃِ الأَشْعَثِ بْنِ قَیْسٍ مَاتَتْ وَہِیَ یَہُودِیَّۃٌ فَلَمْ یُوَرِّثْہُ عُمَرُ مِنْہَا شَیْئًا۔",,,32092
32093,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ : قَالَ : لاَ یَرِثُ الْکَافِرُ الْمُسْلِمَ ، وَلاَ الْمُسْلِمُ الْکَافِرَ۔",,,32093
32094,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، مِثْلَہُ ، وَزَادَ فِیہِ : إلاَّ أَنْ یَکُونَ عَبْدًا لَہُ فَیَرِثُہُ۔",,,32094
32095,"حَدَّثَنَا عَبْدَۃُ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ ، عَنْ عُمَرَ : فِی یَہُودِیَّۃٍ مَاتَتْ ، قَالَ : یَرِثُہَا أَہْلُ دِینِہَا۔",,,32095
32096,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ، عَنْ بَسَّامٍ، عَنْ فُضَیْلٍ، عَنْ إبْرَاہِیمَ، قَالَ: لاَ یَرِثُ النَّصْرَانِیُّ الْمُسْلِمَ، وَلاَ الْمُسْلِمُ النَّصْرَانِی ، فَہَذَا قَوْلُ عَلِیٍّ وَزَیْدٍ ، وَأَمَّا عَبْدُ اللہِ بْنُ مَسْعُودٍ فَإِنَّہُ کَانَ یَقْضِی أَنَّہُمْ یَحْجُبُونَ وَلاَ یُوَرَّثُونَ۔",,,32096
32097,"حَدَّثَنَا حَفْصٌ، عَنْ دَاوُدَ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ، قَالَ: قَالَ عُمَرُ: لاَ یَرِثُ الْکَافِرُ الْمُسْلِمَ، وَلاَ الْمُسْلِمُ الْکَافِرَ۔",,,32097
32098,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : قَالَ عُمَرُ مِثْلَہُ۔",,,32098
32099,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنِ الزُّہْرِیِّ ، قَالَ : لاَ یَرِثُ الْمُسْلِمُ الْکَافِرَ ، وَلاَ الْکَافِرُ الْمُسْلِمَ عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَلاَ عَہْدِ أَبِی بَکْرٍ ، وَلاَ عَہْدِ عُمَرَ ، فَلَمَّا وُلِّیَ مُعَاوِیَۃُ وَرَّثَ الْمُسْلِمَ مِنَ الْکَافِرِ ، وَلَمْ یُوَرِّثَ الْکَافِرَ مِنَ الْمُسْلِمِ ، قَالَ : فَأَخَذَ بِذَلِکَ الْخُلَفَائُ حَتَّی قَامَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ ، فَرَاجَعَ السُّنَّۃَ الأُولَی ، ثُمَّ أَخَذَ بِذَلِکَ یَزِیدُ بْنُ عَبْدِ الْمَلِکِ ، فَلَمَّا قَامَ ہِشَام بْنُ عَبْدِ الْمَلِکِ أَخَذَ بِسُنَّۃِ الْخُلَفَائِ۔ (مسلم 1233)",,,32099
32100,"حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ أَشْعَثَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : لاَ یَرِثُ الرَّجُلُ غَیْرُ أَہْلِ مِلَّتِہِ إلاَّ أَنْ یَکُونَ عَبْدَ رَجُلٍ ، أَوْ أَمَتَہُ۔",,,32100
32101,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَمْرِو بْنِ أَبِی الحَکِیمٍ ، عَنْ عَبْدِ اللہِ بْنِ بُرَیْدَۃَ ، عَنْ یَحْیَی بْنِ یَعْمُرَ ، عَنْ أَبِی الأَسْوَدِ الدِّیَلِیِّ ، قَالَ : کَانَ مُعَاذٌ بِالْیُمْنِ فَارْتَفَعُوا إلَیْہِ فِی یَہُودِیٍّ مَاتَ أَخَاہُ مُسْلِماً ، فَقَالَ مُعَاذٌ : إنِّی سَمِعْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : إنَّ الإسْلاَمَ یَزِیدُ وَلاَ یَنْقُصُ فَوَرَّثَہُ۔\n\n(احمد 230۔ طبرانی 338)",,,32101
32102,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إسْمَاعِیلُ ، عَنِ الشَّعْبِیِّ ، عَنْ عَبْدِ اللہِ بْنِ مَعْقِلٍ ، قَالَ : مَا رَأِیْت قَضَائٌ بَعْدَ قَضَائِ أَصْحَابِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَحْسَنَ مِنْ قَضَائٍ قَضَی بِہِ مُعَاوِیَۃُ فِی أَہْلِ کِتَابٍ ، قَالَ : نَرِثُہُمْ وَلاَ یَرِثُونَنَا ، کَمَا یَحِلُّ لَنَا النِّکَاحُ فِیہِمْ ، وَلاَ یَحِلُّ لَہُمَ النِّکَاحُ فِینَا۔",,,32102
32103,"حَدَّثَنَا وَکِیعٌ ، قَالَ ، حَدَّثَنَا سُفْیَانُ ، عَنْ رَجُلٍ ، عَنِ الْحَسَنِ ، قَالَ : لاَ یَرِثُ الْیَہُودِیُّ ألنَّصْرَانِیَّ ، وَلاَ یَرِثُ النَّصْرَانِیُّ الْیَہُودِیَّ۔",,,32103
32104,"حَدَّثَنَا وَکِیعٌ ، قَالَ : قَالَ سُفْیَانُ : الإسْلاَمُ مِلَّۃٌ وَالشِّرْکُ مِلَّۃٌ۔",,,32104
32105,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ وَحَمَّادٍ ، قَالاَ : الإسْلاَمُ مِلَّۃٌ وَالشِّرْکُ مِلَّۃٌ۔",,,32105
32106,"حَدَّثَنَا الثَّقَفِیُّ، عَنْ خَالِدٍ، عَنْ مُحَمَّدِ بْنِ سِیرِینَ: فِی رَجُلٍ أَعْتَقَ عَبْدًا لَہُ نَصْرَانِیًّا ثُمَّ مَاتَ، قَالَ: لاَ یَرِثُہُ۔",,,32106
32107,"حَدَّثَنَا یَعْلَی ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی حَکِیمٍ : أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ أَعْتَقَ عَبْدًا لَہُ نَصْرَانِیًّا فَمَاتَ ، فَجَعَلَ مِیرَاثَہُ فِی بَیْتِ الْمَالِ۔",,,32107
32108,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ : أَنَّہُ کَانَ یَقُولُ : إذَا مَاتَ الصَّبِیُّ وَأَحَدُ أَبَوَیْہِ مُسْلِمٌ ، قَالَ : یَرِثُہُ الْمُسْلِمُ مِنْہُمَا ، دُونَ الْکََافِر مِنْہُمَا۔",,,32108
32109,حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ۔ وَعَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، مِثْلَ ذَلِکَ۔,,,32109
32110,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ وَحَمَّادًا عَنِ الصَّبِیِّ یَکُونُ أَحَدُ أَبَوَیْہِ مُسْلِمًا ؟ قَالاَ : ہُوَ مَعَ الْمُسْلِمِ ، یَرِثُ الْمُسْلِمَ وَیَرِثُہُ الْمُسْلِمُ۔",,,32110
32111,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عُثْمَانَ الْبَتِّیِّ ، عَنْ عَبْدِ الْحَمِیدِ بْنِ سَلَمَۃَ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ : أَنَّ أَبَوَیْہِ اخْتَصَمَا فِیہِ إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَحَدُہُمَا مُسْلِمٌ وَالآخَرُ کَافِرٌ ، فَخَیَّرَہُ ، فَمَالَ إلَی الْکَافِرِ ، فَقَالَ : اللَّہُمَّ اہْدِہِ ، فَتَوَجَّہَ إلَی الْمُسْلِمِ ، فَقَضَی لَہُ بِہِ۔",,,32111
32112,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، عَنْ عُمَرَ ، قَالَ : الْوَلَدُ مَعَ الْوَالِدِ الْمُسْلِمِ۔",,,32112
32113,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، عَنْ شُرَیْحٍ ، مِثْلَہُ۔,,,32113
32114,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، عَنْ شُرَیْحٍ ، قَالَ : ہُوَ لِلْوَالِدِ الْمُسْلِمِ۔",,,32114
32115,"حَدَّثَنَا أَبُو خَالِد، عَنْ حَجَّاجٍ، عَنْ عَطَائٍ وَالْحَسَنِ: فِی الْیَہُودِیِّ وَالنَّصْرَانِیِّ یُسْلِمُ : الْوَلَدُ مَعَ الْمُسْلِمِ۔",,,32115
32116,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ : أَنَّہُ قَالَ : إذَا مَاتَتْ یَہُودِیَّۃٌ أَوْ نَصْرَانِیَّۃٌ تَحْتَ مُسْلِمٍ لَہُ مِنْہَا أَوْلاَدٌ صِغَارٌ ، فَإِنَّ الْوَلَدَ مَعَ أَبِیہِمَ الْمُسْلِمِ ، فَإِنْ مَاتُوا وَہُمْ صِغَارٌ فَمِیرَاثُہُمْ لأَبِیہِمَ الْمُسْلِمِ ، لَیْسَ لأُمِّہِمْ مِنَ الْمِیرَاثِ شَیْئٌ مَا دَامُوا صِغَارًا۔",,,32116
32117,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ سِمَاکٍ ، عَنْ حَنَشٍ ، قَالَ : وَقَعَ رَجُلٌ عَلَی وَلِیدَۃٍ ، ثُمَّ بَاعَہَا مِنْ آخَرَ فَوَقَعَا عَلَیْہَا فَاجْتَمَعَا عَلَیْہَا فِی طُہْرٍ وَاحِدٍ ، فَوَلَدَتْ غُلاَمًا ، فَأَتَوْا عَلِیًّا ، فَقَالَ عَلِیٌّ : یَرِثُکُمَا وَلَیْسَ لأُمِّہِ ، وَہُوَ لِلْبَاقِی مِنْکُمَا بِمَنْزِلَۃِ أُمِّہِ۔",,,32117
32118,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنِ الشَّعْبِیِّ ، قَالَ : قضَی عَلِیٌّ فِی رَجُلَیْنِ وَطِئَا امْرَأَۃً فِی طُہْرٍ وَاحِدٍ ، فَوَلَدَتْ ، فَقَضَی أَنْ جَعَلَہُ بَیْنَہُمَا ، یَرِثُہُمَا وَیَرِثَانِہِ ، وَہُوَ لأَطْوَلِہِمَا حَیَاۃً۔",,,32118
32119,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنِ الشَّعْبِیِّ ، قَالَ : قضَی عُمَرُ فِیہِ بِقَوْلِ الْقَافَّۃِ۔",,,32119
32120,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : دَعَا عُمَرُ أَمَۃً فَسَأَلَہَا مِنْ أَیِّہِمَا ہُوَ؟ فَقَالَتْ : مَا أَدْرِی وَقَعَا عَلَیَّ فِی طُہْرٍ ، فَجَعَلَہُ عُمَرُ بَیْنَہُمَا۔",,,32120
32121,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الأَجْلَحِ ، عَنِ الشَّعْبِیِّ ، عَنْ عَبْدِ اللہِ بْنِ الْخَلِیلِ الْحَضْرَمِیِّ ، عَنْ زَیْدِ بْنِ أَرْقَمَ ، قَالَ : بَیْنَا نَحْنُ عِنْدَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذْ أَتَاہُ رَجُلٌ مِنَ الْیَمَنِ وَعَلِیٌّ بِہَا فَجَعَلَ یُحَدِّثُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَیُخْبِرُہُ ، قَالَ : یَا رَسُولَ اللہِ ، أَتَی عَلِیًّا ثَلاَثَۃُ نَفَرٍ فَاخْتَصَمُوا فِی وَلَدٍ کُلُّہُمْ زَعَمَ أَنَّہُ ابْنُہُ وَقَعُوا عَلَی امْرَأَۃٍ فِی طُہْرٍ وَاحِدٍ ، فَقَالَ عَلِیٌّ : إنَّکُمْ شُرَکَائُ مُتَشَاکِسُونَ ، وَإِنِّی مُقْرِعٌ بَیْنَکُمْ ، فَمَنْ قَرَعَ فَلَہُ الْوَلَدُ وَعَلَیْہِ ثُلُثَا الدِّیَۃِ لِصَاحِبَیْہِ ، قَالَ : فَأَقْرَعَ بَیْنَہُمْ فَقُرِعَ أَحَدُہُمْ ، فَدَفَعَ إلَیْہِ الْوَلَدَ وَجَعَلَ عَلَیْہِ ثُلُثَیَ الدِّیَۃِ ، فَضَحِکَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَتَّی بَدَتْ نَوَاجِذُہُ ، أَوْ أَضْرَاسُہُ۔",,,32121
32122,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ یَحْیَی بْنِ عَبْدِ الرَّحْمَنِ بْنِ حَاطِبٍ ، عَنْ أَبِیہِ : أَنَّ عُمَرَ قَضَی فِی رَجُلَیْنِ ادَّعَیَا رَجُلاً لاَ یُدْرَی أَیُّہُمَا أَبُوہُ ، فَقَالَ عُمَرُ لِلرَّجُلِ : اِتْبَعْ أَیَّہمَا شِئْت۔",,,32122
32123,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ، عَنْ دَاوُدَ، عَنِ الشَّعْبِیِّ، عَنْ شُرَیْحٍ، قَالَ: أَحْوَجُ مَا یَکُونُ إلَی مِیرَاثِہِ وَہُوَ أَسِیرٌ۔",,,32123
32124,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ ہِشَامٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدٍ ، قَالَ : یَرِثُ۔",,,32124
32125,"حَدَّثَنَا ابْنُ مَہْدِیٍّ، عَنْ ہِشَامٍ، عَنْ قَتَادَۃَ، عَنِ الْحَسَنِ: فِی مِیرَاثِ الأَسِیرِ، قَالَ: أَنَّہُ لِمُحْتَاجٍ إلَی مِیرَاثِہِ۔",,,32125
32126,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : یَرِثُ الأَسِیرُ۔",,,32126
32127,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَمَّنْ سَمِعَ إبْرَاہِیمَ یَقُولُ : لاَ یَرِثُ الأَسِیرُ۔",,,32127
32128,"حَدَّثَنَا خَالِدُ بْنُ الْحَارِثِ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ : فِی الأَسِیرِ فِی أَیْدِی الْعَدُ ، قَالَ : لاَ یَرِثُ۔",,,32128
32129,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا وُہَیْبٌ ، عَنْ دَاوُدَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ : أَنَّہُ کَانَ لاَ یُوَرِّثُ الأَسِیرَ۔",,,32129
32130,"حَدَّثَنَا مَعْن بْنُ عِیسَی ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : یُوَرَّثُ مَالُ الأَسِیرِ وَامْرَأَتُہُ۔",,,32130
32131,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ وَابْنِ سِیرِینَ ، قَالاَ : لاَ یُوَرَّثُ الْمَوْلُودُ حَتَّی یَسْتَہِلَّ۔",,,32131
32132,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَبْدِ اللہِ بْنِ شَرِیکٍ ، عَنْ بِشْرِ بْنِ غَالِبٍ ، قَالَ : سَأَلَ ابْنُ الزُّبَیْرِ الْحُسَیْنَ بْنَ عَلِیٍّ عَنِ الْمَوْلُودِ ؟ فَقَالَ : إذَا اسْتَہَلَّ وَجَبَ عَطَاؤُہُ وَرِزْقُہُ۔",,,32132
32133,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ عَبْدِ اللہِ بْنِ شَرِیکٍ ، عَنْ بِشْرِ بْنِ غَالِبٍ ، قَالَ : لَقِیَ ابْنُ الزُّبَیْرِ الْحُسَیْنَ بْنَ عَلِیٍّ ، فَقَالَ : یَا أَبَا عَبْدِ اللہِ ، أَفْتِنَا فِی الْمَوْلُودِ یُولَدُ فِی الإسْلاَمِ ، قَالَ : وَجَبَ عَطَاء ہُ وَرِزْقُہُ۔",,,32133
32134,"حَدَّثَنَا أَسْبَاطٌ بْنُ مُحَمَّدٍ ، عَنْ أَشْعَثَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ، قَالَ: إذَا اسْتَہَلَّ الصَّبِیُّ صُلِّیَ عَلَیْہِ، وَوَرِثَ ، وَإِذَا لَمْ یَسْتَہِلَّ لَمْ یُوَرَّثْ وَلَمْ یُصَلَّ عَلَیْہِ۔",,,32134
32135,"حَدَّثَنَا أَسْبَاطُ ، عَنْ مُطَرِّفٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : إذَا اسْتَہَلَّ الصَّبِیُّ صُلِّیَ عَلَیْہِ وَوَرِثَ ، وَإِذَا لَمْ یَسْتَہِلَّ لَمْ یُصَلَّ عَلَیْہِ وَلَمْ یُوَرَّثْ۔",,,32135
32136,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا اسْتَہَلَّ تَمَّ عَقْلُہُ وَمِیرَاثُہُ۔",,,32136
32137,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ : أَنَّہُ قَالَ فِی الْمَوْلُودِ : لاَ یُصَلَّی عَلَیْہِ ، وَلاَ یُوَرَّثُ ، وَلاَ تَکْمُلُ فِیہِ الدِّیَۃُ حَتَّی یَسْتَہِلَّ۔",,,32137
32138,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ : فِی الْمَرْأَۃِ تَلِدُ وَلَمْ یَسْتَہِلَّ ؟ قَالَ : إذَا تَحَرَّکَ فَعُلِمَ أَنَّ حَرَکَتَہُ مِنْ حَیَاۃٍ وَلَیْسَتْ مِنَ اخْتِلاَجٍ وَرِثَ ، وَإِنْ کَانَ إنَّمَا حَرَکَتُہُ مِنَ اخْتِلاَجٍ وَلَیْسَتْ مِنْ حَیَاۃٍ لَمْ یُوَرَّثْ۔",,,32138
32139,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الْعَلاَئِ بْنِ الْمُسَیَّبِ ، عَنْ أَبِیہِ ، قَالَ : لاَ یُصَلَّی عَلَی السِّقْطِ ، وَلاَ یُوَرَّثُ۔",,,32139
32140,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شَرِیکٌ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إذَا اسْتَہَلَّ الصَّبِیُّ وَرِثَ وَوُرِثَ وَصُلِّیَ عَلَیْہِ۔",,,32140
32141,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُلَیْمَانَ بْنِ بِلاَلٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنِ الْقَاسِمِ ، قَالَ : لاَ یُوَرَّثُ الْمَوْلُودُ حَتَّی یَسْتَہِلَّ۔",,,32141
32142,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : وَلَدَتِ امْرَأَۃٌ وَلَدًا فَشَہِدْنَ نِسْوَۃٌ : أَنَّہُ اخْتَلَجَ وَوُلِدَ حَیًّا ، وَلَمْ یَشْہَدْنَ عَلَی اسْتِہْلاَلِہِ ، فَقَالَ شُرَیْحٌ : الْحَیُّ یَرِثُ الْمَیِّتَ ، ثُمَّ أَبْطَلَ مِیرَاثَہُ لأَنَّہُنَّ لَمْ یَشْہَدْنَ عَلَی اسْتِہْلاَلِہِ۔",,,32142
32143,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : الاِسْتِہْلاَلُ : الصِّیَاحُ۔",,,32143
32144,"حَدَّثَنَا وَکِیعٌ ، قَالَ: حدَّثَنَا إسْرَائِیلُ ، عَنْ سِمَاکٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ: اسْتِہْلاَلُ الصَّبِیِّ: صِیَاحُہُ۔",,,32144
32145,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُلَیْمَانَ بْنِ بِلاَلٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، قَالَ الْقَاسِمُ بْنُ مُحَمَّدٍ : الاِسْتِہْلاَلُ : النِّدَائُ وَالْعُطَاسُ۔",,,32145
32146,"حَدَّثَنَا مَعْن بْنُ عِیسَی ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : أَرَی : الْعُطَاسَ : الاِسْتِہْلاَل۔",,,32146
32147,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ أَبِی ہُرَیْرَۃَ : أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : مَا مِنْ مَوْلُودٍ وُلِدَ إلاَّ نَخَسَہُ الشَّیْطَانُ فَیَسْتَہِلُّ صَارِخًا مِنْ نَخْسَۃِ الشَّیْطَانِ إلاَّ ابْنَ مَرْیَمَ وَأُمَّہُ۔ (مسلم 1838۔ عبدالرزاق 119)",,,32147
32148,"حَدَّثَنَا الْمُحَارِبِیُّ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ : فِی الإِخْوَۃِ یَدَّعِی أَحَدُہُمَ الأَخَ ، وَیُنْکِرُہُ الآخَرُونَ ، قَالَ : یَدْخُلُ مَعَہُمْ بِمَنْزِلَۃِ العَبْدٍ یَکُونُ بَیْنَ الإِخْوَۃِ فَیَعْتِقُ أَحَدُہُمْ نَصِیبَہُ۔\n\nقَالَ : وَکَانَ عَامِرٌ وَالْحَکَمُ وَأَصْحَابُہُمَا یَقُولُونَ : لاَ یَدْخُلُ إلاَّ فِی نَصِیبِ الَّذِی اعْتَرَفَ بِہِ۔",,,32148
32149,"حَدَّثَنَا ابْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی بَعْضُ أَہْلِ صَنْعَائَ : أَنَّ طَاوُوسًا قَضَی فِی بَنِی أَبٍ أَرْبَعَۃٍ شَہِدَ أَحَدُہُمْ أَنَّ أَبَاہُ اسْتَلْحَقَ عَبْدًا کَانَ بَیْنَہُمْ ، فَلَمْ یُجِزْ طَاوُوس الْحَاقَہُ بِالنَّسَبِ ، وَلَکِنَّہُ أَعْطَی الْعَبْدَ خُمُسَ الْمِیرَاثِ فِی مَالِ الَّذِی شَہِدَ أَنَّ أَبَاہُ اسْتَلْحَقَہُ ، وَأُعْتِقَ الْعَبْدُ فِی مَالِ الَّذِی شَہِدَ۔",,,32149
32150,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَنْ شَرِیکٍ ، عَنْ خَالِدٍ ، عَنِ ابْنِ سِیرِینَ ، عَنْ شُرَیْحٍ : فِی رَجُلٍ أَقَرَّ بِأَخٍ ، قَالَ : بَیِّنَتُہُ أَنَّہُ أَخُوہُ۔",,,32150
32151,"حدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا أَبُو عَوَانَۃَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ : فِی الرَّجُلِ یَدَّعِی أَخًا أَوْ أُخْتًا ، قَالَ : لَیْسَ بِشَیْئٍ حَتَّی یُقِرُّوا جَمِیعًا۔",,,32151
32152,"حَدَّثَنَا وَکِیعٌ ، قَالَ : إذَا کَانَا أَخَوَیْنِ فَادَّعَی أَحَدُہُمَا أَخًا وَأَنْکَرَہُ الآخَرُ ، قَالَ : کَانَ ابْنُ أَبِی لَیْلَی یَقُولُ: ہِیَ مِنْ سِتَّۃٍ : لِلَّذِی لَمْ یَدَّعِ ثَلاَثَۃٌ ، وَلِلْمُدَّعِی سَہْمَانِ ، وَلِلْمُدَّعَی سَہْمٌ۔\n\nقَالَ: وَقَالَ أَبُو حَنِیفَۃَ : ہِیَ مِنْ أَرْبَعَۃٍ : لِلَّذِی لَمْ یَدَّعِ سَہْمَانِ ، وَلِلْمُدَّعِی سَہْمٌ ، وَلِلْمُدَّعَی سَہْمٌ۔",,,32152
32153,"حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ : فِی أَمَۃٍ وَلَدَتْ ثَلاَثَۃَ أَوْلاَدٍ فَادَّعَی مَوْلاَہَا الأَوَّلَ وَالأَوْسَطَ ، وَنَفَی الآخِرَ ؟ قَالَ : ہُوَ کَمَا قَالَ۔",,,32153
32154,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ : فِی الرَّجُلِ یُولَدُ لَہُ الْوَلَدَانِ فَیَنْفِی أَحَدَہُمَا قَالَ : یُقِرُّ بِہِمَا جَمِیعًا ، أَوْ یَنْفِیہِمَا جَمِیعًا۔",,,32154
32155,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلِیٍّ وَعُمَرَ وَزَیْدٍ : أَنَّہُمْ کَانُوا لاَ یُوَرِّثُونَ النِّسَائَ مِنَ الْوَلاَئِ ، إلاَّ مَا أَعْتَقْنَ۔",,,32155
32156,"حَدَّثَنَا عَبَّادُ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : لاَ یَرِثُ النِّسَائُ مِنَ الْوَلاَئِ إلاَّ مَا أَعْتَقْنَ أَوْ کَاتَبْنَ۔",,,32156
32157,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ جَہْمٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لاَ یَرِثُ النِّسَائُ مِنَ الْوَلاَئِ ، إلاَّ مَا کَاتَبْنَ أَوْ أَعْتَقْنَ ، أَوْ أَعْتَقْ مَنْ أَعْتَقْنَ۔",,,32157
32158,"حَدَّثَنَا مُعَاذٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ : أَنَّہُ قَالَ : لاَ یَرِثُ النِّسَائُ مِنَ الْوَلاَئِ إلاَّ مَا أَعْتَقْنَ ، أَوْ أُعْتِقَ مَنْ أَعْتَقْنَ ، إلاَّ الْمُلاعَنَۃ فَإِنَّہَا تَرِثُ ابْنُہَا الَّذِی انْتَفَی مِنْہُ أَبُوہُ۔",,,32158
32159,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ رَجُلٍ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : لاَ یَرِثُ النِّسَائُ مِنَ الْوَلاَئِ إلاَّ مَا کَاتَبْنَ ، أَوْ أَعْتَقْنَ۔",,,32159
32160,"حَدَّثَنَا ابْنِ أَبِی غَنِیَّۃَ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : لاَ یَرِثُ النِّسَائُ مِنَ الْوَلاَئِ شَیْئًا إلاَّ مَا کَاتَبْنَ ، أَوْ أَعْتَقْنَ۔",,,32160
32161,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ ، عَنْ أَبِی قِلاَبَۃَ : فِی امْرَأَۃٍ تُوُفِّیَتْ وَتَرَکَتْ مَوْلاَہَا ، قَالَ : ہُوَ مَوْلاَہَا إذَا مَاتَ یَرِثُہُ مَنْ یَرِثُہَا مِنَ الذُّکُورِ۔",,,32161
32162,"حَدَّثَنَا عُمَرُ بْنُ ہَارُونَ ، عَنْ یُونُسَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : لاَ یَرِثُ النِّسَائُ مِنَ الْوَلاَئِ ، إلاَّ مَا أَعْتَقْنَ ، أَوْ کَاتَبْنَ۔",,,32162
32163,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ یَرِثُ النِّسَائُ مِنَ الْوَلاَئِ ، إلاَّ مَا أَعْتَقْنَ۔",,,32163
32164,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : فِی الرَّجُلِ یُکَاتِبُ عَبْدَہُ ، ثُمَّ یَمُوتُ وَیَدَعُ وَلَدًا : رِجَالاً وَنِسَائً ، قَالَ : الْمَالُ بَیْنَہُمْ بِالْحِصَصِ ، وَالْوَلاَئُ لِلرِّجَالِ دُونَ النِّسَائِ۔",,,32164
32165,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا سُفْیَانُ ، عَنْ رَجُلٍ لَمْ یَکُنْ یُسَمِّیہِ ، عَنْ أَبِی سَلَمَۃَ وَ سَعِیدِ بْنِ الْمُسَیَّبِ : فِی الرَّجُلِ یُکَاتِبُ عَبْدَہُ ثُمَّ یَمُوتُ وَیَدَعُ وَلَدًا : رِجَالاً وَنِسَائً ، قَالَ : الْمَالُ بَیْنَہُمْ بِالْحِصَصِ ، وَالْوَلاَئُ لِلرَّجُلِ دُونَ النِّسَائِ۔ (دارمی 3144۔ بیہقی 10)",,,32165
32166,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ : أَنَّ امْرَأَۃً أَعْتَقَتْ سَالِمًا فَوَالی أَبَا حُذَیْفَۃَ وَتَبَنَّاہُ ، فَمَاتَ فَدُفِعَ مِیرَاثُہُ إلَیْہَا۔",,,32166
32167,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنْ جَہْمٍ ، عَنْ إبْرَاہِیمَ : فِی امْرَأَۃٍ اشْتَرَتْ أَبَاہَا فَأَعْتَقَتْہُ فَمَاتَ وَلَہَا أُخْتٌ ، قَالَ : لَہُمَا الثُّلُثَانِ فِی کِتَابِ اللہِ ، وَلَہَا الثُّلُثُ الْبَاقِی لأَنَّہَا عَصَبَتُہُ۔قَالَ أَبُو بَکْرٍ : وَہُوَعِنْدِی الْقَوْلُ۔",,,32167
32168,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ، عَنْ حَمَّادِ بْنِ الْجَعْدِ، عَنْ قَتَادَۃَ: أَنَّ امْرَأَۃً أَعْتَقَتْ مَمْلُوکًا لَہَا ثُمَّ مَاتَ لِمَنْ یَکُونُ، وَلاَؤُہُ لِعَصَبَتِہَا، أَوْ لِعَصَبَۃِ ابْنِہَا؟ قَالَ: کَانَ الْحَسَنُ وَسَعِیدُ بْنُ الْمُسَیَّبِ یَقُولاَنِ: ہُوَ لِعَصَبَۃِ الْغُلاَمِ۔\n\nقَالَ قَتَادَۃُ : وَحَدَّثَنِی خِلاَس أَنَّ عَلِیًّا جَعَلَہُ لِعَصَبَۃِ الْغُلاَمِ۔\n\nقَالَ : وَحَدَّثَنَا صَالِحُ بْنُ الْخَلِیلِ ، أَنَّ ابْنَ عَبَّاسٍ قَالَ ذَلِکَ۔",,,32168
32169,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ إسْمَاعِیلَ بْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : سَمِعْتُہُ یَقُولُ : وَلَدُ الْمَرْأَۃِ الذَّکَرُ أَحَقُّ بِمِیرَاثِ مَوَالِیہَا مِنْ عَصَبَتِہَا ، وَإِنْ کَانَت جِنَایَۃً فَعَلَی عَصَبَتِہَا۔",,,32169
32170,"حَدَّثَنَا حُمَیْدٌ ، عَنْ حَسَنٍ ، عَنْ فِرَاسٍ ، عَنِ الشَّعْبِیِّ ، عَنْ شُرَیْحٍ : فِی امْرَأَۃٍ أَعْتَقَتْ رَجُلاً ثُمَّ مَاتَتْ ، قَالَ : الْوَلاَئُ لِوَلَدِہَا وَالْعَقْلُ عَلَیْہِمْ ، قَالَ : وَکَانَ عَامِرٌ یَقُولُ : الْوَلاَئُ لِوَلَدِہَا وَالْعَقْلُ عَلَیْہِمْ۔",,,32170
32171,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ حُسَیْنٍ الْمُعَلِّمِ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، قَالَ : تَزَوَّجَ رِئَابُ بْنُ حُذَیْفَۃَ بْنِ سَعِیدِ بْنِ سَہْمٍ أَمَّ وَائِلِ ابْنَۃَ مَعْمَرٍ الْجُمَحِیَّۃَ ، فَوَلَدَتْ لَہُ ثَلاَثَۃً ، فَتُوُفِّیَتْ أُمُّہُمْ ، فَوَرِثَہَا بَنُوہَا رِبَاعَہَا وَوَلاَئَ مَوَالِیہَا ، فَخَرَجَ بِہِمْ عَمْرُو بْنُ الْعَاصِ مَعَہ إلَی الشَّامِ ، فَمَاتُوا فِی طَاعُونٍ عَمَوَاسَ ، قَالَ : فَوَرِثَہُمْ عَمْرٌو ، وَکَانَ عَصَبَتُہُمْ ، فَلَمَّا رَجَعَ عَمْرٌو جَائَ بَنُو مَعْمَرٍ فَخَاصَمُوہُ فِی وَلاَئِ أُخْتِہِمْ إلَی عُمَرَ بْنِ الْخَطَّابِ ، فَقَالَ عُمَرُ : أَقْضِی بَیْنَکُمْ بِمَا سَمِعْت مِنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، سَمِعْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : مَا أَحْرَزَ الْوَلَدُ ، أَو الْوَالِدُ فَہُوَ لِعَصَبَتِہِ مَنْ کَانَ ، قَالَ : فَقَضَی لَنَا بِہِ ، وَکَتَبَ لَنَا کِتَابًا فِیہِ شَہَادَۃُ عَبْدِ الرَّحْمَنِ بْنِ عَوْفٍ وَزَیْدِ بْنِ ثَابِتٍ وَآخَرَ۔\n\nحَتَّی إذَا اسْتُخْلِفَ عَبْدُ الْمَلِکِ بْنُ مَرْوَانَ تُوفِّیَ مَوْلًی لَہَا وَتَرَک أَلْفَیْ دِینَارٍ فَبَلَغَنِی أَنَّ ذَلِکَ الْقَضَائَ قَدْ غُیِّرَ، فَخَاصَمُوہُ إلَی ہِشَامِ بْنِ إسْمَاعِیلَ ، فَرَفَعَنَا إلَی عَبْدِ الْمَلِکِ فَأَتَیْنَاہُ بِکِتَابِ عُمَرَ ، فَقَالَ : إنْ کُنْت لاَرَی ہَذَا مِنَ الْقَضَائِ الَّذِی لاَ یُشَکُّ فِیہِ ، وَمَا کُنْت أَرَی أَنَّ أَمْرَ أَہْلِ الْمَدِینَۃِ بَلَغَ ہَذَا أَنْ یَشُکُّوا فِی ہَذَا الْقَضَائِ ، فَقَضَی لَنَا فِیہِ ، فَلَمْ نَزَلْ فِیہِ بَعْدُ۔ (نسائی 6349۔ احمد 27)",,,32171
32172,"حَدَّثَنَا یَحْیَی بْنُ أَزْہَرَ ، قَالَ : حدَّثَنَا مِنْدَلٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : قَالَ عَلِیٌّ فِی الْمَرْأَۃٍ تَعْتِقُ الرَّجُلَ : الْوَلاَئُ لِوَلَدِہَا وَوَلَدِ وَلَدِہَا مَا بَقِیَ مِنْہُمْ ذَکَرٌ ، فَإِنِ انْقَرَضُوا رَجَعَ إلَی عَصَبَتِہَا۔",,,32172
32173,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ شُرَیْحٍ وَزَیْدِ بْنِ ثَابِتٍ : فِی رَجُلٍ مَاتَ وَتَرَکَ ابْنَہُ وَأَبَاہُ وَمَوْلاَہُ ، ثُمَّ مَاتَ الْمَوْلَی وَتَرَکَ مَالاً ، فَقَالَ شُرَیْحٌ : لأَبِیہِ السُّدُسُ ، وَمَا بَقِیَ فَلِلاِبْنِ۔\n\nوَقَالَ زَیْدُ بْنُ ثَابِتٍ : الْمَالُ لِلاِبْنِ ، وَلَیْسَ لِلأَبِ شَیْئٌ۔",,,32173
32174,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : سَأَلْتُہ عَنْ رَجُلٍ أَعْتَقَ مَمْلُوکًا لَہُ فَمَاتَ وَمَاتَ الْمَوْلَی وَتَرَکَ الَّذِی أَعْتَقَہُ أَبَاہُ وَابْنَہُ ، فَقَالَ إبْرَاہِیمُ : لأَبِیہِ السُّدُسُ ، وَمَا بَقِیَ فَہُوَ لاِبْنِہِ۔",,,32174
32175,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مَنْصُورٍ ، عَنِ الْحَسَنِ ، قَالَ : ہُوَ لِلاِبْنِ۔",,,32175
32176,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُحَمَّدِ بْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ : أَنَّہُ کَانَ یَقُولُ ذَلِکَ۔",,,32176
32177,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَمِعْتُ الْحَکَمَ وَحَمَّادًا یَقُولاَنِ : ہُوَ لِلاِبْنِ۔",,,32177
32178,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، قَالَ : سَأَلْتُ الْحَکَمَ وَحَمَّادًا وَأَبَا إِیَاسَ مُعَاوِیَۃَ بْنِ قُرَّۃَ عَنِ امْرَأَۃٍ أَعْتَقَتْ غُلاَمًا لَہَا ثُمَّ مَاتَتْ وَتَرَکَتْ أَبَاہَا وَابْنَہَا ، فَقَالُوا : الْوَلاَئُ لِلاِبْنِ ، وَقَالَ أَبُو إیَاسٌ : الْوَلاَئُ لِوَلَدِہَا مَا بَقِیَ مِنْہُمْ۔",,,32178
32179,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : الْوَلاَئُ لِلاِبْنِ۔",,,32179
32180,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، قَالَ : بَلَغَنِی عَنْ زَیْدِ بْنِ ثَابِتٍ ، أَنَّہُ قَالَ : الْوَلاَئُ لِلاِبْنِ۔",,,32180
32181,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ حَمَّادٍ ، قَالَ : الْوَلاَئُ لِلاِبْنِ۔\n\nوَہُوَ قَوْلُ سُفْیَانَ۔",,,32181
32182,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ أَبِی مَعْشَرٍ ، قَالَ : کَانَ إبْرَاہِیمُ یَقُولُ : لِلأَبِ سُدُسُ الْوَلاَئِ وَلِلاِبْنِ خَمْسَۃُ أَسْدَاسِ الْوَلاَئِ۔ قَالَ شُعْبَۃُ : قُلْتُ لأَبِی مَعْشَرٍ : أَسَمِعْتہ مِنْ إبْرَاہِیمَ یَقُولُہُ ، قَالَ : سَمِعْتُہُ ، وَقَالَ مُغِیرَۃُ : سَمِعْتہ مِنْ إبْرَاہِیمَ یَقُولُہُ۔",,,32182
32183,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ، عَنْ شُرَیْحٍ : أَنَّہُ کَانَ یَقُولُ : الْوَلاَئُ بِمَنْزِلَۃِ الْمَالِ۔",,,32183
32184,"حَدَّثَنَا وَکِیعٌ ، قَالَ: حدَّثَنَا أَبُو عَاصِمٍ ، عَنِ الشَّعْبِیِّ ، عَنْ شُرَیْحٍ: أَنَّہُ کَانَ یُجْرِی الْوَلاَئَ مُجْرَی الْمَالِ۔",,,32184
32185,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ فِی رَجُلٍ مَاتَ وَتَرَکَ مَوْلًی لَہُ وَجَدَّہُ وَأَخَاہُ لِمَنْ وَلاَئُ مَوْلاَہُ ؟ قَالَ عَطَائٌ : الْوَلاَئُ بَیْنَہُمَا نِصْفَیْنِ۔",,,32185
32186,"حَدَّثَنَا وَکِیعٌ ، قَالَ : قَالَ سُفْیَانُ : بَلَغَنِی عَنِ الزُّہْرِیِّ أَنَّہُ قَالَ : الْوَلاَئُ لِلْجَدِّ۔",,,32186
32187,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ : فِی رَجُلٍ تَرَکَ جَدَّہُ وَأَخَاہُ ، قَالَ : الْوَلاَئُ لِلْجَدِّ لأَنَّہُ یُنْسَبُ إلَی الْجَدِّ ، وَلاَ یُنْسَبُ إلَی الأَخِ۔",,,32187
32188,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ وَالأَعْمَشُ ، عَنْ إِبْرَاہِیمَ ، عَن عُمَرَ : فِی الْمَمْلُوکِ تَزَوَّجَ الْحُرَّۃَ فَتَلِدُ لَہُ أَوْلاَدًا فَیُعْتقُ ، قَالَ : یُلْحَقُ بِہِ وَلاَئُ وَلَدِہِ۔",,,32188
32189,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ إبْرَاہِیمَ ، قَالَ الأَعْمَشُ : أَرَاہُ عَنِ الأَسْوَدِ ، قَالَ عُمَرُ : إذَا کَانَتِ الْحُرَّۃُ تَحْتَ الْمَمْلُوکِ فَوَلَدَتْ ، فَوَلاَئُ وَلَدِہَا لِمَوَالِی الأُمِ ، فَإِذَا أُعْتِقَ الأَبُ جَرَّ الْوَلاَئَ۔",,,32189
32190,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، عَنْ عُمَرَ وَعَلِیٍّ وَعَبْدِ اللہِ وَزَیْدٍ کَانُوا یَقُولُونَ : إذَا لَحِقَتْہُ الْعَتَاقَۃُ وَلَہُ أَوْلاَدٌ مِنْ حُرَّۃٍ جَرَّ وَلاَئَہُمْ ، فَقُلْتُ لِلشَّعْبِیِّ : فَالْجَدُّ ، قَالَ : الْجَدُّ یَجُرُّ کَمَا یَجُرُّ الأَبُ۔",,,32190
32191,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ حَجَّاجٍ ، عَنِ الشَّعْبِیِّ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : یَرْجِعُ الْوَلاَئُ إلَی مَوَالِی الأَبِ إذَا أُعْتِقَ ، وَحَدَّثَ أَنَّ عُمَرَ وَعُثْمَانَ قَضَیَا بِہِ ، وَأَنَّ شُرَیْحًا لَمْ یَقْضِ بِہِ ، ثُمَّ قَضَی بِہِ۔",,,32191
32192,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ہِشَامُ بْنُ عُرْوَۃَ ، عَنْ أَبِیہِ : أَنَّ مُکَاتَبًا لِلزُّبَیْرِ تَزَوَّجَ أُمَّ وَلَدٍ لِرَافِعِ بْنِ خَدِیجٍ، قَالَ : فَوَلَدَتْ أَوْلاَدًا ، ثُمَّ أُعْتِقَ ، فَاخْتَصَمَ الزُّبَیْرُ وَرَافِعٌ فِی ، وَلاَئِہِمْ إلَی عُثْمَانَ فَقَضَی بِالْوَلاَئِ لِلزُّبَیْرِ۔",,,32192
32193,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ حُمَیْدٍ الأَعْرَجِ ، عَنْ مُحَمَّدِ بْنِ إبْرَاہِیمَ التَّیْمِیِّ : أَنَّ عُثْمَانَ بْنَ عَفَّانَ قَضَی بِالْوَلاَئِ لِلزُّبَیْرِ۔",,,32193
32194,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ جَابِرٍ ، عَنِ الشَّعْبِیِّ ، عَنِ الأَسْوَدِ ، عَنْ عَبْدِ اللہِ ، قَالَ : إذَا أُعْتِقَ الأَبُ جَرَّ الْوَلاَئَ۔",,,32194
32195,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا أَبَانُ بْنُ صَمْعَۃَ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إِذَا تَزَوَّجَ الْمَمْلُوکُ الْحُرَّۃَ ، فما جری فِی الرَّحِمِ فَوَلاَؤُہُ لِمَوَالِی الأُمِّ ، فَإِذَا أُعْتِقَ الأَبُ جَرَّ الْوَلاَئَ۔",,,32195
32196,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إسْرَائِیلُ ، عَنْ جَابِرٍ ، عَنْ رَجُلٍ مِنَ الأَنْصَارِ یُقَالَ لَہُ : إبْرَاہِیمُ ، عَنْ عَلِیٍّ ، قَالَ : إذَا أُعْتِقَ الأَبُ جَرَّ الْوَلاَئَ۔",,,32196
32197,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إسْرَائِیلُ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، عَنْ شُرَیْحٍ : أَنَّہُ کَانَ لاَ یَقْضِی بِجَرِّ الْوَلاَئِ حَتَّی حَدَّثَہُ الأَسْوَدُ ، عَنْ عَبْدِ اللہِ أَنَّہُ قَضَی بِہِ ، فَقَضَی شُرَیْحٌ۔",,,32197
32198,"حَدَّثَنَا عَبْدُ الأَعْلَی، عَنْ دَاوُدَ، عَنْ عِکْرِمَۃَ بْنِ خَالِدٍ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ: یَجُرُّ وَلاَئَ وَلَدِہِ۔",,,32198
32199,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنْ مُحَمَّدٍ ، قَالَ : یَجُرُّ وَلاَئَ وَلَدِہِ۔",,,32199
32200,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : یَرْجِعُ الْوَلاَئُ إلَی مَوَالِی الأَبِ إذَا أُعْتِقَ۔",,,32200
32201,"حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدٍ وَخِلاَسٍ : أَنَّہُمَا قَالاَ : إذَا تَزَوَّجَ الْمَمْلُوکُ الْحُرَّۃَ فَوَلَدَتْ أَوْلاَدًا ، ثُمَّ أُعْتِقَ فَإِنَّہُ یَجُرُّ الْوَلاَئَ۔",,,32201
32202,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا سُفْیَانُ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی السَّفَرِ ، عَنِ الشَّعْبِیِّ ، قَالَ: الْجَدُّ یَجُرُّ الْوَلاَئَ۔",,,32202
32203,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ قَیْسِ بْنِ سَعْدٍ ، عَنْ مُجَاہِدٍ۔ وَعَنْ قَتَادَۃَ ، عَنْ حُمَیْدِ بْنِ عَبْدِ الرَّحْمَنِ ، وَعِکْرِمَۃَ بْنِ خَالِدٍ ، عَنْ یَزِیدَ بْنِ عَبْدِ الْمَلِکِ ، قَالاَ : مَا وَلَدَتْ وَہُوَ مَمْلُوکٌ فَالْوَلاَئُ لِمَوَالِی الأُمِ ، وَمَا وَلَدَتْ وَہُوَ حُرٌّ فَالْوَلاَئُ لِمَوَالِی الأَبِ۔",,,32203
32204,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ : أَنَّہُ کَانَ یَقُولُ : لاَ یَجُرُّ الْوَلاَئَ ، إلاَّ مَا وَلَدَتْ وَہُوَ حُرٌّ۔",,,32204
32205,"حَدَّثَنَا عَبْدُ الْوَہَّابِ بْنُ عَطَائٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : رَجُلٌ تَزَوَّجَ حرَّۃً فَوَلَدَتْ ، ثُمَّ عُتِقَ الْعَبْدُ ، لِمَنْ وَلاَئُ وَلَدِہِ ؟ قَالَ : وَلاَئُ وَلَدِہِ لأَہْلِ أُمِّہِمْ۔",,,32205
32206,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنِ الْحَسَنِ کَانَ یَقُولُ : إذَا أُعْتِقَ الرَّجُلُ وَأَعْتَقَ ابْنَہُ رَجُلٌ آخَرُ جَرَّ ، وَلاَئَ أَبِیہِ فَأَتَاہُ مُحَمَّدُ بْنُ سِیرِینَ ، فَقَالَ : عُمَرُ یَقُولُ ہَذَا ؟ قَالَ : نَحْنُ نَقُولُہُ۔",,,32206
32207,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ : فِی رَجُلٍ أَعْتَقَہُ قَوْمٌ وَأَعْتَقَ أَبَاہُ آخَرُونَ ، قَالَ : یَتَوَارَثَانِ بِالأَرْحَامِ وَجِنَایَتُہُمَا عَلَی عَاقِلَۃِ مَوَالِیہِمَا۔",,,32207
32208,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ قَالَ : اخْتَصَمَ عَلِیٌّ وَالزُّبَیْرُ فِی مَوْلًی لِصَفِیَّۃَ إلَی عُمَرَ فَقَضَی عُمَرُ بِالْمِیرَاثِ لِلزُّبَیْرِ وَالْعَقْلِ عَلَی عَلِیٍّ۔",,,32208
32209,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ أَبِی وَائِلٍ ، قَالَ : کَتَبَ عُمَرُ إلَی عَبْدِ اللہِ : إذَا کَانَ أَحَدُ الْعَصَبَۃِ أَقْرَبَ بِأُمٍّ فَأَعْطِہِ الْمَالَ۔",,,32209
32210,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : قَضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِالدَّیْنِ قَبْلَ الْوَصِیَّۃِ ، وَأَنْتُمْ تَقْرَؤُونَ : (مِنْ بَعْدِ وَصِیَّۃٍ یُوصَی بِہَا ، أَوْ دَیْنٍ) وَأَنَّ أَعْیَانَ بَنِی الأُمِّ یَتَوَارَثُونَ دُونَ بَنِی الْعَلاَتِ : الإِخْوَۃُ مِنَ الأَبِ وَالأُمِّ دُونَ الإِخْوَۃِ مِنَ الأَبِ۔",,,32210
32211,"حَدَّثَنَا وَکِیعٌ ، قَالَ : مَالِکُ بْنُ مِغْوَلٍ ، قَالَ : سَأَلْت الشَّعْبِیَّ ، عَنْ بَنِی عَمٍّ لأَبٍ وَأَمٍّ إلَی ثَلاَثَۃٍ ؟ وَعَنْ بَنِی عَمٍّ لأَبٍ إلَی اثْنَیْنِ ؟ فَقَالَ الشَّعْبِیُّ : الْمَالُ لِبَنِی الْعَلاَتِ۔",,,32211
32212,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : قَالَ عُمَرُ : إذَا کَانَتِ الْعَصَبَۃُ أَحَدُہُمْ أَقْرَبَ بِأُمٍّ ، فَالْمَالُ لَہُ فِی الْوَلاَئِ۔",,,32212
32213,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ : أَنَّ عَلِیًّا وَعَبْدَ اللہِ وَزَیْدًا ، قَالُوا : الْوَلاَئُ لِلکُبْرِ۔",,,32213
32214,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَن عُمَرَ وَعَبْدِ اللہِ وَزَیْدٍ ، قَالُوا : الْوَلاَئُ لِلکُبْرِ۔",,,32214
32215,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ، عَنْ شُرَیْحٍ: أَنَّہُ قَضَی فِیہِ کَمَا یُقْضَی فِی الْمَالِ، قَالَ: وَکَانَ عَلِیٌّ وَزَیْدٌ یَجْعَلاَنِہِ لِلکُبْرِ۔",,,32215
32216,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مِسْعَرٌ وَسُفْیَانُ ، عَنْ عِمْرَانَ بْنِ مُسْلِمِ بْنِ رِیَاحٍ الثَّقَفِیِّ ، عَنْ عَبْدِ اللہِ بْنِ مَعْقِلٍ ، عَنْ عَلِیٍّ ، قَالَ : الْوَلاَئُ شُعْبَۃٌ مِنَ الرِّقِّ ، فَمَنْ أَحْرَزَ الْمِیرَاثَ أَحْرَزَ الْوَلاَئَ۔",,,32216
32217,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنِ ابْنِ رِیَاحٍ ، عَنْ سَالِمِ بْنِ عَبْدِ اللہِ ، قَالَ : الْوَلاَئُ لِلکُبْرِ۔",,,32217
32218,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ : الْوَلاَئُ لِلکُبْرِ۔",,,32218
32219,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ قَیْسِ بْنِ مُسْلِمٍ ، عَنْ أَبِی مَالِکٍ الْغِفَارِیِّ ، قَالَ : إذَا مَاتَ الْمُعْتِقُ الأَوَّلُ فَأَیُّکُمْ مَنْ یَرِثُہُ فَلَہُ وَلاَئُ مَوْلاَہُ۔",,,32219
32220,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : إذَا مَاتَ مَوْلَی الْقَوْمِ نُظِرَ إلَی أَقْرَبِ النَّاسِ مِنْہُ فَجُعِلَ لَہُ مِیرَاثُہُ۔",,,32220
32221,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی عَاصِمٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : کَانَ شُرَیْحٌ یُجْرِی الْوَلاَئَ مُجْرَی الْمَالِ ، قَالَ الشَّعْبِیُّ : وَأَہْلُ الْمَدِینَۃِ یَقُولُونَ : الْوَلاَئُ لِلکُبْرِ۔",,,32221
32222,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مِسْعَرٌ ، عَنْ أَبِی عَوْنٍ : أَنْ شُرَیْحًا قَضَی فِی آلِ الأَشْعَثِ أَنَّ الْوَلاَئَ بَیْنَ الْعَمِّ وَبَنِی الأَخِ۔",,,32222
32223,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، سَمِعَ سُنَیْنًا أَبَا جَمِیلَۃَ یَقُولُ : وَجَدْت مَنْبُوذًا عَلَی عَہْدِ عُمَرَ ، فَذَکَرَہُ عَرِیفِیٌّ لِعُمَرَ فَدَعَانِی فَسَأَلَنِی فَأَخْبَرْتہ ، فَقَالَ : ہُوَ حُرٌّ ، وَوَلاَؤُہُ لَک وَعَلَیْنَا رَضَاعُہُ۔",,,32223
32224,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، قَالَ : قَالَ عَلِیٌّ : الْمَنْبُوذُ حُرٌّ ، فَإِنْ أَحَبَّ أَنْ یُوَالِیَ الَّذِی الْتَقَطَہُ : وَالاَہُ ، وَإِنْ أَحَبَّ أَنْ یُوَالِیَ غَیْرَہُ : وَالاَہُ۔",,,32224
32225,"حَدَّثَنَا عُمَرُ بْنُ ہَارُونَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : السَّاقِطُ یُوَالِی مَنْ شَائَ۔",,,32225
32226,"حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : مِیرَاثُ اللَّقِیطِ بِمَنْزِلَۃِ اللُّقَطَۃِ۔",,,32226
32227,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : جَرِیرَتُہُ فِی بَیْتِ الْمَالِ ، وَمِیرَاثُہُ لَہُمْ۔",,,32227
32228,"حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ : أَنَّ عُمَرَ بْنَ الْخَطَّابِ أَعْطَی مِیرَاثَ الْمَنْبُوذِ للَّذِی کَفَلَہُ۔",,,32228
32229,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ عُمَرَ بْنِ رُؤْبَۃَ ، عَنْ عَبْدِ الْوَاحِدِ النَّصْرِیِّ ، عَنْ وَاثِلَۃَ بْنِ الأَسْقَعِ ، قَالَ : تَرِثُ الْمَرْأَۃُ ثَلاَثَۃً : لَقِیطَہَا ، وَعَتِیقَہَا ، وَالْمُلاعَنَۃ : ابْنَہَا۔",,,32229
32230,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عَبْدُ الْعَزِیزِ بْنُ عُمَرَ بْنُ عَبْدِ الْعَزِیزِ ، عَنْ عَبْدِ اللہِ بْنِ مَوْہَبٍ ، قَالَ : سَمِعْتُ تَمِیمًا الدَّارِیَّ یَقُولُ : قُلْتُ : یَا رَسُولَ اللہِ مَا السُّنَّۃُ فِی الرَّجُلِ مِنْ أَہْلِ الْکِتَابِ یُسْلِمُ عَلَی یَدَیَ الرَّجُلِ مِنَ الْمُسْلِمِینَ ؟ قَالَ : ہُوَ أَوْلَی النَّاسِ بِمَحْیَاہُ وَمَمَاتِہِ۔ (ترمذی 2112۔ احمد 102)",,,32230
32231,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ خُصَیْفٍ ، عَنْ مُجَاہِدٍ : أَنَّ رَجُلاً أَتَی عُمَرَ فَقَالَ : إنَّ رَجُلاً أَسْلَمَ عَلَی یَدَیَّ فَمَاتَ وَتَرَکَ أَلْفَ دِرْہَمٍ ، فَتَحَرَّجْت مِنْہَا ، فَرَفَعْتہَا إلَیْک ؟ فَقَالَ : أَرَأَیْت لَوْ جَنَی جِنَایَۃً عَلَی مَنْ کَانَتْ تَکُونُ ؟ قَالَ : عَلَیَّ ، قَالَ : فَمِیرَاثُہُ لَک۔",,,32231
32232,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ : أَنَّ عُمَرَ بْنَ الْخَطَّابِ قَالَ : إذَا وَالَی رَجُلٌ رَجُلاً فَلَہُ مِیرَاثُہُ وَعَلَیْہِ عَقْلُہُ۔",,,32232
32233,"حَدَّثَنَا جَرِیرُ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إذَا أَسْلَمَ الرَّجُلُ عَلَی یَدَی الرَّجُلِ ، فَلَہُ مِیرَاثُہُ وَعَلَیْہِ عَقْلُہُ۔",,,32233
32234,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا عَبْدُ الْعَزِیزِ بْنِ عُمَرَ ، قَالَ : قَضَی أَبِی فِی رَجُلٍ مِنْ أَہْلِ الذِّمَّۃِ أَسْلَمَ عَلَی یَدَیْ رَجُلٍ فَمَاتَ وَتَرَکَ ابْنَۃً ، فَأَعْطَی ابْنَتَہُ النِّصْفَ ، وَأَعْطَی الَّذِی أَسْلَمَ عَلَی یَدَیْہِ النِّصْفَ۔",,,32234
32235,"حَدَّثَنَا وَکِیعٌ ، قَالَ: حدَّثَنَا سُفْیَانُ ، عَنْ قَیْسِ بْنِ مُسْلِمٍ ، عَنْ مُحَمَّدِ بْنِ الْمُنْتَشِرِ ، عَنْ مَسْرُوقٍ ، قَالَ: کَانَ فِینَا رَجُلٌ نَازِلٌ أَقْبَلَ مِنَ الدَّیْلَمِ ، فَمَاتَ وَتَرَکَ ثَلاَثُ مِئَۃ دِرْہَمٍ ، فَأَتَیْت ابْنَ مَسْعُودٍ فَسَأَلْتُہُ ؟ فَقَالَ : ہَلْ لَہُ مِنْ رَحِمٍ؟ أَوْ ہَلْ لأَحَدٍ مِنْکُمْ عَلَیْہِ عَقْدُ وَلاَئٍ؟ قُلْنَا: لاَ ، قَالَ: فَہَاہُنَا وَرِثَہُ کَثِیرٌ۔ یَعْنِی : بَیْتَ الْمَالِ۔",,,32235
32236,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ أَبِی الأَشْعَثِ ، عَنْ مَوْلاَہُ ، قَالَ : سَأَلْتُ عُمَرَ عَنْ رَجُلٍ أَسْلَمَ عَلَی یَدَیَّ وَعَاقَدَنِی فَمَاتَ ؟ قَالَ : أَنْتَ أَحَقُّ النَّاسِ بِمِیرَاثِہِ مَا لَمْ یَتْرُکْ وَارِثًا ، فَإِنْ لَمْ یَتْرُکْ وَارِثًا ، فَإِنْ أَبَیْتَ فَہَذَا بَیْتُ الْمَالِ۔",,,32236
32237,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا الرَّبِیعُ بْنُ أَبِی صَالِحٍ الأَسْلَمِیُّ، عَنْ شیخ یُکنی أَبَا مُدْرِکٍ: أَنَّ رَجُلاً مِنْ أَہْلِ السَّوَادِ یُقَالَ لَہُ: حَبَشِیٌّ أَتَی عَلِیًّا لِیُوَالِیَہُ، فَأَبَی أَنْ یُوَالِیَہُ وَرَدَّہ، قَالَ: فَأَتَی الْعَبَّاسَ - أَو ابْنَ الْعَبَّاسِ - فَوَالاَہُ۔",,,32237
32238,"حَدَّثَنَا غُنْدَرٌ ، عَنْ عُثْمَانَ بْنِ غِیَاثٍ ، قَالَ : سَمِعْتُ الْحَسَن یَقُولُ فِی رَجُلٍ أَسْلَمَ عَلَی یَدَی رَجُلٍ ، فَقَالَ : لَہُ مِیرَاثُہُ إلاَّ أَنْ یَکُونَ لَہُ أُخْتٌ ، فَإِنْ کَانَتْ أُخْتٌ فَلَہَا الْمَالُ وَہِیَ أَحَقُّ بِہِ۔",,,32238
32239,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا ہِشَامٌ ، عَنِ ابْنِ سِیرِینَ : أَنَّ أَبَا الْہُذَیْلِ أَسْلَمَ عَلَی یَدَیْہِ رَجُلٌ ، فَمَاتَ وَتَرَکَ عَشْرَۃَ آلاَفِ دِرْہَمٍ ، فَأَتَی بِہَا أَبُو الہُذَیْلٍ زِیَادًا ، فَقَالَ زِیَادٌ : أَنْتَ أَحَقُّ بِہَا ، فَقَالَ : لاَ حَاجَۃَ لِی فِیہَا ، فَقَالَ زِیَادٌ : أَنْتَ وَارِثُہُ ، فَأَبَی ، فَأَخَذَہَا زِیَادٌ ، فَجَعَلَہَا فِی بَیْتِ الْمَالِ۔",,,32239
32240,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مُطَرِّفٍ ، عَنِ الشَّعْبِیِّ۔ وَعَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالاَ : مِیرَاثُہُ لِلْمُسْلِمِینَ ، وَعَقْلُہُ عَلَیْہِمْ۔",,,32240
32241,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا دَاوُد بْنُ أَبِی عَبْدِ اللہِ ، قَالَ : کَانَتْ لَنَا ظِئْرٌ وَلَہَا ابْنٌ أَسْلَمَ عَلَی أَیْدِینَا : فَمَاتَ وَتَرَکَ مَالاً فَسَأَلْت الشَّعْبِیَّ ؟ فَقَالَ : ادْفَعْہُ إلَی أُمِّہِ۔",,,32241
32242,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا حَسَنُ بْنُ صَالِحٍ ، عَنْ مُطَرِّفٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : لاولاَئَ إلاَّ لِذِی نِعْمَۃٍ۔",,,32242
32243,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ : فِی رَجُلٍ وَالَی رَجُلاً فَأَسْلَمَ عَلَی یَدَیْہِ ، قَالَ : لاَ یَرِثُہُ ، إلاَّ أَنَّہُ إنْ شَائَ أَوْصَی لَہُ بِمَالِہِ کُلِّہِ۔",,,32243
32244,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَصْبَہَانِیِّ ، عَنْ مُجَاہِدِ بْنِ وَرْدَانٍ ، عَنْ عُرْوَۃَ بْنِ الزُّبَیْرِ ، عَنْ عَائِشَۃَ : أَنَّ مَوْلًی لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَقَعَ مِنْ نَخْلَۃٍ فَمَاتَ وَتَرَکَ مَالاً وَلَمْ یَدَعْ وَلَدًا وَلاَ حَمِیمًا ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَعْطُوا مِیرَاثَہُ رَجُلاً مِنْ أَہْلِ قَرْیَتِہِ۔\n\n(ابوداؤد 2894۔ ترمذی 2105)",,,32244
32245,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عَلِیُّ بْنُ مُبَارَکٍ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ ثَوْبَانَ : أَنَّ رَجُلاً مِنْ جُرْہُمٍ تُوُفِّیَ بِالسَّرَاۃِ وَتَرَکَ مَالاً ، فَکُتِبَ فِیہِ إلَی عُمَرَ ، فَکَتَبَ عُمَرُ إلَی الشَّامِ ، فَلَمْ یَجِدُوا بَقِیَ مِنْ جُرْہُمٍ وَاحِدٌ ، فَقَسَمَ عُمَرُ مِیرَاثَہُ فِی الْقَوْمِ الَّذِینَ تُوُفِّیَ فِیہِمْ۔",,,32245
32246,"حَدَّثَنَا بِشْرُ بْنُ الْمُفَضَّلِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ إِسْحَاقَ ، عَنْ أَبِیہِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَمْرِو بْنِ سَہْلٍ ، قَالَ : مَاتَ مَوْلًی عَلَی عَہْدِ عُثْمَانَ لَیْسَ لَہُ مَوْلًی ، فَأَمَرَ عُثْمَان بِمَالِہِ فَأُدْخِلَ بَیْتَ الْمَالِ۔",,,32246
32247,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ ، عَنْ مَسْرُوقٍ : سُئِلَ عَنْ رَجُلٍ مَاتَ وَلَمْ یَتْرُکْ مَوْلًی عَتَاقَۃً وَلاَ وَارِثًا ؟ قَالَ : مَالُہُ حَیْثُ وَضَعَہُ ، فَإِنْ لَمْ یَکُنْ أَوْصَی بِشَیْئٍ فَمَالُہُ فِی بَیْتِ الْمَالِ۔",,,32247
32248,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ أَبِی بَکْرِ بْنِ أَحْمَرَ ، عَنْ عَبْدِ اللہِ بْنِ بُرَیْدَۃَ ، عَنْ أَبِیہِ ، قَالَ : کُنْتُ عِنْدَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَجَائَ رَجُلٌ ، فَقَالَ : یَا رَسُولَ اللہِ ، إنَّ عِنْدِی مِیرَاثَ رَجُلٍ مِنَ الأَزْدِ ، وَإِنِّی لَمْ أَجِدْ أَزْدِیًّا أَدْفَعُہُ إلَیْہِ ، قَالَ : انْطَلِقْ فَالْتَمِسْ أَزْدِیًّا عَامًا - أَوْ حَوْلاً - فَادْفَعْہُ إلَیْہِ ، قَالَ : فَانْطَلَقَ ثُمَّ أَتَاہُ فِی الْعَامِ السَّابِعِ ، فَقَالَ : یَا رَسُولَ اللہِ مَا وَجَدْت أَزْدِیًّا أَدْفَعُہُ إلَیْہِ ، قَالَ : انْطَلِقْ إلَی أَوَّلِ خُزَاعِیٍّ تَجِدُہُ فَادْفَعْہُ إلَیْہِ ، قَالَ : فَلَمَّا قَفَّی قَالَ : عَلَیَّ بِہِ ، قَالَ : فَاذْہَبْ فَادْفَعْہُ إلَی أَکْبَرِ خُزَاعَۃَ۔\n\n(ابوداؤد 2895۔ احمد 347)",,,32248
32249,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، عَنْ یَحْیَی بْنِ جَعْدَۃَ ، عَنْ عُمَرَ : أَنَّ رَجُلاً مَاتَ وَلَمْ یَتْرُکْ عَصَبَۃً ، فَقَالَ عُمَرُ : یَرِثُہُ الَّذِی کَانَ یَغْضَبُ لِغَضَبِہِ وَجِیرَانُہُ۔",,,32249
32250,"حَدَّثَنَا یَزِیدٌ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ إِسْحَاقَ ، عَنْ یَعْقُوبَ بْنِ عَتَبَۃَ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ ، قَالَ : تُوُفِّیَ رَجُلٌ مِنَ الْحَبَشَۃِ ، فَأُتِیَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِمِیرَاثِہِ ، قَالَ : اُنْظُرُوا ہَلْ لَہُ وَارِثٌ ؟ فَلَمْ یَجِدُوا لَہُ وَارِثًا ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : اُنْظُرُوا مَنْ ہَاہُنَا مِنْ مُسْلِمِی الْحَبَشَۃِ فَادْفَعُوا إلَیْہِمْ مِیرَاثَہُ۔",,,32250
32251,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ إِسْحَاقَ بْنِ عَبْدِ اللہِ بْنِ أَبِی فَرْوَۃَ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ : أَنَّ عَمْرَو بْنَ الْعَاصِ کَتَبَ إلَی عُمَرَ فِی الرَّاہِبِ یَمُوتُ لَیْسَ لَہُ وَارِثٌ ، فَکَتَبَ إلَیْہِ : أَنْ أَعْطِ مِیرَاثَہُ الَّذِینَ کَانُوا یُؤَدُّونَ جِزْیَتَہُ۔",,,32251
32252,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ : فِی الَّذِی یَمُوتُ لَیْسَ لَہُ وَارِثٌ ، قَالَ : مِیرَاثُہُ لأَہْلِ قَرْیَتِہِ یَسْتَعِینُونَ بِہِ فِی خَرَاجِہِمْ۔",,,32252
32253,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ سُلَیْمَانَ بْنِ مُغِیرَۃَ ، قَالَ : سَأَلْتُ الْحَسَنَ عَنْ رَجُلٍ بَایَعَ امْرَأَۃً مِنْ أَہْلِ الذِّمَّۃِ ، فَکَانَ لَہَا عِنْدَہُ شَیْئٌ فَنَبَذَہَا فَلَمْ یَجِدْہَا ، أَیَجْعَلُہُ فِی بَیْتِ مَالِ الْمُسْلِمِینَ ؟ قَالَ : نَعَمْ۔",,,32253
32254,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ سُلَیْمَانَ ، عَنْ طَاوُوسٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : کُنْتُ آخِرَ النَّاسِ عَہْدًا بِعُمَرَ ، فَسَمِعْتہ یَقُولُ : الْکَلاَلَۃُ مَنْ لاَ وَلَدَ لَہُ۔",,,32254
32255,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : قَالَ أَبُو بَکْرٍ : رَأَیْت فِی الْکَلاَلَۃِ رَأْیًا ، فَإِنْ یَکُ صَوَابًا فَمِنَ اللہِ ، وَإِنْ یَکُ خَطَأً فَمِنْ قِبَلِی وَالشَّیْطَانِ : الْکَلاَلَۃُ مَا عَدَا الْوَلَدَ وَالْوَالِدَ۔",,,32255
32256,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، عَنِ الْحَسَنِ بْنِ مُحَمَّدٍ ، قَالَ : قَالَ لِی ابْنُ عَبَّاسٍ : الْکَلاَلَۃُ مَنْ لاَ وَلَدَ لَہُ ، وَلاَ وَالِدَ۔",,,32256
32257,"حَدَّثَنَا الْمُقْرِیئُ، عَنْ سَعِیدِ بْنِ أَبِی أَیُّوبَ، قَالَ: حدَّثَنِی یَزِیدُ بْنُ أَبِی حَبِیبٍ، عَنْ أَبِی الْخَیْرِ، عَنْ عُقْبَۃَ بْنِ عَامِرٍ : أَنَّہُ قَالَ : مَا أَعْضَلَ بِأَصْحَابِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ شَیْئٌ مَا أَعْضَلَتْ بِہِمَ الْکَلاَلَۃُ۔",,,32257
32258,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ، عَنْ شُعْبَۃَ، عَنِ الْحَکَمِ، قَالَ: سَأَلْتُہ عَنِ الْکَلاَلَۃِ، فَقَالَ: مَا دُونَ الْوَلَدِ وَالأَبِ۔",,,32258
32259,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ یَعْلَی ، عَنِ الْقَاسِمِ ، عَنْ سَعْدِ بْنِ مَالِکٍ : أَنَّہُ قَرَأَ ہَذَا الْحَرْفَ : وَلَہُ أَخٌ ، أَوْ أُخْتٌ لأم۔",,,32259
32260,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ سَلِیمِ بْنِ عَبْدٍ السَّلُولِیِّ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : الْکَلاَلَۃُ مَا خَلاَ الْوَالِدَ وَالْوَلَدَ۔",,,32260
32261,"حَدَّثَنَا وَکِیعٌ ، عَنْ عِمْرَانَ بْنِ حُدَیْرٍ ، عَنِ السُّمَیْطِ ، قَالَ : کَانَ عُمَرُ یَقُولُ : الْکَلاَلَۃُ مَا خَلاَ الْوَلَدَ وَالْوَالِدَ۔",,,32261
32262,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ سُفْیَانِ بْنِ حُسَیْنٍ ، عَنْ رَجُلٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : الْکَلاَلَۃُ ہُوَ الْمَیِّتُ۔",,,32262
32263,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَبْدِ اللہِ بْنِ دِینَارٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ بَیْعِ الْوَلاَئِ ، وَعَنْ ہِبَتِہِ۔",,,32263
32264,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، قَالَ : قَالَ عَلِیّ : الْوَلاَئُ بِمَنْزِلَۃِ الْحِلْفِ ، لاَ یُبَاعُ ، وَلاَ یُوہَبُ ، أَقِرُّوہُ حَیْثُ جَعَلَہُ اللَّہُ تَعَالَی۔",,,32264
32265,"حَدَّثَنَا جَرِیرٌ، عَنْ مُغِیرَۃَ، عَنْ إبْرَاہِیمَ، قَالَ: قَالَ عَبْدُ اللہِ: إنَّمَا الْوَلاَئُ کَالنَّسَبِ، أَیَبِیعُ الرَّجُلُ نَسَبَہُ؟۔",,,32265
32266,"حَدَّثَنَا جَرِیرٌ وَحَفْصٌ وَأَبُو خَالِدٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : الْوَلاَئُ لاَ یُبَاعُ وَلاَ یُوہَبُ۔",,,32266
32267,"حَدَّثَنَا مُحَمَّدُ بْنُ یَزِیدَ ، عَنْ أَیُّوبَ أَبِی الْعَلاَئِ ، عَنْ قَتَادَۃَ ، عَنْ عُمَرَ ، قَالَ : الْوَلاَئُ کَالرَّحِمِ لاَ یُبَاعُ ، وَلاَ یُوہَبُ۔",,,32267
32268,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ دَاوُدَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : الْوَلاَئُ کَالنَّسَبِ ، لاَ یُبَاعُ وَلاَ یُوہَبُ۔",,,32268
32269,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ إبْرَاہِیمَ بْنِ عَبْدِ الأَعْلَی ، عَنْ سُوَیْد بْنِ غَفَلَۃَ ، قَالَ : الْوَلاَئُ نَسَبٌ ، لاَ یُبَاعُ ، وَلاَ یُوہَبُ۔",,,32269
32270,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی مِسْکِینٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : الْوَلاَئُ لاَ یُبَاعُ ، وَلاَ یُوہَبُ۔",,,32270
32271,"حَدَّثَنَا عَبَّادٌ، عَنْ ہِشَامٍ، عَنِ الْحَسَنِ وَابْنِ سِیرِینَ، أَنَّہُمَا قَالاَ: الْوَلاَئُ شُجْنَۃٌ کَالنَّسَبِ لاَ یُبَاعُ، وَلاَ یُوہَبُ۔",,,32271
32272,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : الْوَلاَئُ لاَ یُبَاعُ ، وَلاَ یُوہَبُ۔",,,32272
32273,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ : الْوَلاَئُ لاَ یُبَاعُ ، وَلاَ یُوہَبُ ، وَلاَ یُتَصَدَّقُ بِہِ۔",,,32273
32274,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، قَالَ : وَہَبَتْ مَیْمُونَۃُ وَلاَئَ سُلَیْمَانَ بْنِ یَسَارٍ لاِبْنِ عَبَّاسٍ۔",,,32274
32275,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، قَالَ : سَأَلْتُ إِبْرَاہِیمَ عَن رَجُلٍ أَعْتَقَ رَجُلاً فَانْطَلَقَ الْمُعْتَقُ فَوَالَی غَیْرَہُ ؟ قَالَ : لَیْسَ لَہُ ذَاکَ إلاَّ أَنْ یَہَبَہُ الْمُعْتِقُ۔",,,32275
32276,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ أَبِی بَکْرِ بْنِ عَمْرِو بْنِ حَزْمٍ : أَنَّ امْرَأَۃً مِنْ مُحَارِبٍ وَہَبَتْ وَلاَئَ عَبْدِہَا لِنَفْسِہِ وَأَعْتَقَتْہُ وَأَعْتَقَ نَفْسَہُ ، قَالَ : فَوَہَبَ نَفْسَہُ لِعَبْدِ الرَّحْمَنِ بْنِ عَمْرِو بْنِ حَزْمٍ ، قَالَ : وَمَاتَتْ ، فَخَاصَمَ الْمَوَالِی إلَی عُثْمَانَ ، قَالَ : فَدَعَا عُثْمَان بِالْبَیِّنَۃِ عَلَی مَا قَالَ : قَالَ : فَأَتَاہُ بِالْبَیِّنَۃِ ، فَقَالَ عُثْمَان : اذْہَبْ فَوَالِ مَنْ شِئْت۔\n\nأَبُو بَکْرٍ : فَوَالَی عَبْدَ الرَّحْمَن بْنَ عَمْرِو بْنِ حَزْمٍ۔",,,32276
32277,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ شُعْبَۃَ ، قَالَ : أَخْبَرَنِی مَنْصُورٌ ، عَنْ إبْرَاہِیمَ وَالشُّعَبِیِّ ، أَنَّہُمَا قَالاَ : لاَ بَأْسَ بِبَیْعِ ، وَلاَئِ السَّائِبَۃِ وَہِبَتِہِ۔",,,32277
32278,"حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ قَتَادَۃَ : أَنَّ امْرَأَۃً وَہَبَتْ وَلاَئَ مَوَالِیہَا لِزَوْجِہَا ، فَقَالَ : ہِشَامُ بْنُ ہُبَیْرَۃَ : أَمَّا أَنَا فَأَرَاہُ لِزَوْجِہَا مَا عَاشَ ، فَإِذَا مَاتَ رَدَدْتہ إلَی وَرَثَۃِ الْمَرْأَۃِ۔",,,32278
32279,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ إذَا أَذِنَ الْمَوْلَی أَنْ یُوَالِیَ غَیْرَہُ۔",,,32279
32280,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ - وَجَدْتہ فِی مَکَان آخَرَ عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ - : أَنَّہُ کَانَ لاَ یَرَی بَأْسًا بِبَیْعِ الْوَلاَئِ إذَا کَانَ مِنْ مُکَاتَبَۃٍ ، وَیَکْرَہُہُ إذَا کَانَ عِتْقًا۔",,,32280
32281,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ مَنْصُورٍ ، قَالَ : سَأَلْتُ إِبْرَاہِیمَ عَن بَیْعِ الْوَلاَئِ ؟ فَقَالَ : ہُوَ مُحْدَثٌ۔",,,32281
32282,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ سُلَیْمَانَ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ تَرِثُ النِّسَائُ مِنَ الْوَلاَئِ إلاَّ مَا أَعْتَقْنَ۔",,,32282
32283,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، قَالَ : حدَّثَنَا زَکَرِیَّا ، سَمِعْت عَامِرًا یَقُولُ ، فِی امْرَأَۃٍ تُوُفِّیَتْ وَلَہَا ثَلاَثَۃُ بَنِینَ ذُکُورٍ ، وَابْنَتَانِ ، إحْدَاہُمَا غَائِبَۃٌ بِالشَّامِ ، وَالأُخْرَی عِنْدَہَا ، فَزَعَمَتْ أَنَّ لَہَا عِنْدَ ابْنَتِہَا الَّتِی بِالشَّامِ مَالاً ، وَأَنَّہَا قَالَتْ لِبَنِیہَا : أُحِبُّ أَنْ تَطْلُبُوا لَہَا الْمَالَ الَّذِی عِنْدَہَا بِمَا یُصِیبُہَا مِنْ مِیرَاثِی ، فَقَالُوا : نَعَمْ ، قَالَتْ : وَأُحِبُّ أَنْ تَجْعَلُوا مَا یُصِیبُہَا مِنْ مِیرَاثِی لأُخْتِہَا ، فَیصِیبُہَا کَماَ یُصِیب رَجُلٍ مِنْکُمْ ، فَقَالُوا : نَعَمْ ، ثُمَّ إنَّ ابْنَتَہَا جَائَتْ بَعْدَ مَا اقْتَسَمُوا الْمِیرَاثَ فَطَلَبَتْ مَا یُصِیبُہَا مِنْ مِیرَاثِہَا ، قَالَتْ : لَمْ یَکُنْ لَہَا عِنْدِی مَالٌ إبْرَاہِیمُ ؟ فَقَالَ : یُؤْخَذُ مِنْ کُلِّ إنْسَانٍ مِنْہُمْ بِالسَّوِیَّۃِ فَیُرَدُّ عَلَیْہَا ، وَقَالَ عَامِرٌ : یُؤْخَذُ أَحَدُ السَّہْمَیْنِ اللَّذَیْنِ أَصَابَتِ الْجَارِیَۃُ ، فَیُرَدُّ عَلَی أُخْتِہَا ، فَیُصِیبُ کُلَّ وَاحِدَۃٍ مِنْہُمَا سَہْمٌ ، وَلِکُلِّ رَجُلٍ سَہْمَانِ۔",,,32283
32284,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَدْہَمَ السَّدُوسِیِّ ، عَنْ أُنَاسٍ مِنْ قَوْمِہِ : أَنَّ امْرَأَۃً مَاتَتْ وَہِیَ مُسْلِمَۃٌ وَتَرَکَتْ أُمًّا لَہَا نَصْرَانِیَّۃً ، فَأَسْلَمَتْ أُمُّہَا قَبْلَ أَنْ یُقْسَمَ مِیرَاثُ ابْنَتِہَا ، فَأَتَوْا عَلِیًّا فَذَکَرُوا ذَلِکَ لَہُ ، فَقَالَ : لاَ مِیرَاثَ لَہَا ، ثُمَّ قَالَ : کَمْ تَرَکَتْ فَأَخْبَرُوہُ ، فَقَالَ : انیلُوہَا مِنْہُ بِشَیْئٍ۔",,,32284
32285,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ دَاوُدَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : إذَا مَاتَ الْمَیِّتُ یُرَدُّ الْمِیرَاثُ لأَہْلِہِ۔",,,32285
32286,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ أَبِی مَعْشَرٍ ، عَنِ ابْنِ إبْرَاہِیمَ ، قَالَ : مَنْ أُعْتِقَ عِنْدَ الْمَوْتِ ، أَوْ أَسْلَمَ عِنْدَ الْمَوْتِ فَلاَ حَقَّ لِوَاحِدٍ مِنْہُمْ ، لأَنَّ الْحُقُوقَ وَجَبَتْ عِنْدَ الْمَوْتِ۔",,,32286
32287,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ شُعْبَۃَ ، عَنْ حُصَیْنٍ ، قَالَ : رَأَیْتُ شَیْخًا یَتَوَکَّأُ عَلَی عَصَی ، فَقِیلَ : ہَذَا وَارِثُ صَفِیَّۃَ أَسْلَمَ عَلَی مِیرَاثٍ ، فَلَمْ یُوَرَّثْ۔",,,32287
32288,"حَدَّثَنَا أَبُو دَاوُدَ، عَنْ شُعْبَۃَ، قَالَ: سَأَلْتُ الْحَکَمَ وَحَمَّادًا عَنْ رَجُلٍ أَسْلَمَ عَلَی مِیرَاثٍ؟ فَقَالاَ: لاَ یَرِثُ۔",,,32288
32289,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ : فِی الْعَبْدِ یُعْتِقُ عَلَی الْمِیرَاثِ : أَنَّہُ لَیْسَ لَہُ شَیْئٌ۔",,,32289
32290,"حَدَّثَنَا عَبْدُ الْوَہَّابِ ، عَنْ خَالِدٍ ، عَنْ أَبِی قِلاَبَۃَ ، عَنْ یَزِیدِ بْنِ قَتَادَۃَ : أَنَّ أَبَاہُ تُوُفِّیَ وَہُوَ نَصْرَانِیٌّ ، وَیَزِیدٌ مُسْلِمٌ وَلَہُ إخْوَۃٌ نَصَارَی ، فَلَمْ یُوَرِّثْہُ عُمَرُ مِنْہُ ، ثُمَّ تُوُفِّیَتْ أُمُّ یَزِیدَ وَہِیَ مُسْلِمَۃٌ ، فَأَسْلَمَ إخْوَتُہُ بَعْدَ مَوْتِہَا ، فَطَلَبُوا الْمِیرَاثَ فَارْتَفَعُوا إلَی عُثْمَانَ فَسَأَلَ عَنْ ذَلِکَ ، فَوَرَّثَہُمْ۔",,,32290
32291,"حَدَّثَنَا مُعْتَمِرٌ ، عَنِ الْحَکَمِ بْنِ أَبَانَ ، عَنْ عِکْرِمَۃَ ، قَالَ : النَّصْرَانِیُّ إذَا مَاتَ لَہُ الْمَیِّتُ فَقُسِمَ مِیرَاثُہُ وَبَقِیَ بَعْضُہُ ، ثُمَّ أَسْلَمَ فَقَدْ أَدْرَکَ۔",,,32291
32292,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : مَنْ أَسْلَمَ عَلَی مِیرَاثٍ ، قَالَ : یَرِثُ مَا لَمْ یُقْسَمْ ، وَفِی الْعَبْدِ یُعْتَقُ عَلَی مِیرَاثٍ ، قَالَ : یَرِثُ مَا لَمْ یُقْسَمْ۔",,,32292
32293,"حَدَّثَنَا حَفْصٌ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ، قَالَ : قَالَ عَلِیٌّ : مَنْ أَسْلَمَ عَلَی مِیرَاثِہِ فَہُوَ لَہُ۔",,,32293
32294,"حَدَّثَنَا عُبَیْدُ اللہِ ، قَالَ : حدَّثَنَا زَکَرِیَّا بْنُ أَبِی زَائِدَۃَ ، قَالَ : أَخَذْت ہَذِہِ الْفَرَائِضَ مِنْ فِرَاسٍ زَعَمَ أَنَّہُ کَتَبَہَا لَہُ الشَّعْبِیُّ :\n\n1۔ قَضَی زَیْدُ بْنُ ثَابِتٍ وَابْنُ مَسْعُودٍ : أَنَّ الأُخْوَۃَ مِنَ الأَبِ وَالأُمِّ شُرَکَائُ الإِخْوَۃِ مِنَ الأُمِّ فِی بَنِیہِمْ : ذَکَرِہِمْ وَأُنْثَاہُمْ ، وَقَضَی عَلِیٌّ : أَنَّ لِبَنِی الأُمِّ دُونَ بَنِی الأَبِ وَالأُمِ۔\n\n2۔ وَقَضَی عَلِیٌّ وَزَیْدٌ : أَنَّہُ لاَ تَرِثُ جَدَّۃٌ أُمُّ أَبٍ مَعَ ابْنِہَا ، وَوَرَّثَہَا عَبْدُ اللہِ مَعَ ابْنِہَا السُّدُسَ۔\n\n3۔ امْرَأَۃٌ تَرَکَتْ أُمَّہَا وَإِخْوَتَہَا کُفَّارًا وَمَمْلُوکِینَ ، قَضَی عَلِیٌّ وَزَیْدٌ : لأُمِّہَا الثُّلُثَ وَلِعَصَبَتِہَا الثُّلُثَیْنِ کَانَا لاَ یُوَرِّثَانِ کَافِرًا وَلاَ مَمْلُوکًا مِنْ مُسْلِمٍ حُرٍّ ، وَلاَ یَحْجُبَانِ بِہِ ، وَکَانَ ابْنُ مَسْعُودٍ یَحْجُبُ بِہِمْ وَلاَ یُوَرِّثُہُمْ ، فَقَضَی : لِلأُمِّ السُّدُسَ وَلِلْعَصَبَۃِ مَا بَقِی۔\n\n4۔ امْرَأَۃٌ تَرَکَتْ زَوْجَہَا وَإِخْوَتِہَا لأُمِّہَا ، وَلَہَا ابْنٌ مَمْلُوک : قَضَی عَلِیٌّ وَزَیْدٌ : لِزَوْجِہَا النِّصْف ، وَلإِخْوَتِہَا الثُّلُث ، وَلِلْعَصَبَۃِ مَا بَقِیَ ، وَقَضَی عَبْدُ اللہِ : لِلزَّوْجِ الرُّبُعَ ، وَمَا بَقِیَ فَہُوَ لِلْعَصَبَۃِ۔\n\n5۔ امْرَأَۃٌ تَرَکَتْ أُمَّہَا وَإِخْوَتَہَا کُفَّارًا وَمَمْلُوکِینَ : قَضَی عَلِیٌّ وَزَیْدٌ : لأُمِّہَا الثُّلُثَ ، وَلِلْعَصَبَۃِ مَا بَقِی ، وَقَضَی عَبْدُ اللہِ : لأُمِّہَا السُّدُسَ وَلِلْعَصَبَۃِ مَا بَقِیَ۔\n\n6۔ امْرَأَۃٌ تَرَکَتْ زَوْجَہَا وَإِخْوَتَہَا لأُمِّہَا ، وَلاَ عَصَبَۃَ لَہَا ، قَضَی زَیْدٌ : لِلزَّوْجِ النِّصْفَ وَلِلإِخْوَۃِ الثُّلُثَ ، وَقَضَی عَلِیٌّ وَعَبْدُ اللہِ : أَنْ یُرَدَّ مَا بَقِیَ عَلَی الإِخْوَۃِ مِنَ الأُمِّ ، لأَنَّہُمَا کَانَا لاَ یَرُدَّانِ مِنْ فُضُولِ الْفَرَائِضِ عَلَی الزَّوْجِ شَیْئًا وَیَرُدَّانِہَا عَلَی أَدْنَی رَحِمٍ یُعْلَمُ۔\n\n7۔ امْرَأَۃٌ تَرَکَتْ أُمَّہَا قَضَوْا جَمِیعًا لِلأُمِّ الثُّلُثَ ، وَقَضَی عَلِیٌّ وَابْنُ مَسْعُودٍ : بِرَدِّ مَا بَقِیَ عَلَی الأُمِّ۔\n\n8۔ رَجُلٌ تَرَکَ أُخْتَہُ لأَبِیہِ وَأُمَّہُ ، وَأُمِّہ ، قَضَوْا جَمِیعًا : لأُخْتِہِ لأَبِیہِ وَأُمِّہِ النِّصْفَ، وَلأُمِّہِ الثُّلُثَ ، وَقَضَی عَلِیٌّ وَعَبْدُ اللہِ : أَنْ یُرَدَّ مَا بَقِیَ - وَہُوَ سَہْمٌ - ، عَلَیْہِما عَلَی قَدْرِ مَا وِرْثًا ، فَیَکُونُ لِلأُخْتِ ثَلاَثَۃُ أَخْمَاسٍ وَیَکُونُ لِلأُمِّ خُمُسَا الْمَالِ۔\n\n9۔ رَجُلٌ تَرَکَ أُخْتَہُ لأَبِیہِ وَجَدَّتَہُ وَامْرَأَتَہُ ، قَضَوْا جَمِیعًا لأُخْتِہِ النِّصْفَ وَلاِمْرَأَتِہِ الرُّبُعَ ، وَلِجَدَّتِہِ سَہْمٌ ، وَرَدَّ عَلِیٌّ مَا بَقِیَ عَلَی أُخْتِہِ وَجَدَّتِہِ عَلَی قِسْمَۃِ فَرِیضَتِہِمْ ، وَأَمَّا عَبْدُ اللہِ فَرَدَّہُ عَلَی الأُخْتِ لأَنَّہُ کَانَ لاَ یَرُدُّ عَلَی جَدَّۃٍ ، إلاَّ أَنْ لاَ یَکُونَ وَارِثًا غَیْرَہَا۔\n\n10۔ امْرَأَۃٌ تَرَکَتْ أُمَّہَا وَأُخْتَہَا لأُمِّہَا قَضَوْا جَمِیعًا : لأُمِّہَا الثُّلُثَ وَلأُخْتِہَا السُّدُسَ ، وَرَدَّ عَلِیٌّ مَا بَقِیَ عَلَیْہَا عَلَی قِسْمَۃِ فَرِیضَتِہِمْ فَیَکُونُ لِلأُمِّ الثُّلُثَانِ ، وَلِلأُخْتِ الثُّلُثُ وَقَضَی عَبْدُ اللہِ : أَنَّ مَا بَقِیَ یُرَدُّ عَلَی الأُمِّ ، لأَنَّہُ کَانَ لاَ یَرُدُّ عَلَی إخْوَۃٍ لأُمٍّ مَعَ أُمٍّ ، فَیَصِیرُ لِلأُمِّ خَمْسَۃُ أَسْدَاسٍ ، وَلِلأُخْتِ سُدُسٌ۔\n\n11۔ امْرَأَۃٌ تَرَکَتْ أُخْتَہَا لأَبِیہَا وَأُمَّہَا ، وَأُخْتَہَا لأَبِیہَا قَضَوْا جَمِیعًا ، لأُخْتِہَا لأَبِیہَا وَأُمِّہَا النِّصْفَ ، وَلأُخْتِہَا لأَبِیہَا السُّدُسَ ، وَرَد مَا بَقِیَ عَلَیْہِمَا عَلَی قِسْمَۃِ فَرِیضَتِہِمْ ، فَیَکُونُ لِلأُخْتِ مِنَ الأَبِ وَالأُمِّ ثَلاَثَۃُ أَرْبَاعٍ ، وَلِلأُخْتِ لِلأَبِ رُبُعٌ ، وَرَدَّ عَبْدُ اللہِ مَا بَقِیَ عَلَی الأُخْتِ مِنَ الأَبِ وَالأُمِّ فَیَصِیرُ لَہَا خَمْسَۃُ أَسْدَاسِ الْمَالِ ، وَلِلأُخْتِ لِلأَبِ سُدُسُ الْمَالِ ، کَانَ لاَ یَرُدُّ عَلَی أُخْتٍ لأَبٍ مَعَ أُخْتٍ لأَمٍّ وأَبٍ۔\n\n12۔ امْرَأَۃٌ تَرَکَتْ إخْوَتَہَا لأَبِیہَا وَأُمِّہَا ، وَأُمَّہَا ، قَضَوْا جَمِیعًا : لأُمِّہَا السُّدُسَ وَلإِخْوَتِہَا الثُّلُثَ ، وَرَدَّ مَا بَقِیَ عَلَیْہِمْ عَلَی قِسْمَۃِ فَرِیضَتِہِمْ ، فَیَکُونُ لِلأُمِّ الثُّلُثُ وَلِلإِخْوَۃِ الثُّلُثَانِ ، وَأَمَّا عَبْدُ اللہِ فَإِنَّہُ رَدَّ مَا بَقِیَ عَلَی الأُمِ ، فَیَکُونُ لِلأُمِّ الثُّلُثَانِ وَلِلإِخْوَۃِ الثُّلُثُ۔\n\n13۔ امْرَأَۃٌ تَرَکَتِ ابْنَتَہَا وَابْنَۃَ ابْنِہَا قَضَوْا جَمِیعًا : لاِبْنَتِہَا النِّصْفَ ، وَلاِبْنَۃِ ابْنِہَا السُّدُسَ ، وَرَدَّ عَلِیٌّ مَا بَقِیَ عَلَیْہِمَا عَلَی قِسْمَۃِ فَرِیضَتِہِمْ ، وَرَدَّ عَبْدُ اللہِ مَا بَقِیَ عَلَی الاِبْنَۃِ خَاصَّۃً۔\n\n14۔ امْرَأَۃٌ تَرَکَتِ ابْنَتَہَا وَجَدَّتَہَا قَضَوْا جَمِیعًا لِلاِبْنَۃِ النِّصْفَ ، وَلِلْجَدَّۃِ السُّدُسَ ، وَرَدَّ عَلِیٌّ مَا بَقِیَ عَلَیْہِمَا عَلَی قِسْمَۃِ فَرِیضَتِہِمْ ، وَرَدَّ عَبْدُ اللہِ مَا بَقِیَ عَلَی الاِبْنَۃِ خَاصَّۃً\n\n15۔ امْرَأَۃٌ تَرَکَتِ ابْنَتَہَا وَابْنَۃَ ابْنِہَا وَأُمَّہَا قَضَوْا جَمِیعًا : أَنَّ لاِبْنَتِہَا النِّصْفَ وَلاِبْنَۃِ ابْنِہَا السُّدُسَ وَلأُمِّہَا السُّدُسَ ، وَرَدَّ مَا بَقِیَ عَلَیْہِمْ عَلَی قِسْمَۃِ فَرِیضَتِہِمْ ، وَرَدَّ عَبْدُ اللہِ مَا بَقِیَ عَلَی الاِبْنَۃِ وَالأُمِ ، وَأَمَّا زَیْدُ بْنُ ثَابِتٍ فَإِنَّہُ جَعَلَ الْفَضْلَ مِنْ ذَلِکَ کُلِّہِ فِی بَیْتِ الْمَالِ ، لاَ یَرُدُّ عَلَی وَارِثٍ شَیْئًا ، وَلاَ یَزِیدُ أَبَدًا عَلَی فَرَائِضِ اللہِ شَیْئًا۔\n\n16۔ امْرَأَۃٌ تَرَکَتْ إخْوَتَہَا مِنْ أُمِّہَا رِجَالاً وَنِسَائً وَہُمْ عَصَبَتُہَا : یَقْتَسِمُونَ الثُّلُثَ بَیْنَہُمْ بِالسَّوِیَّۃِ ، وَالثُّلُثَانِ لِذُکُورِہِمْ دُونَ النِّسَائِ۔",,,32294
32295,"حَدَّثَنَا عُبَیْدُ اللہِ ، عَنْ زَکَرِیَّا ، عَنْ عَامِرٍ ، أَنَّہُ سُئِلَ عَنْ رَجُلٍ أَوْصَی بِعِتْقٍ وَصَدَقَۃٍ وَفِی سَبِیلِ اللہِ ؟ فَقَالَ شُرَیْحٌ : یُعْطَی کُلَّ وَاحِدٍ مِنْہَا بِحِصَّتِہِ۔",,,32295
