{"hadithnumber": "1433", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  ابوالقاسم صلی اللہ علیہ وسلم نے فرمایا:  جمعہ والے دن ایک گھڑی ای"}
{"hadithnumber": "1434", "text": "یعلیٰ بن امیہ کہتے ہیں کہ  میں نے عمر بن خطاب رضی اللہ عنہ سے آیت کریمہ: «‏ليس عليكم جناح أن تقصروا"}
{"hadithnumber": "1435", "text": "امیہ بن عبداللہ بن خالد سے روایت ہے کہ  انہوں نے عبداللہ بن عمر رضی اللہ عنہم سے کہا کہ ہم قرآن میں"}
{"hadithnumber": "1436", "text": "عبداللہ بن عباس رضی اللہ عنہم سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم مکہ سے مدینہ کے لیے نکلے،"}
{"hadithnumber": "1437", "text": "عبداللہ بن عباس رضی اللہ عنہم کہتے ہیں کہ  ہم رسول اللہ صلی اللہ علیہ وسلم کے ساتھ مکہ اور مدینہ کے"}
{"hadithnumber": "1438", "text": "ابن سمط کہتے ہیں کہ  میں نے عمر بن خطاب رضی اللہ عنہ کو ذوالحلیفہ ۱؎ میں دو رکعت نماز پڑھتے دیکھا، ت"}
{"hadithnumber": "1439", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  میں رسول اللہ صلی اللہ علیہ وسلم کے ساتھ مدینہ سے مکہ جانے کے لیے نکلا"}
{"hadithnumber": "1440", "text": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کے ساتھ سفر میں دو رک"}
{"hadithnumber": "1441", "text": "عمر رضی اللہ عنہ کہتے ہیں کہ  جمعہ کی نماز دو رکعت ہے، عید الفطر کی نماز دو رکعت ہے، عید الاضحی کی ن"}
{"hadithnumber": "1442", "text": "عبداللہ بن عباس رضی اللہ عنہم کہتے ہیں کہ  حضر  ( اقامت )  کی نماز تمہارے نبی کریم صلی اللہ علیہ وسل"}
{"hadithnumber": "1443", "text": "عبداللہ بن عباس رضی اللہ عنہم کہتے ہیں کہ  اللہ تعالیٰ نے تمہارے نبی کریم صلی اللہ علیہ وسلم کی زبان"}
{"hadithnumber": "1444", "text": "موسیٰ بن سلمہ کہتے ہیں کہ  میں نے ابن عباس رضی اللہ عنہم سے پوچھا کہ میں مکہ میں کس طرح نماز پڑھوں ک"}
{"hadithnumber": "1445", "text": "موسیٰ بن سلمہ سے روایت ہے کہ  انہوں نے ابن عباس رضی اللہ عنہم سے پوچھا: میں نے کہا: مجھ سے باجماعت ن"}
{"hadithnumber": "1446", "text": "حارثہ بن وہب خزاعی رضی اللہ عنہ کہتے ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم کے ساتھ منیٰ میں دو"}
{"hadithnumber": "1447", "text": "حارثہ بن وہب رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ہمیں منیٰ میں دو رکعت پڑھائی،"}
{"hadithnumber": "1448", "text": "میں نے رسول اللہ صلی اللہ علیہ وسلم کے ساتھ اور ابوبکر اور عمر رضی اللہ عنہم کے ساتھ منیٰ میں دو رکع"}
{"hadithnumber": "1449", "text": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  میں نے منیٰ میں رسول اللہ صلی اللہ علیہ وسلم کے ساتھ دو ر"}
{"hadithnumber": "1450", "text": "عبدالرحمٰن بن یزید کہتے ہیں کہ  عثمان رضی اللہ عنہ نے منیٰ میں چار رکعت پڑھی یہاں تک کہ اس کی خبر عب"}
{"hadithnumber": "1451", "text": "عبداللہ بن عمر رضی اللہ عنہم کہتے ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم کے ساتھ منیٰ میں دو رکع"}
{"hadithnumber": "1452", "text": "عبداللہ بن عمر رضی اللہ عنہم کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے منیٰ میں دو رکعت پڑھی، اور"}
{"hadithnumber": "1453", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  ہم لوگ رسول اللہ صلی اللہ علیہ وسلم کے ساتھ مدینہ سے مکہ جانے"}
{"hadithnumber": "1454", "text": "عبداللہ بن عباس رضی اللہ عنہم سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم مکہ میں پندرہ دن ٹھہرے رہ"}
{"hadithnumber": "1455", "text": "علاء بن حضرمی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مہاجر حج و عمرہ کے"}
{"hadithnumber": "1456", "text": "علاء بن حضرمی رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  مہاجر اپنے نسک  ( حج"}
{"hadithnumber": "1457", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  وہ رسول اللہ صلی اللہ علیہ وسلم کے ساتھ عمرہ کرنے کے"}
{"hadithnumber": "1458", "text": "وبرہ بن عبدالرحمٰن کہتے ہیں کہ  ابن عمر رضی اللہ عنہم سفر میں دو رکعت پر اضافہ نہیں کرتے تھے، نہ تو"}
