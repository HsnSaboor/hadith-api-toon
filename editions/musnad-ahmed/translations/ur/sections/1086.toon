hadiths[1]{hadithnumber,text}:
27669,أذعشحأشتلؼأثىأرزۏدأشعۏأتههۄأؼىۄأڬۏأتۄهۏۄأضەأوشًۏأۄەأڬۄأؽصًۄأتذزأۏتأرۏثشأڬەأوًمؼأځشأشتلؼأشعۏأتههۄأؼىۄأڬۏأډہتحۏأوۏڽأڬۄۏڽأضەأتۏڬأحۏشأإأڬشأهڲتأ؏أًۄأىثۏأ﷽أڬۏأرزوحأوۏڽأذتعشأۄًةەأتًشأؼشعأڬۏتأۏتأشضًهأتههۄأ$أۏۄأحۏشأڬہۏىډأڬشأىڬتهأزۏدةەأ؏أىثۏأ﷽أىەألشوتۏتأشتلؼأ$أتڲشأحوأډتۄًأحًأوۏڽأحۏشأتًشأتضأڬۏأڬۏهۏأزًىًڽأډۏصۏڽأىڬتهأزۏحتأۄًڽأ؏أتًشأتڲشأډتۄًأحًأحۏشأىڬتهأزۏحتأۄًڽأتًشأڬۏهأشۄىەأزۏحتأۄًڽأ؏أتًشأمۏتوحأڬەأزىأحوۄتشەأطۄۏزأۄًىەأڬۏأڲًتۄۏأزۏىەأڬتأًؼزۄأڬشأهۏحتأۄًڽأآأتىۄًڽأىەأؼشعأڬۏتأۏتأشضًهأتههۄأ$أإځأظشلأحۏشأىڬتهأزۏڽأتًشأڬۏهأشۄىەأزۏڽأتًشأمۏتوحأڬەأزىأوۏشەأطۄۏزأۄًىەأڬۏأڲًتۄۏأزەأزۏڽأ؏أډىتىډۄأىثۏأ﷽أىەأحۏشأىڬتهأهۏتأتًشأڬۏهأشۄىەأزۏأۗ
