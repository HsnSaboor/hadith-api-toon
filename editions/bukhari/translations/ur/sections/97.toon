{"hadithnumber": "7531", "text": "ہم سے محمد بن یوسف فریابی نے بیان کیا، کہا ہم سے سفیان ثوری نے بیان کیا، کہا ہم سے اسماعیل نے، ان سے"}
{"hadithnumber": "7532", "text": "ہم سے قتیبہ بن سعید نے بیان کیا، کہا ہم سے جریر نے بیان کیا، ان سے اعمش نے، ان سے ابووائل نے، ان سے"}
{"hadithnumber": "7533", "text": "ہم سے عبدان نے بیان کیا، انہوں نے کہا ہم کو عبداللہ بن مبارک نے خبر دی، انہیں یونس نے خبر دی، انہیں"}
{"hadithnumber": "7534", "text": "مجھ سے سلیمان بن حرب نے بیان کیا، انہوں نے کہا ہم سے شعبہ بن حجاج نے بیان کیا، ان سے ولید بن عیزار ن"}
{"hadithnumber": "7535", "text": "ہم سے ابوالنعمان نے بیان کیا، کہا ہم سے جریر بن حازم نے بیان کیا، ان سے امام حسن بصری نے، ان سے عمرو"}
{"hadithnumber": "7536", "text": "مجھ سے محمد بن عبدالرحیم نے بیان کیا، کہا ہم سے ابوزید بن ربیع ہروی نے، کہا ہم سے شعبہ نے، ان سے قتا"}
{"hadithnumber": "7537", "text": "ہم سے مسدد نے بیان کیا، ان سے یحییٰ نے، ان سے تمیمی نے، ان سے انس بن مالک رضی اللہ عنہ نے اور ان سے"}
{"hadithnumber": "7538", "text": "ہم سے آدم بن ابی ایاس نے بیان کیا، کہا ہم سے شعبہ نے بیان کیا، کہا ہم سے محمد بن زیاد نے بیان کیا، ک"}
{"hadithnumber": "7539", "text": "ہم سے حفص بن عمر نے بیان کیا، کہا ہم سے شعبہ نے بیان کیا، ان سے قتادہ نے (دوسری سند) اور امام بخاری"}
{"hadithnumber": "7540", "text": "ہم سے احمد بن ابی سریح نے بیان کیا، کہا ہم کو شبابہ نے خبر دی، کہا ہم سے شعبہ نے بیان کیا، ان سے معا"}
{"hadithnumber": "7541", "text": "اور ابن عباس رضی اللہ عنہما نے بیان کیا کہ مجھے ابوسفیان بن حرب نے خبر دی کہ  ہرقل نے اپنے ترجمان کو"}
{"hadithnumber": "7542", "text": "ہم سے محمد بن بشار نے بیان کیا، انہوں نے کہا ہم سے عثمان بن عمر نے بیان کیا، انہیں علی بن مبارک نے خ"}
{"hadithnumber": "7543", "text": "ہم سے مسدد بن مسرہد نے بیان کیا، کہا ہم سے اسماعیل بن ابی اویس نے بیان کیا، ان سے ایوب نے، ان سے ناف"}
{"hadithnumber": "7544", "text": "ہم سے ابراہیم بن حمزہ نے بیان کیا، انہوں نے کہا ہم سے ابن ابی حازم نے بیان کیا، ان سے یزید نے بیان ک"}
{"hadithnumber": "7545", "text": "ہم سے یحییٰ بن بکیر نے بیان کیا، انہوں نے کہا ہم سے لیث بن سعد نے بیان کیا، ان سے ابن شہاب نے بیان ک"}
{"hadithnumber": "7546", "text": "ہم سے ابونعیم نے بیان کیا، کہا ہم سے مسعر نے، ان سے عدی بن ثابت نے، میرا یقین ہے کہ انہوں نے براء بن"}
{"hadithnumber": "7547", "text": "ہم سے حجاج بن منہال نے بیان کیا، انہوں نے کہا ہم سے ہشیم نے بیان کیا، ان سے ابوبشر نے بیان کیا، ان س"}
{"hadithnumber": "7548", "text": "ہم سے اسماعیل بن ابی اویس نے بیان کیا، انہوں نے کہا ہم مجھ سے امام مالک نے بیان کا، ان سے عبدالرحمٰن"}
{"hadithnumber": "7549", "text": "ہم سے قبیصہ نے بیان کیا، کہا ہم سے سفیان نے بیان کیا، ان سے منصور نے، ان سے ان کی والدہ نے اور ان سے"}
{"hadithnumber": "7550", "text": "ہم سے یحییٰ بن بکیر نے بیان کیا، انہوں نے کہا ہم سے لیث بن سعد نے بیان کیا، ان سے عقیل نے بیان کیا،"}
{"hadithnumber": "7551", "text": "ہم سے ابومعمر نے بیان کیا، کہا ہم سے عبدالوہاب نے، ان سے یزید نے کہ مجھ سے مطرف بن عبداللہ نے بیان ک"}
{"hadithnumber": "7552", "text": "مجھ سے محمد بن بشار نے بیان کیا، کہا ہم سے غندر نے بیان کیا، ان سے شعبہ نے بیان کیا، ان سے منصور اور"}
{"hadithnumber": "7553", "text": "امام بخاری رحمہ اللہ نے کہا مجھ سے خلیفہ بن خیاط نے بیان کیا۔ ہم سے معتمر نے بیان کیا، کہا میں نے اپ"}
{"hadithnumber": "7554", "text": "مجھ سے محمد بن غالب نے بیان کیا، ان سے محمد بن اسماعیل بصریٰ نے بیان کیا، کہا ہم سے معتمر بن سلیمان"}
{"hadithnumber": "7555", "text": "ہم سے عبداللہ بن عبدالوہاب نے بیان کیا، ان سے عبدالوہاب نے، کہا ہم سے ایوب سختیانی نے، ان سے ابوقلاب"}
{"hadithnumber": "7556", "text": "ہم سے عمرو بن علی نے بیان کیا، ان سے ابوعاصم نے بیان کیا، ان سے قرہ بن خالد نے بیان کیا، ان سے ابوجم"}
{"hadithnumber": "7557", "text": "ہم سے قتیبہ بن سعید نے بیان کیا، ان سے لیث نے بیان کیا، ان سے نافع نے بیان کیا، ان سے قاسم بن محمد ن"}
{"hadithnumber": "7558", "text": "ہم سے ابوالنعمان نے بیان کیا، ان سے حماد بن زید نے بیان کیا، ان سے ایوب نے بیان کیا، ان سے نافع نے ب"}
{"hadithnumber": "7559", "text": "ہم سے محمد بن علاء نے بیان کیا، ان سے ابن فضیل نے بیان کیا، ان سے عمارہ نے، ان سے ابوزرعہ نے اور انہ"}
{"hadithnumber": "7560", "text": "ہم سے ہدبہ بن خالد نے بیان کیا، انہوں نے کہا ہم سے ہمام نے بیان کیا، انہوں نے کہا ہم سے قتادہ نے بیا"}
{"hadithnumber": "7561", "text": "ہم سے علی بن عبداللہ مدینی نے بیان کیا، کہا ہم سے ہشام بن یوسف نے بیان کیا، کہا ہم کو معمر نے خبر دی"}
{"hadithnumber": "7562", "text": "ہم سے ابوالنعمان محمد بن فضل سدوسی نے بیان کیا، انہوں نے کہا ہم سے مہدی بن میمون ازدی نے بیان کیا، ک"}
{"hadithnumber": "7563", "text": "ہم سے احمد بن اشکاب نے بیان کیا، کہا ہم سے محمد بن فضیل نے، ان سے عمارہ بن قعقاع نے، انہوں نے ابوزرع"}
