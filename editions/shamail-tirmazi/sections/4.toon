metadata:

hadiths[5]{hadithnumber,arabic,bengali,english,french,indonesian,russian,urdu,grades,reference,international_number,narrator_chain,chapter_intro}:
{"hadithnumber": "31", "arabic": "حدثنا إسحاق بن موسى الأنصاري، حدثنا مَعْن بن عيسى، حدثنا مالك بن أنس، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، قَالَتْ‏:‏ كُنْتُ أُرَجِّلُ رَأْسَ رَسُولِ اللَّهِ صلى الله عليه وسلم وَأَنَا حَائِضٌ‏.‏", "bengali": "", "english": "“I used to comb the hair of Allah’s Messenger (Allah bless him and give him peace) while I was menstruating.”", "french": "", "indonesian": "", "russian": "", "urdu": "’’ سیدہ ام ھانی رضی اللہ عنہا سے مروی ہے، وہ فرماتی ہیں : میں نے رسول اللہ صلی اللہ علیہ وسلم کو دیکھا آپ صلی اللہ علیہ وسلم کے بال چار گیسوؤں میں بٹے ہوئے تھے۔ ‘‘", "grades": "", "reference": "", "international_number": "31", "narrator_chain": "", "chapter_intro": "The Combing Of The Hair Of Rasoolullah"}
{"hadithnumber": "32", "arabic": "حَدَّثَنَا يُوسُفُ بْنُ عِيسَى، قَالَ‏:‏ حَدَّثَنَا وَكِيعٌ، قَالَ‏:‏ حَدَّثَنَا الرَّبِيعُ بْنُ صَبِيحٍ، عَنْ يَزِيدَ بْنِ أَبَانَ هُوَ الرَّقَاشِيُّ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ‏:‏ كَانَ رَسُولُ اللهِ صلى الله عليه وسلم يُكْثِرُ دَهْنَ رَأْسِهِ وَتَسْرِيحَ لِحْيَتِهِ، وَيُكْثِرُ الْقِنَاعَ حَتَّى كَأَنَّ ثَوْبَهُ، ثَوْبُ زَيَّاتٍ‏.‏", "bengali": "", "english": "“Allah’s Messenger (Allah bless him and give him peace) made a frequent practice of oiling his head and combing his beard, and he often wore the head veil, so it was as if his robe was the robe of an oil dealer.”\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "", "chapter_intro": "The Combing Of The Hair Of Rasoolullah"}
{"hadithnumber": "33", "arabic": "حَدَّثَنَا هَنَّادُ بْنُ السَّرِيِّ، قَالَ‏:‏ حَدَّثَنَا أَبُو الأَحْوَصِ، عَنِ الأَشْعَثِ بْنِ أَبِي الشَّعْثَاءِ، عَنْ أَبِيهِ، عَنْ مَسْرُوقٍ، عَنْ عَائِشَةَ، قَالَتْ‏:‏ إِنْ كَانَ رَسُولُ اللهِ صلى الله عليه وسلم لَيُحِبُّ التَّيَمُّنَ فِي طُهُورِهِ إِذَا تَطَهَّرَ، وَفِي تَرَجُّلِهِ إِذَا تَرَجَّلَ، وَفِي انْتِعَالِهِ إِذَا انْتَعَلَ‏.‏", "bengali": "", "english": "“Allah’s Messenger (Allah bless him and give him peace) used to love tayammun  in his ritual purification when he purified himself", "french": " in his combing when he combed his hair", "indonesian": " and putting on his shoes when he donned them.”\"", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "", "chapter_intro": ""}
{"hadithnumber": "34", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، قَالَ‏:‏ حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، عَنْ هِشَامِ بْنِ حَسَّانَ، عَنِ الْحَسَنِ، عَنْ عَبْدِ اللهِ بْنِ مُغَفَّلٍ، قَالَ‏:‏ نَهَى رَسُولُ اللهِ صلى الله عليه وسلم عنِ التَّرَجُّلِ، إِلا غِبًّا‏.‏", "bengali": "", "english": "\"Allah’s Messenger (Allah bless him and give him peace) forbade combing except at intervals.”", "french": "", "indonesian": "", "russian": "", "urdu": "’’ ام المؤمنین سیدہ عائشہ صدیقہ رضی اللہ عنہا سے مروی ہے، وہ فرماتی ہیں : رسول اللہ صلی اللہ علیہ وسلم دائیں جانب سے شروع کرنا پسند فرماتے، اپنے وضوء کرنے میں جب وضوء کرتے، اور کنگھی کرتے وقت جب کنگھی کرتے، اورجوتا پہنتے وقت جب جو تا پہنتے۔ ‘‘", "grades": "", "reference": "", "international_number": "34", "narrator_chain": "", "chapter_intro": "The Combing Of The Hair Of Rasoolullah"}
{"hadithnumber": "35", "arabic": "حَدَّثَنَا الْحَسَنُ بْنُ عَرَفَةَ، قَالَ‏:‏ حَدَّثَنَا عَبْدُ السَّلامِ بْنُ حَرْبٍ، عَنْ يَزِيدَ بْنِ أَبِي خَالِدٍ، عَنْ أَبِي الْعَلاءِ الأَوْدِيِّ، عَنْ حُمَيْدِ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ رَجُلٍ مِنْ أَصْحَابِ النَّبِيِّ صلى الله عليه وسلم‏:‏ أَنَّ النَّبِيَّ صلى الله عليه وسلم، كَانَ يَتَرَجَّلُ غِبًّا‏.‏", "bengali": "", "english": "\"The Prophet (Allah bless him and give him peace) used to comb his hair at intervals.”", "french": "", "indonesian": "", "russian": "", "urdu": "’’ سیدنا عبداللہ بن مغفل رضی اللہ عنہ سے مروی ہے، وہ فرماتے ہیں : رسول اللہ صلی اللہ علیہ وسلم نے بلاناغہ ؍روزانہ کنگھی کرنے سے منع فرمایا۔‘‘", "grades": "", "reference": "", "international_number": "35", "narrator_chain": "", "chapter_intro": "The Combing Of The Hair Of Rasoolullah"}
