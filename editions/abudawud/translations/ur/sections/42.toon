{"hadithnumber": "4747", "text": "مختار بن فلفل کہتے ہیں کہ  میں نے انس بن مالک رضی اللہ عنہ کو کہتے سنا:  ( ایک بار )  رسول اللہ صلی"}
{"hadithnumber": "4748", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں  جب اللہ کے نبی اکرم صلی اللہ علیہ وسلم کو معراج میں جنت میں لے جا"}
{"hadithnumber": "4749", "text": "عبدالسلام بن ابی حازم ابوطالوت بیان کرتے ہیں کہ  میں نے ابوبرزہ رضی اللہ عنہ کو دیکھا وہ عبیداللہ بن"}
{"hadithnumber": "4750", "text": "براء بن عازب رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مسلمان سے جب قبر م"}
{"hadithnumber": "4751", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  اللہ کے نبی اکرم صلی اللہ علیہ وسلم بنی نجار کے کھجور کے ایک ب"}
{"hadithnumber": "4752", "text": "عبدالوہاب سے اسی جیسی سند سے اس طرح کی حدیث مروی ہے  اس میں ہے:  جب بندہ قبر میں رکھ دیا جاتا ہے، او"}
{"hadithnumber": "4753", "text": "براء بن عازب رضی اللہ عنہما کہتے ہیں کہ  ہم رسول اللہ صلی اللہ علیہ وسلم کے ساتھ انصار کے ایک شخص کے"}
{"hadithnumber": "4754", "text": "ابوعمر زاذان کہتے ہیں کہ  میں نے براء رضی اللہ عنہ کو نبی اکرم صلی اللہ علیہ وسلم سے روایت کرتے سنا،"}
{"hadithnumber": "4755", "text": "حسن بصری کہتے ہیں کہ  ام المؤمنین عائشہ رضی اللہ عنہا نے جہنم کا ذکر کیا تو رونے لگیں، رسول اللہ صلی"}
{"hadithnumber": "4756", "text": "ابوعبیدہ بن جراح رضی اللہ عنہ کہتے ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا:  ن"}
{"hadithnumber": "4757", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم لوگوں میں کھڑے ہوئے، اللہ کی"}
{"hadithnumber": "4758", "text": "ابوذر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے جماعت ۲؎ سے ایک بالشت"}
{"hadithnumber": "4759", "text": "ابوذر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تمہارا کیا حال ہو گا ۱؎ جب"}
{"hadithnumber": "4760", "text": "ام المؤمنین ام سلمہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  عنقریب تم پر"}
{"hadithnumber": "4761", "text": "اس سند سے بھی ام سلمہ رضی اللہ عنہا نے نبی اکرم صلی اللہ علیہ وسلم سے اسی مفہوم کی حدیث روایت کی ہے،"}
{"hadithnumber": "4762", "text": "عرفجہ رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  میری امت میں کئی"}
{"hadithnumber": "4763", "text": "عبیدہ سے روایت ہے کہ  علی رضی اللہ عنہ نے اہل نہروان ۱؎ کا ذکر کیا اور کہا: ان میں چھوٹے ہاتھ کا ایک"}
{"hadithnumber": "4764", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں  علی رضی اللہ عنہ نے نبی اکرم صلی اللہ علیہ وسلم کے پاس مٹی سے آ"}
{"hadithnumber": "4765", "text": "ابو سعید خدری اور انس بن مالک رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:"}
{"hadithnumber": "4766", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے اسی طرح فرمایا، البتہ اس میں یہ ہے کہ"}
{"hadithnumber": "4767", "text": "سوید بن غفلہ کہتے ہیں کہ  علی رضی اللہ عنہ نے کہا: جب میں رسول اللہ صلی اللہ علیہ وسلم کی کوئی حدیث"}
{"hadithnumber": "4768", "text": "زید بن وہب جہنی بیان کرتے ہیں کہ  وہ اس فوج میں شامل تھے جو علی رضی اللہ عنہ کے ساتھ تھی، اور جو خوا"}
{"hadithnumber": "4769", "text": "ابوالوضی کہتے ہیں کہ  علی رضی اللہ عنہ نے کہا: «مخدج»  ( لنجے )  کو تلاش کرو، پھر راوی نے پوری حدیث"}
{"hadithnumber": "4770", "text": "ابومریم کہتے ہیں کہ  یہ «مخدج»  ( لنجا )  مسجد میں اس دن ہمارے ساتھ تھا ہم اس کے ساتھ رات دن بیٹھا ک"}
{"hadithnumber": "4771", "text": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جس کا مال لینے ک"}
{"hadithnumber": "4772", "text": "سعید بن زید رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جو اپنا مال بچانے میں"}
