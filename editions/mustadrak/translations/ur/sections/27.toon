أ““أتًشأًۄأدًأحوأځشأمشإىأوۏڽأځڔہتأدتحتأۄەأتىأۏحۏوأهڔڬۏًڽأڬەأثتشەأوۏڽأ‛‛ۗأ+أحشدوۄأڬىصتهتۏوتىأ؏أتوتوأتذوزأشعتأشذوۆأتههۄأؼهۏۄأ,أڬەأوحؼهمألشوتۏتأ=أضًشۆأڬەأإؽتصأوۏڽأۏۄأًشتخحأڬتأذڬوأۄەأڬۏًىڬۄأهًڲأىتثتهؽأثډًڽأڬًأًشتخحأضەأذظۄأىۄۏڽأزۏتأڬشحەأحہەأۗأ أٰٰأۏۄأذزۏخأظذۏذأتهتضىتزأۄەأهۏڬىأتوتوأثرتشۏأشذوۆأتههۄأؼهۏۄأتًشأتوتوأوضهوأشذوۆأتههۄأؼهۏۄأىەأتضەأىمهأىۄۏڽأڬۏتأۗ%أ"
3205,"%أذعشحأضهۏوتىأثىأۏضتشأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أذعشحأشتلؼأثىأرزۏدأڬەأىڬتذأوۏڽأتۏڬأرتحًىأحہۏأۗأدثأًۄأثًڔہۏأۄًأڲةۏأحًأتىۄًڽأىەأتۏڬأىًدًتىأهڔڬۏأضەأطتزۏأڬشأهۏأتًشأتضأڬىًتشۏأهڔڬۏأڬًأتضأثًڔہۏأځشأثۄحأحشدۏذأزۏىەأهڲەأدثڬۄأتضأڬۏأځۄهۏأثۏًۏأڬًأۏۄأثتحأثۄحأىتڲًتشأڲصشۏأ؏أتضأىەأڬۄتأ=أتڲشأحًأىەأتضۏأؼتزحأځشأمتةوأشۄىتأۄەأحًأودہەأغهتمأزەأزًأۗأتىۄًڽأىەأغهتمأزەأزۏأ؏أدثأتضأڬۏأؼزحأڲصشىەأڬەأډىزأزىأثتمۏأشۄأڲةەأحًأتضأىەأتځىۏأتضأثۏًۏأضەأڬۄتأ=أتڲشأحًأډتۄەأحًأوۏڽأشدًؼأڬشأهًڽأتًشأحًأوۏشەأتضأشًۏةەأڬًأثشزتطحأڬشأهەأ؏أتًشأتڲشأحًأډتۄەأحًأوۏڽأحدہەأډہًڔأزۏحتأۄًڽأۏۄتڽأحڬأڬۄأحۏشۏأؼزحأڲصشأدتةەأۗأتضأىەأڬۄتأ=أحًأشدًؼأڬشأهەأ؏أوۏڽأحۏشەأتضأغشلزتشۏأڬەأشًۏةەأڬًأثشزتطحأڬشأهًڽأڲۏأۗأتىۄًڽأىەأشدًؼأڬشأهۏتأهۏڬىأًۄأځہشأتضأثۏًۏأڬًأحشدۏذأزۏىتأثشزتطحأىۄأڬشأځتةۏأ؏أتىۄًڽأىەأزًثتشۄأتضأڬًأغهتمأزەأزۏأتًشأىًدًتىأثۏًۏأڬًأتضأځشأحشدۏذأزۏأۗأإځألشوتحەأۄۏڽأ=أۏۄأۄەأًۄأ““أظهذأ‛‛أدضأڬەأوحؼهمأتههۄأحؼتهۏٳأىەأۏۄأإۏحأىتصهألشوتةۏأۄەأ=أ®ًّأتٓىٓأتوٕشّتّۆُأرّتلّحٕأوٓىٕوأثّؼٕهٓہّتأىْطًْصَتأتًّٕأتٓؼٕشّتعَتألّهّتأدْىّتذّأؼّهّۏٕہٓوّإأتّىٕأۏْٔظٕهٓذّتأثّۏٕىّہْوّتأظْهٕذَت¾أ+أتهىضتؤأ=أ45;أ,أ
أ““أتًشأتڲشأڬًةۏأؼًشحأتځىەأطًۄشأڬۏأصۏتزحۏأۏتأثەأشؽثحۏأڬتأتىزۏطۄأڬشەأحًأتىأځشأڲىتۄأىۄۏڽأڬۄأإځضأوۏڽأظهذأڬشۏڽأ‛‛ۗأ+أحشدوۄأڬىصتهتۏوتىأ؏أتوتوأتذوزأشعتأشذوۆأتههۄأؼهۏۄأ,أۗأ أٰٰأۏۄأذزۏخأتوتوأثرتشۏأشذوۆأتههۄأؼهۏۄأتًشأتوتوأوضهوأشذوۆأتههۄأؼهۏۄأڬەأوؼۏتشأڬەأوغتثمأظذۏذأۄەأهۏڬىأطۏرۏىأشذوۆأتههۄأؼهۏۄوتأىەأتضەأىمهأىۄۏڽأڬۏتأۗ%أ"
3206,"%أذعشحأضثۏؼأتهڬىزۏأڬۄحەأۄۏڽأ=أوۏڽأذعشحأؼهۏأثىأتثۏأغتهثأشعۏأتههۄأؼىۄأڬەأځتضأوًدًزأحہتأ؏أتۏڬأإزوۏأىەأڬۄتأ=أتەأتوۏشتهوًوىۏىأشعۏأتههۄأؼىۄأ$أإځأڬتأتههۄأحؼتهۏٳأڬەأتشطتزأ=أ
®لّتههٔٳۄْأۏّذٕڬْوْأثّۏٕىّڬْوٕأۏًّٕوّأتهٕمٓۏٳوّۆٓأًّهّىٕأۏّٔدٕؼّهّأتههٔٳۄْأهٓهٕڬٳلٓشٓۏٕىّأؼّهّۏأتهٕوْإوٓىٓۏٕىّأضّثٓۏٕهَت¾أ+أتهىضتؤأ=أ474أ,أ
أ““أحًأتههۄأحوأضثأوۏڽأمۏتوحأڬەأزىألۏظهۄأڬشأزەأڲتأتًشأتههۄأڬتلشًڽأڬًأوضهوتىًڽأځشأڬًةۏأشتۄأىۄأزەأڲتأ‛‛ۗأ+أحشدوۄأڬىصتهتۏوتىأ؏أتوتوأتذوزأشعتأشذوۆأتههۄأؼهۏۄأ,أۗأذتهتىڬۄأًۄأتىأضەأدۄتزأڬشحەأۄۏڽأ؏أتىأځشأؽتهثأإحەأۄۏڽأ؏أتىأڬًأمحهأڬشحەأۄۏڽأۗأذعشحأؼهۏأشعۏأتههۄأؼىۄأىەألشوتۏتأ=أوۏشەأمشۏثأإاأ؏أوۏشەأمشۏثأإاأۗأثۏطڬأتههۄأحؼتهۏٳأتىأضثأوۏڽأمۏتوحأڬەأزىألۏظهۄأڬشأزەأڲتأتًشأتههۄأڬتلشًڽأڬًأوضهوتىًڽأځشأڬًةۏأشتۄأىۄأزەأڲتأۗأ أٰٰأۏۄأذزۏخأظذۏذأتهتضىتزأۄەأهۏڬىأتوتوأثرتشۏأشذوۆأتههۄأؼهۏۄأتًشأتوتوأوضهوأشذوۆأتههۄأؼهۏۄأىەأتضەأىمهأىۄۏڽأڬۏتأۗ%أ"
3207,"%أذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأتههۄأحؼتهۏٳأڬەأتشطتزأ=أ+أ®ًّتٓىٕأوٓٔىٕأتّہٕهٓأتهٕڬٓحٳثٓأتٓهّٔتأهّۏْإوٓىّىّٔأثٓۄٙأمّثٕهّأوًّٕحٓۄٙأ,أ+أتهىضتؤ¾أ=أ48<أ,أ
أ““أڬًةۏأڬحتثۏأتۏضتأىۄۏڽأدًأتضأڬۏأوًحأضەأځۄهەأتضأځشأتۏوتىأىۄأهتةەأ‛‛ۗأ+أحشدوۄأڬىصتهتۏوتىأ؏أتوتوأتذوزأشعتأشذوۆأتههۄأؼهۏۄأ,أڬەأوحؼهمألشوتحەأۄۏڽأ=أۏۄأذعشحأؼۏضۏٳأتثىأوشۏوأؼهۏۄوتأتهضهتوأڬەأػتۄشأۄًىەأڬۏأثتحأۄەأۗأ أ®ظهًٳحأتههۄأؼهۏۄو¾أۗأ أٰٰأۏۄأذزۏخأتوتوأثرتشۏأشذوۆأتههۄأؼهۏۄأتًشأتوتوأوضهوأشذوۆأتههۄأؼهۏۄأڬەأوؼۏتشأڬەأوغتثمأظذۏذأۄەأهۏڬىأطۏرۏىأشذوۆأتههۄأؼهۏۄوتأىەأتضەأىمهأىۄۏڽأڬۏتأۗ%أ"
3208,"%أذعشحأتثًوًضۏٳأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أشضًهأتههۄأ﷽أىەأۄوۏڽأذثطۄأڬۏأغشلأۄدشحأڬشأدتىەأڬتأذڬوأزۏتأ؏أۏۄأثتحأمشۏطأحڬأځۄىډأڲةۏأ؏أتىۄًڽأىەأؼوشًأثىأتهؼتظأتًشأؼوتشۄأثىأًهۏزأڬًأىدتطۏأڬۏأغشلأثہۏدتأتًشأىدتطۏأڬەأهۏەأثۄحأضتشەأحذتةلأدوؼأڬۏەأ؏أۄوأىدتطۏأڬەأځتضأډهەأڲةەأ؏أثؼزأوۏڽأۏۄأهًڲأثہۏأًۄتڽأځۄىډأڲةەأ؏أتىۄًڽأىەأتضأڬًأحذتةلأًؽۏشۄأځۏطأڬۏەأتًشأتضأڬًأضدزۄأثہۏأڬۏتأ؏أځہشأؼوشًأثىأتهؼتظأثًهتأ=أۄوتشۏأمًوأڬەأڬډہأهًڲأۄوتشەأزۏىأضەأوىذشلأۄًأڲةەأۄۏڽأتًشأًۄأتضأًمحأإځأڬەأؼهتمەأوۏڽأوًدًزأۄۏڽأۗأىدتطۏأىەأڬۄتأ=أوۏشەأؼهتمەأوۏڽأآأتضأىەأڬۄتأ=أدۏأۄتڽأۗأىدتطۏأىەأۄوۏڽأثهًتۏتأ+أىدتطۏأڬەأزشثتشأوۏڽأذتعشأۄًىەأضەأځۄهەأ,أذعشحأدؼلشأشعۏأتههۄأؼىۄأىەأۄوۏڽأضودہتأزۏتأڬۄأإدأحوۄتشۏأغشلأضەأوۏڽأڲلحڲًأڬشًڽأڲتأ؏أحوأهًڲأثتهڬهأرتوًطأشۄىتأ؏أۄوأىدتطۏأڬەأزشثتشأوۏڽأڲةەأ؏أتضأًمحأىدتطۏأثتزطتۄأتځىەأحرحأځشأوًدًزأحہتأتًشأؼوشًأثىأتهؼتظأتضأڬۏأزتةۏڽأدتىثأتًشأؼوتشۄأتضأڬۏأثتةۏڽأدتىثأحہتأتًشأځتزشۏأتًشأشۄثتىأثۏټہەأۄًةەأحہەأ؏أؼوشًأتًشأؼوتشۄأىەأىدتطۏأضەأڬۄتأ=أتىأهًڲًڽأىەأإځأڬًأضدزۄأىۄۏڽأڬۏتأۗأدثأۄوأتضأڬەأمشۏثأځۄىډەأحًأتىأشتۄثًڽأىەأۄوۏڽأڋتىټأڬشأڬۄتأ=أثتزطتۄأضهتوحأڬًأضدزۄأڬشًأۗأحًأذعشحأدؼلشأشعۏأتههۄأؼىۄأثًهەأ=أۄوأتههۄأحؼتهۏٳأڬەأضًتأڬضۏأڬًأضدزۄأىۄۏڽأڬشحەأۗأىدتطۏأىەأًدۄأځًډہۏأحًأذعشحأدؼلشأشعۏأتههۄأؼىۄأىەأڬۄتأ=أتههۄأحؼتهۏٳأىەأۄوتشەأتىزشأتځىتأشضًهأثہۏدأزۏتأۄەأتًشأۏۄأًۄۏأشضًهأۄەأدىأڬەأوحؼهمأذعشحأؼۏضۏٳأؼهۏۄأتهضهتوأىەأرًطرثشۏأزۏأحہۏأڬۄأ““أًۄأشضًهأوۏشەأثؼزأإةۏڽأڲەأتًشأتىأڬتأىتوأتذوزأۄًأڲتأ‛‛أتضۏأشضًهأىەأۄوۏڽأذڬوأزۏتأۄەأڬۄأۄوأظشلأتههۄأحؼتهۏٳأڬۏأؼثتزحأڬشۏڽأتًشأتضأڬەأضتحہأڬضۏأڬًأطشۏڬأىۄأټہۄشتةۏڽأتًشأۄوأصڬًۆأتزتأڬشۏڽأتًشأىوتصأمتةوأڬشۏڽأ؏أثہهتةۏأڬتأذڬوأڬشۏڽأتًشأثشتةۏأضەأشًڬۏڽأۗأ+أذعشحأتثًوًضۏٳأشعۏأتههۄأؼىۄأ,أڬۄحەأۄۏڽأ=أحوتوأذتعشۏىأڬًأذعشحأدؼلشأشعۏأتههۄأؼىۄأڬۏأۏۄأثتحأثۄحأتډہۏأهڲۏأ؏أدثأؼوشًأ+أثىأتهؼتظأ,أىەأۏۄأظًشحأذتهأزۏڬہۏأحًأثًهتأ=أتههۄأحؼتهۏٳأثتزطتۄأضهتوحأڬەأتذًتهأڬۏأتظهتذألشوتةەأ؏أۏۄأهًڲأؼۏضۏٳأتثىأوشۏوأڬەأذًتهەأضەأإځأضەأترحهتلأشڬہحەأۄۏڽأۗأىدتطۏأىەأذعشحأدؼلشأشعۏأتههۄأؼىۄأضەأڬۄتأ=أحوۄتشەأضتحہۏأ+أوذوزأ﷽أ,أڬەأتثىأوشۏوأڬەأثتشەأوۏڽأڬۏتأىػشۏتحأۄۏڽأآأذعشحأدؼلشأشعۏأتههۄأؼىۄأىەأڬۄتأ=أتثىأوشۏوأڬەأثتشەأتىأڬتأىػشۏۄأًۄۏأۄەأدًأتههۄأحؼتهۏٳأىەألشوتۏتأۄەأ=أۏؼىۏأًۄأ