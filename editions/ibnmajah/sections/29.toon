hadiths[count]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}:
2987,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو أُسَامَةَ، عَنْ عَوْفٍ، عَنْ زُرَارَةَ بْنِ أَوْفَى، حَدَّثَنِي عَبْدُ اللَّهِ بْنُ سَلاَمٍ، قَالَ لَمَّا قَدِمَ النَّبِيُّ ـ صلى الله عليه وسلم ـ الْمَدِينَةَ انْجَفَلَ النَّاسُ قِبَلَهُ وَقِيلَ قَدْ قَدِمَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ قَدْ قَدِمَ رَسُولُ اللَّهِ قَدْ قَدِمَ رَسُولُ اللَّهِ ‏.‏ ثَلاَثًا فَجِئْتُ فِي النَّاسِ لأَنْظُرَ فَلَمَّا تَبَيَّنْتُ وَجْهَهُ عَرَفْتُ أَنَّ وَجْهَهُ لَيْسَ بِوَجْهِ كَذَّابٍ فَكَانَ أَوَّلَ شَىْءٍ سَمِعْتُهُ تَكَلَّمَ بِهِ أَنْ قَالَ ‏ ‏ يَا أَيُّهَا النَّاسُ أَفْشُوا السَّلاَمَ وَأَطْعِمُوا الطَّعَامَ وَصِلُوا الأَرْحَامَ وَصَلُّوا بِاللَّيْلِ وَالنَّاسُ نِيَامٌ تَدْخُلُوا الْجَنَّةَ بِسَلاَمٍ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن النسائی/الحج ۱۷۷ (۲۹۸۳)،(تحفة الأشراف:۱۸۳۸۲)، وقد أخرجہ: مسند احمد (۶/۴۰۴،۴۰۵),,‘Abdullah bin Salam said:,Chapters on Food
2988,"حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى الأَزْدِيُّ، حَدَّثَنَا حَجَّاجُ بْنُ مُحَمَّدٍ، عَنِ ابْنِ جُرَيْجٍ، قَالَ سُلَيْمَانُ بْنُ مُوسَى حُدِّثْنَا عَنْ نَافِعٍ، أَنَّ عَبْدَ اللَّهِ بْنَ عُمَرَ، كَانَ يَقُولُ إِنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ أَفْشُوا السَّلاَمَ وَأَطْعِمُوا الطَّعَامَ وَكُونُوا إِخْوَانًا كَمَا أَمَرَكُمُ اللَّهُ عَزَّ وَجَلَّ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Hasan,takhreej: «سنن ابی داود/الحج ۵۶ (۱۹۰۴)، سنن الترمذی/الحج ۳۹ (۸۶۴)، سنن النسائی/الحج ۱۷۴ (۲۹۷۹)،(تحفة الأشراف:۷۳۷۹)، وقد أخرجہ: موطا امام مالک/الحج ۳۴ (۱۳۰)، مسند احمد (۲/۵۳،۶۰،۶۱،۱۲۰)، سنن الدارمی/المناسک ۲۵ (۱۸۸۰),,‘Abdullah bin ‘Umar used to say that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Food
2989,"حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، عَنْ يَزِيدَ بْنِ أَبِي حَبِيبٍ، عَنْ أَبِي الْخَيْرِ، عَنْ عَبْدِ اللَّهِ بْنِ عَمْرٍو، ‏.‏ أَنَّ رَجُلاً، سَأَلَ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ فَقَالَ يَا رَسُولَ اللَّهِ أَىُّ الإِسْلاَمِ خَيْرٌ قَالَ ‏ ‏ تُطْعِمُ الطَّعَامَ وَتَقْرَأُ السَّلاَمَ عَلَى مَنْ عَرَفْتَ وَمَنْ لَمْ تَعْرِفْ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۹۹۴، ومصباح الزجاجة:۱۰۴۷),,It was\nnarrated from ‘Abdullah bin ‘Amr that a man asked the\nMessenger\nof Allah (ﷺ):,Chapters on Food
2990,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ الرَّقِّيُّ، حَدَّثَنَا يَحْيَى بْنُ زِيَادٍ الأَسَدِيُّ، أَنْبَأَنَا ابْنُ جُرَيْجٍ، أَنْبَأَنَا أَبُو الزُّبَيْرِ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ طَعَامُ الْوَاحِدِ يَكْفِي الاِثْنَيْنِ وَطَعَامُ الاِثْنَيْنِ يَكْفِي الأَرْبَعَةَ وَطَعَامُ الأَرْبَعَةِ يَكْفِي الثَّمَانِيَةَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الحج ۵۳ (۱۶۰۰)، سنن ابی داود/الحج ۵۶ (۱۹۰۲)،(تحفة الأشراف (۵۱۵۵)، وقد أخرجہ: صحیح مسلم/الحج ۶۸ (۱۳۳۲)، مسند احمد (۴/ ۳۵۳،۳۵۵،۳۸۱)، سنن الدارمی/المناسک ۷۷ (۱۹۶۳),,It was\nnarrated from Jabir bin ‘Abdullah that the Messenger of Allah\n(ﷺ)\nsaid:,Chapters on Food
2991,"حَدَّثَنَا الْحَسَنُ بْنُ عَلِيٍّ الْخَلاَّلُ، حَدَّثَنَا الْحَسَنُ بْنُ مُوسَى، حَدَّثَنَا سَعِيدُ بْنُ زَيْدٍ، حَدَّثَنَا عَمْرُو بْنُ دِينَارٍ، قَهْرَمَانُ آلِ الزُّبَيْرِ قَالَ سَمِعْتُ سَالِمَ بْنَ عَبْدِ اللَّهِ بْنِ عُمَرَ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، عُمَرَ بْنِ الْخَطَّابِ قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِنَّ طَعَامَ الْوَاحِدِ يَكْفِي الاِثْنَيْنِ وَإِنَّ طَعَامَ الاِثْنَيْنِ يَكْفِي الثَّلاَثَةَ وَالأَرْبَعَةَ وَإِنَّ طَعَامَ الأَرْبَعَةِ يَكْفِي الْخَمْسَةَ وَالسِّتَّةَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۷۹۷، ومصباح الزجاجة:۱۰۴۸)، وقد أخرجہ: مسند احمد (۱/۳۰۸،۳/۳۵۳،۴/۱۷۷،۱۸۶),,It was\nnarrated from ‘Umar bin Khattab that the Messenger of Allah\n(ﷺ)\nsaid:,Chapters on Food
2992,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَفَّانُ، ح وَحَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، قَالاَ حَدَّثَنَا شُعْبَةُ، عَنْ عَدِيِّ بْنِ ثَابِتٍ، عَنْ أَبِي حَازِمٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ الْمُؤْمِنُ يَأْكُلُ فِي مِعًى وَاحِدٍ وَالْكَافِرُ يَأْكُلُ فِي سَبْعَةِ أَمْعَاءٍ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۷۲۸، مصباح الزجاجة:۱۰۴۹)، وقدأخرجہ: مسند احمد (۴/۱۷۷،۱۸۶),,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Food
2993,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، عَنْ عُبَيْدِ اللَّهِ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ الْكَافِرُ يَأْكُلُ فِي سَبْعَةِ أَمْعَاءٍ وَالْمُؤْمِنُ يَأْكُلُ فِي مِعًى وَاحِدٍ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن الترمذی/الحج ۹۵ (۹۳۹)،(تحفة الأشراف:۱۸۳۶۰)، وقد أخرجہ: سنن ابی داود/الحج ۸۰ (۱۹۸۸)، مسند احمد (۶/۴۰۵،۴۰۶),,It was\nnarrated from Ibn ‘Umar that the Prophet (ﷺ) said:,Chapters on Food
2994,"حَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا أَبُو أُسَامَةَ، عَنْ بُرَيْدِ بْنِ عَبْدِ اللَّهِ، عَنْ جَدِّهِ أَبِي بُرْدَةَ، عَنْ أَبِي مُوسَى، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ الْمُؤْمِنُ يَأْكُلُ فِي مِعًى وَاحِدٍ وَالْكَافِرُ يَأْكُلُ فِي سَبْعَةِ أَمْعَاءٍ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۸۹۰)، وقد أخرجہ: صحیح البخاری/العمرة ۴ (۱۷۸۲)، جزاء الصید ۲۶ (۱۸۶۳)، صحیح مسلم/الحج ۳۶ (۱۲۵۶)، سنن النسائی/الصیام ۴ (۲۱۱۲)، مسند احمد (۱/۲۲۹،۳۰۸)، سنن الدارمی/المناسک ۴۰ (۱۹۰۱،۱۹۰۲),,It was\nnarrated from Abu Musa that the Messenger of Allah (ﷺ) said:,Chapters on Food
2995,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ، حَدَّثَنَا سُفْيَانُ، عَنِ الأَعْمَشِ، عَنْ أَبِي حَازِمٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ مَا عَابَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ طَعَامًا قَطُّ إِنْ رَضِيَهُ أَكَلَهُ وَإِلاَّ تَرَكَهُ ‏.‏ حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، عَنِ الأَعْمَشِ، عَنْ أَبِي يَحْيَى، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ مِثْلَهُ ‏.‏ قَالَ أَبُو بَكْرٍ نُخَالِفُ فِيهِ يَقُولُونَ عَنْ أَبِي حَازِمٍ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «صحیح البخاری/جزاء الصید ۲۶ (۱۸۶۰تعلیقاً)،(تحفة الأشراف:۲۴۲۹)، وقد أخرجہ: مسند احمد (۱/۳۰۸،۳۵۲،۳۶۱،۳۹۷),,It was\nnarrated from Abu Hazim that Abu Hurairah said:,Chapters on Food
2996,"حَدَّثَنَا جُبَارَةُ بْنُ الْمُغَلِّسِ، حَدَّثَنَا كَثِيرُ بْنُ سُلَيْمٍ، سَمِعْتُ أَنَسَ بْنَ مَالِكٍ، يَقُولُ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ أَحَبَّ أَنْ يُكْثِرَ اللَّهُ خَيْرَ بَيْتِهِ فَلْيَتَوَضَّأْ إِذَا حَضَرَ غَدَاؤُهُ وَإِذَا رُفِعَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۹۵۹، ومصباح الزجاجة:۱۰۵۰)، و قد أخرجہ: سنن الترمذی/الحج ۷ (۸۱۶)، مسند احمد (۱/۲۴۶),,Kathir\nbin Sulaim narrated that he heard Anas bin Malik say:,Chapters on Food
2997,"حَدَّثَنَا جَعْفَرُ بْنُ مُسَافِرٍ، حَدَّثَنَا صَاعِدُ بْنُ عُبَيْدٍ الْجَزَرِيُّ، حَدَّثَنَا زُهَيْرُ بْنُ مُعَاوِيَةَ، حَدَّثَنَا مُحَمَّدُ بْنُ جُحَادَةَ، حَدَّثَنَا عَمْرُو بْنُ دِينَارٍ الْمَكِّيُّ، عَنْ عَطَاءِ بْنِ يَسَارٍ، عَنْ أَبِي هُرَيْرَةَ، عَنْ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ أَنَّهُ خَرَجَ مِنَ الْغَائِطِ فَأُتِيَ بِطَعَامٍ فَقَالَ رَجُلٌ يَا رَسُولَ اللَّهِ أَلاَ آتِيكَ بِوَضُوءٍ قَالَ ‏ ‏ أُرِيدُ الصَّلاَةَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «صحیح البخاری/العمرة ۳ (۱۷۷۵)، المغازي ۴۴ (۴۲۵۳)، صحیح مسلم/الحج ۳۵ (۱۲۵۵)، سنن ابی داود/المناسک ۸۰ (۱۹۹۲)(تحفة الأشراف:۱۷۵۷۴)، وقد أخرجہ: مسند احمد (۶/۲۲۸،۷۰،۱۲۹،۱۳۹،۱۴۳،۱۵۵),,"It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nwent out\nto toilet, then food was brought. A man said:",Chapters on Food
2998,"حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ مِسْعَرٍ، عَنْ عَلِيِّ بْنِ الأَقْمَرِ، عَنْ أَبِي جُحَيْفَةَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ لاَ آكُلُ مُتَّكِئًا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «حدیث ابن عمر أخرجہ: صحیح مسلم/الحج ۳۵ (۱۲۵۵)، سنن الترمذی/الحج ۹۳ (۹۳۶)،(تحفة الأشراف:۷۳۲۱)، حدیث عائشہ أخرجہ: سنن الترمذی/ الحج ۹۳ (۹۳۶)،(تحفة الأشراف:۱۷۳۷۳)، وقد أخرجہ: صحیح البخاری/العمرة ۳ (۱۷۷۷)، سنن ابی داود/الحج ۸۰ (۱۹۹۴)، مسند احمد (۱/۲۴۶),,It was\nnarrated from Abu Juhaifah that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Food
2999,"حَدَّثَنَا عَمْرُو بْنُ عُثْمَانَ بْنِ سَعِيدِ بْنِ كَثِيرِ بْنِ دِينَارٍ الْحِمْصِيُّ، حَدَّثَنَا أَبِي، أَنْبَأَنَا مُحَمَّدُ بْنُ عَبْدِ الرَّحْمَنِ بْنِ عِرْقٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ بُسْرٍ، قَالَ أَهْدَيْتُ لِلنَّبِيِّ ـ صلى الله عليه وسلم ـ شَاةً فَجَثَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَلَى رُكْبَتَيْهِ يَأْكُلُ فَقَالَ أَعْرَابِيٌّ مَا هَذِهِ الْجِلْسَةُ فَقَالَ ‏ ‏ إِنَّ اللَّهَ جَعَلَنِي عَبْدًا كَرِيمًا وَلَمْ يَجْعَلْنِي جَبَّارًا عَنِيدًا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/العمرة ۶ (۱۷۸۴)، الجہاد ۱۲۵ (۲۹۸۵)، صحیح مسلم/الحج ۱۷ (۱۲۱۲)، سنن الترمذی/الحج ۹۱ (۹۳۴)،(تحفة الأشراف:۹۶۸۷)، وقد أخرجہ: سنن ابی داود/الحج ۸۱ (۱۹۹۵)، مسند احمد (۱/۱۹۷)، سنن الدارمی/المناسک ۴۱ (۱۹۰۴),,‘Abdullah bin Busr said:,Chapters on Food
3000,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، عَنِ هِشَامٍ الدَّسْتَوَائِيِّ، عَنْ بُدَيْلِ بْنِ مَيْسَرَةَ، عَنْ عَبْدِ اللَّهِ بْنِ عُبَيْدِ بْنِ عُمَيْرٍ، عَنْ عَائِشَةَ، قَالَتْ كَانَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ يَأْكُلُ طَعَامًا فِي سِتَّةِ نَفَرٍ مِنْ أَصْحَابِهِ فَجَاءَ أَعْرَابِيٌّ فَأَكَلَهُ بِلُقْمَتَيْنِ فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ أَمَا أَنَّهُ لَوْ كَانَ قَالَ بِسْمِ اللَّهِ لَكَفَاكُمْ فَإِذَا أَكَلَ أَحَدُكُمْ طَعَامًا فَلْيَقُلْ بِسْمِ اللَّهِ فَإِنْ نَسِيَ أَنْ يَقُولَ بِسْمِ اللَّهِ فِي أَوَّلِهِ فَلْيَقُلْ بِسْمِ اللَّهِ فِي أَوَّلِهِ وَآخِرِهِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/العمرة ۵ (۱۷۸۳)، صحیح مسلم/الحج ۱۷ (۱۲۱۱)،(تحفة الأشراف:۱۷۰۴۸),,It was\nnarrated that ‘Aishah said:,Chapters on Food
3001,"حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، حَدَّثَنَا سُفْيَانُ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ أَبِيهِ، عَنْ عُمَرَ بْنِ أَبِي سَلَمَةَ، قَالَ قَالَ لِيَ النَّبِيُّ ـ صلى الله عليه وسلم ـ وَأَنَا آكُلُ ‏ ‏ سَمِّ اللَّهَ عَزَّ وَجَلَّ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الحج ۹ (۱۷۴۱)،(تحفة الأشراف:۱۸۲۵۳)، وقد أخرجہ: مسند احمد (۶/۲۹۹),,It was\nnarrated that ‘Umar bin Abu Salamah said:,Chapters on Food
3002,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا الْهِقْلُ بْنُ زِيَادٍ، حَدَّثَنَا هِشَامُ بْنُ حَسَّانَ، عَنْ يَحْيَى بْنِ أَبِي كَثِيرٍ، عَنْ أَبِي سَلَمَةَ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ لِيَأْكُلْ أَحَدُكُمْ بِيَمِينِهِ وَلْيَشْرَبْ بِيَمِينِهِ وَلْيَأْخُذْ بِيَمِينِهِ وَلْيُعْطِ بِيَمِينِهِ فَإِنَّ الشَّيْطَانَ يَأْكُلُ بِشِمَالِهِ وَيَشْرَبُ بِشِمَالِهِ وَيُعْطِي بِشِمَالِهِ وَيَأْخُذُ بِشِمَالِهِ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «أنظر ما قبلہ,,It was\nnarrated from Abu Hurairah that the Prophet (ﷺ) said:,Chapters on Food
3003,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَمُحَمَّدُ بْنُ الصَّبَّاحِ، قَالاَ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ الْوَلِيدِ بْنِ كَثِيرٍ، عَنْ وَهْبِ بْنِ كَيْسَانَ، سَمِعَهُ مِنْ، عُمَرَ بْنِ أَبِي سَلَمَةَ قَالَ كُنْتُ غُلاَمًا فِي حِجْرِ النَّبِيِّ ـ صلى الله عليه وسلم ـ وَكَانَتْ يَدِي تَطِيشُ فِي الصَّحْفَةِ فَقَالَ لِي ‏ ‏ يَا غُلاَمُ سَمِّ اللَّهَ وَكُلْ بِيَمِينِكَ وَكُلْ مِمَّا يَلِيكَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن ابی داود/المناسک ۸۰ (۱۹۹۳)، سنن الترمذی/الحج ۷ (۸۱۶)،(تحفة الأشراف:۶۱۶۸)، وقد أخرجہ: مسند احمد (۱/۲۴۶،۳۲۱)، سنن الدارمی/المناسک ۳۹ (۱۹۰۰),,It was\nnarrated from Wahb bin Kaisan that he heard ‘Umar bin Abu\nSalamah\nsay:,Chapters on Food
3004,"حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، عَنْ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ لاَ تَأْكُلُوا بِالشِّمَالِ فَإِنَّ الشَّيْطَانَ يَأْكُلُ بِالشِّمَالِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن الترمذی/الحج ۵۰ (۸۷۹)،(تحفة الأشراف:۵۸۸۱),,It was\nnarrated from Jabir that the Messenger of Allah (ﷺ) said:,Chapters on Food
3005,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِي عُمَرَ الْعَدَنِيُّ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عَمْرِو بْنِ دِينَارٍ، عَنْ عَطَاءٍ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ ‏""‏ إِذَا أَكَلَ أَحَدُكُمْ طَعَامًا فَلاَ يَمْسَحْ يَدَهُ حَتَّى يَلْعَقَهَا أَوْ يُلْعِقَهَا ‏""‏ ‏.‏ قَالَ سُفْيَانُ سَمِعْتُ عُمَرَ بْنَ قَيْسٍ، يَسْأَلُ عَمْرَو بْنَ دِينَارٍ أَرَأَيْتَ حَدِيثَ عَطَاءٍ ‏""""‏ لاَ يَمْسَحْ أَحَدُكُمْ يَدَهُ حَتَّى يَلْعَقَهَا أَوْ يُلْعِقَهَا ‏""""‏ ‏.‏ عَمَّنْ هُوَ قَالَ عَنِ ابْنِ عَبَّاسٍ ‏.‏ قَالَ فَإِنَّهُ حُدِّثْنَاهُ عَنْ جَابِرٍ ‏.‏ قَالَ حَفِظْنَاهُ مِنْ عَطَاءٍ عَنِ ابْنِ عَبَّاسٍ قَبْلَ أَنْ يَقْدَمَ جَابِرٌ عَلَيْنَا وَإِنَّمَا لَقِيَ عَطَاءٌ جَابِرًا فِي سَنَةٍ جَاوَرَ فِيهَا بِمَكَّةَ ‏.‏""",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan Lighairihi; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۷۳۷، ومصباح الزجاجة:۱۰۵۱)، وقد أخرجہ: موطا امام مالک/الحج ۶۴ (۱۹۵),,It was\nnarrated from Ibn ‘Abbas that the Prophet (ﷺ) said:,Chapters on Food
3006,"حَدَّثَنَا مُوسَى بْنُ عَبْدِ الرَّحْمَنِ، أَنْبَأَنَا أَبُو دَاوُدَ الْحَفَرِيُّ، عَنْ سُفْيَانَ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لاَ يَمْسَحْ أَحَدُكُمْ يَدَهُ حَتَّى يَلْعَقَهَا فَإِنَّهُ لاَ يَدْرِي فِي أَىِّ طَعَامِهِ الْبَرَكَةُ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/المناسک ۸۹ (۲۰۱۹)، سنن الترمذی/الحج ۵۱ (۸۸۱)،(تحفة الأشراف:۱۷۹۶۳)، وقد أخرجہ: مسند احمد (۶/۱۸۷ٕ ۲۰۶)، سنن الدارمی/المناسک ۸۷ (۱۹۸۰),,It was\nnarrated from Jabir that the Messenger of Allah (ﷺ) said:,Chapters on Food
3007,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، أَنْبَأَنَا أَبُو الْيَمَانِ الْبَرَّاءُ، قَالَ حَدَّثَتْنِي جَدَّتِي أَمُّ عَاصِمٍ، قَالَتْ دَخَلَ عَلَيْنَا نُبَيْشَةُ مَوْلَى رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ وَنَحْنُ نَأْكُلُ فِي قَصْعَةٍ فَقَالَ قَالَ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ أَكَلَ فِي قَصْعَةٍ فَلَحِسَهَا اسْتَغْفَرَتْ لَهُ الْقَصْعَةُ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Isnaad Hasan,takhreej: «أنظر ما قبلہ,,It was\nnarrated that Umm ‘Asim said:,Chapters on Food
3008,"حَدَّثَنَا أَبُو بِشْرٍ، بَكْرُ بْنُ خَلَفٍ وَنَصْرُ بْنُ عَلِيٍّ قَالاَ حَدَّثَنَا الْمُعَلَّى بْنُ رَاشِدٍ أَبُو الْيَمَانِ، حَدَّثَتْنِي جَدَّتِي، عَنْ رَجُلٍ، مِنْ هُذَيْلٍ يُقَالُ لَهُ نُبَيْشَةُ الْخَيْرِ قَالَتْ دَخَلَ عَلَيْنَا نُبَيْشَةُ وَنَحْنُ نَأْكُلُ فِي قَصْعَةٍ لَنَا فَقَالَ حَدَّثَنَا رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ مَنْ أَكَلَ فِي قَصْعَةٍ ثُمَّ لَحِسَهَا اسْتَغْفَرَتْ لَهُ الْقَصْعَةُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/العیدین ۱۲ (۹۷۰)، الحج ۸۶ (۱۶۵۹)، صحیح مسلم/الحج ۴۶ (۱۲۸۵)سنن النسائی/الحج ۱۹۲ (۳۰۰۳)،(تحفة الأشراف:۱۴۵۲)، وقد أخرجہ: سنن ابی داود/الحج ۲۸ (۱۸۱۶)، موطا امام مالک/الحج ۱۳ (۴۳)، مسند احمد (۳/۱۱۰،۲۴۰)، سنن الدارمی/المناسک ۴۸ (۱۹۱۹),,Mu’alla\nbin Rashid Abu Yaman said:,Chapters on Food
3009,"حَدَّثَنَا مُحَمَّدُ بْنُ خَلَفٍ الْعَسْقَلاَنِيُّ، حَدَّثَنَا عُبَيْدُ اللَّهِ، حَدَّثَنَا عَبْدُ الأَعْلَى، عَنْ يَحْيَى بْنِ أَبِي كَثِيرٍ، عَنْ عُرْوَةَ بْنِ الزُّبَيْرِ، عَنِ ابْنِ عُمَرَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِذَا وُضِعَتِ الْمَائِدَةُ فَلْيَأْكُلْ مِمَّا يَلِيهِ وَلاَ يَتَنَاوَلْ مِنْ بَيْنِ يَدَىْ جَلِيسِهِ ‏""""‏ ‏.‏""",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/المناسک ۶۱ (۱۹۱۴)،(تحفة الأشراف:۷۰۷۳)، وقد أخرجہ: صحیح البخاری/الحج ۸۷ (۱۶۶۰)، موطا امام مالک/الحج ۶۴ (۱۹۵)، مسند احمد (۲/۲۵),,It was\nnarrated from Ibn ‘Umar that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Food
3010,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا الْعَلاَءُ بْنُ الْفَضْلِ بْنِ عَبْدِ الْمَلِكِ بْنِ أَبِي السَّوِيَّةِ، حَدَّثَنِي عُبَيْدُ اللَّهِ بْنُ عِكْرَاشٍ، عَنْ أَبِيهِ، عِكْرَاشِ بْنِ ذُؤَيْبٍ قَالَ أُتِيَ النَّبِيُّ ـ صلى الله عليه وسلم ـ بِجَفْنَةٍ كَثِيرَةِ الثَّرِيدِ وَالْوَدَكِ فَأَقْبَلْنَا نَأْكُلُ مِنْهَا فَخَبَطْتُ يَدِي فِي نَوَاحِيهَا فَقَالَ ‏""‏ يَا عِكْرَاشُ كُلْ مِنْ مَوْضِعٍ وَاحِدٍ فَإِنَّهُ طَعَامٌ وَاحِدٌ ‏""‏ ‏.‏ ثُمَّ أُتِينَا بِطَبَقٍ فِيهِ أَلْوَانٌ مِنَ الرُّطَبِ فَجَالَتْ يَدُ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ فِي الطَّبَقِ وَقَالَ ‏""‏ يَا عِكْرَاشُ كُلْ مِنْ حَيْثُ شِئْتَ فَإِنَّهُ غَيْرُ لَوْنٍ وَاحِدٍ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/المناسک ۶۴ (۱۹۳۵،۱۹۳۶)، سنن الترمذی/الحج ۵۴ (۸۸۵)،(تحفة الأشراف:۱۰۲۲۹),3010,It was\nnarrated that ‘Ikrash bin Dhu’aib said:,Chapters on Food
3011,"حَدَّثَنَا عَمْرُو بْنُ عُثْمَانَ بْنِ سَعِيدِ بْنِ كَثِيرِ بْنِ دِينَارٍ الْحِمْصِيُّ، حَدَّثَنَا أَبِي، حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الرَّحْمَنِ بْنِ عِرْقٍ الْيَحْصُبِيُّ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ بُسْرٍ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ أُتِيَ بِقَصْعَةٍ فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ كُلُوا مِنْ جَوَانِبِهَا وَدَعُوا ذُرْوَتَهَا يُبَارَكْ فِيهَا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن ابی داود/المناسک ۶۲ (۱۹۱۹)، سنن الترمذی/الحج ۵۳ (۸۸۳)،(تحفة الأشراف:۱۵۵۲۶)، وقد أخرجہ: مسند احمد (۴/۱۳۷),,‘Abdullah bin Busr narrated that the Messenger of Allah (ﷺ) was\nbrought a bowl (of food). The Messenger of Allah (ﷺ) said:,Chapters on Food
3012,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا أَبُو حَفْصٍ، عُمَرُ بْنُ الدَّرَفْسِ حَدَّثَنِي عَبْدُ الرَّحْمَنِ بْنُ أَبِي قَسِيمَةَ، عَنْ وَاثِلَةَ بْنِ الأَسْقَعِ اللَّيْثِيِّ، قَالَ أَخَذَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ بِرَأْسِ الثَّرِيدِ فَقَالَ ‏ ‏ كُلُوا بِسْمِ اللَّهِ مِنْ حَوَالَيْهَا وَاعْفُوا رَأْسَهَا فَإِنَّ الْبَرَكَةَ تَأْتِيهَا مِنْ فَوْقِهَا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: «تفرد ابن ماجہ،(تحفة الأشراف:۳۰۶۹، ومصباح الزجاجة:۱۰۵۲)، وقد أخرجہ: سنن ابی داود/المناسک ۶۵ (۱۹۳۶)، سنن الدارمی/المناسک ۵۰ (۱۹۲۱),,It was\nnarrated that Wathilah bin Asqa’ Al-Laithi said:,Chapters on Food
3013,"حَدَّثَنَا عَلِيُّ بْنُ الْمُنْذِرِ، حَدَّثَنَا مُحَمَّدُ بْنُ فُضَيْلٍ، حَدَّثَنَا عَطَاءُ بْنُ السَّائِبِ، عَنْ سَعِيدِ بْنِ جُبَيْرٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِذَا وُضِعَ الطَّعَامُ فَخُذُوا مِنْ حَافَتِهِ وَذَرُوا وَسَطَهُ فَإِنَّ الْبَرَكَةَ تَنْزِلُ فِي وَسَطِهِ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۱۴۰، ومصباح الزجاجة:۱۰۵۳)، وقد أخرجہ: سنن ابی داود/الأدب ۱۶۸ (۵۲۳۴)، مسند احمد (۴/۱۴),,It was\nnarrated from Ibn ‘Abbas that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Food
3014,حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، حَدَّثَنَا يَزِيدُ بْنُ زُرَيْعٍ، عَنْ يُونُسَ، عَنِ الْحَسَنِ، عَنْ مَعْقِلِ بْنِ يَسَارٍ، قَالَ بَيْنَمَا هُوَ يَتَغَدَّى إِذْ سَقَطَتْ مِنْهُ لُقْمَةٌ فَتَنَاوَلَهَا فَأَمَاطَ مَا كَانَ فِيهَا مِنْ أَذًى فَأَكَلَهَا فَتَغَامَزَ بِهِ الدَّهَاقِينُ فَقِيلَ أَصْلَحَ اللَّهُ الأَمِيرَ إِنَّ هَؤُلاَءِ الدَّهَاقِينَ يَتَغَامَزُونَ مِنْ أَخْذِكَ اللُّقْمَةَ وَبَيْنَ يَدَيْكَ هَذَا الطَّعَامُ ‏.‏ قَالَ إِنِّي لَمْ أَكُنْ لأَدَعَ مَا سَمِعْتُ مِنْ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ لِهَذِهِ الأَعَاجِمِ إِنَّا كُنَّا نَأْمُرُ أَحَدَنَا إِذَا سَقَطَتْ لُقْمَتُهُ أَنْ يَأْخُذَهَا فَيُمِيطَ مَا كَانَ فِيهَا مِنْ أَذًى وَيَأْكُلَهَا وَلاَ يَدَعَهَا لِلشَّيْطَانِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۷۹ (۱۳۴۸)، سنن النسائی/الحج ۱۹۴ (۳۰۰۶)،(تحفة الأشراف:۱۶۱۳۱),3014,It was\nnarrated from Hasan about Ma’qil bin Yasar:,Chapters on Food
3015,"حَدَّثَنَا عَلِيُّ بْنُ الْمُنْذِرِ، حَدَّثَنَا مُحَمَّدُ بْنُ فُضَيْلٍ، حَدَّثَنَا الأَعْمَشُ، عَنْ أَبِي سُفْيَانَ، عَنْ جَابِرٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِذَا وَقَعَتِ اللُّقْمَةُ مِنْ يَدِ أَحَدِكُمْ فَلْيَمْسَحْ مَا عَلَيْهَا مِنَ الأَذَى وَلْيَأْكُلْهَا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الحج ۶۹ (۱۹۴۹)، سنن الترمذی/الحج ۵۷ (۸۸۹،۸۹۰)، سنن النسائی/الحج ۲۰۳ (۳۰۱۹)،۲۱۱ (۳۰۴۷)،(تحفة الأشراف:۹۷۳۵)، وقد أخرجہ: مسند احمد (۴/۳۰۹،۳۱۰،۳۳۵)، سنن الدارمی/المناسک ۵۴ (۱۹۲۹),,It was\nnarrated from Jabir that the Messenger of Allah (ﷺ) said:,Chapters on Food
3016,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، حَدَّثَنَا شُعْبَةُ، عَنْ عَمْرِو بْنِ مُرَّةَ، عَنْ مُرَّةَ الْهَمْدَانِيِّ، عَنْ أَبِي مُوسَى الأَشْعَرِيِّ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ كَمَلَ مِنَ الرِّجَالِ كَثِيرٌ وَلَمْ يَكْمُلْ مِنَ النِّسَاءِ إِلاَّ مَرْيَمُ بِنْتُ عِمْرَانَ وَآسِيَةُ امْرَأَةُ فِرْعَوْنَ وَإِنَّ فَضْلَ عَائِشَةَ عَلَى النِّسَاءِ كَفَضْلِ الثَّرِيدِ عَلَى سَائِرِ الطَّعَامِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الحج ۶۹ (۱۹۵۰)، سنن الترمذی/الحج ۵۷ (۸۹۱)، سنن النسائی/الحج ۲۱۱ (۳۰۴۲)،(تحفة الأشراف:۹۹۰۰)، وقد أخرجہ: مسند احمد (۴/۱۵،۲۶۱،۲۶۲)، سنن الدارمی/المناسک ۵۴ (۱۹۳۰),,It was\nnarrated from Abu Musa Al-Ash’ari that the Prophet (ﷺ) said:,Chapters on Food
3017,"حَدَّثَنَا حَرْمَلَةُ بْنُ يَحْيَى، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، أَنْبَأَنَا مُسْلِمُ بْنُ خَالِدٍ، عَنْ عَبْدِ اللَّهِ بْنِ عَبْدِ الرَّحْمَنِ، أَنَّهُ سَمِعَ أَنَسَ بْنَ مَالِكٍ، يَقُولُ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ فَضْلُ عَائِشَةَ عَلَى النِّسَاءِ كَفَضْلِ الثَّرِيدِ عَلَى سَائِرِ الطَّعَامِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحج ۹۳ (۱۶۶۶)، الجہاد ۱۳۶ (۲۹۹۹)، المغازي ۷۷ (۴۴۱۳)، صحیح مسلم/الحج ۴۷ (۱۲۸۰،۱۲۸۶)، سنن ابی داود/الحج ۶۴ (۱۹۲۳)، سنن النسائی/الحج ۲۰۵ (۳۰۲۶)،۲۱۴ (۳۰۵۴)،(تحفة الأشراف:۱۰۴)، وقد أخرجہ: موطا امام مالک/الحج۵۷ (۱۷۶)، مسند احمد (۵/۲۰۵،۲۱۰)، سنن الدارمی/المناسک ۵۱ (۱۹۲۲),,It was\nnarrated from ‘Abdullah bin ‘Abdur-Rahman that he heard Anas\nbin\nMalik say:,Chapters on Food
3018,حَدَّثَنَا مُحَمَّدُ بْنُ سَلَمَةَ الْمِصْرِيُّ أَبُو الْحَارِثِ الْمُرَادِيُّ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، عَنْ مُحَمَّدِ بْنِ أَبِي يَحْيَى، عَنْ أَبِيهِ، عَنْ سَعِيدِ بْنِ الْحَارِثِ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، قَالَ كُنَّا زَمَانَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ وَقَلِيلٌ مَا نَجِدُ الطَّعَامَ فَإِذَا نَحْنُ وَجَدْنَاهُ لَمْ يَكُنْ لَنَا مَنَادِيلُ إِلاَّ أَكُفَّنَا وَسَوَاعِدَنَا وَأَقْدَامَنَا ثُمَّ نُصَلِّي وَلاَ نَتَوَضَّأْ ‏.‏ قَالَ أَبُو عَبْدِ اللَّهِ غَرِيبٌ لَيْسَ إِلاَّ عَنْ مُحَمَّدِ بْنِ سَلَمَةَ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۶۹۲۲، ومصباح الزجاجة:۱۰۵۴),3018,It was\nnarrated that Jabir bin ‘Abdullah said:,Chapters on Food
3019,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ، عَنْ حَجَّاجٍ، عَنْ رِيَاحِ بْنِ عَبِيدَةَ، عَنْ مَوْلًى، لأَبِي سَعِيدٍ عَنْ أَبِي سَعِيدٍ، قَالَ كَانَ النَّبِيُّ ـ صلى الله عليه وسلم ـ إِذَا أَكَلَ طَعَامًا قَالَ ‏ ‏ الْحَمْدُ لِلَّهِ الَّذِي أَطْعَمَنَا وَسَقَانَا وَجَعَلَنَا مُسْلِمِينَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «سنن ابی داود/المناسک ۶۴ (۱۹۲۱)، سنن النسائی/المواقیت ۵۰ (۶۱۰)، الحج ۲۰۶ (۳۰۲۸)،(تحفة الأشراف:۱۱۶)، وقد أخرجہ: صحیح البخاری/الوضوء ۳۵ (۱۳۹)، الحج ۹۵ (۱۶۶۶)، صحیح مسلم/الحج ۴۷ (۱۲۸۰)، موطا امام مالک/الحج ۶۵ (۱۹۷)، مسند احمد (۵/۲۰۰،۲۰۲،۲۰۸،۲۱۰)، سنن الدارمی/المناسک ۵۱ (۱۹۲۲),,It was\nnarrated that Abu Sa’eed said:,Chapters on Food
3020,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ، حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، حَدَّثَنَا ثَوْرُ بْنُ يَزِيدَ، عَنْ خَالِدِ بْنِ مَعْدَانَ، عَنْ أَبِي أُمَامَةَ الْبَاهِلِيِّ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ أَنَّهُ كَانَ يَقُولُ إِذَا رُفِعَ طَعَامُهُ أَوْ مَا بَيْنَ يَدَيْهِ قَالَ ‏ ‏ الْحَمْدُ لِلَّهِ حَمْدًا كَثِيرًا طَيِّبًا مُبَارَكًا غَيْرَ مَكْفِيٍّ وَلاَ مُوَدَّعٍ وَلاَ مُسْتَغْنًى عَنْهُ رَبَّنَا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحج ۹۶ (۱۶۷۴)، المغازي ۷۶ (۴۴۱۴)، صحیح مسلم/الحج ۴۷ (۱۲۸۷)، سنن النسائی/المواقیت ۴۸ (۶۰۶)،(تحفة الأشراف:۳۴۶۵)، وقد أخرجہ: موطا امام مالک/الحج ۶۵ (۱۹۸)، مسند احمد (۵/۴۱۸،۴۱۹،۴۲۰،۴۲۱)، سنن الدارمی/المناسک ۵۲ (۱۹۲۵),,"It was\nnarrated from Abu Umamah Al-Bahili that when his food, or\nwhatever\nwas in front of him was cleared away, the Prophet (ﷺ) used\nto say:",Chapters on Food
3021,"حَدَّثَنَا حَرْمَلَةُ بْنُ يَحْيَى، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، أَخْبَرَنِي سَعِيدُ بْنُ أَبِي أَيُّوبَ، عَنْ أَبِي مَرْحُومٍ عَبْدِ الرَّحِيمِ، عَنْ سَهْلِ بْنِ مُعَاذِ بْنِ أَنَسٍ الْجُهَنِيِّ، عَنْ أَبِيهِ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ مَنْ أَكَلَ طَعَامًا فَقَالَ الْحَمْدُ لِلَّهِ الَّذِي أَطْعَمَنِي هَذَا وَرَزَقَنِيهِ مِنْ غَيْرِ حَوْلٍ مِنِّي وَلاَ قُوَّةٍ غُفِرَ لَهُ مَا تَقَدَّمَ مِنْ ذَنْبِهِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۷۷۰)، وقد أخرجہ: صحیح البخاری/الحج ۹۶ (۱۶۷۴)، صحیح مسلم/الحج ۴۷ (۱۲۸۶)، سنن ابی داود/المناسک ۶۵ (۱۹۲۶)، موطا امام مالک/الحج ۶۵ (۱۹۶)، سنن الدارمی/المناسک ۵۲ (۶۷۷۰),,"It was\nnarrated from Sahl bin Mu’adh bin Anas Al-Juhani, from his\nfather,\nthat the Prophet (ﷺ) said:",Chapters on Food
3022,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، وَدَاوُدُ بْنُ رُشَيْدٍ، وَمُحَمَّدُ بْنُ الصَّبَّاحِ، قَالُوا حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، حَدَّثَنَا وَحْشِيُّ بْنُ حَرْبِ بْنِ وَحْشِيِّ بْنِ حَرْبٍ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، وَحْشِيٍّ، أَنَّهُمْ قَالُوا يَا رَسُولَ اللَّهِ إِنَّا نَأْكُلُ وَلاَ نَشْبَعُ ‏.‏ قَالَ ‏""‏ فَلَعَلَّكُمْ تَأْكُلُونَ مُتَفَرِّقِينَ ‏""‏ ‏.‏ قَالُوا نَعَمْ ‏.‏ قَالَ ‏""‏ فَاجْتَمِعُوا عَلَى طَعَامِكُمْ وَاذْكُرُوا اسْمَ اللَّهِ عَلَيْهِ يُبَارَكْ لَكُمْ فِيهِ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الحج ۱۰۰ (۱۶۸۴)، مناقب الأنصار ۲۶ (۳۸۳۸)، سنن ابی داود/الحج ۶۵ (۱۹۳۸)، سنن الترمذی/الحج ۶۰ (۸۹۶)، سنن النسائی/الحج ۲۱۳ (۳۰۵۰)،(تحفة الأشراف:۱۰۶۱۶)، وقد أخرجہ: مسند احمد (۱/۱۴،۲۹،۳۹،۴۲،۵۰،۵۲)سنن الدارمی/المناسک ۵۵ (۱۹۳۲),3022,"Wahshi\nbin Harb bin Wahshi bin Harb narrated from his father, from\nhis\ngrandfather, that they said:",Chapters on Food
3023,"حَدَّثَنَا الْحَسَنُ بْنُ عَلِيٍّ الْخَلاَّلُ، حَدَّثَنَا الْحَسَنُ بْنُ مُوسَى، حَدَّثَنَا سَعِيدُ بْنُ زَيْدٍ، حَدَّثَنَا عَمْرُو بْنُ دِينَارٍ، قَهْرَمَانُ آلِ الزُّبَيْرِ قَالَ سَمِعْتُ سَالِمَ بْنَ عَبْدِ اللَّهِ بْنِ عُمَرَ، قَالَ سَمِعْتُ أَبِي يَقُولُ، سَمِعْتُ عُمَرَ بْنَ الْخَطَّابِ، يَقُولُ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ كُلُوا جَمِيعًا وَلاَ تَفَرَّقُوا فَإِنَّ الْبَرَكَةَ مَعَ الْجَمَاعَةِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الحج ۶۶ (۱۹۴۴)، سنن النسائی/الحج ۲۰۴ (۳۰۲۴)،۲۱۵ (۳۰۵۵)،(تحفة الأشراف:۲۷۴۷)، وقد أخرجہ: سنن الترمذی/الحج ۵۵ (۸۸۶)، مسند احمد (۳/۳۰۱،۳۳۲،۳۶۷،۳۹۱),,Salim\nbin ‘Abdullah bin ‘Umar said:,Chapters on Food
3024,"حَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ عَبْدِ الرَّحْمَنِ الْمُحَارِبِيُّ، حَدَّثَنَا شَرِيكٌ، عَنْ عَبْدِ الْكَرِيمِ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ لَمْ يَكُنْ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ يَنْفُخُ فِي طَعَامٍ وَلاَ شَرَابٍ وَلاَ يَتَنَفَّسُ فِي الإِنَاءِ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۰۴۸، ومصباح الزجاجة:۱۰۵۵),3024,It was\nnarrated that Ibn ‘Abbas said:,Chapters on Food
3025,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا أَبِي، حَدَّثَنَا إِسْمَاعِيلُ بْنُ أَبِي خَالِدٍ، عَنْ أَبِيهِ، سَمِعْتُ أَبَا هُرَيْرَةَ، يَقُولُ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِذَا جَاءَ أَحَدَكُمْ خَادِمُهُ بِطَعَامِهِ فَلْيُجْلِسْهُ فَلْيَأْكُلْ مَعَهُ فَإِنْ أَبَى فَلْيُنَاوِلْهُ مِنْهُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الحج ۶۶ (۱۹۴۰)، سنن النسائی/الحج ۲۲۲ (۳۰۶۶)،(تحفة الأشراف:۵۳۹۶)، وقد أخرجہ: سنن الترمذی/الحج ۵۸ (۸۹۳)، مسند احمد (۱/۲۳۴،۳۱۱،۳۴۳),,Isma’il\nbin Abu Khalid narrated from his father:,Chapters on Food
3026,"حَدَّثَنَا عِيسَى بْنُ حَمَّادٍ الْمِصْرِيُّ، أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، عَنْ جَعْفَرِ بْنِ رَبِيعَةَ، عَنْ عَبْدِ الرَّحْمَنِ الأَعْرَجِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِذَا أَحَدُكُمْ قَرَّبَ إِلَيْهِ مَمْلُوكُهُ طَعَامًا قَدْ كَفَاهُ عَنَاءَهُ وَحَرَّهُ فَلْيَدْعُهُ فَلْيَأْكُلْ مَعَهُ فَإِنْ لَمْ يَفْعَلْ فَلْيَأْخُذْ لُقْمَةً فَلْيَجْعَلْهَا فِي يَدِهِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۴۹ (۱۲۹۳)، سنن النسائی/الحج ۲۰۸ (۳۰۳۶)،۲۱۴ (۳۰۵۱)،(تحفة الأشراف:۵۹۴۴)، وقد أخرجہ: مسند احمد (۱/۲۲۱،۲۷۲),,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Food
3027,"حَدَّثَنَا عَلِيُّ بْنُ الْمُنْذِرِ، حَدَّثَنَا مُحَمَّدُ بْنُ فُضَيْلٍ، حَدَّثَنَا إِبْرَاهِيمُ الْهَجَرِيُّ، عَنْ أَبِي الأَحْوَصِ، عَنْ عَبْدِ اللَّهِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِذَا جَاءَ خَادِمُ أَحَدِكُمْ بِطَعَامِهِ فَلْيُقْعِدْهُ مَعَهُ أَوْ لِيُنَاوِلْهُ مِنْهُ فَإِنَّهُ هُوَ الَّذِي وَلِيَ حَرَّهُ وَدُخَانَهُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحج ۹۸ (۱۶۸۰)، صحیح مسلم/الحج ۴۹ (۱۲۹۰)،(تحفة الأشراف:۱۷۴۷۹)، وقد أخرجہ: سنن النسائی/الحج ۲۰۹ (۳۰۴۰)،۲۱۴ (۳۰۵۲)، مسند احمد (۶/۳۰،۹۴،۹۹،۱۳۳،۱۶۴،۲۱۴)، سنن الدارمی/المناسک ۵۳ (۱۹۲۸),,It was\nnarrated from ‘Abdullah that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Food
3028,حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، حَدَّثَنَا مُعَاذُ بْنُ هِشَامٍ، حَدَّثَنَا أَبِي، عَنْ يُونُسَ بْنِ أَبِي الْفُرَاتِ الإِسْكَافِ، عَنْ قَتَادَةَ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ مَا أَكَلَ النَّبِيُّ ـ صلى الله عليه وسلم ـ عَلَى خِوَانٍ وَلاَ فِي سُكُرُّجَةٍ ‏.‏ قَالَ فَعَلاَمَ كَانُوا يَأْكُلُونَ قَالَ عَلَى السُّفَرِ ‏.‏,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan Lighairihi; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/المناسک ۷۸ (۱۹۶۶،۱۹۶۷)،(تحفة الأشراف:۱۸۳۰۶)، وقد أخرجہ: مسند احمد (۳/۵۰۳،۵/۲۷۰،۳۷۹،۶/۳۷۹),3028,"It was\nnarrated from Qatadah, that Anas bin Malik said:",Chapters on Food
3029,حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ يُوسُفَ الْجُبَيْرِيُّ، حَدَّثَنَا أَبُو بَحْرٍ، حَدَّثَنَا سَعِيدُ بْنُ أَبِي عَرُوبَةَ، حَدَّثَنَا قَتَادَةُ، عَنْ أَنَسٍ، قَالَ مَا رَأَيْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ أَكَلَ عَلَى خِوَانٍ حَتَّى مَاتَ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن النسائی/الحج ۲۱۷ (۳۰۵۹)،۲۱۹ (۳۰۶۱)،(تحفة الأشراف:۵۴۲۷)، وقد أخرجہ: مسند احمد (۱/۲۱۵،۳۴۷،۵/۱۲۷),3029,It was\nnarrated that Anas said:,Chapters on Food
3030,حَدَّثَنَا عَبْدُ اللَّهِ بْنُ أَحْمَدَ بْنِ بَشِيرِ بْنِ ذَكْوَانَ الدِّمَشْقِيُّ، حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، عَنْ مُنِيرِ بْنِ الزُّبَيْرِ، عَنْ مَكْحُولٍ، عَنْ عَائِشَةَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ نَهَى أَنْ يُقَامَ عَنِ الطَّعَامِ حَتَّى يُرْفَعَ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحج ۱۳۵ (۱۷۴۷)،۱۳۸ (۱۷۵۰)، صحیح مسلم/الحج ۵۰ (۱۲۹۶)، سنن ابی داود/الحج ۷۸ (۱۹۷۴)، سنن الترمذی/الحج ۶۴ (۹۰۱)، سنن النسائی/الحج ۲۲۶ (۳۰۷۲)،(تحفة الأشراف:۹۳۸۲)، وقد أخرجہ: مسند احمد (۱/۴۱۵،۴۲۷،۴۳۰،۴۳۲،۴۳۶،۴۵۶،۴۵۸),3030,,Chapters on Food
3031,"حَدَّثَنَا مُحَمَّدُ بْنُ خَلَفٍ الْعَسْقَلاَنِيُّ، حَدَّثَنَا عُبَيْدُ اللَّهِ، أَنْبَأَنَا عَبْدُ الأَعْلَى، عَنْ يَحْيَى بْنِ أَبِي كَثِيرٍ، عَنْ عُرْوَةَ بْنِ الزُّبَيْرِ، عَنِ ابْنِ عُمَرَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِذَا وُضِعَتِ الْمَائِدَةُ فَلاَ يَقُومُ رَجُلٌ حَتَّى تُرْفَعَ الْمَائِدَةُ وَلاَ يَرْفَعُ يَدَهُ وَإِنْ شَبِعَ حَتَّى يَفْرُغَ الْقَوْمُ وَلْيُعْذِرْ فَإِنَّ الرَّجُلَ يُخْجِلُ جَلِيسَهُ فَيَقْبِضُ يَدَهُ وَعَسَى أَنْ يَكُونَ لَهُ فِي الطَّعَامِ حَاجَةٌ ‏""""‏ ‏.‏""",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan Lighairihi; Zubair Ali Zai: Daif,takhreej: «انظر حدیث رقم:۳۰۲۸،(تحفة الأشراف:۹۳۸۲),,It was\nnarrated from Ibn ‘Umar that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Food
3032,"حَدَّثَنَا جُبَارَةُ بْنُ الْمُغَلِّسِ، حَدَّثَنَا عُبَيْدُ بْنُ وَسِيمٍ الْجَمَّالُ، حَدَّثَنِي الْحَسَنُ بْنُ الْحَسَنِ، عَنْ أُمِّهِ، فَاطِمَةَ بِنْتِ الْحُسَيْنِ عَنِ الْحُسَيْنِ بْنِ عَلِيٍّ، عَنْ أُمِّهِ، فَاطِمَةَ ابْنَةِ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَتْ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ أَلاَ لاَ يَلُومَنَّ امْرُؤٌ إِلاَّ نَفْسَهُ يَبِيتُ وَفِي يَدِهِ رِيحُ غَمَرٍ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الحج ۱۴۰ (۱۷۵۱)،۱۴۲ (۱۷۵۲،۱۷۵۳)، سنن النسائی/الحج ۲۳۰ (۳۰۸۵)،(تحفة الأشراف:۶۹۸۶)، وقد أخرجہ: مسند احمد (۲/۱۵۲)، سنن الدارمی/المناسک ۶۱ (۱۹۴۴),,"It was\nnarrated from Husain bin ‘Ali that his mother, Fatimah the\ndaughter\nof the Messenger of Allah (ﷺ), said:",Chapters on Food
3033,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الْمَلِكِ بْنِ أَبِي الشَّوَارِبِ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ الْمُخْتَارِ، حَدَّثَنَا سُهَيْلُ بْنُ أَبِي صَالِحٍ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ إِذَا نَامَ أَحَدُكُمْ وَفِي يَدِهِ رِيحُ غَمَرٍ فَلَمْ يَغْسِلْ يَدَهُ فَأَصَابَهُ شَىْءٌ فَلاَ يَلُومَنَّ إِلاَّ نَفْسَهُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih Lighairihi; Shuaib Al Arnaut: Hasan Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۴۸۴، ومصباح الزجاجة:۱۰۵۶),,It was\nnarrated from Abu Hurairah that the Prophet (ﷺ) said:,Chapters on Food
3034,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّ ثَنَا وَكِيعٌ، عَنْ سُفْيَانَ، عَنِ ابْنِ أَبِي حُسَيْنٍ، عَنْ شَهْرِ بْنِ حَوْشَبٍ، عَنْ أَسْمَاءَ بِنْتِ يَزِيدَ، قَالَتْ أُتِيَ النَّبِيُّ ـ صلى الله عليه وسلم ـ بِطَعَامٍ فَعُرِضَ عَلَيْنَا فَقُلْنَا لاَ نَشْتَهِيهِ ‏.‏ فَقَالَ ‏ ‏ لاَ تَجْمَعْنَ جُوعًا وَكَذِبًا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Hasan,takhreej: «سنن الترمذی/الحج ۶۳ (۸۹۹)،(تحفة الأشراف:۶۴۶۷)، وقد أخرجہ: مسند احمد (۱/۲۳۲),,It was\nnarrated that Asma’ bint Yazid said:,Chapters on Food
3035,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا وَكِيعٌ، عَنْ أَبِي هِلاَلٍ، عَنْ عَبْدِ اللَّهِ بْنِ سَوَادَةَ، عَنْ أَنَسِ بْنِ مَالِكٍ، - رَجُلٌ مِنْ بَنِي عَبْدِ الأَشْهَلِ - قَالَ أَتَيْتُ النَّبِيَّ ـ صلى الله عليه وسلم ـ وَهُوَ يَتَغَدَّى فَقَالَ ‏ ‏ ادْنُ فَكُلْ ‏""""‏ ‏.‏ فَقُلْتُ إِنِّي صَائِمٌ فَيَا لَهْفَ نَفْسِي هَلاَّ كُنْتُ طَعِمْتُ مِنْ طَعَامِ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن الترمذی/الحج ۶۵ (۹۰۳)، سنن النسائی/المناسک ۲۲۰ (۳۰۶۳)،(تحفة الأشراف:۱۱۰۷۷)، وقد أخرجہ: مسند احمد۳/۴۱۲،۴۱۳)، سنن الدارمی/المناسک ۶۰ (۱۹۴۲),,It was\nnarrated that Anas bin Malik – a man from the tribe of Banu\n‘Abdul-Ashhal – said:,Chapters on Food
3036,حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، وَحَرْمَلَةُ بْنُ يَحْيَى، قَالاَ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، أَخْبَرَنِي عَمْرُو بْنُ الْحَارِثِ، حَدَّثَنِي سُلَيْمَانُ بْنُ زِيَادٍ الْحَضْرَمِيُّ، أَنَّهُ سَمِعَ عَبْدَ اللَّهِ بْنَ الْحَارِثِ بْنِ جَزْءٍ الزُّبَيْدِيَّ، يَقُولُ كُنَّا نَأْكُلُ عَلَى عَهْدِ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ فِي الْمَسْجِدِ الْخُبْزَ وَاللَّحْمَ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الحج ۷۸ (۱۹۷۵ و ۱۹۷۶)، سنن الترمذی/الحج ۱۰۸ (۹۵۴،۹۵۵)، سنن النسائی/الحج ۲۲۵ (۳۰۷۰)،(تحفة الأشراف:۵۰۳۰)، وقد أخرجہ: موطا امام مالک/الحج ۷۲ (۲۱۸)، مسند احمد (۵/۴۵۰)، سنن الدارمی/المناسک ۵۸ (۱۹۳۸),3036,It was\nnarrated that ‘Abdullah bin Harith bin Jaz’ Az-Zubaidi said:,Chapters on Food
3037,حَدَّثَنَا أَبُو السَّائِبِ، سَلْمُ بْنُ جُنَادَةَ حَدَّثَنَا حَفْصُ بْنُ غِيَاثٍ، عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ كُنَّا عَلَى عَهْدِ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ نَأْكُلُ وَنَحْنُ نَمْشِي وَنَشْرَبُ وَنَحْنُ قِيَامٌ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «أنظر ما قبلہ،(تحفة الأشراف:۵۰۳۰),3037,It was\nnarrated that Ibn ‘Umar said:,Chapters on Food
3038,حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، أَنْبَأَنَا عَبِيدَةُ بْنُ حُمَيْدٍ، عَنْ حُمَيْدٍ، عَنْ أَنَسٍ، قَالَ كَانَ النَّبِيُّ ـ صلى الله عليه وسلم ـ يُحِبُّ الْقَرْعَ ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/الحج ۸۴ (۹۲۷)،(تحفة الأشراف:۲۶۶۲)، وقد أخرجہ: مسند احمد (۳/۳۱۴),3038,It was\nnarrated that Anas said:,Chapters on Food
3039,حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، حَدَّثَنَا ابْنُ أَبِي عَدِيٍّ، عَنْ حُمَيْدٍ، عَنْ أَنَسٍ، قَالَ بَعَثَتْ مَعِي أُمُّ سُلَيْمٍ بِمِكْتَلٍ فِيهِ رُطَبٌ إِلَى رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ فَلَمْ أَجِدْهُ وَخَرَجَ قَرِيبًا إِلَى مَوْلًى لَهُ دَعَاهُ فَصَنَعَ لَهُ طَعَامًا فَأَتَيْتُهُ وَهُوَ يَأْكُلُ ‏.‏ قَالَ فَدَعَانِي لآكُلَ مَعَهُ ‏.‏ قَالَ وَصَنَعَ ثَرِيدَةً بِلَحْمٍ وَقَرْعٍ ‏.‏ قَالَ فَإِذَا هُوَ يُعْجِبُهُ الْقَرْعُ ‏.‏ قَالَ فَجَعَلْتُ أَجْمَعُهُ فَأُدْنِيهِ مِنْهُ فَلَمَّا طَعِمْنَا مِنْهُ رَجَعَ إِلَى مَنْزِلِهِ وَوَضَعْتُ الْمِكْتَلَ بَيْنَ يَدَيْهِ فَجَعَلَ يَأْكُلُ وَيَقْسِمُ حَتَّى فَرَغَ مِنْ آخِرِهِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۴۴۴، ومصباح الزجاجة:۱۰۵۷)، وقد أخرجہ: سنن النسائی/الحج ۲۱۶ (۳۰۵۸)، مسند احمد (۱/۲۱۰،۲۱۴)، سنن الدارمی/المناسک ۶۰ (۱۹۴۳)، وراجع الحدیث الآتي,3039,It was\nnarrated that Anas said:,Chapters on Food
3040,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا وَكِيعٌ، عَنْ إِسْمَاعِيلَ بْنِ أَبِي خَالِدٍ، عَنْ حَكِيمِ بْنِ جَابِرٍ، عَنْ أَبِيهِ، قَالَ دَخَلْتُ عَلَى النَّبِيِّ ـ صلى الله عليه وسلم ـ فِي بَيْتِهِ وَعِنْدَهُ هَذِهِ الدُّبَّاءُ فَقُلْتُ أَىُّ شَىْءٍ هَذَا قَالَ ‏ ‏ هَذَا الْقَرْعُ هُوَ الدُّبَّاءُ نُكَثِّرُ بِهِ طَعَامَنَا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن النسائی/الحج ۲۱۶ (۳۰۵۷)،(تحفة الأشراف:۱۱۰۵۶)، وقد أخرجہ: صحیح البخاری/الحج ۲۲ (۱۵۴۳)،۹۳ (۱۶۶۹)،۱۰۱ (۱۶۸۵)، صحیح مسلم/الحج ۴۵ (۱۲۸۰),,It was\nnarrated from Hakin bin Jabr that his father said:,Chapters on Food
3041,"حَدَّثَنَا الْعَبَّاسُ بْنُ الْوَلِيدِ الْخَلاَّلُ الدِّمَشْقِيُّ، حَدَّثَنَا يَحْيَى بْنُ صَالِحٍ، حَدَّثَنِي سُلَيْمَانُ بْنُ عَطَاءٍ الْجَزَرِيُّ، حَدَّثَنِي مَسْلَمَةُ بْنُ عَبْدِ اللَّهِ الْجُهَنِيُّ، عَنْ عَمِّهِ أَبِي مَشْجَعَةَ، عَنْ أَبِي الدَّرْدَاءِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ سَيِّدُ طَعَامِ أَهْلِ الدُّنْيَا وَأَهْلِ الْجَنَّةِ اللَّحْمُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Daif,takhreej: «سنن النسائی/الحج ۲۳۱ (۳۰۸۶)،(تحفة الأشراف:۵۳۹۷),,It was\nnarrated from Abu Darda’ that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Food
3042,حَدَّثَنَا الْعَبَّاسُ بْنُ الْوَلِيدِ الدِّمَشْقِيُّ، حَدَّثَنَا يَحْيَى بْنُ صَالِحٍ، حَدَّثَنَا سُلَيْمَانُ بْنُ عَطَاءٍ الْجَزَرِيُّ، حَدَّثَنَا مَسْلَمَةُ بْنُ عَبْدِ اللَّهِ الْجُهَنِيُّ، عَنْ عَمِّهِ أَبِي مَشْجَعَةَ، عَنْ أَبِي الدَّرْدَاءِ، قَالَ مَا دُعِيَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ إِلَى لَحْمٍ قَطُّ إِلاَّ أَجَابَ وَلاَ أُهْدِيَ لَهُ لَحْمٌ قَطُّ إِلاَّ قَبِلَهُ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۷ (۱۱۸۹)،(تحفة الأشراف:۱۷۵۳۸)، وقد أخرجہ: صحیح البخاری/الحج ۱۸ (۱۵۳۹)،۱۴۳ (۱۷۵۴)، اللباس ۷۳ (۵۹۲۲۰)،۷۴ (۵۹۲۳)،۷۹ (۵۹۲۸)،۸۱ (۵۹۳۰)، سنن ابی داود/الحج ۱۱ (۱۷۴۵)، سنن الترمذی/الحج ۷۷ (۹۱۷)، سنن النسائی/الحج ۴۱ (۲۶۸۵)، موطا امام مالک/الحج ۷ (۱۷)، مسند احمد (۶/۹۸،۱۰۶،۱۳،۱۶۲،۱۸۱،۱۸۶،۱۹۲،۲۰۰،۲۰۷،۲۰۹،۲۱۴،۲۱۶،۲۳۷،۲۳۸،۲۴۴،۲۴۵،۲۵۸)، سنن الدارمی/المناسک ۱۰ (۱۸۴۴),3042,It was\nnarrated that Abu Darda’ said:,Chapters on Food
3043,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ الْعَبْدِيُّ، ح وَحَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا مُحَمَّدُ بْنُ فُضَيْلٍ، قَالاَ حَدَّثَنَا أَبُو حَيَّانَ التَّيْمِيُّ، عَنْ أَبِي زُرْعَةَ، عَنْ أَبِي هُرَيْرَةَ، قَالَ أُتِيَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ذَاتَ يَوْمٍ بِلَحْمٍ فَرُفِعَ إِلَيْهِ الذِّرَاعُ وَكَانَتْ تُعْجِبُهُ فَنَهَسَ مِنْهَا ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحج ۱۲۷ (۱۷۲۸)، صحیح مسلم/الحج ۵۵ (۱۳۰۲)،(تحفة الأشراف:۱۴۹۰۴)، وقد أخرجہ: مسند احمد (۲/۲۳۱),3043,It was\nnarrated that Abu Hurairah said:,Chapters on Food
3044,"حَدَّثَنَا بَكْرُ بْنُ خَلَفٍ أَبُو بِشْرٍ، حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، عَنِ مِسْعَرٍ، حَدَّثَنِي شَيْخٌ، مِنْ فَهْمٍ - قَالَ وَأَظُنُّهُ يُسَمَّى مُحَمَّدَ بْنَ عَبْدِ اللَّهِ - أَنَّهُ سَمِعَ عَبْدَ اللَّهِ بْنَ جَعْفَرٍ يُحَدِّثُ ابْنَ الزُّبَيْرِ وَقَدْ نَحَرَ لَهُمْ جَزُورًا أَوْ بَعِيرًا أَنَّهُ سَمِعَ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ - قَالَ وَالْقَوْمُ يُلْقُونَ لِرَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ اللَّحْمَ - يَقُولُ ‏ ‏ أَطْيَبُ اللَّحْمِ لَحْمُ الظَّهْرِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۵۵ (۱۳۰۱)،(تحفة الأشراف:۷۹۴۷)، وقد أخرجہ: صحیح البخاری/الحج ۱۴۷ (۱۷۲۷)، سنن ابی داود/الحج ۷۹ (۱۹۷۹)، سنن الترمذی/الحج ۷۴ (۹۱۳)، موطا امام مالک/الحج ۶۰ (۱۸۴)، مسند احمد (۲/۳۴،۱۵۱)، سنن الدارمی/المناسک ۶۴ (۱۹۴۷),,"‘Abdullah bin Ja’far told Ibn Zubair, who had slaughtered a camel\nfor\nthem, that he heard the Messenger of Allah (ﷺ), and he\n(‘Abdullah)\nsaid:",Chapters on Food
3045,حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، حَدَّثَنَا هَمَّامٌ، عَنْ قَتَادَةَ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ مَا أَعْلَمُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ رَأَى شَاةً سَمِيطًا حَتَّى لَحِقَ بِاللَّهِ عَزَّ وَجَلَّ ‏.‏,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۴۱۰، ومصباح الزجاجة:۱۰۵۸)، وقد أخرجہ: مسند احمد (۱/۳۵۳),3045,It was\nnarrated that Anas bin Malik said:,Chapters on Food
3046,حَدَّثَنَا جُبَارَةُ بْنُ الْمُغَلِّسِ، حَدَّثَنَا كَثِيرُ بْنُ سُلَيْمٍ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ مَا رُفِعَ مِنْ بَيْنِ يَدَىْ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ فَضْلُ شِوَاءٍ قَطُّ وَلاَ حُمِلَتْ مَعَهُ طِنْفِسَةٌ ـ صلى الله عليه وسلم ـ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحج ۳۴ (۱۵۶۶)،۱۰۷ (۱۶۹۷)،۱۲۶ (۱۷۲۵)، المغازي ۷۷ (۴۳۹۸)، اللباس ۶۹ (۵۹۱۶)، صحیح مسلم/الحج ۲۵ (۱۲۲۹)، سنن ابی داود/الحج ۲۴ (۱۸۰۶)، سنن النسائی/الحج ۴۰ (۲۶۸۳)،(تحفة الأشراف:۱۵۸۰۰)، وقد أخرجہ: موطا امام مالک/الحج ۵۸ (۱۸۰)، مسند احمد (۶/۲۸۳،۲۸۴،۲۸۵),3046,It was\nnarrated that Anas bin Malik said:,Chapters on Food
3047,حَدَّثَنَا حَرْمَلَةُ بْنُ يَحْيَى، حَدَّثَنَا يَحْيَى بْنُ بُكَيْرٍ، حَدَّثَنَا ابْنُ لَهِيعَةَ، أَخْبَرَنِي سُلَيْمَانُ بْنُ زِيَادٍ الْحَضْرَمِيُّ، عَنْ عَبْدِ اللَّهِ بْنِ الْحَارِثِ بْنِ الْجَزْءِ الزُّبَيْدِيِّ، قَالَ أَكَلْنَا مَعَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ طَعَامًا فِي الْمَسْجِدِ لَحْمًا قَدْ شُوِيَ فَمَسَحْنَا أَيْدِيَنَا بِالْحَصْبَاءِ ثُمَّ قُمْنَا فَصَلَّى وَلَمْ يَتَوَضَّأْ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحج ۱۹ (۱۵۴۰)، اللباس ۶۹ (۵۹۱۵)، صحیح مسلم/الحج ۳ (۱۱۸۴)، سنن ابی داود/الحج ۱۲ (۱۷۴۷)، سنن النسائی/الحج ۴۰ (۲۶۸۴)،(تحفة الأشراف:۶۹۷۶)، وقد أخرجہ: مسند احمد (۲/۱۲۱،۱۳۱),3047,It was\nnarrated that ‘Abdullah bin Harith bin Jaz’ Az-Zubaidi said:,Chapters on Food
3048,"حَدَّثَنَا إِسْمَاعِيلُ بْنُ أَسَدٍ، حَدَّثَنَا جَعْفَرُ بْنُ عَوْنٍ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ أَبِي خَالِدٍ، عَنْ قَيْسِ بْنِ أَبِي حَازِمٍ، عَنْ أَبِي مَسْعُودٍ، قَالَ أَتَى النَّبِيَّ ـ صلى الله عليه وسلم ـ رَجُلٌ فَكَلَّمَهُ فَجَعَلَ تُرْعَدُ فَرَائِصُهُ فَقَالَ لَهُ ‏ ‏ هَوِّنْ عَلَيْكَ فَإِنِّي لَسْتُ بِمَلِكٍ إِنَّمَا أَنَا ابْنُ امْرَأَةٍ تَأْكُلُ الْقَدِيدَ ‏""""‏ ‏.‏ قَالَ أَبُو عَبْدِ اللَّهِ إِسْمَاعِيلُ وَحْدَهُ وَصَلَهُ ‏.‏""",Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/المناسک ۶۵ (۱۹۳۷)،(تحفة الأشراف:۲۳۹۷)، وقد أخرجہ: مسند احمد (۳/۳۲۶)، سنن الدارمی/المناسک ۵۰ (۱۹۲۱),,It was narrated that Abu Mas`ud said:,Chapters on Food
3049,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ، حَدَّثَنَا سُفْيَانُ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَابِسٍ، أَخْبَرَنِي أَبِي، عَنْ عَائِشَةَ، قَالَتْ لَقَدْ كُنَّا نَرْفَعُ الْكُرَاعَ فَيَأْكُلُهُ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ بَعْدَ خَمْسَ عَشْرَةَ مِنَ الأَضَاحِيِّ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/العلم ۲۴ (۸۴)، الحج ۱۲۵ (۱۷۲۳)،۱۳۰ (۱۷۳۵)، الأیمان ۱۵ (۶۶۶۶)،(تحفة الأشراف:۵۹۹۹)، وقد أخرجہ: صحیح مسلم/الحج ۵۷ (۱۳۰۷)، سنن ابی داود/الحج ۷۹ (۱۹۸۳)، سنن النسائی/الحج ۲۲۴ (۳۰۶۹)، مسند احمد (۱/۲۱۶،۲۶۹،۲۹۱،۳۰۰،۳۱۱،۳۲۸),3049,It was\nnarrated that ‘Aishah said:,Chapters on Food
3050,"حَدَّثَنَا أَبُو مُصْعَبٍ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ زَيْدِ بْنِ أَسْلَمَ، عَنْ أَبِيهِ، عَنْ عَبْدِ اللَّهِ بْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ أُحِلَّتْ لَنَا مَيْتَتَانِ وَدَمَانِ فَأَمَّا الْمَيْتَتَانِ فَالْحُوتُ وَالْجَرَادُ وَأَمَّا الدَّمَانِ فَالْكَبِدُ وَالطِّحَالُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الحج ۱۲۵ (۱۷۲۳)،۱۳۰ (۱۷۳۵)، سنن ابی داود/المناسک ۷۹ (۱۹۸۳)، سنن النسائی/مناسک الحج ۲۲۴ (۳۰۶۹)،(تحفة الأشراف:۶۰۴۷)، وقد أخرجہ: مسند احمد (۱/۲۱۶،۲۵۸،۲۶۹،۲۹۱،۳۰۰،۳۱۱،۳۸۲),,It was\nnarrated from ‘Abdullah bin ‘Umar that the Messenger of Allah\n(ﷺ) said:,Chapters on Food
3051,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِيَةَ، حَدَّثَنَا عِيسَى بْنُ أَبِي عِيسَى، عَنْ رَجُلٍ، - أُرَاهُ مُوسَى - عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ سَيِّدُ إِدَامِكُمُ الْمِلْحُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/العلم ۲۳ (۸۳)، الحج ۱۳۱ (۱۷۳۶،۱۷۳۷)، صحیح مسلم/الحج ۵۷ (۱۳۰۶)، سنن ابی داود/الحج ۸۸ (۲۰۱۴)، سنن الترمذی/الحج ۷۶ (۹۱۶)،(تحفة الأشراف:۸۹۰۶)، وقد أخرجہ: موطا امام مالک/الحج ۸۱ (۲۴۲)، مسند احمد (۲/۱۵۹،۱۶۰،۱۹۲،۲۰۲،۲۱۰،۲۱۷)، سنن الدارمی/المناسک ۶۵ (۱۹۴۸),,It was\nnarrated from Anas bin Malik that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Food
3052,"حَدَّثَنَا أَحْمَدُ بْنُ أَبِي الْحَوَارِيِّ، حَدَّثَنَا مَرْوَانُ بْنُ مُحَمَّدٍ، حَدَّثَنَا سُلَيْمَانُ بْنُ بِلاَلٍ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، قَالَتْ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ نِعْمَ الإِدَامُ الْخَلُّ ‏""""‏ ‏.‏""",Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۳۹۸، ومصباح الزجاجة:۱۰۵۹)، وقد أخرجہ: مسند احمد (۳/۳۲۶),,It was\nnarrated from ‘Aishah that the Messenger of Allah (ﷺ) said:,Chapters on Food
3053,"حَدَّثَنَا جُبَارَةُ بْنُ الْمُغَلِّسِ، حَدَّثَنَا قَيْسُ بْنُ الرَّبِيعِ، عَنْ مُحَارِبِ بْنِ دِثَارٍ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ نِعْمَ الإِدَامُ الْخَلُّ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۵۳ (۱۲۹۹)، سنن ابی داود/الحج ۷۸ (۱۹۷۱)، سنن الترمذی/الحج ۵۹ (۸۹۴)، سنن النسائی/الحج ۲۲۱ (۳۰۶۵)،(تحفة الأشراف:۲۷۹۵)، وقد أخرجہ: مسند احمد (۳/۳۱۲،۳۱۹،۴۰۰)، سنن الدارمی/المناسک ۵۸ (۱۹۳۷),,It was\nnarrated from Jabir bin ‘Abdullah that the Messenger of Allah\n(ﷺ)\nsaid:,Chapters on Food
3054,"حَدَّثَنَا الْعَبَّاسُ بْنُ عُثْمَانَ الدِّمَشْقِيُّ، حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، حَدَّثَنَا عَنْبَسَةُ بْنُ عَبْدِ الرَّحْمَنِ، عَنْ مُحَمَّدِ بْنِ زَاذَانَ، أَنَّهُ حَدَّثَهُ قَالَ حَدَّثَتْنِي أُمُّ سَعْدٍ، قَالَتْ دَخَلَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَلَى عَائِشَةَ وَأَنَا عِنْدَهَا فَقَالَ ‏""‏ هَلْ مِنْ غَدَاءٍ ‏""‏ ‏.‏ قَالَتْ عِنْدَنَا خُبْزٌ وَتَمْرٌ وَخَلٌّ ‏.‏ فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏""‏ نِعْمَ الإِدَامُ الْخَلُّ اللَّهُمَّ بَارِكْ فِي الْخَلِّ فَإِنَّهُ كَانَ إِدَامَ الأَنْبِيَاءِ قَبْلِي وَلَمْ يَفْتَقِرْ بَيْتٌ فِيهِ خَلٌّ ‏""‏ ‏.‏",Al-Albani: Daif Isnaad; Muhammad Fouad Abd al-Baqi: Daif Isnaad; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/الحج ۶۲ (۸۹۸)،(تحفة الأشراف:۶۴۶۶)، وقد أخرجہ: مسند احمد (۱/۲۴۸،۲۹۰،۳۲۸),3054,Umm Sa’d\nsaid:,Chapters on Food
3055,"حَدَّثَنَا الْحُسَيْنُ بْنُ مَهْدِيٍّ، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَنْبَأَنَا مَعْمَرٌ، عَنْ زَيْدِ بْنِ أَسْلَمَ، عَنْ أَبِيهِ، عَنْ عُمَرَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ اِئْتَدِمُوا بِالزَّيْتِ وَادَّهِنُوا بِهِ فَإِنَّهُ مِنْ شَجَرَةٍ مُبَارَكَةٍ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/البیوع ۵ (۳۳۳۴)، سنن الترمذی/الفتن ۲ (۲۱۵۹)، تفسیر القرآن ۱۰ (۱)(۳۰۸۷)،(تحفة الأشراف:۱۰۶۹۱)، وقد أخرجہ: مسند احمد (۳/۴۲۶،۴۸۹),,It was\nnarrated from ‘Umar that the Messenger of Allah (ﷺ) said:,Chapters on Food
3056,"حَدَّثَنَا عُقْبَةُ بْنُ مُكْرَمٍ، حَدَّثَنَا صَفْوَانُ بْنُ عِيسَى، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ سَعِيدٍ، عَنْ جَدِّهِ، قَالَ سَمِعْتُ أَبَا هُرَيْرَةَ، يَقُولُ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ كُلُوا الزَّيْتَ وَادَّهِنُوا بِهِ فَإِنَّهُ مُبَارَكٌ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۱۹۸، ومصباح الزجاجة:۱۰۶۰)، وقد أخرجہ: مسند احمد (۴/۸۰)(یہ حدیث مکرر ہے دیکھئے:۲۳۱),,‘Abdullah bin Sa’eed narrated that his grandfather said:,Chapters on Food
3057,"حَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا زَيْدُ بْنُ الْحُبَابِ، عَنْ جَعْفَرِ بْنِ بُرْدٍ الرَّاسِبِيِّ، حَدَّثَتْنِي مَوْلاَتِي أُمُّ سَالِمٍ الرَّاسِبِيَّةُ، قَالَتْ سَمِعْتُ عَائِشَةَ، تَقُولُ كَانَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ إِذَا أُتِيَ بِلَبَنٍ قَالَ ‏ ‏ بَرَكَةٌ أَوْ بَرَكَتَانِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۵۵۷، ومصباح الزجاجة:۱۰۶۱),,I heard\n‘Aishah say:,Chapters on Food
3058,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ عَيَّاشٍ، حَدَّثَنَا ابْنُ جُرَيْجٍ، عَنِ ابْنِ شِهَابٍ، عَنْ عُبَيْدِ اللَّهِ بْنِ عَبْدِ اللَّهِ بْنِ عُتْبَةَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ أَطْعَمَهُ اللَّهُ طَعَامًا فَلْيَقُلِ اللَّهُمَّ بَارِكْ لَنَا فِيهِ وَارْزُقْنَا خَيْرًا مِنْهُ ‏.‏ وَمَنْ سَقَاهُ اللَّهُ لَبَنًا فَلْيَقُلِ اللَّهُمَّ بَارِكْ لَنَا فِيهِ وَزِدْنَا مِنْهُ فَإِنِّي لاَ أَعْلَمُ مَا يُجْزِئُ مِنَ الطَّعَامِ وَالشَّرَابِ إِلاَّ اللَّبَنُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «صحیح البخاری/الحج ۱۳۲ (۱۷۴۲ تعلیقاً)، سنن ابی داود/المناسک ۶۷ (۱۹۴۵)،(تحفة الأشراف:۸۵۱۴),,It was\nnarrated from Ibn ‘Abbas that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Food
3059,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، وَعَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ، قَالُوا حَدَّثَنَا أَبُو أُسَامَةَ، قَالَ حَدَّثَنَا هِشَامُ بْنُ عُرْوَةَ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، قَالَتْ كَانَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ يُحِبُّ الْحَلْوَاءَ وَالْعَسَلَ ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Shadh; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «حدیث ابن عباس أخرجہ: صحیح البخاری/ الحج ۱۲۹ (۱۷۳۲ تعلیقاً)، سنن ابی داود/المناسک ۸۲ (۲۰۰۰)، سنن الترمذی/الحج ۸۰ (۹۲۰)،(تحفة الأشراف:۶۴۵۲،۱۷۵۹۴)، حدیث عائشہ تقدم تخریجہ في حدیث ابن عباس، وحدیث طاوس تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۸۸۴۵، ومصباح الزجاجة:۱۰۶۲)، وقد أخرجہ: مسند احمد (۱/۲۸۸),3059,It was\nnarrated that ‘Aishah said:,Chapters on Food
3060,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا يُونُسُ بْنُ بُكَيْرٍ، حَدَّثَنَا هِشَامُ بْنُ عُرْوَةَ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، قَالَتْ كَانَتْ أُمِّي تُعَالِجُنِي لِلسُّمْنَةِ تُرِيدُ أَنْ تُدْخِلَنِي عَلَى رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ فَمَا اسْتَقَامَ لَهَا ذَلِكَ حَتَّى أَكَلْتُ الْقِثَّاءَ بِالرُّطَبِ فَسَمِنْتُ كَأَحْسَنِ سُمْنَةٍ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/المناسک ۸۳ (۲۰۰۱)،(تحفة الأشراف:۵۹۱۷),3060,It was\nnarrated that ‘Aishah said:,Chapters on Food
3061,حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، وَإِسْمَاعِيلُ بْنُ مُوسَى، قَالاَ حَدَّثَنَا إِبْرَاهِيمُ بْنُ سَعْدٍ، عَنْ أَبِيهِ، عَنْ عَبْدِ اللَّهِ بْنِ جَعْفَرٍ، قَالَ رَأَيْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَأْكُلُ الْقِثَّاءَ بِالرُّطَبِ ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۴۴۲، ومصباح الزجاجة:۱۰۶۳),3061,It was\nnarrated ‘Abdullah bin Ja’far said:,Chapters on Food
3062,حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، وَعَمْرُو بْنُ رَافِعٍ، قَالاَ حَدَّثَنَا يَعْقُوبُ بْنُ الْوَلِيدِ بْنِ أَبِي هِلاَلٍ الْمَدَنِيُّ، عَنْ أَبِي حَازِمٍ، عَنْ سَهْلِ بْنِ سَعْدٍ، قَالَ كَانَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ يَأْكُلُ الرُّطَبَ بِالْبِطِّيخِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۷۸۴، ومصباح الزجاجة:۱۰۶۴)، وقد أخرجہ: مسند احمد (۳/۳۵۷،۳۷۲),3062,It was\nnarrated that Sahl bin Sa’d said:,Chapters on Food
3063,"حَدَّثَنَا أَحْمَدُ بْنُ أَبِي الْحَوَارِيِّ الدِّمَشْقِيُّ، حَدَّثَنَا مَرْوَانُ بْنُ مُحَمَّدٍ، حَدَّثَنَا سُلَيْمَانُ بْنُ بِلاَلٍ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، قَالَتْ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ بَيْتٌ لاَ تَمْرَ فِيهِ جِيَاعٌ أَهْلُهُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الصلاة ۳۰ (۳۹۷)،۸۱ (۴۸۶)،۹۶ (۵۰۴)، التھجد ۲۵ (۱۱۶۷)، الحج ۵۱ (۱۵۹۸)، الجہاد ۱۲۷ (۲۶۸۸)، المغازي ۴۹ (۴۲۸۹)،۷۷ (۴۴۰۰)، صحیح مسلم/الحج ۶۸ (۱۳۲۹)، سنن ابی داود/الحج ۹۳ (۲۰۲۳)، سنن الترمذی/الحج ۴۶ (۸۷۴)، سنن النسائی/المساجد ۵ (۶۹۳)، القبلة ۶ (۷۵۰)، الحج ۱۲۶ (۲۹۰۸)،۱۲۷ (۲۹۰۹)،(تحفة الأشراف:۲۰۳۷)، وقد أخرجہ: موطا امام مالک/الحج ۶۳ (۱۹۳)، مسند احمد (۲/۳۳،۵۵،۱۱۳،۱۲۰،۱۳۸،۶/۱۲،۱۳،۱۴،۱۵)، سنن الدارمی/المناسک ۴۳ (۱۹۰۸),,It was\nnarrated from ‘Aishah that the Messenger of Allah (ﷺ) said:,Chapters on Food
3064,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ الدِّمَشْقِيُّ، حَدَّثَنَا ابْنُ أَبِي فُدَيْكٍ، حَدَّثَنَا هِشَامُ بْنُ سَعْدٍ، عَنْ عُبَيْدِ اللَّهِ بْنِ عَلِيِّ بْنِ أَبِي رَافِعٍ، عَنْ جَدَّتِهِ، سَلْمَى أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ بَيْتٌ لاَ تَمْرَ فِيهِ كَالْبَيْتِ لاَ طَعَامَ فِيهِ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/المناسک ۹۵ (۲۰۲۹)، سنن الترمذی/الحج ۴۵ (۸۷۳)،(تحفة الأشراف:۱۶۲۳۰)، وقد أخرجہ: مسند احمد (۶/۱۳۷),,"It was\nnarrated from ‘Ubaidullah bin Abu Rafi’, from his grandmother\nSalma, that the Prophet (ﷺ) said:",Chapters on Food
3065,"حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، وَيَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، قَالاَ حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ، أَخْبَرَنِي سُهَيْلُ بْنُ أَبِي صَالِحٍ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ كَانَ إِذَا أُتِيَ بِأَوَّلِ الثَّمَرَةِ قَالَ ‏ ‏ اللَّهُمَّ بَارِكْ لَنَا فِي مَدِينَتِنَا وَفِي ثِمَارِنَا وَفِي مُدِّنَا وَفِي صَاعِنَا بَرَكَةً مَعَ بَرَكَةٍ ‏""""‏ ‏.‏ ثُمَّ يُنَاوِلُهُ أَصْغَرَ مَنْ بِحَضْرَتِهِ مِنَ الْوِلْدَانِ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحج ۱۳۳ (۱۷۴۵)، صحیح مسلم/الحج ۶۰ (۱۳۱۵)، سنن ابی داود/المناسک ۷۵ (۱۹۵۹)،(تحفة الأشراف:۷۹۳۹)، وقد أخرجہ: مسند احمد (۲/۲۲)، سنن الدارمی/المناسک ۹۱ (۱۹۸۶),,"It was\nnarrated from Abu Hurairah that when the first fruits (of the\nseason)\nwere brought, the Messenger of Allah (ﷺ) would say:",Chapters on Food
3066,"حَدَّثَنَا أَبُو بِشْرٍ، بَكْرُ بْنُ خَلَفٍ حَدَّثَنَا يَحْيَى بْنُ مُحَمَّدِ بْنِ قَيْسٍ الْمَدَنِيُّ، حَدَّثَنَا هِشَامُ بْنُ عُرْوَةَ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، قَالَتْ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ كُلُوا الْبَلَحَ بِالتَّمْرِ كُلُوا الْخَلَقَ بِالْجَدِيدِ فَإِنَّ الشَّيْطَانَ يَغْضَبُ وَيَقُولُ بَقِيَ ابْنُ آدَمَ حَتَّى أَكَلَ الْخَلَقَ بِالْجَدِيدِ ‏""""‏ ‏.‏""",Al-Albani: Daif Isnaad; Muhammad Fouad Abd al-Baqi: Daif Isnaad; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۸۸۲، ومصباح الزجاجة:۱۰۶۵),,It was\nnarrated from ‘Aishah that the Messenger of Allah (ﷺ) said:,Chapters on Food
3067,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، حَدَّثَنَا سُفْيَانُ، عَنْ جَبَلَةَ بْنِ سُحَيْمٍ، سَمِعْتُ ابْنَ عُمَرَ، يَقُولُ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ أَنْ يَقْرِنَ الرَّجُلُ بَيْنَ التَّمْرَتَيْنِ حَتَّى يَسْتَأْذِنَ أَصْحَابَهُ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «حدیث أبي بکر بن أبي شیبة أخرجہ: صحیح مسلم/الحج ۵۹ (۱۳۱۱)،(تحفة الأشراف:۱۶۷۸۸)، وباقی الإسناد وتفرد بہ ابن ماجہ،(تحفة الأشراف:۱۷۰۹۵،۱۷۲۳۳،۱۷۲۸۶،۱۷۳۰۰)، وقد أخرجہ: صحیح البخاری/الحج ۱۴۷ (۱۷۶۵)، سنن ابی داود/المناسک ۸۷ (۲۰۰۸)، سنن الترمذی/الحج ۸۲ (۹۲۳),3067,Ibn\n‘Umar said:,Chapters on Food
3068,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا أَبُو دَاوُدَ، حَدَّثَنَا أَبُو عَامِرٍ الْخَزَّازُ، عَنِ الْحَسَنِ، عَنْ سَعْدٍ، مَوْلَى أَبِي بَكْرٍ - وَكَانَ سَعْدٌ يَخْدُمُ النَّبِيَّ ـ صلى الله عليه وسلم ـ وَكَانَ يُعْجِبُهُ حَدِيثُهُ - أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ نَهَى عَنِ الإِقْرَانِ ‏.‏ يَعْنِي فِي التَّمْرِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۵۹۶۰، ومصباح الزجاجة:۱۰۶۶)، وقد أخرجہ: مسند احمد (۶/۷۸),3068,,Chapters on Food
3069,حَدَّثَنَا أَبُو بِشْرٍ، بَكْرُ بْنُ خَلَفٍ حَدَّثَنَا أَبُو قُتَيْبَةَ، عَنْ هَمَّامٍ، عَنْ إِسْحَاقَ بْنِ عَبْدِ اللَّهِ بْنِ أَبِي طَلْحَةَ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ رَأَيْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ أُتِيَ بِتَمْرٍ عَتِيقٍ فَجَعَلَ يُفَتِّشُهُ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «صحیح البخاری/الحج ۱۴۸ (۱۷۶۸)مختصراً، صحیح مسلم/الحج ۵۹ (۱۳۱۰)، سنن الترمذی/الحج ۸۱ (۹۲۱)،(تحفة الأشراف:۸۰۲۵)، وقد أخرجہ: مسند احمد (۲/۸۹),3069,It was\nnarrated that Anas bin Malik said:,Chapters on Food
3070,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا صَدَقَةُ بْنُ خَالِدٍ، حَدَّثَنِي ابْنُ جَابِرٍ، حَدَّثَنِي سُلَيْمُ بْنُ عَامِرٍ، عَنِ ابْنَىْ، بُسْرٍ السُّلَمِيَّيْنِ قَالاَ دَخَلَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ فَوَضَعْنَا تَحْتَهُ قَطِيفَةً لَنَا صَبَبْنَاهَا لَهُ صَبًّا فَجَلَسَ عَلَيْهَا فَأَنْزَلَ اللَّهُ عَزَّ وَجَلَّ عَلَيْهِ الْوَحْىَ فِي بَيْتِنَا وَقَدَّمْنَا لَهُ زُبْدًا وَتَمْرًا وَكَانَ يُحِبُّ الزُّبْدَ ـ صلى الله عليه وسلم ـ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۶۷ (۱۳۲۷)، سنن ابی داود/المناسک ۸۴ (۲۰۰۲)،(تحفة الأشراف:۵۷۰۳)، وقد أخرجہ: صحیح البخاری/الحج ۱۴۴ (۱۷۵۵)، مسند احمد (۱/۲۲۲)، سنن الدارمی/المناسک ۸۵ (۱۹۷۴),3070,"It was\nnarrated that the two sons of Busr, who were of the tribe of\nSulaim,\nsaid:",Chapters on Food
3071,حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، وَسُوَيْدُ بْنُ سَعِيدٍ، قَالاَ حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ أَبِي حَازِمٍ، حَدَّثَنِي أَبِي قَالَ، سَأَلْتُ سَهْلَ بْنَ سَعْدٍ هَلْ رَأَيْتَ النَّقِيَّ قَالَ مَا رَأَيْتُ النَّقِيَّ حَتَّى قُبِضَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏.‏ فَقُلْتُ فَهَلْ كَانَ لَهُمْ مَنَاخِلُ عَلَى عَهْدِ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ مَا رَأَيْتُ مُنْخُلاً حَتَّى قُبِضَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏.‏ قُلْتُ فَكَيْفَ كُنْتُمْ تَأْكُلُونَ الشَّعِيرَ غَيْرَ مَنْخُولٍ قَالَ نَعَمْ نَنْفُخُهُ فَيَطِيرُ مِنْهُ مَا طَارَ وَمَا بَقِيَ ثَرَّيْنَاهُ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۱۰۹، ومصباح الزجاجة:۱۰۶۷),3071,‘Abdul-‘Aziz bin Abu Hazim said:,Chapters on Food
3072,"حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، حَدَّثَنَا ابْنُ وَهْبٍ، أَخْبَرَنِي عَمْرُو بْنُ الْحَارِثِ، أَخْبَرَنِي بَكْرُ بْنُ سَوَادَةَ، أَنَّ حَنَشَ بْنَ عَبْدِ اللَّهِ، حَدَّثَهُ عَنْ أُمِّ أَيْمَنَ، أَنَّهَا غَرْبَلَتْ دَقِيقًا فَصَنَعَتْهُ لِلنَّبِيِّ ـ صلى الله عليه وسلم ـ رَغِيفًا فَقَالَ ‏""‏ مَا هَذَا ‏""‏ ‏.‏ قَالَتْ طَعَامٌ نَصْنَعُهُ بِأَرْضِنَا فَأَحْبَبْتُ أَنْ أَصْنَعَ مِنْهُ لَكَ رَغِيفًا ‏.‏ فَقَالَ ‏""‏ رُدِّيهِ فِيهِ ثُمَّ اعْجِنِيهِ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «حدیث أبيبکر بن أبيشیبة تفردبہ ابن ماجہ،(تحفة الأشراف:۱۶۴۵۰)، وحدیث أبي سلمة أخرجہ: صحیح البخاری/الحیض ۲۷ (۳۲۸)، صحیح مسلم/الحج ۶۷ (۱۲۱۱)،(تحفة الأشراف:۱۷۷۶۸)وحدیث عروة أخرجہ: صحیح مسلم/الحج ۶۷ (۱۲۱۱)،(تحفة الأشراف:۱۶۵۸۷)، وقد أخرجہ: سنن ابی داود/المناسک ۸۵ (۲۰۰۳)، سنن الترمذی/الحیض ۹۹ (۳۹۱)، سنن النسائی/الحیض ۲۳ (۳۹۱)، موطا امام مالک/الحج ۷۵ (۲۲۵)، مسند احمد (۶/۳۸،۳۹،۸۲،۹۹،۱۲۲،۱۶۴،۱۷۵،۱۹۳،۲۰۲،۲۰۷،۲۱۳،۲۲۴)، سنن الدارمی/المناسک ۷۳ (۱۹۵۸),3072,It was\nnarrated from Umm Ayman that she sifted some flour and made a\nloaf of\nbread for the Prophet (ﷺ). He said:,Chapters on Food
3073,حَدَّثَنَا الْعَبَّاسُ بْنُ الْوَلِيدِ الدِّمَشْقِيُّ، حَدَّثَنَا مُحَمَّدُ بْنُ عُثْمَانَ أَبُو الْجَمَاهِرِ، حَدَّثَنَا سَعِيدُ بْنُ بَشِيرٍ، حَدَّثَنَا قَتَادَةُ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ مَا رَأَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ رَغِيفًا مُحَوَّرًا بِوَاحِدٍ مِنْ عَيْنَيْهِ حَتَّى لَحِقَ بِاللَّهِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحج ۱۵۱ (۱۷۷۱)، صحیح مسلم/۱۷ (۱۲۱۱)،(تحفة الأشراف:۱۵۹۴۶)، وقد أخرجہ: مسند احمد (۶/۲۲۴، سنن الدارمی/المناسک ۷۳ (۱۹۵۸),3073,It was\nnarrated that Anas bin Malik said:,Chapters on Food
3074,حَدَّثَنَا أَبُو عُمَيْرٍ، عِيسَى بْنُ مُحَمَّدِ بْنِ النَّحَّاسِ الرَّمْلِيُّ حَدَّثَنَا ضَمْرَةُ بْنُ رَبِيعَةَ، عَنِ ابْنِ عَطَاءٍ، عَنْ أَبِيهِ، قَالَ زَارَ أَبُو هُرَيْرَةَ قَوْمَهُ بِيُبْنَا فَأَتَوْهُ بِرُقَاقٍ مِنْ رُقَاقِ الأُوَلِ فَبَكَى وَقَالَ مَا رَأَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ هَذَا بِعَيْنِهِ قَطُّ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۱۹ (۱۲۱۸)بلفظ: ''ابدا'' وھوالصواب، سنن ابی داود/الحج ۵۷ (۱۹۰۵،۱۹۰۹)،(تحفة الأشراف:۲۵۹۳)، وقد أخرجہ: سنن النسائی/الحج ۴۶ (۲۷۱۳)،۵۱ (۲۷۴۱)،۵۲ (۲۷۴۴)،۷۳ (۲۸۰۰)، مسند احمد (۳/۳۲۰،۳۳۱،۳۳۳،۳۴۰،۳۷۳،۳۸۸،۳۹۴،۳۹۷)، سنن الدارمی/المناسک ۱۱ (۱۸۴۶),3074,It was\nnarrated from Ibn ‘Ata that his father said:,Chapters on Food
3075,حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ، وَأَحْمَدُ بْنُ سَعِيدٍ الدَّارِمِيُّ، قَالاَ حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ، حَدَّثَنَا هَمَّامٌ، حَدَّثَنَا قَتَادَةُ، قَالَ كُنَّا نَأْتِي أَنَسَ بْنَ مَالِكٍ - قَالَ إِسْحَاقُ وَخَبَّازُهُ قَائِمٌ وَقَالَ الدَّارِمِيُّ وَخِوَانُهُ مَوْضُوعٌ - فَقَالَ يَوْمًا كُلُوا فَمَا أَعْلَمُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ رَأَى رَغِيفًا مُرَقَّقًا بِعَيْنِهِ حَتَّى لَحِقَ بِاللَّهِ وَلاَ شَاةً سَمِيطًا قَطُّ ‏.‏,Al-Albani: Hasan Isnaad; Muhammad Fouad Abd al-Baqi: Hasan Isnaad; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۷۶۸۴)، وقد أخرجہ:(۶/۱۴۱),3075,Qatadah\nsaid:,Chapters on Food
3076,"حَدَّثَنَا عَبْدُ الْوَهَّابِ بْنُ الضَّحَّاكِ السُّلَمِيُّ أَبُو الْحَارِثِ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ عَيَّاشٍ، حَدَّثَنَا مُحَمَّدُ بْنُ طَلْحَةَ، عَنْ عُثْمَانَ بْنِ يَحْيَى، عَنِ ابْنِ عَبَّاسٍ، قَالَ أَوَّلُ مَا سَمِعْنَا بِالْفَالُوذَجِ، أَنَّ جِبْرِيلَ، عَلَيْهِ السَّلاَمُ أَتَى النَّبِيَّ ـ صلى الله عليه وسلم ـ فَقَالَ إِنَّ أُمَّتَكَ تُفْتَحُ عَلَيْهِمُ الأَرْضُ فَيُفَاضُ عَلَيْهِمْ مِنَ الدُّنْيَا حَتَّى إِنَّهُمْ لَيَأْكُلُونَ الْفَالُوذَجَ ‏.‏ فَقَالَ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏ ‏ وَمَا الْفَالُوذَجُ ‏""""‏ ‏.‏ قَالَ يَخْلِطُونَ السَّمْنَ وَالْعَسَلَ جَمِيعًا ‏.‏ فَشَهَقَ النَّبِيُّ ـ صلى الله عليه وسلم ـ لِذَلِكَ شَهْقَةً ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: «حدیث جابر أخرجہ: سنن الترمذی/الحج ۶ (۸۱۵)،(تحفة الأشراف:۲۶۰۶)، وحدیث ابن عباس تفرد بہ ابن ماجہ، تحفة الأشراف:۶۴۸۵، ومصباح الزجاجة:۱۰۶۸),,It was\nnarrated that Ibn ‘Abbas said:,Chapters on Food
3077,"حَدَّثَنَا هَدِيَّةُ بْنُ عَبْدِ الْوَهَّابِ، حَدَّثَنَا الْفَضْلُ بْنُ مُوسَى السِّيْنَانِيُّ، حَدَّثَنَا الْحُسَيْنُ بْنُ وَاقِدٍ، عَنْ أَيُّوبَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ذَاتَ يَوْمٍ ‏""‏ وَدِدْتُ لَوْ أَنَّ عِنْدَنَا خُبْزَةً بَيْضَاءَ مِنْ بُرَّةٍ سَمْرَاءَ مُلَبَّقَةٍ بِسَمْنٍ نَأْكُلُهَا ‏""‏ ‏.‏ قَالَ فَسَمِعَ بِذَلِكَ رَجُلٌ مِنَ الأَنْصَارِ فَاتَّخَذَهُ فَجَاءَ بِهِ إِلَيْهِ فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏""‏ فِي أَىِّ شَىْءٍ كَانَ هَذَا السَّمْنُ ‏""‏ ‏.‏ قَالَ فِي عُكَّةِ ضَبٍّ ‏.‏ قَالَ فَأَبَى أَنْ يَأْكُلَهُ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن ابی داود/الحج ۴۴ (۱۸۶۲،۱۸۶۳)، سنن الترمذی/الحج ۹۶ (۹۴۰)، سنن النسائی/الحج ۱۰۲ (۲۸۶۳)،(تحفة الأشراف:۳۲۹۴،۶۲۴۱،۱۴۲۵۴)، وقد أخرجہ: مسند احمد (۳/۴۵۰)، سنن الدارمی/المناسک ۵۷ (۱۹۳۶),3077,It was\nnarrated that Ibn ‘Umar said:,Chapters on Food
3078,"حَدَّثَنَا أَحْمَدُ بْنُ عَبْدَةَ، حَدَّثَنَا عُثْمَانُ بْنُ عَبْدِ الرَّحْمَنِ، حَدَّثَنَا حُمَيْدُ الطَّوِيلُ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ صَنَعَتْ أُمُّ سُلَيْمٍ لِلنَّبِيِّ ـ صلى الله عليه وسلم ـ خُبْزَةً وَضَعَتْ فِيهَا شَيْئًا مِنْ سَمْنٍ ثُمَّ قَالَتِ اذْهَبْ إِلَى النَّبِيِّ ـ صلى الله عليه وسلم ـ فَادْعُهُ قَالَ فَأَتَيْتُهُ فَقُلْتُ أُمِّي تَدْعُوكَ ‏.‏ قَالَ فَقَامَ وَقَالَ لِمَنْ كَانَ عِنْدَهُ مِنَ النَّاسِ ‏""‏ قُومُوا ‏""‏ ‏.‏ قَالَ فَسَبَقْتُهُمْ إِلَيْهَا فَأَخْبَرْتُهَا فَجَاءَ النَّبِيُّ ـ صلى الله عليه وسلم ـ فَقَالَ ‏""‏ هَاتِي مَا صَنَعْتِ ‏""‏ ‏.‏ فَقَالَتْ إِنَّمَا صَنَعْتُهُ لَكَ وَحْدَكَ ‏.‏ فَقَالَ ‏""‏ هَاتِيهِ ‏""‏ ‏.‏ فَقَالَ ‏""‏ يَا أَنَسُ أَدْخِلْ عَلَىَّ عَشْرَةً عَشْرَةً ‏""‏ ‏.‏ قَالَ فَمَا زِلْتُ أُدْخِلُ عَلَيْهِ عَشْرَةً عَشْرَةً فَأَكَلُوا حَتَّى شَبِعُوا وَكَانُوا ثَمَانِينَ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «انظر ما قبلہ،(تحفة الأشراف:۳۲۹۴،۶۲۴۱،۱۴۲۵۴),3078,It was\nnarrated that Anas bin Malik said:,Chapters on Food
3079,حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِيَةَ، عَنْ يَزِيدَ بْنِ كَيْسَانَ، عَنْ أَبِي حَازِمٍ، عَنْ أَبِي هُرَيْرَةَ، أَنَّهُ قَالَ وَالَّذِي نَفْسِي بِيَدِهِ مَا شَبِعَ نَبِيُّ اللَّهِ ـ صلى الله عليه وسلم ـ ثَلاَثَةَ أَيَّامٍ تِبَاعًا مِنْ خُبْزِ الْحِنْطَةِ حَتَّى تَوَفَّاهُ اللَّهُ عَزَّ وَجَلَّ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/المحصر ۵ (۱۸۱۴)،۶ (۱۸۱۵)،۷ (۱۸۱۶)،۸ (۱۸۱۷)، المغازي ۳۵ (۴۱۵۹)، تفسیر البقرة ۳۲ (۴۵۱۷)، المرضیٰ ۱۶ (۵۶۶۵)، الطب ۱۶ (۵۷۰۳)، الکفارات ۱ (۶۸۰۸)، صحیح مسلم/الحج ۱۰ (۱۲۰۱)، سنن الترمذی/الحج ۱۰۷ (۹۵۳)،(تحفة الأشراف:۱۱۱۱۲)، وقد أخرجہ: سنن ابی داود/الحج ۴۳ (۱۸۵۶)، سنن النسائی/الحج ۹۶ (۲۸۵۴)، موطا امام مالک/الحج ۷۸ (۲۳۷)، مسند احمد (۴/۲۴۲،۲۴۳),3079,It was\nnarrated that Abu Hurairah said:,Chapters on Food
3080,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا مُعَاوِيَةُ بْنُ عَمْرٍو، حَدَّثَنَا زَائِدَةُ، عَنْ مَنْصُورٍ، عَنْ إِبْرَاهِيمَ، عَنِ الأَسْوَدِ، عَنْ عَائِشَةَ، قَالَتْ مَا شَبِعَ آلُ مُحَمَّدٍ ـ صلى الله عليه وسلم ـ مُنْذُ قَدِمُوا الْمَدِينَةَ ثَلاَثَ لَيَالٍ تِبَاعًا مِنْ خُبْزِ بُرٍّ حَتَّى تُوُفِّيَ ـ صلى الله عليه وسلم ـ ‏.‏,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۱۱۸),3080,it was\nnarrated that ‘Aishah said:,Chapters on Food
3081,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو أُسَامَةَ، حَدَّثَنَا هِشَامُ بْنُ عُرْوَةَ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، قَالَتْ لَقَدْ تُوُفِّيَ النَّبِيُّ ـ صلى الله عليه وسلم ـ وَمَا فِي بَيْتِي مِنْ شَىْءٍ يَأْكُلُهُ ذُو كَبِدٍ إِلاَّ شَطْرُ شَعِيرٍ فِي رَفٍّ لِي فَأَكَلْتُ مِنْهُ حَتَّى طَالَ عَلَىَّ فَكِلْتُهُ فَفَنِيَ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «صحیح البخاری/جزاء الصید ۱۱ (۱۸۳۵)، الصوم ۳۲ (۱۹۳۸)، الطب ۱۲ (۵۶۹۵)،۱۵ (۵۷۰۰)، صحیح مسلم/الحج ۱۱ (۱۲۰۲)، سنن ابی داود/الحج ۳۶ (۱۸۳۵)، سنن الترمذی/الحج ۲۲ (۸۳۹)، سنن النسائی/الحج ۹۲ (۲۸۴۹)،(تحفة الأشراف:۵۷۰۹)، وقد أخرجہ: مسند احمد (۱/۲۱۵،۲۲۱،۲۲۲،۲۳۶،۲۴۸،۲۴۹،۲۶۰،۲۸۳،۲۸۶،۲۹۲،۳۰۶،۳۱۵،۳۳۳،۳۴۶،۳۵۱،۳۷۲،۴،۳)، سنن الدارمی/المناسک ۲۰ (۱۸۶۰),3081,It was\nnarrated that ‘Aishah said:,Chapters on Food
3082,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، حَدَّثَنَا شُعْبَةُ، عَنْ أَبِي إِسْحَاقَ، سَمِعْتُ عَبْدَ الرَّحْمَنِ بْنَ يَزِيدَ، يُحَدِّثُ عَنِ الأَسْوَدِ، عَنْ عَائِشَةَ، قَالَتْ مَا شَبِعَ آلُ مُحَمَّدٍ ـ صلى الله عليه وسلم ـ مِنْ خُبْزِ الشَّعِيرِ حَتَّى قُبِضَ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۷۷۸، ومصباح الزجاجة:۱۰۶۹)، وقد أخرجہ: مسند احمد (۳/۳۵۷،۳۶۳),3082,It was\nnarrated that ‘Aishah said:,Chapters on Food
3083,حَدَّثَنَا عَبْدُ اللَّهِ بْنُ مُعَاوِيَةَ الْجُمَحِيُّ، حَدَّثَنَا ثَابِتُ بْنُ يَزِيدَ، عَنْ هِلاَلِ بْنِ خَبَّابٍ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ كَانَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ يَبِيتُ اللَّيَالِيَ الْمُتَتَابِعَةَ طَاوِيًا وَأَهْلُهُ لاَ يَجِدُونَ الْعَشَاءَ وَكَانَ عَامَّةَ خُبْزِهِمْ خُبْزُ الشَّعِيرِ ‏.‏,Al-Albani: Daif Isnaad; Muhammad Fouad Abd al-Baqi: Daif Isnaad; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/الحج ۱۱۴ (۹۶۲)،(تحفة الأشراف:۷۰۶۰)، وقد أخرجہ: مسند احمد (۲/۲۵،۲۹،۵۹،۷۲،۱۲۶،۱۴۵),3083,It was\nnarrated that Ibn ‘Abbas said:,Chapters on Food
3084,حَدَّثَنَا يَحْيَى بْنُ عُثْمَانَ بْنِ سَعِيدِ بْنِ كَثِيرِ بْنِ دِينَارٍ الْحِمْصِيُّ، - وَكَانَ يُعَدُّ مِنَ الأَبْدَالِ - حَدَّثَنَا بَقِيَّةُ، حَدَّثَنَا يُوسُفُ بْنُ أَبِي كَثِيرٍ، عَنْ نُوحِ بْنِ ذَكْوَانَ، عَنِ الْحَسَنِ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ لَبِسَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ الصُّوفَ وَاحْتَذَى الْمَخْصُوفَ ‏.‏ وَقَالَ أَكَلَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ بَشِعًا وَلَبِسَ خَشِنًا ‏.‏ فَقِيلَ لِلْحَسَنِ مَا الْبَشِعُ قَالَ غَلِيظُ الشَّعِيرِ مَا كَانَ يُسِيغُهُ إِلاَّ بِجُرْعَةِ مَاءٍ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الجنائز ۱۹ (۱۲۶۵)،۲۱ (۱۲۶۷)، جزاء الصید ۲۰ (۱۸۴۹)،۲۱ (۱۸۵۰)، صحیح مسلم/الحج ۱۴ (۱۲۰۶)، سنن ابی داود/الجنائز ۸۴ (۳۲۳۸،۳۲۳۹)، سنن الترمذی/الحج ۱۰۵ (۹۵۱)، سنن النسائی/الجنائز ۴۱ (۱۹۰۵)، الحج ۴۷ (۲۷۱۴)،۹۷ (۲۸۵۶)،۱۰۱ (۲۸۶۱)،(تحفة الأشراف:۵۵۸۲)، وقد أخرجہ: مسند احمد (۱/۲۱۵،۲۶۶،۲۸۶)، سنن الدارمی/المناسک ۳۵ (۱۸۹۴),3084,It was\nnarrated from Hasan that Anas bin Malik said:,Chapters on Food
3085,"حَدَّثَنَا هِشَامُ بْنُ عَبْدِ الْمَلِكِ الْحِمْصِيُّ، حَدَّثَنَا مُحَمَّدُ بْنُ حَرْبٍ، حَدَّثَتْنِي أُمِّي، عَنْ أُمِّهَا، أَنَّهَا سَمِعَتِ الْمِقْدَامَ بْنَ مَعْدِيكَرِبَ، يَقُولُ سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ مَا مَلأَ آدَمِيٌّ وِعَاءً شَرًّا مِنْ بَطْنٍ حَسْبُ الآدَمِيِّ لُقَيْمَاتٌ يُقِمْنَ صُلْبَهُ فَإِنْ غَلَبَتِ الآدَمِيَّ نَفْسُهُ فَثُلُثٌ لِلطَّعَامِ وَثُلُثٌ لِلشَّرَابِ وَثُلُثٌ لِلنَّفَسِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الأطعمة ۳۲ (۳۸۰۱)، سنن الترمذی/الحج ۲۸ (۸۵۱)، الاطعمة ۴ (۱۷۹۲)، سنن النسائی/الحج ۸۹ (۲۸۳۹)، الصید ۲۷ (۴۳۲۸)،(تحفة الأشراف:۲۳۸۱)، وقد أخرجہ: مسند احمد (۳/۲۹۷،۳۱۸،۳۲۲)، سنن الدارمی/المناسک ۹۰ (۱۹۸۴),,Miqdam\nbin Madikarib said:,Chapters on Food
3086,"حَدَّثَنَا عَمْرُو بْنُ رَافِعٍ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ عَبْدِ اللَّهِ أَبُو يَحْيَى، عَنْ يَحْيَى الْبَكَّاءِ، عَنِ ابْنِ عُمَرَ، قَالَ تَجَشَّأَ رَجُلٌ عِنْدَ النَّبِيِّ ـ صلى الله عليه وسلم ـ فَقَالَ ‏ ‏ كُفَّ جُشَاءَكَ عَنَّا فَإِنَّ أَطْوَلَكُمْ جُوعًا يَوْمَ الْقِيَامَةِ أَكْثَرُكُمْ شِبَعًا فِي دَارِ الدُّنْيَا ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۴۸۳۵، ومصباح الزجاجة:۱۰۷۰),,It was\nnarrated that Ibn ‘Umar said:,Chapters on Food
3087,"حَدَّثَنَا دَاوُدُ بْنُ سُلَيْمَانَ الْعَسْكَرِيُّ، قَالَ حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، حَدَّثَنَا سَعِيدُ بْنُ مُحَمَّدٍ الثَّقَفِيُّ، عَنْ مُوسَى الْجُهَنِيِّ، عَنْ زَيْدِ بْنِ وَهْبٍ، عَنْ عَطِيَّةَ بْنِ عَامِرٍ الْجُهَنِيِّ، قَالَ سَمِعْتُ سَلْمَانَ، وَأُكْرِهَ، عَلَى طَعَامٍ يَأْكُلُهُ فَقَالَ حَسْبِي إِنِّي سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ إِنَّ أَكْثَرَ النَّاسِ شِبَعًا فِي الدُّنْيَا أَطْوَلُهُمْ جُوعًا يَوْمَ الْقِيَامَةِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۹ (۱۱۹۸)، سنن النسائی/الحج ۸۳ (۲۸۳۲)،۱۱۳ (۲۸۸۴)،۱۱۴ (۲۸۸۵)،(تحفة الأشراف:۱۶۱۲۲)، وقد أخرجہ: صحیح البخاری/جزاء الصید ۷ (۱۸۲۹)، بدأ الخلق ۱۶ (۳۳۱۴)، سنن الترمذی/الحج ۲۱ (۸۳۷)، مسند احمد (۶/۲۳،۸۷،۹۷،۱۱۲،۱۶۴،۲۰۳،۲۵۹،۲۶۱)، سنن الدارمی/المناسک ۱۹ (۱۸۵۸),,It was\nnarrated that ‘Atiyyah bin ‘Amir Al-Juhani said:,Chapters on Food
3088,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، وَسُوَيْدُ بْنُ سَعِيدٍ، وَيَحْيَى بْنُ عُثْمَانَ بْنِ سَعِيدِ بْنِ كَثِيرِ بْنِ دِينَارٍ الْحِمْصِيُّ، قَالُوا حَدَّثَنَا بَقِيَّةُ بْنُ الْوَلِيدِ، حَدَّثَنَا يُوسُفُ بْنُ أَبِي كَثِيرٍ، عَنْ نُوحِ بْنِ ذَكْوَانَ، عَنِ الْحَسَنِ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِنَّ مِنَ السَّرَفِ أَنْ تَأْكُلَ كُلَّ مَا اشْتَهَيْتَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۹ (۱۱۹۹)،(تحفة الأشراف:۷۹۴۶)، وقد أخرجہ: صحیح البخاری/جزاء الصید ۷ (۱۸۲۶)، بدء الخلق ۱۶ (۳۳۱۵)، سنن ابی داود/الحج ۴۰ (۱۸۴۶)، سنن النسائی/الحج ۸۸ (۲۸۳۸)، موطا امام مالک/الحج ۲۸ (۸۸)، حم۲/۸،۳۲،۳۷،۴۸،۵۰،۵۲،۵۴،۵۷،۶۵،۷۷، سنن الدارمی/المناسک ۱۹ (۱۸۵۷),,It was\nnarrated from Anas bin Malik that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Food
3089,"حَدَّثَنَا إِبْرَاهِيمُ بْنُ مُحَمَّدِ بْنِ يُوسُفَ الْفِرْيَابِيُّ، حَدَّثَنَا وَسَّاجُ بْنُ عُقْبَةَ بْنِ وَسَّاجٍ، حَدَّثَنَا الْوَلِيدُ بْنُ مُحَمَّدٍ الْمُوَقَّرِيُّ، حَدَّثَنَا الزُّهْرِيُّ، عَنْ عُرْوَةَ، عَنْ عَائِشَةَ، قَالَتْ دَخَلَ النَّبِيُّ ـ صلى الله عليه وسلم ـ الْبَيْتَ فَرَأَى كِسْرَةً مُلْقَاةً فَأَخَذَهَا فَمَسَحَهَا ثُمَّ أَكَلَهَا وَقَالَ ‏ ‏ يَا عَائِشَةُ أَكْرِمِي كَرِيمَكِ فَإِنَّهَا مَا نَفَرَتْ عَنْ قَوْمٍ قَطُّ فَعَادَتْ إِلَيْهِمْ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۱۳۳، ومصباح الزجاجة:۱۰۷۱)، وقد أخرجہ: سنن ابی داود/المناسک ۴۰ (۱۸۴۸)، سنن الترمذی/الحج ۲۱ (۸۳۸)، مسند احمد (۳/۳،۴۲،۷۹),,It was\nnarrated that ‘Aishah said:,Chapters on Food
3090,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ، حَدَّثَنَا هُرَيْمٌ، عَنْ لَيْثٍ، عَنْ كَعْبٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ كَانَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ اللَّهُمَّ إِنِّي أَعُوذُ بِكَ مِنَ الْجُوعِ فَإِنَّهُ بِئْسَ الضَّجِيعُ وَأَعُوذُ بِكَ مِنَ الْخِيَانَةِ فَإِنَّهَا بِئْسَتِ الْبِطَانَةُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/جزاء الصید ۶ (۱۸۲۵)، الھبة ۶ (۲۵۷۳)،۱۷ (۲۵۹۶)، صحیح مسلم/الحج ۸ (۱۱۹۳)، سنن الترمذی/الحج ۲۶ (۸۴۹)، سنن النسائی/الحج ۷۹ (۲۸۲۱)،(تحفة الأشراف:۴۹۴۰)، وقد أخرجہ: موطا امام مالک/الحج ۲۵ (۸۳)، مسند احمد (۴/۳۷،۳۸،۷۱،۷۳)، سنن الدارمی/المناسک ۲۲ (۱۸۷۲),,It was\nnarrated that Abu Hurairah said:,Chapters on Food
3091,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ الرَّقِّيُّ، حَدَّثَنَا إِبْرَاهِيمُ بْنُ عَبْدِ السَّلاَمِ بْنِ عَبْدِ اللَّهِ بْنِ بَابَاهْ الْمَخْزُومِيُّ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ مَيْمُونٍ، عَنْ مُحَمَّدِ بْنِ الْمُنْكَدِرِ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لاَ تَدَعُوا الْعَشَاءَ وَلَوْ بِكَفٍّ مِنْ تَمْرٍ فَإِنَّ تَرْكَهُ يُهْرِمُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۱۹۹ (ألف)، ومصباح الزجاجة:۱۰۷۲)، وقد أخرجہ: مسند احمد (۱/۱۰۵),,It was\nnarrated from Jabir bin ‘Abdullah that the Messenger of Allah\n(ﷺ)\nsaid:,Chapters on Food
3092,"حَدَّثَنَا جُبَارَةُ بْنُ الْمُغَلِّسِ، حَدَّثَنَا كَثِيرُ بْنُ سُلَيْمٍ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ الْخَيْرُ أَسْرَعُ إِلَى الْبَيْتِ الَّذِي يُغْشَى مِنَ الشَّفْرَةِ إِلَى سَنَامِ الْبَعِيرِ ‏""""‏ ‏.‏""",Al-Albani: Isnaad Malool; Muhammad Fouad Abd al-Baqi: Isnaad Malool; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۰۰۶، ومصباح الزجاجة:۱۰۷۳),,It was\nnarrated from Anas bin Malik that the Messenger of Allah 9saw)\nsaid:,Chapters on Food
3093,"حَدَّثَنَا جُبَارَةُ بْنُ الْمُغَلِّسِ، حَدَّثَنَا الْمُحَارِبِيُّ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ نَهْشَلٍ، عَنِ الضَّحَّاكِ بْنِ مُزَاحِمٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ الْخَيْرُ أَسْرَعُ إِلَى الْبَيْتِ الَّذِي يُؤْكَلُ فِيهِ مِنَ الشَّفْرَةِ إِلَى سَنَامِ الْبَعِيرِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/جزاء الصید ۲ (۱۸۲۱)،۵ (۱۸۲۴)، الھبة ۳ (۲۵۷۰)، الجہاد ۴۶ (۲۸۵۴)،۸۸ (۲۹۱۴)، الأطعمة ۱۹ (۴۱۴۹)، الذبائح ۱۰ (۵۴۹۰)،۱۱ (۵۴۹۱)، صحیح مسلم/الحج ۸ (۱۱۹۶)کلاھما دون قولہ: ''ولم یأکل منہ'' فإنہ عندھما أنہ أکل منہ، سنن النسائی/الحج ۷۸ (۲۸۱۸)،۸۰ (۲۸۲۸)،(تحفة الأشراف:۱۲۱۰۹)، وقد أخرجہ: سنن ابی داود/الحج ۴۱ (۱۸۵۲)، سنن الترمذی/الحج ۲۵ (۸۴۷)، موطا امام مالک/الحج ۲۴ (۷۶)، مسند احمد (۵/۳۰۰،۳۰۷)، سنن الدارمی/المناسک ۲۲ (۱۸۶۷),,It was\nnarrated from Ibn ‘Abbas that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Food
3094,"حَدَّثَنَا عَلِيُّ بْنُ مَيْمُونٍ الرَّقِّيُّ، حَدَّثَنَا عُثْمَانُ بْنُ عَبْدِ الرَّحْمَنِ، عَنْ عَلِيِّ بْنِ عُرْوَةَ، عَنْ عَبْدِ الْمَلِكِ، عَنْ عَطَاءٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِنَّ مِنَ السُّنَّةِ أَنْ يَخْرُجَ الرَّجُلُ مَعَ ضَيْفِهِ إِلَى بَابِ الدَّارِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحج ۱۰۶ (۱۶۹۶)،۱۱۱ (۱۷۰۱)، الوکالة ۱۴ (۲۳۱۷)، الأضاحي ۱۵ (۵۵۶۶)، صحیح مسلم/الحج ۶۴ (۱۳۲۱)، سنن ابی داود/الحج ۱۷ (۱۷۵۸)، سنن النسائی/الحج ۶۲ (۲۷۷۴)،۶۸ (۲۷۸۵)،(تحفة الأشراف:۱۶۵۸۲،۱۷۹۲۳)، وقد أخرجہ: سنن الترمذی/الحج ۶۹ (۸۰۸)، موطا امام مالک/الحج ۱۵ (۵۱)، مسند احمد (۶/۳۵،۳۶،۷۸،۸۲،۸۵،۹۱،۱۰۲،۱۲۷،۱۷۴،۱۸۰،۱۸۵،۱۹۰،۱۹۱،۲۰۰،۲۰۸،۲۱۳،۲۱۶،۲۱۸،۲۲۵،۲۳۶،۲۵۳،۱۲۷،۱۷۴،۱۸۰،۱۸۵،۱۹۰،۱۹۱،۲۰۰،۲۰۸،۲۱۳،۲۱۶،۲۱۸،۲۲۵،۲۳۶،۲۵۳،۲۶۲)، سنن الدارمی/المناسک ۶۷ (۱۹۵۲),,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Food
3095,حَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا وَكِيعٌ، عَنْ هِشَامٍ الدَّسْتَوَائِيِّ، عَنْ قَتَادَةَ، عَنْ سَعِيدِ بْنِ الْمُسَيَّبِ، عَنْ عَلِيٍّ، قَالَ صَنَعْتُ طَعَامًا فَدَعَوْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ فَجَاءَ فَرَأَى فِي الْبَيْتِ تَصَاوِيرَ فَرَجَعَ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «أنظر ما قبلہ،(تحفة الأشراف:۱۵۹۴۷),3095,It was\nnarrated that ‘Ali said:,Chapters on Food
3096,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ عَبْدِ اللَّهِ الْجَزَرِيُّ، حَدَّثَنَا عَفَّانُ بْنُ مُسْلِمٍ، حَدَّثَنَا حَمَّادُ بْنُ سَلَمَةَ، حَدَّثَنَا سَعِيدُ بْنُ جُمْهَانَ، حَدَّثَنَا سَفِينَةُ أَبُو عَبْدِ الرَّحْمَنِ، أَنَّ رَجُلاً، أَضَافَ عَلِيَّ بْنَ أَبِي طَالِبٍ فَصَنَعَ لَهُ طَعَامًا فَقَالَتْ فَاطِمَةُ لَوْ دَعَوْنَا النَّبِيَّ ـ صلى الله عليه وسلم ـ فَأَكَلَ مَعَنَا ‏.‏ فَدَعَوْهُ فَجَاءَ فَوَضَعَ يَدَهُ عَلَى عِضَادَتَىِ الْبَابِ فَرَأَى قِرَامًا فِي نَاحِيَةِ الْبَيْتِ فَرَجَعَ فَقَالَتْ فَاطِمَةُ لِعَلِيٍّ الْحَقْ فَقُلْ لَهُ مَا رَجَعَكَ يَا رَسُولَ اللَّهِ قَالَ ‏ ‏ إِنَّهُ لَيْسَ لِي أَنْ أَدْخُلَ بَيْتًا مُزَوَّقًا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحج ۱۰۶ (۱۷۰۱)، صحیح مسلم/الحج ۶۴ (۱۳۲۱)، سنن النسائی/الحج ۶۹ (۲۷۸۹)، سنن ابی داود/المناسک ۱۵ (۱۷۵۵)،(تحفة الأشراف:۱۵۹۴۴)، وقدأخرجہ: مسند احمد (۶/۴۱،۴۲،۲۰۸)،(یہ حدیث مکرر ہے، دیکھئے:۳۰۹۴),,"Safinah,\nAbu ‘Abdur-Rahman, narrated that a man visited ‘Ali bin Abu\nTalib\nand he made some food for him.* Fatimah said:",Chapters on Food
3097,حَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا يَحْيَى بْنُ عَبْدِ الرَّحْمَنِ الأَرْحَبِيُّ، حَدَّثَنَا يُونُسُ بْنُ أَبِي الْيَعْفُورِ، عَنْ أَبِيهِ، عَنِ ابْنِ عُمَرَ، قَالَ دَخَلَ عَلَيْهِ عُمَرُ وَهُوَ عَلَى مَائِدَتِهِ فَأَوْسَعَ لَهُ عَنْ صَدْرِ الْمَجْلِسِ فَقَالَ بِسْمِ اللَّهِ ‏.‏ ثُمَّ ضَرَبَ بِيَدِهِ فَلَقِمَ لُقْمَةً ثُمَّ ثَنَّى بِأُخْرَى ثُمَّ قَالَ إِنِّي لأَجِدُ طَعْمَ دَسَمٍ مَا هُوَ بِدَسَمِ اللَّحْمِ ‏.‏ فَقَالَ عَبْدُ اللَّهِ يَا أَمِيرَ الْمُؤْمِنِينَ إِنِّي خَرَجْتُ إِلَى السُّوقِ أَطْلُبُ السَّمِينَ لأَشْتَرِيَهُ فَوَجَدْتُهُ غَالِيًا فَاشْتَرَيْتُ بِدِرْهَمٍ مِنَ الْمَهْزُولِ وَحَمَلْتُ عَلَيْهِ بِدِرْهَمٍ سَمْنًا فَأَرَدْتُ أَنْ يَتَرَدَّدَ عِيَالِي عَظْمًا عَظْمًا ‏.‏ فَقَالَ عُمَرُ مَا اجْتَمَعَا عِنْدَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ قَطُّ إِلاَّ أَكَلَ أَحَدَهُمَا وَتَصَدَّقَ بِالآخَرِ ‏.‏ قَالَ عَبْدُ اللَّهِ خُذْ يَا أَمِيرَ الْمُؤْمِنِينَ فَلَنْ يَجْتَمِعَا عِنْدِي إِلاَّ فَعَلْتُ ذَلِكَ ‏.‏ قَالَ مَا كُنْتُ لأَفْعَلَ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۳۲ (۱۲۴۳)، سنن ابی داود/الحج ۱۵ (۱۷۵۲)، سنن الترمذی/الحج ۶۷ (۹۰۶)، سنن النسائی/الحج ۶۴ (۲۷۷۲)،۶۷ (۲۷۸۱)،۷۰ (۲۷۹۳)،(تحفة الأشراف:۶۴۵۹)، وقد أخرجہ: صحیح البخاری/الحج ۲۳ (۱۵۴۹)، مسند احمد (۱/۲۱۶،۲۵۴،۲۸۰،۳۳۹،۳۴۴،۳۴۷،۳۷۲)، سنن الدارمی/المناسک ۶۸ (۱۹۵۳),3097,"It was\nnarrated that Ibn ‘Umar said that ‘Umar entered upon him when he\nwas eating, and he made room for him in the middle of the gathering.\nHe said:",Chapters on Food
3098,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا عُثْمَانُ بْنُ عُمَرَ، حَدَّثَنَا أَبُو عَامِرٍ الْخَزَّازُ، عَنْ أَبِي عِمْرَانَ الْجَوْنِيِّ، عَنْ عَبْدِ اللَّهِ بْنِ الصَّامِتِ، عَنْ أَبِي ذَرٍّ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ إِذَا عَمِلْتَ مَرَقَةً فَأَكْثِرْ مَاءَهَا وَاغْتَرِفْ لِجِيرَانِكَ مِنْهَا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/ الحج ۱۰۶ (۱۶۹۶)،۱۰۸ (۱۶۹۹)، صحیح مسلم/الحج ۶۴ (۱۳۲۱)، سنن ابی داود/المناسک ۱۷ (۱۷۵۷)، سنن النسائی/الحج ۶۲ (۲۷۷۴)،(تحفة الأشراف:۱۷۴۳۳)، وقد أخرجہ: موطا امام مالک/الحج ۱۵ (۵۱)، مسند احمد (۶/۲۵،۳۶،۷۸،۸۵،۱۹۱،۱۰۲،۱۲۷،۱۷۴،۱۸۰،۱۸۵،۱۹۱،۲۰۰),,It was\nnarrated from Abu Dharr that the Prophet (ﷺ) said:,Chapters on Food
3099,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا إِسْمَاعِيلُ ابْنُ عُلَيَّةَ، عَنْ سَعِيدِ بْنِ أَبِي عَرُوبَةَ، عَنْ قَتَادَةَ، عَنْ سَالِمِ بْنِ أَبِي الْجَعْدِ الْغَطَفَانِيِّ، عَنْ مَعْدَانَ بْنِ أَبِي طَلْحَةَ الْيَعْمُرِيِّ، أَنَّ عُمَرَ بْنَ الْخَطَّابِ، قَامَ يَوْمَ الْجُمُعَةِ خَطِيبًا فَحَمِدَ اللَّهَ وَأَثْنَى عَلَيْهِ ثُمَّ قَالَ يَا أَيُّهَا النَّاسُ إِنَّكُمْ تَأْكُلُونَ شَجَرَتَيْنِ لاَ أُرَاهُمَا إِلاَّ خَبِيثَتَيْنِ هَذَا الثُّومُ وَهَذَا الْبَصَلُ وَلَقَدْ كُنْتُ أَرَى الرَّجُلَ عَلَى عَهْدِ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ يُوجَدُ رِيحُهُ مِنْهُ فَيُؤْخَذُ بِيَدِهِ حَتَّى يُخْرَجَ بِهِ إِلَى الْبَقِيعِ فَمَنْ كَانَ آكِلَهُمَا لاَ بُدَّ فَلْيُمِتْهُمَا طَبْخًا ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحج ۱۱۳ (۱۷۰۷)،۱۲۰ (۱۷۱۶)،۱۲۱ (۱۷۱۷)، صحیح مسلم/الحج ۶۱ (۱۳۱۷)، سنن ابی داود/الحج ۲۰ (۱۷۶۹)،(تحفة الأشراف:۱۰۲۱۹)، وقد أخرجہ: مسند احمد (۱/۲۹،۱۲۳،۱۳۲،۱۴۳،۱۵۴،۱۵۹)، سنن الدارمی/المناسک ۸۹ (۱۹۸۳),3099,"It was\nnarrated from Ma’dan bin Abu Talhah Al-Ya’muri that ‘Umar bin\nKhattab stood up one Friday delivering a sermon. He praised and\nglorified Allah, then he said:",Chapters on Food
3100,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عُبَيْدِ اللَّهِ بْنِ أَبِي يَزِيدَ، عَنْ أَبِيهِ، عَنْ أُمِّ أَيُّوبَ، قَالَتْ صَنَعْتُ لِلنَّبِيِّ ـ صلى الله عليه وسلم ـ طَعَامًا فِيهِ مِنْ بَعْضِ الْبُقُولِ فَلَمْ يَأْكُلْ وَقَالَ ‏ ‏ إِنِّي أَكْرَهُ أَنْ أُوذِيَ صَاحِبِي ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۴۸۱)، وقد أخرجہ: مسند احمد (۱/۲۳۴،۲۶۹),,It was\nnarrated that Umm Ayyub said:,Chapters on Food
3101,"حَدَّثَنَا حَرْمَلَةُ بْنُ يَحْيَى، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، أَنْبَأَنَا أَبُو شُرَيْحٍ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ نِمْرَانَ الْحَجْرِيِّ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، أَنَّ نَفَرًا، أَتَوُا النَّبِيَّ ـ صلى الله عليه وسلم ـ فَوَجَدَ مِنْهُمْ رِيحَ الْكُرَّاثِ فَقَالَ ‏ ‏ أَلَمْ أَكُنْ نَهَيْتُكُمْ عَنْ أَكْلِ هَذِهِ الشَّجَرَةِ إِنَّ الْمَلاَئِكَةَ تَتَأَذَّى مِمَّا يَتَأَذَّى مِنْهُ الإِنْسَانُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih Lighairihi; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۵۳۰، ومصباح الزجاجة:۱۰۷۴),,It was\nnarrated from Jabir that a group of people came to the Prophet\n(ﷺ)\nand he noticed the smell of leeks coming from them. He said:,Chapters on Food
3102,"حَدَّثَنَا حَرْمَلَةُ بْنُ يَحْيَى، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، أَخْبَرَنِي ابْنُ لَهِيعَةَ، عَنْ عُثْمَانَ بْنِ نُعَيْمٍ، عَنِ الْمُغِيرَةِ بْنِ نَهِيكٍ، عَنْ دُخَيْنٍ الْحَجْرِيِّ، أَنَّهُ سَمِعَ عُقْبَةَ بْنَ عَامِرٍ الْجُهَنِيَّ، يَقُولُ إِنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ لأَصْحَابِهِ ‏""‏ لاَ تَأْكُلُوا الْبَصَلَ ‏""‏ ‏.‏ ثُمَّ قَالَ كَلِمَةً خَفِيَّةً ‏""‏ النِّيءَ ‏""‏ ‏.‏",Al-Albani: Daif Isnaad; Muhammad Fouad Abd al-Baqi: Daif Isnaad; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/الحج ۶۸ (۹۰۷)،(تحفة الأشراف:۷۸۹۷),3102,‘Uqbah\nbin ‘Amir Al-Juhani said:,Chapters on Food
3103,"حَدَّثَنَا إِسْمَاعِيلُ بْنُ مُوسَى السُّدِّيُّ، حَدَّثَنَا سَيْفُ بْنُ هَارُونَ، عَنْ سُلَيْمَانَ التَّيْمِيِّ، عَنْ أَبِي عُثْمَانَ النَّهْدِيِّ، عَنْ سَلْمَانَ الْفَارِسِيِّ، قَالَ سُئِلَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنِ السَّمْنِ وَالْجُبْنِ وَالْفِرَاءِ قَالَ ‏ ‏ الْحَلاَلُ مَا أَحَلَّ اللَّهُ فِي كِتَابِهِ وَالْحَرَامُ مَا حَرَّمَ اللَّهُ فِي كِتَابِهِ وَمَا سَكَتَ عَنْهُ فَهُوَ مِمَّا عَفَا عَنْهُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۳۶۶۹)، وقد أخرجہ: صحیح البخاری/الحج ۱۰۳ (۱۶۸۹)،۱۱۲ (۱۷۰۶)، الوصایا ۱۲ (۲۷۵۵)، الأدب ۹۵ (۶۱۶۰)، صحیح مسلم/الحج ۶۵ (۱۳۲۲)، سنن ابی داود/الحج ۱۸ (۱۷۶۰)، سنن النسائی/الحج ۷۴ (۲۸۰۱)، موطا امام مالک/الحج ۴۵ (۱۳۹)، مسند احمد (۲/۲۵۴،۲۷۸،۳۱۲،۴۶۴،۴۷۴،۴۷۸،۴۸۱),,It was\nnarrated that Salman Al-Farisi said:,Chapters on Food
3104,"حَدَّثَنَا عَمْرُو بْنُ عُثْمَانَ بْنِ سَعِيدِ بْنِ كَثِيرِ بْنِ دِينَارٍ الْحِمْصِيُّ، حَدَّثَنَا أَبِي، حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الرَّحْمَنِ بْنِ عِرْقٍ، عَنْ أَبِيهِ، عَنِ النُّعْمَانِ بْنِ بَشِيرٍ، قَالَ أُهْدِيَ لِلنَّبِيِّ ـ صلى الله عليه وسلم ـ عِنَبٌ مِنَ الطَّائِفِ فَدَعَانِي فَقَالَ ‏""‏ خُذْ هَذَا الْعُنْقُودَ فَأَبْلِغْهُ أُمَّكَ ‏""‏ ‏.‏ فَأَكَلْتُهُ قَبْلَ أَنْ أُبْلِغَهُ إِيَّاهَا فَلَمَّا كَانَ بَعْدَ لَيَالٍ قَالَ لِي ‏""‏ مَا فَعَلَ الْعُنْقُودُ هَلْ أَبْلَغْتَهُ أُمَّكَ ‏""‏ ‏.‏ قُلْتُ لاَ ‏.‏ قَالَ فَسَمَّانِي غُدَرَ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الحج ۱۰۳ (۱۶۹۰)، الوصایا ۱۲ (۲۷۵۵)، الأدب ۹۵ (۶۱۶۰)،(تحفة الأشراف:۱۳۶۶)، وقد أخرجہ: صحیح مسلم/الحج ۶۵ (۱۳۲۲)، سنن ابی داود/الحج ۱۸ (۱۷۶۰)، سنن النسائی/الحج ۷۴ (۲۸۰۱)، مسند احمد (۳/۹۹،۱۷۰،۱۷۳،۲۲۰)، سنن الدارمی/المناسک ۶۹ (۱۹۵۴),3104,It was\nnarrated that Nu’man bin Bashir said:,Chapters on Food
3105,"حَدَّثَنَا إِسْمَاعِيلُ بْنُ مُحَمَّدٍ الطَّلْحِيُّ، حَدَّثَنَا نُقَيْبُ بْنُ حَاجِبٍ، عَنْ أَبِي سَعِيدٍ، عَنْ عَبْدِ الْمَلِكِ الزُّبَيْرِيِّ، عَنْ طَلْحَةَ، قَالَ دَخَلْتُ عَلَى النَّبِيِّ ـ صلى الله عليه وسلم ـ وَبِيَدِهِ سَفَرْجَلَةٌ فَقَالَ ‏ ‏ دُونَكَهَا يَا طَلْحَةُ فَإِنَّهَا تُجِمُّ الْفُؤَادَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۶۶ (۱۳۲۶)،(تحفة الأشراف:۳۵۴۴)، وقد أخرجہ: مسند احمد (۴/۲۲۵),,It was\nnarrated that Talhah said:,Chapters on Food
3106,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا كَثِيرُ بْنُ هِشَامٍ، حَدَّثَنَا جَعْفَرُ بْنُ بُرْقَانَ، عَنِ الزُّهْرِيِّ، عَنْ سَالِمٍ، عَنْ أَبِيهِ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ أَنْ يَأْكُلَ الرَّجُلُ وَهُوَ مُنْبَطِحٌ عَلَى وَجْهِهِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن ابی داود/الحج ۱۹ (۱۷۶۲)، سنن الترمذی/الحج ۷۱ (۹۱۰)،(تحفة الأشراف:۱۱۵۸۱)، وقد أخرجہ: موطا امام مالک/الحج ۴۷ (۱۴۸)، مسند احمد (۴/۳۳۳)، سنن الدارمی/المناسک ۶۶ (۱۹۵۰),3106,It was\nnarrated from Salim that his father said:,Chapters on Food
3251,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا أَبُو أُسَامَةَ، ‏‏‏‏‏‏عَنْ عَوْفٍ، ‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «أنظرحدیث رقم:۱۳۳۴،(تحفة الأشراف:۵۳۳۱),3251,,Chapters on Food
3252,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى الْأَزْدِيُّ، ‏‏‏‏‏‏حَدَّثَنَا حَجَّاجُ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏عَنْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۶۷۰، ومصباح الزجاجة:۱۱۱۷)، وقد أخرجہ: مسند احمد (۲/۱۵۶),3252,,Chapters on Food
3253,حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، ‏‏‏‏‏‏أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، ‏‏‏‏‏‏عَنْ يَزِيدَ بْنِ أ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الإیمان ۶ (۱۲)،۲۰ (۲۸)، الاستئذان ۹ (۶۲۳۶)، صحیح مسلم/الإیمان ۱۴ (۳۹)، سنن ابی داود/الأدب ۱۴۲ (۵۱۹۴)، سنن النسائی/الإیمان ۱۲ (۵۰۰۳)،(تحفة الأشراف:۸۹۲۷)، وقد أخرجہ: مسند احمد (۲/۱۵۶),3253,,Chapters on Food
3254,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ الرَّقِّيُّ، ‏‏‏‏‏‏حَدَّثَنَا يَحْيَى بْنُ زِيَادٍ الْأَسَد,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الأشربة ۳۳ (۲۰۵۹)،(تحفة الأشراف:۲۸۲۸)، وقد أخرجہ: سنن الترمذی/الأطعمة ۲۱ (۱۸۲۰)، مسند احمد (۲/۴۰۷،۳/۳۰۱،۳۰۵،۳۸۲)، سنن الدارمی/الأطعمة ۱۴،۲۰۸۷),3254,,Chapters on Food
3255,حَدَّثَنَا الْحَسَنُ بْنُ عَلِيٍّ الْخَلَّالُ، ‏‏‏‏‏‏حَدَّثَنَا الْحَسَنُ بْنُ مُوسَى، ‏‏‏‏‏‏حَدَّثَ,Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۵۳۵، ومصباح الزجاجة:۱۱۱۸),3255,,Chapters on Food
3256,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَفَّانُ . ح وحَدَّثَنَا مُحَمَّدُ بْنُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الأطعمة ۱۲ (۵۳۷۶،۵۳۹۷)،(تحفة الأشراف:۱۳۴۱۲)، وقد أخرجہ: صحیح مسلم/الأشربة ۳۴ (۲۰۶۲،۲۰۶۳)، سنن الترمذی/الأطعمة ۲۰ (۱۸۱۸،۱۸۱۹)، موطا امام مالک/صفة النبی صلی اللہ علیہ وسلم ۶ (۹)، مسند احمد (۲/۲۱،۴۳،۷۴،۱۴۵،۲۵۷،۴۱۵،۴۳۵،۴۳۷،۴۵۵،۳/۳۳۳،۳۴۶،۳۵۷،۳۹۲،۴/۳۳۶،۵/۳۷۰،۶/۳۳۵،۳۹۷)، سنن الدارمی/الأطعمة ۱۳ (۲۰۸۶),3256,,Chapters on Food
3257,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، ‏‏‏‏‏‏عَنْ عُبَيْد,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الأشربة ۳۴ (۲۰۶۰)،(تحفة الأشراف:۷۹۵۰)، وقد أخرجہ: صحیح البخاری/الأطعمة ۱۲ (۵۳۹۴،۵۳۹۵)، سنن الترمذی/الأطعمة ۲۰ (۱۸۱۸)، مسند احمد (۲/۲۱)، سنن الدارمی/الأطعمة ۱۳ (۲۰۸۴),3257,,Chapters on Food
3258,حَدَّثَنَا أَبُو كُرَيْبٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو أُسَامَةَ، ‏‏‏‏‏‏عَنْ بُرَيْدِ بْنِ عَبْدِ اللَّهِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الأشربة ۳۴ (۲۰۶۱)،(تحقة الأشراف:۹۰۵۰)، وقد أخرجہ: سنن الترمذی/الأطعمة ۲۰ (۱۸۱۸),3258,,Chapters on Food
3259,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الرَّحْمَنِ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/المناقب ۲۳ (۳۵۶۴)، الأطعمة ۲۱ (۵۴۰۹)، صحیح مسلم/الأشربة ۳۵ (۲۰۶۴)، سنن ابی داود/الأطعمة ۱۴ (۳۷۶۳)، سنن الترمذی/البروالصلة ۸۴ (۲۰۳۱)،(تحفة الأشراف:۱۳۴۰۳)، وقد أخرجہ: مسند احمد (۲/۴۷۴،۴۷۹،۴۸۱),3259,,Chapters on Food
3260,حَدَّثَنَا جُبَارَةُ بْنُ الْمُغَلِّسِ، ‏‏‏‏‏‏حَدَّثَنَا كَثِيرُ بْنُ سُلَيْمٍ، ‏‏‏‏‏‏سَمِعْتُ أَنَس,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۴۴۵، ومصباح الزجاجة:۱۱۱۹),3260,,Chapters on Food
3261,حَدَّثَنَا جَعْفَرُ بْنُ مُسَافِرٍ، ‏‏‏‏‏‏حَدَّثَنَا صَاعِدُ بْنُ عُبَيْدٍ الْجَزَرِيُّ، ‏‏‏‏‏‏حَدَّ,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۴۲۲۹، ومصباح الزجاجة:۱۱۲۰),3261,,Chapters on Food
3262,حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏عَنْ مِسْعَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الأطعمة ۱۳ (۵۳۹۸،۵۳۹۹)، سنن ابی داود/الأطعمة ۱۷ (۳۷۶۹)، سنن الترمذی/الاطعمة ۲۸ (۱۸۳۰)،(تحفة الأشراف:۱۱۸۰۱)، وقد أخرجہ: مسند احمد (۴/۳۰۸،۳۰۹)، سنن الدارمی/الأطعمة ۳۱ (۲۱۱۵),3262,,Chapters on Food
3263,حَدَّثَنَا عَمْرُو بْنُ عُثْمَانَ بْنِ سَعِيدِ بْنِ كَثِيرِ بْنِ دِينَارٍ الْحِمْصِيُّ، ‏‏‏‏‏‏حَدَّث,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۲۰۲، ومصباح الزجاجة:۱۱۲۱)، وقد أخرج بعضہ: سنن ابی داود/الأطعمة ۱۸ (۳۷۷۳),3263,,Chapters on Food
3264,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، ‏‏‏‏‏‏عَنْ هِشَام,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۶۲۶۷، ومصباح الزجاجة:۱۱۲۲)، وقد أخر جہ: سنن ابی داود/الأطعمة ۱۶ (۳۷۶۷)، سنن الترمذی/الأطعمة ۴۷ (۱۸۵۸)، مسند احمد (۶/۱۴۳،۲۰۷،۲۴۶،۲۶۵)، سنن الدارمی/الأطعمة ۱ (۲۰۶۳),3264,,Chapters on Food
3265,حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ، ‏‏‏‏‏‏عَنْ هِشَامِ بْنِ عُرْوَةَ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Hasan,takhreej: «سنن الترمذی/الأطعمة ۴۷ (۱۸۵۷)،(تحفة الأشراف:۱۰۶۸۵)، وقد أخرجہ: صحیح البخاری/الأطعمة ۲ (۵۳۷۶)، صحیح مسلم/الأشربة ۱۳ (۲۰۲۲)، سنن ابی داود/الأطعمة ۲۰ (۳۷۷۷)، موطا امام مالک/صفة النبیﷺ ۱۰ (۳۲)، مسند احمد (۴/۲۷)، سنن الدارمی/الأطعمة ۱ (۲۰۶۲),3265,,Chapters on Food
3266,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا الْهِقْلُ بْنُ زِيَادٍ، ‏‏‏‏‏‏حَدَّثَنَا هِشَامُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۵۴۲۰، ومصباح الزجاجة:۱۱۲۳)، وقد أخرجہ: مسند احمد (۲/۳۴۹),3266,,Chapters on Food
3267,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَمُحَمَّدُ بْنُ الصَّبَّاحِ، ‏‏‏‏‏‏قَالَا:‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الأطعمة ۲ (۵۳۷۶)، صحیح مسلم/الإشربة ۱۳ (۲۰۲۲)، سنن النسائی/الیوم و اللیلة (۲۷۸،۲۷۹،۲۸۰)،(تحفة الأشراف:۱۰۶۸۸)، وقد أخرجہ: موطا امام مالک/صفة النبیﷺ ۱۰ (۳۲)، مسند احمد (۴/ ۲۶)، سنن الدارمی/الأطمة ۱ (۲۰۶۲),3267,,Chapters on Food
3268,حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، ‏‏‏‏‏‏أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، ‏‏‏‏‏‏عَنْ أَبِي الزُّبَي,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الأشربة ۱۳ (۲۰۱۹)، اللباس ۲۰ (۲۰۹۹)،(تحفة الأشراف:۲۹۱۷)، وقد أخرجہ: سنن ابی داود/اللباس ۴۴ (۴۱۳۷)، موطا امام مالک/صفة النبیﷺ ۴ (۵)، مسند احمد (۳/۳۳۴،۳۴۹),3268,,Chapters on Food
3269,حَدَّثَنَا مُحَمَّدُ بْنُ أَبِي عُمَرَ الْعَدَنِيُّ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «حدیث جابر تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۴۶۷)، وحدیث ابن عباس أخرجہ: صحیح البخاری/الأطعمة ۵۲ (۵۴۵۶)، صحیح مسلم/الأشربة ۱۸ (۲۰۳۱)،(تحفة الأشراف:۵۹۴۲)، وقد أخرجہ: سنن ابی داود/الأطعمة ۵۲ (۳۸۴۷)، مسند احمد (۱/۲۹۳،۳۴۶،۳۷۰)، سنن الدارمی/الأطعمة ۶ (۲۰۶۹),3269,,Chapters on Food
3270,حَدَّثَنَا مُوسَى بْنُ عَبْدِ الرَّحْمَنِ، ‏‏‏‏‏‏أَنْبَأَنَا أَبُو دَاوُدَ الْحَفَرِيُّ، ‏‏‏‏‏‏عَنْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الأشربة ۱۸ (۲۰۳۳)،(تحفة الأشراف:۲۷۴۵)، وقد أخرجہ: مسند احمد (۳/۳۰۱،۳۳۱،۳۳۷،۳۶۵،۳۹۳),3270,,Chapters on Food
3271,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، ‏‏‏‏‏‏أَنْبَأَنَا,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: سنن الترمذی/الأطعمة ۱۱ (۱۸۰۴)،(تحفة الأشراف:۱۱۵۸۸)، وقد أخرجہ: مسند احمد (۵/۷۶)، سنن الدارمی/الأطمة ۷ (۲۰۷۰),3271,,Chapters on Food
3272,حَدَّثَنَا أَبُو بِشْرٍ بَكْرُ بْنُ خَلَفٍ، ‏‏‏‏‏‏ وَنَصْرُ بْنُ عَلِيٍّ،‏‏‏‏ قَالَا:‏‏‏‏ حَدَّثَنَا,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «أنظر ما قبلہ,3272,,Chapters on Food
3273,حَدَّثَنَا مُحَمَّدُ بْنُ خَلَفٍ الْعَسْقَلَانِيُّ، ‏‏‏‏‏‏حَدَّثَنَا عُبَيْدُ اللَّهِ، ‏‏‏‏‏‏حَدَّثَ,Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۳۲۷، ومصباح الزجاجة:۱۱۲۴),3273,,Chapters on Food
3274,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا الْعَلَاءُ بْنُ الْفَضْلِ بْنِ عَبْدِ الْمَلِكِ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/الأطعمة ۴۱ (۱۸۴۸)،(تحفة الأشراف:۱۰۰۱۶),3274,,Chapters on Food
3275,حَدَّثَنَا عَمْرُو بْنُ عُثْمَانَ بْنِ سَعِيدِ بْنِ كَثِيرِ بْنِ دِينَارٍ الْحِمْصِيُّ، ‏‏‏‏‏‏حَدَّث,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الأطعمة ۱۸ (۳۷۷۳)،(تحفة الأشراف:۵۱۹۹),3275,,Chapters on Food
3276,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو حَفْصٍ عُمَرُ بْنُ الدَّرَفْسِ، ‏‏‏‏‏‏حَدَّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۷۴۳، ومصباح الزجاجة:۱۱۲۵)، وقد أخرجہ: مسند احمد (۳/۴۹۰),3276,,Chapters on Food
3277,حَدَّثَنَا عَلِيُّ بْنُ الْمُنْذِرِ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ فُضَيْلٍ، ‏‏‏‏‏‏حَدَّثَنَا عَطَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الأطعمة ۱۸ (۳۷۷۲)، سنن الترمذی/الأطعمة ۱۲ (۱۸۰۵)،(تحفة الأشراف:۵۵۶۶)، وقد أخرجہ: مسند احمد (۱/۲۷۰،۳۰۰،۳۴۳،۳۴۳،۳۴۵،۳۶۴)، سنن الدارمی/الأطعمة ۱۶ (۲۰۹۰),3277,,Chapters on Food
3278,حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، ‏‏‏‏‏‏حَدَّثَنَا يَزِيدُ بْنُ زُرَيْعٍ، ‏‏‏‏‏‏عَنْ يُونُسَ، ‏‏‏‏‏‏,Al-Albani: Daif Isnaad; Muhammad Fouad Abd al-Baqi: Daif Isnaad; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۴۶۹، ومصباح الزجاجة:۱۱۲۶)، وقد أخرجہ: سنن الدارمی/الأطعمة ۸ (۲۰۷۲),3278,,Chapters on Food
3279,حَدَّثَنَا عَلِيُّ بْنُ الْمُنْذِرِ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ فُضَيْلٍ، ‏‏‏‏‏‏حَدَّثَنَا الْأ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الأشربة ۱۸ (۲۰۳۳)، سنن الترمذی/الأطعمة ۱۱ (۱۸۰۲)،(تحفة الأشراف:۲۳۰۵)، وقد أخرجہ: مسند احمد (۳/۳۱۵),3279,,Chapters on Food
3280,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، ‏‏‏‏‏‏حَدَّثَنَا شُعْب,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الأنبیاء ۳۲ (۳۴۱۱)،۴۶ (۳۴۳۳)، فضائل الصحابة ۳۰ (۴۷۶۹)، الأطعمة ۲۵ (۵۴۱۸)، صحیح مسلم/فضائل الصحابة ۱۲ (۲۴۳۱)، سنن الترمذی/الأطعمة ۳۱ (۱۸۳۴)، سنن النسائی/عشرة النساء ۳ (۳۳۹۹)،(تحفة الأشراف:۹۰۲۹)، وقد أخرجہ: مسند احمد (۴/۳۹۴،۴۰۹),3280,,Chapters on Food
3281,حَدَّثَنَا حَرْمَلَةُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، ‏‏‏‏‏‏أَنْبَأَنَا م,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/فضائل الصحابة ۳۰ (۳۷۷۰)، صحیح مسلم/فضائل الصحابة ۱۳ (۲۴۴۶)، سنن الترمذی/المناقب ۶۲ (۳۸۸۷)،(تحفة الأشراف:۹۷۰)، وقد أخرجہ: مسند احمد (۳/۱۵۶،۲۶۴)، سنن الدارمی/الأطعمة ۲۹ (۲۱۱۳),3281,,Chapters on Food
3282,حَدَّثَنَا مُحَمَّدُ بْنُ سَلَمَةَ الْمِصْرِيُّ أَبُو الْحَارِثِ الْمُرَادِيُّ، ‏‏‏‏‏‏حَدَّثَنَا عَب,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الأطعمة ۵۳ (۵۴۵۷)،(تحفة الأشراف:۲۲۵۱)، وقد أخرجہ: سنن ابی داود/الطہارة ۷۵ (۱۹۱)، سنن الترمذی/الطہارة ۵۹ (۸۰),3282,,Chapters on Food
3283,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا أَبُو خَالِدٍ الْأَحْمَرُ، ‏‏‏‏‏‏عَنْ حَ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/الدعوات ۵۷ (۳۴۵۷)،(تحفة الأشراف:۴۴۴۲)، وقد أخرجہ: سنن ابی داود/الأطعمة ۵۳ (۳۸۵۰)، مسند احمد (۳/۳۲،۹۸),3283,,Chapters on Food
3284,حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ، ‏‏‏‏‏‏حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، ‏‏‏‏‏‏حَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الأطعمة ۵۴ (۵۴۵۸)، سنن ابی داود/الأطعمة ۵۳ (۳۸۴۹)، سنن الترمذی/الدعوات ۵۷ (۳۴۵۶)،(تحفة الأشراف:۴۸۵۶)، وقد أخرجہ: مسند احمد (۵/۲۵۲،۲۵۶،۲۶۱،۲۶۷)، سنن الدارمی/الأطعمة ۳ (۲۰۶۶),3284,,Chapters on Food
3285,حَدَّثَنَا حَرْمَلَةُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، ‏‏‏‏‏‏أَخْبَرَنِي س,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/اللباس ۱ (۴۰۲۳)، سنن الترمذی/الدعوات ۵۶ (۳۴۵۸)،(تحفة الأشراف:۱۱۲۹۷)، وقد أخرجہ: مسند احمد (۳/۴۳۹),3285,,Chapters on Food
3286,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏ وَدَاوُدُ بْنُ رُشَيْدٍ،‏‏‏‏ وَمُحَمَّدُ بْنُ الصَّبَّاحِ،‏,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الأطعمة ۱۵ (۳۷۶۴)،(تحفة الأشراف:۱۱۷۹)، وقد أخرجہ: مسند احمد (۳/۵۰۱),3286,,Chapters on Food
3287,حَدَّثَنَا الْحَسَنُ بْنُ عَلِيٍّ الْخَلَّالُ، ‏‏‏‏‏‏حَدَّثَنَا الْحَسَنُ بْنُ مُوسَى، ‏‏‏‏‏‏حَدَّثَ,Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۵۳۵، ومصباح الزجاجة:۱۱۲۷),3287,,Chapters on Food
3288,حَدَّثَنَا أَبُو كُرَيْبٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ عَبْدِ الرَّحْمَنِ الْمُحَارِبِيّ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الأشربة ۲۰ (۳۷۲۸)، سنن الترمذی/الأشربة ۱۵ (۱۸۸۸)،(تحفة الأشراف:۶۱۴۹)، وقد أخرجہ: حم۱/۲۲۰،۳۰۹ھ ۳۵۷)، سنن الدارمی/الأشربة ۲۷ (۲۱۸۰),3288,,Chapters on Food
3289,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبِي، ‏‏‏‏‏‏حَدَّثَنَا إِس,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۹۳۵)، وقد أخرجہ: صحیح البخاری/الأطعمة ۵۵ (۵۴۶۰)، صحیح مسلم/الإیمان ۱۰ (۱۶۶۳)، سنن الترمذی/الأطعمة ۴۴ (۱۸۵۳)، سنن ابی داود/الأطعمة ۵۱ (۳۸۴۶)، مسند احمد (۲/۳۱۶)، سنن الدارمی/الأطعمة ۳۳ (۲۱۱۷),3289,,Chapters on Food
3290,حَدَّثَنَا عِيسَى بْنُ حَمَّادٍ الْمِصْرِيُّ، ‏‏‏‏‏‏أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، ‏‏‏‏‏‏عَنْ جَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۳۶۴۲)، وقد أخرجہ: صحیح البخاری/العتق ۱۸ (۲۵۵۷)، صحیح مسلم/الأیمان ۱۰ (۱۶۶۳)، سنن الترمذی/الأطعمة ۴۴ (۱۸۵۳)، وقد أخرجہ: مسند احمد (۲/۲۴۵),3290,,Chapters on Food
3291,حَدَّثَنَا عَلِيُّ بْنُ الْمُنْذِرِ، ‏‏‏‏‏‏ثَنَا مُحَمَّدُ بْنُ فُضَيْلٍ، ‏‏‏‏‏‏ثَنَا إِبْرَاهِيمُ ا,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۴۹۴، ومصباح الزجاجة:۱۱۲۸)، وقد أخرجہ: مسند احمد (۱/۳۸۸،۴۴۶),3291,,Chapters on Food
3292,حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، ‏‏‏‏‏‏حَدَّثَنَا مُعَاذُ بْنُ هِشَامٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبِي,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الأطعمة ۸ (۵۳۸۶)،۲۳ (۵۴۱۵)، سنن الترمذی/الأطعمة ۱ (۱۷۸۸)،(تحفة الأشراف:۱۴۴۴)، وقد أخرجہ: مسند احمد (۳/۱۳۰),3292,,Chapters on Food
3293,حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ يُوسُفَ الْجُبَيْرِيُّ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو بَحْرٍ، ‏‏‏‏‏‏حَدَّث,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الأطعمة ۸ (۵۳۸۵)، الرقاق ۱۶ (۶۴۵۰)، سنن الترمذی/الأطعمة ۱ (۱۸۸۸)، الزہد ۳۸ (۲۳۶۳)،(تحفة الأشراف:۱۱۷۴)، وقد أخرجہ: مسند احمد (۳/۱۳۰),3293,,Chapters on Food
3294,حَدَّثَنَا عَبْدُ اللَّهِ بْنُ أَحْمَدَ بْنِ بَشِيرِ بْنِ ذَكْوَانَ الدِّمَشْقِيُّ، ‏‏‏‏‏‏حَدَّثَنَا,Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۷۶۶۸، ومصباح الزجاجة:۱۱۲۹),3294,,Chapters on Food
