{"hadithnumber": "2892", "arabic": "حَدَّثَنَا إِبْرَاهِيمُ بْنُ الْمُنْذِرِ الْحِزَامِيُّ، ‏‏‏‏‏‏حَدَّثَنَا صَالِحُ بْنُ عَبْدِ اللَّهِ", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 25, Hadith 11", "international_number": "2892", "narrator_chain": ""}
{"hadithnumber": "2893", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ طَرِيفٍ، ‏‏‏‏‏‏حَدَّثَنَا عِمْرَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏عَنْ عَطَاءِ بْ", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sanad Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 25, Hadith 12", "international_number": "2893", "narrator_chain": ""}
