{"metadata":{"name":"Sunan Ibn Majah","section":{"9":"The Chapters on Marriage"},"section_detail":{"9":{"hadithnumber_first":1845,"hadithnumber_last":2015,"arabicnumber_first":1845,"arabicnumber_last":2015}}},"hadiths":[{"hadithnumber":1896,"arabicnumber":1896,"text":"Rapporté par Muhammad ibn Hatib : Le Messager d’Allah a dit : « Ce qui distingue le licite de l’illicite, c’est (de frapper) le tambourin et d’élever la voix (en chantant) lors du mariage. »","grades":[{"name":"Al-Albani","grade":"Hasan"},{"name":"Muhammad Fouad Abd al-Baqi","grade":"Hasan"},{"name":"Shuaib Al Arnaut","grade":"Hasan"},{"name":"Zubair Ali Zai","grade":"Hasan"}],"reference":{"book":9,"hadith":52}}]}