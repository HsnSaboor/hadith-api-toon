hadiths[count]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}:
1524,حَدَّثَنَا قُتَيْبَةُ،‏‏‏‏ حَدَّثَنَا أَبُو صَفْوَانَ، عَنْ يُونُسَ بْنِ يَزِيدَ،‏‏‏‏ عَنْ ابْنِ شِه,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأیمان ۲۳ (۳۲۹۰-۳۲۹۲)، سنن ابن ماجہ/الکفارات ۱۶ (۲۱۲۵)، سنن النسائی/الأیمان ۴۱ (۳۸۶۵-۳۸۷۰) (تحفة الأشراف : ۱۷۷۷۰)، و مسند احمد (۶/۲۴۷),1524,,The Book on Vows and Oaths
1525,حَدَّثَنَا أَبُو إِسْمَاعِيل التِّرْمِذِيُّ وَاسْمُهُ مُحَمَّدُ بْنُ إِسْمَاعِيل بْنِ يُوسُفَ،‏‏‏‏ ح,Ahmad Muhammad Shakir: Sahih Lighairihi; Al-Albani: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: تخریج دارالدعوہ: انظر ما قبلہ (تحفة الأشراف : ۱۷۷۸۲),1525,,The Book on Vows and Oaths
1526,حَدَّثَنَا قُتَيْبَةُ بْنُ سَعِيدٍ،‏‏‏‏ عَنْ مَالِكِ بْنِ أَنَسٍ،‏‏‏‏ عَنْ طَلْحَةَ بْنِ عَبْدِ الْم,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأیمان والنذور ۲۸ (۶۷۰۰)، سنن ابی داود/ الأیمان ۲۲ (۳۲۸۹)، سنن النسائی/الأیمان ۲۷ (۳۸۳۹)، سنن ابن ماجہ/الکفارات ۱۶ (۳۱۲۶)، (تحفة الأشراف : ۱۷۴۵۸)، وط/النذور ۴ (۸)، و مسند احمد (۶/۳۶، ۴۱، ۲۲۴) سنن الدارمی/النذور ۳ (۲۳۸۳),1526,,The Book on Vows and Oaths
1527,حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ،‏‏‏‏ حَدَّثَنَا إِسْحَاق بْنُ يُوسُفَ الْأَزْرَقُ،‏‏‏‏ عَنْ هِشَامٍ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأدب ۴۴ (۶۰۴۷)، صحیح مسلم/الإیمان ۴۷ (۱۱۰)، سنن ابی داود/ الأیمان ۹ (۳۲۵۷)، سنن النسائی/الأیمان ۷ (۳۸۰۱)، و ۳۱ (۳۸۴۴)، (تحفة الأشراف : ۲۰۶۲)، و مسند احمد (۴/۳۳),1527,,The Book on Vows and Oaths
1528,حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ،‏‏‏‏ حَدَّثَنَا أَبُو بَكْرِ بْنُ عَيَّاشٍ، حَدَّثَنِي مُحَمَّدٌ مَ,Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: صحیح مسلم/النذور ۵ (۱۶۴۵)، سنن ابی داود/ الأیمان ۳۱ (۳۳۲۳)، سنن النسائی/الأیمان ۴۱ (۳۸۶۳)، سنن ابن ماجہ/الکفارات ۱۷ (۲۱۲۵)، (تحفة الأشراف : ۹۹۶۰)، و مسند احمد (۴/۱۴۴، ۱۴۶، ۱۴۷),1528,,The Book on Vows and Oaths
1529,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الْأَعْلَى الصَّنْعَانِيُّ،‏‏‏‏ حَدَّثَنَا الْمُعْتَمِرُ بْنُ سُلَي,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأیمان والنذور ۱ (۶۶۲۲)، والکفارات ۱۰ (۶۷۲۲)، والأحکام ۵ (۴۱۴۶)، صحیح مسلم/الأیمان ۳ (۱۶۵۲)، سنن ابی داود/ الخراج ۲ (۲ (۲۹۲۹)، سنن النسائی/آداب القضاة ۵ (۵۳۸۶)، (تحفة الأشراف : ۹۶۹۵)، و مسند احمد (۵/۶۶) وسنن الدارمی/النذور ۹ (۲۳۹۱),1529,,The Book on Vows and Oaths
1530,حَدَّثَنَا قُتَيْبَةُ،‏‏‏‏ عَنْ مَالِكِ بْنِ أَنَسٍ،‏‏‏‏ عَنْ سُهَيْلِ بْنِ أَبِي صَالِحٍ،‏‏‏‏ عَنْ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/الأیمان ۳ (۶۵۰/۱۲)، (تحفة الأشراف : ۲۷۳۸)، و مسند احمد (۲/۳۶۱),1530,,The Book on Vows and Oaths
1531,حَدَّثَنَا مَحْمُودُ بْنُ غَيْلَانَ،‏‏‏‏ حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ،‏‏‏‏ حَد,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأیمان ۱۱ (۳۲۶۱)، سنن النسائی/الأیمان ۱۸ (۳۸۰۲)، و۳۹ (۳۸۳۸)، سنن ابن ماجہ/الکفارات ۶ (۲۱۰۵)، (تحفة الأشراف : ۷۵۱۷)، و مسند احمد (۲/۶، ۱۰، ۴۸، ۱۵۳),1531,,The Book on Vows and Oaths
1532,حَدَّثَنَا يَحْيَى بْنُ مُوسَى،‏‏‏‏ حَدَّثَنَا عَبْدُ الرَّزَّاقِ،‏‏‏‏ أَخْبَرَنَا مَعْمَرٌ،‏‏‏‏ عَن,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: سنن النسائی/الأیمان ۴۳ (۳۸۸۶)، سنن ابن ماجہ/الکفارات ۶ (۲۱۰۴)، (تحفة الأشراف : ۱۳۵۲۳),1532,,The Book on Vows and Oaths
1533,حَدَّثَنَا قُتَيْبَةُ،‏‏‏‏ حَدَّثَنَا سُفْيَانُ،‏‏‏‏ عَنْ الزُّهْرِيِّ، عَنْ سَالِمٍ،‏‏‏‏ عَنْ أَبِي,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأدب ۷۴ (۶۱۰۸)، و الأیمان ۴ (۶۶۴۶، وتعلیقاً بعد حدیث ۶۶۴۷) صحیح مسلم/الأیمان ۱ (۱۶۴۶/۳)، سنن النسائی/الأیمان ۴ (۳۷۹۶)، و ۵ (۳۷۹۷)، (تحفة الأشراف : ۶۸۱۸)، وط/النذور ۹ (۱۴)، و مسند احمد (۲/۱۱، ۳۴، ۹۶),1533,,The Book on Vows and Oaths
1534,حَدَّثَنَا هَنَّادٌ،‏‏‏‏ حَدَّثَنَا عَبْدَةُ،‏‏‏‏ عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ،‏‏‏‏ عَنْ نَافِع,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: انظر ما قبلہ (تحفة الأشراف : ۸۰۵۸),1534,,The Book on Vows and Oaths
1535,حَدَّثَنَا قُتَيْبَةُ،‏‏‏‏ حَدَّثَنَا أَبُو خَالِدٍ الْأَحْمَرُ، عَنْ الْحَسَنِ بْنِ عُبَيْدِ اللَّه,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأیمان ۵ (۳۲۵۱)، (تحفة الأشراف : ۷۰۴۵)، و مسند احمد ۲/۸۷، ۱۲۵),1535,,The Book on Vows and Oaths
1536,حَدَّثَنَا عَبْدُ الْقُدُّوسِ بْنُ مُحَمَّدٍ الْعَطَّارُ الْبَصْرِيُّ،‏‏‏‏ حَدَّثَنَا عَمْرُو بْنُ ع,Ahmad Muhammad Shakir: Hasan Sahih; Al-Albani: Hasan Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۷۳۲),1536,,The Book on Vows and Oaths
1537,حَدَّثَنَا أَبُو مُوسَى مُحَمَّدُ بْنُ الْمُثَنَّى،‏‏‏‏ حَدَّثَنَا خَالِدُ بْنُ الْحَارِثِ،‏‏‏‏ حَدّ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih,takhreej: تخریج دارالدعوہ: صحیح البخاری/جزاء الصید ۲۷ (۱۸۶۵)، والأیمان ۳۱ (۶۷۰۱)، صحیح مسلم/النذور ۴ (۱۶۴۲)، سنن ابی داود/ الأیمان ۲۳ (۲۳۰۱)، سنن النسائی/الأیمان ۴۲ (۳۸۸۳)، (تحفة الأشراف : ۳۹۲)، و مسند احمد (۳/۱۰۶، ۱۱۴، ۱۸۳، ۱۳۵، ۲۷۱),1537,,The Book on Vows and Oaths
1538,حَدَّثَنَا قُتَيْبَةُ،‏‏‏‏ حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ،‏‏‏‏ عَنْ الْعَلَاءِ بْنِ عَب,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأیمان ۲۶ (۶۶۹۲)، صحیح مسلم/النذور ۲ (۱۶۴۰)، سنن ابی داود/ الأیمان ۲۱ (۳۲۸۸)، سنن النسائی/الأیمان ۲۵ (۳۸۳۵)، و ۲۶ (۳۸۳۶)، سنن ابن ماجہ/الکفارات ۱۵ (۲۱۲۳)، (تحفة الأشراف : ۱۴۰۵۰۰)، و مسند احمد (۲/۲۳۵، ۳۰۱، ۳۱۴، ۴۱۲، ۴۶۳),1538,,The Book on Vows and Oaths
1539,حَدَّثَنَا إِسْحَاق بْنُ مَنْصُورٍ،‏‏‏‏ أَخْبَرَنَا يَحْيَى بْنُ سَعِيدٍ الْقَطَّانُ،‏‏‏‏ عَنْ عُبَي,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الاعتکاف ۵ (۳۰۳۲)، و ۱۵ (۳۰۴۲)، و ۱۶ (۲۰۴۳)، والخمس ۱۹ (۳۱۴۴)، والمغازي ۵۴ (۴۳۲۰)، والأیمان ۲۹ (۶۶۹۷)، صحیح مسلم/الأیمان ۶ (۱۶۵۶)، سنن ابی داود/ الأیمان ۳۲ (۳۳۲۵)، سنن النسائی/الأیمان ۳۶ (۳۸۳۰)، سنن ابن ماجہ/الصیام ۶۰ (۱۷۷۲)، والکفارات ۱۸ (۲۱۱۹)، (تحفة الأشراف : ۱۰۵۵۰)، و مسند احمد (۱/۳۷) وأیضا (۲/۲۰، ۸۲، ۱۵۳) وسنن الدارمی/النذور ۱ (۲۳۷۸),1539,,The Book on Vows and Oaths
1540,حَدَّثَنَا عَلِيُّ بْنُ حُجْرٍ،‏‏‏‏ أَخْبَرَنَا عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ، وَعَبْدُ اللَّهِ ب,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: تخریج دارالدعوہ: صحیح البخاری/القدر ۱۴ (۶۶۱۷)، والأیمان ۳ (۶۶۲۸)، والتوحید ۱۱ (۷۳۹۱)، سنن ابی داود/ الأیمان ۱۲ (۳۲۶۳)، سنن النسائی/الأیمان ۱ (۳۷۷۰)، سنن ابن ماجہ/الکفارات ۱ (۲۰۹۲)، (تحفة الأشراف : ۷۰۲۴)، و مسند احمد (۲/۲۶، ۶۷، ۶۸، ۱۲۷),1540,,The Book on Vows and Oaths
1541,حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا اللَّيْثُ، عَنْ ابْنِ الْهَادِ، عَنْ عُمَرَ بْنِ عَلِيِّ بْنِ الْح,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/العتق ۱ (۲۵۱۷)، والکفارات ۶ (۶۷۱۵)، صحیح مسلم/العتق ۵ (۱۵۰۹)، (تحفة الأشراف : ۱۳۰۸۸,1541,,The Book on Vows and Oaths
1542,حَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا الْمُحَارِبِيُّ، عَنْ شُعْبَةَ، عَنْ حُصَيْنٍ، عَنْ هِلَالِ بْ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/الأیمان ۸ (۱۶۵۸)، سنن ابی داود/ الأدب ۱۳۳ (۵۱۶۶)، (تحفة الأشراف : ۴۸۱۱)، و مسند احمد (۳/۴۴۸)، و (۵/۴۴۴),1542,,The Book on Vows and Oaths
1543,حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا إِسْحَاق بْنُ يُوسُفَ الْأَزْرَقُ، عَنْ هِشَامٍ الدَّسْ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الجنائز ۸۳ (۱۳۶۳)، والأدب ۴۴ (۶۰۴۷)، و۷۳ (۶۱۰۵)، والأیمان ۷ (۶۶۵۲)، صحیح مسلم/الأیمان ۴۷ (۱۱۰)، سنن ابی داود/ الأیمان ۹ (۳۲۵۷)، سنن النسائی/الأیمان ۷ (۳۸۰۱)، سنن ابن ماجہ/الکفارات ۳ (۲۰۹۸)، و ۳۱ (۳۸۴۴)، (تحفة الأشراف : ۲۰۶۲)، و مسند احمد (۴/۳۳، ۳۴),1543,,The Book on Vows and Oaths
1544,حَدَّثَنَا مَحْمُودُ بْنُ غَيْلَانَ، حَدَّثَنَا وَكِيعٌ، عَنْ سُفْيَانَ، عَنْ يَحْيَى بْنِ سَعِيدٍ،,Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأیمان ۲۳ (۳۲۹۳، ۳۲۹۹۴)، سنن النسائی/الأیمان ۳۳ (۳۸۴۵)، سنن ابن ماجہ/الکفارات ۲۰ (۲۱۳۴)، (تحفة الأشراف : ۹۹۳۰)، و مسند احمد (۴/۱۴۳، ۱۴۵، ۱۴۹، ۱۵۱)، سنن الدارمی/النذور ۲ (۲۳۷۹),1544,,The Book on Vows and Oaths
1545,حَدَّثَنَا إِسْحَاق بْنُ مَنْصُورٍ، حَدَّثَنَا أَبُو الْمُغِيرَةِ، حَدَّثَنَا الْأَوْزَاعِيُّ، حَدَّ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/تفسیر سورة النجم ۲ (۴۸۶۰)، والأدب ۷۴ (۶۱۰۷)، والاستئذان ۵۲ (۶۳۰۱)، والأیمان ۵ (۶۶۵۰)، صحیح مسلم/الأیمان ۲ (۱۶۴۸)، سنن ابی داود/ الأیمان ۴ (۳۲۴۷)، سنن النسائی/الأیمان ۱۱ (۳۷۸۴)، سنن ابن ماجہ/الکفارات ۲ (۲۰۹۶)، (تحفة الأشراف : ۱۲۲۷۶)، و مسند احمد (۲/۳۰۹),1545,,The Book on Vows and Oaths
1546,حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا اللَّيْثُ، عَنْ ابْنِ شِهَابٍ، عَنْ عُبَيْدِ اللَّهِ بْنِ عَبْدِ ا,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الوصایا ۱۹ (۲۷۶۱)، والأیمان ۳۰ (۶۶۹۸)، والحیل ۳ (۶۹۵۹)، صحیح مسلم/النذور ۱ (۱۶۳۸)، سنن ابی داود/ الأیمان ۲۵ (۳۳۰۷)، سنن النسائی/الوصایا ۸ (۳۶۸۸)، والأیمان ۳۵ (۳۸۴۸)، سنن ابن ماجہ/الکفارات ۱۹ (۲۱۲۳)، (تحفة الأشراف : ۵۸۳۵)، وط/النذور۱ (۱)، و مسند احمد (۱/۲۱۹، ۲۲۹، ۳۷۰),1546,,The Book on Vows and Oaths
1547,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الْأَعْلَى، حَدَّثَنَا عِمْرَانُ بْنُ عُيَيْنَةَ هُوَ أَخُو سُفْيَا,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۴۸۶۴),1547,,The Book on Vows and Oaths
1558,"حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا أَبُو صَفْوَانَ، عَنْ يُونُسَ بْنِ يَزِيدَ، عَنِ ابْنِ شِهَابٍ، عَنْ أَبِي سَلَمَةَ، عَنْ عَائِشَةَ، قَالَتْ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ لاَ نَذْرَ فِي مَعْصِيَةٍ وَكَفَّارَتُهُ كَفَّارَةُ يَمِينٍ ‏""""‏ ‏.‏ قَالَ وَفِي الْبَابِ عَنِ ابْنِ عُمَرَ وَجَابِرٍ وَعِمْرَانَ بْنِ حُصَيْنٍ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ لاَ يَصِحُّ لأَنَّ الزُّهْرِيَّ لَمْ يَسْمَعْ هَذَا الْحَدِيثَ مِنْ أَبِي سَلَمَةَ ‏.‏ قَالَ سَمِعْتُ مُحَمَّدًا يَقُولُ رَوَى غَيْرُ وَاحِدٍ مِنْهُمْ مُوسَى بْنُ عُقْبَةَ وَابْنُ أَبِي عَتِيقٍ عَنِ الزُّهْرِيِّ عَنْ سُلَيْمَانَ بْنِ أَرْقَمَ عَنْ يَحْيَى بْنِ أَبِي كَثِيرٍ عَنْ أَبِي سَلَمَةَ عَنْ عَائِشَةَ عَنِ النَّبِيِّ صلى الله عليه وسلم ‏.‏ قَالَ مُحَمَّدٌ وَالْحَدِيثُ هُوَ هَذَا ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Daif Isnaad,takhreej: تخریج دارالدعوہ: صحیح مسلم/الجہاد ۵۱ (۱۸۱۷)، سنن ابی داود/ الجہاد ۱۵۳ (۲۷۳۲)، سنن ابن ماجہ/الجہاد ۲۷ (۲۸۳۲)، (تحفة الأشراف : ۱۶۳۵۸)، وسنن الدارمی/السیر۵۴ (۲۵۳۸),,Narrated 'Aishah:,The Book on Vows and Oaths
1559,"حَدَّثَنَا أَبُو إِسْمَاعِيلَ التِّرْمِذِيُّ، - وَاسْمُهُ مُحَمَّدُ بْنُ إِسْمَاعِيلَ بْنِ يُوسُفَ حَدَّثَنَا أَيُّوبُ بْنُ سُلَيْمَانَ بْنِ بِلاَلٍ، حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي أُوَيْسٍ، عَنْ سُلَيْمَانَ بْنِ بِلاَلٍ، عَنْ مُوسَى بْنِ عُقْبَةَ، وَمُحَمَّدِ بْنِ عَبْدِ اللَّهِ بْنِ أَبِي عَتِيقٍ، عَنِ الزُّهْرِيِّ، عَنْ سُلَيْمَانَ بْنِ أَرْقَمَ، عَنْ يَحْيَى بْنِ أَبِي كَثِيرٍ، عَنْ أَبِي سَلَمَةَ، عَنْ عَائِشَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ لاَ نَذْرَ فِي مَعْصِيَةِ اللَّهِ وَكَفَّارَتُهُ كَفَّارَةُ يَمِينٍ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ غَرِيبٌ وَهُوَ أَصَحُّ مِنْ حَدِيثِ أَبِي صَفْوَانَ عَنْ يُونُسَ ‏.‏ وَأَبُو صَفْوَانَ هُوَ مَكِّيٌّ وَاسْمُهُ عَبْدُ اللَّهِ بْنُ سَعِيدِ بْنِ عَبْدِ الْمَلِكِ بْنِ مَرْوَانَ وَقَدْ رَوَى عَنْهُ الْحُمَيْدِيُّ وَغَيْرُ وَاحِدٍ مِنْ جِلَّةِ أَهْلِ الْحَدِيثِ ‏.‏ وَقَالَ قَوْمٌ مِنْ أَهْلِ الْعِلْمِ مِنْ أَصْحَابِ النَّبِيِّ صلى الله عليه وسلم وَغَيْرِهِمْ لاَ نَذْرَ فِي مَعْصِيَةِ اللَّهِ وَكَفَّارَتُهُ كَفَّارَةُ يَمِينٍ ‏.‏ وَهُوَ قَوْلُ أَحْمَدَ وَإِسْحَاقَ وَاحْتَجَّا بِحَدِيثِ الزُّهْرِيِّ عَنْ أَبِي سَلَمَةَ عَنْ عَائِشَةَ ‏.‏ وَقَالَ بَعْضُ أَهْلِ الْعِلْمِ مِنْ أَصْحَابِ النَّبِيِّ صلى الله عليه وسلم وَغَيْرِهِمْ لاَ نَذْرَ فِي مَعْصِيَةٍ وَلاَ كَفَّارَةَ فِي ذَلِكَ ‏.‏ وَهُوَ قَوْلُ مَالِكٍ وَالشَّافِعِيِّ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: تخریج دارالدعوہ: صحیح البخاری/فرض الخمس ۱۵ (۳۱۳۶)، والمناقب ۳۷ (۳۸۷۶)، والمغازي ۳۸ (۴۲۳۰)، صحیح مسلم/فضائل الصحابة ۴۱ (۲۵۰۲)، سنن ابی داود/ الجہاد ۱۵۱ (۲۷۲۵)، (تحفة الأشراف : ۹۰۴۹),,Narrated 'Aishah:,The Book on Vows and Oaths
1560,"حَدَّثَنَا قُتَيْبَةُ بْنُ سَعِيدٍ، عَنْ مَالِكِ بْنِ أَنَسٍ، عَنْ طَلْحَةَ بْنِ عَبْدِ الْمَلِكِ الأَيْلِيِّ، عَنِ الْقَاسِمِ بْنِ مُحَمَّدٍ، عَنْ عَائِشَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ مَنْ نَذَرَ أَنْ يُطِيعَ اللَّهَ فَلْيُطِعْهُ وَمَنْ نَذَرَ أَنْ يَعْصِيَ اللَّهَ فَلاَ يَعْصِهِ ‏""""‏ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih,takhreej: تخریج دارالدعوہ: انظر حدیث رقم ۱۴۶۴,,Narrated 'Aishah:,The Book on Vows and Oaths
1561,حَدَّثَنَا الْحَسَنُ بْنُ عَلِيٍّ الْخَلاَّلُ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ طَلْحَةَ بْنِ عَبْدِ الْمَلِكِ الأَيْلِيِّ، عَنِ الْقَاسِمِ بْنِ مُحَمَّدٍ، عَنْ عَائِشَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم نَحْوَهُ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَقَدْ رَوَاهُ يَحْيَى بْنُ أَبِي كَثِيرٍ عَنِ الْقَاسِمِ بْنِ مُحَمَّدٍ ‏.‏ وَهُوَ قَوْلُ بَعْضِ أَهْلِ الْعِلْمِ مِنْ أَصْحَابِ النَّبِيِّ صلى الله عليه وسلم وَغَيْرِهِمْ وَبِهِ يَقُولُ مَالِكٌ وَالشَّافِعِيُّ قَالُوا لاَ يَعْصِي اللَّهَ وَلَيْسَ فِيهِ كَفَّارَةُ يَمِينٍ إِذَا كَانَ النَّذْرُ فِي مَعْصِيَةٍ ‏.‏,Ahmad Muhammad Shakir: Daif Isnaad; Al-Albani: Daif Isnaad,takhreej: تخریج دارالدعوہ: سنن ابن ماجہ/الجہاد ۳۵ (۲۸۵۲)، (تحفة الأشراف : ۵۰۹۱),1561,,The Book on Vows and Oaths
1562,"حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا إِسْحَاقُ بْنُ يُوسُفَ الأَزْرَقُ، عَنْ هِشَامٍ الدَّسْتَوَائِيِّ، عَنْ يَحْيَى بْنِ أَبِي كَثِيرٍ، عَنْ أَبِي قِلاَبَةَ، عَنْ ثَابِتِ بْنِ الضَّحَّاكِ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ لَيْسَ عَلَى الْعَبْدِ نَذْرٌ فِيمَا لاَ يَمْلِكُ ‏""""‏ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ عَبْدِ اللَّهِ بْنِ عَمْرٍو وَعِمْرَانَ بْنِ حُصَيْنٍ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih,takhreej: تخریج دارالدعوہ: صحیح البخاری/البیوع ۳۷ (۲۱۰۰)، والخمس ۱۸ (۳۱۴۲)، والمغازي ۵۴ (۴۳۲۱)، والأحکام ۲۱ (۷۱۷۰)، صحیح مسلم/الجہاد ۱۳ (۱۵۷۱)، سنن ابی داود/ الجہاد ۱۴۷)، (۲۷۱۷)، سنن ابن ماجہ/الجہاد ۲۹ (۲۸۳۷)، (تحفة الأشراف : ۱۲۱۳۲)، وط/الجہاد ۱۰ (۱۸)، سنن الدارمی/السیر ۴۴ (۲۵۲۸),,Narrated Thabit bin Adh-Dahhak:,The Book on Vows and Oaths
1563,"حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا أَبُو بَكْرِ بْنُ عَيَّاشٍ، حَدَّثَنِي مُحَمَّدٌ، مَوْلَى الْمُغِيرَةِ بْنِ شُعْبَةَ حَدَّثَنِي كَعْبُ بْنُ عَلْقَمَةَ، عَنْ أَبِي الْخَيْرِ، عَنْ عُقْبَةَ بْنِ عَامِرٍ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ كَفَّارَةُ النَّذْرِ إِذَا لَمْ يُسَمَّ كَفَّارَةُ يَمِينٍ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ غَرِيبٌ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: سنن ابن ماجہ/التجارات ۲۴ (۲۱۹۶)، (فی سیاق الحول من ذلک) (تحفة الأشراف : ۴۰۷۳),,Narrated 'Uqbah bin 'Amir:,The Book on Vows and Oaths
1564,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الأَعْلَى الصَّنْعَانِيُّ، حَدَّثَنَا الْمُعْتَمِرُ بْنُ سُلَيْمَانَ، عَنْ يُونُسَ، هُوَ ابْنُ عُبَيْدٍ حَدَّثَنَا الْحَسَنُ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ سَمُرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ يَا عَبْدَ الرَّحْمَنِ لاَ تَسْأَلِ الإِمَارَةَ فَإِنَّكَ إِنْ أَتَتْكَ عَنْ مَسْأَلَةٍ وُكِلْتَ إِلَيْهَا وَإِنْ أَتَتْكَ عَنْ غَيْرِ مَسْأَلَةٍ أُعِنْتَ عَلَيْهَا وَإِذَا حَلَفْتَ عَلَى يَمِينٍ فَرَأَيْتَ غَيْرَهَا خَيْرًا مِنْهَا فَائْتِ الَّذِي هُوَ خَيْرٌ وَلْتُكَفِّرْ عَنْ يَمِينِكَ ‏""""‏ ‏.‏ وَفِي الْبَابِ عَنْ عَلِيٍّ وَجَابِرٍ وَعَدِيِّ بْنِ حَاتِمٍ وَأَبِي الدَّرْدَاءِ وَأَنَسٍ وَعَائِشَةَ وَعَبْدِ اللَّهِ بْنِ عَمْرٍو وَأَبِي هُرَيْرَةَ وَأُمِّ سَلَمَةَ وَأَبِي مُوسَى ‏.‏ قَالَ أَبُو عِيسَى حَدِيثُ عَبْدِ الرَّحْمَنِ بْنِ سَمُرَةَ حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Hasan,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف وتقدم برقم ۱۴۷۴ (تحفة الأشراف : ۹۸۹۳),,Narrated 'Abdur-Rahman bin Samurah:,The Book on Vows and Oaths
1565,"حَدَّثَنَا قُتَيْبَةُ، عَنْ مَالِكِ بْنِ أَنَسٍ، عَنْ سُهَيْلِ بْنِ أَبِي صَالِحٍ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ مَنْ حَلَفَ عَلَى يَمِينٍ فَرَأَى غَيْرَهَا خَيْرًا مِنْهَا فَلْيُكَفِّرْ عَنْ يَمِينِهِ وَلْيَفْعَلْ ‏""""‏ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ أُمِّ سَلَمَةَ ‏.‏ قَالَ أَبُو عِيسَى حَدِيثُ أَبِي هُرَيْرَةَ حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَالْعَمَلُ عَلَى هَذَا عِنْدَ أَكْثَرِ أَهْلِ الْعِلْمِ مِنْ أَصْحَابِ النَّبِيِّ صلى الله عليه وسلم وَغَيْرِهِمْ أَنَّ الْكَفَّارَةَ قَبْلَ الْحِنْثِ تُجْزِئُ وَهُوَ قَوْلُ مَالِكِ بْنِ أَنَسٍ وَالشَّافِعِيِّ وَأَحْمَدَ وَإِسْحَاقَ ‏.‏ وَقَالَ بَعْضُ أَهْلِ الْعِلْمِ لاَ يُكَفِّرُ إِلاَّ بَعْدَ الْحِنْثِ ‏.‏ قَالَ سُفْيَانُ الثَّوْرِيُّ إِنْ كَفَّرَ بَعْدَ الْحِنْثِ أَحَبُّ إِلَىَّ وَإِنْ كَفَّرَ قَبْلَ الْحِنْثِ أَجْزَأَهُ ‏.‏""",Ahmad Muhammad Shakir: Hasan; Al-Albani: Hasan; Bashar Awad Maarouf: Hasan,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأطعمة ۲۴ (۳۷۸۴)، سنن ابن ماجہ/الجہاد ۲۶ (۲۸۰)، (تحفة الأشراف : ۱۱۷۳۴)، و مسند احمد (۵/۲۲۶),,Narrated Abu Hurairah:,The Book on Vows and Oaths
1566,"حَدَّثَنَا مَحْمُودُ بْنُ غَيْلاَنَ، حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ، حَدَّثَنِي أَبِي وَحَمَّادُ بْنُ سَلَمَةَ، عَنْ أَيُّوبَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ مَنْ حَلَفَ عَلَى يَمِينٍ فَقَالَ إِنْ شَاءَ اللَّهُ فَقَدِ اسْتَثْنَى فَلاَ حِنْثَ عَلَيْهِ ‏""""‏ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ أَبِي هُرَيْرَةَ ‏.‏ قَالَ أَبُو عِيسَى حَدِيثُ ابْنِ عُمَرَ حَدِيثٌ حَسَنٌ ‏.‏ وَقَدْ رَوَاهُ عُبَيْدُ اللَّهِ بْنُ عُمَرَ وَغَيْرُهُ عَنْ نَافِعٍ عَنِ ابْنِ عُمَرَ مَوْقُوفًا ‏.‏ وَهَكَذَا رُوِيَ عَنْ سَالِمٍ عَنِ ابْنِ عُمَرَ رضى الله عنهما مَوْقُوفًا ‏.‏ وَلاَ نَعْلَمُ أَحَدًا رَفَعَهُ غَيْرَ أَيُّوبَ السَّخْتِيَانِيِّ وَقَالَ إِسْمَاعِيلُ بْنُ إِبْرَاهِيمَ وَكَانَ أَيُّوبُ أَحْيَانًا يَرْفَعُهُ وَأَحْيَانًا لاَ يَرْفَعُهُ ‏.‏ وَالْعَمَلُ عَلَى هَذَا عِنْدَ أَكْثَرِ أَهْلِ الْعِلْمِ مِنْ أَصْحَابِ النَّبِيِّ صلى الله عليه وسلم وَغَيْرِهِمْ أَنَّ الاِسْتِثْنَاءَ إِذَا كَانَ مَوْصُولاً بِالْيَمِينِ فَلاَ حِنْثَ عَلَيْهِ وَهُوَ قَوْلُ سُفْيَانَ الثَّوْرِيِّ وَالأَوْزَاعِيِّ وَمَالِكِ بْنِ أَنَسٍ وَعَبْدِ اللَّهِ بْنِ الْمُبَارَكِ وَالشَّافِعِيِّ وَأَحْمَدَ وَإِسْحَاقَ ‏.‏""",Ahmad Muhammad Shakir: Hasan; Al-Albani: Hasan; Bashar Awad Maarouf: Hasan; Zubair Ali Zai: Hasan,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۳۴۶۸)، وانظر: مسند احمد (۵/۴۱۳، ۴۱۴)، سنن الدارمی/السیر ۳۹,,Narrated Ibn 'Umar:,The Book on Vows and Oaths
1567,"حَدَّثَنَا يَحْيَى بْنُ مُوسَى، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَخْبَرَنَا مَعْمَرٌ، عَنِ ابْنِ طَاوُسٍ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏""‏ مَنْ حَلَفَ عَلَى يَمِينٍ فَقَالَ إِنْ شَاءَ اللَّهُ لَمْ يَحْنَثْ ‏""‏ ‏.‏ قَالَ أَبُو عِيسَى سَأَلْتُ مُحَمَّدَ بْنَ إِسْمَاعِيلَ عَنْ هَذَا فَقَالَ هَذَا حَدِيثٌ خَطَأٌ أَخْطَأَ فِيهِ عَبْدُ الرَّزَّاقِ اخْتَصَرَهُ مِنْ حَدِيثِ مَعْمَرٍ عَنِ ابْنِ طَاوُسٍ عَنْ أَبِيهِ عَنْ أَبِي هُرَيْرَةَ عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏""‏ إِنَّ سُلَيْمَانَ بْنَ دَاوُدَ قَالَ لأَطُوفَنَّ اللَّيْلَةَ عَلَى سَبْعِينَ امْرَأَةً تَلِدُ كُلُّ امْرَأَةٍ غُلاَمًا ‏.‏ فَطَافَ عَلَيْهِنَّ فَلَمْ تَلِدِ امْرَأَةٌ مِنْهُنَّ إِلاَّ امْرَأَةٌ نِصْفَ غُلاَمٍ ‏""‏ ‏.‏ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏""‏ لَوْ قَالَ إِنْ شَاءَ اللَّهُ لَكَانَ كَمَا قَالَ ‏""‏ ‏.‏ هَكَذَا رُوِيَ عَنْ عَبْدِ الرَّزَّاقِ عَنْ مَعْمَرٍ عَنِ ابْنِ طَاوُسٍ عَنْ أَبِيهِ هَذَا الْحَدِيثُ بِطُولِهِ وَقَالَ ‏""‏ سَبْعِينَ امْرَأَةً ‏""‏ ‏.‏ وَقَدْ رُوِيَ هَذَا الْحَدِيثُ مِنْ غَيْرِ وَجْهٍ عَنْ أَبِي هُرَيْرَةَ عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏""‏ قَالَ سُلَيْمَانُ بْنُ دَاوُدَ لأَطُوفَنَّ اللَّيْلَةَ عَلَى مِائَةِ امْرَأَةٍ ‏""‏ ‏.‏",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (أخرجہ النسائي في الکبریٰ) (تحفة الأشراف : ۱۰۲۳۴),1567,Narrated Abu Hurairah:,The Book on Vows and Oaths
1568,"حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا سُفْيَانُ، عَنِ الزُّهْرِيِّ، عَنْ سَالِمٍ، عَنْ أَبِيهِ، سَمِعَ النَّبِيُّ صلى الله عليه وسلم عُمَرَ وَهُوَ يَقُولُ وَأَبِي وَأَبِي فَقَالَ ‏ ‏ أَلاَ إِنَّ اللَّهَ يَنْهَاكُمْ أَنْ تَحْلِفُوا بِآبَائِكُمْ ‏""""‏ ‏.‏ فَقَالَ عُمَرُ فَوَاللَّهِ مَا حَلَفْتُ بِهِ بَعْدَ ذَلِكَ ذَاكِرًا وَلاَ آثِرًا ‏.‏ قَالَ وَفِي الْبَابِ عَنْ ثَابِتِ بْنِ الضَّحَّاكِ وَابْنِ عَبَّاسٍ وَأَبِي هُرَيْرَةَ وَقُتَيْلَةَ وَعَبْدِ الرَّحْمَنِ بْنِ سَمُرَةَ ‏.‏ قَالَ أَبُو عِيسَى حَدِيثُ ابْنِ عُمَرَ حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ قَالَ أَبُو عِيسَى قَالَ أَبُو عُبَيْدٍ مَعْنَى قَوْلِهِ وَلاَ آثِرًا ‏.‏ أَىْ لَمْ آثُرْهُ عَنْ غَيْرِي يَقُولُ لَمْ أَذْكُرْهُ عَنْ غَيْرِي ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (أخرجہ النسائي فی الکبریٰ) (تحفة الأشراف : ۱۰۸۸۷),,Narrated Salim:,The Book on Vows and Oaths
1569,"حَدَّثَنَا هَنَّادٌ، حَدَّثَنَا عَبْدَةُ، عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم أَدْرَكَ عُمَرَ وَهُوَ فِي رَكْبٍ وَهُوَ يَحْلِفُ بِأَبِيهِ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ إِنَّ اللَّهَ يَنْهَاكُمْ أَنْ تَحْلِفُوا بِآبَائِكُمْ لِيَحْلِفْ حَالِفٌ بِاللَّهِ أَوْ لِيَسْكُتْ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الجہاد ۱۴۷ (۳۰۱۴)، و۱۴۸ (۳۰۱۵)، صحیح مسلم/الجہاد ۸ (۱۷۴۴)، سنن ابی داود/ الجہاد ۱۲۱ (۲۶۶۸)، سنن ابن ماجہ/الجہاد ۳۰ (۲۸۴۱)، (تحفة الأشراف : ۸۶۶۸)، وط/الجہاد ۳ (۹)، سنن الدارمی/السیر ۲۵ (۲۵۰۵),,Narrated Ibn 'Umar:,The Book on Vows and Oaths
1570,"حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ، عَنِ الْحَسَنِ بْنِ عُبَيْدِ اللَّهِ، عَنْ سَعْدِ بْنِ عُبَيْدَةَ، أَنَّ ابْنَ عُمَرَ، سَمِعَ رَجُلاً، يَقُولُ لاَ وَالْكَعْبَةِ ‏.‏ فَقَالَ ابْنُ عُمَرَ لاَ يُحْلَفُ بِغَيْرِ اللَّهِ فَإِنِّي سَمِعْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم يَقُولُ ‏""‏ مَنْ حَلَفَ بِغَيْرِ اللَّهِ فَقَدْ كَفَرَ أَوْ أَشْرَكَ ‏""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ ‏.‏ وَفُسِّرَ هَذَا الْحَدِيثُ عِنْدَ بَعْضِ أَهْلِ الْعِلْمِ أَنَّ قَوْلَهُ ‏""‏ فَقَدْ كَفَرَ أَوْ أَشْرَكَ ‏""‏ عَلَى التَّغْلِيظِ ‏.‏ وَالْحُجَّةُ فِي ذَلِكَ حَدِيثُ ابْنِ عُمَرَ أَنَّ النَّبِيَّ صلى الله عليه وسلم سَمِعَ عُمَرَ يَقُولُ وَأَبِي وَأَبِي ‏.‏ فَقَالَ ‏""‏ أَلاَ إِنَّ اللَّهَ يَنْهَاكُمْ أَنْ تَحْلِفُوا بِآبَائِكُمْ ‏""‏ ‏.‏ وَحَدِيثُ أَبِي هُرَيْرَةَ عَنِ النَّبِيِّ صلى الله عليه وسلم أَنَّهُ قَالَ ‏""‏ مَنْ قَالَ فِي حَلِفِهِ وَاللاَّتِ وَالْعُزَّى فَلْيَقُلْ لاَ إِلَهَ إِلاَّ اللَّهُ ‏""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا مِثْلُ مَا رُوِيَ عَنِ النَّبِيِّ صلى الله عليه وسلم أَنَّهُ قَالَ ‏""‏ إِنَّ الرِّيَاءَ شِرْكٌ ‏""‏ ‏.‏ وَقَدْ فَسَّرَ بَعْضُ أَهْلِ الْعِلْمِ هَذِهِ الآيَة ‏:‏ ‏(‏ وَمَنْ كَانَ يَرْجُو لِقَاءَ رَبِّهِ فَلْيَعْمَلْ عَمَلاً صَالِحًا ‏)‏ الآيَةَ قَالَ لاَ يُرَائِي ‏.‏",Ahmad Muhammad Shakir: Hasan; Al-Albani: Hasan; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الجہاد ۱۴۶ (۳۰۱۲)، صحیح مسلم/الجہاد ۹ (۱۷۸۵)، سنن ابی داود/ الجہاد ۱۲۱ (۲۶۷۲)، سنن ابن ماجہ/الجہاد ۳۰ (۲۸۳۹)، (تحفة الأشراف : ۹۳۹)، و مسند احمد (۴/۳۸، ۷۱، ۷۲، ۷۳),1570,Narrated Sa'd bin 'Ubaidah:,The Book on Vows and Oaths
1571,"حَدَّثَنَا عَبْدُ الْقُدُّوسِ بْنُ مُحَمَّدٍ الْعَطَّارُ الْبَصْرِيُّ، حَدَّثَنَا عَمْرُو بْنُ عَاصِمٍ، عَنْ عِمْرَانَ الْقَطَّانِ، عَنْ حُمَيْدٍ، عَنْ أَنَسٍ، قَالَ نَذَرَتِ امْرَأَةٌ أَنْ تَمْشِيَ، إِلَى بَيْتِ اللَّهِ فَسُئِلَ نَبِيُّ اللَّهِ صلى الله عليه وسلم عَنْ ذَلِكَ فَقَالَ ‏ ‏ إِنَّ اللَّهَ لَغَنِيٌّ عَنْ مَشْيِهَا مُرُوهَا فَلْتَرْكَبْ ‏""""‏ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ أَبِي هُرَيْرَةَ وَعُقْبَةَ بْنِ عَامِرٍ وَابْنِ عَبَّاسٍ ‏.‏ قَالَ أَبُو عِيسَى حَدِيثُ أَنَسٍ حَدِيثٌ حَسَنٌ صَحِيحٌ غَرِيبٌ مِنْ هَذَا الْوَجْهِ ‏.‏ وَالْعَمَلُ عَلَى هَذَا عِنْدَ بَعْضِ أَهْلِ الْعِلْمِ وَقَالُوا إِذَا نَذَرَتِ امْرَأَةٌ أَنْ تَمْشِيَ فَلْتَرْكَبْ وَلْتُهْدِ شَاةً ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: تخریج دارالدعوہ: صحیح البخاری/الجہاد ۴۹ (۳۰۱۶)، (تحفة الأشراف : ۱۳۴۸۱),,Narrated Anas:,The Book on Vows and Oaths
1572,"حَدَّثَنَا أَبُو مُوسَى، مُحَمَّدُ بْنُ الْمُثَنَّى حَدَّثَنَا خَالِدُ بْنُ الْحَارِثِ، حَدَّثَنَا حُمَيْدٌ، عَنْ ثَابِتٍ، عَنْ أَنَسٍ، قَالَ مَرَّ النَّبِيُّ صلى الله عليه وسلم بِشَيْخٍ كَبِيرٍ يَتَهَادَى بَيْنَ ابْنَيْهِ فَقَالَ ‏""‏ مَا بَالُ هَذَا ‏""‏ ‏.‏ قَالُوا يَا رَسُولَ اللَّهِ نَذَرَ أَنْ يَمْشِيَ ‏.‏ قَالَ ‏""‏ إِنَّ اللَّهَ عَزَّ وَجَلَّ لَغَنِيٌّ عَنْ تَعْذِيبِ هَذَا نَفْسَهُ ‏""‏ ‏.‏ قَالَ فَأَمَرَهُ أَنْ يَرْكَبَ ‏.‏",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف، وانظر ما یأتي (تحفة الأشراف : ۲۰۸۵)، و مسند احمد (۲۷۶۵، ۲۸۲),1572,Narrated Anas:,The Book on Vows and Oaths
1573,حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، حَدَّثَنَا ابْنُ أَبِي عَدِيٍّ، عَنْ حُمَيْدٍ، عَنْ أَنَسٍ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم رَأَى رَجُلاً فَذَكَرَ نَحْوَهُ ‏.‏ هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏,Ahmad Muhammad Shakir: Shadh; Al-Albani: Shadh; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: سنن ابن ماجہ/الصدقات ۱۲ (۲۴۱۲)، و مسند احمد (۵/۲۸۱ (تحفة الأشراف : ۲۱۱۴)،,1573,,The Book on Vows and Oaths
1574,"حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ، عَنِ الْعَلاَءِ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ لاَ تَنْذِرُوا فَإِنَّ النَّذْرَ لاَ يُغْنِي مِنَ الْقَدَرِ شَيْئًا وَإِنَّمَا يُسْتَخْرَجُ بِهِ مِنَ الْبَخِيلِ ‏""""‏ ‏.‏ قَالَ وَفِي الْبَابِ عَنِ ابْنِ عُمَرَ ‏.‏ قَالَ أَبُو عِيسَى حَدِيثُ أَبِي هُرَيْرَةَ حَدِيثٌ حَسَنٌ ‏.‏ وَالْعَمَلُ عَلَى هَذَا عِنْدَ بَعْضِ أَهْلِ الْعِلْمِ مِنْ أَصْحَابِ النَّبِيِّ صلى الله عليه وسلم وَغَيْرِهِمْ كَرِهُوا النَّذْرَ ‏.‏ وَقَالَ عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ مَعْنَى الْكَرَاهِيَةِ فِي النَّذْرِ فِي الطَّاعَةِ وَالْمَعْصِيَةِ وَإِنْ نَذَرَ الرَّجُلُ بِالطَّاعَةِ فَوَفَّى بِهِ فَلَهُ فِيهِ أَجْرٌ وَيُكْرَهُ لَهُ النَّذْرُ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/الإیمان ۴۸ (۱۱۴)، (تحفة الأشراف : ۱۰۴۹۷),,Narrated Abu Hurairah:,The Book on Vows and Oaths
1575,"حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ، أَخْبَرَنَا يَحْيَى بْنُ سَعِيدٍ الْقَطَّانُ، عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، عَنْ عُمَرَ، قَالَ قُلْتُ يَا رَسُولَ اللَّهِ إِنِّي كُنْتُ نَذَرْتُ أَنْ أَعْتَكِفَ لَيْلَةً فِي الْمَسْجِدِ الْحَرَامِ فِي الْجَاهِلِيَّةِ ‏.‏ قَالَ ‏ ‏ أَوْفِ بِنَذْرِكَ ‏""""‏ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ عَبْدِ اللَّهِ بْنِ عَمْرٍو وَابْنِ عَبَّاسٍ ‏.‏ قَالَ أَبُو عِيسَى حَدِيثُ عُمَرَ حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَقَدْ ذَهَبَ بَعْضُ أَهْلِ الْعِلْمِ إِلَى هَذَا الْحَدِيثِ قَالُوا إِذَا أَسْلَمَ الرَّجُلُ وَعَلَيْهِ نَذْرُ طَاعَةٍ فَلْيَفِ بِهِ ‏.‏ وَقَالَ بَعْضُ أَهْلِ الْعِلْمِ مِنْ أَصْحَابِ النَّبِيِّ صلى الله عليه وسلم وَغَيْرِهِمْ لاَ اعْتِكَافَ إِلاَّ بِصَوْمٍ ‏.‏ وَقَالَ آخَرُونَ مِنْ أَهْلِ الْعِلْمِ لَيْسَ عَلَى الْمُعْتَكِفِ صَوْمٌ إِلاَّ أَنْ يُوجِبَ عَلَى نَفْسِهِ صَوْمًا ‏.‏ وَاحْتَجُّوا بِحَدِيثِ عُمَرَ أَنَّهُ نَذَرَ أَنْ يَعْتَكِفَ لَيْلَةً فِي الْجَاهِلِيَّةِ فَأَمَرَهُ النَّبِيُّ صلى الله عليه وسلم بِالْوَفَاءِ ‏.‏ وَهُوَ قَوْلُ أَحْمَدَ وَإِسْحَاقَ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/الجہاد ۴۷ (۱۸۱۰)، سنن ابی داود/ الجہاد ۳۴ (۲۵۳۱)، (تحفة الأشراف : ۲۶۱)، (وانظر المعنی عند: صحیح البخاری/الجہاد ۶۵ (۲۸۸۰)، ومناقب الأنصار ۱۸ (۳۸۱۱)، والمغازي ۱۸ (۴۰۶۴),,Narrated 'Umar:,The Book on Vows and Oaths
1576,"حَدَّثَنَا عَلِيُّ بْنُ حُجْرٍ، أَخْبَرَنَا عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ، وَعَبْدُ اللَّهِ بْنُ جَعْفَرٍ، عَنْ مُوسَى بْنِ عُقْبَةَ، عَنْ سَالِمِ بْنِ عَبْدِ اللَّهِ، عَنْ أَبِيهِ، قَالَ كَثِيرًا مَا كَانَ رَسُولُ اللَّهِ صلى الله عليه وسلم يَحْلِفُ بِهَذِهِ الْيَمِينِ ‏ ‏ لاَ وَمُقَلِّبِ الْقُلُوبِ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏""",Ahmad Muhammad Shakir: Very Daif; Al-Albani: Very Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۱۰۱۰۹),,Narrated Salim bin 'Abdullah:,The Book on Vows and Oaths
1577,"حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا اللَّيْثُ، عَنِ ابْنِ الْهَادِ، عَنْ عُمَرَ بْنِ عَلِيِّ بْنِ الْحُسَيْنِ بْنِ عَلِيِّ بْنِ أَبِي طَالِبٍ، عَنْ سَعِيدِ ابْنِ مَرْجَانَةَ، عَنْ أَبِي هُرَيْرَةَ، قَالَ سَمِعْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم يَقُولُ ‏ ‏ مَنْ أَعْتَقَ رَقَبَةً مُؤْمِنَةً أَعْتَقَ اللَّهُ مِنْهُ بِكُلِّ عُضْوٍ مِنْهُ عُضْوًا مِنَ النَّارِ حَتَّى يُعْتِقَ فَرْجَهُ بِفَرْجِهِ ‏""""‏ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ عَائِشَةَ وَعَمْرِو بْنِ عَبَسَةَ وَابْنِ عَبَّاسٍ وَوَاثِلَةَ بْنِ الأَسْقَعِ وَأَبِي أُمَامَةَ وَعُقْبَةَ بْنِ عَامِرٍ وَكَعْبِ بْنِ مُرَّةَ ‏.‏ قَالَ أَبُو عِيسَى حَدِيثُ أَبِي هُرَيْرَةَ هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ غَرِيبٌ مِنْ هَذَا الْوَجْهِ ‏.‏ وَابْنُ الْهَادِ اسْمُهُ يَزِيدُ بْنُ عَبْدِ اللَّهِ بْنِ أُسَامَةَ بْنِ الْهَادِ وَهُوَ مَدَنِيٌّ ثِقَةٌ قَدْ رَوَى عَنْهُ مَالِكُ بْنُ أَنَسٍ وَغَيْرُ وَاحِدٍ مِنْ أَهْلِ الْعِلْمِ ‏.‏""",Ahmad Muhammad Shakir: Hasan Sahih; Al-Albani: Hasan Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Hasan,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الخراج والإمارة ۳۵ (۳۰۵۷)، (تحفة الأشراف : ۱۱۰۱۵)، و مسند احمد (۴/۱۶۲),,Narrated Abu Hurairah:,The Book on Vows and Oaths
1578,حَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا الْمُحَارِبِيُّ، عَنْ شُعْبَةَ، عَنْ حُصَيْنٍ، عَنْ هِلاَلِ بْنِ يِسَافٍ، عَنْ سُوَيْدِ بْنِ مُقَرِّنٍ الْمُزَنِيِّ، قَالَ لَقَدْ رَأَيْتُنَا سَبْعَةَ إِخْوَةٍ مَا لَنَا خَادِمٌ إِلاَّ وَاحِدَةٌ فَلَطَمَهَا أَحَدُنَا فَأَمَرَنَا النَّبِيُّ صلى الله عليه وسلم أَنْ نُعْتِقَهَا ‏.‏ قَالَ وَفِي الْبَابِ عَنِ ابْنِ عُمَرَ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَقَدْ رَوَى غَيْرُ وَاحِدٍ هَذَا الْحَدِيثَ عَنْ حُصَيْنِ بْنِ عَبْدِ الرَّحْمَنِ فَذَكَرَ بَعْضُهُمْ فِي الْحَدِيثِ قَالَ لَطَمَهَا عَلَى وَجْهِهَا ‏.‏,Ahmad Muhammad Shakir: Hasan; Al-Albani: Hasan; Bashar Awad Maarouf: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الجہاد ۱۷۴ (۲۷۷۴)، سنن ابن ماجہ/الإقامة ۱۹۲ (۱۳۹۴)، (تحفة الأشراف : ۱۱۶۹۸),1578,Narrated Suwaid bin Muqarrin Al-Muzani:,The Book on Vows and Oaths
1579,"حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا إِسْحَاقُ بْنُ يُوسُفَ الأَزْرَقُ، عَنْ هِشَامٍ الدَّسْتَوَائِيِّ، عَنْ يَحْيَى بْنِ أَبِي كَثِيرٍ، عَنْ أَبِي قِلاَبَةَ، عَنْ ثَابِتِ بْنِ الضَّحَّاكِ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنْ حَلَفَ بِمِلَّةٍ غَيْرِ الإِسْلاَمِ كَاذِبًا فَهُوَ كَمَا قَالَ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَقَدِ اخْتَلَفَ أَهْلُ الْعِلْمِ فِي هَذَا إِذَا حَلَفَ الرَّجُلُ بِمِلَّةٍ سِوَى الإِسْلاَمِ فَقَالَ هُوَ يَهُودِيٌّ أَوْ نَصْرَانِيٌّ إِنْ فَعَلَ كَذَا وَكَذَا فَفَعَلَ ذَلِكَ الشَّىْءَ فَقَالَ بَعْضُهُمْ قَدْ أَتَى عَظِيمًا وَلاَ كَفَّارَةَ عَلَيْهِ وَهُوَ قَوْلُ أَهْلِ الْمَدِينَةِ وَبِهِ يَقُولُ مَالِكُ بْنُ أَنَسٍ وَإِلَى هَذَا الْقَوْلِ ذَهَبَ أَبُو عُبَيْدٍ ‏.‏ وَقَالَ بَعْضُ أَهْلِ الْعِلْمِ مِنْ أَصْحَابِ النَّبِيِّ صلى الله عليه وسلم وَالتَّابِعِينَ وَغَيْرِهِمْ عَلَيْهِ فِي ذَلِكَ الْكَفَّارَةُ وَهُوَ قَوْلُ سُفْيَانَ وَأَحْمَدَ وَإِسْحَاقَ ‏.‏""",Ahmad Muhammad Shakir: Hasan; Al-Albani: Hasan; Bashar Awad Maarouf: Hasan,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۱۴۸۰۹),,Narrated Thabit bin Adh-Dahhak:,The Book on Vows and Oaths
1580,"حَدَّثَنَا مَحْمُودُ بْنُ غَيْلاَنَ، حَدَّثَنَا وَكِيعٌ، عَنْ سُفْيَانَ، عَنْ يَحْيَى بْنِ سَعِيدٍ، عَنْ عُبَيْدِ اللَّهِ بْنِ زَحْرٍ، عَنْ أَبِي سَعِيدٍ الرُّعَيْنِيِّ، عَنْ عَبْدِ اللَّهِ بْنِ مَالِكٍ الْيَحْصُبِيِّ، عَنْ عُقْبَةَ بْنِ عَامِرٍ، قَالَ قُلْتُ يَا رَسُولَ اللَّهِ إِنَّ أُخْتِي نَذَرَتْ أَنْ تَمْشِيَ إِلَى الْبَيْتِ حَافِيَةً غَيْرَ مُخْتَمِرَةٍ ‏.‏ فَقَالَ النَّبِيُّ صلى الله عليه وسلم ‏ ‏ إِنَّ اللَّهَ لاَ يَصْنَعُ بِشَقَاءِ أُخْتِكَ شَيْئًا فَلْتَرْكَبْ وَلْتَخْتَمِرْ وَلْتَصُمْ ثَلاَثَةَ أَيَّامٍ ‏""""‏ ‏.‏ قَالَ وَفِي الْبَابِ عَنِ ابْنِ عَبَّاسٍ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ ‏.‏ وَالْعَمَلُ عَلَى هَذَا عِنْدَ أَهْلِ الْعِلْمِ وَهُوَ قَوْلُ أَحْمَدَ وَإِسْحَاقَ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الجہاد ۱۶۴ (۲۷۵۹)، (تحفة الأشراف : ۱۰۷۵۳)، و مسند احمد (۴/۱۱۱),,Narrated 'Uqbah bin 'Amir:,The Book on Vows and Oaths
1581,"حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ، حَدَّثَنَا أَبُو الْمُغِيرَةِ، حَدَّثَنَا الأَوْزَاعِيُّ، حَدَّثَنَا الزُّهْرِيُّ، عَنْ حُمَيْدِ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنْ حَلَفَ مِنْكُمْ فَقَالَ فِي حَلِفِهِ وَاللاَّتِ وَالْعُزَّى فَلْيَقُلْ لاَ إِلَهَ إِلاَّ اللَّهُ وَمَنْ قَالَ تَعَالَ أُقَامِرْكَ فَلْيَتَصَدَّقْ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَأَبُو الْمُغِيرَةِ هُوَ الْخَوْلاَنِيُّ الْحِمْصِيُّ وَاسْمُهُ عَبْدُ الْقُدُّوسِ بْنُ الْحَجَّاجِ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الجزیة ۲۲ (۳۱۸۸)، والأدب ۹۹ (۶۱۷۷)، والحیل ۹ (۶۹۶۶)، والفتن ۲۱ (۷۱۱۱)، صحیح مسلم/الجہاد ۴ (۱۷۳۶)، سنن ابی داود/ الجہاد ۱۶۲ (۲۷۵۶)، (تحفة الأشراف : ۷۶۹۰)، و مسند احمد ۲/۱۴۲),,Narrated Abu Hurairah:,The Book on Vows and Oaths
1582,"حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا اللَّيْثُ، عَنِ ابْنِ شِهَابٍ، عَنْ عُبَيْدِ اللَّهِ بْنِ عَبْدِ اللَّهِ بْنِ عُتْبَةَ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ سَعْدَ بْنَ عُبَادَةَ، اسْتَفْتَى رَسُولَ اللَّهِ صلى الله عليه وسلم فِي نَذْرٍ كَانَ عَلَى أُمِّهِ تُوُفِّيَتْ قَبْلَ أَنْ تَقْضِيَهُ فَقَالَ النَّبِيُّ صلى الله عليه وسلم ‏ ‏ اقْضِهِ عَنْهَا ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (أخرجہ النسائي في الکبریٰ (تحفة الأشراف : ۲۹۲۵),,Narrated Ibn 'Abbas:,The Book on Vows and Oaths
1583,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الْأَعْلَى حَدَّثَنَا عِمْرَانُ بْنُ عُيَيْنَةَ هُوَ أَخُو سُفْيَانَ بْنِ عُيَيْنَةَ عَنْ حُصَيْنٍ عَنْ سَالِمِ بْنِ أَبِي الْجَعْدِ عَنْ أَبِي أُمَامَةَ وَغَيْرِهِ مِنْ أَصْحَابِ النَّبِيِّ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ  عَنْ النَّبِيِّ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ قَالَ أَيُّمَا امْرِئٍ مُسْلِمٍ أَعْتَقَ امْرَأً مُسْلِمًا كَانَ فَكَاكَهُ مِنْ النَّارِ يُجْزِي كُلُّ عُضْوٍ مِنْهُ عُضْوًا مِنْهُ وَأَيُّمَا امْرِئٍ مُسْلِمٍ أَعْتَقَ امْرَأَتَيْنِ مُسْلِمَتَيْنِ كَانَتَا فَكَاكَهُ مِنْ النَّارِ يُجْزِي كُلُّ عُضْوٍ مِنْهُمَا عُضْوًا مِنْهُ وَأَيُّمَا امْرَأَةٍ مُسْلِمَةٍ أَعْتَقَتْ امْرَأَةً مُسْلِمَةً كَانَتْ فَكَاكَهَا مِنْ النَّارِ يُجْزِي كُلُّ عُضْوٍ مِنْهَا عُضْوًا مِنْهَا  قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ غَرِيبٌ مِنْ هَذَا الْوَجْهِ قَالَ أَبُو عِيسَى وَفِي الْحَدِيثِ مَا يَدُلُّ عَلَى أَنَّ عِتْقَ الذُّكُورِ لِلرِّجَالِ أَفْضَلُ مِنْ عِتْقِ الْإِنَاثِ لِقَوْلِ رَسُولِ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ مَنْ أَعْتَقَ امْرَأً مُسْلِمًا كَانَ فَكَاكَهُ مِنْ النَّارِ يُجْزِي كُلُّ عُضْوٍ مِنْهُ عُضْوًا مِنْهُ,Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الجہاد ۱۲۱ (۲۶۷۰)، (تحفة الأشراف : ۴۵۹۲)، و مسند احمد (۵/۱۲، ۲۰),1583,"Abu Umamah, and other than him from the Companions of the Prophet (ﷺ), narrated that the Prophet (ﷺ) said:",The Book on Vows and Oaths
