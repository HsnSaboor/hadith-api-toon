hadiths[count]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}:
2618,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، وَأَبُو مُصْعَبٍ الزُّهْرِيُّ وَسُوَيْدُ بْنُ سَعِيدٍ قَالُوا حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، عَنْ سُمَىٍّ، مَوْلَى أَبِي بَكْرِ بْنِ عَبْدِ الرَّحْمَنِ عَنْ أَبِي صَالِحٍ السَّمَّانِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ السَّفَرُ قِطْعَةٌ مِنَ الْعَذَابِ يَمْنَعُ أَحَدَكُمْ نَوْمَهُ وَطَعَامَهُ وَشَرَابَهُ فَإِذَا قَضَى أَحَدُكُمْ نَهْمَتَهُ مِنْ سَفَرِهِ فَلْيُعَجِّلِ الرُّجُوعَ إِلَى أَهْلِهِ ‏""""‏ ‏.‏ حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ، عَنْ سُهَيْلٍ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم بِنَحْوِهِ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۹۳۷، ومصباح الزجاجة:۹۲۷)، وقد أخرجہ: مسند احمد (۴/۱۴۸،۱۵۲),,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Hajj Rituals
2619,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، وَعَمْرُو بْنُ عَبْدِ اللَّهِ، قَالاَ حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا إِسْمَاعِيلُ أَبُو إِسْرَائِيلَ، عَنْ فُضَيْلِ بْنِ عَمْرٍو، عَنْ سَعِيدِ بْنِ جُبَيْرٍ، عَنِ ابْنِ عَبَّاسٍ، عَنِ الْفَضْلِ، - أَوْ أَحَدِهِمَا عَنِ الآخَرِ، - قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنْ أَرَادَ الْحَجَّ فَلْيَتَعَجَّلْ فَإِنَّهُ قَدْ يَمْرَضُ الْمَرِيضُ وَتَضِلُّ الضَّالَّةُ وَتَعْرِضُ الْحَاجَةُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Lighairihi; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۷۶۷، ومصباح الزجاجة:۹۲۸),,It was\nnarrated from Ibn ‘Abbas that Fadl said – or vice verse:,Chapters on Hajj Rituals
2620,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا مَنْصُورُ بْنُ وَرْدَانَ، حَدَّثَنَا عَلِيُّ بْنُ عَبْدِ الأَعْلَى، عَنْ أَبِيهِ، عَنْ أَبِي الْبَخْتَرِيِّ، عَنْ عَلِيٍّ، قَالَ لَمَّا نَزَلَتْ ‏{‏وَلِلَّهِ عَلَى النَّاسِ حِجُّ الْبَيْتِ مَنِ اسْتَطَاعَ إِلَيْهِ سَبِيلاً‏}‏‏.‏ قَالُوا يَا رَسُولَ اللَّهِ الْحَجُّ فِي كُلِّ عَامٍ فَسَكَتَ ثُمَّ قَالُوا أَفِي كُلِّ عَامٍ فَقَالَ ‏""‏ لاَ وَلَوْ قُلْتُ نَعَمْ لَوَجَبَتْ ‏""‏ ‏.‏ فَنَزَلَتْ ‏{‏يَا أَيُّهَا الَّذِينَ آمَنُوا لاَ تَسْأَلُوا عَنْ أَشْيَاءَ إِنْ تُبْدَ لَكُمْ تَسُؤْكُمْ ‏}‏‏.‏",Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۳۳۱۴، ومصباح الزجاجة:۹۲۹),2620,It was\nnarrated that ‘Ali said:,Chapters on Hajj Rituals
2621,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا مُحَمَّدُ بْنُ أَبِي عُبَيْدَةَ، عَنْ أَبِيهِ، عَنِ الأَعْمَشِ، عَنْ أَبِي سُفْيَانَ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ قَالُوا يَا رَسُولَ اللَّهِ الْحَجُّ فِي كُلِّ عَامٍ قَالَ ‏ ‏ لَوْ قُلْتُ نَعَمْ لَوَجَبَتْ وَلَوْ وَجَبَتْ لَمْ تَقُومُوا بِهَا وَلَوْ لَمْ تَقُومُوا بِهَا عُذِّبْتُمْ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن النسائی/تحریم الدم ۲ (۴۰۰۴)، القسامة ۴۸ (۴۸۷۰)،(تحفة الأشراف:۵۴۳۲)، وقد أخرجہ: مسند احمد (۱/۲۴۰،۳۶۴۲۹۴),,It was\nnarrated that Anas bin Malik said:,Chapters on Hajj Rituals
2622,"حَدَّثَنَا يَعْقُوبُ بْنُ إِبْرَاهِيمَ الدَّوْرَقِيُّ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، أَنْبَأَنَا سُفْيَانُ بْنُ حُسَيْنٍ، عَنِ الزُّهْرِيِّ، عَنْ أَبِي سِنَانٍ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ الأَقْرَعَ بْنَ حَابِسٍ، سَأَلَ النَّبِيَّ صلى الله عليه وسلم فَقَالَ يَا رَسُولَ اللَّهِ الْحَجُّ فِي كُلِّ سَنَةٍ أَوْ مَرَّةً وَاحِدَةً قَالَ ‏ ‏ بَلْ مَرَّةً وَاحِدَةً فَمَنِ اسْتَطَاعَ فَتَطَوُّعٌ ‏""""‏ ‏.‏""",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «حدیث أبي رافع تفر د بہ ابن ماجہ،(تحفة الأشراف:۱۹۵۰۵)، وحدیث أبي بکر بن أبي شیبة أخرجہ صحیح البخاری/احادیث الانبیاء ۵۴ (۳۴۷۰)، صحیح مسلم/التوبة ۸ (۶۷۶۶)،(تحفة الأشراف:۳۹۷۳)، وقد أخرجہ: مسند احمد (۳/۲۰،۷۲),,It was\nnarrated from Ibn ‘Abbas that Aqra’ bin Habis asked the\nProphet\n(ﷺ):,Chapters on Hajj Rituals
2623,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عَاصِمِ بْنِ عُبَيْدِ اللَّهِ، عَنْ عَبْدِ اللَّهِ بْنِ عَامِرٍ، عَنْ عُمَرَ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ تَابِعُوا بَيْنَ الْحَجِّ وَالْعُمْرَةِ فَإِنَّ الْمُتَابَعَةَ بَيْنَهُمَا تَنْفِي الْفَقْرَ وَالذُّنُوبَ كَمَا يَنْفِي الْكِيرُ خَبَثَ الْحَدِيدِ ‏""""‏ ‏.‏ حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ، حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ عُمَرَ، عَنْ عَاصِمِ بْنِ عُبَيْدِ اللَّهِ، عَنْ عَبْدِ اللَّهِ بْنِ عَامِرِ بْنِ رَبِيعَةَ، عَنْ أَبِيهِ، عَنْ عُمَرَ بْنِ الْخَطَّابِ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ نَحْوَهُ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الدیات ۳ (۴۴۹۶)،(تحفة الأشراف:۱۲۰۵۹)، وقد أخرجہ: مسند احمد (۴/۳۱)، سنن الدارمی/الدیات ۱ (۲۳۹۶),,It was\nnarrated from ‘Umar that the Prophet (ﷺ) said:,Chapters on Hajj Rituals
2624,"حَدَّثَنَا أَبُو مُصْعَبٍ، حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، عَنْ سُمَىٍّ، - مَوْلَى أَبِي بَكْرِ بْنِ عَبْدِ الرَّحْمَنِ - عَنْ أَبِي صَالِحٍ السَّمَّانِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ الْعُمْرَةُ إِلَى الْعُمْرَةِ كَفَّارَةُ مَا بَيْنَهُمَا وَالْحَجُّ الْمَبْرُورُ لَيْسَ لَهُ جَزَاءٌ إِلاَّ الْجَنَّةُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/العلم ۳۹ (۱۱۲)، اللقطة ۷ (۲۴۳۴)، الدیات ۸ (۶۸۸۰)، صحیح مسلم/الحج ۸۲ (۱۳۵۵)، سنن ابی داود/الدیات ۴ (۴۵۰۵)، سنن الترمذی/الدیات ۱۳ (۱۴۰۵)، سنن النسائی/القسامة ۲۴ (۴۷۸۹،۴۷۹۰)،(تحفة الأشراف:۱۵۳۸۳)، وقد أخرجہ: مسند احمد (۲/۲۳۸),,It was\nnarrated from Abu Hurairah that the Prophet (ﷺ) said:,Chapters on Hajj Rituals
2625,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا وَكِيعٌ، عَنْ مِسْعَرٍ، وَسُفْيَانَ، عَنْ مَنْصُورٍ، عَنْ أَبِي حَازِمٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ حَجَّ هَذَا الْبَيْتَ فَلَمْ يَرْفُثْ وَلَمْ يَفْسُقْ رَجَعَ كَمَا وَلَدَتْهُ أُمُّهُ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الدیات ۳ (۴۵۰۳)،(تحفة الأشراف:۳۸۲۴)، وقد أخرجہ: مسند احمد (۵/۱۱۲،۶/۱۰),,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Hajj Rituals
2626,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، عَنِ الرَّبِيعِ بْنِ صَبِيحٍ، عَنْ يَزِيدَ بْنِ أَبَانَ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ حَجَّ النَّبِيُّ ـ صلى الله عليه وسلم ـ عَلَى رَحْلٍ رَثٍّ وَقَطِيفَةٍ تُسَاوِي أَرْبَعَةَ دَرَاهِمَ أَوْ لاَ تُسَاوِي ثُمَّ قَالَ ‏ ‏ اللَّهُمَّ حِجَّةٌ لاَ رِيَاءَ فِيهَا وَلاَ سُمْعَةَ ‏""""‏ ‏.‏""",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الدیات ۱۸ (۴۵۴۱)، سنن الترمذی/الدیات ۱ (۱۳۸۷)،(تحفة الأشراف:۸۷۰۸)، وقد أخرجہ: مسند احمد (۲/۱۷۸،۱۸۲،۱۸۳،۱۸۴،۱۸۵،۱۸۶),,It was\nnarrated that Anas bin Malik said:,Chapters on Hajj Rituals
2627,"حَدَّثَنَا أَبُو بِشْرٍ، بَكْرُ بْنُ خَلَفٍ حَدَّثَنَا ابْنُ أَبِي عَدِيٍّ، عَنْ دَاوُدَ بْنِ أَبِي هِنْدٍ، عَنْ أَبِي الْعَالِيَةِ، عَنِ ابْنِ عَبَّاسٍ، قَالَ كُنَّا مَعَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ بَيْنَ مَكَّةَ وَالْمَدِينَةِ فَمَرَرْنَا بِوَادٍ فَقَالَ ‏""‏ أَىُّ وَادٍ هَذَا ‏""‏ ‏.‏ قَالُوا وَادِي الأَزْرَقِ ‏.‏ قَالَ ‏""‏ كَأَنِّي أَنْظُرُ إِلَى مُوسَى ـ صلى الله عليه وسلم ـ - فَذَكَرَ مِنْ طُولِ شَعَرِهِ شَيْئًا لاَ يَحْفَظُهُ دَاوُدُ - وَاضِعًا إِصْبَعَيْهِ فِي أُذُنَيْهِ لَهُ جُؤَارٌ إِلَى اللَّهِ بِالتَّلْبِيَةِ مَارًّا بِهَذَا الْوَادِي ‏""‏ ‏.‏ قَالَ ثُمَّ سِرْنَا حَتَّى أَتَيْنَا عَلَى ثَنِيَّةٍ فَقَالَ ‏""‏ أَىُّ ثَنِيَّةٍ هَذِهِ ‏""‏ ‏.‏ قَالُوا ثَنِيَّةُ هَرْشَى أَوْ لَفْتٍ ‏.‏ قَالَ ‏""‏ كَأَنِّي أَنْظُرُ إِلَى يُونُسَ عَلَى نَاقَةٍ حَمْرَاءَ عَلَيْهِ جُبَّةُ صُوفٍ وَخِطَامُ نَاقَتِهِ خُلْبَةٌ مَارًّا بِهَذَا الْوَادِي مُلَبِّيًا ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن النسائی/القسامة ۲۷ (۴۷۹۵)،(تحفة الأشراف:۸۹۱۱)، وقد أخرجہ: سنن ابی داود/الدیات ۱۹ (۴۵۴۷،۴۵۴۸)، مسند احمد (۱/۱۶۴،۱۶۶)، سنن الدارمی/الدیات ۲۲ (۲۴۲۸),2627,It was\nnarrated that Ibn ‘Abbas said:,Chapters on Hajj Rituals
2628,"حَدَّثَنَا إِبْرَاهِيمُ بْنُ الْمُنْذِرِ الْحِزَامِيُّ، حَدَّثَنَا صَالِحُ بْنُ عَبْدِ اللَّهِ بْنِ صَالِحٍ، - مَوْلَى بَنِي عَامِرٍ - حَدَّثَنِي يَعْقُوبُ بْنُ يَحْيَى بْنِ عَبَّادِ بْنِ عَبْدِ اللَّهِ بْنِ الزُّبَيْرِ، عَنْ أَبِي صَالِحٍ السَّمَّانِ، عَنْ أَبِي هُرَيْرَةَ، عَنْ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ أَنَّهُ قَالَ ‏ ‏ الْحُجَّاجُ وَالْعُمَّارُ وَفْدُ اللَّهِ إِنْ دَعَوْهُ أَجَابَهُمْ وَإِنِ اسْتَغْفَرُوهُ غَفَرَ لَهُمْ ‏""""‏ ‏.‏""",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الدیات ۱۹ (۴۵۴۹)، سنن النسائی/القسامة ۲۷ (۴۷۹۷)،(تحفة الأشراف:۷۳۷۲),,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Hajj Rituals
2629,"حَدَّثَنَا مُحَمَّدُ بْنُ طَرِيفٍ، حَدَّثَنَا عِمْرَانُ بْنُ عُيَيْنَةَ، عَنْ عَطَاءِ بْنِ السَّائِبِ، عَنْ مُجَاهِدٍ، عَنِ ابْنِ عُمَرَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ الْغَازِي فِي سَبِيلِ اللَّهِ وَالْحَاجُّ وَالْمُعْتَمِرُ وَفْدُ اللَّهِ دَعَاهُمْ فَأَجَابُوهُ وَسَأَلُوهُ فَأَعْطَاهُمْ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الدیات ۱۸ (۴۵۴۶)، سنن النسائی/القسامة ۲۹ (۴۸۰۷)، سنن الترمذی/الدیات ۲ (۱۳۸۸،۱۳۸۹)،(تحفة الأشراف:۶۱۶۵)، وقد أخرجہ: سنن الدارمی/الدیات ۱۱ (۴۸۰۸),,It was\nnarrated from Ibn ‘Umar that the Prophet (ﷺ) said:,Chapters on Hajj Rituals
2630,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا وَكِيعٌ، عَنْ سُفْيَانَ، عَنْ عَاصِمِ بْنِ عُبَيْدِ اللَّهِ، عَنْ سَالِمٍ، عَنِ ابْنِ عُمَرَ، عَنْ عُمَرَ، أَنَّهُ اسْتَأْذَنَ النَّبِيَّ ـ صلى الله عليه وسلم ـ فِي الْعُمْرَةِ فَأَذِنَ لَهُ وَقَالَ ‏ ‏ يَا أُخَىَّ أَشْرِكْنَا فِي شَىْءٍ مِنْ دُعَائِكَ وَلاَ تَنْسَنَا ‏""""‏ ‏.‏""",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الدیات ۴ (۴۵۰۶)، سنن النسائی/القسامة ۲۷ (۴۸۰۵)،(تحفة الأشراف:۸۷۰۹)، وقد أخرجہ: مسند احمد (۲/۱۸۳،۲۱۷،۲۲۴),,"It was\nnarrated from Ibn ‘Umar (from ‘Umar) that he asked the Prophet\n(ﷺ) for permission to perform ‘Umrah, and he gave him permission\nand\nsaid to him:",Chapters on Hajj Rituals
2631,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، عَنْ عَبْدِ الْمَلِكِ بْنِ أَبِي سُلَيْمَانَ، عَنْ أَبِي الزُّبَيْرِ، عَنْ صَفْوَانَ بْنِ عَبْدِ اللَّهِ بْنِ صَفْوَانَ، قَالَ وَكَانَتْ تَحْتَهُ ابْنَةُ أَبِي الدَّرْدَاءِ فَأَتَاهَا فَوَجَدَ أُمَّ الدَّرْدَاءِ وَلَمْ يَجِدْ أَبَا الدَّرْدَاءِ فَقَالَتْ لَهُ تُرِيدُ الْحَجَّ الْعَامَ قَالَ نَعَمْ ‏.‏ قَالَتْ فَادْعُ اللَّهَ لَنَا بِخَيْرٍ فَإِنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ كَانَ يَقُولُ ‏ ‏ دَعْوَةُ الْمَرْءِ مُسْتَجَابَةٌ لأَخِيهِ بِظَهْرِ الْغَيْبِ عِنْدَ رَأْسِهِ مَلَكٌ يُؤَمِّنُ عَلَى دُعَائِهِ كُلَّمَا دَعَا لَهُ بِخَيْرٍ قَالَ آمِينَ وَلَكَ بِمِثْلِهِ ‏""""‏ ‏.‏ قَالَ ثُمَّ خَرَجْتُ إِلَى السُّوقِ فَلَقِيتُ أَبَا الدَّرْدَاءِ فَحَدَّثَنِي عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ بِمِثْلِ ذَلِكَ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الدیات ۱۸ (۴۵۴۵)، سنن الترمذی/الدیات ۱ (۱۳۸۶)، سنن النسائی/القسامة ۲۸ (۴۸۰۶)،(تحفة الأشراف:۹۱۹۸)، وقد أخرجہ: مسند احمد (۱/۳۸۴،۴۵۰)، سنن الدارمی/الدیات ۱۳ (۲۴۱۲),,"It was\nnarrated from Safwan bin ‘Abdullah bin Safwan said that he was\nmarried to a daughter of Abu Darda’. He came to her and found Umm\nDarda’ there, but he did not find Abu Darda’. She said to him:",Chapters on Hajj Rituals
2632,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِيَةَ، ح وَحَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، وَعَمْرُو بْنُ عَبْدِ اللَّهِ، قَالاَ حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا إِبْرَاهِيمُ بْنُ يَزِيدَ الْمَكِّيُّ، عَنْ مُحَمَّدِ بْنِ عَبَّادِ بْنِ جَعْفَرٍ الْمَخْزُومِيِّ، عَنِ ابْنِ عُمَرَ، قَالَ قَامَ رَجُلٌ إِلَى النَّبِيِّ ـ صلى الله عليه وسلم ـ فَقَالَ يَا رَسُولَ اللَّهِ مَا يُوجِبُ الْحَجَّ قَالَ ‏""‏ الزَّادُ وَالرَّاحِلَةُ ‏""‏ ‏.‏ قَالَ يَا رَسُولَ اللَّهِ فَمَا الْحَاجُّ قَالَ ‏""‏ الشَّعِثُ التَّفِلُ ‏""‏ ‏.‏ وَقَامَ آخَرُ فَقَالَ يَا رَسُولَ اللَّهِ وَمَا الْحَجُّ قَالَ ‏""‏ الْعَجُّ وَالثَّجُّ ‏""‏ ‏.‏ قَالَ وَكِيعٌ يَعْنِي بِالْعَجِّ الْعَجِيجَ بِالتَّلْبِيَةِ وَالثَّجُّ نَحْرُ الْبُدْنِ ‏.‏",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Isnaad Hasan,takhreej: «أنظر رقم:(۲۶۲۹),2632,It was\nnarrated that Ibn ‘Umar said:,Chapters on Hajj Rituals
2633,"حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، حَدَّثَنَا هِشَامُ بْنُ سُلَيْمَانَ الْقُرَشِيُّ، عَنِ ابْنِ جُرَيْجٍ، قَالَ وَأَخْبَرَنِيهِ أَيْضًا، عَنِ ابْنِ عَطَاءٍ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏""‏ الزَّادُ وَالرَّاحِلَةُ ‏""‏ ‏.‏ يَعْنِي قَوْلَهُ ‏{‏ مَنِ اسْتَطَاعَ إِلَيْهِ سَبِيلاً ‏}‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/القسامة ۱۱ (۱۶۸۲)، سنن ابی داود/الدیات ۲۱ (۴۵۶۸)، سنن الترمذی/الدیات ۱۵ (۱۴۱۱)، سنن النسائی/القسامة،۳۳ (۴۸۲۵)،(تحفة الأشراف:۱۱۵۱۰)، وقد أخرجہ: صحیح البخاری/الدیات ۲۵ (۶۹۱۰)، الاعتصام ۱۳ (۷۳۱۷)، مسند احمد (۴/۲۲۴،۲۴۵،۲۴۶،۲۴۹)، سنن الدارمی/الدیات ۲۰ (۲۴۲۵),2633,It was\nnarrated from Ibn ‘Abbas that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Hajj Rituals
2634,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا الأَعْمَشُ، عَنْ أَبِي صَالِحٍ، عَنْ أَبِي سَعِيدٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لاَ تُسَافِرُ الْمَرْأَةُ سَفَرَ ثَلاَثَةِ أَيَّامٍ فَصَاعِدًا إِلاَّ مَعَ أَبِيهَا أَوْ أَخِيهَا أَوِ ابْنِهَا أَوْ زَوْجِهَا أَوْ ذِي مَحْرَمٍ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الفرائض ۸ (۲۸۹۹،۲۹۰۰)،(تحفة الأشراف:۱۱۵۶۹)، وقد أخرجہ: مسند احمد (۴/۱۳۱،۱۳۳),,It was\nnarrated from Abu Sa’eed that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Hajj Rituals
2635,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا شَبَابَةُ، عَنِ ابْنِ أَبِي ذِئْبٍ، عَنْ سَعِيدٍ الْمَقْبُرِيِّ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ لاَ يَحِلُّ لاِمْرَأَةٍ تُؤْمِنُ بِاللَّهِ وَالْيَوْمِ الآخِرِ أَنْ تُسَافِرَ مَسِيرَةَ يَوْمٍ وَاحِدٍ لَيْسَ لَهَا ذُو حُرْمَةٍ ‏""""‏ ‏.‏""",Muhammad Fouad Abd al-Baqi: Batil; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن ابی داود/الدیات ۱۷ (۴۵۳۹مرسلاً)،۲۸ (۴۵۹۱)، سنن النسائی/القسامة ۲۶ (۴۷۹۳)،(تحفة الأشراف:۵۷۳۹),,It was\nnarrated from Abu Hurairah that the Prophet (ﷺ) said:,Chapters on Hajj Rituals
2636,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا شُعَيْبُ بْنُ إِسْحَاقَ، حَدَّثَنَا ابْنُ جُرَيْجٍ، حَدَّثَنِي عَمْرُو بْنُ دِينَارٍ، أَنَّهُ سَمِعَ أَبَا مَعْبَدٍ، مَوْلَى ابْنِ عَبَّاسٍ عَنِ ابْنِ عَبَّاسٍ، قَالَ جَاءَ أَعْرَابِيٌّ إِلَى النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ إِنِّي اكْتُتِبْتُ فِي غَزْوَةِ كَذَا وَكَذَا وَامْرَأَتِي حَاجَّةٌ ‏.‏ قَالَ ‏ ‏ فَارْجِعْ مَعَهَا ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۱۸۰، ومصباح الزجاجة:۹۳۰),,It was\nnarrated that Ibn ‘Abbas said:,Chapters on Hajj Rituals
2637,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا مُحَمَّدُ بْنُ فُضَيْلٍ، عَنْ حَبِيبِ بْنِ أَبِي عَمْرَةَ، عَنْ عَائِشَةَ بِنْتِ طَلْحَةَ، عَنْ عَائِشَةَ، قَالَتْ قُلْتُ يَا رَسُولَ اللَّهِ عَلَى النِّسَاءِ جِهَادٌ قَالَ ‏ ‏ نَعَمْ عَلَيْهِنَّ جِهَادٌ لاَ قِتَالَ فِيهِ الْحَجُّ وَالْعُمْرَةُ ‏""""‏ ‏.‏""",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۱۳۹، ومصباح الزجاجة:۹۳۱),,It was\nnarrated that ‘Aishah said:,Chapters on Hajj Rituals
2638,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا وَكِيعٌ، عَنِ الْقَاسِمِ بْنِ الْفَضْلِ الْحُدَّانِيِّ، عَنْ أَبِي جَعْفَرٍ، عَنْ أُمِّ سَلَمَةَ، قَالَتْ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ الْحَجُّ جِهَادُ كُلِّ ضَعِيفٍ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الدیات ۱۳ (۴۵۳۴)، سنن النسائی/القسامة ۲۰ (۴۷۸۲)،(تحفة الأشراف:۱۶۶۳۶)، وقد أخرجہ: مسند احمد (۶/۲۳۲),,It was\nnarrated from Umm Salamah that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Hajj Rituals
2639,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا عَبْدَةُ بْنُ سُلَيْمَانَ، عَنْ سَعِيدٍ، عَنْ قَتَادَةَ، عَنْ عَزْرَةَ، عَنْ سَعِيدِ بْنِ جُبَيْرٍ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ سَمِعَ رَجُلاً يَقُولُ لَبَّيْكَ عَنْ شُبْرُمَةَ ‏.‏ فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏""‏ مَنْ شُبْرُمَةُ ‏""‏ ‏.‏ قَالَ قَرِيبٌ لِي ‏.‏ قَالَ ‏""‏ هَلْ حَجَجْتَ قَطُّ ‏""‏ ‏.‏ قَالَ لاَ ‏.‏ قَالَ ‏""‏ فَاجْعَلْ هَذِهِ عَنْ نَفْسِكَ ثُمَّ احْجُجْ عَنْ شُبْرُمَةَ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۵۰۹۶)، وقد أخرجہ: صحیح البخاری/الطب ۴۶ (۵۷۵۸)، الفرائض ۱۱ (۵۷۵۹)، الدیات ۲۵ (۶۹۰۹)،۲۶ (۶۹۱۰)، صحیح مسلم/القسامة ۱۱ (۱۶۸۱)، سنن ابی داود/الدیات ۲۱ (۴۵۷۶)، سنن الترمذی/الدیات ۱۵ (۱۴۱۰)، الفرائض ۱۹ (۲۱۱۱)، سنن النسائی/القسامة ۳۳ (۴۸۲۲)، موطا امام مالک/العقول ۷ (۵)، مسند احمد (۲/۲۳۶،۲۷۴،۴۹۸،۵۳۹)، سنن الدارمی/الدیات ۲۰ (۲۴۲۵),2639,It was\nnarrated from Ibn ‘Abbas that the Messenger of Allah (ﷺ)\nheard a\nman saying:,Chapters on Hajj Rituals
2640,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الأَعْلَى الصَّنْعَانِيُّ، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَنْبَأَنَا سُفْيَانُ الثَّوْرِيُّ، عَنْ سُلَيْمَانَ الشَّيْبَانِيِّ، عَنْ يَزِيدَ بْنِ الأَصَمِّ، عَنِ ابْنِ عَبَّاسٍ، قَالَ جَاءَ رَجُلٌ إِلَى النَّبِيِّ ـ صلى الله عليه وسلم ـ فَقَالَ أَحُجُّ عَنْ أَبِي قَالَ ‏ ‏ نَعَمْ حُجَّ عَنْ أَبِيكَ فَإِنْ لَمْ تَزِدْهُ خَيْرًا لَمْ تَزِدْهُ شَرًّا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/القسامة ۲ (۱۶۸۹)، سنن ابی داود/الدیات ۲۱ (۴۵۷۰)،(تحفة الأشراف:۱۱۲۳۳،۱۱۵۲۹)، وقد أخرجہ: مسند احمد (۴/۲۵۳)، سنن الدارمی/المقدمة ۵۴ (۶۶۸)، الدیات ۲۰ (۲۴۲۶),,It was\nnarrated that Ibn ‘Abbas said:,Chapters on Hajj Rituals
2641,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، حَدَّثَنَا عُثْمَانُ بْنُ عَطَاءٍ، عَنْ أَبِيهِ، عَنْ أَبِي الْغَوْثِ بْنِ حُصَيْنٍ، - رَجُلٌ مِنَ الْفُرْعِ - أَنَّهُ اسْتَفْتَى النَّبِيَّ ـ صلى الله عليه وسلم ـ عَنْ حِجَّةٍ كَانَتْ عَلَى أَبِيهِ مَاتَ وَلَمْ يَحُجَّ قَالَ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏""‏ حُجَّ عَنْ أَبِيكَ ‏""‏ ‏.‏ وَقَالَ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏""‏ وَكَذَلِكَ الصِّيَامُ فِي النَّذْرِ يُقْضَى عَنْهُ ‏""‏ ‏.‏",Al-Albani: Sahih Isnaad; Muhammad Fouad Abd al-Baqi: Sahih Isnaad; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن ابی داود/الدیات ۲۱ (۴۵۷۲)، سنن النسائی/القسامة ۳۳ (۴۸۲۰)،(تحفة الأشراف:۳۴۴۴)، وقد أخرجہ: مسند احمد (۱/۳۶۴،۴/۷۹، سنن الدارمی/الدیات ۲۱ (۲۴۲۷),2641,"It was\nnarrated from Abu Ghawth bin Husain – a man from Furu’ – that\nhe consulted the Prophet (ﷺ) about a Hajj that his father owed, but\nhe had died and had not gone for Hajj. The Prophet (ﷺ) said:",Chapters on Hajj Rituals
2642,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا وَكِيعٌ، عَنْ شُعْبَةَ، عَنِ النُّعْمَانِ بْنِ سَالِمٍ، عَنْ عَمْرِو بْنِ أَوْسٍ، عَنْ أَبِي رَزِينٍ الْعُقَيْلِيِّ، أَنَّهُ أَتَى النَّبِيَّ ـ صلى الله عليه وسلم ـ فَقَالَ يَا رَسُولَ اللَّهِ إِنَّ أَبِي شَيْخٌ كَبِيرٌ لاَ يَسْتَطِيعُ الْحَجَّ وَلاَ الْعُمْرَةَ وَلاَ الظَّعَنَ ‏.‏ قَالَ ‏ ‏ حُجَّ عَنْ أَبِيكَ وَاعْتَمِرْ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الفرائض ۱۸ (۲۹۲۷)، سنن الترمذی/الدیات ۱۹ (۱۴۱۵)، الفرائض ۱۸ (۲۱۱۰)،(تحفة الأشراف:۴۹۷۳)، وقد أخرجہ: موطا امام مالک/العقول ۱۷ (۱۰)، مسند احمد (۳/۴۵۲),,It was\nnarrated from Abu Razin Al-‘Uqaili that he came to the Prophet\n(ﷺ) and said:,Chapters on Hajj Rituals
2643,"حَدَّثَنَا أَبُو مَرْوَانَ، مُحَمَّدُ بْنُ عُثْمَانَ الْعُثْمَانِيُّ حَدَّثَنَا عَبْدُ الْعَزِيزِ الدَّرَاوَرْدِيُّ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْحَارِثِ بْنِ عَيَّاشِ بْنِ أَبِي رَبِيعَةَ الْمَخْزُومِيِّ، عَنْ حَكِيمِ بْنِ حَكِيمِ بْنِ عَبَّادِ بْنِ حُنَيْفٍ الأَنْصَارِيِّ، عَنْ نَافِعِ بْنِ جُبَيْرٍ، عَنْ عَبْدِ اللَّهِ بْنِ عَبَّاسٍ، أَنَّ امْرَأَةً، مِنْ خَثْعَمٍ جَاءَتِ النَّبِيَّ ـ صلى الله عليه وسلم ـ فَقَالَتْ يَا رَسُولَ اللَّهِ إِنَّ أَبِي شَيْخٌ كَبِيرٌ قَدْ أَفْنَدَ وَأَدْرَكَتْهُ فَرِيضَةُ اللَّهِ عَلَى عِبَادِهِ فِي الْحَجِّ وَلاَ يَسْتَطِيعُ أَدَاءَهَا فَهَلْ يُجْزِئُ عَنْهُ أَنْ أُؤَدِّيَهَا عَنْهُ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ نَعَمْ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih Lighairihi; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۰۶۴، ومصباح الزجاجة:۹۳۲)، وقد أخرجہ: مسند احمد (۴/۷۹),,It was\nnarrated from ‘Abdullah bin ‘Abbas that a woman from Khath’am\ncame to the Prophet (ﷺ) and said:,Chapters on Hajj Rituals
2644,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ، حَدَّثَنَا مُحَمَّدُ بْنُ كُرَيْبٍ، عَنْ أَبِيهِ، عَنِ ابْنِ عَبَّاسٍ، قَالَ أَخْبَرَنِي حُصَيْنُ بْنُ عَوْفٍ، قَالَ قُلْتُ يَا رَسُولَ اللَّهِ إِنَّ أَبِي أَدْرَكَهُ الْحَجُّ وَلاَ يَسْتَطِيعُ أَنْ يَحُجَّ إِلاَّ مُعْتَرِضًا ‏.‏ فَصَمَتَ سَاعَةً ثُمَّ قَالَ ‏ ‏ حُجَّ عَنْ أَبِيكَ ‏""""‏ ‏.‏""",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۷۳۸، ومصباح الزجاجة:۹۳۳)، وقد أخرجہ: سنن الترمذی/الدیات ۱۷ (۱۴۱۳)، سنن النسائی/القسامة ۳۱ (۴۸۱۰),,It was\nnarrated that Ibn ‘Abbas said:,Chapters on Hajj Rituals
2645,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ الدِّمَشْقِيُّ، حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، حَدَّثَنَا الأَوْزَاعِيُّ، عَنِ الزُّهْرِيِّ، عَنْ سُلَيْمَانَ بْنِ يَسَارٍ، عَنِ ابْنِ عَبَّاسٍ، عَنْ أَخِيهِ الْفَضْلِ، أَنَّهُ كَانَ رِدْفَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ غَدَاةَ النَّحْرِ فَأَتَتْهُ امْرَأَةٌ مِنْ خَثْعَمٍ فَقَالَتْ يَا رَسُولَ اللَّهِ إِنَّ فَرِيضَةَ اللَّهِ فِي الْحَجِّ عَلَى عِبَادِهِ أَدْرَكَتْ أَبِي شَيْخًا كَبِيرًا لاَ يَسْتَطِيعُ أَنْ يَرْكَبَ أَفَأَحُجُّ عَنْهُ قَالَ ‏ ‏ نَعَمْ فَإِنَّهُ لَوْ كَانَ عَلَى أَبِيكِ دَيْنٌ قَضَيْتِيهِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Hasan,takhreej: «سنن الترمذی/الفرائض ۱۷ (۲۱۰۹)،(تحفة الأشراف:۱۲۲۸۶)(یہ حدیث مکرر ہے، دیکھئے:۲۷۳۵),,"It was\nnarrated from Ibn ‘Abbas that his brother Fadl was riding\nbehind\nthe Messenger of Allah (ﷺ) in the morning of sacrifice (i.e.,\nthe\n10th of Dhul-Hijjah), when a woman from Khath’am came\nand said:",Chapters on Hajj Rituals
2646,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، وَمُحَمَّدُ بْنُ طَرِيفٍ، قَالاَ حَدَّثَنَا أَبُو مُعَاوِيَةَ، حَدَّثَنِي مُحَمَّدُ بْنُ سُوقَةَ، عَنْ مُحَمَّدِ بْنِ الْمُنْكَدِرِ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، قَالَ رَفَعَتِ امْرَأَةٌ صَبِيًّا لَهَا إِلَى النَّبِيِّ ـ صلى الله عليه وسلم ـ فِي حَجَّتِهِ فَقَالَتْ يَا رَسُولَ اللَّهِ أَلِهَذَا حَجٌّ قَالَ ‏ ‏ نَعَمْ وَلَكِ أَجْرٌ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۵۶۵۴، ومصباح الزجاجة:۹۳۴)، وقد أخرجہ: مسند احمد (۱/۴۹)، موطا امام مالک/العقول ۱۷ (۱۰),,It was\nnarrated that Jabir bin ‘Abdullah said:,Chapters on Hajj Rituals
2647,حَدَّثَنَا عُثْمَانُ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدَةُ بْنُ سُلَيْمَانَ، عَنْ عُبَيْدِ اللَّهِ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، قَالَتْ نُفِسَتْ أَسْمَاءُ بِنْتُ عُمَيْسٍ بِالشَّجَرَةِ فَأَمَرَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ أَبَا بَكْرٍ أَنْ يَأْمُرَهَا أَنْ تَغْتَسِلَ وَتُهِلَّ ‏.‏,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأ شراف:۸۷۱۵،)، وقد أخرجہ: سنن النسائی/القسامة ۳۰ (۴۸۰۹),2647,It was\nnarrated that ‘Aishah said:,Chapters on Hajj Rituals
2648,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ، عَنْ سُلَيْمَانَ بْنِ بِلاَلٍ، حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، أَنَّهُ سَمِعَ الْقَاسِمَ بْنَ مُحَمَّدٍ، يُحَدِّثُ عَنْ أَبِيهِ، عَنْ أَبِي بَكْرٍ، أَنَّهُ خَرَجَ حَاجًّا مَعَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ وَمَعَهُ أَسْمَاءُ بِنْتُ عُمَيْسٍ فَوَلَدَتْ بِالشَّجَرَةِ مُحَمَّدَ بْنَ أَبِي بَكْرٍ فَأَتَى أَبُو بَكْرٍ النَّبِيَّ ـ صلى الله عليه وسلم ـ فَأَخْبَرَهُ فَأَمَرَهُ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ أَنْ يَأْمُرَهَا أَنْ تَغْتَسِلَ ثُمَّ تُهِلَّ بِالْحَجِّ وَتَصْنَعَ مَا يَصْنَعُ النَّاسُ إِلاَّ أَنَّهَا لاَ تَطُوفُ بِالْبَيْتِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الدیات ۲۱ (۴۵۷۵)،(تحفة الأشراف:۲۳۴۷),2648,,Chapters on Hajj Rituals
2649,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا يَحْيَى بْنُ آدَمَ، عَنْ سُفْيَانَ، عَنْ جَعْفَرِ بْنِ مُحَمَّدٍ، عَنْ أَبِيهِ، عَنْ جَابِرٍ، قَالَ نُفِسَتْ أَسْمَاءُ بِنْتُ عُمَيْسٍ بِمُحَمَّدِ بْنِ أَبِي بَكْرٍ فَأَرْسَلَتْ إِلَى النَّبِيِّ ـ صلى الله عليه وسلم ـ فَأَمَرَهَا أَنْ تَغْتَسِلَ وَتَسْتَثْفِرَ بِثَوْبٍ وَتُهِلَّ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشرف:۶۴۶،۷۶۰)، وقد أخرجہ: صحیح البخاری/الصلح ۸ (۲۷۰۳)، تفسیر البقرة ۲۳ (۴۴۹۹)، المائدة ۶ (۴۶۱۱)، الدیات ۱۹ (۶۸۹۴)، صحیح مسلم/القسامة ۵ (۱۶۷۵)، سنن ابی داود/الدیات ۳۲ (۴۵۹۵)، سنن النسائی/القسامة ۱۲ (۴۷۵۹)، مسند احمد (۳/۱۲۸،۱۶۷،۲۸۴),2649,It was\nnarrated that Jabir said:,Chapters on Hajj Rituals
2650,"حَدَّثَنَا أَبُو مُصْعَبٍ، حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏""‏ يُهِلُّ أَهْلُ الْمَدِينَةِ مِنْ ذِي الْحُلَيْفَةِ وَأَهْلُ الشَّامِ مِنَ الْجُحْفَةِ وَأَهْلُ نَجْدٍ مِنْ قَرْنٍ ‏""‏ ‏.‏ فَقَالَ عَبْدُ اللَّهِ أَمَّا هَذِهِ الثَّلاَثَةُ فَقَدْ سَمِعْتُهَا مِنْ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ وَبَلَغَنِي أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏""‏ وَيُهِلُّ أَهْلُ الْيَمَنِ مِنْ يَلَمْلَمَ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن ابی داود/الدیات ۲۰ (۴۵۵۹)، سنن الترمذی/الدیات ۴ (۱۳۹۱)،(تحفة الأشراف:۶۱۹۳),2650,It was\nnarrated from Ibn ‘Umar that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Hajj Rituals
2651,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا إِبْرَاهِيمُ بْنُ يَزِيدَ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، قَالَ خَطَبَنَا رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ فَقَالَ ‏""‏ مُهَلُّ أَهْلِ الْمَدِينَةِ مِنْ ذِي الْحُلَيْفَةِ وَمُهَلُّ أَهْلِ الشَّامِ مِنَ الْجُحْفَةِ وَمُهَلُّ أَهْلِ الْيَمَنِ مِنْ يَلَمْلَمَ وَمُهَلُّ أَهْلِ نَجْدٍ مِنْ قَرْنٍ وَمُهَلُّ أَهْلِ الْمَشْرِقِ مِنْ ذَاتِ عِرْقٍ ‏""‏ ‏.‏ ثُمَّ أَقْبَلَ بِوَجْهِهِ لِلأُفُقِ ثُمَّ قَالَ ‏""‏ اللَّهُمَّ أَقْبِلْ بِقُلُوبِهِمْ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۲۷۴، ومصباح الزجاجة:۹۳۵)، وقد أخرجہ: سنن الترمذی/الدیات ۴ (۱۳۹۱),2651,It was\nnarrated that Jabir said:,Chapters on Hajj Rituals
2652,حَدَّثَنَا مُحْرِزُ بْنُ سَلَمَةَ الْعَدَنِيُّ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ الدَّرَاوَرْدِيُّ، حَدَّثَنِي عُبَيْدُ اللَّهِ بْنُ عُمَرَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ كَانَ إِذَا أَدْخَلَ رِجْلَهُ فِي الْغَرْزِ وَاسْتَوَتْ بِهِ رَاحِلَتُهُ أَهَلَّ مِنْ عِنْدِ مَسْجِدِ ذِي الْحُلَيْفَةِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الدیات ۲۰ (۶۸۹۵)، سنن ابی داود/الدیات ۲۰ (۴۵۵۸)، سنن الترمذی/الدیات ۴ (۱۳۹۲)، سنن النسائی/القسامة ۳۸ (۴۸۵۱)،(تحفة الأشراف:۶۱۸۷)، وقد أخرجہ: مسند احمد (۱/۳۳۹)، سنن الدارمی/الدیات ۱۵ (۲۴۱۵),2652,,Chapters on Hajj Rituals
2653,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ الدِّمَشْقِيُّ، حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، وَعُمَرُ بْنُ عَبْدِ الْوَاحِدِ، قَالاَ حَدَّثَنَا الأَوْزَاعِيُّ، عَنْ أَيُّوبَ بْنِ مُوسَى، عَنْ عَبْدِ اللَّهِ بْنِ عُبَيْدِ بْنِ عُمَيْرٍ، عَنْ ثَابِتٍ الْبُنَانِيِّ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ إِنِّي عِنْدَ ثَفِنَاتِ نَاقَةِ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ عِنْدَ الشَّجَرَةِ فَلَمَّا اسْتَوَتْ بِهِ قَائِمَةً قَالَ ‏ ‏ لَبَّيْكَ بِعُمْرَةٍ وَحَجَّةٍ مَعًا ‏""""‏ ‏.‏ وَذَلِكَ فِي حَجَّةِ الْوَدَاعِ ‏.‏""",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۸۰۸)، وقد أخرجہ: سنن ابی داود/الدیات ۲۰ (۴۵۵۶)، سنن النسائی/القسامة ۳۸ (۴۸۴۷)، مسند احمد (۲/۲۰۷)، سنن الدارمی/الدیات ۱۵ (۲۴۱۴),,It was\nnarrated that Anas bin Malik said:,Chapters on Hajj Rituals
2654,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، وَأَبُو أُسَامَةَ وَعَبْدُ اللَّهِ بْنُ نُمَيْرٍ عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ تَلَقَّفْتُ التَّلْبِيَةَ مِنْ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ وَهُوَ يَقُولُ ‏ ‏ لَبَّيْكَ اللَّهُمَّ لَبَّيْكَ لَبَّيْكَ لاَ شَرِيكَ لَكَ لَبَّيْكَ إِنَّ الْحَمْدَ وَالنِّعْمَةَ لَكَ وَالْمُلْكَ لاَ شَرِيكَ لَكَ ‏""""‏ ‏.‏ قَالَ وَكَانَ ابْنُ عُمَرَ يَزِيدُ فِيهَا لَبَّيْكَ لَبَّيْكَ لَبَّيْكَ وَسَعْدَيْكَ وَالْخَيْرُ فِي يَدَيْكَ لَبَّيْكَ وَالرَّغْبَاءُ إِلَيْكَ وَالْعَمَلُ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن ابی داود/الدیات ۲۰ (۴۵۵۶،۴۵۵۷)، سنن النسائی/القسامة ۳۸ (۴۸۴۷)،(تحفة الأشراف:۹۰۳۰),,"It was\nnarrated from Nafi’, that Ibn ‘Umar said:",Chapters on Hajj Rituals
2655,"حَدَّثَنَا زَيْدُ بْنُ أَخْزَمَ، حَدَّثَنَا مُؤَمَّلُ بْنُ إِسْمَاعِيلَ، حَدَّثَنَا سُفْيَانُ، عَنْ جَعْفَرِ بْنِ مُحَمَّدٍ، عَنْ أَبِيهِ، عَنْ جَابِرٍ، قَالَ كَانَتْ تَلْبِيَةُ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لَبَّيْكَ اللَّهُمَّ لَبَّيْكَ لَبَّيْكَ لاَ شَرِيكَ لَكَ لَبَّيْكَ إِنَّ الْحَمْدَ وَالنِّعْمَةَ لَكَ وَالْمُلْكَ لاَ شَرِيكَ لَكَ ‏""""‏ ‏.‏""",Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۸۰۷)، وقد أخرجہ: سنن ابی داود/الدیات ۲۰ (۴۵۶۶)، سنن الترمذی/الدیات ۳ (۱۳۹۰)، سنن النسائی/القسامة ۴۰ (۴۸۶۱)، مسند احمد (۲/۱۷۷۹،۱۸۹،۲۰۷،۲۱۲)، سنن الدارمی/الدیات ۱۶ (۲۴۱۷),,It was\nnarrated that Jabir said:,Chapters on Hajj Rituals
2656,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ عَبْدِ اللَّهِ بْنِ أَبِي سَلَمَةَ، عَنْ عَبْدِ اللَّهِ بْنِ الْفَضْلِ، عَنِ الأَعْرَجِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ فِي تَلْبِيَتِهِ ‏ ‏ لَبَّيْكَ إِلَهَ الْحَقِّ لَبَّيْكَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن النسائی/القسامة ۱۵ (۴۷۷۴،۴۷۷۵،۴۷۷۶)،(تحفة الأشراف:۱۱۸۳۵،۴۵۵۴)، وقد أخرجہ: صحیح البخاری/جزاء الصید ۱۹ (۱۸۴۷)، الإجارة ۵ (۲۲۶۵)، الجہاد ۱۲۰ (۲۹۷۳)، المغازي ۷۸ (۴۴۱۷)، الدیات ۱۸ (۶۸۹۳)، صحیح مسلم/القسامة ۴ (۱۶۷۳)، سنن ابی داود/الدیات ۲۴ (۴۵۸۴)، مسند احمد (۴/۲۲۲،۲۲۳،۲۲۴),,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nused to\nsay in his Talbiyah:,Chapters on Hajj Rituals
2657,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ عَيَّاشٍ، حَدَّثَنَا عُمَارَةُ بْنُ غَزِيَّةَ الأَنْصَارِيُّ، عَنْ أَبِي حَازِمٍ، عَنْ سَهْلِ بْنِ سَعْدٍ السَّاعِدِيِّ، عَنْ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ مَا مِنْ مُلَبٍّ يُلَبِّي إِلاَّ لَبَّى مَا عَنْ يَمِينِهِ وَشِمَالِهِ مِنْ حَجَرٍ أَوْ شَجَرٍ أَوْ مَدَرٍ حَتَّى تَنْقَطِعَ الأَرْضُ مِنْ هَا هُنَا وَهَا هُنَا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الدیات ۱۸ (۶۸۹۲)، صحیح مسلم/القسامة ۴ (۱۶۷۳)، سنن الترمذی/الدیات ۲۰ (۱۴۱۶)، سنن النسائی/القسامة ۱۴ (۴۷۶۳)،(تحفة الأشراف:۱۰۸۲۳)، وقد أخرجہ: مسند احمد (۴/۴۲۷،۴۳۸،۴۳۰،۴۳۵)، سنن الدارمی/الدیات ۱۸ (۲۴۲۱),,It was\nnarrated from Sahl bin Sa’d As-Sa’idi that the Messenger of\nAllah\n(ﷺ) said:,Chapters on Hajj Rituals
2658,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عَبْدِ اللَّهِ بْنِ أَبِي بَكْرٍ، عَنْ عَبْدِ الْمَلِكِ بْنِ أَبِي بَكْرِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ الْحَارِثِ بْنِ هِشَامٍ، حَدَّثَهُ عَنْ خَلاَّدِ بْنِ السَّائِبِ، عَنْ أَبِيهِ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ أَتَانِي جِبْرِيلُ فَأَمَرَنِي أَنْ آمُرَ أَصْحَابِي أَنْ يَرْفَعُوا أَصْوَاتَهُمْ بِالإِهْلاَلِ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/العلم ۴۰ (۱۱۱)، الجہاد ۱۷۱ (۳۰۴۷)، الدیات ۲۴ (۶۹۰۳)، سنن الترمذی/الدیات ۱۶ (۱۴۱۲)،(تحفة الأشراف:۱۰۳۱۱)، وقد أخرجہ: سنن ابی داود/الدیات۱۱ (۴۵۳۰)، سنن النسائی/القسامة ۵ (۴۷۳۸)، مسند احمد (۱/۷۹،۱۲۲)، سنن الدارمی/الدیات ۵ (۲۴۰۱),,"It was\nnarrated from Khallad bin Sa’ib, from his father, that the\nMessenger of Allah (ﷺ) said:",Chapters on Hajj Rituals
2659,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا سُفْيَانُ، عَنْ عَبْدِ اللَّهِ بْنِ أَبِي لَبِيدٍ، عَنِ الْمُطَّلِبِ بْنِ عَبْدِ اللَّهِ بْنِ حَنْطَبٍ، عَنْ خَلاَّدِ بْنِ السَّائِبِ، عَنْ زَيْدِ بْنِ خَالِدٍ الْجُهَنِيِّ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ جَاءَنِي جِبْرِيلُ فَقَالَ يَا مُحَمَّدُ مُرْ أَصْحَابَكَ فَلْيَرْفَعُوا أَصْوَاتَهُمْ بِالتَّلْبِيَةِ فَإِنَّهَا مِنْ شِعَارِ الْحَجِّ ‏""""‏ ‏.‏""",Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «سنن الترمذی/الدیات ۱۷ (۱۴۱۳)،(تحفة الأشراف:۸۷۳۹ ألف),,It was\nnarrated from Zaid bin Khalid Al-Juhani that the Messenger of\nAllah\n(ﷺ) said:,Chapters on Hajj Rituals
2660,"حَدَّثَنَا إِبْرَاهِيمُ بْنُ الْمُنْذِرِ الْحِزَامِيُّ، وَيَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، قَالاَ حَدَّثَنَا ابْنُ أَبِي فُدَيْكٍ، عَنِ الضَّحَّاكِ بْنِ عُثْمَانَ، عَنْ مُحَمَّدِ بْنِ الْمُنْكَدِرِ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ يَرْبُوعٍ، عَنْ أَبِي بَكْرٍ الصِّدِّيقِ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ سُئِلَ أَىُّ الأَعْمَالِ أَفْضَلُ قَالَ ‏ ‏ الْعَجُّ وَالثَّجُّ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۰۳۰، ومصباح الزجاجة:۹۳۷)(وستأتي بقیتہ برقم:۲۶۸۳),,It was\nnarrated from Abu Bakr As-Siddiq that the Messenger of Allah\n(ﷺ)\nwas asked:,Chapters on Hajj Rituals
2661,"حَدَّثَنَا إِبْرَاهِيمُ بْنُ الْمُنْذِرِ الْحِزَامِيُّ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نَافِعٍ، وَعَبْدُ اللَّهِ بْنُ وَهْبٍ، وَمُحَمَّدُ بْنُ فُلَيْحٍ، قَالُوا حَدَّثَنَا عَاصِمُ بْنُ عُمَرَ بْنِ حَفْصٍ، عَنْ عَاصِمِ بْنِ عُبَيْدِ اللَّهِ، عَنْ عَبْدِ اللَّهِ بْنِ عَامِرِ بْنِ رَبِيعَةَ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَا مِنْ مُحْرِمٍ يَضْحَى لِلَّهِ يَوْمَهُ يُلَبِّي حَتَّى تَغِيبَ الشَّمْسُ إِلاَّ غَابَتْ بِذُنُوبِهِ فَعَادَ كَمَا وَلَدَتْهُ أُمُّهُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/الدیات ۹ (۱۴۰۱)،(تحفة الأشراف:۵۷۴۰)، وقد أخرجہ: سنن الدارمی/الدیات ۶ (۲۴۰۲),,It was\nnarrated from Jabir bin ‘Abdullah that the Messenger of Allah\n(ﷺ)\nsaid:,Chapters on Hajj Rituals
2662,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ح وَحَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، جَمِيعًا عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، أَنَّهَا قَالَتْ طَيَّبْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ لإِحْرَامِهِ قَبْلَ أَنْ يُحْرِمَ وَلِحِلِّهِ قَبْلَ أَنْ يُفِيضَ - قَالَ سُفْيَانُ - بِيَدَىَّ هَاتَيْنِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/الدیات ۹ (۱۴۰۰)،(تحفة الأشراف:۱۰۵۸۲)، وقد أخرجہ: مسند احمد (۱/۲۲،۴۹),2662,It was\nnarrated that ‘Aishah said:,Chapters on Hajj Rituals
2663,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا الأَعْمَشُ، عَنْ أَبِي الضُّحَى، عَنْ مَسْرُوقٍ، عَنْ عَائِشَةَ، قَالَتْ كَأَنِّي أَنْظُرُ إِلَى وَبِيصِ الطِّيبِ فِي مَفَارِقِ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ وَهُوَ يُلَبِّي ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Hasan,takhreej: «سنن ابی داود/الدیات ۷ (۴۵۱۵،۴۵۱۶،۴۵۱۷)، سنن الترمذی/الدیات ۱۸ (۱۴۱۴)، سنن النسائی/القسامة ۶ (۴۷۴۰)،۷ (۴۷۴۳)،۱۲ (۴۷۵۷)،(تحفة الأشراف:۴۵۸۶، ومصباح الزجاجة:۹۳۶)، وقد أخرجہ: مسند احمد (۵/۱۰،۱۱،۱۲)، سنن الدارمی/الدیات ۷ (۲۴۰۳),2663,It was\nnarrated that ‘Aishah said:,Chapters on Hajj Rituals
2664,حَدَّثَنَا إِسْمَاعِيلُ بْنُ مُوسَى، حَدَّثَنَا شَرِيكٌ، عَنْ أَبِي إِسْحَاقَ، عَنِ الأَسْوَدِ، عَنْ عَائِشَةَ، قَالَتْ كَأَنِّي أَرَى وَبِيصَ الطِّيبِ فِي مَفْرِقِ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ بَعْدَ ثَلاَثَةٍ وَهُوَ مُحْرِمٌ ‏.‏,Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۶۶۳،۱۰۰۲۲، ومصباح الزجاجة:۹۳۸),2664,It was\nnarrated that ‘Aishah said:,Chapters on Hajj Rituals
2665,"حَدَّثَنَا أَبُو مُصْعَبٍ، حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، عَنْ نَافِعٍ، عَنْ عَبْدِ اللَّهِ بْنِ عُمَرَ، أَنَّ رَجُلاً، سَأَلَ النَّبِيَّ ـ صلى الله عليه وسلم ـ مَا يَلْبَسُ الْمُحْرِمُ مِنَ الثِّيَابِ فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لاَ يَلْبَسُ الْقُمُصَ وَلاَ الْعَمَائِمَ وَلاَ السَّرَاوِيلاَتِ وَلاَ الْبَرَانِسَ وَلاَ الْخِفَافَ إِلاَّ أَنْ لاَ يَجِدَ نَعْلَيْنِ فَلْيَلْبَسْ خُفَّيْنِ وَلْيَقْطَعْهُمَا أَسْفَلَ مِنَ الْكَعْبَيْنِ وَلاَ تَلْبَسُوا مِنَ الثِّيَابِ شَيْئًا مَسَّهُ الزَّعْفَرَانُ أَوِ الْوَرْسُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الوصایا ۵ (۲۷۴۶)، الطلاق ۲۴ (تعلیقاً)، الدیات ۴ (۶۸۷۶)،۵ (۶۸۷۷)،۱۲ (۶۸۸۴)، صحیح مسلم/الحدود ۳ (۱۶۷۲)، سنن ابی داود/الدیات ۱۰ (۴۵۲۷ مختصراً)، سنن الترمذی/الدیات ۶ (۱۳۹۴)، سنن النسائی/المحاربة ۷ (۴۰۴۹)،(تحفة الأشرا ف:۱۳۹۱)، القسامة ۸ (۴۷۴۶)، وقد أخرجہ: مسند احمد (۳/۱۶۳،۱۸۳،۲۰۳،۲۶۷)، سنن الدارمی/الدیات ۴ (۲۴۰۰),,"It was\nnarrated from ‘Abdullah bin ‘Umar that a man asked the\nMessenger\nof Allah (ﷺ), what clothes may the Muhrim wear? The\nMessenger of\nAllah (ﷺ) said:",Chapters on Hajj Rituals
2666,حَدَّثَنَا أَبُو مُصْعَبٍ، حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، عَنْ عَبْدِ اللَّهِ بْنِ دِينَارٍ، عَنْ عَبْدِ اللَّهِ بْنِ عُمَرَ، أَنَّهُ قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ أَنْ يَلْبَسَ الْمُحْرِمُ ثَوْبًا مَصْبُوغًا بِوَرْسٍ أَوْ زَعْفَرَانٍ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الطلاق ۲۴ (۵۲۹۵)، تعلیقاً، الدیات ۴ (۶۸۷۷)،۵ (۶۸۷۹)، صحیح مسلم/الحدود ۳ (۱۶۷۲)، سنن ابی داود/الدیات ۱۰ (۴۵۲۹)، سنن النسائی/القسامة ۸ (۴۷۴۶)،(تحفة الأشراف:۱۶۳۱)، وقد أخرجہ: مسند احمد (۳/۱۷۱،۲۰۳),2666,It was\nnarrated that ‘Abdullah bin ‘Umar said:,Chapters on Hajj Rituals
2667,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، وَمُحَمَّدُ بْنُ الصَّبَّاحِ، قَالاَ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عَمْرِو بْنِ دِينَارٍ، عَنْ جَابِرِ بْنِ زَيْدٍ أَبِي الشَّعْثَاءِ، عَنِ ابْنِ عَبَّاسٍ، قَالَ سَمِعْتُ النَّبِيَّ ـ صلى الله عليه وسلم ـ يَخْطُبُ - قَالَ هِشَامٌ عَلَى الْمِنْبَرِ - فَقَالَ ‏""‏ مَنْ لَمْ يَجِدْ إِزَارًا فَلْيَلْبَسْ سَرَاوِيلَ وَمَنْ لَمْ يَجِدْ نَعْلَيْنِ فَلْيَلْبَسْ خُفَّيْنِ ‏""‏ ‏.‏ وَقَالَ هِشَامٌ فِي حَدِيثِهِ ‏""‏ فَلْيَلْبَسْ سَرَاوِيلَ إِلاَّ أَنْ يَفْقِدَ ‏""‏ ‏.‏",Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۶۴۶، ومصباح الزجاجة:۹۴۰),2667,It was\nnarrated that Ibn ‘Abbas said:,Chapters on Hajj Rituals
2668,"حَدَّثَنَا أَبُو مُصْعَبٍ، حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، عَنْ نَافِعٍ، وَعَنْ عَبْدِ اللَّهِ بْنِ دِينَارٍ، عَنِ ابْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ مَنْ لَمْ يَجِدْ نَعْلَيْنِ فَلْيَلْبَسْ خُفَّيْنِ وَلْيَقْطَعْهُمَا أَسْفَلَ مِنَ الْكَعْبَيْنِ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشر اف:۱۱۶۶۹، ومصباح الزجاجة:۹۳۹),,It was\nnarrated from Ibn ‘Umar that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Hajj Rituals
2669,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ إِدْرِيسَ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ، عَنْ يَحْيَى بْنِ عَبَّادِ بْنِ عَبْدِ اللَّهِ بْنِ الزُّبَيْرِ، عَنْ أَبِيهِ، عَنْ أَسْمَاءَ بِنْتِ أَبِي بَكْرٍ، قَالَتْ خَرَجْنَا مَعَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ حَتَّى إِذَا كُنَّا بِالْعَرْجِ نَزَلْنَا فَجَلَسَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ وَعَائِشَةُ إِلَى جَنْبِهِ وَأَنَا إِلَى جَنْبِ أَبِي بَكْرٍ وَكَانَتْ زِمَالَتُنَا وَزِمَالَةُ أَبِي بَكْرٍ وَاحِدَةً مَعَ غُلاَمِ أَبِي بَكْرٍ قَالَ فَطَلَعَ الْغُلاَمُ وَلَيْسَ مَعَهُ بَعِيرُهُ فَقَالَ لَهُ أَيْنَ بَعِيرُكَ قَالَ أَضْلَلْتُهُ الْبَارِحَةَ ‏.‏ قَالَ مَعَكَ بَعِيرٌ وَاحِدٌ تُضِلُّهُ قَالَ فَطَفِقَ يَضْرِبُهُ وَرَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ انْظُرُوا إِلَى هَذَا الْمُحْرِمِ مَا يَصْنَعُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۶۹۴)، وقد أخرجہ: سنن الترمذی/الفتن ۲ (۲۱۵۹),,It was\nnarrated that Asma’ bint Abu Bakr said:,Chapters on Hajj Rituals
2670,حَدَّثَنَا أَبُو مُصْعَبٍ، حَدَّثَنَا مَالِكٌ، عَنْ زَيْدِ بْنِ أَسْلَمَ، عَنْ إِبْرَاهِيمَ بْنِ عَبْدِ اللَّهِ بْنِ حُنَيْنٍ، عَنْ أَبِيهِ، أَنَّ عَبْدَ اللَّهِ بْنَ عَبَّاسٍ، وَالْمِسْوَرَ بْنَ مَخْرَمَةَ، اخْتَلَفَا بِالأَبْوَاءِ فَقَالَ عَبْدُ اللَّهِ بْنُ عَبَّاسٍ يَغْسِلُ الْمُحْرِمُ رَأْسَهُ ‏.‏ وَقَالَ الْمِسْوَرُ بْنُ مَخْرَمَةَ لاَ يَغْسِلُ الْمُحْرِمُ رَأْسَهُ ‏.‏ فَأَرْسَلَنِي ابْنُ عَبَّاسٍ إِلَى أَبِي أَيُّوبَ الأَنْصَارِيِّ أَسْأَلُهُ عَنْ ذَلِكَ، فَوَجَدْتُهُ يَغْتَسِلُ بَيْنَ الْقَرْنَيْنِ وَهُوَ يَسْتَتِرُ بِثَوْبٍ فَسَلَّمْتُ عَلَيْهِ فَقَالَ مَنْ هَذَا قُلْتُ أَنَا عَبْدُ اللَّهِ بْنُ حُنَيْنٍ أَرْسَلَنِي إِلَيْكَ عَبْدُ اللَّهِ بْنُ عَبَّاسٍ أَسْأَلُكَ كَيْفَ كَانَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ يَغْسِلُ رَأْسَهُ وَهُوَ مُحْرِمٌ قَالَ فَوَضَعَ أَبُو أَيُّوبَ يَدَهُ عَلَى الثَّوْبِ فَطَأْطَأَهُ حَتَّى بَدَا لِي رَأْسُهُ ثُمَّ قَالَ لإِنْسَانٍ يَصُبُّ عَلَيْهِ اصْبُبْ ‏.‏ فَصَبَّ عَلَى رَأْسِهِ ثُمَّ حَرَّكَ رَأْسَهُ بِيَدَيْهِ فَأَقْبَلَ بِهِمَا وَأَدْبَرَ ‏.‏ ثُمَّ قَالَ هَكَذَا رَأَيْتُهُ ـ صلى الله عليه وسلم ـ يَفْعَلُ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۹۹۰، ومصباح الزجاجة:۹۴۱)، وقد أخرجہ: سنن النسائی/القسامة ۳۵ (۴۸۳۷),2670,"It was\nnarrated from Ibrahim bin ‘Abdullah bin Hunain, from his father,\nthat ‘Abdullah bin ‘Abbas and Miswar bin Makhramah disagreed at\nAbwa’. Abdullah bin ‘Abbas said that the Muhrim may wash his\nhead, and Miswar said that the Muhrim may not wash his head.\nIbn ‘Abbas sent me to Abu Ayyub Al-Ansari to ask him about that, and I found him taking a bath near the well, screened with a piece of cloth. I greeted him with Salam, and he said:",Chapters on Hajj Rituals
2671,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا مُحَمَّدُ بْنُ فُضَيْلٍ، عَنْ يَزِيدَ بْنِ أَبِي زِيَادٍ، عَنْ مُجَاهِدٍ، عَنْ عَائِشَةَ، قَالَتْ كُنَّا مَعَ النَّبِيِّ ـ صلى الله عليه وسلم ـ وَنَحْنُ مُحْرِمُونَ فَإِذَا لَقِيَنَا الرَّاكِبُ أَسْدَلْنَا ثِيَابَنَا مِنْ فَوْقِ رُءُوسِنَا فَإِذَا جَاوَزَنَا رَفَعْنَاهَا"""".‏ حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ إِدْرِيسَ، عَنْ يَزِيدَ بْنِ أَبِي زِيَادٍ، عَنْ مُجَاهِدٍ، عَنْ عَائِشَةَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ بِنَحْوِهِ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۵۳۴، ومصباح الزجاجة:۹۴۲)، وقد أخرجہ: مسند احمد (۴/۳۴۵،۵/۸۱),,It was\nnarrated that ‘Aishah said:,Chapters on Hajj Rituals
2672,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا أَبِي ح، وَحَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، حَدَّثَنَا عُثْمَانُ بْنُ حَكِيمٍ، عَنْ أَبِي بَكْرِ بْنِ عَبْدِ اللَّهِ بْنِ الزُّبَيْرِ، عَنْ جَدَّتِهِ، - قَالَ لاَ أَدْرِي أَسْمَاءَ بِنْتِ أَبِي بَكْرٍ أَوْ سُعْدَى بِنْتِ عَوْفٍ ‏.‏ أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ دَخَلَ عَلَى ضُبَاعَةَ بِنْتِ عَبْدِ الْمُطَّلِبِ فَقَالَ ‏""‏ مَا يَمْنَعُكِ يَا عَمَّتَاهُ مِنَ الْحَجِّ ‏""‏ ‏.‏ فَقَالَتْ أَنَا امْرَأَةٌ سَقِيمَةٌ وَأَنَا أَخَافُ الْحَبْسَ ‏.‏ قَالَ ‏""‏ فَأَحْرِمِي وَاشْتَرِطِي أَنَّ مَحِلَّكِ حَيْثُ حُبِسْتِ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأ شراف:۱۳۰، ومصباح الزجاجة:۹۴۳),2672,It was\nnarrated from Abu Bakr bin ‘Abdullah bin Zubair from his\ngrandmother – he (the narrator) said:,Chapters on Hajj Rituals
2673,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا مُحَمَّدُ بْنُ فُضَيْلٍ، وَوَكِيعٌ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ أَبِيهِ، عَنْ ضُبَاعَةَ، قَالَتْ دَخَلَ عَلَىَّ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ وَأَنَا شَاكِيَةٌ فَقَالَ ‏""‏ أَمَا تُرِيدِينَ الْحَجَّ الْعَامَ ‏""‏ قُلْتُ إِنِّي لَعَلِيلَةٌ يَا رَسُولَ اللَّهِ ‏.‏ قَالَ ‏""‏ حُجِّي وَقُولِي مَحِلِّي حَيْثُ تَحْبِسُنِي ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «صحیح البخاری/الزکاة ۶۶ (۱۴۹۹)، المساقاة ۳ (۲۳۵۵)، الدیات ۲۸ (۶۹۱۲)،۲۹ (۶۹۱۳)، صحیح مسلم/الحدود ۱۱ (۱۷۱۰)، سنن ابی داود/الخراج ۴۰ (۳۰۸۵)، سنن الترمذی/الأحکام ۳۷ (۱۳۷۷)، سنن النسائی/الزکاة ۲۸ (۲۴۹۷)،(تحفة الأشراف:۱۵۱۴۷۱۳۱۲۸)، وقد أخرجہ: موطا امام مالک/العقول ۱۸ (۱۲)، مسند احمد (۲/۲۲۸،۹ ۲۲،۲۵۴،۲۷۴،۲۸۵،۳۱۹،۳۸۲،۳۸۶،۴۰۶،۴۱۱،۴۱۴،۴۵۴،۴۵۶،۴۶۷،۴۷۵،۴۸۲،۴۹۲،۴۹۵،۴۹۹،۵۰۱،۵۰۷)، سنن الدارمی/الزکاة ۳۰ (۱۷۱۰),2673,It was\nnarrated that Duba’ah said:,Chapters on Hajj Rituals
2674,"حَدَّثَنَا أَبُو بِشْرٍ، بَكْرُ بْنُ خَلَفٍ حَدَّثَنَا أَبُو عَاصِمٍ، عَنِ ابْنِ جُرَيْجٍ، أَخْبَرَنِي أَبُو الزُّبَيْرِ، أَنَّهُ سَمِعَ طَاوُسًا، وَعِكْرِمَةَ، يُحَدِّثَانِ عَنِ ابْنِ عَبَّاسٍ، قَالَ جَاءَتْ ضُبَاعَةُ بِنْتُ الزُّبَيْرِ بْنِ عَبْدِ الْمُطَّلِبِ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ فَقَالَتْ إِنِّي امْرَأَةٌ ثَقِيلَةٌ وَإِنِّي أُرِيدُ الْحَجَّ فَكَيْفَ أُهِلُّ قَالَ ‏ ‏ أَهِلِّي وَاشْتَرِطِي أَنَّ مَحِلِّي حَيْثُ حَبَسْتَنِي ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih Lighairihi; Shuaib Al Arnaut: Hasan Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأ شراف:۱۰۷۸۱، ومصباح الزجاجة:۹۴۴),,It was\nnarrated that Ibn ‘Abbas said:,Chapters on Hajj Rituals
2675,حَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ صَبِيحٍ، حَدَّثَنَا مُبَارَكُ بْنُ حَسَّانَ أَبُو عَبْدِ اللَّهِ، عَنْ عَطَاءِ بْنِ أَبِي رَبَاحٍ، عَنْ عَبْدِ اللَّهِ بْنِ عَبَّاسٍ، قَالَ كَانَتِ الأَنْبِيَاءُ تَدْخُلُ الْحَرَمَ مُشَاةً حُفَاةً وَيَطُوفُونَ بِالْبَيْتِ وَيَقْضُونَ الْمَنَاسِكَ حُفَاةً مُشَاةً ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih Lighairihi; Shuaib Al Arnaut: Hasan Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ، ابن ماجہ،(تحفة الأ شراف:۵۰۶۳، ومصباح الزجاجة:۹۴۵)، وقد أخرجہ: مسند احمد (۵/۳۲۶،۳۲۷),2675,It was\nnarrated that ‘Abdullah bin ‘Abbas said:,Chapters on Hajj Rituals
2676,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ عُمَرَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ كَانَ يَدْخُلُ مَكَّةَ مِنَ الثَّنِيَّةِ الْعُلْيَا وَإِذَا خَرَجَ خَرَجَ مِنَ الثَّنِيَّةِ السُّفْلَى ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن ابی داود/الدیات ۳۱ (۴۵۹۴)،(تحفة الأ شراف:۱۴۶۹۹),2676,,Chapters on Hajj Rituals
2677,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا الْعُمَرِيُّ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ دَخَلَ مَكَّةَ نَهَارًا ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الصلح ۷ (۲۷۰۲)، الجزیة ۱۲ (۳۱۷۳)، الأدب ۸۹ (۶۱۴۳)، الدیات ۲۲ (۶۸۹۸)، الأحکام ۳۸ (۷۱۹۲)، صحیح مسلم/القسامة ۱ (۱۶۶۹)، سنن ابی داود/الدیات ۸ (۴۵۲۰)،۹ (۴۵۲۳)، سنن الترمذی/الدیات ۲۳ (۱۴۴۲)، سنن النسائی/القسامة ۳ (۴۷۱۴)،(تحفة الأ شراف:۴۶۴۴)، وقد أخرجہ: موطا امام مالک/القسامة ۱ (۱)، مسند احمد (۴/۲،۳)، سنن الدارمی/الدیات ۲ (۲۳۹۸),2677,,Chapters on Hajj Rituals
2678,"حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَنْبَأَنَا مَعْمَرٌ، عَنِ الزُّهْرِيِّ، عَنْ عَلِيِّ بْنِ الْحُسَيْنِ، عَنْ عَمْرِو بْنِ عُثْمَانَ، عَنْ أُسَامَةَ بْنِ زَيْدٍ، قَالَ قُلْتُ يَا رَسُولَ اللَّهِ أَيْنَ تَنْزِلُ غَدًا وَذَلِكَ فِي حَجَّتِهِ قَالَ ‏""‏ وَهَلْ تَرَكَ لَنَا عَقِيلٌ مَنْزِلاً ‏""‏ ‏.‏ ثُمَّ قَالَ ‏""‏ نَحْنُ نَازِلُونَ غَدًا بِخَيْفِ بَنِي كِنَانَةَ - يَعْنِي الْمُحَصَّبَ - حَيْثُ قَاسَمَتْ قُرَيْشٌ عَلَى الْكُفْرِ ‏""‏ ‏.‏ وَذَلِكَ أَنَّ بَنِي كِنَانَةَ حَالَفَتْ قُرَيْشًا عَلَى بَنِي هَاشِمٍ أَنْ لاَ يُنَاكِحُوهُمْ وَلاَ يُبَايِعُوهُمْ ‏.‏ قَالَ مَعْمَرٌ قَالَ الزُّهْرِيُّ وَالْخَيْفُ الْوَادِي ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih Lighairihi; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأ شراف:۸۶۷۸، ومصباح الزجاجة:۹۴۹)، وقد أخرجہ: سنن النسائی/القسامة ۲ (۴۷۱۸),2678,It was\nnarrated that Usamah bin Zaid said:,Chapters on Hajj Rituals
2679,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا أَبُو مُعَاوِيَةَ، حَدَّثَنَا عَاصِمٌ الأَحْوَلُ، عَنْ عَبْدِ اللَّهِ بْنِ سَرْجِسَ، قَالَ رَأَيْتُ الأُصَيْلِعَ عُمَرَ بْنَ الْخَطَّابِ يُقَبِّلُ الْحَجَرَ وَيَقُولُ إِنِّي لأُقَبِّلُكَ وَإِنِّي لأَعْلَمُ أَنَّكَ حَجَرٌ لاَ تَضُرُّ وَلاَ تَنْفَعُ وَلَوْلاَ أَنِّي رَأَيْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يُقَبِّلُكَ مَا قَبَّلْتُكَ ‏.‏,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأ شراف:۳۶۵۰، ومصباح الزجاجة:۹۴۷),2679,It was\nnarrated that ‘Abdullah bin Sarjis said:,Chapters on Hajj Rituals
2680,"حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، حَدَّثَنَا عَبْدُ الرَّحِيمِ الرَّازِيُّ، عَنِ ابْنِ خُثَيْمٍ، عَنْ سَعِيدِ بْنِ جُبَيْرٍ، قَالَ سَمِعْتُ ابْنَ عَبَّاسٍ، يَقُولُ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لَيَأْتِيَنَّ هَذَا الْحَجَرُ يَوْمَ الْقِيَامَةِ وَلَهُ عَيْنَانِ يُبْصِرُ بِهِمَا وَلِسَانٌ يَنْطِقُ بِهِ يَشْهَدُ عَلَى مَنْ يَسْتَلِمُهُ بِحَقٍّ ‏""""‏ ‏.‏""",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الدیات ۷ (۴۵۱۹)،(تحفة الأ شراف:۸۷۱۶)، و قد أخرجہ: مسند احمد (۲/۱۸۲،۲۲۵),,It was\nnarrated that Sa’eed bin Jubair said:,Chapters on Hajj Rituals
2681,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا خَالِي، يَعْلَى عَنْ مُحَمَّدِ بْنِ عَوْنٍ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ اسْتَقْبَلَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ الْحَجَرَ ثُمَّ وَضَعَ شَفَتَيْهِ عَلَيْهِ يَبْكِي طَوِيلاً ثُمَّ الْتَفَتَ فَإِذَا هُوَ بِعُمَرَ بْنِ الْخَطَّابِ يَبْكِي فَقَالَ ‏ ‏ يَا عُمَرُ هَاهُنَا تُسْكَبُ الْعَبَرَاتُ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۴۴۱)، وقد أخرجہ: سنن ابی داود/الجہاد ۱۲۰ (۲۶۶۶)، مسند احمد (۱/۳۹۳),,It was\nnarrated that Ibn ‘Umar said:,Chapters on Hajj Rituals
2682,حَدَّثَنَا أَحْمَدُ بْنُ عَمْرِو بْنِ السَّرْحِ الْمِصْرِيُّ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، أَخْبَرَنِي يُونُسُ، عَنِ ابْنِ شِهَابٍ، عَنْ سَالِمِ بْنِ عَبْدِ اللَّهِ، عَنْ أَبِيهِ، قَالَ لَمْ يَكُنْ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ يَسْتَلِمُ مِنْ أَرْكَانِ الْبَيْتِ إِلاَّ الرُّكْنَ الأَسْوَدَ وَالَّذِي يَلِيهِ مِنْ نَحْوِ دُورِ الْجُمَحِيِّينَ ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/ الجہاد ۱۲۰ (۲۶۶۶)،(تحفة الأ شراف:۹۴۷۶),2682,It was\nnarrated from Salim bin ‘Abdullah that his father said:,Chapters on Hajj Rituals
2683,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا يُونُسُ بْنُ بُكَيْرٍ، حَدَّثَنَا مُحَمَّدُ بْنُ إِسْحَاقَ، عَنْ مُحَمَّدِ بْنِ جَعْفَرِ بْنِ الزُّبَيْرِ، عَنْ عُبَيْدِ اللَّهِ بْنِ عَبْدِ اللَّهِ بْنِ أَبِي ثَوْرٍ، عَنْ صَفِيَّةَ بِنْتِ شَيْبَةَ، قَالَتْ لَمَّا اطْمَأَنَّ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَامَ الْفَتْحِ طَافَ عَلَى بَعِيرِهِ يَسْتَلِمُ الرُّكْنَ بِمِحْجَنٍ بِيَدِهِ ثُمَّ دَخَلَ الْكَعْبَةَ فَوَجَدَ فِيهَا حَمَامَةَ عَيْدَانٍ فَكَسَرَهَا ثُمَّ قَامَ عَلَى بَابِ الْكَعْبَةِ فَرَمَى بِهَا وَأَنَا أَنْظُرُهُ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأ شراف:۶۰۲۹، ومصباح الزجاجة:۹۴۸)وقد مضی تمامہ برقم:(۲۶۶۰),2683,It was\nnarrated that Safiyyah bint Shaibah said:,Chapters on Hajj Rituals
2684,حَدَّثَنَا أَحْمَدُ بْنُ عَمْرِو بْنِ السَّرْحِ، أَنْبَأَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، عَنْ يُونُسَ، عَنِ ابْنِ شِهَابٍ، عَنْ عُبَيْدِ اللَّهِ بْنِ عَبْدِ اللَّهِ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ طَافَ فِي حَجَّةِ الْوَدَاعِ عَلَى بَعِيرٍ يَسْتَلِمُ الرُّكْنَ بِمِحْجَنٍ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأ شراف:۱۱۴۷۰، ومصباح الزجاجة:۹۴۹),2684,,Chapters on Hajj Rituals
2685,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، ح وَحَدَّثَنَا هَدِيَّةُ بْنُ عَبْدِ الْوَهَّابِ، حَدَّثَنَا الْفَضْلُ بْنُ مُوسَى، قَالاَ حَدَّثَنَا مَعْرُوفُ بْنُ خَرَّبُوذَ الْمَكِّيُّ، قَالَ سَمِعْتُ أَبَا الطُّفَيْلِ، عَامِرَ بْنَ وَاثِلَةَ قَالَ رَأَيْتُ النَّبِيَّ ـ صلى الله عليه وسلم ـ يَطُوفُ بِالْبَيْتِ عَلَى رَاحِلَتِهِ يَسْتَلِمُ الرُّكْنَ بِمِحْجَنِهِ وَيُقَبِّلُ الْمِحْجَنَ ‏.‏,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأ شراف:۸۷۳۹، ومصباح الزجاجة:۹۵۰)، وقد أخرجہ: سنن ابی داود/الجہاد ۱۵۹ (۲۷۵۱)، مسند احمد (۲/۲۰۵،۲۱۵،۲۱۶),2685,Ma’ruf\nbin Kharrabudh Al-Makki narrated:,Chapters on Hajj Rituals
2686,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا أَحْمَدُ بْنُ بَشِيرٍ، ح وَحَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا مُحَمَّدُ بْنُ عُبَيْدٍ، قَالاَ حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ عُمَرَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ كَانَ إِذَا طَافَ بِالْبَيْتِ الطَّوَافَ الأَوَّلَ رَمَلَ ثَلاَثَةً وَمَشَى أَرْبَعَةً مِنَ الْحَجَرِ إِلَى الْحَجَرِ وَكَانَ ابْنُ عُمَرَ يَفْعَلُهُ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الجزیة ۵ (۳۱۶۶)، الدیات ۲۰ (۶۹۱۴)،(تحفة الأشراف:۸۹۱۷)، وقد أخرجہ: سنن النسائی/القسامة ۱۰ (۴۷۵۳)، مسند احمد (۲/۱۸۶),2686,,Chapters on Hajj Rituals
2687,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا أَبُو الْحُسَيْنِ الْعُكْلِيُّ، عَنْ مَالِكِ بْنِ أَنَسٍ، عَنْ جَعْفَرِ بْنِ مُحَمَّدٍ، عَنْ أَبِيهِ، عَنْ جَابِرٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ رَمَلَ مِنَ الْحَجَرِ إِلَى الْحَجَرِ ثَلاَثًا وَمَشَى أَرْبَعًا ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن الترمذی/الدیات ۱۱ (۱۴۰۳)،(تحفة الأ شراف:۱۴۱۴۰),2687,,Chapters on Hajj Rituals
2688,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا جَعْفَرُ بْنُ عَوْنٍ، عَنْ هِشَامِ بْنِ سَعْدٍ، عَنْ زَيْدِ بْنِ أَسْلَمَ، عَنْ أَبِيهِ، قَالَ سَمِعْتُ عُمَرَ، يَقُولُ فِيمَ الرَّمَلاَنُ الآنَ وَقَدْ أَطَّأَ اللَّهُ الإِسْلاَمَ وَنَفَى الْكُفْرَ وَأَهْلَهُ وَايْمُ اللَّهِ مَا نَدَعُ شَيْئًا كُنَّا نَفْعَلُهُ عَلَى عَهْدِ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۷۳۰، ومصباح الزجاجة:۹۵۱)، وقد أخرجہ: مسند احمد (۵/۲۲۳،۲۲۴،۴۳۶،۴۳۷),2688,It was\nnarrated from Zaid bin Aslam that his father said:,Chapters on Hajj Rituals
2689,"حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَنْبَأَنَا مَعْمَرٌ، عَنِ ابْنِ خُثَيْمٍ، عَنْ أَبِي الطُّفَيْلِ، عَنِ ابْنِ عَبَّاسٍ، قَالَ قَالَ النَّبِيُّ ـ صلى الله عليه وسلم ـ لأَصْحَابِهِ حِينَ أَرَادُوا دُخُولَ مَكَّةَ فِي عُمْرَتِهِ بَعْدَ الْحُدَيْبِيَةِ ‏ ‏ إِنَّ قَوْمَكُمْ غَدًا سَيَرَوْنَكُمْ فَلَيَرَوُنَّكُمْ جُلْدًا ‏""""‏ ‏.‏ فَلَمَّا دَخَلُوا الْمَسْجِدَ اسْتَلَمُوا الرُّكْنَ وَرَمَلُوا وَالنَّبِيُّ ـ صلى الله عليه وسلم ـ مَعَهُمْ حَتَّى إِذَا بَلَغُوا الرُّكْنَ الْيَمَانِيَّ مَشَوْا إِلَى الرُّكْنِ الأَسْوَدِ ثُمَّ رَمَلُوا حَتَّى بَلَغُوا الرُّكْنَ الْيَمَانِيَّ ثُمَّ مَشَوْا إِلَى الرُّكْنِ الأَسْوَدِ فَفَعَلَ ذَلِكَ ثَلاَثَ مَرَّاتٍ ثُمَّ مَشَى الأَرْبَعَ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «حدیث رفاعة تقدم تخریجہ بمثل الحدیث السابق (۲۶۸۸)، وحدیث سلیمان بن صرد، تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۵۷۰ (الف)، ومصباح الزجاجة:۹۵۲)، وقد أخرجہ: مسند احمد (۶/۳۹۴),,It was\nnarrated that Ibn ‘Abbas said:,Chapters on Hajj Rituals
2690,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ، وَقَبِيصَةُ، قَالاَ حَدَّثَنَا سُفْيَانُ، عَنِ ابْنِ جُرَيْجٍ، عَنْ عَبْدِ الْحَمِيدِ، عَنِ ابْنِ يَعْلَى بْنِ أُمَيَّةَ، عَنْ أَبِيهِ، يَعْلَى أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ طَافَ مُضْطَبِعًا ‏.‏ قَالَ قَبِيصَةُ وَعَلَيْهِ بُرْدٌ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الدیات ۳ (۴۴۹۸)، سنن الترمذی/الدیات ۱۳ (۱۴۰۷)، سنن النسائی/القسامة ۳ (۴۷۲۶)،(تحفة الأشراف:۱۲۵۰۷),2690,It was\nnarrated from Ibn Ya’la bin Umayyah that his father Ya’la\nsaid:,Chapters on Hajj Rituals
2691,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ مُوسَى، حَدَّثَنَا شَيْبَانُ، عَنْ أَشْعَثَ بْنِ أَبِي الشَّعْثَاءِ، عَنِ الأَسْوَدِ بْنِ يَزِيدَ، عَنْ عَائِشَةَ، قَالَتْ سَأَلْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ عَنِ الْحِجْرِ ‏.‏ فَقَالَ ‏""‏ هُوَ مِنَ الْبَيْتِ ‏""‏ ‏.‏ قُلْتُ مَا مَنَعَهُمْ أَنْ يُدْخِلُوهُ فِيهِ قَالَ ‏""‏ عَجَزَتْ بِهِمُ النَّفَقَةُ ‏""‏ ‏.‏ قُلْتُ فَمَا شَأْنُ بَابِهِ مُرْتَفِعًا لاَ يُصْعَدُ إِلَيْهِ إِلاَّ بِسُلَّمٍ قَالَ ‏""‏ ذَلِكَ فِعْلُ قَوْمِكِ لِيُدْخِلُوهُ مَنْ شَاءُوا وَيَمْنَعُوهُ مَنْ شَاءُوا وَلَوْلاَ أَنَّ قَوْمَكِ حَدِيثُ عَهْدٍ بِكُفْرٍ مَخَافَةَ أَنْ تَنْفِرَ قُلُوبُهُمْ لَنَظَرْتُ هَلْ أُغَيِّرُهُ فَأُدْخِلَ فِيهِ مَا انْتَقَصَ مِنْهُ وَجَعَلْتُ بَابَهُ بِالأَرْضِ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: سنن النسائی/القسامة ۳ (۴۷۳۴)،(تحفة الأشراف:۴۵۱),2691,It was\nnarrated that ‘Aishah said:,Chapters on Hajj Rituals
2692,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا مُحَمَّدُ بْنُ الْفُضَيْلِ، عَنِ الْعَلاَءِ بْنِ الْمُسَيَّبِ، عَنْ عَطَاءٍ، عَنْ عَبْدِ اللَّهِ بْنِ عُمَرَ، قَالَ سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ مَنْ طَافَ بِالْبَيْتِ وَصَلَّى رَكْعَتَيْنِ كَانَ كَعِتْقِ رَقَبَةٍ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن ابی داود/الدیات ۳ (۴۴۹۷)، سنن النسائی/القسامة ۲۳ (۴۷۸۷،۴۷۸۸)،(تحفة الأ شراف:۱۰۹۵)، وقد أخرجہ: مسند احمد (۳/۲۱۳،۲۵۲),,It was\nnarrated that ‘Abdullah bin ‘Umar said:,Chapters on Hajj Rituals
2693,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ عَيَّاشٍ، حَدَّثَنَا حُمَيْدُ بْنُ أَبِي سَوِيَّةَ، قَالَ سَمِعْتُ ابْنَ هِشَامٍ، يَسْأَلُ عَطَاءَ بْنَ أَبِي رَبَاحٍ عَنِ الرُّكْنِ الْيَمَانِيِّ، وَهُوَ يَطُوفُ بِالْبَيْتِ فَقَالَ عَطَاءٌ حَدَّثَنِي أَبُو هُرَيْرَةَ أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ ‏""‏ وُكِلَ بِهِ سَبْعُونَ مَلَكًا فَمَنْ قَالَ اللَّهُمَّ إِنِّي أَسْأَلُكَ الْعَفْوَ وَالْعَافِيَةَ فِي الدُّنْيَا وَالآخِرَةِ رَبَّنَا آتِنَا فِي الدُّنْيَا حَسَنَةً وَفِي الآخِرَةِ حَسَنَةً وَقِنَا عَذَابَ النَّارِ - قَالُوا آمِينَ ‏""‏ ‏.‏ فَلَمَّا بَلَغَ الرُّكْنَ الأَسْوَدَ قَالَ يَا أَبَا مُحَمَّدٍ مَا بَلَغَكَ فِي هَذَا الرُّكْنِ الأَسْوَدِ فَقَالَ عَطَاءٌ حَدَّثَنِي أَبُو هُرَيْرَةَ أَنَّهُ سَمِعَ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏""‏ مَنْ فَاوَضَهُ فَإِنَّمَا يُفَاوِضُ يَدَ الرَّحْمَنِ ‏""‏ ‏.‏ قَالَ لَهُ ابْنُ هِشَامٍ يَا أَبَا مُحَمَّدٍ فَالطَّوَافُ قَالَ عَطَاءٌ حَدَّثَنِي أَبُو هُرَيْرَةَ أَنَّهُ سَمِعَ النَّبِيَّ ـ صلى الله عليه وسلم ـ يَقُولُ ‏""‏ مَنْ طَافَ بِالْبَيْتِ سَبْعًا وَلاَ يَتَكَلَّمُ إِلاَّ بِسُبْحَانَ اللَّهِ وَالْحَمْدُ لِلَّهِ وَلاَ إِلَهَ إِلاَّ اللَّهُ وَاللَّهُ أَكْبَرُ وَلاَ حَوْلَ وَلاَقُوَّةَ إِلاَّ بِاللَّهِ مُحِيَتْ عَنْهُ عَشْرُ سِيِّئَاتٍ وَكُتِبَتْ لَهُ عَشْرُ حَسَنَاتٍ وَرُفِعَ لَهُ بِهَا عَشْرُ دَرَجَاتٍ وَمَنْ طَافَ فَتَكَلَّمَ وَهُوَ فِي تِلْكَ الْحَالِ خَاضَ فِي الرَّحْمَةِ بِرِجْلَيْهِ كَخَائِضِ الْمَاءِ بِرِجْلَيْهِ ‏""‏ ‏.‏",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/الدیات ۵ (۱۳۹۳)،(تحفة الأشراف:۱۰۹۷۱)، وقد أخرجہ: مسند احمد (۶/۴۴۸),2693,Humaid\nbin Abu Sawiyyah said:,Chapters on Hajj Rituals
2694,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو أُسَامَةَ، عَنِ ابْنِ جُرَيْجٍ، عَنْ كَثِيرِ بْنِ كَثِيرِ بْنِ الْمُطَّلِبِ بْنِ أَبِي وَدَاعَةَ السَّهْمِيِّ، عَنْ أَبِيهِ، عَنِ الْمُطَّلِبِ، قَالَ رَأَيْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ إِذَا فَرَغَ مِنْ سَبْعِهِ جَاءَ حَتَّى يُحَاذِيَ بِالرُّكْنِ فَصَلَّى رَكْعَتَيْنِ فى حَاشِيَةِ الْمَطَافِ وَلَيْسَ بَيْنَهُ وَبَيْنَ الطُّوَّافِ أَحَدٌ ‏.‏ قَالَ ابْنُ مَاجَهْ هَذَا بِمَكَّةَ خَاصَّةً ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأ شراف:۴۸۲۴،۵۰۴۸،۵۱۰۳،۱۱۳۴۱، ومصباح الزجاجة:۹۵۳),2694,It was\nnarrated that Muttalib said:,Chapters on Hajj Rituals
2695,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، وَعَمْرُو بْنُ عَبْدِ اللَّهِ، قَالاَ حَدَّثَنَا وَكِيعٌ، عَنْ مُحَمَّدِ بْنِ ثَابِتٍ الْعَبْدِيِّ، عَنْ عَمْرِو بْنِ دِينَارٍ، عَنِ ابْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَدِمَ فَطَافَ بِالْبَيْتِ سَبْعًا ثُمَّ صَلَّى رَكْعَتَيْنِ - قَالَ وَكِيعٌ يَعْنِي عِنْدَ الْمَقَامِ - ثُمَّ خَرَجَ إِلَى الصَّفَا ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الوصایا ۶ (۱۶۳۵)، سنن ابی داود/الوصایا۱ (۲۸۶۳)، سنن النسائی/الوصایا ۲ (۳۶۵۱)،(تحفة الأ شراف:۱۷۶۱۰)، وقد أخرجہ: مسند احمد (۶/۴۴),2695,"It was\nnarrated from Ibn ‘Umar that the Messenger of Allah (ﷺ) came\nand\nperformed Tawaf around the House seven times, then he prayed two\nRak’ahs. Waki’ said:",Chapters on Hajj Rituals
2696,حَدَّثَنَا الْعَبَّاسُ بْنُ عُثْمَانَ الدِّمَشْقِيُّ، حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، عَنْ مَالِكِ بْنِ أَنَسٍ، عَنْ جَعْفَرِ بْنِ مُحَمَّدٍ، عَنْ أَبِيهِ، عَنْ جَابِرٍ، أَنَّهُ قَالَ لَمَّا فَرَغَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ مِنْ طَوَافِ الْبَيْتِ أَتَى مَقَامَ إِبْرَاهِيمَ فَقَالَ عُمَرُ يَا رَسُولَ اللَّهِ هَذَا مَقَامُ أَبِينَا إِبْرَاهِيمَ الَّذِي قَالَ اللَّهُ سُبْحَانَهُ ‏{وَاتَّخِذُوا مِنْ مَقَامِ إِبْرَاهِيمَ مُصَلًّى}‏ ‏.‏ قَالَ الْوَلِيدُ فَقُلْتُ لِمَالِكٍ هَكَذَا قَرَأَهَا ‏{وَاتَّخِذُوا مِنْ مَقَامِ إِبْرَاهِيمَ مُصَلًّى}‏ قَالَ نَعَمْ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الوصایا ۱ (۲۷۴۰)، المغازي ۸۳ (۴۴۶۰)، فضائل القران ۱۸ (۵۰۲۲)، صحیح مسلم/الوصایا ۵ (۱۶۳۴)، سنن الترمذی/الوصایا ۴ (۲۱۱۹)، سنن النسائی/الوصایا ۲ (۳۶۵۰)،(تحفة الأ شراف:۵۱۷۰،۱۹۵۰۷)، وقد أخرجہ: مسند احمد (۴/۳۵۴،۳۵۵،۳۸۱)، سنن الدارمی/الوصایا ۳ (۳۲۲۴),2696,It was\nnarrated that Jabir said:,Chapters on Hajj Rituals
2697,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا مُعَلَّى بْنُ مَنْصُورٍ، ح وَحَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ، وَأَحْمَدُ بْنُ سِنَانٍ، قَالاَ حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، قَالاَ حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ نَوْفَلٍ، عَنْ عُرْوَةَ، عَنْ زَيْنَبَ، عَنْ أُمِّ سَلَمَةَ، أَنَّهَا مَرِضَتْ فَأَمَرَهَا رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ أَنْ تَطُوفَ مِنْ وَرَاءِ النَّاسِ وَهِيَ رَاكِبَةٌ ‏.‏ قَالَتْ فَرَأَيْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يُصَلِّي إِلَى الْبَيْتِ وَهُوَ يَقْرَأُ ‏{وَالطُّورِ * وَكِتَابٍ مَسْطُورٍ}‏ ‏.‏ قَالَ ابْنُ مَاجَهْ هَذَا حَدِيثُ أَبِي بَكْرٍ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأ شراف:۱۲۲۹، ومصباح الزجاجة:۹۵۴)، وقد أخرجہ: مسند احمد (۳/۱۱۷),2697,"It was\nnarrated from Umm Salamah that she fell sick, so the Messenger\nof\nAllah (ﷺ) told her to perform Tawaf from behind the people,\nriding.\nShe said:",Chapters on Hajj Rituals
2698,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، قَالَ سَمِعْتُ الْمُثَنَّى بْنَ الصَّبَّاحِ، يَقُولُ حَدَّثَنِي عَمْرُو بْنُ شُعَيْبٍ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، قَالَ طُفْتُ مَعَ عَبْدِ اللَّهِ بْنِ عَمْرٍو فَلَمَّا فَرَغْنَا مِنَ السَّبْعِ رَكَعْنَا فِي دُبُرِ الْكَعْبَةِ فَقُلْتُ أَلاَ نَتَعَوَّذُ بِاللَّهِ مِنَ النَّارِ ‏.‏ قَالَ أَعُوذُ بِاللَّهِ مِنَ النَّارِ ‏.‏ قَالَ ثُمَّ مَضَى فَاسْتَلَمَ الرُّكْنَ ثُمَّ قَامَ بَيْنَ الْحَجَرِ وَالْبَابِ فَأَلْصَقَ صَدْرَهُ وَيَدَيْهِ وَخَدَّهُ إِلَيْهِ ثُمَّ قَالَ هَكَذَا رَأَيْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَفْعَلُ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الأدب ۱۳۳ (۵۱۵۶)،(تحفة الأ شراف:۱۰۳۴۳)، وقد أخرجہ: مسند احمد (۱/۷۸),2698,‘Amr\nbin Shu’aib narrated from his father that his grandfather said:,Chapters on Hajj Rituals
2699,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، قَالَتْ خَرَجْنَا مَعَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ لاَ نَرَى إِلاَّ الْحَجَّ فَلَمَّا كُنَّا بِسَرِفَ أَوْ قَرِيبًا مِنْ سَرِفَ حِضْتُ فَدَخَلَ عَلَىَّ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ وَأَنَا أَبْكِي فَقَالَ مَالَكِ أَنَفِسْتِ ‏""‏ ‏.‏ قُلْتُ نَعَمْ ‏.‏ قَالَ ‏""‏ إِنَّ هَذَا أَمْرٌ كَتَبَهُ اللَّهُ عَلَى بَنَاتِ آدَمَ فَاقْضِي الْمَنَاسِكَ كُلَّهَا غَيْرَ أَنْ لاَ تَطُوفِي بِالْبَيْتِ ‏""‏ ‏.‏ قَالَتْ وَضَحَّى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنْ نِسَائِهِ بِالْبَقَرِ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الوصایا ۱ (۱۶۲۸)، سنن الترمذی/الجنائز ۵ (۹۷۴)،(تحفة الأ شراف:۷۹۴۴)، وقد أخرجہ: صحیح البخاری/الوصایا ۱ (۲۷۳۸)، سنن ابی داود/الوصایا ۱ (۲۸۶۲)، سنن الترمذی/الوصایا ۳ (۲۱۱۹)، سنن النسائی/الوصایا ۱ (۳۶۴۵)موطا امام مالک/الوصایا ۱ (۱)، مسند احمد (۲/۴،۱۰،۳۴،۵۰،۵۷،۸۰،۱۱۳)، سنن الدارمی/الوصایا ۱ (۳۲۱۹),2699,It was\nnarrated that ‘Aishah said:,Chapters on Hajj Rituals
2700,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، وَأَبُو مُصْعَبٍ قَالاَ حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، حَدَّثَنِي عَبْدُ الرَّحْمَنِ بْنُ الْقَاسِمِ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ أَفْرَدَ الْحَجَّ ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأ شراف:۱۶۸۵، ومصباح الزجاجة:۹۵۵),2700,,Chapters on Hajj Rituals
2701,حَدَّثَنَا أَبُو مُصْعَبٍ، حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، عَنْ أَبِي الأَسْوَدِ، مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ نَوْفَلٍ - وَكَانَ يَتِيمًا فِي حِجْرِ عُرْوَةَ بْنِ الزُّبَيْرِ - عَنْ عُرْوَةَ بْنِ الزُّبَيْرِ، عَنْ عَائِشَةَ أُمِّ الْمُؤْمِنِينَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ أَفْرَدَ الْحَجَّ ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأ شراف:۳۰۰۰، ومصباح الزجاجة:۹۵۶),2701,,Chapters on Hajj Rituals
2702,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا عَبْدُ الْعَزِيزِ الدَّرَاوَرْدِيُّ، وَحَاتِمُ بْنُ إِسْمَاعِيلَ، عَنْ جَعْفَرِ بْنِ مُحَمَّدٍ، عَنْ أَبِيهِ، عَنْ جَابِرٍ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ أَفْرَدَ الْحَجَّ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأ شراف:۷۶۶۳ ألف),2702,,Chapters on Hajj Rituals
2703,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا الْقَاسِمُ بْنُ عَبْدِ اللَّهِ الْعُمَرِيُّ، عَنْ مُحَمَّدِ بْنِ الْمُنْكَدِرِ، عَنْ جَابِرٍ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ وَأَبَا بَكْرٍ وَعُمَرَ وَعُثْمَانَ أَفْرَدُوا الْحَجَّ ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأ شراف:۸۴۳، ومصباح الزجاجة:۹۵۷),2703,,Chapters on Hajj Rituals
2704,"حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ، حَدَّثَنَا عَبْدُ الأَعْلَى بْنُ عَبْدِ الأَعْلَى، حَدَّثَنَا يَحْيَى بْنُ أَبِي إِسْحَاقَ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ خَرَجْنَا مَعَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ إِلَى مَكَّةَ فَسَمِعْتُهُ يَقُولُ ‏ ‏ لَبَّيْكَ عُمْرَةً وَحَجَّةً ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۳۴۹۵، ومصباح الزجاجة:۹۵۸)، وقد أخرجہ: سنن ابی داود/الوصایا ۳ (۲۸۶۷)، سنن الترمذی/الوصایا ۲ (۲۱۱۷)، مسند احمد (۲/۲۷۸),,It was\nnarrated that Anas bin Malik said:,Chapters on Hajj Rituals
2705,"حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ، حَدَّثَنَا عَبْدُ الْوَهَّابِ، حَدَّثَنَا حُمَيْدٌ، عَنْ أَنَسٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ لَبَّيْكَ بِعُمْرَةٍ وَحَجَّةٍ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Very Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأ شراف:۱۱۰۸۶، ومصباح الزجاجة:۹۵۹),,It was\nnarrated from Anas that the Prophet (ﷺ) said:,Chapters on Hajj Rituals
2706,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَهِشَامُ بْنُ عَمَّارٍ، قَالاَ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عَبْدَةَ بْنِ أَبِي لُبَابَةَ، قَالَ سَمِعْتُ أَبَا وَائِلٍ، شَقِيقَ بْنَ سَلَمَةَ يَقُولُ سَمِعْتُ الصُّبَىَّ بْنَ مَعْبَدٍ، يَقُولُ كُنْتُ رَجُلاً نَصْرَانِيًّا فَأَسْلَمْتُ فَأَهْلَلْتُ بِالْحَجِّ وَالْعُمْرَةِ فَسَمِعَنِي سَلْمَانُ بْنُ رَبِيعَةَ وَزَيْدُ بْنُ صُوحَانَ وَأَنَا أُهِلُّ بِهِمَا جَمِيعًا بِالْقَادِسِيَّةِ فَقَالاَ لَهَذَا أَضَلُّ مِنْ بَعِيرِهِ فَكَأَنَّمَا حَمَلاَ عَلَىَّ جَبَلاً بِكَلِمَتِهِمَا فَقَدِمْتُ عَلَى عُمَرَ بْنِ الْخَطَّابِ فَذَكَرْتُ ذَلِكَ لَهُ فَأَقْبَلَ عَلَيْهِمَا فَلاَمَهُمَا ثُمَّ أَقْبَلَ عَلَىَّ فَقَالَ هُدِيتَ لِسُنَّةِ النَّبِيِّ ـ صلى الله عليه وسلم ـ هُدِيتَ لِسُنَّةِ النَّبِيِّ ـ صلى الله عليه وسلم ـ ‏.‏ قَالَ هِشَامٌ فِي حَدِيثِهِ قَالَ شَقِيقٌ: فَكَثِيرًا مَا ذَهَبْتُ أَنَا وَمَسْرُوقٌ نَسْأَلُهُ عَنْهُ ‏.‏ حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، وَأَبُو مُعَاوِيَةَ وَخَالِي يَعْلَى قَالُوا حَدَّثَنَا الأَعْمَشُ، عَنْ شَقِيقٍ، عَنِ الصُّبَىِّ بْنِ مَعْبَدٍ، قَالَ كُنْتُ حَدِيثَ عَهْدٍ بِنَصْرَانِيَّةٍ فَأَسْلَمْتُ فَلَمْ آلُ أَنْ أَجْتَهِدَ، فَأَهْلَلْتُ بِالْحَجِّ وَالْعُمْرَةِ ‏.‏ فَذَكَرَ نَحْوَهُ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الأدب ۲ (۵۹۷۱)، صحیح مسلم/البر والصلة ۱ (۲۵۴۸)،(تحفة الأشراف:۱۴۹۰۵)، وقد أخرجہ: مسند احمد۲/۳۹۱),,It was\nnarrated that ‘Abdah bin Abu Lubabah said:,Chapters on Hajj Rituals
2707,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، حَدَّثَنَا حَجَّاجٌ، عَنِ الْحَسَنِ بْنِ سَعْدٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ أَخْبَرَنِي أَبُو طَلْحَةَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَرَنَ الْحَجَّ وَالْعُمْرَةَ ‏.‏,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأ شراف:۲۰۱۸، ومصباح الزجاجة:۹۶۰)، وقد أخرجہ: مسند احمد (۴/۲۱۰),2707,It was\nnarrated that Ibn ‘Abbas said:,Chapters on Hajj Rituals
2708,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا يَحْيَى بْنُ يَعْلَى بْنِ حَارِثٍ الْمُحَارِبِيُّ، حَدَّثَنَا أَبِي، عَنْ غَيْلاَنَ بْنِ جَامِعٍ، عَنْ لَيْثٍ، عَنْ عَطَاءٍ، وَطَاوُسٍ، وَمُجَاهِدٍ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، وَابْنِ، عُمَرَ وَابْنِ عَبَّاسٍ أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ لَمْ يَطُفْ هُوَ وَأَصْحَابُهُ لِعُمْرَتِهِمْ وَحَجَّتِهِمْ حِينَ قَدِمُوا إِلاَّ طَوَافًا وَاحِدًا ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الجنائز ۳۶ (۱۲۹۵)، الوصایا ۲ (۲۷۴۲)،۳ (۲۷۴۴)، مناقب الأنصار ۴۹ (۳۹۳۶)، المغازي ۷۷ (۴۳۹۵)، النفقات ۱ (۵۳۵۴)، المرضی ۱۳ (۵۶۵۹)،۱۶ (۵۶۶۸)، الدعوات ۴۳ (۶۳۷۳)، الفرائض ۶ (۶۷۳۳)، صحیح مسلم/الوصایا ۲ (۱۶۲۸)، سنن ابی داود/الوصایا ۲ (۲۸۶۴)، سنن الترمذی/الجنائز ۶ (۹۷۵)، الوصایا ۱ (۲۱۱۷)، سنن النسائی/الوصایا ۳ (۳۶۵۶)،(تحفة الأ شراف:۳۸۹۰)، وقد أخرجہ: موطا امام مالک/الوصایا ۳ (۴)، مسند احمد (۱/۱۶۸،۱۷۲،۱۷۶،۱۷۹)، سنن الدارمی/الوصایا ۷ (۳۲۳۸),2708,,Chapters on Hajj Rituals
2709,حَدَّثَنَا هَنَّادُ بْنُ السَّرِيِّ، حَدَّثَنَا عَبْثَرُ بْنُ الْقَاسِمِ، عَنْ أَشْعَثَ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ طَافَ لِلْحَجِّ وَالْعُمْرَةِ طَوَافًا وَاحِدًا ‏.‏,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأ شراف:۱۴۱۸۰، ومصباح الزجاجة:۹۶۱),2709,,Chapters on Hajj Rituals
2710,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا مُسْلِمُ بْنُ خَالِدٍ الزَّنْجِيُّ، حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ عُمَرَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّهُ قَدِمَ قَارِنًا فَطَافَ بِالْبَيْتِ سَبْعًا وَسَعَى بَيْنَ الصَّفَا وَالْمَرْوَةِ ثُمَّ قَالَ هَكَذَا فَعَلَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأ شراف:۸۴۰۷، ومصباح الزجاجة:۹۶۲),2710,"It was\nnarrated from Ibn ‘Umar that he came (to Makkah) to perform\nHajj\nand ‘Umrah together (Qiran). He circumambulated the House seven\ntimes, and performed Sa’y between Safa and Marwah, then he said:",Chapters on Hajj Rituals
2711,"حَدَّثَنَا مُحْرِزُ بْنُ سَلَمَةَ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ، عَنْ عُبَيْدِ اللَّهِ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ مَنْ أَحْرَمَ بِالْحَجِّ وَالْعُمْرَةِ كَفَى لَهُمَا طَوَافٌ وَاحِدٌ وَلَمْ يَحِلَّ حَتَّى يَقْضِيَ حَجَّهُ وَيَحِلَّ مِنْهُمَا جَمِيعًا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الوصایا ۳ (۲۷۴۳)، صحیح مسلم/الوصایا۱ (۱۶۲۹)، سنن النسائی/الوصایا ۳ (۳۶۶۴)،(تحفة الأ شراف:۸۴۰۴)، وقد آخرجہ: مسند احمد (۱/۲۳۰،۲۳۳),,It was\nnarrated from Ibn ‘Umar that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Hajj Rituals
2712,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا مُحَمَّدُ بْنُ مُصْعَبٍ، ح وَحَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ الدِّمَشْقِيُّ، - يَعْنِي دُحَيْمًا - حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، قَالاَ حَدَّثَنَا الأَوْزَاعِيُّ، حَدَّثَنِي يَحْيَى بْنُ أَبِي كَثِيرٍ، حَدَّثَنِي عِكْرِمَةُ، قَالَ حَدَّثَنَا ابْنُ عَبَّاسٍ، قَالَ حَدَّثَنِي عُمَرُ بْنُ الْخَطَّابِ، قَالَ سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ وَهُوَ بِالْعَقِيقِ ‏ ‏ أَتَانِي آتٍ مِنْ رَبِّي فَقَالَ صَلِّ فِي هَذَا الْوَادِي الْمُبَارَكِ وَقُلْ عُمْرَةٌ فِي حَجَّةٍ ‏""""‏ ‏.‏ وَاللَّفْظُ لِدُحَيْمٍ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن الترمذی/الوصایا ۵ (۲۱۲۱مطولاً)، سنن النسائی/الوصایا ۴ (۳۶۷۱)،(تحفة الأ شراف:۱۰۷۳۱)، وقد أخرجہ: مسند احمد (۴/۱۸۶،۱۸۷،۲۳۸،۲۳۹)، سنن الدارمی/الوصایا ۲۸ (۳۳۰۳),,‘Umar\nbin Khattab said:,Chapters on Hajj Rituals
2713,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا وَكِيعٌ، عَنْ مِسْعَرٍ، عَنْ عَبْدِ الْمَلِكَ بْنِ مَيْسَرَةَ، عَنْ طَاوُسٍ، عَنْ سُرَاقَةَ بْنِ جُعْشُمٍ، قَالَ قَامَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ خَطِيبًا فِي هَذَا الْوَادِي فَقَالَ ‏ ‏ أَلاَ إِنَّ الْعُمْرَةَ قَدْ دَخَلَتْ فِي الْحَجِّ إِلَى يَوْمِ الْقِيَامَةِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/البیوع ۹۰ (۳۵۶۵)، سنن الترمذی/الوصایا ۵ (۲۱۲۰)،(تحفة الأ شراف:۴۸۸۲)، وقد أخرجہ: مسند احمد (۵/۲۶۷),,It was\nnarrated that Suraqah bin Ju’shum said:,Chapters on Hajj Rituals
2714,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا أَبُو أُسَامَةَ، عَنِ الْجُرَيْرِيِّ، عَنْ أَبِي الْعَلاَءِ، يَزِيدَ بْنِ الشِّخِّيرِ عَنْ أَخِيهِ، مُطَرِّفِ بْنِ عَبْدِ اللَّهِ بْنِ الشِّخِّيرِ قَالَ قَالَ لِي عِمْرَانُ بْنُ الْحُصَيْنِ إِنِّي أُحَدِّثُكَ حَدِيثًا لَعَلَّ اللَّهَ أَنْ يَنْفَعَكَ بِهِ بَعْدَ الْيَوْمِ اعْلَمْ أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَدْ أَعْمَرَ طَائِفَةً مِنْ أَهْلِهِ فِي الْعَشْرِ مِنْ ذِي الْحِجَّةِ وَلَمْ يَنْهَ عَنْهُ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ وَلَمْ يَنْزِلْ نَسْخُهُ قَالَ فِي ذَلِكَ بَعْدُ رَجُلٌ بِرَأْيِهِ مَا شَاءَ أَنْ يَقُولَ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأ شراف:۸۶۳، ومصباح الزجاجة:۹۶۳),2714,It was\nnarrated that Mutarrif bin ‘Abdullah bin Shikhkhir said:,Chapters on Hajj Rituals
2715,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَمُحَمَّدُ بْنُ بَشَّارٍ، قَالاَ حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، ح وَحَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ، حَدَّثَنِي أَبِي قَالاَ، حَدَّثَنَا شُعْبَةُ، عَنِ الْحَكَمِ، عَنْ عُمَارَةَ بْنِ عُمَيْرٍ، عَنْ إِبْرَاهِيمَ بْنِ أَبِي مُوسَى، عَنْ أَبِي مُوسَى الأَشْعَرِيِّ، أَنَّهُ كَانَ يُفْتِي بِالْمُتْعَةِ فَقَالَ لَهُ رَجُلٌ رُوَيْدَكَ بَعْضَ فُتْيَاكَ فَإِنَّكَ لاَ تَدْرِي مَا أَحْدَثَ أَمِيرُ الْمُؤْمِنِينَ فِي النُّسُكِ بَعْدَكَ ‏.‏ حَتَّى لَقِيتُهُ بَعْدُ فَسَأَلْتُهُ فَقَالَ عُمَرُ قَدْ عَلِمْتُ أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ فَعَلَهُ وَأَصْحَابُهُ وَلَكِنِّي كَرِهْتُ أَنْ يَظَلُّوا بِهِنَّ مُعْرِسِينَ تَحْتَ الأَرَاكِ ثُمَّ يَرُوحُونَ بِالْحَجِّ تَقْطُرُ رُءُوسُهُمْ ‏.‏,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/الفرائض ۵ (۲۰۹۴،۲۰۹۵)،(تحفة الأ شراف:۱۰۰۴۳)، وقد أخرجہ: مسند احمد (۱/۷۹،۱۳۱،۱۴۴)، سنن الدارمی/الفرائض ۲۸ (۳۰۲۷),2715,It was\nnarrated from Ibrahim bin Abu Musa:,Chapters on Hajj Rituals
2716,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ الدِّمَشْقِيُّ، حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، حَدَّثَنَا الأَوْزَاعِيُّ، عَنْ عَطَاءٍ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، قَالَ أَهْلَلْنَا مَعَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ بِالْحَجِّ خَالِصًا لاَ نَخْلِطُهُ بِعُمْرَةٍ فَقَدِمْنَا مَكَّةَ لأَرْبَعِ لَيَالٍ خَلَوْنَ مِنْ ذِي الْحِجَّةِ فَلَمَّا طُفْنَا بِالْبَيْتِ وَسَعَيْنَا بَيْنَ الصَّفَا وَالْمَرْوَةِ أَمَرَنَا رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ أَنْ نَجْعَلَهَا عُمْرَةً وَأَنْ نَحِلَّ إِلَى النِّسَاءِ ‏.‏ فَقُلْنَا مَا بَيْنَنَا لَيْسَ بَيْنَنَا وَبَيْنَ عَرَفَةَ إِلاَّ خَمْسٌ فَنَخْرُجُ إِلَيْهَا وَمَذَاكِيرُنَا تَقْطُرُ مَنِيًّا فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏""‏ إِنِّي لأَبَرُّكُمْ وَأَصْدَقُكُمْ وَلَوْلاَ الْهَدْىُ لأَحْلَلْتُ ‏""‏ ‏.‏ فَقَالَ سُرَاقَةُ بْنُ مَالِكٍ أَمُتْعَتُنَا هَذِهِ لِعَامِنَا هَذَا أَمْ لأَبَدٍ فَقَالَ ‏""‏ لاَ بَلْ لأَبَدِ الأَبَدِ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۴۰۴۳)، وقد أخرجہ: صحیح مسلم/الوصیة ۲ (۱۶۳۰),2716,It was\nnarrated that Jabir bin ‘Abdullah said:,Chapters on Hajj Rituals
2717,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، عَنْ يَحْيَى بْنِ سَعِيدٍ، عَنْ عَمْرَةَ، عَنْ عَائِشَةَ، قَالَتْ خَرَجْنَا مَعَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ لِخَمْسٍ بَقِينَ مِنْ ذِي الْقَعْدَةِ لاَ نُرَى إِلاَّ الْحَجَّ حَتَّى إِذَا قَدِمْنَا وَدَنَوْنَا أَمَرَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ مَنْ لَمْ يَكُنْ مَعَهُ هَدْىٌ أَنْ يَحِلَّ فَحَلَّ النَّاسُ كُلُّهُمْ إِلاَّ مَنْ كَانَ مَعَهُ هَدْىٌ فَلَمَّا كَانَ يَوْمُ النَّحْرِ دُخِلَ عَلَيْنَا بِلَحْمِ بَقَرٍ فَقِيلَ ذَبَحَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنْ أَزْوَاجِهِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الزکاة ۱۵ (۱۰۰۴)، الوصیة ۲ (۱۶۳۰)،(تحفة الأ شراف:۱۶۸۱۹)، وقد أخرجہ: صحیح البخاری/الوصایا ۱۹ (۲۹۶۰)، سنن ابی داود/الوصیة ۱۵ (۲۸۸۱)، سنن النسائی/الوصیة ۷ (۳۶۷۹)، موطا امام مالک/الأقضیة ۴۱ (۵۳)، مسند احمد (۶/۵۱),2717,It was\nnarrated that ‘Aishah said:,Chapters on Hajj Rituals
2718,"حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، حَدَّثَنَا أَبُو بَكْرِ بْنُ عَيَّاشٍ، عَنْ أَبِي إِسْحَاقَ، عَنِ الْبَرَاءِ بْنِ عَازِبٍ، قَالَ خَرَجَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ وَأَصْحَابُهُ فَأَحْرَمْنَا بِالْحَجِّ فَلَمَّا قَدِمْنَا مَكَّةَ قَالَ ‏""‏ اجْعَلُوا حَجَّكُمْ عُمْرَةً ‏""‏ ‏.‏ فَقَالَ النَّاسُ يَا رَسُولَ اللَّهِ قَدْ أَحْرَمْنَا بِالْحَجِّ فَكَيْفَ نَجْعَلُهَا عُمْرَةً قَالَ ‏""‏ انْظُرُوا مَا آمُرُكُمْ بِهِ فَافْعَلُوا ‏""‏ ‏.‏ فَرَدُّوا عَلَيْهِ الْقَوْلَ فَغَضِبَ فَانْطَلَقَ حَتَّى دَخَلَ عَلَى عَائِشَةَ غَضْبَانَ فَرَأَتِ الْغَضَبَ فِي وَجْهِهِ فَقَالَتْ مَنْ أَغْضَبَكَ أَغْضَبَهُ اللَّهُ قَالَ ‏""‏ وَمَالِي لاَ أَغْضَبُ وَأَنَا آمُرُ أَمْرًا فَلاَ أُتْبَعُ ‏""‏ ‏.‏",Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الوصایا ۸ (۲۸۷۲)، سنن النسائی/الوصایا ۱۰ (۳۶۹۸)،(تحفة الأ شراف:۸۶۸۱)، وقد أخرجہ: مسند احمد (۲/۱۸۶،۲۱۶),2718,It was\nnarrated that Bara’ bin ‘Azib said:,Chapters on Hajj Rituals
2719,"حَدَّثَنَا بَكْرُ بْنُ خَلَفٍ أَبُو بِشْرٍ، حَدَّثَنَا أَبُو عَاصِمٍ، أَنْبَأَنَا ابْنُ جُرَيْجٍ، أَخْبَرَنِي مَنْصُورُ بْنُ عَبْدِ الرَّحْمَنِ، عَنْ أُمِّهِ، صَفِيَّةَ عَنْ أَسْمَاءَ بِنْتِ أَبِي بَكْرٍ، قَالَتْ خَرَجْنَا مَعَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ مُحْرِمِينَ فَقَالَ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ كَانَ مَعَهُ هَدْىٌ فَلْيُقِمْ عَلَى إِحْرَامِهِ وَمَنْ لَمْ يَكُنْ مَعَهُ هَدْىٌ فَلْيَحْلِلْ ‏""""‏ ‏.‏ قَالَتْ وَلَمْ يَكُنْ مَعِي هَدْىٌ فَأَحْلَلْتُ وَكَانَ مَعَ الزُّبَيْرِ هَدْىٌ فَلَمْ يَحِلَّ فَلَبِسْتُ ثِيَابِي وَجِئْتُ إِلَى الزُّبَيْرِ فَقَالَ قُومِي عَنِّي ‏.‏ فَقُلْتُ أَتَخْشَى أَنْ أَثِبَ عَلَيْكَ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۳۶۵۸، ومصباح الزجاجة:۹۶۴)، وقد أخرجہ: سنن الترمذی/الفرائض ۲ (۲۰۹۱),,It was\nnarrated that Asma’ bint Abi Bakr said:,Chapters on Hajj Rituals
2720,"حَدَّثَنَا أَبُو مُصْعَبٍ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ الدَّرَاوَرْدِيُّ، عَنْ رَبِيعَةَ بْنِ أَبِي عَبْدِ الرَّحْمَنِ، عَنِ الْحَارِثِ بْنِ بِلاَلِ بْنِ الْحَارِثِ، عَنْ أَبِيهِ، قَالَ قُلْتُ يَا رَسُولَ اللَّهِ أَرَأَيْتَ فَسْخَ الْحَجِّ فِي الْعُمْرَةِ لَنَا خَاصَّةً أَمْ لِلنَّاسِ عَامَّةً فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ بَلْ لَنَا خَاصَّةً ‏""""‏ ‏.‏""",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الفرائض ۴ (۲۸۹۱،۲۸۹۲)، سنن الترمذی/الفرائض ۳ (۲۰۹۲)،(تحفة الأشراف:۲۳۶۵)، وقد أخرجہ: مسند احمد۳/۳۵۲),,"It was\nnarrated from Harith bin Bilal bin Harith, that his father\nsaid:",Chapters on Hajj Rituals
2721,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، عَنِ الأَعْمَشِ، عَنْ إِبْرَاهِيمَ التَّيْمِيِّ، عَنْ أَبِيهِ، عَنْ أَبِي ذَرٍّ، قَالَ كَانَتِ الْمُتْعَةُ فِي الْحَجِّ لأَصْحَابِ مُحَمَّدٍ ـ صلى الله عليه وسلم ـ خَاصَّةً ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الفرائض ۸ (۶۷۳۶)، سنن ابی داود/الفرائض ۴ (۲۸۹۰)، سنن الترمذی/الفرائض ۴ (۲۰۹۳)،(تحفة الأشراف:۹۵۹۴)، وقد أخرجہ: مسند احمد (۱/۳۸۹،۴۲۸،۴۴۰،۴۶۳)، سنن الدارمی/الفرائض ۷ (۲۹۳۲),2721,It was\nnarrated that Abu Dharr said:,Chapters on Hajj Rituals
2722,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو أُسَامَةَ، عَنْ هِشَامِ بْنِ عُرْوَةَ، قَالَ أَخْبَرَنِي أَبِي قَالَ، قُلْتُ لِعَائِشَةَ مَا أَرَى عَلَىَّ جُنَاحًا أَنْ لاَ أَطَّوَّفَ بَيْنَ الصَّفَا وَالْمَرْوَةِ ‏.‏ قَالَتْ إِنَّ اللَّهَ يَقُولُ ‏{إِنَّ الصَّفَا وَالْمَرْوَةَ مِنْ شَعَائِرِ اللَّهِ فَمَنْ حَجَّ الْبَيْتَ أَوِ اعْتَمَرَ فَلاَ جُنَاحَ عَلَيْهِ أَنْ يَطَّوَّفَ بِهِمَا}‏ وَلَوْ كَانَ كَمَا تَقُولُ لَكَانَ فَلاَ جُنَاحَ عَلَيْهِ أَنْ لاَ يَطَّوَّفَ بِهِمَا ‏.‏ إِنَّمَا أُنْزِلَ هَذَا فِي نَاسٍ مِنَ الأَنْصَارِ كَانُوا إِذَا أَهَلُّوا أَهَلُّوا لِمَنَاةَ فَلاَ يَحِلُّ لَهُمْ أَنْ يَطَّوَّفُوا بَيْنَ الصَّفَا وَالْمَرْوَةِ فَلَمَّا قَدِمُوا مَعَ النَّبِيِّ ـ صلى الله عليه وسلم ـ فِي الْحَجِّ ذَكَرُوا ذَلِكَ لَهُ فَأَنْزَلَهَا اللَّهُ فَلَعَمْرِي مَا أَتَمَّ اللَّهُ عَزَّ وَجَلَّ حَجَّ مَنْ لَمْ يَطُفْ بَيْنَ الصَّفَا وَالْمَرْوَةِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih Lighairihi; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأ شراف:۱۱۴۷۲)، وقد أخرجہ: سنن ابی داود/الفرائض ۶ (۲۸۹۷)، مسند احمد (۵/۲۷),2722,It was\nnarrated that Hisham bin ‘Urwah said:,Chapters on Hajj Rituals
2723,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا هِشَامٌ الدَّسْتَوَائِيُّ، عَنْ بُدَيْلِ بْنِ مَيْسَرَةَ، عَنْ صَفِيَّةَ بِنْتِ شَيْبَةَ، عَنْ أُمِّ وَلَدِ، شَيْبَةَ قَالَتْ رَأَيْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَسْعَى بَيْنَ الصَّفَا وَالْمَرْوَةِ وَهُوَ يَقُولُ ‏ ‏ لاَ يُقْطَعُ الأَبْطَحُ إِلاَّ شَدًّا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الفرائض ۶ (۲۸۹۷)،(تحفة الأشراف:۱۱۳۶۷)، وقد أخرجہ: مسند احمد (۵/۲۷),,It was\nnarratd that an Umm Walad* of Shaibah said:,Chapters on Hajj Rituals
2724,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، وَعَمْرُو بْنُ عَبْدِ اللَّهِ، قَالاَ حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا أَبِي، عَنْ عَطَاءِ بْنِ السَّائِبِ، عَنْ كَثِيرِ بْنِ جُمْهَانَ، عَنِ ابْنِ عُمَرَ، قَالَ إِنْ أَسْعَ بَيْنَ الصَّفَا وَالْمَرْوَةِ فَقَدْ رَأَيْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَسْعَى وَإِنْ أَمْشِ فَقَدْ رَأَيْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَمْشِي وَأَنَا شَيْخٌ كَبِيرٌ ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: سنن ابی داود/الفرائض ۵ (۲۸۹۴)، سنن الترمذی/الفرائض ۱۰ (۲۱۰۰،۲۱۰۱)،(تحفة الأشراف:۱۱۲۳۲،۱۱۵۲۲)، وقد أخرجہ: موطا امام مالک/الفرائض ۸ (۴)مسند احمد (۴/ ۲۲۵),2724,It was\nnarrated that Ibn ‘Umar said:,Chapters on Hajj Rituals
2725,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا الْحَسَنُ بْنُ يَحْيَى الْخُشَنِيُّ، حَدَّثَنَا عُمَرُ بْنُ قَيْسٍ، أَخْبَرَنِي طَلْحَةُ بْنُ يَحْيَى، عَنْ عَمِّهِ، إِسْحَاقَ بْنِ طَلْحَةَ عَنْ طَلْحَةَ بْنِ عُبَيْدِ اللَّهِ، أَنَّهُ سَمِعَ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ الْحَجُّ جِهَادٌ وَالْعُمْرَةُ تَطَوُّعٌ ‏""""‏ ‏.‏""",Al-Albani: Daif Isnaad; Muhammad Fouad Abd al-Baqi: Daif Isnaad; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۷۴۶، ومصباح الزجاجة:۹۶۵)، وقد أخرجہ: سنن الدارمی/الفرائض ۱۸ (۲۹۷۵),,It was\nnarrated from Talhah bin ‘Ubaidullah that he heard the\nMessenger of\nAllah (ﷺ) say:,Chapters on Hajj Rituals
2726,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا يَعْلَى، حَدَّثَنَا إِسْمَاعِيلُ، سَمِعْتُ عَبْدَ اللَّهِ بْنَ أَبِي أَوْفَى، يَقُولُ كُنَّا مَعَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ حِينَ اعْتَمَرَ فَطَافَ وَطُفْنَا مَعَهُ وَصَلَّى وَصَلَّيْنَا مَعَهُ وَكُنَّا نَسْتُرُهُ مِنْ أَهْلِ مَكَّةَ لاَ يُصِيبُهُ أَحَدٌ بِشَىْءٍ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «صحیح مسلم/الفرائض ۲ (۱۶۱۷)،(تحفة الأشراف:۱۰۶۴۶)، وقد أخرجہ: موطا امام مالک/الفرائض ۹ (۷)، مسند احمد (۱/۱۵،۲۶،۲۷،۴۸),2726,Isma’il\nnarrated:,Chapters on Hajj Rituals
2727,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا سُفْيَانُ، عَنْ بَيَانٍ، وَجَابِرٍ، عَنِ الشَّعْبِيِّ، عَنْ وَهْبِ بْنِ خَنْبَشٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ عُمْرَةٌ فِي رَمَضَانَ تَعْدِلُ حِجَّةً ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۶۴۰، ومصباح الزجاجة:۹۶۷),,It was\nnarrated from Wahb bin Khanbash that the Messenger of Allah\n(ﷺ)\nsaid:,Chapters on Hajj Rituals
2728,"حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، حَدَّثَنَا سُفْيَانُ، ح وَحَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، وَعَمْرُو بْنُ عَبْدِ اللَّهِ، قَالاَ حَدَّثَنَا وَكِيعٌ، جَمِيعًا عَنْ دَاوُدَ بْنِ يَزِيدَ الزَّعَافِرِيِّ، عَنِ الشَّعْبِيِّ، عَنْ هَرِمِ بْنِ خَنْبَشٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ عُمْرَةٌ فِي رَمَضَانَ تَعْدِلُ حِجَّةً ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الفرائض ۱۳ (۶۷۴۳)، صحیح مسلم/الفرائض ۲ (۱۶۱۶)، سنن ابی داود/الفرائض ۲ (۲۸۸۶)، سنن الترمذی/الفرائض ۷ (۲۰۹۷)،(تحفة الأشراف:۳۰۲۸)، وقد أخرجہ: سنن الدارمی/الطہارة ۵۵ (۷۳۹),,It was\nnarrated from Harim bin Khanbash that the Messenger of Allah\n(ﷺ)\nsaid:,Chapters on Hajj Rituals
2729,"حَدَّثَنَا جُبَارَةُ بْنُ الْمُغَلِّسِ، حَدَّثَنَا إِبْرَاهِيمُ بْنُ عُثْمَانَ، عَنْ أَبِي إِسْحَاقَ، عَنِ الأَسْوَدِ بْنِ يَزِيدَ، عَنْ أَبِي مَعْقِلٍ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ عُمْرَةٌ فِي رَمَضَانَ تَعْدِلُ حِجَّةً ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحج ۴۴ (۱۵۸۸)، المغازي ۴۸ (۴۲۸۳)، الفرائض ۲۶ (۶۷۶۴)، صحیح مسلم/الفرائض ۱ (۱۶۱۴)، سنن ابی داود/الفرائض ۱۰ (۲۹۰۹)، سنن الترمذی/الفرائض ۱۵ (۲۱۰۷)،(تحفة الأشراف:۱۱۳)، وقد أخرجہ: موطا امام مالک/الفرائض۱۳ (۱۰)، مسند احمد (۵/۲۰۰،۲۰۱،۲۰۸،۲۰۹)، سنن الدارمی/الفرائض ۲۹ (۳۰۴۱),,It was\nnarrated from Abu Ma’qil that the Prophet (ﷺ) said:,Chapters on Hajj Rituals
2730,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، عَنْ حَجَّاجٍ، عَنْ عَطَاءٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ عُمْرَةٌ فِي رَمَضَانَ تَعْدِلُ حِجَّةً ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: حدیث '' لایرث المسلم الکافر '' تقدم تخریجہ بالحدیث السابق (۲۷۲۹)، وحدیث '' وہل ترک لنا عقیل '' أخرجہ: صحیح البخاری/الحج ۴۴ (۱۵۸۸)، الجہاد ۱۸۰ (۳۰۵۸)، المغازي ۴۸ (۴۲۸۲)، صحیح مسلم/الحج ۸۰ (۱۳۵۱)، سنن ابی داود/المناسک (۲۰۱۰)،(تحفة الأشراف:۱۱۴)، وقد أخرجہ: موطا امام مالک/الفرائض ۱۳ (۱۰)، مسند احمد (۲/۲۳۷، سنن الدارمی/الفرائض ۲۹ (۳۰۳۶),,It was\nnarrated from Ibn ‘Abbas that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Hajj Rituals
2731,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَحْمَدُ بْنُ عَبْدِ الْمَلِكِ بْنِ وَاقِدٍ، حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ عَمْرٍو، عَنْ عَبْدِ الْكَرِيمِ، عَنْ عَطَاءٍ، عَنْ جَابِرٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ عُمْرَةٌ فِي رَمَضَانَ تَعْدِلُ حِجَّةً ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: «تفردبہ ابن ماجہ:(تحفة الأشراف:۸۷۸۰)، وقد أخرجہ: سنن ابی داود/الفرائض ۱۰ (۲۹۱۱)، سنن الترمذی/الفرائض ۱۶ (۲۱۰۹)، مسند احمد (۲/۱۷۸،۱۹۵),,It was\nnarrated from Jabir that the Prophet (ﷺ) said:,Chapters on Hajj Rituals
2732,حَدَّثَنَا عُثْمَانُ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَحْيَى بْنُ زَكَرِيَّا بْنِ أَبِي زَائِدَةَ، عَنِ ابْنِ أَبِي لَيْلَى، عَنْ عَطَاءٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ لَمْ يَعْتَمِرْ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ إِلاَّ فِي ذِي الْقَعْدَةِ ‏.‏,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الفرائض ۱۲ (۲۹۱۷)،(تحفة الأشراف:۱۰۵۸۱)، وقد أخرجہ: مسند احمد (۱/۲۷),2732,,Chapters on Hajj Rituals
2733,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، عَنِ الأَعْمَشِ، عَنْ مُجَاهِدٍ، عَنْ عَائِشَةَ، قَالَتْ لَمْ يَعْتَمِرْ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عُمْرَةً إِلاَّ فِي ذِي الْقَعْدَةِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Hasan,takhreej: «سنن ابی داود/الفرائض ۸ (۲۹۰۲)، سنن الترمذی/الفرائض ۱۳ (۲۱۰۵)،(تحفة الأشراف:۱۶۳۸۱)، وقد أخرجہ: مسند احمد (۶/۱۳۷،۱۷۴،۱۸۱),2733,It was\nnarrated that ‘Aishah said:,Chapters on Hajj Rituals
2734,حَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا يَحْيَى بْنُ آدَمَ، عَنْ أَبِي بَكْرِ بْنِ عَيَّاشٍ، عَنِ الأَعْمَشِ، عَنْ حَبِيبٍ، - يَعْنِي ابْنَ أَبِي ثَابِتٍ - عَنْ عُرْوَةَ، قَالَ سُئِلَ ابْنُ عُمَرَ فِي أَىِّ شَهْرٍ اعْتَمَرَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ فِي رَجَبٍ ‏.‏ فَقَالَتْ عَائِشَةُ مَا اعْتَمَرَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ فِي رَجَبٍ قَطُّ وَمَا اعْتَمَرَ إِلاَّ وَهُوَ مَعَهُ - تَعْنِي ابْنَ عُمَرَ ‏.‏,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۸۳۷۲، ومصباح الزجاجة:۹۶۶)، وقد أخرجہ: سنن الدارمی/الفرائض ۳۱ (۳۰۵۶),2734,It was\nnarrated that ‘Urwah said:,Chapters on Hajj Rituals
2735,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَأَبُو إِسْحَاقَ الشَّافِعِيُّ إِبْرَاهِيمُ بْنُ مُحَمَّدِ بْنِ الْعَبَّاسِ بْنِ عُثْمَانَ بْنِ شَافِعٍ قَالاَ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عَمْرِو بْنِ دِينَارٍ، أَخْبَرَنِي عَمْرُو بْنُ أَوْسٍ، حَدَّثَنِي عَبْدُ الرَّحْمَنِ بْنُ أَبِي بَكْرٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ أَمَرَهُ أَنْ يُرْدِفَ عَائِشَةَ فَيُعْمِرَهَا مِنَ التَّنْعِيمِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Hasan,takhreej: «سنن الترمذی/الفرائض ۱۷ (۲۱۰۹)،(تحفة الأ شراف:۱۲۲۸۶)وقد مضی برقم:(۲۶۴۵),2735,,Chapters on Hajj Rituals
2736,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدَةُ بْنُ سُلَيْمَانَ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، قَالَتْ خَرَجْنَا مَعَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ فِي حِجَّةِ الْوَدَاعِ نُوَافِي هِلاَلَ ذِي الْحِجَّةِ فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏""‏ مَنْ أَرَادَ مِنْكُمْ أَنْ يُهِلَّ بِعُمْرَةٍ فَلْيُهْلِلْ فَلَوْلاَ أَنِّي أَهْدَيْتُ لأَهْلَلْتُ بِعُمْرَةٍ ‏""‏ ‏.‏ قَالَتْ فَكَانَ مِنَ الْقَوْمِ مَنْ أَهَلَّ بِعُمْرَةٍ وَمِنْهُمْ مَنْ أَهَلَّ بِحَجٍّ فَكُنْتُ أَنَا مِمَّنْ أَهَلَّ بِعُمْرَةٍ ‏.‏ قَالَتْ فَخَرَجْنَا حَتَّى قَدِمْنَا مَكَّةَ فَأَدْرَكَنِي يَوْمُ عَرَفَةَ وَأَنَا حَائِضٌ لَمْ أَحِلَّ مِنْ عُمْرَتِي فَشَكَوْتُ ذَلِكَ إِلَى النَّبِيِّ ـ صلى الله عليه وسلم ـ فَقَالَ ‏""‏ دَعِي عُمْرَتَكِ وَانْقُضِي رَأْسَكِ وَامْتَشِطِي وَأَهِلِّي بِالْحَجِّ ‏""‏ ‏.‏ قَالَتْ فَفَعَلْتُ فَلَمَّا كَانَتْ لَيْلَةُ الْحَصْبَةِ وَقَدْ قَضَى اللَّهُ حَجَّنَا أَرْسَلَ مَعِي عَبْدَ الرَّحْمَنِ بْنَ أَبِي بَكْرٍ فَأَرْدَفَنِي وَخَرَجَ إِلَى التَّنْعِيمِ فَأَهْلَلْتُ بِعُمْرَةٍ فَقَضَى اللَّهُ حَجَّنَا وَعُمْرَتَنَا وَلَمْ يَكُنْ فِي ذَلِكَ هَدْىٌ وَلاَ صَدَقَةٌ وَلاَ صَوْمٌ ‏.‏",Al-Albani: Mawdu; Muhammad Fouad Abd al-Baqi: Mawdu; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۷۶۶، ومصباح الزجاجة:۹۶۸),2736,It was\nnarrated that ‘Aishah said:,Chapters on Hajj Rituals
2737,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ الأَعْلَى بْنُ عَبْدِ الأَعْلَى، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ، حَدَّثَنِي سُلَيْمَانُ بْنُ سُحَيْمٍ، عَنْ أُمِّ حَكِيمٍ بِنْتِ أُمَيَّةَ، عَنْ أُمِّ سَلَمَةَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ مَنْ أَهَلَّ بِعُمْرَةٍ مِنْ بَيْتِ الْمَقْدِسِ غُفِرَ لَهُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/الفرائض ۱۲ (۲۱۰۳)،(تحفة الأشراف:۱۰۳۸۴)، وقد أخرجہ: مسند احمد (۱/۲۸،۴۶),,It was\nnarrated from Umm Salamah that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Hajj Rituals
2738,"حَدَّثَنَا مُحَمَّدُ بْنُ الْمُصَفَّى الْحِمْصِيُّ، حَدَّثَنَا أَحْمَدُ بْنُ خَالِدٍ، حَدَّثَنَا مُحَمَّدُ بْنُ إِسْحَاقَ، عَنْ يَحْيَى بْنِ أَبِي سُفْيَانَ، عَنْ أُمِّهِ أُمِّ حَكِيمٍ بِنْتِ أُمَيَّةَ، عَنْ أُمِّ سَلَمَةَ، زَوْجِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَتْ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ أَهَلَّ بِعُمْرَةٍ مِنْ بَيْتِ الْمَقْدِسِ كَانَتْ لَهُ كَفَّارَةً لِمَا قَبْلَهَا مِنَ الذُّنُوبِ ‏""""‏ ‏.‏ قَالَتْ فَخَرَجْتُ - أَىْ مِنْ بَيْتِ الْمَقْدِسِ - بِعُمْرَةٍ ‏.‏""",Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الفرائض ۸ (۲۸۹۹،۲۹۰۰)،(تحفة الأشراف:۱۱۵۶۹),,"It was\nnarrated from Umm Salamah, the wife of the Prophet (ﷺ), that\nthe\nMessenger of Allah (ﷺ) said:",Chapters on Hajj Rituals
2739,حَدَّثَنَا أَبُو إِسْحَاقَ الشَّافِعِيُّ، إِبْرَاهِيمُ بْنُ مُحَمَّدٍ حَدَّثَنَا دَاوُدُ بْنُ عَبْدِ الرَّحْمَنِ، عَنْ عَمْرِو بْنِ دِينَارٍ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ اعْتَمَرَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ أَرْبَعَ عُمَرٍ عُمْرَةَ الْحُدَيْبِيَةِ وَعُمْرَةَ الْقَضَاءِ مِنْ قَابِلٍ وَالثَّالِثَةَ مِنَ الْجِعْرَانَةِ وَالرَّابِعَةَ الَّتِي مَعَ حَجَّتِهِ ‏.‏,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/الفرائض ۵ (۲۰۹۴،۲۰۹۵)،(تحفة الأشراف:۱۰۰۴۳)، وقد أخرجہ: سنن الدارمی/الفرائض ۲۸ (۳۰۲۷)، وقد مضی برقم:۲۷۱۵,2739,It was\nnarrated that Ibn ‘Abbas said:,Chapters on Hajj Rituals
2740,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، عَنْ إِسْمَاعِيلَ، عَنْ عَطَاءٍ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ صَلَّى بِمِنًى يَوْمَ التَّرْوِيَةِ الظُّهْرَ وَالْعَصْرَ وَالْمَغْرِبَ وَالْعِشَاءَ وَالْفَجْرَ ثُمَّ غَدَا إِلَى عَرَفَةَ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الفرائض ۵ (۶۷۳۲)، صحیح مسلم/الفرائض ۱ (۱۶۱۵)، سنن ابی داود/الفرائض ۷ (۲۸۹۸)، سنن الترمذی/الفرائض ۸ (۲۰۹۸)،(تحفة الأشراف:۵۷۰۵)، وقد أخرجہ: مسند احمد (۱/۲۹۲،۳۱۳،۳۲۵)، سنن الدارمی/الفرائض ۲۸ (۳۰۳۰),2740,,Chapters on Hajj Rituals
2741,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَنْبَأَنَا عَبْدُ اللَّهِ بْنُ عُمَرَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّهُ كَانَ يُصَلِّي الصَّلَوَاتِ الْخَمْسَ بِمِنًى ثُمَّ يُخْبِرُهُمْ أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ كَانَ يَفْعَلُ ذَلِكَ ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الفرائض ۸ (۲۹۰۵)، سنن الترمذی/الفرائض ۱۴ (۲۱۰۶)،(تحفة الأشراف:۶۳۲۶)، وقد أخرجہ: مسند احمد (۱/۲۲۱،۳۵۸),2741,,Chapters on Hajj Rituals
2742,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا وَكِيعٌ، عَنْ إِسْرَائِيلَ، عَنْ إِبْرَاهِيمَ بْنِ مُهَاجِرٍ، عَنْ يُوسُفَ بْنِ مَاهَكَ، عَنْ أُمِّهِ، عَنْ عَائِشَةَ، قَالَتْ قُلْتُ يَا رَسُولَ اللَّهِ أَلاَ نَبْنِي لَكَ بِمِنًى بَيْتًا قَالَ ‏ ‏ لاَ مِنًى مُنَاخُ مَنْ سَبَقَ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الفرائض ۹ (۲۹۰۶)، سنن الترمذی/الفرائض ۲۳ (۲۱۱۵)،(تحفة الأشراف:۱۱۷۴۴)، وقد أخرجہ: مسند احمد (۳/۴۹۰،۴/۱۰۶،۱۰۷),,It was\nnarrated that ‘Aishah said:,Chapters on Hajj Rituals
2743,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، وَعَمْرُو بْنُ عَبْدِ اللَّهِ، قَالاَ حَدَّثَنَا وَكِيعٌ، عَنْ إِسْرَائِيلَ، عَنْ إِبْرَاهِيمَ بْنِ مُهَاجِرٍ، عَنْ يُوسُفَ بْنِ مَاهَكَ، عَنْ أُمِّهِ، مُسَيْكَةَ عَنْ عَائِشَةَ، قَالَتْ قُلْنَا يَا رَسُولَ اللَّهِ أَلاَ نَبْنِي لَكَ بِمِنًى بُنْيَانًا يُظِلُّكَ قَالَ ‏ ‏ لاَ مِنًى مُنَاخُ مَنْ سَبَقَ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۳۰۷۵، ومصباح الزجاجة:۹۶۹)، وقد أخرجہ: سنن ابی داود/الطلاق ۲۹ (۲۲۶۳)، سنن النسائی/الطلاق ۴۷ (۳۵۱۱)، سنن الدارمی/النکاح ۴۲ (۲۲۸۴),,It was\nnarrated that ‘Aishah said:,Chapters on Hajj Rituals
2744,حَدَّثَنَا مُحَمَّدُ بْنُ أَبِي عُمَرَ الْعَدَنِيُّ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ مُحَمَّدِ بْنِ عُقْبَةَ، عَنْ مُحَمَّدِ بْنِ أَبِي بَكْرٍ، عَنْ أَنَسٍ، قَالَ غَدَوْنَا مَعَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ فِي هَذَا الْيَوْمِ مِنْ مِنًى إِلَى عَرَفَةَ فَمِنَّا مَنْ يُكَبِّرُ وَمِنَّا مَنْ يُهِلُّ فَلَمْ يَعِبْ هَذَا عَلَى هَذَا وَلاَ هَذَا عَلَى هَذَا - وَرُبَّمَا قَالَ هَؤُلاَءِ عَلَى هَؤُلاَءِ وَلاَ هَؤُلاَءِ عَلَى هَؤُلاَءِ ‏.‏,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأ شراف:۸۸۱۷ ألف، ومصباح الزجاجة:۹۷۰)، وقد أخرجہ: مسند احمد (۲/۲۱۵),2744,It was\nnarrated that Anas said:,Chapters on Hajj Rituals
2745,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، وَعَمْرُو بْنُ عَبْدِ اللَّهِ، قَالاَ حَدَّثَنَا وَكِيعٌ، أَنْبَأَنَا نَافِعُ بْنُ عُمَرَ الْجُمَحِيُّ، عَنْ سَعِيدِ بْنِ حَسَّانَ، عَنِ ابْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ كَانَ يَنْزِلُ بِعَرَفَةَ فِي وَادِي نَمِرَةَ ‏.‏ قَالَ فَلَمَّا قَتَلَ الْحَجَّاجُ ابْنَ الزُّبَيْرِ أَرْسَلَ إِلَى ابْنِ عُمَرَ أَىَّ سَاعَةٍ كَانَ النَّبِيُّ ـ صلى الله عليه وسلم ـ يَرُوحُ فِي هَذَا الْيَوْمِ قَالَ إِذَا كَانَ ذَلِكَ رُحْنَا ‏.‏ فَأَرْسَلَ الْحَجَّاجُ رَجُلاً يَنْظُرُ إِلَى سَاعَةِ يَرْتَحِلُ ‏.‏ فَلَمَّا أَرَادَ ابْنُ عُمَرَ أَنْ يَرْتَحِلَ قَالَ أَزَاغَتِ الشَّمْسُ قَالُوا لَمْ تَزِغْ بَعْدُ ‏.‏ فَجَلَسَ ثُمَّ قَالَ أَزَاغَتِ الشَّمْسُ قَالُوا لَمْ تَزِغْ بَعْدُ ‏.‏ فَجَلَسَ ثُمَّ قَالَ أَزَاغَتِ الشَّمْسُ قَالُوا لَمْ تَزِغْ بَعْدُ ‏.‏ فَجَلَسَ ثُمَّ قَالَ أَزَاغَتِ الشَّمْسُ قَالُوا نَعَمْ ‏.‏ فَلَمَّا قَالُوا قَدْ زَاغَتِ ارْتَحَلَ ‏.‏ قَالَ وَكِيعٌ يَعْنِي رَاحَ ‏.‏,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۷۷۸)، وقد أخرجہ: سنن الترمذی/الفرائض ۲۱ (۲۱۱۳),2745,"It was\nnarrated from Ibn ‘Umar that the Messenger of Allah (ﷺ) used to\nstop at ‘Arafat in Namirah Valley. When Hajjaj killed Ibn Zubair,\nhe sent word to Ibn ‘Umar asking:",Chapters on Hajj Rituals
2746,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا يَحْيَى بْنُ آدَمَ، عَنْ سُفْيَانَ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَيَّاشٍ، عَنْ زَيْدِ بْنِ عَلِيٍّ، عَنْ أَبِيهِ، عَنْ عُبَيْدِ اللَّهِ بْنِ أَبِي رَافِعٍ، عَنْ عَلِيٍّ، قَالَ وَقَفَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ بِعَرَفَةَ فَقَالَ ‏ ‏ هَذَا الْمَوْقِفُ وَعَرَفَةُ كُلُّهَا مَوْقِفٌ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۷۱۲ألف، ومصباح الزجاجة:۹۷۱)، وقد أخرجہ: سنن ابی داود/الطلاق ۳۰ (۲۲۶۵)، مسند احمد (۲/۱۸۱،۲۱۹)، سنن الدارمی/الفرائض ۴۵ (۳۱۵۴),,It was\nnarrated that ‘Ali said:,Chapters on Hajj Rituals
2747,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عَمْرِو بْنِ دِينَارٍ، عَنْ عَمْرِو بْنِ عَبْدِ اللَّهِ بْنِ صَفْوَانَ، عَنْ يَزِيدَ بْنِ شَيْبَانَ، قَالَ كُنَّا وُقُوفًا فِي مَكَانٍ تُبَاعِدُهُ مِنَ الْمَوْقِفِ فَأَتَانَا ابْنُ مِرْبَعٍ فَقَالَ إِنِّي رَسُولُ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ إِلَيْكُمْ يَقُولُ ‏ ‏ كُونُوا عَلَى مَشَاعِرِكُمْ فَإِنَّكُمُ الْيَوْمَ عَلَى إِرْثٍ مِنْ إِرْثِ إِبْرَاهِيمَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/العتق ۱۰ (۲۵۳۵)، الفرائض ۲۱ (۶۷۵۶)، صحیح مسلم/العتق ۳ (۱۵۰۶)، سنن ابی داود/الفرائض ۱۴ (۲۹۱۹)، سنن الترمذی/البیوع ۲۰،(۱۲۳۶)، سنن النسائی/البیوع ۸۵ (۴۶۶۳)،(تحفة الأشراف:۷۱۵،۷۱۸۹)، وقد أخرجہ: موطا امام مالک/العتق والولاء ۱۰ (۲۰)، مسند احمد (۳/۹،۷۹،۱۰۷)، سنن الدارمی/البیوع ۳۶ (۲۶۱۴),,It was\nnarrated that Yazid bin Shaiban said:,Chapters on Hajj Rituals
2748,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا الْقَاسِمُ بْنُ عَبْدِ اللَّهِ الْعُمَرِيُّ، حَدَّثَنَا مُحَمَّدُ بْنُ الْمُنْكَدِرِ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ كُلُّ عَرَفَةَ مَوْقِفٌ وَارْفَعُوا عَنْ بَطْنِ عُرَنَةَ وَكُلُّ الْمُزْدَلِفَةِ مَوْقِفٌ وَارْفَعُوا عَنْ بَطْنِ مُحَسِّرٍ وَكُلُّ مِنًى مَنْحَرٌ إِلاَّ مَا وَرَاءَ الْعَقَبَةِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ:(تحفة الأ شراف:۸۲۲۲)، وقد أخرجہ: سنن الترمذی/البیوع ۲۰ (۱۲۳۶)،۵۴ (۱۲۸۷)،,,It was\nnarrated from Jabir bin ‘Abdullah that the Messenger of Allah\n(ﷺ)\nsaid:,Chapters on Hajj Rituals
2749,"حَدَّثَنَا أَيُّوبُ بْنُ مُحَمَّدٍ الْهَاشِمِيُّ، حَدَّثَنَا عَبْدُ الْقَاهِرِ بْنُ السَّرِيِّ السُّلَمِيُّ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ كِنَانَةَ بْنِ عَبَّاسِ بْنِ مِرْدَاسٍ السُّلَمِيُّ، أَنَّ أَبَاهُ، أَخْبَرَهُ عَنْ أَبِيهِ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ دَعَا لأُمَّتِهِ عَشِيَّةَ عَرَفَةَ بِالْمَغْفِرَةِ فَأُجِيبَ إِنِّي قَدْ غَفَرْتُ لَهُمْ مَا خَلاَ الظَّالِمَ فَإِنِّي آخُذُ لِلْمَظْلُومِ مِنْهُ ‏.‏ قَالَ ‏""‏ أَىْ رَبِّ إِنْ شِئْتَ أَعْطَيْتَ الْمَظْلُومَ مِنَ الْجَنَّةِ وَغَفَرْتَ لِلظَّالِمِ ‏""‏ ‏.‏ فَلَمْ يُجَبْ عَشِيَّتَهُ فَلَمَّا أَصْبَحَ بِالْمُزْدَلِفَةِ أَعَادَ الدُّعَاءَ فَأُجِيبَ إِلَى مَا سَأَلَ ‏.‏ قَالَ فَضَحِكَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏.‏ أَوْ قَالَ تَبَسَّمَ ‏.‏ فَقَالَ لَهُ أَبُو بَكْرٍ وَعُمَرُ بِأَبِي أَنْتَ وَأُمِّي إِنَّ هَذِهِ لَسَاعَةٌ مَا كُنْتَ تَضْحَكُ فِيهَا فَمَا الَّذِي أَضْحَكَكَ أَضْحَكَ اللَّهُ سِنَّكَ قَالَ ‏""‏ إِنَّ عَدُوَّ اللَّهِ إِبْلِيسَ لَمَّا عَلِمَ أَنَّ اللَّهَ عَزَّ وَجَلَّ قَدِ اسْتَجَابَ دُعَائِي وَغَفَرَ لأُمَّتِي أَخَذَ التُّرَابَ فَجَعَلَ يَحْثُوهُ عَلَى رَأْسِهِ وَيَدْعُو بِالْوَيْلِ وَالثُّبُورِ فَأَضْحَكَنِي مَا رَأَيْتُ مِنْ جَزَعِهِ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Lighairihi; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۲۳۲، ومصباح الزجاجة:۹۷۲),2749,"‘Abdullah bin Kinanah bin ‘Abbas bin Mirdas As-Sulami narrated\nthat\nhis father told him, from his father, that the Messenger of\nAllah\n(ﷺ) prayed for forgiveness for his nation one evening at\n‘Arafat,\nand the response came:",Chapters on Hajj Rituals
2750,"حَدَّثَنَا هَارُونُ بْنُ سَعِيدٍ الْمِصْرِيُّ أَبُو جَعْفَرٍ، أَنْبَأَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، أَخْبَرَنِي مَخْرَمَةُ بْنُ بُكَيْرٍ، عَنْ أَبِيهِ، قَالَ سَمِعْتُ يُونُسَ بْنَ يُوسُفَ، يَقُولُ عَنِ ابْنِ الْمُسَيَّبِ، قَالَ قَالَتْ عَائِشَةُ إِنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ مَا مِنْ يَوْمٍ أَكْثَرَ مِنْ أَنْ يُعْتِقَ اللَّهُ عَزَّ وَجَلَّ فِيهِ عَبْدًا مِنَ النَّارِ مِنْ يَوْمِ عَرَفَةَ وَإِنَّهُ لَيَدْنُو عَزَّ وَجَلَّ ثُمَّ يُبَاهِي بِهِمُ الْمَلاَئِكَةَ فَيَقُولُ مَا أَرَادَ هَؤُلاَءِ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۷۰۸)، وقد أخرجہ: سنن الترمذی/الجنائز ۴۳ (۱۰۳۲)، سنن الدارمی/الفرائض ۴۷ (۳۱۶۸)، وقد مضی برقم:(۱۵۰۸),,It was\nnarrated from Ibn Musayyab that ‘Aishah said that the\nMessenger of\nAllah (ﷺ) said:,Chapters on Hajj Rituals
2751,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا سُفْيَانُ، عَنْ بُكَيْرِ بْنِ عَطَاءٍ، سَمِعْتُ عَبْدَ الرَّحْمَنِ بْنَ يَعْمُرَ الدِّيلِيَّ، قَالَ شَهِدْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ وَهُوَ وَاقِفٌ بِعَرَفَةَ وَأَتَاهُ نَاسٌ مِنْ أَهْلِ نَجْدٍ فَقَالُوا يَا رَسُولَ اللَّهِ كَيْفَ الْحَجُّ قَالَ ‏ ‏ الْحَجُّ عَرَفَةُ فَمَنْ جَاءَ قَبْلَ صَلاَةِ الْفَجْرِ لَيْلَةَ جَمْعٍ فَقَدْ تَمَّ حَجُّهُ أَيَّامُ مِنًى ثَلاَثَةٌ فَمَنْ تَعَجَّلَ فِي يَوْمَيْنِ فَلاَ إِثْمَ عَلَيْهِ وَمَنْ تَأَخَّرَ فَلاَ إِثْمَ عَلَيْهِ ‏""""‏ ‏.‏ ثُمَّ أَرْدَفَ رَجُلاً خَلْفَهُ فَجَعَلَ يُنَادِي بِهِنَّ ‏.‏ حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَنْبَأَنَا الثَّوْرِيُّ، عَنْ بُكَيْرِ بْنِ عَطَاءٍ اللَّيْثِيِّ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ يَعْمُرَ الدِّيلِيِّ، قَالَ أَتَيْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ بِعَرَفَةَ فَجَاءَهُ نَفَرٌ مِنْ أَهْلِ نَجْدٍ فَذَكَرَ نَحْوَهُ ‏.‏ قَالَ مُحَمَّدُ بْنُ يَحْيَى مَا أُرَى لِلثَّوْرِيِّ حَدِيثًا أَشْرَفَ مِنْهُ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۲۵۷،(الف)۱۲۶۶ (الف),,Sufyan\nbin Bukair bin ‘Ata’ said:,Chapters on Hajj Rituals
2752,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا إِسْمَاعِيلُ ابْنُ أَبِي خَالِدٍ، عَنْ عَامِرٍ، - يَعْنِي الشَّعْبِيَّ - عَنْ عُرْوَةَ بْنِ مُضَرِّسٍ الطَّائِيِّ، أَنَّهُ حَجَّ عَلَى عَهْدِ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ فَلَمْ يُدْرِكِ النَّاسَ إِلاَّ وَهُمْ بِجَمْعٍ ‏.‏ قَالَ فَأَتَيْتُ النَّبِيَّ ـ صلى الله عليه وسلم ـ فَقُلْتُ يَا رَسُولَ اللَّهِ إِنِّي أَنْضَيْتُ رَاحِلَتِي وَأَتْعَبْتُ نَفْسِي وَاللَّهِ إِنْ تَرَكْتُ مِنْ حَبْلٍ إِلاَّ وَقَفْتُ عَلَيْهِ فَهَلْ لِي مِنْ حَجٍّ فَقَالَ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ شَهِدَ مَعَنَا الصَّلاَةَ وَأَفَاضَ مِنْ عَرَفَاتٍ لَيْلاً أَوْ نَهَارًا فَقَدْ قَضَى تَفَثَهُ وَتَمَّ حَجُّهُ ‏""""‏ ‏.‏""",Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Zubair Ali Zai: Hasan,takhreej: «سنن ابی داود/الفرائض ۱۳ (۲۹۱۸)، سنن الترمذی/الفرائض۲۰ (۲۱۱۲)،(تحفة الأشراف:۲۰۵۲)، وقد أخرجہ: مسند احمد (۴/۱۰۴،۱۰۳)، سنن الدارمی/الفرائض ۳۴ (۳۰۷۶),,"It was\nnarrated from ‘Urwah bin Mudarris At-Ta’i that he performed\nHajj\nduring the time of the Messenger of Allah (ﷺ), and he did not\ncatch\nup with the people until they were at Jam’ (Al-Muzdalifah). He\nsaid:",Chapters on Hajj Rituals
2753,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، وَعَمْرُو بْنُ عَبْدِ اللَّهِ، قَالاَ حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا هِشَامُ بْنُ عُرْوَةَ، عَنْ أَبِيهِ، عَنْ أُسَامَةَ بْنِ زَيْدٍ، أَنَّهُ سُئِلَ كَيْفَ كَانَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ يَسِيرُ حِينَ دَفَعَ مِنْ عَرَفَةَ قَالَ كَانَ يَسِيرُ الْعَنَقَ فَإِذَا وَجَدَ فَجْوَةً نَصَّ ‏.‏ قَالَ وَكِيعٌ وَالنَّصُّ يَعْنِي فَوْقَ الْعَنَقِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الإیمان ۲۶ (۳۶ مطولاً)، الجہاد ۲ ۲۷۸۷)، فرض الخمس ۸ (۳۱۲۳)، التوحید ۲۸ (۷۴۵۷)، صحیح مسلم/الإمارة ۲۸ (۱۸۷۶)، سنن النسائی/الجہاد ۱۴ (۳۱۲۴)،(تحفة الأشراف:۱۴۹۰۱)، وقد أخرجہ: موطا امام مالک/الجہاد ۱ (۲)، مسند احمد (۲/۲۳۱،۳۸۴،۳۹۹،۴۲۴،۴۹۴)، سنن الدارمی/الجہاد ۲ (۲۴۳۶),2753,It was\nnarrated from Usamah bin Zaid that he was asked:,Chapters on Hajj Rituals
2754,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَنْبَأَنَا الثَّوْرِيُّ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، قَالَتْ قَالَتْ قُرَيْشٌ نَحْنُ قَوَاطِنُ الْبَيْتِ لاَ نُجَاوِزُ الْحَرَمَ ‏.‏ فَقَالَ اللَّهُ عَزَّ وَجَلَّ ‏{ثُمَّ أَفِيضُوا مِنْ حَيْثُ أَفَاضَ النَّاسُ }‏ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۲۲۴، ومصباح الزجاجة:۹۷۳),2754,It was\nnarrated that ‘Aishah said:,Chapters on Hajj Rituals
2755,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، حَدَّثَنَا سُفْيَانُ، عَنْ إِبْرَاهِيمَ بْنِ عُقْبَةَ، عَنْ كُرَيْبٍ، عَنْ أُسَامَةَ بْنِ زَيْدٍ، قَالَ أَفَضْتُ مَعَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ فَلَمَّا بَلَغَ الشِّعْبَ الَّذِي يَنْزِلُ عِنْدَهُ الأُمَرَاءُ نَزَلَ فَبَالَ وَتَوَضَّأَ قُلْتُ الصَّلاَةَ ‏.‏ قَالَ ‏ ‏ الصَّلاَةُ أَمَامَكَ ‏""""‏ ‏.‏ فَلَمَّا انْتَهَى إِلَى جَمْعٍ أَذَّنَ وَأَقَامَ ثُمَّ صَلَّى الْمَغْرِبَ ثُمَّ لَمْ يَحِلَّ أَحَدٌ مِنَ النَّاسِ حَتَّى قَامَ فَصَلَّى الْعِشَاءَ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن الترمذی/فضائل الجہاد ۱۷ (۱۶۴۹)،(تحفة الأشراف:۱۳۴۲۸)، وقد أخرجہ: صحیح البخاری/الجہاد ۵ (۲۷۹۲)، مسند احمد (۲/۵۳۲،۵۳۳),,It was\nnarrated that Usamah bin Zaid said:,Chapters on Hajj Rituals
2756,حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، عَنْ يَحْيَى بْنِ سَعِيدٍ، عَنْ عَدِيِّ بْنِ ثَابِتٍ الأَنْصَارِيِّ، عَنْ عَبْدِ اللَّهِ بْنِ يَزِيدَ الْخَطْمِيِّ، أَنَّهُ سَمِعَ أَبَا أَيُّوبَ الأَنْصَارِيَّ، يَقُولُ صَلَّيْتُ مَعَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ الْمَغْرِبَ وَالْعِشَاءَ فِي حِجَّةِ الْوَدَاعِ بِالْمُزْدَلِفَةِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۶۷۳)، وقد أخرجہ: صحیح البخاری/الجہاد ۵ (۲۷۹۴)،۷۳ (۲۸۹۲)، الرقاق ۲ (۶۴۱۵)، صحیح مسلم/الإمارة ۳۰ (۱۸۸۱)، سنن الترمذی/فضائل الجہاد ۱۷ (۱۶۴۸)،۲۶ (۱۶۶۴)، سنن النسائی/الجہاد ۱۱ (۳۱۲۰)، مسند احمد (۳/۴۳۳،۵/۳۳۵،۳۳۷،۳۳۹)، سنن الدارمی/الجہاد ۹ (۲۴۴۳),2756,It was\nnarrated from ‘Abdullah bin Yazid Al-Khatmi that he heard Abu\nAyyub\nAl-Ansari say:,Chapters on Hajj Rituals
2757,"حَدَّثَنَا مُحْرِزُ بْنُ سَلَمَةَ الْعَدَنِيُّ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ، عَنْ عُبَيْدِ اللَّهِ، عَنْ سَالِمٍ، عَنْ أَبِيهِ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ صَلَّى الْمَغْرِبَ بِالْمُزْدَلِفَةِ فَلَمَّا أَنَخْنَا قَالَ ‏ ‏ الصَّلاَةُ بِإِقَامَةٍ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۲۶)، وقد أخرجہ: صحیح البخاری/الجہاد ۵ (۲۷۹۲)، صحیح مسلم/الإمارة ۳۰ (۱۸۸۰)، سنن الترمذی/فضائل الجہاد ۱۷ (۱۶۵۱),,"It was\nnarrated from ‘Ubaidullah, from Salim, from his father, that\nthe\nProphet (ﷺ) prayed Maghrib at Muzdalifah. When we halted he\nsaid:",Chapters on Hajj Rituals
2758,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ، عَنْ حَجَّاجٍ، عَنْ أَبِي إِسْحَاقَ، عَنْ عَمْرِو بْنِ مَيْمُونٍ، قَالَ حَجَجْنَا مَعَ عُمَرَ بْنِ الْخَطَّابِ فَلَمَّا أَرَدْنَا أَنْ نُفِيضَ، مِنَ الْمُزْدَلِفَةِ قَالَ إِنَّ الْمُشْرِكِينَ كَانُوا يَقُولُونَ أَشْرِقْ ثَبِيرُ كَيْمَا نُغِيرُ ‏.‏ وَكَانُوا لاَ يُفِيضُونَ حَتَّى تَطْلُعَ الشَّمْسُ فَخَالَفَهُمْ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ فَأَفَاضَ قَبْلَ طُلُوعِ الشَّمْسِ ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۶۰۵، ومصباح الزجاجة:۹۷۴)، وقد أخرجہ: مسند احمد (۱/۲۰،۵۳),2758,It was\nnarrated that ‘Amr bin Maimun said:,Chapters on Hajj Rituals
2759,"حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ رَجَاءٍ الْمَكِّيُّ، عَنِ الثَّوْرِيِّ، قَالَ قَالَ أَبُو الزُّبَيْرِ قَالَ جَابِرٌ أَفَاضَ النَّبِيُّ ـ صلى الله عليه وسلم ـ فِي حَجَّةِ الْوَدَاعِ وَعَلَيْهِ السَّكِينَةُ وَأَمَرَهُمْ بِالسَّكِينَةِ وَأَمَرَهُمْ أَنْ يَرْمُوا بِمِثْلِ حَصَى الْخَذْفِ وَأَوْضَعَ فِي وَادِي مُحَسِّرٍ ‏.‏ وَقَالَ ‏ ‏ لِتَأْخُذْ أُمَّتِي نُسُكَهَا فَإِنِّي لاَ أَدْرِي لَعَلِّي لاَ أَلْقَاهُمْ بَعْدَ عَامِي هَذَا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن الترمذی/فضائل الجہاد ۶ (۱۶۲۹ ۱۶۳۰)،(تحفة الأشراف:۳۷۶۱)، وقد أخرجہ: صحیح البخاری/الجہاد ۳۸ (۲۸۴۳)، صحیح مسلم/الإمارة ۳۸ (۱۸۹۵)، سنن ابی داود/الجہاد ۲۱ (۲۵۰۹)، سنن النسائی/الجہاد ۴۴ (۳۱۸۲)، مسند احمد (۴/۱۱۵،۱۱۶،۱۱۷،۵/۱۹۲،۱۹۳)، سنن الدارمی/الجہاد ۲۷ (۲۴۶۳),,Jabir\nsaid:,Chapters on Hajj Rituals
2760,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، وَعَمْرُو بْنُ عَبْدِ اللَّهِ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا ابْنُ أَبِي رَوَّادٍ، عَنْ أَبِي سَلَمَةَ الْحِمْصِيِّ، عَنْ بِلاَلِ بْنِ رَبَاحٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ لَهُ غَدَاةَ جَمْعٍ ‏""‏ يَا بِلاَلُ أَسْكِتِ النَّاسَ ‏""‏ ‏.‏ أَوْ ‏""‏ أَنْصِتِ النَّاسَ ‏""‏ ‏.‏ ثُمَّ قَالَ ‏""‏ إِنَّ اللَّهَ تَطَوَّلَ عَلَيْكُمْ فِي جَمْعِكُمْ هَذَا فَوَهَبَ مُسِيئَكُمْ لِمُحْسِنِكُمْ وَأَعْطَى مُحْسِنَكُمْ مَا سَأَلَ ادْفَعُوا بِاسْمِ اللَّهِ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الزکاة ۱۲ (۹۹۴)، سنن الترمذی/البر والصلة ۴۲ (۱۹۶۶)،(تحفة الأشراف:۲۱۰۱)، وقد أخرجہ: مسند احمد۵/ (۲۷۹،۲۸۴),2760,"It was\nnarrated from Bilal bin Rabah that the Prophet (ﷺ) said to\nhim, on\nthe morning of Jama’:",Chapters on Hajj Rituals
2761,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا مِسْعَرٌ، وَسُفْيَانُ، عَنْ سَلَمَةَ بْنِ كُهَيْلٍ، عَنِ الْحَسَنِ الْعُرَنِيِّ، عَنِ ابْنِ عَبَّاسٍ، قَالَ قَدَّمَنَا رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ أُغَيْلِمَةَ بَنِي عَبْدِ الْمُطَّلِبِ عَلَى حُمُرَاتٍ لَنَا مِنْ جَمْعٍ فَجَعَلَ يَلْطَحُ أَفْخَاذَنَا وَيَقُولُ ‏""‏ أُبَيْنِيَّ لاَ تَرْمُوا الْجَمْرَةَ حَتَّى تَطْلُعَ الشَّمْسُ ‏""‏ ‏.‏ زَادَ سُفْيَانُ فِيهِ ‏""‏ وَلاَ إِخَالُ أَحَدًا يَرْمِيهَا حَتَّى تَطْلُعَ الشَّمْسُ ‏""‏ ‏.‏",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۲۲۷،۸۶۱۷،۱۰۰۶۸،۱۰۷۹۴،۱۰۹۲۹،۱۲۲۶۱، ومصباح الزجاجة:۹۷۵),2761,It was\nnarrated that Ibn ‘Abbas said:,Chapters on Hajj Rituals
2762,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا سُفْيَانُ، حَدَّثَنَا عَمْرٌو، عَنْ عَطَاءٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ كُنْتُ فِيمَنْ قَدَّمَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ فِي ضَعَفَةِ أَهْلِهِ ‏.‏,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الجہاد ۱۸ (۲۵۰۳)،(تحفة الأشراف:۴۸۹۷)، وقد أخرجہ: سنن الدارمی/الجہاد ۲۶ (۲۴۶۲),2762,It was\nnarrated that Ibn ‘Abbas said:,Chapters on Hajj Rituals
2763,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا سُفْيَانُ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، أَنَّ سَوْدَةَ بِنْتَ زَمْعَةَ، كَانَتِ امْرَأَةً ثَبِطَةً فَاسْتَأْذَنَتْ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ أَنْ تَدْفَعَ مِنْ جَمْعٍ قَبْلَ دُفْعَةِ النَّاسِ فَأَذِنَ لَهَا ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/فضائل الجہاد ۲۶ (۱۶۶۶)،(تحفة الأشراف:۱۲۵۵۴)، وقد أخرجہ: مسند احمد (۳/۱۶۰،۲۱۴),2763,,Chapters on Hajj Rituals
2764,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ، عَنْ يَزِيدَ بْنِ أَبِي زِيَادٍ، عَنْ سُلَيْمَانَ بْنِ عَمْرِو بْنِ الأَحْوَصِ، عَنْ أُمِّهِ، قَالَتْ رَأَيْتُ النَّبِيَّ ـ صلى الله عليه وسلم ـ يَوْمَ النَّحْرِ عِنْدَ جَمْرَةِ الْعَقَبَةِ وَهُوَ رَاكِبٌ عَلَى بَغْلَةٍ فَقَالَ ‏ ‏ يَا أَيُّهَا النَّاسُ إِذَا رَمَيْتُمُ الْجَمْرَةَ فَارْمُوا بِمِثْلِ حَصَى الْخَذْفِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۵۸)، وقد أخرجہ: صحیح البخاری/الجہاد ۳۵ (۲۸۳۹)، صحیح مسلم/الإمارة ۴۸ (۱۹۱۱)، سنن ابی داود/الجہاد ۲۰ (۲۵۰۸),,It was\nnarrated from Sulaiman bin ‘Amr bin Ahwas that his mother\nsaid:,Chapters on Hajj Rituals
2765,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا أَبُو أُسَامَةَ، عَنْ عَوْفٍ، عَنْ زِيَادِ بْنِ الْحُصَيْنِ، عَنْ أَبِي الْعَالِيَةِ، عَنِ ابْنِ عَبَّاسٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ غَدَاةَ الْعَقَبَةِ وَهُوَ عَلَى نَاقَتِهِ ‏""‏ الْقُطْ لِي حَصًى ‏""‏ ‏.‏ فَلَقَطْتُ لَهُ سَبْعَ حَصَيَاتٍ هُنَّ حَصَى الْخَذْفِ فَجَعَلَ يَنْفُضُهُنَّ فِي كَفِّهِ وَيَقُولُ ‏""‏ أَمْثَالَ هَؤُلاَءِ فَارْمُوا ‏""‏ ‏.‏ ثُمَّ قَالَ ‏""‏ يَا أَيُّهَا النَّاسُ إِيَّاكُمْ وَالْغُلُوَّ فِي الدِّينِ فَإِنَّمَا أَهْلَكَ مَنْ كَانَ قَبْلَكُمُ الْغُلُوُّ فِي الدِّينِ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الإمارة ۴۸ (۱۹۱۱)،(تحفة الأشراف:۲۳۰۴)، وقد أخرجہ: مسند احمد (۳/۳۰۰),2765,It was\nnarrated that Ibn ‘Abbas said:,Chapters on Hajj Rituals
2766,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، عَنِ الْمَسْعُودِيِّ، عَنْ جَامِعِ بْنِ شَدَّادٍ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ يَزِيدَ، قَالَ لَمَّا أَتَى عَبْدُ اللَّهِ بْنُ مَسْعُودٍ جَمْرَةَ الْعَقَبَةِ اسْتَبْطَنَ الْوَادِيَ وَاسْتَقْبَلَ الْكَعْبَةَ وَجَعَلَ الْجَمْرَةَ عَلَى حَاجِبِهِ الأَيْمَنِ ثُمَّ رَمَى بِسَبْعِ حَصَيَاتٍ يُكَبِّرُ مَعَ كُلِّ حَصَاةٍ ثُمَّ قَالَ مِنْ هَاهُنَا وَالَّذِي لاَ إِلَهَ غَيْرُهُ رَمَى الَّذِي أُنْزِلَتْ عَلَيْهِ سُورَةُ الْبَقَرَةِ ‏.‏,Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۸۱۶، ومصباح الزجاجة:۹۷۶)، وقد أخرجہ: مسند احمد (۱/۶۱،۶۴),2766,It was\nnarrated that ‘Abdur-Rahman bin Yazid said:,Chapters on Hajj Rituals
2767,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ، عَنْ يَزِيدَ بْنِ أَبِي زِيَادٍ، عَنْ سُلَيْمَانَ بْنِ عَمْرِو بْنِ الأَحْوَصِ، عَنْ أُمِّهِ، قَالَتْ رَأَيْتُ النَّبِيَّ ـ صلى الله عليه وسلم ـ يَوْمَ النَّحْرِ عِنْدَ جَمْرَةِ الْعَقَبَةِ اسْتَبْطَنَ الْوَادِيَ فَرَمَى الْجَمْرَةَ بِسَبْعِ حَصَيَاتٍ يُكَبِّرُ مَعَ كُلِّ حَصَاةٍ ثُمَّ انْصَرَفَ ‏.‏ حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ سُلَيْمَانَ، عَنْ يَزِيدَ بْنِ أَبِي زِيَادٍ، عَنْ سُلَيْمَانَ بْنِ عَمْرِو بْنِ الأَحْوَصِ، عَنْ أُمِّ جُنْدُبٍ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ بِنَحْوِهِ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۴۶۱۷، ومصباح الزجاجة:۹۷۸)، وقد أخرجہ: مسند احمد (۲/۴۰۴),,It was\nnarrated from Sulaiman bin ‘Amr bin Ahwas that his mother\nsaid:,Chapters on Hajj Rituals
2768,حَدَّثَنَا عُثْمَانُ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا طَلْحَةُ بْنُ يَحْيَى، عَنْ يُونُسَ بْنِ يَزِيدَ، عَنِ الزُّهْرِيِّ، عَنِ سَالِمٍ، عَنِ ابْنِ عُمَرَ، أَنَّهُ رَمَى جَمْرَةَ الْعَقَبَةِ وَلَمْ يَقِفْ عِنْدَهَا وَذَكَرَ أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ فَعَلَ مِثْلَ ذَلِكَ ‏.‏,Al-Albani: Mawdu; Muhammad Fouad Abd al-Baqi: Mawdu; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۵، ومصباح الزجاجة:۹۷۹),2768,,Chapters on Hajj Rituals
2769,حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ، عَنِ الْحَجَّاجِ، عَنِ الْحَكَمِ بْنِ عُتَيْبَةَ، عَنْ مِقْسَمٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ كَانَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ إِذَا رَمَى جَمْرَةَ الْعَقَبَةِ مَضَى وَلَمْ يَقِفْ ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۹۴۵، ومصباح الزجاجة:۹۸۰)، وقد أخرجہ: سنن الدارمی/الجہاد ۱۱ (۲۴۴۵),2769,It was\nnarrated that Ibn ‘Abbas said:,Chapters on Hajj Rituals
2770,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ، عَنْ حَجَّاجٍ، عَنِ الْحَكَمِ، عَنْ مِقْسَمٍ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ رَمَى الْجَمْرَةَ عَلَى رَاحِلَتِهِ ‏.‏,Al-Albani: Mawdu; Muhammad Fouad Abd al-Baqi: Mawdu; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۶۰، ومصباح الزجاجة:۹۸۱),2770,,Chapters on Hajj Rituals
2771,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا وَكِيعٌ، عَنْ أَيْمَنَ بْنِ نَابِلٍ، عَنْ قُدَامَةَ بْنِ عَبْدِ اللَّهِ الْعَامِرِيِّ، قَالَ رَأَيْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ رَمَى الْجَمْرَةَ يَوْمَ النَّحْرِ عَلَى نَاقَةٍ لَهُ صَهْبَاءَ لاَ ضَرْبَ وَلاَ طَرْدَ وَلاَ إِلَيْكَ إِلَيْكَ ‏.‏,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن الترمذی/الدعوات ۴۶ (۳۴۴۵)،(تحفة الأشراف:۱۲۹۴۶)، وقد أخرجہ:۲/۳۲۵،۳۳۱،۴۴۳،۴۷۶),2771,It was\nnarrated that Qudamah bin ‘Abdullah Al-‘Amiri said:,Chapters on Hajj Rituals
2772,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عَبْدِ اللَّهِ بْنِ أَبِي بَكْرٍ، عَنْ عَبْدِ الْمَلِكِ بْنِ أَبِي بَكْرٍ، عَنْ أَبِي الْبَدَّاحِ بْنِ عَاصِمٍ، عَنْ أَبِيهِ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ رَخَّصَ لِلرِّعَاءِ أَنْ يَرْمُوا يَوْمًا وَيَدَعُوا يَوْمًا ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/ الجہاد ۴۲ (۲۸۲۰)،۵۴ (۲۸۶۶)،۸۲ (۲۹۰۸)، الأدب ۳۹ (۶۰۳۳)، صحیح مسلم/الفضائل ۱۱ (۲۳۰۷)، سنن الترمذی/الجہاد ۱۴ (۱۶۸۷)،(تحفة الأشراف:۲۸۹)، وقد أخرجہ: مسند احمد۳/۱۴۷،۱۶۳،۱۸۵،۲۷۱),2772,,Chapters on Hajj Rituals
2773,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَنْبَأَنَا مَالِكُ بْنُ أَنَسٍ، ح وَحَدَّثَنَا أَحْمَدُ بْنُ سِنَانٍ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، عَنْ مَالِكِ بْنِ أَنَسٍ، حَدَّثَنِي عَبْدُ اللَّهِ بْنُ أَبِي بَكْرٍ، عَنْ أَبِيهِ، عَنْ أَبِي الْبَدَّاحِ بْنِ عَاصِمٍ، عَنْ أَبِيهِ، قَالَ رَخَّصَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ لِرِعَاءِ الإِبِلِ فِي الْبَيْتُوتَةِ أَنْ يَرْمُوا يَوْمَ النَّحْرِ ثُمَّ يَجْمَعُوا رَمْىَ يَوْمَيْنِ بَعْدَ النَّحْرِ فَيَرْمُونَهُ فِي أَحَدِهِمَا - قَالَ مَالِكٌ ظَنَنْتُ أَنَّهُ قَالَ فِي الأَوَّلِ مِنْهُمَا - ثُمَّ يَرْمُونَ يَوْمَ النَّفْرِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۴۱۸، ومصباح الزجاجة:۹۸۲)، وقد أخرجہ: صحیح البخاری/جزاء الصید ۴ (۱۸۳۴)، الجہاد ۱ (۲۷۸۳)،۲۷ (۲۸۲۵)،۱۹۴ (۳۰۷۷)، صحیح مسلم/الإمارة ۲۰ (۱۳۵۳)، سنن الترمذی/السیر ۳۳ (۱۵۹۰)، سنن النسائی/البیعة ۱۵ (۴۱۷۵)، مسند احمد (۱/۲۲۶،۲۶۶،۳۱۶،۳۵۵)، سنن الدارمی/السیر ۶۹ (۲۵۵۴),2773,It was\nnarrated from Abu Baddah bin ‘Asim that his father said:,Chapters on Hajj Rituals
2774,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، عَنْ أَشْعَثَ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، قَالَ حَجَجْنَا مَعَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ وَمَعَنَا النِّسَاءُ وَالصِّبْيَانُ فَلَبَّيْنَا عَنِ الصِّبْيَانِ وَرَمَيْنَا عَنْهُمْ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن الترمذی/فضائل الجہاد ۸ (۱۶۳۳)، الزہد ۸ (۲۳۱۱)، سنن النسائی/الجہاد ۸ (۳۱۰۹)،(تحفة الأشراف:۱۴۲۸۵)، وقد أخرجہ: مسند احمد (۲/۵۰۵),2774,It was\nnarrated that Jabir said:,Chapters on Hajj Rituals
2775,حَدَّثَنَا بَكْرُ بْنُ خَلَفٍ أَبُو بِشْرٍ، حَدَّثَنَا حَمْزَةُ بْنُ الْحَارِثِ بْنِ عُمَيْرٍ، عَنْ أَبِيهِ، عَنْ أَيُّوبَ، عَنْ سَعِيدِ بْنِ جُبَيْرٍ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ لَبَّى حَتَّى رَمَى جَمْرَةَ الْعَقَبَةِ ‏.‏,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۰۳، ومصباح الزجاجة:۹۸۳),2775,,Chapters on Hajj Rituals
2776,حَدَّثَنَا هَنَّادُ بْنُ السَّرِيِّ، حَدَّثَنَا أَبُو الأَحْوَصِ، عَنْ خُصَيْفٍ، عَنْ مُجَاهِدٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ قَالَ الْفَضْلُ بْنُ عَبَّاسٍ كُنْتُ رِدْفَ النَّبِيِّ ـ صلى الله عليه وسلم ـ فَمَا زِلْتُ أَسْمَعُهُ يُلَبِّي حَتَّى رَمَى جَمْرَةَ الْعَقَبَةِ فَلَمَّا رَمَاهَا قَطَعَ التَّلْبِيَةَ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الجہاد ۳ (۲۷۸۸)،۸ (۲۷۹۹)،۶۳ (۲۸۷۷)،۷۵ (۲۸۹۴)،۹۳ (۲۹۲۴)، الاستئذان ۴۱ (۶۲۸۲)، التعبیر ۱۲ (۷۰۰۱)، صحیح مسلم/الإمارة ۴۹ (۱۹۱۲)، سنن ابی داود/الجہاد ۱۰ (۲۴۹۰،۲۴۹۲)، سنن الترمذی/فضائل الجہاد ۱۵ (۱۶۴۵)، سنن النسائی/الجہاد ۴۰ (۳۱۷۴)،(تحفة الأشراف:۱۸۳۰۷)، وقد أخرجہ: موطا امام مالک/الجہاد ۱۸ (۳۹)، مسند احمد (۳/۲۶۴،۶/۳۶۱،۴۲۳،۴۳۵)، سنن الدارمی/الجہاد ۲۹ (۲۴۶۵),2776,It was\nnarrated that Ibn ‘Abbas said:,Chapters on Hajj Rituals
2777,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا وَكِيعٌ، ح وَحَدَّثَنَا أَبُو بَكْرِ بْنُ خَلاَّدٍ الْبَاهِلِيُّ، حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، وَوَكِيعٌ، وَعَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، قَالُوا حَدَّثَنَا سُفْيَانُ، عَنْ سَلَمَةَ بْنِ كُهَيْلٍ، عَنِ الْحَسَنِ الْعُرَنِيِّ، عَنِ ابْنِ عَبَّاسٍ، قَالَ إِذَا رَمَيْتُمُ الْجَمْرَةَ فَقَدْ حَلَّ لَكُمْ كُلُّ شَىْءٍ إِلاَّ النِّسَاءَ ‏.‏ فَقَالَ لَهُ رَجُلٌ يَا ابْنَ عَبَّاسٍ وَالطِّيبُ فَقَالَ أَمَّا أَنَا فَقَدْ رَأَيْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يُضَمِّخُ رَأْسَهُ بِالْمِسْكِ أَفَطِيبٌ ذَلِكَ أَمْ لاَ ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Sanad Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۰۰۱، ومصباح الزجاجة:۹۸۴),2777,It was\nnarrated that Ibn ‘Abbas said:,Chapters on Hajj Rituals
2778,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا خَالِي، مُحَمَّدٌ وَأَبُو مُعَاوِيَةَ وَأَبُو أُسَامَةَ عَنْ عُبَيْدِ اللَّهِ، عَنِ الْقَاسِمِ بْنِ مُحَمَّدٍ، عَنْ عَائِشَةَ، قَالَتْ طَيَّبْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ لإِحْرَامِهِ حِينَ أَحْرَمَ وَلإِحْلاَلِهِ حِينَ أَحَلَّ ‏.‏,Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۸۷۲، ومصباح الزجاجة:۹۸۵),2778,It was\nnarrated that ‘Aishah said:,Chapters on Hajj Rituals
2779,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا مُحَمَّدُ بْنُ فُضَيْلٍ، حَدَّثَنَا عُمَارَةُ بْنُ الْقَعْقَاعِ، عَنْ أَبِي زُرْعَةَ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏""‏ اللَّهُمَّ اغْفِرْ لِلْمُحَلِّقِينَ ‏""‏ ‏.‏ قَالُوا يَا رَسُولَ اللَّهِ وَالْمُقَصِّرِينَ قَالَ ‏""‏ اللَّهُمَّ اغْفِرْ لِلْمُحَلِّقِينَ ‏""‏ ‏.‏ ثَلاَثًا قَالُوا يَا رَسُولَ اللَّهِ وَالْمُقَصِّرِينَ قَالَ ‏""‏ وَالْمُقَصِّرِينَ ‏""‏ ‏.‏",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۸۴۱، ومصباح الزجاجة:۹۸۶),2779,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Hajj Rituals
2780,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، وَأَحْمَدُ بْنُ أَبِي الْحَوَارِيِّ الدِّمَشْقِيُّ، قَالاَ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، عَنْ عُبَيْدِ اللَّهِ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏""‏ رَحِمَ اللَّهُ الْمُحَلِّقِينَ ‏""‏ ‏.‏ قَالُوا وَالْمُقَصِّرِينَ يَا رَسُولَ اللَّهِ قَالَ ‏""‏ رَحِمَ اللَّهُ الْمُحَلِّقِينَ ‏""‏ ‏.‏ قَالُوا وَالْمُقَصِّرِينَ يَا رَسُولَ اللَّهِ قَالَ ‏""‏ رَحِمَ اللَّهُ الْمُحَلِّقِينَ ‏""‏ ‏.‏ قَالُوا وَالْمُقَصِّرِينَ يَا رَسُولَ اللَّهِ قَالَ ‏""‏ وَالْمُقَصِّرِينَ ‏""‏ ‏.‏",Al-Albani: Mawdu; Muhammad Fouad Abd al-Baqi: Mawdu; Shuaib Al Arnaut: Mawdu; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۶۸۶، ومصباح الزجاجة:۹۸۷),2780,It was\nnarrated from Ibn ‘Umar that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Hajj Rituals
2781,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا يُونُسُ بْنُ بُكَيْرٍ، حَدَّثَنَا ابْنُ إِسْحَاقَ، حَدَّثَنَا ابْنُ أَبِي نَجِيحٍ، عَنْ مُجَاهِدٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ قِيلَ يَا رَسُولَ اللَّهِ لِمَ ظَاهَرْتَ لِلْمُحَلِّقِينَ ثَلاَثًا وَلِلْمُقَصِّرِينَ وَاحِدَةً قَالَ ‏ ‏ إِنَّهُمْ لَمْ يَشُكُّوا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن النسائی/الجہاد ۶ (۳۱۰۶)،(تحفة الأشراف:۱۱۳۷۵)، وقد أخرجہ: مسند احمد (۳/۴۲۹),,It was\nnarrated that Ibn ‘Abbas said:,Chapters on Hajj Rituals
2782,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو أُسَامَةَ، عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ حَفْصَةَ، زَوْجَ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَتْ قُلْتُ يَا رَسُولَ اللَّهِ مَا شَأْنُ النَّاسِ حَلُّوا وَلَمْ تَحِلَّ أَنْتَ مِنْ عُمْرَتِكَ قَالَ ‏ ‏ إِنِّي لَبَّدْتُ رَأْسِي وَقَلَّدْتُ هَدْيِي فَلاَ أَحِلُّ حَتَّى أَنْحَرَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Hasan,takhreej: «سنن ابی داود/الجہاد ۳۳ (۲۵۲۸)، سنن النسائی/الجہاد ۵ (۳۱۰۵)،(تحفة الأشراف:۸۶۴۰)، وقد أخرجہ: صحیح البخاری/الجہاد ۱۳۸ (۳۰۰۴)، صحیح مسلم/البر ۱ (۲۵۴۹)، سنن الترمذی/الجہاد ۲ (۱۶۷۱)، مسند احمد (۲/۱۶۵،۱۹۴،۱۹۸،۲۰۴),,"It was\nnarrated from Ibn ‘Umar that Hafsah, the wife of the Prophet\n(ﷺ),\nsaid:",Chapters on Hajj Rituals
2783,حَدَّثَنَا أَحْمَدُ بْنُ عَمْرِو بْنِ السَّرْحِ الْمِصْرِيُّ، أَنْبَأَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، أَنْبَأَنَا يُونُسُ، عَنِ ابْنِ شِهَابٍ، عَنْ سَالِمٍ، عَنْ أَبِيهِ، سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يُهِلُّ مُلَبِّدًا ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/العلم ۴۵ (۱۲۳)، الجہاد ۱۵ (۲۸۱۰)، الخمس ۱۰ (۳۱۲۶)، التوحید ۲۸ (۷۴۵۸)، صحیح مسلم/الإمارة ۴۲ (۱۹۰۴)، سنن ابی داود/الجہاد ۲۶ (۲۵۱۷،۲۵۱۸)، سنن الترمذی/فضائل الجہاد ۱۶ (۱۶۴۶)، سنن النسائی/الجہاد ۲۱ (۳۱۳۸)،(تحفة الأشراف:۸۹۹۹)، وقد أخرجہ: مسند احمد (۴/۳۹۲،۳۹۷،۴۰۵،۴۱۷),2783,"It was\nnarrated from Salim, from his father:",Chapters on Hajj Rituals
2784,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، وَعَمْرُو بْنُ عَبْدِ اللَّهِ، قَالاَ حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا أُسَامَةُ بْنُ زَيْدٍ، عَنْ عَطَاءٍ، عَنْ جَابِرٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مِنًى كُلُّهَا مَنْحَرٌ وَكُلُّ فِجَاجِ مَكَّةَ طَرِيقٌ وَمَنْحَرٌ وَكُلُّ عَرَفَةَ مَوْقِفٌ وَكُلُّ الْمُزْدَلِفَةِ مَوْقِفٌ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الأدب ۱۲۱ (۵۱۲۳)،(تحفة الأشراف:۱۲۰۷۰)، وقد أخرجہ: مسند احمد (۵/۲۹۵),,It was\nnarrated from Jabir that the Messenger of Allah (ﷺ) said:,Chapters on Hajj Rituals
2785,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ أَيُّوبَ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ مَا سُئِلَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَمَّنْ قَدَّمَ شَيْئًا قَبْلَ شَىْءٍ إِلاَّ يُلْقِي بِيَدَيْهِ كِلْتَيْهِمَا ‏ ‏ لاَ حَرَجَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الإمارة ۴۴ (۱۹۰۶)، سنن ابی داود/الجہاد ۱۳ (۲۴۹۷)، سنن النسائی/الجہاد ۱۵ (۳۱۲۷)،(تحفة الأشراف:۸۸۴۷)، وقد أخرجہ: مسند احمد (۲/۱۶۹),,It was\nnarrated that Ibn ‘Abbas said:,Chapters on Hajj Rituals
2786,"حَدَّثَنَا أَبُو بِشْرٍ، بَكْرُ بْنُ خَلَفٍ حَدَّثَنَا يَزِيدُ بْنُ زُرَيْعٍ، عَنْ خَالِدٍ الْحَذَّاءِ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ كَانَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ يُسْأَلُ يَوْمَ مِنًى فَيَقُولُ ‏""‏ لاَ حَرَجَ لاَ حَرَجَ ‏""‏ ‏.‏ فَأَتَاهُ رَجُلٌ فَقَالَ حَلَقْتُ قَبْلَ أَنْ أَذْبَحَ قَالَ ‏""‏ لاَ حَرَجَ ‏""‏ ‏.‏ قَالَ رَمَيْتُ بَعْدَ مَا أَمْسَيْتُ قَالَ ‏""‏ لاَ حَرَجَ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «صحیح البخاری/الجہاد ۴۳ (۲۸۵۰)،۴۴ (۲۸۵۲)، الخمس ۸ (۳۱۱۹)، المناقب ۲۸ (۳۶۴۲)، صحیح مسلم/الإمارة ۲۶ (۱۸۷۳)، سنن الترمذی/الجہاد ۱۹ (۱۶۹۴)، سنن النسائی/الخیل ۶ (۳۶۰۴)،(تحفة الأشراف:۹۸۹۷)، وقد أخرجہ: مسند احمد (۴/۳۷۵)، سنن الدارمی/الجہاد ۳۴ (۲۴۷۰),2786,It was\nnarrated that Ibn ‘Abbas said:,Chapters on Hajj Rituals
2787,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ الزُّهْرِيِّ، عَنْ عِيسَى بْنِ طَلْحَةَ، عَنْ عَبْدِ اللَّهِ بْنِ عَمْرٍو، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ سُئِلَ عَمَّنْ ذَبَحَ قَبْلَ أَنْ يَحْلِقَ أَوْ حَلَقَ قَبْلَ أَنْ يَذْبَحَ قَالَ ‏ ‏ لاَ حَرَجَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الإمارة ۲۶ (۱۸۷۱)، سنن النسائی/الخیل ۶ (۳۶۰۳)،(تحفة الأشراف:۸۲۸۷)، وقد أخرجہ: صحیح البخاری/الجہاد ۴۳ (۲۸۴۹)، المناقب ۲۸ (۳۶۴۴)، موطا امام مالک/الجہاد ۱۹ (۴۴)، مسند احمد (۲/۴۹،۵۷،۱۰۱،۱۱۲),,"It was\nnarrated from ‘Abdullah bin ‘Amr that the Prophet (ﷺ) was\nasked\nabout a man who slaughtered his sacrifice before shaving his\nhead, or\nwho shaved his head before slaughtering his sacrifice, and he\nsaid:",Chapters on Hajj Rituals
2788,"حَدَّثَنَا هَارُونُ بْنُ سَعِيدٍ الْمِصْرِيُّ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، أَخْبَرَنِي أُسَامَةُ بْنُ زَيْدٍ، حَدَّثَنِي عَطَاءُ بْنُ أَبِي رَبَاحٍ، أَنَّهُ سَمِعَ جَابِرَ بْنَ عَبْدِ اللَّهِ، يَقُولُ قَعَدَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ بِمِنًى يَوْمَ النَّحْرِ لِلنَّاسِ فَجَاءَهُ رَجُلٌ فَقَالَ يَا رَسُولَ اللَّهِ إِنِّي حَلَقْتُ قَبْلَ أَنْ أَذْبَحَ قَالَ ‏""‏ لاَ حَرَجَ ‏""‏ ‏.‏ ثُمَّ جَاءَهُ آخَرُ فَقَالَ يَا رَسُولَ اللَّهِ إِنِّي نَحَرْتُ قَبْلَ أَنْ أَرْمِيَ قَالَ ‏""‏ لاَ حَرَجَ ‏""‏ ‏.‏ فَمَا سُئِلَ يَوْمَئِذٍ عَنْ شَىْءٍ قُدِّمَ قَبْلَ شَىْءٍ إِلاَّ قَالَ ‏""‏ لاَ حَرَجَ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الزکاة ۶ (۹۸۷)،(تحفة الأشراف:۱۲۷۸۵)، وقد أخرجہ: صحیح البخاری/الشرب المساقاة ۱۲ (۲۳۷۱)، الجہاد ۴۸ (۲۸۶۰)، المناقب ۲۸ (۳۶۴۶)، تفسیر سورة الزلزلة ۱ (۴۹۶۲)، الاعتصام ۲۴ (۷۳۵۶)، سنن الترمذی/فضائل الجہاد ۱۰ (۱۶۳۶)، سنن النسائی/الخیل (۳۵۹۲)، موطا امام مالک/الجہاد ۱ (۳)، مسند احمد (۲/۲۶۲،۲۸۳),2788,Jabir\nbin ‘Abdullah said:,Chapters on Hajj Rituals
2789,حَدَّثَنَا حَرْمَلَةُ بْنُ يَحْيَى الْمِصْرِيُّ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، حَدَّثَنَا ابْنُ جُرَيْجٍ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، قَالَ رَأَيْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ رَمَى جَمْرَةَ الْعَقَبَةِ ضُحًى وَأَمَّا بَعْدَ ذَلِكَ فَبَعْدَ زَوَالِ الشَّمْسِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن الترمذی/الجہاد۲۰ (۱۶۹۵)،(تحفة الأشراف:۱۲۱۲۱)، وقد أخرجہ: مسند احمد (۵/۳۰۰)، سنن الدارمی/الجہاد ۳۵ (۲۴۷۲),2789,It was\nnarrated that Jabir said:,Chapters on Hajj Rituals
2790,حَدَّثَنَا جُبَارَةُ بْنُ الْمُغَلِّسِ، حَدَّثَنَا إِبْرَاهِيمُ بْنُ عُثْمَانَ بْنِ أَبِي شَيْبَةَ أَبُو شَيْبَةَ، عَنِ الْحَكَمِ، عَنْ مِقْسَمٍ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ كَانَ يَرْمِي الْجِمَارَ إِذَا زَالَتِ الشَّمْسُ قَدْرَ مَا إِذَا فَرَغَ مِنْ رَمْيِهِ صَلَّى الظُّهْرَ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الإمارة ۲۷ (۱۸۷۵)، سنن ابی داود/الجہاد ۴۶ (۲۵۴۷)، سنن الترمذی/الجہاد ۲۱ (۱۶۹۸)، سنن النسائی/الخیل ۴ (۳۵۹۷)،(تحفة الأشراف:۱۴۸۹۰)، وقد أخرجہ: مسند احمد (۲/۲۵۰،۴۳۶،۴۶۱،۷۶),2790,,Chapters on Hajj Rituals
2791,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَهَنَّادُ بْنُ السَّرِيِّ، قَالاَ حَدَّثَنَا أَبُو الأَحْوَصِ، عَنْ شَبِيبِ بْنِ غَرْقَدَةَ، عَنْ سُلَيْمَانَ بْنِ عَمْرِو بْنِ الأَحْوَصِ، عَنْ أَبِيهِ، قَالَ سَمِعْتُ النَّبِيَّ ـ صلى الله عليه وسلم ـ يَقُولُ فِي حَجَّةِ الْوَدَاعِ ‏""‏ يَا أَيُّهَا النَّاسُ أَلاَ أَىُّ يَوْمٍ أَحْرَمُ ‏""‏ ‏.‏ ثَلاَثَ مَرَّاتٍ قَالُوا يَوْمُ الْحَجِّ الأَكْبَرِ ‏.‏ قَالَ ‏""‏ فَإِنَّ دِمَاءَكُمْ وَأَمْوَالَكُمْ وَأَعْرَاضَكُمْ بَيْنَكُمْ حَرَامٌ كَحُرْمَةِ يَوْمِكُمْ هَذَا فِي شَهْرِكُمْ هَذَا فِي بَلَدِكُمْ هَذَا أَلاَ لاَ يَجْنِي جَانٍ إِلاَّ عَلَى نَفْسِهِ وَلاَ يَجْنِي وَالِدٌ عَلَى وَلَدِهِ وَلاَ مَوْلُودٌ عَلَى وَالِدِهِ ‏.‏ أَلاَ إِنَّ الشَّيْطَانَ قَدْ أَيِسَ أَنْ يُعْبَدَ فِي بَلَدِكُمْ هَذَا أَبَدًا وَلَكِنْ سَيَكُونُ لَهُ طَاعَةٌ فِي بَعْضِ مَا تَحْتَقِرُونَ مِنْ أَعْمَالِكُمْ فَيَرْضَى بِهَا أَلاَ وَكُلُّ دَمٍ مِنْ دِمَاءِ الْجَاهِلِيَّةِ مَوْضُوعٌ وَأَوَّلُ مَا أَضَعُ مِنْهَا دَمُ الْحَارِثِ بْنِ عَبْدِ الْمُطَّلِبِ - كَانَ مُسْتَرْضِعًا فِي بَنِي لَيْثٍ فَقَتَلَتْهُ هُذَيْلٌ - أَلاَ وَإِنَّ كُلَّ رِبًا مِنْ رِبَا الْجَاهِلِيَّةِ مَوْضُوعٌ لَكُمْ رُءُوسُ أَمْوَالِكُمْ لاَ تَظْلِمُونَ وَلاَ تُظْلَمُونَ أَلاَ يَا أُمَّتَاهُ هَلْ بَلَّغْتُ ‏""‏ ‏.‏ ثَلاَثَ مَرَّاتٍ قَالُوا نَعَمْ ‏.‏ قَالَ ‏""‏ اللَّهُمَّ اشْهَدْ ‏""‏ ‏.‏ ثَلاَثَ مَرَّاتٍ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۰۵۹، ومصباح الزجاجة:۹۸۸),2791,It was\nnarrated from Sulaiman bin ‘Amr bin Ahwas that his father\nsaid:,Chapters on Hajj Rituals
2792,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا أَبِي، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ، عَنْ عَبْدِ السَّلاَمِ، عَنِ الزُّهْرِيِّ، عَنْ مُحَمَّدِ بْنِ جُبَيْرِ بْنِ مُطْعِمٍ، عَنْ أَبِيهِ، قَالَ قَامَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ بِالْخَيْفِ مِنْ مِنًى فَقَالَ ‏ ‏ نَضَّرَ اللَّهُ امْرَأً سَمِعَ مَقَالَتِي فَبَلَّغَهَا فَرُبَّ حَامِلِ فِقْهٍ غَيْرُ فَقِيهٍ وَرُبَّ حَامِلِ فِقْهٍ إِلَى مَنْ هُوَ أَفْقَهُ مِنْهُ ثَلاَثٌ لاَ يُغِلُّ عَلَيْهِنَّ قَلْبُ مُؤْمِنٍ إِخْلاَصُ الْعَمَلِ لِلَّهِ وَالنَّصِيحَةُ لِوُلاَةِ الْمُسْلِمِينَ وَلُزُومُ جَمَاعَتِهِمْ فَإِنَّ دَعْوَتَهُمْ تُحِيطُ مِنْ وَرَائِهِمْ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن ابی داود/الجہاد ۴۲ (۲۵۴۱)، سنن النسائی/الجہاد ۲۵ (۳۱۴۳)، سنن الترمذی/فضائل الجہاد ۱۹ (۱۶۵۴)،۲۱ (۱۹۵۶)،(تحفة الأشراف:۱۱۳۵۹)، وقد أخرجہ: مسند احمد (۵/۲۳۰،۲۳۵،۲۴۳،۲۴۴، سنن الدارمی/الجہاد ۵ (۲۴۳۹),,It was\nnarrated from Muhammad bin Jubair bin Mut’im that his father\nsaid:,Chapters on Hajj Rituals
2793,"حَدَّثَنَا إِسْمَاعِيلُ بْنُ تَوْبَةَ، حَدَّثَنَا زَافِرُ بْنُ سُلَيْمَانَ، عَنْ أَبِي سِنَانٍ، عَنْ عَمْرِو بْنِ مُرَّةَ، عَنْ مُرَّةَ، عَنْ عَبْدِ اللَّهِ بْنِ مَسْعُودٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ وَهُوَ عَلَى نَاقَتِهِ الْمُخَضْرَمَةِ بِعَرَفَاتٍ فَقَالَ ‏""‏ أَتَدْرُونَ أَىُّ يَوْمٍ هَذَا وَأَىُّ شَهْرٍ هَذَا وَأَىُّ بَلَدٍ هَذَا ‏""‏ ‏.‏ قَالُوا هَذَا بَلَدٌ حَرَامٌ وَشَهْرٌ حَرَامٌ وَيَوْمٌ حَرَامٌ ‏.‏ قَالَ ‏""‏ أَلاَ وَإِنَّ أَمْوَالَكُمْ وَدِمَاءَكُمْ عَلَيْكُمْ حَرَامٌ كَحُرْمَةِ شَهْرِكُمْ هَذَا فِي بَلَدِكُمْ هَذَا فِي يَوْمِكُمْ هَذَا أَلاَ وَإِنِّي فَرَطُكُمْ عَلَى الْحَوْضِ وَأُكَاثِرُ بِكُمُ الأُمَمَ فَلاَ تُسَوِّدُوا وَجْهِي أَلاَ وَإِنِّي مُسْتَنْقِذٌ أُنَاسًا وَمُسْتَنْقَذٌ مِنِّي أُنَاسٌ فَأَقُولُ يَا رَبِّ أُصَيْحَابِي ‏.‏ فَيَقُولُ إِنَّكَ لاَ تَدْرِي مَا أَحْدَثُوا بَعْدَكَ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۲۵۶، ومصباح الزجاجة:۹۸۹),2793,It was\nnarrated that ‘Abdullah bin Mas’ud said:,Chapters on Hajj Rituals
2794,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا صَدَقَةُ بْنُ خَالِدٍ، حَدَّثَنَا هِشَامُ بْنُ الْغَازِ، قَالَ سَمِعْتُ نَافِعًا، يُحَدِّثُ عَنِ ابْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ وَقَفَ يَوْمَ النَّحْرِ بَيْنَ الْجَمَرَاتِ فِي الْحَجَّةِ الَّتِي حَجَّ فِيهَا فَقَالَ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏""‏ أَىُّ يَوْمٍ هَذَا ‏""‏ ‏.‏ قَالُوا يَوْمُ النَّحْرِ ‏.‏ قَالَ ‏""‏ فَأَىُّ بَلَدٍ هَذَا ‏""‏ ‏.‏ قَالُوا هَذَا بَلَدُ اللَّهِ الْحَرَامُ ‏.‏ قَالَ ‏""‏ فَأَىُّ شَهْرٍ هَذَا ‏""‏ ‏.‏ قَالُوا شَهْرُ اللَّهِ الْحَرَامُ ‏.‏ قَالَ ‏""‏ هَذَا يَوْمُ الْحَجِّ الأَكْبَرِ وَدِمَاؤُكُمْ وَأَمْوَالُكُمْ وَأَعْرَاضُكُمْ عَلَيْكُمْ حَرَامٌ كَحُرْمَةِ هَذَا الْبَلَدِ فِي هَذَا الشَّهْرِ فِي هَذَا الْيَوْمِ ‏""‏ ‏.‏ ثُمَّ قَالَ ‏""‏ هَلْ بَلَّغْتُ ‏""‏ ‏.‏ قَالُوا نَعَمْ ‏.‏ فَطَفِقَ النَّبِيُّ ـ صلى الله عليه وسلم ـ يَقُولُ ‏""‏ اللَّهُمَّ اشْهَدْ ‏""‏ ‏.‏ ثُمَّ وَدَّعَ النَّاسَ فَقَالُوا هَذِهِ حَجَّةُ الْوَدَاعِ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۷۵۷، ومصباح الزجاجة:۹۹۰)، وقد أخرحہ: مسند احمد (۴/۱۱۴),2794,"It was\nnarrated from Ibn ‘Umar that the Messenger of Allah (ﷺ)\nstood, on\nthe Day of Sacrifice, between the Pillars, during the Hajj\nthat he\nperformed. The Prophet (ﷺ) said:",Chapters on Hajj Rituals
2795,حَدَّثَنَا بَكْرُ بْنُ خَلَفٍ أَبُو بِشْرٍ، حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، حَدَّثَنَا سُفْيَانُ، حَدَّثَنِي مُحَمَّدُ بْنُ طَارِقٍ، عَنْ طَاوُسٍ، وَأَبُو الزُّبَيْرِ، عَنْ عَائِشَةَ، وَابْنِ، عَبَّاسٍ أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ أَخَّرَ طَوَافَ الزِّيَارَةِ إِلَى اللَّيْلِ ‏.‏,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۸۷۴، ومصباح الزجاجة:۹۹۱)، وقد أخرجہ: صحیح البخاری/الجہاد ۱۰ (۲۸۰۳)، صحیح مسلم/الإمارة ۲۸ (۱۸۷۶)، سنن الترمذی/فضائل الجہاد ۲۱ (۱۶۵۶)، موطا امام مالک/الجہاد ۱۴ (۲۹)، مسند احمد (۲/۳۹۱،۳۹۸،۳۹۹،۴۰۰،۵۱۲،۵۲،۵۳۱،۵۳۷)، سنن الدارمی/الجہاد ۱۵ (۲۴۵۰),2795,,Chapters on Hajj Rituals
2796,حَدَّثَنَا حَرْمَلَةُ بْنُ يَحْيَى، حَدَّثَنَا ابْنُ وَهْبٍ، أَنْبَأَنَا ابْنُ جُرَيْجٍ، عَنْ عَطَاءٍ، عَنْ عَبْدِ اللَّهِ بْنِ عَبَّاسٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ لَمْ يَرْمُلْ فِي السَّبْعِ الَّذِي أَفَاضَ فِيهِ ‏.‏ قَالَ عَطَاءٌ وَلاَ رَمَلَ فِيهِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الجہاد ۹۸ (۲۹۳۳)، صحیح مسلم/الجہاد ۷ (۱۷۴۲)، سنن الترمذی/الجہاد ۸ (۱۶۷۸)،(تحفة الأشراف:۵۱۵۴)، وقد أخرجہ: مسند احمد (۴/۳۵۳،۳۵۵،۳۸۱),2796,,Chapters on Hajj Rituals
2797,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ مُوسَى، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ أَبِي بَكْرٍ، قَالَ كُنْتُ عِنْدَ ابْنِ عَبَّاسٍ جَالِسًا فَجَاءَهُ رَجُلٌ فَقَالَ مِنْ أَيْنَ جِئْتَ قَالَ مِنْ زَمْزَمَ ‏.‏ قَالَ فَشَرِبْتَ مِنْهَا كَمَا يَنْبَغِي قَالَ وَكَيْفَ قَالَ إِذَا شَرِبْتَ مِنْهَا فَاسْتَقْبِلِ الْكَعْبَةَ وَاذْكُرِ اسْمَ اللَّهِ وَتَنَفَّسْ ثَلاَثًا وَتَضَلَّعْ مِنْهَا فَإِذَا فَرَغْتَ فَاحْمَدِ اللَّهَ عَزَّ وَجَلَّ فَإِنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ إِنَّ آيَةَ مَا بَيْنَنَا وَبَيْنَ الْمُنَافِقِينَ أَنَّهُمْ لاَ يَتَضَلَّعُونَ مِنْ زَمْزَمَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الإمارة ۴۶ (۱۹۰۹)، سنن ابی داود/الصلا ة۳۶۱ (۱۵۲۰)، سنن الترمذی/فضائل الجہاد ۱۹ (۱۶۵۳)، سنن النسائی/الجہاد ۳۶ (۳۱۶۴)،(تحفة الأشراف:۴۶۵۵)، سنن الدارمی/الجہاد ۱۶ (۲۴۵۱),,It was\nnarrated that Muhammad bin ‘Abdur-Rahman bin Abu Bakr said:,Chapters on Hajj Rituals
2798,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، قَالَ قَالَ عَبْدُ اللَّهِ بْنُ الْمُؤَمَّلِ إِنَّهُ سَمِعَ أَبَا الزُّبَيْرِ، يَقُولُ سَمِعْتُ جَابِرَ بْنَ عَبْدِ اللَّهِ، يَقُولُ سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ مَاءُ زَمْزَمَ لِمَا شُرِبَ لَهُ ‏""""‏ ‏.‏""",Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۳۵۰۰، ومصباح الزجاجة:۹۹۲)، وقد أخرجہ: مسند احمد (۲/۲۹۷،۴۲۷),,It was\nnarrated that Jabir bin ‘Abdullah said:,Chapters on Hajj Rituals
2799,حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ الدِّمَشْقِيُّ، حَدَّثَنَا عُمَرُ بْنُ عَبْدِ الْوَاحِدِ، عَنِ الأَوْزَاعِيِّ، حَدَّثَنِي حَسَّانُ بْنُ عَطِيَّةَ، حَدَّثَنِي نَافِعٌ، عَنِ ابْنِ عُمَرَ، قَالَ دَخَلَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ يَوْمَ الْفَتْحِ الْكَعْبَةَ وَمَعَهُ بِلاَلٌ وَعُثْمَانُ بْنُ شَيْبَةَ فَأَغْلَقُوهَا عَلَيْهِمْ مِنْ دَاخِلٍ فَلَمَّا خَرَجُوا سَأَلْتُ بِلاَلاً أَيْنَ صَلَّى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ فَأَخْبَرَنِي أَنَّهُ صَلَّى عَلَى وَجْهِهِ حِينَ دَخَلَ بَيْنَ الْعَمُودَيْنِ عَنْ يَمِينِهِ ثُمَّ لُمْتُ نَفْسِي أَنْ لاَ أَكُونَ سَأَلْتُهُ كَمْ صَلَّى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن الترمذی/فضائل الجہاد ۲۵ (۱۶۶۳)،(تحفة الأشراف:۱۱۵۵۶)، وقد أخرجہ: مسند احمد (۴/۱۳۱),2799,It was\nnarrated that Ibn ‘Umar said:,Chapters on Hajj Rituals
2800,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ عَبْدِ الْمَلِكِ، عَنِ ابْنِ أَبِي مُلَيْكَةَ، عَنْ عَائِشَةَ، قَالَتْ خَرَجَ النَّبِيُّ ـ صلى الله عليه وسلم ـ مِنْ عِنْدِي وَهُوَ قَرِيرُ الْعَيْنِ طَيِّبُ النَّفْسِ ثُمَّ رَجَعَ إِلَىَّ وَهُوَ حَزِينٌ فَقُلْتُ يَا رَسُولَ اللَّهِ خَرَجْتَ مِنْ عِنْدِي وَأَنْتَ قَرِيرُ الْعَيْنِ وَرَجَعْتَ وَأَنْتَ حَزِينٌ ‏.‏ فَقَالَ ‏ ‏ إِنِّي دَخَلْتُ الْكَعْبَةَ وَوَدِدْتُ أَنِّي لَمْ أَكُنْ فَعَلْتُ إِنِّي أَخَافُ أَنْ أَكُونَ أَتْعَبْتُ أُمَّتِي مِنْ بَعْدِي ‏""""‏ ‏.‏""",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۲۵۷ (ألف)، وقد أخرجہ: سنن الترمذی/تفسیر القرآن (۳۰۱۰)، تقدم برقم:۱۹۰,,It was\nnarrated that ‘Aishah said:,Chapters on Hajj Rituals
2801,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، حَدَّثَنَا عُبَيْدُ اللَّهِ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ اسْتَأْذَنَ الْعَبَّاسُ بْنُ عَبْدِ الْمُطَّلِبِ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ أَنْ يَبِيتَ بِمَكَّةَ أَيَّامَ مِنًى مِنْ أَجْلِ سِقَايَتِهِ فَأَذِنَ لَهُ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الإمارة ۳۳ (۱۸۸۷)سنن الترمذی/تفسیر القرآن ۴ (۳۰۱۱)،(تحفة الأشراف:۹۵۷۰)، وقد أخرجہ: سنن الدارمی/الجہاد ۱۹ (۲۴۵۴),2801,It was\nnarrated that Ibn ‘Umar said:,Chapters on Hajj Rituals
2802,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، وَهَنَّادُ بْنُ السَّرِيِّ، قَالاَ حَدَّثَنَا أَبُو مُعَاوِيَةَ، عَنْ إِسْمَاعِيلَ بْنِ مُسْلِمٍ، عَنْ عَطَاءٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ لَمْ يُرَخِّصِ النَّبِيُّ ـ صلى الله عليه وسلم ـ لأَحَدٍ يَبِيتُ بِمَكَّةَ إِلاَّ لِلْعَبَّاسِ مِنْ أَجْلِ السِّقَايَةِ ‏.‏,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/فضائل الجہاد ۲۶ (۱۶۶۸)، سنن النسائی/الجہاد ۳۵ (۳۱۶۳)،(تحفة الأشراف:۱۲۸۶۱)، وقد أخرجہ: مسند احمد (۲/۲۹۷)، سنن الدارمی/الجہاد ۱۷ (۲۴۵۲),2802,It was\nnarrated that Ibn ‘Abbas said:,Chapters on Hajj Rituals
2803,حَدَّثَنَا هَنَّادُ بْنُ السَّرِيِّ، حَدَّثَنَا ابْنُ أَبِي زَائِدَةَ، وَعَبْدَةُ، وَوَكِيعٌ، وَأَبُو مُعَاوِيَةَ ح وَحَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، وَأَبُو مُعَاوِيَةَ ح وَحَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا حَفْصُ بْنُ غِيَاثٍ، كُلُّهُمْ عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، قَالَتْ إِنَّ نُزُولَ الأَبْطَحِ لَيْسَ بِسُنَّةٍ إِنَّمَا نَزَلَهُ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ لِيَكُونَ أَسْمَحَ لِخُرُوجِهِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الجنائز ۱۵ (۳۱۱۱)، سنن النسائی/الجنائز ۱۴ (۱۸۴۷)، الجہاد ۳۹ (۳۱۹۶)،(تحفة الأشراف:۳۱۷۳)، وقد أخرجہ: موطا امام مالک/الجنائز ۱۲ (۳۶)، مسند احمد (۵/۴۴۶),2803,It was\nnarrated that ‘Aishah said:,Chapters on Hajj Rituals
2804,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا مُعَاوِيَةُ بْنُ هِشَامٍ، عَنْ عَمَّارِ بْنِ رُزَيْقٍ، عَنِ الأَعْمَشِ، عَنْ إِبْرَاهِيمَ، عَنِ الأَسْوَدِ، عَنْ عَائِشَةَ، قَالَتِ ادَّلَجَ النَّبِيُّ ـ صلى الله عليه وسلم ـ لَيْلَةَ النَّفْرِ مِنَ الْبَطْحَاءِ ادِّلاَجًا ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۷۳۲)، وقد أخرجہ: صحیح البخاری/الأذان ۳۲ (۶۵۲)، صحیح مسلم/الإمارة ۵۱ (۱۹۱۴),2804,It was\nnarrated that ‘Aishah said:,Chapters on Hajj Rituals
2805,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَنْبَأَنَا عُبَيْدُ اللَّهِ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ كَانَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ وَأَبُو بَكْرٍ وَعُمَرُ وَعُثْمَانُ يَنْزِلُونَ بِالأَبْطَحِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/جزاء الصید ۱۸ (۱۸۴۶)، الجہاد۱۶۰ (۳۰۴۴)، المغازي ۴۸ (۴۲۸۶)، اللباس ۱۷ (۵۸۰۸)، صحیح مسلم/الحج ۸۴ (۱۳۵۷)، سنن ابی داود/الجہاد ۱۲۷ (۲۶۸۵)، سنن الترمذی/الجہاد ۱۸ (۱۶۹۳)، الشمائل ۱۶ (۱۰۶)، سنن النسائی/الحج ۱۰۷ (۲۸۷۰،۲۸۷۱)،(تحفة الأشراف:۱۵۲۷)، وقد أخرجہ: موطا امام مالک/الحج ۸۱ (۲۴۷)، مسند احمد (۳/۱۰۹،۱۶۴،۱۸۰،۱۸۶،۲۲۴،۲۳۲،۲۴۰)، سنن الدارمی/المناسک ۸۸ (۱۹۸۱)، السیر ۲۰ (۲۵۰۰),2805,It was\nnarrated that Ibn ‘Umar said:,Chapters on Hajj Rituals
2806,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ سُلَيْمَانَ، عَنْ طَاوُسٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ كَانَ النَّاسُ يَنْصَرِفُونَ كُلَّ وَجْهٍ فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لاَ يَنْفِرَنَّ أَحَدٌ حَتَّى يَكُونَ آخِرُ عَهْدِهِ بِالْبَيْتِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۸۰۵، ومصباح الزجاجة:۹۹۳)، وقد أخرجہ: سنن ابی داود/الجہاد ۷۵ (۲۵۹۰)، مسند احمد (۳/۴۴۹),,It was\nnarrated that Ibn ‘Abbas said:,Chapters on Hajj Rituals
2807,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا إِبْرَاهِيمُ بْنُ يَزِيدَ، عَنْ طَاوُسٍ، عَنِ ابْنِ عُمَرَ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ أَنْ يَنْفِرَ الرَّجُلُ حَتَّى يَكُونَ آخِرُ عَهْدِهِ بِالْبَيْتِ ‏.‏,Al-Albani: Sahih Isnaad; Muhammad Fouad Abd al-Baqi: Sahih Isnaad; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الجہاد ۸۳ (۲۹۰۹)،(تحفة الأشراف:۴۸۷۴),2807,It was\nnarrated that Ibn ‘Umar said:,Chapters on Hajj Rituals
2808,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ الزُّهْرِيِّ، عَنْ عُرْوَةَ، عَنْ عَائِشَةَ، ح وَحَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، عَنِ ابْنِ شِهَابٍ، عَنْ أَبِي سَلَمَةَ، وَعُرْوَةَ، عَنْ عَائِشَةَ، قَالَتْ حَاضَتْ صَفِيَّةُ بِنْتُ حُيَىٍّ بَعْدَمَا أَفَاضَتْ ‏.‏ قَالَتْ عَائِشَةُ فَذَكَرْتُ ذَلِكَ لِرَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ ‏.‏ فَقَالَ ‏""‏ أَحَابِسَتُنَا هِيَ ‏""‏ ‏.‏ فَقُلْتُ إِنَّهَا قَدْ أَفَاضَتْ ثُمَّ حَاضَتْ بَعْدَ ذَلِكَ ‏.‏ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏""‏ فَلْتَنْفِرْ ‏""‏ ‏.‏",Al-Albani: Hasan Isnaad; Muhammad Fouad Abd al-Baqi: Hasan Isnaad; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن الترمذی/السیر ۱۲ (۱۵۱۶)،(تحفة الأشراف:۵۸۲۷)، وقد أخرجہ: مسند احمد (۱/۲۴۶۱،۲۷۱),2808,It was\nnarrated that ‘Aishah said:,Chapters on Hajj Rituals
2809,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا أَبُو مُعَاوِيَةَ، حَدَّثَنَا الأَعْمَشُ، عَنْ إِبْرَاهِيمَ، عَنِ الأَسْوَدِ، عَنْ عَائِشَةَ، قَالَتْ ذَكَرَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ صَفِيَّةَ فَقُلْنَا قَدْ حَاضَتْ ‏.‏ فَقَالَ ‏""‏ عَقْرَى حَلْقَى مَا أُرَاهَا إِلاَّ حَابِسَتَنَا ‏""‏ ‏.‏ فَقُلْنَا يَا رَسُولَ اللَّهِ إِنَّهَا قَدْ طَافَتْ يَوْمَ النَّحْرِ ‏.‏ قَالَ ‏""‏ فَلاَ إِذًا مُرُوهَا فَلْتَنْفِرْ ‏""‏ ‏.‏",Al-Albani: Daif Isnaad; Muhammad Fouad Abd al-Baqi: Daif Isnaad; Zubair Ali Zai: Daif,takhreej: «تفرد بن ابن ماجہ،(تحفة الأشراف:۱۰۱۸۲، ومصباح الزجاجة:۹۹۴)، وقد أخرجہ: مسند احمد (۱/۱۴۸),2809,It was\nnarrated that ‘Aishah said:,Chapters on Hajj Rituals
2811,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ الْعَبْدِيُّ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو، حَدَّثَنِي يَحْيَى بْنُ عَبْدِ الرَّحْمَنِ بْنِ حَاطِبٍ، عَنْ عَائِشَةَ، قَالَتْ خَرَجْنَا مَعَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ لِلْحَجِّ عَلَى أَنْوَاعٍ ثَلاَثَةٍ فَمِنَّا مَنْ أَهَلَّ بِحَجٍّ وَعُمْرَةٍ مَعًا وَمِنَّا مَنْ أَهَلَّ بِحَجٍّ مُفْرَدٍ وَمِنَّا مَنْ أَهَلَّ بِعُمْرَةٍ مُفْرَدَةٍ ‏.‏ فَمَنْ كَانَ أَهَلَّ بِحَجٍّ وَعُمْرَةٍ مَعًا لَمْ يَحْلِلْ مِنْ شَىْءٍ مِمَّا حَرُمَ مِنْهُ حَتَّى يَقْضِيَ مَنَاسِكَ الْحَجِّ وَمَنْ أَهَلَّ بِالْحَجِّ مُفْرَدًا لَمْ يَحْلِلْ مِنْ شَىْءٍ مِمَّا حَرُمَ مِنْهُ حَتَّى يَقْضِيَ مَنَاسِكَ الْحَجِّ وَمَنْ أَهَلَّ بِعُمْرَةٍ مُفْرَدَةٍ فَطَافَ بِالْبَيْتِ وَبَيْنَ الصَّفَا وَالْمَرْوَةِ حَلَّ مَا حَرُمَ مِنْهُ حَتَّى يَسْتَقْبِلَ حَجًّا ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن الترمذی/فضائل الجہاد ۱۱ (۱۶۳۷،۱۶۳۸)،(تحفة الأشراف:۹۹۲۹)، وقد أخرجہ: مسند احمد (۴/۱۴۴،۱۴۸، سنن الدارمی/الجہاد ۱۴ (۲۴۴۹),2811,It was\nnarrated that ‘Aishah said:,Chapters on Hajj Rituals
2812,حَدَّثَنَا الْقَاسِمُ بْنُ مُحَمَّدِ بْنِ عَبَّادٍ الْمُهَلَّبِيُّ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ دَاوُدَ، حَدَّثَنَا سُفْيَانُ، قَالَ حَجَّ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ثَلاَثَ حَجَّاتٍ حِجَّتَيْنِ قَبْلَ أَنْ يُهَاجِرَ وَحَجَّةً بَعْدَ مَا هَاجَرَ مِنَ الْمَدِينَةِ وَقَرَنَ مَعَ حَجَّتِهِ عُمْرَةً وَاجْتَمَعَ مَا جَاءَ بِهِ النَّبِيُّ ـ صلى الله عليه وسلم ـ وَمَا جَاءَ بِهِ عَلِيٌّ مِائَةَ بَدَنَةٍ مِنْهَا جَمَلٌ لأَبِي جَهْلٍ فِي أَنْفِهِ بُرَةٌ مِنْ فِضَّةٍ فَنَحَرَ النَّبِيُّ ـ صلى الله عليه وسلم ـ بِيَدِهِ ثَلاَثًا وَسِتِّينَ وَنَحَرَ عَلِيٌّ مَا غَبَرَ ‏.‏ قِيلَ لَهُ مَنْ ذَكَرَهُ قَالَ جَعْفَرٌ عَنْ أَبِيهِ عَنْ جَابِرٍ وَابْنُ أَبِي لَيْلَى عَنِ الْحَكَمِ عَنْ مِقْسَمٍ عَنِ ابْنِ عَبَّاسٍ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۷۶۵)، وقد أخرجہ: سنن الترمذی/فضائل الجہاد ۱۱ (۱۶۳۸),2812,Sufyan\nsaid:,Chapters on Hajj Rituals
2813,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، وَابْنُ، عُلَيَّةَ عَنْ حَجَّاجِ بْنِ أَبِي عُثْمَانَ، حَدَّثَنِي يَحْيَى بْنُ أَبِي كَثِيرٍ، حَدَّثَنِي عِكْرِمَةُ، حَدَّثَنِي الْحَجَّاجُ بْنُ عَمْرٍو الأَنْصَارِيُّ، قَالَ سَمِعْتُ النَّبِيَّ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ مَنْ كُسِرَ أَوْ عَرِجَ فَقَدْ حَلَّ وَعَلَيْهِ حَجَّةٌ أُخْرَى ‏""""‏ ‏.‏ فَحَدَّثْتُ بِهِ ابْنَ عَبَّاسٍ، وَأَبَا، هُرَيْرَةَ فَقَالاَ صَدَقَ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الإمارة ۵۲ (۱۹۱۷)، سنن ابی داود/الجہاد ۲۴ (۲۵۱۴)،(تحفة الأشراف:۹۹۱۱)، وقد أخرجہ: سنن الترمذی/تفسیر القرآن ۹ (۳۰۸۳)، مسند احمد (۴/۱۵۷)، سنن الدارمی/الجہاد ۱۴ (۲۴۴۸),,It was\nnarrated from ‘Ikrimah:,Chapters on Hajj Rituals
2814,"حَدَّثَنَا سَلَمَةُ بْنُ شَبِيبٍ، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَنْبَأَنَا مَعْمَرٌ، عَنْ يَحْيَى بْنِ أَبِي كَثِيرٍ، عَنْ عِكْرِمَةَ، عَنْ عَبْدِ اللَّهِ بْنِ رَافِعٍ، - مَوْلَى أُمِّ سَلَمَةَ - قَالَ سَأَلْتُ الْحَجَّاجَ بْنَ عَمْرٍو عَنْ حَبْسِ الْمُحْرِمِ فَقَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ كُسِرَ أَوْ مَرِضَ أَوْ عَرِجَ فَقَدْ حَلَّ وَعَلَيْهِ الْحَجُّ مِنْ قَابِلٍ ‏""""‏ ‏.‏ قَالَ عِكْرِمَةُ فَحَدَّثْتُ بِهِ ابْنَ عَبَّاسٍ، وَأَبَا، هُرَيْرَةَ فَقَالاَ صَدَقَ ‏.‏ قَالَ عَبْدُ الرَّزَّاقِ فَوَجَدْتُهُ فِي جُزْءِ هِشَامٍ صَاحِبِ الدَّسْتَوَائِيِّ فَأَتَيْتُ بِهِ مَعْمَرًا فَقَرَأَ عَلَىَّ أَوْ قَرَأْتُ عَلَيْهِ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۹۷۱)، وقد أخرجہ: سنن ابی داود/الجہاد ۲۴ (۲۵۱۳)، سنن الترمذی/فضائل الجہاد ۱۱ (۱۶۳۷)، سنن النسائی/الجہاد ۲۶ (۳۱۴۸)، الخیل ۸ (۳۶۰۸)، مسند احمد (۴/۱۴۴،۱۴۶،۱۴۸،۱۵۴، سنن الدارمی/الجہاد ۱۴ (۲۴۴۹),,"It was\nnarrated from ‘Ikrimah, from ‘Abdullah bin Rafi’, the freed\nslave of Umm Salamah, that he said:",Chapters on Hajj Rituals
2815,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، وَمُحَمَّدُ بْنُ الْوَلِيدِ، قَالاَ حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، حَدَّثَنَا شُعْبَةُ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَصْبَهَانِيِّ، عَنْ عَبْدِ اللَّهِ بْنِ مَعْقِلٍ، قَالَ قَعَدْتُ إِلَى كَعْبِ بْنِ عُجْرَةَ فِي الْمَسْجِدِ فَسَأَلْتُهُ عَنْ هَذِهِ الآيَةِ، ‏{فَفِدْيَةٌ مِنْ صِيَامٍ أَوْ صَدَقَةٍ أَوْ نُسُكٍ}‏ ‏.‏ قَالَ كَعْبٌ فِيَّ أُنْزِلَتْ كَانَ بِي أَذًى مِنْ رَأْسِي فَحُمِلْتُ إِلَى رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ وَالْقَمْلُ يَتَنَاثَرُ عَلَى وَجْهِي فَقَالَ ‏""‏ مَا كُنْتُ أُرَى الْجُهْدَ بَلَغَ مِنْكَ مَا أَرَى أَتَجِدُ شَاةً ‏""‏ ‏.‏ قُلْتُ لاَ ‏.‏ قَالَ فَنَزَلَتْ هَذِهِ الآيَةُ ‏{فَفِدْيَةٌ مِنْ صِيَامٍ أَوْ صَدَقَةٍ أَوْ نُسُكٍ}‏ ‏.‏ قَالَ فَالصَّوْمُ ثَلاَثَةُ أَيَّامٍ وَالصَّدَقَةُ عَلَى سِتَّةِ مَسَاكِينَ لِكُلِّ مِسْكِينٍ نِصْفُ صَاعٍ مِنْ طَعَامٍ وَالنُّسُكُ شَاةٌ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۴۲۸، ومصباح الزجاجة:۹۹۶)، وقد أخرجہ: مسند احمد (۱/۳۶۴),2815,It was\nnarrated that ‘Abdullah bin Ma’qil said:,Chapters on Hajj Rituals
2816,حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نَافِعٍ، عَنْ أُسَامَةَ بْنِ زَيْدٍ، عَنْ مُحَمَّدِ بْنِ كَعْبٍ، عَنْ كَعْبِ بْنِ عُجْرَةَ، قَالَ أَمَرَنِي النَّبِيُّ ـ صلى الله عليه وسلم ـ حِينَ آذَانِي الْقَمْلُ أَنْ أَحْلِقَ رَأْسِي وَأَصُومَ ثَلاَثَةَ أَيَّامٍ أَوْ أُطْعِمَ سِتَّةَ مَسَاكِينَ وَقَدْ عَلِمَ أَنْ لَيْسَ عِنْدِي مَا أَنْسُكُ ‏.‏,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن الترمذی/تفسیر القرآ ن ۵۱ (۲)(۳۲۷۳،۳۲۷۴)،(تحفة الأشراف:۳۲۷۷)، وقد أخرجہ: مسند احمد (۳/۴۸۲),2816,It was\nnarrated that Ka’b bin ‘Ujrah said:,Chapters on Hajj Rituals
2817,حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، أَنْبَأَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ يَزِيدَ بْنِ أَبِي زِيَادٍ، عَنْ مِقْسَمٍ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ احْتَجَمَ وَهُوَ صَائِمٌ مُحْرِمٌ ‏.‏,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Hasan,takhreej: «سنن ابی داود/الجہاد ۷۶ (۲۵۹۲)، سنن الترمذی/الجہاد ۹ (۱۶۷۹)، سنن النسائی/الحج ۱۰۶ (۲۸۶۹)،(تحفة الأشراف:۲۸۸۹),2817,,Chapters on Hajj Rituals
2818,حَدَّثَنَا بَكْرُ بْنُ خَلَفٍ أَبُو بِشْرٍ، حَدَّثَنَا مُحَمَّدُ بْنُ أَبِي الضَّيْفِ، عَنِ ابْنِ خُثَيْمٍ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ احْتَجَمَ وَهُوَ مُحْرِمٌ مِنْ رَهْصَةٍ أَخَذَتْهُ ‏.‏,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Hasan,takhreej: «سنن الترمذی/الجہاد ۱۰ (۱۶۸۱)،(تحفة الأشراف:۶۵۴۲),2818,,Chapters on Hajj Rituals
2819,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا حَمَّادُ بْنُ سَلَمَةَ، عَنْ فَرْقَدٍ السَّبَخِيِّ، عَنْ سَعِيدِ بْنِ جُبَيْرٍ، عَنِ ابْنِ عُمَرَ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ كَانَ يَدَّهِنُ رَأْسَهُ بِالزَّيْتِ وَهُوَ مُحْرِمٌ غَيْرَ الْمُقَتَّتِ ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «صحیح مسلم/اللباس و الزینة ۲ (۲۰۶۹)، سنن ابی داود/اللباس ۱۲ (۴۰۵۴)، سنن النسائی/الکبری الزینة (۹۶۱۹)،(تحفة الأشراف:۱۵۷۲۱)، وقد أخرجہ: مسند احمد (۶/۴۷،۳۴۸،۳۵۳)، الأدب المفرد (۳۴۸),2819,,Chapters on Hajj Rituals
2820,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا سُفْيَانُ، عَنْ عَمْرِو بْنِ دِينَارٍ، عَنْ سَعِيدِ بْنِ جُبَيْرٍ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ رَجُلاً، أَوْقَصَتْهُ رَاحِلَتُهُ وَهُوَ مُحْرِمٌ فَقَالَ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏""‏ اغْسِلُوهُ بِمَاءٍ وَسِدْرٍ وَكَفِّنُوهُ فِي ثَوْبَيْهِ وَلاَ تُخَمِّرُوا وَجْهَهُ وَلاَ رَأْسَهُ فَإِنَّهُ يُبْعَثُ يَوْمَ الْقِيَامَةِ مُلَبِّيًا ‏""‏ ‏.‏ حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا شُعْبَةُ، عَنْ أَبِي بِشْرٍ، عَنْ سَعِيدِ بْنِ جُبَيْرٍ، عَنِ ابْنِ عَبَّاسٍ، مِثْلَهُ إِلاَّ أَنَّهُ قَالَ أَعْقَصَتْهُ رَاحِلَتُهُ ‏.‏ وَقَالَ ‏""""‏ لاَ تُقَرِّبُوهُ طِيبًا فَإِنَّهُ يُبْعَثُ يَوْمَ الْقِيَامَةِ مُلَبِّيًا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/اللباس ۲۵ (۵۸۲۸)، صحیح مسلم/اللباس ۲ (۲۰۶۹)، سنن ابی داود/اللباس ۱۰ (۴۰۴۲)، سنن النسائی/الزینة ۳۸ (۵۳۱۴)،(تحفة الأشراف:۱۰۵۹۷)، وقد أخرجہ: مسند احمد (۱/۱۵،۳۶،۴۳),,It was\nnarrated from Ibn ‘Abbas that a man’s neck was broken by his\nmount (from falling) while he was in the state of Ihram. The Prophet\n(ﷺ) said:,Chapters on Hajj Rituals
2821,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا جَرِيرُ بْنُ حَازِمٍ، عَنْ عَبْدِ اللَّهِ بْنِ عُبَيْدِ بْنِ عُمَيْرٍ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِي عَمَّارٍ، عَنْ جَابِرٍ، قَالَ جَعَلَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ فِي الضَّبُعِ يُصِيبُهُ الْمُحْرِمُ كَبْشًا وَجَعَلَهُ مِنَ الصَّيْدِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «صحیح مسلم/الحج ۸۴ (۱۳۵۹)،(تحفة الأشراف:۱۰۷۱۶)، وقد أخرجہ: سنن ابی داود/اللباس ۲۴ (۴۰۷۷)، سنن الترمذی/الشمائل ۱۶ (۱۰۸،۱۰۹)، سنن النسائی/الزینة من المجتبیٰ ۵۶ (۵۳۴۸)، مسند احمد (۴/۳۰۷)، سنن الدارمی/المناسک ۸۸ (۱۹۸۲),2821,It was\nnarrated that Jabir said:,Chapters on Hajj Rituals
2822,"حَدَّثَنَا مُحَمَّدُ بْنُ مُوسَى الْقَطَّانُ الْوَاسِطِيُّ، حَدَّثَنَا يَزِيدُ بْنُ مَوْهَبٍ، حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِيَةَ الْفَزَارِيُّ، حَدَّثَنَا عَلِيُّ بْنُ عَبْدِ الْعَزِيزِ، حَدَّثَنَا حُسَيْنٌ الْمُعَلِّمُ، عَنْ أَبِي الْمُهَزِّمِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ فِي بَيْضِ النَّعَامِ يُصِيبُهُ الْمُحْرِمُ ‏ ‏ ثَمَنُهُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «صحیح مسلم/الحج ۸۴ (۱۳۵۸)، سنن ابی داود/اللباس ۲۴ (۴۰۷۶)، سنن الترمذی/اللباس ۱۱ (۱۷۳۵)، سنن النسائی/الحج ۱۰۷ (۲۸۷۲)، والزینة من المجتبیٰ ۵۵ (۵۳۴۶،۵۳۴۷)،(تحفة الأشراف:۲۶۸۹)، وقد أخرجہ: مسند احمد (۳/۳۶۳،۳۸۷),,"It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid,\nconcerning an ostrich egg taken by a Muhrim:",Chapters on Hajj Rituals
2823,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَمُحَمَّدُ بْنُ بَشَّارٍ، وَمُحَمَّدُ بْنُ الْمُثَنَّى، وَمُحَمَّدُ بْنُ الْوَلِيدِ، قَالُوا حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، حَدَّثَنَا شُعْبَةُ، سَمِعْتُ قَتَادَةَ، يُحَدِّثُ عَنْ سَعِيدِ بْنِ الْمُسَيَّبِ، عَنْ عَائِشَةَ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ خَمْسٌ فَوَاسِقُ يُقْتَلْنَ فِي الْحِلِّ وَالْحَرَمِ الْحَيَّةُ وَالْغُرَابُ الأَبْقَعُ وَالْفَأْرَةُ وَالْكَلْبُ الْعَقُورُ وَالْحِدَأَةُ ‏""""‏ ‏.‏""",Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۷۱۳، ومصباح الزجاجة:۹۹۷)، وقد أخرجہ: مسند احمد (۳/۴۴۰),,It was\nnarrated from ‘Aishah that the Prophet (ﷺ) said:,Chapters on Hajj Rituals
2824,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، عَنْ عُبَيْدِ اللَّهِ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ خَمْسٌ مِنَ الدَّوَابِّ لاَ جُنَاحَ عَلَى مَنْ قَتَلَهُنَّ - أَوْ قَالَ فِي قَتْلِهِنَّ - وَهُوَ حَرَامٌ الْعَقْرَبُ وَالْغُرَابُ وَالْحِدَأَةُ وَالْفَأْرَةُ وَالْكَلْبُ الْعَقُورُ ‏""‏ ‏.‏",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۲۹۶، ومصباح الزجاجة:۹۹۸),2824,It was\nnarrated from Ibn ‘Umar that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Hajj Rituals
2825,"حَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا مُحَمَّدُ بْنُ فُضَيْلٍ، عَنْ يَزِيدَ بْنِ أَبِي زِيَادٍ، عَنِ ابْنِ أَبِي نُعْمٍ، عَنْ أَبِي سَعِيدٍ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ أَنَّهُ قَالَ ‏ ‏ يَقْتُلُ الْمُحْرِمُ الْحَيَّةَ وَالْعَقْرَبَ وَالسَّبُعَ الْعَادِيَ وَالْكَلْبَ الْعَقُورَ وَالْفَأْرَةَ الْفُوَيْسِقَةَ ‏""""‏ ‏.‏ فَقِيلَ لَهُ لِمَ قِيلَ لَهَا الْفُوَيْسِقَةُ قَالَ لأَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ اسْتَيْقَظَ لَهَا وَقَدْ أَخَذَتِ الْفَتِيلَةَ لِتُحْرِقَ بِهَا الْبَيْتَ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۴۶۲۶، ومصباح الزجاجة:۹۹۹)، وقد أخرجہ: مسند احمد (۲/۳۵۸،۴۰۳),,It was\nnarrated from Abu Sa’eed that the Prophet (ﷺ) said:,Chapters on Hajj Rituals
2826,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَهِشَامُ بْنُ عَمَّارٍ، قَالاَ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ح وَحَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، جَمِيعًا عَنِ ابْنِ شِهَابٍ الزُّهْرِيِّ، عَنْ عُبَيْدِ اللَّهِ بْنِ عَبْدِ اللَّهِ، عَنِ ابْنِ عَبَّاسٍ، قَالَ أَنْبَأَنَا صَعْبُ بْنُ جَثَّامَةَ، قَالَ مَرَّ بِي رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ وَأَنَا بِالأَبْوَاءِ أَوْ بِوَدَّانَ فَأَهْدَيْتُ لَهُ حِمَارَ وَحْشٍ فَرَدَّهُ عَلَىَّ فَلَمَّا رَأَى فِي وَجْهِيَ الْكَرَاهِيَةَ ‏.‏ قَالَ ‏ ‏ إِنَّهُ لَيْسَ بِنَا رَدٌّ عَلَيْكَ وَلَكِنَّا حُرُمٌ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۴۲۷، ومصباح الزجاجة:۱۰۰۰)، وقد أخرجہ: سنن ابی داود/الجہاد ۸۰ (۲۶۰۰)، سنن الترمذی/الدعوات ۴۴ (۳۴۳۸),,It was\nnarrated that Ibn ‘Abbas said:,Chapters on Hajj Rituals
2827,حَدَّثَنَا عُثْمَانُ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عِمْرَانُ بْنُ مُحَمَّدِ بْنِ أَبِي لَيْلَى، عَنْ أَبِيهِ، عَنْ عَبْدِ الْكَرِيمِ، عَنْ عَبْدِ اللَّهِ بْنِ الْحَارِثِ، عَنِ ابْنِ عَبَّاسٍ، عَنْ عَلِيِّ بْنِ أَبِي طَالِبٍ، قَالَ أُتِيَ النَّبِيُّ ـ صلى الله عليه وسلم ـ بِلَحْمِ صَيْدٍ وَهُوَ مُحْرِمٌ فَلَمْ يَأْكُلْهُ ‏.‏,Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۵۷۱، ومصباح الزجاجة:۱۰۰۱),2827,It was\nnarrated that ‘Ali bin Abu Talib said:,Chapters on Hajj Rituals
2828,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ يَحْيَى بْنِ سَعِيدٍ، عَنْ مُحَمَّدِ بْنِ إِبْرَاهِيمَ التَّيْمِيِّ، عَنْ عِيسَى بْنِ طَلْحَةَ، عَنْ طَلْحَةَ بْنِ عُبَيْدِ اللَّهِ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ أَعْطَاهُ حِمَارَ وَحْشٍ وَأَمَرَهُ أَنْ يُفَرِّقَهُ فِي الرِّفَاقِ وَهُمْ مُحْرِمُونَ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/المغازي ۶ (۳۹۵۹)،(تحفة الأشراف:۱۸۵۱)، وقد أخرجہ: سنن الترمذی/السیر ۳۸ (۱۵۹۸),2828,,Chapters on Hajj Rituals
2829,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَنْبَأَنَا مَعْمَرٌ، عَنْ يَحْيَى بْنِ أَبِي كَثِيرٍ، عَنْ عَبْدِ اللَّهِ بْنِ أَبِي قَتَادَةَ، عَنْ أَبِيهِ، قَالَ خَرَجْتُ مَعَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ زَمَنَ الْحُدَيْبِيَةِ فَأَحْرَمَ أَصْحَابُهُ وَلَمْ أُحْرِمْ فَرَأَيْتُ حِمَارًا فَحَمَلْتُ عَلَيْهِ وَاصْطَدْتُهُ فَذَكَرْتُ شَأْنَهُ لِرَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ وَذَكَرْتُ أَنِّي لَمْ أَكُنْ أَحْرَمْتُ وَأَنِّي إِنَّمَا اصْطَدْتُهُ لَكَ فَأَمَرَ النَّبِيُّ ـ صلى الله عليه وسلم ـ أَصْحَابَهُ فَأَكَلُوا وَلَمْ يَأْكُلْ مِنْهُ حِينَ أَخْبَرْتُهُ أَنِّي اصْطَدْتُهُ لَهُ ‏.‏,Al-Albani: Daif Isnaad; Muhammad Fouad Abd al-Baqi: Daif Isnaad; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۵۵۱۸، ومصباح الزجاجة:۱۰۰۲),2829,It was\nnarrated from ‘Abdullah bin Abu Qatadah that his father said:,Chapters on Hajj Rituals
2830,حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، عَنِ ابْنِ شِهَابٍ، عَنْ عُرْوَةَ بْنِ الزُّبَيْرِ، وَعَمْرَةَ بِنْتِ عَبْدِ الرَّحْمَنِ، أَنَّ عَائِشَةَ، زَوْجَ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَتْ كَانَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ يُهْدِي مِنَ الْمَدِينَةِ فَأَفْتِلُ قَلاَئِدَ هَدْيِهِ ثُمَّ لاَ يَجْتَنِبُ شَيْئًا مِمَّا يَجْتَنِبُ الْمُحْرِمُ ‏.‏,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Hasan,takhreej: «سنن ابی داود/الأطعمة ۲۴ (۳۷۸۴)، سنن الترمذی/السیر ۱۶ (۱۵۶۵)،(تحفة الأشراف:۱۱۷۳۴)، وقد مسند احمد (۵/۲۲۶),2830,,Chapters on Hajj Rituals
2831,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، عَنِ الأَعْمَشِ، عَنْ إِبْرَاهِيمَ، عَنِ الأَسْوَدِ، عَنْ عَائِشَةَ، زَوْجِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَتْ كُنْتُ أَفْتِلُ الْقَلاَئِدَ لِهَدْىِ النَّبِيِّ ـ صلى الله عليه وسلم ـ فَيُقَلِّدُ هَدْيَهُ ثُمَّ يَبْعَثُ بِهِ ثُمَّ يُقِيمُ لاَ يَجْتَنِبُ شَيْئًا مِمَّا يَجْتَنِبُهُ الْمُحْرِمُ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۸۶۹، ومصباح الزجاجة:۱۰۰۳),2831,It was\nnarrated that ‘Aishah the wife of the Prophet (ﷺ) said:,Chapters on Hajj Rituals
2832,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا أَبُو مُعَاوِيَةَ، عَنِ الأَعْمَشِ، عَنْ إِبْرَاهِيمَ، عَنِ الأَسْوَدِ، عَنْ عَائِشَةَ، قَالَتْ أَهْدَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ مَرَّةً غَنَمًا إِلَى الْبَيْتِ فَقَلَّدَهَا ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الجہاد ۵۱ (۱۸۱۷)، سنن ابی داود/الجہاد ۱۵۳ (۲۷۳۲)، سنن الترمذی/السیر ۱۰ (۱۵۵۸)،(تحفة الأشراف:۱۶۳۵۸)، وقد أخرجہ: مسند احمد (۶/۶۷،۱۴۸)، سنن الدارمی/السیر ۵۴ (۲۵۳۸),2832,It was\nnarrated that ‘Aishah said:,Chapters on Hajj Rituals
2833,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا وَكِيعٌ، عَنْ هِشَامٍ الدَّسْتَوَائِيِّ، عَنْ قَتَادَةَ، عَنْ أَبِي حَسَّانَ الأَعْرَجِ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ أَشْعَرَ الْهَدْىَ فِي السَّنَامِ الأَيْمَنِ وَأَمَاطَ عَنْهُ الدَّمَ ‏.‏ وَقَالَ عَلِيٌّ فِي حَدِيثِهِ بِذِي الْحُلَيْفَةِ وَقَلَّدَ نَعْلَيْنِ ‏.‏,Al-Albani: Sahih Mutawatir; Muhammad Fouad Abd al-Baqi: Sahih Mutawatir; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۷۳۶۱، ومصباح الزجاجة:۱۰۰۴),2833,,Chapters on Hajj Rituals
2834,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ، عَنْ أَفْلَحَ، عَنِ الْقَاسِمِ، عَنْ عَائِشَةَ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَلَّدَ وَأَشْعَرَ وَأَرْسَلَ بِهَا وَلَمْ يَجْتَنِبْ مَا يَجْتَنِبُ الْمُحْرِمُ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۲۱۸، ومصباح الزجاجة:۱۰۰۵),2834,,Chapters on Hajj Rituals
2835,"حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، أَنْبَأَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عَبْدِ الْكَرِيمِ، عَنْ مُجَاهِدٍ، عَنِ ابْنِ أَبِي لَيْلَى، عَنْ عَلِيِّ بْنِ أَبِي طَالِبٍ، قَالَ أَمَرَنِي رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ أَنْ أَقُومَ عَلَى بُدْنِهِ وَأَنْ أَقْسِمَ جِلاَلَهَا وَجُلُودَهَا وَأَنْ لاَ أُعْطِيَ الْجَازِرَ مِنْهَا شَيْئًا وَقَالَ ‏ ‏ نَحْنُ نُعْطِيهِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/المغازي ۸ (۳۹۶۶،۳۹۶۸)، تفسیر سورة الحج ۳ (۴۷۴۳)، صحیح مسلم/التفسیر ۷ (۳۰۳۳)،(تحفة الأشراف:۱۱۹۷۴),,It was\nnarrated that ‘Ali bin Abu Talib said:,Chapters on Hajj Rituals
2836,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا سُفْيَانُ، عَنِ ابْنِ أَبِي لَيْلَى، عَنِ الْحَكَمِ، عَنْ مِقْسَمٍ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ أَهْدَى فِي بُدْنِهِ جَمَلاً لأَبِي جَهْلٍ بُرَتُهُ مِنْ فِضَّةٍ ‏.‏,Al-Albani: Sahih Isnaad; Muhammad Fouad Abd al-Baqi: Sahih Isnaad; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۵۲۹، ومصباح الزجاجة:۱۰۰۶)وقد أخرجہ: صحیح البخاری/الجہاد ۱۷۳ (۳۰۵۱)، صحیح مسلم/الجہاد ۱۳ (۱۷۵۴)، مسند احمد (۴/۴۵،۴۶)، سنن الدارمی/السیر ۱۵ (۲۴۹۵),2836,,Chapters on Hajj Rituals
2837,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ مُوسَى، أَنْبَأَنَا مُوسَى بْنُ عُبَيْدَةَ، عَنْ إِيَاسِ بْنِ سَلَمَةَ، عَنْ أَبِيهِ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ كَانَ فِي بُدْنِهِ جَمَلٌ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/البیوع ۳۷ (۲۱۰۰)، فرض الخمس ۱۸ (۳۱۴۲)، المغازي ۱۸ (۴۳۲۱،۴۳۲۲)، الاحکام ۲۱ (۷۱۷۰)، صحیح مسلم/الجہاد ۱۳ (۱۷۵۱)، سنن ابی داود/الجہاد ۱۴۷ (۲۷۱۷)، سنن الترمذی/السیر ۱۳ (۱۵۶۲)،(تحفة الأشراف:۱۲۱۳۲)، وقد أخرجہ: موطا امام مالک/الجہاد ۱۰ (۱۸)، مسند احمد (۵/۲۹۵،۲۹۶،۳۰۶)، سنن الدارمی/السیر ۴۴ (۲۵۲۸),2837,,Chapters on Hajj Rituals
2838,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا يَحْيَى بْنُ يَمَانٍ، عَنْ سُفْيَانَ، عَنْ عُبَيْدِ اللَّهِ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ اشْتَرَى هَدْيَهُ مِنْ قُدَيْدٍ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۶۲۲، ومصباح الزجاجة:۱۰۰۷)، وقد أخرجہ: مسند احمد (۵/۱۲),2838,,Chapters on Hajj Rituals
2839,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا وَكِيعٌ، عَنْ سُفْيَانَ الثَّوْرِيِّ، عَنْ أَبِي الزِّنَادِ، عَنِ الأَعْرَجِ، عَنْ أَبِي هُرَيْرَةَ، ‏.‏ أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ رَأَى رَجُلاً يَسُوقُ بَدَنَةً فَقَالَ ‏""‏ ارْكَبْهَا ‏""‏ ‏.‏ قَالَ إِنَّهَا بَدَنَةٌ ‏.‏ قَالَ ‏""‏ ارْكَبْهَا وَيْحَكَ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الجہاد ۱۴۶ (۳۰۱۲)، صحیح مسلم/الجہاد ۹ (۱۷۸۵)، سنن الترمذی/السیر ۱۹ (۱۵۷۰)، سنن ابی داود/الجہاد ۱۲۱ (۲۶۷۲)،(تحفة الأشراف:۴۹۳۹)، وقد أخرجہ: مسند احمد (۴/۳۸،۷۱،۷۲،۷۳),2839,It was\nnarrated from Abu Hurairah that the Prophet (ﷺ) saw a man\ndriving a\ncamel and said:,Chapters on Hajj Rituals
2840,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، عَنْ هِشَامٍ، - صَاحِبِ الدَّسْتَوَائِيِّ - عَنْ قَتَادَةَ، عَنْ أَنَسِ بْنِ مَالِكٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ مُرَّ عَلَيْهِ بِبَدَنَةٍ فَقَالَ ‏""‏ ارْكَبْهَا ‏""‏ ‏.‏ قَالَ إِنَّهَا بَدَنَةٌ ‏.‏ قَالَ ‏""‏ ارْكَبْهَا ‏""‏ ‏.‏ قَالَ فَرَأَيْتُهُ رَاكِبَهَا مَعَ النَّبِيِّ ـ صلى الله عليه وسلم ـ فِي عُنُقِهَا نَعْلٌ ‏.‏",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الجہاد ۱۳۴ (۲۵۹۷)،(تحفة الأشراف:۴۵۱۶)، وقد أخرجہ: صحیح مسلم/الجہاد ۱۴ (۱۷۵۵)، مسند احمد (۵/۳۷۷),2840,It was\nnarrated from Anas bin Malik that the Prophet (ﷺ) was brought a\nsacrificial animal and he said (to the man driving the animal):,Chapters on Hajj Rituals
2841,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ الْعَبْدِيُّ، حَدَّثَنَا سَعِيدُ بْنُ أَبِي عَرُوبَةَ، عَنْ قَتَادَةَ، عَنْ سِنَانِ بْنِ سَلَمَةَ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ ذُؤَيْبًا الْخُزَاعِيَّ، حَدَّثَ أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ كَانَ يَبْعَثُ مَعَهُ بِالْبُدْنِ ثُمَّ يَقُولُ ‏ ‏ إِذَا عَطِبَ مِنْهَا شَىْءٌ فَخَشِيتَ عَلَيْهِ مَوْتًا فَانْحَرْهَا ثُمَّ اغْمِسْ نَعْلَهَا فِي دَمِهَا ثُمَّ اضْرِبْ صَفْحَتَهَا وَلاَ تَطْعَمْ مِنْهَا أَنْتَ وَلاَ أَحَدٌ مِنْ أَهْلِ رُفْقَتِكَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۴۰۱)، وقد أخرجہ: صحیح البخاری/الجہاد ۱۴۷ (۳۰۱۴)، صحیح مسلم/الجہاد ۸ (۱۷۴۴)، سنن ابی داود/الجہاد ۱۲۱ (۲۶۶۸)، سنن الترمذی/الجہاد ۱۹ (۱۵۶۹)، موطا امام مالک/الجہاد ۳ (۹)، مسند احمد (۲/۱۲۲،۱۲۳)، سنن الدارمی/السیر ۲۵ (۲۵۰۵),,"It was\nnarrated from Ibn ‘Abbas that Dhu’aib Al-Khuza’i narrated that\nthe Prophet (ﷺ) used to send the sacrificial animals with him, then\nhe would say:",Chapters on Hajj Rituals
2842,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، وَعَمْرُو بْنُ عَبْدِ اللَّهِ، قَالُوا حَدَّثَنَا وَكِيعٌ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ أَبِيهِ، عَنْ نَاجِيَةَ الْخُزَاعِيِّ، - قَالَ عَمْرٌو فِي حَدِيثِهِ وَكَانَ صَاحِبَ بُدْنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ - قَالَ قُلْتُ يَا رَسُولَ اللَّهِ كَيْفَ أَصْنَعُ بِمَا عَطِبَ مِنَ الْبُدْنِ قَالَ ‏ ‏ انْحَرْهُ وَاغْمِسْ نَعْلَهُ فِي دَمِهِ ثُمَّ اضْرِبْ صَفْحَتَهُ وَخَلِّ بَيْنَهُ وَبَيْنَ النَّاسِ فَلْيَأْكُلُوهُ ‏""""‏ ‏.‏""",Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۴۴۹، ومصباح الزجاجة:۱۰۰۸)، وقد أخرجہ: سنن ابی داود/الجہاد ۱۲۱ (۲۶۶۹)، مسند احمد (۴/۱۷۸),,"It was\nnarrated that Najiyah Al-Khuza’i – in his narration, ‘Amr (one\nof the narrators) said that he was the one who looked after the\nsacrificial animals of the Prophet (ﷺ) – said:",Chapters on Hajj Rituals
2843,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عِيسَى بْنُ يُونُسَ، عَنْ عُمَرَ بْنِ سَعِيدِ بْنِ أَبِي حُسَيْنٍ، عَنْ عُثْمَانَ بْنِ أَبِي سُلَيْمَانَ، عَنْ عَلْقَمَةَ بْنِ نَضْلَةَ، قَالَ تُوُفِّيَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ وَأَبُو بَكْرٍ وَعُمَرُ وَمَا تُدْعَى رِبَاعُ مَكَّةَ إِلاَّ السَّوَائِبَ مَنِ احْتَاجَ سَكَنَ وَمَنِ اسْتَغْنَى أَسْكَنَ ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الجہاد ۹۱ (۲۶۱۶)،(تحفة الأشراف:۱۰۷)، وقد أخرجہ: مسند احمد (۵/۲۰۵،۲۰۹),2843,It was\nnarrated that ‘Alqamah bin Nadlah said:,Chapters on Hajj Rituals
2844,"حَدَّثَنَا عِيسَى بْنُ حَمَّادٍ الْمِصْرِيُّ، أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، أَخْبَرَنِي عُقَيْلٌ، عَنْ مُحَمَّدِ بْنِ مُسْلِمٍ، أَنَّهُ قَالَ إِنَّ أَبَا سَلَمَةَ بْنَ عَبْدِ الرَّحْمَنِ بْنِ عَوْفٍ أَخْبَرَهُ أَنَّ عَبْدَ اللَّهِ بْنَ عَدِيِّ بْنِ الْحَمْرَاءِ قَالَ لَهُ رَأَيْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ وَهُوَ عَلَى رَاحِلَتِهِ وَاقِفٌ بِالْحَزْوَرَةِ يَقُولُ ‏ ‏ وَاللَّهِ إِنَّكِ لَخَيْرُ أَرْضِ اللَّهِ وَأَحَبُّ أَرْضِ اللَّهِ إِلَيَّ وَاللَّهِ لَوْلاَ أَنِّي أُخْرِجْتُ مِنْكِ مَا خَرَجْتُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحرث والمزارعة ۴ (۲۳۵۶)، الجہاد ۱۵۴ (۳۰۲۰)، المغازي ۱۴ (۴۰۳۱)، صحیح مسلم/الجہاد ۱۰ (۱۷۴۶)، سنن ابی داود/الجہاد ۹۱ (۲۶۱۵)، سنن الترمذی/التفسیر ۵۹ (۳۳۰۲، السیر ۴ (۱۵۵۲)،(تحفة الأشراف:۸۲۶۷)، وقد أخرجہ: مسند احمد (۲/۱۲۳،۱۴۰)، سنن الدارمی/السیر ۲۳ (۲۵۰۳),,Abu\nSalamah bin ‘Abdur-Rahman bin ‘Awf narrated that ‘Abdullah bin\n‘Adiy bin Hamra’ said to him:,Chapters on Hajj Rituals
2845,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا يُونُسُ بْنُ بُكَيْرٍ، حَدَّثَنَا مُحَمَّدُ بْنُ إِسْحَاقَ، حَدَّثَنَا أَبَانُ بْنُ صَالِحٍ، عَنِ الْحَسَنِ بْنِ مُسْلِمِ بْنِ يَنَّاقٍ، عَنْ صَفِيَّةَ بِنْتِ شَيْبَةَ، قَالَتْ سَمِعْتُ النَّبِيَّ ـ صلى الله عليه وسلم ـ يَخْطُبُ عَامَ الْفَتْحِ فَقَالَ ‏""‏ يَا أَيُّهَا النَّاسُ إِنَّ اللَّهَ حَرَّمَ مَكَّةَ يَوْمَ خَلَقَ السَّمَوَاتِ وَالأَرْضَ فَهِيَ حَرَامٌ إِلَى يَوْمِ الْقِيَامَةِ لاَ يُعْضَدُ شَجَرُهَا وَلاَ يُنَفَّرُ صَيْدُهَا وَلاَ يَأْخُذُ لُقَطَتَهَا إِلاَّ مُنْشِدٌ ‏""‏ ‏.‏ فَقَالَ الْعَبَّاسُ إِلاَّ الإِذْخِرَ فَإِنَّهُ لِلْبُيُوتِ وَالْقُبُورِ ‏.‏ فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏""‏ إِلاَّ الإِذْخِرَ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «أنظر ماقبلہ،(تحفة الأشراف:۸۰۶۰),2845,It was\nnarrated that Safiyyah bint Shaibah said:,Chapters on Hajj Rituals
2846,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ، وَابْنُ الْفُضَيْلِ، عَنْ يَزِيدَ بْنِ أَبِي زِيَادٍ، أَنْبَأَنَا عَبْدُ الرَّحْمَنِ بْنُ سَابِطٍ، عَنْ عَيَّاشِ بْنِ أَبِي رَبِيعَةَ الْمَخْزُومِيِّ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لاَ تَزَالُ هَذِهِ الأُمَّةُ بِخَيْرٍ مَا عَظَّمُوا هَذِهِ الْحُرْمَةَ حَقَّ تَعْظِيمِهَا فَإِذَا ضَيَّعُوا ذَلِكَ هَلَكُوا ‏""""‏ ‏.‏""",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/المغازي ۱۴ (۱۷۵۵)، سنن ابی داود/الجہاد ۱۳۴ (۲۶۹۷)،(تحفة الأشراف:۴۵۱۵)، وقد أخرجہ: مسند احمد (۴/ و ۴۷،۵۱),,It was\nnarrated from ‘Ayyash bin Abu Rabi’ah (Makhzumi) that the\nMessenger of Allah (ﷺ) said:,Chapters on Hajj Rituals
2847,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، وَأَبُو أُسَامَةَ عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ خُبَيْبِ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ حَفْصِ بْنِ عَاصِمٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِنَّ الإِيمَانَ لَيَأْرِزُ إِلَى الْمَدِينَةِ كَمَا تَأْرِزُ الْحَيَّةُ إِلَى جُحْرِهَا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الجہاد ۱۸۷ (۳۰۶۷ تعلیقاً)، سنن ابی داود/الجہاد ۱۳۵ (۲۶۹۹)،(تحفة الأشراف:۷۹۴۳),,it was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Hajj Rituals
2848,"حَدَّثَنَا بَكْرُ بْنُ خَلَفٍ، حَدَّثَنَا مُعَاذُ بْنُ هِشَامٍ، حَدَّثَنَا أَبِي، عَنْ أَيُّوبَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ مَنِ اسْتَطَاعَ مِنْكُمْ أَنْ يَمُوتَ بِالْمَدِينَةِ فَلْيَفْعَلْ فَإِنِّي أَشْهَدُ لِمَنْ مَاتَ بِهَا ‏""‏ ‏.‏",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الجہاد ۱۴۳ (۲۷۱۰)، سنن النسائی/الجنائز ۶۶ (۱۹۶۱)،(تحفة الأشراف:۳۷۶۷)، وقد أخرجہ: موطا امام مالک/الجہاد۱۳ (۲۳)، مسند احمد (۴/۱۱۴،۵/۱۹۲),2848,It was\nnarrated from Ibn ‘Umar that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Hajj Rituals
2849,"حَدَّثَنَا أَبُو مَرْوَانَ، مُحَمَّدُ بْنُ عُثْمَانَ الْعُثْمَانِيُّ حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ أَبِي حَازِمٍ، عَنِ الْعَلاَءِ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ اللَّهُمَّ إِنَّ إِبْرَاهِيمَ خَلِيلُكَ وَنَبِيُّكَ وَإِنَّكَ حَرَّمْتَ مَكَّةَ عَلَى لِسَانِ إِبْرَاهِيمَ اللَّهُمَّ وَأَنَا عَبْدُكَ وَنَبِيُّكَ وَإِنِّي أُحَرِّمُ مَا بَيْنَ لاَبَتَيْهَا ‏""""‏ ‏.‏ قَالَ أَبُو مَرْوَانَ لاَبَتَيْهَا حَرَّتَىِ الْمَدِينَةِ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الجہاد ۱۹۰ (۳۰۷۴)،(تحفة الأشراف:۸۶۳۲)، وقد أخرجہ: مسند احمد (۲/۱۶۰),,It was\nnarrated from Abu Hurairah that the Prophet (ﷺ) said:,Chapters on Hajj Rituals
2850,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدَةُ بْنُ سُلَيْمَانَ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو، عَنْ أَبِي سَلَمَةَ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ أَرَادَ أَهْلَ الْمَدِينَةِ بِسُوءٍ أَذَابَهُ اللَّهُ كَمَا يَذُوبُ الْمِلْحُ فِي الْمَاءِ ‏""""‏ ‏.‏""",Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۱۲۱، ومصباح الزجاجة:۱۰۰۹),,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Hajj Rituals
2851,"حَدَّثَنَا هَنَّادُ بْنُ السَّرِيِّ، حَدَّثَنَا عَبْدَةُ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ، عَنْ عَبْدِ اللَّهِ بْنِ مِكْنَفٍ، قَالَ سَمِعْتُ أَنَسَ بْنَ مَالِكٍ، يَقُولُ إِنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ إِنَّ أُحُدًا جَبَلٌ يُحِبُّنَا وَنُحِبُّهُ وَهُوَ عَلَى تُرْعَةٍ مِنْ تُرَعِ الْجَنَّةِ وَعَيْرٌ عَلَى تُرْعَةٍ مِنْ تُرَعِ النَّارِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الجہاد ۱۵۸ (۲۷۴۸،۲۷۴۹،۲۷۵۰)،(تحفة الأشراف:۳۲۹۳)، وقد أخرجہ: مسند احمد (۴/۱۵۹،۱۶۰)، سنن الدارمی/السیر ۴۳ (۲۵۲۶),,It was\nnarrated that ‘Abdullah bin Miknaf said:,Chapters on Hajj Rituals
2852,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا الْمُحَارِبِيُّ، عَنِ الشَّيْبَانِيِّ، عَنْ وَاصِلٍ الأَحْدَبِ، عَنْ شَقِيقٍ، قَالَ بَعَثَ رَجُلٌ مَعِيَ بِدَرَاهِمَ هَدِيَّةً إِلَى الْبَيْتِ ‏.‏ قَالَ فَدَخَلْتُ الْبَيْتَ وَشَيْبَةُ جَالِسٌ عَلَى كُرْسِيٍّ فَنَاوَلْتُهُ إِيَّاهَا ‏.‏ فَقَالَ أَلَكَ هَذِهِ قُلْتُ لاَ وَلَوْ كَانَتْ لِي لَمْ آتِكَ بِهَا ‏.‏ قَالَ أَمَا لَئِنْ قُلْتَ ذَلِكَ لَقَدْ جَلَسَ عُمَرُ بْنُ الْخَطَّابِ مَجْلِسَكَ الَّذِي جَلَسْتَ فِيهِ فَقَالَ لاَ أَخْرُجُ حَتَّى أَقْسِمَ مَالَ الْكَعْبَةِ بَيْنَ فُقَرَاءِ الْمُسْلِمِينَ ‏.‏ قُلْتُ مَا أَنْتَ بِفَاعِلٍ ‏.‏ قَالَ لأَفْعَلَنَّ ‏.‏ قَالَ وَلِمَ ذَاكَ قُلْتُ لأَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَدْ رَأَى مَكَانَهُ ‏.‏ وَأَبُو بَكْرٍ وَهُمَا أَحْوَجُ مِنْكَ إِلَى الْمَالِ فَلَمْ يُحَرِّكَاهُ ‏.‏ فَقَامَ كَمَا هُوَ فَخَرَجَ ‏.‏,Al-Albani: Daif Isnaad; Muhammad Fouad Abd al-Baqi: Daif Isnaad; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Sahih,takhreej: «سنن الترمذی/السیر ۱۲ (۱۵۶۱)،(تحفة الأشراف:۵۰۹۱)، وقد أخرجہ: مسند احمد (۵/۳۱۹،۳۲۲،۳۲۳)، سنن الدارمی/السیر ۴۲ (۲۵۲۵),2852,It was\nnarrated that Shaqiq said:,Chapters on Hajj Rituals
2853,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِي عُمَرَ الْعَدَنِيُّ، حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ زَيْدٍ الْعَمِّيِّ، عَنْ أَبِيهِ، عَنْ سَعِيدِ بْنِ جُبَيْرٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ أَدْرَكَ رَمَضَانَ بِمَكَّةَ فَصَامَ وَقَامَ مِنْهُ مَا تَيَسَّرَ لَهُ كَتَبَ اللَّهُ لَهُ مِائَةَ أَلْفِ شَهْرِ رَمَضَانَ فِيمَا سِوَاهَا ‏.‏ وَكَتَبَ اللَّهُ لَهُ بِكُلِّ يَوْمٍ عِتْقَ رَقَبَةٍ وَكُلِّ لَيْلَةٍ عِتْقَ رَقَبَةٍ وَكُلِّ يَوْمٍ حُمْلاَنَ فَرَسٍ فِي سَبِيلِ اللَّهِ وَفِي كُلِّ يَوْمٍ حَسَنَةً وَفِي كُلِّ لَيْلَةٍ حَسَنَةً ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «حدیث عبد اللہ بن عمرو تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۷۰۵، ومصباح الزجاجة:۱۰۱۰)، وحدیث حبیب بن مسلمة تقدم تخریجہ،(۲۸۵۱),,It was\nnarrated from Ibn ‘Abbas that the Messenger of Allah (ﷺ)\nsaid:,Chapters on Hajj Rituals
2854,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِي عُمَرَ الْعَدَنِيُّ، حَدَّثَنَا دَاوُدُ بْنُ عَجْلاَنَ، قَالَ طُفْنَا مَعَ أَبِي عِقَالٍ فِي مَطَرٍ فَلَمَّا قَضَيْنَا طَوَافَنَا أَتَيْنَا خَلْفَ الْمَقَامِ فَقَالَ طُفْتُ مَعَ أَنَسِ بْنِ مَالِكٍ فِي مَطَرٍ فَلَمَّا قَضَيْنَا الطَّوَافَ أَتَيْنَا الْمَقَامَ فَصَلَّيْنَا رَكْعَتَيْنِ فَقَالَ لَنَا أَنَسٌ ‏ ‏ ائْتَنِفُوا الْعَمَلَ فَقَدْ غُفِرَ لَكُمْ ‏""""‏ ‏.‏ هَكَذَا قَالَ لَنَا رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ وَطُفْنَا مَعَهُ فِي مَطَرٍ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن ابی داود/الجہاد ۱۵۴ (۲۷۳۳)،(تحفة الأشراف:۸۱۱۱)، وقد أخرجہ: صحیح البخاری/الجہاد ۵۱ (۲۸۶۳)، صحیح مسلم/الجہاد ۱۷ (۱۷۶۲)، سنن الترمذی/السیر ۶ (۱۵۵۴)، مسند احمد (۲/۲،۶۲)، سنن الدارمی/السیر۳۳ (۲۵۱۵),,Dawud\nbin ‘Ajlan said:,Chapters on Hajj Rituals
2855,"حَدَّثَنَا إِسْمَاعِيلُ بْنُ حَفْصٍ الأُبُلِّيُّ، حَدَّثَنَا يَحْيَى بْنُ يَمَانٍ، عَنْ حَمْزَةَ بْنِ حَبِيبٍ الزَّيَّاتِ، عَنْ حُمْرَانَ بْنِ أَعْيَنَ، عَنْ أَبِي الطُّفَيْلِ، عَنْ أَبِي سَعِيدٍ، قَالَ حَجَّ النَّبِيُّ ـ صلى الله عليه وسلم ـ وَأَصْحَابُهُ مُشَاةً مِنَ الْمَدِينَةِ إِلَى مَكَّةَ وَقَالَ ‏ ‏ ارْبُطُوا أَوْسَاطَكُمْ بِأُزُرِكُمْ ‏""""‏ ‏.‏ وَمَشَى خِلْطَ الْهَرْوَلَةِ ‏.‏""",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الجہاد ۱۵۲ (۲۷۳۰)، سنن الترمذی/السیر ۹ (۱۵۵۷)،(تحفة الأشراف:۱۰۸۹۸)، وقد أخرجہ: مسند احمد۵/۲۲۳)، سنن الدارمی/السیر ۳۵ (۲۵۱۸),,It was\nnarrated that Abu Sa’eed said:,Chapters on Hajj Rituals
2882,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏ وَأَبُو مُصْعَبٍ الزُّهْرِيُّ، ‏‏‏‏‏‏ وَسُوَيْدُ بْنُ سَعِي,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «صحیح البخاری/العمرة ۱۹ (۱۸۰۴)، الجہاد ۱۳۶ (۳۰۰۱)، الأطعمة ۳۰ (۵۴۲۹)، صحیح مسلم/الإمارة ۵۵ (۱۹۲۷)،(تحفة الأشراف:۱۲۵۷۲)، وقد أخرجہ: موطا امام مالک/الاستئذان ۱۵ (۳۹)، مسند احمد (۲/۲۳۶،۴۴۵)، سنن الدارمی/الاستئذان ۴۰ (۲۷۱۲),2882,,Chapters on Hajj Rituals
2883,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏ وَعَمْرُو بْنُ عَبْدِ اللَّهِ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَ,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۰۴۷، ومصباح الزجاجة:۱۰۱۵)، وقد أخرجہ: سنن ابی داود/المناسک ۶ (۱۷۳۲)، مسند احمد (۱/۲۲۵،۳۲۳،۳۵۵)، سنن الدارمی/الحج ۱ (۱۸۲۵),2883,,Chapters on Hajj Rituals
2884,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، ‏‏‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏قَالَ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/الحج ۵ (۸۱۴)،(تحفة الأشراف:۱۰۱۱۱)، وقد أخرجہ: مسند احمد (۱/۱۱۳),2884,,Chapters on Hajj Rituals
2885,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ أَبِي عُبَيْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۲۷، ومصباح الزجاجة:۱۰۱۶)، وقد أخرجہ: مسند احمد (۱/۳۸۷),2885,,Chapters on Hajj Rituals
2886,حَدَّثَنَا يَعْقُوبُ بْنُ إِبْرَاهِيمَ الدَّوْرَقِيُّ، ‏‏‏‏‏‏حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، ‏‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: سنن ابی داود/الحج ۱ (۱۷۲۱)، سنن النسائی/الحج ۱ (۲۶۲۱)،(تحفة الأشراف:۶۵۵۶، ومصباح الزجاجة:۱۰۱۷)، وقد أخرجہ: مسند احمد (۱/۲۵۵،۲۹۰،۳۰۱،۳۰۳،۳۲۳،۳۲۵،۳۵۲،۳۷۰،۳۷۱)، سنن الدارمی/الحج ۴ (۱۸۲۹),2886,,Chapters on Hajj Rituals
2887,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏عَنْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۴۷۷، ومصباح الزجاجة:۱۰۱۸),2887,,Chapters on Hajj Rituals
2888,حَدَّثَنَا أَبُو مُصْعَبٍ، ‏‏‏‏‏‏حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، ‏‏‏‏‏‏عَنْ سُمَيٍّ مَوْلَى أَبِي بَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/العمرة ۱ (۱۷۷۳)، صحیح مسلم/الحج ۷۹ (۱۳۴۹)، سنن النسائی/الحج ۵ (۲۶۳۰)،(تحفة الأشراف:۱۲۵۷۳)، وقد أخرجہ: سنن الترمذی/الحج ۹۰ (۹۳۳)، موطا امام مالک/الحج ۲۱ (۶۵)، مسند احمد (۲/۲۴۶،۴۶۱،۴۶۲)، سنن الدارمی/الحج ۷ (۱۸۳۶),2888,,Chapters on Hajj Rituals
2889,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏عَنْ مِسْعَرٍ، ‏‏‏‏‏‏ و,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الإیمان ۱۸ (۲۶)، الحج ۴ (۱۵۱۹و۱۵۲۱)، المحصر ۹ (۱۸۱۹)،۱۰ (۱۸۲۰)، صحیح مسلم/الحج ۷۸ (۱۳۵۰)، سنن الترمذی/الحج ۲ (۸۱۱)، سنن النسائی/الحج ۴ (۲۶۲۸)،(تحفة الأشراف:۱۳۴۳۱)، وقد أخرجہ: مسند احمد (۲/۲۲۹،۲۴۸،۴۱۰،۴۸۴،۴۹۴)، سنن الدارمی/الحج ۷ (۱۸۳۶),2889,,Chapters on Hajj Rituals
2890,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏عَنْ الرَّبِيعِ بْنِ صَبِيحٍ، ‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۶۷۲، ومصباح الزجاجة:۱۰۱۹)، وقد أخرجہ: صحیح البخاری/الحج ۳ (۱۵۱۷)، عن ثمامة بن عبد اللہ بن أنس قال: حج أنس علی رحل ولم یکن شحیحاً وحدث أن رسول اللہ صلی اللہ علیہ وسلم حج علی رحل وکانت زاعلتہ,2890,,Chapters on Hajj Rituals
2891,حَدَّثَنَا أَبُو بِشْرٍ بَكْرُ بْنُ خَلَفٍ، ‏‏‏‏‏‏حَدَّثَنَا ابْنُ أَبِي عَدِيٍّ، ‏‏‏‏‏‏عَنْ دَاوُدَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الإیمان ۷۴ (۱۶۶)،(تحفة الأشراف:۵۴۲۴)، وقد أخرجہ: صحیح البخاری/الحج ۳۰ (۱۵۵۵),2891,,Chapters on Hajj Rituals
2892,حَدَّثَنَا إِبْرَاهِيمُ بْنُ الْمُنْذِرِ الْحِزَامِيُّ، ‏‏‏‏‏‏حَدَّثَنَا صَالِحُ بْنُ عَبْدِ اللَّهِ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۸۸۸، ومصباح الزجاجة:۱۰۲۰),2892,,Chapters on Hajj Rituals
2893,حَدَّثَنَا مُحَمَّدُ بْنُ طَرِيفٍ، ‏‏‏‏‏‏حَدَّثَنَا عِمْرَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏عَنْ عَطَاءِ بْ,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Sanad Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۴۰۶، ومصباح الزجاجة:۱۰۲۱),2893,,Chapters on Hajj Rituals
2894,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏عَنْ سُفْيَانَ، ‏‏‏‏‏‏ع,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الصلاة ۳۵۸ (۱۴۹۸)، سنن الترمذی/الدعوات ۱۱۰ (۳۵۶۲)،(تحفة الأشراف:۱۰۵۲۲)، وقد أٰخرجہ: مسند احمد (/۲۹),2894,,Chapters on Hajj Rituals
2895,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، ‏‏‏‏‏‏عَنْ عَبْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الذکر والدعاء ۲۳ (۲۷۳۲)،(تحفة الأشراف:۱۰۹۳۹),2895,,Chapters on Hajj Rituals
2896,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِيَةَ، ‏‏‏‏‏‏ح وحَدَّثَنَا ع,Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: سنن الترمذی/الحج ۴ (۸۱۳)،(تحفة الأشراف:۷۴۴۰),2896,,Chapters on Hajj Rituals
2897,حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، ‏‏‏‏‏‏حَدَّثَنَا هِشَامُ بْنُ سُلَيْمَانَ الْقُرَشِيُّ، ‏‏‏‏‏‏عَنْ,Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۱۵۲،۶۱۶۳، ومصباح الزجاجة:۱۰۲۲),2897,,Chapters on Hajj Rituals
2898,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏حَدَّثَنَا الْأَعْمَشُ، ‏‏‏‏‏‏عَن,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۷۴ (۱۳۴۰)، سنن ابی داود/الحج ۲ (۱۷۲۶)، سنن الترمذی/الرضاع ۱۵ (۱۱۶۹)،(تحفة الأشراف:۴۰۰۴)، وقد أخرجہ: صحیح البخاری/جزء الصید ۲۶ (۱۸۶۴ مختصراً)، مسند احمد (۳/ ۵۴)، سنن الدارمی/الاستئذان ۴۶ (۲۷۲۰),2898,,Chapters on Hajj Rituals
2899,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا شَبَابَةُ، ‏‏‏‏‏‏عَنْ ابْنِ أَبِي ذِئْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۳۰۳۵)، وقد أخرجہ: صحیح البخاری/تقصیر الصلاة ۴ (۱۰۸۸)، صحیح مسلم/الحج ۷۴ (۱۳۳۹)، سنن ابی داود/الحج ۲ (۱۷۲۳)، سنن الترمذی/الرضاع ۱۵ (۱۶۶۹)، موطا امام مالک/الإستئتذان ۱۴ (۳۷)، مسند احمد (۲/۲۳۶،۳۴۰،۳۴۷،۴۲۳،۴۳۷،۴۴۵،۴۹۳),2899,,Chapters on Hajj Rituals
2900,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا شُعَيْبُ بْنُ إِسْحَاق، ‏‏‏‏‏‏حَدَّثَنَا ابْنُ جُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح مسلم/الحج ۷۴ (۱۳۴۱)، الجہاد ۱۸۱ (۳۰۶۱)،(تحفة الأشراف:۶۵۱۵)، وقد أخرجہ: صحیح البخاری/جزاء الصید ۲۶ (۳۰۶۱)، مسند احمد (۱/۳۴۶),2900,,Chapters on Hajj Rituals
2901,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ فُضَيْلٍ، ‏‏‏‏‏‏عَنْ حَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الحج ۴ (۱۵۲۰)، الجہاد ۶۲ (۲۷۸۴،۲۸۷۶)سنن النسائی/الحج ۴ (۲۶۲۹)،(تحفة الأشراف:۱۷۸۷۱)، وقد أخرجہ: مسند احمد (۶/۷۱،۷۶،۷۹ ۱۶۵),2901,,Chapters on Hajj Rituals
2902,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏عَنْ الْقَاسِمِ بْنِ ال,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۸۲۱۱، ومصباح الزجاجة:۱۰۲۳)، وقد أخرجہ: سنن النسائی/الحج ۴ (۲۶۲۹)، مسند احمد (۲/۲۱،۶/۲۹۴،۳۰۳،۳۱۴),2902,,Chapters on Hajj Rituals
2903,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدَةُ بْنُ سُلَيْمَانَ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Hasan,takhreej: «سنن ابی داود/المناسک ۲۶ (۱۸۱۱)،(تحفة الأشراف:۵۵۶۴),2903,,Chapters on Hajj Rituals
2904,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الْأَعْلَى الصَّنْعَانِيُّ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الرَّزَّاقِ، ‏‏,Al-Albani: Sahih Isnaad; Muhammad Fouad Abd al-Baqi: Sahih Isnaad; Shuaib Al Arnaut: Sahih Muquf; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۵۵۵، ومصباح الزجاجة:۱۰۲۴),2904,,Chapters on Hajj Rituals
2905,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، ‏‏‏‏‏‏حَدَّثَنَا عُثْمَ,Al-Albani: Daif Isnaad; Muhammad Fouad Abd al-Baqi: Daif Isnaad; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۰۷۷، ومصباح الزجاجة:۱۰۲۵),2905,,Chapters on Hajj Rituals
2906,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن ابی داود/الحج ۲۶ (۱۸۱۰)، سنن النسائی/الحج ۲ (۲۶۲۲)،۱۰ (۲۶۳۸)،(تحفة الأشراف:۱۱۱۷۳)، وقد أخرجہ: سنن الترمذی/الحج ۸۷ (۹۳۰)، مسند احمد (۴/۱۰،۱۱،۱۲),2906,,Chapters on Hajj Rituals
2907,حَدَّثَنَا أَبُو مَرْوَانَ مُحَمَّدُ بْنُ عُثْمَانَ الْعُثْمَانِيُّ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْعَزِ,Al-Albani: Hasan Isnaad; Muhammad Fouad Abd al-Baqi: Hasan Isnaad; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۵۲۲)، وقد أخرجہ: صحیح البخاری/الحج ۱ (۱۵۱۳)، جزاء الصید ۲۳ (۱۸۵۴)،۲۴ (۱۸۵۵)، المغازي ۷۷ (۴۳۹۹)، الاستئذان ۲ (۶۲۲۸)، صحیح مسلم/الحج ۷۱ (۱۳۳۴)، سنن ابی داود/الحج ۲۶ (۱۸۰۹)، سنن الترمذی/الحج ۸۵ (۹۲۸)، سنن النسائی/الحج ۸ (۲۶۳۴)،۹ (۲۶۳۶)، موطا امام مالک/الحج ۳۰ (۹۷)، مسند احمد (۱/۲۱۹،۲۵۱،۳۲۹،۳۴۶،۳۵۹)، سنن الدارمی/الحج ۲۳ (۱۸۷۳),2907,,Chapters on Hajj Rituals
2908,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو خَالِدٍ الْأَحْمَرُ،,Al-Albani: Daif Isnaad; Muhammad Fouad Abd al-Baqi: Daif Isnaad; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۴۱۷، ومصباح الزجاجة:۱۰۲۶),2908,,Chapters on Hajj Rituals
2909,حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ الدِّمَشْقِيُّ، ‏‏‏‏‏‏حَدَّثَنَا الْوَلِيدُ بْنُ مُس,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/جزاء الصید ۲۳ (۱۸۵۳)، صحیح مسلم/الحج ۷۱ (۱۳۳۵)، سنن الترمذی/الحج ۸۵ (۹۲۸)، سنن النسائی/آداب القضاة ۹ (۵۳۹۱)،(تحفة الأشراف:۱۱۰۴۸)، وقد أخرجہ: مسند احمد (۱/۲۱۲،۳۱۳،۳۵۹)، سنن الدارمی/المناسک ۲۳ (۱۸۷۵),2909,,Chapters on Hajj Rituals
2910,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏ وَمُحَمَّدُ بْنُ طَرِيفٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَا أَب,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن الترمذی/الحج ۸۳ (۹۲۴)،(تحفة الأشراف:۳۰۷۶),2910,,Chapters on Hajj Rituals
2911,حَدَّثَنَا عُثْمَانُ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدَةُ بْنُ سُلَيْمَانَ، ‏‏‏‏‏‏عَنْ عُب,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۱۶ (۱۲۰۹)، سنن ابی داود/الحج ۱۰ (۱۷۴۳)، سنن النسائی/الحیض ۲۴ (۲۱۵)، الحج ۵۷ (۲۷۶۱)،(تحفة الأشراف:۱۷۵۰۲)، وقد أخرجہ: موطا امام مالک/الحج ۴۱ (۱۲۷،۱۲۸)، سنن الدارمی/المناسک ۱۱ (۱۸۴۵)،۳۴ (۱۸۹۲),2911,,Chapters on Hajj Rituals
2912,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ، ‏‏‏‏‏‏عَنْ سُلَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن النسائی/الحج ۲۶ (۲۶۶۵)،(تحفة الأشراف:۶۶۱۷),2912,,Chapters on Hajj Rituals
2913,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا يَحْيَى بْنُ آدَمَ، ‏‏‏‏‏‏عَنْ سُفْيَانَ، ‏‏‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۱۶ (۱۲۱۰)، سنن ابی داود/الحج ۱۰ (۱۷۴۳)، سنن النسائی/الحیض ۲۴ (۲۱۵)، الحج ۵۷ (۲۷۶۲،۲۷۶۳)،(تحفة الأشراف:۲۶۰۰)، وقد أخرجہ: موطا امام مالک/الحج ۴۱ (۱۲۷،۱۲۸)، سنن الدارمی/المناسک ۱۱ (۱۸۴۵),2913,,Chapters on Hajj Rituals
2914,حَدَّثَنَا أَبُو مُصْعَبٍ، ‏‏‏‏‏‏حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، ‏‏‏‏‏‏عَنْ نَافِعٍ، ‏‏‏‏‏‏عَنْ ابْن,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/العلم ۵۳ (۱۳۳)، الحج ۵ (۱۵۲۲)،۸ (۱۵۲۵،۱۰ (۱۵۲۸)، صحیح مسلم/الحج ۲ (۱۱۸۲)، سنن ابی داود/الحج ۹ (۱۷۳۷)، سنن النسائی/الحج ۱۷ (۲۶۵۲)،(تحفة الأشراف:۸۳۲۶)، وقد أخرجہ: موطا امام مالک/الحج ۸ (۲۲)، مسند احمد (۲/۴۸،۵۵،۶۵)، سنن الدارمی/المناسک ۵ (۱۸۳۱),2914,,Chapters on Hajj Rituals
2915,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏حَدَّثَنَا إِبْرَاهِيمُ بْنُ يَزِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۶۵۲، ومصباح الزجاجة:۱۰۲۷)، وقد أخر جہ: صحیح مسلم/الحج ۲ (۱۱۸۳)، مسند احمد (۲/۱۸۱،۳/۳۳۳،۳۳۶),2915,,Chapters on Hajj Rituals
2916,حَدَّثَنَا مُحْرِزُ بْنُ سَلَمَةَ الْعَدَنِيُّ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ ال,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۰۳۲، ومصباح الزجاجة:۱۰۲۸)، وقد أخرجہ: صحیح البخاری/الحج ۲ (۱۵۱۴)،۲۸ (۱۵۵۲)،۲۹ (۱۵۵۳)، صحیح مسلم/الحج ۳ (۱۱۸۷)، سنن النسائی/الحج ۵۶ (۲۷۵۹)، موطا امام مالک/الحج ۸ (۲۳)، مسند احمد (۲/۱۷،۱۸،۲۹،۳۶،۳۷)، سنن الدارمی/المناسک ۸۲ (۱۹۷۰),2916,,Chapters on Hajj Rituals
2917,حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ الدِّمَشْقِيُّ، ‏‏‏‏‏‏حَدَّثَنَا الْوَلِيدُ بْنُ مُس,Al-Albani: Sahih Isnaad; Muhammad Fouad Abd al-Baqi: Sahih Isnaad; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۵۲، ومصباح الزجاجة:۱۰۲۹)، وقد أخرجہ: مسند احمد (۳/۱۸۳،۲۲۵),2917,,Chapters on Hajj Rituals
2918,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو مُعَاوِيَةَ، ‏‏‏‏‏‏ وَأَبُو أُسَامَةَ، ‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۸۷۳،۸۰۱۳،۱۸۱۳)، وقد أخرجہ: صحیح البخاری/الحج ۲۶ (۱۵۴۹)، اللباس ۶۹ (۵۹۵۱)، صحیح مسلم/الحج ۳ (۱۱۸۴)، سنن ابی داود/الحج ۲۷ (۱۸۱۲)، سنن الترمذی/الحج ۱۳ (۸۲۵)، سنن النسائی/الحج ۵۴ (۲۷۵۰)، موطا امام مالک/الحج ۹ (۲۸)، حم۲/۳،۲۸،۳۴،۴۱،۴۳،۴۷،۴۸،۵۳،۷۶،۷۷،۷۹،۱۳۱، سنن الدارمی/المناسک ۱۳ (۱۸۴۹),2918,,Chapters on Hajj Rituals
2919,حَدَّثَنَا زَيْدُ بْنُ أَخْزَمَ، ‏‏‏‏‏‏حَدَّثَنَا مُؤَمَّلُ بْنُ إِسْمَاعِيل، ‏‏‏‏‏‏حَدَّثَنَا سُفْي,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الحج ۲۷ (۱۸۱۳)،(تحفة الأشراف:۲۶۰۴),2919,,Chapters on Hajj Rituals
2920,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ:(تحفة الأشراف:۱۳۹۴۱، ومصباح الزجاجة:۱۰۳۰)، وقد أخرجہ: سنن النسائی/الحج ۵۴ (۲۷۵۳)، مسند احمد (۲/۳۴۱،۳۵۲،۴۷۶),2920,,Chapters on Hajj Rituals
2921,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا إِسْمَاعِيل بْنُ عَيَّاشٍ، ‏‏‏‏‏‏حَدَّثَنَا عُمَا,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن الترمذی/الحج ۱۴ (۸۲۸)،(تحفة الأشراف:۴۷۳۵),2921,,Chapters on Hajj Rituals
2922,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏عَنْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الحج ۲۷ (۱۸۱۴)، سنن الترمذی/الحج ۱۵ (۸۲۹)، سنن النسائی/الحج ۵۵ (۲۷۵۴)،(تحفة الأشراف:۳۷۸۸)، وقد أخرجہ: موطا امام مالک/الحج ۱۰ (۳۴)، مسند احمد (۴/۵۵،۵۶)، سنن الدارمی/المناسک ۱۴ (۱۸۵۰),2922,,Chapters on Hajj Rituals
2923,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ، ‏‏‏‏‏‏عَنْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۷۵۰، و مصباح الزجاجة:۱۰۳۱)، وقد أخرجہ: مسند احمد (۵/۱۹۲),2923,,Chapters on Hajj Rituals
2924,حَدَّثَنَا إِبْرَاهِيمُ بْنُ الْمُنْذِرِ الْحِزَامِيُّ، ‏‏‏‏‏‏ وَيَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِب,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/الحج ۱۴ (۸۲۷)،(تحفة الأشراف:۶۶۰۸)، وقد أخرجہ: سنن الدارمی/المناسک ۸ (۱۸۳۸),2924,,Chapters on Hajj Rituals
2925,حَدَّثَنَا إِبْرَاهِيمُ بْنُ الْمُنْذِرِ الْحِزَامِيُّ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نَافِعٍ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۳۶۲، ومصباح الزجاجة:۱۰۳۲)، وقد أخرجہ: مسند احمد (۳/۲۷۳),2925,,Chapters on Hajj Rituals
2926,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏ح وحَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «حدیث أبي بکر بن أبي شیبة أخرجہ: صحیح البخاری/الحج ۱۸ (۱۵۳۹)،۱۴۳ (۱۷۵۴)، اللباس ۷۳ (۵۹۲۲)،۷۴ (۵۹۲۳)،۷۹ (۵۹۲۸)،۸۱ (۵۹۳۰)،(تحفة الأشراف:۱۷۴۸۵)، وحدیث محمد بن رمح تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۷۵۱۴)، وقد أخرجہ: صحیح مسلم/الحج ۷ (۱۱۸۹)، سنن ابی داود/الحج ۱۱ (۱۷۴۵)، سنن الترمذی/الحج ۷۷ (۹۱۷)، سنن النسائی/الحج ۴۱ (۲۶۸۷)، موطا امام مالک/الحج ۷ (۱۷)، مسند احمد (۶/۹۸،۱۰۶،۱۳۰،۱۶۲،۱۸۱،۱۸۶،۱۹۲،۲۰۰،۲۰۷،۲۰۹،۲۱۴،۲۱۶،۲۳۷،۲۳۸،۲۴۴،۲۴۵،۲۵۸)، سنن الدارمی/المناسک ۱۰ (۱۸۴۴),2926,,Chapters on Hajj Rituals
2927,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏حَدَّثَنَا الْأَعْمَشُ، ‏‏‏‏‏‏عَن,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۷ (۱۱۹۰)،(تحفة الأشراف:۱۷۶۴۵)، وقد أخرجہ: مسند احمد (۶/۱۰۹،۲۰۷),2927,,Chapters on Hajj Rituals
2928,حَدَّثَنَا إِسْمَاعِيل بْنُ مُوسَى، ‏‏‏‏‏‏حَدَّثَنَا شَرِيكٌ، ‏‏‏‏‏‏عَنْ أَبِي إِسْحَاق، ‏‏‏‏‏‏عَنْ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: «سنن النسائی/الحج ۴۱ (۲۶۹۵)،۴۲ (۶۲۹۶،۲۷۰۴)،(تحفة الأشراف:۱۶۰۲۶)، وقد أخرجہ: صحیح البخاری/الغسل ۱۴ (۲۶۷)، الحج ۱۸ (۱۵۳۹)، اللباس ۷۰ (۵۹۱۸)، صحیح مسلم/الحج ۷ (۱۱۹۰)، بدون ذکر'' بعد ثلاثة ''، مسند احمد (۶/۲۰۰،۲۰۷،۲۰۹،۲۱۴،۲۱۶،۲۳۷،۲۳۸،۲۴۴،۲۴۵،۲۵۸),2928,,Chapters on Hajj Rituals
2929,حَدَّثَنَا أَبُو مُصْعَبٍ، ‏‏‏‏‏‏حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، ‏‏‏‏‏‏عَنْ نَافِعٍ عَنْ عَبْدِ اللّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/العلم ۵۳ (۱۳۴)، الصلاة ۹ (۳۶۶)، الحج ۲۱ (۱۵۴۲)، جزاء الصید ۱۳ (۱۸۳۸)،۱۵ (۱۸۴۲)، اللباس ۸ (۵۷۹۴)،۱۳ (۵۸۰۳)،۱۵ (۵۸۰۶)، صحیح مسلم/الحج ۱ (۱۱۷۷)، سنن ابی داود/المناسک ۳۲ (۱۸۲۴)، سنن الترمذی/الحج ۱۸ (۸۳۳)، سنن النسائی/الحج ۳۰ (۲۶۷۰)،(تحفة الأشراف:۸۳۲۵)، موطا امام مالک/الحج ۴ (۹)، مسند احمد (۲/۴،۸،۲۲،۲۹،۳۲،۳۴،۴۱،۵۴،۵۶،۵۸،۶۳،۶۵،۱۷۷،۱۱۹)، سنن الدارمی/المناسک ۹ (۱۸۳۹),2929,,Chapters on Hajj Rituals
2930,حَدَّثَنَا أَبُو مُصْعَبٍ، ‏‏‏‏‏‏حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، ‏‏‏‏‏‏عَنْ عَبْدِ اللَّهِ بْنِ دِين,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/اللباس۳۷ (۵۸۵۲)، صحیح مسلم/الحج ۱ (۱۱۷۷)،(تحفة الأشراف:۷۲۲۶)،(أنظر ما قبلہ),2930,,Chapters on Hajj Rituals
2931,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏ وَمُحَمَّدُ بْنُ الصَّبَّاحِ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَا,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/جزاء الصید ۱۵ (۱۸۴۱)،۱۶ (۱۸۴۳)، اللباس۱۴ (۵۸۰۴)،۳۷ (۵۸۵۳)، صحیح مسلم/الحج ۱ (۱۱۷۸)، سنن ابی داود/المناسک ۳۲ (۱۸۲۹)، سنن الترمذی/الحج ۱۹ (۸۳۴)، سنن النسائی/الحج ۳۲ (۲۶۷۲،۲۶۷۳)،۳۷ (۲۶۸۰)، الزینة من المجتبیٰ ۴۶ (۵۳۲۷)،(تحفة الأشراف:۵۳۷۵)، وقد أخرجہ: مسند احمد (۱/۲۱۵،۲۲۱،۲۲۸،۲۷۹،۳۳۷)، سنن الدارمی/المناسک ۹ (۱۸۴۰),2931,,Chapters on Hajj Rituals
2932,حَدَّثَنَا أَبُو مُصْعَبٍ، ‏‏‏‏‏‏حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، ‏‏‏‏‏‏عَنْ نَافِعٍ، ‏‏‏‏‏‏وَعَنْ عَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «حدیث نافع تقدم تخریجہ،(۲۹۲۹)، وحدیث عبد اللہ بن دینار تقدم تخریجہ،(۲۹۳۰)،(تحفة الأشراف:۲۹۳۰),2932,,Chapters on Hajj Rituals
2933,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ إِدْرِيسَ، ‏‏‏‏‏‏ع,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/المناسک ۳۰ (۱۷۷۰)،(تحفة الأشراف:۱۵۷۱۵),2933,,Chapters on Hajj Rituals
2934,حَدَّثَنَا أَبُو مُصْعَبٍ، ‏‏‏‏‏‏حَدَّثَنَا مَالِكٌ، ‏‏‏‏‏‏عَنْ زَيْدِ بْنِ أَسْلَمَ، ‏‏‏‏‏‏عَنْ إِب,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/جزاء الصید ۱۴ (۱۸۴۰)، صحیح مسلم/الحج ۱۳ (۱۲۰۵)، سنن ابی داود/الحج ۳۸ (۱۸۴۰)، سنن النسائی/الحج ۲۷ (۲۶۶۶)،(تحفة الأشراف:۳۴۶۳)، وقد أخرجہ: موطا امام مالک/الحج ۲ (۴)، مسند احمد (۵/۴۱۶،۴۱۸،۴۲۱)، سنن الدارمی/المناسک ۶ (۱۸۳۴),2934,,Chapters on Hajj Rituals
2935,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ فُضَيْلٍ، ‏‏‏‏‏‏عَنْ يَ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/المناسک ۳۴ (۱۸۳۳)،(تحفة الأشراف:۱۷۵۷۷)، وقد أخرجہ: مسند احمد (۶/۳۰),2935,,Chapters on Hajj Rituals
2936,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبِي، ‏‏‏‏‏‏ح وحَدَّثَنَا,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۵۸۹۲، ومصباح الزجاجة:۱۰۳۳)، وقد أخرجہ: مسند احمد (۶/۳۴۹),2936,,Chapters on Hajj Rituals
2937,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ فُضَيْلٍ، ‏‏‏‏‏‏ وَوَكِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۵۹۱۴، ومصباح الزجاجة:۱۰۳۴)، وقد أخرجہ: مسند احمد (۶/۳۶۰),2937,,Chapters on Hajj Rituals
2938,حَدَّثَنَا أَبُو بِشْرٍ بَكْرُ بْنُ خَلَفٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو عَاصِمٍ، ‏‏‏‏‏‏عَنْ ابْنِ جُرَيْج,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۱۵ (۱۲۰۸)، سنن النسائی/الحج ۶۰ (۲۷۶۷)،(تحفة الأشراف:۵۷۵۴،۶۲۱۴)، وقد أخرجہ: سنن ابی داود/الحج ۲۲ (۱۷۷۶)، سنن الترمذی/الحج ۹۷ (۹۴۱)، مسند احمد (۱/۳۳۷،۳۵۲)، سنن الدارمی/المناسک ۱۵ (۱۸۵۲),2938,,Chapters on Hajj Rituals
2939,حَدَّثَنَا أَبُو كُرَيْبٍ، ‏‏‏‏‏‏حَدَّثَنَا إِسْمَاعِيل بْنُ صَبِيحٍ، ‏‏‏‏‏‏حَدَّثَنَا مُبَارَكُ بْن,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۹۵۷، ومصباح الزجاجة:۱۰۳۵),2939,,Chapters on Hajj Rituals
2940,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو مُعَاوِيَةَ، ‏‏‏‏‏‏حَدَّثَنَا عُبَيْدُ الل,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۱۱۴)، وقد أخرجہ: صحیح البخاری/الحج ۴۰ (۱۵۷۶)،۴۱ (۱۵۷۷)، صحیح مسلم/الحج ۳۷ (۱۲۵۷)، سنن ابی داود/الحج ۴۵ (۱۸۶۶)، سنن النسائی/الحج ۱۰۵ (۲۸۶۸)، مسند احمد (۲/۱۴،۱۹)، سنن الدارمی/المناسک ۸۱ (۱۹۶۹),2940,,Chapters on Hajj Rituals
2941,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏حَدَّثَنَا الْعُمَرِيُّ، ‏‏‏‏‏‏عَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن الترمذی/الحج ۳۱ (۸۵۴)،(تحفة الأشراف:۷۷۲۳)، وقد أخرجہ: صحیح البخاری/الصلاة ۸۹ (۴۸۴)، الحج ۱۴۸ (۱۵۷۳)،۱۴۹ (۱۵۷۴)، صحیح مسلم/الحج ۳۸ (۱۲۵۹)، سنن النسائی/الحج ۱۰۳ (۲۸۶۵)، مسند احمد (۲/۵۹،۷۸)، سنن الدارمی/المناسک ۸۰ (۱۹۶۸),2941,,Chapters on Hajj Rituals
2942,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الرَّزَّاقِ، ‏‏‏‏‏‏أَنْبَأَنَا مَعْمَرٌ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحج ۴۴ (۱۵۸۸)، الجہاد۱۸۰ (۳۰۵۸)، مناقب الأنصار ۳۹ (۴۲۸۲)، المغازي ۴۸ (۴۲۸۲)، التوحید ۳۱ (۷۴۷۹)، صحیح مسلم/الحج ۸۰ (۱۳۵۱)، سنن ابی داود/الفرائض ۱۰ (۲۹۰۹،۱۰ ۲۹)،(تحفة الأشراف:۱۱۴)، وقد أخرجہ: سنن الترمذی/الفرائض ۱۵ (۲۱۰۷)، موطا امام مالک/الفرائض ۱۳ (۱۰)، مسند احمد (۲/۲۳۷، سنن الدارمی/الفرائض ۲۹ (۳۰۲۶),2942,,Chapters on Hajj Rituals
2943,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۴۱ (۱۲۷۰)،(تحفة الأشراف:۱۰۴۸۶)، وقد أخرجہ: صحیح البخاری/الحج ۵۰ (۱۵۹۷)،۵۷ (۱۶۰۵)،۶۰ (۱۶۱۰)، سنن ابی داود/الحج ۴۷ (۱۸۷۳)، سنن الترمذی/الحج ۳۷ (۸۶۰)، سنن النسائی/الحج ۱۴۷ (۲۹۴۰)، موطا امام مالک/الحج ۳۶ (۱۱۵)، مسند احمد (۱/۲۱،۲۶،۳۴،۳۵،۳۹،۴۶،۵۱،۵۳،۵۴)، سنن الدارمی/المناسک ۴۲ (۱۹۰۶),2943,,Chapters on Hajj Rituals
2944,حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الرَّحِيمِ الرَّازِيُّ، ‏‏‏‏‏‏عَنْ ابْنِ خ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Hasan,takhreej: «سنن الترمذی/الحج ۱۱۳ (۹۶۱)،(تحفة الأشراف:۵۵۳۶)، وقد أخرجہ: مسند احمد (۱/۲۴۷،۲۶۶،۲۹۱،۳۰۷،۳۷۱)، سنن الدارمی/المناسک ۲۶ (۱۸۸۱),2944,,Chapters on Hajj Rituals
2945,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا خَالِي يَعْلَى، ‏‏‏‏‏‏عَنْ مُحَمَّدِ بْنِ عَوْنٍ,Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۴۴۱، ومصباح الزجاجة:۱۰۳۶),2945,,Chapters on Hajj Rituals
2946,حَدَّثَنَا أَحْمَدُ بْنُ عَمْرِو بْنِ السَّرْحِ الْمِصْرِيُّ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ و,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۴۰ (۱۲۶۸)، سنن النسائی/الحج ۱۵۷ (۲۹۵۲)،(تحفة الأشراف:۶۹۸۸)، وقد أخرجہ: صحیح البخاری/الحج ۵۹ (۱۶۱۱)، سنن ابی داود/الحج ۴۸ (۱۸۷۴)، مسند احمد (۲/۸۶،۱۱۴،۱۱۵)، سنن الدارمی/المناسک ۲۵ (۱۸۸۰),2946,,Chapters on Hajj Rituals
2947,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، ‏‏‏‏‏‏حَدَّثَنَا يُونُسُ بْنُ بُكَيْرٍ، ‏‏‏‏,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الحج ۴۹ (۱۸۷۸)،(تحفة الأشراف:۱۵۹۰۹),2947,,Chapters on Hajj Rituals
2948,حَدَّثَنَا أَحْمَدُ بْنُ عَمْرِو بْنِ السَّرْحِ، ‏‏‏‏‏‏أَنْبَأَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، ‏‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحج ۵۸ (۱۶۰۷)،۶۱ (۱۶۱۲)،۶۲ (۱۶۱۳)،۷۴ (۱۶۳۲)، الطلاق ۲۴ (۵۲۹۳)، صحیح مسلم/الحج ۴۲ (۱۲۷۲)، سنن النسائی/المساجد ۲۱ (۷۱۴)، الحج ۱۵۹ (۲۹۵۷)،۱۶۰ (۲۹۵۸)،(تحفة الأشراف:۵۸۳۷)، وقد أخرجہ: سنن ابی داود/الحج ۴۹ (۱۸۷۷)، سنن الترمذی/الحج ۴۰ (۸۶۵)، مسند احمد (۱/۲۱۴،۲۳۷،۲۴۸،۳۰۴)، سنن الدارمی/المناسک ۲۶ (۱۸۸۱),2948,,Chapters on Hajj Rituals
2949,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏ح وحَدَّثَنَا هَدِيَّةُ بْنُ عَبْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۳۹ (۱۲۶۵)، سنن ابی داود/الحج ۴۹ (۱۸۷۹)،(تحفة الأشراف:۵۰۵۱)، وقد أخرجہ: مسند احمد (۵/۴۵۴),2949,,Chapters on Hajj Rituals
2950,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، ‏‏‏‏‏‏حَدَّثَنَا أَحْمَدُ بْنُ بَشِيرٍ، ‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih Sahih Bukhari,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۷۹۷،۸۱۱۷، ومصباح الزجاجة:۱۰۳۷)، وقد أخرجہ: صحیح البخاری/الحج ۶۳ (۱۶۱۶)، صحیح مسلم/الحج ۳۹ (۱۲۶۲)، سنن ابی داود/الحج ۵۱ (۱۸۹۱)، سنن النسائی/الحج ۱۵۰ (۲۹۴۳)، موطا امام مالک/الحج ۳۴ (۸۰)، مسند احمد (۳/۱۳)، سنن الدارمی/المناسک ۲۷ (۱۸۸۳،۱۸۸۴),2950,,Chapters on Hajj Rituals
2951,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو الْحُسَيْنِ الْعُكْلِيُّ، ‏‏‏‏‏‏عَنْ مَالِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۳۹ (۱۶۶۳)، سنن الترمذی/الحج ۳۳ (۸۵۶)، سنن النسائی/الحج ۱۵۴ (۲۹۴۷)،(تحفة الأشراف:۲۵۹۴)، وقد أخرجہ: سنن ابی داود/الحج ۵۱ (۱۸۹۱)، مسند احمد (۳/۳۲۰،۳۴۰،۳۹۴)، سنن الدارمی/المناسک ۲۷ (۱۸۸۲),2951,,Chapters on Hajj Rituals
2952,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا جَعْفَرُ بْنُ عَوْنٍ، ‏‏‏‏‏‏عَنْ هِشَا,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/المناسک ۵۱ (۱۸۸۷)،(تحفة الأشراف:۱۰۳۹۱)، وقد أخرجہ: مسند احمد (۱/۴۵),2952,,Chapters on Hajj Rituals
2953,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الرَّزَّاقِ، ‏‏‏‏‏‏أَنْبَأَنَا مَعْمَرٌ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/المناسک ۵۱ (۱۸۹۰)، سنن الترمذی/الحج ۳۹ (۸۶۳)، سنن النسائی/الحج ۱۷۶ (۲۹۸۲)،(تحفة الأشراف:۵۷۷۷)، وقد أخرجہ: صحیح البخاری/الحج ۸۰ (۱۶۴۹)، المغازي ۴۳ (۴۲۵۷)، صحیح مسلم/الحج ۳۹ (۱۲۶۶)، مسند احمد (۱/۲۲۱،۲۵۵،۳۰۶،۳۱۰،۳۱۱،۳۷۳),2953,,Chapters on Hajj Rituals
2954,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ، ‏‏‏‏‏‏ وَقَبِيصَةُ، ‏‏‏‏,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/المناسک ۵۰ (۱۸۸۳)، سنن الترمذی/الحج ۳۶ (۸۵۹)،(تحفة الأشراف:۱۱۸۳۹)، وقد أخرجہ: مسند احمد (۴/۲۲۲،۲۲۳،۲۲۴)، سنن الدارمی/المناسک ۲۸ (۱۸۸۵),2954,,Chapters on Hajj Rituals
2955,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ مُوسَى، ‏‏‏‏‏‏حَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحج ۴۲ (۱۵۸۴)، أحادیث الأنبیاء ۱۰ (۳۳۶۸)، تفسیر البقرة ۱۰ (۴۴۸۴)، صحیح مسلم/الحج ۶۹ (۱۳۳۳)، سنن النسائی/الحج ۱۲۸ (۲۹۱۳)،(تحفة الأشراف:۱۶۰۰۵)، وقد أخرجہ: موطا امام مالک/الحج ۳۳ (۱۰۴)، سنن الدارمی/المناسک ۴۴ (۱۹۱۱),2955,,Chapters on Hajj Rituals
2956,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ الْفُضَيْلِ، ‏‏‏‏‏‏عَنْ الْعَلَاء,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۳۳۱، ومصباح الزجاجة:۱۰۳۹)، وقد أخرجہ: سنن الترمذی/الحج ۱۱۱ (۹۵۹)، سنن النسائی/الحج ۱۳۴ (۲۹۲۲)، مسند احمد (۲/۳،۱۱،۹۵),2956,,Chapters on Hajj Rituals
2957,(حديث موقوف) قَالَ لَهُ ابْنُ هِشَامٍ:‏‏‏‏ يَا أَبَا مُحَمَّدٍ، ‏‏‏‏‏‏فَالطَّوَافُ، ‏‏‏‏‏‏قَالَ قَال,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۴۱۷۴، ومصباح الزجاجة:۱۰۳۸),2957,,Chapters on Hajj Rituals
2958,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو أُسَامَةَ، ‏‏‏‏‏‏عَنْ ابْنِ جُرَ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الحج ۸۹ (۲۰۱۶)، سنن النسائی/القبلة ۹ (۷۵۹)، الحج ۱۶۲ (۲۹۶۲)،(تحفة الأشراف:۱۱۲۸۵)، وقد أخرجہ: مسند احمد (۶/۳۹۹),2958,,Chapters on Hajj Rituals
2959,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏ وَعَمْرُو بْنُ عَبْدِ اللَّهِ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحج ۱۰۴ (۱۶۹۱)، صحیح مسلم/الحج ۲۸ (۱۲۳۴)، سنن النسائی/الحج ۱۴۲ (۲۹۳۳)،(تحفة الأشراف:۷۳۵۲)، وقد أخرجہ: سنن ابی داود/الحج ۲۴ (۱۸۰۵)، موطا امام مالک/الحج ۳۷ (۱۱۶)، مسند احمد (۲/۱۵،۸۵،۱۵۲،۳/۳۰۹)، سنن الدارمی/المناسک ۸۴ (۱۹۷۲),2959,,Chapters on Hajj Rituals
2960,حَدَّثَنَا الْعَبَّاسُ بْنُ عُثْمَانَ الدِّمَشْقِيُّ، ‏‏‏‏‏‏حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، ‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الحروف ۱ (۳۹۶۹)، سنن الترمذی/الحج ۳۸ (۸۵۶)، سنن النسائی/الحج ۱۶۳ (۲۹۶۴)،(تحفة الأشراف:۲۵۹۵)، وقد أخرجہ: صحیح مسلم/الحج ۱۵ (۱۲۶۳)، سنن الدارمی/المناسک ۳۴ (۱۸۹۲),2960,,Chapters on Hajj Rituals
2961,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا مُعَلَّى بْنُ مَنْصُورٍ، ‏‏‏‏‏‏ح وحَدّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الصلاة ۷۸ (۴۶۴)، الحج ۶۴ (۱۶۱۹)،۷۱ (۱۶۲۶)،۷۴ (۱۶۳۳)، تفسیرالطور ۱ (۴۸۵۳)، صحیح مسلم/الحج ۴۲ (۱۲۷۶)، سنن ابی داود/الحج ۴۹ (۱۸۸۲)، سنن النسائی/الحج ۱۳۸ (۲۹۲۸)،(تحفة الأشراف:۱۸۲۶۲)، وقد أخرجہ: موطا امام مالک/الحج ۴۰ (۱۲۳)، مسند احمد (۶/۲۹۰،۳۱۹),2961,,Chapters on Hajj Rituals
2962,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الرَّزَّاقِ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ سَمِعْتُ ال,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: سنن ابی داود/المناسک ۵۵ (۱۸۹۹)،(تحفة الأشراف:۸۷۷۶),2962,,Chapters on Hajj Rituals
2963,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحیض ۱ (۲۹۴)، الأضاحي ۳ (۵۵۴۸)،۱۰ (۵۵۵۹)، صحیح مسلم/الحج ۱۷ (۱۲۱۱)، سنن ابی داود/الحج ۲۳ (۱۷۷۸)، سنن النسائی/الحج ۵۸ (۲۷۶۴)،(تحفة الأشراف:۱۷۴۸۲)، وقد أخرجہ: موطا امام مالک/الحج ۷۴ (۲۲۳)، مسند احمد (۳/۳۹۴)، سنن الدارمی/المناسک ۶۲ (۱۹۴۵),2963,,Chapters on Hajj Rituals
2964,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏ وَأَبُو مُصْعَبٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَا مَالِكُ بْنُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۱۷ (۱۲۱۱)، سنن ابی داود/الحج ۲۳ (۱۷۷۷)، سنن الترمذی/الحج ۱۰ (۸۲۰)، سنن النسائی/الحج ۴۸ (۲۷۱۶)،(تحفة الأشراف:۱۷۵۱۷)، وقد أخرجہ: موطا امام مالک/الحج ۱۱ (۳۷)، مسند احمد (۶/۲۴۳)، سنن الدارمی/المناسک ۱۶ (۱۸۵۳),2964,,Chapters on Hajj Rituals
2965,حَدَّثَنَا أَبُو مُصْعَبٍ، ‏‏‏‏‏‏حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، ‏‏‏‏‏‏عَنْ أَبِي الْأَسْوَدِ مُحَمّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحج ۳۴ (۱۵۶۲)، المغازي ۷۸ (۴۴۰۸)، صحیح مسلم/الحج ۱۷ (۱۲۱۱)، سنن ابی داود/المناسک ۲۳ (۱۷۷۹،۱۷۸۰)، سنن النسائی/المناسک ۴۸ (۲۷۱۷)،(تحفة الأشراف:۱۶۳۸۹)، وقد أخرجہ: مسند احمد (۶/۳۶،۱۰۴،۱۰۷،۲۴۳),2965,,Chapters on Hajj Rituals
2966,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْعَزِيزِ الدَّرَاوَرْدِيُّ، ‏‏‏‏‏‏ وَحَا,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۶۳۸، ومصباح الزجاجة:۱۰۴۰),2966,,Chapters on Hajj Rituals
2967,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا الْقَاسِمُ بْنُ عَبْدِ اللَّهِ الْعُمَرِيُّ، ‏‏‏‏,Al-Albani: Daif Isnaad; Muhammad Fouad Abd al-Baqi: Daif Isnaad; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۰۶۸، ومصباح الزجاجة:۱۰۴۱),2967,,Chapters on Hajj Rituals
2968,حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْأَعْلَى بْنُ عَبْدِ الْأَع,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۳۴ (۱۲۵۱)، سنن ابی داود/الحج ۲۴ (۱۷۹۵)، سنن النسائی/الحج ۴۹ (۲۷۳۰)،(تحفة الأشراف:۱۶۵۳)، وقد أخرجہ: سنن الترمذی/الحج ۱۱ (۸۲۱)، مسند احمد (۳/۹۹،۲۸۲)، سنن الدارمی/المناسک ۷۸ (۱۹۶۵),2968,,Chapters on Hajj Rituals
2969,حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْوَهَّابِ، ‏‏‏‏‏‏حَدَّثَنَا حُمَيْدٌ، ‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۲۴),2969,,Chapters on Hajj Rituals
2970,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَهِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن ابی داود/الحج ۲۴ (۱۷۹۸،۱۷۹۹)، سنن النسائی/الحج ۴۹ (۲۷۲۰،۲۷۷۱،۲۷۲۲)،(تحفة الأشراف:۱۰۴۶۶)، وقد أخرجہ: مسند احمد (۱/۱۴،۲۵،۳۴،۳۷،۵۳,2970,,Chapters on Hajj Rituals
2971,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو مُعَاوِيَةَ، ‏‏‏‏‏‏حَدَّثَنَا حَجَّاجٌ، ‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۷۸۰، ومصباح الزجاجة:۱۰۴۲)، وقد أخرجہ: مسند احمد (۴/۲۸،۲۹),2971,,Chapters on Hajj Rituals
2972,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، ‏‏‏‏‏‏حَدَّثَنَا يَحْيَى بْنُ يَعْلَى بْنِ ح,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۴۷۹، ومصباح الزجاجة:۱۰۴۳),2972,,Chapters on Hajj Rituals
2973,حَدَّثَنَا هَنَّادُ بْنُ السَّرِيِّ، ‏‏‏‏‏‏حَدَّثَنَا عَبْثَرُ بْنُ الْقَاسِمِ، ‏‏‏‏‏‏عَنْ أَشْعَثَ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «تفردبہ ابن ماجہ،(تحفة الأشراف:۲۶۶۴)، وقد أخرجہ: مسند احمد (۳/۳۸۷),2973,,Chapters on Hajj Rituals
2974,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا مُسْلِمُ بْنُ خَالِدٍ الزَّنْجِيُّ، ‏‏‏‏‏‏حَدَّثَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۱۱۸، ومصباح الزجاجة:۱۰۴۴),2974,,Chapters on Hajj Rituals
2975,حَدَّثَنَا مُحْرِزُ بْنُ سَلَمَةَ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏عَنْ عُب,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Muquf; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن الترمذی/الحج ۱۰۲ (۹۴۸)،(تحفة الأشراف:۸۰۲۹)، وقد أخرجہ: مسند احمد (۲/۶۷)، سنن الدارمی/النسک ۲۹ (۱۸۸۶),2975,,Chapters on Hajj Rituals
2976,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ مُصْعَبٍ، ‏‏‏‏‏‏ح وحَدّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الحج ۱۶ (۱۵۳۴)، سنن ابی داود/الحج ۲۴ (۱۸۰۰)،(تحفة الأشراف:۱۰۵۱۳)، وقد أخرجہ: مسند احمد (۱/۲۴),2976,,Chapters on Hajj Rituals
2977,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۸۱۵، ومصباح الزجاجة:۱۰۴۵)، سنن النسائی/الحج ۷۷ (۲۸۰۸)، مسند احمد (۴/۱۷۵),2977,,Chapters on Hajj Rituals
2978,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو أُسَامَةَ، ‏‏‏‏‏‏عَنْ الْجُرَيْرِيِّ، ‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۲۳ (۱۲۲۶)،(تحفة الأشراف:۱۰۸۵۶)، وقد أخرجہ: صحیح البخاری/الحج ۳۶ (۱۵۷۱)، تفسیر البقرة ۳۳ (۴۵۱۸)، سنن النسائی/الحج ۴۹ (۲۷۲۸)، مسند احمد (۴/۴۲۷،۴۲۸،۴۲۹،۴۳۴،۴۳۶،۴۳۸)، سنن الدارمی/النسک ۱۸ (۱۸۵۵),2978,,Chapters on Hajj Rituals
2979,حدثنا أبو بكر بن أبي شيبة ومحمد بن بشار قالا: حدثنا محمد بن جعفر (ح) وحدثنا نصر بن علي الجهضمي حدثني,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۲۲ (۱۲۲۱)، سنن النسائی/الحج ۵۰ (۲۷۳۶)،(تحفة الأشراف:۱۰۵۸۴)، وقد أخرجہ: مسند احمد (۱/۴۹)، سنن الدارمی/النسک ۱۸ (۱۸۵۶),2979,,Chapters on Hajj Rituals
2980,حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ الدِّمَشْقِيُّ، ‏‏‏‏‏‏حَدَّثَنَا الْوَلِيدُ بْنُ مُس,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «سنن ابی داود/المناسک ۲۳ (۱۷۸۷)،(تحفة الأشراف:۲۴۲۶)، وقد أخرجہ: صحیح مسلم/الحج ۱۷ (۱۲۱۶)، سنن النسائی/الحج ۷۷ (۲۸۰۷),2980,,Chapters on Hajj Rituals
2981,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، ‏‏‏‏‏‏عَنْ يَحْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحج ۳۴ (۱۵۶۱)،۱۱۵ (۱۷۰۹)،۱۲۴ (۱۷۲۰)، الجہاد ۱۰۵ (۲۹۵۲)، صحیح مسلم/الحج ۱۷ (۱۲۱۱)، سنن النسائی/الحج ۱۶ (۲۶۵۱)،۷۷ (۲۸۰۵،۲۸۰۶)،(تحفة الأشراف:۱۷۹۳۳)، وقد أخرجہ: سنن ابی داود/الحج ۲۳ (۱۷۸۱)، موطا امام مالک/الحج ۵۸ (۱۷۹)، مسند احمد (۶/۱۲۲،۲۶۶،۲۷۳),2981,,Chapters on Hajj Rituals
2982,حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو بَكْرِ بْنُ عَيَّاشٍ، ‏‏‏‏‏‏عَنْ أَبِي,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۹۰۷، ومصباح الزجاجة:۱۰۴۶)، وقد أخرجہ:(۴/۲۸۶),2982,,Chapters on Hajj Rituals
2983,حَدَّثَنَا بَكْرُ بْنُ خَلَفٍ أَبُو بِشْرٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو عَاصِمٍ، ‏‏‏‏‏‏أَنْبَأَنَا ابْنُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۲۹ (۱۲۳۶)، سنن النسائی/الحج ۱۸۶ (۲۹۹۵)،(تحفة الأشراف:۱۵۷۳۹)، وقد أخرجہ: مسند احمد (۶/۳۵۱),2983,,Chapters on Hajj Rituals
2984,حَدَّثَنَا أَبُو مُصْعَبٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ الدَّرَاوَرْدِيُّ، ‏‏‏‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الحج ۲۵ (۱۸۰۸)، سنن النسائی/الحج ۷۷ (۲۸۱۰)،(تحفة الأشراف:۲۰۲۷)، وقد أخرجہ: مسند احمد (۳/۴۶۹)، سنن الدارمی/المناسک ۳۷ (۱۸۹۷),2984,,Chapters on Hajj Rituals
2985,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو مُعَاوِيَةَ، ‏‏‏‏‏‏عَنْ الْأَعْمَشِ، ‏‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۲۳ (۱۲۲۴)، موقوفاً، سنن النسائی/الحج ۷۷ (۲۸۱۱،۲۸۱۲،۲۸۱۳)،(تحفة الأشراف:۱۱۹۹۵),2985,,Chapters on Hajj Rituals
2986,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو أُسَامَةَ، ‏‏‏‏‏‏عَنْ هِشَامِ بْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «تفرد بہ ابن ماجہ:(تحفة الأشراف:۱۶۸۲۰)، وقد أخرجہ: صحیح البخاری/الحج ۷۹ (۱۶۴۳)، العمرة ۱۰ (۱۷۹۰)، تفسیر البقرة ۲۱ (۴۴۹۵)، تفسیر النجم ۳ (۴۸۶۱)، صحیح مسلم/الحج ۴۳ (۱۲۷۷)، سنن ابی داود/الحج ۵۶ (۱۹۰۱)، سنن الترمذی/تفسیر البقرة (۲۹۶۹)، سنن النسائی/الحج ۱۶۸ (۲۹۷۰)، موطا امام مالک/الحج ۴۲ (۱۲۹)، مسند احمد (۳/۱۴۴،۱۶۲،۲۲۷),2986,,Chapters on Hajj Rituals
2987,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن النسائی/الحج ۱۷۷ (۲۹۸۳)،(تحفة الأشراف:۱۸۳۸۲)، وقد أخرجہ: مسند احمد (۶/۴۰۴،۴۰۵),2987,,Chapters on Hajj Rituals
2988,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏ وَعَمْرُو بْنُ عَبْدِ اللَّهِ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Hasan,takhreej: «سنن ابی داود/الحج ۵۶ (۱۹۰۴)، سنن الترمذی/الحج ۳۹ (۸۶۴)، سنن النسائی/الحج ۱۷۴ (۲۹۷۹)،(تحفة الأشراف:۷۳۷۹)، وقد أخرجہ: موطا امام مالک/الحج ۳۴ (۱۳۰)، مسند احمد (۲/۵۳،۶۰،۶۱،۱۲۰)، سنن الدارمی/المناسک ۲۵ (۱۸۸۰),2988,,Chapters on Hajj Rituals
2989,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا الْحَسَنُ بْنُ يَحْيَى الْخُشَنِيُّ، ‏‏‏‏‏‏حَدَّث,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۹۹۴، ومصباح الزجاجة:۱۰۴۷),2989,,Chapters on Hajj Rituals
2990,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، ‏‏‏‏‏‏حَدَّثَنَا يَعْلَى، ‏‏‏‏‏‏حَدَّثَنَا إ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الحج ۵۳ (۱۶۰۰)، سنن ابی داود/الحج ۵۶ (۱۹۰۲)،(تحفة الأشراف (۵۱۵۵)، وقد أخرجہ: صحیح مسلم/الحج ۶۸ (۱۳۳۲)، مسند احمد (۴/ ۳۵۳،۳۵۵،۳۸۱)، سنن الدارمی/المناسک ۷۷ (۱۹۶۳),2990,,Chapters on Hajj Rituals
2991,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۷۹۷، ومصباح الزجاجة:۱۰۴۸)، وقد أخرجہ: مسند احمد (۱/۳۰۸،۳/۳۵۳،۴/۱۷۷،۱۸۶),2991,,Chapters on Hajj Rituals
2992,حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ، ‏‏‏‏‏‏ح وحَدَّثَنَا عَلِيُّ بْنُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۷۲۸، مصباح الزجاجة:۱۰۴۹)، وقدأخرجہ: مسند احمد (۴/۱۷۷،۱۸۶),2992,,Chapters on Hajj Rituals
2993,حَدَّثَنَا جُبَارَةُ بْنُ الْمُغَلِّسِ، ‏‏‏‏‏‏حَدَّثَنَا إِبْرَاهِيمُ بْنُ عُثْمَانَ، ‏‏‏‏‏‏عَنْ أَب,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن الترمذی/الحج ۹۵ (۹۳۹)،(تحفة الأشراف:۱۸۳۶۰)، وقد أخرجہ: سنن ابی داود/الحج ۸۰ (۱۹۸۸)، مسند احمد (۶/۴۰۵،۴۰۶),2993,,Chapters on Hajj Rituals
2994,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو مُعَاوِيَةَ، ‏‏‏‏‏‏عَنْ حَجَّاجٍ، ‏‏‏‏‏‏عَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۸۹۰)، وقد أخرجہ: صحیح البخاری/العمرة ۴ (۱۷۸۲)، جزاء الصید ۲۶ (۱۸۶۳)، صحیح مسلم/الحج ۳۶ (۱۲۵۶)، سنن النسائی/الصیام ۴ (۲۱۱۲)، مسند احمد (۱/۲۲۹،۳۰۸)، سنن الدارمی/المناسک ۴۰ (۱۹۰۱،۱۹۰۲),2994,,Chapters on Hajj Rituals
2995,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا أَحْمَدُ بْنُ عَبْدِ الْمَلِكِ بْنِ وَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «صحیح البخاری/جزاء الصید ۲۶ (۱۸۶۰تعلیقاً)،(تحفة الأشراف:۲۴۲۹)، وقد أخرجہ: مسند احمد (۱/۳۰۸،۳۵۲،۳۶۱،۳۹۷),2995,,Chapters on Hajj Rituals
2996,حَدَّثَنَا عُثْمَانُ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا يَحْيَى بْنُ زَكَرِيَّا بْنِ أَبِي زَائِد,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۹۵۹، ومصباح الزجاجة:۱۰۵۰)، و قد أخرجہ: سنن الترمذی/الحج ۷ (۸۱۶)، مسند احمد (۱/۲۴۶),2996,,Chapters on Hajj Rituals
2997,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، ‏‏‏‏‏‏عَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «صحیح البخاری/العمرة ۳ (۱۷۷۵)، المغازي ۴۴ (۴۲۵۳)، صحیح مسلم/الحج ۳۵ (۱۲۵۵)، سنن ابی داود/المناسک ۸۰ (۱۹۹۲)(تحفة الأشراف:۱۷۵۷۴)، وقد أخرجہ: مسند احمد (۶/۲۲۸،۷۰،۱۲۹،۱۳۹،۱۴۳،۱۵۵),2997,,Chapters on Hajj Rituals
2998,حَدَّثَنَا أَبُو كُرَيْبٍ، ‏‏‏‏‏‏حَدَّثَنَا يَحْيَى بْنُ آدَمَ، ‏‏‏‏‏‏عَنْ أَبِي بَكْرِ بْنِ عَيَّاش,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «حدیث ابن عمر أخرجہ: صحیح مسلم/الحج ۳۵ (۱۲۵۵)، سنن الترمذی/الحج ۹۳ (۹۳۶)،(تحفة الأشراف:۷۳۲۱)، حدیث عائشہ أخرجہ: سنن الترمذی/ الحج ۹۳ (۹۳۶)،(تحفة الأشراف:۱۷۳۷۳)، وقد أخرجہ: صحیح البخاری/العمرة ۳ (۱۷۷۷)، سنن ابی داود/الحج ۸۰ (۱۹۹۴)، مسند احمد (۱/۲۴۶),2998,,Chapters on Hajj Rituals
2999,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَأَبُو إِسْحَاق الشَّافِعِيُّ إِبْرَاهِيمُ بْنُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/العمرة ۶ (۱۷۸۴)، الجہاد ۱۲۵ (۲۹۸۵)، صحیح مسلم/الحج ۱۷ (۱۲۱۲)، سنن الترمذی/الحج ۹۱ (۹۳۴)،(تحفة الأشراف:۹۶۸۷)، وقد أخرجہ: سنن ابی داود/الحج ۸۱ (۱۹۹۵)، مسند احمد (۱/۱۹۷)، سنن الدارمی/المناسک ۴۱ (۱۹۰۴),2999,,Chapters on Hajj Rituals
3000,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدَةُ بْنُ سُلَيْمَانَ، ‏‏‏‏‏‏عَنْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/العمرة ۵ (۱۷۸۳)، صحیح مسلم/الحج ۱۷ (۱۲۱۱)،(تحفة الأشراف:۱۷۰۴۸),3000,,Chapters on Hajj Rituals
3001,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْأَعْلَى بْنُ عَبْدِ الْأَعْل,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الحج ۹ (۱۷۴۱)،(تحفة الأشراف:۱۸۲۵۳)، وقد أخرجہ: مسند احمد (۶/۲۹۹),3001,,Chapters on Hajj Rituals
3002,حَدَّثَنَا مُحَمَّدُ بْنُ الْمُصَفَّى الْحِمْصِيُّ، ‏‏‏‏‏‏حَدَّثَنَا أَحْمَدُ بْنُ خَالِدٍ، ‏‏‏‏‏‏حَ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «أنظر ما قبلہ,3002,,Chapters on Hajj Rituals
3003,حَدَّثَنَا أَبُو إِسْحَاق الشَّافِعِيُّ إِبْرَاهِيمُ بْنُ مُحَمَّدٍ حَدَّثَنَا دَاوُدُ بْنُ عَبْدِ ا,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن ابی داود/المناسک ۸۰ (۱۹۹۳)، سنن الترمذی/الحج ۷ (۸۱۶)،(تحفة الأشراف:۶۱۶۸)، وقد أخرجہ: مسند احمد (۱/۲۴۶،۳۲۱)، سنن الدارمی/المناسک ۳۹ (۱۹۰۰),3003,,Chapters on Hajj Rituals
3004,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو مُعَاوِيَةَ، ‏‏‏‏‏‏عَنْ إِسْمَاعِيل، ‏‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن الترمذی/الحج ۵۰ (۸۷۹)،(تحفة الأشراف:۵۸۸۱),3004,,Chapters on Hajj Rituals
3005,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الرَّزَّاقِ، ‏‏‏‏‏‏أَنْبَأَنَا عَبْدُ الل,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan Lighairihi; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۷۳۷، ومصباح الزجاجة:۱۰۵۱)، وقد أخرجہ: موطا امام مالک/الحج ۶۴ (۱۹۵),3005,,Chapters on Hajj Rituals
3006,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏عَنْ إِسْرَائِيلَ، ‏‏‏‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/المناسک ۸۹ (۲۰۱۹)، سنن الترمذی/الحج ۵۱ (۸۸۱)،(تحفة الأشراف:۱۷۹۶۳)، وقد أخرجہ: مسند احمد (۶/۱۸۷ٕ ۲۰۶)، سنن الدارمی/المناسک ۸۷ (۱۹۸۰),3006,,Chapters on Hajj Rituals
3007,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏ وَعَمْرُو بْنُ عَبْدِ اللَّهِ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Isnaad Hasan,takhreej: «أنظر ما قبلہ,3007,,Chapters on Hajj Rituals
3008,حَدَّثَنَا مُحَمَّدُ بْنُ أَبِي عُمَرَ الْعَدَنِيُّ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/العیدین ۱۲ (۹۷۰)، الحج ۸۶ (۱۶۵۹)، صحیح مسلم/الحج ۴۶ (۱۲۸۵)سنن النسائی/الحج ۱۹۲ (۳۰۰۳)،(تحفة الأشراف:۱۴۵۲)، وقد أخرجہ: سنن ابی داود/الحج ۲۸ (۱۸۱۶)، موطا امام مالک/الحج ۱۳ (۴۳)، مسند احمد (۳/۱۱۰،۲۴۰)، سنن الدارمی/المناسک ۴۸ (۱۹۱۹),3008,,Chapters on Hajj Rituals
3009,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏ وَعَمْرُو بْنُ عَبْدِ اللَّهِ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَ,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/المناسک ۶۱ (۱۹۱۴)،(تحفة الأشراف:۷۰۷۳)، وقد أخرجہ: صحیح البخاری/الحج ۸۷ (۱۶۶۰)، موطا امام مالک/الحج ۶۴ (۱۹۵)، مسند احمد (۲/۲۵),3009,,Chapters on Hajj Rituals
3010,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا يَحْيَى بْنُ آدَمَ، ‏‏‏‏‏‏عَنْ سُفْيَانَ، ‏‏‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/المناسک ۶۴ (۱۹۳۵،۱۹۳۶)، سنن الترمذی/الحج ۵۴ (۸۸۵)،(تحفة الأشراف:۱۰۲۲۹),3010,,Chapters on Hajj Rituals
3011,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏عَنْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن ابی داود/المناسک ۶۲ (۱۹۱۹)، سنن الترمذی/الحج ۵۳ (۸۸۳)،(تحفة الأشراف:۱۵۵۲۶)، وقد أخرجہ: مسند احمد (۴/۱۳۷),3011,,Chapters on Hajj Rituals
3012,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا الْقَاسِمُ بْنُ عَبْدِ اللَّهِ الْعُمَرِيُّ، ‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: «تفرد ابن ماجہ،(تحفة الأشراف:۳۰۶۹، ومصباح الزجاجة:۱۰۵۲)، وقد أخرجہ: سنن ابی داود/المناسک ۶۵ (۱۹۳۶)، سنن الدارمی/المناسک ۵۰ (۱۹۲۱),3012,,Chapters on Hajj Rituals
3013,حَدَّثَنَا أَيُّوبُ بْنُ مُحَمَّدٍ الْهَاشِمِيُّ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْقَاهِرِ بْنُ السَّرِيِّ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۱۴۰، ومصباح الزجاجة:۱۰۵۳)، وقد أخرجہ: سنن ابی داود/الأدب ۱۶۸ (۵۲۳۴)، مسند احمد (۴/۱۴),3013,,Chapters on Hajj Rituals
3014,حَدَّثَنَا هَارُونُ بْنُ سَعِيدٍ الْمِصْرِيُّ أَبُو جَعْفَرٍ، ‏‏‏‏‏‏أَنْبَأَنَا عَبْدُ اللَّهِ بْنُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۷۹ (۱۳۴۸)، سنن النسائی/الحج ۱۹۴ (۳۰۰۶)،(تحفة الأشراف:۱۶۱۳۱),3014,,Chapters on Hajj Rituals
3015,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الحج ۶۹ (۱۹۴۹)، سنن الترمذی/الحج ۵۷ (۸۸۹،۸۹۰)، سنن النسائی/الحج ۲۰۳ (۳۰۱۹)،۲۱۱ (۳۰۴۷)،(تحفة الأشراف:۹۷۳۵)، وقد أخرجہ: مسند احمد (۴/۳۰۹،۳۱۰،۳۳۵)، سنن الدارمی/المناسک ۵۴ (۱۹۲۹),3015,,Chapters on Hajj Rituals
3016,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الحج ۶۹ (۱۹۵۰)، سنن الترمذی/الحج ۵۷ (۸۹۱)، سنن النسائی/الحج ۲۱۱ (۳۰۴۲)،(تحفة الأشراف:۹۹۰۰)، وقد أخرجہ: مسند احمد (۴/۱۵،۲۶۱،۲۶۲)، سنن الدارمی/المناسک ۵۴ (۱۹۳۰),3016,,Chapters on Hajj Rituals
3017,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏ وَعَمْرُو بْنُ عَبْدِ اللَّهِ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحج ۹۳ (۱۶۶۶)، الجہاد ۱۳۶ (۲۹۹۹)، المغازي ۷۷ (۴۴۱۳)، صحیح مسلم/الحج ۴۷ (۱۲۸۰،۱۲۸۶)، سنن ابی داود/الحج ۶۴ (۱۹۲۳)، سنن النسائی/الحج ۲۰۵ (۳۰۲۶)،۲۱۴ (۳۰۵۴)،(تحفة الأشراف:۱۰۴)، وقد أخرجہ: موطا امام مالک/الحج۵۷ (۱۷۶)، مسند احمد (۵/۲۰۵،۲۱۰)، سنن الدارمی/المناسک ۵۱ (۱۹۲۲),3017,,Chapters on Hajj Rituals
3018,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الرَّزَّاقِ، ‏‏‏‏‏‏أَنْبَأَنَا الثَّوْرِي,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۶۹۲۲، ومصباح الزجاجة:۱۰۵۴),3018,,Chapters on Hajj Rituals
3019,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، ‏‏‏‏‏‏حَدَّث,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «سنن ابی داود/المناسک ۶۴ (۱۹۲۱)، سنن النسائی/المواقیت ۵۰ (۶۱۰)، الحج ۲۰۶ (۳۰۲۸)،(تحفة الأشراف:۱۱۶)، وقد أخرجہ: صحیح البخاری/الوضوء ۳۵ (۱۳۹)، الحج ۹۵ (۱۶۶۶)، صحیح مسلم/الحج ۴۷ (۱۲۸۰)، موطا امام مالک/الحج ۶۵ (۱۹۷)، مسند احمد (۵/۲۰۰،۲۰۲،۲۰۸،۲۱۰)، سنن الدارمی/المناسک ۵۱ (۱۹۲۲),3019,,Chapters on Hajj Rituals
3020,حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، ‏‏‏‏‏‏أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، ‏‏‏‏‏‏عَنْ يَحْيَى بْنِ س,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحج ۹۶ (۱۶۷۴)، المغازي ۷۶ (۴۴۱۴)، صحیح مسلم/الحج ۴۷ (۱۲۸۷)، سنن النسائی/المواقیت ۴۸ (۶۰۶)،(تحفة الأشراف:۳۴۶۵)، وقد أخرجہ: موطا امام مالک/الحج ۶۵ (۱۹۸)، مسند احمد (۵/۴۱۸،۴۱۹،۴۲۰،۴۲۱)، سنن الدارمی/المناسک ۵۲ (۱۹۲۵),3020,,Chapters on Hajj Rituals
3021,حَدَّثَنَا مُحْرِزُ بْنُ سَلَمَةَ الْعَدَنِيُّ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ، ‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۷۷۰)، وقد أخرجہ: صحیح البخاری/الحج ۹۶ (۱۶۷۴)، صحیح مسلم/الحج ۴۷ (۱۲۸۶)، سنن ابی داود/المناسک ۶۵ (۱۹۲۶)، موطا امام مالک/الحج ۶۵ (۱۹۶)، سنن الدارمی/المناسک ۵۲ (۶۷۷۰),3021,,Chapters on Hajj Rituals
3022,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو خَالِدٍ الْأَحْمَرُ، ‏‏‏‏‏‏عَنْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الحج ۱۰۰ (۱۶۸۴)، مناقب الأنصار ۲۶ (۳۸۳۸)، سنن ابی داود/الحج ۶۵ (۱۹۳۸)، سنن الترمذی/الحج ۶۰ (۸۹۶)، سنن النسائی/الحج ۲۱۳ (۳۰۵۰)،(تحفة الأشراف:۱۰۶۱۶)، وقد أخرجہ: مسند احمد (۱/۱۴،۲۹،۳۹،۴۲،۵۰،۵۲)سنن الدارمی/المناسک ۵۵ (۱۹۳۲),3022,,Chapters on Hajj Rituals
3023,حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ رَجَاءٍ الْمَكِّيُّ، ‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الحج ۶۶ (۱۹۴۴)، سنن النسائی/الحج ۲۰۴ (۳۰۲۴)،۲۱۵ (۳۰۵۵)،(تحفة الأشراف:۲۷۴۷)، وقد أخرجہ: سنن الترمذی/الحج ۵۵ (۸۸۶)، مسند احمد (۳/۳۰۱،۳۳۲،۳۶۷،۳۹۱),3023,,Chapters on Hajj Rituals
3024,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏ وَعَمْرُو بْنُ عَبْدِ اللَّهِ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۰۴۸، ومصباح الزجاجة:۱۰۵۵),3024,,Chapters on Hajj Rituals
3025,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الحج ۶۶ (۱۹۴۰)، سنن النسائی/الحج ۲۲۲ (۳۰۶۶)،(تحفة الأشراف:۵۳۹۶)، وقد أخرجہ: سنن الترمذی/الحج ۵۸ (۸۹۳)، مسند احمد (۱/۲۳۴،۳۱۱،۳۴۳),3025,,Chapters on Hajj Rituals
3026,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ، ‏‏‏‏‏‏حَدَّثَنَا عَمْرٌو، ‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۴۹ (۱۲۹۳)، سنن النسائی/الحج ۲۰۸ (۳۰۳۶)،۲۱۴ (۳۰۵۱)،(تحفة الأشراف:۵۹۴۴)، وقد أخرجہ: مسند احمد (۱/۲۲۱،۲۷۲),3026,,Chapters on Hajj Rituals
3027,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ، ‏‏‏‏‏‏عَنْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحج ۹۸ (۱۶۸۰)، صحیح مسلم/الحج ۴۹ (۱۲۹۰)،(تحفة الأشراف:۱۷۴۷۹)، وقد أخرجہ: سنن النسائی/الحج ۲۰۹ (۳۰۴۰)،۲۱۴ (۳۰۵۲)، مسند احمد (۶/۳۰،۹۴،۹۹،۱۳۳،۱۶۴،۲۱۴)، سنن الدارمی/المناسک ۵۳ (۱۹۲۸),3027,,Chapters on Hajj Rituals
3028,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ، ‏‏‏‏‏‏عَنْ يَزِ,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan Lighairihi; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/المناسک ۷۸ (۱۹۶۶،۱۹۶۷)،(تحفة الأشراف:۱۸۳۰۶)، وقد أخرجہ: مسند احمد (۳/۵۰۳،۵/۲۷۰،۳۷۹،۶/۳۷۹),3028,,Chapters on Hajj Rituals
3029,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو أُسَامَةَ، ‏‏‏‏‏‏عَنْ عَوْفٍ، ‏‏‏‏‏‏عَنْ ز,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن النسائی/الحج ۲۱۷ (۳۰۵۹)،۲۱۹ (۳۰۶۱)،(تحفة الأشراف:۵۴۲۷)، وقد أخرجہ: مسند احمد (۱/۲۱۵،۳۴۷،۵/۱۲۷),3029,,Chapters on Hajj Rituals
3030,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏عَنْ الْمَسْعُودِيِّ، ‏‏‏‏‏‏عَنْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحج ۱۳۵ (۱۷۴۷)،۱۳۸ (۱۷۵۰)، صحیح مسلم/الحج ۵۰ (۱۲۹۶)، سنن ابی داود/الحج ۷۸ (۱۹۷۴)، سنن الترمذی/الحج ۶۴ (۹۰۱)، سنن النسائی/الحج ۲۲۶ (۳۰۷۲)،(تحفة الأشراف:۹۳۸۲)، وقد أخرجہ: مسند احمد (۱/۴۱۵،۴۲۷،۴۳۰،۴۳۲،۴۳۶،۴۵۶،۴۵۸),3030,,Chapters on Hajj Rituals
3031,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ، ‏‏‏‏‏‏عَنْ يَزِ,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan Lighairihi; Zubair Ali Zai: Daif,takhreej: «انظر حدیث رقم:۳۰۲۸،(تحفة الأشراف:۹۳۸۲),3031,,Chapters on Hajj Rituals
3032,حَدَّثَنَا عُثْمَانُ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا طَلْحَةُ بْنُ يَحْيَى، ‏‏‏‏‏‏عَنْ يُونُسَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الحج ۱۴۰ (۱۷۵۱)،۱۴۲ (۱۷۵۲،۱۷۵۳)، سنن النسائی/الحج ۲۳۰ (۳۰۸۵)،(تحفة الأشراف:۶۹۸۶)، وقد أخرجہ: مسند احمد (۲/۱۵۲)، سنن الدارمی/المناسک ۶۱ (۱۹۴۴),3032,,Chapters on Hajj Rituals
3033,حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، ‏‏‏‏‏‏حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ، ‏‏‏‏‏‏عَنْ الْحَجَّاجِ، ‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih Lighairihi; Shuaib Al Arnaut: Hasan Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۴۸۴، ومصباح الزجاجة:۱۰۵۶),3033,,Chapters on Hajj Rituals
3034,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو خَالِدٍ الْأَحْمَرُ، ‏‏‏‏‏‏عَنْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Hasan,takhreej: «سنن الترمذی/الحج ۶۳ (۸۹۹)،(تحفة الأشراف:۶۴۶۷)، وقد أخرجہ: مسند احمد (۱/۲۳۲),3034,,Chapters on Hajj Rituals
3035,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏عَنْ أَيْمَنَ بْنِ نَاب,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن الترمذی/الحج ۶۵ (۹۰۳)، سنن النسائی/المناسک ۲۲۰ (۳۰۶۳)،(تحفة الأشراف:۱۱۰۷۷)، وقد أخرجہ: مسند احمد۳/۴۱۲،۴۱۳)، سنن الدارمی/المناسک ۶۰ (۱۹۴۲),3035,,Chapters on Hajj Rituals
3036,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏عَنْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الحج ۷۸ (۱۹۷۵ و ۱۹۷۶)، سنن الترمذی/الحج ۱۰۸ (۹۵۴،۹۵۵)، سنن النسائی/الحج ۲۲۵ (۳۰۷۰)،(تحفة الأشراف:۵۰۳۰)، وقد أخرجہ: موطا امام مالک/الحج ۷۲ (۲۱۸)، مسند احمد (۵/۴۵۰)، سنن الدارمی/المناسک ۵۸ (۱۹۳۸),3036,,Chapters on Hajj Rituals
3037,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الرَّزَّاقِ، ‏‏‏‏‏‏أَنْبَأَنَا مَالِكُ بْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «أنظر ما قبلہ،(تحفة الأشراف:۵۰۳۰),3037,,Chapters on Hajj Rituals
3038,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، ‏‏‏‏‏‏عَ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/الحج ۸۴ (۹۲۷)،(تحفة الأشراف:۲۶۶۲)، وقد أخرجہ: مسند احمد (۳/۳۱۴),3038,,Chapters on Hajj Rituals
3039,حَدَّثَنَا بَكْرُ بْنُ خَلَفٍ أَبُو بِشْرٍ، ‏‏‏‏‏‏حَدَّثَنَا حَمْزَةُ بْنُ الْحَارِثِ بْنِ عُمَيْرٍ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۴۴۴، ومصباح الزجاجة:۱۰۵۷)، وقد أخرجہ: سنن النسائی/الحج ۲۱۶ (۳۰۵۸)، مسند احمد (۱/۲۱۰،۲۱۴)، سنن الدارمی/المناسک ۶۰ (۱۹۴۳)، وراجع الحدیث الآتي,3039,,Chapters on Hajj Rituals
3040,حَدَّثَنَا هَنَّادُ بْنُ السَّرِيِّ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو الْأَحْوَصِ، ‏‏‏‏‏‏عَنْ خُصَيْفٍ، ‏‏‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن النسائی/الحج ۲۱۶ (۳۰۵۷)،(تحفة الأشراف:۱۱۰۵۶)، وقد أخرجہ: صحیح البخاری/الحج ۲۲ (۱۵۴۳)،۹۳ (۱۶۶۹)،۱۰۱ (۱۶۸۵)، صحیح مسلم/الحج ۴۵ (۱۲۸۰),3040,,Chapters on Hajj Rituals
3041,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Daif,takhreej: «سنن النسائی/الحج ۲۳۱ (۳۰۸۶)،(تحفة الأشراف:۵۳۹۷),3041,,Chapters on Hajj Rituals
3042,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا خَالِي مُحَمَّدٌ، ‏‏‏‏‏‏ وَأَبُو مُعَاوِيَةَ، ‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۷ (۱۱۸۹)،(تحفة الأشراف:۱۷۵۳۸)، وقد أخرجہ: صحیح البخاری/الحج ۱۸ (۱۵۳۹)،۱۴۳ (۱۷۵۴)، اللباس ۷۳ (۵۹۲۲۰)،۷۴ (۵۹۲۳)،۷۹ (۵۹۲۸)،۸۱ (۵۹۳۰)، سنن ابی داود/الحج ۱۱ (۱۷۴۵)، سنن الترمذی/الحج ۷۷ (۹۱۷)، سنن النسائی/الحج ۴۱ (۲۶۸۵)، موطا امام مالک/الحج ۷ (۱۷)، مسند احمد (۶/۹۸،۱۰۶،۱۳،۱۶۲،۱۸۱،۱۸۶،۱۹۲،۲۰۰،۲۰۷،۲۰۹،۲۱۴،۲۱۶،۲۳۷،۲۳۸،۲۴۴،۲۴۵،۲۵۸)، سنن الدارمی/المناسک ۱۰ (۱۸۴۴),3042,,Chapters on Hajj Rituals
3043,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحج ۱۲۷ (۱۷۲۸)، صحیح مسلم/الحج ۵۵ (۱۳۰۲)،(تحفة الأشراف:۱۴۹۰۴)، وقد أخرجہ: مسند احمد (۲/۲۳۱),3043,,Chapters on Hajj Rituals
3044,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏ وَأَحْمَدُ بْنُ أَبِي الْحَوَارِيِّ الدمشقي، ‏‏‏‏‏‏قَالَا:,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۵۵ (۱۳۰۱)،(تحفة الأشراف:۷۹۴۷)، وقد أخرجہ: صحیح البخاری/الحج ۱۴۷ (۱۷۲۷)، سنن ابی داود/الحج ۷۹ (۱۹۷۹)، سنن الترمذی/الحج ۷۴ (۹۱۳)، موطا امام مالک/الحج ۶۰ (۱۸۴)، مسند احمد (۲/۳۴،۱۵۱)، سنن الدارمی/المناسک ۶۴ (۱۹۴۷),3044,,Chapters on Hajj Rituals
3045,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، ‏‏‏‏‏‏حَدَّثَنَا يُونُسُ بْنُ بُكَيْرٍ، ‏‏‏‏,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۴۱۰، ومصباح الزجاجة:۱۰۵۸)، وقد أخرجہ: مسند احمد (۱/۳۵۳),3045,,Chapters on Hajj Rituals
3046,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو أُسَامَةَ، ‏‏‏‏‏‏عَنْ عُبَيْدِ ا,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحج ۳۴ (۱۵۶۶)،۱۰۷ (۱۶۹۷)،۱۲۶ (۱۷۲۵)، المغازي ۷۷ (۴۳۹۸)، اللباس ۶۹ (۵۹۱۶)، صحیح مسلم/الحج ۲۵ (۱۲۲۹)، سنن ابی داود/الحج ۲۴ (۱۸۰۶)، سنن النسائی/الحج ۴۰ (۲۶۸۳)،(تحفة الأشراف:۱۵۸۰۰)، وقد أخرجہ: موطا امام مالک/الحج ۵۸ (۱۸۰)، مسند احمد (۶/۲۸۳،۲۸۴،۲۸۵),3046,,Chapters on Hajj Rituals
3047,حَدَّثَنَا أَحْمَدُ بْنُ عَمْرِو بْنِ السَّرْحِ الْمِصْرِيُّ، ‏‏‏‏‏‏أَنْبَأَنَا عَبْدُ اللَّهِ بْنُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحج ۱۹ (۱۵۴۰)، اللباس ۶۹ (۵۹۱۵)، صحیح مسلم/الحج ۳ (۱۱۸۴)، سنن ابی داود/الحج ۱۲ (۱۷۴۷)، سنن النسائی/الحج ۴۰ (۲۶۸۴)،(تحفة الأشراف:۶۹۷۶)، وقد أخرجہ: مسند احمد (۲/۱۲۱،۱۳۱),3047,,Chapters on Hajj Rituals
3048,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏ وَعَمْرُو بْنُ عَبْدِ اللَّهِ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَ,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/المناسک ۶۵ (۱۹۳۷)،(تحفة الأشراف:۲۳۹۷)، وقد أخرجہ: مسند احمد (۳/۳۲۶)، سنن الدارمی/المناسک ۵۰ (۱۹۲۱),3048,,Chapters on Hajj Rituals
3049,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏عَنْ أَيُّوبَ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/العلم ۲۴ (۸۴)، الحج ۱۲۵ (۱۷۲۳)،۱۳۰ (۱۷۳۵)، الأیمان ۱۵ (۶۶۶۶)،(تحفة الأشراف:۵۹۹۹)، وقد أخرجہ: صحیح مسلم/الحج ۵۷ (۱۳۰۷)، سنن ابی داود/الحج ۷۹ (۱۹۸۳)، سنن النسائی/الحج ۲۲۴ (۳۰۶۹)، مسند احمد (۱/۲۱۶،۲۶۹،۲۹۱،۳۰۰،۳۱۱،۳۲۸),3049,,Chapters on Hajj Rituals
3050,حَدَّثَنَا أَبُو بِشْرٍ بَكْرُ بْنُ خَلَفٍ، ‏‏‏‏‏‏حَدَّثَنَا يَزِيدُ بْنُ زُرَيْعٍ، ‏‏‏‏‏‏عَنْ خَالِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الحج ۱۲۵ (۱۷۲۳)،۱۳۰ (۱۷۳۵)، سنن ابی داود/المناسک ۷۹ (۱۹۸۳)، سنن النسائی/مناسک الحج ۲۲۴ (۳۰۶۹)،(تحفة الأشراف:۶۰۴۷)، وقد أخرجہ: مسند احمد (۱/۲۱۶،۲۵۸،۲۶۹،۲۹۱،۳۰۰،۳۱۱،۳۸۲),3050,,Chapters on Hajj Rituals
3051,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏عَنْ الزُّهْرِي,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/العلم ۲۳ (۸۳)، الحج ۱۳۱ (۱۷۳۶،۱۷۳۷)، صحیح مسلم/الحج ۵۷ (۱۳۰۶)، سنن ابی داود/الحج ۸۸ (۲۰۱۴)، سنن الترمذی/الحج ۷۶ (۹۱۶)،(تحفة الأشراف:۸۹۰۶)، وقد أخرجہ: موطا امام مالک/الحج ۸۱ (۲۴۲)، مسند احمد (۲/۱۵۹،۱۶۰،۱۹۲،۲۰۲،۲۱۰،۲۱۷)، سنن الدارمی/المناسک ۶۵ (۱۹۴۸),3051,,Chapters on Hajj Rituals
3052,حَدَّثَنَا هَارُونُ بْنُ سَعِيدٍ الْمِصْرِيُّ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، ‏‏‏‏‏‏أَ,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۳۹۸، ومصباح الزجاجة:۱۰۵۹)، وقد أخرجہ: مسند احمد (۳/۳۲۶),3052,,Chapters on Hajj Rituals
3053,حَدَّثَنَا حَرْمَلَةُ بْنُ يَحْيَى الْمِصْرِيُّ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، ‏‏‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۵۳ (۱۲۹۹)، سنن ابی داود/الحج ۷۸ (۱۹۷۱)، سنن الترمذی/الحج ۵۹ (۸۹۴)، سنن النسائی/الحج ۲۲۱ (۳۰۶۵)،(تحفة الأشراف:۲۷۹۵)، وقد أخرجہ: مسند احمد (۳/۳۱۲،۳۱۹،۴۰۰)، سنن الدارمی/المناسک ۵۸ (۱۹۳۷),3053,,Chapters on Hajj Rituals
3054,حَدَّثَنَا جُبَارَةُ بْنُ الْمُغَلِّسِ، ‏‏‏‏‏‏حَدَّثَنَا إِبْرَاهِيمُ بْنُ عُثْمَانَ بْنِ أَبِي شَيْ,Al-Albani: Daif Isnaad; Muhammad Fouad Abd al-Baqi: Daif Isnaad; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/الحج ۶۲ (۸۹۸)،(تحفة الأشراف:۶۴۶۶)، وقد أخرجہ: مسند احمد (۱/۲۴۸،۲۹۰،۳۲۸),3054,,Chapters on Hajj Rituals
3055,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَهَنَّادُ بْنُ السَّرِيِّ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/البیوع ۵ (۳۳۳۴)، سنن الترمذی/الفتن ۲ (۲۱۵۹)، تفسیر القرآن ۱۰ (۱)(۳۰۸۷)،(تحفة الأشراف:۱۰۶۹۱)، وقد أخرجہ: مسند احمد (۳/۴۲۶،۴۸۹),3055,,Chapters on Hajj Rituals
3056,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبِي، ‏‏‏‏‏‏عَنْ مُحَمَّدِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۱۹۸، ومصباح الزجاجة:۱۰۶۰)، وقد أخرجہ: مسند احمد (۴/۸۰)(یہ حدیث مکرر ہے دیکھئے:۲۳۱),3056,,Chapters on Hajj Rituals
3057,حَدَّثَنَا إِسْمَاعِيل بْنُ تَوْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا زَافِرُ بْنُ سُلَيْمَانَ، ‏‏‏‏‏‏عَنْ أَبِي سِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۵۵۷، ومصباح الزجاجة:۱۰۶۱),3057,,Chapters on Hajj Rituals
3058,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا صَدَقَةُ بْنُ خَالِدٍ، ‏‏‏‏‏‏حَدَّثَنَا هِشَامُ ب,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «صحیح البخاری/الحج ۱۳۲ (۱۷۴۲ تعلیقاً)، سنن ابی داود/المناسک ۶۷ (۱۹۴۵)،(تحفة الأشراف:۸۵۱۴),3058,,Chapters on Hajj Rituals
3059,حَدَّثَنَا بَكْرُ بْنُ خَلَفٍ أَبُو بِشْرٍ، ‏‏‏‏‏‏حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، ‏‏‏‏‏‏حَدَّثَنَا,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Shadh; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «حدیث ابن عباس أخرجہ: صحیح البخاری/ الحج ۱۲۹ (۱۷۳۲ تعلیقاً)، سنن ابی داود/المناسک ۸۲ (۲۰۰۰)، سنن الترمذی/الحج ۸۰ (۹۲۰)،(تحفة الأشراف:۶۴۵۲،۱۷۵۹۴)، حدیث عائشہ تقدم تخریجہ في حدیث ابن عباس، وحدیث طاوس تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۸۸۴۵، ومصباح الزجاجة:۱۰۶۲)، وقد أخرجہ: مسند احمد (۱/۲۸۸),3059,,Chapters on Hajj Rituals
3060,حَدَّثَنَا حَرْمَلَةُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا ابْنُ وَهْبٍ، ‏‏‏‏‏‏أَنْبَأَنَا ابْنُ جُرَيْجٍ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/المناسک ۸۳ (۲۰۰۱)،(تحفة الأشراف:۵۹۱۷),3060,,Chapters on Hajj Rituals
3061,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ مُوسَى، ‏‏‏‏‏‏عَنْ عُثْمَا,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۴۴۲، ومصباح الزجاجة:۱۰۶۳),3061,,Chapters on Hajj Rituals
3062,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ قَالَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۷۸۴، ومصباح الزجاجة:۱۰۶۴)، وقد أخرجہ: مسند احمد (۳/۳۵۷،۳۷۲),3062,,Chapters on Hajj Rituals
3063,حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ الدِّمَشْقِيُّ، ‏‏‏‏‏‏حَدَّثَنَا عُمَرُ بْنُ عَبْدِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الصلاة ۳۰ (۳۹۷)،۸۱ (۴۸۶)،۹۶ (۵۰۴)، التھجد ۲۵ (۱۱۶۷)، الحج ۵۱ (۱۵۹۸)، الجہاد ۱۲۷ (۲۶۸۸)، المغازي ۴۹ (۴۲۸۹)،۷۷ (۴۴۰۰)، صحیح مسلم/الحج ۶۸ (۱۳۲۹)، سنن ابی داود/الحج ۹۳ (۲۰۲۳)، سنن الترمذی/الحج ۴۶ (۸۷۴)، سنن النسائی/المساجد ۵ (۶۹۳)، القبلة ۶ (۷۵۰)، الحج ۱۲۶ (۲۹۰۸)،۱۲۷ (۲۹۰۹)،(تحفة الأشراف:۲۰۳۷)، وقد أخرجہ: موطا امام مالک/الحج ۶۳ (۱۹۳)، مسند احمد (۲/۳۳،۵۵،۱۱۳،۱۲۰،۱۳۸،۶/۱۲،۱۳،۱۴،۱۵)، سنن الدارمی/المناسک ۴۳ (۱۹۰۸),3063,,Chapters on Hajj Rituals
3064,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏حَدَّثَنَا إِسْمَاعِيل بْنُ عَبْد,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/المناسک ۹۵ (۲۰۲۹)، سنن الترمذی/الحج ۴۵ (۸۷۳)،(تحفة الأشراف:۱۶۲۳۰)، وقد أخرجہ: مسند احمد (۶/۱۳۷),3064,,Chapters on Hajj Rituals
3065,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، ‏‏‏‏‏‏حَدَّثَنَا ع,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحج ۱۳۳ (۱۷۴۵)، صحیح مسلم/الحج ۶۰ (۱۳۱۵)، سنن ابی داود/المناسک ۷۵ (۱۹۵۹)،(تحفة الأشراف:۷۹۳۹)، وقد أخرجہ: مسند احمد (۲/۲۲)، سنن الدارمی/المناسک ۹۱ (۱۹۸۶),3065,,Chapters on Hajj Rituals
3066,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏ وَهَنَّادُ بْنُ السَّرِيِّ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَا أ,Al-Albani: Daif Isnaad; Muhammad Fouad Abd al-Baqi: Daif Isnaad; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۸۸۲، ومصباح الزجاجة:۱۰۶۵),3066,,Chapters on Hajj Rituals
3067,حَدَّثَنَا هَنَّادُ بْنُ السَّرِيِّ، ‏‏‏‏‏‏حَدَّثَنَا ابْنُ أَبِي زَائِدَةَ، ‏‏‏‏‏‏ وَعَبْدَةُ، ‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «حدیث أبي بکر بن أبي شیبة أخرجہ: صحیح مسلم/الحج ۵۹ (۱۳۱۱)،(تحفة الأشراف:۱۶۷۸۸)، وباقی الإسناد وتفرد بہ ابن ماجہ،(تحفة الأشراف:۱۷۰۹۵،۱۷۲۳۳،۱۷۲۸۶،۱۷۳۰۰)، وقد أخرجہ: صحیح البخاری/الحج ۱۴۷ (۱۷۶۵)، سنن ابی داود/المناسک ۸۷ (۲۰۰۸)، سنن الترمذی/الحج ۸۲ (۹۲۳),3067,,Chapters on Hajj Rituals
3068,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا مُعَاوِيَةُ بْنُ هِشَامٍ، ‏‏‏‏‏‏عَنْ ع,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۵۹۶۰، ومصباح الزجاجة:۱۰۶۶)، وقد أخرجہ: مسند احمد (۶/۷۸),3068,,Chapters on Hajj Rituals
3069,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الرَّزَّاقِ، ‏‏‏‏‏‏أَنْبَأَنَا عُبَيْدُ ا,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «صحیح البخاری/الحج ۱۴۸ (۱۷۶۸)مختصراً، صحیح مسلم/الحج ۵۹ (۱۳۱۰)، سنن الترمذی/الحج ۸۱ (۹۲۱)،(تحفة الأشراف:۸۰۲۵)، وقد أخرجہ: مسند احمد (۲/۸۹),3069,,Chapters on Hajj Rituals
3070,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏عَنْ سُلَيْمَانَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۶۷ (۱۳۲۷)، سنن ابی داود/المناسک ۸۴ (۲۰۰۲)،(تحفة الأشراف:۵۷۰۳)، وقد أخرجہ: صحیح البخاری/الحج ۱۴۴ (۱۷۵۵)، مسند احمد (۱/۲۲۲)، سنن الدارمی/المناسک ۸۵ (۱۹۷۴),3070,,Chapters on Hajj Rituals
3071,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏حَدَّثَنَا إِبْرَاهِيمُ بْنُ يَزِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۱۰۹، ومصباح الزجاجة:۱۰۶۷),3071,,Chapters on Hajj Rituals
3072,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏عَنْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «حدیث أبيبکر بن أبيشیبة تفردبہ ابن ماجہ،(تحفة الأشراف:۱۶۴۵۰)، وحدیث أبي سلمة أخرجہ: صحیح البخاری/الحیض ۲۷ (۳۲۸)، صحیح مسلم/الحج ۶۷ (۱۲۱۱)،(تحفة الأشراف:۱۷۷۶۸)وحدیث عروة أخرجہ: صحیح مسلم/الحج ۶۷ (۱۲۱۱)،(تحفة الأشراف:۱۶۵۸۷)، وقد أخرجہ: سنن ابی داود/المناسک ۸۵ (۲۰۰۳)، سنن الترمذی/الحیض ۹۹ (۳۹۱)، سنن النسائی/الحیض ۲۳ (۳۹۱)، موطا امام مالک/الحج ۷۵ (۲۲۵)، مسند احمد (۶/۳۸،۳۹،۸۲،۹۹،۱۲۲،۱۶۴،۱۷۵،۱۹۳،۲۰۲،۲۰۷،۲۱۳،۲۲۴)، سنن الدارمی/المناسک ۷۳ (۱۹۵۸),3072,,Chapters on Hajj Rituals
3073,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحج ۱۵۱ (۱۷۷۱)، صحیح مسلم/۱۷ (۱۲۱۱)،(تحفة الأشراف:۱۵۹۴۶)، وقد أخرجہ: مسند احمد (۶/۲۲۴، سنن الدارمی/المناسک ۷۳ (۱۹۵۸),3073,,Chapters on Hajj Rituals
3074,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِيل، ‏‏‏‏‏‏حَدَّثَنَا جَعْفَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۱۹ (۱۲۱۸)بلفظ: ''ابدا'' وھوالصواب، سنن ابی داود/الحج ۵۷ (۱۹۰۵،۱۹۰۹)،(تحفة الأشراف:۲۵۹۳)، وقد أخرجہ: سنن النسائی/الحج ۴۶ (۲۷۱۳)،۵۱ (۲۷۴۱)،۵۲ (۲۷۴۴)،۷۳ (۲۸۰۰)، مسند احمد (۳/۳۲۰،۳۳۱،۳۳۳،۳۴۰،۳۷۳،۳۸۸،۳۹۴،۳۹۷)، سنن الدارمی/المناسک ۱۱ (۱۸۴۶),3074,,Chapters on Hajj Rituals
3075,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ الْعَبْدِيُّ، ‏‏,Al-Albani: Hasan Isnaad; Muhammad Fouad Abd al-Baqi: Hasan Isnaad; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۷۶۸۴)، وقد أخرجہ:(۶/۱۴۱),3075,,Chapters on Hajj Rituals
3076,حَدَّثَنَا الْقَاسِمُ بْنُ مُحَمَّدِ بْنِ عَبَّادٍ الْمُهَلَّبِيُّ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: «حدیث جابر أخرجہ: سنن الترمذی/الحج ۶ (۸۱۵)،(تحفة الأشراف:۲۶۰۶)، وحدیث ابن عباس تفرد بہ ابن ماجہ، تحفة الأشراف:۶۴۸۵، ومصباح الزجاجة:۱۰۶۸),3076,,Chapters on Hajj Rituals
3077,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، ‏‏‏‏‏‏ وَابْنُ ع,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن ابی داود/الحج ۴۴ (۱۸۶۲،۱۸۶۳)، سنن الترمذی/الحج ۹۶ (۹۴۰)، سنن النسائی/الحج ۱۰۲ (۲۸۶۳)،(تحفة الأشراف:۳۲۹۴،۶۲۴۱،۱۴۲۵۴)، وقد أخرجہ: مسند احمد (۳/۴۵۰)، سنن الدارمی/المناسک ۵۷ (۱۹۳۶),3077,,Chapters on Hajj Rituals
3078,حَدَّثَنَا سَلَمَةُ بْنُ شَبِيبٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الرَّزَّاقِ، ‏‏‏‏‏‏أَنْبَأَنَا مَعْمَرٌ، ‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «انظر ما قبلہ،(تحفة الأشراف:۳۲۹۴،۶۲۴۱،۱۴۲۵۴),3078,,Chapters on Hajj Rituals
3079,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، ‏‏‏‏‏‏ وَمُحَمَّدُ بْنُ الْوَلِيدِ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَا,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/المحصر ۵ (۱۸۱۴)،۶ (۱۸۱۵)،۷ (۱۸۱۶)،۸ (۱۸۱۷)، المغازي ۳۵ (۴۱۵۹)، تفسیر البقرة ۳۲ (۴۵۱۷)، المرضیٰ ۱۶ (۵۶۶۵)، الطب ۱۶ (۵۷۰۳)، الکفارات ۱ (۶۸۰۸)، صحیح مسلم/الحج ۱۰ (۱۲۰۱)، سنن الترمذی/الحج ۱۰۷ (۹۵۳)،(تحفة الأشراف:۱۱۱۱۲)، وقد أخرجہ: سنن ابی داود/الحج ۴۳ (۱۸۵۶)، سنن النسائی/الحج ۹۶ (۲۸۵۴)، موطا امام مالک/الحج ۷۸ (۲۳۷)، مسند احمد (۴/۲۴۲،۲۴۳),3079,,Chapters on Hajj Rituals
3080,حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نَافِعٍ، ‏‏‏‏‏,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۱۱۸),3080,,Chapters on Hajj Rituals
3081,حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، ‏‏‏‏‏‏أَنْبَأَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏عَنْ يَزِي,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «صحیح البخاری/جزاء الصید ۱۱ (۱۸۳۵)، الصوم ۳۲ (۱۹۳۸)، الطب ۱۲ (۵۶۹۵)،۱۵ (۵۷۰۰)، صحیح مسلم/الحج ۱۱ (۱۲۰۲)، سنن ابی داود/الحج ۳۶ (۱۸۳۵)، سنن الترمذی/الحج ۲۲ (۸۳۹)، سنن النسائی/الحج ۹۲ (۲۸۴۹)،(تحفة الأشراف:۵۷۰۹)، وقد أخرجہ: مسند احمد (۱/۲۱۵،۲۲۱،۲۲۲،۲۳۶،۲۴۸،۲۴۹،۲۶۰،۲۸۳،۲۸۶،۲۹۲،۳۰۶،۳۱۵،۳۳۳،۳۴۶،۳۵۱،۳۷۲،۴،۳)، سنن الدارمی/المناسک ۲۰ (۱۸۶۰),3081,,Chapters on Hajj Rituals
3082,حَدَّثَنَا بَكْرُ بْنُ خَلَفٍ أَبُو بِشْرٍ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ أَبِي الضَّيْفِ، ‏‏‏‏‏‏ع,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۷۷۸، ومصباح الزجاجة:۱۰۶۹)، وقد أخرجہ: مسند احمد (۳/۳۵۷،۳۶۳),3082,,Chapters on Hajj Rituals
3083,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏حَدَّثَنَا حَمَّادُ بْنُ سَلَمَةَ,Al-Albani: Daif Isnaad; Muhammad Fouad Abd al-Baqi: Daif Isnaad; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/الحج ۱۱۴ (۹۶۲)،(تحفة الأشراف:۷۰۶۰)، وقد أخرجہ: مسند احمد (۲/۲۵،۲۹،۵۹،۷۲،۱۲۶،۱۴۵),3083,,Chapters on Hajj Rituals
3084,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ، ‏‏‏‏‏‏عَنْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الجنائز ۱۹ (۱۲۶۵)،۲۱ (۱۲۶۷)، جزاء الصید ۲۰ (۱۸۴۹)،۲۱ (۱۸۵۰)، صحیح مسلم/الحج ۱۴ (۱۲۰۶)، سنن ابی داود/الجنائز ۸۴ (۳۲۳۸،۳۲۳۹)، سنن الترمذی/الحج ۱۰۵ (۹۵۱)، سنن النسائی/الجنائز ۴۱ (۱۹۰۵)، الحج ۴۷ (۲۷۱۴)،۹۷ (۲۸۵۶)،۱۰۱ (۲۸۶۱)،(تحفة الأشراف:۵۵۸۲)، وقد أخرجہ: مسند احمد (۱/۲۱۵،۲۶۶،۲۸۶)، سنن الدارمی/المناسک ۳۵ (۱۸۹۴),3084,,Chapters on Hajj Rituals
3085,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏حَدَّثَنَا جَرِيرُ بْنُ حَازِمٍ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الأطعمة ۳۲ (۳۸۰۱)، سنن الترمذی/الحج ۲۸ (۸۵۱)، الاطعمة ۴ (۱۷۹۲)، سنن النسائی/الحج ۸۹ (۲۸۳۹)، الصید ۲۷ (۴۳۲۸)،(تحفة الأشراف:۲۳۸۱)، وقد أخرجہ: مسند احمد (۳/۲۹۷،۳۱۸،۳۲۲)، سنن الدارمی/المناسک ۹۰ (۱۹۸۴),3085,,Chapters on Hajj Rituals
3086,حَدَّثَنَا مُحَمَّدُ بْنُ مُوسَى الْقَطَّانُ الْوَاسِطِيُّ، ‏‏‏‏‏‏حَدَّثَنَا يَزِيدُ بْنُ مَوْهَبٍ،,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۴۸۳۵، ومصباح الزجاجة:۱۰۷۰),3086,,Chapters on Hajj Rituals
3087,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَمُحَمَّدُ بْنُ بَشَّارٍ، ‏‏‏‏‏‏ وَمُحَمَّدُ بْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۹ (۱۱۹۸)، سنن النسائی/الحج ۸۳ (۲۸۳۲)،۱۱۳ (۲۸۸۴)،۱۱۴ (۲۸۸۵)،(تحفة الأشراف:۱۶۱۲۲)، وقد أخرجہ: صحیح البخاری/جزاء الصید ۷ (۱۸۲۹)، بدأ الخلق ۱۶ (۳۳۱۴)، سنن الترمذی/الحج ۲۱ (۸۳۷)، مسند احمد (۶/۲۳،۸۷،۹۷،۱۱۲،۱۶۴،۲۰۳،۲۵۹،۲۶۱)، سنن الدارمی/المناسک ۱۹ (۱۸۵۸),3087,,Chapters on Hajj Rituals
3088,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، ‏‏‏‏‏‏عَنْ عُبَيْد,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۹ (۱۱۹۹)،(تحفة الأشراف:۷۹۴۶)، وقد أخرجہ: صحیح البخاری/جزاء الصید ۷ (۱۸۲۶)، بدء الخلق ۱۶ (۳۳۱۵)، سنن ابی داود/الحج ۴۰ (۱۸۴۶)، سنن النسائی/الحج ۸۸ (۲۸۳۸)، موطا امام مالک/الحج ۲۸ (۸۸)، حم۲/۸،۳۲،۳۷،۴۸،۵۰،۵۲،۵۴،۵۷،۶۵،۷۷، سنن الدارمی/المناسک ۱۹ (۱۸۵۷),3088,,Chapters on Hajj Rituals
3089,حَدَّثَنَا أَبُو كُرَيْبٍ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ فُضَيْلٍ، ‏‏‏‏‏‏عَنْ يَزِيدَ بْنِ أَبِي ز,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۱۳۳، ومصباح الزجاجة:۱۰۷۱)، وقد أخرجہ: سنن ابی داود/المناسک ۴۰ (۱۸۴۸)، سنن الترمذی/الحج ۲۱ (۸۳۸)، مسند احمد (۳/۳،۴۲،۷۹),3089,,Chapters on Hajj Rituals
3090,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَهِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/جزاء الصید ۶ (۱۸۲۵)، الھبة ۶ (۲۵۷۳)،۱۷ (۲۵۹۶)، صحیح مسلم/الحج ۸ (۱۱۹۳)، سنن الترمذی/الحج ۲۶ (۸۴۹)، سنن النسائی/الحج ۷۹ (۲۸۲۱)،(تحفة الأشراف:۴۹۴۰)، وقد أخرجہ: موطا امام مالک/الحج ۲۵ (۸۳)، مسند احمد (۴/۳۷،۳۸،۷۱،۷۳)، سنن الدارمی/المناسک ۲۲ (۱۸۷۲),3090,,Chapters on Hajj Rituals
3091,حَدَّثَنَا عُثْمَانُ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا عِمْرَانُ بْنُ مُحَمَّدِ بْنِ أَبِي لَيْل,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۱۹۹ (ألف)، ومصباح الزجاجة:۱۰۷۲)، وقد أخرجہ: مسند احمد (۱/۱۰۵),3091,,Chapters on Hajj Rituals
3092,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏عَنْ يَحْيَى بْن,Al-Albani: Isnaad Malool; Muhammad Fouad Abd al-Baqi: Isnaad Malool; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۰۰۶، ومصباح الزجاجة:۱۰۷۳),3092,,Chapters on Hajj Rituals
3093,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الرَّزَّاقِ، ‏‏‏‏‏‏أَنْبَأَنَا مَعْمَرٌ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/جزاء الصید ۲ (۱۸۲۱)،۵ (۱۸۲۴)، الھبة ۳ (۲۵۷۰)، الجہاد ۴۶ (۲۸۵۴)،۸۸ (۲۹۱۴)، الأطعمة ۱۹ (۴۱۴۹)، الذبائح ۱۰ (۵۴۹۰)،۱۱ (۵۴۹۱)، صحیح مسلم/الحج ۸ (۱۱۹۶)کلاھما دون قولہ: ''ولم یأکل منہ'' فإنہ عندھما أنہ أکل منہ، سنن النسائی/الحج ۷۸ (۲۸۱۸)،۸۰ (۲۸۲۸)،(تحفة الأشراف:۱۲۱۰۹)، وقد أخرجہ: سنن ابی داود/الحج ۴۱ (۱۸۵۲)، سنن الترمذی/الحج ۲۵ (۸۴۷)، موطا امام مالک/الحج ۲۴ (۷۶)، مسند احمد (۵/۳۰۰،۳۰۷)، سنن الدارمی/المناسک ۲۲ (۱۸۶۷),3093,,Chapters on Hajj Rituals
3094,حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، ‏‏‏‏‏‏أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، ‏‏‏‏‏‏عَنْ ابْنِ شِهَابٍ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحج ۱۰۶ (۱۶۹۶)،۱۱۱ (۱۷۰۱)، الوکالة ۱۴ (۲۳۱۷)، الأضاحي ۱۵ (۵۵۶۶)، صحیح مسلم/الحج ۶۴ (۱۳۲۱)، سنن ابی داود/الحج ۱۷ (۱۷۵۸)، سنن النسائی/الحج ۶۲ (۲۷۷۴)،۶۸ (۲۷۸۵)،(تحفة الأشراف:۱۶۵۸۲،۱۷۹۲۳)، وقد أخرجہ: سنن الترمذی/الحج ۶۹ (۸۰۸)، موطا امام مالک/الحج ۱۵ (۵۱)، مسند احمد (۶/۳۵،۳۶،۷۸،۸۲،۸۵،۹۱،۱۰۲،۱۲۷،۱۷۴،۱۸۰،۱۸۵،۱۹۰،۱۹۱،۲۰۰،۲۰۸،۲۱۳،۲۱۶،۲۱۸،۲۲۵،۲۳۶،۲۵۳،۱۲۷،۱۷۴،۱۸۰،۱۸۵،۱۹۰،۱۹۱،۲۰۰،۲۰۸،۲۱۳،۲۱۶،۲۱۸،۲۲۵،۲۳۶،۲۵۳،۲۶۲)، سنن الدارمی/المناسک ۶۷ (۱۹۵۲),3094,,Chapters on Hajj Rituals
3095,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو مُعَاوِيَةَ، ‏‏‏‏‏‏عَنْ الْأَعْم,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «أنظر ما قبلہ،(تحفة الأشراف:۱۵۹۴۷),3095,,Chapters on Hajj Rituals
3096,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحج ۱۰۶ (۱۷۰۱)، صحیح مسلم/الحج ۶۴ (۱۳۲۱)، سنن النسائی/الحج ۶۹ (۲۷۸۹)، سنن ابی داود/المناسک ۱۵ (۱۷۵۵)،(تحفة الأشراف:۱۵۹۴۴)، وقدأخرجہ: مسند احمد (۶/۴۱،۴۲،۲۰۸)،(یہ حدیث مکرر ہے، دیکھئے:۳۰۹۴),3096,,Chapters on Hajj Rituals
3097,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۳۲ (۱۲۴۳)، سنن ابی داود/الحج ۱۵ (۱۷۵۲)، سنن الترمذی/الحج ۶۷ (۹۰۶)، سنن النسائی/الحج ۶۴ (۲۷۷۲)،۶۷ (۲۷۸۱)،۷۰ (۲۷۹۳)،(تحفة الأشراف:۶۴۵۹)، وقد أخرجہ: صحیح البخاری/الحج ۲۳ (۱۵۴۹)، مسند احمد (۱/۲۱۶،۲۵۴،۲۸۰،۳۳۹،۳۴۴،۳۴۷،۳۷۲)، سنن الدارمی/المناسک ۶۸ (۱۹۵۳),3097,,Chapters on Hajj Rituals
3098,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ، ‏‏‏‏‏‏عَنْ أَفْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/ الحج ۱۰۶ (۱۶۹۶)،۱۰۸ (۱۶۹۹)، صحیح مسلم/الحج ۶۴ (۱۳۲۱)، سنن ابی داود/المناسک ۱۷ (۱۷۵۷)، سنن النسائی/الحج ۶۲ (۲۷۷۴)،(تحفة الأشراف:۱۷۴۳۳)، وقد أخرجہ: موطا امام مالک/الحج ۱۵ (۵۱)، مسند احمد (۶/۲۵،۳۶،۷۸،۸۵،۱۹۱،۱۰۲،۱۲۷،۱۷۴،۱۸۰،۱۸۵،۱۹۱،۲۰۰),3098,,Chapters on Hajj Rituals
3099,حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، ‏‏‏‏‏‏أَنْبَأَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏عَنْ عَبْد,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحج ۱۱۳ (۱۷۰۷)،۱۲۰ (۱۷۱۶)،۱۲۱ (۱۷۱۷)، صحیح مسلم/الحج ۶۱ (۱۳۱۷)، سنن ابی داود/الحج ۲۰ (۱۷۶۹)،(تحفة الأشراف:۱۰۲۱۹)، وقد أخرجہ: مسند احمد (۱/۲۹،۱۲۳،۱۳۲،۱۴۳،۱۵۴،۱۵۹)، سنن الدارمی/المناسک ۸۹ (۱۹۸۳),3099,,Chapters on Hajj Rituals
3100,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۴۸۱)، وقد أخرجہ: مسند احمد (۱/۲۳۴،۲۶۹),3100,,Chapters on Hajj Rituals
3101,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ مُوسَى، ‏‏‏‏‏‏أَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih Lighairihi; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۵۳۰، ومصباح الزجاجة:۱۰۷۴),3101,,Chapters on Hajj Rituals
3102,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، ‏‏‏‏‏‏حَدَّثَنَا يَحْيَى بْنُ يَمَانٍ، ‏‏‏‏‏,Al-Albani: Daif Isnaad; Muhammad Fouad Abd al-Baqi: Daif Isnaad; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/الحج ۶۸ (۹۰۷)،(تحفة الأشراف:۷۸۹۷),3102,,Chapters on Hajj Rituals
3103,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏عَنْ سُفْيَانَ الثَّوْر,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۳۶۶۹)، وقد أخرجہ: صحیح البخاری/الحج ۱۰۳ (۱۶۸۹)،۱۱۲ (۱۷۰۶)، الوصایا ۱۲ (۲۷۵۵)، الأدب ۹۵ (۶۱۶۰)، صحیح مسلم/الحج ۶۵ (۱۳۲۲)، سنن ابی داود/الحج ۱۸ (۱۷۶۰)، سنن النسائی/الحج ۷۴ (۲۸۰۱)، موطا امام مالک/الحج ۴۵ (۱۳۹)، مسند احمد (۲/۲۵۴،۲۷۸،۳۱۲،۴۶۴،۴۷۴،۴۷۸،۴۸۱),3103,,Chapters on Hajj Rituals
3104,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏عَنْ هِشَامٍ، ‏‏‏‏‏‏صَاحِبِ الدَّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الحج ۱۰۳ (۱۶۹۰)، الوصایا ۱۲ (۲۷۵۵)، الأدب ۹۵ (۶۱۶۰)،(تحفة الأشراف:۱۳۶۶)، وقد أخرجہ: صحیح مسلم/الحج ۶۵ (۱۳۲۲)، سنن ابی داود/الحج ۱۸ (۱۷۶۰)، سنن النسائی/الحج ۷۴ (۲۸۰۱)، مسند احمد (۳/۹۹،۱۷۰،۱۷۳،۲۲۰)، سنن الدارمی/المناسک ۶۹ (۱۹۵۴),3104,,Chapters on Hajj Rituals
3105,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ الْعَبْدِيُّ، ‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۶۶ (۱۳۲۶)،(تحفة الأشراف:۳۵۴۴)، وقد أخرجہ: مسند احمد (۴/۲۲۵),3105,,Chapters on Hajj Rituals
3106,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏وَ عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏وَ عَمْرُو بْنُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن ابی داود/الحج ۱۹ (۱۷۶۲)، سنن الترمذی/الحج ۷۱ (۹۱۰)،(تحفة الأشراف:۱۱۵۸۱)، وقد أخرجہ: موطا امام مالک/الحج ۴۷ (۱۴۸)، مسند احمد (۴/۳۳۳)، سنن الدارمی/المناسک ۶۶ (۱۹۵۰),3106,,Chapters on Hajj Rituals
3107,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا عِيسَى بْنُ يُونُسَ، ‏‏‏‏‏‏عَنْ عُمَرَ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۰۱۸، ومصباح الزجاجة:۱۰۷۵),3107,,Chapters on Hajj Rituals
3108,حَدَّثَنَا عِيسَى بْنُ حَمَّادٍ الْمِصْرِيُّ، ‏‏‏‏‏‏أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، ‏‏‏‏‏‏أَخْبَر,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن الترمذی/المناقب ۶۹ (۳۹۲۵)،(تحفة الأشراف:۶۶۴۱)، وقد أخرجہ: مسند احمد (۴/۳۰۵)، سنن الدارمی/السیر ۶۷ (۲۵۵۲),3108,,Chapters on Hajj Rituals
3109,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، ‏‏‏‏‏‏حَدَّثَنَا يُونُسُ بْنُ بُكَيْرٍ، ‏‏‏‏,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۵۹۰۸، ومصباح الزجاجة:۱۰۷۶)، وقد أخرجہ: صحیح البخاری/الجنائز ۷۶ (۱۳۴۹ تعلیقاً),3109,,Chapters on Hajj Rituals
3110,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ، ‏‏‏‏‏‏ وَابْنُ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۰۱۲، ومصباح الزجاجة:۱۰۷۷)، وقد أخرجہ: مسند احمد (۴/۳۴۷),3110,,Chapters on Hajj Rituals
3111,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، ‏‏‏‏‏‏ و,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحج۶ (۱۸۷۶)، صحیح مسلم/الإیمان ۶۵ (۱۴۷)،(تحفة الأشراف:۱۲۲۶۶)، وقد أخرجہ: مسند احمد (۲/۲۸۶،۴۲۲،۴۹۶),3111,,Chapters on Hajj Rituals
3112,حَدَّثَنَا بَكْرُ بْنُ خَلَفٍ، ‏‏‏‏‏‏حَدَّثَنَا مُعَاذُ بْنُ هِشَامٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبِي، ‏‏‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن الترمذی/المناقب ۶۸ (۳۹۱۷)،(تحفة الأشراف:۷۵۵۳)، وقد أخرجہ: مسند احمد (۲/۷۴،۱۰۴),3112,,Chapters on Hajj Rituals
3113,حَدَّثَنَا أَبُو مَرْوَانَ مُحَمَّدُ بْنُ عُثْمَانَ الْعُثْمَانِيُّ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْعَزِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۴۰۴۰، ومصباح الزجاجة:۱۰۷۸)، وقد أخرجہ: صحیح مسلم/الحج ۸۵ (۱۳۷۲)، سنن الترمذی/الدعوات ۵۴ (۳۴۵۴)، موطا امام مالک/الجامع ۱ (۲),3113,,Chapters on Hajj Rituals
3114,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدَةُ بْنُ سُلَيْمَانَ، ‏‏‏‏‏‏عَنْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۵۰۶۸)، وقد أخرجہ: صحیح مسلم/الحج ۸۹ (۱۳۸۶)، مسند احمد (۲/۲۷۹،۳۰۹،۳۵۷),3114,,Chapters on Hajj Rituals
3115,حَدَّثَنَا هَنَّادُ بْنُ السَّرِيِّ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدَةُ، ‏‏‏‏‏‏عَنْ مُحَمَّدِ بْنِ إِسْحَاق،,Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۷۷، ومصباح الزجاجة:۱۰۷۹),3115,,Chapters on Hajj Rituals
3116,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا الْمُحَارِبِيُّ، ‏‏‏‏‏‏عَنْ الشَّيْبَا,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Daif,takhreej: «صحیح البخاری/الحج ۴۸ (۱۵۹۴)، الاعتصام ۲ (۷۲۷۵)، سنن ابی داود/المناسک ۹۶ (۲۰۳۱)،(تحفة الأشراف:۴۸۴۹)، وقد أخرجہ: مسند احمد (۳/۴۱۰),3116,,Chapters on Hajj Rituals
3117,حَدَّثَنَا مُحَمَّدُ بْنُ أَبِي عُمَرَ الْعَدَنِيُّ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ زَيْدٍ,Al-Albani: Mawdu; Muhammad Fouad Abd al-Baqi: Mawdu; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۵۰۸، ومصباح الزجاجة:۱۰۸۰),3117,,Chapters on Hajj Rituals
3118,حَدَّثَنَا مُحَمَّدُ بْنُ أَبِي عُمَرَ الْعَدَنِيُّ، ‏‏‏‏‏‏حَدَّثَنَا دَاوُدُ بْنُ عَجْلَانَ، ‏‏‏‏‏‏,Al-Albani: Very Daif Isnaad; Muhammad Fouad Abd al-Baqi: Very Daif Isnaad; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۷۲۴، ومصباح الزجاجة:۱۰۸۱),3118,,Chapters on Hajj Rituals
3119,حَدَّثَنَا إِسْمَاعِيل بْنُ حَفْصٍ الْأُبُلِّيُّ، ‏‏‏‏‏‏حَدَّثَنَا يَحْيَى بْنُ يَمَانٍ، ‏‏‏‏‏‏عَنْ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۰۸۹، ومصباح الزجاجة:۱۰۸۲),3119,,Chapters on Hajj Rituals
