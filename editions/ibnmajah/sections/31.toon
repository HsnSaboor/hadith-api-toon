3490,حَدَّثَنَا عَمْرُو بْنُ رَافِعٍ،‏‏‏‏ حَدَّثَنَا هُشَيْمٌ،‏‏‏‏ عَنْ مَنْصُورٍ،‏‏‏‏ وَيُونُسُ،‏‏‏‏ عَن,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۸۰۹،۱۰۸۱۴)، وقد أخرجہ: سنن ابی داود/الطب ۷ (۳۸۶۵)، سنن الترمذی/الطب ۱۰ (۲۰۴۹)، مسند احمد (۴/۴۲۷،۴۴۴،۴۴۶),3490,,Chapters on Medicine
3491,حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ،‏‏‏‏ حَدَّثَنَا مَرْوَانُ بْنُ شُجَاعٍ،‏‏‏‏ حَدَّثَنَا سَالِمٌ الْأ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الطب ۳ (۵۶۸۰،۵۶۸۱)،(تحفة الأشراف:۵۵۰۹),3491,,Chapters on Medicine
3492,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ وَمُحَمَّدُ بْنُ بَشَّارٍ،‏‏‏‏ قَالَا:‏‏‏‏ حَدَّثَن,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۸۲۱، ومصباح الزجاجة:۱۲۱۷)، وقد أخرجہ: موطا امام مالک/العین ۵ (۱۳),3492,,Chapters on Medicine
3493,حَدَّثَنَا عَمْرُو بْنُ رَافِعٍ،‏‏‏‏ حَدَّثَنَا مُحَمَّدُ بْنُ عُبَيْدٍ الطَّنَافِسِيُّ،‏‏‏‏ عَنْ ال,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/السلام ۲۶ (۲۲۰۷)، سنن ابی داود/الطب ۶ (۳۸۶۴)،(تحفة الأشراف:۲۲۹۶)، وقد أخرجہ: مسند احمد (۳/۳۰۳،۳۰۴،۳۱۵،۳۷۱),3493,,Chapters on Medicine
3494,حَدَّثَنَا عَلِيُّ بْنُ أَبِي الْخَصِيبِ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ سُفْيَانَ،‏‏‏‏ عَنْ أَبِي,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «تفرد ابن ماجہ،(تحفة الأشراف:۲۷۶۲، ومصباح الزجاجة:۱۲۱۸)، وقد أخرجہ: صحیح مسلم/السلام ۲۶ (۲۲۰۸)، سنن ابی داود/الطب ۷ (۳۸۶۶)، سنن الترمذی/السیر ۲۹ (۱۵۸۲)، مسند احمد (۳/۳۶۳)، سنن الدارمی/السیر ۶۶ (۲۵۵۱),3494,,Chapters on Medicine
3495,حَدَّثَنَا أَبُو سَلَمَةَ يَحْيَى بْنُ خَلَفٍ،‏‏‏‏ حَدَّثَنَا أَبُو عَاصِمٍ،‏‏‏‏ حَدَّثَنِي عُثْمَان,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Lighairihi; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۷۷۱، ومصباح الزجاجة:۱۲۱۹),3495,,Chapters on Medicine
3496,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ سُلَيْمَانَ،‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۰۰۸، ومصباح الزجاجة:۱۲۲۰),3496,,Chapters on Medicine
3497,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا يَحْيَى بْنُ آدَمَ،‏‏‏‏ عَنْ سُفْيَانَ،‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Hasan,takhreej: «سنن الترمذی/ الجنائز ۱۸ (۹۹۴)، الشمائل ۵۱، سنن ابی داود/الطب ۱۴ (۳۸۷۸)، سنن النسائی/الزینة ۲۸ (۵۱۱۶)،(تحفة الأشراف:۵۵۳۵)، وقد أخرجہ: مسند احمد (۱/۲۳۱،۲۴۷،۲۷۴،۳۲۸،۳۵۵،۶۳ ۳),3497,,Chapters on Medicine
3498,حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ عُمَرَ،‏‏‏‏ حَدَّثَنَا عَبْدُ الْمَلِكِ بْنُ الصَّبَّاحِ،‏‏‏‏ عَن,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Sanad Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الطہارة ۲۳ (۳۵)،(تحفة الأشراف:۱۴۹۳۸)، وقد أخرجہ: موطا امام مالک/الطہارة ۱ (۲)، مسند احمد (۲/۳۷۱، سنن الدارمی/الطہارة ۵ (۶۸۹),3498,,Chapters on Medicine
3499,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ،‏‏‏‏ عَنْ عَبَّادِ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/اللباس ۲۳ (۱۷۵۷)، الطب ۹ (۲۰۴۸)،(تحفة الأشراف:۶۱۳۷)، وقد أخرجہ: مسند احمد (۱/۳۵۴),3499,,Chapters on Medicine
3500,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَفَّانُ،‏‏‏‏ حَدَّثَنَا حَمَّادُ بْنُ س,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الطب ۱۱ (۳۸۷۳)،(تحفة الأشراف:۴۹۸۰)، وقد أخرجہ: مسند احمد (۴/۳۱۱،۵/۲۹۳),3500,,Chapters on Medicine
3501,حَدَّثَنَا مُحَمَّدُ بْنُ عُبَيْدِ بْنِ عُتْبَةَ بْنِ عَبْدِ الرَّحْمَنِ الْكِنْدِيُّ،‏‏‏‏ حَدَّثَنَ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۰۵۶، ومصباح الزجاجة:۱۲۲۱),3501,,Chapters on Medicine
3502,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا زَيْدُ بْنُ الْحُبَابِ،‏‏‏‏ حَدَّثَنَا ف,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الطب ۳ (۳۸۵۸)، سنن الترمذی/الطب ۱۳ (۲۰۵۴)،(تحفة الأشراف:۱۵۸۹۳)، وقد أخرجہ: مسند احمد (۶/۴۶۲),3502,,Chapters on Medicine
3503,حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ،‏‏‏‏ حَدَّثَنَا عَبْدُ الْوَهَّابِ،‏‏‏‏ حَدَّثَنَا حُم,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «صحیح البخاری/الوضوء ۶۷ (۲۳۷)، الزکاة ۶۸ (۱۵۰۱)، الجہاد ۱۵۲ (۳۰۱۸)، المغازي ۳۷ (۴۱۹۲،۴۱۹۳)، الطب ۵ (۵۶۸۵)،۶ (۵۶۸۶)،۲۹ (۵۷۲۷)، الحدود ۱ (۶۸۰۲)،۲ (۶۸۰۳)،۳ (۶۸۰۴)،۴ (۶۸۰۵)، الدیات ۲۲ (۶۸۹۹)، صحیح مسلم/القسامة ۲ (۱۶۷۱)، سنن الترمذی/الحدود ۳ (۴۳۶۴)، الأطعمة ۳۸ (۱۸۴۵)، الطب ۶ (۲۰۴۲)، سنن النسائی/الطہارة ۱۹۱ (۳۰۶)،(تحفة الأشراف:۷۲۸)، وقد أخرجہ: مسند احمد (۳/۱۶۱،۱۶۳،۱۷۰،۲۳۳),3503,,Chapters on Medicine
3504,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ،‏‏‏‏ عَنْ ابْنِ أَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن النسائی/الفرع والعتیرة ۱۰ (۴۲۶۷)،(تحفة الأشراف:۴۴۲۶، ومصباح الزجاجة:۱۲۲۲)، وقد أخرجہ: مسند احمد (۳/۲۴،۶۷),3504,,Chapters on Medicine
3505,حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ،‏‏‏‏ حَدَّثَنَا مُسْلِمُ بْنُ خَالِدٍ،‏‏‏‏ عَنْ عُتْبَةَ بْنِ مُسْل,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/بدء الخلق ۱۷ (۳۳۲۰)، الطب ۵۸ (۵۷۸۲)، سنن ابی داود/الأطعمة ۴۹ (۳۸۴۴)،(تحفة الأشراف:۱۴۱۲۶)، وقد أخرجہ: مسند احمد (۲/۲۲۹،۲۴۶،۴۴۳)، سنن الدارمی/الأطعمة ۱۲ (۲۰۸۱),3505,,Chapters on Medicine
3506,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ،‏‏‏‏ حَدَّثَنَا مُعَاوِيَةُ بْنُ هِشَامٍ،‏‏‏‏,Al-Albani: Sahih Mutawatir; Muhammad Fouad Abd al-Baqi: Sahih Mutawatir; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۰۳۷، ومصباح الزجاجة:۱۲۲۳)، وقد أخرجہ: مسند احمد (۱/۲۷۴،۲۹۴،۲/۲۲۲،۲۸۹،۳۱۹،۳/۴۴۷),3506,,Chapters on Medicine
3507,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا إِسْمَاعِيل بْنُ عُلَيَّةَ،‏‏‏‏ عَنْ الْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۴۶۱۳)، وقد أخرجہ: صحیح البخاری/الطب ۳۶ (۵۷۴۰)، صحیح مسلم/السلام ۱۶ (۲۱۸۷)، سنن ابی داود/الطب ۱۵ (۳۸۷۹)، مسند احمد (۲/۳۱۹),3507,,Chapters on Medicine
3508,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ،‏‏‏‏ حَدَّثَنَا أَبُو هِشَامٍ الْمَخْزُومِيُّ،‏‏‏‏ حَدَّثَنَا وُه,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۷۷۲۵، ومصباح الزجاجة:۱۲۲۴),3508,,Chapters on Medicine
3509,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ،‏‏‏‏ حَدَّثَنَا سُفْيَانُ،‏‏‏‏ عَنْ الزُّهْرِيِّ،‏‏‏‏ عَنْ أَبِي أُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۳۶، ومصباح الزجاجة:۱۲۲۵)، وقد أخرجہ: موطا امام مالک/العین ۱ (۱)مسند احمد (۳/۴۸۶),3509,,Chapters on Medicine
3510,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ،‏‏‏‏ عَنْ عَمْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: سنن الترمذی/الطب ۱۷ (۲۰۵۹)،(تحفة الأشراف:۱۵۷۵۸)، وقد أخرجہ: مسند احمد (۶/۴۳۸),3510,,Chapters on Medicine
3511,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا سَعِيدُ بْنُ سُلَيْمَانَ،‏‏‏‏ عَنْ عَبَّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/الطب ۱۶ (۲۰۵۸)، سنن النسائی/الإستعاذة ۳۶ (۵۴۹۶)،(تحفة الأشراف:۴۳۲۷),3511,,Chapters on Medicine
3512,حَدَّثَنَا عَلِيُّ بْنُ أَبِي الْخَصِيبِ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ سُفْيَانَ،‏‏‏‏ وَمِسْعَرٍ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الطب ۳۵ (۵۷۳۸)، صحیح مسلم/السلام ۲۱ (۲۱۹۵)،(تحفة الأشراف:۱۶۱۹۹)، وقد أخرجہ: مسند احمد (۶/۶۳،۱۳۸),3512,,Chapters on Medicine
3513,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ،‏‏‏‏ حَدَّثَنَا إِسْحَاق بْنُ سُلَيْمَانَ،‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الإیمان ۹۴ (۲۲۰)،(تحفة الأشراف:۱۹۴۵),3513,,Chapters on Medicine
3514,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ إِدْرِيسَ،‏‏‏‏ عَنْ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۵۸۲۳، ومصباح الزجاجة:۱۲۲۶),3514,,Chapters on Medicine
3515,حَدَّثَنَا عَلِيُّ بْنُ أَبِي الْخَصِيبِ،‏‏‏‏ حَدَّثَنَا يَحْيَى بْنُ عِيسَى،‏‏‏‏ عَنْ الْأَعْمَشِ،‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/السلام ۲۱ (۲۱۹۹)،(تحفة الأشراف:۲۳۰۷)، وقد أخرجہ: مسند احمد (۳/۳۰۲،۳۱۵),3515,,Chapters on Medicine
3516,حَدَّثَنَا عَبْدَةُ بْنُ عَبْدِ اللَّهِ،‏‏‏‏ حَدَّثَنَا مُعَاوِيَةُ بْنُ هِشَامٍ،‏‏‏‏ حَدَّثَنَا سُف,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/السلام ۲۱ (۲۱۹۶)، سنن الترمذی/الطب ۱۵ (۲۰۵۶،۲۰۵۷)،(تحفة الأشراف:۱۷۰۹)، وقد أخرجہ: مسند احمد (۳/۱۱۸،۱۱۹،۱۲۷),3516,,Chapters on Medicine
3517,حَدَّثَنَا عُثْمَانُ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ وَهَنَّادُ بْنُ السَّرِيِّ،‏‏‏‏ قَالَا:‏‏‏‏ حَدَّثَنَا,Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/السلام ۲۱ (۲۱۹۳)،(تحفة الأشراف:۱۵۹۷۷)، وقد أخرجہ: صحیح البخاری/الطب ۳۷ (۵۷۴۱)، مسند احمد (۶/۳۰),3517,,Chapters on Medicine
3518,حَدَّثَنَا إِسْمَاعِيل بْنُ بَهْرَامَ،‏‏‏‏ حَدَّثَنَا عُبَيْدُ اللَّهِ الْأَشْجَعِيُّ،‏‏‏‏ عَنْ سُفْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۶۶۳، ومصباح الزجاجة:۱۲۲۷)، وقد أخرجہ: سنن ابی داود/الطب ۱۹ (۳۸۹۹)، مسند احمد (۲/۳۷۵),3518,,Chapters on Medicine
3519,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَفَّانُ،‏‏‏‏ حَدَّثَنَا عَبْدُ الْوَاحِ,Al-Albani: Daif Isnaad; Muhammad Fouad Abd al-Baqi: Daif Isnaad; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۷۲۹، ومصباح الزجاجة:۱۲۲۸),3519,,Chapters on Medicine
3520,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا جَرِيرٌ،‏‏‏‏ عَنْ مَنْصُورٍ،‏‏‏‏ عَنْ أَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «صحیح البخاری/المغازي ۸۴ (۴۴۳۷)، المرضی ۱۹ (۵۶۷۵)، صحیح مسلم/السلام ۱۹ (۲۱۹۱)، سنن الترمذی/الدعوات ۷۷ (۳۴۹۶)،(تحفة الأشراف:۱۷۶۳۸)، وقد أخرجہ: موطا امام مالک/الجنائز ۱۵ (۴۶),3520,,Chapters on Medicine
3521,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا سُفْيَانُ،‏‏‏‏ عَنْ عَبْدِ رَبِّهِ،‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الطب ۳۸ (۵۷۴۵،۵۷۴۶)، صحیح مسلم/السلام ۲۱ (۲۱۹۴)، سنن ابی داود/الطب ۱۹ (۳۸۹۵)،(تحفة الأشراف:۱۷۹۰۶)، وقد أخرجہ: مسند احمد (۶/۹۳),3521,,Chapters on Medicine
3522,حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا يَحْيَى بْنُ أَبِي بُكَيْرٍ،‏‏‏‏ حَدَّثَنَا زُهَيْرُ بْنُ مُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/السلام ۲۴ (۲۲۰۲)، سنن ابی داود/الطب ۱۹ (۳۸۹۱)، سنن الترمذی/الطب ۲۹ (۲۰۸۰)،(تحفة الأشراف:۹۷۷۴)، وقد أخرجہ: موطا امام مالک/العین ۴ (۹)، مسند احمد (۴/۲۱،۲۱۷),3522,,Chapters on Medicine
3523,حَدَّثَنَا بِشْرُ بْنُ هِلَالٍ الصَّوَّافُ،‏‏‏‏ حَدَّثَنَا عَبْدُ الْوَارِثِ،‏‏‏‏ عَنْ عَبْدِ الْعَز,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/السلام ۱۶ (۲۱۸۶)، سنن الترمذی/الجنائز۴ (۹۷۲)،(تحفة الأشراف:۴۳۶۳)، وقد أخرجہ: مسند احمد (۳/۲۸،۵۶،۵۸،۷۵),3523,,Chapters on Medicine
3524,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ،‏‏‏‏ وَحَفْصُ بْنُ عُمَرَ،‏‏‏‏ قَالَا:‏‏‏‏ حَدَّثَنَا عَبْدُ الرّ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۹۰۱، ومصباح الزجاجة:۱۲۲۹)، وقد أخرجہ: مسند احمد (۲/۴۴۶),3524,,Chapters on Medicine
3525,حَدَّثَنَا مُحَمَّدُ بْنُ سُلَيْمَانَ بْنِ هِشَامٍ الْبَغْدَادِيُّ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ . ح وحَدّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الأنبیاء ۱۰ (۳۳۷۱)، سنن ابی داود/السنة ۲۲ (۴۷۳۷)، سنن الترمذی/الطب ۱۸ (۲۰۶۰)،(تحفة الأشراف:۵۶۲۷)، وقد أخرجہ: مسند احمد (۱/۲۳۶،۲۷۰),3525,,Chapters on Medicine
3526,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ،‏‏‏‏ حَدَّثَنَا أَبُو عَامِرٍ،‏‏‏‏ حَدَّثَنَا إِبْرَاهِيمُ الْأَش,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/الطب ۲۶ (۲۰۷۵)،(تحفة الأشراف:۶۰۷۶)، وقد أخرجہ: مسند احمد (۳۰۰۱),3526,,Chapters on Medicine
3527,حَدَّثَنَا عَمْرُو بْنُ عُثْمَانَ بْنِ سَعِيدِ بْنِ كَثِيرِ بْنِ دِينَارٍ الْحِمْصِيُّ،‏‏‏‏ حَدَّثَن,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۰۸۱، ومصباح الزجاجة:۱۲۳۰)، وقد أخرجہ: مسند احمد (۵/۳۲۳),3527,,Chapters on Medicine
3528,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَة،‏‏‏‏ وَعَلِيُّ بْنُ مَيْمُونٍ الرَّقِّيُّ،‏‏‏‏ وَسَهْلُ ب,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۶۶۰۳),3528,,Chapters on Medicine
3529,حَدَّثَنَا سَهْلُ بْنُ أَبِي سَهْلٍ،‏‏‏‏ قَالَ:‏‏‏‏ حَدَّثَنَا مَعْنُ بْنُ عِيسَى . ح وحَدَّثَنَا مُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/فصل القرآن ۱۴ (۵۰۱۶)، صحیح مسلم/السلام ۲۰ (۲۱۹۲)، سنن ابی داود/الطب ۱۹ (۳۹۰۲)،(تحفة الأشراف:۱۶۵۸۹)، وقد أخرجہ: موطا امام مالک/العین ۴ (۱۰)، مسند احمد (۶/۱۰۴،۱۸۱،۲۵۶،۲۶۳),3529,,Chapters on Medicine
3530,حَدَّثَنَا أَيُّوبُ بْنُ مُحَمَّدٍ الرَّقِّيُّ،‏‏‏‏ حَدَّثَنَا مُعَمَّرُ بْنُ سُلَيْمَانَ،‏‏‏‏ حَدَّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۶۴۳، مصباح الزجاجة:۱۲۳۱)، وقد أخرجہ: سنن ابی داود/الطب ۱۷ (۳۸۸۳)، وقد أخرجہ: مسند احمد (۱/۳۸۱),3530,,Chapters on Medicine
3531,حَدَّثَنَا عَلِيُّ بْنُ أَبِي الْخَصِيبِ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ مُبَارَكٍ،‏‏‏‏ عَنْ الْحَ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۸۰۷، ومصباح الزجاجة:۱۲۳۲)، وقد أخرجہ: مسند احمد (۴/۴۴۵,3531,,Chapters on Medicine
3532,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ سُلَيْمَانَ،‏‏‏‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «انظر حدیث رقم:(۳۰۳۱),3532,,Chapters on Medicine
3533,حَدَّثَنَا مُحَمَّدُ بْنُ عُبَيْدِ بْنِ عَبْدِ الرَّحْمَنِ الْكِنْدِيُّ قَالَ: حَدَّثَنَا عَلِيُّ بْ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۰۵۶),3533,,Chapters on Medicine
3534,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَبْدَةُ بْنُ سُلَيْمَانَ،‏‏‏‏ عَنْ هِشَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/السلام ۳۷ (۲۲۳۲)،(تحفة الأشراف:۱۷۰۶۸)، وقد أخرجہ: صحیح البخاری/بدء الخلق ۱۵ (۳۳۰۸),3534,,Chapters on Medicine
3535,حَدَّثَنَا أَحْمَدُ بْنُ عَمْرِو بْنِ السَّرْحِ،‏‏‏‏ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ،‏‏‏‏ أَخْ,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/بدء الخلق ۱۴ (۳۲۹۷ تعلیقاً)، صحیح مسلم/السلام ۳۷ (۲۲۳۳)،(تحفة الأشراف:۶۹۸۵)، وقد أخرجہ: سنن ابی داود/الأدب ۱۷۴ (۵۲۵۲)، موطا امام مالک/الإستئذان ۱۲ (۳۷)، مسند احمد (۳/۴۳۰،۴۵۲،۴۵۳),3535,,Chapters on Medicine
3536,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ،‏‏‏‏ حَدَّثَنَا عَبْدَةُ بْنُ سُلَيْمَانَ،‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۵۰۶۹)، وقد أخرجہ: صحیح البخاری/الطب ۴۳ (۵۷۵۴)،۴۴ (۵۷۵۵)، صحیح مسلم/السلام ۳۳ (۲۲۲۰),3536,,Chapters on Medicine
3537,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ،‏‏‏‏ أَنْبَأَنَا شُعْبَ,Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الطب ۴۵ (۵۷۷۶)، صحیح مسلم/السلام ۳۴ (۲۲۲۴)،(تحفة الأشراف:۱۲۵۹)، وقد أخرجہ: سنن ابی داود/الطب ۲۴ (۳۹۱۶)، سنن الترمذی/السیر ۴۷ (۱۶۱۵)، مسند احمد (۳/۱۱۸،۱۵۴،۱۳۰،۱۷۸،۲۵۱،۱۷۳،۲۷۵),3537,,Chapters on Medicine
3538,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ سُفْيَانَ،‏‏‏‏ عَنْ سَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الطب ۲۴ (۳۹۱۰)، سنن الترمذی/السیر ۴۷ (۱۶۱۴)، تحفة الأشراف (۹۲۰۷)، وقد أخرجہ: مسند احمد (۱/۳۸۹،۴۳۸،۴۴۰),3538,,Chapters on Medicine
3539,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا أَبُو الْأَحْوَصِ،‏‏‏‏ عَنْ سِمَاكٍ،‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۱۲۶، ومصباح الزجاجة:۱۲۳۴)، وقد أخرجہ: مسند احمد (۱/۲۶۹،۳۲۸),3539,,Chapters on Medicine
3540,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ أَبِي جَنَابٍ،‏‏‏‏ عَن,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «انظر حدیث رقم:(۸۶)،(تحفة الأشراف:۸۵۸۰، ومصباح الزجاجة:۱۲۳۵),3540,,Chapters on Medicine
3541,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ،‏‏‏‏ عَنْ مُحَمَّد,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۵۰۷۵)، وقد أخرجہ: صحیح مسلم/السلام ۳۳ (۲۲۲۱،۲۲۲۳)، سنن ابی داود/الطب ۲۴ (۳۹۱۱)، مسند احمد (۲/۴۳۴),3541,,Chapters on Medicine
3542,حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ وَمُجَاهِدُ بْنُ مُوسَى،‏‏‏‏ ومحمد بن خلف العسقلاني،‏‏‏‏ قَالُوا:‏‏‏‏ ح,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: سنن ابی داود/الطب ۲۴ (۳۹۲۵)، سنن الترمذی/الأطعمة ۱۹ (۱۸۱۷)،(تحفة الأشراف:۳۰۱۰),3542,,Chapters on Medicine
3543,حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ،‏‏‏‏ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نَافِعٍ،‏‏‏‏ عَن,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۵۷۵، ومصباح الزجاجة:۱۲۳۶)، وقد أخرجہ: مسند احمد (۱/۲۳۳،۲۹۹),3543,,Chapters on Medicine
3544,حَدَّثَنَا عَمْرُو بْنُ رَافِعٍ،‏‏‏‏ حَدَّثَنَا هُشَيْمٌ،‏‏‏‏ عَنْ يَعْلَى بْنِ عَطَاءٍ،‏‏‏‏ عَنْ رَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/السلام ۳۶ (۲۲۳۱)، سنن النسائی/البیعة ۱۹ (۴۱۸۷)،(تحفة الأشراف:۴۸۳۷)، وقد أخرجہ: مسند احمد (۴/۳۸۹،۳۹۰),3544,,Chapters on Medicine
3545,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ،‏‏‏‏ عَنْ ه,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/السلام ۱۷ (۲۱۸۹)،(تحفة الأشراف:۱۶۹۸۵)، وقد أخرجہ: صحیح البخاری/الجزیة ۱۴ (۳۱۷۵)، الطب ۵۰ (۵۷۶۶)، مسند احمد (۶/۵۷),3545,,Chapters on Medicine
3546,حَدَّثَنَا يَحْيَى بْنُ عُثْمَانَ بْنِ سَعِيدِ بْنِ كَثِيرِ بْنِ دِينَارٍ الْحِمْصِيُّ،‏‏‏‏ حَدَّثَن,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۴۴۳،۸۵۳۲، ومصباح الزجاجة:۱۲۳۷),3546,,Chapters on Medicine
3547,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَفَّانُ،‏‏‏‏ حَدَّثَنَا وَهْيبٌ،‏‏‏‏ قَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «صحیح مسلم/الذکر والدعاء ۱۶ (۲۷۰۸)، سنن الترمذی/الدعوات ۴۱ (۳۴۳۷)،(تحفة الأشراف:۱۵۸۲۶)، وقد أخرجہ: مسند احمد (۶/ ۳۳۷،۳۷۸،۴۰۹)، سنن الدارمی/الاستئذان ۴۸ (۲۷۲۲),3547,,Chapters on Medicine
3548,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ،‏‏‏‏ حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ الْأَنْصَارِيُّ،‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۷۶۷، ومصباح الزجاجة:۱۲۳۸),3548,,Chapters on Medicine
3549,حَدَّثَنَا هَارُونُ بْنُ حَيَّانَ،‏‏‏‏ حَدَّثَنَا إِبْرَاهِيمُ بْنُ مُوسَى،‏‏‏‏ أَنْبَأَنَا عَبْدَةُ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۱۵۴، ومصباح الزجاجة:۱۲۳۹),3549,,Chapters on Medicine
