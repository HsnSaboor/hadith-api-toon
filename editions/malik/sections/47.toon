{"hadithnumber": "1633", "arabic": "[1633] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ یَحْیَی بْنِ سَعِیدٍ، أَ نَّہُ قَالَ : بَلَغَنِی أَنَّ الْم", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Daif'}", "reference": "Book 47, Hadith 1", "international_number": "1633", "narrator_chain": ""}
{"hadithnumber": "1634", "arabic": "[1634] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ یَحْیَی بْنِ سَعِیدٍ، أَ نَّہُ قَالَ : سَمِعْتُ سَعِیدَ بْنَ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 47, Hadith 2", "international_number": "1634", "narrator_chain": ""}
{"hadithnumber": "1635", "arabic": "[1635] وَحَدَّثَنِي، عَنْ مَالِك أَنَّهُ قَدْ بَلَغَهُ، أَنَّ رَسُولَ اللَّهِ صَلَّى اللَّهُ عَلَيْه", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Hasan'}", "reference": "Book 47, Hadith 3", "international_number": "1635", "narrator_chain": ""}
{"hadithnumber": "1636", "arabic": "[1636] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ سَلَمَۃَ بْنِ صَفْوَانَ بْنِ سَلَمَۃَ الزُّرَقِیِّ، عَنْ زَیْ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 47, Hadith 4", "international_number": "1636", "narrator_chain": ""}
{"hadithnumber": "1637", "arabic": "[1637] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنِ ابْنِ شِہَابٍ، عَنْ سَالِمِ بْنِ عَبْدِ اللّٰہِ، عَنْ عَبْدِ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Maqtu Sahih'}", "reference": "Book 47, Hadith 5", "international_number": "1637", "narrator_chain": ""}
{"hadithnumber": "1638", "arabic": "[1638] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنِ ابْنِ شِہَابٍ، عَنْ حُمَیْدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ عَو", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Hasan'}", "reference": "Book 47, Hadith 6", "international_number": "1638", "narrator_chain": ""}
{"hadithnumber": "1639", "arabic": "[1639] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنِ ابْنِ شِہَابٍ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ، عَنْ أبِی ہُر", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Maqtu Sahih'}", "reference": "Book 47, Hadith 7", "international_number": "1639", "narrator_chain": ""}
{"hadithnumber": "1640", "arabic": "[1640] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنِ ابْنِ شِہَابٍ، عَنْ عَطَائِ بْنِ یَزِیدَ اللَّیْثِیِّ، عَنْ ا", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih Lighairihi'}", "reference": "Book 47, Hadith 8", "international_number": "1640", "narrator_chain": ""}
{"hadithnumber": "1641", "arabic": "[1641] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنِ ابْنِ شِہَابٍ، عَنْ أَنَسِ بْنِ مَالِکٍ، أَنَّ رَسُولَ اللّ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih Lighairihi'}", "reference": "Book 47, Hadith 9", "international_number": "1641", "narrator_chain": ""}
{"hadithnumber": "1642", "arabic": "[1642] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ أبِی الزِّنَادِ، عَنِ الأَعْرَجِ، عَنْ أبِی ہُرَیْرَۃَ، أ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 47, Hadith 10", "international_number": "1642", "narrator_chain": ""}
{"hadithnumber": "1643", "arabic": "[1643] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ عَطَائِ بْنِ أبِی مُسْلِمٍ عَبْدِ اللّٰہِ الْخُرَاسَانِیِّ ق", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih Lighairihi'}", "reference": "Book 47, Hadith 11", "international_number": "1643", "narrator_chain": ""}
{"hadithnumber": "1644", "arabic": "[1644] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ سُہَیْلِ بْنِ أبِی صَالِحٍ، عَنْ أَبِیہِ، عَنْ أبِی ہُرَیْ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 47, Hadith 12", "international_number": "1644", "narrator_chain": ""}
{"hadithnumber": "1645", "arabic": "[1645] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ مُسْلِمِ بْنِ أبِی مَرْیَمَ، عَنْ أبِی صَالِحٍ السَّمَّانِ،", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 47, Hadith 13", "international_number": "1645", "narrator_chain": ""}
{"hadithnumber": "1646", "arabic": "[1646] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ زَیْدِ بْنِ أَسْلَمَ، عَنْ جَابِرِ بْنِ عَبْدِ اللّٰہِ الْأ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 47, Hadith 14", "international_number": "1646", "narrator_chain": ""}
{"hadithnumber": "1647", "arabic": "[1647] وَحَدَّثَنِی عَنْ مَالِکٍ، أَ نَّہُ بَلَغَہُ : أَنَّ عُمَرَ بْنَ الْخَطَّابِ قَالَ : إنِّی", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 47, Hadith 15", "international_number": "1647", "narrator_chain": ""}
{"hadithnumber": "1648", "arabic": "[1648] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ أَیُّوبَ بْنِ أبِی تَمِیمَۃَ، عَنِ ابْنِ سِیرِینَ، قَالَ :", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Daif'}", "reference": "Book 47, Hadith 16", "international_number": "1648", "narrator_chain": ""}
{"hadithnumber": "1649", "arabic": "[1649] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ نَافِعٍ : أَنَّ عَبْدَ اللّٰہِ بْنَ عُمَرَ کَانَ یَلْبَسُ ال", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 47, Hadith 17", "international_number": "1649", "narrator_chain": ""}
{"hadithnumber": "1650", "arabic": "[1650] وَحَدَّثَنِی مَالِکٌ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ، عَنْ أَبِیہِ، عَنْ عَائِشَۃَ زَوْجِ النَّب", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Mauquf Sahih'}", "reference": "Book 47, Hadith 18", "international_number": "1650", "narrator_chain": ""}
{"hadithnumber": "1758", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، أَنَّ مُعَاذَ بْنَ جَبَلٍ، قَالَ آخِرُ مَا أَوْصَانِي بِهِ رَسُولُ اللَّهِ صلى الله عليه وسلم حِينَ وَضَعْتُ رِجْلِي فِي الْغَرْزِ أَنْ قَالَ ‏ ‏ أَحْسِنْ خُلُقَكَ لِلنَّاسِ يَا مُعَاذُ بْنَ جَبَلٍ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1759", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنِ ابْنِ شِهَابٍ، عَنْ عُرْوَةَ بْنِ الزُّبَيْرِ، عَنْ عَائِشَةَ، زَوْجِ النَّبِيِّ صلى الله عليه وسلم أَنَّهَا قَالَتْ مَا خُيِّرَ رَسُولُ اللَّهِ صلى الله عليه وسلم فِي أَمْرَيْنِ قَطُّ إِلاَّ أَخَذَ أَيْسَرَهُمَا مَا لَمْ يَكُنْ إِثْمًا فَإِنْ كَانَ إِثْمًا كَانَ أَبْعَدَ النَّاسِ مِنْهُ وَمَا انْتَقَمَ رَسُولُ اللَّهِ صلى الله عليه وسلم لِنَفْسِهِ إِلاَّ أَنْ تُنْتَهَكَ حُرْمَةُ اللَّهِ فَيَنْتَقِمُ لِلَّهِ بِهَا ‏.‏", "grades": "", "reference": "", "international_number": "1759", "narrator_chain": ""}
{"hadithnumber": "1760", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنِ ابْنِ شِهَابٍ، عَنْ عَلِيِّ بْنِ حُسَيْنِ بْنِ عَلِيِّ بْنِ أَبِي طَالِبٍ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ مِنْ حُسْنِ إِسْلاَمِ الْمَرْءِ تَرْكُهُ مَا لاَ يَعْنِيهِ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1761", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، أَنَّهُ بَلَغَهُ عَنْ عَائِشَةَ، زَوْجِ النَّبِيِّ صلى الله عليه وسلم أَنَّهَا قَالَتِ اسْتَأْذَنَ رَجُلٌ عَلَى رَسُولِ اللَّهِ صلى الله عليه وسلم قَالَتْ عَائِشَةُ وَأَنَا مَعَهُ فِي الْبَيْتِ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ بِئْسَ ابْنُ الْعَشِيرَةِ ‏\"‏ ‏.‏ ثُمَّ أَذِنَ لَهُ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏.‏ قَالَتْ عَائِشَةُ فَلَمْ أَنْشَبْ أَنْ سَمِعْتُ ضَحِكَ رَسُولِ اللَّهِ صلى الله عليه وسلم مَعَهُ فَلَمَّا خَرَجَ الرَّجُلُ قُلْتُ يَا رَسُولَ اللَّهِ قُلْتَ فِيهِ مَا قُلْتَ ثُمَّ لَمْ تَنْشَبْ أَنْ ضَحِكْتَ مَعَهُ ‏.‏ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ إِنَّ مِنْ شَرِّ النَّاسِ مَنِ اتَّقَاهُ النَّاسُ لِشَرِّهِ ‏\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "1761", "narrator_chain": ""}
{"hadithnumber": "1762", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ عَمِّهِ أَبِي سُهَيْلِ بْنِ مَالِكٍ، عَنْ أَبِيهِ، عَنْ كَعْبِ الأَحْبَارِ، أَنَّهُ قَالَ إِذَا أَحْبَبْتُمْ أَنْ تَعْلَمُوا مَا لِلْعَبْدِ عِنْدَ رَبِّهِ فَانْظُرُوا مَاذَا يَتْبَعُهُ مِنْ حُسْنِ الثَّنَاءِ ‏.‏", "grades": "", "reference": "", "international_number": "1762", "narrator_chain": ""}
{"hadithnumber": "1763", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ يَحْيَى بْنِ سَعِيدٍ، أَنَّهُ قَالَ بَلَغَنِي أَنَّ الْمَرْءَ، لَيُدْرِكُ بِحُسْنِ خُلُقِهِ دَرَجَةَ الْقَائِمِ بِاللَّيْلِ الظَّامِي بِالْهَوَاجِرِ ‏.‏", "grades": "", "reference": "", "international_number": "1763", "narrator_chain": ""}
{"hadithnumber": "1764", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ يَحْيَى بْنِ سَعِيدٍ، أَنَّهُ قَالَ سَمِعْتُ سَعِيدَ بْنَ الْمُسَيَّبِ، يَقُولُ أَلاَ أُخْبِرُكُمْ بِخَيْرٍ، مِنْ كَثِيرٍ مِنَ الصَّلاَةِ وَالصَّدَقَةِ قَالُوا بَلَى ‏.‏ قَالَ إِصْلاَحُ ذَاتِ الْبَيْنِ وَإِيَّاكُمْ وَالْبِغْضَةَ فَإِنَّهَا هِيَ الْحَالِقَةُ ‏.‏", "grades": "", "reference": "", "international_number": "1764", "narrator_chain": ""}
{"hadithnumber": "1765", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، أَنَّهُ قَدْ بَلَغَهُ أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ بُعِثْتُ لأُتَمِّمَ حُسْنَ الأَخْلاَقِ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1766", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ سَلَمَةَ بْنِ صَفْوَانَ بْنِ سَلَمَةَ الزُّرَقِيِّ، عَنْ زَيْدِ بْنِ طَلْحَةَ بْنِ رُكَانَةَ، يَرْفَعُهُ إِلَى النَّبِيِّ صلى الله عليه وسلم قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ لِكُلِّ دِينٍ خُلُقٌ وَخُلُقُ الإِسْلاَمِ الْحَيَاءُ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1767", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنِ ابْنِ شِهَابٍ، عَنْ سَالِمِ بْنِ عَبْدِ اللَّهِ، عَنْ عَبْدِ اللَّهِ بْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم مَرَّ عَلَى رَجُلٍ وَهُوَ يَعِظُ أَخَاهُ فِي الْحَيَاءِ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ دَعْهُ فَإِنَّ الْحَيَاءَ مِنَ الإِيمَانِ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1768", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنِ ابْنِ شِهَابٍ، عَنْ حُمَيْدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ عَوْفٍ، أَنَّ رَجُلاً، أَتَى إِلَى رَسُولِ اللَّهِ صلى الله عليه وسلم فَقَالَ يَا رَسُولَ اللَّهِ عَلِّمْنِي كَلِمَاتٍ أَعِيشُ بِهِنَّ وَلاَ تُكْثِرْ عَلَىَّ فَأَنْسَى ‏.‏ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ لاَ تَغْضَبْ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1769", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنِ ابْنِ شِهَابٍ، عَنْ سَعِيدِ بْنِ الْمُسَيَّبِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ لَيْسَ الشَّدِيدُ بِالصُّرَعَةِ إِنَّمَا الشَّدِيدُ الَّذِي يَمْلِكُ نَفْسَهُ عِنْدَ الْغَضَبِ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1770", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنِ ابْنِ شِهَابٍ، عَنْ عَطَاءِ بْنِ يَزِيدَ اللَّيْثِيِّ، عَنْ أَبِي أَيُّوبَ الأَنْصَارِيِّ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ لاَ يَحِلُّ لِمُسْلِمٍ أَنْ يُهَاجِرَ أَخَاهُ فَوْقَ ثَلاَثِ لَيَالٍ يَلْتَقِيَانِ فَيُعْرِضُ هَذَا وَيُعْرِضُ هَذَا وَخَيْرُهُمَا الَّذِي يَبْدَأُ بِالسَّلاَمِ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1771", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنِ ابْنِ شِهَابٍ، عَنْ أَنَسِ بْنِ مَالِكٍ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ لاَ تَبَاغَضُوا وَلاَ تَحَاسَدُوا وَلاَ تَدَابَرُوا وَكُونُوا عِبَادَ اللَّهِ إِخْوَانًا وَلاَ يَحِلُّ لِمُسْلِمٍ أَنْ يُهَاجِرَ أَخَاهُ فَوْقَ ثَلاَثِ لَيَالٍ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1772", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ أَبِي الزِّنَادِ، عَنِ الأَعْرَجِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ إِيَّاكُمْ وَالظَّنَّ فَإِنَّ الظَّنَّ أَكْذَبُ الْحَدِيثِ وَلاَ تَجَسَّسُوا وَلاَ تَحَسَّسُوا وَلاَ تَنَافَسُوا وَلاَ تَحَاسَدُوا وَلاَ تَبَاغَضُوا وَلاَ تَدَابَرُوا وَكُونُوا عِبَادَ اللَّهِ إِخْوَانًا ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1773", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ عَطَاءِ بْنِ أَبِي مُسْلِمٍ عَبْدِ اللَّهِ الْخُرَاسَانِيِّ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ تَصَافَحُوا يَذْهَبِ الْغِلُّ وَتَهَادَوْا تَحَابُّوا وَتَذْهَبِ الشَّحْنَاءُ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1774", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ سُهَيْلِ بْنِ أَبِي صَالِحٍ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ تُفْتَحُ أَبْوَابُ الْجَنَّةِ يَوْمَ الاِثْنَيْنِ وَيَوْمَ الْخَمِيسِ فَيُغْفَرُ لِكُلِّ عَبْدٍ مُسْلِمٍ لاَ يُشْرِكُ بِاللَّهِ شَيْئًا إِلاَّ رَجُلاً كَانَتْ بَيْنَهُ وَبَيْنَ أَخِيهِ شَحْنَاءُ فَيُقَالُ أَنْظِرُوا هَذَيْنِ حَتَّى يَصْطَلِحَا أَنْظِرُوا هَذَيْنِ حَتَّى يَصْطَلِحَا ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1775", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ مُسْلِمِ بْنِ أَبِي مَرْيَمَ، عَنْ أَبِي صَالِحٍ السَّمَّانِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّهُ قَالَ تُعْرَضُ أَعْمَالُ النَّاسِ كُلَّ جُمُعَةٍ مَرَّتَيْنِ يَوْمَ الاِثْنَيْنِ وَيَوْمَ الْخَمِيسِ فَيُغْفَرُ لِكُلِّ عَبْدٍ مُؤْمِنٍ إِلاَّ عَبْدًا كَانَتْ بَيْنَهُ وَبَيْنَ أَخِيهِ شَحْنَاءُ فَيُقَالُ اتْرُكُوا هَذَيْنِ حَتَّى يَفِيئَا ‏.‏ أَوِ ارْكُوا هَذَيْنِ حَتَّى يَفِيئَا ‏.‏", "grades": "", "reference": "", "international_number": "1775", "narrator_chain": ""}
