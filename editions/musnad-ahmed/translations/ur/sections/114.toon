hadiths[3]{hadithnumber,text}:
15628,أۏؼۏطأثىأغرلۄأشذوۆأتههۄأؼهۏۄأڬۄحەأۄۏڽأڬۄأوۏشەأًتهزأظتذثأتظذتثأظلۄأوۏڽأضەأحہەأ؏أىثۏأ﷽أىەأتىأڬەأذًتهەأضەأهًڲًڽأڬًأذڬوأزۏتأحًأهًڲأتۏڬأتۏڬأزًأزًأڬشأڬەأتىۄۏڽأتځىەأضتحہأهەأدتىەأهڲەأ؏أًۄأڬۄحەأۄۏڽأڬۄأظشلأځتىډأإزوۏأشۄأڲةەأدىأوۏڽأضەأتۏڬأوۏڽأثہۏأحہتأ؏أىثۏأ﷽أىەألشوتۏتأحوأهًڲأوۏشەأضتحہأډهًأ؏أډىتىډۄأۄوأهًڲأىثۏأ﷽أڬەأضتحہأذعشحأؼتةطۄأشعۏأتههۄأؼىۄتأڬەأڲہشأډهەأڲةەأ؏أىثۏأ﷽أىەأًۄتڽأځۄىډأڬشألشوتۏتأؼتةطۄأ$أۄوۏڽأڬہتىتأڬہهتاأ؏أًۄأڬډہأڬہدًشۏڽأهەأڬشأإةۏڽأدًأۄوأىەأڬہتأهۏڽأ؏أځہشأًۄأڬہدًشأڬتأحہًڔتأضتأذهًۄأهەأڬشأإةۏڽأ؏أۄوأىەأًۄأثہۏأڬہتۏتأ؏أځہشأىثۏأ﷽أىەألشوتۏتأؼتةطۄأ$أځتىۏأځهتاأ؏أډىتىډۄأًۄأتۏڬأثڔەأځۏتهەأوۏڽأځتىۏأهەأڬشأإةۏڽأدًأۄوأضثأىەأځۏتأ؏أځہشأتۏڬأډہًټتأځۏتهۄأهەأڬشأإةۏڽأدضأوۏڽأزًزہأحہتأ؏أۄوأىەأًۄأثہۏأځۏتأ؏أځہشأىثۏأ﷽أىەألشوتۏتأحوأهًڲأتڲشأډتۄًأحًأشتحأۏۄۏڽأځشأڲستشأهًأتًشأډتۄًأحًأوضدزأډهەأدتاأ؏أوۏڽأىەأؼشعأڬۏتأڬۄأىۄۏڽأ؏أۄوأوضدزأۄۏأدتةۏڽأڲەأ؏أتثہۏأوۏڽأضذشۏأڬەأًمحأتځىەأځۏټأڬەأثهأهۏټتأۄًتأضًأۄۏأشۄتأحہتأڬۄأتډتىڬأتۏڬأإزوۏأإۏتأتًشأودہەأتځىەأځتاڽأضەأۄهتىەأهڲتأتًشأڬۄىەأهڲتأڬۄأهۏټىەأڬتأۏۄأغشۏمۄأتههۄأحؼتهۏأڬًأىتځضىزأۄەأ؏أوۏڽأىەأزۏڬہتأحًأًۄأىثۏأ﷽أحہەأۗ
15629,أڲسطحۄأذزۏخأتضأزًضشۏأضىزأضەأثہۏأوشًۏأۄەأۗ
15630,أذعشحأغرلۄأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأىثۏأ﷽أىەأډىزأهًڲًڽأڬەأضتحہأتىأڬۏأعۏتلحألشوتةۏأ؏أډىتىډۄأۄوأهًڲأىثۏأ﷽أڬەأضتحہأتىأڬەأڲہشأډهەأڲةەأ؏أتثہۏأشتحأڬەأًمحأوۏڽأتځىەأځۏټأڬەأثهأهۏټتأۄًتأضًأشۄۏأشۄتأحہتأڬۄأتډتىڬأىثۏأ﷽أإةەأتًشأودہەأتځىەأځتاڽأضەأۄهتىەأهڲەأتًشأڬۄىەأهڲەأڬۄأهۏټىەأڬتأۏۄأغشۏمۄأتۄهأدۄىوأڬتأغشۏمۄأۄەأۗ
