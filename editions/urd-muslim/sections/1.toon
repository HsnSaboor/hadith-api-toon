metadata:

hadiths[436]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
93,کہمس سے ا بن بریدہ سے ، انہوں نے  یحیی بن یعمر سےروایت کی  ،  انہوں نے کہا  کہ سب سے پہلا شخص جس نے ,,"Book 1, Hadith 93",,,93
94,کہمس کے بجائے مطر وراق نےعبد اللہ بن بریدہ سے  ،  انہوں نے یحیی بن یعمر سے نقل کیا کہ جب معبد  ( جہن,,"Book 1, Hadith 94",,,94
95,( عبد اللہ بن بریدہ کے ایک تیسرے شاگرد )  عثمان بن غیاث نے یحییٰ بن یعمر اور حمید بن عبد الرحمٰن دون,,"Book 1, Hadith 95",,,95
96,معتمر کے والد  ( سلیمان بن طرخان )  نے یحییٰ بن یعمر سے  ،  انہوں نے عبد اللہ بن عمر  ‌رضی ‌اللہ ‌عن,,"Book 1, Hadith 96",,,96
97,اسماعیل بن ابراہیم  (  ابن علیہ  )  نے ابو حیان سے  ،  انہوں نے ابو زرعہ بن عمرو بن جریر سے اور انہو,,"Book 1, Hadith 97",,,97
98,"( ابن علیہ کے بجائے  )  محمد بن بشر نےکہا  :  ہمیں ابو حیان نے  سابقہ سند سے وہی حدیث بیان کی  ،  ال",,"Book 1, Hadith 98",,,98
99,"حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا  :  ’’مجھ سے  ( دین کے بار",,"Book 1, Hadith 99",,,99
100,مالک بن انس نے ابو سہیل سے  ،  اور انہوں نے اپنے والد سے روایت کی  ،  انہوں نے حضرت طلحہ بن عبیداللہ,,"Book 1, Hadith 100",,,100
101,اسماعیل بن جعفر نے ابو سہیل سے  ،  انہوں نے اپنے والد سے  ،  انہوں نےحضرت طلحہ بن عبید اللہ  ‌رضی ‌ا,,"Book 1, Hadith 101",,,101
102,"ہاشم بن قاسم ابونضر نے کہا :  ہمیں سلیمان بن مغیرہ نے ثابت کے حوالے سے یہ حدیث سنائی  ،  انہوں نے حض",,"Book 1, Hadith 102",,,102
103,"بہزنے کہا  :  ہمیں سلیمان بن مغیرہ نے ثابت سے حدیث سنائی اور انہوں نے حضرت انس  ‌رضی ‌اللہ ‌عنہ ‌ ‌ ",,"Book 1, Hadith 103",,,103
104,"عمر و بن عثمان نے کہا  :  ہمیں موسیٰ بن طلحہ نےحدیث سنائی  ،  انہوں نےکہا  :  مجھےحضرت ابوایوب  ‌رضی",,"Book 1, Hadith 104",,,104
105,محمد بن عثمان بن عبد اللہ بن موہب اور ان کے والد عثمان دونوں موسیٰ بن طلحہ سے سنا وہ  حضرت ابو ایوب ,,"Book 1, Hadith 105",,,105
106,"یحییٰ بن یحییٰ تمیمی او رابوبکر بن ابی شیبہ نے کہا  :  ہمیں ابو احوص نے حدیث بیان کی  ،  انہوں نے اب",,"Book 1, Hadith 106",,,106
107,"حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ ایک اعرابی رسول اللہ ﷺ کے پاس آیا اور کہا  :  اے",,"Book 1, Hadith 107",,,107
108,ابومعاویہ نے اعمش سے حدیث سنائی  ،  انہوں نے ابو سفیان سے اور انہوں نے حضرت جابر ‌رضی ‌اللہ ‌عنہ ‌ ‌,,"Book 1, Hadith 108",,,108
109,شیبان نے اعمش سے  ،  انہوں نے ابو صالح اور ابو سفیان سے اور انہوں نے حضرت جابر ‌رضی ‌اللہ ‌عنہ ‌ ‌  ,,"Book 1, Hadith 109",,,109
110,سلمہ بن  شبیب  ‘ حسن بن اعین ‘ معقل یعنی عبد اللہ ‘ ابوالزبیر ‘ جابر سے روایت ہے کہ ایک شخص نے رسول ,,"Book 1, Hadith 110",,,110
111,ابو خالد سلیمان بن حیان احمر نے ابومالک اشجعی سے  ،  انہوں نے سعد بن عبیدہ سے  ،  انہوں نے حضرت ابن ,,"Book 1, Hadith 111",,,111
112,"یحییٰ بن زکریا نے ہمیں حدیث بیان کی  ،  کہا  :  مجھے سعد بن طارق  (  ابو مالک اشجعی )  نے حدیث بیان ",,"Book 1, Hadith 112",,,112
113,"عاصم بن محمد بن زید عبد اللہ بن عمر نے اپنے والد سے حدیث بیان کی  ،  کہا  :  حضرت عبد اللہ بن عمر  ‌",,"Book 1, Hadith 113",,,113
114,عکرمہ بن خالد  ،  طاؤس کو حدیث سنا رہے تھے کہ ایک آدمی نے حضرت عبد اللہ بن عمر  ‌رضی ‌اللہ ‌عنہ ‌ ‌ ,,"Book 1, Hadith 114",,,114
115,"خلف بن ہشام نے  بیان کیا  ( کہا )  ہمیں حماد بن زید نے ابو جمرہ سے حدیث بیان کی  ،  انہوں نے کہا  : ",,"Book 1, Hadith 115",,,115
116,"شعبہ نے ابو جمرہ سے حدیث بیان  کی  ،  انہوں نے کہا  :  میں حضرت عبد اللہ بن عباس  ‌رضی ‌اللہ ‌عنہ ‌ ",,"Book 1, Hadith 116",,,116
117,قرہ بن خالد نے ابوجمرہ سے حدیث بیان کی  ،  انہوں نے حضرت ابن عباس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے اور انہوں,,"Book 1, Hadith 117",,,117
118,"( اسماعیل )  ابن علیہ نے کہا  :  ہمیں سعید بن ابی عروبہ نے قتادہ سے حدیث سنائی ،  انہوں نےکہا  :  مج",,"Book 1, Hadith 118",,,118
119,ابن ابی عدی نے سعید کےحوالے سے قتادہ سے روایت کی ،  انہوں نے کہا کہ مجھے عبد القیس کے وفد سے ملاقات ,,"Book 1, Hadith 119",,,119
120,محمد بن بکار  بصری ‘ عاصم بن جریج ‘ محمد بن رافع ‘ عبد الرزاق  ‘ ابن جریج ‘ ابو قرعہ ‘ ابو نضرہ ‘ اب,,"Book 1, Hadith 120",,,120
121,"بن ابی شیبہ  ،  ابو کریب اور اسحاق بن ابراہیم سب نے  وکیع سے حدیث سنائی  ۔  ابو بکر نے کہا  :  وکیع ",,"Book 1, Hadith 121",,,121
122,بشر بن سری اور ابو عاصم نے زکریا بن اسحاق سے خبر دی کہ یحییٰ بن عبداللہ بن صیفی نے ابو معبد سے اور ا,,"Book 1, Hadith 122",,,122
123,اسماعیل بن امیہ نے یحییٰ بن عبداللہ بن صیفی سے  ،  انہوں نے ابو معبد سے ا ور انہوں نے حضرت ابن عباس ,,"Book 1, Hadith 123",,,123
124,جناب عبید اللہ بن عبد اللہ بن عتبہ بن مسعود نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ ج,,"Book 1, Hadith 124",,,124
125,سعید بن مسیب نے بیان کیا کہ حضرت ابوہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے انہیں خبر کہ رسول اللہ ﷺ نے فرمایا,,"Book 1, Hadith 125",,,125
126,"عبدالرحمٰن بن یعقوب نے حضرت ابوہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ رسو ل اللہ ﷺ نے فرمایا  :  ",,"Book 1, Hadith 126",,,126
127,اعمش نے ابو سفیان سے  ،  انہوں نے حضرت جابر ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے  ،  نیز اعمش ہی نے ابو صالح سے ا,,"Book 1, Hadith 127",,,127
129,ابو غسان مسمعی ‘ مالک بن عبد الواحد ‘ عبد الملک بن  الصباح ‘ شعبہ  ‘ واقد بن محمدزید بن عبد اللہ ‘ ا,,"Book 1, Hadith 129",,,129
130,مروان فزاری نے ابو مالک  ( سعد بن طارق اشجعی )  سے حدیث سنائی  ،  انہوں نے اپنے والد  (  طارق بن اشی,,"Book 1, Hadith 130",,,130
131,ابو خالد احمر اور یزید بن ہارون نے ابومالک سے  ،  انہوں نے اپنے والد سے روایت کی  کہ انہوں نے نبی اک,,"Book 1, Hadith 131",,,131
132,یونس نے ابن شہاب سے  ،  انہوں نے سعید بن مسیب سے اور انہوں نے اپنے والد سے ورایت کی کہ جب ابو طالب ک,,"Book 1, Hadith 132",,,132
133,معمر اور صالح  ،  دونوں نے زہری سے ان کی سابقہ سند کےساتھ یہی روایت بیان کی  ،  فرق یہ ہے کہ صالح کی,,"Book 1, Hadith 133",,,133
134,مروان بن یزید سے  ،  جو کیسان کے بیٹے ہیں  ،  حدیث سنائی  ،  انہوں نے ابو حازم سے  ،  انہوں نے حضرت ,,"Book 1, Hadith 134",,,134
135,"یحییٰ بن سعید نے کہا  :  ہمیں یزید بن کیسان نے حدیث سنائی....  (  اس کے بعد مذکورہ سند کے ساتھ  )  ح",,"Book 1, Hadith 135",,,135
136,"اسماعیل بن ابراہیم  ( ابن علیہ )  نے خالد  ( حذاء )  سے روایت کی  ،  انہوں نے کہا  :  مجھے ولید بن م",,"Book 1, Hadith 136",,,136
137,ابن علیہ کے بجائے بشر بن مفضل نے بھی خالد حذاء سے یہی روایت بیان  کی  ، انہوں نے ولید ابو بشر سے روا,,"Book 1, Hadith 137",,,137
138,"طلحہ بن مصرف نے ابو صالح سے  ،  انہوں نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے ورایت کی  ،  کہا  :",,"Book 1, Hadith 138",,,138
139,اعمش نےابو صالح سے  ،  انہوں نے  ( اعمش کو شک ہے  )  حضرت ابوہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  یا حضرت ابو ,,"Book 1, Hadith 139",,,139
140,"( عبد الرحمٰن بن یزید )  ابن جابر نے کہا  :  مجھے عمیر بن ہانی نےحدیث سنائی  ،  انہوں نے کہا  :  مجھ",,"Book 1, Hadith 140",,,140
141,عمیر بن ہانی سے  (  عبد الرحمٰن بن یزید )  ابن جابر کے بجائے اوزاعی کے واسطے سے یہی حدیث بیان کی گئی,,"Book 1, Hadith 141",,,141
142,حضرت عباد بن صامت  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے جنادہ بن ابی امیہ کے بجائے  (  ابو عبداللہ عبدالرحمٰن بن ,,"Book 1, Hadith 142",,,142
143,سیدنا انس بن مالک  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے حضرت معاذ بن جبل  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے یہ حدیث روایت ک,,"Book 1, Hadith 143",,,143
144,"عمرو بن میمون نے حضرت معاذ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  انہوں نے کہا  :  میں  رسول اللہ ﷺ ک",,"Book 1, Hadith 144",,,144
145,شعبہ نے ابوحصین اور اشعث بن سلیم سے حدیث سنائی  ،  ان دونوں نے اسود بن ہلال سے سنا ،  وہ حضرت معاذ ب,,"Book 1, Hadith 145",,,145
146,"زائدہ  (  بن قدامہ  )  نے ابو حصین سے  ،  انہوں نے اسود بن ہلال سے روایت کی  ،  انہوں نے کہا :  میں ",,"Book 1, Hadith 146",,,146
147,"حضرت ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے کہا :  ہم رسول اللہ ﷺ کے چاروں طرف ایک جماعت  (  کی صورت )  م",,"Book 1, Hadith 147",,,147
148,"قتادہ نے کہا  :  ہمیں حضرت انس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے حدیث سنائی کہ رسول اللہ ﷺ نے حضرت معاذ  ‌رضی",,"Book 1, Hadith 148",,,148
149,"سلیمان بن مغیرہ نے کہا :  ہمیں ثابت نے حضرت انس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے حدیث سنائی  ،  انہوں نے کہا",,"Book 1, Hadith 149",,,149
150,"حماد نے کہا  :  ہمیں ثابت نےحضرت انس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے حدیث سنائی  ،  انہوں نے کہا  :  مجھے ع",,"Book 1, Hadith 150",,,150
151,حضرت عباس بن عبدالمطلب  ‌رضی ‌اللہ ‌عنہ ‌ ‌  بیان کرتے ہیں کہ انہوں نے رسول اللہ ﷺ سے سنا ،  آپ فرما,,"Book 1, Hadith 151",,,151
152,سلیمان بن بلال نے عبد اللہ بن دینار سے   ،  انہوں ابو صالح سے اور انہوں نے حضرت ابوہریرہ ‌رضی ‌اللہ ,,"Book 1, Hadith 152",,,152
153,سہیل نے عبداللہ بن دینار سے  ،  انہوں نے ابو صالح سے اور انہوں نے حضرت ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌,,"Book 1, Hadith 153",,,153
154,سفیان بن عیینہ نے زہری سے حدیث سنائی  ،  انہوں نے سالم سے اور انہوں نے اپنے والد حضرت عبداللہ بن عمر,,"Book 1, Hadith 154",,,154
155,سفیان بن عیینہ کے بجائے معمر نے زہری سے مذکورہ بالاسند کےساتھ خبر دی اور کہا کہ آپ ایک انصاری کے پاس,,"Book 1, Hadith 155",,,155
156,ابو سوار بیان کرتے ہیں کہ انہوں نے حضرت عمران بن حصین ‌رضی ‌اللہ ‌عنہ ‌ ‌  کو سنا  ،  وہ نبی ﷺ سے حد,,"Book 1, Hadith 156",,,156
157,حماد بن زید نے اسحاق بن سوید سے روایت کی کہ ابو قتادہ  (  تمیم بن نذیر )  نے حدیث بیان کی  ،  کہا کہ,,"Book 1, Hadith 157",,,157
158,"نضر  ( بن شمیل  )  نے کہا :  ہمیں ابو نعامہ عدوی نے حدیث بیان کی  ،  انہوں نے کہا :  میں نےحجیر بن ر",,"Book 1, Hadith 158",,,158
159,عبد اللہ بن نمیر ،  جریر اور ابواسامہ نے ہشام بن عروہ سے حدیث سنائی  ،  انہوں نے اپنے والد ( عروہ ) ,,"Book 1, Hadith 159",,,159
160,لیث نے یزید بن ابی حبیب سے  ،  انہوں نے ابو خیر سے اور انہوں حضرت عبد اللہ بن عمر  ‌رضی ‌اللہ ‌عنہ ‌,,"Book 1, Hadith 160",,,160
161,عمرو بن حارث نے یزید بن ابی  حبیب سے  ،  انہوں نے ابوخیر سے روایت کی اور انہوں نے حضرت عبداللہ بن عم,,"Book 1, Hadith 161",,,161
162,"حضرت جابر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  بیان کرتے ہیں کہ میں نے رسول اللہ ﷺ کو یہ کہتے ہوئے سنا  :  ’’ مسلما",,"Book 1, Hadith 162",,,162
163,"یحییٰ بن سعید اموی نے کہا  :  ہمیں ابو بردہ  ( برید )  بن عبداللہ بن ابی بردہ بن ابی موسیٰ اشعری نے ",,"Book 1, Hadith 163",,,163
164,ابراہیم بن سعید جوہری  ‘ ابو اسامہ  ‘ برید بن عبد اللہ اس روایت میں دوسری سند کے ساتھ یہ الفاظ ہیں ج,,"Book 1, Hadith 164",,,164
165,ابو قلابہ نےحضرت انس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  وہ نبیﷺ سے روایت کرتے ہیں کہ آپ نے فرمایا,,"Book 1, Hadith 165",,,165
166,"قتادہ حضرت  انس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے حدیث بیان  کرتے ہیں  ،  انہوں نے کہا :  رسول اللہ ﷺ نے فرما",,"Book 1, Hadith 166",,,166
167,"ثابت نے حضرت انس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  انہوں نے کہا  :  رسول اللہ ﷺ نے فرمایا...... ",,"Book 1, Hadith 167",,,167
168,اسماعیل بن علیہ اور عبد الوارث دونوں نے عبد العزیز سے اور انہوں نے حضرت انس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے,,"Book 1, Hadith 168",,,168
169,قتادہ نے حضرت انس بن مالک  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  انہوں نے کہا کہ رسول اللہ ﷺ نے فرمای,,"Book 1, Hadith 169",,,169
170,"شعبہ نے کہا  :  میں نے قتادہ کو حضرت انس بن مالک ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے حدیث بیان کرتے ہوئے سنا  ، ",,"Book 1, Hadith 170",,,170
171,حسن معلم نے قتادہ سے اور انہوں ن حضرت انس بن مالک  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے  ،  انہوں نے نبی کریم ﷺ س,,"Book 1, Hadith 171",,,171
172,"حضرت ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا :  ’’ جس کی ایذا رسانی سے ا",,"Book 1, Hadith 172",,,172
173,ابو سلمہ بن عبد الرحمٰن نے ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے  ،  انہوں نے رسول اللہ ﷺ سے حدیث روایت ,,"Book 1, Hadith 173",,,173
174,ابوحصین نے ابوصالح سے اور انہو ں نے حضرت ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  انہوں نے کہا,,"Book 1, Hadith 174",,,174
175,اعمش نے ابو صالح سے  ،  انہوں نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  انہوں نے کہا  ,,"Book 1, Hadith 175",,,175
176,"ابو شریح  (  خویلد بن عمرو  )  خزاعی  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ نبی اکرم ﷺ نے فرمایا : ’’ ",,"Book 1, Hadith 176",,,176
177,"ابو بکر بن ابی شیبہ نے کہا  :  ہمیں وکیع نے سفیان سے حدیث سنائی  ،  نیز محمد بن مثنیٰ نے کہا :  ہمیں",,"Book 1, Hadith 177",,,177
178,اعمش نے اسماعیل بن رجاء سے  ،  انہوں نے اپنے والد  ( رجاء بن  ربیعہ  )  سے اور انہوں نے حضرت ابوسعید,,"Book 1, Hadith 178",,,178
179,صالح بن کیسان نے حارث  (  بن فضیل )  سے  ،  انہوں نے جعفر بن عبد اللہ بن حکم سے  ،  انہوں نے عبد  ال,,"Book 1, Hadith 179",,,179
180,حارث بن فضیل خطمی سے  (  صالح بن کیسان کے بجائے  )  عبدالعزیز بن محمد کی سند کےساتھ رسول  اللہ ﷺ کے ,,"Book 1, Hadith 180",,,180
181,"حضرت ابو مسعود ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے  ،  انہوں نے کہا  :  نبی اکرم ﷺ نے ہاتھ سے یمن کی طر",,"Book 1, Hadith 181",,,181
182,"ایوب نے کہا  :  ہمیں محمد  (  ابن سیرین  )  نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے حدیث سنائی  ،",,"Book 1, Hadith 182",,,182
183,( عبد اللہ  )  ابن عون نے محمد  (  ابن سیرین  )  سے  ، انہوں نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌ ,,"Book 1, Hadith 183",,,183
184,"صالح  نے اعرج سے روایت کی  ،  انہوں نے کہا کہ حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے کہا :  رسو ل ا",,"Book 1, Hadith 184",,,184
185,و زناد نے اعرج سے اور انہوں نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ رسو ل اللہ ﷺ نے ف,,"Book 1, Hadith 185",,,185
186,علاء  (  بن عبدالرحمان  الجہنی )  نے اپنے والد سے  ،  انہوں نے ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے رو,,"Book 1, Hadith 186",,,186
187,"یونس نے ابن شہاب سے روایت کی  ،  انہوں نے کہا  :  مجھے ابو سلمہ بن عبد الرحمٰن نے خبر دی کہ حضرت ابو",,"Book 1, Hadith 187",,,187
188,"شعیب نے زہری سے اسی سند کے ساتھ یہی روایت کی اور  ( آخرمیں یہ  )  اضافہ کیا  : ’’ ایمان یمنی ہے اور ",,"Book 1, Hadith 188",,,188
189,"سعید بن مسیت نے حدیث بیان کی کہ حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے کہا  :  میں نے نبی اکرمﷺ کو ",,"Book 1, Hadith 189",,,189
190,ابو معاویہ نے اعمش سے حدیث سنائی  ،  انہوں نے ابو صالح سے اور انہوں نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌ع,,"Book 1, Hadith 190",,,190
191,جریر نے اعمش سے اسی سند کے ساتھ حدیث بیان کی  ،  لیکن اس نے ’’ کفر کا مرکز مشرق کی طرف ہے  ‘  ‘  کے ,,"Book 1, Hadith 191",,,191
192,شعبہ نے اعمش سے سابقہ سند کے ساتھ جریر کی طرح حدیث سنائی اور یہ ا لفاظ زائد بیان کیے کہ ’’غرور اور گ,,"Book 1, Hadith 192",,,192
193,"حضرت جابر بن عبد اللہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے کہا کہ رسول اللہ ﷺ نے  فرمایا  :  ’’ دلوں کی سختی اور",,"Book 1, Hadith 193",,,193
194,ابو معاویہ اور وکیع نے اعمش سے حدیث سنائی  ،  انہوں نے ابو صالح سے اور انہوں نے حضرت ابو ہریرہ  ‌رضی,,"Book 1, Hadith 194",,,194
195,"( ابو معاویہ اور وکیع کے بجائے  )  جریر نے اعمش سے ان کی اسی سند سے حدیث سنائی  ،  کہا  :  رسول اللہ",,"Book 1, Hadith 195",,,195
196,"سفیان بن عیینہ نے کہا  :  میں نے سہیل سے کہا کہ عمرو نے ہمیں قعقاع کے واسطے سے آپ کے والد سے حدیث سن",,"Book 1, Hadith 196",,,196
197,سفیان ثوری نے سہیل بن ابی صالح سے  ،  انہوں نے عطاء بن یزید لیثی سے  ،  انہوں نے حضرت تمیم داری  ‌رض,,"Book 1, Hadith 197",,,197
198,"ہمیں روح بن قاسم نے حدیث سنائی  ،   ( کہا :  )  ہمیں سہیل نے عطاء سے اس وقت سن کر روایت کی جب وہ ابو",,"Book 1, Hadith 198",,,198
199,"قیس (  بن ابی حازم  )  نے حضرت جریر  (  بن عبد اللہ  )   ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  کہا  :",,"Book 1, Hadith 199",,,199
200,زیاد بن علاقہ  ( کوفی )  سے روایت ہے  ،  انہوں نے حضرت جریر بن عبد اللہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے سنا,,"Book 1, Hadith 200",,,200
201,"سریج بن یونس اور یعقوب دورقی نے کہا  :  ہشیم نےہمیں سیار کے واسطے سے شعبی سے حدیث سنائی اور انہوں نے",,"Book 1, Hadith 201",,,201
202,"یونس بن ابن شہاب سے خبر دی  ،  انہوں نے کہا  :  میں نے ابو سلمہ بن عبدالرحمٰن اور سعید بن مسیب سے سن",,"Book 1, Hadith 202",,,202
203,"عقیل بن خالد نے حدیث سنائی کہ ابن شہاب  ( زہری )  نےکہا :  مجھے ابو بکر بن عبدالرحمن بن حارث بن ہشام",,"Book 1, Hadith 203",,,203
204,اوزاعی نے زہری سے حدیث بیان کی  ،  انہوں نے ابن مسیب  ،  ابو سلمہ اور ابوبکر بن عبدالرحمٰن بن حارث ب,,"Book 1, Hadith 204",,,204
205,صفوان بن سلیم نے حضرت میمونہ رضی اللہ عنہا کے آزاد کردہ غلام عطاء بن یسار سے اور حمید بن عبدالرحمٰن ,,"Book 1, Hadith 205",,,205
206,قتیبہ  بن سعید  ‘ عبد العزیز دراوردی  ‘ \n\nعلاء بن عبدالرحمٰن نے ابو ھریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  ،  ا,,"Book 1, Hadith 206",,,206
207,معمر نے ہمام بن منبہ سے  ،  انہوں نے حضرت ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے اور انہوں نے نبی ﷺ سے رو,,"Book 1, Hadith 207",,,207
208,شعبہ نے سلیمان سے  ،  انہوں نے ذکوان سے اور انہوں نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ک,,"Book 1, Hadith 208",,,208
210,عبد اللہ بن نمیر اور سفیان نے اعمش سے  ،  انہوں نے نے عبد اللہ بن مرہ سے  ،  انہوں نے مسروق سے اور ا,,"Book 1, Hadith 210",,,210
211,نافع بن مالک بن ابی عامر نے اپنے والد سے  ،  انہوں نے حضرت ابوہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ک,,"Book 1, Hadith 211",,,211
212,"محمد بن جعفر نے کہا  :  ہمیں حرقہ کے آزاد کردہ غلام علاء بن عبد الرحمن بن یعقوب نے اپنے والد سے خبر ",,"Book 1, Hadith 212",,,212
213,"یحییٰ بن محمد بن قیس ابو زکیر نے کہا  :  میں نے علاء بن عبدالرحمٰن کو اسی  (  مذکورہ بالا )  سند کے ",,"Book 1, Hadith 213",,,213
214,حماد بن سلمہ نے داؤد بن ابی ہندہ سے  ،  انہوں نے سعید بن مسیب کے حوالے سے  حضرت ابو ہریرہ  ‌رضی ‌الل,,"Book 1, Hadith 214",,,214
215,"نافع نے حضرت عبد اللہ بن عمر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ رسول اللہ ﷺ نے فرمایا  : ’’ جو شخص",,"Book 1, Hadith 215",,,215
216,عبد اللہ بن دینار سے روایت ہے  ،  انہوں نے حضرت ابن عمر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  کو یہ کہتے سنا کہ رسو ,,"Book 1, Hadith 216",,,216
217,"حضرت ابو ذر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ انہوں نے رسو ل اللہ ﷺ سے سنا : ’’ جس شخص نے دانستہ ",,"Book 1, Hadith 217",,,217
218,"حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا  : ’’ اپنے آباء سے بے رغبت",,"Book 1, Hadith 218",,,218
219,خالد نے ابو عثمان سےنقل کیا کہ جب زیاد کی نسبت  (  ابوسفیان ‌رضی ‌اللہ ‌عنہ ‌ ‌  کی طرف ہونے )  کا د,,"Book 1, Hadith 219",,,219
220,عاصم نے ابو عثمان سے اور انہوں نے حضرت سعد اور حضرت ابوبکر رضی اللہ عنہما سے روایت کی ہے کہ وہ دونوں,,"Book 1, Hadith 220",,,220
221,محمد بن طلحہ  ،  سفیان اور شعبہ تینوں نے زبید سے حدیث سنائی  ،  انہوں نے ابو وائل سے اور انہوں نے حض,,"Book 1, Hadith 221",,,221
222,منصور اور اعمش دونوں نے ابووائل سے  ،  انہون نے حضرت عبداللہ بن مسعود ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے اور ان,,"Book 1, Hadith 222",,,222
223,ابو زرعہ  (  ہرم بن عمرو بن جریر بن عبد ا للہ البجلی  )  نے اپنے دادا حضرت جریر  ‌رضی ‌اللہ ‌عنہ ‌ ‌,,"Book 1, Hadith 223",,,223
224,معاذ بن معاذ نے شعبہ سے  ،  انہوں نے واقد بن محمد سے  ،  انہوں نے اپنےوالد سے  ،  ا نہوں نے حضرت ابن,,"Book 1, Hadith 224",,,224
225,"محمد بن جعفر نے کہا  :  ہم سے شعبہ نے واقد بن محمد بن زید سے حدیث بیان کی کہ انہوں نے اپنے والد سے س",,"Book 1, Hadith 225",,,225
226,"عبد اللہ بن وہب نے کہا  :  ہمیں عمر بن محمد نے حدیث بیان کی کہ ان کے والد نے انہیں حضرت ابن  عمر  ‌ر",,"Book 1, Hadith 226",,,226
227,"حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا  :  ’’ لوگوں میں دو باتیں ",,"Book 1, Hadith 227",,,227
228,منصور بن عبدالرحمٰن نے شعبی سےروایت کی ،  انہوں نے کہا کہ میں جریر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  کو کہتے ہوئ,,"Book 1, Hadith 228",,,228
229,"داؤد نے شعبی سے  ،  انہوں نے حضرت جریر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ رسول اللہ ﷺ نے فرمایا  :",,"Book 1, Hadith 229",,,229
230,"مغیرہ نے شعبی سے روایت کی  ،  انہوں نے کہا  :  حضرت جریر بن عبداللہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نبی ﷺ سے ب",,"Book 1, Hadith 230",,,230
231,حضرت زید بن جہنی  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ رسول اللہ ﷺ نے حدیبیہ کے مقام پر رات کو ہونے و,,"Book 1, Hadith 231",,,231
232,"عبید اللہ بن عبد اللہ بن عتبہ نےحدیث بیان کی کہ حضرت ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  نےکہا  :  رسول ا",,"Book 1, Hadith 232",,,232
233,محمد بن سلمہ مرادی نے اپنی سند سے اور عمرو بن سواد نے اپنی سند سے عمرو بن حارث سے روایت کی  ،  انہوں,,"Book 1, Hadith 233",,,233
234,حضرت ابن عباس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ رسول اللہ ﷺ نے دور میں لوگوں کو بارش سے نوازا گیا,,"Book 1, Hadith 234",,,234
235,انس ‌سے ‌روایت ‌ہے ‌رسول ‌اللہ ‌صلی ‌اللہ ‌علیہ ‌وسلم ‌نے ‌فرمایا ‌منافق ‌كی ‌نشانی ‌یہ ‌ہے ‌كہ ‌انص,,"Book 1, Hadith 235",,,235
236,"خالد بن حارث نے کا  :  ہمیں شعبہ نے حدیث سنائی  ،  انہوں نے عبد اللہ بن عبد اللہ سے  ،  انہوں نے حضر",,"Book 1, Hadith 236",,,236
237,"شعبہ نے عدی بن ثابت سے روایت کی  ،  انہوں نے کہا  :  میں نے حضرت براء  ‌رضی ‌اللہ ‌عنہ ‌ ‌  کو نبی ا",,"Book 1, Hadith 237",,,237
238,"حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا  : ’’ کوئی ایسا آدمی انصار",,"Book 1, Hadith 238",,,238
239,"حضرت ابو سعید  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا  :  ’’ کوئی شخص انصار سے بغ",,"Book 1, Hadith 239",,,239
240,"حضرت علی  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے کہا :  اس ذات کی قسم جس نے دانے کو پھاڑ اور روح کو تخلیق کیا ! نبی",,"Book 1, Hadith 240",,,240
241,لیث نے ابن ہادلیثی سے خبر دی کہ عبد اللہ بن دینار نےحضرت عبداللہ بن عمر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے اور,,"Book 1, Hadith 241",,,241
242,( لیث کے بجائے )  بکر بن مضر نے ابن ہاد سے اسی سند کے ساتھ اسی طرح روایت کی,,"Book 1, Hadith 242",,,242
243,عیاض بن عبد اللہ نےحضرت ابو سعید خدری  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے اورانہوں نے نبی اکرمﷺ سے اور  ( سعید ,,"Book 1, Hadith 243",,,243
244,"حضرت ابوبکر بن ابی شیبہ اور ابو کریب نے کہا  :  ہمیں ابو معاویہ نے اعمش سے حدیث سنائی  ،  انہو ں نے ",,"Book 1, Hadith 244",,,244
245,وکیع نے  اعمش سے اسی سند کے ساتھ یہی حدیث بیان کی  ۔  فرق یہ ہے کہ وکیع نے  ( فأبيت..... ’’ میں نے ا,,"Book 1, Hadith 245",,,245
246,"ابو سفیان سےروایت ہے  ،  انہوں نے کہا  :  میں نے حضرت جابر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  کو یہ کہتے ہوئے سنا",,"Book 1, Hadith 246",,,246
247,"ابو زبیر نے خبر دی کہ انہوں نے حضرت جابر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے سنا  ،  انہوں نے کہا  :  میں نے رس",,"Book 1, Hadith 247",,,247
249,( ابراہیم بن سعد کے بجائے معمر نے زہری سے اسی سند کے ساتھ یہی روایت بیان کی  ۔,,"Book 1, Hadith 249",,,249
250,ہشام بن عروہ نے اپنے والد  ( عروہ )  سے  ،  انہوں نے ابو مراوح لیثی سے اور انہون نے حضرت ابو ذر ‌رضی,,"Book 1, Hadith 250",,,250
251,( ہشام کے بجائے  )  عروہ بن زبیر کے آزاد کردہ غلام حبیب نے سابقہ سند سے یہی روایت بیان کی  ، فرق صرف,,"Book 1, Hadith 251",,,251
252,( ابو اسحاق سلیمان بن فیروز کوفی )  شیبانی نے ولید بن عیزار سے  ،  انہوں نے سعد بن ایاس ابو عمرو شیب,,"Book 1, Hadith 252",,,252
253,ابو یعفور  (  عبد  الرحمان بن عبید بن نسطانس  )  نے ولید بن عیزار کے حوالے سے ابو عمرو شیبانی سے حدی,,"Book 1, Hadith 253",,,253
254,"عبید اللہ کے والد معاذ بن معاذ عنبری نے کہا  :  ہمیں شعبہ نے ولید بن عیزار سے حدیث بیان کی  ،  انہوں",,"Book 1, Hadith 254",,,254
255,"شعبہ سے ان کے ایک شاگر د محمد بن جعفر نے اسی سند سے یہی روایت بیان کی اور اس میں یہ اضافہ کیا  :  اب",,"Book 1, Hadith 255",,,255
256,ابو عمرو شیبانی سے ان کے ایک شاگرد حسن بن عبید اللہ نے یہی روایت بیان کی کہ حضرت عبد اللہ  ‌رضی ‌الل,,"Book 1, Hadith 256",,,256
257,منصور نے ابو وائل سے  ،  انہوں نے عمروبن شرحبیل سےاور انہوں نے حضرت عبد اللہ بن مسعود ‌رضی ‌اللہ ‌عن,,"Book 1, Hadith 257",,,257
258,( منصور کے بجائے )  اعمش نے ابو وائل سے سابقہ سند کے ساتھ حضرت عبد اللہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روا,,"Book 1, Hadith 258",,,258
259,"حضرت ابو بکرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سےروایت ہے  ،  انہوں نے کہا :  ہم رسول اللہ ﷺ کی خدمت میں حاضر ت",,"Book 1, Hadith 259",,,259
260,"خالد بن حارث نے کہا  :  ہم سے شعبہ نے حدیث بیان کی  ،  انہوں نےکہا  :  ہمیں عبید اللہ بن ابی بکر نے ",,"Book 1, Hadith 260",,,260
261,"محمد بن جعفر نے کہا  :  ہم سے شعبہ نے حدیث بیان کی  ،  انہوں نے کہا  :  مجھ سے عبید اللہ بن ابی بکر ",,"Book 1, Hadith 261",,,261
262,"حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ رسو ل اللہ ﷺ نے فرمایا : ’’ سات تباہ کن گناہوں س",,"Book 1, Hadith 262",,,262
263,( یزید بن عبد اللہ )  ابن ہاد نے سعد بن ابراہیم سے  ،  انہوں نے حمید بن عبد الرحمان سے اور انہوں نے ,,"Book 1, Hadith 263",,,263
264,شعبہ اور سفیان نے بھی سعد بن ابراہیم سے اسی سند کے ساتھ اسی طرح حدیث بیان کی ہے,,"Book 1, Hadith 264",,,264
265,"یحییٰ بن حماد نے کہا  :  ہمیں شعبہ نے ابان بن تغلب سے حدیث سنائی  ،  انہوں نے فضیل بن عمرو فقیمی سے ",,"Book 1, Hadith 265",,,265
266,اعمش نے ابراہیم نخعی سے سابقہ سند کے ساتھ روایت کی کہ حضرت عبد اللہ بن مسعود ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے,,"Book 1, Hadith 266",,,266
267,( یحییٰ کے بجائے )  شعبہ کے ایک اور شاگرد ابو داؤد نے سابقہ سند کے ساتھ حضرت عبد اللہ  (  بن مسعود ),,"Book 1, Hadith 267",,,267
268,عبد اللہ بن نمیر اور وکیع نے اعمش سے  ،  انہوں نے شقیق سے اور انہوں نے حضرت عبد اللہ  ‌رضی ‌اللہ ‌عن,,"Book 1, Hadith 268",,,268
269,ابو سفیان نےحضرت جاب ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ ایک آدمی نبی اکرم ﷺ کی خدمت میں حاضر ہوا او,,"Book 1, Hadith 269",,,269
270,"ابو ایوب غیلانی سلیمان بن عبید اللہ او رحجاج بن شاعر نے کہا : ہمیں عبد الملک بن عمرو نے حدیث سنائی  ",,"Book 1, Hadith 270",,,270
271,( قرہ کے بجائے  )  ہشام نے ابوزبیر کے واسطے سے حضرت جابر بن عبد اللہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  کی حدیث س,,"Book 1, Hadith 271",,,271
272,"معرور بن سوید نےکہا  :  میں نے حضرت ابو ذر ‌رضی ‌اللہ ‌عنہ ‌ ‌  کو نبی ﷺ سے حدیث بیان کرتے ہوئے سنا ",,"Book 1, Hadith 272",,,272
273,ابو اسود دیلی نے بیان کیا کہ حضرت ابو ذر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے اس سے حدیث بیان کی کہ میں نبی اکرم,,"Book 1, Hadith 273",,,273
274,ليث  نے ابن شہاب  ( زہری )  سے  ،  انہوں نے عطاء بن یزید لیثی سے روایت کی کہ مقداد بن اسود  ‌رضی ‌ال,,"Book 1, Hadith 274",,,274
275,امام مسلم  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے معمر  ،  اوزاعی اور ابن جریج کی الگ الگ سندوں کےساتھ زہری سے سابق,,"Book 1, Hadith 275",,,275
276,"یونس نے ابن شہاب نے خبر دی  ،  انہوں نےکہا  : مجھے عطاء بن یزید لیثی جندعی نے بیان کیا کہ عبید اللہ ",,"Book 1, Hadith 276",,,276
277,"ابوبکر بن ابی شیبہ نے کہا  :  ہمیں ابو خالد احمر نے حدیث سنائی اور ابو کریب اور  اسحاق بن ابراہیم نے",,"Book 1, Hadith 277",,,277
278,"حصین نے کہا  :  ہمیں ابو ظبیان نے حدیث سنائی  ،  انہوں نےکہا  :  میں نے اسامہ بن زید بن حارثہ ‌رضی ‌",,"Book 1, Hadith 278",,,278
279,صفوان بن محرز نے حدیث بیان کی کہ حضرت ابن زبیر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے فتنے کے زمانے میں جندب بن عب,,"Book 1, Hadith 279",,,279
280,عبید ا للہ  اور امام مالک نےنافع سے اور انہو ں نے ابن عمر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ نبی ک,,"Book 1, Hadith 280",,,280
281,"ایاس بن سلمہ نے اپنے والد سے  ،  انہوں نے نبی ﷺ سے روایت کی  ،  آپ ﷺ نے فرمایا  : ’’ جس نےہم پر تلوا",,"Book 1, Hadith 281",,,281
282,"حضرت ابو موسیٰ ‌رضی ‌اللہ ‌عنہ ‌  نے نبی ﷺ سے روایت کی کہ آپ نے فرمایا  : ’’ جس نے ہمارے خلاف اسلحہ ",,"Book 1, Hadith 282",,,282
283,سہیل بن ابی صالح نے اپنے والد ابو صالح سے اور انہوں نے حضرت ابوہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ک,,"Book 1, Hadith 283",,,283
284,علاء نےاپنے والد عبدالرحمن بن یعقوب سے اور انہوں نے حضرت ابوہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی ک,,"Book 1, Hadith 284",,,284
285,"یحییٰ بن یحییٰ اور ابوبکر بن ابی شیبہ نے کہا  :  ہمیں ابو معاویہ اور وکیع نے حدیث بیان کی  ،  نیز  (",,"Book 1, Hadith 285",,,285
286,"جریر او رعیسیٰ نے اعمش سے اسی  ( سابقہ  )  سند کے ساتھ روایت کی اور دونوں نے کہا  : ’’ اور گریبان چا",,"Book 1, Hadith 286",,,286
287,قاسم بن مخیمرہ نے بیان کیا کہ مجھے ابو بردہ بن ابی موسیٰ  ( اشعری )  نے بیان کیا  ،  انہوں نے فرمایا,,"Book 1, Hadith 287",,,287
288,ابو صخرہ نے عبد الرحمن بن یزید اور ابوبردہ بن ابی موسیٰ سے  (  حضرت ابو موسیٰ ‌رضی ‌اللہ ‌عنہ ‌ ‌ کے,,"Book 1, Hadith 288",,,288
289,امام مسلم ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے تین دیگر سندوں سے حضرت ابو موسیٰ اشعری ‌رضی ‌اللہ ‌عنہ ‌ ‌  کی مذک,,"Book 1, Hadith 289",,,289
290,ابووائل نےحضرت حذیفہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے حدیث روایت کی کہ ان کو پتہ چلا کہ ایک آدمی  ( لوگوں کی ,,"Book 1, Hadith 290",,,290
291,منصور نے ابراہیم سے اور انہوں نے ہمام بن حارث سے روایت کی  ،  انہوں نے کہا کہ ایک آدمی  ( لوگوں کی  ,,"Book 1, Hadith 291",,,291
292,"اعمش نے ابراہیم سے اور انہوں نے ہمام بن حارث سے روایت کی  ،  انہوں نے کہا  :  ہم حضرت حذیفہ  ‌رضی ‌ا",,"Book 1, Hadith 292",,,292
293,ابو زرعہ سے خرشہ بن حر سے انہوں نے حضرت ابو ذر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے اور انہوں نے نبی ﷺ سے روایت ,,"Book 1, Hadith 293",,,293
294,"سفیان نے کہا  :  ہمیں سلیمان اعمش نے سلیمان بن مسہر سے حدیث سنائی  ،  انہوں نے خرشہ بن حر سے روایت ک",,"Book 1, Hadith 294",,,294
295,"( سفیان کے بجائے )  شعبہ نے سلیمان بن اعمش سے یہی روایت انہی کی سند سے بیان کی کہ آپﷺ نے فرمایا  :  ",,"Book 1, Hadith 295",,,295
296,"ابوبکر بن ابی شیبہ نے کہا  :  ہمیں ابو معاویہ اور وکیع نے اعمش سے  ، انہون نے ابو حازم سے اور انہوں ",,"Book 1, Hadith 296",,,296
297,ابوبکر بن ابی شیبہ اور ابو کریب دونوں نے کہا کہ ہمیں ابو معاویہ نے اعمش سے حدیث سنائی  ،  انہوں نے ا,,"Book 1, Hadith 297",,,297
298,جریر اور عبثر دونوں نے اپنی اپنی سند سے اعمش سے مذکورہ بالا روایت بیان کی  ،  البتہ جریر کی روایت می,,"Book 1, Hadith 298",,,298
299,عمرو نے ابو صالح سے اور انہوں نے حضرت ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  (  انہوں  (  ابو ص,,"Book 1, Hadith 299",,,299
300,وکیع نے اعمش سے  ،  انہوں نے ابو صالح سےاور انہوں نے حضرت ابوہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی,,"Book 1, Hadith 300",,,300
301,جریر  ،  عبثر بن قاسم اور شعبہ سےبھی  ،  سابقہ سند کے ساتھ  ،  مذکورہ بالا روایت بیان کی گئی ہے  ۔  ,,"Book 1, Hadith 301",,,301
302,معاویہ بن سلام دمشقی نے یحییٰ بن ابی کثیر سے روایت کی کہ ابو قلابہ نے انہیں خبر دی کہ حضرت ثابت بن ض,,"Book 1, Hadith 302",,,302
303,ہشام دستوائی نے یحییٰ بن ابی کثیر سے سابقہ سند کے ساتھ حدیث سنائی کہ حضرت ثابت بن ضحاک  ‌رضی ‌اللہ ‌,,"Book 1, Hadith 303",,,303
304,شعبہ نے ایوب سے  ،  انہوں نے ابو قلابہ سے اور انہوں نے حضرت ثابت بن ضحاک انصاری  ‌رضی ‌اللہ ‌عنہ ‌ ‌,,"Book 1, Hadith 304",,,304
305,"حضرت ابوہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے  ،  انہوں نے کہا  :  ہم رسول اللہ ﷺ کی معیت میں جنگ ",,"Book 1, Hadith 305",,,305
306,حضرت سہل بن سعد ساعدی  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سےروایت ہے کہ رسول اللہ ﷺ اور مشرکوں کا آمنا سامنا ہوا ا,,"Book 1, Hadith 306",,,306
307,"شیبان نے بیان کیا کہ میں نےحسن  ( بصری )  کو کہتے ہوئے سنا  : ’’ تم سے پہلے لوگوں میں سے ایک آدمی تھ",,"Book 1, Hadith 307",,,307
308,"( شیبان کے بجائے  )  جریر نے بیان کیا کہ میں نے حسن کو کہتے ہوئے سنا  :  ’’ ہمیں جندب بن عبد اللہ بج",,"Book 1, Hadith 308",,,308
309,"حضرت عبد اللہ بن عباس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے کہا  :  مجھے حضرت عمر بن خطاب  ‌رضی ‌اللہ ‌عنہ ‌ ‌  ن",,"Book 1, Hadith 309",,,309
310,"حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے  ،  انہوں نے کہا  :  ہم نبی ﷺ کی معیت میں خیبر کی ط",,"Book 1, Hadith 310",,,310
311,حضرت جابر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ طفیل بن عمرو دوسی نبی ﷺ کی خدمت میں حاضر ہوئے اور عرض,,"Book 1, Hadith 311",,,311
312,"عبدالعزیز بن محمد اور ابو علقمہ فروی نے کہا  :  ہمیں صفوان بن سلیم نے عبد اللہ بن سلمان کے واسطے سے ",,"Book 1, Hadith 312",,,312
313,"ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا  : ’’ ان فتنوں سے پہلے پہلے جو ",,"Book 1, Hadith 313",,,313
314,حماد بن سلمہ نے ثابت بنانی سے حدیث سنائی  ،  انہوں نے حضرت انس بن مالک  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روای,,"Book 1, Hadith 314",,,314
315,"جعفر بن سلیمان نے کہا  :  ہمیں ثابت ( بنانی  )  نے حضرت انس بن مالک ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے حدیث سنا",,"Book 1, Hadith 315",,,315
316,( جعفر بن سلیمان کے بجائے  )  سلیمان بن مغیرہ نے ثابت  ( بنانی )  سے نقل کرتے ہوئے حضرت انس  ‌رضی ‌ا,,"Book 1, Hadith 316",,,316
317,معتمر کے والد سلیمان بن طرخان نے ثابت کے واسطے سے حضرت انس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  کی روایت بیان کی کہ,,"Book 1, Hadith 317",,,317
318,منصور نے ابو وائل سے اور انہوں نے حضر ت عبد اللہ (  بن مسعود ‌رضی ‌اللہ ‌عنہ ‌ ‌  )  سے روایت کی کہ ,,"Book 1, Hadith 318",,,318
319,وکیع نے اعمش کے واسطے سے ابو وائل سے اور انہوں نے حضرت عبد اللہ بن مسعود ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روا,,"Book 1, Hadith 319",,,319
320,اعمش کے ایک اور شاگرد علی بن مسہر نے اسی سند کے ساتھ مذکورہ بالا روایت بیان کی ۔,,"Book 1, Hadith 320",,,320
321,"ابن شماسہ مہری ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے  ،  انہوں نے کہا  :  ہم عمرو بن عاص ‌رضی ‌اللہ ‌عنہ ",,"Book 1, Hadith 321",,,321
322,حضرت ابن عباس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ  ( جاہلی دور میں  )  مشرکین میں سے کچھ لوگوں نے ق,,"Book 1, Hadith 322",,,322
323,"یونس نے ابن شہاب سے خبر دی  ،  انہوں نے کہا  :  مجھے عروہ بن زبیر نےخبر دی کہ انہیں حکیم بن حزام  ‌ر",,"Book 1, Hadith 323",,,323
324,"( یونس کے بجائے  )  صالح نے ابن شہاب سے روایت کی  ،  کہا :  مجھے عروہ بن زبیر نے خبر دی کہ حکیم بن ح",,"Book 1, Hadith 324",,,324
325,ابن شہاب زہری کے ایک  اور شاگرد معمر نے اسی  ( سابقہ (  سند کے ساتھ یہی روایت بیان کی  ،  نیز  (  ای,,"Book 1, Hadith 325",,,325
326,عبد اللہ بن نمیر نے ہشام سے سابقہ سند سے روایت کی کہ حکیم بن حزام  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے دور جاہلی,,"Book 1, Hadith 326",,,326
327,عبد اللہ بن ادریس  ،  ابو معاویہ اور وکیع اعمش نے حدیث سنائی ،  انہوں نے ابراہیم سے  ،  انہوں نے علق,,"Book 1, Hadith 327",,,327
328,"اسحٰق بن ابراہیم اور علی بن خشرم نے کہا  :  ہمیں عیسٰی بن یونس نے خبر دی  ،  نیز منجاب بن حارث تمیمی",,"Book 1, Hadith 328",,,328
329,"حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ جب رسول اللہ ﷺ پر یہ آیت اتری : ’’ آسمانوں اور ز",,"Book 1, Hadith 329",,,329
330,"حضرت ابن عبا ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ انہوں نے کہا :  جب یہ آیت نازل ہوئی  : ’’ تمہارے دل",,"Book 1, Hadith 330",,,330
331,ابو عوانہ نے قتادہ سے حدیث سنائی  ،  انہوں نے زرارہ بن اوفیٰ سے اور انہوں نے حضرت ابو ہریرہ  ‌رضی ‌ا,,"Book 1, Hadith 331",,,331
332,سعید بن ابی عروبہ نے قتادہ سے  ، انہوں نے زرارہ بن اوفیٰ سے اور انہوں نے ابوہریرہ  ‌رضی ‌اللہ ‌عنہ ‌,,"Book 1, Hadith 332",,,332
333,مسعر  ، ہشام اور شیبان سب نے قتادہ سے سابقہ سند کے ساتھ اسی حدیث کی طرح روایت کی  ۔,,"Book 1, Hadith 333",,,333
334,"اعرج نے حضرت ابوہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  انہوں نے کہا  :  رسول اللہ ﷺ نے فرمایا  :",,"Book 1, Hadith 334",,,334
335,علاء کے والد عبد الرحمن بن یعقوب نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے اور انہوں نے رسول  اللہ ,,"Book 1, Hadith 335",,,335
336,"ہمام بن منبہ نے روایت کرتے ہوئے کہا  :  یہ وہ حدیثیں ہیں جو ابوہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے ہمیں م",,"Book 1, Hadith 336",,,336
337,"ابن سیرین نے حضرت ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  انہوں نے کہا  :  رسول اللہ ﷺ نے فرم",,"Book 1, Hadith 337",,,337
338,"عبدالوارث نے جعد ابو عثمان سے حدیث سنائی  ،  انہوں نےکہا  :  ہمیں ابو رجاء عطاردی نے حضرت ابن عباس  ",,"Book 1, Hadith 338",,,338
339,"جعفر بن سلیمان نے جعد ابوعثمان سے عبد الوارث کی حدیث کے ہم معنی روایت کی اور یہ اضافہ کیا  :  ’’یا ا",,"Book 1, Hadith 339",,,339
340,"سہیل نے اپنے والد سے  ،  انہوں نے ابوہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  انہوں نے کہا :  نبی",,"Book 1, Hadith 340",,,340
341,اعمش نے ابو صالح سے  ،  انہوں نے حضرت ابوہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے اور انہوں نے بنی ﷺ سے یہ حدیث,,"Book 1, Hadith 341",,,341
342,حضرت عبد اللہ  ( بن مسعود (   ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے  ،  انہوں نے کہا کہ نبی ﷺ سے وسوسے کے,,"Book 1, Hadith 342",,,342
343,سفیان نے ہشام سے حدیث سنائی  ،  انہوں نے اپنےوالد  ( عروہ )  سے  ،  انہوں نے حضرت ابوہریرہ  ‌رضی ‌ال,,"Book 1, Hadith 343",,,343
344,"ابو سعید مؤدب نے ہشام بن عروہ سے اسی سند کے ساتھ روایت کی کہ رسول ا للہ ﷺ نے فرمایا  : ’’ تم میں سے ",,"Book 1, Hadith 344",,,344
345,ابن شہاب کے بھتیجے  (  محمد بن عبد اللہ بن مسلم  )  نے اپنے چچا  (  محمد بن مسلم زہری  )  سے حدیث سن,,"Book 1, Hadith 345",,,345
346,"عقیل بن خالد نے کہاکہ ابن شہاب نے کہا  :  مجھے عروہ بن زبیر نے خبر دی کہ حضرت ابوہریرہ  ‌رضی ‌اللہ ‌",,"Book 1, Hadith 346",,,346
347,عبد الوارث بن عبد ا لصمد کے دادا عبد الوارث بن سعید نے ایوب سے  ،  انہوں نے محمد بن سیرین سے  ،  انہ,,"Book 1, Hadith 347",,,347
348,اسماعیل بن علیہ نے ایوب سے  ،  انہوں نے محمد سے روایت کی کہ حضرت ابوہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے ک,,"Book 1, Hadith 348",,,348
349,"ابو سلمہ نے حضرت ابوہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  انہوں نے کہا  : مجھ سے رسول اللہ ﷺ ن",,"Book 1, Hadith 349",,,349
350,"یزید بن اصم نے کہا  :  میں نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے سنا  ،  وہ کہتے تھے  :  رسول ا",,"Book 1, Hadith 350",,,350
351,محمد بن فضیل نے مختار بن فلفل سے  ،  انہوں نے حضرت انس بن مالک ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے  ،  انہوں نے ,,"Book 1, Hadith 351",,,351
352,"اسحق بن ابراہیم نے کہا :  ہمیں جریر نے خبر دی  ،  نیز ابو بکر بن ابی شیبہ نے کہا  :  ہمیں حسن بن علی",,"Book 1, Hadith 352",,,352
353,معبد بن کعب سلمی نے اپنے بھائی عبد اللہ بن کعب سے  ،  انہوں نے حضرت ابو امامہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  ,,"Book 1, Hadith 353",,,353
354,محمد بن کعب سے روایت ہے  ،  انہوں نےاپنے بھائی عبد اللہ بن کعب سےسنا  ،  وہ بیان کر تے تھے کہ ابو ام,,"Book 1, Hadith 354",,,354
355,اعمش نے ابو وائل سے  ،  انہوں نے حضرت عبد اللہ  (  بن مسعود )   ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے اور انہوں نے,,"Book 1, Hadith 355",,,355
356,( اعمش کے بجائے  )  منصور نے ابووائل سے اور انہوں نے عبداللہ بن مسعود ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ,,"Book 1, Hadith 356",,,356
357,"جامع بن ابی راشد اور عبد المالک بن اعین نے  ( ابو وائل )  شقیق بن سلمہ سے سنا  ،  کہہ رہے تھے  : میں",,"Book 1, Hadith 357",,,357
358,سماک نے علقمہ بن وائل سے  ،  انہوں نے اپنے والد (  حضرت وائل بن حجر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  )  سے روای,,"Book 1, Hadith 358",,,358
359,زہیر بن حرب اور اسحاق بن ابراہیم دونوں نے ابو ولید سے حدیث سنائی  ( زہیر نے عن أبى الولید کے بجائے ح,,"Book 1, Hadith 359",,,359
360,"حضرت ابوہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے  ،  انہوں نے کہا  :  ایک آدمی رسول اللہ ﷺ کی خدمت می",,"Book 1, Hadith 360",,,360
361,"عبد الرزاق نے کہا  :  ہمیں ابن جریج نے خبر دی ،  انہوں نے کہا  :  مجھے سلیمان احول نے خبر دی کہ عمر ",,"Book 1, Hadith 361",,,361
362,( ابن جریج کے دوسرے شاگردوں  )  محمد بن بکر اور ابو عاصم نےاسی مذکورہ سند کے ساتھ  (  سابقہ حدیث  ) ,,"Book 1, Hadith 362",,,362
363,"ابو اشہب نے حسن ( بصری )  سے حدیث بیان کی  ،  انہوں نے کہا  : عبید اللہ بن زیاد نےحضرت معقل بن یسار ",,"Book 1, Hadith 363",,,363
364,"( ابو اشہب کے بجائے  )  یونس نے حسن سے روایت کی  ،  انہوں نےکہا :  عبید اللہ بن زیاد حضرت معقل بن یس",,"Book 1, Hadith 364",,,364
365,"(  ایک اور سند سے  )  ہشام سے روایت ہے  ،  انہوں نےکہا :  حسن نے کہا  :  ہم معقل بن یسار ‌رضی ‌اللہ ",,"Book 1, Hadith 365",,,365
366,ابو ملیح  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ عبید اللہ بن زیاد نےمعقل بن یسار ‌رضی ‌اللہ ‌عنہ ‌ ‌  ,,"Book 1, Hadith 366",,,366
367,ابو معاویہ اور وکیع نے اعمش سے حدیث سنائی  ،  انہوں نے زید بن وہب سے اور انہوں نے حضرت حذیفہ  ‌رضی ‌,,"Book 1, Hadith 367",,,367
368,( اعمش کےدوسرے شاگردوں  )  عبد اللہ بن نمیر  ،  وکیع اور عیسیٰ بن یونس نے بھی اسی سند کے ساتھ مذکورہ,,"Book 1, Hadith 368",,,368
369,ابو خالد سلیمان بن حیان نے سعد بن طارق سے حدیث سنائی ،  انہوں نے ربعی سے اور انہوں نے حضرت  حذیفہ  ‌,,"Book 1, Hadith 369",,,369
370,"مروان فزاری نے کہا  :  ہمیں ابو مالک اشجعی نے حضرت ربعی سے حدیث سنائی  ،  انہوں نےکہا : جب حذیفہ  ‌ر",,"Book 1, Hadith 370",,,370
371,نعیم بن ابی ہند نے ربعی بن حراش سے اور انہوں نےحضرت حذیفہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ حضرت ,,"Book 1, Hadith 371",,,371
372,"حضرت ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے  ،  انہوں نے کہا  :  رسو ل اللہ ﷺ نے فرمایا  :  ’’اس",,"Book 1, Hadith 372",,,372
373,"سیدنا عبداللہ بن عمر ؓ سے روایت ہے ، رسول اللہ ﷺ نے فرمایا : ” اسلام شروع ہوا غربت میں اور پھر غریب ",,"Book 1, Hadith 373",,,373
374,"حضرت ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ رسو ل اللہ ﷺ نے فرمایا  :  ’’ بلاشبہ ایمان مدینہ ",,"Book 1, Hadith 374",,,374
375,"حماد نے کہا :  ہمیں ثابت نے حضرت انس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے حدیث سنائی کہ رسول اللہ ﷺ نے فرمایا : ",,"Book 1, Hadith 375",,,375
376,معمر نے ثابت سے خبر دی  ،  انہوں نے حضرت انس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  انہوں نے کہا کہ ر,,"Book 1, Hadith 376",,,376
377,"حضرت حذیفہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سےروایت ہے ،  انہوں نے کہا  :  ہم رسو ل اللہ ﷺ کے ساتھ تھے ،  آپ نے",,"Book 1, Hadith 377",,,377
378,سفیان نے زہری سے حدیث بیان کی ،  انہوں نے عامر بن سعد (  بن ابی وقاص )  سے اور انہوں نے اپنے والد سے,,"Book 1, Hadith 378",,,378
379,"ابن شہاب  ( زہری )  کے بھتیجے نے اپنے چچا سے حدیث بیان کی  ، انہوں نے کہا  :  مجھے عامر بن سعد بن اب",,"Book 1, Hadith 379",,,379
380,"صالح نے ابن شہاب سے روایت کی  ،  انہوں نے کہا  :  مجھے عامر بن سعد نے اپنے والد  ( حضرت  )  سعد ‌رضی",,"Book 1, Hadith 380",,,380
381,"( عامر بن سعد کے بھائی )  محمد بن سعد یہ حدیث بیان کرتے ہیں  ،  انہوں نے اپنی حدیث میں کہا :  رسول  ",,"Book 1, Hadith 381",,,381
382,یونس نے ابن شہاب زہری سے خبر دی ،  انہوں نے ابو سلمہ بن عبد الرحمن اور سعید بن مسیب سے روایت کی  ،  ,,"Book 1, Hadith 382",,,382
383,مالک نے زہری سے روایت کی کہ سعید بن  مسیب اور ابوعبیدہ نے انہیں حضرت ابوہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  ,,"Book 1, Hadith 383",,,383
385,"حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ رسو ل اللہ ﷺ نے فرمایا :  ’’ انبیاء میں سے ہر ای",,"Book 1, Hadith 385",,,385
386,حضرت ‌ابو ‌ہریرہ ‌رضی ‌اللہ ‌عنہ ‌سے ‌روایت ‌ہے ‌رسول ‌اللہ ‌صلی ‌اللہ ‌علیہ ‌وسلم ‌نے ‌فرمایا ‌. ‌ق,,"Book 1, Hadith 386",,,386
387,"ہشیم نے صالح بن صالح ہمدانی سے خبر دی  ،  انہوں نے شعبی سےروایت کی  ،  انہوں نے کہا :  میں نے اہل خر",,"Book 1, Hadith 387",,,387
389,لیث نے ابن شہاب سے حدیث سنائی  انہوں نے ابن مسیب  سے انہوں نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  س,,"Book 1, Hadith 389",,,389
390,سفیان بن عیینہ  ،  یونس اور صالح نے  (  ابن شہاب )  زہری سے  ( ان کی  )  اسی سند سے روایت نقل کی  ۔ ,,"Book 1, Hadith 390",,,390
391,"عطاء بن میناء نے حضرت ابوہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے بیان کیا کہ رسول اللہ ﷺ نے فرمایا  :  ’’ الل",,"Book 1, Hadith 391",,,391
392,"یونس نے ابن شہاب سے روایت کی  ،  انہوں نے کہا  :  ابوقتادہ انصاری  ‌رضی ‌اللہ ‌عنہ ‌ ‌  کے آزاد کردہ",,"Book 1, Hadith 392",,,392
393,ابن شہاب کے بھتیجے نے اپنے چچا  (  ابن شہاب  )  کے سابقہ سند کے ساتھ حضرت ابوہریرہ  ‌رضی ‌اللہ ‌عنہ ,,"Book 1, Hadith 393",,,393
394,ابن ابی ذئب نے ابن شہاب سے سابقہ سند کے ساتھ حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ رسو,,"Book 1, Hadith 394",,,394
395,حضرت  جابر بن عبد اللہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  بیان کرتے ہیں  ،  میں نے رسول اللہ ﷺ کو فرماتے ہوئے سنا,,"Book 1, Hadith 395",,,395
396,علاء بن عبد الرحمن نے اپنے والد سے اور انہوں نے حضرت ابوہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ رس,,"Book 1, Hadith 396",,,396
397,ابو زرعہ  ،  عبدالرحمن اعرج اور ہمام بن منبہ سے بھی حضرت ابوہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے اسی جیسی ,,"Book 1, Hadith 397",,,397
398,"ابو حازم نے حضرت ابوہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ رسول اللہ ﷺ نے فرمایا : ’’ تین چیزیں ہ",,"Book 1, Hadith 398",,,398
399,"اسماعیل  )  ابن علیہ نے کہا :  ہمیں یونس نے ابراہیم بن یزید تیمی کے حوالے سے حدیث سنائی  ،  میرے علم",,"Book 1, Hadith 399",,,399
400,خالد بن عبد اللہ نے یونس سے سابقہ سند کے ساتھ حضرت ابو ذر ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ  ایک د,,"Book 1, Hadith 400",,,400
401,"ابو معاویہ نے کہا :  ہمیں اعمش نے ابراہیم تیمی سے سابقہ سند کے ساتھ حضرت ابو ذر  ‌رضی ‌اللہ ‌عنہ ‌ ‌",,"Book 1, Hadith 401",,,401
402,وکیع نے اعمش سے سابقہ سند کے ساتھ حضرت ابو ذر ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ میں نے رسول اللہ ﷺ,,"Book 1, Hadith 402",,,402
403,"یونس نے ابن شہاب  ( زہری )  سے خبر دی  ،  انہوں نے کہا :  مجھے عروہ بن زبیر نے حدیث سنائی کہ حضرت عا",,"Book 1, Hadith 403",,,403
404,"ہمیں معمر نے خبر دی کہ انہوں نے کہا :  مجھے عروہ نے حضرت عائشہ ؓ سے خبر دی کہ انہوں نے کہا :  رسو ل ",,"Book 1, Hadith 404",,,404
405,"عقیل بن خالد نے بیان کیا کہ ابن شہاب نے کہا :  میں نے عروہ بن زبیر کو یہ کہتے ہوئے سنا :  نبی ﷺ کی ز",,"Book 1, Hadith 405",,,405
406,"یونس نے  ( اپنی سند کے ساتھ )  ابن شہاب سے بیان کیا  ،  انہوں نے کہا  :  مجھے ابو سلمہ بن عبد الرحمن",,"Book 1, Hadith 406",,,406
407,"عقیل بن خالد نے ابن شہاب سے بیان کیا ،  انہوں نے کہا  :  میں نے ابو سلمہ بن عبد الرحمن کو یہ کہتے ہو",,"Book 1, Hadith 407",,,407
408,"معمر نے زہری سے اسی سند کےساتھ یونس کی طرح حدیث بیان کی  ( اس میں یہ  )  کہا  : تو اللہ تبارک وتعالی",,"Book 1, Hadith 408",,,408
409,"اوزاعی نے کہا :  میں نے یحییٰ سے سنا ،  کہتے تھے :  میں نے ابوسلمہ سے سوال کیا  :  ’’ قرآن کا کون سا",,"Book 1, Hadith 409",,,409
410,"علی بن مبارک نے بھی یحییٰ بن ابی کثیر سے اسی سند کے ساتھ روایت کی اور کہا : ’’ تو وہ آسمان و زمین کے",,"Book 1, Hadith 410",,,410
411,"سیدنا انس بن مالک رضی اللہ عنہ سے روایت ہے، رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”میرے سامنے براق",,"Book 1, Hadith 411",,,411
412,"سلیمان بن مغیرہ نے کہا :  ہمیں ثابت نے حضرت انس بن مالک ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے حدیث بیان کی  ،  انہ",,"Book 1, Hadith 412",,,412
413,( سلیمان بن مغیرہ کے بجائے  )  حماد بن سلمہ نے ثابت کے واسطے سے حضرت انس بن مالک ‌رضی ‌اللہ ‌عنہ ‌ ‌,,"Book 1, Hadith 413",,,413
414,"شریک بن عبد اللہ بن ابی نمر نے حدیث سنائی  ( کہا )  :  میں نے حضرت انس بن مالک  ‌رضی ‌اللہ ‌عنہ ‌ ‌ ",,"Book 1, Hadith 414",,,414
415,"ابن شہاب نے حضرت انس بن مالک ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  انہوں نے کہا :  حضرت ابوذر ‌رضی ‌ا",,"Book 1, Hadith 415",,,415
416,سعید نے قتادہ سے اور انہوں نے حضرت انس بن مالک ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  (  انہوں نے غالباً ,,"Book 1, Hadith 416",,,416
417,"ہشام نے قتادہ سے حدیث سنائی ،   (  انہوں نے کہا :  ) ہمیں انس بن مالک ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے حضرت م",,"Book 1, Hadith 417",,,417
418,"شعبہ نے ا بو قتادہ سے حدیث سنائی  ،  انہوں نے کہا :  میں نے ابو عالیہ سے سنا  ، وہ کہہ رہے تھے  :  م",,"Book 1, Hadith 418",,,418
419,شیبان بن عبد الرحمن نے قتادہ کے حوالے سے سابقہ سند کے ساتھ حدیث سنائی کہ ہمیں تمہارے نبی ﷺ کے چچازاد,,"Book 1, Hadith 419",,,419
420,"احمد بن حنبل اور سریج بن یونس نے کہا :  ہمیں ہشیم نے حدیث سنائی  ،  انہوں نے کہا  :  ہمیں داؤد بن اب",,"Book 1, Hadith 420",,,420
421,ابن ابی عدی نے داؤد سے حدیث سنائی  ،  انہوں نےابو عالیہ سے اور انہوں نے حضرت ابن عباس ‌رضی ‌اللہ ‌عن,,"Book 1, Hadith 421",,,421
422,"مجاہد سے روایت ہے کہ انہوں نے کہا :  ہم ابن عباس ‌رضی ‌اللہ ‌عنہ ‌ ‌  کے پاس تھے تو لوگوں نے دجال کا",,"Book 1, Hadith 422",,,422
423,قتیبہ بن سعید اور محمد بن رمح نے لیث سے انہوں نے ابو زبیر سے اور انہوں نے حضرت جابر  ‌رضی ‌اللہ ‌عنہ,,"Book 1, Hadith 423",,,423
424,"حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے  ، کا  :  نبی کریم ﷺ نے فرمایا : ’’جب مجھے اسراء کر",,"Book 1, Hadith 424",,,424
425,مالک (  بن انس )  نے نافع سے اور ا نہوں نے حضرت عبد اللہ بن عمر ‌رضی ‌اللہ ‌عنہ ‌ ‌ سے روایت کی کہ ر,,"Book 1, Hadith 425",,,425
426,"موسیٰ بن عقبہ نے نافع سے روایت کی  ،  انہوں نے کہا :  حضرت عبد اللہ بن عمر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے ",,"Book 1, Hadith 426",,,426
427,حنظلہ نے سالم کے واسطے سے حضرت ابن عمر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے حدیث سنائی کہ رسول اللہ ﷺ نے فرمایا ,,"Book 1, Hadith 427",,,427
428,"حضرت جابر بن عبد اللہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ رسو ل اللہ ﷺ نے فرمایا : ’’ جب قریش نے مج",,"Book 1, Hadith 428",,,428
429,ابن شہاب نےسالم بن عبد اللہ بن عمر سے  ،  انہوں نے اپنے والد حضرت عبد اللہ بن عمر  ‌رضی ‌اللہ ‌عنہ ‌,,"Book 1, Hadith 429",,,429
430,"حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ سے روایت ہے کہ رسو ل اللہ ﷺ نے فرمایا : ’’ میں نے اپنے آپ کو حجر (  ",,"Book 1, Hadith 430",,,430
431,"حضرت عبد اللہ  (  بن مسعود )   ‌رضی ‌اللہ ‌عنہ ‌ ‌  سےروایت ہے  ،  انہوں نے کہا :  جب رسول اللہ ﷺ کو",,"Book 1, Hadith 431",,,431
432,"عباد بن عوام نے کہا :  ہمیں شیبانی نے خبر دی ،  انہوں نے کہا :  میں نے زربن حبیش سے اللہ تعالیٰ کے ا",,"Book 1, Hadith 432",,,432
433,حفص بن غیاث نے شیبانی سے حدیث سنائی ،  انہوں نے زر سے  ،  انہوں نے حضرت عبداللہ  (  بن مسعود )   ‌رض,,"Book 1, Hadith 433",,,433
434,شعبہ نے سلیمان شیبانی سے حدیث بیان کی ،  انہوں نے زربن حبیش سے سنا کہا کہ حضرت عبداللہ  (  بن مسعود ,,"Book 1, Hadith 434",,,434
435,حضرت ابو ھریرہ رضی اللہ عنہ سے روایت ہے کہ  ( اللہ کے فرمان ) آپ ﷺنے اسے ایک اور بار اترتےہوئے دیکھا,,"Book 1, Hadith 435",,,435
436,"عطاء نے حضرت ابن عباس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  انہوں نے کہا :  آپ ﷺ نے اسے  ( رب تعالیٰ",,"Book 1, Hadith 436",,,436
437,"وکیع نے کہا :  ہمیں اعمش نے زیاد بن حصین ابو جہمہ سے حدیث سنائی  ،  انہوں نے ابو عالیہ سے اور انہوں ",,"Book 1, Hadith 437",,,437
438,"( وکیع کے بجائے )  حفص ابن غیاث نے اعمش سے حدیث سنائی ،  انہوں نے کہا :  ہمیں ابو جہمہ  ( زیاد بن حص",,"Book 1, Hadith 438",,,438
439,"اسماعیل بن ابراہیم نے داود سے  ،  انہوں نے شعبی سے اور انہوں نے مسروق سے روایت کی  ،  کہا  :  میں حض",,"Book 1, Hadith 439",,,439
440,"( اسماعیل کے بجائے  )  عبدالوہاب نے کہا :  ہمیں داود نے اسی طرح حدیث سنائی  (  اسماعیل بن ابراہیم  )",,,,,440
441,اسماعیل  ( بن ابی خالد )  نے  (  عامر بن شراحیل  )  شعبی سے حدیث بیان کی  ،  انہوں نے مسروق سے روایت,,,,,441
442,"( سعید بن عمرو )  ابن اشوع نے عامر ( شعبی )  سے ،  انہوں نے مسروق سے روایت کی  ،  انہوں نے کہا :  می",,,,,442
443,یزید بن ابراہیم نے قتادہ سے  ،  انہوں نے عبد اللہ بن شقیق سے اور انہوں نے حضرت ابو ذر ‌رضی ‌اللہ ‌عن,,,,,443
444,ہشام او رہمام دونوں نے دو مختلف سندوں کے ساتھ قتادہ سے حدیث بیان کی  ،  انہوں نے عبد اللہ بن شقیق سے,,,,,444
445,"ابو بکر بن ابی شیبہ اور ابو کریب نے کہا :  ہمیں ابو معاویہ نےحدیث بیان کی  ،  انہوں نے کہا :  ہمیں ا",,,,,445
446,"اعمش کے ایک اور شاگرد جریر نے اسی  (  مذکورہ )  سند سے روایت کی ،  کہا :  رسول اللہ ﷺ ہمارے درمیان ک",,,,,446
447,شعبہ نے عمرو بن مرہ کے حوالے سے ابو عبیدہ سےاور انہوں نے حضرت ابو موسیٰ اشعری  ‌رضی ‌اللہ ‌عنہ ‌ ‌  ,,,,,447
448,"عبد اللہ بن قیس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ نبی ﷺ نے فرمایا : ’’دو جنتیں چاندی کی ہیں  ،  ا",,,,,448
449,"عبد الرحمن بن مہدی نے کہا :  ہمیں حماد بن سلمہ نے ثابت بنانی سے حدیث بیان کی  ،  انہوں نے عبد الرحمن",,,,,449
450,( عبد الرحمن بن مہدی کےبجائے )  یزید بن ہارون نے حماد بن سلمہ سے اسی سند کے ساتھ حدیث بیان کی  ۔  اس,,,,,450
451,"یعقوب بن ابراہیم نے حدیث بیان کی  ،  کہا :  میرے والد نے ہمیں ابن شہاب زہری سے حدیث سنائی  ،  انہوں ",,,,,451
452,"شعیب نے ابن شہاب زہری سے خبر دی  ،  انہوں نے کہا :  عطاء اور سعید بن مسیب نے مجھے خبر دی کہ حضرت ابو",,,,,452
453,"ہمام بن منبہ سے روایت ہے  ،  انہوں نے کہا :  یہ احادیث ہیں جو حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  ن",,,,,453
454,حفص بن میسرہ نے زید بن اسلم سے  ،  انہوں نے عطاء بن یسار سے اور انہوں نے حضرت ابو سعید خدری ‌رضی ‌ال,,,,,454
455,"امام مسلم نے کہا :  میں نے شفاعت کے بارے میں یہ حدیث عیسیٰ بن حماد زغبہ مصری کے سامنے پڑھی اور ان سے",,,,,455
456,زید بن اسلم کے ایک اور شاگرد ہشام بن سعد نے بھی ان دونوں  ( حفص اور سعید )  کی مذکورہ سندوں کے ساتھ ,,,,,456
457,"مالک بن انس نے عمرو بن یحییٰ بن عمارہ سے خبر دی ،  انہوں نے کہا :  میرے والد نے مجھے حضرت ابوسعید خد",,,,,457
458,"وہیب اور خالد دونوں نے عمرو بن یحییٰ سے اسی سند کے ساتھ یہی روایت بیان کی  ۔  اس میں ہے  : ’’انہیں ا",,,,,458
459,بشر بن مفضل نے ابو مسلمہ سے حدیث سنائی ،  انہوں نے ابو نضرہ سے  ،  انہوں نے حضرت ابو سعید ‌رضی ‌اللہ,,,,,459
460,( بشر کےبجائے )  شعبہ نے ابومسلمہ سے حدیث سنائی کہا ،  میں نے ابونضرہ سے سنا ،   ( انہوں نے )  حضرت ,,,,,460
461,منصور نے ابراہیم سے  ،  انہوں نے عبیدہ سے ،  انہوں نے حضرت عبد اللہ بن مسعود  ‌رضی ‌اللہ ‌عنہ ‌ ‌  س,,,,,461
462,( منصور کے بجائے )  اعمش نے ابراہیم سے ،  سابقہ سند کے ساتھ  ،  عبد ہ اللہ بن مسعود  ‌رضی ‌اللہ ‌عنہ,,,,,462
463,انس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نےحضرت ابن مسعود ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ رسول اللہ ﷺ نے فرمایا,,,,,463
464,"حضرت ابو سعید خدری ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا : ’’اہل جنت میں سب سے ک",,,,,464
465,"ہمیں سعید بن عمر و اشعثی نے حدیث بیان سنائی ،  کہا :  ہمیں سفیان بن عیینہ نے حدیث سنائی  ،  انہوں نے",,,,,465
466,"ہا :  میں نے شعبی سے سنا ،  انہوں نے کہا :  میں نے مغیرہ بن شعبہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے سنا ،  وہ ",,,,,466
467,"محمد بن عبد اللہ بن نمیر نے ہمیں اپنے والد سے حدیث بیان کی  ،  کہا :  ہمیں اعمش نے معرور بن سوید سے ",,,,,467
468,اعمش کے دوشاگردوں ابو معاویہ اور وکیع نے اپنی اپنی سند کے ساتھ مذکورہ بالا روایت بیان کی  ۔,,,,,468
469,ابو زبیر نے بتایا کہ انہوں نے حضرت جابر بن عبد اللہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے سنا ،  ان سے  ( جنت اور,,,,,469
470,سفیان بن عیینہ نے عمر  (  بن دینار )  سے روایت کی کہ انہوں نے حضرت جابر ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے سنا ,,,,,470
471,"حماد بن زید نے کہا :  میں نے عمر وبن دینارسے پوچھا :  کیا آپ نے جابربن عبداللہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  ",,,,,471
472,"قیس بن سلیم عنبری سے کہا :  یزید الفقیر نے مجھے حدیث بیان کی کہ حضرت جابربن عبد اللہ  ‌رضی ‌اللہ ‌عن",,,,,472
473,"م  ، یعنی محمد بن ابی ایوب نے کہا :  مجھے یزید الفقیر نےحدیث سنائی ،  انہوں نے کہا :  کہ خارجیوں کے ",,,,,473
474,"ابو عمران  اور ثابت نے حضرت انس بن مالک  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ رسول اللہ ﷺ نے فرمایا :",,,,,474
475,"ابو کامل فضیل بن حسین جحدری اور محمد بن عبید غبری نے کہا :   ( الفاظ ابو کامل کے ہیں  )  ہمیں ابو عو",,,,,475
476,دوسری سند سے جس میں  (  ابو عوانہ کے بجائے )  سعید نے قتادہ سے اور انہوں نے حضرت انس  ‌رضی ‌اللہ ‌عن,,,,,476
477,"معاذ بن ہشام نے کہا :  میرے والد نے مجھے قتادہ کے حوالے سے حدیث سنائی اور انہوں نے حضرت انس بن مالک ",,,,,477
478,"محمد بن منہال الضریر  ( نابینا )  نے کہا :  ہمیں یزید بن زریع نے حدیث سنائی  ،  انہوں نے کہا :  ہمیں",,,,,478
479,"معبد بن ہلال عنزی نے کہا :  ہم لوگ انس بن مالک ‌رضی ‌اللہ ‌عنہ ‌ ‌  کے پاس گئے اور ثابت  ( البنانی )",,,,,479
480,ابو حیان نے ابو زرعہ سے اور انہوں نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  انہوں نےکہ,,,,,480
481,ایک دوسرے سند سے  )  عمارہ بن قعقاع نے ابو زرعہ سے  ،  انہوں نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌ ,,,,,481
482,"محمد بن فضیل  نے کہا :  ہمیں ابو مالک اشجعی نے حدیث سنائی  ،  انہوں نے ابو حازم سے اور انہوں نے حضرت",,,,,482
483,جریر نےمختار بن فلفل سے  ، انہوں نے حضرت انس بن مالک ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  انہوں نےکہ,,,,,483
484,وَحَدَّثَنَا أَبُو كُرَيْبٍ مُحَمَّدُ بْنُ الْعَلَاءِ ،  حَدَّثَنَا مُعَاوِيَةُ بْنُ هِشَامٍ ،  عَنْ,,,,,484
485,"زائدہ نےمختار بن فلفل سے روایت کی  ،  انہوں نے کہا :  حضرت انس بن مالک ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے کہا ک",,,,,485
486,ثابت نے حضرت  انس بن مالک ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے حدیث بیان کی  ،  انہوں نے کہا کہ رسول اللہ ﷺ نے فر,,,,,486
487,مالک بن انس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے ابن شہاب سے خبر دی  ،  انہوں نے ابو سلمہ بن  عبد الرحمن سے اور ,,,,,487
488,"( مالک بن ا نس کے بجائے  )  ابن شہاب کے بھتیجے نے ابن شہاب سے حدیث سنائی ،  انہوں نے کہا  :  مجھے اب",,,,,488
489,ابن شہاب کے بھتیجے نے ابن شہاب سے اور انہوں نے  (  ابو سلمہ کے بجائے )  عمرو بن ابی سفیان بن اسید بن,,,,,489
