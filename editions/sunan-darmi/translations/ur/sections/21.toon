hadiths[77]{hadithnumber,text}:
2671,"ضۏٔزىتأتثًضؼۏزأرزشۏأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأتثًوًضۏٳأتطؼشۏأشعۏأتههۄأؼىۄأىەأضۏٔزىتأؼوشأشعۏأتههۄأؼىۄأضەأحۏىأزلؼۄأتدتصحأوتىڲۏأۗأتًشأتىۄۏڽأتدتصحأىۄأزۏأڲةۏأًۄأًتځضأډهەأڲةەأۗأتىۄًڽأىەأڬۄتأ=أًتځضأڬۏًڽأډهەأآأڬۄتأ=أوۏڽأىەأشضًهأتههۄأ﷽أضەأضىتأًۄألشوتحەأحہەأ=““أتدتصحأهۏىەأًتهەأڬًأحۏىأزلؼۄأتدتصحأهۏىۏأډتۄةەأتڲشأتضەأتدتصحأوهأدتةەأحًأټہۏڬأًڲشىۄأًتځضأهًټأإةەأۗ‛‛أضۏٔزىتأؼوشأشعۏأتههۄأؼىۄأىەأڬۄتأ=““أتضأثتحأڬتأڲًتۄأهتاأًشىۄأوۏڽأحوأضەأثشتأضهًڬأڬشًڽأڲتأۗ‛‛أتثًضؼۏزأڬۄحەأۄۏڽأ=أوۏڽأوضدزأوۏڽأشضًهأتههۄأ﷽أڬەأډىزأتظذتثأڬەأضتحہأثۏټہتأحہتأًۄأؼوشأشعۏأتههۄأؼىۄأڬۏأزہوڬۏأضەأڲہثشتةەأۄًةەأإةەأۗأتًشأۄوتشەأځتضأڬہڔەأۄًأڬشأڬۄتأ=أوۏڽأحوۄۏڽأمضوأزۏحتأۄًڽأدضأىەأۏۄأثتحأشضًهأتههۄأ﷽أضەأضىۏأۄەأًۄأوۏشەأهةەأڲًتۄۏأزەأحًأوۏڽأىەأضشأتټہتأڬشأڬۄتأ=أتىأضەأڬۄًأوۏڽأتضأثتحأوۏڽأحوۄتشەأضتحہأۄًڽأ‛أزًضشەأهًڲًڽأىەأثہۏأتۏضتأۄۏأڬۄتأحًأتثًوًضۏٳأشعۏأتههۄأؼىۄأوغوةىأۄًأڲةەأۗ

[تخریج]: !متفق علیہ: البخاری،کتاب الإستیذان، باب التسلیم والاستئذان ثلاثًا(6245)ومسلم،کتاب الآداب،باب الاستئذان (5592)"
2672,"ضۏٔزىتأدتثشأثىأؼثزتههۄأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأوۏڽأىەأشضًهأتههۄأ﷽أڬەأځتضأدتأڬشأزشًتصۄأڬہټڬہټتۏتأإځأىەألشوتۏتأ=أڬًىأآأوۏڽأىەأڬۄتأ=““أوۏڽأۗ‛‛أإځأىەألشوتۏتأ=““أوۏڽأ‛أوۏڽأڬۏتأإځأىەأتضەأىتځضىزأڬۏتأۗ

[تخریج]: @متفق علیہ: البخاری،کتاب الإستئذان،باب اذا قال من ذا؟ فقال أن(6250)ومسلم،کتاب الآداب،باب فی کراہیۃ قول المستأذن،أنا،اِذا قیل من ہذا؟(5600)"
2673,"ضۏٔزىتأدتثشأثىأؼثزتههۄأشعۏأتههۄأؼىۄوتأڬۄحەأۄۏڽأشضًهأتههۄأ﷽أىەأتضأثتحأضەأوىؼأڬۏتأڬۄأإزوۏأضلشأضەأإحەأۄۏأتځىۏأثۏًۏأڬەأځتضأإةەأۗأتًشأتضأڬًأرتةىأمشتشأزەأتًشأتضأڬەأؼۏثأحهتطأڬشەأۗأضلۏتىأڬۄحەأۄۏڽأ=أودہەأؼهوأىۄۏڽأڬۄأىمظتىأتًشأؼۏثأڋہًىڋىەأڬۏأووتىؼحأوذتشثأڬتأمًهأۄەأۏتأذزۏخأڬەأتهلتػأۄۏڽأۗ

[تخریج]: !متفق علیہ: البخاری،کتاب العمرۃ،باب لایطرق أہلہ اذا بلغ المدینہ(1801)ومسلم،کتاب الإمارۃ،باب کراہیۃ الطروق (4946)"
2674,"ضۏٔزىتأؼثزتههۄأثىأضهتوأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأدثأشضًهأتههۄأ﷽أوزۏىۄأحطشۏلأهتةەأۗأهًڲأإځأڬًأزۏڬہىەأڲةەأًۄأڬۄۄأشۄەأحہەأ=““أشضًهأتههۄأ﷽أحطشۏلأهتةەأۗأتًشأهًڲًڽأڬەأضتحہأوۏڽأثہۏأإځأڬًأزۏڬہىەأڲۏتأۗأدثأوۏڽأىەأإځأڬۏأظًشحأزۏڬہۏأتضۏأًمحأځۄډتىأڲۏتأڬۄأۏۄأدہًټۏأظًشحأىۄۏڽأۄەأۗأتًشأځۄهۏأثتحأدًأوۏڽأىەأإځأضەأضىۏأًۄأۏۄأحہۏأۗ‛‛أإځألشوتأشۄەأحہەأ=““أضهتوأڬًأؼتوأڬشًأ‛أڬہتىتأڬہهتاأ‛أشطحۄأزتشًڽأڬەأضتحہأىۏڬۏأڬشًأ‛أتضأًمحأىوتصأځڔہًأدثأهًڲأضًأشۄەأۄًڽأ‛أحوأضهتوحۏأڬەأضتحہأدىحأوۏڽأزترهأۄًأدتاأڲەأۗ‛‛

[تخریج]: !صحیح: أخرجہ الترمذی،کتاب صفۃ القیامۃ،باب (42)(2485)وابن ماجہ،کتاب اقامۃ الصلاۃ والسنۃ فیہا (1334) والحکام3/13"
2675,"ضۏٔزىتأؼهۏأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أوضهوتىأڬەأوضهوتىأځشأډہأذمأۄۏڽأ=أدثأتضەأوهەأحًأضهتوأڬۄەأ‛أدثأًۄأډہۏىڬەأتضەأزؼتأزەأ‛أدثأثۏوتشأۄًأتضأڬۏأؼۏتزحأڬشەأ‛أدثأًۄأزؼًحأزەأحًأمثًهأڬشەأ‛أتًشأدثأًۄأوشأدتةەأحًأتضأڬەأدىتصەأوۏڽأطشۏڬأۄًأۗأدًأثتحأتځىەأهةەأځضىزأڬشەأًۄۏأتضأڬەأهةەأځضىزأڬشەأتًشأتضأڬۏأؽۏشأذتعشۏأوۏڽأتضأڬۏأرۏشرًتۄۏأڬشەأۗ‛‛

[تخریج]: !حسن: أخرجہ ترمذی،کتاب الأدب،باب ماجاء تشمیت العاطس(2736)وابن ماجہ،کتاب الجنائز،باب ماجاء فی عیادۃ المریض(4133)"
2676,"ضۏٔزىتألعتهۄأثىأؼثۏزأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أضًتشأځۏزهأڬًأ‛أڬہڔتأثۏټہەأڬًأتًشأڬوأهًڲأصۏتزۄأهًڲًڽأڬًأضهتوأڬشۏڽأۗ‛‛

[تخریج]: @صحیح: اخرجہ الترمذی،کتاب الإستئذان،باب ماجاء فی تسلیم الراکب علی الماشی(2705)"
2677,"ضۏٔزىتأؼثزتههۄأثىأؼوشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أۏۄًزأدثأحوأڬًأضهتوأڬۄحەأۄۏڽأحًأًۄأتهضتوأؼهۏڬوأ+أحوأځشأوًحأۄًأ,أڬۄحەأۄۏڽأۗأحًأحوأڬۄًأ=أؼهۏڬأ+أحوأځشأۄًأ,أۗ

[تخریج]: # متفق علیہ: البخاری،کتاب الإستیذان،باب کیف الرد علی اہل الذمّۃ(6257)ومسلم،کتاب السلام،باب النہی عن ابتداء أہل الکتاب بالسلام5620)"
2678,"ضۏٔزىتأضۏتشأشذوۄأتههۄأڬۄحەأۄۏڽأوۏڽأختثحأثىتىۏأشذوۄأتههۄأڬەأضتحہأدتأشۄتأحہتأ؏أًۄأثډًڽأڬەأځتضأضەأڲصشەأحًأتىۄۏڽأضهتوأڬۄتأتًشأختثحأشذوۄأتههۄأىەأثحتۏتأڬۄأًۄأتىضأشعۏأتههۄأؼىۄأڬەأضتحہأحہەأًۄأثډًڽأڬەأځتضأضەأڲصشەأحًأتىۄۏڽأضهتوأڬۄتأۗ

[تخریج]: !متفق علیہ :البخاری،کتاب الإستیذان،باب التسلیم علی الصبیان(6247)ومسلم،کتاب السلام،باب استحباب السلام علی الصبیان(5630)"
2679,"ضۏٔزىتأتضوتؤأثىحأۏصۏزأثىأضڬىأشعۏأتههۄأؼىۄتأثىًأؼثزتهتطۄهأڬۏأتۏڬأؼًشحأضەأوىمًهأۄەأڬۄأًۄأډىزأؼًشحًڽأڬەأضتحہأحہۏأۗأىثۏأ﷽أتىأڬەأځتضأضەأڲصشەأتًشأتىۄۏڽأضهتوأڬۄتأۗ

[تخریج]: !حسن: أخرجہ ابوداؤد،کتاب الأدب،باب فی السلام علی النسائ(5204)وترمذی،کتاب الإستئذان،باب ماجاء فی التسلیم(2697)"
2680,"ضۏٔزۄأؼتةطۄأشعۏأتههۄأؼىۄتأصًدأتهىثۏأ﷽أڬۄحۏأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أۏتأؼتةطۄأ$أۏۄأدثشۏهأحوۄۏڽأضهتوأڬۄحەأۄۏڽأۗ‛‛أوۏڽأىەأڬۄتأ=““أ®ًؼهۏۄأتهضهتوأًأشذوۆأتههۄأتهۏۄأًأثشڬتحۄ¾أۗ‛‛أضۏٔزۄأؼتةطۄأشعۏأتههۄأؼىۄتأڬۄحۏأۄۏڽأ=““أإځأًۄأډۏصأزۏڬہحەأحہەأدًأودہەأىػشأىۄأإحۏأحہۏأۗ‛‛

[تخریج]: @متفق علیہ :البخاری،کتاب الإستئذان،باب تسلیم الرجال علی النساء والنساء علی الرجال(6249)ومسلم،کتاب فضائل الصحابہ،باب من فضل عائشۃ(6240)"
2681,"ضۏٔزىتأتثًسشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأ=أشضًهأتههۄأ﷽أىوتصأځڔہأشۄەأحہەأدثأإځأىوتصأضەألتشؽأۄًةەأحًأوۏڽأإځأڬەأځتضأڲۏتأۗأوۏڽأځۄهتأطرظأحہتأدضأىەأإځأڬًأضهتوأڬتأحذلۄأځۏطأڬۏتأۗأإځأىەألشوتۏتأ=““أؼهۏڬأتهضهتوأًأشذوۆأتههۄأ‛أڬضأمثۏهەأضەأۄًأآأوۏڽأىەأڬۄتأ=““أؽلتشأضەأۗ‛‛أإځأىەأتځىتأۄتحہأثڔہتۏتأحًأوۏڽأىەأتځىەأزهأوۏڽأڬۄتأ=““أإځأىەأىتځضىزأڬۏتأڬۄأوۏڽأمثۏهۄأؽلتشأضەأۄًڽأۗ‛‛

[تخریج]: !صحیح :أخرجہ مسلم،کتاب فضائل الصحابہ،باب من فضائل ابی ذر رضی اللہ عنہ (6309)والبیہقی فی الحج،باب سقایۃ الحاج والشرب منہا من ماء زمزم5/147"
2682,"ضۏٔزىتأؼوشتىأثىأذظۏىأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأ=أتۏڬأإزوۏأىثۏأ﷽أڬەأځتضأإۏتأۗأتضأىەأڬۄتأ=أتهضهتوأؼهۏڬوأإځأىەأتضەأدًتثأزۏتأتًشألشوتۏتأ=أتضأڬەأهةەأزضأىۏڬۏتڽأۄۏڽأۗأځہشأتۏڬأإزوۏأإۏتأتضأىەأڬۄتأ=أتهضهتوأؼهۏڬوأًأشذوۆأتههۄأإځأىەأتضەأدًتثأزۏتأتًشألشوتۏتأ=““أتضأڬەأهةەأثۏضأىۏڬۏتڽأۄۏڽأۗ‛‛أځہشأتۏڬأإزوۏأإۏتأتضأىەأڬۄتأ=أتهضهتوأؼهۏڬوأًأشذوۆأتههۄأًأثشڬتحۄأإځأىەأتضەأدًتثأزۏتأتًشألشوتۏتأ=““أتضەأحۏضأىۏڬۏتڽأوهۏڽأڲۏأۗ‛‛

[تخریج]: ! صحیح: أخرجہ ابوداؤد،کتاب الأدب،کیف السلام(5195)والترمذی،کتاب الاستیذان،باب ماذکر فی فضل السلام (2689) احمد4/439"
2683,"ضۏٔزىتأوۄتدشأثىأمىلسأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأتىۄًڽأىەأىثۏأ﷽أڬًأضهتوأڬۏتأتًشأإځأځۏطتثأڬشأشۄەأحہەأإځأىەأضهتوأڬتأدًتثأىۄأزۏتأۗأذحۏٳأڬۄأًعًأڬۏتأ؏أتًشأدثأًعًأڬشأهۏتأحثأتضأڬتأدًتثأزۏتأۗ

[تخریج]: @صحیح: أخرجہ ابوداؤد۱کتاب الطہارۃ،باب أیرد السلام،رد السلام وہو یبول(17)والنسائی،کتاب الطہارۃ،باب رد السلام بعد الوضوئ(38)وابن ماجہ،کتاب الطہارۃ وستہا،باب الرجل یسلم علیہ وہو یبول(350)"
2684,"ضۏٔزىتأؼمثۄأثىأؼتوشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أؼًشحًڽأڬەأځتضأوحأدتاأۗ‛‛أڬۄتأڲۏتأ=أۏتأشضًهأتههۄأ“أذوًأ‛أڬۏأتدتصحأزۏأدتةەأۗألشوتۏتأ=““أًۄأحًأوًحأۄەأۗ‛‛أۏذۏۏأڬۄحەأۄۏڽأ=أ“أذوًأ‛أرتًىزأڬەأمشۏثۏأشطحۄأزتشأڬًأڬۄحەأۄۏڽأۗ

[تخریج]: !متفق علیہ :البخاری،کتاب النکاح،باب لا یخلون رجل بامرأۃ إلا ذی محرم والد خول علی المغیبۃ (5232) و مسلم ، کتاب السلام،باب تحریم الخلوۃ بالأجنبیۃ(5638)"
2685,"ضۏٔزىتأتثًصشؼۄأثىأؼوشًأثىأدشۏشأشعۏأتههۄأؼىۄأتځىەأزتزتأضەأثۏتىأڬشحەأۄۏڽأتىۄًڽأىەأىثۏأ﷽أضەأتډتىڬأىػشأڬەأوحؼهمأځًډہتأحًأإځأىەألشوتۏتأ=““أتځىۏأىػشأځہۏشأهًأۗ‛‛

[تخریج]: !صحیح :أخرجہ مسلم،کتاب الآداب،باب نظر الفجأۃ(5609)وابوداؤد،کتاب النکاح،باب ما یومر بہ من غض البصر (2148)"
2686,"ىثۏأ﷽أڬۏأثۏًۏأتوأضهوۄأشعۏأتههۄأؼىۄتأڬۄحۏأۄۏڽأڬۄأىثۏأ﷽أضەأؼًشحأڬۏأډتزشأڬەأوحؼهمأځًډہتأڲۏتأ‛أإځأىەألشوتۏتأ=أتۏڬأثتهطحأهټڬتةەأۗأوۏڽأىەأڬۄتأۏتأشضًهأتههۄأ$أتضأضەأحًأځتاڽأػتۄشأۄًڽأڲەأۗ‛‛ألشوتۏتأ=““أتۏڬأۄتحہأتضأضەأصۏتزۄأىۄأۄًىەأزۏڽأۗ‛‛

[تخریج]: @ضعیف :أخرجہ ابوداؤد،کتاب اللباس،باب قدر ذیل(4117)والترمذی،کتاب اللباس،باب ماجاء فی خیر ذیول ذبول (1731)والنسائی،کتاب الزینۃ،باب ذبول النساء (5353)"
2687,"ضۏٔزىتأذسۏلۄأشعۏأتههۄأؼىۄأڬۏأثۄىأڬۄحۏأۄۏڽأتۏڬأزلؼۄأشضًهأتههۄأ﷽أىەأۄوۏڽأرغثۄأزۏتأحًألشوتۏتأ=““أتەأؼًشحًڽأڬەأڲشًۄأ$أڬۏتأحوۄتشەأهةەأډتىزۏأڬتأصۏًشأڬتلۏأىۄۏڽأآأرثشزتشأ$أدًأضًىەأڬتأصۏًشأځۄىأڬشأػتۄشأڬشەأڲۏأتضەأؼستثأۄًأڲتأۗ‛‛

[تخریج]: !ضعیف: أخرجہ ابوداؤد،کتاب الخاتم،باب ماجاء فی الذہب للنسائ(4237)والنسائی،کتاب الزینۃ،باب کراہیۃ للنسائی فی إظہار الزینۃ الحلی والذہب(5152)"
2688,"ؽىۏوأثىأمۏضأتثًوًضۏٳأضەأىمهأڬشحەأۄۏڽأ=““أدًأؼًشحأرًطثًأهڲتأڬشأثتۄشأىڬهەأتًشأتضأڬۏأرًطثًأځتةۏأدتةەأًۄأثزڬتشأۄەأۗأتًشأۄشأإىڬہأصتىۏأۄەأۗ‛‛أتثًؼتظوأڬۄحەأۄۏڽأ=““أۄوتشەأثؼعأضتحہۏأتضەأوشلًؼأثۏتىأڬشحەأۄۏڽأۗ‛‛

[تخریج]: @صحیح :أخرجہ الترمذی،کتاب الأدب،باب ماجاء فی کراہیۃ خروج المرأۃ متعطرۃ(2786)والنسائی،کتاب الزینۃ،باب مایکرہ للنساء فی الطیب(5141)"
2689,"ضۏٔزىتأؼهموۄأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأ=أؼثزتههۄأىەأڬۄتأ=““أتههۄأڬۏأتىأځشأهؼىحأۄًأدًأىۏهأثہشحۏأتًشأثہشًتحۏأۄۏڽأ؏أثہىًًڽأتًشأډۄشەأڬەأثتهأتڬہتڔحۏأۄۏڽأتًشأذضىأڬەأهةەأزتىحأثتشۏڬأڬشحۏأۄۏڽأۗأتههۄأڬۏأځۏزتأڬۏأۄًةۏأډۏصأڬًأثزهحۏأۄۏڽأۏۄأثتحأثىۏأتضزأڬۏأتۏڬأؼًشحأڬًأځۄىډۏأدضەأتوأۏؼمًثأڬۄحەأحہەأ؏أتضأىەأإأڬشأڬۄتأ=““أودہەأرثشأوهۏأۄەأڬۄأإځأتۏضەأهؼىحأڬشحەأۄۏڽأۗ‛‛أتىۄًڽأىەأڬۄتأ=““أدضأڬًأشضًهأتههۄأ﷽أىەأهؼىحأڬۏأتًشأتضأڬتأسڬشأمشإىأوۏڽأۄەأۗأتضأځشأوۏڽأڬۏًڽأىۄأهؼىحأڬشًڽأآأتضأىەأڬۄتأ=““أوۏڽأىەأحًأوڬوهأمشإىأځڔہأهۏتأۄەأوۏڽأىەأإځأڬۏأثتحأتضأوۏڽأىۄۏڽأځتةۏأ‛أتىۄًڽأىەأڬۄتأتڲشأحوأځڔہحۏأحًأعشًشأځتحۏأڬۏتأحوأىەأۏۄأإۏحأىۄۏڽأځڔہۏأ=““أشضًهأحوۄۏڽأدًأزۏڽأًۄأهەأهًأ‛أتًشأدضأضەأوىؼأڬشۏڽأتضأضەأشڬأدتاأۗ‛‛أ+أضًشۆأتهذطشأ=أ:أ,أتضأىەأڬۄتأ=““أڬۏًڽأىۄۏڽأۗ‛‛أتىۄًڽأىەأڬۄتأ=أتضأضەأإځأىەأوىؼأڬۏتأۄەأۗأتضأىەأڬۄتأ=أوۏڽأحوۄتشۏأثۏًۏأڬًأزۏڬہحۏأۄًڽأًۄأتۏضتأڬشحۏأۄەأۗأتىۄًڽأىەأڬۄتأ=أدتاأزۏڬہأهًأۗأتضأىەأدتأڬشأزۏڬہتأحًأتضەأتځىۏأؽشعأڬۏأڬًةۏأډۏصأىػشأىۄأإةۏأۗأتىۄًڽأىەأڬۄتأ=““أتڲشأًۄأتۏضۏأۄًحۏڽأحًأوۏڽأتىأڬەأضتحہأىۄأشۄحتأۗ‛‛

[تخریج]: !متفق علیہ: کتاب اللباس،باب متفلجات للحسن(5931)ومسلم،کتاب اللباس والزینۃ،باب تحریم فعل الواصلۃ والمستوصلۃ والواشمۃ والمستو شۃ والنامصۃ والمتنامصۃ …(5538)"
2690,"شضًهأتههۄأ﷽أڬەأظذتثۏأتثًشۏذتىۄأڬۄحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أزضأرظهحًڽأضەأوىؼأڬشحەأحہەأۗأإزوۏأڬتأإزوۏأڬەأضتحہأهۏټىتأتۏضەأڬۄأزًىًڽأڬەأزشوۏتىأڬًةۏأډۏصأىۄأۄًأۗأؼًشحأڬتأؼًشحأڬەأضتحہأهۏټىتأتۏضەأڬۄأزًىًڽأڬەأزشوۏتىأڬًةۏأډۏصأىۄأۄًأۗأثتهأتڬہتڔىەأڲًزىەأ‛أهًټىەأتًشأډۏحەأڬۏأڬہتهأڬۏأصۏىأځشأضًتشۏأڬشىەأۗأڬىزہًڽأتًشأڬځڔًڽأڬەأىۏډەأشۏطوأځۄىىەأضەأ‛أؼثزتههۄأڬۄحەأۄۏڽأ=أتثًؼتوشأتىأڬەأتضحتزأۄۏڽأۗأوڬتوؼۄأڬتأوؼىۏأهۏټىتأۄەأۗ

[تخریج]: !صحیح :ابوداؤد،کتاب اللباس،باب فی کراہہ(4049)والنسائی،کتاب الزینۃ،باب تحریم الوشر (5126) واحمد 4/134"
2691,"ضۏٔزىتأتثىأؼثتضأثۏتىأڬشحەأۄۏڽأڬۄأىثۏأڬشۏوأ﷽أىەأتْىأوشزًڽأځشأهؼىحألشوتةۏأدًأورىخۏىأ+أۄۏدڔًڽأ,أڬۏأوطتثۄحأترحۏتشأڬشحەأۄۏڽأۗأتًشأتْىأؼًشحًڽأځشأدًأوشزًڽأڬۏأوطتثۄحأترحۏتشأڬشحۏأۄۏڽأ؏أتًشألشوتۏتأ=أحوأتىأڬًأتځىەأڲہشًڽأضەأىڬتهًأۗأځہشأڬۄتأڬۄأىثۏأڬشۏوأ﷽أىەألهتڽأڬًأىڬتهتأ؏أتضۏأغشذأؼوشأشعۏأتههۄأؼىۄأىەأثہۏألهتڽأ؏ألهتڽأڬًأىڬتهتأۗ

[تخریج]: !صحیح البخاری،کتاب الحدود،باب نفی أہل المعاصی والمخنثین(6834)والترمذی،کتاب الآدب،باب ماجاء فی المتشابہات بالرجال من النسائ(2785)"
2692,"ضۏٔزىتأؼثزتهشذوىأشعۏأتههۄأؼىۄأدًأتظذتثأظلۄأضەأۄۏڽأڬۄحەأۄۏڽأتۏڬأزلؼۄأۄوتشەأځتضأشضًهأتههۄأ﷽أثۏټہەأحہەأۗأوۏشتأصتىًأڬہهتأحہتأۗأإځأىەألشوتۏتأ=““أصتىًأڋہتىځأهًأڬۏتأحوۄۏڽأؼهوأىۄۏڽأڬۄأصتىًأځشزۄأۄەأۗ‛‛

[تخریج]: @ جید: أخرجہ ابوداؤد،کتاب الحمام،باب النہی عن التعری(4014)والترمذی،کتاب الأدب،باب ماجاء أن الفخذ عورۃ (2795)"
2693,"ؼوشًأثىأوۄشۄأضتهوأثىأتثۏأتهدؼزأضەأثۏتىأڬشحەأۄۏڽأۗأڬۄحەأۄۏڽأڬډہأرًتحۏىأذعشحأؼتةطۄأشعۏأتههۄأؼىۄتأڬەأځتضأإةۏڽأتًشأًۄأإىەأًتهۏأرًتحۏىأذوظأڬەأؼهتمۄأڬۏأحہۏڽأۗأرًتحۏىأىەأذعشحأؼتةطۄأشعۏأتههۄأؼىۄتأضەأوضةهۄأزشۏتلحأڬۏتأۗأضۏٔزۄأؼتةطۄأشعۏأتههۄأؼىۄتأىەألشوتۏتأ=أڬۄۏڽأًۄأرًتحۏىأذوتوتحأوۏڽأحًأزترهأىۄۏڽأۄًىەأًتهۏڽأۗأتىۄًڽأىەأدًتثتَأؼشعأڬۏتأ=أۄتڽأۗأحًأتىۄًڽأىەألشوتۏتأ=أوۏڽأىەأشضًهأتههۄأ﷽أضەأضىتأ؏أإځأىەألشوتۏتأ=أدًأؼًشحأتځىەأڬځڔەأتحتشەأتځىەأرتًىزأڬەأڲہشأڬەأؼهتًۄأۗأحًأتۏضۏأؼًشحأتځىەأتًشأتههۄأڬەأزشوۏتىأًتهتأځشزۄأځہتڔأزۏحۏأۄەأۗ

[تخریج]: !منقطع :جب کہ حدیث آئندہ سند کی بناء پر صحیح ہے۔أخرجہ ابوداؤد،کتاب الحمام،باب فی فاتحتہ (4010) والترمذی، کتاب الأدب،باب دخول الحمام(3750)"
2694,"تثًوهۏذأىەأثہۏأضۏٔزۄأؼتةطۄأشعۏأتههۄأؼىۄتأضەأتضأذزۏخأڬتأثۏتىأڬۏتأۗ

[تخریج]: @اسنادہ صحیح: سابقہ حدیث ہی مکرر آئی ہے۔"
2695,"ضۏٔزىتأتثىأؼوشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أڬًةۏأإزوۏأتځىەأثہتةۏأڬًأتضأڬۏأدڲۄأضەأىۄأتټہتةەأۗأحتڬۄأًۄتڽأرًزأثۏټہأدتةەأۗأثهڬۄأودهضأڬطتزۄأڬشًأتًشأڬہهەأۄًأڬشأثۏټہًأۗ‛‛

[تخریج]: !متفق علیہ: البخاری،کتاب الإستیذان،باب اذا قیل لکم تفسحوا…(6270)ومسلم،کتاب السلام،باب تحریم إقامۃ الإنسان من موضعہ المباح الذی سبق الیہ(5648)"
2696,"ضۏٔزىتأتثًۄشۏشۄأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أدثأڬًةۏأإزوۏأتځىۏأدڲۄأضەأتټہأدتةەأځہشأًتځضأإةەأحًأًۄۏأتضأدڲۄأڬتأوضحذمأۄەأۗ‛‛

[تخریج]: @صحیح: أخرجہ مسلم،کتاب السلام،باب اذا قام من مجلسہ ثم عاد فہوا حق بہ(5653)وابوداؤد،کتاب الأدب،باب اذا قام من مجلس ثم رجع(4853)"
2697,"ضۏٔزىتأثشتؤأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أډىزأتىظتشۏًڽأڬەأځتضأضەأڲصشەأۗأدًأشتضحۄأوۏڽأثۏټہەأۄًةەأحہەأۗأإځأىەألشوتۏتأ=““أتڲشأحوأۏۄأڬتوأڬشىتأ+أشتضحەأوۏڽأثۏټہىتأ,أۄۏأډتۄحەأۄًأحًأشتضحۄأثحتاأتًشأضهتوأڬًأؼتوأڬشًأتًشأوػهًوأڬۏأوززأڬشًأۗ‛‛أطؼثۄأڬۄحەأۄۏڽأ=أتثًتضذمأىەأثشتؤأشعۏأتههۄأؼىۄأضەأۏۄأذزۏخأىۄۏڽأضىۏأۗ

[تخریج]: #حدیث صحیح أخرجہ الترمذی،کتاب الاستیذان،باب ماجاء فی المجالس علی الطریق(3726)"
2698,"ضۏٔزىتأؼثتزأثىأحوۏوأشعۏأتههۄأؼىۄأتځىەأډډتأضەأىمهأڬشحەأۄۏڽأتىۄًڽأىەأڬۄتأ=أوۏڽأىەأشضًهأتههۄأ﷽أڬًأزۏڬہتأإځأتۏڬأځتاڽأزًضشەأځتاڽأځشأشڬہەأۄًةەأوضدزأوۏڽأځۏټہأڬەأثهأهۏټەأۄًةەأحہەأۗ

[تخریج]: !متفق علیہ: البخاری،کتاب الصلاۃ،باب الإستلقاء فی المسجد (475)ومسلم،کتاب اللباس والزینۃ،باب اباحۃ الاستلقاء ووضع إحدی الترجلین(5471)"
2699,"ضۏٔزىتأؼثزتههۄأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أدثأحوأحۏىأإزوۏأۄًأحًأزًأإزوۏأتځىەأضتحہۏأڬًأډہًڔأڬشأضشڲًطۏأىۄأڬشۏڽأۗأڬۏًىڬۄأتضەأتضأضەأؽوأځۄىډەأڲتأۗ‛‛

[تخریج]: @متفق علیہ: البخاری،کتاب الاستیذان،باب اذا کان اکثر من ثلاثۃ(6290)ومسلم،کتاب السلام،باب تحریم منا جاۃ الاثنین دون الثالث بغیر رضا ہ (5660)"
2700,"ضۏٔزىتأتثًثشصۄأتضهوۏأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأإرشۏأؼوشأوۏڽأشضًهأتههۄأ﷽أدثأڬضۏأودهضأوۏڽأثۏټہحەأتًشأتټہىتأډتۄحەأحًأتضأغشذأڬۄحەأ=““أتەأتههۄأتځىۏأحؼشۏلأڬەأضتحہأحًأځتڬأۄەأوۏڽأڲًتۄۏأزۏحتأۄًڽأحۏشەأؼهتًۄأڬًةۏأوؼثًزأىۄۏڽأوۏڽأحدہأضەأثرططأوتىڲحتأۄًڽأتًشأحۏشۏأغشلأشدًؼأڬشحتأۄًڽأۗ‛‛أهًڲًڽأىەأڬۄتأ=أۏتأشضًهأتههۄأ$أإځأتۏضۏأثتحأڬۄحەأۄۏڽأدًأځۄهەأىۄۏڽأڬۄتأڬشحەأحہەأۗأإځأىەألشوتۏتأ=““أۏۄأودهضأڬۏأثتحًڽأڬتأڬلتشۄأۄەأۗ‛‛

[تخریج]: !صحیح: أخرجہ ابوداؤد،کتاب الأدب،باب فی کفارۃ المجلس(4859)"
2701,"ضۏٔزىتأتثًتۏًثأتىظتشۏأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأىثۏأ﷽أىەألشوتۏتأ=““أدضأڬًأډہۏىڬأإةەأًۄأتۏضەأڬۄەأ=““أۄشأذتهأوۏڽأحؼشۏلأتههۄأۄۏأڬەأهةەأۄەأۗ‛‛أتًشأضىىەأًتهتأطرظأتۏضەأڬۄەأ=““أتههۄأحوأځشأشذوأڬشەأۗ‛‛أډہۏىڬىەأًتهتأځہشأتضەأۏًڽأڬۄەأ=““أتههۄأحوۄۏڽأۄزتۏحأزەأتًشأحوۄتشەأوؼتوهەأڬًأزشضحأڬشأزەأۗ‛‛

[تخریج]: @ضعیف: لیکن اس کے شواہد موجود ہونے کی بناء پر یہ قوی ہوجاتی ہے۔دیکھئے بخاری کتاب الأدب،باب اذا عطس کیف یشمت(6224)وابوداؤد،کتاب الأدب،باب ماجاء فی تشمیت العاطس(5433)"
2702,"ضۏٔزىتأتىضأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأىثۏأ﷽أڬەأځتضأزًأإزوۏًڽأڬًأډہۏىڬأإةۏأإځأىەأتۏڬأڬتأدًتثأزۏتأزًضشەأڬتأدًتثأىۄأزۏتأۗأڬۄتأڲۏتأ=أۏتأشضًهأتههۄأ$أإځأىەأتضأڬتأدًتثأزۏتأۄەأتًشأزًضشەأڬتأىۄۏڽأزۏتأحًأإځأىەألشوتۏتأ=““أتۏڬأىەأتهذوزههۄأڬۄتأۄەأتًشأزًضشەأىەأىۄۏڽأڬۄتأۗ‛‛

[تخریج]: !متفق علیہ: البخاری،کتاب الأدب،باب الحمد للعاطس(6221)ومسلم،کتاب الزہد،باب تشمیت العاطس(7411)"
2703,"ضۏٔزىتأتۏتضأثىأضهوۄأڬۄحەأۄۏڽأودہأضەأوۏشەأًتهزأىەأثۏتىأڬۏتأڬۄأىثۏأ﷽أڬەأځتضأڬضۏأإزوۏأىەأډہۏىڬتأۗأإځأىەألشوتۏتأ=““أتههۄأحدہأځشأشذوأڬشەأۗ‛‛أځہشأًۄأزًضشۏأزلؼۄأډہۏىڬتأحًأإځأىەألشوتۏتأ=““أتضأڬًأصڬتوأۄەأۗ‛‛

[تخریج]: @متفق علیہ: البخاری،کتاب الأدب،باب اذا عطس کم یشمت (6224)مسلم،کتاب الزہد،باب تشمیت العاطس (7414)"
2704,"ضۏٔزۄأؼتةطۄأشعۏأتههۄأؼىۄتأڬۄحۏأۄۏڽأۄوتشتأتۏڬأحظًۏشًڽأًتهتأڬځڔتأحہتأۗأوۏڽأىەأتضەأىثۏأ﷽أڬەأإڲەأڬشأزۏتأتًشأإځأىوتصأځڔہأشۄەأحہەأۗأإځأىەأودہەأوىؼأڬۏتأۗأۏتأتىۄًڽأىەأڬۄتأ=أإځأىەأتضەأثشتأضودہتأۗأوۏڽأىەأتضأڬەأحڬۏەأثىتأزۏةەأۗ

[تخریج]: !متفق علیہ: البخاری،کتاب المظالم،باب ہل تکسر الدنان التی فیہا خمر أو تخرق الزقاق(2476)ومسلم،کتاب اللباس والزینۃ باب تحریم تصویر صورۃ الحیوان(5478)"
2705,"ضۏٔزىتأؼهۏأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأىثۏأ﷽أىەألشوتۏتأ=““ألشطحەأتۏضەأڲہشأوۏڽأىۄۏڽأدتحەأدضأوۏڽأڬحتأتًشأحظًۏشۏڽأۄًڽأۗأتًشأىۄأۏۄأدىثۏأڬەأڲہشأوۏڽأدتحەأۄۏڽأۗ‛‛

[تخریج]: @اسنادہ جید: عبداللہ بن نجی کا علی رضی اللہ عنہ سے سماع ثابت ہے دیکھئے ابن حبان کی الثقات5/30، أخرجہ ابوداؤد،کتاب الطہارۃ، باب فی الجنب یومر بالغسل(2207)والنسائی،کتاب الطہارۃ،باب فی الجنب اذالم یتوضا(2301)وابن ماجہ،کتاب اللباس،باب الصور فی البیت (3650)"
2706,"ضۏٔزىتأتثًوضؼًزأثزشۏأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأىثۏأ﷽أىەألشوتۏتأ=““أوضهوتىأدثأتځىەأتۄهأځشأرشډأڬشحتأۄەأتضەأثتؼخأتدشأضودہحتأۄەأحًأًۄأتضأڬەأهةەأظزمۄأۄەأۗ‛‛

[تخریج]: !متفق علیہ: البخاری،کتاب الإیامن،باب ماجاء ان الاعمال بالنیات(55)ومسلم،کتاب الزکاۃ،باب فضل النفقۃ والصدقۃ علی الأقربین والزوج ولاولاد والوالدین ولو کانوا مشرکین(2319)"
2707,"ضۏٔزىتأؼثزتههۄأثىأدؼلشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأشضًهأتههۄأ﷽أڬۄۏڽأضەأضلشأڬشأڬەأًتځضأإأشۄەأحہەأۗأحًأودہأضەأتًشأذضىأشعۏأتههۄأؼىۄأۏتأذضۏىأشعۏأتههۄأؼىۄأضەأوهتمتحأۄًةۏأۗأوۏشتأرۏتهأۄەأتىۄًڽأىەأڬۄتأ=أذضىأشعۏأتههۄأؼىۄأضەأوهتمتحأۄًةۏأۗأحًأإځأ﷽أىەأودہەأتځىەأإڲەأتًشأذضىأڬًأتځىەأځۏډہەأثټہتۏتأ‛أۄوأتضۏأضًتشۏأځشأوزۏىۄأځۄىډەأدضأځشأىثۏأ﷽أحہەأۗ

[تخریج]: @صحیح أخرجہ مسلم،کتاب فضائل الصحابہ،باب فضائل عبداللہ بن جعفر رضی اللہ عنہ (6218)أخرجہ ابوداؤد،کتاب الجہاد، باب فی رکوب ثلا ثۃ علی دابۃ (2566)وابن ماجہ،کتاب الأدب،باب رکوب ثلاثۃ علی دابۃ (3773)"
2708,"ضۏٔزىتأؼثزتههۄأثىأۏصۏزأرغوۏأدًأڬًلۄأڬەأتوۏشأحہەأڬۄحەأۄۏڽأڬۄأۄوأمۏضأثىأضؼزأثىأؼثتزۄأڬەأځتضأتضأڬەأڲہشأڲةەأۗأحًأوًٗسىأىەأىوتصأڬەأهةەأتستىأڬۄۏأۄوأىەأمۏضأضەأڬۄتأ=أۄوۏڽأىوتصأځڔہتاأۗأتىۄًڽأىەأڬۄتأ=““أوۏڽأتۏضەأهًڲًڽأڬًأىوتصأىۄۏڽأځڔہتاڽأڲتأدىأڬتأوۏڽأتوۏشأىۄۏڽأۄًڽأحًأتۏڬأإزوۏأىەأڬۄتأدًأتىأضەأڬوأىۄۏڽأحہەأدىۄۏڽأؼثزتههۄأثىأذىػهۄأثىأؽضۏهأڬۄحەأۄۏڽأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أإزوۏأتځىۏأضًتشۏأتًشألشطأڬەأتڲهەأومتوأڬتأصۏتزۄأوضحذمأۄەأتًشأتضأڬتأثہۏأڬۄأتځىۏأدڲۄأوۏڽأرًزأتوتوحأڬشەأۗ‛‛أتضأًمحأمۏضأثىأضؼزأىەأتځىەأإصتزأڬشزۄأؽهتوأضەأڬۄتأ=““أتەألهتڽأ$أتټہًأتًشأتىۄۏڽأىوتصأځڔہتاأۗ‛‛

[تخریج]: !قوی بشواہدہ"
2709,"وذوزأثىأذوصۄأثىأؼوشًأتضهوۏأڬۄحەأۄۏڽأتىأڬەأًتهزأشضًهأتههۄأ﷽أڬەأظذتثۏأحہەأۗأڬۄحەأۄۏڽأوۏڽأىەأتځىەأًتهزأضەأضىتأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أۄشأتًىټأځشأتۏڬأطۏغتىأۄًحتأۄەأهۄٳستأدثأضًتشأۄًأحًأثضوأتههۄأځڔہًأ‛أتًشأتځىەأعشًشۏأڬتوًڽأوۏڽأڬًحتۄۏأىۄأڬشًأۗ‛‛

[تخریج]: !حسن: أخرجہ الطبرانی،فی الاوسط(1945)وابن ابی شیبہ10/391(9772)"
2710,"ضۄهأثىأوؼتسأثىأتىضأتځىەأًتهزأضەأىمهأڬشحەأۄۏڽأًۄأىثۏأ﷽أڬەأتظذتثأوۏڽأضەأحہەأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أتىأضًتشۏًڽأځشأتۏضۏأذتهحأوۏڽأضًتشأۄًأدثأضهتوحۏأًتهۏأۄًڽأتًشأتىۄۏڽأڬشضۏأىۄأثىتاأۗ‛‛

[تخریج]: @صحیح: أخرجہ مسلم،کتاب الحج،باب رکوب البدنۃ المہداۃ لم احتاج الیہا(319)والنسائی،کتاب المناسک باب رکوب البدنۃ(2799)"
2711,"ضۏٔزىتأهۏخأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأطثتثۄأىەأتضأذزۏخأڬۏأڬضۏأثتحأڬۏأورتهلحأڬۏأۗ

[تخریج]: !صحیح: سابقہ تخریج ہی ہے۔"
2712,"ضۏٔزىتأتثًۄشۏشۄأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أضلشأؼستثأڬتأټڬڔتأۄەأۗأتضأضەأحوۄتشتأضًىتأ‛أڬہتىتأتًشأځۏىتأثىزأۄًأدتحتأۄەأهۄٳستأضلشأوۏڽأدثأحوأتځىۏأعشًشحأضەألتشؽأۄًأدتاأحًأدهزأتځىەأڲہشأڬۏأغشلأهًټأإاأۗ‛‛

[تخریج]: @متفق علیہ: البخاری،کتاب العمرۃ،باب السقر قطعۃ من العذاب(1804)ومسلم،کاب الإمارۃ،باب السقر قطعۃ من العذاب(4938)"
2713,"ضۏٔزىتأتىضأثىأوتهڬأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأتۏڬأإزوۏأىثۏأ﷽أڬەأځتضأإۏتأتضأىەأڬۄتأ=““أتەأتههۄأڬەأىثۏأ$أوۏڽأضلشأڬشىتأډتۄحتأۄًڽأۗأإځأىەألشوتۏتأ=““أڬثأآ‛‛أتضأىەأڬۄتأ=أڬهأتىأطتؤأتههۄأۗأًۄأإځأڬەأځتضأإۏتأإځأىەأتضأڬتأۄتحہأځڬڔأڬشألشوتۏتأ=““أتههۄأڬۏأذلتػحأوۏڽأتًشأتضأڬۏأىڲۄثتىۏأوۏڽأ؏أتههۄأحدہەأحمًۏٳأڬەأصتزٓشتۄأضەأضشلشتصأڬشەأۗأتًشأحوۄتشەأڲىتۄًڽأڬًأثرطأزەأۗأتًشأدۄتڽأثہۏأحًأمظزأڬشەأحدہەأثہهتةۏأضەأىًتصەأۏتأدزہشأثہۏأحۏشتأشرأۄًأۗأزًىًڽأڬهوتحأوۏڽأضەأتۏڬأوۏڽأضؼۏزأىەأطڬأڬۏتأۄەأۗ

[تخریج]: !جید: أخرجہ ترمذی،کتاب الدعوات،باب مناقب عبداللہ بن زبیر رضی اللہ عنہ (3444)"
2714,"ضۏٔزىتأؼثزتههۄأثىأضشدضأڬۄحەأۄۏڽأڬۄأىثۏأ﷽أدثأضلشأڬشەأحًأڬۄحەأ=““أتەأتههۄأ$أوۏڽأحدہأضەأضلشأڬۏأوطمحأ؏أىتوشتزأًتځضأهًټىەأ؏أتډہۏأذتهحأڬەأثؼزأثشۏأذتهحأإىەأ؏أوػهًوأڬۏأثززؼتأ؏أتًشأتځىەأتۄهأًأوتهأوۏڽأثشەأوىػشأضەأځىتۄأډتۄحتأۄًڽأۗ‛‛

[تخریج]: @صحیح : أخرجہ مسلم،کتاب الحج،باب ما یقول اذا رکب الی السفر الحج(3263)والترمذی،کتاب الدعوات باب ما یقول اذا خرج مسافراً(3439)والنسائی،کتاب الاستعاذۃ،باب الإستعاذہ من الحور بعد الکور(5513)"
2715,"ضۏٔزىتأؼثزتههۄأثىأؼوشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأشضًهأتههۄأ﷽أدثأضلشأڬەأهۏەأضًتشۏأځشأضًتشأۄًحەأحًأحۏىأزلؼۄأتههۄأتڬثشأڬۄحەأۗأتًشأڬۄحەأ=““أځتڬأۄەأًۄأستحأدضأىەأتضەأۄوتشەأهۏەأوضرشأڬۏتأتًشأۄوأتضأځشأمتثًأځتىەأًتهەأىۄۏڽأحہەأ؏أتًشأۄوۏڽأتځىەأشثأڬۏأغشلأۄۏأهًټىتأۄەأۗأتەأتههۄأ$أوۏڽأتځىەأتضأضلشأوۏڽأحدہأضەأىۏڬۏأتًشأحمًۏٳأڬتأضًتهأڬشحتأۄًڽأتًشأتۏضەأؼوهأڬتأدضەأحًأځضىزأڬشەأۗأتەأتههۄأ$أۄوتشەأضلشأڬًأإضتىأڬشأزەأۗأتًشأۄوتشەأهۏەأصوۏىأڬۏأزًشۏأڬوأڬشأزەأۗأتەأتههۄأ$أضلشأوۏڽأحًأۄۏأضتحہۏأۄەأۗأتًشأتۄهأوۏڽأحًأۄۏأرهۏلۄأۄەأۗأتەأتههۄأ$أۄوتشەأضلشأوۏڽأۄوتشتأضتحہۏأثىأدتأتًشأۄوتشەأتۄهأوۏڽأۄوتشتأثۄحشأرهۏلۄأثىأدتأ‛‛ۗ

[تخریج]: !صحیح: أخرجہ مسلم،کتاب الحج،باب ما یقول اذا رکب إلی سفر الحج وغیرہ(3262)وابوداؤد،کتاب الجہاد، باب ما یقول الرجل اذا سافر(2599)والترمذی،کتاب الدعوات،باب مایقول اذا رکب الناقۃ(3447)"
2716,"ضۏٔزىتأدتثشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأدثأۄوأتًځشأډڔہحەأحًأ“أتههۄأتڬثشأ‛أڬۄحەأ‛أتًشأتحشحەأحًأ“أضثذتىأتههۄأ‛أڬۄحەأۗ

[تخریج]: @صحیح البخاری،کتاب الدعوات،باب الدعاء اذا ہبط وادیا(تعلیقًا)واحمد3/333"
2717,"ضۏٔزۄأتوأذثۏثۄأشعۏأتههۄأؼىۄتأڬۄحۏأۄۏڽأىثۏأ﷽أىەألشوتۏتأ=““أدضأمتلهەأوۏڽأڲہىټۏأۄًألشطحەأتىأڬەأضتحہأىۄۏڽأشۄحەأۗ‛‛

[تخریج]: #صحیح: ابوداؤد،کتاب الجہاد،باب فی تعلیق الجرس(2554)"
2718,"ضۏٔزىتأتثًۄشۏشۄأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأىثۏأ﷽أىەألشوتۏتأ=““ألشطحەأتضأدوتؼحأڬەأضتحہأىۄۏڽأۄًحەأدضأوۏڽأڬحتأۏتأڲہىټۏأۄًأۗ‛‛

[تخریج]: !صحیح: اخرجہ مسلم،کتاب اللباس،باب فی کراہۃ الکلب والجرس فی السفر(5512)وابوداؤدکتاب الجہاد،باب فی تعلیق الجرس(2555)"
2719,"ضۏٔزىتأؼوشتىأثىأذظۏىأشعۏأتههۄأؼىۄوتأڬۄحەأۄۏڽأىثۏأ﷽أتۏڬأضلشأوۏڽأحہەأإځأىەأهؼىحأڬۏأإًتصأضىۏأحًأإځأىەألشوتۏتأ=أۏۄأڬۏتأۄەأآأهًڲًڽأىەأڬۄتأ=ألهتڽأؼًشحأىەأتځىۏأضًشۏأځشأهؼىحأڬۏأۄەأۗأإځأىەألشوتۏتأ=““أتضەأتضأضًتشۏأضەأتحتشأزًأ‛أڬۏًىڬۄأًۄأوهؼًىأۄەأۗ‛‛أهًڲًڽأىەأتضەأتًىټىۏأضەأتحتشأزۏتأۗأؼوشتىأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأ=أڲًۏتأڬۄأوۏڽأتضەأزۏڬہأشۄتأۄًڽأًۄأڲىزوۏأشىڲأڬۏأتًىټىۏأحہۏأۗ

[تخریج]: @صحیح: أخرجہ مسلم،کتاب البروالصلۃ،باب النہی عن لعن الدواب وغیرہا(6547)وابوداؤد،کتاب الجہاد،باب النہی عن لعن البہیمۃ(2561)"
2720,"ضۏٔزىتأتثًضؼۏزأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أؼًشحأتځىەأثتځأ؏أثہتةۏأ؏أطًۄشأ؏أۏتأتځىەأڬضۏأوذشوأڬەأؼهتًۄأحۏىأزىأضەأصۏتزۄأضلشأىۄأڬشەأۗ‛‛

[تخریج]: !متفق علیہ: البخاری،کتاب فضل الصلاۃ،باب مسجد بیت المقدس(1197)مسلم،کتاب الحج،باب سفرالمرأۃ مع محرم ابی حج وغیرہ(3248)"
2721,"ضۏٔزىتأتثىأؼوشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأىثۏأ﷽أىەألشوتۏتأ=““أتڲشأهًڲأحىۄتةۏأڬۏأثشتةۏأدتىأهۏحەأحًأڬًةۏأضًتشأشتحأڬًأتڬۏهتأضلشأىۄأڬشحتأۗ‛‛

[تخریج]: @صحیح: أخرجہ البخاری،کتاب الجہاد والسیر ، باب سیر الرجل وحدہ باللیل(2998)والترمذی،کتاب الجہاد ، باب ماجاء فی کراہیۃ أیسافر الرجل وحدہ(1673)"
2722,"ضۏٔزۄأرًهۄأثىحأذڬۏوأشعۏأتههۄأؼىۄتأڬۄحۏأۄۏڽأوۏڽأىەأشضًهأتههۄأ﷽أضەأضىتألشوتحەأحہەأ=““أدثأحوأوۏڽأضەأڬًةۏأڬضۏأدڲۄأځشأتحشەأتڲشأتضأغشذأڬۄۄأهەأ=““أوۏڽأتههۄأڬەأحوتوأڬهوتحأڬەأضتحہأتضأڬۏأځۏزتأڬشزۄأۄشأطشأضەأځىتۄأوتىڲحتأۄًڽأۗ‛‛أحًأتضأدڲۄأتضەأڬًةۏأډۏصأىمظتىأىۄأزەأڲۏأۗأذحۏأڬۄأًۄأتضأدڲۄأضەأڬًډأڬشأدتةەأۗ‛‛

[تخریج]: ! صحیح: اخرجہ مسلم،کتاب الدعوات،باب فی التعوذ من سوء القضاء ودرک الشفاء وغیرہ (6817) والترمذی، کتاب الدعوات باب ماجاء مایقول اذا نزل منزلاً(3437)"
2723,"ضۏٔزىتأتىضأثىأوتهڬأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأىثۏأ﷽أڬضۏأدڲۄأتحشحەأحًأزًأشڬؼحأځڔہىەأضەأځۄهەأڬًډأىۄأڬشحەأۗأۏتأڬۄتأ=““أتضأوىصهأڬًأزًأشڬؼحأضەأرۏشثتزأڬۄحەأحہەأۗ‛‛أؼثزتههۄأڬۄحەأۄۏڽأ=““أتضأذزۏخأڬەأشتًۏأؼخوتىأثىأضؼزأعؼۏلأۄۏڽأۗ‛‛

[تخریج]: @ضعیف:عثمان بن سعد ضعیف راوی ہے، اخرجہ ابوداؤد،کتاب الصلاۃ،باب المسافر یصلی وہو یشک فی الوقت (1205) والنسائی،کتاب المواقیت،باب تعجیل الظہر فی السفر(4907)"
2724,"ضۏٔزىتأؼثزتههۄأثىأؼوشأشعۏأتههۄأؼىۄوتأڬۄحەأۄۏڽأڬۄأىثۏأ﷽أدثأضلشأضەأًتځضأإحەأحًأڬۄحەأ=““أًتځضأهًټىەأًتهەأ‛أتڲشأتههۄأىەأډتۄتأحًثۄأڬشىەأًتهەأؼثتزحأڬشىەأًتهەأتًشأتځىەأشثأڬۏأحؼشۏلأڬشىەأًتهەأۄۏڽأۗ‛‛

[تخریج]: !متفق علیہ: البخاری،کتاب العمرۃ،باب مایقول اذا رجع من الحج أوالعمرۃ أو الغزوۃ(1797)ومسلم،کتاب الحج،باب مایقول اذا قفل من سفرا الحج وغیرہ(3266)"
2725,"ضۏٔزىتأثشتأثىأؼتصثأڬۄحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەأذڬوأزۏتأڬۄأدثأإزوۏأتځىەأثضحشأځشأهۏټەأحًأۏًڽأڬۄەأ=““أتەأتههۄأ$أوۏڽأىەأتځىەأإځأڬًأحۏشەأضځشزأڬۏتأۗأتًشأتځىتأډۄشۄأحۏشۏأغشلأوحًدۄأڬۏتأۗأتًشأتځىتأوؼتوهۄأحۏشەأذًتهەأڬۏتأۗأتًشأوۏڽأىەأتځىۏأځۏټہأڬًأحۏشۏأځىتۄأوۏڽأزۏتأۗأحۏشۏأغشلأشؽثحأڬشحەأۄًةەأتًشأحدہأضەأڋشحەأۄًةەأځىتۄأڲتۄأتًشأىدتحأحۏشۏأۄۏأغشلأۄەأۗأوۏڽأحۏشۏأىتصهأڬشزۄأڬحتثأتًشأحۏشەأثہۏدەأۄًةەأىثۏأځشأتۏوتىأشڬہحتأۄًڽأۗ‛‛أځضأتڲشأ+أتضەأځڔہىەأًتهتأتضۏأشتحأ,أوشأڲۏتأحًأًۄألغشحأځشأوشەأڲتأۗ

[تخریج]: @متفق علیہ: البخاری،کتاب الوضوئ،باب فضل من مات علی الوضوئ(247)ومسلم،کتاب الذکر والدعائ،باب مایقول عند النوم وأخذ مضجعہ(6820)"
2726,"ضۏٔزىتأتثًۄشۏشۄأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أدثأحوأوۏڽأضەأڬًةۏأتځىەأثضحشأڬۏأغشلأدتةەأحًأتځىۏأډتزشأضەأتضەأدہتڔەأڬۏًىڬۄأًۄأىۄۏڽأدتىحتأڬۄأتضأڬەأثؼزأتضأځشأڬۏتأشۄتأۄەأځہشأۏًڽأڬۄەأ=““أتەأتههۄأ$أحۏشۏأوززأضەأوۏڽأتځىتأځۄهًأ+أثضحشأځشأ,أشڬہحتأۄًڽأتًشأحۏشۏأۄۏأوززأضەأتټہتاڽأڲتأۗأتەأتههۄأ$أتڲشأحًأوۏشۏأشًذأڬًأشًڬأهەأحًأتضەأوؼتلأڬشأزۏىتأتڲشأًتځضأڬشەأحًأتضأڬۏأذلتػحأڬشىتأدۏضەأىۏڬأثىزًڽأڬۏأذلتػحأڬشحتأۄەأۗ‛‛

[تخریج]: !متفق علیہ: البخاری،کتاب الدعوات،باب اذا آوی الی فراشہ فلینفض فراشہ (6320)ومسلم،کتاب الذکر والدعائ، باب مایقول عندالنوم وأخذ المضجعہ(6830)"
2727,"ضۏٔزىتأؼهۏأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أۄوتشەأځتضأحطشۏلأهتةەأتًشأوۏشەأتًشألتغوۄأشعۏأتههۄأؼىۄتأڬەأزشوۏتىأتځىتأمزوأشڬہتأۗأتًشأۄوۏڽأضڬہتۏتأڬۄأدثأۄوأتځىەأثضحشأځشأهۏټۏڽأحًأ66أزلؼۄأضثذتىأتههۄأ‛أ66أزلؼۄأتهذوزههۄأتًشأ67أزلؼۄأتههۄأتڬثشأڬۄتأڬشۏڽأۗ‛‛أؼهۏأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأ=أتضأڬەأثؼزأوۏڽأىەأتضەأڬثہۏأىۄۏڽأډہًڔتأ‛أتۏڬأطرظأىەأڬۄتأ=أ“أظلۏىأ‛أڬۏأشتحأڬًأثہۏأىۄۏڽأډہًڔتأآأڬۄتأ=“أظلۏىأ‛أڬۏأشتحأڬًأثہۏأىۄۏڽأډہًڔتأۗ

[تخریج]: @متفق علیہ: البخاری،کتاب النفقۃ،باب خادم المرأۃ(5362)ومسلم،کتاب الذکروالدعائ،باب التسبیح اول النہار عند النوم(9855)"
2728,"ضۏٔزىتأذسۏلۄأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأىثۏأ﷽أدثأىۏىزأضەأثۏزتشأۄًحەأحًأڬۄحەأ=““أحوتوأحؼشۏلۏڽأتضأستحأڬەأهةەأۄۏڽأدضأىەأۄوتشۏأوًحأڬەأثؼزأۄوۏڽأصىزۄأڬۏتأۗأتًشأتضۏأڬۏأغشلأتڬټہەأۄًأڬشأدتىتأۄەأۗ‛‛

[تخریج]: !صحیح البخاری،کتات الدعوات،باب مایقول اذا نام(6312)وابوداؤدکتاب الأدب،باب مایقول عند النوم (5049) والترمذی،کتاب الدعوات،باب منہ(3417)"
2729,"ضۏٔزىتأؼثتزۄأثىأظتوحأشعۏأتههۄأؼىۄوتأڬۄحەأۄۏڽأڬۄأىثۏأ﷽أىەألشوتۏتأ=““أدًأطرظأشتحأڬًأىۏىزأضەأثۏزتشأۄًأڬشأۏًڽأڬۄەأ=““أتههۄأڬەأؼهتًۄأڬًةۏأوؼثًزأىۄۏڽأًۄأتڬۏهتأۄەأتضأڬتأڬًةۏأطشۏڬأىۄۏڽأتضۏأڬەأهةەأثتزطتۄۏأتًشأتضۏأڬەأهةەأحؼشۏلأۄەأتًشأًۄأۄشأډۏصأځشأمتزشأۄەأ؏أتههۄأځتڬأۄەأتههۄأڬەأهةەأحؼشۏلأۄەأتًشأتههۄأڬەأؼهتًۄأڬًةۏأوؼثًزأىۄۏڽأتًشأتههۄأثۄحأثڔتأۄەأۗأىۏڬۏأڬۏأمًحأتًشأثشتةۏأضەأثډىەأڬۏأمًحأظشلأتههۄأڬۏأحًلۏمأضەأۄەأځہشأڬۄەأ=““أتەأوۏشەأشثأ$أودہەأثرطأزەأۏتأإځأىەألشوتۏتأ=أځہشأزؼتأڬشەأتضأڬۏأزؼتأمثًهأڬۏأدتةەأڲۏأۗأځہشأتڲشأًۄأډتۄەأحًأًعًأڬشأڬەأىوتصأځڔہەأحًأتضأڬۏأىوتصأمثًهأڬۏأدتةەأڲۏأۗ‛‛

[تخریج]: @صحیح: أخرجہ البخاری،کتاب التہجد،باب فضل من تعار من اللیل وفصلی(1154)وابوداؤد،کتاب الأدب باب ما یقول الرجل اذا تعار من اللیل(5060)والترمذی،کتاب الدعوات،باب ماجاء فی الدعاء اذا انتبہ من اللیل(3414)"
2730,"ضۏٔزىتأؼثزتههۄأتځىەأًتهزأؼثزتهشذوىأثىأتثصۏأضەأثۏتىأڬشحەأۄۏڽأۗأتىۄًڽأىەأڬۄتأڬۄأ=أىثۏأ﷽أدثأظثذأڬشحەأحًأتضأغشذأڬۄحەأحہەأ=““أۄوأىەأتضهتوأڬۏألغشحأ؏أترهتظأڬەأڬهوەأتًشأتځىەأىثۏأوذوزأ﷽أڬەأزۏىأتًشأتځىەأثتځأتثشتۄۏوأدًأڬۄأۏڬغشلۄأوضهوتىأحہەأڬەأزۏىأځشأظثذأڬۏأۗ‛‛

[تخریج]: !حسن: أخرجہ ابن ابی شیبہ9/77(6591)واحمد3/407"
2731,"ضۏٔزىتأتثًۄشۏشۄأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأتثًثڬشأشعۏأتههۄأؼىۄأىەأڬۄتأ=““أۏتأشضًهأتههۄأ$أودہەأتۏضۏأډۏصأڬتأذڬوأزۏڽأدًأوۏڽأظثذأًأطتوأڬۄتأڬشًڽأۗ‛‛أإځأىەألشوتۏتأڬۄًأ=““أتەأتههۄأ$أإضوتىأًأصوۏىأڬەأځۏزتأڬشىەأًتهەأ‛أؽۏثأًأذتعشأڬًأدتىىەأًتهەأۄشأډۏصأڬەأوتهڬأتًشأځتهىەأًتهەأوۏڽأڲًتۄۏأزۏحتأۄًڽأڬۄأحۏشەأؼهتًۄأڬًةۏأوؼثًزأىۄۏڽأۗأوۏڽأتځىەأىلضأتًشأطۏغتىأڬەأطشأضەأتًشأتضأڬۏأطشڬحأضەأحۏشۏأځىتۄأډتۄحتأۄًڽأۗ‛‛أإځأىەألشوتۏتأ=““أظثذأًأطتوأتًشأتځىەأثضحشأځشأهۏټحەأۄًةەأتضەأځڔہأهۏتأڬشًأۗ‛‛

[تخریج]: @صحیح: أخرجہ الترمذی،کتاب الدعوات،باب(90)الحدیث(3529)"
2732,"ضۏٔزىتأضۄهأثىأوؼتسأثىأتىضأتځىەأًتهزأضەأثۏتىأڬشحەأۄۏڽأتىۄًڽأىەأڬۄتأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أدًأطرظأىۏتأڬځڔتأځۄىەأًۄأتۏضەأڬۄەأ=““أحوتوأحؼشۏلۏڽأتههۄأڬەأهةەأۄۏڽأدضأىەأودہەأۏۄأڬځڔتأځۄىتۏتأتًشأودہەأشصمأزۏتأۗأوۏشۏأمًحأًأغتمحأڬەأثؽۏشأۗ‛‛أحًأتضأڬەأځۄهەأڲىتۄأثرطأزۏةەأدتةۏڽأڲەأۗ

[تخریج]: !صحیح: أخرجہ الحاکم4/162وابوداؤد،کتاب اللباس با(1)(الحدیث4023)والترمذی،کتاب الدعوات،باب ما یقول اذا فرغ من الطعام(3458)"
2733,"تثًذوۏزأۏتأتثًتضۏزأڬۄحەأۄۏڽأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أدثأڬًةۏأوضدزأوۏڽأزترهأۄًأحًأًۄأۏًڽأڬۄەأ=““أتەأتههۄأوۏشەأهةەأتځىۏأشذوحأڬەأزشًتصەأڬہًهأزەأۗ‛‛أتًشأدثأثتۄشأىڬهەأحًأڬۄەأ=““أتەأتههۄأ$أوۏڽأحدہأضەأحۏشەألعهأڬتأضًتهأڬشحتأۄًڽأۗ‛‛

[تخریج]: @صحیح: أخرجہ مسلم،کتاب صلاۃ المسافرین،باب ما یقول اذا دخل المسجد(1649)وابوداؤد،کتاب الصلاۃ،باب فی مایقول الرجل دخولہ المسجد(465)"
2734,"وذوزأثىأًتضؼأڬۄحەأۄۏڽأوۏڽأوڬۄأڲۏتأحًأتځىەأثہتةۏأضتهوأثىأؼثزتههۄأضەأوهتأتىۄًڽأىەأتځىەأًتهزأضەأثۏتىأڬۏتأۗأًۄأتىأڬەأزتزتأضەأىمهأڬشحەأحہەأىثۏأ﷽أىەألشوتۏتأ=““أدًأطرظأثتصتشأوۏڽأزترهأۄًأًۄأڬۄەأ=““أتههۄأڬەأؼهتًۄأڬًةۏأوؼثًزأىۄۏڽأًۄأتڬۏهتأۄەأتضأڬتأڬًةۏأطشۏڬأىۄۏڽأ‛أتضۏأڬەأهةەأثتزطتۄۏأۄەأتًشأتضۏأڬەأهةەأحؼشۏلأۄەأًۄۏأصىزۄأڬشحتأۄەأتًشأًۄۏأوتشحتأۄەأًۄأۄوۏطۄأصىزۄأشۄىەأًتهتأۄەأتضەأوًحأڬثہۏأىۄۏڽأإةەأڲۏأۗأتضأڬەأۄتحہأوۏڽأثہهتةۏأۄەأتًشأًۄأۄشأډۏصأځشأمتزشأۄەأۗ‛‛أحًأتههۄأحؼتهۏٳأتضأڬەأهةەأزضأۄصتشأىۏڬۏتڽأهڬہأزەأڲتأۗأتًشأتضأڬەأزضأۄصتشأڲىتۄأوټتةەأڲتأتًشأزضأۄصتشأزشدەأثهىزأڬشەأڲتأۗأوذوزأثىأًتضؼأڬۄحەأۄۏڽأ=أوۏڽأرشتضتىأڲۏتأحًأمحۏثۄأثىأوضهوأضەأوهتأوۏڽأىەأڬۄتأ=أوۏڽأإځأڬەأهةەأتۏڬأحذلۄأهتۏتأۄًڽأۗأوۏڽأىەأتضأضەأۏۄأذزۏخأثۏتىأڬۏأۗأًۄأتځىەأضًتشًڽأوۏڽأضًتشأۄًأڬشأثتصتشأوۏڽأدتحەأحہەأۗأڬہڔەأۄًأڬشأتضأغشذأځڔہحەأحہەأتًشأځہشأًتځضأإحەأۗ

[تخریج]: !حسن بشواہدہ وطرقہ: أخرجہ الترمذی،کتاب الدعوات،باب ما یقول اذا دخل السوق(3428)وابن ماجہ،کتاب التجارات،باب الاسواق ودخولہا(2235)"
2735,"ضۏٔزىتأتثًۄشۏشۄأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أوۏشەأىتوأځشأىتوأشڬہًأوڲشأوۏشۏأڬىۏحأىۄأشڬہًأۗ‛‛

[تخریج]: !متفق علیہ: أخرجہ البخاری،کتاب المناقب،باب کتیۃ النبی صلعم(3539)ومسلم،کتاب الأداب،باب النہی عن التکنی بأبی القاسم…(5562)"
2736,"ضۏٔزىتأتثًزشزتؤأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أحوۄۏڽأمۏتوحأڬەأزىأحوۄتشەأتًشأحوۄتشەأثتځًڽأڬەأىتوأضەأځڬتشتأدتةەأڲتأهۄٳستأتځىەأىتوأتډہەأشڬہًأۗ‛‛

[تخریج]: @ منقطع ضعیف: أخرجہ ابوداؤد،کتاب الأدب،باب فی تغییر الأسمائ(4948)"
2737,"ضۏٔزىتأتثىأؼوشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أتههۄأڬەأوذثًثأىتوأؼثزتههۄأتًشأؼثزتهشذوىأۄۏڽأۗ‛‛

[تخریج]: !صحیح: أخرجہ مسلم،کتاب الآداب،باب النہی عن التکنی بابی القاسم وبیان مایستحب من الأسماء (5552) وابوداؤد،کتاب الأدب،باب فی تغییر الأسمائ(4949)"
2738,"ضۏٔزىتأضوشۄأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأىثۏأ﷽أىەأۄوۏڽأتضأثتحأضەأوىؼأڬۏتأڬۄأۄوتشەأؽهتوًڽأڬەأۏۄأډتشأىتوأۄًڽأۗ““أتلهذأ‛أىتلؼأ‛أشثتذأ‛أىدتذأۗ‛‛

[تخریج]: @صحیح: أخرجہ مسلم،کتاب الآداب،باب کراہیۃ التسمیۃ بالاسماء القبیحۃ وبنافع ونحوہ(5564)وابوداؤد،کتاب الأدب،باب فی تغییر الاسماء القبیحۃ(4958)والترمذی،کتاب الأدب،باب مایکرہ من الاسمائ(2836)"
2739,"ضۏٔزىتأتثىأؼوشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأتوأؼتظوأڬًأ“أؼتظۏۄأ‛أڬۄتأدتحتأحہتأۗأحًأىثۏأ﷽أىەأتضأڬتأىتوأ“أدوۏهۄأ‛أشڬہتأۗ

[تخریج]: !صحیح: أخرجہ مسلم،کتاب الآداب،باب استحباب تغییر الاسماء القبیحۃ الی حسن…(5570)وابن ماجہ کتاب الأدب،باب تغییر الاسمائ(3733)"
2740,"ضۏٔزىتأتثًۄشۏشۄأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأصۏىثأڬتأىتوأ“أثشٔۄأ‛أحہتأحًأىثۏأ﷽أىەأتضأڬتأىتوأصۏىثأشڬہأزۏتأۗ

[تخریج]: @متفق علیہ: البخاری،کتاب الأدب،باب تحویل الاسماء الی اسم احسن منہ(6192)ومسلم،کتاب الآداب،باب استحباب تغییر الاسماء القبیحۃ الی حسن…(5572)"
2741,"ضۏٔزۄأؼتةطۄأشعۏأتههۄأؼىۄتأڬەأثہتةۏأغلۏهأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأوطشڬًڽأڬەأڬضۏأإزوۏأىەأوضهوتىًڽأڬەأڬضۏأإزوۏأضەأڬۄتأ=““أحوأڬۏتأۄۏأتډہەأحہەأتڲشأحوأتضأغشذأڬۄحەأ=““أدًأتههۄأتًشأوذوزأىەأډتۄتأۗ‛‛أىثۏأ﷽أىەأضىتأحًألشوتۏتأ=““أتۏضەأىۄأڬۄًأ=أدًأتههۄأتًشأوذوزأىەأډتۄتأ‛أتهثحۄأۏًڽأڬۄًأ=أدًأتههۄأىەأډتۄتأځہشأوذوزأىەأډتۄتأۗ

[تخریج]: #صحیح: أخرجہ ابن قانع فی معجم الصحابہ(489)"
2742,"ضۏٔزىتأتثًۄشۏشۄأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أتىڲًشأ+أڬەأثتؽأ,أڬًأڬشوأىۄأڬۄًأ؏أڬشوأحًأتۏڬأوضهوتىأإزوۏأۄەأۗ‛‛

[تخریج]: !متفق علیہ: أخرجہ البخاری،کتاب الأدب،باب لاتسبو الدہر(6182)ومسلم،کتاب الألفاظ،باب کراہیۃ تسمیۃ العنب کرمًا(5832)"
2743,"ضۏٔزىتأتثىأؼثتضأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأتۏڬأؽهتوأحہتأدًأىثۏأ﷽أڬۏأتصًتدأڬەأتًىټًڽأڬًأۄتىڬأشۄتأحہتأۗأتًشأڲۏحأڲتۏتأڬشحتأحہتأۗأإځأىەألشوتۏتأ=““أتەأتىدطۄأ$أطۏطًڽأڬًأإۄضحڲۏأضەأډهتاأۗ‛‛

[تخریج]: @اسنادہ واہٍ :لیکن حدیث متفقق علیہ ہے أخرجہ البخاری فی الأدب باب مایجوز من الشعروالرجز والحداء (6149) ومسلم ، کتاب فضائل باب رحمتہ النبی صلعم للنسائ(2322)"
2744,"ثۄصأثىأذڬۏوأتځىەأًتهزأضەأثۏتىأڬشحەأۄۏڽأتىۄًڽأىەأڬۄتأ=أوۏڽأىەأشضًهأتههۄأ﷽أڬًأۏۄألشوتحەأۄًةەأضىتأ=““أتضأطرظأځشأتلضًضأۄەأدًأثتحأڬشحەأۄًةەأظشلأتضأهةەأدہًټأثًهحتأۄەأحتڬۄأهًڲأۄىضۏڽأۗأتضأځشأتلضًضأۄەأ‛أتضأځشأتلضًضأۄەأۗ‛‛

[تخریج]: !جید: أخرجہ ابوداؤد،کتاب الأدب،باب فی التشدید فی الکذب(4990)أخرجہ احمد5/7والحاکم(144)"
2745,"ضۏٔزىتأتثىأؼثتضأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأىثۏأ﷽أىەأتوۏۄأثىأتثًظهحأڬەأزًأطؼشًڽأڬۏأحظزۏمألشوتةۏأۗأتضأىەأڬۄتأ=““أ““أحوتوأډۏصۏڽأتضأغشذأتههۄأحؼتهۏٳأڬەأمثعۄأمزشحأوۏڽأۄۏڽأدضأغشذأإزوۏأتًشأتۏڬأثۏهأتضأڬەأزتةۏڽأځتاڽأڬەأىۏډەأۄۏڽأۗأتًشأڲزہأزًضشەأځتاڽأڬەأىۏډەأتًشأتۏڬأطۏشأۄەأدًأڲہتحأهڲتۏتأڲۏتأۄەأۗ‛‛حًأىثۏأ﷽أىەألشوتۏتأ=““أتضأىەأضډأڬۄتأۗ‛‛أتضأىەأڬۄتأ=““أضًشدأۄشأشتحأڬەأثؼزأضشرأشىڲأځشأىڬهحتأۄەأځہشأتضأڬتأشىڲأڲهتثۏأۄًىەأهڲحتأۄەأۗ‛‛أحًأىثۏأ﷽أىەألشوتۏتأ=““أتضأىەأضډأڬۄتأۗ‛‛أتضأىەأڬۄتأ=““أًۄأتىڬتشأڬشحەأشۄەأتًشأإۄضحۏأتًشأضڬًىأضەأۄوتشەأهۏەأغهًؼأىۄۏڽأۄًحتأوڲشأدثأڬۄأتضأځشأضرحۏأڬۏأدتةەأًشىۄأتضأڬًأڬًڔەأوتشەأدتةۏڽأڲەأۗ‛‛أىثۏأ﷽أىەألشوتۏتأ=““أتضأىەأضډأڬۄتأۗ‛‛

[تخریج]: !ضعیف: أخرجہ ابن ابی شیبہ8/693(6064) والطبرانی فی الکبیر11/233"
2746,"تثۏأثىأڬؼثأڬۄحەأۄۏڽأڬۄأىثۏأ﷽أىەألشوتۏتأ=““أثؼعأطؼشألتةزۄأوىزأۄًحەأۄۏڽأۗ‛‛

[تخریج]: !صحیح: أخرجہ البخاری،کتاب الأدب،باب مایجوز من الشعرو الرجز والحداء وما یکرہ منہا (6145) وابوداؤد، کتاب الأدب ، باب ماجاء فی الشعر(5010)وابن ماجہ،کتاب الأدب،باب الشعر(3755)"
2747,"ضۏٔزىتأتثىأؼوشأشعۏأتههۄأؼىۄوتأڬۄحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أحوأوۏڽأضەأڬضۏأڬتأځۏټأځۏځأۏتأرًىأضەأثہشتأۄًتأۄًأحًأًۄأتضأضەأثۄحشأۄەأڬۄأطؼشأضەأثہشتأۄًأۗ‛‛

[تخریج]: @صحیح البخاری،کتاب الأدب،باب مایکرہ أن یکون الغالب علی الإنسان الشعر حتی یصدہ عن ذکر اللہ والعلم والقران (1654)وابوداؤد،کتاب الأدب،باب ماجاء فی الشعر(5009)"
