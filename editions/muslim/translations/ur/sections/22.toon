{"hadithnumber": "4040", "text": ")  شعبہ نے ہمیں حمید سے حدیث بیان کی ،  انہوں نے کہا :  میں نے حضرت انس رضی اللہ عنہ کو کہتے سنا :"}
{"hadithnumber": "4041", "text": "طاوس نے حضرت ابن عباس رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ علیہ وسلم نے پچھنے لگوائے اور س"}
{"hadithnumber": "4042", "text": "شعبی نے حضرت ابن عباس رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  بنو بیاضہ کے ایک غلام نے نبی صلی ا"}
{"hadithnumber": "4043", "text": "حضرت ابوسعید خدری رضی اللہ عنہ سے روایت ہے ،  انہوں نے کہا :  میں نے رسول اللہ صلی اللہ علیہ وسلم سے"}
{"hadithnumber": "4044", "text": "سوید بن سعید نے ہمیں حدیث بیان کی ،  کہا :  ہمیں حفص بن میسرہ نے زید بن اسلم سے حدیث سنائی ،  انہوں"}
{"hadithnumber": "4045", "text": "یحییٰ بن سعید نے عبدالرحمٰن بن وعلہ سے ،  انہوں نے حضرت عبداللہ بن عباس رضی اللہ عنہ سے اور انہوں نے"}
{"hadithnumber": "4046", "text": "منصور نے ابوضحیٰ  ( مسلم بن صبیح )  سے ،  انہوں نے مسروق سے اور انہوں نے حضرت عائشہ رضی اللہ عنہا سے"}
{"hadithnumber": "4047", "text": ")  اعمش نے  ( ابوضحیٰ )  مسلم سے ،  انہوں نے مسروق سے اور انہوں نے حضرت عائشہ رضی اللہ عنہا سے روایت"}
{"hadithnumber": "4048", "text": "لیث نے ہمیں یزید بن ابی حبیب سے حدیث بیان کی ،  انہوں نے عطاء بن ابی رباح سے اور انہوں نے حضرت جابر"}
{"hadithnumber": "4049", "text": "عبدالحمید سے روایت ہے ،  کہا :  مجھے یزید بن ابی حبیب نے حدیث بیان کی ،  انہوں نے کہا :  عطاء نے مجھ"}
{"hadithnumber": "4050", "text": ")  سفیان بن عیینہ نے ہمیں عمرو سے حدیث بیان کی ،  انہوں نے طاوس سے اور انہوں نے حضرت ابن عباس رضی ال"}
{"hadithnumber": "4051", "text": "روح بن قاسم نے عمرو بن دینار سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی ۔"}
{"hadithnumber": "4052", "text": "ابن جریج نے ہمیں حدیث بیان کی ،  کہا :  مجھے ابن شہاب نے سعید بن مسیب سے خبر دی کہ انہوں نے انہیں  ("}
{"hadithnumber": "4053", "text": ")  یونس نے مجھے ابن شہاب سے خبر دی ،  انہوں نے سعید بن مسیب سے اور انہوں نے حضرت ابوہریرہ رضی اللہ ع"}
{"hadithnumber": "4054", "text": "امام مالک نے نافع سے اور انہوں نے حضرت ابوسعید خدری رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ ع"}
{"hadithnumber": "4055", "text": "قتیبہ بن سعید اور محمد بن رمح نے لیث سے حدیث بیان کی اور انہوں نے نافع سے روایت کی کہ بنو لیث کے ایک"}
{"hadithnumber": "4056", "text": "جریر بن حازم ،  یحییٰ بن سعید اور ابن عون ،  سب نے نافع سے روایت کی ،  لیث کے نافع سے ،  ان کی حضرت"}
{"hadithnumber": "4057", "text": ")  ابوصالح نے حضرت ابوسعید خدری رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :"}
{"hadithnumber": "4058", "text": "حضرت عثمان بن عفان رضی اللہ عنہ سے روایت ہے کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   \" تم ایک د"}
{"hadithnumber": "4059", "text": "لیث نے ہمیں ابن شہاب سے خبر دی اور انہوں نے مالک بن اوس بن حدثان سے روایت کی کہ انہوں نے کہا :  میں"}
{"hadithnumber": "4060", "text": "ابن عیینہ نے زہری سے اسی سند کے ساتھ  ( یہی )  روایت بیان کی ۔"}
{"hadithnumber": "4061", "text": "حماد بن زید نے ہمیں ایوب سے حدیث بیان کی اور انہوں نے ابوقلابہ سے روایت کی ،  انہوں نے کہا :  میں شا"}
{"hadithnumber": "4062", "text": "عبدالوہاب ثقفی نے ایوب سے اسی سند کے ساتھ اسی کی طرح روایت بیان کی ۔"}
{"hadithnumber": "4063", "text": "خالد حذاء نے ابوقلابہ سے ،  انہوں نے ابواشعث سے اور انہوں نے حضرت عبادہ بن صامت رضی اللہ عنہ سے روای"}
{"hadithnumber": "4064", "text": ")  اسماعیل بن مسلم عبدی نے ہمیں حدیث بیان کی ،  کہا :  ہمیں ابومتوکل ناجی نے حضرت ابوسعید خدری رضی ا"}
{"hadithnumber": "4065", "text": "سلیمان ربعی نے ہمیں خبر دی ،  کہا :  ہمیں ابومتوکل ناجی نے حضترت ابوسعید خدری رضی اللہ عنہ سے حدیث ب"}
{"hadithnumber": "4066", "text": ")  فضیل کے بیٹے  ( محمد )  نے ہمیں اپنے والد سے حدیث بیان کی ،  انہوں نے ابوزرعہ سے اور انہوں نے حضر"}
{"hadithnumber": "4067", "text": "محاربی نے فضیل بن گزوان سے اسی سند کے ساتھ حدیث بیان کی اور انہوں نے  \" دست بدست \"  کے الفاظ بیان نہ"}
{"hadithnumber": "4068", "text": "ابن ابی نُعیم نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  رسول اللہ صلی اللہ علیہ و"}
{"hadithnumber": "4069", "text": "سلیمان بن ہلال نے ہمیں موسیٰ بن ابی تمیم سے حدیث بیان کی ،  انہوں نے سعید بن یسار سے اور انہوں نے حض"}
{"hadithnumber": "4070", "text": "امام مالک بن انس نے کہا :  مجھے موسیٰ بن ابی تمیم نے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی ۔"}
{"hadithnumber": "4071", "text": "عمرو  ( بن دینار )  نے ابومنہال سے روایت کی ،  انہوں نے کہا :  میرے ایک شریک نے موسم  ( حج کے موسم )"}
{"hadithnumber": "4072", "text": "حبیب سے روایت ہے کہ انہوں نے ابومنہال سے سنا ،  وہ کہہ رہے تھے :  میں نے حضرت براء بن عازب رضی اللہ"}
{"hadithnumber": "4073", "text": "عباد بن عوام نے کہا :  یحییٰ بن ابی اسحاق نے ہمیں خبر دی ،  انہوں نے کہا :  ہمیں عبدالرحمٰن بن ابی ب"}
{"hadithnumber": "4074", "text": "یحییٰ بن ابی کثیر نے یحییٰ بن ابی اسحاق سے روایت کی کہ انہیں عبدالرحمان بن ابی بکرہ نے بتایا کہ حضرت"}
{"hadithnumber": "4075", "text": "علی بن رباح لخمی نے کہا :  میں نے حضرت فضالہ بن عبید رضی اللہ عنہ سے سنا ،  وہ کہہ رہے تھے :  رسول ا"}
{"hadithnumber": "4076", "text": "لیث نے ہمیں ابوشجاع سعید بن یزید سے حدیث بیان کی ،  انہوں نے خالد بن ابی عمران سے ،  انہوں نے حنش صن"}
{"hadithnumber": "4077", "text": ")  ابن مبارک نے سعید بن یزید سے اسی سند کے ساتھ اسی طرح حدیث بیان کی ۔"}
{"hadithnumber": "4078", "text": "جلاح ابوکثیر سے روایت ہے ،  انہوں نے کہا :  مجھے حنش صنعانی نے حضرت فضالہ بن عبید رضی اللہ عنہ سے حد"}
{"hadithnumber": "4079", "text": "عامر بن یحییٰ معافری نے حنش سے خبر دی کہ انہوں نے کہا :  ہم ایک غزوے میں حضرت فضالہ بن عبید رضی اللہ"}
{"hadithnumber": "4080", "text": "بُسر بن سعید نے معمر بن عبداللہ رضی اللہ عنہ سے روایت کی کہ انہوں نے گندم کا ایک صاع دے کر اپنا غلام"}
{"hadithnumber": "4081", "text": ")  سلیمان بن بلال نے ہمیں عبدالمجید بن سہیل بن عبدالرحمان سے حدیث بیان کی کہ انہوں نے سعید بن مسیب س"}
{"hadithnumber": "4082", "text": ")  امام مالک نے عبدالمجید بن سہیل بن عبدالرحمان بن عوف سے ،  انہوں نے سعید بن مسیب سے اور انہوں نے ح"}
{"hadithnumber": "4083", "text": "اسحاق بن منصور نے کہا :  ہمیں یحییٰ بن صالح وحاظی سے حدیث بیان کی ،  انہوں نے کہا :  ہمیں معاویہ بن"}
{"hadithnumber": "4084", "text": "ابونضرہ نے حضرت ابوسعید خدری رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  رسول اللہ صلی اللہ علیہ وسل"}
{"hadithnumber": "4085", "text": "حضرت ابوسعید رضی اللہ عنہ سے روایت ہے ،  انہوں نے کہا :  رسول اللہ صلی اللہ علیہ وسلم کے زمانے میں ہ"}
{"hadithnumber": "4086", "text": "سعید جریری نے ابونضرہ سے روایت کی ،  انہوں نے کہا :  میں نے حضرت ابن عباس رضی اللہ عنہ سے دینار و در"}
{"hadithnumber": "4087", "text": "داود نے ہمیں ابونضرہ سے خبر دی ،  انہوں نے کہا :  میں نے حضرت ابن عمر رضی اللہ عنہ اور حضرت ابن عباس"}
{"hadithnumber": "4088", "text": "ابوصالح سے روایت ہے ،  انہوں نے کہا :  میں نے حضرت ابوسعید خدری رضی اللہ عنہ سے سنا ،  وہ کہہ رہے تھ"}
{"hadithnumber": "4089", "text": ")  عبیداللہ بن ابی یزید سے روایت ہے کہ انہوں نے حضرت ابن عباس رضی اللہ عنہ سے سنا ،  وہ کہہ رہے تھے"}
{"hadithnumber": "4090", "text": "طاوس نے حضرت ابن عباس رضی اللہ عنہ سے اور انہوں نے حضرت اسامہ بن زید رضی اللہ عنہ سے روایت کی کہ رسو"}
{"hadithnumber": "4091", "text": "عطاء بن ابی رباح نے مجھے حدیث بیان کی کہ حضرت ابوسعید خدری رضی اللہ عنہ نے حضرت ابن عباس رضی اللہ عن"}
{"hadithnumber": "4092", "text": ")  علقمہ نے حضرت عبداللہ  ( بن مسعود رضی اللہ عنہ )  سے روایت کی ،  انہوں نے کہا :  رسول اللہ صلی ال"}
{"hadithnumber": "4093", "text": "حضرت جابر رضی اللہ عنہ سے روایت ہے ،  انہوں نے کہا :  رسول اللہ صلی اللہ علیہ وسلم نے سود کھانے والے"}
{"hadithnumber": "4094", "text": "عبداللہ بن نمیر ہمدانی نے ہمیں حدیث بیان کی ،  کہا :  ہمیں زکریا نے شعبی سے حدیث بیان کی ،  انہوں نے"}
{"hadithnumber": "4095", "text": "وکیع اور عیسیٰ بن یونس نے زکریا سے اسی سند کے ساتھ اسی کی مانند حدیث بیان کی ۔"}
{"hadithnumber": "4096", "text": "اس سند سے بھی مذکورہ بالا حدیث مروی ہے ۔  لیکن زکریا کی حدیث ان سب سے زیادہ مکمل ہے ۔"}
{"hadithnumber": "4097", "text": "نعمان بن بشیر بن سعد سے روایت ہے جو صحابی تھے رسول اﷲ ﷺ کے اور وہ خطبہ سناتے تھے لوگوں کو حمص میں  ("}
{"hadithnumber": "4098", "text": "جابر بن عبداﷲ رضی اﷲ عنہ سے روایت ہے وہ جارہے تھے ایک اونٹ پر جو تھک گیا تھا انہوں نے چاہا اس کو آزا"}
{"hadithnumber": "4099", "text": "مذکورہ بالا حدیث اس سند سے بھی مروی ہے ۔"}
{"hadithnumber": "4100", "text": "جابر بن عبداﷲ رضی اﷲ عنہ سے روایت ہے میں نے جہاد کیا رسول اﷲ ﷺ کے ساتھ تو آپ مجھ سے ملے  ( راہ میں )"}
{"hadithnumber": "4101", "text": "سالم بن ابی جعد نے حضرت جابر رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  ہم رسول اللہ صلی اللہ علیہ"}
{"hadithnumber": "4102", "text": "ابونضرہ نے حضرت جابر بن عبداللہ رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  ایک سفر میں ہم نبی صلی ا"}
{"hadithnumber": "4103", "text": "ابوزبیر نے حضرت جابر رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  جب نبی صلی اللہ علیہ وسلم میرے پاس"}
{"hadithnumber": "4104", "text": "ابومتوکل ناجی نے حضرت جابر بن عبداللہ رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  میں نے رسول اللہ ص"}
{"hadithnumber": "4105", "text": "معاذ عنبری نے ہمیں حدیث بیان کی ،  کہا :  ہمیں شعبہ نے محارب سے حدیث بیان کی کہ انہوں نے حضرت جابر ب"}
{"hadithnumber": "4106", "text": "خالد بن حارث نے ہمیں حدیث بیان کی ،  کہا :  ہمیں شعبہ نے حدیث بیان کی ،  انہوں نے کہا :  مجھے محارب"}
{"hadithnumber": "4107", "text": "عطاء نے حضرت جابر رضی اللہ عنہ سے روایت کی کہ نبی صلی اللہ علیہ وسلم نے ان سے فرمایا :   \" میں نے تم"}
{"hadithnumber": "4108", "text": "امام مالک بن انس نے زید بن اسلم سے ،  انہوں نے عطاء بن یسار سے اور انہوں نے حضرت ابورافع رضی اللہ عن"}
{"hadithnumber": "4109", "text": "محمد بن جعفر سے روایت ہے ،  میں نے زید بن اسلم سے سنا ،  انہوں نے کہا :  ہمیں عطاء بن یسار نے رسول ا"}
{"hadithnumber": "4110", "text": "شعبہ نے ہمیں سلمہ بن کہیل سے حدیث بیان کی ،  انہوں نے ابوسلمہ سے اور انہوں نے حضرت ابوہریرہ رضی اللہ"}
{"hadithnumber": "4111", "text": "علی بن صالح نے سلمہ بن کہیل سے ،  انہوں نے ابوسلمہ سے اور انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے روا"}
{"hadithnumber": "4112", "text": "سفیان نے ہمیں سلمہ بن کہیل سے حدیث بیان کی ،  انہوں نے ابوسلمہ سے اور انہوں نے حضرت ابوہریرہ رضی الل"}
{"hadithnumber": "4113", "text": "حضرت جابر رضی اللہ عنہ سے روایت ہے ،  انہوں نے کہا :  ایک غلام آیا ،  اس نے ہجرت پر نبی صلی اللہ علی"}
{"hadithnumber": "4114", "text": "ابومعاویہ نے اعمش سے ،  انہوں نے ابراہیم سے ،  انہوں نے اسود سے اور انہوں نے حضرت عائشہ رضی اللہ عنہ"}
{"hadithnumber": "4115", "text": ")  عیسیٰ بن یونس نے ہمیں اعمش سے خبر دی ،  انہوں نے ابراہیم سے ،  انہوں نے اسود سے اور انہوں نے حضرت"}
{"hadithnumber": "4116", "text": "عبدالواحد بن زیاد نے ہمیں اعمش سے حدیث بیان کی ،  انہوں نے کہا :  ہم نے ابراہیم نخعی کے پاس بیع سلم"}
{"hadithnumber": "4117", "text": "حفص بن غیاث نے ہمیں اعمش سے حدیث بیان کی ،  انہوں نے ابراہیم سے روایت کی ،  انہوں نے کہا :  مجھے اسو"}
{"hadithnumber": "4118", "text": ")  یحییٰ بن یحییٰ اور عمرو ناقد نے ہمیں حدیث بیان کی  ۔  ۔  الفاظ یحییٰ کے ہیں ،  عمرو نے کہا :  ہمی"}
{"hadithnumber": "4119", "text": "عبدالوارث نے ہمیں ابن ابی نجیح سے حدیث بیان کی ،  کہا :  ہمیں عبداللہ بن کثیر نے ابومنہال سے حدیث بی"}
{"hadithnumber": "4120", "text": "یحییٰ بن یحییٰ ،  ابوبکر بن ابی شیبہ اور اسماعیل سالم سب نے  ( سفیان )  بن عیینہ سے ،  انہوں نے ابن"}
{"hadithnumber": "4121", "text": "وکیع اور عبدالرحمان بن مہدی دونوں نے سفیان  ( ثوری )  سے ،  انہوں نے ابن ابی نجیح سے انہی کی سند کے"}
{"hadithnumber": "4122", "text": "سلیمان بن بلال نے ہمیں یحییٰ بن سعید سے حدیث بیان کی ،  انہوں نے کہا :  سعید بن مسیب حدیث بیان کرتے"}
{"hadithnumber": "4123", "text": "محمد بن عجلان نے محمد بن عمرو بن عطاء سے ،  انہوں نے سعید بن مسیب سے ،  انہوں نے حضرت معمر بن عبدالل"}
{"hadithnumber": "4124", "text": "عمرو بن یحییٰ نے محمد بن عمرو سے ،  انہوں نے سعید بن مسیب سے اور انہوں نے بنو عدی بن کعب کے ایک فرد"}
{"hadithnumber": "4125", "text": "حضرت ابوہریرہ رضی اللہ عنہ نے کہا :  میں نے رسول اللہ صلی اللہ علیہ وسلم سے سنا ،  آپ فرما رہے تھے :"}
{"hadithnumber": "4126", "text": "حضرت ابوقتادہ انصاری رضی اللہ عنہ سے روایت ہے کہ انہوں نے رسول اللہ صلی اللہ علیہ وسلم سے سنا ،  آپ"}
{"hadithnumber": "4127", "text": "ابوخثیمہ نے ہمیں ابوزبیر سے خبر دی ،  اور انہوں نے حضرت جابر بن عبداللہ رضی اللہ عنہ سے روایت کی ،"}
{"hadithnumber": "4128", "text": "عبداللہ بن ادریس نے ہمیں حدیث بیان کی ،  کہا :  ہمیں ابن جریج نے ابوزبیر سے حدیث بیان کی ،  انہوں نے"}
{"hadithnumber": "4129", "text": "ابن وہب نے ہمیں ابن جریج سے خبر دی کہ انہیں ابوزبیر نے بتایا کہ انہوں نے حضرت جابر بن عبداللہ رضی ال"}
{"hadithnumber": "4130", "text": "سیدنا ابوہریرہ ؓ سے روایت ہے ، رسول اللہ ﷺ نے فرمایا : ”کوئی تم سے اپنے ہمسایہ کو اپنی دیوار میں لکڑ"}
{"hadithnumber": "4131", "text": "سفیان بن عیینہ ،  یونس اور معمر سب نے زہری سے اسی سند کے ساتھ اسی طرح روایت کی ۔"}
{"hadithnumber": "4132", "text": "عباس بن سہل بن سعد ساعدی نے حضرت سعید بن زید بن عمرو بن نفیل رضی اللہ عنہ سے روایت کی کہ رسول اللہ ص"}
{"hadithnumber": "4133", "text": "عمر بن محمد کے والد  ( محمد بن زید )  نے حضرت سعید بن زید بن عمرو بن نفیل رضی اللہ عنہ سے حدیث بیان"}
{"hadithnumber": "4134", "text": "حماد بن زید نے ہمیں ہشام بن عروہ سے حدیث بیان کی ،  انہوں نے اپنے والد سے روایت کی کہ ارویٰ بنت اویس"}
{"hadithnumber": "4135", "text": "یحییٰ بن زکریا بن ابی زائدہ نے ہمیں ہشام سے حدیث بیان کی ،  انہوں نے اپنے والد سے اور انہوں نے حضرت"}
{"hadithnumber": "4136", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ،  انہوں نے کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :"}
{"hadithnumber": "4137", "text": "حرب بن شداد نے ہمیں حدیث بیان کی ،  کہا :  ہمیں یحییٰ بن ابی کثیر نے محمد بن ابراہیم سے حدیث بیان کی"}
{"hadithnumber": "4138", "text": "ابان نے ہمیں حدیث بیان کی ،  کہا :  ہمیں یحییٰ نے حدیث بیان کی کہ انہیں محمد بن ابراہیم نے حدیث بیان"}
{"hadithnumber": "4139", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ نبی صلی اللہ علیہ وسلم نے فرمایا :   \" جب تمہارا راستے  ("}
