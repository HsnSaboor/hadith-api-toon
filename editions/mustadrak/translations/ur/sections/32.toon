5385,%أوؼتًۏۄأثىأمشۄأتځىەأًتهزأڬتأۏۄأثۏتىأىمهأڬشحەأۄۏڽأ=أذعشحأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄأتۏڬأزشرحأځشأډڔہەأۄًةەأتځىەأضتحہۏًڽأڬەأهةەأځہهأحًڔأشۄەأحہەأ؏أتضأزًشتىأۄًتأډهۏأ؏أدضأڬۏأًدۄأضەأتىأڬۏأځىڋهۏأىىڲۏأۄًأڲةۏأ؏أۏۄأزۏڬہأڬشأظذتثۄأڬشتوأۄىضأځڔەأ؏أشضًهأتههۄأ﷽أىەألشوتۏتأ=أتضأستحأڬۏأمضوأدضأڬەأمثعۄأوۏڽأوۏشۏأدتىأۄەأ؏أۏۄأوۏصتىأوۏڽأتذزأځۄتڔأضەأثہۏأصۏتزۄأًصىۏأۄەأۗ أٰٰأۏۄأذزۏخأظذۏذأتهتضىتزأۄەأهۏڬىأطۏرۏىأشذوۆأتههۄأؼهۏۄوتأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗ%أ
5386,%أذعشحأؼهۏأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أوۏڽأىثۏأتڬشوأ﷽أڬەأځتضأحہتأ؏أتضأًمحأذعًشأ﷽أڬەأځتضأذعشحأتثًثڬشأشعۏأتههۄأؼىۄأتًشأڬډہأزۏڲشأظذتثۄأڬشتوأشعۏأتههۄأؼىۄوأوًدًزأحہەأۗأۄوأذعشحأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄأڬەأځتضأضەأڲصشەأ؏أًۄأتضأًمحأىوتصأځڔہأشۄەأحہەأ؏أىثۏأتڬشوأ﷽أىەأځًډہتأ=أۏۄأڬًىأۄەأآأإځأڬًأثحتۏتأڲۏتأڬۄأۏۄأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄأۄۏڽأ؏أإځأ﷽أىەألشوتۏتأ=أؼثزتههۄأتضۏأتىزتصأوۏڽأمشإىأځڔہحتأۄەأدضأتىزتصأوۏڽأىتصهأۄًتأۗأځہشأذعًشأ﷽أىەأتههۄأحؼتهۏٳأڬۏأثتشڲتۄأوۏڽأذعشحأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄأڬۏأحؼشۏلأڬۏأۗأتًشأتىأڬۏأرًثأحًظۏلأًأخىتؤأڬۏأ؏أځہشأتىأڬەأهۏەأثۄحأتذضىأتىزتصأوۏڽأزؼتأوتىڲۏأدضأتىزتصأوۏڽأتۏڬأؽهتوأتځىەأإمتأضەأڬًةۏأډۏصأوتىڲحتأۄەأۗأځہشأڬۄتأ=أتەأتههۄأوۏڽأحدہأضەأتۏضتأتۏوتىأوتىڲحتأۄًڽأدضأوۏڽأتشحزتزأىۄأۄًأ؏أتًشأتۏضۏأىؼوحۏڽأوتىڲحتأۄًڽأدًأرحوأىۄأۄًڽأۗأتًشأحۏشۏأدىحأتهلشزًضأڬەأتؼهۏأؼهۏۏىأوۏڽأحۏشەأوذثًثأ﷽أڬۏأضىڲحأوتىڲحتأۄًڽأۗأتًشأشضًهأتههۄأ﷽أىەأتىأڬًأڬۄتأ†أحوأوتىڲًأ؏أحوۄۏڽأزۏتأدتةەأڲتأ؏أحوأوتىڲًأحوۄۏڽأزۏتأدتةەأڲتأ‟أځہشأوۏڽأتىأڬۏأرًطرثشۏأزۏىەأڬەأهةەأډهتأحًأزۏڬہتأڬۄأذعشحأتثًثڬشأشعۏأتههۄأؼىۄأودہأضەأځۄهەأرًطرثشۏأزەأډڬەأحہەأ؏أتًشأذعشحأتثًثڬشأشعۏأتههۄأؼىۄأىۏڬۏًڽأوۏڽأضثأضەأإڲەأثڔہتأڬشحەأحہەأۗ أٰٰأۏۄأذزۏخأظذۏذأتهتضىتزأۄەأهۏڬىأطۏرۏىأشذوۆأتههۄأؼهۏۄوتأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗ%أ
5387,"%أذعشحأؼثزتههيألشوتحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەأتشطتزألشوتۏتأ†أوۏڽأتځىۏأتوحأڬەأهةەأتضۏأډۏصأځشأشتعۏأۄًڽأدضأډۏصأځشأتوأؼثزأڬتأثۏټتأ+أۏؼىۏأذعشحأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄأ,أشتعۏأۄەأۗ أٰٰأۏۄأتضىتزأتوتوأثرتشۏأشذوۆأتههۄأؼهۏۄأتًشأتوتوأوضهوأشذوۆأتههۄأؼهۏۄأڬەأوؼۏتشأڬەأوغتثمأظذۏذأۄەأهۏڬىأطۏرۏىأشذوۆأتههۄأؼهۏۄوتأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗأتًشأتضأوۏڽأڬًةۏأؼهحأوًدًزأۄەأۗأتىۄًڽأىەأزشدأسۏهأتضىتزأڬەأۄوشتۄأذزۏخأىمهأڬۏأۄەأۗ أ®لّئّرٕثّشّىّتأوْذّؤّزْأثٕىْأوًْضٌّأثٕىٓأؼٓوٕشّتىّأتهٕلّمٍٓيْ؏أخّىّتأبٓثٕشّتيٍٓوْأثٕىْأئّثٍٓأغّتهٓثِ؏أخّىّتأئّثًْأنْشٍّٕثِ؏أخّىّتأًّنٍٓؼُ؏أؼّىٕأضْلٍّٕتىّ¾ أتًشأتضشتةۏهأڬۏأشًتۏحأڬشزۄأذزۏخأزشدأسۏهأۄەأۗ%أ"
5388,أمتضوأثىأؼثزتهشذوىألشوتحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەأتشطتزألشوتۏتأ=أوۏڽأتځىۏأتوحأڬەأهةەأتضۏأډۏصأځشأشتعۏأۄًڽأدضأډۏصأځشأتوأؼثزأڬتأثۏټتأشتعۏأۄەأۗأ
5389,%أذعشحأؼهۏأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەأتشطتزألشوتۏتأ=أتڲشأوۏڽأڬضۏأڬًأثؽۏشأوطًشۄأڬەأحوۄتشتأرهۏلۄأثىتحتأحًأتثىأتوأؼثزأڬًأثىتحتأۗ أٰٰأۏۄأذزۏخأظذۏذأتهتضىتزأۄەأهۏڬىأطۏرۏىأشذوۆأتههۄأؼهۏۄوتأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗ%أ
5390,%أذعشحأؼوشأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەأتشطتزألشوتۏتأ=أدًأطرظأتضۏأتىزتصأوۏڽأمشإىأځڔہىتأډتۄحتأۄًأدضأتىزتصأوۏڽأىتصهأۄًتأحًأًۄأتثىأتوأوؼثزأڬۏأمشتؤحأځڔہەأۗ أٰٰأۏۄأذزۏخأتوتوأثرتشۏأشذوۆأتههۄأؼهۏۄأتًشأتوتوأوضهوأشذوۆأتههۄأؼهۏۄأڬەأوؼۏتشأڬەأوغتثمأظذۏذأۄەأهۏڬىأطۏرۏىأشذوۆأتههۄأؼهۏۄوتأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗ%أ
5391,"أذعشحأصۏزأثىأًۄثألشوتحەأۄۏڽأ=أوۏڽأذعشحأؼوشأشعۏأتههۄأؼىۄأڬەأځتضأثۏټہتأۄًتأحہتأڬۄأتۏڬأڬوصًشأطرظأتىأڬەأځتضأإۏتأ؏أإځأتىأڬۏأدتىثأزۏڬہىەأهڲەأتًشأتىأڬتأډۄشيأ+ألشغأوضشحأضەأ,أډوڬىەأهڲتأ؏أځہشألشوتۏتأ=أۏۄأطرظأؼهوأضەأڬۏضەأثہشځًشأۄەأ؏أۏۄأطرظأؼهوأضەأڬۏضەأثہشځًشأۄەأۗأ+أإځأڬۏأوشتزأ,أذعشحأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄأحہەأۗأ"
5392,%أذعشحأؼهۏأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أتىأضەأڬۄتأڲۏتأڬۄأشضًهأتههۄأ﷽أڬەأظذتثۄأڬەأثتشەأوۏڽأڬډہأثحتةۏڽأۗأإځأىەأزشۏتلحأڬۏتأ=أڬضأڬەأثتشەأوۏڽأثحتاڽأآأهًڲًڽأىەأڬۄتأ=أذعشحأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄأڬەأثتشەأوۏڽأۗأذعشحأؼهۏأشعۏأتههۄأؼىۄأىەألشوتۏتأ=أتىۄًڽأىەأڬحتثأًأضىحأڬتأؼهوأضۏڬہتأتًشأتضۏأځشأتىحۄتؤأڬشأزۏأتًشأۏۄأتىأڬًأڬتلۏأۄًأڲۏتأۗأتضأڬەأثؼزأځًشۏأذزۏخأثۏتىأڬۏأۗ أٰٰأۏۄأذزۏخأتوتوأثرتشۏأشذوۆأتههۄأؼهۏۄأتًشأتوتوأوضهوأشذوۆأتههۄأؼهۏۄأڬەأوؼۏتشأڬەأوغتثمأظذۏذأۄەأهۏڬىأطۏرۏىأشذوۆأتههۄأؼهۏۄوتأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗ%أ
5393,%أذعشحأضؼزأثىأتثۏأًمتظأشعۏأتههۄأؼىۄأزشدأسۏهأإۏحأڬەأثتشەأوۏڽأڬۄحەأۄۏڽأ= أ®~ًّهّتأحّغٕشْزٓأتهّٔسٍٓىّأٍّزٕؼًْىّأشّثّٔيْوٕأثٓتهٕؽّزّتجٓأًّتهٕؼّطٍٓٔٓأٍْشٍٓزًْىّأًّدٕيّيْأ^تهئىؼتو=أ85`¾ أ““أتًشأزًشأىۄأڬشًأتىۄۏڽأدًأتځىەأشثأڬًأځڬتشحەأۄۏڽأظثذأتًشأطتوأتضأڬۏأشعتأډتۄحەأ‟ۗأ+أحشدوۄأڬىصتهتۏوتىأتوتوأتذوزأشعتأ أۏۄأإۏحأځتىډأمشۏطۏأظذتثۏًڽأڬەأثتشەأوۏڽأىتصهأۄًةۏأ؏أوۏڽأتًشأتثىأوضؼًزأشعۏأتههۄأؼىۄأثہۏأتىأوۏڽأضەأۄۏڽأۗأمشۏطأىەأىثۏأتڬشوأ﷽أضەأڬۄتأ=أتڲشأحوأتىأڬًأتځىەأإځأضەأزًشأڬشأزًأحًأۄوأإځأڬەأځتضأثۏټہۏڽأڲەأۗأإځأتىأڬًأمشۏثأشڬہحەأۄۏڽأ؏أۄوۏڽأىۄۏڽأشڬہحەأۗأحثأۏۄأإۏحأىتصهأۄًةۏأ=
أ®ًّهّتأحّغٕشْزٓأتهّٔسٍٓىّأٍّزٕؼًْىّأشّثّٔيْوٕأثٓتهٕؽّزّتجٓأًّتهٕؼّطٍٓٔٓأٍْشٍٓزًْىّأًّدٕيّيْأوّتأؼّهٍّٕنّأوٓىٕأذٓضّتثٓيٓوٕأوٓىٕأطٍّٕؤِأًّوّتأوٓىٕأذٓضّتثٓنّأؼّهٍّٕيٓوٕأوٓىٕأطٍّٕؤِألّحّغٕشْزّيْوٕألّحّنًْىّأوٓىّأتهػّٔتهٓوٍٓىّأ؏أًّنّسّهٓنّألّحّىّٔتأثّؼٕعّيْوٕأثٓثّؼٕعِأهٍّٓمًْهًْتأئّيّاْهّتؤٓأوّىّٔأتههّٔيْأؼّهٍّٕيٓوٕأوٓىٕأثٍّٕىٓىّتأئّهٍّٕضّأتههّٔيْأثٓئّؼٕهّوّأثٓتهطّٔتنٓشٍٓىّأ+أتهئىؼتوأ=أ85أ؏أ86أ,"¾ أ†أتًشأزًشأىۄأڬشًأتىۄۏڽأدًأتځىەأشثأڬًأځڬتشحەأۄۏڽأظثذأتًشأطتوأتضأڬۏأشعتأډتۄحەأحوأځشأتىأڬەأذضتثأضەأڬډہأىۄۏڽأتًشأتىأځشأحوۄتشەأذضتثأضەأڬډہأىۄۏڽأځہشأتىۄۏڽأحوأزًشأڬشًأحًأۏۄأڬتوأتىظتلأضەأثؼۏزأۄەأ؏أتًشأۏًىۄۏأۄوأىەأتىأوۏڽأتۏڬأڬًأزًضشەأڬەأهةەألحىۄأثىتۏتأڬۄأوتهزتشأڬتلشأوذحتدأوضهوتىًڽأڬًأزۏڬہأڬشأڬۄۏڽأڬۏتأۏۄأۄۏڽأدىأځشأتههۄأىەأتذضتىأڬۏتأۄوأوۏڽأضەأڬۏتأتههيأرًثأىۄۏڽأدتىحتأذمأوتىىەأًتهًڽأڬًأ‟أ+أحشدوۄأڬىصتهتۏوتىأ؏أتوتوأتذوزأشعتأ أٰٰأۏۄأذزۏخأتوتوأثرتشۏأشذوۆأتههۄأؼهۏۄأتًشأتوتوأوضهوأشذوۆأتههۄأؼهۏۄأڬەأوؼۏتشأڬەأوغتثمأظذۏذأۄەأهۏڬىأطۏرۏىأشذوۆأتههۄأؼهۏۄوتأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗ%أ"""
5394,"%أدؼلشأثىأؼوشًأثىأذشۏخأتځىەأًتهزأڬتأۏۄأثۏتىأىمهأڬشحەأۄۏڽأڬۄأىثۏأتڬشوأ﷽أىەأذعشحأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄأضەألشوتۏتأ=أمشإىأڬۏأمشتؤحأڬشًأ؏أ+أذعشحأؼثزتههۄأىەأ,أڬۄتأ=أمشإىأحًأإځأ﷽أځشأىتصهأۄًتأۄەأحًأوۏڽأمشتؤحأڬۏضەأڬشًڽأآأشضًهأتههۄأ﷽أىەألشوتۏتأ=أوۏڽأزًضشەأضەأمشإىأضىىتأډتۄحتأۄًڽأۗأډىتىډۄأذعشحأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄأىەأضًشۆأتهىضتؤأڬۏأحهتًحأطشًؼأڬۏأدثأًۄأتضأإۏحأځشأځۄىډەأۗ"
أ®لّڬّۏٕلّأتٓسّتأدٓةٕىّتأوٓىٕأڬْهٔٓأتْؤّۆِأثٓطّہٓۏٕزِأًّدٓةٕىّتأثٓڬّأؼّهۏٳأہّاْهّتؤٓأطّہٓۏٕزَتأ+أتهىضتؤأ=أ74أ,"¾ أ†أحًأڬۏضۏأۄًأڲۏأدثأۄوأۄشأتوحأضەأتۏڬأڲًتۄأهتةۏڽأڲەأتًشأتەأوذثًثأحوۄۏڽأتىأضثأځشأڲًتۄأتًشأىڲۄثتىأثىتأڬشأهتةۏڽأڲەأ‟أ+أحشدوۄأڬىصتهتۏوتىأ؏أتوتوأتذوزأشعتأ أحًأشضًهأتههۄأ﷽أإثزۏزۄأۄًأڲةەأ؏أتضأومتوأځشأذعًشأ﷽أىەأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄأڬًأحهتًحأضەأشًڬأزۏتأۗأځہشأشضًهأتههۄأ﷽أىەأتىأڬًأڬۄتأ=أتثأثتحأڬشًأ؏أحًأتىۄًڽأىەأتځىۏأڲلحڲًأضەأځۄهەأتههۄأحؼتهۏٳأڬۏأذوزأًأخىتؤأڬۏأتًشأشضًهأتههۄأ﷽أځشأزشًزأًأضهتوأځڔہتأتًشأذمأڬۏأڲًتۄۏأزۏأ؏أتًشأځہشأڬۄتأ=أۄوأتههۄأحؼتهۏٳأڬەأشثأۄًىەأځشأ؏أتضهتوأڬەأزۏىأۄًىەأځشأشتعۏأۄۏڽأۗأتًشأوۏڽأحوۄتشەأهةەأتضأډۏصأځشأشتعۏأۄًڽأدضأډۏصأځشأتههۄأتًشأتضأڬتأشضًهأشتعۏأۄۏڽأۗأشضًهأتههۄأ﷽أىەألشوتۏتأ=أوۏڽأحوۄتشەأتضأډۏصأځشأشتعۏأۄًڽأدضأډۏصأځشأتوأوؼثزأڬەأثۏټەأشتعۏأۄۏڽأۗ أٰٰأۏۄأذزۏخأظذۏذأتهتضىتزأۄەأهۏڬىأطۏرۏىأشذوۆأتههۄأؼهۏۄوتأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗ%أ"""
5395,"%أتؼوطأڬۄحەأۄۏڽأ=أذعشحأطمۏمأشذوۆأتههۄأؼهۏۄأظذتثۄأڬشتوأشعۏأتههۄأؼىۄوأڬتأسڬشأڬشأشۄەأحہەأهۏڬىأتىۄًڽأىەأذعشحأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄأڬتأسڬشأىۄأڬۏتأۗأوۏڽأىەأتىأڬًأڬۄتأ=أوۏڽأزۏڬہأشۄتأۄًڽأڬۄأحوأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄأڬتأحسڬشۄأىۄۏڽأڬشأشۄەأ+أتضأڬۏأڬۏتأًدۄأۄەأآأ,أتىۄًڽأىەأڬۄتأ=أًۄأتۏضەأإزوۏأۄۏڽأڬۄأتىأضەأتلعهأڬًةۏأثہۏأىۄۏڽأۄەأ+أتضأهةەأًۄأوذحتدأثۏتىأىۄۏڽأۄۏڽأ أٰٰأۏۄأذزۏخأتوتوأثرتشۏأشذوۆأتههۄأؼهۏۄأتًشأتوتوأوضهوأشذوۆأتههۄأؼهۏۄأڬەأوؼۏتشأڬەأوغتثمأظذۏذأۄەأهۏڬىأطۏرۏىأشذوۆأتههۄأؼهۏۄوتأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗ%أ"
5396,%أذعشحأؼهموۄأڬۄحەأۄۏڽأ=أذعشحأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄأۄزتۏحأ؏أشتۄىوتةۏأتًشأرتوًطۏأوۏڽأشضًهأتههۄأ﷽أڬەأضتحہأوطتثۄحأشڬہحەأحہەأۗ أتثشتۄۏوأڬۄحەأۄۏڽأ=أتًشأذعشحأؼهموۄأ؏أذعشحأؼثزتههۄأڬەأضتحہأوطتثۄحأشڬہحەأحہەأۗ أٰٰأۏۄأذزۏخأتوتوأثرتشۏأشذوۆأتههۄأؼهۏۄأتًشأتوتوأوضهوأشذوۆأتههۄأؼهۏۄأڬەأوؼۏتشأڬەأوغتثمأظذۏذأۄەأهۏڬىأطۏرۏىأشذوۆأتههۄأؼهۏۄوتأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗ%أ
5397,%أؼوشًأثىأًتثظۄأتضزۏأڬەأًتهزألشوتحەأۄۏڽأڬۄأوۏڽأڬًلۄأوۏڽأتځىەأڲہشأوۏڽأحہتأ؏أزشًتصەأځشأڬضۏأىەأضهتوأڬۄۄأڬشأتىزشأإىەأڬۏأتدتصحأوتىڲۏأ؏أوۏڽأىەأضهتوأڬتأدًتثأزۏتأتًشأتىزشأإىەأڬۏأتدتصحأزەأزۏأۗأدثأًۄأإزوۏأتىزشأزترهأۄًتأحًأًۄأذعشحأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄأحہەأۗأوۏڽأىەأتىأضەأڬۄتأ=أتەأتثًؼثزتهشذوىأ$أتىحۄتةۏأضرحأزًځۄشأوۏڽأوهتمتحأڬتأۏۄأڬًىأضتأًمحأۄەأآأتىۄًڽأىەأڬۄتأ=أودہەأحًأزىأثۄحأهوثتأوذضًضأۄًأشۄتأحہتأوۏڽأىەأضًډتأڬۄأڬضۏأإزوۏأڬەأځتضأدتأڬشأتذتزۏخأڬتأحڬشتشأۄۏأڬشأهۏتأدتةەأۗأډىتىډۄأۄوأتۏڬأزًضشەأڬًأتذتزۏخأثۏتىأڬشىەأهڲەأ؏أتىۄًڽأىەأودہەأۏۄأذزۏخأضىتةۏأڬۄأشضًهأتههۄأ﷽أىەأتشطتزألشوتۏتأۄەأڬۄأتۏڬأًمحأوۏڽألحىەأؼتوأۄًڽأڲەأ؏أتضأًمحأضًةەأۄًةەأطرظأڬتألحىۄأهۏټەأۄًةەأطرظأضەأڬوأۄًأڲتأۗأتًشأهۏټتأۄًتأطرظأثۏټہەأۄًةەأضەأثۄحشأۄًأڲتأ؏أتًشأثۏټہتأۄًتأطرظأڬہڔەأۄًةەأضەأثۄحشأۄًأڲتأۗأتًشأڬہڔتأۄًتأځۏزهأډهىەأًتهەأضەأثۄحشأۄًأڲتأتًشأځۏزهأډهىەأًتهتأضًتشأضەأثۄحشأۄًأڲتأۗأځہشألشوتۏتأ=أضثأڬەأضثأهًڲأزًصرۏأۄًڽأڲەأۗ
أوۏڽأىەأځًډہتأ=أۏتأشضًهأتههۄأ﷽أۏۄأًمحأڬثأإةەأڲتأآأإځأىەألشوتۏتأ=أۄشدأڬەأزىًڽأوۏڽأۗأوۏڽأىەأځًډہتأ=أۏتأشضًهأتههۄأ﷽أۄشدأڬەأزىأڬًىأضەأۄًڽأڲەأآأإځأ﷽أىەألشوتۏتأ=أدثأڬًةۏأطرظأتځىەأزًضحأضەأوذلًػأىۄۏڽأۄًأڲتأۗأوۏڽأىەأځًډہتأ=أۏتأشضًهأتههۄأ﷽أتڲشأوۏڽأًۄأصوتىۄأځتاڽأحًأتضأًمحأڬەأهةەأإځأودہەأڬۏتأتشطتزألشوتحەأۄۏڽأآأإځأ﷽أىەألشوتۏتأ=أتځىەأضتىضأتًشأۄتحہأڬًأشًڬأڬشأڲہشأوۏڽأثۏټہأدتىتأۗأوۏڽأىەأځًډہتأ=أۏتأشضًهأتههۄأ﷽أتڲشأڬًةۏأطرظأڲہشأوۏڽأودہأځشأذوهۄأإًشأۄًأدتةەأحًأوۏڽأڬۏتأڬشًڽأآألشوتۏتأ=أحًأحوأتځىۏأذًۏهۏأڬەأڬضۏأڬوشەأوۏڽأڲہضأدتىتأۗأوۏڽأىەأځًډہتأ=أۏتأشضًهأتههۄأ﷽أتڲشأًۄأ+أزۄطحأڲشزأ,أوۏشەأڬوشەأوۏڽأڲہضأإةەأحًأوۏڽأڬۏتأڬشًڽأآألشوتۏتأ=أۏًڽأڬشأڬەأ+أۏۄأڬۄحەأۄًةەأإځأ﷽أىەأتځىتأزتۏتڽأۄتحہأتهټەأۄتحہأڬۏأڬهتةۏأځشأشڬہأڬشأ
5398,أوؽۏشۄأثىأتثۏأشصۏىأڬۄحەأۄۏڽأ=أذعشحأؼثتضأثىأؼثزتهوغهثأشعۏأتههۄأؼىۄأضەأځًډہتأڲۏتأ=أحوأثڔەأۄًأۏتأىثۏأتڬشوأ﷽أثڔەأۄۏڽأآأإځأىەألشوتۏتأ=أؼوشأوۏشۏأصۏتزۄأۄەأهۏڬىأودہأضەأثڔەأًۄأۄۏڽأۗأ
5399,"أذعشحأصثۏشأثىأثڬتشألشوتحەأۄۏڽأ=أذعشحأؼثتضأثىأؼثزتهوغهثأشعۏأتههۄأؼىۄأ+أضەأځًډہتأڲۏتأڬۄأإځأشضًهأتههۄأ﷽أضەأڬحىەأثڔەأۄۏڽأآأحًأتىۄًڽأىەألشوتۏتأ=أڬۄأًۄأ,أشضًهأتههۄأ﷽أضەأحۏىأضتهأثڔەأۄۏڽأۗأوۏشۏأًتهزۄأوذحشوۄأڬەأځتضأۏۄأرثشأځۄىډۏأڬۄأذعشحأإوىۄأڬەأۄتڽأثۏټتأځۏزتأۄًتأۄەأ؏أحًأدثأظثذأۄًةۏأحًأوۏشۏأًتهزۄأىەأوۏشتأۄتحہأځڬڔتأتًشأذعشحأإوىۄأڬەأڲہشأډهۏأڲةۏڽأۗأإدأثہۏأوۏشۏأىڲتۄًڽأوۏڽأًۄأوىػشأوًدًزأۄەأدثأشضًهأتههۄأ﷽أتځىەأڲہشأڬەأظذىأوۏڽأحہەأتًشأتځىەأځتاڽأۄهتأشۄەأحہەأۗأتًشأؼًشحۏڽأودہأضەأثتحۏڽأڬشىەأهڲۏڽأتًشأڬۄىەأهڲۏڽأڬۄأتځىەأثہتةۏأڬەأۄتحہًڽأڬًأډًوًأۗأشتًۏأڬۄحەأۄۏڽأڬۄأذعشحأؼثتضأثىأؼثزتهوغهثأشعۏأتههۄأؼىۄأ;;أضتهأڬۏأؼوشأوۏڽأضىأ67أۄدشۏأوۏڽألًحأۄًةەأۗأ"
5400,%أوذوزأثىأؼوشأتځىەأطۏًرأڬەأذًتهەأضەأثۏتىأڬشحەأۄۏڽأڬۄأؼثتضأثىأؼثزتهوغهثأثىأۄتطوأثىأؼثزأوىتلأ؏أشضًهأتههۄأ﷽أڬەأډډتأۄۏڽأ؏أتىأڬۏأًتهزۄأىحۏهۄأثىحأرثتثأثىأڬهۏثأثىأوتهڬأثىأؼوشًأثىأؼتوشأثىأصۏزأوىتۆأثىأؼتوشأتهرصشدۏۄأۄۏڽأۗأذعشحأؼثتضأثىأؼثزتهوغهثأشعۏأتههۄأؼىۄأڬۏأڬىۏحأ†أتثًتهلعهأ‟أحہۏأۗأذعشحألعهأتىأڬۏأتًهتزًڽأوۏڽأضثأضەأثڔەأحہەأ؏أتًشأذعشحأؼثتضأشعۏأتههۄأؼىۄأشضًهأتههۄأ﷽أضەأحۏىأضتهأثڔەأحہەأ؏أذعشحأؼثتضأشعۏأتههۄأؼىۄأىەأشضًهأتههۄأ﷽أڬەأۄوشتۄألحذأوڬۄأ؏أؽصًۄأذىۏىأ؏أؽصًۄأحثًڬأتًشأؽصًۄأغتةلأوۏڽأطشۏڬأۄًةەأتًشأدىڲأذىۏىأڬەأزىأدثأهًڲأإځأضەأثہتڲأډڬەأحہەأ؏أتضأًمحأإځأشضًهأتههۄأ﷽أڬەأضتحہأتىأڬەأڲہشأوۏڽأټہۄشەأحہەأۗ
أتثىأؼثتضأڬەأإصتزأڬشزۄأؽهتوأذعشحأطؼثۄألشوتحەأۄۏڽأ=أذعشحأؼثتضأشعۏأتههۄأؼىۄأضۏزہەأمزأًتهەأحہەأتًشأإځأذعشحأؼثزتهوغهثأڬەأثتشەأوۏڽأثحتۏتأڬشحەأحہەأڬۄأًلتحأڬەأًمحأثہۏأتىأڬتأمزأثتهڬهأضۏزہتأحہتأ+أوؼحزهأتهمىتۆأڬتأوغهثأۏۄأۄەأڬۄأثڔہتځەأڬۏأًدۄأضەأتىأڬەأمزأوۏڽأدہڬتاأځۏزتأىۄۏڽأۄًتأحہتأۗأطلۏمأ,"%أ"""
5401,أوذوزأثىأؼثزتههۄأثىأىوۏشألشوتحەأۄۏڽأ=أؼثتضأثىأؼثزتهوغهثأڬۏأًتهزۄأىحۏهۄأثىحأرثتثأثىأڬهۏثأثىأوتهڬأثىأؼوشًأثىأؼتوشأثىأىوشأثىأمتضغأۄۏڽأۗأذعشحأؼثتضأثىأؼثزتهوغهثأشعۏأتههۄأؼىۄأؼتوأتهلۏهأضەأحۏىأضتهأځۄهەأځۏزتأۄًةەأۗأ
5402,أذعشحأؼهۏأثىأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتألشوتحەأۄۏڽأ=أذعشحأؼثتضأشعۏأتههۄأؼىۄأىەأتځىۏأًلتحأڬەأًمحأ:3أؽهتوأإصتزأڬةەأۗأ
5403,%أشضًهأتههۄأ﷽أڬەأإصتزأڬشزۄأؽهتوأذعشحأتثًشتلؼأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أوۏڽأؼثتضأثىأؼثزتهوغهثأشعۏأتههۄأؼىۄأڬتأؽهتوأحہتأ؏أوۏڽأتضهتوأمثًهأڬشأډڬتأحہتأ؏أتىأڬۏأصًدۄأذعشحأتوأتهلعهأثہۏأتضهتوأهتأډڬۏأحہۏڽأتًشأذعشحأؼثتضأثہۏأوضهوتىأۄًأډڬەأحہەأهۏڬىأۏۄأهًڲأتځىەأمًوأڬەأڋشأڬۏأًدۄأضەأتځىەأتضهتوأڬًأډہځتةەأۄًةەأحہەأۗأتًشأتثًهۄثأدىڲأثزشأوۏڽأىۄۏڽأڲۏتأحہتأثهڬۄأتضأىەأتځىۏأدڲۄأؼتظأثىأۄطتوأڬًأثہۏدتأحہتأۗأؼتظأثىأۄطتوأځشأتثًهۄثأڬتأمشعۄأحہتأۗأتثًهۄثأىەأڬۄتأحہتأڬۄأحًأوۏشۏأغشلأضەأتضأدىڲأوۏڽأطشڬحأڬشأهەأ؏أوۏڽأحۏشتأحوتوأمشعۄأوؼتلأڬشأزًڽأڲتأۗأتضأىەأتۏضەأۄۏأڬۏتأۗأهۏڬىأدثأدىڲأثزشأڬۏأشضًتأڬىأرثشأإةۏأتًشأتههۄأحؼتهۏٳأىەأتثًهۄثأڬًأسهۏهأڬشأزۏتأۗأوۏڽأڬوصًشأإزوۏأحہتأ؏أوۏڽأتځىەأڬوشەأوۏڽأثۏټہأڬشأتىأحۏشًڽأڬًأډہۏهتأڬشحتأحہتأۗأرزتأڬۏأمضوأ$أوۏڽأتځىەأڬوشەأثۏټہتأحۏشأډہۏهأشۄتأحہتأتًشأتوأتهلعهأوۏشەأځتضأثۏټہۏأۄًةۏأحہۏڽأۗأتضۏأزًشتىأۄوتشەأرۏوەأڬۏأځډہهۏأدتىثأتثًهۄثأځتاڽأڲہضۏټحتأۄًتأإأڬشأثۏټہأڲۏتأ؏أتضأڬۏأځطحأوۏشۏأځطحأڬۏأدتىثأحہۏأ؏أتډتىڬأهًڲًڽأڬۏأإًتصأإةۏأ†أۏۄأتثًضلۏتىأثىأذتشخأإأڲۏتأ‟أتثًهۄثأىەأڬۄتأ=أتەأوۏشەأثہحۏدەأوۏشەأځتضأإاأ؏أتثًضلۏتىأإأڬشأتثًهۄثأڬەأځتضأثۏټہأڲۏتأتًشأڬډہأهًڲأوصۏزأإأڲةەأ؏أتًشأتىأڬەأځتضأڬہڔەأۄًأڲةەأ؏أتثًضلۏتىأىەأدىڲأڬەأذتهتحأتًشأطڬضحأڬۏأًدۄأځًډہۏأحًأتضأىەأڬۄتأ=أطڬضحأڬۏأًدۄأڬډہأثہۏأىۄۏڽأۄەأۗأرزتأڬۏأمضوأ$أدثأتىأضەأۄوتشۏأوڋثہۏڔأۄًةۏأحًأۄوأىەأتځىەأإځأڬًأتىأڬەأضځشزأڬشأزۏتأحتڬۄأًۄأدۏضەأډتۄۏڽأۄوۏڽأمحهأڬشۏڽأتًشأدۏضەأډتۄۏڽأڲشلحتشأڬشأهۏڽأتًشأتههۄأڬۏأمضوأ$أتضأضهضهەأوۏڽألًدۏًڽأڬًأڬًةۏأوهتوحأىۄۏڽأڬشحتأ؏أتضأىەأتضأڬۏأًدۄأځًډہۏأحًأتضأىەأثحتۏتأڬۄأۄوأىەأتثهمأڲہًڔًڽأځشأضلۏزأشىڲأڬەأهًڲًڽأڬًأزۏڬہتأۄەأًۄأىۄأحًأڬضۏأڬًأځىتۄأزۏحەأۄۏڽأتًشأىۄأتىأڬەأإڲەأڬًةۏأډۏصأټہۄشأضڬحۏأۄەأۗ
أ+أتثًشتلؼأ,"ألشوتحەأۄۏڽأ=أوۏڽأىەأرۏوەأڬتأځشزۄأتټہتۏتأتًشأڬۄتأ=أرزتأڬۏأمضوأ$أًۄألشطحەأحہەأۗأتثًهۄثأىەأودہەأحہځڔأوتشأزۏتأ؏أتًشأثزهەأوۏڽأ؏أوۏڽأىەأثہۏأتضأڬًأحہځڔأزەأوتشتأ؏أًۄأودہأضەأهڔأځڔتأتًشأودہەأصوۏىأځشأڲشتأڬشأوۏشەأضۏىەأځشأضًتشأۄًأڲۏتأ؏أتوأتهلعهأتټہۏڽأتًشأرۏوەأڬۏأتۏڬأهڬڔۏأڬہۏىډأڬشأتضأڬەأضشأځشأزەأوتشۏأدضأڬۏأًدۄأضەأتضأڬەأضشأوۏڽأثۄحأثڔتأصروأۄًأڲۏتأۗأتوأتهلعهأىەأڬۄتأ=أتەأتههۄأڬەأزطوىأ$أحوأىەأتضأڬەأإمتأڬًأؽۏشأوًدًزأځتأڬشأتضأڬًأڬوصًشأضودہأهۏتأحہتأ؏أحًأتثًهۄثأسهۏهأۄًأڬشأًۄتڽأضەأتټہتأ؏أرزتأڬۏأمضوأ$أتضأڬەأثؼزأًۄأظشلأ:أزىأصىزۄأشۄتأۗأتههۄأحؼتهۏٳأىەأتضأڬەأدضوأوۏڽأځہىضۏتڽأځۏزتأڬشأزۏڽأ؏أتًشأتىأځہىضۏًڽأڬۏأًدۄأضەأًۄأوشأڲۏتأ؏أتضأڬەأزًىًڽأثۏټًڽأىەأتضأڬًأزًأحۏىأزىأحڬأتضۏأغشذأډہًڔەأشڬہتأتًشأزلىأىۄۏڽأڬۏتأدضأڬۏأًدۄأضەأتضأڬەأدضوأضەأثزثًأځہًټىەأهڲۏأ؏أتۏڬأمشۏطۏأإزوۏأىەأتىأڬًأڬۄتأ=أحوۄۏڽأذۏتؤأىۄۏڽأإحۏأ؏أحوۄتشەأثتځأڬۏأهتطأڲہشأوۏڽأځڔۏأضڔأشۄۏأۄەأۗأتىۄًڽأىەأڬۄتأ=أۄوأتضأځۏځأًتهەأځہًڔًڽأضەأڋشأشۄەأۄۏڽأۗأمشۏطأتىأځہىضۏًڽأضەأتحىتأڲہثشتحەأحہەأدحىتأغتؼًىأضەأۗأثتهإرشأتۏڬأطرظأىەأڬۄتأ=أحوأتضأڬًأزلىأڬشىەأهەأډهًأوۏڽأحوۄتشەأضتحہأډهحتأۄًڽأۗأشتًۏأڬۄحەأۄۏڽأرزتأڬۏأمضوأ$أتىۄًڽأىەأتځىەأثتځأڬًأؽضهأىۄۏڽأزۏتأثهڬۄأزًشأضەأۄۏأتضأځشأځتىۏأڋتهأزۏتأ؏أځہشأتضأڬًأتټہتأڬشأهەأڲةەأوڬۄأڬەأثتهتةۏأؼهتمًڽأوۏڽأتۏڬأزۏًتشأڬەأضتحہأځہۏىڬأڬشأتضأڬەأتًځشأځحہشأًؽۏشۄأځہۏىڬأزۏةەأۗ%أ"""
5404,أذعشحأؼشًۄأثىأصثۏشألشوتحەأۄۏڽأ=أذعشحأؼثتضأثىأؼثزتهوغهثأشعۏأتههۄأؼىۄأتضهتوأهتةەأتًشأتځىەأًغىأوۏڽأټہۄشەأشۄەأ؏أتًشأۄدشحأىۄۏڽأڬۏأۗأ
5405,%أذعشحأدتثشأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أوۏشەأوتوًڽأدزأثىأمۏضأىەأودہەأتىظتشأڬەأتىأضحشأضًتشًڽأوۏڽأطتوهأۄًىەأځشأتثہتشتأدًأشضًهأتههۄأ﷽أڬۏأثتشڲتۄأوۏڽأذتعشأۄًةەأحہەأ؏أذتهتىڬۄأوۏڽأتۏڬأځحہشأثہۏأځہۏىڬىەأڬۏأغتمحأىۄۏڽأشڬہحتأحہتأۗأذعًشأ﷽أۄوتشەأځتضأحطشۏلأهتةەأتًشأتضأًمحأإځأ﷽أڬەأۄوشتۄأتىأڬەأډډتأذعشحأؼثتضأشعۏأتههۄأؼىۄأثہۏأحہەأۗأذعًشأ﷽أىەألشوتۏتأ=أتەأډډتأ$أوۏشەأهةەأتځىەأوتوًاڽأوۏڽأضەأڬډہأهًڲًڽأڬًأډىأهًأ؏أتىۄًڽأىەأدًتثتَأڬۄتأ=أتەأوذوزأ$أتځىەأشثأڬەأهةەأتًشأتځىەأهةەأدًأډتۄۏڽأإځأغهثألشوتأهۏڽأۗأشضًهأتههيأ﷽أىەألشوتۏتأ=أدضأڬًأوۏڽأتځىەأهةەأغهثأڬشًڽأڲتأتضأڬًأحوأشًڬأهًأڲەأدۏضتأڬۄأحوأىەأتضأضەأتځىەأوتهأتًشأتځىۏأدتىًڽأڬًأشًڬأشڬہتأۄەأۗأهًڲًڽأىەأڬۄتأ=أتڲشأۄوأۏۄأڬتوأڬشأڲصشۏڽأحًأۄوۏڽأتضأڬەأثزهەأوۏڽأڬۏتأوهەأڲتأآأإځأ﷽أىەألشوتۏتأدىحأۗ أٰٰأۏۄأحوتوأشًتۏتحأتۏڬأۄۏأؼثتشحأڬەأضتحہأوشًۏأۄۏڽأۗأتًشأوًضۏٳأثىأؼوشتىأڬۏأذزۏخأڬًأتىأضەأظشلأتىۄًڽأىەأۄۏأضىتأۄەأۗ أٰٰأۏۄأذزۏخأظذۏذأتهتضىتزأۄەأهۏڬىأطۏرۏىأشذوۆأتههۄأؼهۏۄوتأىەأتضأڬًأىمهأىۄۏڽأڬۏتأتًشأؼثتضۏۄأڬەأځتضأذعشحأؼثتضأڬەأمزۏوأتهتضهتوأۄًىەأځشأتضأضەأثڔہأڬشأڬًةۏأظذۏذأذزۏخأوًدًزأىۄۏڽأۄەأۗ%أ
5406,%أشضًهأتههۄأ﷽أڬەأإصتزأڬشزۄأؽهتوأذعشحأتثًشتلؼأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أوۏڽأؼثتضأثىأؼثزتهوغهثأشعۏأتههۄأؼىۄأڬتأؽهتوأحہتأ؏أۄوتشەأزهًڽأوۏڽأتضهتوأزترهأۄًأډڬتأحہتأهۏڬىأۄوأهًڲأتځىەأتضهتوأڬًأډہځتةەأۄًةەأحہەأۗأوۏڽأذعشحأؼثتضأشعۏأتههۄأؼىۄأڬتأؽهتوأحہتأوۏڽأحۏشأډہۏهتأڬشحتأحہتأ؏أځہشأدثأمشۏطأدىڲأثزشأوۏڽأشضًهأتههۄأ﷽أڬۏأدتىثأشًتىۄأۄًةەأ؏أۄوأًۄتڽأڬۏأرثشًڽأڬەأوىحػشأشۄتأڬشحەأحہەأۗأذعشحأعوتىأرصتؼۏأشعۏأتههۄأؼىۄأدىڲأثزشأڬۏأتۏڬأرًطأڬىأرثشأهەأڬشأۄوتشەأځتضأإةەأحًأۄوأشضًهأتههۄأ﷽أڬەأؽهثۄأڬۏأرثشأضىأڬشأثۄحأرًطأۄًةەأ؏أرزتأڬۏأمضوأ$أوۏڽأوڬۄأوۏڽأحہتأتًشأحۏشأډہۏهأشۄتأحہتأتًشأتوأتهلعهأوۏشەأځتضأثۏټہۏأۄًةۏأحہۏڽأتًشأۄوأشضًهأتههۄأ﷽أڬۏألحذأڬۏأرثشأضىأڬشأرًطأۄًأشۄەأحہەأتًشأشضًهأتههۄأ﷽أڬەأثتشەأوۏڽأۄوۏڽأتغهتؼتحأوهأشۄۏأحہۏڽأۗأتزہشأتثًهۄثأرثۏخأتځىەأځتاڽأڲہضۏټحتأۄًتأإأڲۏتأۗأتههۄأحؼتهۏٳأىەأتضأڬًألحذأوظغلۏٳأ﷽أڬۏأرثشأزەأڬشأسهۏهأًأشضًتأڬشأزۏتأۄًتأحہتأۗأًۄأإأڬشأرۏوەأڬۏأتضأدتىثأثۏټہأڲۏتأدزہشأرۏوەأڬۏأشضۏتڽأثتىزہۏأدتحۏأۄۏڽأۗأهًڲًڽأىەأإًتصأهڲتةۏأ““أۏۄأتثًضلۏتىأإأڲۏتأإأڲۏتأ‛‛أهًڲأتضأڬەأتشزڲشزأدوؼأۄًأڲةەأ؏أتثًهۄثأىەأتضأضەأڬۄتأ=أتەأوۏشەأثہحۏدەأوۏشەأځتضأإاأ؏أًۄأإأڬشأتضأڬەأضتوىەأثۏټہأڲۏتأۗأتثًهۄثأىەأدىڲأڬەأذتهتحأتًشأطڬضحأڬۏأًدۄأځًډہۏأحًأتضأىەأڬۄتأ=أطڬضحأڬۏأًدۄأڬډہأثہۏأىۄۏڽأۄەأۗأرزتأڬۏأمضوأ$أدثأتىأضەأۄوتشۏأوڋثہۏڔأۄًةۏأحًأۄوأىەأتځىەأڬتىزہەأتىأڬەأضځشزأڬشأزۏةەأحتڬۄأًۄأدۄتڽأډتۄۏڽأتځىتأتضهذۄأشڬہۏڽأتًشأتههۄأڬۏأمضوأ$أتضأضهضهەأوۏڽألًدۏًڽأڬًأڬًةۏأوهتوحأىۄۏڽأڬۏأ؏أتضأىەأتضأڬۏأًدۄأځًډہۏأحًأتضأىەأثحتۏتأڬۄأۄوأىەأتثهمأڲہًڔًڽأځشأضلۏزأشىڲأڬەأهًڲًڽأڬًأزۏڬہتأۄەأتىأڬەأإڲەأڬًةۏأطەأىۄۏڽأټہۄشأضڬحۏأۄەأۗ
أ+أتثًشتلؼأ,"ألشوتحەأۄۏڽأ=أوۏڽأىەأرۏوەأڬتأځشزۄأتټہتۏتأتًشأڬۄتأ=أرزتأڬۏأمضوأ$أًۄألشطحەأحہەأۗأتثًهۄثأىەأودہەأصًشأزتشأحہځڔأضەأوتشتأ؏أتًشأثزهەأوۏڽأ؏أوۏڽأىەأثہۏأتضأڬًأحہځڔأشضۏزأڬشأزۏتأ؏أًۄأودہأضەأهڔأځڔتأتًشأودہەأصوۏىأځشأڲشتأڬشأوۏشەأضۏىەأځشأضًتشأۄًأڲۏتأ؏أتوأتهلعهأتټہۏڽأتًشأرۏوەأڬۏأتۏڬأهڬڔۏأڬہۏىډأڬشأتضأڬەأضشأځشأزەأوتشۏأدضأڬۏأًدۄأضەأتضأڬەأضشأوۏڽأثۄحأثڔتأصروأۄًأڲۏتأۗأتوأتهلعهأىەأڬۄتأ=أتەأتههۄأڬەأزطوىأ$أحوأىەأتضأڬەأإمتأڬًأؽۏشأوًدًزأځتأڬشأتضأڬًأڬوصًشأضودہأهۏتأحہتأ؏أحًأتثًهۄثأسهۏهأۄًأڬشأًۄتڽأضەأتټہتأ؏أرزتأڬۏأمضوأ$أتضأڬەأثؼزأًۄأظشلأ:أزىأصىزۄأشۄتأۗ أتههيأحؼتهۏٳأىەأتضأڬەأدضوأوۏڽأځہىضۏتڽأځۏزتأڬشأزۏڽأ؏أتًشأتىأځہىضۏًڽأڬۏأًدۄأضەأًۄأوشأڲۏتأ؏أتضأڬەأزًىًڽأثۏټًڽأىەأتضأڬًأزًأحۏىأزىأحڬأتضۏأغشذأډہًڔەأشڬہتأتًشأزلىأىۄۏڽأڬۏتأدضأڬۏأًدۄأضەأتضأڬەأدضوأضەأثزثًأځہًټىەأهڲۏأۗأتۏڬأمشۏطۏأإزوۏأىەأتىأڬًأڬۄتأ=أحوۄۏڽأذۏتؤأىۄۏڽأإحۏأ؏أحوۄتشەأثتځأڬۏأهتطأڲہشأوۏڽأځڔۏأضڔأشۄۏأۄەأۗأتىۄًڽأىەأڬۄتأ=أۄوأتضأځۏځأًتهەأځہًڔًڽأضەأڋشأشۄەأۄۏڽأۗأمشۏطأتىأځہىضۏًڽأضەأتحىتأڲہثشتحەأحہەأدحىتأغتؼًىأضەأۗأثتهإرشأتۏڬأطرظأىەأڬۄتأ=أحوأتضأڬًأزلىأڬشىەأهەأډهًأوۏڽأحوۄتشەأضتحہأډهحتأۄًڽأۗأشتًۏأڬۄحەأۄۏڽأرزتأڬۏأمضوأ$أتىۄًڽأىەأتځىەأثتځأڬًأؽضهأىۄۏڽأزۏتأثهڬۄأزًشأضەأۄۏأتضأځشأځتىۏأڋتهأزۏتأ؏أځہشأتضأڬًأتټہتأڬشأهەأڲةەأوڬۄأڬەأثتهتةۏأؼهتمًڽأوۏڽأتۏڬأزۏًتشأڬەأضتحہأهټتأڬشأتضأڬەأتًځشأځحہشأًؽۏشۄأځہۏىڬأزۏةەأۗ%أ"""
5407,%أؼڬشوۄأشًتۏحأڬشحەأۄۏڽأڬۄأذعشحأتثًشتلؼأڬۄحەأۄۏڽأ=أوۏڽأؼثتضأثىأؼثزتهوغهثأشعۏأتههۄأؼىۄأڬتأؽهتوأحہتأۄوتشەأڲہشأوۏڽأتضهتوأزترهأۄًأډڬتأحہتأۗأذعشحأؼثتضأشعۏأتههۄأؼىۄأثہۏأتضهتوأهەأإةەأ؏أتوألعهأشعۏأتههۄأؼىۄتأثہۏأتضهتوأهەأإةۏڽأ؏أتًشأوۏڽأثہۏأوضهوتىأۄًأډڬتأحہتأۗأذعشحأؼثتضأشعۏأتههۄأؼىۄأتځىۏأمًوأضەأڲہثشتأشۄەأحہەأ؏أتًشأتىأڬۏأورتهلحأضەأڋشحەأحہەأۗأتضأهةەأًۄأتځىتأتضهتوأډہځتحەأحہەأۗ أٰٰأتثًتذوزأىەأتضأتضىتزأوۏڽأتضأوحىأځشأڬډہأتعتلۄأىۄۏڽأڬۏتأتًشأتضأڬًأوشضهتَأشًتۏحأڬۏتأۄەأۗأذعشحأؼثتضأشعۏأتههۄأؼىۄأڬەأدىڲأثزشأضەأځۄهەأمثًهأتضهتوأڬەأوحؼهمأدًأتذتزۏخأۄوأحڬأځۄىډۏأۄۏڽأًۄأۏۄۏأۄۏڽأۗأتىأڬًأحضهۏوأڬشأهًأ؏أتًشأؽًشأضەأضىًأ$أتثأتىأڬۏأوحعتزأشًتۏتحأثۏتىأڬۏأدتةۏڽأڲۏأۗ%أ
5408,%أذعشحأتىضأثىأوتهڬأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأۗأڬډہأتىظتشۏًڽأىەأشضًهأتههۄأ﷽أضەأتدتصحأوتىڲۏأتًشأؼشعأڬۏأ=أۏتأشضًهأتههۄأ﷽أ$أۄوۏڽأتدتصحأزۏدةەأۗأۄوأتځىەأثہتىدەأڬًأتضأڬتألزۏۄأوؼتلأڬشأزۏڽأۗأشضًهأتههۄأ﷽أىەألشوتۏتأ=أرزتأڬۏأمضوأ$أحوأتۏڬأزشۄوأثہۏأىۄأډہًڔًأڲەأۗ أٰٰأۏۄأذزۏخأتوتوأثرتشۏأشذوۆأتههۄأؼهۏۄأتًشأتوتوأوضهوأشذوۆأتههۄأؼهۏۄأڬەأوؼۏتشأڬەأوغتثمأظذۏذأۄەأهۏڬىأتىۄًڽأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗ%أ
5409,%أتوأتهوًوىۏىأذعشحأؼتةطۄأشعۏأتههۄأؼىۄتألشوتحۏأۄۏڽأ=أدثأتۄهأوڬۄأتځىەأمۏزۏًڽأڬەألزۏەأزۏىەأإةەأحًأذعشحأصۏىثأثىحأشضًهأتههيأ﷽أىەأتثًتهؼتظأڬتألزۏۄأثہۏدتأتًشأتضأوۏڽأًۄأۄتشأثہۏدتأدًأتىأڬۏأشرظحۏأڬەأًمحأتوأتهوًوىۏىأذعشحأرزۏدۄأشعۏأتههۄأؼىۄتأىەأتىأڬًأځۄىتۏتأحہتأۗأدثأشضًهأتههيأ﷽أىەأتضأۄتشأڬًأزۏڬہتأحًأإځأځشأثۄحأطزۏزأشمحأغتشۏأۄًأڲةۏأ؏أإځأىەألشوتۏتأ=أتڲشأحوأوىتضثأضودہًأحًأصۏىثأڬەأمۏزۏأڬًأډہًڔأزًأتًشأتضأڬتأۄتشأثہۏأًتځضأثہۏدأزًأۗأظذتثۄأڬشتوأشعۏأتههۄأؼىۄوأىەأضشأحضهۏوأروأڬۏتأتًشأذعشحأصۏىثأشعۏأتههۄأؼىۄتأڬتأۄتشأًتځضأثہۏدأزۏتأۗأتضأوًمؼأځشأذعشحأؼثتضأشعۏأتههۄأؼىۄأىەأڬۄتأ=أۏتأشضًهأتههيأ﷽أ$أوۏڽأحًأوضهوتىأحہتأ؏أشضًهأتههۄأ﷽أىەألشوتۏتأ=أوۏڽأحوۄتشەأتضهتوأڬًأثۄحشأدتىحتأۄًڽأتڲشأثتحأتضۏأغشذأۄًةۏأدۏضەأحوأڬۄۄأشۄەأۄًأحًأتههۄأحؼتهۏٳأحوۄۏڽأتضأڬۏأدصتؤأزەأڲتأۗأحوأتځىتأثہۏألزۏۄأزًأتًشأتځىەأزًىًڽأثہحۏدًڽأىًلهأثىأذتشخأثىأؼثزتهوغهثأتًشأؼمۏهأثىأتثۏأغتهثأثىأؼثزتهوغهثأڬتأثہۏألزۏۄأزًأتًشأتځىەأذهۏلأؼحثۄأثىأؼوشًأثىأدذزوأثىۏأذتشخأثىألۄشأڬەأثہتةۏأڬتأثہۏألزۏۄأزًأۗ أذعشحأؼثتضأشعۏأتههۄأؼىۄأىەأڬۄتأ=أۏتأشضًهأتههۄأ﷽أوۏشەأځتضأحًأڬډہأثہۏأىۄۏڽأۄەأۗ أشضًهأتههيأ﷽أىەألشوتۏتأ=أًۄأوتهأڬۄتڽأۄەأدًأحوأىەأتًشأتوألعهأىەأزلىأڬۏتأۄەأآأتًشأحًأىەأتوأتهلعهأضەأڬۄتأحہتأڬۄأتڲشأوۏڽأدىڲأوۏڽأطۄۏزأۄًأدتاڽأحًأۏۄألعهأڬۏأتًهتزًڽأڬًأتًشأؼثزتههۄأڬًأتًشأمخوأڬًأزۏىتأۗ أذعشحأؼثتضأشعۏأتههۄأؼىۄأىەأڬۄتأ=أۏتأشضًهأتههيأ﷽أتههۄأڬۏأمضوأ$أوۏڽأڲًتۄۏأزۏحتأۄًڽأ؏أثەأطڬأإځأتههۄأڬەأشضًهأۄۏڽأۗأۏۄأًۄأثتحأحہۏأدضأڬًأوۏشەأتًشأتوأتهلعهأڬەأضًتأزًضشتأڬًةۏأثہۏأىۄۏڽأدتىحتأحہتأۗأۏتأشضًهأتههۄأ﷽أوۏشۏأدتىثأضەأثۏضأتًمۏۄأدًأڬۄأوۏشەأځتضأۄەأتضأڬتأذضتثأڬشأهۏڽأۗأشضًهأتههيأ﷽أىەألشوتۏتأ=أټہۏڬأۄەأتۏضتأۄۏأڬشأهًأ؏أډىتىډۄأذعشحأؼثتضأشعۏأتههۄأؼىۄأىەأتځىتأ؏أتځىەأثہتىدًڽأتًشأتځىەأذهۏلأڬۏأدتىثأضەألزۏۄأتزتأڬۏتأۗأتضأوًمؼأځشأتههيأحؼتهۏٳأىەأۏۄأإۏحأىتصهألشوتةۏأۗ أ®~ٍّتأئٍّْٔيّتأتهىّٔثٍْٓٔأمْهٕأهٓوّىٕألٍٓأئٍّٕزٍٓنْوٕأوٓىّأتهٕئّضٕشٌّأبٓىٕأٍّؼٕهٓوٓأتههّٔيْألٍٓأمْهًْثٓنْوٕأرٍّٕشَتأٍْإحٓنْوٕأرٍّٕشَتأوٓؤّتأئْرٓسّأوٓىٕنْوٕأًٍّّؽٕلٓشٕأهّنْوٕأًّتههّٔيْأؽّلًْشُأشّذٍٓوُأ^تهئىلته=أ:3`¾ أ†أتەأؽۏثأڬۏأرثشۏڽأثحتىەأًتهەأدًأمۏزۏأحوۄتشەأۄتحہأوۏڽأۄۏڽأتىأضەألشوتاأتڲشأتههۄأىەأحوۄتشەأزهأوۏڽأثہهتةۏأدتىۏأحًأدًأحوأضەأهۏتأڲۏتأتضأضەأثۄحشأحوۄۏڽأؼغتألشوتةەأڲتأتًشأحوۄۏڽأثرطأزەأڲتأتًشأتههۄأثرطىەأًتهتأوۄشثتىأۄەأ‟أ+أحشدوۄأڬىصتهتۏوتىأ؏أتوتوأتذوزأشعتأ أشضًهأتههۄأ﷽أىەأتىأثۏضأتًمۏۄأڬەأثزهەأتضهتوأوۏڽأثۏضأؽهتوأؼغتألشوتةەأتىأوۏڽأضەأۄشأتۏڬأڬۏأوهڬأوۏڽأثۄحأضتشتأوتهأحہتأۗأهۏڬىأودہەأرًتۄطألمغأتههيأحؼتهۏٳأڬۏأدتىثأضەأوؽلشحأڬۏأحہۏأۗ أٰٰأۏۄأذزۏخأتوتوأوضهوأشذوۆأتههۄأؼهۏۄأڬەأوؼۏتشأڬەأوغتثمأظذۏذأۄەأهۏڬىأطۏرۏىأشذوۆأتههۄأؼهۏۄوتأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗ%أ
5410,%أذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتألشوتحەأۄۏڽأ=أشضًهأتههۄأ﷽أذعشحأؼثتضأشعۏأتههۄأؼىۄأڬتأتذحشتوأتۏضەأڬۏتأڬشحەأحہەأدۏضەأڬًةۏأثۏټتأتځىەأثتځأڬتأتذحشتوأڬشحتأۄەأۗأذعًشأ﷽أتىأڬًأۏۄأحرظۏظأتضأهةەأزۏتأڬشحەأحہەأڬۄأتههيأحؼتهۏٳأىەأتىأڬًأهًڲًڽأوۏڽأضەأرتظأڬۏتأحہتأۗ أٰٰأۏۄأذزۏخأظذۏذأتهتضىتزأۄەأهۏڬىأطۏرۏىأشذوۆأتههۄأؼهۏۄوتأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗ%أ
5411,%أذعشحأؼثزتههيأثىأؼثتضأشعۏأتههۄأؼىۄوتألشوتحەأۄۏڽأڬۄأشضًهأتههيأ﷽أىەأتشطتزألشوتۏتأ=أؼثتضأودہأضەأۄەأتًشأوۏڽأؼثتضأضەأۄًڽأۗ أٰٰأۏۄأذزۏخأظذۏذأتهتضىتزأۄەأهۏڬىأطۏرۏىأشذوۆأتههۄأؼهۏۄوتأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗ%أ
5412,%أذعشحأتثًشتلؼأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەأتشطتزألشوتۏتأ=أتەأتثًتهلعهأ$أحدہەأتههيأحؼتهۏٳأڬۏأتحىۏأشذوحۏڽأوهۏڽأڲۏأذحۏأڬۄأحًأشتعۏأۄًأدتةەأڲتأۗ أٰٰأۏۄأذزۏخأظذۏذأتهتضىتزأۄەأهۏڬىأطۏرۏىأشذوۆأتههۄأؼهۏۄوتأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗ%أ
5413,%أؼثتضأثىأؼثزتهوغهثأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أوۏڽأتۏڬأزىأوضدزأوۏڽأثۏټہتأۄًتأحہتأ؏أتثًدۄهأإۏتأتًشأڬۄىەأهڲتأ=أودہەأتههۄأڬۏأمضوأۄەأتڲشأوۏڽأىەأوذوزأڬًأزۏڬہأهۏتأحًأتضأڬۏأڲشزىأهحتڔًڽأڲتأۗأوۏڽألًشتَأشضًهأتههۄأ﷽أڬەأځتضأڲۏتأتًشأإځأ﷽أڬًأتثًدۄهأڬۏأثتحأثحتةۏأۗأځہشأتثًدۄهأؽظەأڬەأؼتهوأوۏڽأوضدزأوۏڽأإأڲۏتأ؏أًۄأتحىۏأدهزۏأوۏڽأحہتأڬۄأزشًتصەأوۏڽأضەأڲصشىەأڬۏأثدتةەأزۏًتشأځہتىزأڬشأتىزشأإۏتأ؏أوۏڽأىەأڬۄتأ=أإدأحًأثڔۏأإصوتةطأڬتأزىأۄەأۗأوۏڽأثہۏأتضأڬەأځۏډہەأځۏډہەأإأڲۏتأۗأځہشأشضًهأتههۄأ﷽أۏۄأإۏتحأځڔہحەأۄًةەأوضدزأوۏڽأحطشۏلأهتةەأ=
أ®تمٕشّئٕأثٓتضٕوٓأشّثٔٓنّأتهّٔسٍٓأرّهّمّأرّهّمّأتهٕبٓىٕضّتىّأوٓىٕأؼّهّمِأ+أتهؼهمأ=أ4أ؏أ5أ,¾
أ†أځڔہًأتځىەأشثأڬەأىتوأضەأدضأىەأځۏزتأڬۏتأإزوۏأڬًأرًىأڬۏأځہټڬأضەأثىتۏتأ‟أ+أحشدوۄأڬىصتهتۏوتىأ؏أتوتوأتذوزأشعتأ,أتًشأدثأإځأتثًدۄهأڬەأوحؼهمأىتصهأۄًىەأًتهۏأتىأإۏتحأځشأځۄىډە
أ®~نّهّٔتأبٓىّٔأتهٕبٓىٕضّتىّأهٍّّغٕؽٌّأئّىٕأشّإيْأتضٕحّؽٕىٌّأ+أتهؼهمأ=أ9أۗأ:أ,¾ أ†أۄتڽأۄتڽأثەأطڬأإزوۏأضشڬطۏأڬشحتأۄەأتضأځشأڬۄأتځىەأإځأڬًأؽىۏأضودہأهۏتأ‟أ+أحشدوۄأڬىصتهتۏوتىأ؏أتوتوأتذوزأشعتأ
أتۏڬأإزوۏأىەأتثًدۄهأڬًأڬۄتأ=أتەأتثًتهذڬوأ$أۏۄأۄۏڽأوذوزأشضًهأتههيأ﷽أ+أتثأڬشأهًأدًأڬډہأزؼًەأڬشأشۄتأحہتأ,"أتثًدۄهأىەأڬۄتأ=أدًأڬډہأودہەأىػشأإأشۄتأۄەأڬۏتأحوأًۄأضثأىۄۏڽأزۏڬہأشۄەأۄًأ؏أرزتأڬۏأمضوأ$أإضوتىأودہأځشأڲشىەأًتهتأۄەأۗأځہشأدثأشضًهأتههيأ﷽أتضأضًشحأڬەأإرشأحڬأځۄىډەأحًأضدزۄأڬۏتأۗ أٰٰأۏۄأذزۏخأظذۏذأتهتضىتزأۄەأهۏڬىأطۏرۏىأشذوۆأتههۄأؼهۏۄوتأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗ%أ"""
5414,"%أذعشحأؼثتضأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أوۏڽأتۏڬأشتحأشضًهأتههۄأ﷽أڬەأځتضأوًدًزأحہتأ؏أإځأ﷽أىەأودہەأڬۄتأ=أإضوتىأڬۏأدتىثأزۏڬہًأ؏أوۏڽأىەأإضوتىأڬۏأدتىثأزۏڬہتأۗأإځأ﷽أىەألشوتۏتأ=أڬۏتأحوۄۏڽأإضوتىأوۏڽأڬًةۏأډۏصأىػشأإأشۄۏأۄەأآأوۏڽأىەأڬۄتأ=أدۏأۄتڽأۗأإځأ﷽أىەألشوتۏتأ=أڬۏتأډۏصأىػشأإأشۄۏأۄەأآأوۏڽأىەأڬۄتأ=أخشۏتأۗأ+أۏؼىۏأضحتشەأىػشأإأشۄەأۄۏڽأ,أإځأ﷽أىەألشوتۏتأ=أحۏشۏأىضهأوۏڽأتضأڬەأثشتثشأحؼزتزأۄًأڲۏأۗ أٰٰأؼثۏزأثىأتثۏأمشۄأۏۄأذزۏخأهۏخأضەأشًتۏحأڬشىەأوۏڽأوىلشزأۄۏڽأۗأتًشأۄوتشەأتوتوأتثًصڬشۏتأشذوۆأتههۄأؼهۏۄأتڲشأتضأذزۏخأځشأشتعۏأىۄأۄًحەأحًأتۏضۏأذزۏخأۄشڲصأثۏتىأىۄأڬشحەأۗ%أ"
5415,"%أذعشحأضۄهأثىأضؼزأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أشضًهأتههۄأ﷽أضرحأڲشوۏأڬەأوًضوأوۏڽأ+أضلشأځشأ,أىڬهەأ؏أتۏڬأومتوأځشأځڔتاأڋتهتأ؏أإځأ﷽أؽضهأڬشىەأڬەأهةەأڬہڔەأۄًةەأ؏أذعشحأؼثتضأثىأؼثزتهوغهثأشعۏأتههۄأؼىۄأىەأتۏڬأتًىۏأډتزشأڬەأضتحہأإځأڬەأهةەأځشزۄأڬشأزۏتأۗأذعشحأضۄهأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أوۏڽأىەأډتزشأڬۏأدتىثأضەأشضًهأتههۄأ﷽أڬًأزۏڬہتأ؏أإځأتځىتأډۄشتأإضوتىأڬۏأدتىثأتټہتأڬشأۏۄأزؼتأوتىڲأشۄەأحہەأ““أتەأتههۄأ$أؼثتضأتًشأتضأڬۏأتًهتزأڬًأزًصرأضەأثډتأ‟ۗ أٰٰأۏۄأذزۏخأظذۏذأتهتضىتزأۄەأهۏڬىأطۏرۏىأشذوۆأتههۄأؼهۏۄوتأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗ%أ"
5416,%أذعشحأؼثزتههيأثىأذتشخۄأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأدثأظلًتىأثىأرهلأثىأتوۏۄأدوذۏأإةەأحًأشضًهأتههيأ﷽أىەأزشۏتلحأڬۏتأ=أحوأڬضأڬەأځتضأټہۄشەأۄًأآأتىۄًڽأىەأدًتثأزۏتأ=أؼثتضأشعۏأتههۄأؼىۄأڬەأځتضأۗأشضًهأتههيأ﷽أىەألشوتۏتأ=أحوأتضأمشۏطۏأڬەأځتضأټہۄشەأۄًأدضأڬەأضتحہأمشۏطۏأهًڲأثۄحأوذثحأڬشحەأۄۏڽأۗ أٰٰأۏۄأذزۏخأظذۏذأتهتضىتزأۄەأهۏڬىأطۏرۏىأشذوۆأتههۄأؼهۏۄوتأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗ%أ
5417,"%أرشۏوأثىأتًضأثىأذتشخۄأثىأهتوأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أدثأشضًهأتههيأ﷽أحثًڬأضەأًتځضأهًټەأوۏڽأإځأ﷽أڬۏأثتشڲتۄأوۏڽأذتعشأۄًتأ؏أتًشأتضهتوأهەأإۏتأ؏أوۏڽأىەأضىتأڬۄأذعشحأؼثتضأثىأؼثزتهوغهثأشعۏأتههۄأؼىۄأڬۄۄأشۄەأحہەأ=أۏتأشضًهأتههۄأ﷽أوۏڽأإځأڬۏأحؼشۏلأًأخىتؤأڬشىتأډتۄحتأۄًڽأۗأشضًهأتههۄأ﷽أىەألشوتۏتأ=أ+أټہۏڬأۄەأ,أڬۄًأ؏أتههۄأحؼتهۏٳأحوۄتشەأوىۄأڬًأڬثہۏأرتهۏأىۄأڬشەأۗأتىۄًڽأىەأزشدأسۏهأتطؼتشأځڔہەأۗ أ-أإځأتضأضەأځۄهەأدىحأوۏڽأحہەأتًشأذعشحأذًتؤأشعۏأتههۄأؼىۄتأڬەأثغىأوثتشڬأوۏڽأدۄتڽأځشأدضوأځشأزشرحًڽأڬەأځحەأهځۏټەأدتأشۄەأحہەأۗ"
أ-أځہشأإځأتضأًغىأوۏڽأإةەأدۄتڽأإځأىۄأثطشأحہەأ؏أىۄأوعؽۄأ+أڲًطحأڬۏأثًټۏأ,أحہەأتًشأىۄأؼهمأ+أرًىأڬۏأځہټڬأ
5418,"%أذعشحأؼثتضأثىأؼثزتهوغهثأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أوۏڽأدىڲأذىۏىأڬەأزىأشضًهأتههۄأ﷽أڬەأځتضأذتعشأۄًتأ؏أوۏڽأتًشأتثًضلۏتىأثىأذتشخأثىأؼثزتهوغهثأشعۏأتههۄأؼىۄأوضهضهأشضًهأتههۄأ﷽أڬەأۄوشتۄأشۄەأ؏أشضًهأتههۄأ﷽أتضأزىأتځىەأثۏعتؤأرډشأځشأضًتشأحہەأ؏أدًأڬۄألشًۄأثىأىؼتوۄأدستوۏأىەأإځأ﷽أڬًأحذلۄأزۏتأحہتأۗأدثأوضهوتىًڽأتًشأڬتلشًڽأڬۏأوڋثہۏڔأۄًةۏأحًأڬډہأ+أڬوصًشأتؼظتثأًتهەأ,أوضهوتىأوۏزتىأډہًڔأڬشأثہتڲأىڬهەأهۏڬىأشضًهأتههۄأ﷽أىەأ+أتىأضرحأذتهتحأوۏڽأثہۏأ,أتځىەأرډشأڬًأڬلتشأڬۏأدتىثأتۏڔہأهڲتةۏأۗأذعشحأؼثتضأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أتضأزىأإځأ﷽أڬەأرډشأڬۏأهڲتوأوۏشەأۄتحہأوۏڽأحہۏأتًشأوۏڽأدتىأثًدہأڬشأتضأڬًأشًڬىەأڬۏأڬًططأڬشأشۄتأحہتأحتڬۄأًۄأڬلتشأڬۏأظلًڽأوۏڽأدهزۏأىۄأځۄىډأضڬەأۗأتًشأتثًضلۏتىأشضًهأتههۄأ﷽أڬۏأشڬتثۏڽأحہتوەأۄًةەأحہەأۗأشضًهأتههۄأ﷽أىەألشوتۏتأ=أتەأؼثتضأ$أثۏؼحأشعًتىأڬەأطشڬتؤأڬًأثهتاأ؏أوۏڽأىەأتىأڬًأإًتصأزۏأ؏أتههۄأڬۏأمضوأ$أهڲحتأحہتأڬۄأدثأتىۄًڽأىەأوۏشۏأإًتصأضىۏأحًأڬضۏأډۏصأىەأتىأڬتأوىۄأځڬڔأڬشأًتځضأزہڬۏهأزۏتأۄًأدۏضەأڲتةەأتځىۏأثډہۏتأڬًأًتځضأهتحۏأۄەأۗأتىۄًڽأىەأوۏشۏأإًتصأځشأڬۄتأ=أۄوأذتعشأۄۏڽأ؏أۄوأذتعشأۄۏڽأۗأشتًۏأڬۄحەأۄۏڽأځہشأتىأهًڲًڽأىەأرًثأدوأڬشأهڔتةۏأڬۏأۗأتًشأتىظتشأڬًأتىأهلػًڽأوۏڽأځڬتشتأڲۏتأحہتأ†أۏتأڲشًيأتىظتشأ؏أتەأڲشًۄأتىظتشأ‟أځہشأۏۄأثهتًتأظشلأتىظتشأحڬأوذزًزأڬشأزۏتأڲۏتأۗأتىأڬًۏًڽأځڬتشتأڲۏتأ†أتەأڲشًۄأتىظتشأ؏أتەأڲشًۄأتىظتشأ‟ۗأځہشأۏۄأزؼًحأظشلأثىۏأذتشخأثىأرصشدأحڬأوذزًزأۄًأڲةۏأتًشأتىۄًڽأىەأتەأثىۏأذتشخأثىأرصشدأ؏أتەأثىۏأذتشخأثىأرصشدأ‟أڬۄۄأڬشأإًتصۏڽأزۏڽأۗأشضًهأتههيأ﷽أىەأتځىەأرډشأځشأضًتشأذتهحأوۏڽأضشأتًىډتأڬشأڬەأتىأڬۏأهڔتةۏأڬتأىػتشتأڬۏتأحًألشوتۏتأ=أۏۄأڲہوضتىأڬۏأدىڲأڬتأًمحأۄەأۗأشتًۏأڬۄحەأۄۏڽأ=أځہشأشضًهأتههۄأ﷽أىەأڬډہأڬىڬشۏتڽأځڬڔأڬشأڬلتشأڬەأډۄشًڽأڬۏأدتىثأځہۏىڬۏڽأځہشألشوتۏتأ=أًۄأطڬضحأڬہتأڲةەأوذوزأ﷽أڬەأشثأڬۏأمضوأ$أځہشأوۏڽأدىڲأڬتأوىػشأزۏڬہىەأڬەأهةەأڲۏتأتضأًمحأوۏشەأزۏڬہىەأوۏڽأحًأدىڲأتثہۏأتځىۏأتضۏأظًشحأځشأمتةوأحہۏأهۏڬىأدثأشضًهأتههۄأ﷽أىەأڬىڬشۏتڽأتىأڬۏأدتىثأځہۏىڬأزۏڽأحًأتضأڬەأثؼزأًۄأڬوصًشأۄًىتأطشًؼأۄًأڲةەأتًشأثتهإرشأًۄأهًڲأوۏزتىأدىڲأضەأثہتڲأڬہڔەأۄًةەأۗ أٰٰأۏۄأذزۏخأتوتوأثرتشۏأشذوۆأتههۄأؼهۏۄأتًشأتوتوأوضهوأشذوۆأتههۄأؼهۏۄأڬەأوؼۏتشأڬەأوغتثمأظذۏذأۄەأهۏڬىأتىۄًڽأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗ%أ"
5419,%أذعشحأضؼزأثىأتثۏأًمتظأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أشضًهأتههيأ﷽أڲہًڔًڽأڬەأتظغثهأوۏڽأهطڬشأڬۏأحۏتشۏأڬشًتأشۄەأحہەأڬۄأذعشحأؼثتضأثىأؼثزتهوغهثأشعۏأتههۄأؼىۄأًۄتڽأإأڲةەأ؏أحًأشضًهأتههيأ﷽أىەألشوتۏتأ=أۏۄأؼثتضأحوۄتشەأىثۏأڬەأډډتأۄۏڽأ؏أحوتوأمشۏطأضەأصۏتزأضرۏأۄۏڽأتًشأتىأځشأضثأضەأصۏتزۄأوۄشثتىأۄۏڽأۗ أٰٰأۏۄأذزۏخأظذۏذأتهتضىتزأۄەأهۏڬىأطۏرۏىأشذوۆأتههۄأؼهۏۄوتأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗ%أ
5420,أذعشحأضؼزأثىأتثۏأًمتظأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأىثۏأتڬشوأ﷽أهطڬشأڬۏأحۏتشۏأڬەأضهضهەأوۏڽأىڬهەأۄًةەأحہەأ؏أإځأ﷽أىەأذعشحأؼثتضأشعۏأتههۄأؼىۄأڬًأزۏڬہأڬشألشوتۏتأ=أۏۄأىثۏأ﷽أڬەأډډتأۄۏڽأتًشأحوتوأمشۏطأضەأصۏتزۄأضرۏأۄۏڽأتًشأتىأڬەأضتحہأضثأضەأصۏتزۄأظهۄأشذوۏأڬشىەأًتهەأۄۏڽأۗأ
5421,%أذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتألشوتحەأۄۏڽأ=أتۏڬأطرظأىەأذعشحأؼثتضأشعۏأتههۄأؼىۄأڬەأًتهزأڬتأحسڬشۄأڬۏتأتًشأتىأڬًأثشتأثہهتأڬۄىەأهڲأڲۏتأۗأذعشحأؼثتضأشعۏأتههۄأؼىۄأىەأتىأڬًأحہځڔأزەأوتشتأ؏أتضأځشأثۄحأضتشەأهًڲأدوؼأۄًأڲةەأتًشأڬۄىەأهڲەأ=أرزتأڬۏأمضوأ$أۄوأثہۏأؼثتضأڬًأتضۏأغشذأحہځڔأوتشۏڽأڲەأدۏضەأتضأىەأوتشتأۄەأۗأۏۄأثتحأشضًهأتههيأ﷽أحڬأځۄىډۏأحًأشضًهأتههۄأ﷽أىەأرغثۄأزۏتأتًشأتشطتزألشوتۏتأ=أؼثتضأودہأضەأۄەأتًشأوۏڽأؼثتضأضەأۄًڽأ؏أحوأوشەأۄًاڽأڬًأڲتهۏأوحأزًأڬۄأتضأضەأتىأڬەأصىزۄأشطحۄأزتشًڽأڬًأحڬهۏلأۄًحۏأۄەأۗ أٰٰأۏۄأذزۏخأظذۏذأتهتضىتزأۄەأهۏڬىأطۏرۏىأشذوۆأتههۄأؼهۏۄوتأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗ%أ
5422,%أذعشحأؼمثۄأثىأؼثزتهؽتلشألشوتحەأۄۏڽأ=أذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأ؏أذعشحأوؼتًۏۄأثىأتثًضلۏتىأشعۏأتههۄأؼىۄأڬەأځتضأڲةەأ؏أتضأًمحأوؼتًۏۄأشعۏأتههۄأؼىۄأڬەأځتضأمشۏطأڬەأڬډہأرتىزتىأذهمۄأهڲتةەأثۏټہەأحہەأۗأذعشحأوؼتًۏۄأشعۏأتههۄأؼىۄأىەأتىأڬەأإثتؤأًأتدزتزأڬەأثتشەأوۏڽأضًتهتحأڬةەأ؏أځہشأۏۄأځًډہتأڬۄأحوۄتشۏأتځىەأًتهزأؼثتضأثىأؼثزتهوغهثأڬەأثتشەأوۏڽأڬۏتأشتةەأۄەأآتىۄًڽأىەأڬۄتأ=أتههۄأحؼتهۏٳأتىأځشأشذوأڬشەأ؏أًۄأتثًتهلعهأىثۏأتڬشوأ﷽أڬەأډډتأحہەأ؏أشضًهأتههۄأ﷽أڬۏأإىڬہًڽأڬۏأټہىڋڬأحہەأۗأإځأڬەأضثأضەأثڔەأډډتأحہەأ؏أتًشأإځأڬەأثۄحأتډہەأزًضحأحہەأ؏أثۄحأثصشڲۏأًتهەأحہەأ؏أتىأڬەأإثتؤأًأتدزتزأضرۏأتًشأتډہەأشتۄىوتأحہەأ؏أتىأڬًأثۄحأضەأتوًشأڬتأؼهوأحہتأ؏أذًظهۄأتًشأثشزثتشۏأتىأڬتأصۏًشأحہتأ؏أتىأڬۏألۄوأًألشتضحأثۄحأثهىزأحہۏأ؏أۄشأڲتهۏأزۏىەأًتهەأڬەأضتوىەأذًظهۄأشڬہحەأحہەأ؏أتًشأۄشأضرحأورتهلأڬًأتځىەأشتةەأڬەأوًتلمأڬشأهۏحەأحہەأ؏أدثأتىأڬۏألعۏهحًڽأڬتأحسڬشۄأۄًحتأۄەأحًأتىأڬەأزًضحأتىأڬۏأڬوۏأوذضًضأڬشحەأۄۏڽأ؏أتىأڬەأرتىزتىأڬتأحسڬشۄأډهەأحًأهًڲأتىأڬەأڲہشتىەأ؏أتىأڬەأرتىزتىأ؏أتىأڬەأىضثأتًشأمشتثحأڬۏأزًشأزشتصأڬەأحؼهمتحأدًڔأڬشأتىأضەأىضثحأمتةوأڬشحەأۄۏڽأۗأتۏضتأڬۏًڽأىۄأۄًأآأۏۄأڬۏضەأىۄأۄًأآأتىأڬۏأضۏتضحأڬۏأحزثۏشۏڽأڬشىەأًتهتأتىأڬەأځډہهەأحوتوأهًڲًڽأضەأصۏتزۄأثتؼصحأۄەأتًشأځًشەأمشۏطأرتىزتىأضەأصۏتزۄأضودہزتشأۄەأۗ أٰٰأۏۄأذزۏخأتوتوأثرتشۏأشذوۆأتههۄأؼهۏۄأتًشأتوتوأوضهوأشذوۆأتههۄأؼهۏۄأڬەأوؼۏتشأڬەأوغتثمأظذۏذأۄەأهۏڬىأتىۄًڽأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗ%أ
5423,%أذعشحأتثًوًضۏٳأتطؼشۏأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أؼهتؤأثىأذعشوۏأىەأثذشۏىأضەأتضۏأۄصتشأوتهأثہۏدتأۗأشضًهأتههۄأ﷽أڬەأځتضأىۄأتضأضەأځۄهەأتًشأىۄأتضأڬەأثؼزأتحىتأوتهأڬثہۏأڬضۏأىەأىۄۏڽأثہۏدتأ؏أشضًهأتههۄأ﷽أىەأذڬوأزۏتأتًشأًۄأوتهأډټتةۏأځشأثڬہۏشأزۏتأڲۏتأ؏أځہشأدثأتستىأۄًةۏأحًأشضًهأتههۄأ﷽أحطشۏلأهتةەأتًشأوتهأڬۏأدتىثأدہڬأڬشأڬہڔەأۄًأڲةەأ؏أهًڲأإىتأطشًؼأۄًةەأتًشأإځأ﷽أىەأتىأڬًأوتهأزۏىتأطشًؼأڬۏتأۗأتضأزىأوتهأىۄأحًأڲىأڬشأزۏتأڲۏتأتًشأىۄأۄۏأحًهتأڲۏتأثهڬۄأإځأهځأثہشأثہشأڬشأزۏحەأشۄەأۗأذعشحأؼثتضأشعۏأتههۄأؼىۄأثہۏأحطشۏلأهەأإةەأ؏أتىۄًڽأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ﷽أوۏڽأىەأدىڲأثزشأڬەأوًمؼأځشأتځىتأثہۏألزۏۄأزۏتأحہتأتًشأؼمۏهأتثىأتثۏأغتهثأڬتأثہۏأزۏتأحہتأهۏڬىأؼمۏهأڬەأځتضأتضأًمحأحڬأتحىتأوتهأىۄۏڽأۄەأڬۄأًۄأوۏشتأمشعۄأتزتأڬشأضڬەأۗأتضأهةەأإځأودہەأتضأوتهأوۏڽأضەأذظۄأؼغتألشوتأزۏدةەأ؏أشضًهأتههۄأ﷽أىەألشوتۏتأ=أهەأهۏدةەأ؏أتىۄًڽأىەأتځىەأدثۄأوۏڽأثۄحأضتشتأوتهأثہشأهۏتأ؏أتًشأډهىەأهڲەأحًأًۄأدثۄأتټہتأىۄأضڬەأ؏أتىۄًڽأىەأشضًهأتههيأ﷽أضەأؼشعأڬۏتأ=أۏتأشضًهأتههۄأ﷽أۏۄأڲټہڔۏأتټہًًتأزۏدةەأ؏أۏۄأوىػشأزۏڬہأڬشأشضًهأتههيأ﷽أوضڬشتأزۏةەأتًشألشوتۏتأ=أوۏڽأحًأۏۄأدتىحتأۄًڽأڬۄأوۏڽأىەأدضأدضأضەأدًأًؼزۄأڬۏتأحہتأإدأتههۄأحؼتهۏٳأىەأًۄأځًشتأڬشأزۏتأۗأًۄأًؼزۄأۏۄأحہت
أ®مْهٕأهٓوّىٕألٍٓأئٍّٕزٍٓنْوٕأوٓىّأتهٕئْضّتشٌّ؏أبٓىٕأٍّؼٕهّوٓأتههّٔيْألٍٓأمْهًْثٓنْوٕأرٍّٕشَتأٍْإحٓنْوٕأرٍّٕشَتأوٓؤّتأئْرٓسّأوٓىٕنْوٕأًٍّّؽٕلٓشٕأهّنْوٕأ+أتهتىلتهأ=أ:3أ,¾ أ†أتەأؽۏثأڬۏأرثشۏڽأثحتىەأًتهەأدًأمۏزۏأحوۄتشەأۄتحہأۄۏڽأتىأضەألشوتاأتڲشأتههۄأىەأحوۄتشەأزهأوۏڽأثہهتةۏأدتىۏأحًأدًأحوأضەأهۏتأڲۏتأتضأضەأثۄحشأحوۄۏڽأؼغتألشوتةەأڲتأتًشأحوۄۏڽأثرطأزەأڲتأتًشأتههۄأثرطىەأًتهتأوۄشثتىأۄەأ‟أ+أحشدۄأڬىصتهتۏوتىأ؏أتوتوأتذوزأشعتأ
أ+أذعشحأؼثتضأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ,"أۏۄأوتهأحًأًتمؼۏأتضأضەأثۄحشأۄەأدًأتضأىەأودہأضەأهۏتأحہتأهۏڬىأتثأۏۄأځحتأىۄۏڽأۄەأڬۄأوؽلشحأڬەأذًتهەأضەأۄوتشەأضتحہأڬۏتأثىەأڲتأآ أتۏڬأزًضشۏأضىزأڬەأۄوشتۄأثہۏأذعشحأتثًوًضۏٳأڬتأثۏتىأۄەأڬۄأؼهتؤأثىأذعشوۏأشعۏأتههۄأؼىۄأىەأثذشۏىأضەأشضًهأتههۄأ﷽أڬۏأثتشڲتۄأوۏڽأوتهأثہۏدتأ؏أتضأڬەأثؼزأوسڬًشۄأذزۏخأڬۏأغشذأذزۏخأثۏتىأڬۏأۗ أٰٰأۏۄأذزۏخأتوتوأوضهوأشذوۆأتههۄأؼهۏۄأڬەأوؼۏتشأڬەأوغتثمأۄەأهۏڬىأطۏرۏىأشذوۆأتههۄأؼهۏۄوتأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗ%أ"""
5424,أتثًدؼلشأوذوزأثىأؼهۏأثىأذضۏىأتځىەأًتهزأڬتأۏۄأثۏتىأىمهأڬشحەأۄۏڽأڬۄأؼثتضأثىأؼثزتهوغهثأشعۏأتههۄأؼىۄأشضًهأتههۄأ﷽أڬەأځتضأإةەأ؏أتضأًمحأتىأڬەأتًځشأتۏڬأدثۄأحہتأ؏أتىأڬەأضلۏزأثتهًڽأڬۏأزًأوۏىڋہۏتڽأحہۏڽأۗأشضًهأتههۄأ﷽أىەأتىأڬًأزۏڬہتأحًأوضڬشتأزۏةەأۗأذعشحأؼثتضأشعۏأتههۄأؼىۄأىەأځًډہتأ=أتههۄأحؼتهۏٳأإځأڬًأۄوۏطۄأرًطأشڬہەأ؏أإځأڬضأًدۄأضەأوضڬشتةەأۄۏڽأآأشضًهأتههۄأ﷽أىەألشوتۏتأ=أىثۏأؼهۏۄأتهضهتوأڬەأډډتأڬەأذضىأًأدوتهأځشأوضڬشتۏتأۄًڽأۗأذعشحأؼثتضأشعۏأتههۄأؼىۄأىەأځًډہتأ=أۏتأشضًهأتههۄأ﷽أوشزًڽأڬتأذضىأًأدوتهأڬضأډۏصأوۏڽأۄًحتأۄەأآأحًأإځأ﷽أىەألشوتۏتأ=أصثتىأوۏڽأۗأ
5425,"%أذعشحأدتثشأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أذعشحأؼثتضأشعۏأتههۄأؼىۄأوزۏىۄأوۏڽأحہەأ؏أتىظتشأىەأتۏضتأموۏظأثۄحأڋہًىڋتأدًأتىأڬەأدضوأځشأځًشتأإةەأهۏڬىأضًتةەأؼثزتههۄأثىأتثۏأ+أوىتلمأ,أڬەأموۏظأڬەأتًشأڬًةۏأىۄأوهتأ؏أهًڲًڽأىەأًۄۏأموۏظأذعشحأؼثتضأشعۏأتههۄأؼىۄأڬًأځۄىتأزۏتأۗأذعشحأدتثشأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أذعشحأؼثتضأشعۏأتههۄأؼىۄأدىڲأثزشأوۏڽأشضًهأتههۄأ﷽أڬەأمۏزۏأثىەأحہەأ؏أتىأڬًأصثشزضحۏأدىڲأوۏڽأهتۏتأڲۏتأحہتأ؏أځہشأڲشلحتشأڬشأڬەأتىأڬًأوزۏىۄأطشۏلأوۏڽأهتۏتأڲۏتأتًشأؼثزتههۄأثىأتثۏأ+أوىتلمأ,أىەأتىأڬًأتځىتأموۏظأځۄىتۏتأحہتأۗأتضأڬەأتضۏأؼوهأڬتأثزهۄأزۏىەأڬەأهةەأشضًهأتههۄأ﷽أىەأؼثزتههۄأثىأتثۏأ+أوىتلمأ,أڬەأڬلىأڬەأهةەأتځىتأموۏظأزۏتأحہتأۗ أٰٰأۏۄأذزۏخأتوتوأثرتشۏأشذوۆأتههۄأؼهۏۄأتًشأتوتوأوضهوأشذوۆأتههۄأؼهۏۄأڬەأوؼۏتشأڬەأوغتثمأظذۏذأۄەأهۏڬىأتىۄًڽأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗ%أ"
5426,%أذعشحأدتثشأثىأؼثزتههۄأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ؏أدثأذعشحأؼثتضأشعۏأتههۄأؼىۄأڬًأمۏزأڬشأڬەأهتۏتأڲۏتأحًأؼثزتههۄأثىأتثۏأڬەأموۏظأڬەأضًتأتًشأڬًةۏأموۏظأتىأڬًأځًشتأىۄۏڽأإۏتأۗ أٰٰأۏۄأذزۏخأتوتوأثرتشۏأشذوۆأتههۄأؼهۏۄأتًشأتوتوأوضهوأشذوۆأتههۄأؼهۏۄأڬەأوؼۏتشأڬەأوغتثمأظذۏذأۄەأهۏڬىأتىۄًڽأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗ%أ
5427,%أۏؼمًثأثىأدؼلشأثىأضهۏوتىأشعۏأتههۄأؼىۄأتځىەأًتهزأڬتأۏۄأثۏتىأىمهأڬشحەأۄۏڽأ=أوۏڽأتځىەأًتهزأدؼلشأوىظًشأڬەأځتضأڲۏتأتىۄًڽأىەأتىأڬۏأڲہىۏأصهلۏڽأزۏڬہۏڽأ؏أوۏڽأتىأڬۏأصهلًڽأڬەأذضىأڬۏأدتىثأزۏڬہىەأهڲأڲۏتأۗأحًأدؼلشأوىظًشأىەأڬۄتأ=أوۏشەأًتهزأوذوزأثىأؼهۏأڬۏأثہۏأصهلۏڽأحہۏڽأ؏أتًشأتىۄًڽأىەأودہەأثحتۏتأۄەأڬۄأتىأڬەأًتهزأؼهۏأثىأؼثزتههۄأڬۏأثہۏأصهلۏڽأحہۏڽأ؏أًۄأڬۄحەأۄۏڽأودہەأتىۄًڽأىەأثحتۏتأڬۄأوۏشەأًتهزأؼثتضأثىأؼثزتهوغهثأڬۏأثہۏأصهلۏڽأحہۏڽأ؏أتًشأؼثتضأشعۏأتههۄأؼىۄأىەأثحتۏتأڬۄأىثۏأتڬشوأ﷽أڬۏأثہۏأصهلۏڽأحہۏڽأ؏أتًشأثتطوأثىأؼثزأوىتلأڬۏأثہۏأصهلۏڽأحہۏڽأۗأوۏڽأىەأتځىەأًتهزأضەأڬۄتأ=أۏۄأثۄحأرًثظًشحأۄۏڽأۗأتىۄًڽأىەأڬۄتأ=أۏۄأرهتلحأڬتأىًشأۄەأۗأشتًۏأڬۄحەأۄۏڽأ=أوۏشەأًتهزأتځىەأًتهزأضەأًۄأتىأڬەأزتزتأضەأشًتۏحأڬشحەأۄۏڽأڬۄأدثأتههيأحؼتهۏٳأڬضۏأڬۏأحرهۏمأرهتلحأڬەأهةەألشوتحتأۄەأحًأتضأڬۏأځۏطتىۏأځشأۄتحہأځہۏشأزۏحتأۄەأ؏أتضأًدۄأضەأتضأځشأظشلأوذثحأڬشىەأًتهەأڬۏأۄۏأىػشأځڔحۏأۄەأ+أتًشأىڲتۄأثزأضەأًۄأثډتأشۄحتأۄەأ أٰٰأتضأذزۏخأڬەأحوتوأشتًۏأۄتطوۏأۄۏڽأتًشأىۏڬأرتىزتىأوۏڽأوطۄًشأۄۏڽأۗ%أ
5428,"%أؼثزتهشذوىأثىأصۏزأثىأتضهوأتځىەأًتهزأضەأًۄأتىأڬەأزتزتأضەأشًتۏحأڬشحەأۄۏڽأڬۄأذعشحأؼوشأثىأرغتثأشعۏأتههۄأؼىۄأىەأذعشحأؼثتضأثىأؼثزتهوغهثأشعۏأتههۄأؼىۄأضەأڬۄتأڬۄأشضًهأتههۄأ﷽أىەأتشطتزألشوتۏتأ=أۄوأوضدزأڬۏأحًضۏؼأڬشىتأډتۄحەأۄۏڽأتًشأحۏشتأڲہشأوضدزأڬەأمشۏثأۄەأۗأتضأهةەأإځأتځىتأڲہشأۄوۏڽأزەأزۏدةەأۄوأوضدزأڬۏأحًضۏؼأوۏڽأتضأڬًأطتوهأڬشأهۏڽأڲەأتًشأتضأڬەأثزهەأوۏڽأإځأڬًأتضأضەأثہۏأصۏتزۄأًضۏؼأڲہشأزۏحەأۄۏڽأۗأذعشحأؼثتضأشعۏأتههۄأؼىۄأىەأتىڬتشأڬشأزۏتأۗأذعشحأؼوشأشعۏأتههۄأؼىۄأىەأڬۄتأ=أ+أتڲشأحوأىەأشعتأوىزۏأڬەأضتحہأۏۄأوڬتىأۄوۏڽأىۄأزۏتأحًأ,أۄوأصثشزضحۏأحوأضەأۏۄأوڬتىأرتهۏأڬشًتأهۏڽأڲەأۗأذعشحأؼثتضأشعۏأتههۄأؼىۄأىەأڬۄتأ=أإځأڬًأۏۄأذمأىۄۏڽأځۄىډحتأۗأۏۄأهًڲأذعشحأذسۏلۄأشعۏأتههۄأؼىۄأڬەأځتضأإةەأتًشأتىأڬًأځًشتأوؼتوهۄأضىتۏتأۗأتىۄًڽأىەأڬۄتأ=أتضأضهضهەأوۏڽأوۏشەأځتضأتۏڬأذزۏخأوًدًزأۄەأۗأتىۄًڽأىەأځًډہتأ=أًۄأڬۏتأآأتىۄًڽأىەأڬۄتأ=أذعشحأزتازأؼهۏۄأتهضهتوأىەأثۏحأتهومزضأڬۏأحًضۏؼأڬشىتأډتۄۏأ؏أتًشأوضدزأڬەأمشۏثأدًأوڬتىأحہتأًۄأتۏڬأۏحۏوأڬتأحہتأ؏أذعشحأزتازأؼهۏۄأتهضهتوأىەأتضأضەأوڬتىأوتىڲتأهۏڬىأتضأىەأزۏىەأضەأتىڬتشأڬشأزۏتأ؏أذعشحأزتازأؼهۏۄأتهضهتوأتضأضەأًۄأوڬتىأصثشزضحۏأډہۏىىتأډتۄحەأحہەأڬۄأتههيأحؼتهۏٳأىەأًذۏأىتصهألشوتةۏأڬۄأوۏشەأڲہشأڬًأزًضشًڽأڬەأڲہشًڽأځشأػهوأضەأثډتۏتأدتةەأحًأذعشحأزتازأؼهۏۄأتهضهتوأىەأًۄأتشتزۄأحشڬألشوتأزۏتأۗ"
أذعشحأؼثتضأشعۏأتههۄأؼىۄأىەأذعشحأؼوشأشعۏأتههۄأؼىۄأضەأڬۄتأ=أڬۏتأتثأثہۏأڬًةۏأثتحأثتمۏأشۄأڲةۏأۄەأآأتىۄًڽأىەأڬۄتأ=أىۄۏڽأۗأشتًۏأڬۄحەأۄۏڽأ=أځہشأذعشحأؼوشأثىأرغتثأشعۏأتههۄأؼىۄأوضدزأوۏڽأإةەأ؏أذعشحأؼثتضأشعۏأتههۄأؼىۄأڬەأځشىتهەأڬتأشرأوضدزأىثًۏأڬۏأدتىثأحہتأتًشأثتشطأڬتأځتىۏأتضأڬەأسشۏؼەأوضدزأوۏڽأڲشحتأحہتأذعشحأؼوشأشعۏأتههۄأؼىۄأىەأًۄأځشىتهۄأتڬہۏڔأڋتهتأتًشأڬۄتأ=أۏۄأځشىتهۄأشضًهأتههۄأ﷽أڬۏأوضدزأوۏڽأىۄۏڽأڲشأضڬحتأۗأذعشحأؼثتضأشعۏأتههۄأؼىۄأىەأتىأضەأڬۄتأ=أتضأستحأڬۏأمضوأ$أدضأىەأوذوزأ﷽أڬًأذمأڬەأضتحہأثہۏدتأۄەأشضًهأتههۄأ﷽أىەأثستحأرًزأۏۄأځشىتهۄأتضۏأومتوأځشأشڬہتأحہتأتًشأتەأؼوشأحوأىەأ+أشضًهأتههۄأ﷽أڬتأثىتۏتأۄًتأځشىتهۄأ,"أتڬہۏڔأزۏتأۗأذعشحأؼوشأ﷽أىەأڬۄتأ=أإځأتځىەأځتاڽأوۏشۏأڲشزىأځشأشڬہأڬشأډڔہأدتةۏەأتًشأۏۄأځشىتهۄأدۄتڽأځشأحہتأًۄۏڽأهڲتأهۏدةەأۗأذعشحأؼثتضأشعۏأتههۄأؼىۄأىەأتۏضتأۄۏأڬۏتأۗأځہشألشوتۏتأ=أوۏڽأىەأۏۄأوڬتىأحوۄۏڽأزۏتأحوأوضدزأىثًۏأطشۏلأڬۏأحًضۏؼأڬشأهًأ؏أحثأذعشحأؼوشأشعۏأتههۄأؼىۄأىەأتىأڬتأوڬتىأوضدزأوۏڽأطتوهأڬشأهۏتأتًشأتىأڬًأتضأڬەأثزهەأومتوأصًشتؤأځشأتۏڬأًضۏؼأًأؼشۏعأوڬتىأزۏتأۗ أٰٰأۏۄأذزۏخأۄوأىەأتثًدؼلشأتًشأتثًؼهۏأذتلػأڬەأذًتهەأضەأىمهأڬۏأۄەأتًشأتىۄًڽأىەأتضأڬًأظشلأتضۏأتضىتزأڬەأۄوشتۄأهڬہتأۄەأتًشأتوتوأثرتشۏأشذوۆأتههۄأؼهۏۄأتًشأتوتوأوضهوأشذوۆأتههۄأؼهۏۄأىەأؼثزتهشذوىأثىأصۏزأثىأتضهوأڬۏأشًتۏتحأىمهأىۄۏڽأڬۏڽأۗ%أ"""
5429,أذعشحأضؼۏزأثىأوضۏثأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أدثأذعشحأؼوشأثىأرغتثأشعۏأتههۄأؼىۄأىەأوضدزأىثًۏأطشۏلأڬۏأحًضۏؼأڬتأځشًڲشتوأثىتۏتأحًأذعشحأؼثتضأثىأؼثزتهوغهثأشعۏأتههۄأؼىۄأڬەأوڬتىأڬەأوؼتوهەأوۏڽأدہڲڔتأۄًأڲۏتأ؏أتضأڬەأثؼزأضتثمۄأذزۏخأڬۏأغشذأذزٍخأىمهأڬۏأۗأ
5430,%أذعشحأتثًشصۏىأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أوۏڽأىەأذعشحأؼثتضأشعۏأتههۄأؼىۄأضەأڬۄتأ=أإځأشضًهأتههۄأ﷽أڬۏأثتشڲتۄأوۏڽأزشرًتضحأځۏطأڬشۏڽأڬۄأًۄأإځأڬًأظزمتحأڬۏأًظًهۏأڬتأىڲشتىأثىتأزۏڽأۗأتىۄًڽأىەأشضًهأتههيأ﷽أڬۏأثتشڲتۄأوۏڽأؼشعأڬشأزۏأۗأشضًهأتههۄأ﷽أىەألشوتۏتأ=أوۏڽأحدہەأهًڲًڽأڬەأڲىتۄًڽأڬەأزہًًىأڬتأىڲشتىأىۄۏڽأثىتأضڬحتأۗ أتًشأتۏڬأزًضشۏأتضىتزأڬەأۄوشتۄأذعشحأؼهۏأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأإځألشوتحەأۄۏڽأڬۄأوۏڽأىەأذعشحأؼثتضأشعۏأتههۄأؼىۄأضەأڬۄتأ=أإځأىثۏأتڬشوأ﷽أضەأۄوتشەأهةەأزشثتىۏأڬۏأضلتشطأڬشأزۏڽأ؏أشضًهأتههۄأ﷽أىەألشوتۏتأ=أوۏڽأحوۄۏڽأًۄأډۏصأزًڽأڲتأدًأتضأضەأثۄحشأۄەأۗأحوأځتىۏأځهتۏتأڬشًأ؏أًۄأحوۄۏڽأوتهأزەأڲتأحوأتضأڬًأوتهأىۄۏڽأزًأڲەأۗ أٰٰأوسڬًشۄأزًىًڽأذزۏخۏڽأظذۏذأتهتضىتزأۄەأهۏڬىأطۏرۏىأشذوۆأتههۄأؼهۏۄوتأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗ%أ
5431,%أذعشحأؼهۏأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أذعشحأؼثتضأثىأؼثزتهوغهثأشعۏأتههۄأؼىۄأىەأشضًهأتههۄأ﷽أضەأظزمۄأڬتأوتهأڬہًهىەأضەأځۄهەأ؏أهۏىەأڬۏأزشرًتضحأڬۏأ؏أحًأشضًهأتههيأ﷽أىەأتىأڬًأتدتصحأزەأزۏأۗ أٰٰأۏۄأذزۏخأظذۏذأتهتضىتزأۄەأهۏڬىأطۏرۏىأشذوۆأتههۄأؼهۏۄوتأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗ%أ
5432,%أذعشحأوغهثأثىأشثۏؼۄألشوتحەأۄۏڽأ=أذعشحأؼثتضأشعۏأتههۄأؼىۄأځشۏطتىأذتهحأوۏڽأشضًهأتههۄأ﷽أڬۏأثتشڲتۄأوۏڽأإةەأ؏أشضًهأتههيأ﷽أىەأځشۏطتىۏأڬۏأًدۄأځًډہۏأ؏أتىۄًڽأىەأڬۄتأ=أۏتأشضًهأتههۄأ﷽أۄوۏڽأتًشأمشۏطأڬًأڬۏتأوضةهۄأۄەأآأشضًهأتههيأ﷽أىەأځًډہتأ=أحوۄۏڽأتًشأتىۄۏڽأڬۏتأوضةهۄأۄەأآأتىۄًڽأىەأڬۄتأ=أۏۄأتۏڬأزًضشەأڬەأضتحہأحًأثۄحأرىزۄأځۏطتىۏأضەأوهحەأۄۏڽأهۏڬىأدثأۏۄأهًڲأۄوأضەأوهحەأۄۏڽأحًأتىأڬەأتىزتصأزشضحأىۄۏڽأۄًحەأۗأشتًۏأڬۄحەأۄۏڽأ=أۏۄأثتحأضىأڬشأشضًهأتههيأ﷽أڬًأؽظۄأإۏتأذحۏأڬۄأؽظۄأڬۏأًدۄأضەأإځأڬۏأځۏطتىۏأځشأځضۏىۄأإأڲۏتأ؏أدثأإځأڬۏأًۄأڬۏلۏحأرحوأۄًةۏأحًأإځأ﷽أىەألشوتۏتأ=أتضأستحأڬۏأمضوأ$أدضأڬەأمثعۄأمزشحأوۏڽأوذوزأڬۏأدتىأۄەأڬضۏأطرظأڬەأزهأوۏڽأتضأًمحأحڬأتۏوتىأزترهأىۄۏڽأۄًحتأدثأحڬأڬۄأًۄأتههۄأتًشأتضأڬەأشضًهأڬۏأرتغشأحوأضەأوذثحأىۄأشڬہەأ؏أځہشألشوتۏتأ=أتىأهًڲًڽأڬتأڬۏتأذتهأۄًأڲتأدًأؼثتضأڬەأثتشەأوۏڽأودہەأحڬهۏلأزۏحەأۄۏڽأۗأڬضۏأإزوۏأڬتأډډتأتضأڬەأثتځأڬۏأغشذأۄًحتأۄەأۗ أٰٰأتضأذزۏخأڬًأتضوتؼۏهأثىأتثۏأرتهزأىەأۏصۏزأثىأتثۏأصۏتزأتًشأۏصۏزأضەأشًتۏحأڬۏتأۄەأهۏڬىأطۏرۏىأشذوۆأتههۄأؼهۏۄوتأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗأۏۄأثہۏأڬًلۏۏىأڬۏأذزۏخأڬەأتشڬتىأوۏڽأضەأتۏڬأشڬىأۄەأۗ%أ
5433,%أذعشحأؼثتضأثىأؼثزتهوغهثأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أوۏڽأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ﷽أمشۏطأهًڲأدثأتۏڬأزًضشەأضەأوهحەأۄۏڽأحًأثۄحأڲشوأدًطۏأڬەأضتحہأوهحەأۄۏڽأهۏڬىأدثأًۄأۄوأضەأوهحەأۄۏڽأحًأثۄحأثەأشرۏأضەأوهحەأۄۏڽأۗأتضأثتحأضەأشضًهأتههۄأ﷽أثۄحأؽعثىتڬأۄًةەأتًشألشوتۏتأ=أتضأستحأڬۏأمضوأدضأڬەأمثعۄأوۏڽأوذوزأڬۏأدتىأۄەأڬضۏأتىضتىأڬەأزهأوۏڽأتضأًمحأحڬأتۏوتىأزترهأىۄۏڽأۄًأضڬحتأدثأحڬأًۄأتههيأتًشأتضأڬەأشضًهأڬۏأشعتأڬۏأرتغشأحوأضەأوذثحأىۄأڬشەأڲتأۗ أٰٰأوۏڽأىەأتضأذزۏخأڬتأڬډہأذظۄأذعشحأذضىأتًشأذعشحأذضۏىأشعۏأتههۄأؼىۄوتأڬەألعتةهأوۏڽأتًشأشضًهأتههۄأ﷽أڬەأتۄهأثۏحأڬەألعتةهأڬەأتثًتثأوۏڽأثۏتىأڬشأزۏتأۄەأتًشأوغهثأثىأشثۏؼۄأڬتأسڬشأڬشحەأۄًةەأتضأڬۏأؼهحأثہۏأثۏتىأڬشأزۏأحہۏأ؏أتًشأدضأىەأتضأتضىتزأوۏڽأتىأڬًأضتمغأڬشأزۏتأتضأڬًأتضأوًمؼأځشأتضأذزۏخأڬەأتؼتزۄأڬۏأذتدحأىۄۏڽأۄەأۗ%أ
5434,أذعشحأضؼۏزأثىأوضۏثأشعۏأتههۄأؼىۄأذعشحأؼثتضأثىأؼثزتهوغهثأشعۏأتههۄأؼىۄأڬەأثتشەأوۏڽألشوتحەأۄۏڽأ=أًۄأتضأتوحأڬەأضثأضەأثۄحشۏىأطرظأۄۏڽأ؏أشضًهأتههۄأ﷽أڬەأًتشخأۄۏڽأتًشأتىأڬەأډډتأۄۏڽأۗأ
5435,أتثًظتهذأسڬًتىألشوتحەأۄۏڽأ=أذعشحأؼثتضأثىأؼثزتهوغهثأشعۏأتههۄأؼىۄأىەأودہەأذعشحأؼخوتىأشعۏأتههۄأؼىۄأڬۏأغشلأثہۏدتأۗأوۏڽأتىأڬەأځتضأإۏتأًۄأهًڲًڽأڬًأىتطحۄأڬشًتأشۄەأحہەأ؏أوۏڽأىەأتىأڬًأزؼًحأزۏأ؏أذعشحأؼخوتىأشعۏأتههۄأؼىۄأ؏أذعشحأؼثتضأشعۏأتههۄأؼىۄأڬەأځتضأډهەأإةەأ؏أتًشأڬۄتأ=أتەأتثًتهلعهأ$أډۄشەأڬتوۏتثأۄًأڲةەأ؏أتىۄًڽأىەأڬۄتأ=أتًشأتەأتوۏشتهوًوىۏىأإځأڬتأډۄشۄأآأتىۄًڽأىەأڬۄتأ=أوۏڽأضەأتضأضەأصۏتزۄأڬًحتۄۏأىۄۏڽأڬۏأڬۄأدثأإځأڬتأمتظزأوۏشەأځتضأإۏتأحًأوۏڽأهًڲًڽأڬًأىتطحۄأڬشًتأشۄتأحہتأ؏أًۄتڽأضەألتشؽأۄًحەأۄۏأوۏڽأإځأڬەأځتضأإأڲۏتأۗأ
5436,أذعشحأؼوشًأثىأختثحأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أتۏڬأطرظأذعشحأذضۏىأثىأؼهۏأشعۏأتههۄأؼىۄأڬەأځتضأإۏتأ؏أتضأًمحأذعشحأذضۏىأڬہتىتأڬہتأشۄەأحہەأ؏أإځأىەأتضأڬًأثہۏأڬہتىەأوۏڽأطتوهأۄًىەأڬۏأزؼًحأزۏأ؏أتضأىەأڬۄتأ=أوۏڽأڬہتأډڬتأۄًڽأ؏أإځأځًډہتأڬضأڬەأځتضأآأتضأىەأڬۄتأ=أذعشحأؼثزتههيأثىأؼثتضأشعۏأتههۄأؼىۄوتأڬەأځتضأۗأإځأىەألشوتۏتأ=أڬۏًڽأىۄۏڽأتىأڬەأًتهزأمشۏطأڬەأضشزتشأۄۏڽأۗأ
5437,أذعشحأؼثزتههۄأثىأخؼهثۄأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەأتشطتزألشوتۏتأ=أتههۄأحؼتهۏٳأىەأودہەأمشتثحأزتشًڽأڬەأضتحہأذضىأضهًڬأڬۏأحتڬۏزألشوتةۏأۄەأتًشأذڬوأزۏتأۄەأڬۄأإؽتصأ†أؼثتضأ‟أڬشًڽأۗأ
5438,%أذعشحأؼثزتههۄأثىأؼوشأشعۏأتههۄأؼىۄوتألشوتحەأۄۏڽأ=أذعشحأؼوشأثىأرغتثأشعۏأتههۄأؼىۄأىەأمذغأڬەأضتهأذعشحأؼثتضأثىأؼثزتهوغهثأشعۏأتههۄأؼىۄأڬتأًتضغۄأتًشأًضۏهۄأزەأڬشأثتشطأڬۏأزؼتأۏًڽأوتىڲۏ
أ†أتەأتههۄأ$أۏۄأحۏشەأىثۏأڬەأډډتأذعشحأؼثتضأشعۏأتههۄأؼىۄأۄۏڽأ؏أۄوأحۏشۏأثتشڲتۄأوۏڽأتىأڬتأًتضغۄأتًشأًضۏهۄأځۏطأڬشحەأۄۏڽأحًأتىأڬەأظزمەأۄوأځشأشذوحأڬۏأثشضتحأىتصهألشوتأ‟ۗأ+أتضأزؼتأڬەأثؼزأ,"أتثہۏأصۏتزۄأًمحأىۄۏڽأڲصشتأحہتأڬۄأثشضتحأىتصهأۄًأڲةۏأۗأذعشحأؼوشأثىأرغتثأشعۏأتههۄأؼىۄأىەأهًڲًڽأڬًأرغثۄأزۏتأتًشألشوتۏتأ=أتەأهًڲًأ$أشضًهأتههيأ﷽أذعشحأؼثتضأشعۏأتههۄأؼىۄأڬًأًتهزأڬتأتذحشتوأزۏحەأحہەأتًشأتۏڬأًتهزأۄۏأڬۏأغشذأؼصحأڬشحەأحہەأ؏أتىأڬۏأمضوأڬًأځًشتأڬشحەأحہەأ؏أحًأتەأهًڲًأ$أتىأڬەأډډتأڬەأذًتهەأضەأشضًهأتههۄأ﷽أڬۏأځۏشًۏأڬشًأتًشأتىأڬًأتههيأحؼتهۏٳأڬۏأثتشڲتۄأوۏڽأتضأڬۏأىتصهأڬشزۄأډۏصأڬەأضهضهەأوۏڽأًضۏهۄأثىتأڬشأشڬہًأۗ%أ"""
5439,%أوظؼثأثىأؼثزتههيأىەأتىأڬتأىضثأۏًڽأثۏتىأڬۏتأۄە أ†أؼثزتههيأثىأتشموأثىأؼثزأٍؽًخأثىأتۄۏثأثىأؼثزأوىتلأثىأصۄشيأ‟ أتىأڬۏأًتهزۄأڬتأىتوأ†أؼوشۄأثىحأتشموأثىأۄتطوأثىأؼثزأوىتلأ‟أۄەأۗ أذعشحأؼثزتههيأثىأتشموأًلتحأضەأځۄهەأىتثۏىتأۄًأڲةەأحہەأۗأتىأڬتأتىحمتهأضىأ68أۄدشۏأڬًأۄًتأۗ%أ
5440,أرهۏلۄأثىأرۏتغأىەأذعشحأؼثزتههۄأثىأتشموأشعۏأتههۄأؼىۄأڬتأىضثأثۏتىأڬشىەأڬەأثؼزألشوتۏتأ=أإځأىثۏأتڬشوأ﷽أڬەأ؏أذعشحأتثًثڬشأشعۏأتههۄأؼىۄأڬەأتًشأذعشحأؼوشأشعۏأتههۄأؼىۄأڬەأڬتحثأحہەأۗأ
5441,%أذعشحأؼثزتههيأثىأؼوشأشعۏأتههۄأؼىۄوتألشوتحەأۄۏڽأ=أىثۏأتڬشوأ﷽أڬۏأثتشڲتۄأوۏڽأڬضۏأإزوۏأڬتأرغأإۏتأحًأىثۏأتڬشوأ﷽أىەأذعشحأؼثزتههۄأثىأتشموأشعۏأتههۄأؼىۄأضەأڬۄتأ=أتضأڬًأوۏشۏأدتىثأضەأدًتثأهڬہأزًأ؏أتىۄًڽأىەأدًتثأهڬہتأتًشأځہشأځڔہأڬشأضىتۏتأ؏أشضًهأتههيأ﷽أىەأضىأڬشألشوتۏتأ=أثتهڬهأټہۏڬأۄەأ؏أثۄحأرًثأ؏أٍتأتههيأتىأڬۏأشتةەأڬًأوًتلمحأؼغتألشوتأۗأځہشأدثأذعشحأؼوشأشعۏأتههۄأؼىۄأىەأرهتلحأضىثہتهۏأحًأإځأتىأضەأوطًشۄأڬۏتأڬشحەأحہەأۗ أٰٰأۏۄأذزۏخأظذۏذأتهتضىتزأۄەأهۏڬىأطۏرۏىأشذوۆأتههۄأؼهۏۄوتأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗ%أ
5442,أصثۏشأثىأثڬتشأڬۄحەأۄۏڽأ=أذعشحأؼثزتههۄأثىأتشموأثىأؼثزأۏؽًخأشعۏأتههۄأؼىۄأ؏أذعشحأؼوشأشعۏأتههۄأؼىۄأڬەأزًشأرهتلحأوۏڽأتًشأذعشحأؼخوتىأؽىۏأشعۏأتههۄأؼىۄأڬەأتثحزتةۏأزًشأوۏڽأتځىۏأصىزڲۏأڬەأإرشۏأتۏتوأحڬأثۏحأتهوتهأڬەأىڲشتىأشۄەأۗأتًشأتىأڬًأثتشڲتۄأوظغلۏأ﷽أڬۏأوذثحأثہۏأذتظهأۄەأۗأ
5443,%أذعشحأؼثزتههۄأثىأتشموأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەأتشطتزألشوتۏتأ=أدثأىوتصأڬہڔۏأۄًأدتةەأتًشأڬًةۏأطرظأمعتةەأذتدحأڬەأهةەأثۏټہتأۄًأحًأتضأڬًأډتۄةەأڬۄأځۄهەأمعتةەأذتدحأڬشأهەأ؏أ+أىوتصأثؼزأوۏڽأځڔہأهەأ أٰٰأۏۄأذزۏخأظذۏذأتهتضىتزأۄەأهۏڬىأطۏرۏىأشذوۆأتههۄأؼهۏۄوتأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗ%أ
5444,"أتثىأتضذتمأىەأثىۏأدطوأثىأذتشخأوۏڽأضەأتًشأثىۏأصۏزأثىأذتشخأوۏڽأضەأثۏؼحأؼمثۄأتًشأدىڲأثزشأوۏڽأطشۏڬأۄًىەأًتهًڽأوۏڽأؼثزتههۄأثىأصۏزأثىأؼثزشثۄأثىأخؼهثۄأڬتأىتوأثہۏأسڬشأڬۏتأۄەأۗأۏۄأًۄۏأظذتثۏأۄۏڽأدىۄًڽأىەأرًتثأوۏڽأتستىأزۏڬہۏأحہۏأ؏أتىۄًڽأىەأإأڬشأشضًهأتههۄأ﷽أڬًأضىتةۏأحًأشضًهأتههۄأ﷽أىەأتضأ+أڬًأدتشۏأڬشىەأ,أڬتأذڬوأزەأزۏتأۗأ"
5445,"أۏذۏۏأثىأثڬۏشأڬۄحەأۄۏڽأ=أؼثزتههيأثىأصۏزأ+أتستىأًتهەأ,أڬۏأڬىۏحأ““أتثًوذوزأ‛‛أۄەأۗأ"
5446,أؼشًۄأثىۏأدطوأثىأصۏزأثىأذتشخأوۏڽأضەأتًشأثىۏأصۏزأثىأذتشخأوۏڽأضەأثزشأوۏڽأتًشأثۏؼحأؼمثۄأوۏڽأطشۏڬأۄًىەأًتهًڽأوۏڽأ†أذعشحأؼثزتههۄأثىأصۏزأثىأؼثزشثۄأثىأخؼهثۄأثىأصۏزأثىأذتشخأثىأرصشدأ‟أڬتأىتوأثہۏأسڬشأڬۏتأۄەأ؏أتىأڬەأثہتةۏأذتشخأثىأصۏزأۄۏڽأۗأؼثزتههۄأثىأصۏزأًۄۏأۄۏڽأدىۄًڽأىەأرًتثأوۏڽأتستىأزۏڬہۏأحہۏأۗأ
5447,%أوذوزأثىأؼوشأىەأتىأڬتأىضثأۏًڽأثۏتىأڬۏتأۄەأ†أؼثزتههۄأثىأصۏزأثىأؼثزشثۄأثىأخؼهثۄأثىأصۏزأثىأذتشخأ‟أتىأڬۏأڬىۏحأ†أتثًوذوزأ‟أۄەأۗ أحوتوأواشرۏىأڬتأتضأثتحأځشأتحلتمأۄەأڬۄأذعشحأؼثزتههيأثىأصۏزأشعۏأتههۄأؼىۄأضحشأظذتثۄأڬشتوأڬەأۄوشتۄأهٍهۆأتهؼمثۄأوۏڽأثہۏأطشۏڬأۄًةەأ؏أدىڲأثزشأ؏أتذزأ؏أرىزمأتًشأحوتوأؽصًتحأوۏڽأشضًهأتههۄأ﷽أڬەأۄوشتۄأطشۏڬأۄًةەأۗألحذأوڬۄأڬەأوًمؼأځشأثىۏأذتشخأثىأرصشدأڬتأؼهوأتىۄۏأڬەأۄتحہأوۏڽأحہتأ؏أۏۄأًۄۏأظذتثۏأۄۏڽأدىأڬًأرًتثأوۏڽأًۄأتستىأضىتةۏأڲةۏأحہۏأدضأتستىأڬًألمۄتةەأتضهتوأىەأتځىەأۄتڽأشتةدأڬۏتأۗ أٰٰأتضأذزۏخأڬًأتوتوأثرتشۏأشذوۆأتههۄأؼهۏۄأتًشأتوتوأوضهوأشذوۆأتههۄأؼهۏۄأىەأىمهأىۄۏڽأڬۏتأڬۏًىڬۄأتضأڬۏأتضتىۏزأوۏڽأىتمهۏىأڬتأترحهتلأۄەأۗ أتىأوۏڽأضثأضەأثۄحشۏىأشًتۏحأذعشحأضؼۏزأثىأوضۏثأشعۏأتههۄأؼىۄأڬۏأۄەأۗأهۏڬىأتىأڬەأثتشەأوۏڽأۄوتشەأإةوۄأىەأۏۄأًۄوأڬۏتأۄەأڬۄأذعشحأضؼۏزأڬۏأذعشحأؼثزتههۄأثىأصۏزأڬەأضتحہأوهتمتحأىۄۏڽأۄًةۏأ؏أذتهتىڬۄأۏۄأثتحأزشضحأىۄۏڽأۄەأڬۏًىڬۄأذعشحأضؼۏزأثىأوضۏثأشعۏأتههۄأؼىۄأحًأًۄأطرظۏحأۄۏڽأدًأذعشحأؼخوتىأشعۏأتههۄأؼىۄأتًشأذعشحأؼهۏأشعۏأتههۄأؼىۄأڬەأزشوۏتىأختهخأثىىەأًتهًڽأوۏڽأطتوهأحہەأۗأتًشأذعشحأؼثزتههۄأثىأصۏزأشعۏأتههۄأؼىۄأڬتأتىحمتهأذعشحأؼخوتىأشعۏأتههۄأؼىۄأڬۏأرهتلحأڬەأإرشۏأتۏتوأوۏڽأۄًتأۗ أتًشأصۄشۏأىەأدًأذعشحأضؼۏزأثىأوضۏثأشعۏأتههۄأؼىۄأضەأذزۏخأشًتۏحأڬۏأۄەأًۄأوطۄًشأۄەأ؏أتضأڬًأۏًىضأثىأۏصۏزأىەأ؏أوؼوشأثىأشتطزأىەأ؏أطؼۏثأثىأتثًذوصۄأىەأتًشأوذوزأثىأتضذتمأتًشأزۏڲشأوذزخۏىأىەأشًتۏحأڬۏتأۄەأۗ أتضأثتثأوۏڽأڬًلۏۏىأڬۏأحوتوأشًتۏتحأڬتأوزتشأؼثزتهشذوىأثىأتثۏأهۏهأڬۏأذزۏخأځشأۄەأۗأڬډہأوذزخۏىأتضأڬًأۏًڽأثۏتىأڬشحەأۄۏڽأ†أؼىأوؼتسأثىأدثهأتًأؼثزتههيأثىأصۏزأ‟ أتًشأڬډہأوذزخۏىأۏًڽأثۏتىأڬشحەأۄۏڽأ““أؼثزتهشذوىأؼىأؼثزتههيأثىأصٍزأ‟ أتًشأؼثزتههۄأثىأصۏزأڬۏأتىأڬەأإثتؤأڬەأذًتهەأثۏتىأڬشزۄأشًتۏتحأڬۏأتضتىۏزأوعثًغأىۄۏڽأۄۏڽأڬۏًىڬۄأؼثزتههۄأثىأصۏزأىەأرًزأثہۏأۏۄأذزۏخأشضًهأ﷽أضەأوضىزأڬۏأۄەأۗ%أ
5448,"أتثًثڬشأثىأوذوزأثىأؼوشًأثىأذصوأضەأشًتۏحأۄەأڬۄأذعشحأؼثزتههيأثىأصۏزأثىأؼثزشثۄأشعۏأتههۄأؼىۄأ+أدىأڬًأرًتثأوۏڽأتستىأثحتةۏأڲةۏأحہۏأ,أشضًهأتههۄأ﷽أڬۏأرزوحأوۏڽأإةەأتًشأؼشعأڬۏأ=أۏتأشضًهأتههۄأ﷽أوۏڽأىەأۏۄأثتؽأتههۄأتًشأتضأڬەأشضًهأڬەأهةەأظزمۄأوۏڽأزۏتأۗأتىأڬەأًتهزۏىأىەأإأڬشأثحتۏتأ=أۏتأشضًهأتههۄأ﷽أۏۄۏأثتؽأۄوتشۏأڲصشأتًمتحأڬتأًتذزأسشۏؼۄأحہتأ؏أشضًهأتههيأ﷽أىەأًۄأثتؽأتىأڬًأًتځضأڬشأزۏتأۗأځہشأدثأًۄأزًىًڽألًحأۄًأڲةەأحًأتىأڬەأثؼزأتىأڬەأثۏټەأڬًأًشتخحأوۏڽأزەأزۏتأۗأ"
5449,%أوذوزأثىأؼوشأىەأتىأڬتأىضثأۏًڽأثۏتىأڬۏتأۄەأۗ““أتثًتهزشزتؤأؼًۏوشأثىأصۏزأثىأمۏضأثىأرىتضۄأثىأتوۏۄأثىأوتهڬأثىأؼتوشأثىأؼزۏأثىأڬؼثأثىأرصشدأثىأذتشخأثىأرصشدأ‛‛أثہۏأڬۄتأڲۏتأۄەأڬۄأذعشحأتثًتهزشزتؤأشعۏأتههۄأڬتأىتوأ““أؼتوشأ‛‛أحہتأهۏڬىأۏۄأډہًټەأحہەأ؏أتضأهةەأتىأڬًأؼًۏوشأڬۄتأدتىەأهڲتأۗأتىأڬۏأًتهزۄأ““أوذثۄأثىحأًتمزأثىأؼوشًأثىأتػىتثۄأثىأؼتوشأثىأصۏزأوىتۆأثىأوتهڬأثىأخؼهثۄأثىأڬؼثأ‛‛أۄۏڽأۗ أذعشحأتثًتهزشزتؤأشعۏأتههۄأؼىۄأتځىەأرتىزتىأوۏڽأضثأضەأإرشأوۏڽأتۏوتىأهتةەأۗأۏۄأۄوۏطۄأتځىتأثحأتځىەأضتحہأشڬہتأڬشحەأحہەأۗأتضأڬەأتًځشأتۏڬأشًوتهأڋتهأڬشأشڬہحەأحہەأ؏أذعشحأؼثزتههۄأثىأشًتذۄأشعۏأتههۄأؼىۄأتىأڬًأتڬخشأتضهتوأڬۏأزؼًحأزۏتأڬشحەأحہەأهۏڬىأۏۄأتىڬتشأڬشأزۏتأڬشحەأحہەأ؏أتۏڬأزىأؼثزتههۄأثىأشًتذۄأشعۏأتههۄأؼىۄأتىأڬەأځتضأإةەأ؏أۏۄأصوتىۄأدتۄهۏحأوۏڽأتىأڬەأثہتةۏأثىەأۄًةەأحہەأدثأتىۄًڽأىەأزۏڬہتأڬۄأتثًتهزشزتؤأشعۏأتههۄأؼىۄأڲہشأضەأثتۄشأډهەأڲةەأۄۏڽأحًأتىأڬەأڲہشأوۏڽأزترهأۄًأڲةەأتًشأتىأڬۏأثۏًۏأڬەأځتضأڲةەأًۄأتضأًمحأتځىەأضشأوۏڽأڬىڲہۏأڬشأشۄۏأحہۏأ؏أتىۄًڽأىەأځًډہتأ=أتثًتهزشزتؤأشعۏأتههۄأؼىۄأڬۄتڽأۄەأآأتىأڬۏأصًدۄأىەأڬۄتأ=أحوۄتشتأثہتةۏأتثہۏأثتۄشأىڬهتأۄەأ؏أحًأذعشحأؼثزتههۄأثىأشًتذۄأشعۏأتههۄأؼىۄأڬهۄتڔتأهەأڬشأتضأڬوشەأوۏڽأڲةەأدضأوۏڽأتىۄًڽأىەأتځىتأثحأشڬہتأۄًتأحہتأتضأڬًأىۏډەأڲشتۏتأتًشأشۏصۄأشۏصۄأڬشأڋتهتأتًشأطۏغتىأڬتأتۏڬأتۏڬأىتوأهەأڬشأۏًڽأڬۄۄأشۄەأحہەأ““أرثشزتشأۄشأًۄأډۏصأدضأوۏڽأتههۄأڬەأۄوشتۄأؼثتزحأڬۏأدتةەأًۄأثتغهأۄەأ‛‛أدثأذعشحأؼثزتههۄأۄثىأشًتذۄأشعۏأتههۄأؼىۄأتضأثحأڬًأڬهۄتڔەأضەأحًڔأشۄەأحہەأحًأتثًتهزشزتؤأشعۏأتههۄأؼىۄأڬۏأصًدۄأڬهۄتڔەأڬۏأإًتصأضىأڬشأثًهۏأ=أتەأتثىأشًتذۄأحًأىەأوشًتأزۏتأۗأذعشحأؼثزتههۄأثىأشًتذۄأشعۏأتههۄأؼىۄأتىأڬۏأإًتصأضىأڬشأثتۄشأحطشۏلأهەأإةەأۗأتضأڬەأثؼزأذعشحأتثًتهزشزتؤأشعۏأتههۄأؼىۄأتځىەأڲہشأًتځضأإةەأ؏أحًأزۏڬہتأڬۄأتىأثۏًۏأرًلأڬەأوتشەأشًأشۄۏأۄەأۗأتىۄًڽأىەأشًىەأڬۏأًدۄأځًډہۏأحًأتىۄًڽأىەأثحتأزۏتأڬۄأحوۄتشتأثہتةۏأؼثزتههۄأثىأشًتذۄأشعۏأتههۄأؼىۄأإۏتأحہتأتًشأزۏڬہأهًأحوۄتشەأثحأڬتأۏۄأذطشأڬشأڬەأډهتأڲۏتأۄەأۗأتثًتهزشزتؤأشعۏأتههۄأؼىۄأڬًأثۄحأطزۏزأؽظۄأإۏتأهۏڬىأتىۄًڽأىەأڬډہأزۏشأضًډتأتًشأدثأضًډتأحًأۏۄأىحۏدۄأىڬتهتأڬۄأتڲشأتضأڬەأځتضأڬًةۏأثہهتةۏأۄًحۏأحًأۏۄأتځىەأإځأڬًأثډتأىۄأهۏحتأ؏أًۄأًۄۏڽأضەأډهەأتًشأشضًهأتههۄأ﷽أڬۏأثتشڲتۄأوۏڽأذتعشأۄًأڲةەأ؏أذعشحأؼثزتههۄأثىأشًتذۄأشعۏأتههۄأؼىۄأثہۏأتىأڬەأۄوشتۄأحہەأ؏أذعًشأ﷽أڬۏأثتشڲتۄأوۏڽأذتعشأۄًأڬشأذهمۄأثڲًطأتضهتوأۄًأڲةەأۗ أتىأڬەأمثًهأتضهتوأڬەأثتشەأوۏڽأۏۄأثہۏأشًتۏحأۄەأڬۄأدىڲأتذزأڬەأزىأدثأهًڲًڽأوۏڽأثہڲزڔأوډأڲةۏأحہۏأتضأًمحأشضًهأتههۄأ﷽أىەأذعشحأتثًتهزشزتؤأشعۏأتههۄأؼىۄأڬًأزۏڬہأڬشألشوتۏتأ=أؼًۏوشأڬحىتأتډہتأطۄضًتشأۄەأوڲشأۏۄأڬۄأًۄأؽۏشأوضتلشأًتمؼأۄًتأۄەأۗ أذعشحأؼثزتههۄأثىأؼوشأشعۏأتههۄأؼىۄوتألشوتحەأۄۏڽأ=أوۏڽأىەأڬډہأهًڲًڽأڬًأۏۄأڬۄحەأۄًةەأثہۏأضىتأۄەأڬۄأذعشحأتثًتهزشزتؤأشعۏأتههۄأؼىۄأؽصًۄأتذزأوۏڽأطشۏڬأىۄۏڽأۄًةەأحہەأتهثحۄأإځأشضًهأتههۄأ﷽أڬەأظذتثۄأڬشتوأشعۏأتههۄأؼىۄوأوۏڽأطتوهأۄۏڽأۗأتًشأشضًهأتههۄأ﷽أڬەأۄوشتۄأثۄحأضتشەأؽصًتحأوۏڽأطشۏڬأۄًةەأۗأذعشحأؼثزتههۄأثىأؼوشأشعۏأتههۄأؼىۄوتألشوتحەأۄۏڽأ=أذعشحأتثًتهزشزتؤأشعۏأتههۄأؼىۄأذعشحأؼخوتىأؽىۏأشعۏأتههۄأؼىۄأڬۏأزًشأرهتلحأوۏڽأضىأ65أۄدشۏأڬًأزوطمأوۏڽألًحأۄًةەأۗ%أ
5450,%أثىۏأۄثتشأڬەأإصتزأڬشزۄأؽهتوأتثًتضذتمأتدشثألشوتحەأۄۏڽأ=أوۏڽأظذتثۏأشضًهأتههۄأذعشحأتثًتهزشزتؤأؼًۏوشأثىأمۏضأثىأرىتضۄأشعۏأتههۄأؼىۄأڬًأزۏڬہتأۄەأتىأڬۏأإىڬہۏڽأضۏتۄۏأوتةهأضشرأحہۏڽأتًشأإځأطشوأًأذۏتؤأڬەأځۏڬشأحہەأ؏أإځأصشزأشىڲأڬتأرعتثأهڲتۏتأڬشحەأحہەأۗأوۏڽأتىأڬەأضشأځشأډہًټەأضتةصأڬۏأټًځۏأزۏڬہۏأۄەأتًشأتضأڬەأتًځشأؼوتوۄأطشۏلأدضأڬًأتىۄًڽأىەأتځىەأڬىزہەأځشأهټڬتۏتأۄًتأحہتأۗ أذعشحأؼثتضأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أتۏڬأإزوۏأڬًأدًأوۏشەأضتحہأحہتأتضأىەأتىأضەأځًډہتأ=أحوأىەأڬحىتأؼشظۄأتىأڬًأزۏڬہتأآأتىۄًڽأىەأڬۄتأ=أوۏڽأىەأتۏڬأضتهأضەأصۏتزۄأتىأڬًأزۏڬہتأ؏أًۄأدًشتثۏڽأتًشأدًحەأځۄىأڬشأشڬہحەأحہەأۗأتًشأًۄأتثًتضذتمأڬەأځتضأتۏڬأضًأثۏضأضتهأحڬأإحەأشۄەأۗ%أ
5451,أوظؼثأثىأؼثزتههۄأصثۏشۏأىەأتىأڬتأىتوأ““أتثًسشأدىزثأثىأدىتزۄأ‛‛أثۏتىأڬۏتأۄەأۗأثؼعأواشرۏىأىەأ““أۏصۏزأثىأدىتزۄأ‛‛أثۏتىأڬۏتأۄەأۗأ65أضىأۄدشۏأوۏڽأشثسۄأوۏڽأتىأڬتأتىحمتهأۄًتأۗأتىأڬۏأىوتصأدىتصۄأڬضأىەأځڔہتةۏأۄەأتضأثتشەأوۏڽأترحهتلأۄەأثؼعأىەأڬۄتأۄەأڬۄأ““أذعشحأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄأىەأځڔہتةۏأحہۏأتًشأثؼعأىەأڬۄتأۄەأڬۄأ““أذعشحأدشۏشأثىأؼثزتههۄأتهثدهۏأشعۏأتههۄأؼىۄأىەأځڔہتةۏأحہۏأۗأ
5452,أذعشحأودتۄزألشوتحەأۄۏڽأ=أذعشحأتثًسشأشعۏأتههۄأؼىۄأڬەأځتضأڬډہأهًڲأوًدًزأحہەأإځأىەأتىأضەألشوتۏتأ=أوۏشۏأوًحأڬتأًمحأمشۏثأۄەأۗأتڲشأوۏشەأځتضأۏتأوۏشەأضتحہۏأڬەأځتضأتحىتأڬځڔتأوًدًزأۄًأڬۄأًۄأڬلىأڬەأهۏەأڬلتۏحأڬشەأحًأودہەأتضۏأڬځڔەأوۏڽأڬلىأزۏىتأ؏أتًشأوۏڽأحوۄۏڽأمضوأزۏحتأۄًڽأودہەأڬًةۏأىوثشزتشأ؏أډًۄزشۏأ؏أۏتأذتڬوأ؏أضشزتشأ؏أمتظزأۏتأتۏهډۏأمضوأڬتأإزوۏأڬلىأىۄأزەأ؏أًۄأهًڲأحوتوأثڔەأظتذثأوىظثأحہەأ؏أتهثحۄأذدشتهوزشۏأتًشأوتهڬأتهتطحشأتۏڬأدوتؼحأوۏڽأوًدًزأحہەأ؏أتىأوۏڽأتۏڬأإزوۏأتىظتشأوۏڽأضەأحہتأتًشأتضأځًشۏأمًوأوۏڽأظشلأتۏڬأًۄۏأتىظتشۏأۄۏأتىأطشتةغأڬەأځۏطأىػشأڬلىأزۏىەأڬتأتۄهأحہتأ؏أتضأىەأڬۄتأ=أوۏڽأإځأڬًأتځىۏأتضأډتزشأوۏڽأتًشأزًأڬځڔەأوۏڽأدًأڬۄأظىزًمأوۏڽأشڬہەأۄًةەأۄۏڽأدًأڬۄأوۏشۏأًتهزۄأىەأوۏشەأتذشتوأڬەأهۏەأرًزأتځىەأۄتحہًڽأضەأڬتحأڬشأثىتةەأۄۏڽأ؏أتىأوۏڽأإځأڬًأڬلىأزًڽأڲتأۗأذعشحأتثًسشأشعۏأتههۄأؼىۄأىەألشوتۏتأ=أًۄأوۏشەأهۏەأڬتلۏأۄۏڽأۗأ
5453,أتثًؼثۏزۄأوؼوشأثىأوخىۏأىەأتىأڬتأىتوأۏۄأثۏتىأڬۏتأۄەأ““أتثًسشأؽلتشۏأدىزثأثىأدىتزۄأثىأضلۏتىأثىأؼثۏزأثىأذشتوأۗأتثىأضهتوأڬۄحەأۄۏڽأ=أتىأڬتأىتوأ““أۏصۏزأ‛‛أثہۏأثۏتىأڬۏتأڲۏتأۄەأۗأ
5454,أوذوزأثىأؼثزتههۄأثىأىوۏشأىەأتىأڬتأىتوأۏۄأثۏتىأڬۏتأۄەأ““أتثًسشأدىزثأثىأدىتزۄأثىأمۏضأثىأؼوشًأثىأظؼۏشأثىأذشتوأثىأؽلتشأ‛‛أتىأڬۏأًتهزۄأڬتأىتوأ““أشوهۄأثىحأًمۏؼۄأثىأؽلتشأ‛‛أۄەأۗأتًشأۏۄأدًأشًتۏحأۄەأڬۄأتىأڬتأىتوأ““أۏصۏزأ‛‛أحہتأحًأتضأڬەأثتشەأوۏڽأوشًۏأۄەأڬۄأۏۄأىتوأشضًهأتههۄأ﷽أىەأشڬہتأحہتأۗأ
5455,"أذعشحأصۏزأثىأتضهوأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أىثۏأتڬشوأ﷽أڬۏأذعشحأتثًسشأشعۏأتههۄأؼىۄأضەأتۏڬأغًۏهأڲلحڲًأوشًۏأۄەأتضأوۏڽأإځأ﷽أىەأتىأڬًأ““أۏتأۏصۏزأ‛‛أ+أتەأۏصۏزأ,أڬۄۄأڬشأځڬتشتأحہتأۗأ"
5456,%أتثًذوصۄأڬۄحەأۄۏڽأ=أذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأىەأۄوأضەأڬۄتأ=أڬۏتأوۏڽأحوۄۏڽأذعشحأتثًسشأشعۏأتههۄأؼىۄأڬەأتضهتوأمثًهأڬشىەأڬتأًتمؼۄأضىتاڽأآأۄوأىەأڬۄتأ=أدۏأۄتڽأ$أتىۄًڽأىەأڬۄتأ=أذعشحأتثًسشأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أوۏشتأحؼهمأؽلتشأمثۏهەأڬەأضتحہأحہتأ؏أۄوۏڽأۏۄأتغهتؼأوهۏأڬۄأوڬۄأوڬشوۄأوۏڽأتۏڬأإزوۏأىەأىثًحأڬتأزؼًۏٳأڬۏتأۄەأۗأوۏڽأىەأتځىەأثہتةۏأضەأڬۄتأڬۄأتضأإزوۏأضەأدتأڬشأوهًأتًشأتضأضەأثتحأډۏحأڬشأڬەأإاأتًشأودہەأثحتاأ؏أوۏشتأثہتةۏأًۄتڽأڲۏتأتًشأتىأضەأوهتمتحأڬۏأ؏أتًشأًتځضأهًټأڬشأإأڲۏتأ؏أوۏڽأىەأتضأضەأځًډہتأڬۄأحوأڬۏتأرثشأهەأڬشأإةەأۄًأآأتضأىەأڬۄتأ=أرزتأڬۏأمضوأ$أوۏڽأىەأزۏڬہتأڬۄأًۄأطرظأىۏڬۏأڬتأذڬوأزۏحتأۄەأتًشأثشتةۏأضەأشًڬحتأۄەأۗ
أذعشحأتثًسشأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أوۏڽأىەأتضأضەأڬۄتأ=أودہەأحۏشۏأزۏأۄًةۏأرثشأضەأظذۏذأغًشأځشأحطلۏأىۄۏڽأۄًةۏأ؏أوۏڽأىەأتځىۏأحهًتشأتًشأؼظتأتټہتۏتأتًشأوڬۄأوڬشوۄأڬۏأدتىثأشًتىۄأۄًأڲۏتأ؏أ+أدثأوۏڽأوڬۄأوڬشوۄأځۄىډتأحًأځشۏطتىۏأۏۄأحہۏأڬۄأ,أوۏڽأذعًشأ﷽أڬًأځۄډتىحتأثہۏأىۄأحہتأتًشأوۏڽأإځأ﷽أڬەأثتشەأوۏڽأڬضۏأضەأځًډہىتأثہۏأىۄۏڽأډتۄحتأحہتأ؏أوۏڽأإثأصوأصوأځۏأڬشأوضدزأوۏڽأثۏټہأڲۏتأ؏أ+أذعشحأتثًسشأشعۏأتههۄأؼىۄأ
5457,"%أذعشحأتثًسشأؽلتشۏأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أطشًؼأطشًؼأوۏڽأوۏشەأتضهتوأڬۏأغشلأوتةهأۄًىەأڬۏأًدۄأۏۄأحہۏأڬۄأۄوأوضتلشأهًڲأحہەأۄوتشەأؼهتمەأوۏڽأمذغأځڔأڲۏتأوۏڽأتځىۏأًتهزۄأتًشأتځىەأثہتةۏأتىۏضأڬًأضتحہأهەأڬشأىدزأڬەأثتهتةۏأؼهتمەأوۏڽأتځىەأضضشتهأډهتأڲۏتأ؏أدثأۄوأتىأڬەأځتضأځۄىډەأحًأتىۄًڽأۄوتشۏأثۄحأؼصحأڬۏأتضأوذهەأڬەأتۏڬأإزوۏأىەأودہەأزۏڬہتأحًأًۄأوۏشەأوتوًڽأڬەأځتضأڲۏتأتًشأتىأضەأڬۄىەأهڲتأ=أڬۏتأحوأدتىحەأۄًأڬۄأتىۏضأحوۄتشتأورتهلأۄەأآأ+أذعشحأتثًسشأشعۏأتههۄأؼىۄأ,ألشوتحەأۄۏڽأ=أتىأڬەأزهأوۏڽأوۏشەأثتشەأوۏڽأشىدطأضۏأځۏزتأۄًأڲةۏأ؏أوۏڽأتًىټًڽأڬەأشۏًڔأوۏڽأډهتأڲۏتأ؏أوۏڽأتىأڬًأطڬضحۄأزهأځشۏطتىأذتهأثۏټہەأزۏڬہتأۗأوۏڽأىەأتىأضەأځًډہتأڬۄأتەأوتوًڽأإځأڬۏًڽأځشۏطتىأثۏټہەأۄۏڽأآأتىۄًڽأىەأضتشتأوتدشتأڬۄۄأضىتۏتأۗأتههۄأحؼتهۏٳأثډتةەأ؏أۄوأڲىتۄأضەأڋشحەأۄۏڽأۗأصوتىەأىەأۄوۏڽأوذحتدأڬشأزۏتأۄەأتًشأتثحزتؤأوۏڽأإځأىەأدضأتىزتصأوۏڽأۄوتشتأرۏتهأڬۏتأۄەأتثأتضأحؼهمأوۏڽأزشتڔأځڔأډڬۏأۄەأتضأثىتؤأځشأهڲحتأۄەأڬۄأتثأتځىتأتڬټہەأشۄىتأووڬىأىۄۏڽأۄەأ؏أوۏڽأىەأتځىۏأًتهزۄأتًشأثہتةۏأڬًأضتحہأهۏتأتًشأوڬۄأڬەأمشۏثأإأڬشأڋۏشۄأهڲتأهۏتأۗأوۏشتأثہتةۏأطتؼشأحہتأتضأىەأڬۄتأ=أوۏڽأتځىەأتطؼتشأڬۏأثزًهحأځتىۏأځشأمثعۄأڬشأضڬحتأۄًڽأ؏أوۏڽأىەأتضأڬًأتضأڬتوأضەأوىؼأڬۏتأهۏڬىأًۄأعزأڬشأڬەأډهتأڲۏتأتًشأدشۏدأثىأظوۄأڬەأضتحہأتضأڬەأتًىټًڽأڬەأڲهۄأوۏڽأدتأڬشأومتثهۄأطشًؼأڬشأزۏتأۗأرزتأڬۏأمضوأ$أدشۏدأوۏشەأثہتةۏأضەأثڔتأطتؼشأحہتأۗأۏۄأزًىًڽأرىضتؤأڬەأځتضأإأڲةەأتًشأتطؼتشأڬتأومتثهۄأڬۏتأ؏أ+أرىضتؤأتىأوۏڽأوىظلأحہۏأ,أتضأىەأوۏشەأثہتةۏأڬًألتحذأمشتشأزۏتأتًشأۏۄأتضأهةەأڬۏتأڬۄأدشۏدأىەأتضأڬەأثتځأضەأتضأڬتأشطحۄأوتىڲتأحہتأهۏڬىأتضأىەأإڲەأضەأڬۄتأ=أًۄأثۄحأثًڔہتأۄەأودہەأتضأوۏڽأڬًةۏأزهډضځۏأىۄۏڽأۄەأ؏أتضأًدۄأضەأتضأڬەأزهأوۏڽأڬۏىۄأځۏزتأۄًأڲۏتأحہتأ؏أۏۄأطشغأدۏحأڬشأۄوأىەأتضأڬتأڲهۄأتځىەأڲهۄأڬەأضتحہأوهتأهۏتأ؏أتضأغشذأۄوتشەأتًىټأضًأضەأثہۏأصۏتزۄأۄًأڲةەأۗأإځألشوتحەأۄۏڽأ=أځہشأوۏڽأوڬۄأوۏڽأإأڲۏتأ؏أضثأضەأځۄهەأوۏڽأظلتأوشًۄأڬۏأضؼۏأڬشىەأهڲتأًۄتڽأوۏڽأىەأمشۏطأڬەأثۄحأضتشەأمتلهەأزۏڬہەأ؏أودہەأڬضۏأىەأثحتۏتأڬۄأًۄتڽأځشأتۏڬأظتثۏأ+أتځىەأزۏىأضەأثشڲطحۄأ,أطرظأۄەأ؏أۏتأودىًىأۏتأطتؼشأۏتأدتزًڲشأوًدًزأۄەأۗأوۏڽأىەأڬۄتأ=أدضأطرظأڬەأثتشەأوۏڽأحوأۏۄأڲوتىأشڬہحەأۄًأ؏أًۄأڬۄتڽأۄەأآأهًڲًڽأىەأڬۄتأ=أۏۄأدضأطرظأڬًأحوأزۏڬہأشۄەأۄًأ؏أۏۄۏأًۄأۄەأۗأوۏڽأځهټأڬشأتىأڬەأځتضأڲۏتأۗأرزتأڬۏأمضوأ$أوۏڽأًۄتڽأضەأتۏڬأځحہشأڬۏأومزتشأثہۏأإڲەأىۄۏڽأثڔہتأحہتأڬۄأتىۄًڽأىەأودہأځشأۄڋۏًڽأ؏أځحہشًڽأتًشأڲىزڲۏأڬۏأثًډہتڔأڬشأزۏأۗأتًشأودہەأضشثضشأرًىأضەأىۄهتأزۏتأۗأوۏڽأثۏحأتههۄأوۏڽأإۏتأتًشأڬؼثۄأڬەأځشزًڽأوۏڽأډہځأڲۏتأ؏أوۏڽأحۏىأزىأًۄتڽأإثأصوأصوأڬەأؼهتًۄأثؽۏشأڬډہأڬہتةەأ؏أځۏةەأشًصەأڬۏأذتهحأوۏڽأشۄتأۗأتۏڬأشًطىأشتحأوۏڽأدثأډتىزأرًثأډوڬأشۄتأحہتأثىۏأرصتؼۄأڬۏأزًأؼًشحۏڽأثۏحأتههۄأطشۏلأڬتأغًتلأڬشىەأإةۏڽأ؏أتىۄًڽأىەأتضتلأتًشأىتةهۄأزًأثحًڽأڬتأسڬشأڬۏتأۏۄأهًڲأتىأڬۏأؼثتزحأڬۏتأڬشحەأحہەأۗأوۏڽأىەأځشزًڽأضەأتځىتأضشأثتۄشأىڬتهتأتًشأڬۄتأ=أحوأوۏڽأضەأتۏڬأ؏أزًضشۏأځشأډڔہأدتاأ؏أۏۄأثتحأضىأڬشأًۄأطزۏزأؽعثىتڬأۄًأڲةۏڽأتًشأڬۄىەأهڲۏڽأ=أتههۄأڬۏأمضوأ$أتڲشأإدأۄوتشەأضتحہأۄوتشەأوشزأۄًحەأحًأحوأۏۄأثتحأىۄأڬۄۄأضڬحەأ؏أځہشأًۄأډهۏأڲةۏڽأۗأوۏڽأتىأڬەأځۏډہەأځۏډہەأډهأزۏتأ؏أًۄأشضًهأتههۄأ﷽أڬۏأثتشڲتۄأوۏڽأڲةۏڽأۗأشضًهأتههۄأ﷽أىەأتىأضەأځًډہتأڬۄأحوأڬًىأۄًأآأڬضأمثۏهەأضەأحؼهمأشڬہحۏأۄًأآأڬۄتڽأضەأإةۏأۄًأآأتًشأحوۄۏڽأڬۏتأڬتوأڬتوأۄەأآأتىۄًڽأىەأضتشتأمظۄأڬۄۄأضىتۏتأۗأشضًهأتههۄأ﷽أىەأځًډہتأ=أحوأىەأتضأظتثۏأڬًأڬۄتڽأډہًڔتأۄەأآأتىۄًڽأىەأڬۄتأ=أڬؼثۄأڬۏأؼوتشحأتًشأځشزًڽأڬەأزشوۏتىأۗأإځأ﷽أىەأتىأضەأځًډہتأ=أڬۏتأتضأىەأحوأضەأثہۏأڬډہأڬۄتأۄەأآأتىۄًڽأىەأڬۄتأ=أدۏأۄتڽأۗأذعشحأتثًسشأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أوۏڽأشضًهأتههۄأ﷽أڬۏأثتشڲتۄأوۏڽأځۏطأۄًأڲۏتأتًشأإځأڬًأضهتوأؼشعأڬۏتأۗأإځأ﷽أىەأځًډہتأ=أحوأڬًىأۄًأآأڬضأمثۏهەأضەأحؼهمأۄەأآأڬۄتڽأضەأإةەأۄًأآأتًشأڬضأهةەأإةەأۄًأآأوۏڽأىەأإځأ﷽أڬًأضتشتأوتدشتأڬۄۄأضىتۏتأۗأشضًهأتههۄأ﷽أځًډہتأ=أتحىەأزىأحوأڬۄتڽأضەأڬہتحەأځۏحەأشۄەأآأوۏڽأىەأڬۄتأ=أۏتأشضًهأتههۄأ﷽أوۏڽأظشلأإثأصوأصوأځشأڲصتشتأڬشحتأشۄتأ؏أإځأ﷽أىەألشوتۏتأ=أۄتڽأ؏أإثأصوأصوأڬہتۏتأدتىەأًتهتأغؼتوأۄەأۗأتضأًمحأشضًهأتههۄأ﷽أڬەأځتضأذعشحأتثًثڬشأظزۏمأشعۏأتههۄأؼىۄأثۏټہەأۄًةەأحہەأ؏أتىۄًڽأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ﷽أودہەأتدتصحأزۏدةەأوۏڽأتىأڬەأهۏەأڬہتىەأڬتأتىحػتوأڬشحتأۄًڽأۗأإځأ﷽أىەأتىأڬًأتدتصحأزەأزۏأۗأځہشأشضًهأتههۄأ﷽أًۄتڽأضەأځۏزهأډهأىڬهەأتًشأذعشحأتثًثڬشأشعۏأتههۄأؼىۄأىەأوۏشتأۄتحہأحہتوأهۏتأتًشأډهحەأډهحەأشضًهأتههۄأ﷽أذعشحأتثًثڬشأشعۏأتههۄأؼىۄأڬەأزشًتصەأځشأدتأڬشأشڬەأۗأذعشحأتثًثڬشأشعۏأتههۄأؼىۄأڲہشأڲةەأتًشأغتةلأڬتأزشإوزأطزۄأوىمؼأهەأڬشأإةەأ؏أشضًهأتههۄأ﷽أتۏڬأتۏڬأوټہۏأثہشأڬشأۄوۏڽأزۏحەأشۄەأتًشأۄوأڬہتحەأشۄەأۗأذحۏأڬۄأۄوتشتأځۏټأثہشأڲۏتأۗ أشضًهأتههۄأ﷽أىەأودہەأإًتصأزۏأ؏أوۏڽأىەأهثۏڬأڬۄتأۗأحًأإځأ﷽أىەألشوتۏتأ=أثەأطڬأصوۏىأوۏشەأهةەأثهىزأڬۏأڲةۏأۄەأۏۄأوتهأًأزًهحأضەأثہشۏأۄًةۏأۄەأ؏أوۏشتأرۏتهأۄەأڬۄأۏۄأضشصوۏىأوڬۄأۄەأ؏أتضأهةەأحوأتځىەأڲہشأًتهًڽأڬەأځتضأډهەأدتاأتًشأدًأزۏىأحًأىەأترحۏتشأڬۏتأۄەأتىأڬًأثہۏأتضأڬۏأزؼًحأزًأ؏أذعشحأتثًسشأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أوۏڽأًۄتڽأضەأىڬهتأتًشأتځىۏأًتهزۄأتًشأثہتةۏأڬەأځتضأإۏتأتًشأتىأڬًأضتشۏأڬۄتىۏأضىتةۏأ؏أتىۄًڽأىەأڬۄتأ=أحوأدضأزۏىأوۏڽأزترهأۄًةەأۄًأۄوۏڽأتضأزۏىأضەأڬًةۏأىلشحأىۄۏڽأۄەأۗأډىتىډۄأتىأزًىًڽأىەأثہۏأتضهتوأمثًهأڬشأهۏتأ؏أځہشأۄوأهًڲأًۄتڽأضەأىڬهەأتًشأوزۏىۄأوىًشۄأوۏڽأإأڲةەأ؏أۏۄتڽأإأڬشأۄوأىەأتځىۏأمًوأڬًأضتشۏأثتحأثحتةۏأ؏أتىۄًڽأىەأڬۄتأ=أۄوأحوۄتشۏأحظزۏمأڬشحەأۄۏڽأتًشأۄًأضڬحتأۄەأڬۄأۏۄأضؼتزحأۄوۏڽأثہۏأىظۏثأۄًأدتةەأتًشأۄوأثہۏأثتشڲتۄأوظغلۏأوۏڽأذتعشأۄًأدتةۏڽأۗأځہشأدثأشضًهأتههۄأ﷽أۄدشحأڬشأڬەأوزۏىۄأطشۏلأحطشۏلأهتةەأ؏أحًأۄوأإځأ﷽أڬۏأرزوحأوۏڽأذتعشأۄًةەأ؏أمثۏهۄأؽلتشأىەأإځأ﷽أضەأڬۄتأ=أۏتأشضًهأتههۄأ﷽أتثًسشأشعۏأتههۄأؼىۄأىەأۄوۏڽأًۄأضثأڬډہأثحتأزۏتأحہتأدًأإځأىەأثحتۏتأۄەأ؏أتًشأۄوأضثأوضهوتىأۄًأډڬەأۄۏڽأتًشأۄوأڲًتۄۏأزۏحەأۄۏڽأڬۄأثەأطڬأإځأتههۄأڬەأضډەأشضًهأۄۏڽأۗأځہشأمثۏهۄأتضهوأتًشأرصتؼۄأڬەأهًڲأثہۏأذتعشأۄًةەأتًشأتىۄًڽأىەأڬۄتأ=أۏتأشضًهأتههۄأ﷽أۄوأثہۏأوضهوتىأۄۏڽأتًشأتضۏأزۏىأوۏڽأزترهأۄۏڽأدضأوۏڽأۄوتشەأزًضشەأثہتةۏأتًشأۄوتشەأذهۏلأزترهأۄًةەأۄۏڽأۗأشضًهأتههۄأ﷽أىەأمثۏهۄأتضهوأڬەأثتشەأوۏڽأڬۄتأ=أتضهوأڬًأتههۄأحؼتهۏٳأضهتوحأشڬہەأ؏أتًشأؽلتشأڬەأثتشەأوۏڽألشوتۏتأ=أؽلتشأڬۏأتههۄأحؼتهۏٳأوؽلشحألشوتةەأۗأځہشأذعشحأتثًثڬشأشعۏأتههۄأؼىۄأىەأوۏشتأۄتحہأځڬڔأڬشأودہەأإًتصأزۏأحًأوۏڽأىەأهثۏڬأڬۄتأۗأإځأىەأڬۄتأ=أڬۏتأحوأدتۄهۏحأڬەأزًشأوۏڽأثہۏأؼثتزحأڬۏتأڬشحەأحہەأآأوۏڽأىەأڬۄتأ=أدۏأۄتڽأۗأوۏڽأضًشدأڬەأضتوىەأڬہڔتأۄًأڬشأؼثتزحأطشًؼأڬشأزۏحتأحہتأتًشأوۏڽأتضأًمحأحڬأؼثتزحأوۏڽأوظشًلأشۄحتأحہتأدثأحڬأزہًځأڬۏأطزحأڬۏأًدۄأضەأوۏشەأځتاڽأدهىەأىۄأهڲأدتحەأۗأځہشأوۏڽأضدزەأوۏڽأڲشأدتحتأۗأتىۄًڽأىەأودہأضەأڬۄتأ=أحوأتضهتوأڬۏأدتىثأڬضأغشذأوتةهأۄًةەأآأوۏڽأىەأڬۄتأ=أۏۄأودہەأىۄۏڽأځحتأثضأدزہشأتههۄأحؼتهۏٳأىەأودہەأوحًدۄأڬۏتأوۏڽأتزہشأۄۏأۄًأڲۏتأذحۏٳأڬۄأتههۄأحؼتهۏٳأىەأودہەأىؼوحأتضهتوأضەأىًتصأزۏتأۗ%أ"
5458,%أذعشحأدثۏشأثىأىلۏشأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أذعشحأتثًسشأشعۏأتههۄأؼىۄألشوتۏتأڬشحەأحہەأ؏أوۏڽأتځىەأإځأڬًأډًحہەأىوثشأځشأتضهتوأهتىەأًتهتأضودہحتأۄًڽأڬۏًىڬۄأودہأضەأظشلأشضًهأتههۄأ﷽أذعشحأتثًثڬشأشعۏأتههۄأؼىۄأتًشأذعشحأثهتهأشعۏأتههۄأؼىۄأتضهتوأهتةەأحہەأۗ أٰٰأۏۄأذزۏخأظذۏذأتهتضىتزأۄەأهۏڬىأتوتوأثرتشۏأشذوۆأتههۄأؼهۏۄأتًشأتوتوأوضهوأشذوۆأتههۄأؼهۏۄأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗ%أ
5459,"أذعشحأوتهڬأثىأوشخزأتځىەأًتهزأڬتأۏۄأثۏتىأىمهأڬشحەأۄۏڽأڬۄأذعشحأتثًسشأشعۏأتههۄأؼىۄألشوتۏتأڬشحەأحہەأڬۄأوۏڽأډًحہەأىوثشأځشأتضهتوأهتىەأًتهتأۄًڽأڬۏًىڬۄأودہأضەأځۄهەأحۏىأهًڲأتضهتوأهتةەأحہەأتًشأوۏڽأډًحہتأۄًڽأۗأوۏڽأىثۏأتڬشوأ﷽أڬۏأثتشڲتۄأوۏڽأذتعشأۄًتأتًشأڬۄتأ=أتهضهتوأؼهۏڬوأۏتأشضًهأتههۄأ﷽أوۏڽأڲًتۄۏأزۏحتأۄًڽأڬۄأتههۄأڬەأضًتأڬًةۏأؼثتزحأڬەأهتةمأىۄۏڽأۄەأتًشأثەأطڬأوذوزأ﷽أتههۄأحؼتهۏٳأڬەأثىزەأتًشأشضًهأۄۏڽأۗأ+أوۏشەأتضهتوأمثًهأڬشىەأځشأ,أوۏڽأىەأشضًهأتههۄأ﷽أڬەأډۄشۄأتىًشأځشأرًطۏأڬەأإختشأزۏڬہەأۗأ"
5460,%أوتهڬأثىأوشخزأتځىەأًتهزأڬتأۏۄأثۏتىأىمهأڬشحەأۄۏڽأڬۄأذعشحأتثًسشأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأشضًهأتههۄأىەأتشطتزألشوتۏتأ=أصوۏىأًأإضوتىأىەأتثًسشأشعۏأتههۄأؼىۄأضەأثڔہأڬشأصۏتزۄأضډەأهۄدەأًتهتأتًشأًؼزۄأًلتةۏأڬشىەأًتهتأطرظأڬثہۏأىۄۏڽأزۏڬہتأ؏أۏۄأذعشحأؼۏضۏٳأتثىأوشۏوأؼهۏۄوتأتهضهتوأضەأوطتثۄحأشڬہحەأۄۏڽأۗأذعشحأؼوشأثىأرغتثأشعۏأتههۄأؼىۄأتټہأڬشأڬہڔەأۄًةەأتًشأؼشعأڬۏتأ=أۏتأشضًهأتههۄأ﷽أڬۏتأۄوألعۏهحأضەأتثًسشأشعۏأتههۄأؼىۄأڬًأإڲتۄأڬشأزۏڽأآأإځأ﷽أىەألشوتۏتأ=أټہۏڬأۄەأ؏أحوأتضأڬًأإڲتۄأڬشأزًأۗ أۏۄأذزۏخأتوتوأوضهوأشذوۆأتههۄأؼهۏۄأڬەأوؼۏتشأڬەأوغتثمأۄەأهۏڬىأطۏرۏىأشذوۆأتههۄأؼهۏۄوتأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗ أۏۄۏأذزۏخأذعشحأؼثزتههۄأثىأؼوشًأتًشأتثًتهزشزتؤأضەأثہۏأوشًۏأۄەأۗ أذعشحأؼثزتههۄأثىأؼوشًأشعۏأتههۄأؼىۄأضەأوشًۏأذزۏخأزشدأسۏهأۄەأۗ%أ
5461,أذعشحأتثًتهزشزتؤأشعۏأتههۄأؼىۄأضەأوشًۏأذزۏخأزشدأسۏهأۄەأۗأ
5462,ڬحتثأوۏڽأتضأذزۏخأڬتأحشدوۄأوًدًزأىۄۏڽأۄەأ
5463,أذعشحأوظؼثأثىأضؼزأثىأتثۏأًمتظأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەأتشطتزألشوتۏتأ=أضثأضەأصۏتزۄأإصوتةطۏڽأتىثۏتؤأڬشتوأؼهۏۄوأتهضهتوأځشأإحۏأۄۏڽأ؏أتضأضەأڬوأ““أؼهوتؤأڬشتوأ‛‛أځشأۗأځہشأتضۏأغشذأزشدۄأثزشدۄأۗأ
5464,%أذعشحأتثًسشأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەأتشطتزألشوتۏتأ=أتەأتثًسشأ$أًۄأًمحأڬۏضتأۄًأڲتأدثأحوأڲہټۏتأهًڲًڽأوۏڽأځہىضەأۄًأڲەأۗأۏۄأڬۄحەأۄًةەأإځأ﷽أىەأتځىەأتۏڬأۄتحہأڬۏأتىڲهۏتڽأزًضشەأۄتحہأڬۏأتىڲهۏًڽأوۏڽأڋتهۏڽأۗأوۏڽأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ﷽أتۏضەأذتهتحأوۏڽأإځأوۏشەأهةەأڬۏتأتشطتزألشوتحەأۄۏڽأآأإځأ﷽أىەألشوتۏتأ=أظثشأڬشىتأ؏أظثشأڬشىتأ؏أظثشأڬشىتأۗأهًڲًڽأڬەأضتحہأذضىأترهتمأڬەأضتحہأځۏطأإىتأتًشأتىأڬەأتؼوتهأوۏڽأتىأڬۏأورتهلحأڬشىتأۗ أٰٰأۏۄأذزۏخأتوتوأثرتشۏأشذوۆأتههۄأؼهۏۄأتًشأتوتوأوضهوأشذوۆأتههۄأؼهۏۄأڬەأوؼۏتشأڬەأوغتثمأظذۏذأۄەأهۏڬىأتىۄًڽأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗ%أ
5465,"%أوىحظشأثىأؼوتشۄأثىأتثۏأسشأتځىەأًتهزأضەأًۄأتىأڬەأزتزتأضەأشًتۏحأڬشحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەأتشطتزألشوتۏتأ=أدثأمۏتوحأمشۏثأۄًأڲۏأحًأشۏطوۏأهثتضأڬۏأڬخشحأۄًأڲۏأ؏أحدتشحأثۄحأثڔہأدتةەأڲۏأ؏أوتهأًأزًهحأوۏڽأتعتلۄأۄًأڲتأ؏أزًهحوىزأتځىۏأزًهحأځشألرشأڬشۏڽأڲەأۗأڲىتۄأؼتوأۄًأدتةۏڽأڲەأ؏أثډًڽأڬۏأذڬًوحۏڽأۄًڽأڲۏڽأ؏أؼًشحۏڽأثڔہأدتةۏڽأڲۏأ؏أثتزطتۄأػتهوأۄًڽأڲەأ؏أىتځأحًهأوۏڽأڬوۏأڬۏأدتةەأڲۏأ؏أإزوۏأڬضۏأڬحەأۏتأطۏشأڬەأثډەأڬًأځتهأهەأ؏أۏۄأتضأڬەأهۏەأتځىۏأتًهتزأڬًأځتهىەأضەأثۄحشأۄًأڲتأ؏أثڔًڽأڬتأتذحشتوأرحوأۄًأدتةەأڲتأ؏أډہًټًڽأځشأشذوأىۄۏڽأڬۏتأدتةەأڲتأۗأذشتوۏأثډەأصۏتزۄأۄًڽأڲەأ+أذتهتحأتضأذزأحڬأڲىزەأۄًأدتةۏڽأڲەأڬۄأ,أإزوۏأضڔڬأڬىتشەأؼًشحأضەأصىتأڬشەأڲتأ؏أڬًةۏأطشۏلأإزوۏأتىأڬًأزۏڬہەأڲتأحًأ+أتضأڬۏأؽۏشحأثہۏأظشلأتحىۏأۄۏأۄًأڲۏأ,أًۄأڬۄەأڲتأ=أحوأضڔڬأضەأزًشأۄټأڬشأۏۄأڬتوأىۄۏڽأڬشأضڬحەأآأهًڲًڽأڬەأزهأثہۏڔۏةەأڬۏأغشذأۄًڽأتًشأتًځشأهثتضأثہۏڔأڬۏأغشذأطشۏلتىۄأۄًأڲتأۏۄأهًڲأتضأزہًڬۄأزۄۏأڬەأصوتىەأڬەأطشۏلأهًڲأۄًڽأڲەأۗ أتضأذزۏخأڬًأوثتشڬأثىألعتهۄأضەأشًتۏحأڬشىەأوۏڽأضۏلأثىأوضڬۏىأوىلشزأۄۏڽأۗأتًشأوثتشڬأثىألعتهۄأخمۄأۄۏڽأۗ%أ"
5466,أظزمۄأثىأتثۏأؼوشتىأثىأذغتىألشوتحەأۄۏڽأ=أوۏڽأذعشحأتثًسشأشعۏأتههۄأؼىۄأڬەأځتضأڲۏتأ؏أًۄأوضدزأوۏڽأتځىۏأڬتهۏأ؏أډتزشأهځۏټەأحىۄتأثۏټہەأحہەأ؏أوۏڽأىەأځًډہتأ=أتەأتثًسشأ$أإځأتضأغشذأتڬۏهەأڬۏًڽأثۏټہەأۄۏڽأآأتىۄًڽأىەأدًتثأزۏتأ=أوۏڽأىەأشضًهأتههۄأ﷽أڬًأۏۄألشوتحەأۄًةەأضىتأۄەأ““أثشەأضتحہۏأڬۏأضىڲحأضەأحىۄتةۏأثۄحشأۄەأ؏أتًشأحىۄتةۏأضەأثۄحشأتډہەأزًضحأڬۏأضىڲحأۄەأتًشأتډہۏأثتحأڬشىتأرتوًطۏأضەأثۄحشأۄەأتًشأثشۏأثتحأضەأرتوًطۏأثۄحشأۄەأۗأ
5467,أؼثزتهشذوىأثىأؽىوألشوتحەأۄۏڽأ=أوۏڽأذعشحأتثًتهزشزتؤأشعۏأتههۄأؼىۄأڬەأځتضأحہتأ؏أتۏڬأإزوۏأوزۏىۄأڬۏأدتىثأضەأإۏتأتًشأتىأضەأذعشحأتثًسشأشعۏأتههۄأؼىۄأڬەأثتشەأوۏڽأځًډہتأحًأتىۄًڽأىەأڬۄتأ=أًۄأحًأشثسۄأڬۏأدتىثأډهەأڲةەأۄۏڽأ؏أتضأىەأڬۄتأ=أتىتأههۄأًتىتأتهۏۄأشتدؼًىأ؏أذعشحأتثًسشأشعۏأتههۄأؼىۄأتڲشأوۏشتأۄتحہأۏتأڬًةۏأؼعًأڬتټأڋتهەأحًأودہەأۏۄأثہۏأثشتأىۄأهڲەأدثأضەأوۏڽأىەأشضًهأتههۄأ﷽أڬۏأصثتىۏأتىأڬەأثتشەأوۏڽأۏۄأڬهوتحأضىەأۄۏڽأ=أصوۏىأڬەأضۏىەأىەأتًشأډطوألهڬأىەأتثًسشأشعۏأتههۄأؼىۄأضەأثڔہأڬشأڬًةۏأضډتأتىضتىأىۄۏڽأزۏڬہتأۗأ
5468,%أذعشحأؼثزتههۄأثىأظتوحألشوتحەأۄۏڽأ=أتوأسشأىەأڬۄتأ=أذعشحأؼخوتىأشعۏأتههۄأؼىۄأىەأذعشحأتثًسشأشعۏأتههۄأؼىۄأڬًأدهتًغىأىۄۏڽأڬۏتأحہتأثهڬۄأشضًهأتههۄأ﷽أىەأتىأڬًألشوتۏتأحہتأڬۄأدثأؼوتشحأځۄتڔأڬۏأزشتڔأحڬأځۄىډأدتةەأحًأحوأۏۄتڽأضەأىڬهأدتىتأۗأتوأسشألشوتحۏأۄۏڽأ=أدثأؼوتشحأځۄتڔأڬۏأزشتڔأحڬأځۄىډأڲةۏأتًشأتضأضەأإڲەأحدتًصأڬشأڲةۏأحًأًۄأۏۄتڽأضەأطتوأڬۏأدتىثأډهەأڲةەأۗأتضأڬەأثؼزأځًشۏأولظهأذزۏخأثۏتىأڬۏأۗ
أۏۄأذزۏخأتوتوأثرتشۏأشذوۆأتههۄأؼهۏۄأتًشأتوتوأوضهوأشذوۆأتههۄأؼهۏۄأڬەأوؼۏتشأڬەأوغتثمأظذۏذأۄەأهۏڬىأتىۄًڽأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗأتضأثتثأوۏڽأولضشأذزۏخأًۄأۄەأدًأتؼوطأىەأتثًًتةهأڬەأذًتهەأضەأذشتوأثىأدىزهأؽلتشۏأضەأشًتۏحأڬۏأۄەأ؏أوۏڽأىەأتضأڬًأغًتهحأتًشأثؼعأ+أؽۏشأوضحىزأ,"أتهلتػأڬۏأًدۄأضەأډہًڔأزۏتأۄەأتًشأظشلأظذۏذۏىأڬۏأتضىتزًڽأځشأۄۏأتڬحلتأڬۏتأۄەأۗ%أ"""
5469,أرهۏلۄأثىأرۏتغألشوتحەأۄۏڽأ=أذعشحأتثًسشأشعۏأتههۄأؼىۄأ65أۄدشۏأڬًأشثسۄأوۏڽألًحأۄًةەأ؏أذعشحأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄأىەأتىأڬۏأىوتصأدىتصۄأځڔہتةۏأ؏أتضۏأشًتۏحأوۏڽأۏۄأثہۏأۄەأڬۄأذعشحأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄأڬۏأًۄۏڽأًلتحأۄًةۏأۗأتًشأذعشحأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄأڬتأذعشحأتثًسشأڬەأدىتصۄأڬۏأىوتصأځڔہتىتأڬًةۏأثؼۏزأىۄۏڽأۄەأڬۏًىڬۄأتۏڬأزًضشۏأتضىتزأڬەأۄوشتۄأوىمًهأۄەأڬۄأإځأڬًلۄأًتهًڽأڬەأتضأمتلهەأڬەأۄوشتۄأحہەأدىۄًڽأىەأذعشحأتثًسشأشعۏأتههۄأؼىۄأڬۏأىوتصأدىتصۄأځڔہۏأحہۏأۗأ
5470,"%أذعشحأتوأسشأشعۏأتههۄأؼىۄتألشوتحۏأۄۏڽأ=أدثأذعشحأتثًسشأشعۏأتههۄأؼىۄأڬۏأًلتحأڬتأًمحأمشۏثأإۏتأحًأوۏڽأشًأځڔۏأ؏أتىۄًڽأىەأودہأضەأشًىەأڬۏأًدۄأزشۏتلحأڬۏأ؏أوۏڽأىەأڬۄتأ=أوۏڽأڬۏًڽأىۄأشًاڽأ؏أحوأتۏڬأدىڲأثۏتثتىأوۏڽألًحأۄًأشۄەأۄًأ؏أتىأذتهتحأوۏڽأإځأڬەأتًشأوۏشەأځتضأتحىتأڬځڔتأثہۏأىۄۏڽأۄەأدضأضەأوۏڽأحوۄۏڽأڬلىأزەأضڬًڽأ؏أتًشأحوۄتشۏأوۏحأڬەأهةەأڬلىأحًأعشًشۏأۄەأۗأتىۄًڽأىەأڬۄتأ=أحوأرًطأۄًأدتاأ؏أتًشأشًىتأزہًىتأثىزأڬشًأ؏أڬۏًڽڬۄأوۏڽأىەأشضًهأتههۄأ﷽أڬًأۏۄألشوتحەأضىتأۄەأڬۄأدىأوضهوتىأوتڽأثتځأڬەأزًأۏتأحۏىأثډەألًحأۄًأدتةۏڽأًۄأڬثہۏأزًصرأوۏڽأىۄۏڽأدتةۏڽأڲەأۗأتًشأوۏڽأىەأشضًهأتههۄأ﷽أڬًأڬډہأهًڲًڽأڬەأثتشەأوۏڽأ+أتىأهًڲًڽأوۏڽأ؏أوۏڽأثہۏأوًدًزأحہتأ,أۏۄألشوتحەأۄًةەأضىتأۄەأڬۄأحوأوۏڽأضەأتۏڬأإزوۏأدىڲهأثۏتثتىأوۏڽألًحأۄًأڲتأتًشأتضأڬەأځتضأوضهوتىًڽأڬۏأتۏڬأدوتؼحأځۄىډەأڲۏأۗأًۄأحوتوأهًڲأإثتزۏًڽأوۏڽأتًشألًحأۄًةەأۄۏڽأ؏أتثأظشلأوۏڽأۄۏأثتمۏأثډتأۄًڽأ؏أتضأهةەأًۄأطرظأوۏڽأۄۏأۄًڽأ؏أرزتأڬۏأمضوأ$أىۄأحًأوۏڽأىەأۏۄأثتحأدہًټأڬۄۏأۄەأتًشأىۄأۄۏأۏۄأدہًټأۄًأڲتأ؏أتضأهةەأحوأشتضحۄأڬًأحڬحۏأشۄًأ؏أوۏڽأىەأڬۄتأ=أتثأمتلهۄأڬۄتڽأضەأإةەأڲتأآأذتدۏأدتأډڬەأۄۏڽأۗأشتضحەأثىزأۄًأډڬەأۄۏڽأۗأتىۄًڽأىەأځہشأۏۄۏأڬۄتأڬۄأدتاأتًشأزۏڬہًأ؏أوۏڽأتۏڬأټۏهەأځشأدتأڬشأزًشأزًشأحڬأىػشأزًڔتحۏأ؏أځہشأًتځضأإأڬشأتىأڬًأزۏڬہحۏأ؏أوۏڽأتضۏأڬطوڬطأوۏڽأحہۏأڬۄأتډتىڬأڬډہأهًڲأضًتشۏًڽأځشأضًتشأتځىەأصتزشتۄأضوۏحأًۄتڽأځشأإأڲةەأۗ أؼهۏأڬۄحەأۄۏڽأ=أوۏڽأىەأۏذۏۏأثىأوؼۏىأضەأځًډہتأڬۄأتضأشًتۏحأوۏڽأهلػأ““أحدزأ‛‛أزتهأڬەأضتحہأۄەأۏتأ““أحرثأ‛‛أرأتًشأثأڬەأضتحہأۄەأآأتىۄًڽأىەأڬۄتأ=““أحدزأ‛‛أزتهأڬەأضتحہأۄەأۗ"
أوۏڽأىەأتځىەأڬځڔەأڬەأضتحہأتطتشۄأڬۏتأحًأًۄأهًڲأدهزۏأضەأوۏشەأځتضأإأڲةەأ؏أتًشأځًډہىەأهڲەأڬۄأۏۄأڬًىأۄەأآأوۏڽأىەأڬۄتأ=أتثًسشأشعۏأتههۄأؼىۄأۗأتىۄًڽأىەأڬۄتأ=أظذتثۏأشضًهأآأوۏڽأىەأڬۄتأ=أدۏأۄتڽأۗأًۄأۏۄأڬۄحەأۄًةەأڬۄأۄوتشەأوتڽأثتځأإځأځشأمشثتىأۄًأدتةۏڽأتىأڬەأځتضأإىتأطشًؼأۄًأڲةەأۗأذعشحأتثًسشأشعۏأتههۄأؼىۄأىەأتىأڬًأڬۄتأ=أحوۄۏڽأرًطرثشۏأۄًأڬۄأوۏڽأىەأشضًهأتههۄأ﷽أڬًأتۏڬأدوتؼحأ+أدضأوۏڽأ؏أوۏڽأثہۏأوًدًزأحہتأ,أڬەأثتشەأۏۄألشوتحەأۄًةەأضىتأۄەأڬۄأحوأوۏڽأضەأتۏڬأطرظأدىڲهأثۏتثتىأوۏڽألًحأۄًأڲتأتًشأتۏڬأوضهوتىأدوتؼحأتضأڬەأځتضأإةەأڲۏأ؏أتضأدوتؼحأڬەأحوتوأهًڲأإثتزۏًڽأوۏڽألًحأۄًأډڬەأۄۏڽأ+أتثأظشلأوۏڽأۄۏأثتمۏأثډتأۄًڽأ
5471,%أوظؼثأثىأؼثزتههۄأصثۏشۏأىەأتىأڬتأىضثأۏًڽأثۏتىأڬۏتأۄەأ““أذثۏثأثىأوضهوۄأثىأوتهڬأتهتڬثشأثىأًۄثأثىأخؼهثۄأثىأًتةهۄأثىأؼوشًأثىأطۏثتىأثىأوذتشثأثىألۄشأ‛‛أۏۄأطشۏلأإزوۏأحہەأتىۄًڽأىەأشضًهأتههۄأ﷽أڬۏأتذتزۏخأضىۏأۄۏڽأۗأۏۄأتڬخشأشًوأدتۏتأڬشحەأحہەأدضأڬۏأًدۄأضەأتىأڬًأذثۏثأتهشًوأڬۄتأدتحتأحہتأۗأتىأڬەأثتشەأوۏڽأطشۏذأثىأذتشخأىەأڬۄتأ= أرثشزتشأ$أۄشأًۄأطرظأدضأڬًأذثۏثأڬەأىتوأضەأځڬتشتأدتحتأۄەأتڲشډۄأتضأڬۏأوشًحأػتۄشأۄًأډڬۏأۄەأځہشأثہۏأًۄأذثۏثأثىألۄشأځشألزتأۄًحتأۄەأۗ أًۄأتۏضتأشتۄىوتأۄەأڬۄأدوتؼحأڬًأډهتحتأۄەأڲًۏتأڬۄأًۄأڬىڬشۏًڽأڬًأڬًةهًڽأڬۏأغشذأهحتڔحۏأۄۏڽأدضأضەأًۄأځًشۏأغشذأټًټحۏأثہۏأىۄۏڽأۄۏڽأۗ%أ
5472,%أؼغۏۄأثىأمۏضأتًشأشتطزأثىأضؼزألشوتحەأۄۏڽأ=أشًوأذثۏثأثىأوضهوۄأڬۏأدتىثأشًتىۄأۄًتأ؏أًۄأتضأًمحأإشوۏىۏۄأوۏڽأحہەأتضأىەأذعشحأوؼتًۏۄأڬۏأدتىثأرغأهڬہأڬشأتىأضەأتوزتزأغهثأڬۏأ؏أذعشحأوؼتًۏۄأشعۏأتههۄأؼىۄأىەأذعشحأؼخوتىأشعۏأتههۄأؼىۄأڬەأسوۄأهڲتأزۏتأ؏أتىۄًڽأىەأؼشتمأڬەأڲًشىشأڬًأرغأهڬہأزۏتأڬۄأذثۏثأڬۏأوززأڬۏأدتةەأۗأډىتىډۄأتۄهأؼشتمأڬەأضتحہأتىأڬۏأوززأڬشأزۏأڲةۏأتًشأضهوتىأثىأشثۏؼۄأڬًأتىأڬتأضځۄأضتهتشأثىتأزۏتأڲۏتأ؏أۏۄأهطڬشأذثۏثأڬۏأوززأڬەأهۏەأشًتىۄأۄًأڲۏتأۗأۏۄأهًڲأتىأحڬأحًأىۄۏڽأځۄىډأځتةەأحہەأثهڬۄأشتضحۄأوۏڽأۄۏأزطوىأڬەأضتحہأتىأڬۏأوڋثہۏڔأۄًأڲةۏأ؏أتههۄأحؼتهۏٳأىەأتىأڬًألحذأضەأۄوڬىتشأڬۏتأۗأدثأضهوتىأتًشأتضأڬەأضتحہۏأذثۏثأڬەأځتضأإةەأحًأتىۄًڽأىەأوغتهثۄأڬۏتأڬۄأتىأڬًأثہۏأوتهأؽىۏوحأضەأذظۄأزۏتأدتةەأۗأتىأڬتأوًملأۏۄأحہتأڬۄأۄوأىەأحوۄتشۏأوززأڬۏأۄەأۗأدثڬۄأتۄهأطتوأڬتأڬۄىتأحہتأڬۄأحوأهًڲأدىڲأوۏڽأطشۏڬأۄۏأىۄۏڽأۄًةەأۄًأ؏أتضأهةەأۄوتشەأتوًتهأوۏڽأحوۄتشتأڬًةۏأذمأىۄۏڽأۄەأۗأذثۏثأىەأتىأڬًأوتهأؽىۏوحأوۏڽأطشۏڬأڬشىەأضەأتىڬتشأڬشأزۏتأۗأتًشأتىۄًڽأىەأتځىەأۄۏأضتحہۏًڽأوۏڽأوتهأحمضۏوأڬشأهۏتأۗأتضأځشأتۄهأطتوأتًشأتۄهأؼشتمأوۏڽأترحهتلتحأځۏزتأۄًأڲةەأترحهتلتحأتضأمزشأطزحأترحۏتشأڬشأڲةەأڬۄأمشۏثأحہتأڬۄأتىأوۏڽأثتۄوأدىڲأطشًؼأۄًأدتحۏأ؏أتۏڬأؼشتمۏأىەأڬۄتأ= أتڲشأحوأىەأضهوتىأڬًأمحهأڬۏتأحًأۄوأحوۄتشەأذثۏثأڬًأمحهأڬشأزۏڽأڲەأتًشأتڲشأحوأتثىأؼلتىأڬۏأغشلأشًتىۄأۄًأڲەأحًأۄوأثہۏأتزہشأشًتىۄأۄًأدتةۏڽأڲەأۗ أتثًثڬشأؽضتىۏأڬۄحەأۄۏڽأ=أوۏڽأىەأضىتأۄەأڬۄأتۄهأؼشتمأتًشأتۄهأطتوأڬەأوتثۏىأۏۄأضثأضەأځۄهۏأزطوىۏأحہۏأۗ%أ
5473,أتذوزأثىأصۄۏشأثىأذشثأتځىەأًتهزأڬتأۏۄأثۏتىأىمهأڬشحەأۄۏڽأڬۄأذثۏثأثىأوضهوۄأشعۏأتههۄأؼىۄأڬۏأڬىۏحأ““أتثًؼثزتهشذوىأ‛‛أحہۏأۗأ
5474,"أذعشحأذثۏثأثىأوضهوۄأشعۏأههۄأؼىۄألشوتحەأۄۏڽأ=أوۏڽأىەأىثۏأتڬشوأ﷽أڬەأۄوشتۄأؽصًتحأوۏڽأطشڬحأڬۏأ؏أ+أڬةۏأوشحثۄأ,أإځأىەأحۏضشتأذظۄأؽىۏوحأڬەأغًأځشأؼغتألشوتۏتأۗأ"
5475,أؼتوشأثىأؼثزتههۄأثىأۏذۏۏأثۏتىأڬشحەأۄۏڽأڬۄأذعشحأتثًسشأؽلتشۏأشعۏأتههۄأؼىۄأتًشأثۄحأضتشەأهًڲأذعشحأذثۏثأثىأوضهوۄأشعۏأتههۄأؼىۄأڬًأذثۏثأتهشًوأڬۄتأڬشحەأحہەأڬۏًىڬۄأتىۄًڽأىەأشًوأڬەأضتحہأدىڲًڽأوۏڽأثۄحأڬخشحأضەأطشڬحأڬۏأۄەأۗأ
5476,أۏذۏۏأثىأثڬۏشألشوتحەأۄۏڽأ=أذعشحأذثۏثأثىأوضهوۄأشعۏأتههۄأؼىۄأځډتضأضتهأڬۏأؼوشأوۏڽأضىأ75أۄدشۏأوۏڽأتشوۏىۏۄأوۏڽألًحأۄًةەأۗأ
5477,أذعشحأذثۏثأثىأوضهوۄأشعۏأتههۄأؼىۄألشوتحۏۄۏڽأڬۄأشضًهأتههۄأ﷽أىەأتشطتزألشوتۏتأ=أزۏشأثؼزأوهتڬشًأ؏أتضأضەأوذثحأثڔہحۏأۄەأۗأ
5478,"أذعشحأذثۏثأثىأوضهوۄأشعۏأتههۄأؼىۄأوضحدتثأتهزؼًتحأۄۏڽأ؏أ+أشتًۏأ,ألشوتحەأۄۏڽأ=أتىأڬًأتۏڬأهطڬشأڬتأضځۄأضتهتشأثىتأزۏتأڲۏتأ؏أتىۄًڽأىەأدىڲأڬۏأحۏتشۏأوڬوهأڬشأهۏأتًشأدثأزطوىأضەأومتثهۄأڬتأًمحأإۏتأحًألشوتۏتأ=أوۏڽأىەأشضًهأتههۄأ﷽أڬًأۏۄألشوتحەأۄًةەأضىتأۄەأڬۄأ““أدثأزطوىأضەأوڋثہۏڔأۄًأدتةەأتضأًمحأڬډہأهًڲأزؼتأوتىڲۏڽأ؏أثتمۏأإوۏىأڬۄۏڽأحًأتههۄأحؼتهۏٳأتىأڬۏأزؼتأڬًأمثًهأڬشحتأۄەأ‛‛أتضأڬەأثؼزأتىۄًڽأىەأتههۄأحؼتهۏٳأڬۏأذوزأًأخىتؤأڬۏأتًشأۏًڽأزؼتأوتىڲۏأ““أتەأتههۄأ$أۄوتشەأرًىًڽأڬۏأذلتغحألشوتأ؏أۄوۏڽأطۄۏزًڽأڬتأضتأتدشأًأخًتثأؼغتألشوتأ؏أڬډہأۄۏأزۏشأوۏڽأزطوىأڬۏألًدأڬتأضځۄأضتهتشأًۄتڽأإأځۄىډتأتًشأذثۏثأڬەأرۏوەأوۏڽأڲہضأڲۏتأۗأ"
5479,أتثىأتضذتمأڬۄحەأۄۏڽأ=أثىۏأصۄشۄأتًشأتىأڬەأرهلتؤأوۏڽأضەأشضًهأتههۄأ﷽أڬەأۄوشتۄأدىڲأثزشأوۏڽأطشۏڬأۄًىەأًتهًڽأوۏڽأ““أومزتزأثىأؼوشًأثىأخؼهثۄأثىأوتهڬأثىأصوؼۄأثىأخوتوۄأثىأوغشًزأثىأؼوشًأثىأشثۏؼۄأثىأصۄۏشأثىأىوشأثىأخؼهثۄأثىأوتهڬأ‛‛أثہۏأۄۏڽأۗأ
5480,أؼشًۄأضەأوشًۏأۄەأڬۄأثىۏأصۄشۄأتًشأتىأڬەأذهۏلًڽأوۏڽأضەأدىڲأثزشأوۏڽأشضًهأتههۄأ﷽أڬەأۄوشتۄأطشۏڬأۄًىەأًتهًڽأوۏڽأ““أذعشحأومزتزأثىأؼوشًأ‛‛أۄۏڽأۗأ
5481,أتثىأتضذتمأڬۄحەأۄۏڽأ=أذعشحأومزتزأشعۏأتههۄأؼىۄأڬًأتضًزأثىأؼثزأۏؽًخأثىأًۄثأثىأؼثزأوىتلأثىأصۄشۄأڬۏأدتىثأوىضًثأڬۏتأدتحتأۄەأذتهتىڬۄأتضًزأثىأؼثزأۏؽًخأىەأتىأڬًأتځىتأوىۄأثًهتأثۏټتأثىتۏتأحہتأۗأتًشأۏۄأثہۏأڬۄتأدتحتأۄەأڬۄأتضًزأثىأتثۏأمۏضأثىأؼثزأوىتلأڬۏأدتىثأوىضًثأڬۏتأدتحتأۄەأۗأ
5482,أضؼۏزأثىأؼلۏشألشوتحەأۄۏڽأ=أصوتىۄأدتۄهۏحأوۏڽأ؏أوۏڽأومزتزأثىأتضًزأڬتأزًضحأۄًحتأحہتأ؏أتىأضەأتۏڬأمحهأۄًأڲۏتأحہتأتضأهةەأۏۄأومتوأڬىزۄأڬۏأدتىثأثہتڲأڲةەأتًشأتىأهًڲًڽأڬەأذهۏلأثىأڲةەأ؏أځہشأًۄتڽأثہۏأتىأضەأمحهأۄًأڲۏتأحًأۏۄأوڬۄأڬۏأدتىثأثہتڲأڲةەأتًشأۏۄتڽأتضًزأثىأؼثزأۏؽًخأڬەأذهۏلأثىەأ؏أتضۏأًدۄأضەأتىأڬًأتضًزأڬۏأدتىثأوىضًثأڬۏتأدتحتأۄەأۗأ
5483,"أوذوزأثىأؼثزتههۄأثىأىوۏشألشوتحەأۄۏڽأ=أومزتزأثىأتضًزأشعۏأتههۄأؼىۄأڬۏأڬىۏحأ““أتثًوؼثزأ‛‛أحہۏأ؏أتىأڬتأتىحمتهأضحشأضتهأڬۏأؼوشأوۏڽأضىأحۏضأۄدشۏأڬًأۄًتأۗأإځأزتڔہۏأځشأصشزأرعتثأهڲتۏتأڬشحەأحہەأۗأتىأڬتأتىحمتهأومتوأدشلأ+أدًأڬۄأوزۏىۄأوىًشۄأضەأحۏىأوۏهأڬەألتظهەأځشأۄەأ,أځشأۄًتأ؏أهًڲأتىأڬًأتځىەأڬىزہًڽأځشأتټہتأڬشأوزۏىۄأطشۏلأهتةەأ؏أذعشحأؼخوتىأثىأؼلتىأشعۏأتههۄأؼىۄأىەأتىأڬۏأىوتصأدىتصۄأځڔہتةۏأ؏أتًشأتىأڬًأدىحأتهثمۏؼأوۏڽأزلىأڬۏتأڲۏتأۗأ"
5484,%أوذوزأثىأؼوشأىەأتىأڬتأىضثأثۏتىأڬشحەأۄًةەأ““أومزتزأثىأؼوشًأثىأخؼهثۄأثىأوتهڬأثىأشثۏؼۄأ‛‛أضەأمعتؼۄأحڬأسڬشأڬۏتأۗأتىأڬۏأڬىۏحأتثًوؼثزأحہۏأ؏أۏۄأدتۄهۏحأوۏڽأتضًزأثىأؼثزأۏؽًخأصۄشۏأڬەأذهۏلأحہەأ؏أتضًزأىەأتىأڬًأوىۄأثًهتأثۏټتأثىتۏتأۄًتأحہتأ؏أتضأهةەأتىأڬًأتضًزأڬۏأدتىثأوىضًثأڬۏتأدتحتأحہتأۗأتًشأتىأڬًأ““أومزتزأثىأتضًزأ‛‛أڬۄتأدتحتأحہتأۗأدثأمشإىأڬشۏوأڬۏأۏۄأإۏتحأىتصهأۄًةۏأۗ
أ®تْزٕؼًْٕہْوأهٓإثإةٓہٓوٕأ+أتهتذصتثأ=أ8أ,"¾أ““أتىۄۏڽأتىأڬەأثتځأۄۏأڬتأڬۄۄأڬشأځڬتشًأ‛‛ۗأ+أحشدوۄأڬىصتهتۏوتىأ؏أتوتوأتذوزأشعتأ أحًأتضأڬەأثؼزأتىأڬًأ““أومزتزأثىأؼوشًأ‛‛أڬۄتأدتىەأهڲتأذعشحأومزتزأشعۏأتههۄأؼىۄأىەأذعشحأذثطۄأزًوأوۏڽأطشڬحأڬۏأحہۏأتًشأتثىأتضذتمأڬۏأشًتۏحأڬەأوغتثمأذعشحأومزتزأشعۏأتههۄأؼىۄأدىڲأثزشأ؏أدىڲأتذزأ؏أرىزمأتًشأحوتوأؽصًتحأوۏڽأشضًهأتههۄأ﷽أڬەأۄوشتۄأطشۏڬأۄًةەأۗ أتثىأؼوشألشوتحەأۄۏڽأ=أوًضۏٳأثىأۏؼمًثأڬۏأځہًځہۏأڬشۏوۄأثىحأومزتزأتىأڬًأتىأڬەأًتهزأڬەأثتشەأوۏڽأثحتۏتأڬشحۏأحہۏأڬۄأتىأڬتأمزأهوثتأحہتأ؏أشىڲأڲىزوأڲًڽأحہتأ؏أځۏټأوًټتأحہتأ؏أضشأڬەأثتهأڲہىەأحہەأ؏أًۄأتځىۏأزتڔہۏأڬًأوۄىزۏأهڲتۏتأڬشحەأحہەأ؏أتىأڬۏأزتڔہۏأثۄحأرًثظًشحأحہۏأىۄأثۄحأصۏتزۄأڲہىۏأحہۏأتًشأىۄأثتهڬهأۄهڬۏأحہۏأ؏أتىأڬۏأثہىًۏڽأوهۏأۄًةۏأحہۏڽأ؏أطشوأًأذۏتؤأڬەأځۏڬشأحہەأ؏أتىأڬۏأځہًځہۏألشوتحۏأۄۏڽأ=أذعشحأومزتزأومتوأدشلأوۏڽألًحأۄًةەأۏۄأومتوأوزۏىۄأوىًشۄأضەأحمشۏثتَأحۏىأوۏهأڬەألتظهەأځشأۄەأۗأهًڲأتىأڬتأدىتصۄأتټہتأڬشأوزۏىۄأطشۏلأهتةەأتًشأۏۄۏڽأځشأتىأڬًأزلىأڬۏتأڲۏتأۗأذعشحأؼخوتىأثىأؼلتىأشعۏأتههۄأؼىۄأىەأتىأڬۏأىوتصأدىتصۄأځڔہتةۏأ؏أۏۄأضىأ66أۄدشۏأڬۏأثتحأۄەأ؏أًلتحأڬەأًمحأذعشحأومزتزأشعۏأتههۄأؼىۄأڬۏأؼوشأحمشۏثتَأضحشأثشضأحہۏأۗ%أ"""
5485,أذعشحأضؼزأثىأتثشتۄۏوألشوتحەأۄۏڽأ=أذعشحأومزتزأثىأتضًزأشعۏأتههۄأؼىۄأوڬۄأحطشۏلأهتةەأتًشألشوتۏتأ=أوۏڽأوڬۄأڬەأضثأضەأصۏتزۄأثتؼصحأطرظأڬتأذهۏلأثىًڽأڲتأۗأډىتىډۄأإځأتضًزأثىأؼثزأۏؽًخأڬەأذهۏلأثىەأۗأتىأڬًأومزتزأثىأتضًزأڬۄتأدتحتأۄەأ؏أذتهتىڬۄأًۄأومزتزأثىأؼوشًأثۄشتًۏأۄۏڽأ؏أۏۄأتضًزأڬىزۏأڬەأثۏټەأىۄۏڽأۄۏڽأۗأ
5486,%أذعشحأؼثزتههۄألشوتحەأۄۏڽأ=أوۏڽأذعشحأومزتزأڬۏأدڲۄأتۏڬأدىڲأوۏڽأطشۏڬأۄًتأ؏أتضأڬەأثزهەأوۏڽأوتهأؽىۏوحأهۏىەأڬۏأثدتةەأودہەأۏۄأثتحأصۏتزۄأؼصۏصأۄەأڬۄأوۏڽأومزتزأڬتأضتحہۏأثىًڽأ؏أڬۏًىڬۄأتۏڬأوشحثۄأًۄأشضًهأتههۄأ﷽أڬۏأثتشڲتۄأوۏڽأإةەأ؏أتضأًمحأىثۏأتڬشوأ﷽أوطشڬًڽأڬەأرهتلأزؼتأڬشأشۄەأحہەأحًأتىۄًڽأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ﷽أرزتأڬۏأمضوأ$أۄوأوًضۏٳأؼهۏۄأتهضهتوأڬۏأمًوأڬۏأغشذأإځأڬًأۏۄأىۄۏڽأڬۄۏڽأڲەأڬۄأتەأوًضۏٳأإځأتًشأإځأڬتأشثأدتأڬشأهڔۏڽأۄوأحًأۏۄتڽأثۏټہەأۄۏڽأۗأثهڬۄأۄوأحًأإځأڬەأزتةۏڽأثتةۏڽأتًشأإڲەأځۏډہەأإځأځشأتځىۏأدتىأىډہتًشأڬشۏڽأڲەأ؏أوۏڽأىەأزۏڬہتأڬۄأۏۄأثتحأضىأڬشأشضًهأتههۄأ﷽أڬتأډۄشۄأتىًشأډوڬأتټہتأتًشأإځأ﷽أثۄحأرًطأۄًةەأۗ أٰٰأۏۄأذزۏخأظذۏذأتهتضىتزأۄەأهۏڬىأتوتوأثرتشۏأشذوۆأتههۄأؼهۏۄأتًشأتوتوأوضهوأشذوۆأتههۄأؼهۏۄأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗ%أ
5487,"%أتثًشتطزأذشتىۏألشوتحەأۄۏڽأ=أوۏڽأىەأشضًهأتههۄأ﷽أڬەأوذتلػأذعشحأومزتزأثىأتضًزأشعۏأتههۄأؼىۄأڬًأزۏڬہتأًۄأومتوأذوظأوۏڽأتۏڬأحدتشحۏأحتثًحأځشأثۏټہەأۄًةەأحہەأثڔہتځەأڬۏأًدۄأضەأحتثًحأځشأضًتشأۄًأڲةەأتًشأدۄتزأوۏڽأطشڬحأڬتأتشتزۄأڬةەأۄًةەأحہەأۗأوۏڽأىەأتىأضەأڬۄتأ=أتههۄأحؼتهۏٳأىەأإځأڬەأثڔہتځەأڬۏأًدۄأضەأإځأڬەأؼسشأڬًأمثًهأڬۏتأۄەأ+أإځأځہشأڬۏًڽأدۄتزأځشأدتأشۄەأۄۏڽأآأ,أتىۄًڽأىەأدًتثتَأڬۄتأ=أضًشۆأحًثۄأڬۏأتضأإۏحأىەأودہەأدۄتزأځشأىڬهىەأځشأودثًشأڬشأزۏتأۄەأۗ"
