metadata:

hadiths[20]{hadithnumber,arabic,bengali,english,french,indonesian,russian,urdu,grades,reference,international_number,narrator_chain,chapter_intro}:
{"hadithnumber": "4212", "arabic": "أَخْبَرَنَا عَمْرُو بْنُ عَلِيٍّ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا يَحْيَى، ‏‏‏‏‏‏عَنْ سُفْيَانَ، ‏‏‏‏‏‏ع", "bengali": "", "english": "It was narrated from 'Amr bin Shuaib, from his fahther, that his grandfather said:\"The messenger of Allah was asked about the 'Aqiqah and he said: \"Allah, the mighty and sublime, does not like Al-Uquq' as if he disliked the word (Al-Aqiqah). He said to the Messenger of Allah: 'But one of us may offer a sacrifice when a child is born to him.' He said: 'Whoever wants to offer a sacrifice for his child, let him do so, for a boy; two sheep, Mukafaatan, (of equal age), and for a girl, one.' (One of the narrators) Dawud said: 'I asked Ziad bin Aslam about the word Mukafaatan and he said: 'Two similar sheep that are slaughtered together", "french": "", "indonesian": "", "russian": "", "urdu": "کعب بن عجرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ہمارے پاس آئے، ہم نو لوگ تھے، آپ", "grades": "{'name': 'Abu Ghuddah', 'grade': 'Hasan Sahih'},{'name': 'Al-Albani', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 40, Hadith 1", "international_number": "4212", "narrator_chain": "", "chapter_intro": "The Book of al-'Aqiqah"}
{"hadithnumber": "4213", "arabic": "أَخْبَرَنَا هَارُونُ بْنُ إِسْحَاق، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا مُحَمَّدٌ يَعْنِي ابْنَ عَبْدِ الْوَ", "bengali": "", "english": "It was narrated from 'Abdullah bin Buraidah, from his father, that:the Messenger of Allah offered the 'Aqiqah for Al-Hasan and Al-Husain", "french": "", "indonesian": "", "russian": "", "urdu": "کعب بن عجرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ہمارے پاس آئے، ہم نو لوگ تھے، پان", "grades": "{'name': 'Abu Ghuddah', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 40, Hadith 2", "international_number": "4213", "narrator_chain": "", "chapter_intro": "The Book of al-'Aqiqah"}
{"hadithnumber": "4214", "arabic": "أَخْبَرَنَا إِسْحَاق بْنُ مَنْصُورٍ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا عَبْدُ الرَّحْمَنِ، ‏‏‏‏‏‏عَنْ سُفْ", "bengali": "", "english": "It was narrated from Salman bin 'Amir Ad-Dabbi that the Messenger of Allah said:\"For a boy there shoud be an 'Aqiqah, so shed blood for him, and remove the harm from him", "french": "", "indonesian": "", "russian": "", "urdu": "طارق بن شہاب رضی اللہ عنہ ۱؎ کہتے ہیں کہ  ایک شخص نے نبی اکرم صلی اللہ علیہ وسلم سے سوال کیا اور وہ", "grades": "{'name': 'Abu Ghuddah', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 40, Hadith 3", "international_number": "4214", "narrator_chain": "", "chapter_intro": "The Book of al-'Aqiqah"}
{"hadithnumber": "4215", "arabic": "أخْبَرَنَا قُتَيْبَةُ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا سُفْيَانُ، ‏‏‏‏‏‏عَنِ الزُّهْرِيِّ، ‏‏‏‏‏‏عَنْ أَ", "bengali": "", "english": "it was narrated from Um Kurz that the Messenger of Allah said:\"for a boy two sheep, Mukafaatan (of equal age), and for a girl, one sheep", "french": "", "indonesian": "", "russian": "", "urdu": "عبادہ بن صامت رضی اللہ عنہ کہتے ہیں کہ  ہم ایک مجلس میں نبی اکرم صلی اللہ علیہ وسلم کے پاس تھے تو آپ", "grades": "{'name': 'Abu Ghuddah', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 40, Hadith 4", "international_number": "4215", "narrator_chain": "", "chapter_intro": "The Book of al-'Aqiqah"}
{"hadithnumber": "4216", "arabic": "أَخْبَرَنَا مُحَمَّدُ بْنُ آَدَمَ بْنِ سُلَيْمَانِ،‏‏‏‏ عَنِ ابْنِ الْمُبَارَكِ،‏‏‏‏ عَنِ ابْنِ أَبِ", "bengali": "", "english": "It was narrated from Umm Kurz that the Messenger of Allah said:\"For a boy two sheep, Mukafaatan (of equal age), and for a girl, one sheep", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”عنقریب تم لوگ امارت و سرد", "grades": "{'name': 'Abu Ghuddah', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 40, Hadith 5", "international_number": "4216", "narrator_chain": "", "chapter_intro": "The Book of al-'Aqiqah"}
{"hadithnumber": "4217", "arabic": "أَخْبَرَنَا أَحْمَدُ بْنُ سُلَيْمَانَ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا أَبُو نُعَيْمٍ، ‏‏‏‏‏‏قَالَ:‏‏‏‏", "bengali": "", "english": "It was narrated that umm Kurz said:\"I came to the Prophet and asked him about the sacrificial meat. I heard him say: 'For a boy, two sheep, and for a girl, one sheep, and it does not matter if they are male or female", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم سے عقیقہ کے سلسلے میں پوچھا", "grades": "{'name': 'Abu Ghuddah', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 40, Hadith 6", "international_number": "4217", "narrator_chain": "", "chapter_intro": "The Book of al-'Aqiqah"}
{"hadithnumber": "4218", "arabic": "أَخْبَرَنَا الْحُسَيْنُ بْنُ حُرَيْثٍ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا الْفَضْلُ، ‏‏‏‏‏‏عَنْ الْحُسَيْنِ", "bengali": "", "english": "It was narrated from Umma Kurz that the Messenger of Allah said:\"For a boy, two sheep, and or a girl, one sheep, and it does not matter if they are male or female", "french": "", "indonesian": "", "russian": "", "urdu": "بریدہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے حسن اور حسین رضی اللہ عنہما کی طر", "grades": "{'name': 'Abu Ghuddah', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 40, Hadith 7", "international_number": "4218", "narrator_chain": "", "chapter_intro": "The Book of al-'Aqiqah"}
{"hadithnumber": "4219", "arabic": "أَخْبَرَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا عَفَّانُ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّ", "bengali": "", "english": "It was narrated that Ibn 'Abbas said:\"The Messenger of Allah offered an 'Aqiqah for Al-Hasan and Al-Husain, may Allah be please with them, two rams for each", "french": "", "indonesian": "", "russian": "", "urdu": "سلمان بن عامر ضبی رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”لڑکے کی پیدا", "grades": "{'name': 'Abu Ghuddah', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 40, Hadith 8", "international_number": "4219", "narrator_chain": "", "chapter_intro": "The Book of al-'Aqiqah"}
{"hadithnumber": "4220", "arabic": "أَخْبَرَنَا أَحْمَدُ بْنُ سُلَيْمَانَ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا عَفَّانُ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّث", "bengali": "", "english": "It was narrated from Qatadah, from Al-Hasan, from Samurh bin Jundab that the Messenger of Allah said:\"Every boy is in pledge for his 'Aqiqah, so slaughter (the animal) for him on the seventh day, and shave his head, and a name", "french": "", "indonesian": "", "russian": "", "urdu": "ام کرز رضی اللہ عنہا سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ” ( عقیقہ کے لیے )  لڑک", "grades": "{'name': 'Abu Ghuddah', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Bukhari'}", "reference": "Book 40, Hadith 9", "international_number": "4220", "narrator_chain": "", "chapter_intro": "The Book of al-'Aqiqah"}
{"hadithnumber": "4221", "arabic": "أَخْبَرَنَا عُبَيْدُ اللَّهِ بْنُ سَعِيدٍ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا سُفْيَانُ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ ق", "bengali": "", "english": "It was narrated from Habib bin Ash-Shahid:\"Muhammad bin Sirin said to me: 'Ask Al-Hasan (Al-Basri) from whom he heard this Hadith about the 'Aqiqah.' I asked him about that and he said: 'I heard it from Samurh", "french": "", "indonesian": "", "russian": "", "urdu": "ام کرز رضی اللہ عنہا سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ” ( عقیقے کے لیے )  لڑک", "grades": "{'name': 'Abu Ghuddah', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Bukhari'}", "reference": "Book 40, Hadith 10", "international_number": "4221", "narrator_chain": "", "chapter_intro": "The Book of al-'Aqiqah"}
{"hadithnumber": "4222", "arabic": "أَخْبَرَنَا أَحْمَدُ بْنُ سُلَيْمَانَ، قَالَ حَدَّثَنَا أَبُو نُعَيْمٍ، قَالَ حَدَّثَنَا دَاوُدُ بْنُ قَيْسٍ، عَنْ عَمْرِو بْنِ شُعَيْبٍ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، قَالَ سُئِلَ رَسُولُ اللَّهِ صلى الله عليه وسلم عَنِ الْعَقِيقَةِ فَقَالَ ‏\"‏ لاَ يُحِبُّ اللَّهُ عَزَّ وَجَلَّ الْعُقُوقَ ‏\"‏ ‏.‏ وَكَأَنَّهُ كَرِهَ الاِسْمَ قَالَ لِرَسُولِ اللَّهِ صلى الله عليه وسلم إِنَّمَا نَسْأَلُكَ أَحَدُنَا يُولَدُ لَهُ ‏.‏ قَالَ ‏\"‏ مَنْ أَحَبَّ أَنْ يَنْسُكَ عَنْ وَلَدِهِ فَلْيَنْسُكْ عَنْهُ عَنِ الْغُلاَمِ شَاتَانِ مُكَافَأَتَانِ وَعَنِ الْجَارِيَةِ شَاةٌ ‏\"‏ ‏.‏ قَالَ دَاوُدُ سَأَلْتُ زَيْدَ بْنَ أَسْلَمَ عَنِ الْمُكَافَأَتَانِ قَالَ الشَّاتَانِ الْمُشَبَّهَتَانِ تُذْبَحَانِ جَمِيعًا ‏.‏", "bengali": "", "english": "\"The messenger of Allah was asked about the 'Aqiqah and he said: \"Allah, the mighty and sublime, does not like Al-Uquq' as if he disliked the word (Al-Aqiqah). He said to the Messenger of Allah: 'But one of us may offer a sacrifice when a child is born to him.' He said: 'Whoever wants to offer a sacrifice for his child, let him do so, for a boy; two sheep, Mukafaatan, (of equal age), and for a girl, one.' (One of the narrators) Dawud said: 'I asked Ziad bin Aslam about the word Mukafaatan and he said: 'Two similar sheep that are slaughtered together.", "french": "", "indonesian": "", "russian": "", "urdu": "ام کرز رضی اللہ عنہا کہتی ہیں کہ  میں حدیبیہ میں ہدی کے گوشت کے بارے میں پوچھنے کے لیے نبی اکرم صلی", "grades": "", "reference": "", "international_number": "4222", "narrator_chain": "It was narrated from 'Amr bin Shuaib, from his fahther, that his grandfather said:", "chapter_intro": "The Book of al-'Aqiqah"}
{"hadithnumber": "4223", "arabic": "أَخْبَرَنَا الْحُسَيْنُ بْنُ حُرَيْثٍ، قَالَ حَدَّثَنَا الْفَضْلُ، عَنِ الْحُسَيْنِ بْنِ وَاقِدٍ، عَنْ عَبْدِ اللَّهِ بْنِ بُرَيْدَةَ، عَنْ أَبِيهِ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم عَقَّ عَنِ الْحَسَنِ وَالْحُسَيْنِ ‏.‏", "bengali": "", "english": "the Messenger of Allah offered the 'Aqiqah for Al-Hasan and Al-Husain.", "french": "", "indonesian": "", "russian": "", "urdu": "ام کرز رضی اللہ عنہا سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”لڑکے کی طرف سے دو بکری", "grades": "", "reference": "", "international_number": "4223", "narrator_chain": "It was narrated from 'Abdullah bin Buraidah, from his father, that:", "chapter_intro": "The Book of al-'Aqiqah"}
{"hadithnumber": "4224", "arabic": "أَخْبَرَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، قَالَ حَدَّثَنَا عَفَّانُ، قَالَ حَدَّثَنَا حَمَّادُ بْنُ سَلَمَةَ، قَالَ حَدَّثَنَا أَيُّوبُ، وَحَبِيبٌ، وَيُونُسُ، وَقَتَادَةُ، عَنْ مُحَمَّدِ بْنِ سِيرِينَ، عَنْ سَلْمَانَ بْنِ عَامِرٍ الضَّبِّيِّ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ فِي الْغُلاَمِ عَقِيقَةٌ فَأَهْرِيقُوا عَنْهُ دَمًا وَأَمِيطُوا عَنْهُ الأَذَى ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"For a boy there shoud be an 'Aqiqah, so shed blood for him, and remove the harm from him.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Salman bin 'Amir Ad-Dabbi that the Messenger of Allah said:", "chapter_intro": "The Book of al-'Aqiqah"}
{"hadithnumber": "4225", "arabic": "أَخْبَرَنَا أَحْمَدُ بْنُ سُلَيْمَانَ، قَالَ حَدَّثَنَا عَفَّانُ، قَالَ حَدَّثَنَا حَمَّادٌ، عَنْ قَيْسِ بْنِ سَعْدٍ، عَنْ عَطَاءٍ، وَطَاوُسٍ، وَمُجَاهِدٍ، عَنْ أُمِّ كُرْزٍ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ فِي الْغُلاَمِ شَاتَانِ مُكَافَأَتَانِ وَفِي الْجَارِيَةِ شَاةٌ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"for a boy two sheep, Mukafaatan (of equal age), and for a girl, one sheep.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "it was narrated from Um Kurz that the Messenger of Allah said:", "chapter_intro": "The Book of al-'Aqiqah"}
{"hadithnumber": "4226", "arabic": "أَخْبَرَنَا عُبَيْدُ اللَّهِ بْنُ سَعِيدٍ، قَالَ حَدَّثَنَا سُفْيَانُ، قَالَ قَالَ عَمْرٌو عَنْ عَطَاءٍ، عَنْ حَبِيبَةَ بِنْتِ مَيْسَرَةَ، عَنْ أُمِّ كُرْزٍ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ عَنِ الْغُلاَمِ شَاتَانِ مُكَافَأَتَانِ وَعَنِ الْجَارِيَةِ شَاةٌ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"For a boy two sheep, Mukafaatan (of equal age), and for a girl, one sheep,", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Umm Kurz that the Messenger of Allah said:", "chapter_intro": "The Book of al-'Aqiqah"}
{"hadithnumber": "4227", "arabic": "أَخْبَرَنَا قُتَيْبَةُ، قَالَ حَدَّثَنَا سُفْيَانُ، عَنْ عُبَيْدِ اللَّهِ، - وَهُوَ ابْنُ أَبِي يَزِيدَ - عَنْ سِبَاعِ بْنِ ثَابِتٍ، عَنْ أُمِّ كُرْزٍ، قَالَتْ أَتَيْتُ النَّبِيَّ صلى الله عليه وسلم بِالْحُدَيْبِيَةِ أَسْأَلُهُ عَنْ لُحُومِ الْهَدْىِ فَسَمِعْتُهُ يَقُولُ ‏ ‏ عَلَى الْغُلاَمِ شَاتَانِ وَعَلَى الْجَارِيَةِ شَاةٌ لاَ يَضُرُّكُمْ ذُكْرَانًا كُنَّ أَمْ إِنَاثًا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"I came to the Prophet and asked him about the sacrificial meat. I heard him say: 'For a boy, two sheep, and for a girl, one sheep, and it does not matter if they are male or female.\"'", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that umm Kurz said:", "chapter_intro": "The Book of al-'Aqiqah"}
{"hadithnumber": "4228", "arabic": "أَخْبَرَنَا عَمْرُو بْنُ عَلِيٍّ، قَالَ حَدَّثَنَا يَحْيَى، قَالَ حَدَّثَنَا ابْنُ جُرَيْجٍ، قَالَ حَدَّثَنِي عُبَيْدُ اللَّهِ بْنُ أَبِي يَزِيدَ، عَنْ سِبَاعِ بْنِ ثَابِتٍ، عَنْ أُمِّ كُرْزٍ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ عَنِ الْغُلاَمِ شَاتَانِ وَعَنِ الْجَارِيَةِ شَاةٌ لاَ يَضُرُّكُمْ ذُكْرَانًا كُنَّ أَمْ إِنَاثًا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"For a boy, two sheep, and or a girl, one sheep, and it does not matter if they are male or female", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Umma Kurz that the Messenger of Allah said:", "chapter_intro": "The Book of al-'Aqiqah"}
{"hadithnumber": "4229", "arabic": "أَخْبَرَنَا أَحْمَدُ بْنُ حَفْصِ بْنِ عَبْدِ اللَّهِ، قَالَ حَدَّثَنِي أَبِي قَالَ، حَدَّثَنِي إِبْرَاهِيمُ، - هُوَ ابْنُ طَهْمَانَ - عَنِ الْحَجَّاجِ بْنِ الْحَجَّاجِ، عَنْ قَتَادَةَ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ عَقَّ رَسُولُ اللَّهِ صلى الله عليه وسلم عَنِ الْحَسَنِ وَالْحُسَيْنِ رضى الله عنهما بِكَبْشَيْنِ كَبْشَيْنِ ‏.‏", "bengali": "", "english": "\"The Messenger of Allah offered an 'Aqiqah for Al-Hasan and Al-Husain, may Allah be please with them, two rams for each.\"", "french": "", "indonesian": "", "russian": "", "urdu": "مخنف بن سلیم رضی اللہ عنہ کہتے ہیں کہ  ہم عرفہ میں نبی اکرم صلی اللہ علیہ وسلم کے ساتھ بیٹھے ہوئے تھ", "grades": "", "reference": "", "international_number": "4229", "narrator_chain": "It was narrated that Ibn 'Abbas said:", "chapter_intro": "The Book of al-'Aqiqah"}
{"hadithnumber": "4230", "arabic": "أَخْبَرَنَا عَمْرُو بْنُ عَلِيٍّ، وَمُحَمَّدُ بْنُ عَبْدِ الأَعْلَى، قَالاَ حَدَّثَنَا يَزِيدُ، - وَهُوَ ابْنُ زُرَيْعٍ - عَنْ سَعِيدٍ، أَنْبَأَنَا قَتَادَةُ، عَنِ الْحَسَنِ، عَنْ سَمُرَةَ بْنِ جُنْدُبٍ، عَنْ رَسُولِ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ كُلُّ غُلاَمٍ رَهِينٌ بِعَقِيقَتِهِ تُذْبَحُ عَنْهُ يَوْمَ سَابِعِهِ وَيُحْلَقُ رَأْسُهُ وَيُسَمَّى ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Every boy is in pledge for his 'Aqiqah, so slaughter (the animal) for him on the seventh day, and shave his head, and a name\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Qatadah, from Al-Hasan, from Samurh bin Jundab that the Messenger of Allah said:", "chapter_intro": "The Book of al-'Aqiqah"}
{"hadithnumber": "4231", "arabic": "أَخْبَرَنَا هَارُونُ بْنُ عَبْدِ اللَّهِ، قَالَ حَدَّثَنَا قُرَيْشُ بْنُ أَنَسٍ، عَنْ حَبِيبِ بْنِ الشَّهِيدِ، قَالَ لِي مُحَمَّدُ بْنُ سِيرِينَ سَلِ الْحَسَنَ مِمَّنْ سَمِعَ حَدِيثَهُ، فِي الْعَقِيقَةِ ‏.‏ فَسَأَلْتُهُ عَنْ ذَلِكَ، فَقَالَ سَمِعْتُهُ مِنْ، سَمُرَةَ ‏.‏", "bengali": "", "english": "\"Muhammad bin Sirin said to me: 'Ask Al-Hasan (Al-Basri) from whom he heard this Hadith about the 'Aqiqah.' I asked him about that and he said: 'I heard it from Samurh.\"'", "french": "", "indonesian": "", "russian": "", "urdu": "حارث بن عمرو رضی اللہ عنہ کہتے ہیں کہ  میں حجۃ الوداع میں رسول اللہ صلی اللہ علیہ وسلم سے ملا، آپ اپ", "grades": "", "reference": "", "international_number": "4231", "narrator_chain": "It was narrated from Habib bin Ash-Shahid:", "chapter_intro": "The Book of al-'Aqiqah"}
