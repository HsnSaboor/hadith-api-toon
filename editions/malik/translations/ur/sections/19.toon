{"hadithnumber": "690", "text": "اسلم رحمہ اللہ جو حضرت عمر بن خطاب رضی اللہ عنہ کے آزاد کردہ غلام ہیں ، سے روایت ہے کہ حضرت عمر بن خ"}
{"hadithnumber": "691", "text": "زید بن اسلم اپنے باپ ( اسلم عدوی رحمہ اللہ ) سے روایت کرتے ہیں ، انھوں نے ( اپنے آقا امیرالمومنین )"}
{"hadithnumber": "692", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ بے شک حضرت عمر بن عبدالعزیز رحمہ اللہ نے اپنے عاملوں ( سرکاری"}
{"hadithnumber": "693", "text": "سالم بن عبداللہ رحمہ اللہ اپنے والد ( حضرت عبدللہ بن عمر رضی اللہ عنہ ) سے روایت کرتے ہیں کہ یقیناً"}
{"hadithnumber": "694", "text": "حضرت سائب بن یزید رضی اللہ عنہ سے روایت ہے ، کہتے ہیں کہ میں حضرت عمر بن خطاب رضی اللہ عنہ کے زمانے"}
{"hadithnumber": "695", "text": "امام مالک رحمہ اللہ نے ابن شہاب رحمہ اللہ سے پوچھا کہ حضرت عمر بن خطاب رضی اللہ عنہ کس طریقے کے مطاب"}
{"hadithnumber": "696", "text": "زید بن اسلم رحمہ اللہ اپنے والد ( اسلم عدوی رحمہ اللہ ) سے روایت کرتے ہیں ، انھوں نے کہا کہ میں نے ح"}
{"hadithnumber": "697", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہ سے روایت ہے کہ بے شک حضرت عمر رضی اللہ عنہ نے اللہ کی راہ میں ایک گ"}
{"hadithnumber": "698", "text": "نافع رحمہ اللہ سے روایت ہے کہ یقیناً حضرت عبدللہ بن عمر رضی اللہ عنہ اپنے ان غلاموں کی طرف سے بھی صد"}
{"hadithnumber": "699", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہ سے روایت ہے کہ یقیناً رسول اللہ ﷺ نے رمضان کے صدقۂ فطر کو لوگوں پر"}
{"hadithnumber": "700", "text": "حضرت ابوسعید خدری رضی اللہ عنہ سے روایت ہے ، کہتے ہیں کہ ہم ایک صاع اناج سے ، یا ایک صاع جو سے ، یا"}
{"hadithnumber": "701", "text": "نافع رحمہ اللہ سے روایت ہے کہ حضرت عبداللہ بن عمر رضی اللہ عنہ صدقۂ فطر میں ( ہمیشہ ) کھجور کے سوا"}
{"hadithnumber": "702", "text": "امام نافع رحمہ اللہ بیان کرتے ہیں کہ حضرت عبداللہ بن عمر رضی اللہ عنہما عید سے دو تین دن پہلے ہی صدق"}
{"hadithnumber": "703", "text": "امام مالک رحمہ اللہ نے فرمایا کہ اپنے غلام کے غلاموں اور اپنے نوکروں اور لونڈی کے غلام کا صدقہ فطر و"}
{"hadithnumber": "704", "text": "سیدہ اسماء بنت عُمیَس رضی اللہ عنہا سے روایت ہے کہ انھوں نے ( حجۃ الوداع کے سفر میں ) بَیداء کے مقام"}
