hadiths[2]{hadithnumber,text}:
22832,"أذعشحأشؼۏۄأضذۏوۏأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأًۄأىثۏأ﷽أڬۏأرزوحأوۏڽأذتعشأۄًةەأتًشأؼشعأڬۏتأڬۄأوۏشەأثۏټەأتًشأوتهأڬًأذوهۄأڬشأڬەأډہۏىأهۏتأڲۏتأۄەأ؏أىثۏأ﷽ألشوتۏتأوتهأحًأحمضۏوأۄًأډڬتأ؏أتهثحۄأثهتهأ$أتىۄۏڽأتځىەأضتحہأتىأڬەأثډەأڬەأځتضأهەأدتاأ؏أتڲشأتىأڬتأثډۄأتىۄۏڽأطىترحأڬشەأحًأتضەأتىأڬەأذًتهەأڬشأزًأ؏أډىتىډۄأذعشحأثهتهأشعۏأتههۄأؼىۄأتىۄۏڽأتځىەأضتحہأهەأڲةەأتًشأتىأڬتأثۏټتأزڬہتأزۏتأ؏أتًشأتضأضەأځًډہتأڬۄأحوأتىۄۏڽأځۄډتىحەأۄًأآأتضأىەأتؼحشتلأڬۏتأحًأذعشحأثهتهأشعۏأتههۄأؼىۄأتضەأتىأڬەأذًتهەأڬشأزۏتأۗأضلۏتىأڬۄحەأۄۏڽأڬۄأؼهوتؤأڬتأرۏتهأۄەأڬۄأشؼۏۄأمثهأتصأذوهۄأتضهتوأمثًهأڬشأډڬەأحہەأۗألتةزۄأۗأوڬوهأًعتذحأڬەأهةەأتڲهۏأذزۏخأځڔہۏەأۗ"
22833,"أذعشحأشؼۏۄأضذۏوۏأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأتىأڬەأځتضأىثۏأ﷽أڬتأضشرأډوڔەأځشأهڬہتأۄًتأتۏڬأرغأإۏتأ؏أتىۄًڽأىەأتضەأتځىەأڋًهأڬتأځۏًىزأثىتأهۏتأ؏أڬډہأؼشظەأثؼزأىثۏأ﷽أىەأتىأڬەأؼهتمەأوۏڽأتۏڬأهطڬشأشًتىۄألشوتأزۏتأدضأىەأتىأڬەأځتضأڬډہأثہۏأىۄأډہًڔتأ؏أىۄأتۄهأرتىۄأتًشأىۄأوتهأًأزًهحأثهڬۄأضثأڬډہأهەأڲةەأ؏أًۄأثشۄىۄأتۏڬأڲہًڔەأځشأ““أدًأځتهتىأضەأوذشًوأحہتأ‛‛أدتىأثډتأڬشأثہتڲەأ؏أتًشأتځىۏأثۏټۏأڬەأځتضأځۄىډەأدضأڬۏأطتزۏأثىًأۄهتهأوۏڽأۄًةۏأحہۏأتًشأتضأىەأتځىەأڲہشأًتهًڽأڬەأضتحہأتضهتوأمثًهأڬشأهۏتأحہتأ؏أتًشأتضأڬەأڲہشأڬتأظذىأهًڲًڽأڬۏأثۏټہڬأۄًحتأحہتأ؏أتضأهةەأًۄأڲہًوأڬشأځډہهەأذظەأضەأڲہشأوۏڽأزترهأۄًةەأ؏أتىأڬۏأثۏټۏأىەأتىۄۏڽأتضأذتهأوۏڽأزۏڬہأڬشأځۄىىەأڬەأهةەأڬځڔەأزۏةەأتًشأځًډہتأڬۄأڬۏتأۄًتأآأتىۄًڽأىەأدًتثأزۏتأڬۄأحۏشەأثتځأځشأثڔۏأضرحأوظۏثحأإةۏأ؏أتضأڬەأځتضأڬډہأثہۏأىۄۏڽأشۄتأ؏أتۄهأرتىۄأتًشأىۄأۄۏأوتهأًأزًهحأ؏أضثأڬډہأډہۏىأهۏتأڲۏتأ؏أتضأىەأځًډہتأڬۄأإځأڬًأتضهتوأڬۏأزؼًحأزۏأڲةۏأحہۏأآأهۏڬىأتىۄًڽأىەأتضأڬتأدًتثأزۏةەأثؽۏشأځًډہتأڬۄأحوۄتشتأطًۄشأڬۄتڽأۄەأآأتضأىەأثحتۏتأتًىټًڽأڬەأځتضأۄۏڽأۗأځہشأًۄأتځىەأزتوتزأڬەأځتضأڲةەأ؏أتضأىەأثہۏأځًډہتأڬۄأإځأڬًأڬۏتأۄًتأآأتىۄًڽأىەأًۄۏأدًتثأزۏتأتًشأڬۄتأڬۄأوۏڽأډتۄحتأۄًڽأڬۄأتځىەأتۄهأرتىۄأتًشأوتهأڬەأحمضۏوأۄًىەأضەأځۄهەأوذوزأ﷽أڬەأځتضأځۄىډأدتاڽأ؏أتضأىەأڬۄتأڬۄأځہشأإځأوۏشۏأضًتشۏأهەأدتةۏڽأ؏أتىۄًڽأىەأڬۄتأڬۄأتضأڬۏأعشًشحأىۄۏڽأ؏أځہشأتضأىەأډشًتۄەأڬتأتۏڬأدًتىأتًىټأهۏتأتًشأتۏڬأثشحىأوۏڽأځتىۏأڬتأحًطۄأزەأڬشأشًتىۄأڬشأزۏتأ؏أتىأڬەأدضوأځشأتۏڬأڬځڔتأحہتأهۏڬىأًۄأتحىتأډہًټتأحہتأتڲشأتضأضەأډۄشۄأڋہتىځحەأحًأدضوأڬتأىډهتأذظۄأثشۄىۄأۄًأدتحتأتًشأتڲشأىډهەأذظەأڬًأڋہتىځحەأحًأډۄشۄأىػشأإحتأحہتأتًشأًۄأتضأثتحأڬًأتډہتأىۄۏڽأضودہحەأحہەأڬۄأتىۄۏڽأڬًةۏأطىترحأڬشأهەأۗأثۄشذتهأ$أًۄأوزۏىۄأوىًشۄأځۄىډەأ؏أتځىۏأضًتشۏأڬًأثتىزہتأتًشأىثۏأ﷽أڬۏأرزوحأوۏڽأذتعشأۄًأڲةەأ؏أىثۏأ﷽أدثأىوتصألدشأضەألتشؽأۄًةەأحًأتىۄًڽأىەأؼشعأڬۏتأۏتأشضًهأتههۄأ$أۄتحہأثڔہتةۏەأڬۄأوۏڽأإځأڬۏأثۏؼحأڬشًڽأ؏أىثۏأ﷽أىەأتځىتأزضحأوثتشڬأإڲەأثڔہتۏتأ؏أدثأتىۄًڽأىەأتځىتأۄتحہأتضأځشأشڬہىتأډتۄتأحًأىثۏأ﷽أىەأتځىتأزضحأوثتشڬأځۏډہەأڬہۏىډأهۏتأ؏أحۏىأوشحثۄأتضۏأغشذأۄًتأ؏أځہشأىثۏأ﷽أىەأتىأضەأځًډہتأڬۄأحوأڬًىأۄًأآأؼشعأڬۏتأڬۄأوۏڽأشؼۏۄأضذۏوۏأۄًڽأ؏أىثۏأ﷽أىەأتىأڬتأۄتحہأځڬڔأڬشأتضەأثهىزأڬۏتأتًشألشوتۏتأتەأڲشًۄأوضهوۏىأ$أۏۄأشؼۏۄأضذۏوۏأۄەأدضأڬۏأغشلأوۏڽأىەأرغأهڬہتأحہتأتًشأتضأىەأوۏشتأرغأځڬڔأڬشأتځىەأڋًهأڬتأځۏًىزأثىتأهۏتأحہتأۗأځہشأتىۄًڽأىەأىۄتۏحأؼتدصۏأضەأؼشعأڬۏتأۏتأشضًهأتههۄأ$أوۏشەأتۄهأرتىۄأتًشأوۏشتأوتهأًتځضأڬشأزۏدةەأ؏أىثۏأ﷽أىەألشوتۏتأحوۄتشتأوتهأحًأحمضۏوأۄًأډڬتأ؏أتهثحۄأحوۄتشەأدًأتۄهأرتىۄأحوۄۏڽأوهأدتةۏڽأًۄأحوۄتشەأۄۏأۄۏڽأ؏أډىتىډۄأًۄأثتۄشأىڬهەأحًأتىأڬتأثۏټتأتىأڬۏأضًتشۏأڬًأځۄډتىأڬشأڬەأتضأڬەأځتضأڬہڔتأحہتأ؏أًۄأىثۏأ﷽أڬۏأرزوحأوۏڽأذتعشأۄًةەأتًشأؼشعأڬۏتأڬۄأۏۄأوۏشتأثۏټتأۄەأ؏أىثۏأ﷽أىەألشوتۏتأثهتهأ$أتضأڬەأضتحہأدتاأ؏أتضأهڔڬەأضەأځًډہًأڬۄأڬۏتأۏۄأحۏشتأثتځأۄەأآأتڲشأًۄأتمشتشأڬشأهەأحًأتضەأتىأڬەأذًتهەأڬشأزًأ؏أډىتىډۄأذعشحأثهتهأشعۏأتههۄأؼىۄأتضأڬەأځتضأڲةەأتًشأؼشعأڬۏتأۏتأشضًهأتههۄأ$أوۏڽأىەأتىأزًىًڽأوۏڽأضەأڬضۏأڬًأثہۏأتۏڬأزًضشەأضەأوهأڬشأإىضًأثۄتحەأۄًةەأىۄۏڽأزۏڬہتأ؏أىثۏأ﷽أىەألشوتۏتأۏۄۏأحًأزۏۄتحۏًڽأڬۏأضرحأزهۏأۄەأۗ"
