{"hadithnumber": "1175", "text": "طلق بن علی رضی الله عنہ کہتے ہیں کہ  میں نے ابن عمر رضی الله عنہما سے ایک ایسے شخص کے بارے میں پوچھا"}
{"hadithnumber": "1176", "text": "عبداللہ بن عمر رضی الله عنہما سے روایت ہے کہ  انہوں نے اپنی بیوی کو حالت حیض میں طلاق دے دی، ان کے و"}
{"hadithnumber": "1177", "text": "رکانہ رضی الله عنہ کہتے ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم کے پاس آ کر عرض کیا: اللہ کے رسو"}
{"hadithnumber": "1178", "text": "حماد بن زید کا بیان ہے کہ  میں نے ایوب  ( سختیانی )  سے پوچھا: کیا آپ حسن بصری کے علاوہ کسی ایسے شخص"}
{"hadithnumber": "1179", "text": "ام المؤمنین عائشہ رضی الله عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ہمیں اختیار دیا  ( چاہی"}
{"hadithnumber": "1180", "text": "عامر بن شراحیل شعبی کہتے ہیں کہ  فاطمہ بنت قیس رضی الله عنہا کہتی ہیں کہ مجھے میرے شوہر نے نبی اکرم"}
{"hadithnumber": "1181", "text": "عبداللہ بن عمرو رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”ابن آدم کے لیے"}
{"hadithnumber": "1182", "text": "ام المؤمنین عائشہ رضی الله عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”لونڈی کے لیے د"}
{"hadithnumber": "1183", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اللہ تعالیٰ نے میری امت"}
{"hadithnumber": "1184", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”تین چیزیں ایسی ہیں کہ ان"}
{"hadithnumber": "1185", "text": "ربیع بنت معوذ بن عفراء رضی الله عنہا کہتی ہیں کہ  انہوں نے نبی اکرم صلی اللہ علیہ وسلم کے زمانے میں"}
{"hadithnumber": "1185", "text": "ربیع بنت معوذ بن عفراء رضی الله عنہا کہتی ہیں کہ  انہوں نے نبی اکرم صلی اللہ علیہ وسلم کے زمانے میں"}
{"hadithnumber": "1186", "text": "ثوبان رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”خلع لینے والی عورتیں مناف"}
{"hadithnumber": "1187", "text": "ثوبان رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس عورت نے بغیر کسی بات کے"}
{"hadithnumber": "1188", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”عورت کی مثال پسلی کی ہے"}
{"hadithnumber": "1189", "text": "عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  میرے نکاح میں ایک عورت تھی، میں اس سے محبت کرتا تھا، اور"}
{"hadithnumber": "1190", "text": "ابوہریرہ رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”عورت اپنی سوکن کی طلاق"}
{"hadithnumber": "1191", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”ہر طلاق واقع ہوتی ہے سوا"}
{"hadithnumber": "1192", "text": "ام المؤمنین عائشہ رضی الله عنہا کہتی ہیں کہ  لوگوں کا حال یہ تھا کہ آدمی اپنی بیوی کو جتنی طلاقیں د"}
{"hadithnumber": "1193", "text": "طلق بن علی رضی الله عنہ کہتے ہیں کہ  سبیعہ نے اپنے شوہر کی موت کے تئیس یا پچیس دن بعد بچہ جنا، اور ج"}
{"hadithnumber": "1194", "text": "سلیمان بن یسار کہتے ہیں کہ  ابوہریرہ، ابن عباس اور ابوسلمہ بن عبدالرحمٰن رضی الله عنہم نے آپس میں ا"}
{"hadithnumber": "1195", "text": "حمید بن نافع سے روایت ہے کہ  زینب بنت ابی سلمہ نے انہیں یہ تینوں حدیثیں بتائیں  ( ان میں سے ایک یہ ہ"}
{"hadithnumber": "1196", "text": "(دوسری حدیث یہ ہے) زینب کہتی ہیں:  پھر میں زینب بنت جحش رضی الله عنہا کے پاس آئی جس وقت ان کے بھائی"}
{"hadithnumber": "1197", "text": "(تیسری حدیث یہ ہے) زینب کہتی ہیں  میں نے اپنی ماں ام المؤمنین ام سلمہ رضی الله عنہا کو کہتے سنا کہ ر"}
{"hadithnumber": "1198", "text": "سلمہ بن صخر بیاضی رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے اس ظہار ۱؎ کرنے والے ک"}
{"hadithnumber": "1199", "text": "عبداللہ بن عباس رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم کے پاس ایک آدمی آیا، اس"}
{"hadithnumber": "1200", "text": "ابوسلمہ اور محمد بن عبدالرحمٰن بن ثوبان کا بیان ہے کہ  سلمان بن صخر انصاری رضی الله عنہ نے جو بنی بی"}
{"hadithnumber": "1201", "text": "ام المؤمنین عائشہ رضی الله عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے اپنی بیویوں سے ایلاء ۱؎"}
{"hadithnumber": "1202", "text": "سعید بن جبیر کہتے ہیں کہ  مصعب بن زبیر کے زمانہ امارت میں مجھ سے لعان ۱؎ کرنے والوں کے بارے میں پوچھ"}
{"hadithnumber": "1203", "text": "عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  ایک آدمی نے اپنی بیوی کے ساتھ لعان کیا، تو نبی اکرم صلی"}
{"hadithnumber": "1204", "text": "زینب بنت کعب بن عجرہ سے روایت ہے کہ  فریعہ بنت مالک بن سنان رضی الله عنہا جو ابو سعید خدری کی بہن ہی"}
