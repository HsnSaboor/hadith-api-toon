hadiths[65]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
3371,ابو الدرداء رضی اللہ عنہ کہتے ہیں کہ  میرے خلیل  ( جگری دوست )  رسول اللہ صلی اللہ علیہ وسلم نے مجھے,,,,,3371
3372,"خباب بن ارت رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  شراب سے بچو، اس لیے ک",,,,,3372
3373,"عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص دنیا م",,,,,3373
3374,"ابوہریرہ رضی اللہ عنہ بیان کرتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو دنیا میں شراب پئ",,,,,3374
3375,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  شراب کا عادی ایسے ہی ہے ",,,,,3375
3376,"ابو الدرداء رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  عادی شرابی جنت میں داخ",,,,,3376
3377,"عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شراب پی کر م",,,,,3377
3378,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  شراب ان دو درختوں: کھجور",,,,,3378
3379,"نعمان بن بشیر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  شراب کئی چیزوں سے ب",,,,,3379
3380,"عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  شراب دس طرح سے م",,,,,3380
3381,انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے دس قسم کے لوگوں پر شراب کی وجہ,,,,,3381
3382,ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  جب سود کے سلسلے میں سورۃ البقرہ کی آخری آیات نازل ہوئ,,,,,3382
3383,عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  عمر رضی اللہ عنہ کو خبر ملی کہ سمرہ رضی اللہ عنہ نے شراب,,,,,3383
3384,"ابوامامہ باہلی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  رات اور دن یعنی زم",,,,,3384
3385,"عبادہ بن صامت رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  میری امت کے بعض لوگ",,,,,3385
3386,"ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ہر نشہ لانے وا",,,,,3386
3387,"عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ہر نشہ لانے والی",,,,,3387
3388,"عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ہر نشہ آور چیز ",,,,,3388
3389,"معاویہ رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  ہر نشہ لانے وال",,,,,3389
3390,"عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ہر نشہ لانے والی",,,,,3390
3391,"ابوموسیٰ اشعری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ہر نشہ لانے والی چ",,,,,3391
3392,"عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ہر نشہ لانے والی",,,,,3392
3393,"جابر رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس کی زیادہ مقدار نشہ آو",,,,,3393
3394,"عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس کی ",,,,,3394
3395,جابر رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے کھجور اور انگور کو ملا کر، اور کچی,,,,,3395
3396,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  پکی اور کچی کھجوریں ملا ",,,,,3396
3397,"ابوقتادہ رضی اللہ عنہ کہتے ہیں کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  تر اور کچی ",,,,,3397
3398,ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  ہم رسول اللہ صلی اللہ علیہ وسلم کے لیے ایک مشک میں نبیذ,,,,,3398
