{"hadithnumber": "507", "text": "ہم سے محمد بن ابی بکر مقدمی بصریٰ نے بیان کیا، کہا کہ ہم سے معتمر بن سلیمان نے بیان کیا عبیداللہ بن"}
{"hadithnumber": "508", "text": "ہم سے عثمان بن ابی شیبہ نے بیان کیا، کہا ہم سے جریر بن عبدالحمید نے بیان کیا منصور بن معتمر سے، انہو"}
{"hadithnumber": "509", "text": "ہم سے ابومعمر نے بیان کیا، کہا ہم سے عبدالوارث نے بیان کیا، کہا کہ ہم سے یونس بن عبید نے حمید بن ہلا"}
{"hadithnumber": "510", "text": "ہم سے عبداللہ بن یوسف تینسی نے بیان کیا، انہوں نے کہا ہم سے امام مالک نے عمر بن عبیداللہ کے غلام ابو"}
{"hadithnumber": "511", "text": "ہم سے اسماعیل بن خلیل نے بیان کیا، کہا ہم سے علی بن مسہر نے بیان کیا سلیمان اعمش کے واسطہ سے، انہوں"}
{"hadithnumber": "512", "text": "ہم سے مسدد بن مسرہد نے بیان کیا، کہا کہ ہم سے یحییٰ بن سعید قطان نے بیان کیا، کہا کہ ہم سے ہشام بن ع"}
{"hadithnumber": "513", "text": "ہم سے عبداللہ بن یوسف تینسی نے بیان کیا، کہا کہ ہمیں امام مالک نے خبر دی عمر بن عبیداللہ کے غلام ابو"}
{"hadithnumber": "514", "text": "ہم سے عمر بن حفص بن غیاث نے بیان کیا کہا، کہ مجھ سے میرے باپ نے بیان کیا، کہا کہ ہم سے اعمش نے بیان"}
{"hadithnumber": "515", "text": "ہم سے اسحاق بن ابراہیم نے بیان کیا، کہا کہ ہمیں یعقوب بن ابراہیم نے خبر دی، کہا کہ مجھ سے میرے بھتیج"}
{"hadithnumber": "516", "text": "ہم سے عبداللہ بن یوسف تنیسی نے بیان کیا، انہوں نے کہا کہ ہمیں امام مالک نے عامر بن عبداللہ بن زبیر ر"}
{"hadithnumber": "517", "text": "ہم سے عمرو بن زرارہ نے بیان کیا، کہا کہ ہم سے ہشیم نے شیبانی کے واسطے سے بیان کیا، انہوں نے عبداللہ"}
{"hadithnumber": "518", "text": "ہم سے ابوالنعمان محمد بن فضل نے بیان کیا، کہا کہ ہم سے عبدالواحد بن زیاد نے بیان کیا، کہا ہم سے شیبا"}
{"hadithnumber": "519", "text": "ہم سے عمرو بن علی نے بیان کیا، کہا کہ ہم سے یحییٰ بن سعید قطان نے بیان کیا، کہا کہ ہم سے عبیداللہ عم"}
{"hadithnumber": "520", "text": "ہم سے احمد بن اسحاق سرماری نے بیان کیا، انہوں نے کہا کہ ہم سے اسرائیل نے ابواسحاق کے واسطہ سے بیان ک"}
