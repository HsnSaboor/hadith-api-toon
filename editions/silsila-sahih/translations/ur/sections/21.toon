2674,"ذسۏلۄأشعۏأتههۄأؼىۄأأضەأوشًۏأۄەأڬۄأشضًهأتههۄأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ڬەأځتضأزدتهأڬتأسڬشأڬۏتأڲۏتأحًأإځأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أحوأوۏڽأضەأڬضۏأطرظأڬتألحىەأوۏڽأوثحهتأۄًىتأوۏشەأىصزۏڬأزدتهأڬەألحىەأضەأصۏتزۄأرًلأڬتأثتؼخأۄەأتًشأدًأطرظأځۄهەألحىەأضەأوذلًػأشۄتأًۄأزدتهأڬەألحىەأضەأثہۏأوذلًػأشۄەأڲت؏أتًشأدثأضەأزىۏتأۄەأدًأثہۏأډہًټتأۏتأثڔتألحىۄأثځتأۄًتأۏتأىػشأؼتوأځشأإۏتأۄەأأًۄأزدتهأڬەألحىەأڬۏأًدۄأضەأۄە

[تخریج]: الصحيحة رقم (3082) مسند أحمد رقم (22215)"
2675,"تثًأذشثأثىأتثًأتهتضًزأشعۏأتههۄأؼىۄأأڬۄحەأۄۏڽأڬۄأوۏڽأؼهۏأتًشأصثۏشأشعۏأتههۄأؼىۄأڬەأځتضأوًدًزأحہتأدثأصثۏشأشعۏأتههۄأؼىۄأتځىۏأضًتشۏأځشأظلًڽأڬًأډۏشحەأۄًةەأًتځضأځهټأشۄەأحہە؏تىأڬتأثۏټتأؼثزتههۄأتىأڬەأضتوىەأإڬشأڬہڔتأۄًڲۏتأتًشأڬۄتأڬۄأڬۏتأۄًتآأحًأصثۏش‏شعۏأتههۄأؼىۄأىەأڬۄت=أؼهۏأشعۏأتههۄأؼىۄأىەأودہەأتۏڬأذزۏخأۏتزأڬشًتزۏأۄەأدًأوۏڽأىەأشضًهأتههۄأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ضەأضىۏأحہۏۗأشضًهأتههۄأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ىەألشوتۏت=أڬۄأحوأتضأضەأهڔتةۏأڬشًأڲەأتًشأحوأػتهوأۄًڲەۗأ+تضأهةە,أوۏڽأتضأضەأمحتهأىۄۏڽأڬشًڽأڲت؏ؼثزتههۄ‏شعۏأتههۄأؼىۄأىەأڬۄت=أڬۏتأحوأهڔتةۏأڬەأهةەأإةەأۄًآأإځأحًأتضأهةەإةەأۄًأحتڬۄأإځأهًڲًڽأڬەأزشوۏتىأظهذأڬشًتزۏڽ؏تًشأتههۄأحؼتهۏٳأإځأڬۏأًدۄأضەأتضأوؼتوهەأڬًأزشضحأڬشأزەۗأصثۏشأشعۏأتههۄأؼىۄأأىەأڬۄت=أوۏڽأمضوأڬہتډڬتأڬۄأهڔتةۏأىۄۏڽأڬشًڽأڲتۗأؼثزتههۄ‏شعۏأتههۄأؼىۄأىەأڬۄت=أتځىتأؽهتوأدشدضأإصتزأڬشأزۏدةەأتًشأهًڲًڽأڬەأزشوۏتىأظهذأڬشًتىەأحڬأټہۄشەأشۄۏڽۗأصثۏشأشعۏأتههۄأؼىۄأأىەأتځىتأؽهتوأدشدضأإصتزأڬشأزۏتأتًشأًۄۏڽأټہۄشەأشۄە؏أځہشأهًڲًڽأڬەأوؼتوهەأوۏڽأترحهتلأځڔأڲۏتأحًأًۄأتځىەأڲہًڔەأځشأثۏټہأڬشأډهەأڲةە

[تخریج]: الصحيحة رقم (2659) مستدرك الحاكم رقم (5588)"
2676,"ذسۏلۄأشعۏأتههۄأؼىۄأأضەأوشًۏأۄەأڬۄحەأۄۏڽأڬۄأشضًهأتههۄأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ىەألشوتۏت=وۏشۏأتوحأځشأتۏڬأصوتىۄأتۏضتأإةەأڲتأدضأوۏڽأًۄأزدتهأڬۏأحوىتأڬشۏڽأڲەۗأوۏڽأىەأڬۄت=تەأتههۄأڬەأشضًه$وۏشەأوتڽأثتځأإځأځشمشثتى$ڬضأًدۄأضەآإځأظهۏأتههۄأؼهۏۄأًضهوأىەلشوتۏت=تىۄۏڽأدًوطمح+مذغ,ۏتأثۏوتشۏأځۄىډەڲۏأتضأًدۄأضەۗأ

[تخریج]: الصحيحة رقم (3090) المعجم الأوسط للطبراني رقم (4440)"
2677,"ؼتةطۄأۏتأتوأضهوۄأشعۏأتههۄأؼىۄوتأضەأوشًۏأۄەأڬۄأىثۏأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ىەأتىأزًىًڽأوۏڽأضەأڬضۏأتۏڬأضەألشوتۏت=أوۏشەأځتضأڲہشأوۏڽأتۏڬألشطحۄأإۏتأۄەأدًأتضأضەأځۄهەأوۏشەأځتضأىۄۏڽأإۏتأتًشأودہأضەأڬۄت=أحوۄتشتأثۏټتأذضۏىأمحهأڬۏتأدتةەأڲت؏أتڲشأإځأډتۄۏڽأحًأوۏڽأإځأڬًأتضأصوۏىأڬۏأوټۏأزڬہتأضڬحتأۄًڽأدضأوۏڽأتضەأمحهأڬۏتأدتةەأڲتأۗځہشأتضأىەأضشرأوټۏأىڬتهأڬشأزڬہتةۏۗ

[تخریج]: الصحيحة رقم (822) مسند أحمد رقم (25315)"
2678,"تثًأصثۏشأشعۏأتﷵأؼىۄأضەأوشًۏأۄەأڬۄحەأۄۏڽأڬۄأوۏڽأىەأدتثشأشعۏأتﷵأؼىۄأضەأًشًزأ+ذتعشۏ,أڬەأثتشەأوۏڽأضًتهأڬۏتۗأتىۄًڽأىەأودہەأثحتۏتأڬۄأتىۄًڽأىەأشضًهأتﷵأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ضەأضىتألشوتشۄەأحہە=أۄوأمۏتوحأڬەأزىأهًڲًڽأضەأتًځشأتۏڬأټۏهەأځشأۄًڽأڲە؏أحوتوأتوحًڽأڬً؏أتىأڬەأثحًڽأتًشأدىأڬۏأًۄأؼثتزحأڬشحەأحہەأتۏڬأتۏڬأڬشڬەأثهتۏتأدتةەأڲتۗأځہشأتضأڬەأثؼزأۄوتشتأشثأإةەأڲتأتًأشڬۄەأڲت=أحوأڬضأڬتأتىحػتشأڬششۄەأۄًآأحًأهًڲأڬۄۏڽأڲە=أۄوأتځىەأشثأڬتأتىحػتشأڬششۄەأۄۏڽ؏أتﷵأحؼتهۏٳألشوتةەأڲت=أوۏڽأحوۄتشتأشثأۄًڽ؏أًۄأڬۄۏڽأڲە=أدثأحڬأۄوأإځأڬًأزۏڬہأىۄأهۏڽ؏أحثأتﷵأحؼتهۏٳأوضڬشتحەأۄًةەأحدهۏألشوتةەأڲتأتًشأهًڲأتﷵأحؼتهۏٳأڬەأځۏډہەأډهأځڔۏڽأڲەۗ

[تخریج]: الصحيحة رقم (3090) المعجم الأوسط للطبراني رقم (4440)"
2679,"ضؼزأشعۏأتﷵأؼىۄأڬۄحەأۄۏڽأڬۄأشضًهأتﷵأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ىەألشوتۏت=أثۄحشۏىأوًحأًۄأۄەأڬۄأإزوۏأتځىتأذمأثډتحەأۄًةەأوشأدتةەۗ

[تخریج]: الصحيحة رقم (822) مسند أحمد رقم (25315)"
2680,"دتثشأثىأؼثزتﷵأشعۏأتﷵأؼىوتأضەأوشًۏأۄەأڬۄحەأۄۏڽأڬۄأشضًهأتﷵأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ذشۄأ+إحطألطتىۏأضىڲشۏصە,أڬۏأڬضۏأتًىډۏأدڲۄأځشأډڔہەأۄوأثہۏأإځأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ڬەأضتحہأحہە؏أإځأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ىەألشوتۏت=أثۄحشۏىأصوۏىأ+ؼهتمۄ,أوزۏىەأڬۏأۄە؏أدثأزدتهأىڬهەأڲتأحًأتضأڬەأۄشأشتضحەأځشألشطحۄأثۏټہتأۄًڲتأتًشأزدتهأتضأوۏڽأزترهأىۄۏڽأۄًضڬەأڲت؏أدثأظًشحأذتهأتضأغشذأۄًڲۏأحًأوزۏىۄأحۏىأوشحثۄأتځىەأشۄىەأًتهًڽأڬًأۄهتةەأڲت؏أڬًةۏأوىتلمأتًشأوىتلمۄأتضأوۏڽأثتمۏأىۄۏڽأشۄەأڲت؏أًۄأوزۏىەأضەأثتۄشأىڬهأدتةۏڽأڲە؏أتڬخشأىڬهىەأًتهۏأؼًشحۏڽأۄًڽأڲۏ؏أۏۄأرهتظۏأڬتأزىأۄًڲت؏أتًشأتۏضتأزىأۄًڲتأڬۄأوزۏىۄأتځىتأوۏهأڬډۏهأتضأغشذأىڬتهأزەأڲت؏أدضأغشذأثہټۏأهًۄەأڬتأصىڲأرحوأڬشزۏحۏأۄە؏أزدتهأڬەأضتحہأضحشأۄصتشأۏۄًزۏأۄًڽأڲەأتىأوۏڽأضەأۄشأطرظأځشأډوڬحۏأۄًةۏأحهًتشأۄًڲۏ؏أتضأڬۏأڲشزىأځشأتۏضۏأعشثأهڲتةۏأدتةەأڲۏأدۏضەأضۏهتثۏأځتىۏأځشأهڲتةۏأدتحۏأۄەۗأځہشأشضًهأتﷵأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ىەألشوتۏت=أڬًةۏألحىۄأمۏتوحأحڬأزدتهأڬەألحىەأضەأثڔتأىۄۏڽأۄًتأىۄأۄًڲتۗأتًأشڬًةۏأىثۏأتۏضتأىۄۏڽأدضأىەأتځىۏأتوحأڬًأتضأضەأڋشتۏتأىۄأۄً؏أوۏڽأحوۄۏڽأتۏضۏأىطتىۏأثحتأشۄتأۄًڽأدًأودہأضەأځۄهەأڬضۏأىثۏأىەأىۄۏڽأثحتةۏۗأځہشأتځىتأۄتحہأتځىۏأإىڬہأځشأشڬہتأځہشألشوتۏت=أوۏڽأڲًتۄۏأزۏحتأۄًڽأڬۄأتﷵأحؼتهۏٳأڬتأىتوأىۄۏڽۗ

[تخریج]: الصحيحة رقم (4006) صحيح البخاري كِتَاب الْمَنَاقِبِ بَاب عَلَامَاتِ النُّبُوَّةِ فِي الْإِسْلَامِ رقم (3359)"
2681,"دتثشأأشعۏأتههۄأؼىۄأأضەأوشًۏأۄەأڬۄأىثۏأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ىەألشوتۏت=أڬۏتأحوۄتشەأځتضأمتهۏىأۄۏڽآأوۏڽأىەأڬۄت=أۄوتشەأځتضأمتهۏىأغشذأۄًأضڬحەأۄۏڽآأإځأىەألشوتۏت=أؼىمشۏثأحوۄتشەأځتضأزضحشرًتىأۄًڽأڲەأۗدتثشأڬۄحەأۄۏڽأڬۄأوۏڽأۏۄأثتحأتځىۏأثۏًۏأضەأڬۄتأڬشحتأحہتأڬۄ=أودہأضەأتځىەأمتهۏىأزًشأڬشأهً؏أحًأًۄأڬۄحۏ=ڬۏتأىثۏأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ىەأۏۄأىۄۏڽأڬۄتأڬۄأؼىمشۏثأحوۄتشەأهةەأمتهۏىأۄًڽأڲەأآأحًأوۏڽأتضەأډہًڔأزۏتأڬشحتأۗ

[تخریج]: الصحيحة رقم (822) مسند أحمد رقم (25315)"
2682,"تثًأۄشۏشۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأشضًهأتههۄأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ىەألشوتۏت=أتضأستحأڬۏأمضوأدضأڬەأۄتحہأوۏڽأتثًأتهمتضوأڬۏأدتىأۄە$أؼۏضۏٳأثىأوشۏوأؼهۏۄوتأتهضهتوأتىظتلأځضىزأتوتوأتًشأأؼتزهأوىظلأثىأڬشأىتصهأۄًڽأڲەأًۄأظهۏثأڬًأعشًشأحًڔۏڽأڲە؏أرىصۏشأڬًأمحهأڬشۏڽأڲەأتًشأهًڲًڽأڬەأزشوۏتىأظهذأڬشًتةۏڽأڲە؏تًشأثرۏهۏأڬًأرحوأڬشأزۏڽأڲەأۗتىأڬەأضتوىەأوتهأځۏطأڬۏتأدتةەأڲتأحًأتضەأمثًهأىۄۏڽأڬشۏڽأڲە؏ځہشأتڲشأًۄأوۏشۏأمثشأځشأڬہڔەأۄًأڬشأڬۄۏڽ=ۏتأوذوزأأحًأوۏڽأدًتثأزًڽأڲتۗ

[تخریج]: الصحيحة رقم (2733) مسند أبي يعلى رقم (6449)"
2683,"تثًأۄشۏشۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄحەأۄۏڽأڬۄأىثۏأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ظذتثۄأڬەأتۏڬأڲشًۄأڬەأځتضأإةەأًۄأۄىضأشۄەأحہەأتًشأثتحۏڽأڬشأشۄەأحہەۗأإځأظهۏأتههۄأؼهۏۄأًضهوأ‏ىەألشوتۏت=أتضأستحأڬۏأمضوأدضأڬەأۄتحہأوۏڽأوۏشۏأدتىأۄە$أتڲشأحوۄۏڽأًۄأثتحۏڽأوؼهًوأۄًأدتةۏڽأدًأوۏڽأدتىحتأۄًڽأحًأحوأۄىضًأڬوأتًشأشًًٗأأصۏتزۄۗځہشأىثۏأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ًتځضأځهټأڲةەأتًشأهًڲأشًىەأهڲەۗأتههۄأؼصًدهأىەأإځأڬۏأغشلأًذۏأڬۏ=أتەأوذوز$أحوأوۏشەأثىزًڽأڬًأىتأتوۏزأڬۏًڽأڬشحەأۄًآأىثۏأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ًتځضأځهټەأتًشألشوتۏت=أرًطأۄًأدتًٗ؏ضۏزہەأۄًأدتًٗأتًشأمشۏثأۄًأدتًٗ

[تخریج]: الصحيحة رقم (3194) شعب الإيمان للبيهقي رقم (1073)"
2684,"تثًأثڬشۄأشعۏأتههۄأؼىۄأأضەأوشًۏأۄەأڬۄحەأۄۏڽأڬۄأىثۏأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏تۏڬأإزوۏأڬەأځتضأضەأڲصشەأدًأضدزەأوۏڽأځڔتأۄًتأحہت؏إځأظهۏأتههۄأؼهۏۄأًضهوأىوتصأڬۏأغشلأدتأشۄەأحہەۗأإځأىەأىوتصأوڬوهأڬشأهۏأتضأڬەأځتضأضەأًتځضأځهټەأحًأًۄأضدزەأوۏڽأځڔتأۄًتأحہتۗأىثۏأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ڬہڔەأۄًڲةەأتًشألشوتۏت=أتضەأڬًىأمحهأڬشەأڲتآأتۏڬأإزوۏأڬہڔتأۄًتأتځىەأثتصًأډڔہتةەأتًشأحهًتشأضًىحأهۏأتضەأذشڬحأزەأڬشأڬۄت=أتەأتههۄأڬەأىثۏأ$أوۏشەأوتڽأثتځأإځأځشأمشثتى$وۏڽأتضأإزوۏأڬًأڬضأغشذأمحهأڬشًڽأدًأضدزەأوۏڽأځڔتأۄًتأۄەأتًشأڲًتۄۏأزۏحتأۄەأڬۄأتههۄأڬەأؼهتًۄأڬًةۏأوؼثًزأثشذمأىۄۏڽأتًشأوذوزأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏تضأڬەأثىزەأتًشأشضًهأۄۏڽآأإځأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ىەأځہشألشوتۏت=أتضەأڬًىأمحهأڬشەأڲتآأتۏڬأإزوۏأڬہڔتۄًتتًشڬۄىەأهڲت=وۏڽ؏أتضأىەأتځىەأثتصًأډڔہتةە؏تځىۏأحهًتشأضًىحأڬشأذشڬحأزۏأدثأتضأڬتأۄتحہأذشڬحأوۏڽأإۏتأحًأڬۄىەأهڲت=أتەأتههۄأڬەأىثۏ$أوۏڽأتضأإزوۏأڬًأڬضأغشذأمحهأڬشًڽأدًأضدزەأڬۏأذتهحأوۏڽأځڔتأۄًتأهتأتهۄأتهتأتههۄأوذوزأشضًهأتههۄأڬۏأڲًتۄۏأزەأشۄتأۄەآأىثۏأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ىەألشوتۏت=أتضأستحأڬۏأمضوأدضأڬەأۄتحہأوۏڽأوۏشۏأدتىأۄەأتڲشأحوأتضەأمحهأڬشأزۏحەأحًأۏۄأځۄهتأتًشأإرشۏألحىۄأۄًحتۗ

[تخریج]: الصحيحة رقم (2495) مسند أحمد رقم (19536)"
2685,"تثًأضؼۏزأرزشۏأشعۏأتههۄأؼىۄأضەأوشًۏأۄە؏أڬۄحەأۄۏڽأڬۄأتۏڬأثہۏڔۏەأىەأتۏڬأثڬشۏأځشأذوهۄأڬشأڬەأتضەأځڬڔأهۏتۗأډشًتۄەأىەأتضأڬتأځۏډہتأڬشڬەأثڬشۏأتضأضەأډہۏىأهۏۗأثہۏڔۏتأتځىۏأزْوأځشأثۏټہأڲۏتأځہشڬۄىەأهڲت=أڬۏتأحوأتههۄأضەأىۄۏڽأڋشحەأآودہأضەأوۏشتأشصمأډہۏىأشۄەأۄًأدًأتههۄأحؼتهۏٳأىەأودہەأزۏتأۄەآأًۄأإزوۏأڬۄىەأهڲت=أۄتةەأحؼدثأۄە$أثہۏڔۏتأتځىۏأزْوأځشأثۏټہتأودہأضەأتىضتىًڽأڬۏأغشذأڲلحڲًأڬشأشۄتأۄەۗأثہۏڔۏەأىەأڬۄت=أڬۏتأوۏڽأحوۄۏڽأتضأضەأثہۏأؼدۏثأثتحأىۄأثحتًٗڽآأوذوزأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ۏخشثأوۏڽأۄۏڽأدًأًتمؼتحأڲصشأډڬەأۄۏڽأتىأڬۏأرثشۏڽأثحتشۄەأۄۏڽًۗۄأډشًتۄتأتځىۏأثڬشۏتڽأډشتحتأۄًتأوزۏىەأوۏڽأزترهأۄًڲۏتځہشأوزۏىەأڬەأڬضۏأڲًطەأتځىۏأثڬشۏتڽأدوؼأڬۏڽ؏أځہششضًهأتههۄأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ڬەأځتضأإۏتأأتًشأتىۄۏڽأۏۄأثتحأثحتةۏۗأشضًهأتههۄأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ىەأذڬوأزۏتأحًأىوتصأڬەأهةەأدوؼأۄًىەأڬتأتؼهتىأڬۏتأڲۏت؏ځہشأإځأثتۄشأىڬهەأتًشأډشًتۄەأضەأڬۄت=أتىۄۏڽأثہۏأثحتًٗۗأډشًتۄەأىەأهًڲًڽأڬًأًتمؼۄأثۏتىأڬۏتۗأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأىەلشوتۏت=تضأىەضډأڬۄت=تضأستحأڬۏأمضوأدضأڬەۄتحہأوۏڽأوۏشۏأدتىأۄە$مۏتوحأتضأًمحأمتةوأىۄۏڽأۄًڲۏأدثأحڬأزشىزە+دتىًش,أتىضتىًڽأضەأثتحأىۄأڬشىەأهڲأدتةۏڽأتًشأإزوۏأضەأتضأڬەأڬًڔەأڬۏأډہڔۏأتًشأدًحەأڬتأحضوۄأىۄأثًهىەأهڲأدتةەأتًشأتضەأتضأڬۏأشتىأثحهتةەأڬۄأتضأڬەأثؼزأتضأڬەأڲہشأًتهًڽأىەأڬۏتأڬۏتأۄەۗ

[تخریج]: الصحيحة رقم (122) مسند أحمد رقم (11365)"
2686,"تثًأؼتوشأۏتأتثًأوتهڬأتطؼشۏأشعۏأتههۄأؼىۄأأضەأوشًۏأۄەأڬۄأىثۏأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ىەألشوتۏت=أوۏشۏأتوحأوۏڽأڬډہأهًڲأۄًڽأڲەأدًأطشوڲتۄأ+ۏؼىۏأصىت,؏أشۏطو؏أطشتأثأتًشأڲتىەأثدتىەأڬەأإهتحأڬًأذهتهأڬشأهۏڽأڲەۗأتًشأڬډہأهًڲأځۄتڔأڬۏأډًټۏأځشأ+تځىەأثىڲهًڽأوۏڽأشۄتةطأڬەأهةە,أإةۏڽأڲەۗأتىأڬەأډشًتۄەأتىأڬەأوًۏطۏأظثذأًأطتوأهتةۏڽأهەأدتةۏڽأڲەۗأتىأڬەأځتضأڬًةۏألمۏشأعشًشحأضەأإةەأڲتحًأأًۄأڬۄۏڽأڲە=ۄوتشەأځتضأڬهأإىت؏أتههۄأحؼتهۏٳأشتحأڬەأًمحأتىأځشأؼستثأىتصهأڬشأەأڲتۗتىأځشأځۄتڔأڬًأڲشتأزەأڲتأتًشأزًضشەأهًڲًڽأڬًأمۏتوحأحڬأثىزشًڽأتًشأرىصۏشًڽأڬۏأطڬهأوۏڽأحثزۏهأڬشأزەأڲت

[تخریج]: الصحيحة رقم (91) صحيح البخاري كِتَاب الْأَشْرِبَةِ بَاب مَا جَاءَ فِيمَنْ يَسْتَحِلُّ الْخَمْرَ وَيُسَمِّيهِ بِغَيْرِ اسْمِهِ رقم (5162)"
2687,"توأتهوًوىۏىأتوأذثۏثۄأشعۏأتههۄأؼىۄت؏أصۏىثأثىحأدذطأأشعۏأتههۄأؼىۄتأضەأثۏتىأڬشحۏأۄۏڽ؏ڬۄحۏأۄۏڽأڬۄأتۏڬأزىأشضًهأتههۄأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ۄوتشەأځتضأڲہثشتةەأۄًةەأإةەأإځأڬتأډۄشۄأضشرأۄًأشۄتأحہتأتًشأإځأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏لشوتأشۄەأحہە=ؼشثأڬەأهةەأتضأطشأضەأۄهتڬحأۄەأدًأمشۏثأإډڬتأۄە؏إدأۏتأدًدأوتدًدأڬۏأزۏًتشأوۏڽأتحىتأضًشترأڬشأزۏتأڲۏتأۄەأإځأىەأتىڲًټہەأتًشأطۄتزحأڬۏأتىڲهۏأضەأذهمۄأثىتۏت؏وۏڽأىەأڬۄت=أتەأتههۄأڬەأشضًه$أڬۏتأۄوأۄهتڬأڬشأزۏةەأدتةۏڽأڲە؏أذتهتىڬۄأۄوأوۏڽأىۏڬأهًڲأثہۏأۄًڽأڲەآأإځأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ىەألشوتۏت=أۄتڽ؏دثأرثخ+أڲىتۄ,أصۏتزۄأۄًأدتةەڲت

[تخریج]: الصحيحة رقم (9878) صحيح البخاري كِتَاب الْفِتَنِ بَاب قَوْلِ النَّبِيِّ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ وَيْلٌ لِلْعَرَبِ مِنْ شَرٍّ قَدْ اقْتَرَبَ رقم (6535)"
