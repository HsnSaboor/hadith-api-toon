{"hadithnumber": "2014", "text": "ہم سے علی بن عبداللہ مدینی نے بیان کیا، کہا کہ ہم سے سفیان بن عیینہ نے بیان کیا، انہوں نے کہا کہ ہم"}
{"hadithnumber": "2015", "text": "ہم سے عبداللہ بن یوسف نے بیان کیا، کہا کہ ہم کو امام مالک رحمہ اللہ نے خبر دی، انہیں نافع نے، اور ان"}
{"hadithnumber": "2016", "text": "ہم سے معاذ بن فضالہ نے بیان کیا کہا کہ ہم سے ہشام نے بیان کیا، ان سے یحییٰ بن ابی کثیر نے، ان سے ابو"}
{"hadithnumber": "2017", "text": "ہم سے قتیبہ بن سعید نے بیان کیا، کہا ہم سے اسماعیل بن جعفر نے بیان کیا، کہا کہ ہم سے ابوسہیل نے بیان"}
{"hadithnumber": "2018", "text": "ہم سے ابراہیم بن حمزہ نے بیان کیا، کہا کہ مجھ سے عبدالعزیز بن ابی حازم اور عبدالعزیز دراوردی نے بیان"}
{"hadithnumber": "2019", "text": "مجھ سے محمد بن مثنیٰ نے بیان کیا، کہا کہ ہم سے یحییٰ قطان نے بیان کیا، ان سے ہشام بن عروہ نے کہا کہ"}
{"hadithnumber": "2020", "text": "مجھ سے محمد بن سلام نے بیان کیا۔ انہوں نے کہا ہمیں عبدہ بن سلیمان نے خبر دی، انہیں ہشام بن عروہ نے،"}
{"hadithnumber": "2021", "text": "ہم سے موسیٰ بن اسماعیل نے بیان کیا، کہا کہ ہم سے وہیب بن خالد نے بیان کیا، کہا کہ ہم سے ایوب سختیانی"}
{"hadithnumber": "2022", "text": "ہم سے عبداللہ بن ابی الاسود نے بیان کیا، کہا کہ ہم سے عبدالواحد بن زیاد نے بیان کیا، ان سے عاصم بن س"}
{"hadithnumber": "2023", "text": "ہم سے محمد بن مثنی نے بیان کیا، ان سے خالد بن حارث نے بیان کیا، ان سے حمید طویل نے بیان کیا، ان سے ا"}
{"hadithnumber": "2024", "text": "ہم سے علی بن عبداللہ مدینی نے بیان کیا، کہا کہ ہم سے سفیان بن عیینہ نے بیان کیا، ان سے ابویعفور نے ب"}
