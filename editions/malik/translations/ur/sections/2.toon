{"hadithnumber": "109", "text": "عطاء بن یسار رحمہ اللہ سے روایت ہے کہ رسول اللہ ﷺ نے نمازوں میں سے کسی نماز میں تکبیر تحریمہ کہہ ڈال"}
{"hadithnumber": "110", "text": "زُیید بن صلت رحمہ اللہ سے روایت ہے ، کہتے ہیں کہ میں حضرت عمر بن خطاب رضی اللہ عنہ کے ہمراہ جُرُف نا"}
{"hadithnumber": "111", "text": "سلیمان بن یسار رحمہ اللہ سے روایت ہے کہ حضرت عمر بن خطاب رضی اللہ عنہ صبح کے وقت جُرُف نامی جگہ میں"}
{"hadithnumber": "112", "text": "سلیمان بن یسار رحمہ اللہ سے روایت ہے کہ حضرت عمر بن خطاب رضی اللہ عنہ نے ( مدینہ میں ) لوگوں کو صبح"}
{"hadithnumber": "113", "text": "’’ یحیی بن عبدالرحمن بن حاطب رحمہ اللہ سے روایت ہے کہ وہ ( یحیی کے والد ) ایک شُتر سوار قافلے میں حض"}
{"hadithnumber": "114", "text": "عروہ بن زبیر رحمہ اللہ سے روایت ہے کہ حضرت اُم سلیم رضی اللہ عنہا نے رسول اللہ ﷺ سے عرض کیا کہ اے ال"}
{"hadithnumber": "115", "text": "حضرت اُمِ سلمہ رضی اللہ عنہا سے روایت ہے کہ حضرت ابو طلحہ انصاری رضی اللہ عنہ کی بیوی اُمِ سلیم رضی"}
{"hadithnumber": "116", "text": "نافع رحمہ اللہ سے روایت ہے کہ حضرت عبداللہ بن عمر رضی اللہ عنہما کہا کرتے تھے : اس میں کوئی حرج نہیں"}
{"hadithnumber": "117", "text": "نافع رحمہ اللہ سے روایت ہے کہ حضرت عبداللہ بن عمر رضی اللہ عنہما کو کپڑے میں پسینہ آ جاتا ، اس حال م"}
{"hadithnumber": "118", "text": "نافع رحمہ اللہ سے روایت ہے کہ حضرت عبداللہ بن عمر رضی اللہ عنہما کی لونڈیاں اُن کے پاؤں دھویا کرتی"}
{"hadithnumber": "119", "text": "اُم المومنین حضرت عائشہ رضی اللہ عنہا سے روایت ہے ، کہتی ہیں کہ ہم رسول اللہ ﷺ کے ہمراہ آپ ﷺ کے کسی"}
{"hadithnumber": "120", "text": "نافع رحمہ اللہ سے روایت ہے کہ وہ اور ( اُن کے آقا ) حضرت عبداللہ بن عمر رضی اللہ عنہما جُرُف نامی جگ"}
{"hadithnumber": "121", "text": "نافع رحمہ اللہ سے روایت ہے کہ بے شک حضرت عبداللہ بن عمر رضی اللہ عنہما کہنیوں تک تیمم کیا کرتے تھے ۔"}
{"hadithnumber": "122", "text": "عبدالرحمن بن حرملہ رحمہ اللہ سے روایت ہے کہ ایک آدمی نے سعید بن مسیب رحمہ اللہ سے اُس جنبی شخص کے مت"}
{"hadithnumber": "123", "text": "زید بن اسلم رحمہ اللہ سے روایت ہے کہ ایک آدمی نے رسول اللہ ﷺ سے سوال کیا اور کہا کہ میرے لیے میری بی"}
{"hadithnumber": "124", "text": "ربیعہ بن ابی عبدالرحمن رحمہ اللہ سے روایت ہے کہ بے شک زوجۂ رسول ﷺ حضرت عائشہ رضی اللہ عنہا رسول الل"}
{"hadithnumber": "125", "text": "نافع رحمہ اللہ سے روایت ہے کہ عبید اللہ رحمہ اللہ بن عبداللہ بن عمر نے زوجۂ رسول ﷺ اُم المومنین عائ"}
{"hadithnumber": "126", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ سالم بن عبداللہ رحمہ اللہ اور سلیمان بن یسار رحمہ اللہ دونوں"}
{"hadithnumber": "127", "text": "علقمہ بن ابی علقمہ رحمہ اللہ اپنی والدہ اُمِ علقمہ ( جن کا نام مرجانہ تھا ) جو اُم المومنین سیدہ عائ"}
{"hadithnumber": "128", "text": "حضرت زید بن ثابت رضی اللہ عنہ کی بیٹی ( اُمِ کلثوم رحمہ اللہ جو سالم رحمہ اللہ بن عبداللہ بن عمر کی"}
{"hadithnumber": "129", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ حضرت عائشہ رضی اللہ عنہا نے اس حاملہ عورت کے متعلق جو خون دیک"}
{"hadithnumber": "130", "text": "امام مالک رحمہ اللہ نے ابن شہاب زہری رحمہ اللہ سے اُس حاملہ عورت کے متعلق سوال کیا جو خون دیکھتی ہے"}
{"hadithnumber": "131", "text": "زوجۂ پیغمبر ﷺ حضرت عائشہ رضی اللہ عنہا سے روایت ہے ، کہتی ہیں کہ میں رسول اللہ ﷺ کے سر مبارک میں کن"}
{"hadithnumber": "132", "text": "حضرت اسماء بنت ابی بکر رضی اللہ عنہا سے روایت ہے کہ ایک عورت نے رسول اللہ ﷺ سے سوال کیا کہ آپ ہمیں ب"}
{"hadithnumber": "133", "text": "ام المومنین سیدہ عائشہ رضی اللہ عنہا سے روایت ہے کہ حضرت فاطمہ بنت ابی حبیش رضی اللہ عنہا نے عرض کیا"}
{"hadithnumber": "134", "text": "زوجۂ رسول ﷺ سیدہ اُمِ سلمہ رضی اللہ عنہا سے روایت ہے کہ زمانۂ رسول ﷺ میں ایک عورت کا خون بہت بہتا"}
{"hadithnumber": "135", "text": "حضرت زینب بنت ابی سلمہ رضی اللہ عنہما سے روایت ہے کہ انھوں نے زینب ( کی بہن اُمِ حبیبہ ) بنت جحش رضی"}
{"hadithnumber": "136", "text": "سمی رحمہ اللہ جو کہ ابوبکر بن عبدالرحمن رحمہ اللہ کے آزاد کردہ غلام تھے ، روایت کرتے ہیں کہ قعقاع بن"}
{"hadithnumber": "137", "text": "ہشام بن عروہ رحمہ اللہ اپنے باپ عروہ رحمہ اللہ سے روایت کرتے ہیں ، انھوں نے کہا کہ مستحاضہ عورت پر ا"}
{"hadithnumber": "138", "text": "سیدہ عائشہ رضی اللہ عنہا زوجۂ رسول ﷺ سے روایت ہے کہ رسول اللہ ﷺ کے پاس ایک بچہ لایا گیا ، اس نے آپ"}
{"hadithnumber": "139", "text": "حضرت اُم قیس بنت محصن رضی اللہ عنہا سے روایت ہے کہ وہ اپنے اس چھوٹے بچے کو لے کر رسول اللہ ﷺ کی خدمت"}
{"hadithnumber": "140", "text": "یحیی بن سعید رحمہ اللہ سے روایت ہے کہ ایک اعرابی ( دیہاتی صحابی رضی اللہ عنہ ) مسجد ( نبوی ) میں داخ"}
{"hadithnumber": "141", "text": "عبداللہ بن دینار رحمہ اللہ روایت کرتے ہیں کہ میں نے حضرت عبداللہ بن عمر رضی اللہ عنہما کو دیکھا کہ و"}
{"hadithnumber": "142", "text": "عبید بن سباق رحمہ اللہ سے روایت ہے کہ یقیناً رسول اللہ ﷺ نے جمعوں میں سے کسی جمعہ میں فرمایا :’’ اے"}
{"hadithnumber": "143", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا :’’ اگر میں اپنی امت پر مشقت نہ سمجھ"}
{"hadithnumber": "144", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ اگر آپ ﷺ کی امت پر مشکل اور شاق نہ ہوتا تو آپ ﷺ ان کو ہر و"}
{"hadithnumber": "145", "text": "یحیی بن سعید انصاری رحمہ اللہ سے روایت ہے کہ رسول اللہ ﷺ یہ ارادہ فرما چکے تھے کہ دو لکڑیاں لے لیں ،"}
