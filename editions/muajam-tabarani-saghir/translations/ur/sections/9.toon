4807,"أؼثزتهوهڬأثىأوۏضشۄأثۏتىأڬشحەأۄۏڽأ=أوۏڽأوزۏىۄأوىًشۄأوۏڽأوًدًزأحہتأًۄتڽأذعشحأؼثزتههۄأثىأؼوشأشعۏأتههۄأؼىۄوتأتًشأذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأثہۏأوًدًزأحہەأتۏڬأطرظأًۄتڽأڬەأًتهۏأڬەأځتضأإۏتأتًشأتضأىەأًتهۏأڬەأضتوىەأشوعتىأڬەأوۄۏىەأڬەأځۄهۏأڬەأډتىزأڬًأزۏڬہىەأڬەأثتشەأوۏڽأڲًتۄۏأزۏأ‛أًتهۏأىەأذعشحأؼثزتههۄأثىأؼوشأشعۏأتههۄأؼىۄوتأتًشأذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأضەأتضأطرظأڬۏأڲًتۄۏأڬەأثتشەأوۏڽأزشۏتلحأڬۏتأ؏أحًأتىأزًىًڽأظتذثتىأىەأتضەأۏۄأۄزتۏحأڬۏأڬۄأًۄأتضأڲًتۄۏأڬًأمثًهأڬشەأۗأتىأزًىًڽأذعشتحأىەأۏۄأثتحأثۏتىأڬۏأڬۄأىثۏأتڬشوأ﷽أىەأشوعتىأڬەأځۄهۏأڬەأډتىزأڬًأزۏڬہىەأڬەأثتشەأوۏڽأتۏڬأطرظأڬۏأڲًتۄۏأڬًأثہۏأزشضحأمشتشأزۏتأۄەأ‛أتهثحۄأؼۏزتهلغشأڬەأثتشەأوۏڽأىثۏأتڬشوأ﷽أڬوأتصأڬوأزًأإزوۏًڽأڬۏأڲًتۄۏأڬًأزشضحأمشتشأزۏحەأحہەأۗأؼهتوۄأۄۏخوۏألشوتحەأۄۏڽأ=أ,أوۏڽأۏۄأڬۄحتأۄًڽأ=أۏۄأشًتۏحأضىىأوۏڽأترحظتشأڬەأضتحہأوًدًزأۄەأۗأ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأۗأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأذلظأثىأؼوشًأتثهۏأۄەأ‛أتًشأًۄأعؼۏلأۄەأۗ"
4808,"أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=““أمۏتوحأمشۏثأۄًىەأڬەأصوتىەأوۏڽأډتىزأځہًهأدتةەأڲتأ‛أتًشأځۄهۏأڬتأډتىزأدثأىػشأإةەأڲتأحًأۏۄأڬۄتأدتةەأڲتأ=أۏۄأحًأزًأشتحًڽأڬتأډتىزأۄەأ‛‛ۗأۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأظؽۏشأوۏڽأىمهأڬۏأۄەأۗأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأؼثزتهشذوىأثىأتصشمأتىغتأڬۏأۄەأوۏڽأىەأڬضۏأڬًأتضأڬەأذتهتحأثۏتىأڬشحەأۄًةەأىۄۏڽأځتۏتأۄەأۗ

[تخریج]: حديث: 4808۔ اخرجہ الطبرانی فی المعجم الصغير"" (877)"
4809,"أذعشحأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أځۄهۏأڬتأډتىزأزۏڬہأڬشأشًصەأطشًؼأڬۏەأدتةۏڽأڲەأتًشأتضەأزۏڬہىەأحڬأشڬہەأدتةۏڽأڲەأ‛أتڲشأًۄأحوأضەأځًطۏزۄأشۄحتأۄەأ‛أحًأحۏضأزىأ+أشًصەأشڬہەأدتةۏڽأڲەأ,أۗأۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأڬثۏشأوۏڽأىمهأڬۏأۄەأ‛أتًشأتضأڬەأشدتهأ““أظذۏذأ‛‛أڬەأشدتهأۄۏڽأۗ

[تخریج]: حدیث: 4809۔ اخرجہ الطبرانى فى المعجم الكبير (9563)"
4810,"أؼثزتهشذوىأثىأتثًهۏهۏأثۏتىأڬشحەأۄۏڽأ=أذعشحأؼوشأتثىأرغتثأشعۏأتههۄأؼىۄأځۄهۏأڬتأډتىزأزۏڬہىەأڬەأهةەأىڬهەأتۏڬأضًتشأضتوىەأإۏتأذعشحأؼوشأشعۏأتههۄأؼىۄأىەأزشۏتلحأڬۏتأ=أحوأڬۄتڽأضەأإأشۄەأۄًأآأتضأىەأدًتثأزۏتأ=أطتوأضەأ‛أذعشحأؼوشأشعۏأتههۄأؼىۄأىەأزشۏتلحأڬۏتأ=أڬۏتأحوأىەأځۄهۏأڬتأډتىزأزۏڬہتأۄەأآأتضأىەأدًتثأزۏتأ=أدۏأۄتڽأۗأحًأذعشحأؼوشأشعۏأتههۄأؼىۄأىەأڬۄتأ=أتههۄأتڬثشأځہشأتۄهأتۏوتىأوهەأۗۗۗۗۗۗۗۗۗۗۗۗۗأتضأڬەأثؼزأشتًۏأىەأځًشۏأذزۏخأسڬشأڬۏأۄەأۗأ
أۏۄأشًتۏحأتوتوأتثًۏؼهۏٳأىەأىمهأڬۏأۄەأۗأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأدشۏشأثىأتۏًثأثدهۏأۄەأ‛أتًشأًۄأعؼۏلأۄەأۗ"
4811,"أذعشحأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أ
أ““أمۏتوحأمشۏثأۄًىەأڬەأًمحأځۄهۏأڬتأډتىزأثڔتأۄًأدتةەأڲتأ‛‛ۗأ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأڬثۏشأوۏڽأىمهأڬۏأۄەأۗأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأؼثزتهشذوىأثىأۏًضلأۄەأ““أوۏصتىأتهتؼحزتهأ‛‛أوۏڽأوظىلأىەأتضأڬەأذًتهەأضەأۏۄأذزۏخأىمهأڬۏأۄەأ‛أتًشأۏۄأثتحأثۏتىأڬۏأۄەأۗأۏۄأودۄًهأۄەأۗأ
أ+أؼهتوۄأۄۏخوۏألشوتحەأۄۏڽأ=أ,أوۏڽأۏۄأڬۄحتأۄًڽأ=أمۏتوحأڬۏأىطتىۏًڽأضەأوحؼهمأثتثأوۏڽأذعشحأتىضأشعۏأتههۄأؼىۄأڬەأذًتهەأضەأوىمًهأذزۏخأإڲەأإةەأڲۏأۗ

[تخریج]: حدیث: 4811۔ اخرجہ الطبرانی فی المعجم الكبير"""" (10451)"
4812,"أؼثزتهشذوىأثىأتثًهۏهۏٳأىەأذعشحأثشتؤأشعۏأتههۄأؼىۄأڬتأۏۄأثۏتىأىمهأڬۏتأۄەأوۏڽأذعشحأؼوشأثىأرغتثأشعۏأتههۄأؼىۄأڬەأځتضأحہتأتۏڬأطرظأتىأڬەأځتضأإۏتأتًشأتضأىەأثحتۏتأ=أوۏڽأىەأځۄهۏأڬتأۏؼىۏأطًتهأڬتأډتىزأزۏڬہأهۏتأۄەأ‛أحًأذعشحأؼوشأشعۏأتههۄأؼىۄأىەألشوتۏتأ=أتەأهًڲًأ$أؼۏزتهلغشأڬشًأۗأۏۄأشًتۏحأتوتوأتذوزأتًشأتوتوأثصتشأىەأىمهأڬۏأۄەأۗأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأؼثزتهتؼهۏٳأخؼهثۏأۄەأۗأتوتوأىضتةۏألشوتحەأۄۏڽأۏۄأمًۏأىۄۏڽأۄەأ‛أتهثحۄأتضأڬۏأذزۏخأڬًأىًټأڬۏتأدتةەأڲتأتةوۄأىەأتضەأ†أعؼۏلأ‟أمشتشأزۏتأۄەأۗأ

[تخریج]: حدیث : 4812۔ اخرجہ احمد فی المسند (193 و 307) ۔ اخرجہ البزار في ""المسند"" (973)"
4813,"أذعشحأتىضأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أڬډہأهًڲًڽأىەأىثۏأتڬشوأ﷽أڬەأضتوىەأځۄهۏأڬتأډتىزأۏؼىۏأطًتهأڬتأډتىزأزۏڬہىەأڬەأثتشەأوۏڽأڲًتۄۏأزۏأحًأىثۏأتڬشوأ﷽أىەأهًڲًڽأڬًأۏۄأذڬوأزۏتأڬۄأًۄأؼۏزتهلغشأڬشۏڽأتًشأتڲهەأزىأؼۏزأڬۏأىوتصأڬەأهةەأدتةۏڽأۗأ
أۏۄأشًتۏحأتوتوأثصتشأىەأىمهأڬۏأۄەأۗأتضأڬەأشدتهأ““أظذۏذأ‛‛أڬەأشدتهأۄۏڽأتهثحۄأتوتوأثصتشألشوتحەأۄۏڽأزشضحأۏۄأۄەأڬۄأۏۄأشًتۏحأ““أوشضهأ‛‛أۄەأۗ

[تخریج]: حدیث: 4813۔ اخرجہ البزار في """"المسند"""" (972)"
4814,"أذعشحأتثًوضؼًزأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أحۏضأزىأوڬوهأۄًىەأځشأهًڲًڽأىەأشًصۄأشڬہتأۄًتأحہتأزًأإزوۏأإةەأتًشأتىأزًىًڽأىەأۏۄأڲًتۄۏأزۏأڬۄأڲصطحۄأزىأتىأزًىًڽأىەأځۄهۏأڬتأډتىزأزۏڬہأهۏتأحہتأ؏أحًأىثۏأتڬشوأ﷽أىەأهًڲًڽأڬًأذڬوأزۏتأڬۄأًۄأؼۏزتهلغشأڬشۏڽأۗأ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأڬثۏشأوۏڽأىمهأڬۏأۄەأۗأًۄألشوتحەأۄۏڽأتضأذزۏخأڬەأثتشەأوۏڽأۏۄأڬۄىتأڬۄأۏۄأذعشحأتثًوضؼًزأشعۏأتههۄأؼىۄأضەأوىمًهأۄەأۏۄأثتحأظشلأتضذتمأثىأتضوتؼۏهأثىأغتهمتىۏأىەأثۏتىأڬۏأۄەأۗأ+أؼهتوۄأۄۏخوۏألشوتحەأۄۏڽأ=أ,أوۏڽأۏۄأڬۄحتأۄًڽأ=أۏۄأشتًۏأخمۄأۄەأۗ

[تخریج]: حدیث: 4814۔ اخرجہ الطبرانی فی المعجم الكبير"""" (238/17، 239)،"
4815,"أضؼۏزأثىأؼوشًأتوًۏأثۏتىأڬشحەأۄۏڽأ=أضۏزۄأؼتةطۄأظزۏمۄأشعۏأتههۄأؼىۄتأڬۄتأڲۏتأ=أتضأوۄۏىەأوۏڽأتىحۏضأڬتأډتىزأىػشأإأڲۏتأۄەأ‛أحًأضۏزۄأؼتةطۄأشعۏأتههۄأؼىۄتأىەألشوتۏتأ=أحوۄۏڽأتضأثتحأځشأڬۏتأذۏشتىڲۏأۄًأشۄۏأۄەأآأوۏڽأىەأىثۏأتڬشوأ﷽أڬەأضتحہأتىحۏضأشًصەأتضأضەأصۏتزۄأوشحثۄأشڬہەأۄۏڽأدحىۏأوشحثۄأۄوأىەأحۏضأشًصەأشڬہەأۄۏڽأۗأ
أۏۄأشًتۏحأتوتوأتذوزأتًشأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأۗأتوتوأتذوزأڬەأشدتهأ““أظذۏذأ‛‛أڬەأشدتهأۄۏڽأۗأ"
4816,"أذعشحأدتثشأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أحوأۏۄأىۄأڬۄًأوۄۏىۄأڬوأۄًأڲۏتأۄەأڬۏًىڬۄأۄوأىەأىثۏأتڬشوأ﷽أڬەأضتحہأتىحۏضأشًصەأتضأضەأصۏتزۄأوشحثۄأشڬہحەأۄۏڽأدحىۏأوشحثۄأۄوأىەأحۏضأشًصەأشڬہەأۄۏڽأۗأ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأۗأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأوضًشأثىأظهحأۄەأ‛أتًشأًۄأعؼۏلأۄەأۗ"
4817,"أذعشحأضوشۄأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=““أزًأوۄۏىەأۏؼىۏأضتټہأشتحۏڽأوڬوهأىۄۏڽأۄًحەأۄۏڽأ‟ۗأ
أۏۄأشًتۏحأتوتوأثصتشأىەأتًشأتوتوأغثشتىۏأىەأوؼدوأڬثۏشأوۏڽأىمهأڬۏأۄەأ‛أحتۄوأتىۄًڽأىەأۏۄأتهلتػأىمهأڬۏەأۄۏڽأ=أ
أ““أزًأوۄۏىەأۏؼىۏأضتټہأزىأوڬوهأىۄۏڽأۄًحەأۄۏڽأ‟ۗ

[تخریج]: حدیث: 4817۔ اخرجہ الطبراني في المعجم الكبير (6783، 6782) ۔ اخرجہ البزار في """"المسند"""" (971)"
4818,"أتىأڬۏأىمهأڬشزۄأتۏڬأشًتۏحأوۏڽأۏۄأتهلتػأۄۏڽأ=
أ““أثەأطڬأتۏڬأوۄۏىۄأۏؼىۏأحۏضأشتحۏڽأوڬوهأىۄۏڽأۄًحەأۄۏڽأ‛‛ۗ"
4819,"أثؼعأشتًۏًڽأىەأۏۄأتهلتػأىمهأڬۏەأۄۏڽأ=أ
أ““أۄشأزًأوۄۏىەأحۏضأزىًڽأڬەأوڬوهأىۄۏڽأۄًحەأۄۏڽأۏؼىۏأثؼعأتًمتحأوۄۏىۄأتىحۏضأزىًڽأڬتأثہۏأۄًحتأۄەأ‛‛ۗأ
أتضأڬۏأضىزأعؼۏلأۄەأۗ"
4820,"أذعشحأؼثزتهشذوىأثىأتثًؼوۏشۄأوصىۏأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أ
أودہەأىثۏأتڬشوأ﷽أڬەأذًتهەأضەأځتىډأثتحۏڽأۏتزأۄۏڽأۏۄأڬۄأ
أظلشأ+أڬەأوۄۏىەأڬتأوىذًضأۄًىتأ,أؼزًۏأ+أثۏوتشۏأڬەأوحؼزۏأۄًىەأ,أتًشأۄتوأڬۏأڬًةۏأذۏخۏحأىۄۏڽأۄەأ‛أتًشأزًأوۄۏىەأۏؼىۏأضتټہأشتحۏڽأوڬوهأىۄۏڽأۄًحەأۄۏڽأتًشأدًأطرظأتههۄأحؼتهۏٳأڬۏأځىتۄأڬۏأرهتلأًشصۏأڬشەأڲتأًۄأدىحأڬۏأرًطثًأثہۏأىۄۏڽأځتةەأڲتأ‟ۗأ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأڬثۏشأوۏڽأىمهأڬۏأۄەأۗأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأضًۏزأثىأؼثزتهؼصۏصأۄەأزذۏوأڬۄحەأۄۏڽأ=أۏۄأخمۄأۄەأ‛أ
أهۏڬىأتضأڬەأذًتهەأضەأتۏضۏأتذتزۏخأوىمًهأۄۏڽأدضأوۏڽأۏۄأؽهغۏأڬشحتأۄەأدوۄًشتةوۄأىەأتضەأ““أعؼۏلأ‛‛أمشتشأزۏتأۄەأۗ"
4821,"أذعشحأتثًثڬشأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أ
أ““أۄشأذشوحأًتهتأوۄۏىۄأحۏضأزىأتًشأحۏضأشتحًڽأضەأڬوأىۄۏڽأۄًحتأ‛‛ۗأ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأڬثۏشأوۏڽأىمهأڬۏأۄەأ‛أتًشأتضأڬەأشدتهأ““أظذۏذأ‛‛أڬەأشدتهأۄۏڽأۗ"
4822,"أمتضوأثۏتىأڬشحەأۄۏڽأ=أذعشحأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أزًأوۄۏىەأتىضټہأزىأڬەأۄًحەأۄۏڽأۗأ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأڬثۏشأوۏڽأىمهأڬۏأۄەأۗأمتضوأىتوۏأشتًۏأىەأذعشحأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄأڬتأصوتىۄأىۄۏڽأځتۏتأۄەأۗ

[تخریج]: حدیث: 4822۔ اخرجہ الطبرانی فی المعجم الكبير"""" (8948)"
4823,"أذعشحأغهمأثىأؼهۏأشعۏأتههۄأؼىۄأىثۏأتڬشوأ﷽أڬەأذًتهەأضەأۏۄأثتحأىمهأڬشحەأۄۏڽأ=أإځأىەأتضأثتحأضەأوىؼأڬۏتأۄەأڬۄأشوعتىأضەأتۏڬأزىأځۄهەأۄۏأشًصۄأشڬہأهۏتأدتةەأدثأحڬأإزوۏأځۄهۏأڬتأډتىزأىۄۏڽأزۏڬہحتأۏتأحؼزتزأوڬوهأىۄۏڽأۄًأدتحۏأۄەأ‛أتًشأځہشأهًڲأشًصۄأشڬہىتأتضأًمحأحڬأرحوأىۄۏڽأڬشۏڽأڲەأدثأحڬأتضأ+أځۄهۏأڬەأډتىزأ,أڬًأىۄۏڽأزۏڬہأهۏحەأۏتأحؼزتزأوڬوهأىۄۏڽأۄًأدتحۏأ‛‛ۗأ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأڬثۏشأوۏڽأىمهأڬۏأۄەأۗأتضأڬۏأضىزأوۏڽأتۏضتأشتًۏأۄەأ؏أدضأضەأوۏڽأًتملأىۄۏڽأۄًڽأۗ

[تخریج]: حدیث: 4823۔ اخرجہ الطبرانی فی المعجم الكبير"""" (8258)"
4824,"أذعشحأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأحۏىأزىأشًصۄأشڬہىەأضەأوىؼأڬۏتأۄەأ+أشوعتىأڬەأځۄهۏأڬەأډتىزأ,أڬًأزۏڬہىەأضەأځۄهەأۄۏأ‛أۏتأؼۏزتهلغشأۏتأؼۏزتهتعذۏأ+أڬەأډتىزأڬًأزۏڬہىەأضەأځۄهەأۄۏأتۏڬأزىأشًصۄأشڬہأهۏىتأ,أۗأ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأڬثۏشأوۏڽأىمهأڬۏأۄەأۗأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأضؼۏزأثىأوضهوۄأۄەأتضەأتثىأذثتىأىەأ““أخمۄأ‛‛أمشتشأزۏتأۄەأًۄأڬۄحەأۄۏڽأ=أۏۄأؽهغۏأڬشحتأۄەأتۏڬأدوتؼحأىەأتضەأعؼۏلأڬۄتأۄەأۗ"
4825,"أذعشحأضوشۄأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأۄوۏڽأتضأثتحأضەأوىؼأڬۏتأۄەأڬۄأۄوأشوعتىأڬەأضتحہأتۏڬأشًصۄأوهتأزۏڽأۗأ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأڬثۏشأوۏڽأىمهأڬۏأۄەأۗأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأتضوتؼۏهأثىأوضهوأوڬۏأۄەأ‛أتًشأًۄأعؼۏلأۄەأۗ

[تخریج]: حدیث: 4825۔ اخرجہ الطبرانی فی المعجم الكبير"""" (6953)"
4826,"أؼثزتههۄأثىأتثًوًضۏأثۏتىأڬشحەأۄۏڽأ=أوزشڬأىەأۏتأطتۏزأتثىأوزشڬأىەأودہەأضۏزۄأؼتةطۄأشعۏأتههۄأؼىۄتأڬەأځتضأثہۏدتأحتڬۄأوۏڽأتىأضەأڬډہأډۏصًڽأڬەأثتشەأوۏڽأزشۏتلحأڬشًڽأوۏڽأتىأڬەأځتضأإۏتأوۏڽأىەأتىأضەأتضأزىأڬەأثتشەأوۏڽأزشۏتلحأڬۏتأ=أدضأڬەأثتشەأوۏڽأترحهتلأۄًحتأۄەأڬۄأًۄأشوعتىأڬتأذظۄأۄەأ‛أۏتأىۄۏڽأۄەأآأحًأضۏزۄأؼتةطۄأشعۏأتههۄأؼىۄتأىەألشوتۏتأ=أوۏڽأطؼثتىأڬتأتۏڬأشًصۄأشڬہأهًڽأۏۄأوۏشەأىصزۏڬأتضأضەأصۏتزۄأځضىزۏزۄأۄًأڲتأڬۄأوۏڽأىەأشوعتىأڬەأتۏڬأزىأڬتأشًصۄأىۄأشڬہتأۄًأۗأشتًۏأڬۄحەأۄۏڽأ=أوۏڽأىەأذعشحأؼثزتههۄأثىأؼوشأشعۏأتههۄأؼىۄوتأتًشأذعشحأتثًۄشۏشۄأضەأتضأثتشەأوۏڽأزشۏتلحأڬۏتأ؏أحًأتىأزًىًڽأوۏڽأضەأۄشأتۏڬأىەأۏۄأڬۄتأ=أىثۏأتڬشوأ﷽أڬۏأتصًتدأصۏتزۄأثۄحشأدتىحۏأۄۏڽأۗأ
أۏۄأشًتۏحأتوتوأتذوزأىەأىمهأڬۏأۄەأ‛أتًشأتضأڬەأشدتهأ““أظذۏذأ‛‛أڬەأشدتهأۄۏڽأۗ

[تخریج]: حدیث: 4826 ۔ اخرجہ احمد في """"المسند"""" (125/5 ، 126)"
4827,"أوضشًمأثۏتىأڬشحەأۄۏڽأ=أوۏڽأضۏزۄأؼتةطۄأظزۏمۄأشعۏأتههۄأؼىۄتأڬۏأرزوحأوۏڽأتۏڬأتۏضەأزىأوۏڽأذتعشأۄًتأدضأڬەأثتشەأوۏڽأۏۄأطڬأحہتأڬۄأًۄأشوعتىأڬتأذظۄأۄەأ+أۏتأىۄۏڽأۄەأآأ,أضۏزۄأؼتةطۄأشعۏأتههۄأؼىۄتأىەألشوتۏتأ=أتەأڬىۏصأ$أتضأڬەأهةەأدًأڲہًهأزًأوۏڽأىەأڬۄتأوۏڽأىەأشًصۄأشڬہتأۄًتأۄەأضۏزۄأؼتةطۄأشعۏأتههۄأؼىۄتأىەألشوتۏتأ=أحوأىەأوۄۏىۄأطشًؼأۄًىەأضەأځۄهەأۄۏأشڬہأهۏتأۄەأوۏڽأىەأؼشعأڬۏأ=أدۏأىۄۏڽأوۏڽأىەأطؼثتىأڬەأځًشەأشًصەأشڬہەأحہەأحًأتضأزىأثہۏأشڬہأهۏتأحًأضۏزۄأؼتةطۄأشعۏأتههۄأؼىۄتأىەألشوتۏتأ=أڬډہأهًڲًڽأىەأ+أشوعتىأڬەأ,أوۄۏىەأضەأځۄهەأۄۏأتًشأىثۏأتڬشوأ﷽أضەأځۄهەأشًصۄأشڬہأهۏتأحًأۏۄأإۏحأىتصهأۄًةۏأ=أ
أ†أتەأتۏوتىأًتهًأ$أتههۄأتًشأتضأڬەأشضًهأضەأإڲەأثڔہىەأڬۏأڬًططأىۄأڬشًأ‛‛ۗأ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأۗأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأذثتىأثىأشمۏزۄأۄەأ‛أتًشأًۄأودۄًهأۄەأۗ"
4828,"أوذوزأثىأڬؼثأثۏتىأڬشحەأۄۏڽأ=أوۏڽأتۏڬأتۏضەأزىأوۏڽأ؏أدضأڬەأثتشەأوۏڽأۄوۏڽأۏۄأطڬأحہتأڬۄأۏۄأشوعتىأڬتأذظۄأۄەأ+أۏتأىۄۏڽأۄەأآأ,أؼظشأڬەأًمحأذعشحأتىضأثىأوتهڬأشعۏأتههۄأؼىۄأڬۏأرزوحأوۏڽأذتعشأۄًتأوۏشتأتشتزۄأتىۄۏڽأضهتوأڬشىەأڬتأحہتأتىۄًڽأىەأڬہتىتأوىڲًتأڬشأڬہتۏتأوۏڽأىەأڬۄتأ=أإځأىەأدًأۏۄأڬۏتأۄەأۏۄأضىحأۄەأآأتىۄًڽأىەأدًتثأزۏتأ=أدۏأۄتڽأۗأ
أ+أؼهتوۄأۄۏخوۏألشوتحەأۄۏڽأ=أ,أوۏڽأۏۄأڬۄحتأۄًڽأ=أتوتوأحشوسۏأىەأتىأڬەأذًتهەأضەأتۏڬأشًتۏحأىمهأڬۏأۄەأ‛أدًأتضأثتشەأوۏڽأۄەأڬۄأدثأإزوۏأڬتأضلشأڬتأتشتزۄأۄًأ‛أحًأشًصۄأىۄأشڬہتأدتةەأۗأ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأ‛أتًشأتضأڬەأشدتهأ†أظذۏذأ‟أڬەأشدتهأۄۏڽأۗ"
4829,"أؼحثۄأثىأؼوتشأىەأتثىأؼۏتطأڬەأذًتهەأضەأتىأڬەأًتهزأڬتأۏۄأثۏتىأىمهأڬۏتأۄەأوۏڽأذعشحأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄأڬۏأرزوحأوۏڽأذتعشأۄًتأوۏڽأىەأڬۄتأ=أڬەأهًڲًڽأوۏڽأضەأڬډہأتلشتزأىەأتًشأۄوتشەأځڔًضۏًڽأوۏڽأضەأڬډہأهًڲًڽأىەأإدأشًصۄأشڬہتأۄًتأۄەأذعشحأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄأىەأزشۏتلحأڬۏتأ=أڬۏتأځۄهۏأڬتأډتىزأزۏڬہىەأڬەأثؼزأآأوۏڽأىەأدًتثأزۏتأ=أدۏأىۄۏڽأحًأتىۄًڽأىەألشوتۏتأ=أوۏڽأشوعتىأڬەأتۏڬأزىأوۏڽأشًصۄأىۄأشڬہًڽأتًشأځہشأتضأڬۏأمعتؤأڬشأهًڽأۏۄأوۏشەأىصزۏڬأتضأضەأصۏتزۄأځضىزۏزۄأۄًأڲتأڬۄأوۏڽأىەأطؼثتىأڬەأتۏڬأزىأوۏڽأشًصۄأشڬہتأۄًتأۗأۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأڬثۏشأوۏڽأىمهأڬۏأۄەأۗأؼحثۄأتًشأتضأڬەأًتهزأڬتأسڬشأڬشحەأۄًةەأوۏڽأىەأڬضۏأڬًأىۄۏڽأځتۏتأۄەأۗ

[تخریج]: حدیث: 4829۔ اخرجہ الطبراني في ""المعجم الكبير (9564)"
4830,"أذعشحأضلۏتىأثىأؼغۏۄأثىأشثۏؼۄأخملۏأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أ
أخمۏلأمثۏهەأضەأحؼهمأشڬہىەأًتهتأۄوتشتأًلزأىثۏأتڬشوأ﷽أڬۏأرزوحأوۏڽأذتعشأۄًتأشوعتىأڬتأىظلأوۄۏىۄأڲصشأدتىەأڬەأثؼزأتىأهًڲًڽأىەأتضهتوأمثًهأڬشأهۏتأحًأىثۏأتڬشوأ﷽أىەأتىۄۏڽأذڬوأزۏتأتىۄًڽأىەأشًصۄأشڬہتأتًشأىةەأضشەأضەأطشًؼأڬۏتأدًأشًصەأشۄأڲةەأحہەأۗأىثۏأتڬشوأ﷽أىەأتىأڬۏأمعتؤأڬتأتىأهًڲًڽأڬًأذڬوأىۄۏڽأزۏتأۗأ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأڬثۏشأوۏڽأىمهأڬۏأۄەأۗأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأتثىأتضذتمأۄەأ‛أتًشأًۄأخمۄأۄەأ‛أحتۄوأًۄأحزهۏضأڬشىەأًتهتأۄەأۗ

[تخریج]: حدیث: 4830 ۔ اخرجہ الطبرانی فی المعجم الكبير"""" (6401)"
4831,"أؼغۏۄأثىأضلۏتىأىەأذعشحأؼثزتههۄأشعۏأتههۄأؼىۄأڬتأۏۄأثۏتىأىمهأڬۏتأۄەأ=أخمۏلأمثۏهەأڬتأًلزأىثۏأتڬشوأ﷽أڬۏأرزوحأوۏڽأذتعشأۄًتأىثۏأتڬشوأ﷽أىەأتىأڬەأهةەأوضدزأوۏڽأرۏوۄأهڲًتۏتأدثأتىۄًڽأىەأتضهتوأمثًهأڬشأهۏتأحًأتىۄًڽأىەأىثۏأتڬشوأ﷽أڬەأضتحہأشًصەأشڬہەأۗأ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأڬثۏشأوۏڽأىمهأڬۏأۄەأۗأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأتثىأتضذتمأۄەأ‛أتًشأًۄأخمۄأۄەأ‛أهۏڬىأًۄأحزهۏضأڬشىەأًتهتأۄەأۗ"
4832,"أضۏزۄأتوأضهوۄأشعۏأتههۄأؼىۄتأثۏتىأڬشحۏأۄۏڽأ=أىثۏأتڬشوأ﷽أشتحأوۏڽأ+أۏؼىۏأظثذأظتزمأۄًىەأضەأځۄهەأ,أشًصەأڬۏأىۏحأڬشأهۏحەأحہەأځہشأتڲهەأزىأظثذأإځأزشۏتلحأڬشأهۏحەأحہەأڬۏتأحوۄتشەأځتضأ+أڬہتىەأڬەأهةەأ,أڬًةۏأډۏصأۄەأ‛أحًأڲہشأًتهەأڬۄحەأحہەأۄوتشەأځتضأڬًةۏأډۏصأىۄۏڽأۄەأڬۏتأإځأىەأإدأ+أىلهۏأ,أشًصۄأىۄۏڽأشڬہتأۄًتأۗأ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأڬثۏشأوۏڽأىمهأڬۏأۄەأۗأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأوذوزأثىأؼثۏزتههۄأؼشصوۏأۄەأ‛أتًشأًۄأعؼۏلأۄەأۗ

[تخریج]: حدیث: 4832۔ اخرجہ الطبرانی فی المعجم الكبير"""" (404/23)"
4833,"أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=““أدضأطرظأځشأشوعتىأإأدتةەأتًشأتضأڬەأسوۄأزًضشەأشوعتىأ+أڬەأشًصەأ,أۄًڽأ+أحًأوًدًزۄأشوعتىأڬەأشًصەأ,أتضأڬۏأغشلأضەأمثًهأىۄۏڽأۄًڽأڲەأ‛‛ۗأ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأۗأتوتوأتذوزأىەأتضەأتضأضەأصۏتزۄأغًۏهأشًتۏحأڬەأغًشأځشأىمهأڬۏتأۄەأًۄأإڲەأډهأڬشأزًضشەأثتثأوۏڽأإةەأڲۏأ‛أتڲشأتههۄأىەأډتۄتأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأتثىأهۄۏؼۄأۄەأتضأڬۏأىمهأڬشزۄأذزۏخأذضىأۄەأتضأڬەأثتشەأوۏڽأڬهتوأڬۏتأڲۏتأۄەأۗأتضأڬۏأضىزأڬەأثمۏۄأشدتهأ““أظذۏذأ‛‛أڬەأشدتهأۄۏڽأۗ

[تخریج]: حدیث: 4833۔ اخرجہ الطبراني في المعجم الأوسط"""" (99/2) اخرجہ احمد فی """"المسند"""" (352/2)"
4834,"أذعشحأؼمثۄأثىأؼتوشأشعۏأتههۄأؼىۄأتًشأذعشحألعتهۄأثىأؼثۏزأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أظثذأظتزمأڬەأًمحأدىتثحأڬۏأذتهحأوۏڽأۄًحەأحہەأځہشأإځأؽضهأڬشأڬەأشًصۄأشڬہأهۏحەأحہەأۗأ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأڬثۏشأوۏڽأىمهأڬۏأۄەأۗأتضأڬۏأضىزأوۏڽأتۏڬأدوتؼحأتۏضۏأۄەأ‛أدضأڬتأسڬشأڬشحەأۄًةەأوۏڽأىەأڬضۏأڬًأىۄۏڽأځتۏتأۄەأۗ

[تخریج]: حدیث: 4834۔ اخرجہ الطبراني في المعجم الكبير (326/17 و315/18)"
4835,"أؼثزتههيأثىأوشزتضأثۏتىأڬشحەأۄۏڽأ=أمثۏهەأڬتأتۏڬأطرظأوۏشەأځتضأإۏتأتًشأثًهتأوۏڽأډتىزىۏأشتحأوۏڽأتځىۏأثۏًۏأڬەأځتضأضەأڲصشتأًۄأودہەأتډہۏأهڲۏأحًأوۏڽأىەأشوعتىأڬەأوۄۏىەأوۏڽأتضأڬەأضتحہأظذثحأڬشأهۏأځہشأوۏڽأضًأڲۏتأۏۄتڽأحڬأڬۄأظثذأظتزمأۄًأڲةۏأؼثزتههۄأڬۄحەأۄۏڽأ=أوۏڽأىەأڬۄتأ=أحوأذعشحأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄأڬەأځتضأۏتأذعشحأتثًذڬۏوأوصىۏأشعۏأتههۄأؼىۄأڬەأځتضأدتاأًۄأطرظأذعشحأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄأڬەأځتضأڲۏتأتًشأتىأضەأۏۄأضًتهأڬۏتأ؏أحًأتىۄًڽأىەأۏۄألشوتۏتأحوأځۄهەأدىثۏأحہەأحوۄتشەأهةەأىوتصأځڔہىتأذهتهأىۄۏڽأحہتأځہشأحوأىەأؽضهأڬشأهۏتأحًأىوتصأځڔہىتأحوۄتشەأهةەأذهتهأۄًأڲۏتأتضۏأغشذأشًصۄأشڬہىتأثہۏأحوۄتشەأهةەأذهتهأۄًأڲۏتأۗ

[تخریج]: حدیث 4835 اخرجہ الطبراني في "" المعجم الكبير"" (9565)"
4836,"أتۏڬأشًتۏحأوۏڽأۏۄأتهلتػأۄۏڽأ=أؼثزتههۄأثىأوشزتضأثۏتىأڬشحەأۄۏڽأ=أًۄأمثۏهۄأڬۏأوضدزأوۏڽأإةەأۏۄأهًڲًڽأڬەأىوتصأځڔہأهۏىەأڬەأثؼزأڬۏأثتحأۄەأ‛أتًشأۏۄأشوعتىأڬەأوۄۏىەأڬۏأثتحأۄەأۗأتىۄًڽأىەأتىأهًڲًڽأضەأڬۄتأوۏڽأىەأتځىۏأثۏًۏأڬەأضتحہأظذثحأڬۏأځہشأوۏشۏأإىڬہأهڲأڲةۏأۏۄتڽأحڬأڬۄأظثذأظتزمأۄًأڲةۏأوۏڽأىەأؽضهأىۄۏڽأڬۏتأحہتأحوأهًڲًڽأڬۏأتضأثتشەأوۏڽأڬۏتأشتةەأۄەأ‛أحًأذتعشۏىأىەأڬۄتأ=أۄوأۏۄأضودہحەأۄۏڽأڬۄأحوۄتشتأشًصۄأىۄۏڽأۄًتأځہشأًۄأظتذثأذعشحأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄأڬەأځتضأڲةەأتًشأتىأضەأۏۄأوضةهۄأزشۏتلحأڬۏتأ=أځہشأتضأىەأتىأهًڲًڽأڬًأإأڬشأۏۄأڬۄتأوۏڽأتىأظتذثأڬەأځتضأڲۏتأحہتأدًأحوأهًڲًڽأضەأصۏتزۄأثۄحشأۄۏڽأ+أشتًۏأڬًأطڬأۄەأطتۏزأۏۄأتهلتػأۄۏڽأ=أ,أزۏىأڬۏأصۏتزۄأضودہأثًدہأشڬہىەأًتهەأۄۏڽأتىۄًڽأىەأۏۄألشوتۏتأڬۄأڬہتىەأۏتأځۏىەأڬۏأًدۄأضەأشًصۄأرحوأۄًحتأۄەأحوأتځىتأشًصۄأوڬوهأڬشًأۗأ
أؼثزتههۄأثىأوشزتضأڬتأسڬشأڬشحەأۄًةەأوۏڽأىەأڬضۏأڬًأىۄۏڽأځتۏتأۄەأۗأتضأشًتۏحأڬەأثمۏۄأشدتهأ†أظذۏذأ‟أڬەأشدتهأۄۏڽأۗ

[تخریج]: حدیث: 4836۔ اخرجہ الطبراني في """" المعجم الكبير"""" (9566)"
4837,"أذعشحأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أتڲشأوۏڽأشتحأڬەأًمحأتځىۏأثۏًۏأڬەأضتحہأظذثحأڬشأهًڽأتًشأځہشأدتىأثًدہأڬشأؽضهأحشڬأڬشأزًڽأۏۄتڽأحڬأڬۄأظثذأ+أظتزمأ,أۄًأدتةەأحًأۏۄأډۏصأوۏشەأهةەأشًصۄأشڬہىەأوۏڽأشڬتًټأىۄۏڽأثىەأڲۏأڬۏًىڬۄأدثأوۏڽأىەأتضأؼًشحأڬەأضتحہأظذثحأڬۏأحہۏأتضأًمحأًۄأوۏشەأهةەأذهتهأحہۏأۗأ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأڬثۏشأوۏڽأىمهأڬۏأۄەأۗأۏذۏۏأثىأذتشخأىتوۏأشتًۏأڬتأسڬشأڬشحەأۄًةەأوۏڽأىەأڬضۏأڬًأىۄۏڽأځتۏتأۄەأۗأتضأشًتۏحأڬەأثمۏۄأشدتهأ†أظذۏذأ‟أڬەأشدتهأۄۏڽأۗ

[تخریج]: حدیث: 4837۔ اخرجہ الطبراني في """" المعجم الكبير"""" (9568)"
4838,"أذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأثۏتىأڬشحەأۄۏڽأ=أدثأشوعتىأڬتأوۄۏىۄأطشًؼأۄًأدتحتأحہتأ؏أحًأىثۏأتڬشوأ﷽أۄشأمۏزۏأڬًأډہًڔأزۏحەأحہەأ‛أتًشأۄشأوتىڲىەأًتهەأڬًأؼغتأڬۏتأڬشحەأحہەأۗأ
أۏۄأشًتۏحأتوتوأثصتشأىەأىمهأڬۏأۄەأۗأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأتثًثڬشأۄسهۏأۄەأ‛أتًشأًۄأعؼۏلأۄەأۗأ
أ+أؼهتوۄأۄۏخوۏألشوتحەأۄۏڽأ=أ,أوۏڽأۏۄأڬۄحتأۄًڽأ=أشًصەأڬۏأذتهحأوۏڽأظزمۄأڬشىەأۏتأثۏوتشأڬۏأؼۏتزحأڬشىەأۏتأدىتصەأوۏڽأطشۏڬأۄًىەأضەأوحؼهمأتذتزۏخأإڲەأإةۏڽأڲۏأ‛أتڲشأتههۄأىەأډتۄتأۗ

[تخریج]: حدیث : 4838۔ اخرجہ البزار في المسند (968)"
4839,"أذعشحأدتثشأشعۏأتههۄأؼىۄأىثۏأتڬشوأ﷽أڬتأۏۄألشوتىأىمهأڬشحەأۄۏڽأ=أ
أ““أدًأطرظأشًصۄأشڬہىەأڬتأتشتزۄأشڬہحتأۄًأتضەأڬضۏأډۏصأڬەأسشۏؼەأضذشۏأڬشأهۏىۏأډتۄۏەأ‛‛ۗأ
أۏۄأشًتۏحأتوتوأتذوزأتوتوأتثًۏؼهۏٳأتوتوأثصتشأىەأتًشأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأۗأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأؼثزتههۄأثىأوذوزأثىأؼمۏهأۄەأتضأڬۏأىمهأڬشزۄأذزۏخأذضىأۄەأتضأشتًۏأڬەأثتشەأوۏڽأڬهتوأڬۏتأڲۏتأۄەأۗ

