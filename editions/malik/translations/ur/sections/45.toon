{"hadithnumber": "1598", "text": "ہشام بن عُروہ رحمہ اللہ اپنے والد ( عروہ بن زبیر رحمہ اللہ ) سے روایت کرتے ہیں کہ بلاشبہ رسول اللہ ﷺ"}
{"hadithnumber": "1599", "text": "حضرت سفیان بن ابی زُبیر رضی اللہ عنہ سے روایت ہے ، کہتے ہیں کہ میں نے رسول اللہ ﷺ کو یہ فرماتے ہوئے"}
{"hadithnumber": "1600", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ بے شک رسول اللہ ﷺ نے فرمایا :’’ ضرور ضرور ( ایسا وقت آئے گ"}
{"hadithnumber": "1601", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ بے شک حضرت عمر بن عبدالعزیز رحمہ اللہ جب ( ملک شام میں جا کر"}
{"hadithnumber": "1602", "text": "حضرت انس بن مالک رضی اللہ عنہ سے روایت ہے کہ بے شک ( کسی سفر سے واپسی پر ) رسول اللہ ﷺ کے سامنے اُحد"}
{"hadithnumber": "1603", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ، وہ فرمایا کرتے تھے کہ اگر میں ہرنیوں کو دیکھ لوں کہ وہ مدین"}
{"hadithnumber": "1604", "text": "حضرت ابوایوب انصاری رضی اللہ عنہ سے روایت ہے ، انھوں نے کچھ لڑکوں ( بچوں ) کو دیکھا کہ انھوں نے ایک"}
{"hadithnumber": "1605", "text": "ایک شخص ( شُرحبیل بن سعد رحمہ اللہ ) سے روایت ہے ، وہ کہتے ہیں کہ حضرت زید بن ثابت رضی اللہ عنہ میرے"}
{"hadithnumber": "1606", "text": "سیدہ عائشہ اُم المومنین رضی اللہ عنہا سے روایت ہے ، کہتی ہیں کہ جب رسول اللہ ﷺ ( ہجرت کر کے ) مدینہ"}
{"hadithnumber": "1607", "text": "سیدہ عائشہ رضی اللہ عنہا سے روایت ہے ، کہتی ہیں کہ ( ان کے والد کے آزاد کردہ غلام ) حضرت عامر بن فہی"}
{"hadithnumber": "1608", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا :’’ مدینہ کے راستوں پر فرشتے ( متعین"}
{"hadithnumber": "1609", "text": "حضرت عمر بن عبدالعزیز رحمہ اللہ سے روایت ہے ، وہ کہا کرتے تھے کہ رسول اللہ ﷺ نے ( وفات سے قبل ) جو آ"}
{"hadithnumber": "1610", "text": "ابن شہاب رحمہ اللہ سے روایت ہے کہ بے شک رسول اللہ ﷺ نے فرمایا :’’ جزیرۂ عرب میں دو دین اکٹھے نہیں ر"}
{"hadithnumber": "1611", "text": "ہشام بن عروہ رحمہ اللہ اپنے والد ( عروہ بن زبیر رحمہ اللہ ) سے روایت کرتے ہیں : بے شک رسول اللہ ﷺ کے"}
{"hadithnumber": "1612", "text": "اسلم رحمہ اللہ جو کہ حضرت عمر بن خطاب رضی اللہ عنہ کے آزاد کردہ غلام ہیں ، سے روایت ہے کہ وہ حضرت عب"}
{"hadithnumber": "1613", "text": "حضرت عبداللہ بن عباس رضی اللہ عنہ سے روایت ہے کہ بے شک حضرت عمر بن خطاب رضی اللہ عنہ ( 17 یا 18ھ میں"}
{"hadithnumber": "1614", "text": "عامر بن سعد بن ابی وقاص رحمہ اللہ اپنے والد ( حضرت سعد بن ابی وقاص رضی اللہ عنہ ) سے روایت کرتے ہیں"}
{"hadithnumber": "1615", "text": "عبداللہ بن عامر بن ربیعہ رحمہ اللہ سے روایت ہے کہ بے شک حضرت عمر بن خطاب رضی اللہ عنہ ملک شام کی طرف"}
{"hadithnumber": "1616", "text": "سالم بن عبداللہ رحمہ اللہ سے روایت ہے کہ بے شک حضرت عمر بن خطاب رضی اللہ عنہ صرف اور صرف حضرت عبدالر"}
{"hadithnumber": "1617", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ بے شک حضرت عمر بن خطاب رضی اللہ عنہ نے فرمایا کہ : رُکبہ جگہ"}
{"hadithnumber": "1618", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ بے شک رسول اللہ ﷺ نے فرمایا :’’ حضرت آدم اور حضرت موسیٰ عل"}
{"hadithnumber": "1619", "text": "مسلم بن یسار جُہنی رحمہ اللہ سے روایت ہے کہ بے شک حضرت عمر بن خطاب رضی اللہ عنہ سے اس آیت مبارکہ کے"}
{"hadithnumber": "1620", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ بے شک رسول اللہ ﷺ نے فرمایا :’’ میں نے تم میں دو چیزیں چھوڑ د"}
{"hadithnumber": "1621", "text": "طاؤس یمانی رحمہ اللہ ( جن کا اصل نام ذکوان بن کیسان تھا ) سے روایت ہے ، کہتے ہیں کہ میں نے رسول الل"}
{"hadithnumber": "1622", "text": "عمرو بن دینار رحمہ اللہ سے روایت ہے ، کہتے ہیں کہ میں نے حضرت عبداللہ بن زبیر رضی اللہ عنہ کو سنا وہ"}
