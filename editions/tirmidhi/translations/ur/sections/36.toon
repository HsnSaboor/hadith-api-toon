{"hadithnumber": "2381", "text": "ابو سعید خدری رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جو ریاکاری کرے گا ت"}
{"hadithnumber": "2382", "text": "عقبہ بن مسلم سے شفیا اصبحی نے بیان کیا کہ  ایک مرتبہ وہ مدینہ میں داخل ہوئے، اچانک ایک آدمی کو دیکھ"}
{"hadithnumber": "2383", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ” «جب الحزن»  ( غم کی واد"}
{"hadithnumber": "2384", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  ایک آدمی نے عرض کیا: اللہ کے رسول! آدمی نیک عمل کرتا ہے پھر اسے"}
{"hadithnumber": "2385", "text": "انس رضی الله عنہ سے روایت ہے کہ  ایک آدمی نے رسول اللہ صلی اللہ علیہ وسلم کی خدمت میں حاضر ہو کر عر"}
{"hadithnumber": "2386", "text": "انس بن مالک رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”ہر آدمی اسی کے ساتھ"}
{"hadithnumber": "2387", "text": "صفوان بن عسال رضی الله عنہ کہتے ہیں کہ  ایک دیہاتی جس کی آواز بہت بھاری تھی رسول اللہ صلی اللہ علیہ"}
{"hadithnumber": "2388", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اللہ تعالیٰ فرماتا ہے: م"}
{"hadithnumber": "2389", "text": "نواس بن سمعان رضی الله عنہ سے روایت ہے کہ  ایک آدمی نے رسول اللہ صلی اللہ علیہ وسلم سے نیکی اور بدی"}
{"hadithnumber": "2390", "text": "معاذ بن جبل رضی الله عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا: ”اللہ"}
{"hadithnumber": "2391", "text": "ابوہریرہ یا ابو سعید خدری رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”سات ق"}
{"hadithnumber": "2392", "text": "مقدام بن معدیکرب رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جب تم میں سے کوئ"}
{"hadithnumber": "2393", "text": "ابومعمر عبداللہ بن سخبرہ کہتے ہیں کہ  ایک شخص نے کھڑے ہو کر ایک امیر کی تعریف شروع کی تو مقداد بن عم"}
{"hadithnumber": "2394", "text": "۴- ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ہمیں حکم دیا کہ ہم بے جا تعریف"}
{"hadithnumber": "2395", "text": "ابو سعید خدری رضی الله عنہ کہتے ہیں کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا: ”م"}
{"hadithnumber": "2396", "text": "انس رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جب اللہ تعالیٰ اپنے کسی بندے"}
{"hadithnumber": "2397", "text": "ابووائل شقیق بن سلمہ کہتے ہیں کہ  ام المؤمنین عائشہ رضی الله عنہا نے کہا: میں نے رسول اللہ صلی اللہ"}
{"hadithnumber": "2398", "text": "سعد بن ابی وقاص رضی الله عنہ کہتے ہیں کہ  میں نے عرض کیا: اللہ کے رسول! سب سے زیادہ مصیبت کس پر آتی"}
{"hadithnumber": "2399", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”مومن مرد اور مومن عورت ک"}
