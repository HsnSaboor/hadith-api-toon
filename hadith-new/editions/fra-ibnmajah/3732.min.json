{"metadata":{"name":"Sunan Ibn Majah","section":{"33":"Etiquette"},"section_detail":{"33":{"hadithnumber_first":3657,"hadithnumber_last":3826,"arabicnumber_first":3657,"arabicnumber_last":3826}}},"hadiths":[{"hadithnumber":3732,"arabicnumber":3732,"text":"Rapporté par Abu Hurairah : \"Zainab s’appelait 'Barrah' (vertueuse), et on disait qu’elle se vantait. Alors le Messager d’Allah (ﷺ) a changé son nom en Zainab","grades":[{"name":"Al-Albani","grade":"Sahih"},{"name":"Muhammad Fouad Abd al-Baqi","grade":"Sahih"},{"name":"Shuaib Al Arnaut","grade":"Sahih"},{"name":"Zubair Ali Zai","grade":"Sahih - Agreed Upon"}],"reference":{"book":33,"hadith":76}}]}