hadiths[1]{hadithnumber,text}:
17935,أذعشحأؼوشًأتىظتشۏأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأتۏڬأوشحثۄأًۄأڬۄۏڽأدتأشۄەأحہەأ؏أتىأڬتأحۄثىزأټرىًڽأضەأىۏډەأهټڬأشۄتأحہتأ؏أتضۏأزًشتىأىثۏأ﷽أتىأڬەأمشۏثأځۄىډأڲةەأىثۏأ﷽أتځىۏأځۏطتىۏأځڬڔأڬشأۏۄأڬۄۄأشۄەأحہەأتەأتههۄأ$أوۏڽأحۏشتأثىزۄأۄًڽأ؏أحۏشەأثىزەأڬتأثۏټتأۄًڽأ؏أحۏشۏأثىزۏأڬتأثۏټتأۄًڽأ؏أوۏڽأىەأؼشعأڬۏتأۏتأشضًهأتههۄأ$أوۏشۏأځىڋهۏتڽأثڔۏأځحهۏأۄۏڽأ؏أىثۏأ﷽أىەألشوتۏتأؼوشًأ$أتههۄأىەأۄشأډۏصأڬًأثۄحشۏىأتىزتصأوۏڽأحرهۏمألشوتۏتأۄەأ؏أځہشأىثۏأ﷽أىەأتځىۏأډتشأتىڲهۏتڽأؼوشًأڬەأڲہټىەأڬەأىۏډەأوتشۏڽأتًشألشوتۏتأؼوشًأ$أۏۄأۄەأحۄثىزأثتىزہىەأڬۏأدڲۄأ؏أځہشأتضأڬەأىۏډەأۄتحہأشڬہأڬشأډتشأتىڲهۏتڽأوتشۏڽأتًشألشوتۏتأؼوشًأ$أۏۄأۄەأحۄثىزأثتىزہىەأڬۏأدڲۄأ؏أځہشأحۏضشۏأوشحثۄأتضأڬەأىۏډەأډتشأتىڲهۏتڽأشڬہأڬشأثہۏأۏۄۏأدوهۄألشوتۏتأۗأ
