metadata:

hadiths[51]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
2523,"ابوہریرہ رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جنت میں ایسے درخت ہیں",,,,,2523
2524,"ابو سعید خدری رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جنت میں ایسے درخت",,,,,2524
2525,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جنت میں کوئی درخت ایسا ن",,,,,2525
2526,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  ہم نے عرض کیا: اللہ کے رسول! آخر کیا وجہ ہے کہ جب ہم آپ کی خدمت ",,,,,2526
2527,حَدَّثَنَا عَلِيُّ بْنُ حُجْرٍ، حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ إِسْح,,,,,2527
2528,"ابوموسیٰ اشعری عبداللہ بن قیس رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”ج",,,,,2528
2529,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جنت میں سو درجے ہیں، ہر ",,,,,2529
2530,"معاذ بن جبل رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے رمضان کے روز",,,,,2530
2531,"عبادہ بن صامت رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جنت میں سو درجے ہیں",,,,,2531
2532,"ابو سعید خدری رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جنت میں سو درجے ہ",,,,,2532
2533,"عبداللہ بن مسعود رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جنتیوں کی عورت",,,,,2533
2534,اس سند سے بھی  عبداللہ بن مسعود رضی الله عنہ سے اسی جیسی حدیث مروی ہے، اور اسے  ( ابوالاحوص نے )  مر,,,,,2534
2535,"ابو سعید خدری رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”قیامت کے دن جنت م",,,,,2535
2536,"انس رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جنت میں مومن کو جماع کی اتن",,,,,2536
2537,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”پہلا گروہ جو جنت میں داخ",,,,,2537
2538,"سعد بن ابی وقاص رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”اگر ناخن کے برا",,,,,2538
2539,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جنتی بغیر بال کے، امرد ا",,,,,2539
2540,ابو سعید خدری رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم اللہ تعالیٰ کے قول «وفرش مرفو,,,,,2540
2541,اسماء بنت ابوبکر رضی الله عنہما کہتی ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا،,,,,,2541
2542,"انس بن مالک رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم سے پوچھا گیا: کوثر کیا ہے؟ آپ نے ",,,,,2542
2543,بریدہ رضی الله عنہ روایت کرتے ہیں کہ  ایک آدمی نے نبی اکرم صلی اللہ علیہ وسلم سے پوچھتے ہوئے عرض کی,,,,,2543
2544,"ابوایوب رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کے پاس ایک اعرابی نے آ کر عرض کیا: ال",,,,,2544
2545,"معاذ بن جبل رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جنتی جنت میں اس حال",,,,,2545
2546,"بریدہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جنتیوں کی ایک سو بیس صفیں ہ",,,,,2546
2547,عبداللہ بن مسعود رضی الله عنہ کہتے ہیں کہ  ایک خیمہ میں ہم تقریباً چالیس آدمی نبی اکرم صلی اللہ علی,,,,,2547
2548,"عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”وہ دروازہ جس سے ",,,,,2548
2549,"سعید بن مسیب سے روایت ہے  وہ ابوہریرہ رضی الله عنہ سے ملے تو ابوہریرہ رضی الله عنہ نے کہا: میں اللہ ",,,,,2549
2550,"علی رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جنت میں ایک ایسا بازار ہے جس ",,,,,2550
2551,جریر بن عبداللہ بجلی رضی الله عنہ کہتے ہیں کہ  ہم لوگ نبی اکرم صلی اللہ علیہ وسلم کے پاس بیٹھے ہوئے ,,,,,2551
2552,"صہیب رضی الله عنہ سے روایت کرتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے آیت کریمہ: «للذين أحسنوا الح",,,,,2552
2553,"عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”سب سے کم تر درجے",,,,,2553
2554,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”کیا تم چودہویں رات کا چا",,,,,2554
2555,"ابو سعید خدری رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اللہ تعالیٰ جنت وال",,,,,2555
2556,"ابوہریرہ رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”فرق مراتب کے باوجود ای",,,,,2556
2557,"ابوہریرہ رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اللہ تعالیٰ قیامت کے ",,,,,2557
2558,"ابو سعید خدری رضی الله عنہ سے روایت ہے کہ  نبی اکرم  (  صلی اللہ علیہ وسلم  )  نے فرمایا: ”قیامت کے ",,,,,2558
2559,"انس رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جنت ناپسندیدہ اور تکلیف دہ چی",,,,,2559
2560,"ابوہریرہ رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جب اللہ تعالیٰ جنت او",,,,,2560
2561,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جنت اور جہنم کے درمیان ب",,,,,2561
2562,"ابو سعید خدری رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”کم درجے کا جتنی وہ ",,,,,2562
2563,"ابو سعید خدری رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جب مومن جنت میں لڑک",,,,,2563
2564,"علی رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جنت میں حورعین کے لیے ایک محف",,,,,2564
2565,"یحییٰ بن ابی کثیر آیت کریمہ: «فهم في روضة يحبرون» ”وہ جنت میں خوش کر دیئے جائیں گے“ کے بارے میں کہت",,,,,2565
2566,"عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”تین قسم کے لوگ م",,,,,2566
2567,"عبداللہ بن مسعود رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”تین قسم کے لوگ",,,,,2567
2568,"ابوذر رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”تین قسم کے لوگوں سے اللہ ",,,,,2568
2569,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”قریب ہے کہ دریائے فرات س",,,,,2569
2570,ابوہریرہ رضی الله عنہ سے اس سند سے بھی  نبی اکرم صلی اللہ علیہ وسلم سے اسی جیسی حدیث روایت کی ہے، مگ,,,,,2570
2571,"معاویہ بن حیدہ قشیری رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جنت میں پا",,,,,2571
2572,"انس بن مالک رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جو اللہ تعالیٰ سے تین",,,,,2572
2735,عکرمہ بن ابی جہل رضی الله عنہ کہتے ہیں کہ  جب میں  ( مکہ سے مدینہ ہجرت کر کے )  آیا تو رسول اللہ صل,,,,,2735
