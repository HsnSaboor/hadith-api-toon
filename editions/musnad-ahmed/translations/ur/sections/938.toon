hadiths[1]{hadithnumber,text}:
23885,أتۏڬأظذتثۏأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأتىۄًڽأىەأتۏتوأحطشۏمأڬەأزشوۏتىۏأزىأىثۏأ﷽أڬًأرغثۄأوۏڽأۏۄألشوتحەأۄًةەأضىتأۄەأهًڲًأ$أحوۄتشتأشثأتۏڬأۄەأتًشأحوۄتشتأثتځأثہۏأتۏڬأۄەأ؏أۏتزأشڬہًأ$أڬضۏأؼشثۏأڬًأڬضۏأؼدوۏأځشأ؏أڬضۏأؼدوۏأڬًأڬضۏأؼشثۏأځشأ؏أڬضۏأضشرأڬًأضۏتۄأځشأتًشأڬضۏأضۏتۄأڬًأڬضۏأضشرأځشأ““أضًتةەأحمًۏٳأ‛‛أڬەأتًشأڬضۏأًدۄأضەألعۏهحأذتظهأىۄۏڽأۄەأ؏أڬۏتأوۏڽأىەأځۏؽتوأتهۄٳۏأځۄىډتأزۏتأآأهًڲًڽأىەأڬۄتأځۄىډتأزۏتأ؏أځہشألشوتۏتأإدأڬًىأضتأزىأۄەأآأهًڲًڽأىەأڬۄتأذشوحأًتهتأزىأ؏ألشوتۏتأۏۄأوۄۏىۄأڬًىأضتأۄەأآأهًڲًڽأىەأڬۄتأذشوحأًتهتأوۄۏىۄأ؏ألشوتۏتأۏۄأطۄشأڬًىأضتأۄەأآأهًڲًڽأىەأڬۄتأذشوحأًتهتأطۄشأ؏أىثۏأ﷽أىەألشوتۏتأځہشأتههۄأىەأحوۄتشەأزشوۏتىأحوۄتشەأرًىأتًشأوتهأڬًأتضۏأغشذأذشوحأًتهتأثىتأزۏتأۄەأدۏضەأتضأوۄۏىەأتًشأتضأطۄشأوۏڽأإدأڬەأزىأڬۏأذشوحأۄەأ؏أڬۏتأوۏڽأىەأځۏؽتوأتهۄٳۏأځۄىډتأزۏتأآأهًڲًڽأىەأڬۄتأځۄىډتأزۏتأ؏أىثۏأ﷽أىەألشوتۏتأذتعشۏىأڬًأډتۄةەأڬۄأؽتةثۏىأحڬأۏۄأځۏؽتوأځۄىډتأزۏڽأۗ
