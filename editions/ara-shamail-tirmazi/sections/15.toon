metadata:
  section_id: 15
  section_name: رسول اللہ صلی اللہ علیہ وسلم کی تلوار کا بیان
  hadith_first: 102
  hadith_last: 105

hadiths[4]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
102,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا وَهْبُ بْنُ جَرِيرٍ، حَدَّثَنَا أَبِي، عَنْ قَتَادَةَ، عَنْ أَنَسٍ قَالَ: ((كَانَتْ قَبِيعَةُ سَيْفِ رَسُولِ اللَّهِ صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ مِنْ فِضَّةٍ))",,,102,,رسول اللہ صلی اللہ علیہ وسلم کی تلوار کا بیان
103,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ ، حَدَّثَنَا مُعَاذُ بْنُ هِشَامٍ قَالَ: حَدَّثَنِي أَبِي، عَنْ قَتَادَةَ، عَنْ سَعِيدِ بْنِ أَبِي الْحَسَنِ قَالَ: ((كَانَتْ قَبِيعَةُ سَيْفِ رَسُولِ اللَّهِ صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ مِنْ فِضَّةٍ))",,,103,,رسول اللہ صلی اللہ علیہ وسلم کی تلوار کا بیان
104,"حَدَّثَنَا أَبُو جَعْفَرٍ مُحَمَّدُ بْنُ صُدْرَانَ الْبَصْرِيُّ،حَدَّثَنَا طَالِبُ بْنُ حُجَيْرٍ، عَنْ هُودٍ وَهُوَ ابْنُ عَبْدِ اللَّهِ بْنِ سَعْدٍ، عَنْ جَدِّهِ قَالَ: ((دَخَلَ رَسُولُ اللَّهِ صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ مَكَّةَ يَوْمَ الْفَتْحِ وَعَلَى سَيْفِهِ ذَهَبٌ وَفِضَّةٌ)) قَالَ طَالِبٌ: فَسَأَلْتُهُ عَنِ الْفِضَّةِ فَقَالَ: ((كَانَتْ قَبِيعَةُ السَّيْفِ فِضَّةً))",,,104,,رسول اللہ صلی اللہ علیہ وسلم کی تلوار کا بیان
105,"حَدَّثَنَا مُحَمَّدُ بْنُ شُجَاعٍ الْبَغْدَادِيُّ ، حَدَّثَنَا أَبُو عُبَيْدَةَ الْحَدَّادُ، عَنْ عُثْمَانَ بْنِ سَعْدٍ، عَنِ ابْنِ سِيرِينَ قَالَ: ((صَنَعْتُ سَيْفِي عَلَى سَيْفِ سَمُرَةَ بْنِ جُنْدُبٍ، وَزَعَمَ سَمُرَةُ أَنَّهُ صَنَعَ سَيْفَهُ عَلَى سَيْفِ رَسُولِ اللَّهِ صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ وَكَانَ حَنَفِيًّا)) حَدَّثَنَا عُقْبَةُ بْنُ مُكْرَمٍ الْبَصْرِيُّ ، حَدَّثَنَا مُحَمَّدُ بْنُ بَكْرٍ، عَنْ عُثْمَانَ بْنِ سَعْدٍ، بِهَذَا الْإِسْنَادِ نَحْوِهِ",,,105,,رسول اللہ صلی اللہ علیہ وسلم کی تلوار کا بیان
