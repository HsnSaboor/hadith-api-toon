hadiths[3933]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}:
5026,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ صَفْوَانَ بْنِ سُلَیْمٍ ، عَنْ عَطَائِ بْنِ یَسَارٍ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْغُسْلُ یَوْمَ الْجُمُعَۃِ وَاجِبٌ عَلَی کُلِّ مُحْتَلِمٍ۔ (بخاری 2665۔ ابن ماجہ 1089)",,,5026,,
5027,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یَزِیدُ بْنُ أَبِی زِیَادٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْبَرَائِ بْنِ عَازِبٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنَّ مِنَ الْحَقِّ عَلَی الْمُسْلِمِینَ ؛ أَنْ یَغْتَسِلَ أَحَدُہُمْ یَوْمَ الْجُمُعَۃِ ، وَأَنْ یَمَسَّ مِنْ طِیبٍ إِنْ کَانَ عِنْدَ أَہْلِہِ ، فَإِنْ لَمْ یَکُنْ عِنْدَہُ طِیبٌ ، فَالْمَائُ لَہُ طِیبٌ۔ (ترمذی 528۔ احمد 4/282)",,,5027,,
5028,"حَدَّثَنَا عَبْدُ اللہِ بْنُ مُبَارَکٍ ، عَنِ الأَوْزَاعِیِّ ، قَالَ : حدَّثَنَا حَسَّانُ بْنُ عَطِیَّۃَ ، قَالَ : حَدَّثَنَا أَبُو الأَشْعَثِ ، قَالَ : حَدَّثَنِی أَوْسُ بْنُ أَوْسٍ الثَّقَفِیُّ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : مَنْ غَسَّلَ یَوْمَ الْجُمُعَۃِ وَاغْتَسَلَ ، وَبَکَّرَ وَابْتَکَرَ ، وَمَشَی وَلَمْ یَرْکَبْ ، فَدَنَا مِنَ الإِمَام وَاسْتَمَعَ وَلَمْ یَلْغُ کَانَ لَہُ بِکُلِّ خُطْوَۃٍ عَمَلُ سَنَۃٍ ، أَجْرُ صِیَامِہَا وَقِیَامِہَا۔ (ترمذی 496۔ ابوداؤد 349)",,,5028,,
5029,"حَدَّثَنَا شَرِیکٌ ، وَأَبُو الأَحْوَص ، عَنْ أَبِی إِسْحَاقَ ، عَنْ یَحْیَی بْنِ وَثَّابٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ أَتَی الْجُمُعَۃَ فَلْیَغْتَسِلْ۔ (نسائی 1680)",,,5029,,
5030,حَدَّثَنَا ابْنُ عَیَّاشٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ بِمِثْلِہِ۔ (بخاری 877۔ مسلم 579),,,5030,,
5031,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ دَاوُدَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : حَقٌّ عَلَی کُلِّ مُسْلِمٍ فِی کُلِّ سَبْعٍ غُسْلُ یَوْمٍ ، وَذَلِکَ یَوْمُ الْجُمُعَۃِ۔ (نسائی 1669۔ احمد 3/304)",,,5031,,
5032,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا زَکَرِیَّا بْنُ أَبِی زَائِدَۃَ ، عَنْ مُصْعَبِ بْنِ شَیْبَۃَ ، عَنْ طَلْقٍ ، عَنِ ابْنِ الزُّبَیْرِ ، عَنْ عَائِشَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : الْغُسْلُ مِنْ أَرْبَعٍ ؛ مِنَ الْجَنَابَۃِ ، وَالْحِجَامَۃِ ، وَغُسْلِ الْمَیِّتِ ، وَغُسْلِ الْجُمُعَۃِ۔",,,5032,,
5033,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یُونُسُ ، عَنِ الْحَسَنِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : أَوْصَانِی خَلِیلِی بِالْغُسْلِ یَوْمَ الْجُمُعَۃِ۔ (ابویعلی 6198)",,,5033,,
5034,"حَدَّثَنَا عُبَیْدُ اللہِ ، عَنْ شَیْبَانَ ، عَنْ یَحْیَی ، عن أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ؛ أَنَّ عُمَرَ بْنَ الْخَطَّابِ بَیْنَمَا ہُوَ یَخْطُبُ یَوْمَ الْجُمُعَۃِ إِذْ جَائَ رَجُلٌ ، فَقَالَ عُمَرُ : لِمَ تَحْتَبِسُونَ عَنِ الصَّلاَۃ ؟ فَقَالَ الرَّجُلُ : مَا ہُوَ إِلاَّ أَنْ سَمِعْتُ النِّدَائَ فَتَوَضَّأْتُ ، فَقَالَ : وَالْوُضُوئُ أَیْضًا ، أَوَلَمْ تَسْمَعُوا رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَقُولُ: إِذَا رَاحَ أَحَدُکُمْ إِلَی الْجُمُعَۃِ فَلْیَغْتَسِلْ۔ (بخاری 882۔ مسلم 580)",,,5034,,
5035,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ سَعْدِ بْنِ إِبْرَاہِیمَ ، قَالَ : سَمِعْتُ مُحَمَّدَ بْنَ عَبْدِ الرَّحْمَنِ بْنِ ثَوْبَانَ ، یُحَدِّثُ عَنْ رَجُلٍ مِنَ الأَنْصَارِ ، عَنْ رَجُلٍ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ أَنَّہُ قَالَ : ثَلاَثٌ حَقٌّ عَلَی کُلِّ مُسْلِمٍ ؛ الْغُسْلُ یَوْمَ الْجُمُعَۃِ ، وَالسِّوَاکُ ، وَیَمَسُّ مِنْ طِیبٍ إِنْ کَانَ۔ (بخاری 880۔ احمد 4/34)",,,5035,,
5036,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یَزِیدُ بْنُ أَبِی زِیَادٍ ، عَنْ عبد اللہِ بْنِ الْحَارِثِ ، قَالَ : کُنْتُ مَعَ ابْن سَعْدٍ فَجَائَ ابْنٌ لَہُ ، فَقَالَ لَہُ : ہَلِ اغْتَسَلْتَ ؟ قَالَ : لاَ ، تَوَضَّأْتُ ، ثُمَّ جِئْتُ ، فَقَالَ لَہُ سَعْدٌ : مَا کُنْتُ أَحْسَبُ أَنَّ أَحَدًا یَدَعُ الْغُسْلَ یَوْمَ الْجُمُعَۃِ۔",,,5036,,
5037,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مَنْصُورٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : أَقْبَلَ رَجُلٌ مِنَ الْمُہَاجِرِینَ یَوْمَ الْجُمُعَۃِ ، فَقَالَ لَہُ عُمَرُ : ہَلِ اغْتَسَلْتَ ؟ قَالَ : لاَ ، قَالَ : لَقَدْ عَلِمْتَ أَنَّا أُمِرْنَا بِغَیْرِ ذَلِکَ ، قَالَ الرَّجُلُ : بِمَ أُمِرْتُمْ ؟ قَالَ : بِالْغُسْلِ، قَالَ : أَنْتُمْ مَعْشَرَ الْمُہَاجِرِینَ ، أُمُّ النَّاسِ ؟ قَالَ : لاَ أَدْرِی۔ (عبدالرزاق 5293)",,,5037,,
5038,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : بَیْنَمَا عُمَرُ بْنُ الْخَطَّابِ یَخْطُبُ ، ثُمَّ ذَکَرَ نَحْوَہُ۔",,,5038,,
5039,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ أَبِی الْبَخْتَرِیِّ ، قَالَ ، قَاوَلَ عَمَّارٌ رَجُلاً فَاسْتَطَالَ عَلَیْہِ ، فَقَالَ : أَنَا إِذَن أَنْتَنُ مِنَ الَّذِی لاَ یَغْتَسِلُ یَوْمَ الْجُمُعَۃِ۔",,,5039,,
5040,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ عَمْرِو بْنِ مُرَّۃٍ ، عَنْ زَاذَانَ ، قَالَ : سُئِلَ عَلِیٌّ عَنْ غُسْلِ یَوْمَ الْجُمُعَۃِ ؟ فَقَالَ : الْغُسْلُ یَوْمَ الْجُمُعَۃِ ، وَفِی الْعِیدَیْنِ ، وَیَوْمَ عَرَفَۃَ۔",,,5040,,
5041,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یَحْیَی بْنِ أَبِی إِسْحَاقَ ، قَالَ : سَمِعْتُ أَبَا الْوَلِیدِ عَبْدَ اللہِ بْنَ الْحَارِثِ ؛ أَنَّہُ سَمِعَ ابْنَ عَبَّاسٍ یَقُولُ : مَا شَعَرْتُ أَنْ أَحَدًا یَرَی أَنَّ لَہُ طَہُورًا یَوْمَ الْجُمُعَۃِ غَیْرَ الْغُسْلِ۔",,,5041,,
5042,"حَدَّثَنَا وَکِیعٌ، عَنْ ثَوْرٍ، عَنْ زِیَادٍ النُّمَیْرِیِّ، عَنْ أَبِی ہُرَیْرَۃَ، قَالَ: لأَغْتَسِلَنَّ یَوْمَ الْجُمُعَۃِ وَلَوْ کَأْسٌ بِدِینَارٍ۔",,,5042,,
5043,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا أَبُو بِشْرٍ ، عَنْ مُجَاہِدٍ ، قَالَ : قَالَ کَعْبٌ : یَفْزَعُ لِیَوْمِ الْجُمُعَۃِ کُلُّ شَیْئٍ إِلاَّ الثَّقَلَیْنِ ، وَعَلَی کُلِّ حَالِمٍ فِیہِ الْغُسْلُ۔",,,5043,,
5044,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یَحْیَی بن سَعِیدٍ ، عَنْ عَمْرَۃَ بِنْتِ عَبْدِ الرَّحْمَنِ ، عَنْ عَائِشَۃَ ، قَالَتْ : کَانَ النَّاسُ یَخْدُمُونَ أَنْفُسَہُمْ ، فَکَانَ أَحَدُہُمْ یَرُوحُ بِہَیْئَتِہِ إِلَی الْجُمُعَۃِ ، فَقِیلَ لَہُمْ : لَوِ اغْتَسَلْتُمْ۔ (بخاری 903۔ مسلم 6)",,,5044,,
5045,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ دَاوُدَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : حقٌّ عَلَی کُلِّ مُسْلِمٍ غُسْلُ یَوْمٍ بَیْنَ سَبْعَۃِ أَیَّامٍ ، وَہُوَ یَوْمُ الْجُمُعَۃِ۔",,,5045,,
5046,"حَدَّثَنَا ہُشَیْمٌ، عَنْ عُبَیْدَۃَ، عَنْ إِبْرَاہِیمَ، قَالَ: قَالَ عُمَرُ فِی شَیْئٍ: لأَنْتَ أَشَرُّ مِمَّنْ لاَ یَغْتَسِلُ یَوْمَ الْجُمُعَۃِ۔",,,5046,,
5047,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانُوا یَسْتَحِبُّونَ غُسْلَ یَوْمِ الْجُمُعَۃِ۔",,,5047,,
5048,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ إِسْحَاقَ ، عَنِ النُّعْمَانِ بْنِ سَعْدٍ ، عَنْ أَخِیہِ عَبْدِ اللہِ بْنِ سَعْدٍ ، قَالَ : کَانَ عُمَرَ إِذَا حَلَفَ ، قَالَ : أَنَا إِذَن شَرٌّ مِنَ الَّذی لاَ یَغْتَسِلُ یَوْمَ الْجُمُعَۃِ۔",,,5048,,
5049,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ یَحْیَی بْنِ مَیْسَرَۃَ ، قَالَ : سَأَلْتُ ) عَنْ غُسْلِ یَوْمِ الْجُمُعَۃِ ، سُنَّۃٌ ؟ فَقَالَ : کَانَ الْمُسْلِمُونَ یَغْتَسِلُونَ ، فَأَعَدْتُ عَلَیْہِ ، فَلَمْ یَزِدْنِی عَلَی أَنْ قَالَ : کَانَ الْمُسْلِمُونَ یَغْتَسِلُونَ ، فَعَرَفْتُ أَنَّہُ شَیْئٌ اسْتَحَبَّہُ الْمُسْلِمُونَ ، وَلَیْسَ بِسُنَّۃٍ۔",,,5049,,
5050,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ یَزِیدَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، قَالَ : الْغُسْلُ یَوْمَ الْجُمُعَۃِ ، وَیَوْمَ الأَضْحَی ، وَیَوْمَ الْفِطْرِ ، وَیَوْمَ عَرَفَۃَ ، وَیَوْمَ دُخُولِ مَکَّۃَ۔",,,5050,,
5051,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانُوا یُحِبُّونَ إِذَا شَہِدُوا الأَمْصَارَ أَنْ لاَ یَدَعُوا الْغُسْلَ یَوْمَ الْجُمُعَۃِ۔",,,5051,,
5052,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا عُبَیْدُ اللہِ بْنُ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ رَاحَ إِلَی الْجُمُعَۃِ فَلْیَغْتَسِلْ۔ (احمد 2/55۔ طبرانی 13392)",,,5052,,
5053,حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ لَیْثٍ ، عَنْ مَغْرَائَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ أَنَّہُ کَانَ یَغْتَسِلُ وَہُوَ فِی الْحَدِیدِ یَوْمَ الْجُمُعَۃِ۔,,,5053,,
5054,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، قَالَ : أَخْبَرَنِی مَالِکُ بْنُ أَنَسٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : أَخْبَرَنِی ابْنُ سَبَّاقٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ فِی جُمُعَۃٍ مِنَ الْجُمَعِ : إِنَّ ہَذَا یَوْمُ عِیدٍ فَاغْتَسِلُوا ، وَمَنْ کَانَ عِنْدَہُ طِیبٌ فَلاَ یَضُرُّہُ أَنْ یَمَسَّ مِنْہُ ، وَعَلَیْکُمْ بِالسِّوَاکِ۔",,,5054,,
5055,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، وَالْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ مِسْعَرٍ ، عَنْ أَبِی بَکْرِ بْنِ عَمْرِو بْنِ عُتْبَۃَ ، عَنِ ابْنِ مُغَفَّلٍ ، قَالَ : لَہَا غُسْلٌ وَطِیبٌ إِنْ کَانَ۔",,,5055,,
5056,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ یَزِیدَ ، قَالَ : قُلْتُ لِعَبْدِ الرَّحْمَنِ : ہَلْ مِنْ غُسْلٍ غَیْرَ یَوْمِ الْجُمُعَۃِ ؟ قَالَ : نَعَمْ ، یَوْمَ الأَضْحَی ، وَیَوْمَ الْفِطْرِ ، وَیَوْمَ عَرَفَۃَ۔",,,5056,,
5057,حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، وَوَکِیعٌ ، عَنْ عُمَر بْنِ ذَرٍّ ، عَنْ إِبْرَاہِیمَ التَّیْمِیِّ ، عَنْ أَبِیِہِ ؛ أَنَّہُ کَانَ یَسْتَحِبُّ الْغُسْلَ فِی الْعِیدَیْنِ وَالْجُمُعَۃِ۔,,,5057,,
5058,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، وَابْنُ فُضَیْلٍ ، قَالاَ : حدَّثَنَا مِسْعَرٌ ، عَنْ وَبَرَۃَ ، عَنْ ہَمَّامِ بْنِ الْحَارِثِ ، قَالَ : قَالَ عَبْدُ اللہِ : إِنَّ مِنَ السُّنَّۃِ الْغُسْلَ یَوْمَ الْجُمُعَۃِ۔ (عبدالرزاق 5316۔ طیالسی 391)",,,5058,,
5059,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ خَطَبَ یَوْمَ الْجُمُعَۃِ ، فَقَالَ : مَنْ رَاحَ إِلَی الْجُمُعَۃِ فَلْیَغْتَسِلْ۔",,,5059,,
5060,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ عَلِیِّ بْنِ رِفَاعَۃَ ، عَنْ حَیَّانَ الأَعْرَجِ ، عَنْ جَابِرِ بْنِ زَیْدٍ ، قَالَ : رُبَّمَا وَجَدْتُ الْبَرْدَ یَوْمَ الْجُمُعَۃِ فَلاَ أَغْتَسِلُ۔ (نسائی 1405)",,,5060,,
5061,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا إِسْمَاعِیلُ ، عَنِ الشَّعْبِیِّ (ح) وَأَخْبَرَنَا عُبَیْدَۃُ ، وَمُغِیرَۃُ ، عَنْ إِبْرَاہِیمَ (ح) وَعَبْدُ الْمَلِکِ ، عَنْ عَطَائٍ ؛ أَنَّہُمْ قَالُوا : مَنْ تَوَضَّأَ یَوْمَ الْجُمُعَۃِ فَحَسَنٌ ، وَمَنِ اغْتَسَلَ فَالْغُسْلُ أَفْضَلُ۔",,,5061,,
5062,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا عُبَیْدَۃُ ، عَنْ أَبِی وَائِلٍ ، قَالَ : ذَکَرُوا غُسْلَ یَوْمِ الْجُمُعَۃِ عِنْدَہُ ، فَقَالَ أَبُو وَائِلٍ : إِنَّہُ لَیْسَ بِوَاجِبٍ ، رُبَّ شَیْخٍ کَبِیرٍ لَوِ اغْتَسَلَ فِی الْبَرْدِ الشَّدِیدِ یَوْمَ الْجُمُعَۃِ لَمَاتَ۔",,,5062,,
5063,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا إِسْمَاعِیلُ بْنُ أَبِی خَالِدٍ ، عَنِ الشَّعْبِیِّ ؛ أَنَّہُ کَانَ لاَ یَرَی غُسْلاً وَاجِبًا ، إِلاَّ الْغُسْلَ مِنَ الْجَنَابَۃِ۔",,,5063,,
5064,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا ہَمَّامٌ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، عَنْ سَمُرَۃََ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، قَالَ : مَنْ تَوَضَّأَ یَوْمَ الْجُمُعَۃِ فَبِہَا وَنَعِمَتْ ، وَمَنَ اغْتَسَلَ فَذَلِکَ أَفْضَلُ۔ (ابوداؤد 358۔ احمد 5/16)",,,5064,,
5065,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ تَوَضَّأَ فَأَحْسَنَ الْوُضُوئَ ، ثُمَّ أَتَی الْجُمُعَۃَ ، فَدَنَا وَأَنْصَتَ وَاسْتَمَعَ ، غُفِرَ لَہُ مَا بَیْنَہُ وَبَیْنَ الْجُمُعَۃِ الأُخْرَی ، وَزِیَادَۃُ ثَلاَثَۃِ أَیَّامٍ ، وَمَنْ مَسَّ الْحَصَی فَقَدْ لَغَا۔ (مسلم 27۔ ابوداؤد 1043)",,,5065,,
5066,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : سَأَلْتُُہُ عَنْ غُسْلِ الْجُمُعَۃِ؟ فَقَالَ: لَیْسَ غُسْلٌ وَاجِبٌ إِلاَّ مِنَ الْجَنَابَۃِ۔",,,5066,,
5067,"حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطِیَّۃَ ، عَنْ أَبِی سَعِیدٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : مَنْ تَطَہَّرَ فَأَحْسَنَ الطُّہُورَ ، ثُمَّ أَتَی الْجُمُعَۃَ ، فَلَمْ یَلْہُ وَلَمْ یَجْہَلْ ، کَانَ کَفَّارَۃً لِمَا بَیْنَہَا وَبَیْنَ الْجُمُعَۃِ الأُخْرَی ، وَالصَّلَوَاتُ الْخَمْسُ کَفَّارَاتٌ لِمَا بَیْنَہُنَّ ، وَفِی الْجُمُعَۃِ سَاعَۃٌ لاَ یُوَافِقُہَا عَبْدٌ مُسْلِمٌ فَیَسْأَلُ اللَّہَ خَیْرًا إِلاَّ أَعْطَاہُ۔ (عبد بن حمید 901)",,,5067,,
5068,"حَدَّثَنَا ہُشَیْمٌ، قَالَ: أَخْبَرَنَا الأَعْمَش، عَنْ إِبْرَاہِیمَ، عَن عَلْقَمَۃَ؛ أَنَّہُ کَانَ لاَ یَغْتَسِلُ یَوْمَ الْجُمُعَۃِ فِی السَّفَرِ۔",,,5068,,
5069,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ سَالِمٍ ، عَنِ ابْنِ عُمَر (ح) وَعَنِ الْعُمَرِیِّ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ لاَ یَغْتَسِلُ یَوْمَ الْجُمُعَۃِ فِی السَّفَرِ۔,,,5069,,
5070,حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنْ خَالِہِ الْحَارِثِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنِ ابْنِ جُبَیْرِ بْنِ مُطْعِمٍ ؛ أَنَّہُ کَانَ لاَ یَغْتَسِلُ یَوْمَ الْجُمُعَۃِ فِی السَّفَرِ۔,,,5070,,
5071,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ؛ أَنَّ مُجَاہِدًا ، وَطَاوُوسا کَانَا لاَ یَغْتَسِلاَنِ فِی السَّفَرِ یَوْمَ الْجُمُعَۃِ ، وَکَانَ سَعِیدُ بْنُ جُبَیْرٍ یَغْتَسِلُ حِینَ جِیئَ بِہِ أَسِیرًا۔,,,5071,,
5072,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ جَابِرٍ ، قَالَ : سَأَلْتُ الْقَاسِمَ عَنِ الْغُسْلِ یَوْمَ الْجُمُعَۃِ فِی السَّفَرِ ؟ فَقَالَ : کَانَ ابْنُ عُمَرَ لاَ یَغْتَسِلُ ، وَأَنَا أَرَی لَکَ أَنْ لاَ تَغْتَسِلَ۔",,,5072,,
5073,حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ؛ أَنَّ الأَسْوَدَ ، وَعَلْقَمَۃَ کَانَا لاَ یَغْتَسِلاَنِ یَوْمَ الْجُمُعَۃِ فِی السَّفَرِ۔,,,5073,,
5074,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ إِیَاسِ بْنِ مُعَاوِیَۃَ ، قَالَ : إِنَّمَا الْغُسْلُ عَلَی مَنْ حَضَرَ الْجُمُعَۃَ۔",,,5074,,
5075,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرُ ، عَنْ عُقْبَۃَ بْنِ أَبِی جَسْرَۃ ، قَالَ : سَأَلْتُ إِسْحَاقَ بْنَ عَبْدِ اللہِ بْنِ الْحَارِثِ عَنِ الْغُسْلِ یَوْمَ الْجُمُعَۃِ ؟ فَقَالَ : کَانَ عَبْدُ اللہِ بْنُ الْحَارِثِ یَغْتَسِلُ یَوْمَ الْجُمُعَۃِ فِی السَّفَرِ وَالْحَضَرِ۔",,,5075,,
5076,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنْ عَبْدِ اللہِ بْنِ مَعْدَانَ ، قَالَ : سَمِعْتُ حَبِیبًا وَسَأَلَہُ رَجُلٌ : مَا تَقُولُ فِی غُسْلِ الْجُمُعَۃِ ، أَوَاجِبٌ ہُوَ ؟ فَقَالَ : قَدْ رَأَیْتُ طَلْقًا أَقْبَلَ مِنْ مَکَّۃَ إِلَی الْحَجَّاجِ أَسِیرًا ، فَمَا تَرَکَ الْغُسْلَ یَوْمَ الْجُمُعَۃِ۔",,,5076,,
5077,حَدَّثَنَا عُبَیْدُاللہِ بْنُ مُوسَی، عَنْ إِسْرَائِیلَ، عَنْ جَابِرٍ، عَنْ أَبِی جَعْفَرٍ؛ أَنَّہُ کَانَ یَغْتَسِلُ فِی السَّفَرِ کُلَّ جُمُعَۃٍ۔,,,5077,,
5078,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْحَاقَ بْنِ یَحْیَی ، عَنِ الْمُسَیَّبِ بْنِ رَافِعٍ ، عَنْ زِیَادِ بْنِ حُدَیْرٍ ، قَالَ : سَتَرْتُ طَلْحَۃَ فِی سَفَرٍ یَوْمَ جُمُعَۃٍ فَاغْتَسَلَ۔",,,5078,,
5079,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، قَالَ : إِذَا اغْتَسَلَ یَوْمَ الْجُمُعَۃِ بَعْدَ طُلُوعِ الْفَجْرِ مِنَ الْجَنَابَۃِ ، أَجْزَأَہُ مِنْ غُسْلِ یَوْمِ الْجُمُعَۃِ۔",,,5079,,
5080,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یُونُسُ ، عَنِ الْحَسَنِ (ح) وَمُغِیرَۃُ ، عَنْ إِبْرَاہِیمَ (ح) وَعَبْدُ الْمَلِکِ ، عَنْ عَطَائٍ ؛ أَنَّہُمْ قَالُوا : إِذَا اغْتَسَلَ الرَّجُلُ یَوْمَ الْجُمُعَۃِ بَعْدَ طُلُوعِ الْفَجْرِ أَجْزَأَہُ مِنْ غُسْلِ الْجُمُعَۃِ۔",,,5080,,
5081,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حَبِیبُ بْنُ أَبِی الْعَالِیَۃِ ، عَنْ مُجَاہِدٍ ؛ مِثْلَ ذَلِکَ۔",,,5081,,
5082,"حَدَّثَنَا وَکِیعٌ، عَنْ مَعْمَرٍ، عَنْ أَبِی جَعْفَرٍ، قَالَ: إِذَا اغْتَسَلَ بَعْدَ طُلُوعِ الْفَجْرِ أَجْزَأَہُ مِنْ غُسْلِ یَوْمِ الْجُمُعَۃِ۔",,,5082,,
5083,"حَدَّثَنَا ابْنُ أَبِی غَنِیَّۃَ ، عَنْ أَبِیہِ ، عَنِ الْحَکَمِ ، قَالَ : مَنِ اغْتَسَلَ یَوْمَ الْجُمُعَۃِ بَعْدَ طُلُوعِ الْفَجْرِ أَجْزَأَہُ مِنْ غُسْلِ الْجُمُعُۃِ۔",,,5083,,
5084,"حَدَّثَنَا وَکِیعٌ ، عَنْ عُمَرَ بْنِ بشیر ، عَنِ الشَّعْبِیِّ ، قَالَ : سُئِلَ عَنْ رَجُلٍ اغْتَسَلَ یَوْمَ الْجُمُعَۃِ بِسَحَرٍ ؟ قَالَ : یُجْزِئُہُ۔",,,5084,,
5085,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا الْعَوَّامُ ، عَنْ إِبْرَاہِیمَ التَّیْمِیِّ ، قَالَ : کَانُوا یُحِبُّونَ لِمَنِ اغْتَسَلَ یَوْمَ الْجُمُعَۃِ أَنْ لاَ یَکُونَ بَیْنَہُ وَبَیْنَ الْجُمُعَۃِ حَدَثٌ ، قَالَ : وَکَانُوا یَقُولُونَ : إِذَا أَحْدَثَ بَعْدَ الْغُسْلِ ، عَادَ إِلَی حَالِہِ الَّتِی کَانَ عَلَیْہَا قَبْلَ أَنْ یَغْتَسِلَ۔",,,5085,,
5086,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ إِبْرَاہِیمَ بن نَافِعٍ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ ؛ فِی الرَّجُلِ یَغْتَسِلُ یَوْمَ الْجُمُعَۃِ ، ثُمَّ یُحْدِثُ ، قَالَ : یُعِیدُ الْغُسْلَ۔",,,5086,,
5087,حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَبْدَۃَ بْنِ أَبِی لُبَابَۃَ ، عَنْ سَعِیدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ أَبْزَی ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یَغْتَسِلُ یَوْمَ الْجُمُعَۃِ ، ثُمَّ یُحْدِثُ بَعْدَ الْغُسْلِ ، ثُمَّ لاَ یُعِیدُ غُسْلاً۔,,,5087,,
5088,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ ہِشَامٍ ، قَالَ : کَانَ مُحَمَّدٌ یَسْتَحِبُّ أَنْ لاَ یَکُونَ بَیْنَہُ وَبَیْنَ الْجُمُعَۃِ حَدَثٌ ۔ وَقَالَ الْحَسَنُ : إِذَا أَحْدَثَ تَوَضَّأَ۔",,,5088,,
5089,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُبَارَکٍ ، عَنِ الْحَسَنِ ، قَالَ : إِذَا اغْتَسَلَ یَوْمَ الْجُمُعَۃِ ، ثُمَّ أَحْدَثَ أَجْزَأَہُ الْوُضُوئُ۔",,,5089,,
5090,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ عُبَیْدَۃَ ابْنَۃِ نَابِلٍ ، قَالَتْ : سَمِعْتُ ابْنَ عُمَرَ ، وَابْنَۃَ سَعْدِ بْنِ أَبِی وَقَّاصٍ ، یَقُولاَنِ لِلنِّسَائِ : مَنْ جَائَ مِنْکُنَّ الْجُمُعَۃَ فَلْتَغْتَسِلْ۔",,,5090,,
5091,حَدَّثَنَا یَحْیَی بْنُ أَبِی کَثِیرٍ ، عَنْ إِبْرَاہِیمَ بْنِ نَافِعٍ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یَأْمُرُ نِسَائَہُ یَغْتَسِلْنَ یَوْمَ الْجُمُعَۃِ۔,,,5091,,
5092,حَدَّثَنَا ابْنُ مَہْدِیٍّ عَنْ إِبْرَاہِیمَ بْنِ نَافِعٍ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ ؛ بِمِثْلِہِ۔,,,5092,,
5093,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : لَیْسَ عَلَی النِّسَائِ غُسْلٌ یَوْمَ الْجُمُعَۃِ۔",,,5093,,
5094,"حَدَّثَنَا عُبَیْدُ اللہِ ، عَنْ زُفَرَ بْن مُہَاجِرِ الْغَاضِرِیِّ ، قَالَ : کَانَ شَقِیقٌ یَأْمُرُ أَہْلَہُ ، الرِّجَالَ وَالنِّسَائَ ، بِالْغُسْلِ یَوْمَ الْجُمُعَۃِ۔",,,5094,,
5095,حَدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَغْتَسِلُ لِلْجَنَابَۃِ وَالْجُمُعَۃِ غُسْلاً وَاحِدًا۔,,,5095,,
5096,"حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی الْمَوَالِی ، عَنْ عُمَرَ بْنِ أَبِی مُسْلِمٍ ، قَالَ : کَانَ بَنُو أَخِی عُرْوَۃَ بْنِ الزُّبَیْرِ یَغْتَسِلُونَ فِی الْحَمَّامِ یَوْمَ الْجُمُعَۃِ ، فَیَقُولُ عُرْوَۃُ : یَا بَنِی أَخِی ، إِنَّمَا اغْتَسَلْتُمْ فِی الْحَمَّامِ مِنَ الْوَسَخِ ، فَاغْتَسِلُوا لِلْجُمُعَۃِ۔",,,5096,,
5097,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، قَالَ : حدَّثَنِی یَحْیَی بْنُ عَبْدِ اللہِ بْنِ أَبِی قَتَادَۃَ ، قَالَ : حَدَّثَتْنِی أُمِّیْ، أَنَّ أَبَاہَا حَدَّثَہَا ، أَنَّ بَعْضَ وَلَدِ أَبِی قَتَادَۃَ دَخَلَ عَلَیْہِ یَوْمَ الْجُمُعَۃِ یَنْفُضُ رَأْسَہُ مُغْتَسِلاً ، فَقَالَ : لِلْجُمُعَۃِ اغْتَسَلْتَ ؟ قَالَ: لاَ ، وَلَکِنْ مِنَ جَنَابَۃٍ ، قَالَ : فَأَعِدْ غُسْلاً لِلْجُمُعَۃِ۔",,,5097,,
5098,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ طَلْحَۃَ ، عَنْ سَعْدِ بْنِ عُبَیْدَۃَ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ، قَالَ : قَالَ عَلِیٌّ : لاَ جُمُعَۃَ ، وَلاَ تَشْرِیقَ إِلاَّ فِی مِصْرٍ جَامِعٍ۔",,,5098,,
5099,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی إِسْحَاقٍ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : لاَ جُمُعَۃَ ، وَلاَ تَشْرِیقَ ، وَلاَ صَلاَۃَ فِطْرٍ ، وَلاَ أَضْحَی ، إِلاَّ فِی مِصْرٍ جَامِعٍ ، أَوْ مَدِینَۃٍ عَظِیمَۃٍ۔\n\nقَالَ حَجَّاجٌ : وَسَمِعْتُ عَطَائً یَقُولُ مِثْلَ ذَلِکَ۔",,,5099,,
5100,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ عُمَرَ بْنِ عَامِرٍ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، عَن حُذَیْفَۃَ ، قَالَ : لَیْسَ عَلَی أَہْلِ الْقُرَی جُمُعَۃٌ ، إِنَّمَا الْجُمُعَۃُ عَلَی أَہْلِ الأَمْصَارِ ، مِثْلِ الْمَدَائِنِ۔",,,5100,,
5101,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَمُحَمَّدٍ ؛ أَنَّہُمَا قَالاَ : الْجُمُعَۃُ فِی الأَمْصَارِ۔",,,5101,,
5102,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یُونُسُ ، عَنِ الْحَسَنِ ؛ أَنَّہُ سُئِلَ : عَلَی أَہْلِ الأُبُلَّۃ جُمُعَۃٌ ؟ قَالَ : لاَ۔",,,5102,,
5103,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ أَبِی بَکْرِ بْنِ مُحَمَّدٍ ؛ أَنَّہُ أَرْسَلَ إِلَی أَہْلِ ذِی الْحُلَیْفَۃِ: أَنْ لاَ تُجَمِّعُوا بِہَا ، وَأَنْ تَدْخُلُوا إِلَی الْمَسْجِدِ ، مَسْجِدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,5103,,
5104,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانُوا لاَ یُجَمِّعُونَ فِی الْعَسَاکِرِ۔",,,5104,,
5105,"حَدَّثَنَا غُنْدَرٌ ، عن شُعْبَۃَ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لاَ جُمُعَۃَ ، وَلاَ تَشْرِیقَ إِلاَّ فِی مِصْرٍ جَامِعٍ۔",,,5105,,
5106,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ سَعْدِ بْنِ عُبَیْدَۃَ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ السُّلَمِیِّ ، عَنْ عَلِیٍّ ، قَالَ: لاَ تَشْرِیقَ ، وَلاَ جُمُعَۃَ إِلاَّ فِی مِصْرٍ جَامِعٍ۔",,,5106,,
5107,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : الرَّیُّ مِصْرٌ۔",,,5107,,
5108,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إِدْرِیسَ ، عَنْ شُعْبَۃَ ، عَنْ عَطَائِ بْنِ أَبِی مَیْمُونَۃَ ، عَنْ أَبِی رَافِعٍ ، عَنْ أَبِی ہُرَیْرَۃَ ؛ أَنَّہُمْ کَتَبُوا إِلَی عُمَرَ یَسْأَلُونَہُ عَنِ الْجُمُعَۃِ ؟ فَکَتَبَ : جَمِّعُوا حَیْثُمَا کُنْتُمْ۔",,,5108,,
5109,"حَدَّثَنَا وَکِیعٌ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، قَالَ : کَتَبَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ إِلَی عَدِیِّ بْنِ عَدِیٍّ ، أَیُّمَا أَہْلِ قَرْیَۃٍ لَیْسُوا بِأَہْلِ عَمُودٍ یَنْتَقِلُونَ ، فَأَمِّرْ عَلَیْہِمْ أَمِیرًا یُجَمِّعُ بِہِمْ۔",,,5109,,
5110,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ مَعْقِلٍ ، عَنْ عَطَائٍ ، قَالَ : إِذَا کَانَتْ قَرْیَۃٌ لاَزِقَۃٌ بَعْضُہَا بِبَعْضٍ ، جَمَّعُوا۔",,,5110,,
5111,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ مَالِکٍ ، قَالَ : کَانَ أَصْحَابُ مُحَمَّدٍ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی ہَذِہِ الْمِیَاہِ بَیْنَ مَکَّۃَ وَالْمَدِینَۃِ یُجَمِّعُونَ۔",,,5111,,
5112,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، قَالَ : أَرْسَلْتُ إِلَی عَائِشَۃَ ابْنَۃِ سَعْدٍ ، أَسْأَلُہَا عَنِ الْجُمُعَۃِ ؟ فَقَالَتْ : کَانَ سَعْدٌ عَلَی رَأْسِ سَبْعَۃِ أَمْیَالٍ ، أَوْ ثَمَانِیَۃٍ ، فَکَانَ أَحْیَانَا یَأْتِیہَا ، وَأَحْیَانَا لاَ یَأْتِیہَا۔",,,5112,,
5113,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا أَبُو عَامِرٍ الْمُزَنِیُّ ، قَالَ : سَمِعْتُ نَافِعًا ، یُحَدِّثُ عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ قَالَ : الْجُمُعَۃُ عَلَی مَنْ آوَاہُ الْمَرَاحُ۔",,,5113,,
5114,"حَدَّثَنَا شَرِیکٌ ، عَنْ سَعِیدِ بْنِ مَسْرُوقٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : تُؤْتَی الْجُمُعَۃُ مِنْ فَرْسَخَیْنِ۔",,,5114,,
5115,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ عَبْدِ اللہِ بْنِ یَزِیدَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : سَأَلْتُُہُ : عَلَی مَنْ تَجِبُ الْجُمُعَۃُ ؟ فَقَالَ : عَلَی مَنْ سَمِعَ النِّدَائَ۔",,,5115,,
5116,"حَدَّثَنَا وَکِیعٌ، عَنْ أَبِی الْبَخْتَرِیِّ، قَالَ: رَأَیْتُ أَنَسًا شَہِدَ الْجُمُعَۃَ مِنَ الزَّاوِیَۃِ، وَہِیَ فَرْسَخَانِ مِنَ الْبَصْرَۃِ۔",,,5116,,
5117,"حَدَّثَنَا أَزْہَرُ، عَنِ ابْنِ عَوْنٍ، قَالَ: کَانَ أَبُو الْمَلِیحِ عَامِلاً عَلَی الأُبُلَّۃ، فَکَانَتْ إِذَا أَتَتِ الْجُمُعَۃُ جَمَّعَ مِنْہَا۔",,,5117,,
5118,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ إِسْمَاعِیلَ بْنِ مُسْلِمٍ الْعَبْدِیِّ ، عَنْ مَالِکِ بْنِ دِینَارٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : تُؤْتَی الْجُمُعَۃُ مِنْ أَرْبَعَۃِ فَرَاسِخَ۔",,,5118,,
5119,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ، عَنْ عَطَائِ بْنِ السَّائِبِ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ، قَالَ: کُنَّا نَأْتِیہَا مِنْ فَرْسَخَیْنِ۔",,,5119,,
5120,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا ہِشَامٌ ، عَنِ الْحَسَنِ ، قَالَ : الْجُمُعَۃُ عَلَی کُلِّ مَنْ آوَاہُ اللَّیْلُ إِلَی أَہْلِہِ۔",,,5120,,
5121,"حَدَّثَنَا ابْنُ مَہْدِی ، عَنْ وُہَیْبٍ ، عَنْ عُبَیْدِ بْنِ عُمَیْرٍ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : إِنَّمَا الْجُمُعَۃُ عَلَی مَنْ آوَاہُ اللَّیْلُ إِلَی أَہْلِہِ۔",,,5121,,
5122,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، قَالَ: کَانَ أَبِی یَکُونُ بِبِئْرِ عُرْوَۃَ ثَلاَثَۃِ أَمْیَالٍ مِنَ الْمَدِینَۃِ، فَلاَ یَشْہَدُ جُمُعَۃً ، وَلاَ جَمَاعَۃً۔",,,5122,,
5123,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ قُرَّۃَ بْنِ خَالِدٍ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ سِیرِینَ ، عَنْ أَفْلَحَ مَوْلَی أَبِی أَیُّوبَ ، قَالَ : کَانَ ابْنُ سَلاَمٍ یَأْتِینَا یَوْمَ الْجُمُعَۃِ ، فَیُعَلِّقُ مَعَہُ إِدَاوَۃً مِنْ مَائٍ ، وَیُجَمِّعُ مِنَ الْعَوَالِی۔",,,5123,,
5124,"حَدَّثَنَا رَوَّادُ بْنُ الْجَرَّاحِ ، عَنِ الأَوْزَاعِیِّ ، عَنْ وَاصِلٍ ، عَنْ مُجَاہِدٍ ، قَالَ : کَانَتِ الْعُصْبَۃُ مِنَ الرِّجَالِ وَالنِّسَائِ یُجَمِّعُونَ مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَمَا یَأْتُونَ رِحَالَہُمْ إِلاَّ مِنَ الْغَدِ۔ (ابوداؤد 52)",,,5124,,
5125,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، قَالَ : الْجُمُعَۃُ عَلَی مَنْ آوَاہُ اللَّیْلُ إِلَی أَہْلِہِ۔",,,5125,,
5126,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ عَبْدِ الْحَمِیدِ بْنِ جَعْفَرٍ ، عَنْ أَبِیہِ ؛ أَنَّ عَبْدَ اللہِ بْنَ رَوَاحَۃَ کَانَ یَأْتِی الْجُمُعَۃَ مَاشِیًا ، فَقُلْتُ لِعَبْدِ الْحَمِیدِ : کَمْ کَانَ بَیْنَ مَنْزِلِہِ وَبَیْنَ الْجُمُعَۃِ ؟ قَالَ : مِیلَیْنِ۔",,,5126,,
5127,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ؛ أَنَّہُمْ کَانُوا یَشْہَدُونَ الْجُمُعَۃَ مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِنْ ذِی الْحُلَیْفَۃِ۔ (عبدالرزاق 5151),,,5127,,
5128,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا حَوْشَبُ بْنُ عَقِیلٍ الْعَبْدِیُّ ، قَالَ : سَأَلْتُ عَطَائً : مِنْ کَمْ تُؤْتَی الْجُمُعَۃُ ؟ قَالَ : مِنْ سَبْعَۃِ أَمْیَالٍ۔",,,5128,,
5129,"حَدَّثَنَا وَکِیعٌ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، قَالَ : قُلْتُ لِلزُّہْرِیِّ : عَلَی مَنْ تَجِبُ الْجُمُعَۃُ مِمَّنْ کَانَ ہُوَ قُرْبَ الْمَدِینَۃِ ؟ قَالَ : کَانَ أَہْلُ ذِی الْحُلَیْفَۃِ یَشْہَدُونَ الْجُمُعَۃَ۔",,,5129,,
5130,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَانَ مُحَمَّدٌ یُسْأَلُ عَنِ الرَّجُلِ ، یُجَمِّعُ مِنْ ہَذِہِ الْمَزَالِفِ ؟ فَیَقُولُ : قَدْ کَانَتِ الأَنْصَارُ یُجَمِّعُونَ مِنَ الْمَزَالِفِ حَوْلَ الْمَدِینَۃِ۔",,,5130,,
5131,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ حَمَّادًا عَنِ الرَّجُلِ یُجَمِّعُ مِنْ فَرْسَخَیْنِ ؟ فَقَالَ : لاَ ۔ وَسَأَلْتُ الْحَکَمَ ؟ فَقَالَ : إِذَا کَانَ یَجِیئُ وَیَذْہَبُ فِی یَوْمٍ فَعَلَیْہِ الْجُمُعَۃُ۔",,,5131,,
5132,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ أَیُّوبَ بْنِ عُتْبَۃَ ، عَنْ یَحْیَی ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : تُؤْتََی الْجُمُعَۃُ مِنْ فَرْسَخَیْنِ۔",,,5132,,
5133,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ عُمَرَ بْنِ عَامِرٍ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، عَن حُذَیْفَۃَ ، قَالَ : لَیْسَ عَلَی مَنْ عَلَی رَأْسِ مِیلٍ جُمُعَۃٌ۔",,,5133,,
5134,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ أَبِیہِ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ؛ أَنَّہُ کَانَ یَشْہَدُ الْجُمُعَۃَ فِی الطَّائِفِ وَہُوَ فِی قَرْیَۃٍ ، یُقَالُ لَہَا : الْوَہْطُ ، عَلَی رَأْسِ ثَلاَثَۃِ أَمْیَالٍ۔",,,5134,,
5135,"حَدَّثَنَا وَکِیعُ ، عَنْ دَاوُد بْنِ قَیْسٍ الْفَرَّائُ ، قَالَ : سَمِعْتُ عَمْرَو بْنَ شُعَیْبٍ ، قِیلَ لَہُ : یَا أَبَا إِبْرَاہِیمَ ، عَلَی مَنْ یَجِبُ الْجُمُعَۃُ ؟ قَالَ : عَلَی مَنْ سَمِعَ الصَّوْتَ۔",,,5135,,
5136,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ، عَنْ عَلِیٍّ، قَالَ: لَیْسَ عَلَی الْمُسَافِرِ جُمُعَۃٌ۔",,,5136,,
5137,حَدَّثَنَا وَکِیعٌ ، عَنِ الْعُمَرِیِّ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ لاَ یُجَمِّعُ فِی السَّفَرِ۔,,,5137,,
5138,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ، قَالَ : لَیْسَ عَلَی الْمُسَافِرِ أَضْحَی ، وَلاَ فِطْرٌ ، وَلاَ جُمُعَۃٌ۔",,,5138,,
5139,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ أَبِی الْعُمَیْسِ ، عَنْ عَلِیِّ بْنِ الأَقْمَرِ ، قَالَ : خَرَجَ مَسْرُوقٌ ، وَعُرْوَۃُ بْنُ الْمُغِیرَۃَ ، وَنَفَرٌ مِنْ أَصْحَابِ عَبْدِ اللہِ ، فَحَضَرَتِ الْجُمُعَۃُ فَلَمْ یُجَمِّعُوا ، وَحَضَرَ الْفِطْرُ فَلَمْ یُفْطِرُوا۔",,,5139,,
5140,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّ عَبْدَ الرَّحْمَن بْنَ سَمُرَۃَ شَتَا بِکَابُلَ شَتْوَۃً ، أَوْ شَتْوَتَیْنِ لاَ یُجَمِّعُ ، وَیُصَلِّی رَکْعَتَیْنِ۔,,,5140,,
5141,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّ أَنَسَ بْنَ مَالِکٍ أَقَامَ بِنَیْسَابُورَ سَنَۃً ، أَوْ سَنَتَیْنِ ، فَکَانَ یُصَلِّی رَکْعَتَیْنِ ، ثُمَّ یُسَلِّمُ ، ثُمَّ یُصَلِّی رَکْعتَیْنِ ، ثُمَّ یُسَلِّمُ ، وَلاَ یُجَمِّعُ۔,,,5141,,
5142,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنِ الْمُغِیرَۃ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانَ أَصْحَابُنَا یَغْزُونَ ، فَیُقِیمُونَ السَّنَۃَ ، أَوْ نَحْوَ ذَلِکَ ، یُقَصِّرُونَ الصَّلاَۃ ، وَلاَ یُجَمِّعُونَ۔",,,5142,,
5143,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ ہِشَامِ بْنِ الْغَازِ ، عَنْ عُبَادَۃَ بْنِ نُسَیٍّ ، قَالَ : خَرَجَ عَبْدُ الْمَلِکِ بْنُ مَرْوَانَ یُرِیدُ الصَّلاَۃَ فِی بَیْتِ الْمُقَدَّسِ ، فَضَرَبَ حُجْرَتَہُ عَلَی فَاثُورِ إِبْرَاہِیمَ ، فَلَقِیتُہُ وَمَعِی الْجُنْدُ ، فَدَخَلْتُ عَلَیْہِ ، فَقَالَ : یَا عُبَادَۃُ ، إِنَّا قَوْمٌ سَفْرٌ لَیْسَتْ عَلَیْنَا جُمُعَۃٌ ، فَجَمِّعْ بِأَصْحَابِکَ۔",,,5143,,
5144,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِبْرَاہِیمَ بن یَزِیدَ ، عَنْ عَوْنِ بْنِ عَبْدِ اللہِ بْنِ عُتْبَۃَ ، عَنِ ابْنِ مَسْعُودٍ ، قَالَ : لَیْسَ عَلَی الْمُسْلِمِینَ جُمُعَۃٌ فِی سَفَرِہِمْ ، وَلاَ یَوْمَ نَفْرِہِمْ۔",,,5144,,
5145,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مُجَالِدٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : لَیْسَ عَلَی الْمُسَافِرِ جُمُعَۃٌ۔",,,5145,,
5146,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، قَالَ : حدَّثَنَا رَجَائُ بْنُ أَبِی سَلَمَۃَ ، قَالَ : حَدَّثَنِی أَبُو عُبَیْدٍ مَوْلَی سُلَیْمَانَ بْنِ عَبْدِ الْمَلِکِ ، قَالَ : خَرَجَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ مِنْ دَابَقَ ، وَہُوَ یَوْمئِذٍ أَمِیرُ الْمُؤْمِنِینَ ، فَمَرَّ بِحَلَبٍ یَوْمَ الْجُمُعَۃِ ، فَقَالَ لأَمِیرِہَا : جَمِّعْ فَإِنَّا سَفْرٌ۔",,,5146,,
5147,"حَدَّثَنَا شَرِیکٌ ، عَنِ الأَسْوَدِ بْنِ قَیْسٍ ، عَنْ أَبِیہِ ، قَالَ : قَالَ عُمَرُ : الْجُمُعَۃُ لاَ تَمْنَعُ مِنْ سَفَرٍ۔",,,5147,,
5148,حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ صَالِحِ بْنِ کَیْسَانَ ؛ أَنَّ أَبَا عُبَیْدَۃَ خَرَجَ یَوْمَ الْجُمُعَۃِ فِی بَعْضِ أَسْفَارِہِ ، وَلَمْ یَنْتَظِرِ الْجُمُعَۃَ۔,,,5148,,
5149,حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ نَافِعٍ ؛ أَنَّ ابْنًا لِسَعِیدِ بْنِ زَیْدِ بْنِ نُفَیْلٍ کَانَ بِأَرْضٍ لَہُ بِالْعَقِیقِ ، عَلَی رَأْسِ أَمْیَالٍ مِنَ الْمَدِینَۃِ ، فَلَقِیَ ابْنَ عُمَرَ غَدَاۃَ الْجُمُعَۃِ فَأَخْبَرَہُ بِشَکْوَاہُ ، فَانْطَلَقَ إِلَیْہِ وَتَرَکَ الْجُمُعَۃَ۔,,,5149,,
5150,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یُونُسُ ، عَنِ الْحَسَنِ ، قَالَ : لاَ بَأْسَ بِالسَّفَرِ یَوْمَ الْجُمُعَۃِ ، مَا لَمْ یَحْضُرْ وَقْتُ الصَّلاَۃ۔",,,5150,,
5151,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا خَالِدٌ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّہُ کَانَ یَقُولُ ذَلِکَ۔",,,5151,,
5152,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ خَالِدٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : لاَ بَأْسَ بِالسَّفَرِ یَوْمَ الْجُمُعَۃِ۔",,,5152,,
5153,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ الْوَلِیدِ بْنِ کَثِیرٍ ، عَنْ مُحَمَّدِ بْنِ کَعْبٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی ذَؤیبٍ ، قَالَ : خَرَجْتُ مَعَ الزُّبَیْرِ مَخْرَجًا یَوْمَ الْجُمُعَۃِ ، فَصَلَّی الْجُمُعَۃَ أَرْبَعًا۔",,,5153,,
5154,"حَدَّثَنَا الْفَضْلُ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، قَالَ : رَأَیْتُ ابْنَ شِہَابٍ یُرِیدُ أَنْ یُسَافِرَ یَوْمَ الْجُمُعَۃِ ضَحْوَۃً ، فَقُلْتُ لَہُ : تُسَافِرُ یَوْمَ الْجُمُعَۃِ ؟ فَقَالَ : إِنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سَافَرَ یَوْمَ الْجُمُعَۃِ۔ (ابوداؤد 310۔ عبدالرزاق 5540)",,,5154,,
5155,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، عَنْ عَائِشَۃَ ، قَالَتْ : إِذَا أَدْرَکَتْکَ الْجُمُعَۃُ ، فَلاَ تَخْرُجْ حَتَّی تُصَلِّی الْجُمُعَۃَ۔",,,5155,,
5156,حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یُسَافِرُ لَیْلَۃَ الْجُمُعَۃِ ، فَإِذَا طَلَعَ الْفَجْرُ لَمْ یُسَافِرْ۔,,,5156,,
5157,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ خَیْثَمَۃَ ، قَالَ : کَانُوا یَسْتَحِبُّونَ إِذَا حَضَرَتِ الْجُمُعَۃُ أَنْ لاَ یَخْرُجُوا حَتَّی یُجَمِّعُوا۔",,,5157,,
5158,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، عَنْ حَسَّانَ بْنِ عَطِیَّۃَ ، قَالَ : إِذَا سَافَرَ یَوْمَ الْجُمُعَۃِ دُعِیَ عَلَیْہِ؛ أَنْ لاَ یُصَاحَبَ ، وَلاَ یُعَانَ عَلَی سَفَرِہِ۔ (عبدالرزاق 5542)",,,5158,,
5159,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، عَمَّنْ سَمِعَ سَعِیدَ بْنَ الْمُسَیَّبِ یَقُولُ : السَّفَرُ یَوْمَ الْجُمُعَۃِ بَعْدَ الصَّلاَۃ۔",,,5159,,
5160,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : خَرَجَ قَوْمٌ وَقَدْ حَضَرَتِ الْجُمُعَۃُ ، فَاضْطَرَمَ عَلَیْہِمْ خِبَاؤُہُمْ نَارًا مِنْ غَیْرِ نَارٍ یَرَوْنَہَا۔",,,5160,,
5161,حَدَّثَنَا شَاذَانُ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ؛ أَنَّ عُرْوَۃَ کَانَ یُسَافِرُ لَیْلَۃَ الْجُمُعَۃِ ، وَلاَ یَنْتَظِرُ الْجُمُعَۃَ۔,,,5161,,
5162,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنْ مُصْعَبِ بْنِ سَعْدٍ ، قَالَ : کَانَ سَعْدٌ یَقِیلُ بَعْدَ الْجُمُعَۃِ۔",,,5162,,
5163,"حَدَّثَنَا بِشْرُ بْنُ مُفَضَّلٍ ، عَنْ أَبِی حَازِمٍ ، عَنْ سَہْلِ بْنِ سَعْدٍ ، قَالَ : کُنَّا نَتَغَدَّی وَنَقِیلُ بَعْدَ الْجُمُعَۃِ۔ (بخاری 939۔ مسلم 588)",,,5163,,
5164,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُحَمَّدُ بْنُ سَعْدٍ الأَنْصَارِیُّ ، عَنْ أَبِیہِ ، قَالَ : کُنَّا نُجَمِّعُ مَعَ عُثْمَانَ بْنِ عَفَّانَ ، ثُمَّ نَرْجِعُ فَنَقِیلُ۔",,,5164,,
5165,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ حُمَیْدٍ ، عَنْ أَنَسٍ ، قَالَ : کُنَّا نُجَمِّعُ فَنَرْجِعُ فَنَقِیلُ۔ (بخاری 940)",,,5165,,
5166,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، قَالَ : حدَّثَنِی ثَابِتُ بْنُ الْحَجَّاجِ ، عَنِ ابْنِ عُمَرَ ، قَالَ : کُنَّا نُجَمِّعُ ، ثُمَّ نَرْجِعُ فَنَقِیلُ۔",,,5166,,
5167,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ بُدَیْلِ بْنِ مَیْسَرَۃَ ، عَنِ امْرَأَۃٍ ، قَالَتْ : جَاوَرْتُ مَعَ عُمَرَ سَنَۃً ، فَکَانَتِ الْقَائِلَۃُ بَعْدَ الْجُمُعَۃِ۔",,,5167,,
5168,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنِ الزِّبْرِقَانِ ، قَالَ : کُنَّا نُجَمِّعُ مَعَ أَبِی وَائِلٍ ، ثُمَّ نَرْجِعُ فَنَقِیلُ۔",,,5168,,
5169,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ عِمْرَان بْنِ مُسْلِمٍ ، عَنْ سُوَیْد بْنِ غَفَلَۃَ ، قَالَ : کُنَّا نُصَلِّی الْجُمُعَۃَ ، ثُمَّ نَرْجِعُ فَنَقِیلُ۔",,,5169,,
5170,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ زَیْدِ بْنِ وَہْبٍ ، قَالَ : کُنَّا نُصَلِّی مَعَ عَبْدِ اللہِ الْجُمُعَۃَ ، ثُمَّ نَرْجِعُ فَنَقِیلُ۔",,,5170,,
5171,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مُحَمَّدٍ الْمُحَارِبِیُّ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، قَالَ : حدَّثَنَا أَشْیَاخُنَا مِنْہُمْ : أَبُو سَلَمَۃَ، قَالَ : کُنَّا نَقِیلُ بَعْدَ الْجُمُعَۃِ۔",,,5171,,
5172,"حَدَّثَنَا عَبْدُ اللہِ بْنُ الأَجْلَحِ ، عَنِ الْحَسَنِ بْنِ عُبَیدِ اللہِ ، قَالَ : سَمِعْتُ ابْنَ أَبِی الْہُذَیْلِ یَقُولُ : کُنَّا نُصَلِّی الْجُمُعَۃَ ، ثُمَّ نَرْجِعُ فَنَقِیلُ۔",,,5172,,
5173,"حَدَّثَنَا شَرِیکٌ ، عَنِ الأَعْمَشِ ، عَنْ مُجَاہِدٍ ، قَالَ : مَا کَانَ لِلنَّاسِ عِیدٌ إِلاَّ فِی أَوَّلِ النَّہَارِ۔",,,5173,,
5174,"حَدَّثَنَا وَکِیعٌ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنْ ثَابِتِ بْنِ الْحَجَّاجِ الْکِلاَبِیِّ ، عَنْ عَبْدِ اللہِ بْنِ سِیدَانَ السُّلَمِیِّ، قَالَ : شَہِدْتُ الْجُمُعَۃَ مَعَ أَبِی بَکْرٍ الصِّدِّیقِ ، فَکَانَتْ خُطْبَتُہُ وَصَلاَتُہُ قَبْلَ نِصْفِ النَّہَارِ ، ثُمَّ شَہِدْنَا مَعَ عُمَرَ ، فَکَانَتْ خُطْبَتُہُ وَصَلاَتُہُ إِلَی أَنْ أَقُولَ : انْتَصَفَ النَّہَارُ ، ثُمَّ شَہِدْنَا مَعَ عُثْمَانَ ، فَکَانَتْ صَلاَتُہُ وَخُطْبَتُہُ إِلَی أَنْ أَقُولَ : زَالَ النَّہَارُ ، فَمَا رَأَیْتُ أَحَدًا عَابَ ذَلِکَ ، وَلاَ أَنْکَرَہُ۔",,,5174,,
5175,"حَدَّثَنَا جَرِیرٌ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنْ عَطَائٍ ، قَالَ : کَانَ مَنْ قَبْلَکُمْ یُصَلُّونَ الْجُمُعَۃَ ، وَإِنَّ ظِلَّ الْکَعْبَۃِ کَمَا ہُوَ۔",,,5175,,
5176,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَمْرِو بْنِ مُرَّۃٍ ، عَنْ عَبْدِ اللہِ بْنِ سَلِمَۃَ ، قَالَ : صَلَّی بِنَا عَبْدُ اللہِ الْجُمُعَۃَ ضُحًی ، وَقَالَ : خَشِیتُ عَلَیْکُمُ الْحَرَّ۔",,,5176,,
5177,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ عَمْرِو بْنِ مُرَّۃٍ ، عَنْ سَعِیدِ بْنِ سُوَیْد ، قَالَ : صَلَّی بِنَا مُعَاوِیَۃُ الْجُمُعَۃَ ضُحًی۔",,,5177,,
5178,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، قَالَ : حدَّثَنَا فُلَیْحُ بْنُ سُلَیْمَانَ ، قَالَ : أَخْبَرَنِی عُثْمَانُ بْنُ عَبْدِ الرَّحْمَنِ ؛ أَنَّہُ سَمِعَ أَنَسَ بْنَ مَالِکٍ ، یَقُولُ : کُنَّا نُصَلِّی مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْجُمُعَۃَ إِذَا مَالَتِ الشَّمْسُ۔ (بخاری 904۔ ابوداؤد 1077)",,,5178,,
5179,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا حَسَنُ بْنُ عَیَّاشٍ ، عَنْ جَعْفَرِ بْنِ مُحَمَّدٍ ، عَنْ أَبِیہِ ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ ، قَالَ : کُنَّا نُصَلِّی مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْجُمُعَۃَ ، ثُمَّ نَرْجِعُ فَنُرِیحُ نَوَاضِحَنَا۔ قَالَ حَسَنٌ : فَقُلْتُ لِجَعْفَرٍ : وَأَیُّ سَاعَۃٍ تِیکَ ؟ قَالَ : زَوَالُ الشَّمْسِ۔ (مسلم 29)",,,5179,,
5180,"حَدَّثَنَا وَکِیعٌ ، عَنْ یَعْلَی بْنِ الْحَارِثِ ، عَنْ إِیَاسِ بْنِ سَلَمَۃَ بْنِ الأَکْوَعِ ، عَنْ أَبِیہِ ، قَالَ : کُنَّا نُصَلِّی مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْجُمُعَۃَ إِذَا زَالَتِ الشَّمْسُ ، ثُمَّ نَرْجِعُ نَتَّبِعُ الْفَیْئَ۔ (بخار ی4168۔ مسلم 32)",,,5180,,
5181,"حَدَّثَنَا وَکِیعٌ، عَنْ أَبِی الْعَنْبَسِ عَمْرِو بْنِ مَرْوَانَ، عَنْ أَبِیہِ، قَالَ: کُنَّا نُجَمِّعُ مَعَ عَلِیٍّ إِذَا زَالَتِ الشَّمْسُ۔",,,5181,,
5182,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مُحَمَّدٍ الْمُحَارِبِیُّ ، عَنْ إِسْمَاعِیلَ بْنِ سُمَیْعٍ ، عَنْ بِلاَلٍ الْعَبْسِیِّ ؛ أَنَّ عَمَّارًا صَلَّی بِالنَّاسِ الْجُمُعَۃَ ، وَالنَّاسُ فَرِیقَانِ : بَعْضُہُمْ یَقُولُ : زَالَتِ الشَّمْسُ ، وَبَعْضُہُمْ یَقُولُ : لَمْ تَزَلْ۔",,,5182,,
5183,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ یُوسُفَ بْنِ مَاہَکَ ، قَالَ : قدِمَ مُعَاذٌ مَکَّۃَ وَہُمْ یُجَمِّعُونَ فِی الْحِجْرِ ، فَقَالَ : لاَ تُجَمِّعُوا حَتَّی تَفِیئَ الْکَعْبَۃُ مِنْ وَجْہِہَا۔",,,5183,,
5184,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَانُوا یُصَلُّونَ الْجُمُعَۃَ فِی عَہْدِ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ وَالْفَیْئُ ہُنَیْہَۃٌ۔",,,5184,,
5185,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : حدَّثَنَا مَنْصُورٌ ، عَنِ الْحَسَنِ ، قَالَ : وَقْتُ الْجُمُعَۃِ عِنْدَ زَوَالِ الشَّمْسِ۔",,,5185,,
5186,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ إِسْمَاعِیلَ بْنِ سُمَیْعٍ ، عَنْ أَبِی رَزِینٍ ، قَالَ : کُنَّا نُصَلِّی مَعَ عَلِیٍّ الْجُمُعَۃَ ، فَأَحْیَانًا نَجِدُ فَیْئًا ، وَأَحْیَانًا لاَ نَجِدُہُ۔",,,5186,,
5187,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، قَالَ : أَخْبَرَنَا الْحَسَنُ ، عَنْ سِمَاکٍ ، قَالَ : کَانَ النُّعْمَانُ بْنُ بَشِیرٍ یُصَلِّی بِنَا الْجُمُعَۃَ بَعْدَ مَا تَزُولُ الشَّمْسُ۔",,,5187,,
5188,"حَدَّثَتَا مُحَمَّدُ بْنُ بِشْرٍ الْعَبْدِیِّ ، قَالَ : حدَّثَنَا عَبْدُ اللہِ بْنُ الْوَلِیدِ ، عَنِ الْوَلِیدِ بْنِ الْعَیْزَارِ ، قَالَ : مَا رَأَیْتُ إِمَامًا کَانَ أَحْسَنَ صَلاَۃً لِلْجُمُعَۃِ مِنْ عَمْرِو بْنِ حُرَیْثٍ ، کَانَ یُصَلِّیہَا إِذَا زَالَتِ الشَّمْسُ۔",,,5188,,
5189,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : وَقْتُ الْجُمُعَۃِ ، وَقْتُ الظُّہْرِ۔",,,5189,,
5190,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ الرُّؤَاسِیُّ ، عَنِ حَسَنٍ ، عَنْ أَبِیہِ ، عَنْ أَبِی حَازِمٍ ، عن مَوْلًی لآلِ الزُّبَیْرِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْجُمُعَۃُ وَاجِبَۃٌ عَلَی کُلِّ حَالِمٍ ، إِلاَّ أَرْبَعَۃً : الصَّبِیُّ ، وَالْعَبْدُ ، وَالْمَرْأَۃُ ، وَالْمَرِیضُ۔ (بیہقی 184)",,,5190,,
5191,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ لَیْثٍ ، عَنْ مُحَمَّدِ بْنِ کَعْبٍ الْقُرَظِیِّ ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: مَنْ کَانَ یُؤْمِنُ بِاللَّہِ وَالْیَوْمِ الأَخِرِ ، فَعَلَیْہِ الْجُمُعَۃُ یَوْمَ الْجُمُعَۃِ ، إِلاَّ عَلَی امْرَأَۃٍ ، أَوْ صَبِیٍّ ، أَوْ مَمْلُوکٍ ، أَوْ مَرِیضٍ۔",,,5191,,
5192,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : لَیْسَ عَلَی النِّسَائِ جُمُعَۃٌ۔",,,5192,,
5193,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنٍ ، عَنْ أَبِی فَرْوَۃَ ، قَالَ : سَمِعْتُ الشَّعْبِیُّ یَقُولُ : الْجُمُعَۃ حَقٌ عَلَی کُلِّ مُؤْمِنٍ ، إِلاَّ ثَلاَثَۃٌ : عَبْدٌ مَمْلُوک ، أَوْ مَرِیضٌ ، أَوْ امْرَأَۃٌ۔",,,5193,,
5194,"حدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنِ الْوَصَّافِیِّ ، قَالَ : کُنْتُ عِنْدَ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ فَکَتَبَ إِلَی عَبْدِ الْحَمِیدِ : اُنْظُرْ مَنْ قِبَلَکَ مِنَ النِّسَائِ ، فَلاَ یَحْضُرْنَ جَمَاعَۃً ، وَلاَ جِنَازَۃً ، فَإِنَّہُ لاَ حَقَّ لَہُنَّ فِی جُمُعَۃٍ ، وَلاَ جِنَازَۃٍ۔",,,5194,,
5195,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : لَیْسَ عَلَی الْعَبْدِ جُمُعَۃٌ۔",,,5195,,
5196,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : لَیْسَ عَلَی الْعَبْدِ جُمُعَۃٌ۔",,,5196,,
5197,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ مُسْلِمِ بْنِ نَجِیحٍ ، عَنْ عَبْدِ اللہِ بْنِ مَعْدَانَ ، عَنْ جَدَّتِہِ ، قَالَتْ : قَالَ لَنَا عَبْدُ اللہِ بْنُ مَسْعُودٍ : إِذَا صَلَّیْتُنَّ یَوْمَ الْجُمُعَۃِ مَعَ الإِمَامِ ، فَصَلِّینَ بِصَلاَتِہِ ، وَإذَا صَلَّیْتُنَّ فِی بُیُوتِکُنَّ فَصَلِّینَ أَرْبَعًا۔",,,5197,,
5198,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی امْرَأَۃٍ تَحْضُرُ الْمَسْجِدَ یَوْمَ الْجُمُعَۃِ ، أَنَّہَا تُصَلِّی بِصَلاَۃِ الإِمَام وَیُجْزِئُہَا ذَلِکَ۔,,,5198,,
5199,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : إِنْ جَمَّعَنْ مَعَ الإِمَامِ ، أَجْزَأَہُنَّ مِنْ صَلاَۃِ الإِمَام۔",,,5199,,
5200,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : کُنَّ النِّسَائُ یُجَمِّعْنَ مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَکَانَ یُقَالُ : لاَ تَخْرُجْنَ إِلاَّ تَفِلاَتٍ ، لاَ یُوجَدُ مِنْکُنَّ رِیحُ طِیبٍ۔",,,5200,,
5201,"حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ؛ فِی الْمَرْأَۃِ تَأْتِی الْجُمُعَۃَ ، قَالَ : تُصَلِّی رَکْعَتَیْنِ یُجْزِئُ عَنْہَا ، وَلَکِنَّہُ لَیْسَ لَہَا أَنْ تَأْتِیَ الْجُمُعَۃَ۔",,,5201,,
5202,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : کُنَّ نِسَائُ الْمُہَاجِرِینَ یُصَلِّینَ الْجُمُعَۃَ مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، ثُمَّ یَحْتَسِبْنَ بِہَا مِنَ الظُّہْرِ۔",,,5202,,
5203,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، قَالَ : إِنْ صَلَّتْ مَعَ الإِمَامِ أَجْزَأَہَا۔",,,5203,,
5204,"حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی سُفْیَانَ ، عَنْ جَابِرٍ ، قَالَ : جَائَ سُلَیْکٌ الْغَطَفَانِیُّ وَالنَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَخْطُبُ یَوْمَ الْجُمُعَۃِ ، فَقَالَ : صَلِّ رَکْعَتَیْنِ تَجَوَّزْ فِیہِمَا۔ (بخاری 1166۔ ترمذی 510)",,,5204,,
5205,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مَنْصُورٌ ، وَأَبُو حُرَّۃَ ، وَیُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : جَائَ سُلَیْکٌ الْغَطَفَانِیُّ وَالنَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَخْطُبُ یَوْمَ الْجُمُعَۃِ ، وَلَمْ یَکُنْ صَلَّی الرَّکْعَتَیْنِ ، فَأَمَرَہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یُصَلِّیَ رَکْعَتَیْنِ یَتَجَوَّزُ فِیہِمَا۔",,,5205,,
5206,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا أَبُو مَعْشَرٍ ، عَنْ مُحَمَّدِ بْنِ قَیْسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَیْثُ أَمَرَہُ أَنْ یُصَلِّیَ رَکْعَتَیْنِ ، أَمْسَکَ عَنِ الْخُطْبَۃِ حَتَّی فَرَغَ مِنْ رَکْعَتَیْہِ ، ثُمَّ عَادَ إِلَی خُطْبَتِہِ۔ (دارقطنی 13)",,,5206,,
5207,حَدَّثَنَا حَفْصٌ ، عَنْ حَمَّادِ بْنِ أَبِی الدَّرْدَائِ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یُصَلِّی رَکْعَتَیْنِ وَالإِمَام یَخْطُبُ۔,,,5207,,
5208,"حَدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَانَ الْحَسَنُ یَجِیئُ وَالإِمَام یَخْطُبُ فَیُصَلِّی رَکْعَتَیْنِ۔",,,5208,,
5209,"حَدَّثَنَا وَکِیعٌ ، عَنْ عِمْرَانَ بْنِ حُدَیْرٍ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ : إِذَا جِئْتَ وَالإِمَام یَخْطُبُ یَوْمَ الْجُمُعَۃِ ، فَإِنْ شِئْتَ رَکَعْتَ رَکْعَتَیْنِ ، وَإِنْ شِئْتَ جَلَسْتَ۔",,,5209,,
5210,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ (ح) وَعَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ (ح) وَعَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ أَنَّہُمْ کَرِہُوا الصَّلاَۃ وَالإِمَام یَخْطُبُ یَوْمَ الْجُمُعَۃِ۔,,,5210,,
5211,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا ہِشَامٌ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّہُ کَانَ یَقُولُ : إِذَا خَرَجَ الإِمَامُ فَلاَ یُصَلِّ أَحَدٌ حَتَّی یَفْرُغَ الإِمَام۔",,,5211,,
5212,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا إِسْمَاعِیلُ بْنُ أَبِی خَالِدٍ ، قَالَ : رَأَیْتُ شُرَیْحًا دَخَلَ یَوْمَ الْجُمُعَۃِ مِنْ أَبْوَابِ کِنْدَۃَ فَجَلَسَ ، وَلَمْ یُصَلِّ۔",,,5212,,
5213,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، قَالَ : إِذَا قَعَدَ الإِمَام عَلَی الْمِنْبَرِ فَلاَ صَلاَۃَ۔",,,5213,,
5214,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ؛ فِی الرَّجُلِ یَجِیئُ یَوْمَ الْجُمُعَۃِ وَالإِمَامُ یَخْطُبُ یَجْلِسُ ، وَلاَ یُصَلِّی۔,,,5214,,
5215,"حَدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَانَ ابْنُ سِیرِینَ یَجْلِسُ ، وَلاَ یُصَلِّی۔",,,5215,,
5216,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ یَزِیدَ بْنِ عَبْدِ اللہِ ، عَنْ ثَعْلَبَۃَ بْنِ أَبِی مَالِکٍ الْقُرَظِیِّ ، قَالَ : أَدْرَکْتُ عُمَرَ ، وَعُثْمَانَ ، فَکَانَ الإِمَام إِذَا خَرَجَ یَوْمَ الْجُمُعَۃِ تَرَکْنَا الصَّلاَۃ۔",,,5216,,
5217,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : خُرُوجُ الإِمَامِ یَقْطَعُ الصَّلاَۃ۔",,,5217,,
5218,حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، وَابْنِ عُمَرَ ؛ أَنَّہُمَا کَانَا یَکْرَہَانِ الصَّلاَۃ وَالْکَلاَمَ بَعْدَ خُرُوجِ الإِمَام۔,,,5218,,
5219,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ تَوْبَۃَ ، عَنِ الشَّعْبِیِّ ، قَالَ : کَانَ شُرَیْحٌ إِذَا أَتَی الْجُمُعَۃَ ، فَإِنْ لَمْ یَکُنْ خَرَجَ الإِمَامُ صَلَّی رَکْعَتَیْنِ ، وَإِنْ کَانَ خَرَجَ جَلَسَ وَاحْتَبَی ، وَاسْتَقْبَلَ الإِمَام ، فَلَمْ یَلْتَفِتْ یَمِینًا ، وَلاَ شِمَالاً۔",,,5219,,
5220,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ سِمَاکٍ ، عَنْ جَابِرِ بْنِ سَمُرَۃَ ، قَالَ : کَانَتْ لِرَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ خُطْبَتَانِ یَجْلِسُ بَیْنَہُمَا ، یَقْرَأُ الْقُرْآنَ وَیُذَکِّرُ النَّاسَ۔ (مسلم 35۔ ابوداؤد 1087)",,,5220,,
5221,"حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَخْطُبُ قَائِمًا ، ثُمَّ یَجْلِسُ ، ثُمَّ یَقُومُ ، یَخْطُبُ خُطْبَتَیْنِ۔ (بیہقی 198)",,,5221,,
5222,"حَدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ : لَمْ یَکُنْ أَبُو بَکْرٍ ، وَلاَ عُمَرُ یَقْعُدَانِ عَلَی الْمِنْبَرِ یَوْمَ الْجُمُعَۃِ ، وَأَوَّلُ مَنْ قَعَدَ مُعَاوِیَۃُ۔",,,5222,,
5223,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ : خَطَبَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَائِمًا ، وَأَبُو بَکْرٍ قَائِمًا ، وَعُثْمَانَ قَائِمًا ، وَإِنَّ أَوَّلَ مَنْ جَلَسَ عَلَی الْمِنْبَرِ مُعَاوِیَۃُ بْنُ أَبِی سُفْیَانَ۔",,,5223,,
5224,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنِ الْحَسَنِ ، عَنْ إِسْحَاقَ ، قَالَ : رَأَیْتُ عَلِیًّا یَخْطُبُ عَلَی الْمِنْبَرِ ، فَلَمْ یَجْلِسْ حَتَّی فَرَغَ۔",,,5224,,
5225,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مَنْصُورٍ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ أَبِی عُبَیْدَۃَ ، عَنْ کَعْبِ بْنِ عُجْرَۃَ ، قَالَ: دَخَلَ الْمَسْجِدَ وَعَبْدُ الرَّحْمَن بْنُ أُمِّ الْحَکَمِ یَخْطُبُ قَاعِدًا ، فَقَالَ : اُنْظُرُوا إِلَی ہَذَا الْحَدَثِ یَخْطُبُ قَاعِدًا ، قَالَ اللَّہُ تَعَالَی : (وَإِذَا رَأَوْا تِجَارَۃً ، أَوْ لَہْوَا نِانْفَضُّوا إِلَیْہَا وَتَرَکُوکَ قَائِمًا)۔",,,5225,,
5226,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، قَالَ : سَأَلَہُ رَجُلٌ ، أَکَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَخْطُبُ قَائِمًا ، أَوْ قَاعِدًا ؟ قَالَ : أَلَسْتَ تَقْرَأُ : {وَتَرَکُوک قَائِمًا}۔",,,5226,,
5227,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنْ سَالِمٍ ، عَنْ جَابِرٍ ، قَالَ : أَقْبَلَتْ عِیرٌ بِتِجَارَۃٍ یَوْمَ جُمُعَۃِ ، وَرَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَخْطُبُ ، فَانْصَرَفَ النَّاسُ یَنْظُرُونَ ، وَبَقِیَ رَسُولُ اللہِ فِی اثْنَیْ عَشَرَ رَجُلاً ، فَنَزَلَتْ ہَذِہِ الأَیَۃُ : { وَإِذَا رَأَوْا تِجَارَۃً ، أَوْ لَہْوَا نِانْفَضُّوا إِلَیْہَا ، وَتَرَکُوکَ قَائِمًا }۔ (بخار ی4899۔ مسلم 38)",,,5227,,
5228,"حَدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ : الْجُلُوسُ عَلَی الْمِنْبَرِ یَوْمَ الْجُمُعَۃِ بِدْعَۃٌ۔",,,5228,,
5229,"حَدَّثَنَا أَحْمَدُ بْنُ عَبْدِ اللہِ ، عَنْ زَائِدَۃَ ، عَنْ عَبْدِ الْمَلِکِ بْنِ عُمَیْرٍ ، قَالَ : کَانَ الْمُغِیرَۃُ یَخْطُبُ فِی الْجُمُعَۃِ قَائِمًا ، وَلَمْ یَکُنْ لَہُ إِلاَّ مُؤَذِّنٌ وَاحِدٌ۔",,,5229,,
5230,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، قَالَ : أَخْبَرَنَا حَسَنُ بْنُ صَالِحٍ ، عَنْ سِمَاکٍ ، قَالَ : رَأَیْتُ النُّعْمَانَ یَخْطُبُ قَائِمًا۔",,,5230,,
5231,"حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ ، قَالَ : حَدَّثَنَا ابْنُ أَبِی ذِئْبٍ ، عَنْ صَالِحٍ ، قَالَ : رَأَیْتُ أَبَا ہُرَیْرَۃَ ، وَکَانَ مَرْوَانُ اسْتَخْلَفَہُ عَلَی الْمَدِینَۃِ ، فَکَانَ یَخْطُبُ خُطْبَتَیْنِ ، وَیَجْلِسُ جِلْسَتَیْنِ۔",,,5231,,
5232,حَدَّثَنَا الْمُحَارِبِیُّ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنْ مِقْسَمٍ ، عَنِ ابْنِ عَبَّاسٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ أَنَّہُ کَانَ یَخْطُبُ یَوْمَ الْجُمُعَۃِ قَائِمًا ، ثُمَّ یَقْعُدُ ، ثُمَّ یَقُومُ فَیَخْطُبُ۔ (احمد 1/257۔ بزار 640),,,5232,,
5233,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : سُئِلَ عَبْدُ اللہِ عَنِ الْخُطْبَۃِ یَوْمَ الْجُمُعَۃِ ؟ فَقَرَأَ : {وَتَرَکُوک قَائِمًا}۔",,,5233,,
5234,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی سِنَانٍ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، قَالَ : سَأَلْتُ أَبَا عُبَیْدَۃَ عَنِ الْخُطْبَۃِ یَوْمَ الْجُمُعَۃِ ؟ فَقَرَأَ : {وَتَرَکُوک قَائِمًا}۔",,,5234,,
5235,"حَدَّثَنَا وَکِیعٌ ، عَنْ یَزِیدَ ، عَنِ ابْنِ سِیرِینَ ؛ سُئِلَ عَنْ خُطْبَۃِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَوْمَ الْجُمُعَۃِ ؟ فَقَرَأَ : {وَتَرَکُوک قَائِمًا}۔",,,5235,,
5236,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ، عَنِ الشَّعْبِیِّ، قَالَ: إِنَّمَا خَطَبَ مُعَاوِیَۃُ قَاعِدًا، حِیْنَ کَثُرَ شَحْمُ بَطْنِہِ وَلَحْمُہُ۔",,,5236,,
5237,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الْعُمَرِیُّ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَخْطُبُ خُطْبَتَیْنِ ، یَجْلِسُ بَیْنَہُمَا۔ (بخاری 928۔ مسلم 589)",,,5237,,
5238,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حدَّثَنَا مُجَالِدٌ ، عَنِ الشَّعْبِیِّ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إِذَا صَعِدَ الْمِنْبَرَ یَوْمَ الْجُمُعَۃِ اسْتَقْبَلَ النَّاسَ بِوَجْہِہِ ، فَقَالَ : السَّلاَمُ عَلَیْکُمْ ، وَیَحْمَدُ اللَّہَ وَیُثْنِی عَلَیْہِ وَیَقْرَأُ سُورَۃً، ثُمَّ یَجْلِسُ ، ثُمَّ یَقُومُ فَیَخْطُبُ ، ثُمَّ یَنْزِلُ ۔ وَکَانَ أَبُو بَکْرٍ ، وَعُمَرُ یَفْعَلاَنِہِ۔ (عبدالرزاق 5281)",,,5238,,
5239,"حَدَّثَنَا غَسَّانُ بْنُ مُضَرَ ، عَنْ سَعِیدِ بْنِ یَزِیدَ ، عَنْ أَبِی نَضْرَۃَ ، قَالَ : کَانَ عُثْمَانُ قَدْ کَبُرَ ، فَإِذَا صَعِدَ الْمِنْبَرَ ، سَلَّمَ فَأَطَالَ قَدْرَ مَا یَقْرَأُ إِنْسَانٌ أُمَّ الْکِتَابِ۔",,,5239,,
5240,حَدَّثَنَا إِسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ عَمْرِو بْنِ مُہَاجِرٍ ؛ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ کَانَ إِذَا اسْتَوَی عَلَی الْمِنْبَرِ سَلَّمَ عَلَی النَّاسِ ، وَرَدُّوا عَلَیْہِ۔,,,5240,,
5241,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ سِمَاکٍ ، عَنْ جَابِرِ بْنِ سَمُرَۃَ ، قَالَ : کَانَتْ خُطْبَۃُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَصْدًا ، وَصَلاَتُہُ قَصْدًا۔",,,5241,,
5242,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ شَقِیقٍ ، قَالَ : قَالَ : عَبْدُ اللہِ : إِنَّ قِصَرَ الْخُطْبَۃِ وَطُولَ الصَّلاَۃ مَئِنَّۃٌ مِنْ فِقْہِ الرَّجُلِ۔ (بزار 638)",,,5242,,
5243,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْمَاعِیلَ ، عَنْ قَیْسٍ ، قَالَ : قَالَ : عَبْدُ اللہِ : أَحْسِنُوا ہَذِہِ الصَّلاَۃ ، وَاقْصِرُوا ہَذِہِ الْخُطْبَۃَ۔",,,5243,,
5244,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنِ الْعَلاَئِ بْنِ صَالِحٍ ، عَنْ عَدِیِّ بْنِ ثَابِتٍ ، قَالَ : حدَّثَنَا أَبُو رَاشِدٍ ، قَالَ : خَطَبَنَا عَمَّارٌ ، فَتَجَوَّزَ فِی الْخُطْبَۃِ ، فَقَالَ رَجُلٌ : قَدْ قُلْتَ قَوْلاً شِفَائً لَوْ أَنَّک أَطَلْتَ ، فَقَالَ : إِنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی أَنْ نُطِیلَ الْخُطْبَۃَ۔ (ابوداؤد 1099۔ حاکم 289)",,,5244,,
5245,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ إِسْحَاقَ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی بَکْرٍ ، عَنْ یَحْیَی بْنِ عَبْدِ اللہِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ سَعْدِ بْن زُرَارَۃَ ، عَنْ أُمِّ ہِشَامٍ ابْنَۃِ جَارِیَۃَ ، أَوْ حَارِثَۃَ ، قَالَتْ : مَا أَخَذْتُ (ق وَالْقُرْآنِ الْمَجِیدِ) إِلاَّ عَلَی لِسَانِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، یَقْرَؤُہَا عَلَی النَّاسِ فِی کُلِّ یَوْمِ جُمُعَۃٍ إِذَا خَطَبَہُمْ۔ (مسلم 51۔ ابوداؤد 1093)",,,5245,,
5246,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ عَاصِمِ بْنِ کُلَیْبٍ ، عَنْ أَبِیہِ ، قَالَ : کَانَ عُمَرُ یُعْجِبُہُ أَنْ یَقْرَأَ بِسُورَۃِ آلِ عِمْرَانَ فِی الْجُمُعَۃِ إِذَا خَطَبَ۔",,,5246,,
5247,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ ہَارُونَ بْنِ عَنْتَرَۃَ ، عَنْ أَبِیہِ ؛ أَنَّ عَلِیًّا قَرَأَ وَہُوَ عَلَی الْمِنْبَرِ : {قُلْ یَا أَیُّہَا الْکَافِرُونَ} وَ {قُلْ ہُوَ اللَّہُ أَحَدٌ}۔",,,5247,,
5248,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ، قَالَ : نَزَلْنَا الْمَدَائِنَ ، فَکُنَّا مِنْہَا عَلَی رَأْسِ فَرْسَخٍ ، فَجَائَتِ الْجُمُعَۃُ ، فَحَضَرَ أَبِی وَحَضَرْتُ مَعَہُ ، فَخَطَبَنَا حُذَیْفَۃُ ، فَقَالَ : إِنَّ اللَّہَ تَبَارَکَ وَتَعَالَی یَقُولُ : {اقْتَرَبَتِ السَّاعَۃُ وَانْشَقَّ الْقَمَرُ}۔",,,5248,,
5249,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنْ بَکْرِ بْنِ عَبْدِ اللہِ ، عَنْ صَفْوَانَ بْنِ مُحْرِزٍ ، قَالَ : بَیْنَا الأَشْعَرِیُّ یَخْطُبُ یَوْمَ الْجُمُعَۃِ ، إِذْ قَرَأَ السَّجْدَۃَ الآخِرَۃَ فِی سُورَۃِ الْحَجِّ۔",,,5249,,
5250,"حَدَّثَنَا وَکِیعٌ ، عَنْ طَلْحَۃَ بْنِ یَحْیَی ، قَالَ : سَمِعْتُ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ یَقْرَأُ وَہُوَ عَلَی الْمِنْبَرِ : {وَأَنِیبُوا إِلَی رَبِّکُمْ وَأَسْلِمُوا لَہُ} ، وَفِی یَدِہِ عَصًا۔",,,5250,,
5251,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ سِمَاکِ بْنِ حَرْبٍ ، قَالَ : قُلْتُ لَہُ : کَیْفَ کَانَ یَخْطُبُ النُّعْمَانُ ؟ قَالَ : کَانَ یَلْمَعُ بِیَدَیْہِ ۔ قَالَ : وَکَانَ الضَّحَّاکُ بْنُ قَیْسٍ إِذَا خَطَبَ ضَمَّ یَدَہُ عَلَی فِیہِ۔",,,5251,,
5252,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنْ عُمَارَۃَ بْنِ رُوَیْبَۃَ ؛ رَأَی بِشْرَ بْنَ مَرْوَانَ یَرْفَعُ یَدَیْہِ عَلَی الْمِنْبَرِ ، فَقَالَ : قبَّحَ اللَّہُ ہَاتَیْنِ الْیَدَیْنِ ، لَقَدْ رَأَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَا یَزِیدُ عَلَی أَنْ یَقُولَ بِیَدِہِ ہَکَذَا ، وَأَشَارَ بِإِصْبَعِہِ الْمُسَبِّحَۃِ۔ (ترمذی 515۔ ابوداؤد 1097)",,,5252,,
5253,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، قَالَ : إِذْنُ الإِمَام یَوْمَ الْجُمُعَۃِ أَنْ یُشِیرَ بِیَدِہِ۔",,,5253,,
5254,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ خَالِدٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : کَانُوا یَسْتَأْذِنُونَ الإِمَام وَہُوَ عَلَی الْمِنْبَرِ ، فَلَمَّا کَانَ زِیَادٌ وَکَثُرَ ذَلِکَ ، قَالَ : مَنْ وَضَعَ یَدَہُ عَلَی أَنْفِہِ فَہُوَ إِذْنُہُ۔",,,5254,,
5255,"حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی سُفْیَانَ ، عَنْ جَابِرٍ ، قَالَ : جَائَ سُلَیْکٌ الْغَطَفَانِیُّ وَالنَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَخْطُبُ یَوْمَ الْجُمُعَۃِ ، فَقَالَ لَہُ : صَلَّیْتَ ؟ قَالَ : لاَ ، قَالَ : صَلِّ رَکْعَتَیْنِ ، تَجَوَّزْ فِیہِمَا۔",,,5255,,
5256,"حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَخْطُبُ ، فَقَالَ لِلنَّاسِ : اجْلِسُوا ، فَسَمِعَہُ عَبْدُ اللہِ بْنُ مَسْعُودٍ وَہُوَ عَلَی الْبَابِ فَجَلَسَ ، فَقَالَ لَہُ : یَا عَبْدَ اللہِ ، اُدْخُلْ۔ (عبدالرزاق 5368۔ بیہقی 218)",,,5256,,
5257,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، وَابْنُ نُمَیْرٍ ، عَنْ إِسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنْ قَیْسٍ ، قَالَ : جَائَ أَبِی وَالنَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَخْطُبُ ، فَقَامَ بَیْنَ یَدَیْہِ فِی الشَّمْسِ ، فَأَمَرَ بِہِ ، فَحُوِّلَ إِلَی الظِّلِّ۔ (احمد 3/426۔ حاکم 171)",,,5257,,
5258,"حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : إِنْ کَانُوا لَیُسْلِّمُونَ عَلَی الإِمَام وَہُوَ عَلَی الْمِنْبَرِ فَیَرُدُّ۔",,,5258,,
5259,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ ہِلاَلِ بْنِ قَیْسٍ ، عَنْ زَیْدِ بْنِ صُوحَانَ ، قَالَ : إِذَا سَمِعْتُ الرَّجُلَ وَالإِمَام یَخْطُبُ یَوْمَ الْجُمُعَۃِ یَتَکَلَّمُ ، فَإِنْ کَانَ قَرِیبًا مِنْک فَاغْمِزْہُ ، وَإِنْ کَانَ بَعِیدًا فَأَشِرْ إِلَیْہِ ، وَلاَ تَرْمِہِ بِالْحَصَی۔",,,5259,,
5260,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی فَرْوَۃَ ، قَالَ : رَأَیْتُ ابْنَ أَبِی لَیْلَی وَأَشَارَ إِلَی مُحَمَّدِ بْنِ سَعْدٍ ، وَتَکَلَّمَ : أَنِ اسْکُتْ۔",,,5260,,
5261,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا عُبَیْدُ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ رَأَی رَجُلاً یَتَکَلَّمُ وَالإِمَام یَخْطُبُ یَوْمَ الْجُمُعَۃِ ، فَرَمَاہُ بِحَصًی ، فَلَمَّا نَظَرَ إِلَیْہِ وَضَعَ یَدَہُ عَلَی فِیہِ۔",,,5261,,
5262,"حَدَّثَنَا وَکِیعٌ ، عَنْ بُکَیْرِ بْنِ عَامِرٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ؛ فِی الرَّجُلِ یَتَکَلَّمُ وَالإِمَام یَخْطُبُ یَوْمَ الْجُمُعَۃِ ، فَقَالَ : یَضَعُ یَدَہُ عَلَی فِیہِ ، وَلاَ یَرْمِیہِ بِالْحَصَی۔",,,5262,,
5263,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ عَوْنٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : یَضَعُ یَدَہُ عَلَی فِیہِ۔",,,5263,,
5264,حَدَّثَنَا عَبْدُ الْوَہَّابُ الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ ؛ أَنَّہُ کَانَ یُشِیرُ إِلَی الرَّجُلِ الَّذِی یَتَکَلَّمُ أَنْ یَسْکُتَ۔,,,5264,,
5265,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا بَعْضُ أَشْیَاخِنَا ، عَنِ الْحَسَنِ ؛ أَنَّہُ رَأَی إِنْسَانًا یَتَکَلَّمُ یَوْمَ الْجُمُعَۃِ وَالإِمَام یَخْطُبُ ، فَرَمَاہُ بِالْحَصَی۔",,,5265,,
5266,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ مُحَمَّدِ بْنِ مُسْلِمٍ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ طَاوُوسٍ ، قَالَ : لاَ تُشِرْ إِلَی أَحَدٍ یَوْمَ الْجُمُعَۃِ ، وَلاَ تَنْہَہُ عَنْ شَیْئٍ ، وَلاَ تَدْعُ إِلاَّ أَنْ یَدْعُوَ الإِمَامُ۔",,,5266,,
5267,حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ إِسْرَائِیلَ ، عَنْ مَجْزَأَۃَ بْنِ زَاہِرٍ ، عَنْ أَبِیہِ ؛ أَنَّہُ رَأَی رَجُلاً یَتَکَلَّمُ یَوْمَ الْجُمُعَۃِ ، فَأَشَارَ إِلَیْہِ أَنِ اُسْکُتْ۔,,,5267,,
5268,"حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ ، عَنْ خَالِدِ بْنِ أَبِی عُثْمَانَ ، عَنْ سَعِیدِ بْنِ عَبْدِ اللہِ بْنِ یَسَارٍ ، قَالَ : کُنْتُ مَعَ سَعِیدِ بْنِ جُبَیْرٍ یَوْمَ جُمُعَۃِ وَالإِمَام یَخْطُبُ ، فَمَسِسْتُ الْحَصَی ، فَضَرَبَ یَدِی۔",,,5268,,
5269,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبَانَ بْنِ عَبْدِ اللہِ الْبَجَلِیِّ ، عَنْ عَدِیِّ بْنِ ثَابِتٍ ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إِذَا خَطَبَ اسْتَقْبَلَہُ أَصْحَابُہُ بِوُجُوہِہِمْ۔ (ابن ماجہ 1136)",,,5269,,
5270,حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ عَوْنٍ ، عَنِ الشَّعْبِیِّ، عَنْ شُرَیْحٍ؛ أَنَّہُ کَانَ یَسْتَقْبِلُ الإِمَامَ یَوْمَ الْجُمُعَۃِ إِذَا خَطَبَ، وَلاَ یَقُولُ ہَکَذَا ، وَلاَ ہَکَذَا۔,,,5270,,
5271,حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی إِسْحَاقَ ؛ عَمَّنْ رَأَی صَعْصَعَۃَ یَسْتَقْبِلُ الإِمَامَ یَوْمَ الْجُمُعَۃِ۔,,,5271,,
5272,"حَدَّثَنَا وَکِیعٌ ، عَنْ یُونُسَ ، عَنِ الشَّعْبِیِّ ، قَالَ : مِنَ السُّنَّۃِ أَنْ یُسْتَقْبَلَ الإِمَام یَوْمَ الْجُمُعَۃِ۔",,,5272,,
5273,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ حُمَیْدٍ ، قَالَ : رَأَیْتُ النَّضْرَ بْنَ أَنَسٍ یَسْتَقْبِلُ الإِمَامَ۔",,,5273,,
5274,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، قَالَ : رَأَیْتُ إِبْرَاہِیمَ یَوْمَ الْجُمُعَۃِ دَخَلَ مِمَّا یَلِی أَبْوَابَ کِنْدَۃَ ، فَجَلَسَ وَجَعَلَ وَجْہَہُ قِبَلَ الْمِنْبَرِ۔",,,5274,,
5275,"حَدَّثَنَا وَکِیعٌ ، عَنْ وَاصِلِ بْنِ السَّائِبِ الرَّقَاشِیِّ ، قَالَ : رَأَیْتُ عَطَائً ، وَطَاوُوسًا ، وَمُجَاہِدًا یَسْتَقْبِلُونَ الإِمَامَ یَوْمَ الْجُمُعَۃِ۔",,,5275,,
5276,"حَدَّثَنَا عَبْدُ الصَّمَدِ ، عَنِ الْمُسْتَمِرِّ بْنِ الرَّیَّانِ ، قَالَ : رَأَیْتُ أَنَسًا عِنْدَ الْبَابِ الأَوَّلِ یَوْمَ الْجُمُعَۃِ ، قَدِ اسْتَقْبَلَ الْمِنْبَرَ۔",,,5276,,
5277,حَدَّثَنَا الْمُحَارِبِیُّ، عَنْ سُفْیَانَ، عَنْ جَابِرٍ، عَنْ سَالِمٍ، وَالْقَاسِمِ؛ أَنَّہُمَا کَانَا یَسْتَقْبِلاَنِ الإِمَام یَوْمَ الْجُمُعَۃِ۔,,,5277,,
5278,حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ سُفْیَانَ ، عَنْ حَکِیمِ بْنِ الدَّیْلَمِ ، عَنْ زَاذَانَ ؛ أَنَّہُ کَانَ یَسْتَقْبِلُ الإِمَام یَوْمَ الْجُمُعَۃِ۔,,,5278,,
5279,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا عَبْدُ الْحَمِیدِ بْنُ جَعْفَرٍ الأَنْصَارِیُّ ، بِإِسْنَادٍ لاَ أَحْفَظُہُ ، قَالَ : کَانُوا یَجِیئُونَ یَوْمَ الْجُمُعَۃِ فَیَجْلِسُونَ حَوْلَ الْمِنْبَرِ ، ثُمَّ یُقْبِلُونَ عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِوُجُوہِہِمْ۔",,,5279,,
5280,"حَدَّثَنَا مُحَمَّدُ بْنُ مُصْعَبٍ ، عَنِ الأَوْزَاعِیِّ ، عَنْ عَمْرِو بْنِ مُہَاجِرٍ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : الْوَاعِظُ قِبْلَۃٌ ، یَعْنِی الإِمَامُ۔",,,5280,,
5281,حَدَّثَنَا أَبُوخَالِدٍ الأَحْمَرِِ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ؛ أَنَّہُ کَانَ یَحْتَبِی وَالإِمَام یَخْطُبُ۔,,,5281,,
5282,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّہُ کَانَ مُحْتَبِیًا یَوْمَ الْجُمُعَۃِ وَالإِمَام یَخْطُبُ۔,,,5282,,
5283,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، قَالَ : رَأَیْتُ سَالِمًا ، وَالْقَاسِمَ یَحْتَبِیَانِ یَوْمَ الْجُمُعَۃِ وَالإِمَام یَخْطُبُ۔",,,5283,,
5284,"حَدَّثَنَا وَکِیعٌ ، عَنْ فِطْرٍ ، قَالَ : رَأَیْتُ عَطَائً مُحْتَبِیًا یَوْمَ الْجُمُعَۃِ۔",,,5284,,
5285,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، قَالَ : رَأَیْتُ الْحَسَنَ یَحْتَبِی وَالإِمَام یَخْطُبُ یَوْمَ الْجُمُعَۃِ۔",,,5285,,
5286,"حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنْ سَالِمٍ الْخَیَّاطِ ، قَالَ : رَأَیْتُ الْحَسَنَ ، وَمُحَمَّدًا ، وَعِکْرِمَۃَ بْنَ خَالِدٍ الْمَخْزُومِیَّ ، وَعَمْرَو بْنَ دِینَارٍ ، وَأَبَا الزُّبَیْرِ ، وَعَطَائً یَحْتَبُونَ یَوْمَ الْجُمُعَۃِ وَالإِمَام یَخْطُبُ۔",,,5286,,
5287,حَدَّثَنَا وَکِیعٌ ، عَنِ الْعُمَرِیِّ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَحْتَبِی وَالإِمَامُ یَخْطُبُ یَوْمَ الْجُمُعَۃِ۔,,,5287,,
5288,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حدَّثَنَا عُبَیْدُ اللہِ ، عَنْ نَافِعٍ ، قَالَ : کَانَ ابْنُ عُمَرَ یَحْتَبِی یَوْمَ الْجُمُعَۃِ وَالإِمَام یَخْطُبُ۔",,,5288,,
5289,حَدَّثَنَا مُحَمَّدُ بْنُ مُصْعَبٍ ، عَنِ الأَوْزَاعِیِّ ، عَنْ مَکْحُولٍ ، وَعَطَائٍ ، وَالْحَسَنِ ؛ أَنَّہُمْ کَانُوا یَکْرَہُونَ أَنْ یَحْتَبُوا وَالإِمَام یَخْطُبُ یَوْمَ الْجُمُعَۃِ۔,,,5289,,
5290,"حَدَّثَنَا إِسْمَاعِیلُ بْنُ إِبْرَاہِیمَ ، عَن أَیُّوبَ ، قَالَ : سَمِعْتُ رَجُلاً یَخْطُبُ ، یَقُولُ ، قَالَ مُحَمَّدٌ : إِنَّ النَّوْمَ فِی الْجُمَعِ مِنَ الشَّیْطَانِ ، فَإِذَا نَعَسَ أَحَدُکُمْ فَلْیَتَحَوَّلْ۔",,,5290,,
5291,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنِ ابْنِ عُمَرَ ، قَالَ : إِذَا نَعَسْتَ یَوْمَ الْجُمُعَۃِ وَالإِمَامُ یَخْطُبُ فَتَحَوَّلْ۔",,,5291,,
5292,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، قَالَ : کَانَ مُحَمَّدٌ یُوقِظُ النَّائِمَ یَوْمَ الْجُمُعَۃِ ، وَالإِمَامُ یَخْطُبُ۔",,,5292,,
5293,حَدَّثَنَا الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّہُ کَانَ إِذَا خَشِیَ أَنْ یَنْعَسَ فِی الْجُمُعَۃِ تَحَوَّلَ۔,,,5293,,
5294,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، وَطَاوُوس ؛ فِی الَّذِی یَنْعُسُ یَوْمَ الْجُمُعَۃِ ، فَقَالَ أَحَدُہُمَا : یَتَزَحْزَحُ عَنْ مَکَانِہِ ، وَقَالَ الأَخَرُ : یَتَنَحَّی عَنْ مَکَانِہِ۔",,,5294,,
5295,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُبَارَکٍ ، عَنِ الْحَسَنِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : النَّوْمُ ، أَوِ النُّعَاسُ فِی الْجُمُعَۃِ مِنَ الشَّیْطَانِ ، فَإِذَا نَعَسَ أَحَدُکُمْ فَلْیَتَحَوَّلْ۔",,,5295,,
5296,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا مُحَمَّدُ بْنُ إِسْحَاقَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، یَقُولُ : إِذَا نَعَسَ أَحَدُکُمْ یَوْمَ الْجُمُعَۃِ فَلْیَتَحَوَّلْ مِنْ مَجْلِسِہِ إِلَی غَیْرِہِ۔ (ترمذی 526۔ ابوداؤد 112)",,,5296,,
5297,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ الأَحْوَص بْنِ حَکِیمٍ ، عَنْ طَاوُوسٍ ، قَالَ : لأَنْ تَخْتَلِفَ السِّیَاطُ عَلَی ظَہْرِی ، أَحَبُّ إِلَیَّ مِنْ أَنْ أَنَامَ وَالإِمَام یَخْطُبُ یَوْمَ الْجُمُعَۃِ۔",,,5297,,
5298,حَدَّثَنَا إِسْمَاعِیلُ بْنُ عُلَیَّۃَ ، عَنِ الْجُرَیرِیِّ ؛ أَنَّ أَبَا الْعَلاَئِ کَانَ یَنَامُ یَوْمَ الْجُمُعَۃِ وَہُوَ قَاعِدٌ۔,,,5298,,
5299,"حَدَّثَنَا عُبَیْدُ اللہِ ، عَنْ إِسْرَائِیلَ ، عَنْ عَبْدِ اللہِ بْنِ الْمُخْتَارِ ، عَنْ مَالِکِ بْنِ دِینَارٍ ، قَالَ : کَانَ أَبُو الْعَالِیَۃِ ، وَخِلاَسُ بْنُ عَمْرٍو یَنَامَانِ یَوْمَ الْجُمُعَۃِ نَوْمًا طَوِیلاً ، ثُمَّ یَقُومَانِ فَیُصَلِّیَانِ۔",,,5299,,
5300,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : حدَّثَنَا سَعِیدُ بْنُ أَبِی عَرُوبَۃَ ، عَنْ سَعِیدِ بْنِ أَبِی حُرَّۃَ ، عَنْ نَافِعٍ ، قَالَ: کَانَ ابْنُ عُمَرَ یَحْتَبِی یَوْمَ الْجُمُعَۃِ وَالإِمَام یَخْطُبُ ، فَإِنْ طَالَ وَضَعَ رَأْسَہُ فِی حِجْرِی۔",,,5300,,
5301,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یُونُسُ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یُسَلِّمُ إِذَا جَائَ وَالإِمَامُ یَخْطُبُ ، وَیَرُدُّونَ عَلَیْہِ السَّلاَمَ۔",,,5301,,
5302,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، وَالأَعْمَشُ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانُوا یَرُدُّونَ السَّلاَمَ یَوْمَ الْجُمُعَۃِ وَالإِمَام یَخْطُبُ ، وَیُشَمِّتُونَ الْعَاطِسَ۔",,,5302,,
5303,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، وَحَمَّادٍ ؛ فِی الرَّجُلِ یَدْخُلُ الْمَسْجِدَ یَوْمَ الْجُمُعَۃِ وَقَدْ خَرَجَ الإِمَام ، قَالاَ : یُسَلِّمُ وَیَرُدُّونَ عَلَیْہِ ، وَإِذَا عَطَسَ شَمَّتُوہُ وَرَدُّوا عَلَیْہِ۔",,,5303,,
5304,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرِ ، عَنْ عَامِرٍ ، وَسَالِمٍ ، قَالاَ : یَرُدُّ السَّلاَمَ یَوْمَ الْجُمُعَۃِ وَیُسْمِعُ۔",,,5304,,
5305,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ أَبِی عَوَانَۃَ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ؛ أَنَّہُ کَانَ یَکْرَہُ أَنْ یَرُدَّ السَّلاَمَ وَیُشَمِّتَ الْعَاطِسَ وَالإِمَامُ یَخْطُبُ۔,,,5305,,
5306,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا ابْنُ عَوْنٍ ، عَنْ إِبْرَاہِیمَ ، وَابْنِ سِیرِینَ ؛ أَنَّہُ سَأَلَہُمَا عَنْ رَدِّ السَّلاَمِ یَوْمَ الْجُمُعَۃِ وَالإِمَام یَخْطُبُ ؟ فَقَالاَ : کَانَ یُقَالُ: مَنْ قَالَ انْصِتْ فَقَدْ لَغَا۔",,,5306,,
5307,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ عَوْنٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : السُّکُوتَ۔",,,5307,,
5308,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، قَالَ : کَانَ مُحَمَّدٌ یَقُولُ : إِذَا سُلِّمَ عَلَیْک یَوْمَ الْجُمُعَۃِ وَالإِمَام یَخْطُبُ ، فَأَوْمِیئْ إِلَیْہِ۔",,,5308,,
5309,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ اللہِ بْنِ سَعِیدٍ ، قَالَ : سَمِعْتُ سَعِیدَ بْنَ الْمُسَیَّبِ ، وَسَأَلَہُ رَجُلٌ عَنْ رَجُلٍ شَمَّتَ رَجُلاً وَالإِمَام یَخْطُبُ ، أَلَغَا ؟ قَالَ : لاَ ، وَلَکِنْ لاَ یَعُودُ۔",,,5309,,
5310,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، قَالَ : قَالَ مُحَمَّدُ بْنُ عَلِیٍّ ، وَالْقَاسِمُ : یَرُدُّ فِی نَفْسِہِ۔",,,5310,,
5311,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ أَبِی الْہَیْثُمِ ، قَالَ : سَلَّمْتُ عَلَی إِبْرَاہِیمَ وَالإِمَامُ یَخْطُبُ یَوْمَ الْجُمُعَۃِ فَلَمْ یَرُدَّ عَلَیَّ ، وَقَالَ حِینَ صَلَّی : إِنَّ الْکَلاَمَ یُکْرَہُ۔",,,5311,,
5312,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ ؛ أَنَّ أَمِیرًا بِالْبَحْرَیْنِ أشْتَکَی ، فَأَمَرَ رَجُلاً فَصَلَّی بِالنَّاسِ ، فَلَمْ یَخْطُبْ فَصَلَّی أَرْبَعًا ، قَالَ مُحَمَّدٌ : فَأَصَابَ السُّنَّۃَ۔",,,5312,,
5313,حَدَّثَنَا ہُشَیْمٌ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ؛ مِثْلَہُ۔,,,5313,,
5314,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ، عَنْ سَعِیدٍ، عَنْ أَبِی مَعْشَرٍ، عَنْ إِبْرَاہِیمَ، قَالَ: إذَا لَمْ یَخْطُبِ الإِمَامُ صَلَّی أَرْبَعًا۔",,,5314,,
5315,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : الإِمَامُ إِذَا لَمْ یَخْطُبْ صَلَّی أَرْبَعًا۔",,,5315,,
5316,"حَدَّثَنَا یَحْیَی بْنُ أَبِی بُکَیْرٍ ، قَالَ : أَخْبَرَنَا إِبْرَاہِیمُ بْنُ نَافِعٍ ، قَالَ : سَمِعْتُ ابْنَ طَاوُوس یَذْکُرُ ذَلِکَ ، عَنْ أَبِیہِ ، قَالَ : مَنْ خَطَبَ فَلْیُصَلِّ رَکْعَتَیْنِ ، وَمَنْ لَمْ یَخْطُبْ فَلْیُصَلِّ أَرْبَعًا۔",,,5316,,
5317,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : کَانَ یُصَلِّی أَرْبَعًا۔",,,5317,,
5318,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الزُّبَیْرِ بْنِ عَدِیٍّ ، عَنِ الضَّحَّاکِ ، قَالَ : یُصَلِّی أَرْبَعًا۔",,,5318,,
5319,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ؛ أَنَّہُ انْطَلَقَ حَاجًّا ، فَقَدِمَ تَبُوکَ فِی یَوْمَ الْجُمُعَۃِ ، فَصَلَّی إِمَامُہُمْ رَکْعَتَیْنِ ، وَلَمْ یَخْطُبْ ، فَقَالَ مَکْحُولٌ : قَاتَلَ اللَّہُ ہَذَا الَّذِی نَقَصَ صَلاَۃَ الْقَوْمِ ، وَلَمْ یَخْطُبْ ، وَإِنَّمَا قُصِّرَتْ صَلاَۃُ الْجُمُعَۃِ مِنْ أَجْلِ الْخُطْبَۃِ۔",,,5319,,
5320,حَدَّثَنَا مُعْتَمِرٌ ، عَنْ کَہْمَسٍ ، عَنْ عَبْدِ اللہِ بْنِ مُسْلِمِ بْنِ یَسَارٍ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ إِذَا خَطَبَ الإِمَامُ ، لَمْ یُسَبِّحْ وَلَمْ یَدْعُ۔,,,5320,,
5321,"حَدَّثَنَا ہُشَیْمٌ، عَنْ حُصَیْنٍ، عَنْ مَیْمُونٍ؛ أَنَّہُ کَرِہَ الْکَلاَمَ وَالإِمَام یَخْطُبُ یَوْمَ الْجُمُعَۃِ، وَقَالَ: یَذْکُرُ اللَّہَ۔",,,5321,,
5322,"حَدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ : إِذَا تَکَلَّمَ الإِمَامُ یَوْمَ الْجُمُعَۃِ ، فَلاَ کَلاَمَ إِلاَّ أَنْ یَقْرَأَ قُرْآنًا۔",,,5322,,
5323,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : قُلْتُ لِعَلْقَمَۃَ : أَقْرَأُ فِی نَفْسِی ؟ قَالَ : لَعَلَّ ذَلِکَ أَنْ لاَ یَکُونَ بِہِ بَأْسٌ۔",,,5323,,
5324,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا فِی الرَّجُلِ یَوْمَ الْجُمُعَۃِ أَنْ یَذْکُرَ اللَّہَ فِی نَفْسِہِ وَالإِمَام یَخْطُبُ۔,,,5324,,
5325,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : سَأَلْتُ مُحَمَّدًا عَنِ الرَّجُلِ یَکُونُ یَوْمَ الْجُمُعَۃِ بَعِیدًا مِنَ الإِمَام ، لاَ یَسْمَعُ صَوْتَہُ، یَقْرَأُ فِی أُذُنِ صَاحِبِہِ؟ قَالَ: لاَ أَعْلَمُ عَلَی الرَّجُلِ بَأْسًا أَنْ یَذْکُرَ اللَّہَ فِی نَفْسِہِ۔",,,5325,,
5326,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ أَنْ یَقْرَأَ وَیَذْکُرَ اللَّہَ ، إِذَا قَرَؤُوا الصُّحُفَ یَوْمَ الْجُمُعَۃِ۔",,,5326,,
5327,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ فِرَاسٍ ، عَنْ عَامِرٍ ، قَالَ : لاَ بَأْسَ بِالْکَلاَمِ وَالصُّحُفِ تُقْرَأُ یَوْمَ الْجُمُعَۃِ۔",,,5327,,
5328,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ؛ أَنَّ أَبَا بُرْدَۃَ کَانَ یَتَکَلَّمُ فِی الْجُمُعَۃِ وَالصُّحُفُ تُقْرَأُ ، وَکَانَ الشَّعْبِیُّ لاَ یَرَی بِہِ بَأْسًا۔,,,5328,,
5329,"حَدَّثَنَا إِسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ عُبَیْدِ اللہِ ، عَنْ مُحَمَّدِ بْنِ عَلِیٍّ ، قَالَ : لاَ بَأْسَ بِالْکَلاَمِ إِذَا قُرِئَتِ الصُّحُفُ یَوْمَ الْجُمُعَۃِ ، حَتَّی یَأْخُذَ الإِمَامُ فِی الْمَوْعِظَۃِ۔",,,5329,,
5330,حَدَّثَنَا إِسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ عَمْرِو بْنِ مُہَاجِرٍ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ؛ أَنَّہُ مَنَعَ الصُّحُفَ أَنْ تُقْرَأَ یَوْمَ الْجُمُعَۃِ ، حَتَّی یَفْرُغَ مِنَ الْخُطْبَۃِ۔,,,5330,,
5331,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَبِی حَیَّانَ ، عَنْ حَمَّادٍ ، قَالَ : قُلْتُ لإِبْرَاہِیمَ : إِنَّ الْکُتُبَ تَجِیئُ مِنْ قِبَلِ قُتَیْبَۃَ فِیہَا الْبَاطِلُ وَالْکَذِبُ ، فَإِذَا أَرَدْتُ أُکَلِّمُ صَاحِبِی ، أَوْ أُنْصِتُ ؟ قَالَ : لاَ ، بَلْ أَنْصِتْ ، یَعْنِی فِی الْجُمُعَۃِ۔",,,5331,,
5332,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : لَقِیَنِی حَمَّادُ بْنُ أَبِی سُلَیْمَانَ وَالْمُؤَذِّنُونَ یُؤَذِّنُونَ یَوْمَ الْجُمُعَۃِ ، وَقَدْ خَرَجَ الإِمَام ، فَکَلَّمَنِی فَلَمْ أُکَلِّمْہُ ۔ ثُمَّ اجْتَمَعْنَا فِی جُمُعَۃٍ أُخْرَی ، فَکَلَّمَنِی وَالصُّحُفُ تُقْرَأُ ، فَجَعَلَ یُکَلِّمُنِی ، وَلاَ أُکَلِّمُہُ ، فَقَالَ : یَابْنَ أَخِی ، إِنَّمَا کَانَ السُّکُوتُ قَبْلَ الْیَوْمِ إِذَا وَعَظُوا بِکِتَابِ اللہِ ، وَقَالُوا فِیہِ ، فَنَسْکُتُ لِصُحُفِہِمْ ہَذِہِ ؟ ۔ قَالَ ابْنُ عَوْنٍ : فَذَکَرْتُہُ لإِبْرَاہِیمَ ، فَقَالَ إِبْرَاہِیمُ : إِنَّ الشَّیْطَانَ یَأْتِی أَحَدَہُمَ ، اللہُمَّ ، أَوْ نَفْسَہُ ، إِنَّمَا کَانَ السُّکُوتُ قَبْلُ إِذَا وَعَظُوا بِکِتَابِ اللہِ ، وَقَالُوا فِیہِ۔",,,5332,,
5333,"حَدَّثَنَا وَکِیعٌ ، عَنِ الرَّبِیعِ ، عَنِ الْحَسَنِ ، قَالَ : کَانَ یُکْرَہُ الْکَلاَمُ وَالصُّحُفُ تُقْرَأُ ، وَقَالَ الْحَسَنُ : کَانَتِ الصُّحُفُ تُقْرَأُ قَبْلَ الصَّلاَۃ۔",,,5333,,
5334,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سَعِیدِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ خَالِدِ بْنِ عِیسَی ، قَالَ : رَأَیْتُ عُمَرَ بْنَ عَبْدَ الْعَزِیزِ یُحَدِّثُ الْوَلِیدَ بْنَ ہِشَامٍ ، وَسُلَیْمَانُ أَمِیرُ الْمُؤْمِنِینَ عَلَی الْمِنْبَرِ ، وَصُحُفٌ تُقْرَأُ فِی یَوْمِ الْجُمُعَۃِ۔",,,5334,,
5335,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنِ الرُّکَیْنِ ، عَنْ أَبِیہِ ، عَنْ عَبْدِ اللہِ ، قَالَ : کَفَی لَغْوًا إِذَا صَعِدَ الإِمَام الْمِنْبَرَ أَنْ تَقُولَ لِصَاحِبِکَ أَنْصِتْ۔",,,5335,,
5336,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : قًلْتُ لِعَلْقَمَۃَ : مَتَی یُکْرَہُ الْکَلاَمُ یَوْمَ الْجُمُعَۃِ ؟ قَالَ : إِذَا صَعِدَ الإِمَامُ الْمِنْبَرَ ، وَإِذَا خَطَبَ الإِمَامُ ، وَإِذَا تَکَلَّمَ الإِمَامُ۔",,,5336,,
5337,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ عُبَیْدِ اللہِ بْنِ عَبْدِ اللہِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : مَنْ قَالَ لِصَاحِبِہِ یَوْمَ الْجُمُعَۃِ أَنْصِتْ ، وَالإِمَام یَخْطُبُ ، فَقَدْ لَغَا۔ (عبدالرزاق 5417)",,,5337,,
5338,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ أَبِی الزِّنَادِ ، عَنِ الأَعْرَجِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : إِذَا قُلْتَ لِصَاحِبِکَ أَنْصِتْ ، فَقَدْ لَغَوْتَ۔",,,5338,,
5339,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ یَزِیدَ بْنِ عَبْدِ اللہِ ، عَنْ ثَعْلَبَۃَ بْنِ أَبِی مَالِکٍ الْقُرَظِیِّ ، قَالَ: أَدْرَکْتُ عُمَرَ ، وَعُثْمَانَ ، فَکَانَ الإِمَامُ إِذَا خَرَجَ یَوْمَ الْجُمُعَۃِ تَرَکْنَا الصَّلاَۃ، فَإِذَا تَکَلَّمَ تَرَکْنَا الْکَلاَمَ۔",,,5339,,
5340,حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، وَابْنِ عُمَرَ ؛ أَنَّہُمَا کَانَا یَکْرَہَانِ الصَّلاَۃ وَالْکَلاَمَ یَوْمَ الْجُمُعَۃِ بَعْدَ خُرُوجِ الإِمَامِ۔,,,5340,,
5341,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یُصَلِّی یَوْمَ الْجُمُعَۃِ ،فَإِذَا خَرَجَ الإِمَامُ لَمْ یُصَلِّ۔,,,5341,,
5342,"حَدَّثَنَا ابْنُ عُلَیَّۃُ ، عَنْ مَعْمَرٍ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ: خُرُوجُ الإِمَامِ یَقْطَعُ الصَّلاَۃَ، وَکَلاَمُہُ یَقْطَعُ الْکَلاَمَ۔",,,5342,,
5343,حَدَّثَنَا ہُشَیْمٌ ، عَنْ حُصَیْنٍ ، عَنْ مَیْمُونِ بْنِ مِہْرَانَ ؛ أَنَّہُ کَرِہَ الْکَلاَمَ وَالإِمَام یَخْطُبُ۔,,,5343,,
5344,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَشْعَثَ ، عَنِ الزُّہْرِیِّ ، قَالَ : خُرُوجُ الإِمَام یَقْطَعُ الصَّلاَۃَ ، وَکَلاَمُہُ یَقْطَعُ الْکَلاَمَ۔",,,5344,,
5345,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ إِبْرَاہِیمَ ، عَن نَافِعٍ ، عَنْ سَعِیدِ بْنِ أَبِی ہِنْدٍ ، عَنْ حُمَیْدِ بْنِ عَبْدِ الرَّحْمَنِ ، قَالَ : إِذَا قَالَ الرَّجُلُ یَوْمَ الْجُمُعَۃِ وَالإِمَام یَخْطُبُ أَنْصِتْ ، فَقَدْ لَغَا۔",,,5345,,
5346,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ دَاوُدَ بْنِ أَبِی ہِنْدٍ ، عَنْ بَکْرِ بْنِ عَبْدِ اللہِ ، عَنْ عَلْقَمَۃَ بْنِ عَبْدِ اللہِ ، قَالَ : قدِمْنَا الْمَدِینَۃَ یَوْمَ الْجُمُعَۃِ ، فَأَمَرْتُ أَصْحَابِی أَنْ یَرْتَحِلُوا ، ثُمَّ أَتَیْتُ الْمَسْجِدَ ، فَجَلَسْتُ قَرِیبًا مِنِ ابْنِ عُمَرَ ، فَجَائَ رَجُلٌ مِنْ أَصْحَابِی ، فَجَعَلَ یُحَدِّثُنِی وَالإِمَامُ یَخْطُبُ ، فَعلْنَا کَذَا وَکَذَا ، فَلَمَّا أَکْثَرَ قُلْتُ لَہُ : اُسْکُتْ ، فَلَمَّا قَضَیْنَا الصَّلاَۃ ذَکَرْتُ ذَلِکَ لْاِبْنِ عُمَرَ ، فَقَالَ : أَمَّا أَنْتَ فَلاَ جُمُعَۃَ لَکَ ، وَأَمَّا صَاحِبُک فَحِمَارٌ۔",,,5346,,
5347,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا دَاوُد بْنُ أَبِی ہِنْدٍ ، عَنِ الشَّعْبِیِّ ؛ أَنَّ أَبَا ذَرٍّ ، أَوِ الزُّبَیْرَ بْنَ الْعَوَّامِ ، سَمِعَ أَحَدُہُمَا مِنَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ آیَۃً یَقْرَؤُہَا وَہُوَ عَلَی الْمِنْبَرِ یَوْمَ الْجُمُعَۃِ ، قَالَ : فَقَالَ لِصَاحِبِہِ : مَتَی أُنْزِلَتْ ہَذِہِ الأَیَۃُ ؟ قَالَ : فَلَمَّا قَضَی صَلاَتَہُ ، قَالَ لَہُ عُمَرُ بْنُ الْخَطَّابِ : لاَ جُمُعَۃَ لَکَ ، فَأَتَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَذَکَرَ ذَلِکَ لَہُ ، قَالَ : فَقَالَ : صَدَقَ عُمَرُ۔",,,5347,,
5348,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ مُجَالِدٍ ، عَنْ عَامِرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: مَنْ تَکَلَّمَ یَوْمَ الْجُمُعَۃِ وَالإِمَامُ یَخْطُبُ فَہُوَ کَالْحِمَارِ یَحْمِلُ أَسْفَارًا ، وَالَّذِی یَقُولُ لَہُ أَنْصِتْ لَیْسَتْ لَہُ جُمُعَۃٌ۔ (احمد 1/230)",,,5348,,
5349,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُجَالِدٍ ، عَنْ عَامِرٍ ، عَنْ جَابِرٍ ، قَالَ : قَالَ سَعْدٌ لِرَجُلٍ یَوْمَ الْجُمُعَۃِ : لاَ صَلاَۃَ لَکَ، قَالَ : فَذَکَرَ ذَلِکَ الرَّجُلُ لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : یَا رَسُولَ اللہِ ، إِنَّ سَعْدًا قَالَ : لاَ صَلاَۃَ لَکَ ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لِمَ یَا سَعْدُ ؟ قَالَ : إِنَّہُ تَکَلَّمَ وَأَنْتَ تَخْطُبُ ، فَقَالَ : صَدَقَ سَعْدٌ۔ (بزار 642۔ ابو یعلی 708)",,,5349,,
5350,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ إِبْرَاہِیمَ السَّکْسَکِیِّ ، قَالَ : سَمِعْتُ ابْنَ أَبِی أَوْفَی ، قَالَ : ثَلاَثَۃٌ مَنْ سَلِمَ مِنْہُنَّ غُفِرَ لَہُ مَا بَیْنَہُ وَبَیْنَ الْجُمُعَۃِ الأُخْرَی ؛ مِنْ أَنْ یُحْدِثَ حَدَثًا لاَ یَعْنِی أَذًی مِنْ بَطْنِہِ ، أَوْ أَنْ یَتَکَلَّمَ ، أَوْ یَقُولَ : صَہْ۔",,,5350,,
5351,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : إِذَا قَالَ یَوْمَ الْجُمُعَۃِ وَالإِمَام یَخْطُبُ : صَہٍ ، فَقَدْ لَغَا۔",,,5351,,
5352,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : أَخْبَرَنَا إِسْمَاعِیلُ بْنُ أَبِی خَالِدٍ ، قَالَ : رَأَیْتُ إِبْرَاہِیمَ یُکَلِّمُ رَجُلاً وَالإِمَام یَخْطُبُ یَوْمَ الْجُمُعَۃِ۔",,,5352,,
5353,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَیْمَنَ بْنِ نَابِلٍ ، عَنْ إِسْمَاعِیلَ بْنِ أُمَیَّۃَ ، عَنْ عُرْوَۃَ بْنِ الزُّبَیْرِ ، قَالَ : کَانَ لاَ یَرَی بَأْسًا بِالْکَلاَمِ إِذَا لَمْ یَسْمَعِ الْخُطْبَۃَ یَوْمَ الْجُمُعَۃِ۔",,,5353,,
5354,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْمَاعِیلَ بْنِ إِبْرَاہِیمَ ، عَن أَبِیہِ ، قَالَ : رَأَیْتُ إِبْرَاہِیمَ ، وَسَعِیدَ بْنَ جُبَیْرٍ یَتَکَلَّمَانِ وَالْحَجَّاجُ یَخْطُبُ۔",,,5354,,
5355,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ بُرْدِ بْنِ سِنَانٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رُبَّمَا کُلِّمَ فِی الْحَاجَۃِ یَوْمَ الْجُمُعَۃِ فِیمَا بَیْنَ نُزُولِہِ مِنْ مِنْبَرِہِ إِلَی مُصَلاَّہُ۔ (ابوداؤد 63)",,,5355,,
5356,"حَدَّثَنَا یَحْیَی بْنُ سُلَیْمٍ الطَّائِفِیُّ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، قَالَ : أَدْرَکْتُ أَبِی وَمَنْ مَضَی مِمَّنْ یَرْضَاہُ وَنَأْخُذُ عَنْہُمْ ، لاَ یَرَوْنَ بَأْسًا بِالْکَلاَمِ حِینَ یَنْزِلُ الإِمَامُ مِنَ الْمِنْبَرِ إِلَی أَنْ یَدْخُلَ فِی الصَّلاَۃ۔",,,5356,,
5357,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ، عَنْ إِبْرَاہِیمَ بْنِ مَیْسَرَۃَ، قَالَ: کَلَّمَنِی طَاوُوسٌ بَعْدَ مَا نَزَلَ سُلَیْمَانُ مِنَ الْمِنْبَرِ۔",,,5357,,
5358,حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَمُحَمَّدٍ ؛ أَنَّہُمَا کَانَا لاَ یَرَیَانِ بَأْسًا أَنْ یَتَکَلَّمَ فِیمَا بَیْنَ نُزُولِہِ إِلَی أَنْ یُکَبِّرَ۔,,,5358,,
5359,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حَجَّاجٌ ، عَنْ عَطَائٍ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا بِالْکَلاَمِ حَتَّی یَخْطُبَ ، وَإِذَا فَرَغَ مِنَ الْخُطْبَۃِ حَتَّی یَدْخُلَ فِی الصَّلاَۃ۔",,,5359,,
5360,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ ، وَحَمَّادًا عَنِ الْکَلاَمِ إِذَا خَرَجَ الإِمَام حَتَّی یَتَکَلَّمَ ، وَإِذَا نَزَلَ قَبْلَ أَنْ یُصَلِّیَ ؟ فَکَرِہَہُ الْحَکَمُ ، وَقَالَ حَمَّادٌ : لاَ بَأْسَ بِہِ۔",,,5360,,
5361,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ مَعْمَرٍ ، عَنْ قَتَادَۃَ ، قَالَ : یَتَکَلَّمُ مَا لَمْ یَجْلِسْ۔",,,5361,,
5362,"حَدَّثَنَا وَکِیعٌ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، عَنْ ثَابِتٍ ، عَنْ أَنَسٍ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَنْزِلُ یَوْمَ الْجُمُعَۃِ مِنَ الْمِنْبَرِ ، فَیَقُومُ مَعَہُ الرَّجُلُ فَیُکَلِّمُہُ فِی الْحَاجَۃِ ، ثُمَّ یَنْتَہِی إِلَی مُصَلاَّہُ فَیُصَلِّی۔ (ترمذی 517۔ ابوداؤد 1113)",,,5362,,
5363,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، قَالَ : رَأَیْتُ إِبْرَاہِیمَ ، وَإِبْرَاہِیمَ بْنَ مُہَاجِرٍ یَتَکَلَّمَانِ یَوْمَ الْجُمُعَۃِ وَالإِمَامُ یَخْطُبُ ، فَلَقِیتُ إِبْرَاہِیمَ بْنَ مُہَاجِرٍ بَعْدَ ذَلِکَ ، فَذَکَرْتُ ذَلِکَ لَہُ ، فَقَالَ : إِنَّا کُنَّا صَلَّیْنَا ۔ وَکَانَ الإِمَامُ الْحَجَّاجَ۔",,,5363,,
5364,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ: کَانَ یُقَالُ: لاَ کَلاَمَ بَعْدَ أَنْ یَنْزِلَ الإِمَام مِنَ الْمِنْبَرِ حَتَّی یَقْضِیَ الصَّلاَۃ۔",,,5364,,
5365,"حَدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : نُبِّئْتُ عَنْ إِبْرَاہِیمَ أَنَّہُ کَرِہَہُ۔",,,5365,,
5366,"حَدَّثَنَا عَبْدُاللہِ بْنُ مُبَارَکٍ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ (ح) وَعَنِ ابْنِ الْمُبَارَکِ ، عَنِ الْحَسَنِ (ح) وَعَنِ ابْنِ عُلاَثَۃَ ، عَنِ الزُّہْرِیِّ ؛ فِی الَّذِی یَتَکَلَّمُ وَالإِمَامُ یَخْطُبُ یَوْمَ الْجُمُعَۃِ ، قَالُوا : یُصَلِّی رَکْعَتَیْنِ۔",,,5366,,
5367,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا ہِشَامُ بْنُ أَبِی عَبْدِ اللہِ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، قَالَ : حُدِّثْتُ عَنْ عُمَرَ بْنِ الْخَطَّابِ أَنَّہُ قَالَ : إِنَّمَا جُعِلَتِ الْخُطْبَۃُ مَکَانَ الرَّکْعَتَیْنِ ، فَإِنْ لَمْ یُدْرِکِ الْخُطْبَۃَ فَلْیُصَلِّ أَرْبَعًا۔",,,5367,,
5368,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا دَاودُ بْنُ أَبِی ہِنْدٍ ، عَنْ عَطَائٍ ؛ أَنَّہُ کَانَ یَقُولُ : إِذَا لَمْ یُدْرِکِ الْخُطْبَۃَ فَلْیُصَلِّ أَرْبَعًا۔",,,5368,,
5369,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ عَطَائٍ ، وَطَاوُوسٍ ، وَمُجَاہِدٍ ؛ قَالُوا : إِذَا فَاتَتْہُ الْخُطْبَۃُ یَوْمَ الْجُمُعَۃِ صَلَّی أَرْبَعًا۔",,,5369,,
5370,"حَدَّثَنَا مُعْتَمِرٌ، عَنْ أَبِیہِ ، قَالَ: بَلَغَنِی عَنْ عَطَائٍ، وَطَاوُوسٍ ، قَالاَ: مَنْ فَاتَہُ الْقَصَصُ یَوْمَ الْجُمُعَۃِ فَلْیُصَلِّ أَرْبَعًا۔",,,5370,,
5371,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ، قَالَ : إِذَا فَاتَتْہُ الْخُطْبَۃُ صَلَّی أَرْبَعًا۔",,,5371,,
5372,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ مُوسَی بْنِ عَبْدِ الْوَاحِدِ الرَّمْلِیِّ ، قَالَ : سَمِعْتُ عَطَائَ بْنَ یَزِیدَ اللَّیْثِیَّ ، قَالَ : إِذَا فَاتَتْہُ الْخُطْبَۃُ فَلْیُصَلِّ أَرْبَعًا۔",,,5372,,
5373,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : ذُکِرَ لِمُحَمَّدٍ قَوْلُ أَہْلِ مَکَّۃَ ، إِذَا لَمْ یُدْرِکِ الْخُطْبَۃَ صَلَّی أَرْبَعًا ، فَقَالَ : لَسَ(3 ہَذَا بِشَیْئٍ۔",,,5373,,
5374,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَوْزَاعِیِّ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ عُمَرَ بْنِ الْخَطَّابِ ، قَالَ : کَانَتِ الْجُمُعَۃُ أَرْبَعًا ، فَجُعِلَتْ رَکْعَتَیْنِ مِنْ أَجْلِ الْخُطْبَۃِ ، فَمَنْ فَاتَتْہُ الْخُطْبَۃُ فَلْیُصَلِّ أَرْبَعًا۔",,,5374,,
5375,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا زَکَرِیَّا بْنُ أَبِی زَائِدَۃَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الأَحْوَص ، قَالَ : قَالَ عَبْدُ اللہِ : مَنْ أَدْرَکَ رَکْعَۃً مِنَ الْجُمُعَۃِ فَلْیُصَلِّ إِلَیْہَا أُخْرَی ، وَمَنْ لَمْ یُدْرِکِ الرُّکُوعَ فَلْیُصَلِّ أَرْبَعًا۔",,,5375,,
5376,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الأَحْوَص ، قَالَ : قَالَ عَبْدُ اللہِ : مَنْ أََدْرَکَ الْجُمُعَۃَ فَہِیَ رَکْعَتَانِ ، وَمَنْ لَمْ یُدْرِکْ فَلْیُصَلِّ أَرْبَعًا۔",,,5376,,
5377,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : مَنْ أَدْرَکَ مِنَ الْجُمُعَۃِ رَکْعَۃً فَلْیُضِفْ إِلَیْہَا أُخْرَی۔",,,5377,,
5378,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إِبْرَاہِیمَ ، قَالَ : قَالَ أَبُو مَعْمَرٍ : شَیْئٌ وَدِدْتُ أَنِّی کُنْتُ سَأَلْتُ عَنْہُ الأَسْوَدَ ، قَالَ : قَالَ إِبْرَاہِیمُ : وَمَا ہُوَ ؟ فَلَعَلَّک قَدْ کُفِیتَہُ ، قَالَ : الرَّجُلُ یُدْرِکُ مِنَ الْجُمُعَۃِ رَکْعَۃً ؟ قَالَ : قَالَ الأَسْوَدُ : مَنْ أَدْرَکَ مِنَ الْجُمُعَۃِ رَکْعَۃً فَلْیُصَلِّ رَکْعَۃً أُخْرَی ، وَمَنْ لَمْ یُدْرِکِ الرُّکُوعَ فَلْیُصَلِّ أَرْبَعًا۔",,,5378,,
5379,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یُونُسُ ، عَنِ الْحَسَنِ (ح) وَمُغِیرَۃُ ، عَنْ إِبْرَاہِیمَ (ح) وَإِسْمَاعِیلُ بْنُ أَبِی خَالِدٍ ، عَنِ الشَّعْبِیِّ ، قَالُوا : مَنْ أَدْرَکَ رَکْعَۃً مِنَ الْجُمُعَۃِ فَلْیُضِفْ إِلَیْہَا أُخْرَی ، وَمَنْ لَمْ یُدْرِکِ الرُّکُوعَ فَلْیُصَلِّ أَرْبَعًا۔",,,5379,,
5380,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا إِسْمَاعِیلُ بْنُ سَالِمٍ ، قَالَ : سَمِعْتُ الشَّعْبِیَّ یَقُولُ : مَنْ أَدْرَکَ الْخُطْبَۃَ فَہِیَ الْجُمُعَۃُ ، وَمَنْ أَدْرَکَ رَکْعَتَیْنِ فَہِیَ الْجُمُعَۃُ ، وَمَنْ أَدْرَکَ رَکْعَۃً فَقَدْ أَدْرَکَ الْجُمُعَۃَ ، فَلْیُصَلِّ رَکْعَۃً أُخْرَی ، وَمَنْ لَمْ یُدْرِکِ الرُّکُوعَ فَلْیُصَلِّ أَرْبَعًا۔",,,5380,,
5381,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی الضُّحَی ، عَنْ مَسْرُوقٍ ، قَالَ : قَالَ عَبْدُ اللہِ : مَنْ لَمْ یُدْرِکِ الرُّکُوعَ یَوْمَ الْجُمُعَۃِ فَلْیُصَلِّ أَرْبَعًا۔",,,5381,,
5382,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا سَعِیدٌ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسٍ ، وَسَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّہُمَا قَالاَ : مَنْ أَدْرَکَ مِنَ الْجُمُعَۃِ رَکْعَۃً فَلْیُصَلِّ إِلَیْہَا أُخْرَی۔",,,5382,,
5383,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ حُسَیْنِ بْنِ ذَکْوَانَ ، عَنِ الْحَسَنِ ، وَمُحَمَّدٍ ، قَالاَ : إِذَا أَدْرَکَ رَکْعَۃً مِنَ الْجُمُعَۃِ أَضَافَ إِلَیْہَا أُخْرَی۔",,,5383,,
5384,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الأَسْوَدِ ، وَعَلْقَمَۃَ ، قَالاَ : إِذَا أَدْرَکْتَ مِنْ الْجُمُعَۃِ رَکْعَۃً فَأَضِفْ إِلَیْہَا أُخْرَی۔",,,5384,,
5385,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : مَنْ أَدْرَکَ رَکْعَۃً فَلْیُضِفْ إِلَیْہَا رَکْعَۃً أُخْرَی۔",,,5385,,
5386,"حَدَّثَنَا ابْنُ مَہْدِیٍّ، عَنْ حَمَّادٍ، عَنْ ہِشَامٍ، عَنْ أَبِیہِ، قَالَ: إِذَا أَدْرَکَ رَکْعَۃً مِنَ الْجُمُعَۃِ صَلَّی إِلَیْہَا أُخْرَی۔",,,5386,,
5387,"حَدَّثَنَا خَالِدُ بْنُ حَیَّانَ ، عَنْ جَعْفَرٍ ، قَالَ : قُلْتُ لِمَیْمُونٍ : أَدْرَکْتُ رَکْعَۃً مِنَ الْجُمُعَۃِ ؟ فَقَالَ : أَمَّا أَنَا فَکُنْتُ بَانِیًا عَلَی مَا بَقِیَ۔",,,5387,,
5388,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانُوا یَقُولُونَ : مَنْ فَاتَتْہُ رَکْعَۃٌ مِنَ الْجُمُعَۃِ فَلْیُصَلِّ إِلَیْہَا رَکْعَۃً أُخْرَی ، وَمَنْ لَمْ یُدْرِکْ فَلْیُصَلِّ أَرْبَعًا۔",,,5388,,
5389,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، قَالَ : إِذَا أَدْرَکْتَ رَکْعَۃً فَأَضِفْ إِلَیْہَا أُخْرَی۔",,,5389,,
5390,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سُفْیَانَ ، عَنِ الزُّبَیْرِ بْنِ عَدِیٍّ ، عَنْ سَالِمٍ ، قَالَ : إِذَا أَدْرَکَ مِنَ الْجُمُعَۃِ رَکْعَۃً أَضَافَ إِلَیْہَا أُخْرَی۔",,,5390,,
5391,"حَدَّثَنَا إِسْحَاقُ الرَّازِیّ ، عَنْ حَنْظَلَۃَ ، عَنِ الْقَاسِمِ ؛ أَنَّ سَالِمًا قَالَ : لَوْ لَمْ أُدْرِکْ مِنَ الْجُمُعَۃِ إِلاَّ رَکْعَۃً ، لأَضَفْتُ إِلَیْہَا رَکْعَۃً أُخْرَی۔",,,5391,,
5392,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، وَأَنَسٍ ، وَالْحَسَنِ ، قَالُوا : إِذَا أَدْرَکَ مِنَ الْجُمُعَۃِ رَکْعَۃً أَضَافَ إِلَیْہَا أُخْرَی ، فَإِذَا أَدْرَکَہُمْ جُلُوسًا صَلَّی أَرْبَعًا۔",,,5392,,
5393,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، عَنْ عَلْقَمَۃَ ، وَالأَسْوَدِ ، قَالاَ : إِذَا أَدْرَکَہُمْ جُلُوسًا صَلَّی أَرْبَعًا۔",,,5393,,
5394,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ ، قَالَ : إِذَا جَائَ وَالإِمَامُ جَالِسٌ یَوْمَ الْجُمُعَۃِ ؟ قَالَ : یُصَلِّی أَرْبَعًا۔",,,5394,,
5395,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُبَارَکٍ ، عَنِ الْحَسَنِ ، قَالَ : یُصَلِّی أَرْبَعًا۔",,,5395,,
5396,"حَدَّثَنَا عَبْدَۃُ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسِ بْنِ مَالِکٍ ، قَالَ : إِذَا أَدْرَکَہُمْ یَوْمَ الْجُمُعَۃِ جُلُوسًا صَلَّی أَرْبَعًا۔",,,5396,,
5397,حَدَّثَنَا عَبْدَۃُ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدٍ ، وَخِلاَسٍ ، وَالْحَسَنِ (ح) وَعَنْ أَبِی مَعْشَرٍ ، عَنْ إِبْرَاہِیمَ ؛ مِثْلَہُ۔,,,5397,,
5398,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ ، وَحَمَّادًا عَنِ الرَّجُلِ یَجِیئُ یَوْمَ الْجُمُعَۃِ قَبْلَ أَنْ یُسَلِّمَ الإِمَامُ ؟ قَالاَ : یُصَلِّی رَکْعَتَیْنِ۔",,,5398,,
5399,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا جُوَیْبِرٌ ، عَنِ الضَّحَّاکِ ، قَالَ : إِذَا أَدْرَکَ النَّاسَ یَوْمَ الْجُمُعَۃِ جُلُوسًا صَلَّی رَکْعَتَیْنِ۔",,,5399,,
5400,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ أَبِی حَنِیفَۃَ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : یُصَلِّی رَکْعَتَیْنِ۔",,,5400,,
5401,"حَدَّثَنَا شَرِیکٌ ، عَنْ عَامِرِ بْنِ شَقِیقٍ ، عَنْ أَبِی وَائِلٍ ، قَالَ : قَالَ عَبْدُ اللہِ : مَنْ أَدْرَکَ التَّشَہُّدَ فَقَدْ أَدْرَکَ الصَّلاَۃ۔",,,5401,,
5402,"حَدَّثَتَا ابْنُ فُضَیْلٍ ، عَنْ خُصَیْفٍ ، عَنْ أَبِی عُبَیْدَۃَ ، عَنْ عَبْدِ اللہِ ، قَالَ : کَانَ یُصَلِّی قَبْلَ الْجُمُعَۃِ أَرْبَعًا۔",,,5402,,
5403,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنِ ابْنِ عَوْنٍ ، عَنْ نَافِعٍ ، قَالَ : کَانَ ابْنُ عُمَرَ یُہَجِّرُ یَوْمَ الْجُمُعَۃِ ، فَیُطِیلُ الصَّلاَۃ قَبْلَ أَنْ یَخْرُجَ الإِمَامُ۔",,,5403,,
5404,"حَدَّثَنَا شَرِیکٌ ، عَنْ عَمْرِو بْنِ عُثْمَانَ ، قَالَ : قَالَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ : صَلِّ قَبْلَ الْجُمُعَۃِ عَشْرَ رَکَعَاتٍ۔",,,5404,,
5405,"حَدَّثَنَا حَفْصٌ، عَنِ الأَعْمَشِ، عَنْ إِبْرَاہِیمَ، قَالَ: کَانُوا یُصَلُّونَ قَبْلَہَا أَرْبَعًا۔(ترمذی 478۔ احمد 3/411)",,,5405,,
5406,حَدَّثَنَا غُنْدَرٌ ، عَنْ عِمْرَانَ ، عَنْ أَبِی مِجْلَزٍ ؛ أَنَّہُ کَانَ یُصَلِّی فِی بَیْتِہِ رَکْعَتَیْنِ یَوْمَ الْجُمُعَۃِ۔,,,5406,,
5407,حَدَّثَنَا عَبْدُالصَّمَدِ بْنُ عَبْدِالْوَارِثِ ، عَنْ وُہَیْبٍ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ لاَ یَأْتِی الْمَسْجِدَ یَوْمَ الْجُمُعَۃِ حَتَّی یُصَلِّیَ فِی بَیْتِہِ رَکْعَتَیْنِ۔,,,5407,,
5408,حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُصَلِّی بَعْدَ الْجُمُعَۃِ رَکْعَتَیْنِ۔ (بخاری 1165۔ ترمذی 521),,,5408,,
5409,"حَدَّثَنَا ہُشَیْمُ بْنُ بَشِیرٍ ، قَالَ : حدَّثَنَا یُونُسُ بْنُ عُبَیْدٍ ، عَنْ حُمَیْدِ بْنِ ہِلاَلٍ ، عَنْ عِمْرَانَ بْنِ حُصَیْنٍ ؛ أَنَّہُ کَانَ یُصَلِّی بَعْدَ الْجُمُعَۃِ رَکْعَتَیْنِ ، فَقِیلَ لَہُ : یَا أَبَا نُجَیْدٍ ، مَا یَقُولُ النَّاسُ ؟ قَالَ : وَمَا یَقُولُونَ؟ قَالَ: یَقُولُونَ: إِنَّک تُصَلِّی رَکْعَتَیْنِ إِلَی الْجُمُعَۃِ فَتَکُونُ أَرْبَعًا ۔ قَالَ : فَقَالَ عِمْرَانُ : لأَنْ تَخْتَلِفَ النَّیَازِکُ بَیْنَ أضْلاَعِی أَحَبُّ إِلَیَّ مِنْ أَنْ أَفْعَلَ ذَلِکَ ۔ فَلَمَّا کَانَتِ الْجُمُعَۃُ الْمُقْبِلَۃُ صَلَّی الْجُمُعَۃَ ، ثُمَّ احْتَبَی فَلَمْ یُصَلِّ شَیْئًا حَتَّی أُقِیمَتْ صَلاَۃُ الْعَصْرِ۔",,,5409,,
5410,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا عَطَائُ بْنُ السَّائِبِ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ، قَالَ : قَدِمَ عَلَیْنَا ابْنُ مَسْعُودٍ ، فَکَانَ یَأْمُرنَا أَنْ نُصَلِّیَ بَعْدَ الْجُمُعَۃِ أَرْبَعًا ، فَلَمَّا قَدِمَ عَلَیْنَا عَلِیٌّ أَمَرَنَا أَنْ نُصَلِّیَ سِتًّا ،فَأَخَذْنَا بِقَوْلِ عَلِیٍّ ، وَتَرَکْنَا قَوْلَ عَبْدِ اللہِ ، قَالَ : کَانَ یُصَلِّی رَکْعَتَیْنِ ، ثُمَّ أَرْبَعًا۔",,,5410,,
5411,"حَدَّثَنَا شَرِیکٌ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ اللہِ بْنِ حَبِیبٍ ، قَالَ : کَانَ عَبْدُ اللہِ یُصَلِّی أَرْبَعًا ، فَلَمَّا قَدِمَ عَلِیٌّ صَلَّی سِتًّا ، رَکْعَتَیْنِ ، وَأَرْبَعًا۔",,,5411,,
5412,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَطَائٍ ، قَالَ : کَانَ ابْنُ عُمَرَ إِذَا صَلَّی الْجُمُعَۃَ ، صَلَّی بَعْدَہَا سِتَّ رَکَعَاتٍ ، رَکْعَتَیْنِ ، ثُمَّ أَرْبَعًا۔",,,5412,,
5413,حَدَّثَنَا عَلِیُّ بْنِ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ أَبِی بَکْرِ بْنِ أَبِی مُوسَی ، عَنْ أَبِیہِ ؛ کَانَ یُصَلِّی بَعْدَ الْجُمُعَۃِ سِتَّ رَکَعَاتٍ۔,,,5413,,
5414,"حَدَّثَنَا وَکِیعٌ ، عَنْ زَکَرِیَّا ، عَنْ مُحَمَّدِ بْنِ الْمُنْتَشِرِ ، عَنْ مَسْرُوقٍ ، قَالَ : کَانَ یُصَلِّی بَعْدَ الْجُمُعَۃِ سِتًّا ، رَکْعَتَیْنِ ، وَأَرْبَعًا۔",,,5414,,
5415,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : صَلِّ بَعْدَ الْجُمُعَۃِ رَکْعَتَیْنِ ، ثُمَّ صَلِّ بَعْدَہُمَا مَا شِئْتَ۔",,,5415,,
5416,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ سُہَیْلٍ ، عَنْ أَبِیہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: مَنْ کَانَ مِنْکُمْ مُصَلِّیًا بَعْدَ الْجُمُعَۃِ ، فَلْیُصَلِّ أَرْبَعًا۔ (ترمذی 523۔ ابوداؤد 1124)",,,5416,,
5417,"حَدَّثَنَا شَرِیکٌ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِاللہِ بْنِ حَبِیبٍ، قَالَ: کَانَ عَبْدُاللہِ یُصَلِّی بَعْدَ الْجُمُعَۃِ أَرْبَعًا۔",,,5417,,
5418,حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ خُصَیْفٍ ، عَنْ أَبِی عُبَیْدَۃَ ، عَنْ عَبْدِ اللہِ ؛ أَنَّہُ کَانَ یُصَلِّی بَعْدَ الْجُمُعَۃِ أَرْبَعًا۔,,,5418,,
5419,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ، عَنِ الْعَلاَئِ بْنِ الْمُسَیَّبِ، عَنْ أَبِیہِ، قَالَ: کَانَ عَبْدُاللہِ یُصَلِّی بَعْدَ الْجُمُعَۃِ أَرْبَعًا۔",,,5419,,
5420,حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ، عَن عَلْقَمَۃَ؛ أَنَّہُ کَانَ یُصَلِّی أَرْبَعًا بَعْدَ الْجُمُعَۃِ، لاَ یَفْصِلُ بَیْنَہُنَّ۔,,,5420,,
5421,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی حُصَینٍ ، قَالَ : رَأَیْتُ الأَسْوَدَ بْنَ یَزِیدَ صَلَّی بَعْدَ الْجُمُعَۃِ أَرْبَعًا۔",,,5421,,
5422,"حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانُوا یُصَلُّونَ بَعْدَہَا أَرْبَعًا۔",,,5422,,
5423,"حَدَّثَنَا غُنْدَرٌ ، عَنْ عِمْرَانَ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ : إِذَا سَلَّمَ الإِمَامُ صَلَّی رَکْعَتَیْنِ یَوْمَ الْجُمُعَۃِ ، وَإِذَا رَجَعَ صَلَّی رَکْعَتَیْنِ۔",,,5423,,
5424,"حَدَّثَنَا جَرِیرُ بن عَبْدِ الْحَمِیدِ ، عَنْ مُغِیرَۃَ ، عَنْ حَمَّادٍ ، قَالَ : کَانَ یُسْتَحَبُّ فِی الأَرْبَعِ الَّتِی بَعْدَ الْجُمُعَۃِ أَنْ لاَ یُسَلَّمَ بَیْنَہُنَّ۔",,,5424,,
5425,حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ أَبِی بَکْرِ بْنِ عَمْرِو بْنِ عُتْبَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَبْدِ اللہِ ؛ أَنَّہُ کَانَ یُصَلِّی بَعْدَ الْجُمُعَۃِ أَرْبَعًا۔,,,5425,,
5426,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ کُلْثُومِ بْنِ جَبْرٍ ، قَالَ : قَالَ لِی مُسْلِمُ بْنُ یَسَارٍ : إِِذَا عَلِمْتَ أَنَّ النَّہَارَ قَدِ انْتَصَفَ یَوْمَ الْجُمُعَۃِ فَلاَ تَبْتَاعَنَّ شَیْئًا۔",,,5426,,
5427,حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنِ ابْنِ أَبِی ذِئْبٍ ؛ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ کَانَ یَمْنَعُ النَّاسَ الْبَیْعَ یَوْمَ الْجُمُعَۃِ إِذَا نُودِیَ بِالصَّلاَۃ۔,,,5427,,
5428,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا جُوَیْبِرٌ ، عَنِ الضَّحَّاکِ ، قَالَ : إِذَا زَالَتِ الشَّمْسُ مِنْ یَوْمِ الْجُمُعَۃِ ، فَقَدْ حَرُمَ الْبَیْعُ وَالشِّرَائُ ، حَتَّی تُقْضَی الصَّلاَۃ۔",,,5428,,
5429,حَدَّثَنَا ہُشَیْمٌ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ (ح) وَعَنْ بَعْضِ أَصْحَابِہِ ، عَنِ الْحَسَنِ ؛ أَنَّہُمَا قَالاَ ذَلِکَ۔,,,5429,,
5430,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا أَبُو الْمِقْدَامِ مَوْلَی لِقُرَیْشٍ ، عَنِ الْقَاسِمِ بْنِ مُحَمَّدٍ ؛ أَنَّہُ اشْتَرَی مِنْ رَجُلٍ شَیْئًا یَوْمَ الْجُمُعَۃِ ، فَلَقِیَہُ بَعْدَ ذَلِکَ ، فَقَالَ : تَارِکْنِی الْبَیْعَ ، فَإِنِّی أَحْسَبُنِی اشْتَرَیْتُ مِنْکَ مَا اشْتَرَیْتُ بَعْدَ زَوَالِ الشَّمْسِ۔",,,5430,,
5431,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ، عَنْ عَبْدِ الْکَرِیمِ، عَنْ مُجَاہِدٍ، أَوْ غَیْرِہِ، قَالَ: مَنْ بَاعَ شَیْئًا بَعْدَ زَوَالِ الشَّمْسِ یَوْمَ الْجُمُعَۃِ ، فَإِنَّ بَیْعَہُ مَرْدُودٌ ، لأَنَّ اللَّہَ نَہَی عَنِ الْبَیْعِ إِذَا نُودِیَ لِلصَّلاَۃِ مِنْ یَوْمِ الْجُمُعَۃِ ۔ شَکَّ سُفْیَانُ۔",,,5431,,
5432,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ بُرْدٍ ، قَالَ : قُلْتُ لِلزُّہْرِیِّ : مَتَی یَحْرُمُ الْبَیْعُ وَالشِّرَائُ یَوْمَ الْجُمُعَۃِ ؟ فَقَالَ : کَانَ الأَذَانُ عِنْدَ خُرُوجِ الإِمَامِ ، فَأَحْدَثَ أَمِیرُ الْمُؤْمِنِینَ عُثْمَانُ التَّأْذِینَۃَ الثَّالِثَۃَ ، فَأَذَّنَ عَلَی الزَّوْرَائِ لِیَجْتَمِعَ النَّاسُ ، فَأَرَی أَنْ یُتْرَکَ الْبَیْعُ وَالشِّرَائُ عِنْدَ التَّأْذِینَۃِ۔",,,5432,,
5433,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنْ مَیْمُونٍ ، قَالَ : کَانَ بِالْمَدِینَۃِ إِذَا أَذَّنَ الْمُؤَذِّنُ یَوْمَ الْجُمُعَۃِ یُنَادُونَ فِی الأَسْوَاقِ : حَرُمَ الْبَیْعُ ، حَرُمَ الْبَیْعُ۔",,,5433,,
5434,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُحَمَّدِ بْنِ قَیْسٍ ، عَنِ الشَّعْبِیِّ ؛ فِی السَّاعَۃِ الَّتِی تُرْجَی فِی الْجُمُعَۃِ ، قَالَ : فِیمَا بَیْنَ أَنْ یَحْرُمَ الْبَیْعُ إِلَی أَنْ یَحِلَّ۔",,,5434,,
5435,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا ہِشَامٌ ، عَنِ ابْنِ سِیرِینَ ، عَنْ زَیْدِ بْنِ ثَابِتٍ ؛ أَنَّہُ رَاحَ إِلَی الْجُمُعَۃِ ، فَإِذَا النَّاسُ قَدِ اسْتَقْبَلُوہُ وَقَدْ صَلَّوْا ، قَالَ : فَمَالَ إِلَی مَسْجِدٍ ، أَوْ إِلَی دَارٍ فَصَلَّی ، قَالَ : فَقِیلَ لَہُ فِی ذَلِکَ ؟ فَقَالَ : إِنَّہُ مَنْ لاَ یَسْتَحْیِی مِنَ النَّاسِ ، لاَ یَسْتَحْیِی مِنَ اللہِ۔",,,5435,,
5436,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ ابْنِ عَوْنٍ ، وَحَجَّاجِ بْنِ أَبِی عُثْمَانَ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّہُ کَانَ یَقُولُ : إِذَا اسْتَقْبَلَکَ النَّاسُ یَوْمَ الْجُمُعَۃِ وَقَدْ صَلَّوْا ، فَامْضِ إِلَی الْمَسْجِدِ ، فَإِنْ عَلِمْتَ مَا قَرَأَ بِہِ الإِمَامُ ، فَاقْرَأْ بِہِ وَصَلِّ۔",,,5436,,
5437,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّ زَیْدَ بْنِ ثَابِتٍ لَقِیَ النَّاسَ رَاجِعِینَ مِنَ الْجُمُعَۃِ ، فَمَالَ إِلَی دَارٍ ، فَقِیلَ لَہُ ؟ فَقَالَ : مَنْ لاَ یَسْتَحْیِی مِنَ النَّاسِ ، لاَ یَسْتَحْیِی مِنَ اللہِ ۔ قَالَ : وَقَالَ الْحَسَنُ ، وَابْنُ سِیرِینَ : یَمْضِی۔",,,5437,,
5438,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُوسَی بْنِ مُسْلِمٍ ، قَالَ : شَہِدْتُ إِبْرَاہِیمَ التَّیْمِیَّ ، وَإِبْرَاہِیمَ النَّخَعِیّ ، وَزِرًّا ، وَسَلَمَۃَ بْنَ کُہَیْلٍ ، فَذَکَّرَ زِرٌّ ، وَالتَّیْمِیُّ فِی یَوْمِ جُمُعَۃٍ ، ثُمَّ صَلَّوُا الْجُمُعَۃَ أَرْبَعًا فِی مَکَانِہِمْ ، وَکَانُوا خَائِفِینَ۔",,,5438,,
5439,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَفْلَحَ ، قَالَ : أَذَّنَ مُؤَذِّنٌ وَنَحْنُ بِالرَّوْحَائِ فِی یَوْمِ جُمُعَۃٍ ، فَجِئْنَا وَقَدْ صَلَّوْا ، فَصَلَّی الْقَاسِمُ وَلَمْ یُجَمِّعْ۔",,,5439,,
5440,"حَدَّثَنَا غُنْدَرٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ فِی قَوْمٍ فَاتَتْہُمُ الْجُمُعَۃُ ، قَالَ : یُصَلُّونَ شَتَّی۔",,,5440,,
5441,"حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ، عَنِ الْقَاسِمِ بْنِ الْوَلِیدِ، قَالَ: قَالَ عَلِیٌّ: لاَ جَمَاعَۃَ یَوْمَ جُمُعَۃٍ إِلاَّ مَعَ الإِمَامِ۔",,,5441,,
5442,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، قَالَ : حدَّثَنَا جَمِیلُ بْنُ عُبَیْدٍ الطَّائِیُّ ، قَالَ : رَأَیْتُ إِیَاسَ بْنَ مُعَاوِیَۃَ ، وَہُوَ یَوْمئِذٍ قَاضِی الْبَصْرَۃِ ، جَائَ إِلَی الْجُمُعَۃِ وَفَاتَتْہُ ، فَتَقَدَّمَ فَصَلَّی بِنَا الظُّہْرَ أَرْبَعَ رَکَعَاتٍ۔",,,5442,,
5443,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، قَالَ : أَتَیْتُ الْمَسْجِدَ أَنَا وَزِرٌّ یَوْمَ الْجُمُعَۃِ ، فَوَجَدْنَاہُمْ قَدْ صَلَّوْا ، فَصَلَّیْنَا جَمِیعًا۔",,,5443,,
5444,"حَدَّثَنَا شَرِیکٌ ، عَنْ مُخْتَارٍ أَبِی غَسَّانَ، عَنْ أَبِی ظَبْیَانَ الْجَنْبِیِّ، قَالَ: قَالَ عَلِیٌّ: تُؤْتَی الْجُمُعَۃُ وَلَوْ حَبْوًا۔",,,5444,,
5445,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنِ الْحَسَنِ بْنِ الْحُرِّ ، عَنْ مَیْمُونِ بْنِ أَبِی شَبِیبٍ ، قَالَ : أَرَدْتُ الْجُمُعَۃَ فِی زَمَنِ الْحَجَّاجِ ، فَتَہَیَّأْتُ لِلذَّہَابِ ، ثُمَّ قُلْتُ : أَیْنَ أَذْہَبُ ، أُصَلِّی خَلْفَ ہَذَا ؟ قَالَ : فَقُلْتُ مَرَّۃً : أَذْہَبُ ، وَمَرَّۃً: لاَ أَذْہَبُ ، قَالَ : فَاجْتَمَعَ رَأْیِی عَلَی الذَّہَابِ ، قَالَ : فَنَادَانِی مُنَادٍ مِنْ جَانِبِ الْبَیْتِ : { یَا أَیُّہَا الَّذِینَ آمَنُوا إِِذَا نُودِیَ لِلصَّلاَۃِ مِنْ یَوْمِ الْجُمُعَۃِ ، فَاسْعَوْا إِلَی ذِکْرِ اللہِ وَذَرُوا الْبَیْعَ } ۔\n\nقَالَ : وَجَلَسْتُ مَرَّۃً أَکْتُبُ کِتَابًا ، فَعَرَضَ لِی شَیْئٌ ، إِنْ أَنَا کَتَبْتُہُ فِی کِتَابِی زَیَّنَ کِتَابِی ، وَکُنْتُ قَدْ کَذَبْتُ ، وَإِنْ أَنَا تَرَکْتُہُ کَانَ فِی کِتَابِی بَعْضُ الْقُبْحِ ، وَکُنْتُ قَدْ صَدَقْتُ ، فَقُلْتُ مَرَّۃً : أَکْتُبُہُ ، وَقُلْتُ مَرَّۃً : لاَ أَکْتُبُہُ ، قَالَ : فَاجْتَمَعَ رَأْیِی عَلَی تَرْکِہِ ، فَتَرَکْتُہُ ، قَالَ : فَنَادَانِی مُنَادٍ مِنْ جَانِبِ الْبَیْتِ : { یُثَبِّتُ اللَّہُ الَّذِینَ آمَنُوا بِالْقَوْلِ الثَّابِتِ فِی الْحَیَاۃِ الدُّنْیَا وَفِی الآخِرَۃِ } ۔",,,5445,,
5446,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ أَبِی سِنَانٍ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی الْہُذَیْلِ ، قَالَ : تَذَاکَرُوا الْجُمُعَۃَ زَمَانَ الْمُخْتَارِ ، فَقَالَ : ائْتُوہَا وَإِنْ بَلَغَ الْمَائُ الْحَصَی۔",,,5446,,
5447,"حَدَّثَنَا ہُشَیْمٌ، عَنْ عَبْدِالْحَمِیدِ بْنِ جَعْفَرٍ، عَنْ أَبِیہِ، قَالَ: کَانَ عَبْدُ اللہِ بْنُ رَوَاحَۃَ یَأْتِی الْجُمُعَۃَ مَاشِیًا، فَإِذَا رَجَعَ رَجَعَ کَیْفَ شَائَ ، إِنْ شَائَ مَاشِیًا ، وَإِنْ شَائَ رَاکِبًا۔",,,5447,,
5448,"حَدَّثَنَا أَبُو عَبْدِ الرَّحْمَنِ الْمُقْرِیئُ ، عَنْ سَعِیدِ بْنِ أَبِی أَیُّوبَ ، قَالَ : حدَّثَنِی الْوَلِیدُ بْنُ أَبِی الْوَلِیدِ ، قَالَ: رَأَیْتُ أَبَا ہُرَیْرَۃَ یَأْتِی الْجُمُعَۃَ مِنْ ذِی الْحُلَیْفَۃِ مَاشِیًا۔",,,5448,,
5449,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ إِبْرَاہِیمَ بْنِ مُہَاجِرٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانُوا یَکْرَہُونَ الرُّکُوبَ إِلَی الْجُمُعَۃِ وَالْعِیدَیْنِ۔",,,5449,,
5450,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنَ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ التَّحَلُّق لِلْحَدِیثِ یَوْمَ الْجُمُعَۃِ قَبْلَ الصَّلاَۃ۔",,,5450,,
5451,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ أُسَامَۃَ بْنِ زَیْدٍ ، عَنْ یُوسُفَ بْنِ السَّائِبِ ، عَنِ السَّائِبِ ، قَالَ : کُنَّا نَتَحَلَّقُ یَوْمَ الْجُمُعَۃِ قَبْلَ الصَّلاَۃِ۔",,,5451,,
5452,"حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنْ مُعَاوِیَۃَ بْنِ صَالِحٍ ، عَنْ أَبِی الزَّاہِرِیَّۃِ ، قَالَ : کُنْتُ مَعَ عَبْدِ اللہِ بْنِ بُسْرٍ یَوْمَ الْجُمُعَۃِ ، فَمَا زَالَ یُحَدِّثُنِی حَتَّی خَرَجَ الإِمَامُ۔",,,5452,,
5453,"حَدَّثَنَا جَدِّی أَبُو عَامِرٍ الْعَقَدِیُّ ، عَنْ مُحَمَّدِ بْنِ ہِلاَلٍ ، عَنْ أَبِیہِ ، قَالَ : کَانَ أَبُو ہُرَیْرَۃَ یُحَدِّثُنَا یَوْمَ الْجُمُعَۃِ حَتَّی یَخْرُجَ الإِمَامُ۔",,,5453,,
5454,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، قَالَ : أَخْبَرَنَا الضَّحَّاکُ بْنُ عُثْمَانَ ، قَالَ : أَخْبَرَنِی نَافِعٌ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَتَرَبَّعُ وَیَسْتَوِی فِی مَجْلِسِہِ یَوْمَ الْجُمُعَۃِ قَبْلَ أَنْ یَخْرُجَ الإِمَامُ۔",,,5454,,
5455,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ : الْقُنُوتُ یَوْمَ الْجُمُعَۃِ بِدْعَۃٌ۔",,,5455,,
5456,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ؛ أَنَّہُ کَانَ یَکْرَہُ الْقُنُوتَ یَوْمَ الْجُمُعَۃِ۔,,,5456,,
5457,"حَدَّثَنَا شَرِیکٌ ، عَنْ عبد اللہِ بْنِ یَزِیدَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : الْقُنُوتُ فِی الْجُمُعَۃِ بِدْعَۃٌ۔",,,5457,,
5458,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ شَرِیکٍ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : صَلَّیْتُ خَلْفَ الْمُغِیرَۃِ بْنِ شُعْبَۃَ ، وَالنُّعْمَانِ بْنِ بَشِیرٍ الْجُمُعَۃَ فَلَمْ یَقْنُتَا ، وَخَلْفَ عَلِیٍّ ۔ فَقُلْتُ : أَقَنَتَ بِکُمْ ؟ قَالَ : لاَ۔",,,5458,,
5459,"حَدَّثَنَا یَحْیَی بْنُ أَبِی بُکَیْرٍ ، قَالَ : حَدَّثَنِی أَبِی ، قَالَ : أَدْرَکْتُ النَّاسَ قَبْلَ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ یَقْنُتُونَ فِی الْجُمُعَۃِ ، فَلَمَّا کَانَ زَمَنُ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ تُرِکَ الْقُنُوتُ فِی الْجُمُعَۃِ۔",,,5459,,
5460,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ أَشْعَثَ بْنِ أَبِی الشَّعْثَائِ ، عَنْ نَافِعٍ ، قَالَ : لَمْ یَکُنْ عَبْدُ اللہِ بْنُ عُمَرَ یَقْنُتُ فِی الْفَجْرِ وَالْجُمُعَۃِ۔",,,5460,,
5461,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یُسْتَحَبُّ لِلإِمَامِ إذَا صَلَّی أَنْ یَدْخُلَ۔,,,5461,,
5462,حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی الْعُمَیْسِ ، عَنْ مُحَمَّدِ بْنِ عَمْرو بْنِ حَلْحَلَۃَ ، عَنْ مُحَمَّدِ بْنِ عَمْرو بْنِ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ کَانَ إِذَا صَلَّی الْجُمُعَۃَ فَسَلَّمَ ، دَخَلَ۔,,,5462,,
5463,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّی الرَّکْعَتَیْنِ بَعْدَ الْجُمُعَۃِ فِی بَیْتِہِ۔",,,5463,,
5464,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنْ أَبِی قِلاَبَۃَ ، قَالَ : صَلَّیْتُ مَعَہُ الْجُمُعَۃَ ، فَلَمَّا قَضَیْتُ صَلاَتِی أَخَذَ بِیَدِی ، فَقَامَ فِی مَقَامِی ، وَأَقَامَنِی فِی مُقَامِہِ۔",,,5464,,
5465,"حَدَّثَنَا غُنْدَرٌ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ یَحْیَی بْنِ أَبِی کَیرٍرے ، قَالَ : رَأَیْتُ عُقْبَۃَ بْنَ عبْدِ الْغَافِرِ ، وَحَسَّانَ بْنَ بِلاَلٍ یَوْمَ الْجُمُعَۃِ إِذَا قَضَی الإِمَامُ صَلاَتَہُ تَحَوَّلاَ مِنْ مَقَامِہِمَا۔",,,5465,,
5466,"حَدَّثَنَا غُنْدَرٌ ، عَنْ عِمْرَانَ بْنِ حُدَیْرٍ ، قَالَ : حدَّثَنِی دِعَامَۃُ بْنُ یَزِیدَ الْعَنْبَرِیُّ ؛ أَنَّہُ صَلَّی إِلَی جَنْبِ أَبِی مِجْلَزٍ فِی الْجُمُعَۃِ ، فَلَمَّا قُضِیَتِ الصَّلاَۃُ أَخَذَ بِیَدِی ، فَأَقَامَنِی فِی مُقَامِہِ الَّذِی کَانَ فِیہِ ، وَقَامَ فِی مَقَامِی۔",,,5466,,
5467,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ ہَمَّامٍ ، عَنْ قَتَادَۃَ ، عَنْ حَبِیبٍ ، قَالَ : صَلَّیْتُ إِلَی جَنْبِ صَفْوَانَ بْنِ مُحْرِزٍ الْجُمُعَۃَ ، فَحَوَّلَنِی إِلَی مَکَانِہِ ، وَتَحَوَّلَ فِی مَکَانِی۔",,,5467,,
5468,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حدَّثَنَا عَبْدُ الْمَلِکِ بْنُ أَبِی سُلَیْمَانَ ، قَالَ : حَدَّثَنَا عَطَائٌ ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ صَلَّی الْجُمُعَۃَ ، ثُمَّ تَنَحَّی عَنْ مَکَانِہِ ، فَصَلَّی رَکْعَتَیْنِ فِیہِمَا خِفَّۃٌ ، ثُمَّ تَنَحَّی عَنْ مَقَامِہِ ذَلِکَ فَصَلَّی أَرْبَعًا ، ہِیَ أَطْوَلُ مِنْ تَیْنِکَ۔",,,5468,,
5469,"حَدَّثَنَا غُنْدَرٌ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی عُمَرُ بْنُ عَطَائِ بْنِ أَبِی الْخُوَارِ ؛ أَنَّ نَافِعَ بْنَ جُبَیْرٍ أَرْسَلَہُ إِلَی السَّائِبِ ابْنِ أُخْتِ نَمِرٍ ، یَسْأَلُہُ عَنْ شَیْئٍ رَآہُ مِنْہُ مُعَاوِیَۃُ فِی الصَّلاَۃِ ، فَقَالَ : نَعَمْ ، صَلَّیْتُ مَعَہُ الْجُمُعَۃَ فِی الْمَقْصُورَۃِ ، فَلَمَّا سَلَّمَ الإِمَامُ قُمْتُ فِی مَقَامِی فَصَلَّیْتُ ، فَلَمَّا دَخَلَ أَرْسَلَ إِلَیَّ ، وَقَالَ : لاَ تَعُدْ لِمَا فَعَلْتَ ، إِذَا صَلَّیْتَ الْجُمُعَۃَ فَلاَ تَصِلْہَا بِصَلاَۃٍ حَتَّی تَکَلَّمَ ، أَوْ تَخْرُجَ ، فَإِنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَمَرَنَا بِذَلِکَ : أَنْ لاَ نُوصِلَ صَلاَۃً حَتَّی نَتَکَلَّمَ ، أَوْ نَخْرُجَ۔ (مسلم 73۔ ابوداؤد 122)",,,5469,,
5470,"حَدَّثَنَا وَکِیعُ بْنُ الْجَرَّاحِ ، عَنْ ثَوْرٍ ، عَنْ سُلَیْمَانَ بْنِ مُوسَی ، عَنْ عَمْرِو بْنِ الْعَاصِ ، قَالَ : کَانَ یَکْرَہُ الصَّلاَۃَ نِصْفَ النَّہَارِ ، إِلاَّ یَوْمَ جُمُعَۃٍ۔",,,5470,,
5471,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ : یَوْمُ الْجُمُعَۃِ صَلاَۃٌ کُلُّہُ۔",,,5471,,
5472,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، قَالَ : تُکْرَہُ الصَّلاَۃ نِصْفَ النَّہَارِ إِلاَّ یَوْمَ الْجُمُعَۃِ۔",,,5472,,
5473,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ مُعَاوِیَۃَ بْنَ قُرَّۃَ عَنِ الصَّلاَۃِ قَبْلَ أَنْ تَزُولَ الشَّمْسُ یَوْمَ الْجُمُعَۃِ ؟ فَلَمْ یَرَ بِہَا بَأْسًا۔",,,5473,,
5474,"حَدَّثَنَا مُحَمَّدُ بْنُ مُیَسَّر ، عَنْ مُبَارَکٍ ، عَنِ الْحَسَنِ ، قَالَ : تُکْرَہُ الصَّلاَۃُ نِصْفَ النَّہَارِ ، إِلاَّ یَوْمَ جُمُعَۃٍ۔",,,5474,,
5475,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ ، قَالَ : یَوْمُ الْجُمُعَۃِ صَلاَۃٌ کُلُّہُ۔",,,5475,,
5476,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : لاَ بَأْسَ بِالصَّلاَۃ یَوْمَ الْجُمُعَۃِ نِصْفَ النَّہَارِ۔",,,5476,,
5477,"حَدَّثَنَا ہُشَیْمُ بْنُ بَشِیرٍ ، عَنْ مَنْصُورٍ ، عَنِ الْحَسَنِ ، أَنَّہُ قَالَ : النِّدَائُ الأَوَّلُ یَوْمَ الْجُمُعَۃِ ؛ الَّذِی یَکُونُ عِنْدَ خُرُوجِ الإِمَامِ ، وَالَّذِی قَبْلَ ذَلِکَ مُحْدَثٌ۔",,,5477,,
5478,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا شَیْخٌ مِنْ قُرَیْشٍ ، عَنْ نَافِعٍ ، قَالَ : سَمِعْتُہُ یُحَدِّثُ عَنِ ابْنِ عُمَرَ ، أَنَّہُ قَالَ : الأَذَانُ یَوْمَ الْجُمُعَۃِ ؛ الَّذِی یَکُونُ عِنْدَ خُرُوجِ الإِمَامِ ، وَالَّذِی قَبْلَ ذَلِکَ مُحْدَثٌ۔",,,5478,,
5479,"حَدَّثَنَا شَبَابَۃُ، قَالَ: حدَّثَنَا ہِشَامُ بْنُ الْغَازِ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ: الأَذَانُ الأَوَّلُ یَوْمَ الْجُمُعَۃِ بِدْعَۃٌ۔",,,5479,,
5480,"حَدَّثَنَا ہُشَیْمٌ، عَنْ أَشْعَثَ، عَنِ الزُّہْرِیِّ، قَالَ: أَوَّلُ مَنْ أَحْدَثَ الأَذَانَ الأَوَّلَ عُثْمَانُ، لِیُؤْذِنَ أَہْلَ الأَسْوَاقِ۔",,,5480,,
5481,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ إِسْمَاعِیلَ ، عَنِ الْحَسَنِ ، أَنَّہُ حَدَّثَہُمْ : أَنَّ الأَذَانَ کَانَ عَلَی عَہْدِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إِذَا خَرَجَ ، فَإِذَا فَرَغَ مِنَ الْخُطْبَۃِ أُقِیمَتِ الصَّلاَۃ۔ (بخاری 912)",,,5481,,
5482,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ بُرْدٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : کَانَ الأَذَانُ عِنْدَ خُرُوجِ الإِمَامِ ، فَأَحْدَثَ أَمِیرُ الْمُؤْمِنِینَ عُثْمَانُ التَّأْذِینَۃَ الثَّالِثَۃَ عَلَی الزَّوْرَائِ ، لِیَجْتَمِعَ النَّاسُ۔",,,5482,,
5483,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ہِشَامُ بْنُ الْغَازِ ، قَالَ : سَأَلْتُ نَافِعًا مَوْلَی ابْنِ عُمَرَ عَنِ الأَذَانِ الأَوَّلِ یَوْمَ الْجُمُعَۃِ ؟ فَقَالَ : قَالَ ابْنُ عُمَرَ : بِدْعَۃٌ۔",,,5483,,
5484,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی فَرْوَۃَ ، عَنْ أَبِی الأَحْوَص ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقْرَأُ فِی صَلاَۃِ الْغَدَاۃِ ، یَوْمَ الْجُمُعَۃِ : (الم تَنْزِیلُ) السَّجْدَۃِ ، وَسُورَۃً مِنَ الْمُفَصَّلِ۔",,,5484,,
5485,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانَ یُسْتَحَبُّ أَنْ یُقْرَأَ یَوْمَ الْجُمُعَۃِ بِسُورَۃٍ فِیہَا سَجْدَۃٌ۔",,,5485,,
5486,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : مَا شَہِدْتُ ابْنَ عَبَّاسٍ قَرَأَ یَوْمَ الْجُمُعَۃِ إِلاَّ بـ : (الم تَنْزِیلُ) ، وَ(ہَلْ أَتَی عَلَی الإِنْسَانِ) ۔",,,5486,,
5487,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ شَرِیکٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : مَا صَلَّیْتُ خَلْفَ ابْنِ عَبَّاسٍ یَوْمَ الْجُمُعَۃِ الْغَدَاۃَ ، إِلاَّ قَرَأَ سُورَۃً فِیہَا سَجْدَۃٌ۔",,,5487,,
5488,حَدَّثَنَا وَکِیعٌ ، عَنِ الْحَسَنِ بْنِ صَالِحٍ ، عَنْ أَبِیہِ ، عَنْ عُثْمَانَ بْنِ أَبِی صَفِیَّۃَ ، عَنْ عَلِیٍّ ؛ أَنَّہُ قَرَأَ فِی الْفَجْرِ یَوْمَ الْجُمُعَۃِ بِسُورَۃِ الْحَشْرِ ، وَسُورَۃِ الْجُمُعَۃِ۔,,,5488,,
5489,"حَدَّثَنَا مُحَمَّدُ بْنِ أَبِی عَدِیٍّ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَانُوا یَقْرَؤُونَ یَوْمَ الْجُمُعَۃِ بِسُورَۃٍ فِیہَا سَجْدَۃٌ ، فَسَأَلْتُ مُحَمَّدًا ، فَقَالَ : لاَ أَعْلَمُ بِہِ بَأْسًا۔",,,5489,,
5490,"حَدَّثَنَا عَبْدَۃُ ، عَنْ سُفْیَانَ ، عَنْ مُخوَّلٍ ، عَنْ مُسْلِمٍ الْبَطِینِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَقْرَأُ فِی صَلاَۃِ الْفَجْرِ یَوْمَ الْجُمُعَۃِ بِـ : (الم تَنْزِیلُ) ، وَ{ہَلْ أَتَی عَلَی الإِنْسَان حِینٌ مِنَ الدَّہْرِ}۔ (ترمذی 520۔ ابوداؤد 1067)",,,5490,,
5491,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، قَالَ : حدَّثَنَا زُہَیْرٌ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : أَمَّنَا إِبْرَاہِیمُ بْنُ عَبْدِ الرَّحْمَنِ بْنِ عَوْفٍ وَنَحْنُ بِالْمَدِینَۃِ ، فَصَلَّیْتُ وَرَائَہُ یَوْمَ الْجُمُعَۃِ صَلاَۃَ الْغَدَاۃِ ، فَقَرَأَ : (الم تَنْزِیلُ) وَ{ہَلْ أَتَی عَلَی الإِنْسَان}۔",,,5491,,
5492,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سَعْدِ بْنِ إِبْرَاہِیمَ ، عَن عَبْدِ الرَّحْمَنِ بْنِ ہُرْمُزَ ، عَنْ أَبِی ہُرَیْرَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَقْرَأُ فِی الْفَجْرِ یَوْمَ الْجُمُعَۃِ بِـ : (الم تَنْزِیلُ) ، وَ{ہَلْ أَتَی عَلَی الإِنْسَان}۔ (بخاری 1068۔ مسلم 66)",,,5492,,
5493,"حَدَّثَنَا ابْنُ فُضَیْلِ ، عَنْ مُغِیرَۃَ ، عَنْ أَبِی حَمْزَۃَ الأَعْوَرِ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّہُ صَلَّی بِہِمْ یَوْمَ الْجُمُعَۃِ الْفَجْر، فَقَرَأَ بِہِمْ بِـ : (کہیعص)۔",,,5493,,
5494,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ إِبْرَاہِیمَ بْنِ مُحَمَّدِ بن الْمُنْتَشِرِ ، عَنْ أَبِیہِ ، عَنْ حَبِیبِ بْنِ سَالِمٍ ، عَنِ النُّعْمَانِ بْنِ بَشِیرٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَقْرَأُ فِی الْعِیدَیْنِ وَالْجُمُعَۃِ بِـ : {سَبِّحِ اسْمَ رَبِّکَ الأَعْلَی} ، وَ{ہَلْ أَتَاکَ حَدِیثُ الْغَاشِیَۃِ} وَإِذَا اجْتَمَعَ الْعِیدَانِ فِی یَوْمٍ ، قَرَأَ بِہِمَا فِیہِمَا۔ (مسلم 62۔ ابوداؤد 1115)",,,5494,,
5495,"حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ عُبَیْدِ اللہِ بْنِ أَبِی رَافِعٍ ، قَالَ : اسْتَخْلَفَ مَرْوَانُ أَبَا ہُرَیْرَۃَ عَلَی الْمَدِینَۃِ ، وَخَرَجَ إِلَی مَکَّۃَ ، فَصَلَّی بِنَا أَبُو ہُرَیْرَۃَ الْجُمُعَۃَ ، فَقَرَأَ بِسُورَۃِ الْجُمُعَۃِ فِی السَّجْدَۃِ الأُولَی ، وَفِی الآخِرَۃِ : {إِذَا جَائَکَ الْمُنَافِقُونَ} ۔\n\nفَقَالَ عُبَیْدُ اللہِ : فَأَدْرَکْتُ أَبَا ہُرَیْرَۃَ حِینَ انْصَرَفَ ، فَقُلْتُ لَہُ : إِنَّک قَرَأْتَ بِسُورَتَیْنِ کَانَ عَلِیٌّ یَقْرَأُ بِہِمَا بِالْکُوفَۃِ ، فَقَالَ أَبُو ہُرَیْرَۃَ : إِنِّی سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقْرَأُ بِہِمَا۔ (مسلم 61۔ ابوداؤد 1117)",,,5495,,
5496,حَدَّثَنَا عَبْدَۃُ ، عَنْ سُفْیَانَ ، عَنْ مُخَوَّلٍ ، عَنْ مُسْلِمٍ الْبَطِینِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَقْرَأُ فِی الْجُمُعَۃِ بِسُورَۃِ الْجُمُعَۃِ ، وَ{إِذَا جَائَکَ الْمُنَافِقُونَ}۔ (ابوداؤد 1068۔ نسائی 1736),,,5496,,
5497,"حَدَّثَنَا یَعْلَی ، عَنْ مِسْعَرٍ ، عَنْ مَعْبَدِ بْنِ خَالِدٍ ، عَنْ زَیْدِ بْنِ عُقْبَۃَ ، عَنْ سَمُرَۃََ ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقْرَأُ فِی الْجُمُعَۃِ بِـ : {سَبِّحِ اسْمَ رَبِّکَ الأَعْلَی} ، وَ{ہَلْ أَتَاکَ حَدِیثُ الْغَاشِیَۃِ}۔ (ابوداؤد 118۔ نسائی 1739)",,,5497,,
5498,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَنِ الْحَکَمِ ، عَنْ أُنَاسٍ مِنْ أَہْلِ الْمَدِینَۃِ ، أُرَی فِیہِمْ أَبَا جَعْفَرٍ ، قَالَ : کَانَ یُقْرَأُ فِی الْجُمُعَۃِ بِسُورَۃِ الْجُمُعَۃِ وَالْمُنَافِقِینَ ، فَأَمَّا سُورَۃُ الْجُمُعَۃِ فَیُبَشِّرُ بِہَا الْمُؤْمِنِینَ وَیُحَرِّضُہُمْ ، وَأَمَّا سُورَۃُ الْمُنَافِقِینَ فَیُؤَیِّسُ بِہَا الْمُنَافِقِینَ وَیُوَبِّخُہُمْ بِہَا۔",,,5498,,
5499,"حَدَّثَنَا عَبْدَۃُ ، وَوَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ عُمَیْرِ بْنِ سَعِیدٍ ، قَالَ : صَلَّیْتُ خَلْفَ أَبِی مُوسَی الْجُمُعَۃَ فَقَرَأَ بِـ : {سَبِّحِ اسْمَ رَبِّکَ الأَعْلَی} ، وَ{ہَلْ أَتَاک حَدِیثُ الْغَاشِیَۃِ} ۔",,,5499,,
5500,"حَدَّثَنَا إِسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنَ ، قَالَ : صَلَّیْتُ خَلْفَ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، وَأَبِی بَکْرِ بْنِ عَمْرٍو الْجُمُعَۃَ ، فَقَرَآ فِی الرَّکْعَۃِ الأُولَی بِسُورَۃِ الْجُمُعَۃِ ، وَفِی الرَّکْعَۃِ الثَّانِیَۃِ بِـ : {سَبِّحِ اسْمَ رَبِّکَ الأَعْلَی}۔",,,5500,,
5501,"حَدَّثَنَا غُنْدَرٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ فِی الْقِرَائَۃِ یَوْمَ الْجُمُعَۃِ ، قَالَ : یَقْرَأُ الإِمَامُ بِمَا شَائَ۔",,,5501,,
5502,"حَدَّثَنَا ہُشَیْمُ بْنُ بَشِیرٍ ، وَعَبْدُ اللہِ بْنُ إِدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنِ الشَّعْبِیِّ ، عَنْ عَوْفِ بْنِ حَصِیرَۃ ؛ فِی السَّاعَۃِ الَّتِی تُرْجَی فِی الْجُمُعَۃِ : مَا بَیْنَ خُرُوجِ الإِمَامِ إِلَی أَنْ تُقْضَی الصَّلاَۃُ۔",,,5502,,
5503,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حَجَّاجٌ ، عَنْ عَطَائٍ ، عَنْ عَبْدِ اللہِ بْنِ سَلاَمٍ ، قَالَ : مَا بَیْنَ الْعَصْرِ إِلَی أَنْ تَغْرُبَ الشَّمْسُ۔",,,5503,,
5504,"حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْن أَبِی لَیْلَی ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، وَأَبِی ہُرَیْرَۃَ ، قَالاَ : السَّاعَۃُ الَّتِی تُذْکَرُ فِی الْجُمُعَۃِ : مَا بَیْنَ الْعَصْرِ إِلَی أَنْ تَغْرُبَ الشَّمْسُ۔",,,5504,,
5505,حَدَّثَنَا ہُشَیْمٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطَائٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، مِثْلَہُ۔,,,5505,,
5506,"حَدَّثَنَا ہُشَیْمٌ، عَنْ مُغِیرَۃَ، عَنْ وَاصِلٍ ، عَنْ أَبِی بُرْدَۃَ، قَالَ: کُنْتُ عِنْدَ ابْنِ عُمَرَ، فَسُئِلَ عَنِ السَّاعَۃِ الَّتِی فِی الْجُمُعَۃِ ؟ قَالَ : فَقُلْتُ ہِیَ السَّاعَۃُ الَّتِی اخْتَارَ اللَّہُ لَہَا ، أَوْ فِیہَا الصَّلاَۃَ ، قَالَ : فَمَسَحَ رَأْسِی ، وَبَرَّکَ عَلَیَّ ، وَأَعْجَبَہُ مَا قُلْتُ۔",,,5506,,
5507,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی بُرْدَۃَ ، قَالَ : ہِیَ عِنْدَ خُرُوجِ الإِمَام۔",,,5507,,
5508,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، قَالَ : حدَّثَنَا مُعَاوِیَۃُ بْنُ صَالِحٍ ، قَالَ : حَدَّثَنَا مُوسَی بْنُ یَزِیدَ بْنِ مَوْہَبٍ أَبُو عَبْدِ الرَّحْمَنِ الأَمْلُوکِیُّ ، عَنْ أَبِی أُمَامَۃَ ، قَالَ : إِنِّی لأَرْجُو أَنْ تَکُونَ السَّاعَۃُ الَّتِی فِی الْجُمُعَۃِ إِحْدَی ہَذِہِ السَّاعَاتِ: إِذَا أَذَّنَ الْمُؤَذِّنُ ، أَوْ الإِمَامُ عَلَی الْمِنْبَرِ ، أَوَعِنْدَ الإِقَامَۃِ۔",,,5508,,
5509,"حَدَّثَنَا ہُشَیْمٌ، قَالَ: أَخْبَرَنَا مَنْصُورٌ، عَنِ الْحَسَنِ؛ أَنَّہُ کَانَ یَقُولُ ہِیَ عِنْدَ زَوَالِ الشَّمْسِ، فِی وَقْتِ الصَّلاَۃ۔",,,5509,,
5510,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُحَمَّدِ بْنِ قَیْسٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : ہِیَ مَا بَیْنَ أَنْ یَحْرُمَ الْبَیْعُ إِلَی أَنْ یَحْلِل۔",,,5510,,
5511,"حَدَّثَنَا وَکِیعٌ ، عَنِ الرَّبِیعِ ، عَنْ قَیْسِ بْنِ سَعْدٍ ، عَنْ مُجَاہِدٍ ، قَالَ : ہِیَ بَعْدَ الْعَصْرِ۔",,,5511,,
5512,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، قَالَ : حدَّثَنَا سُلَیْمَانُ بْنُ قَرْمٍ ، عَنْ أَبِی حَبِیبٍ ، عَنْ نُبَلَ ، عَنْ سَلاَمَۃَ بِنْتِ أَفْعَی ، قَالَتْ : کُنْتُ عِنْدَ عَائِشَۃَ فِی نِسْوَۃٍ ، فَسَمِعْتُہَا تَقُولُ : إِنَّ یَوْمَ الْجُمُعَۃِ مِثْلُ یَوْمِ عَرَفَۃَ ، وَإِنَّ فِیہِ لَسَاعَۃً تُفْتَحُ فِیہَا أَبْوَابُ الرَّحْمَۃِ ، فَقُلْنَا : أَیُّ سَاعَۃٍ ؟ فَقَالَتْ : حِینَ یُنَادِی الْمُنَادِی بِالصَّلاَۃِ۔",,,5512,,
5513,"حَدَّثَنَا عَبِیْدَۃُ بْنُ حُمَیْدٍ ، عَنْ سِنَانِ بْنِ حَبِیبٍ ، عَنْ نُبَلَ بِنْتِ بَدْرٍ ، عَنْ سَلاَمَۃَ بِنْتِ أفْعَی ، عَنْ عَائِشَۃَ ، قَالَتْ : إِنَّ یَوْمَ الْجُمُعَۃِ مِثْلُ یَوْمِ عَرَفَۃَ ، تُفْتَحُ فِیہِ أَبْوَابُ الرَّحْمَۃِ ، وَفِیہِ سَاعَۃٌ لاَ یَسْأَلُ اللَّہَ الْعَبْدُ شَیْئًا إِلاَّ أَعْطَاہُ، قِیلَ : وَأَیَّۃُ سَاعَۃٍ ؟ قَالَتْ : إِذَا أَذَّنَ الْمُؤَذِّنُ لِصَلاَۃِ الْغَدَاۃِ۔",,,5513,,
5514,"حَدَّثَنَا أَحْمَدُ بْنُ إِسْحَاقَ ، عَنْ وُہَیْبٍ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ ، قَالَ : إِنَّ السَّاعَۃَ الَّتِی تُرْجَی فِی الْجُمُعَۃِ بَعْدَ الْعَصْرِ۔",,,5514,,
5515,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، وَمَنْصُورٍ ، عَنِ الْحَسَنِ ، قَالَ : بَیْنَا النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَخْطُبُ إِذْ جَائَ رَجُلٌ یَتَخَطَّی رِقَابَ النَّاسِ یَوْمَ الْجُمُعَۃِ ، حَتَّی جَلَسَ قَرِیبًا مِنَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَلَمَّا قَضَی صَلاَتَہُ ، قَالَ لَہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : یَا فُلاَنُ ، أَمَا جَمَّعْتَ ؟ قَالَ : یَا رَسُولَ اللہِ ، أَمَا رَأَیْتَنِی ؟ قَالَ : قَدْ رَأَیْتُک آنَیْتَ وَآذَیْتَ۔ (ابوداؤد 1111۔ ابن خزیمۃ 1811)",,,5515,,
5516,"حَدَّثَنَا وَکِیعُ بْنُ الْجَرَّاحِ ، عَنِ الأَوْزَاعِیِّ ، عَنْ مُوسَی بْنِ سُلَیْمَانَ ، عَنِ الْقَاسِمِ بْنِ مُخَیْمِرَۃَ ، قَالَ : مَثَلُ الَّذِی یَتَخَطَّی رِقَابَ النَّاسِ یَوْمَ الْجُمُعَۃِ وَالإِمَامُ یَخْطُبُ ، کَالرَّافِعِ قَدَمَیْہِ فِی النَّارِ ، وَوَاضِعِہِمَا فِی النَّارِ۔",,,5516,,
5517,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَبْدِ اللہِ بْنِ الْوَلِیدِ ، قَالَ : حدَّثَنِی عُثْمَانُ بْنُ عَبْدِ اللہِ بْنِ مَوْہَبٍ ، قَالَ : قَالَ سَعِیدُ بْنُ الْمُسَیَّبِ : لأَنْ أُصَلِّیَ الْجُمُعَۃَ بِالْحَرَّۃِ ، أَحَبُّ إِلَیَّ مِنَ التَّخَطِّی۔",,,5517,,
5518,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَبْدِ اللہِ بْنِ الْوَلِیدِ ، عَنْ عُبَیْدِ بْنِ الْحَسَنِ ، قَالَ : رَأَیْتُ عُرْوَۃَ بْنَ الْمُغِیرَۃِ جَائَ إِلَی الْجُمُعَۃِ ، فَلَمَّا انْتَہَی قَامَ ، یَعْنِی وَلَمْ یَتَخَطَّ۔",,,5518,,
5519,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : قَالَ مُحَمَّدٌ : إِنَّہُمْ یَقُولُونَ : إِنَّ مُحَمَّدًا یَتَخَطَّی رِقَابَ النَّاسِ یَوْمَ الْجُمُعَۃِ ، وَلَسْتُ أَتَخَطَّی ، إِنَّمَا أَجِیئُ فَأَقُومُ فَیَعْرِفُنِی الرَّجُلُ ، فَیُوَسِّعُ لِی۔",,,5519,,
5520,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ حُمَیْدٍ الأَصَمِّ ، عَنْ أَبِی قَیْسٍ ، قَالَ : دَخَلَ عَبْدُ اللہِ بْنُ مَسْعُودٍ الْمَسْجِدَ یَوْمَ جُمُعَۃٍ ، وَعَلَیْہِ ثِیَابٌ بِیضٌ حِسَانٌ ، فَرَأَی مَکَانًا فِیہِ سَعَۃٌ فَجَلَسَ وَلَمْ یَتَخَطَّ۔",,,5520,,
5521,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ، قَالَ : لاَ بَأْسَ أَنْ یَتَخَطَّی رِقَابَ النَّاسِ إِِذَا کَانَ فِی الْمَسْجِدِ سَعَۃٌ۔",,,5521,,
5522,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، قَالَ : رَأَیْتُ شُرَیْحًا جَائَ یَوْمَ الْجُمُعَۃِ وَالإِمَامُ یَخْطُبُ فَجَلَسَ ، یَعْنِی وَلَمْ یَتَخَطَّ۔",,,5522,,
5523,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَمَّادٍ ، عَنْ عُمَرَ بْنِ عَطِیَّۃَ ، عَنْ سَلْمَانَ ، قَالَ : إِیَّاکَ وَتَخَطِّیَ رِقَابِ النَّاسِ یَوْمَ الْجُمُعَۃِ ، وَاجْلِسْ حَیْثُ تَبْلُغُکَ الْجُمُعَۃُ۔",,,5523,,
5524,"حَدَّثَنَا وَکِیعٌ ، وَالْفَضْلُ ، عَنْ سُفْیَانَ ، عَنْ صَالِحٍ مَوْلَی التَّوْأَمَۃِ ، قَالَ : سَمِعْتُ أَبَا ہُرَیْرَۃَ یَقُولُ : لأَنْ أُصَلِّیَ بِالْحَرَّۃِ أَحَبُّ إلَیَّ مِنْ أَنْ أَتَخَطَّی رِقَابَ النَّاسِ یَوْمَ الْجُمُعَۃِ۔",,,5524,,
5525,"حَدَّثَنَا وَکِیعٌ ، عَنْ جُوَیْرِیَۃَ بْنِ أَسْمَائَ ، عَنْ خَوَّاتِ بْنِ بُکَیْر ، عَنْ کَعْبٍ ، قَالَ : لأَنْ أَدَعَ الْجُمُعَۃَ أَحَبُّ إِلَیَّ مِنْ أَنْ أَتَخَطَّی رِقَابَ النَّاسِ۔",,,5525,,
5526,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : أَطَالَ بَعْضُ الأُمَرَائِ الْخُطْبَۃَ ، فَأَنْکَیْتُ یَدَیَّ حَتَّی أَدْمَیْتُہَا ، ثُمَّ قُمْتُ وَأَخَذَتْیِح السِّیَاطُ ، فَمَضَیْتُ فَخَرَجْتُ۔",,,5526,,
5527,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ سَوَّارٍ ، عَنْ عَبْدِ الْوَاحِدِ بْنِ سَبْرَۃَ ؛ أَنَّ سَالِمًا حَدَّثَ الْقَاسِمَ بْنَ مُحَمَّدٍ ، قَالَ : لَمَّا قَدِمَ عَلَیْنَا الأَمِیرُ ، جَائَتِ الْجُمُعَۃُ ، فَجَمَّعَ بِنَا ، فَمَا زَالَ یَخْطُبُ وَیَقْرَأُ الْکُتُبَ حَتَّی مَضَی وَقْتُ الْجُمُعَۃِ ، وَلَمْ یَنْزِلْ یُصَلِّی ۔ فَقَالَ لَہُ الْقَاسِمُ : فَمَا قُمْتَ فَصَلَّیْتَ ؟ قَالَ : لاَ وَاللَّہِ ، خَشِیتُ أَنْ یُقَالَ : رَجُلٌ مِنْ آلِ عُمَرَ ، قَالَ : فَمَا صَلَّیْتَ قَاعِدًا ؟ قَالَ : لاَ ، قَالَ : فَمَا أَوْمَأْتَ ؟ قَالَ : لاَ ، قَالَ : ثُمَّ مَا زَالَ یَخْطُبُ وَیَقْرَأُ حَتَّی مَضَی وَقْتُ الْعَصْرِ وَلَمْ یَنْزِلْ یُصَلِّی ، فَقَالَ لَہُ الْقَاسِمُ : فَمَا قُمْتَ صَلَّیْتَ ؟ قَالَ : لاَ ، قَالَ : فَمَا صَلَّیْت قَاعِدًا ؟ قَالَ : لاَ ، قَالَ : فَمَا أَوْمَأْتَ ؟ قَالَ : لاَ۔",,,5527,,
5528,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، عَنْ إِبْرَاہِیمَ بْنِ الْمُہَاجِرِ ، عَنْ أَبِی بَکْرِ بْنِ عَمْرِو بْنِ عُتْبَۃَ الزُّہْرِیِّ ، قَالَ : أَخَّرَ الْحَجَّاجُ الْجُمُعَۃَ ، فَلَمَّا صَلَّی صَلاَّہَا مَعَہُ أَبُو جُحَیْفَۃَ ، ثُمَّ قَامَ فَوَصَلَہَا بِرَکْعَتَیْنِ ، ثُمَّ قَالَ : یَا أَبَا بَکْرٍ ، أُشْہِدُکَ أَنَّہَا الْعَصْرُ۔",,,5528,,
5529,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنٍ ، عَنْ إِبْرَاہِیمَ بْنِ مُہَاجِرٍ ، قَالَ : کَانَ الْحَجَّاجُ یُؤَخِّرُ الْجُمُعَۃَ ، فَکُنْت أَنَا أُصَلِّی ، وَإِبْرَاہِیمُ وَسَعِیدُ بْنُ جُبَیْرٍ نُصَلِّی الظُّہْرَ ، ثُمَّ نَتَحَدَّثُ وَہُوَ یَخْطُبُ ، ثُمَّ نُصَلِّی مَعَہُمْ ، ثُمَّ نَجْعَلُہَا نَافِلَۃً۔",,,5529,,
5530,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنْ مُسْلِمٍ ، قَالَ: کُنْتُ أَجْلِسُ مَعَ مَسْرُوقٍ ، وَأَبِی عُبَیْدَۃَ زَمَنَ زِیَادٍ، فَإِذَا دَخَلَ وَقْتُ الصَّلاَۃِ قَامَا فَصَلَّیَا ، ثُمَّ یَجْلِسَانِ حَتَّی إِذَا أَذَّنَ الْمُؤَذِّنُ وَخَرَجَ الإِمَامُ ، قَامَا فَصَلَّیَا مَعَہُ ، وَیَفْعَلاَنِہِ فِی الْعَصْرِ۔",,,5530,,
5531,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی ہَاشِمٍ ؛ أَنَّ الْحَجَّاجَ أَخَّرَ الصَّلاَۃَ ، فَأَوْمَأَ أَبُو وَائِلٍ وَہُوَ جَالِسٌ۔,,,5531,,
5532,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ عَبْدِ اللہِ بْنِ عُثْمَانَ بْنِ خُثَیْمٍ ، عَنِ الْقَاسِمِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِیہِ ؛ أَنَّ الْوَلِیدَ بْنَ عُقْبَۃَ أَخَّرَ الصَّلاَۃَ بِالْکُوفَۃِ وَأَنَا جَالِسٌ مَعَ أَبِی فِی الْمَسْجِدِ ، فَقَامَ عَبْدُ اللہِ فَثَوَّبَ بِالصَّلاَۃ ، فَصَلَّی لِلنَّاسِ ، فَأَرْسَلَ إِلَہِ الْوَلِیدُ بْنُ عُقْبَۃَ : مَا حَمَلَک عَلَی مَا صَنَعْتَ ؟ أَجَائَک مِنْ أَمِیرِ الْمُؤْمِنِینَ أَمْرٌ فِیمَا قِبَلَنَا ، فَسَمْعٌ وَطَاعَۃٌ ، أَمِ ابْتَدَعْتَ مَا صَنَعْتَ الْیَوْمَ ؟ قَالَ : لَمْ یَأْتِنِی مِنْ أَمِیرِ الْمُؤْمِنِینَ أَمْرٌ ، وَمَعَاذَ اللہِ أَنْ أَکُونَ ابْتَدَعْتُ ، أَبَی اللَّہُ وَرَسُولُہُ أَنْ نَنْتَظِرَک بِصَلاَتِنَا وَأَنْتَ فِی حَوَائِجِک۔",,,5532,,
5533,"حَدَّثَنَا مُحَمَّدُ بْنُ عُبَیْدٍ ، عَنِ الزِّبْرِقَانَ ، قَالَ : قُلْتُ لِشَقِیقٍ : إِنَّ الْحَجَّاجَ یُمِیتُ الْجُمُعَۃَ ، قَالَ : تَکَتَّمَ عَیََّ ؟ قَالَ : قُلْتُ : نَعَمْ ، قَالَ : صَلِّہَا فِی بَیْتِکَ لِوَقْتِہَا ، وَلاَ تَدَعِ الْجَمَاعَۃَ۔",,,5533,,
5534,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : رَفْعُ الأَیْدِی یَوْمَ الْجُمُعَۃِ مُحْدَثٌ۔",,,5534,,
5535,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : أَوَّلُ مَنْ رَفَعَ یَدَیْہِ فِی الْجُمُعِ عُبَیْدُ اللہِ بْنُ عَبْدِ اللہِ بْنِ مَعْمَرٍ۔",,,5535,,
5536,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ : کَانَ یَکْرَہُ دُعَائَہُمُ الَّذِی یَدْعُونَہُ یَوْمَ الْجُمُعَۃِ ، وَکَانَ لاَ یَرْفَعُ یَدَیْہِ۔",,,5536,,
5537,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، وَأَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ عَبْدِ اللہِ بْنِ مُرَّۃَ ، عَنْ مَسْرُوقٍ ، قَالَ : رَفَعَ الإِمَامُ یَوْمَ الْجُمُعَۃِ یَدَیْہِ عَلَی الْمِنْبَرِ ، فَرَفَعَ النَّاسُ أَیْدِیَہُمْ ، فَقَالَ مَسْرُوقٌ : مَا لَہُمْ ، قَطَعَ اللَّہُ أَیْدِیَہُمْ۔",,,5537,,
5538,حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنْ عُمَارَۃَ بْنِ رُوَیْبَۃَ ؛ أَنَّہُ رَأَی بِشْرَ بْنَ مَرْوَانَ رَافِعًا یَدَیْہِ یَدْعُو ، حَتَّی کَادَ یَسْتَلْقِی خَلْفَہُ۔,,,5538,,
5539,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنْ عُمَارَۃَ بْنِ رُوَیْبَۃَ ، قَالَ : رَأَی بِشْرَ بْنَ مَرْوَانَ رَافِعًا یَدَیْہِ عَلَی الْمِنْبَرِ ، فَقَالَ : قَبَّحَ اللَّہُ ہَاتَیْنِ الْیَدَیْنِ ، لَقَدْ رَأَیْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَا یَزِیدُ عَلَی أَنْ یَقُولَ بِیَدَیْہِ ہَکَذَا ، وَأَشَارَ بِإِصْبَعِہِ الْمُسَبِّحَۃِ۔",,,5539,,
5540,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنِ الأَعْمَشِ ، قَالَ : کَانَ أَصْحَابُ عَبْدِ اللہِ یُصَلُّونَ مَعَ الْمُخْتَارِ الْجُمُعَۃَ ، وَیَحْتَسِبُونَ بِہَا۔",,,5540,,
5541,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ عُقْبَۃَ الأَسَدِیِّ ، عَنْ یَزِیدَ بْنِ أَبِی سُلَیْمَانَ ؛ أَنَّ أَبَا وَائِلٍ جَمَّعَ مَعَ الْمُخْتَارِ۔,,,5541,,
5542,"حَدَّثَنَا وَکِیعٌ ، عَنْ سَعِیدِ بْنِ السَّائِبِ ، عَنْ صَالِحِ بْنِ سَعِیدٍ ، قَالَ : خَرَجْتُ مَعَ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ إِلَی السُّوَیْدَائِ مُتَبَدِّیًا ، فَلَمَّا حَضَرَتِ الْجُمُعَۃُ أَذَّنَ الْمُؤَذِّنُ ، فَجَمَعُوا لَہُ حَصْبَائَ ، قَالَ : فَقَامَ فَخَطَبَ ، ثُمَّ صَلَّی الْجُمُعَۃَ رَکْعَتَیْنِ ، ثُمَّ قَالَ : الإِمَامُ یُجَمِّعُ حَیْثُ مَا کَانَ۔",,,5542,,
5543,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ سَعِیدِ بْنِ سُوَیْد ، قَالَ : صَلَّی بِنَا مُعَاوِیَۃُ الْجُمُعَۃَ بِالنَّخِیلَۃِ فِی الضُّحَی ، ثُمَّ خَطَبَنَا۔",,,5543,,
5544,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ أَبِیہِ ، عَنِ الْحَسَنِ ، عَنْ قَیْسِ بْنِ عُبَادٍ (ح) وَعَنْ زُرَارَۃَ بْنِ أَوْفَی ، عَنْ أَبِی ہُرَیْرَۃَ ، أَنَّہُمَا قَالاَ : مَنْ لَمْ یُصَلِّ فِی الْمَسْجِدِ فَلاَ صَلاَۃَ لَہُ۔",,,5544,,
5545,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ بِالصَّلاَۃ یَوْمَ الْجُمُعَۃِ فِی السُّدَّۃِ۔",,,5545,,
5546,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : لاَ بَأْسَ بِالصَّلاَۃِ یَوْمَ الْجُمُعَۃِ فِی الرَّحَبَۃِ ، وَإِنْ کَانَ یَقْدِرُ أَنْ یَدْخُلَ فَلاَ صَلاَۃَ لَہُ۔",,,5546,,
5547,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الشَّیْبَانِیِّ ، قَالَ : رَأَیْتُ عُرْوَۃَ بْنَ الْمُغِیرَۃِ بْنِ شُعْبَۃَ صَلَّی فِی السُّدَّۃِ۔",,,5547,,
5548,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، وَابْنُ نُمَیْرٍ ، قَالاَ : حدَّثَنَا سَعِیدٌ ، عَنْ قَتَادَۃَ ، عَنْ زُرَارَۃَ بْنِ أَوْفَی ؛ أَنَّ أَبَا ہُرَیْرَۃَ أَتَی عَلَی رِجَالٍ جُلُوسٍ فِی الرَّحْبَۃِ ، فَقَالَ : اُدْخُلُوا الْمَسْجِدَ ، فَإِنَّہُ لاَ جُمُعَۃَ إِلاَّ فِی الْمَسْجِدِ۔",,,5548,,
5549,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا سَعِیدٌ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، أَنَّہُ قَالَ : لاَ جُمُعَۃَ لِمَنْ صَلَّی فِی الرَّحْبَۃِ ، إِلاَّ أَنْ لاَ یَقْدِرَ عَلَی الدُّخُولِ۔",,,5549,,
5550,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنِ الصَّلْتِ الرَّبْعِی ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : سَمِعْتُہُ یَقُولُ : إِذَا لَمْ تَسْمَعْ قِرَائَۃَ الإِمَامِ یَوْمَ الْجُمُعَۃِ فَاقْرَأْ۔",,,5550,,
5551,"حَدَّثَنَا حَاتِمٌ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ حَرْمَلَۃَ ، عَنِ ابن الْمُسَیَّبِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : سَیِّدُ الأَیَّامِ یَوْمُ الْجُمُعَۃِ۔ (ابن خزیمۃ 1728۔ بیہقی 2971)",,,5551,,
5552,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ ہُبَیْرَۃَ ، عَنْ عَبْدِ اللہِ ، قَالَ : إِنَّ سَیِّدَ الأَیَّامِ یَوْمُ الْجُمُعَۃِ ، وَسَیِّدَ الشُّہُورِ رَمَضَانُ۔",,,5552,,
5553,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الأَجْلَحِ ، عَنْ أَبِی بُرْدَۃَ بن أَبِی مُوسَی ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنَّ فِی الْجُمُعَۃِ لَسَاعَۃً ، مَا دَعَا اللَّہَ فِیہَا عَبْدٌ مُسْلِمٌ بَشَیئٍ إِلاَّ اسْتَجَابَ لَہُ۔(بخاری 6400۔ مسلم 584)",,,5553,,
5554,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ بْنِ جَابِرٍ ، عَنْ أَبِی الأَشْعَثِ الصَّنْعَانِیِّ ، عَنْ أَوْسِ بْنِ أَوْسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنَّ مِنْ أَفْضَلِ أَیَّامِکُمْ یَوْمَ الْجُمُعَۃِ ، فِیہِ خُلِقَ آدَم ، وَفِیہِ النَّفْخَۃُ ، وَفِیہِ الصَّعْقَۃُ۔ (ابوداؤد 1526۔ احمد 4/8)",,,5554,,
5555,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ مُجَاہِدٍ ، عَنْ عَبْدِ اللہِ بْنِ ضَمْرَۃَ ، عَنْ کَعْبٍ ، قَالَ : لَمْ تَطْلُعِ الشَّمْسُ بِیَوْمٍ ہُوَ أَعْظَمُ مِنَ الْجُمُعَۃِ ، إِنَّہَا إِذَا طَلَعَتْ فَزِعَ لَہَا کُلُّ شَیْئٍ إِلاَّ الثَّقَلَینِ ، اللَّذیْنِ عَلَیْہِمَا الْحِسَابُ وَالْعَذَابُ۔",,,5555,,
5556,"حَدَّثَنَا أبو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ مُجَاہِدٍ ، عَنْ عَبْدِ اللہِ بْنِ ضَمْرَۃَ ، عَنْ کَعْبٍ ، قَالَ : الصَّدَقَۃُ تُضَاعَفُ یَوْمَ الْجُمُعَۃِ۔",,,5556,,
5557,حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنْ ہِلاَلِ بْنِ یَِسَافٍ ، عَنْ کَعْبٍ ؛ أَنَّ یَوْمَ الْجُمُعَۃِ لَیَفْزَعُ لَہُ الْخَلاَئِقُ وَالْجِنُّ وَالإِنْسُ ، وَإِنَّہُ لَتُضَاعَفُ فِیہِ الْحَسَنَۃُ وَالسَّیِّئَۃُ ، وَإِنَّہُ لَیَوْمُ الْقِیَامَۃِ۔,,,5557,,
5558,"حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ ، قَالَ : حدَّثَنَا کَثِیرُ بْنُ عَبْدِ اللہِ الْمُزَنِیُّ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، یَقُولُ : فِی الْجُمُعَۃِ سَاعَۃٌ مِنَ النَّہَارِ ، لاَ یَسْأَلُ فِیہَا الْعَبْدُ شَیْئًا إِلاَّ أُعْطِیَ سُؤْلَہُ ، قِیلَ : أَیُّ سَاعَۃٍ ہِیَ ؟ قَالَ : حَیْثُ تُقَامُ الصَّلاَۃُ إِلَی الانْصِرَافِ مِنْہَا۔ (ترمذی 490۔ ابن ماجہ 1138)",,,5558,,
5559,"حَدَّثَنَا یَحْیَی بْنُ أَبِی بُکَیْرٍ ، قَالَ : حدَّثَنَا زُہَیْرُ بْنُ مُحَمَّدٍ ، عَنْ عَبْدِ اللہِ بْنِ مُحَمَّدٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، عَنْ أَبِی لُبَابَۃَ بْنِ عَبْدِ الْمُنْذِرِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنَّ یَوْمَ الْجُمُعَۃِ سَیِّدُ الأَیَّامِ ، وَأَعْظَمُہَا عِنْدَ اللہِ ، وَأَعْظَمُ عِنْدَ اللہِ مِنْ یَوْمِ الأَضْحَی وَیَوْمِ الْفِطْرِ ، فِیہِ خَمْسُ خِلاَلٍ : خَلَقَ اللَّہُ فِیہِ آدَمَ ، وَأَہْبَطَ اللَّہُ فِیہِ آدَمَ ، وَفِیہِ تَوَفَّی اللَّہُ آدَمَ ، وَفِیہِ سَاعَۃٌ لاَ یَسْأَلُ اللَّہَ الْعَبْدُ فِیہَا شَیْئًا إِلاَّ أَعْطَاہُ إِیَّاہُ، مَا لَمْ یَسْأَلْ حَرَامًا ، وَفِیہِ تَقُومُ السَّاعَۃُ ، مَا مِنْ مَلَکٍ مُقَرَّبٍ ، وَلاَ أَرْضٍ ، وَلاَ سَمَائٍ ، وَلاَ رِیَاحٍ ، وَلاَ جِبَالٍ ، وَلاَ بَحْرٍ إِلاَّ ہُنَّ یُشْفِقْنَ مِنْ یَوْمِ الْجُمُعَۃِ۔ (ابن ماجہ 1084۔ احمد 3/430)",,,5559,,
5560,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مُحَمَّدٍ الْمُحَارِبِیُّ ، عَنْ لَیْثٍ ، عَنْ عُثْمَانَ ، عَنْ أَنَسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَتَانِی جِبْرِیلُ ، وَفِی یَدِہِ کَالْمِرْآۃِ الْبَیْضَائِ ، فِیہَا کَالنُّکْتَۃِ السَّوْدَائِ ، فَقُلْتُ : یَا جِبْرِِیلُ! مَا ہَذِہِ ؟ قَالَ : ہَذِہِ الْجُمُعَۃ ۔\n\nقَالَ : قُلْتُ : وَمَا الْجُمُعَۃُ ؟ قَالَ : لَکُمْ فِیہَا خَیْرٌ ۔ قَالَ : قُلْتُ : وَمَا لَنَا فِیہَا ؟ قَالَ : تَکُونُ عِیدًا لَکَ وَلِقَوْمِکَ مِنْ بَعْدِکَ ، وَیَکُونُ الْیَہُودُ وَالنَّصَارَی تَبَعًا لَکَ ۔قَالَ : قُلْتُ : وَمَا لَنَا فِیہَا ؟ قَالَ : لَکُمْ فِیہَا سَاعَۃٌ ، لاَ یُوَافِقُہَا عَبْدٌ مُسْلِمٌ یَسْأَلُ اللَّہَ فِیہَا شَیْئًا مِنَالدُّنْیَا وَالأَخِرَۃِ ، ہُوَ لَہُ قَسَمٌ إِلاَّ أَعْطَاہُ إِیَّاہُ ، أَوْ لَیْسَ لَہُ بِقَسَمٍ إِلاَّ ذُخِرَ لَہُ عِنْدَہُ مَا ہُوَ أَفْضَلُ مِنْہُ ، أَوْ یَتَعَوَّذُ بِہِ مِنْ شَرٍّ ، ہُوَ عَلَیْہِ مَکْتُوبٌ إِلاَّ صَرَفَ عَنْہُ مِنَ الْبَلاَئِ مَا ہُوَ أَعْظَمُ مِنْہُ ۔\n\nقَالَ : قُلْتُ لَہُ : وَمَا ہَذِہِ النُّکْتَۃُ فِیہَا ؟ قَالَ : ہِیَ السَّاعَۃُ ، وَہِیَ تَقُومُ یَوْمَ الْجُمُعَۃِ ، وَہُوَ عِنْدَنَا سَیِّدُ الأَیَّامِ ، وَنَحْنُ نَدْعُوہُ یَوْمَ الْقِیَامَۃِ ، یَوْمَ الْمَزِیدِ ۔\n\nقَالَ : قُلْتُ : مِمَّ ذَاکَ ؟ قَالَ : لأَنَّ رَبَّک ، تَبَارَکَ وَتَعَالَی اتَّخَذَ فِی الْجَنَّۃِ وَادِیًا مِنْ مِسْکٍ أبْیَضَ ، فَإِذَا کَانَ یَوْمُ الْجُمُعَۃِ ہَبَطَ مِنْ عِلِّیِّینَ عَلَی کُرْسِیِّہِ ، تَبَارَکَ وَتَعَالَی ، ثُمَّ حَفَّ الْکُرْسِیَّ بِمَنَابِرَ مِنْ ذَہَبٍ مُکَلَّلَۃٍ بِالْجَوَاہِرِ ، ثُمَّ یَجِیئُ النَّبِیُّونَ حَتَّی یَجْلِسُوا عَلَیْہَا ، وَیَنْزِلُ أَہْلُ الْغُرَفِ حَتَّی یَجْلِسُوا عَلَی ذَلِکَ الْکَثِیبِ ، ثُمَّ یَتَجَلَّی لَہُمْ رَبُّہُم ، تَبَارَکَ وَتَعَالَی ، ثُمَّ یَقُولُ : سَلُونِی أُعْطِکُمْ ، قَالَ : فَیَسْأَلُونَہُ الرِّضَی ، فَیَقُولُ : رِضَائِی أَحَلَّکُمْ دَارِی ، وَأَنَالَکُمْ کَرَامَتِی ، فَسَلُونِی أُعْطِکُمْ ، قَالَ : فَیَسْأَلُونَہُ الرَّضَی ، قَالَ : فَیُشْہِدُہُمْ أَنَّہُ قَدْ رَضِیَ عَنْہُمْ ، قَالَ : فَیُفْتَحُ لَہُمْ مَا لَمْ تَرَ عَیْنٌ ، وَلَمْ تَسْمَعْ أُذُنٌ ، وَلَمْ یَخْطِرْ عَلَی قَلْبِ بَشَرٍ ، قَالَ : وَذَلِکُمْ مِقْدَارُ انْصِرَافِکُمْ مِنْ یَوْمِ الْجُمُعَۃِ ۔\n\nقال ثُمَّ یَرْتَفِعُ ، وَیَرْتَفِعُ مَعَہُ النَّبِیُّونَ ، وَالصِّدِّیقُونَ ، وَالشُّہَدَائُ ، وَیَرْجِعُ أَہْلُ الْغُرَفِ إِلَی غُرَفِہِمْ ، وَہِیَ دُرَّۃٌ بَیْضَائُ ، لَیْسَ فِیہَا قَصْمٌ ، وَلاَ فَصْمٌ ، أَوْ دُرَّۃٌ حَمْرَائُ ، أَوْ زَبَرْجَدَۃٌ خَضْرَائُ فِیہَا غُرَفُہَا وَأَبْوَابُہَا مَطْرُورَۃٌ ، وَفِیہَا أَنْہَارُہَا وَثِمَارُہَا مُتَدَلِّیَۃٌ ، قَالَ : فَلَیْسُوا إِلَی شَیْئٍ أَحْوَجَ مِنْہُمْ إِلَی یَوْمِ الْجُمُعَۃِ لِیَزْدَادُوا إِلَی رَبِّہِمْ نَظَرًا ، وَلِیَزْدَادُوا مِنْہُ کَرَامَۃً۔ (طبرانی 6713۔ بزار 3519)",,,5560,,
5561,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ یَزِیدَ الرَّقَاشِیِّ ، عَنْ أَنَسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : جَائَنِی جِبْرِیلُ بِمِرْآۃٍ بَیْضَائَ فِیہَا نُکْتَۃٌ سَوْدَائُ ، قَالَ : فَقُلْتُ : مَا ہَذِہِ ؟ قَالَ : ہَذِہِ الْجُمُعَۃُ وَفِیہَا السَّاعَۃٌ۔ (ابو یعلی 4089)",,,5561,,
5562,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، عَنِ الأَغَرِّ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : الْمُتَعَجِّلُ إِلَی الْجُمُعَۃِ کَالَّذِی یُہْدِی بَدَنَۃً ، ثُمَّ کَالْمُہْدِی بَقَرَۃً ، ثُمَّ کَالْمُہْدِی شَاۃً، ثُمَّ کَالْمُہْدِی طَائِرًا۔ (بخاری 929۔ مسلم 24)",,,5562,,
5563,"حَدَّثَنَا شَبَابَۃُ ، قَالَ : حدَّثَنَا ابْنُ أَبِی ذِئْبٍ ، عَنِ الْمَقْبُرِیِّ ، عَنْ أَبِیہِ ، عَنْ عَبْدِ اللہِ بْنِ وَدِیعَۃَ ، عَنْ سَلْمَانَ الْخَیْرِ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لاَ یَغْتَسِلُ الرَّجُلُ یَوْمَ الْجُمُعَۃِ وَیَتَطَہَّرُ بِمَا اسْتَطَاعَ مِنْ طَہُورِہِ ، وَیَدَّہِنُ مِنْ دُہْنِہِ ، أَوْ یَمَسُّ طِیبًا مِنْ بَیْتِہِ ، ثُمَّ رَاحَ ، فَلَمْ یُفَرِّقْ بَیْنَ اثْنَیْنِ ، ثُمَّ صَلَّی مَا کَتَبَ اللَّہُ لَہُ ، ثُمَّ أَنْصَتَ إِذَا تَکَلَّمَ الإِمَامُ ، إِلاَّ غُفِرَ لَہُ مَا بَیْنَہُ وَبَیْنَ الْجُمُعَۃِ الأُخْرَی۔ (بخاری 883۔ احمد 5/440)",,,5563,,
5564,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، قَالَ : أَخْبَرَنَا عَلِیُّ بْنُ زَیْدٍ ، عَنْ أَوْسِ بْنِ خَالِدٍ ، عَنْ أَبِی ہُرَیْرَۃَ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إِنَّ الْمَلاَئِکَۃَ عَلَی أَبْوَابِ الْمَسْجِدِ یَکْتُبُونَ النَّاسَ عَلَی مَنَازِلِہِمْ : جَائَ فُلاَنٌ مِنْ سَاعَۃِ کَذَا وَکَذَا ، جَائَ فُلاَنٌ مِنْ سَاعَۃِ کَذَا ، جَائَ فُلاَنٌ وَالإِمَامُ یَخْطُبُ ، جَائَ فُلاَنٌ فَأَدْرَکَ الصَّلاَۃَ وَلَمْ یُدْرِکِ الْخُطْبَۃَ۔ (احمد 2/343۔ طیالسی 2565)",,,5564,,
5565,"حَدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : نُبِّئْت أَنَّ مُحَمَّدًا اشْتَدَّ الْمَطَرُ یَوْمَ جُمُعَۃٍ فَلَمْ یُجَمِّعْ۔",,,5565,,
5566,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ الْقَطَّانُ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ کَثِیرٍ مَوْلَی ابْنِ سَمُرَۃَ ، قَالَ : مَرَرْتُ بِعَبْدِ الرَّحْمَنِ بْنِ سَمُرَۃَ وَہُوَ عَلَی بَابِہِ جَالِسٌ ، فَقَالَ : مَا خَطْبُ أَمِیرِکُمْ ؟ قُلْتُ : أَمَا جَمَّعْتَ ؟ قَالَ : مَنَعَنَا مِنْہَا ہَذَا الرَّدْغُ۔",,,5566,,
5567,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا سَعِیدٌ ، عَنْ قَتَادَۃَ ، عَنْ عَبْدِ اللہِ بْنِ الْحَارِثِ ؛ أَنَّ ابْنَ عَبَّاسٍ أَمَرَ مُنَادِیَہُ فَنَادَی فِی یَوْمٍ مَطِیرٍ یَوْمَ جُمُعَۃٍ : الصَّلاَۃُ فِی الرِّحَالِ ، الصَّلاَۃُ فِی الرِّحَالِ۔",,,5567,,
5568,حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ نَافِعٍ ؛ أَنَّ ابْنًا لِسَعِیدِ بْنِ زَیْدِ بْنِ نُفَیْلٍ کَانَ بِأَرْضٍ لَہُ بِالْعَقِیقِ ، عَلَی رَأْسِ أَمْیَالٍ مِنَ الْمَدِینَۃِ ، فَأَتَی ابْنَ عُمَرَ غَدَاۃَ یَوْمِ الْجُمُعَۃِ ، فَذَکَرَ لَہُ شَکَوَاہُ ، فَانْطَلَقَ إِلَیْہِ وَتَرَکَ الْجُمُعَۃَ۔,,,5568,,
5569,"حَدَّثَنَا عَبْدُ الْوَہَّابِ ، قَالَ : سَأَلْتُ یُونُسَ عَنِ الرَّجُلِ تُحْتَضَرُ وَالِدَتُہُ ، أَوْ وَالِدُہُ ، أَوْ نَسِیبُہُ ، أَلَہُ عُذْرٌ فِی تَرْکِ الْجُمُعَۃِ ؟ فَقَالَ : کَانَ الْحَسَنُ یُرَخِّصُ فِیہَا لِصَاحِبِ الْجِنَازَۃِ ، یَخَافُ عَلَیْہَا ، أَوِ الرَّجُلُ یَکُونُ خَائِفًا۔",,,5569,,
5570,"حَدَّثَنَا عُمَرُ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : إِذَا اسْتُصْرِخَ عَلَی ابْنِکَ یَوْمَ الْجُمُعَۃِ وَالإِمَامُ یَخْطُبُ، فَقُمْ إِلَیْہِ ، وَاتْرُکق الْجُمُعَۃَ۔",,,5570,,
5571,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ عِمْرَانَ بْنِ حُدَیْرٍ ، قَالَ : قَالَ رَجُلٌ لأَبِی مِجْلَزٍ : أَوْ قُلْتُ لَہُ : آتِی الْجُمُعَۃَ وَأَنَا أَشْتَکِی بَطْنِی ؟ قَالَ : عَجْزٌ۔",,,5571,,
5572,حَدَّثَنَا وَکِیعٌ ، عَنْ عِمْرَانَ ، عَنْ أَبِی مِجْلَزٍ ، نَحْوَہُ۔,,,5572,,
5573,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی الْفَضْلِ ، عَنِ الْحَسَنِ ، قَالَ : لَیْسَ عَلَی الْخَائِفِ ، وَلاَ عَلَی الْعَبْدِ الَّذِی یَخْدِمُ أَہْلَہُ ، وَلاَ عَلَی وَلِیِّ الْجِنَازَۃِ ، وَلاَ عَلَی الأَعْمَی إِذَا لَمْ یَجِدْ قَائِدًا جُمُعَۃٌ۔",,,5573,,
5574,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہَمَّامٍ ، قَالَ : سَمِعْتُ الْحَسَنَ وَسُئِلَ عَنِ الْخَائِفِ ، عَلَیْہِ جُمُعَۃٌ ؟ فَقَالَ : وَمَا خَوْفُہُ؟ قَالَ : مِنَ السُّلْطَانِ ، قَالَ : إِنَّ لَہُ عُذْرًا۔",,,5574,,
5575,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : تَجِبُ الْجُمُعَۃُ عَلَی الأَعْمَی إِذَا وَجَدَ قَائِدًا ، وَعَلَی الْعَبْدِ إِذَا کَانَ یُؤَدِّی الضَّرِیبَۃَ ۔ قَالَ : وَکَانَ یُرَخِّصُ لِلْخَائِفِ فِی الْجُمُعَۃِ۔",,,5575,,
5576,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، وَمُحَمَّدُ بْنُ بِشْرٍ ، وَابْنُ إِدْرِیسَ ، قَالُوا : أَخْبَرَنَا مُحَمَّدُ بْنُ عَمْرٍو ، عَنْ عَبِیْدَۃَ بْنِ سُفْیَانَ الْحَضْرَمِیِّ ، قَالَ : سَمِعْتُ أَبَا الْجَعْدِ الضَّمْرِیَّ ، وَکَانَتْ لَہُ صُحْبَۃٌ ، یَقُولُ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ تَرَکَ الْجُمُعَۃَ ثَلاَثَ مَرَّاتٍ تَہَاوُنًا ، طُبِعَ عَلَی قَلْبِہِ۔ (ترمذی 500۔ ابوداؤد 1045)",,,5576,,
5577,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا ہِشَامُ الدَّسْتَوَائِیُّ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ أَبِی سَلاَّمٍ ، عَنِ الْحَکَمِ بْنِ مِینَائَ ، عَنِ ابْنِ عُمَرَ ، وَابْنِ عَبَّاسٍ ؛ أَنَّہُمَا شَہِدَا عَلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنَّہُ قَالَ، وَہُوَ عَلَی أَعْوَادِ الْمِنْبَرِ : لَیَنْتَہِیَنَّ أَقْوَامٌ عَنْ وَدَعِہِمُ الْجُمُعَاتِ ، أَوْ لَیَطْبَعَنَّ اللَّہُ عَلَی قُلُوبِہِمْ ، وَلَیُکْتَبُنَّ مِنَ الْغَافِلِینَ۔ (مسلم 40۔ نسائی 1658)",,,5577,,
5578,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا ہَمَّامُ بْنُ یَحْیَی ، عَنْ قَتَادَۃَ ، عَنْ قُدَامَۃَ بْنِ وَبَرَۃَ الْعُجَیْفِیِّ ، عَنْ سَمُرَۃََ بْنِ جُنْدُبٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : مَنْ تَرَکَ الْجُمُعَۃَ مِنْ غَیْرِ عُذْرٍ فَلْیَتَصَدَّقْ بِدِینَارٍ، فَإِنْ لَمْ یَجِدْ فَبِنِصْفِ دِینَارٍ۔ (ابوداؤد 1046۔ ابن حبان 2788)",,,5578,,
5579,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ عَوْفٍ ، عَنْ سَعِیدِ بْنِ أَبِی الْحَسَنِ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : مَنْ تَرَکَ الْجُمُعَۃَ ثَلاَثًا مُتَوَالِیَاتٍ ، طَبَعَ اللَّہُ عَلَی قَلْبِہِ۔",,,5579,,
5580,"حَدَّثَنَا عُبَیْدُ اللہِ ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنِ الْعَبَّاسِ بْنِ عَبْدِ اللہِ بْنِ مَعْبَدٍ ، قَالَ : قَالَ : أَبُو ہُرَیْرَۃَ : مَا أُحِبُّ أَنَّ لِی حُمْرَ النِّعَمِ ، وَلاَ أَنَّ الْجُمُعَۃَ تَفُوتُنِی إِلاَّ مِنْ عُذْرٍ۔",,,5580,,
5581,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ مُحَمَّدِ بْنِ عَبَّادِ بْنِ جَعْفَرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : عَسَی أَحَدُکُمْ أَنْ یَتَّخِذَ الصَّبَّۃَ مِنَ الْغَنَمِ عَلَی رَأْسِ الْمِیلَیْنِ ، أَوِ الثَّلاَثَۃِ ، فَتَکُونُ الْجُمُعَۃُ فَلاَ یَشْہَدُہَا ، ثُمَّ تَکُونُ فَلاَ یَشْہَدُہَا ، ثُمَّ تَکُونُ فَلاَ یَشْہَدُہَا ، فَیَطْبَعُ اللَّہُ عَلَی قَلْبِہِ۔ (احمد 3/332۔ ابو یعلی 2198)",,,5581,,
5582,"حَدَّثَنَا الْفُضَیْلُ بْنُ دُکَیْنٍ ، عَنْ زُہَیْرٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الأَحْوَص ، سَمِعَہُ مِنْہُ ، عَنْ عَبْدِ اللہِ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ لِقَوْمٍ یَتَخَلَّفُونَ عَنِ الْجُمُعَۃِ : لَقَدْ ہَمَمْتُ أَنْ آمُرَ رَجُلاً یُصَلِّی بِالنَّاسِ، ثُمَّ أُحَرِّقَ عَلَی رِجَالٍ یَتَخَلَّفُونَ عَنِ الْجُمُعَۃِ بُیُوتَہُمْ۔",,,5582,,
5583,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : اخْتَلَفَ رَجُلٌ إِلَی ابْنِ عَبَّاسٍ شَہْرًا ، یَسْأَلُہُ عَنْ رَجُلٍ یَقُومُ اللَّیْلَ وَیَصُومُ النَّہَارَ ، وَلاَ یَشْہَدُ جَمَاعَۃً ، وَلاَ جُمُعَۃً ، قَالَ : فِی النَّارِ۔",,,5583,,
5584,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یَزِیدُ بْنُ أبی زِیَادٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، عَنِ الْبَرَائِ بْنِ عَازِبٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنَّ مِنَ الْحَقِّ عَلَی الْمُسْلِمِینَ أَنْ یَغْتَسِلَ أَحَدُہُمْ یَوْمَ الْجُمُعَۃِ ، وَأَنْ یَمَسَّ مِنْ طِیبٍ إِنْ کَانَ عِنْدَہُ ، فَإِنْ لَمْ یَکُنْ عِنْدَہُ طِیبٌ فَإِنَّ الْمَائَ لَہُ طِیبٌ۔",,,5584,,
5585,"حَدَّثَنَا عَبْدَۃُ، عَنْ عُثْمَانَ بْنِ حَکِیمٍ، عَنْ عُثْمَانَ بْنِ أَبِی سُلَیْمَانَ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ، قَالَ: إِنَّ مِنَ الْحَقِّ عَلَی الْمُسْلِمِ إِذَا کَانَ یَوْمُ الْجُمُعَۃِ، السِّوَاکَ، وَأَنْ یَلْبَسَ مِنْ صَالِحِ ثِیَابِہِ، وَأَنْ یَتَطَیَّبَ بِطِیبٍ إِنْ کَانَ۔",,,5585,,
5586,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حدَّثَنَا عُبَیْدُ اللہِ ، عَنْ نَافِعٍ ، قَالَ : کَانَ ابْنُ عُمَرَ إِذَا رَاحَ إِلَی الْجُمُعَۃِ اغْتَسَلَ، وَتَطَیَّبَ بِأَطْیَبِ طِیبٍ عِنْدَہُ۔",,,5586,,
5587,"حَدَّثَنَا ہُشَیْمٌ، عَنْ أَبِی بِشْرٍ، عَنْ مُجَاہِدٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: أَقُولُ بِرَأْیِی، وَیَمَسُّ طِیبًا إِنْ کَانَ عِنْدَہُ۔",,,5587,,
5588,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، وَالْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ مِسْعَرٍ ، عَنْ أَبِی بَکْرِ بْنِ عَمْرِو بْنِ عُتْبَۃَ ، عَنِ ابْنِ مُغَفَّلٍ ، قَالَ : لَہَا غُسْلٌ وَطِیبٌ إِنْ کَانَ۔",,,5588,,
5589,"حَدَّثَنَا عُبَیْدُ اللہِ ، عَنْ عُثْمَانَ ، عَنْ مُجَاہِدٍ ، قَالَ : اِلْبَسْ أَفْضَلَ ثِیَابِکَ یَوْمَ الْجُمُعَۃِ ، وَتَطَیَّبْ بِأَطْیَبِ مَا تَجِدُ۔",,,5589,,
5590,"حَدَّثَنَا وَکِیعٌ ، عَنْ شَدَّادٍ أَبِی طَلْحَۃَ ، عَنْ مُعَاوِیَۃَ بْنِ قُرَّۃٍ ، قَالَ : أَدْرَکْتُ ثَلاَثِینَ مِنْ مُزَیْنَۃَ کُلُّہُمْ قَدْ طَعَنَ ، أَوْ طُعِنَ ، أَوْ ضَرَبَ ، أَوْ ضُرِبَ ، إِذَا کَانَ یَوْمَ الْجُمُعَۃِ اغْتَسَلُوا ، وَلَبِسُوا مِنْ أَحْسَنِ ثِیَابِہِمْ ، وَتَطَیَّبُوا ، ثُمَّ رَاحُوا وَصَلَّوْا رَکْعَتَیْنِ ، ثُمَّ جَلَسُوا ، فَبَثَّوا عِلْمًا۔",,,5590,,
5591,حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ مُوسَی بْنِ عُقْبَۃَ، عَنْ نَافِعٍ؛ أَنَّ ابْنَ عُمَرَ کَانَ یُجَمِّرُ ثِیَابَہُ فِی کُلِّ جُمُعَۃٍ۔,,,5591,,
5592,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا الْحَجَّاجُ ، عَنْ أَبِی جَعْفَرٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَلْبَسُ بُرْدَہُ الأَحْمَر یَوْمَ الْجُمُعَۃِ ، وَیَعْتَمُّ یَوْمَ الْعِیدَیْنِ۔ (ابن سعد 451)",,,5592,,
5593,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ نَافِعٍ ، قَالَ : کَانَ ابْنُ عُمَرَ یَغْتَسِلُ لِلْجُمُعَۃِ کَاغْتِسَالِہِ مِنَ الْجَنَابَۃِ ، وَیَلْبَسُ مِنْ أَحْسَنِ ثِیَابِہِ ، ثُمَّ یَخْرُجُ حَتَّی یَأْتِیَ الْمُصَلَّی۔",,,5593,,
5594,"حَدَّثَنَا عُبَیْدُ اللہِ ، قَالَ : أَخْبَرَنَا إِسْرَائِیلُ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ ابْنِ أَبِی لَیْلَی ، قَالَ : أَدْرَکْتُ أَصْحَابَ مُحَمَّدٍ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، مِنْ أَصْحَابِ بَدْرٍ وَأَصْحَابِ الشَّجَرَۃِ ، إِذَا کَانَ یَوْمَ الْجُمُعَۃِ لَبِسُوا أَحْسَنَ ثِیَابِہِمْ ، وَإِنْ کَانَ عِنْدَہُمْ طِیبٌ مَسُّوا مِنْہُ ، ثُمَّ رَاحُوا إِلَی الْجُمُعَۃِ۔",,,5594,,
5595,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، عْن جَابِرِ بْنِ عَبْدِ اللہِ ، قَالَ: نَظَرَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إِلَی النَّاسِ یَوْمَ الْجُمُعَۃِ بَاذَّۃٌ ہَیْئَتُہُمْ ، فَقَالَ : مَا ضَرَّ رَجُلاً لَوِ اتَّخَذَ لِہَذَا الْیَوْمِ ثَوْبَیْنِ؟۔ (ابن ماجہ 1095۔ ابن خزیمۃ 1765)",,,5595,,
5596,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، عْن جَابِرٍ ، عَنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، مِثْلَہُ ، وَزَادَ فِیہِ : ثَوْبَیْنِ یَرُوحُ فِیہِمَا۔",,,5596,,
5597,"حَدَّثَنَا مَرْحُومُ بْنُ عَبْدِ الْعَزِیزِ ، أَنَّہُ سَمِعَ ثَابِتًا الْبُنَانِیَّ ، یَقُولُ : کُنْت مَعَ أَنَسِ بْنِ مَالِکٍ یَوْمَ جُمُعَۃٍ ، فَلَمَّا أَنْ سَمِعَ النِّدَائَ بِالصَّلاَۃِ ، قَالَ : قُمْ نَسْعَی۔",,,5597,,
5598,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : {فَاسْعَوْا إِلَی ذِکْرِ اللہِ} قَالَ : بِقَلْبِہِ۔",,,5598,,
5599,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی حَیَّانَ ، عَنْ عِکْرِمَۃَ ، قَالَ : السَّعْیُ الْعَمَلُ۔",,,5599,,
5600,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ مَنْصُورٍ، عَنْ رَجُلٍ، عَنْ مَسْرُوقٍ؛ {فَاسْعَوْا إِلَی ذِکْرِ اللہِ} قَالَ: الْوَقْتُ۔",,,5600,,
5601,"حَدَّثَنَا وَکِیعٌ، عَنْ مُوسَی بْنِ دِینَارٍ، عَنْ مُوسَی بْنِ أَبِی کَثِیرٍ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ: مَوْعِظَۃُ الإِمَامِ۔",,,5601,,
5602,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ مُحَمَّدِ بْنِ کَعْبٍ ، قَالَ : السَّعْیُ الْعَمَلُ۔",,,5602,,
5603,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ عَبَّادِ بْنِ رَاشِدٍ ، عَنِ الْحَسَنِ ؛ فِی قَوْلِہِ : (فَاسْعَوْا إِلَی ذِکْرِ اللہِ) قَالَ : أَمَا وَاللَّہِ مَا ہُوَ بِالسَّعْیِ عَلَی الأَقْدَامِ ، وَقَدْ نُہُوا أَنْ یَأْتُوا الصَّلاَۃَ إِلاَّ وَعَلَیْہِمُ السَّکِینَۃُ وَالْوَقَارُ ، وَلَکِنْ بِالْقُلُوبِ ، وَالنِّیَاتِ، وَالْخُشُوعِ۔ (بخاری 635۔ مسلم 155)",,,5603,,
5604,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانَ عَبْدُ اللہِ یَقْرَؤُہَا : (فَامْضُوا إِلَی ذِکْرِ اللہِ) وَیَقُولُ : لَوْ قَرَأْتُہَا : (فَاسْعَوْا) لَسَعَیْتُ حَتَّی یَسْقُطَ رِدَائِی۔",,,5604,,
5605,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، عَن خَرَشَۃَ ، قَالَ : قرَأَہَا عُمَرُ بْنُ الْخَطَّابِ : {فَامْضُوا إلَی ذِکْرِ اللہِ}۔",,,5605,,
5606,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ ، فِی قَوْلِہِ : {فَإِذَا قُضِیَتِ الصَّلاَۃُ فَانْتَشِرُوا فِی الأَرْضِ وَابْتَغُوا مِنْ فَضْلِ اللہِ} قَالَ : ہُوَ إِذْنٌ مِنَ اللہِ ، فَإِذَا فَرَغَ فَإِنْ شَائَ خَرَجَ ، وَإِنْ شَائَ قَعَدَ فِی الْمَسْجِدِ۔",,,5606,,
5607,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ (ح) وَعَنِ الْقَاسِمِ ، عَنْ مُجَاہِدٍ ؛ (فَإِذَا قُضِیَتِ الصَّلاَۃُ فَانْتَشِرُوا فِی الأَرْضِ) قَالاَ : إِنْ شَائَ فَعَلَ ، وَإِنْ شَائَ لَمْ یَفْعَلْ۔",,,5607,,
5608,حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی جَنَابٍ ، عَنْ یَزِیدَ بْنِ الْبَرَائِ ، عَنْ أَبِیہِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ خَطَبَہُمْ یَوْمَ عِیدٍ ، وَفِی یَدِہِ قَوْسٌ ، أَوْ عَصًا۔ (عبدالرزاق 5658۔ احمد 282),,,5608,,
5609,"حَدَّثَنَا وَکِیعٌ ، عَنْ طَلْحَۃَ بْنِ یَحْیَی ، قَالَ : رَأَیْتُ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ یَخْطُبُ وَبِیَدِہِ قَضِیبٌ۔",,,5609,,
5610,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ وَاصِلٍ ، عَنْ أَبِی وَائِلٍ ؛ أَنَّ کَعْبًا رَأَی جَرِیرًا وَفِی یَدِہِ قَضِیبٌ ، فَقَالَ : إِنَّ ہَذَا لاَ یَصْلُحُ إِلاَّ لِرَاعٍ ، أَوْ وَالٍ۔",,,5610,,
5611,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہَمَّامٍ ، قَالَ : سَمِعْتُ قَتَادَۃَ یَقُولُ فِی رَجُلٍ افْتَتَحَ مَعَ الإِمَامِ یَوْمَ الْجُمُعَۃِ فَلَمْ یَقْدِرْ عَلَی رُکُوعٍ ، وَلاَ سُجُودٍ حَتَّی صَلَّی الإِمَامُ ، قَالَ : کَانَ الْحَسَن وَإِبْرَاہِیمُ یَقُولاَنِ : یُصَلِّی رَکْعَتَیْنِ ۔ یَعْنِی یَوْمَ الْجُمُعَۃِ۔",,,5611,,
5612,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، قَالَ : سُئِلَ عَنْ رَجُلٍ رَکَعَ رَکْعَتَیْنِ یَوْمَ الْجُمُعَۃِ ، فَلَمْ یَقْدِرْ عَلَی السُّجُودِ حَتَّی سَلَّمَ الإِمَامُ ؟ فَقَالَ : نُبِّئْتُ عَنِ الْحَسَنِ أَنَّہُ قَالَ : یَسْجُدُ سَجْدَتَیْنِ ، ثُمَّ یَقُومُ فَیَقْضِی الرَّکْعَۃَ الأُولَی۔",,,5612,,
5613,"حَدَّثَنَا أَزْہَرُ السَّمَّانُ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : قَالَ رَجُلٌ لِنَافِعٍ : زُحِمْتُ یَوْمَ الْجُمُعَۃِ ، فَلَمْ أَقْدِرْ عَلَی الرُّکُوعِ وَالسُّجُودِ ، فَقَالَ : أَمَّا أَنَا فَلَوْ کُنْتُ لأَوْمَأْتُ۔",,,5613,,
5614,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللہِ ، عَنْ مِعْقَلٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : إِذَا ازْدَحَمَ النَّاسُ فِی الْجُمُعَۃِ فَلَمْ تَسْتَطِعْ أَنْ تَسْجُدَ ، فَانْتَظِرْ حَتَّی إِذَا قَامُوا فَاسْجُدْ۔",,,5614,,
5615,"حَدَّثَنَا حَفْصٌ، عَنْ أَشْعَثَ، عَنِ الْحَکَمِ، وَحَمَّادٍ، عَنْ إِبْرَاہِیمَ، قَالَ: یُنَقِّی الرَّجُلُ أَظْفَارَہُ فِی کُلِّ جُمُعَۃٍ۔",,,5615,,
5616,"حَدَّثَنَا مُعَاذٌ ، عَنِ الْمَسْعُودِیِّ ، عَنِ ابْنِ حُمَیْدِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِیہِ ؛ أَنَّہُ قَالَ فِیمَنْ قَلَّمَ أَظْفَارَہُ یَوْمَ الْجُمُعَۃِ : أَخْرَجَ اللَّہُ مِنْہَا الدَّائَ ، وَأَدْخَلَ فِیہَا الشِّفَائَ۔",,,5616,,
5617,حَدَّثَنَا وَکِیعٌ ، عَنْ مُبَارَکٍ ، عَنْ عَبْدِ اللہِ بْنِ مُسْلِمِ بْنِ یَسَارٍ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یَدْعُو بِالْقَلَمَیْنِ یَوْمَ الْجُمُعَۃِ ، یَعْنِی الْمِقَصَّیْنِ۔,,,5617,,
5618,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، قَالَ : حدَّثَنَا مِنْدَلٌ ، عَنْ عِمْرَانَ بْنِ أَبِی عَطَائٍ ، قَالَ : رَأَیْتُ ابْنَ الْحَنَفِیَّۃِ یُنَقِّی أَظْفَارَہُ فِی یَوْمِ جُمُعَۃٍ۔",,,5618,,
5619,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ أَبِی الْہَیْثُمِ ، قَالَ : رَأَیْتُ سَعِیدَ بْنَ جُبَیْرٍ یُنَقِّی أَظْفَارَہُ فِی الصَّلاَۃِ۔",,,5619,,
5620,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ : لاَ بَأْسَ بِالشُّرْبِ وَالإِمَامُ یَخْطُبُ۔",,,5620,,
5621,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ حَجَّاجٍ ، عَنْ عَوْنٍ ، عَنْ أَسْمَائَ ، قَالَتْ : مَنْ قَرَأَ : {قُلْ ہُوَ اللَّہُ أَحَدٌ} وَالْمُعَوِّذَتَیْنِ یَوْمَ الْجُمُعَۃِ سَبْعَ مَرَّاتٍ فِی مَجْلِسِہِ ، حُفِظَ إِلَی مِثْلِہَا۔",,,5621,,
5622,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا عَبْدُ الْوَاحِدِ ، قَالَ : حَدَّثَنَا یُونُسُ ، قَالَ : کَانَ الْحَسَنُ یُحَصِّبُ الْمَسَاکِینَ یَوْمَ الْجُمُعَۃِ وَالإِمَامُ یَخْطُبُ ، یَقُولُ لَہُمْ : اُقْعُدُوا ۔ قَالَ : وَکَانَ عِکْرِمَۃُ لاَ یَرَی لَہُمْ جُمُعَۃً۔",,,5622,,
5623,"حَدَّثَنَا جَرِیرٌ ، عَنْ سنان بْنِ حَبِیبٍ ، قَالَ : قُلْتُ لإِبْرَاہِیمَ : فَاتَتْنِی الْجُمُعَۃُ ؟ قَالَ : أَکْثِرْ مِنَ السُّجُودِ۔",,,5623,,
5624,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ رَجُلٍ ، عَنِ ابْنِ سِیرِینَ ؛ فِی أَہْلِ السُّجُونِ ، قَالَ: تَجَمَّعُوا لِلصَّلاَۃِ یَوْمَ الْجُمُعَۃِ۔",,,5624,,
5625,"حَدَّثَنَا شَیْخٌ لَنَا ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لَیْسَ عَلَی أَہْلِ السُّجُونِ جُمُعَۃٌ۔",,,5625,,
5626,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا یَزِیدُ بْنُ إِبْرَاہِیمَ ؛ سُئِلَ الْحَسَنُ عَنْ رَجُلٍ أَحْدَثَ یَوْمَ الْجُمُعَۃِ ، فَذَہَبَ لِیَتَوَضَّأَ ، فَجَائَ وَقَدْ صَلَّی الإِمَام ؟ قَالَ : یُصَلِّی أَرْبَعًا۔",,,5626,,
5627,"حَدَّثَنَا وَکِیعٌ ، قَالَ : سَأَلْتُ سُفْیَانَ عَنْ رَجُلٍ افْتَتَحَ مَعَ الإِمَامِ الصَّلاَۃَ یَوْمَ الْجُمُعَۃِ ، فَذَہَبَ لِیَتَوَضَّأَ ، فَجَائَ وَقَدْ صَلَّی الإِمَامُ ؟ قَالَ : یُصَلِّی رَکْعَتَیْنِ مَا لَمْ یَتَکَلَّمْ۔",,,5627,,
5628,"حَدَّثَنَا ہُشَیْمُ بْنُ بَشِیرٍ ، قَالَ : أَخْبَرَنَا مُحَمَّدُ بْنُ إِسْحَاقَ ، عَنْ حَفْصِ بْنِ عُبَیْدِ اللہِ بْنِ أَنَسٍ ، عَنْ أَنَسٍ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُفْطِرُ یَوْمَ الْفِطْرِ عَلَی تَمَرَاتٍ ، ثُمَّ یَغْدُو۔ (ترمذی 543۔ ابن ماجہ 1754)",,,5628,,
5629,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنِ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : اِطْعَمْ یَوْمَ الْفِطْرِ قَبْلَ أَنْ تَخْرُجَ إِلَی الْمُصَلَّی۔",,,5629,,
5630,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إِنَّ مِنَ السُّنَّۃِ أَنْ تُخْرِجَ صَدَقَۃَ الْفِطْرِ قَبْلَ الصَّلاَۃ ، وَلاَ تَخْرُجُ حَتَّی تَطْعَمَ۔ (طبرانی 11296۔ بزار 651)",,,5630,,
5631,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حُصَیْنٌ ، قَالَ : غَدَوْتُ مَعَ مُعَاوِیَۃَ بْنِ سُوَیْد بْنِ مُقَرِّنٍ یَوْمَ فِطْرٍ ، فَقُلْت لَہُ : یَا أَبَا سُوَیْد ، ہَلْ طَعِمْتَ شَیْئًا قَبْلَ أَنْ تَغْدُوَ ؟ قَالَ : لَعِقْتُ لَعْقَۃً مِنْ عَسَلٍ۔",,,5631,,
5632,حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنِ ابْنِ مَعْقِلٍ ؛ أَنَّہُ لَعِقَ لَعْقَۃً مِنْ عَسَلٍ ، ثُمَّ خَرَجَ۔,,,5632,,
5633,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، قَالَ : اِطْعَمْ یَوْمَ الْفِطْرِ قَبْلَ أَنْ تَخْرُجَ۔",,,5633,,
5634,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یَحْیَی بْنِ أَبِی إِسْحَاقَ ، قَالَ : أَتَیْتُ صَفْوَانَ بْنَ مُحْرِزٍ یَوْمَ فِطْرٍ ، فَقَعَدْت بِبَابِہِ حَتَّی خَرَجَ عَلَیَّ ، فَقَالَ لِی کَالْمُعْتَذِرِ : إِنَّہُ کَانَ یُؤْمَرُ فِی ہَذَا الْیَوْمِ أَنْ یُصِیبَ الرَّجُلُ مِنْ غِذَائِہِ قَبْلَ أَنْ یَغْدُوَ ، وَإِنِّی أَصَبْتُ شَیْئًا ، فَذَاکَ الَّذِی حَبَسَنِی ، وَأَمَّا الأَخَرُ فَإِنَّہُ یُؤَخِّرُ غِذَائَہُ حَتَّی یَرْجِعَ۔",,,5634,,
5635,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَانَ ابْنُ سِیرِینَ یُؤْتَی فِی الْعِیدَیْنِ بِفَالُوذَجٍ ، فَکَانَ یَأْکُلُ مِنْہُ قَبْلَ أَنْ یَغْدُوَ ۔ وَقَالَ : ابْنُ عَوْنٍ أَنَّہُ یُمْسِکُ الْبَوْلَ۔",,,5635,,
5636,حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ عَبْدِ اللہِ بْنِ شَدَّادٍ ؛ أَنَّہُ مَرَّ عَلَی بَقَّالٍ یَوْمَ عِیدٍ ، فَأَخَذَ مِنْہُ قَسْبَۃً فَأَکَلَہَا۔,,,5636,,
5637,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : حَدَّثَنَا الْمُغِیرَۃُ ، عَنِ الشَّعْبِیِّ ، قَالَ : إِنَّ مِنَ السُّنَّۃِ أَنْ تَطْعَمَ یَوْمَ الْفِطْرِ قَبْلَ أَنْ تَغْدُوَ، وَتُؤَخِّرَ الطَّعَامَ یَوْمَ النَّحْرِ حَتَّی تَرْجِعَ۔",,,5637,,
5638,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ إِبْرَاہِیمَ بْنِ عَبْدِ الأَعْلَی ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ ، قَالَ : کَانَ الأَسْوَدُ یَأْمُرنَا أَنْ نَطْعَمَ قَبْلَ أَنْ نَغْدُوَ یَوْمَ الْفِطْرِ۔",,,5638,,
5639,"حَدَّثَنَا وَکِیعٌ ، عَنْ مَسَرَّۃَ بْنِ مَعْبَدٍ ، عَنْ إِبْرَاہِیمَ بْنِ أَبِی عَبْلَۃَ ، عَنْ أُمِّ الدَّرْدَائِ ، قَالَتْ : کُلْ قَبْلَ أَنْ تَغْدُوَ یَوْمَ الْفِطْرِ ، وَلَوْ تَمْرَۃً۔",,,5639,,
5640,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، قَالَ : حدَّثَنَا ابْنُ أَبِی ذِئْبٍ ، عَنْ یُوسُفَ ، عَنِ السَّائِبِ بْنِ یَزِیدَ ، قَالَ : مَضَتِ السُّنَّۃُ أَنْ تَأْکُلَ قَبْلَ أَنْ تَغْدُوَ یَوْمَ الْفِطْرِ۔",,,5640,,
5641,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إِدْرِیسَ ، عَنِ الأَعْمَشِ ، عَنِ الْمِنْہَالِ ، عَنْ عَبْدِ اللہِ بْنِ الْحَارِثِ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إِذَا خَرَجْتَ یَوْمَ الْعِیدِ ، یَعْنِی الْفِطْرَ ، فَکُلْ وَلَوْ تَمْرَۃً۔",,,5641,,
5642,"حَدَّثَنَا أَبُو عَامِرٍ الْعَقَدِیُّ ، عَنِ الزُّبَیْرِ بْنِ عَبْدِ اللہِ بْنِ رُہَیْمَۃَ ، قَالَ : سَمِعْتُ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ یَوْمَ الْفِطْرِ یَخْطُبُ ، فَقَالَ : إِنَّ ہَذَا یَوْمٌ قَدْ کَانَ یُبْتَغَی فِیہِ بَعْضُ الطَّعَامِ وَبَعْضُ الشَّرَابِ ، فَبَعْضُ الطَّعَامِ وَبَعْضُ الشَّرَابِ۔",,,5642,,
5643,"حَدَّثَنَا یَحْیَی بْنُ یَعْلَی ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنْ مُجَاہِدٍ ، أَنَّہُ قَالَ : اِطْعَمْ یَوْمَ الْفِطْرِ قَبْلَ أَنْ تَخْرُجَ۔",,,5643,,
5644,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : بَلَغَہُ أَنْ تَمِیمَ بْنَ سَلَمَۃَ خَرَجَ یَوْمَ الْفِطْرِ وَمَعَہُ صَاحِبٌ لَہُ ، فَقَالَ لِصَاحِبِہِ : ہَلْ طَعِمْتَ شَیْئًا ؟ قَالَ : لاَ ، فَمَشَی تَمِیمٌ إِلَی بَقَّالٍ فَسَأَلَہُ تَمْرَۃً أَنْ یُعْطِیَہُ ، أَوْ غَیْرَ ذَلِکَ فَفَعَلَ ، فَأَعْطَاہُ صَاحِبَہُ فَأَکَلَہُ ۔ فَقَالَ إِبْرَاہِیمُ : مَمْشَاہُ إِلَی رَجُلٍ یَسْأَلُہُ ، أَشَدُّ عَلَیْہِ مِنْ تَرْکِہِ الطَّعَامَ لَوْ تَرَکَہُ۔",,,5644,,
5645,"حَدَّثَنَا وَکِیعٌ ، عَنْ عِمْرَانَ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ : أَصَبْتَ شَیْئًا قَبْلَ أَنْ تَغْدُوَ ؟۔",,,5645,,
5646,"حَدَّثَنَا شَبَابَۃُ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنِ ابْنِ إِسْحَاقَ ، عَنْ رَجُلٍ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ أَنَّہُ کَانَ یَأْمُرُ بِالأَکْلِ یَوْمَ الْفِطْرِ قَبْلَ أَنْ یَأْتِیَ الْمُصَلَّی۔",,,5646,,
5647,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، قَالَ : أَخْبَرَنِی مَالِکٌ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : کَانُوا یُؤْمَرُونَ أَنْ یَأْکُلُوا قَبْلَ أَنْ یَغْدُوا یَوْمَ الْفِطْرِ۔",,,5647,,
5648,"حَدَّثَنَا أَحْمَدُ بْنُ عَبْدِ الْمَلِکِ بْنِ وَاقِدٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عَمْرٍو ، عَنْ عَبْدِ اللہِ بْنِ مُحَمَّدِ بْنِ عَقِیلٍ ، عَنْ عَطَائِ بْنِ یَسَارٍ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَأْکُلُ یَوْمَ الْفِطْرِ قَبْلَ أَنْ یَخْرُجَ إِلَی الْمُصَلَّی۔ (احمد 3/28۔ عبدالرزاق 5735)",,,5648,,
5649,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا عُبَیْدُ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَخْرُجُ یَوْمَ الْعِیدِ إِلَی الْمُصَلَّی ، وَلاَ یَطْعَمُ شَیْئًا۔",,,5649,,
5650,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِنْ طَعِمَ فَحَسَنٌ ، وَإِنْ لَمْ یَطْعَمْ فَلاَ بَأْسَ۔",,,5650,,
5651,"حَدَّثَنَا وَکِیعٌ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، قَالَ : کَتَبَ إِلَیْنَا عُمَرُ بْنُ عَبْدِ الْعَزِیزِ : مَنِ اسْتَطَاعَ مِنْکُمْ أَنْ یَأْتِیَ الْعِیدَ مَاشِیًا فَلْیَفْعَلْ۔",,,5651,,
5652,"حَدَّثَنَا شَرِیکٌ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : مِنَ السُّنَّۃِ أَنْ تَأْتِیَ الْعِیدَ مَاشِیًا۔ (ترمذی 530۔ ابن ماجہ 1296)",,,5652,,
5653,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ مِسْعَرٍ ، عَنْ عَاصِمٍ ، عَنْ زِرٍّ ، قَالَ : خَرَجَ عُمَرُ بْنُ الْخَطَّابِ فِی یَوْمِ فِطْرٍ ، أَوْ فِی یَوْمِ أَضْحَی ، خَرَجَ فِی ثَوْبِ قُطْنٍ مُتَلَبِّبًا بِہِ ، یَمْشِی۔",,,5653,,
5654,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ الْمُہَاجِرِ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّہُ کَرِہَ الرُّکُوبَ إِلَی الْعِیدَیْنِ وَالْجُمُعَۃِ۔,,,5654,,
5655,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُحَمَّدِ بْنِ أَبِی حَفْصَۃَ ، قَالَ : رَأَیْتُ الْحَسَنَ یَأْتِی الْعِیدَ رَاکِبًا۔",,,5655,,
5656,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، قَالَ : کَانَ ابْنُ عُمَرَ یُصَلِّی الصُّبْحَ فِی مَسْجِدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، ثُمَّ یَغْدُو کَمَا ہُوَ إِلَی الْمُصَلَّی۔",,,5656,,
5657,حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِیلَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ حَرْمَلَۃَ ؛ أَنَّہُ کَانَ یَنْصَرِفُ مَعَ سَعِیدِ بْنِ الْمُسَیَّبِ مِنَ الصُّبْحِ حِینَ یُسَلِّمُ الإِمَامُ فِی یَوْمِ عِیدٍ ، حَتَّی یَأْتِیَ الْمُصَلَّی عِنْدَ دَارِ کَثِیرِ بْنِ الصَّلْتِ ، فَیَجْلِسُ عِنْدَ الْمِصْرَاعَیْنِ۔,,,5657,,
5658,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، قَالَ : صَلَّیْتُ الْفَجْرَ فِی ہَذَا الْمَسْجِدِ فِی یَوْمِ فِطْرٍ ، فَإِذَا أَبُو عَبْدِ الرَّحْمَنِ ، وَعَبْدُ اللہِ بْنُ مَعْقِلٍ ، فَلَمَّا قَضَیَا الصَّلاَۃَ خَرَجَا ، وَخَرَجْتُ مَعَہُمَا إِلَی الْجَبَّانَۃِ۔",,,5658,,
5659,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سُفْیَانَ ، عَنْ عُبَیْدٍ الْمُکَتَّبِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانُوا یُصَلُّونَ الْفَجْرَ وَعَلَیْہِمْ ثِیَابُہُمْ ، یَعْنِی یَوْمَ الْعِیدِ۔",,,5659,,
5660,"حَدَّثَنَا وَکِیعٌ ، عَنْ عِمْرَانَ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ : لِیَکُنْ غَدْوُک یَوْمَ الْفِطْرِ مِنْ مَسْجِدِکَ إِلَی مُصَلاَّک۔",,,5660,,
5661,"حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِیلَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، قَالَ : کَانَ عُرْوَۃُ لاَ یَأْتِی الْعِیدَ حَتَّی تَسْتَقِلَّ الشَّمْسُ۔",,,5661,,
5662,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ مُحَمَّدِ بْنِ عَلِیٍّ ، وَعَامِرٍ ، وَعَطَائٍ ، قَالُوا : لاَ تَخْرُجُ یَوْمَ الْعِیدِ حَتَّی تَطْلُعَ الشَّمْسُ۔",,,5662,,
5663,"حَدَّثَنَا شَبَابَۃُ ، قَالَ : حدَّثَنَا ابْنُ أَبِی ذِئْبٍ ، عَنْ عِیسَی بْنِ سَہْلِ بْنِ رَافِعِ بْنِ خَدِیجٍ ؛ أَنَّہُ رَأَی جَدَّہُ رَافِعَ بْنَ خَدِیجٍ وَبَنِیہِ یَجْلِسُونَ فِی الْمَسْجِدِ ، حَتَّی إِذَا طَلَعَتِ الشَّمْسُ صَلَّوْا رَکْعَتَیْنِ ، ثُمَّ یَذْہَبُونَ إِلَی الْمُصَلَّی ، وَذَلِکَ فِی الْفِطْرِ وَالأَضْحَی۔",,,5663,,
5664,"حَدَّثَنَا شَرِیکٌ ، عَنْ مَنْصُورٍ ، قَالَ : غَدَوْت إِلَی إِبْرَاہِیمَ یَوْمَ عِیدٍ ، فَوَجَدْتُہُ قَدْ صَلَّی وَعَلَیْہِ ثِیَابُہُ۔",,,5664,,
5665,حَدَّثَنَا عَبْدُ اللہِ بْنُ إِدْرِیسَ ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَغْدُو یَوْمَ الْعِیدِ، وَیُکَبِّرُ ، وَیَرْفَعُ صَوْتَہُ حَتَّی یَبْلُغَ الإِمَامُ۔,,,5665,,
5666,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إِدْرِیسَ ، عَنْ یَحْیَی بْنِ عَبْدِ اللہِ بْنِ أَبِی قَتَادَۃَ ، قَالَ : أُرَاہُ عَنْ مُحَمَّدِ بْنِ إِبْرَاہِیمَ ؛ أَنَّ أَبَا قَتَادَۃَ کَانَ یُکَبِّرُ یَوْمَ الْعِیدِ وَیَذْکُرُ اللَّہَ۔",,,5666,,
5667,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَخْرُجُ یَوْمَ الْفِطْرِ فَیُکَبِّرُ حَتَّی یَأْتِیَ الْمُصَلَّی ، وَحَتَّی یَقْضِیَ الصَّلاَۃَ ، فَإِذَا قَضَی الصَّلاَۃَ قَطَعَ التَّکْبِیرَ۔ (دارقطنی 6۔ بیہقی 279),,,5667,,
5668,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، قَالَ : خَرَجْتُ مَعَ أَبِی عَبْدِ الرَّحْمَنِ ، وَابْنِ مَعْقِلٍ ، فَکَانَ أَبُو عَبْدِ الرَّحْمَنِ یُکَبِّرُ ، یَرْفَعُ صَوْتَہُ بِالتَّکْبِیرِ ، وَکَانَ ابْنُ مَعْقِلٍ یَقُولُ : لاَ إِلَہَ إِلاَّ اللَّہُ وَحْدَہُ لاَ شَرِیکَ لَہُ ، لَہُ الْمُلْکُ وَلَہُ الْحَمْدُ ، وَہُوَ عَلَی کُلِّ شَیْئٍ قَدِیرٌ۔",,,5668,,
5669,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، قَالَ : خَرَجْتُ مَعَ سَعِیدِ بْنِ جُبَیْرٍ ، وَعَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی فَلَمْ یَزَالاَ یُکَبِّرَانِ ، وَیَأْمُرَانِ مَنْ مَرَّا بِہِ بِالتَّکْبِیرِ۔",,,5669,,
5670,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنِ الأَعْمَشِ ، قَالَ : کُنْتُ أَخْرُجُ مَعَ أَصْحَابِنَا ؛ إِبْرَاہِیمَ وَخَیْثَمَۃَ ، وَأَبِی صَالِحٍ یَوْمَ الْعِیدِ فَلاَ یُکَبِّرُونَ۔",,,5670,,
5671,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مُحَمَّدٍ الْمُحَارِبِیُّ ، عَنْ حَجَّاجٍ ، قَالَ : حدَّثَنِی رَجُلٌ مِنَ الْمُسْلِمِینَ ، عَنْ حَنَشٍ أَبِی الْمُعْتَمِرِ ؛ أَنَّ عَلِیًّا یَوْمَ أَضْحَی کَبَّرَ حَتَّی انْتَہَی إِلَی الْعِیدِ۔",,,5671,,
5672,"حَدَّثَنَا الْمُحَارِبِیُّ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : إِنَّ مِنَ السُّنَّۃِ أَنْ یُکَبِّرَ یَوْمَ الْعِیدِ۔",,,5672,,
5673,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ شُعْبَۃَ ، قَالَ : قُلْتُ لِلْحَکَمِ ، وَحَمَّادٍ : أُکَبِّرُ إِذَا خَرَجْتُ إِلَی الْعِیدِ ؟ قَالاَ : نَعَمْ۔",,,5673,,
5674,حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، وَأَبُو مُعَاوِیَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ؛ أَنَّ أَبَاہُ کَانَ یُکَبِّرُ یَوْمَ الْعِیدِ۔,,,5674,,
5675,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : کَانَ النَّاسُ یُکَبِّرُونَ فِی الْعِیدِ ، حِینَ یَخْرُجُونَ مِنْ مَنَازِلِہِمْ حَتَّی یَأْتُوا الْمُصَلَّی ، وَحَتَّی یَخْرُجَ الإِمَامُ ، فَإِذَا خَرَجَ الإِمَامُ سَکَتُوا ، فَإِذَا کَبَّرَ کَبَّرُوا۔",,,5675,,
5676,"حَدَّثَنَا یَزِیدُ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنْ شُعْبَۃَ ، قَالَ : کُنْتُ أَقُودُ ابْنَ عَبَّاسٍ یَوْمَ الْعِیدِ ، فَسَمِعَ النَّاسَ یُکَبِّرُونَ ، فَقَالَ : مَا شَأْنُ النَّاسِ ؟ قُلْتُ : یُکَبِّرُونَ ، قَالَ : یُکَبِّرُونَ ؟ قَالَ : یُکَبِّرُ الإِمَامُ ؟ قُلْتُ : لاَ ، قَالَ : أَمَجَانِینُ النَّاسُ ؟۔",,,5676,,
5677,حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ عَاصِمٍ ، عَنْ شَقِیقٍ ، عَنْ عَلِیٍّ (ح) وَعَنْ عَبْدِ الأَعْلَی ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ، عَنْ عَلِیٍّ ؛ أَنَّہُ کَانَ یُکَبِّرُ بَعْدَ صَلاَۃِ الْفَجْرِ یَوْمَ عَرَفَۃَ إِلَی صَلاَۃِ الْعَصْرِ مِنْ آخِرِ أَیَّامِ التَّشْرِیقِ، وَیُکَبِّرُ بَعْدَ الْعَصْرِ۔,,,5677,,
5678,حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی جُنَابٍ ، عَنْ عُمَیْرِ بْنِ سَعِیدٍ ، عَنْ عَلِیٍّ ؛ أَنَّہُ کَانَ یُکَبِّرُ مِنْ صَلاَۃِ الْفَجْرِ یَوْمَ عَرَفَۃَ إِلَی صَلاَۃِ الْعَصْرِ مِنْ آخِرِ أَیَّامِ التَّشْرِیقِ۔,,,5678,,
5679,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الأَسْوَدِ ، قَالَ : کَانَ عَبْدُ اللہِ یُکَبِّرُ مِنْ صَلاَۃِ الْفَجْرِ یَوْمَ عَرَفَۃَ إِلَی صَلاَۃِ الْعَصْرِ مِنْ یوم النَّحْرِ ، یَقُولُ : اللَّہُ أَکْبَرُ اللَّہُ أَکْبَرُ اللَّہُ أَکْبَرُ لاَ إلَہَ إِلاَّ اللَّہُ ، وَاللَّہُ أَکْبَرُ اللَّہُ أَکْبَرُ وَلِلَّہِ الْحَمْدُ۔",,,5679,,
5680,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ غَیْلاَنَ بْنِ جَامِعٍ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ أَبِی وَائِلٍ ، عَنْ عَبْدِ اللہِ ؛ أَنَّہُ کَانَ یُکَبِّرُ مِنْ صَلاَۃِ الْفَجْرِ یَوْمَ عَرَفَۃَ إِلَی صَلاَۃِ الْعَصْرِ مِنْ یَوْمِ النَّحْرِ۔,,,5680,,
5681,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ أَبِی عَوَانَۃَ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، عَنْ عُبَیْدِ بْنِ عُمَیْرٍ ، عَنْ عُمَرَ ؛ أَنَّہُ کَانَ یُکَبِّرُ مِنْ صَلاَۃِ الْغَدَاۃِ یَوْمَ عَرَفَۃَ إِلَی صَلاَۃِ الظُّہْرِ مِنْ آخِرِ أَیَّامِ التَّشْرِیقِ۔,,,5681,,
5682,"حَدَّثَنَا زَیدُ بْنُ الْحُبَابِ ، قَالَ : أَخْبَرَنَا أَبُو عَوَانَۃَ ، عَنْ عَبْدِ الْحَمِیدِ بْنِ أبی رِبَاحٍ الشَّامِیِّ ، عَنْ رَجُلٍ مِنْ أَہْلِ الشَّامِ ، عَنْ زَیْدِ بْنِ ثَابِتٍ ؛ أَنَّہُ کَانَ یُکَبِّرُ مِنْ صَلاَۃِ الظُّہْرِ یَوْمَ النَّحْرِ إِلَی آخِرِ أَیَّامِ التَّشْرِیقِ ، یُکَبِّرُ فِی الْعَصْرِ۔",,,5682,,
5683,"حَدَّثَنَا عَفَّانُ، قَالَ: حدَّثَنَا أَبُو عَوَانَۃَ، عَنْ عَبْدِ الْحَمِیدِ بْنِ أَبِی رِبَاحٍ، قَالَ: حَدَّثَنِی رَجُلٌ مِنْ أَہْلِ الشَّامِ، عَنْ زَیْدِ بْنِ ثَابِتٍ؛ أَنَّہُ کَانَ یُکَبِّرُ مِنْ صَلاَۃِ الظُّہْرِ مِنْ یَوْمِ النَّحْرِ إِلَی صَلاَۃِ الْعَصْرِ مِنْ آخِرِ أَیَّامِ التَّشْرِیقِ۔",,,5683,,
5684,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ حُمَیْدٍ ، قَالَ : کَانَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ یُکَبِّرُ تَکْبِیرَ الْعِیدِ مِنْ صَلاَۃِ الظُّہْرِ یَوْمَ النَّحْرِ إِلَی آخِرِ أَیَّامِ التَّشْرِیقِ۔",,,5684,,
5685,حَدَّثَنَا وَکِیعٌ ، عَنْ شَرِیکٍ ، عَنْ خُصَیْفٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ کَانَ یُکَبِّرُ مِنْ صَلاَۃِ الظُّہْرِ یَوْمَ النَّحْرِ إِلَی صَلاَۃِ الْعَصْرِ مِنْ آخِرِ أَیَّامِ التَّشْرِیقِ۔,,,5685,,
5686,حَدَّثَنَا وَکِیعٌ ، عَنِ الْعُمَرِیِّ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یُکَبِّرُ مِنْ صَلاَۃِ الظُّہْرِ یَوْمَ النَّحْرِ إِلَی صَلاَۃِ الْعَصْرِ مِنْ یَوْمِ النَّفْرِ ، یَعْنِی الأَوَّلَ۔,,,5686,,
5687,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : یُکَبِّرُ مِنْ صَلاَۃِ الظُّہْرِ یَوْمَ النَّحْرِ إِلَی آخِرِ أَیَّامِ التَّشْرِیقِ۔",,,5687,,
5688,"حَدَّثَنَا مَالِکُ بْنُ إِسْمَاعِیلَ ، قَالَ : حدَّثَنَا زُہَیْرٌ ، قَالَ : حَدَّثَنَا طَارِقٌ ؛ أَنَّہُ حَفِظَ مِنْ قَیْسِ بْنِ أَبِی حَازِمٍ تَکْبِیرَ أَیَّامِ التَّشْرِیقِ حَتَّی صَلَّی الْعَصْرَ ، یُکَبِّرُ بَعْدَہَا۔",,,5688,,
5689,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ عَاصِمٍ ؛ أَنَّ أَبَا وَائِلٍ کَانَ یُکَبِّرُ مِنْ یَوْمِ عَرَفَۃَ مِنْ صَلاَۃِ الصُّبْحِ إِِلَی صَلاَۃِ الظُّہْرِ ، یَعْنِی مِنْ یَوْمِ النَّحْرِ۔,,,5689,,
5690,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ؛ أَنَّہُ کَانَ یُکَبِّرُ فی أَیَّامَ التَّشْرِیقِ ، فی صَلاَۃِ الظُّہْرِ یَوْمِ عَرَفَۃَ إِلَی صَلاَۃِ الفَجْر مِنْ آخِرِ أَیَّامِ التَّشْرِیقِ۔,,,5690,,
5691,حَدَّثَنَا جَعْفَرُ بْنُ عَوْنٍ ، عَنْ سَلَمَۃَ بْنِ نُبَیْطٍ ، عَنِ الضَّحَّاکِ ؛ أَنَّہُ کَانَ یُکَبِّرُ مِنْ صَلاَۃِ الْفَجْرِ یَوْمَ عَرَفَۃَ إِلَی صَلاَۃِ الْعَصْرِ مِنْ آخِرِ أَیَّامِ التَّشْرِیقِ۔,,,5691,,
5692,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ الْقَطَّانُ ، عَنْ أَبِی بَکَّارٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ کَانَ یُکَبِّرُ مِنْ صَلاَۃِ الْفَجْرِ یَوْمَ عَرَفَۃَ إِلَی آخِرِ أَیَّامِ التَّشْرِیقِ ، لاَ یُکَبِّرُ فِی الْمَغْرِبِ : اللَّہُ أَکْبَرُ کَبِیرًا اللَّہُ أَکْبَرُ کَبِیرًا ، اللَّہُ أَکْبَرُ وَأَجَلُّ ، اللَّہُ أَکْبَرُ وَلِلَّہِ الْحَمْدُ۔",,,5692,,
5693,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا ابْنُ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُکَبِّرُ مِنْ صَلاَۃِ الظُّہْرِ یَوْمَ عَرَفَۃَ إِلَی صَلاَۃِ الظُّہْرِ مِنْ آخِرِ أَیَّامِ التَّشْرِیقِ۔",,,5693,,
5694,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حُمَیْدٍ ؛ أَنَّ الْحَسَنَ کَانَ یُکَبِّرُ مِنْ صَلاَۃِ الظُّہْرِ یَوْمَ النَّحْرِ إِلَی صَلاَۃِ الظُّہْرِ مِنَ النَّفْرِ الأَوَّلِ۔,,,5694,,
5695,"حَدَّثَنَا عَبِیدَۃُ بْنُ حُمَیْدٍ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ۔ وَقَالَ غَیْرُہُ : عَنْ یَزِیدَ بْنِ أَوْسٍ ، عَنْ عَلْقَمَۃَ ؛ أَنَّہُ کَانَ یُکَبِّرُ یَوْمَ عَرَفَۃَ صَلاَۃ الْفَجْرِ حَتَّی صَلاَۃِ الْعَصْرِ مِنْ یَوْمِ النَّحْرِ۔",,,5695,,
5696,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانُوا یُکَبِّرُونَ یَوْمَ عَرَفَۃَ وَأَحَدُہُمْ مُسْتَقْبِلٌ الْقِبْلَۃَ فِی دُبُرِ الصَّلاَۃ : اللَّہُ أَکْبَرُ اللَّہُ أَکْبَرُ لاَ إِلَہَ إِلاَّ اللَّہُ ، وَاللَّہُ أَکْبَرُ اللَّہُ أَکْبَرُ وَلِلَّہِ الْحَمْدُ۔",,,5696,,
5697,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الأَحْوَص ، عَنْ عَبْدِ اللہِ ؛ أَنَّہُ کَانَ یُکَبِّرُ أَیَّامَ التَّشْرِیقِ : اللَّہُ أَکْبَرُ اللَّہُ أَکْبَرُ لاَ إِلَہَ إِلاَّ اللَّہُ ، وَاللَّہُ أَکْبَرُ اللَّہُ أَکْبَرُ وَلِلَّہِ الْحَمْدُ۔",,,5697,,
5698,حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الأَسْوَدِ ، عَنْ عَبْدِ اللہِ ؛ أَنَّہُ کَانَ یُکَبِّرُ مِنْ صَلاَۃِ الْفَجْرِ یَوْمَ عَرَفَۃَ إِلَی صَلاَۃِ الْعَصْرِ مِنْ یَوْمِ النَّحْرِ ، فَذَکَرَ مِثْلَ حَدِیثِ وَکِیعٍ۔,,,5698,,
5699,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : حدَّثَنَا شَرِیکٌ ، قَالَ : قُلْتُ لأَبِی إِسْحَاقَ : کَیْفَ کَانَ تَکْبِیرُ عَلِیٍّ ، وَعَبْدِ اللہِ ؟ فَقَالَ : کَانَا یَقُولاَنِ : اللَّہُ أَکْبَرُ اللَّہُ أَکْبَرُ لاَ إِلَہَ إِلاَّ اللَّہُ ، وَاللَّہُ أَکْبَرُ اللَّہُ أَکْبَرُ وَلِلَّہِ الْحَمْدُ۔",,,5699,,
5700,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا حُمَیْدٌ ؛ أَنَّ الْحَسَنَ کَانَ یُکَبِّرُ : اللَّہُ أَکْبَرُ اللَّہُ أَکْبَرُ ، ثَلاَثَ مَرَّاتٍ۔",,,5700,,
5701,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ أَبِی بَکَّارٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّہُ کَانَ یَقُولُ : اللَّہُ أَکْبَرُ کَبِیرًا اللَّہُ ، أَکْبَرُ کَبِیرًا اللَّہُ ، أَکْبَرُ وَأَجَلُّ ، اللَّہُ أَکْبَرُ وَلِلَّہِ الْحَمْدُ۔",,,5701,,
5702,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ سِمَاکٍ ، عَنْ جَابِرِ بْنِ سَمُرَۃَ ، قَالَ : صَلَّیْتُ مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْعِیدَیْنِ غَیْرَ مَرَّۃٍ ، وَلاَ مَرَّتَیْنِ بِغَیْرِ أَذَانٍ ، وَلاَ إِقَامَۃٍ۔ (مسلم 604۔ ابوداؤد 1141)",,,5702,,
5703,"حَدَّثَنَا عَبْدَۃُ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، عَنْ جَابِرٍ ، قَالَ : شَہِدْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی الْعِیدَیْنِ بِغَیْرِ أَذَانٍ ، وَلاَ إِقَامَۃٍ۔ (بخاری 960۔ مسلم 5)",,,5703,,
5704,حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطَائٍ ، عَنْ جَابِرٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی یَوْمَ الْعِیدِ بِغَیْرِ أَذَانٍ ، وَلاَ إِقَامَۃٍ۔,,,5704,,
5705,حَدَّثَنَا وَکِیعٌ ، عن سُفْیَانَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَابِسٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی بِہِمْ یَوْمَ الْعِیدِ عِنْدَ دَارِ کَثِیرِ بْنِ الصَّلْتِ ، فَصَلَّی قَبْلَ الْخُطْبَۃِ ، وَلَمْ یَذْکُرْ أَذَانًا ، وَلاَ إِقَامَۃً۔ (بخاری 863۔ احمد 1/368),,,5705,,
5706,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ سِمَاکٍ ، قَالَ : رَأَیْتُ الْمُغِیرَۃَ بْنَ شُعْبَۃَ ، وَالضَّحَّاکَ ، وَزِیَادًا یُصَلُّونَ یَوْمَ الْفِطْرِ وَالأَضْحَی بِلاَ أَذَانٍ ، وَلاَ إِقَامَۃٍ۔",,,5706,,
5707,حَدَّثَنَا وَکِیعٌ، عَنْ إِسْرَائِیلَ، عَنْ سِمَاکٍ، عَنِ الْمُغِیرَۃِ بْنِ شُعْبَۃَ؛ أَنَّہُ صَلَّی یَوْمَ عِیدٍ بِغَیْرِ أَذَانٍ، وَلاَ إِقَامَۃٍ۔,,,5707,,
5708,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ؛ أَنَّہُ کَانَ یَقُولُ : لَیْسَ فِی الْعِیدَیْنِ أَذَانٌ ، وَلاَ إِقَامَۃٌ۔",,,5708,,
5709,"حَدَّثَنَا خَالِد بْنِ حَیَّانَ ، عَنْ جَعْفَر بْنِ بُرْقَان ، عَنْ عِکْرِمَۃَ ، قَال : لَیْسَ فِیہِ أَذَانٌ ، وَلاَ إِقَامَۃٌ۔",,,5709,,
5710,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ أَنَّ ابْنَ الزُّبَیْرِ سَأَلَ ابْنَ عَبَّاسٍ ؟ قَالَ : وَکَانَ الَّذِی بَیْنَہُمَا حَسَنٌ ، فَقَالَ : لاَ تُؤَذِّنْ ، وَلاَ تُقِمْ ، فَلَمَّا سَائَ الَّذِی بَیْنَہُمَا أَذَّنَ وَأَقَامَ۔",,,5710,,
5711,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ ، قَالَ : الأَذَانُ فِی الْعِیدِ مُحْدَثٌ۔",,,5711,,
5712,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ قَتَادَۃَ ، عَنِ ابْنِ الْمُسَیَّبِ ، قَالَ : أَوَّلُ مَنْ أَحْدَثَ الأَذَانَ فِی الْعِیدِ مُعَاوِیَۃُ۔",,,5712,,
5713,"حَدَّثَنَا سَلاَّمٌ أَبو الأَحْوَص ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لاَ أَذَانَ ، وَلاَ إِقَامَۃَ فِی الْعِیدَیْنِ ، وَلاَ قِرَائَۃَ خَلْفَ الإِمَامِ۔",,,5713,,
5714,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ عِیسَی بْنِ الْمُغِیرَۃِ ، قَالَ : قُلْتُ لأَبِی وَائِلٍ : کَانُوا یُؤَذِّنُونَ فِی الأَضْحَی وَالْفِطْرِ ؟ قَالَ : لاَ۔",,,5714,,
5715,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ، وَالْحَکَمِ، قَالاَ: الأَذَانُ یَوْمَ الأَضْحَی وَالْفِطْرِ بِدْعَۃٌ۔",,,5715,,
5716,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ حُصَیْنٍ ، قَالَ : أَوَّلُ مَنْ أَذَّنَ فِی الْعِیدِ زِیَادٌ۔",,,5716,,
5717,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، قَالَ : أَخْبَرَنَا زَکَرِیَّا ، عَنْ رَجُلٍ ، عَنِ الشَّعْبِیِّ ، عَنِ الْبَرَائِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی یَوْمَ الْعِیدِ بِغَیْرِ أَذَانٍ ، وَلاَ إِقَامَۃٍ۔",,,5717,,
5718,حَدَّثَنَا مُعْتَمِرٌ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَمَّن حَدَّثَہُ ، عَنْ عَلِیٍّ ؛ أَنَّہُ صَلَّی یَوْمَ عِیدٍ بِغَیْرِ أَذَانٍ ، وَلاَ إِقَامَۃٍ۔,,,5718,,
5719,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، قَالَ : حدَّثَنَا أَیُّوبَ ، قَالَ : سَمِعْتُ عَطَائً ، قَالَ : سَمِعْتُ ابْنَ عَبَّاسٍ ، یَقُولُ : أَشْہَدُ عَلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لَصَلَّی قَبْلَ الْخُطْبَۃِ ، ثُمَّ خَطَبَ۔ (بخار ی1449۔ ابوداؤد 1137)",,,5719,,
5720,"حَدَّثَنَا عَبْدَۃُ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، عَنْ جَابِرٍ ، قَالَ : شَہِدْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَوْمَ عِیدٍ بَدَأَ بِالصَّلاَۃ قَبْلَ الْخُطْبَۃِ۔",,,5720,,
5721,حَدَّثَنَا عَبْدَۃُ بْنَ سُلَیْمَانَ ، وَأَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَأَبَا بَکْرٍ ، وَعُمَرَ کَانُوا یُصَلُّونَ الْعِیدَیْنِ قَبْلَ الْخُطْبَۃِ۔ (بخاری 957۔ ترمذی 531),,,5721,,
5722,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَابِسٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی بِہِمْ یَوْمَ عِیدٍ عِنْدَ دَارِ کَثِیرِ بْنِ الصَّلْتِ ، فَصَلَّی بِہِمْ قَبْلَ الْخُطْبَۃِ۔,,,5722,,
5723,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ مَنْصُورٍ ، عَنِ الشَّعْبِیِّ ، عَنِ الْبَرَائِ ، قَالَ : خَطَبَنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَوْمَ النَّحْرِ بَعْدَ الصَّلاَۃ۔ (بخاری 955۔ ترمذی 1508)",,,5723,,
5724,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا شُعْبَۃُ ، عَنِ الأَسْوَدِ بْنِ قَیْسٍ ، قَالَ : سَمِعْتُ جُنْدُبَ بْنَ عَبْدِ اللہِ ، یَقُولُ : صَلَّیْتُ مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَوْمَ النَّحْرِ ، ثُمَّ خَطَبَ۔ (بخاری 985۔ مسلم 1552)",,,5724,,
5725,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ الْحَسَنِ بْنِ مُسْلِمٍ ، عَنْ طَاوُوسٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : شَہِدْتُ الْعِیدَ مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَمَعَ أَبِی بَکْرٍ ، وَعُمَرَ فَبَدَؤُوا بِالصَّلاَۃ قَبْلَ الْخُطْبَۃِ ۔ (بخاری 962۔ مسلم 602)",,,5725,,
5726,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ أَبِی عُبَیْدٍ مَوْلَی ابْنِ أَزْہَرَ ، قَالَ : شَہِدْتُ الْعِیدَ مَعَ عُمَرَ بْنِ الْخَطَّابِ فَبَدَأَ بِالصَّلاَۃ قَبْلَ الْخُطْبَۃِ ، قَالَ : ثُمَّ شَہِدْتُ الْعِیدَ مَعَ عُثْمَانَ فَبَدَأَ بِالصَّلاَۃ قَبْلَ الْخُطْبَۃِ ، قَالَ : وَشَہِدْتُہُ مَعَ عَلِیٍّ فَبَدَأَ بِالصَّلاَۃ قَبْلَ الْخُطْبَۃِ۔",,,5726,,
5727,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنْ مَیْسَرَۃَ أَبِی جَمِیلَۃَ ، قَالَ : شَہِدْتُ الْعِیدَ مَعَ عَلِیٍّ ، فَلَمَّا صَلَّی خَطَبَ ۔ قَالَ : وَکَانَ عُثْمَانُ یَفْعَلُہُ۔",,,5727,,
5728,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ أَنَّ ابْنَ الزُّبَیْرِ سَأَلَ ابْنَ عَبَّاسٍ ، قَالَ : کَیْفَ أَصْنَعُ فِی ہَذَا الْیَوْمِ ، یَوْمِ عِیدٍ ؟ وَکَانَ الَّذِی بَیْنَہُمَا حَسَنٌ ، فَقَالَ : لاَ تُؤَذِّنْ ، وَلاَ تُقِمْ ، وَصَلِّ قَبْلَ الْخُطْبَۃِ ۔ فَلَمَّا سَائَ الَّذِی بَیْنَہُمَا ، أَذَّنَ وَأَقَامَ ، وَخَطَبَ قَبْلَ الصَّلاَۃ۔",,,5728,,
5729,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ حُمَیْدِ ، عَنْ أَنَسٍ ، قَالَ : کَانَتِ الصَّلاَۃُ فِی الْعِیدَیْنِ قَبْلَ الْخُطْبَۃِ۔",,,5729,,
5730,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ شِبَاکٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانَ الإِمَامُ یَوْمَ الْعِیدِ یَبْدَأُ فَیُصَلِّی ، ثُمَّ یَرْکَبُ بَعِیرَہُ فَیَخْطُبُ قَدْرَ مَا یَرْجِعُ النِّسَائُ۔",,,5730,,
5731,"حَدَّثَنَا وَکِیعٌ ، عَنِ الْعَلاَئِ بْنِ عَبْدِ الْکَرِیمِ ، قَالَ : سَمِعْتُ أَبَا الْبَخْتَرِیِّ یَوْمَ عِیدٍ ، وَسَمِعَ رَجُلاً یَقُولُ : الصَّلاَۃُ قَبْلَ الْخُطْبَۃِ ، فَقَالَ : السُّنَّۃُ وَرَبِّ الْکَعْبَۃِ۔",,,5731,,
5732,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنْ أَبِی حَمْزَۃَ مَوْلَی یَزِیدَ بْنِ الْمُہَلِّبِ ؛ أَنَّ مَطَرَ بْنَ نَاجِیَۃَ سَأَلَ سَعِیدَ بْنَ جُبَیْرٍ عَنِ الصَّلاَۃ یَوْمَ الأَضْحَی وَیَوْمَ الْفِطْرِ ؟ فَأَمَرَہُ أَنْ یُصَلِّیَ قَبْلَ الْخُطْبَۃِ ، فَاسْتَنْکَرَ النَّاسُ ذَلِکَ ، فَقَالَ سَعِیدٌ : ہِیَ وَاللَّہِ مَعْرُوفَۃٌ ، ہِیَ وَاللَّہِ مَعْرُوفَۃٌ۔",,,5732,,
5733,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ، عَنْ یَزِیدَ عَنِ ابْنِ أَبِی لَیْلَی، قَالَ: صَلَّی بِنَا عَلِیٌّ الْعِیدَ، ثُمَّ خَطَبَ عَلَی رَاحِلَۃٍ۔",,,5733,,
5734,"حَدَّثَنَا عَبْدَۃُ بْنَ سُلَیْمَانَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ یُوسُفَ بْنِ عَبْدِ اللہِ بْنِ سَلاَمٍ ، قَالَ : کَانَ النَّاسُ یَبْدَؤُونَ بِالصَّلاَۃ ، ثُمَّ یُثَنَّوْنَ بِالْخُطْبَۃِ ، حَتَّی إَِذَا کَانَ عُمَرُ وَکَثُرَ النَّاسُ فِی زَمَانِہِ ، فَکَانَ إِذَا ذَہَبَ لِیَخْطُبُ ذَہَبَ جُفَاۃُ النَّاسِ ، فَلَمَّا رَأَی ذَلِکَ عُمَرُ بَدَأَ بِالْخُطْبَۃِ حَتَّی خَتَمَ بِالصَّلاَۃ۔",,,5734,,
5735,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنِ الأَعْمَشِ ، عَنْ إِسْمَاعِیلَ بْنِ رَجَائٍ ، عَنْ أَبِیہِ ، قَالَ : أَخْرَجَ مَرْوَانُ الْمِنْبَرَ ، وَبَدَأَ بِالْخُطْبَۃِ قَبْلَ الصَّلاَۃ ، فَقَامَ إِلَیْہِ رَجُلٌ ، فَقَالَ : یَا مَرْوَانُ ، خَالَفْتَ السُّنَّۃَ ، أَخْرَجْتَ الْمِنْبَرَ وَلَمْ یَکُنْ یُخْرَجُ ، وَبَدَأْتَ بِالْخُطْبَۃِ قَبْلَ الصَّلاَۃِ ، فَقَالَ أَبُو سَعِیدٍ : مَنْ ہَذَا ؟ قَالُوا : فُلاَنٌ ، فَقَالَ : أَمَّا ہَذَا فَقَدْ قَضَی مَا عَلَیْہِ۔ (مسلم 79۔ ابوداؤد 1133)",,,5735,,
5736,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ قَیْسِ بْنِ مُسْلِمٍ ، عَنْ طَارِقِ بْنِ شِہَابٍ ، قَالَ : أَوَّلُ مَنْ بَدَأَ بِالْخُطْبَۃِ یَوْمَ الْعِیدِ قَبْلَ الصَّلاَۃِ مَرْوَانُ ، فَقَامَ إِلَیْہِ رَجُلٌ ، فَقَالَ : الصَّلاَۃُ قَبْلَ الْخُطْبَۃِ ، فَقَالَ : تُرِکَ مَا ہُنَالِکَ ، فَقَالَ أَبُو سَعِیدٍ : أَمَّا ہَذَا فَقَدْ قَضَی مَا عَلَیْہِ۔ (مسلم 78۔ ابوداؤد 1133)",,,5736,,
5737,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یُونُسُ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَکْرَہُ الْکَلاَمَ وَالإِمَامُ یَخْطُبُ یَوْمَ الْعِیدَیْنِ۔",,,5737,,
5738,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ أَنَّہُ کَرِہَہُ۔,,,5738,,
5739,حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی عَوَانَۃَ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّہُ کَرِہَہُ۔,,,5739,,
5740,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی الْہَیْثُمِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : خَرَجْتُ مَعَہُ یَوْمَ عِیدٍ ، فَلَمَّا خَطَبَ الإِمَامُ سَکَتَ۔",,,5740,,
5741,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ: قُلْتُ لَہُ: یُکْرَہُ الْکَلاَمُ فِی الْعِیدِ وَالإِمَامُ یَخْطُبُ؟ قَالَ : نَعَمْ۔",,,5741,,
5742,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ شُعْبَۃَ ، قَالَ : کَلَّمَنِی الْحَکَمُ بْنُ عُتَیْبَۃَ فِی یَوْمِ عِیدٍ وَالإِمَام یَخْطُبُ۔",,,5742,,
5743,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عَبْدُ اللہِ بْنُ عَبْدِ الرَّحْمَنِ بْنِ یَعْلَی الطَّائِفِیُّ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ، عَنْ جَدِّہِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَبَّرَ فِی عِیدٍ ثِنْتَیْ عَشْرَۃَ تَکْبِیرَۃً ، سَبْعًا فِی الأُولَی ، وَخَمْسًا فِی الآخِرَۃِ۔ (ابوداؤد 1144۔ احمد 2/180)",,,5743,,
5744,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، قَالَ : حدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ ثَوْبَانَ ، عَنْ أَبِیہِ ، عَنْ مَکْحُولٍ ، قَالَ : حَدَّثَنِی أَبُو عَائِشَۃَ ، وَکَانَ جَلِیسًا لأَبِی ہُرَیْرَۃَ ، قَالَ : شَہِدْتُ سَعِیدَ بْنَ الْعَاصِ وَدَعَا أَبَا مُوسَی الأَشْعَرِیَّ وَحُذَیْفَۃَ ، فَسَأَلَہُمَا عَنِ التَّکْبِیرِ فِی الْعِیدَیْنِ ؟ فَقَالَ أَبُو مُوسَی : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُکَبِّرُ فِی الْعِیدَیْنِ أَرْبَعًا کَمَا یُکَبِّرُ عَلَی الْجِنَازَۃِ ، قَالَ : وَصَدَّقَہُ حُذَیْفَۃُ ، قَالَ : فَقَالَ أَبُو مُوسَی : وَکَذَلِکَ کُنْتُ أُصَلِّی بِأَہْلِ الْبَصْرَۃِ وَأَنَا عَلَیْہَا ، قَالَ أبُو عَائِشَۃَ : وَأَنَا حَاضِرٌ ذَلِکَ ، فَمَا نَسِیتُ قَوْلَہُ أَرْبَعًا کَالتَّکْبِیرِ عَلَی الْجِنَازَۃِ۔ (ابوداؤد 1146۔ بیہقی 290)",,,5744,,
5745,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مَکْحُولٍ ، قَالَ : أَخْبَرَنِی مَنْ شَہِدَ سَعِیدَ بْنَ الْعَاصِ أَرْسَلَ إِلَی أَرْبَعَۃِ نَفَرٍ مِنْ أَصْحَابِ الشَّجَرَۃِ فَسَأَلَہُمْ عَنِ التَّکْبِیرِ فِی الْعِیدِ ؟ فَقَالُوا : ثَمَانُ تَکْبِیرَاتٍ ، قَالَ : فَذَکَرْتُ ذَلِکَ لاِبْنِ سِیرِینَ ، فَقَالَ : صَدَقَ ، وَلَکِنَّہُ أَغْفَلَ تَکْبِیرَۃَ فَاتِحَۃِ الصَّلاَۃِ۔",,,5745,,
5746,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُجَالِدٌ ، عَنِ الشَّعْبِیِّ ، عَنْ مَسْرُوقٍ ، قَالَ : کَانَ عَبْدُ اللہِ یُعَلِّمُنَا التَّکْبِیرَ فِی الْعِیدَیْنِ تِسْعَ تَکْبِیرَاتٍ ؛ خَمْسٌ فِی الأُولَی ، وَأَرْبَعٌ فِی الآخِرَۃِ ، وَیُوَالِی بَیْنَ الْقِرَائَتَیْنِ۔",,,5746,,
5747,حَدَّثَنَا وَکِیعٌ ، عَنْ مُحِلٍّ ، عَنْ إِبْرَاہِیمَ (ح) وَعَنْ إِسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ ، عَنْ عَبْدِ اللہِ ؛ أَنَّہُ کَانَ یُکَبِّرُ فِی الْفِطْرِ وَالأَضْحَی تِسْعًا تِسْعًا ؛ خَمْسًا فِی الأُولَی ، وَأَرْبَعًا فِی الآخِرَۃِ ، وَیُوَالِی بَیْنَ الْقِرَائَتَیْنِ۔,,,5747,,
5748,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی مُوسَی (ح) وَعَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّ أَمِیرًا مِنْ أُمَرَائِ الْکُوفَۃِ ، قَالَ سُفْیَانُ : أَحَدُہُمَا سَعِیدُ بْنُ الْعَاصِ ، وَقَالَ : الآخَرُ الْوَلِیدُ بْنُ عُقْبَۃَ ، بَعَثَ إِلَی عَبْدِ اللہِ بْنِ مَسْعُودٍ ، وَحُذَیْفَۃَ بْنِ الْیَمَانِ ، وَعَبْدِ اللہِ بْنِ قَیْسٍ ، فَقَالَ : إِنَّ ہَذَا الْعِیدَ قَدْ حَضَرَ ، فَمَا تَرَوْنَ ؟ فَأَسْنَدُوا أَمْرَہُمْ إِلَی عَبْدِ اللہِ ، فَقَالَ : تُکَبِّرُ تِسْعًا ؛ تَکْبِیرَۃً تَفْتَتِحُ بِہَا الصَّلاَۃَ ، ثُمَّ تُکَبِّرُ ثَلاَثًا ، ثُمَّ تَقْرَأُ سُورَۃً ، ثُمَّ تُکَبِّرُ ، ثُمَّ تَرْکَعُ ، ثُمَّ تَقُومُ فَتَقْرَأُ سُورَۃً ، ثُمَّ تُکَبِّرُ أَرْبَعًا ، تَرْکَعُ بِإِحْدَاہُنَّ۔",,,5748,,
5749,"حَدَّثَنَا وَکِیعٌ ، قَالَ: حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ؛ أَنَّہُ کَانَ یُکَبِّرُ فِی الْفِطْرِ إِحْدَی عَشْرَۃَ ؛ سِتًّا فِی الأُولَی ، وَخَمْسًا فِی الآخِرَۃِ ، یَبْدَأُ بِالْقِرَائَۃِ فِی الرَّکْعَتَیْنِ ، وَخَمْسًا فِی الأَضْحَی؛ ثَلاَثًا فِی الأُولَی ، وَثِنْتَیْنِ فِی الآخِرَۃِ ، یَبْدَأُ بِالْقِرَائَۃِ فِی الرَّکْعَتَیْنِ۔",,,5749,,
5750,حَدَّثَنَا ہُشَیْمٌ ، عَنْ حَجَّاجٍ ، وَعَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ کَانَ یُکَبِّرُ ثَلاَثَ عَشْرَۃَ تَکْبِیرَۃً۔,,,5750,,
5751,حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ أَنَّ ابْنَ عَبَّاسٍ کَبَّرَ فِی عِیدٍ ثَلاَثَ عَشْرَۃَ ؛ سَبْعًا فِی الأُولَی ، وَسِتًّا فِی الآخِرَۃِ۔,,,5751,,
5752,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : کَانَ یُکَبِّرُ فِی الأُولَی سَبْعَ تَکْبِیرَاتٍ ، وَفِی الثَّانِیَۃِ خَمْسًا ، کُلُّہُنَّ قَبْلَ الْقِرَائَۃِ۔",,,5752,,
5753,حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ کَانَ یُکَبِّرُ فِی الْعِیدِ ، فِی الأُولَی سَبْعَ تَکْبِیرَاتٍ بِتَکْبِیرَۃِ الافْتِتَاحِ ، وَفِی الآخِرَۃِ سِتًّا بِتَکْبِیرَۃِ الرَّکْعَۃِ ، کُلُّہُنَّ قَبْلَ الْقِرَائَۃِ۔,,,5753,,
5754,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَشْعَثَ ، عَنْ کُرْدُوسٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لَمَّا کَانَ لَیْلَۃَ الْعِیدِ أَرْسَلَ الْوَلِیدُ بْنُ عُقْبَۃَ إِلَی ابْنِ مَسْعُودٍ ، وَأَبِی مَسْعُودٍ ، وَحُذَیْفَۃَ ، وَأَبِی مُوسَی الأَشْعَرِیِّ ، فَقَالَ لَہُم : إِنَّ الْعِیدَ غَدًا ، فَکَیْفَ التَّکْبِیرُ ؟ فَقَالَ عَبْدُ اللہِ : تَقُومُ فَتُکَبِّرُ أَرْبَعَ تَکْبِیرَاتٍ ، وَتَقْرَأُ بِفَاتِحَۃِ الْکِتَابِ وَسُورَۃٍ مِنَ الْمُفَصَّلِ لَیْسَ مِنْ طِوَالِہَا ، وَلاَ مِنْ قِصَارِہَا ، ثُمَّ تَرْکَعُ ، ثُمَّ تَقُومُ فَتَقْرَأُ ، فَإِذَا فَرَغْتَ مِنَ الْقِرَائَۃِ کَبَّرْتَ أَرْبَعَ تَکْبِیرَاتٍ ، ثُمَّ تَرْکَعُ بِالرَّابِعَۃِ۔",,,5754,,
5755,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ الْمَسْعُودِیِّ ، عَنْ مَعْبَدِ بْنِ خَالِدٍ ، عَنْ کُرْدُوسٍ ، قَالَ : قدِمَ سَعِیدُ بْنُ الْعَاصِ فِی ذِی الْحِجَّۃِ ، فَأَرْسَلَ إِلَی عَبْدِ اللہِ ، وَحُذَیْفَۃَ ، وَأَبِی مَسْعُودٍ الأَنْصَارِیِّ ، وَأَبِی مُوسَی الأَشْعَرِیِّ فَسَأَلَہُمْ عَنِ التَّکْبِیرِ فِی الْعِیدِ ؟ فَأَسْنَدُوا أَمْرَہُمْ إِلَی عَبْدِ اللہِ ، فَقَالَ عَبْدُ اللہِ : یَقُومُ فَیُکَبِّرُ ، ثُمَّ یُکَبِّرُ ، ثُمَّ یُکَبِّرُ، ، ثُمَّ یُکَبِّرُ فَیَقْرَأُ ، ثُمَّ یُکَبِّرُ وَیَرْکَعُ ، وَیَقُومُ فَیَقْرَأُ ، ثُمَّ یُکَبِّرُ ، ثُمَّ یُکَبِّرُ ، ثُمَّ یُکَبِّرُ ، ثُمَّ یُکَبِّرُ الرَّابِعَۃَ ، ثُمَّ یَرْکَعُ۔",,,5755,,
5756,"حَدَّثَنَا أَبُو أُسَامَۃُ ، عَنْ سَعِیدِ بْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ ، وَسَعِیدِ بْنِ الْمُسَیَّبِ ، قَالاَ : تِسْعُ تَکْبِیرَاتٍ ، وَیُوَالِی بَیْنَ الْقِرَائَتَیْنِ۔",,,5756,,
5757,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا خَالِدٌ ، عَنْ عَبْدِ اللہِ بْنِ الْحَارِثِ ، قَالَ : صَلَّی بِنَا ابْنُ عَبَّاسٍ یَوْمَ عِیدٍ ، فَکَبَّرَ تِسْعَ تَکْبِیرَاتٍ ؛ خَمْسًا فِی الأُولَی ، وَأَرْبَعًا فِی الآخِرَۃِ ، وَوَالَی بَیْنَ الْقِرَائَتَیْنِ۔",,,5757,,
5758,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا دَاوُد ، عَنِ الشَّعْبِیِّ ، قَالَ : أَرْسَلَ زِیَادٌ إِلَی مَسْرُوقٍ : إِنَّا تَشْغَلُنَا أَشْغَالٌ ، فَکَیْفَ التَّکْبِیرُ فِی الْعِیدَیْنِ ؟ قَالَ : تِسْعُ تَکْبِیرَاتٍ ، قَالَ : خَمْسًا فِی الأُولَی ، وَأَرْبَعًا فِی الآخِرَۃِ ، وَوَالِ بَیْنَ الْقِرَائَتَیْنِ۔",,,5758,,
5759,حَدَّثَنَا غُنْدَرٌ ، وَابْنُ مَہْدِیٍّ ، عَنْ شُعْبَۃَ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، وَمَسْرُوقٍ ؛ أَنَّہُمَا کَانَا یُکَبِّرَانِ فِی الْعِیدِ تِسْعَ تَکْبِیرَاتٍ۔,,,5759,,
5760,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ أَشْعَثَ ، عَنْ مُحَمَّدِ بْنِ سِیرِینَ ، عَنْ أَنَسٍ ؛ أَنَّہُ کَانَ یُکَبِّرُ فِی الْعِیدِ تِسْعًا ۔ فَذَکَرَ مِثْلَ حَدِیثِ عَبْدِ اللہِ۔,,,5760,,
5761,حَدَّثَنَا إِسْحَاقُ الأَزْرَقُ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّ أَصْحَابَ عَبْدِ اللہِ کَانُوا یُکَبِّرُونَ فِی الْعِیدَیْنِ تِسْعَ تَکْبِیرَاتٍ۔,,,5761,,
5762,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ خَالِدٍ ، عَنْ أَبِی قِلاَبَۃَ ، قَالَ : التَّکْبِیرُ فِی الْعِیدَیْنِ تِسْعٌ تِسْعٌ۔",,,5762,,
5763,حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنِ أَبِی جَعْفَرٍ ؛ أَنَّہُ کَانَ یُفْتِی بِقَوْلِ عَبْدِ اللہِ فِی التَّکْبِیرِ فِی الْعِیدَیْنِ۔,,,5763,,
5764,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ؛ أَنَّہُ قَالَ : التَّکْبِیرُ فِی الأَضْحَی وَالْفِطْرِ سَبْعٌ وَخَمْسٌ فِی الْعِیدَیْنِ ، کِلاَہُمَا قَبْلَ الْقِرَائَۃِ ، لاَ یُوَالِی بَیْنَ الْقِرَائَتَیْنِ۔",,,5764,,
5765,حَدَّثَنَا إِسْحَاقُ الأَزْرَقُ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَمُحَمَّدٍ ؛ أَنَّہُمَا کَانَا یُکَبِّرَانِ تِسْعَ تَکْبِیرَاتٍ۔,,,5765,,
5766,حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ إِسْحَاقَ بْنِ سُوَیْد ، عَنْ یَحْیَی بْنِ یَعْمَُرَ ؛ فِی الْعِیدَیْنِ ، فِی إِحْدَاہُمَا تِسْعُ تَکْبِیرَاتٍ ، وَفِی الآخِرَۃِ إِحْدَی عَشْرَۃَ۔,,,5766,,
5767,حَدَّثَنَا جَعْفَرُ بْنُ عَوْنٍ ، عَنِ الإِفْرِیقِیِّ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ رَافِعٍ ؛ أَنَّ عُمَرَ بْنَ الْخَطَّابِ کَانَ یُکَبِّرُ فِی الْعِیدَیْنِ ثِنْتَیْ عَشْرَۃَ ؛ سَبْعًا فِی الأُولَی ، وَخَمْسًا فِی الآخِرَۃِ۔,,,5767,,
5768,حَدَّثَنَا عُمَرُ بْنُ ہَارُونَ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ عُمَرَ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یُکَبِّرُ فِی الْعِیدِ سَبْعًا وَخَمْسًا ؛ سَبْعًا فِی الأُولَی ، وَخَمْسًا فِی الآخِرَۃِ۔,,,5768,,
5769,"حَدَّثَنَا خَالِدُ بْنُ مَخْلَد ، قَالَ : حَدَّثَنَا إِبْرَاہِیمُ بْنُ إِسْمَاعِیلَ بْنِ أَبِی حَبِیبَۃَ ، قَالَ : أَخْبَرَنَا دَاودُ بْنُ الْحُصَیْنِ ، عَنْ أَبِی سُفْیَانَ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ، قَالَ : التَّکْبِیرُ فِی الْعِیدَیْنِ سَبْعٌ وَخَمْسٌ ؛ سَبْعٌ فِی الأُولَی قَبْلَ الْقِرَائَۃِ ، وَخَمْسٌ فِی الآخِرَۃِ قَبْلَ الْقِرَائَۃِ۔",,,5769,,
5770,"حَدَّثَنَا خَالِدُ بْنُ مَخْلَد ، قَالَ : حدَّثَنَا نَافِعُ بْنُ أَبِی نُعَیْمٍ ، قَالَ : سَمِعْتُ نَافِعًا ، قَالَ : قَالَ عَبْدُ اللہِ بْنُ عُمَرَ: التَّکْبِیرُ فِی الْعِیدَیْنِ سَبْعٌ وَخَمْسٌ۔",,,5770,,
5771,"حَدَّثَنَا خَالِدُ بْنُ مَخْلَد ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ ہِلاَلٍ ، قَالَ : سَمِعْتُ سَالِمَ بْنَ عَبْدِ اللہِ ، وَعُبَیْدَ اللہِ بْنَ عَبْدِ اللہِ یَأْمُرَانِ عَبْدَ الرَّحْمَن بْنَ الضَّحَّاکِ یَوْمَ الْفِطْرِ ، وَکَانَ عَلَی الْمَدِینَۃِ : أَنْ یُکَبِّرَ فِی أَوَّلِ رَکْعَۃٍ سَبْعًا ، ثُمَّ یَقْرَأَ بِـ : {سَبِّحِ اسْمَ رَبِّکَ الأَعْلَی} وَفِی الآخِرَۃِ خَمْسًا ، ثُمَّ یَقْرَأَ : {اقْرَأْ بِاسْمِ رَبِّکَ الَّذِی خَلَقَ}۔",,,5771,,
5772,"حَدَّثَنَا خَالِدُ بْنُ مَخْلَد ، قَالَ : حدَّثَنَا ثَابِتُ بْنُ قَیْسٍ ، قَالَ : صَلَّیْتُ خَلْفَ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ الْفِطْرَ ، فَکَبَّرَ فِی الأُولَی سَبْعًا قَبْلَ الْقِرَائَۃِ ، وَفِی الثَّانِیَۃِ خَمْسًا قَبْلَ الْقِرَائَۃِ۔",,,5772,,
5773,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا حُمَیْدٌ ، عَنْ عَمَّارِ بْنِ أَبِی عَمَّارٍ ؛ أَنَّ ابْنَ عَبَّاسٍ کَبَّرَ فِی عِیدٍ ثِنْتَیْ عَشْرَۃَ تَکْبِیرَۃً ؛ سَبْعًا فِی الأُولَی ، وَخَمْسًا فِی الآخِرَۃِ۔",,,5773,,
5774,"حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ ، قَالَ : حدَّثَنَا أَبُو کُدَیْنَۃَ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ، وَالْمُسَیَّبِ ، قَالاَ : الصَّلاَۃُ یَوْمَ الْعِیدَیْنِ تِسْعُ تَکْبِیرَاتٍ ؛ خَمْسٌ فِی الأُولَی ، وَأَرْبَعٌ فِی الآخِرَۃِ ، لَیْسَ بَیْنَ الْقِرَائَتَیْنِ تَکْبِیرَۃٌ۔",,,5774,,
5775,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، قَالَ : حدَّثَنَا ضَمْرَۃُ بْنُ سَعِیدٍ ، قَالَ : سَمِعْتُ عُبَیْدَ اللہِ بْنَ عَبْدِ اللہِ بْنِ عَُتبۃَ ، یَقُولُ : خَرَجَ عُمَرُ یَوْمَ عِیدٍ ، فَسَأَلَ أَبا وَاقِدٍ اللَّیْثِیَّ : بِأَیِّ شَیْئٍ قَرَأَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی ہَذَا الْیَوْمِ ؟ قَالَ : بِـ : (ق) ، وَ(اقْتَرَبَت)۔ (ترمذی 535۔ ابن ماجہ 1282)",,,5775,,
5776,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ إِبْرَاہِیمَ بْنِ مُحَمَّدِ بْنِ الْمُنْتَشِرِ ، عَنْ أَبِیہِ ، عَنْ حَبِیبِ بْنِ سَالِمْ ، عَنِ النُّعْمَانِ بْنِ بَشِیرٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَقْرَأُ فِی الْعِیدَیْنِ وَالْجُمُعَۃِ : {ہَلْ أَتَاک حَدِیثُ الْغَاشِیَۃِ} ، وَ{سَبِّحِ اسْمَ رَبِّکَ الأَعْلَی} وَإِذَا اجْتَمَعَ الْعِیدَانِ فِی یَوْمٍ قَرَأَ بِہِمَا فِیہِمَا۔",,,5776,,
5777,"حَدَّثَنَا وَکِیعُ بْنُ الْجَرَّاحِ ، عَنْ سُفْیَانَ ، عَنْ مَعْبَدِ بْنِ خَالِدٍ ، عَنْ زَیْدِ بْنِ عُقْبَۃَ ، عَنْ سَمُرَۃََ بْنِ جُنْدُبٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَقْرَأُ فِی الْعِیدَیْنِ بِـ : {سَبِّحِ اسْمَ رَبِّکَ الأَعْلَی} وَ{ہَلْ أَتَاک حَدِیثُ الْغَاشِیَۃِ}۔ (احمد 5/14۔ طبرانی 6773)",,,5777,,
5778,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَجَّاجٍ ، عَنْ مَعْبَد بْنِ خَالِدٍ ، عَنْ زَید بْنِ عُقْبَۃَ ، عَنْ سَمُرَۃََ بْنِ جُنْدُبٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَقْرَأُ فِی الْعِیدَیْنِ ، فَذَکَرَ مِثْلَہُ۔ (طبرانی 6778),,,5778,,
5779,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ ابن طَاوُوسٍ ، عَنْ أَبِیہِ (ح) وَعَنْ إِبْرَاہِیمَ بْنِ مَیْسَرَۃَ ، عَنْ طَاوُوسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَرَأَ فِی الْعِیدِ ۔ قَالَ أَحَدُہُمَا : بِـ : (اقْتَرَبَتْ) ، وَقَالَ الآخَرُ : بِـ : (ق)۔",,,5779,,
5780,حَدَّثَنَا مُعْتَمِرٌ ، عَنْ حُمَیْدٍ ، عَنْ أَنَسٍ ؛ أَنَّ أَبَا بَکْرٍ قَرَأَ فِی یَوْمِ عِیدٍ بِالْبَقَرَۃِ ، حَتَّی رَأَیْتُ الشَّیْخَ یَمِیدُ مِنْ طُولِ الْقِیَامِ۔,,,5780,,
5781,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ عَبْدِ الْمَلِکِ بْنِ عُمَیْرٍ ، قَالَ : حدِّثْتُ عَنْ عُمَرَ ؛ أَنَّہُ کَانَ یَقْرَأُ فِی الْعِیدِ بِـ : {سَبِّحِ اسْمَ رَبِّکَ الأَعْلَی} ، وَ{ہَلْ أَتَاک حَدِیثُ الْغَاشِیَۃِ}۔",,,5781,,
5782,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ مُحَمَّدِ بْنِ عَمْرِو بْنِ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَقْرَأُ فِی الْعِیدِ بِـ : {سَبِّحِ اسْمَ رَبِّکَ الأَعْلَی} ، وَ{ہَلْ أَتَاک حَدِیثُ الْغَاشِیَۃِ}۔ (ابن ماجہ 1283۔ عبدالرزاق 5705)",,,5782,,
5783,"حَدَّثَنَا ہُشَیْمٌ ، وَابْنُ إِدْرِیسَ ، عَنْ أَشْعَثَ ، عَنْ کُرْدُوسٍ ، عَنْ عَبْدِ اللہِ ؛ أَنَّ الْوَلِیدَ بْنَ عُقْبَۃَ أَرْسَلَ إِلَیْہِ، فَقَالَ : تَقْرَأُ بِأُمِّ الْکِتَابِ ، وَسُورَۃٍ مِنَ الْمُفَصَّلِ۔ زَادَ فِیہِ ہُشَیْمٌ : لَیْسَ مِنْ قِصَارِہَا ، وَلاَ مِنْ طِوَالِہَا۔",,,5783,,
5784,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا عُمَارَۃُ الصَّیْدَلاَنِیُّ ، عَنْ مَوْلًی لأَنَسٍ قَدْ سَمَّاہُ ، قَالَ : انْتَہَیْتُ مَعَ أَنَسٍ یَوْمَ الْعِیدِ ، حَتَّی انْتَہَیْنَا إِلَی الزَّاوِیَۃِ ، فَإِذَا مَوْلًی لَہُ یَقْرَأُ فِی الْعِیدِ بِـ : {سَبِّحِ اسْمَ رَبِّکَ الأَعْلَی} ، وَ{ہَلْ أَتَاک حَدِیثُ الْغَاشِیَۃِ} ، فَقَالَ أَنَسٌ : إِنَّہُمَا لَلسُّورَتَانِ اللَّتَانِ قَرَأَ بِہِمَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔ (ابوداؤد 2046)",,,5784,,
5785,"حَدَّثَنَا وَکِیعٌ ، وابْنُ إِدْرِیسَ ، عَنْ شُعْبَۃَ ، عَنْ عَدِیِّ بْنِ ثَابِتٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : خَرَجَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَوْمَ عِیدٍ ، فَصَلَّی بِالنَّاسِ ، فَلَمْ یُصَلِّ قَبْلَہَا ، وَلاَ بَعْدَہَا۔ (بخاری 989۔ ابوداؤد 1152)",,,5785,,
5786,حَدَّثَنَا وَکِیعٌ ، عَنْ أَبَانَ بْنِ عَبْدِ اللہِ الْبَجَلِیِّ ، عَنْ أَبِی بَکْرِ بْنِ حَفْصٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ خَرَجَ یَوْمَ عِیدٍ فَلَمْ یُصَلِّ قَبْلَہَا ، وَلاَ بَعْدَہَا ، وَذَکَرَ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَعَلَہُ۔ (ترمذی 538),,,5786,,
5787,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، وَابْنُ عَبَّادٍ ، عَنْ لَیْثٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : رَأَیْتُ ابْنَ أَبِی أَوْفَی ، وَابْنَ عُمَرَ ، وَجَابِرَ بْنَ عَبْدِ اللہِ ، وَشُرَیْحًا ، وَابْنَ مَعْقِلٍ ، لاَ یُصَلُّونَ قَبْلَ الْعِیدِ ، وَلاَ بَعْدَہُ۔",,,5787,,
5788,"حَدَّثَنَا ہُشَیْمُ ، عَنُ أَبِی بِشْرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : کُنْتُ مَعَہُ جَالِسًا فِی الْمَسْجِدِ الْحَرَامِ یَوْمَ الْفِطْرِ ، فَقَامَ عَطَائٌ یُصَلِّی قَبْلَ خُرُوجِ الإِمَامِ ، فَأَرْسَلَ إِلَیْہِ سَعِیدٌ : أَنِ اجْلِسْ ، فَجَلَسَ عَطَائٌ ۔ قَالَ : فَقُلْتُ لِسَعِیدٍ : عَمَّنْ ہَذَا یَا أَبَا عَبْدِ اللہِ ؟ فَقَالَ : عَنْ حُذَیْفَۃَ وَأَصْحَابِہِ۔",,,5788,,
5789,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ إِسْمَاعِیلَ بْنِ سُمَیْعٍ ، عَنْ عَلِیِّ بْنِ أَبِی کَثِیرٍ ؛ أَنَّ أَبَا مَسْعُودٍ ألأَنْصَارِیَّ کَانَ إِذَا کَانَ یَوْمَ أَضْحَی ، أَوْ یَوْمَ فِطْرٍ طَافَ فِی الصُّفُوفِ ، فَقَالَ : لاَ صَلاَۃَ إِلاَّ مَعَ الإِمَام۔",,,5789,,
5790,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَشْعَثَ بْنِ أَبِی الشَّعْثَائِ ، عَنِ الأَسْوَدِ بْنِ ہِلاَلٍ ، عَنْ ثَعْلَبَۃَ بْنِ زَہْدَمٍ الْحَنْظَلِیِّ؛ أَنَّ أَبَا مَسْعُودٍ الأَنْصَارِیَّ قَامَ فِی یَوْمِ عِیدٍ، فَقَالَ: إِنَّہُ لاَ صَلاَۃَ فِی ہَذَا الْیَوْمِ حَتَّی یَخْرُجَ الإِمَامُ۔",,,5790,,
5791,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ لاَ یُصَلِّی قَبْلَ الْعِیدِ ، وَلاَ بَعْدَہُ۔,,,5791,,
5792,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ مُجَالِدٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : کُنْتُ بَیْنَ مَسْرُوقٍ وَشُرَیْحٍ فِی یَوْمِ عِیدٍ ، فَلَمْ یُصَلِّیَا قَبْلَہَا ، وَلاَ بَعْدَہَا۔",,,5792,,
5793,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : کَانَ لاَ یُصَلِّی قَبْلَ الْعِیدِ ، وَلاَ بَعْدَہُ۔",,,5793,,
5794,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ إِسْمَاعِیلَ ، قَالَ : رَأَی الشَّعْبِیُّ إِنْسَانًا یُصَلِّی بَعْدَ مَا انْصَرَفَ الإِمَامُ ، فَجَبَذَہُ۔",,,5794,,
5795,"حَدَّثَنَا وَکِیعٌ ، عَنْ سَلَمَۃَ ، عَنِ الضَّحَّاکِ ، قَالَ : لاَ صَلاَۃَ قَبْلَہَا ، وَلاَ بَعْدَہَا۔",,,5795,,
5796,حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنِ الشَّعْبِیِّ ؛ أَنَّہُ کَانَ لاَ یُصَلِّی قَبْلَہَا ، وَلاَ بَعْدَہَا۔,,,5796,,
5797,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْمَاعِیلَ ، عَنْ أَبِی عُمَر ، عَنِ ابْنِ الْحَنَفِیَّۃِ ، قَالَ : لاَ صَلاۃَ قَبْلَہَا ، وَلاَ بَعْدَہَا۔",,,5797,,
5798,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، قَالَ : أَخْبَرَنَا إِسْرَائِیلُ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَمْرِو بْنِ عَبْدِ اللہِ الأَصَمِّ ؛ أَنَّہُ خَرَجَ مَعَ مَسْرُوقٍ فِی یَوْمِ عِیدٍ ، فَقُمْتُ أُصَلِّی ، فَأَخَذَ بِثِیَابِی فَأَجْلَسَنِی ، ثُمَّ قَالَ : لاَ صَلاَۃَ حَتَّی یُصَلِّیَ الإِمَامُ۔",,,5798,,
5799,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : کَانَ سَعِیدُ بْنُ جُبَیْرٍ ، وَإِبْرَاہِیمُ ، وَعَلْقَمَۃُ یُصَلُّونَ بَعْدَ الْعِیدِ أَرْبَعًا۔",,,5799,,
5800,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إِدْرِیسَ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، قَالَ : رَأَیْتُ إِبْرَاہِیمَ ، وَسَعِیدَ بْنَ جُبَیْرٍ ، وَمُجَاہِدًا، وَعَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، یُصَلُّونَ بَعْدَہَا أَرْبَعًا۔",,,5800,,
5801,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانَ عَلْقَمَۃُ یَجِیئُ یَوْمَ الْعِیدِ ، فَیَجْلِسُ فِی الْمُصَلَّی ، وَلاَ یُصَلِّی حَتَّی یُصَلِّیَ الإِمَامُ ، فَإِذَا صَلَّی الإِمَامُ ، قَامَ فَصَلَّی أَرْبَعًا۔",,,5801,,
5802,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ صَالِحِ بْنِ حَیٍّ ، عَنِ الشَّعْبِیِّ ، قَالَ : سَمِعْتُہُ یَقُولُ : کَانَ عَبْدُ اللہِ إِذَا رَجَعَ یَوْمَ الْعِیدِ ، صَلَّی فِی أَہْلِہِ أَرْبَعًا۔",,,5802,,
5803,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ أَبِی صَخْرَۃَ ، عَنِ الأَسْوَدِ بْنِ ہِلاَلٍ ، قَالَ : خَرَجْتُ مَعَ عَلِیٍّ ، فَلَمَّا صَلَّی الإِمَامُ ، قَامَ فَصَلَّی بَعْدَہَا أَرْبَعًا۔",,,5803,,
5804,حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، وَأَصْحَابِ عَبْدِ اللہِ ؛ أَنَّہُمْ کَانُوا یُصَلُّونَ بَعْدَ الْعِیدِ أَرْبَعًا۔,,,5804,,
5805,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانُوا یُصَلُّونَ بَعْدَ الْعِیدِ أَرْبَعًا ، وَلاَ یُصَلُّونَ قَبْلَہَا شَیْئًا۔",,,5805,,
5806,"حَدَّثَنَا عَبْدَۃُ ، عَنْ عَاصِمٍ ، قَالَ : رَأَیْتُ الْحَسَنَ ، وَابْنَ سِیرِینَ یُصَلِّیَانِ بَعْدَ الْعِیدِ ، وَیُطِیلاَنِ الْقِیَامَ۔",,,5806,,
5807,"حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ ، قَالَ : حدَّثَنَا الْمُغِیرَۃُ بْنُ مُسْلِمٍ ، عَنْ عَبْدِ اللہِ بْنِ بُرَیْدَۃَ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یُصَلِّی یَوْمَ الْعِیدِ قَبْلَ الصَّلاَۃ أَرْبَعًا ، وَبَعْدَہَا أَرْبَعًا۔",,,5807,,
5808,"حَدَّثَنَا عَبِیْدَۃُ بْنُ حُمَیْدٍ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانَ الأَسْوَدُ یُصَلِّی قَبْلَ الْعِیدَیْنِ ۔ قَالَ : وَکَانَ عَلْقَمَۃُ لاَ یُصَلِّی قَبْلَہَا ، وَیُصَلِّی بَعْدَہَا أَرْبَعًا۔",,,5808,,
5809,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَفَاک بِقَوْلِ عَبْدِ اللہِ ، یَعْنِی فِی الصَّلاَۃ بَعْدَ الْعِیدِ۔",,,5809,,
5810,"حَدَّثَنَا إِسْمَاعِیلُ ابْنُ عُلَیَّۃَ، عَنْ أَیُّوبَ، قَالَ: رَأَیْتُ أَنَسَ بْنَ مَالِکٍ وَالْحَسَنَ یُصَلِّیَانِ قَبْلَ خُرُوجِ الإِمَامِ۔ یَعْنِی یَوْمَ الْعِیدِ۔",,,5810,,
5811,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ؛ أَنَّ أَبَا بَرْزَۃَ کَانَ یُصَلِّی فِی الْعِیدِ قَبْلَ الإِمَامِ۔,,,5811,,
5812,حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنِ التَّیْمِیِّ ؛ أَنَّہُ رَأَی أَنَسًا ، وَالْحَسَنَ ، وَسَعِیدَ بْنَ أَبِی الْحَسَنِ ، وَجَابِرَ بْنَ زَیْدٍ ، یُصَلُّونَ قَبْلَ الإمَامِ فِی الْعیِدیْنِ۔,,,5812,,
5813,"حَدَّثَنَا مُعَاذٌ ، عَنِ التَّیْمِیِّ ، عَنْ عَبْدِ اللہِ الدَّانَاجِ ، قَالَ : رَأَیْتُ أَبَا بَرْزَۃَ یَفْعَلُہُ۔",,,5813,,
5814,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ؛ أَنَّہُ کَانَ یُصَلِّی یَوْمَ الْفِطْرِ وَالنَّحْرِ قَبْلَ خُرُوجِ الإِمَامِ۔,,,5814,,
5815,حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنِ الأَسْوَدِ ؛ أَنَّہُ کَانَ یُصَلِّی یَوْمَ الْعِیدِ قَبْلَ خُرُوجِ الإِمَامِ۔,,,5815,,
5816,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنِ التَّیْمِیِّ ، عَنِ الأَزْرَقِ بْنِ قَیْسٍ ، عَنْ رَجُلٍ ، قَالَ : رَأَیْتُ رِجَالاً مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ جَاؤُوا یَوْمَ عِیدٍ ، فَصَلَّوْا قَبْلَ الإِمَامِ۔",,,5816,,
5817,"حَدَّثَنَا عَبْدُ الأَعْلَی، عَنِ الْجُرَیرِیِّ، عَنْ خَالِدٍ الأَحْدَبِ، عَنْ عَمِّہِ صَفْوَانَ بْنَ مُحْرِزٍ، قَالَ: کَانَتْ صَلاَۃُ صَفْوَانَ یَوْمَ الْفِطْرِ وَالنَّحْرِ عَشْرَ رَکَعَاتٍ قَبْلَ خُرُوجِ الإِمَام ، وَرَکْعَتَیْنِ مَعَ الإِمَامِ ، وَرَکْعَتَیْنِ بَعْدَ الإِمَامِ۔",,,5817,,
5818,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ التَّیْمِیِّ ، قَالَ : رَأَیْتُ أَنَسًا ، وَالْحَسَنَ ، وَسَعِیدَ بْنَ أَبِی الْحَسَنِ ، یُصَلُّونَ یَوْمَ الْعِیدِ قَبْلَ الإِمَامِ۔",,,5818,,
5819,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : کَانَ إِذَا قَرَأَ فِی الْعِیدَیْنِ أَسْمَعَ مَنْ یَلِیہِ ، وَلاَ یَجْہَرُ ذَلِکَ الْجَہْرَ۔",,,5819,,
5820,"حَدَّثَنَا عُمَرُ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : یُرْفَعُ الصَّوْتُ بِالْقِرَائَۃِ فِی الْجُمُعَۃِ وَالْعِیدَیْنِ۔",,,5820,,
5821,"حَدَّثَنَا جَرِیرٌ ، وَابْنُ إِدْرِیسَ ، عَنْ یَزِیدَ ، عَنِ ابْنِ أَبِی لَیْلَی ، قَالَ : الْغُسْلُ یَوْمَ الأَضْحَی وَیَوْمَ الْفِطْرِ۔",,,5821,,
5822,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ زَاذَانَ ؛ أَنَّ رَجُلاً سَأَلَ عَلِیًّا عَنِ الْغُسْلِ ؟ فَقَالَ : الْغُسْلُ یَوْمَ الأَضْحَی وَیَوْمَ الْفِطْرِ۔",,,5822,,
5823,"حَدَّثَنَا عَبْدُاللہِ بْنُ نُمَیْرٍ، قَالَ: حدَّثَنَا عُبَیْدُاللہِ بْنُ عُمَرَ، عَنْ نَافِعٍ، عَنِ ابْنَ عُمَرَ؛ أَنَّہُ کَانَ یَغْتَسِلُ لِلْعِیدَیْنِ۔",,,5823,,
5824,"حَدَّثَنَا وَکِیعٌ ، عَنْ سَعِیدِ بْنِ سِنَانٍ ، عَنْ رَجُلٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : اغْتَسَلَ فِی الْعِیدَیْنِ۔",,,5824,,
5825,حَدَّثَنَا وَکِیعٌ ، عَنِ الْعُمَرِیِّ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَغْتَسِلُ فِی الْعِیدَیْنِ۔,,,5825,,
5826,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَغْتَسِلُ یَوْمَ الْفِطْرِ وَیَوْمَ النَّحْرِ۔,,,5826,,
5827,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَمُحَمَّدٍ ؛ أَنَّہُمَا کَانَا یَغْتَسِلاَنِ یَوْمَ الْفِطْرِ وَیَوْمَ النَّحْرِ۔,,,5827,,
5828,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ مُجَاہِدٍ ، قَالَ : کَانُوا یَسْتَحِبُّونَ أَنْ یَغْتَسِلُوا یَوْمَ الأَضْحَی وَیَوْمَ الْفِطْرِ۔",,,5828,,
5829,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ زَمْعَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، أَنَّہُ سَمِعَہُ یَقُولُ : الاغْتِسَالُ یَوْمَ الأَضْحَی وَیَوْمَ الْفِطْرِ قَبْلَ أَنْ تَخْرُجَ حَقٌّ۔",,,5829,,
5830,حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ خَالِدٍ ، عَنْ أَبِی بَکْرٍ ؛ أَنَّ سَالِمَ بْنَ عَبْدِ اللہِ کَانَ یَغْتَسِلُ لِلْعِیدِ۔,,,5830,,
5831,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی، عَنْ خَالِدٍ، عَنْ أَبِی بَکْرٍ، قَالَ: سَمِعْتُ عُبَیْدَاللہِ بْنَ عَبْدِاللہِ یَأْمُرُ بِالْغُسْلِ لِلْعِیدَیْنِ۔",,,5831,,
5832,حَدَّثَنَا وَکِیعٌ ، وَالْفَضْلُ بْنُ دُکَیْنٍ ، عَنِ عُمَرَ بْنِ ذَرٍّ ، عَنْ إِبْرَاہِیمَ التَّیْمِیِّ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یَسْتَحِبُّ الْغُسْلَ لِلْجُمُعَۃِ وَالْعِیدَیْنِ۔,,,5832,,
5833,حَدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ؛ أَنَّہُ کَانَ یَغْتَسِلُ یَوْمَ الْعِیدِ قَبْلَ أَنْ یَغْدُوَ۔,,,5833,,
5834,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ حَجَّاجٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَابِسٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُخْرِجُ بَنَاتہ وَنِسَائَہُ إِلَی الْعِیدَیْنِ۔ (ابن ماجہ 1309۔ احمد 1/354)",,,5834,,
5835,"حَدَّثَنَا حَفْصٌ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، عَنْ طَلْحَۃَ الْیَامِیِّ ، قَالَ : قَالَ أَبُو بَکْرٍ : حَقٌّ عَلَی کُلِّ ذَاتِ نِطَاقٍ الْخُرُوجُ إِلَی الْعِیدَیْنِ۔",,,5835,,
5836,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : حقٌّ عَلَی کُلِّ ذَاتِ نِطَاقٍ أَنْ تَخْرُجَ إِلَی الْعِیدَیْنِ ، وَلَمْ یَکُنْ یُرَخِّصُ لَہُنَّ فِی شَیْئٍ مِنَ الْخُرُوجِ إِلاَّ إِلَی الْعِیدَیْنِ۔",,,5836,,
5837,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، قَالَ : کَانَ عَبْدُ اللہِ بْنُ عُمَرَ یُخْرِجُ إِلَی الْعِیدَیْنِ مَنِ اسْتَطَاعَ مِنْ أَہْلِہِ۔",,,5837,,
5838,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ خَالِدٍ ، عَنْ أَبِی قِلاَبَۃَ ، قَالَ : قالَتْ عَائِشَۃُ : قَدْ کَانَتِ الْکِعَابُ تَخْرُجُ لِرَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِنْ خِدْرِہَا فِی الْفِطْرِ وَالأَضْحَی۔ (احمد 6/184۔ ابن راھویہ 1358)",,,5838,,
5839,"حَدَّثَنَا یَحْیَی بْنُ سُلَیْمِ ، عن ابْنِ جُرَیْجٍ ، عَنْ مُجَاہِدٍ فِی قَوْلِہِ : (کَوَاعِبُ) قَالَ : نَوَاہِدُ۔",,,5839,,
5840,حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ حَجَّاجٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ؛ أَنَّ عَلْقَمَۃَ ، وَالأَسْوَدَ کَانَا یُخْرِجَانِ نِسَائَہُمَا فِی الْعِیدَیْنِ ، وَیَمْنَعُونَہُنَّ مِنَ الْجُمُعَۃِ۔,,,5840,,
5841,"حَدَّثَنَا شَرِیکٌ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : إِنْ کَانَتِ امْرَأَۃُ أَبِی مَیْسَرَۃَ لَتَخْرُجَ إِلَی الْعِیدِ۔",,,5841,,
5842,"حَدَّثَنَا جَرِیرٌ، عَنْ مَنْصُورٍ، عَنْ إِبْرَاہِیمَ، قَالَ: کَانَ لِعَلْقَمَۃَ امْرَأَۃٌ قَدْ خَلَتْ فِی السِّنِّ تَخْرُجُ إِلَی الْعِیدَیْنِ۔",,,5842,,
5843,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنْ حَفْصَۃَ ، عَنْ أُمِّ عَطِیَّۃَ ، قَالَتْ : أَمَرَنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ نُخْرِجَہُنَّ یَوْمَ الْفِطْرِ وَیَوْمَ النَّحْرِ ، قَالَتْ أُمُّ عَطِیَّۃَ : فَقُلْنَا : أَرَأَیْتَ إِحْدَاہُنَّ لاَ یَکُونُ لَہَا جِلْبَابٌ ؟ قَالَ: فَتُلْبِسُہَا أُخْتُہَا مِنْ جِلْبَابِہَا۔ (بخاری 324۔ ابوداؤد 1131)",,,5843,,
5844,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : یُکْرَہُ خُرُوجُ النِّسَائِ فِی الْعِیدَیْنِ۔",,,5844,,
5845,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ جَابِرٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ لاَ یُخْرِجُ نِسَائَہُ فِی الْعِیدَیْنِ۔,,,5845,,
5846,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ لاَ یَدَعُ امْرَأَۃً مِنْ أَہْلِہِ تَخْرُجُ إِلَی فِطْرٍ ، وَلاَ إِلَی أَضْحَی۔,,,5846,,
5847,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ قُرَّۃَ ، قَالَ : حدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ الْقَاسِمِ ، قَالَ : کَانَ الْقَاسِمُ أَشَدَّ شَیْئٍ عَلَی الْعَوَاتِقِ ، لاَ یَدَعُہُنَّ یَخْرُجْنَ فِی الْفِطْرِ وَالأَضْحَی۔",,,5847,,
5848,"حَدَّثَنَا وَکِیعٌ، عَنْ حَسَنِ بْنِ صَالِحٍ، عَنْ مَنْصُورٍ، عَنْ إِبْرَاہِیمَ، قَالَ: کُرِہَ لِلشَّابَّۃِ أَنْ تَخْرُجَ إلَی الْعِیدَیْنِ۔",,,5848,,
5849,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ مُطَرِّفٍ ، عَنِ الشَّعْبِیِّ ، عَنْ عَبْدِ اللہِ ، قَالَ : یُصَلِّی أَرْبَعًا۔",,,5849,,
5850,"حَدَّثَنَا ہُشَیْمٌ ، وَحَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ مُسْلِمٍ ، عَنْ مَسْرُوقٍ ، قَالَ : قَالَ عَبْدُ اللہِ : مَنْ فَاتَہُ الْعِیدُ فَلْیُصَلِّ أَرْبَعًا۔",,,5850,,
5851,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ ، قَالَ : یُصَلِّی أَرْبَعًا۔",,,5851,,
5852,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : یُصَلِّی رَکْعَتَیْنِ وَیُکَبِّرُ۔",,,5852,,
5853,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، قَالَ : حدَّثَنِی بَعْضُ آلِ أَنَسٍ ؛ أَنَّ أَنَسًا کَانَ رُبَّمَا جَمَعَ أَہْلَہُ وَحَشَمَہُ یَوْمَ الْعِیدِ ، فَصَلَّی بِہِمْ عَبْدُ اللہِ بْنُ أَبِی عُتْبَۃَ رَکْعَتَیْنِ۔",,,5853,,
5854,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، قَالَ : کَانَ أَبُو عِیَاضٍ مُسْتَخْفِیًا ، قَالَ : فَجَائَہُ مُجَاہِدٌ یَوْمَ عِیدٍ ، فَصَلَّی بِہِ رَکْعَتَیْنِ ، وَدَعَا۔",,,5854,,
5855,"حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ ، قَالَ : مَنْ کَانَ لَہُ عُذْرٌ یُعْذَرُ بِہِ فِی یَوْمِ فِطْرٍ ، أَوْ جُمُعَۃٍ ، أَوْ أَضْحَی ، فَصَلاَتُہُ أَرْبَعُ رَکَعَاتٍ۔",,,5855,,
5856,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْمَاعِیلَ ، عَنْ أَبِی عُمَرَ ، عَنِ ابْنِ الْحَنَفِیَّۃِ ، قَالَ : یُصَلِّی رَکْعَتَیْنِ۔",,,5856,,
5857,"حَدَّثَنَا وَکِیعٌ ، عَنْ رَبِیعٍ ، عَنِ الْحَسَنِ ، قَالَ : یُصَلِّی مِثْلَ صَلاَۃِ الإِمَام۔",,,5857,,
5858,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا فَاتَتْک الصَّلاَۃُ مَعَ الإِمَامِ فَصَلِّ مِثْلَ صَلاَتِہِ ۔ وَقَالَ إِبْرَاہِیمُ : وَإِذَا اسْتَقْبَلَ النَّاسَ رَاجِعِینَ فَلْیَدْخُلْ أَدْنَی مَسْجِدٍ ، ثُمَّ لِیُصَلِّ صَلاَۃَ الإِمَامِ ، وَمَنْ لاَ یَخْرُجُ إِلَی الْعِیدِ ، فَلْیُصَلِّ مِثْلَ صَلاَۃِ الإِمَام۔",,,5858,,
5859,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ حَمَّادٍ ؛ فِیمَنْ لَمْ یُدْرِکِ الصَّلاَۃَ یَوْمَ الْعِیدِ ، قَالَ : یُصَلِّی مِثْلَ صَلاَتِہِ ، وَیُکَبِّرُ مِثْلَ تَکْبِیرِہِ۔",,,5859,,
5860,"حَدَّثَنَا شَرِیکٌ ، قَالَ : سَأَلْتُ أَبَا إِسْحَاقَ عَنِ الرَّجُلِ یَجِیئُ یَوْمَ الْعِیدِ وَقَدْ فَرَغَ الإِمَامُ ؟ قَالَ : یُصَلِّی رَکْعَتَیْنِ۔",,,5860,,
5861,"حَدَّثَنَا حسن بن عَبْدُ الرَّحْمَان الْحَارِثِیُّ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدِ ؛ فِی الَّذِی یَفُوتُہُ الْعِیدُ ، قَالَ : کَانَ یُسْتَحَبُّ أَنْ یُصَلِّیَ مِثْلَ صَلاَۃِ الإِمَامِ ، وَإِنْ عَلِمَ مَا قَرَأَ بِہِ الإِمَام قَرَأَ بِہِ۔",,,5861,,
5862,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مُغِیرَۃَ ، عَنْ حَمَّادٍ ، قَالَ : إِذَا فَاتَتْک مِنْ صَلاَۃِ الْعِیدِ رَکْعَۃٌ فَاقْضِہَا، وَاصْنَعْ فِیہَا مِثْلَ مَا یَصْنَعُ الإِمَامُ فِی الرَّکْعَۃِ الأُولَی۔",,,5862,,
5863,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : یُکَبِّرُ مَعَہُ فِی ہَذِہِ مَا أَدْرَکَ مِنْہَا ، وَیَقْضِی الَّتِی فَاتَتْہُ وَیُکَبِّرُ فِیہَا مِثْلَ تَکْبِیرِ الإِمَامِ فِی الرَّکْعَۃِ الثَّانِیَۃِ۔",,,5863,,
5864,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ لَیْثٍ ، عَنِ الْحَکَمِ ، عَنْ حَنَشٍ ، قَالَ : قیلَ لِعَلِیِّ بْنِ أَبِی طَالِبٍ : إِنَّ ضَعَفَۃً مِنْ ضَعَفَۃِ النَّاسِ لاَ یَسْتَطِیعُونَ الْخُرُوجَ إِلَی الْجَبَّانَۃِ ، فَأَمَرَ رَجُلاً یُصَلِّی بِالنَّاسِ أَرْبَعَ رَکَعَاتٍ ؛ رَکْعَتَیْنِ لِلْعِیدِ ، وَرَکْعَتَیْنِ لِمَکَانِ خُرُوجِہِمْ إِلَی الْجَبَّانَۃِ۔",,,5864,,
5865,حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ أَبِی إِسْحَاقَ؛ أَنَّ عَلِیًّا أَمَرَ رَجُلاً یُصَلِّی بِضَعَفَۃِ النَّاسَ فِی الْمَسْجِدِ رَکْعَتَیْنِ۔,,,5865,,
5866,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی قَیْسٍ ، قَالَ : أَظُنُّہُ ، عَنْ ہُزََیْلٍ ؛ أَنَّ عَلِیًّا أَمَرَ رَجُلاً یُصَلِّی بِضَعَفَۃِ النَّاسِ یَوْمَ الْعِیدِ أَرْبَعًا ، کَصَلاَۃِ الْہَجِیرِ۔",,,5866,,
5867,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِالرَّحْمَنِ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عِیسَی ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، قَالَ : صَلَّی بِالنَّاسِ فِی مَسْجِدِ الْکُوفَۃِ رَکْعَتَیْنِ ، فِی إِمَارَۃِ مُصْعَبِ بْنِ الزُّبَیْرِ۔",,,5867,,
5868,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنٍ ، عَنِ ابْنِ أَبِی لَیْلَی ؛ أَنَّ عَلِیًّا أَمَرَ رَجُلاً یُصَلِّی بِالنَّاسِ فِی مَسْجِدِ الْکُوفَۃِ رَکْعَتَیْنِ ۔ قَالَ : وَقَالَ ابْنُ أَبِی لَیْلَی : یُصَلِّی رَکْعَتَیْنِ ، فَقَالَ رَجُلٌ لْاِبْنِ أَبِی لَیْلَی : یُصَلِّی بِغَیْرِ خُطْبَۃٍ ؟ قَالَ : نَعَمْ۔",,,5868,,
5869,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مُسْلِمُ بْنِ یَزِیدَ بْنِ مَذْکُورٍ الْخَارِقِیِّ ، قَالَ : صَلَّی بِنَا الْقَاسِمُ بْنُ عَبْدِ الرَّحْمَنِ یَوْمَ عِیدٍ فِی الْمَسْجِدِ الْجَامِعِ رَکْعَتَیْنِ ، وَخَطَبَ۔",,,5869,,
5870,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ عُرَیْفِ بْنِ دِرْہَمٍ ، قَالَ : رَأَیْتُ عَبْدَ اللہِ بْنَ أَبِی ہُذَیْلٍ یَأْتِی الْمَسْجِدَ الأَعْظَمَ یَوْمَ الْعِیدِ۔",,,5870,,
5871,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ، قَالَ : یُکَبِّرُ ، ثُمَّ یَقُومُ فَیَقْضِی ، ثُمَّ یُکَبِّرُ۔",,,5871,,
5872,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنِ ابْنِ شُبْرُمَۃَ ، عَنِ الشَّعْبِیِّ ، قَالَ : یَقْضِی ، ثُمَّ یُکَبِّرُ۔",,,5872,,
5873,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، قَالَ : رَأَیْتُ ابْنَ شُبْرُمَۃَ غَیْرَ مَرَّۃٍ ، إِذَا فَاتَہُ شَیْئٌ مِنَ الصَّلاَۃِ أَیَّامَ التَّشْرِیقِ قَامَ فَقَضَی ، ثُمَّ کَبَّرَ۔",,,5873,,
5874,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : کَانَ یَقُولُ : یُکَبِّرُ مَعَہُ ، ثُمَّ یَقُومُ فَیَقْضِی۔",,,5874,,
5875,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إِدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَابْنِ سِیرِینَ ؛ فِی الرَّجُلِ تَفُوتُہُ الرَّکْعَۃُ أَیَّامَ التَّشْرِیقِ ، قَالَ ابْنُ سِیرِینَ : یَقْضِی ، ثُمَّ یُکَبِّرُ ، وَقَالَ الْحَسَنُ : یُکَبِّرُ ، ثُمَّ یَقْضِی ۔",,,5875,,
5876,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ أَبِی حَنِیفَۃَ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ، قَالَ: إِذَا فَاتَتْک رَکْعَۃٌ أَیَّامَ التَّشْرِیقِ فَلاَ تُکَبِّرْ حَتَّی تَقْضِیَہَا۔",,,5876,,
5877,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یُونُسُ ، عَنِ الْحَسَنِ ، قَالَ : یُکَبِّرُ مَعَ الإِمَامِ ، ثُمَّ یَقْضِی مَا سُبِقَ بِہِ۔",,,5877,,
5878,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّہُ کَانَ یَقُولُ : یَقْضِی مَا فَاتَہُ ، ثُمَّ یُکَبِّرُ۔",,,5878,,
5879,"حَدَّثَنَا حَکَّامٌ الرَّازِیُّ ، عَنْ عَنْبَسَۃَ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ مُجَاہِدٍ ، قَالَ : یُکَبِّرُ مَعَ الإِمَامِ ، ثُمَّ یُکَبِّرُ إِذَا قَضَی۔ قَالَ أَبُو بَکْرٍ : وَبَلَغَنِی أَنَّ ہَکَذَا قَوْلُ ابْنِ أَبِی لَیْلَی۔",,,5879,,
5880,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ، عَنْ عَمْرٍو، عَنِ الْحَسَنِ، قَالَ: إِذَا صَلَّی وَحْدَہُ، أَوْ فِی جَمَاعَۃٍ، أَوْ تَطَوَّعَ، کَبَّرَ۔",,,5880,,
5881,"حَدَّثَنَا حَفْصٌ ، عَنْ أَبِی حَنِیفَۃَ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لاَ یُکَبِّرُ إِلاَّ أَنْ یُصَلِّیَ فِی جَمَاعَۃٍ۔",,,5881,,
5882,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ ہَمَّامٍ ، قَالَ : رَأَیْتُ قَتَادَۃَ صَلَّی وَحْدَہُ أَیَّامَ التَّشْرِیقِ ، فَکَبَّرَ۔",,,5882,,
5883,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : کَبِّرْ فِی التَّطَوُّعِ وَإِنْ صَلَّیْت وَحْدَک۔",,,5883,,
5884,"حَدَّثَنَا حَکَّامٌ الرَّازِیُّ ، عَنْ عَنْبَسَۃَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : التَّکْبِیرُ أَیَّامَ التَّشْرِیقِ فِی کُلِّ نَافِلَۃٍ وَفَرِیضَۃٍ۔",,,5884,,
5885,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ مُجَاہِدٍ ، قَالَ : کَانُوا یُکَبِّرُونَ فِی دُبُرِ الرَّکْعَتَیْنِ یَوْمَ النَّحْرِ۔",,,5885,,
5886,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ عَبْدِ الْحَمِیدِ بْنِ جَعْفَرٍ ، عَنْ وَہْبِ بْنِ کَیْسَانَ ، قَالَ : اجْتَمَعَ عِیدَانِ فِی عَہْدِ ابْنِ الزُّبَیْرِ ، فَأَخَّرَ الْخُرُوجَ ، ثُمَّ خَرَجَ فَخَطَبَ فَأَطَالَ الْخُطْبَۃَ ، ثُمَّ صَلَّی ، وَلَمْ یَخْرُجْ إِلَی الْجُمُعَۃِ ، فَعَابَ ذَلِکَ أُنَاسٌ عَلَیْہِ ، فَبَلَغَ ذَلِکَ عِنْدَ ابْنِ عَبَّاسٍ ، فَقَالَ : أَصَابَ السُّنَّۃَ ۔ فَبَلَغَ ابْنَ الزُّبَیْرِ ، فَقَالَ : شَہِدْتُ الْعِیدَ مَعَ عُمَرَ فَصَنَعَ کَمَا صَنَعْتُ۔ (ابوداؤد 1064۔ نسائی 1794)",,,5886,,
5887,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ أَبِی عُبَیْدٍ مَوْلَی ابْنِ أَزْہَرَ ، قَالَ : شَہِدْتُ الْعِیدَ مَعَ عُثْمَانَ وَوَافَقَ یَوْمَ جُمُعَۃٍ ، فَقَالَ : إِنَّ ہَذَا یَوْمٌ اجْتَمَعَ فِیہِ عِیدَانِ لِلْمُسْلِمِینَ ، فَمَنْ کَانَ ہَاہُنَا مِنْ أَہْلِ الْعَوَالِی فَقَدْ أَذِنَّا لَہُ أَنْ یَنْصَرِفَ ، وَمَنْ أَحَبَّ أَنْ یَمْکُثَ فَلْیَمْکُثْ۔",,,5887,,
5888,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ عَبْدِ الأَعْلَی ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ، قَالَ : اجْتَمَعَ عِیدَانِ عَلَی عَہْدِ عَلِیٍّ فَصَلَّی بِالنَّاسِ ، ثُمَّ خَطَبَ عَلَی رَاحِلَتِہِ ، ثُمَّ قَالَ : یَا أَیَّہَا النَّاسُ ، مَنْ شَہِدَ مِنْکُمُ الْعِیدَ فَقَدْ قَضَی جُمُعَتَہُ إِنْ شَائَ اللَّہُ۔",,,5888,,
5889,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، قَالَ : اجْتَمَعَ عِیدَانِ عَلَی عَہْدِ عَلِیٍّ فَشَہِدَ بِہِمُ الْعِیدَ ، ثُمَّ قَالَ : إِنَّا مُجَمِّعُونَ ، فَمَنْ أَرَادَ أَنْ یَشْہَدَ فَلْیَشْہَدْ۔",,,5889,,
5890,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ إِبْرَاہِیمَ بْنِ مُحَمَّدِ بْنِ الْمُنْتَشِرِ ، عَنْ أَبِیہِ ، عَنْ حَبِیبِ بْنِ سَالِمٍ ، عَنِ النُّعْمَانِ بْنِ بَشِیرٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَقْرَأُ فِی الْعِیدَیْنِ بِـ : {سَبِّحِ اسْمَ رَبِّکَ الأَعْلَی} ، وَ{ہَلْ أَتَاک حَدِیثُ الْغَاشِیَۃِ} ، وَإِذَا اجْتَمَعَ الْعِیدَانِ فِی یَوْمٍ قَرَأَ بِہِمَا فِیہِمَا۔",,,5890,,
5891,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ وَہْبِ بْنِ کَیْسَانَ ، قَالَ : اجْتَمَعَ عِیدَانِ فِی یَوْمٍ ، فَخَرَجَ عَبْدُ اللہِ بْنُ الزُّبَیْرِ فَصَلَّی الْعِیدَ بَعْدَ مَا ارْتَفَعَ النَّہَارُ ، ثُمَّ دَخَلَ ، فَلَمْ یَخْرُجْ حَتَّی صَلَّی الْعَصْرَ ۔ قَالَ ہِشَامٌ : فَذَکَرْتُ ذَلِکَ لِنَافِعٍ ، أَوْ ذُکِرَ لَہُ ، فَقَالَ : ذُکِرَ ذَلِکَ لاِبْنِ عُمَرَ فَلَمْ یُنْکِرْہُ۔",,,5891,,
5892,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مَنْصُورٍ ، عَنْ عَطَائٍ ، قَالَ : اجْتَمَعَ عِیدَانِ فِی عَہْدِ ابْنِ الزُّبَیْرِ فَصَلَّی بِہِمُ الْعِیدَ ، ثُمَّ صَلَّی بِہِمُ الْجُمُعَۃَ صَلاَۃَ الظُّہْرِ أَرْبَعًا۔",,,5892,,
5893,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، قَالَ : اجْتَمَعَ عِیدَانِ عَلَی عَہْدِ الْحَجَّاجِ ، فَصَلَّی أَحَدَہُمَا ، فَقَالَ أَبُو الْبَخْتَرِیِّ : قَاتَلَہُ اللَّہُ أَنَّی عَلِقَ ہَذَا ؟۔",,,5893,,
5894,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : تُجْزِئُہُ الأُولَی مِنْہُمَا۔",,,5894,,
5895,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، قَالَ : إِذَا اجْتَمَعَ عِیدَانِ فِی یَوْمٍ ، فَأَیُّہُمَا أَتَیْتَ أَجْزَأَکَ۔",,,5895,,
5896,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ إِسْرَائِیلَ ، عَنْ عُثْمَانَ الثَّقَفِیِّ ، عَنِ ابْنِ أَبِی رَمْلَۃَ الشَّامِیِّ ، قَالَ : شَہِدْتُ مُعَاوِیَۃَ یَسْأَلُ زَیْدَ بْنَ أَرْقَمَ : ہَلْ شَہِدْتَ مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عِیدَیْنِ اجْتَمَعَا ؟ قَالَ : نَعَمْ ، قَالَ: فَکَیْفَ صَنَعَ ؟ قَالَ : صَلَّی الْعِیدَ ، ثُمَّ رَخَّصَ فِی الْجُمُعَۃِ ، قَالَ : مَنْ شَائَ أَنْ یُصَلِّیَ فَلْیُصَلِّ۔ (ابوداؤد 1063۔ احمد 4/372)",,,5896,,
5897,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، قَالَ : اجْتَمَعَ الْعِیدَانِ فِی یَوْمٍ ، فَقَامَ الْحَجَّاجُ فِی الْعِیدِ الأَوَّلِ ، فَقَالَ : مَنْ شَائَ أَنْ یُجَمِّعَ مَعَنَا فَلْیُجَمِّعْ ، وَمَنْ شَائَ أَنْ یَنْصَرِفَ فَلْیَنْصَرِفْ ، وَلاَ حَرَجَ ، فَقَالَ أَبُو الْبَخْتَرِیِّ ، وَمَیْسَرَۃُ : مَا لَہُ ، قَاتَلَہُ اللَّہُ تَعَالَی مِنْ أَیْنَ سَقَطَ عَلَی ہَذَا ؟۔",,,5897,,
5898,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا الْحَجَّاجُ ، عَنْ عَطَائٍ ، عَنْ عَلِیٍّ ) (ح) وَعَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ، عَنْ إِبْرَاہِیمَ ؛ فِی الْعِیدَیْنِ إِذَا اجْتَمَعَا ؟ قَالاَ : یُجْزِئُ أَحَدُہُمَا۔",,,5898,,
5899,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ: أَخْبَرَنَا حَجَّاجٌ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ رُفَیْعٍ، عَنِ الزُّبَیْرِ، قَالَ: یُجْزِئُ أَحَدُہُمَا۔",,,5899,,
5900,"حَدَّثَنَا مُعَاوِیَۃُ بن ہِشَامٍ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مُجَالِدٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : إِذَا کَانَ یَوْمُ جُمُعَۃٍ وَعِیدٍ ، أَجْزَأَ أَحَدُہُمَا مِنَ الآخَرِ۔",,,5900,,
5901,"حَدَّثَنَا شَرِیکٌ ، عَنْ زُبَیْدِ ، عَنِ ابْنِ أَبِی لَیْلَی، عَنْ عُمَرَ، قَالَ: صَلاَۃُ السَّفَرِ رَکْعَتَانِ ، وَالْجُمُعَۃُ رَکْعَتَانِ، وَالْعِیدَانِ رَکْعَتَانِ ، تَمَامٌ غَیْرُ قَصْرٍ ، عَلَی لِسَانِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔ (ابن ماجہ 1063۔ نسائی 1733)",,,5901,,
5902,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ شُعْبَۃَ ، عَنْ عَدِیِّ بْنِ ثَابِتٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : خَرَجَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَوْمَ عِیدِ فِطْرٍ ، أَوْ أَضْحَی فَصَلَّی بِالنَّاسِ رَکْعَتَیْنِ ثُمَّ انْصَرَفَ ، وَلَمْ یُصَلِّ قَبْلَہَا ، وَلاَ بَعْدَہَا۔",,,5902,,
5903,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ دَاوُدَ بْنِ قَیْسٍ ، قَالَ : حدَّثَنِی عِیَاضُ بْنُ عَبْدِ اللہِ بْنِ أَبِی سَرْحٍ ، عَنْ أَبِی سَعِیدٍ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَخْرُجُ یَوْمَ الْعِیدِ یَوْمَ الْفِطْرِ ، فَیُصَلِّی بِالنَّاسِ رَکْعَتَیْنِ ، ثُمَّ یُسَلِّمُ۔ (مسلم 605۔ نسائی 1785)",,,5903,,
5904,"حَدَّثَنَا وَکِیعٌ ، عَنْ دَاوُدَ بْنِ قَیْسٍ ، عَنْ عِیَاضٍ ، عَنْ أَبِی سَعِیدٍ ، قَالَ : إِنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ خَطَبَ یَوْمَ عِیدٍ عَلَی رَاحِلَتِہِ۔ (ابویعلی 1177۔ ابن حبان 2825)",,,5904,,
5905,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنْ مَیْسَرَۃَ أَبِی جَمِیلَۃَ ، قَالَ : شَہِدْتُ مَعَ عَلِیٍّ الْعِیدَ ، فَلَمَّا صَلَّی خَطَبَ عَلَی رَاحِلَتِہِ ، قَالَ : وَکَانَ عُثْمَانُ یَفْعَلُہُ۔",,,5905,,
5906,"حَدَّثَنَا أَبُوبَکْرِ بْنُ عَیَّاشٍ، عَنْ یَزِیدَ، عَنِ ابْنِ أَبِی لَیْلَی، قَالَ: صَلَّی بِنَا عَلِیٌّ الْعِیدَ، ثُمَّ خَطَبَ عَلَی رَاحِلَتِہِ۔",,,5906,,
5907,"حَدَّثَنَا مُحَمَّدُ بْنُ عُبَیْدٍ ، عَنْ إِسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنْ قَیْسٍ ، قَالَ : رَأَیْتُ الْمُغِیرَۃَ بْنَ شُعْبَۃَ یَخْطُبُ عَلَی بُخْتِیَّۃٍ۔",,,5907,,
5908,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنْ أَخِیہِ ، عَنْ أَبِی کَاہِلٍ ، قَالَ : رَأَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَخْطُبُ عَلَی نَاقَۃٍ خَرْمَاء ، وَحَبَشِیٌّ مُمْسِکٌ بِخِطَامِہَا۔ (ابن ماجہ 1284۔ احمد 4/306)",,,5908,,
5909,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا سَعِیدُ بْنُ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ شَہْرِ بْنِ حَوْشَبٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ غَنْمٍ ، عَنْ عَمْرِو بْنِ خَارِجَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ خَطَبَہُمْ وَہُوَ عَلَی رَاحِلَتِہِ ۔ قَالَ : وَإِنَّ رَاحِلَتَہُ لَتَقَصَعُ بِجِرَّتِہَا ، وَإِنَّ لُعَابَہَا لَیَسِیلُ بَیْنَ کَتِفَیَّ۔ (ترمذی 2121۔ احمد 4/187)",,,5909,,
5910,"حَدَّثَنَا ہَاشِمُ بْنُ الْقَاسِم ، عَنْ عِکْرِمَۃَ بْنِ عَمَّارٍ ، قَالَ : حدَّثَنَا الْہِرْمَاسُ بْنُ زِیَادٍ ، قَالَ : کُنْتُ رِدْفَ أَبی یَوْمِ الأَضْحَی ، وَرَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَخْطُبُ عَلَی نَاقَۃٍ بِمِنًی۔ (بخاری 2883۔ ابوداؤد 1949)",,,5910,,
5911,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی جَنَابٍ، عَنْ أَبِیہِ، عَنِ الْمُغِیرَۃِ بْنِ شُعْبَۃَ، قَالَ: خَطَبَنَا عَلِیٌّ یَوْمَ عِیدٍ عَلَی رَاحِلَتِہِ۔",,,5911,,
5912,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ شِبَاکٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانَ الإِمَامُ یَوْمَ الْعِیدِ یَبْدَأُ فَیُصَلِّی ، ثُمَّ یَرْکَبُ فَیَخْطُبُ۔",,,5912,,
5913,"حَدَّثَنَا الْمُحَارِبِیُّ ، عَنْ عَبْدِ الْمَلِکِ بْنِ عُمَیْرٍ ، أَنَّہُ سَمِعَہُ یَذْکُرُہُ ، قَالَ : رَأَیْتُ الْمُغِیرَۃَ بْنَ شُعْبَۃَ یَخْطُبُ النَّاسَ یَوْمَ الْعِیدِ ، عَلَی بَعِیرٍ۔",,,5913,,
5914,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانَ یُحِبُّ لِلنِّسَائِ أَنْ یُکَبِّرْنَ دُبُرَ الصَّلاَۃ أَیَّامَ التَّشْرِیقِ۔",,,5914,,
5915,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، قَالَ : کَانَ الْحَسَنُ لاَ یَرَی التَّکْبِیرَ عَلَی النِّسَائِ أَیَّامَ التَّشْرِیقِ۔",,,5915,,
5916,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ الْقَارِیِّ ، عَنْ عُبَیْدِ اللہِ بْنِ عَبْدِ اللہِ بْنِ عُتْبَۃَ ، قَالَ: مِنَ السُّنَّۃِ أَنْ یُکَبِّرَ الإِمَامُ عَلَی الْمِنْبَرِ فِی الْعِیدَیْنِ تِسْعًا قَبْلَ الْخُطْبَۃِ، وَسَبْعًا بَعْدَہَا۔(عبدالرزاق 5672)",,,5916,,
5917,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنِ الْحَسَنِ بْنِ أَبِی الْحَسْنَائِ ، عَنِ الْحَسَنِ ، قَالَ : یُکَبِّرُ یَوْمَ الْعِیدَیْنِ أَرْبَعَ عَشْرَۃَ تَکْبِیرَۃً۔",,,5917,,
5918,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ بُکَیْرِ بْنِ عَامِرٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : یَتَیَمَّمُ لِلْعِیدَیْنِ وَالْجِنَازَۃِ۔",,,5918,,
5919,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِیہِ ، عَنْ جَعْفَرِ بْنِ نَجِیحٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ؛ فِی الرَّجُلِ یُحْدِثُ فِی الْعِیدِ وَیَخَافُ الْفَوْتَ ، قَالَ : یَتَیَمَّمُ وَیُصَلِّی إِذَا خَافَ۔",,,5919,,
5920,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یُحْدِثُ یَوْمَ الْعِیدِ ، قَالَ : یَطْلُبُ الْمَائَ فَیَتَوَضَّأْ ، وَلاَ یَتَیَمَّمْ۔",,,5920,,
5921,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، قَالَ : أَخْبَرَنَا عَطَائٌ الْخُرَاسَانِیُّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : کَانَتِ الصَّلاَۃُ الَّتِی أَرَادَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یُحَرِّقَ عَلَی مَنْ تَخَلَّفَ عَنْہَا صَلاَۃَ الْعِشَائِ۔",,,5921,,
5922,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ حُمَیْدٍ ، وَغَیْرِہِ ، عَنِ الْحَسَنِ ، قَالَ : کَانَتِ الصَّلاَۃُ الَّتِی أَرَادَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یُحَرِّقَ عَلَی مَنْ تَخَلَّفَ عَنْہَا الْجُمُعَۃَ۔",,,5922,,
5923,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی صَالِح ، عَنْ أَبِی ہُرَیْرَۃَ ، فِی حَدِیثٍ ذَکَرَہُ عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أَنَّہُ قَالَ : ہِیَ الْعِشَائُ وَالْفَجْرُ۔ (بخاری 644۔ نسائی 921)",,,5923,,
5924,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ زُہَیْرٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الأَحْوَص ، قَالَ : سَمِعَہُ مِنْہُ ، عَنْ عَبْدِ اللہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أَنَّہُ قَالَ : ہِیَ الْجُمُعَۃُ۔",,,5924,,
5925,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَتَبْتُ إِلَی نَافِعٍ أَسْأَلُہُ عَنِ الْقَوْمِ یَکُونُونَ فِی الرَُسْتَاقِ وَیَحْضُرُہُمُ الْعِیدُ ، ہَلْ یَجْتَمِعُونَ فَیُصَلِّی بِہِمْ رَجُلٌ ؟ وَعَنِ الْجُمُعَۃِ ؟ فَکَتَبَ إِلَیَّ : أَمَّا الْعِیدُ فَإِنَّہُمْ یَجْتَمِعُونَ فَیُصَلِّی بِہِمْ رَجُلٌ ، وَأَمَّا الْجُمُعَۃُ فَلاَ عِلْمَ لِی بِہَا۔",,,5925,,
5926,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ عِکْرِمَۃَ ؛ أَنَّہُ قَالَ فِی الْقَوْمِ یَکُونُونَ فِی السَّوَادِ فِی السَّفَرِ فِی یَوْمِ عِیدِ فِطْرِ ، أَوْ أَضْحَی ، قَالَ : یَجْتَمِعُونَ فَیُصَلُّونَ ، وَیَؤُمُّہُمْ أَحَدُہُمْ۔",,,5926,,
5927,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ؛ فِی أَہْلِ الْقُرَی وَأَہْلِ السَّوَادِ یَحْضُرُہُمُ الْعِیدُ ، قَالَ : کَانَ لاَ یَرَی أَنْ یَخْرُجُوا فَیُصَلِّی بِہِمْ رَجُلٌ۔",,,5927,,
5928,"حَدَّثَنَا الْحَسَنُ بْنُ مُوسَی، قَالَ: حدَّثَنَا شَیْبَانُ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، قَالَ : سُئِلَ عَطَائُ بْنُ أَبِی رَبَاحٍ؟ قَالَ : إِذَا کَانَتْ قَرْیَۃً جَامِعَۃً فَلْیُصَلُّوا رَکْعَتَیْنِ مِثْلَ یَوْمِ الْجُمُعَۃِ ۔\n\nقَالَ یَحْیَی : وَسُئِلَ الْحَکَمُ بْنُ عُتَیْبَۃَ ؟ فَقَالَ : لاَ جُمُعَۃَ إِلاَّ مَعَ الإِمَامِ فِی الْمَسْجِدِ الْجَامِعِ ۔\n\nقَالَ یَحْیَی ، وَقَالَ قَتَادَۃُ : لاَ أَعْلَمُ الْجُمُعَۃَ إِلاَّ مَعَ السُّلْطَانِ فِی أَمْصَارِ الْمُسْلِمِینَ ۔\n\nقَالَ یَحْیَی : یُقَالُ : لاَ جُمُعَۃَ ، وَلاَ أَضْحَی ، وَلاَ فِطْرَ إِلاَّ لِمَنْ حَضَرَ مَعَ الإِمَام۔",,,5928,,
5929,"حَدَّثَنَا مُعَمَّرُ بْنُ سُلَیْمَانَ الرَّقِّیُّ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، قَالَ : کَتَبَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ إِلَی أَہْلِ الْقُرَی یَأْمُرہُمْ أَنْ یُصَلُّوا الْفِطْرَ وَالأَضْحَی ، وَأَنْ یُجَمِّعُوا۔",,,5929,,
5930,"حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ ، عَنْ مُحَمَّدِ بْنِ رَاشِدٍ ، عَنْ مَکْحُولٍ ، قَالَ : إِذَا کَانَتِ الْقَرْیَۃُ لَہَا أَمِیرٌ فَعَلَیْہِمُ الْجُمُعَۃُ۔",,,5930,,
5931,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ أَبِی الْعُمَیْسِ ، عَنْ عَلِیِّ بْنِ الأَقْمَرِ ، قَالَ : خَرَجَ مَسْرُوقٌ ، وَعُرْوَۃُ بْنُ الْمُغِیرَۃِ إِلَی بَدْوٍ لَہُمْ ، قَالَ : فَحَضَرَتِ الْجُمُعَۃُ ، فَلَمْ یُجَمِّعُوا ، وَحَضَرَ الْفِطْرُ فَلَمْ یُفْطِرُوا۔",,,5931,,
5932,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَسَنٍ ، عَنْ مُطَرِّفٍ ، عَمَّنْ سَمِعَ عَطَائً ، وَمُجَاہِدًا ، قَالاَ : یُقْضَی التَّکْبِیرُ فِی الْعِیدَیْنِ ، کَمَا تُقْضَی الصَّلاَۃ۔",,,5932,,
5933,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : یُصَلِّی رَکْعَتَیْنِ وَیُکَبِّرُ۔",,,5933,,
5934,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ حَمَّادٍ ، قَالَ : یُصَلِّی مِثْلَ صَلاَتِہِ ، وَیُکَبِّرُ مِثْلَ تَکْبِیرِہِ۔",,,5934,,
5935,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنِ ابْنِ عَوْنٍ ، عَنْ أَنَسِ بْنِ سِیرِینَ ، قَالَ : کَانُوا یَقُولُونَ : إِذَا شَکَّ الرَّجُلُ فِی صَلاَۃِ الْمَغْرِبِ فَأَرَادَ أَنْ یُعِیدَ ، صَلَّی رَکْعَۃً فَشَفَّعَہَا ، ثُمَّ صَلَّی ثَلاَثَۃً۔",,,5935,,
5936,حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنِ ابْنِ عَوْنٍ ، عَنِ الْقَاسِمِ ، مِثْلَہُ۔,,,5936,,
5937,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إِدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنْ ہِلاَلِ بْنِ یَِسَافٍ ، قَالَ : أَخَذَ بِیَدِی زِیَادُ بْنُ أَبِی الْجَعْدِ فَأَوْقَفَنِی عَلَی شَیْخٍ بِالرَّقَّۃِ ، یُقَالَ لَہُ : وَابِصَۃُ بْنُ مَعْبَدٍ ، فَقَالَ : صَلَّی رَجُلٌ خَلْفَ الصَّفِّ وَحْدَہُ فَأَمَرَہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یُعِیدَ۔ (ترمذ ی230۔ احمد 4/228)",,,5937,,
5938,"حَدَّثَنَا مُلاَزِمُ بْنُ عَمْرٍو ، عَنْ عَبْدِ اللہِ بْنِ بَدْرٍ ، قَالَ : حدَّثَنِی عَبْدُ الرَّحْمَنِ بْنُ عَلِیِّ بْنِ شَیْبَانَ ، عَنْ أَبِیہِ عَلِیِّ بْنِ شَیْبَانَ ، وَکَانَ مِنَ الْوَفْدِ ، قَالَ : خَرَجْنَا حَتَّی قَدِمْنَا عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَبَایَعْنَاہُ وَصَلَّیْنَا خَلْفَہُ ، فَرَأَی رَجُلاً یُصَلِّی خَلْفَ الصَّفِّ وَحْدَہُ ، فَوَقَفَ عَلَیْہِ نَبِیُّ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَتَّی انْصَرَفَ ، فَقَالَ : اسْتَقْبِلْ صَلاَتَکَ ، فَلاَ صَلاَۃَ لِلَّذِی خَلْفَ الصَّفِّ۔",,,5938,,
5939,"حَدَّثَنَا حَفْصٌ ، عَنْ عَمْرِو بْنِ مَرْوَانَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : یُعِیدُ۔",,,5939,,
5940,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : لاَ یَقُمْ وَحْدَہُ۔",,,5940,,
5941,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ عَمْرِو بْنِ مُرۃ : عَنْ ہِلاَلِ بْنِ یَِسَافٍ ، عَنْ عَمْرِو بْنِ رَاشِدٍ ، عَنْ وَابِصَۃَ بْنِ مَعْبَدٍ ؛ أَنَّ رَجُلاً صَلَّی خَلْفَ الصُفُوفِ وَحْدَہُ ، فَأَمَرَہُ رَسُول اللہ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یُعِیدَ الصَلاَۃَ۔ (ابوداؤد 682۔ احمد 4/228)",,,5941,,
5942,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ، عَنْ جُوَیْبِرٍ، عَنِ الضَّحَّاکِ، عَنْ حُذَیْفَۃَ ، قَالَ: سُئِلَ عَنْ رَجُلٍ صَلَّی خَلْفَ الصُّفُوفِ وَحْدَہُ ؟ قَالَ : لاَ یُعِیدُ۔",,,5942,,
5943,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، وَعَمْرٍو ، عَنِ الْحَسَنِ ، قَالَ : یُجْزِئُہُ۔",,,5943,,
5944,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یَدْخُلُ الْمَسْجِدَ فَلاَ یَسْتَطِیعُ أَنْ یَدْخُلَ فِی الصَّفِّ ، قَالَ : کَانَ یَرَی ذَلِکَ یُجْزِئُہُ إِنْ صَلَّی خَلْفَہُ۔",,,5944,,
5945,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ سَلمِ بْنِ أَبِی الذَّیَّالِ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یُسْبَقُ بِرَکْعَۃٍ فَیُحْدِثُ الإِمَام، فَیَأْخُذُ بِیَدِ الَّذِی سُبِقَ فَیُقَدِّمُہُ، کَیْفَ یَصْنَعُ؟ قَالَ: یُصَلِّی رَکْعَۃً وَیَجْلِسُ، ثُمَّ یَبْنِی عَلَی صَلاَۃِ الْقَوْمِ، فَإِذَا أَتَمَّ بِہِمْ أَرْبَعًا جَلَسَ فَتَشَہَّدَ ، ثُمَّ أَخَذَ بِیَدِ رَجُلٍ فَسَلَّمَ ، ثُمَّ قَامَ الرَّجُلُ فَصَلَّی رَکْعَتَہُ الَّتِی سُبِقَ بِہَا۔",,,5945,,
5946,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ زَیْدٍ ، عَنْ أَبِی عَبْدِ اللہِ الشَّقَرِیِّ ، عَنْ إِبْرَاہِیمَ ؛ فِی رَجُلٍ صَلَّی رَکْعَۃً فَأَحْدَثَ ، فَأَخَذَ بِیَدِ رَجُلٍ فَقَدَّمَہُ ، وَقَدْ فَاتَتْہُ تِلْکَ الرَّکْعَۃُ ، قَالَ : یُصَلِّی بِہِمْ بَقِیَّۃَ صَلاَتِہِمْ ، فَإِذَا أَتَمَّ أَخَذَ بِیَدِ رَجُلٍ مِمَّنْ شَہِدَ تِلْکَ الرَّکْعَۃَ ، فَقَدَّمَہُ فَسَلَّمَ بِہِمْ ، ثُمَّ قَامَ فَقَضَی تِلْکَ الرَّکْعَۃَ۔",,,5946,,
5947,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إِسْرَائِیلُ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَرْقَمَ بْنِ شُرَحْبِیلَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لَمَّا جَائَ إِلَی أَبِی بَکْرٍ وَہُوَ فِی الصَّلاَۃ فِی مَرَضِہِ ، أَخَذَ مِنَ الْقِرَائَۃِ مِنْ حَیْثُ بَلَغَ أَبُو بَکْرٍ۔ (احمد 1/355)",,,5947,,
5948,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إِسْرَائِیلُ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ؛ فِی رَجُلٍ أَحْدَثَ فِی الصَّلاَۃ ، فَأَخَذَ بِیَدِ رَجُلٍ فَقَدَّمَہُ ، قَالَ : تُجْزِئُہِ قِرَائَتُہُ إِنْ کَانَ قَرَأَ ، وَتَکْبِیرُہُ إِنْ کَانَ کَبَّرَ۔",,,5948,,
5949,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ ہِشَامٍ ، قَالَ : کَانَ الْحَسَنُ یَقُولُ فِی الَّذِی یُقَدِّمُہُ الإِمَامُ : إِنْ شَائَ قَرَأَ مِنْ حَیْثُ انْتَہَی الإِمَامُ ، وَإِنْ شَائَ اخْتَصَّ بَعْضَ السُّوَرِ۔",,,5949,,
5950,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنِ حَجَّاجٍ ، عَنْ رَجُلٍ ، عَنْ عَمْرِو بْنِ الْحَارِثِ بْنِ أَبِی ضِرَارٍ ، عَنْ عُمَرَ بْنِ الْخَطَّابِ ؛ فِی الرَّجُلِ إِذَا رَعَفَ فِی الصَّلاَۃِ ، قَالَ : یَنْفَتِلُ فَیَتَوَضَّأُ ، ثُمَّ یَرْجِعُ فَیُصَلِّی ، وَیَعْتَدُّ بِمَا مَضَی۔",,,5950,,
5951,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ، عَنْ حَجَّاجٍ، قَالَ: حدَّثَنِی شَیْخٌ مِنْ أَہْلِ الْحَدِیثِ، عَنْ أَبِی بَکْرٍ، بِمِثْلِ قَوْلِ عُمَرَ۔",,,5951,,
5952,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ، عَنْ سَعِیدٍ، عَنْ قَتَادَۃَ، عَنْ خِلاَسٍ، عَنْ عَلِیٍّ، قَالَ: إِذَا رَعَفَ الرَّجُلُ فِی صَلاَتِہِ، أَوْ قَائَ فَلْیَتَوَضَّأْ ، وَلاَ یَتَکَلَّمْ ، وَلْیَبْنِ عَلَی صَلاَتِہِ۔",,,5952,,
5953,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا ابْنُ أَبِی لَیْلَی ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : مَنْ رَعَفَ فِی صَلاَتِہِ فَلْیَنْصَرِفْ فَلْیَتَوَضَّأْ ، فَإِنْ لَمْ یَتَکَلَّمْ بَنَی عَلَی صَلاَتِہِ ، وَإِنْ تَکَلَّمَ اسْتَأْنَفَ الصَّلاَۃَ۔",,,5953,,
5954,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عِمْرَانَ بْنِ ظَبْیَانَ ، عَنْ أَبِی تِحْیَی حُکَیْمِ بْنِ سَعْدٍ ، عَنْ سَلْمَانَ ، قَالَ : إِذَا أَحْدَثَ أَحَدُکُمْ فِی الصَّلاَۃِ فَلْیَنْصَرِفْ غَیْرَ وَاعٍ لِصُنْعِہِ فَلْیَتَوَضَّأْ ، ثُمَّ لْیَعُدْ فِی آیَتِہِ الَّتِی کَانَ یَقْرَأُ۔",,,5954,,
5955,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عَلِیُّ بْنُ صَالِحٍ ، وَإِسْرَائِیلُ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ ، عَنْ عَلِیٍّ ، قَالَ : إِذَا وَجَدَ أَحَدُکُمْ فِی بَطْنِہِ رزًّا ، أَوْ قَیْئًا ، أَوْ رُعَافًا فَلْیَنْصَرِفْ ، فَلْیَتَوَضَّأْ ، ثُمَّ لِیَبْنِ عَلَی صَلاَتِہِ مَا لَمْ یَتَکَلَّمْ۔",,,5955,,
5956,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّ عَلْقَمَۃَ رَعَفَ فِی الصَّلاَۃِ ، فَأَخَذَ بِیَدِ رَجُلٍ فَقَدَّمَہُ ، ثُمَّ ذَہَبَ فَتَوَضَّأَ ، ثُمَّ جَائَ فَبَنَی عَلَی مَا بَقِیَ مِنْ صَلاَتِہِ۔,,,5956,,
5957,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، عَنْ طَاوُوسٍ ، قَالَ : إِذَا رَعَفَ الرَّجُلُ فِی صَلاَتِہِ انْصَرَفَ فَتَوَضَّأَ ، ثُمَّ بَنَی عَلَی مَا بَقِیَ مِنْ صَلاَتِہِ۔",,,5957,,
5958,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، قَالَ : أَبْصَرْتُ سَالِمَ بْنَ عَبْدِ اللہِ صَلَّی صَلاَۃَ الْغَدَاۃِ رَکْعَۃً ، ثُمَّ رَعَفَ ، فَخَرَجَ فَتَوَضَّأَ ، ثُمَّ جَائَ فَبَنَی عَلَی مَا بَقِیَ مِنْ صَلاَتِہِ۔",,,5958,,
5959,"حَدَّثَنَا ہُشَیْمٌ ، وَابْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، وَالشَّعْبِیِّ ، أَنَّہُمَا قَالاَ فِی الْحَدَثِ وَالرُّعَافِ : یَنْصَرِفُ فَیَتَوَضَّأُ ، فَإِنْ تَکَلَّمَ اسْتَأْنَفَ الصَّلاَۃَ ، وَإِنْ لَمْ یَتَکَلَّمْ بَنَی عَلَی صَلاَتِہِ۔",,,5959,,
5960,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّہُ کَانَ یَقُولُ فِیمَنْ رَعَفَ فِی صَلاَتِہِ ، قَالَ : یَنْصَرِفُ فَیَتَوَضَّأُ ، ثُمَّ یَبْنِی عَلَی مَا بَقِیَ مِنْ صَلاَتِہِ مَا لَمْ یَتَکَلَّمْ ، فَإِنْ تَکَلَّمَ اسْتَأْنَفَ الصَّلاَۃَ۔",,,5960,,
5961,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا عَبْدُ الْمَلِکِ ، عَنْ عَطَائٍ ؛ أَنَّہُ قَالَ مِثْلَ ذَلِکَ۔",,,5961,,
5962,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إِبْرَاہِیمَ ؛ فِی صَاحِبِ الْقَیْئِ ، وَالرُّعَافِ ، وَالْقُبْلَۃِ : یَنْصَرِفُ فَیَتَوَضَّأُ ، فَإِنْ لَمْ یَتَکَلَّمْ بَنَی عَلَی مَا بَقِیَ ، وَإِنْ تَکَلَّمَ اسْتَأْنَفَ ۔ وَکَانَ یَقُولُ فِی صَاحِبِ الْغَائِطِ وَالْبَوْلِ : یَنْصَرِفُ فَیَتَوَضَّأُ ، وَیَسْتَقْبِلُ الصَّلاَۃ۔",,,5962,,
5963,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانُوا یُشَدِّدُونَ فِی الْغَائِطِ وَالْبَوْلِ ، وَیَرَوْنَ أَنَّہُ أَشَدُّ مِنَ الْمَنِیِّ وَالدَّمِ۔",,,5963,,
5964,"حَدَّثَنَا عَبْدُالأَعْلَی، عَنْ بُرْدٍ، عَنْ مَکْحُولٍ، أَنَّہُ کَانَ یَقُولُ: إِنَّہُ إِذَا رَعَفَ الرَّجُلُ فِی صَلاَتِہِ، فَإِنَّہُ یَنْصَرِفُ فَیَتَوَضَّأُ ، ثُمَّ یَجِیئُ فَیَبْنِی عَلَی مَا مَضَی ، مَا لَمْ یَتَکَلَّمْ إِنْ شَائَ ، فَإِنْ أَحْدَثَ أَعَادَ الْوُضُوئَ وَأَعَادَ الصَّلاَۃ۔",,,5964,,
5965,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا عَبْدُ الْحَمِیدِ الْمَدَنِیُّ ، عَنْ یَزِیدَ بْنِ عَبْدِ اللہِ بْنِ قُسَیْطٍ ، قَالَ : رَأَیْتُ سَعِیدَ بْنَ الْمُسَیَّبِ رَعَفَ وَہُوَ فِی صَلاَتِہِ ، فَأَتَی دَارَ أُمِّ سَلَمَۃَ زَوْجِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَتَوَضَّأَ وَلَمْ یَتَکَلَّمْ ، وَبَنَی عَلَی صَلاَتِہِ۔",,,5965,,
5966,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إِسْمَاعِیلُ بْنُ أَبِی خَالِدٍ ، عَنْ عَامِرٍ ، قَالَ : إِذَا أَحْدَثْتَ فِی الصَّلاَۃِ ، فَصَلِّ مَا بَقِیَ وَإِنْ تَکَلَّمْتَ۔",,,5966,,
5967,"حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ خِلاَسٍ ، عَنْ علی ؛ فِی رَجُلٍ یُصِیبُہُ الْقَیْئُ وَالرُّعَافُ فِی الصَّلاَۃِ ، قَالَ : یَنْفَتِلُ فَیَتَوَضَّأُ ، ثُمَّ یَبْنِی عَلَی صَلاَتِہِ مَا لَمْ یَتَکَلَّمْ۔",,,5967,,
5968,حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ سَعِیدٍ ، عَنْ أَبِی معشرٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَبْدِ اللہِ ، بِمِثْلِہِ ، إِلاَّ أَنَّہُ لَمْ یَذْکُرِ الْقَیْئَ۔,,,5968,,
5969,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مَنْصُورٌ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : أَجْمَعُوا عَلَی أَنَّہُ إِذَا تَکَلَّمَ اسْتَأْنَفَ ، وَأَنَا أُحِبُّ أَنْ یَتَکَلَّمَ وَیَسْتَأْنِفَ الصَّلاَۃَ۔",,,5969,,
5970,"حَدَّثَنَا أَبُو بَکْرٍ ، قَالَ : حَدَّثَنَا رَبِیعٌ ، عَنِ الْحَسَنِ ، قَالَ : إِذَا اسْتَدْبَرَ الرَّجُلُ الْقِبْلَۃَ اسْتَقْبَلَ ، وَإِنِ الْتَفَتَ عَنْ یَمِینِہِ ، أَوْ عَنْ شِمَالِہِ مَضَی فِی صَلاَتِہِ۔",,,5970,,
5971,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : أَحَبُّ إِلَیَّ فِی الرُّعَافِ إِذَا اسْتَدْبَرَ الْقِبْلَۃَ أَنْ یَسْتَقْبِلَ۔",,,5971,,
5972,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، عَنْ عَمِّہِ ، قَالَ : سَاعَۃٌ مَا أَتَیْتُ عَبْدَ اللہِ بْنَ مَسْعُودٍ فِیہَا إِلاَّ وَجَدْتُہُ یُصَلِّی ؛ مَا بَیْنَ الْمَغْرِبِ وَالْعِشَائِ ، وَکَانَ یَقُولُ : ہِیَ سَاعَۃُ غَفْلَۃٍ۔",,,5972,,
5973,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مُوسَی بْنُ عُبَیْدَۃَ ، عَنْ أَخِیہِ عَبْدِ اللہِ بْنِ عُبَیْدَۃَ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ، قَالَ : صَلاَۃُ الأَوَّابِینَ مَا بَیْنَ أَنْ یَنْکَفِتَ أَہْلُ الْمَغْرِبِ إِلَی أَنْ یُثَوَّب إِلَی الْعِشَائِ۔",,,5973,,
5974,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الأَعْمَشِ ، عَنِ الْعَلاَئِ بْنِ بَدْرٍ ، عَنْ أَبِی الشَّعْثَائِ ، قَالَ : قَالَ سَلْمَانُ : عَلَیْکُمْ بِالصَّلاَۃ فِیمَا بَیْنَ الْعِشَائَیْنِ ، فَإِنَّہُ یُخَفِّفُ عَنْ أَحَدِکُمْ مِنْ حِزْبِہِ ، وَیُذْہِبُ عَنْہُ مَلْغَاہُ أَوَّلَ اللَّیْلِ ، فَإِنَّ مَلْغَاہُ أَوَّلَ اللَّیْلِ مَہْدَنَۃٌ ، أَوْ مَذْہَبَۃٌ لآخِرِہِ۔",,,5974,,
5975,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ وِقَائِ بْنِ إِیَاسٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ أَنَّہُ کَانَ یُصَلِّی مَا بَیْنَ الْمَغْرِبِ وَالْعِشَائِ ، وَیَقُولُ : ہِیَ نَاشِئَۃُ اللَّیْلِ۔",,,5975,,
5976,حَدَّثَنَا عَبْدُ اللہِ بْنِ دَاوُد ، عَنْ بُکَیْرِ بنِ عَامِرٍ ، عَنِ الشَّعْبِیِّ ، عَنْ شُرَیْحٍ ؛ أَنَّہُ کَانَ یُصَلِّی مَا بَیْنَ الْمَغْرِبِ وَالْعِشَائِ۔,,,5976,,
5977,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ عُمَارَۃَ بْنِ زَاذَانَ ، عَنْ ثَابِتٍ ، عَنْ أَنَسٍ ؛ أَنَّہُ کَانَ یُصَلِّی مَا بَیْنَ الْمَغْرِبِ وَالْعِشَائِ ، وَیَقُولُ : ہِیَ نَاشِئَۃُ اللَّیْلِ۔",,,5977,,
5978,"حَدَّثَنَا یَحْیَی بْنُ أَبِی بُکَیْرٍ ، عَنْ إِبْرَاہِیمَ بْنِ نَافِعٍ ، قَالَ : کَانَ الْحَسَنُ بْنُ مُسْلِمٍ یُصَلِّی مَا بَیْنَ الْمَغْرِبِ وَالْعِشَائِ ، قَالَ : وَزَعَمَ الْحَسَنُ أَنَّ طَاوُوسًا لَمْ یَکُنْ یَرَاہُ شَیْئًا۔",,,5978,,
5979,"حَدَّثَنَا یَحْیَی بْنُ أَبِی بُکَیْرٍ ، قَالَ : حدَّثَنَا إِبْرَاہِیمُ بْنُ نَافِعٍ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ، قَالَ : لَمْ یَکُنْ یَعُدُّہَا مِنْ صَلاَۃِ اللَّیْلِ۔",,,5979,,
5980,"حَدَّثَنَا یَحْیَی بْنُ أَبی بُکَیْر ، قَالَ : حدَّثَنَا إِبْرَاہِیمُ بْنُ نَافِعٍ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ؛ أَنَّ عَبْدَ اللہِ بْنَ عُمَرَ لَمْ یَکُنْ یُصَلِّیہَا إِلاَّ فِی رَمَضَانَ ، یَعْنِی مَا بَیْنَ الْمَغْرِبِ وَالْعِشَائِ۔",,,5980,,
5981,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشرٍ ، قَالَ : حدَّثَنَا سَعِیدٌ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسٍ ؛ فِی قَوْلِہِ : {تَتَجَافَی جُنُوبُہُمْ عَنِ الْمَضَاجِعِ} قَالَ : کَانُوا یَتَطَوَّعُونَ فِیمَا بَیْنَ الصَّلاَتَیْنِ ؛ الْمَغْرِبِ وَالْعِشَائِ ، فَیُصَلُّونَ۔",,,5981,,
5982,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ، عَنْ إِسْرَائِیلَ، عَنْ مَیْسَرَۃَ بْنِ حَبِیبٍ النَّہْدِیِّ ، عَنِ الْمِنْہَالِ ، عَنْ زِرِّ بْنِ حُبَیْشٍ، عَنْ حُذَیْفَۃَ ، قَالَ : أَتَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَصَلَّیْتُ مَعَہُ الْمَغْرِبَ ، ثُمَّ قَامَ یُصَلِّی حَتَّی صَلاَۃِ الْعِشَائِ۔ (ترمذی 3781۔ احمد 5/404)",,,5982,,
5983,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إِسْرَائِیلُ ، عَنْ ثُوَیْرِ بْنِ أَبِی فَاخِتَۃَ ، عَنْ أَبِیہِ ، عَنْ عَلِیٍّ ، قَالَ : ذُکِرَ لَہُ أَنَّ مَا بَیْنَ الْمَغْرِبِ وَالْعِشَائِ صَلاَۃُ الْغَفْلَۃِ ، فَقَالَ عَلِیٌّ : فِی الْغَفْلَۃِ وَقَعْتُمْ۔",,,5983,,
5984,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مُوسَی بْنُ عُبَیْدَۃَ ، عَنْ أَیُّوبَ بْنِ خَالِدٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : مَنْ صَلَّی أَرْبَعًا بَعْدَ الْمَغْرِبِ کَانَ کَالْمُعَقِّبِ غَزْوَۃً بَعْدَ غَزْوَۃٍ۔",,,5984,,
5985,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ ، قَالَ : صَلَّیْتُ إِلَی جَنْبِ الْحَسَنِ بْنِ عَلِیٍّ الْمَغْرِبَ ، ثُمَّ صَلَّیْتُ رَکْعَتَیْنِ بَعْدَ الْمَغْرِبِ ، ثُمَّ قُمْتُ أُصَلِّی فَنَہَرَنِی ، وَقَالَ : إِنَّمَا ہُمَا رَکْعَتَانِ۔",,,5985,,
5986,"حَدَّثَنَا أَبُو بَکْرٍ ، قَالَ : حَدَّثَنَا عَبْدُ الْعَزِیزِ بْنُ عُمَرَ ، قَالَ : سَمِعْتُ مَکْحُولاً ، یَقُولُ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ صَلَّی رَکْعَتَیْنِ بَعْدَ الْمَغْرِبِ ، یَعْنِی قَبْلَ أَنْ یَتَکَلَّمَ ، رُفِعَتْ صَلاَتُہُ فِی عِلِّیِّینَ۔",,,5986,,
5987,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا جَرِیرُ بْنُ حَازِمٍ ، عَنْ عِیسَی بْنِ عَاصِمِ الأَسَدِیِّ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ: لَقَدْ تَرَکْتُ ، أَوْ لَوْ تَرَکْتُ الرَّکْعَتَیْنِ بَعْدَ الْمَغْرِبِ لَخَشِیتُ أَنْ لاَ یُغْفَرَ لِی۔",,,5987,,
5988,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا فُضَیْلُ بْنُ غَزْوَانَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یُحْیِی مَا بَیْنَ الظُّہْرِ وَالْعَصْرِ۔",,,5988,,
5989,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ إِبْرَاہِیمَ بْنِ مُہَاجِرٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانُوا یُشْبِہُونَ صَلاَۃَ الْعِشَائِ ، وَمَا بَیْنَ الظُّہْرِ وَالْعَصْرِ بِصَلاَۃِ اللَّیْلِ۔",,,5989,,
5990,"حَدَّثَنَا عَبْدُاللہِ بْنُ دَاوُد، عَنْ بُکَیْرِ بْنِ عَامِرٍ، عَنِ الشَّعْبِیِّ، قَالَ: کَانَ عَبْدُاللہِ یُصَلِّی مَا بَیْنَ الظُّہْرِ وَالْعَصْرِ۔",,,5990,,
5991,"حَدَّثَنَا جَرِیرٌ ، عَنْ أَبِی سِنَانٍ ، عَنْ أَبِی صَالِحٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَرْبَعُ رَکَعَاتٍ قَبْلَ الظُّہْرِ یُعْدَلْنَ بِصَلاَۃِ السَّحَرِ۔",,,5991,,
5992,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ سَعِیدِ بْنِ مَسْرُوقٍ ، عَنِ الْمُسَیَّبِ بْنِ رَافِعٍ ، قَالَ : قَالَ أَبُو أَیُّوبَ الأَنْصَارِیُّ: یَا رَسُولَ اللہِ ، مَا أَرْبَعُ رَکَعَاتٍ تُوَاظِبُ عَلَیْہِنَّ قَبْلَ الظُّہْرِ ؟ فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنَّ أَبْوَابَ الْجَنَّۃِ تُفْتَحُ عِنْدَ زَوَالِ الشَّمْسِ ، فَلاَ تُرْتَجُّ حَتَّی تُقَامَ الصَّلاَۃُ ، فَأُحِبُّ أَنْ أُقَدِّمَ۔ (ابوداؤد 1264۔ احمد 5/416)",,,5992,,
5993,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا شَرِیکٌ ، عَنِ الأَعْمَشِ ، عَنِ الْمُسَیَّبِ بْنِ رَافِعٍ ، عَنْ عَلِیِّ بْنِ الصَّلْتِ ، عَنْ أَبِی أَیُّوبَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، بِنَحْوِہِ۔ (بخاری 2403۔ احمد 5/418)",,,5993,,
5994,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُحَمَّدِ بْنِ قَیْسٍ ، عَنْ عَوْنِ بْنِ عَبْدِ اللہِ بْنِ عُتْبَۃَ ، عَنْ أَبِیہِ ، قَالَ : صَلَّیْتُ مَعَ عُمَرَ أَرْبَعَ رَکَعَاتٍ قَبْلَ الظُّہْرِ فِی بَیْتِہِ۔",,,5994,,
5995,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ حُصَیْنٍ ، عَنْ عَمْرِو بْنِ مَیْمُونٍ ، قَالَ : لَمْ یَکُنْ أَصْحَابُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَتْرُکُونَ أَرْبَعَ رَکَعَاتٍ قَبْلَ الظُّہْرِ ، وَرَکْعَتَیْنِ قَبْلَ الْفَجْرِ عَلَی حَالٍ۔",,,5995,,
5996,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ حُصَیْنٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : قَالَ عَبْدُ اللہِ : أَرْبَعٌ قَبْلَ الظُّہْرِ لاَ یُسَلِّمُ بَیْنَہُنَّ إِلاَّ أَنْ یَتَشَہَّدَ۔",,,5996,,
5997,"حَدَّثَنَا وَکِیعٌ، عَنْ مِسْعَرٍ، عَنْ أَبِی صَخْرَۃَ، عَنْ عَبْدِاللہِ بْنِ عُتْبَۃَ، قَالَ: رَأَیْتُ عُمَرَ یُصَلِّی أَرْبَعًا قَبْلَ الظُّہْرِ۔",,,5997,,
5998,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ عُمَرَ بْنِ حَمْزَۃَ ، عَنِ ابْنِ أَبِی نَمِرٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّہُ کَانَ یُصَلِّی أَرْبَعًا قَبْلَہَا۔,,,5998,,
5999,"حَدَّثَنَا وَکِیعٌ ، عَنْ بَشِیرٍ ، عَنْ شَیْخٍ مِنَ الأَنْصَارِ ، عَنْ أَبِیہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ صَلَّی أَرْبَعًا قَبْلَ الظُّہْرِ کُنَّ لَہُ کَعِتْقِ رَقَبَۃٍ مِنْ وَلَدِ إِسْمَاعِیلَ۔ (طبرانی 965)",,,5999,,
6000,حَدَّثَنَا وَکِیعٌ ، عَنْ عِکْرِمَۃَ بْنِ عَمَّارٍ ، عَنْ سَالِمٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یُصَلِّی قَبْلَ الظُّہْرِ أَرْبَعًا۔,,,6000,,
6001,حَدَّثَنَا یَزِیدُ ، عَنِ الأَصْبَغِ ، عَنِ الْقَاسِمِ بْنِ أَبِی أَیُّوبَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ أَنَّہُ کَانَ یُصَلِّی قَبْلَہَا أَرْبَعًا۔,,,6001,,
6002,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ الْجُرَیْرِیِّ ، عَنْ عَبْدِ اللہِ بْنِ شَقِیقٍ ، عَنْ عَائِشَۃَ ، قَالَتْ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّی أَرْبَعًا قَبْلَ الظُّہْرِ۔ (بخاری 1182۔ ابوداؤد 1247)",,,6002,,
6003,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ قَابُوسَ ، عَنْ أَبِیہِ ، قَالَ : أَرْسَلَ أَبِی إِلَی عَائِشَۃَ : أَیُّ صَلاَۃٍ کَانَتْ أَحَبَّ إِلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یُوَاظِبَ عَلَیْہَا ؟ قَالَتْ : کَانَ یُصَلِّی أَرْبَعًا قَبْلَ الظُّہْرِ ، یُطِیلُ فِیہِنَّ الْقِیَامَ ، وَیُحْسِنُ فِیہِنَّ الرُّکُوعَ وَالسُّجُودَ۔",,,6003,,
6004,"حَدَّثَنَا جَرِیرٌ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ رُفَیْعٍ ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ یُصَلِّی أَرْبَعًا قَبْلَ الظُّہْرِ ، یُطِیلُہُنَّ۔",,,6004,,
6005,حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ رُفَیْعٍ ، عَنِ ابْنِ عُمَرَ ، مِثْلَہُ۔,,,6005,,
6006,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُحَمَّدِ بْنِ قَیْسٍ ، عَنْ أَبِی عَوْنٍ الثَّقَفِیِّ ؛ أَنَّ الْحَسَنَ بْنَ عَلِیٍّ کَانَ یُصَلِّی أَرْبَعًا قَبْلَ الظُّہْرِ ، یُطِیلُ فِیہِنَّ ۔ قَالَ أَبُو عَوْنٍ : إِنْ کَانَ خَفِیفَ الْقِرَائَۃِ فَمِنَ الطِّوَالِ ، وَإِنْ کَانَ بَطِیئَ الْقِرَائَۃِ فَمِنَ الْمِئِینَ۔",,,6006,,
6007,"حَدَّثَنَا ابن أَبِی غَنِیَّۃ ، عَنِ الصَّلْتِ بْنِ بَہْرَامَ ، عَمَّنْ حَدَّثَہُ ، عَنْ حُذَیْفَۃَ بْنِ أَسِیدٍ ، قَالَ : رَأَیْتُ عَلِیًّا إِذَا زَالَتِ الشَّمْسُ صَلَّی أَرْبَعًا طِوَالاً۔",,,6007,,
6008,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ بُدَیْلٍ ، قَالَ : حدَّثَنِی أَبْطَنُ النَّاسِ بِعَبْدِ اللہِ بْنِ مَسْعُودٍ : أَنَّہُ کَانَ یُصَلِّی فِی بَیْتِہِ إِذَا زَالَتِ الشَّمْسُ أَرْبَعَ رَکَعَاتٍ ، یُطِیلُ فِیہِنَّ ، فَإِذَا تَجَاوَبَ الْمُؤَذِّنُونَ خَرَجَ ، فَجَلَسَ فِی الْمَسْجِدِ حَتَّی تُقَامَ الصَّلاَۃُ۔",,,6008,,
6009,"حَدَّثَنَا مُحَمَّدُ بْنُ عُبَیْدٍ ، عَنِ الأَعْمَشِ ، عَنِ الْمُسَیَّبِ بْنِ رَافِعٍ ، عَنْ رَجُلٍ ؛ أَنَّ عُمَرَ قَرَأَ فِی الأَرْبَعِ قَبْلَ الظُّہْرِ بِـ : (ق)۔",,,6009,,
6010,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الأَعْمَشِ ، عَنِ الْمُسَیَّبِ بْنِ رَافِعٍ ؛ أَنَّ أَبَا أَیُّوبَ کَانَ یُصَلِّی ثَمَانَ رَکَعَاتٍ قَبْلَ الظُّہْرِ۔,,,6010,,
6011,حَدَّثَنَا عَبْدَۃُ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ؛ أَنَّہُ کَانَ یُصَلِّی ثَمَانِ رَکَعَاتِ قَبْلَ الظُّہْرِ۔,,,6011,,
6012,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یُصَلِّی بَعْدَ الظُّہْرِ أَرْبَعًا۔,,,6012,,
6013,حَدَّثَنَا عَبْدَۃُ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یُصَلِّی بعدہا أَرْبَعًا۔,,,6013,,
6014,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُمرَ بْنِ حَمْزَۃَ ، عَنْ شَرِیکِ بْنِ أَبِی نَمِرٍ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ؛ أَنَّہُ کَانَ یُصَلِّی بَعْدَہَا أَرْبَعًا ، لاَ یُطِیلُ فِیہِنَّ۔,,,6014,,
6015,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ الأَصْبَغِ بْنِ زَیْدٍ ، عَنِ الْقَاسِمِ بْنِ أَبِی أَیُّوبَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ أَنَّہُ کَانَ یُصَلِّی بَعْدَہَا أَرْبَعًا۔,,,6015,,
6016,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا الأَصْبَغُ بْنُ زَیْدٍ ، قَالَ : حَدَّثَنَا ثَوْرُ بْنُ یَزِیدَ ، عَمَّنْ أَخْبَرَہُ ؛ أَنَّ أَبَا ذَرٍّ ، قَالَ : صَلِّ بَعْدَ الظُّہْرِ أَرْبَعًا ، فَإِنْ نَسِیتَ الْعَصْرَ کَانَتْ بِہَا۔",,,6016,,
6017,حَدَّثَنَا وَکِیعٌ ، عَنْ عِکْرِمَۃَ بْنِ عَمَّارٍ ، عَنْ سَالِمٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یُصَلِّی بَعْدَہَا أَرْبَعًا۔,,,6017,,
6018,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمٍ بْنِ ضَمْرَۃَ ، قَالَ : قَالَ نَاسٌ مِنْ أَصْحَابِ عَلِیٍّ لِعَلِیٍّ: أَلاَ تُحَدِّثُنَا بِصَلاَۃِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِالنَّہَارِ التَّطَوُّعِ ؟ قَالَ : فَقَالَ عَلِیٌّ : إِنَّکُمْ لَنْ تُطِیقُوہَا۔ قَالَ: فَقَالُوا : أَخْبِرْنَا بِہَا نَأْخُذْ مِنْہَا مَا أَطَقْنَا ۔ قَالَ : فَقَالَ : کَانَ إِذَا ارْتَفَعَتِ الشَّمْسُ مِنْ مَشْرِقِہَا ، فَکَانَتْ کَہَیْئَتِہَا مِنَ الْمَغْرِبِ مِنْ صَلاَۃِ الْعَصْرِ صَلَّی رَکْعَتَیْنِ ، فَإِذَا کَانَتْ مِنَ الْمَشْرِقِ کَہَیْئَتِہَا مِنَ الظُّہْرِ مِنَ الْمَغْرِبِ ، صَلَّی أَرْبَعَ رَکَعَاتٍ ، وَصَلَّی قَبْلَ الظُّہْرِ أَرْبَعَ رَکَعَاتٍ ، وَبَعْدَ الظُّہْرِ رَکْعَتَیْنِ ، وَصَلَّی قَبْلَ الْعَصْرِ أَرْبَعَ رَکَعَاتٍ ، یُسَلِّمُ فِی کُلِّ رَکْعَتَیْنِ عَلَی الْمَلاَئِکَۃِ الْمُقَرَّبِینَ وَالنَّبِیِّینَ وَمَنْ تَبِعَہُمْ مِنَ الْمُؤْمِنِینَ وَالْمُسْلِمِینَ۔ (ترمذی 424۔ احمد 143)",,,6018,,
6019,"حَدَّثَنَا وَکِیعٌ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنْ مَیْمُونٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : حفِظْتُ مِنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ثَمَانَ رَکَعَاتٍ ؛ رَکْعَتَیْنِ قَبْلَ الظُّہْرِ ، وَرَکْعَتَیْنِ بَعْدَہَا ، وَرَکْعَتَیْنِ بَعْدَ الْمَغْرِبِ ، وَرَکْعَتَیْنِ بَعْدَ الْعِشَائِ ، وَحَدَّثَتْنِی حَفْصَۃُ بِرَکْعَتَیْنِ قَبْلَ الْفَجْرِ۔ (ترمذی 432۔ ابوداؤد 1246)",,,6019,,
6020,"حَدَّثَنَا وَکِیعٌ ، عَنْ یَزِیدَ ، عَنِ ابْنِ سِیرِینَ ، عَنْ مُغِیرَۃَ بْنِ سَلْمَانَ ، عَنِ ابْنِ عُمَرَ ، قَالَ : حفِظْتُ مِنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَشْرَ رَکَعَاتٍ ، فَذَکَرَ مِثْلَ حَدِیثِ جَعْفَرَ ، إِلاَّ أَنَّہُ لَمْ یَقُلْ حَدَّثَتْنِی حَفْصَۃُ۔ (بخاری 1180۔ عبدالرزاق 4811)",,,6020,,
6021,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ مَیْسَرَۃَ ، وَزَاذَانَ ، قَالاَ : کَانَ عَلِیٌّ یُصَلِّی مِنَ التَّطَوُّعِ أَرْبَعًا قَبْلَ الظُّہْرِ ، وَرَکْعَتَیْنِ بَعْدَہَا ، وَرَکْعَتَیْنِ بَعْدَ الْمَغْرِبِ ، وَأَرْبَعًا بَعْدَ الْعِشَائِ ، وَرَکْعَتَیْنِ قَبْلَ الْفَجْرِ۔",,,6021,,
6022,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ أَبِی عُبَیْدَۃَ ، قَالَ : کَانَتْ صَلاَۃُ عَبْدِ اللہِ الَّتِی لاَ یَدَعُ مِنَ التَّطَوُّعِ ؛ أَرْبَعًا قَبْلَ الظُّہْرِ ، وَرَکْعَتَیْنِ بَعْدَہَا ، وَرَکْعَتَیْنِ بَعْدَ الْمَغْرِبِ ، وَرَکْعَتَیْنِ بَعْدَ الْعِشَائِ ، وَرَکْعَتَیْنِ قَبْلَ الْفَجْرِ۔",,,6022,,
6023,"حَدَّثَنَا وَکِیعٌ ، عَنِ الرَّبِیعِ ، عَنِ الْحَسَن ، وَابْنِ سِیرِینَ ؛ أَنَّہُما قَالاَ : التَّطَوعُ عَشَرَ رَکَعَاتٍ ؛ رَکْعَتَیْنِ قَبْلَ الظُّہْرِ ، وَرَکْعَتَیْنِ بَعْدَہَا ، وَرَکْعَتَیْنِ بَعْدَ الْمَغْرِبِ ، وَرَکْعَتَیْنِ بَعْدَ الْعِشَائِ ، وَرَکْعَتَیْنِ قَبْلَ الْفَجْرِ۔",,,6023,,
6024,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانُوا یَعُدُّونَ مِنَ السُّنَّۃِ ؛أَرْبَعًا قَبْلَ الظُّہْرِ، وَرَکْعَتَیْنِ بَعْدَہَا ، وَرَکْعَتَیْنِ بَعْدَ الْمَغْرِبِ ، وَرَکْعَتَیْنِ بَعْدَ الْعِشَائِ ، وَرَکْعَتَیْنِ قَبْلَ الْفَجْرِ ۔ قَالَ إِبْرَاہِیمُ : وَکَانُوا یَسْتَحِبُّونَ رَکْعَتَیْنِ قَبْلَ الْعَصْرِ ، إِلاَّ أَنَّہُمْ لَمْ یَکُونُوا یَعُدُّونَہَا مِنَ السُّنَّۃِ۔",,,6024,,
6025,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ أَبِی عُبَیْدَۃَ ، قَالَ : کَانَتْ صَلاَۃُ عَبْدِ اللہِ الَّتِی لاَ یَدَعُ ؛ أَرْبَعًا قَبْلَ الظُّہْرِ ، وَرَکْعَتَیْنِ بَعْدَہَا ، وَرَکْعَتَیْنِ بَعْدَ الْمَغْرِبِ ، وَرَکْعَتَیْنِ بَعْدَ الْعِشَائِ ، وَرَکْعَتَیْنِ قَبْلَ الْفَجْرِ۔",,,6025,,
6026,"حَدَّثَنَا شَرِیکٌ ، عَنْ ہِلاَلِ الْوَزَّانِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إِذَا فَاتَتْہُ أَرْبَعٌ قَبْلَ الظُّہْرِ صَلاَّہَا بَعْدَہَا۔ (ترمذی 426۔ ابن ماجہ 1158)",,,6026,,
6027,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ رَجُلٍ مِنْ بَنِی أَوْدٍ ، عَنْ عَمْرِو بْنِ مَیْمُونٍ ، قَالَ : مَنْ فَاتَتْہُ أَرْبَعٌ قَبْلَ الظُّہْرِ صَلاَّہَا بَعْدَہَا۔",,,6027,,
6028,"حَدَّثَنَا إِسْحَاقُ بْنُ سُلَیْمَانَ ، عَنْ مُغِیرَۃَ بْنِ زِیَادٍ ، عَنْ عَطَائٍ ، عَنْ عَائِشَۃَ ، قَالَتْ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ ثَابَرَ عَلَی اثْنَتَیْ عَشْرَۃَ رَکْعَۃً مِنَ السُّنَّۃِ بَنَی اللَّہُ لَہُ بَیْتًا فِی الْجَنَّۃِ ؛ أَرْبَعًا قَبْلَ الظُّہْرِ ، وَرَکْعَتَیْنِ بَعْدَہَا ، وَرَکْعَتَیْنِ بَعْدَ الْمَغْرِبِ ، وَرَکْعَتَیْنِ بَعْدَ الْعِشَائِ ، وَرَکْعَتَیْنِ قَبْلَ الْفَجْرِ۔ (ترمذی 414۔ ابو یعلی 4508)",,,6028,,
6029,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : حدَّثَنَا إِسْمَاعِیلُ بْنُ أَبِی خَالِدٍ ، عَنِ الْمُسَیَّبِ بْنِ رَافِعٍ ، عَنْ عَنْبَسَۃَ بْنِ أَبِی سُفْیَانَ ، عَنْ أُمِّ حَبِیبَۃَ ابْنَۃِ أَبِی سُفْیَانَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : مَنْ صَلَّی فِی یَوْمٍ وَلَیْلَۃٍ ثِنْتَیْ عَشْرَۃَ سَجْدَۃً سِوَی الْمَکْتُوبَۃِ ، بُنِیَ لَہُ بَیْتٌ فِی الْجَنَّۃِ۔ (ترمذی 415۔ احمد 6/326)",,,6029,,
6030,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ إِسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنِ الْمُسَیَّبِ بْنِ رَافِعٍ ، عَنْ عَنْبَسَۃَ بْنِ أَبِی سفْیَانَ ، عَنْ أُمِّ حَبِیبَۃَ بِنْتِ أَبِی سُفْیَانَ ، وَلَمْ تَرْفَعْہُ ، قَالَتْ : مَنْ صَلَّی فِی یَوْمٍ ثِنْتَیْ عَشْرَۃَ سِوَی الْمَکْتُوبَۃِ ، بُنِیَ لَہُ بَیْتٌ فِی الْجَنَّۃِ۔",,,6030,,
6031,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنِ الْجُرَیْرِیِّ ، عَنِ ابْنِ بُرَیْدَۃَ ، عَنْ کَعْبٍ ، قَالَ : ثِنْتَا عَشَرَۃَ رَکْعَۃً ، مَنْ صَلاَّہَا فِی یَوْمٍ سِوَی الْمَکْتُوبَۃِ دَخَلَ الْجَنَّۃَ ، أَوْ بُنِیَ لَہُ بَیْتٌ فِی الْجَنَّۃِ ؛ رَکْعَتَانِ قَبْلَ الْغَدَاۃِ ، وَرَکْعَتَانِ مِنَ الضُّحَی ، وَأَرْبَعُ رَکَعَاتٍ قَبْلَ الظُّہْرِ ، وَرَکْعَتَانِ بَعْدَہَا ، وَرَکْعَتَانِ بَعْدَ الْمَغْرِبِ۔",,,6031,,
6032,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مَنْصُورٍ ، عَنْ أَبِی عُثْمَانَ ، مَوْلَی الْمُغِیرَۃِ بْنِ شُعْبَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ: مَا مِنْ عَبْدٍ مُسْلِمٍ یُصَلِّی فِی یَوْمٍ اثْنَتَیْ عَشْرَۃَ رَکْعَۃً ، إِلاَّ بَنَی اللَّہُ لَہُ بَیْتًا فِی الْجَنَّۃِ۔",,,6032,,
6033,"حَدَّثَنَا عَبِیْدَۃُ بْنُ حُمَیْدٍ ، عَنْ دَاوُدَ بْنِ أَبِی ہِنْدٍ ، عَنِ النُّعْمَانِ بْنِ سَالِمٍ ، عَنْ عَمْرِو بْنِ أَوْسٍ ، عَنْ عَنْبَسَۃَ بْنِ أَبِی سُفْیَانَ ، عَنْ أُمِّ حَبِیبَۃَ ، قَالَتْ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ صَلَّی فِی یَوْمٍ ثِنْتَیْ عَشْرَۃَ سَجْدَۃً تَطَوُّعًا ، بُنِیَ لَہُ بَیْتٌ فِی الْجَنَّۃِ۔ (مسلم 503۔ ابوداؤد 1244)",,,6033,,
6034,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُعَرِّفِ بْنِ وَاصِلٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ مَیْسَرَۃَ ، عَنْ عَائِشَۃَ ، قَالَتْ : مَنْ صَلَّی أَوَّلَ النَّہَارِ ثِنْتَیْ عَشَرَۃَ رَکْعَۃً ، بُنِیَ لَہُ بَیْتٌ فِی الْجَنَّۃِ۔",,,6034,,
6035,"حَدَّثَنَا مُحَمَّدُ بْنُ سُلَیْمَانَ الأَصْبَہَانِیُّ ، عَنْ سُہَیْلٍ ، عَنْ أَبِیہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ صَلَّی فِی یَوْمٍ اثْنَتَیْ عَشْرَۃَ رَکْعَۃً ، بُنِیَ لَہُ بَیْتٌ فِی الْجَنَّۃِ ؛ رَکْعَتَیْنِ قَبْلَ الْفَجْرِ ، وَرَکْعَتَیْنِ قَبْلَ الظُّہْرِ ، وَرَکْعَتَیْنِ بَعْدَ الظُّہْرِ ، وَرَکْعَتَیْنِ ، أَظُنُّہُ قَالَ : قَبْلَ الْعَصْرِ ، وَرَکْعَتَیْنِ بَعْدَ الْمَغْرِبِ ، وَأَظُنُّہُ قَالَ : وَرَکْعَتَیْنِ بَعْدَ الْعِشَائِ۔ (ابوداؤد 1263۔ نسائی 1481)",,,6035,,
6036,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ: حدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللہِ الشُّعَیثیُّ، عَنْ أَبِیہِ ، عَنْ عَنْبَسَۃَ بْنِ أَبِی سُفْیَانَ، عَنْ أُمِّ حَبِیبَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : مَنْ صَلَّی أَرْبَعًا قَبْلَ الظُّہْرِ ،وَأَرْبَعًا بَعْدَہَا حَرَّمَہُ اللَّہُ عَلَی النَّارِ۔",,,6036,,
6037,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : حدَّثَنَا الْمَسْعُودِیُّ ، عَنِ الْقَاسِمِ ، قَالَ : لَمَّا حُضِرَ مُعَاذٌ ، قَالَ : لَیْسَ أَحَدٌ یُصَلِّی أَرْبَعَ رَکَعَاتٍ تَطَوُّعَا بَعْدَ صَلاَۃٍ مَکْتُوبَۃٍ ، فَیَلْحَقُہُ یَوْمئِذٍ ذَنْبٌ إِلاَّ الشِّرْکَ بِاللَّہِ ، حَتَّی تَغْرُبَ الشَّمْسُ۔",,,6037,,
6038,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ أَبِی الزَّعْرَائِ؛ أَنَّ أَبَا الأَحْوَص کَانَ لاَ یَرْکَعُ الرَّکْعَتَیْنِ قَبْلَ الْعَصْرِ۔,,,6038,,
6039,"حَدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَانَ الْحَسَنُ یُؤَذِّنُ الْمُؤَذِّنُ الْعَصْرَ ، فَلاَ یُصَلِّی حَتَّی یُصَلِّی الْعَصْرَ۔",,,6039,,
6040,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ إِسْمَاعِیلَ ، قَالَ : صَلَّیْتُ مَعَ قَیْسٍ الظُّہْرَ ، ثُمَّ جَلَسَ فَلَمْ یُصَلِّ شَیْئًا حَتَّی صَلَّی الْعَصْرَ۔",,,6040,,
6041,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنِی إِسْمَاعِیلُ ، عَنْ عَامِرٍ ؛ أَنَّہُ سُئِلَ عَنِ الرَّکْعَتَیْنِ قَبْلَ الْعَصْرِ ؟ فَقَالَ: إِنْ کُنْتَ تَعْلَمُ أَنَّک تُصَلِّیہَا قَبْلَ أَنْ یُقِیمَ فَصَلِّ۔",,,6041,,
6042,"حَدَّثَنَا یَحْیَی بْنُ أَبِی بُکَیْرٍ ، قَالَ : حدَّثَنَا أَبِی ، عَنْ أَبِی بِشْرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ أَنَّہُ کَانَ لاَ یُصَلِّی قَبْلَ الْعَصْرِ۔",,,6042,,
6043,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ حَفْصِ بْنِ سُلَیْمَانَ ، عَنْ مُعَاوِیَۃَ بْنِ قُرَّۃَ ، قَالَ : کَانَ حُذَیْفَۃُ إِذَا فَاتَتْہُ الصَّلاَۃُ فِی مَسْجِدِ قَوْمِہِ ، یُعَلِّقُ نَعْلَیْہِ وَیَتَّبِعُ الْمَسَاجِدَ ، حَتَّی یُصَلِّیَہَا فِی جَمَاعَۃٍ۔",,,6043,,
6044,حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، عَنْ إِبْرَاہِیمَ ، عَنِ الأَسْوَدِ ؛ أَنَّہُ کَانَ إِذَا فَاتَتْہُ الصَّلاَۃُ فِی مَسْجِدِ قَوْمِہِ ، ذَہَبَ إِلَی مَسْجِدٍ غَیْرِہِ۔,,,6044,,
6045,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الرَّبِیعِ بْنِ أَبِی رَاشِدٍ ، قَالَ : جَائَنَا سَعِیدُ بْنُ جُبَیْرٍ وَنَحْنُ فِی آخِرِ الصَّلاَۃ ، فَسَمِعَ مُؤَذِّنًا فَأَتَاہُ۔",,,6045,,
6046,"حَدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : إِذَا فَاتَتْک الصَّلاَۃ فِی مَسْجِدِکَ ، فَلاَ تَتَّبِعِ الْمَسَاجِدَ ، صَلِّ فِی مَسْجِدِک۔",,,6046,,
6047,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا فَاتَتِ الرَّجُلُ الصَّلاَۃ فِی مَسْجِدِ قَوْمِہِ لَمْ یَتَّبِعِ الْمَسَاجِدَ۔",,,6047,,
6048,"حَدَّثَنَا جَرِیرٌ ، عَنِ الْحَسَنِ بْنِ عَمْرٍو ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، قَالَ : کَانَ تَفُوتُہُ الصَّلاَۃ فِی مَسْجِدِ قَوْمِہِ ، فَیَجِیئُ إِلَی الْمَسْجِدِ فَیَدْخُلُہُ ، فَیُصَلِّی فِیہِ وَہُوَ یَسْمَعُ الأَذَانَ مِنَ الْمَسْجِدِ فَلاَ یَأْتِیہِمْ۔",,,6048,,
6049,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنِ السَّرِیِّ بْنِ یَحْیَی ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ تَفُوتُہُ الصَّلاَۃ فِی مَسْجِدِ قَوْمِہِ ، فَیَأْتِی مَسْجِدًا آخَرَ ؟ فَقَالَ الْحَسَنُ : مَا رَأَیْنَا الْمُہَاجِرِینَ یَفْعَلُونَ ذَلِکَ۔",,,6049,,
6050,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : قَالَ عُمَرُ : لاَ یُصَلَّی بَعْدَ الصَّلاَۃِ مِثْلُہَا۔",,,6050,,
6051,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، وَابْنُ إِدْرِیسَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن سُلَیْمَانَ بْنِ مُسْہِرٍ ، عَنْ خَرَشَۃَ ، قَالَ : کَانَ عُمَرُ یَکْرَہُ أَنْ یُصَلَّی خَلْفَ صَلاَۃٍ مِثْلُہَا۔",,,6051,,
6052,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنْ إِبْرَاہِیمَ ، وَالشَّعْبِیِّ ، قَالاَ : قَالَ عَبْدُ اللہِ : لاَ یُصَلَّی عَلَی إِثْرِ صَلاَۃٍ مِثْلُہَا۔",,,6052,,
6053,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حُصَیْنٌ ، عَنْ أَصْحَابِ عَبْدِ اللہِ ، عَنْ عَبْدِ اللہِ ؛ أَنَّہُ کَانَ یَکْرَہُ أَنْ یُصَلَّی بَعْدَ الْمَکْتُوبَۃِ مِثْلُہَا۔",,,6053,,
6054,"حَدَّثَنَا سَلاَّم أَبُو الأَحْوَصِ ، عَنْ أَبِی حَمْزَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانَ عَبْدُ اللہِ یَکْرَہُ أَنْ یُصَلَّی بَعْدَ الْمَکْتُوبَۃِ مِثْلُہَا۔",,,6054,,
6055,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانُوا یَکْرَہُونَ أَنْ یُصَلُّوا بَعْدَ الْمَکْتُوبَۃِ مِثْلَہَا۔",,,6055,,
6056,"حَدَّثَنَا ہُشَیْمٌ، عَنِ الْعَوَّامِ، قَالَ: حَدَّثَنَا الْمُسَیَّبُ بْنِ رَافِعٍ ، قَالَ: کَانُوا یَکْرَہُونَ أَنْ یُصَلُّوا بَعْدَ الْمَکْتُوبَۃِ مِثْلَہَا۔",,,6056,,
6057,حَدَّثَنَا ہُشَیْمٌ ، عَنِ الأَعْمَشِ ، عَنْ سُلَیْمَانَ بْنِ مُسْہِرٍ ، عَنْ خَرَشَۃَ بْنِ الْحُرِّ ، عَنْ عُمَرَ ؛ أَنَّہُ کَرِہَ أَنْ یُصَلَّی بَعْدَ الْمَکْتُوبَۃِ مِثْلُہَا۔,,,6057,,
6058,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ مِہْرَانَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ سَعْدٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الأَبْعَدُ فَالأَبْعَدُ مِنَ الْمَسْجِدِ ، أَعْظَمُ أَجْرًا۔ (ابوداؤد 557۔ احمد 2/351)",,,6058,,
6059,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الأَسْوَدِ بْنِ الْعَلاَئِ بْنِ جَارِیَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مِنْ حِینِ یَخْرُجُ أَحَدُکُمْ مِنْ مَسْجِدِہِ إِلَی بَیْتِہِ ، فَرِجْلٌ تَکْتُبُ لَہُ حَسَنَۃً ، وَالأُخْرَی تَحُطُّ عَنْہُ سَیِّئَۃً۔ (احمد 2/478۔ ابن حبان 1622)",,,6059,,
6060,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ أَخِیہِ ، عَنْ جَابِرٍ ، قَالَ : کَانَتْ مَنَازِلُنَا قَاصِیَۃً ، فَأَرَدْنَا أَنْ نَتَقَرَّبَ مِنْ مَسْجِدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَذَکَرْنَا ذَلِکَ لَہُ ، فَقَالَ : لاَ تَفْعَلُوہَا ، ائْتُوہَا کَمَا کُنْتُمْ ، مَا مِنْ مُؤْمِنٍ یَتَوَضَّأُ فَیُحْسِنُ الْوُضُوئَ ، ثُمَّ یَخْرُجُ إِلَی الْمَسْجِدِ ، إِلاَّ کَتَبَ اللَّہُ لَہُ بِکُلِّ خُطْوَۃٍ حَسَنَۃً ، وَحَطَّ عَنْہُ بِہَا سَیِّئَۃً۔",,,6060,,
6061,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا حُمَیْدٌ الطَّوِیلُ ، عَنْ أَنَسِ بْنِ مَالِکٍ ؛ أَنَّ بَنِی سَلِمَۃَ أَرَادُوا أَنْ یَتَحَوَّلُوا عَنْ مَنَازِلِہِمْ ، فَیَبنوا قَرِیبًا مِنَ الْمَسْجِدِ ، فَکَرِہَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ تُعْرَی الْمَدِینَۃُ ، فَقَالَ : یَا بَنِی سَلِمَۃَ ، أَلاَ تَحْتَسِبُونَ آثَارَکُمْ ؟ قَالُوا : بَلَی ، فَثَبَتُوا۔ (بخاری 655۔ احمد 3/106)",,,6061,,
6062,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّ بَنِی سَلِمَۃَ کَانَتْ دُورُہُمْ قَاصِیَۃً عَنِ الْمَسْجِدِ ، فَہَمُّوا أَنْ یَتَحَوَّلُوا قَرِیبًا مِنَ الْمَسْجِدِ ، فَیَشْہَدُونَ الصَّلاَۃَ مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ لَہُم النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَلاَ تَحْتَسِبُونَ آثَارَکُمْ یَا بَنِی سَلِمَۃَ ؟ فَثَبَتُوا فِی دِیَارِہِمْ۔",,,6062,,
6063,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی عُثْمَانَ النَّہْدِیِّ ، عَنْ أُبَیِّ بْنِ کَعْبٍ ، قَالَ : کَانَ رَجُلٌ بِالْمَدِینَۃِ ، مَا أَعْلَمُ أَحَدًا مِنْ أَہْلِ الْمَدِینَۃِ مِمَّنْ یُصَلِّی الْقِبْلَۃَ أَبْعَدَ مَنْزِلاً مِنَ الْمَسْجِدِ مِنْہُ ، فَکَانَ یَشْہَدُ الصَّلاَۃَ مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقِیلَ : لو ابْتَغَیْتَ حِمَارًا تَرْکَبُہُ فِی الرَّمْضَائِ وَالظُّلْمَۃِ ؟ فَقَالَ: وَاللَّہِ مَا یَسُرُّنِی أَنَّ مَنْزِلِی بِلَزْقِ الْمَسْجِدِ ، فَذُکِرَ ذَلِکَ لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : یَا رَسُولَ اللہِ، کَیْمَا یُکْتَبُ خُطَایَ وَإِقْبَالِی ، وَإِدْبَارِی ، وَرُجُوعِی إِلَی أَہْلِی ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَنْطَاکَ اللَّہُ ذَلِکَ ، وَأَعْطَاک مَا احْتَسَبْت أَجْمَعَ ، أَوْ کَمَا قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔(مسلم 460۔ ابوداؤد 558)",,,6063,,
6064,"حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، قَالَ : سَأَلْتُ ابْنَ أَبِی لَیْلَی ، فَقُلْتُ : بَنُو سَلِمَۃَ أَرَادُوا أَنْ یَتَحَوَّلُوا قَرِیبًا مِنَ الْمَسْجِدِ ؟ فَذُکِرَ عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : فَإِنَّ بِکُلِّ خُطْوَۃٍ حَسَنَۃً۔ (مسلم 461)",,,6064,,
6065,"حَدَّثَنَا إِسْمَاعِیلُ بْنُ إِبْرَاہِیمَ ، عَن لَیْثٍ ، عَنِ الْحَجَّاجِ بْنِ عُبَیْدٍ ، عَنْ إِبْرَاہِیمَ بْنِ إِسْمَاعِیلَ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : أَیَعْجَزُ أَحَدُکُمْ إِذَا صَلَّی أَنْ یَتَقَدَّمَ ، أَوْ یَتَأَخَّرَ ، أَوْ عَنْ یَمِینِہِ ، أَوْ عَنْ شِمَالِہِ ، یَعْنِی السَّبْحَۃَ۔ (ابوداؤد 998۔ احمد 2/425)",,,6065,,
6066,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ عَطَائٍ ، عَن ابْنِ عَبَّاسٍ ، قَالَ : یَتَقَدَّمَ ، أَوْ یَتَأَخَّرَ۔",,,6066,,
6067,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ أَبِیِہِ ، عَنْ رَجُلٍ ، عَنْ عَطَائٍ ؛ أَنَّ ابْنَ عَبَّاسٍ ، وَابْنَ الزُّبَیْرِ وَأَبَا سَعِیدٍ ، وَابْنَ عُمَرَ ، کَانُوا یَقُولُونَ : لاَ یَتَطَوَّعُ حَتَّی یَتَحَوَّلَ مِنْ مَکَانِہِ الَّذِی صَلَّی فِیہِ الْفَرِیضَۃَ۔",,,6067,,
6068,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنْ عَامِرٍ ، قَالَ : لاَ یَتَطَوَّعُ حَتَّی یَنْہَزَ خُطْوَۃً ، أَوْ خُطْوَتَیْنِ۔",,,6068,,
6069,"حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِیلَ ، عَنْ ہِشَامٍ ، قَالَ : کَانَ أَبِی إِذَا صَلَّی الْمَکْتُوبَۃَ نَکَّبَ عَنْ مَکَانِہِ فَسَبَّحَ۔",,,6069,,
6070,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی بَحْرٍ ، عَنْ شَیْخٍ ، قَالَ : سُئِلَ ابْنُ مَسْعُودَ عَنِ الرَّجُلِ یُصَلِّی فِی مَکَانِہِ الَّذِی صَلَّی فِیہِ الْفَرِیضَۃَ ؟ قَالَ : لاَ بَأْسَ بِہِ۔",,,6070,,
6071,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یُصَلِّی سُبْحَتَہُ مَکَانَہُ۔,,,6071,,
6072,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، قَالَ : رَأَیْتُ الْقَاسِمَ ، وَسَالِمًا یُصَلِّیَانِ الْفَرِیضَۃَ ، ثُمَّ یَتَطَوَّعَانِ فِی مَکَانِہِمَا۔ قَالَ : وَأَنْبَأَنِی نَافِعٌ ؛ أَنَّ ابْنَ عُمَرَ کَانَ لاَ یَرَی بِہِ بَأْسًا۔",,,6072,,
6073,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، قَالَ: سَأَلْتُ عَطَائً عَنِ الرَّجُلِ یَتَطَوَّعُ فِی مَکَانِہِ ؟ فَقَالَ : لاَ بَأْسَ بِہِ۔",,,6073,,
6074,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَمُحَمَّدٍ ؛ أَنَّہُمَا کَانَا یُصَلِّیَانِ التَّطَوُّعَ فِی مَکَانِہِمَا الَّذِی یُصَلِّیَانِ فِیہِ الْفَرِیضَۃَ۔,,,6074,,
6075,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : غَیْرُ الإِمَامِ إِنْ شَائَ لَمْ یَتَحَوَّلْ۔",,,6075,,
6076,"حَدَّثَنَا شَرِیکٌ ، عَنْ مَیْسَرَۃَ ، عَنِ الْمِنْہَالِ ، عَنْ عَبَّاد بْنِ عَبْدِ اللہِ ، عَنْ عَلِیٍّ ، قَالَ : إِذَا سَلَّمَ الإِمَامُ لَمْ یَتَطَوَّعْ حَتَّی یَتَحَوَّلَ مِنْ مَکَانِہِ ، أَوْ یَفْصِلَ بَیْنَہُمَا بِکَلاَمٍ۔",,,6076,,
6077,حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الشَّعْبِیِّ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَرِہَ إِذَا صَلَّی الإِمَامُ أَنْ یَتَطَوَّعَ فِی مَکَانِہِ ، وَلَمْ یَرَ بِہِ لِغَیْرِ الإِمَامِ بَأْسًا۔,,,6077,,
6078,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ إِبْرَاہِیمَ بْنِ مُہَاجِرٍ ، عَنْ مُجَاہِدٍ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ؛ أَنَّہُ کَرِہَ لِلإِمَامِ أَنْ یُصَلِّیَ فِی مَکَانِہِ الَّذِی صَلَّی فِیہِ الْفَرِیضَۃَ۔,,,6078,,
6079,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنِ ابْنِ أَبِی لَیْلَی ؛ أَنَّہُ کَانَ یَسْتَحِبُّ لِلإِمَامِ إِذَا صَلَّی أَنْ لاَ یَتَطَوَّعَ فِی مَکَانِہِ الَّذِی صَلَّی فِیہِ ۔ أَوَ قَالَ : کَانَ یَکْرَہُہُ۔",,,6079,,
6080,حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، وَالْحَسَنِ ؛ أَنَّہُمَا کَانَا یُعْجِبُہُمَا إِذَا سَلَّمَ الإِمَامُ أَنْ یَتَقَدَّمَ۔,,,6080,,
6081,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّہُ کَانَ یُکْرَہُ لِلإِمَامِ أَنْ یَتَطَوَّعَ فِی مَکَانِہِ الَّذِی صَلَّی فِیہِ الْفَرِیضَۃَ۔,,,6081,,
6082,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَیْسَرَۃَ ، عَنِ الْمِنْہَالِ بْنِ عَمْرٍو ، عَنْ عَبَّادِ بْنِ عَبْدِ اللہِ ، عَنْ عَلِیٍّ ، قَالَ: لاَ یَتَطَوَّعُ الإِمَامُ فِی الْمَکَانِ الَّذِی أَمَّ فِیہِ الْقَوْمَ حَتَّی یَتَحَوَّلَ ، أَوْ یَفْصِلَ بِکَلاَمٍ۔",,,6082,,
6083,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : الإِمَام یَتَحَوَّلُ۔",,,6083,,
6084,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا صَلَّی الإِمَام الْمَکْتُوبَۃَ ، ثُمَّ أَرَادَ أَنْ یُصَلِّیَ التَّطَوُّعَ، تَنَحَّی مِنْ مَکَانِہِ الَّذِی صَلَّی فِیہِ الْفَرِیضَۃَ۔",,,6084,,
6085,"حَدَّثَنَا عَبْدُالأَعْلَی، عَنْ خَالِدٍ، عَنْ أَبِی قِلاَبَۃَ، قَالَ: کَانُوا یَسْتَحِبُّونَ أَنْ یَتَقَدَّمُوا فِی الصَّلاَۃ، وَلاَ یَتَأَخَّرُوا۔",,,6085,,
6086,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : قُلْتُ لِمُحَمَّدٍ : الرَّجُلُ یَتَقَدَّمُ إِلَی الصَّفِّ فِی الصَّلاَۃ؟ قَالَ: لاَ أَعْلَمُ بَأْسًا أَنْ یَتَقَدَّمَ خُطْوَۃً ، أَوْ خُطْوَتَیْنِ ۔ وَقَالَ فِی الَّذِی یَصِل الصَّفَّ مُعْتَرِضًا : لاَ أَدْرِی مَا ہُوَ ؟۔",,,6086,,
6087,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ فِی الرَّجُلِ یَکُونُ مَعَہُ الشَّیئُ فَیَضَعُہُ فَیُصَلِّیَ ، ثُمَّ یَبْدُو لَہُ أَنْ یَتَقَدَّمَ ، قَالَ : لاَ بَأْسَ أَنْ یَأْخُذَہُ ، ثُمَّ یَتَقَدَّمَ۔",,,6087,,
6088,"حَدَّثَنَا وَکِیعٌ، عَنْ مِسْعَرٍ، وَسُفْیَانَ، عَنْ سَعْدِ بْنِ إِبْرَاہِیمَ، عَن عُرْوَۃَ، قَالَ: کَانَ یُقَالُ: تَقَدَّمُوا، تَقَدَّمُوا۔",,,6088,,
6089,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ إِسْمَاعِیلَ بْنِ سَالِمٍ ، قَالَ : سَأَلْتُ الشَّعْبِیَّ عَنْ رَجُلٍ کَانَ یُصَلِّی وَبَیْنَ یَدَیْہِ قَوْمٌ یُصَلُّونَ ، فَانْصَرَفُوا ؟ قَالَ : یَتَقَدَّمُ إِلَی الْحَائِطِ بَیْنَ یَدَیْہِ ۔ قَالَ : قُلْتُ : أَفَیَقْرَأُ وَہُوَ یَمْشِی ؟ قَالَ : لاَ ، حَتَّی یَنْتَہِیَ إِلَی الْمَکَانِ الَّذِی یَقُومُ فِیہِ۔",,,6089,,
6090,"حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ ثَابِتٍ الْبُنَانِیِّ ، عَنِ ابْنِ أَبِی لَیْلَی ، عن أَبِی لَیْلَی ، قَالَ : صَلَّیْتُ إِلَی جَنْبِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ یُصَلِّی بِاللَّیْلِ تَطَوُّعًا ، فَمَرَّ بِآیَۃٍ ، فَقَالَ : أَعُوذُ بِاللَّہِ مِنَ النَّارِ، وَوَیْلٌ لأَہْلِ النَّارِ۔ (ابوداؤد 877۔ احمد 4/347)",,,6090,,
6091,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ أَبِی الضُّحَی ، عَنْ مَسْرُوقٍ ، عَنْ عَائِشَۃَ ؛ أَنَّہَا مَرَّتْ بِہَذِہِ الأَیَۃِ : {فَمَنَّ اللَّہُ عَلَیْنَا وَوَقَانَا عَذَابَ السَّمُومِ}فَقَالَتْ : اللَّہُمَّ مُنَّ عَلَیْنَا وَقِنَا عَذَابَ السَّمُومِ ، إِنَّک أَنْتَ الْبَرُّ الرَّحِیمُ۔ فَقِیلَ لِلأَعْمَشِ : فِی الصَّلاَۃِ ؟ فَقَالَ : فِی الصَّلاَۃِ۔",,,6091,,
6092,"حَدَّثَنَا عَبْدَۃُ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ عَبْدِ الْوَہَّابِ ، عَنْ جَدِّہِ عَبَّادِ بْنِ حَمْزَۃَ ، قَالَ : دَخَلْتُ عَلَی أَسْمَائَ وَہِیَ تَقْرَأُ : {فَمَنَّ اللَّہُ عَلَیْنَا وَوَقَانَا عَذَابَ السَّمُومِ} قَالَ : فَوَقَفَتْ عَلَیْہَا ، فَجَعَلَتْ تَسْتَعِیذُ وَتَدْعُو ۔ قَالَ عَبَّادُ : فَذَہَبْتُ إِلَی السُّوقِ ، فَقَضَیْتُ حَاجَتِی ، ثُمَّ رَجَعْتُ ، وَہِیَ فِیہَا بَعْدُ تَسْتَعِیذُ وَتَدْعُو۔",,,6092,,
6093,"حَدَّثَنَا وَکِیعٌ ، عَنْ عِیسَی ، عَنِ الشَّعْبِیِّ ، قَالَ : قَالَ عَبْدُ اللہِ : إِذَا مَرَّ أَحَدُکُمْ فِی الصَّلاَۃ بِذِکْرِ النَّارِ ، فَلْیَسْتَعِذْ بِاللَّہِ مِنَ النَّارِ ، وَإِذَا مَرَّ بِذِکْرِ الْجَنَّۃِ ، فَلْیَسْأَلِ اللَّہَ الْجَنَّۃَ۔",,,6093,,
6094,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا إِذَا مَرَّ بِآیَۃٍ أَنْ یَسْأَلَ ، وَأَنَّ ابْنَ سِیرِینَ کَرِہَہُ۔,,,6094,,
6095,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، وَابْنُ نُمَیْرٍ ، عَنِ الأَعْمَشِ ، عَنْ سَعْدِ بْنِ عُبَیْدَۃَ ، عَنِ الْمُسْتَوْرِدِ بْنِ الأَحْنَفِ ، عَنْ صِلَۃ ، عَنْ حُذَیْفَۃَ ، قَالَ : صَلَّیْتُ مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَکَانَ إِذَا مَرَّ بِآیَۃٍ فِیہَا تَسْبِیحٌ سَبَّحَ ، وَإِذَا مَرَّ بِسُؤَالٍ سَأَلَ ، وَإِذَا مَرَّ بِتَعَوُّذٍ تَعَوَّذَ۔",,,6095,,
6096,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، قَالَ : قُلْتُ لإِبْرَاہِیمَ : أَسْمَعُ الرَّجُلَ وَأَنَا أُصَلِّی یَقُولُ : {إِنَّ اللَّہَ وَمَلاَئِکَتَہُ یُصَلُّونَ عَلَی النَّبِیِّ} ، أَأُصَلِّی عَلَیْہِ ؟ قَالَ : نَعَمْ ، إِنْ شِئْتَ۔",,,6096,,
6097,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : إِذَا قَالَ الرَّجُلُ فِی الصَّلاَۃ : {إِنَّ اللَّہَ وَمَلاَئِکَتَہُ یُصَلُّونَ عَلَی النَّبِیِّ ، یَا أَیُّہَا الَّذِینَ آمَنُوا صَلُّوا عَلَیْہِ وَسَلِّمُوا تَسْلِیمَا} ، فَلْیُصَلِّ عَلَیْہِ۔ قَالَ: وَقَالَ ابْنُ سِیرِینَ : کَانُوا إِذَا قَرَؤُوا الْقُرْآنَ لَمْ یَخْلِطُوا بِہِ مَا لَیْسَ مِنْہُ ، وَیَمْضُونَ کَمَا ہُمْ۔",,,6097,,
6098,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : قُلْتُ لَہُ : الرَّجُلُ یَمُرُّ بِہَذِہِ الآیَۃِ فِی الصَّلاَۃ : {إِنَّ اللَّہَ وَمَلاَئِکَتَہُ یُصَلُّونَ عَلَی النَّبِیِّ} ، أَیُصَلِّی عَلَیْہِ ؟ قَالَ : یَمُرُّ۔",,,6098,,
6099,حَدَّثَنَا خَالِدُ بْنُ الْحَارِثِ ، وَعَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ مَطَرٍ ، عَنْ عَطَائٍ ، عَنْ عَائِشَۃَ ؛ فِی الْحَامِلِ تَرَی الدَّمَ ، لاَ یَمْنَعُہَا ذَلِکَ مِنَ الصَّلاَۃ۔,,,6099,,
6100,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ جَامِعِ بْنِ أَبِی رَاشِدٍ، عَنْ عَطَائٍ؛ فِی الْحَامِلِ تَرَی الدَّمَ، قَالَ: تَوَضَّأُ وَتُصَلِّی۔",,,6100,,
6101,"حَدَّثَنَا إِسْمَاعِیلُ ، عَنْ أَیُّوبَ ، قَالَ: کَتَبْتُ إِلَی نَافِعٍ أَسْأَلُہُ عَنِ الْحَامِلِ تَرَی الدَّمَ ؟ فَکَتَبَ إِلَیَّ : سَأَلْتُ سُلَیْمَانَ بْنَ یَسَارٍ عَنِ الْمَرْأَۃِ تَرَی الدَّمَ فِی غَیْرِ حَیْضٍ ، وَلاَ نِفَاسٍ؟ فَقَالَ: تَغْتَسِلُ ، وَتَسْتَثْفِرُ بِثَوْبٍ ، وَتُصَلِّی۔",,,6101,,
6102,حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ، عَنْ لَیْثٍ، عَنِ الشَّعْبِیِّ، وَعَطَائٍ؛ فِی الْحُبْلَی تَرَی الدَّمَ عَبِیطًا ، تَغْتَسِلُ وَتُصَلِّی۔,,,6102,,
6103,"حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنْ یُونُسَ، عَنِ الْحَسَنِ؛ فِی الْحَامِلِ تَرَی الدَّمَ، قَالَ: تَصْنَعُ کَمَا تَصْنَعُ الْمُسْتَحَاضَۃُ۔",,,6103,,
6104,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ فِی الْحَامِلِ تَرَی الدَّمَ ، قَالَ : إِنْ کَانَتْ تَرَاہُ کَمَا کَانَتْ تَرَاہُ قَبْلَ ذَلِکَ فِی أَقْرَائِہَا ؛ تَرَکَتِ الصَّلاَۃ ، وَإِنْ کَانَ إِنَّمَا ہُوَ فِی الْیَوْمِ وَالْیَوْمَیْنِ ، لَمْ تَدَعِ الصَّلاَۃ۔",,,6104,,
6105,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الْحَسَنِ بْنِ الْحَکَمِ ، عَنِ الْحَکَمِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا رَأَتْہُ وَہِیَ حُبْلَی فَلْتَوَضَّأْ وَلْتُصَلِّ ، فَإِنَّہُ لَیْسَ بِشَیْئٍ۔",,,6105,,
6106,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ؛ فِی الْحَامِلِ تَرَی الدَّمَ ، قَالَ : لَیْسَ بِشَیْئٍ۔ وَقَالَ حَمَّادٌ : ہِیَ بِمَنْزِلَۃِ الْمُسْتَحَاضَۃِ۔",,,6106,,
6107,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَبِیبٍ ، عَنْ عَمْرِو بْنِ ہَرِمٍ ، قَالَ : سُئِلَ جَابِرُ بْنُ زَیْدٍ عَنِ الْحَامِلِ تَرَی الدَّمَ ، أَیَمْنَعُہَا ذَلِکَ مِنَ الصَّلاَۃ ؟ فَقَالَ : إِنَّمَا یَمْنَعُ مِنَ الصَّلاَۃ وَالصَّوْمِ ؛ الْحَیْضُ ، وَہَذَا الْغَیْضُ۔",,,6107,,
6108,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ مَالِکِ بْنِ أَنَسٍ ، قَالَ : سَأَلْتُ الزُّہْرِیَّ عَنِ الْحَامِلِ تَرَی الدَّمَ ؟ قَالَ : تَکُفُّ عَنِ الصَّلاَۃ۔",,,6108,,
6109,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ مِنْدَلٍ ، عَنِ ابْنِ أَبِی إِسْحَاقَ ، عَنْ عِکْرِمَۃَ ، وَالْحَکَمِ ، وَحَمَّادٍ ؛ قَالُوا : لاَ یَجْتَمِعُ حَبَلٌ وَحَیْضٌ ، فَإِذَا رَأَتِ الْحَامِلُ الدَّمَ فَلْتُصَلِّ۔",,,6109,,
6110,"حَدَّثَنَا ہُشَیْمٌ، عَنْ یُونُسَ، عَنِ الْحَسَنِ؛ أَنَّہُ کَانَ یَقُولُ: إِذَا رَأَتِ الدَّمَ عَلَی الْوَلَدِ ،أَمْسَکَتْ عَنِ الصَّلاَۃ۔",,,6110,,
6111,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ فِی الْمَرْأَۃِ تَرَی الدَّمَ وَہِیَ تُطْلَقُ ، قَالَ : تَصْنَعُ مَا تَصْنَعُ الْمُسْتَحَاضَۃُ۔",,,6111,,
6112,"حَدَّثَنَا ابْنُ فُضَیْلٍ، عَنِ الْحَسَنِ بْنِ الْحَکَمِ، عَنِ الْحَکَمِ، عَنْ إِبْرَاہِیمَ؛ فِی الْمَرْأَۃِ تَرَی الدَّمَ وَہِیَ تَمْخُضُ، قَالَ : ہُوَ حَیْضٌ لاَ تُصَلِّی۔",,,6112,,
6113,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ ہَمَّامٍ ، عَنِ الْحَسَنِ ، قَالَ : إِذَا رَأَتِ الدَّمَ عَلَی رَأْسِ الْوَلَدِ ، أَمْسَکَتْ عَنِ الصَّلاَۃ۔",,,6113,,
6114,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : أَخْبَرَنَا مُجَالِدٌ ، عَنِ الشَّعْبِیِّ ، قَالَ : خَرَجَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إِلَی بَدْرٍ ، فَاسْتَخْلَفَ ابْنَ أُمِّ مَکْتُومٍ عَلَی الْمَدِینَۃِ ، فَکَانَ یَؤُمُّہُمْ وَہُوَ أَعْمَی۔",,,6114,,
6115,حَدَّثَنَا وَکِیعٌ ، عَنْ یُونُسَ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الشَّعْبِیِّ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ اسْتَخْلَفَ ابْنَ أُمِّ مَکْتُومٍ ، فَکَانَ یَؤُمُّ النَّاسَ وَہُوَ أَعْمَی۔ (ابوداؤد 595۔ احمد 3/192),,,6115,,
6116,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ؛ أَنَّ أُنَاسًا مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانُوا یَؤُمُّونَ وَہُمْ عُمْیَانٌ مِنْہُمْ ؛ عِتْبَانُ بْنُ مَالِکٍ ، وَمُعَاذُ بْنُ عَفْرَائَ ، وَابْنُ أُمِّ مَکْتُومٍ۔,,,6116,,
6117,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : کَانَ نَاسٌ مِنْ أَہْلِ بَدْرٍ یَؤُمُّونَ فِی مَسَاجِدِہِمْ ، بَعْدَ مَا ذَہَبَتْ أَبْصَارُہُمْ۔",,,6117,,
6118,"حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، قَالَ : دَخَلْنَا عَلَی جَابِرِ بْنِ عَبْدِ اللہِ وَہُوَ أَعْمَی ، فَجَائَ وَقْتُ الصَّلاَۃ ، فَقَامَ فِی نِسَاجَۃٍ مُلْتَحِفًا بِہَا ، کُلَّمَا وَضَعَہَا عَلَی مَنْکِبَیْہِ رَجَعَ طَرَفَاہَا إِلَیْہِ مِنْ صِغَرِہَا ، وَرِدَاؤُہُ إِلَی جَنْبِہِ عَلَی الْمِشْجَبِ ، فَصَلَّی بِنَا۔ (مسلم 147)",,,6118,,
6119,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ أَبِی عَامِرٍ ؛ أَنَّ رَجُلاً سَأَلَ الْحَسَنَ ، أَؤُمُّ قَوْمِی وَأَنَا أَعْمَی ؟ قَالَ : نَعَمْ۔",,,6119,,
6120,"حَدَّثَنَا رَوْحُ بْنُ عُبَادَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ؛ سُئِلَ عَنِ الأَعْمَی یَؤُمُّ؟ قَالَ: فَقَالَ: إِذَا کَانَ أَفْقَہَہُمْ۔",,,6120,,
6121,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ أَنْ یَؤُمَّ الأَعْمَی۔",,,6121,,
6122,"حَدَّثَنَا مُحَمَّدُ بْنُ الْحَسَنِ ، قَالَ : حدَّثَنَا شَرِیکٌ ، عَنْ مُہَاجِرٍ ، قَالَ : کَانَ الْبَرَائُ یُصَلِّی بِنَا وَہُوَ أَعْمَی۔",,,6122,,
6123,"حَدَّثَنَا مُحَمَّدُ بْنُ الْحَسَنِ ، قَالَ : حدَّثَنَا شَرِیکٌ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : أَمَّنَا ابْنُ عَبَّاسٍ وَہُوَ أَعْمَی۔",,,6123,,
6124,حَدَّثَنَا عَبْدَۃُ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنِ ابْنٍ لَعُمَیرٍ ، عَنْ أَبِیہِ ؛ أَنَّ رَجُلاً أَعْمَی کَانَ یَؤُمُّ بَنِی خَطْمَۃَ فِی زَمَنِ عُمَرَ۔,,,6124,,
6125,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ مَحْمُودِ بْنِ رَبِیعٍ ، عَنْ عِتْبَانَ بْنِ مَالِکٍ ؛ أَنَّہُ کَانَ یَؤُمُّ قَوْمَہُ وَہُوَ أَعْمَی۔,,,6125,,
6126,"حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ ، قَالَ : حدَّثَنَا مَالِکُ بْنُ أَنَسٍ ، عَنِ ابْنِ شِہَابٍ ، عَنْ مَحْمُودِ بْنِ الرَّبِیعِ ، عَنْ عِتْبَانَ بْنِ مَالِکٍ ؛ أَنَّہُ کَانَ یَؤُمُّ قَوْمَہُ وَہُوَ أَعْمَی۔ (بخاری 667۔ نسائی 863)",,,6126,,
6127,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ہِشَامٌ ، عَنْ أَبِیہِ ، قَالَ : کَانَ إِمَامُ بَنِی خَطْمَۃَ أَعْمَی۔",,,6127,,
6128,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا حَمَّادُ بْنُ زَیْدٍ، عَنْ عَمْرٍو، عَنْ أَبِی جَعْفَرٍ، قَالَ: أَمَّنَا جَابِرٌ بَعْدَ مَا ذَہَبَ بَصَرُہُ۔",,,6128,,
6129,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، قَالَ : سَأَلَ الْحَکَمُ بْنُ عُتَیْبَۃَ الْقَاسِمَ عَنِ الأَعْمَی یَؤُمُّ ، وَتَجُوزُ شَہَادَتُہُ ؟ فَقَالَ : مَا یَمْنَعُہُ أَنْ یَؤُمَّ وَتَجُوزُ شَہَادَتُہُ۔",,,6129,,
6130,"حَدَّثَنَا ابْنُ مَہْدِیّ ، عَنْ عُمَر بْنِ عَطِیَّۃَ ، قَالَ : أَمَّنَا الْمُسَیَّبُ وَہُوَ أَعْمَی۔",,,6130,,
6131,حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، عَنْ شَیْخٍ یُکَنَّی أَبَا عَبْدِ اللہِ ؛ أَنَّ ابْنَ أَبِی أَوْفَی أَمَّہُمْ وَہُوَ أَعْمَی۔,,,6131,,
6132,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الأَعْلَی ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : کَیْفَ أَؤُمُّہُمْ وَہُمْ یَعْدِلُونِی إِلَی الْقِبْلَۃِ۔",,,6132,,
6133,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ حَسَنِ بْنِ أَبِی الْحَسْنَائِ ، عَنْ زِیَادِ النُّمَیْرِیِّ ، قَالَ : سَأَلْتُ أَنَسًا عَنِ الأَعْمَی ، یَؤُمُّ ؟ فَقَالَ : مَا أَفْقَرَکُمْ إِلَی ذَلِکَ ؟۔",,,6133,,
6134,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ وَاصِلٍ الأَحْدَبِ ، عَنْ قَبِیصَۃَ بْنِ بُرْمَۃَ الأَسَدِیِّ ، قَالَ : قَالَ عَبْدُ اللہِ : مَا أُحِبُّ أَنْ یَکُونَ مُؤَذِّنِیکُمْ عُمْیَانُکُمْ ۔ قَالَ : أَحْسِبُہُ ، قَالَ : وَلاَ قُرَّائَکُمْ۔",,,6134,,
6135,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ إِسْرَائِیلَ ، عَنْ مَرْزُوقٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، أَنَّہُ قَالَ : الأَعْمَی لاَ یَؤُمُّ۔",,,6135,,
6136,حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ رَجُلٍ مِنْ طَیئٍ ؛ أَنَّ ابْنَ مَسْعُودٍ حَجَّ ، فَصَلَّی خَلْفَ أَعْرَابِیٍّ۔,,,6136,,
6137,حَدَّثَنَا مُعْتَمِرٌ ، عَنْ کَہَمْسٍ ، عَنِ الْعَبَّاسِ الْجُرَیْرِیِّ ؛ أَنَّ أَبَا مِجْلَزٍ کَرِہَ إِمَامَۃَ الأَعْرَابِیِّ ، وَأَنَّ الْحَسَنَ لَمْ یَرَ بِذَلِکَ بَأْسًا۔,,,6137,,
6138,"حَدَّثَنَا عَبْدُ الصَّمَدِ بْنِ عَبْدِ الْوَارِثِ ، عَنْ دَارِمٍ ، قَالَ : سَأَلْتُ سَالِمًا : أَیَؤُمُّ الأَعْرَابِیُّ الْمُہَاجِرَ ؟ قَالَ : وَمَا عَلَیْک إِذَا کَانَ رَجُلاً صَالِحًا۔",,,6138,,
6139,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّہُ سُئِلَ عَنْ إِمَامَۃِ الْعَبْدِ وَالأَعْرَابِیِّ ؟ فَقَالَ : الْعَبْدُ إِذَا فَقُہَ أَحَبَّہُمَا إِلَیَّ۔",,,6139,,
6140,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ أَنْ یَؤُمَّ الأَعْرَابِیُّ۔",,,6140,,
6141,حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ؛ أَنَّ ابْنَ مَسْعُودٍ صَلَّی خَلْفَ أَعْرَابِیٍّ۔,,,6141,,
6142,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ بُرْدٍ أَبِی الْعَلاَئِ ، عَنِ الزُّہْرِیِّ ، قَالَ : کَانَ أَئِمَّۃٌ مِنْ ذَلِکَ الْعَمَلِ، یَعْنِی أَوْلاَدَ الزِّنَا۔",,,6142,,
6143,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ أَنْ یَؤُمَّ وَلَدُ الزِّنَا۔",,,6143,,
6144,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ زُہَیْرِ بْنِ أَبِی ثَابِتٍ الْعَبْسِیِّ ، قَالَ : سَمِعْتُ الشَّعْبِیَّ ، یَقُولُ : تَجُوزُ شَہَادَتُہُ ، وَیَؤُمُّ۔",,,6144,,
6145,"حَدَّثَنَا ہُشَیْمٌ، عَنْ مُطَرِّفٍ، عَنِ الشَّعْبِیِّ؛ أَنَّہُ سُئِلَ عَنْ إِمَامَۃِ وَلَدِ الزِّنَا؟ فَقَالَ: إِنَّ لَنَا إِمَامًا مَا یُعْرَفُ لَہُ أَبٌ۔",,,6145,,
6146,"حدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ أَنْ یَؤُمَّ وَلَدُ الزِّنَا۔",,,6146,,
6147,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا أَبُو حَنِیفَۃَ ، قَالَ : سَأَلْتُ عَطَاء ً عَنْ وَلَدِ الزِّنَا ، یَؤُمُّ الْقَوْمَ ؟ فَقَالَ : لاَ بَأْسَ بِہِ، أَلَیْسَ مِنْہُمْ مَنْ ہُوَ أَکْثَرُ صَوْمًا وَصَلاَۃً مِنَّا۔",,,6147,,
6148,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُطَرِّفٍ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ أَنْ یَؤُمَّ وَلَدُ الزِّنَا۔",,,6148,,
6149,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : وَلَدُ الزِّنَا وَغَیْرُہُ سَوَائٌ۔",,,6149,,
6150,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنِ الرَّبِیعِ بْنِ الْمُنْذِرِ الثَّوْرِیِّ ، قَالَ : سَأَلْتُ الْحَارِثَ الْعُکْلِیَّ عَنْ وَلَدِ الزِّنَا یَؤُمُّ؟ قَالَ : نَعَمْ۔",,,6150,,
6151,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ہِشَامُ بْنُ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ؛ أَنَّہَا کَانَتْ إِذَا سُئِلَتْ عَنْ وَلَدِ الزِّنَا؟ قَالَتْ : لَیْسَ عَلَیْہِ مِنْ خَطِیئَۃِ أَبَوَیْہِ شَیْئٌ ، لاَ تَزِرُ وَازِرَۃٌ وِزْرَ أُخْرَی۔",,,6151,,
6152,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ یَحْیَی بْنَ سَعِیدٍ ، قَالَ : بَلَغَنِی أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ قَالَ لِرَجُلٍ ، کَانَ یَؤُمُّ قَوْمًا بِالْعَقِیقِ ، لاَ یُعْرَفُ مَنْ وَلَدُہُ ، فَنَہَاہُ أَنْ یَؤُمَّہُمْ۔",,,6152,,
6153,حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ؛ أَنَّہُ کَرِہَ أَنْ یَؤُمَّ وَلَدُ زِنَیً ، وَصَاحِبُ نَمِیمَۃٍ۔,,,6153,,
6154,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا دَاوُد بْنُ عَبْدِ الرَّحْمَنِ ، قَالَ : حَدَّثَنِی عَمْرُو بْنُ یَحْیَی الْمَازِنِیُّ ؛ أَنَّ رَجُلاً حُدَّ فِی فِرْیَۃٍ ، فَکَانَ یَؤُمُّ أَصْحَابَہُ ، فَسَأَلُوا عُمَرَ بْنَ عَبْدِ الْعَزِیزِ ، فَقَالَ : کَیْفَ رَأَیْتُمُوہُ ؟ فَقَالُوا : قَدْ کَانَ مِنْہُ مَا کَانَ ، فَأَثْنَوْا عَلَیْہِ خَیْرًا ، فَأَمَرَہُ أَنْ یَؤُمَّہُمْ۔",,,6154,,
6155,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی عِمْرَانَ الْجَوْنِیِّ ، عَنْ عَبْدِ اللہِ بْنِ الصَّامِتِ ، عَنْ أَبِی ذَرٍّ ؛ أَنَّہُ قَدِمَ وَعَلَی الرَّبَذَۃِ عَبْدٌ حَبَشِیٌّ ، فَأُقِیمَتِ الصَّلاَۃ ، فَقَالَ : تَقَدَّمْ۔",,,6155,,
6156,حَدَّثَنَا یَزِیدُ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّ أَبَا ذَرٍّ قَدَّمَ مَمْلُوکًا۔,,,6156,,
6157,حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ ، عَنْ أَبِی ذَرٍّ ؛ أَنَّہُ صَلَّی خَلْفَ عَبْدٍ حَبَشِیٍّ۔,,,6157,,
6158,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ہِشَامُ بْنُ عُرْوَۃَ ، عَنْ أَبِی بَکْرِ بْنِ أَبِی مُلَیْکَۃَ ، عَنْ عَائِشَۃَ ؛ أَنَّہَا کَانَ یَؤُمُّہَا مُدَبَّرٌ لَہَا۔",,,6158,,
6159,"حَدَّثَنَا وَکِیعٌ ، قَالَ: حدَّثَنَا سُفْیَان ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ القَاسِم بن مُحَمَّد ، عَن أَبِیہِ ؛ أَنَّ عَائِشَۃَ صَلّتْ خَلْفَ مَملُوکٍ لَہَا۔",,,6159,,
6160,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ دَاوُدَ بْنِ أَبِی ہِنْدٍ ، عَنْ أَبِی نَضْرَۃَ ، عَنْ أَبِی سَعِیدٍ مَوْلَی أَبِی أَسِیْد ، قَالَ : تَزَوَّجْتُ وَأَنَا عَبْدٌ مَمْلُوکٌ ، فَدَعَوْتُ أُنَاسًا مِنْ أَصْحَابِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِیہِمْ ؛ أَبُو ذَرٍّ ، وَابْنُ مَسْعُودٍ ، وَحُذَیْفَۃُ ، فَأُقِیمَتِ الصَّلاَۃ ، فَتَقَدَّمَ أَبُو ذَرٍّ ، فَقَالَ : وَرَائَک ، فَالْتَفَتَ إِلَی أَصْحَابِہِ ، فَقَالَ : کَذَلِکَ ؟ قَالَ : نَعَمْ ، قَالَ : فَقَدَّمُونِی ، فَصَلَّیْتُ بِہِمْ وَأَنَا عَبْدٌ مَمْلُوکٌ۔",,,6160,,
6161,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ إِبْرَاہِیمَ بْنِ أَبِی حَبِیبَۃَ ، عَنْ دَاوُدَ بْنِ الْحُصَیْنِ ، عَنْ أَبِی سُفْیَانَ ؛ أَنَّہُ کَانَ یَؤُمُّ بَنِی عَبْدِ الأَشْہَلِ وَہُوَ مُکَاتَبٌ ، وَفِیہِمْ رِجَالٌ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ مُحَمَّدُ بْنُ مَسْلَمَۃَ ، وَسَلَمَۃُ بْنُ سَلاَمَۃَ ، فَأَرَادُوا تَأْخِیرَہُ ، فَلَمَّا سَمِعَا قِرَائَتَہُ ، قَالاَ : أَمِثْلُ ہَذَا یُؤَخَّرُ ؟۔",,,6161,,
6162,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إِدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَابْنِ سِیرِینَ ، قَالاَ : لاَ بَأْسَ أَنْ یَؤُمَّ الْعَبْدُ۔",,,6162,,
6163,حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ یَؤُمَّ الْعَبْدُ۔,,,6163,,
6164,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سُفْیَانَ ، عَنْ بَیَانٍ ، عَنْ عَامِرٍ ، قَالَ : لاَ بَأْسَ أَنْ یَؤُمَّ الْعَبْدُ۔",,,6164,,
6165,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ شَہْرٍ ، قَالَ : لاَ بَأْسَ أَنْ یَؤُمَّ الْعَبْدُ إِذَا کَانَ أَفْقَہَہُمْ۔",,,6165,,
6166,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ زِیَادٍ مَوْلَی أُمِّ الْحَسَنِ ، قَالَ : صَلَّی خَلْفِی سَالِمُ بْنُ عَبْدِ اللہِ ، وَأَنَا عَبْدٌ۔",,,6166,,
6167,حَدَّثَنَا مُعْتَمِرٌ ، عَنْ کَہَمْسٍ ، عَنِ الْعَبَّاسِ الْجُرَیْرِیِّ ؛ أَنَّ أَبَا مِجْلَزٍ کَرِہَ إِمَامَۃَ الْعَبْدِ ، وَأَنَّ الْحَسَنَ لَمْ یَرَ بِہِ بَأْسًا۔,,,6167,,
6168,"حَدَّثَنَا رَوْحُ بْنُ عُبَادَۃَ ، قَالَ : أَخْبَرَنِی ابْنُ جُرَیْجٍ ، عَنْ عَبْدِ اللہِ بْنِ عُبَیْدِ اللہِ بْنِ أَبِی مُلَیْکَۃَ ؛ أَنَّہُمْ کَانُوا یَأْتُونَ عَائِشَۃَ ، أَبُوہُ ، وَعُبَیْدُ بْنُ عُمَیْرٍ ، وَالْمِسْوَرُ بْنُ مَخْرَمَۃَ ، وَأُنَاسٌ کَثِیرٌ فَیَؤُمُّہُمْ أَبُو عَمْرٍو مَوْلًی لِعَائِشَۃَ ، وَأَبُو عَمْرٍو حِینَئِذٍ غُلاَمٌ لَمْ یُعْتَقْ۔",,,6168,,
6169,"حَدَّثَنَا رَوْحُ بْنُ عُبَادَۃَ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، قَالَ : کَانَ یَؤُمُّنَا فِی مَسْجِدِنَا ہَذَا عَبْدٌ أَرْبَعِینَ سَنَۃً ، مَسْجِدٍ کَانَ یُصَلِّی فِیہِ شُرَیْحٌ۔",,,6169,,
6170,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ بَشَّارِ بْنِ کِدَامٍ السُّلَمِیِّ ، عَنْ عَمْرِو بْنِ مَیْسَرَۃَ ، عَنِ الْحَسَنِ بْنِ عَلِیٍّ ؛ أَنَّہُ صَلَّی خَلْفَ مَمْلُوکٍ فِی حَائِطٍ مِنْ حِیطَانِہِ ، وَنَاسٌ مِنْ أَہْلِ بَیْتِہِ۔,,,6170,,
6171,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا بَشِیر بْن سَلْمَانَ ، عَنْ یَحْیَی بْنِ بِسْطَامٍ التَّمِیمِیِّ ، عَنِ الضِّحَّاکِ ، قَالَ : لاَ یَؤُمُّ الْمَمْلُوکُ وَفِیہِمْ حُرٌّ ، وَلاَ یَؤُمُّ مَنْ لَمْ یَحُجَّ ، وَفِیہِمْ مَنْ قَدْ حَجَّ۔",,,6171,,
6172,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، قَالَ : حدَّثَنِی إِبْرَاہِیمُ بْنُ أَبِی حَبِیبَۃَ ، قَالَ : حَدَّثَنِی عَبْدُ اللہِ بْنُ أَبِی سُفْیَانَ ، عَنْ أَبِیہِ ، قَالَ : خَرَجْتُ مَعَ عَبْدِ اللہِ بْنِ جَعْفَرٍ ، وَحُسَیْنِ بْنِ عَلِیٍّ ، وَابْنِ أَبِی أَحْمَدَ إِلَی یَنْبُعَ ، فَحَضَرَتِ الصَّلاَۃ ، فَقَدَّمُونِی ، فَصَلَّیْت بِہِمْ۔",,,6172,,
6173,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ سُلَیْمَانَ بْنِ الْغَسِیلِ ، قَالَ : حَدَّثَنِی الْمُنْذِرُ بْنُ أَبِی أُسَیْدِ الأَنْصَارِیِّ ، قَالَ : کَانَ أَبِی یُصَلِّی خَلْفِی ، فَرُبَّمَا قَالَ لِی : یَا بُنَیَّ طَوَّلْتَ بِنَا الْیَوْمَ۔",,,6173,,
6174,"حَدَّثَنَا وَکِیعٌ ، قَالَ : أَخْبَرَنَا إِبْرَاہِیمُ بْنُ یَزِیدَ الْمَکِّیُّ ، عَنْ عَطَائٍ ، قَالَ : لاَ یَؤُمُّ الرَّجُلُ أَبَاہُ۔",,,6174,,
6175,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا أَبَانُ بْنُ یَزِیدَ الْعَطَّارُ ، عَنْ بُدَیْلِ بْنِ مَیْسَرَۃَ الْعُقَیْلِیِّ ، عَنْ أَبِی عَطِیَّۃَ رَجُلٌ مِنْہُمْ ، قَالَ : کَانَ مَالِکُ بْنُ الْحُوَیْرِثِ یَأْتِینَا فِی مُصَلاَّنَا ہَذَا نَتَحَدَّثُ ، فَحَضَرَتِ الصَّلاَۃُ ، فَقُلْنَا لَہُ : تَقَدَّمْ ، فَقَالَ : لاَ ، لِیَتَقَدَّمُ بَعْضُکُمْ حَتَّی أُحَدِّثَـکُمْ لِمَ لاَ أَتَقَدَّمُ ، سَمِعْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، یَقُولُ : مَنْ زَارَ قَوْمًا فَلاَ یَؤُمُّہُمْ ، وَلْیَؤُمَّہُمْ رَجُلٌ مِنْہُمْ۔ (ابوداؤد 596۔ احمد 3/436)",,,6175,,
6176,"حَدَّثَنَا جَرِیرٌ ، وَہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ سِمَاکِ بْنِ سَلَمَۃَ الضَّبِّیِّ ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ ، وَابْنَ عَبَّاسٍ وَہُمَا مُتَرَبِّعَانِ فِی الصَّلاَۃ۔",,,6176,,
6177,"حَدَّثَنَا حَفْصٌ ، عَنْ عُقْبَۃَ ، قَالَ : رَأَیْتُ أَنَسًا یُصَلِّی مُتَرَبِّعًا۔",,,6177,,
6178,"حَدَّثَنَا وَکِیعٌ ، عَنْ سَعِیدِ بْنِ عُبَیْدٍ الطَّائِیِّ ، عَنْ أَخِیہِ ، قَالَ : رَأَیْتُ أَنَسًا یُصَلِّی مُتَرَبِّعًا۔",,,6178,,
6179,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عُمَرَ الأَنْصَارِیِّ ، قَالَ : رَأَیْتُ أَنَسًا یُصَلِّی مُتَرَبِّعًا عَلَی طِنْفُسَۃٍ۔",,,6179,,
6180,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُحَمَّدِ بْنِ جُحَادَۃَ ، قَالَ : رَأَیْتُ سَالِمًا یُصَلِّی مُتَرَبِّعًا۔",,,6180,,
6181,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ رَجَائٍ ، عَنْ مُجَاہِدٍ ، قَالَ : یُصَلِّی مُتَرَبِّعًا۔",,,6181,,
6182,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ حُمَیْدٍ ، قَالَ : رَأَیْتُ أَبَا بَکْرٍ یُصَلِّی مُتَرَبِّعًا وَمُتَّکِئًا۔",,,6182,,
6183,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْمَاعِیلَ بْنِ عَبْدِ الْمَلِکِ ، قَالَ : رَأَیْتُ عَطَائً یُصَلِّی مُتَرَبِّعًا۔",,,6183,,
6184,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا جَرِیرُ بْنُ حَازِمٍ ، قَالَ : رَأَیْتُ ابْنَ سِیرِینَ یُصَلِّی مُتَرَبِّعًا۔",,,6184,,
6185,حَدَّثَنَا عُبَیْدُاللہِ بْنُ مُوسَی، عَنْ إِسْرَائِیلَ، عَنْ جَابِرٍ، عَنْ أَبِی جَعْفَرَ؛ أَنَّہُ کَانَ یَجْلِسُ فِی الصَّلاَۃ مُتَرَبِّعًا۔,,,6185,,
6186,"حَدَّثَنَا وَکِیعٌ ، عَنِ الْفَضْلِ بْنِ دَلْہَمٍ ، عَنِ الْحَسَنِ ، قَالَ : لاَ بَأْسَ أَنْ یُصَلِّیَ فِی التَّطَوُّعِ مُتَرَبِّعًا۔",,,6186,,
6187,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنِ الْہَیْثُمِ بْنِ شِہَابٍ ؛ أَنَّہُ رَأَی رَجُلاً مِنْ قَوْمِہِ وَہُوَ یُصَلِّی قَاعِدًا مُتَرَبِّعًا فَنَہَاہُ ، فَأَبَی أَنْ یُطِیعَہُ ، فَقَالَ الْہَیْثُمِ : سَمِعْتُ عَبْدَ اللہِ بْنَ مَسْعُودٍ ، یَقُولُ : لأَنْ أَقْعُدَ عَلَی رَضْفَتَیْنِ أَحَبُّ إِلَیَّ مِنْ أَنْ أَقْعُدَ مُتَرَبِّعًا فِی الصَّلاَۃ۔",,,6187,,
6188,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، قَالَ : سَأَلْتُ الْحَکَمَ عَنِ التَّرَبُّعِ فِی الصَّلاَۃِ ؟ فَکَأَنَّہُ کَرِہَہُ ۔ قَالَ : وَأَحْسِبُہُ قَالَ : کَرِہَہُ ابْنُ عَبَّاسٍ۔",,,6188,,
6189,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ، عَنْ حَجَّاجٍ، عَنْ حَمَّادٍ، عَنْ إِبْرَاہِیمَ؛ أَنَّہُ کَرِہَ أَنْ یُصَلِّیَ مُتَرَبِّعًا، وَقَالَ: اجْلِسْ غَیْرَ جِلْسَتِکَ لِلْحَدِیثِ۔",,,6189,,
6190,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا سُفْیَانُ ، عَنِ الزُّبَیْرِ بْنِ عَدِیٍّ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّہُ کَرِہَ أَنْ یَجْلِسَ فِی الصَّلاَۃ جِلْسَۃَ الرَّجُلِ یُحَدِّثُ أَصْحَابَہُ۔",,,6190,,
6191,"حَدَّثَنَا وَکِیعٌ، قَالَ: حَدَّثَنَا جَرِیرُ بْنُ حَازِمٍ، عَنِ الْمُغِیرَۃِ بْنِ حَکِیمٍ الصَّنْعَانِیِّ، قَالَ: رَأَیْتُ ابْنَ عُمَرَ مُتَرَبِّعًا فِی آخَرِ صَلاَتِہِ ، حِینَ رَفَعَ رَأْسَہُ مِنَ السَّجْدَۃِ الآخِرَۃِ ، فَلَمَّا صَلَّی ، قُلْتُ لَہُ ؟ فَقَالَ : إِنِّی أَشْتَکِی رِجْلِی۔",,,6191,,
6192,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ؛ أَنَّ ابْنَ عُمَرَ صَلَّی مُتَرَبِّعًا مِنْ وَجَعٍ۔,,,6192,,
6193,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ ، قَالَ : کَانَ یُکْرَہُ أَنْ یَتَرَبَّعَ الرَّجُلُ فِی صَلاَتِہِ حَتَّی یَتَشَہَّدَ۔",,,6193,,
6194,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنِ ابْنِ سِیرِینَ ؛ نُبِّئْتُ أَنَّ ابْنَ عُمَرَ صَلَّی مُتَرَبِّعًا ، وَقَالَ : إِنَّہُ لَیْسَ بِسُنَّۃٍ، إِنَّمَا أَفْعَلُہُ مِنْ وَجَعٍ۔",,,6194,,
6195,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ؛ أَنَّہُ کَرِہَ التَّرَبُّعَ ، وَقَالَ : جِلْسَۃُ مَمْلَکَۃٍ۔",,,6195,,
6196,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا صَلَّی قَاعِدًا جَعَلَ قِیَامَہُ مُتَرَبِّعًا۔",,,6196,,
6197,"حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ مُطَرِّفٍ ، عَنْ سُلَیْمَانَ بْنِ بَزِیعٍ ، قَالَ : دَخَلْتُ عَلَی سَالِمٍ وَہُوَ یُصَلِّی جَالِسًا ، فَإِذَا کَانَ الجُلُوس جَثَا لرُکْبَتَیہِ ، وَإِذَا کَانَ القِیام تَرَبَّعَ۔",,,6197,,
6198,"حَدَّثَنَا وَکِیعٌ ، قَالَ : قَالَ سُفْیَانُ : إِذَا صَلَّی جَالِسًا جَعَلَ قِیَامَہُ مُتَرَبِّعًا ، فَإِذَا أَرَادَ أَنْ یَرْکَعَ رَکَعَ وَہُوَ مُتَرَبِّعٌ ، فَإِذَا أَرَادَ أَنْ یَسْجُدَ ثَنَی رِجْلَہُ۔",,,6198,,
6199,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مِسْعَرٌ ، عَنْ حَمَّادٍ ، عَنْ مُجَاہِدٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : إِذَا صَلَّی مُتَرَبِّعًا ، قَالَ مِسْعَرٌ : أَوْ کَمَا قَالَ ، یَجْلِسُ ، فَإِذَا أَرَادَ أَنْ یَرْکَعَ ، أَوْ یَسْجُدَ ثَنَی رِجْلَہُ۔",,,6199,,
6200,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : یُصَلِّی مُتَرَبِّعًا ، فَإِذَا أَرَادَ أَنْ یَرْکَعَ ثَنَی رِجْلَہُ۔",,,6200,,
6201,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا حَسَنٌ ، عَنْ أَبِی حَفْصٍ ، قَالَ : رَأَیْتُ أَنَسًا یُصَلِّی مُتَرَبِّعًا ، فَإِذَا أَرَادَ أَنْ یَرْکَعَ ثَنَی رِجْلَہُ۔",,,6201,,
6202,"حَدَّثَنَا عَبَّادُ بْنُ عَوَّامٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ فِی الرَّجُلِ یَدْخُلُ الْمَسْجِدَ وَقَدْ تَمَّ الصَّفُّ ، قَالَ : إِنِ اسْتَطَاعَ أَنْ یَدْخُلَ فِی الصَّفِّ دَخَلَ ، وَإِلاَّ أَخَذَ بِیَدِ رَجُلٍ فَأَقَامَہُ مَعَہُ ، وَلَمْ یَقُمْ وَحْدَہُ۔",,,6202,,
6203,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ عَمْرِو بْنِ مَیْمُونٍ ، قَالَ : قُلْتُ لإِبْرَاہِیمَ : أَجِیئُ إِلَی الصَّفِّ وَقَدِ امْتَلأَ ؟ قَالَ : مُرْ رَجُلاً ، فَأَقِمْہُ مَعَک ، فَإِنْ صَلَّیْتَ وَحْدَک فَأَعِدْ۔",,,6203,,
6204,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، وَعَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یَؤُمُّ نِسَائَہُ فِی الْمَکْتُوبَۃِ ، لَیْسَ مَعَہُنَّ رَجُلٌ۔,,,6204,,
6205,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ہِشَامٌ ، عَنْ أَبِیہِ ، قَالَ : جَعَلَ عُمَرُ بْنُ الْخَطَّابَ لِلنَّاسِ قَارِئِینَ فِی رَمَضَانَ ، فَکَانَ أُبَیٌّ یُصَلِّی بِالنَّاسِ ، وَابْنُ أَبِی حَثْمَۃَ یُصَلِّی بِالنِّسَائِ۔",,,6205,,
6206,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ غَالِبٍ أَبِی الْہُذَیْلِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کُنْتُ أُصَلِّی فِی الْحَیِّ فِی زَمَنِ الْحَجَّاجِ ، وَمَا خَلْفِی إِلاَّ امْرَأَۃٌ۔",,,6206,,
6207,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، قَالَ : سَأَلْتُ الشَّعْبِیَّ ، وَعَطَائً عَنِ الرَّجُلِ یَؤُمُّ النِّسَائَ ، لَیْسَ مَعَہُنَّ رَجُلٌ ؟ فَقَالاَ : لاَ بَأْسَ بِہِ۔",,,6207,,
6208,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ عُمَرَ بْنِ عَبْدِ اللہِ الثَّقَفِیِّ ، قَالَ : حدَّثَنَا عَرْفَجَۃُ ، قَالَ : کَانَ عَلِیٌّ یَأْمُرُ النَّاسَ بِقِیَامِ رَمَضَانَ ، وَکَانَ یَجْعَلُ لِلرِّجَالِ إِمَامًا ، وَلِلنِّسَائِ إِمَامًا ۔ قَالَ عَرْفَجَۃُ : فَأَمَرَنِی عَلِیٌّ ، فَکُنْتُ إِمَامَ النِّسَائِ۔",,,6208,,
6209,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : سُئِلَ عَنِ الرَّجُلِ یَؤُمُّ النِّسْوَۃَ فِی رَمَضَانَ ؟ قَالَ: کَانَ لاَ یَرَی بِہِ بَأْسًا إِذَا کَانَ الرَّجُلُ لاَ بَأْسَ بِہِ ، قَالَ : ، وَإِنْ کَانَ الرَّجُلُ لَیَخْرُجُ فَتَفُوتُہُ الصَّلاَۃ فِی جَمَاعَۃٍ ، فَیَرْجِعُ إِلَی أَہْلِہِ ، فَیَجْمَعُہُمْ فَیُصَلِّی بِہِمْ۔",,,6209,,
6210,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ مُطَہَّرِ بْنِ جُوَیْرِیَۃَ ، قَالَ : رَأَیْتُ أَبَا مِجْلَزٍ وَلَہُ مَسْجِدٌ فِی دَارِہِ ، فَرُبَّمَا جَمَّعَ بِأَہْلِہِ وَغِلْمَانِہِ۔",,,6210,,
6211,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ لَیْثٍ ، عَنْ نُعَیْمٍ ، قَالَ : قَالَ عُمَرُ : إِذَا کَانَ بَیْنَہُ وَبَیْنَ الإِمَام طَرِیقٌ ، أَوْ نَہْرٌ ، أَوْ حَائِطٌ فَلَیْسَ مَعَہُ۔",,,6211,,
6212,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّہُ کَانَ یَکْرَہُ أَنْ یُصَلِّیَ بِصَلاَۃِ الإِمَام إِذَا کَانَ بَیْنَہُمَا طَرِیقٌ ، أَوْ نِسَائٌ۔,,,6212,,
6213,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ إِسْرَائِیلَ ، عَنْ عِیسَی بْنِ أَبِی عَزَّۃَ ، عَنِ الشَّعْبِیِّ ، قَالَ : سَأَلْتُُہُ عَنِ الْمَرْأَۃِ تَأْتَمُّ بِالإِمَام ، وَبَیْنَہُمَا طَرِیقٌ ؟ فَقَالَ : لَیْسَ ذَلِکَ لَہَا۔",,,6213,,
6214,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ حُمَیْدٍ ، قَالَ : کَانَ أَنَسُ یُجَمِّعُ مَعَ الإِمَامِ ، وَہُوَ فِی دَارِ نَافِعِ بْنِ عَبْدِ الْحَارِثِ ، بَیْتٌ مُشْرِفٌ عَلَی الْمَسْجِدِ ، لَہُ بَابٌ إِلَی الْمَسْجِدِ ، فَکَانَ یُجَمِّعُ فِیہِ وَیَأْتَمُّ بِالإِمَام۔",,,6214,,
6215,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنْ صَالِحٍ مَوْلَی التَّوْأَمَۃِ ، قَالَ : صَلَّیْتُ مَعَ أَبِی ہُرَیْرَۃَ فَوْقَ الْمَسْجِدِ بِصَلاَۃِ الإِمَام ، وَہُوَ أَسْفَلُ۔",,,6215,,
6216,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ لَیْثٍ ، عَنْ أَبِی مِجْلَزٍ ؛ فِی الْمَرْأَۃِ تُصَلِّی وَبَیْنَہَا وَبَیْنَ الإِمَام حَائِطٌ ، قَالَ : إِذَا کَانَتْ تَسْمَعُ التَّکْبِیرَ أَجْزَأَہَا ذَلِکَ۔",,,6216,,
6217,"حَدَّثَنَا أَبُو عَامِرٍ الْعَقَدِیُّ ، عَنْ سَعِیدِ بْنِ مُسْلِمٍ ، قَالَ : رَأَیْتُ سَالِمَ بْنَ عَبْدِ اللہِ یُصَلِّی فَوْقَ ظَہْرِ الْمَسْجِدِ صَلاَۃَ الْمَغْرِبِ ، وَمَعَہُ رَجُلٌ آخَرَ ، یَعْنِی وَیَأْتَمُّ بِالإِمَام۔",,,6217,,
6218,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، قَالَ : کَانَ إِلَی جَنْبِ مَسْجِدِنَا سَطْحٌ ، عَنْ یَمِینِ الْمَسْجِدِ ، أَسْفَلُ مِنَ الإِمَام ، فَکَانَ قَوْمٌ ہَارِبِینَ فِی إِمَارَۃِ الْحَجَّاجِ ، وَبَیْنَہُمْ وَبَیْنَ الْمَسْجِدِ حَائِطٌ طَوِیلٌ ، یُصَلُّونَ عَلَی ذَلِکَ السَّطْحِ ، وَیَأْتَمُّونَ بِالإِمَام ، فَذَکَرْتُہُ لإِبْرَاہِیمَ ، فَرَآہُ حَسَنًا۔",,,6218,,
6219,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : سُئِلَ مُحَمَّدٌ عَنِ الرَّجُلِ یَکُونُ عَلَی ظَہْرِ بَیْتٍ ، یُصَلِّی بِصَلاَۃِ الإِمَام فِی رَمَضَانَ ؟ فَقَالَ : لاَ أَعْلَمُ بِہِ بَأْسًا ، إِلاَّ أَنْ یَکُونَ بَیْنَ یَدَیِ الإِمَام۔",,,6219,,
6220,حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ؛ أَنَّ عُرْوَۃَ کَانَ یُصَلِّی بِصَلاَۃِ الإِمَامِ ، وَہُوَ فِی دَارِ حُمَیْدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ الْحَارِثِ ، وَبَیْنَہُمَا وَبَیْنَ الْمَسْجِدِ طَرِیقٌ۔,,,6220,,
6221,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : سُئِلَ عَنِ الْمُؤَذِّنِ یُقِیمُ فِی الْمِئْذَنَۃِ ، وَیُصَلِّی بِصَلاَۃِ الإِمَام ؟ قَالَ : یُجْزِئُہُ۔",,,6221,,
6222,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی حَنِیفَۃَ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : سَأَلْتُُہُ عَنْ صَلاَۃِ الْمُؤَذِّنِینَ فَوْقَ الْمَسْجِدِ یَوْمَ الْجُمُعَۃِ بِصَلاَۃِ الإِمَام وَہُوَ أَسْفَلُ ؟ قَالَ : یُجْزِئُہُمْ۔",,,6222,,
6223,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : سَأَلْتُُہُ عَنِ الْمُؤَذِّنِ یُصَلِّی فِی صَوْمَعَتِہِ ، وَیَأْتَمُّ بِالإِمَام ؟ فَکَرِہَ ذَلِکَ۔",,,6223,,
6224,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ سُلَیْمَانَ التَّیْمِیِّ ، عَنِ ابْنِ سِیرِینَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ عُمَرُ : تُصَلِّی الْمَرْأَۃُ فِی ثَلاَثَۃِ أَثْوَابٍ۔",,,6224,,
6225,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، عَنْ مَکْحُولٍ ، قَالَ : سُئِلَتْ عَائِشَۃُ : فِی کَمْ تُصَلِّی الْمَرْأَۃُ ؟ فَقَالَتْ : ائْتِ عَلِیًّا فَاسْأَلْہُ ثُمَّ ارْجِعْ إِلَیَّ ، فَأَتَی عَلِیًّا فَسَأَلَہُ ، فَقَالَ : فِی دِرْعٍ سَابِغٍ وَخِمَارٍ ، فَرَجَعَ إِلَیْہَا فَأَخْبَرَہَا، فَقَالَتْ : صَدَقَ۔",,,6225,,
6226,"حَدَّثَنَا عَبَّادُ بْنُ عَوَّامٍ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ بُکَیْرِ بْنِ الأَشَجِّ ، عَنْ عُبیدِ اللہِ الْخَوْلاَنِیِّ ، قَالَ : رَأَیْتُ مَیْمُونَۃَ زَوْجَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ تُصَلِّی فِی دِرْعٍ وَاحِدٍ فَضْلاً ، وَقَدْ وَضَعَتْ بَعْضَ کُمِّہَا عَلَی رَأْسِہَا ۔ قَالَ : وَکَانَ عُبَیْدُ اللہِ یَتِیمًا فِی حِجْرِہَا۔",,,6226,,
6227,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مَالِکُ بْنُ أَنَسٍ ، عَنْ بُکَیْرِ بْنِ عَبْدِ اللہِ بْنِ الأَشَجِّ ، عَنْ عُبَیْدِ اللہِ الْخَوْلاَنِیِّ، عَنْ مَیْمُونَۃَ بِنْتِ الْحَارِثِ ، زَوْجِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ أَنَّہَا صَلَّتْ فِی دِرْعٍ وَخِمَارٍ۔",,,6227,,
6228,"أَخْبَرَنَا حَفْصٌ ، عَنْ مُحَمَّدِ بْنِ زَیْدٍ ، قَالَ : حدَّثَتْنِی أُمِّی ؛ أَنَّہَا سَأَلَتْ أُمَّ سَلَمَۃَ ، زَوْجَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : فِی أَیِّ شَیْئٍ تُصَلِّی الْمَرْأَۃُ ؟ فَقَالَتْ : تُصَلِّی فِی دِرْعٍ سَابِغٍ ، یُغَطِّی قَدَمَیْہَا وَالْخِمَارِ۔",,,6228,,
6229,"حَدَّثَنَا وَکِیعٌ ، قَالَ : أَخْبَرَنَا ہِشَامُ بْنُ سَعْدٍ ، عَنْ مُحَمَّدِ بْنِ زَیْدٍ بن مُہَاجِرِ بْنِ قُنْفُذٍ ، عَنْ أُمِّہِ ، عَنْ أُمِّ سَلَمَۃَ ، قَالَتْ : تُصَلِّی الْمَرْأَۃُ فِی الدِّرْعِ السَّابِغِ وَالْخِمَارِ۔",,,6229,,
6230,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ جَابِرٍ ، عَنْ أُمِّ ثَوْرٍ ، عَنْ زَوْجِہَا بِشْرٍ ؛ أَنَّہُ سَأَلَ ابْنَ عَبَّاسٍ : فِی کَمْ تُصَلِّی الْمَرْأَۃُ ؟ فَقَالَ : فِی دِرْعٍ وَخِمَارٍ۔",,,6230,,
6231,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : إِذَا صَلَّتِ الْمَرْأَۃُ ، فَلْتُصَلِّ فِی ثِیَابِہَا کُلِّہَا ؛ الدِّرْعُ ، وَالْخِمَارُ ، وَالْمِلْحَفَۃُ۔",,,6231,,
6232,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ أَشْعَثَ، عَنْ مُحَمَّدٍ، عَنْ عَبِیدَۃَ، قَالَ: تُصَلِّی الْمَرْأَۃُ فِی الدِّرْعِ وَالْخِمَارِ وَالْحَقْوٗ۔\n\nقَالَ أَشْعَثُ ، عَنْ مُحَمَّدٍ ، مِثْلَہُ ، فَقُلْتُ لَہُ : مَا ہَذِہِ الْخُمُرُ ؟ فَقَالَ : الْخِمَارُ مَا خَمَّرَ ، وَکَانَتِ الأَنْصَارُ تُسَمِّی الإِزَارَ الْحَقْوَ۔",,,6232,,
6233,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : تُصَلِّی الْمَرْأَۃُ فِی ثَلاَثَۃِ أَثْوَابٍ۔",,,6233,,
6234,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا أَبُو ہِلاَلٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : کَانَ یَسْتَحِبُّ أَنْ تُصَلِّیَ الْمَرْأَۃُ فِی ثَلاَثَۃِ أَثْوَابٍ ؛ فِی الدِّرْعِ ، وَالْخِمَارِ ، وَالْحَقْوِ۔",,,6234,,
6235,حَدَّثَنَا أَبُوالأَحْوَصِ، عَنْ مُغِیرَۃَ، عَنْ إِبْرَاہِیمَ؛ أَنَّہُ کَانَ یُرَخِّصُ لِلْمَرْأَۃِ أَنْ تُصَلِّیَ فِی الدِّرْعِ وَالْجِلْبَابِ۔,,,6235,,
6236,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، قَالَ : قالَتِ امْرَأَۃٌ لأَبِی : إِنِّی امْرَأَۃٌ حُبْلَی ، وَإِنَّہُ یَشُقُّ عَلَیَّ أَنْ أُصَلِّیَ فِی الْمِنْطَقِ ، أَفَأُصَلِّی فِی دِرْعٍ وَخِمَارٍ ؟ قَالَ : نَعَمْ۔",,,6236,,
6237,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ الْجُرَیْرِیِّ ، عَنْ عِکْرِمَۃَ ، قَالَ : تُصَلِّی الْمَرْأَۃُ فِی دِرْعٍ وَخِمَارِ حَصِیْفٍ۔",,,6237,,
6238,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہَمَّامٍ ، عَنْ قَتَادَۃَ ، عَنْ جَابِرِ بْنِ زَیْدٍ ، قَالَ : تُصَلِّی الْمَرْأَۃُ فِی دِرْعٍ صَفِیقٍ ، وَخِمَارٍ صَفِیقٍ۔",,,6238,,
6239,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، قَالَ : قَالَ عَطَائٌ : فِی دِرْعٍ وَخِمَارٍ۔",,,6239,,
6240,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ ، فَقَالَ : فِی دِرْعٍ وَخِمَارٍ ، وَسَأَلْتُ حَمَّادًا ، فَقَالَ : تُصَلِّی فِی دِرْعٍ ، وَمِلْحَفَۃٍ تُغَطِّی رَأْسَہَا۔",,,6240,,
6241,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : لاَ تُصَلِّی الْمَرْأَۃُ فِی أَقَلَّ مِنْ أَرْبَعَۃِ أَثْوَابٍ۔",,,6241,,
6242,حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَاصِمٍ ، عَنْ مُعَاذَۃَ ، عَنْ عَائِشَۃَ ؛ أَنَّہَا قَامَتْ تُصَلِّی فِی دِرْعٍ وَخِمَارٍ ، فَأَتَتْہَا الأَمَۃُ ، فَأَلْقَتْ عَلَیْہَا ثَوْبًا۔,,,6242,,
6243,"حَدَّثَنَا أَزْہَرُ السَّمَّانُ ، عَنِ ابن عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : تَتَّزِرُ بِہِ۔",,,6243,,
6244,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عُمَرَ بْنِ ذَرٍّ ، قَالَ : سَأَلْتُ مُجَاہِدًا ، وَعَطَائً عَنِ الْمَرْأَۃِ تَحْضُرُہَا الصَّلاَۃ ، وَلَیْسَ لَہَا إِلاَّ ثَوْبٌ وَاحِدٌ ؟ قَالاَ : تَتَّزِرُ بِہِ۔",,,6244,,
6245,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عُمَرُ بْنُ ذَرٍّ ، قَالَ : سَأَلْتُ عَطَائً عَنِ الْمَرْأَۃِ لاَ یَکُونُ لَہَا إِلاَّ الثَّوْبُ الْوَاحِدُ؟ قَالَ : تَتَّزِرُ بِہِ ۔\n\nقَالَ وَکِیعٌ : یَعْنِی إِذَا کَانَ صَغِیرًا۔",,,6245,,
6246,حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا عِکْرِمَۃُ بْنُ عَمَّارٍ ، عَنْ عَطَائٍ ، عَنْ جَابِرٍ ؛ أَنَّہُ أَمَّہُمْ فِی قَمِیصٍ وَاحِدٍ۔,,,6246,,
6247,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا أَبَانُ بْنُ صَمْعَۃَ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ بَأْسَ بِالصَّلاَۃ فِی الْقَمِیصِ الْوَاحِدِ ، إِذَا کَانَ صَفِیقًا۔",,,6247,,
6248,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ إِسْمَاعِیلَ السَّرَّاجِ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ صَلَّی فِی قَمِیصٍ لَیْسَ عَلَیْہِ شَیْئٌ غَیْرُہُ۔,,,6248,,
6249,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ مُعَاوِیَۃَ بْنِ صَالِحٍ ، عَنْ مُوسَی بْنِ یَزِیدَ ، قَالَ : وَسَمِعْتُ أَبَا أُمَامَۃَ وَسُئِلَ عَنِ الصَّلاَۃ فِی الْقَمِیصِ الْوَاحِدِ ؟ فَقَالَ : لاَ بَأْسَ بِہِ ۔ وَفِی الرَّیْطَۃِ ؟ إِذَا تَوَشَّحْتَ بِہَا فَلاَ بَأْسَ بِہِ۔",,,6249,,
6250,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مَنْصُورٍ ، عَنْ أَبِی الضُّحَی ، قَالَ : سُئِلَ ابْنُ عَبَّاسٍ عَنِ الصَّلاَۃ فِی الْقَمِیصِ الْوَاحِدِ ؟ فَقَالَ : رُبَّ رَجُلٍ لَیْسَ لَہُ إِلاَّ قَمِیصٌ۔",,,6250,,
6251,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ، عَنِ الأَعْمَشِ، عَنْ إِبْرَاہِیمَ، قَالَ: لاَ بَأْسَ بِالصَّلاَۃِ فِی الْقَمِیصِ الْوَاحِدِ إِذَا کَانَ صَفِیقًا۔",,,6251,,
6252,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ سَعْدِ بْنِ إِبْرَاہِیمَ ، عَن أَبِیہِ ، قَالَ : أَمَّنَا مُعَاوِیَۃُ فِی قَمِیصٍ۔",,,6252,,
6253,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ سَعْدِ بْنِ عُبَیْدَۃَ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ؛ أَنَّہُ صَلَّی فِی قَمِیصٍ۔,,,6253,,
6254,"حَدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ، عَنْ سَعِیدِ بْنِ أَبِی ہِنْدٍ، قَالَ: بَعَثْتُ غُلاَمًا لِی کَاتِبًا حَاسِبًا إِلَی سَعِیدِ بْنِ الْمُسَیَّبِ، یَسْأَلُہُ عَنِ الصَّلاَۃ فِی قَمِیصٍ لَیْسَ تَحْتَہُ إِزَارٌ؟ قَالَ: لَیْسَ بِہِ بَأْسٌ إِذَا لَمْ یَشِفَّ عَنْہُ۔",,,6254,,
6255,حَدَّثَنَا أَبُو أُسَامَۃَ، عَنِ الْجُرَیْرِیِّ، عَنْ عِکْرِمَۃَ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا بِالصَّلاَۃِ فِی الْقَمِیصِ الْوَاحِدِ حَصِیفًا۔,,,6255,,
6256,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنِ الْہُذَیْلِ بْنِ بِلاَلٍ الْفَزَارِیِّ ، قَالَ : حدَّثَنِی زِیَادُ بْنُ عُثْمَانَ الأَحْمَریُّ ، قَالَ: رَأَیْتُ عَلْقَمَۃَ یُصَلِّی فِی قَمِیصٍ صَفِیقٍ قَصِیرٍ۔",,,6256,,
6257,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الْعَوَّامُ ، عَنْ عَطَائِ بْنِ أَبِی رَبَاحٍ ، قَالَ : لاَ بَأْسَ بِالصَّلاَۃ فِی ثَوْبٍ وَاحِدٍ إِذَا کَانَ صَفِیقًا۔",,,6257,,
6258,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا أَبُو إِسْرَائِیلَ إِسْمَاعِیلُ ، عَنْ فُضَیْلِ بْنِ عَمْرٍوَ ، قَالَ : لاَ بَأْسَ بِالصَّلاَۃ فِی الْقَمِیصِ الْوَاحِدِ إِذَا کَانَ صَفِیقًا۔",,,6258,,
6259,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، قَالَ : أَمَّنَا الْحَکَمُ فِی قَمِیصٍ غَلِیظٍ ، وَقَالَ الْحَکَمُ : لاَ بَأْسَ بِالصَّلاَۃ فِی الْقَمِیصِ الْوَاحِدِ إِذَا کَانَ صَفِیقًا۔",,,6259,,
6260,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنِ ابْنِ لَہِیعَۃَ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ نَوْفَلٍ ، قَالَ : رَأَیْتُ عُرْوَۃَ بْنَ الزُّبَیْرِ یُصَلِّی فِی قَمِیصٍ ، لَیْسَ عَلَیْہِ غَیْرُہُ۔",,,6260,,
6261,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَبِیبٍ ، عَنْ عَمْرِو بْنِ ہَرِمٍ ، قَالَ : سُئِلَ جَابِرُ بْنُ زَیْدٍ عَنِ الرَّجُلِ یُصَلِّی فِی جُبَّۃٍ وَحْدَہَا ، أَوْ قَمِیصٍ صَفِیقٍ ، یُوَارِی عَوْرَتَہُ ، لَیْسَ عَلَیْہِ غَیْرُہُ ؟ قَالَ : لاَ بَأْسَ بِہِ۔",,,6261,,
6262,"حَدَّثَنَا أَبُوبَکْرِ بْنُ عَیَّاشٍ ، عَنْ أَبِی حَصِینٍ ، قَالَ : حدَّثَتْنِی مُلَیْکَۃُ بِنْتُ أَبِی عَبْدِ الرَّحْمَنِ ؛ أَنَّ أَبَاہَا کَانَ یُصَلِّی فِی قَمِیصٍ تَطَوُّعًا بِاللَّیْلِ۔",,,6262,,
6263,حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنِ الْحَکَمِ ؛ أَنَّ سَعْدًا صَلَّی بِالنَّاسِ فِی مُسْتُقَۃٍ۔,,,6263,,
6264,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا أَبَانُ بْنُ صَمْعَۃَ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ بَأْسَ بِالصَّلاَۃِ فِی الْجُبَّۃِ الْوَاحِدَۃِ۔",,,6264,,
6265,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا زَائِدَۃُ بْنُ قُدَامَۃَ ، عَنْ عَلِیِّ بْنِ زَیْدِ بْنِ جُدْعَانَ ، قَالَ : سَأَلْتُ سَعِیدَ بْنَ الْمُسَیَّبِ عَنِ الصَّلاَۃ فِی الْجُبَّۃِ ؟ قَالَ : وَفِی الْقَمِیصِ إِذَا کَانَ صَفِیقًا۔",,,6265,,
6266,"حَدَّثَنَا وَکِیعٌ ، قَالَ : أَخْبَرَنَا الرَّبِیعُ بْنُ صَبِیحٍ ، قَالَ : أَخْبَرَنِی مَنْ رَأَی عُمَرَ بْنَ عَبْدِ الْعَزِیزِ یُصَلِّی فِی جُبَّۃٍ طَیَالِسَۃٍ ، لَیْسَ عَلَیْہِ إِزَارٌ۔",,,6266,,
6267,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُحِلٍّ ، قَالَ : رَأَیْتُ إِبْرَاہِیمَ یُصَلِّی فِی مُسْتُقَۃٍ ، لاَ یُخْرِجُ یَدَیْہِ مِنْہَا۔",,,6267,,
6268,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ خُصَیْفٍ ، عَنْ مُجَاہِدٍ ، قَالَ : أَیُّمَا امْرَأَۃٍ صَلَّتْ وَلَمْ تُغَطِّ شَعْرَہَا ، لَمْ تُقْبَلْ لَہَا صَلاَۃٌ۔",,,6268,,
6269,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ، رَفَعَہُ ، قَالَ : إِذَا حَاضَتِ الْجَارِیَۃُ ، لَمْ تُقْبَلْ لَہَا صَلاَۃٌ إِلاَّ بِخِمَارٍ۔ (ترمذی 377۔ ابوداؤد 641)",,,6269,,
6270,"حَدَّثَنَا جَرِیرٌ ، عَنْ قَابُوسَ ، عَنْ أَبِیہِ ؛ أَنَّہُ أَرْسَلَ امْرَأَۃً إِلَی عَائِشَۃَ ، فَرَأَتْ جَارِیَۃً لَہَا جَمَّۃٌ ، فَقَالَتْ : لَوِ اسْتَتَرَتْ ہَذِہِ کَانَ أَخْیَرَ ، فَقَالَتْ : إِنَّہَا لَمْ تَحِضْ ، وَلاَ بَدَا بَعْدُ الْحَیْضُ۔",,,6270,,
6271,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنْ مُحَمَّدٍ ؛ أَنَّ عَائِشَۃَ ، قَالَتْ : دَخَلَ عَلَیَّ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَعِنْدِی فَتَاۃٌ ، فَأَلْقَی إِلَیَّ حِقْوَہُ ، فَقَالَ : شُقِّیہِ بَیْنَ ہَذِہِ الْفَتَاۃِ وَبَیْنَ الَّتِی عِنْدَ أُمِّ سَلَمَۃَ ، فَإِنِّی لاَ أُرَاہُمَا إِلاَّ قَدْ حَاضَتَا۔ (ابوداؤد 642۔ احمد 6/238)",,,6271,,
6272,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ عَمْرِو بْنِ سَعِیدٍ ، عَنْ عَائِشَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ دَخَلَ عَلَیْہَا ، فَاخْتَبَأَتْ مَوْلاَۃٌ لَہُمْ ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَاضَتْ ؟ فَقَالُوا : نَعَمْ ، فَشَقَّ لَہَا مِنْ عِمَامَتِہِ ، فَقَالَ : اخْتَمِرِی بِہَذَا۔ (ابن ماجہ 654)",,,6272,,
6273,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شَرِیکٌ ، عَنْ عُثْمَانَ الثَّقَفِیِّ ، عَنْ مَاہَانَ ، عَنْ أُمِّ سَلَمَۃَ ، قَالَتْ : إِذَا حَاضَتِ الْجَارِیَۃُ وَجَبَ عَلَیْہَا مَا وَجَبَ عَلَی أُمِّہَا مِنَ التَّسَتُّرِ۔",,,6273,,
6274,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مَرْزُوقُ بْنُ عَبْدِ اللہِ مَوْلَی بَنِی زُہْرَۃَ ، قَالَ : سَأَلْتُ سَعِیدَ بْنَ الْمُسَیَّبِ : مَتَی تُکْتَبُ عَلَی الْجَارِیَۃِ الصَّلاَۃُ ؟ فَقَالَ : إِذَا حَاضَتْ۔",,,6274,,
6275,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا حَاضَتِ الْجَارِیَۃُ وَجَبَ عَلَیْہَا مَا وَجَبَ عَلَی أُمِّہَا مِنَ التَّسَتُّرِ۔",,,6275,,
6276,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا رَبِیعٌ، عَنِ الْحَسَنِ، قَالَ: إِذَا حَاضَتِ الْجَارِیَۃُ لَمْ تُقْبَلْ لَہَا صَلاَۃٌ إِلاَّ بِخِمَارٍ۔",,,6276,,
6277,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ خُصَیْفٍ ، عَنْ مُجَاہِدٍ ، قَالَ : إِذَا حَاضَتِ الْجَارِیَۃُ لَمْ تُقْبَلْ لَہَا صَلاَۃٌ إِلاَّ بِخِمَارٍ۔",,,6277,,
6278,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنِ الشَّیْبَانِیِّ ، عَنْ مَاہَانَ أَبِی سَالِمٍ ، قَالَ : قالَتْ عَائِشَۃُ : إِذَا احْتَلَمَتِ الْجَارِیَۃُ وَجَبَ عَلَیْہَا مَا وَجَبَ عَلَی أُمِّہَا ۔ یَعْنِی مِنَ التَّسَتُّرِ۔",,,6278,,
6279,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ قَتَادَۃَ ، عَنِ ابْنِ سِیرِینَ ، عَنْ صَفِیَّۃَ ، عَنْ عَائِشَۃَ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لاَ یَقْبَلُ اللَّہُ صَلاَۃَ حَائِضٍ إِلاَّ بِخِمَارٍ۔",,,6279,,
6280,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : إِذَا بَلَغَتِ الْمَرْأَۃُ الْحَیْضَ ، وَلَمْ تُغَطِّ أُذُنَیْہَا وَرَأْسَہَا ، لَمْ تُقْبَلْ لَہَا صَلاَۃٌ۔",,,6280,,
6281,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُجَالِدٍ ، عَنِ الشَّعْبِیِّ ، عَنْ مَسْرُوقٍ ، قَالَ : تُصَلِّی کَمَا تَخْرُجُ۔",,,6281,,
6282,"حَدَّثَنَا شَرِیکٌ ، عَنْ أَبِی إِسْحَاقَ ؛ أَنَّ عَلِیًّا ، وَشُرَیْحًا کَانَا یَقُولاَنِ : تُصَلِّی الأَمَۃُ کَمَا تَخْرُجُ۔",,,6282,,
6283,"حَدَّثَنَا ہُشَیْمٌ، عَنْ مُغِیرَۃَ، عَنْ إِبْرَاہِیمَ، قَالَ: تُصَلِّی أُمُّ الْوَلَدِ بِغَیْرِ خِمَارٍ، وَإِنْ کَانَتْ قَدْ بَلَغَتْ سِتِّینَ سَنَۃً۔",,,6283,,
6284,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لَیْسَ عَلَی الأَمَۃِ خِمَارٌ ، وَإِنْ کَانَتْ عَجُوزًا۔",,,6284,,
6285,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : لَیْسَ عَلَی الأَمَۃِ خِمَارٌ۔",,,6285,,
6286,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُجَالِدٍ ، عَنِ الشَّعْبِیِّ ، عَنْ مَسْرُوقٍ ، قَالَ : تُصَلِّی الأَمَۃُ کَمَا تَخْرُجُ۔",,,6286,,
6287,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنِ الْحَارِثِ ، قَالَ : تُصَلِّی الأَمَۃُ کَمَا تَخْرُجُ۔",,,6287,,
6288,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ مُجَالِدٍ، عَنِ الشَّعْبِیِّ، عَنْ شُرَیْحٍ ، قَالَ : تُصَلِّی الأَمَۃُ کَمَا تَخْرُجُ۔",,,6288,,
6289,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إِسْرَائِیلُ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : لَیْسَ عَلَی الأَمَۃِ خِمَارٌ ، وَإِنْ وَلَدَتْ مِنْ سَیِّدِہَا۔",,,6289,,
6290,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إِسْرَائِیلُ ، عَنْ جَابِرٍ ، عَنْ عَطَائٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنَّ الأَمَۃَ قَدْ أَلْقَتْ فَرْوَۃَ رَأْسِہَا۔",,,6290,,
6291,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسٍ ، قَالَ : رَأَی عُمَرُ أَمَۃً لَنَا مُتَقَنِّعَۃً ، فَضَرَبَہَا ، وَقَالَ : لاَ تَتَشَبَّہِینَ بِالْحَرَائِرِ۔",,,6291,,
6292,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنِ الْحَکَمِ ، عَنْ مُجَاہِدٍ ، قَالَ : قَالَ عُمَرُ : ِإنَّ الأَمَۃَ قَدْ أَلْقَتْ فَرْوَۃَ رَأْسِہَا مِنْ وَرَائِ الْجِدَارِ۔",,,6292,,
6293,حَدَّثَنَا ہُشَیْمٌ ، عَنْ حَجَّاجٍ ، عَنْ عِکْرِمَۃَ بْنِ خَالِدٍ الْمَخْزُومِیِّ ، عَنْ عُمَرَ بْنِ الْخَطَّابِ ، بِمِثْلِ حَدِیثِ وَکِیعٍ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ۔,,,6293,,
6294,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ أَنَسٍ ، قَالَ : رَأَی عُمَرُ جَارِیَۃً مُتَقَنِّعَۃً فَضَرَبَہَا ، وَقَالَ : لاَ تَشَبَّہِینَ بِالْحَرَائِرِ۔",,,6294,,
6295,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الْمُخْتَارِ بْنِ فُلْفُلٍ ، عَنْ أَنَسِ بْنِ مَالِکٍ ، قَالَ : دَخَلَتْ عَلَی عُمَرَ بْنِ الْخَطَّابِ أَمَۃٌ ، قَدْ کَانَ یُعَرِّفُہَا لِبَعْضِ الْمُہَاجِرِینَ ، أَوِ الأَنْصَارِ وَعَلَیْہَا جِلْبَابٌ ، مُتَقَنِّعَۃً بِہِ ، فَسَأَلَہَا : عَتَقْتِ ؟ قَالَتْ : لاَ ، قَالَ : فَمَا بَالُ الْجِلْبَابِ ؟ ضَعِیہِ عَنْ رَأْسِکَ ، إِنَّمَا الْجِلْبَابُ عَلَی الْحَرَائِرِ مِنْ نِسَائِ الْمُؤْمِنِینَ ، فَتَلَکَّأَتْ فَقَامَ إِلَیْہَا بِالدِّرَّۃِ ، فَضَرَبَ بِہَا رَأْسَہَا حَتَّی أَلْقَتْہُ عَنْ رَأْسِہَا۔",,,6295,,
6296,"حَدَّثَنَا حَفْصٌ ، عَنْ مُجَالِدٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : سَأَلَہُ أَبُو ہُبَیْرَۃَ : کَیْفَ تُصَلِّی الأَمَۃُ ؟ قَالَ : تُصَلِّی کَمَا تَخْرُجُ۔",,,6296,,
6297,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ خَالِدٍ ، عَنْ أَبِی قِلاَبَۃَ ، قَالَ : کَانَ عُمَرُ بْنُ الْخَطَّابِ لاَ یَدَعُ فِی خِلاَفَتِہِ أَمَۃً تَقَنَّعُ ۔ قَالَ : وَقَالَ عُمَرُ : إِنَّمَا الْقِنَاعُ لِلْحَرَائِرِ ، لَکَیْ لاَ یُؤْذَیْنَ۔",,,6297,,
6298,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ: حدَّثَنَا عَوْفٌ ، قَالَ: قَدِمَ عَامِلٌ لِمُعَاوِیَۃَ ، وَکَانَ بَعَثَہُ عَلَی الصَّدَقَاتِ ، فَنَزَلَ مَنْزِلاً، فَإِذَا ہُوَ بِمَسْجِدَیْنِ ، قَالَ : أَیُّہُمَا أَقْدَمُ ؟ فَأُخْبِرَ بِہِ ، فَأَتَی الَّذِی ہُوَ أَقْدَمُہُمَا۔",,,6298,,
6299,حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ لَیْثٍ ؛ أَنَّ أَبَا وَائِلٍ فَاتَتْہُ الصَّلاَۃ فِی مَسْجِدِ کَذَا وَکَذَا ، فَصَلَّی فِی مَسْجِدِ کَذَا وَکَذَا ، وَبَیْنَہُمَا مَسَاجِدُ کَثِیرَۃٌ مُحْدَثَۃٌ ، لَمْ یُصَلِّ فِیہَا۔,,,6299,,
6300,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ عُمَارَۃَ الصَّیْدَلاَنِیِّ ، عَنْ ثَابِتٍ الْبُنَانِیِّ ، قَالَ : کُنْتُ أَکُونُ مَعَ أَنَسٍ ، فَیَأْتِی عَلَی الْمَسْجِدِ فَیَسْمَعُ الأَذَانَ ، فَیَقُولُ : مُحْدَثٌ ہَذَا ؟ فَإِذَا قَالُوا : نَعَمْ ، تَجَاوَزَہُ إِلَی غَیْرِہِ۔",,,6300,,
6301,حَدَّثَنَا مُعْتَمِرٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ؛ أَنَّہُ کَانَ یَتَجَاوَزُ الْمَسَاجِدَ الْمُحْدَثَۃَ إِلَی الْقَدِیمَۃِ۔,,,6301,,
6302,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ عَوْفٍ ، قَالَ : أَخْبَرَنِی رَجُلٌ مِنْ أَہْلِ الْبَادِیَۃِ ، قَالَ : قَدِمَ عَلَیْنَا مُصَدِّقٌ مِنَ الْمَدِینَۃِ ، لَیَالِی مُعَاوِیَۃَ ، فَبَیْنَمَا ہُوَ عَلَی مَائٍ لَنَا ذَاتَ یَوْمٍ ، قَالَ : وَحَضَرَتِ الصَّلاَۃُ ، وَعَلَی الْمَائِ مَسْجِدَانِ مِنْ مَسَاجِدِ أَہْلِ الْبَادِیَۃِ ، قَالَ : أَیُّہُمَا بُنِیَ أَوَّلاً ؟ فَقِیلَ : ہَذَا ، فَقَصَدَ نَحْوَہُ۔",,,6302,,
6303,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ: أَخْبَرَنَا مَنْصُورٌ ، عَنِ الْحَسَنِ؛ أَنَّہُ سُئِلَ عَنِ الرَّجُلِ یَدَعُ مَسْجِدَ قَوْمِہِ وَیَأْتِی غَیْرَہُ؟ قَالَ: فَقَالَ الْحَسَنُ : کَانُوا یُحِبُّونَ أَنْ یُکَثِّرَ الرَّجُلُ قَوْمَہُ بِنَفْسِہِ۔",,,6303,,
6304,"حَدَّثَنَا جَرِیرٌ ، عَنْ قَابُوسَ ، عَنْ أَبِیہِ ؛ أَنْ عُمَر دَخَلَ الْمَسْجِد فَرَکَعَ فِیہِ رَکْعَۃً ، فَقَالُوا لَہُ ؟ فَقَالَ : إِنَّمَا ہُوَ تَطَوُّعٌ ، فَمَنْ شَائَ زَاد ، وَمَن شَائَ نَقَصَ۔",,,6304,,
6305,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ قَابُوسَ بْنِ أَبِی ظَبْیَانَ ، عَنْ أَبِیہِ ؛ أَنْ عُمَرَ بْنَ الْخَطَّابِ مَرَّ فِی الْمَسْجِدِ فَرَکَعَ رَکْعَۃً ، فَقِیلَ لَہُ : إِنَّمَا رَکَعْتَ رَکْعَۃً ؟ فَقَالَ : إِنَّمَا ہُوَ تَطَوُّعٌ ، وَکَرِہْتُ أَنْ أَتَّخِذَہُ طَرِیقًا۔",,,6305,,
6306,"حَدَّثَنَا شَرِیکٌ ، عَنْ سِمَاکٍ ، قَالَ : حدَّثَنِی مَنْ رَأَی طَلْحَۃَ بْنَ عُبَیْدِ اللہِ مَرَّ فِی الْمَسْجِدِ فَرَکَعَ رَکْعَۃً ، ثُمَّ خَرَجَ۔",,,6306,,
6307,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا شَرِیکٌ ، عَنْ سِمَاکٍ ، قَالَ : أَخْبَرَنَا مَنْ رَأَی طَلْحَۃَ بْنَ عُبَیْدِ اللہِ مَرَّ فِی الْمَسْجِدِ ، فَسَجَدَ سَجْدَۃً۔",,,6307,,
6308,"حَدَّثَنَا وَکِیعٌ ، عَنْ سَیْفِ بْنِ مَیْسَرَۃَ ، عَنْ أَبِی سَعِیدٍ ، قَالَ : رَأَیْتُ الزُّبَیْرَ بْنَ الْعَوَّامِ خَرَجَ مِنْ الْقَصْرِ ، فَمَرَّ بِالْمَسْجِدِ فَرَکَعَ رَکْعَۃً ، أَوْ سَجَدَ سَجْدَۃً۔",,,6308,,
6309,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ الأَحْوَص بْنِ حَکِیمٍ ، عَنْ رَاشِدِ بْنِ سَعْدٍ ، قَالَ : کَانَ أَصْحَابُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلُّونَ وَعَلَیْہِمْ قِسِیُّہُمْ۔",,,6309,,
6310,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ الأَحْوَص بْنِ حَکِیمٍ ، قَالَ : حدَّثَنِی رَاشِدُ بْنُ سَعْدٍ ، عَنْ عُرْوَۃَ بْنِ الزُّبَیْرِ ، قَالَ : کَانَ یُقَالُ : السُّیُوفُ أَرْدِیَۃُ الْغُزَاۃِ۔",,,6310,,
6311,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانُوا یَرَوْنَ أَنَّ السُّیُوفَ بِمَنْزِلَۃِ الرِّدَائِ فِی الصَّلاَۃ۔",,,6311,,
6312,"حَدَّثَنَا ہُشَیمٌ ، عَنْ مُغِیرَۃ ، عَنْ إِبْرَاہِیمَ ، قَالَ : السَیف بِمَنْزِلَۃِ الرِّدَائِ فِی الصَّلاَۃ۔",,,6312,,
6313,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللہِ الأَسَدِیُّ ، عَنْ إِسْرَائِیلَ ، عَنْ سَعِیدِ بْنِ مَسْرُوقٍ ، قَالَ : رَأَیْتُ إِبْرَاہِیمَ التَّیْمِیَّ یُصَلِّی وَلَیْسَ عَلَیْہِ رِدَائٌ إِلاَّ سَیْفُہُ۔",,,6313,,
6314,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عُبَیْدَۃُ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانَ أَصْحَابُ مُحَمَّدٍ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلُّونَ فِی السُّیُوفِ ، عَلَیْہَا الْکِیْمُخْتُ مِنْ جُلُودِ الْمَیْتَۃِ۔",,,6314,,
6315,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الرَّبِیعُ ، عَنِ الْحَسَنِ ، قَالَ : السُّیُوفُ أَرِدْیَۃُ الْغُزَاۃِ۔",,,6315,,
6316,"حَدَّثَنَا جَرِیرٌ ، عَنْ مِسْعَرٍ ، عَنْ حَمَّادٍ ، قَالَ : الْقَوْسُ لاَ یُجْزِئُ مَکَانَ الرِّدَائِ۔",,,6316,,
6317,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا عُبَیْدَۃُ ، عَنْ إِبْرَاہِیمَ ، قَالَ : الْقَوْسُ بِمَنْزِلَۃِ الرِّدَائِ۔",,,6317,,
6318,"حَدَّثَنَا عُقْبَۃُ بْنُ خَالِدٍ ، عَنْ مُوسَی بْنِ مُحَمَّدِ بْنِ إِبْرَاہِیمَ ، قَالَ : أَخْبَرَنِی أَبِی ، عَنْ سَلَمَۃَ بْنِ الأَکْوَعِ ؛ أَنَّہُ سَأَلَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الصَّلاَۃ فِی الْقَوْسِ وَالْقَرْنِ ؟ فَقَالَ : صَلِّ فِی الْقَوْسِ ، وَاطْرَحِ الْقَرْنَ۔ (ابویعلی 379 )",,,6318,,
6319,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : کَانَ إِذَا کَانَ لَیْلَۃٌ مَطِیرَۃٌ ، أَوْ شَدِیدَۃُ الرِّیحِ ، أَمَرَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مُنَادِیًا فَنَادَی : أَنْ صَلُّوا فِی رِحَالِکُمْ۔ (بخاری 666۔ مسلم 484)",,,6319,,
6320,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ خَالِدٍ ، عَنْ أَبِی الْمَلِیحِ ، عَنْ أَبِیہِ ، قَالَ : کُنْتُ مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَامَ الْحُدَیْبِیَۃِ ، أَوْ حُنَیْنٍ فَأَصَابَنَا مَطَرٌ لَمْ یَبُلَّ أَسَافِلَ نِعَالِنَا ، فَنَادَی مُنَادِی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَنْ صَلُّوا فِی رِحَالِکُمْ۔ (ابوداؤد 1050۔ احمد 5/75)",,,6320,,
6321,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا عَوْفٌ ، عَنْ أَبِی رَجَائٍ ، قَالَ : أَصَابَنَا مَطَرٌ فِی یَوْمِ جُمُعَۃٍ فِی عَہْدِ ابْنِ عَبَّاسٍ ، فَأَمَرَ مُنَادِیًا فَنَادَی : أَنْ صَلُّوا فِی رِحَالِکُمْ۔",,,6321,,
6322,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ ، عَنْ أَبِی قِلاَبَۃَ ، عَنْ أَبِی الْمَلِیحِ ، قَالَ : خَرَجْتُ ذَاتَ لَیْلَۃٍ مَطِیرَۃٍ إِلَی الْمَسْجِدِ ، فَلَمَّا رَجَعْتُ اسْتَفْتَحْتُ ، قَالَ أَبِی : مَنْ ہَذَا ؟ قَالُوا : أَبُو الْمَلِیحِ ، قَالَ : لَقَدْ رَأَیْتُنَا مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَوْمَ الْحُدَیْبِیَۃِ ، وَأَصَابَتْنَا سَمَائٌ لَمْ تَبُلَّ أَسَافِلَ نِعَالِنَا ، فَنَادَی مُنَادِی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَنْ صَلُّوا فِی رِحَالِکُمْ۔",,,6322,,
6323,"حَدَّثَنَا عَفَّانُ ، قَالَ: حدَّثَنَا ہَمَّامٌ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، عَنْ سَمُرَۃَ ؛ أَنَّ یَوْمَ حَنِینٍ کَانَ یَوْمًا مَطِیرًا، فَأَمَرَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مُنَادِیَہُ : إِنَّ الصَّلاَۃَ فِی الرِّحَالِ۔ (بخاری 615۔ احمد 5/74)",,,6323,,
6324,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حدَّثَنَا عُبَیْدُ اللہِ ، عَنْ نَافِعٍ ، قَالَ : کَانَ أُمَرَاؤُنَا إِذَا کَانَتْ لَیْلَۃٌ مَطِیرَۃٌ أَبْطَؤُوا بِالْمَغْرِبِ ، وَعَجَّلُوا الْعِشَائَ قَبْلَ أَنْ یَغِیبَ الشَّفَقُ ، فَکَانَ ابْنُ عُمَرَ یُصَلِّی مَعَہُمْ لاَ یَرَی بِذَلِکَ بَأْسًا ۔ قَالَ عُبَیْدُ اللہِ : وَرَأَیْتُ الْقَاسِمَ وَسَالِمًا یُصَلِّیَانِ مَعَہُمْ فِی مِثْلِ تِلْکَ اللَّیْلَۃِ۔",,,6324,,
6325,"حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِیلَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ حَرْمَلَۃَ ، قَالَ : رَأَیْتُ سَعِیدَ بْنَ الْمُسَیَّبِ یُصَلِّی مَعَ الأَئِمَّۃِ حِینَ یَجْمَعُونَ بَیْنَ الْمَغْرِبِ وَالْعِشَائِ فِی اللَّیْلَۃِ الْمَطِیرَۃِ۔",,,6325,,
6326,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُلَیْمَانَ بْنِ بِلاَلٍ ، عَنْ ہِشَامِ بْنِ عَرُوَۃَ ، قَالَ : رَأَیْتُ أَبَانَ بْنَ عُثْمَانَ یَجْمَعُ بَیْنَ الصَّلاَتَیْنِ فِی اللَّیْلَۃِ الْمَطِیرَۃِ ؛ الْمَغْرِبِ وَالْعِشَائِ ، فَیُصَلِّیہِمَا مَعہ عُرْوَۃُ بْنُ الزُّبَیْرِ وَسَعِیدُ بْنُ الْمُسَیَّبِ ، وَأَبُو بَکْرِ بْنُ عَبْدِ الرَّحْمَنِ ، وَأَبُو سَلَمَۃَ بْنُ عَبْدِ الرَّحْمَنِ ، لاَ یُنْکِرُونَہُ۔",,,6326,,
6327,"حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنْ أَبِی مَوْدُودٍ عَبْدِ الْعَزِیزِ بْنِ أَبِی سُلَیْمَانَ ، قَالَ : صَلَّیْتُ مَعَ أَبِی بَکْرِ بْنِ مُحَمَّدٍ الْمَغْرِبَ وَالْعِشَائَ ، فَجَمَعَ بَیْنَہُمَا فِی لَیْلَۃٍ مَطِیرَۃٍ۔",,,6327,,
6328,"حَدَّثَنَا مُحَمَّدُ بْنُ عُبَیْدٍ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ نَافِعٍ ، قَالَ : کَانَ ابْنُ عُمَرَ یُصَلِّی مَعَ مَرْوَانَ ، وَکَانَ مَرْوَانُ إِذَا کَانَتْ لَیْلَۃٌ مَطِیرَۃٌ جَمَعَ بَیْنَ الْمَغْرِبِ وَالْعِشَائِ ، وَکَانَ ابْنُ عُمَرَ یُصَلِّیہِمَا مَعَہُ۔",,,6328,,
6329,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، قَالَ : أَخْبَرَنِی مَالِکُ بْنُ أَنَسٍ ، عَنْ دَاوُدَ بْنِ حُصَیْنٍ ، قَالَ : أَخْبَرَنِی مُخْبِرٌ ، عَنِ ابْنِ عَبَّاسٍ ؛ فِی قَوْلِہِ تَبَارَکَ وَتَعَالَی : {لِدُلُوکِ الشَّمْسِ} قَالَ : إِذَا فَائَ الْفَیئُ۔ {وَاللَّیْلِ وَمَا وَسَقَ} قَالَ : وَمَا جَمَعَ۔",,,6329,,
6330,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : {دُلُوکُ الشَّمْسِ} مَیْلُہَا بَعْدَ نِصْفِ النَّہَارِ۔",,,6330,,
6331,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عَبَّاسٍ : {أَقِمِ الصَّلاَۃ لِدُلُوکِ الشَّمْسِ إِلَی غَسَقِ اللَّیْلِ} قَالَ : دُلُوکُہَا غُرُوبُہَا۔",,,6331,,
6332,"حَدَّثَنَا یَحْیَی بْنُ أَبِی بُکَیْرٍ ، قَالَ : حدَّثَنَا إِبْرَاہِیمُ بْنُ نَافِعٍ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ : {أَقِمِ الصَّلاَۃ لِدُلُوکِ الشَّمْسِ} قَالَ : دُلُوکُہَا قَبْلَ أَنْ تَغِیبَ۔",,,6332,,
6333,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، قَالَ : حدَّثَنَا إِسْمَاعِیلُ بْنُ عَبْدِ الْمَلِکِ ، قَالَ : حَدَّثَنِی یُونُسُ بْنُ خَبَّابٍ ، عَنْ مُجَاہِدٍ ، قَالَ : کُنْتُ أَقُودُ مَوْلاَیَ السَّائِبَ ، وَہُوَ أَعْمَی ، فَیَقُولُ لِی : یَا مُجَاہِدُ ، أَدَلَکَتِ الشَّمْسُ ؟ فَإِذَا قُلْتُ نَعَمْ ، قَامَ فَصَلَّی الظُّہْرَ۔",,,6333,,
6334,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، عَنْ أَبِیہِ ، قَالَ : کُنْتُ جَالِسًا مَعَ عَبْدِ اللہِ فِی بَیْتِہِ ، فَوَجَبَتِ الشَّمْسُ ، فَقَالَ عَبْدُ اللہِ : {أَقِمِ الصَّلاَۃ لِدُلُوکِ الشَّمْسِ إِلَی غَسَقِ اللَّیْلِ} ثُمَّ قَالَ : ہَذَا وَاللَّہِ الَّذِی لاَ إِلَہَ غَیْرُہُ حِینَ أَفْطَرَ الصَّائِمُ ، وَبَلَغَ وَقْتُ ہَذِہِ الصَّلاَۃ۔",,,6334,,
6335,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَبْدِ الْحَمِیدِ بْنِ جَعْفَرٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : دُلُوکُہَا مَیْلُہَا۔",,,6335,,
6336,"حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ ، عَنْ یَعْقُوبَ الْقُمِّیِّ ، عَنْ جَعْفَرِ بْنِ أَبِی الْمُغِیرَۃِ ، قَالَ : دُلُوکُہَا زَوَالُہَا۔",,,6336,,
6337,"حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ ، عَنْ أَبِی کُدَیْنَۃَ ، عَنْ مُغِیرَۃَ ، عَنِ الشَّعْبِیِّ ، قَالَ : دُلُوکُہَا زَوَالُہَا۔",,,6337,,
6338,"حَدَّثَنَا شَبَابَۃُ ، عَنْ وَرْقَائَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، قَالَ : دُلُوکُ الشَّمْسِ حَتَّی تَزِیغَ ، وَغَسَقُ اللَّیْلِ غُرُوبُ الشَّمْسِ۔",,,6338,,
6339,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، قَالَ : حَدَّثَنَا أَبو العُمَیْس ، قَالَ : حَدَّثَنِی وَبَرَۃ ، عَنْ سَعِیدِ بن جُبَیرٍ ، عَنْ عَبْدِ اللہِ ، وَابْنِ عَبَّاسٍ ، قَالاَ : دُلُوکُہَا حِینَ تَغْرُبُ۔",,,6339,,
6340,"حدَّثَنَا إِسْحَاقُ بن سُلَیْمَان ، عَنْ أَبِی سِنَانٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَلِیٍّ ، قَالَ : دُلُوکُہَا غُرُوبُہَا۔",,,6340,,
6341,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ أَبِی الْعُمَیْسِ ، عَنِ الْقَاسِمِ ؛ قَالَ : ذَہَبَ بَصَرُ عُبَیْدِ اللہِ بْنِ عُتْبَۃَ فَأَتَی الطَّبِیبُ ، فَقَالَ : أُدَاوِیَکَ عَلَی أَنْ تَسْتَلْقِیَ سَبْعَۃَ أَیَّامٍ ، وَلاَ تُصَلِّی إِلاَّ مُضْطَجِعًا ، فَأَبَی وَکَرِہَہُ۔",,,6341,,
6342,"حَدَّثَنَا ابن مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ عَاصِمٍ ، عَنْ أَبِی وَائِلٍ ؛ أَنَّہُ وَقَع فِی عَیْنَیْہِ الْمَائُ، فَقِیلَ لَہُ: تَسْتَلْقِی سَبْعًا ، فَکَرِہَ ذَلِکَ۔",,,6342,,
6343,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنِ الْمُسَیَّبِ بْنِ رَافِعٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لَمَّا کُفَّ بَصَرُہُ أَتَاہُ رَجُلٌ ، فَقَالَ لَہُ : إِنْ صَبَرْتَ لِی سَبْعًا لاَ تُصَلِّی إِلاَّ مُسْتَلْقِیًا دَاوَیْتُک ، وَرَجَوْتُ أَنْ تَبْرَأَ عَیْنُک ۔ قَالَ: فَأَرْسَلَ ابْنُ عَبَّاسٍ إِلَی عَائِشَۃَ ، وَأَبِی ہُرَیْرَۃَ ، وَغَیْرِہِمَا مِنْ أَصْحَابِ مُحَمَّدٍ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، قَالَ: فَکُلُّہُمْ یَقُولُونَ: أَرَأَیْتَ إِنْ مِتَّ فِی ہَذِہِ السَّبْعِ، کَیْفَ تَصْنَعُ بِالصَّلاَۃ؟ قَالَ: فَتَرَکَ عَیْنَیْہِ، فَلَمْ یُدَاوِہَا۔",,,6343,,
6344,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ أَبِی الضُّحَی ؛ أَنَّ ابْنَ عَبَّاسٍ أُوقِعَ فِی عَیْنَیْہِ الْمَائُ ، فَقِیلَ لَہُ : أَتَسْتَلْقِی سَبْعًا ، وَلاَ تُصَلِّی إِلاَّ مُسْتَلْقِیًا ؟ فَبَعَثَ إِلَی عَائِشَۃَ ، وَأَمِّ سَلَمَۃَ ، فَسَأَلَہُمَا ، فَنَہَتَاہُ۔",,,6344,,
6345,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ إِسْمَاعِیلَ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عَنْ عُمَرَ ، قَالَ : إِذَا کَانَ یَوْمُ الْغَیْمِ ، فَعَجِّلُوا الْعَصْرَ وَأَخِّرُوا الظُّہْرَ۔",,,6345,,
6346,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا حَسَنُ بْنُ صَالِحٍ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ رُفَیْعٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : عَجِّلُوا صَلاَۃَ النَّہَارِ فِی یَوْمِ الْغَیْمِ ، وَأَخِّرُوا الْمَغْرِبَ۔",,,6346,,
6347,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا قَیْسٌ ، عَنْ أَبِی حَصِینٍ ، عَنْ حِزَامِ بْنِ جَابِرٍ ، قَالَ : سَمِعْتُ ابْنَ مَسْعُودٍ ، یَقُولُ : إِذَا کَانَ یَوْمُ الْغَیْمِ فَعَجِّلُوا الظُّہْرَ ، وَأَخِّرُوا الْعَصْرَ ، وَأَخِّرُوا الْمَغْرِبَ۔",,,6347,,
6348,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَوْزَاعِیُّ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ أَبِی قِلاَبَۃَ ، عَنْ أَبِی الْمُہَاجِرِ ، عَنْ بُرَیْدَۃَ الأَسْلَمِیِّ ، قَالَ : کُنَّا مَعَہُ فِی غُزَاۃٍ ، فَقَالَ : سَمِعْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : بَکِّرُوا بِالصَّلاَۃ فِی الْیَوْمِ الْغَیْمِ ، فَإِنَّہُ مَنْ فَاتَتْہُ صَلاَۃُ الْعَصْرِ حَبِطَ عَمَلُہُ۔ (ابن ماجہ 694۔ احمد 361)",,,6348,,
6349,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا ہِشَامٌ الدَّسْتَوَائِیُّ ، عَنْ یَحْیَی ، عَنْ أَبِی قِلاَبَۃَ ، عَنْ أَبِی الْمَلِیحِ ، عَنْ بُرَیْدَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، بِنَحْوٍ مِنْہُ۔ (بخاری 594۔ احمد 5/439)",,,6349,,
6350,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا یُونُسُ بْنُ أَبِی إِسْحَاقَ ، عَنْ بَکْرِ بْنِ مَاعِزٍ ، عَنِ الرَّبِیعِ بْنِ خُثَیْمٍ ، أَنَّہُ قَالَ لِمُؤَذِّنِہِ : إِذَا کَانَ یَوْمُ الْغَیْمِ فَاغْسِقْ بِالْمَغْرِبِ۔",,,6350,,
6351,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : کَانَ یُعْجِبُہُ فِی یَوْمِ الْغَیْمِ أَنْ یُؤَخِّرَ الظُّہْرَ ، وَیُعَجِّلَ الْعَصْرَ۔",,,6351,,
6352,"حَدَّثَنَا ابْنُ یَمَانٍ ، عَنْ سُفْیَانَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی صَالِحٍ ، قَالَ : یُعَجَّلُ الْعَصْرُ یَوْمَ الْغَیْمِ ، وَیُؤَخَّرُ الْمَغْرِبُ۔",,,6352,,
6353,"حَدَّثَنَا ابْنُ یَمَانٍ ، عَنْ سُفْیَانَ ، عَنْ أَبِی حَمْزَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : یُعَجَّلُ الْعَصْرُ وَیُؤَخَّرُ الْمَغْرِبُ۔",,,6353,,
6354,حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ سُفْیَانَ ، عَنْ خَالِدٍ ، عَنِ الْحَسَنِ ، وَابْنِ سِیرِینَ ، بِمِثْلِہِ۔,,,6354,,
6355,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ عَاصِمٍ ، عَنْ أَبِی الْعَالِیَۃِ ؛ (کَانُوا قَلِیلاً مِنَ اللَّیْلِ مَا یَہْجَعُونَ) قَالَ : لاَ یَنَامُونَ عَنِ الْعِشَائِ الآخِرَۃِ۔",,,6355,,
6356,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُبَارَکٍ ، عَنِ الْحَسَنِ ؛ {کَانُوا قَلِیلاً مِنَ اللَّیْلِ مَا یَہْجَعُونَ ، وَبِالأَسْحَارِ ہُمْ یَسْتَغْفِرُونَ} قَالَ : صَلَّوْا ، فَلَمَّا کَانَ السَّحَرُ اسْتَغْفَرُوا۔",,,6356,,
6357,"حَدَّثَنَا حُمَیْدٌ ، عَنْ إِسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنْ رَجُلٍ ، عَنِ الْحَسَنِ ، عَنْ عَبْدِ اللہِ بْنِ رَوَاحَۃَ ؛ {کَانُوا قَلِیلاً مِنَ اللَّیْلِ مَا یَہْجَعُونَ} قَالَ : ہَجَعُوا قَلِیلاً ، ثُمَّ مَدُّوہَا إِلَی السَّحَرِ۔",,,6357,,
6358,"حَدَّثَنَا غُنْدَرٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ {کَانُوا قَلِیلاً مِنَ اللَّیْلِ مَا یَہْجَعُونَ} ، قَالَ : ذَلِکَ إِذْ أُمِرُوا بِقِیَامِ اللَّیْلِ ، فَکَانَ أَبُو ذَرٍّ یَحْتَجِزُ احْتِجَازَہُ ، وَیَأْخُذُ الْعَصَا فَیَعْتَمِدُ عَلَیْہَا ، فَکَانُوا کَذَلِکَ حَتَّی نَزَلَتِ الرُّخْصَۃُ: {فَاقَرَؤُوا مَا تَیَسَّرَ مِنْہُ}۔",,,6358,,
6359,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا بُکَیْر بْنُ أَبِی السُّمَیْطِ ، قَالَ : حَدَّثَنَا قَتَادَۃُ ؛ فِی قَوْلِہِ تَعَالَی : {کَانُوا قَلِیلاً مِنَ اللَّیْلِ مَا یَہْجَعُونَ} قَالَ : کَانَ الْحَسَنُ ، یَقُولُ : قَلِیلاً مِنَ اللَّیْلِ مَا یَنَامُونَ ۔ وَکَانَ مُطَرِّفُ بْنُ عَبْدِ اللہِ ، یَقُولُ : کَانُوا قَلَّ لَیْلَۃٍ إِلاَّ یُصِیبُونَ مِنْہَا ۔ وَکَانَ مُحَمَّدُ بْنُ عَلِیٍّ ، یَقُولُ : لاَ یَنَامُونَ حَتَّی یُصَلُّوا الْعَتَمَۃَ۔",,,6359,,
6360,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ مُطَرِّفِ بْنِ عَبْدِ اللہِ بْنِ الشِّخِّیرِ ، قَالَ : قلَّ لَیْلَۃٍ أَتَتْ عَلَیْہِمْ ہَجَعُوہَا کُلَّہَا۔",,,6360,,
6361,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنِ أَبِی بِسْطَامٍ ، عَنِ الضَّحَّاکِ ، قَالَ : {الْمُتَّقِینَ} ہُمُ الْقَلِیلُ۔",,,6361,,
6362,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ إِسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنْ رَجُلٍ ، عَنِ الْحَسَنِ ؛ {کَانُوا قَلِیلاً مِنَ اللَّیْلِ مَا یَہْجَعُونَ} قَالَ : ہَجَعُوا قَلِیلاً ، ثُمَّ مَدُّوہَا إِلَی السَّحَرِ۔",,,6362,,
6363,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عَوْفٍ ، عَنْ سَعِیدِ بْنِ أَبِی الْحَسَنِ ، قَالَ : قلَّ لَیْلَۃً أَتَتْ عَلَیْہِمْ ہَجَعُوہَا۔",,,6363,,
6364,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : کَانُوا لاَ یَنَامُونَ کُلَّ اللَّیْلِ۔",,,6364,,
6365,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْحَکَمِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ {کَانُوا قَلِیلاً مِنَ اللَّیْلِ مَا یَہْجَعُونَ} قَالَ : قلَّ لَیْلَۃً تَمُرُّ بِہِمْ إِلاَّ صَلَّوْا فِیہَا۔",,,6365,,
6366,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الزُّبَیْرِ بْنِ عَدِیٍّ ، عَنِ الضَّحَّاکِ ، قَالَ : {کَانُوا} مِنَ النَّاسِ قَلِیلٌ۔",,,6366,,
6367,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ؛ {کَانُوا قَلِیلاً مِنَ اللَّیْلِ مَا یَہْجَعُونَ} قَالَ : مَا یَنَامُونَ۔",,,6367,,
6368,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ؛ قَالَ : {کَانُوا قَلِیلاً ما یَنَامُونَ لَیْلَۃً حَتَّی الصَّبَاحِ}۔",,,6368,,
6369,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنِ الْحَکَمِ بْنِ عَطِیَّۃَ ، قَالَ : سَمِعْتُ الْحَسَنَ ، وَسُئِلَ عَنِ الثَّوْبِ یَخْرُجُ مِنَ النَّسَّاجِ ، یُصَلَّی فِیہِ ؟ قَالَ : نَعَمْ ۔ قَالَ : وَسَمِعْتُ ابْنَ سِیرِینَ یَکْرَہُہُ۔",,,6369,,
6370,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا رَبِیعٌ ، عَنِ الْحَسَنِ ، قَالَ : لاَ بَأْسَ بِالصَّلاَۃ فِی رِدَائِ الْیَہُودِیِّ وَالنَّصْرَانِیِّ۔",,,6370,,
6371,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عَلِیُّ بْنُ صَالِحٍ ، عَنْ عَطَائٍ أَبِی مُحَمَّدٍ ، قَالَ : رَأَیْتُ عَلَی عَلِیٍّ قَمِیصًا مِنْ ہَذِہِ الْکَرَابِیسِ ، غَیْرَ غَسِیلٍ۔",,,6371,,
6372,حَدَّثَنَا حَفْصٌ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ؛ أَنَّ جَابِرَ بْنِ عَبْدِ اللہِ صَلَّی فِی ثَوْبٍ نَسِیجٍ۔,,,6372,,
6373,"حَدَّثَنَا أَبُو مَالِکٍ الْجَنْبِیُّ عَمْرُو بْنُ ہَاشِمٍ ، عَنْ عَبْدِ اللہِ ، عَنْ عَطَائٍ ، قَالَ : سَأَلْتُ أَبَا جَعْفَرَ عَنِ الثَّوْبِ یَحُوکُہُ الْیَہُودِیُّ وَالنَّصْرَانِیُّ ، یُصَلَّی فِیہِ ؟ قَالَ : لاَ بَأْسَ بِہِ۔",,,6373,,
6374,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنِ الْمُسَیَّبِ بْنِ رَافِعٍ ، عَنْ تَمِیمِ بْنِ طَرَفَۃَ ، عَنْ جَابِرِ بْنِ سَمُرَۃَ ، قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَیَنْتَہِیَنَّ أَقْوَامٌ یَرْفَعُونَ أَبْصَارَہُمْ إِلَی السَّمَائِ فِی الصَّلاَۃ ، أَوْ لاَ تَرْجِعُ إِلَیْہِمْ۔ (مسلم 117۔ احمد 5/108)",,,6374,,
6375,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا سَعِیدٌ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أَنَّہُ قَالَ : مَا بَالُ أَقْوَامٍ یَرْفَعُونَ أَبْصَارَہُمْ إِلَی السَّمَائِ فِی صَلاَتِہِمْ ، فَاشْتَدَّ فِی ذَلِکَ حَتَّی قَالَ : لَیَنْتَہُنَّ عَنْ ذَلِکَ ، أَوْ لَتُخْطَفَنَّ أَبْصَارُہُمْ۔ (بخاری 750۔ ابوداؤد 910)",,,6375,,
6376,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَمَّارٍ الْعَبْسِیِّ ، قَالَ : سَمِعْتُ ابْنَ یَسَارٍ ، یَقُولُ : قَالَ حُذَیْفَۃُ : أَمَا یَخْشَی أَحَدُکُمْ إِذَا رَفَعَ بَصَرَہُ إِلَی السَّمَائِ أَنْ لاَ یَرْجِعَ إِلَیْہِ بَصَرُہُ ۔ یَعْنِی وَہُوَ فِی الصَّلاَۃ۔",,,6376,,
6377,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، وَسُفْیَانَ ، عَنْ زِیَادِ بْنِ فَیَّاضٍ ، عَنْ تَمِیمِ بْنِ سَلَمَۃَ ، قَالَ : قَالَ عَبْدُ اللہِ : لَیَنْتَہِیَنَّ أَقْوَامٌ یَرْفَعُونَ أَبْصَارَہُمْ إِلَی السَّمَائِ فِی الصَّلاَۃ ، أَوْ لاَ تَرْجِعُ إِلَیْہِمْ۔",,,6377,,
6378,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ حُصَیْنٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَبْدِ اللہِ ؛ أَنَّہُ رَأَی رَجُلاً رَافِعًا بَصَرَہُ إِلَی السَّمَائِ ، فَقَالَ عَبْدُ اللہِ : مَا یَدْرِی ہَذَا ؟ لَعَلَّ بَصَرَہُ سَیَلْتَمِعُ قَبْلَ أَنْ یَرْجِعَ إِلَیْہِ۔",,,6378,,
6379,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الشَّیْبَانِیِّ ، عَنْ أَبِی بَکْرِ بْنِ عَمْرِو بْنِ عُتْبَۃَ ، عَنْ شُرَیْحٍ ؛ أَنَّہُ رَأَی رَجُلاً قَدْ رَفَعَ یَدَہُ وَبَصَرَہُ إِلَی السَّمَائِ ، فَقَالَ : اُکْفُفْ یَدَک ، وَاخْفِضْ مِنْ بَصَرِکَ ، فَإِنَّک لَنْ تَرَاہُ ، وَلَنْ تَنَالَہُ۔",,,6379,,
6380,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِمَّا یَنْظُرُ إِلَی الشَّیْئِ فِی الصَّلاَۃ ، فَیَرْفَعُ بَصَرَہُ حَتَّی نَزَلَتْ آیَۃٌ ، إِنْ لَمْ تَکُنْ ہَذِہِ فَلاَ أَدْرِی مَا ہِیَ : {الَّذِینَ ہُمْ فِی صَلاَتِہِمْ خَاشِعُونَ} ، قَالَ : فَوَضَعَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَأْسَہُ۔ (ابوداؤد 45۔ عبدالرزاق 3262)",,,6380,,
6381,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، عَنْ عُبَیْدِ بْنِ عُمَیْرٍ ، عَنْ عَائِشَۃَ ، قَالَتْ : مَا رَأَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُسْرِعُ إِلَی شَیْئٍ مِنَ النَّوَافِلِ ، مِثْلَ إِسْرَاعِہِ إِلَی رَکْعَتَیِ الْفَجْرِ ، وَلاَ إِلَی غَنِیمَۃٍ۔ (بخاری 1169۔ ابوداؤد 1248)",,,6381,,
6382,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ مُحَمَّدِ بْنِ زَیْدٍ ، عَنْ عَبْدِ رَبِّہِ ، قَالَ : سَمِعْتُ أَبَا ہُرَیْرَۃَ یَقُولُ : لاَ تَدَعْ رَکْعَتَیِ الْفَجْرِ ، وَلَوْ طَرَقَتْک الْخَیْلُ۔",,,6382,,
6383,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یَعْلَی بْنِ عَطَائٍ ، عَنِ الْوَلِیدِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ قَالَ : یَا حُمْرَانُ ، لاَ تَدَعْ رَکْعَتَیْنِ قَبْلَ الْفَجْرِ ، فَإِنَّ فِیہِمَا الرَّغَائِبُ۔",,,6383,,
6384,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی بِشْرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : قَالَ عُمَرُ فِی الرَّکْعَتَیْنِ قَبْلَ الْفَجْرِ : لَہُمَا أَحَبُّ إِلَیَّ مِنْ حُمْرِ النَّعَمِ۔",,,6384,,
6385,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حُصَیْنٌ ، قَالَ : سَمِعْتُ عَمْرَو بْنَ مَیْمُونٍ ، یَقُولُ : کَانُوا لاَ یَتْرُکُونَ أَرْبَعًا قَبْلَ الظُّہْرِ ، وَرَکْعَتَیْنِ قَبْلَ الْفَجْرِ عَلَی حَالٍ۔",,,6385,,
6386,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، قَالَ : بَلَغَنِی أَنَّ عَائِشَۃَ کَانَتْ تَقُولُ : حَافِظُوا عَلَی رَکْعَتَیِ الْفَجْرِ ، فَإِنَّ فِیہِمَا الْخَیْرُ وَالرَّغَائِبُ۔",,,6386,,
6387,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا صَلاَّہُمَا ، أَوْ أَحَدَہُمَا ثُمَّ مَاتَ ، أَجْزَأَہُ مِنْ رَکْعَتَیِ الْفَجْرِ۔",,,6387,,
6388,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ زِیَادِ بْنِ فَیَّاضٍ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ، قَالَ : إِذَا صَلَّی رَکْعَتَیِ الْفَجْرِ ثُمَّ مَاتَ ، فَکَأَنَّمَا صَلَّی الْفَجْرَ۔",,,6388,,
6389,"حَدَّثَنَا مُعَاذٌ ، عَنْ أَشْعَثَ ، قَالَ : کَانَ الْحَسَنُ یَرَی الرَّکْعَتَیْنِ قَبْلَ الْفَجْرِ وَاجِبَتَیْنِ۔",,,6389,,
6390,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ شُعْبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ زُرَارَۃَ بْنِ أَوْفَی ، عَنْ سَعدِ بْنِ ہِشَامٍ ، عَنْ عَائِشَۃَ ، قَالَتْ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : رَکْعَتَا الْفَجْرِ خَیْرٌ مِنَ الدُّنْیَا وَمَا فِیْہَا۔ (مسلم 501۔ ترمذی 416)",,,6390,,
6391,حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ مُبَارَکٍ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ أَبِی سَلَمَۃَ ، عَنْ عَائِشَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُصَلِّی الرَّکْعَتَیْنِ عِنْدَ الإِقَامَۃِ ، بَیْنَ الأَذَانِ وَالإِقَامَۃِ۔ (بخاری 619۔ مسلم 501),,,6391,,
6392,"حَدَّثَنَا أَبُو الأَحْوَصِ ، وَشَرِیکٌ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُصَلِّی الرَّکْعَتَیْنِ عِنْدَ الأَذَانِ۔ قَالَ أَحَدُہُمَا: وَیُوتِرُ عِنْدَ الإِقَامَۃِ۔ (ابن ماجہ 1147۔ احمد 1/77)",,,6392,,
6393,"حَدَّثَنَا عَلِیُّ بْنُ الْجَعْدِ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ أَنَسِ بْنِ سِیرِینَ ، عَنِ ابْنِ عُمَرَ ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّی رَکْعَتَیِ الْفَجْرِ ، وَکَأَنَّ الأَذَانُ عِنْدَ أُذُنَیْہِ۔ (بخاری 995۔ ترمذی 461)",,,6393,,
6394,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : سَمِعْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أَکْثَرَ مِنْ عِشْرِینَ مَرَّۃً ، یَقْرَأُ فِی الرَّکْعَتَیْنِ قَبْلَ الْفَجْرِ وَالرَّکْعَتَیْنِ بَعْدَ الْمَغْرِبِ : {قُلْ یَا أَیُّہَا الْکَافِرُونَ} ، وَ{قُلْ ہُوَ اللَّہُ أَحَدٌ}۔ (عبدالرزاق 4790۔ نسائی1064)",,,6394,,
6395,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ، عَنْ عَائِشَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَقْرَأُ فِی رَکْعَتَیِ الْفَجْرِ : {قُلْ یَا أَیُّہَا الْکَافِرُونَ} ، وَ{قُلْ ہُوَ اللَّہُ أَحَدٌ} یُسِرُّ فِیہِمَا الْقِرَائَۃَ۔ (احمد 6/184۔ عبدالرزاق 4788)",,,6395,,
6396,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ عُثْمَانَ بْنِ حَکِیمٍ ، عَنْ سَعِیدِ بْنِ یَسَارٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَقْرَأُ فِی رَکْعَتَیِ الْفَجْرِ ، فِی الأُولَی : {قُولُوا آمَنَّا بِاللَّہِ وَمَا أُنْزِلَ إِلَیْنَا} الآیَۃَ ، وَفِی الثَّانِیَۃِ : {تَعَالَوْا إِلَی کَلِمَۃٍ سَوَائٍ بَیْنَنَا وَبَیْنَکُمْ}۔ (مسلم 100۔ ابوداؤد 1253)",,,6396,,
6397,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، وَغُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ إِبْرَاہِیمَ بْنِ مُہَاجِرٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانَ ابْنُ مَسْعُودٍ یَقْرَأُ فِی الرَّکْعَتَیْنِ قَبْلَ صَلاَۃِ الصُّبْحِ ۔ أَوَ قَالَ : قَبْلَ الْغَدَاۃِ بـ : {قُلْ یَا أَیُّہَا الْکَافِرُونَ} ، وَ{قُلْ ہُوَ اللَّہُ أَحَدٌ} ۔ زَادَ غُنْدَرٌ : وَفِی الرَّکْعَتَیْنِ بَعْدَ الْمَغْرِبِ۔",,,6397,,
6398,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ الْجُرَیْرِیِّ ، عَنْ أَبِی السَّلِیلِ ، عَنْ غُنَیْمِ بْنِ قَیْسٍ ، قَالَ : کُنَّا نُؤْمَرُ أَنْ نُنَابِذَ الشَّیْطَانَ فِی الرَّکْعَتَیْنِ قَبْلَ الصُّبْحِ ، أَوْ قَبْلَ الْغَدَاۃِ بِـ : {قُلْ یَا أَیُّہَا الْکَافِرُونَ} ، وَ{قُلْ ہُوَ اللَّہُ أَحَدٌ}۔",,,6398,,
6399,"حَدَّثَنَا عَبَّادٌ ، عَنْ حُصَیْنٍ ، عَنِ الْقَاسِمِ بْنِ أَبِی أَیُّوبَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ أنَّہُ کَانَ یَقْرَأُ فِی الرَّکْعَتَیْنِ قَبْلَ الْفَجْرِ وَالرَّکْعَتَیْنِ بَعْدَ الْمَغْرِبِ : بـ : {قُلْ یَا أَیُّہَا الْکَافِرُونَ} ، وَ{قُلْ ہُوَ اللَّہُ أَحَدٌ}۔",,,6399,,
6400,"حَدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : حدَّثَنِی عَبْدُ اللَّہِ بْنِ مُحَمَّدِ بْنِ سِیرِینَ ؛ عَنِ ابْنِ سِیرِینَ ؛ أَنَّہُ کَانَ یَقْرَأُ فِی الرَّکْعَتَیْنِ قَبْلَ الْفَجْرِ : {قُلْ یَا أَیُّہَا الْکَافِرُونَ} ، وَ{قُلْ ہُوَ اللَّہُ أَحَدٌ}۔",,,6400,,
6401,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : کَانُوا یَقْرَؤُونَ فِیہِمَا بِـ : {قُلْ یَا أَیُّہَا الْکَافِرُونَ} ، وَ{قُلْ ہُوَ اللَّہُ أَحَدٌ}۔",,,6401,,
6402,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانَ أَصْحَابُ عَبْدِ اللہِ یَقْرَؤُونَ فِی الرَّکْعَتَیْنِ قَبْلَ الْفَجْرِ ، وَالرَّکْعَتَیْنِ بَعْدَ الْمَغْرِبِ : {قُلْ لِّلَّذِینَ کَفَرُوا} ، وَ{قُلْ ہُوَ اللَّہُ أَحَدٌ}۔",,,6402,,
6403,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ زُہَیْرٍ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ حَکِیمٍ الْحَضْرَمِیِّ ، عَنْ طَلْحَۃَ ، عَنْ سُویْدِ بْنِ غَفَلَۃَ ؛ أنَّہُ کَانَ یَقْرَأُ فِی الرَّکْعَتَیْنِ بَعْدَ الْمَغْرِبِ بِـ : {قُلْ یَا أَیُّہَا الْکَافِرُونَ} ، وَ{قُلْ ہُوَ اللَّہُ أَحَدٌ}۔",,,6403,,
6404,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ زَمْعَۃَ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یَقْرَأُ فِی الرَّکْعَتَیْنِ قَبْلَ الصُّبْحِ : {إِذَا زُلْزِلَت} وَ{الْعَادِیَاتِ} ، وَفِی الرَّکْعَتَیْنِ بَعْدَ الْعِشَائِ : {آمَنَ الرَّسُولُ۔۔۔} ، وَ{قُلْ ہُوَ اللَّہُ أَحَدٌ}۔",,,6404,,
6405,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ؛ أَنَّہُ کَانَ یَقْرَأُ فِی الرَّکْعَتَیْنِ قَبْلَ الْفَجْرِ وَالرَّکْعَتَیْنِ بَعْدَ الْمَغْرِبِ : {قُلْ یَا أَیُّہَا الْکَافِرُونَ} ، وَ{قُلْ ہُوَ اللَّہُ أَحَدٌ}۔",,,6405,,
6406,"حَدَّثَنَا وَکِیعٌ ، حدَّثَنَا ہِشَامُ بْنُ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، قَالَتْ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُخَفِّفُ رَکْعَتَیِ الْفَجْرِ۔ (بخاری 626۔ مسلم 500)",,,6406,,
6407,حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ إِذَا طَلَعَ الْفَجْرُ صَلَّی رَکْعَتَیْنِ خَفِیفَتَیْنِ۔,,,6407,,
6408,"حَدَّثَنَا إِسْمَاعِیلُ بْنُ إِبْرَاہِیمَ ، عَن خَالِدٍ ، عَنْ مُحَمَّدٍ ، قَالَ : قالَتْ عَائِشَۃُ : کَانَ قِیَامُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی الرَّکْعَتَیْنِ قَبْلَ صَلاَۃِ الصُّبْحِ ، قَدْرَ فَاتِحَۃِ الْکِتَابِ۔ (احمد 217)",,,6408,,
6409,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ أَبِی یَعْفُورٍ ، عَنْ إِبْرَاہِیمَ، عَن صِلَۃَ، قَالَ: أَتَیْتُ حُذَیْفَۃَ فِی دَارِہِ، ثُمَّ أَتَیْنَا الْمَسْجِدَ ، فَصَلَّی رَکْعَتَیْنِ خَفِیفَتَیْنِ ، ثُمَّ أُقِیمَتِ الصَّلاَۃ۔",,,6409,,
6410,حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَمُحَمَّدٍ ؛ أَنَّہُمَا کَانَا لاَ یَزِیدَانِ إِذَا طَلَعَ الْفَجْرُ عَلَی رَکْعَتَیْنِ خَفِیفَتَیْنِ۔,,,6410,,
6411,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی لَبِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : کَانَتَا تُخَفِّفَانِ الرَّکْعَتَانِ قَبْلَ الْفَجْرِ۔",,,6411,,
6412,حَدَّثَنَا وَکِیعٌ ، عَنِ الْعُمَرِیِّ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، عَنْ حَفْصَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُصَلِّی إِذَا طَلَعَ الْفَجْرُ رَکْعَتَیْنِ خَفِیفَتَیْنِ۔ (حمیدی 288),,,6412,,
6413,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : أَخْبَرَتْنِی حَفْصَۃُ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُصَلِّیہِمَا سَجْدَتَیْنِ خَفِیفَتَیْنِ ، إِذَا طَلَعَ الْفَجْرُ۔ (بخاری 1173۔ مسلم 89)",,,6413,,
6414,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ أُمِّہِ عَمْرَۃَ ، عَنْ عَائِشَۃَ، قَالَتْ : إِنْ کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لَیُصَلِّی الرَّکْعَتَیْنِ قَبْلَ الْفَجْرِ ، فَیُخَفِّفُہُمَا حَتَّی إِنْ کُنْتُ لأَقُولُ : أَقَرَأَ فِیہِمَا بِأُمِّ الْکِتَابِ ؟۔(بخاری 1171۔ احمد 6/235)",,,6414,,
6415,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا أَبُو حُمَیْدٍ ، سَمِعَہُ مِنْ جَعْفَرِ بْنِ مُحَمَّدٍ ، عَنْ أَبِیہِ ، قَالَ : مَا رَأَیْتُ أَبِی یُصَلِّیہِمَا قَطُّ ، إِلاَّ وَکَأَنَّہُ یُبَادِرُ حَاجَۃً۔",,,6415,,
6416,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مِسْعَرٌ ، عَنْ شَیْخٍ مِنَ الأَنْصَارِ ، قَالَ مِسْعَرٌ : أُرَاہُ عُثْمَانَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رُبَّمَا أَطَالَ رَکْعَتَیِ الْفَجْرِ۔",,,6416,,
6417,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ لیث أَبِی الْمَشْرَفِیِّ ، عَنِ الْحَسَنِ ، قَالَ : لاَ بَأْسَ أَنْ یُطِیلَ رَکْعَتَیِ الْفَجْرِ ، یَقْرَأُ فِیہِمَا مِنْ حِزْبِہِ إِذَا فَاتَہُ۔",,,6417,,
6418,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ رَجُلٍ ، عَنْ مُجَاہِدٍ ، قَالَ : لاَ بَأْسَ أَنْ یُطِیلَ رَکْعَتَیِ الْفَجْرِ۔",,,6418,,
6419,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : سَأَلْتُ إِبْرَاہِیمَ عَنِ الرَّجُلِ یُوتِرُ مِنْ آخِرِ اللَّیْلِ ، وَقَدْ بَقِیَ عَلَیْہِ مِنَ اللَّیْلِ؟ فَلْیَسْتَفْتِحْ فَلْیَقْرَأْ ، فَإِذَا طَلَعَ الْفَجْرُ رَکَعَ رَکْعَۃً ، ثُمَّ یَضُمُّ إِلَیْہَا أُخْرَی ، فَتَکُونُ رَکْعَتَیِ الْفَجْرِ۔ قَالَ: فَذَکَرْت ذَلِکَ لِمُحَمَّدِ بْنِ سِیرِینَ ، فَقَالَ : مَا أَدْرِی مَا ہَذَا ؟۔",,,6419,,
6420,"حَدَّثَنَا کثیر بْنُ ہِشَامٍ ، عَنْ جَعْفَرَ بْنِ بُرْقَانَ ، قَالَ : قُلْتُ لِمَیْمُونٍ : أَقْرَأُ مِنَ اللَّیْلِ بِسُورَۃٍ طَوِیلَۃٍ ، فَیُدْرِکُنِی الصُّبْحُ حَتَّی أُسْفِرَ جِدًّا ، فَأُضِیفُ إِلَیْہَا أُخْرَی ، فَأَجْعَلُہَا رَکْعَتَیِ الْفَجْرِ ؟ قَالَ : نَعَمْ۔",,,6420,,
6421,"حَدَّثَنَا یَزِیدُ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، عَنْ یَعْلَی بْنِ حَکِیمٍ ، عَنْ مُجَاہِدٍ ، قَالَ : إِنْ شَائَ الرَّجُلُ افْتَتَحَ رَکْعَۃً مِنْ آخِرِ اللَّیْلِ یُطَوِّلُ فِیہَا ، حَتَّی إِذَا أَصْبَحَ رَکَعَ ، ثُمَّ ضَمَّ إِلَیْہَا أُخْرَی ، ثُمَّ اعْتَدَّ بِہِمَا مِنْ رَکْعَتَیِ الْفَجْرِ۔",,,6421,,
6422,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ اللہِ بْنِ سَعِیدٍ ، عَنْ سَالِمٍ أَبِی النَّضْرِ ، عَنْ بُسْرِ بْنِ سَعِیدٍ ، عَنْ زَیْدِ بْنِ ثَابِتٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَفْضَلُ الصَّلاَۃ صَلاَۃُ الْمَرْئِ فِی بَیْتِہِ إِلاَّ الْمَکْتُوبَۃَ۔ (بخار ی6113۔ ابوداؤد 1442)",,,6422,,
6423,"حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِیلَ ، عَنْ عَبْدِ اللہِ بْنِ یَزِیدَ ، قَالَ : رَأَیْتُ السَّائِبَ بْنَ یَزِیدَ یُصَلِّی فِی الْمَسْجِدِ ، ثُمَّ یَخْرُجُ قَبْلَ أَنْ یُصَلِّیَ فِیہِ شَیْئًا ۔ یَعْنِی لاَ یَتَطَوَّعُ۔",,,6423,,
6424,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ إِبْرَاہِیمَ ، قَالَ : سُئِلَ حُذَیْفَۃُ عَنِ التَّطَوُّعِ فِی الْمَسْجِدِ ؟ یَعْنِی بَعْدَ الْفَرِیضَۃِ ، فَقَالَ : إِنِّی لأَکْرَہہُ ، بَیْنَمَا ہُمْ جَمِیعًا فِی الصَّلاَۃ إِذَا اخْتَلَفُوا۔",,,6424,,
6425,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، قَالَ : مَا رَأَیْتُ إِبْرَاہِیمَ مُتَطَوِّعًا فِی مَسْجِدِ قَوْمِہِ۔",,,6425,,
6426,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ نُسَیر بْن ذَعْلُوقٍ ، قَالَ : مَا رَأَیْتُ الرَّبِیعَ بْنَ خُثَیْمٍ مُتَطَوِّعًا فِی مَسْجِدِ الْحَیِّ قَطُّ۔",,,6426,,
6427,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، عَنْ أَبِی مَعْمَرٍ ، قَالَ : إِذَا صُلِّیَتِ الْمَکْتُوبَۃُ فَبَیْتُک۔",,,6427,,
6428,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ النُّعْمَانِ بْنِ قَیْسٍ ، قَالَ : مَا رَأَیْتُ عَبِیدَۃَ مُتَطَوِّعًا فِی مَسْجِدِ الْحَیِّ إِلاَّ مَرَّۃً۔",,,6428,,
6429,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا زُہَیْرٌ ، عَنْ عِمْرَانَ بْنِ مُسْلِمٍ ، قَالَ : کَانَ سُوَیْدُ بْنُ غَفَلَۃَ لاَ یُصَلِّی تَطَوُّعًا بَعْدَ صَلاَۃٍ ، حَتَّی یَنْفَتِلَ حِینَ یُسَلِّمُ إِلَی بَیْتِہِ۔",,,6429,,
6430,"حَدَّثَنَا ابْنُ فُضَیْلٍ، عَنِ النُّعْمَانِ بْنِ قَیْسٍ، عَنْ عَبِیدَۃَ، قَالَ: کَانَ لاَ یُصَلِّی فِی مَسْجِدِہِ شَیْئًا بَعْدَ الْفَرِیضَۃِ۔",,,6430,,
6431,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ أَبِی ذِئْبٍ ، وَالْعُمَرِیُّ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی الرَّکْعَتَیْنِ بَعْدَ الْمَغْرِبِ فِی بَیْتِہِ۔ (بخاری 1180۔ ترمذی 432)",,,6431,,
6432,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ سَعْدِ بْنِ إِبْرَاہِیمَ ، عَن أَبِیہِ ، قَالَ : کَانَ عَبْدُ الرَّحْمَنِ بْنُ عَوْفٍ یُصَلِّی الرَّکْعَتَیْنِ بَعْدَ الْمَغْرِبِ فِی بَیْتِہِ۔",,,6432,,
6433,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ عُمَرَ بْنِ قَتَادَۃَ ، عَنْ مَحْمُودِ بْنِ لَبِیدٍ ، قَالَ: أَتَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَسْجِدَ بَنِی عبد الأَشْہَلِ ، فَصَلَّی بِہِمُ الْمَغْرِبَ ، فَلَمَّا سَلَّمَ ، قَالَ : ارْکَعُوا ہَاتَیْنِ الرَّکْعَتَیْنِ فِی بُیُوتِکُمْ ، قَالَ : فَلَقَدْ رَأَیْتُ مَحْمُودًا ، وَکَانَ إِمَامَ قَوْمِہِ یُصَلِّی بِہِمُ الْمَغْرِبَ ، ثُمَّ یَخْرُجُ فَیَجْلِسُ بِفِنَائِ الْمَسْجِدِ ، حَتَّی یَقُومَ قَبْلَ الْعَتَمَۃِ ، فَیَدْخُلَ بَیْتَہُ فَیُصَلِّیہِمَا۔ (ابن ماجہ 1165۔ احمد 5/427)",,,6433,,
6434,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنِ ابْنِ إِسْحَاقَ ، قَالَ : حدَّثَنَا الْعَبَّاسُ بْنُ سَہْلِ السَّاعِدِیُّ ، قَالَ : لَقَدْ أَدْرَکْتُ زَمَانَ عُثْمَانَ بْنِ عَفَّانَ ، وَإِنَّہُ لَیُسَلِّمُ مِنَ الْمَغْرِبِ ، فَمَا أَرَی رَجُلاً وَاحِدًا یُصَلِّیہِمَا فِی الْمَسْجِدِ ، یَبْتَدِرُونَ أَبْوَابَ الْمَسْجِدِ حَتَّی یَخْرُجُوا ، فَیُصَلُّونَہَا فِی بُیُوتِہِمْ۔",,,6434,,
6435,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرَ ، عَنْ مَیْمُونٍ ، قَالَ : کَانُوا یَسْتَحِبُّونَ ہَاتَیْنِ الرَّکْعَتَیْنِ بَعْدَ الْمَغْرِبِ فِی بُیُوتِہِمْ۔",,,6435,,
6436,"حَدَّثَنَا عُمْرُ بْنُ أَیُّوبَ ، عَنْ جَعْفَرَ بْنِ بُرْقَانَ ، عَنْ مَیْمُونِ بْنِ مِہْرَانَ ، قَالَ : صَلَّی حُذَیْفَۃُ الْمَغْرِبَ فِی جَمَاعَۃٍ ، فَلَمَّا سَلَّمَ الإِمَامُ قَامَ رَجُلٌ إِلَی جَنْبِہِ ، فَأَرَادَ أَنْ یُصَلِّیَ الرَّکْعَتَیْنِ ، فَجَذَبَہُ حُذَیْفَۃُ ، فَقَالَ : اجْلِسْ ، لاَ عَلَیْک أَنْ تُؤَخِّرَ ہَاتَیْنِ الرَّکْعَتَیْنِ ، انْتَظِرْ قَلِیلاً۔",,,6436,,
6437,"حَدَّثَنَا عُمَرُ بْنُ أَیُّوبَ ، عَنْ جَعْفَرَ بْنِ بُرْقَانَ ، عَنْ مَیْمُونٍ ، قَالَ : کَانُوا یُحِبُّونَ تَأْخِیرَ الرَّکْعَتَیْنِ بَعْدَ الْمَغْرِبِ حَتَّی تَشْتَبِکَ النُّجُومُ۔",,,6437,,
6438,"حَدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَانَ رَجَائُ بْنُ حَیْوَۃَ إِذَا صَلَّی الْمَغْرِبَ ) ، لَمْ یُصَلِّ بَعْدَہَا شَیْئًا حَتَّی یَغِیبَ الشَّفَقُ۔",,,6438,,
6439,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ إِسْحَاقَ ، عَنِ الزُّہْرِیِّ ، عَنْ عُرْوَۃَ ، عَنْ عَائِشَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ إِذَا صَلَّی السَّجْدَتَیْنِ قَبْلَ الْفَجْرِ اضْطَجَعَ۔ (بخاری 6310۔ ابوداؤد 1331),,,6439,,
6440,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : حدَّثَنَا مَنْصُورٌ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّ أَبَا مُوسَی الأَشْعَرِیَّ ، وَرَافِعَ بْنِ خَدِیجٍ ، وَأَنْسَ بْنَ مَالِکٍ کَانُوا یَضْطَجِعُونَ بَعْدَ رَکْعَتَیِ الْفَجْرِ۔",,,6440,,
6441,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ ؛ أَنَّ أَبَا مُوسَی ، وَرَافِعَ بْنَ خَدِیجٍ ، وَأَنَسًا کَانُوا یَفْعَلُونَہُ۔,,,6441,,
6442,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ: أَخْبَرَنَا غَیْلاَنُ بْنُ عَبْدِاللہِ، قَالَ: رَأَیْتُ ابْنَ عُمَرَ صَلَّی رَکْعَتَیِ الْفَجْرِ، ثُمَّ اضْطَجَعَ۔",,,6442,,
6443,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ مُجَاہِدٍ ؛ أَنَّ مَرْوَانَ سَأَلَ أَبَا ہُرَیْرَۃَ عَنِ الإِضْطِجَاعِ بَعْدَ رَکْعَتَیِ الْفَجْرِ ؟ فَقَالَ : لاَ ، حَتَّی تَضْطَجِعَ۔",,,6443,,
6444,حَدَّثَنَا حَسَنُ بْنُ عَبْدِ الرَّحْمَنِ الحارِثیُّ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ؛ أَنَّہُ کَانَ إِذَا صَلَّی رَکْعَتَیِ الْفَجْرِ اضْطَجَعَ۔,,,6444,,
6445,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَبْدِ الْکَرِیمِ ؛ أَنَّ عُرْوَۃَ دَخَلَ الْمَسْجِدَ وَالنَّاسُ فِی الصَّلاَۃ ، فَرَکَعَ رَکْعَتَیْنِ ، ثُمَّ أَمَسَّ جَنْبَہُ الأَرْضَ ، ثُمَّ قَامَ فَدَخَلَ مَعَ النَّاسِ فِی الصَّلاَۃ۔,,,6445,,
6446,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : حدَّثَنَا حُصَیْنٌ ، عَنْ مُجَاہِدٍ ، قَالَ : صَحِبْتُ ابْنَ عُمَرَ فِی السَّفَرِ وَالْحَضَرِ ، فَمَا رَأَیْتُہُ اضْطَجَعَ بَعْدَ رَکْعَتَیِ الْفَجْرِ۔",,,6446,,
6447,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، قَالَ : کَانَ إِبْرَاہِیمُ یَکْرَہُ الضِّجْعَۃَ بَعْدَ مَا یُصَلِّی الرَّکْعَتَیْنِ اللَّتَیْنِ قَبْلَ الْفَجْرِ۔",,,6447,,
6448,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مُحَمَّدِ بْنِ الْمُنْکَدَرِ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : رَأَی عُمَرُ رَجُلاً اضْطَجَعَ بَعْدَ الرَّکْعَتَیْنِ ، فَقَالَ : احْصِبُوہُ ، أَوْ أَلاَ حَصَّبْتُمُوہُ ؟۔",,,6448,,
6449,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : قَالَ عَبْدُ اللہِ : مَا بَالُ الرَّجُلِ إِذَا صَلَّی الرَّکْعَتَیْنِ یَتَمَعَّکُ کَمَا تَتَمَعَّکُ الدَّابَّۃُ وَالْحِمَارُ ؟ إِذَا سَلَّمَ فَقَدْ فَصَلَ۔",,,6449,,
6450,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عِمْرَانُ بْنُ حُدَیْرٍ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ : سَأَلْتُ ابْنَ عُمَرَ عَنْ ضِجْعَۃِ الرَّجُلِ عَلَی یَمِینِہِ بَعْدَ الرَّکْعَتَیْنِ قَبْلَ صَلاَۃِ الْفَجْرِ ؟ فَقَالَ : یَتَلَعَّبُ بِکُمُ الشَّیْطَانُ۔",,,6450,,
6451,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنِ الْقَاسِمِ بْنِ أَبِی أَیُّوبَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : لاَ تَضْطَجِعْ بَعْدَ الرَّکْعَتَیْنِ قَبْلَ الْفَجْرِ ، وَاضْطَجِعْ بَعْدَ الْوِتْرِ۔",,,6451,,
6452,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عِیسَی الْخَبَّاطُ ، قَالَ : سَمِعْتُ سَعِیدَ بْنَ الْمُسَیَّبِ ، یَقُولُ : مَا بَالُ أَحَدِکُمْ إِذَا صَلَّی الرَّکْعَتَیْنِ یَتَمَرَّغُ ؟ یَکْفِیہِ التَّسْلِیمُ۔",,,6452,,
6453,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الْحَسَنِ بْنِ عُبَیْد اللہ ، عَنْ إِبْرَاہِیمَ ، قَالَ : ہِیَ ضَجْعَۃُ الشَّیْطَانِ۔",,,6453,,
6454,حَدَّثَنَا إِسْحَاقُ الأَزْرَقُ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ لاَ یُعْجِبُہُ أَنْ یَضْطَجِعَ بَعْدَ رَکْعَتَیِ الْفَجْرِ۔,,,6454,,
6455,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مِسْعَرٌ ، عَنْ زَیْدٍ الْعَمِّیِّ ، عَنْ أَبِی الصِّدِّیقِ النَّاجِی ، قَالَ : رَأَی ابْنُ عُمَرَ قَوْمًا اضْطَجَعُوا بَعْدَ رَکْعَتَیِ الْفَجْرِ ، فَأَرْسَلَ إِلَیْہِمْ فَنَہَاہُمْ ، فَقَالُوا : نُرِیدُ بِذَلِکَ السُّنَّۃَ ، فَقَالَ ابْنُ عُمَرَ : ارْجِعْ إِلَیْہِمْ فَأَخْبِرْہُمْ أَنَّہَا بِدْعَۃٌ۔",,,6455,,
6456,حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِیہِ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَنِ الأَسْوَدِ بْنِ یَزِیدَ ؛ أَنَّہُ کَانَ إِذَا صَلَّی رَکْعَتَیِ الْفَجْرِ احْتَبَی۔,,,6456,,
6457,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حُصَیْنٌ ، وَمُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ عَبْدُ اللہِ : مَا ہَذَا التَّمَرُّغُ بَعْدَ رَکْعَتَیِ الْفَجْرِ کَتَمَرُّغِ الْحِمَارِ۔",,,6457,,
6458,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ أَبِی النَّضْرِ ، عَنْ أَبِی سَلَمَۃَ ، عَنْ عَائِشَۃَ ، قَالَتْ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إِذَا صَلَّی رَکْعَتَیِ الْفَجْرِ ، فَإِنْ کُنْت مُسْتَیْقِظَۃً حَدَّثَنِی ، وَإِلاَّ اضْطَجَعَ۔ (بخاری 1161۔ مسلم 511)",,,6458,,
6459,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الْعُمَرِیُّ ، عَنْ نَافِعٍ ، قَالَ : رُبَّمَا تَکَلَّمَ ابْنُ عُمَرَ بَعْدَ رَکْعَتَیِ الْفَجْرِ۔",,,6459,,
6460,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی حَمْزَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ أَنْ یُسَلِّمَ وَیَتَکَلَّمَ بِالْحَاجَۃِ بَعْدَ رَکْعَتَیِ الْفَجْرِ۔",,,6460,,
6461,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ إِسْمَاعِیلَ ، عَنِ الْحَسَنِ ، وَابْنِ سِیرِینَ ؛ أَنَّہُمَا کَانَا لاَ یَرَیَانِ بَأْسًا بِالْکَلاَمِ بَعْدَ رَکْعَتَیِ الْفَجْرِ۔,,,6461,,
6462,"حَدَّثَنَا مُعتَمِر بْنُ سُلَیْمَانَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : رَأَی ابْنُ مَسْعُودَ رَجُلاً یُکَلِّمُ آخَرَ بَعْدَ رَکْعَتَیِ الْفَجْرِ ، فَقَالَ : إِمَّا أَنْ تَذْکُرَ اللَّہَ وَإِمَّا أَنْ تَسْکُتَ۔",,,6462,,
6463,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ أَبِی عُبَیْدَۃَ ، قَالَ : مَا مِنْ أَحَدٍ أَکْرَہُ إِلَیْہِ الْکَلاَمَ بَعْدَ رَکْعَتَیِ الْفَجْرِ حَتَّی یُصَلِّیَ الْغَدَاۃَ مِنِ ابْنِ مَسْعُودٍ۔",,,6463,,
6464,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الْمَسْعُودِیُّ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ أَبِی عُبَیْدَۃَ ، قَالَ : کَانَ عَبْدُ اللہِ یَعِزُّ عَلَیْہِ أَنْ یُسْمَعَ مُتَکَلِّمٌ بَعْدَ الْفَجْرِ ، یَعْنِی بَعْدَ الرَّکْعَتَیْنِ ، إِلاَّ بِالْقُرْآنِ ، أَوْ بِذِکْرِ اللہِ ، حَتَّی یُصَلِّیَ۔",,,6464,,
6465,حَدَّثَنَا مُعَمَّرُ بْنُ سُلَیْمَانَ الرَّقِّیُّ ، عَنْ خُصَیْفٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ أَنَّہُ کَانَ یَکْرَہُ الْکَلاَمَ بَعْدَ رَکْعَتَیِ الْفَجْرِ ، إِلاَّ أَنْ یُذْکَرَ اللَّہُ۔,,,6465,,
6466,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ خُصَیْفٍ ، قَالَ : سَأَلْتُ سَعِیدَ بْنَ جُبَیْرٍ عَنْ آیَۃٍ بَعْدَ رَکْعَتَیِ الْفَجْرِ ؟ فَلَمْ یُجِبْنِی ، فَلَمَّا صَلَّی ، قَالَ : إِنَّ الْکَلاَمَ یُکْرَہُ بَعْدَہُمَا۔",,,6466,,
6467,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لاَ تَکَلُّمَ بَعْدَ رَکْعَتَیِ الْفَجْرِ وَالْفَجْرِ ، إِلاَّ أَنْ تَکُونَ لَکَ حَاجَۃً۔",,,6467,,
6468,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ: کَانُوا یَکْرَہُونَ الْکَلاَمَ بَعْدَ رَکْعَتَیِ الْفَجْرِ۔ قَالَ : قُلْتُ لإِبْرَاہِیمَ : قَوْلُ الرَّجُلِ لأَہْلِہِ : الصَّلاَۃ ؟ قَالَ : لاَ بَأْسَ۔",,,6468,,
6469,حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ (ح) وعَنْ أَبِی مَعْشَرٍ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّہُمْ کَرِہُوا الْکَلاَمَ بَعْدَ رَکْعَتَیِ الْفَجْرِ۔,,,6469,,
6470,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنْ قَرَظَۃَ ، عَنْ مُجَاہِدٍ ، قَالَ: رَأَیْتُ ابْنَ عُمَرَ صَلَّی رَکْعَتَیِ الْفَجْرِ ثُمَّ احْتَبَی ، فَلَمْ یَتَکَلَّمْ حَتَّی صَلَّی الْغَدَاۃَ۔",,,6470,,
6471,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَبِیبٍ ، عَنْ عَمْرٍو ، قَالَ : سُئِلَ جَابِرُ بْنُ زَیْدٍ : ہَلْ یُفَرَّقُ بَیْنَ صَلاَۃِ الْفَجْرِ وَبَیْنَ الرَّکْعَتَیْنِ قَبْلَہُمَا بِکَلاَمٍ ؟ قَالَ : لاَ ، إِلاَّ أَنْ یَتَکَلَّمَ بِحَاجَۃٍ إِنْ شَائَ۔",,,6471,,
6472,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : حدَّثَنَا حُصَیْنٌ ، وَابْنُ عَوْنٍ ، عَنِ الشَّعْبِیِّ ، عَنْ مَسْرُوقٍ ؛ أَنَّہُ دَخَلَ الْمَسْجِدَ وَالْقَوْمُ فِی صَلاَۃِ الْغَدَاۃِ ، وَلَمْ یَکُنْ صَلَّی الرَّکْعَتَیْنِ ، فَصَلاَّہُمَا فِی نَاحِیَۃٍ ، ثُمَّ دَخَلَ مَعَ الْقَوْمِ فِی صَلاَتِہِمْ۔",,,6472,,
6473,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسِ ، عَنِ الْحَسَنِ ، قَالَ : کَانَ یَقُولُ : یَُصَلیہِمَا فِی نَاحِیَۃٍ ، ثُمَّ دَخَلَ مَعَ الْقَوْمِ فِی صَلاَتِہِمْ۔",,,6473,,
6474,حَدَّثَنَا عَبَّادُ بْنُ عَوَّامٍ ، عَنْ حُصَیْنٍ ، عَنِ الْقَاسِمِ بْنِ أَبِی أَیُّوبَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ أَنَّہُ جَائَ إِلَی الْمَسْجِدِ وَالإِمَامُ فِی صَلاَۃِ الْفَجْرِ ، فَصَلَّی الرَّکْعَتَیْنِ قَبْلَ أَنْ یَلِجَ الْمَسْجِدَ ، عِنْدَ بَابِ الْمَسْجِدِ۔,,,6474,,
6475,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُثْمَانَ بْنِ غِیَاثٍ ، قَالَ : حدَّثَنِی أَبُو عُثْمَانَ ، قَالَ : قَدْ رَأَیْتُ الرَّجُلَ یَجِیئُ وَعُمَرُ بْنُ الْخَطَّابِ فِی صَلاَۃِ الْفَجْرِ ، فَیُصَلِّی الرَّکْعَتَیْنِ فِی جَانِبِ الْمَسْجِدِ ، ثُمَّ یَدْخُلُ مَعَ الْقَوْمِ فِی صَلاَتِہِمْ۔",,,6475,,
6476,حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ مُطَرِّفٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ حَارِثَۃَ بْنِ مُضَرِّبٍ ؛ أَنَّ ابْنَ مَسْعُودٍ وَأَبَا مُوسَی خَرَجَا مِنْ عِنْدِ سَعِیدِ بْنِ الْعَاصِ ، فَأُقِیمَتِ الصَّلاَۃُ ، فَرَکَعَ ابْنُ مَسْعُودٍ رَکْعَتَیْنِ ، ثُمَّ دَخَلَ مَعَ الْقَوْمِ فِی الصَّلاَۃ ، وَأَمَّا أَبُو مُوسَی فَدَخَلَ فِی الصَّفِّ۔,,,6476,,
6477,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ دَاوُدَ بْنِ إِبْرَاہِیمَ ، قَالَ : قُلْتُ لِطَاوُوسٍ : أَرْکَعُ الرَّکْعَتَیْنِ وَالْمُقِیمُ یُقِیمُ ؟ قَالَ : ہَلْ تَسْتَطِیعُ ذَلِکَ ؟۔",,,6477,,
6478,"حَدَّثَنَا مُعْتَمِرٌ ، عَنِ الْحَکَمِ بْنِ أَبَانَ ، عَنْ عِکْرِمَۃَ ، قَالَ : اقْرَأْ ، وَلاَ تَقْرَأْ ، وَإِنْ قَرَأْتَ فَخَفِّفْ ، صَلِّہمَا وَلَوْ بِالطَّرِیقِ ، یَعْنِی رَکْعَتَیِ الْفَجْرِ۔",,,6478,,
6479,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنْ مُجَاہِدٍ ، قَالَ : إِذَا دَخَلْتَ الْمَسْجِدَ وَالنَّاسُ فِی صَلاَۃِ الصُّبْحِ ، وَلَمْ تَرْکَعْ رَکْعَتَیِ الْفَجْرِ فَارْکَعْہُمَا ، وَإِنْ ظَنَنْتَ أَنَّ الرَّکْعَۃَ الأُولَی تَفُوتُک۔",,,6479,,
6480,"حَدَّثَنَا وَکِیعٌ ، عَنْ دَلْہَمِ بْنِ صَالِحٍ ، عَنْ وَبَرَۃَ ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ یَفْعَلُہُ ، وَحَدَّثَنِی مَنْ رَآہُ فَعَلَہُ مَرَّتَیْنِ ؛ جَائَ مَرَّۃً وَہُمْ فِی الصَّلاَۃ ، فَصَلاَّہُمَا فِی جَانِبِ الْمَسْجِدِ ، ثُمَّ دَخَلَ مَرَّۃً أُخْرَی فَصَلَّی مَعَہُمْ ، وَلَمْ یُصَلِّہِمَا۔",,,6480,,
6481,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّہُ کَرِہَ إِذَا جَائَ وَالإِمَامُ فِی صَلاَۃِ الْفَجْرِ أَنْ یُصَلِّیَہُمَا فِی الْمَسْجِدِ ، وَقَالَ : یُصَلِّیہِمَا عَلَی بَابِ الْمَسْجِدِ ، أَوْ فِی نَاحِیَتِہِ۔",,,6481,,
6482,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنِ الْوَلِیدِ بْنِ أَبِی مَالِکٍ ، عَنْ أَبِی عُبَیْدِ اللہِ ، عَنْ أَبِی الدَّرْدَائِ ، قَالَ : إِنِّی لأَجِیئُ إِلَی الْقَوْمِ وَہُمْ صُفُوفٌ فِی صَلاَۃِ الْفَجْرِ ، فَأُصَلِّی الرَّکْعَتَیْنِ ، ثُمَّ أَنْضَمُّ إِلَیْہِمْ۔",,,6482,,
6483,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یُونُسُ بْنُ عُبَیْدٍ ، عَنِ ابْنِ سِیرِینَ ، أَنَّہُ کَانَ یَقُولُ فِی الرَّجُلِ إِذَا دَخَلَ الْمَسْجِدَ ، وَالْقَوْمُ یُصَلُّونَ الْغَدَاۃَ ، قَالَ : یَدْخُلُ مَعَ الْقَوْمِ فِی صَلاَتِہِمْ ، وَلاَ یُصَلِّی الرَّکْعَتَیْنِ ، فَإِنَّ مَا یَفُوتُہُ مِنَ الْمَکْتُوبَۃِ أَعْظَمُ مِنَ الرَّکْعَتَیْنِ۔",,,6483,,
6484,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : ذَکَرْتُہُ لإِبْرَاہِیمَ ، فَقَالَ : الْمَکْتُوبَۃُ تُقْضَی ، وَمُرَّ فِی التَّطَوُّعِ۔",,,6484,,
6485,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ سَلَمَۃَ بْنِ عَلْقَمَۃَ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : مَا یَفُوتُہُ مِنْ صَلاَۃِ الإِمَام أَفْضَلُ مِمَّا یَطْلُبُ فِی تَیْنِکَ الرَّکْعَتَیْنِ۔",,,6485,,
6486,"حَدَّثَنَا الْمُحَارِبِیُّ ، عَنْ عَاصِمٍ الأَحْوَلِ ، عَنْ حَمَّادٍ ، قَالَ : لاَ تَدْخُلِ الْمَسْجِدَ حَتَّی تُصَلِّیَ رَکْعَتَیْنِ قَبْلَ الْفَجْرِ ، وَلَوْ عَلَی کُنَاسَۃٍ۔",,,6486,,
6487,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرِ ، عَنْ عُبَیْدِ بْنِ الْحَسَنِ ، قَالَ : رَأَیْتُ ابْنَ مَعْقِلٍ صَلَّی الرَّکْعَتَیْنِ قَبْلَ الْفَجْرِ فِی السُّدَّۃِ۔",,,6487,,
6488,"حَدَّثَنَا مُلاَزِمُ بْنُ عَمْرٍو ، عَنْ بُشَیْرِ بْنِ فَرّوخَ ، قَالَ : حدَّثَنِی أَیُّوبُ بْنُ عُتْبَۃَ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، قَالَ : مَنْ أَتَی الْمَسْجِدَ وَقَدْ أُقِیمَتِ الصَّلاَۃُ ، فَلِیُؤَخِّرِ الرَّکْعَتَیْنِ قَبْلَ الْفَجْرِ حَتَّی یُصَلِّیَہُمَا ضُحًی۔",,,6488,,
6489,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی بِشْرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : إِنْ کَانَ فِی مَکَانٍ صَلاَّہُمَا ، وَإِنْ کَانَ فِی الْمَسْجِدِ لَمْ یُصَلِّہِمَا۔",,,6489,,
6490,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : إِنْ خَشِیَ فَوْتَ رَکْعَۃٍ دَخَلَ مَعَہُمْ ، وَلَمْ یُصَلِّہِمَا۔",,,6490,,
6491,"حَدَّثَنَا حَفْصٌ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، قَالَ : دَخَلَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْمَسْجِدَ وَأَخَذَ بِلاَلٌ فِی الإِقَامَۃِ ، فَقَامَ ابْنُ بُحَینۃَ یُصَلِّی رَکْعَتَیْنِ ، فَضَرَبَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَنْکِبَہُ ، وَقَالَ : یَا ابْنَ الْقِشْبِ ، تُصَلِّی الصُّبْحَ أَرْبَعًا۔ (بیہقی 482)",,,6491,,
6492,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ شُعْبَۃَ ، عَنْ سَعْدِ بْنِ إِبْرَاہِیمَ ، عَن حَفْصٍ ، عَنِ ابْنُ بُحَینۃَ ، قَالَ : أُقِیمَتْ صَلاَۃُ الصُّبْحِ ، فَقَامَ رَجُلٌ یُصَلِّی الرَّکْعَتَیْنِ ، فَلَمَّا صَلَّی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لاَثَ النَّاسُ حَوْلَہُ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لِلَّذِی صَلَّی الرَّکْعَتَیْنِ : أَتُصَلِّی الصُّبْحَ أَرْبَعًا ؟۔ (بخاری 663۔ مسلم 493)",,,6492,,
6493,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا أَبُو عَامِرِ الْمُزَنِیُّ صَالِحُ بْنُ رُسْتُم ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : أُقِیمَتْ صَلاَۃُ الصُّبْحِ ، فَقَامَ رَجُلٌ یُصَلِّی الرَّکْعَتَیْنِ ، فَجَذَبَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِثَوْبِہِ ، وَقَالَ : أَتُصَلِّی الصُّبْحَ أَرْبَعًا ؟۔ (احمد 1/355۔ ابویعلی 2568)",,,6493,,
6494,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی الْہَیْثُمِ ، قَالَ : قَالَ إِبْرَاہِیمُ : لأَنْ أُدْرِکَ مَا فَاتَنِی مِنَ الْمَکْتُوبَۃِ أَحَبُّ إِلَیَّ مِنْ أَنْ أُصَلِّیَہُمَا۔",,,6494,,
6495,"حَدَّثَنَا ہُشَیْمٌ، قَالَ: أَخْبَرَنَا مُغِیرَۃُ، عَنْ إِبْرَاہِیمَ، قَالَ: کَانُوا یَکْرَہُونَ التَّسَانُدَ إِلَی الْقِبْلَۃِ بَعْدَ رَکْعَتَیِ الْفَجْرِ۔",,,6495,,
6496,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا الْمَسْعُودِیُّ ، عَنِ الْقَاسِمِ بْنِ عَبْدِ الرَّحْمَنِ ؛ أَنَّ ابْنَ مَسْعُودٍ دَخَلَ الْمَسْجِدَ فَرَأَی أُنَاسًا قَدْ تَسَانَدُوا إِلَی الْقِبْلَۃِ ۔ قَالَ : فَقَالَ لَہُم عَبْدُ اللہِ : ہَکَذَا ، عَنْ وُجُوہِ الْمَلاَئِکَۃِ ؟۔",,,6496,,
6497,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حُصَیْنٌ ، عَنْ مُجَاہِدٍ ، قَالَ : کَانَ ابْنُ عُمَرَ إِذَا طَلَعَ الْفَجْرُ صَلَّی رَکْعَتَیْنِ ، ثُمَّ یَحْتَبِی وَنَحْنُ حَوْلَہُ ، فَإِنْ رَأَی أَحَدًا مِنَّا نَعَسَ حَرَّکَہُ ، قَالَ: وَکَانَ یَنْعَسُ وَہُوَ مُحْتَبٍ ، ثُمَّ تُقَامُ الصَّلاَۃُ فَیَنْہَضُ وَیُصَلِّی۔",,,6497,,
6498,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنِ الْقَاسِمِ ، عَنْ أَبِیہِ ، قَالَ : دَخَلَ عَبْدُ اللہِ الْمَسْجِدَ لِصَلاَۃِ الْفَجْرِ، فَإِذَا قَوْمٌ قَدْ أَسْنَدُوا ظُہُورَہُمْ إِلَی الْقِبْلَۃِ ، فَقَالَ : تَنَحَّوْا عَنِ الْقِبْلَۃِ ، لاَ تَحُولُوا بَیْنَ الْمَلاَئِکَۃِ وَبَیْنَ صَلاَتِہَا، وَإِنَّ ہَاتَیْنِ الرَّکْعَتَیْنِ صَلاَۃُ الْمَلاَئِکَۃِ۔",,,6498,,
6499,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ بْنِ جَابِرٍ ، عَنْ مَکْحُولٍ ، عَنْ أَبِی الدَّرْدَائِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : مَنْ مَشَی فِی ظُلْمَۃِ اللَّیْلِ إِلَی الْمَسْجِدِ ، لَقِیَ اللَّہَ بِنُورٍ یَوْمَ الْقِیَامَۃِ۔ (دارمی 1422۔ ابن حبان 2046)",,,6499,,
6500,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مَنْصُورٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانُوا یَرَوْنَ الْمَشْیَ فِی اللَّیْلَۃِ الْمُظْلِمَۃِ مُوجِبَۃً۔",,,6500,,
6501,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ سَعدِ بْنِ سَعِیدٍ ، قَالَ : حدَّثَنِی مُحَمَّدُ بْنُ إِبْرَاہِیمَ ، عَن قَیْسِ بْنِ عَمرو ، قَالَ : رَأَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجُلاً یُصَلِّی بَعْدَ صَلاَۃِ الصُّبْحِ رَکْعَتَیْنِ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَصَلاَۃُ الصُّبْحِ مَرَّتَیْنِ ؟ فَقَالَ الرَّجُلُ : إِنِّی لَمْ أَکُنْ صَلَّیْتُ الرَّکْعَتَیْنِ اللَّتَیْنِ قَبْلَہُمَا ، فَصَلَّیْتُہُمَا الأَنَ ، فَسَکَتَ۔ (ترمذی 422۔ ابوداؤد 1261)",,,6501,,
6502,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا عَبْدُ الْمَلِکِ ، عَنْ عَطَائٍ ؛ أَنَّ رَجُلاً صَلَّی مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلاَۃَ الصُّبْحِ ، فَلَمَّا قَضَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الصَّلاَۃَ ، قَامَ الرَّجُلُ فَصَلَّی رَکْعَتَیْنِ ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَا ہَاتَانِ الرَّکْعَتَانِ ؟ فَقَالَ : یَا رَسُولَ اللہِ ، جِئْتُ وَأَنْتَ فِی الصَّلاَۃ ، وَلَمْ أَکُنْ صَلَّیْتُ الرَّکْعَتَیْنِ قَبْلَ الْفَجْرِ ، فَکَرِہْتُ أَنْ أُصَلِّیَہُمَا وَأَنْتَ تُصَلِّی ، فَلَمَّا قَضَیْتَ الصَّلاَۃَ ، قُمْتُ فَصَلَّیْتُ الصَّلاَۃَ ، فَضَحِکَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَلَمْ یَأْمُرْہُ ، وَلَمْ یَنْہَہُ۔ (طبرانی 939)",,,6502,,
6503,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا شَیْخٌ ، یُقَالُ لَہُ : مِسْمَعُ بْنُ ثَابِتٍ ، قَالَ : رَأَیْتُ عَطَائً فَعَلَ مِثْلَ ذَلِکَ۔",,,6503,,
6504,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : إِذَا فَاتَتْہُ رَکْعَتَا الْفَجْرِ صَلاَّہُمَا بَعْدَ صَلاَۃِ الْفَجْرِ۔",,,6504,,
6505,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، قَالَ : سَمِعْتُ الْقَاسِمَ ، یَقُولُ : لَوْ لَمْ أُصَلِّہِمَا حَتَّی أُصَلِّیَ الْفَجْرَ ، صَلَّیْتُہُمَا بَعْدَ طُلُوعِ الشَّمْسِ۔",,,6505,,
6506,حَدَّثَنَا وَکِیعٌ ، عَنْ فُضَیْلِ بْنِ غَزْوَانَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ جَائَ إِلَی الْقَوْمِ وَہُمْ فِی الصَّلاَۃ ، وَلَمْ یَکُنْ صَلَّی الرَّکْعَتَیْنِ فَدَخَلَ مَعَہُمْ ، ثُمَّ جَلَسَ فِی مُصَلاَّہُ ، فَلَمَّا أَضْحَی قَامَ فَقَضَاہُمَا۔,,,6506,,
6507,حَدَّثَنَا وَکِیعٌ ، عَنْ یَزِیدَ ، وَرَبِیعٌ ، عَنِ ابْنِ سِیرِینَ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ صَلاَّہُمَا بَعْدَ مَا أَضْحَی۔,,,6507,,
6508,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : لاَ تُقْضَی رَکْعَتَا الْفَجْرِ۔",,,6508,,
6509,"حَدَّثَنَا وَکِیعٌ ، عَنْ فُضَیْلِ بْنِ مَرْزُوقٍ ، عَنْ عَطِیَّۃَ ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ قَضَاہُمَا حِینَ سَلَّمَ الإِمَامُ۔",,,6509,,
6510,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، عَنْ زَیْدِ بْنِ خَالِدٍ الْجُہَنِیِّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : صَلُّوا فِی بُیُوتِکُمْ ، وَلاَ تَتَّخِذُوہَا قُبُورًا۔ (عبد بن حمید 275۔ بزار 706)",,,6510,,
6511,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی سُفْیَانَ ، عَنْ جَابِرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِذَا قَضَی أَحَدُکُمُ الصَّلاَۃ فِی مَسْجِدِہِ ، فَلْیَجْعَلْ لِبَیْتِہِ نَصِیبًا مِنْ صَلاَتِہِ ، فَإِنَّ اللَّہَ جَاعِلٌ فِی بَیْتِہِ مِنْ صَلاَتِہِ خَیْرًا۔ (مسلم 539۔ احمد 3/316)",,,6511,,
6512,حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ أَبِی سَعِیدٍ ؛ عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، بِمِثْلِ حَدِیثِ أَبِی مُعَاوِیَۃَ۔ (احمد 3/59۔ عبدالرزاق 4837),,,6512,,
6513,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا عُبَیْدُ اللہِ بْنُ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أَنَّہُ قَالَ : صَلُّوا فِی بُیُوتِکُمْ ، وَلاَ تَتَّخِذُوہَا قُبُورًا۔ (بخاری 1187۔ مسلم 538)",,,6513,,
6514,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ اللہِ بْنِ سَعِیدٍ ، عَنْ سَالِمٍ أَبِی النَّضْرِ ، عَنْ بُسْرِ بْنِ سَعِیدٍ ، عَنْ زَیْدِ بْنِ ثَابِتٍ ، قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَفْضَلُ الصَّلاَۃِ صَلاَۃُ الْمَرْئِ فِی بَیْتِہِ ، إِلاَّ الْمَکْتُوبَۃَ۔",,,6514,,
6515,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ أَبِی الْعُمَیْسِ ، عَنِ الْقَاسِمِ ، قَالَ : کَانَتْ أَفْضَلُ صَلاَۃِ عَبْدِ اللہِ فِی بَیْتِہِ۔",,,6515,,
6516,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ ہِلاَلِ بْنِ یَِسَافٍ ، عَنْ ضَمْرَۃَ بْنِ حَبِیبٍ ، عَنْ رَجُلٍ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : تَطَوُّعُ الرَّجُلِ فِی بَیْتِہِ یَزِیدُ عَلَی تَطَوُّعِہِ عِنْدَ النَّاسِ ، کَفَضْلِ صَلاَۃِ الرَّجُلِ فِی الْجَمَاعَۃِ عَلَی صَلاَتِہِ وَحْدَہُ۔",,,6516,,
6517,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، قَالَ : کَانَ شُرَیْحٌ ، وَمَسْرُوقٌ کِلاَہُمَا لَہُ بَیْتٌ یُطِیلُ فِیہِ الصَّلاَۃ۔",,,6517,,
6518,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، عَنْ حَسَّانَ بْنِ عَطِیَّۃَ، قَالَ: صَلاَۃُ الرَّجُلِ عِنْدَ أَہْلِہِ مِنَ السِّرِّ۔",,,6518,,
6519,"حَدَّثَنَا الْحَسَنُ بْنُ مُوسَی ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ سُہَیْلٍ ، عَنْ أَبِیہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ : رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تَجْعَلُوا بُیُوتَکُمْ مَقَابِرَ۔ (مسلم 539۔ ترمذی 2877)",,,6519,,
6520,"حَدَّثَنَا شَبَابَۃُ ، قَالَ : حدَّثَنَا ابْنُ أَبِی ذِئْبٍ ، عَنْ صَالِحٍ مَوْلَی التَّوْأَمَۃِ ، عَنِ السَّائِبِ بْنِ خَبَّابٍ ، قَالَ : کُنْتُ لاَ أُصَلِّی إِلاَّ فِی الْمَسْجِدِ ، فَقَالَ لِی زَیْدُ بْنُ ثَابِتٍ : صَلاَۃُ الرَّجُلِ فِی بَیْتِہِ أَفْضَلُ مِنْ صَلاَتہٍ فِی الْمَسْجِدِ إِلاَّ الْمَکْتُوبَۃَ ، وَصَلاَۃُ الرَّجُلِ فِی بَیْتِہِ نُورٌ۔",,,6520,,
6521,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ طَارِقٍ ، عَنْ عَاصِمِ بْنِ عَمْرٍو ؛ أَنَّ نَفَرًا مِنْ أَہْلِ الْعِرَاقِ قَدِمُوا عَلَی عُمَرَ ، فَسَأَلُوہُ عَنْ صَلاَۃِ الرَّجُلِ فِی بَیْتِہِ ؟ فَقَالَ عُمَرُ : مَا سَأَلَنِی عَنْہَا أَحَدٌ مُذْ سَأَلْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْہَا ، فَقَالَ : صَلاَۃُ الرَّجُلِ فِی بَیْتِہِ نُورٌ ، فَنَوِّرُوا بُیُوتَکُمْ۔",,,6521,,
6522,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ یَحْیَی بْنِ الْجَزَّارِ ، قَالَ : کَانَ أصْحَابُ عَبْدِ اللہِ یَقُولُونَ : الصَّفُّ الْمُقَدَّمُ الَّذِی یَلِی الْمَقْصُورَۃَ۔",,,6522,,
6523,"حَدَّثَنَا وَکِیعٌ ، عَنِ الْمَسْعُودِیِّ ، عَنْ ثَابِتِ بْنِ عُبَیْدٍ ، قَالَ : سَمِعْتُ أَبَا عُبَیْدَۃَ یَقُولُ : الصَّفُّ الأَوَّلُ الَّذِی یَلِی الْمَقْصُورَۃَ۔",,,6523,,
6524,"حَدَّثَنَا حَفْصٌ ، عَنِ الشَّیْبَانِیِّ ، قَالَ : رَأَیْتُ أَبَا عَبْدِ الرَّحْمَنِ ، وَزِرَّ بْنَ حُبَیْشٍ ، وَعَمْرَو بْنَ مَیْمُونٍ یُصَلُّونَ عَنْ یَمِینِ الْمَقْصُورَۃِ ، وَقَالَ حَفْصٌ مَرَّۃً : مَا بَیْنَ الأُسْطُوَانَۃِ إِلَی الْحَائِطِ۔",,,6524,,
6525,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، قَالَ : حدَّثَنَا عَبْدُ الْوَاحِدِ بْنُ زِیَادٍ ، قَالَ : قُلْتُ لِلْحَسَنِ : إِنَّہُمْ یَقُولُونَ : الصَّفُّ الأَوَّلُ الَّذِی یَلِی الْمَقْصُورَۃَ ، فَقَالَ : ہُوَ الَّذِی یَلِی الْحَائِطَ۔",,,6525,,
6526,"حَدَّثَنَا وَکِیعٌ ، عَنْ سَلَمَۃَ بْنِ وَرْدَانَ ، قَالَ : رَأَیْتُ أَنَسًا یُصَلِّی عِنْدَ الْحَجَرِ۔",,,6526,,
6527,"حَدَّثَنَا إِسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، یَرْفَعُہُ ، قَالَ : لاَ تَأْتَمُّ بِنَائِمٍ ، وَلاَ مُتَحَدِّثٍ۔",,,6527,,
6528,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَبْدِ الْکَرِیمِ أَبِی أُمَیَّۃَ ، عَنْ مُجَاہِدٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی أَنْ یُصَلِّیَ خَلْفَ النُّوَّامِ وَالْمُتَحَدِّثِینَ۔ (طبرانی5242)",,,6528,,
6529,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : حدَّثَنَا یُوسُفَ بْنُ عَبْدِ اللہِ بْنِ الْحَارِثِ ، قَالَ : کُنْتُ جَالِسًا إِلَی جَنْبِ حُمَیْدِ بْنِ عَبْدِ الرَّحْمَنِ ، فَالْتَفَتَ ، فَإِذَا رَجُلٌ یُصَلِّی خَلْفَہُ ، فَقَالَ لَہُ : إِمَّا أَنْ تَحَوَّلَ عَنِّی ، وَإِمَّا أَنْ أَقُومَ عَنک۔",,,6529,,
6530,حَدَّثَنَا الثَّقَفِیُّ ، عَنْ خَالِدٍ الْحَذَّائِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ سَعِیدِ بْنِ وَہْبٍ ، عَنْ أَبِیہِ ، عَنِ ابْنِ مَسْعُودٍ ؛ أَنَّہُ کَرِہَ أَنْ یَأْتَمَّ بِقَوْمٍ یَتَحَدَّثُونَ۔,,,6530,,
6531,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ مَعْدِی کَرِبَ ، عَنْ عَبْدِ اللہِ ، قَالَ : لاَ تَأْتَمْ بِقَوْمٍ یَمْتَرُونَ ، أَوْ یَلْغُونَ۔",,,6531,,
6532,"حَدَّثَنَا عُمَرُ بْنُ أَیُّوبَ ، عَنْ جَعْفَرٍ ، عَنْ مَیْمُونٍ ، قَالَ : کَانَ ابْنُ عُمَرَ لاَ یُصَلِّی خَلْفَ رَجُلٍ لاَ یُصَلِّی ، إِلاَّ یَوْمَ جُمُعَۃٍِ ۔ قَالَ : فَذَکَرْتُ ذَلِکَ لِعَبْدِ الْکَرِیمِ ، فَقَالَ : کَانَ ابْنُ عُمَرَ لاَ یُصَلِّی خَلْفَ رَجُلٍ یَتَکَلَّمُ إِلاَّ یَوْمَ الْجُمُعَۃِ۔",,,6532,,
6533,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَشْعَثَ بْنِ أَبِی الشَّعْثَائِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : إِذا کَانُوا یَتَحَدَّثُونَ بِذِکْرِ اللہِ فَلاَ بَأْسَ أَنْ یَأْتَمَّ بِہِمْ۔",,,6533,,
6534,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنْ مُجَاہِدٍ ، قَالَ : أُصَلِّی وَرَائَ قاعِدٍ أَحَبُّ إِلَیَّ مِنْ أَنْ أُصَلِّیَ وَرَائَ نَائِمٍ۔",,,6534,,
6535,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الرَّبِیعُ بْنُ صَبِیحٍ ، عَنْ قَیْسِ بْنِ سَعْدٍ ، عَنْ طَاوُوسٍ ؛ أَنَّہُ کَرِہَ أَنْ یَأْتَمَّ بِنَائِمٍ۔",,,6535,,
6536,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یُونُسُ بْنُ عُبَیْدٍ ، عَنِ ابْنِ سِیرِینَ ، عَنْ أَنَسِ بْنِ مَالِکٍ ؛ أَنَّ عُمَرَ بْنَ الْخَطَّابِ رَأَی رَجُلاً یُصَلِّی وَعَلَیْہِ قَلَنْسُوَۃٌ ، بِطَانَتُہَا مِنْ جُلُودِ الثَّعَالِبِ ، قَالَ : فَأَلْقَاہَا عَنْ رَأْسِہِ ، وَقَالَ : مَا یُدْرِیَک لَعَلَّہُ لَیْسَ بِذَکِیٍّ ؟۔",,,6536,,
6537,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ: أَخْبَرَنَا مَنْصُورٌ ، عَنِ الْحَکَمِ ، عَنْ عَلِیٍّ؛ أَنَّہُ کَانَ یَکْرَہُ الصَّلاَۃ فِی جُلُودِ الثَّعَالِبِ۔",,,6537,,
6538,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ حَبِیبٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ (ح) وَعَنْ أَشْعَثَ بْنِ عَبْدِ الْمَلِکِ ، عَنِ الْحَسَنِ ، أَنَّہُمَا قَالاَ : اِلْبَسْ جُلُودَ الثَّعَالِبِ ، وَلاَ تُصَلِّ فِیہَا۔",,,6538,,
6539,حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ لاَ یَرَی بِذَلِکَ بَأْسًا إِذَا دُبِغَتْ۔,,,6539,,
6540,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : حدَّثَنَا یُونُسُ ، عَنْ عَمْرِو بْنِ سَعِیدٍ ، قَالَ : رَأَیْتُ أَبَا الْعَالِیَۃَ دَخَلَ الْمَسْجِدَ فَصَلَّی فِیہِ ، وَعَلَیْہِ قَلَنْسُوَۃٌ بِطَانَتُہَا جُلُودُ ثَعَالِبَ ، فَأَخَذَہَا مِنْ رَأْسِہِ وَوَضَعَہَا فِی کُمِّہِ ، فَلَمَّا قَضَی صَلاَتَہُ ، قَالَ : قُلْتُ لَہُ : رَأَیْتُک أَخَذْتَ قَلَنْسُوَتَکَ مِنْ رَأْسِکَ فَوَضَعْتَہَا فِی کُمِّکَ ؟ فَقَالَ : إِنِّی کَرِہْتُ أَنْ أُصَلِّیَ فِیہَا ، وَکَرِہْتُ أَنْ أَضَعَہَا فَتُسْرَقَ ، فَلِذَلِکَ جَعَلْتُہَا فِی کُمِّ قَمِیصِی۔",,,6540,,
6541,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سَدِیرٍ الصَّیْرَفِیِّ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : کَانَ لِعَلِیِّ بْنِ الْحُسَیْنِ سَبَنجُونَ ثَعَالِبَ یَلْبَسُہُ ، فَإِذَا صَلَّی نَزَعَہُ۔",,,6541,,
6542,"حَدَّثَنَا إِسْمَاعِیلُ بْنُ إِبْرَاہِیمَ ، عَن خَالِدٍ الْحَذَّائِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ سَعِیدِ بْنِ وَہْبٍ ، عَنْ أَبِیہِ ؛ أَنَّ عَلِیًّا رَأَی قَوْمًا یُصَلُّونَ وَقَدْ سَدَلُوا ، فَقَالَ : کَأَنَّہُمُ الْیَہُودُ خَرَجُوا مِنْ فِہْرِہِمْ۔",,,6542,,
6543,حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنِ الْحَسَنِ بْنِ عُبیْدِ اللہِ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّہُ کَرِہَ أَنْ یَسْدُلَ الرَّجُلُ ثَوْبَہُ فِی الصَّلاَۃ۔,,,6543,,
6544,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : کُرِہَ السَّدْلُ۔",,,6544,,
6545,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا فُضَیْلُ بْنُ غَزْوَانَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَرِہَ السَّدْلَ فِی الصَّلاَۃ ، مُخَالَفَۃً لِلْیَہُودِ ، وَقَالَ : إِنَّہُمْ یَسْدُلُونَ۔",,,6545,,
6546,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، وَہُشَیْمٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ؛ أَنَّہُ کَانَ یَکْرَہُ السَّدْلَ فِی الصَّلاَۃ۔,,,6546,,
6547,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ (ح) وَعَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ؛ أَنَّہُمَا کَرِہَا السَّدْلَ فِی الصَّلاَۃ ۔ قَالَ وَکِیعٌ : وَنَحْنُ نَکْرَہُہُ۔",,,6547,,
6548,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ عِسْلِ بْنِ سُفْیَانَ ، عَنْ عَطَائٍ ، عَنْ أَبِی ہُرَیْرَۃَ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی عَنِ السَّدْلِ فِی الصَّلاَۃ۔ (ترمذی 378۔ احمد 2/295)",,,6548,,
6549,حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ أَنَّہُ لَمْ یَکُنْ یَرَی بِالسَّدْلِ بَأْسًا۔,,,6549,,
6550,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَکْثَرُ مَا رَأَیْتُ عَطَائً یَسْدُلُ۔",,,6550,,
6551,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّہُ کَانَ لاَ یَرَی بِہِ بَأْسًا ، إِذَا کَانَ عَلَیْہِ قَمِیصٌ۔,,,6551,,
6552,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ مُحَارِبٍ ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ یَسْدُلُ فِی الصَّلاَۃ۔",,,6552,,
6553,"حَدَّثَنَا وَکِیعٌ ، قَالَ: حدَّثَنَا أَبُو شِہَابٍ مُوسَی بْنُ ثَابِتٍ ، قَالَ: رَأَیْتُ سَعِیدَ بْنَ جُبَیْرٍ یَسْدُلُ فِی التَّطَوُّعِ، وَعَلَیْہِ مُسْتُقَۃٌ مُکَفَّفَۃٌ۔",,,6553,,
6554,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ؛ أَنَّہُ کَانَ یَسْدُلُ فِی الصَّلاَۃ۔",,,6554,,
6555,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ، عَنْ حُمَیْدٍ، قَالَ: رَأَیْتُ الْحَسَنَ مَا لاَ أُحْصِی فِی الصَّلاَۃ یَسْدُلُ، وَأَنَا أَرَی ظَہْرَہُ۔",,,6555,,
6556,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا یَزِیدُ بْنُ إِبْرَاہِیمَ ، عَنِ الْحَسَنِ ، قَالَ : لاَ بَأْسَ بِالسَّدْلِ فِی الصَّلاَۃ۔",,,6556,,
6557,"حَدَّثَنَا مُعَاذٌ ، قَالَ : حدَّثَنَا ابْنُ عَوْنٍ ، قَالَ : رَأَیْتُ مُحَمَّدًا یُصَلِّی وَقَدْ سَدَلَ ثَوْبَہُ ، فَلاَ أَدْرِی عَلَی الإِزَارِ کَانَ ، أَوْ عَلَی الْقَمِیصِ۔",,,6557,,
6558,"حَدَّثَنَا عَبْدَۃُ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، قَالَ : رَأَیْتُ ابْنَ سِیرِینَ یَسْدُلُ فِی الصَّلاَۃ۔",,,6558,,
6559,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، قَالَ : رَأَیْتُ مَکْحُولاً یَسْدُلُ طَیْلَسَانَۃً عَلَیْہِ فِی الصَّلاَۃ۔",,,6559,,
6560,حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا۔,,,6560,,
6561,"حَدَّثَنَا وَکِیعٌ ، عَنْ مَہْدِیِّ بْنِ مَیْمُونٍ ، قَالَ : رَأَیْتُ الْحَسَنَ یَسْدُلُ عَلَی الْقَبَائِ۔",,,6561,,
6562,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنْ أَبِی قِلاَبَۃَ ، قَالَ : سَأَلْتُ مُسْلِمَ بْنَ یَسَارٍ : أَیْنَ مُنْتَہَی الْبَصَرِ فِی الصَّلاَۃ ؟ فَقَالَ : إِنْ حَیْثُ تَسْجُدُ فَحَسَنٌ۔",,,6562,,
6563,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا الْعَوَّامُ ، عَنْ إِبْرَاہِیمَ النَّخَعِیِّ ؛ أَنَّہُ کَانَ یُحِبُّ لِلْمُصَلِّی أَنْ لاَ یُجَاوِزَ بَصَرُہُ مَوْضِعَ سُجُودِہِ۔",,,6563,,
6564,حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی حُرَّۃَ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّہُ کَانَ یُحِبُّ أَنْ یَضَعَ الرَّجُلُ بَصَرَہُ حِذَائَ مَوْضِعِ سُجُودِہِ ، فَإِنْ لَمْ یَفْعَلْ ، أَوْ کَلِمَۃً نَحْوَہَا فَلْیُغْمِضْ عَیْنَیْہِ۔,,,6564,,
6565,حَدَّثَنَا ہُشَیْمٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ؛ أَنَّہُ کَرِہَ أَنْ یُصَلِّیَ الرَّجُلُ وَہُوَ مُغْمِضُ الْعَیْنِ۔,,,6565,,
6566,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، قَالَ : حدَّثَنَا جَمِیلُ بْنُ عُبَیْدٍ ، قَالَ : سَمِعْتُ الْحَسَنَ ، وَسَأَلَہُ رَجُلٌ : أُغْمِضُ عَیْنِی إِذَا سَجَدْتُ ؟ فَقَالَ : إِنْ شِئْتَ۔",,,6566,,
6567,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَنْ جَمِیلٍ ، قَالَ : سَمِعْتُ الْحَسَنَ ، وَسُئِلَ عَنِ الرَّجُلِ یُغْمِضُ عَیْنَیْہِ وَہُوَ سَاجِدٌ فِی الصَّلاَۃ ؟ قَالَ : لاَ بَأْسَ بِہِ۔",,,6567,,
6568,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ بُرْدِ بْنِ أَبِی زِیَادٍ ، عَنْ أَبِی فَاخِتَۃَ ، عَنِ ابْنِ عُمَرَ ، قَالَ : شُدَّ حَقْوَک فِی الصَّلاَۃ ، وَلَوْ بِعِقَالٍ۔",,,6568,,
6569,حَدَّثَنَا عَبْدَۃُ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ لاَ یُصَلَّی إِلاَّ وَہُوَ مُؤْتَزِرٌ۔,,,6569,,
6570,"حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنْ أَیُّوبَ، قَالَ: رَأَیْتُ سَالِمَ بْنَ عَبْدِاللہِ یُصَلِّی وَہُوَ مُؤْتَزِرٌ فَوْقَ قَمِیصِہِ، أَوْ قَالَ: جُبَّتِہِ۔",,,6570,,
6571,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حُصَیْنٌ ، عَنْ أَبِی مَالِکٍ؛ أَنَّہُ کَانَ یَشُدُّ حِقْوَہُ فِی الصَّلاَۃ بِخَیْطٍ، أَوْ بِشَیْئٍ۔",,,6571,,
6572,"حَدَّثَنَا شَرِیکٌ ، عَنْ أَبِی الْہَیْثُمِ ، قَالَ : قُلْتُ لإِبْرَاہِیمَ : أُصَلِّی بِاللَّیْلِ فِی الْقَمِیصِ وَالْقَبَائِ ؟ قَالَ : شُدَّ حِقْوَک بِالإِزَارِ۔",,,6572,,
6573,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُحَمَّدِ بْنِ قَیْسٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : شُدَّ حِقْوَک وَلَوْ بِعِقَالٍ۔",,,6573,,
6574,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ الْمَلِکِ بْنِ عَطَائٍ الْبَکَّائِیِّ ، عَنْ یَزِیدَ بْنِ الأَصَمِّ ، قَالَ : کَانَ یُقَالُ : شُدَّ حِقْوَک وَلَوْ بِعِقَالٍ۔",,,6574,,
6575,حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ شُعْبَۃَ ، عَنْ وَضَّاحٍ ؛ أَنَّہُمْ سَافَرُوا مَعَ جَابِرِ بْنِ زَیْدٍ ، فَکَانَ یَؤُمُّہُمْ مُؤْتَزِرًا فَوْقَ الْقَمِیصِ۔,,,6575,,
6576,حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ، عَنِ ابْنِ عَوْنٍ، عَنْ مُحَمَّدٍ؛ أَنَّہُ کَانَ یَکْرَہُ لِلرَّجُلِ وَالْمَرْأَۃِ یُصَلِّیَانِ بِغَیْرِ إزَارٍ۔,,,6576,,
6577,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ جُہَیْرِ بْنِ یَزِیدَ ، عَنِ ابْنِ سِیرِینَ ؛ سَأَلْتُُہُ عَنِ الرَّجُلِ یُصَلِّی مُؤْتَزِرًا فَوْقَ الْقَمِیصِ ؟ فَقَالَ : لاَ بَأْسَ بِہِ۔",,,6577,,
6578,"حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ عَبْدِ الرَّحْمَنِ الأَشْجَعِیِّ ، عَنِ ابْنِ مَعْقِلٍ ، قَالَ : شُدَّ حِقْوَک ، وَلَوْ بِعِقَالٍ۔",,,6578,,
6579,"حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنْ مُجَاہِدٍ ، قَالَ : شُدَّ حِقْوَک بِشَیْئٍ۔",,,6579,,
6580,"حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنِ الْحَارِثِ بْنِ ثَقِیفٍ ، عَنِ الْحَسَنِ ، قَالَ : شُدَّ حِقْوَک ، وَلَوْ بِعِقَالٍ۔",,,6580,,
6581,حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ أَبِی حَصِینٍ ، عَنِ ابْنِ الأَسْوَدِ ، وَإِبْرَاہِیمَ ؛ أَنَّہُمَا کَانَا یَؤُمَّانِ بِغَیْرِ إِزَارٍ۔,,,6581,,
6582,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُجَالِدٌ ؛ أَنَّ أَبَا ہُبَیْرَۃَ الأَنْصَارِیَّ سَأَلَ الشَّعْبِیَّ ، فَقَالَ : أَشُدُّ حِقْوِی إِذَا قُمْتُ أُصَلِّی ؟ فَقَالَ لَہُ الشَّعْبِیُّ : إِنَّمَا یَفْعَلُ ذَلِکَ الْمَجُوسُ۔",,,6582,,
6583,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إِدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنْ أَبِی مَالِکٍ ، قَالَ : إِذَا ضَمَمْتَ عَلَیْک الْقَبَائَ ، أَجْزَأَکَ مَجْزَأَ الإِزَارِ۔",,,6583,,
6584,"حَدَّثَنَا مُحَمَّدُ بْنُ عُبَیْدٍ ، عَنِ الرَّبِیعِ بْنِ حَسَّانٍ ، قَالَ : رَأَیْتُ أَبَا الْبَخْتَرِیَّ یُصَلِّی فِی قَبَائٍ۔",,,6584,,
6585,"حَدَّثَنَا عُبَیْدُ اللہِ ، عَنْ إِسْرَائِیلَ ، عَنْ إِبْرَاہِیمَ بْنِ مُہَاجِرٍ ، عَنْ إِبْرَاہِیمَ بْنِ سُوَیْد ، قَالَ : قدِمَ الأَسْوَدُ مِنْ سَفَرٍ ، فَصَلَّی وَعَلَیْہِ قَبَائٌ۔",,,6585,,
6586,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن ہَمَّامٍ ، قَالَ : صَلَّی حُذَیْفَۃُ عَلَی دُکَّانٍ وَہُمْ أَسْفَلُ مِنْہُ ، قَالَ : فَجَذَبَہُ سَلْمَانُ حَتَّی أَنْزَلَہُ ، فَلَمَّا انْصَرَفَ ، قَالَ لَہُ : أَمَا عَلِمْتَ أَنَّ أَصْحَابَک کَانُوا یَکْرَہُونَ أَنْ یُصَلِّیَ الإِمَامُ عَلَی الشَّیْئِ ، وَہُمْ أَسْفَلُ مِنْہُ ؟ قَالَ : فَقَالَ حُذَیْفَۃُ : بَلَی ، قَدْ ذَکَرْتُ حِینَ مَدَدْتَنِی۔",,,6586,,
6587,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ عَوْنٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : صَلَّی حُذَیْفَۃُ عَلَی دُکَّانٍ بِالْمَدَائِنِ ، أَرْفَعَ مِنْ أَصْحَابِہِ ، فَمَدَّہُ أَبُو مَسْعُودٍ ، فَقَالَ لَہُ : أَمَّا عَلِمْتَ أَنْ ہَذَا یُکْرَہُ ؟ قَالَ : أَلَمْ تَرَ أَنَّک لَمَّا ذَکَّرْتَنِی ذَکَرْتُ۔",,,6587,,
6588,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی قَیْسٍ ، عَنْ ہُزَیْلٍ ، عَنْ عَبْدِ اللہِ ؛ أَنَّہُ کَرِہَ أَنْ یَرْتَفِعَ الإِمَامُ عَلَی أَصْحَابِہِ۔,,,6588,,
6589,"حَدَّثَنَا وَکِیعٌ ، عَنِ الْمَسْعُودِیِّ ، عَنِ الْقَاسِمِ ، قَالَ : کَانَ شَاذَرْوَانُ الْقَصْرِ یَقُومُ عَلَیْہِ الإِمَامُ ۔ قَالَ : فَکَرِہَہُ عَبْدُ اللہِ ، وَأَمَرَ بِہِ فَکُسِرَ۔",,,6589,,
6590,حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّہُ کَانَ یَکْرَہُ أَنْ یَکُونَ مَکَانُ الإِمَامِ أَرْفَعَ مِنْ مَکَانِ الْقَوْمِ ، وَکَانَ یَکْرَہُ أَنْ یَرْفَعَ الرَّجُلُ فِی مُصَلاَّہُ شَیْئًا یَسْجُدُ عَلَیْہِ۔,,,6590,,
6591,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ إِسْمَاعِیلَ بْنِ سُمَیْعٍ ، عَنْ بِلاَلٍ الْعَبْسِیِّ ، قَالَ : رَأَی عَمَّارٌ رَجُلاً یُصَلِّی عَلَی رَابِیَۃٍ ، فَأَخَذَ بِقَفَاہُ ، فَحَطَّہُ إِلَی الأَرْضِ ، فَقَالَ : صَلِّ ہَاہُنَا۔",,,6591,,
6592,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عُثْمَانُ بْنِ أَبِی ہِنْدٍ ، قَالَ : رَأَیْتُ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ یُصَلِّی فَوْقَ کَنِیسَۃٍ بِالشَّامِ ، وَالنَّاسُ أَسْفَلَ مِنْہُ۔",,,6592,,
6593,"حَدَّثَنَا غُنْدَرٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : کَانَ لاَ یَرَی بَأْسًا أَنْ یُصَلِّیَ الإِمَامُ عَلَی مَکَان أَرْفَعَ مِنْ أَصْحَابِہِ۔",,,6593,,
6594,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، وَمُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : إِمَامُ الْقَوْمِ ضَامِنٌ ، فَلاَ یَخُصُّ نَفْسَہُ بِشَیْئٍ مِنَ الدُّعَائِ دُونَہُمْ۔",,,6594,,
6595,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ الْحَذَّائِ ، قَالَ : قَالَ أَبُو قِلاَبَۃَ : تَدْرِی لِمَ کُرِہَتِ الإِمَامۃُ ؟ قَالَ : لاَ ، وَلَکِنَّہَا کُرِہَتْ أَنَّہُ لَیْسَ لإِمَامٍ أَنْ یَخُصَّ نَفْسَہُ بِدُعَائٍ مِنْ دُونِ مَنْ وَرَائَہُ۔",,,6595,,
6596,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : یُکْرَہُ أَنْ یَخُصَّ الإِمَام نَفْسَہُ بِشَیْئٍ مِنْ دُونِ أصْحَابِہِ۔",,,6596,,
6597,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ ہَارُونَ بْنِ إِبْرَاہِیمَ ، قَالَ : قُلْتُ لاِبْنِ سِیرِینَ : لِلإِمَامِ أَنْ یَخُصَّ بِشَیْئٍ مِنَ الدُّعَائِ ؟ قَالَ : لاَ ، فَلْیَدْعُ لَہُمْ کَمَا یَدْعُو لِنَفْسِہِ۔",,,6597,,
6598,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، ومُجَاہِدٍ ، قَالَ : لاَ یَنْبَغِینَّ لِلإِمَامِ أَنْ یَخُصَّ نَفْسَہُ بِدُعَائٍ مِنْ دُونِ الْقَوْمِ۔",,,6598,,
6599,حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ أَشْعَثَ ، عَنْ کُرْدُوسٍ ، عَنْ عَبْدِ اللہِ ؛ أَنَّہُ کَانَ یَکْرَہُ إِذَا کَانَ الرَّجُلُ فِی الْقَوْمِ أَنْ یَخُصَّ نَفْسَہُ بِشَیْئٍ مِنَ الدُّعَائِ دُونَہُمْ۔,,,6599,,
6600,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حُصَیْنٌ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : مَا أُبَالِی نَفَخْتُ ، أَوْ تَکَلَّمْتُ ۔ وَقَالَ : النَّفْخُ فِی الصَّلاَۃ کَلاَمٌ۔",,,6600,,
6601,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ: أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إِبْرَاہِیمَ؛ أَنَّہُ کَانَ یَکْرَہُ النَّفْخَ فِی الصَّلاَۃ ، وَقَالَ: نَحِّہِ بِثَوْبِکَ، أَوْ بِکُمِّ قَمِیصِکَ ۔ وَکُرِہَ النَّفْخُ۔",,,6601,,
6602,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ الشَّیْبَانِیِّ ، عَنِ ابْنِ أَبِی الْہُذَیْلِ ، قَالَ : لأَنْ أَسْجُدَ عَلَی الرَّضْفِ أَحَبُّ إِلَیَّ أَنْ أَنْفُخَ فِی صَلاَتِی۔",,,6602,,
6603,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی الْہُذَیْلِ ، قَالَ : لأَنْ أَضَعَ جَبْہَتِی عَلَی جَمْرَۃٍ حَتَّی تُطْفَأَ ، أَحَبُّ إِلَیَّ مِنْ أَنْ أَنْفُخَ فِی صَلاَتِی ، ثُمَّ أَسْجُدَ۔",,,6603,,
6604,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنْ مُسْلِمٍ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّہُ قَالَ : النَّفْخُ فِی الصَّلاَۃ کَلاَمٌ۔",,,6604,,
6605,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، عَنْ أَبِی الضُّحَی ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : النَّفْخُ فِی الصَّلاَۃِ یَقْطَعُ الصَّلاَۃ۔",,,6605,,
6606,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ أَنَّہُ کَرِہَ النَّفْخَ فِی الصَّلاَۃ۔,,,6606,,
6607,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ؛ أَنَّہُ کَانَ یَکْرَہُ النَّفْخَ فِی الصَّلاَۃ۔,,,6607,,
6608,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ إِسْرَائِیلَ ، عَنْ أَبِی حَصِینٍ ؛ أَنَّ أَبَا عَبْدِ الرَّحْمَنِ کَرِہَ النَّفْخَ فِی الصَّلاَۃ۔,,,6608,,
6609,"حَدَّثَنَا وَکِیعٌ ، عَنْ کَہَمْسٍ ، عَنِ ابْنِ بُرَیْدَۃَ ، قَالَ : کَانَ یُقَالُ : مِنَ الْجَفَائِ أَنْ یَنْفُخَ الرَّجُلُ فِی صَلاَتِہِ۔",,,6609,,
6610,"حَدَّثَنَا مُحَمَّدُ بْنُ عُبَیْدٍ ، عَنْ سُفْیَانَ الْعُصْفُرِیِّ ، قَالَ : صَلَّیْتُ فِی حُجْرَۃِ الشَّعْبِیِّ فَنَفَخْتُ ، فَنَہَانِی ، وَقَالَ : إِنْ رَأَیْتَ أَذًی فَامْسَحْہُ بِیَدِک۔",,,6610,,
6611,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی حَمْزَۃَ ، عَنْ أَبِی صَالِحٍ؛ أَنَّ قَرِیبًا لأُمِّ سَلَمَۃَ صَلَّی فَنَفَخَ ، فَقَالَتْ أُمُّ سَلَمَۃَ: لاَ تَفْعَلْ ، فَإِنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ لِغُلاَمٍ لَنَا أَسْوَدَ ، یُقَالُ لَہُ : رَبَاحٌ : تَرِّبْ یَا رَبَاحُ وَجْہَک۔ (ترمذی 382۔ احمد 6/323)",,,6611,,
6612,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ؛ أَنَّہُ کَرِہَ النَّفْخَ فِی الصَّلاَۃ۔,,,6612,,
6613,حَدَّثَنَا شَرِیکٌ ، عَنْ لَیْثٍ ؛ أَنَّہُ رَأَی مُجَاہِدًا یَتَرَوَّحُ فِی الصَّلاَۃ۔,,,6613,,
6614,"حَدَّثَنَا وَکِیعٌ، عَنْ یُونُسَ بْنِ أَبِی إِسْحَاقَ، عَنْ أَبِی السَّفَرِ، قَالَ: أَدْرَکْنَا أَشْیَاخَ الْحَیِّ وَالشَّبَابَ یُرَوِّحُونَہُمْ فِی الصَّلاَۃ۔",,,6614,,
6615,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ عُبَیْدَۃَ ابْنَۃِ نَابِلٍ ، مَوْلاَۃِ عَائِشَۃَ ابْنَۃِ سَعْدٍ ، قَالَتْ : رَأَیْتُ عَائِشَۃَ ابْنَۃَ سَعْدٍ تَنْفُضُ دِرْعَہَا فِی الصَّلاَۃ ۔ أَیْ تُرَوِّحُ بِہِ۔",,,6615,,
6616,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ ہَارُونَ بْنِ إِبْرَاہِیمَ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : لاَ بَأْسَ بِالتَّرَوُّحِ فِی الصَّلاَۃ۔",,,6616,,
6617,حَدَّثَنَا وَکِیعٌ ، عَنِ مُبَارَکٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَرِہَہُ عَبَثًا ، وَلَمْ یَرَ بِہِ فِی شِدَّۃِ الْحَرِّ بَأْسًا۔,,,6617,,
6618,حَدَّثَنَا عَبْدُاللہِ بْنُ مُبَارَکٍ، وَوَکِیعٌ، عَنْ عَبْدِاللہِ بْنِ مُسْلِمِ بْنِ یَسَارٍ، عَنْ أَبِیہِ؛ أَنَّہُ کَرِہَ التَّرَوُّحَ فِی الصَّلاَۃ۔,,,6618,,
6619,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ عَبْدِ الْکَرِیمِ أَبِی أُمَیَّۃَ ، عَنْ عُمَیْرٍ ، قَالَ : تَرَوَّحْتُ بَیْنَ أَبِی الْعَالِیَۃِ وَمُسْلِمِ بْنِ یَسَارٍ ، فَنَہَیَانِی۔",,,6619,,
6620,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الْعَلاَئِ بْنِ الْمُسَیَّبِ ، عَنْ رَجُلٍ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّہُ کَرِہَ التَّرَوُّحَ فِی الصَّلاَۃ۔,,,6620,,
6621,حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، وَسُفْیَانَ ، عَنْ أَبِی حَصِینٍ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ السُّلَمِیِّ؛ أَنَّہُ کَرِہَ التَّرَوُّحَ فِی الصَّلاَۃ۔,,,6621,,
6622,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إِدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنْ مُجَاہِدٍ ، قَالَ : کُنَّا نَغْزُو مَعَ جُنَادَۃَ بْنِ أَبِی أُمَیَّۃَ الْبَحْرَ ، فَکُنَّا نُصَلِّی فِی السَّفِینَۃِ قُعُودًا۔",,,6622,,
6623,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، أَنَّ ابْنَ سِیرِینَ ، قَالَ : خَرَجْتُ مَعَ أَنَسٍ إِلَی بَنِی سِیرِینَ فِی سَفِینَۃٍ عَظِیمَۃٍ۔ قَالَ : فَأَمَّنَا ، فَصَلَّی بِنَا فِیہَا جُلُوسًا رَکْعَتَیْنِ ، ثُمَّ صَلَّی بِنَا رَکْعَتَیْنِ أُخْرَاوَیْنِ۔",,,6623,,
6624,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ ، عَنْ أَبِی قِلاَبَۃَ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا بِالصَّلاَۃ فِی السَّفِینَۃِ جَالِسًا۔,,,6624,,
6625,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی خُزَیْمَۃَ ، عن َطَاوُوسٍ ، قَالَ : صَلِّ فِیہَا قَاعِدًا۔",,,6625,,
6626,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ حُمَیْدٍ ، قَالَ : سُئِلَ أَنَسٌ عَنِ الصَّلاَۃ فِی السَّفِینَۃِ ؟ فَقَالَ عَبْدُ اللہِ بْنُ أَبِی عُتْبَۃَ مَوْلَی أَنَسٍ ، وَہُوَ مَعَنَا جَالِسٌ : سَافَرْتُ مَعَ أَبِی سَعِیدٍ الْخُدْرِیِّ ، وَأَبِی الدَّرْدَائِ ، وَجَابِرِ بْنِ عَبْدِ اللہِ ، قَالَ حُمَیْدُ : وَأُنَاسٍ قَدْ سَمَّاہُمْ ، فَکَانَ إِمَامُنَا یُصَلِّی بِنَا فِی السَّفِینَۃِ قَائِمًا ، وَنُصَلِّی خَلْفَہُ قِیَامًا ، وَلَوْ شِئْنَا لأَرْفَأنَا وَخَرَجْنَا۔",,,6626,,
6627,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ عَبْدِ اللہِ بْنِ مُسْلِمٍ بْنِ یَسَارٍ ، عَنْ أَبِیہِ ؛ أَنَّ أَبَاہُ کَانَ یَنْصِبُ عَلَمًا فِی السَّفِینَۃِ ، یُصَلِّی قَائِمًا ، وَإِنَّہَا لَمَرْفُوعَۃٌ شِرَاعُہَا تَجْرِی۔,,,6627,,
6628,"حَدَّثَنَا حَفْصٌ ، عَنْ عَاصِمٍ ، عَنِ الشَّعْبِیِّ ، وَالْحَسَنِ ، وَابْنِ سِیرِینَ ، قَالُوا : صَلِّ فِی السَّفِینَۃِ قَائِمًا ۔ وَقَالَ الْحَسَنُ : لاَ تَشُقَّ عَلَی أَصْحَابِک۔",,,6628,,
6629,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنِ ابْنِ سِیرِینَ ، أَنَّہُ قَالَ فِی الصَّلاَۃ فِی السَّفِینَۃِ : إِنْ شِئْتَ قَائِمًا ، وَإِنْ شِئْتَ قَاعِدًا ، وَالْقِیَامُ أَفْضَلُ۔",,,6629,,
6630,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، أَنَّہُ قَالَ : یُصَلِّی فِی السَّفِینَۃِ قَائِمًا ، فَإِنْ لَمْ یَسْتَطِعْ فَقَاعِدًا ، وَاسْجُدْ عَلَی قَرَارٍ مِنْہَا۔",,,6630,,
6631,"حَدَّثَنَا وَکِیعٌ ، عَنْ مَالِکِ بْنِ مِغْوَلٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : صَلِّ فِیہَا قَائِمًا۔",,,6631,,
6632,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : صَلِّ فِی السَّفِینَۃِ قَائِمًا۔",,,6632,,
6633,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ مُغِیرَۃَ ، قَالَ : سَأَلْتُ إِبْرَاہِیمَ عَنِ الصَّلاَۃ فِی السَّفِینَۃِ ؟ فَقَالَ : إِنِ اسْتَطَاعَ أَنْ یَخْرُجَ فَلْیَخْرُجْ ، وَإِلاَّ فَلَیُصَلِّ قَائِمًا ، فَإِنِ اسْتَطَاعَ ، وَإِلاَّ فَلْیُصَلِّ قَاعِدًا وَیَسْتَقْبِلَ الْقِبْلَۃَ کُلَّمَا تَحَرَّفَتْ۔",,,6633,,
6634,"حَدَّثَنَا ابْنُ أَبِی غَنِیَّۃَ ، عَنْ أَبِیہِ ، عَنِ الْحَکَمِ ، قَالَ : یُصَلِّی فِیہَا قَائِمًا ، فَإِنْ لَمْ یَسْتَطِعْ فَقَاعِدًا ، وَإِنِ اسْتَطَاعَ أَنْ یَخْرُجَ إِلَی الْجُدِّ فَلْیَخْرُجْ۔",,,6634,,
6635,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا حَسَنُ بْنُ صَالِحٍ ، عَنْ مُطَرِّفٍ ، عَنْ عَامِرٍ ، قَالَ : یَنْصِبُ عَلَمًا فِی السَّفِینَۃِ ثُمَّ یَتَّبِعْہُ۔",,,6635,,
6636,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الْعَلاَئُ بْنُ قَیْسٍ الْکَاہِلِیُّ ، قَالَ : سَأَلْتُ عَطَائً عَنِ الصَّلاَۃ فِی السَّفِینَۃِ ؟ فَقَالَ : لاَ تُصَلُّوا فِیہَا مَا وَجَدْتُمْ جُدًّا۔",,,6636,,
6637,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : یَسْتَقْبِلُ الْقِبْلَۃَ کُلَّمَا تَحَرَّفَتْ۔",,,6637,,
6638,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : یَدُورُونَ مَعَ الْقِبْلَۃِ حَیْثُ دَارَتِ السَّفِینَۃُ۔",,,6638,,
6639,"حَدَّثَنَا ابْنُ أَبِی غَنِیَّۃَ، عَنْ أَبِیہِ، عَنِ الْحَکَمِ ، قَالَ : تَیَمَّمِ الْقِبْلَۃَ حَیْثُ دَارَتِ السَّفِینَۃُ۔",,,6639,,
6640,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الرَّبِیعُ بْنُ صَبِیحٍ ، عَنِ الْحَسَنِ ، وَابْنِ سِیرِینَ ، قَالاَ : یُصَلُّونَ فِیہَا قِیَامًا جَمَاعَۃً ، وَیَدُورُونَ مَعَ الْقِبْلَۃِ حَیْثُ دَارَتْ۔",,,6640,,
6641,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَیُّوبَ أَبِی الْعَلاَئِ ، قَالَ : سَمِعْتُ عَطَائً ، وَسُئِلَ عَنْ مَلاَّحٍ یَکُونُ فِی سَفِینَۃٍ ، وَمَعَہُ فِیہَا أَہْلُہُ ، وَہِیَ مَنْزِلُہُ ، یُسَافِرُ فِیہَا ؟ قَالَ : یُصَلِّی فِیہَا أَرْبَعًا۔",,,6641,,
6642,"حَدَّثَنَا حَفْصٌ ، عَنْ إِسْمَاعِیلَ ، قَالَ : سُئِلَ الْحَسَنُ عَنِ الْمَلاَّحِینَ یَکُونُونَ فِی السَّفِینَۃِ فِی أَہَالِیہمْ ، یُتِمُّونَ الصَّلاَۃ ؟ قَالَ : نَعَمْ ، ہِیَ مَنَازِلُہُمْ۔",,,6642,,
6643,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إِیَاسُ بْنُ دَغْفَلٍ ، قَالَ : سَأَلْتُ عَطَائً عَنِ الصَّلاَۃ فِی السَّفِینَۃِ ؟ فَقَالَ : ہُمْ مُطْمَئِنُّونَ۔",,,6643,,
6644,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَوْشَبِ بْنِ عَقِیلٍ الْعَبْدِیِّ ، قَالَ : سُئِلَ الْحَسَنُ عَنِ الْمَلاَّحِ الْمَجُوسِیِّ یَکُونُ بَیْنَ یَدَیِ الْقَوْمِ فِی السَّفِینَۃِ وَہُمْ یُصَلُّونَ ، وَہُوَ قَائِمٌ ؟ قَالَ : یُصَلَّی خَلْفَہُ ، وَإِنْ کَانَ قَائِمًا۔",,,6644,,
6645,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شَرِیکٌ ، عَنْ مَطَرٍ ، عَنْ عَطَائِ ؛ فِی الْمَلاَّحِینَ الْمَجُوسِیِّینَ یَکُونُونَ بَیْنَ یَدَیِ الْقَوْمِ فِی السَّفِینَۃِ وَہُمْ یُصَلُّونَ ؟ قَالَ : لاَ بَأْسَ بِہِ۔",,,6645,,
6646,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ السُّدِّیِّ ، عَنْ رَجُلٍ ، یُقَالُ لَہُ : یَزِیدُ ، عَنْ عَمَّارِ بْنِ یَاسِرٍ ؛ أَنَّہُ أُغْمِیَ عَلَیْہِ الظُّہْرَ ، وَالْعَصْرَ ، وَالْمَغْرِبَ ، وَالْعِشَائَ ، فَأَفَاقَ فِی بَعْضِ اللَّیْلِ فَقَضَاہُنَّ۔",,,6646,,
6647,"حَدَّثَنَا حَفْصٌ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ : قیلَ لِعِمْرَانَ بْنِ حُصَیْنٍ : إِنَّ سَمُرَۃَ بْنَ جُنْدُبٍ یَقُولُ فِی الْمُغْمَی عَلَیْہِ : یَقْضِی مَعَ کُلِّ صَلاَۃٍ مِثْلَہَا ، فَقَالَ عِمْرَانُ : لَیْسَ کَمَا قَالَ ، یَقْضِیہِنَّ جَمِیعًا۔",,,6647,,
6648,حَدَّثَنَا ہُشَیْمٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، وَأَشْعَثَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ أُغْمِیَ عَلَیْہِ أَیَّامًا ، فَأَعَادَ صَلاَۃَ یَوْمِہِ الَّذِی أَفَاقَ فِیہِ ، وَلَمْ یُعِدْ شَیْئًا مِمَّا مَضَی۔,,,6648,,
6649,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ أَبِی لَیْلَی ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ أُغْمِیَ عَلَیْہِ ، قَالَ وَکِیعٌ : أُرَاہُ قَالَ : شَہْرًا ، فَصَلَّی صَلاَۃَ یَوْمِہِ۔",,,6649,,
6650,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُوسٍ ، وَمُجَاہِدٍ ، أَنَّہُمْ قَالُوا فِی الْمُغْمَی عَلَیْہِ : یَقْضِی صَلاَتَہُ کَمَا یَقْضِی رَمَضَانَ۔",,,6650,,
6651,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : یَقْضِی صَلاَۃَ یَوْمِہِ الَّذِی أَفَاقَ فِیہِ۔",,,6651,,
6652,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إِبْرَاہِیمَ ، قَالَ : سَأَلْتُُہُ عَنِ الْمُغْمَی عَلَیْہِ إِذَا أَفَاقَ ؟ قَالَ : یَقْضِی صَلاَۃَ یَوْمِہِ الَّذِی أَفَاقَ فِیہِ۔",,,6652,,
6653,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یُونُسُ ، عَنِ الْحَسَنِ ، أَنَّہُ کَانَ یَقُولُ : إِذَا أُغْمِیَ عَلَی الرَّجُلِ صَلاَتَیْنِ لَمْ یُعِدْ ، وَإِذَا أُغْمِیَ عَلَیْہِ صَلاَۃٌ وَاحِدَۃٌ أَعَادَہَا۔",,,6653,,
6654,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مَنْصُورٍ ، عَنِ الْحَارِثِ ، عَنْ إِبْرَاہِیمِ ، قَالَ : کَانَ یَقُولُ فِی الْمُغْمَی عَلَیْہِ : إِذَا أُغْمِیَ عَلَیْہِ یَوْمٌ وَلَیْلَۃٌ أَعَادَ ، وَإِذَا کَانَ أَکْثَرَ مِنْ ذَلِکَ لَمْ یُعِدْ۔",,,6654,,
6655,"حَدَّثَنَا ابْنُ أَبِی غَنِیَّۃَ ، عَنْ أَبِیہِ ، عَنِ الْحَکَمِ ، قَالَ : إِذَا أُغْمِیَ عَلَی الرَّجُلِ أَیَّامًا ثُمَّ أَفَاقَ ، قَضَی صَلاَۃَ یَوْمِہِ وَلَیْلَتِہِ۔",,,6655,,
6656,حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ مِجْشَرٍ ؛ أَنَّ مَیْمُونًا کَانَ یَرَی أَنْ یَقْضِیَ الرَّجُلُ الْمُغْمَی عَلَیْہِ الصَّلاَۃ کَمَا یَقْضِی الصَّوْمَ۔,,,6656,,
6657,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یُونُسُ بْنُ عُبَیْدٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : أُغْمِیَ علَیْہِ أَیَّامًا فَلَمْ یُعِدْ شَیْئًا۔",,,6657,,
6658,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا جُوَیْبِرٌ ، عَنِ الضَّحَّاکِ ، قَالَ : أُغْمِیَ عَلَیْہِ صَلَوَاتٌ ، فَقِیلَ لَہُ : إِنَّہُ قَدْ ذَہَبَ مُنْذُ کَذَا وَکَذَا صَلاَۃٌ ، قَالَ : فَقَالَ : لَمْ یَذْہَبْ مِنِّی شَیْئٌ ، وَلَمْ یُعِدْ۔",,,6658,,
6659,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : الْمُغْمَی عَلَیْہِ یَقْضِی الصِّیَامَ ، وَلاَ یَقْضِی الصَّلاَۃ ، کَمَا أَنَّ الْحَائِضَ تَقْضِی الصِّیَامَ وَلاَ تَقْضِی الصَّلاَۃ۔",,,6659,,
6660,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : الْمُغْمَی عَلَیْہِ لاَ یَقْضِی ، اسْتَنَّ بِأُمَّہَاتِ الْمُؤْمِنِینَ ، لَمْ یَکُنْ یَقْضِینَ فِی حَیْضَتِہِنَّ۔",,,6660,,
6661,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : الْمُغْمَی عَلَیْہِ لاَ یَقْضِی ۔ قَالَ : وَأُغْمِیَ عَلَی ابْنِ سِیرِینَ أَیَّامًا فَلَمْ یَقْضِ۔",,,6661,,
6662,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الْعُمَرِیُّ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ أُغْمِیَ عَلَیْہِ یَوْمَیْنِ فَلَمْ یَقْضِ۔",,,6662,,
6663,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ؛ فِی الْمُغْمَی عَلَیْہِ ، قَالَ : لَیْسَ عَلَیْہِ إِعَادَۃٌ۔",,,6663,,
6664,"حَدَّثَنَا وَکِیعٌ ، وَالَّذِی یَأْخُذُ بِہِ النَّاسُ : الَّذِی یُغْمَی عَلَیْہِ أَیَّامًا ، لاَ یَقْضِی إِلاَّ صَلاَۃَ یَوْمِہِ الَّذِی أَفَاقَ فِیہِ مِثْلُ الْحَائِضِ ، وَالَّذِی یُغْمَی عَلَیْہِ یَوْمًا وَاحِدًا یَقْضِی صَلاَۃَ ذَلِکَ الْیَوْمِ۔",,,6664,,
6665,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا یَزِیدُ بْنُ إِبْرَاہِیمَ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : نُـبِّئْتُ أَنَّ مَسْرُوقًا کَانَ یَحْمِلُ مَعَہُ لَبِنَۃً فِی السَّفِینَۃِ ، یَعْنِی یَسْجُدُ عَلَیْہَا۔",,,6665,,
6666,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : حَدَّثَنَا ابْنُ عَوْنٍ ، عَنْ مُحَمَّدٍ ؛ أَنَّ مَسْرُوقًا کَانَ إِذَا سَافَرَ حَمَلَ مَعَہُ فِی السَّفِینَۃِ لَبِنَۃً یَسْجُدُ عَلَیْہَا۔",,,6666,,
6667,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ؛ أَنَّہُ کَانَ یَکْرَہُ أَنْ یَسْجُدَ عَلَی الْخَشَبَتَیْنِ الْمَقْرُونَتَیْنِ فِی السَّفِینَۃِ۔,,,6667,,
6668,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا أَبُو عَامِرٍ الْمُزَنِیُّ ، عَنِ الْحَسَنِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : صَلُّوا مِنَ اللَّیْلِ أَرْبَعًا ، صَلُّوا وَلَوْ رَکْعَتَیْنِ ، مَا مِنْ أَہْلِ بَیْتٍ یُعْرَفُ لَہُمْ صَلاَۃٌ مِنَ اللَّیْلِ إِلاَّ نَادَاہُمْ مُنَادٍ: یَا أَہْلَ الْبَیْتِ : قُومُوا لِصَلاَتِکُمْ۔",,,6668,,
6669,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یُونُسُ ، عَنِ الْحَسَنِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : رَحِمَ اللَّہُ رَجُلاً قَامَ مِنَ اللَّیْلِ فَصَلَّی ، ثُمَّ أَیْقَظَ أَہْلَہُ فَصَلَّوْا ، رَحِمَ اللَّہُ امْرَأَۃً قَامَتْ مِنَ اللَّیْلِ فَصَلَّتْ ، ثُمَّ أَیْقَظَتْ زَوْجَہَا فَصَلَّی۔ (ابوداؤد 1445۔ احمد 2/250)",,,6669,,
6670,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا أَبُو الأَشْہَبِ ، عَنِ الْحَسَنِ ، قَالَ : صَلُّوا مِنَ اللَّیْلِ وَلَوْ قَدْرَ حَلْبِ شَاۃٍ۔",,,6670,,
6671,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنْ مُحَمَّدٍ ؛ أَنَّہُ کَانَ یَسْتَحِبُّ أَنْ لاَ یَتْرُکَ الرَّجُلُ قِیَامَ اللَّیْلِ ، وَلَوْ قَدْرَ حَلْبِ شَاۃٍ۔,,,6671,,
6672,"حَدَّثَنَا عَبْدَۃُ ، عَنْ مِسْعَرٍ ، عَنْ زُبَیْدٍ ، عَنْ مُرَّۃَ ، قَالَ : قَالَ عَبْدُ اللہِ : فَضْلُ صَلاَۃِ اللَّیْلِ عَلَی صَلاَۃِ النَّہَارِ ، کَفَضْلِ صَدَقَۃِ السِّرِّ عَلَی صَدَقَۃِ الْعَلاَنِیَۃِ۔",,,6672,,
6673,"حَدَّثَنَا حَمَّادُ بن خَالِدٍ ، عَنِ الزُّبَیْرِ بْنِ عَبْدِ اللہِ بْنِ رُہَیْمَۃَ ، عَنْ جَدَّتِہِ ، قَالَتْ : کَانَ عُثْمَانُ یَصُومُ الدَّہْرَ ، وَیَقُومُ اللَّیْلَ إِلاَّ ہَجْعَۃً مِنْ أَوَّلِہِ۔",,,6673,,
6674,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ مَنْصُورٍ ، عَنْ أَبِی وَائِلٍ ، عَنْ عَبْدِ اللہِ ، قَالَ : ذُکِرَ عِنْدَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجُلٌ ، فَقِیلَ : یَا رَسُولَ اللہِ ، إِنَّ فُلاَنًا نَامَ اللَّیْلَ حَتَّی أَصْبَحَ ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : ذَاکَ رَجُلٌ بَالَ الشَّیْطَانُ فِی أُذُنِہِ ، أَوْ أُذُنَیْہِ۔ (بخار ی1144۔ مسلم 537)",,,6674,,
6675,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَلِیِّ بْنِ الأَقْمَرِ ، عَنِ الأَغَرِّ أَبِی مُسْلِمٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، وَأَبِی سَعِیدٍ ، قَالاَ : إِذَا أَیْقَظَ الرَّجُلُ امْرَأَتَہُ مِنَ اللَّیْلِ فَصَلَّیَا ، کُتِبَا مِنَ الذَّاکِرِینَ اللَّہَ کَثِیرًا وَالذَّاکِرَاتِ۔",,,6675,,
6676,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مَنْصُورٌ ، عَنِ الْحَسَنِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سُئِلَ : أَیُّ اللَّیْلِ أَفْضَلُ ؟ فَقَالَ : جَوْفُ اللَّیْلِ الأَوْسَطُ۔",,,6676,,
6677,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی حُرَّۃَ ، عَنِ الْحَسَنِ ؛ أَنَّ رَجُلاً سَأَلَ أَبَا ذَرٍّ : أَیُّ اللَّیْلِ أَسْمَعُ ؟ قَالَ : جَوْفُ اللَّیْلِ الأَوْسَطُ ، قَالَ : وَمَنْ یُطِیقُ ذَلِکَ ؟ قَالَ : مَنْ خَافَ أَدْلَجَ۔",,,6677,,
6678,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ سَعِیدِ بْنِ أَبِی بُرْدَۃَ ، عَنْ أَبِیہِ ؛ أَنَّ مُعَاذًا قَالَ لأَبِی مُوسَی : کَیْفَ تَقْرَأُ الْقُرْآنَ ؟ قَالَ : أَتَفَوَّقُہُ تَفَوُّقًا ۔ فَقَالَ لَہُ أَبُو مُوسَی : فَکَیْفَ تَقْرَؤُہُ أَنْتَ ، یَا مُعَاذُ ؟ قَالَ : أَنَامُ أَوَّلَ اللَّیْلِ ، أَتَقَوَّی بِہِ عَلَی آخِرِہِ ، وَإِنِّی لأَرْجُو الأَجْرَ فِی رَقْدَتِی کَمَا أَرْجُوہُ فِی یَقَظَتِی۔ (بخاری 4341۔ مسلم 15)",,,6678,,
6679,"حَدَّثَنَا عَبْدَۃُ ، عَنْ مِسْعَرٍ ، عَنْ عَوْنِ بْنِ عَبْدِ اللہِ ، عَنْ عُبَیْدِ اللہِ بْنِ عَبْدِ اللہِ بْنِ عُتْبَۃَ ، قَالَ : کَانَ عَبْدُ اللہِ إِذَا ہَدَأَتِ الْعُیُونُ قَامَ ، فَسَمِعْتُ لَہُ دَوِیًّا کَدَوِیِّ النَّحْلِ ، حَتَّی یُصْبِحَ۔",,,6679,,
6680,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مُغِیرَۃَ ، عَنْ سَلَمَۃَ بْنِ یَحْیَی بْنِ طَلْحَۃَ ، عَنْ عَمَّتِہِ أُمِّ إِسْحَاقَ بِنْتِ طَلْحَۃَ ، قَالَتْ : کَانَ الْحَسَنُ بْنُ عَلِیٍّ یَأْخُذُ نَصِیبَہُ مِنْ قِیَامِ اللَّیْلِ مِنْ أَوَّلِ اللَّیْلِ ، وَکَانَ الْحُسَیْنُ یَأْخُذُ نَصِیبَہُ مِنْ آخِرِ اللَّیْلِ۔",,,6680,,
6681,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا ابْنُ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : کَانَ ابْنُ عُمَرَ کُلَّمَا اسْتَیْقَظَ مِنَ اللَّیْلِ صَلَّی۔",,,6681,,
6682,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : حَدَّثَنَا أَبُو حُرَّۃَ ، قَالَ : حَدَّثَنَا الْحَسَنُ ، عَنْ سَعْدِ بْنِ ہِشَامٍ ، عَنْ عَائِشَۃَ ، قَالَتْ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إِذَا قَامَ مِنَ اللَّیْلِ یُصَلِّی ، افْتَتَحَ صَلاَتَہُ بِرَکْعَتَیْنِ خَفِیفَتَیْنِ۔ (مسلم 197۔ احمد 6/30)",,,6682,,
6683,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا ہِشَامٌ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : قَالَ أَبُو ہُرَیْرَۃَ : إِذَا قَامَ أَحَدُکُمْ مِنَ اللَّیْلِ، فَلْیَفْتَتِحْ بِرَکْعَتَیْنِ خَفِیفَتَیْنِ۔",,,6683,,
6684,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنْ مُحَمَّدٍ ، قَالَ : مَا رَأَیْتُہُ افْتَتَحَ صَلاَۃَ تَطَوُّعٍ إِلاَّ بِرَکْعَتَیْنِ خَفِیفَتَیْنِ۔",,,6684,,
6685,حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ، عَنْ أَبِی ہُرَیْرَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَفْتَتِحُ صَلاَتَہُ مِنَ اللَّیْلِ بِرَکْعَتَیْنِ خَفِیفَتَیْنِ۔ (مسلم 198۔ ابوداؤد 1317),,,6685,,
6686,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ ، عَنِ ابْنِ عُمَرَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : صَلاَۃُ اللَّیْلِ مَثْنَی مَثْنَی۔ (بخاری 1137۔ مسلم 146)",,,6686,,
6687,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَبْدِ اللہِ بْنِ دِینَارٍ ، عَنِ ابْنِ عُمَرَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : صَلاَۃُ اللَّیْلِ مَثْنَی مَثْنَی۔ (بخاری 990۔ ابوداؤد 1320)",,,6687,,
6688,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا خَالِدٌ ، عَنْ عَبْدِ اللہِ بْنِ شَقِیقٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : صَلاَۃُ اللَّیْلِ مَثْنَی مَثْنَی۔ (مسلم 148۔ احمد 2/58)",,,6688,,
6689,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ مَوْلَی آلِ طَلْحَۃَ ، عَنْ أَبِی سَلَمَۃَ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُسَلِّمُ فِی کُلِّ رَکْعَتَیْنِ مِنْ صَلاَۃِ اللَّیْلِ۔",,,6689,,
6690,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَبِیبِ بْنِ أَبِی عَمْرَۃَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ، قَالَ: فِی کُلِّ رَکْعَتَیْنِ فَصْلٌ۔",,,6690,,
6691,"حَدَّثَنَا وَکِیعٌ ، عَنْ عُمَرَ بْنِ الْوَلِیدِ الشَّنِّیِّ ، عَنْ عِکْرِمَۃَ ، قَالَ : بَیْنَ کُلِّ رَکْعَتَیْنِ تَسْلِیمَۃٌ۔",,,6691,,
6692,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ خَالِدِ بْنِ دِینَارٍ ، عَنْ سَالِمٍ ، أَنَّہُ قَالَ : صَلاَۃُ اللَّیْلِ مَثْنَی مَثْنَی۔",,,6692,,
6693,"حَدَّثَنَا مُحَمَّد بن أَبِی عَدِی ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : صَلاَۃُ اللَّیْلِ مَثْنَی مَثْنَی۔",,,6693,,
6694,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : صَلاَۃُ اللَّیْلِ مَثْنَی مَثْنَی۔",,,6694,,
6695,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ رَجَائٍ ، عَنْ قَبِیصَۃَ بْنِ ذُؤَیْبٍ ، قَالَ : مَرَّ عَلَیَّ أَبُو ہُرَیْرَۃَ وَأَنَا أُصَلِّی ، فَقَالَ : اِفْصِلْ ، فَلَمْ أَدْرِ مَا قَالَ ، فَلَمَّا انْصَرَفْتُ قُلْتُ : مَا أَفْصِلُ ؟ قَالَ : اِفْصِلْ بَیْنَ صَلاَۃِ اللَّیْلِ وَصَلاَۃِ النَّہَارِ۔",,,6695,,
6696,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، قَالَ : سَأَلْتُ إِبْرَاہِیمَ عَن صَلاَۃِ اللَّیْلِ ؟ فَقَالَ : یَکْفِیَک التَّشَہُّدُ فِی کُلِّ رَکْعَتَیْنِ ، إِلاَّ أَنْ تَکُونَ لَکَ حَاجَۃٌ۔",,,6696,,
6697,"حَدَّثَنَا وَکِیعٌ ، وَغُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ یَعْلَی بْنِ عَطَائٍ ، عَنْ عَلِیٍّ الأَزْدِیِّ ، عَنِ ابْنِ عُمَرَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : صَلاَۃُ اللَّیْلِ وَالنَّہَارِ رَکْعَتَانِ رَکْعَتَانِ ۔ إِلاَّ أَنَّ غُنْدَرًا قَالَ : مَثْنَی مَثْنَی۔ (نسائی 472۔ احمد 26)",,,6697,,
6698,حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یُصَلِّی بِالنَّہَارِ أَرْبَعًا أَرْبَعًا۔,,,6698,,
6699,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ یَحْیَی ، أَنَّہُ قَالَ : أَرْبَعٌ أَرْبَعٌ۔",,,6699,,
6700,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ حَجَّاجٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : صَلاَۃُ النَّہَارِ أَرْبَعٌ أَرْبَعٌ ۔ ہَذَا فِی التَّطَوُّعِ۔",,,6700,,
6701,"حَدَّثَنَا مُعْتَمِرٌ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : سَأَلْتُ نَافِعًا عَنِ التَّطَوُّعِ بِالنَّہَارِ ؟ فَقَالَ : أَمَّا أَنَا فَأُصَلِّی أَرْبَعًا ۔ فَذَکَرْتُہُ لِمُحَمَّدٍ ، فَقَالَ: أَلَیْسَ یُصَلِّی رَکْعَتَیْنِ ؟ اِحْفَظْ۔",,,6701,,
6702,"حَدَّثَنَا إِبْرَاہِیمُ بْنُ صَدَقَۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : صَلاَۃُ اللَّیْلِ وَالنَّہَارِ مَثْنَی مَثْنَی۔",,,6702,,
6703,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَنْظَلَۃَ بْنِ عَبْدِ الْکَرِیمِ ، قَالَ : سَأَلْتُ حَمَّادًا عَنْ صَلاَۃِ النَّہَارِ ؟ فَقَالَ : رَکْعَتَانِ رَکْعَتَانِ۔",,,6703,,
6704,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ حَبِیبِ بْنِ أَبِی عَمْرَۃَ ، قَالَ : کَانَ سَعِیدُ بْنُ جُبَیْرٍ یُصَلِّی بِاللَّیْلِ وَالنَّہَارِ مَثْنَی مَثْنَی۔",,,6704,,
6705,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یَعْلَی بْنُ عَطَائٍ ، قَالَ : حَدَّثَنِی جَابِرُ بْنُ یَزِیدَ بْنِ الأَسْوَدِ الْعَامِرِیُّ ، عَنْ أَبِیہِ، قَالَ: شَہِدْتُ مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَجَّتَہُ ، قَالَ : فَصَلَّیْتُ مَعَہُ الْغَدَاۃَ فِی مَسْجِدِ الْخَیْفِ،\n\nفَلَمَّا قَضَی صَلاَتَہُ وَانْحَرَفَ ، إِذَا ہُوَ بِرَجُلَیْنِ فِی آخِرِ الْقَوْمِ لَمْ یُصَلِّیَا مَعَہُ ، قَالَ : فَقَالَ : عَلَیَّ بِہِمَا ، فَأُتِیَ بِہِمَا تَرْعَدُ فَرَائِصُہُمَا ، فَقَالَ : مَا مَنَعَکُمَا أَنْ تُصَلِّیَا مَعَنَا ؟ فَقَالاَ : یَا رَسُولَ اللہِ ، کُنَّا قَدْ صَلَّیْنَا فِی رِحَالِنَا ، قَالَ : فَلاَ تَفْعَلاَ ، إِذَا صَلَّیْتُمَا فِی رِحَالِکُمَا ثُمَّ أَتَیْتُمَا مَسْجِدَ جَمَاعَۃٍ فَصَلِّیَا مَعَہُمْ ، فَإِنَّہُمَا لَکُمَا نَافِلَۃٌ۔",,,6705,,
6706,"حَدَّثَنَا وَکِیعٌ ، عَنْ رَبِیعَۃَ بْنِ عُثْمَانَ ، وَأَبِی الْعُمَیْسِ ، عَنْ عُثْمَانَ بْنِ عَبُیدِ اللہِ بْنِ أَبِی رَافِعٍ ، عَنِ ابْنِ عُمَرَ قَالَ : صَلاَتُہُ الأُولَی۔",,,6706,,
6707,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إِبْرَاہِیمَ ، قَالَ : صَلاَتُہُ الأُولَی ، ہِیَ الْفَرِیضَۃُ ، وَہَذِہِ نَافِلَۃٌ۔",,,6707,,
6708,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا إِسْمَاعِیلُ بْنُ سَالِمٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : سَمِعْتُہُ قَالَ ذَلِکَ أَیْضًا۔",,,6708,,
6709,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یُونُسُ ، عَنِ الْحَکَمِ بْنِ الأَعْرَجِ ، قَالَ : أَتَیْتُ عَلَی ابْنِ عُمَرَ ، وَالنَّاسُ فِی صَلاَۃِ الظُّہْرِ ، فَظَنَنْتُہُ عَلَی غَیْرِ طُہْرٍ ، فَقُلْتُ لَہُ : یَا أَبَا عَبْدِ الرَّحْمَنِ ، آتِیکَ بِطُہْرٍ ؟ قَالَ : إِنِّی عَلَی طَہَارَۃٍ وَقَدْ صَلَّیْت ، فَبِأَیِّہِمَا أَحْتَسِبُ ؟۔ قَالَ یُونُسُ : فَذَکَرْتُ ذَلِکَ لِلْحَسَنِ ، فَقَالَ : یَرْحَمُ اللَّہُ أَبَا عَبْدِ الرَّحْمَنِ ، فَجَعَلَ الأُولَی الْمَکْتُوبَۃَ وَہَذِہِ نَافِلَۃٌ۔",,,6709,,
6710,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ سِمَاکِ بْنِ حَرْبٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا صَلَّی الرَّجُلُ وَحْدَہُ، ثُمَّ صَلَّی فِی جَمَاعَۃٍ ، فَالْفَرِیضَۃُ ہِیَ الأُولَی۔",,,6710,,
6711,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا أَبُو بِشْرٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : لَوْ صَلَّیْتُ فِی مَنْزِلِی ، ثُمَّ أَتَیْتُ مَسْجِدَ جَمَاعَۃٍ ، ثُمَّ أَدْرَکْتُ مَعَہُ رَکْعَۃً وَاحِدَۃً ، کَانَتْ أَحَبَّ إِلَیَّ مِنْ صَلاَتِی الَّتِی صَلَّیْتُ وَحْدِی۔",,,6711,,
6712,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا دَاوُد ، عَنِ ابْنِ الْمُسَیَّبِ ، قَالَ : صَلاَتُہُ الَّتِی صَلَّی فِی الْجَمَاعَۃِ۔",,,6712,,
6713,"حَدَّثَنَا وَکِیعٌ ، عَنْ رَبَاحِ بْنِ أَبِی مَعْرُوفٍ ، عَنْ عَطَائٍ ، قَالَ : إِذَا صَلَّی فِی جَمَاعَۃٍ وَقَدْ کَانَ صَلَّی وَحْدَہُ، فَصَلاَتُہُ الآخِرَۃُ۔",,,6713,,
6714,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مِسْعَرٌ ، عَنْ رَجُلٍ ، عَنِ ابْنِ الْمُسَیَّبِ ، قَالَ : الْفَرِیضَۃُ ہِیَ الْجَمَاعَۃُ فِی الْمَسْأَلَۃِ الأُولَی۔",,,6714,,
6715,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ، عَنْ عَلِیٍّ ، قَالَ: صَلاَتُہُ الأُولَی۔",,,6715,,
6716,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ جَابِرٍ ، عَنْ سَعدِ بْنِ عُبَیْدَۃَ ، عَنْ صِلَۃ بْنِ زُفَرَ ، قَالَ : أَعَدْتُ الصَّلَوَاتِ کُلَّہَا مَعَ حُذَیْفَۃَ ، وَشَفَعَ فِی الْمَغْرِبَ بِرَکْعَۃٍ۔",,,6716,,
6717,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی السَّوْدَائِ النَّہْدِیِّ ، قَالَ : صَلَّیْتُ الْمَغْرِبَ ثُمَّ صَلَّیْتُہَا فِی جَمَاعَۃٍ ، فَلَمَّا سَلَّمَ الإِمَامُ قُمْتُ فَشَفَعْتُ بِرَکْعَۃٍ ، فَسَأَلْتُ عَطَائً ؟ فَقَالَ : أَکِیستَ۔",,,6717,,
6718,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا صَلَّی الْمَغْرِبَ وَحْدَہُ ، ثُمَّ صَلَّی فِی جَمَاعَۃٍ شَفَعَ بِرَکْعَۃٍ۔",,,6718,,
6719,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عَمْرو بْنُ حَسَّانَ الْمُسْلِیُّ ، عَنْ وَبَرَۃَ بْنِ عَبْدِ الرَّحْمَنِ ، قَالَ : صَلَّیْتُ أَنَا ، وَإِبْرَاہِیمُ النَّخَعِیُّ ، وَعَبْدُ الرَّحْمَن بْنُ الأَسْوَدِ الْمَغْرِبَ ، ثُمَّ جِئْنَا إِلَی الْمَسْجِدِ وَہُمْ فِی صَلاَۃِ الْمَغْرِبِ ، فَدَخَلْنَا مَعَہُمْ فَصَلَّیْنَا ، فَلَمَّا سَلَّمَ الإِمَامُ اِرتبکت أَنَا وَعَبْدُ الرَّحْمَن بْنُ الأَسْوَدِ ، وَقَامَ إِبْرَاہِیمُ فَشَفَعَ بِرَکْعَۃٍ۔",,,6719,,
6720,حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ نُعَیْمٍ ، عَنْ صِلَۃ ، عَنْ حُذَیْفَۃَ ؛ أَنَّہُ صَلَّی الظُّہْرَ مَرَّتَیْنِ ، وَالْعَصْرَ مَرَّتَیْنِ ، وَالْمَغْرِبَ مَرَّتَیْنِ ، وَشَفَعَ فِی الْمَغْرِبِ بِرَکْعَۃٍ۔,,,6720,,
6721,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی الضُّحَی ، عَنْ مَسْرُوقٍ ؛ أَنَّہُ سُئِلَ عَنْ رَجُلٍ صَلَّی الْمَغْرِبَ وَحْدَہُ ، ثُمَّ أَعَادَہَا فِی جَمَاعَۃٍ ؟ قَالَ : یُضِیفُ إِلَیْہَا رَکْعَۃً۔",,,6721,,
6722,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : یَشْفَعُ بِرَکْعَۃٍ ، یَعْنِی إِذَا أَعَادَ الْمَغْرِبَ۔",,,6722,,
6723,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : حدَّثَنَا خَصِیْبُ بْنُ زَیدٍ التَّمِیمِیُّ ، قَالَ : حَدَّثَنَا الْحَسَنُ ؛ أَنَّ رَجُلاً دَخَلَ الْمَسْجِدَ وَقَدْ صَلَّی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : أَلاَ رَجُلٌ یَقُومُ إِلَی ہَذَا فَیُصَلِّی مَعَہُ ؟ فَقَامَ أَبُو بَکْرٍ فَصَلَّی مَعَہُ ، وَقَدْ کَانَ صَلَّی تِلْکَ الصَّلاَۃ۔",,,6723,,
6724,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ حُمَیْدٍ ، عَنْ أَنَسٍ ، قَالَ : کَانَ النُّعْمَانُ بْنُ مُقَرِّنٍ عَلَی جُنْدِ أَہْلِ الْکُوفَۃِ ، وَأَبُو مُوسَی الأَشْعَرِیُّ عَلَی جُنْدِ أَہْلِ الْبَصْرَۃِ ، وَکُنْتُ بَیْنَہُمَا ، فَاتَّعَدَا أَنْ یَلْتَقِیَا عِنْدِی غَدْوَۃً ، فَصَلَّی أَحَدُہُمَا صَلاَۃَ الْغَدَاۃِ بِأَصْحَابِہِ ، ثُمَّ جَائَ وَأَنَا أُصَلِّی فَصَلَّی مَعِی۔",,,6724,,
6725,حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ الضَّحَّاکِ بْنِ عُثْمَانَ، عَنْ نَافِعٍ؛ أَنَّ ابْنَ عُمَرَ اشْتَغَلَ بِبِنَائٍ لَہُ فَصَلَّی الظُّہْرَ، ثُمَّ مَرَّ بِمَسْجِدِ بَنِی عَوْفٍ وَہُمْ یُصَلُّونَ فَصَلَّی مَعَہُمْ۔,,,6725,,
6726,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : إِذَا صَلَّی الرَّجُلُ فِی بَیْتِہِ ، ثُمَّ أَدْرَکَ جَمَاعَۃً صَلَّی مَعَہُمْ ، إِلاَّ الْمَغْرِبَ وَالْفَجْرَ۔",,,6726,,
6727,"حَدَّثَنَا حَفْصٌ، عَنْ عَاصِمٍ، عَنْ بَکْرِ بْنِ عَبْدِ اللہِ الْمُزَنِیِّ ، قَالَ: سُئِلَ ابْنُ عَبَّاسٍ عَنْ ثَلاَثَۃٍ صَلُّوا الْعَصْرَ، ثُمَّ مَرُّوا بِمَسْجِدٍ ، فَدَخَلَ أَحَدُہُمْ فَصَلَّی ، وَمَضَی وَاحِدٌ ، وَجَلَسَ وَاحِدٌ عَلَی الْبَابِ ؟ فَقَالَ ابْنُ عَبَّاسٍ: أَمَّا الَّذِی صَلَّی فَزَادَ خَیْرًا إِلَی خَیْرٍ، وَأَمَّا الَّذِی مَضَی فَمَضَی لِحَاجَتِہِ، وَأَمَّا الَّذِی جَلَسَ عَلَی الْبَابِ فَأَخَسُّہُمْ۔",,,6727,,
6728,"حَدَّثَنَا حَفْصٌ ، عَنْ عَاصِمٍ ، قَالَ : خَرَجْتُ مَعَ ابْنِ سِیرِینَ ، وَقَدْ صَلَّی الْجُمُعَۃَ وَالْعَصْرَ ، فَمَرَّ بِمَسْجِدٍ یُصَلَّی فِیہِ الْعَصْرُ ، فَدَخَلَ فَصَلَّی فِیہِ مَعَہُمْ۔",,,6728,,
6729,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّہُ کَانَ یَقُولُ : یُعِیدُ الصَّلاَۃَ کُلَّہَا إِلاَّ الْمَغْرِبَ ، فَإِنْ خَافَ سُلْطَانًا فَلْیُصَلِّ مَعَہُ ، فَإِذَا فَرَغَ فَلْیَشْفَعْ بِرَکْعَۃٍ۔",,,6729,,
6730,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : صَلَّیْتُ الْعَصْرَ فِی أَہْلِی ، ثُمَّ خَرَجْتُ مَعَ ابْنِ الأَسْوَدِ ، فَمَرَرْتُ بِمَسْجِدٍ یُصَلَّی فِیہِ ، فَقَالَ : اُدْخُلْ بِنَا نُصَلِّ ۔ فَقَالَ : إِنِّی قَدْ صَلَّیْتُ ، قَالَ : وَإِنْ کُنْتَ۔",,,6730,,
6731,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ؛ فِی الرَّجُلِ یُصَلِّی الظُّہْرَ ، أَوِ الْعَصْرَ ثُمَّ یُدْرِکْہُمَا فِی جَمَاعَۃٍ ، قَالَ : مَا أُحِبُّ أَنْ یَتَعَرَّضَ لَہَا ، وَإِنْ أُقِیمَتْ وَہُوَ فِی الْمَسْجِدِ فَلْیُصَلِّ۔",,,6731,,
6732,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، قَالَ : صَلَّیْتُ فِی مَنْزِلِی الظُّہْرَ ، ثُمَّ أَتَیْتُ الْمَسْجِدَ وَہُمْ یُصَلُّونَ ، فَسَأَلْتُ سَالِمًا ؟ فَقَالَ : صَلِّ مَعَہُمْ۔",,,6732,,
6733,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عِمْرَانُ بْنُ حُدَیْرٍ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ : تُعَادُ الصَّلاَۃُ کُلُّہَا إِلاَّ الْمَغْرِبَ ، فَإِنَّہَا وِتْرٌ ، فَلاَ تَجْعَلُوہَا شَفْعًا۔",,,6733,,
6734,حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّہُ لَمْ یَکْرَہْ أَنْ تُعَادَ الْعَصْرُ۔,,,6734,,
6735,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، قَالَ : سَأَلْتُ الْحَسَنَ عَنِ الرَّجُلِ یُصَلِّی الْمَکْتُوبَۃَ ، ثُمَّ یَأْتِی الْمَسْجِدَ وَالْقَوْمُ یُصَلُّونَ تِلْکَ الصَّلاَۃ ؟ قَالَ : یُصَلِّی مَعَہُمْ مَا خَلاَ ہَاتَیْنِ الصَّلاَتَیْنِ ؛ الْفَجْرِ وَالْعَصْرِ۔",,,6735,,
6736,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : یُعِیدُ الصَّلاَۃَ کُلَّہَا۔",,,6736,,
6737,حَدَّثَنَا ابْنُ أَبِی غَنِیَّۃَ ، عَنْ أَبِیہِ ، عَنِ الْحَکَمِ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا بِإِعَادَۃِ الصَّلاَۃَ کُلِّہَا إِذَا لَمْ یُصَلِّہِنَّ فِی جَمَاعَۃٍ ، إِلاَّ صَلاَۃَ الْفَجْرِ ، فَإِنَّہُ کَانَ یَکْرَہُ إِعَادَۃَ صَلاَۃِ الْفَجْرِ۔,,,6737,,
6738,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ حُسَیْنٍ الْمُکْتِبِ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ ، قَالَ : أَتَیْتُ عَلَی ابْنِ عُمَرَ وَہُوَ جَالِسٌ عَلَی الْبَلاَطِ ۔ قَالَ : وَنَاسٌ یُصَلُّونَ ، فَقُلْنَا : یَا أَبَا عَبْدَ الرَّحْمَن ، أَلاَ تُصَلِّی؟ فَقَالَ : إِنِّی سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، یَقُولُ : لاَ تُصَلَّی صَلاَۃٌ فِی یَوْمٍ مَرَّتَیْنِ۔ (ابوداؤد 580۔ احمد 19)",,,6738,,
6739,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ عَبْدِ اللہِ بْنِ عُثْمَانَ ، عَنْ مُجَاہِدٍ ، قَالَ : خَرَجْتُ مَعَ ابْنِ عُمَرَ مِنْ دَارِ عَبْدِ اللہِ بْنِ خَالِدٍ ، حَتَّی إِذَا نَظَرْنَا إِلَی بَابِ الْمَسْجِدِ، إِذْ النَّاسُ فِی صَلاَۃِ الْعَصْرِ ، فَلَمْ یَزَلْ وَاقِفًا حَتَّی صَلَّی النَّاسُ، وَقَالَ: إِنِّی صَلَّیْتُ فِی الْبَیْتِ۔",,,6739,,
6740,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، وَمِسْعَرٌ، عَنْ زِیَادِ بْنِ فَیَّاضٍ، عَنْ أَبِی عِیَاضٍ: قَالَ: قَالَ عُمَرُ: لاَ تُعَادُ الصَّلاَۃ۔",,,6740,,
6741,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ شَقِیقٍ ، عَنْ عَبْدِ اللہِ ، قَالَ : جَدَبَ لَنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ السَّمَرَ بَعْدَ صَلاَۃِ الْعَتَمَۃِ۔ (احمد 1/410۔ ابن حبان 2031)",,,6741,,
6742,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ أَبِی حَصِینٍ ، عَنْ أَبِی وَائِلٍ ، عَنْ سَلْمَانَ ، یَعْنِی ابْنَ رَبِیعَۃَ ، قَالَ : قَالَ لِی عُمَرُ : یَا سَلْمَانُ ، إِنِّی أَذُمُّ لَکَ الْحَدِیثَ بَعْدَ صَلاَۃِ الْعَتَمَۃِ۔",,,6742,,
6743,"حَدَّثَنَا عَبْدَۃُ ، عَنِ الأَعْمَشِ ، عَنْ شَقِیقٍ ، عَنْ سَلْمَانَ بْنِ رَبِیعَۃَ ، قَالَ : کَانَ عُمَرُ بْنُ الْخَطَّابِ یَجْدُبُ لَنَا السَّمَرَ بَعْدَ صَلاَۃِ النَّوْمِ۔",,,6743,,
6744,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ سُلَیْمَانَ بْنِ مُسْہِرٍ ، عَنْ خَرَشَۃَ بْنِ الْحُرِّ ، قَالَ : رَأَیْتُ عُمَرَ بْنَ الْخَطَّابِ یَضْرِبُ النَّاسَ عَلَی الْحَدِیثِ بَعْدَ الْعِشَائِ ، وَیَقُولُ : أَسَمَرٌ أَوَّلَ اللَّیْلِ وَنَوْمٌ آخِرَہُ ؟۔",,,6744,,
6745,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ یَحْیَی بْنِ مَیْسَرَۃَ ، قَالَ : حدَّثَنَا الْعَلاَئُ بْنُ بَدْرٍ ، عَمَّنْ سَمِعَ سَلْمَانَ ، یَقُولُ : إِیَّاکُمْ وَسَمَرَ أَوَّلَ اللَّیْلِ ، فَإِنَّہُ مَہْدَنَۃٌ ، أَوْ مُذْہِبَۃٌ لآخِرِہِ ، فَمَنْ فَعَلَ ذَلِکَ فَلْیُصَلِّ رَکْعَتَیْنِ ، قَبْلَ أَنْ یَأْوِیَ إِلَی فِرَاشِہِ۔",,,6745,,
6746,حَدَّثَنَا عَبْدَۃُ ، عَنِ الأَعْمَشِ ، عَنْ خَیْثَمَۃَ ؛ کَانُوا یَسْتَحِبُّونَ إِذَا أَوْتَرَ الرَّجُلُ أَنْ یَنَامَ۔,,,6746,,
6747,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنِ الْقَاسِمِ بْنِ أَبِی أَیُّوبَ ، قَالَ : کُنْتُ أَکُونُ مَعَ سَعِیدِ بْنِ جُبَیْرٍ فَأُصَلِّیَ بَعْدَ الْعِشَائِ أَرْبَعَ رَکَعَاتٍ ، فَأُکَلِّمُہُ فَلاَ یُکَلِّمُنِی حَتَّی یَنَامَ۔",,,6747,,
6748,حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّہُ کَانَ یَکْرَہُ الْکَلاَمَ بَعْدَ الْعِشَائِ۔,,,6748,,
6749,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُغِیرَۃَ ، عَنْ أَبِی وَائِلٍ ، وَإِبْرَاہِیمَ ، قَالاَ : جَائَ رَجُلٌ إِلَی حُذَیْفَۃَ ، فَدَقَّ الْبَابَ فَخَرَجَ إِلَیْہِ حُذَیْفَۃُ ، فَقَالَ : مَا جَائَ بِکَ ؟ فَقَالَ : جِئْت لِلْحَدِیثِ ، فَسَفَقَ حُذَیْفَۃُ الْبَابَ دُونَہُ ، ثُمَّ قَالَ : إِنَّ عُمَرَ جَدَبَ لَنَا السَّمَرَ بَعْدَ صَلاَۃِ الْعِشَائِ۔",,,6749,,
6750,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَوْفٍ ، عَنِ أَبی الْمِنْہَالِ ، عَنْ أَبِی بَرْزَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی عَنِ النَّوْمِ قَبْلَہَا ، وَعَنِ الْحَدِیثِ بَعْدَہَا۔ (بخاری 771۔ ابوداؤد 410),,,6750,,
6751,حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ رَجُلٍ ، عَنْ أَنَسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی عَنِ النَّوْمِ قَبْلَہَا ، وَعَنِ الْحَدِیثِ بَعْدَہَا۔ (احمد 25۔ ابویعلی 4039۔ عبدالرزاق2137),,,6751,,
6752,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، عَنْ عُمَرَ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَسْمُرُ عِنْدَ أَبِی بَکْرٍ اللَّیْلَۃَ کَذَاکَ فِی الأَمْرِ مِنْ أَمْرِ الْمُسْلِمِینَ وَأَنَا مَعَہُ ، وَإِنَّہُ سَمَرَ عِنْدَہُ ذَاتَ لَیْلَۃٍ وَأَنَا مَعَہُ۔",,,6752,,
6753,حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْمِنْہَالِ ، وَالْحَکَمِ ، وَعِیسَی ، وَعَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ؛ أَنَّ أَبَا لَیْلَی سَمَرَ عِنْدَ عَلِیٍّ۔,,,6753,,
6754,حَدَّثَنَا عَبْدُ اللہِ بْنُ إِدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنْ زِیَادٍ أَبِی یَحْیَی ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ وَالْمِسْوَرُ بْنُ مَخْرَمَۃَ سَمَرَا۔,,,6754,,
6755,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُعَاوِیَۃَ بْنِ إِسْحَاقَ الطَّلْحِیِّ ، عَنْ عَائِشَۃَ ابْنَۃِ طَلْحَۃَ ؛ أَنَّ الْحَسَنَ بْنَ عَلِیٍّ سَمَرَ ہُوَ وَرَجُلٌ۔,,,6755,,
6756,"حَدَّثَنَا عَبَّادُ بْنُ عَوَّامٍ ، عَنْ لَیْثٍ ، عَنْ أَبِی بَکْرِ بْنِ أَبِی مُوسَی ؛ أَنَّ أَبَا مُوسَی أَتَی عُمَرَ بْنَ الْخَطَّابِ بَعْدَ الْعِشَائِ ، قَالَ : فَقَالَ لَہُ عُمَرُ بْنُ الْخَطَّابِ : مَا جَائَ بِکَ ؟ قَالَ : جِئْت أَتَحَدَّثُ إِلَیْک ،\n\nقَالَ : ہَذِہِ السَّاعَۃَ ؟ قَالَ : إِنَّہُ فِقْہٌ ، فَجَلَسَ عُمَرُ ، فَتَحَدَّثَا لَیْلاً طَوِیلاً ، حَسِبْتُہُ قَالَ : ثُمَّ إِنَّ أَبَا مُوسَی ، قَالَ : الصَّلاَۃ یَا أَمِیرَ الْمُؤْمِنِینَ ؟ قَالَ : إِنَّا فِی صَلاَۃٍ۔",,,6756,,
6757,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّ حُذَیْفَۃَ ، وَابْنَ مَسْعُودٍ سَمَرَا عِنْدَالْوَلِیدِ بْنِ عُقْبَۃَ۔,,,6757,,
6758,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یَسْمُرُ بَعْدَ الْعِشَائِ حَتَّی تَقُولَ عَائِشَۃُ : قدْ أَصْبَحْتُمْ۔",,,6758,,
6759,"حَدَّثَنَا وَکِیعٌ ، عَنْ عِمْرَانَ بْنِ حُدَیْرٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : سَمَرَ ابْنُ عَبَّاسٍ عِنْدَ مُعَاوِیَۃَ حَتَّی ذَہَبَ ہَزِیعٌ مِنَ اللَّیْلِ۔",,,6759,,
6760,"حَدَّثَنَا وَکِیعٌ ، عَنِ السَّائِبِ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ؛ أَنَّ قَوْمًا مِنْ قُرَیْشٍ کَانُوا یَسْمُرُونَ ، فَتُرْسِلُ إِلَیْہِمْ عَائِشَۃُ : انْقَلِبُوا إِلَی أَہْلِیکُمْ ، فَإِنَّ لَہُمْ فِیکُمْ نَصِیبًا۔",,,6760,,
6761,حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّہُ کَانَ یَتَحَدَّثُ بَعْدَ الْعِشَائِ۔,,,6761,,
6762,"حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : لاَ بَأْسَ بِالسَّمَرِ فِی الْفِقْہِ۔",,,6762,,
6763,حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ؛ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ کَانَ لَہُ سُمَّارٌ۔,,,6763,,
6764,"حَدَّثَنَا أَبُوخَالِدٍ الأَحْمَرِِ، عَنْ یَحْیَی بْنِ سَعِیدٍ، قَالَ: کَانَ الْقَاسِمُ وَأَصْحَابُہُ یَجْلِسُونَ بَعْدَ الْعِشَائِ یَتَحَدَّثُونَ۔",,,6764,,
6765,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حَدَّثَنَا عُبَیْدُ اللہِ بْنُ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : اجْعَلُوا آخِرَ صَلاَتِکُمْ بِاللَّیْلِ وِتْرًا۔ (بخاری 998۔ مسلم 517)",,,6765,,
6766,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عَبْدُ الْحَمِیدِ بْنُ بَہْرَامَ ، عْن شَہْرِ بْنِ حَوْشَبٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : النَّوْمُ عَلَی وِتْرٍ خَیْرٌ۔",,,6766,,
6767,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنِ الْعَوَّامِ ، عَنْ سُلَیْمَانَ بْنِ أَبِی سُلَیْمَانَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : أَوْصَانِی خَلِیلِی صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَنْ لاَ أَنَامَ إِلاَّ عَلَی وِتْرٍ۔ (مسلم 86۔ ابوداؤد 1428)",,,6767,,
6768,"حَدَّثَنَا ابْنُ مُسْہِرٍ، عَنْ لَیْثٍ، عَنْ مُجَاہِدٍ، عَنْ أَبِی ہُرَیْرَۃَ، قَالَ: أَوْصَانِی خَلِیلِی أَنْ لاَ أَنَامَ إِلاَّ عَلَی وِتْرٍ۔ (احمد 497)",,,6768,,
6769,"حَدَّثَنَا ہُشَیْمٌ، قَالَ: أَخْبَرَنَا یَحْیَی بْنُ سَعِیدٍ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ، قَالَ: أَمَّا أَنَا فَإِنِّی أُوتِرُ قَبْلَ أَنْ أَنَامَ۔",,,6769,,
6770,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : کَانَ أَبُو بَکْرٍ یُوتِرُ أَوَّلَ اللَّیْلِ ، وَکَانَ عُمَرُ یُوتِرُ آخِرَ اللَّیْلِ۔",,,6770,,
6771,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ، وَحَفْصٌ، عَنِ الأَعْمَشِ، عَنْ أَبِی سُفْیَانَ، عَنْ جَابِرٍ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: مَنْ خَافَ أَنْ لاَ یَقُومَ آخِرَ اللَّیْلِ فَلْیُوتِرْ أَوَّلہ، وَمَنْ طَمِعَ أَنْ یَقُومَ آخِرَ اللَّیْلِ فَلْیُوتِرْ آخِرَ اللَّیْلِ ، فَإِنَّ صَلاَۃَ آخِرِ اللَّیْلِ مَشْہُودَۃٌ ۔ وَقَالَ أَبُو مُعَاوِیَۃَ : مَحْضُورَۃٌ ، وَذَلِکَ أَفْضَلُ۔(مسلم 162۔ احمد 3/300)",,,6771,,
6772,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ عَبْدِ اللہِ بْنِ مُحَمَّدِ بْنِ عَقِیلٍ ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لأَبِی بَکْرٍ : مَتَی تُوتِرُ ؟ قَالَ : مِنْ أَوَّلِ اللَّیْلِ بَعْدَ الْعَتَمَۃِ ، قَبْلَ أَنْ أَنَامَ، وَقَالَ لِعُمَرَ: مَتَی تُوتِرُ ؟ قَالَ : مِنْ آخِرِ اللَّیْلِ ، قَالَ لأَبِی بَکْرٍ : أَخَذْتَ بِالْحَزْمِ ، وَقَالَ لِعُمَرَ: أَخَذْتَ بِالْقُوَّۃِ۔ (احمد 3/330۔ ابو یعلی 1815)",,,6772,,
6773,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ، عَنِ ابْنِ عُمَرَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : صَلاَۃُ الْمَغْرِبِ وِتْرُ النَّہَارِ۔ (نسائی 1382۔ احمد 2/83)",,,6773,,
6774,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ، عَنْ عَائِشَۃَ ، قَالَتْ : أَوَّلُ مَا فُرِضَتِ الصَّلاَۃ رَکْعَتَیْنِ ، إِلاَّ الْمَغْرِبَ فَإِنَّہَا وِتْرُ النَّہَارِ۔ (احمد 6/241)",,,6774,,
6775,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ حَبِیبٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : صَلاَۃُ اللَّیْلِ عَلَیْہَا وِتْرٌ ، وَصَلاَۃُ النَّہَارِ عَلَیْہَا وِتْرٌ ۔ یَعْنِی الْمَغْرِبَ آخِرَ الصَّلَوَاتِ۔",,,6775,,
6776,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : لاَ أَعْلَمُہُمْ یَخْتَلِفُونَ أَنَّ الْمَغْرِبَ وِتْرُ صَلاَۃِ النَّہَارِ۔",,,6776,,
6777,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنْ مُجَاہِدٍ ، قَالَ : الْمَغْرِبُ وِتْرُ النَّہَارِ۔",,,6777,,
6778,"حَدَّثَنَا مُحَمَّدُ بْنُ عُبَیْدٍ ، عَنْ خَالِدٍ النِّیلِیِّ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : قَالَ : رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : صَلاَۃُ الْمَغْرِبِ وِتْرُ صَلاَۃِ النَّہَارِ ، فَأَوْتِرُوا صَلاَۃَ اللَّیْلِ۔",,,6778,,
6779,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ مَالِکِ بْنِ الْحَارِثِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، قَالَ : قَالَ عَبْدُ اللہِ : الْوِتْرُ ثَلاَثٌ ، کَصَلاَۃِ الْمَغْرِبِ وِتْرُ النَّہَارِ۔",,,6779,,
6780,"حَدَّثَنَا وَکِیعٌ ، قَالَ: حدَّثَنَا عِمْرَانُ بْنُ حُدَیْرٍ، عَنْ أَبِی مِجْلَزٍ؛ أَنَّہُ کَانَ لاَ یُصَلِّی بَعْدَ الْوِتْرِ، إِلاَّ رَکْعَتَیْنِ۔",,,6780,,
6781,حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ أَبِیہِ ، عَنِ الْقَاسِمِ ؛ أَنَّہُ سُئِلَ عَنِ الرَّکْعَتَیْنِ بَعْدَ الْوِتْرِ ؟ فَحَلَفَ بِاللَّہِ إِنَّہُمَا لَبِدْعَۃٌ۔,,,6781,,
6782,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ أَبِیہِ ، قَالَ : سَأَلَ رَجُلٌ مِنْ أَہْلِ الْیَمَنِ عَنْہُمَا عَطَائً ؟ فَقَالَ : أَنْتُمْ تَفْعَلُونَہُمَا ؟۔",,,6782,,
6783,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی جَمْرَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إِنِ اسْتَطَعْتَ أَنْ لاَ تُصَلِّی صَلاَۃً إِلاَّ سَجَدْتَ بَعْدَہَا سَجْدَتَیْنِ ، فَافْعَلْ۔",,,6783,,
6784,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ أَبِی الْعَالِیَۃِ الْبَرَائِ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : رَأَیْتُہُ یَسْجُدُ بَعْدَ وِتْرِہِ سَجْدَتَیْنِ۔",,,6784,,
6785,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عَوْنُ بْنُ صَالِحٍ الْبَارِقِیُّ ، عَنْ عَطِیَّۃَ الْعَوْفِی ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ؛ أَنَّہُ کَرِہَ الصَّلاَۃ بَعْدَ الْوِتْرِ۔",,,6785,,
6786,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی مِجْلَزٍ ، عَنْ قَیْسِ بْنِ عُبَادٍ ، قَالَ : لأَنْ أَقْعُدَ بَعْدَ الْوِتْرِ فَأَقْرَأُ ، أَحَبُّ إِلَیَّ مِنْ صَلاَۃٍ بَعْدَ الْوِتْرِ۔",,,6786,,
6787,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ سُلَیْمَانَ التَّیْمِیِّ ، عَنْ أَبِی مِجْلَزٍ ، عَنْ قَیْسِ بْنِ عُبَادٍ ، قَالَ : إِذَا أَوْتَرْتَ ثُمَّ قُمْتَ ، فَاقْرَأْ وَأَنْتَ جَالِسٌ۔",,,6787,,
6788,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ؛ أَنَّہُ سُئِلَ عَنِ السَّجْدَتَیْنِ بَعْدَ الْوِتْرِ ؟ فَقَالَ : ہَذَا شَیْئٌ قَدْ تُرِکَ۔",,,6788,,
6789,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا سُلَیْمَانُ التَّیْمِیُّ ، عَنْ أَبِی مِجْلَزٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ کَانَ یَقُولُ : إِذَا أَوْتَرَ الرَّجُلُ مِنْ أَوَّلِ اللَّیْلِ ثُمَّ قَامَ مِنْ آخِرِ اللَّیْلِ ، فَلْیَشْفَعْ وَتْرَہُ بِرَکْعَۃٍ ، ثُمَّ لِیُصَلِّ ، ثُمَّ لِیُوتِرْ آخِرَ صَلاَتِہِ۔",,,6789,,
6790,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حُصَیْنٌ ، عَنِ الشَّعْبِیِّ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَفْعَلُ ذَلِکَ۔",,,6790,,
6791,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ: أَخْبَرَنَا الشَّیْبَانِیُّ ، عَنْ أَبِی قَیْسٍ ، عَنْ عَمْرِو بْنِ مَیْمُونٍ؛ أَنَّہُ کَانَ یَقُولُ ذَلِکَ أَیْضًا۔",,,6791,,
6792,"حَدَّثَنَا وَکِیعٌ ، عَنْ عِمْرَانَ بْنِ حُدَیْرٍ ، عَنْ أَبِی مِجْلَزٍ ؛ أَنَّ أُسَامَۃَ بْنَ زَیْدٍ ، وَابْنَ عَبَّاسٍ ، قَالاَ: إِذَا أَوْتَرْتَ مِنْ أَوَّلِ اللَّیْلِ ثُمَّ قُمْتَ تُصَلِّی ، فَصَلِّ مَا بَدَا لَکَ وَاشْفَعْ ، ثُمَّ أَوْتِرْ بِرَکْعَۃٍ۔",,,6792,,
6793,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یُوتِرُ أَوَّلَ اللَّیْلِ ، فَإِذَا قَامَ شَفَعَ۔,,,6793,,
6794,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا سُفْیَانُ، وَشُعْبَۃُ، عَنْ عَبْدِالْمَلِکِ بْنِ عُمَیْرٍ، عَنْ مُوسَی بْنِ طَلْحَۃَ، عَنْ عُثْمَانَ؛ أَنَّہُ کَانَ یَشْفَعُ بِرَکْعَۃٍ ، وَیَقُولُ : مَا أُشَبِّہُہَا إِلاَّ بِالْغَرِیبَۃِ مِنَ الإِبِلِ۔",,,6794,,
6795,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی قَیْسٍ الأَوْدِیِّ عَبْدِ الرَّحْمَنِ بْنِ ثَرَوَانِ ، قَالَ : سَأَلْتُ عَمْرَو بْنَ مَیْمُونٍ عَنِ الرَّجُلِ یُوتِرُ ، ثُمَّ یَسْتَیْقِظُ ؟ قَالَ : یَشْفَعُ بِرَکْعَۃٍ۔",,,6795,,
6796,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ، قَالَ : إِذَا أَوْتَرَ ثُمَّ قَامَ یُصَلِّی ، صَلَّی شَفْعًا شَفْعًا۔",,,6796,,
6797,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ إِبْرَاہِیمَ بْنِ الْمُہَاجِرِ ، عَنْ کُلَیْبٍ الْجَرْمِیِّ ، عَنْ سَعْدٍ ، قَالَ : أَمَّا أَنَا فَإِذَا أَوْتَرْتُ ثُمَّ قُمْتُ ، صَلَّیْتُ رَکْعَتَیْنِ رَکْعَتَیْنِ۔",,,6797,,
6798,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃٌ ، عَنْ قَتَادَۃَ ، عَنْ خِلاَسِ بْنِ عَمْرٍو الْہَجَرِیِّ ، عَنْ عَمَّارٍ ، قَالَ : أَمَّا أَنَا فَأُوتِرُ ، فَإِذَا قُمْتُ صَلَّیْتُ مَثْنَی مَثْنَی ، وَتَرَکْتُ وِتْرِی الأَوَّلَ کَمَا ہُوَ۔",,,6798,,
6799,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی جَمْرَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، وَعَائِذِ بْنِ عَمْرٍو ، قَالاَ : إِذَا أَوْتَرْتَ أَوَّلَ اللَّیْلِ ، فَلاَ تُوتِرْ آخِرَہُ ، وَإِذَا أَوْتَرْتَ آخِرَہُ ، فَلاَ تُوتِرْ أَوَّلَہُ۔",,,6799,,
6800,حَدَّثَنَا حَفْصٌ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ أَبِی بَکْرٍ ؛ أَنَّہُ کَانَ یُوتِرُ أَوَّلَ اللَّیْلِ ، وَکَانَ إِذَا قَامَ یُصَلِّی ، صَلَّی رَکْعَتَیْنِ رَکْعَتَیْنِ ۔ وَکَانَ سَعِیدٌ یَفْعَلُہُ۔,,,6800,,
6801,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ بِشْرِ بْنِ حَرْبٍ أَبِی عَمْرٍو ، قَالَ : سَمِعْتُ رَافِعَ بْنَ خَدِیجٍ ، قَالَ : أَمَّا أَنَا فَأُوتِرُ ، فَإِذَا قُمْتُ صَلَّیْتُ مَثْنَی مَثْنَی ، وَتَرَکْتُ وِتْرِی۔",,,6801,,
6802,"حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : مَنْ أَوْتَرَ أَوَّلَ اللَّیْلِ ثُمَّ قَامَ ، فَلْیُصَلِّ رَکْعَتَیْنِ رَکْعَتَیْنِ۔",,,6802,,
6803,حَدَّثَنَا حَفْصٌ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ؛ مِثْلَہُ۔,,,6803,,
6804,حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ؛ مِثْلَہُ۔,,,6804,,
6805,"حَدَّثَنَا حَفْصٌ، عَنْ حَجَّاجٍ، عَنْ طَلْقِ بْنِ مُعَاوِیَۃَ، عَنْ عَلْقَمَۃَ؛ أَنَّہُ سَأَلَہُ؟ فَقَالَ: یُصَلِّی رَکْعَتَیْنِ رَکْعَتَیْنِ۔",,,6805,,
6806,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ وِقَائٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : یُصَلِّی مَثْنَی مَثْنَی۔",,,6806,,
6807,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ الشَّیْبَانِیِّ ، عَنْ أَبِی قَیْسٍ ، قَالَ : لَقِیتُ عَلْقَمَۃَ فَذَکَرْتُ ذَلِکَ لَہُ ، فَقَالَ : صَلِّ رَکْعَتَیْنِ رَکْعَتَیْنِ۔",,,6807,,
6808,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی قَیْسٍ ، قَالَ : سَأَلْتُ عَلْقَمَۃَ ؟ فَقَالَ : إِذَا أَوْتَرْتَ ثُمَّ قُمْتَ، فَاشْفَعْ بِرَکْعَۃٍ حَتَّی تُصْبِحَ۔",,,6808,,
6809,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إِبْرَاہِیمَ ، عَن عَائِشَۃَ ؛ أَنَّہَا سُئِلَتْ عَنِ الَّذِی یَنْقُضُ وَتْرَہُ ؟ فَقَالَتْ : ہَذَا یَلْعَبُ بِوِتْرِہِ۔",,,6809,,
6810,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا دَاوُدُ ، عَنِ الشَّعْبِیِّ ، قَالَ : سَأَلْتُُہُ عَنِ الَّذِی یَنْقُضُ وِتْرَہُ ؟ فَقَالَ : إِنَّمَا أُمِرْنَا بِالإِبْرَامِ ، وَلَمْ نُؤْمَرْ بِالنَّقْضِ۔",,,6810,,
6811,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : إِذَا أَوْتَرَ ثُمَّ قَامَ وَعَلَیْہِ لَیْلٌ ؟ قَالَ : یُصَلِّی شَفْعًا شَفْعًا۔",,,6811,,
6812,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، قَالَ : إِذَا أَوْتَرَ الرَّجُلُ مِنْ أَوَّلِ اللَّیْلِ ، ثُمَّ بَدَا لَہُ أَنْ یُصَلِّیَ مِنْ آخِرِ اللَّیْلِ ، فَلْیُصَلِّ رَکْعَتَیْنِ رَکْعَتَیْنِ حَتَّی یُصْبِحَ۔",,,6812,,
6813,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ الزُّبَیْرِ بْنِ عَدِیٍّ ، عَنْ إِبْرَاہِیمَ ، قَالَ : سَأَلْتُُہُ عَنِ الرَّجُلِ یُوتِرُ ثُمَّ یَسْتَیْقِظُ ؟ قَالَ : یُصَلِّی مَثْنَی مَثْنَی ، وَکَانُوا یَسْتَحِبُّونَ أَنْ یَکُونَ آخِرُ صَلاَتِہِمْ وِتْرًا۔",,,6813,,
6814,"حَدَّثَنَا مُلاَزِمُ بْنُ عَمْرٍو ، عَنْ عَبْدِ اللہِ بْنِ بَدْرٍ ، عَنْ قَیْسِ بْنِ طَلْقٍ ، عَنْ أَبِیہِ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، یَقُولُ : لاَ وِتْرَانِ فِی لَیْلَۃٍ۔ (ترمذی 470۔ ابوداؤد 1434)",,,6814,,
6815,"حَدَّثَنَا سَلاَّمُ بْنُ سُلَیْمٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ (ح) وَحَدَّثَنَا شَرِیکٌ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُوتِرُ عِنْدَ الأَذَانِ ، وَیُصَلِّی الرَّکْعَتَیْنِ مَعَ الإِقَامَۃِ ۔",,,6815,,
6816,"حَدَّثَنَا سَلاَّمُ بْنُ سُلَیْمٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ (ح) وَحَدَّثَنَا شَرِیکٌ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُوتِرُ عِنْدَ الأَذَانِ ، وَیُصَلِّی الرَّکْعَتَیْنِ مَعَ الإِقَامَۃِ ۔ زَادَ سَلاَّمُ : الأَذَانَ الأَوَّلَ ، قَالَ سَلاَّمُ : وَسَمِعْت أَبَا إِسْحَاقَ مَرَّۃً ، قَالَ : یُوتِرُ عِنْدَ طُلُوعِ الْفَجْرِ۔",,,6816,,
6817,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا خَالِدٌ الْحَذَّائُ ، عَنْ أَبِی قِلاَبَۃَ ، قَالَ : قَالَ أَبُو الدَّرْدَائِ : رُبَّمَا أَوْتَرْتُ وَإِنَّ الإِمَام لَصَافٍ فِی صَلاَۃِ الصُّبْحِ۔",,,6817,,
6818,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، قَالَ : جَائَ رَجُلٌ إِلَی ابْنِ مَسْعُودٍ ، قَالَ : أُوتِرُ وَالْمُؤَذِّنُ یُقِیمُ؟ قَالَ : نَعَمْ ، فَأَوْتِرْ۔",,,6818,,
6819,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عَاصِمٍ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ : کَانَ ابْنُ عَبَّاسٍ یُوتِرُ عِنْدَ الإِقَامَۃِ۔",,,6819,,
6820,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ حُصَیْنٍ ، قَالَ : حدَّثَنَا أَبُو ظَبْیَانَ ، قَالَ : کَانَ عَلِیٌّ یَخْرُجُ إِلَیْنَا وَنَحْنُ نَنْظرُ إِلَی تَبَاشِیرَ الصُّبْحِ ، فَیَقُولُ : الصَّلاَۃُ الصَّلاَۃُ ، نِعْمَ سَاعَۃُ الْوِتْرِ ہَذِہِ ، فَإِذَا طَلَعَ الْفَجْرُ صَلَّی رَکْعَتَیْنِ ، ثُمَّ أُقِیمَتِ الصَّلاَۃ فَصَلَّی۔",,,6820,,
6821,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ أَبِی حَصِینٍ ، عَنْ یَحْیَی بْنِ وَثَّابٍ ، عَنْ مَسْرُوقٍ ، قَالَ : سَأَلْتُ عَائِشَۃَ عَنْ وِتْرِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ فَقَالَتْ: کُلُّ اللَّیْلِ قَدْ أَوْتَرَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ؛ أَوَّلَہُ، وَأَوْسَطَہُ ، فَانْتَہَی وِتْرُہُ حِینَ مَاتَ فِی السَّحَرِ۔ (ترمذی 456۔ احمد 6/129)",,,6821,,
6822,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی الضُّحَی ، عَنْ مَسْرُوقٍ ، عَنْ عَائِشَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ مِثْلَہُ۔ (بخاری 996۔ ابوداؤد 1430),,,6822,,
6823,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَلْقَمَۃَ ، قَالَ : صَلَّیْتُ مَعَ عَبْدِ اللہِ لَیْلَۃً کُلَّہَا ، فَکَانَ یَرْفَعُ صَوْتَہُ یَقْرَأُ قِرَائَۃً یُسْمِعُ أَہْلَ الْمَسْجِدِ ، یُرَتِّلُ ، وَلاَ یَرْجِعُ حَتَّی إِذَا کَانَ قَبْلَ أَنْ یَطْلُعَ الْفَجْرُ بِمِقْدَارِ مَا بَیْنَ أَذَانِ الْمَغْرِبِ إِلَی الاِنْصِرَافِ مِنْہَا أَوْتَرَ۔",,,6823,,
6824,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ جَامِعِ بْنِ شَدَّادٍ ، عَنِ الأَسْوَدِ بْنِ ہِلاَلٍ ، عَنْ عَبْدِ اللہِ ، قَالَ: الْوِتْرُ مَا بَیْنَ الصَّلاَتَیْنِ۔",,,6824,,
6825,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا ابْنُ عَوْنٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : قُلْتُ : أَیُّ سَاعَۃٍ أَحَبُّ إِلَیْک أَنْ أُوتِرَ ؟ قَالَ: إِذَا نعَبَ الْمُؤَذِّنُونَ۔",,,6825,,
6826,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الزُّبَیْرِ بْنِ عَدِیٍّ ، عَنْ إِبْرَاہِیمَ ، قَالَ : سَأَلْتُ عَبِیْدَۃَ عَنِ الرَّجُلِ یَسْتَیْقِظُ عِنْدَ الإِقَامَۃِ ؟ قَالَ : یُوتِرُ۔",,,6826,,
6827,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ بَیَانَ ، عَنْ وَبَرَۃَ ، قَالَ : جَائَ ابْنُ عُمَرَ مَعَ الْفَجْرِ ، فَأَوْتَرَ۔",,,6827,,
6828,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُطَرِّفٌ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ بَعْضِ أَصْحَابِ عَلِیٍّ ، قَالَ : قَالَ عَلِیٌّ : مِنْ کُلِّ اللَّیْلِ قَدْ أَوْتَرَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ مِنْ أَوَّلِہِ ، وَأَوْسَطِہِ ، وَآخِرِہِ ، وَلَکِنْ ثَبَتَ الْوِتْرُ لِرَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِنْ آخِرِ اللَّیْلِ۔ (احمد 78)",,,6828,,
6829,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَاصِمِ بْنِ کُلَیْبٍ ، عَنْ أَبِیہِ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ کَانَ یُوتِرُ إِذَا بَقِیَ مِنَ اللَّیْلِ مِثْلُ مَا ذَہَبَ مِنْہُ إِلَی صَلاَۃِ الْمَغْرِبِ۔,,,6829,,
6830,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ إِبْرَاہِیمَ بْنِ مُحَمَّدِ بْنِ الْمُنْتَشِرِ ، عَنْ أَبِیہِ ، عَنْ عَمْرِو بْنِ شُرَحْبِیلَ ، قَالَ: سُئِلَ عَبْدُ اللہِ عَنِ الْوِتْرِ بَعْدَ الأَذَانِ ؟ فَقَالَ : نَعَمْ ، وَبَعْدَ الإِقَامَۃِ۔",,,6830,,
6831,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْمَاعِیلَ ، عَنْ حَکِیمِ بْنِ جَابِرٍ ؛ أَنَّ أَبَا مَیْسَرَۃَ کَانَ یَؤُمُّ قَوْمَہُ ، فَأَبْطَأَ عَلَیْہِمْ ، فَقَالَ : إِنِّی کُنْتُ أُوتِرُ۔",,,6831,,
6832,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، عَن أَبِی عَبْدِ اللہِ الْجَدَلِیِّ ، عَنْ أَبِی مَسْعُودٍ ، قَالَ: مِنْ کُلِّ اللَّیْلِ قَدْ أَوْتَرَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَسَلَّمَ ؛ مِنْ أَوَّلِہِ ، وَوَسَطِہِ، وَآخِرِہِ ، فَانْتَہَی وِتْرُہُ إِلَی السَّحَرِ۔ (احمد 5/272۔ طبرانی 681)",,,6832,,
6833,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ أَبِی نَضْرَۃَ ، عَنْ أَبِی سَعِیدٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أَنَّہُ قَالَ : أَوْتِرُوا قَبْلَ أَنْ تُصْبِحُوا۔ (مسلم 519۔ احمد 3/37)",,,6833,,
6834,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ ابْنِ عَوْنٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانُوا یُحِبُّونَ أَنْ یُوتِرُوا مِنْ آخِرِ اللَّیْلِ۔",,,6834,,
6835,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : الْوِتْرُ بِلَیْلٍ ، وَالسُّحُورُ بِلَیْلٍ۔",,,6835,,
6836,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إِبْرَاہِیمَ ، قَالَ : الْوِتْرُ مِنْ أَوَّلِ اللَّیْلِ حَسَنٌ ،وَأَفْضَلُہُ آخِرُہُ۔",,,6836,,
6837,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ (ح) وَمُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ (ح) وَعَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالُوا : الْوِتْرُ بِاللَّیْلِ۔",,,6837,,
6838,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یُونُسُ ، عَنِ الْحَسَنِ ، قَالَ : قَالَ عُمَرُ بْنُ الْخَطَّابِ : لأَنْ أُوتِرَ بِلَیْلٍ أَحَبُّ إِلَیَّ مِنْ أَنْ أُحْیِیَ لَیْلَتِی ، ثُمَّ أُوتِرُ بَعْدَ مَا أُصْبِحُ۔",,,6838,,
6839,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ صَالِحٍ ، عَنْ أَبِی حَبِیبٍ ، قَالَ : قُلْتُ لإِبْرَاہِیمَ : أَیُّ سَاعَۃٍ ، قَالَ عَلِیٌّ : نِعْمَ سَاعَۃِ الْوِتْرِ ہَذِہِ ، قَالَ : بِغَلَسٍ قَبْلَ الْفَجْرِ۔",,,6839,,
6840,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی ہَارُونَ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ، قَالَ : نَادَی مُنَادِی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَنْ لاَ وِتْرَ بَعْدَ طُلُوعِ الْفَجْرِ۔",,,6840,,
6841,حَدَّثَنَا مُعْتَمِرٌ ، عَنْ أَبِی ہَارُونَ ، عَنْ أَبِی سَعِیدٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ بِنَحْوِہِ۔,,,6841,,
6842,"حَدَّثَنَا ہُشَیْمٌ، قَالَ: أَخْبَرَنَا یُونُسُ، وَمَنْصُورٌ، عَنِ الْحَسَنِ، قَالَ: إِذَا صَلَّیْتَ الْغَدَاۃَ وَطَلَعَتِ الشَّمْسُ، فَقَدْ ذَہَبَ الْوِتْرُ۔",,,6842,,
6843,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إِبْرَاہِیمَ (ح) وَعَبْدُ الْمَلِکِ ، عَنْ عَطَائٍ ؛ أَنَّہُمَا قَالاَ : إِذَا صَلَّیْتَ الْغَدَاۃَ وَطَلَعَتِ الشَّمْسُ فَلاَ وِتْرَ۔",,,6843,,
6844,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : لاَ وِتْرَ بَعْدَ الْغَدَاۃِ۔",,,6844,,
6845,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ مُطَرِّفٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : مَنْ صَلَّی الْغَدَاۃَ وَلَمْ یُوتِرْ ، فَلاَ وَتْرَ عَلَیْہِ۔",,,6845,,
6846,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ، قَالَ : مَنْ أَصْبَحَ وَلَمْ یُوتِرْ ، فَلاَ وَتْرَ عَلَیْہِ۔",,,6846,,
6847,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : إِذَا طَلَعَ الْفَجْرُ فَلاَ تُوتِرُ ، کَیْفَ تَجْعَلُ صَلاَۃَ اللَّیْلِ فِی صَلاَۃِ النَّہَارِ ؟۔",,,6847,,
6848,"حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ یَزِیدَ بْنِ عَبْدِ الرَّحْمَنِ ، عَنِ الْحَکَمِ ، قَالَ : رُبَّمَا قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِیَدِہِ ہَکَذَا ؛ وَمَسَحَ لِحْیَتَہُ بِیَدِہِ فِی الصَّلاَۃ۔",,,6848,,
6849,"حَدَّثَنَا جَرِیرٌ، عَنْ مَنْصُورٍ، عَنْ مُجَاہِدٍ، قَالَ: کَانَ یُقَالُ: لِیَمَسَّ الرَّجُلُ لِحْیَتَہُ مَرَّۃً فِی الصَّلاَۃ، أَوْ لِیَدَعْ۔",,,6849,,
6850,"حَدَّثَنَا أَبُو بَحْرٍ الْبَکْرَاوِیُّ ، عَنْ یُونُسَ ، قَالَ : رَأَیْتُ سَعِیدَ بْنَ جُبَیْرٍ یَمَسُّ لِحْیَتَہُ وَہُوَ یُصَلِّی۔",,,6850,,
6851,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ مُخْتَارِ بْنِ سَعْدٍ ، قَالَ : رَأَیْتُ الْقَاسِمَ بْنَ مُحَمَّدٍ یَوْمًا وَہُوَ یُصَلِّی ، قَبَضَ عَلَی لِحْیَتِہِ۔",,,6851,,
6852,"حَدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : قُلْتُ لَہُ : رَأَیْتَ مُحَمَّدَ بْنَ سِیرِینَ یَمَسَّ لِحْیَتَہُ وَہُوَ فِی الصَّلاَۃ ؟ قَالَ: مَا أَکْثَرَ مَا رَأَیْتُہُ یَمَسَّ لِحْیَتَہُ فِی الصَّلاَۃ۔",,,6852,,
6853,حَدَّثَنَا ہُشَیْمٌ ، عَنْ حُصَیْنٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ عَمْرِو بْنِ حُوَیْرِثٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ رُبَّمَا مَسَّ لِحْیَتَہُ وَہُوَ یُصَلِّی۔ (ابوداؤد 48۔ عبدالرزاق 3317),,,6853,,
6854,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ مَعْمَرٍ ، عَنْ رَجُلٍ ، قَالَ : رَأَی سَعِیدُ بْنُ الْمُسَیَّبِ رَجُلاً وَہُوَ یَعْبَثُ بِلِحْیَتِہِ فِی الصَّلاَۃ ، فَقَالَ : لَوْ خَشَعَ قَلْبُ ہَذَا لَخَشَعَتْ جَوَارِحُہُ۔",,,6854,,
6855,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ أَبِی جَعْفَرٍ ، عَنْ سَعِیدٍ الزُّبَیْدِیِّ ، قَالَ : سَمِعْتُ إِبْرَاہِیمَ یَقُولُ : مَنْ أَنَّ فِی صَلاَتِہِ ، فَقَدْ فَسَدَتْ عَلَیْہِ صَلاَتُہُ۔",,,6855,,
6856,حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّہُ کَرِہَ التَّأَوُّہَ فِی الصَّلاَۃ۔,,,6856,,
6857,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ ابْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ؛ أَنَّہُ کَانَ یَکْرَہُ الزَّفِرَ فِی الصَّلاَۃ ، وَقَالَ : یُشَبَّہُ بِالْکَلاَمِ۔",,,6857,,
6858,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ ابْنِ عَوْنٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : لاَ تَدَعْ وِتْرَک وَلَوْ بِنِصْفِ النَّہَارِ۔",,,6858,,
6859,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ لَیْثٍ ، عَنِ الشَّعْبِیِّ ، وَعَطَائٍ ، وَالْحَسَنِ ، وَطَاوُوسٍ ، وَمُجَاہِدٍ ، قَالُوا : لاَ تَدَعِ الْوِتْرَ ، وَإِنْ طَلَعَتِ الشَّمْسُ۔",,,6859,,
6860,"حَدَّثَنَا أَبُو بَکْرٍ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُوسٍ ، أَنَّہُمَا قَالاَ : مَنْ لَمْ یُوتِرْ حَتَّی تَطْلُعَ الشَّمْسُ فَلْیُوتِرْ۔",,,6860,,
6861,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ وَبَرَۃَ ، قَالَ : سَأَلْتُ ابْنَ عُمَرَ عَنْ رَجُلٍ أَصْبَحَ ، وَلَمْ یُوتِرْ ؟ قَالَ : أَرَأَیْتَ لَوْ نِمْتَ عَنِ الْفَجْرِ حَتَّی تَطْلُعَ الشَّمْسُ ، أَلَیْسَ کُنْتَ تُصَلِّی ؟ ۔ کَأَنَّہُ یَقُولُ : یُوتِرُ۔",,,6861,,
6862,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبَّادِ بْنِ مَنْصُورٍ ، قَالَ : سَمِعْتُ سَعِیدَ بْنِ جُبَیْرٍ ، وَسُئِلَ عَنْ رَجُلٍ نَامَ عَنِ الْوِتْرِ حَتَّی أَصْبَحَ ؟ فَقَالَ : یُوتِرُ مِنَ الْقَابِلَۃِ وِتْرَیْنِ۔",,,6862,,
6863,"حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنْ مَالِکٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، قَالَ : أَوْتَرَ أَبِی وَقَدْ طَلَعَ الْفَجْرُ۔",,,6863,,
6864,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : قُلْتُ لَہُ : الرَّجُلُ یَنَامُ فَیُصْبِحُ ، یُوتِرُ بَعْدَ مَا یُصْبِحُ بِرَکْعَۃٍ ؟ قَالَ : لاَ أَعْلَمُ بِہِ بَأْسًا۔",,,6864,,
6865,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ حَمَّادًا عَنْ رَجُلٍ لَمْ یُوتِرْ حَتَّی طَلَعَتِ الشَّمْسُ ؟ فَقَالَ : أَحَبُّ إِلَیَّ أَنْ یُوتِرَ۔وَسَأَلْت الْحَکَمَ ؟ فَقَالَ : إِنْ شَائَ لَمْ یُوتِرْ۔",,,6865,,
6866,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إِدْرِیسَ ، عَنْ خَالِدِ بْنِ أَبِی کَرِیمَۃَ ، عَنْ مُعَاوِیَۃَ بْنِ قُرَّۃَ ، قَالَ : جَائَ رَجُلٌ إِلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : یَا رَسُولَ اللہِ ، إِنِّی أَصْبَحْتُ وَلَمْ أُوتِرْ ؟ فَقَالَ : إِنَّمَا الْوِتْرُ بِاللَّیْلِ ، ثُمَّ قَالَ : یَا رَسُولَ اللہِ ، إِنِّی أَصْبَحْتُ وَلَمْ أُوتِرْ ؟ فَقَالَ : إِنَّمَا الْوِتْرُ بِاللَّیْلِ ، ثُمَّ قَالَ : إِنِّی أَصْبَحْتَ وَلَمْ أُوتِرْ ؟ قَالَ فِی الثَّالِثَۃِ ، أَوِ الرَّابِعَۃِ : فَأَوْتِرْ۔ (عبدالرزاق 4607)",,,6866,,
6867,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یُونُسُ ، عَنِ الْحَسَنِ (ح) وَمُغِیرَۃُ ، عَنْ إِبْرَاہِیمَ (ح) وَعَبْدُ الْمَلِکِ ، عَنْ عَطَائٍ ، أَنَّہُمْ قَالُوا : إِنْ لَمْ تَفْعَلْ وَطَلَعَ الْفَجْرُ ، فَأَوْتِرْ ، مَا لَمْ تُصَلِّ الْغَدَاۃَ۔",,,6867,,
6868,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَلِیِّ بْنِ الأَقْمَرِ ، عَنْ أَبِی الضُّحَی ، عَنْ مَسْرُوقٍ ، قَالَ : یُوتِرُ وَإِنْ أَدْرَکَتْہُ صَلاَۃُ الصُّبْحِ۔",,,6868,,
6869,"حَدَّثَنَا وَکِیعٌ ، عَنْ نُعَیْمِ بْنِ حَکِیمٍ ، عَنْ أَبِی مَرْیَمَ ، قَالَ : جَائَ رَجُلٌ إِلَی عَلِیٍّ ، فَقَالَ : إِنِّی نِمْتُ وَنَسِیتُ الْوِتْرَ حَتَّی طَلَعَتِ الشَّمْسُ ؟ فَقَالَ : إِذَا اسْتَیْقَظْتَ وَذَکَرْتَ ، فَصَلِّ۔",,,6869,,
6870,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ ، عَنْ أَبِیہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : صَلاَۃُ اللَّیْلِ مَثْنَی مَثْنَی ، فَإِذَا خَشِیتَ الصُّبْحَ فَأَوْتِرْ بِرَکْعَۃٍ۔",,,6870,,
6871,"حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ ، قَالَ : حدَّثَنَا ابْنُ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، عَنْ عُرْوَۃَ ، عَنْ عَائِشَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُوتِرُ بِرَکْعَۃٍ ، وَکَانَ یَتَکَلَّمُ بَیْنَ الرَّکْعَتَیْنِ وَالرَّکْعَۃِ ۔ (ابوداؤد 1330۔ احمد 6/74)",,,6871,,
6872,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا خَالِدٌ ، عَنْ عَبْدِ اللہِ بْنِ شَقِیقٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : صَلاَۃُ اللَّیْلِ مَثْنَی مَثْنَی ، وَالْوِتْرُ وَاحِدَۃٌ ، وَسَجْدَتَانِ قَبْلَ صَلاَۃِ الصُّبْحِ۔",,,6872,,
6873,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یَحْیَی بْنُ سَعِیدٍ ، وَابْنُ عَوْنٍ ، وَغَیْرُہُمَا ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ رَجُلاً سَأَلَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ صَلاَۃِ اللَّیْلِ ؟ قَالَ : مَثْنَی مَثْنَی ، فَإِذَا حَسِسْتَ الصُّبْحَ ، أَوْ خَشِیتَ الصُّبْحَ ، فَصَلِّ لَکَ رَکْعَۃً ، تُوتِرُ لَکَ صَلاَتَک۔ (بخاری990۔ مسلم 145)",,,6873,,
6874,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ: أَخْبَرَنَا مَنْصُورٌ، عَنْ بَکْرِ بْنِ عَبْدِ اللہِ الْمُزَنِیِّ؛ أَنَّ ابْنَ عُمَرَ صَلَّی رَکْعَتَیْنِ ثُمَّ سَلَّمَ، ثُمَّ قَالَ: أَدْخِلُوا إِلَیَّ نَاقَتِی فُلاَنَۃً ، ثُمَّ قَامَ فَأَوْتَرَ بِرَکْعَۃٍ۔",,,6874,,
6875,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا أَبُو بِشْرٍ ، عَنِ ابْنِ شَقِیقٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : صَلاَۃُ اللَّیْلِ مَثْنَی مَثْنَی ، وَالْوِتْرُ وَاحِدَۃٌ۔",,,6875,,
6876,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حُصَیْنٌ ، عَنْ مُصْعَبِ بْنِ سَعْدٍ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یُوتِرُ بِرَکْعَۃٍ ، قَالَ : فَقِیلَ لَہُ ؟ فَقَالَ : إِنَّمَا اسْتَقْصَرْتُہَا۔",,,6876,,
6877,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا الْحَجَّاجُ ، عَنْ عَطَائٍ ؛ أَنَّ مُعَاوِیَۃَ أَوْتَرَ بِرَکْعَۃٍ ، فَأُنْکِرَ ذَلِکَ عَلَیْہِ ، فَسُئِلَ ابْنُ عَبَّاسٍ ؟ فَقَالَ : أَصَابَ السُّنَّۃَ۔",,,6877,,
6878,"حَدَّثَنَا إِسْمَاعِیلُ بْنُ إِبْرَاہِیمَ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : سَمَرَ ابْنُ مَسْعُودٍ ،وَحُذَیْفَۃُ عِنْدَ الْوَلِیدِ بْنِ عُقْبَۃَ ، ثُمَّ خَرَجَا فَتَقَاوَمَا ، فَلَمَّا أَصْبَحَا رَکَعَ کُلُّ وَاحِدٍ مِنْہُمَا رَکْعَۃً۔",,,6878,,
6879,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، قَالَ : سَأَلْتُ عَطَائً ، أُوتِرُ بِرَکْعَۃٍ ؟ فَقَالَ : نَعَمْ ، إِنْ شِئْتَ۔",,,6879,,
6880,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ، قَالَ : کَانَ آلُ سَعْدٍ ، وَآلُ عَبْدِ اللہِ بْنِ عُمَرَ یُسَلِّمُونَ فِی رَکْعَتَیِ الْوِتْرِ ، وَیُوتِرُونَ بِرَکْعَۃٍ۔",,,6880,,
6881,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَانَ الْحَسَنُ یُسَلِّمُ فِی رَکْعَتَیِ الْوِتْرِ۔",,,6881,,
6882,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ عَجْلاَنِ ، عَنْ سَعِیدٍ ، وَنَافِعٍ ، قَالَ : رَأَیْنَا مُعَاذًا الْقَارِیئَ یُسَلِّمُ فِی رَکْعَتَیِ الْوِتْرِ۔",,,6882,,
6883,حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ لَیْثٍ ؛ أَنَّ أَبَا بَکْرٍ أَوْتَرَ بِرَکْعَۃٍ۔,,,6883,,
6884,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : حدَّثَنَا مَنْصُورٌ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : قَالَتْ نَائِلَۃُ ابْنَۃُ فُرَافِصَۃَ الْکَلْبِیَّۃُ : إِنْ تقْتُلُوہُ، أَوْ تَدَعُوہُ فَقَدْ کَانَ یُحْیِی اللَّیْلَ بِرَکْعَۃٍ یَجْمَعُ فِیہَا الْقُرْآنَ ، تَعْنِی یُوتِرُ بِہَا ، تَعْنِی عُثْمَانَ رَضِیَ اللَّہُ عَنْہُ۔",,,6884,,
6885,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنْ عُمَارَۃَ بْنِ عُمَیْرٍ ، عَنْ یَحْیَی بْنِ الْجَزَّارِ ، عَنْ عَائِشَۃَ ، قَالَت : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُوتِرُ بِتِسْعٍ ، فَلَمَّا أَسَنَّ وَثَقُلَ أَوْتَرَ بِسَبْعٍ۔ (ابوداؤد 1343۔ احمد 6/32)",,,6885,,
6886,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ یَحْیَی بْنِ الْجَزَّارِ ، عَنْ أُمِّ سَلَمَۃَ ، قَالَتْ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُوتِرُ بِثَلاَثَ عَشَرَۃَ ، فَلَمَّا کَبِرَ وَضَعُفَ ، أَوْتَرَ بِسَبْعٍ۔ (ترمذی 457۔ احمد 322)",,,6886,,
6887,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ أَبِی بِشْرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ (ح) قَالَ ہُشَیْمٌ : وَأَخْبَرَنَا مَنْصُورٌ ، عَنِ الْحَسَنِ ، قَالاَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُوتِرُ بِتِسْعِ رَکَعَاتٍ ، فَلَمَّا أَسَنَّ وَبَدُنَ ، أَوْتَرَ بِسَبْعٍ، وَرَکْعَتَیْنِ وَہُوَ جَالِسٌ۔",,,6887,,
6888,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ أَبِی بِشْرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ (ح) قَالَ ہُشَیْمٌ : وَأَخْبَرَنَا مَنْصُورٌ ، عَنِ الْحَسَنِ ، قَالاَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُوتِرُ بِتِسْعِ رَکَعَاتٍ ، فَلَمَّا أَسَنَّ وَبَدُنَ ، أَوْتَرَ بِسَبْعٍ، وَرَکْعَتَیْنِ وَہُوَ جَالِسٌ۔",,,6888,,
6889,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَن الأَعْمَش ، عَنْ مَالِکِ بْنِ الْحَارِثِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، قَالَ : قَالَ عَبْدُ اللہِ : الْوِتْرُ ثَلاَثُ رَکَعَاتٍ کَصَلاَۃِ الْمَغْرِبِ۔",,,6889,,
6890,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : ذَکَرْتُ لِسَعِیدِ بْنِ جُبَیْرٍ قَوْلَ عَبْدِ اللہِ ، الْوِتْرُ بِسَبْعٍ ، أَوْ بِخَمْسٍ ، وَلاَ أَقَلَّ مِنْ ثَلاَثٍ ، فَقَالَ سَعِیدٌ : قَالَ ابْنُ عَبَّاسٍ : إِنِّی لأَکْرَہُ أَنْ یَکُونَ ثَلاَثًا بُتْرًا ، وَلَکِنْ سَبْعًا ، أَوْ خَمْسًا۔",,,6890,,
6891,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ ابْنِ جُرَیج ، عَنْ إِسْمَاعِیلَ بْنِ مُحَمَّدِ بْنِ سَعدٍ ، عَنِ ابْنِ السَّبَّاقِ ؛ أَنَّ عُمَرَ دَفَنَ أَبَا بَکْرٍ لَیْلاً ، ثُمَّ دَخَلَ الْمَسْجِدَ فَأَوْتَرَ بِثَلاَثٍ۔,,,6891,,
6892,"حَدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنْ عُثْمَانَ بْنِ حَکِیمٍ ، عَنْ إِسْمَاعِیلَ بْنِ زَیْدٍ ، قَالَ : کَانَ زَیْدُ بْنُ ثَابِتٍ یُوتِرُ بِخَمْسِ رَکَعَاتٍ ، لاَ یَنْصَرِفُ فِیہَا۔",,,6892,,
6893,حَدَّثَنَا ہُشَیْمٌ ، عَنْ حُمَیْدٍ ، عَنْ أَنَسٍ ؛ أَنَّہُ کَانَ یُوتِرُ بِثَلاَثِ رَکَعَاتٍ۔,,,6893,,
6894,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ: أَخْبَرَنَا عَبْدُالرَّحْمَنِ بْنُ إِسْحَاقٍ ، عَنْ عَبْدِالْمَلِکِ بْنِ عُمَیْرٍ ، قَالَ: کَانَ ابْنُ مَسْعُودٍ یُوتِرُ بِثَلاَثٍ۔",,,6894,,
6895,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا عَبْدُ الْمَلِکِ بْنُ أَبِی سُلَیْمَانَ ، عَنْ أَبِی عَبْدِ الرَّحِیمِ ، عَنْ زَاذَانَ أَبِی عُمَرَ ؛ أَنَّ عَلِیًّا کَانَ یَفْعَلُ ذَلِکَ۔",,,6895,,
6896,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُلَیْمَانَ بْنِ حَیَّانَ ، عَنْ أَبِی غَالِبٍ ، قَالَ : کَانَ أَبُو أُمَامَۃَ یُوتِرُ بِثَلاَثِ رَکَعَاتٍ۔",,,6896,,
6897,حَدَّثَنَا عَبْدَۃُ بن سُلَیمَان ، عَنْ عُثْمَانَ بْنِ حَکِیمٍ ، عَنْ عُثْمَانَ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یُوتِرُ بِخَمْسٍ ، لاَ یَنْصَرِفُ فِیہَا۔,,,6897,,
6898,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنِ الْعَلاَئِ بْنِ الْمُسَیَّبِ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، قَالَتْ : لاَ تُوتَرُ بِثَلاَثٍ بُتْرٍ ، صَلِّ قَبْلَہَا رَکْعَتَیْنِ ، أَوْ أَرْبَعًا۔",,,6898,,
6899,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُثْمَانَ بْنِ غِیَاثٍ ، قَالَ : سَمِعْتُ جَابِرَ بْنَ زَیْدٍ ، یَقُولُ : الْوِتْرُ ثَلاَثٌ۔",,,6899,,
6900,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ طَلْقِ بْنِ مُعَاوِیَۃَ ، عَنْ عَلْقَمَۃَ ، قَالَ : الْوِتْرُ ثَلاَثٌ۔",,,6900,,
6901,حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ مَکْحُولٍ ، عَنْ عُمَرَ بْنِ الْخَطَّابِ ؛ أَنَّہُ أَوْتَرَ بِثَلاَثِ رَکَعَاتٍ، لَمْ یَفْصِلْ بَیْنَہُنَّ بِسَلاَمٍ۔,,,6901,,
6902,"حَدَّثَنَا ہُشَیْمٌ، عَنِ الْعَوَّامِ، قَالَ: حُدِّثْنَا عَنْ إِبْرَاہِیمَ التَّیْمِیِّ، قَالَ: کَانُوا یَکْرَہُونَ أَنْ یُشَبِّہُوا الْوِتْرَ بِالْمَغْرِبِ۔",,,6902,,
6903,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانُوا یُوتِرُونَ بِإِحْدَی عَشْرَۃَ ، وَبِتِسْعٍ ، وَبِسَبْعٍ ، وَبِخَمْسٍ ، وَکَانَ یُقَالُ : لاَ وِتْرَ بِأَقَلَّ مِنْ ثَلاَثٍ۔",,,6903,,
6904,"حَدَّثَنَا حَفْصٌ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ، قَالَ : أَجْمَعَ الْمُسْلِمُونَ عَلَی أَنَّ الْوِتْرَ ثَلاَثٌ ، لاَ یُسَلِّمُ إِلاَّ فِی آخِرِہِنَّ۔",,,6904,,
6905,حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ إِسْمَاعِیلَ بْنِ عَبْدِ الْمَلِکِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ أَنَّہُ کَانَ یُوتِرُ بِثَلاَثٍ ، وَیَقْنُتُ فِی الْوِتْرِ قَبْلَ الرُّکُوعِ۔,,,6905,,
6906,حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ الْغَازِ ، عَنْ مَکْحُولٍ ؛ أَنَّہُ کَانَ یُوتِرُ بِثَلاَثٍ ، لاَ یُسَلِّمُ إِلاَّ فِی آخِرِہِنَّ۔,,,6906,,
6907,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : لاَ یُسَلَّمُ فِی الرَّکْعَتَیْنِ مِنَ الْوِتْرِ۔",,,6907,,
6908,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ حَمَّادٍ ، قَالَ : نَہَانِی إِبْرَاہِیمُ أَنْ أُسَلِّمَ فِی الرَّکْعَتَیْنِ مِنَ الْوِتْرِ۔",,,6908,,
6909,"حَدَّثَنَا وَکِیعٌ ، عَنْ زِیَادِ بْنِ أَبِی مُسْلِمٍ ، قَالَ : سَأَلْتُ أَبَا الْعَالِیَۃِ ، وَخِلاَسًا عَنِ الْوِتْرِ ؟ فَقَالاَ : اَصْنَعُ فِیہِ کَمَا تَصْنَعُ فِی الْمَغْرِبِ۔",,,6909,,
6910,حَدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ ثَابِتٍ ، عَنْ أَنَسٍ ؛ أَنَّہُ أَوْتَرَ بِثَلاَثٍ ، لَمْ یُسَلِّمْ إِلاَّ فِی آخِرِہِنَّ۔,,,6910,,
6911,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : کَانَ أَصْحَابُ عَلِیٍّ ، وَأَصْحَابُ عَبْدِ اللہِ لاَ یُسَلِّمُونَ فِی رَکْعَتَیِ الْوِتْرِ۔",,,6911,,
6912,"حَدَّثَنَا عَبْدَۃُ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ زُرَارَۃَ ، عَنْ سَعدِ بْنِ ہِشَامٍ ، عَنْ عَائِشَۃَ ، قَالَتْ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لاَ یُسَلِّمُ فِی رَکْعَتَیِ الْوِتْرِ۔",,,6912,,
6913,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ مَوْلَی آلِ طَلْحَۃَ ، عَنْ أَبِی سَلَمَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُوتِرُ بِثَلاَثٍ۔,,,6913,,
6914,حَدَّثَنَا وَکِیعٌ ، عَنْ مَالِکِ بْنِ مِغْوَلٍ ، عَنْ سَالِمِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ زَاذَانَ ؛ أَنَّ عَلِیًّا کَانَ یُوتِرُ بِثَلاَثٍ۔,,,6914,,
6915,حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، وَشُعْبَۃَ ، عَنْ عُمَر بْنِ مُرَّۃ ، عَنْ أَبِی عُبَیْدَۃ ، عَنْ عَبْدِ اللہِ ؛ أَنَّہ کَانَ یُوتِرُ بِثَلاَثٍ مِنْ آخِرِ اللَّیْلِ ، قَاعِدًا۔,,,6915,,
6916,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ سُفْیَانَ بْنِ حُسَیْنٍ ، عَنِ الزُّہْرِیِّ ، عَنْ عَطَائِ بْنِ یَزِیدَ اللَّیْثِیِّ ، عَنْ أَبِی أَیُّوبَ ، قَالَ : قَالَ لِی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَوْتِرْ بِخَمْسٍ ، فَإِنْ لَمْ تَسْتَطِعْ فَبِثَلاَثٍ ، فَإِنْ لَمْ تَسْتَطِعْ فَبِوَاحِدَۃٍ ، فَإِنْ لَمْ تَسْتَطِعْ فَأَوْمِئْ إِیمَائً۔ (احمد 418۔ دارمی 1582)",,,6916,,
6917,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عَطَائِ بْنِ یَزِیدَ ، عَنْ أَبِی أَیُّوبَ ؛ نَحْوَہُ ، وَلَمْ یَرْفَعْہُ۔ (نسائی 1402۔ طحاوی 291),,,6917,,
6918,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ عَبْدِ الْحَکِیمِ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : سَنَّ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْوِتْرَ کَمَا سَنَّ الْفِطْرَ وَالأَضْحَی۔",,,6918,,
6919,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ ، قَالَ : قَالَ عَلِیٌّ : الْوِتْرُ لَیْسَ بِحَتْمٍ کَالصَّلاَۃ الْمَکْتُوبَۃِ۔",,,6919,,
6920,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : الْوِتْرُ سُنَّۃٌ۔",,,6920,,
6921,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُسْلِمٍ مَوْلًی لِعَبْدِ الْقَیْسِ ، قَالَ : قَالَ رَجُلٌ لْاِبْنِ عُمَرَ : أَرَأَیْتَ الْوِتْرَ ، سُنَّۃٌ ہُوَ ؟ قَالَ : فَقَالَ : مَا سُنَّۃٌ ؟ أَوْتَرَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ،وَأَوْتَرَ الْمُسْلِمُونَ ، قَالَ : لاَ، أُسُنَّۃُ ہُوَ ؟ قَالَ : مَہْ ، أَتَغْفُلُ ، أَوْتَرَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَأَوْتَرَ الْمُسْلِمُونَ۔",,,6921,,
6922,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمٍ ، عَنْ عَلِیٍّ ، قَالَ : قیلَ لَہُ : الْوِتْرُ ، فَرِیضَۃٌ ہِیَ ؟ فَقَالَ : قَدْ أَوْتَرَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَثَبَتَ عَلَیْہِ الْمُسْلِمُونَ۔ (احمد 1/120)",,,6922,,
6923,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا یَحْیَی بْنُ سَعِیدٍ ، أَنَّ مُحَمَّدَ بْنَ یَحْیَی بْنِ حَبَّانَ أَخْبَرَہُ ، عَنِ ابْنِ مُحَیْرِیزٍ الْقُرَشِیِّ ، أَنَّہُ أَخْبَرَہُ ، عَنِ الْمُخْدَجِیِّ ، رَجُلٍ مِنْ بَنِی کِنَانَۃَ ، أَنَّہُ أَخْبَرَہُ ؛ أَنَّ رَجُلاً مِنَ الأَنْصَارِ کَانَ بِالشَّامِ ، یُکَنَّی : أَبَا مُحَمَّدٍ ، وَکَانَتْ لَہُ صُحْبَۃٌ ، وَکَانَ یَقُولُ : الْوِتْرُ وَاجِبٌ ، فَذَکَرَ الْمُخْدَجِیُّ أَنَّہُ رَاحَ إِلَی عُبَادَۃَ بْنِ الصَّامِتِ فَذَکَرَ ذَلِکَ لَہُ ، فَقَالَ عُبَادَۃُ : کَذَبَ أَبُو مُحَمَّدٍ ، سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، یَقُولُ : خَمْسُ صَلَوَاتٍ ، کَتَبَہُنَّ اللَّہُ عَلَی الْعِبَادِ ، مَنْ جَائَ بِہِنَّ لَمْ یُضَیِّعْ مِنْ حَقِّہِنَّ شَیْئًا ، جَائَ وَلَہُ عِنْدَ اللہِ عَہْدٌ أَنْ یُدْخِلَہُ اللَّہُ الْجَنَّۃَ ، وَمَنِ انْتَقَصَ مِنْ حَقِّہِنَّ شَیْئًا ، جَائَ وَلَیْسَ لَہُ عِنْدَ اللہِ عَہْدٌ ، إِنْ شَائَ عَذَّبَہُ ، وَإِنْ شَائَ أَدْخَلَہُ الْجَنَّۃَ۔ (ابوداؤد 1415۔ ابن حبان 1732)",,,6923,,
6924,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ مُطَرِّفٍ ، عَنْ عَامِرٍ ؛ أَنَّہُ سُئِلَ عَنْ رَجُلٍ یَنْسَی الْوِتْرَ ؟ قَالَ : لاَ یَضُرُّہُ ، کَأَنَّمَا ہُوَ فَرِیضَۃٌ۔",,,6924,,
6925,حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ لاَ یَرَی الْوِتْرَ فَرِیضَۃً۔,,,6925,,
6926,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَطَائٍ ، وَمُحَمَّدِ بْنِ عَلِیٍّ ، قَالاَ : الأَضْحَی وَالْوَتْرُ سُنَّۃٌ۔",,,6926,,
6927,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمٍ ، عَنْ عَلِیٍّ ، قَالَ : الْوِتْرُ لَیْسَ بِحَتْمٍ ، وَلَکِنَّہُ سَنَّہَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔ (نسائی 1385۔ احمد 1/86)",,,6927,,
6928,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ یَزِیدَ بْنِ أَبِی حَبِیبٍ ، عَنْ عَبْدِ اللہِ بْنِ رَاشِدٍ الزَّوْفِیِّ ، عَنْ عَبْدِ اللہِ بْنِ مُرَّۃَ الزَّوْفِیِّ ، عَنْ خَارِجَۃَ بْنِ حُذَافَۃَ الْعَدَوِیِّ ، قَالَ : خَرَجَ عَلَیْنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلاَۃَ الْغَدَاۃِ ، فَقَالَ : لَقَدْ أَمَدَّکُمُ اللَّہُ اللَّیْلَۃَ بِصَلاَۃٍ ، ہِیَ خَیْرٌ لَکُمْ مِنْ حُمْرِ النَّعَمِ ۔ قَالَ : قُلْنَا: وَمَا ہِیَ یَا رَسُولَ اللہِ ؟ قَالَ : الْوِتْرُ ، فِیمَا بَیْنَ صَلاَۃِ الْعِشَائِ إِلَی طُلُوعِ الْفَجْرِ۔(ترمذی 452۔ ابوداؤد 1413)",,,6928,,
6929,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ حَجَّاجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنَّ اللَّہَ زَادَکُمْ صَلاَۃً إِلَی صَلاَتِکُمْ ، وَہِیَ الْوِتْرُ۔ (احمد 2/206۔ دار قطنی 3)",,,6929,,
6930,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ، عَنِ الزُّہْرِیِّ، عَنْ عَطَائِ بْنِ یَزِیدَ ، عَنْ أَبِی أَیُّوبَ ، قَالَ: الْوِتْرُ حَقٌّ ، أَوْ وَاجِبٌ۔",,,6930,,
6931,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ إِبْرَاہِیمَ بْنِ مَیْسَرَۃَ ، عَنْ مُجَاہِدٍ ، قَالَ : ہُوَ وَاجِبٌ ، وَلَم یُکْتَبْ۔",,,6931,,
6932,"حَدَّثَنَا وَکِیعٌ ، عَنْ خَلِیلِ بْنِ مُرَّۃَ ، عَنْ مُعَاوِیَۃَ بْنِ قُرَّۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ لَمْ یُوتِرْ فَلَیْسَ مِنَّا۔ (احمد 2/443۔ راھویہ 97)",,,6932,,
6933,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَمَّادٍ ، قَالَ : أَخْبَرَنِی مُخْبِرٌ ، عَنْ عَبْدِ اللہِ بْنِ عُمَرَ ، قَالَ : مَا أُحِبُّ أَنِّی تَرَکْتُ الْوِتْرَ ، وَلَوْ أَنَّ لِی حُمْرَ النِّعَمِ۔ (عبدالرزاق 4578)",,,6933,,
6934,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، قَالَ : حدَّثَنَا أَبُو الْمُنِیبِ ، عَنْ عَبْدِ اللہِ بْنِ بُرَیْدَۃَ ، عَنْ أَبِیہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْوِتْرُ حَقٌّ ، فَمَنْ لَمْ یُوتِرْ فَلَیْسَ مِنَّا۔ (ابوداؤد 1414۔ احمد 5/357)",,,6934,,
6935,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا ہِشَامٌ ، عَنْ مُحَمَّدٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنَّ اللَّہَ وِتْرٌ ، یُحِبُّ الْوِتْرَ۔ (بخاری 6410۔ مسلم 2062)",,,6935,,
6936,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ وَہِشَامٌ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : أَوْتَرَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَلَیْسَ عَلَیْک ، قُلْتُ : لِمَنْ ؟ قَالَ : إِنَّمَا قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَوْتِرُوا یَا أَہْلَ الْقُرْآنِ۔ (ترمذی 453۔ ابوداؤد 1411)",,,6936,,
6937,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا أَبُو سِنَانٍ سَعِیدُ بْنُ سِنَانٍ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ أَبِی عُبَیْدَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَوْتِرُوا یَا أَہْلَ الْقُرْآنِ ، فَإِنَّ اللَّہَ وِتْرٌ یُحِبُّ الْوِتْرَ ۔ فَقَالَ أَعْرَابِیٌّ : مَا یَقُولُ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ قَالَ : إِنَّہَا لَیْسَتْ لَکَ ، وَلاَ لأَصْحَابِک۔ (عبدالرزاق 4571)",,,6937,,
6938,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا جُوَیْبِرٌ ، عَنِ الضَّحَّاکِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنَّ اللَّہَ وِتْرٌ ، یُحِبُّ الْوِتْرَ ، فَأَوْتِرُوا یَا أَہْلَ الْقُرْآنِ۔",,,6938,,
6939,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ عِمْرَانَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : قَالَ عَبْدُ اللہِ : إِنَّمَا الْوِتْرُ عَلَی أَہْلِ الْقُرْآنِ۔",,,6939,,
6940,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شَرِیکٌ ، عَنْ عَمَّارِ بْنِ مُعَاوِیَۃَ الدَّہْنِیِّ ، عَنْ سَالِمِ بْنِ أَبِی الْجَعْدِ ، عَنْ حُذَیْفَۃَ ، قَالَ : إِنَّمَا الْوِتْرُ عَلَی أَہْلِ الْقُرْآنِ۔",,,6940,,
6941,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا سُفْیَانُ، عَنْ مَنْصُورٍ، عَنْ إِبْرَاہِیمَ، قَالَ: کَانَ یُقَالُ: إِنَّمَا الْوِتْرُ عَلَی أَہْلِ الْقُرْآنِ۔",,,6941,,
6942,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ أَبِی عُبَیْدَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنَّمَا الْوِتْرُ عَلَی أَہْلِ الْقُرْآنِ۔",,,6942,,
6943,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا عَبْدُ الْمَلِکِ ، عَنْ زُبَیْدٍ ، عَنْ سَعِیدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ أَبْزَی ، عَنْ أَبِیہِ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَقْرَأُ فِی وِتْرِہِ بِـ : {سَبِّحِ اسْمَ رَبِّکَ الأَعْلَی} ، وَ{قُلْ یَا أَیُّہَا الْکَافِرُونَ} ، وَ{قُلْ ہُوَ اللَّہُ أَحَدٌ} فَإِذَا سَلَّمَ ، قَالَ : سُبْحَانَ الْمَلِکِ الْقُدُّوسِ ، ثَلاَثَ مَرَّاتٍ۔(نسائی 10580۔ احمد 3/407)",,,6943,,
6944,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ زُبَیْدٍ ، عَنْ ذِرٍّ ، عَنْ سَعِیدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ أَبْزَی ، عَنْ أَبِیہِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُوتِرُ بِـ : {سَبِّحِ اسْمَ رَبِّکَ الأَعْلَی} ، وَ{قُلْ یَا أَیُّہَا الْکَافِرُونَ} ، وَ{قُلْ ہُوَ اللَّہُ أَحَدٌ} وَیَقُولُ فِی آخِرِ صَلاَتِہِ إِذَا جَلَسَ : سُبْحَانَ الْمَلِکِ الْقُدُّوسِ ،ثَلاَثًا ، یَمُدُّ بِہَا صَوْتَہُ فِی الآخِرَۃِ۔ (نسائی 1430۔ احمد 3/407)",,,6944,,
6945,"حَدَّثَنَا شَبَابَۃُ ، قَالَ : حدَّثَنَا شُعْبَۃٌ ، عَنْ قَتَادَۃَ ، عَنْ زُرَارَۃَ بْنِ أَوْفَی ، عَنْ عِمْرَانَ بْنِ حُصَیْنٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُوتِرُ بِـ : {سَبِّحِ اسْمَ رَبِّکَ الأَعْلَی}۔ (نسائی 1743)",,,6945,,
6946,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا حَمَّادُ بْنُ زَیْدٍ، عَنْ أَنَسِ بْنِ سِیرِینَ، عَنْ عُمَرَ؛ کَانَ یَقْرَأُ بِالْمُعَوِّذَتَیْنِ فِی الْوِتْرِ۔",,,6946,,
6947,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا عَبْدُ الرَّحْمَنِ بْنُ إِسْحَاقَ ، عَنْ عَبْدِ الْمَلِکِ بْنِ عُمَیْرٍ ، قَالَ : کَانَ ابْنُ مَسْعُودٍ یُوتِرُ بِثَلاَثٍ ، یَقْرَأُ فِی کُلِّ رَکْعَۃٍ مِنْہُنَّ بِثَلاَثِ سُوَرٍ ، مِنْ آخِرِ الْمُفَصَّلِ ، مِنْ تَأْلِیفِ عَبْدِ اللہِ۔",,,6947,,
6948,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا عَبْدُ الْمَلِکِ بْنُ أَبِی سُلَیْمَانَ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ، عَنْ زَاذَانَ ؛ أَنَّ عَلِیًّا کَانَ یَفْعَلُ ذَلِکَ أَیْضًا۔",,,6948,,
6949,"حَدَّثَنَا أَبُو الأَحْوَصِ، عَنْ أَبِی إِسْحَاقَ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: کَانَ یَقْرَأُ فِی الْوِتْرِ بِثَلاَثٍ۔",,,6949,,
6950,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّہُ کَانَ یُوتِرُ بِثَلاَثٍ بِـ : {سَبِّحِ اسْمَ رَبِّکَ الأَعْلَی} ، وَ{قُلْ یَا أَیُّہَا الْکَافِرُونَ} ، وَ{قُلْ ہُوَ اللَّہُ أَحَدٌ}۔",,,6950,,
6951,"حَدَّثَنَا شَبَابَۃُ ، قَالَ : حدَّثَنَا یُونُسُ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُوتِرُ بِثَلاَثٍ ، یَقْرَأُ فِیہِنَّ بِـ : {سَبِّحِ اسْمَ رَبِّکَ الأَعْلَی} ، وَ{قُلْ یَا أَیُّہَا الْکَافِرُونَ} ، وَ{قُلْ ہُوَ اللَّہُ أَحَدٌ}۔ (ترمذی 462۔ احمد 299)",,,6951,,
6952,"حَدَّثَنَا شاَذَانُ ، قَالَ : حدَّثَنَا شَرِیکٌ ، عَنْ مُخَوَّلٍ ، عَنْ مُسْلِمٍ الْبَطِینِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ بِنَحْوِہِ۔",,,6952,,
6953,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ عَاصِمٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : کَانَ عُثْمَانُ یَقْرَأُ الْقُرْآنَ کُلَّہُ ، یُوتِرُ بِہِ۔",,,6953,,
6954,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجِ بْنِ دِینَارٍ ، قَالَ : سَأَلْتُ أَبَا جَعْفَرٍ ، مَا یَقْرَأُ فِی الرَّکْعَتَیْنِ مِنَ الْوِتْرِ ؟ قَالَ : لَیْسَ شَیْئٌ مِنَ الْقُرْآنِ مَہْجُورًا ، فَاقْرَأْ بِمَا شِئْتَ۔",,,6954,,
6955,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا عُیَیْنَۃُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ نَافِعٍ ، عَنْ ابْنِ عُمَرٍ ؛ أَنَّہُ کَانَ یَقْرَأُ فِی وِتْرِہِ مِنْ آخِرِ حِزْبِہِ۔",,,6955,,
6956,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، قَالَ : قُلْتُ لإِبْرَاہِیمَ : أَقْرَأُ فِی وَتْرِی مِنْ آخِرِ حِزْبِی {آمَنَ الرَّسُولُ بِمَا أُنْزِلَ إِلَیْہِ مِنْ رَّبِّہِ} إِلَی آخِرِ السُّورَۃِ ؟ قَالَ : نَعَمْ ، إِنْ شِئْتَ۔",,,6956,,
6957,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : اِقْرَأْ فِی الْوِتْرِ بِالْمُعَوِّذَتَیْنِ۔",,,6957,,
6958,"حَدَّثَنَا حَفْصٌ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ، قَالَ : وَدِدْتُ أَنِّی أَقْدِرُ أَنْ أُوتِرَ بِالْبَقَرَۃِ۔",,,6958,,
6959,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُحِلٍّ ، عَنْ إِبْرَاہِیمَ ، قَالَ : اِقْرَأْ فِی الرَّکْعَتَیْنِ الأُولَیَیْنِ مِنَ الْوِتْرِ بِسُورَتَیْنِ ، وَفِی الآخِرَۃِ : {آمَنَ الرَّسُولُ} ، وَ{قُلْ ہُوَ اللَّہُ أَحَدٌ}۔",,,6959,,
6960,"حَدَّثَنَا مُحَمَّدُ بْنِ أَبِی عُبَیْدَۃ ، قَالَ : حدَّثَنِی أَبِی ، عَنِ الأَعْمَشِ ، عَنْ طَلْحَۃَ ، عَنْ ذَِرٍّ ، عَنْ سَعِیدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ أَبْزَی ، عَنْ أَبِیہِ ، عَنْ أُبَیِّ بْنِ کَعْبٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُوتِرُ بِـ : {سَبِّحِ اسْمَ رَبِّکَ الأَعْلَی} ، وَ{قُلْ یَا أَیُّہَا الْکَافِرُونَ} ، وَ{قُلْ ہُوَ اللَّہُ أَحَدٌ} ، وَیَقُولُ فِی آخِرِ صَلاَتِہِ : سُبْحَانَ الْمَلِکِ الْقُدُّوسِ ، ثَلاَثًا۔ (ابوداؤد 1418۔ ابن حبان 2436)",,,6960,,
6961,"حَدَّثَنَا شَرِیکٌ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ بُرَیْدِ بْنِ أَبِی مَرْیَمَ ، عْن أَبِی الْحَوْرَائِ ، عَنِ الْحَسَنِ بْنِ عَلِیٍّ ، قَالَ : عَلَّمَنِی جَدِّی صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَلِمَاتٍ أَقُولُہُنَّ فِی قُنُوتِ الْوِتْرِ : اللَّہُمَّ اہْدِنِی فِیمَنْ ہَدَیْتَ ، وَعَافِنِی فِیمَنْ عَافَیْتَ ، وَتَوَلَّنِی فِیمَنْ تَوَلَّیْتَ ، وَبَارِکْ لِی فِیمَا أَعْطَیْتَ ، وَقِنِی شَرَّ مَا قَضَیْتَ ، فَإِنَّک تَقْضِی وَلاَ یُقْضَی عَلَیْکَ، إِنَّہُ لاَ یَذِلُّ مَنْ وَالَیْتَ، تَبَارَکْتَ رَبَّنَا وَتَعَالَیْتَ۔ (ابن ماجہ 1178۔ ابو یعلی 6765)",,,6961,,
6962,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہَارُونَ بْنِ إِبْرَاہِیمَ ، عَن عَبْدِ اللہِ بْنِ عُبَیْدِ بْنِ عُمَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ کَانَ یَقُولُ فِی قُنُوتِ الْوِتْرِ : لَکَ الْحَمْدُ مِلْئَ السَّمَاوَاتِ السَّبْعِ ، وَمِلْئَ الأَرْضِینَ السَّبْعِ ، وَمِلْئَ مَا بَیْنَہُمَا مِنْ شَیْئٍ بَعْدُ، أَہْلَ الثَّنَائِ وَالْمَجْدِ ، حَقَّ مَا قَالَ الْعَبْدُ ، کُلُّنَا لَکَ عَبْدٌ ، لاَ مَانِعَ لِمَا أَعْطَیْتَ ، وَلاَ مُعْطِیَ لِمَا مَنَعْتَ ، وَلاَ یَنْفَعُ ذَا الْجَدِّ مِِنْکَ الْجَدُّ۔",,,6962,,
6963,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، عَنْ مَنْصُورٍ ، عَنْ شَیْخٍ ، یُکَنَّی : أَبَا مُحَمَّدٍ ؛ أَنَّ الْحُسَیْنَ بْنَ عَلِیٍّ کَانَ یَقُولُ فِی قُنُوتِ الْوِتْرِ : اللَّہُمَّ إِنَّکَ تَرَی وَلاَ تُرَی ، وَأَنْتَ بِالْمَنْظَرِ الأَعْلَی ، وَإِنَّ إِلَیْکَ الرُّجْعَی ، وَإِنَّ لَکَ الآخِرَۃَ وَالأُولَی ، اللَّہُمَّ إِنَّا نَعُوذُ بِکَ أَنْ نَذِلَّ وَنَخْزَی۔",,,6963,,
6964,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الزُّبَیْرِ بْنِ عَدِیٍّ ، عَنْ إِبْرَاہِیمَ ، قَالَ : قُلْ فِی قُنُوتِ الْوِتْرِ : اللَّہُمَّ إِنَّا نَسْتَعِینُکَ وَنَسْتَغْفِرُکَ۔",,,6964,,
6965,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ، قَالَ : عَلَّمَنَا ابْنُ مَسْعُودٍ أَنْ نَقْرَأَ فِی الْقُنُوتِ : اللَّہُمَّ إِنَّا نَسْتَعِینُکَ وَنَسْتَغْفِرُکَ ، وَنُثْنِی عَلَیْکَ الْخَیْرَ ، وَلاَ نَکْفُرُکَ ، وَنَخْلَعُ وَنَتْرُکُ مَنْ یَفْجُرُکَ ، اللَّہُمَّ إِیَّاکَ نَعْبُدُ ، وَلَکَ نُصَلِّی وَنَسْجُدُ ، وَإِلَیْکَ نَسْعَی وَنَحْفِدُ ، نَرْجُو رَحْمَتَکَ وَنَخْشَی عَذَابَکَ ، إِنَّ عَذَابَکَ الْجِدَّ بِالْکُفَّارِ مُلْحِقٌ۔",,,6965,,
6966,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لَیْسَ فِی قُنُوتِ الْوِتْرِ شَیْئٌ مُؤقَّتٌ ، إِنَّمَا ہُوَ دُعَائٌ وَاسْتِغْفَارٌ۔",,,6966,,
6967,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ ، قَالَ : لَیْسَ عَلَی الْمُسَافِرِ وِتْرٌ۔",,,6967,,
6968,"حَدَّثَنَا وَکِیعٌ ، عَنْ عِمْرَانَ بْنِ حُدَیْرٍ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ : سَأَلْتُ ابْنَ عُمَرَ عَنِ الْوِتْرِ ؟ فَقَالَ : أَرَأَیْتَ إِنْ سَافَرْتُ ؟ قَالَ : رَکْعَۃٌ مِنْ آخِرِ اللَّیْلِ۔",,,6968,,
6969,"حَدَّثَنَا وَکِیعٌ ، عَنْ خَالِدِ بْنِ دِینَارٍ ، عَنْ شَیْخٍ ، قَالَ : صَحِبْتُ ابْنَ عَبَّاسٍ فِی سَفَرٍ ، فَلاَ أَحْفَظُ أَنَّہُ أَوْتَرَ۔",,,6969,,
6970,حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِیہِ ، عَنْ طَارِقٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ أَوْتَرَ فِی السَّفَرِ۔,,,6970,,
6971,"حَدَّثَنَا وَکِیعٌ، عَنْ إِسْرَائِیلَ، عَنْ جَابِرٍ، عَنْ عَامِرٍ، عَنِ ابْنِ عُمَرَ، وَابْنِ عَبَّاسٍ، قَالَ: الْوِتْرُ فِی السَّفَرِ سُنَّۃٌ۔",,,6971,,
6972,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مَنْصُورٌ ، عَنِ الْحَارِثِ الْعُکْلِیِّ ، عَنْ إِبْرَاہِیمَ ، عَنِ الأَسْوَدِ بْنِ یَزِیدَ ؛ أَنَّ عُمَرَ قَنَتَ فِی الْوِتْرِ قَبْلَ الرُّکُوعِ۔",,,6972,,
6973,حَدَّثَنَا شَرِیکٌ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ أَبِیہِ ؛ أَنَّ عَلِیًّا کَانَ یَقْنُتُ فِی الْوِتْرِ بَعْدَ الرُّکُوعِ۔,,,6973,,
6974,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا عَطَائُ بْنُ السَّائِبِ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ؛ أَنَّ عَلِیًّا کَانَ یَقْنُتُ فِی الْوِتْرِ بَعْدَ الرُّکُوعِ۔",,,6974,,
6975,حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، عَنْ أَبِیہِ ؛ أَنَّ عَبْدَ اللہِ کَانَ یُوتِرُ ، فَیَقْنُتُ قَبْلَ الرُّکُوعِ۔,,,6975,,
6976,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا لَیْثٌ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، عَنْ أَبِیہِ ، قَالَ : کَانَ ابْنُ مَسْعُودٍ لاَ یَقْنُتُ فِی شَیْئٍ مِنَ الصَّلَوَاتِ ، إِلاَّ فِی الْوِتْرِ قَبْلَ الرُّکُوعِ۔",,,6976,,
6977,حَدَّثَنَا وَکِیعٌ ، عَنْ عُمَرَ بْنِ ذَرٍّ ، عَنْ أَبِیہِ ، رَفَعَہُ ؛ أَنَّہُ کَانَ یَقْنُتُ فِی الْوِتْرِ قَبْلَ الرَّکْعَۃِ۔,,,6977,,
6978,"حَدَّثَنَا حَفْصٌ ، عَنِ الْحَسَنِ بْنِ عُبیدِ اللہِ ، عَنْ إِبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، قَالَ : مَرَّضْتُہُ فَأَوْتَرَ ، فَلَمَّا فَرَغَ مِنَ الْقِرَائَۃِ حَنیْتُہُ لِیَرْکَعَ ، فَلَمْ یَفْعَلْ حَتَّی قَنَتَ ، ثُمَّ رَکَعَ۔",,,6978,,
6979,حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ إِبْرَاہِیمَ ، عَنِ الأَسْوَدِ ؛ أَنَّہُ کَانَ یَقْنُتُ فِی الْوِتْرِ قَبْلَ الرَّکْعَۃِ۔,,,6979,,
6980,"حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانُوا یَقُولُونَ : الْقُنُوتُ بَعْدَ مَا یَفْرُغُ مِنَ الْقِرَائَۃِ۔",,,6980,,
6981,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانَ یَقُولُ فِی قُنُوتِ الْوِتْرِ : قَبْلَ الرُّکُوعِ إِذَا فَرَغَ مِنَ الْقِرَائَۃِ۔",,,6981,,
6982,حَدَّثَنَا ابْنُ نُمَیْرٍ، عَنْ إِسْمَاعِیلَ بْنِ عَبْدِالْمَلِکِ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ؛ أَنَّہُ کَانَ یَقْنُتُ فِی الْوِتْرِ قَبْلَ الرُّکُوعِ۔,,,6982,,
6983,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ؛ أَنَّ ابْنَ مَسْعُودٍ، وَأَصْحَابَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانُوا یَقْنُتُونَ فِی الْوِتْرِ قَبْلَ الرُّکُوعِ۔,,,6983,,
6984,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا أَبَانُ بْنُ أَبِی عَیَّاشٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، عَنْ عَبْدِ اللہِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَقْنُتُ فِی الْوِتْرِ قَبْلَ الرُّکُوعِ ۔ قَالَ : ثُمَّ أَرْسَلْتُ أُمِّیَ أُمَّ عَبْدٍ ، فَبَاتَتْ عِنْدَ نِسَائِہِ ، فَأَخْبَرَتْنِی أَنَّہُ قَنَتَ فِی الْوِتْرِ قَبْلَ الرُّکُوعِ۔(دارقطنی 32۔ بیہقی 41)",,,6984,,
6985,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا سُفْیَانُ ، عَنْ أَبَانَ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، عَنْ عَبْدِ اللہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ أَنَّہُ قَنَتَ قَبْلَ الرُّکُوعِ فِی الْوِتْرِ ۔ (دارقطنی5۔ بیہقی 41)",,,6985,,
6986,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : سَأَلْتُ الْقَاسِمَ عْن رَجُلٍ یُوتِرُ عَلَی رَاحِلَتِہِ ؟ فَقَالَ : زَعَمُوا أَنَّ عُمَرَ کَانَ یُوتِرُ بِالأَرْضِ۔",,,6986,,
6987,"حَدَّثَنَا مُعْتَمِرٌ ، عَنِ ابْنِ عَوْنٍ ، عَنِ الْقَاسِمِ ، قَالَ : کَانَ عُمَرُ یُوتِرُ بِالأَرْضِ۔",,,6987,,
6988,حَدَّثَنَا مُعْتَمِرٌ ، عَنْ حُمَیْدٍ ، عَنْ بَکْرٍ ؛ أَنَّ ابْنَ عُمَرَ کَانَ إِذَا أَرَادَ أَنْ یُوتِرَ ، نَزَلَ فَأَوْتَرَ بِالأَرْضِ۔,,,6988,,
6989,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانُوا یُصَلُّونَ عَلَی رَوَاحِلِہِمْ وَدَوَابِّہِمْ ، حَیْثُ مَا کَانَتْ وُجُوہُہُمْ ، إِلاَّ الْمَکْتُوبَۃَ وَالْوِتْرَ ، فَإِنَّہُمْ کَانُوا یُصَلُّونَہُمَا عَلَی الأَرْضِ۔",,,6989,,
6990,"حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِیلَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، قَالَ : کَانَ یُصَلِّی عَلَی رَاحِلَتِہِ حَیْثُ مَا تَوَجَّہَتْ بِہِ ، فَإِذَا أَرَادَ أَنْ یُوتِرَ نَزَلَ۔",,,6990,,
6991,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ أَبِی الْہَزْہَازِ ، عَنِ الضَّحَّاکِ ، قَالَ : إِذَا أَرَادَ أَنْ یُوتِرَ ، نَزَلَ فَأَوْتَرَ۔",,,6991,,
6992,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ ہَارُونَ بْنِ إِبْرَاہِیمَ ، قَالَ : سَأَلْتُ الْحَسَنَ ، قُلْتُ: أُصَلِّی عَلَی دَابَّتِی؟ فَقَالَ: صَلِّ عَلَیْہَا ، قُلْتُ : أُوتِرُ عَلَی دَابَّتِی ؟ قَالَ : لاَ۔ وَقَالَ ابْنُ سِیرِینَ : أَوْتِرْ بِالأَرْضِ۔",,,6992,,
6993,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ صَلَّی عَلَی رَاحِلَتِہِ ، فَأَوْتَرَ عَلَیْہَا ، وَقَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَفْعَلُہُ۔ (بخاری 1095۔ احمد 2/13)",,,6993,,
6994,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ ثُوَیْرٍ ، عَنْ أَبِیہِ ؛ أَنَّ عَلِیًّا کَانَ یُوتِرُ عَلَی رَاحِلَتِہِ۔,,,6994,,
6995,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ عَبَّادِ بْنِ مَنْصُورٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ أَوْتَرَ ، وَقَالَ : الْوِتْرُ عَلَی الرَّاحِلَۃِ۔",,,6995,,
6996,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عُمَرَ بْنِ نَافِعٍ ؛ أَنَّ أَبَاہُ کَانَ یُوتِرُ عَلَی الْبَعِیرِ۔,,,6996,,
6997,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ، قَالَ: کَانَ الْحَسَنُ لاَ یَرَی بَأْسًا أَنْ یُوتِرَ الرَّجُلُ عَلَی رَاحِلتِہِ۔",,,6997,,
6998,"حَدَّثَنَا عَمْرُو بْنُ مُحَمَّدٍ ، عَنِ ابْنِ أَبِی رَوَّادٍ ، عَنْ مُوسَی بْنِ عُقْبَۃَ ، قَالَ : صَحِبْتُ سَالِمًا ، فَتَخَلَّفْتُ عَنْہُ بِالطَّرِیقِ ، فَقَالَ : مَا خَلَّفَکَ ؟ قَالَ : قُلْتُ : أَوْتَرْتُ ، قَالَ : فَہَلاَّ أَوْتَرْتَ عَلَی رَاحِلَتِکَ ؟۔",,,6998,,
6999,"حَدَّثَنَا إِسْحَاقُ بْنُ سُلَیْمَانَ ، عَنْ أَبِی سِنَانٍ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ أَنَّ رَجُلاً سَأَلَہُ عَنِ الرَّجُلِ یُوتِرُ ، ثُمَّ یُصَلِّی ؟ فَقَالَ : یَنَامُ ، ثُمَّ یُصَلِّی۔",,,6999,,
7000,حَدَّثَنَا إِسْحَاقُ بْنُ سُلَیْمَانَ ، عَنْ أَبِی جَعْفَرٍ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّہُ کَرِہَ أَنْ یُوتِرَ ، ثُمَّ یُصَلِّیَ عَلَی إِثْرِ وِتْرِہِ۔,,,7000,,
7001,حَدَّثَنَا إِسْحَاقُ بْنُ سُلَیْمَانَ ، عَنْ زَکَرِیَّا بْنِ سَلاَّمٍ ، عَنِ الْعَلاَئِ بْنِ بَدْرٍ ؛ أَنَّ سَعْدًا کَانَ یُوتِرُ ، ثُمَّ یُصَلِّی۔,,,7001,,
7002,"حَدَّثَنَا فُضَیْلُ بْنُ عِیَاضٍ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانُوا یَسْتَحِبُّونَ الضَّجْعَۃَ بَیْنَ الْوِتْرِ وَبَیْنَ الرَّکْعَتَیْنِ۔",,,7002,,
7003,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، وَحَمَّادٍ ، وَجَہْمٍ ، عَنْ إِبْرَاہِیمَ ؛ فِی الَّذِی یَشُکُّ فِی وِتْرِہِ ، قَالَ : یَشْفَعُ بِرَکْعَۃٍ ، وَیَسْتَقْبِلُ الْوِتْرَ۔",,,7003,,
7004,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنِ الْحَکَمِ ، قَالَ : سَأَلْتُہُ عَنِ الرَّجُلِ یَشُکُّ فِی الرَّکْعَۃِ مِنَ الْوِتْرِ ، أَیَسْتَقْبِلُ أَمْ لاَ ؟ قَالَ : لاَ ، وَلَکِنْ یَقْضِی الرَّکْعَۃَ ، وَیَسْجُدُ سَجْدَتَیْنِ۔",,,7004,,
7005,حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنْ أَیُّوبَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ؛ أَنَّہُ کَانَ لاَ یَقْنُتُ إِلاَّ فِی النِّصْفِ۔ یَعْنِی مِنْ رَمَضَانَ۔,,,7005,,
7006,حَدَّثَنَا الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ بِنَحْوِہِ۔,,,7006,,
7007,حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ أَبِی إِسْحَاقَ، عَنِ الْحَارِثِ، عَنْ عَلِیٍّ؛ أَنَّہُ کَانَ یَقْنُتُ فِی النِّصْفِ مِنْ رَمَضَانَ۔,,,7007,,
7008,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا سَعِیدٌ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ؛ أَنَّ أُبَیًّا أَمَّ النَّاسَ فِی خِلاَفَۃِ عُمَرَ، فَصَلَّی بِہِمُ النِّصْفَ مِنْ رَمَضَانَ لاَ یَقْنُتُ ، فَلَمَّا مَضَی النِّصْفُ قَنَتَ بَعْدَ الرُّکُوعِ ، فَلَمَّا دَخَلَتِ الْعَشْرُ أَبَقَ وَخَلاَ عَنْہُمْ ، فَصَلَّی بِہِمُ الْعَشْرَ مُعَاذٌ الْقَارِیئُ فِی خِلاَفَۃِ عُمَرَ۔",,,7008,,
7009,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : الْقُنُوتُ فِی شَہْرِ رَمَضَانَ ؟ قَالَ : عُمَرُ أَوَّلُ مَنْ قَنَتَ ، قُلْتُ : النِّصْفُ الآخَرُ أَجْمَعُ ؟ قَالَ : نَعَمْ۔",,,7009,,
7010,حَدَّثَنَا وَکِیعٌ ، عَنْ عَبَّادِ بْنِ رَاشِدٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَقْنُتُ فِی النِّصْفِ مِنْ رَمَضَانَ۔,,,7010,,
7011,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ الْمُہَلَّبِ بْنِ أَبِی حَبِیبَۃَ ، قَالَ : سَأَلْت سَعِیدَ بْنَ أَبِی الْحَسَنِ عَنِ الْقُنُوتِ ؟ فَقَالَ : فِی النِّصْفِ مِنْ رَمَضَانَ ، کَذَلِکَ عُلِّمْنَا۔",,,7011,,
7012,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ یَحْیَی ، قَالَ : کَانَ یُصَلِّی وَلاَ یَقْنُتُ فِی الْوِتْرِ حَتَّی النِّصْفِ ۔ یَعْنِی مِنْ رَمَضَانَ۔",,,7012,,
7013,"حَدَّثَنَا أَزْہَرُ السَّمَّانُ ، عَنِ ابْنِ عَوْنٍ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّہُ کَانَ یَقُولُ : الْقُنُوتُ فِی السَّنَۃِ کُلِّہَا ۔ قَالَ : وَکَانَ ابْنُ سِیرِینَ لاَ یَرَاہُ إِلاَّ فِی النِّصْفِ مِنْ رَمَضَانَ۔",,,7013,,
7014,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ، عَنْ عَمْرٍو، عَنِ الْحَسَنِ؛ أَنَّ عُمَرَ حَیْثُ أَمَرَ أُبَیًّا أَنْ یُصَلِّیَ بِالنَّاسِ فِی رَمَضَانَ، وَأَمَرَہُ أَنْ یَقْنُتَ بِہِمْ فِی النِّصْفِ الْبَاقِی لَیْلَۃَ سِتَّ عَشْرَۃَ ۔\n\nقَالَ : وَکَانَ الْحَسَنُ یَقُولُ : إِذَا کَانَ إِمَامًا قَنَتَ فِی النِّصْفِ ، وَإِذَا لَمْ یَکُنْ إِمَامًا قَنَتَ الشَّہْرَ کُلَّہُ۔",,,7014,,
7015,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانَ عَبْدُ اللہِ لاَ یَقْنُتُ السَّنَۃَ کُلَّہَا فِی الْفَجْرِ ، وَیَقْنُتُ فِی الْوِتْرِ کُلَّ لَیْلَۃٍ قَبْلَ الرُّکُوعِ ۔ قَالَ أَبُو بَکْرٍ : ہَذَا الْقَوْلُ عِنْدَنَا۔",,,7015,,
7016,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ ہِشَامٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْحَارِثِ بْنِ ہِشَامٍ ، عَنْ عَلِیٍّ ، قَالَ : إِنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَقُولُ فِی آخِرِ وِتْرِہِ : اللَّہُمَّ إِنِّی أَعُوذُ بِرِضَاکَ مِنْ سَخَطِکَ، وَأَعُوذُ بِمُعَافَاتِکَ مِنْ عُقُوبَتِکَ ، وَأَعُوذُ بِکَ مِنْکَ ، لاَ أُحْصِی ثَنَائً عَلَیْکَ ، أَنْتَ کَمَا أَثْنَیْتَ عَلَی نَفْسِکَ۔ (ترمذی 3566۔ ابوداؤد 1422)",,,7016,,
7017,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ سُلَیْمَانَ التَّیْمِیِّ ، عَنْ رَجُلٍ ، عَنْ أَبِی الْمُہَزِّمِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : نَزَلْتُ عَلَیْہِ عَشْرَ سِنِینَ ، فَمَا رَأَیْتُہُ قَنَتَ فِی وِتْرِہِ۔",,,7017,,
7018,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ لاَ یَقْنُتُ فِی الْفَجْرِ، وَلاَ فِی الْوِتْرِ ، وَکَانَ إِذَا سُئِلَ عَنِ الْقُنُوتِ ، قَالَ : مَا نَعْلَمُ الْقُنُوتَ إِلاَّ طُولَ الْقِیَامِ ، وَقِرَائَۃَ الْقُرْآنِ۔",,,7018,,
7019,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ أَبِی عُبَیْدَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنَّمَا الْوِتْرُ عَلَی أَہْلِ الْقُرْآنِ۔",,,7019,,
7020,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ مِسْعَرٍ ، عَنْ حَمَّادٍ ، قَالَ : إِذَا سَہَا قَبْلَ أَنْ یَقْنُتَ ، فَلْیَسْجُدْ سَجْدَتَیِ السَّہْوِ ۔ یَعْنِی فِی الْوِتْرِ۔",,,7020,,
7021,حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ لَیْثٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، عَنْ أَبِیہِ ؛ أَنَّ عَبْدَ اللہِ بْنَ مَسْعُودٍ کَانَ إِذَا فَرَغَ مِنَ الْقِرَائَۃِ کَبَّرَ ثُمَّ قَنَتَ ، فَإِذَا فَرَغَ مِنَ الْقُنُوتِ کَبَّرَ ثُمَّ رَکَعَ۔,,,7021,,
7022,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا أَرَدْتَ أَنْ تَقْنُتَ ، فَکَبِّرْ لِلْقُنُوتِ ، وَکَبِّرْ إِذَا أَرَدْتَ أَنْ تَرْکَعَ۔",,,7022,,
7023,حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّہُ کَانَ یُکَبِّرُ إِذَا قَنَتَ ، وَیُکَبِّرُ إِذَا فَرَغَ۔,,,7023,,
7024,"حَدَّثَنَا ہُشَیْمٌ، عَنْ مُغِیرَۃَ، عَنْ إِبْرَاہِیمَ، قَالَ: إِذَا فَرَغْتَ مِنَ الْقِرَائَۃِ فَکَبِّرْ، ثُمَّ إِذَا فَرَغْتَ فَکَبِّرْ وَارْکَعْ۔",,,7024,,
7025,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَمِعْتُ الْحَکَمَ ، وَحَمَّادًا ، وَأَبَا إِسْحَاقَ ، یَقُولُونَ فِی قُنُوتِ الْوِتْرِ : إِذَا فَرَغَ کَبَّرَ ، ثُمَّ قَنَتَ۔",,,7025,,
7026,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : ارْفَعْ یَدَیْک لِلْقُنُوتِ۔",,,7026,,
7027,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ لَیْثٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، عَنْ أَبِیہِ ، عَنْ عَبْدِ اللہِ ؛ أَنَّہُ کَانَ یَرْفَعُ یَدَیْہِ فِی قُنُوتِ الْوِتْرِ۔",,,7027,,
7028,حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مُحَمَّدٍ الْمُحَارِبِیُّ ، عَنْ لَیْثٍ ، عَنِ ابْنِ الأَسْوَدِ ، عَنْ أَبِیہِ ، عَنْ عَبْدِ اللہِ ؛ أَنَّہُ کَانَ یَرْفَعُ یَدَیْہِ إِذَا قَنَتَ فِی الْوِتْرِ۔,,,7028,,
7029,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : دَخَلْتُ عَلَی الأَسْوَدِ ذَاتَ لَیْلَۃٍ وَہُوَ مَرِیضٌ ، فَصَلَّی الْوِتْرَ وَرَجُلٌ مُسْنِدٌ إِلَیْہِ ۔ قَالَ : فَقَنَتَ فَأَطَالَ الْقُنُوتَ ، حَتَّی ظَنَنْتُ أَنَّہُ قَدْ زَادَ عَلَی مَا کَانَ یَصْنَعُ۔",,,7029,,
7030,حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْمَاعِیلَ بْنِ عَبْدِ الْمَلِکِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ أَنَّہُ کَانَ یَقُومُ بِنَا فِی الْوِتْرِ قَدْرَ مَا یَقْرَأُ مِئَۃَ آیَۃٍ۔,,,7030,,
7031,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : یُقَامُ فِی قُنُوتِ الْوِتْرِ قَدْرَ : {إِذَا السَّمَائُ انْشَقَّتْ}۔",,,7031,,
7032,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ عَاصِمٍ ، عَنْ أَبِی عُثْمَانَ ؛ أَنَّہُ سُئِلَ عَنْ قُنُوتِ عُمَرَ فِی الْفَجْرِ ؟ فَقَالَ : کَانَ یَقْنُتُ بِقَدْرِ مَا یَقْرَأُ الرَّجُلُ مِئَۃَ آیَۃٍ۔",,,7032,,
7033,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لاَ وِتْرَ إِلاَّ بِقُنُوتٍ۔",,,7033,,
7034,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ أَبِی مَالِکٍ الأَشْجَعِیِّ ، قَالَ : قُلْتُ لأَبِی : یَا أَبَتِ ، صَلَّیْتَ خَلْفَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَخَلْفَ أَبِی بَکْرٍ ، وَعُمَرَ ، وَعُثْمَانَ ، فَہَلْ رَأَیْتَ أَحَدًا مِنْہُمْ یَقْنُتُ ؟ فَقَالَ : یَا بُنَیَّ ، ہِیَ مُحْدَثَۃٌ۔ (ترمذی 403۔ احمد 3/472)",,,7034,,
7035,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مِسْعَرٌ ، عَنْ یَحْیَی بْنِ غَسَّانَ الْمُرَادِیِّ ، عَنْ عَمْرِو بْنِ مَیْمُونٍ ؛ أَنَّ عُمَرَ بْنَ الْخَطَّابِ لَمْ یَقْنُتْ فِی الْفَجْرِ۔",,,7035,,
7036,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ أَبِی مَالِکٍ ، عَنْ أَبِیہِ ، قَالَ : قُلْتُ لَہُ : صَلَّیْت خَلْفَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَأَبِی بَکْرٍ ، وَعُمَرَ ، وَعُثْمَانَ ، أَفَکَانُوا یَقْنُتُونَ ؟ فَقَالَ : لاَ یَا بُنَیَّ ، ہِیَ مُحْدَثَۃٌ۔(ابن ماجہ 1241۔ طبرانی 8179)",,,7036,,
7037,حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّ الأَسْوَدَ ، وَعَمْرَو بْنَ مَیْمُونٍ صَلَّیَا خَلْفَ عُمَرَ الْفَجْرَ فَلَمْ یَقْنُتْ۔,,,7037,,
7038,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَنِ الأَسْوَدِ بْنِ یَزِیدَ ، وَعَمْرِو بْنِ مَیْمُونٍ ؛ أَنَّہُمَا صَلَّیَا خَلْفَ عُمَرَ الْفَجْرَ فَلَمْ یَقْنُتْ۔,,,7038,,
7039,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مِسْعَرٌ ، عَنْ عُثْمَانَ الثَّقَفِیِّ ، عَنْ عَرْفَجَۃَ ؛ أَنَّ ابْنَ مَسْعُودٍ کَانَ لاَ یَقْنُتُ فِی الْفَجْرِ۔",,,7039,,
7040,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَلْقَمَۃَ بْنِ قَیْسٍ ، أَنَّ ابْنَ مَسْعُودٍ لَمْ یَکُنْ یَقْنُتُ فِی الْفَجْرِ۔",,,7040,,
7041,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ عَبْدُ اللہِ لاَ یَقْنُتُ فِی صَلاَۃِ الصُّبْحِ۔",,,7041,,
7042,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ إِبْرَاہِیمَ ، عَن سُلَیْمٍ أَبِی الشَّعْثَائِ الْمُحَارِبِیِّ ، قَالَ : سَأَلْتُ ابْنَ عُمَرَ عَنِ الْقُنُوتِ فِی الْفَجْرِ ، فَقَالَ : فَأَیُّ شَیْئٍ الْقُنُوتُ قُلْتُ یَقُومُ الرَّجُلُ سَاعَۃً بَعْدَ الْقِرَائَۃِ ، فَقَالَ ابْنُ عُمَرَ : مَا شَعَرْت۔",,,7042,,
7043,"حَدَّثَنَا وَکِیعٌ ، قَالَ: حدَّثَنَا سُفْیَانُ ، عَنْ وَاقِدٍ مَوْلَی زَیْدِ بْنِ خُلَیْدَۃَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ، عَنِ ابْنِ عَبَّاسٍ، وَابْنِ عُمَرَ أَنَّہُمَا کَانَا لاَ یَقْنُتَانِ فِی الْفَجْرِ۔",,,7043,,
7044,"حَدَّثَنَا رَوْحُ بْنُ عُبَادَۃَ ، عَنْ زَکَرِیَّا بْنِ إِسْحَاقَ ، قَالَ : حدَّثَنِی عَمْرُو بْنُ دِینَارٍ ، أَنَّ ابْنَ الزُّبَیْرِ صَلَّی بِہِمُ الصُّبْحَ فَلَمْ یَقْنُتْ۔",,,7044,,
7045,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ أَبِی خَالِدٍ ، عَنْ أَبِی الضُّحَی ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، أَنَّ عُمَرَ کَانَ لاَ یَقْنُتُ فِی الْفَجْرِ۔",,,7045,,
7046,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ إبْرَاہِیمَ ، أَنَّ عُمَر بْنَ الْخَطَّابِ کَانَ لاَ یَقْنُت فِی الْفَجْرِ۔",,,7046,,
7047,حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ إبْرَاہِیمَ بْنِ عَبْدِ الأَعْلَی ، عَنْ طَلْحَۃَ ، أَنَّ أَبَا بَکْرٍ لَمْ یَقْنُتْ فِی الْفَجْرِ۔,,,7047,,
7048,حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ یَزِیدَ الْفَقِیرِ ، قَالَ صَلَّیْت خَلْفَ ابْنِ عُمَرَ الْفَجْرَ فَلَمْ یَقْنُتْ۔,,,7048,,
7049,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حُصَیْنٌ ، عَنْ عِمْرَانَ بْنِ الْحَارِثِ ، قَالَ صَلَّیْت مَعَ ابْنِ عَبَّاسٍ فِی دَارِہِ صَلاَۃَ الصُّبْحِ فَلَمْ یَقْنُتْ قَبْلَ الرُّکُوعِ ، وَلاَ بَعْدَہُ۔",,,7049,,
7050,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا ابْنُ عَوْنٍ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ بْنِ یَزِیدَ ، قَالَ : قَالَ ابْنُ عُمَرَ فِی قُنُوتِ الصُّبْحِ مَا شَہِدْت ، وَلاَ عَلِمْت۔",,,7050,,
7051,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ عَوْنٍ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ بْنِ یَزِیدَ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ لَمْ یَعْرِفِ الْقُنُوتَ فِی الْفَجْرِ۔",,,7051,,
7052,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ہِشَامٌ الدَّسْتَوَائِیُّ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسٍ ، قَالَ : إنَّمَا قَنَتَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ شَہْرًا بَعْدَ الرُّکُوعِ۔ (بخاری 4089۔ مسلم 304)",,,7052,,
7053,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی مِجْلَزٍ ، عَنْ أَنَسٍ ، قَالَ : إنَّمَا قَنَتَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی صَلاَۃِ الصُّبْحِ شَہْرًا بَعْدَ الرُّکُوعِ یَدْعُو عَلَی رِعْلٍ وَذَکْوَانَ۔ (بخاری 4094۔ احمد 3/116)",,,7053,,
7054,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنْ أَنَسٍ ، قَالَ : إنَّمَا قَنَتَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ شَہْرًا یَدْعُو عَلَی أُنَاسٍ قَتَلُوا أُنَاسًا مِنْ أَصْحَابِہِ ، یُقَالُ لَہُمُ الْقُرَّائُ۔ (بخاری 1002۔ مسلم 469)",,,7054,,
7055,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا عُرْوَۃُ الْہَمْدَانِیُّ ، قَالَ : حَدَّثَنَا الشَّعْبِیُّ ، قَالَ لَمَّا قَنَتَ عَلِیٌّ فِی صَلاَۃِ الصُّبْحِ أَنْکَرَ النَّاسُ ذَلِکَ ، قَالَ : فَقَالَ : إنَّمَا اسْتَنْصَرْنَا عَلَی عَدُوِّنَا۔",,,7055,,
7056,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ قَیْسٍ ، عَنْ عَامِرٍ الْجُہَنِیِّ ، أَنَّ عُمَرَ بْنَ الْخَطَّابِ کَانَ لاَ یَقْنُتُ فِی الْفَجْرِ ، وَقَالَ عَامِرٌ مَا کَانَ الْقُنُوتُ حَتَّی جَائَ أَہْلُ الشَّامِ۔",,,7056,,
7057,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ قَیْسٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : قَالَ عَبْدُ اللہِ لَوْ أَنَّ النَّاسَ سَلَکُوا وَادِیًا وَشِعْبًا وَسَلَکَ عُمَرُ وَادِیًا وَشِعْبًا سَلَکْت وَادِیَ عُمَرَ وَشِعْبَہُ وَلَوْ قَنَتَ عُمَرُ قَنَتَ عَبْدُ اللہِ۔",,,7057,,
7058,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا أَبُو بِشْرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، أَنَّہُ کَانَ لاَ یَقْنُتُ فِی صَلاَۃِ الصُّبْحِ۔",,,7058,,
7059,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ الْحَسَنِ بْنِ عَمْرو ، عَنْ فُضَیْلٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إنَّمَا قَنَتَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَیَّامًا۔ (طحاوی 244)",,,7059,,
7060,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مِسْعَرٌ ، عَنْ أَبِی حَمْزَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : قَالَ عَبْدُ اللہِ بْنُ مَسْعُودٍ : قَدْ عَلِمُوا ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إنَّمَا قَنَتَ شَہْرًا۔ (طحاوی 243۔ طبرانی 483)",,,7060,,
7061,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مِسْعَرٌ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، قَالَ صَلَّیْت خَلْفَ سَعِیدِ بْنِ جُبَیْرٍ فَلَمْ یَقْنُتْ۔",,,7061,,
7062,حَدَّثَنَا وَکِیعٌ ، عَنْ مُوسَی بْنِ نَافِعٍ ، قَالَ صَلَّیْت خَلْفَ سَعِیدِ بْنِ جُبَیْرٍ الْفَجْرَ فَلَمْ یَقْنُتْ۔,,,7062,,
7063,حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ سُلَیْمَانَ التَّیْمِیِّ ، عَنْ شَیْخٍ ، أَنَّہُ صَلَّی خَلْفَ عُثْمَانَ فَلَمْ یَقْنُتْ۔,,,7063,,
7064,حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ صَلَّیْت خَلْفَ ابْنِ عُمَرَ فَلَمْ یَقْنُتْ قَبْلَ الرُّکُوعِ ، وَلاَ بَعْدَہُ۔,,,7064,,
7065,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ مُحَمَّدِ بْنِ أَبِی إسْمَاعِیلَ ، قَالَ : سَأَلْتُ سَعِیدَ بْنَ جُبَیْرٍ ، عَنِ الْقُنُوتِ ، فَقَالَ : إذَا قَرَأْت فَارْکَعْ۔",,,7065,,
7066,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إسْرَائِیلُ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ ذَاکَرْت أَبَا جَعْفَرٍ الْقُنُوتَ ، فَقَالَ : خَرَجَ عَلِیٌّ مِنْ عِنْدِنَا ، وَمَا یَقْنُتْ وَإِنَّمَا قَنَتَ بَعْدَ مَا أَتَاکُمْ۔",,,7066,,
7067,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ وَسُلَیْمَانَ ، قَالاَ : کَانَ إبْرَاہِیمُ لاَ یَقْنُتُ فِی صَلاَۃِ الْفَجْرِ وَہُوَ إمَامٌ۔",,,7067,,
7068,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ مَنْصُورٍ ، قَالَ : حدَّثَنِی مُجَاہِدٌ وَسَعِیدُ بْنُ جُبَیْرٍ ، أَنَّ ابْنَ عَبَّاسٍ کَانَ لاَ یَقْنُتُ فِی صَلاَۃِ الْفَجْرِ۔",,,7068,,
7069,حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی بِشْرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، أَنَّہُ کَانَ لاَ یَقْنُتُ فِی صَلاَۃِ الصُّبْحِ۔,,,7069,,
7070,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا إسْرَائِیلُ ، عَنْ جَابِرٍ، عَنْ عَامِرٍ، قَالَ لَمْ یَقْنُتْ أَبُو بَکْرٍ، وَلاَ عُمَرُ فِی الْفَجْرِ۔",,,7070,,
7071,حَدَّثَنَا وَکِیعٌ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن أَبِی الشَّعْثَائِ ، عَنِ ابْنِ عُمَرَ ، عَن عُمَرَ أَنَّہُ کَانَ لاَ یَفْعَلُہُ، یَعْنِی الْقُنُوتَ فِی الْفَجْرِ۔,,,7071,,
7072,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ وَشُعْبَۃُ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْبَرَائِ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَنَتَ فِی الْفَجْرِ وَالْمَغْرِبِ۔ (مسلم 306۔ احمد 4/299)",,,7072,,
7073,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا فِطَرٌ ، عَنْ عَطَائٍ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَنَتَ فِی الْفَجْرِ۔ (احمد 3/162۔ بیہقی 201)",,,7073,,
7074,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ أَبِی ذِئْبٍ ، عَنْ شَیْخٍ لَمْ یُسَمِّہِ ، أَنَّ أَبَا بَکْرٍ قَنَتَ فِی الْفَجْرِ۔",,,7074,,
7075,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی حَصِینٍ ، عَنْ عَبْدِ الرحمنِ بْنِ مَعْقِلٍ ، قَالَ قَنَتَ فِی الْفَجْرِ رَجُلاَنِ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَلِیٌّ ، وَأَبُو مُوسَی۔",,,7075,,
7076,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا أَبُو جَعْفَرٍ الرَّازِیّ ، عَنِ الرَّبِیعِ بْنِ أَنَسٍ ، عَنْ أَنَسٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَنَتَ فِی الْفَجْرِ۔",,,7076,,
7077,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ عَوْفٍ ، عَنْ أَبِی رَجَائٍ ، قَالَ : رَأَیْتُ ابْنَ عَبَّاسٍ یَمُدُّ بِضَبْعَیْہِ فِی قُنُوتِ صَلاَۃِ الْغَدَاۃِ إذْ کَانَ بِالْبَصْرَۃِ۔",,,7077,,
7078,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا أَبُو الأَشْہَبِ جَعْفَرُ بْنُ حَیَّانَ وَقُرَّۃُ بْنُ خَالِدٍ سَمِعَاہُ مِنْ أَبِی رَجَائٍ الْعُطَارِدِیِّ، قَالَ : صَلَّی ابْنُ عَبَّاسٍ الْفَجْرَ بِالْبَصْرَۃِ فَقَنَتَ۔",,,7078,,
7079,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مِسْعَرٌ ، عَنْ عَبْدِ الْمَلِکِ بْنِ مَیْسَرَۃَ الزَّرّاد ، عَنْ زَیْدِ بْنِ وَہْبٍ ، قَالَ : رُبَّمَا قَنَتَ عُمَرُ فِی صَلاَۃِ الْفَجْرِ۔",,,7079,,
7080,حَدَّثَنَا شَرِیکٌ ، عَنْ زُبَیْدٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، قَالَ الْقُنُوتُ سُنَّۃٌ مَاضِیَۃٌ۔,,,7080,,
7081,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ زُبَیْدِ بْنِ الْحَارِثِ الیامی ، قَالَ : سَأَلْتُ ابْنَ أَبِی لَیْلَی ، عَنِ الْقُنُوتِ فِی الْفَجْرِ ، فَقَالَ : سُنَّۃٌ مَاضِیَۃٌ۔",,,7081,,
7082,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا یَزِیدُ بْنُ إِبرَاہِیم ، عَنِ ابْنِ سِیرِینَ ، أَنَّہُ قَالَ : الْقُنُوتُ فِی الْفَجْرِ ہُنَیْہَۃٌ ، أَوْ سَاعَۃٌ ، أَوْ کَلِمَۃٌ تُشْبِہُہَا۔",,,7082,,
7083,حَدَّثَنَا ابْن مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ مُحَارِبٍ عَنْ عُبَیْدِ بْنِ الْبَرَائِ، عَنِ الْبَرَائِ، أَنَّہُ کَانَ یَقْنُتُ فِی الْفَجْرِ۔,,,7083,,
7084,سَمِعْت وَکِیعًا یَقُولُ سَمِعْت سُفْیَانَ یَقُولُ مَنْ قَنَتَ فَحَسَنٌ وَمَنْ لَمْ یَقْنُتْ فَحَسَنٌ وَمَنْ قَنَتَ فَإِنَّمَا الْقُنُوتُ عَلَی الإِمَام وَلَیْسَ عَلَی مَنْ وَرَائَہُ قُنُوتٌ۔,,,7084,,
7085,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ الْعَوَّامِ بْنِ حَمْزَۃَ ، قَالَ : سَأَلْتُ أَبَا عُثْمَانَ ، عَنِ الْقُنُوتِ ، فَقَالَ : بَعْدَ الرُّکُوعِ ، فَقُلْت : عَمَّنْ ؟ فَقَالَ : عَنْ أَبِی بَکْرٍ وَعُمر وَعُثْمَانَ۔",,,7085,,
7086,حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ عَوْفٍ ، عَنْ أَبِی رَجَائٍ ، قَالَ صَلَّیْت مَعَ ابْنِ عَبَّاسٍ فِی مَسْجِدِ الْبَصْرَۃِ صَلاَۃَ الْغَدَاۃِ فَقَنَتَ بِنَا قَبْلَ الرُّکُوعِ۔,,,7086,,
7087,حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ عَوْفٍ ، قَالَ ذَکَرْت ذَلِکَ لأَبِی الْمِنْہَالِ فَحَدَّثَنِی ، عَنْ أَبِی الْعَالِیَۃِ ، عَنِ ابْنِ عَبَّاسٍ بِمِثْلِہِ۔,,,7087,,
7088,حَدَّثَنَا ہُشَیْمٌ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ مُحَمَّدِ بْنِ یَحْیَی بْنِ حَبَّانَ ، قَالَ قَنَتَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَرْبَعِینَ صَبَاحًا فِی صَلاَۃِ الصُّبْحِ بَعْدَ الرُّکُوعِ۔,,,7088,,
7089,حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ حَجَّاجٍ ، عَنْ عَیَّاشٍ الْعَامِرِیِّ ، عَنِ ابْنِ معقلٍ ، أَنَّ عُمَرَ وَعَلِیًّا وَأَبَا مُوسَی قَنَتُوا فِی الْفَجْرِ قَبْلَ الرُّکُوعِ۔,,,7089,,
7090,حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُطَرِّفٍ ، عَنْ أَبِی الْجَہْمِ ، عَنِ الْبَرَائِ ، أَنَّہُ کَانَ یَقْنُتُ قَبْلَ الرَّکْعَۃِ۔,,,7090,,
7091,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یَزِیدُ بْنُ أَبِی زِیَادٍ ، قَالَ : حَدَّثَنَا زَیْدُ بْنُ وَہْبٍ ، أَنَّ عُمَرَ بْنَ الْخَطَّابِ قَنَتَ فِی صَلاَۃِ الصُّبْحِ قَبْلَ الرُّکُوعِ۔",,,7091,,
7092,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا عَلِیُّ بْنُ زَیْدٍ ، قَالَ : أَخْبَرَنَا أَبُو عُثْمَانَ النَّہْدِیُّ ، قَالَ صَلَّیْت خَلْفَ عُمَرَ بْنِ الْخَطَّابِ صَلاَۃَ الصُّبْحِ فَقَنَتَ قَبْلَ الرُّکُوعِ۔",,,7092,,
7093,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : حَدَّثَنَا عَطَائُ بْنُ السَّائِبِ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ السُّلَمِیِّ ، أَنَّ عَلِیًّا کَانَ یَقْنُتُ فِی صَلاَۃِ الصُّبْحِ قَبْلَ الرُّکُوعِ۔",,,7093,,
7094,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا ابْنُ أَبِی لَیْلَی ، عَنْ عَطَائٍ ، عَنْ عُبَیْدِ بْنِ عُمَیْرٍ ، قَالَ صَلَّیْت خَلْفَ عُمَرَ الْغَدَاۃَ ، قَالَ فَقَنَتَ فِیہَا قَبْلَ الرُّکُوعِ۔",,,7094,,
7095,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ أَبِی لَیْلَی ، عَنْ عَطَائٍ ، عَنْ عُبَیْدِ بْنِ عُمَیْرٍ ، عَنْ عُمَرَ بِمِثْلِہِ۔",,,7095,,
7096,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ نُسَیْرِ بْنِ ذُعْلُوقٍ ، قَالَ صَلَّیْت خَلْفَ رَبِیعِ بْنِ خُثَیم فَقَنَتَ قَبْلَ الرَّکْعَۃِ۔",,,7096,,
7097,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ النُّعْمَانِ بْنِ قَیْسٍ ، قَالَ صَلَّیْت خَلْفَ عَبِیدَۃَ الْفَجْرَ فَقَنَتَ قَبْلَ الرَّکْعَۃِ۔",,,7097,,
7098,"حدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ، عَنْ زَائِدَۃَ، عَنْ أَبِی فَرْوَۃَ، قَالَ: کان ابْنُ أَبِی لَیْلَی یَقْنُتُ فِی الْفَجْرِ قَبْلَ الرَّکْعَۃِ۔",,,7098,,
7099,"حَدَّثَنَا أَحْمَدُ بْنُ إِسْحَاقَ ، عَنْ وَہْبٍ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، قَالَ : کَانَ یَدْعُو بِدُعَائٍ کَثِیرٍ فِی صَلاَۃِ الصُّبْحِ قَبْلَ الرُّکُوعِ۔",,,7099,,
7100,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا ابْنُ أَبِی لَیْلَی ، عَنْ عَطَائٍ ، عَنْ عُبَیْدِ بْنِ عُمَیْرٍ ، قَالَ صَلَّیْت خَلْفَ عُمَرَ بْنِ الْخَطَّابِ الْغَدَاۃَ ، فَقَالَ : فِی قُنُوتِہِ : اللَّہُمَّ إنَّا نَسْتَعِینُک وَنَسْتَغْفِرُک وَنُثْنِی عَلَیْک الْخَیْرَ ، وَلاَ نَکْفُرُک وَنَخْلَعُ وَنَتْرُکُ مَنْ یَفْجُرُکَ اللَّہُمَّ إیَّاکَ نَعْبُدُ وَلَک نُصَلِّی وَنَسْجُدُ وَإِلَیْک نَسْعَی وَنَحْفِدُ، نَرْجُو رَحْمَتَکَ وَنَخْشَی عَذَابَک إنَّ عَذَابَک بِالْکُفَّارِ مُلْحِقٌ۔",,,7100,,
7101,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حُصَیْنٌ ، عَنْ زِرٍّ ، عَنْ سَعِیدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ أَبْزَی ، عَنْ أَبِیہِ ، أَنَّہُ صَلَّی خَلْفَ عُمَرَ فَصَنَعَ مِثْلَ ذَلِکَ۔",,,7101,,
7102,"حَدَّثَنَا وَکِیعٌ ، قَالَ : أَخْبَرَنَا سُفْیَانُ ، عَنْ حَبِیبِ بْنِ أَبِی ثَابِتٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ سُوَیْد الْکَاہِلِیِّ ، أَنَّ عَلِیًّا قَنَتَ فِی الْفَجْرِ بِہَاتَیْنِ السُّورَتَیْنِ : اللَّہُمَّ إنَّا نَسْتَعِینُک وَنَسْتَغْفِرُک وَنُثْنِی عَلَیْک وَلاَ نَکْفُرُک ، وَنَخْلَعُ وَنَتْرُکُ مَنْ یَفْجُرُکَ ، اللَّہُمَّ إیَّاکَ نَعْبُدُ وَلَک نُصَلِّی وَنَسْجُدُ ، وَإِلَیْک نَسْعَی وَنَحْفِدُ ، نَرْجُو رَحْمَتَکَ ، وَنَخْشَی عَذَابَک ، إنَّ عَذَابَک بِالْکُفَّارِ مُلْحِقٌ۔ (بیہقی 204۔ ابن سعد 241)",,,7102,,
7103,"حَدَّثَنَا وَکِیعٌ ، قَالَ : أَخْبَرَنَا جَعْفَرُ بْنُ بُرْقَانَ ، عَنْ مَیْمُونِ بْنِ مِہْرَانَ فِی قِرَائَۃِ أُبَیِّ بْنِ کَعْبٍ : اللَّہُمَّ إنَّا نَسْتَعِینُک وَنَسْتَغْفِرُک وَنُثْنِی عَلَیْک ، وَلاَ نَکْفُرُک وَنَخْلَعُ وَنَتْرُکُ مَنْ یَفْجُرُکَ اللَّہُمَّ إیَّاکَ نَعْبُدُ وَلَک نُصَلِّی وَنَسْجُدُ وَإِلَیْک نَسْعَی وَنَحْفِدُ ، نَرْجُو رَحْمَتَکَ وَنَخْشَی عَذَابَک إنَّ عَذَابَک بِالْکُفَّارِ مُلْحِقٌ۔",,,7103,,
7104,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، عَنْ عُبَیْدِ بْنِ عُمَیْرٍ ، قَالَ : سَمِعْتُ عُمَرَ یَقْنُتُ فِی الْفَجْرِ یَقُولُ : بِسْمِ اللہِ الرَّحْمَن الرَّحِیمِ\n\nاللَّہُمَّ إنَّا نَسْتَعِینُک وَنُؤْمِنُ بِکَ وَنَتَوَکَّلُ عَلَیْک وَنُثْنِی عَلَیْک الْخَیْرَ ، وَلاَ نَکْفُرُک۔\n\nثُمَّ قَرَأَ بِسْمِ اللہِ الرَّحْمَن الرَّحِیمِ اللَّہُمَّ إیَّاکَ نَعْبُدُ وَلَک نُصَلِّی وَنَسْجُدُ وَإِلَیْک نَسْعَی وَنَحْفِدُ نَرْجُو رَحْمَتَکَ وَنَخْشَی عَذَابَک إنَّ عَذَابَک الْجِدَّ بِالْکَافِرینَ مُلْحِقٌ اللَّہُمَّ عَذِّبْ کَفَرَۃَ أَہْلِ الْکِتَابِ الَّذِینَ یَصُدُّونَ عَنْ سَبِیلِک۔",,,7104,,
7105,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حُصَیْنٌ ، قَالَ : صَلَّیْت الْغَدَاۃَ ذَاتَ یَوْمٍ وَصَلَّی خَلْفِی عُثْمَانُ بْنُ زِیَادٍ ، قَالَ: فَقَنَتُّ فِی صَلاَۃِ الصُّبْحِ ، قَالَ : فَلَمَّا قَضَیْتُ صَلاَتِی ، قَالَ لِی مَا قُلْتَ فِی قُنُوتِکَ ، قَالَ : فَقُلْتُ ذَکَرْتُ ہَؤُلاَئِ الْکَلِمَاتِ اللَّہُمَّ إنَّا نَسْتَعِینُک وَنَسْتَغْفِرُک وَنُثْنِی عَلَیْک الْخَیْرَ ، وَلاَ نَکْفُرُک وَنَخْلَعُ وَنَتْرُکُ مَنْ یَفْجُرُکَ اللَّہُمَّ إیَّاکَ نَعْبُدُ وَلَک نُصَلِّی وَنَسْجُدُ وَإِلَیْک نَسْعَی وَنَحْفِدُ نَرْجُو رَحْمَتَکَ وَنَخْشَی عَذَابَک الْجِدَّ إنَّ عَذَابَک بِالْکُفَّارِ مُلْحِقٌ۔ فَقَالَ عُثْمَانُ کَذَا کَانَ یَصْنَعُ عُمَرُ بْنُ الْخَطَّابِ وَعُثْمَانُ بْنُ عَفَّانَ۔",,,7105,,
7106,"حَدَّثَنَا وَکِیعُ بْنُ الْجَرَّاحِ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مُخَارِقٍ ، عَنْ طَارِقِ بْنِ شِہَابٍ ، أَنَّہُ صَلَّی خَلْفَ عُمَرَ بْنِ الْخَطَّابِ الْفَجْرَ ، فَلَمَّا فَرَغَ مِنَ الْقِرَائَۃِ کَبَّرَ ، ثُمَّ قَنَتَ ، ثُمَّ کَبَّرَ ، ثُمَّ رَکَعَ۔",,,7106,,
7107,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَبْدِ الأَعْلَی ، عَنْ أَبِی عَبْدِالرَّحْمَنِ السُّلَمِیِّ، أَنَّ عَلِیًّا کَبَّرَ حِینَ قَنَتَ فِی الْفَجْرِ وَکَبَّرَ حِینَ رَکَعَ۔",,,7107,,
7108,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُطَرِّفٍ ، عَنْ أَبِی الْجَہْمِ ، قَالَ : کَانَ الْبَرَائُ یُکَبِّرُ قَبْلَ أَنْ یَقْنُتَ۔",,,7108,,
7109,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مُطَرِّفٍ ، عَنْ أَبِی الْجَہْمِ ، عَنِ الْبَرَائِ ، أَنَّہُ قَنَتَ فِی الْفَجْرِ فَکَبَّرَ حِینَ فَرَغَ مِنَ الْقِرَائَۃِ وَکَبَّرَ حِینَ رَکَعَ۔",,,7109,,
7110,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنٍ ، عَنْ أَبِی سِنَانٍ ، عَنْ مَاہَانَ ، قَالَ : کَانَ یُکَبِّرُ قَبْلَ أَنْ یَقْنُتَ فِی صَلاَۃِ الْفَجْرِ۔",,,7110,,
7111,حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنٍ ، عَنْ عَبْدِ الأَعْلَی ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ، أَنَّہُ کَانَ یُکَبِّرُ قَبْلَ أَنْ یَقْنُتَ فِی صَلاَۃِ الْفَجْرِ وَحِینَ یُرِیدُ أَنْ یَرْکَعَ۔,,,7111,,
7112,حَدَّثَنَا حُمَیْدٌ عَنْ زُہَیْرٍ ، قَالَ قُلْتُ لأَبِی إِسْحَاقَ تُکَبِّرُ أَنْتَ قَبْلَ أَنْ تَقْنُتَ فِی صَلاَۃِ الْفَجْرِ ، قَالَ نَعَمْ۔,,,7112,,
7113,حَدَّثَنَا نَصْرُ بْنُ إسْمَاعِیلَ، عَنِ ابْنِ أَبِی لَیْلَی، عَنْ أَبِی إِسْحَاقَ، عَنِ الْحَارِثِ، عَنْ عَلِیٍّ، أَنَّہُ کَانَ یَفْتَتِحُ الْقُنُوتَ بِالتَّکْبِیرِ۔,,,7113,,
7114,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ جَعْفَرِ بْنِ مَیْمُونٍ ، عَنْ أَبِی عُثْمَانَ ، قَالَ : کَانَ عُمَرُ یَقْنُتُ بِنَا بَعْدَ الرُّکُوعِ وَیَرْفَعُ یَدَیْہِ حَتَّی یَبْدُوَ ضَبْعَاہُ وَیُسْمَعَ صَوْتُہُ مِنْ وَرَائِ الْمَسْجِدِ۔",,,7114,,
7115,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَعْفَرٍ صَاحِبِ الأَنْمَاطِ ، عَنْ أَبِی عُثْمَانَ ، أَنَّ عُمَرَ رَفَعَ یَدَیْہِ فِی قُنُوتِ الْفَجْرِ۔,,,7115,,
7116,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَوْفٍ ، عَنْ خَلاَّسِ بْنِ عَمْرٍو الْہَجَرِیِّ ، عَنِ ابْنِ عَبَّاسٍ ، أنَّہُ صَلَّی فَقَنَتَ بِہِمْ فِی الْفَجْرِ بِالْبَصْرَۃِ فَرَفَعَ یَدَیْہِ حَتَّی مَدَّ ضَبْعَیْہِ۔",,,7116,,
7117,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ عَوْفٍ ، عَنْ أَبِی رَجَائٍ ، قَالَ : رَأَیْتُ ابْنَ عَبَّاسٍ یَمُدُّ بِضَبْعَیْہِ فِی قُنُوتِ صَلاَۃِ الْغَدَاۃِ۔",,,7117,,
7118,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ أَبِی فَرْوَۃَ ، قَالَ : کَانَ ابْنُ أَبِی لَیْلَی یَدْعُو بِإِصْبَعٍ وَاحِدَۃٍ یَقُولُ فِی قُنُوتِ الْفَجْرِ۔",,,7118,,
7119,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : لَمَّا رَفَعَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَأْسَہُ مِنْ صَلاَۃِ الصُّبْحِ ، قَالَ اللَّہُمَّ أَنْجِ الْوَلِیدَ بْنَ الْوَلِیدِ وَسَلَمَۃَ بْنَ ہِشَامٍ وَعَیَّاشَ بْنَ أَبِی رَبِیعَۃَ وَالْمُسْتَضْعَفِینَ بِمَکَّۃَ اللَّہُمَّ اشْدُدْ وَطْأَتَکَ عَلَی مُضَرَ وَاجْعَلْہَا عَلَیْہِمْ سِنِینَ کَسِنِی یُوسُفَ۔ (بخاری 6200۔ مسلم 294)",,,7119,,
7120,"حَدَّثَنَا یَعْقُوبُ بْنُ إِبْرَاہِیمَ، عَن یَزِیدَ بْنِ أَبِی زِیَادٍ، عَنِ ابْنِ یُحَنَّسَ، عَنْ سَعِیدِ بْنِ زَیْدٍ، قَالَ: قَنَتَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : اللَّہُمَّ الْعَنْ رِعْلاً وَذَکْوَانَ وَعَضَلاً ، وَعُصَیَّۃَ عَصَتِ اللَّہَ وَرَسُولَہُ۔",,,7120,,
7121,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَبْدِ الأَعْلَی ، أَنَّ أَبَا عَبْدِ الرَّحْمَنِ السُّلَمِیَّ قَنَتَ فِی الْفَجْرِ یَدْعُو عَلَی قُطَرِی۔",,,7121,,
7122,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَمْرِو بْنِ قَیْسٍ عَمَّنْ سَمِعَ إبْرَاہِیمَ یَقُولُ لاَ یُسَمَّی الرِّجَالُ فِی الصَّلاَۃ۔,,,7122,,
7123,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حُصَیْنٌ ، قَالَ : حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَعْقِلٍ ، قَالَ : صَلَّیْت مَعَ عَلِیٍّ صَلاَۃَ الْغَدَاۃِ ، قَالَ : فَقَنَتَ ، فَقَالَ فِی قُنُوتِہِ : اللَّہُمَّ عَلَیْک بِمُعَاوِیَۃَ وَأَشْیَاعِہِ وَعَمْرِو بْنِ الْعَاصِ وَأَشْیَاعِہِ ، وَأَبِی الأعور السُّلَمِیِّ ، وَعَبْدِ اللہِ بْنِ قَیْسٍ وَأَشْیَاعِہِ۔",,,7123,,
7124,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ یَحْیَی بْنِ حَبَّانَ ، قَالَ مَکَثَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَرْبَعِینَ صَبَاحًا یَقْنُتُ فِی صَلاَۃِ الصُّبْحِ بَعْدَ الرُّکُوعِ وَکَانَ یَقُولُ فِی قُنُوتِہِ : اللَّہُمَّ أَنْجِ الْوَلِیدَ بْنَ الْوَلِیدِ وَعَیَّاشَ بْنَ أَبِی رَبِیعَۃَ وَالْعَاصَ بْنَ ہِشَامٍ وَالْمُسْتَضْعَفِینَ مِنَ الْمُؤْمِنِینَ بِمَکَّۃَ الَّذِینَ لاَ یَسْتَطِیعُونَ حِیلَۃً ، وَلاَ یَہْتَدُونَ سَبِیلاً۔",,,7124,,
7125,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا مُحَمَّدُ بْنُ إِسْحَاقَ ، عَنْ عِمْرَانَ بْنِ أَبِی أَنَسٍ ، عَنْ حَنْظَلَۃَ بْنِ عَلِیٍّ الأَسْلَمِیِّ ، عَنْ خُفَافِ بْنِ إیمَائِ بْنِ رَحَضَۃَ الْغِفَارِیِّ ، قَالَ : صَلَّی بِنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْفَجْرَ ، فَلَمَّا رَفَعَ رَأْسَہُ مِنَ الرَّکْعَۃِ الآخِرَۃِ ، قَالَ : لَعَنَ اللَّہُ لِحْیَانًا وَرِعْلاً وَذَکْوانًا وَعُصَیَّۃَ عَصَتِ اللَّہَ وَرَسُولَہُ أَسْلَمُ سَالَمَہَا اللَّہُ ، غِفَارٌ غَفَرَ اللَّہُ لَہَا ، ثُمَّ خَرَّ سَاجِدًا ، فَلَمَّا قَضَی الصَّلاَۃ أَقْبَلَ عَلَی النَّاسِ بِوَجْہِہِ ، فَقَالَ : أَیُّہَا النَّاسُ إنِّی أَنَا لَسْتُ قُلْتُ ہَذَا وَلَکِنَّ اللَّہَ ، قَالَہُ۔ (مسلم 307۔ احمد 57)",,,7125,,
7126,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : إذَا نَسِیَ الْقُنُوتَ فِی الْفَجْرِ فَعَلَیْہِ سَجْدَتَا السَّہْوِ۔",,,7126,,
7127,"حَدَّثَنَا شَرِیکٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، قَالَ : سُئِلَ عَنْ رَجُلٍ سَہَا فَقَنَتَ ، فَقَالَ : ہَذَا سَہَا فَأَصَابَ۔",,,7127,,
7128,"حَدَّثَنَا الْوَلِیدُ بْنُ عُقْبَۃَ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ مَنْ رَأَی الْقُنُوتَ فَلَمْ یَقْنُتْ فَعَلَیْہِ سَجْدَتَا السَّہْوِ۔",,,7128,,
7129,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ووَکِیعٌ وَغُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْبَرَائِ بْنِ عَازِبٍ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَنَتَ فِی الصُّبْحِ وَالْمَغْرِبِ۔ قَالَ : فَقَالَ : إبْرَاہِیمُ أَہُوَ کَأَصْحَابِ عَبْدِ اللہِ إنَّمَا ہُوَ کَانَ صَاحِبَ أُمَرَائَ ، وَلَمْ یَذْکُرْ وَکِیعٌ قَوْلَ إبْرَاہِیمَ۔ (ترمذی 401۔ ابوداؤد 1436)",,,7129,,
7130,حَدَّثَنَا شَرِیکٌ ، عَنْ حُصَیْنٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ مَعقِلٍ ، قَالَ صَلَّیْت خَلْفَ عَلِیٍّ الْمَغْرِبَ ، فَقَنَتَ۔,,,7130,,
7131,حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنْ خَالِدٍ، عَنْ أَبِی قِلاَبَۃَ، عَنْ أَنَسٍ، قَالَ صَلاَتَانِ کَانَ یُقْنَتُ فِیہِمَا الْمَغْرِبُ وَالْفَجْرُ۔,,,7131,,
7132,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ عَبْدِ اللہِ بْنِ خَالِدٍ ، عَنِ ابْنِ مَعقِلٍ ، قَالَ قَنَتَ عَلِیٌّ فِی الْمَغْرِبِ۔,,,7132,,
7133,"حَدَّثَنَا شَرِیکٌ ، عَنْ ثَابِتٍ الثُّمَالِیِّ ، قَالَ : سَأَلْتُ أَبَا جَعْفَرٍ ، عَنِ الْقُنُوتِ ، فَقَالَ : کُلُّ صَلاَۃٍ یُجْہَرُ فِیہَا فَفِیہَا الْقُنُوتُ۔",,,7133,,
7134,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ الأَعْمَشِ ، عَنِ الْمِنْہَالِ ، عَنْ أَبِی عُبَیْدَۃَ ، قَالَ رَأَی عَبْدُ اللہِ رَجُلاً یُصَلِّی صَافًّا بَیْنَ قَدَمَیْہِ ، فَقَالَ : لَوْ رَاوَحَ ہَذَا بَیْنَ قَدَمَیْہِ کَانَ أَفْضَلَ۔",,,7134,,
7135,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَیْسَرَۃَ النَّہْدِیِّ ، عَنِ الْمِنْہَالِ ، عَنْ أَبِی عُبَیْدَۃَ ، قَالَ : خَرَجَ عَبْدُ اللہِ مِنْ دَارِہِ إلَی الْمَسْجِدِ ، فَإِذَا رَجُلٌ یُصَلِّی صَافًّا بَیْنَ قَدَمَیْہِ ، فَقَالَ عَبْدُ اللہِ أَمَّا ہَذَا فَقَدْ أَخْطَأَ السُّنَّۃَ وَلَوْ رَاوَحَ بَیْنَ قَدَمَیْہِ کَانَ أَحَبَّ إلَیَّ۔ (نسائی 967)",,,7135,,
7136,"حَدَّثَنَا وَکِیعٌ ، عَنْ عُیَیْنَۃَ بْنِ عَبْدِ الرَّحْمَنِ ، قَالَ : کُنْتُ مَعَ أَبِی فِی الْمَسْجِدِ فَرَأَی رَجُلاً صَافًّا بَیْنَ قَدَمَیْہِ ، فَقَالَ : أَلْزِقْ إحْدَاہُمَا بِالأُخْرَی لَقَدْ رَأَیْت فِی ہَذَا الْمَسْجِدِ ، ثَمَانیَۃَ عَشَرَ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَا رَأَیْت أَحَدًا مِنْہُمْ فَعَلَ ہَذَا قَطُّ۔",,,7136,,
7137,"حَدَّثَنَا شَرِیکٌ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : رَأَیْتُ عَمْرَو بْنَ مَیْمُونٍ یُرَاوِحُ بَیْنَ قَدَمَیْہِ فِی الصَّلاَۃ۔",,,7137,,
7138,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بن أَبِی خَالِدٍ ، قَالَ : رَأَیْتُ عَمْرَو بْنَ مَیْمُونٍ یُرَاوِحُ بَیْنَ قَدَمَیْہِ یَضَعُ ہَذِہِ عَلَی ہَذِہِ وَہَذِہِ عَلَی ہَذِہِ۔",,,7138,,
7139,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ یُوسُفَ بْنِ عَبْدَۃَ ، قَالَ : رَأَیْتُ ابْنَ سِیرِینَ یُصَلِّی وَہُوَ ہَکَذَا ، یَعْنِی یُقَدِّمُ رِجْلاً وَیُؤَخِّرُ أُخْرَی۔",,,7139,,
7140,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ ، قَالَ : کَانَ ابْنُ سِیرِینَ یُرَاوِحُ بَیْنَ قَدَمَیْہِ فِی الصَّلاَۃ۔",,,7140,,
7141,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ عَبْدِ اللہِ بْنِ رَاشِدٍ ، قَالَ : رَأَیْتُ مَکْحُولاً یَتَّکیئُ عَلَی قَدَمَیْہِ عَلَی ہَذِہِ مَرَّۃً وَعَلَی ہَذِہِ مَرَّۃً فِی الصَّلاَۃ۔",,,7141,,
7142,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ خَالِدِ بْنِ أَبِی بَکْرٍ ، قَالَ : رَأَیْتُ سَالِمًا لاَ یَصُفُّ قَدَمَیْہِ فِی الصَّلاَۃ وَیُحَرِّکُہَا وَہُوَ یُصَلِّی۔",,,7142,,
7143,حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ رَجُلٍ ، أَنَّ ابْنَ الزُّبَیْرِ کَانَ یَصُفُّ بَیْنَ قَدَمَیْہِ فِی الصَّلاَۃ۔,,,7143,,
7144,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، قَالَ : أَخْبَرَنِی مَنْ رَأَی ابْنَ الزُّبَیْرِ یُصَلِّی قَدْ صَفَّ بَیْنَ قَدَمَیْہِ وَأَلْزَقَ إحْدَاہُمَا بِالأُخْرَی۔",,,7144,,
7145,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ حُصَیْنٍ ، قَالَ : رَأَیْتُ ابْنَ مَعقِلٍ یُصَلِّی صَافًّا بَیْنَ قَدَمَیْہِ۔",,,7145,,
7146,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : رَأَیْتُ مُسْلِمَ بْنَ یَسَارٍ یُصَلِّی کَأَنَّہُ وِدٌّ لاَ یَتَرَوَّحُ عَلَی رِجْلٍ مَرَّۃً وَعَلَی رِجْلٍ مَرَّۃً۔",,,7146,,
7147,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ شُعْبَۃَ ، عَنْ سَعْدِ بْنِ إبْرَاہِیمَ ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ یُصَلِّی صَافًّا بَیْنَ قَدَمَیْہِ فِیمَا نَعْلَمُ۔",,,7147,,
7148,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ إسْمَاعِیلَ بْنِ مُسْلِمٍ ، عَنْ مَالِکِ بْنِ دِینَارٍ ، قَالَ : رَأَیْتُ عِکْرِمَۃَ یُصَلِّی صَافًّا بَیْنَ قَدَمَیْہِ۔",,,7148,,
7149,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ قُرَیْشِ بْنِ حَیَّانَ ، قَالَ : رَأَیْتُ الْحَسَنَ یُصَلِّی صَافًّا بَیْنَ قَدَمَیْہِ۔",,,7149,,
7150,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ مُخْتَارِ بْنِ سَعْدٍ ، قَالَ : رَأَیْتُ الْقَاسِمَ بْنَ مُحَمَّدٍ یَصُفُّ رِجْلَیْہِ فِی الصَّلاَۃ ، وَلاَ یُرَاوِحُ بَیْنَہُمَا۔",,,7150,,
7151,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ حُصَیْنٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : مَنْ دَخَلَ الْمَسْجِدَ وَقَدْ سُبِقَ بِالصَّلاَۃ ، قَالَ یَبْدَأُ بِالْمَکْتُوبَۃِ۔",,,7151,,
7152,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃ۔ وَحَفص ، عن الأَعمَش ، عَن إِبْرَاہِیم قَالَ : یَبْدَأُ بِالْمَکْتُوبَۃِ۔",,,7152,,
7153,حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ رَجُلٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ یَبْدَأُ بِالْمَکْتُوبَۃِ۔,,,7153,,
7154,حَدَّثَنَا ہُشَیْمٌ ووَکِیعٌ ، عَنِ ابْنِ عَوْنٍ ، عَنِ الشَّعْبِیِّ ، قَالَ ابْدَأْ بِالَّذِی جِئْت لَہُ۔,,,7154,,
7155,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ ابْنِ عَوْنٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : ابْدَأْ بِالْمَکْتُوبَۃِ۔",,,7155,,
7156,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الزُّبَیْرِ بْنِ عَدِیٍّ ، عَنْ إبْرَاہِیمَ ، قَالَ ابْدَأْ بِالْمَکْتُوبَۃِ۔,,,7156,,
7157,حَدَّثَنَا وَکِیعٌ ، عَنْ أَفْلَحَ ، قَالَ جِئْت أَنَا وَالْقَاسِمُ الْمَسْجِدَ وَقَدْ صَلَّوْا فَصَلَّی لِنَفْسِہِ ، یَعْنِی بَدَأَ بِالْمَکْتُوبَۃِ۔,,,7157,,
7158,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، قَالَ : کَانُوا یَبْدَؤُونَ بِالْمَکْتُوبَۃِ۔",,,7158,,
7159,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : قَالَ الْحَکَمُ : کَانُوا یَبْدَؤُونَ بِالْفَرِیضَۃِ۔ وَقَالَ أبو إِسْحَاقَ : کَانُوا یَبْدَؤُونَ بِالْفَرِیضَۃِ۔",,,7159,,
7160,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنِ الْعَبَّاسِ بْنِ ذَرِیحٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : مَثَلُ الَّذِی یَدْخُلُ الْمَسْجِدَ وَقَدْ صُلِّی فِیہِ فَیَتَطَوَّعُ مَثَلُ الَّذِی یَعْتَمِرُ قَبْلَ أَنْ یَحُجَّ۔",,,7160,,
7161,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، قَالَ ابْدَأْ بِالَّذِی جِئْت لَہُ۔,,,7161,,
7162,حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ مِسْعَرٍ ، عَنِ الْعَبَّاسِ بْنِ ذَرِیحٍ ، عَنِ ابْنِ عَبَّاسٍ فِی رَجُلٍ دَخَلَ مَسْجِدًا وَقَدْ صَلَّی أَہْلُہُ أَیَتَطَوَّعُ ، قَالَ ہُوَ کَرَجُلٍ یَتَطَوَّعُ قَبْلَ أَنْ یَحُجَّ۔,,,7162,,
7163,حَدَّثَنَا ہُشَیْمٌ ، عَنْ مَنْصُورٍ ، وَیُونُس ، عَنِ الْحَسَنِ أَنَّہ کَانَ لاَ یَرَی بَأْسًا أَنْ یَتَطَوَّعَ۔,,,7163,,
7164,حَدَّثَنَا ہُشَیْمٌ ، عَنْ حُصَیْنٍ ، عَنْ زِرٍّ ، قَالَ یَتَطَوَّعُ إِنْ شَائَ۔,,,7164,,
7165,حَدَّثَنَا ہُشَیْمٌ ، عَنِ الْعَوَّامِ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی الْہُذَیْلِ ، أَنَّہُ کَانَ یَتَطَوَّعُ إذَا سُبِقَ بِالْمَکْتُوبَۃِ۔,,,7165,,
7166,"حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : سُئِلَ الْحَسَنُ ، عَنِ الرَّجُلِ یَدْخُلُ الْمَسْجِدَ وَقَدْ صَلَّی أَہْلُہُ ، قَالَ: فَقَالَ : أَمَّا أَنَا فَکُنْت أُصَلِّی کَمَا کُنْت أُصَلِّی قَبْلَ ذَلِکَ۔",,,7166,,
7167,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ حَمَّادٍ ، قَالَ : لاَ بَأْسَ بِہِ إذَا کَانَ فِی وَقْتِ صَلاَۃٍ۔",,,7167,,
7168,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، قَالَ : قَالَ حَمَّادٌ : یَتَطَوَّعُ إِنْ شَائَ۔",,,7168,,
7169,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یُونُسُ بْنُ عُبَیْدٍ ، قَالَ : حَدَّثَنِی أَبُو عُثْمَانَ الْیَشْکُرِیُّ ، قَالَ : مَرَّ بِنَا أَنَسُ بْنُ مَالِکٍ وَقَدْ صَلَّیْنَا صَلاَۃَ الْغَدَاۃِ وَمَعَہُ رَہْطٌ فَأَمَرَ رَجُلاً مِنْہُمْ فَأَذَّنَ ، ثُمَّ صَلَّوْا رَکْعَتَیْنِ قَبْلَ الْفَجْرِ۔ قَالَ ، ثُمَّ أَمَرَہُ فَأَقَامَ ، ثُمَّ تَقَدَّمَ فَصَلَّی بِہِمْ۔",,,7169,,
7170,حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنِ الْجَعْدِ أَبِی عُثْمَانَ ، عَنْ أَنَسٍ بِمِثْلِہِ۔,,,7170,,
7171,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ، عَنْ أَبِی حُرَّۃَ ، قَالَ دَخَلْت أَنَا، وَعَبْدُ اللہِ بْنُ حُمَیْدٍ مَسْجِدًا وَقَدْ صُلِّیَ فِیہِ ، فقَالَ : أَلاَ تَجِیئُ حَتَّی نُصَلِّیَ فِی جَمَاعَۃٍ قُلْتُ : إنَّ بَعْضَہُمْ قَدْ کَرِہَ ذَلِکَ ، قَالَ : کَانَ أَبِی لاَ یَرَی بِذَلِکَ بَأْسًا۔",,,7171,,
7172,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ سُلَیْمَانَ النَّاجِی ، عَنْ أَبِی الْمُتَوَکِّلِ، عَنْ أَبِی سَعِیدٍ، قَالَ : جَائَ رَجُلٌ وَقَدْ صَلَّی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : أَیُّکُمْ یَتَّجِرُ عَلَی ہَذَا ، قَالَ فَقَامَ رَجُلٌ مِنَ الْقَوْمِ فَصَلَّی مَعَہُ۔ (ترمذی 220۔ احمد 3/64)",,,7172,,
7173,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ أَخْبَرَنَا سُلَیْمَانُ التَّیْمِیُّ ، عَنْ أَبِی عُثْمَانَ ، قَالَ : دَخَلَ رَجُلٌ الْمَسْجِدَ وَقَدْ صَلَّی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : أَلا رَجُلٌ یَتَصَدَّقُ عَلَی ہَذَا فَیَقُومُ فَیُصَلِّی مَعَہُ۔",,,7173,,
7174,حَدَّثَنَا شَرِیکٌ ، عَنْ عَبْدِ اللہِ بْنِ یَزِیدَ ، قَالَ دَخَلْت مَعَ إبْرَاہِیمَ مَسْجِدَ مُحَارِبٍ وَقَدْ صَلَّوْا فَأَمَّنِی۔,,,7174,,
7175,حَدَّثَنَا ہُشَیْمٌ ، عَنْ زِیَادٍ مَوْلَی قُرَیْشٍ ، قَالَ دَخَلْت مَعَ الْحَسَنِ مَسْجِدَ الْبَصْرَۃِ فَوَجَدْنَاہُمْ قَدْ صَلَّوْا فَصَلَّی بِی۔,,,7175,,
7176,حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ تُصَلَّی الْجَمَاعَۃُ بَعْدَ الْجَمَاعَۃِ فِی مَسْجِدِ الْکلاّئِ بِالْبَصْرَۃِ۔,,,7176,,
7177,"حَدَّثَنَا ہُشَیْمٌ، قَالَ: أَخْبَرَنَا مَنْصُورٌ، عَنِ الْحَسَنِ، قَالَ: إنَّمَا کَانُوا یکْرَہُونَ أَنْ یَجْمَعُوا مَخَافَۃَ السُّلْطَانِ۔",,,7177,,
7178,حَدَّثَنَا وَکِیعٌ ، عَنْ مُسَافِرٍ الْجَصَّاصِ ، عَنْ فُضَیْلِ بْنِ عَمْرٍو ، أَنَّ عَدِیَّ بْنَ ثَابِتٍ وَأَصْحَابًا لَہُ رَجَعُوا مِنْ جِنَازَۃٍ فَدَخَلُوا مَسْجِدًا قَدْ صُلِّیَ فِیہِ فَجَمَعُوا فَکَرِہَ ذَلِکَ إبْرَاہِیمُ۔,,,7178,,
7179,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ رَبِّہِ بْنِ أَبِی رَاشِدٍ ، قَالَ : حدَّثَنَا الحیُّ ، قَالَ جَائَنَا أَنَسُ بْنُ مَالِکٍ وَقَدْ صَلَّیْنَا الْغَدَاۃَ فَأَقَامَ الصَّلاَۃ ، ثُمَّ صَلَّی بِہِم فَقَامَ وَسَطَہُمْ۔",,,7179,,
7180,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَمْرِو بْنِ مُحَمَّدٍ ، عَنْ عَطَائٍ ، أَنَّہُ صَلَّی ہُوَ وَسَلْم بْنُ عَطِیَّۃَ فِی الْمَسْجِدِ الْحَرَامِ فِی جَمَاعَۃٍ بَعْدَ مَا صَلَّی أَہْلُہُ۔,,,7180,,
7181,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، أَنَّہُ قَالَ : یُصَلُّونَ جَمِیعًا فِی صَفٍّ وَاحِدٍ إمَامُہُمْ وَسَطُہُمْ۔",,,7181,,
7182,حَدَّثَنَا إِسْحَاقُ الأَزْرَقُ ، عَنْ عَبْدِ الْمَلِکِ بْنِ أَبِی سُلَیْمَانَ ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ ، أَنَّ ابْنَ مَسْعُودٍ دَخَلَ الْمَسْجِدَ وَقَدْ صَلَّوْا فَجَمَّعَ بِعَلْقَمَۃَ وَمَسْرُوقٍ وَالأَسْوَدِ۔,,,7182,,
7183,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، أَنَّہُ کَانَ یَقُولُ : یُصَلُّونَ فُرَادَی۔",,,7183,,
7184,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخبَرَنا خَالِد ، عَنْ أَبِی قِلاَبَۃَ أَنَّہُ کَانَ یَقُولُ : یُصَلُّونَ فُرَادَی۔",,,7184,,
7185,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ، قَالَ : یُصَلُّونَ فُرَادَی۔",,,7185,,
7186,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : یُصَلُّونَ شَتَّی۔",,,7186,,
7187,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ ہِشام الدَّستوائی ، عَن حَمَّاد ، عَن إِبْرَاہِیم قَالَ : یُصَلُّونَ فُرَادَی۔",,,7187,,
7188,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی ہِلاَلٍ ، عَنْ کَثِیرٍ ، عَنِ الْحَسَنِ ، قَالَ : کَانَ أَصْحَابُ مُحَمَّدٍ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا دَخَلُوا الْمَسْجِدَ وَقَدْ صُلِّیَ فِیہِ صَلَّوْا فُرَادَی۔",,,7188,,
7189,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَفْلَحَ ، قَالَ : دَخَلْنَا مَعَ الْقَاسِمِ الْمَسْجِدَ وَقَدْ صُلِّیَ فِیہِ ، قَالَ : فَصَلَّی الْقَاسِمُ وَحْدَہُ۔",,,7189,,
7190,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مَنْصُورٌ ، عَنِ الْحَسَنِ ، عَنْ عَلِیٍّ ، أَنَّہُ کَانَ یَقُولُ : مَنْ أَدْرَکَ مَعَ الإِمَامِ رَکْعَتَیْنِ ، قَالَ : یَقْرَأُ فِیمَا أَدْرَکَ۔",,,7190,,
7191,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ رَبِیعۃَ بْنِ أَبِی عَبْدِ الرَّحْمَنِ ، أَنَّ عُمَرَ بْنَ الْخَطَّابِ وَأَبَا الدَّرْدَائِ کَانَا یَقُولاَنِ : مَا أَدْرَکْت مِنْ صَلاَۃِ الإِمَام فَاجْعَلْہُ أَوَّلَ صَلاَتِک۔",,,7191,,
7192,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ عَمْرِو بْنِ مُہَاجِرٍ ، قَالَ : سَمِعْتُ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ یَقُولُ : اجْعَلْہُ أَوَّلَ صَلاَتِک۔",,,7192,,
7193,"حَدَّثَنَا عَبْدَۃُ، عَنْ سَعِیدٍ، عَنْ قَتَادَۃَ، عَنْ سَعِیدٍ، وَالْحَسَنِ، قَالاَ: مَا أَدْرَکْت مَعَ الإِمَامِ فَہُوَ أَوَّلُ صَلاَتِک۔",,,7193,,
7194,حَدَّثَنَا عَبْدَۃُ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ عَلِیٍّ مِثْلَہُ۔,,,7194,,
7195,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ الأَعْمَشِ ، قَالَ : کَانَ سَعِیدُ بْنُ جُبَیْرٍ یَقُولُ : یَقْرَأُ فِیمَا أَدْرَکَ لأَنَّہُ کَانَ یُسِرُّ الْقِرَائَۃَ خَلْفَ الإِمَام۔",,,7195,,
7196,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ أَشْعَثَ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ؛ فِی الرَّجُلِ تَفُوتُہُ مَعَ الإِمَامِ الرَّکْعَۃُ ، أَوِ الرَّکْعَتَانِ ، قَالَ : یَقْرَأُ فِی سَکْتَۃِ الإِمَام۔ وَقَالَ الْحَسَنُ مِثْلَہُ۔",,,7196,,
7197,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَبْدِ اللہِ ، قَالَ : مَا أَدْرَکْت مَعَ الإِمَامِ فَہُوَ آخِرُ صَلاَتِک۔",,,7197,,
7198,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ قَتَادَۃَ ، عَنِ ابْنِ سِیرِینَ ، عَنِ ابْنِ مَسْعُودٍ ، قَالَ : اجْعَلْ آخِرَ صَلاَتِکَ أَوَّلُ صَلاَتک۔",,,7198,,
7199,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ یَجْعَلُ مَا أَدْرَکَ مَعَ الإِمَامِ آخِرَ صَلاَتِہِ۔,,,7199,,
7200,حَدَّثَنَا حَفْصٌ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ إذَا أَدْرَکَ مَعَ الإِمَامِ لَمْ یَقْرَأْ فَإِذَا قَامَ یَقْضِی قَرَأَ۔,,,7200,,
7201,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ قَالَ : اقْرَأْ فِیمَا تَقْضِی۔",,,7201,,
7202,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حُصَیْنٌ وَمُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ، قَالَ : یَقْرَأُ فِیمَا یَقْضِی۔",,,7202,,
7203,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : سَأَلْتُ مُجَاہِدًا ، عَنْ رَجُلٍ فَاتَتْہُ رَکْعَتَانِ مَعَ الإِمَامِ فَقَرَأَ فِیہِمَا قَالَ : اجْعَلْ آخِرَ صَلاَتِکَ أَوَّلَ صَلاَتِک۔",,,7203,,
7204,"حَدَّثَنَا عَبْدُ الْوَہَّابِ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ فِی رَجُلٍ تَفُوتُہُ بَعْضُ الصَّلاَۃ فَیَقُومُ یَقْضِی ، قَالَ : یَجْعَلُ مَا بَقِیَ أَوَّلَ صَلاَتِہِ وَإِنْ عَلِمْت مَا الَّذِی قَرَأَہُ الإِمَام فَاقْرَأْہُ۔",,,7204,,
7205,"حَدَّثَنَا وَکِیعٌ ، عَنْ نَافِعِ بْنِ عُمَرَ ، قَالَ : سَمِعْتُ عَمْرَو بْنَ دِینَارٍ یَقُولُ : اقْضِ مَا فَاتَکَ کَمَا فَاتَک۔",,,7205,,
7206,"حَدَّثَنَا یَعْقُوبُ بْنُ إِبْرَاہِیمَ ، عَن أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، وَابْنِ سِیرِینَ ، أَنَّہُمَا قَالاَ : فِیمَنْ سَبَقَہُ الإِمَام إذَا قَضَیْت بَعْدَہُ فَاقْضِ قِرَائَتَک۔",,,7206,,
7207,"حَدَّثَنَا ابْنُ عُیینََۃَ، عَنْ عَمْرٍو قَالَ: فَاتَتْ عُبَیْدَ بْنَ عُمَیْرٍ رَکْعَۃٌ مِنَ الْمَغْرِبِ فَسَمِعْتُہُ یَقْرَأُ وَاللَّیْلِ إذَا یَغْشَی۔",,,7207,,
7208,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنِ الأَعْمَشِ ، قَالَ : کَانَ إبْرَاہِیمُ النَّخْعِی یَقْرَأُ فِیمَا یَقْضِی۔",,,7208,,
7209,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : یُکْرَہُ أَنْ یَرْفَعَ إحْدَی رِجْلَیْہِ عَلَی الأُخْرَی فِی الصَّلاَۃ ، أَوْ یَسْتَنِدُ إلَی جِدَارٍ إِلاَّ مِنْ عِلَّۃٍ۔",,,7209,,
7210,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ یَحْیَی بْنِ ہَانِیئٍ ، قَالَ : رَأَیْتُ عَمْرَو بْنَ مَیْمُونٍ قَائِمًا یُصَلِّی وَاضِعًا إحْدَی رِجْلَیْہِ عَلَی الأُخْرَی۔",,,7210,,
7211,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، قَالَ : سَمِعْتُ أَنَسًا ، قَالَ : سَقَطَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، عَنْ فَرَسٍ فَجُحِشَ شِقُّہُ الأَیْمَنُ فَدَخَلْنَا عَلَیْہِ نَعُودُہُ فَحَضَرَتِ الصَّلاَۃ فَصَلَّی بِنَا قَاعِدًا فَصَلَّیْنَا وَرَائَہُ قُعُودًا، فَلَمَّا قَضَی الصَّلاَۃ ، قَالَ : إنَّمَا جُعِلَ الإِمَام لِیُؤْتَمَّ بِہِ فَإِذَا کَبَّرَ فَکَبِّرُوا ، وَإِذَا رَکَعَ فَارْکَعُوا ، وَإذَا قَالَ سَمِعَ اللَّہُ لِمَنْ حَمِدَہُ فَقُولُوا رَبَّنَا وَلَک الْحَمْدُ ، وَإِذَا صَلَّی قَاعِدًا فَصَلُّوا قُعُودًا أَجْمَعُونَ۔ (بخاری 1114۔ مسلم 77)",,,7211,,
7212,"حَدَّثَنَا عَبْدَۃُ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، قَالَتِ : اشْتَکَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَدَخَلَ نَاسٌ مِنْ أَصْحَابِہِ یَعُودُونَہُ فَصَلَّی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ جَالِسًا فَصَلَّوا بِصَلاَتِہِ قِیَامًا فَأَشَارَ إلَیْہِمْ أَنِ اجْلِسُوا فَجَلَسُوا ، فَلَمَّا انْصَرَفَ ، قَالَ : إنَّمَا جُعِلَ الإِمَام لِیُؤْتَمَّ بِہِ فَإِذَا رَکَعَ فَارْکَعُوا ، وَإِذَا رَفَعَ فَارْفَعُوا ، وَإِذَا صَلَّی جَالِسًا فَصَلُّوا جُلُوسًا۔ (بخاری 688۔ ابوداؤد 605)",,,7212,,
7213,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ أَبِی سُفْیَانَ ، عَنْ جَابِرٍ ، قَالَ : صُرِعَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ فَرَسٍ لَہُ فَوَقَعَ عَلَی جِذْعِ نَخْلَۃٍ فَانْفَکَّتْ قَدَمُہُ فَدَخَلْنَا عَلَیْہِ نَعُودُہُ وَہُوَ یُصَلِّی فِی مَشْرُبَۃٍ لِعَائِشَۃَ جَالِسًا فَصَلَّیْنَا بِصَلاَتِہِ وَنَحْنُ قِیَامٌ ، ثُمَّ دَخَلْنَا عَلَیْہِ مَرَّۃً أُخْرَی وَہُوَ یُصَلِّی جَالِسًا فَصَلَّیْنَا بِصَلاَتِہِ وَنَحْنُ قِیَامٌ فَأَوْمَأَ إلَیْنَا أَنِ اجْلِسُوا ، فَلَمَّا صَلَّی ، قَالَ : إنَّمَا جُعِلَ الإِمَام لِیُؤْتَمَّ بِہِ فَإِذَا صَلَّی قَائِمًا فَصَلُّوا قِیَامًا ، وَإِذَا صَلَّی جَالِسًا فَصَلُّوا جُلُوسًا ، وَلاَ تَقُومُوا وَہُوَ جَالِسٌ کَمَا تَفْعَلُ أَہْلُ فَارِسٍ بِعُظَمَائِہِمْ۔ (ابوداؤد 602۔ احمد 3/334)",,,7213,,
7214,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنَ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، عْن أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّمَا جُعِلَ الإِمَام لِیُؤْتَمَّ بِہِ فَإِذَا کَبَّرَ فَکَبِّرُوا ، وَإِذَا قَرَأَ فَأَنْصِتُوا، وَإذَا قَالَ غَیْرِ الْمَغْضُوبِ عَلَیْہِمْ ، وَلاَ الضَّالِّینَ فَقُولُوا آمِین ، وَإِذَا رَکَعَ فَارْکَعُوا ، وَإذَا قَالَ سَمِعَ اللَّہُ لِمَنْ حَمِدَہُ فَقُولُوا اللَّہُمَّ رَبَّنَا لَکَ الْحَمْدُ ، وَإِذَا سَجَدَ فَاسْجُدُوا ، وَإِذَا صَلَّی جَالِسًا فَصَلُّوا جُلُوسًا۔",,,7214,,
7215,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، قَالَ : أَخْبَرَنِی أَبُو الزُّبَیْرِ ، أَنَّ جَابِرًا اشْتَکَی عِنْدَہُمْ بِمَکَّۃَ ، فَلَمَّا أَنْ تَمَاثَلَ خَرَجَ وَإِنَّہُمْ خَرَجُوا مَعَہُ یَتْبَعُونَہُ حَتَّی إذَا بَلَغُوا بَعْضَ الطَّرِیقِ حَضَرَتْ صَلاَۃٌ مِنَ الصَّلَوَاتِ فَصَلَّی بِہِمْ جَالِسًا وَصَلَّوْا مَعَہُ جُلُوسًا۔",,,7215,,
7216,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، عَنْ قَیْسٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : الإِمَام أَمِیرٌ ، فَإِنْ صَلَّی قَائِمًا فَصَلُّوا قِیَامًا وَإِنْ صَلَّی قَاعِدًا فَصَلُّوا قُعُودًا۔",,,7216,,
7217,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ إسْمَاعِیلَ ، عَنْ قَیْسِ بْنِ قَہْدٍ ، قَالَ اشْتَکَی إمَامُنَا فَصَلَّی قَاعِدًا أَیَّامًا فَصَلَّیْنَا بِصَلاَتِہِ ، فَقَالَ : أَبُو ہُرَیْرَۃَ الإِمَام أَمِیْرٌ، فَإِنْ صَلَّی قَائِمًا فَصَلُّوا قِیَامًا وَإِنْ صَلَّی قَاعِدًا فَصَلُّوا قُعُودًا۔",,,7217,,
7218,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عَبْدِ اللہِ بْنِ ہُبَیْرَۃَ ، أَنَّ أُسَیْدَ بْنَ حُضَیْرٍ کَانَ یَؤُمُّ قَومَہُ بَنِی عَبْدِ الأَشْہَلِ وَأَنَّہُ اشْتَکَی فَخَرَجَ إلَیْہِمْ بَعْدَ شَکْوَاہُ ، فَقَالُوا لَہُ تَقَدَّمْ ، قَالَ : لاَ أَسْتَطِیعُ أَنْ أُصَلِّیَ، قَالُوا : لاَ یَؤُمُّنَا أَحَدٌ غَیْرُک مَا دُمْت ، فَقَالَ : اجْلِسُوا فَصَلَّی بِہِمْ جُلُوسًا۔",,,7218,,
7219,"حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ ، عَنْ سُلَیْمَانَ بْنِ بِلاَلٍ ، عَنْ جَعْفَرِ بْنِ مُحَمَّدٍ ، قَالَ : سَمِعْتُ الْقَاسِمَ بْنَ مُحَمَّدٍ یَقُولُ ، قَالَ مُعَاوِیَۃُ ، قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا صَلَّی الإِمَام جَالِسًا فَصَلُّوا جُلُوسًا ، قَالَ فَعَجِبَ النَّاسُ مِنْ صِدْقِ مُعَاوِیَۃَ۔",,,7219,,
7220,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إسْمَاعِیلُ ، عَنْ قَیْسِ بْنِ أَبِی حَازِمٍ ، عَنْ قَیْسِ بْنِ قَہْدٍ ، قَالَ : کَانَ لَنَا إمَامٌ فَمَرِضَ فَصَلَّیْنَا بِصَلاَتِہِ قُعُودًا۔",,,7220,,
7221,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الأَحْوَص ، قَالَ : قَالَ عَبْدُ اللہِ إنَّمَا جُعِلَ الإِمَام لِیُؤْتَمَّ بِہِ فَإِذَا کَبَّرَ فَکَبِّرُوا ، وَإِذَا رَکَعَ فَارْکَعُوا ، وَإِذَا سَجَدَ فَاسْجُدُوا ، فَإِنَّہُ أَوَّلُ مَنْ یَرْفَعُ وَأَوَّلُ مَنْ یَضَعُ۔",,,7221,,
7222,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ طَلْحَۃَ ، قَالَ : قَالَ سَلْمَانُ : مَنْ رَفَعَ رَأْسَہُ قَبْلَ الإِمَام وَوَضَعَ رَأْسَہُ قَبْلَ الإِمَام فَنَاصِیَتُہُ بِیَدِ الشَّیْطَانِ یَرْفَعُہَا وَیَضَعُہَا۔",,,7222,,
7223,"حَدَّثَنَا عَبْدَۃُ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ مَلِیحِ بْنِ عَبْدِ اللہِ السَّعْدِیِّ ، قَالَ : قَالَ أَبُو ہُرَیْرَۃَ : إنَّ الَّذِی یَخْفِضُ وَیَرْفَعُ رَأْسَہُ قَبْلَ الإِمَام فَإِنَّمَا نَاصِیَتُہُ بِیَدِ شَیْطَانِ۔",,,7223,,
7224,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ مُحَمَّدِ بْنِ زِیَادٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَمَا یَخَافُ الَّذِی یَرْفَعُ رَأْسَہُ قَبْلَ الإِمَام أَنْ یُحَوِّلَ اللَّہُ رَأْسَہُ رَأْسَ حِمَارٍ۔ (بخاری 691۔ ابوداؤد 623)",,,7224,,
7225,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ زِیَادِ بْنِ فَیَّاضٍ ، عَنْ تَمِیمِ بْنِ سَلَمَۃَ ، قَالَ : قَالَ عَبْدُ اللہِ : أَمَا یَخَافُ الَّذِی یَرْفَعُ رَأْسَہُ قَبْلَ الإِمَام أَنْ یُحَوِّلَ اللَّہُ رَأْسَہُ رَأْسَ کَلْبٍ۔",,,7225,,
7226,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا الْعَوَّامُ ، عَنْ عَزْرَۃَ بْنِ الْحَارِثِ ، أَنَّہُ حَدَّثَہُ ، عَنِ الْبَرَائِ بْنِ عَازِبٍ ، قَالَ : کُنَّا إذَا صَلَّیْنَا خَلْفَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَرَفَعْنَا رُؤُوسَنَا مِنَ الرُّکُوعِ قُمْنَا صُفُوفًا حَتَّی یَسْجُدَ فَإِذَا سَجَدَ تَبِعْنَاہُ۔ (احمد 4/292۔ ابو یعلی 1673)",,,7226,,
7227,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ مُحَمَّدِ بْنِ یَحْیَی بْنِ حَبَّانَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنِّی قَدْ بَدَنْتُ فَلاَ تُبَادِرُونِی بِالرُّکُوعِ ، وَلاَ بِالسُّجُودِ فَإِنِّی مَہْمَا أَسْبِقُکُمْ بِہِ إذَا رَکَعْت فَإِنَّکُمْ تُدْرِکُونِی بِہِ إذَا رَفَعْت وَمَہْمَا أَسْبِقُکُمْ بِہِ إذَا سَجَدْت فَإِنَّکُمْ تُدْرِکُونِی بِہِ إذَا وَضَعْت۔",,,7227,,
7228,حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ مُحَمَّدِ بْنِ یَحْیَی بْنِ حَبَّانَ ، عَنِ ابْنِ مُحَیْرِیزٍ ، عَنْ مُعَاوِیَۃَ ، رَفَعَہ مِثْلَہُ۔ (ابوداؤد 619۔ احمد 98),,,7228,,
7229,"حَدَّثَنَا ہُشَیْمٌ ، وَابْنُ إدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنْ ہِلاَلِ بْنِ یَِسَافٍ ، عَنْ أَبِی حَیَّانَ ، قَالَ : قَالَ عَبْدُ اللہِ : لاَ تُبَادِرُوا أَئِمَّتَکُمْ بِالرُّکُوعِ ، وَلاَ بِالسُّجُودِ۔",,,7229,,
7230,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، قَالَ : مَنْ کَانَ مَعَ الإِمَامِ فَرَکَعَ قَبْلَ رُکُوعِہِ وَسَجَدَ قَبْلَ سُجُودِہِ فَلَیْسَ مَعَہُ۔",,,7230,,
7231,"حَدَّثَنَا مُعْتَمِرٌ، عَنْ کَہْمَسٍ، قَالَ: صَلَّیْت إلَی جَنْبِ أَبِی قِلاَبَۃَ، فَکَانَ لاَ یَصْنَعُ شَیْئًا حَتَّی یَصْنَعَہُ الإِمَام۔",,,7231,,
7232,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ اللہِ بْنِ یَزِیدَ ، عَنِ الْبَرَائِ بْنِ عَازِبٍ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا رَفَعَ رَأْسَہُ مِنَ الرُّکُوعِ لَمْ یَحْنِ أَحَدٌ مِنَّا ظَہْرَہُ حَتَّی یَسْجُدَ فَإِذَا سَجَدَ تَبِعْنَاہُ۔ (بخاری 747۔ ابوداؤد 620)",,,7232,,
7233,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الْمُخْتَارِ بْنِ فُلْفُلٍ ، عَنْ أَنَسٍ ، قَالَ : صَلَّی بِنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ذَاتَ یَوْمٍ ، فَلَمَّا قَضَی الصَّلاَۃ أَقْبَلَ عَلَیْنَا بِوَجْہِہِ ، فَقَالَ : أَیُّہَا النَّاسُ إنِّی إمَامُکُمْ فَلاَ تَسْبِقُونِی بِالرُّکُوعِ، وَلاَ بِالسُّجُودِ ، وَلاَ بِالْقِیَامِ ، وَلاَ بِالإِنْصِرَافِ فَإِنِّی أَرَاکُمْ أَمَامِی وَمِنْ خَلْفِی۔ (مسلم 112۔ ابوداؤد 624)",,,7233,,
7234,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَانَ مُحَمَّدُ یَکْرَہُ أَنْ یُسْبَقَ الإِمَام بِشَیْئٍ مِنَ التَّکْبِیرِ۔",,,7234,,
7235,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حدَّثَنَا ابْنُ أَبِی عَرُوبَۃَ ، قَالَ : حَدَّثَنَا قَتَادَۃُ ، عَنْ یُونُسَ بْنِ جُبَیْرٍ ، عَنْ حِطَّانَ بْنِ عَبْدِ اللہِ ، قَالَ : صَلَّی بِنَا أَبُو مُوسَی ، فَلَمَّا انْفَتَلَ ، قَالَ : إنَّ نَبِیَّ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ خَطَبَنَا فَبَیَّنَ لَنَا سُنَّتَنَا وَعَلَّمَنَا صَلاَتَنَا ، فَقَالَ : إذَا کَبَّرَ الإِمَام فَکَبِّرُوا ، وَإِذَا رَکَعَ فَارْکَعُوا فَإِنَّ الإِمَام یَرْکَعُ قَبْلَکُمْ وَیَرْفَعُ قَبْلَکُمْ۔ (مسلم 303۔ ابوداؤد 965)",,,7235,,
7236,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ قَیْسٍ ، عَنْ عَلِیِّ بْنِ مُدْرِکٍ ، أَنَّ مُعَاذًا لَمَّا قَدِمَ الْیَمَنَ کَانَ یُعْلَمُ النَّخْعَ ، فَقَالَ لَہُم : إذَا رَأَیْتُمُونِی صَنَعْت شَیْئًا فِی الصَّلاَۃ فَاصْنَعُوا مِثْلَہُ ، فَلَمَّا سَجَدَ أَضَرَّ بِعَیْنَیْہِ غُصْنُ شَجَرَۃٍ فَکَسَرَہُ فِی الصَّلاَۃ فَعَمَدَ کُلُّ رَجُلٍ مِنْہُمْ إلَی غُصْنٍ فِی الصَّلاَۃ فَکَسَرَہُ ، فَلَمَّا صَلَّی ، قَالَ إنِّی إنَّمَا کَسَرْتُہُ لأَنَّہُ أَضَرَّ بِعَیْنَیْ حِینَ سَجَدْت وَقَدْ أَحْسَنْتُمْ فِیمَا أَطَعْتُمْ۔",,,7236,,
7237,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ سَعْدِ بْنِ إِبْرَاہِیمَ ، عَن نَافِعِ بْنِ جُبَیْرِ بْنِ مُطْعِمٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنِّی امْرُؤٌ قَدْ بَدَنْتُ فَلاَ تُبَادِرُونِی بِالْقِیَامِ ، وَلاَ بِالسُّجُودِ۔ (ابن سعد 420۔ طبرانی 1579)",,,7237,,
7238,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عَنْ عَائِشَۃَ ، قَالَتْ لَمَّا مَرِضَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَرَضَہُ الَّذِی مَاتَ فِیہِ جَائَ بِلاَلٌ یُؤْذِنُہُ بِالصَّلاَۃ ، فَقَالَ : مُرُوا أَبَا بَکْرٍ فَلْیُصَلِّ بِالنَّاسِ قُلْنَا یَا رَسُولَ اللہِ إنَّ أَبَا بَکْرٍ رَجُلٌ رَقِیقٌ أَسِیفٌ وَمَتَی یَقُومُ مَقَامَک یَبْکِی فَلاَ یَسْتَطِیعُ فَلَوْ أَمَرْت عُمَرَ ، فَقَالَ : مُرُوا أَبَا بَکْرٍ فَلْیُصَلِّ بِالنَّاسِ فَإِنَّکُنَّ صَوَاحِبَاتُ یُوسُفَ فَأُرْسَلَ إلَی أَبِی بَکْرٍ فَصَلَّی بِالنَّاسِ فَوَجَدَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِنْ نَفْسِہِ خِفَّۃً فَخَرَجَ إلَی الصَّلاَۃ یُہَادَی بَیْنَ رَجُلَیْنِ وَرِجْلاَہُ تَخُطَّانِ فِی الأَرْضِ ، فَلَمَّا أَحَسَّ بِہِ أَبُو بَکْرٍ ذَہَبَ یَتَأَخَّرُ فَأَوْمَأَ إلَیْہِ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ مَکَانَک ، قَالَتْ : فَجَائَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَجَلَسَ إلَی جَنْبِ أَبِی بَکْرٍ ، فَکَانَ أَبُو بَکْرٍ یَأْتَمُّ بِالنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَالنَّاسُ یَأْتَمُّونَ بِأَبِی بَکْرٍ۔ (مسلم 95۔ ابن ماجہ 1232)",,,7238,,
7239,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا سُفْیَانُ بْنُ حُسَیْنٍ ، عَنِ الزُّہْرِیِّ ، عَنْ أَنَسٍ ، قَالَ : لَمَّا مَرِضَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی مَرَضِہِ الَّذِی مَاتَ فِیہِ أَتَاہُ بِلاَلٌ فَأَذَّنَہُ بِالصَّلاَۃ ، فَقَالَ : یَا بِلاَلُ قَدْ بَلَّغْت فَمَنْ شَائَ فَلْیُصَلِّ وَمَنْ شَائَ فَلْیَدَعْ ، فَقَالَ : یَا رَسُولَ اللہِ فَمَنْ یُصَلِّی بِالنَّاسِ؟ قَالَ : مُرُوا أَبَا بَکْرٍ فَلْیُصَلِّ بِالنَّاسِ ، فَلَمَّا تَقَدَّمَ أَبُو بَکْرٍ رُفِعَتِ السُّتُورُ ، عَنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَنَظَرْنَا إلَیْہِ کَأَنَّہُ وَرَقَۃٌ بَیْضَائُ عَلَیْہِ خَمِیصَۃٌ فَظَنَّ أَبُو بَکْرٍ ، أَنَّہُ یُرِیدُ الْخُرُوجَ فَتَأَخَّرَ وَأَشَارَ إلَیْہِ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ صَلِّ مَکَانَک فَصَلَّی أَبُو بَکْرٍ وَمَا رَأَیْنَا رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَتَّی مَاتَ مِنْ یَوْمِہِ۔ (بخاری 680۔ مسلم 98)",,,7239,,
7240,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ عَبْدِ الْمَلِکِ بْنِ عُمَیْرٍ ، عَنْ أَبِی بُرْدَۃَ ، عَنْ أَبِی مُوسَی ، قَالَ : مَرِضَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَاشْتَدَّ مَرَضُہُ ، فَقَالَ : مُرُوا أَبَا بَکْرٍ فَلْیُصَلِّ بِالنَّاسِ ، فَقَالَتْ عَائِشَۃُ یَا رَسُولَ اللہِ إنَّ أَبَا بَکْرٍ رَجُلٌ رَقِیقٌ مَتَی یَقُمُ مَقَامَک فَلاَ یَسْتَطِیعُ أَنْ یُصَلِّیَ بِالنَّاسِ ، فَقَالَ : مُرِی أَبَا بَکْرٍ فَلْیُصَلِّ بِالنَّاسِ فَإِنَّکُنَّ صَوَاحِبُ یُوسُفَ ، قَالَ : فَصَلَّی بِہِمْ أَبُو بَکْرٍ حَیَاۃَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔ (بخاری 678۔ مسلم 101)",,,7240,,
7241,حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِیہِ ، عَنْ أَبِی الزُبَیْرٍ ، عَنْ جَابِرٍ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَمَّہُمْ وَکَانَ أَبُو بَکْرٍ خَلْفَہُ فَیُکَبِّرُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَیُکَبِّرُ أَبُو بَکْرٍ یُسْمِعُ النَّاسَ۔ (مسلم 85۔ ابوداؤد 606),,,7241,,
7242,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ عَاصِمٍ ، عَنْ زِرٍّ ، عَنْ عَبْدِ اللہِ ، قَالَ : لَمَّا قُبِضَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَتِ الأَنْصَارُ مِنَّا أَمِیرٌ وَمِنْکُمْ أَمِیرٌ فَأَتَاہُمْ عُمَرُ ، فَقَالَ : یَا مَعْشَرَ الأَنْصَارِ أَلَسْتُمْ تَعْلَمُونَ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَمَّرَ أَبَا بَکْرٍ یُصَلِّی بِالنَّاسِ ، قَالُوا : بَلَی ، قَالَ : فَأَیُّکُمْ تَطِیبُ نَفْسُہُ أَنْ یَتَقَدَّمَ أَبَا بَکْرٍ۔ (نسائی 852۔ احمد 1/396",,,7242,,
7243,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إسْمَاعِیلُ بْنُ أَبِی خَالِدٍ ، قَالَ : سَمِعْتُ أَبَا سَلَمَۃَ بْنَ عَبْدِ الرَّحْمَنِ یُحَدِّثُ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ اشْتَکَی ، فَقَالَ : مُرُوا أَبَا بَکْرٍ فَلْیُصَلِّ بِالنَّاسِ فَوَجَدَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِنْ نَفْسِہِ خِفَّۃً فَخَرَجَ ، فَلَمَّا رَآہُ أَبُو بَکْرٍ ذَہَبَ لِیَتَأَخَّرَ فَأَوْمَأَ إلَیْہِ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَکَانَک فَجَائَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَتَّی جَلَسَ إلَی جَنْبِ أَبِی بَکْرٍ ، فَکَانَ أَبُو بَکْرٍ یَأْتَمُّ بِالنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَالنَّاسُ یَأْتَمُّونَ بِأَبِی بَکْرٍ۔",,,7243,,
7244,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ عَاصِمِ بْنِ أَبِی النَّجُودِ ، عَنْ شَقِیقٍ ، عَنْ مَسْرُوقٍ، عَنْ عائِشَۃَ، قَالَتْ : أُغْمِیَ عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَلَمَّا أَفَاقَ ، قَالَ : أَصَلَّی النَّاسُ ؟ قَالَتْ : فَقُلْنَا : لاَ ، قَالَ : مُرُوا أَبَا بَکْرٍ فَلْیُصَلِّ بِالنَّاسِ ، قَالَتْ : فَقُلْنَا : یَا رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْک وَسَلَّمَ إنَّ أَبَا بَکْرٍ رَجُلٌ أَسِیفٌ ، قَالَ : عَاصِمٌ الأَسِیفُ الرَّقِیقُ الرَّحِیمُ ، وَإِنَّہُ مَتَی یَقُمُ مَقَامَک لاَ یَسْتَطِیعُ أَنْ یُصَلِّیَ بِالنَّاسِ ، قَالَتْ : ثُمَّ أُغْمِیَ عَلَیْہِ ، ثُمَّ أَفَاقَ ، فَقَالَ : مِثْلَ ذَلِکَ ، فَرَدَّت عَلَیْہِ ثَلاَثَ مَرَّاتٍ ، فَقَالَ : إنَّکُنَّ صَوَاحِبُ یُوسُفَ مُرُوا أَبَا بَکْرٍ فَلْیُصَلِّ بِالنَّاسِ ، فَقَالَتْ : فَوَجَدَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِنْ نَفْسِہِ خِفَّۃً فَخَرَجَ بَیْنَ بَرِیرَۃَ وَنَوْبَۃَ ، تَخُطُّ نَعْلاَہُ إنِّی لأَرَی بَیَاضَ بُطُون قَدَمَیْہِ ، وَأَبُو بَکْرٍ یَؤُمُّ النَّاسَ ، فَلَمَّا رَآہُ أَبُو بَکْرٍ ذَہَبَ یَتَأَخَّرُ فَأَوْمَأَ إلَیْہِ أَنْ لاَ یَتَأَخَّرَ ، قَالَتْ : فَقَامَ أَبُو بَکْرٍ بِجَنْبِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، والنَّبیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَاعِدٌ ، یُصَلِّی أَبُو بَکْرٍ بِصَلاَۃِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَالنَّاسُ یُصَلُّونَ بِصَلاَۃِ أَبِی بَکْرٍ۔(ابن حبان 2118)",,,7244,,
7245,"حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ نُعَیْمِ بْنِ أَبِی ہِنْدٍ ، عَنْ أَبِی وَائِلٍ ، عَنْ مَسْرُوقٍ ، عَنْ عَائِشَۃَ ، قَالَتْ : صَلَّی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی مَرَضِہِ الَّذِی مَاتَ فِیہِ خَلْفَ أَبِی بَکْرٍ قَاعِدًا۔ (ترمذی 362۔ احمد 6/159)",,,7245,,
7246,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ مُوسَی بْنِ أَبِی عَائِشَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ عَبْدِ اللہِ بْنِ عُتْبَۃَ ، قَالَ : دَخَلْت عَلَی عَائِشَۃَ فَقُلْت : إِلاَّ تُحَدِّثِینِی ، عَنْ مَرَضِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَتْ : بَلَی۔ ثَقُلَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : أَصَلَّی النَّاسُ ؟ فَقُلْت لاَ ہُمْ یَنْتَظِرُونَک یَا رَسُولَ اللہِ، فَقَالَ : ضَعُوا لِی مَائً فِی الْمِخْضَبِ ، قَالَتْ فَفَعَلْنَا فَاغْتَسَلَ ، ثُمَّ ذَہَبَ لِیَنُوئَ فَأُغْمِیَ عَلَیْہِ ، ثُمَّ أَفَاقَ ، فَقَالَ : أَصَلَّی النَّاسُ ؟ فَقُلْنَا لاَ ہُمْ یَنْتَظِرُونَک ، فَقَالَ : ضَعُوا لِی مَائً فِی الْمِخْضَبِ ، قَالَتْ : فَفَعَلْنَا فَاغْتَسَلَ ، ثُمَّ ذَہَبَ لِیَنُوئَ فَأُغْمِیَ عَلَیْہِ ، ثُمَّ أَفَاقَ ، فَقَالَ : أَصَلَّی النَّاسُ ؟ فَقُلْنَا ہُمْ یَنْتَظِرُونَک یَا رَسُولَ اللہِ وَالنَّاسُ عُکُوفٌ فِی الْمَسْجِدِ یَنْتَظِرُونَ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لِصَلاَۃِ الْعِشَائِ الآخِرَۃِ۔ \n\nقَالَتْ : فَأَرْسَلَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إلَی أَبِی بَکْرٍ أَنْ صَلِّ بِالنَّاسِ فَأَتَاہُ الرَّسُولُ ، فَقَالَ : إنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَأْمُرُک أَنْ تُصَلِّیَ بِالنَّاسِ ، فَقَالَ : أَبُو بَکْرٍ ، وَکَانَ رَجُلاً رَقِیقًا ، یَا عُمَرُ صَلِّ بِالنَّاسِ ، فَقَالَ لَہُ : عُمَرُ أَنْتَ أَحَقُّ بِذَلِکَ فَصَلَّی بِہِمْ أَبُو بَکْرٍ تِلْکَ الأَیَّامَ۔\n\nقَالَتْ ، ثُمَّ إنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَجَدَ فِی نَفْسِہِ خِفَّۃً فَخَرَجَ بَیْنَ رَجُلَیْنِ لِصَلاَۃِ الظُّہْرِ ، وَأَبُو بَکْرٍ یُصَلِّی بِالنَّاسِ ، قَالَتْ ، فَلَمَّا رَآہُ أَبُو بَکْرٍ ذَہَبَ لِیَتَأَخَّرَ فَأَوْمَأَ إلَیْہِ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ لاَ یَتَأَخَّرَ ، وَقَالَ لَہُمَا : اجْلِسَانِی إلَی جَنْبِہِ فَأَجْلَسَاہُ إلَی جَنْبِ أَبِی بَکْرٍ فَجَعَلَ أَبُو بَکْرٍ یُصَلِّی وَہُوَ قَائِمٌ بِصَلاَۃِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَالنَّاسُ یُصَلُّونَ بِصَلاَۃِ أَبِی بَکْرٍ وَالنَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَاعِدٌ۔\n\nقَالَ عُبَیْدُ اللہِ : فَدَخَلْت عَلَی عَبْدِ اللہِ بْنِ عَبَّاسٍ ، فَقُلْت : أَلاَ أَعْرِضُ عَلَیْک مَا حَدَّثَتْنِی بِہِ عَائِشَۃُ عَنْ مَرَضِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : ہَاتِ فَعَرَضْت عَلَیْہِ حَدِیثَہَا فَمَا أَنْکَرَ مِنْہُ شَیْئًا۔ (بخاری 665۔ مسلم 311)",,,7246,,
7247,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنِ ابْنِ سِیرِینَ ، عَنْ عَمْرِو بْنِ وَہْبٍ ، عَنِ الْمُغِیرَۃِ بنِ شُعْبَۃَ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی خَلْفَ عَبْدِ الرَّحْمَنِ بْنِ عَوْفٍ۔ (مسلم 81۔ احمد248),,,7247,,
7248,"حَدَّثَنَا جَرِیرٌ ، عَنْ أَبِی حَازِمٍ ، عَنْ سَہْلِ بْنِ سَعْدٍ ، قَالَ : کَانَ کَوْنٌ فِی الأَنْصَارِ فَأَتَاہُمُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لِیُصْلِحَ بَیْنَہُمْ ، قَالَ : فَجَائَ وَأَبُو بَکْرٍ یُصَلِّی بِالنَّاسِ ، قَالَ : فَصَلَّی خَلْفَ أَبِی بَکْرٍ۔ (بخاری 1201۔ ابوداؤد 938)",,,7248,,
7249,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مَنْصُورٍ ، عَنِ الْحَسَنِ ، قَالَ : کَانَ لاَ یَرَی بَأْسًا أَنْ یَضَعَ الرَّجُلُ رِدَائَہُ عَنْ مَنْکِبَیْہِ وَہُوَ فِی الصَّلاَۃ۔",,,7249,,
7250,حَدَّثَنَا ہُشَیْمٌ ، عَنْ مَنْصُورٍ ، عَنِ ابْنِ سِیرِینَ ، أَنَّہُ کَرِہَہُ۔,,,7250,,
7251,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مِسْعَرٌ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ إذَا جَلَسَ الرَّجُلُ فِی الصَّلاَۃ أَنْ یَضَعَ رِدَائَہُ عَنْ عَاتِقِہِ۔",,,7251,,
7252,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ رَجُلٍ ، عَنْ أَنَسٍ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، عَنِ النَّوْمِ قَبْلَہَا ، یَعْنِی الْعِشَائَ۔",,,7252,,
7253,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَوْفٍ ، عَنْ سَیَّارِ بْنِ سَلاَمَۃَ ، عَنْ أَبِی بَرْزَۃَ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَنْہَی عَنِ النَّوْمِ قَبْلَ الْعِشَائِ۔",,,7253,,
7254,"حَدَّثَنَا جَرِیرٌ، عَنْ مُغِیرَۃَ، عَنْ إبْرَاہِیمَ، وَمُجَاہِدٍ، قَالَ: کَانَ ابْنُ عُمَرَ یَکَادُ أَنْ یَسُبَّ الَّذِی یَنَامُ، عَنِ الْعِشَائِ۔",,,7254,,
7255,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیمَانَ، عَنْ أَبِیہِ، قَالَ: بَلَغَنِی عَنْ أَنَسٍ، قَالَ: کُنَّا نَجْتَنِبُ الْفُرُشَ قَبْلَ صَلاَۃِ الْعِشَائِ۔",,,7255,,
7256,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، عَنْ أَسْلَمَ ، قَالَ : کَتَبَ عُمَرُوَلاَ یَنَامَ قَبْلَ أَنْ یُصَلِّیَہَا فَمَنْ نَامَ فَلاَ نَامَتْ عَیْنُہُ۔",,,7256,,
7257,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُبَیدِ اللہِ ، عَنْ نَافِعٍ ، عَنْ صَفِیَّۃَ ، عَنْ عُمَرَ بِنَحْوٍ مِنْ حَدِیثِ الثَّقَفِیِّ۔,,,7257,,
7258,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ سَعِیدِ بْنِ یسَََار ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : جَائَہ رَجُلٌ ، فَقَالَ: إنَّ مِنَّا الْمُحَارِجَ وَالْمُضَارِبَ فَہَلْ عَلَیْنَا حَرَجٌ أَنْ نَنَامَ قَبْلَ صَلاَۃِ الْعِشَائِ ؟ قَالَ : نَعَمْ وَحَرَجٌ وَحَرَجَانِ وَثَلاَثَۃُ أَحْراجَ۔",,,7258,,
7259,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ الْہَیْثُمِ الْمُرَادِیِّ ، عَنِ ابْنِ عُمَرَ ، أَنَّ رَجُلاً سَأَلَہُ ، عَنْ ذَلِکَ ، فَقَالَ : صَلِّ ، ثُمَّ نَمْ ، قَالَ ثُمَّ قَالَ لَہُ ذَلِکَ ثَلاَثًا ، فَقَالَ فِی الثَّالِثَۃِ : صَلِّ ثُمَّ نَمْ فَلاَ نَامَتْ عَیْنُک۔",,,7259,,
7260,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ عَبْدِ الْمَلِکِ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ مُجَاہِدٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : مَنْ نَامَ عَنْہَا فَلاَ نَامَتْ عَیْنُہُ ، یَعْنِی الْعِشَائَ۔",,,7260,,
7261,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ الْحَمِیدِ بْنِ بَہْرَامَ عْن شَہْرِ بْنِ حَوْشَبٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : مَا أُحِبُّ النَّوْمَ قَبْلَہَا ، وَلاَ الْحَدِیثَ بَعْدَہَا۔",,,7261,,
7262,حَدَّثَنَا وَکِیعٌ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُوس ، وَمُجَاہِدٍ أَنَّہُمْ کَانُوا یَکْرَہُونَ النَّوْمَ قَبْلَہَا وَالْحَدِیثَ بَعْدَہَا۔,,,7262,,
7263,"حَدَّثَنَا وَکِیعٌ ، وَابْنُ فُضَیْلٍ ، عَنْ مِسْعَرٍ ، قَالَ : سَأَلْتُ یَزِیدَ الْفَقِیرَ أَسَمِعْت ابْنَ عُمَرَ یَکْرَہُ النَّوْمَ قَبْلَہَا، قَالَ نَعَمْ۔",,,7263,,
7264,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یَکْرَہُونَ النَّوْمَ قَبْلَہَا وَالْحَدِیثَ بَعْدَہَا۔",,,7264,,
7265,"حَدَّثَنَا وَکِیعٌ ، عَنْ طَلْحَۃَ ، عَنْ عَطَائٍ فِی قولہ تعالی: (تَتَجَافَی جُنُوبُہُمْ عَنِ الْمَضَاجِعِ) قَالَ: عَنِ الْعَتَمَۃِ۔",,,7265,,
7266,"حَدَّثَنَا شُعْبَۃُ ، عَنْ سَہْلٍ الْقُرَشِیِّ ، قَالَ : سَمِعْتُ سَعِیدَ بْنَ الْمُسَیَّبِ یَقُولُ : لأَنْ أُصَلِّیَ الْعِشَائَ فِی ہَذِہِ السَّاعَۃِ وَذَلِکَ بَعْدَ الْمَغْرِبِ أَحَبُّ إلَیَّ مِنْ أَنْ أَنَامَ عْنہَا ، ثُمَّ أَقُومَ فَأُصَلِّیَہَا۔",,,7266,,
7267,"حَدَّثَنَا وَکِیعٌ ، قَالَ: حدَّثَنَا إسْمَاعِیلُ بْنُ عَبْدِ الْمَلِکِ ، عَنْ عَبْدِ الْکَرِیمِ أَبِی أُمَیَّۃَ ، عَنْ مُجَاہِدٍ، قَالَ: لأَنْ أُصَلِّیَ الْعِشَائَ قَبْلَ أَنْ یَغِیبَ الشَّفَقُ أَحَبُّ إلَیَّ مِنْ أَنْ أَنَامَ عْنہَا، ثُمَّ أُصَلِّیَہَا بَعْدَ مَا یَغِیبُ الشَّفَقُ فِی جَمَاعَۃٍ۔",,,7267,,
7268,حَدَّثَنَا حَفْصٌ ، وَابْنُ فُضَیْلٍ ووَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَبْدِ اللہِ بن عَبْدِ اللہِ الرَّازِیّ ، عَنْ جَدَّتِہِ وَکَانَتْ سُرِّیَّۃً لِعَلِیٍّ ، أَنَّ عَلِیًّا رُبَّمَا غَفَا قَبْلَ الْعِشَائِ۔,,,7268,,
7269,حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ أَبِی حَصِینٍ ، أَنَّ خَبَّابًا نَامَ ، عَنِ الْعِشَائِ۔,,,7269,,
7270,حَدَّثَنَا وَکِیعٌ، عَنْ إسْرَائِیلَ، عَنْ أَبِی حَصِینٍ، أَنَّ أَبَا وَائِلٍ وَأَصْحَابَ عَبْدِاللہِ کَانُوا یَنَامُونَ قَبْلَ الْعِشَائِ۔,,,7270,,
7271,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ الأَسْوَدُ لاَ یُفْطِرُ فِی رَمَضَانَ حَتَّی یُصَلِّیَ ، فَکَانَ یَنَامُ مَا بَیْنَ الْمَغْرِبِ وَالْعِشَائِ۔",,,7271,,
7272,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، قَالَ : قُلْتُ لَہُ : أَکَانَ ابْنُ عُمَرَ یَنَامُ عَنْہَا ، یَعْنِی الْعِشَائَ ، قَالَ : قَدْ کَانَ یَنَامُ وَیُوَکِّلُ مَنْ یُوقِظُہُ۔",,,7272,,
7273,حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، أَنَّہُ کَانَ یَنَامُ قَبْلَہَا۔,,,7273,,
7274,"حَدَّثَنَا عَبِیْدَۃُ بْنُ حُمَیْدٍ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، عَنْ عَلِیٍّ الأَزْدِیِّ ، قَالَ : کَانَ یَخْتِمُ الْقُرْآنَ فِی رَمَضَانَ کُلَّ لَیْلَۃٍ وَکَانَ یَنَامُ مَا بَیْنَ الْمَغْرِبِ وَالْعِشَائِ۔",,,7274,,
7275,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، قَالَ : کَانُوا یَنَامُونَ نَوْمَۃً قَبْلَ الصَّلاَۃ۔",,,7275,,
7276,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ وَقَائٍ ، أَنَّ سَعِیدَ بْنَ جُبَیْرٍ کَانَ یَنَامُ قَبْلَ أَنْ یُصَلِّیَ الْعِشَائَ ، ثُمَّ یَقُومُ فِی رَمَضَانَ۔,,,7276,,
7277,حَدَّثَنَا عَبَّادُ بْنُ عَوَّامٍ ، عَنْ ہِشَامٍ ، عَنْ مُحَمَّدٍ ، أَنَّہُ کَانَ یَنَامُ قَبْلَ الْعِشَائِ۔,,,7277,,
7278,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : نُبِّئْتُ أَنَّ أَبَا مُوسَی الأَشْعَرِیَّ أَعَادَ صَلاَۃَ الصُّبْحِ فِی یَوْمٍ ثَلاَثَ مَرَّاتٍ صَلَّی ، ثُمَّ قَعَدَ ، حَتَّی تَبَیَّنَ لَہُ ، أَنَّہُ صَلَّی بِلَیْلٍ ، ثُمَّ أَعَادَہَا ، ثُمَّ صَلَّی وَقَعَدَ حَتَّی تَبَیَّنَ ، أَنَّہُ صَلَّی بِلَیْلٍ ، ثُمَّ أَعَادَہَا الثَّالِثَۃَ۔",,,7278,,
7279,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، أنَّ ابْنَ عُمَرَ أَعَادَ صَلاَۃَ الصُّبْحِ یجمع فِی یَوْمٍ ثَلاَثَ مَرَّاتٍ صَلَّی فَإِذَا ہُوَ قَدْ صَلَّی بِلَیْلٍ ، ثُمَّ أَعَادَہَا فَإِذَا ہُوَ قَدْ صَلَّی بِلَیْلٍ ، ثُمَّ أَعَادَہَا الثَّالِثَۃَ۔,,,7279,,
7280,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مَنْصُورٌ ، عَنِ الْحَسَنِ ، قَالَ : شَکُّوا فِی طُلُوعِ الْفَجْرِ فِی عَہْدِ ابْنِ عَبَّاسٍ ، قَالَ : فَأَمَرَ مُؤَذِّنَہُ فَأَقَامَ الصَّلاَۃ ، ثُمَّ تَقَدَّمَ فَصَلَّی بِہِمْ وَاسْتَفْتَحَ الْبَقَرَۃَ حَتَّی خَتَمَہَا ، ثُمَّ رَکَعَ ، ثُمَّ سَجَدَ ، ثُمَّ قَامَ فَاسْتَفْتَحَ آلَ عِمْرَانَ حَتَّی خَتَمَہَا ، ثُمَّ رَکَعَ وَسَجَدَ ، قَالَ وَأَضَائَ لَہُمُ الصُّبْحُ۔",,,7280,,
7281,"حَدَّثَنَا ہُشَیْمٌ، قَالَ: حدَّثَنَا حُصَیْنٌ، عَنْ إبْرَاہِیمَ، قَالَ: کَانَتْ بِی سَعْلَۃٌ فَخَرَجْت لِصَلاَۃِ الصُّبْحِ فَسَمِعَ الْمُؤَذِّنُ سَعْلَتِی فَظَنَّ أَنْ قَدْ أَصْبَحْنَا فَأَقَامَ الصَّلاَۃ فَصَلَّیْنَا ، ثُمَّ نَظَرْنَا فَإِذَا الْفَجْرُ لَمْ یَطْلُعْ فَأَعَدْنَا الصَّلاَۃ۔",,,7281,,
7282,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ مُحَمَّدِ بْنِ عُثْمَانَ الْمَخْزُومِیِّ ، قَالَ : أَخْبَرَتْنِی جَدَّتِی ، عَنْ مَوْلًی لِعَبْدِ الرَّحْمَنِ بْنِ عَوْفٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَوْفٍ قَالَ : سَمِعْتُہُ یَقُولُ : إذَا طَہُرَتِ الْحَائِضُ قَبْلَ غُرُوبِ الشَّمْسِ صَلَّتِ الظُّہْرَ وَالْعَصْرَ ، وَإِذَا طَہُرَتْ قَبْلَ الْفَجْرِ صَلَّتِ الْمَغْرِبَ وَالْعِشَائَ۔",,,7282,,
7283,حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ وَعُبَیْدَۃَ أَخْبَرَاہُ ، عَنْ إبْرَاہِیمَ ، وَعَنْ حَجَّاجٍ ، عَنْ عَطَائٍ وَالشَّعْبِیِّ ، وَعَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ فِی الْحَائِضِ إذَا طَہُرَتْ قَبْلَ غُرُوبِ الشَّمْسِ صَلَّتِ الظُّہْرَ وَالْعَصْرَ ، وَإِذَا طَہُرَتْ قَبْلَ الْفَجْرِ صَلَّتِ الْمَغْرِبَ وَالْعِشَائَ۔,,,7283,,
7284,حَدَّثَنَا ہُشَیْمٌ ، عَنْ یَزِیدَ ، عَنْ مِقْسَمٍ ، عَنِ ابْنِ عَبَّاسٍ مِثْلَہُ۔,,,7284,,
7285,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ عَطَائٍ ، وَطَاوُوس ، وَمُجَاہِدٍ ، قَالُوا : إذَا طَہُرَتْ قَبْلَ غُرُوبِ الشَّمْسِ صَلَّتِ الظُّہْرَ وَالْعَصْرَ ، وَإِذَا طَہُرَتْ قَبْلَ طُلُوعِ الْفَجْرِ صَلَّتِ الْمَغْرِبَ وَالْعِشَائَ۔",,,7285,,
7286,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُوس ، أَنَّہُمَا قَالاَ : إذَا طَہُرَتِ الْحَائِضُ قَبْلَ غُرُوبِ الشَّمْسِ اغْتَسَلَتْ وَصَلَّتِ الظُّہْرَ وَالْعَصْرَ ، وَإِذَا طَہُرَتْ قَبْلَ الْفَجْرِ اغْتَسَلَتْ وَصَلَّتِ الْمَغْرِبَ وَالْعِشَائَ۔",,,7286,,
7287,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا طَہُرَتِ الْحَائِضُ مِنْ آخِرِ النَّہَارِ صَلَّتِ الظُّہْرَ وَالْعَصْرَ ، وَإِذَا طَہُرَتْ مِنْ آخِرِ اللَّیْلِ صَلَّتِ الْمَغْرِبَ وَالْعِشَائَ۔",,,7287,,
7288,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنِ الْعَلاَئِ بْنِ الْمُسَیَّبِ ، عَنْ عَطَائٍ ، قَالَ : إذَا طَہُرَتْ مِنْ آخِرِ اللَّیْلِ فَلْتُصَلِّ صَلاَۃَ لَیْلَتِہَا ، وَإِذَا طَہُرَتْ مِنْ آخِرِ النَّہَارِ فَلْتُصَلِّ صَلاَۃَ یَوْمِہَا۔",,,7288,,
7289,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنِ الْحَکَمِ ، قَالَ : إذَا رَأَتِ الطُّہورَ قَبْلَ الْمَغْرِبِ صَلَّتِ الظُّہْرَ وَالْعَصْرَ ، وَإِذَا رَأَتْہُ قَبْلَ الْفَجْرِ صَلَّتِ الْمَغْرِبَ وَالْعِشَائَ۔",,,7289,,
7290,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : تُصَلِّی الصَّلاَۃ الَّتِی طَہُرَتْ فِی وَقْتِہَا۔",,,7290,,
7291,"حَدَّثَنَا وَکِیعٌ ، عَنِ الرَّبِیعِ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إن رَأَتِ الطُّہْرَ فِی وَقْتِ الظُّہْرِ فَلَمْ تَغْتَسِلْ حَتَّی یَدْخُلَ وَقْتُ الْعَصْرِ صَلَّتِ الظُّہْرَ وَالْعَصْرَ۔",,,7291,,
7292,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، قَالَ : کَانَ مُحَمَّدٌ لاَ یَرَی بَأْسًا أَنْ یَؤُمَّ الرَّجُلُ الْقَوْمَ یَقْرَأُ فِی الْمُصْحَفِ۔",,,7292,,
7293,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، قَالَ : سَمِعْتُ الْقَاسِمَ یَقُولُ کَانَ یَؤُمُّ عَائِشَۃَ عَبْدٌ یَقْرَأُ فِی الْمُصْحَفِ۔",,,7293,,
7294,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ہِشَامُ بْنُ عُرْوَۃَ ، عَنْ أَبِی بَکْرِ بْنِ أَبِی مُلَیْکَۃَ ، أَنَّ عَائِشَۃَ أَعْتَقَتْ غُلاَمًا لَہَا عَنْ دُبُرٍ ، فَکَانَ یَؤُمُّہَا فِی رَمَضَانَ فِی الْمُصْحَفِ۔",,,7294,,
7295,حَدَّثَنَا أَزْہَرُ ، عَنِ ابْن عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ، عَنْ عَائِشَۃَ ابْنَۃِ طَلْحَۃَ ، أَنَّہَا کَانَتْ تَأْمُرُ غُلاَمًا ، أَوْ إنْسَانًا یَقْرَأُ فِی الْمُصْحَفِ یَؤُمُّہَا فِی رَمَضَانَ۔,,,7295,,
7296,حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ؛ فِی الرَّجُلِ یَؤُمُّ فِی رَمَضَانَ یَقْرَأُ فِی الْمُصْحَفِ رَخَّصَ فِیہِ۔,,,7296,,
7297,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ شُعْبَۃَ ، عَنْ مَنْصُورٍ ، عَنِ الْحَسَنِ وَمُحَمَّدٍ ، قَالاَ : لاَ بَأْسَ بِہِ۔",,,7297,,
7298,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ رَبَاحِ بْنِ أَبِی مَعْرُوفٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ بَأْسَ بِہِ۔",,,7298,,
7299,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الرَّبِیعُ ، عَنِ الْحَسَنِ ، قَالَ : لاَ بَأْسَ أَنْ یَؤُمَّ فِی الْمُصْحَفِ إذَا لَمْ یَجِدْ ، یَعْنِی مَنْ یَقْرَأُ ظَاہِرًا۔",,,7299,,
7300,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا عِیسَی بْنُ طَہْمَانَ ، قَالَ : حَدَّثَنِی ثَابِتٌ الْبُنَانِیُّ ، قَالَ : کَانَ أَنَسٌ یُصَلِّی وَغُلاَمُہُ یُمْسِکُ الْمُصْحَفَ خَلْفَہُ فَإِذَا تَعَایَا فِی آیَۃٍ فَتَحَ عَلَیْہِ۔",,,7300,,
7301,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ عَیَّاشِ الْعَامِرِیِّ ، عَنْ سُلَیْمَانَ بْنِ حَنْظَلَۃَ الْبَکْرِیِّ ، أَنَّہُ مَرَّ عَلَی رَجُلٍ یَؤُمُّ قَوْمًا فِی الْمُصْحَفِ فَضَرَبَہُ بِرِجْلِہِ۔",,,7301,,
7302,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَطَائٍ ، عَنْ أَبِی عَبْدِ الرَّحْمَانِ ، أَنَّہُ کَرِہَ أَنْ یَؤُمَّ فِی الْمُصْحَفِ۔",,,7302,,
7303,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ کَرِہَ أَنْ یَؤُمَّ الرَّجُلُ فِی الْمُصْحَفِ کَرَاہَۃَ أَنْ یَتَشَبَّہُوا بِأَہْلِ الْکِتَابِ۔,,,7303,,
7304,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یَکْرَہُونَ أَنْ یَؤُمَّ الرَّجُلُ وَہُوَ یَقْرَأُ فِی الْمُصْحَفِ۔",,,7304,,
7305,حَدَّثَنَا الْمُحَارِبِیُّ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، أَنَّہُ کَانَ یَکْرَہُ أَنْ یَؤُمَّ الرَّجُلُ فِی الْمُصْحَفِ۔,,,7305,,
7306,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ہِشَامٌ الدَّسْتَوَائِیُّ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : إذَا کَانَ مَعَہُ مَنْ یَقْرَأُ رَدَّدُوہُ ، وَلَمْ یَؤُمَّ فِی الْمُصْحَفِ۔",,,7306,,
7307,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا ہِشَامٌ الدَّسْتَوَائِیُّ، عَنْ قَتَادَۃَ، عَنِ الْحَسَنِ، أَنَّہُ کَرِہَہُ، وَقَالَ: ہَکَذَا تَفْعَلُ النَّصَارَی۔",,,7307,,
7308,حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ شُعْبَۃَ ، عَنْ حَمَّادٍ وَقَتَادَۃَ فِی رَجُلٍ یَؤُمُّ الْقَوْمَ فِی رَمَضَانَ فِی الْمُصْحَفِ فَکَرِہَاہُ۔,,,7308,,
7309,"حَدَّثَنَا إسْرَائِیلُ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : لاَ یَؤُمُّ فِی الْمُصْحَفِ۔",,,7309,,
7310,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنِ مُغِیرَۃَ ، عَنِ الشَّعْبِیِّ ، قَالَ : إذَا دَخَلَ وَقْتُ صَلاَۃٍ عَلَی الْمَرْأَۃِ فَلَمْ تُصَلِّ حَتَّی حَاضَتْ وَہِیَ فِی وَقْتِ صَلاَۃٍ قَضَتْہَا إذَا طَہُرَتْ۔",,,7310,,
7311,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ ابْنِ شُبْرُمَۃَ ، عَنِ الشَّعْبِیِّ ، قَالَ : إذَا دَخَلَ وَقْتُ الصَّلاَۃ فَحَاضَتِ الْمَرْأَۃُ قَبْلَ أَنْ تُصَلِّیَ فَلْتُصَلِّہَا حِین تَطْہُرَ۔",,,7311,,
7312,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ حَجَّاجٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ إیَاسٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : سَأَلْتُہُ ، عَنِ امْرَأَۃٍ دَخَلَتْ فِی وَقْتِ صَلاَۃٍ فَأَخَّرَتْہَا حَتَّی حَاضَتْ ، قَالَ : تَبْدَأُ بِہَا إذَا طَہُرَتْ۔",,,7312,,
7313,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ وَمُحَمَّدٍ ، قَالاَ : إذَا حَاضَتْ فِی وَقْتِ صَلاَۃٍ فَلَیْسَ عَلَیْہَا قَضَائُ تِلْکَ الصَّلاَۃ إِلاَّ أَنْ یَکُونَ الْوَقْتُ قَدْ ذَہَبَ۔",,,7313,,
7314,حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ مُغِیرَۃَ ، عَنْ حَمَّادٍ ، قَالَ لَیْسَ عَلَیْہَا قَضَاؤُہَا لأَنَّہَا فِی وَقْتٍ۔,,,7314,,
7315,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ مُعَاذَۃَ الْعَدَوِیَّۃِ ، عَنْ عَائِشَۃَ ، أَنَّ الْمَرْأَۃَ سَأَلَتْہَا تَقْضِی الْحَائِضُ الصَّلاَۃ ، فَقَالَتْ لَہَا عَائِشَۃُ : أَحَرُورِیَّۃٌ أَنْتِ قَدْ کُنَّا نَحِیضُ عَلَی عَہْدِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، ثُمَّ نَطْہُرُ فَلاَ یَأْمُرُنَا بِقَضَائِ الصَّلاَۃ۔ (بخاری 321۔ ابوداؤد 266)",,,7315,,
7316,"حَدَّثَنَا وَکِیعٌ، عَنْ شُعْبَۃَ، عَنْ یَزِیدَ الرِّشْکِ، عَنْ مُعَاذَۃَ الْعَدَوِیَّۃِ، قَالَتْ: سُئلَتْ عَائِشَۃَ أَتَجْزِی الْحَائِضَ الصَّلاَۃ ، قَالَتْ : قَدْ کُنَّ نِسَائُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَحِضْنَ أَفَکُنَّ یَجْزِینَ ، تَعْنِی لاَ یَقْضِینَ۔ (مسلم 265۔ احمد 6/185)",,,7316,,
7317,"حَدَّثَنَا حُمَیْدُ بنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کُنَّا بَنَاتُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَأَزْوَاجُہُ یَحِضْنَ فَیَأْمُرُہُنَّ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِقَضَائِ الصِّیَامِ ، وَلاَ یَأْمُرُہُنَّ بِقَضَائِ الصَّلاَۃ۔ (عبدالرزاق 1279)",,,7317,,
7318,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ وَالشَّعْبِیِّ ، قَالاَ : لاَ تَقْضِی الْحَائِضُ الصَّلاَۃ۔",,,7318,,
7319,"حَدَّثَنَا وَکِیعٌ ، عَنْ شَرِیکٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : لاَ تَقْضِی الْحَائِضُ الصَّلاَۃ۔",,,7319,,
7320,"حَدَّثَنَا وَکِیعٌ قَالَ : حَدَّثَنَا شَرِیکٌ ، عَنْ کَثِیرٍ النَّوَّائِ ، قَالَ : سَأَلْتُ فَاطِمَۃَ بِنْتَ عَلِیٍّ أَتَقْضِینَ الصَّلاَۃ فِی أَیَّامِ حَیْضَتِکَ ، قَالَتْ لاَ۔",,,7320,,
7321,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ فِی الْحَائِضِ تَسْمَعُ السَّجْدَۃَ ، قَالَ : لاَ تَقْضِی لأَنَّہَا لاَ تَقْضِی الصَّلاَۃ۔",,,7321,,
7322,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، قَالَ : کَانَ ابْنُ الزُّبَیْرِ إذَا قَامَ فِی الصَّلاَۃ کَأَنَّہُ عُودٌ مِنَ الْخُشُوعِ ، قَالَ مُجَاہِدٌ : وَحُدِّثْت ، أَنَّ أَبَا بَکْرٍ کَانَ کَذَلِکَ۔",,,7322,,
7323,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ مُسْلِمٍ ، عَنْ مَسْرُوقٍ ، قَالَ : قَالَ عَبْدُ اللہِ : قَارُّوا الصَّلاَۃ ، یَعْنِی اُسْکُنُوا فِیہَا۔",,,7323,,
7324,"حَدَّثَنَا وَکِیعٌ ، عَنْ رَجُلٍ قَدْ سَمَّاہُ حَسَنٌ ، أَوْ سُفْیَانُ ، عَنْ زُبَیْدٍ، قَالَ: رَأَیْتُ زَاذَانَ یُصَلِّی کَأَنَّہُ خَشَبَۃٌ۔",,,7324,,
7325,"حَدَّثَنَا مُعَاذٌ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : رَأَیْتُ مُسْلِمَ بْنَ یَسَارٍ یُصَلِّی کَأَنَّہُ وَدٌّ۔",,,7325,,
7326,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنِ الأَعْمَشِ ، قَالَ : کَانَ عَبْدُ اللہِ إذَا قَامَ إلَی الصَّلاَۃ کَأَنَّہُ ثَوْبٌ مُلْقًی۔",,,7326,,
7327,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ أَبِی الضُّحَی ، عَنْ مَسْرُوقٍ ، قَالَ : قَالَ عَبْدُ اللہِ : قَارُّوا الصَّلاَۃ۔",,,7327,,
7328,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ مَنْصُورٍ ، عَنْ أَبِی الضُّحَی ، عَنْ مَسْرُوقٍ ، قَالَ : قَالَ عَبْدُ اللہِ: قَارُّوا الصَّلاَۃ۔ قَالَ زَائِدَۃُ : فَقُلْت لِمَنْصُورٍ : مَا یَعْنِی بِذَلِکَ ؟ قَالَ : فَقَالَ : التَّمَکُّنَ فِیہَا۔",,,7328,,
7329,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ أَبِی ہَاشِمٍ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ کَرِہَ أَنْ یَقُولَ الرَّجُلُ لَمْ أُصَلِّ وَیَقُولُ نُصَلِّی۔,,,7329,,
7330,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : التَّسْبِیحُ لِلرِّجَالِ وَالتَّصْفِیقُ لِلنِّسَائِ۔ (بخاری 1203۔ ابوداؤد 936)",,,7330,,
7331,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ الْجُرَیْرِیِّ ، عَنْ أَبِی نَضْرَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : صَلَّی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِالنَّاسِ ذَاتَ یَوْمٍ ، فَلَمَّا قَامَ لِیُکَبِّرَ ، قَالَ : إِنْ أَنْسَانِی الشَّیْطَانُ شَیْئًا مِنْ صَلاَتِی فَالتَّسْبِیحُ لِلرِّجَالِ وَالتَّصْفِیقُ لِلنِّسَائِ۔ (ترمذی 2787۔ نسائی 9409)",,,7331,,
7332,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ عَبْدِ الْحَمِیدِ الْمَدَنِیِّ ، عَنْ أَبِی حَازِمٍ ، عَنْ سَہْلِ بْنِ سَعْدٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : التَّسْبِیحُ لِلرِّجَالِ وَالتَّصْفِیقُ لِلنِّسَائِ۔",,,7332,,
7333,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِیہِ ، عَنْ أَبِی الزُّبَیْرِ، عَنْ جَابِرٍ، قَالَ: التَّسْبِیحُ فِی الصَّلاَۃ لِلرِّجَالِ وَالتَّصْفِیقُ لِلنِّسَائِ۔",,,7333,,
7334,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ ، قَالَ : اسْتَأْذَنْت عَلَی ابْنِ أَبِی لَیْلَی وَہُوَ یُصَلِّی فَسَبَّحَ بِالْغُلاَمِ فَفَتَحَ لِی۔",,,7334,,
7335,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : اسْتَأْذَنَ رَجُلٌ عَلَی جَابِرِ بْنِ عَبْدِ اللہِ فَسَبَّحَ فَدَخَلَ فَجَلَسَ حَتَّی انْصَرَفَ۔",,,7335,,
7336,"حَدَّثَنَا وَکِیعٌ ، عَنْ نَافِعِ بْنِ عُمَرَ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، قَالَ : رَأَیْتُ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ یُصَلِّی فِی الْمَسْجِدِ فَمَرَّ بِہِ إنْسَانٌ فَسَبَّحَ بِہِ۔",,,7336,,
7337,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذْنُ الرَّجُلِ إذَا کَانَ یُصَلِّی فِی بَیْتِہِ التَّسْبِیحُ وَإِذْنُ الْمَرْأَۃِ التَّصْفِیقُ۔",,,7337,,
7338,"حَدَّثَنَا ابْنُ أَبِی عَدِیٍّ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَانَ مُحَمَّدٌ رُبَّمَا کَانَ الإِنْسَاْن یَجِیئُ وَہُوَ فِی الصَّلاَۃ فَیَرَی ظِلَّہُ فَیُشِیرُ مُحَمَّدٌ بِیَدِہِ سُبْحَانَ اللہِ۔",,,7338,,
7339,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ یَزِیدَ بْنِ زِیَادٍ ، قَالَ : دَخَلْت عَلَی سَالِمِ بْنِ أَبِی الْجَعْدِ وَہُوَ یُصَلِّی ، فَقَالَ: سُبْحَانَ اللہِ ، فَلَمَّا انْصَرَفَ ، قَالَ : إنَّ التَّسْبِیحَ لِلرِّجَالِ وَالتَّصْفِیقَ لِلنِّسَائِ۔",,,7339,,
7340,"حَدَّثَنَا عَبِیْدَۃُ بْنُ حُمَیْدٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : التَّسْبِیحُ لِلرِّجَالِ وَالتَّصْفِیقُ لِلنِّسَائِ۔",,,7340,,
7341,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ مُغِیرَۃَ ، عَنِ الْحَارِثِ الْعُکْلِیِّ ، عَنْ عَبْدِ اللہِ بْنِ نُجیٍّ ، عَنْ عَلِیٍّ ، قَالَ : کُنْتُ إذَا دَخَلْت عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ یُصَلِّی تَنَحْنَحُ لِی۔ (ابن ماجہ 3708۔ احمد 1/85)",,,7341,,
7342,"حَدَّثَنَا وَکِیعٌ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، قَالَ : مَرَرْت بِابْنِ عُمَرَ وَہُوَ یُصَلِّی فَانْتَہَرَنِی بِتَسْبِیحِہِ۔",,,7342,,
7343,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، أَنَّہُ کَانَ یَقُولُ : فِی الْحَائِضِ تُنَظِّفُ وَتَتَّخِذُ مَکَانًا فِی مَوَاقِیتِ الصَّلاَۃ تَذْکُرُ اللَّہَ فِیہِ۔",,,7343,,
7344,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ أَبِیہِ ، قَالَ : قِیلَ لأَبِی قِلاَبَۃَ : الْحَائِضُ تَسْمَعُ الأَذَانَ فَتَوَضَّأُ وَتُکَبِّرُ وَتُسَبِّحُ ، قَالَ : قَدْ سَأَلْنَا ، عَنْ ذَلِکَ فَمَا وَجَدْنَا لَہُ أَصْلاً۔",,,7344,,
7345,"حَدَّثَنَا وَکِیعٌ ، عَنْ سفیان ، عَنْ سلیمان التیمی ، عن أبی قلابۃ ، قَالَ : لم نجد لہ أصلاً۔",,,7345,,
7346,حَدَّثَنَا وَکِیعٌ ، عَنْ شَرِیکٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ بِدْعَۃ۔,,,7346,,
7347,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ وَحَمَّادًا عَنْہُ فَکَرِہَاہُ۔",,,7347,,
7348,"حَدَّثَنَا أَبُو عَبْدِ الرَّحْمَنِ الْمُقْرِیٔ ، عَنْ سَعِیدِ بْنِ أَبِی أَیُّوبَ ، قَالَ : حدَّثَنِی خَالِدُ بْنُ یَزِیدَ الصَّدَفِیُّ ، عَنْ أَبِیہِ ، عَنْ عُقْبَۃَ بْنِ عَامِرٍ ، أَنَّہُ کَانَ یَأْمُرُ الْمَرْأَۃَ الْحَائِضَ فِی وَقْتِ الصَّلاَۃ أَنْ تَوَضَّأَ وَتَجْلِسَ بِفِنَائِ الْمَسْجِدِ وَتَذْکُرَ اللَّہَ وَتُہَلِّلَ وَتُسَبِّحَ۔",,,7348,,
7349,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : إِنَّا لَنَأْمُرُ نِسَائَنَا فِی الْحَیْضِ أَنْ یَتَوَضَّأْنَ فِی وَقْتِ کُلِّ صَلاَۃٍ ، ثُمَّ یَجْلِسْنَ وَیُسَبِّحْنَ وَیَذْکُرْنَ اللَّہَ۔",,,7349,,
7350,"حَدَّثَنَا یَزیْدُ بْنُ ہَارُونَ ، عَنْ یَزِیدَ بْنِ إبْرَاہِیمَ ، عَنِ الْحَسَنِ ، قَالَ : سَمِعْتُہُ یَقُولُ فِی الْحَائِضِ تَوَضَّأُ عِنْدَ کُلِّ صَلاَۃٍ وَتَذْکُرُ اللَّہَ۔",,,7350,,
7351,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنْ مُجَاہِدٍ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو قَالَ : مَنْ صَلَّی أَرْبَعًا بَعْدَ الْعِشَائِ کُنَّ کَقَدْرِہِنَّ مِنْ لَیْلَۃِ الْقَدْرِ۔",,,7351,,
7352,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنِ الْعَلاَئِ بْنِ الْمُسَیَّبِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ، قَالَتْ: أَرْبَعَۃٌ بَعْدَ الْعِشَائِ یُعْدَلْنَ بِمِثْلِہِنَّ مِنْ لَیْلَۃِ الْقَدْرِ۔",,,7352,,
7353,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ الْجَبَّارِ بْنِ عَبَّاسٍ ، عَنْ قَیْسِ بْنِ وَہْبٍ ، عَنْ مُرَّۃَ ، عَنْ عَبْدِ اللہِ ، قَالَ : مَنْ صَلَّی أَرْبَعًا بَعْدَ الْعِشَائِ لاَ یَفْصِلُ بَیْنَہُنَّ بِتَسْلِیمٍ عُدِلْنَ بِمِثْلِہِنَّ مِنْ لَیْلَۃِ الْقَدْرِ۔",,,7353,,
7354,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ الْوَاحِدِ بْنِ أَیْمَنَ ، عَنْ أَبِیہِ ، عَنْ تُبَیْعٍ ، عَنْ کَعْبِ بْنِ مَاتِعٍ ، قَالَ : مَنْ صَلَّی أَرْبَعًا بَعْدَ الْعِشَائِ یُحْسِنُ فِیہِنَّ الرُّکُوعَ وَالسُّجُودَ عُدِلْنَ بمِثْلَہِنَّ مِنْ لَیْلَۃِ الْقَدْرِ۔",,,7354,,
7355,حَدَّثَنَا عَبْدَۃُ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، عَنْ أَیْمَنَ ، عَنْ تُبَیع ، عَنْ کَعْبٍ نَحْوَہُ۔,,,7355,,
7356,"حَدَّثَنَا یَعْلَی ، عَنِ الأَعْمَشِ ، عَنْ مُجَاہِدٍ ، قَالَ : أَرْبَعُ رَکَعَاتٍ بَعْدَ الْعِشَائِ الآخِرَۃِ یَکُنَّ بِمَنْزِلَتِہِنَّ مِنْ لَیْلَۃِ الْقَدْرِ۔",,,7356,,
7357,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ بُکَیْرِ بْنِ عَامِرٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، قَالَ : مَنْ صَلَّی أَرْبَعَ رَکَعَاتٍ بَعْدَ الْعِشَائِ الآخِرَۃِ عُدِلْنَ بِمِثْلِہِنَّ مِنْ لَیْلَۃِ الْقَدْرِ۔",,,7357,,
7358,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنْ شُعْبَۃَ مَوْلَی ابْنِ عَبَّاسٍ ، قَالَ : صَلَّیْت إلَی جَنْبِ ابْنِ عَبَّاسٍ فَفَقَعْت أَصَابِعِی ، فَلَمَّا قَضَیْت الصَّلاَۃ ، قَالَ : لاَ أُمَّ لَکَ أَتَفْقَع أَصَابِعَک وَأَنْتَ فِی الصَّلاَۃ۔",,,7358,,
7359,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ یَکْرَہُ أَنْ یُنْقِضَ الرَّجُلُ أَصَابِعَہُ ، یَعْنِی وَہُوَ فِی الصَّلاَۃ۔",,,7359,,
7360,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، أَنَّہُ کَرِہَ أَنْ یُنْقِضَ أَصَابِعَہُ وَہُوَ فِی الصَّلاَۃ۔,,,7360,,
7361,"حَدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : خَمْسٌ تُنْقِصُ الصَّلاَۃ : التَّمَطِّی وَالأَلْتِفَاتُ وَتَقْلِیبُ الْحَصَی وَالْوَسْوَسَۃُ وَتَفْقِیعُ الأَصَابِعِ۔",,,7361,,
7362,حَدَّثَنَا وَکِیعٌ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، وَعَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ أَنَّہُمَا کَرِہَا أَنْ یُفَرْقِعَ الرَّجُلُ أَصَابِعَہُ وَہُوَ فِی الصَّلاَۃ۔,,,7362,,
7363,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حُصَیْنٌ ، قَالَ : سَأَلْتُ إبْرَاہِیمَ ، عَنِ الرَّجُلِ یَرَی فِی ثَوْبِہِ دَمًا وَہُوَ فِی الصَّلاَۃ ، قَالَ : إِنْ کَانَ کَثِیرًا فَلْیُلْقِ الثَّوْبَ عَنْہُ ، وَإِنْ کَانَ قَلِیلاً فَلْیَمْضِ فِی صَلاَتِہِ۔",,,7363,,
7364,حَدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَنْ بُرْدٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ إذَا کَانَ فِی الصَّلاَۃ فَرَأَی فِی ثَوْبِہِ دَمًا فَاسْتَطَاعَ أَنْ یَضَعَہُ وَضَعَہُ وَإِنْ لَمْ یَسْتَطِعْ أَنْ یَضَعَہُ خَرَجَ فَغَسَلَہُ ، ثُمَّ جَائَ فَبَنَی عَلَی مَا کَانَ صَلَّی۔,,,7364,,
7365,حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عُبَیدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ یَنْصَرِفُ مِنَ الدَّمِ قَلِیلِہِ وَکَثِیرِہِ۔,,,7365,,
7366,"حَدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : إذَا رَأَیْتُہُ وَقَدْ صَلَّیْت بَعْضَ صَلاَتِکَ فَضَعِ الثَّوْبَ عَنْک وَامْضِ فِی صَلاَتِک۔",,,7366,,
7367,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ حَمَّادًا ، عَنِ الرَّجُلِ یُصَلِّی فَیَرَی فِی ثَوْبِہِ الدَّمَ ، قَالَ : یُلْقِی الثَّوْبَ عَنْہُ قُلْتُ ، فَإِنْ لَمْ یَکُنْ إِلاَّ ثَوْبَیْنِ ، قَالَ : یُلْقِی أَحَدَہُمَا وَیَتَوَشَّحُ بِالأَخَرِ۔ وَسَأَلَتُ الْحَکَمَ ، فَقَالَ مِثْلُ ذَلِکَ۔",,,7367,,
7368,حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ أَفْلَحَ ، عَنِ الْقَاسِمِ ، أَنَّہُ کَانَ یُصَلِّی فَرَأَی فِی ثَوْبِہِ دَمًا فَوَضَعَہُ۔,,,7368,,
7369,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ عِمْرَانَ ، عَنْ أَبِی مِجْلَزٍ فِی الدَّمِ یَکُونُ فِی الثَّوْبِ ، قَالَ : إذَا کَبَّرْت وَدَخَلْت فِی الصَّلاَۃ ، وَلَمْ تَرَ شَیْئًا ، ثُمَّ رَأَیْتُہُ بَعْدُ فَأَتِمَّ الصَّلاَۃ۔",,,7369,,
7370,"حَدَّثَنَا وَکِیعٌ، عَنْ إسْرَائِیلَ، عَنْ جَابِرٍ، عَنْ أَبِی جَعْفَرٍ، قَالَ: إذَا رَأَیْت فِی ثَوْبِکَ دَمًا فَامْضِ فِی صَلاَتِک۔",,,7370,,
7371,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ أَبِی الْبَخْتَرِیِّ ، عَنِ الْہُجَیْمِ ، قَالَ : قُلْتُ لِعَبْدِ اللہِ بْنِ رَبَاحٍ : أَرَی الدَّمَ فِی ثَوْبِی وَأَنَا فِی الصَّلاَۃ ، قَالَ : امْضِ فِی صَلاَتِکَ فَإِذَا انْصَرَفْت فَاغْسِلْہُ۔",,,7371,,
7372,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، عَنْ خُصَیْفٍ الْجَزَرِیِّ ، عَنْ مُجَاہِدٍ ، قَالَ: رُخِّصَ لِلشَّیْخِ إذَا أَرَادَ الْقِیَامَ لِلصَّلاَۃِ أَنْ یُقَدِّمَ رِجْلَہُ۔",,,7372,,
7373,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُحَمَّدِ بْنِ عَلِیٍّ السُّلَمِیِّ ، عَنْ إبْرَاہِیمَ بْنِ مَعْبَدٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ فِی الرَّجُلِ یَنْہَضُ فِی الصَّلاَۃ فَیُقَدِّمُ إحْدَی رِجْلَیْہِ فَکَرِہَہُ ، وَقَالَ : ہَذِہِ خُطْوَۃٌ مَلْعُونَۃٌ۔ (ابوداؤد 643۔ ابن خزیمۃ 772)",,,7373,,
7374,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی أَبُو بَکْرٍ عَمَّنْ أَخْبَرَہُ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی أَنْ یُخَمَّرَ الْفَمُ فِی الصَّلاَۃ۔",,,7374,,
7375,حَدَّثَنِی الثَّقَفِیُّ ، عَنْ أَیُّوب ، عَنْ مُحَمَّدٍ ، أَنَّہُ کَانَ یَکْرَہُ أَنْ یُغَطِّیَ الرَّجُلُ فَاہُ وَہُوَ فِی الصَّلاَۃ۔,,,7375,,
7376,حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ شُعْبَۃَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ کَرِہَ أَنْ یُغَطِّیَ فَمَہ وَہُوَ فِی صَلاَۃٍ۔,,,7376,,
7377,حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنْ ہِلاَلِ بْنِ یَِسَافٍ ، عَنْ جَعْدَۃَ بْنِ ہُبَیْرَۃَ ، أَنَّہُ رَأَی رَجُلاً یُصَلِّی وَعَلَیْہِ مِغْفَرٌ وَعِمَامَۃٌ قَدْ غَطَّی بِہِمَا وَجْہَہُ فَأَخَذَ بِمِغْفَرِہِ وَعِمَامَتِہِ فَأَلْقَاہُمَا مِنْ خَلْفِہِ۔,,,7377,,
7378,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : سَأَلْتُہُ ، عَنْ تَغْطِیَۃِ الْفَمِ فِی الصَّلاَۃ وَالطَّوَافِ فَکَرِہَہُ فِی الصَّلاَۃ وَرَخَّصَ فِیہِ فِی الطَّوَافِ۔",,,7378,,
7379,حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ مَالِکِ بْنِ أَنَسٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْمُجَبِّرِ ، أَنَّ سَالِمَ بْنَ عَبْدِ اللہِ کَانَ إذَا رَأَی الرَّجُلَ یُغَطِّی فَاہُ وَہُوَ فِی الصَّلاَۃ جَبَذَ الثَّوْبَ جَبْذًا شَدِیدًا حَتَّی یَنْزِعَہُ عَنْ فِیہِ۔,,,7379,,
7380,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، أَنَّہُ کَرِہَ أَنْ یُغَطِّیَ الرَّجُلُ فَمَہ فِی الصَّلاَۃ۔,,,7380,,
7381,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَجَّاجٍ عَمَّنْ سَمِعَ ابْنَ أَبِی لَیْلَی یَقُولُ مِثْلَہُ۔,,,7381,,
7382,حَدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُسْلِمِ بْنِ بُدَیْلٍ ، أَنَّہُ کَانَ یَکْرَہُ أَنْ یُصَلِّیَ ہَکَذَا وَوَضَعَ أَزْہَرُ ثَوْبَہُ عَلَی شَفَتِہِ۔,,,7382,,
7383,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا بُکَیْر بْن عَامِرٍ ، عَنْ إبْرَاہِیمَ وَالشَّعْبِیِّ أَنَّہُمَا کَرِہَا أَنْ یُغَطِّیَ الرَّجُلُ فَاہُ فِی الصَّلاَۃ۔",,,7383,,
7384,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الْعُمَرِیُّ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَرِہَ أَنْ یَتَلَثَّمَ الرَّجُلُ فِی الصَّلاَۃ۔",,,7384,,
7385,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ہِشَامٌ الدَّسْتَوَائِیُّ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، وَعِکْرِمَۃَ أنَّہُمَا کَرِہَا أَنْ یَتَلَثَّمَ الرَّجُلُ فِی الصَّلاَۃ۔",,,7385,,
7386,حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، أَنَّہُ کَرِہَ أَنْ یُصَلِّیَ الرَّجُلُ مُتَلَثِّمًا۔,,,7386,,
7387,حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ کَرِہَ أَنْ یَتَلَثَّمَ الرَّجُلُ فِی الصَّلاَۃ۔,,,7387,,
7388,حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، أَنَّہُ کَرِہَ لِلرَّجُلِ أَنْ یُصَلِّیَ مُتَلَثِّمًا۔,,,7388,,
7389,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، قَالَ : کَانَ یُکْرَہُ التَّلَثُّمَ فِی ثَلاَثٍ فِی الْقِتَالِ ، وَفِی الْجَنَائِزِ ، وَفِی الصَّلاَۃ۔",,,7389,,
7390,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ خَالِدٍ ، عَنْ رَجُلٍ ، عَنْ عَلِیٍّ ، أَنَّہُ کَرِہَ الاِلْتِثَامَ فِی الصَّلاَۃ عَلَی الأَنْفِ وَالْفَمِ۔,,,7390,,
7391,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ ہَمَّام ، عَنْ قَتَادَۃَ ؛ فِی الرَّجُلِ یُغَطِّی أَنْفَہُ فِی الصَّلاَۃ ، فَقَالَ : حدَّثَنِی عِکْرِمَۃُ ، أَنَّ ابْنَ عَبَّاسٍ کَرِہَ الأَنْفَ۔\n\nقَالَ قَتَادَۃُ : وَکَانَ سَعِیدُ بْنُ الْمُسَیَّبِ وَالنَّخَعِیُّ وَعَطَائٌ یَکْرَہُونَہُ وَکَانَ الْحَسَنُ لاَ یَرَی بِہِ بَأْسًا۔\n\nقَالَ قَتَادَۃُ : فَأَمَّا الْفَمُ فَلاَ أَرَی بِہِ بَأْسًا۔",,,7391,,
7392,حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ أَبِی خَلْدَۃَ ، عَنْ أَبِی الْعَالِیَۃِ ، أَنَّہُ کَرِہَ أَنْ یُغَطِّیَ أَنْفَہُ فِی الصَّلاَۃ۔,,,7392,,
7393,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ حَمَّادًا فَکَرِہَہُ۔",,,7393,,
7394,"حَدَّثَنَا حَفْصٌ ، عَنْ شُعْبَۃَ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، قَالَ : کَانَ یَکْرَہُ أَنْ یُغَطِّیَ أَنْفَہُ وَفَمَہ جَمِیعًا ، وَلاَ یَرَی بَأْسًا أَنْ یُغَطِّیَ فَمَہ دُونَ أَنْفِہِ۔",,,7394,,
7395,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَبْدِ الْحَمِیدِ بْنِ أَبِی رَافِعٍ ، عَنْ سَعِیدِ بْنِ کَعْبٍ ، عَنْ جَابِرِ بْنِ زَیْدٍ ، أَنَّہُ کَرِہَ أَنْ تُصَلِّیَ الْمَرْأَۃُ وَہِیَ مُتَنَقِّبۃٌ ، أَوْ تَطُوفَ وَہِیَ مُتَنَقِّبۃٌ۔",,,7395,,
7396,حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، أَنَّہُ کَرِہَ أَنْ تُصَلِّیَ الْمَرْأَۃُ مُتَنَقِّبۃً۔,,,7396,,
7397,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : کَانَ یَکْرَہُ أَنْ تُصَلِّیَ الْمَرْأَۃُ مُتَنَقِّبۃً۔",,,7397,,
7398,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ ضَمْرَۃَ بْنِ سَعِیدٍ ، سَمِعَ أَبَا سَعِیدٍ یَقُولُ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، عَنْ صَلاَۃٍ بَعْدَ الْعَصْرِ حَتَّی الْغُرُوبِ وَبَعْدَ الْفَجْرِ حَتَّی الطُّلُوعِ۔ (بخاری 1197۔ مسلم 567)",,,7398,,
7399,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ سَعْدِ بْنِ إِبْرَاہِیمَ ، عَن نَصْرِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ جَدِّہِ مُعَاذٍ الْقُرَشِیِّ ، أَنَّہُ طَافَ بِالْبَیْتِ مَعَ مُعَاذِ بْنِ عَفْرَائَ بَعْدَ الْعَصْرِ ، وَبَعْدَ الصُّبْحِ فَلَمْ یُصَلِّ فَسَأَلْتُہُ ، فَقَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ صَلاَۃَ بَعْدَ صَلاَتَیْنِ بَعْدَ الْغَدَاۃِ حَتَّی تَطْلُعَ الشَّمْسُ ، وَبَعْدَ الْعَصْرِ حَتَّی تَغْرُبَ الشَّمْسُ۔ (طبرانی 378۔ احمد 4/219)",,,7399,,
7400,"حَدَّثَنَا أَبُو أُسَامَۃَ ، وَابْنُ نُمَیْرٍ ، عَنْ عُبَیدِ اللہِ بْنِ عُمَرَ ، عَنْ خُبَیب بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ حَفْصِ بْنِ عَاصِمٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، عَنْ صَلاَتَیْنِ ، عَنِ الصَّلاَۃ بَعْدِ طُلُوعِ الْفَجْرِ حَتَّی تَطْلُعَ الشَّمْسُ وَبَعْدَ الْعَصْرِ حَتَّی تَغْرُبَ الشَّمْسُ۔ (بخاری 584۔ احمد 2/496)",,,7400,,
7401,"حَدَّثَنَا أَبُو أُسَامَۃَ ، وَابْنُ نُمَیْرٍ ، عَنْ سَعدِ بْنِ سَعِیدٍ ، قَالَ أَخْبَرَتْنِی عَمْرَۃُ ، عَنْ عَائِشَۃَ ، قَالَتْ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، عَنْ صَلاَتَیْنِ ، عَنْ صَلاَۃٍ بَعْدَ طُلُوعِ الْفَجْرِ حَتَّی تَطْلُعَ الشَّمْسُ وَتَرْتَفِعَ فَإِنَّہَا تَطْلُعُ بَیْنَ قَرْنَیِ الشَّیْطَانِ وتَغِیبُ بَیْنَ قَرْنَیِ الشَّیْطَانِ ، وَعَنْ صَلاَۃٍ بَعْدَ الْعَصْرِ حَتَّی تَغِیبَ الشَّمْسُ۔ (طحاوی 303)",,,7401,,
7402,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ ہِلاَلِ بْنِ یَِسَافٍ ، عَنْ وَہْبِ بْنِ الأَجْدَعِ ، عَنْ عَلِیٍّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ صَلاَۃَ بَعْدَ الْعَصْرِ إِلاَّ أَنْ تَکُونَ الشَّمْسُ بَیْضَائَ نَقِیَّۃً۔(ابوداؤد 1268۔ احمد 1/81)",,,7402,,
7403,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ شُعْبَۃَ ، عَنْ سِمَاکٍ ، قَالَ : سَمِعْتُ الْمُہَلَّبَ بْنَ أَبِی صُفْرَۃَ یُحَدِّثُ ، عَنْ سَمُرَۃََ بْنِ جُنْدُبٍ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : لاَ تُصَلُّوا ، أَوَ قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یُصَلِّیَ بَعْدَ صَلاَۃِ الصُّبْحِ حَتَّی تَطْلُعَ الشَّمْسُ فَإِنَّہَا تَطْلُعُ عَلَی قَرْنٍ ، أَوْ بَیْنَ قَرْنَیْ شَیْطَانٍ۔ (طحاوی 152۔ احمد 5/15)",,,7403,,
7404,"حَدَّثَنَا شَبَابَۃُ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی التَّیَّاحِ ، قَالَ : سَمِعْتُ حُمْرَانَ بْنَ أَبَانَ یُحَدِّثُ ، عَنْ مُعَاوِیَۃَ ، أَنَّہُ نَظَرَ إلَی أُنَاسٍ یُصَلُّونَ بَعْدَ الْعَصْرِ ، فَقَالَ : إنَّکُمْ تُصَلُّونَ صَلاَۃً قَدْ صَحِبْنَا رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَمَا رَأَیْنَاہُ یُصَلِّیہَا وَقَدْ نَہَی عَنْہَا۔ (احمد 4/99)",,,7404,,
7405,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حُسَیْنٍ الْمُعَلِّمِ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی عَنْ صَلاَۃٍ بَعْدَ الْعَصْرِ حَتَّی تَغْرُبَ الشَّمْسُ ، وَعَنْ صَلاَۃٍ بَعْدَ الصُّبْحِ حَتَّی تَطْلُعَ الشَّمْسُ۔,,,7405,,
7406,حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی عَنْ صَلاَتَیْنِ ، عَنْ صَلاَۃٍ بَعْدَ الصُّبْحِ حَتَّی تَطْلُعَ الشَّمْسُ ، وَعَنْ صَلاَۃٍ بَعْدَ الْعَصْرِ حَتَّی تَغْرُبَ الشَّمْسُ۔ (بخاری 585۔ مسلم 289),,,7406,,
7407,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا ہَمَّامٌ ، عَنْ قَتَادَۃَ ، عَنْ أَبِی الْعَالِیَۃِ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : حَدَّثَنی رِجَالٌ مَرْضِیُّونَ فِیہِمْ عُمَرُ وَأَرْضَاہُمْ ، عِنْدِی عُمَرُ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لاَ صَلاَۃَ بَعْدَ الصُّبْحِ حَتَّی تَطْلُعَ الشَّمْسُ ، وَلاَ صَلاَۃَ بَعْدَ الْعَصْرِ حَتَّی تَغْرُبَ الشَّمْسُ۔ (بخاری 581۔ ابوداؤد 1270)",,,7407,,
7408,"حَدَّثَنَا الثَّقَفِیُّ ، عَنِ الْمُہَاجِرِ ، عَنْ أَبِی الْعَالِیَۃِ ، قَالَ : لاَ تَصلُح الصَّلاَۃ بَعْدَ الْعَصْرِ حَتَّی تَغِیبَ الشَّمْسُ وَبَعْدَ الصُّبْحِ حَتَّی تَطْلُعَ الشَّمْسُ ، قَالَ وَکَانَ عُمَرَ یَضْرِبُ عَلَی ذَلِکَ۔",,,7408,,
7409,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، عَنْ مُحَمَّدِ بْنِ شَدَّادٍ ، عَنْ عبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، عَنِ الأَشْتَرِ ، قَالَ : کَانَ خَالِدُ بْنُ الْوَلِیدِ یَضْرِبُ النَّاسَ عَلَی الصَّلاَۃ بَعْدَ الْعَصْرِ۔",,,7409,,
7410,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ووَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ شَقِیقٍ ، عَنْ عَبْدِ اللہِ ، أَنَّ عُمَرَ کَرِہَ الصَّلاَۃ بَعْدَ الْعَصْرِ وَإِنِّی أَکْرَہُ مَا کَرِہَ عُمَرُ۔,,,7410,,
7411,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنْ عَبْدِ اللہِ بْنِ شَقِیقٍ ، قَالَ : رَأَیْتُ عُمَرَ أَبْصَرَ رَجُلاً یُصَلِّی بَعْدَ الْعَصْرِ فَضَرَبَہُ حَتَّی سَقَطَ رِدَاؤُہُ۔",,,7411,,
7412,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ اللہِ بْنِ أَبِی سَارَۃَ ، قَالَ : سَأَلْتُ سَالِمًا ، عَنِ الصَّلاَۃ بَعْدَ الْعَصْرِ ، فَقَالَ : مَا أُحِبُّ أَنْ أَبْتَدِئُ بِصَلاَۃٍ حَتَّی تَغْرُبَ الشَّمْسُ۔",,,7412,,
7413,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : کَانَ یَکْرَہُ الصَّلاَۃ بَعْدَ الْعَصْرِ حَتَّی تَغْرُبَ الشَّمْسُ۔",,,7413,,
7414,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی جَمْرَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : رَأَیْتُ عُمَرَ یَضْرِبُ عَلَی الرَّکْعَتَیْنِ بَعْدَ الْعَصْرِ۔",,,7414,,
7415,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ سَعْدِ بْنِ إبْرَاہِیمَ ، قَالَ : سَمِعْتُ عُبَیْدَ اللہِ بْنَ رَافِعِ بْنِ خَدِیجٍ یُحَدِّثُ ، عَنْ أَبِیہِ ، قَالَ : رَآنِی عُمَرُ بْنُ الْخَطَّابِ یَوْمًا وَأَنَا أُصَلِّی بَعْدَ الْعَصْرِ فَانْتَظَرَنِی حَتَّی صَلَّیْت ، فَقَالَ : مَا ہَذِہِ الصَّلاَۃ؟ فَقُلْت: سَبَقْتنِی بِشَیْئٍ مِنَ الصَّلاَۃ، فَقَالَ عُمَرُ: لَوْ عَلِمْت أَنَّک تُصَلِّی بَعْدَ الْعَصْرِ لَفَعَلْت وَفَعَلْت۔",,,7415,,
7416,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ثَابِتُ بن عُمَارَۃَ ، عَنْ أَبِی تَمِیمَۃَ الْہُجَیْمِیِّ ، عَنِ ابْنِ عُمَرَ ، قَالَ : صَلَّیْت مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَمَعَ أَبِی بَکْرٍ وَعُمَرَ وَعُثْمَانَ فَلاَ صَلاَۃَ بَعْدَ الْغَدَاۃِ حَتَّی تَطْلُعَ الشَّمْسُ۔ (ابوداؤد 1410۔ احمد 2/106)",,,7416,,
7417,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ ، عَنْ عَلِیٍّ ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّی عَلَی إِثْرِ کُلِّ صَلاَۃٍ مَکْتُوبَۃٍ رَکْعَتَیْنِ إِلاَّ الْفَجْرَ وَالْعَصْرَ۔ (ابوداؤد 1269۔ احمد 1/124)",,,7417,,
7418,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، عَنِ السَّائِبِ ، قَالَ : رَأَیْتُ عُمَرَ بْنَ الْخَطَّابِ یَضْرِبُ الْمُنْکَدِرَ عَلَی السَّجْدَتَیْنِ بَعْدَ الْعَصْرِ ، یَعْنِی الرَّکْعَتَیْنِ۔",,,7418,,
7419,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ عِمْرَانَ ، عَنْ سُوَیْد ، وَعَنْ أَبِی حُصَیْنٍ ، عَنْ قَبِیصَۃَ بْنِ جَابِرٍ ، قَالاَ : کَانَ عُمَرُ یَضْرِبُ عَلَی الرَّکْعَتَیْنِ بَعْدَ الْعَصْرِ۔",,,7419,,
7420,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الْمُخْتَارِ ، قَالَ : سَأَلْتُ أَنَسَ بْنَ مَالِکٍ ، عَنِ الصَّلاَۃ بَعْدَ الْعَصْرِ ، فَقَالَ : کَانَ عُمَرُ یَضْرِبُ الأَیْدِی عَلَی الصَّلاَۃ بَعْدَ الْعَصْرِ۔",,,7420,,
7421,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا أَبُو ہِلاَلٍ ، عَنِ ابن بُرَیْدَۃَ ، عَنْ أَبِی سَعِیدٍ ، قَالَ تَمْرَتَانِ بِزُبْدٍ أَحَبُّ إلَیَّ مِنْ صَلاَۃٍ بَعْدَ الْعَصْرِ۔",,,7421,,
7422,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ یَعْلَی بْنِ عَطَائٍ ، عَنْ یَزِیدَ بْنِ طَلْقٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْبَیْلَمَانِیِّ ، عَنْ عَمْرِو بْنِ عَبَسَۃَ ، قَالَ : قُلْتُ : یَا رَسُولَ اللہِ ہَلْ مِنْ سَاعَۃٍ أَقْرَبُ إلَی اللہِ مِنْ سَاعَۃٍ ، فَقَالَ : نَعَمْ جَوْفُ اللَّیْلِ فَصَلِّ مَا بَدَا لَکَ حَتَّی تُصَلِّیَ الصُّبْحَ ، ثُمَّ أَنْہِہْ حَتَّی تَطْلُعَ الشَّمْسُ وَمَا دَامَتْ : کأَنَّہَا حجفَۃٌ حَتَّی تَنْتَشِرَ ، ثُمَّ صَلِّ مَا بَدَا لَکَ حَتَّی یَقُومَ الْعَمُودُ عَلَی ظِلِّہِ ، ثُمَّ أَنْہِہْ حَتَّی تَزُولَ الشَّمْسُ فَإِنَّ جَہَنَّمَ تُسجَرُ نِصْفَ النَّہَارِ ، ثُمَّ صَلِّ مَا بَدَا لَکَ حَتَّی تُصَلِّیَ الْعَصْرَ ، ثُمَّ أَنْہِہْ حَتَّی تَغْرُبَ الشَّمْسُ فَإِنَّہَا تَطْلُعُ بَیْنَ قَرْنَیْ شَیْطَانٍ وَتَغْرُبُ بَیْنَ قَرْنَیْ شَیْطَانٍ۔ (نسائی 1560۔ احمد 4/113)",,,7422,,
7423,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، قَالَتْ : مَا تَرَکَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَکْعَتَیْنِ بَعْدَ الْعَصْرِ فِی بَیْتِی قَطُّ۔ (بخاری 591۔ مسلم 299)",,,7423,,
7424,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ یَزِیدَ ، عَنْ عَبْدِ اللہِ بْنِ الْحَارِثِ ، قَالَ : دَخَلْت مَعَ ابْنِ عَبَّاسٍ عَلَی مُعَاوِیَۃَ فَأَجْلَسَہُ مُعَاوِیَۃُ عَلَی السَّرِیرِ ، ثُمَّ قَالَ لَہُ : مَا رَکْعَتَانِ یُصَلِّیہِمَا النَّاسُ بَعْدَ الْعَصْرِ لَمْ نَرَ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلاَّہُمَا وَلاَ أَمَرَ بِہِمَا قَالَ : ذَلِکَ مَا یُفْتِی بِہِ النَّاسَ ابْنُ الزُّبَیْرِ ، فَأَرْسَلَ إلَی ابْنِ الزُّبَیْرِ فَسَأَلَہُ ، فَقَالَ: أَخْبَرَتْنِی ذَلِکَ عَائِشَۃُ ، فَأَرْسَلَ إلَی عَائِشَۃَ ، فَقَالَتْ : أَخْبَرَتْنِی ذَلِکَ أُمُّ سَلَمَۃَ ، فَأَرْسَلَ إلَی أُمِّ سَلَمَۃَ فَانْطَلَقَتْ مَعَ الرَّسُولِ فَسَأَلَ أُمَّ سَلَمَۃَ ، فَقَالَتْ یَرْحَمُہَا اللَّہُ مَا أَرَادَتْ إلَی ہَذَا فَقَدْ أَخْبَرْتہُا ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی عَنْہُمَا۔\n\nإنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَیْنَمَا ہُوَ فِی بَیْتِی یَتَوَضَّأُ للظُّہْر وَکَانَ قَدْ بَعَثَ سَاعِیًا وَکَثُرَ عِنْدَہُ الْمُہَاجِرُونَ وَکَانَ قَدْ أَہَمَّہُ شَأْنُہُمْ إذْ ضَرَبَ الْبَابَ فَخَرَجَ إلَیْہِ فَصَلَّی الظُّہْرَ ، ثُمَّ جَلَسَ یُقسِمُ مَا جَائَ بِہِ فَلَمْ یَزَلْ کَذَلِکَ حَتَّی صَلَّی الْعَصْرَ ، فَلَمَّا فَرَغَ رَآہ بِلاَلٌ فَأَقَامَ الصَّلاَۃ فَصَلَّی الْعَصْرَ ثُمَّ دَخَلَ مَنْزِلِی فَصَلَّی رَکْعَتَیْنِ ، فَلَمَّا فَرَغَ قُلْتُ : مَا رَکْعَتَانِ رَأَیْتُک تُصَلِّیہِمَا بَعْدَ الْعَصْرِ لَمْ أَرَک تُصَلِّیہِمَا ، فَقَالَ : شَغَلَنِی أَمْرُ السَّاعِی لَمْ أَکُنْ صَلَّیْتُہُمَا بَعْدَ الظُّہْرِ فَصَلَّیْتہمَا۔\n\nفَقَالَ ابْنُ الزُّبَیْرِ : قَدْ صَلاَّہُمَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَأَنَا أُصَلِّیہِمَا۔(ابوداؤد 2167۔ احمد 6/311)",,,7424,,
7425,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : رَأَیْتُ أَبَا بُرْدَۃَ بْنَ أَبِی مُوسَی یُصَلِّی بَعْدَ الْعَصْرِ رَکْعَتَیْنِ۔",,,7425,,
7426,حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ شُعْبَۃَ ، عَنْ أَشْعَثَ بْنِ أَبِی الشَّعْثَائِ ، قَالَ خَرَجْت مَعَ أَبِی وَعَمْرِو بْنِ مَیْمُونٍ وَالأَسْوَدِ بْنِ یَزِیدَ ، وَأَبِی وَائِلٍ فَکَانُوا یُصَلُّونَ بَعْدَ الْعَصْرِ رَکْعَتَیْنِ۔,,,7426,,
7427,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا أَبُو عَوَانَۃَ ، قَالَ : حَدَّثَنَا إبْرَاہِیمُ بْنُ مُحَمَّدِ بْنِ الْمُنْتَشِرِ ، عَنْ أَبِیہِ ، أَنَّہُ کَانَ یُصَلِّی بَعْدَ الْعَصْرِ رَکْعَتَیْنِ فَقِیلَ لَہُ ، فَقَالَ : لَوْ لَمْ أُصَلِّہِمَا إِلاَّ أَنِّی رَأَیْت مَسْرُوقًا یُصَلِّیہِمَا لَکَانَ ثِقَۃً وَلَکِنِّی سَأَلْت عَائِشَۃَ ، فَقَالَتْ کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لاَ یَدَعُ رَکْعَتَیْنِ قَبْلَ الْفَجْرِ وَرَکْعَتَیْنِ بَعْدَ الْعَصْرِ۔",,,7427,,
7428,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا أَبُو عَوَانَۃَ ، قَالَ : حَدَّثَنَا إبْرَاہِیمُ بْنُ مُحَمَّدِ بْنِ الْمُنْتَشِرِ ، عَنْ أَبِی طَلْحَۃَ مولی شُرَیْحٍ ، قَالَ : کَانَ شُرَیْحٌ یُصَلِّی رَکْعَتَیْنِ بَعْدَ الْعَصْرِ أَخَذَہُمَا عَنْ مَسْرُوقٍ۔",,,7428,,
7429,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، أَنَّ الزُّبَیْرَ ، وَعَبْدَ اللہِ بْنَ الزُّبَیْرِ کَانَا یُصَلِّیَانِ بَعْدَ الْعَصْرِ رَکْعَتَیْنِ۔",,,7429,,
7430,حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ ، عَنْ عَلِیٍّ ، أَنَّہُ صَلَّی بِفُسْطَاطِہِ بِصِفِّینَ رَکْعَتَیْنِ بَعْدَ الْعَصْرِ۔,,,7430,,
7431,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا طَلْحَۃُ بْنُ یَحْیَی ، قَالَ : سَمِعْتُ عُبَیْدَ اللہِ بْنَ عَبْدِ اللہِ بْنِ عُتْبَۃَ ، عَنْ أُمِّ سَلَمَۃَ ، قَالَتْ : شُغِلَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، عَنِ الرَّکْعَتَیْنِ بَعْدَ الظُّہْرِ فَصَلاَّہُمَا بَعْدَ الْعَصْرِ۔ (احمد 6/306۔ طبرانی 583)",,,7431,,
7432,"حَدَّثَنَا جَعْفَرُ بْنُ عَوْنٍ ، عَنْ مِسْعَرٍ ، عَنْ حَبِیبِ بْنِ أَبِی ثَابِتٍ ، عَنْ أَبِی الضُّحَی ، عَنْ مَسْرُوقٍ ، قَالَ : حَدَّثَتْنِی الصِّدِّیقَۃُ بِنْتُ الصِّدِّیقِ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَا دَخَلَ عَلَیْہَا بَعْدَ الْعَصْرِ إِلاَّ صَلَّی رَکْعَتَیْنِ۔",,,7432,,
7433,"حَدَّثَنَا عَبْدُ الْوَہَّابِ بْنُ عَطَائٍ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : سَأَلْتُ أَبَا جُحَیْفَۃَ عَنْہُمَا فَقَالَ : إِنْ لَمْ تَنْفَعَاک لَمْ تَضُرَّاک۔",,,7433,,
7434,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، وَأَبُو أُسَامَۃَ ، قَالاَ : حدَّثَنَا عُبَیْدُ اللہِ بْنُ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : لاَ تَتَحَیَّنَنَّ عِنْدَ طُلُوعِ الشَّمْسِ ، وَلاَ غُرُوبِہَا بِالصَّلاَۃ فَإِنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَنْہَی عَنْ ذَلِکَ۔ (نسائی 1546)",,,7434,,
7435,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مُوسَی بْنُ عُلَیٍّ ، عَنْ أَبِیہِ ، عَنْ عُقْبَۃَ بْنِ عَامِرٍ ، قَالَ : سَمِعْتُہ یَقُولُ ثَلاَثُ سَاعَاتٍ کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَنْہَانَا أَنْ نُصَلِّیَ فِیہَا أَوْ أَنْ نَقْبُرَ فِیہِنَّ مَوْتَانَا حِینَ تَطْلُعُ الشَّمْسُ بَازِغَۃً حَتَّی تَرْتَفِعَ وَحِینَ تَضَیَّفُ لِلْغُرُوبِ حَتَّی تَغِیبَ وَحِینَ یَقُومُ قَائِمُ الظَّہِیرَۃِ حَتَّی تَمِیلَ۔ (ترمذی 1030۔ ابوداؤد 3185)",,,7435,,
7436,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ عَاصِمٍ ، عَنْ زِرٍّ ، عَنْ عَبْدِ اللہِ ، قَالَ : إنَّ الشَّمْسَ تَطْلُعُ حِینَ تَطْلُعُ بَیْنَ قَرْنَیْ شَیْطَانٍ ، قَالَ : فَکُنَّا نُنْہَی ، عَنِ الصَّلاَۃ عِنْدَ طُلُوعِ الشَّمْسِ ، وَعِنْدَ غُرُوبِہَا۔ (ابو یعلی 4977۔ بزار 1823)",,,7436,,
7437,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ قَیْسِ بْنِ مُسْلِمٍ ، عَنْ طَارِقِ بْنِ شِہَابٍ ، عَنْ بِلاَلٍ ، قَالَ : لَمْ یُنْہَ عَنِ الصَّلاَۃ إِلاَّ عِنْدَ غُرُوبِ الشَّمْسِ لأنَّہَا تَغْرُبُ فِی قَرْنِ الشَّیْطَانِ۔",,,7437,,
7438,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ حَبِیبٍ ، عَنْ عَطَائٍ ، قَالَ : حدَّثَنِی عُرْوَۃُ بْنُ الزُّبَیْرِ ، أَنَّ أُنَاسًا طَافُوا بِالْبَیْتِ بَعْدَ الْفَجْرِ، ثُمَّ قَعَدُوا عِنْدَ الْمَذْکَرِ حَتَّی إذَا کَانَ عِنْدَ طُلُوعِ الشَّمْسِ قَامُوا یُصَلُّونَ ، قَالَتْ عَائِشَۃُ: قَعَدُوا حَتَّی إذَا کَانَتِ السَّاعَۃُ الَّتِی یُکْرَہُ فِیہِ الصَّلاَۃ قَامُوا یُصَلُّونَ۔",,,7438,,
7439,"حَدَّثَنَا وَکِیعٌ ، عَنْ بِسْطَامِ بْنِ مُسْلِمٍ ، عَنْ أَبِی رَجَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ یُصَلَّ عِنْدَ طُلُوعِ الشَّمْسِ ، وَلاَ حِینَ تَغْرُبُ فَإِنَّہَا تَطْلُعُ وَتَغْرُبُ فِی قَرْنَیْ شَیْطَانٍ وَلَکِنْ إذَا صَفَتْ وَعَلَتْ۔",,,7439,,
7440,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ مِسْعَرٍ ، عَنْ عُبَیْدِ بن الْحَسَنِ ، عَنِ ابْنِ مَعقِل ، قَالَ : رَأَی أَبُو مَسْعُودٍ رَجُلاً یُصَلِّی عِنْدَ طُلُوعِ الشَّمْسِ ، أَوْ فِی السَّاعَۃِ الَّتِی تُکْرَہُ فِیہَا الصَّلاَۃ فَأَمَرَ رَجُلاً فَنَہَاہُ۔",,,7440,,
7441,"حَدَّثَنَا عَبْدُ الْوَہَّابِ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ ، أَنَّ شُرَیْحًا رَأَی رَجُلاً یُصَلِّی حِینَ اصْفَارَّتِ الشَّمْسُ ، فَقَالَ : انْہَوْا ہَذَا أَنْ یُصَلِّیَ فَإِنَّ ہَذِہِ سَاعَۃٌ لاَ تَحِلُّ فِیہَا الصَّلاَۃ۔",,,7441,,
7442,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ہِشَامُ بْنُ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تَحَرَّوْا بِصَلاَتِکُمْ طُلُوعَ الشَّمْسِ ، وَلاَ غُرُوبَہَا فَإِنَّہَا تَطْلُعُ بِقَرْنِ الشَّیْطَانِ۔ (بخاری 582۔ نسائی 1551)",,,7442,,
7443,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ہِشَامُ بْنُ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا بَدَا حَاجِبُ الشَّمْسِ فَأَخِّرُوا الصَّلاَۃ حَتَّی تَبْرُزَ ، وَإِذَا غَابَ حَاجِبُ الشَّمْسِ فَأَخِّرُوا الصَّلاَۃ حَتَّی تَغِیبَ۔ (بخاری 3272)",,,7443,,
7444,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عِیسَی بْنُ حُمَیْدٍ الرَّاسِبِیُّ ، قَالَ : سَمِعْتُ الْحَسَنَ یَقُولُ : کَانُوا یَکْرَہُونَ الصَّلاَۃ عِنْدَ طُلُوعِ الشَّمْسِ حَتَّی تَرْتَفِعَ ، وَعِنْدَ غُرُوبِہَا حَتَّی تَغِیبَ۔",,,7444,,
7445,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : قَالَ ابْنُ مَسْعُودٍ : مَا أُحِبُّ أَنَّ لِی بِصَلاَۃِ الرَّجُلِ حِینَ تَصْفَارُّ الشَّمْسُ فَلْسَیْنِ۔",,,7445,,
7446,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَفْرِیقِیِّ ، عَنْ عَبْدِ اللہِ بْنِ یَزِیدَ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ صَلاَۃَ بَعْدَ طُلُوعِ الْفَجْرِ إِلاَّ رَکْعَتَیْنِ قَبْلَ صَلاَۃِ الْفَجْرِ۔ (دارقطنی 2۔ عبدالرزاق 4757)",,,7446,,
7447,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی مُحَمَّدٍ الْیَمَامیِّ ، عَنْ طَاوُوسٍ ، عَنِ ابْنِ عُمَرَ ، وَابْنِ عَبَّاسٍ ، قَالاَ : لاَ صَلاَۃَ بَعْدَ طُلُوعِ الْفَجْرِ إِلاَّ رَکْعَتَیِ الْفَجْرِ۔",,,7447,,
7448,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حَجَّاجٌ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ قَالَ : لاَ صَلاَۃَ بَعْدَ رَکْعَتَیِ الْفَجْرِ حَتَّی تُصَلِّیَ الْفَجْرَ۔",,,7448,,
7449,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الشَّیْبَانِیِّ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، قَالَ : رَآنِی سَعِیدُ بْنُ الْمُسَیَّبِ وَأَنَا أُصَلِّی بَعْضَ مَا فَاتَنِی مِنْ صَلاَۃِ اللَّیْلِ بَعْدَ مَا طَلَعَ الْفَجْرُ ، فَقَالَ : أَمَا عَلِمْت أَنَّ الصَّلاَۃ تُکْرَہُ ہَذِہِ السَّاعَۃَ إِلاَّ رَکْعَتَیْنِ قَبْلَ صَلاَۃِ الْفَجْرِ۔",,,7449,,
7450,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یَکْرَہُونَ إذَا طَلَعَ الْفَجْرُ أَنْ یُصَلُّوا إِلاَّ رَکْعَتَیْنِ۔",,,7450,,
7451,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یَکْرَہُونَ الصَّلاَۃ بَعْدَ رَکْعَتَیِ الْفَجْرِ حَتَّی یُصَلُّوا الْمَکْتُوبَۃَ۔",,,7451,,
7452,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، قَالَ : مَنْ شَائَ أَنْ یُصَلِّیَ بَعْدَ طُلُوعِ الْفَجْرِ فَلْیَفْعَلْ۔",,,7452,,
7453,"حَدَّثَنَا حَفْصٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، قَالَ : إنَّ بَعْدَ طُلُوعِ الْفَجْرِ لَجُزْئًا حَسَنًا ، وَکَانَ یَقْرَأُ بَعْدَ الْفَجْرِ بِالْبَقَرَۃِ۔",,,7453,,
7454,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مَنْصُورِ بْنِ الأَشَلِّ الْغُدَانِیِّ ، قَالَ : سَأَلَ أَبُو حَصِینٍ الشَّعْبِیَّ وَأَنَا أَسْمَعُ ، عَنْ رَجُلٍ بَقِیَ عَلَیْہِ مِنْ وِرْدِہِ شَیْئٌ وَہُوَ یُصَلِّی وَقَدْ طَلَعَ الْفَجْرُ ، فَقَالَ : یَقْرَأُ بَقِیَّۃَ وِرْدِہِ۔",,,7454,,
7455,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : رَأَیْتُ أَبَا إِسْحَاقَ وَالْحَکَمَ یُصَلِّیَانِ بَعْدَ طُلُوعِ الْفَجْرِ۔",,,7455,,
7456,"حَدَّثَنَا شَرِیکٌ ، عَنْ عَاصِمٍ ، عَنْ زِرٍّ ، قَالَ : رَأَیْتُ عَبْدَ الرَّحْمَن بْنَ عَوْفٍ وَأُبَیَّ بْنَ کَعْبٍ إذَا أَذَّنَ الْمُؤَذِّنُ لِلْمَغْرِبِ قَامَا فصَلَّیَا رَکْعَتَیْنِ۔",,,7456,,
7457,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ حُمَیْدٍ ، عَنْ أَنَسٍ ، قَالَ : سُئِلَ عَنِ الرَّکْعَتَیْنِ قَبْلَ الْمَغْرِبِ ، فَقَالَ : رَأَیْتُہُمْ إذَا أَذَّنَ الْمُؤَذِّنُ ابْتَدَرُوا السَّوَارِیَ فَصَلَّوْا۔",,,7457,,
7458,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ یَعْلَی بْنِ عَطَائٍ ، عَنْ أَبِی فَزَارَۃَ ، قَالَ : سَأَلْتُ أَنَسًا ، عَنِ الرَّکْعَتَیْنِ قَبْلَ الْمَغْرِبِ ، فَقَالَ : کُنَّا نَبْتَدِرُہُمَا عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔ (بخاری 625۔ ابوداؤد 1276)",,,7458,,
7459,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، قَالَ : رَأَیْتُ ابْنَ أَبِی لَیْلَی صَلَّی رَکْعَتَیْنِ قَبْلَ الْمَغْرِبِ۔",,,7459,,
7460,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ حَبِیبِ بْنِ أَبِی ثَابِتٍ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، قَالَ : أَدْرَکْت أَصْحَابَ مُحَمَّدٍ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلُّونَ عِنْدَ کُلِّ تَأْذِینٍ۔",,,7460,,
7461,"حَدَّثَنَا وَکِیعٌ ، عَنْ کَہَمْسٍ ، عَنِ ابْنِ بُرَیْدَۃَ ، عَنْ عَبْدِ اللہِ بْنِ الْمُغَفَّلِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : بَیْنَ کُلِّ اَذَانَیْنِ صَلاَۃٌ بَیْنَ کُلِّ اَذَانَیْنِ صَلاَۃٌ بَیْنَ کُلِّ اَذَانَیْنِ صَلاَۃٌ لِمَنْ شَائَ۔ (بخاری 627۔ مسلم 304)",,,7461,,
7462,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنِ الْجُرَیْرِیِّ ، عَنِ ابْنِ بُرَیْدَۃَ ، عَنْ عَبْدِ اللہِ بْنِ الْمُغَفَّلِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِمِثْلِہِ۔ (بخاری 624۔ ابوداؤد 1277),,,7462,,
7463,"حَدَّثَنَا وَکِیعٌ ، عَنْ یَزِیدَ بْنِ إبْرَاہِیمَ ، قَالَ : قَالَ تَمِیمُ بْنُ سَلاَّمٍ ، أَوْ سَلاَّمُ بْنُ تَمِیمٍ لِلْحَسَنِ : مَا تَقُولُ فِی الرَّکْعَتَیْنِ قَبْلَ الْمَغْرِبِ ، فَقَالَ : حَسَنَتَانِ جَمِیلَتَانِ لِمَنْ أَرَادَ اللَّہُ بِہِمَا۔",,,7463,,
7464,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : مَا رَأَیْت فَقِیہًا یُصَلِّی قَبْلَ الْمَغْرِبِ إِلاَّ سَعْدَ بْنَ أَبِی وَقَّاصٍ۔",,,7464,,
7465,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَمِعْتُ شَیْخًا بِوَاسِطٍ یَقُولُ : سَمِعْت طَاوُوسًا یقول : سَأَلْت ابْنَ عُمَرَ، عَنِ الرَّکْعَتَیْنِ قَبْلَ الْمَغْرِبِ فَلَمْ یَنْہَ عَنْہُمَا۔",,,7465,,
7466,"حَدَّثَنَا وَکِیعٌ ، عَنْ خَارِجَۃَ بْنِ مُصْعَبٍ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، عْن عَطَائِ بْنِ یَسَارٍ ، قَالَ : قَالَ رَسُولُ اللہِ: لاَ تَسْتَقْبِلُ الصُّورَۃُ الصُّورَۃَ۔",,,7466,,
7467,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَانَ إبْرَاہِیمُ جَالِسًا مُوَلِّیًا ظَہْرَہُ إلَی الْقِبْلَۃِ وَإِنْسَانٌ قَائِمٌ یُصَلِّی مُسْتَقْبِلَہُ فَأَخَذَ إبْرَاہِیمُ یَتَّقِیہِ بِیَدِہِ مِنْ ہَذَا الْجَانِبِ وَمِنْ ہَذَا الْجَانِبِ۔",,,7467,,
7468,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا حَنْظَلَۃُ الْجُمَحِیُّ ، عَنْ طَاوُوسٍ ، أَنَّ رَجُلاً نَذَرَ أَنْ یَسْجُدَ عَلَی جَبْہَۃِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَأَتَاہُ فَجَلَسَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مُسْتَقْبِلَ الْقِبْلَۃِ ، ثُمَّ أَقَامَ الرَّجُلَ خَلْفَہُ ، وَقَالَ ہَکَذَا بِجَبْہَتِہِ فَسَجَدَ عَلَیْہَا۔",,,7468,,
7469,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عَبْدُ اللہِ بْنُ مَعْدَانَ أَبُو مَعْدَانَ ، قَالَ : سَمِعْتُ طَاوُوسًا یُحَدِّثُ بِہَذَا الْحَدِیثِ وَزَادَ فِیہِ ، فَقَالَ لَہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : قَدْ وَفَیْتَ بِنَذْرِکَ۔ (نسائی 7630۔ احمد 214)",,,7469,,
7470,حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، أَنَّہُ کَانَ یُہَرْوِلُ إلَی الصَّلاَۃ۔,,,7470,,
7471,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، عَنْ إبْرَاہِیمَ ، قَالَ : رَأَیْتُ عَبْدَ الرَّحْمَن بْنَ یَزِیدَ مُسَارِعًا إلَی الصَّلاَۃ۔",,,7471,,
7472,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا ابْنُ جُرَیْجٍ، عَنْ رَجُلٍ مِنْ أَہْلِ الْمَدِینَۃِ، عَنِ ابْنِ عُمَرَ، أَنَّہُ کَانَ یُہَرْوِلُ إلَی الصَّلاَۃ۔",,,7472,,
7473,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا مَالِکُ بْنُ أَنَسٍ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّہُ سَمِعَ الإِقَامَۃَ بِالْبَقِیعِ فَأَسْرَعَ الْمَشْیَ۔",,,7473,,
7474,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا شَرِیکٌ، عَنْ عِمْرَانَ بْنِ مُسْلِمٍ، قَالَ: رَأَیْتُ سَعِیدَ بْنَ جُبَیْرٍ یُہَرْوِلُ إلَی الصَّلاَۃ۔",,,7474,,
7475,"حَدَّثَنَا عَبِیْدَۃُ بْنُ حُمَیْدٍ ، عَنْ عِمْرَانَ بْنِ مُسْلِمٍ ، قَالَ : رَأَیْتُ سَعِیدَ بْنَ جُبَیْرٍ یُہَرْوِلُ إلَی الصَّلاَۃ۔",,,7475,,
7476,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَمْرِو بْنِ قَیْسٍ الْمُلاَئِیِّ ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنْ عُمَارَۃَ بْنِ عُمَیْرٍ ، قَالَ : قَالَ عَبْدُ اللہِ : أَحَقُّ مَا سَعَیْنَا إلَیْہِ الصَّلاَۃ۔",,,7476,,
7477,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا سُفْیَانُ، عَنْ عَاصِمِ بْنِ عُبَیْدِاللہِ، قَالَ: رَأَیْتُ ابْنَ عُمَرَ یُہَرْوِلُ إلَی الْمَسْجِدِ فِی کُسُوفٍ وَمَعَہُ نَعْلاَہُ۔",,,7477,,
7478,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ أَبِی ہُرَیْرَۃَ رِوَایَۃً ، قَالَ : إذَا أَتَیْتُمُ الصَّلاَۃ فَلاَ تَأْتُوہَا وَأَنْتُمْ تَسْعَوْنَ وَأْتُوہَا وَعَلَیْکُمُ السَّکِینَۃُ فَمَا أَدْرَکْتُمْ فَصَلُّوا وَمَا فَاتَکُمْ فَاقْضُوا۔ (بخاری 636۔ ابوداؤد 573)",,,7478,,
7479,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ سَعْدِ بْنِ إِبْرَاہِیمَ ، عَن عُمَرَ بْنِ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا أَتَیْتُمُ الصَّلاَۃ فَأْتُوہَا بِالْوَقَارِ وَالسَّکِینَۃِ فَمَا أَدْرَکْتُمْ فَصَلُّوا وَمَا فَاتَکُمْ فَأَتِمُّوا۔ (بخاری 636۔ ترمذی 327)",,,7479,,
7480,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ عَمْرٍو ، عَنْ أَبِی نَضْرَۃَ ، عَنْ أَبِی ذَرٍّ ، قَالَ : إذَا أُقِیمَتِ الصَّلاَۃ فَامْشِ إلَیْہَا کَمَا کُنْت تَمْشِی فَصَلِّ مَا أَدْرَکْت وَاقْضِ مَا سَبَقَک۔",,,7480,,
7481,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : إذَا ثُوِّبَ بِالصَّلاَۃ فَامْشُوا وَعَلَیْکُمُ السَّکِینَۃَ وَالْوَقَارَ فَصَلُّوا مَا أَدْرَکْتُمْ وَاقْضُوا مَا سَبَقَکُمْ۔ (مسلم 154)",,,7481,,
7482,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی عُبَیْدَۃَ ، عَنْ عَبْدِ اللہِ ، قَالَ : امْشُوا إلَی الصَّلاَۃ وَقَارِبُوا بَیْنَ الْخُطَا وَاذْکُرُوا اللَّہَ۔",,,7482,,
7483,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الْمَسْعُودِیُّ ، عَنْ عَلِیِّ بْنِ الأَقْمَرِ ، عَنْ أَبِی الأَحْوَص ، قَالَ : قَالَ عَبْدُ اللہِ: لَقَدْ رَأَیْتُنَا وَإِنَّا لَنُقَارِبُ بَیْنَ الْخُطَا إلَی الصَّلاَۃ۔",,,7483,,
7484,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا جَعْفَرُ بْنُ حَیَّانَ أَبُو الأَشْہَبِ ، عَنْ ثَابِتٍ الْبُنَانِیِّ ، عَنْ أَنَسِ بْنِ مَالِکٍ ، قَالَ : خَرَجْت مَعَ زَیْدِ بْنِ ثَابِتٍ إلَی الْمَسْجِدِ فَأَسْرَعْتُ الْمَشْیَ فَحَبَسَنِی۔",,,7484,,
7485,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ دَاوُدَ بْنِ فَرَاہِیجَ ، قَالَ : حدَّثَنِی مَوْلاَیَ سُفْیَانُ بْنُ زِیَادٍ ، أَنَّہُ کَانَ یَنْطَلِقُ إلَی الْمَسْجِدِ وَہُوَ یَسْتَعْجِلُ ، قَالَ : فَلَحِقَنِی الزُّبَیْرُ بْنُ الْعَوَّامِ ، فَقَالَ : اقْصِدْ فِی مَشْیِکَ فَإِنَّک فِی صَلاَۃٍ لَنْ تَخْطُوَ خُطْوَۃً إِلاَّ رَفَعَ اللَّہُ لَکَ بِہَا دَرَجَۃً ، وَحَطَّ عَنْکَ بِہَا خَطِیئَۃً۔",,,7485,,
7486,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ خَالِدِ بْنِ أَبِی بَکْرٍ ، عَنْ بُہَیَّۃَ حَاضِنَۃِ بَنِی عَبْدِ اللہِ ، قَالَتْ : سَمِعْتُ الإِقَامَۃَ فَأَسْرَعْت فَمَرَرْتُ بِعَلِیِّ بْنِ حُسَیْنٍ وَأَنَا مُسْرِعَۃٌ فَجَذَبَ ثَوْبِی ، وَقَالَ : امْشی عَلَی رِسْلِک۔",,,7486,,
7487,"حَدَّثَنَا یَحْیَی بْنُ یَعْلَی ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، قَالَ : عُدْنَا مُجَاہِدًا أَنَا وَصَاحِبٌ لِی فَحَضَرَتِ الصَّلاَۃ، فَقَالَ : انْطَلِقُوا فَصَلُّوا وَامْشُوا عَلَی ہَیْنَتِکُمْ فَمَا أَدْرَکْتُمْ مَعَ الإِمَامِ فَصَلُّوا وَمَا فَاتَکُمْ فَأَتِمُّوا۔",,,7487,,
7488,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَبِی سِنَانٍ ، عَنْ مُحَمَّدِ بْنِ زَیْدِ بْنِ خُلَیْدَۃَ ، قَالَ : کُنْتُ أَمْشِی مَعَ ابْنِ عُمَرَ إلَی الصَّلاَۃ فَلَوْ مَشَتْ مَعَہُ نَمْلَۃٌ لَرَأَیْتُ أَنْ لاَ یَسْبِقَہَا۔",,,7488,,
7489,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا حُمَیْدٌ الطَّوِیلُ ، عَنْ ثَابِتٍ ، قَالَ : أَخَذَ بِیَدِی أَنَسٌ فَجَعَلَ یَمْشِی رُوَیْدًا إلَی الصَّلاَۃ ، ثُمَّ الْتَفَتَ إلَیَّ ، فَقَالَ : ہَکَذَا کَانَ یَصْنَعُ زَیْدُ بْنُ ثَابِتٍ لِتَکْثُرَ خُطَاہُ۔",,,7489,,
7490,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ ثَابِتِ بْنِ عُبَیْدٍ ، عَنِ الْقَاسِمِ بْنِ مُحَمَّدٍ ، عَنْ عَائِشَۃَ ، قَالَتْ : قَالَ لِی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: نَاوِلِینِی الْخُمْرَۃَ مِنَ الْمَسْجِدِ فَقُلْتُ: إنِّی حَائِضٌ، فَقَالَ إنَّ حَیْضَتَکِ لَیْسَتْ فِی یَدِک۔ (مسلم 244۔ ترمذی 134)",,,7490,,
7491,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : سُئِلَ ابْنُ عُمَرَ ، عَنِ الْحَائِضِ تُنَاوِلُ الرَّجُل الطَّہُورَ، أَوِ الشَّیْئَ مِنَ الْمَسْجِدِ ، فَقَالَ : إنَّ حَیْضَتَہَا لَیْسَتْ فِی یَدِہَا۔",,,7491,,
7492,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ أَنْ تَضَعَ الْحَائِضُ فِی الْمَسْجِدِ الشَّیْئَ وَتَأْخُذَہُ مِنْہُ ، وَلاَ تَدْخُلُہُ۔",,,7492,,
7493,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ تَضَعَ الْحَائِضُ فِی الْمَسْجِدِ مَا شَائَتْ وَتَأْخُذَہُ مِنْہُ۔,,,7493,,
7494,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ قَتَادَۃَ ، قَالَ : الْحَائِضُ تَأْخُذُ مِنَ الْمَسْجِدِ ، وَلاَ تَضَعُ فِیہِ۔",,,7494,,
7495,"حَدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنْ عُثْمَانَ بْنِ حَکِیمٍ ، عَنْ جَدَّتِہِ الرَّبَابِ ، أَنَّ عُثْمَانَ بْنَ حُنَیْفٍ ، قَالَ : یَا جَارِیَۃُ نَاوِلِینِی الْخُمْرَۃَ ، قَالَتْ : لَسْتُ أُصَلِّی ، قَالَ : إنَّ حَیْضَتَکِ لَیْسَتْ فِی یَدِکِ۔",,,7495,,
7496,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ یَقُولُ لِجَارِیَتِہِ : نَاوِلِینِی الْخُمْرَۃَ مِنَ الْمَسْجِدِ ، فَتَقُولُ : إنِّی حَائِضٌ ، فَیَقُولُ : إنَّ حَیْضَتَکِ لَیْسَتْ بِیَدِکِ۔",,,7496,,
7497,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : تَأْخُذُ الْحَائِضُ مِنَ الْمَسْجِدِ وَتَضَعُ فِیہِ۔",,,7497,,
7498,"حَدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ : فِی الْحَائِضِ تُنَاوِلُ مِنَ الْمَسْجِدِ الشَّیْئَ ، قَالَ : نَعَمْ إِلاَّ الْمُصْحَفَ۔",,,7498,,
7499,حَدَّثَنَا ابْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ تَأْخُذَ الْحَائِضُ الشَّیْئَ مِنَ الْمَسْجِدِ وَتَضَعَہُ فِیہِ۔,,,7499,,
7500,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، قَالَ : کَانَ أَبُو وَائِلٍ یُرْسِلُ خَادِمہُ وَہِیَ حَائِضٌ إلَی أَبِی رَزِینٍ فَتَأْتِیہِ بِالْمُصْحَفِ مِنْ عِنْدِہِ فَتُمْسِکُ بِعِلاَقَتِہِ۔",,,7500,,
7501,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ، قَالَ: لاَ بَأْسَ أَنْ یَتَنَاوَلَ الرَّجُلُ الْمُصْحَفَ إذَا کَانَ فِی وِعَائِہِ، أَوْ بِعِلاَقَتِہِ۔",,,7501,,
7502,"حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ أَبِی خَالِدٍ الدَّالانِیِّ ، عَنِ الْقَاسِمِ ، یَعْنِی الأَعْرَجَ ، قَالَ : رَأَیْتُُ سَعِیدَ بْنَ جُبَیْرٍ قَرَأَ فِی الْمُصْحَفِ ، ثُمَّ نَاوَلَ غُلاَمًا لَہُ مَجُوسِیًّا بِعِلاَقَتِہِ۔",,,7502,,
7503,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَیْمَنَ بْنِ نَابِلٍ ، قَالَ : سَمِعْتُ عَطَائً یَقُولُ : لاَ بَأْسَ أَنْ تَأْخُذَ الْحَائِضُ بِعِلاَقَۃِ الْمُصْحَفِ۔",,,7503,,
7504,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنْ مُحَمَّدٍ ، أَنَّہُ لَمْ یَکُنْ یَرَی بَأْسًا أَنْ یُحَوِّل الرَّجُلُ الْمُصْحَفَ وَہُوَ غَیْرُ طَاہِرٍ۔,,,7504,,
7505,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ صَالِحٍ ، عَنْ غَالِبٍ أَبِی الْہُذَیْلِ ، قَالَ : أَمَرَنِی أَبُو رَزِینٍ أَنْ أَفْتَحَ الْمُصْحَفَ عَلَی غَیْرِ وُضُوئٍ فَسَأَلْت إبْرَاہِیمَ فَکَرِہَہُ۔",,,7505,,
7506,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا عُبَیْدُ اللہِ بْنُ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ لاَ یَمَسُّ الْمُصْحَفَ إِلاَّ وَہُوَ طَاہِرٌ۔",,,7506,,
7507,حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، أَنَّہُ کَانَ لاَ یَرَی بِہِ بَأْسًا۔,,,7507,,
7508,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، قَالَ : سَأَلْتُ عَامِرًا عَنْ مَسِّ الْمُصْحَفِ عَلَی غَیْرِ وُضُوئٍ ، فَقَالَ : لاَ بَأْسَ بِہِ۔\n\nوَکَرِہَہُ مُحَمَّدُ بْنُ عَلِیٍّ ، وَعَبْدُ الرَّحْمَن بْنُ الأَسْوَدِ وَالْقَاسِمُ وَسَالِمٌ وَطَاوُوس۔",,,7508,,
7509,"أَخْبَرَنَا أَبُو أُسَامَۃَ ، قَالَ : حدَّثَنَا عُبَیْدُ اللہِ بْنُ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ عُمَرُ: مَا بَیْنَ الْمَشْرِقِ وَالْمَغْرِبِ قِبْلَۃٌ۔",,,7509,,
7510,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، قَالَ : قَالَ عُمَرُ : مَا بَیْنَ الْمَشْرِقِ وَالْمَغْرِبِ قِبْلَۃٌ مَا اسْتُقْبِلَتِ الْقِبْلَۃُ۔",,,7510,,
7511,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مَالِکُ بْنُ مِغْوَلٍ ، عَنْ عَبْدِ اللہِ بْنِ بُرَیْدَۃَ ، عَنِ ابْنِ عُمَرَ ، قَالَ : مَا بَیْنَ الْمَشْرِقِ وَالْمَغْرِبِ قِبْلَۃٌ۔",,,7511,,
7512,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الْمَسْعُودِیُّ ، عَنِ الْقَاسِمِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنِ ابْنِ عُمَرَ ، قَالَ : إذَا جَعَلْت الْمَغْرِبَ عَنْ یَمِینِکَ وَالْمَشْرِقَ عَنْ یَسَارِکَ فَمَا بَیْنَہُمَا قِبْلَۃٌ لأَہْلِ الشَّمَالِ۔",,,7512,,
7513,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا إسْرَائِیلُ ، عَنْ عَبْدِ الأَعْلَی بن عَامِرٍ الثَّعْلَبِی ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ السُّلَمِیِّ، عَنْ عَلِیٍّ ، قَالَ : مَا بَیْنَ الْمَشْرِقِ وَالْمَغْرِبِ قِبْلَۃٌ۔",,,7513,,
7514,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إسْرَائِیلُ ، عَنْ عَبْدِ الأَعْلَی ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : مَا بَیْنَ الْمَشْرِقِ وَالْمَغْرِبِ قِبْلَۃٌ۔",,,7514,,
7515,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیانُ ، عَنْ حَکِیمِ بْنِ جُبَیْرٍ ، عَنْ إِبْرَاہِیم۔ وسُفْیان ، عَنْ عَبْدِ الأَعْلَی ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ قَالا : مَا بَیْنَ الْمَشْرِقِ وَالْمَغْرِبِ قِبْلَۃٌ۔",,,7515,,
7516,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیان ، عَنْ خَالِدٍ الْحَذَّائِ ، عَنْ رَجُلٍ قَدْ سَمَّاہُ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : مَا بَیْنَ الْمَشْرِقِ وَالْمَغْرِبِ قِبْلَۃٌ۔",,,7516,,
7517,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الْعُمَرِیُّ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، عَنْ عُمَرَ ، قَالَ : مَا بَیْنَ الْمَشْرِقِ وَالْمَغْرِبِ قِبْلَۃٌ۔",,,7517,,
7518,"حَدَّثَنَا الْمُعَلَّی بْنُ مَنْصُورٍ ، قَالَ : حدَّثَنَا عَبْدُ اللہ بْنُ جَعْفَرٍ ، عَنْ عُثْمَانَ بْنِ مُحَمَّدٍ الأَخْنَسِیِّ ، عَنِ الْمَقْبُرِیِّ، عَنْ أَبِی ہُرَیْرَۃَ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، قَالَ: مَا بَیْنَ الْمَشْرِقِ وَالْمَغْرِبِ قِبْلَۃٌ۔ (حاکم 205)",,,7518,,
7519,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنِ الْعَبَّاسِ بنْ عَبْدِ الرَّحْمَنِ الْہَاشِمِیِّ ، قَالَ: أَوَّلُ مَا خُلِّقَتِ الْمَسَاجِدُ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَأَی فِی الْمَسْجِدِ نُخَامَۃً فَحَکَّہَا ، ثُمَّ أَمَرَ بِخَلُوقٍ فَلُطِخَ مَکَانَہَا۔ قَالَ: فَخَلَّقَ النَّاسُ الْمَسَاجِدَ۔ (ابوداؤد 482)",,,7519,,
7520,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ الْمُجَالِدِ ، عَنِ الشَّعْبِیِّ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَأَی فِی قِبْلَۃِ الْمَسْجِدِ نُخَامَۃً فَقَامَ إلَیْہَا فَحَکَّہَا بِیَدِہِ ، ثُمَّ دَعَا بِخَلُوقٍ ، فَقَالَ : عَامِرٌ ہُوَ سُنَّۃٌ۔",,,7520,,
7521,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، أَنَّ ابْنَ زُبَیْرٍ لَمَّا بَنَی الْکَعْبَۃَ طَلَی حِیطَانہَا بِالْمِسْکِ۔,,,7521,,
7522,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ہِشَامُ بْنُ عُرْوَۃَ ، عَنْ أَبِیہِ ، قَالَ أَمَرَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِبِنَائِ الْمَسَاجِدِ فِی الدُّورِ وَأَمَرَ أَنْ تُطَہَّرَ وَتُطَیَّبَ ، یَعْنِی الْقَبَائِلَ۔ (ابوداؤد 456۔ ابن ماجہ 759)",,,7522,,
7523,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الْعُمَرِیُّ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّ عُمَرَ بْنَ الْخَطَّابِ کَانَ یُجَمِّرُ الْمَسْجِدَ فِی کُلِّ جُمُعَۃٍ۔",,,7523,,
7524,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ سُلَیْمَانَ ، قَالَ : رَأَیْتُ إبْرَاہِیمَ یَرَی الْمَسْجِدَ یُخَلَّقُ فَلاَ یَعِیبُ ذَلِکَ۔",,,7524,,
7525,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ہِشَامٌ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَکَّ بُزَاقًا فِی قِبْلَۃِ الْمَسْجِدِ۔ (بخاری 407۔ مسلم 549)",,,7525,,
7526,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عَلِیُّ بْنُ المُبَارَکِ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، قَالَ نُبِّئْتُ ، أَنَّ أَبَا الدَّرْدَائِ رَأَی بُزَاقًا فِی عَرْضِ جِدَارِ الْمَسْجِدِ فَحَکَّہُ۔",,,7526,,
7527,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنَ ، عَنْ عِیَاضِ بْنِ عَبْدِ اللہِ بْنِ سَعْدِ بْنِ أَبِی سَرْحٍ ، عَنْ أَبِی سَعِیدٍ ، قَالَ : دَخَلَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْمَسْجِدَ وَبِیَدِہِ عُرْجُونٌ وَکَانَ یُحِبُّ الْعَرَاجِینَ فَرَأَی نُخَامَۃً فِی الْقِبْلَۃِ فَحَکَّہَا ، ثُمَّ أَقْبَلَ عَلَی النَّاسِ ، فَقَالَ : أَیُّہَا النَّاسُ إنَّ أَحَدَکُمْ إذَا قَامَ یُصَلِّی اسْتَقْبَلَہُ اللَّہُ ، وَعَنْ یَمِینِہِ مَلَکٌ أَفَیُحِبُّ أَحَدُکُمْ أَنْ یَسْتَقْبِلَہُ الرَّجُلُ فَیَبْزُقَ فِی وَجْہِہِ فَلاَ یَبْزُقْ أَحَدُکُمْ فِی الْقِبْلَۃِ ، وَلاَ عَنْ یَمِینِہِ وَلْیَبْزُقْ تَحْتَ رِجْلِہِ الْیُسْرَی ، أَوْ عَنْ یَسَارِہِ ، فَإِنْ عَجِلَتْ بِہِ بَادِرَۃٌ فَلیَقُل ہَکَذَا ، یَعْنِی فِی ثَوْبِہِ۔ (ابوداؤد 481۔ احمد 3/24)",,,7527,,
7528,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ الْقَاسِمِ بْنِ مِہْرَانَ ، عَنْ أَبِی رَافِعٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَأَی نُخَامَۃً فِی قِبْلَۃِ الْمَسْجِدِ فَأَقْبَلَ عَلَی النَّاسِ بِوَجْہِہِ ، فَقَالَ : مَا بَالُ أَحَدِکُمْ یَقُومُ مُسْتَقْبِلَہ رَبُّہُ فَیَتَنَخَّعُ أَمَامَہُ أَیحب أَحَدُکُم أَن یُستقبل فَیُتَنَخَّعَ فِی وَجْہِہِ ؟ إذَا انتَخَعَ أَحَدُکُمْ فَلْیَتَنَخَّعْ ، عَنْ یَسَارِہِ ، أَوْ تَحْتَ قَدَمہِ ، فَإِنْ لَمْ یَجِدْ فَلْیَقُلْ ہَکَذَا فِی ثَوْبِہِ ، ثُمَّ أَرَانَا إسْمَاعِیلُ أَنَّہُ یَبْزُقُ فِی ثَوْبِہِ ، ثُمَّ یَدْلُکُہُ۔ (مسلم 389۔ نسائی 298)",,,7528,,
7529,"حَدَّثَنَا حَفْصٌ ، عَنْ حُمَیْدٍ ، عَنْ أَنَسٍ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَبْصَرَ نُخَامَۃً فِی الْمَسْجِدِ فَمَسَحَہَا ، ثُمَّ قَالَ : إذَا بَزَقَ أَحَدُکُمْ فَلاَ یَبْزُقْ فِی الْقِبْلَۃِ ، وَلاَ عَنْ یَمِینِہِ وَلَکِنْ لِیَبْزُقْ ، عَنْ یَسَارِہِ ، أَوْ تَحْتَ قَدَمِہِ، أَوْ لِیَصْنَعْ، أَوْ لِیَقُلْ ہَکَذَا، ثُمَّ بَزَقَ فِی طَرَفِ ثَوْبِہِ ، ثُمَّ رَدَّہُ عَلَیْہِ۔ (بخاری 417۔ دارمی 1396)",,,7529,,
7530,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ حُمَیْدِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِی سَعِیدٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَأَی نُخَامَۃً فِی قِبْلَۃِ الْمَسْجِدِ فَحَکَّہَا بِحَصَاہُ ، وَقَالَ : إذَا بَزَقَ أَحَدُکُمْ فَلاَ یَبْزُقْ بَیْنَ یَدَیْہِ ، وَلاَ عَنْ یَمِینِہِ وَلْیَبْزُقْ ، عَنْ یَسَارِہِ۔ (بخاری 414۔ مسلم 52)",,,7530,,
7531,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مَنْصُورٍ ، عَنْ رِبْعِیٍّ ، عَنْ طَارِقِ بْنِ عَبْدِ اللہِ الْمُحَارِبِیِّ ، قَالَ : قَالَ لِی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا صَلَّیْتَ فَلاَ تَبْزُقْ بَیْنَ یَدَیْکَ ، وَلاَ عَنْ یَمِینِکَ وَلَکِنَ اُبْزُقْ ، عَنْ یَسَارِکَ ، أَوْ تَحْتَ قَدَمِکَ۔ (ترمذی 571۔ ابوداؤد 479)",,,7531,,
7532,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ أَبِی وَائِلٍ ، عَنْ حُذَیْفَۃَ ، قَالَ : إنَّ الْعَبْدَ الْمُسْلِمَ إذَا تَوَضَّأَ فَأَحْسَنَ الْوُضُوئَ ، ثُمَّ قَامَ یُصَلِّی أَقْبَلَ اللَّہُ عَلَیْہِ بِوَجْہِہِ حَتَّی یَکُونَ ہُوَ الَّذِی یَنْصَرِفُ ، أَوْ یُحْدِث حَدَثَ سوْئٍ فَلاَ یَبْزُقْ بَیْنَ یَدَیْہِ ، وَلاَ عَنْ یَمِینِہِ فَإِنَّ عَنْ یَمِینِہِ کَاتِبَ الْحَسَنَاتِ وَلَکِنْ یَبْزُقُ ، عَنْ شِمَالہِ ، أَوْ خَلْفَ ظَہْرِہِ۔",,,7532,,
7533,حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ عَاصِمٍ ، عَنْ أَبِی وَائِلٍ ، عَنْ حُذَیْفَۃَ رَفَعَہُ بِنَحْوِہِ۔ (ابن ماجہ 1023),,,7533,,
7534,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ عَدِیِّ بْنِ ثَابِتٍ ، عَنْ زِرٍّ ، عَنْ حُذَیْفَۃَ ، قَالَ : مَنْ صَلَّی فَبَزَقَ تُجَاہَ الْقِبْلَۃِ جَائَتْ بَزْقَتُہُ یَوْمَ الْقِیَامَۃِ فِی وَجْہِہِ۔ (بزار 411)",,,7534,,
7535,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ ابْنِ سُوقَۃَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : إذَا بَزَقَ فِی الْقِبْلَۃِ جَائَتْ أَحْمَی مَا تَکُونُ یَوْمَ الْقِیَامَۃِ حَتَّی تَقَعَ بَیْنَ عَیْنَیْہِ۔ (طبرانی 7960)",,,7535,,
7536,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ یُکْرَہُ أَنْ یَبْزُقَ الرَّجُلُ بَیْنَ یَدَیْہِ فِی الصَّلاَۃ ، أَوْ عَنْ یَمِینِہِ ، وَقَالَ : اُبْزُقْ ، عَنْ شِمَالِکَ ، أَوْ تَحْتَ قَدَمِکَ۔",,,7536,,
7537,"حَدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَانَ مُحَمَّدٌ یَکْرَہُ أَنْ یَبْزُقَ الرَّجُلُ تُجَاہَ الْقِبْلَۃِ ، وَعَنْ یَمِینِہِ۔",,,7537,,
7538,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، أَنَّہُ کَرِہَ أَنْ یَبْزُقَ تُجَاہَ الْقِبْلَۃِ ، قَالَ : وَکَانَ ابْنُ سِیرِینَ یَکْرَہُ الْقِبْلَتَیْنِ جَمِیعًا۔",,,7538,,
7539,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا عُبَید اللہِ بْنُ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أَنَّہُ رَأَی نُخَامَۃً فِی قِبْلَۃِ الْمَسْجِدِ فَحَتَّہَا ، ثُمَّ قَالَ : إذَا قَامَ أَحَدُکُمْ فِی صَلاَۃٍ فَلاَ یَتَنَخَّمْ قِبَلَ وَجْہِہِ فَإِنَّ اللَّہَ قِبَلَ وَجْہِ أَحَدِکُمْ إذَا کَانَ فِی الصَّلاَۃ۔ (بخاری 406۔ مسلم 50)",,,7539,,
7540,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِنَحْوٍمِنْہُ۔ (بخاری 1213۔ مسلم 388),,,7540,,
7541,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ہِشَامٌ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : التَفْلُ فِی الْمَسْجِدِ خَطِیئَۃٌ وَکَفَّارَتُہُ أَنْ تُوَارِیَہُ۔ (بخاری 1214۔ مسلم 55)",,,7541,,
7542,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ حُسَیْنِ بْنِ وَاقِدٍ ، عَنْ أَبِی غَالِبٍ ، عَنْ أَبِی أُمَامَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْبُزَاقُ فِی الْمَسْجِدِ خَطِیئَۃٌ وَدَفْنُہُ حَسَنَۃٌ۔ (احمد 5/260۔ طبرانی 8091)",,,7542,,
7543,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ عُبَیْدِ اللہِ ، أَنَّ أَبَا عُبَیْدَۃَ أَتَی مَنْزِلَہُ وَقَدْ بَزَقَ فِی الْمَسْجِدِ وَسَہَا أَنْ یَدْفِنَہَا حَتَّی أَتَی مَنْزِلَہُ فَذَکَر فَجَائَ بِمِصْبَاحٍ حَتَّی وَارَاہَا۔,,,7543,,
7544,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، عَنْ مَکْحُولٍ ، أَنَّ ابْنَ عُمَرَ تَنَخَّعَ ، أَوْ بَسَقَ فِی الْمَسْجِدِ فَنَسِیَ أَنْ یُوَارِیَہَا حَتَّی أَتَی مَنْزِلَہُ فَذَکَرَ بَعْدَ انْصِرَافِہِ فَرَجَعَ بِسِرَاجٍ فَالْتَمَسَہَا فِی الْمَسْجِدِ حَتَّی وَارَاہَا ، ثُمَّ قَالَ : مَنْ بَزَقَ فِی الْمَسْجِدِ فَہِیَ خَطِیئَۃٌ وَتَوْبَتُہُ أَنْ یُوَارِیَہَا۔",,,7544,,
7545,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، وَعَبْدَۃُ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ أَبِی الأَزْہَرِ ، عَنْ مُجَاہِدٍ ، قَالَ : الْبُزَاقُ فِی الْمَسْجِدِ خَطِیئَۃٌ وَکَفَّارَتُہُ أَنْ یُوَارِیَہُ۔",,,7545,,
7546,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، قَالَ : الْبُزَاقُ فِی الْمَسْجِدِ خَطِیئَۃٌ ، قَالَ : فَذَکَرْتُ ذَلِکَ لِلنَّخَعِیِّ ، فَقَالَ : کَانَ یُقَالُ ، کَفَّارَتُہُ دَفْنُہُ۔",,,7546,,
7547,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ، عَنِ الْعَوَّامِ، عَنِ ابْنِ أَبِی الْہُذَیْلِ، قَالَ: الْبُزَاقُ فِی الْمَسْجِدِ خَطِیئَۃٌ وَکَفَّارَتہا دَفْنُہَا۔",,,7547,,
7548,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سَیْفُ بْنُ سُلَیْمَانَ الْمَکِّیُّ ، قَالَ : سَمِعْتُ مُجَاہِدًا یَقُولُ بَزَقَ أَبُو عُبَیْدَۃَ بْنُ الْجَرَّاحِ فِی الْمَسْجِدِ لَیْلاً فَلَمْ یَدْرِ أَیْنَ مَوْضِعُہُ فَخَرَجَ فَجَائَ بِالْمِصْبَاحِ فَطَلَبَہُ حَتَّی وَارَاہُ۔",,,7548,,
7549,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مِسْعَرٌ ، عَنْ یَزِیدَ بْنِ مِلْقط ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : إنَّ الْمَسْجِدَ لَیَنْزَوِی مِنَ الْمُخَاطِ ، أَوِ النُّخَامَۃِ کَمَا تَنْزَوِی الْجِلْدَۃُ فِی النَّارِ۔",,,7549,,
7550,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ أَبِی الْوَسْمِیِّ ، عَنْ رَجُلٍ ، یُقَالَ لَہُ زِیَادٌ رَجُلٌ مِنْ بَنِی فَزَارَۃَ ، أَنَّہُ سَمِعَ أَبَا ہُرَیْرَۃَ یَقُولُ : إنَّ الْمَسْجِدَ لَیَنْزَوِی مِنَ النُّخَامَۃِ کَمَا تَنْزَوِی الْبَضْعۃُ ، أَوِ الْجِلْدَۃُ مِنَ النَّارِ۔",,,7550,,
7551,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا أَبِی ، عَنْ لَیْثٍ ، قَالَ : مَا رَأَیْت طَاوُوسًا بَزَقَ فِی الْمَسْجِدِ قَطُّ ، وَلاَ مَسَّ الْحَصَی ، وَلاَ اتَّکَأَ فِیہِ۔",,,7551,,
7552,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنِ الرُّکَیْنِ ، عَنْ أَبِیہِ ، عَنْ أَسْمَائَ بْنِ الْحَکَمِ ، قَالَ : سَأَلْتُ عَنْ کُلِّ شَیْئٍ حَتَّی النَّفْثۃِ فِی الْمَسْجِدِ فَقِیلَ کَفَّارَتُہَا دَفْنُہَا۔",,,7552,,
7553,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ إِسْحَاقَ ، عَنْ عَبْدِ اللہِ بْنِ مُحَمَّدٍ ، عَنْ عَامِرِ بْنِ سَعْدِ بْنِ أَبِی وَقَّاصٍ ، عَنْ أَبِیہِ سَعْدٍ ، قَالَ : سَمِعْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : إذَا تَنَخَّمَ أَحَدُکُمْ فِی الْمَسْجِدِ فَلْیُغَیِّبْہَا ، ولاَ تُصِبْ جِلْدَ مُؤْمِنٍ ، أَوْ ثَوْبَہُ فَتُؤْذِیَہُ۔ (احمد 1/179۔ ابن خزیمۃ 1311)",,,7553,,
7554,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا أَبُو مَوْدُودٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی حَدْرَدٍ الأَسْلَمِیِّ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا بَزَقَ أَحَدُکُمْ فِی مَسْجِدِی ، أَوَ قَالَ فِی الْمَسْجِدِ فَلْیَحْفِرْ فَلْیُمْعِنْ ، أَوْ لِیَبْزُقْ فِی ثَوْبٍ حَتَّی یَخْرُجَہُ۔ (ابوداؤد 478۔ اح",,,7554,,
7555,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنِ الأَوْزَاعِیِّ ، عَنْ حَسَّانَ بْنِ عَطِیَّۃَ ، قَالَ : کَانَ مُعَاذُ بْنُ جَبَلٍ یَأْخُذُ الْبُرْغُوثَ فِی الصَّلاَۃ فَیَفْرُکُہُ بِیَدِہِ حَتَّی یَقْتُلَہُ ، ثُمَّ یَبْزُقُ عَلَیْہِ۔",,,7555,,
7556,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ أَبِی بَکْرِ بْنِ أَبِی مَرْیَمَ ، عْن عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، قَالَ : کَانَ عُمَرُ بْنُ الْخَطَّابِ یَقْتُلُ الْقَمْلَۃَ فِی الصَّلاَۃ حَتَّی یَظْہَرَ دَمُہَا عَلَی یَدِہِ۔",,,7556,,
7557,"حَدَّثَنَا عَبْدَۃُ ، عَنْ عَبْدِ الرَّحْمَانِ بْنِ زِیَادِ بْنِ أَنْعُمٍ ، عْن مُسْلِمِ بْنِ یَسَارٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ فِی الرَّجُلِ یَأْخُذُ الْقَمْلَۃَ فِی صَلاَتِہِ ، قَالَ : یَحْدُرُہَا وَیَطْرَحُہَا۔",,,7557,,
7558,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ؛ فِی الرَّجُلِ یَجِدُ الْقَمْلَۃَ فِی الصَّلاَۃ ، قَالَ : یَدْفِنُہَا۔",,,7558,,
7559,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إِنْ قَتَلَہَا فِی الصَّلاَۃ فَلاَ شَیْئَ۔",,,7559,,
7560,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ثَوْرٌ الشَّامِیُّ ، عَنْ رَاشِدِ بْنِ سَعْدٍ ، عَنْ مَالِکِ بْنِ یُخَامِرَ ، قَالَ ثَوْرٌ مَرَّۃً رَاشِدُ بْنُ سَعْدٍ ، أَوْ غَیْرُہُ ، قَالَ : رَأَیْتُ مُعَاذَ بْنَ جَبَلٍ یَقْتُلُ الْقَمْلَ وَالْبَرَاغِیثَ فِی الصَّلاَۃ۔",,,7560,,
7561,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی حَمْزَۃَ ، قَالَ : قُلْتُ لإِبْرَاہِیمَ : آخُذُ الْقَمْلَۃَ وَأَنَا فِی الصَّلاَۃ ؟ قَالَ : ادْفِنْہَا فِی الْحَصَی إنَّمَا جُعِلَتِ الأَرْضُ کِفَاتًا أَحْیَائً وَأَمْوَاتًا۔",,,7561,,
7562,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ، عَنْ جُوَیْبِرٍ، عَنِ الضَّحَّاکِ؛ فِی الرَّجُلِ یَقْتُلُ الْقَمْلَۃَ فِی الصَّلاَۃ، قَالَ: لاَ بَأْسَ بہ۔",,,7562,,
7563,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إسْرَائِیلُ ، عَنْ ثُوَیر، عَنْ مُجَاہِدٍ ؛ فِی الرَّجُلِ یَجِدُ الْقَمْلَۃَ فِی الصَّلاَۃ ، قَالَ: لاَ بَأْسَ أَنْ یُحَوِّلَہَا۔",,,7563,,
7564,"حَدَّثَنَا وَکِیعٌ قَالَ: حَدَّثَنَا إسْرَائِیلُ، عَنْ جَابِرٍ، عَنْ عَامِرٍ؛ فِی الرَّجُلِ یَجِدُ الْقَمْلَۃَ فِی الصَّلاَۃ، قَالَ: یَدَعُہَا۔",,,7564,,
7565,حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنْ مُعَاوِیَۃَ بْنِ صَالِحٍ ، عَنْ صَدَقَۃَ أَبِی تَوْبَۃَ ، عَنْ أَنَسٍ ، أَنَّہُ کَانَ یَقْتُلُ الْقَمْلَ فِی الصَّلاَۃ۔,,,7565,,
7566,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عَلِیُّ بْنُ مُبَارَکٍ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنِ الْحَضْرَمِیِّ بْنِ لاَحِقٍ ، عَنْ رَجُلٍ مِنَ الأَنْصَارِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا وَجَدَ أَحَدُکُمُ الْقَمْلَۃَ فِی الْمَسْجِدِ فَلْیَصُرَّہَا فِی ثَوْبِہِ حَتَّی یُخْرِجَہَا۔ (احمد 410۔ بیہقی 294)",,,7566,,
7567,"حَدَّثَنَا جَرِیرٌ ، عَنْ قَابُوسَ ، عَنْ أَبِیہِ ، عَنِ ابْنِ عَبَّاسٍ ؛ فِی الرَّجُلِ یَجِدُ الْقَمْلَۃَ وہو فِی الْمَسْجِدِ ، قَالَ: یَدْفِنُہَا فِی الْحَصْبَائِ ، قَالَ وَرَأَیْت أَبَا ظَبْیَانَ یَفْعَلُ ذَلِکَ۔",,,7567,,
7568,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ مُسْلِمٍ الْمُلاَئِیِّ ، عَنْ زَاذَانَ ، عَنِ الرَّبِیعِ بْنِ خُثَیم ، أَنَّ عَبْدَ اللہِ دَفَنَ قَمْلَۃً فِی الْمَسْجِدِ ، ثُمَّ قَرَأَ : {أَلَمْ نَجْعَل الأَرْضَ کِفَاتًا}۔",,,7568,,
7569,"حَدَّثَنَا عَبَّادُ بْنُ عَوَّامٍ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الْمُسَیَّبِ بْنِ رَافِعٍ ، عَنْ رَجُلٍ ، قَالَ : رَأَیْتُ أَبَا أُمَامَۃَ یَتَفَلَّی فِی الْمَسْجِدِ ویدفنہ فیہ۔",,,7569,,
7570,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا أبان بن عبد اللہ البجلی عن أبی مسلم الثعلبی قَالَ : رَأَیْتُ أَبَا أُمَامَۃَ یَتَفَلَّی فِی مَسْجِدِہِ وَہُوَ یَدْفِنُ الْقَمْلَ فِی الْحَصَی۔",,,7570,,
7571,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا أَبُو خَلْدَۃَ ، قَالَ : رَأَیْتُ أَبَا الْعَالِیَۃِ یَدْفِنُ الْقَمْلَ فِی الْمَسْجِدِ وَقَرَأَ : {أَلَمْ نَجْعَلِ الأَرْضَ کِفَاتًا}۔",,,7571,,
7572,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنِ ابْنِ الْمُسَیَّبِ ، قَالَ ادْفِنْہَا فِی الْمَسْجِدِ قَدْ یُدْفَنُ مَا ہُوَ شَرٌّ مِنْہَا : النُّخَامَۃُ۔",,,7572,,
7573,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا سُفْیَانُ ، عَنِ الْحَسَنِ بْنِ عَلِیٍّ ، قَالَ : رَأَیْتُُ ابْنَ مَعْقِل یَتَفَلَّی فِی الْمَسْجِدِ وَکَانَتْ جَدَّتِی أُمَّ وَلَدٍ لِلْحَسَنِ بْنِ عَلِیٍّ ، فَکَانَ یَعْزِلُ عَنْہَا۔",,,7573,,
7574,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ لَیْثٍ ، عَنِ الْحَسَنِ بْنِ مُسْلِمٍ ، عَنْ عُبَیْدِ بْنِ عُمَیْرٍ ، قَالَ : أَخَذْتُ عَنِ ابْنِ عُمَرَ دَابَّۃً وَہُوَ یُصَلِّی فِی الْمَسْجِدِ فَأَلْقَیْتُہَا فِی نَاحِیَۃِ الْمَسْجِدِ فَلَمْ یَعِبْ ذَلِکَ عَلَیَّ۔",,,7574,,
7575,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا أَخَذْت الْقَمْلَۃَ وَأَنْتَ فِی الْمَسْجِدِ فَادْفِنْہَا فِی الْحَصْبَائِ۔",,,7575,,
7576,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ یُوسُفَ بْنِ مَاہَکَ ، قَالَ : رَأَیْتُ ابْنَ عُمَیْرٍ أَخَذَ مِنْ ثَوْبِ ابْنِ عُمَرَ قَمْلَۃً فَدَفَنَہَا فِی الْمَسْجِدِ۔",,,7576,,
7577,"حَدَّثَنَا قَطَنُ بْنُ عَبْدِ اللہِ ، عَنْ أَبِی غَالِبٍ ، قَالَ : رَأَیْتُُ أَبَا أُمَامَۃَ یَأْخُذُ الْقَمْلَ وَیُلْقِیہِ فِی الْمَسْجِدِ فَقُلْت یَا أَبَا أُمَامَۃَ تَأْخُذُ الْقَمْلَ وَتُلْقِیہِ فِی الْمَسْجِدِ ، قَالَ : {أَلَمْ نَجْعَلِ الأَرْضَ کِفَاتًا * أَحْیائً وَأمْواتًا}۔",,,7577,,
7578,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ یَحْیَی بْنِ ہَانِئِ بْنِ عُرْوَۃَ الْمُرَادِیِّ ، عَنْ عَبْدِ الْحَمِیدِ بْنِ مَحْمُودٍ ، قَالَ: صَلَّیْنَا خَلْفَ أَمِیرٍ مِنَ الأُمَرَائِ فَاضْطَرَّنَا النَّاسُ حَتَّی صَلَّیْنَا بَیْنَ السَّارِیَتَیْنِ، فَلَمَّا صَلَّیْنَا، قَالَ أَنَسُ بْنُ مَالِکٍ: کُنَّا نَتَّقِی ہَذَا عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔ (ابوداؤد 673۔ احمد 3/131)",,,7578,,
7579,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا خَالِدٌ عَمَّنْ حَدَّثَہُ ، عَنْ أَنَسٍ ، قَالَ نُہِینَا أَنْ نُصَلِّیَ بَیْنَ الأَسَاطِینِ۔",,,7579,,
7580,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ مَعْدِی کَرِبَ ، عَنِ ابْنِ مَسْعُود ، قَالَ : لاَ تَصُفُّوا بَیْنَ الأَسَاطِینِ ، وَلاَ تَأْتَمُّوا بِقَوْمٍ یَمْتَرُونَ وَیَلْغُونَ۔ (عبدالرزاق 2487۔ طبرانی 9295)",,,7580,,
7581,حَدَّثَنَا فُضَیْلُ بْنُ عِیَاضٍ ، عَنْ حُصَیْنِ بْنِ ہِلاَلٍ ، عَنْ حُذَیْفَۃَ ، أَنَّہُ کَرِہَ الصَّلاَۃ بَیْنَ الأَسَاطِینِ۔,,,7581,,
7582,"حَدَّثَنَا مُحَمَّدُ بْنُ یَزِیدَ ، عَنْ أَیُّوبَ أَبِی الْعَلاَئِ ، عَنْ مُعَاوِیَۃَ بْنِ قُرَّۃَ ، عَنْ أَبِیہِ ، قَالَ : رَآنِی عُمَرُ وَأَنَا أُصَلِّی بَیْنَ أُسْطُوَانَتَیْنِ فَأَخَذَ بِقَفَای فَأَدْنَانِی إلَی سُتْرَۃٍ ، فَقَالَ : صَلِّ إلَیْہَا۔",,,7582,,
7583,"حَدَّثَنَا شَرِیکٌ، عَنْ إبْرَاہِیمَ بْنِ مُہَاجِرٍ، عَنْ إبْرَاہِیمَ، أَنَّہُ کَرِہَ الصَّلاَۃ بَیْنَ الأَسَاطِینِ، وَقَالَ: أَتِمُّوا الصُّفُوفَ۔",,,7583,,
7584,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا حَسَنُ بْنُ صَالِحٍ، عَنْ إبْرَاہِیمَ بن مہاجر، عَنْ إبْرَاہِیمَ قَالَ: لاَ تُصَلُّوا بَیْنَ الأَسَاطِینِ۔",,,7584,,
7585,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، أَنَّہُ کَانَ لاَ یَرَی بَأْسًا فی الصَّفِّ بَیْنَ السَّوَارِی۔,,,7585,,
7586,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : لاَ أَعْلَمُ بِالصَّلاَۃ بَیْنَ السَّوَارِی بَأْسًا۔",,,7586,,
7587,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ وِقَائٍ ، قَالَ : کَانَ سَعِیدُ بْنُ جُبَیْرٍ یَؤُمُّنَا بَیْنَ سَارِیَتَیْنِ۔",,,7587,,
7588,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، قَالَ: رَأَیْتُ إبْرَاہِیمَ التَّیْمِیَّ یَؤُمُّ قَوْمَہُ بَیْنَ أُسْطُوَانَتَیْنِ۔",,,7588,,
7589,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا مُوسَی بْنُ نَافِعٍ ، قَالَ : رَأَیْتُ سعید بن جبیر یَؤُمُّنَا بَیْنَ السَارِیَتَیْنِ۔",,,7589,,
7590,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا سُفْیَانُ ، عَنْ بِشْرِ بْنِ طُعْمَۃَ الثَّوْرِیِّ ، قَالَ : رَأَیْتُ الرَّبِیعَ بْنَ خُثَیم صَلَّی فِی مَرَضِہِ بَیْنَ سَارِیَتَیْنِ یَعْتَمِدُ عَلَی إحْدَاہُمَا۔",,,7590,,
7591,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا سُفْیَانُ وَإِسْرَائِیلُ ، عَنْ إبْرَاہِیمَ بْنِ عَبْدِ الأَعْلَی ، قَالَ : کَانَ سُوَیْد بْنُ غَفَلَۃَ یَؤُمُّنَا بَیْنَ أُسْطُوَانَتَیْنِ۔",,,7591,,
7592,"حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، قَالَ : کَانَ یَحْیَی بْنُ وَثَّابٍ یَؤُمُّنَا بَیْنَ أُسْطُوَانَتَیْنِ۔",,,7592,,
7593,"حَدَّثَنَا وَکِیعٌ ، عَنْ رَبِیعَۃَ بْنِ عُثْمَانَ التَّیْمِیِّ ، قَالَ : حدَّثَنَا إدْرِیسُ الصَّنْعَانِیُّ ، عَنْ رَجُلٍ ، یُقَالُ لَہُ ہَمْدَانُ وَکَانَ بَرِیدَ أَہْلِ الْیَمَنِ إلَی عُمَرَ ، قَالَ : قَالَ عُمَرُ : الْمُصَلُّونَ أَحَقُّ بِالسَّوَارِی مِنَ الْمُتَحَدِّثِینَ إلَیْہَا۔",,,7593,,
7594,"حَدَّثَنَا ہُشَیْمُ بْنُ بَشِیر ، قَالَ : أَخْبَرَنَا حُصَینٌ ، عَنْ مُحَمَّدِ بْنِ طَلْحَۃَ بْنِ رُکَانَۃَ الْمُطَّلِبِیِّ ، عَنْ جُبَیْرِ بْنِ مُطْعِمٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ صَلاَۃً فِی مَسْجِدِی ہَذَا خَیْرٌ مِنْ أَلْفِ صَلاَۃٍ فِیمَا سِوَاہُ إِلاَّ الْمَسْجِدَ الْحَرَامَ۔ (طیالسی 950۔ احمد 4/80)",,,7594,,
7595,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حدَّثَنَا عَبْدُ اللہِ بْنُ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : صَلاَۃٌ فِی مَسْجِدِی ہَذَا أَفْضَلُ مِنْ أَلْفِ صَلاَۃٍ فِی غَیْرِہِ إِلاَّ الْمَسْجِدَ الْحَرَامَ۔ (مسلم 1013۔ احمد 6/53)",,,7595,,
7596,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ سَعْدِ بْنِ إبْرَاہِیمَ ، أَنَّہُ سَمِعَ أَبَا سَلَمَۃَ یُحَدِّثُ الأَغَرَّ ، أَنَّہُ سَمِعَ أَبَا ہُرَیْرَۃَ یُحَدِّثُ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : صَلاَۃٌ فِی مَسْجِدِی ہَذَا أَفْضَلُ مِنْ أَلْفِ صَلاَۃٍ فِیمَا سِوَاہُ مِنَ الْمَسَاجِدِ إِلاَّ الْکَعْبَۃَ۔ (بخاری 1190۔ ترمذی 325)",,,7596,,
7597,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی أَخْبَرَنَا مُوسَی بْنُ عُبَیْدَۃَ ، عَنْ دَاوُدَ بْنِ مُدْرِکٍ ، عَنْ عُرْوَۃَ ، عَنْ عَائِشَۃَ ، قالَتْ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : صَلاَۃٌ فِی مَسْجِدِی أَفْضَلُ مِنْ أَلْفِ صَلاَۃٍ فِیمَا سِوَاہُ مِنَ الْمَسَاجِدِ إِلاَّ الْمَسْجِدَ الْحَرَامَ۔ (بزار 1193)",,,7597,,
7598,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ حُمَیْدِ بْنِ صَخْرٍ ، عَنِ الْمَقْبُرِیِّ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : مَنْ جَائَ مَسْجِدِی ہَذَا لَمْ یَأْتِہِ إِلاَّ لِخَیْرٍ یُعَلِّمُہُ ، أَوْ یَتَعَلَّمُہُ فَہُوَ بِمَنْزِلَۃِ الْمُجَاہِدِ فِی سَبِیلِ اللہِ وَمَنْ جَائَہُ لِغَیْرِ ذَلِکَ فَہُوَ بِمَنْزِلَۃِ الرَّجُلِ یَنْظُرُ إلَی مَتَاعِ غَیْرِہِ۔ (احمد 2/418۔ ابن حبان 87)",,,7598,,
7599,"حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ ، عَنْ لَیْثِ بْنِ سَعْدٍ ، عَنْ نَافِع ، عَنْ إبْرَاہِیمَ بْنِ عَبْدِ اللہِ بْنِ مَعْبَدٍ ، عَنِ ابْنِ عَبَّاسٍ ، عَنْ مَیْمُونَۃَ قَالَت : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : صَلاَۃٌ فِیہِ ، یَعْنِی مَسْجِدَ الْمَدِینَۃِ، أَفْضَلُ مِنْ أَلْفِ صَلاَۃٍ فِیمَا سِوَاہُ إِلاَّ مَسْجِدَ مَکَّۃَ۔ (مسلم 510)",,,7599,,
7600,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ زِیَادِ بْنِ سَعْدٍ ، عَنْ سُلَیْمَانَ بْنِ عُثْمَانَ سَمِعَ ابن الزُّبَیْرَ یَقُولُ : سَمِعْتُ عُمَرَ یَقُولُ : صَلاَۃٌ فِی ہَذَا الْمَسْجِدِ أَفْضَلُ مِنْ مِئَۃ صَلاَۃٍ فِیمَا سِوَاہُ۔",,,7600,,
7601,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ أُنیَسِ بْنِ أَبِی یَحْیَی ، عَنْ أَبِیہِ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ، قَالَ : امْتَرَی رَجُلٌ مِنْ بَنِی خُدْرَۃَ وَرَجُلٌ مِنْ بَنِی عَمْرِو بْنِ عَوْفٍ فِی الْمَسْجِدِ الَّذِی أُسِّسَ عَلَی التَّقْوَی ، فَقَالَ الْخُدْرِیِّ : ہُوَ مَسْجِدُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَقَالَ الْعَوْفِی : ہُوَ مَسْجِدُ قُبَائٍ فَأَتَیَا رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی ذَلِکَ ، فَقَالَ : ہُوَ ہَذَا ہُوَ ہَذَا ، یَعْنِی مَسْجِدَہُ وَفِی ذَلِکَ خَیْرٌ کَثِیرٌ۔ (ترمذی 323۔ احمد 3/23)",,,7601,,
7602,"حَدَّثَنَا وَکِیعٌ ، عَنْ أُسَامَۃَ بْنِ زَیْدٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی سَعِیدٍ الْخُدْرِیِّ ، عَنْ أَبِیہِ ، قَالَ : الْمَسْجِدُ الَّذِی أُسِّسَ عَلَی التَّقْوَی ہُوَ مَسْجِدُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,7602,,
7603,"حَدَّثَنَا وَکِیعٌ ، عَنْ رَبِیعَۃَ بْنِ عُثْمَانَ ، قَالَ : حدَّثَنِی عِمْرَانُ بْنُ أَبِی أَنَسٍ ، عَنْ سَہْلِ بْنِ سَعْدٍ ، قَالَ : اخْتَلَفَ رَجُلاَنِ فِی الْمَسْجِدِ الَّذِی أُسِّسَ عَلَی التَّقْوَی ، فَقَالَ : أَحَدُہُمَا ہُوَ مَسْجِدُ الْمَدِینَۃِ ، وَقَالَ الأَخَرُ ہُوَ مَسْجِدُ قُبَائٍ فَأَتَیَا رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : ہُوَ مَسْجِدِی ہَذَا۔ (احمد 5/331۔ ابن حبان 1605)",,,7603,,
7604,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا رَبِیعَۃُ بْنُ عُثْمَانَ ، عَنْ عُثْمَانَ بْنِ عَبْدِ اللہِ ، عَنِ ابْنِ عُمَرَ ، قَالَ : الْمَسْجِدُ الَّذِی أُسِّسَ عَلَی التَّقْوَی ہُوَ مَسْجِدُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,7604,,
7605,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ أَبِی الزِّنَادِ ، عَنْ خَارِجَۃَ بْنِ زَیْدٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : الْمَسْجِدُ الَّذِی أُسِّسَ عَلَی التَّقْوَی مِنْ أَوَّلِ یَوْمٍ مَسْجِدُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔ (طبرانی 4854)",,,7605,,
7606,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی ہِلاَلٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : مَسْجِدُ الْمَدِینَۃِ الأَعْظَمُ۔",,,7606,,
7607,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ حُمَیْدِ بْنِ صَخْرٍ ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی سَعِیدٍ ، قَالَ : دَخَلْت عَلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَسَأَلْتُہُ ، عَنِ الْمَسْجِدِ الَّذِی أُسِّسَ عَلَی التَّقْوَی فَقَبَضَ قَبْضَۃً مِنَ الْحَصَی ، ثُمَّ ضَرَبَ بِہَا الأَرْضَ ، فَقَالَ : ہَذَا ہُوَ ، یَعْنِی مَسْجِدَ الْمَدِینَۃِ۔ (مسلم 1015۔ احمد 3/24)",,,7607,,
7608,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ، عَنِ ابن حَرْمَلَۃَ، عَنِ ابْنِ الْمُسَیَّبِ، قَالَ: ہُوَ مَسْجِدُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,7608,,
7609,"حَدَّثَنَا الْفَضْلُ ، عَنْ عَبْدِ اللہِ بْنِ عَامِرٍ ، عَنْ عِمْرَانَ بْنِ أَبِی أَنَسٍ ، عَنْ سَہْلِ بْنِ سَعْدٍ ، عَنْ أُبَیِّ بْنِ کَعْبٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : الْمَسْجِدُ الَّذِی أُسِّسَ عَلَی التَّقْوَی ہُوَ مَسْجِدِی۔ (احمد 5/116۔ حاکم 334)",,,7609,,
7610,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَبْدِ الْحَمِیدِ بْنِ جَعْفَرٍ ، قَالَ : حدَّثَنَا أَبُو الأَبْرَدِ مَوْلَی بَنِی خَطْمَۃَ ، أَنَّہُ سَمِعَ أُسَیْدَ بْنَ ظُہَیْرٍ الأَنْصَارِیَّ وَکَانَ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُحَدِّثُ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : صَلاَۃٌ فِی مَسْجِدِ قُبَائٍ کَعُمْرَۃٍ۔ (بخاری 1641۔ ابن ماجہ 1411)",,,7610,,
7611,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، قَالَ : أَخْبَرَنِی یُوسُفُ بْنُ طَہْمَانَ ، عَنْ أَبِی أُمَامَۃَ بْنِ سَہْلٍ ، عَنْ أَبِیہِ سَہْلِ بْنِ حُنَیْفٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ تَوَضَّأَ فَأَحْسَنَ وُضُوئَہُ ، ثُمَّ جَائَ مَسْجِدَ قُبَائٍ فَرَکَعَ فِیہِ أَرْبَعَ رَکَعَاتٍ کَانَ ذَلِکَ عَدْلَ عُمْرَۃٍ۔ (بخاری 3389۔ احمد 3/487)",,,7611,,
7612,"حَدَّثَنَا أَبُو أُسَامَۃَ حَدَّثَنَا عُبَیْدُ اللہِ بْنُ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَأْتِی مَسْجِدَ قُبَائٍ مَاشِیًا وَرَاکِبًا۔ (بخاری 1194۔ ابوداؤد 2033)",,,7612,,
7613,"حَدَّثَنَا أَبُو خَالِدٍ سُلَیْمَانُ بْنُ حَیَّانَ ، عَنْ سَعْدِ بْنِ إِسْحَاقَ ، عَنْ سَلِیطِ بْنِ سَعْدٍ ، قَالَ : سَمِعْتُ ابْنَ عُمَرَ یَقُولُ مَنْ خَرَجَ یُرِیدُ قُبَائً لاَ یُرِیدُ غَیْرَہُ فَصَلَّی فِیہِ کَانَتْ کَعُمْرَۃٍ۔",,,7613,,
7614,حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ ہَاشِمِ بْنِ ہَاشِمٍ ، عَنْ عَائِشَۃَ بِنْتِ سَعْدٍ ، قَالَتْ سَمِعْتُ أَبِی یَقُولُ لأَنْ أُصَلِّیَ فِی مَسْجِدِ قُبَائٍ أَحَبُّ إلَیَّ مِنْ أَنْ أُصَلِّیَ فِی بَیْتِ الْمَقْدِسِ۔,,,7614,,
7615,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی الْعُمَیْسِ ، عَنْ عَمْرِو بْنِ مُرَّۃَ، عَنْ أَبِی صَالِحٍ الْحَنَفِیِّ ، عَنْ أَخِیہِ طَلِیقِ بْنِ قَیْسٍ، قَالَ : قَالَ أَبُو ذَرٍّ : لأَنْ أُصَلِّیَ عَلَی رَمْلَۃٍ حَمْرَائَ أَحَبُّ إلَیَّ مِنْ أَنْ أُصَلِّیَ فِی بَیْتِ الْمَقْدِسِ۔",,,7615,,
7616,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ وَاصِلٍ ، عَنْ أَبِی وَائِلٍ ، عَنْ حُذَیْفَۃَ ، قَالَ : لَوْ سِرْتُ حَتَّی لاَ یَکُونَ بَیْنِی وَبَیْنَ بَیْتِ الْمَقْدِسِ إِلاَّ فَرْسَخٌ ، أَوْ فَرْسَخَانِ مَا أَتَیْتُہُ ، أَوْ مَا أَحْبَبْتُ أَنْ آتِیَہُ۔",,,7616,,
7617,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی الْمِقْدَامِ ، عَنْ حَبَّۃَ ، قَالَ : جَائَ رَجُلٌ إلَی عَلِیٍّ ، فَقَالَ : إنِّی اشْتَرَیْتُ بَعِیرًا وَتَجَہَّزْتُ وأُرِیدُ بَیْتَ الْمَقْدِسِ ، فَقَالَ : بِعْ بَعِیرَک وَصَلِّ فِی ہَذَا الْمَسْجِدِ ، یَعْنِی مَسْجِدَ الْکُوفَۃِ فَمَا مِنْ مَسْجِدٍ بَعْدَ مَسْجِدِ الْحَرَامِ وَمَسْجِدِ الْمَدِینَۃِ أَحَبُّ إلَیَّ مِنْہُ وَلَقَدْ نَقَصَ مِمَّا أُسِّسَ خَمْسَمِئَۃِ ذِرَاعٍ، یَعْنِی مَسْجِدَ الْکُوفَۃِ۔",,,7617,,
7618,"حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ حَدَّثَنَا إسْرَائِیلُ ، عَنْ إبْرَاہِیمَ بْنِ مُہَاجِرٍ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، قَالَ : لَقِیَنِی کَعْبٌ بِبَیْتِ الْمَقْدِسِ ، فَقَالَ : مِنْ أَیْنَ ؟ فَقُلْتُ : مِنْ مَسْجِدِ الْکُوفَۃِ ، فَقَالَ : لأَنْ أَکُونَ جِئْتُ مِنْ حَیْثُ جِئْتَ أَحَبُّ إلَیَّ مِنْ أَنْ أَتَصَدَّقَ بِأَلْفِ دِینَارٍ أَضَعُ کُلَّ دِینَارٍ مِنْہَا فِی یَدِ مِسْکِینٍ ، ثُمَّ حَلَفَ أَنَّہُ أَوْسَطُ الأَرْضِ کَقَعْرِ الطَّسْتِ۔",,,7618,,
7619,"حَدَّثَنَا یَحْیَی بْنُ یَعْلَی ، عَنْ عَبْدِ الْمَلِکِ بْنِ عُمَیْرٍ ، عَنْ قَزَعَۃَ ، عَنْ أَبِی سَعِیدٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تُشَدُّ الرِّحَالُ إِلاَّ إلَی ثَلاَثَۃِ مَسَاجِدَ : مسجد الحرام ، ومسجد المدینۃ ، ومسجد بَیْتِ الْمَقْدِسِ۔ (بخاری 1197۔ مسلم 416)",,,7619,,
7620,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : لاَ تُشَدُّ الرِّحَالُ إِلاَّ إلَی ثَلاَثَۃِ مَسَاجِدَ : الْمَسْجِدِ الْحَرَامِ وَمَسْجِدِی ہَذَا وَالْمَسْجِدِ الأَقْصَی۔ (بخاری 1189۔ احمد 2/234)",,,7620,,
7621,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ طَلْقٍ ، عَنْ قَزَعَۃَ ، قَالَ : سَأَلْتُ ابن عُمَرَ آتِی الطُّورَ ، قَالَ : دَعِ الطُّورَ وَلاَ تَأْتِہَا ، وَقَالَ : لاَ تُشَدُّ الرِّحَالُ إِلاَّ إلَی ثَلاَثَۃِ مَسَاجِدَ۔",,,7621,,
7622,"حَدَّثَنَا یَحْیَی بْنُ الْیَمَانَ ، عَنْ سُفْیَانَ ، عَنْ أَبِی سِنَانٍ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی الْہُذَیْلِ ، قَالَ : لاَ تُشَدُّ الرِّحَالُ إِلاَّ إلَی الْبَیْتِ الْعَتِیقِ۔",,,7622,,
7623,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِاللہِ، عَنْ إبْرَاہِیمَ، قَالَ: لاَ تُشَدُّ الرِّحَالُ إِلاَّ إلَی ثَلاَثَۃِ مَسَاجِدَ۔",,,7623,,
7624,"حَدَّثَنَا زَیْدُ بْنُ حَبَّابٍ ، حَدَّثَنَا جَعْفَرُ بْنُ إبْرَاہِیمَ مِنْ وَلَدِ ذِی الْجَنَاحَیْنِ ، قَالَ : حدَّثَنِی عَلِیُّ بْنُ عُمَرَ ، عَنْ أَبِیہِ ، عَنْ عَلِیِّ بْنِ الْحُسَیْنِ ، أَنَّہُ رَأَی رَجُلاً یَجِیئُ إلَی فُرْجَۃٍ کَانَتْ عِنْدَ قَبْرِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَیَدْخُلُ فِیہَا فَیَدْعُو فَدَعَاہُ ، فَقَالَ : أَلاَ أُحَدِّثُکَ بِحَدِیثٍ سَمِعْتُہُ مِنْ أَبِی ، عَنْ جَدِّی ، عَنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لاَ تَتَّخِذُوا قَبْرِی عِیدًا ، وَلاَ بُیُوتَکُمْ قُبُورًا وَصَلُّوا عَلَیَّ فَإِنَّ صَلاَتَکُمْ وَتَسْلِیمَکُم یَبْلُغُنِی حَیْثُ مَا کُنْتُمْ۔(بخاری 186۔ ابو یعلی 6728)",,,7624,,
7625,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ سُہَیْلِ ، عَنْ حَسَنِ بْنِ حَسَنٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تَتَّخِذُوا قَبْرِی عِیدًا ، وَلاَ بُیُوتَکُمْ قُبُورًا وَصَلُّوا عَلَیَّ حَیْثُ مَّا کُنْتُمْ فَإِنَّ صَلاَتَکُمْ تَبْلُغُنِی۔ (عبدالرزاق 6726)",,,7625,,
7626,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : اللَّہُمَّ لاَ تَجْعَلْ قَبْرِی وَثَنًا یُصَلَّی لَہُ ، اشْتَدَّ غَضَبُ اللہِ عَلَی قَوْمٍ اتَّخَذُوا قُبُورَ أَنْبِیَائِہِمْ مَسَاجِدَ۔ (امام مالک 85)",,,7626,,
7627,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، قَالَ : أَخْبَرَنَا ابْنُ عَوْنٍ ، عَنْ نَافِعٍ ، قَالَ بَلَغَ عُمَرَ بْنَ الْخَطَّابِ ، أَنَّ نَاسًا یَأْتُونَ الشَّجَرَۃَ الَّتِی بُویِعَ تَحْتَہَا ، قَالَ فَأَمَرَ بِہَا فَقُطِعَتْ۔",,,7627,,
7628,"حَدَّثَنَا زَکَرِیَّا بْنُ عَدِیٍّ ، عَنْ عُبَیْدِ اللہِ بْنِ عَمرو ، عَنْ زَیْدِ بْنِ أَبِی أُنَیْسَۃَ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ عَبْدِ اللہِ بْنِ الْحَارِثِ النَّجْرَانِیِّ ، قَالَ : حدَّثَنِی جُنْدَب ، قَالَ : سَمِعْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَبْلَ أَنْ یَمُوتَ بِخَمْسٍ وَہُوَ یَقُولُ : أَلا وَإِنَّ مَنْ کَانَ قَبْلَکُمْ کَانُوا یَتَّخِذُونَ قُبُورَ أَنْبِیَائِہِمْ وَصَالِحِیہِمْ مَسَاجِدَ أَلا فَلاَ تَتَّخِذُوا الْقُبُورَ مَسَاجِدَ إنِّی ، أَنْہَاکُمْ ، عَنْ ذَلِکَ۔ (مسلم 23۔ طبرانی 1686)",,,7628,,
7629,"حَدَّثَنَا ہَاشِمُ بْنُ الْقَاسِمِ ، حَدَّثَنَا شَیْبَانُ ، عَنْ ہِلاَلِ بْنِ أَبِی حُمَیْدٍ الأَنْصَارِیِّ ، عَنْ عُرْوَۃَ بْنِ الزُّبَیْرِ ، عَنْ عَائِشَۃَ ، قَالَتْ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی مَرَضِہِ الَّذِی لَمْ یَقُمْ مِنْہُ : لَعَنَ اللَّہُ الْیَہُودَ وَالنَّصَارَی اتَّخَذُوا قُبُورَ أَنْبِیَائِہِمْ مَسَاجِدَ۔\n\nوَلَوْلاَ ذَلِکَ لأُبْرِزَ قَبْرُہُ ، إِلاَّ إِنَّہُ خُشِیَ أَنْ یُتَّخَذَ مَسْجِدًا۔ (بخاری 1390۔ مسلم 19)",,,7629,,
7630,"حَدَّثَنَا وَکِیعٌ حَدَّثَنَا ہِشَامُ بْنُ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ أَنَّہُمْ تَذَاکَرُوا عِنْدَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی مَرَضِہِ فَذَکَرَتْ أُمُّ سَلَمَۃَ ، أَوْ أُمُّ حَبِیبَۃَ کَنِیسَۃً رَأَتْہَا فِی أَرْضِ الْحَبَشَۃِ فِیہَا تَصَاوِیرُ ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أُولَئِکَ کَانُوا إذَا کَانَ فِیہِمُ الرَّجُلُ الصَّالِحُ فَمَاتَ بَنَوْا عَلَی قَبْرِہِ مَسْجِدًا وَصَوَّرُوہُ أُولَئِکَ شِرَارُ الْخَلْقِ۔ (بخاری 434۔ مسلم 16)",,,7630,,
7631,"حَدَّثَنَا وَکِیعٌ حَدَّثَنَا شُعْبَۃُ ، عَنْ مُحَمَّدِ بْنِ جُحَادَۃَ الأَوْدِیِّ ، قَالَ : سَمِعْتُ أَبَا صَالِحٍ بَعْدَ مَا کَبِرَ یُحَدِّثُ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لَعَنَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ زَائِرَاتِ الْقُبُورِ وَالْمُتَّخِذَاتِ عَلَیْہَا الْمَسَاجِدَ وَالسُّرُجَ۔ (ترمذی 320۔ ابوداؤد 3228)",,,7631,,
7632,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنِ الْمَعْرُورِ بْنِ سُوَیْد ، قَالَ : خَرَجْنَا مَعَ عُمَرَ فِی حَجَّۃٍ حَجَّہَا فَقَرَأَ بِنَا فِی الْفَجْرِ : (أَلَمْ تَرَ کَیْفَ فَعَلَ رَبُّکَ بِأَصْحَابِ الْفِیلِ) ، وَ(لإِیلاَفِ قُرَیْشٍ) فَلَمَّا قَضَی حَجَّہُ وَرَجَعَ وَالنَّاسُ یَبْتَدِرُونَ ، فَقَالَ : مَا ہَذَا ؟ فَقَالُوا : مَسْجِدٌ صَلَّی فِیہِ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : ہَکَذَا ہَلَکَ أَہْلُ الْکِتَابِ اتَّخَذُوا آثَارَ أَنْبِیَائِہِمْ بِیَعًا مَنْ عَرَضَتْ لَہُ مِنْکُمْ فِیہِ الصَّلاَۃ فَلْیُصَلِّ وَمَنْ لَمْ تَعْرِضْ لَہُ مِنْکُمْ فِیہِ الصَّلاَۃ فَلاَ یُصَلِّ۔",,,7632,,
7633,"حَدَّثَنَا مُعَاذٌ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : کَانُوا یَکْرَہُونَ أَنْ یُغَیِّرُوا آثَارَ الأَنْبِیَائِ۔",,,7633,,
7634,"حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ عَائِشَۃَ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لَعَنَ اللَّہُ أَقْوَامًا اتَّخَذُوا قُبُورَ أَنْبِیَائِہِمْ مَسَاجِدَ۔ (بخاری 437۔ مسلم 20 )",,,7634,,
7635,حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ کَرِہَ أَنْ یُبْنَی عَلَی الْقَبْرِ مَسْجِدٌ۔,,,7635,,
7636,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ قُدَامَۃَ ، عَنْ جَسْرَۃَ بِنْتِ دِجَاجَۃَ ، قَالَتْ : صَلَّیْتُ خَلْفَ أَبِی ذَرٍّ وَحْدِی مَا مَعِی امْرَأَۃٌ۔",,,7636,,
7637,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : الْمَرْأَۃُ صَفٌّ۔",,,7637,,
7638,"حَدَّثَنَا وَکِیعٌ حَدَّثَنَا الْمُغِیرَۃُ بْنُ أَبِی الْحُرِّ الْکِنْدِیِّ ، عَنْ حُجْرِ بْنِ ، عَنْبَسٍ الْحَضْرَمِیِّ ، قَالَ : خَرَجْنَا مَعَ عَلِیٍّ إلَی النَّہْرَوَانِ حَتَّی إذَا کُنَّا بِبَابِلَ حَضَرَتْ صَلاَۃُ الْعَصْرِ قُلْنَا : الصَّلاَۃ فَسَکَتَ ، ثُمَّ قُلْنَا الصَّلاَۃ فَسَکَتَ ، فَلَمَّا خَرَجَ مِنْہَا صَلَّی ، ثُمَّ قَالَ : مَا کُنْتُ أُصَلِّی بِأَرْضٍ خُسِفَ بِہَا ثَلاَثَ مَرَّاتٍ۔",,,7638,,
7639,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ شَرِیکٍ الْعَامِرِیِّ ، عَنْ عَبْدِ اللہِ أَبِی الْمُحِلِّ ، عَنْ عَلِیٍّ ، أَنَّہُ کَرِہَ الصَّلاَۃ فِی الْخُسُوفِ۔,,,7639,,
7640,حَدَّثَنَا ابْنُ عُیَیْنَۃَ، عَنْ عَبْدِاللہِ بْنِ شَرِیکٍ، عَنِ ابْنِ أَبِی الْمُحِلِّ، أَنَّ عَلِیًّا مَرَّ بِجَانِبٍ مِنْ بَابِلَ فَلَمْ یُصَلِّ بِہَا۔,,,7640,,
7641,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، عَنْ عُمَیْرِ بْنِ ہَانِیئٍ ، قَالَ : شَہِدْتُ ابْنَ عُمَرَ وَالْحَجَّاجُ مُحَاصِرٌ ابْنَ الزُّبَیْرِ ، فَکَانَ مَنْزِلُ ابْنِ عُمَرَ بَیْنَہُمَا ، فَکَانَ رُبَّمَا حَضَرَ الصَّلاَۃ مَعَ ہَؤُلاَئِ وَرُبَّمَا حَضَرَ الصَّلاَۃ مَعَ ہَؤُلاَئِ۔",,,7641,,
7642,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، قَالَ : کَانَ الْحَسَنُ وَالْحُسَیْنُ یُصَلِّیَانِ خَلْفَ مَرْوَانَ، قَالَ : فَقِیلَ لَہُ : أَمَا کَانَ أَبُوک یُصَلِّی إذَا رَجَعَ إلَی الْبَیْتِ ، قَالَ : فَیَقُولُ لاَ وَاللَّہِ مَا کَانُوا یَزِیدُونَ عَلَی صَلاَۃِ الأَئِمَّۃِ۔",,,7642,,
7643,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یُصَلُّونَ خَلْفَ الأُمَرَائِ مَا کَانُوا۔",,,7643,,
7644,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی حُرَّۃَ ، عَنِ الْحَسَنِ ، قَالَ : لاَ یَضُرُّ الْمُؤْمِنَ صَلاَتُہُ خَلْفَ الْمُنَافِقِ ، وَلاَ یَنْفَعُ الْمُنَافِقَ صَلاَۃُ الْمُؤْمِنِ خَلْفَہُ۔",,,7644,,
7645,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ حَبِیبِ بْنِ جُرَیّ ، قَالَ : سَأَلْتُ أَبَا جَعْفَرٍ ، عَنِ الصَّلاَۃ خَلْفَ الأُمَرَائِ ، فَقَالَ : صَلِّ مَعَہُمْ۔",,,7645,,
7646,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، قَالَ : سَأَلْتُ مَیْمُونًا عَنِ الصَّلاَۃ خَلْفَ الأُمَرَائِ ، فَقَالَ : صَلِّ مَعَہُمْ۔",,,7646,,
7647,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، قَالَ : سَأَلْتُ مَیْمُونًا ، عَنْ رَجُلٍ فَذَکَرَ ، أَنَّہُ مِنَ الْخَوَارِجِ، فَقَالَ : أَنْتَ لاَ تُصَلِّی لَہُ إنَّمَا تُصَلِّی لِلَّہِ قَدْ کُنَّا نُصَلِّی خَلْفَ الْحَجَّاجِ وَکَانَ حَرُورِیًّا أَزْرَقِیًّا۔",,,7647,,
7648,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ عَبْدُ اللہِ یُصَلِّی مَعَہُمْ إذَا أَخَّرُوا عَنِ الْوَقْتِ قَلِیلاً وَیَرَی أَنَّ مَأْثَمَ ذَلِکَ عَلَیْہِمْ۔",,,7648,,
7649,حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا سُفْیَانَ ، عَنِ الْعَلاَئِ بْنِ الْمُسَیَّبِ ، عَنْ رَجُلٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، أَنَّہُ کَانَ یُصَلِّی مَعَ الْحَجَّاجِ عِنْدَ أَبْوَابِ کِنْدَۃَ وَخَرَجَ عَلَیْہِ۔,,,7649,,
7650,"حَدَّثَنَا وَکِیعٌ حَدَّثَنَا بِسَّام ، قَالَ : سَأَلْتُ أَبَا جَعْفَرٍ ، عَنِ الصَّلاَۃ مَعَ الأُمَرَائِ ، فَقَالَ : صَلِّ مَعَہُمْ فَإِنَّا نُصَلِّی مَعَہُمْ قَدْ کَانَ الْحَسَنُ وَالْحُسَیْنُ یَبْتَدِرَانِ الصَّلاَۃ خَلْفَ مَرْوَانَ ، قَالَ : قُلْتُ : إنَّ النَّاس یَزْعُمُونَ أَنَّ ذَلِکَ تَقِیَّۃٌ ، قَالَ : وَکَیْفَ إِنْ کَانَ الْحَسَنُ بْنُ عَلِیٍّ لیَسُبُّ مَرْوَانَ فِی وَجْہِہِ وَہُوَ عَلَی الْمِنْبَرِ حَتَّی یُوَلّی۔",,,7650,,
7651,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا سُفْیَانُ ، عَنْ إبْرَاہِیمَ بْنِ أَبِی حَفْصَۃَ ، قَالَ : قُلْتُ لِعَلِیِّ بْنِ حُسَیْنٍ : إنَّ أَبَا حَمْزَۃَ الثُّمَالیَّ ، وَکَانَ فِیہِ غُلُوٌّ ، یَقُولُ : لاَ نُصَلِّی خَلْفَ الأَئِمَّۃِ ، وَلاَ نُنَاکِحُ إِلاَّ مَنْ یَرَی مِثْلَ رَأْینَا ، فَقَالَ عَلِیُّ بْنُ الحُسَیْنِ : بَلْ نُصَلِّی خَلْفَہُمْ وَنُنَاکِحُہُمْ بِالسُّنَّۃِ۔",,,7651,,
7652,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا سُفْیَانُ ، عَنِ الأَعْمَشِ ، قَالَ : کَانُوا یُصَلُّونَ خَلْفَ الأُمَرَائِ وَیَحْتَسِبُونَ بِہَا۔",,,7652,,
7653,حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا سُفْیَانُ ، عَنْ عُقْبَۃَ الأَسَدِیِّ ، عَنْ یَزِیْدَ بْنِ أَبِی سُلَیْمَانَ ، أَنَّ أَبَا وَائِلٍ کَانَ یُجَمّعُ مَعَ الْمُخْتَارِ۔,,,7653,,
7654,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا سُفْیَانُ ، عَنْ مُسْلِمٍ أَبِی فَرْوَۃَ ، قَالَ : رَأَیْتُ عَبْدَ الرَّحْمَن بْنَ أَبِی لَیْلَی وَأَشَارَ إلَی مُحَمَّدِ بْنِ سَعْدٍ وَالْحَجَّاجُ یَخْطُبُ أَنِ اسْکُتْ۔",,,7654,,
7655,حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنِ الأَعْمَشِ ، عَنِ الْقَاسِمِ بْنِ مُخَیْمِرَۃَ ، أَنَّہُ کَانَ یُصَلِّی خَلْفَ الْحَجَّاجِ۔,,,7655,,
7656,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا سُفْیَانُ ، عَنْ عَمْرِو بْنِ یَحْیَی بْنِ عُمَارَۃَ الْمَازِنِیِّ ، عَنْ أَبِیہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الأَرْضُ کُلُّہَا مَسْجِدٌ إِلاَّ الْمَقْبَرَۃَ وَالْحَمَّامَ۔ (ترمذی 317۔ ابوداؤد 96)",,,7656,,
7657,"حَدَّثَنَا حَفْصٌ ، عَنْ حُمَیْدٌ ، عَنْ أَنَسٍ ، قَالَ : رَآنِی عُمَرُ وَأَنَا أُصَلِّی إلَی قَبْرٍ فَجَعَلَ یَقُولُ یَا أَنَسُ الْقَبْرَ ، فَجَعَلْتُ أَرْفَعُ رَأْسِی أَنْظُرُ إلَی الْقَمَرِ ، فَقَالُوا : إنَّمَا ہُوَ یَقُولُ الْقَبْرَ۔",,,7657,,
7658,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا سُفْیَانُ حَدَّثَنَا حُمَیْدٌ ، عَنْ أَنَسٍ ، قَالَ : رَآنِی عُمَرُ وَأَنَا أُصَلِّی ، فَقَالَ : الْقَبْرُ أَمَامَک فَنَہَانِی۔",,,7658,,
7659,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ أَبِی ظَبْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو قَالَ : لاَ تُصَلِّ إلَی الْحُشِّ ، وَلاَ إلَی حَمَّام ، وَلاَ إلَی مَقْبَرَۃ۔",,,7659,,
7660,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنِ الْحَسَنِ الْعُرَنِیِّ ، قَالَ : الأَرْضُ کُلُّہَا مَسَاجِدُ إِلاَّ الْحُشَّ وَالْحَمَّامَ وَالْمَقْبَرَۃَ۔",,,7660,,
7661,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنِ الْعَلاَئِ بْنِ الْمُسَیَّبِ ، عَنْ أَبِیہِ وَخَیْثَمَۃَ ، قَالاَ : لاَ یُصَلَّیَ إلَی حَائِطِ حَمَّامٍ ، وَلاَ وَسَطَ مَقْبَرَۃٍ۔",,,7661,,
7662,"حَدَّثَنَا وَکِیعٌ حَدَّثَنَا ہَمَّامٌ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسٍ ، قَالَ : کَانَ یَکْرَہُ أَنْ یُبْنَی مَسْجِدٌ بَیْنَ الْقُبُورِ۔",,,7662,,
7663,"حَدَّثَنَا وَکِیعٌ ، أَخْبَرَنَا سُفْیَانُ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا إذَا خَرَجُوا مَعَ جِنَازَۃٍ فَحَضَرَتِ الصَّلاَۃ تَنَحَّوْا ، عَنِ الْقُبُورِ۔",,,7663,,
7664,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا سُفْیَانُ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یَکْرَہُونَ ثَلاَثَ أَبْیَاتٍ لِلْقِبْلَۃِ : الْحُشَّ وَالْمَقْبَرَۃَ وَالْحَمَّامَ۔",,,7664,,
7665,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا سُفْیَانُ ، عَنْ بَکْرِ بْنِ قَیْسٍ ، عَنِ ابْنِ سِیرِینَ ، أَنَّہُ کَرِہَ الصَّلاَۃ إلَی التَّنور ، وَقَالَ : بَیْتُ نَارٍ۔",,,7665,,
7666,حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَرِہَ الصَّلاَۃ بَیْنَ الْقُبُورِ۔,,,7666,,
7667,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ تُدْرِکُہُ الصَّلاَۃ فِی الْمَقَابِرِ ، قَالَ : یُصَلِّی ، وَقَالَ ابْنُ سِیرِینَ : یَرْجِع۔",,,7667,,
7668,حَدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ، أَنَّہُ کَانَ یَکْرَہُ الصَّلاَۃ فِی الْمَقَابِرِ۔,,,7668,,
7669,حَدَّثَنَا حَفْصٌ ، عَنْ عَاصِمٍ ، عَنِ ابْنِ سِیرِینَ ، عَنْ أَنَسٍ ، أَنَّہُ کَرِہَ أَنْ یُصَلَّی عَلَی الْجِنَازَۃِ فِی الْمَقْبَرَۃِ۔,,,7669,,
7670,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنِ الأَسْوَدِ بْنِ شَیْبَانَ ، قَالَ : رَأَیْتُُ مُوسَی بْنَ أَنَسٍ یُصَلِّی الْعَصْرَ فِی قَبْرِ أَخِیہِ النَّضِرِ بْنِ أَنَسٍ وَقَدْ ضُرِحَ لَہُ وَسَطَ الْقَبْرِ۔",,,7670,,
7671,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ لَیْثٍ ، عَنِ الْحَکَمِ ، قَالَ : قَالَ عَلِیٌّ : لاَ تُصَلِّ تُجَاہَ حُشٍّ ، وَلاَ حَمَّامٍ ، وَلاَ مَقْبَرَۃٍ۔",,,7671,,
7672,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا سُفْیَانُ ، عَنْ مَنْصُورٍ ، عَنْ ہِلاَلِ بْنِ یَِسَافٍ ، عَنِ أبی الْمُثَنَّی الْحِمْصِیِّ ، عَنِ أَبِی أُبَی ابن امرَأَۃ عُبَادَۃَ بْنِ الصَّامِتِ ،عَنْ عُبَادَۃَ بْنِ الصَّامِتِ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَنَّہَا سَتَکُونُ عَلَیْکُمْ أُمَرَائُ فَتَشْغَلُہُمْ أَشْیَائٌ عَنِ الصَّلاَۃ حَتَّی یُؤَخِّرُوہَا عَنْ وَقْتِہَا فَصَلُّوہَا لِوَقْتِہَا ، فَقَالَ رَجُلٌ : یَا رَسُولَ اللہِ إِنْ أَدْرَکْتُہَا مَعَہُمْ أُصَلِّی مَعَہُمْ ؟ قَالَ : نَعَمْ إِنْ شِئْتَ۔ (ابوداؤد 434۔ احمد 5/315)",,,7672,,
7673,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ وَعَلْقَمَۃَ ، قَالاَ : قَالَ عَبْدُ اللہِ : إِنَّہُ سَیَکُونُ عَلَیْکُمْ أُمَرَائُ یُؤَخِّرُونَ الصَّلاَۃ عَنْ وَقْتِہَا وَیَخْنُقُونَہَا إلَی شَرَقِ الْمَوْتَی فَإِذَا رَأَیْتُمُوہُمْ قَدْ فَعَلُوا ذَلِکَ فَصَلُّوا فِی بُیُوتِکُمْ ، ثُمَّ اجْعَلُوا صَلاَتَکُمْ سُبْحَۃً۔",,,7673,,
7674,"حَدَّثَنَا وَکِیعٌ حَدَّثَنَا شُعْبَۃُ ، عَنْ أَبِی عِمْرَانَ الْجَوْنِیِّ ، عَنْ عَبْدِ اللہِ بْنِ الصَّامِتِ ، عَنْ أَبِی ذَرٍّ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : صَلُّوا الصَّلاَۃ لِوَقْتِہَا۔ (احمد 5/157۔ طیالسی 449)",,,7674,,
7675,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا سُفْیَانُ ، عَنِ الأَعْمَشِ ، قَالَ : رَأَیْتُ إبْرَاہِیمَ وَخَیْثَمَۃَ یُصَلِّیَانِ الظُّہْرَ وَالْعَصْرَ فِی بُیُوتِہِمَا ثُمَّ یَأْتِیَانِ الْحَجَّاجَ فَیُصَلِّیَانِ مَعَہُ۔",,,7675,,
7676,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنْ مُسْلِمٍ قَالَ : کُنْتُ أَجْلِسُ مَعَ مَسْرُوقٍ ، وَأَبِی عُبَیْدَۃَ فِی الْمَسْجِدِ فِی زَمَنِ زِیَادٍ فَإِذَا دَخَلَ وَقْتُ الظُّہْرِ قَامَا فَصَلَّیَا ، ثُمَّ یَجْلِسَانِ حَتَّی إذَا أَذَّنَ الْمُؤَذِّنُ وَخَرَجَ الإِمَام قَامَا فَصَلَّیَا وَیَفْعَلاَنِہِ فِی الْعَصْرِ۔",,,7676,,
7677,حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا سُفْیَانُ ، عَنْ أَبِی ہَاشِمٍ ، أَنَّ الْحَجَّاجَ أَخَّرَ الصَّلاَۃ فَأَوْمَأَ أَبُو وَائِلٍ وَہُوَ جَالِسٌ۔,,,7677,,
7678,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا سُفْیَانُ ، عَنْ عَبْدِ اللہِ بْنِ عُثْمَانَ ، عَنْ عَلِیٍّ الأَزْدِیِّ ، قَالَ : أَخَّرَ الْحَجَّاجُ الصَّلاَۃ بِعَرَفَۃَ فَصَلَّی ابْنُ عُمَرَ فِی رَحْلِہِ وَثَمَّ نَاسٌ وُقُفٌ ، قَالَ : فَأَمَرَ بِہِ الْحَجَّاجَ فَنُخِسَ بِہِ۔",,,7678,,
7679,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا الْمَسْعُودِیُّ ، عَنْ عَبْدِ الْمَلِکِ بْنِ عُمَیْرٍ ، قَالَ : کَانَ أَبُو عُبَیْدَۃَ یَنْتَظِرُ الْمَغْرِبَ فَإِذَا أَبْطؤوا بِہَا حَلَّ حَبْوَتَہُ وَخَرَجَ۔",,,7679,,
7680,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا إسْرَائِیلُ ، عَنْ عَامِرِ بْنِ شَقِیقٍ ، قَالَ : کَانَ الْحَجَّاجُ یُؤَخِّرُ الصَّلاَۃ یَوْمَ الْجُمُعَۃِ ، فَکَانَ أَبُو وَائِلٍ یَأْمُرُنَا أَنْ نُصَلِّیَ فِی بُیُوتِنَا ، ثُمَّ نَأْتِیَ الْمَسْجِدَ۔",,,7680,,
7681,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی عِمْرَانَ الْجَوْنِیِّ ، عَنْ عَبْدِ اللہِ بْنِ الصَّامِتِ ، عَنْ أَبِی ذَرٍّ ، قَالَ: إنَّ خَلِیلِی صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَوْصَانِی أَنْ أُصَلِّیَ الصَّلاَۃ لِوَقْتِہَا ، فَإِنْ أَدْرَکْتَ الْقَوْمَ قَدْ صَلَّوْا کُنْتَ قَدْ أَحْرَزْتَ صَلاَتَکَ وَالأَ کَانَتْ نَافِلَۃً۔ (مسلم 448)",,,7681,,
7682,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ مُحَمَّدِ بْنِ أَبِی إسْمَاعِیلَ ، قَالَ : رَأَیْتُ عَطَائً وَسَعِیدَ بْنَ جُبَیْرٍ وَأَخَّرَ الْوَلِیدُ الصَّلاَۃ فَأَوْمَآ فِی وَقْتِ الصَّلاَۃ ، ثُمَّ قَعَدَا حَتَّی صَلَّیَا مَعَہُ تِلْکَ الصَّلاَۃ رَأَیْتُہُمَا فَعَلاَ ذَلِکَ مِرَارًا۔",,,7682,,
7683,حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ عَائِشَۃَ ، أَنَّ نَبِیَّ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَکْرَہُ الصَّلاَۃ فِی مَشَاعِرِہِنَّ۔ (ابوداؤد 371۔ ترمذی 600),,,7683,,
7684,"حَدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ ، عَنْ عَمْرِو بْنِ سَعِیدٍ ، عَنْ مُحَمَّدٍ ، قَالَ : لاَ تُصَلُّوا فِی شُعُرِ النِّسَائِ۔\n\nقَالَ أَبُو بَکْر : یَعْنِی ثِیَابَہُنَّ۔",,,7684,,
7685,"حَدَّثَنَا غُنْدَرٌ ، عَنِ الأَشْعَثِ ، عَنِ الْحَسَنِ ، قَالَ : لاَ بَأْسَ أَنْ یُصَلِّیَ الرَّجُلُ فِی مَلاَحِفِ النِّسَائِ۔",,,7685,,
7686,"حَدَّثَنَا یَحْیَی بْنُ یَمَانَ ، عَنْ حَنْظَلَۃَ ، عَنْ طَاوُوسٍ ، قَالَ : لاَ بَأْسَ أَنْ یُصَلِّیَ الرَّجُلُ فِی ثَوْبِ الْمَرْأَۃِ۔",,,7686,,
7687,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عُمَیْرِ بْنِ یَرِیمَ أَبِی ہِلاَلٍ ، قَالَ: سَمِعْتُ ابْنَ العَبَّاسٍ یَقُولُ: لاَ یَقُولُ انْصَرَفْنَا مِنَ الصَّلاَۃ فَإِنَّ قَوْمًا انْصَرَفُوا فَصَرَفَ اللَّہُ قُلُوبَہُمْ وَلَکِنْ قُولُوا : قَدْ قُضِیَتِ الصَّلاَۃ۔",,,7687,,
7688,حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ کَانَ لاَ یَرَی بِذَلِکَ بَأْسًا۔,,,7688,,
7689,"حَدَّثَنَا عَفَّانُ ، حَدَّثَنَا سَعِیدُ بْنُ زَیْدٍ ، قَالَ : حدَّثَنَا الزُّبَیْرُ بْنُ الْخِرِّیتِ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عُمَرَ قَالَ: لاَ یُقَالُ : انْصَرَفْنَا مِنَ الصَّلاَۃ وَلَکِنْ قَدْ قُضِیَتِ الصَّلاَۃ۔",,,7689,,
7690,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : کَانَتِ امْرَأَۃٌ لِعُمَرَ تَشْہَدُ صَلاَۃَ الصُّبْحِ وَالْعِشَائِ فِی جَمَاعَۃٍ فِی الْمَسْجِدِ فَقِیلَ لَہَا : لِمَ تَخْرُجِینَ وَقَدْ تَعْلَمِینَ أَنَّ عُمَرَ یَکْرَہُ ذَلِکَ وَیَغَارُ ؟ قَالَتْ : فَمَا یَمْنَعُہُ أَنْ یَنْہَانِی ، قَالُوا : یَمْنَعُہُ قَوْلُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تَمْنَعُوا إمَائَ اللہِ مَسَاجِدَ اللہِ۔ (بخاری 900۔ احمد 2/7)",,,7690,,
7691,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تَمْنَعُوا إمَائَ اللہِ مَسَاجِدَ اللہِ وَلْیَخْرُجْنَ إذَا خَرَجْنَ تَفِلاَتٍ۔ (ابوداؤد 566۔ احمد 438)",,,7691,,
7692,"حَدَّثَنَا أَبُو خَالِدٍ وعَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عَمْرَۃَ ، عَنْ عَائِشَۃَ قَالَتْ : لَوْ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَدْرَکَ مَا أَحْدَثْنَ النِّسَائُ الیَوْم لَمَنَعَہُنَّ الْمَسَاجِدَ کَمَا مُنِعْنَہُ نِسَائُ بَنِی إسْرَائِیلَ ، قَالَتْ : قُلْتُ : وَمُنِعْنَہُ ؟ قَالَتْ : نَعَمْ۔ (مسلم 144۔ مؤطا 15)",,,7692,,
7693,"حَدَّثَنَا عَبْدَۃُ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تَمْنَعُوا إمَائَ اللہِ مَسَاجِدَ اللہِ۔ (بخاری 900۔ ابوداؤد 567)",,,7693,,
7694,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ شبَاکٍ ، عَنْ إبْرَاہِیمَ قَالَ : کَانَتِ امْرَأَۃُ أَبِی مَسْعُودٍ تُصَلِّی الْعِشَائَ الآخِرَۃَ فِی مَسْجِدِ الْجَمَاعَۃِ۔",,,7694,,
7695,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا حَنْظَلَۃُ الْجُمَحِیُّ ، عَنْ سَالِمٍ بنِ عَبْدِ اللہِ ، عَنِ ابْنِ عُمَرَ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا اسْتَأْذَنَکُمْ نِسَاؤُکُمْ إلَی الْمَسَاجِدِ فَأْذَنُوا لَہُنَّ۔ (بخاری 865۔ مسلم 137)",,,7695,,
7696,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا مِسْعَرٌ ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنْ أَبِی عَمْرٍو الشَّیْبَانِیِّ ، قَالَ : قَالَ عَبْدُ اللہِ : مَا صَلَّتِ امْرَأَۃٌ صَلاَۃً قَطُّ أَفْضَلَ مِنْ صَلاَۃٍ تُصَلِّیہَا فِی بَیْتِہَا إِلاَّ أَنْ تُصَلِّیَ عِنْدَ الْمَسْجِدِ الْحَرَامِ ، إِلاَّ عَجُوزٌ فِی مَنْقَلَیْہَا ، یَعْنِی خُفَّیْہَا۔",,,7696,,
7697,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا إسْرَائِیلُ ، عَنْ عَبْدِ الأَعْلَی ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنْ عَبْدِ اللہِ بْنِ عَبَّاسٍ ، أَنَّ امْرَأَۃً سَأَلَتْہُ عَنِ الصَّلاَۃ فِی الْمَسْجِدِ یَوْمَ الْجُمُعَۃِ ؟ فَقَالَ : صَلاَتُکِ فِی مَخْدَعِکِ أَفْضَلُ مِنْ صَلاَتِکِ فِی بَیْتِکِ ، وَصَلاَتُکِ فِی بَیْتِکِ أفْضَلُ مِنْ صَلاَتِکِ فِی حُجْرَتِکِ ، وَصَلاَتُکِ فِی حُجْرَتِکِ أَفْضَلُ مِنْ صَلاَتِکَ فِی مَسْجِدِ قَوْمِک۔",,,7697,,
7698,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا سُلَیْمَانُ بْنُ الْمُغِیرَۃِ ، عَنْ حُمَیْدِ بْنِ ہِلاَلٍ ، عَنْ أَبِی الأَحْوَص ، قَالَ : قَالَ عَبْدُ اللہِ : الْمَرْأَۃُ عَوْرَۃٌ وَأَقْرَبُ مَا تَکُونُ مِنْ رَبِّہَا إذَا کَانَتْ فِی قَعْرِ بَیْتِہَا فَإِذَا خَرَجَتِ اسْتَشْرَفَہَا الشَّیْطَانُ۔",,,7698,,
7699,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا سُفْیَانُ ، عَنْ أَبِی فَرْوَۃَ الْہَمْدَانِیِّ ، عَنْ أَبِی عَمْرٍو الشَّیْبَانِیِّ ، قَالَ : رَأَیْتُ ابْنَ مَسْعُودٍ یَحْصِبُ النِّسَائَ یُخْرِجُہُنَّ مِنَ الْمَسْجِدِ یَوْمَ الْجُمُعَۃِ۔",,,7699,,
7700,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا إیَاسُ بْنُ دَغْفَلٍ ، قَالَ : سُئِلَ الْحَسَنُ عَنِ امْرَأَۃٍ جَعَلَتْ عَلَیْہَا إِنْ أُخْرِجَ زَوْجُہَا مِنَ السِّجْنِ أَنْ تُصَلِّیَ فِی کُلِّ مَسْجِدٍ تُجَمَّعُ فِیہِ الصَّلاَۃ بِالْبَصْرَۃِ رَکْعَتَیْنِ ، فَقَالَ الْحَسَنُ : تُصَلِّی فِی مَسْجِدِ قَوْمِہَا فَإِنَّہَا لاَ تُطِیقُ ذَلِکَ لَوْ أَدْرَکَہَا عُمَرُ بْنُ الْخَطَّابِ لأَوْجَعَ رَأْسَہَا۔",,,7700,,
7701,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ سَعِیدِ بْنِ مَسْرُوقٍ ، عَنْ أَبِی عَمْرٍو الشَّیْبَانِیِّ ، قَالَ : سَمِعْتُ رَبَّ ہَذِہِ الدَّارِ، یَعْنِی ابْنَ مَسْعُودٍ حَلَفَ فَبَالَغَ فِی الْیَمِینِ مَا صَلَّتِ امْرَأَۃٌ صَلاَۃً أَحَبَّ إلَی اللہِ مِنْ صَلاَۃٍ فِی بَیْتِہَا إِلاَّ فِی حَجٍّ أَوْ عُمْرَۃٍ ، إِلاَّ امْرَأَۃٌ قَدْ أَیِسَتْ مِنَ الْبُعُولَۃِ۔",,,7701,,
7702,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، حَدَّثَنَا ابْنُ لَہِیعَۃَ ، حَدَّثَنِی عَبْدُ الْحَمِیدِ بْنُ الْمُنْذِرِ السَّاعِی ، عَنْ أَبِیہِ ، عَنْ جَدَّتِہِ أُمِّ حُمَیْدٍ ، قَالَتْ : قُلْتُ : یَا رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَمْنَعُنَا أَزْوَاجُنَا أَنْ نُصَلِّیَ مَعَک وَنُحِبُّ الصَّلاَۃ مَعَک ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : صَلاَتُکُنَّ فِی بُیُوتِکُنَّ أَفْضَلُ مِنْ صَلاَتِکُنَّ فِی حُجَرِکُنَّ ، وَصَلاَتُکُنَّ فِی حُجَرِکُنَّ أَفْضَلُ مِنْ صَلاَتِکُنَّ فِی الْجَمَاعَۃِ۔ (طبرانی 356۔ احمد 6/371)",,,7702,,
7703,"حَدَّثَنَا حَفْصٌ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ: کَانَ لإِبْرَاہِیمَ ثَلاَثُ نِسْوَۃٍ فَلَمْ یَکُنْ یَدَعُہُنَّ یَخْرُجْنَ إلَی جُمُعَۃٍ ، وَلاَ جَمَاعَۃٍ۔",,,7703,,
7704,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ مُحَمَّدِ بْنِ عَقِیلٍ ، عَنْ جَابِرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : خَیْرُ صُفُوفِ النِّسَائِ آخِرُہَا وَشَرُّہَا مُقَدَّمُہَا۔",,,7704,,
7705,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ إبْرَاہِیمَ بْنِ مُہَاجِرٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ عَبْدُ اللہِ یَقُولُ : خَیْرُ صُفُوفِ النِّسَائِ الْمُؤَخَّرُ۔",,,7705,,
7706,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ یَحْیَی بْنِ أَیُّوبَ ، عَنْ أَبِی زُرْعَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : خَیْرُ صُفُوفِ النِّسَائِ آخِرُہَا وَشَرُّہَا أَوَّلُہَا۔",,,7706,,
7707,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، قَالَ : کَانَ یُقَالُ : خَیْرُ صُفُوفِ النِّسَائِ مُؤَخَّرُہَا وَشَرُّہَا مُقَدَّمُہَا۔",,,7707,,
7708,حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ بِمِثْلِہِ۔,,,7708,,
7709,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حُصَیْنٌ ، قَالَ : حُدِّثْتُ أَنَّ ابْنَ مَسْعُودٍ کَانَ یُقَدِّمُ الْعَجَائِزَ فِی الصَّفِّ الأَوَّلِ مِنْ صُفُوفِ النِّسَائِ ، وَیُؤَخِّرُ الشَّوَابَّ إلَی الصَّفِّ الْمُؤَخَّرِ۔",,,7709,,
7710,"حَدَّثَنَا یَحْیَی بْنُ أَبِی بُکَیْرٍ ، حَدَّثَنَا زُہَیْرُ بْنُ مُحَمَّدٍ ، عَنْ عَبْدِ اللہِ بْنِ مُحَمَّدِ بْنِ عَقِیلٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ أَبِی سیدٍ الْخُدْرِیِّ ، أَنَّہُ سَمِعَ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : خَیْرُ صُفُوفِ النِّسَائِ الْمُؤَخَّرُ وَشَرُّہَا الْمُقَدَّمُ۔",,,7710,,
7711,"حَدَّثَنَا عَبِیْدَۃُ بْنُ حُمَیْدٍ ، عَنْ سُہَیْلٍ ، عَنْ أَبِیہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : خَیْرُ صُفُوفِ الرِّجَالِ مُقَدَّمُہَا وَشَرُّہَا مُؤَخَّرُہَا وَخَیْرُ صُفُوفِ النِّسَائِ آخِرُہَا وَشَرُّہَا مُقَدَّمُہَا۔ (ترمذی 224۔ ابوداؤد 678)",,,7711,,
7712,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، حَدَّثَنَا سُفْیَانُ ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنِ ، عَنْ أَبِیہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : خَیْرُ صُفُوفِ الرِّجَالِ أَوَّلُہَا ، وَشَرُّ صُفُوفِ الرِّجَالِ آخِرُہَا ، وَخَیْرُ صُفُوفِ النِّسَائِ آخِرُہَا ، وَشَرُّ صُفُوفِ النِّسَائِ أَوَّلُہَا۔ (حمیدی 1001۔ احمد 2/340)",,,7712,,
7713,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، قَالَ : أَخْبَرَنَا ثَابِتُ بْنُ أَسْلَمَ ، قَالَ : حَدَّثَنَا صِلَۃ بْنُ أَشْیَمَ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : مَنْ صَلَّی رَکْعَتَیْنِ لَمْ یُحَدِّثْ نَفْسَہُ فِیہِمَا بِشَیْئٍ مِنَ الدُّنْیَا لَمْ یَسْأَلِ اللَّہَ شَیْئًا إِلاَّ أَعْطَاہُ إیَّاہُ۔",,,7713,,
7714,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، حَدَّثَنَا لَیْثٌ ، عَنْ عِیسَی ، عَنْ زَیْدِ بْنِ أَرْطَاۃَ ، عَنْ أَبِی أُمَامَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَا أُوتِیَ عَبْدٌ فِی ہَذِہِ الدُّنْیَا خَیْرٌ لَہُ مِنْ أَنْ یُؤْذَنَ لَہُ فِی رَکْعَتَیْنِ فَیُصَلِّیَہُمَا۔ (ترمذی 2911۔ احمد 5/268)",,,7714,,
7715,"حَدَّثَنَا حَفْصٌ ، عَنْ أَبِی مَالِکٍ ، عَنْ أَبِی حَازِمٍ ، قَالَ : مَرَرْت مَعَ أَبِی ہُرَیْرَۃَ عَلَی قَبْرٍ دُفِنَ حَدِیثًا ، فَقَالَ: لَرَکْعَتَانِ خَفِیفَتَانِ مِمَّا تَحْتَقِرُونَ زَادَہُمَا ہَذا : أَحَبُّ إلَیْہِ مِنْ بَقِیَّۃِ دُنْیَاکُمْ۔",,,7715,,
7716,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ عَاصِمٍ ، عَنْ أَبِی عُثْمَانَ ، قَالَ : اشْتَرَی رَجُلٌ حَائِطًا مِنَ الْمَدِینَۃِ فَرَبِحَ فِیہِ مِئَۃ نَخْلَۃٍ کَامِلَۃٍ ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِلاَّ أُخْبِرُکُمْ بِأَفْضَلَ مِنْ ہَذَا ؟ رَجُلٌ تَوَضَّأَ فَأَحْسَنَ الْوُضُوئَ ، ثُمَّ صَلَّی رَکْعَتَیْنِ فِی غَارٍ ، أَوْ سَفْحِ جَبَلٍ أَفْضَلُ رِبْحًا مِنْ ہَذَا۔",,,7716,,
7717,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا بَعْضُ أَصْحَابِنَا ، عَنِ الْجُرَیرِیِّ ، عَنْ أَبِی الْوَرْدِ ، عَنْ کَعْبٍ : إنَّ فِی ہَذَا لَبَلاَغًا لِقَوْمٍ عَابِدِینَ ، قَالَ : الصَّلَوَاتُ الْخَمْسُ۔",,,7717,,
7718,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا ابْنُ أَبِی خَالِدٍ وَمِسْعَرٌ وَالْبَخْتَرِیُّ بْنُ الْمُخْتَارِ ، سَمِعُوہُ مِنْ أَبِی بَکْرِ بْنِ عُمَارَۃَ بْنِ رُوَیْبَۃَ الثَّقَفِیِّ ، عَنْ أَبِیہِ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : لَنْ یَلِجَ النَّارَ مَنْ صَلَّی قَبْلَ طُلُوعِ ألشَّمْسِ وَقَبْلَ غُرُوبِہَا ، فَقَالَ لَہُ رَجُلٌ مِنْ أَہْلِ الْبَصْرَۃِ : أَنْتَ سَمِعْتَہُ مِنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ قَالَ : نَعَمْ أَشْہَدُ أَنِّی سَمِعْتُہُ مِنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سَمِعَتْہُ أُذُنَایَ وَوَعَاہُ قَلْبِی۔ (مسلم 213۔ احمد 4/261)",,,7718,,
7719,"حَدَّثَنَا شَرِیکٌ ، عَنْ عَاصِمٍ ، عَنْ زِرٍّ ، قَالَ : کُنَّا نَعْرِضُ الْمَصَاحِفَ عَلَی عَبْدِ اللہِ ، فَسَأَلَہُ رَجُلٌ مِنْ ثَقِیفٍ ، فَقَالَ : یَا أَبَا عَبْدِ الرَّحْمَنِ أَیُّ الأَعْمَالِ أَفْضَلُ ؟ قَالَ : الصَّلاَۃ ، وَمَنْ لَمْ یُصَلِّ فَلاَ دِینَ لَہُ۔",,,7719,,
7720,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ مَنْصُورٍ ، عَنْ شَقِیقٍ ، عَنْ مَسْرُوقٍ ، قَالَ : مَا مِنْ حَالٍ أَحْرَی أَنْ یُسْتَجَابَ لِلْعَبْدِ فِیہِ إِلاَّ أَنْ یَکُونَ فِی سَبِیلِ اللہِ مِنْ أَنْ یَکُونَ عَافِرًا وَجْہَہُ سَاجِدًا۔",,,7720,,
7721,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ مَنْصُورٍ ، عَنْ مَالِکِ بْنِ الْحَارِثِ ، قَالَ حُدِّثْتُ أَنَّ مَسْرُوقًا کَانَ یَقُولُ : مَنْ حَافَظَ عَلَی ہَؤُلاَئِ الصَّلَوَاتِ لَمْ یُکْتَبْ مِنَ الْغَافِلِینَ فَإِنَّ فِی إفْرَاطِہِنَّ الْہَلَکَۃَ۔",,,7721,,
7722,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ مُحَمَّدِ بْنِ أَبِی إسْمَاعِیلَ ، عَنْ مَعْقِلٍ الْخَثْعَمِیِّ ، عَنْ عَلِیٍّ قَالَ : مَنْ لَمْ یُصَلِّ فَقَدْ کَفَرَ۔",,,7722,,
7723,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ عِمْرَانَ بْنِ سُلَیْمَانَ ، عَنْ عَلِیِّ بْنِ ثَابِتٍ ، قَالَ : قرْبَانُ الْمُتَّقِینَ الصَّلاَۃ۔",,,7723,,
7724,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا مِسْعَرٌ وَسُفْیَان ، عَنْ عُثْمَانَ بْنِ الْمُغِیرَۃِ الثَّقَفِیِّ ، عَنْ عَلِیِّ بْنِ رَبِیعَۃَ الْوَالِبِیِّ ، عَنْ أَسْمَائَ بْنِ الْحَکَمِ الْفَزَارِیِّ ، عَنْ عَلِیٍّ قَالَ : کُنْتُُ إذَا سَمِعْتُ مِنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَدِیثًا نَفَعَنِی اللَّہُ بِمَا شَائَ مِنْہُ فَإِذَا حَدَّثَنِی عَنْہُ غَیْرِی اسْتَحْلَفْتُہُ فَإِذَا حَلَفَ لِی صَدَّقْتُہُ ، وَإِنَّ أَبَا بَکْرٍ حَدَّثَنِی وَصَدَقَ أَبُو بَکْرٍ ، أَنَّہُ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : مَا مِنْ رَجُلٍ یُذْنِبُ ذَنْبًا فَیَتَوَضَّأُ فَیُحْسِنُ الْوُضُوئَ ، قَالَ سُفْیَانُ : ثُمَّ یُصَلِّی رَکْعَتَیْنِ ، قَالَ مِسْعَرٌ : ثُمَّ یُصَلِّی فَیَسْتَغْفِرُ اللَّہَ إِلاَّ غَفَرَ لَہُ۔ (ترمذی 3006۔ ابوداؤد 1516)",,,7724,,
7725,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا الأَعْمَش ، عَنْ سُلَیْمَانَ بْنِ مَیْسَرَۃَ وَالْمُغِیرَۃِ بْنِ شِبْلٍ ، عَنْ طَارِقِ بْنِ شِہَابٍ ، عَنْ سَلْمَانَ ، قَالَ : الصَّلَوَاتُ الْخَمْسُ کَفَّارَاتٌ لِمَا بَیْنَہُنَّ مَا اجْتُنِبَتِ المَقْتل۔",,,7725,,
7726,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ووَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی وَائِلٍ قَالَ : قَالَ عَبْدُ اللہِ : الصَّلَوَاتُ الْحَقَائِقُ کَفَّارَاتٌ لِمَا بَیْنَہُنَّ مَا اجْتُنِبَتِ الْکَبَائِرُ۔ (طبرانی 8740)",,,7726,,
7727,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا ہِشَامُ بْنُ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ حُمْرَانَ بْنِ أَبَانَ ، عَنْ عُثْمَانَ بْنِ عَفَّانَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَا مِنْ رَجُلٍ یَتَوَضَّأُ فَیُحْسِنُ الْوُضُوئَ ، ثُمَّ یُصَلِّی إِلاَّ غُفِرَ لَہُ مَا بَیْنَہُ وَبَیْنَ الصَّلاَۃ الأُخْرَی۔ (مسلم 206)",,,7727,,
7728,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، أَخْبَرَنَا عَوْفٌ وَالْجُرَیرِیُّ ، عَنْ قَسَامَۃَ بْنِ زُہَیْرٍ ، عَنْ أَبِی مُوسَی ، قَالَ : مَثَلُ الصَّلَوَاتِ الْخَمْسِ مَثَلُ نَہْرٍ جَارٍ عَلَی بَابِ أَحَدِکُمْ یَغْتَسِلُ مِنْہُ کُلَّ یَوْمٍ خَمْسَ مَرَّاتٍ ، فَمَاذَا یُبْقِینَ بَعْدُ عَلَیْہِ مِنْ دَرَنِہِ۔",,,7728,,
7729,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ یَعْلَی بْنِ عَطَائٍ ، قَالَ : سَمِعْتُ إبْرَاہِیمَ بْنَ یُحَنَّسَ ، عَنْ أَبِی الدَّرْدَائِ ، قَالَ : مَثَلُ الصَّلَوَاتِ الْخَمْسِ مَثَلُ رَجُلٍ عَلَی بَابِہِ نَہْرٌ یَغْتَسِلُ مِنْہُ کُلَّ یَوْمٍ خَمْسَ مَرَّاتٍ فَمَاذَا یُبْقِی ذَلِکَ مِنْ دَرَنِہِ۔",,,7729,,
7730,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا مِسْعَرٌ ، عَنْ أَبِی صَخْرَۃَ جَامِعِ بْنِ شَدَّادٍ ، قَالَ : سَمِعْتُ حُمْرَانَ بْنَ أَبَانَ مَوْلَی عُثْمَانَ یَقُولُ : کُنْتُ أَضَعُ لِعُثْمَانَ طَہُورَہُ فَمَا أَتَی عَلَیْہِ یَوْمٌ إِلاَّ وَہُوَ یُفِیضُ مِنْہُ عَلَیْہِ نُطْفَۃً مِنْ مَائٍ ، فَقَالَ عُثْمَانُ : حدَّثَنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عِنْدَ انْصِرَافِنَا مِنْ صَلاَتِنَا ہَذِہِ ، فَقَالَ مِسْعَرٌ : أُرَاہُ قَالَ : الْعَصْرَ ، فَقَالَ : مَا أَدْرِی أُحَدِّثُکُمْ ، أَوْ أَسْکُتُ ، قَالَ : قُلْنَا یَا رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إِنْ کَانَ خَیْرًا فَحَدِّثْنَا ، وَإِنْ کَانَ غَیْرَ ذَلِکَ فَاللَّہُ وَرَسُولُہُ أَعْلَمُ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَا مِنْ رَجُلٍ یَتَوَضَّأُ فَیُحْسِنُ الْوُضُوئَ ، ثُمَّ یُصَلِّی إِلاَّ غُفِرَ لَہُ مَا بَیْنَہُ وَبَیْنَ الصَّلاَۃ الأُخْرَی۔",,,7730,,
7731,"حَدَّثَنَا وَکِیعٌ، حَدَّثَنَا الأَوْزَاعِیُّ، عَنْ عَبْدِالْوَاحِدِ بْنِ قَیْسٍ، عَنْ أَبِی ہُرَیْرَۃَ قَالَ: تَکْفِیرُ کُلَّ لِحَائٍ رَکْعَتَانِ۔",,,7731,,
7732,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی سُفْیَانَ ، عَنْ جَابِرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَثَلُ الصَّلَوَاتِ الْخَمْسِ کَمَثَلِ نَہْرٍ جَارٍ غَمْرٍ عَلَی بَابِ أَحَدِکُمْ یَغْتَسِلُ مِنْہُ کُلَّ یَوْمٍ خَمْسَ مَرَّاتٍ، قَالَ : فَقَالَ الْحَسَنُ : فَمَا یُبْقِی ذَلِکَ مِنَ الدَّرَنِ ؟۔ (مسلم 284۔ بیہقی 63)",,,7732,,
7733,"حَدَّثَنَا مُحَمَّدُ بْنُ عُبَیْدٍ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّمَا مَثَلُ الصَّلَوَاتِ الْخَمْسِ کَمَثَلِ نَہْرٍ جَارٍ عَلَی بَابِ أَحَدِکُمْ یَغْتَسِلُ مِنْہُ کُلَّ یَوْمٍ خَمْسَ مَرَّاتٍ ، فَمَا یُبْقِی مِنْ دَرَنِہِ؟۔ (احمد 2/441)",,,7733,,
7734,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا مِسْعَرٌ ، وَشُعْبَۃُ ، عَنْ سَعِیدِ بْنِ أَبِی بُرْدَۃَ ، عَنْ أَبِیہِ ، قَالَ : سَمِعْتُ ابْنَ عُمَرَ یَقُولُ: مَا صَلَّیْتُ صَلاَۃً إِلاَّ وَأَنَا أَرْجُو أَنْ تَکُونَ کَفَّارَۃً لِمَا أَمَامَہَا۔",,,7734,,
7735,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا مِسْعَرٌ ، عَنِ الْقَاسِمِ بْنِ عَبْدِ الرَّحْمَنِ ، قَالَ : قَالَ عَبْدُ اللہِ : یَحْتَرِقُونَ فَإِذَا صَلَّوُا الظُّہْرَ غَسَلَتْ ، ثُمَّ یَحْتَرِقُونَ فَإِذَا صَلَّوُا الْعَصْرَ غَسَلَتْ ، ثُمَّ یَحْتَرِقُونَ فَإِذَا صَلَّوُا الْمَغْرِبَ غَسَلَتْ حَتَّی ذَکَرَ الصَّلَوَاتِ کُلَّہُنَّ۔",,,7735,,
7736,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا الْمَسْعُودِیُّ ، عَنِ الْقَاسِمِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ لَقِیطِ بْنِ قَبِیصَۃَ الْجَعْفَرِیِّ رَجُلٍ مِنْ أَصْحَابِ عَبْدِ اللہِ قَالَ : کَانَ عَبْدُ اللہِ فَذَکَرَ مِثْلَہُ۔",,,7736,,
7737,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا الأَعْمَش ، عَنْ أَبِی سُفْیَانَ ، عَنْ عُبَیْدِ بْنِ عُمَیْرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَثَلُ الصَّلَوَاتِ الْخَمْسِ کَمَثَلِ نَہْرٍ جَارٍ عَلَی بَابِ أَحَدِکُمْ یَغْتَسِلُ مِنْہُ کُلَّ یَوْمٍ خَمْسَ مَرَّاتٍ، فَمَاذَا یُبْقِینَ مِنَ الدَّرَنِ؟۔",,,7737,,
7738,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ، حَدَّثَنَا ہَانِیئُ بْنُ عُثْمَانَ یُحَدِّثُ عَنْ أُمِّہِ حُمَیْضَۃَ ابْنَۃِ یَاسِرٍ، عَنْ جَدَّتِہَا یُسَیرَۃَ، وَکَانَتْ إحْدَی الْمُہَاجِرَاتِ ، قَالَتْ : قَالَ لَہَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : عَلَیْکُنَّ بَِالتَّہْلِیلِ والتَّسْبِیحِ وَالتَّکْبِیرِ وَاعْقِدْنَ بِالأَنَامِلِ ، فَإِنَّہُنَّ یَأْتِینَ یَوْمَ الْقِیَامَۃِ مَسْئُولاَتٍ مُسْتَنْطَقَاتٍ ، وَلاَ تَغْفُلْنَ فَتَنْسَیْنَ الرَّحْمَۃَ۔ (ترمذی 3583۔ احمد 6/370)",,,7738,,
7739,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ الْقَطَّانُ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی تَمِیمَۃَ ، عَنِ امْرَأَۃٍ مِنْ بَنِی کُلَیْبٍ ، قَالَتْ : رَأَتْنِی عَائِشَۃُ أُسَبِّحُ بِتَسَابِیحَ مَعِی ، فَقَالَتْ : أَیْنَ الشَّوَاہِدُ ؟ تَعْنِی الأَصَابِعَ۔",,,7739,,
7740,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سُفْیَانَ ، عَنْ حَکِیمِ بْنِ الدَّیْلَمِ ، عَنْ مَوْلاَۃٍ لِسَعْدٍ : أَنَّ سَعْدًا کَانَ یُسَبِّحُ بِالْحَصَی وَالنَّوَی۔",,,7740,,
7741,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ حَکِیمِ بْنِ الدَّیْلَمِ ، عَنْ مَوْلاَۃٍ لِسَعْدٍ : أَنَّ سَعْدًا کَانَ یُسَبِّحُ بِالْحَصَی وَالنَّوَی۔",,,7741,,
7742,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عُبَیْدِ اللہِ بْنِ الأَخْنَسِ ، قَالَ : حدَّثَنِی مَوْلًی لأَبِی سَعِیدٍ ، عَنْ أَبِی سَعِیدٍ : أَنَّہُ کَانَ یَأْخُذُ ثَلاَثَ حَصَیَاتٍ فَیَضَعُہُنَّ عَلَی فَخِذِہِ فَیُسَبِّحُ وَیَضَعُ وَاحِدَۃً ، ثُمَّ یُسَبِّحُ وَیَضَعُ أُخْرَی ، ثُمَّ یُسَبِّحُ وَیَضَعُ أُخْرَی ، ثُمَّ یُرْفَعَنْ وَیَصنَعُ مِثْلَ ذَلِکَ ، وَقَالَ : لاَ تُسَبِّحُوا بِالتَّسْبِیحِ صَفِیرًا۔",,,7742,,
7743,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ الْجُرَیرِیِّ ، عَنْ أَبِی نَضْرَۃَ ، عَنْ رَجُلٍ مِنَ الطَّفَاوَۃ ، قَالَ : نَزَلْتُ عَلَی أَبِی ہُرَیْرَۃَ وَمَعَہُ کِیسٌ فِیہِ حَصًی ، أَوْ نَوًی فَیَقُولُ سُبْحَانَ اللہِ سُبْحَانَ اللہِ حَتَّی إذَا نَفِدَ مَا فِی الْکِیسِ أَلْقَاہُ إلَی جَارِیَۃٍ سَوْدَائَ فَجَمَعَتْہُ ، ثُمَّ دَفَعَتْہُ إلَیْہِ۔",,,7743,,
7744,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِالرَّحْمَنِ، عَنْ حَسَنِ عن مُوسَی الْقَارِیِٔ، عَنْ طَلْحَۃَ بْنِ عَبْدِ اللہِ، عَنْ زَاذَانَ، قَالَ: أَخَذْتُ مِنْ أُمِّ یَعْفُورَ تَسَابِیحَ لَہَا ، فَلَمَّا أَتَیْتُ عَلِیًّا عَلَّمَنِی، قَالَ: یَا أَبَا عُمَرَ اُرْدُدْ عَلَی أُمِّ یَعْفُورَ تَسَابِیحَہا۔",,,7744,,
7745,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ أَبِیہِ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو قَالَ : رَأَیْتُُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَعْقِدُہُ بِیَدِہِ ، یَعْنِی التَّسْبِیحَ۔ (ترمذی 3411۔ ابوداؤد 1427)",,,7745,,
7746,حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ یُسَبِّحَ الرَّجُلُ وَیَعْقِدَ تَسْبِیحَہُ۔,,,7746,,
7747,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ مُخْتَارِ بْنِ سَعْدٍ ، قَالَ: رَأَیْتُُ مُحَمَّدَ بْنَ عَلِیٍّ یُسَبِّحُ فِی النَّافِلَۃِ وَیَعْقِدُ بِیَدِہِ۔",,,7747,,
7748,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ إبْرَاہِیمَ مُؤَذِّنِ بَنِی حَنِیفَۃَ ، قَالَ : رَأَیْتُ مَاہَانَ الْحَنَفِیَّ وَأَمَرَ بِہِ الْحَجَّاجُ أَنْ یُصْلَبَ عَلَی بَابِہِ فَنَظَرْتُ إلَیْہِ وَإِنَّہُ عَلَی الْخَشَبَۃِ وَإِنَّہُ یُسَبِّحُ وَیُکَبِّرُ وَیُہَلِّلُ وَیَحْمَدُ اللَّہَ حَتَّی بَلَغَ تسْعَۃً وَعِشْرِینَ یَعْقِدُ بِیَدِہِ ، فَطُعِنَ وَہُوَ عَلَی تِلْکَ الْحَالِ ، فَلَقَدْ رَأَیْتُہُ بَعْدَ شَہْرٍ مَعْقُودًا تِسْعًا وَعِشْرِینَ بِیَدِہِ وَکَانَ یُرَی عِنْدَہُ ضَوْئٌ بِاللَّیْلِ۔",,,7748,,
7749,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ عَبْدُ اللہِ یَکْرَہُ الْعَدَدَ وَیَقُولُ : أَیُمَنُّ عَلَی اللہِ حَسَنَاتِہِ؟۔",,,7749,,
7750,"حَدَّثَنَا أَزْہَرُ السَّمَّانُ ، عَنِ ابْنِ عَوْنٍ ، عَنْ عُقْبَۃَ ، قَالَ : سَأَلْتُ ابْنَ عُمَرَ عَنِ الرَّجُلِ یَذْکُرُ اللَّہَ وَیَعْقِدُ ؟ فَقَالَ : یُحَاسِبُونَ اللَّہَ؟۔",,,7750,,
7751,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ وِقَائٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : رَأَی عُمَرُ بْنُ الْخَطَّابِ رَجُلاً یُسَبِّحُ بِتَسَابِیحَ مَعَہُ ، فَقَالَ عُمَرُ : إنَّمَا یُجْزِئہ مِنْ ذَلِکَ أَنْ یَقُولَ : سُبْحَانَ اللہِ مِلْئَ السَّمَاوَاتِ وَالأَرْضِ وَمِلْئَ مَا شَائَ مِنْ شَیْئٍ بَعْدُ ، وَیَقُولَ : الْحَمْدُ لِلَّہِ مِلْئَ السَّمَاوَاتِ وَالأَرْضِ وَمِلْئَ مَا شَائَ مِنْ شَیْئٍ بَعْدُ ، وَیَقُولَ : اللَّہُ أَکْبَرُ مِلْئَ السَّمَاوَاتِ وَالأَرْضِ وَمِلْئَ مَا شَائَ مِنْ شَیْئٍ بَعْدُ۔",,,7751,,
7752,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنٍ ، عَنْ إبْرَاہِیمَ بْنِ الْمُہَاجِرِ ، عَنْ إبْرَاہِیمَ : أَنَّہُ کَانَ یَنْہَی ابْنَتَہُ أَنْ تُعِینَ النِّسَائَ عَلَی فَتْلِ خُیُوطِ التَّسْبِیحِ الَّتِی یُسَبَّحُ بِہَا۔",,,7752,,
7753,"حَدَّثَنَا أَبُو مُحَمَّدٍ عَبْدُ اللہِ بْنُ یُونُسَ ، قَالَ : حدَّثَنَا بَقِیُّ بْنُ مَخْلَدٍ رحمہ اللہ قَالَ : حَدَّثَنَا أَبُو بَکْرٍ قَالَ :\n\n حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ الْقَطَّانُ ، عَنْ مُحَمَّدِ بْنِ یُوسُفَ ، أَنَّ السَّائِبَ أَخْبَرَہُ : أَنَّ عُمَرَ جَمَعَ النَّاسَ عَلَی أُبَیٍّ وَتَمِیمٍ فَکَانَا یُصَلِّیَانِ إحْدَی عَشْرَۃَ رَکْعَۃً ، یَقْرَآنِ بِالْمِئِینَ ، یَعْنِی فِی رَمَضَانَ۔",,,7753,,
7754,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنْ أَبِی عُثْمَانَ ، قَالَ : دَعَا عُمَرُ الْقُرَّائَ فِی رَمَضَانَ فَأَمَرَ أَسْرَعَہُمْ قِرَائَۃً أَنْ یَقْرَأَ ثَلاَثِینَ آیَۃً وَالْوَسَطَ خَمْسۃ وَعِشْرِینَ آیَۃً وَالْبَطِیئَ عِشْرِینَ آیَۃً۔",,,7754,,
7755,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَلِیِّ بْنِ الأَقْمَرِ : أَنَّ مَسْرُوقًا قَرَأَ فِی رَکْعَۃٍ مِنَ الْقِیَامِ بِالْعَنْکَبُوتِ۔",,,7755,,
7756,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ نَافِعِ بْنِ عُمَرَ ، قَالَ : سَمِعْتُ ابْنَ أَبِی مُلَیْکَۃَ یَقُولُ : کُنْتُ أَقُومُ بِالنَّاسِ فِی شَہْرِ رَمَضَانَ فَأَقْرَأُ فِی الرَّکْعَۃِ : {الْحَمْدُ لِلَّہِ فَاطِرِ} وَنَحْوَہَا وَمَا یَبْلُغُنِی ، أَنَّ أَحَدًا یَسْتَقِلُّ ذَلِکَ۔",,,7756,,
7757,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ، عَنْ وِقَائٍ، قَالَ: کَانَ سَعِیدُ بْنُ جُبَیْرٍ یَقْرَأُ فِی کُلِّ رَکْعَۃٍ بِخَمْسۃ وَعِشْرِینَ آیَۃً۔",,,7757,,
7758,"حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنِ الْعُمَرِیِّ ، عَنْ أَبِیہِ ، قَالَ : کَانَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ یَأْمُرُ الَّذِینَ یَقْرَؤُونَ فِی رَمَضَانَ ، یَقْرَؤُونَ فِی کُلِّ رَکْعَۃٍ بِعَشْرِ آیَاتٍ عَشْرِ آیَاتٍ۔",,,7758,,
7759,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ عِمْرَانَ بْنِ حُدَیْرٍ قَالَ : کَانَ أَبُو مِجْلَزٍ یَقُومُ بِالْحَیِّ فِی رَمَضَانَ یَخْتِمُ فِی کُلِّ سَبْعٍ۔",,,7759,,
7760,حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عِرَاکِ بْنِ مَالِکٍ ، عَنْ أَبِیہِ ، قَالَ أَدْرَکْت النَّاسَ فِی شَہْرِ رَمَضَانَ تُرْبَط لَہُمُ الْحِبَالَ یَسْتَمْسِکُونَ بِہَا مِنْ طُولِ الْقِیَامِ۔,,,7760,,
7761,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ قَالَ : مَنْ أَمَّ النَّاسَ فِی رَمَضَانَ فَلْیَأْخُذْ بِہِمُ الْیُسْرَ ، فَإِنْ کَانَ بَطِیئَ الْقِرَائَۃِ فَلْیَخْتِمِ الْقُرْآنَ خَتْمَۃً ، وَإِنْ کَانَ قِرَائَۃً بَیْنَ ذَلِکَ فَخَتْمَۃ وَنِصْف ، فَإِنْ کَانَ سَرِیعَ الْقِرَائَۃِ فَمَرَّتَیْنِ۔",,,7761,,
7762,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ اللہِ بْنِ قَیْسٍ ، عَنْ شُتَیْرِ بْنِ شَکَلٍ : أَنَّہُ کَانَ یُصَلِّی فِی رَمَضَانَ عِشْرِینَ رَکْعَۃً وَالْوِتْرَ۔",,,7762,,
7763,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، عَنْ عَمْرِو بْنِ قَیْسٍ ، عَنِ أَبِی الْحَسْنَائِ : أَنَّ عَلِیًّا أَمَرَ رَجُلاً یُصَلِّی بِہِمْ فِی رَمَضَانَ عِشْرِینَ رَکْعَۃً۔",,,7763,,
7764,حَدَّثَنَا وَکِیعٌ ، عَنْ مَالِکِ بْنِ أَنَسٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، أَنَّ عُمَرَ بْنَ الْخَطَّابِ أَمَرَ رَجُلاً یُصَلِّی بِہِمْ عِشْرِینَ رَکْعَۃً۔,,,7764,,
7765,"حَدَّثَنَا وَکِیعٌ ، عَنْ نَافِعِ بْنِ عُمَرَ ، قَالَ : کَانَ ابْنُ أَبِی مُلَیْکَۃَ یُصَلِّی بِنَا فِی رَمَضَانَ عِشْرِینَ رَکْعَۃً وَیَقْرَأُ بِحَمْدِ الْمَلاَئِکَۃِ فِی رَکْعَۃٍ۔",,,7765,,
7766,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنٍ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ رُفَیْعٍ ، قَالَ : کَانَ أُبَیّ بْنُ کَعْبٍ یُصَلِّی بِالنَّاسِ فِی رَمَضَانَ بِالْمَدِینَۃِ عِشْرِینَ رَکْعَۃً وَیُوتِرُ بِثَلاَثٍ۔",,,7766,,
7767,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ : أَنَّہُ کَانَ یَؤُمُّ النَّاسَ فِی رَمَضَانَ بِاللَّیْلِ بِعِشْرِینَ رَکْعَۃً وَیُوتِرُ بِثَلاَثٍ وَیَقْنُتُ قَبْلَ الرُّکُوعِ۔",,,7767,,
7768,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ خَلَفٍ ، عَنْ رَبِیعٍ وَأَثْنَی عَلَیْہِ خَیْرًا ، عَنْ أَبِی الْبَخْتَرِیِّ : أَنَّہُ کَانَ یُصَلِّی خَمْسَ تَرْوِیحَاتٍ فِی رَمَضَانَ وَیُوتِرُ بِثَلاَثٍ۔",,,7768,,
7769,"حَدَّثَنَا حَفْصٌ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، قَالَ : کَانَ عَبْدُ الرَّحْمَنِ بْنُ الأَسْوَدِ یُصَلِّی بِنَا فِی رَمَضَانَ أَرْبَعِینَ رَکْعَۃً وَیُوتِرُ بِسَبْعٍ۔",,,7769,,
7770,"حَدَّثَنَا ابْنُ نُمَیْرٍ، عَنْ عَبْدِالْمَلِکِ، عَنْ عَطَائٍ، قَالَ: أَدْرَکْت النَّاسَ وَہُمْ یُصَلُّونَ ثَلاَثًا وَعِشْرِینَ رَکْعَۃً بِالْوِتْرِ۔",,,7770,,
7771,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ دَاوُدَ بْنِ قَیْسٍ ، قَالَ : أَدْرَکْتُ النَّاسَ بِالْمَدِینَۃِ فِی زَمَنِ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ وَأَبَانَ بْنِ عُثْمَانَ یُصَلُّونَ سِتَّۃ وَثَلاَثِینَ رَکْعَۃً وَیُوتِرُونَ بِثَلاَثٍ۔",,,7771,,
7772,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ سَعِیدِ بْنِ عُبَیْدٍ : أَنَّ عَلِیَّ بْنَ رَبِیعَۃَ کَانَ یُصَلِّی بِہِمْ فِی رَمَضَانَ خَمْسَ تَرْوِیحَاتٍ وَیُوتِرُ بِثَلاَثٍ۔",,,7772,,
7773,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ وِقَائٍ ، قَالَ : کَانَ سَعِیدُ بْنُ جُبَیْرٍ یَؤُمُّنَا فِی رَمَضَانَ فَیُصَلِّی بِنَا عِشْرِینَ لَیْلَۃً سِتَّ تَرْوِیحَاتٍ ، فَإِذَا کَانَ الْعَشْرُ الأَخَرُ اعْتَکَفَ فِی الْمَسْجِدِ وَصَلَّی بِنَا سَبْعَ تَرْوِیحَاتٍ۔",,,7773,,
7774,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا إبْرَاہِیمُ بْنُ عُثْمَانَ ، عَنِ الْحَکَمِ ، عَنْ مِقْسَمٍ ، عَنِ ابْنِ عَبَّاسٍ : أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُصَلِّی فِی رَمَضَانَ عِشْرِینَ رَکْعَۃً وَالْوِتْرَ۔ (عبد بن حمید 653)",,,7774,,
7775,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنِ الأَعْمَشِ ، عَنْ زَیْدِ بْنِ وَہْبٍ قَالَ : کَانَ عَبْدُ اللہِ یَؤُمُّنَا فِی رَمَضَانَ۔",,,7775,,
7776,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ قَالَ : سَأَلْتُ عَطَائً ہَلْ کَانَ عَلِیٌّ یُصَلِّی بِہِمْ فِی رَمَضَانَ ؟ قَالَ : کَانَ خِیَارُ أَصْحَابِ عَلِیٍّ زَاذَانُ ، وَأَبُو الْبَخْتَرِیِّ وَغَیْرُہُمْ یَدْعُونَ أَہْلِیہِمْ وَیَؤُمُّونَ فِی الْمَسْجِدِ فِی رَمَضَانَ۔",,,7776,,
7777,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ دَاوُدَ بْنِ أَبِی ہِنْدٍ ، عَنِ الْوَلِیدِ بْنِ عَبْدِ الرَّحْمَنِ الْجُرَشِیِّ ، عَنْ جُبَیْرِ بْنِ نُفَیْرٍ الْحَضْرَمِیِّ ، عَنْ أَبِی ذَرٍّ ، قَالَ : صُمْنَا مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَمَضَانَ فَلَمْ یُصَلِّ بِنَا حَتَّی بَقِیَ سَبْعٌ مِنَ الشَّہْرِ ، فَقَامَ بِنَا حَتَّی ذَہَبَ ثُلُثُ اللَّیْلِ ، ثُمَّ لَمْ یَقُمْ بِنَا فِی السَّادِسَۃِ ، ثُمَّ قَامَ بِنَا فِی الخَامِسَۃِ حَتَّی ذَہَبَ شَطْرُ اللَّیْلِ ، فَقُلْنَا : یَا رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لَوْ قُمْتَ بِنَا بَقِیَّۃَ لَیْلَتِنَا ہَذِہِ ، فَقَالَ : إنَّہُ مَنْ قَامَ مَعَ الإِمَامِ حَتَّی یَنْصَرِفَ کُتِبَ لَہُ قِیَامُ لَیْلَۃٍ۔ قَالَ : ثُمَّ صَلَّی بِنَا حَتَّی بَقِیَ ثَلاَثٌ مِنَ الشَّہْرِ ، ثُمَّ صَلَّی بِنَا وَجَمَعَ أَہْلَہُ وَنِسَائَہُ ، قَالَ : فَقَامَ حَتَّی تَخَوَّفْنَا أَنْ یَفُوتَنَا الْفَلاَحُ ، قَالَ : قُلْتُ : وَمَا الْفَلاَحُ ؟ قَالَ : السَّحُورُ۔ (ابوداؤد 1730۔ احمد 5/163)",,,7777,,
7778,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ مُعَاوِیَۃَ بْنِ صَالِحٍ ، قَالَ : حدَّثَنِی نُعَیْمُ بْنُ زِیَادٍ أَبُو طَلْحَۃَ الأَنْمَارِیُّ ، قَالَ : سَمِعْتُ النُّعْمَانَ بْنَ بَشِیرٍ عَلَی مِنْبَرِ حِمْصَ یَقُولُ : قُمْنَا مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لَیْلَۃَ ثَلاَثٍ وَعِشْرِینَ إلَی ثُلُثِ اللَّیْلِ الأَوَّلِ ، وَقُمْنَا مَعَہُ لَیْلَۃَ خَمْسٍ وَعِشْرِینَ إلَی نِصْفِ اللَّیْلِ ، وَقُمْنَا مَعَہُ لَیْلَۃَ سَابِعَۃٍ وَعِشْرِینَ حَتَّی ظَنَنَّا أَنَّہُ یَفُوتُنَا الْفَلاَحُ وَکُنَّا نَعُدُّہُ السَّحُورَ۔ (احمد 4/272۔ ابن خزیمۃ 2204)",,,7778,,
7779,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الْعَلاَئِ بْنِ الْمُسَیَّبِ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ طَلْحَۃَ بْنِ یَزِیدَ ، عَنْ حُذَیْفَۃَ ، قَالَ : قَامَ بِنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ذَاتَ لَیْلَۃٍ مِنْ رَمَضَانَ فِی حُجْرَۃٍ مِنْ جَرِیدِ النَّخْلِ ، ثُمَّ صَبَّ عَلَیْہِ دَلْوًا مِنْ مَائٍ ، ثُمَّ قَالَ : اللَّہُ أَکْبَرُ ذُو الْمَلَکُوتِ وَالْجَبَرُوتِ وَالْکِبْرِیَائِ وَالْعَظَمَۃِ۔",,,7779,,
7780,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ : أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُرَغِّبُ فِی قِیَامِ رَمَضَانَ مِنْ غَیْرِ عَزِیمَۃٍ۔ (ترمذی 808۔ ابوداؤد 1366)",,,7780,,
7781,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ خَالِدٍ ، عَنْ عِکْرِمَۃَ : أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَامَ فِی رَمَضَانَ فِی بَعْضِ حُجَرِہِ یُصَلِّی فَائْتَمُّوا بِصَوْتِہِ ، فَلَمَّا عَلِمَ بِہِمْ خَفَضَ صَوْتَہُ۔",,,7781,,
7782,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ زَیْدِ بْنِ وَہْبٍ ، قَالَ : کَانَ عَبْدُ اللہِ یَؤُمُّنَا فِی رَمَضَانَ وَیَنْصَرِفُ وَعَلَیْہِ لَیْلٌ۔",,,7782,,
7783,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ، عَنْ عَلِیٍّ : أَنَّہُ قَامَ بِہِمْ فِی رَمَضَانَ۔",,,7783,,
7784,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنِ الْوَلِیدِ بْنِ عَلِیٍّ ، عَنْ أَبِیہِ ، قَالَ : کَانَ سُوَیْد بْنُ غَفَلَۃَ یَؤُمُّنَا فَیَقُومُ بِنَا فِی شَہْرِ رَمَضَانَ وَہُوَ ابْنُ عِشْرِینَ وَمِئَۃِ سَنَۃٍ۔",,,7784,,
7785,"حَدَّثَنَا شَبَابَۃُ ، قَالَ : حدَّثَنَا لَیْثُ بْنُ سَعْدٍ ، عَنِ ابْنِ شِہَابٍ ، عَنْ عُرْوَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَبْدٍ الْقَارِیِٔ ، قَالَ : خَرَجَ عُمَرُ بْنُ الْخَطَّابِ فِی شَہْرِ رَمَضَانَ وَالنَّاسُ یُصَلُّونَ قِطَعًا ، فَقَالَ : لَوْ جَمَعْنَا ہَؤُلاَئِ عَلَی قَارِیٍٔ وَاحِدٍ لَکَانَ خَیْرًا فَجَمَعَہُمْ عَلَی أُبَیِّ بْنِ کَعْبٍ۔",,,7785,,
7786,"حَدَّثَنَا وَکِیعٌ ، عَنْ مَالِکٍ ، عَنِ الزُّہْرِیِّ ، عَنْ أَبِی سَلَمَۃَ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُرَغِّبُ فِی قِیَامِ رَمَضَانَ مِنْ غَیْرِ أَنْ یَأْمُرَ فِیہِ بِعَزِیمَۃٍ۔",,,7786,,
7787,"حَدَّثَنَا وَکِیعٌ ، عَنْ نَصْرِ بْنِ عَلِیٍّ ، عَنْ نَضْرِ بْنِ شَیْبَانَ قَالَ : سَأَلْتُ أَبَا سَلَمَۃَ بْنَ عَبْدِ الرَّحْمَنِ ، فَذَکَر عَنْ أَبِیہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ اللَّہَ افْتَرَضَ عَلَیْکُمْ صِیَامَہُ وَسَنَنْتُ لَکُمْ قِیَامَہُ فَمَنْ صَامَہُ إیمَانًا وَاحْتِسَابًا غُفِرَ لَہُ مَا تَقَدَّمَ مِنْ ذَنْبِہِ۔ (احمد 1/194۔ طیالسی 224)",,,7787,,
7788,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ہِشَامُ بْنُ عُرْوَۃَ ، عَنْ أَبِیہِ : أَنَّ عُمَرَ بْنَ الْخَطَّابِ أَمَرَ أُبَیًّا أَنْ یُصَلِّیَ بِالنَّاسِ فِی شَہْرِ رَمَضَانَ۔",,,7788,,
7789,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ إبْرَاہِیمَ بْنِ مَیْسَرَۃَ ، عَنْ طَاوُوسٍ ، قَالَ : سَمِعْتُ ابْنَ عَبَّاسٍ یَقُولُ : دَعَانِی عُمَرُ لأَتَغَدَّی عِنْدَہُ ، قَالَ أَبُو بَکْرٍ : یَعْنِی السَّحُورَ فِی رَمَضَانَ فَسَمِعَ ہَیْعَۃَ النَّاسِ حِینَ خَرَجُوا مِنَ الْمَسْجِدِ ، قَالَ : مَا ہِیَ ؟ قَالَ : ہَیْعَۃُ النَّاسِ حَیْثُ خَرَجُوا مِنَ الْمَسْجِدِ ، قَالَ : مَا بَقِیَ مِنَ اللَّیْلِ خَیْرٌ مِمَّا ذَہَبَ مِنْہُ۔",,,7789,,
7790,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عُرْوَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَبْدِ الْقَارِیّ قَالَ : قَالَ عُمَرُ : فِی السَّاعَۃِ الَّتِی یَنَامُونَ فِیہَا أَعْجَبُ إلَیَّ مِنَ السَّاعَۃِ الَّتِی یَقُومُونَ فِیہَا۔",,,7790,,
7791,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ أَبِی یَزِیدَ الْمَدِینِیِّ ، قَالَ : قَالَ ابْنُ عَبَّاسٍ فِی قِیَامِ رَمَضَانَ : مَا یَتْرُکُونَ مِنْہُ أَفْضَلُ مِمَّا یَقُومُونَ فِیہِ۔",,,7791,,
7792,"حَدَّثَنَا وَکِیعٌ، عَنْ أَبِی الْمُعْتَمِرِ، قَالَ: سَأَلْتُ الْحَسَنَ أَیَّ سَاعَۃٍ أَقُومُ بِہِمْ؟ قَالَ: اُنْظُرْ أَرْفَقَ ذَلِکَ بِالْقَوْمِ۔",,,7792,,
7793,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنِ الْحَکَمِ قَالَ : کَانُوا یَنَامُونَ نَوْمَۃً قَبْلَ الْقِیَامِ فِی شَہْرِ رَمَضَانَ۔",,,7793,,
7794,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا أُسَامَۃُ بْنُ زَیْدٍ ، عَنْ مُحَمَّدِ بْنِ یُوسُفَ الأَعْرَجِ ، عَنِ السَّائِبِ قَالَ : قَالَ عُمَرُ: إنَّکُمْ تَدَعُونَ أَفْضَلَ اللَّیْلِ آخِرَہُ۔",,,7794,,
7795,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مِسْعَرٌ ، عَنْ حَبِیبٍ قَالَ : قَالَ رَجُلٌ : ذَہَبَ اللَّیْلُ ، فَقَالَ : عُمَرُ مَا بَقِیَ مِنَ اللَّیْلِ خَیْرٌ مِمَّا ذَہَبَ۔",,,7795,,
7796,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا عُبَیْدُ اللہِ بْنُ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ لاَ یَقُومُ مَعَ النَّاسِ فِی شَہْرِ رَمَضَانَ ، قَالَ : وَکَانَ سَالِمٌ وَالْقَاسِمُ لاَ یَقُومَانَ مَعَ النَّاسِ۔",,,7796,,
7797,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، قَالَ : سَأَلَ رَجُلٌ ابْنَ عُمَرَ أَقُومُ خَلْفَ الإِمَام فِی شَہْرِ رَمَضَانَ ، فَقَالَ : تُنْصِتُ کَأَنَّک حِمَارٌ۔",,,7797,,
7798,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی حَمْزَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : لَوْ لَمْ یَکُنْ مَعِی إِلاَّ سُورَۃٌ أَوْ سُورَتَانِ لأَنْ أُرَدِّدَہُمَا أَحَبُّ إلَیَّ مِنْ أَنْ أَقُومَ خَلْفَ الإِمَام فِی شَہْرِ رَمَضَانَ۔",,,7798,,
7799,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَعْمَشِ ، قَالَ : کَانَ إبْرَاہِیمُ یَؤُمُّہُمْ فِی الْمَکْتُوبَۃِ ، وَلاَ یَؤُمُّہُمْ فِی صَلاَۃِ رَمَضَانَ وَعَلْقَمَۃُ وَالأَسْوَدُ۔",,,7799,,
7800,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ الأَعْمَشِ ، قَالَ : کَانَ إبْرَاہِیمُ وَعَلْقَمَۃُ لاَ یَقُومُانَ مَعَ النَّاسِ فِی رَمَضَانَ۔",,,7800,,
7801,"حَدَّثَنَا قَطَنُ بْنُ عَبْدِ اللہِ أَبُو مُرَیٍّ ، عَنْ نَصْرٍ الْمُعَلِّمِ ، قَالَ : حدَّثَنِی عُمَرُ بْنُ عُثْمَانَ ، قَالَ : سَأَلْتُ الْحَسَنَ فَقُلْت : یَا أَبَا سَعِیدٍ یَجِیئُ رَمَضَانُ ، أَوْ یَحْضُرُ رَمَضَانُ ، فَیَقُومُ النَّاسُ فِی الْمَسَاجِدِ ، فَمَا تَرَی أَقُومُ مَعَ النَّاسِ أَوْ أُصَلِّی أَنَا لِنَفْسِی ؟ قَالَ : تَکُونُ أَنْتَ تَفُوہُ الْقُرْآنَ أَحَبُّ إلَیَّ مِنْ أَنْ یُفَاہَ عَلَیْک بِہِ۔",,,7801,,
7802,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ مُحَمَّدِ بْنِ عَبَّادٍ ، عَنْ عَبْدِ اللہِ بْنِ السَّائِبِ ، قَالَ : کُنْتُ أُصَلِّی بِالنَّاسِ فِی رَمَضَانَ فَبَیْنَا أَنَا أُصَلِّی إذْ سَمِعْت تَکْبِیرَ عُمَرَ عَلَی بَابِ الْمَسْجِدِ قَدِمَ مُعْتَمِرًا فَدَخَلَ فَصَلَّی خَلْفِی۔",,,7802,,
7803,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ : أَنَّہُ کَانَ یُصَلِّی مَعَہُمْ فِی شَہْرِ رَمَضَانَ یُصَلِّی لِنَفْسِہِ وَیَرْکَعُ وَیَسْجُدُ مَعَہُمْ۔",,,7803,,
7804,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ، عَنِ ابْنِ عَوْنٍ، عَنْ مُحَمَّدٍ: أَنَّہُ کَانَ یَخْتَارُ الْقِیَامَ مَعَ النَّاسِ فِی شَہْرِ رَمَضَانَ۔",,,7804,,
7805,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ الْمُتَہَجِّدُونَ یُصَلُّونَ فِی جَانِبِ الْمَسْجِدِ وَالإِمَام یُصَلِّی بِالنَّاسِ فِی شَہْرِ رَمَضَانَ۔",,,7805,,
7806,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، قَالَ : رَأَیْتُُ عَبْدَ اللہِ بْنَ أَبِی مُلَیْکَۃَ یُصَلِّی بِالنَّاسِ فِی رَمَضَانَ خَلْفَ الْمَقَامِ بِمَنْ صَلَّی خَلْفَہُ وَالنَّاسُ بَعْدُ فِی سَائِرِ الْمَسْجِدِ مِنْ بَیْنِ طَائِفٍ بِالْبَیْتِ وَمُصَلٍّ۔",,,7806,,
7807,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ شُعْبَۃَ ، عَنْ أَشْعَثَ بْنِ أَبِی الشَّعْثَائِ ، قَالَ: شَہِدْتُ مَکَّۃَ فِی زَمَانِ ابْنِ الزُّبَیْرِ فِی رَمَضَانَ وَالإِمَام یُصَلِّی بِقَومٍ عَلَی حِدَۃٍ ، وَالنَّاسُ یُصَلُّونَ فِی نَوَاحِی الْمَسْجِدِ۔",,,7807,,
7808,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ عَبْدِ الْمَلِکِ بْنِ عُمَیْرٍ ، قَالَ : رَأَیْتُُ شَبَثَ بْنَ رِبْعِیٍّ وَنَاسٌ مَعَہُ یُصَلُّونَ وُحْدَانًا فِی رَمَضَانَ وَالنَّاسُ فِی الصَّلاَۃ ، وَرَأَیْت شَبَثًا یُصَلِّی فِی سُتْرَۃٍ وَحْدَہُ۔",,,7808,,
7809,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ الإِمَام یُصَلِّی بِالنَّاسِ فِی الْمَسْجِدِ وَالْمُتَہَجِّدُونَ یُصَلُّونَ فِی نَوَاحِی الْمَسْجِدِ لأَنْفُسِہِمْ۔",,,7809,,
7810,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ قَتَادَۃَ ، عَنِ ابنِ جُبَیْر وَالْحَسَنِ ؛ فِی الرَّجُلِ یَقُومُ بَیْنَ التَّرْوِیحَتَیْنِ یَقْرَأُ حَتَّی یَنْہَضَ الإِمَام فَیَدْخُلُ مَعَہُ ، قَالَ شُعْبَۃُ : کَرِہَہُ أَحَدُہُمَا وَلَمْ یَکْرَہْہُ الأَخَرُ۔\n\nوَقَالَ ہِشَامٌ : ہُوَ یُونُسُ بْنُ جُبَیْرٍ۔",,,7810,,
7811,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ ہَارُونَ بْنِ أَبِی مَرْیَمَ ، عَنِ ابْنِ الأَسْوَدِ : أَنَّہُ کَانَ یُصَلِّی بِہِمْ أَرْبَعِینَ رَکْعَۃً وَیُوتِرُ بِہِمْ وَیُصَلِّی بَیْنَ التَّرْوِیحَتَیْنِ اثْنَتَیْ عَشْرَۃَ رَکْعَۃً ، وَیَقُولُ بَیْنَ التَّرْوِیحَتَیْنِ : الصلاۃ۔",,,7811,,
7812,"حَدَّثَنَا عَفَّانُ، قَالَ: حدَّثَنَا ہَمَّامٌ، قَالَ: حَدَّثَنَا یَحْیَی بْنُ أَبِی کَثِیرٍ، أَنَّ رَجُلاً مِنْ أَہْلِ الشَّامِ حَدَّثَہُ یُقَالُ لَہُ أَبُو سُفْیَانَ، أَنَّ بَحِیرَ بْنَ رَیْسَانَ حَدَّثَہُ، أَنَّہُ کَانَ عِنْدَ عُبَادَۃَ بْنِ الصَّامِتِ شَہِدَ ذَلِکَ، زَجَرَہُمْ أَنْ یُصَلُّوا إذَا تَرَوَّحَ الإِمَام فِی رَمَضَانَ فَجَعَلَ یَزْجُرُہُمْ وَہُمْ لاَ یُبَالُونَ ، وَلاَ یَنْتَہُونَ فَضَرَبَہُمْ فَرَأَیْتُہُ یَضْرِبُہُمْ عَلَی ذَلِکَ۔",,,7812,,
7813,حَدَّثَنَا یَحْیَی بْنُ وَاضِحٍ أَبُو تُمَیْلَۃَ ، عَنْ أَبِی حَمْزَۃَ ، عَنْ حَبِیبِ بن أَبِی عَمْرَۃَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، أَنَّہُ کَانَ یَکْرَہُ أَنْ یَقُولَ بَیْنَ التَّرْوِیحَتَیْنِ الصَّلاَۃ۔,,,7813,,
7814,"حَدَّثَنَا عَبَّادُ بْنُ عَوَّامٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ والحسن : أَنَّہُمَا کَانَا یَکْرَہَانِ التَّعْقِیبَ فِی رَمَضَانَ۔",,,7814,,
7815,"حَدَّثَنَا عَبَّادٌ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسٍ قَالَ : لاَ بَأْسَ بِہِ إنَّمَا یَرْجِعُونَ إلَی خَیْرٍ یَرْجُونَہُ وَیَبْرَؤُونَ مِنْ شَرٍّ یَخَافُونَہُ۔",,,7815,,
7816,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا الرَّبِیعُ ، عَنِ الْحَسَنِ ، أَنَّہُ کَرِہَ التَّعْقِیبَ فِی شَہْرِ رَمَضَانَ ، وَقَالَ الْحَسَنُ لاَ تُمِلُّوا النَّاسَ۔",,,7816,,
7817,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ أَبِی عَمْرٍو ، أَنَّہُ صَلَّی خَلْفَ أَبِی ہُرَیْرَۃَ فِی رَمَضَانَ ، وَکَانَ یُصَلِّی رَکْعَتَیْنِ ثُمَّ یُسَلِّمُ ، ثُمَّ یَقُومُ فَیُوتِرُ بِرَکْعَۃٍ۔,,,7817,,
7818,حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ یَحْیَی بْنِ وَثَّابٍ ، أَنَّہُ کَانَ یَؤُمُّہُمْ فِی شَہْرِ رَمَضَانَ فِی الْقِیَامِ وَکَانَ لاَ یُسَلِّمُ إِلاَّ فِی أَرْبَعِ رَکَعَاتٍ۔,,,7818,,
7819,"حَدَّثَنَا حَفْصٌ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، قَالَ : کَانَ عَبْدُ الرَّحْمَنِ بْنُ الأَسْوَدِ یَقُومُ بِنَا لَیْلَۃَ الْفِطْرِ۔",,,7819,,
7820,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا عَبْدُ اللہِ بْنُ الْوَلِیدِ ، قَالَ : أَخْبَرَنِی عُمَرُ بْنُ أَیُّوبَ ، قَالَ : أَخْبَرَنِی أَبُو إیَاسٍ مُعَاوِیَۃُ بْنُ قُرَّۃَ ، قَالَ : کُنْتُ نَازِلاً عَلَی عَمْرِو بْنِ النُّعْمَانِ بْنِ مُقَرِّنٍ ، فَلَمَّا حَضَرَ رَمَضَانُ جَائَہُ رَجُلٌ بِأَلْفَیْ دِرْہَمٍ مِنْ قِبَلِ مُصْعَبِ بْنِ الزُّبَیْرِ ، فَقَالَ : إنَّ الأَمِیرَ یُقْرِئُکَ السَّلاَمَ وَیَقُولُ : إنَّا لَمْ نَدَعْ قَارِئًا شَرِیفًا إِلاَّ قَدْ وَصَلَ إلَیْہِ مِنَّا مَعْرُوفٌ فَاسْتَعِنْ بِہَذَیْنِ عَلَی نَفَقَۃِ شَہْرِکَ ہَذَا ، فَقَالَ عَمْرٌو : اقْرَأْ عَلَی الأَمِیرِ السَّلاَمَ وَقُلْ وَاللَّہِ مَا قَرَأْنَا الْقُرْآنَ نُرِیدُ بِہِ الدُّنْیَا وَرَدَّہُ عَلَیْہِ۔",,,7820,,
7821,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنِی أَبِی ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ اللہِ بْنِ مَعْقِلٍ : أَنَّہُ صَلَّی بِالنَّاسِ فِی شَہْرِ رَمَضَانَ ، فَلَمَّا کَانَ یَوْمُ الْفِطْرِ بَعَثَ إلَیْہِ عُبَیدُ اللہِ بْنُ زِیَادٍ بِحُلَّۃٍ وَبِخَمْسِمِئَۃِ دِرْہَمٍ فَرَدَّہَا وَقَالَ : إِّنَا لاَ نَأْخُذُ عَلَی الْقُرْآنِ أَجْرًا۔",,,7821,,
7822,"حَدَّثَنَا وَکِیعٌ ، قَالَ: حدَّثَنَا الْمَسْعُودِیُّ، عَنِ الْقَاسِمِ بْنِ عَبْدِ الرَّحْمَنِ، قَالَ: لاَ یُؤْخَذُ عَلَی الْقُرْآنِ أَجْرٌ۔",,,7822,,
7823,"حَدَّثَنَا جَرِیرٌ ، عَنْ رَجُلٍ : أَنَّ سَعِیدَ بْنَ جُبَیْرٍ قَامَ بِالنَّاسِ فِی رَمَضَانَ فَأَرْسَلَ إلَیْہِ الْحَجَّاجُ بِبُرْنُسٍ فَقَبِلَہُ۔",,,7823,,
7824,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ وَاقِدٍ ، عَنْ زَاذَانَ ، قَالَ سَمِعْتُہُ یَقُولُ : مَنْ قَرَأَ الْقُرْآنَ یَأْکُلُ بِہِ جَائَ یَوْمَ الْقِیَامَۃِ وَوَجْہُہُ عَظْمٌ لَیْسَ عَلَیْہِ لَحْمٌ۔",,,7824,,
7825,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ہِشَامٌ الدَّسْتَوَائِیُّ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ أَبِی رَاشِدٍ ، عَنْ عَبْدِ اللہِ بْنِ شِبْلٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : اقرَؤُوا الْقُرْآنَ ، وَلاَ تَأْکُلُوا بِہِ ، وَلاَ تَسْتَکْثِرُوا بِہِ ، وَلاَ تَجْفُوا عَنْہُ ، وَلاَ تَغْلُوا فِیہِ۔ (احمد 3/444۔ ابویعلی 1515)",,,7825,,
7826,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا یَزِیدُ بْنُ الْحَطِیم ، عَنِ الْحَسَنِ ، قَالَ عُمَرُ : اقْرَؤُوا الْقُرْآنَ وَسَلُوا اللَّہَ بِہِ قَبْلَ أَنْ یَقْرَأَہُ قَوْمٌ یَسْأَلُونَ النَّاسَ بِہِ۔",,,7826,,
7827,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ حَسَنٍ ، عَنْ إبْرَاہِیمَ بْنِ عَبْدِ الأَعْلَی ، عَنْ سُوَیْد بْنِ غَفَلَۃَ : أَنَّہُ کَانَ یَنْہَی عَنِ الصَّلاَۃ عَلَی الطَّرِیقِ۔",,,7827,,
7828,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ سِمَاکٍ ، عَنْ سَیَّارِ بْنِ مَعْرُورٍ قَالَ : رَأَی عُمَرُ قَوْمًا یُصَلُّونَ عَلَی الطَّرِیقِ ، فَقَالَ : صَلُّوا فِی الْمَسْجِدِ۔",,,7828,,
7829,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا ہِشَامٌ ، عَنِ الْحَسَنِ ، عَنْ جَابِرٍ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تُصَلُّوا عَلَی جَوَادِ الطَّرِیقِ ، وَلاَ تَنْزِلُوا عَلَیْہَا فَإِنَّہَا مَأْوَی الْحَیَّاتِ وَالسِّبَاعِ۔ (احمد 3/382۔ عبدالرزاق 9247)",,,7829,,
7830,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ ثَابِتٍ الْبُنَانِیِّ ، عَنْ أَنَسِ بْنِ مَالِکٍ، قَالَ: کَانَ أَصْحَابُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلُّونَ فِی سِکَکِ الأَہْوَازِ ، وَکَانَ أَنَسُ بْنُ مَالِکٍ یُصَلِّی فِی مَمَرِّ خَدَمِہِ۔",,,7830,,
7831,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ أَبِی مَالِکٍ الأَشْجَعِیِّ ، عَنْ رِبْعِیِّ بْنِ حِرَاشٍ ، عَنْ حُذَیْفَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : جُعِلَتْ لَنَا الأَرْضُ کُلُّہَا مَسْجِدًا۔",,,7831,,
7832,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا سَیَّارٌ ، قَالَ : حَدَّثَنَا یَزِیدُ الْفَقِیرُ ، قَالَ : أَخْبَرَنَا جَابِرُ بْنُ عَبْدِ اللہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : جُعِلَتْ لِی الأَرْضُ طَہُورًا وَمَسْجِدًا فَأَیُّمَا رَجُلٍ مِنْ أُمَّتِی أَدْرَکَتْہُ الصَّلاَۃ فَلْیُصَلِّ حَیْثُ أَدْرَکَتْہُ۔ (بخاری 335۔ مسلم 2)",,,7832,,
7833,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنْ مُجَاہِدٍ وَمِقْسَمٍ ، عَنِ ابْنِ عَبَّاسٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : جُعِلَتْ لِی الأَرْضُ طَہُورًا وَمَسْجِدًا۔ (بخاری 2152۔ احمد 1/301)",,,7833,,
7834,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ إسْرَائِیلَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی بُرْدَۃَ ، عَنْ أَبِیہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : جُعِلَتْ لِی الأَرْضُ طَہُورًا وَمَسْجِدًا۔ (احمد 4/4z",,,7834,,
7835,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ التَّیْمِیِّ ، عَنْ أَبِیہِ ، عَنْ أَبِی ذَرٍّ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : أَیْنَمَا أَدْرَکَتْکَ الصَّلاَۃ فَصَلِّ فَہُوَ مَسْجِدٌ۔ (بخاری 3366۔ مسلم 370۔ احمد 5/160)",,,7835,,
7836,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عُمَر بْن ذَرٍّ ، عَنْ مُجَاہِدٍ ، عَنْ أَبِی ذَرٍّ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : جُعِلَتْ لِی الأَرْضُ مَسْجِدًا وَطَہُورًا۔ (طیالسی 472۔ احمد 5/161)",,,7836,,
7837,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ مَالِکِ بْنِ الْحَارِثِ ، عَنْ أَبِیہِ قَالَ : کُنَّا مَعَ أَبِی مُوسَی فِی دَارِ الْبَرِیدِ فَحَضَرَتِ الصَّلاَۃ فَصَلَّی بِنَا عَلَی رَوْثٍ وَتِبْنٍ ، فَقُلْنَا تُصَلِّی بِنَا ہُنَا وَالْبَرِّیَّۃُ إلَی جَنْبِکَ ؟ فَقَالَ : الْبَرِّیَّۃُ وَہَا ہُنَا سَوَائٌ۔",,,7837,,
7838,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عِکْرِمَۃُ بْنُ عَمَّارٍ ، قَالَ : رَأَیْتُُ سَالِمًا کَنَسَ مَکَانًا ، ثُمَّ صَلَّی فِیہِ۔",,,7838,,
7839,"حَدَّثَنَا مَالِکُ بْنُ إسْمَاعِیلَ ، قَالَ : حدَّثَنَا مِنْدَلٌ ، عَنِ الأَعْمَشِ ، عَنْ مُجَاہِدٍ ، عَنْ عُبَیْدِ بْنِ عُمَیْرٍ ، عَنْ أَبِی ذَرٍّ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : جُعِلَتْ لِی الأَرْضُ طَہُورًا وَمَسْجِدًا۔ (ابوداؤد 490)",,,7839,,
7840,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، قَالَ : کَانَ النَّاسُ یَقْرَؤُونَ مُتَوَاتِرِینَ فِی رَمَضَانَ کُلُّ قَارِیٍٔ فِی أَثَرِ صَاحِبِہِ حَتَّی وَلِیَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ فَقَالَ : لِیَقْرَأْ کُلُّ قَارِیٍٔ مِنْ حَیْثُ أَحَبَّ۔",,,7840,,
7841,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا عَبْدُ الْمَلِکِ بْنُ عُمَیْرٍ ، قَالَ : حَدَّثَنَا جَابِرُ بْنُ سَمُرَۃَ : أَنَّ أُنَاسًا شَکَوْا سَعْدًا إلَی عُمَرَ بْنِ الْخَطَّابِ ، قَالَ وَشَکَوْہُ فِی الصَّلاَۃ ، قَالَ : فَکَتَبَ إلَیْہِ عُمَرُ فَقَدِمَ عَلَیْہِ ، قَالَ : فَذَکَرَ الَّذِی شَکَوْہُ فِیہِ وَذَکَرَ أَنَّہُمْ شَکَوْہُ فِی الصَّلاَۃ ، فَقَالَ سَعْدٌ : إنِّی لأُصَلِّی بِہِمْ صَلاَۃَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، إنِّی لأَرْکُدُ بِہِمْ فِی الأُولَیَیْنِ وَأَحْذِفُ بِہِم فِی الأُخْرَیَیْنِ ، قَالَ : ذَلِکَ الظَّنُّ بِکَ یَا أَبَا إِسْحَاقَ۔ (بخاری 770۔ مسلم 159)",,,7841,,
7842,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مَنْصُورٍ ، عَنْ أَبِی بِشْرٍ الْہُجَیْمِیِّ ، عَنْ أَبِی الصِّدِّیقِ ، عَنْ أَبِی سَعِیدٍ ، قَالَ : کُنَّا نَحْزِرُ قِیَامَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی الظُّہْرِ وَالْعَصْرِ ، فَحَزَرْنَا قِیَامَہ فِی الظُّہْرِ فِی الرَّکْعَتَیْنِ الأُولَیَیْنِ قَدْرَ ثَلاَثِینَ آیَۃً ، وَحَزَرْنَا قِیَامَہُ فِی الرَّکْعَتَیْنِ الأُخْرَیَیْنِ عَلَی النِّصْفِ مِنْ ذَلِکَ ، وَحَزَرْنَا قِیَامَہُ فِی الرَّکْعَتَیْنِ الأُولَیَیْنِ مِنَ الْعَصْرِ عَلَی قَدْرِ الأُخْرَیَیْنِ مِنَ الظُّہْرِ ، وَحَزَرْنَا قِیَامَہُ فِی الرَّکْعَتَیْنِ الأُخْرَیَیْنِ مِنَ الْعَصْرِ عَلَی النِّصْفِ مِنْ ذَلِکَ۔",,,7842,,
7843,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی قَتَادَۃَ ، عَنْ أَبِیہِ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقْرَأُ بِنَا فِی الرَّکْعَتَیْنِ الأُولَیَیْنِ مِنَ الظُّہْرِ وَیُسْمِعُنَا الآیَۃَ أَحْیَانًا وَیُطِیلُ الأُولَی ، وَیَقْصِرُ فِی الثَّانِیَۃِ ، وَکَانَ یَفْعَلُ ذَلِکَ فِی صَلاَۃِ الصُّبْحِ یُطِیلُ فِی الأُولَی وَیَقْصِرُ فِی الثَّانِیَۃِ ، وَکَانَ یَقْرَأُ بِنَا فِی الرَّکْعَتَیْنِ الأُولَیَیْنِ مِنَ الْعَصْرِ۔",,,7843,,
7844,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی عُثْمَانَ : أَنَّ عُمَرَ کَانَ یُصَلِّی الظُّہْرَ عِنْدَ زَوَالِ الشَّمْسِ وَیُطِیلُ أَوَّلَ رَکْعَۃٍ۔",,,7844,,
7845,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ خَالِدِ بْنِ أَبِی بَکْرٍ، قَالَ: صَلَّیْتُ خَلْفَ الْقَاسِمِ، فَکَانَ یُطِیلُ الأُولَیَیْنِ أَطْوَلَ مِنَ الأُخْرَیَیْنِ الأُولَیَیْنِ مِنَ الظُّہْرِ وَالأُولَیَیْنِ مِنَ الْعَصْرِ وَالأُولَیَیْنِ مِنَ الْمَغْرِبِ وَالأُولَیَیْنِ مِنَ الْعِشَائِ۔",,,7845,,
7846,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ خَالِدِ بْنِ أَبِی بَکْرٍ ، قَالَ : صَلَّیْتُ خَلْفَ سَالِمٍ ، فَکَانَ یَفْعَلُ مِثْلَ ذَلِکَ وَکَانَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ یَفْعَلُ ذَلِکَ۔",,,7846,,
7847,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنِ الضَّحَّاکِ بْنِ عُثْمَانَ ، قَالَ : رَأَیْتُُ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ یُصَلِّی بِنَا الظُّہْرَ فَیُطِیلُ فِی الأُولَیَیْنِ وَیُخَفِّفُ الأُخْرَیَیْنِ وَیُحَفِّفُ فِی الْعَصْرِ۔",,,7847,,
7848,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یزَیْدِ بْنِ جَابِرٍ ، عَنْ مَکْحُولٍ : أَنَّہُ کَانَ یُطَوِّلُ فِی أَوَّلِ رَکْعَۃٍ۔",,,7848,,
7849,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا أَبُو عَوَانَۃَ ، عَنْ عُمَرَ بْنِ أَبِی سَلَمَۃ ، عَنْ أَبِیہِ ، قَالَ : کَانَ عُثْمَانُ بْنُ عَفَّانَ یُطِیلُ الرَّکْعَتَیْنِ الأُولَیَیْنِ مِنَ الظُّہْرِ یَقْرَأُ فِیہِمَا بِسُورَۃِ الْبَقَرَۃِ۔",,,7849,,
7850,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ سِمَاکٍ ، عَنْ جَابِرِ بْنِ سَمُرَۃَ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا صَلَّی الْفَجْرَ قَعَدَ فِی مَجْلِسِہِ حَتَّی تَطْلُعَ الشَّمْسُ۔ (مسلم 464۔ ابوداؤد 1288)",,,7850,,
7851,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُوسَی بْنِ عَبْدِ اللہِ بْنِ إِسْحَاقَ بْنِ طَلْحَۃَ ، عَنْ مُوسَی بْنِ طَلْحَۃَ ، قَالَ : کَانَ طَلْحَۃُ یَثْبُتُ فِی مُصَلاَّہُ حَیْثُ صَلَّی فَلاَ یَبْرَحُ حَتَّی تَحْضُرَ السُّبْحَۃُ فَیُسَبِّحُ۔",,,7851,,
7852,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، قَالَ : بَلَغَنِی عَنْ رَجُلٍ مِنْ بَنِی تَمِیمٍ ، أَنَّہُ دَخَلَ عَلَی الْحَسَنِ بْنِ عَلِیٍّ وَہُوَ قَاعِدٌ فِی مُصَلاَّہُ ، وَقَالَ : مَا مِنْ مُسْلِمٍ یُصَلِّی الصُّبْحَ ، ثُمَّ یَقْعُدُ فِی مُصَلاَّہُ إِلاَّ کَانَ لَہُ حِجَابًا مِنَ النَّارِ۔",,,7852,,
7853,"حَدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنْ أَبِی سِنَانٍ ، عَنِ الْعَلاَئِ بْنِ بَدْرٍ ، عَنْ أَبِی الشَّعْثَائِ الْمُحَارِبِیِّ ، عَنْ سَلْمَانَ ، قَالَ : إذَا صَلَّیْتُمُ الْغَدَاۃَ فَاذْکُرُوا اللَّہَ حَتَّی تَطْلُعَ الشَّمْسُ ، فَإِنْ لَمْ تَفْعَلُوا فَنَامُوا فَإِنَّ النَّائِمَ سَالِمٌ۔",,,7853,,
7854,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی الأَشْہَبِ ، عَنِ الْحَسَنِ : أَنَّ أَبَا ہُرَیْرَۃَ لَقِیَ رَجُلاً ، فَقَالَ : کَأَنَّک لَسْتَ مِنْ أَہْلِ الْبَلَدِ ؟ قَالَ : أَجَلْ ، قَالَ : أَلاَ أُحَدِّثُکَ حَدِیثًا سَمِعْتُہُ مِنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لَعَلَّک أَنْ تنْتَفِعَ بِہِ؟ سَمِعْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : أَوَّلُ مَا یُحَاسَبُ بِہِ الْعَبْدُ الصَّلاَۃ ، فَإِنْ کَانَ أَتَمَّہَا وَإلاَّ قِیلَ لِلْمَلاَئِکَۃِ أَکْمِلُوا صَلاَتَہُ مِنْ تَطَوُّعِہِ ، قَالَ الْحَسَنُ : وَسَائِرُ الأَعْمَالِ عَلَی ذَلِکَ۔ (بخاری 1593۔ ابویعلی 6197)",,,7854,,
7855,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ دَاوُدَ بْنِ أَبِی ہِنْدٍ ، عَنْ زُرَارَۃَ بْنِ أَوْفَی ، عَنْ تَمِیمٍ الدَّارِیِّ ، قَالَ : إنَّ أَوَّلَ مَا یُحَاسَبُ بِہِ الْعَبْدُ الصَّلاَۃ ، فَإِنْ أَتَمَّہَا وَالأَ قِیلَ : اُنْظُرُوا لَہُ تَطَوُّعٌ ، فَإِنْ کَانَ لَہُ تَطَوُّعٌ فَأَکْمِلُوا الْمَکْتُوبَۃَ مِنَ التَّطَوُّعِ۔ (احمد 103۔ دارمی 1355)",,,7855,,
7856,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ تَمِیمِ بْنِ سَلَمَۃَ ، قَالَ : أَوَّلُ مَایُسْأَلُ عَنْہُ الْعَبْدُ یُسْئلُ عَنْ صَلاَتِہِ ، فَإِنْ تُقُبِّلَتْ مِنْہُ تُقُبِّلَ مِنْہُ سَائِرُ عَمَلِہِ وَإِنْ رُدَّتْ عَلَیْہِ رُدَّ عَلَیْہِ سَائِرُ عَمَلِہِ۔",,,7856,,
7857,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ تَوْبَۃَ الْعَنْبَرِیِّ ، عَنْ مُوَرِّقٍ الْعِجْلِیّ ، قَالَ : قُلْتُ لِاِبْنِ عُمَرَ : أَتُصَلِّی الضُّحَی ؟ قَالَ : لاَ ، قُلْتُ : صَلاَّہَا عُمَرُ ؟ قَالَ : لاَ ، قُلْتُ : صَلاَّہَا أَبُو بَکْرٍ ؟ قَالَ : لاَ ، قُلْتُ صَلاَّہَا النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ قَالَ : لاَ أَخَالُُ۔ (بخاری 1175۔ احمد 2/23)",,,7857,,
7858,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ أَبِی خَالِدٍ ، عَنِ الشَّعْبِیِّ ، عَنِ ابْنِ عُمَرَ قَالَ : مَا صَلَّیْتُ الضُّحَی مُذْ أَسْلَمْتُ إِلاَّ أَنْ أَطُوفَ بِالْبَیْتِ۔",,,7858,,
7859,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ الْجُرَیرِیِّ ، عَنِ الْحَکَمِ بْنِ الأَعْرَجِ قَالَ : سَأَلْتُ ابْن عُمَرَ ، عَنْ صَلاَۃِ الضُّحَی وَہُوَ مُسْتَنِدٌ ظَہْرَہُ إلَی حُجْرَۃِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : بِدْعَۃٌ وَنِعْمَتِ الْبِدْعَۃُ۔ (بخاری 1775۔ مسلم 220)",,,7859,,
7860,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ أَبِی عُبَیْدَۃَ ، قَالَ : لَمْ یُخْبِرْنِی أَحَدٌ مِنَ النَّاسِ أَنَّہُ رَأَی ابْنَ مَسْعُودٍ یُصَلِّی الضُّحَی۔",,,7860,,
7861,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ أَبِی الضُّحَی ، عَنْ مَسْرُوقٍ ، قَالَ : کُنَّا نَقْرَأُ فِی الْمَسْجِدِ فَیَثْبُتُ النَّاسُ فِی الْقِرَائَۃِ بَعْدَ قِیَامِ ابْنِ مَسْعُودٍ ، ثُمَّ نَقُومُ فَنُصَلِّی الضُّحَی ، فَبَلَغَ ذَلِکَ ابْنَ مَسْعُودٍ ، فَقَالَ : عِبَادَ اللہِ لِمَ تُحَمِّلُوا عِبَادَ اللہِ مَا لَمْ یُحَمِّلْہُمُ اللَّہُ إِنْ کُنْتُمْ لاَ بُدَّ فَاعِلِینَ فَفِی بُیُوتِکُمْ۔",,,7861,,
7862,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنِی أَبِی وَإِسْرَائِیلُ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ التَّمِیمِیِّ ، قَالَ : سَأَلْتُ ابْنَ عُمَرَ عَنْ صَلاَۃِ الضُّحَی فَقَالَ : وَلِلضُّحَی صَلاَۃ؟۔",,,7862,,
7863,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ الزُّہْرِیِّ ، عَنْ عُرْوَۃَ ، عَنْ عَائِشَۃَ قَالَتْ : لَمْ یَکُنِ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُسَبِّحُ سُبْحَۃَ الضُّحَی ، قَالَتْ : وَکَانَ یَتْرُکُ أَشْیَائَ کَرَاہَۃَ أَنْ یُسْتَنَّ بِہِ فِیہَا۔ (احمد 170)",,,7863,,
7864,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا ابْنُ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، عَنْ عُرْوَۃَ ، عَنْ عَائِشَۃَ قَالَتْ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لاَ یُصَلِّی سُبْحَۃَ الضُّحَی وَإِنِّی لأُسَبِّحُہَا۔ (بخاری 1177۔ ابوداؤد 1287)",,,7864,,
7865,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا سُفْیَانُ، عَنْ مَنْصُورٍ، عَنْ إِبْرَاہِیمَ، عَن عَلْقَمَۃَ، قَالَ: کَانَ لاَ یُصَلِّی الضُّحَی۔",,,7865,,
7866,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا حَاجِبُ بْنُ عُمَرَ ، عَنِ الْحَکَمِ بْنِ الأَعْرَجِ ، قَالَ : سَأَلْتُ ابْنَ عُمَرَ عَنْ صَلاَۃِ الضُّحَی ؟ فَقَالَ : بِدْعَۃٌ۔",,,7866,,
7867,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شَرِیکٌ ، عَنْ عَباس ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : إنِّی لأَدَعُ صَلاَۃَ الضُّحَی وَإِنِّی أَشْتَہِیہَا۔",,,7867,,
7868,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا النَّہَّاسُ بْنُ قَہْمٍ أَبُو الْخَطَّابِ ، عَنْ شَدَّادٍ أَبِی عَمَّارٍ الشَّامِیِّ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ حَافَظَ عَلَی شُفْعَۃِ الضُّحَی غُفِرَتْ لَہُ ذُنُوبُہُ وَإِنْ کَانَتْ مِثْلَ زَبَدِ الْبَحْرِ۔ (احمد 497)",,,7868,,
7869,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ہِشَامٌ الدَّسْتَوَائِیُّ ، عَنِ الْقَاسِمِ بْنِ عَوْفٍ الشَّیْبَانِیِّ ، عَنْ زَیْدِ بْنِ أَرَقْمَ ، قَالَ: خَرَجَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَلَی أَہْلِ قُبَائٍ وَہُمْ یُصَلُّونَ صَلاَۃَ الضُّحَی ، فَقَالَ : صَلاَۃُ الأَوَّابِینَ إذَا رَمِضَتِ الْفِصَالُ مِنَ الضُّحَی۔ (مسلم 144۔ احمد 4/367)",,,7869,,
7870,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا کَہْمَسُ بْنُ الْحَسَنِ ، عَنْ عَبْدِ اللہِ بْنِ شَقِیقٍ الْعُقَیْلِیِّ ، قَالَ : قُلْتُ لِعَائِشَۃَ : أَکَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّی الضُّحَی ؟ قَالَتْ : لاَ ، إِلاَّ أَنْ یَجِیئَ مِنْ مَغِیبِہِ۔ (مسلم 76۔ احمد 6/171)",,,7870,,
7871,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَاصِمِ بْنِ کُلَیْبٍ ، عَنْ أَبِیہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : مَا رَأَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی الضُّحَی إِلاَّ مَرَّۃً۔ (احمد 2/446۔ نسائی 477)",,,7871,,
7872,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ سَعدِ بْنِ إبْرَاہِیمَ ، عَنِ الْقَاسِمِ بْنِ مُحَمَّدٍ : أَنَّ عَائِشَۃَ کَانَتْ تُصَلِّی الضُّحَی صَلاَۃً طَوِیلَۃً۔",,,7872,,
7873,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا أَبُو الْمِنْہَالِ الطَّائِیُّ نَصْرُ بْنُ أَوْسٍ ، عَنْ عَبْدِ اللہِ بْنِ زَیْدٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ لِی : عَلَیْک بِسَجْدَتَیِ الضُّحَی ہُمَا خَیْرٌ لَکَ مِنْ نَاقَتَیْنِ دَہْمَاوَیْنِ مِنْ نَتَاجِ بَنِی بُحتُر۔",,,7873,,
7874,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ أُسَامَۃ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِی الرَّبَابِ : أَنَّ أَبَا ذَرٍّ صَلَّی الضُّحَی فَأَطَالَ۔",,,7874,,
7875,"حَدَّثَنَا إسْمَاعِیلُ ، عَنْ حَبِیبِ بْنِ الشَّہِیدِ ، قَالَ : سُئِلَ عِکْرِمَۃُ ، عَنْ صَلاَۃِ ابْنِ عَبَّاسٍ الضُّحَی ؟ قَالَ : کَانَ یُصَلِّیہَا الْیَوْمَ وَیَدَعُہَا الْعَشْرَ۔",,,7875,,
7876,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، قَالَ : کَانَ سَعِیدُ بْنُ الْمُسَیَّبِ یُصَلِّی الضُّحَی۔",,,7876,,
7877,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یُصَلُّونَ الضُّحَی وَیَدَعُونَ۔",,,7877,,
7878,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ أوَغَیْرِہِ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یَکْرَہُونَ أَنْ یُدِیمُوا صَلاَۃَ الضُّحَی مِثْلَ الْمَکْتُوبَۃِ۔",,,7878,,
7879,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ سَعْدِ بْنِ إبْرَاہِیمَ ، عَنِ الْقَاسِمِ بْنِ مُحَمَّدٍ ، عَنْ عَائِشَۃَ ، أَنَّہَا کَانَتْ تُغْلِقُ عَلَیْہَا بَابَہَا ، ثُمَّ تُصَلِّی الضُّحَی۔",,,7879,,
7880,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ شَرِیکٍ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّہُ سُئِلَ عَنْ صَلاَۃِ الضُّحَی ، فَقَالَ : إِنَّہَا لَفِی کِتَابِ اللہِ ، وَلاَ یَغُوصُ عَلیہَا إلا غَوَّاصٌ ، ثُمَّ قَرَأَ : (فِی بُیُوتٍ أَذِنَ اللَّہُ أَنْ تُرْفَعَ وَیُذْکَرَ فِیہَا اسْمُہُ یُسَبِّحُ لَہُ فِیہَا بِالْغُدُوِّ وَالأَصَالِ) ۔",,,7880,,
7881,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا شَرِیکٌ، عَنْ سَالِمٍ الأَفْطَسِ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ: أَنَّہُ صَلَّی الضُّحَی فِی الْکَعْبَ",,,7881,,
7882,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ مُطَہَّرِ بْنِ جُوَیْرِیَۃَ ، قَالَ : رَأَیْتُُ الضَّحَّاکَ یُصَلِّی الضُّحَی ، وَرَأَیْتُ أَبَا مِجْلَزٍ یُصَلِّی فِی مَنْزِلِہِ الضُّحَی۔",,,7882,,
7883,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا یَحْیَی بْنُ مُسْلِمٍ الْہَمْدَانِیُّ ، عَنْ سَعِیدِ بْنِ عَمْرٍو الْقُرَشِیِّ ، قَالَ : أَتْبَعَنِی أبی عَبْدَ اللہِ بْنَ عُمَرَ لأَتَعَلَّمَ مِنْہُ فَمَا رَأَیْتُہُ یُصَلِّی السُّبْحَۃَ ، وَکَانَ إذَا رَآہُمْ یُصَلُّونَہَا قَالَ : مِنْ أَحْسَنِ مَا أَحْدَثُوا سُبْحَتُہُمْ ہَذِہِ۔",,,7883,,
7884,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنِ الْعَوَّامِ ، عَنْ سُلَیْمَانَ بْنِ أَبِی سُلَیْمَانَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : أَوْصَانِی خَلِیلِی صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ أُصَلِّیَ الضُّحَی فَإِنَّہَا صَلاَۃُ الأَوَّابِینَ۔",,,7884,,
7885,"حَدَّثَنَا وَکِیعٌ ، عَنْ سِمَاکٍ ، عَنْ عَمِّہِ سَلَمَۃَ بْنِ سِمَاکٍ ، قَالَ : سَمِعْتُ عُمَرَ بْنَ الْخَطَّابِ یَقُولُ : أَضْحُوا عِبَادَ اللہِ بِصَلاَۃِ الضُّحَی۔",,,7885,,
7886,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا یُوسُفُ بْنُ صُہَیْبٍ ، عَنْ حَبِیبِ بْنِ یَسَارٍ ، عَنْ أَبِی رَمْلَۃَ الأَزْدِیِّ ، عَنْ عَلِیٍّ: أَنَّہُ رَآہُمْ یُصَلُّونَ الضُّحَی عِنْدَ طُلُوعِ الشَّمْسِ ، فَقَالَ : ہَلاَّ تَرَکُوہَا حَتَّی إذَا کَانَتِ الشَّمْسُ قِیدْ رُمْحٍ أَوْ رُمْحَیْنِ ، صَلَّوْہَا فَذَلکَ صَلاَۃُ الأَوَّابِینَ۔",,,7886,,
7887,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی زَیْدٍ ، عَنْ شُعْبَۃَ مَوْلَی ابْنِ عَبَّاسٍ ، قَالَ : کَانَ ابْنُ عَبَّاسٍ یَقُولُ لِی : سَقَطَ الْفَیْئُ ؟ فَإِذَا قُلْتُ نَعَمْ قَامَ فَسَبَّحَ۔",,,7887,,
7888,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، قَالَ : کَانَ أَبُو سَلَمَۃَ لاَ یُصَلِّی الضُّحَی حَتَّی تَمِیلَ الشَّمْسُ ، قَالَ : وَکَانَ عُرْوَۃُ یَجِیئُ فَیُصَلِّی ، ثُمَّ یَجْلِسُ۔",,,7888,,
7889,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شَرِیکٌ ، عَنْ دِثَارٍ الْقَطَّانِ ، عَنِ النُّعْمَانِ بْنِ نَافِذٍ : أَنَّ عَلِیًّا خَرَجَ فَرَأَی قوْمًا یُصَلُّونَ الضُّحَی عِنْدَ طُلُوعِ الشَّمْسِ ، فَقَالَ : مَا لَہُمْ نَحَرُوہَا نَحَرَہُمُ اللَّہُ فَہَلاَّ تَرَکُوہَا حَتَّی إذَا کَانَتْ بِالْجَبِینِ صَلَّوْا فَتِلْکَ صَلاَۃُ الأَوَّابِینَ۔",,,7889,,
7890,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ أَبِی خَالِدٍ ، عَنْ أَبِی صَالِحٍ مَوْلَی أُمِّ ہَانِیئٍ ، عَنْ أُمِّ ہَانِیئٍ ، قَالَتْ : دَخَلَ عَلَیَّ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَیْتِی یَوْمَ فَتْحِ مَکَّۃَ فَوَضَعْتُ لَہُ مَائً فَاغْتَسَلَ ، ثُمَّ صَلَّی ثَمَانَ رَکَعَاتٍ صَلاَۃَ الضُّحَی لَمْ یُصَلِّہِنَّ قَبْلَ یَوْمِہِ ، وَلاَ بَعْدَہُ۔ (طبرانی 1003۔ احمد 6/342)",,,7890,,
7891,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنِ ابْنِ أَبِی لَیْلَی ، قَالَ : لَمْ یُخْبِرْنَا أَحَدٌ مِنَ النَّاسِ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی الضُّحَی إِلاَّ أُمَّ ہَانِیئٍ فَإِنَّہَا قَالَتْ : دَخَلَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَیْتِی یَوْمَ فَتْحِ مَکَّۃَ فَاغْتَسَلَ ، ثُمَّ صَلَّی ثَمَانِ رَکَعَاتٍ یُخَفِّفُ فِیہِنَّ الرُّکُوعَ وَالسُّجُودَ ، لَمْ أَرَہُ صَلاَّہُنَّ قَبْلَ یَوْمَئِذٍ وَلاَ بَعْدَہُ۔ (بخاری 1103۔ ابوداؤد 1285)",,,7891,,
7892,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ یَزِیدَ ، عَنِ ابْنِ أَبِی لَیْلَی ، قَالَ : أَدْرَکْتُ النَّاسَ وَہُمْ مُتَوَافِرُونَ ، أَوْ مُتَوَافُونَ فَلَمْ یُخْبِرْنِی أَحَدٌ أَنَّہُ صَلَّی الضُّحَی إِلاَّ أُمُّ ہَانِیئٍ ، فَإِنَّہَا أَخْبَرَتْنِی أَنَّہُ صَلاَّہَا ثَمَانَ رَکَعَاتٍ۔",,,7892,,
7893,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ إِسْحَاقَ ، عَنْ سَعِیدِ بْنِ أَبِی سَعِیدٍ ، عَنْ أَبِی مُرَّۃَ مَوْلَی أُمِّ ہَانِیئٍ ابْنَۃِ أَبِی طَالِبٍ ، عَنْ أُمِّ ہَانِیئٍ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی الضُّحَی ثَمَانَ رَکَعَاتٍ۔ (ترمذی 1579۔ احمد 6/343)",,,7893,,
7894,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ الْمُنْکَدِرِ ، عَنِ ابن رُمَیْثَۃَ ، عَنْ جَدَّتِہِ ، قَالَتْ : دَخَلْتُ عَلَی عَائِشَۃَ وَہِیَ تُصَلِّی مِنَ الضُّحَی فَصَلَّتْ ثَمَانِ رَکَعَاتٍ۔",,,7894,,
7895,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنِ ابْنِ إِسْحَاقَ ، عَنْ سَعِیدِ بْنِ أَبِی سَعِیدٍ ، عَنْ سَعِیدِ بْنِ مَرْجَانَۃَ ، قَالَ : جَلَسْتُ وَرَائَ سَعْدِ بْنِ مَالِکٍ وَہُوَ یُسَبِّحُ الضُّحَی فَرَکَعَ ثَمَانَ رَکَعَاتٍ أَعُدُّہُنَّ لاَ یَقْعُدُ فِیہِنَّ حَتَّی قَعَدَ فِی آخِرِہِنَّ ، فَتَشَہَّدَ ثُمَّ سَلَّمَ وَانْطَلَقَ۔",,,7895,,
7896,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ، عَنْ تَمِیمَۃَ ابنَۃ دُہَیْمٍ: أَنَّہَا رَأَتْ عَائِشَۃَ صَلَّتْ مِنَ الضُّحَی سِتَّ رَکَعَاتٍ۔",,,7896,,
7897,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ ابْنِ عَجْلاَنَ ، عَنِ الْقَعْقَاعِ بْنِ حَکِیمٍ ، عَنْ جَدَّتِہِ رُمَیْثَۃَ ، قَالَتْ : دَخَلْتُ عَلی عَائِشَۃَ بَیْتًا کَانَتْ تَخْلُو فِیہِ ، فَرَأَیْتُہَا صَلَّتْ مِنَ الضُّحَی ثَمَانَ رَکَعَاتٍ۔",,,7897,,
7898,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ رَجُلٍ ، عَنْ أُمِّ سَلَمَۃَ : أَنَّہَا کَانَتْ تُصَلِّی الضُّحَی ، ثَمَانَ رَکَعَاتٍ وَہِیَ قَاعِدَۃٌ ، فَقِیلَ لَہَا : إنَّ عَائِشَۃَ تُصَلِّی أَرْبَعًا ، فَقَالَتْ : إنَّ عَائِشَۃَ امْرَأَۃٌ شَابَّۃٌ۔",,,7898,,
7899,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ : أَنَّہُ کَانَ إذَا حَضَرَ الْمِصْرَ صَلَّی الضُّحَی أَرْبَعًا۔",,,7899,,
7900,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ حَکِیمِ بْنِ حَکِیمٍ ، عَنْ عَلِیِّ بْنِ عَبْدِ الرَّحْمَنِ ، عنْ حُذَیْفَۃَ ، قَالَ : خَرَجْتُ مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إلَی حَرَّۃِ بَنِی مُعَاوِیَۃَ فَصَلَّی الضُّحَی ثَمَانَ رَکَعَاتٍ طَوَّلَ فِیہِنَّ۔",,,7900,,
7901,"حَدَّثَنَا ابْنُ مُسْہِرٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : أَوْصَانِی خَلِیلِی صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِرَکْعَتَیِ الضُّحَی۔",,,7901,,
7902,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عُبَیْدُ اللہِ بْنُ عَبْدِ الرَّحْمَنِ بْنِ مَوْہَبٍ ، عَنْ مُحَمَّدِ بْنِ کَعْبٍ الْقُرَظِیِّ ، قَالَ : مَنْ قَرَأَ فِی سُبْحَۃِ الضُّحَی بِـ {قُلْ ہُوَ اللَّہُ أَحَدٌ} عَشْرَ مَرَّاتٍ بُنِیَ لَہُ بَیْتٌ فِی الْجَنَّۃِ۔",,,7902,,
7903,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ أَبِی الأَحْوَص ، عَنْ أَبِی ذَرٍّ ، قِیلَ لِسُفْیَانَ : عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ قَالَ : نَعَمْ ، قَالَ : إذَا قَامَ أَحَدُکُمْ إلَی الصَّلاَۃ فَلاَ یَمْسَحِ الْحَصَی۔ (ابوداؤد 942۔ احمد 5/150)",,,7903,,
7904,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ أَشْعَثَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ : أَنَّہُ کَانَ یَکْرَہُ مَسْحَ الْحَصَی۔",,,7904,,
7905,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عُثْمَانَ بْنِ الحَکَمِ ، عَنْ شُرَحْبِیلَ أَبِی سَعدٍ ، عَنْ أَبِی الدَّرْدَائِ ، قَالَ : مَا أُحِبُّ أَنَّ لِی حُمْرَ النَّعَمِ وَأَنِّی مَسَحْتُ مَکَانَ جَبِینِی مِنَ الْحَصَی ، إِلاَّ أَنْ یَغْلِبَنِی فَأَمْسَحَ مَسْحَۃً۔",,,7905,,
7906,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ زُہَیْرٍ ، عَنْ جَابِرٍ ، عَنْ سَالِمِ بْنِ عَبْدِ اللہِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ زَیْدِ بْنِ الْخَطَّابِ : أَنَّہُ صَلَّی إلَی جَنْبِ عُمَرَ فَمَسَحَ الْحَصَی فَأمْسَکَ بِیَدِہِ۔",,,7906,,
7907,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِیہِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی عَطِیَّۃَ ، عَنْ أَبِی صَالِحٍ ، قَالَ : إذَا سَجَدْتَ فَلاَ تَملْحَصَی فَإِنَّ کُلَّ حَصَاۃٍ تُحِبُّ أَنْ یُسْجَدَ عَ",,,7907,,
7908,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عِیسَی بْنِ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، عَنْ أَبِیہِ ، عَنْ أَبِی ذَرٍّ قَالَ : سَأَلْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ أَشْیَائَ حَتَّی سَأَلْتُہُ عَنْ مَسْحِ الْحَصَی فَقَالَ : مَرَّۃً وَاحِدَۃً وَالأَ فَدَعْ۔ (عبدالرزاق 2406۔ طیالسی 470)",,,7908,,
7909,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ أَبِی لَیْلَی ، عَنْ شَیْخٍ یُقَالُ لَہُ ہِلاَلٌ ، عَنْ حُذَیْفَۃَ ، قَالَ : سَأَلْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ کُلِّ شَیْئٍ حَتَّی عَن مَسْحِ الْحَصَی فَقَالَ : وَاحِدَۃً ، أَوْ دَعْ۔ (احمد 385)",,,7909,,
7910,"حَدَّثَنَا وَکِیعٌ ، قَالَ: حدَّثَنَا ہِشَامٌ الدَّسْتَوَائِیُّ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ أَبِی سَلَمَۃَ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ مُعَیْقِیبٍ ، قَالَ : ذُکِرَ لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَسْحُ الْحَصَی فَقَالَ : إِنْ کُنْتَ لاَ بُدَّ فَاعِلاً فَوَاحِدَۃً۔ (بخاری 1207۔ ابوداؤد 943)",,,7910,,
7911,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ أَبِی ذِئْبٍ ، عَنْ شُرَحْبِیلَ أَبِی سَعدٍ ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ ، قَالَ : سَأَلْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ مَسْحِ الْحَصَی فِی الصَّلاَۃ فَقَالَ : وَاحِدَۃٌ وَلأَنْ تُمْسِکَ عَنْہَا خَیْرٌ لَکَ مِنْ مِئَۃ نَاقَۃٍ کُلُّہَا سُودُ الْحَدَقَۃِ۔ (احمد 3/300۔ احمد 328)",,,7911,,
7912,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ مُحَمَّدِ بْنِ طَلْحَۃَ بْنِ رُکَانَۃَ ، عَنْ عَبْدِ اللہِ بْنِ عَیَّاشِ بْنِ أَبِی رَبِیعَۃَ ، قَالَ : مَرَّ بِی أَبُو ذَرٍّ وَأَنَا أُصَلِّی قَالَ : إنَّ الأَرْضَ لاَ تُمْسَحُ إِلاَّ وَاحِدَۃً۔",,,7912,,
7913,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، قَالَ : کَانَ عَبْدُ اللہِ یُرَخِّصُ فِی مَسْحَۃٍ وَاحِدَۃٍ لِلْحَصَی۔",,,7913,,
7914,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، عَنْ عَمِّہِ ، قَالَ : رَأَیْتُُ ابْنَ مَسْعُودٍ یُسَوِّی الْحَصَی بِیَدِہِ وَہُوَ یُصَلِّی خَبَطَہُ بِیَدِہِ ، ثُمَّ سَجَدَ۔",,,7914,,
7915,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ الشَّیْبَانِیِّ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، عَنْ أَبِیہِ ، قَالَ : رَأَیْتُ عَبْدَ اللہِ بْنَ مَسْعُودٍ خبَطَ الْحَصَی بِیَدِہِ ، ثُمَّ سَجَدَ۔",,,7915,,
7916,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، عَنْ أَبِی ہُرَیْرَۃَ : أَنَّہُ کَانَ یُرَخِّصُ أن تُسَوَّی الْحَصَی فِی الصَّلاَۃ مَرَّۃً وَاحِدَۃً ، قَالَ : وَإِنْ لَمْ یَفْعَلْ فَہُوَ أَحَبُّ إلَیَّ۔",,,7916,,
7917,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَبْدِ الْحَمِیدِ بْنِ جَعْفَرٍ ، عَنْ نَافِعٍ ، قَالَ : کَانَ ابْنُ عُمَرَ مِمَّا یُسَوِّی الْحَصَی بِرِجْلِہِ وَہُوَ قَائِمٌ فِی الصَّلاَۃ۔",,,7917,,
7918,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مَالِکُ بْنُ أَنَسٍ ، عَنْ أَبِی جَعْفَرٍ الْقَارِیِٔ مَوْلَی ابْنِ عَیَّاشٍ ، قَالَ : رَأَیْتُُ ابْنَ عُمَرَ یَمْسَحُ الْحَصَی مَسْحًا خَفِیفًا فِی الصَّلاَۃ۔",,,7918,,
7919,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إسْرَائِیلُ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : رَأَیْتُُ ابْنَ عُمَرَ یُسَوِّی الْحَصَی بِرِجْلِہِ فِی الصَّلاَۃ۔",,,7919,,
7920,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : قَالَ حُذَیْفَۃُ : ہَکَذَا وَاحِدَۃً ، أَوْ دَعْ ، وَمَسَحَ بِیَدِہِ الأَرْضَ۔ قَالَ أَبُو أُسَامَۃَ : یَعْنِی تَسْوِیَۃَ الْحَصَی ، أَوْ شَیْئٌ فِی مَوْضِعِ سُجُودِہِ۔",,,7920,,
7921,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی صَالِحٍ ، قَالَ : کَانَ یُرَخَّصُ فِی مَسْحَۃٍ وَاحِدَۃٍ لِلْحَصَی۔",,,7921,,
7922,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ أَبِی مَالِکٍ الأَشْجَعِیِّ ، عَنْ إبْرَاہِیمَ : أَنَّہُ لَمْ یَرَ بَأْسًا بِتَسْوِیَۃِ الْحَصَی مَرَّۃً وَاحِدَۃً۔",,,7922,,
7923,"حَدَّثَنَا عَبْدُ الْوَہَّابِ بْنُ عَطَائٍ ، عَنِ الأَغَرِّ بْنِ یَحْیَی ، قَالَ : رَأَیْتُ الْحَسَنَ یُوضَعُ الْحَصَی مَوْضِعَ سُجُودِہِ وَہُوَ فِی الصَّلاَۃ۔",,,7923,,
7924,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عِمْرَانُ بْنُ زَائِدَۃَ بْنِ نَشِیطٍ ، عَنْ نُفَیْعٍ أَبِی دَاوُد ، قَالَ : خَرَجْتُ مَعَ ابْنِ عَبَّاسٍ مِنَ الْمَسْجِدِ فَخَلَعْتُ خُفَّیَّ فَسَمِعَ وَقْعَ حَصَاۃٍ ، فَقَالَ ابْنُ عَبَّاسٍ : رُدَّہَا وَإِلاَّ خَاصَمَتْک یَوْمَ الْقِیَامَۃِ۔",,,7924,,
7925,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إسْرَائِیلُ ، عَنْ أَبِی حَصِینٍ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، أَوْ عَنْ کَعْبٍ، قَالَ : إنَّ الْحَصَاۃَ إذَا أُخْرِجَتْ مِنَ الْمَسْجِدِ تُنَاشِدُ صَاحِبَہَا۔ (ابوداؤد 460)",,,7925,,
7926,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مَالِکُ بْنُ مِغْوَلٍ ، عَنْ زُبَیْدِ بْنِ الْحَارِثِ ، عَنْ مُجَاہِدٍ ، قَالَ : حَدِیث لَیْسَ بِمُحْدَثٍ : إذَا أُخْرِجَت الْحَصَی مِنَ الْمَسْجِدِ صَاحَتْ ، أَوْ سَبَّحَتْ۔",,,7926,,
7927,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ حَمَّادًا عَنِ الْحَصَی یُخْرَجُ بِہِنَّ مِنَ الْمَسْجِدِ ؟ قَالَ : انْبِذْ بِہِنَّ۔ وَسَأَلْت الْحَکَمَ ، فَقَالَ : صُرَّہُنَّ حَتَّی تَرُدَّہُنَّ ، فَإِنِّی بَلَغَنِی أَنَّ لَہُنَّ صِیَاحًا۔",,,7927,,
7928,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ دَاوُدَ أَبِی الْہَیْثُمِ ، قَالَ : سَأَلْتُ ابْنَ سِیرِینَ عَنِ الرَجُلِ یَقُولُ لِغُلاَمٍ لَہُ ، أَوْ لِخَادِمِہِ : إِنْ وَجَدْت فِی خُفَّیَّ حَصَاۃً فَرُدَّہَا إلَی الْمَسْجِدِ۔",,,7928,,
7929,"حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ لَیْثٍ ، عَنْ حَبِیبٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : الْحَصَاۃُ تَسُبُّ وَتَلْعَنَ مَنْ یُخْرِجُہَا مِنَ الْمَسْجِدِ۔",,,7929,,
7930,"حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ ، عَنْ مُثَنَّی بْنِ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ ، قَالَ : الْحَصَاۃُ إذَا أُخْرِجَتْ مِنَ الْمَسْجِدِ تَصِیحُ حَتَّی تُرَدَّ إلَی مَوْضِعِہَا۔",,,7930,,
7931,"حَدَّثَنَا أَسْبَاطٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : الْحَصَاۃُ تَصِیحُ إذَا أُخْرِجَتْ مِنَ الْمَسْجِدِ۔",,,7931,,
7932,"حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْحَکَمِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إذَا کُنْتَ فِی صَلاَۃٍ فَلاَ تُحَرِّکِ الْحَصَی۔",,,7932,,
7933,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ الْوَلِیدِ بْنِ أَبِی ہَاشِمٍ ، عَنْ مُسْلِمِ بْنِ أَبِی مَرْیَمَ ، قَالَ : رَأَی ابْنُ عُمَرَ رَجُلاً یُقَلِّبُ الْحَصَی فِی الصَّلاَۃ ، فَقَالَ : لاَ تُقَلِّبِ الْحَصَاۃَ فِی الصَّلاَۃ ، فَإِنَّہُ مِنَ الشَّیْطَانِ۔",,,7933,,
7934,حَدَّثَنَا مُعْتَمِرٌ ، عَنْ لَیْثٍ ، عَنْ طَلْحَۃَ ، قَالَ تَقْلِیبُ الْحَصَی أَذَی للْمَلَکِ۔,,,7934,,
7935,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَلِیِّ بْنِ الأَقْمَرِ ، قَالَ : صَلَّیْتُ إلَی جَنْبِ مَسْرُوقٍ فَمَسِسْتُ الْحَصَی فَضَرَبَ بِیَدَیَّ۔",,,7935,,
7936,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ زِیَادِ بْنِ فَیَّاضٍ ، قَالَ : صَلَّیْتُ إلَی جَنْبِ أَبِی عِیَاضٍ فَمَسِسْت الْحَصَی فَضَرَبَ یَدی ، فَلَمَّا قَضَی صَلاَتَہُ قَالَ : إِنَّہُ یُقَالُ فِی ہَذَا قَوْلًا شَدِیدًا۔",,,7936,,
7937,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ أَبِی إِسْحَاقَ، عَنِ الْحَارِثِ، عَنْ عَلِیٍّ قَالَ: إذَا صَلَّیْتَ فَلاَ تَعْبَثْ بِالْحَصَی۔",,,7937,,
7938,"حَدَّثَنَا وَکِیعٌ ، عَنْ عِمْرَانَ بْنَ حُدَیْرٍ ، عَنْ دینَارمَوْلَی عَطِیَّۃَ ، قَالَ : صَلَّیْتُ إلَی جَنْبِ قَیْسِ بْنِ عُبَادٍ فَأَخَذْت عُودًا فَرَفَعْتُہُ إلَی فَمی فَضَرَبَ ذَقَنِی ، فَلَمَّا صَلَّی قُلْتُ لَہُ مَا حَمَلَک ؟ وَقَدْ أَعْجَبَنِی ، فَقَالَ : کَانَ یُقَالُ: مَنْ عَبِثَ بِشَیْئٍ فِی صَلاَتِہِ کَانَ حَظَّہُ مِنْ صَلاَتِہِ۔",,,7938,,
7939,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ : أَنَّہُ کَانَ یَکْرَہُ أَنْ یَعْبَثَ الرَّجُلُ بِشَیْئٍ فِی صَلاَتِہِ۔",,,7939,,
7940,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مَعْمَرٍ عَنْ عَبْدِ الرَّحْمَنِ قَالَ : صَلَّیْتُ إلَی جَنْبِ رَجُلٍ مِنْ أَصْحَابِ عَبْدِ اللہِ ، فَمَسِسْت الْحَصَی ، فَلَمَّا صَلَّی قَالَ : قَالَ عَبْدُ اللہِ : لاَ یَسْأَلَنَّ أَحَدُکُمْ رَبَّہُ شَیْئًا مِنَ الْخَیْرِ وَفِی یَدِہِ الْحَجَرُ۔",,,7940,,
7941,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا أَبِی ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ : أَنَّہُ کَرِہَ الْعَبَثَ فِی الصَّلاَۃ۔",,,7941,,
7942,"حَدَّثَنَا شَرِیکٌ ، عَنْ عَبْدِ الْمَلِکِ بْنِ عُمَیْرٍ ، عَنْ زِیَادٍ الْحَارِثِیِّ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : رَأَیْتُُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی وَہُمَا عَلَیْہِ وَخَرَجَ وَہُمَا عَلَیْہِ ، یَعْنِی نَعْلَیْہِ۔",,,7942,,
7943,"حَدَّثَنَا عَبَّادُ بْنُ عَوَّامٍ ، عَنْ حُسَیْنِ الْمُکْتِبِ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُصَلِّی حَافِیًا وَمُنْتَعِلاً۔ (ابوداؤد 653۔ احمد 2/174)",,,7943,,
7944,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنِ النُّعْمَانِ بْنِ سَالِمٍ ، عَنِ ابْنِ أَبی أَوْسٍ ، عَنْ جَدِّہِ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی فِی نَعْلَیْہِ۔ (طیالسی 1111۔ احمد 4/8)",,,7944,,
7945,حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ النُّعْمَانِ بْنِ سَالِمٍ ، عَنِ ابْنِ أَبی أَوْسٍ ، عَنْ جَدِّہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِمِثْلِہِ۔ (ابن ماجہ 1037),,,7945,,
7946,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ السُّدِیِّ عَمَّنْ سَمِعَ عَمْرَو بْنَ حُرَیْثٍ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی فِی نَعْلَیْہِ۔ (نسائی 9805۔ احمد 4/307)",,,7946,,
7947,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُلَیْمَانَ بْنِ الْمُغِیرَۃِ ، عَنْ حُمَیْدِ بْنِ ہِلاَلٍ الْعَدَوِیِّ ، عَمَّنْ سَمِعَ الأَعْرَابِیَّ یَقُولُ : رَأَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّی فِی نَعْلَیْنِ مِنْ بَقَرٍ۔ (احمد 6)",,,7947,,
7948,"حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : سَأَلْتُ عَطَائً أَیُصَلِّی الرَّجُلُ فِی نَعْلَیْہِ ؟ فَقَالَ : نَعَمْ ، قَدْ صَلَّی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی نَعْلَیْہِ۔",,,7948,,
7949,"حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْحَکَمِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی فِی نَعْلَیْہِ۔",,,7949,,
7950,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنِ الْحَکَمِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، قَالَ : صَلَّی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی نَعْلَیْہِ فَصَلَّی النَّاسُ فِی نِعَالِہِمْ ، فَخَلَعَ فَخَلَعُوا ، فَلَمَّا صَلَّی قَالَ : مَنْ شَائَ أَنْ یُصَلِّیَ فِی نَعْلَیْہِ فَلْیُصَلِّ وَمَنْ شَائَ أَنْ یَخْلَعَ فَلْیَخْلَع",,,7950,,
7951,"حَدَّثَنَا عُبَیْدُ بن سَعِیدٍ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی مَسلَمَۃَ ، قَالَ : سَأَلْتُ أَنَسًا أَیُصَلِّی الرَّجُلُ فِی نَعْلَیْہِ ؟ فَقَالَ: قَدْ صَلَّی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی نَعْلَیْہِ۔ (بخاری 386۔ مسلم 60)",,,7951,,
7952,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : خَلَعَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَعْلَیْہِ وَہُوَ فِی الصَّلاَۃ ، فَخَلَعَ النَّاسُ نِعَالَہُمْ ، ثُمَّ لَبِسَہُمَا فَلَمْ یُرَ نَازِعَہُمَا بَعْدُ۔",,,7952,,
7953,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ أَبِی الْعُمَیْسِ ، عَنِ الْقَاسِمِ ، قَالَ : کَانَ عَبْدُ اللہِ یُصَلِّی فِی نَعْلَیْہِ۔",,,7953,,
7954,"حَدَّثَنَا عَبْدَۃُ ، وَأَبُو خَالِدٍ ، عَنْ عُثْمَانَ بْنِ حَکِیمٍ ، قَالَ : رَأَیْتُُ أَبَا جَعْفَرٍ وَعَلِیَّ بْنَ حُسَیْنٍ یُصَلِّیَانِ فِی نِعَالِہِمَا۔",,,7954,,
7955,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ ، قَالَ : قُلْتُ لِشُرَیْحٍ أُصَلِّی فِی نَعْلِی ؟ فَلَمْ یَکْرَہْہُ۔",,,7955,,
7956,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ أَبِی خَالِدٍ ، قَالَ : رَأَیْتُُ الأَسْوَدَ یُصَلِّی فِی نَعْلَیْہِ ، وَرَأَیْتُ أَبَا عَمْرٍو الشَّیْبَانِیَّ یَضْرِبُ النَّاسَ إذَا خَلَعُوا نِعَالَہُمْ فِی الصَّلاَۃ۔",,,7956,,
7957,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ زِیَادِ بْنِ فَیَّاضٍ ، عَنْ شَیْخٍ لَہُمْ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی فِی نَعْلٍ مَخْصُوفَۃٍ۔",,,7957,,
7958,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، قَالَ : رَأَیْتُ إبْرَاہِیمَ التَّیْمِیَّ یَؤُمُّ قَوْمَہُ عَلَیْہِ نَعْلاَہُ۔",,,7958,,
7959,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ : أَنَّہُ کَانَ یُصَلِّی فِی نَعْلَیْہِ۔",,,7959,,
7960,"حَدَّثَنَا عَبْدَۃُ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ، قَالَ: کَانَ عُمَرُ یَشتَد عَلَی النَّاسِ فِی خَلْعِ نِعَالِہِمْ فِی الصَّلاَۃ۔",,,7960,,
7961,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ یَزِیدَ مَوْلَی سَلَمَۃَ ، قَالَ : رَأَیْتُ سَلَمَۃَ یُصَلِّی فِی نَعْلَیْہِ۔",,,7961,,
7962,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ کَانَ یُصَلِّی فِی نَعْلَیْہِ۔",,,7962,,
7963,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی حَمْزَۃَ ، قَالَ : رَأَیْتُ ابْنَ عَبَّاسٍ یُصَلِّی فِی نَعْلَیْہِ۔",,,7963,,
7964,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الْحَسَنِ بْنِ عُبَیدِ اللہِ ، قَالَ : کَانَ إبْرَاہِیمُ یَکْرَہُ خَلْعَ النِّعَالِ فِی الصَّلاَۃ وَیَقُولُ: وَدِدْت أَنَّ إنْسَانًا مُحْتَاجًا أَتی الْمَسْجِدِ فَأَخَذَ نِعَالَہُمْ۔",,,7964,,
7965,"حَدَّثَنَا حَفْصٌ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ : أَنَّہُ کَانَ یُصَلِّی فِی نَعْلَیْہِ۔",,,7965,,
7966,"حَدَّثَنَا عَفَانُ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ عَبْدِ اللہِ بْنِ إیَاسٍ الْحَنَفِیِّ ، عَنْ أَبِیہِ ، قَالَ : رَأَیْتُ عُثْمَانَ یُصَلِّی فِی نَعْلَیْہِ۔",,,7966,,
7967,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، قَالَ : رَأَیْتُُ الْقَاسِمَ وَسَالِمًا یُصَلِّیَانِ فِی نِعَالِہِمَا۔",,,7967,,
7968,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی الْمِقْدَامِ ، قَالَ : رَأَیْتُُ سَعِیدَ بْنَ الْمُسَیَّبِ وَعَطَائَ بْنَ یَسَارٍ وَسَالِمًا وَالْقَاسِمَ یُصَلُّونَ فِی نِعَالِہِمْ۔",,,7968,,
7969,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ خُضَیْرٍ ، قَالَ : رَأَیْتُُ مُجَاہِدًا وَعَطَائً وَطَاوُوسا یُصَلُّونَ فِی نِعَالِہِمْ۔",,,7969,,
7970,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عُقْبَۃُ بْنُ أَبِی صَالِحٍ ، قَالَ : کُنْتُ عِنْدَ إبْرَاہِیمَ وَہُوَ خَالِعٌ نَعْلَیْہِ ، فَلَمَّا أَقَامَ الْمُؤَذِّنُ لَبِسَہُمَا۔",,,7970,,
7971,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إبْرَاہِیمُ بْنُ إسْمَاعِیلَ بْنِ مُجَمِّعِ بْنِ جَارِیَۃَ ، عَنْ یَعْقُوبَ بْنِ مُجَمِّعٍ ، قَالَ : أَوَّلُ مَنْ صَلَّی فِی نَعْلَیْہِ عُوَیْمُ بْنُ سَاعِدَۃَ۔",,,7971,,
7972,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عِمْرَانُ بْنُ حُدَیْرٍ ، عَنْ أَبِی مِجْلَزٍ ، أَنَّہُ کَانَ یُصَلِّی فِی نَعْلَیْہِ۔",,,7972,,
7973,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إسْرَائِیلُ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ : أَنَّہُ کَانَ یَخْلَعُ نَعْلَیْہِ ، فَلَمَّا قَامَ إلَی الصَّلاَۃ لَبِسَہُمَا۔",,,7973,,
7974,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ أَبِی نَعَامَۃَ ، عَنْ أَبِی نَضْرَۃَ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ: أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی فَخَلَعَ نَعْلَیْہِ فَخَلَعَ النَّاسُ نِعَالَہُمْ ، فَلَمَّا انْصَرَفَ قَالَ : لِمَ خَلَعْتُمْ نِعَالَکُمْ ؟ قَالُوا : یَا رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَأَیْنَاک خَلَعْتَ فَخَلَعْنَا ، فَقَالَ : إنَّ جِبْرِِیلَ أَتَانِی فَأَخْبَرَنِی أَنَّ فِیہِمَا خَبَثًا فَإِذَا جَائَ أَحَدُکُمْ إلَی الْمَسْجِدِ فَلْیَقْلِبْ نَعْلَیْہِ وَلْیَنْظُرْ فِیہِمَا فَإنْ رَأی فِیہِمَا خَبَثًا فَلْیَمْسَحْہُ بِالأَرْضِ وَلْیُصَلِّ فِیہِمَا۔ (احمد 3/20۔ دارمی 1378)",,,7974,,
7975,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا یَزِیدُ بْنُ إبْرَاہِیمَ التُّسْتَرِیُّ ، عَنِ الْحَسَنِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : تَعَاہَدُوا نِعَالَکُمْ فَإِنْ رَأَی أَحَدُکُمْ فِیہِمَا أَذًی فَلْیُمِطْہُ وَإلا فَلْیُصَلِّ فِیہِمَا۔",,,7975,,
7976,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا زُہَیْرٌ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَلْقَمَۃَ قَالَ ، وَلَمْ یَسْمَعْہُ مِنْہُ ، عَنْ عَبْدِ اللہِ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی فِی نَعْلَیْہِ۔ (طیالسی 395۔ احمد 1/461)",,,7976,,
7977,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ غَیْلاَنَ بْنِ عَبْدِ اللہِ مَوْلَی بَنِی مَخْزُومٍ قَالَ : رَأَیْتُُ ابْنَ عُمَرَ یَنْتَعِلُ ہَذِہِ السِّبْتِیَّۃَ فَإِذَا صَلَّی خَلَعَہُمَا۔",,,7977,,
7978,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شَرِیکٌ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الأَحْوَص ، أَنَّ ابْنَ مَسْعُودٍ أَتَی أَبَا مُوسَی فِی دَارِہِ فَحَضَرَتِ الصَّلاَۃ ، فَقَالَ أَبُو مُوسَی لِعَبْدِ اللہِ : تَقَدَّمْ ، فَقَالَ عَبْدُ اللہِ : أَنْتَ أَحَقُّ ، فَتَقَدَّمَ أَبُو مُوسَی فَخَلَعَ نَعْلَیْہِ ، فَقَالَ لَہُ : عَبْدُ اللہِ أَبِالْوَادِی الْمُقَدَّسِ أَنْتَ؟۔ (عبدالرزاق 1507)",,,7978,,
7979,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ مُحَمَّدِ بْنِ عَبَّادٍ ، عَنْ عَبْدِ اللہِ بْنِ سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ السَّائِبِ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی یَوْمَ فَتْحِ مَکَّۃَ فَجَعَلَ نَعْلَیْہِ عَنْ یَسَارِہِ۔ (ابوداؤد 648۔ احمد 3/411)",,,7979,,
7980,"حَدَّثَنَا وَکِیعٌ ، قَالَ : أَخْبَرَنَا ابْنُ أَبِی ذِئْبٍ ، عَنْ سَعِیدٍ الْمَقْبُرِیِّ ، عَنْ أَبِیہِ ، قَالَ : قُلْتُ لأَبِی ہُرَیْرَۃَ : کَیْفُ أَصْنَعُ بِنَعْلِی إذَا صَلَّیْت ؟ قَالَ : اجْعَلْہُمَا بَیْنَ رِجْلَیْک ، وَلاَ تُؤْذِ بِہِمَا مُسْلِمًا۔",,,7980,,
7981,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مُوسَی بْنُ عُبَیْدَۃَ ، قَالَ : سَمِعْتُ نَافِعَ بْنَ جُبَیْرٍ یَقُولُ : وَضْعُ الرَّجُلِ نَعْلَہُ مِنْ قدمہِ فِی الصَّلاَۃ بِدْعَۃٌ۔",,,7981,,
7982,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ حَکِیمٍ الْحَضْرَمِیِّ ، قَالَ : رَأَیْتُُ ابْنَ عُمَرَ خَلَعَ نَعْلَیْہِ فَجَعَلَہُمَا خَلْفَہُ۔",,,7982,,
7983,"حَدَّثَنَا شَبَابَۃُ ، قَالَ : حدَّثَنَا ابْنُ أَبِی ذِئْبٍ ، عَنِ الْمَقْبُرِیِّ ، عَنْ أَبِیہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا صَلَّی أَحَدُکُمْ فَلْیَجْعَلْ نَعْلَیْہِ بَیْنَ رِجْلَیْہِ۔ (ابوداؤد 1655۔ ابن حبان 2182)",,,7983,,
7984,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ قَالَ : أَخْبَرَنَا أَبُو نَعَامَۃَ السَّعْدِیُّ ، عَنْ أَبِی نَضْرَۃَ ، عَنْ أَبِی سَعِیدٍ ، قَالَ : بَیْنَمَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّی فَخَلَعَ نَعْلَیْہِ فَوَضَعَہُمَا عَنْ یَسَارِہِ۔ (ابوداؤد 650۔ احمد 3/92)",,,7984,,
7985,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَلْقَمَۃَ بْنِ مَرْثَدٍ ، عَنْ سُلَیْمَانَ بْنِ بُرَیْدَۃَ ، عَنْ أَبِیہِ ، قَالَ : صَلَّی بِنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ رَجُلٌ : مَنْ دَعَا إلَی الْجَمَلِ الأَحْمَر ؟ فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ وَجَدْتَ إنَّمَا بُنِیَتِ الْمَسَاجِدُ لِمَا بُنِیَتْ لَہُ۔ (مسلم 81۔ احمد 5/361)",,,7985,,
7986,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ سَعْدِ بْنِ إِبْرَاہِیمَ ، عَن أَبِیہِ ، قَالَ : سَمِعَ عُمَرُ بْنُ الْخَطَّابِ رَجُلاً رَافِعًا صَوْتَہُ فِی الْمَسْجِدِ ، فَقَالَ : أَتَدْرِی أَیْنَ أَنْتَ۔",,,7986,,
7987,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الْعُمَرِیُّ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ : أَنَّ عُمَرَ نَہَی عَنِ اللَّغَطِ فِی الْمَسْجِدِ ، وَقَالَ : إنَّ مَسْجِدَنَا ہَذَا لاَ تُرْفَعُ فِیہِ الأَصْوَاتُ۔",,,7987,,
7988,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ہِشَامٌ ، عَنْ أَبِیہِ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سَمِعَ رَجُلاً یَنْشُدُ ضَالَّۃً فِی الْمَسْجِدِ ، فَقَالَ : لاَ وَجَدْتَ۔",,,7988,,
7989,"حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ عَوْنٍ ، أَوْ عَاصِمٍ قَالَ : وَلاَ أَعْلَمُہُ إِلاَّ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : سَمِعَ ابْنُ مَسْعُودٍ رَجُلاً یَنْشُدُ ضَالَّۃً فِی الْمَسْجِدِ ، فَقَامَ إلَیْہِ فَنَالَ مِنْہُ۔",,,7989,,
7990,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الْبَیْعِ وَالشِّرَائِ فِی الْمَسْجِدِ ، وَعَنْ إنْشَادِ الضَّوَالِّ۔ (ترمذی 322۔ احمد 2/179)",,,7990,,
7991,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ عَمْرِو بْنِ أَبِی عَمْرٍو ، عَنْ أَنَسِ بْنِ مَالِکٍ ، قَالَ: دَخَلَ رَجُلٌ یَنْشُدُ ضَالَّۃً فِی الْمَسْجِدِ ، فَسَمِعَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَوْتَہُ ، فَقَالَ : لاَ وَجَدْتَ۔",,,7991,,
7992,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ قَالَ : حدَّثَنَا عُبَیْدُ اللہِ بْنُ عُمَرَ ، عَنْ نَافِعٍ ، أَنَّ عَبْدَ اللہِ أَخْبَرَہُ : أَنَّ عُمَرَ کَانَ إذَا خَرَجَ إلَی الصَّلاَۃ نَادَی فِی الْمَسْجِدِ ، قَالَ : إیَّاکُمْ وَاللَّغَطَ۔",,,7992,,
7993,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ، عَنِ ابْنِ الْمُنْکَدِرِ، سَمِعَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجُلاً یَنْشُدُ ضَالَّۃً فِی الْمَسْجِدِ، فَقَالَ : أَیُّہَا النَّاشِدُ غَیْرُکَ الْوَاجِدُ۔",,,7993,,
7994,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ سَعِیدٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قولُوا لاَ وَجَدْتَ۔",,,7994,,
7995,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، قَالَتْ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا حَضَرَتِ الصَّلاَۃ وَوُضِعَ الْعَشَائُ فَابْدَؤُوا بِالْعَشَائِ۔ (بخاری 671۔ مسلم 65)",,,7995,,
7996,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ أَنَسٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : إذَا حَضَرَ الْعَشَائُ وَأُقِیمَتِ الصَّلاَۃ فَابْدَؤُوا بِالْعَشَائِ۔ (بخاری 672۔ ترمذی 353)",,,7996,,
7997,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، قَالَ : حدَّثَنَا عَبْدُ اللہِ بْنُ رَافِعٍ ، عَنْ أُمِّ سَلَمَۃَ ، قَالَت : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا حَضَرَ الْعَشَائُ وَحَضَرَتِ الصَّلاَۃُ فَابْدَؤُوا بِالْعَشَائِ۔ (احمد 6/291۔ ابویعلی 6957)",,,7997,,
7998,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حدَّثَنَا عُبَیْدُ اللہِ بْنُ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا وُضِعَ عَشَائُ أَحَدِکُمْ وَأُقِیمَتِ الصَّلاَۃ فَابْدَؤُوا بِالْعَشَائِ وَلاَ یَعْجَلَنَّ حَتَّی یَفْرُغَ مِنْہُ۔\n\nقَالَ نَافِعٌ : وَکَانَ ابْنُ عُمَرَ یُوضَعُ لَہُ الطَّعَامُ فَتُقَامُ الصَّلاَۃ فَلاَ یَأْتِیہَا حَتَّی یَفْرُغَ وَإِنَّہُ لیَسْمَعُ قِرَائَۃَ الإِمَام۔ (بخاری 673۔ ابوداؤد 3751)",,,7998,,
7999,"حَدَّثَنَا ہَاشِمُ بْنُ الْقَاسِمِ ، عَنْ أَیُّوبَ بْنِ عُتْبَۃَ ، عَنْ إیَاسِ بْنِ سَلَمَۃَ ، عَنْ أَبِیہِ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : إذَا حَضَرَتِ الصَّلاَۃ وَالْعَشَائُ فَابْدَؤُوا بِالْعَشَائِ۔ (احمد 4/49۔ طبرانی6250)",,,7999,,
8000,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ سُفْیَانَ بْنِ حُسَیْنٍ ، عَنِ الزُّہْرِیِّ ، عَنْ أَنَسِ بْنِ مَالِکٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا حَضَرَتِ الْعَشَائُ وَالصَّلاَۃ فَابْدَؤُوا بِالْعَشَائِ۔ (احمد 3/238)",,,8000,,
8001,"حَدَّثَنَا ہُشَیْمٌ قَالَ: أَخْبَرَنَا حُمَیْدٌ، عَنْ أَنَسِ بْنِ مَالِکٍ مِثْلَ ذَلِکَ، وَلَمْ یَذْکُرِ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,8001,,
8002,"حَدَّثَنَا عَبْدُ الْوَہَّابِ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا حَضَرَ الْعَشَائُ وَأُقِیمَتِ الصَّلاَۃ فَابْدَؤُوا بِالْعَشَائِ۔",,,8002,,
8003,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ ثَابِتٍ ، عَنْ أَنَسِ بْنِ مَالِکٍ ، قَالَ : کُنَّا عَلَی طَعَامٍ لَنَا وَحَضَرَتِ الصَّلاَۃُ فَحَبَسَنِی أَبُو طَلْحَۃَ۔",,,8003,,
8004,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنِ ابْنٍ لأَبِی الْمَلِیحِ ، عَنْ أَبِیہِ ، قَالَ : کُنَّا مَعَ أَبِی بَکْرٍ وَقَدْ خَرَجَ لِصَلاَۃِ الْمَغْرِبِ وَأَذَّنَ الْمُؤَذِّنُ فَتُلُقِّیَ بِقَصْعَۃٍ فِیہَا ثَرِیدٌ وَلَحْمٌ ، فَقَالَ : اجْلِسُوا فَکُلُوا فَإِنَّمَا صُنِعَ الطَّعَامُ لِیُؤْکَلَ ، فَأَکَلَ ، ثُمَّ دَعَا بِمَائٍ فَغَسَلَ أَطْرَافَ أَصَابِعِہِ وَمَضْمَضَ وَصَلَّی۔",,,8004,,
8005,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ أَبِی عَاصِمٍ ، عَنْ عَلِیِّ بْنِ عُبَیْدِ اللہِ ، قَالَ : دَعَانَا یَسَارُ بْنُ نُمَیْرٍ إلَی طَعَامٍ عِنْدَ الْمَغْرِبِ ، فَقَالَ : إنَّ عُمَرَ بْنَ الْخَطَّابِ کَانَ یَقُولُ : ابْدَؤُوا بِطَعَامِکُمْ ، ثُمَّ افْرُغُوا لِصَلاَتِکُمْ۔",,,8005,,
8006,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ أَبِی عَاصِمٍ ، عَنْ یَسَارِ بْنِ نُمَیْرٍ ، قَالَ : قَالَ عُمَرُ : إذَا وُضِعَ الْعَشَائُ وَأُقِیمَتِ الصَّلاَۃ فَابْدَؤُوا بِالْعَشَائِ۔",,,8006,,
8007,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ قَنَانِ بْنِ عَبْدِ اللہِ النَّہْمِیِّ ، عَنْ أَشْیَاخٍ لَہُمْ ، قَالُوا : کُنَّا عِنْدَ عَلِیٍّ وَحَضَرَ الْفِطْرُ فِی رَمَضَانَ ، فَقَالَ لَنَا عَلِیٌّ : أَفْطِرُوا ، فَإِنَّہُ أَحْسَنُ لِصَلاَتِکُ",,,8007,,
8008,"حَدَّثَنَا شَرِیکٌ، عَنْ أَبِی إِسْحَاقَ: أَنَّ الْحَسَنَ بْنَ عَلِیٍّ کَانَ یَقُولُ الْعَشَائُ قَبْلَ الصَّلاَۃ یُذْہِبُ النَّفْسَ اللَّوَّامَۃَ۔",,,8008,,
8009,"حَدَّثَنَا وَکِیعٌ ، عَنْ شَرِیکٍ ، عَنْ عُثْمَانَ الثَّقَفِیِّ ، عَنْ رَجُلٍ یُقَالُ لَہُ زِیَادٌ ، قَالَ : کُنَّا عِنْدَ ابْنِ عَبَّاسٍ وَشِوَائٌ لَہُ فِی التَّنُّورِ وَحَضَرَتِ الصَّلاَۃُ فَقُلْنَا لَہُ ، فَقَالَ : لاَ حَتَّی نَأْکُلَ لاَ یَعْرِضُ لَنَا فِی صَلاَتِنَا۔",,,8009,,
8010,"حَدَّثَنَا جَرِیرٌ ، عَنْ یزِیْدٍ ، عَنْ عَبْدِ اللہِ بْنِ الْحَارِثِ ، قَالَ : إذَا جِیئَ بِعَشَائِکَ وَنُودِیَ بِالصَّلاَۃ فَابْدَأْ بِالْعَشَائِ ، ثُمَّ الصَّلاَۃ۔",,,8010,,
8011,"حَدَّثَنَا شَبَابَۃُ ، عَنْ سُلَیْمَانَ بْنِ الْمُغِیرَۃِ ، عَنْ ثَابِتٍ ، عَنْ أَنَسٍ ، قَالَ : قَدِمْتُ مِنَ الْعِرَاقِ فَقُرِّبَ عَشَائُ أَبِی طَلْحَۃَ وَمَعَہُ مَنْ شَائَ اللَّہُ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ لِی : ہَلُمَّ فَکُلْ فَقُلْت : حَتَّی أُصَلِّیَ ، فَقَالَ : قَدْ أَخَذْتَ بِأَخْلاَقِ أَہْلِ الْعِرَاقِ ہَلُمَّ فَکُلْ۔",,,8011,,
8012,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ الْجُرَیرِیِّ ، عَنْ عَبْدِ اللہِ بْنِ بُرَیْدَۃَ ، قَالَ : قَالَ عَبْدُ اللہِ بْنُ عَمْرٍو : مَا أُبَالِی کَانَا مَصْرُورَیْنِ فِی نَاحِیَۃِ ثَوْبِی ، أَوْ نَازَعَانِی فِی صَلاَتِی۔",,,8012,,
8013,"حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنْ لَیْثٍ، عَنْ مُجَاہِدٍ، قَالَ: قَالَ عُمَرُ: لاَ تُعَالِجُوا الأَخْبَثَیْنِ فِی الصَّلاَۃ الْغَائِطَ وَالْبَوْلَ۔",,,8013,,
8014,حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی حُرَّۃَ ، عَنِ الْحَسَنِ ، عَنْ عُمَرَ ، بِنَحْوِ ذَلِکَ۔,,,8014,,
8015,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ حُمَیْدِ بْنِ ہِلاَلٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ یُصَلِّیَنَّ أَحَدُکُمْ وَہُوَ یُدَافِعُ الطَّوْفَ الْغَائِطَ وَالْبَوْلَ۔",,,8015,,
8016,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ کَثِیرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ قَالَ : مَا أُبَالِی دَافَعْتُہُ ، أَوْ صَلَّیْتُ وَہُوَ فِی جَانِبِ ثَوْبِی۔",,,8016,,
8017,"حَدَّثَنَا زَیْدُ بْنُ حُبَاب ، عَنْ مُعَاوِیَۃَ بْنِ صَالِحٍ ، قَالَ : حدَّثَنِی السَّفْرُ بْنُ نُسَیْرٍ الأَسَدِیُّ ، عَنْ یَزِیدَ بْنِ شُرَیْحٍ الْحَضْرَمِیِّ ، أَنَّہُ سَمِعَ أَبَا أُمَامَۃَ یَقُولُ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَأْتِی أَحَدُکُمُ الصَّلاَۃ وَہُوَ حَاقِنٌ حَتَّی یَتَخَفَّفَ۔ (احمد 5/250۔ طبرانی 7507)",,,8017,,
8018,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ إدْرِیسَ ، عَنْ أَبِیہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : لاَ یَقُومُ أَحَدُکُمْ إلَی الصَّلاَۃ وَبِہِ أَذًی۔ (احمد 2/442۔ ابن حبان 2072)",,,8018,,
8019,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ زَمْعَۃَ ، عَنْ عُثْمَانَ بْنِ الزُّبَیْرِ ، عَنْ یَحْیَی بْنِ جَعْدَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَقْرَبُ الصَّلاَۃ الزَّنیء قِیلَ : یَا رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَمَا الزَّنیء ؟ قَالَ : الَّذِی یَجِدُ الرِّزّ فِی بَطْنِہِ۔",,,8019,,
8020,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ سَعِیدِ بْنِ أَبِی صَدَقَۃَ ، عَنْ یَحْیَی بْنِ عَتِیقٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : یُکْرَہُ حَبْسُ الأَذَی مَا لَمْ یَخَفْ فَوْتَ الصَّلاَۃ۔",,,8020,,
8021,"حَدَّثَنَا حَفْصٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ عَبْدِ اللہِ بْنِ الأَرْقَمِ ، قَالَ : خَرَجَ مُعْتَمِرًا مَعَ أَصْحَابِہِ فَأَذَّنَ وَأَقَامَ ، وَقَالَ لِبَعْضِ أَصْحَابِہِ : تَقَدَّمْ إنِّی سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : إذَا حَضَرَتِ الصَّلاَۃ وَأَحَدُکُمْ یُرِیدُ الْخَلاَئَ فَابْدَأْ بِالْخَلاَئِ۔ (ترمذ ی142۔ ابوداؤد 89)",,,8021,,
8022,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : سُئِلَ نَافِعٌ عَنِ الرَّجُلِ یَجِدُ النَّفْخَۃَ فِی بَطْنِہِ ؟ قَالَ : لاَ یُصَلِّی وَہُوَ یَجِدُ النَّفْخَۃَ۔",,,8022,,
8023,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ أَبِی حَزْرَۃَ شَیْخٍ مِنْ أَہْلِ الْمَدِینَۃِ وَأَثْنَی عَلَیْہِ خَیْرًا ، عَنِ الْقَاسِمِ بْنِ مُحَمَّدٍ، قَالَ : دَخَلَ بَعْضُ بَنِی أَخِی عَائِشَۃَ إلَیْہَا فَقَامَ إلَی الْمَسْجِدِ ، فَقَالَتْ لَہُ : اجْلِسْ إنِّی سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : لاَ یُصَلِّی أَحَدُکُمْ بِحَضْرَۃِ طَعَامٍ ، وَلاَ ہُوَ یُدَافِعُ الأَخْبَثَیْنِ۔ (مسلم 393۔ ابن حبان 2073)",,,8023,,
8024,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ أَبِیہِ ، عَنْ عِکْرِمَۃَ ، قَالَ : لأَنْ أَصُرَّہُ فِی عِمَامَتِی ، ثُمَّ أَقُومَ إلَی الصَّلاَۃ أَحَبُّ إلَیَّ مِنْ أَنْ أُدَافِعَہُ وَأَنَا أُصَلِّی ، یَعْنِی الْغَائِطَ وَالْبَوْلَ۔",,,8024,,
8025,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ أَبِیہِ ، عَنْ بَکْرٍ ، قَالَ : لأَنْ أُہْرِیقَ الْمَائَ وَأَتَیَمَّمَ وَأُصَلِّیَ أَحَبُّ إلَیَّ مِنْ أَنْ أُصَلِّیَ وَأَنَا أُدَافِعُ غَائِطًا ، أَوْ بَوْلاً۔",,,8025,,
8026,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ فِی الرَّجُلِ یَجِدُ الْبَوْلَ أَوِ النَّفْخَۃَ ، قَالَ : یُصَلِّی مَا لَمْ یُعَجِّلْہُ عَنْ صَلاَتِہِ۔",,,8026,,
8027,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، قَالَ : نُبِّئْتُ عَنْ طَاوُوسٍ قَالَ : إنَّا لَنَصُرُّہُ صَرًّا۔",,,8027,,
8028,"حَدَّثَنَا ہُشَیْمٌ ، وَابْنُ عُلَیَّۃَ ، عَنِ ابن عَوْنٍ ، عَنْ إبْرَاہِیمَ قَالَ : ذَکَرُوا عِنْدَہُ الرَّجُلَ یَجِدُ الْبَوْلَ ، قَالَ ہُشَیْمٌ : وَیَجِدُ النَّفْخَۃَ أَیَتَوَضَّأُ ؟ فَقَالَ : إذنْ وَاللَّہِ لاَ نَزَالُ نَتَوَضَّأُ۔",,,8028,,
8029,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : ذَکَرْت ذَلِکَ لِمُحَمَّدٍ ، فَقَالَ : کَانُوا یَرَوْنَہُ مَا وَجَدَ بُدًّا۔",,,8029,,
8030,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ وَاصِلٍ ، عَنْ عَطَائٍ ، قَالَ : قُلْتُ لَہُ : أَجِدُ الْعَصْرَ مِنَ الْبَوْلِ فَتَحْضُرُ الصَّلاَۃ فَأُصَلِّی وَأَنَا أَجِدُہُ ، قَالَ : نَعَمْ إِنْ کُنْتَ تَرَی أَنَّک تَحْبِسُہُ حَتَّی تُصَلِّی۔",,,8030,,
8031,"حَدَّثَنَا وَکِیعٌ، عَنْ إسْرَائِیلَ، عَنْ جَابِرٍ، عَنْ مُحَمَّدِ بْنِ عَلِیٍّ وَعَامِرٍ وَعَطَائٍ، قَالُوا: لاَ بَأْسَ أَنْ یَحْقِنَ الرَّجُلُ۔",,,8031,,
8032,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِاللہ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ أَنْ یَحْقِنَ الرَّجُلُ الْبَوْلَ مَا لَمْ یُعْجِلہُ عَنِ الرُّکُوعِ وَالسُّجُودِ۔",,,8032,,
8033,"حَدَّثَنَا حَفْصٌ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ، عَنْ أَبِیہِ، قَالَ: قَالَ عُمَرُ: إنِّی لأَحْسِبُ جِزْیَۃَ الْبَحْرَیْنِ وَأَنَا فِی الصَّلاَۃ۔",,,8033,,
8034,"حَدَّثَنَا حَفْصٌ، عَنْ عَاصِمٍ، عَنْ أَبِی عُثْمَانَ النَّہْدِیِّ، قَالَ: قَالَ عُمَرُ: إنِّی لأُجَہِّزُ جُیُوشِی وَأَنَا فِی الصَّلاَۃ۔",,,8034,,
8035,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : سَأَلْتُ مُحَمَّدًا عَنِ الإِمَام یُصَلی بِالقَوم یَقُومُ فِی زَاوِیَۃٍ وَلاَ یَقُومُ وَسَطًا ؟ فَقَالَ : لاَ أَعْلَمُ بِہِ بَأْسًا۔",,,8035,,
8036,"حَدَّثَنَا بِشْرُ بْنُ مُفَضَّلٍ ، عَنْ قُرَّۃَ ، قَالَ : کَانَ أَبُو الْعَلاَئِ یَسْتَعْرِضُ بِنَا الظِّلَّ فَیُصَلِّی بِنَا أَیَّ نَوَاحِی الْمَسْجِدِ کَانَ۔",,,8036,,
8037,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مُغِیرَۃُ بْنُ زِیَادٍ الْمَوْصِلِیُّ ، قَالَ : رَأَیْتُ عَطَائً یُصَلِّی فِی السَّقِیفَۃِ فِی الْمَسْجِدِ الْحَرَامِ فِی النَّفَرِ وَہُمْ مُتَفَرِّقُونَ عَنِ الصُّفُوفِ فَقُلْتُ لَہُ ، أَوْ قِیلَ لَہُ ، فَقَالَ : إنِّی شَیْخٌ کَبِیرٌ وَمَکَّۃُ دَوِّیَّۃٌ ، قَدْ کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی سَفَرٍ فَأَصَابَہُ مَطَرٌ فَصَلَّی بِالنَّاسِ وَہُمْ فِی رِحَالِہِمْ وَبِلاَلٌ یُسْمِعُ النَّاسَ التَّکْبِیرَ۔",,,8037,,
8038,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ زَیدَ ، عَنِ الزُّبَیْرِ بْنِ الْخِرِّیتِ ، عَنْ عَبْدِ اللہِ بْنِ شَقِیقٍ الْعُقَیْلِیِّ قَالَ : رُبَّمَا أَمَّنَا ابْنُ عَبَّاسٍ فِی زَاوِیَۃِ الْمَسْجِدِ ، وَلاَ یَتَوَسَّطُہُ۔",,,8038,,
8039,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ، قَالَ: حدَّثَنَا سُفْیَانُ، عَنْ أَبِی عَرُوبَۃَ قَالَ: رَأَیْتُُ الْحَسَنَ الْبَصْرِیَّ یَؤُمُّہُمْ فِی زَاوِیَۃٍ۔",,,8039,,
8040,"حَدَّثَنَا حَفْصٌ ، عَنْ عَاصِمٍ ، عَنْ أَبِی عُثْمَانَ ، قَالَ : قَالَ بِلاَلٌ : یَا رَسُولَ اللہِ لاَ تَسْبِقْنِی بِآمِینَ۔ (ابوداؤد 934۔ احمد 6/15)",,,8040,,
8041,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدٍ ، عَنْ أَبِی ہُرَیْرَۃَ رفعہ ، قَالَ : إذَا أَمَّنَ الْقَارِیئُ فَأَمِّنُوا فَمَنْ وَافَقَ تَأْمِینُہُ تَأْمِینَ الْمَلاَئِکَۃِ غُفِرَ لَہُ مَا تَقَدَّمَ مِنْ ذَنْبِہِ۔ (بخاری 6402۔ مسلم 72)",,,8041,,
8042,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ الْجَبَّارِ بْنِ وَائِلٍ ، عَنْ أَبِیہِ ، قَالَ : صَلَّیْتُ خَلْفَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَلَمَا قَالَ {غَیْرِ الْمَغْضُوبِ عَلَیْہِمْ وَلاَ الضَّالِّینَ} قَالَ : آمِینَ۔ (عبدالرزاق 2633۔ احمد 4/318)",,,8042,,
8043,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنْ حُجْرِ بْنِ عَنْبَسٍ ، عَنْ وَائِلِ بْنِ حُجْرٍ ، قَالَ : سَمِعْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَرَأَ : {وَلاَ الضَّالِّینَ} فَقَالَ : آمِینَ یَمُدُّ بِہَا صَوْتَہُ۔ (ترمذی 249۔ ابوداؤد 930)",,,8043,,
8044,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إسْرَائِیلُ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی مَیْسَرَۃَ : أَنَّ جِبْرِیل علیہ السلام أَقْرَأَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَاتِحَۃَ الْکِتَابِ ، فَلَمَا قَالَ : {وَلاَ الضَّالِّینَ} قَالَ : قُلْ آمِینَ ، فَقَالَ : آمِینَ۔",,,8044,,
8045,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا کَثِیرُ بْنُ زَیدٍ ، عَنِ الْوَلِیدِ بْنِ رَبَاحٍ ، عَنْ أَبِی ہُرَیْرَۃَ : أَنَّہُ کَانَ مُؤَذِّنًا بِالْبَحْرَیْنِ ، فَقَالَ لِلإِمَامِ : لاَ تَسْبِقْنِی بِآمِینَ۔",,,8045,,
8046,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا فِطْرٌ ، قَالَ : سَمِعْتُ عِکْرِمَۃَ یَقُولُ : أَدْرَکْتُ النَّاسَ وَلَہُمْ رَجَّۃٌ فِی مَسَاجِدِہِمْ بِآمِینَ إذَا قَالَ الإِمَام : {غَیْرِ الْمَغْضُوبِ عَلَیْہِمْ وَلاَ الضَّالِّینَ}۔",,,8046,,
8047,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، عْن أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّمَا جُعِلَ الإِمَام لِیُؤْتَمَّ بِہِ فَإذَا قَالَ : {غَیْرِ الْمَغْضُوبِ عَلَیْہِمْ وَلاَ الضَّالِّینَ} فَقُولُوا : آمِینَ۔ (ابن ماجہ 846۔ مالک 45)",,,8047,,
8048,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ سَعِید ، عَنْ قَتَادَۃَ ، عَنْ یُونُسَ بْنِ جُبَیْرٍ ، عَنْ حِطَّانَ بْنِ عَبْدِ اللہِ ، عَنْ أَبِی مُوسَی، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِمِثْلِہِ۔ (مسلم 63۔ ابوداؤد 964),,,8048,,
8049,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ أَبِیہِ ، عَنْ أَبِی یَعْلَی ، قَالَ : کَانَ الرَّبِیعُ بْنُ خُثَیم إذَا قَالَ الإِمَام : {غَیْرِ الْمَغْضُوبِ عَلَیْہِمْ وَلاَ الضَّالِّینَ} فَقَالَ : اللَّہُمَّ اغْفِرْ لِی آمِینَ۔",,,8049,,
8050,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا یُونُسُ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ بَکْرِ بْنِ مَاعِز ، عَنِ الرُّبَیعِ بْنِ خُثَیم ، قَالَ : إذَا قَالَ الإِمَام : {غَیْرِ الْمَغْضُوبِ عَلَیْہِمْ وَلاَ الضَّالِّینَ} فَاسْتَعِنْ مِنَ الدُّعاء بِمَا شِئْتَ۔",,,8050,,
8051,"حَدَّثَنَا أَبُو الأَحْوَصِ، عَنْ أَبِی حَمْزَۃَ، عَنْ إبْرَاہِیمَ، قَالَ: کَانَ یُسْتَحَبُّ إذَا قَالَ الإِمَام: {غَیْرِ الْمَغْضُوبِ عَلَیْہِمْ وَلاَ الضَّالِّینَ} أَنْ یُقَالَ : اللَّہُمَّ اغْفِرْ لِی آمِینَ۔",,,8051,,
8052,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، قَالَ : صَلَّیْتُ خَلْفَ أَبِی عَبْدِ اللہِ الْجَدَلِیِّ ، فَلَمَا قَالَ : {غَیْرِ الْمَغْضُوبِ عَلَیْہِمْ وَلاَ الضَّالِّینَ} قَالَ : کَفَی بِاللَّہِ ہَادِیًا وَنَصِیرًا۔",,,8052,,
8053,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ یُونُسَ ، عَنْ مُجَاہِدٍ ، قَالَ : إذَا قَالَ الإِمَام : {غَیْرِ الْمَغْضُوبِ عَلَیْہِمْ وَلاَ الضَّالِّینَ} فَقُلْ : اللَّہُمَّ إنِّی أَسْأَلُک الْجَنَّۃَ وَأَعُوذُ بِکَ مِنَ النَّارِ۔",,,8053,,
8054,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ ہِلاَلِ بْنِ یَِسَافٍ ، قَالَ : آمِینَ اسْمٌ مِنْ أَسْمَائِ اللہِ۔",,,8054,,
8055,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا سُفْیَانُ ، عَنْ مَنْصُورٍ ، عَنْ ہِلاَلِ بْنِ یَِسَافٍ مِثْلَہُ۔",,,8055,,
8056,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ سُفْیَانَ ، عَنْ طَارِقٍ ، عَنْ حَکِیمِ بْنِ جَابِرٍ ، قَالَ : آمِینَ اسْمٌ مِنْ أَسْمَائِ اللہِ۔",,,8056,,
8057,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : آمِینَ اسْمٌ مِنْ أَسْمَائِ اللہِ۔",,,8057,,
8058,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الرَّبِیعُ ، عَنْ عَطَائٍ ، قَالَ : لَقَدْ کَانَ لَنَا دَوِیٌّ فِی مَسْجِدِنَا ہَذَا بِآمِینَ إذَا قَالَ الإِمَام : {غَیْرِ الْمَغْضُوبِ عَلَیْہِمْ وَلاَ الضَّالِّینَ}۔",,,8058,,
8059,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ رَجُلٍ ، عَنْ مُعَاذٍ : أَنَّہُ کَانَ إذَا خَتَمَ الْبَقَرَۃَ قَالَ : آمِینَ۔",,,8059,,
8060,"حَدَّثَنَا عُمَرُ بْنُ أَیُّوبَ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنْ أَبِی حَمْزَۃَ مَوْلَی الْمُہَلَّبِ : أَنَّہُ صَلَّی إلَی جَنْبِ سَعِیدِ بْنِ جُبَیْرٍ ، فَلَمَا قَالَ : {غَیْرِ الْمَغْضُوبِ عَلَیْہِمْ وَلاَ الضَّالِّینَ} قَالَ : آمِینَ ، أَوْ شَیْئًا ہَذَا مَعَنَاہُ۔",,,8060,,
8061,"حَدَّثَنَا أَبُو أُسَامَۃَ، عَنْ ہِشَامٍ، عَنْ مُحَمَّدٍ: أَنَّ أَبَا ہُرَیْرَۃَ کَانَ مُؤَذِّنًا بِالْبَحْرَیْنِ، فَقَالَ لِلإِمَامِ: لاَ تَسْبِقْنِی بِآمِینَ۔",,,8061,,
8062,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ رَجُلٍ ، أَنَّ مُعَاذًا کَانَ إذَا قَرَأَ آخِرَ الْبَقَرَۃِ {فَانْصُرْنَا عَلَی الْقَوْمِ الْکَافِرِینَ} قَالَ : آمِینَ۔",,,8062,,
8063,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، قَالَ : لَعَلَّہُ عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، عَنِ الزُّبَیْرِ ، قَالَ : کَانَ لِلْمَسْجِدِ رَجَّۃٌ ، أَوْ قَالَ لُجَّۃٌ إذَا قَالَ الإِمَام : {غَیْرِ الْمَغْضُوبِ عَلَیْہِمْ وَلاَ الضَّالِّینَ}۔",,,8063,,
8064,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سُہَیْلِ بْنِ أَبِی صَالِحٍ ، عَنِ ابْنِ أَبِی سَعِیدٍ الْخُدْرِیِّ ، عَنْ أَبِیہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا تَثَائَبَ أَحَدُکُمْ فِی الصَّلاَۃ فَلْیَکْظِمْ مَا اسْتَطَاعَ فَإِنَّ الشَّیْطَانَ یَدْخُلُ۔ (مسلم 58۔ ابوداؤد 4987)",,,8064,,
8065,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی فَزَارَۃَ الْعَبْسِیِّ ، عَنْ یَزِیدَ بْنِ الأَصَمِّ ، قَالَ : مَا تَثَائَبَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی صَلاَۃ قَطُّ۔",,,8065,,
8066,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مَنْصُورٍ ، عَنْ ہِلاَلِ بْنِ یَِسَافٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ: إذَا تَثَائَبَ أَحَدُکُمْ فِی الصَّلاَۃ فَلْیَضَعْ یَدَہُ عَلَی فِیہِ۔",,,8066,,
8067,عن قتادۃ بِمِثْلِ حَدِیثِ سُفْیَانَ۔,,,8067,,
8068,"حَدَّثَنَا عَبْدَۃَُ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ خِلاَسٍ ، عَنْ عَلِیٍّ ، قَالَ : التَّثَاؤُبُ فِی الصَّلاَۃ مِنَ الشَّیْطَانِ وَشِدَّۃُ الْعُطَاسِ وَالنُّعَاسُ عِنْدَ الْمَوْعِظَۃِ۔",,,8068,,
8069,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ یَزِیدَ عَنْ أَبِی ظَبْیَانَ ، عَنِ ابْنِ مَسْعُودٍ ، قَالَ : التَّثَاؤُبُ فِی الصَّلاَۃ وَالْعُطَاسُ مِنَ الشَّیْطَانِ فَتَعَوَّذُوا بِاللَّہِ مِنْہُ۔",,,8069,,
8070,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إنِّی لأَدْفَعُ التَّثَاوُبَ فِی الصَّلاَۃ بِالتَّنَحْنُحِ۔",,,8070,,
8071,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا تَثَائَبَ فِی الصَّلاَۃ ضَمَّ شَفَتَیْہِ ، وَمَسَحَ أَنْفَہُ۔",,,8071,,
8072,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، قَالَ : نُبِّئْتُ أَنَّ لِلشَّیْطَانِ قَارُورَۃً یُشِمُّہَا الْقَوْمَ فِی الصَّلاَۃ کَیْ یَتَثَائَبُوا۔",,,8072,,
8073,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الرَّبِیعُ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : یَرُدُّ الرَّجُلُ التَّثَاؤُبَ فِی الصَّلاَۃ مَا اسْتَطَاعَ ، فَإِنْ غَلَبَہُ وَضَعَ یَدَہُ عَلَی فِیہِ۔",,,8073,,
8074,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : التَّثَاؤُبُ فِی الصَّلاَۃ مِنَ الشَّیْطَانِ۔",,,8074,,
8075,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، قَالَ : إنَّ لِلشَّیْطَانِ قَارُورَۃً فِیہَا نَفُوخٌ فَإِذَا قَامُوا إلَی الصَّلاَۃ أُنْشَقُوہَا فَأُمِرُوا عِنْدَ ذَلِکَ بِالاسْتِنْثَارِ۔",,,8075,,
8076,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا أَبُو مَعْشَرٍ ، عَنْ سَعِیدٍ الْمَقْبُرِیِّ، عَنْ أَبِی ہُرَیْرَۃَ، قَالَ: إنَّ اللَّہَ یَکْرَہُ التَّثَاؤُبَ وَیُحِبُّ الْعُطَاسَ فِی الصَّلاَۃ۔",,,8076,,
8077,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنْ مُجَاہِدٍ ، قَالَ : إذَا تَثَائَبَ فِی الصَّلاَۃ فَلْیُمْسِکْ ، عَنِ الْقِرَائَۃِ۔",,,8077,,
8078,"حَدَّثَنَا أَبُو خَالِدٍ وَلَیْسَ بِالأَحْمَر ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، عَنْ یَعْلَی بْنِ حَکِیمٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : إذَا تَثَائَبَ أَحَدُکُمْ وَہُوَ یَقْرَأُ فَلْیُمْسِکْ عَنِ الْقِرَائَۃِ۔",,,8078,,
8079,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عَبَّادِ بْنِ تَمِیمٍ ، عَنْ عَمِّہِ : شُکِیَ إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الرَّجُلُ یَجِدُ الشَّیْئَ فِی الصَّلاَۃ یَتَشَبَّہُ عَلَیْہِ ، قَالَ : إِنَّہُ لاَ یَجِبُ عَلَیْہِ شَیْئٌ حَتَّی یَجِدَ رِیحَہُ ، وَیَسْمَعَ صَوْتَہُ۔ (بخاری 137۔ ابوداؤد 178)",,,8079,,
8080,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ مُبَارَکٍ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ عِیَاضِ بْنِ ہِلاَلٍ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا جَائَ أَحَدَکُمُ الشَّیْطَانُ وَہُوَ فِی صَلاَتِہِ فَقَالَ لَہُ : إنَّکَ قَدْ أَحْدَثْتَ فَلْیَقُلْ : کَذَبْتَ مَا لَمْ یَجِدْ رِیحَہُ بِأَنْفِہِ ، أَوْ یَسْمَعْ صَوْتَہُ بِأُذُنِہِ۔(ابوداؤد 1021۔ احمد 3/51)",,,8080,,
8081,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ سُہَیْلٍ ، عَنْ أَبِیہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ وُضُوئَ إِلاَّ مِنْ رِیحٍ ، أَوْ صَوْتٍ۔ (ترمذی 75۔ ابوداؤد 179)",,,8081,,
8082,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ عُبَیْدِ اللہِ ، عَنْ مُحَمَّدِ بْنِ عَمْرِو بْنِ عَطَائٍ ، قَالَ : رَأَیْتُُ السَّائِبَ بْنَ خَبَّابٍ یَشُمُّ ثَوْبَہُ فَقُلْتُ لَہُ : مِمَّ ذَلِکَ رَحِمَک اللَّہُ ؟ فَقَالَ : إنِّی سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : لاَ وُضُوئَ إِلاَّ مِنْ رِیحٍ ، أَوْ سَمَاعٍ۔ (احمد 3/426۔ طبرانی 6622)",,,8082,,
8083,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنِ الْمِنْہَالِ بْنِ عَمْرٍو ، عَنْ قَیْسِ بْنِ سَکَنٍ ، عَنْ عَبْدِ اللہِ ، قَالَ : إنَّ الشَّیْطَانَ یَأْتِی أَحَدَکُمْ وَہُوَ فِی الصَّلاَۃ فَیَبَلُّ إحْلِیلَہُ حَتَّی یَرَی أَنَّہُ قَدْ أَحْدَثَ ، وَأَنَّہُ یَأْتِیہِ فَیَضْرِبُ دُبُرَہُ ، فَیُرِیہِ أَنَّہُ قَدْ أَحْدَثَ ، فَلاَ تَنْصَرِفُوا حَتَّی تَجِدُوا رِیحًا ، أَوْ تَجِدُوا بَلَلاً۔",,,8083,,
8084,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا الْعَوَّامُ ، عَنْ إبْرَاہِیمِ التَّیْمِیِّ ، قَالَ : قَالَ عَبْدُ اللہِ : إنَّ الشَّیْطَانَ یَأْتِی أَحَدَکُمْ وَہُوَ فِی صَلاَتِہِ فَیَنْقُرُ دُبُرَہُ لِیُرِیَہُ أَنَّہُ قَدْ أَحْدَثَ ، فَإِذَا فَعَلَ ذَلِکَ فَلاَ یَنْصَرِفَنَّ أَحَدُکُمْ حَتَّی یَسْمَعَ صَوْتًا ، أَوْ یَجِدَ رِیحًا۔",,,8084,,
8085,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : سَأَلَہُ رَجُلٌ فَقَالَ لَہُ : إنَّ الشَّیْطَانَ یَأْتِینِی وَأَنَا فِی الصَّلاَۃ فَیُوَسْوِسُ إلیّ حَتَّی یَقُولَ : إنَّکَ قَدْ أَحْدَثْتَ ، فَقَالَ : لاَ یَنْصَرِفْ حَتَّی یَجِدَ لَہَا رِیحًا ، أَوْ یَسْمَعَ لَہَا طَنِینًا۔",,,8085,,
8086,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ حَرْمَلَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، أَنَّہُ سَمِعَہُ یَقُولُ : إنَّ الشَّیْطَانَ یَجْرِی مِنَ الإِنْسَان مَجْرَی الدَّمِ ، ثُمَّ یَنبِضُ عِنْدَ عِجَانِہِ فَیُخْرِجُہُ ، فَلاَ یَخْرُجُ أَحَدُکُمْ حَتَّی یَسْمَعَ حِسًّا ، أَوْ یَجِدَ رِیحًا۔",,,8086,,
8087,"حَدَّثَنَا عَبَّادٌ، عَنْ خَالِدٍ، عَنْ عِکْرِمَۃَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: لاَ یَنْصَرِفُ حَتَّی یَسْمَعَ صَوْتًا، أَوْ یَجِدَ رِیحًا۔",,,8087,,
8088,"حَدَّثَنَا حَفْصٌ ، عَنْ دَاوُدَ ، عَنْ شَہْرِ بْنِ حَوْشَبٍ ، قَالَ : إنَّ الشَّیْطَانَ لَیَأْتِی أَحَدَکُمْ فَیُدْخِلُ خَطْمہ فِی دُبُرِہِ فَیُحَرِّکُہُ وَیُحَرِّکُ إحْلِیلَہُ لِیَشِرَ ، فَلاَ یَنْصَرِفَنَّ حَتَّی یَسْمَعَ صَوْتًا ، أَوْ یَجِدَ رِیحًا۔",,,8088,,
8089,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ یَقُولُ : إنَّ الشَّیْطَانَ یَجْرِی فِی الإِحْلِیلِ فَیَنبِضُ عِنْدَ الدُّبُرِ فَیَرَی الرَّجُلُ أَنَّہُ قَدْ أَحْدَثَ ، فَلاَ یَنْصَرِفَنَّ أَحَدُکُمْ حَتَّی یَسْمَعَ صَوْتًا ، أَوْ یَجِدَ رِیحًا ، أَوْ یَرَی بَلَلاً۔",,,8089,,
8090,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِیہِ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : لاَ یَنْصَرِفُ حَتَّی یَسْمَعَ صَوْتًا ، أَوْ یَجِدَ رِیحًا۔",,,8090,,
8091,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، قَالَ : حَدَّثَنَا الْمِنْہَالُ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إنَّ الشَّیْطَانَ یَطِیفُ بِالْعَبْدِ لِیَقْطَعَ عَلَیْہِ صَلاَتَہُ فَإِذَا أَعْیَاہُ نَفَخَ فِی دُبُرِہِ فَلاَ یَنْصَرِفْ حَتَّی یَسْمَعَ صَوْتًا، أَوْ یَجِدَ رِیحًا ، وَیَأْتِیہِ فَیَعْصِرُ ذَکَرَہُ فَیُرِیہِ أَنَّہُ أُخْرِجَ مِنْہُ شَیْئٌ فَلاَ یَنْصَرِفْ حَتَّی یَسْتَیْقِنَ۔",,,8091,,
8092,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : قَالَ أَبُو ہُرَیْرَۃَ : إذَا شَکَّ أَحَدُکُمْ فِی الْبِلَّۃِ وَہُوَ فِی الصَّلاَۃ فَلْیَضَعْ یَدَیہ عَلَی الْحَصَی فَلْیَمْسَحْ إحْدَاہُمَا بِالأُخْرَی وَلْیَمْضِ فِی صَلاَتِہِ۔",,,8092,,
8093,"حَدَّثَنَا مُعْتَمِرٌ ، أَنَّہُ سَمِعَ أَبَاہُ یُحَدِّثُ : أَنَّ زَیْدَ بْنَ ثَابِتٍ وَحُذَیْفَۃَ وَالْحَسَنَ الْبَصْرِیَّ وَعَطَائً لَمْ یَرَوْا بَأْسًا بِالْبِلَّۃِ یَجِدُہَا الرَّجُلُ وَہُوَ یُصَلِّی ، إِلاَّ أَنَّ عَطَائً قَالَ : إِلاَّ أَنْ تَقْطُرَ ، قَالَ : وَقَالَ سَعِیدُ بْنُ الْمُسَیَّبِ : وَإِنْ قَطَرَ عَلَی رِجْلِکَ فَلاَ یَرَاہا ، ولا عَلَیْہِ إعَادَۃً وَلاَ طُہُور۔",,,8093,,
8094,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ أَبِیہِ ، قَالَ : حدَّثَنِی شَیْخٌ ، عَنِ الْحَسَنِ بْنِ عَلِیٍّ : أَنَّہُ سَأَلَ زَیْدَ بْنَ ثَابِتٍ عَنْ ذَلِکَ ، فَرَخَّصَ فِیہِ۔",,,8094,,
8095,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ یُونُسَ ، عَنْ حُمَیْدِ بْنِ ہِلاَلٍ ، قَالَ : سُئِلَ حُذَیْفَۃُ عَنِ الرَّجُلِ یَجِدُ الْبِلَّۃَ بَعْدَ الْوُضُوئِ ، فَقَالَ : مَا کُنْت أُبَالِی إذَا کَانَ ذَلِکَ بَعْدَ الْوُضُوئِ ذَاکَ کَانَ أَوْ ہَذَا ، وَأَوْمَأَ بِیَدِہِ إلَی فِیہِ۔",,,8095,,
8096,"حَدَّثَنَا أَبُو بَکْرٍ الْحَنَفِیُّ ، عَنِ الضَّحَّاکِ بْنِ عُثْمَانَ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ ، قَالَ : سَأَلْتُ سَعِیدَ بْنَ الْمُسَیَّبِ وَعُرْوَۃَ بْنَ الزُّبَیْرِ وَسُلَیْمَانَ بْنَ یَسَارٍ وَأَبَا سَلَمَۃَ بْنَ عَبْدِ الرَّحْمَنِ ، عَنِ الرَّجُلِ یَخْرُجُ مِنْہُ الْمَذْیُ فَکُلُّہُمْ قَالَ: أُنْزِلُہُ بِمَنْزِلَۃِ الْقُرْحَۃِ، مَا عَلِمْتَ مِنْہُ فَاغْسِلْہُ وَمَا غَلَبَکَ مِنْہُ فَدَعْہُ۔",,,8096,,
8097,"حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنْ مُحَمَّدِ بْنِ الْمُنْکَدِرِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا دَعَتْکَ أُمُّکَ فِی الصَّلاَۃ فَأَجِبْہَا ، وَإِذَا دَعَاکَ أَبُوکَ فَلاَ تُجِبْہُ۔",,,8097,,
8098,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، عَنْ مَکْحُولٍ ، قَالَ : إذَا دَعَتْکَ وَالِدَتُکَ وَأَنْتَ فِی الصَّلاَۃ فَأَجِبْہَا ، وَإِذَا دَعَاکَ أَبُوکَ فَلاَ تُجِبْہُ حَتَّی تَفْرُغَ۔",,,8098,,
8099,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ الْعَوَّامِ ، قَالَ : سَأَلْتُ مُجَاہِدًا ، قَالَ : قُلْتُ لَہُ : تُقَامُ الصَّلاَۃ وَتَدْعُونِی وَالِدَتِی ؟ قَالَ: أَجِبْ وَالِدَتَکَ۔",,,8099,,
8100,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ ہَمَّامِ بْنِ یَحْیَی ، قَالَ : حدَّثَنَا فَرْقَدٌ السَّبَخِیُّ ، عَنْ مُرَّۃَ الطَّیِّبِ ، عَنْ عُمَرَ ، أَنَّہُ کَرِہَ لِلرَّجُلِ أَنْ یُصَلِّیَ وَفِی رِجْلَیْہِ قَیْدٌ۔",,,8100,,
8101,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ سَعِیدِ بْنِ أَبِی صَدَقَۃَ ، قَالَ : قُلْتُ لِاِبْنِ سِیرِینَ : إذَا عَطَسْت فِی الصَّلاَۃ مَا أَقُولُ ؟ قَالَ : قُلِ : الْحَمْدُ لِلَّہِ رَبِّ الْعَالَمِینَ۔",,,8101,,
8102,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ : فِی الرَّجُلِ یَعْطِسُ فِی الصَّلاَۃ قَالَ : یَحْمَدُ اللَّہَ۔",,,8102,,
8103,"حَدَّثَنَا وَکِیعٌ، عَنْ رَبِیعٍ، عَنِ الْحَسَنِ: فِی الرَّجُلِ یَعْطِسُ فِی الصَّلاَۃ؟ قَالَ: یَحْمَدُ اللَّہَ فِی الْمَکْتُوبَۃِ وَغَیْرِہَا۔",,,8103,,
8104,"حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنْ حَجَّاجٍ الصَّوَّافِ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ ہِلاَلِ بْنِ أَبِی مَیْمُونَۃَ ، عَنْ عَطَائِ بْنِ یَسَارٍ ، عَنْ مُعَاوِیَۃَ بْنِ الْحَکَمِ السُّلَمِیِّ ، قَالَ: بَیْنََا أَنَا أُصَلِّی مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذْ عَطَسَ رَجُلٌ مِنَ الْقَوْمِ ، فَقُلْتُ : یَرْحَمُک اللَّہُ ، فَرَمَی الْقَوْمُ بِأَبْصَارِہِمْ ، فَقُلْتُ : وَاثُکْلَ أُمَّاہُ مَا شَأْنُکُمْ تَنْظُرُونَ إلَیَّ ؟ قَالَ : فَجَعَلُوا یَضْرِبُونَ بِأَیْدِیہِمْ عَلَی أَفْخَاذِہِمْ ، فَلَمَّا رَأَیْتُہُمْ یُصْمِتُونَنِی سَکَتُّ ، فَلَمَّا صَلَّی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِأَبِی ہُوَ وَأُمِّی مَا رَأَیْتُ مِثْلَہُ قَبْلَہُ وَلاَ بَعْدَہُ أَحْسَنَ تَعْلِیمًا مِنْہُ ، وَاللَّہِ مَا کَہَرَنِی ، وَلاَ شَتَمَنِی ، وَلاَ ضَرَبَنِی ، قَالَ : إنَّ ہَذِہِ الصَّلاَۃ لاَ یَصْلُحُ فِیہَا شَیْئٌ مِنْ کَلاَمِ النَّاسِ إنَّمَا ہِیَ التَّسْبِیحُ وَالتَّکْبِیرُ وَقِرَائَۃُ الْقُرْآنِ ، أَوْ کَمَا قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔ (مسلم 381۔ ابوداؤد 927)",,,8104,,
8105,"حَدَّثَنَا عَبْدَۃُ ، عَنْ سُفْیَانَ ، عَنْ غَالِبٍ أَبِی الْہُذَیْلِ ، قَالَ : سُئِلَ إبْرَاہِیمُ عَنْ رَجُلٍ عَطَسَ فِی الصَّلاَۃ ، فَقَالَ لَہُ آخَرُ وَہُوَ فِی الصَّلاَۃ : یَرْحَمُک اللَّہُ ، فَقَالَ إبْرَاہِیمُ : إنَّمَا قَالَ مَعْرُوفًا وَلَیْسَ عَلَیْہِ إعَادَۃٌ۔",,,8105,,
8106,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ : فِی رَجُلٍ عَطَسَ وَہُوَ فِی الصَّلاَۃ فَشَمَّتَہُ رَجُلٌ ، فَقَالَ وَہُوَ فِی الصَّلاَۃ : یَرْحَمُک اللَّہُ ، وَقَالَ إبْرَاہِیمُ : یَسْتَأْنِفُ۔",,,8106,,
8107,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَبْدِ الْحَمِیدِ بْنِ جُبَیْرِ بْنِ شَیْبَۃَ ، قَالَ : سَأَلْتُ سَعِیدَ بْنَ الْمُسَیَّبِ عَنِ الرَّجُلِ یَتَیَمَّمُ ثُمَّ یَجِدُ الْمَائَ فِی وَقْتٍ ؟ قَالَ : یُعِیدُ۔",,,8107,,
8108,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنِ الأَشْعَثِ ، عَنِ الْحَسَنِ وَمُحَمَّدٍ ، قَالاَ : إذَا تَیَمَّمَ ، ثُمَّ وَجَدَ الْمَائَ فِی وَقْتِ الصَّلاَۃ ، أَعَادَ الصَّلاَۃ۔",,,8108,,
8109,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ مُحَمَّدِ بْنِ مُسْلِمٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، عَنْ أَبِیہِ ؛ فِی الرَّجُلِ یَتَیَمَّمُ فَیُصَلِّی ، ثُمَّ یَجِدُ الْمَائَ فِی وَقْتٍ ، قَالَ : یُعِیدُ۔",,,8109,,
8110,"حَدَّثَنَا وَکِیعٌ ، عَنْ زَکَرِیَّا ، عَنِ الشَّعْبِیِّ ؛ فِی الرَّجُلِ یَتَیَمَّمُ ثُمَّ یَجِدُ الْمَائَ ، قَالَ : یُعِیدُ۔",,,8110,,
8111,"حَدَّثَنَا الْمُحَارِبِیُّ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ : یُعِیدُ۔",,,8111,,
8112,"حَدَّثَنَا الْمُحَارِبِیُّ ، عَنِ الْعَلاَئِ ، عَنْ عَطَائٍ قَالَ : یُعِیدُ۔",,,8112,,
8113,"حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنْ عُثْمَانَ بن أبی عثمان ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ ، قَالَ : یُعِیدُ۔",,,8113,,
8114,"حَدَّثَنَا عَبْدَۃُ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، قَالَ : إذَا أَصَابَ الْمَائَ فِی وَقْتٍ أَعَادَ الصَّلاَۃ۔",,,8114,,
8115,"حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : یُعِیدُ الصَّلاۃَ۔",,,8115,,
8116,"حَدَّثَنَا وَکِیعٌ ، عَنْ لَیْثِ بْنِ سَعْدٍ ، عَنْ بَکْرِ بْنِ سَوَادَۃَ ، عَنْ عَطَائِ بْنِ یَسَارٍ : أَنَّ رَجُلَیْنِ أَصَابَتْہُمَا جَنَابَۃٌ فَتَیَمَّمَا فَصَلَّیَا ، ثُمَّ أَدْرَکَا الْمَائَ فِی وَقْتٍ فَأَعَادَ أَحَدُہُمَا وَلَمْ یُعِدِ الأَخَرُ فَذُکِرَ ذَلِکَ لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : أَمَّا الَّذِی أَعَادَ فَلَہُ أَجْرُہَا مَرَّتَیْنِ ، وَأَمَّا الأَخَرُ فَقَدْ أَجْزَأَتْ عَنْہُ صَلاَتُہُ۔ (ابوداؤد 342۔ دارقطنی 2)",,,8116,,
8117,"حَدَّثَنَا شَرِیکٌ ، عَنِ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : یَتَلَوَّمُ الْجُنُبُ مَا بَیْنَہُ وَبَیْنَ آخِرِ الْوَقْتِ ، فَإِنْ وَجَدَ الْمَائَ تَوَضَّأَ ، وَإِنْ لَمْ یَجِدِ الْمَائَ تَیَمَّمَ وَصَلَّی ، فَإِنْ وَجَدَ الْمَائَ بَعْدُ اغْتَسَلَ ، وَلَمْ یُعِدِ الصَّلاَۃ۔",,,8117,,
8118,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَبْدِ الْحَمِیدِ بْنِ جُبَیْرِ بْنِ شَیْبَۃَ ، عَنِ ابنِ سَلَمَۃَ ، عَنْ أَبِی سَلَمَۃَ ، قَالَ : لاَ یُعِیدُ۔",,,8118,,
8119,"حَدَّثَنَا وَکِیعٌ ، عَنِ الْعُمَرِیِّ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ : أَنَّہُ تَیَمَّمَ وَصَلَّی ، ثُمَّ دَخَلَ الْمَدِینَۃَ فِی وَقْتٍ فَلَمْ یُعِدْ۔",,,8119,,
8120,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا تَیَمَّمَ الرَّجُلُ فَصَلَّی ، ثُمَّ أَتَی الْمَائَ وَہُوَ فِی وَقْتٍ بَعْدَ مَا یَفْرُغُ مِنْ صَلاَتِہِ فَقَدْ فَرَغَ مِنْ صَلاَتِہِ۔",,,8120,,
8121,"حَدَّثَنَا أَبُو دَاوُدَ، عَنْ جَرِیرِ بْنِ حَازِمٍ، عَنْ قَیْسِ بْنِ سَعْدٍ، عَنْ مُجَاہِدٍ، قَالَ: لاَ یُعِیدُ، قَدْ مَضَتْ صَلاَتُہُ۔",,,8121,,
8122,"حَدَّثَنَا عَبْدَۃُ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ وَالشَّعْبِیِّ ، قَالاَ : إذَا صَلَّی لِغَیْرِ الْقِبْلَۃِ أَوْ تَیَمَّمَ ، أَوْ صَلَّی وَفِی ثَوْبِہِ دَمٌ أَوْ جَنَابَۃٌ ثُمَّ أَصَابَ الْمَائَ فِی وَقْتٍ أوْغَیْر وَقْتٍ ، فَلَیْسَ عَلَیْہِ إعَادَۃٌ۔",,,8122,,
8123,"حَدَّثَنَا وَکِیعٌ ، عَنْ یَزِیدَ بْنِ إبْرَاہِیمَ ، عَنِ الْحَسَنِ ، قَالَ : إذَا وَجَدَ الْمَائَ اغْتَسَلَ ، فَإِنْ شَائَ أَعَادَ ، وَإِنْ شَائَ لَمْ یُعِدْ۔",,,8123,,
8124,"حَدَّثَنَا مُعْتَمِرٌ ، عَنِ الْحَکَمِ بْنِ أَبَانَ ، عَنْ عِکْرِمَۃَ ، قَالَ : کُنْتُ أَنَا فِی رُفْقَۃٍ ، وعِکْرِمَۃُ فی رُفْقَۃٍ ، فَلَمْ یَکُنْ مَعَ عِکْرِمَۃَ وَأَصْحَابِہِ مَائٌ فَتَیَمَّمُوا وَصَلَّوْا فَأَتَوْا عَلَی الْمَائِ ، فَقَالَ لَہُم عِکْرِمَۃُ : تَرَوْنَ الشَّمْسَ عَلَی رَأْسِ الْجَبَلِ ؟ فَقَالُوا : لاَ ، قَالَ : لَوْ رَأَیْتُمُوہَا لَمْ نُعِدْ إذًا کَفَانَا التَّیَمُّمُ ، فَقَالَ : فَانْطَلَقْتُ حَتَّی دَخَلْت الْجَنَد فَلَقِیتُ عَمْرَو بْنَ مُسْلِمٍ صَاحِبَ طَاوُوس ، فَحَدَّثْتُہُ بِمَا قَالَ عِکْرِمَۃُ ، فَانْطَلَقَ إلَی طَاوُوس فَذَکَرَ ذَلِکَ لَہُ ثُمَّ رَجَعَ إلَیَّ فَقَالَ : ذَکَرْتُ لِطَاوُوس مَا قَالَ عِکْرِمَۃُ فَقَالَ : صَدَقَ۔",,,8124,,
8125,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ کَثِیرِ بْنِ نَبَاتَۃَ ، قَالَ : سَمِعْتُ ابْنَ سِیرِینَ یَقُولُ : خَرَجْتُ فِی سَفَرِ حَجٍّ أَوْ عُمْرَۃٍ ، فَلَمَّا کَانَ مِنْ آخِرِ اللَّیْلِ أَصَابَتْنِی جَنَابَۃٌ وَلَیْسَ مَعَنَا مَائٌ ، فَتَیَمَّمْت وَصَلَّیْت ، فَلَمَّا ارْتَفَعَ الضُّحَی قَالَ رَجُلٌ : یَا أَبَا بَکْرٍ أَعَدْتَ صَلاَتَکَ ؟ قَالَ : وَلَوْ لَمْ أَجِد الْمَائَ عِشْرِینَ سَنَۃً أَکُنْتُ أُعِیدُ صَلاَتِی۔",,,8125,,
8126,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ شُعْبَۃَ ، عَنِ الْمُخَوَّلِ ، عَنْ أَبِی سَعْدٍ ، عَنْ أَبِی رَافِعٍ ، قَالَ : مَرَّ بِی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَأَنَا سَاجِدٌ قَدْ عَقَصْتُ شَعْرِی فَحَلَّہُ ، أَوَ قَالَ : فَنَہَانِی عَنْہُ۔ (ابوداؤد 646۔ عبدالرزاق 2990)",,,8126,,
8127,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ أَبِی ہَاشِمٍ ، عَنْ مُجَاہِدٍ ، عَنْ عُمَرَ بْنِ الْخَطَّابِ وَحُذَیْفَۃَ ؛ فِی الرَّجُلِ یُصَلِّی وَہُوَ عَاقِصٌ شَعْرَہُ ، فَذَکَرَا حَدِیثًا غَیْرَ أَنَّ مَعَنَاہُ أَنَّہُمَا کَرِہَاہُ۔,,,8127,,
8128,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ زُہَیْرِ بْنِ مُحَمَّدٍ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، عْن أَبَانَ بْنِ عُثْمَانَ ، قَالَ : رَأَی عُثْمَانُ رَجُلاً یُصَلِّی وَقَدْ عَقَدَ شَعْرَہُ ، فَقَالَ : یَا ابْنَ أَخِی مَثَلُ الَّذِی یُصَلِّی وَقَدْ عَقَصَ شَعْرَہُ مَثَلُ الَّذِی یُصَلِّی وَہُوَ مَکْتُوفٌ۔",,,8128,,
8129,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ شَرِیکٍ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : کَانَ ابْنُ عَبَّاسٍ إذَا صَلَّی وَقَعَ شَعْرُہُ الأَرْضَ۔",,,8129,,
8130,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ، عَنِ الأَعْمَشِ، عَنْ زَیْدِ بْنِ وَہْبٍ ، عَنْ عَبْدِ اللہِ : أَنَّہُ دَخَلَ الْمَسْجِدَ فَإِذَا فِیہِ رَجُلٌ یُصَلِّی عَاقِصًا شَعْرَہُ ، فَلَمَّا انْصَرَفَ قَالَ عَبْدُ اللہِ : إذَا صَلَّیْت فَلاَ تَعْقِصْ شَعْرَکَ ، فَإِنَّ شَعْرَکَ یَسْجُدُ مَعَکَ وَلَکَ بِکُلِّ شَعَرَۃٍ أَجْرٌ ، فَقَالَ الرَّجُلُ : إنِّی أَخَافُ أَنْ یَتْرَبَ ، فَقَالَ : تَتْرِیبُہُ خَیْرٌ لَک۔",,,8130,,
8131,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ أَبِی فَرْوَۃَ ، قَالَ : کَانَ عَبْدُ الرَّحْمَنِ بْنُ أَبِی لَیْلَی یَضفِرُ شَعْرَہُ فَإِذَا صَلَّی نَشَرَہُ۔",,,8131,,
8132,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ : أَنَّہُ کَانَ یَکْرَہُ عَقْدَ الرَّجُلِ شَعْرَہُ فِی الصَّلاَۃ۔",,,8132,,
8133,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : لاَ یُصَلِّی الرَّجُلُ وَہُوَ عَاقِصٌ شَعْرَہُ۔",,,8133,,
8134,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، عَنِ ابْنِ عَبَّاسٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنَّہُ قَالَ : أُمِرْتُ أَنْ أَسْجُدَ عَلَی سَبْعَۃِ أَعْظُمٍ ، وَلاَ أَکُفَّ شَعْرًا ، وَلاَ ثَوْبًا۔",,,8134,,
8135,"حَدَّثَنَا شَبَابَۃُ ، عَنْ شُعْبَۃَ ، عَنْ عَمْرٍو ، عَنْ طَاوُوسٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : أُمِرَ نَبِیُّکُمْ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یُسْجَدَ عَلَی سَبْعَۃٍ وَأُمِرَ أَنْ لاَ یَکُفَّ شَعْرًا وَلاَ ثَوْبًا۔ (بخاری 815۔ ابوداؤد 886)",,,8135,,
8136,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، وَابْنُ إدْرِیسَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی وَائِلٍ ، عَنْ عَبْدِ اللہِ ، قَالَ : کُنَّا لاَ نَتَوَضَّأُ مِنْ مَوْطَِأ ، وَلاَ نَکُفُّ شَعْرًا وَلاَ ثَوْبًا فِی الصَّلاَۃ۔",,,8136,,
8137,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ أَبِی حَیَّانَ التَّیْمِیِّ ، عَنْ مُجَمِّعٍ ، قَالَ : کَانَ الْحَسَنُ بْنُ یَزِیدَ یبصرُ السُّیُوفَ فَکَانَ إِذَا أُتِیَ بِالسَّیْفِ لِیَنْظُرَ إلَیْہِ وَہُوَ فی الْمَسْجِدِ خَرَجَ بِہِ فَنَظَرَ إلَیْہِ۔",,,8137,,
8138,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مُعاذ ، عَنْ أَسْلَمَ الْمِنْقَرِیِّ ، عَنْ عَبْدِ اللہِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ أَبْزَی الْخُزَاعِیِّ ، قَالَ : لاَ یُسَلُّ السَّیْفُ فِی الْمَسْجِدِ۔",,,8138,,
8139,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : نَہَی أَو نُہِیَ عَنْ سَلِّ السَّیْفِ فِی الْمَسْجِدِ۔",,,8139,,
8140,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، سَمِعَ جَابِرًا یَقُولُ : مَرَّ رَجُلٌ فِی الْمَسْجِدِ بِسِہَامٍ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَمْسِکْ بِنِصَالِہَا۔ (بخاری 7074۔ مسلم 121)",,,8140,,
8141,"حَدَّثَنَا وَکِیعٌ ، عَنْ بُرَیدِ بْنِ عَبْدِ اللہِ ، عَنْ أَبِی بُرْدَۃَ ، عَنْ أَبِی مُوسَی ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا مَرَّ أَحَدُکُمْ بِالنَّبْلِ فِی الْمَسْجِدِ فَلْیُمْسِکْ عَلَی نُصُولِہَا۔ (بخاری 452۔ ابوداؤد 2580)",,,8141,,
8142,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : إذَا مَرَرْت بِنَبْلٍ فَامْسِکْ بِنِصَالِہَا۔",,,8142,,
8143,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ سُلَیْمَانَ بْنِ سُحَیْمٍ ، عَنْ إبْرَاہِیمَ بْنِ عَبْدِ اللہِ بْنِ مَعْبَدٍ ، عَنْ أَبِیہِ ، عَنِ ابْنِ عَبَّاسٍ، قَالَ : کَشَفَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ السِّتَارَۃَ وَالنَّاسُ صُفُوفٌ خَلْفَ أَبِی بَکْرٍ ، وَقَالَ : یَا أَیُّہَا النَّاسُ، إِنَّہُ لَمْ یَبْقَ مِنْ مُبَشِّرَاتِ النُّبُوَّۃِ إِلاَّ الرُّؤْیَا الصَّالِحَۃُ یَرَاہَا الْمُسْلِمُ أَوْ تُرَی لَہُ أَلاَ وَإِنِّی نُہِیتُ أَنْ أَقْرَأَ الْقُرْآنَ رَاکِعًا ، أَوْ سَاجِدًا۔",,,8143,,
8144,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ عَمْرٍو ، قَالَ : حَدَّثَنِی إبْرَاہِیمُ بْنُ عَبْدِ اللہِ بْنِ حُنَیْنٍ ، عَنْ أَبِیہِ ، قَالَ : سَمِعْتُ عَلِیًّا بِرَحْبَۃِ الْکُوفَۃِ یَقُولُ : نَہَانِی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، عَنْ قِرَائَۃِ الْقُرْآنِ وَأَنَا رَاکِعٌ۔ (مسلم 213۔ احمد 1/81)",,,8144,,
8145,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : لاَ تَقْرَأُ الْقُرْآنَ وَأَنْتَ رَاکِعٌ ، وَلاَ سَاجِدٌ۔",,,8145,,
8146,"حَدَّثَنَا ابْنُ إدْرِیسَ ، وَعُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ عُبَیْدِ اللہِ بْنِ أَبِی زِیَادٍ ، قَالَ : قرَأْتُُ السَّجْدَۃَ وَأَنَا سَاجِدٌ فَسَأَلْتُ سَعِیدَ بْنَ جُبَیْرٍ فَقَالَ : یُجْزِئُکََ وَلِمَ تَقْرَأْ وَأَنْتَ سَاجِدٌ۔",,,8146,,
8147,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنْ مُجَاہِدٍ ، قَالَ : لاَ قِرَائَۃَ فِی الرُّکُوعِ وَلاَ فِی السُّجُودِ ، إنَّمَا جُعِلاَ لِذِکْرِ اللہِ تَعَالَی۔",,,8147,,
8148,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُحَمَّدِ بْنِ قَیْسٍ ، عَنْ عَلِیِّ بْنِ مُدْرِکٍ ، عَنْ إبْرَاہِیمَ ، عَنِ الرَّبِیعِ بْنِ خُثَیْمٍ ، قَالَ : أَیَعْجِزُ أَحَدُکُمْ أَنْ یَقْرَأَ ثُلُثَ الْقُرْآنِ وَہُوَ رَاکِعٌ ، أَوْ سَاجِدٌ للہ الوَاحِدِ الصَّمَدِ۔",,,8148,,
8149,حَدَّثَنَا وَکِیعٌ ، عَنْ أَبَانَ بْنِ صَمْعَۃَ ، عَنْ شَیْخٍ کَانَ مَعَ ابْنِ الزُّبَیْرِ فَقَرَأَ الْبَقَرَۃَ وَہُوَ رَاکِعٌ ، ثُمَّ رَفَعَ رَأْسَہُ فَقَرَأَ آلَ عِمْرَانَ ، ثُمَّ سَجَدَ فَقَرَأَ النِّسَائَ ، ثُمَّ رَفَعَ رَأْسَہُ فَقَرَأَ الْمَائِدَۃَ۔,,,8149,,
8150,"حَدَّثَنَا عَبِیْدَۃُ بْنُ حُمَیْدٍ، عَنْ عَبْدِالْمَلِکِ، عَنْ عَطَائٍ، قَالَ: کَانَ عُبَیْدُ بْنُ عُمَیْرٍ یَقْرَأُ فِی الرُّکُوعِ وَالسُّجُودِ۔",,,8150,,
8151,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ : أَنَّہُ کَانَ لاَ یَرَی بَأْسًا إذَا عَجَّلَ الرَّجُلُ فَرَکَعَ وَبَقِیَ عَلَیْہِ مِنَ السُّورَۃِ آیَۃٌ أَوْ آیَتَانِ أَنْ یَقْرَأَہُمَا وَہُوَ رَاکِعٌ۔",,,8151,,
8152,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ أَبِی حَیَّانَ ، عَنْ أَبِیہِ ، قَالَ : مَا سَمِعْتُ الرَّبِیعَ بْنَ خُثَیْمٍ یَذْکُرُ شَیْئًا مِنْ أَمْرِ الدُّنْیَا إِلاَّ أَنِّی سَمِعْتُہُ مَرَّۃً یَقُولُ : کَمْ للتَّیمْ مَسْجِدًا۔",,,8152,,
8153,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَاصِمٍ ، قَالَ : سَمِعْتُ زِرًّا وأَبَا وَائِلٍ یَقُولاَنِ : مَسْجِدُ بَنِی فُلاَنٍ۔",,,8153,,
8154,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ : أَنَّہُ کَانَ یَکْرَہُ أَنْ یَقُولَ : مَسْجِدُ بَنِی فُلاَنٍ ، وَلاَ یَرَی بَأْسًا أَنْ یَقُولَ : مُصَلَّی بَنِی فُلاَنٍ۔",,,8154,,
8155,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُحَمَّدِ بْنِ قَیْسٍ ، عَنْ مُحَارِبٍ ، عَنْ جَابِرٍ ، أَنَّہُ قَالَ : فَانْأ مَسْجِدَ مُعَاذٍ۔",,,8155,,
8156,"حَدَّثَنَا جَرِیرٌ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ رُفَیْعٍ ، عَنْ عَطَائٍ ، عَنِ ابن عَبَّاسٍ ، قَالَ : تؤَخِّرُ الْمُسْتَحَاضَۃُ الظُّہْرَ وَتُعَجِّلُ الْعَصْرَ ، وَتَقْرِنُ بَیْنَہُمَا ، وَتَغْتَسِلُ مَرَّۃً وَاحِدَۃً ، وَتُؤَخِّرُ الْمَغْرِبَ ، وَتُعَجِّلُ الْعِشَائَ ، وَتَغْتَسِلُ مَرَّۃً وَاحِدَۃً ، وَتَغْتَسِلُ لِلْفَجْرِ۔",,,8156,,
8157,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ الأَجْلَحِ ، عَنْ عِکْرِمَۃَ : فِی الْمُسْتَحَاضَۃِ ، قَالَ : تَجْمَعُ بَیْنَ الصَّلاَتَیْنِ۔",,,8157,,
8158,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حَنْظَلَۃَ ، عَنِ الْقَاسِمِ قَالَ : إِنْ شَائَتْ فَلْتَجْمَعْ بَیْنَہُمَا۔",,,8158,,
8159,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ حَرْمَلَۃَ ، سَمِعَ أَبَا سَلَمَۃَ بْنَ عَبْدِ الرَّحْمَنِ یَقُولُ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَغْلِبَنَّکُمُ الأَعْرَابُ عَلَی اسْمِ صَلاَتِکُمْ فَإِنَّمَا ہِیَ الْعِشَائُ وَإِنَّمَا تَدْعُونَہَا الْعَتَمَۃُ لإعْتَامِ الإِبِلِ۔",,,8159,,
8160,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی لَبِیدٍ ، عَنْ أَبِی سَلَمَۃَ بْنِ عَبْدِ الرَّحْمَنِ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تَغْلِبَنَّکُمُ الأَعْرَابُ عَلَی اسْمِ صَلاَتِکُمُ الْعِشَائِ ، فَإِنَّمَا ہِیَ فِی کِتَابِ اللہِ الْعِشَائُ ، وَإِنَّمَا یُعْتَمُ بِحِلاَبِ الإِبِلِ۔ (مسلم 229۔ احمد 2/10)",,,8160,,
8161,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ أَبِی رَوَّادٍ ، عَنْ رَجُلٍ لَمْ یُسَمِّہِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَوْفٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَغْلِبَنَّکُمُ الأَعْرَابُ عَلَی اسْمِ صَلاَتِکُمُ الْعِشَائِ ، فَإِنَّمَا ہِیَ فِی کِتَابِ اللہِ الْعِشَائُ ، وَإِنَّمَا یُعْتَمُ بِحِلاَبِ الإِبِلِ۔ (ابویعلی 865۔ بیہقی 372)",,,8161,,
8162,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عَبْدُ الْعَزِیزِ بْنُ أَبِی رَوَّادٍ ، عَنْ نَافِعٍ قَالَ : کَانَ ابْنُ عُمَرَ إذَا سَمِعَہُمْ یَقُولُونَ الْعَتَمَۃُ غَضِبَ غَضَبًا شَدِیدًا ، أَوْ نَہَی نَہْیًا شَدِیدًا۔",,,8162,,
8163,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا یَزِیدُ بْنُ طَہْمَانَ أَبُو الْمُعْتَمِرِ ، عَنِ ابْنِ سِیرِینَ : أَنَّہُ کَرِہَ أَنْ یَقُولَ الْعَتَمَۃُ۔",,,8163,,
8164,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شَرِیکٌ ، عَنْ أَبِی فَزَارَۃَ الْعَبْسِیِّ ، عَنْ مَیْمُونِ بْنِ مِہْرَانَ ، قَالَ : قُلْتُ لِعَبْدِ اللہِ بْنِ عُمَرَ : مَنْ أَوَّلُ مَنْ سَمَّاہَا الْعَتَمَۃَ ؟ قَالَ : الشَّیْطَانُ۔",,,8164,,
8165,حَدَّثَنَا شَرِیکٌ ، عَنْ أَبِی فَزَارَۃَ ، عَنْ مَیْمُونٍ ، عَنِ ابْنِ عُمَرَ بِنَحْوِہِ۔,,,8165,,
8166,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنِ مُحَمدِ بْنِ عَبْدِ اللہِ بْنِ أَبِی سَارَۃَ ، قَالَ : سَمِعْتُ سَالِمًا وَہُوَ یَقُولُ : لاَ تَقُلِ الْعَتَمَۃَ إنَّمَا ہِیَ الْعِشَائُ الأَخِرَۃُ مَرَّتَیْنِ۔",,,8166,,
8167,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : حدَّثَنَا حَرِیزُ بْنُ عُثْمَانَ ، عَنْ رَاشِدِ بْنِ سَعْدٍ ، عَنْ عاصِمِ بْنِ حُمَیْدٍ السَّکُونِیِّ وَکَانَ مِنْ أَصْحَابِ مُعَاذٍ ، عَنْ مُعَاذِ بْنِ جَبَلٍ ، قَالَ : بَقَیْنَا رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی صَلاَۃِ الْعِشَائِ فَخَرَجَ عَلَیْنَا فَقَالَ : أَعْتِمُوا بِہَذِہِ الصَّلاَۃ ، فَقَدْ فُضِّلْتُمْ بِہَا عَلَی سَائِرِ الأُمَمِ ، وَلَمْ تُصَلِّہَا أُمَّۃٌ قَبْلَکُمْ۔",,,8167,,
8168,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ عَبْدِ اللہِ بْنِ مُحَمَّدِ بْنِ عَقِیلٍ ، عَنْ جَابِرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لأَبِی بَکْرٍ : مَتَی تُوتِرُ ؟ قَالَ مِنْ أَوَّلِ اللَّیْلِ بَعْدَ الْعَتَمَۃِ قَبْلَ أَنْ أَنَامَ۔",,,8168,,
8169,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إذَا کَانَ سَفَرُکَ یَوْمًا إلَی الْعَتَمَۃِ فَلاَ تَقْصُرِ الصَّلاَۃ ، فَإِنْ جَاوَزْت ذَلِکَ فَقَصِّر۔",,,8169,,
8170,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ہِشَامُ بْنُ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ فِی قَوْلِہِ : {وَلاَ تَجْہَرْ بِصَلاَتِکَ وَلاَ تُخَافِتْ بِہَا} قَالَتْ : فِی الدُّعَائِ۔",,,8170,,
8171,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عُبَیْدِ الْمُکْتِبِ ، عَنْ إبْرَاہِیمَ ۔ وَعَنْ سُفْیَانَ ، عَنْ سِمَاکِ بْنِ عُبَیْدٍ ، عَنْ عَطَائٍ ، قَالاَ : الدُّعَائُ۔",,,8171,,
8172,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ قَیْسِ بْنِ مُسْلِمٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : قِرَائَۃُ الْقُرْآنِ۔",,,8172,,
8173,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ إبْرَاہِیمَ الْہَجَرِیِّ ، عَنِ أَبِی عِیَاضٍ قَالَ : الدُّعَائُ۔",,,8173,,
8174,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنِ أَبِی بِشْرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا قَرَأَ یَرْفَعُ صَوْتَہُ یُعْجِبُ ذَلِکَ الْمُسْلِمِینَ وَیَسُوئُ الْکُفَّارَ ، قَالَ فَنَزَلَتْ : {وَلاَ تَجْہَرْ بِصَلاَتِکَ وَلاَ تُخَافِتْ بِہَا}۔ (بخاری 4722۔ ترمذی 3146)",,,8174,,
8175,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَشْعَثَ بْنِ أَبِی الشَّعْثَائِ ، عَنِ الأَسْوَدِ بْنِ ہِلاَلٍ ، عَنْ عَبْدِ اللہِ ، قَالَ : لَمْ یُخَافِتْ مَنْ أَسْمَعَ أُذُنَیْہِ۔",,,8175,,
8176,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : سَأَلْتُ عَبِیْدَۃَ عَنِ الْقِرَائَۃِ ؟ فَقَالَ : أَسْمِعْ نَفْسَک۔",,,8176,,
8177,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَاصِمٍ ، عَنِ الْحَسَنِ ، أَنَّہُ قَالَ فِی قِرَائَۃِ النَّہَارِ : أَسْمِعْ نَفْسَک۔",,,8177,,
8178,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ الْہَجَرِیِّ ، عَنْ أَبِی عِیَاضٍ ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا صَلَّی عِنْدَ الْبَیْتِ جَہَرَ بِقِرَائَتِہِ ، فَکَانَ الْمُشْرِکُونَ یُؤْذُونَہُ فَنَزَلَتْ : (وَلاَ تَجْہَرْ بِصَلاَتِکَ وَلاَ تُخَافِتْ بِہَا) الآیَۃَ۔",,,8178,,
8179,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ أَشْعَثَ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ قَوْلُہُ : (وَلاَ تَجْہَرْ بِصَلاَتِکَ وَلاَ تُخَافِتْ بِہَا) قَالَ : الدُّعَائُ۔",,,8179,,
8180,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ مُجَاہِدٍ ، قَالَ : الدُّعَاء ۔",,,8180,,
8181,"حَدَّثَنَا مُعَاذُ بْنُ ہِشَامٍ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَیَّاشٍ الْعَامِرِیِّ ، عَنْ عَبْدِ اللہِ بْنِ شَدَّادٍ ، قَالَ : کَانَ أَعْرَابٌ لِبَنِی تَمِیمٍ إذَا سَلَّمَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالُوا : اللَّہُمَّ ارْزُقْنَا مَالاً وَوَلَدًا ، فَنَزَلَتْ (وَلاَ تَجْہَرْ بِصَلاَتِک)۔",,,8181,,
8182,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللہِ الأَسَدِیُّ ، عَنْ سُفْیَانَ ، عَنْ عَیَّاشٍ الْعَامِرِیِّ ، عَنْ عَبْدِ اللہِ بْنِ شَدَّادٍ بِنَحْوِہِ۔,,,8182,,
8183,"حَدَّثَنَا یَحْیَی بْنُ أَبِی بُکَیْرٍ ، عَنْ شُعْبَۃَ ، عَنْ مَنْصُورٍ ، عَنِ ابْنِ سِیرِینَ : {وَلاَ تَجْہَرْ بِصَلاَتِکَ وَلاَ تُخَافِتْ بِہَا} قَالَ : تُحْسِنُ عَلاَنِیَۃً وَتَجَوَّزُ سِرًّا {وَابْتَغِ بَیْنَ ذَلِکَ سَبِیلاً} قَالَ : تُجْعَلُہا سَوَائً فِی السِّرِّ وَالْعَلاَنِیَۃِ۔",,,8183,,
8184,"حَدَّثَنَا ہَاشِمُ بْنُ الْقَاسِمِ ، قَالَ : حدَّثَنَا أَبُو سَعِیدٍ ، قَالَ : حَدَّثَنَا سَالِمٌ ، عَنْ سَعِیدٍ : {وَلاَ تَجْہَرْ بِصَلاَتِکَ وَلاَ تُخَافِتْ بِہَا} ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَرْفَعُ صَوْتَہُ بِبِسْمِ اللہِ الرَّحْمَن الرَّحِیمِ وَکَانَ مُسَیْلِمَۃُ قَدْ تَسَمَّی الرَّحْمَان ، فَکَانَ الْمُشْرِکُونَ إذَا سَمِعُوا ذَلِکَ مِنَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالُوا : قَدْ ذَکَرَ مُسَیْلِمَۃَ إلَہَ الْیَمَامَۃِ ، ثُمَّ عَارَضُوہُ بِالْمُکَائِ وَالتَّصْدِیَۃِ وَالصَّفِیرِ فَأَنْزَلَ اللَّہُ تَعَالَی : {وَلاَ تَجْہَرْ بِصَلاَتِکَ وَلاَ تُخَافِتْ بِہَا}۔ (طبری 182)",,,8184,,
8185,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ ہِشَامٍ : أَنَّ أَبَاہُ کَانَ یَدْعُو لِلزُّبَیْرِ فِی صَلاَتِہِ وَیُسَمِّیہِ۔",,,8185,,
8186,"حَدَّثَنَا وَکِیعٌ، عَنْ شُعْبَۃَ، عَنْ أَبِی إیَاسٍ، قَالَ: قَالَ أَبُوالدَّرْدَائِ: إنِّی لأَدْعُو لِسَبْعِینَ مِنْ إخْوَانِی وَأَنَا سَاجِدٌ۔",,,8186,,
8187,"حَدَّثَنَا وَکِیعٌ، عَنْ حَسَنِ بْنِ صَالِحٍ، عَنْ مُجَالِدٍ، عَنِ الشَّعْبِیِّ: أَنَّ عَلِیًّا کَانَ یُسَمِّی الرِّجَالَ بَعْدَ الصَّلاَۃ۔",,,8187,,
8188,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا الْفَضْلُ بْنُ عَطِیَّۃَ قَالَ : أَخْبَرَنِی مَنْ رَأَی عُرْوَۃَ بْنَ الزُّبَیْرِ وَہُوَ یُصَلِّی وَہُوَ یَقُولُ : اللَّہُمَّ اغْفِرْ لِلزُّبَیْرِ اللَّہُمَّ اغْفِرْ لأَسْمَائَ بِنْت أَبِی بَکْرٍ۔",,,8188,,
8189,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ۔ وَعَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ، أَنَّہُمَا قَالاَ : اُدْعُ فِی صَلاَتِکَ بِمَا بَدَا لَک۔",,,8189,,
8190,"حَدَّثَنَا مُعَاذٌ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : نُبِّئْت أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ کَتَبَ أَنْ لاَ یُسَمّی أَحَدٌ فِی الدُّعَائِ۔",,,8190,,
8191,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنِ الْفُرَافِصَۃِ ، قَالَ : سَمِعْتُ ابْنَ الزُّبَیْرِ یَقُولُ وَہُوَ سَاجِدٌ : اللَّہُمَّ اغْفِرْ لِلزُّبَیْرِ اللَّہُمَّ اغْفِرْ لأَسْمَائَ بِنْتِ أَبِی بَکْرٍ الصِّدِّیق۔",,,8191,,
8192,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنِ عَطَائٍ ، قَالَ : لاَ بَأْسَ أَنْ یَقُولَ فِی الصَّلاَۃ : اللَّہُمَّ ارْزُقْنِی غُلاَمًا ، وَلاَ یُسَمِّی۔",,,8192,,
8193,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا جَعْفَرُ بْنُ بُرْقَانَ ، عَنْ حَبِیبِ بْنِ أَبِی مَرْزُوقٍ ، قَالَ : قَالَ عُثْمَانَ : لاَ یَقْطَعُ الصَّلاَۃ شَیْئٌ إِلاَّ الْکَلاَمُ وَالْحَدَثُ",,,8193,,
8194,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ وَحَمَّادًا عَنِ الرَّجُلِ یَتَکَلَّمُ فِی الصَّلاَۃ فَقَالاَ : إذَا تَکَلَّمَ وَقَدْ فَرَغَ مِنْ صَلاَتِہِ فَزَادَ فَقَدْ مَضَتْ ، وَعَلَیْہِ سَجْدَتَا السَّہْوِ ، وَإِنْ تَکَلَّمَ وَلَمْ یُتِمَّ صَلاَتَہُ فَإِنَّہُ یُعِیدُ۔",,,8194,,
8195,"حَدَّثَنَا غُنْدَرٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : یَسْتَأْنِفُ۔",,,8195,,
8196,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا تَکَلَّمَ فِی الصَّلاَۃ أَعَادَ الصَّلاَۃ ، وَلَمْ یُعِدِ الْوُضُوئَ۔",,,8196,,
8197,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی ہَارُونَ ، عَنْ أَبِی سَعِیدٍ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ إذَا سَافَرَ فَرْسَخًا قَصَرَ الصَّلاَۃ۔ (عبد بن حمید 947)",,,8197,,
8198,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا جُوَیْبِرٌ ، عَنِ الضَّحَّاکِ ، عَنِ النَّزَّال : أَنَّ عَلِیًّا خَرَجَ إلَی النُّخِیلَۃ فَصَلَّی بِہَا الظُّہْرَ وَالْعَصْرَ رَکْعَتَیْنِ ، ثُمَّ رَجَعَ مِنْ یَوْمِہِ فَقَالَ : أَرَدْتُ أَنْ أُعَلِّمَکُمْ سُنَّۃَ نَبِیِّکُمْ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,8198,,
8199,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ إبْرَاہِیمَ بْنِ مَیْسَرَۃَ ، سَمِعَ أَنَسًا یَقُولُ : صَلَّی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِالْمَدِینَۃِ الظُّہْرَ أَرْبَعًا وَبِذِی الْحُلَیْفَۃِ رَکْعَتَیْنِ ، یَعْنِی الْعَصْرَ۔",,,8199,,
8200,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ محمد بْنِ الْمُنْکَدِرِ وَإِبْرَاہِیمَ بْنِ مَیْسَرَۃَ ، سَمِعَا أَنَسًا یَقُولُ : صَلَّیْتُ مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الظُّہْرَ بِالْمَدِینَۃِ أَرْبَعًا وَبِذِی الْحُلَیْفَۃِ الْعَصْرَ رَکْعَتَیْنِ۔ (ترمذی 546۔ ابوداؤد 1195)",,,8200,,
8201,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا زَکَرِیَّا ، عَنْ عَامِرٍ ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا خَرَجَ مُسَافِرًا قَصَرَ الصَّلاَۃ مِنْ ذِی الْحُلَیْفَۃِ۔",,,8201,,
8202,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ عُمَرَ بْنِ عَامِرٍ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ : أَنَّ حُذَیْفَۃَ کَانَ یُصَلِّی رَکْعَتَیْنِ فِیمَا بَیْنَ الْکُوفَۃِ وَالْمَدَائِنِ۔",,,8202,,
8203,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : تُقْصَرُ الصَّلاَۃ فِی مَسِیرَۃِ یَوْمٍ وَلَیْلَۃٍ۔",,,8203,,
8204,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ مُحَمَّدِ بْنِ زَیْدِ بْنِ خُلَیْدَۃَ ، عَنِ ابْنِ عُمَرَ ، قَالَ : تُقْصَرُ الصَّلاَۃ فِی مَسِیرَۃِ ثَلاَثَۃِ أَمْیَالٍ۔",,,8204,,
8205,"حَدَّثَنَا حَفْصٌ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، عَنْ إبْرَاہِیمَ ،: أَنَّ مَسْرُوقًا کَانَ یَقْصُرُ الصَّلاَۃ إلَی وَاسِطٍ۔",,,8205,,
8206,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مَنْصُورٍ ، عَنْ أَبِی وَائِلٍ ، قَالَ : خَرَجْت مَعَ مَسْرُوقٍ إلَی السِّلْسِلَۃِ فَقَصَرَ الصَّلاَۃ وَأَقَامَ بِہَا سَنَتَیْنِ یَقْصُرُ الصَّلاَۃ وَقَصَرَ حِینَ رَجَعَ حَتَّی دَخَلَ۔",,,8206,,
8207,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ یَحْیَی بْنِ یَزِیدَ الْہُنَائِیِّ ، قَالَ : سَأَلْتُ أَنَسَ بْنَ مَالِکٍ عَنْ قَصْرِ الصَّلاَۃ ، فَقَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا خَرَجَ مَسِیرَۃَ ثَلاَثَۃِ أَمْیَالٍ ، أَوْ ثَلاَثَۃِ فَرَاسِخَ ، شُعْبَۃُ الشَّاکُّ صَلَّی رَکْعَتَیْنِ۔ (مسلم 12۔ ابوداؤد 1194)",,,8207,,
8208,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ وَمَنْصُورٍ ، عَنِ الْحَسَنِ ، قَالَ : تُقْصُرُ الصَّلاَۃُ فِی مَسِیرَۃِ اللَّیْلَتَیْنِ۔",,,8208,,
8209,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا الْمُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ، قَالَ : قَالَ لَہُ الْحَارِثُ : أَتَقْصُرُ الصَّلاَۃ إلَی الْمَدَائِنِ؟ قَالَ : إنَّ الْمَدَائِنَ لَقَرِیبٌ وَلَکِنْ إلَی الأَہْوَازِ وَنَحْوِہَا۔",,,8209,,
8210,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حَجَّاجٍ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : : کَانَ أَصْحَابُ عَبْدِ اللہِ لاَ یَقْصُرُونَ إلَی وَاسِطٍ وَالْمَدَائِنِ وَأَشْبَاہِہِمَا۔",,,8210,,
8211,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ زَکَرِیَّا ، أَنَّہُ سَمِعَ الشَّعْبِیَّ یَقُولُ : لَوْ سَافَرْتُ إلَی دَیْرِ الثَّعَالِبِ لَقَصَرْتُ۔",,,8211,,
8212,"حَدَّثَنَا وَکِیعٌ ، عَنْ زَکَرِیَّا ، عَنْ عَامِرٍ مِثْلَہُ ، إِلاَّ أَنَّ وَکِیعًا قَالَ : لَوْ خَرَجْتُ۔",,,8212,,
8213,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ زَمعَۃ ، عَنْ عَمْرٍو ، عَنْ أَبِی الشَّعْثَائِ ، قَالَ : تُقْصَرُ فِی مَسِیرَۃِ سِتَّۃِ أَمْیَالٍ۔",,,8213,,
8214,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الْحَسَنُ بْنُ صَالِحٍ وَإِسْرَائِیلُ ، عَنْ إبْرَاہِیمَ بْنِ عَبْدِ الأَعْلَی ، عَنْ سُوَیْد بْنِ غَفَلَۃَ ، قَالَ : تُقْصَرُ الصَّلاَۃ فِی مَسِیرَۃِ ثَلاَثٍ۔",,,8214,,
8215,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عِمْرَانَ بْنِ مُسْلِمٍ ، أَوْ غَیْرِہِ ، عَنِ الشَّعْبِیِّ : أَنَّہُ کَانَ یَقْصُرُ الصَّلاَۃ إلَی وَاسِطٍ۔",,,8215,,
8216,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إسْرَائِیلُ ، عَنْ عِیسَی بْنِ أَبِی عَزَّۃَ ، قَالَ : رَأَیْتُُ الشَّعْبِیَّ یَقْصُرُ الصَّلاَۃ إلَی وَاسِطٍ۔",,,8216,,
8217,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ رَجُلٍ یُقَالُ لَہُ شُبَیْلٌ ، عَنْ أَبِی حِبَرَۃَ ، قَالَ : قُلْتُ لِاِبْنِ عَبَّاسٍ : أَقْصُرُ إلَی الأُبُلَّۃِ ؟ فَقَالَ : تَذْہَبُ وَتَجِیئُ فِی یَوْمٍ ؟ قَالَ : قُلْتُ : نَعَمْ ، قَالَ : لاَ إِلاَّ فِی یَوْمٍ مَتَّاحٍ۔",,,8217,,
8218,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا ہِشَامُ بْنُ الْغَازِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ : أَنَّہُ کَانَ لاَ یَقْصُرُ الصَّلاَۃ إِلاَّ فِی الْیَوْمِ التَّامِّ۔\n\nقَالَ ہِشَامٌ : وَسَمِعْتُ مَکْحُولاً یَقُولُ مِثْلَ ذَلِکَ۔",,,8218,,
8219,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إذَا کَانَ سَفَرُک یَوْمًا إلَی الْعَتَمَۃِ فَلاَ تُقَصِّرِ الصَّلاَۃ ، فَإِنْ جَاوَزْتَ ذَلِکَ فَقَصِّرِ الصَّلاَۃ۔",,,8219,,
8220,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، عَنْ سَالِمٍ : أَنَّ ابْنَ عُمَرَ خَرَجَ إلَی أَرْضٍ لَہُ بِذَاتِ النُّصُبِ فَقَصَرَ وَہِیَ سِتَّۃَ عَشَرَ فَرْسَخًا۔",,,8220,,
8221,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ الْجُرَیرِیِّ ، عَنْ أَبِی الْوَرْدِ ، عَنِ اللَّجْلاَجِ ، قَالَ : کُنَّا نُسَافِرُ مَعَ عُمَرَ بْنِ الْخَطَّابِ فَیَسِیرُ ثَلاَثَۃَ أَمْیَالٍ فَیَتَجَوَّزُ فِی الصَّلاَۃ وَیَفْطُرُ۔",,,8221,,
8222,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ہِشَامُ بْنُ الْغَازِ ، عَنْ رَبِیعَۃَ الْجُرَشِیِّ ، عَنْ عَطَائِ بْنِ أَبِی رَبَاحٍ ، قَالَ : قُلْتُ لِاِبْنِ عَبَّاسٍ : أَقْصُرُ إلَی عَرَفَۃَ ؟ فَقَالَ : لاَ ، قُلْتُ : أَقْصُرُ إلَی مَرٍّ ؟ قَالَ : لاَ ، قُلْتُ أَقْصُرُ إلَی الطَّائِفِ وَإِلَی عُسْفَانَ ؟ قَالَ : نَعَمْ ، وَذَلِکَ ثَمَانِیَۃٌ وَأَرْبَعُونَ مِیلاً وَعَقَدَ بِیَدِہِ۔",,,8222,,
8223,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مُحَارِبِ بْنِ دِثَارٍ ، قَالَ : سَمِعْتُ ابْنَ عُمَرَ یَقُولُ : إنِّی لأُسَافِرُ السَّاعَۃَ مِنَ النَّہَارِ فَأَقْصُرُ۔",,,8223,,
8224,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو، قَالَ: أَخْبَرَنِی عَطَائٌ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ تَقْصُرْ إلَی عَرَفَۃَ وَبَطْنِ نَخْلَۃٍ ، وَاقْصُرْ إلَی عُسْفَانَ وَالطَّائِفِ وَجُدَّۃَ فَإِذَا قَدِمْتَ عَلَی أَہْلٍ أَوْ مَاشِیَۃٍ فَأَتِمَّ۔",,,8224,,
8225,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، قَالَ : قَالَ لِی جَابِرُ بْنُ زَیْدٍ : اُقْصُرْ بِعَرَفَۃَ۔",,,8225,,
8226,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَوْزَاعِیِّ ، عَنْ عَطَائٍ ، قَالَ : قُلْتُ لِاِبْنِ عَبَّاسٍ أَقْصُرُ بِعَرَفَۃَ ؟ قَالَ : لاَ۔",,,8226,,
8227,"حَدَّثَنَا عُبَیْدُ بْنُ سَعِیدٍ ، عَنْ شُعْبَۃَ ، عَنْ یَزِیدَ بْنِ خُمَیْرٍ ، قَالَ : سَمِعْتُ حَبِیبَ بْنَ عُبَیْدٍ یُحَدِّثُ ، عَنْ جُبَیْرِ بْنِ نُفَیْرٍ ، عَنِ ابْنِ السِّمْطِ قَالَ : شَہِدْتُ عُمَرَ بِذِی الْحُلَیْفَۃِ کَأَنَّہُ یُرِیدُ مَکَّۃَ صَلَّی رَکْعَتَیْنِ فَقُلْتُ لَہُ لِمَ تَفْعَلُ ہَذَا ؟ قَالَ : إنَّمَا أَصْنَعُ کَمَا رَأَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَصْنَعُ۔ (مسلم 481۔ احمد 1/30)",,,8227,,
8228,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ خَیْثَمَۃَ ، قَالَ : خَرَجَ الْحَارِثُ بْنُ قَیْسٍ الْجُعْفِیُّ ، فَلَمَّا خَرَجَ مِنَ الْبُیُوتِ قَصَرَ الصَّلاَۃ ، قَالَ : فَقِیلَ لَہُ : تَقْصُرُ الصَّلاَۃ ، قَالَ أُتِمُّ الْیَوْمَ وَأَقْصُرُ غَدًا۔",,,8228,,
8229,"حَدَّثَنَا سُفْیَانُ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ الْفَائشیِّ ، قَالَ : خَرَجْنَا مَعَ عَلِیٍّ إلَی صِفِّینَ فَصَلَّی بَیْنَ الْجِسْرِ وَالْقَنْطَرَۃِ رَکْعَتَیْنِ۔",,,8229,,
8230,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ عَلْقَمَۃُ إذَا خَرَجَ حَاجًّا أَحْرَمَ مِنَ النَّجَفِ وَقَصَرَ۔",,,8230,,
8231,"حَدَّثَنَا مُعَاذٌ قَالَ : أَخْبَرَنَا ابْنُ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : قَالَ ابْنُ عَبَّاسٍ : تُقْصَرُ الصَّلاَۃ فِی الْیَوْمِ التَّامِّ ، وَلاَ تُقْصَرُ فِیمَا دُونَ ذَلِکَ۔",,,8231,,
8232,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ عِمْرَانَ بْنِ عُمَیْرٍ ، عَنْ أَبِیہِ ، قَالَ : خَرَجْتُ مَعَ عَبْدِ اللہِ إلَی مَکَّۃَ فَصَلَّی رَکْعَتَیْنِ بِقَنْطَرَۃِ الْحِیرَۃِ۔",,,8232,,
8233,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، وَأَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ عُمَارَۃَ بْنِ عُمَیْرٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، قَالَ : قَالَ عَبْدُ اللہِ : لاَ تُقْصَرُ الصَّلاَۃ إِلاَّ فِی حَجٍّ أَوْ جِہَادٍ۔",,,8233,,
8234,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مِسْعَرٌ وَسُفْیَانُ ، عَنْ قَیْسِ بْنِ مُسْلِمٍ ، عَنْ طَارِقِ بْنِ شِہَابٍ ، قَالَ : قَالَ لِی ابْنُ مَسْعُودٍ : لاَ یَغُرَّنَّکُمْ سَوَادُکُمْ مِنْ صَلاَتِکُمْ فَإِنَّمَا ہُوَ مِنْ کُوفَتِِکُمْ۔",,,8234,,
8235,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ، قَالَ : حدَّثَنِی رَجُلٌ مِنْ قُرَّائِ کِتَابِ عُثْمَانَ أَوْ قُرِئَ عَلَیْہِ ، فَقَالَ : أَمَّا بَعْدُ فَإِنَّہُ بَلَغَنِی أَنَّ رِجَالاً مِنْکُمْ یَخْرُجُونَ إلَی سَوَادِہِمْ ، إمَّا فِی جشْرٍ وَإِمَّا فِی جِبَایَۃٍ وَإِمَّا فِی تِجَارَۃٍ فَیَقْصُرُونَ الصَّلاَۃ أوْ لاَ یُتِمُّونَ الصَّلاَۃ ، فَلاَ تَفْعَلُوا فَإِنَّمَا یَقْصُرُ الصَّلاَۃ مَنْ کَانَ شَاخِصًا أَوْ بِحَضْرَۃِ عَدُوٍّ۔",,,8235,,
8236,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ الْعَوَّامِ ، قَالَ : کَانَ إبْرَاہِیمُ التَّیْمِیُّ لاَ یَرَی الْقَصْرَ إِلاَّ فِی حَجٍّ ، أَوْ جِہَادٍ ، أَوْ عُمْرَۃٍ۔",,,8236,,
8237,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ عَاصِمٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : کَانُوا یَقُولُونَ : السَّفَرُ الَّذِی تُقْصَرُ فِیہِ الصَّلاَۃ الَّذِی یُحْمَلُ فِیہِ الزَّادَ وَالْمَزَادَ۔",,,8237,,
8238,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ قَیْسِ بْنِ مُسْلِمٍ ، عَنْ طَارق بْنِ شِہَابٍ ، عَنِ ابْنِ مَسْعُودٍ ، قَالَ : لاَ یَغُرَّنکُمْ سَوَادُکُمْ ہَذَا مِنْ صَلاَتِکُمْ فَإِنَّمَا ہُوَ مِنْ مِصْرِکُمْ۔",,,8238,,
8239,"حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنِ ابْنِ أَبِی فَرْوَۃَ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ : أَنَّ مُعَاذًا وَعُقْبَۃَ بْنَ عَامِرٍ ، وَابْنَ مَسْعُودٍ قَالُوا : لاَ یَغُرَّنکُمْ مَوَاشِیکُمْ یَطَأُ أَحَدُکُمْ بِمَاشِیَتِہِ أَحْدَابَ الْجِبَالِ ، أَوْ بُطُونَ الأَوْدِیَۃِ وَتَزْعُمُونَ بِأَنَّکُمْ سَفْرٌ لاَ وَلاَ کَرَامَۃَ ، إنَّمَا التَّقْصِیرُ فِی السَّفَرِ الْبَاتِّ مِنَ الأُفُقِ إلَی الأُفُقِ۔",,,8239,,
8240,"حَدَّثَنَا شَرِیکٌ ، عَنْ زُبَیْدٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، عَنْ عُمَرَ ، قَالَ : صَلاَۃُ السَّفَرِ رَکْعَتَانِ تَمَامٌ غَیْرُ قَصْرٍ عَلَی لِسَانِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,8240,,
8241,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ سَعِیدِ بْنِ شُفَیٍّ ، قَالَ : قُلْتُ لِاِبْنِ عَبَّاسٍ : إنَّا قَوْمٌ کُنَّا إذَا سَافَرْنَا کَانَ مَعَنَا مَنْ یَکْفِینَا الْخِدْمَۃَ مِنْ غِلْمَانِنَا فَکَیْفَ نُصَلِّی ؟ فَقَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا سَافَرَ صَلَّی رَکْعَتَیْنِ حَتَّی یَرْجِعَ ، قَالَ : ثُمَّ عُدْتُ فَسَأَلْتُہُ فَقَالَ مِثْلَ ذَلِکَ ، ثُمَّ عُدْت فَقَالَ لِی بَعْضُ الْقَوْمِ : أَمَا تَعْقِلُ أَمَا تَسْمَعُ مَا یَقُولُ لَک۔ (احمد 1/241۔ طبرانی 12712)",,,8241,,
8242,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ أَبِی خَالِدٍ ، عَنْ أَبِی حَنْظَلَۃَ ، قَالَ : سَأَلْتُ ابْنَ عُمَرَ عَنِ الصَّلاَۃ فِی السَّفَرِ ، فَقَالَ : رَکْعَتَانِ سُنَّۃُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔ (احمد 2/135)",,,8242,,
8243,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ أَبِی عَمَّارٍ ، عَنْ عَبْدِ اللہِ بْنِ بَابَاہ ، عَنْ یَعْلَی بْنِ أُمَیَّۃَ ، قَالَ: سَأَلْتُ عُمَرَ بْنَ الْخَطَّابِ قُلْتُ {فَلَیْسَ عَلَیْکُمْ جُنَاحٌ أَنْ تَقْصُرُوا مِنَ الصَّلاَۃ إِنْ خِفْتُمْ أَنْ یَفْتِنَکُمُ الَّذِینَ کَفَرُوا} وَقَدْ أَمِنَ النَّاسُ ، فَقَالَ : عَجِبْتُ مِمَّا عَجِبْتَ مِنْہُ فَسَأَلْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ ذَلِکَ فَقَالَ : صَدَقَۃٌ تَصَدَّقَ اللَّہُ بِہَا عَلَیْکُمْ فَاقْبَلُوا صَدَقَتَہُ۔ (مسلم 4۔ ابوداؤد 1192)",,,8243,,
8244,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی لَیْلَی ، قَالَ : خَرَجَ سَلْمَانُ فِی ثَلاَثَۃَ عَشَرَ رَجُلاً مِنْ أَصْحَابِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ غُزَاۃً وَسَلْمَانُ أَسَنُّہُمْ ، فَلَمَّا حَضَرَتِ الصَّلاَۃ قَالُوا لَہُ : تَقَدَّمْ یَا أَبَا عَبْدِ اللہِ ، فَقَالَ : مَا أَنَا بِالَّذِی أَتَقَدَّمُ وَأَنْتُمُ الْعَرَبُ مِنْکُمُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَلْیَتَقَدَّمْ بَعْضُکُمْ ، فَتَقَدَّمَ بَعْضُ الْقَوْمِ فَصَلَّی بِہِمْ أَرْبَعَ رَکَعَاتٍ ، فَلَمَّا قَضَیْنَا الصَّلاَۃ قَالَ سَلْمَانُ : وَمَا لِلْمُرْبَعَۃِ ، إنَّمَا کَانَ یَکْفِینَا رَکْعَتَانِ نِصْفُ الْمُرْبَعَۃِ۔",,,8244,,
8245,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سَعِیدُ بْنُ عُبَیْدٍ الطَّائِیُّ ، عَنْ عَلِیِّ بْنِ رَبِیعَۃَ الْوَالِبی ، عَنِ الرَّبِیعِ بْنِ نَضْلَۃَ ، قَالَ : خَرَجْنَا فِی سَفَرٍ وَنَحْنُ اثْنَا عَشَرَ ، أَوْ ثَلاَثَۃَ عَشَرَ رَاکِبًا کُلُّہُمْ قَدْ صَحِبَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ غَیْری ، قَالَ : فَحَضَرَتِ الصَّلاَۃ فَتَدَافَعَ الْقَوْمُ فَتَقَدَّمَ شَابٌّ مِنْہُمْ فَصَلَّی بِہِمْ أَرْبَعَ رَکَعَاتٍ ، فَلَمَّا صَلَّی قَالَ سَلْمَانُ : مَا لَنَا وَلِلْمَرْبُوعَۃِ یَکْفِینَا نِصْفُ الْمَرْبُوعَۃِ ، نَحْنُ إلَی التَّخْفِیفِ أَفْقَرُ فَقَالُوا : تَقَدَّمْ أَنْتَ یَا أَبَا عَبْدِ اللہِ فَصَلِّ بِنَا ، فَقَالَ : أَنْتُمْ بَنُو إسْمَاعِیلَ الأَئِمَّۃُ وَنَحْنُ الْوُزَرَائُ۔",,,8245,,
8246,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ إبْرَاہِیمَ ، قَالَ : جَائَ رَجُلٌ إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : یَا رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إنِّی رَجُلٌ تَاجِرٌ أَخْتَلِفُ إلَی الْبَحْرَیْنِ فَأَمَرَہُ أَنْ یُصَلِّیَ رَکْعَتَیْنِ۔",,,8246,,
8247,"حَدَّثَنَا شَرِیکٌ ، عَنِ أَبِی إِسْحَاقَ ، قَالَ : سَأَلْتُ سَلَمَۃَ بْنَ صُہَیْبٍ وَنَحْنُ بِسِجِسْتَانَ ، عَنِ الصَّلاَۃ ، فَقَالَ : رَکْعَتَیْنِ رَکْعَتَیْنِ حَتَّی تَرْجِعَ إلَی أَہْلِکَ ، ہَکَذَا کَانَ عَبْدُ اللہِ بْنُ مَسْعُودٍ یَقُولُ۔",,,8247,,
8248,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا ابْنُ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : صَلَّیْنَا مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَیْنَ مَکَّۃَ وَالْمَدِینَۃِ وَنَحْنُ آمِنُونَ لاَ نَخَافُ شَیْئًا رَکْعَتَیْنِ۔ (ترمذی 547۔ احمد 1/226)",,,8248,,
8249,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، وَابْنُ أَبِی لَیْلَی ، عَنْ عَوْنِ بْنِ أَبِی جُحَیْفَۃَ السُّوَائِیِّ ، عَنْ أَبِیہِ ، قَالَ: صَلَّیْتُ مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِمِنًی الظُّہْرَ رَکْعَتَیْنِ ، ثُمَّ لَمْ یَزَلْ یُصَلِّی رَکْعَتَیْنِ حَتَّی رَجَعَ إلَی الْمَدِینَۃِ۔ (احمد 4/309۔ طبرانی 251)",,,8249,,
8250,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ہِشَامُ بْنُ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، قَالَتْ : أَوَّلُ مَا فُرِضَتِ الصَّلاَۃ رَکْعَتَیْنِ ، ثُمَّ زِیدَ فِیہَا فَجُعِلَ لِلْمُقِیمِ أَرْبَعًا۔ (بخاری 350۔ مسلم 478)",,,8250,,
8251,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مِسْعَرٌ ، عَنْ سِمَاکٍ الْحَنَفِیِّ ، قَالَ : سَمِعْتُ ابْنَ عُمَرَ یَقُولُ : الرَّکْعَتَانِ فِی السَّفَرِ تَمَامٌ غَیْرُ قَصْرٍ۔",,,8251,,
8252,"حَدَّثَنَا عَبْدَۃُ ، عَنْ وِقَائِ بْنِ إیَاسٍ ، عَنْ عَلِیِّ بْنِ رَبِیعَۃَ : أَنَّ عَلِیًّا خَرَجَ فِی السَّفَرِ ، فَکَانَ یُصَلِّی رَکْعَتَیْنِ رَکْعَتَیْنِ حَتَّی یَرْجِعَ۔",,,8252,,
8253,"حَدَّثَنَا عَبَّادُ بْنُ عَوَّامٍ ، عَنْ دَاوُدَ بْنِ أَبِی ہِنْدٍ ، عَنْ أَبِی حَرْبِ بْنِ أَبِی الأَسْوَدِ : أَنَّ عَلِیًّا خَرَجَ مِنَ الْبَصْرَۃِ فَصَلَّی الظُّہْرَ أَرْبَعًا ، ثُمَّ قَالَ : أَمَا إنَّا إذَا جَاوَزْنَا ہَذَا الْخُصَّ صَلَّیْنَا رَکْعَتَیْنِ۔",,,8253,,
8254,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ حَرْمَلَۃَ ، أَنَّہُ سَمِعَ رَجُلاً یَسْأَلُ سَعِیدَ بْنَ الْمُسَیَّبِ أُتِمُّ الصَّلاَۃ وَأَصُومُ فِی السَّفَرِ ؟ قَالَ : لاَ ، قَالَ : فَإِنِّی أَقْوَی عَلَی ذَلِکَ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَقْوَی مِنْک کَانَ یَقْصُرُ الصَّلاَۃ فِی السَّفَرِ وَیُفْطِرُ ، وَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : خِیَارُکُمْ مَنْ قَصَرَ الصَّلاَۃ فِی السَّفَرِ وَأَفْطَرَ۔ (عبدالرزاق 4480۔ طبرانی 6554)",,,8254,,
8255,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنِ أَبِی إِسْحَاقَ ، قَالَ : لَقِیتُ عَبْدَ اللہِ بْنَ مَعقِلٍ بِالْمَدَائِنِ فَقُلْتُ : إنِّی إمَامُ قَوْمِی وَإِنِّی أُرِیدُ الرُّجُوعَ إلَی أَہْلِی فَکَمْ أُصَلِّی ؟ قَالَ : أَرْبَعًا ، ثُمَّ لَقِیتُہُ بَعْدُ بِالرَّیِّ فَقُلْت إنِّی أُرِیدُ أنْ أرْجِع إلَی أَہْلِی فَکَمْ تَأْمُرُنِی أَنْ أُصَلِّیَ ؟ قَالَ رَکْعَتَیْنِ۔",,,8255,,
8256,"حَدَّثَنَا یَحْیَی بْنُ أَبِی بُکَیْرٍ قَالَ : حدَّثَنَا إبْرَاہِیمُ بْنُ نَافِعٍ ، عَنِ ابْنِ طَاوُوس ، قَالَ : کَانَ أَبِی یَقْصُرُ مِنْ حِینِ یَخْرُجُ مِنْ بَیْتِہِ حَتَّی یَرْجِعَ إلَی أَہْلِہِ۔",,,8256,,
8257,"حَدَّثَنَا ہُشَیْمٌ قَالَ : أَخْبَرَنَا ہَارُونُ بْنُ زَارْوَی ، عَنْ مُجَاہِدٍ ، قَالَ : جَائَ رَجُلٌ إلَی ابْنِ عَبَّاسٍ ، فَقَالَ : إنِّی وَصَاحِبٌ لِی کُنَّا فِی سَفَرٍ فَکُنْتُ أُتِمُّ وَکَانَ صَاحِبِی یَقْصُرُ ، فَقَالَ لَہُ ابْنُ عَبَّاسٍ : بَلْ أَنْتَ الَّذِی کُنْتَ تَقْصُرُ وَصَاحِبُک الَّذِی کَانَ یُتِمُّ۔",,,8257,,
8258,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَلِیِّ بْنِ زَیْدٍ ، عَنْ أَبِی نَضْرَۃَ ، قَالَ : مَرَّ عِمْرَانُ بْنُ حُصَیْنٍ فِی مَجْلِسِنَا ، فَقَامَ إلَیْہِ فَتًی مِنَ الْقَوْمِ فَسَأَلَہُ عَنْ صَلاَۃِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی الْحَجِّ وَالْغَزْوِ وَالْعُمْرَۃِ ، فَجَائَ فَوَقَفَ عَلَیْنَا فَقَالَ : إنَّ ہَذَا سَأَلَنِی عَنْ أَمْرٍ فَأَرَدْتُ أَنْ تَسْمَعُوہُ ، أَوْ کَمَا قَالَ : غَزَوْتُ مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَلَمْ یُصَلِّ إِلاَّ رَکْعَتَیْنِ حَتَّی رَجَعَ إلَی الْمَدِینَۃِ ، وَحَجَجْتُ مَعَہُ فَلَمْ یُصَلِّ إِلاَّ رَکْعَتَیْنِ حَتَّی رَجَعَ إلَی الْمَدِینَۃِ ، وَشَہِدْتُ مَعَہُ الْفَتْحَ فَأَقَامَ بِمَکَّۃَ ثَمَانَ عَشْرَۃَ لَیْلَۃً لاَ یُصَلِّی إِلاَّ رَکْعَتَیْنِ ، یَقُولُ لأَہْلِ الْبَلَدِ : صَلُّوا أَرْبَعًا فَإِنَّا سَفْرٌ ، وَاعْتَمَرْتُ مَعَہُ ثَلاَثَ عُمَرَ لاَ یُصَلِّی إِلاَّ رَکْعَتَیْنِ ، وَحَجَجْت مَعَ أَبِی بَکْرٍ وَغَزَوْت فَلَمْ یُصَلِّ إِلاَّ رَکْعَتَیْنِ حَتَّی رَجَعَ إلَی الْمَدِینَۃِ ، وَحَجَجْت مَعَ عُمَرَ حَجَّاتٍ فَلَمْ یُصَلِّ إِلاَّ رَکْعَتَیْنِ حَتَّی رَجَعَ إلَی الْمَدِینَۃِ، وَحَجَجْت مَعَ عُثْمَانَ سَبْعَ سِنِینَ مِنْ إمَارَتِہِ لاَ یُصَلِّی إِلاَّ رَکْعَتَیْنِ ، ثُمَّ صَلاَّہا بِمِنًی أَرْبَعًا۔",,,8258,,
8259,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ سِمَاکٍ ، عَنْ عَوْنِ بْنِ أَبِی جُحَیْفَۃَ ، عَنْ أَبِیہِ ، قَالَ : صَلَّی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِمَکَّۃَ الظُّہْرَ رَکْعَتَیْنِ صَلاَۃَ الْمُسَافِرِ۔",,,8259,,
8260,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَبْدِ الرَّحْمَنِ بْنِ یَزَیْدٍ ، قَالَ : صَلَّی عُثْمَانُ بِمِنًی أَرْبَعًا ، فَقَالَ عَبْدُ اللہِ : صَلَّیْتُ مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِمِنًی رَکْعَتَیْنِ ، وَمَعَ أَبِی بَکْرٍ رَکْعَتَیْنِ ، وَمَعَ عُمَرَ رَکْعَتَیْنِ ، ثُمَّ تَفَرَّقَتْ بِکُمُ الطُّرُقُ ، وَلَوَدِدْت أَنَّ لِی مِنْ أَرْبَعِ رَکَعَاتٍ رَکْعَتَیْنِ مُتَقَبَّلَتَیْنِ۔\n\n(بخاری 1657۔ مسلم 19)",,,8260,,
8261,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، وَأَبُو الأَحْوَص ، عَنْ أَبِی إِسْحَاقَ ، عَنْ حَارِثَۃَ بْنِ وَہْبٍ الْخُزَاعِیِّ ، قَالَ : صَلَّیْتُ مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِمِنًی آمَنَ مَا کَانَ النَّاسُ وَأَکْثَرہ رَکْعَتَیْنِ۔ (بخاری 1083۔ مسلم 21)",,,8261,,
8262,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سَعِیدُ بْنُ السَّائِبِ الطَّائِفِیُّ ، عَنْ دَاوُدَ بْنِ أَبِی عَاصِمٍ الثَّقَفِیِّ ، قَالَ : سَأَلْتُ ابْنَ عُمَرَ عَنِ الصَّلاَۃ بِمِنًی فَقَالَ : ہَلْ سَمِعْتَ بِمُحَمَّدٍ وَ آمَنْتَ بِہِ ، فَإِنَّہُ کَانَ یُصَلِّی بِمِنًی رَکْعَتَیْنِ۔ (احمد 2/24)",,,8262,,
8263,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ہِشَامُ بْنُ عُرْوَۃَ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَأَبَا بَکْرٍ وَعُمَرَ وَعُثْمَانَ صَدْرًا مِنْ إمَارَتِہِ صَلَّوْا بِمِنًی رَکْعَتَیْنِ۔",,,8263,,
8264,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا حَنْظَلَۃُ قَالَ: سَأَلْتُ الْقَاسِمَ وَسَالِمًا وَطَاوُوسا عَنِ الصَّلاَۃ بِمِنًی، فَقَالُوا: قَصر۔",,,8264,,
8265,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : یُصَلِّی الْمُسَافِرُ رَکْعَتَیْنِ حَتَّی یَرْجِعَ إِلاَّ أَنْ یَأْتِیَ مِصْرًا مِنَ الأَمْصَارِ فَیُصَلِّیَ بِصَلاَتِہِمْ۔",,,8265,,
8266,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عُرْوَۃَ ، عَنْ عَائِشَۃَ: إِنَّ الصَّلاَۃ أَوَّلُ مَا فُرِضَتْ رَکْعَتَیْنِ فَزِیدَتْ فِی صَلاَۃِ الْحَضَرِ وَأُقِرَّتْ صَلاَۃُ السَّفَرِ ، فَقُلْت لِعُرْوَۃِ : مَا بَالُ عَائِشَۃَ کَانَتْ تُتِمُّ الصَّلاَۃ فِی السَّفَرِ وَہِیَ تَقُولُ ہَذَا ؟ قَالَ : تَأَوَّلَتْ مَا تَأَوَّلَ عُثْمَانُ فَلَمْ أَسْأَلْہُ مَا تَأَوَّلَ عُثْمَانُ۔ (مسلم 678)",,,8266,,
8267,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، قَالَ : نُبِّئْت عَنِ الْقَاسِمِ وَسَالِمٍ أَنَّہُمَا کَانَ یَقُولاَنِ : أَہْلُ مَکَّۃَ إذَا خَرَجُوا إلَی مِنًی قَصَرُوا۔\n\nقَالَ : وَکَانَ عَطَائٌ وَالزُّہْرِیُّ یَقُولاَنِ : یُتِمُّونَ۔",,,8267,,
8268,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ إسْمَاعِیلَ بْنِ أُمَیَّۃَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ : أَنَّہُ کَانَ یُقِیمُ بِمَکَّۃَ فَإِذَا خَرَجَ إلَی مِنًی قَصَرَ۔",,,8268,,
8269,"حَدَّثَنَا عُبَیْدُاللہِ بْنُ مُوسَی، عَنْ حَنْظَلَۃَ، قَالَ: سَأَلْتُ الْقَاسِمَ عَنِ الصَّلاَۃ مَعَ الإِمَامِ بِعَرَفَۃَ؟ قَالَ: صَلِّ بِصَلاَتِہِ۔\n\nقَالَ : وَسَأَلْت سَالِمًا وَطَاوُوسا فَقَالاَ مِثْلَ ذَلِکَ۔",,,8269,,
8270,"حَدَّثَنَا عُبَیْدُ اللہِ بنُ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنْ مُجَاہِدٍ ، وَعَطَائٍ ، قَالاَ : لَیْسَ عَلَی أَہْلِ مَکَّۃَ قَصْرُ صَلاَۃٍ فِی حَجٍّ۔",,,8270,,
8271,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الْمُغِیرَۃُ بْنُ زِیَادٍ ، عَنْ عَطَائٍ ، عَنْ عَائِشَۃَ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُتِمُّ الصَّلاَۃ فِی السَّفَرِ وَیَقْصُرُ وَیَصُومُ وَیُفْطِرُ وَیُؤَخِّرُ الظُّہْرَ وَیُعَجِّلُ الْعَصْرَ وَیُؤَخِّرُ الْمَغْرِبَ وَیُعَجِّلُ الْعِشَائَ۔ (دارقطنی 45۔ طحاوی 164)",,,8271,,
8272,"حَدَّثَنَا عَبْدَۃُ ، عَنْ عَاصِمٍ ، عَنْ أَبِی قِلاَبَۃَ ، قَالَ : إِنْ صَلَّیْتَ فِی السَّفَرِ رَکْعَتَیْنِ فَالسُّنَّۃُ ، وَإِنْ صَلَّیْتَ أَرْبَعًا فَالسُّنَّۃُ۔",,,8272,,
8273,"حَدَّثَنَا عَبْدَۃُ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ : أَنَّہَا کَانَتْ تُتِمُّ الصَّلاَۃ فِی السَّفَرِ۔",,,8273,,
8274,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ خُضَیْرٍ ، عَنْ أَبِی نَجِیحٍ الْمَکِّیِّ ، قَالَ : اصْطَحَبَ أَصْحَابُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی السَّیْرِ ، فَکَانَ بَعْضُہُمْ یُتِمُّ وَبَعْضُہُمْ یَقْصُرُ وَبَعْضُہُمْ یَصُومُ وَبَعْضُہُمْ یُفْطِرُ، فَلاَ یَعِیبُ ہَؤُلاَئِ عَلَی ہَؤُلاَئِ ، وَلاَ ہَؤُلاَئِ عَلَی ہَؤُلاَئِ۔",,,8274,,
8275,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا بِسْطَامُ بْنُ مُسْلِمٍ ، قَالَ : سَأَلْتُ عَطَائً عَنْ قَصْرِ الصَّلاَۃ فِی السَّفَرِ ؟ فَقَالَ: إِنْ قَصَرْتَ فَرُخْصَۃٌ وَإِنْ شِئْتَ أَتْمَمْتَ۔",,,8275,,
8276,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ حَبِیبِ بْنِ شَہِیدٍ ، عَنْ مَیْمُونِ بْنِ مِہْرَانَ ، أَنَّہُ سَأَلَ سَعِیدَ بْنَ الْمُسَیَّبِ عَنِ الصَّلاَۃ فِی السَّفَرِ ، فَقَالَ : إِنْ شِئْتَ رَکْعَتَیْنِ وَإِنْ شِئْتَ فَأَرْبَع۔",,,8276,,
8277,"حَدَّثَنَا غُنْدَرٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ وَمُحَمَّدٍ ، قَالَ : قُلْتُ لَہُمَا : الرَّجُلُ یَبْدُو عَشَرَۃَ أَیَّامٍ أَیَقْصُرُ الصَّلاَۃ ؟ قَالَ : فَقَالاَ : لاَ۔",,,8277,,
8278,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَبِیبٍ ، عَنْ عَمْرِو بْنِ ہَرِمٍ ، قَالَ : سُئِلَ جَابِرُ بْنُ زَیدٍ عَنِ الْقَوْمِ یَبْدُونَ مِنْ مِصْرِہِمْ إلَی الْبَرِّیَّۃِ أَیُصَلُّونَ ثِنْتَیْنِ مَا دَامُوا بُدَاۃً حَتَّی یَرْجِعُوا إلَی مِصْرِہِمْ ؟ قَالَ : لاَ لیُتِمُّوا الصَّلاَۃ فِی الْقُرْبِ والبُعد مَا دَامُوا بُدَاۃً۔",,,8278,,
8279,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَلِیِّ بْنِ زَیْدٍ ، عَنْ أَبِی نَضْرَۃَ ، عَنْ عِمْرَانَ بْنِ حُصَیْنٍ ، قَالَ : شَہِدْتُ مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْفَتْحَ فَأَقَامَ بِمَکَّۃَ ثَمَانَ عَشْرَۃَ لَیْلَۃً لاَ یُصَلِّی إِلاَّ رَکْعَتَیْنِ ، ثُمَّ یَقُولُ لأَہْلِ الْبَلَدِ : صَلُّوا أَرْبَعًا فَإِنَّا سَفْرٌ۔",,,8279,,
8280,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنِ الزُّہْرِیِّ ، عَنْ عُبَیْدِ اللہِ ، عَنِ ابْنِ عَبَّاسٍ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أقَامَ حَیْثُ فَتَحَ مَکَّۃَ خَمْسَ عَشْرَۃَ یَقْصُرُ الصَّلاَۃ حَتَّی سَارَ إلَی حُنَیْنٍ۔ (ابوداؤد 1224۔ نسائی 511)",,,8280,,
8281,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ یَحْیَی بْنِ أَبِی إِسْحَاقَ ، قَالَ : سَمِعْتُ أَنَسَ بْنَ مَالِکٍ یَقُولُ : خَرَجْنَا مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقَصَرَ الصَّلاَۃ حَتَّی أَتَیْنَا مَکَّۃَ وَأَقَامَ بِہَا عَشْرًا یَقْصُرُ الصَّلاَۃ حَتَّی رَجَعَ إلَی الْمَدِینَۃِ۔ (بخاری 1081۔ مسلم 15)",,,8281,,
8282,"حَدَّثَنَا شَرِیکٌ ، عَنِ ابْنِ الأَصْبَہَانِیِّ ، عَنْ عِکْرِمَۃَ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَقَامَ بِمَکَّۃَ سَبْعَ عَشْرَۃَ یَقْصُرُ الصَّلاَۃ۔",,,8282,,
8283,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ سِمَاکِ بْنِ سَلَمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إِنْ أَقَمْتَ فِی بَلَدٍ خَمْسَۃَ أَشْہُرٍ فَاقْصُرِ الصَّلاَۃ۔",,,8283,,
8284,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مِسْعَرٌ وَسُفْیَانُ ، عَنْ حَبِیبِ بْنِ أَبِی ثَابِتٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ مِسْوَرٍ ، قَالَ : أَقَمْنَا مَعَ سَعْدِ بْنِ مَالِکٍ شَہْرَیْنِ ، قَالَ سُفْیَانُ : بِعُمَّانَ ، وَقَالَ مِسْعَرٌ : بِعُمَّانَ ، أَوْ عَمَّان یَقْصُرُ الصَّلاَۃ وَنَحْنُ نُتِمُّ ، فَقُلْنَا لَہُ فَقَالَ : نَحْنُ أَعْلَمُ۔",,,8284,,
8285,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ أَبِی التَّیَّاحِ الضُّبَعِیِّ ، عَنْ رَجُلٍ مِنْ عَنْزَۃَ یُکَنَّی أَبَا الْمِنْہَالِ ، قَالَ: قُلْتُ لِاِبْنِ عَبَّاسٍ : إنِّی أُقِیمُ بِالْمَدِینَۃِ حَوْلاً لاَ أَشُدُّ عَلَی سَیْرٍ ، قَالَ : صَلِّ رَکْعَتَیْنِ۔",,,8285,,
8286,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الْمُثَنَّی بْنُ سَعِیدٍ ، عَنْ أَبِی جَمْرَۃَ نَصْرِ بْنِ عِمْرَانَ ، قَالَ : قلت لِاِبْنِ عَبَّاسٍ: إنَّا نُطِیلُ الْقِیَامَ بِالْغَزْوِ بِخُرَاسَانَ فَکَیْفَ تَرَی ؟ فَقَالَ : صَلِّ رَکْعَتَیْنِ وَإِنْ أَقَمْتَ عِشْرِینَ سَنَۃ۔",,,8286,,
8287,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ : أَنَّ عَبْدَ الرَّحْمَن بْنَ سَمُرَۃَ شَتَی بِکَابُلَ شَتْوَۃً ، أَوْ شَتْوَتَیْنِ یُصَلِّی رَکْعَتَیْنِ۔",,,8287,,
8288,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ : أَنَّ أَنَسَ بْنَ مَالِکٍ أَقَامَ بِسَابُورَ سَنَۃً ، أَوْ سَنَتَیْنِ یُصَلِّی رَکْعَتَیْنِ ، ثُمَّ یُسَلِّمُ ، ثُمَّ یُصَلِّی رَکْعَتَیْنِ۔",,,8288,,
8289,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ مَالِکٍ ، قَالَ : قُلْتُ لِجَابِرِ بْنِ زَیْدٍ : أُقِیمُ بِکَسْکَرٍ السَّنَۃَ وَالسَّنَتَیْنِ وَأَنَا شِبْہُ الأَہِلِ ، فَقَالَ : صَلِّ رَکْعَتَیْنِ۔",,,8289,,
8290,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ أَبِی وَائِلٍ ، عَنْ مَسْرُوقٍ ، قَالَ : أَقَمْتُ مَعَہُ سَنَتَیْنِ یُصَلِّی رَکْعَتَیْنِ بِالسِّلْسِلَۃِ ، قَالَ : قُلْتُ لَہُ : مَا حَمَلَک عَلَی ہَذَا یَا أَبَا عَائِشَۃَ ؟ فَقَالَ : الْتِمَاسُ السُّنَّۃِ۔",,,8290,,
8291,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی وَائِلٍ ، عَنْ مَسْرُوقٍ بِنَحْوِ ذَلِکَ۔,,,8291,,
8292,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ، عَنِ الأَعْمَشِ، عَنْ إبْرَاہِیمَ، قَالَ: کُنْتُ مَعَ عَلْقَمَۃَ بِخَوَارِزْمَ سَنَتَینِ یُصَلِّی رَکْعَتَیْنِ۔",,,8292,,
8293,"حَدَّثَنَا وَکِیعٌ ، قَالَ : عَلِیُّ بْنُ مُبَارَکٍ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ ثَوْبَانَ ، قَالَ : أَقَامَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِتَبُوکَ عِشْرِینَ لَیْلَۃً یُصَلِّی صَلاَۃَ الْمُسَافِرِ رَکْعَتَیْنِ۔ (بیہقی 152۔ عبدالرزاق 4335)",,,8293,,
8294,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا زَکَرِیَّا عَنْ عَامِرٍ قَالَ : أَقَامَ عَلْقَمَۃُ بِمَرْوَ سَنَتَیْنِ فِی الْغَزْوِ یَقْصُرُ الصَّلاَۃ۔",,,8294,,
8295,"حَدَّثَنَا حَفْصٌ ، عَنْ عَاصِمٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَقَامَ سَبْعَ عَشْرَۃَ یَقْصُرُ الصَّلاَۃ ، قَالَ : وَقَالَ ابْنُ عَبَّاسٍ : مَنْ أَقَامَ سَبْعَ عَشْرَۃَ قَصَرَ الصَّلاَۃ وَمَنْ أَقَامَ أَکْثَرَ مِنْ ذَلِکَ أَتَمَّ۔ (بخاری 1080۔ ابوداؤد 1223)",,,8295,,
8296,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ دَاوُدَ بْنِ أَبِی ہِنْدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : إذَا أَجْمَعَ الرَّجُلُ عَلَی إقَامَۃِ خَمْسَ عَشْرَۃَ أَتَمَّ الصَّلاَۃ",,,8296,,
8297,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ عَلِیٍّ ، قَالَ : إذَا أَقَمْت عَشْرًا فَأَتِمَّ۔",,,8297,,
8298,حَدَّثَنَا حَفْصٌ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ عَلِیٍّ بِنَحْوِہِ۔,,,8298,,
8299,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ ابی جَعْفَرٍ ، عَنْ أَبِیہِ ، قَالَ : مَنْ أَقَامَ عَشْرًا أَتَمَّ۔",,,8299,,
8300,حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ عَنْ أَبِی جَعْفَرٍ ، أَنَّہُ کَانَ یُتِمُّ فِی عَشْر۔,,,8300,,
8301,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عُمَر بْنُ ذَرٍّ ، عَنْ مُجَاہِدٍ ، قَالَ : کَانَ ابْنُ عُمَرَ إذَا أَجْمَعَ عَلَی إقَامَۃِ خَمْسَ عَشْرَۃَ سَرَحَ ظَہْرَہُ وَصَلَّی أَرْبَعًا۔",,,8301,,
8302,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ أَبِی بِشْرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : إذَا أَقَمْتَ أَکْثَرَ مِنْ خَمْسَ عَشْرَۃَ فَأَتِمَّ الصَّلاَۃ۔",,,8302,,
8303,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ہِشَامٌ ، عَنْ قَتَادَۃَ ، عَنِ ابْنِ الْمُسَیَّبِ ، قَالَ : إذَا أَقَمْتَ أَرْبَعًا فَصَلِّ أَرْبَعًا۔",,,8303,,
8304,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا قُرَّۃُ بْنُ خَالِدٍ ، عَنْ أَبِی حُکَیمَۃَ ، قَالَ : سَأَلْتُ سَعِیدَ بْنَ الْمُسَیَّبِ ، فَقَالَ : إذَا أَقَمْتَ ثَلاَثًا فَأَتِمَّ الصَّلاَۃ۔",,,8304,,
8305,"قَالَ وَکِیعٌ : سَمِعْتُ سُفْیَانَ یَقُولُ : إذَا أَجْمَعَ عَلَی مُقَامِ خَمْسَ عَشْرَۃَ أَتَمَّ الصَّلاَۃ حِینَ یَدْخُلُ ، وَإِذَا لَمْ یَدْرِ مَتَی یَخْرُجُ صَلَّی رَکْعَتَیْنِ وَإِنْ أَقَامَ حَوْلاً وَہُوَ الْقَوْلُ عِنْدَہُ۔",,,8305,,
8306,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، عَنْ عَائِشَۃَ ، قَالَتْ : إذَا وَضَعْتَ الزَّادَ وَالْمَزَادَ فَصَلِّ أَرْبَعًا وَکَانَ طَاوُوس إذَا قَدِمَ مَکَّۃَ صَلَّی أَرْبَعًا۔",,,8306,,
8307,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ دَاوُدَ ، عَنْ أَبِی الْعَالِیَۃِ ، قَالَ : یُصَلِّی رَکْعَتَیْنِ فَإِذَا اطْمَأَنَّ صَلَّی أَرْبَعًا ، یَعْنِی إذَا نَزَلَ۔",,,8307,,
8308,"حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنْ أَیُّوبَ، عَنْ عَمْرٍو، عَنْ عَطَائٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: إذَا انْتَہَیْتَ إلَی مَاشِیَتِکَ فَأَتْمِمْ۔",,,8308,,
8309,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ مِثْلَہُ۔,,,8309,,
8310,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : إذَا قَدِمَ مُسَافِرٌ مِصْرًا مِنَ الأَمْصَارِ صَلَّی أَرْبَعًا۔",,,8310,,
8311,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ ، عَنْ أَبِیہِ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ إذَا جَدَّ بِہِ السَّیْرُ جَمَعَ بَیْنَ الْمَغْرِبِ وَالْعِشَائِ۔ (بخاری 1106۔ مسلم 45)",,,8311,,
8312,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ جَابِرِ بْنِ زَیْدٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : صَلَّیْتُ مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ثَمَانِیًا جَمِیعًا وَسَبْعًا جَمِیعًا ، قَالَ : قُلْتُ : یَا أَبَا الشَّعْثَائِ أَظُنُّہُ أَخَّرَ الظُّہْرَ وَعَجَّلَ الْعَصْرَ وَأَخَّرَ الْمَغْرِبَ وَعَجَّلَ الْعِشَائَ ، قَالَ : وَأَنَا أَظُنُّ ذَلِکَ۔ (بخاری 543۔ ابوداؤد 1207)",,,8312,,
8313,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطَائٍ ، عَنْ جَابِرٍ ، قَالَ : جَمَعَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی غَزْوَۃِ تَبُوکَ بَیْنَ الظُّہْرِ وَالْعَصْرِ وَبَیْنَ الْمَغْرِبِ وَالْعِشَائِ۔",,,8313,,
8314,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ أَبِی الطُّفَیْلِ ، عَنْ مُعَاذِ بْنِ جَبَلٍ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ جَمَعَ بَیْنَ الظُّہْرِ وَالْعَصْرِ وَبَیْنَ الْمَغْرِبِ وَالْعِشَائِ فِی السَّفَرِ فِی غَزْوَۃِ تَبُوکَ۔ (مسلم 52۔ ابوداؤد 1199)",,,8314,,
8315,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا دَاوُد بْنُ قَیْسٍ الْفَرَّائُ ، عَنْ صَالِحٍ مَوْلَی التَّوْأَمَۃِ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : جَمَعَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَیْنَ الظُّہْرِ وَالْعَصْرِ وَالْمَغْرِبِ وَالْعِشَائِ فِی الْمَدِینَۃِ فِی غَیْرِ خَوْفٍ وَلاَ مَطَرٍ ، قَالَ: فَقِیلَ لِاِبْنِ عَبَّاسٍ : لِمَ فَعَلَ ذَلِکَ ؟ قَالَ : أَرَادَ التَّوْسِعَۃَ عَلَی أُمَّتِہِ۔ (احمد 1/346۔ ابو یعلی 2670)",,,8315,,
8316,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عِمْرَانُ بْنُ حُدَیْرٍ ، عَنْ عَبْدِ اللہِ بْنِ شَقِیقٍ الْعُقَیْلِیِّ ، قَالَ : قَالَ رَجُلٌ لِاِبْنِ عَبَّاسٍ : الصَّلاَۃ فَسَکَتَ ، ثُمَّ قَالَ لَہُ : الصَّلاَۃ فَسَکَتَ ، ثُمَّ قَالَ لَہُ : الصَّلاَۃ ثَلاَثًا ، فَقَالَ : لاَ أُمَّ لَکَ أَنْتَ تُعَلِّمُنَا بِالصَّلاَۃ ، قَدْ کُنَّا نَجْمَعُ بَیْنَ الصَّلاَتَیْنِ عَلَی عَہْدِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، یَعْنِی فِی السَّفَرِ۔ (مسلم 58۔ احمد 351)",,,8316,,
8317,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ حَفْصِ بْنِ عُبَیْدِ اللہِ بْنِ أَنَسٍ ، قَالَ : کُنَّا نُسَافِرُ مَعَ أَنَسِ بْنِ مَالِکٍ ، فَکَانَ إِذَا زَالَتِ الشَّمْسُ وَہُوَ فِی مَنْزِلٍ ، لَمْ یَرْکَبْ حَتَّی یُصَلِّیَ الظُّہْرَ ، فَإِذَا رَاحَ فَحَضَرَتِ الْعَصْرُ صَلَّی الْعَصْرَ ، فَإِنْ سَارَ مِنْ مَنْزِلِہِ قَبْلَ أَنْ تَزُولَ ، فَحَضَرَتِ الصَّلاَۃُ قُلْنَا لَہُ : الصَّلاَۃَ ، فَیَقُولُ : سِیرُوا ، حَتَّی إِذَا کَانَ بَیْنَ الصَّلاَتَیْنِ نَزَلَ فَجَمَعَ بَیْنَ الظُّہْرِ وَالْعَصْرِ ، ثُمَّ یَقُولُ : رَأَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، إِذَا وَصَلَ ضَحْوَتَہُ بِرَوْحَتِہِ صَنَعَ ہَکَذَا۔ (عبدالرزاق 4395",,,8317,,
8318,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : أَقْبَلَ ابْنُ عَبَّاسٍ مِنَ الطَّائِفِ فَأَخَّرَ صَلاَۃَ الْمَغْرِبِ ، ثُمَّ نَزَلَ فَجَمَعَ بَیْنَ َالْعِشَائِ والْمَغْرِبِ۔",,,8318,,
8319,"حَدَّثَنَا عَبْدَۃُ ، عَنْ عَاصِمٍ ، عَنْ أَبِی عُثْمَانَ ، قَالَ : خَرَجْتُ أَنَا وَسَعْدٌ إلَی مَکَّۃَ ، فَکَانَ یَجْمَعُ بَیْنَ الصَّلاَتَیْنِ بَیْنَ الظُّہْرِ وَالْعَصْرِ یُؤَخِّرُ مِنْ ہَذِہِ وَیُعَجِّلُ مِنْ ہَذِہِ وَیُصَلِّیہِمَا جَمِیعًا وَیُؤَخِّرُ الْمَغْرِبَ وَیُعَجِّلُ الْعِشَائَ ، ثُمَّ یُصَلِّیہِمَا جَمِیعًا حَتَّی قَدِمْنَا مَکَّۃَ۔",,,8319,,
8320,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ حَبِیبِ بْنِ شِہَابٍ ، عَنْ أَبِیہِ ، عَنْ أَبِی مُوسَی ، قَالَ : صَحِبْتُہُ فِی سَفَرٍ ، فَکَانَ یَجْمَعُ بَیْنَ الظُّہْرِ وَالْعَصْرِ وَبَیْنَ الْمَغْرِبِ وَالْعِشَائِ۔",,,8320,,
8321,"حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی عُثْمَانَ ، قَالَ : سَافَرْتُ مَعَ أُسَامَۃَ بْنِ زَیْدٍ ، وَسَعِیدِ بْنِ زَیْدٍ وَکَانَا یَجْمَعَانِ بَیْنَ الظُّہْرِ وَالْعَصْرِ وَالْمَغْرِبِ وَالْعِشَائِ۔",,,8321,,
8322,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عَبْدِ الْجَلِیلِ بْنِ عَطِیَّۃَ ، قَالَ : سَافَرْتُ مَعَ جَابِرِ بْنِ زَیْدٍ ، فَکَانَ یَجْمَعُ بَیْنَ الصَّلاَتَیْنِ۔",,,8322,,
8323,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مُغِیرَۃُ بْنُ زِیَادٍ ، عَنْ عَطَائٍ ، عَنْ عَائِشَۃَ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُؤَخِّرُ الظُّہْرَ وَیُعَجِّلُ الْعَصْرَ وَیُؤَخِّرُ الْمَغْرِبَ وَیُعَجِّلُ الْعِشَائَ فِی السَّفَرِ۔",,,8323,,
8324,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی قَیْسٍ ، عَنْ ہُذَیْلِ بْنِ شُرَحْبِیلَ الأَوْدِیِّ ، قَالَ : جَمَعَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَیْنَ الظُّہْرِ وَالْعَصْرِ وَالْمَغْرِبِ وَالْعِشَائِ فِی السَّفَرِ۔ (طیالسی 376)",,,8324,,
8325,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، وَابْنُ نُمَیْرٍ ، عَنِ الأَعْمَشِ ، عَنْ عُمَارَۃَ بْنِ عُمَیْرٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، عَنْ عَبْدِ اللہِ ، قَالَ : مَا رَأَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی صَلاَۃً إِلاَّ لِوَقْتِہَا إِلاَّ الْعِشَائَ وَالْمَغْرِبَ فَإِنَّہُ جَمَعَہُمَا یَوْمَئِذٍ بِجَمْعٍ ، وَصَلَّی الْفَجْرَ یَوْمَئِذٍ قَبْلَ مِیقَاتِہَا۔ (بخاری 1682۔ ابوداؤد 1929)",,,8325,,
8326,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ الْجُرَیرِیِّ ، عَنْ أَبِی عُثْمَانَ ، قَالَ : کَانَ أُسَامَۃُ بْنُ زَیْدٍ إذَا عَجِلَ بِہِ السَّیْرُ جَمَعَ بَیْنَ الصَّلاَتَیْنِ۔",,,8326,,
8327,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مَالِکُ بْنُ مِغْوَلٍ ، قَالَ : سَأَلْتُ عَطَائً عَنْ تَأْخِیرِ الظُّہْرِ وَالْمَغْرِبِ فِی السَّفَرِ، فَلَمْ یَرَ بِہِ بَأْسًا۔",,,8327,,
8328,"حَدَّثَنَا وَکِیعٌ ، عَنْ زَیْدٍ أَبِی أُسَامَۃَ ، قَالَ : سَأَلْتُ مُجَاہِدًا عَنْ تَأْخِیرِ الْمَغْرِبِ وَتَعْجِیلِ الْعِشَائِ فِی السَّفَرِ ، فَلَمْ یَرَ بِہِ بَأْسًا۔",,,8328,,
8329,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ حَجَّاجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، قَالَ : جَمَعَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَیْنَ الصَّلاَتَیْنِ فِی غَزْوَۃِ بَنِی الْمُصْطَلِقِ۔ (احمد 179)",,,8329,,
8330,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَبْدِ اللہِ بْنِ مُحَمَّدِ بْنِ عُمَرَ بْنِ عَلِیٍّ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ : أَنَّ عَلِیًّا کَانَ یُصَلِّی الْمَغْرِبَ فِی السَّفَرِ ، ثُمَّ یَتَعَشَّی ، ثُمَّ یُصَلِّی الْعِشَائَ عَلَی إثْرِہَا ، ثُمَّ یَقُولُ : ہَکَذَا رَأَیْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَصْنَعُ۔ (ابوداؤد 1227۔ نسائی 1571)",,,8330,,
8331,"حَدَّثَنَا بَکْرُ بْنُ عَبْدِ الرَّحْمَنِ ، قَالَ : حدَّثَنَا عِیسَی بْنُ الْمُخْتَارِ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ أَبِی قَیْسٍ ، عَنْ ہُزَیْلٍ ، عَنْ عَبْدِ اللہِ بْنِ مَسْعُودٍ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ جَمَعَ بَیْنَ الصَّلاَتَیْنِ فِی السَّفَرِ۔ (طبرانی 9881۔ ابو یعلی 5413)",,,8331,,
8332,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ الأَسْوَدُ وَأَصْحَابُہُ یَنْزِلُونَ عِنْدَ وَقْتِ کُلِّ صَلاَۃٍ فِی السَّفَرِ فَیُصَلُّونَ الْمَغْرِبَ لِوَقْتِہَا، ثُمَّ یَتَعَشَّوْنَ، ثُمَّ یَمْکُثُونَ سَاعَۃً، ثُمَّ یُصَلُّونَ الْعِشَائَ۔",,,8332,,
8333,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ أُبَیِّ بْنِ عَبْدِ اللہِ ، قَالَ : جَائَنَا کِتَابُ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ : أنْ لاَ تَجْمَعُوا بَیْنَ الصَّلاَتَیْنِ إِلاَّ مِنْ عُذْرٍ۔",,,8333,,
8334,"حَدَّثَنَا عَبْدُ الأَعْلَی بْنُ عَبْدِ الأَعْلَی ، عَنْ یُونُسَ ، قَالَ : سُئِلَ الْحَسَنُ عَنْ جَمْعِ الصَّلاَتَیْنِ فِی السَّفَرِ ، فَکَانَ لاَ یُعْجِبُہُ ذَلِکَ إِلاَّ مِنْ عُذْرٍ۔",,,8334,,
8335,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ : أَنَّ الأَسْوَدَ کَانَ یَنْزِلُ لِوَقْتِ الصَّلاَۃ فِی السَّفَرِ وَلَوْ عَلَی حَجَرٍ۔",,,8335,,
8336,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عُمَارَۃَ ، عَنِ الأَسْوَدِ ، قَالَ : مَا کَانَ إِلاَّ رَاہِبًا إذَا جَائَ وَقْتُ الصَّلاَۃ نَزَلَ وَلَوْ عَلَی حَجَرٍ۔",,,8336,,
8337,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا أَبُو ہِلاَلٍ ، عَنْ حَنْظَلَۃَ السَّدُوسِیِّ ، عَنْ أَبِی مُوسَی ، قَالَ : الْجَمْعُ بَیْنَ الصَّلاَتَیْنِ مِنْ غَیْرِ عُذْرٍ مِنَ الْکَبَائِرِ۔",,,8337,,
8338,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ ہِشَامِ بْنِ حَسَّانَ ، عَنْ رَجُلٍ ، عَنْ أَبِی الْعَالِیَۃِ ، عَنْ عُمَرَ ، قَالَ: الْجَمْعُ بَیْنَ الصَّلاَتَیْنِ مِنْ غَیْرِ عُذْرٍ مِنَ الْکَبَائِرِ۔",,,8338,,
8339,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عُبَیدُ اللہِ بْنُ عَبْدِ الرَّحْمَنِ بْنِ مَوْہَبٍ ، قَالَ : أَتَیْتُُ سَالِمًا فَقُلْتُ یَا أَبَا عُمَرَ تَجْمَعُ بَیْنَ الصَّلاَتَیْنِ فِی السَّفَرِ ؟ فَقَالَ : لاَ إِلاَّ أَنْ یَعْجَلَنِی سَیْرٌ۔",,,8339,,
8340,"حَدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : ذُکِرَ لِمُحَمَّدِ بْنِ سِیرِینَ أَنَّ جَابِرَ بْنَ زَیْدٍ یَجْمَعُ بَیْنَ الصَّلاَتَیْنِ ، فَقَالَ : مَا أَرَی أَنْ یَجْمَعَ بَیْنَ الصَّلاَتَیْنِ إِلاَّ مِنْ أَمْرٍ۔",,,8340,,
8341,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ وَمُحَمَّدٍ ، قَالاَ : مَا نَعْلَمُ مِنَ السُّنَّۃِ الْجَمْعَ بَیْنَ الصَّلاَتَیْنِ فِی حَضَرٍ وَلاَ سَفَرٍ إِلاَّ بَیْنَ الظُّہْرِ وَالْعَصْرِ بِعَرَفَۃَ وَبَیْنَ الْمَغْرِبِ وَالْعِشَائِ بِجَمْعٍ۔",,,8341,,
8342,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ حَرْمَلَۃَ : أَنَّ رَجُلاً جَائَ إلی سَعِیدِ بْنَ الْمُسَیَّبِ ، فَقَالَ: إنِّی رَاعِی إبِلٍ أَطلُبہَا حَتَّی إذَا أَمْسَیْتُ صَلَّیْتُ الْمَغْرِبَ ، ثُمَّ طَرَحْتُ نَفْسِی فَرَقَدْتُ عَنِ الْعَتَمَۃِ ، فَقَالَ : لاَ تَنَمْ حَتَّی تُصَلِّیَہَا ، فَإِنْ خِفْتَ أَنْ تَرْقُدَ فَاجْمَعْ بَیْنَہُمَا۔",,,8342,,
8343,"حَدَّثَنَا عَبْدُ اللہِ بْنُ مُبَارَکٍ ، عَنْ یَعْقُوبَ ، عَنْ عَطَائٍ ، وَعَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ فِی الْمَرِیضِ یُصَلِّی ، قَالاَ : إِنْ شَائَ جَمَعَ بَیْنَ الصَّلاَتَیْنِ۔",,,8343,,
8344,"حَدَّثَنَا عَبْدُ اللہِ بْنُ مُبَارَکٍ ، عَنْ یَعْقُوبَ ، عَنْ عَطَائٍ فِی الرَّاعِی یَقْصُرُ ، قَالَ : إنَّمَا یَقْصُرُ الْمُسَافِرُ۔",,,8344,,
8345,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ عَطَائٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، وَأَبِی الْبَخْتَرِیِّ ، قَالَ : أَظُنُّ فِیہِ وَأَصْحَابِہِمْ قَالُوا : إذَا الْتَقَی الزَّحْفَانِ وَضَرَبَ النَّاسُ بَعْضُہُمْ بَعْضًا وَحَضَرَتِ الصَّلاَۃُ فَقُلْ : سُبْحَانَ اللہِ وَالْحَمْدُ لِلَّہِ ، وَلاَ إلَہَ إِلاَّ اللَّہُ وَاللَّہُ أَکْبَرُ فَتِلْکَ صَلاَتُکَ ، ثُمَّ لاَ تُعِدْ۔",,,8345,,
8346,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ وَالْحَکَمِ ، قَالاَ : إذَا کَانَ عِنْدَ الطِّرَادِ وَعِنْدَ سَلِّ السُّیُوفِ أَجْزَأَ الرَّجُلَ أَنْ تَکُونَ صَلاَتُہُ تَکْبِیرًا ، فَإِنْ لَمْ یَکُنْ إِلاَّ تَکْبِیرَۃٌ وَاحِدَۃٌ أَجْزَأَتْہُ أَیْنَمَا کَانَ وَجْہُہُ۔",,,8346,,
8347,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ : فِی قولہ تعالی : {فَإِنْ خِفْتُمْ فَرِجَالاً ، أَوْ رُکْبَانًا} قَالَ : إذَا حَضَرَتِ الصَّلاَۃ فِی الْمُطَارَدَۃِ فَأَوْمِ حَیْثُ کَانَ وَجْہُکَ وَاجْعَلِ السُّجُودَ أَخْفَضَ مِنَ الرُّکُوعِ۔",,,8347,,
8348,"حَدَّثَنَا عَبَّادُ بْنُ عَوَّامٍ ، عَنْ أَبِی مَسْلَمَۃَ ، عَنْ أَبِی نَضْرَۃَ ، عَنْ جَابِرِ بْنِ غُرَابٍ وَکَانَ سَیِّدَ النَّمِر ، قَالَ : کُنَّا مَعَ ہَرِمِ بْنِ حَیَّانَ فِی جَیْشٍ نُقَاتِلُ الْعَدُوَّ ، فَقَالَ ہَرِمٌ : لیَسْجُدُ کُلُّ رَجُلٍ مِنْکُمْ سَجْدَۃً تَحْتَ جُنَّتِہِ۔",,,8348,,
8349,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، سُئِلَ عَنِ الرَّجُلِ إذَا حَضَرَتِ الْمُسَایَفَۃُ کَیْفَ یُصَلِّی ؟ فَقَالَ : یُصَلِّی رَکْعَۃً وَسَجْدَتَیْنِ تِلْقَائَ وَجْہِہِ۔",,,8349,,
8350,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، قَالَ : سَأَلْتُ الْحَکَمَ وَحَمَّادًا عَنْ صَلاَۃِ الْمُسَایَفَۃِ ، فَقَالاَ : رَکْعَۃً حَیْثُ کَانَ وَجْہُہُ یُومِیئُ إیمَائً۔",,,8350,,
8351,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا شُعْبَۃُ عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : الصَّلاَۃ عِنْد الْمُسَایَفَۃِ رَکْعَۃً یُومِیئُ إیمَائً حَیْثُ کَانَ وَجْہُہُ۔",,,8351,,
8352,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، قَالَ : تُجْزِئہ تَکْبِیرَۃٌ عِنْدَ السَّلَّۃِ إذَا لَمْ یَسْتَطِعْ۔",,,8352,,
8353,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ ، أَنَّہُ کَانَ یَقُولُ فِی صَلاَۃِ الْمُسَایَفَۃِ : یُومِئُ إیمَائً حَیْثُ کَانَ وَجْہُہُ۔",,,8353,,
8354,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ ، قَالَ : تَکْبِیرَتَیْنِ عِنْدَ الْمُسَایَفَۃِ۔",,,8354,,
8355,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : الصَّلاَۃ عِنْدَ الْمُسَایَفَۃِ رَک",,,8355,,
8356,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ عَوْنٍ ، عَنْ رَجَائِ بْنِ حَیْوَۃَ الْکِنْدِیِّ ، قَالَ : کَانَ ثَابِتُ بْنُ السِّمْطِ ، أَوِ السِّمْطُ بْنُ ثَابِتٍ فِی مَسِیرٍ فِی خَوْفٍ فَحَضَرَتِ الصَّلاَۃ فَصَلَّوْا رُکْبَانًا فَنَزَلَ الأَشْتَرُ ، فَقَالَ : مَا لَہُ ؟ قَالُوا : نَزَلَ فَصَلَّی ، قَالَ : مَا لَہُ خَالَفَ خُولِفَ بِہِ۔",,,8356,,
8357,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی بَکْرٍ بْنِ أَبِی الْجَہْمِ بن صُخَیْرٍ الْعَدَوِیِّ ، عَنْ عُبَیْدِ اللہِ بْنِ عَبْدِ اللہِ بْنِ عُتْبَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : صَلَّی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلاَۃَ الْخَوْفِ بِذِی قَرَدٍ أَرْضٍ مِنْ أَرْضِ بَنِی سُلَیْمٍ ، فَصَفَّ النَّاسُ خَلفَہُ صَفَّیْنِ ، صَفٌّ خَلْفَہُ ، وَصَفٌّ مُوَاز الْعَدُوِّ ، فَصَلَّی بِالصَّفِّ الَّذِی یَلِیہِ رَکْعَۃً ، ثُمَّ نَکَصَ ہَؤُلاَئِ إلَی مَصَافِّ ہَؤُلاَئِ وَہَؤُلاَئِ إلَی مَصَافِّ ہَؤُلاَئِ فَصَلَّی بِہِمْ رَکْعَۃً۔ (احمد 1/232۔ عبدالرزاق 357)",,,8357,,
8358,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ الرُّکَیْنِ الْفَزَارِیِّ ، عَنِ الْقَاسِمِ بْنِ حَسَّانَ ، عَنْ زَیْدِ بْنِ ثَابِتٍ : أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی صَلاَۃَ الْخَوْفِ۔\n\nقَالَ سُفْیَانُ فَذَکَرَ مِثْلَ حَدِیثِ ابْنِ عَبَّاسٍ۔ (نسائی 1919۔ ابن خزیمۃ 1345)",,,8358,,
8359,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَشْعَثَ بن أَبِی الشَّعْثَائِ ، عَنِ الأَسْوَدِ بْنِ ہِلاَلٍ ، عَنْ ثَعْلَبَۃَ بْنِ زَہْدَمٍ الْحَنْظَلِیِّ ، قَالَ : کُنَّا مَعَ سَعِیدِ بْنِ الْعَاصِ بِطَبَرِسْتَانَ وَمَعَنَا حُذَیْفَۃُ ، فَقَالَ سَعِیدٌ : أَیُّکُمْ صَلَّی مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلاَۃَ الْخَوْفِ ؟ فَقَالَ : حُذَیْفَۃُ : أَنَا ، قَالَ : فَقَامَ فَصَلَّی بِالنَّاسِ۔\n\nقَالَ سُفْیَانُ : فَذَکَرَ مِثْلَ حَدِیثِ ابْنِ عَبَّاسٍ وَزَیْدِ بْنِ ثَابِتٍ۔ (ابوداؤد 1240۔ احمد 5/399)",,,8359,,
8360,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ: حدَّثَنَا سَعِیدٌ، عَنْ قَتَادَۃَ، عَنْ أَبِی الْعَالِیَۃِ الرِّیَاحِیِّ: أَنَّ أَبَا مُوسَی الأَشْعَرِِی کَانَ بِالدَّارِ مِنْ أَصْبَہَانَ وَمَا بِہِمْ یَوْمَئِذٍ کَثِیرُ خَوْفٍ وَلَکِنْ أَحَبَّ أَنْ یُعَلِّمَہُمْ دِینَہُمْ وَسُنَّۃَ نَبِیِّہِمْ فَجَعَلَہُمْ صَفَّیْنِ ، طَائِفَۃٌ مَعَہَا السِّلاَحُ مُقْبِلَۃٌ عَلَی عَدُوِّہَا وَطَائِفَۃٌ وَرَائَہَا ، فَصَلَّی بِالَّذِینَ یَلُونَہ رَکْعَۃً ، ثُمَّ نَکَصُوا عَلَی أَدْبَارِہِمْ حَتَّی قَامُوا مَقَامَ الأَخَرِینَ یَتَخَلَّلُونَہُمْ حَتَّی قَامُوا وَرَائَہُ فَصَلَّی بِہِمْ رَکْعَۃً أُخْرَی ، ثُمَّ سَلَّمَ ، فَقَامَ الَّذِینَ یَلُونَ وَالأَخَرُونَ فَصَلَّوْا رَکْعَۃً رَکْعَۃً فَسَلَّمَ بِہِمْ بَعْضُہُمْ عَلَی بَعْضٍ فَتَمَّتْ لِلإِمَامِ رَکْعَتَانِ فِی جَمَاعَۃٍ وَلِلنَّاسِ رَکْعَۃٌ رَکْعَۃٌ۔ (طبرانی 197۔ بیہقی 253)",,,8360,,
8361,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ خُصَیْفٍ ، عَنْ أَبِی عُبَیْدَۃَ ، عَن عَبد اللہ ، قَالَ : صَلَّی بِنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلاَۃَ الْخَوْفِ فَقَامُوا صَفَّیْنِ صَفٌّ خَلْفَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَصَفٌّ مُسْتَقْبِلٌ الْعَدُوَّ فَصَلَّی بِہِمْ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَکْعَۃً وَجَائَ الأَخَرُونَ فَقَامُوا مَقَامَہُمْ وَاسْتَقْبَلَ ہَؤُلاَئِ الْعَدُوَّ فَصَلَّی بِہِمْ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَکْعَۃً ، ثُمَّ سَلَّمَ فَقَامَ ہَؤُلاَئِ فَصَلَّوْا لأَنْفُسِہِمْ رَکْعَۃً ، ثُمَّ سَلَّمُوا ، ثُمَّ ذَہَبُوا فَقَامُوا مَقَامَ أُولَئِکَ مُسْتَقْبِلَ الْعَدُوِّ وَرَجَعَ أُولَئِکَ إلَی مَقَامِہِمْ فَصَلَّوْا لأَنْفُسِہِمْ رَکْعَۃً، ثُمَّ سَلَّمُوا۔ (ابوداؤد 1237۔ احمد 375)",,,8361,,
8362,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ یَزِیدَ الْفَقِیرِ ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ : أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی بِہِمْ صَلاَۃَ الْخَوْفِ فَقَامَ صَفٌّ بَیْنَ یَدَیْہِ وَصَفٌّ خَلْفَہُ فَصَلَّی بِہِمْ وَجَائَ أُولَئِکَ حَتَّی قَامُوا مَقَامَ ہَؤُلاَئِ فَصَلَّی بِہِمْ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَکْعَۃً وَسَجْدَتَیْنِ ، ثُمَّ سَلَّمَ فَکَانَتْ لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَکْعَتَانِ وَلَہُمْ رَکْعَۃٌ رَکْعَۃٌ۔ (نسائی 1933۔ احمد 3/298)",,,8362,,
8363,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عُمَرُ بْنُ ذَرٍّ سَمِعَہُ مِنْ مُجَاہِدٍ قَالَ : کَانَ رَسُولُ اللہِ بِعُسْفَانَ وَالْمُشْرِکُونَ بِضَجِنَانَ ، فَلَمَّا صَلَّی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الظُّہْرَ رَآہُ الْمُشْرِکُونَ یَرْکَعُ وَیَسْجُدُ فَائْتَمَرُوا أَنْ یُغِیرُوا عَلَیْہِ ، فَلَمَّا حَضَرَتِ الْعَصْرُ صَفَّ النَّاسُ خَلْفَہُ صَفَّیْنِ فَکَبَّرَ وَکَبَّرُوا جَمِیعًا وَرَکَعَ وَرَکَعُوا جَمِیعًا وَسَجَدَ وَسَجَدَ الصَّفُّ الَّذِینَ یَلُونَہُ وَقَامَ الصَّفُّ الثَّانِی الَّذِینَ بِسِلاَحِہِمْ مُقْبِلِینَ عَلَی الْعَدُوِّ بِوُجُوہِہِمْ ، فَلَمَّا رَفَعَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَأْسَہُ سَجَدَ الصَّفُّ الثَّانِی ، فَلَمَّا رَفَعُوا رُؤُوسَہُمْ رَکَعَ وَرَکَعُوا جَمِیعًا وَسَجَدَ وَسَجَدَ الصَّفُّ الَّذِینَ یَلُونَہُ وَقَامَ الصَّفُّ الثَّانِی بِسِلاَحِہِمْ مُقْبِلِینَ عَلَی الْعَدُوِّ بِوُجُوہِہِمْ ، فَلَمَّا رَفَعَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَأْسَہُ سَجَدَ الصَّفُّ الثَّانِی۔\n\n قَالَ: قَالَ مُجَاہِدٌ، فَکَانَ تَکْبِیرُہُمْ وَرُکُوعُہُمْ وَتَسْلِیمُہُ عَلَیْہِمْ سَوَائً وَتَنَاصَفُوا فِی السُّجُودِ۔ قَالَ: قَالَ مُجَاہِدٌ فَلَمْ یُصَلِّ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلاَۃَ الْخَوْفِ قَبْلَ یَوْمِہِ، وَلاَ بَعْدَہُ۔(عبدالرزاق 4235)",,,8363,,
8364,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، عَنْ أَبِی عَیَّاشٍ الزُّرَقِیِّ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِنَحْوٍ مِنْ حَدِیثِ عُمَرَ بْنِ ذَرٍّ۔ (ابوداؤد 1229۔ ابن حبان 2876)",,,8364,,
8365,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِنَحْوٍ مِنْ حَدِیثِ مُجَاہِدٍ ، وَزَادَ فِیہِ کَمَا یَفْعَلُ حَرَسُکُمْ ہَؤُلاَئِ بِأُمَرَائِہِمْ۔ (مسلم 308۔ احمد 3/374),,,8365,,
8366,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سَالِمٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی بِہِمْ رَکْعَتَیْنِ فَکَانَ لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَکْعَتَانِ وَلَہُمْ رَکْعَۃٌ رَکْعَۃٌ۔",,,8366,,
8367,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الْمَسْعُودِیُّ وَمِسْعَرٌ ، عَنْ یَزِیدَ الْفَقِیرِ ، عَنْ جَابِرِ بْنِ عَبْد اللہِ ، قَالَ : صَلاَۃُ الْخَوْفِ رَکْعَۃٌ رَکْعَۃٌ۔",,,8367,,
8368,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی عَوَانَۃَ ، عَنْ بُکَیْرِ بْنِ الأَخْنَسِ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : فَرَضَ اللَّہُ تَعَالی صَلاَۃَ الْحَضَرِ أَرْبَعَۃً وَالسَّفَرِ رَکْعَتَیْنِ وَالْخَوْفِ رَکْعَۃً عَلَی لِسَانِ نَبِیِّکُمْ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔ (مسلم 479۔ ابوداؤد 1241)",,,8368,,
8369,"حَدَّثَنَا قَاسِمُ بْنُ مَالِکٍ ، عَنْ أَیُّوبَ بْنِ عَائِذٍ ، عَنْ بُکَیرِ بْنِ الأَخْنَسِ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ: فَرَضَ اللَّہُ صَلاَۃَ الْحَضَرِ أَربَعًا وَصَلاَۃَ السَّفَرِ رَکْعَتَیْنِ وَالْخَوْفِ رَکْعَۃً عَلَی لِسَانِ نَبِیِّہِ ، أَوَ قَالَ نَبِیِّکُمْ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔ (مسلم 479۔ احمد 1/243)",,,8369,,
8370,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مُوسَی بْنِ عُقْبَۃَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : صَلَّی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلاَۃَ الْخَوْفِ فِی بَعْضِ أَیَّامِہِ فَقَامَتْ طَائِفَۃٌ مَعَہُ وَطَائِفَۃٌ بِإِزَائِ الْعَدُوِّ ، فَصَلَّی بِالَّذِینَ مَعَہُ رَکْعَۃً ، ثُمَّ ذَہَبُوا وَجَائَ الأَخَرُونَ فَصَلَّی بِہِمْ رَکْعَۃً ، ثُمَّ قَضَتِ الطَّائِفَتَانِ رَکْعَۃً رَکْعَۃً۔\n\nقَالَ : وَقَالَ ابْنُ عُمَرَ إذَا کَانَ خَوْفٌ أَکْبَرُ مِنْ ذَلِکَ فَصَلِّ رَاکِبًا ، أَوْ قَائِمًا تُومِیئُ إیمَائً۔ (بخاری 943۔ مسلم 306)",,,8370,,
8371,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : صَلَّیْت صَلاَۃَ الْخَوْفِ مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَکْعَتَیْنِ رَکْعَتَیْنِ إِلاَّ الْمَغْرِبَ ، فَإِنَّہُ صَلاَّہَا ثَلاَثًا۔",,,8371,,
8372,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ سُئِلَ عَنْ صَلاَۃِ الْخَوْفِ ، فَقَالَ : نُبِّئْت عَنْ جَابِرِ بْنِ عَبْدِ اللہِ : أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی بِأَصْحَابِہِ فَصَلَّی بِطَائِفَۃٍ مِنْہُمْ وَطَائِفَۃٌ مُوَاجِہَۃُ الْعَدُوِّ فَصَلَّی بِہِمْ رَکْعَتَیْنِ ، ثُمَّ قَامُوا مَقَامَ الأَخَرِینَ فَجَائَ الأَخَرُونَ فَصَلَّوا فَصَلَّی بِہِمْ رَکْعَتَیْنِ ، ثُمَّ سَلَّمَ۔ (نسائی 1942۔ بیہقی 259)",,,8372,,
8373,"حَدَّثَنَا عَفَّانُ ، قَالَ : أَبَانُ بْنُ زَیْدٍ قَالَ : حَدَّثَنَا یَحْیَی بْنُ أَبِی کَثِیرٍ ، عَنْ أَبِی سَلَمَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ ، عَنْ جَابِرِ بنِ عَبْدِ اللہِ ، قَالَ : أَقْبَلْنَا مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَتَّی إذَا کُنَّا بِذَاتِ الرِّقَاعِ نُودِیَ بِالصَّلاَۃ فَصَلَّی بِطَائِفَۃٍ رَکْعَتَیْنِ ، ثُمَّ تَأَخَّرُوا وَصَلَّی بِالطَّائِفَۃِ الأُخْرَی رَکْعَتَیْنِ ، قَالَ : فَکَانَتْ لِرَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَرْبَعُ رَکَعَاتٍ ، وَلِلْقَوْمِ رَکْعَتَانِ۔ (مسلم 311۔ ابن حبان 2884)",,,8373,,
8374,"حَدَّثَنَا شَرِیکٌ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ سُلَیْمِ بْنِ عَبْدٍ ، عَنْ حُذَیْفَۃَ ، قَالَ : صَلاَۃُ الْخَوْفِ رَکْعَتَانِ وَأَرْبَعُ سَجَدَاتٍ ، فَإِنْ أَعْجَلَکَ الْعَدُوُّ فَقَدْ حَلَّ لَکَ الْقِتَالُ وَالْکَلاَمُ بَیْنَ الرَّکْعَتَیْنِ۔",,,8374,,
8375,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ سُلَیْمِ بْنِ عَبْدٍ السَّلُولِیِّ ، عَنْ حُذَیْفَۃَ قَالَ : إِنْ ہَاجَ بِکَ ہَیجٌ فَقَد حَلَّ لَکَ الْقِتَالُ وَالْکَلاَمُ ، یَعْنِی فِی الصَّلاَۃ۔",,,8375,,
8376,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ : أَنَّ أَبَا مُوسَی صَلَّی بِأَصْحَابِہِ بِأَصْبَہَانَ فَصَلَّتْ طَائِفَۃٌ مِنْہُمْ مَعَہُ وَطَائِفَۃٌ مُوَاجِہَۃُ الْعَدُوِّ فَصَلَّی بِہِمْ رَکْعَۃً ، ثُمَّ نَکَصُوا وَأَقْبَلَ الأَخَرُونَ یَتَخَلَّلُونَہُمْ فَصَلَّی بِہِمْ رَکْعَۃً ، ثُمَّ سَلَّمَ وَقَامَتِ الطَّائِفَتَانِ فَصَلَّتَا رَکْعَۃً رَکْعَۃً۔",,,8376,,
8377,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ أَبِی الزُّبَیْرِ ، سَمِعَ جَابِرًا یَقُولُ : سُئِلَ عَنْ صَلاَۃِ الْخَوْفِ ؟ فَقَالَ : کَمَا یَصْنَعُ أُمَرَاؤُکُمْ ہَؤُلاَئِ۔",,,8377,,
8378,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، قَالَ : سَمِعْتُہُ یُحَدِّثُ ، عَنْ أَبِی عَیَّاشٍ الزُّرَقِیِّ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ مُصَافَّ الْعَدُوِّ بِعُسْفَانَ وَعَلَی الْمُشْرِکِینَ خَالِدُ بْنُ الْوَلِیدِ ، فَصَلَّی بِہِمُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الظُّہْرَ ، ثُمَّ قَالَ الْمُشْرِکُونَ : إنَّ لَہُمْ صَلاَۃً بَعْدَ ہَذِہِ ہِیَ أَحَبُّ إلَیْہِمْ مِنْ أَمْوَالِہِمْ وَأَبْنَائِہِمْ ، قَالَ : فَصَلَّی بِہِمْ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَصَفَّہُمْ خَلْفَہُ صَفَّیْنِ ، قَالَ : فَرَکَعَ بِہِمْ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ جَمِیعًا ، فَلَمَّا رَفَعُوا رُؤُوسَہُمْ سَجَدَ الصَّفُّ الَّذِی یَلِیہِ وَقَامَ الأَخَرُونَ ، فَلَمَّا رَفَعُوا رُؤُوسَہُمْ مِنَ السُّجُودِ سَجَدَ الصَّفُّ الْمُؤَخَّرُ لِرُکُوعِہِمْ مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : ثُمَّ تَأَخَّرَ الصَّفُّ الْمُقَدَّمُ وَتَقَدَّمَ الصَّفُّ الْمُؤَخَّرُ لِرُکُوعِہِمْ مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، ثُمَّ تَأَخَّرَ الصَّفُّ الْمُؤَخَّرُ وَتَقَدَّمَ الصَّفُّ الْمُقَدَّمُ فَقَامَ کُلُّ وَاحِدٍ مِنْہُمَا فِی مَقَامِ صَاحِبِہِ ، ثُمَّ رَکَعَ وَقَامَ الأَخَرُونَ ، فَلَمَّا فَرَغُوا مِنْ سُجُودِہِمْ سَجَدَ الأَخَرُونَ ، ثُمَّ سَلَّمَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَلَیْہِمْ۔ (نسائی 1937۔ احمد 4/60)",,,8378,,
8379,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : أَخْبَرَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ الْقَاسِمِ بْنِ مُحَمَّدٍ ، عَنْ صَالِحِ بْنِ خَوَّاتٍ ، عَنْ سَہْلِ بْنِ أَبِی حَثْمَۃَ فِی صَلاَۃِ الْخَوْفِ ، قَالَ : یَقُومُ الإِمَام إلَی الْقِبْلَۃِ وَمَعَہُ طَائِفَۃٌ وَطَائِفَۃٌ مُوَاجِہَۃُ الْعَدُوِّ فَیُصَلی بِمَنْ مَعَہُ رَکْعَۃً فَإِذَا قَامَ وَقَفَ قَائمًا وَصَلَّی الَّذِینَ وَرَائَہُ لأَنْفُسِہِمْ رَکْعَۃً وَسَجَدُوا وَسَلَّمُوا ، ثُمَّ ذَہَبُوا حَتَّی یَقُومُوا مَقَامَ إخْوَانِہِمُ الَّذِینَ بِإِزَائِ الْعَدُوِّ وَرَجَعَ الأَخَرُونَ عَلَی أَعْقَابِہِمْ فَوَقَفُوا خَلْفَ الإِمَام فَصَلَّی بِہِمْ رَکْعَۃً أُخْرَی ، ثُمَّ سَلَّمَ وَقَامَ الَّذِینَ وَرَائَہُمْ فَرَکَعُوا لأَنْفُسِہِمْ وَسَجَدُوا وَسَلَّمُوا۔ (بخاری 4131۔ ابوداؤد 1232)",,,8379,,
8380,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ سَالِمٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ قَالَ : رَکْعَۃٌ کَیْفَ تَکُونُ مَقْصُورَۃً وَہُمَا رَکْعَتَانِ۔",,,8380,,
8381,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مُغِیرَۃَ ، عَنِ الشَّعْبِیِّ ، عَنْ مَسْرُوقٍ ، أَنَّہُ قَالَ : صَلاَۃُ الْخَوْفِ یَقُومُ الإِمَام وَیَصُفُّونَ خَلْفَہُ صَفَّیْنِ ، ثُمَّ یَرْکَعُ الإِمَام فَیَرْکَعُ الَّذِینَ یَلُونَہُ ، ثُمَّ یَسْجُدُ بِالَّذِین یَلُونَہُ فَإِذَا قَامَ تَأَخَّرَ ہَؤُلاَئِ الَّذِینَ یَلُونَہُ وَجَائَ الأَخَرُونَ فَقَامُوا مَقَامَہُمْ فَرَکَعَ بِہِمْ وَسَجَدَ بِہِمْ وَالأَخَرُونَ قِیَامٌ ، ثُمَّ یَقُومُونَ فَیَقْضُونَ رَکْعَۃً رَکْعَۃً فَیَکُونُ لِلإِمَامِ رَکْعَتَانِ فِی جَمَاعَۃٍ وَیَکُونُ لِلْقَوْمِ رَکْعَۃٌ رَکْعَۃٌ فِی جَمَاعَۃٍ وَیَقْضُونَ الرَّکْعَۃَ الثَّانِیَۃَ۔",,,8381,,
8382,حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَلِیِّ بْنِ زَیْدٍ ، عَنْ یُوسُفَ بْنِ مِہْرَانَ ، عَنِ ابْنِ عَبَّاسٍ مِثْلَ ذَلِکَ۔,,,8382,,
8383,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ أَبِی خَالِدٍ ، عَنْ قَیْسِ بْنِ أَبِی حَازِمٍ ، عَنْ أَبِی مَسْعُودٍ الأَنْصَارِیِّ عُقْبَۃَ بْنِ عَمْرٍو قَالَ : انْکَسَفَتِ الشَّمْسُ عَلَی عَہْدِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ النَّاسُ : إنَّمَا انْکَسَفَتْ لِمَوْتِ إبْرَاہِیمَ ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ الشَّمْسَ وَالْقَمَرَ لاَ یَنْکَسِفَانِ لِمَوْتِ أَحَدٍ وَلاَ لِحَیَاتِہِ وَلَکِنَّہُمَا آیَتَانِ مِنْ آیَاتِ اللہِ فَإِذَا رَأَیْتُمُوہُمَا فَصَلُّوا۔ (بخاری 1041۔ مسلم 23)",,,8383,,
8384,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَاصِمٍ ، عَنْ أَبِی قِلاَبَۃَ ، عَنِ النُّعْمَانِ بْنِ بَشِیرٍ : أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی فِی کُسُوفٍ نَحْوًا مِنْ صَلاَتِکُمْ یَرْکَعُ وَیَسْجُدُ۔ (ابوداؤد 1186۔ احمد 4/267)",,,8384,,
8385,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ أَبِیہِ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ، قَالَ : انْکَسَفَتِ الشَّمْسُ عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقَامَ وَقُمْنَا مَعَہُ ، ثُمَّ قَالَ : یَا أَیُّہَا النَّاسُ إنَّ الشَّمْسَ وَالْقَمَرَ آیَتَانِ مِنْ آیَاتِ اللہِ فَإِذَا انْکَسَفَتْ إحْدَاہُمَا فَافْزَعُوا إلَی الْمَسَاجِدِ۔ (نسائی 1867)",,,8385,,
8386,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، وَابْنُ نُمَیْرٍ ، عَنْ سُفْیَانَ ، عَنْ حَبِیبٍ ، عَنْ طَاوُوسٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : صَلَّی بِنَا رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی کُسُوفِ الشَّمْسِ ، ثَمَانَ رَکَعَاتٍ فِی أَرْبَعِ سَجَدَاتٍ۔ (مسلم 18۔ ابوداؤد 1176)",,,8386,,
8387,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ حَبِیبِ بْنِ أَبِی ثَابِتٍ ، عَنْ طَاوُوسٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِمِثْلِہِ ، وَلَمْ یَذْکُرِ ابْنَ عَبَّاسٍ۔",,,8387,,
8388,"حَدَّثَنَا عَبْدَۃُ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، قَالَتْ : خُسِفَت الشَّمْسُ عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَصَلَّی فَفَرَغَ مِنْ صَلاَتِہِ حِینَ تَجَلَّی عَنِ الشَّمْسِ فَحَمِدَ اللَّہَ وَأَثْنَی عَلَیْہِ ، ثُمَّ قَالَ : إنَّ الشَّمْسَ وَالْقَمَرَ آیَتَانِ مِنْ آیَاتِ اللہِ لاَ یَخْسِفَان لِمَوْتِ أَحَدٍ وَلاَ لِحَیَاتِہِ وَلَکِنَّہُمَا آیَتَانِ مِنْ آیَاتِ اللہِ فَإِذَا رَأَیْتُمُوہُمَا فَصَلُّوا وَتَصَدَّقُوا۔ (بخاری 1044۔ مسلم 618)",,,8388,,
8389,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِثْلَہُ ، إِلاَّ أَنَّ ابْنَ نُمَیْرٍ قَالَ : فَکَبِّرُوا وَادْعُوا۔ (مسلم 618)",,,8389,,
8390,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، قَالَ : أَخْبَرَنَا عَبْدُ الْمَلِکِ ، عَنْ عَطَائٍ ، عَنْ جَابِرٍ ، قَالَ : انْکَسَفَتِ الشَّمْسُ عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَوْمَ مَاتَ إبْرَاہِیمُ بْنُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ النَّاسُ : إنَّمَا انْکَسَفَتِ الشَّمْسُ لِمَوْتِ إبْرَاہِیمَ ، فَقَامَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَصَلَّی بِالنَّاسِ سِتَّ رَکَعَاتٍ وَأَرْبَعَ سَجَدَاتٍ ، بَدَأَ فَکَبَّرَ ، ثُمَّ قَرَأَ فَأَطَالَ الْقِرَائَۃَ ، ثُمَّ رَکَعَ نَحْوًا مِمَّا قَامَ ، ثُمَّ رَفَعَ رَأْسَہُ مِنَ الرُّکُوعِ فَقَرَأَ قِرَائَۃً دُونَ القِرَائَۃ الأُولی ، ثُمَّ رَکَعَ نَحْوًا مِمَّا قَامَ ، ثُمَّ رَفَعَ رَأْسَہُ مِنَ الرُّکُوعِ ، فَقَرَأَ قِرَائَۃً دُونَ الثَانِیۃ ثُمَّ رَکَعَ نَحْوًا مِمَّا قَامَ ، ثُمَّ رَفَعَ رَأْسَہُ مِنَ الرُّکُوعِ ثُمَّ انْحَدَرَ بِالسُّجُودِ فَسَجَدَ سَجْدَتَیْنِ ، ثُمَّ قَامَ فَرَکَعَ أَیْضًا ثَلاَثَ رَکَعَاتٍ لَیْسَ مِنْہَا رَکْعَۃٌ إِلاَّ الَّتِی قَبْلَہَا أَطْوَلُ مِنَ الَّتِی بَعْدَہَا وَرُکُوعُہُ نَحْوًا مِنْ سُجُودِہِ ، ثُمَّ تَأَخَّرَ وَتَأَخَّرَتِ الصُّفُوفُ خَلْفَہُ حَتَّی انْتَہَی إلَی النِّسَائِ ، ثُمَّ تَقَدَّمَ وَتَقَدَّمَ النَّاسُ مَعَہُ حَتَّی قَامَ فِی مَقَامِہِ فَانْصَرَفَ حِینَ انْصَرَفَ وَقَدْ أَضَائَتِ الشَّمْسُ ، فَقَالَ : یَا أَیُّہَا النَّاسُ إنَّ الشَّمْسَ وَالْقَمَرَ آیَتَانِ مِنْ آیَاتِ اللہِ لاَ یَنْکَسِفَانِ لِمَوْتِ بَشَرٍ فَإِذَا رَأَیْتُمْ شَیْئًا مِنْ ذَلِکَ فَصَلُّوا حَتَّی تَنْجَلِیَ۔ (مسلم 9۔ ابوداؤد 1172)",,,8390,,
8391,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ السَّائِبِ بْنِ مَالِکٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أَنَّہُ صَلَّی فِی کُسُوفِ الشَّمْسِ رَکْعَتَیْنِ۔,,,8391,,
8392,"حَدَّثَنَا ہُشَیْمٌ قَالَ: أَخْبَرَنَا یُونُسُ، عَنِ الْحَسَنِ: أَنَّ عَلِیًّا صَلَّی فِی الْکُسُوفِ عَشْرَ رَکَعَاتٍ بِأَرْبَعِ سَجَدَاتٍ۔",,,8392,,
8393,"حَدَّثَنَا غُنْدَرٌ ، عَنِ ابْنِ جُرَیْجٍ، عَنْ سُلَیْمَانَ الأَحْوَلِ، عَنْ طَاوُوس: أَنَّ الشَّمْسَ انْکَسَفَتْ عَلَی عَہْدِ ابْنِ عَبَّاسٍ فَصَلَّی عَلَی صُفَّۃِ زَمْزَمَ رَکْعَتَیْنِ فِی کُلِّ رَکْعَۃٍ أَرْبَعُ سَجَدَاتٍ۔",,,8393,,
8394,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یُونُسُ ، عَنِ الْحَسَنِ ، عَنْ أَبِی بَکْرَۃَ ، قَالَ : انْکَسَفَتِ الشَّمْسُ أَوِ الْقَمَرُ عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : إنَّ الشَّمْسَ وَالْقَمَرَ آیَتَانِ مِنْ آیَاتِ اللہِ لاَ یَنْکَسِفَانِ لِمَوْتِ أَحَدٍ مِنَ النَّاسِ ، فَإِذَا کَانَ ذَلِکَ فَصَلُّوا حَتَّی تَنْجَلِیَ۔ (بخاری 1040۔ نسائی 1847)",,,8394,,
8395,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یَقُولُونَ : إذَا کَانَ ذَلِکَ فَصَلُّوا کَصَلاَتِکُمْ حَتَّی تَنْجَلِیَ۔",,,8395,,
8396,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ ہِشَامٍ ، عَنْ فَاطِمَۃَ ، عَنْ أَسْمَائَ ، قَالَتْ : خَسَفَتِ الشَّمْسُ عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَأَطَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَتَّی تَجَلاَّنِی الْغَشْیُ ، قَالَ : قَالَتْ : فَانْصَرَفَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَقَدْ تَجَلَّتْ۔ (بخاری 86۔ مسلم 624)",,,8396,,
8397,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، قَالَ : حدَّثَنِی فُلاَنٌ وَفُلاَنٌ ، أَنَّ رَسُولَ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : إنَّ کُسُوفَ الشَّمْسِ وَالْقَمَرِ آیَتَانِ مِنْ آیَاتِ اللہِ فَإِذَا رَأَیْتُمْ ذَلِکَ فَافْزَعُوا إلَی الصَّلاَۃ۔ (بزار 1371۔ طبرانی 1094)",,,8397,,
8398,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنِ الْجُرَیرِیِّ ، عَنْ حَیَّانَ بْنِ عُمَیْرٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ سَمُرَۃَ ، وَکَانَ مِنْ أَصْحَابِ النَبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : کُنْتُُ أَرْتَمِی بِأَسْہُمٍ بِالْمَدِینَۃِ فِی حَیَاۃِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، إذِ انْکَسَفَتِ الشَّمْسُ فَنَبَذْتُہَا ، فَقُلْتُ : وَاللَّہِ لأَنْظُرَنَّ إلَی مَا حَدَثَ لِرَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی کُسُوفِ الشَّمْسِ ، قَالَ : فَأَتَیْتُہُ وَہُوَ قَائِمٌ فِی الصَّلاَۃ رَافِعًا یَدَیْہِ ، قَالَ : فَجَعَلَ یُسَبِّحُ وَیَحْمَدُ وَیُکَبِّرُ وَیُہَلِّلُ وَیَدْعُو حَتَّی حُسِرَ عَنْہَا ، قَالَ : فَلَمَّا حُسِرَ عَنْہَا قَالَ قَرَأَ سُورَتَیْنِ وَصَلَّی رَکْعَتَیْنِ۔ (مسلم 27۔ ابوداؤد 1188)",,,8398,,
8399,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، قَالَ : حدَّثَنَا زُہَیْرٌ ، عَنِ الأَسْوَدِ بْنِ قَیْسٍ ، قَالَ : حَدَّثَنِی ثَعْلَبَۃُ بْنُ عِبَادٍ الْعَبْدِیُّ : أَنَّہُ شَہِدَ یَوْمًا خُطْبَۃً لِسَمُرَۃَ بْنِ جُنْدُبٍ فَذَکَرَ فِی خُطْبَتِہِ حَدِیثًا عَنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : قَالَ سَمُرَۃُ : بَیْنَا أَنَا یَوْمًا وَغُلاَمٌ مِنَ الأَنْصَارِ نَرْمِی غَرَضًا لَنَا عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَتَّی إذَا کَانَتِ الشَّمْسُ قِیدَ رُمْحَیْنِ أَوْ ثَلاَثَۃٍ فِی عَیْنِ النَّاظِرِ مِنَ الأُفُقِ اسْوَدَّتْ حَتَّی آضَتْ کأَنَّہَا تَنُّومَۃٌ ، فَقَالَ أَحَدُنَا لصاحبِہِ : انْطَلِقْ بِنَا إلَی الْمَسْجِدِ فَوَاللَّہِ لَتُحْدِثَنَّ ہَذِہِ الشَّمْسُ لِرَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی أُمَّتِہِ حَدَثًا ، فَقَالَ : فَدَفَعْنَا إلَی الْمَسْجِدِ فَإِذَا ہُوَ بَارِزٌ مُحْتَفِلٌ ، قَالَ : وَوَافَقْنَا رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حِینَ خَرَجَ إلَی النَّاسِ فَاسْتَقْدَمَ فَصَلَّی بِنَا کَأَطْوَلِ مَا قَامَ بِنَا فِی صَلاَۃٍ قَطُّ لاَ نَسْمَعُ لَہُ صَوْتًا ، ثُمَّ سَجَدَ بِنَا کَأَطْوَلِ مَا سَجَدَ بِنَا فِی صَلاَۃٍ قَطُّ لاَ نَسْمَعُ لَہُ صَوْتًا ، قَالَ : ثُمَّ فَعَلَ فِی الرَّکْعَۃِ الثَّانِیَۃِ مِثْلَ ذَلِکَ ، قَالَ : فَوَافَقَ تَجَلِّی الشَّمْسِ جُلُوسَہُ فِی الرَّکْعَۃِ الثَّانِیَۃِ فَسَلَّمَ۔ (ابوداؤد 1177۔ نسائی 1869)",,,8399,,
8400,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ہِشَامٌ الدَّسْتَوَائِیُّ ، عَنْ قَتَادَۃَ ، عَنْ عَطَائٍ ، عَنْ عُبَیْدِ بْنِ عُمَیْرٍ ، عَنْ عَائِشَۃَ ، قَالَتْ : صَلاَۃُ الأَیَاتِ سِتُّ رَکَعَاتٍ فِی أَرْبَعِ سَجَدَاتٍ۔",,,8400,,
8401,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَاصِمِ بْنِ عُبَیْدِ اللہِ ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ یُہَرْوِلُ إلَی الْمَسْجِدِ فِی کُسُوفٍ وَمَعَہُ نَعْلاَہُ۔",,,8401,,
8402,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا رَبِیعٌ ، عَنِ الْحَسَنِ ، قَالَ : یُصَلِّی رَکْعَتَیْنِ رَکْعَتَیْنِ فِی الْکُسُوفِ۔",,,8402,,
8403,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ أَبِی الْخَیْرِ بْنِ تَمِیمِ بْنِ حَذْلَمٍ ، قَالَ : کَانَتْ بِالْکُوفَۃِ ظُلْمَۃٌ فَجَائَ ہُنَیُّ بْنُ نُوَیْرَۃَ مَعَہُ صَاحِبٌ لَہُ حَتَّی دَخَلاَ عَلَی تَمِیمِ بْنِ حَذْلَمٍ ، وَکَانَ مِنْ أَصْحَابِ عَبْدِاللہِ، فَوَجَدَاہُ یُصَلِّی ، قَالَ : فَقَالَ لَہُمَا : ارْجِعَا إلَی بُیُوتِکُمَا وَصَلِّیَا حَتَّی یَنْجَلِیَ مَا تَرَوْنَ ، فَإِنَّہُ کَانَ یُؤْمَرُ بِذَلِکَ۔",,,8403,,
8404,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، قَالَ : إذَا فَزِعْتُمْ مِنْ أُفُقٍ مِنْ آفَاقِ السَّمَائِ فَافْزَعُوا إلَی الصَّلاَۃ۔",,,8404,,
8405,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنٍ ، عَنْ عِیسَی بْنِ أَبِی عَزَّۃَ ، قَالَ : فَزِعَ النَّاسُ فِی انْکِسَافِ شَمْسٍ ، أَوْ قَمَرٍ ، أَوْ شَیْئٍ ، فَقَالَ الشَّعْبِیُّ : عَلَیْکُمْ بِالْمَسْجِدِ ، فَإِنَّہُ مِنَ السُّنَّۃِ۔",,,8405,,
8406,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : یُصَلِّی رَکْعَتَیْنِ فِی الْکُسُوفِ۔",,,8406,,
8407,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ إِسْحَاقَ بْنِ سُوَیْد ، عَنِ الْعَلاَئِ بْنِ زِیَادٍ : فِی صَلاَۃِ الْکُسُوف ، قَالَ : یَقُومُ فَیَقْرَأُ وَیَرْکَعُ ، فَإذَا قَالَ : سَمِعَ اللَّہُ لِمَنْ حَمِدَہُ نَظَرَ إلَی الْقَمَرِ ، فَإِنْ کَانَ لَمْ یَنجَلِ قَرَأَ ثُمَّ رَکَعَ ، ثُمَّ رَفَعَ رَأْسَہُ ، فَإذَا قَالَ : سَمِعَ اللَّہُ لِمَنْ حَمِدَہُ نَظَرَ إلَی الْقَمَرِ ، فَإِنْ کَانَ لَمْ یَنجَلِ قَرَأَ ثُمَّ رَکَعَ ، ثُمَّ رَفَعَ رَأْسَہُ ، فَإذَا قَالَ : سَمِعَ اللَّہُ لِمَنْ حَمِدَہُ نَظَرَ إلَی الْقَمَرِ ، فَإِنْ کَانَ انْجَلَی سَجَدَ ، ثُمَّ قَامَ فَشَفعََہَا بِرَکْعَۃٍ ، وَإِنْ لَمْ یَنْجَلِ لَمْ یَسْجُدْ أَبَدًا حَتَّی تَنْجَلِی مَتَی مَا تجَلَّی ، ثُمَّ إِنْ کَانَ کُسُوفٌ بَعْدُ لَمْ یُصَلِّ ہَذِہِ الصَّلاَۃ۔",,,8407,,
8408,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا إِسْحَاقُ بْنُ عُثْمَانَ الْکِلاَبِیُّ ، عَنْ أَبِی أَیُّوبَ الْہَجَرِیُّ قَالَ : انْکَسَفَتِ الشَّمْسُ بِالْبَصْرَۃِ ، وَابْنُ عَبَّاسٍ أَمِیرٌ عَلَیْہَا فَقَامَ یُصَلِّی بِالنَّاسِ ، فَقَرَأَ فَأَطَالَ الْقِرَائَۃَ ، ثُمَّ رَکَعَ فَأَطَالَ الرُّکُوعَ ، ثُمَّ رَفَعَ رَأْسَہُ ، ثُمَّ سَجَدَ ثُمَّ فَعَلَ مِثْلَ ذَلِکَ فِی الثَّانِیَۃِ ، فَلَمَّا فَرَغَ قَالَ : ہَکَذَا صَلاَۃُ الأَیَاتِ ، قَالَ : فَقُلْتُ : بِأَیِّ شَیْئٍ قَرَأَ فِیہِمَا ؟ قَالَ : بِالْبَقَرَۃِ وَآلِ عِمْرَانَ۔",,,8408,,
8409,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، قَالَ : أَخْبَرَنَا شَیْبَانُ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ أَبِی سَلَمَۃَ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرِو بْنِ الْعَاصِ : أَنَّہُ لَمَّا انْکَسَفَتِ الشَّمْسُ عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نُودِیَ بِالصَّلاَۃ جَامِعَۃً، فَرَکَعَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَکْعَتَیْنِ فِی سَجْدَۃٍ، ثُمَّ قَامَ فَرَکَعَ رَکْعَتَیْنِ فِی سَجْدَۃٍ، ثُمَّ جُلِّیَ عَنِ الشَّمْسِ ، قَالَ : قالَتْ عَائِشَۃُ : مَا سَجَدْتُ سُجُودًا قَطُّ وَلاَ رَکَعْتُ رُکُوعًا قَطُّ کَانَ أَطْوَلَ مِنْہُ۔ (بخاری 1045۔ مسلم 20)",,,8409,,
8410,"حَدَّثَنَا مُصْعَبُ بْنُ الْمِقْدَامِ ، قَالَ : أَخْبَرَنَا زَائِدَۃُ ، قَالَ : قَالَ زِیَادُ بْنُ عِلاَقَۃَ : سَمِعْتُ الْمُغِیرَۃَ بْنَ شُعْبَۃَ یَقُولُ : انْکَسَفَتِ الشَّمْسُ فِی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَوْمَ مَاتَ إبْرَاہِیمُ ، فَقَالَ النَّاسُ : انْکَسَفَتْ لِمَوْتِ إبْرَاہِیمَ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ الشَّمْسَ وَالْقَمَرَ آیَتَانِ مِنْ آیَاتِ اللہِ ، لاَ یَنْکَسِفَانِ لِمَوْتِ أَحَدٍ وَلاَ لِحَیَاتِہِ ، فَإِذَا رَأَیْتُمُوہُمَا فَادْعُوا اللَّہَ وَصَلُّوا حَتَّی تَنْکَشِفَ۔ (بخاری 6199۔ احمد 4/249)",,,8410,,
8411,"حَدَّثَنَا وَکِیعٌ قَالَ : حَدَّثَنَا یَزِیدُ بْنُ إبْرَاہِیمَ ، عَنِ الْحَسَنِ ، أنَّ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی فِی کُسُوفٍ رَکْعَتَیْنِ فَقَرَأَ فِی إحْدَاہُمَا بِالنَّجْمِ۔",,,8411,,
8412,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إبْرَاہِیمُ بْنُ إسْمَاعِیلَ بْنِ مُجَمِّعٍ ، عَنِ الْمَاجِشُونِ ، قَالَ : سَمِعْتُ أَبَانَ بْنَ عُثْمَانَ قَرَأَ فِی کُسُوفٍ : {سَأَلَ سَائِلٌ}۔",,,8412,,
8413,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنٍ ، عَنْ عَبْدِ اللہِ بْنِ عِیسَی ، قَالَ : صَلَّی بِنَا عَبْدُ الرَّحْمَنِ بْنُ أَبِی لَیْلَی حِینَ انْکَسَفَ الْقَمَرُ مِثْلَ صَلاَتِنَا ہَذِہِ فِی رَمَضَانَ ، قَالَ وَقَرَأَ أَوَّلَ شَیْئٍ قَرَأَ {یس وَالْقُرْآنِ الْحَکِیمِ} ۔",,,8413,,
8414,"حَدَّثَنَا وَکِیعٌ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، قَالَ : کَتَبَ إلَیْنَا عُمَرُ بْنُ عَبْدِ الْعَزِیزِ فِی زَلْزَلَۃٍ کَانَتْ بِالشَّامِ ، أَنِ اخْرُجُوا یَوْمَ الإِثْنَیْنِ مِنْ شَہْرِ کَذَا وَکَذَا وَمَنِ اسْتَطَاعَ مِنْکُمْ أَنْ یُخْرِجَ صَدَقَۃً فَلْیَفْعَلْ فَإِنَّ اللَّہَ تَعَالَی قَالَ : {قَدْ أَفْلَحَ مَنْ تَزَکَّی وَذَکَرَ اسْمَ رَبِّہِ فَصَلَّی}۔",,,8414,,
8415,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا سُفْیَانُ ، عَنِ الأَسْوَدِ بْنِ قَیْسٍ الْعَبْدِیِّ ، عَنْ ثَعْلَبَۃَ بْنِ عِبَادٍ ، عَنْ سَمُرَۃََ بْنِ جُنْدُبٍ ، قَالَ : صَلَّی بِنَا النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی کُسُوفٍ ، وَلاَ نَسْمَعُ لَہُ صَوْتًا۔ (ترمذی 562۔ نسائی 1882)",,,8415,,
8416,"حَدَّثَنَا سُفْیَانُ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الْحَکَمِ ، عَنْ حَنَشٍ الْکِنَانِیِّ : أَنَّ عَلِیًّا جَہَرَ بِالْقِرَائَۃِ فِی الْکُسُوفِ۔",,,8416,,
8417,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا سَعِیدٌ ، عَنْ قَتَادَۃَ ، عَنْ عَطَائٍ ، قَالَ : إذَا کَانَ الْکُسُوفُ بَعْدَ الْعَصْرِ وَبَعْدَ الصُّبْحِ قَامُوا فَذَکَرُوا رَبَّہُمْ ، وَلاَ یُصَلُّونَ۔",,,8417,,
8418,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : إذَا انْکَسَفَتِ الشَّمْسُ فِی وَقْتٍ لاَ تَحِلُّ فِیہِ الصَّلاَۃ ، قَالَ : یَدْعُونَ۔",,,8418,,
8419,حَدَّثَنَا الثَّقَفِیُّ ، عَنْ خَالِدٍ ، عَنْ عَبْدِ اللہِ بْنِ الْحَارِثِ ، أَنَّ ابْنَ عَبَّاسٍ صَلَّی بِہِمْ فِی زَلْزَلَۃٍ کَانَتْ أَرْبَعَ سَجَدَاتٍ رَکَعَ فِیہَا سِتًّا۔,,,8419,,
8420,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ شَہْرٍ ، قَالَ : زُلْزِلَتِ الْمَدِینَۃُ فِی عَہْدِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ: إنَّ رَبَّکُمْ یَسْتَعْتِبُکُمْ فَأَعْتِبُوہُ۔",,,8420,,
8421,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ اللہِ ، عَنْ نَافِعٍ ، عَنْ صَفِیَّۃَ ابْنَۃِ أَبِی عُبَیْدٍ ، قَالَت : زُلْزِلَتِ الأَرْضُ عَلَی عَہْدِ عُمَرَ حَتَّی اصْطَفَقَتِ السُّرُرُ فَوَافَقَ ذَلِکَ عَبْدَ اللہِ بْنَ عُمَرَ وَہُوَ یُصَلِّی فَلَمْ یَدْرِ ، قَالَت : فَخَطَبَ عُمَرُ لِلنَّاسِ فَقَالَ : أَحدَثْتُم لَقَدْ عَجِلْتُمْ ، قَالَت : وَلاَ أَعْلَمُہُ إِلاَّ قَالَ : لَئِنْ عَادَتْ لأَخْرُجَنَّ مِنْ بَیْنِ ظَہْرَانِیکُمْ۔",,,8421,,
8422,"وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ ہِشَامِ بْنِ إِسْحَاقَ بْنِ عَبْدِ اللہِ بْنِ کِنَانَۃَ ، عَنْ أَبِیہِ قَالَ : أَرْسَلَنِی أَمِیرٌ مِنَ الأُمَرَائِ إلَی ابْنِ عَبَّاسٍ أَسْأَلُہُ عَنِ الاِسْتِسْقَائِ ؟ فَقَالَ ابْنُ عَبَّاسٍ : مَا مَنَعَہُ أَنْ یَسْأَلَنِی؟ ثُمَّ قَالَ ابْنُ عَبَّاسٍ : خَرَجَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مُتَوَاضِعًا مُتَبذِلاً مُتَخَشِّعًا مُتَضَرِّعًا مُتَرَسِّلاً ، فَصَلَّی رَکْعَتَیْنِ کَمَا یُصَلِّی فِی الْعِیدِ ، وَلَمْ یَخْطُبْ خُطْبَتَکُمْ ہَذِہِ۔ (ترمذی 558۔ ابوداؤد 1160)",,,8422,,
8423,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا یُونُسُ بْنُ أَبِی إِسْحَاقَ ، عَنْ أَبِیہِ ، عَنْ حَارِثَۃَ بْنِ مُضَرِّبٍ الْعَبْدِیِّ ، قَالَ : خَرَجْنَا مَعَ أَبِی مُوسَی نَسْتَسْقِی فَصَلَّی بِنَا رَکْعَتَیْنِ بغَیْرِ أَذَانٍ وَلاَ إقَامَۃٍ۔",,,8423,,
8424,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : خَرَجْنَا مَعَ عَبْدِ اللہِ بْنِ یَزِیدَ الأَنْصَارِیِّ نَسْتَسْقِی ، فَصَلَّی رَکْعَتَیْنِ وَخَلْفَہُ زَیْدُ بْنُ أَرْقَمَ۔",,,8424,,
8425,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ مُحَمَّدِ بْنِ ہِلاَلٍ : أَنَّہُ شَہِدَ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ فِی الاِسْتِسْقَائِ بَدَأَ بِالصَّلاَۃ قَبْلَ الْخُطْبَۃِ ، قَالَ : وَرَأَیْتُہُ اسْتَسْقَی فَحَوَّلَ رِدَائَہُ۔",,,8425,,
8426,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، عَنْ عَبَّادِ بْنِ تَمِیمٍ ، عَنْ عَمِّہِ ، قَالَ : شَہِدْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ خَرَجَ یَسْتَسْقِی ، فَاسْتَقْبَلَ الْقِبْلَۃَ ، وَوَلَّی ظَہْرَہُ الناس ، وَحَوَّلَ رِدَائَہُ ، وَصَلَّی رَکْعَتَیْنِ ، وَجَہَرَ بِالْقِرَائَۃِ۔ (بخاری 1025۔ ابوداؤد 1155)",,,8426,,
8427,"حَدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ أَبِی بَکْرِ بْنِ مُحَمَّدِ بْنِ عَمْرِو بْنِ حَزْمٍ ، عَنْ عَبَّادِ بْنِ تَمِیمٍ ، عَنْ عَبْدِ اللہِ بْنِ زَیْدٍ قَالَ : خَرَجَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إلَی الْمُصَلَّی یَسْتَسْقِی ، فَلَمَّا دَعَا اسْتَقْبَلَ الْقِبْلَۃَ وَحَوَّلَ رِدَائَہُ۔ (بخاری 1028۔ مسلم 611)",,,8427,,
8428,"حَدَّثَنَا وَکِیعٌ ، عَنْ عِیسَی بْنِ حَفْصِ بْنِ عَاصِمٍ ، عَنْ عَطَائِ بْنِ أَبِی مَرْوَانَ الأَسْلَمِیِّ ، عَنْ أَبِیہِ ، قَالَ : خَرَجْنَا مَعَ عُمَرَ بْنِ الْخَطَّابِ نَسْتَسْقِی فَمَا زَادَ عَلَی الاِسْتِغْفار۔",,,8428,,
8429,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مُطَرِّفٍ ، عَنِ الشَّعْبِیِّ : أَنَّ عُمَرَ بْنَ الْخَطَّابِ خَرَجَ یَسْتَسْقِی فَصَعِدَ الْمِنْبَرَ فَقَالَ : {اسْتَغْفِرُوا رَبَّکُمْ إِنَّہُ کَانَ غَفَّارًا یُرْسِلِ السَّمَائَ عَلَیْکُمْ مِّدْرَارًا وَیُمْدِدْکُمْ بِأَمْوَالٍ وَبَنِینَ وَیَجْعَلْ لَکُمْ جَنَّاتٍ وَیَجْعَلْ لَکُمْ أَنَّہَارًا} ، {اسْتَغْفِرُوا رَبَّکُمْ أَنَّہُ کَانَ غَفَّارًا} ، ثُمَّ نَزَلَ فَقَالُوا : یَا أَمِیرَ الْمُؤْمِنِینَ لَوِ اسْتَسْقَیْتَ ، فَقَالَ : لَقَدْ طَلَبْتُہُ بِمَجَادِیحِ السَّمَائِ الَّتِی یُسْتَنْزَلُ بِہَا الْقَطَرُ۔",,,8429,,
8430,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ أَسْلَمَ الْعِجْلِیّ ، قَالَ : خَرَجَ أناسُ مَرَّۃً یَسْتَسْقُونَ وَخَرَجَ إبْرَاہِیمُ مَعَہُمْ، فَلَمَّا فَرَغُوا قَامُوا یُصَلُّونَ فَرَجَعَ إبْرَاہِیمُ ، وَلَمْ یُصَلِّ مَعَہُمْ۔",,,8430,,
8431,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ : أَنَّہُ خَرَجَ مَعَ الْمُغِیرَۃِ بْنِ عَبْدِ اللہِ الثَّقَفِیِّ یَسْتَسْقِی ، قَالَ : فَصَلَّی الْمُغِیرَۃُ فَرَجَعَ إبْرَاہِیمُ حَیْثُ رَآہُ صَلَّی۔",,,8431,,
8432,"حَدَّثَنَا أَبُو مُحَمَّدٍ عَبْدُ اللہِ بْنُ یُونُسَ ، قَالَ : حدَّثَنَا بَقِیُّ بْنُ مَخْلَدٍ رَحِمَہُ اللَّہُ ، قَالَ : حَدَّثَنَا أَبُو بَکْرٍ قَالَ :\n\n حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی سُفْیَانَ ، عَنْ جَابِرٍ قَالَ : سُئِلَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَیُّ الصَّلاَۃ أَفْضَلُ ؟ قَالَ : طُولُ الْقُنُوتِ۔ (مسلم 520۔ ابن ماجہ 1421)",,,8432,,
8433,"حَدَّثَنَا وَکِیعٌ، عَنِ الأَعْمَشِ، عَنْ أَبِی صَالِحٍ، عَنْ رَجُلٍ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: أنَّ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَقُومُ فِی الصَّلاَۃ حَتَّی تَرِمَ قَدَمَاہُ فَقِیلَ لَہُ ، فَقَالَ : أَلاَ أَکُونُ عَبْدًا شَکُورًا۔",,,8433,,
8434,حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، وَسُفْیَانَ ، عَنْ زِیَادِ بْنِ عِلاَقَۃَ ، عَنِ الْمُغِیرَۃِ بْنِ شُعْبَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِثْلَہُ۔ (بخاری 4836۔ مسلم 79),,,8434,,
8435,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : طُولُ الْقِیَامِ أَحَبُّ إلَیَّ مِنْ کَثْرَۃِ الرُّکُوعِ وَالسُّج",,,8435,,
8436,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا حَجَّاجُ بْنُ حَسَّانَ ، قَالَ : سَمِعت أَبَا مِجْلَزٍ ، أَو سَأَلْتُ أَبَا مِجْلَزٍ عَنْ صَلاَۃِ اللَّیْلِ أَطُولُ الْقِرَائَۃِ أَحَبُّ إلَیْک ، أَوْ کَثْرَۃُ الرُّکُوعِ وَالسُّجُودِ ؟ فَقَالَ : لاَ بَلْ طُولُ الْقِرَائَۃِ۔",,,8436,,
8437,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنْ یَحْیَی بْنِ رَافِعٍ ، قَالَ : کَانَ یُقَالُ : لاَ تُطِیلُ الْقِرَائَۃَ فِی الصَّلاَۃ فَیَعْرِضُ لَکَ الشَّیْطَانُ فَیَفْتِنُکَ۔",,,8437,,
8438,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مَنْصُورٍ ، عَنْ سَالِمِ بْنِ أَبِی الْجَعْدِ ، قَالَ : حدَّثَنی أنَّ رَجُلاً أَتَی إلَی أَبِی ذَرٍّ بِالرَّبَذَۃِ فَقَالَ : أَیْنَ أَبُو ذَرٍّ ؟ فَقَالُوا : ہُوَ فِی سَفْحِ ذَلِکَ الْجَبَلِ فِی غُنَیمَۃ لَہُ ، قَالَ : فَأَتَیْتُہُ فَإِذَا ہُوَ یُصَلِّی وَإِذَا ہُوَ یُقِلُّ الْقِیَامَ وَیُکْثِرُ الرُّکُوعَ وَالسُّجُودَ ، قَالَ : فَلَمَّا صَلَّی قُلْتُ : یَا أَبَا ذَرٍّ رَأَیْتُک تُصَلِّی تُقِلُّ الْقِیَامَ وَتُکْثِرُ الرُّکُوعَ وَالسُّجُودَ ، فَقَالَ : إنِّی حُدِّثْتُ أَنَّہُ مَا مِنْ مُسْلِمٍ یَسْجُدُ لِلَّہِ سَجْدَۃً إِلاَّ رَفَعَہُ اللَّہُ بِہَا دَرَجَۃً وَکَفَّرَ عَنْہُ بِہَا خَطِیئَۃً۔",,,8438,,
8439,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ أَبِی مُصْعَبٍ الأَسْلَمِیِّ ؛ أَنَّ غُلاَمًا مِنْ أَسْلَمَ کَانَ یَخْدُمُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَخَفَّ لَہُ فَقَالَ : یَا رَسُولَ اللہِ اُدْعُ اللَّہَ لِی أَنْ یُدْخِلَنِی الْجَنَّۃَ ، أَوْ یَجْعَلَنِی فِی شَفَاعَتِکَ ، قَالَ: نَعَمْ، وَأَعِنِّی بِکَثْرَۃِ السُّجُودِ۔ (مسلم 226۔ ابوداؤد 1314)",,,8439,,
8440,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ زَیْدٍ ، عَنْ أَنَسِ بْنِ سِیرِینَ ، عَنْ مَسْرُوقٍ : أَنَّہُ کَانَ یُصَلِّی حَتَّی تَجْلِسَ امْرَأَتُہُ تَبْکِی خَلْفَہُ۔",,,8440,,
8441,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، وَسُفْیَانَ ، عَنْ زُبَیْدٍ ، عَنْ مُرَّۃَ ، قَالَ : قَالَ عَبْدُ اللہِ : إنَّک مَا دُمْت فِی صَلاَۃٍ تَقْرَعُ بَابَ الْمَلِکِ وَمَنْ یُکْثِرُ قَرْعَ بَابِ الْمَلِکِ یُوشِکُ أَنْ یُفْتَحَ لَہُ۔",,,8441,,
8442,"حَدَّثَنَا وَکِیعٌ ، عَنْ رَبِیعٍ ، عَنِ الْحَسَنِ ، قَالَ : طُولُ الْقِیَامِ فِی الصَّلاَۃ أَفْضَلُ مِنَ الرُّکُوعِ وَالسُّجُودِ۔",,,8442,,
8443,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ خَیْثَمَۃَ ، عَنِ الْحَارِثِ بْنِ قَیْسٍ ، قَالَ : إذَا ہَمَمْتَ بِخَیْرٍ فَعَجِّلْہُ ، وَإِذَا أَتَاکَ الشَّیْطَانُ فَقَالَ : إنَّکَ تُرَائِی فَزِدْہَا طُولاً۔",,,8443,,
8444,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ رَجُلٍ، عَنْ إبْرَاہِیمَ، قَالَ: إذَا أَکَلَ أَوْ شَرِبَ فِی الصَّلاَۃ اسْتَقْبَلَ الصَّلاَۃ۔",,,8444,,
8445,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ أَبَانَ الْعَطَّارِ ، عَنِ الصَّلْتِ بْنِ رَاشِدٍ ، قَالَ : سُئِلَ طَاوُوس عَنِ الشُّرْبِ فِی الصَّلاَۃ ؟ قَالَ : لاَ۔",,,8445,,
8446,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عَطَائٍ ، عَنْ حَجَّاجٍ ، وَإِبْرَاہِیمَ : أَنَّہُمَا کَرِہَا الشُّرْبَ فِی الصَّلاَۃ۔",,,8446,,
8447,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : لاَ یَحِلُّ الأَکْلُ فِی الصَّلاَۃ۔",,,8447,,
8448,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ لَیْثٍ، عَنْ طَاوُوسٍ، قَالَ: لاَ بَأْسَ بِالشُّرْبِ وَالإِمَام یَخْطُبُ یَوْمَ الْجُمُعَۃِ۔",,,8448,,
8449,"حَدَّثَنَا عَبْدُاللہِ بْنُ إدْرِیسَ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ، عَنْ مُحَمَّدِ بْنِ جَعْفَرِ بْنِ الزُّبَیْرِ: أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَعَثَ عَبْدَ اللہِ بْنَ أُنَیْسٍ إلَی خَالِدِ بْنِ سُفْیَانَ ، قَالَ : فَلَمَّا دَنَوْتُ مِنْہُ وَذَلِکَ فِی وَقْتِ الْعَصْرِ خِفْتُ أَنْ یَکُونَ دُونَہُ مُحَاوَلَۃٌ أَوْ مُزَاوَلَۃٌ ، فَصَلَّیْتُ وَأَنَا أَمْشِی۔ (ابوداؤد 1243۔ احمد 3/496)",,,8449,,
8450,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنِ الْحَسَنِ بْنِ أَبِی جَعْفَرٍ ، عَنْ أَبِی الصَّہْبَائِ ، قَالَ : رَأَیْتُُ مُجَاہِدًا أَقْبَلَ مِنَ الْبَطْحَائِ ، فَلَمَّا انْتَہَی إلَی الْمَسْجِدِ الْحَرَامِ قَرَأَ سَجْدَۃً فَسَجَدَ فَذَکَرْتُ ذَلِکَ لِعَطَائٍ ، قَالَ : وَمَا تَعْجَبُ مِنْ ذَا ؟ کَانَ أَصْحَابُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلُّونَ وَہُمْ یَمْشُونَ۔",,,8450,,
8451,"حَدَّثَنَا مَخْلَدُ بْنُ یَزِیدَ ، عَنْ سَعِیدِ بْنِ عَبْدِ الْعَزِیزِ ، عَنْ مَکْحُولٍ ، قَالَ : سَأَلْتُُہُ عَنِ الرَّجُلِ یُصَلِّی وَہُوَ یَمْشِی ؟ قَالَ : لاَ بَأْسَ یُومِیئُ إیمَائً۔",,,8451,,
8452,"حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ یَزِیدَ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : إِنْ کَانَ أَحَدُنَا لیُصَلِّی وَہُوَ یَسْعَی ، یَعْنِی فِی الْحَرْبِ۔",,,8452,,
8453,"حَدَّثَنَا حَفْصٌ ، عَنْ حُمَیْدٍ ، عَنِ الأَزْرَقِ بْنِ قَیْسٍ ، عَنْ أَبِی بَرْزَۃَ : أَنَّہُ صَلَّی وَہُوَ مُمْسِکٌ بِعَنَانِ دَابَّتِہِ وَہُوَ یَمْشِی۔",,,8453,,
8454,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا قُدَامَۃُ الْعَامِرِیُّ ، عَنْ جَسْرَۃَ بِنْتِ دَجَاجَۃَ ، عَنْ أَبِی ذَرٍّ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَدَّدَ ہَذِہِ الآیَۃَ حَتَّی أَصْبَحَ {إنْ تُعَذِّبْہُمْ ، فَإِنَّہُمْ عِبَادُکَ وَإِنْ تَغْفِرْ لَہُمْ فَإِنَّکَ أَنْتَ الْعَزِیزُ الْحَکِیمُ}۔ (نسائی 1083۔ احمد 5/170)",,,8454,,
8455,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سَعِیدُ بْنُ عُبَیْدٍ الطَّائِیُّ ، قَالَ : سَمِعْتُ سَعِیدَ بْنَ جُبَیْرٍ وَہُوَ یُصَلِّی بِہِمْ فِی شَہْرِ رَمَضَانَ یُرَدِّدُ ہَذِہِ الآیَۃَ {فَسَوْفَ یَعْلَمُونَ إذِ الأَغْلاَلُ فِی أَعْنَاقِہِمْ وَالسَّلاَسِلُ یُسْحَبُونَ فِی الْحَمِیمِ ثُمَّ فِی النَّارِ یُسْجَرُونَ}۔",,,8455,,
8456,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حُصَیْنٍ ، عَنْ أَبِی الضُّحَی ، عَنْ مَسْرُوقٍ ، أَنَّ تَمِیمًا الدَّارِیَّ رَدَّدَ ہَذِہِ الآیَۃَ : {أَمْ حَسِبَ الَّذِینَ اجْتَرَحُوا السَّیِّئَاتِ أَنْ نَّجْعَلَہُمْ کَاَلَّذِینَ آمَنُوا وَعَمِلُوا الصَّالِحَاتِ سَوَائً مَّحْیَاہُمْ وَمَمَاتُہُمْ}۔",,,8456,,
8457,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَجْلاَنَ ، عَنْ نُسِیر أَبِی طُعْمَۃَ مَوْلَی الرَّبِیعِ بْنِ خُثَیْمٍ ، قَالَ : کَانَ الرَّبِیعُ بْنُ خُثَیْمٍ یُصَلِّی فَمَرَّ بِہَذِہِ الآیَۃِ : {أَمْ حَسِبَ الَّذِینَ اجْتَرَحُوا السَّیِّئَاتِ} حَتَّی خَتَمَہا یُرَدِّدُہَا حَتَّی أَصْبَحَ۔",,,8457,,
8458,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ مُعَاوِیَۃَ بْنِ قُرَّۃَ ، قَالَ : سَمِعْتُ عَبْدَ اللہِ بْنَ مُغَفَّلٍ یَقُولُ : قَرَأَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی مَسِیرٍ لَہُ فِی عَامِ الْفَتْحِ سُورَۃَ الْفَتْحِ عَلَی رَاحِلَتِہِ فَرَجَّعَ فِی قِرَائَتِہِ ، قَالَ مُعَاوِیَۃُ : وَلَوْلاَ أَنِّی أَخَافُ أَنْ یَجْتَمِعَ عَلَیَّ النَّاسُ لَحَکَیْتُ لَکُمْ قِرَائَتَہُ۔ (بخاری 4281۔ مسلم 239)",,,8458,,
8459,"حَدَّثَنَا عَبْدُاللہِ بْنُ إدْرِیسَ، عَنْ لَیْثٍ، عَنِ الأَسْوَدِ، قَالَ: کَانُوا یُحِبُّونَ أَنْ یُرَجِّعُوا بِالآیَۃِ مِنْ آخِرِ اللَّیْلِ۔",,,8459,,
8460,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، قَالَ : أُرَاہُ عَنْ إبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ أَنْ یَقِفَ الرَّجُلُ عِنْدَ الآیَۃِ فَیُرَدِّدُہَا۔",,,8460,,
8461,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إبْرَاہِیمَ فِی قولہ تعالی : {وَإِذَا قُرِیئَ الْقُرْآنُ فَاسْتَمِعُوا لَہُ وَأَنْصِتُوا} قَالَ : فِی الصَّلاَۃ الْمَکْتُوبَۃِ۔",,,8461,,
8462,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ الْعَوَّامِ ، أُخْبِرنَا عَنْ مُجَاہِدٍ قَالَ : فِی خُطْبَۃِ الإِمَام یَوْمَ الْجُمُعَۃِ۔",,,8462,,
8463,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا جُوَیْبِرٌ ، عَنِ الضَّحَّاکِ ، قَالَ : فِی الصَّلاَۃ الْمَکْتُوبَۃِ ، وَعِنْدَ الذِّکْرِ۔",,,8463,,
8464,"حَدَّثَنَا وَکِیعٌ ، عَنْ حُرَیث ، عَنِ الشَّعْبِیِّ ۔ وَعَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ مُجَاہِدٍ ۔ وَعَنْ أَبِی الْمِقْدَامِ ، عَنْ مُعَاوِیَۃَ بْنِ قُرَّۃَ ، عَنْ عَبْدِ اللہِ بْنِ مُغَفَّلٍ : فِی قولہ تعالی : {وَإِذَا قُرِیئَ الْقُرْآنُ فَاسْتَمِعُوا لَہُ وَأَنْصِتُوا} قَالُوا : فِی الصَّلاَۃ۔",,,8464,,
8465,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مَنْ سَمِعَ الْحَسَنَ یَقُولُ : عِنْدَ الصَّلاَۃ الْمَکْتُوبَۃِ ، وَعِنْدَ الذِّکْرِ۔",,,8465,,
8466,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ الْہَجَرِیِّ ، عَنْ أَبِی عِیَاضٍ ، عَنْ أَبِی ہُرَیْرَۃَ قَالَ : کَانُوا یَتَکَلَّمُونَ فِی الصَّلاَۃ فَنَزَلَتْ : {وَإِذَا قُرِیئَ الْقُرْآنُ فَاسْتَمِعُوا لَہُ وَأَنْصِتُوا} ، قَالُوا : ہَذَا فِی الصَّلاَۃ۔",,,8466,,
8467,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ أَشْعَثَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقْرَأُ وَرَجُلٌ یَقْرَأُ فَنَزَلَ : {وَإِذَا قُرِیئَ الْقُرْآنُ فَاسْتَمِعُوا لَہُ وَأَنْصِتُوا}۔",,,8467,,
8468,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مَنْصُورٍ ، قَالَ : سَمِعْتُ إبْرَاہِیمَ بْنَ أَبِی حُرَّۃَ ، أَنَّہُ سَمِعَ مُجَاہِدًا قَالَ فِی ہَذِہِ الآیَۃِ : {وَإِذَا قُرِیئَ الْقُرْآنُ فَاسْتَمِعُوا لَہُ وَأَنْصِتُوا} قَالَ : فِی الصَّلاَۃ وَالْخُطْبَۃِ یَوْمَ الْجُمُعَۃِ۔",,,8468,,
8469,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ : {وَإِذَا قُرِیئَ الْقُرْآنُ فَاسْتَمِعُوا لَہُ وَأَنْصِتُوا} قَالَ: فِی الصَّلاَۃ الْمَکْتُوبَۃِ۔",,,8469,,
8470,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا لَمْ یَسْکُنِ الرُّعَافُ شَدَّہُ ، ثُمَّ بَادَرَ فَصَلَّی۔",,,8470,,
8471,"حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنْ مَالِکِ بْنِ أَنَسٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : إذَا لَمْ یَنْقَطِعِ الرُّعَافُ أَوْمَأَ صَاحِبُہُ إیمَائً۔",,,8471,,
8472,"حَدَّثَنَا عُمَرُ بْنُ ہَارُونَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ : فِی رَجُلٍ رَعَفَ فَلَمْ یَرْقَأ عَنْہُ حَتَّی یَخْشَی فَوْتَ الصَّلاَۃ ، قَالَ : یَشُدُّ مَنْخِرَیْہِ بِخِرْقَۃٍ وَیُبَادِرُ فَیُصَلِّی ، قُلْتُ : إذًا یَقَعُ فِی جَوْفِہِ ، قَالَ : وَلَوْ۔",,,8472,,
8473,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : یُدَارَی مَا بَیْنَہُ وَبَیْنَ أَنْ یَخَافَ فَوْتَ الْوَقْتِ فَإِذَا کَانَ ذَلِکَ بَادَرَ فَصَلَّی ، یَعْنِی الرُّعَافَ۔",,,8473,,
8474,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ ، عَنِ الْمِسْوَرِ بْنِ مَخْرَمَۃَ : أَنَّ عُمَرَ بْنَ الْخَطَّابِ صَلَّی وَإِنَّ جُرْحَہُ لَیَثْعَبُ دَمًا۔",,,8474,,
8475,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ أَبِی الأَحْوَص ، عَنْ عَبْدِ اللہِ ، سَمِعَ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : فَضْلُ صَلاَۃِ الرَّجُلِ فِی جَمَاعَۃٍ عَلَی صَلاَتِہِ وَحْدَہُ بِضْعٌ وَعِشْرُونَ دَرَجَۃً۔ (احمد 1/376۔ بزار 458)",,,8475,,
8476,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ ہِلالِ بْنِ مَیْمُونٍ ، عَنْ عَطَائِ بْنِ یَزِیدَ اللَّیْثِیِّ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : صَلاَۃُ الرَّجُلِ فِی جَمَاعَۃٍ تَزِیدُ عَلَی صَلاَتِہِ وَحْدَہُ خَمْسًا وَعِشْرِینَ دَرَجَۃً ، وَإِنْ صَلاَّہَا بِأَرْضِ فَلاَۃٍ فَأَتَمَّ وُضُوئَہَا وَرُکُوعَہَا وَسُجُودَہَا بَلَغَتْ صَلاَتُہُ خَمْسِینَ دَرَجَۃً۔ (ابوداؤد 561۔ ابن ماجہ 788)",,,8476,,
8477,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : تَفْضُلُ الصَّلاَۃ فِی الْجَمِیعِ عَلَی صَلاَۃِ الرَّجُلِ وَحْدَہُ خَمْسًا وَعِشْرِینَ دَرَجَۃً۔ (بخاری 648۔ مسلم 245)",,,8477,,
8478,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حدَّثَنَا عُبَیْدِ اللہِ بْنُ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : صَلاَۃُ الرَّجُلِ فِی جَمَاعَۃٍ تَفْضُلُ عَلَی صَلاَتِہِ وَحْدَہُ بِسَبْعٍ وَعِشْرِینَ دَرَجَۃً۔ (مسلم 451۔ ابن ماجہ 789)",,,8478,,
8479,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الصَّلاَۃ فِی الْجَمَاعَۃِ تَزِیدُ عَلَی صَلاَۃِ الْفَذِّ خَمْسًا وَعِشْرِینَ دَرَجَۃً۔ (بخاری 648۔ مسلم 450)",,,8479,,
8480,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ دَاوُدَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : فَضْلُ صَلاَۃِ الْجَمَاعَۃِ عَلَی صَلاَۃِ الرَّجُلِ وَحْدَہُ أَرْبَعٌ وَعِشْرُونَ دَرَجَۃً۔",,,8480,,
8481,"حَدَّثَنَا خَلَفُ بْنُ خَلِیفَۃَ ، عَنْ أَبِی مَالِکٍ الأَشْجَعِیِّ ، عَنْ أَبِی جَعْفَرٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : تُضَاعَفُ صَلاَۃُ الْجَمَاعَۃِ عَلَی صَلاَۃِ الْوَحْدَۃِ خَمْسًا وَعِشْرِینَ دَرَجَۃً۔",,,8481,,
8482,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ أَبِی حَصِینٍ ، عَنْ أَبِی الأَحْوَص ، قَالَ : قَالَ عَبْدُ اللہِ : صَلاَۃُ الرَّجُلِ فِی جَمَاعَۃٍ أَفْضَلُ مِنْ صَلاَتِہِ فِی سُوقِہِ أَوْ وَحْدَہُ ببِضْعٍ وَعِشْرِینَ دَرَجَۃً ، قَالَ : وَکَانَ یُؤْمَرُ أَنْ یُقَارَبَ بَیْنَ الْخُطَی۔",,,8482,,
8483,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ حَجَّاجٍ ، عَنْ ثَابِتِ بنِ عُبَیْدٍ ، قَالَ : دَخَلْنَا عَلَی زَیْدِ بْنِ ثَابِتٍ وَہُوَ یُصَلِّی عَلَی حَصِیرٍ یَسْجُدُ عَلَیْہِ ، وَقَالَ : فَضْلُ صَلاَۃِ الْجَمَاعَۃِ عَلَی صَلاَۃِ الْوَحْدَۃِ خَمْسٌ وَعِشْرُونَ دَرَجَۃً۔",,,8483,,
8484,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : الصَّلاَۃ مَعَ الإِمَامِ تَفْضُلُ عَلَی صَلاَتِہِ وَحْدَہُ سَبْعًا وَعِشْرِینَ دَرَجَۃً۔",,,8484,,
8485,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ عَمْرِو بْنِ قَیْسٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : فَضْلُ صَلاَۃِ الْجَمَاعَۃِ عَلَی صَلاَۃِ الْوَحْدَۃِ خَمْسٌ وَعِشْرُونَ دَرَجَۃً ، فَإِنْ کَانُوا أَکْثَرَ فَعَلَی عَدَدِ مَنْ فِی الْمَسْجِدِ ، فَقَالَ رَجُلٌ : وَإِنْ کَانُوا عَشْرَۃَ الأَفٍ ؟ قَالَ : نَعَمْ وَإِنْ کَانُوا أَرْبَعِینَ أَلْفًا۔",,,8485,,
8486,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ مُحَمَّدِ بْنِ سُوقَۃَ ، عَنْ رَجُلٍ ، عَنْ کَعْبٍ ، قَالَ : عَلَی عَدَدِ مَنْ فِی الْمَسْجِدِ۔",,,8486,,
8487,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، عَنْ کَثِیرِ بْنِ أَفْلَحَ ، قَالَ : کُنَّا بِالْمَدِینَۃِ فِی دَارِ أَبِی یُوسُفَ فِی حِسَابٍ لَنَا نَحْسِبُہُ وَمَعَنَا زَیْدُ بْنُ ثَابِتٍ ، فَقَالَ : صَلاَۃُ الرَّجُلِ مَعَ الإِمَامِ تُضَعَّفُ عَلَی صَلاَتِہِ وَحْدَہُ بِضْعًا وَعِشْرِینَ دَرَجَۃً۔",,,8487,,
8488,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الأَحْوَص ، قَالَ : قَالَ عَبْدُ اللہِ : تَزِیدُ صَلاَۃُ الرَّجُلِ فِی جَمَاعَۃٍ عَلَی صَلاَتِہِ وَحْدَہُ أَرْبَعًا وَعِشْرِینَ دَرَجَۃً ، أَوْ خَمْسًا وَعِشْرِینَ دَرَجَۃً۔",,,8488,,
8489,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ سَعْدِ بْنِ إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ عُمَرَ بْنِ قَتَادَۃَ ، عَنْ مَحْمُودِ بْنِ لَبِیدٍ ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إیَّاکُمْ إیَّاکُمْ وَشِرْکَ السَّرَائِرِ ، قَالُوا : وَمَا شِرْکُ السَّرَائِرِ؟ قَالَ: أَنْ یَقُومَ أَحَدُکُمْ یُزَیِّنُ صَلاَتَہُ جَاہِدًا لِیَنْظُرَ النَّاسُ إلَیْہِ ، فَذَلِکَ شِرْکُ السَّرَائِرِ۔ (بیہقی 290۔ احمد 5/429)",,,8489,,
8490,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الأَحْوَص ، عَنْ عَبْدِ اللہِ ، قَالَ : مَنْ صَلَّی صَلاَۃً وَالنَّاسُ یَرَوْنَہُ فَلْیُصَلِّ إذَا خَلاَ مِثْلَہَا وَالأَ فَإِنَّمَا ہِیَ اسْتِہَانَۃٌ یَسْتَہِینُ بِہَا رَبَّہُ۔",,,8490,,
8491,حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ رَجُلٍ ، عَنْ حُذَیْفَۃَ مِثْلَہُ۔,,,8491,,
8492,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ بُرْدٍ ، عَنْ سُلَیْمَانَ بْنِ مُوسَی ، عَنْ عَائِشَۃَ ، قَالَتْ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّی فِی الثَّوْبِ الَّذِی یُجَامِعُ فِیہِ۔ (احمد 217)",,,8492,,
8493,"حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ عُمَیْرٍ ، قَالَ : سَأَلَ رَجُلٌ جَابِرَ بْنَ سَمُرَۃَ أُصَلِّی فِی الثَّوْبِ وَأُجَامِعُ فِیہِ ؟ قَالَ : إِنْ أَصَابَہُ شَیْئٌ فَاغْسِلْہُ ، وَإِن لَم یُصبہ شَیْئٌ فَلاَ بَأْسَ أَنْ تُصَلِّیَ فِیہِ۔",,,8493,,
8494,"حَدَّثَنَا وَکِیعٌ، عَنْ بَشِیرٍ، عَنْ أَبِی حَازِمٍ، عَنِ ابْنِ عُمَرَ، قَالَ: إنَّ ہَذِہِ لَتَعْلَمُ أَنَّا نُجَامِعُ فِیہِ وَنُصَلِّی فِیہِ۔",,,8494,,
8495,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنِ الشَّعْبِیِّ : سُئِلَ عَنِ الثَّوْبِ الَّذِی یُجَامِعُ فِیہِ أَیُصَلِّی فِیہِ ؟ قَالَ : قُلْتُ : نَعَمْ ، قُلْتُ : فَأَنْضَحُہُ بِالْمَائِ ؟ قَالَ : لاَ یَزِیدُہ إِلاَّ نَتَنًا۔",,,8495,,
8496,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ مُعَاوِیَۃَ بْنِ صَالِحٍ قَالَ : حدَّثَنِی ضَمْرَۃُ بْنُ حَبِیبٍ ، قَالَ : حَدَّثَنِی مُحَمَّدُ بْنُ أَبِی سُفْیَانَ الثَّقَفِیُّ ، أَنَّ أُمَّ حَبِیبَۃَ زَوْجَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَتْ : رَأَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّی فِی ثَوْبٍ عَلَیَّ وَعَلَیْہِ کَانَ فِیہِ مَا کَانَ۔ (بخاری 288۔ احمد 6/325)",,,8496,,
8497,"حَدَّثَنَا شَبَابَۃُ ، عَنْ لَیْثٍ ، عَنْ یَزِیدَ بْنِ أَبِی حَبِیبٍ ، عَنْ سُوَیْد بْنِ قَیْسٍ ، عَنْ مُعَاوِیَۃَ بْنِ حُدَیْجٍ ، عَنْ مُعَاوِیَۃَ بْنِ أَبِی سُفْیَانَ : أَنَّہُ سَأَلَ أُمَّ حَبِیبَۃَ ابْنَۃَ أَبِی سُفْیَانَ ہَلْ کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّی فِی الثَّوْبِ الَّذِی کَانَ یُجَامِعُہَا فِیہِ ؟ قَالَتْ : نَعَمْ إذَا لَمْ یَرَ فِیہِ أَذًی۔ (ابوداؤد 369۔ احمد 6/427)",,,8497,,
8498,"حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَأَی رَجُلاً قَصِیرًا یُقَالُ لَہُ : زنیْمٌ فَسَجَدَ ، وَقَالَ : الْحَمْدُ لِلَّہِ الَّذِی لَمْ یَجْعَلْنِی مِثْلَ ہَذَا۔ (ابوداؤد 2768۔ ترمذی 1578)",,,8498,,
8499,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مِسْعَرٌ ، عَنْ أَبِی عَوْنٍ الثَّقَفِیِّ مُحَمَّدِ بْنِ عُبَیدِ اللہِ ، عَنْ رَجُلٍ لَمْ یُسَمِّہِ ، أَنَّ أَبَا بَکْرٍ لَمَّا فَتَحَ الْیَمَامَۃَ سَجَدَ۔",,,8499,,
8500,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا مِسْعَرٌ ، عَنْ أَبِی عَوْنٍ الثَّقَفِیِّ ، عَنْ یَحْیَی بْنِ الْجَزَّارِ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَرَّ بِہِ رَجُلٌ بِہِ زَمَانَۃٌ فَسَجَدَ ، وَأَبُو بَکْرٍ ، وَعُمَرُ۔",,,8500,,
8501,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، عْن أَبِیہِ : أَنَّ عُمَرَ أَتَاہُ فَتْحٌ مِنْ قِبَلِ الْیَمَامَۃِ فَسَجَدَ۔",,,8501,,
8502,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مُحَمَّدِ بْنِ قَیْسٍ الْہَمْدَانِیِّ ، عَنْ شَیْخٍ لَہُمْ یُکَنَّی أَبَا مُوسَی قَالَ : شَہِدْتُ عَلِیًّا لَمَّا أُتِیَ بِالْمُخْدَجِ سَجَدَ۔",,,8502,,
8503,"حَدَّثَنَا شَرِیکٌ ، عَنْ مُحَمَّدِ بْنِ قَیْسٍ ، عَنْ أَبِی مُوسَی : أَنَّ عَلِیًّا لَمَّا أُتِیَ بِالْمُخْدَجِ سَجَدَ۔",,,8503,,
8504,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ : أَنَّہُ کَرِہَ سَجْدَۃَ الشُّکْرِ ، قَالَ مَنْصُورٌ : وَبَلَغَنِی أَنَّ أَبَا بَکْرٍ وَعُمَرَ سَجَدَا سَجْدَۃَ الشُّکْرِ۔",,,8504,,
8505,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَرَّ بنُغَاشِیٍّ فَسَجَدَ وَقَالَ : اسْأَلُوا اللَّہَ الْعَافِیَۃَ۔",,,8505,,
8506,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا الْکَلْبِیُّ ، عَنْ أَبِی صَالِحٍ ، عَنِ ابْنِ عَبَّاسٍ قَالَ : لَمَّا نَزَلَ نِکَاحُ زَیْنَبَ انْطَلَقَ زَیْدُ بْنُ حَارِثَۃَ حَتَّی اسْتَأْذَنَ عَلَی زَیْنَبَ ، قَالَ : فَقَالَتْ زَیْنَبُ : مَا لِی وَلِزَیْدٍ ، قَالَ : فَأَرْسَلَ إلَیْہَا فَقَالَ : إنِّی رَسُولُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إلَیْکِ ، قَالَ : فَأَذِنَتْ لَہُ ، فَبَشَّرَہَا أَنَّ اللَّہَ قَدْ زَوَّجَہَا مِنْ نَبِیِّہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : فَخَرَّتْ سَاجِدَۃً لِلَّہِ شُکْرًا۔ (ابن سعد 102)",,,8506,,
8507,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إبْرَاہِیمَ : أَنَّہُ کَانَ یَکْرَہُ سَجْدَۃَ الْفَرَحِ ، وَیَقُولُ : لَیْسَ فِیہَا رُکُوعٌ وَلاَ سُجُودٌ۔",,,8507,,
8508,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا سُوَیْد بْنُ عُبَیْدٍ الْعِجْلِیّ ، عَنْ أَبِی مُؤَمَّنٍ الْوَاثِلِیِّ قَالَ : شَہِدْتُ عَلِیًّا لَمَّا أُتِیَ بِالْمُخْدَجِ سَجَدَ۔",,,8508,,
8509,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : سَجْدَۃُ الشُّکْرِ بِدْعَۃٌ۔",,,8509,,
8510,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : أَخْبَرَنَا إسْمَاعِیلُ بْنُ زَرْبِیٍّ ، قَالَ : حَدَّثَنَا رَبَّانُ بْنُ صَبِرَۃَ الْحَنَفِیُّ : أَنَّہُ شَہِدَ یَوْمَ النَّہْرَوَانِ ، قَالَ : وَکُنْتُ فِیمَنِ اسْتَخْرَجَ ذَا الثُّدَیَّۃِ فَبُشِّرَ بِہِ عَلِیًّا قَبْلَ أَنْ یَنْتَہِیَ إلَیْہِ ، فَانْتَہَیْنا إلَیْہِ وَہُوَ سَاجِدٌ فَرِحًا بِہِ۔",,,8510,,
8511,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ قَالَ : حدَّثَنَا مُوسَی بْنُ عُبَیْدَۃَ ، عَنْ قَیْسِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ أَبِی صَعْصَعَۃَ ، عَنْ سَعْدِ بْنِ إِبْرَاہِیمَ ، عَن أَبِیہِ ، عَنْ جَدِّہِ عَبْدِ الرَّحْمَنِ بْنِ عَوْفٍ ، قَالَ : انْتَہَیْتُ إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ ساجِدٌ ، فَلَمَّا انْصَرَفَ قُلْتُ : أَطَلْت السُّجُودَ ، قَالَ : إنِّی سَجَدْتُ شُکْرًا لِرَبِّی فِیمَا أَبْلاَنِی فِی أُمَّتِی۔ (احمد 1/191۔ ابو یعلی 843)",,,8511,,
8512,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : أَبْصَرَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سَعْدًا وَہُوَ یَدْعُو بِإِصْبَعَیْہِ ، قَالَ : فَقاَلَ لَہُ : یَا سَعد أَحِّد أَحِّد۔ (ترمذی 3557۔ ابوداؤد 1494)",,,8512,,
8513,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ، عَنْ أَبِی ہُرَیْرَۃَ : أَنَّہُ رَأَی رَجُلاً یَدْعُو بِإِصْبَعَیْہِ کِلْتَیْہِمَا فَنَہَاہُ ، وَقَالَ بِإِصْبَعٍ وَاحِدَۃٍ بِالْیُمْنَی۔",,,8513,,
8514,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ رَاشِدٍ أَبِی سَعْدٍ ، عَنْ سَعِیدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ أَبْزَی ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا جَلَسَ فِی الصَّلاَۃ وَضَعَ یَدَہُ عَلَی فَخِذِہِ یُشِیرُ بِإِصْبَعِہِ فِی الدُّعَائِ۔ (مسلم 408۔ ابوداؤد 979)",,,8514,,
8515,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ التَّمِیمِیِّ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : ہُوَ الإِخْلاَصُ ، یَعْنِی الدُّعَائَ بِالأَصْبَعِ۔",,,8515,,
8516,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ سُلَیْمَانَ بْنِ أَبِی یَحْیَی، قَالَ: کَانَ أَصْحَابُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَأْخُذُ بَعْضُہُمْ عَلَی بَعْضٍ ، یَعْنِی الإِشَارَۃَ بِالأَصْبَعِ فِی الدُّعَائِ۔",,,8516,,
8517,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنْ مُجَاہِدٍ ، أَنَّہُ قَالَ : الدُّعَائُ ہَکَذَا وَأَشَارَ بِإِصْبَعٍ وَاحِدَۃٍ مِقْمَعَۃُ الشَّیْطَانِ۔",,,8517,,
8518,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ أَبِی عَلْقَمَۃَ ، عَنْ عَائِشَۃَ ، قَالَتْ : إنَّ اللَّہَ یُحِبُّ أَنْ یُدْعاَ ہَکَذَا وَأَشَارَتْ بِإِصْبَعٍ وَاحِدَۃٍ۔",,,8518,,
8519,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ سَلَمَۃَ بْنِ عَلْقَمَۃَ ، عَنْ مُحَمَّدِ بْنِ سِیرِینَ ، عَنْ کَثِیرِ بْنِ أَفْلَحَ ، قَالَ : صَلَّیْتُ ، فَلَمَّا کَانَ فِی آخِرِ الْقَعْدَۃِ قُلْتُ ہَکَذَا وَأَشَارَ ابْنُ عُلَیَّۃَ بِإِصْبَعَیْہِ ، فَقَبَضَ ابْنُ عُمَر ہَذِہِ ، یَعْنِی الْیُسْرَی۔",,,8519,,
8520,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عُمَرَ : أَنَّہُ کَانَ یُشِیرُ بِإِصْبَعِہِ فِی الصَّلاَۃ۔",,,8520,,
8521,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنْ طلحۃ ، عَنْ خَیْثَمَۃَ : أَنَّہُ کَانَ یَعْقِدُ ثَلاَثًا وَخَمْسِینَ ، وَیُشِیرُ بِإِصْبَعِہِ۔",,,8521,,
8522,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : کَانُوا إذَا رَأَوْا إنْسَانًا یَدْعُو بِإِصْبَعَیْہِ ضَرَبُوا إحْدَاہُمَا وَقَالُوا : إنَّمَا ہُوَ إلَہٌ وَاحِدٌ۔",,,8522,,
8523,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا أَشَارَ الرَّجُلُ بِإِصْبَعِہِ فِی الصَّلاَۃ فَہُوَ حَسَنٌ وَہُوَ التَّوْحِیدُ ، وَلَکِنْ لاَ یُشِیرُ بِإِصْبَعَیْہِ ، فَإِنَّہُ یُکْرَہُ۔",,,8523,,
8524,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ : أَنَّ أَبَاہُ کَانَ یُشِیرُ بِإِصْبَعِہِ فِی الدُّعَائِ ، وَلاَ یُحَرِّکُہَا۔",,,8524,,
8525,"حَدَّثَنَا وَکِیعٌ، عَنْ مِسْعَرٍ، عَنْ مَعْبَدِ بْنِ خَالِدٍ، عَنْ قَیْسِ بْنِ سَعْدٍ، قَالَ: کَانَ لاَ یُزَادُ ہَکَذَا وَأَشَارَ بِإِصْبَعِہِ۔",,,8525,,
8526,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَاصِمِ بْنِ قُدَامَۃَ ، عَنْ مَالِکِ بْنِ نُمَیْرٍ الْخُزَاعِیِّ ، عَنْ أَبِیہِ ، قَالَ : رَأَیْتُُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ جَالِسًا فِی الصَّلاَۃ وَاضِعًا یَدَہُ الْیُمْنَی عَلَی فَخِذِہِ یُشِیرُ بِإِصْبَعِہِ۔ (ابوداؤد 983۔ ابن حبان 1946)",,,8526,,
8527,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی صَالِحٍ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَأَی سَعْدًا یَدْعُو بِإِصْبَعَیْہِ، فَقَالَ : أَحِّدْ ، أَحِّدْ۔",,,8527,,
8528,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ عَامِرِ بْنِ عَبْدِ اللہِ بْنِ الزُّبَیْرِ ، عَنْ أَبِیہِ ،قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، إِذَا قَعَدَ یَدْعُو، وَضَعَ یَدَہُ الْیُمْنَی عَلَی فَخِذِہِ الْیُمْنَی ، وَیَدَہُ الْیُسْرَی عَلَی فَخِذِہِ الْیُسْرَی ، وَأَشَارَ بِإِصْبَعِہِ السَّبَّابَۃِ ، وَوَضَعَ إِبْہَامَہُ عَلَی إِصْبَعِہِ الْوُسْطَی ، وَیُلْقِمُ کَفَّہُ الْیُسْرَی رُکْبَتَہُ۔\n\n(مسلم 113۔ ابوداؤد 980)",,,8528,,
8529,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ عَاصِمِ بْنِ کُلَیْبٍ ، عَنْ أَبِیہِ ، عَنْ وَائِلِ بْنِ حُجْرٍ ، قَالَ : رَأَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَاضِعًا حَدَّ مِرْفَقہِ الأَیْمَنَ عَلَِ فَخِذِہِ الْیُمْنَی ، وَحَلَّقَ بِالإِبْہَامِ وَالْوُسْطَی ، وَرَفَعَ الَّتِی تَلِی الإِبْہَامَ یَدْعُو بِہَا۔ (ابوداؤد 726۔ احمد 4/319)",,,8529,,
8530,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنْ سُلَیْمَانَ بْنِ عَمْرِو بْنِ الأَحْوَص ، قَالَ : أَخْبَرَنِی أَبُو ہِلاَلٍ ، عَنْ أَبِی بَرْزَۃَ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ دَعَا عَلَی رَجُلَیْنِ فَرَفَعَ یَدَیْہِ۔ (ابویعلی 7440)",,,8530,,
8531,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنِ الْجُرَیرِیِّ ، عَنْ حَیَّانَ بْنِ عُمَیْرٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ سَمُرَۃَ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَفَعَ یَدَیْہِ ، یَعْنِی فِی الدُّعَائِ۔",,,8531,,
8532,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ إِسْحَاقَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ مُعَاوِیَۃَ ، عَنِ ابْنِ أَبِی ذُبابٍ ، عَنْ سَہْلِ بْنِ سَعْدٍ ، قَالَ : مَا رَأَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ شَاہِرًا یَدَیْہِ فِی الدُّعَائِ عَلَی مِنْبَرٍ وَلاَ غَیْرِہِ ، وَلَقَدْ رَأَیْتُ یَدَیْہِ حَذْوَ مَنْکِبَیْہِ وَیَدْعُو۔ (ابوداؤد 1098۔ احمد 5/337)",,,8532,,
8533,"حَدَّثَنَا عَبَّادُ بْنُ عَوَّامٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسٍ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ لاَ یَرْفَعُ یَدَیْہِ فِی شَیْئٍ مِنَ الدُّعَائِ إِلاَّ فِی الاِسْتِسْقَائِ۔ (بخاری 1031۔ ابوداؤد",,,8533,,
8534,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنِ الْمُسَیَّبِ بْنِ رَافِعٍ ، عَنْ تَمِیمِ بْنِ طَرَفَۃَ ، عَنْ جَابِرِ بْنِ سَمُرَۃَ ، قَالَ : خَرَجَ عَلَیْنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : مَا لِی أَرَاکُمْ رَافِعِی أَیْدِیکُمْ کَأَنَّہَا أَذْنَابُ خَیْلٍ شُمْسٍ ، اُسْکُنُوا فِی الصَّلاَۃ۔ (مسلم 119۔ ابوداؤد 909)",,,8534,,
8535,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ حُمَیْدٍ ، عَنْ أَنَسٍ ، قَالَ : سُئِلَ ہَلْ کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَرْفَعُ یَدَیْہِ ؟ فَقَالَ : نَعَمْ شَکَا إلَیْہِ النَّاسُ ذَاتَ جُمُعَۃٍ فَقَالُوا : یَا رَسُولَ اللہِ قَحَطَ الْمَطَرُ وَأَجْدَبَتِ الأَرْضُ وَہَلَکَ الْمَالُ ، قَالَ : فَرَفَعَ یَدَیْہِ وَدَعَا حَتَّی رَأَیْتُ بَیَاضَ إبِطَیْہِ۔ (بخاری 612۔ مسلم 612)",,,8535,,
8536,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّہُ قَالَ : لاَ تقُومُوا تَدْعُونَ کَمَا تَصْنَعُ الْیَہُودُ فِی کَنَائِسِہَا۔",,,8536,,
8537,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنِ ابْنِ الأَصْبَہَانِیِّ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ : أَنَّہُ رَأَی رَجُلاً یَدْعُو قَائِمًا بَعْدَ مَا انْصَرَفَ فَسَبَّہُ ، أَوْ شَتَمَہُ۔",,,8537,,
8538,حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنِ الْحَکَمِ ، عَنْ عَبْدَۃَ بْنِ أَبِی لُبَابَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، أَنَّہُ کَرِہَہُ۔,,,8538,,
8539,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، عَنْ عَبْدِ اللہِ ، قَالَ : ثِنْتَانِ ہُمَا بِدْعَۃٌ أَنْ یَقُومَ الرَّجُلُ بَعْدَ مَا یَفْرُغُ مِنْ صَلاَتِہِ مُسْتَقْبِلَ الْقِبْلَۃِ یَدْعُو وَأَنْ یَسْجُدَ السَّجْدَۃَ الثَّانِیَۃَ فَیَرَی أَنَّ حَقًّا عَلَیْہِ أَنْ یُلْزِقَ أَلْیَتَیْہِ بِالأَرْضِ قَبْلَ أَنْ یَنْہَضَ۔",,,8539,,
8540,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، أَنَّہُ کَانَ یَکْرَہُ الْقِیَامَ بَعْدَہَا یَتَشَبَّہُ بِالْیَہُودِ۔,,,8540,,
8541,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : قُلْتُ لِلْمُغِیرَۃِ : أَکَانَ إبْرَاہِیمُ یَکْرَہُ إذَا انْصَرَفَ أَنْ یَقُومَ مُسْتَقْبِلَ الْقِبْلَۃِ یَرْفَعُ یَدَیْہِ ؟ قَالَ : نَعَمْ۔",,,8541,,
8542,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ ، عَنْ عَبْدِ اللہِ : أَنَّہُ بَلَغَہُ أَنَّ قَوْمًا یَذْکُرُونَ اللَّہَ قِیَامًا فَأَتَاہُمْ، فَقَالَ : مَا ہَذِہِ النَّکْرَاء ؟ قَالُوا : سَمِعْنَا اللَّہَ یَقُولُ : {فَاذْکُروا اللَّہَ قِیَامًا وَقُعُودًا وَعَلَی جُنُوبِکمْ} ، فَقَالَ : ہَذَا إنَّمَا إذَا لَمْ یَسْتَطِعِ الرَّجُلُ أَنْ یُصَلِّیَ قَائِمًا صَلَّی قَاعِدًا۔",,,8542,,
8543,"حَدَّثَنَا عَبَّادُ بْنُ العَوَّامِ ، عَنْ جَمِیلِ بْنِ زَیْدٍ ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ دَخَلَ الْبَیْتَ فَصَلَّی رَکْعَتَیْنِ ، ثُمَّ تَحَوَّلَ فَصَلَّی رَکْعَتَیْنِ مِمَّا یَلِی الرُّکْنَ ، ثُمَّ خَرَجْتُ وَتَرَکْتُہُ قَائِمًا یَدْعُو وَیُکَبِّرُ۔",,,8543,,
8544,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ أَشْعَثَ ، قَالَ : رَأَیْتُُ الْحَسَنَ یَرْفَعُ بَصَرَہُ إلَی السَّمَائِ فِی الصَّلاَۃ یَدْعُو وَہُوَ قَائِمٌ۔",,,8544,,
8545,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی ہَاشِمٍ ، عَنْ مُجَاہِدٍ : أَنَّہُ سَمِعَ رَجُلاً یَرْفَعُ صَوْتَہُ بِالدُّعَائِ ، فَرَمَاہُ بِالْحَصَی۔",,,8545,,
8546,"حَدَّثَنَا وَکِیعٌ ، عَنْ عِمْرَانَ بْنِ حُدَیْرٍ ، عَنْ أَبِی مِجْلَزٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : أَیُّہَا النَّاسُ إنَّکُمْ لاَ تَدْعُونَ أَصَمَّ وَلاَ غَائِبًا ، یَعْنِی فِی رَفْعِ الصَّوْتِ بِالدُّعَائِ۔",,,8546,,
8547,"حَدَّثَنَا وَکِیعٌ ، عَنِ الرَّبِیعِ ، عَنْ یَزِیدَ بْنِ أَبَانَ ، عَنْ أَنَسٍ ۔ وَعَنْ رَبِیعٍ ، عَنِ الْحَسَنِ : أَنَّہُمَا کَرِہَا أَنْ یُسْمِعَ الرَّجُلُ جَلِیسَہُ شَیْئًا مِنَ الدُّعَائِ۔",,,8547,,
8548,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُبَارَکٍ ، عَنِ الْحَسَنِ ، قَالَ : کَانُوا یَجْتَہِدُونَ فِی الدُّعَائِ ، وَلاَ تَسْمَعُ إِلاَّ ہَمْسًا۔",,,8548,,
8549,"حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ صَدَقَۃَ ، عَنِ ابْنِ عُمَرَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إنَّ الْمُصَلِّیَ إذَا صَلَّی یُنَاجِی رَبَّہُ فَلْیَعْلَمْ أَحَدُکُمْ بِمَا یُنَاجِیہِ ، وَلاَ یَجْہَرْ بَعْضُکُمْ عَلَی بَعْضٍ۔ (احمد 2/67۔ بزار 726)",,,8549,,
8550,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، وَأَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنْ أَبِی عُثْمَانَ ، عَنْ أَبِی مُوسَی ، قَالَ : کُنَّا مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی سَفَرٍ فَجَعَلَ النَّاسُ یَجْہَرُونَ بِالتَّکْبِیرِ ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَیُّہَا النَّاسُ ارْبَعُوا عَلَی أَنْفُسِکُمْ إِنَّکم لَیْسَ تَدْعُونَ أَصَمَّ ، وَلاَ غَائِبًا إنَّکُمْ تَدْعُونَ سَمِیعًا قَرِیبًا وَہُوَ مَعَکُمْ۔ (بخاری 2992۔ ابوداؤد 1523)",,,8550,,
8551,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عَبْدِ اللہِ بْنِ نُسَیْبٍ قَالَ : صَلَّیْتُ إلَی جَنْبِ سَعِیدِ بْنِ الْمُسَیَّبِ الْمَغْرِبَ ، فَلَمَّا جَلَسْتُ فِی الرَّکْعَۃِ الثَّانِیۃ رَفَعْتُ صَوْتِی بِالدُّعَائِ فَانْتَہَرَنِی ، فَلَمَّا انْصَرَفْتُ قُلْتُ لَہُ : مَا کَرِہْتَ مِنِّی؟ قَالَ : ظَنَنْتَ أَنَّ اللَّہَ لَیْسَ بِقَرِیبٍ مِنْکَ؟۔",,,8551,,
8552,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ زَیْدٍ الْعَمِّیِّ ، عَنْ أَبِی إیَاسٍ ، عَنْ أَنَسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الدُّعَائُ بَیْنَ الأَذَانِ وَالإِقَامَۃِ لاَ یُرَدُّ۔ (ترمذی 212۔ احمد 3/119)",,,8552,,
8553,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنْ أَبِی مُرَارَۃَ ، عَنْ مُجَاہِدٍ ، قَالَ : أَفْضَلُ السَّاعَاتِ مَوَاقِیتُ الصَّلَوَاتِ فَادْعُوا فِیہَا۔",,,8553,,
8554,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ إِسْحَاقَ ، عَنْ مُحَارِبٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : کَانَ یُسْتَحَبُّ الدُّعَائُ عِنْدَ أَذَانِ الْمَغْرِبِ ، وَقَالَ : إِنَّہَا سَاعَۃٌ یُسْتَجَابُ فِیہَا الدُّعَائُ۔",,,8554,,
8555,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ زِیَادِ بْنِ أَنْعُمٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ رَافِعٍ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرو ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا جَلَسَ الإِمَام ثُمَّ أَحْدَثَ فَقَدْ تَمَّتْ صَلاَتُہُ وَمَنْ کَانَ خَلْفَہُ مِمَّنْ أَدْرَکَ مَعَہُ الصَّلاَۃ عَلَی مِثْلِ ذَلِکَ۔ (ترمذی 408۔ ابوداؤد 617)",,,8555,,
8556,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : إذَا جَلَسَ الإِمَام فِی الرَّابِعَۃِ ، ثُمَّ أَحْدَثَ فَقَدْ تَمَّتْ صَلاَتُہُ فَلْیَقُمْ حَیْثُ شَائَ۔",,,8556,,
8557,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی إِسْحَاقَ الْکُوفِی ، عَنْ أَبِی سَعِیدٍ ، عَنْ عَلِیٍّ ، قَالَ : إذَا رَعَفَ فِی صَلاَتہِ بَعْدَ السَجْدَۃِ الآخِرَۃِ فَقَدْ تَمَّتْ صَلاَتُہُ۔",,,8557,,
8558,"حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، وَالْحَسَنِ ، قَالاَ : إذَا رَفَعَ رَأْسَہُ ، ثُمَّ أَحْدَثَ فَقَدْ أَجْزَأَتْہُ صَلاَتُہُ۔",,,8558,,
8559,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا رَفَعَ رَأْسَہُ مِنَ السَّجْدَۃِ فَقَدْ مَضَتْ صَلاَتُہُ۔",,,8559,,
8560,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ ، قَالَ : إذَا جَلَسَ بَعْدَ تَمَامِ الصَّلاَۃ فَأَحْدَثَ قبْلَ أَنْ یَتَشَہَّدَ أَوْ بَعْدَ التَّشَہُّدِ قَبْلَ أَنْ یُسَلِّمَ الإِمَام ، فَقَدْ جَازَتْ وَلْیَنْصَرِفْ۔",,,8560,,
8561,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ طَلْحَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا أَتَمَّ الرُّکُوعَ وَالسُّجُودَ ، ثُمَّ أَحْدَثَ فَقَدِ انْقَضَتْ صَلاَتُہُ وَإِنْ لَمْ یَتَشَہَّدْ۔",,,8561,,
8562,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : إذَا رَعَفَ بَعْدَ مَا یَفْرُغُ مِنَ السَّجْدَۃِ الأَخِرَۃِ فَلْیَنْصَرِفْ فَلْیَتَوَضَّأْ وَلْیَرْجِعْ فَلْیَتَشَہَّدْ مَا لَمْ یَتَکَلَّمْ ، فَإِنْ تَکَلَّمَ اسْتَأْنَفَ الصَّلاَۃ۔",,,8562,,
8563,حَدَّثَنَا ہُشَیْمٌ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ مِثْلَ ذَلِکَ۔,,,8563,,
8564,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یُونُسُ ، عَنِ ابْنِ سِیرِینَ أَنَّہُ کَانَ یَقُولُ : حَتَّی یُسَلِّمَ۔",,,8564,,
8565,"حَدَّثَنَا وَکِیعٌ ، عَنْ مَعْقِلٍ ، عَنْ عَطَائٍ : فِی الرَّجُلِ یُحْدِثُ ، قَالَ : إذَا قَالَ : السَّلاَمُ عَلَیْنَا وَعَلَی عِبَادِ اللہِ الصَّالِحِینَ أَجْزَأَہُ۔",,,8565,,
8566,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ وَحَمَّادٍ ، قَالاَ : حتَّی یَتَشَہَّدَ ، أَوْ یَقْعُدَ مِقْدَارَ التَّشَہُّدِ۔",,,8566,,
8567,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ؛ فِی الرَّجُلِ یَتَشَہَّدُ ثُمَّ یُحْدِثُ ، قَالَ : ہَذَا قَدْ تَمَّتْ صَلاَتُہُ۔",,,8567,,
8568,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنِ ابْنِ الْمُسَیَّبِ ، قَالَ : ہَلْ تَعْلَمُونَ صَلاَۃً یُقْعَدُ فِیہَا کُلِّہَا ؟ فَقَالَ : ذَلکَ رَجُلٌ أَدْرَکَ مِنَ الْمَغْرِبِ رَکْعَۃً فَیَقْعُدُ فِیہِنَّ جَمِیعًا۔",,,8568,,
8569,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : أَدْرَکَ مَسْرُوقٌ وَجُنْدُبٌ رَکْعَۃً مِنَ الْمَغْرِبِ ، فَلَمَّا سَلَّمَ الإِمَام قَامَ مَسْرُوقٌ فَأَضَافَ إلَیْہَا رَکْعَۃً ، ثُمَّ جَلَسَ وَقَامَ جُنْدُبٌ فِیہِما جَمِیعًا ، ثُمَّ جَلَسَ فِی آخِرِہَا فَذَکَرَ ذَلِکَ لِعَبْدِ اللہِ ، فَقَالَ : کِلاَہُمَا قَدْ أَحْسَنَ وَأَفْعَلُ کَمَا فَعَلَ مَسْرُوقٌ أَحَبُّ إلَیَّ۔",,,8569,,
8570,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إبْرَاہِیمَ : أَنَّ جُنْدُبًا وَمَسْرُوقًا خَرَجَا یُرِیدَانِ صَلاَۃَ الْمَغْرِبِ فَأَدْرَکَا مَعَ الإِمَامِ رَکْعَۃً ، فَلَمَّا سَلَّمَ الإِمَام جَلَسَ مَسْرُوقٌ فِی الرَّکْعَۃِ الثَّانِیَۃِ ، وَلَمْ یَجْلِسْ جُنْدُبٌ ، قَالَ وَقَرَأَ جُنْدُبٌ فِی الرَّکْعَۃِ الَّتِی أَدْرَکَ وَلَمْ یَقْرَأْ مَسْرُوقٌ ، فَأَتَیَا ابْنَ مَسْعُودٍ فَذَکَرَا لَہُ مَا صَنَعَا ، فَقَالَ عَبْدُ اللہِ : کِلاَکُمَا قَدْ أَحْسَنَ وَأَفْعَلُ کَمَا فَعَلَ مَسْرُوقٌ۔",,,8570,,
8571,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ مُحَمَّدِ بْنِ أَبِی یَحْیَی ، قَالَ : حدَّثَنَا أَبو الْمُثَنَّی الْجُہَنِیُّ ، عَنْ سَعْدٍ قَالَ : إذَا أَدْرَکَ مَعَ الإِمَامِ رَکْعَۃً مِنَ الأَرْبَعِ فَلاَ یَقْعُدُ إِلاَّ فِی آخِرہنَّ ، فَإِنَّہ لاَ یُقْعَدُ مِنَ الصَّلاَۃ إِلاَّ فِی قَعدَتَیْن۔",,,8571,,
8572,"حَدَّثَنَا یُوسُفَ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ : فِی الرَّجُلِ یُدْرِکُ رَکْعَۃً مِنَ الْمَغْرِبِ ، قَالَ : یَقْعُدُ فِی کُلِّہِنَّ۔",,,8572,,
8573,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابن أَبِی لَبِیدٍ ، عَنْ أَبِی سَلَمَۃَ ، عَنْ عَائِشَۃَ ، قُلْتُ : أَخْبِرِینِی عَنْ صَلاَۃِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ قَالَتْ : کَانَتْ صَلاَتُہُ بِاللَّیْلِ فِی رَمَضَانَ وَغَیْرِہِ ثَلاَثَ عَشْرَۃَ رَکْعَۃً مِنْہَا رَکْعَتَا الْفَجْرِ۔ (ترمذی 439۔ ابوداؤد 1335)",,,8573,,
8574,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی جَمْرَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ سَمِعْتُہُ یَقُولُ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّی مِنَ اللَّیْلِ ثَلاَثَ عَشْرَۃَ رَکْعَۃً۔ (بخاری 1138۔ مسلم 194)",,,8574,,
8575,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ شُرَحْبِیلَ ، عَنْ جَابِرٍ ، قَالَ : أَقْبَلْنَا مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِنَ الْحُدَیْبِیَۃِ حَتَّی إذَا کُنَّا بِالصَّہْبَائِ قَالَ مُعَاذٌ : مَنْ یُسْقِینَا فِی أَسْقِیَتِنَا ، قَالَ : فَخَرَجْتُ فِی فِتْیَانٍ مَعِی حَتَّی أَتَیْنا الأُثایَۃَ فَأَسْقَیْنَا وَاسْتَقَیْنَا ، فَلَمَّا کَانَ بَعْدَ عَتَمَۃٍ مِنَ اللَّیْلِ فَإِذَا رَجُلٌ یُنَازِعُہُ بَعِیرُہُ الْمَائَ ، قَالَ : فَإِذَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَأَخَذْتُ رَاحِلَتَہُ فَأَنَخْتُہَا فَتَقَدَّمَ فَصَلَّی الْعِشَائَ وَأَنَا عَنْ یَمِینِہِ ، ثُمَّ صَلَّی ثَلاَثَ عَشْرَۃَ رَکْعَۃً۔ (احمد 3/380۔ ابویعلی 2213)",,,8575,,
8576,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ سَعِیدِ بْنِ مَسْرُوقٍ ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنْ أَبِی رِشْدِینَ کُرَیْبٍ مَوْلَی ابْنِ عَبَّاسٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : بِتّ عِنْدَ خَالَتِی مَیْمُونَۃَ وَبَاتَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عِنْدَہَا فَرَأَیْتُہُ قَامَ مِنَ اللَّیْلِ قَوْمَۃً فَصَلَّی إمَّا إحْدَی عَشْرَۃَ رَکْعَۃً وَإِمَّا ثَلاَثَ عَشْرَۃَ رَکْعَۃً۔(بخاری 6316۔ مسلم 181)",,,8576,,
8577,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عَنْ عَائِشَۃَ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُصَلِّی بِاللَّیْلِ تِسْعَ رَکَعَاتٍ۔ (ترمذی 443۔ احمد 6/253)",,,8577,,
8578,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : صَلَّی عُمَرُ صَلاَۃً عِنْدَ الْبَیْتِ فَقَرَأَ {لإِیلاَفِ قُرَیْشٍ} فَجَعَلَ یُومِیئُ إلَی الْبَیْتِ وَیَقُولُ : {فَلْیَعْبُدُوا رَبَّ ہَذَا الْبَیْتِ الَّذِی أَطْعَمَہُمْ مِنْ جُوعٍ وَآمَنَہُمْ مِّنْ خَوْفٍ}۔",,,8578,,
8579,"حَدَّثَنَا غُنْدَرٌ، عَنْ شُعْبَۃَ، عَنِ النُّعْمَانِ بْنِ سَالِمٍ، عَنِ ابْنِ أَبِی أَوْسٍ، قَالَ: کَانَ جَدِّی أَوْسٌ أَحْیَانًا یُصَلِّی فَیُشِیرُ إلَیَّ وَہُوَ فِی الصَّلاَۃ فَأُعْطِیہِ نَعْلَیْہِ۔",,,8579,,
8580,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ شُعْبَۃَ ، عَنْ ہِشَامٍ ، قَالَ : کَانَ أَبِی یُومِیئُ فِی الصَّلاَۃ ، قَالَ : وکَانَتْ عَائِشَۃُ تَفْعَلُہُ۔",,,8580,,
8581,"حَدَّثَنَا وَکِیعٌ ، عَنْ یَزِیدَ بْنِ إبْرَاہِیمَ ، عَنِ الْحَسَنِ ، قَالَ : لاَ بَأْسَ بالإِیمَائِ فِی الصَّلاَۃ۔",,,8581,,
8582,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، قَالَ : أَصَابَنِی رُعَافٌ وَأَنَا أَطُوفُ بِالْبَیْتِ فَمَرَرْتُ بِطَاوُوس وَہُوَ یُصَلِّی فَأَشَارَ إلَیَّ أَنِ اغْسِلْہُ بِالْمَائِ ، ثُمَّ عُدْ۔",,,8582,,
8583,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَانَ مُحَمَّدٌ رُبَّمَا أَشَارَ بِیَدِہِ وَہُوَ فِی الصَّلاَۃ۔",,,8583,,
8584,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : قُلْتُ لإِبْرَاہِیمَ : الرَّجُلُ یُشِیرُ إلَی الشَّیْئِ فِی الصَّلاَۃ ؟ قَالَ : إنَّ فِی الصَّلاَۃ لَشُغْلاً۔",,,8584,,
8585,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ : أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ یُومِیئَ الرَّجُلُ فِی الصَّلاَۃ۔",,,8585,,
8586,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنِ الأَجْلَحِ ، عَنْ عَطَائٍ ، قَالَ :قُلْت لَہُ : تَکُونُ لِی الْحَاجَۃُ وَأَنَا فِی الصَّلاَۃ فَأُومِیئُ إلَی الْجَارِیَۃِ بِیَدَیَّ ، قَالَ : إنَّا لنَفْعَلُ ذَلِکَ۔",,,8586,,
8587,"حَدَّثَنَا غُنْدَرٌ، عَنْ شُعْبَۃَ، عَنْ أَبِی إِسْحَاقَ، قَالَ: رَأَیْتُُ عَمْرَو بْنَ مَیْمُونٍ وَہُوَ یُصَلِّی فَأَوْمَأَ إلَی رَجُلٍ بِیَدِہِ۔",,,8587,,
8588,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ أَبِی سُفْیَانَ ، عَنْ جَابِرٍ قَالَ : صُرِعَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ فَرَسٍ لَہُ فَوَقَعَ عَلَی جِذْعِ نَخْلَۃٍ فَانْفَکَّتْ قَدَمُہُ ، فَدَخَلْنَا عَلَیْہِ نَعُودُہُ وَہُوَ یُصَلِّی فِی مَشْرُبَۃٍ لِعَائِشَۃَ جَالِسًا فَصَلَّیْنَا بِصَلاَتِہِ وَنَحْنُ قِیَامٌ ، ثُمَّ دَخَلْنَا عَلَیْہِ مَرَّۃً أُخْرَی وَہُوَ یُصَلِّی جَالِسًا فَصَلَّیْنَا بِصَلاَتِہِ وَنَحْنُ قِیَامٌ فَأَوْمَأَ إلَیْنَا أَنِ اجْلِسُوا۔",,,8588,,
8589,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، قَالَتِ : اشْتَکَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَدَخَلَ عَلَیْہِ نَاسٌ مِنْ أَصْحَابِہِ یَعُودُونَہُ ، فَصَلَّی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ جَالِسًا فَصَلَّوْا بِصَلاَتِہِ قِیَامًا فَأَشَارَ إلَیْہِمْ أَنِ اجْلِسُوا فَجَلَسُوا۔",,,8589,,
8590,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنِ الزُّبَیْرِ بْنِ عَدِیٍّ ، عَنْ إبْرَاہِیمَ : أَنَّہُ سُئِلَ عَنِ الإِیمَائِ فِی الصَّلاَۃ ؟ فَقَالَ : إنَّ فِی الصَّلاَۃ لَشُغْلاً۔",,,8590,,
8591,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ أَبِی ذِئْبٍ ، عَنْ عُثْمَانَ بْنِ عَبْدِ اللہِ بْنِ سُرَاقَۃَ ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ ، قَالَ : رَأَیْتُُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّی عَلَی رَاحِلَتِہِ نَحْوَ الْمَشْرِقِ فِی غَزْوَۃِ أَنْمَارٍ۔ (بخاری4140۔ احمد 3/300)",,,8591,,
8592,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ أَبِی لَیْلَی ، عَنْ عَطِیَّۃَ ، عَنْ أَبِی سَعِیدٍ ۔ وَعَنِ ابْنِ أَبِی لَیْلَی ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَنَّہُ کَانَ یُصَلِّی عَلَی رَاحِلَتِہِ التَّطَوُّعَ فِی السَّفَرِ حَیْثُ تَوَجَّہَتْ بِہِ یُومِیئُ إیمَائً ، السُّجُودُ أَخْفَضُ مِنَ الرُّکُوعِ۔ (مسلم 32)",,,8592,,
8593,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَمْرٍو بنِ یَحْیَی بْنِ عُمَارَۃَ الْمَازِنِیِّ ، عَنْ سَعِیدِ بْنِ یَسَارٍ ، عَنِ ابْنِ عُمَرَ قَالَ : رَأَیْتُُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّی عَلَی حِمَارٍ نَحْوَ الْمَشْرِقِ وَہُوَ مُتَوَجِّہٌ إلَی خَیْبَرَ۔ (مسلم 487۔ ابوداؤد 1219)",,,8593,,
8594,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ قَالَ : بَعَثَنِی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی حَاجَۃٍ ، قَالَ : فَجِئْتُہُ وَہُوَ یُصَلِّی عَلَی رَاحِلَتِہِ نَحْوَ الْمَشْرِقِ وَالسُّجُودُ أَخْفَضُ مِنَ الرُّکُوعِ۔ (ترمذی 351۔ ابوداؤد 1220)",,,8594,,
8595,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَبْدِ اللہِ بْنِ دِینَارٍ ، عَنِ ابْنِ عُمَرَ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُصَلِّی عَلَی رَاحِلَتِہِ فِی السَّفَرِ حَیْثُمَا تَوَجَّہَتْ بِہِ۔ (مالک 26)",,,8595,,
8596,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ زُہَیْرٍ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : کَانَ عَلِیٌّ یُصَلِّی عَلَی رَاحِلَتِہِ حَیْثُ تَوَجَّہَتْ بِہِ ، وَیَجْعَلُ السُّجُودَ دُونَ الرُّکُوع۔",,,8596,,
8597,"حَدَّثَنَا حُمَیْدٌ ، عَنْ حَسَنٍ ، عَنْ عَاصِمٍ ، عَنْ أَبِی عُثْمَانَ : أَنَّ أَبَا ذَرٍّ کَانَ یُصَلِّی عَلَی رَاحِلَتِہِ وَہُوَ قِبَلَ الْمَشْرِقِ وَہُوَ یَخْفِقُ بِرَأْسِہِ فَقِیلَ لَہُ : کُنْتَ نَائِمًا ؟ قَالَ : لاَ وَلَکِنْ کُنْتُ أُصَلِّی۔",,,8597,,
8598,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ یَحْیَی بْنَ أَبِی کَثِیرٍ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ جَابِرٍ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّی عَلَی رَاحِلَتِہِ نَحْوَ الْمَشْرِقِ فَإِذَا أَرَادَ أَنْ یُصَلِّیَ الْمَکْتُوبَۃَ نَزَلَ فَاسْتَقْبَلَ الْقِبْلَۃَ۔ (بخاری 1099۔ مسلم 383)",,,8598,,
8599,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ رِبْعِیِّ بْنِ الْجَارُودِ بْنِ أَبِی سَبْرَۃَ التَّمِیمِیِّ ، قَالَ : حدَّثَنِی عَمْرُو بْنُ أَبِی الْحَجَّاجِ ، عَنِ الْجَارُودِ بْنِ أَبِی سَبْرَۃَ ، عَنْ أَنَسِ بْنِ مَالِکٍ قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا أَرَادَ أَنْ یُصَلِّیَ عَلَی رَاحِلَتِہِ تَطَوُّعًا اسْتَقْبَلَ الْقِبْلَۃَ فَکَبَّرَ لِلصَّلاَۃِ ، ثُمَّ صَلَّی عَلی رَاحِلَتِہِ فَصَلَّی حَیْثُمَا تَوَجَّہَتْ بِہِ۔ (ابوداؤد 1218۔ دارقطنی 395)",,,8599,,
8600,"حَدَّثَنَا عَبْدَۃُ ، عَنْ عَبْدِ الْمَلِکِ ، عَنِ ابْنِ جُبَیْرٍ ، عَنِ ابْنِ عُمَرَ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُصَلِّی عَلَی رَاحِلَتِہ حَیْثُ تَوَجَّہَتْ بِہِ ، وَکَانَ ابْنُ عُمَرَ یَفْعَلُ ذَلِکَ۔ (مسلم 486۔ ترمذی 2958)",,,8600,,
8601,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا یُونُسُ بْنُ الْحَارِثِ الطَّائِفِیُّ ، عَنْ أَبِی بُرْدَۃَ بْنِ أَبِی مُوسَی ، عَنْ أَبِیہِ : أَنَّہُ کَانَ یُصَلِّی عَلَی رَاحِلَتِہِ حَیْثُمَا تَوَجَّہَتْ بِہِ فِی السَّفَرِ۔",,,8601,,
8602,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مِسْعَرٌ ، عَنْ عَلِیِّ بْنِ عَتِیقٍ ، عَنْ أَبِی بُرْدَۃَ ، عَنْ أَبِی مُوسَی : أَنَّہُ کَانَ یُصَلِّی عَلَی رَاحِلَتِہِ فِی السَّفَرِ حَیْثُمَا تَوَجَّہَتْ بِہِ۔",,,8602,,
8603,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، قَالَ : رَأَیْتُُ أَنَسًا یُصَلِّی عَلَی حِمَارٍ یُومِیئُ بِِغَیْرِ الْقِبْلَۃِ۔",,,8603,,
8604,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا عُمَرُ بْنُ شَیْبَۃَ بْنِ قَارِظٍ ، عَنْ عَبْدِ اللہِ الْبَہِیِّ مَوْلَی آلِ الزُّبَیْرِ ، قَالَ : صَحِبْتُ عَبْدَ اللہِ بْنَ عُمَرَ مِنْ مَکَّۃَ إلَی الْمَدِینَۃِ ، فَکَانَ یُصَلِّی عَلَی رَاحِلَتِہِ إلَی غَیْرِ الْقِبْلَۃِ۔",,,8604,,
8605,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حُصَیْنٌ ، عَنْ مُجَاہِدٍ قَالَ : صَحِبْتُ ابْنَ عُمَرَ مِنَ الْمَدِینَۃِ إلَی مَکَّۃَ ، فَکَانَ یُصَلِّی عَلَی دَابَّتِہِ حَیْثُ تَوَجَّہَتْ بِہِ ، فَإِذَا کَانَتِ الْفَرِیضَۃُ نَزَلَ فَصَلَّی۔",,,8605,,
8606,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنْ مُحَمَّدٍ : أَنَّ أَبَا أَیُّوبَ کَانَ یُصَلِّی عَلَی رَاحِلَتِہِ حَیْثُ تَوَجَّہَتْ بِہِ۔",,,8606,,
8607,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ الْعَلاَئِ بْنِ زَیْدٍ ، عَنِ الْحَسَنِ أَوْ غَیْرِہِ الشَّکُّ مِنِّی : أَنَّ أَصْحَابَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانُوا یُصَلُّونَ فِی أَسْفَارِہِمْ عَلَی دَوَابِّہِمْ حَیْثُمَا کَانَتْ وُجُوہُہُمْ۔",,,8607,,
8608,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یُصَلُّونَ عَلَی رَوَاحِلِہِمْ وَدَوَابِّہِمْ حَیْثُمَا کَانَتْ وُجُوہُہُمْ إِلاَّ الْمَکْتُوبَۃَ وَالْوِتْرَ ، فَإِنَّہُمْ کَانُوا یُصَلُّونَہُمَا بِالأَرْضِ۔",,,8608,,
8609,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ ابْنِ عَوْنٍ ، قَالَ: سَأَلْتُ الْقَاسِمَ بْنَ مُحَمَّدٍ یُصَلِّی الرَّجُلُ عَلَی رَاحِلَتِہِ ؟ قَالَ: نَعَمْ ، قُلْتُ : یُصَلِّی حَیْثُ کَانَ وَجْہُہُ ؟ قَالَ : نَعَمْ ، قُلْتُ : یَجْعَلُ السُّجُودَ أَخْفَضَ مِنَ الرُّکُوعِ ؟ قَالَ : نَعَمْ۔",,,8609,,
8610,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنْ مُحَمَّدٍ ، عَنْ عَبِیْدَۃَ ، قَالَ :یُصَلِّی الرَّجُلُ عَلَی رَاحِلَتِہِ حَیْثُ کَانَ وَجْہُہُ ، فَإِذَا کَانَتِ الْفَرِیضَۃُ نَزَلَ۔",,,8610,,
8611,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عَبْدُ اللہِ بْنُ حُمَیْدٍ ، عَنْ أَبِی جَعْفَرٍ مُحَمَّدِ بْنِ عَلِیٍّ : أَنَّ أَبَاہُ عَلِیَّ بْنَ حُسَیْنٍ کَانَ یُصَلِّی عَلَی رَاحِلَتِہِ فِی السَّفَرِ حَیْثُ تَوَجَّہَتْ بِہِ۔",,,8611,,
8612,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مِسْعَرٌ ، عَنْ بُکَیْرِ بْنِ الأَخْنَسِ ، عَنْ رَجُلٍ ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُصَلِّی فِی السَّفَرِ عَلَی رَاحِلَتِہِ حَیْثُ تَوَجَّہَتْ بِہِ۔",,,8612,,
8613,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ أَبِی الْہَزْہَازِ : سَأَلْتُ الضَّحَّاکَ عَنِ الصَّلاَۃ عَلَی الدَّابَّۃِ ؟ فَقَالَ : حیْثُ کَانَ وَجْہُہُ یَجْعَلُ السُّجُودَ أَسْفَلَ مِنَ الرُّکُوعِ۔",,,8613,,
8614,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ عِمْرَانَ بْنِ مُسْلِمٍ ، عَنْ سُوَیْد بْنِ غَفَلَۃَ ، قَالَ : کُنَّا نُصَلِّی عَلَی دَوَابِّنَا فِی الْغَزْوِ حَیْثُمَا تَوَجَّہْنا۔",,,8614,,
8615,"حَدَّثَنَا عَبْدُ الأَعْلَی ، أَوْ حُدِّثْتُ عَنْہُ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ عَبْدِ اللہِ بْنِ عَامِرِ بْنِ رَبِیعَۃَ ، عَنْ أَبِیہِ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُصَلِّی عَلَی رَاحِلَتِہِ حَیْثُمَا تَوَجَّہَتْ بِہِ۔(بخاری 1097۔ مسلم 40)",,,8615,,
8616,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ہِشَامُ بْنُ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ قَالَتْ : مَا أُبَالِی صَلَّیْتُ فِی الْحِجْرِ أَوْ فِی الْکَعْبَۃِ۔",,,8616,,
8617,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، قَالَتْ : مَا أُبَالِی صَلَّیْتُ فِی الْحِجْرِ أَوْ فِی الْبَیْتِ۔",,,8617,,
8618,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ عَبْدِ الْمَلِکِ ، قَالَ : رَأَیْتُُ سَعِیدَ بْنَ جُبَیْرٍ إذَا قَضَی طَوَافَہُ دَخَلَ الْحِجْرَ فَصَلَّی فِیہِ، وَرَأَیْتُ عَلِیَّ بْنَ حُسَیْنٍ یَفْعَلُ ذَلِکَ۔",,,8618,,
8619,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إسْرَائِیلَ ، عَنِ الْہَیْثُمِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : الْحِجْرُ مِنَ الْکَعْبَۃِ۔",,,8619,,
8620,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ یَعْلَی بْنِ عَطَائٍ ، عَنْ یَحْیَی بْنِ قِمطََۃَ ، عَنْ عَبْدِ اللہِ بْنِ عُمَرَ : أَنَّہُ قَالَ فِی ہَذِہِ الآیَۃِ (فَلَنُوَلِّیَنَّکَ قِبْلَۃً تَرْضَاہَا) قَالَ : قِبْلَۃُ إبْرَاہِیمَ تَحْتَ الْمِیزَابِ ، یَعْنِی فِی الْحِجْرِ۔",,,8620,,
8621,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، قَالَ : أَخْبَرَنَا شَیْبَانُ ، عَنْ أَشْعَثَ بْنِ أَبِی الشَّعْثَائِ ، عَنِ الأَسْوَدِ بْنِ یَزِیدَ ، عَنْ عَائِشَۃَ : سَأَلْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الْحِجْرِ ، فَقَالَ : ہُوَ مِنَ الْبَیْتِ۔ (بخاری 7243۔ مسلم 405)",,,8621,,
8622,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ وَحَمَّادًا عَنِ الرَّجُلِ یَنْتَہِی إلَی الْقَوْمِ وَہُمْ جُلُوسٌ فَیُکَبِّرُ ثُمَّ یَجْلِسُ ؟ فَقَالاَ : إذَا قَامَ اعْتَدَّ بِتِلْکَ التَّکْبِیرَۃِ۔",,,8622,,
8623,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ أَبِی حَصِینٍ ، عَنْ یَحْیَی ، عَنْ مَسْرُوقٍ ، عَنْ عَبْدِ اللہِ بنِ مَسْعُودٍ : أَنَّہُ کَرِہَ التَّعْشِیرَ فِی الْمُصْحَفِ۔",,,8623,,
8624,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : کَانَ یُکْرَہُ التَّعْشِیرَ فِی الْمُصْحَفِ ، وَأَنْ یُکْتَبَ فِیہِ شَیْئٌ مِنْ غَیْرِہِ۔",,,8624,,
8625,حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ حَجَّاجٍ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ مِثْلَہُ۔,,,8625,,
8626,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مُحَمَّدٍ الْمُحَارِبِیُّ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ : أَنَّہُ کَانَ یَکْرَہُ أَنْ یُکْتَبَ فِی الْمُصْحَفِ تَعْشِیرٌ أَوْ تَفْصِیل ، وَیَقُولَ : سُورَۃُ الْبَقَرَۃِ ، وَیَقُولُ : السُّورَۃُ الَّتِی یُذْکَرُ فِیہَا الْبَقَرَۃُ۔",,,8626,,
8627,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ : أَنَّہُ کَانَ یَکْرَہُ التَّعْشِیرَ فِی الْمُصْحَفِ ، أَوْ یُکْتَبَ فِیہِ شَیْئٌ مِنْ غَیْرِہِ۔",,,8627,,
8628,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ، عَنِ الزِّبْرِقَانِ، قَالَ: قُلْتُ لأَبِی رَزِینٍ: إنَّ عِنْدِی مُصْحَفًا أُرِیدُ أَنْ أَخْتِمَہُ بِالذَّہَبِ وَأَکْتُبَ عِنْدَ أَوَّلِ کُل سُورَۃٍ آیَۃُ کَذَا وَکَذَا، قَالَ أَبُو رَزِینٍ: لاَ تَزِیدن فِیہِ شَیْئًا مِنَ الدُّنْیَا قَلَّ أَوْ کَثُرَ۔",,,8628,,
8629,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ، عَنْ ہِشَامٍ، عَنْ مُحَمَّدٍ: أَنَّہُ کَانَ یَکْرَہُ الْفَوَاتِحَ وَالْعَوَاشِرَ الَّتِی فِیہَا قَافٌ وَکَافٌ۔",,,8629,,
8630,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ، عَنْ حَجَّاجٍ، عَنْ شَیْخٍ، عَنْ عَبْدِ اللہِ: أَنَّہُ رَأَی خَطًّا فِی مُصْحَفٍ فَحَکَّہُ وَقَالَ: لاَ تَخْلِطُوا بِہِ غَیْرَہُ۔",,,8630,,
8631,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ : أَنَّہُ کَرِہَ التَّعْشِیرَ فِی الْمُصْحَفِ۔",,,8631,,
8632,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ : أَنَّہُ کَرِہَ التَّعْشِیرَ فِی الْمُصْحَفِ۔",,,8632,,
8633,"حَدَّثَنَا وَکِیعٌ ، قَالَ: حدَّثَنَا سُفْیَانُ ، عَنْ مُغِیرَۃَ، عَنْ إبْرَاہِیمَ: أَنَّہُ کَرِہَ النَّقْطَ وَخَاتِمَۃَ سُورَۃِ کَذَا وَکَذَا۔",,,8633,,
8634,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنْ أَبِی الزَّعْرَائِ ، عَنِ ابْنِ مَسْعُودٍ قَالَ : جَرِّدُوا الْقُرْآنَ ، وَلاَ تَلْبِسُوا بِہِ مَا لَیْسَ مِنْہُ۔",,,8634,,
8635,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ الأَعْمَش ، عَنْ إبْرَاہِیمَ قَالَ : قَالَ عَبْدُ اللہِ : جَرِّدُوا الْقُرْآنَ۔",,,8635,,
8636,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : کَانَ یُقَال : جَرِّدُوا الْقُرْآنَ۔",,,8636,,
8637,"حَدَّثَنَا الْمُحَارِبِیُّ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، قَالَ : قَالَ عَبْدُ اللہِ : جَرِّدُوا الْقُرْآنَ۔",,,8637,,
8638,"حَدَّثَنَا الْمُحَارِبِیُّ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، قَالَ : قُلْتُ لِعَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ : مَا مَنَعَک أَنْ تَکُونَ سَأَلْتَ کَمَا سَأَلَ إبْرَاہِیم ؟ فَقَالَ : کَانَ یُقَالُ : جَرِّدُوا الْقُرْآنَ۔",,,8638,,
8639,"حَدَّثَنَا مَالِکٌ وَعَفَّانُ ، قَالاَ : حدَّثَنَا حَمَّادُ بْنُ زَیْدٍ ، عَنْ شُعَیْبِ بْنِ الْحَبْحَابِ : أَنَّ أَبَا الْعَالِیَۃِ کَانَ یَکْرَہُ الْجُمَلَ الَّتِی تُکْتَبُ فِی الْمَصَاحِفِ فَاتِحَۃً وَخَاتِمَۃً ، وَقَالَ : جَرِّدُوا الْقُرْآنَ۔",,,8639,,
8640,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلِیٍّ : أَنَّہُ کَرِہَ أَنْ یُکْتَبَ الْقُرْآنُ فِی الْمَصَاحِفِ الصِّغَارِ۔",,,8640,,
8641,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : کَانَ یُقَالُ : عَظِّمُوا الْقُرْآنَ ، یَعْنِی کَبِّرُوا الْمَصَاحِفَ۔",,,8641,,
8642,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عَلِیُّ بْنُ مُبَارَکٍ ، عَنْ أَبِی حُکَیمَۃَ الْعَبْدِیِّ قَالَ : کُنَّا نَکْتُبُ الْمَصَاحِفَ بِالْکُوفَۃِ فَیَمُرُّ عَلَیْنَا عَلِیٌّ فَیَقُومُ فَیَنْظُرُ فَیُعْجِبُہُ خَطُّنَا وَیَقُولُ : ہَکَذَا نَوِّرُوا مَا نَوَّرَ اللَّہُ۔",,,8642,,
8643,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عَبْدُ الْمَلِکِ بْنُ شَدَّادٍ الأَزْدِیُّ ، عَنْ عُبَیْدِ اللہ بْنِ سُلَیْمَانَ الْعَبْدِیِّ ، عَنْ أَبِی حُکَیمَۃَ الْعَبْدِیِّ قَالَ : کُنَّا نَکْتُبُ الْمَصَاحِفَ بِالْکُوفَۃِ فَیَمُرُّ عَلَیْنَا عَلِیٌّ وَنَحْنُ نَکْتُبُ فَیَقُولُ : أَجِلَّ قَلَمَکَ ، قَالَ: فَقَطَطْتُ مِنْہُ ثُمَّ کَتَبْتُ ، فَقَالَ : ہَکَذَا نَوِّرُوا مَا نَوَّرَ اللَّہُ تَعَالَی۔",,,8643,,
8644,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلِیٍّ : أَنَّہُ کَرِہَ أَنْ یُکْتَبَ الْقُرْآنُ فِی الْمُصْحَفِ الصَّغِیرِ۔",,,8644,,
8645,"حَدَّثَنَا وَکِیعٌ ، وَعُبَیْدُ اللہِ ، عَنْ سُفْیَانَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ : أَنَّہُ کَرِہَ أَنْ یَقُولَ مُصَیْحِفٌ۔",,,8645,,
8646,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا سُفْیَانُ، عَنْ عَاصِمٍ، عَنْ زِرٍّ، عَنْ عَبْدِاللہِ قَالَ: أَدِیمُوا ألنَّظَرَ فِی الْمُصْحَفِ۔",,,8646,,
8647,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ خَیْثَمَۃَ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ، قَالَ : انْتَہَیْت إلَیْہِ وَہُوَ یَقْرَأُ فِی الْمُصْحَفِ ، فَقَالَ : ہَذَا حِزْبِی الَّذِی أُرِیدُ أَنْ أَقُومَ بِہِ اللَّیْلَۃَ۔",,,8647,,
8648,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ الأَعْمَشِ ، عَنْ خَیْثَمَۃَ قَالَ : دَخَلْتُ عَلَی عَبْدِ اللہِ بْنِ عَمْرٍو وَہُوَ یَقْرَأُ فِی الْمُصْحَفِ فَقَالَ : ہَذَا حِزْبِی الَّذِی أُرِیدُ أَنْ أَقُومَ بِہِ اللَّیْلَۃَ۔",,,8648,,
8649,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، قَالَ : کَانَ خُلُقَ الأَوَّلِینَ النَّظَرُ فِی الْمَصَاحِفِ ، قَالَ : وَکَانَ الأَحْنَفُ بْنُ قَیْسٍ إذَا خَلَی نَظَرَ فِی الْمُصْحَفِ۔",,,8649,,
8650,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ شُمَیْسَۃَ أُمِّ سَلَمَۃَ ، عَنْ عَائِشَۃَ : أَنَّہَا کَانَتْ تَقْرَأُ فِی الْمُصْحَفِ فَإِذَا مَرَّتْ بِالسَّجْدَۃِ قَامَتْ فَسَجَدَتْ۔",,,8650,,
8651,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، قَالَ : حَدَّثَتْنِی سُرِّیَّۃُ الرَّبِیعِ بْنِ خُثَیم قَالَتْ : إِنْ کَانَ الرَّبِیعُ لَیَقْرَأُ فِی الْمُصْحَفِ فَإِذَا دَخَلَ عَلَیْہِ إنْسَانٌ غَطَّاہُ۔",,,8651,,
8652,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، قَالَ : دَخَلْتُ عَلَی إبْرَاہِیمَ وَہُوَ یَقْرَأُ فِی الْمُصْحَفِ ، فَاسْتَأْذَنَ عَلَیْہِ رَجُلٌ فَغَطَّاہُ ، وقَالَ : لاَ یَرَی ہَذَا أَنِّی أَقْرَأُ فِیہِ کُلَّ سَاعَۃٍ۔",,,8652,,
8653,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ أَبِی مُوسَی ، عَنِ الْحَسَنِ ، قَالَ : دَخَلُوا عَلَی عُثْمَانَ وَالْمُصْحَفُ فِی حِجْرِہِ۔",,,8653,,
8654,"حَدَّثَنَا سُلیمَانُ بْنُ حَرْبٍ ، قَالَ : حدَّثَنَا أَبُو ہِلاَلٍ ، قَالَ : حَدَّثَنَا أَبُو صَالِحٍ الْعُقَیْلِیُّ ، قَالَ : کَانَ أَبُو الْعَلاَئِ یَزِیدُ بْنُ عَبْدِ اللہِ بْنِ الشِّخِّیرِ یَقْرَأُ فِی الْمُصْحَفِ حَتَّی یُغْشَی عَلَیْہِ۔",,,8654,,
8655,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ لَیْثٍ ، قَالَ : رَأَیْتُُ طَلْحَۃَ یَقْرَأُ فِی الْمُصْحَفِ۔",,,8655,,
8656,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ أَبِی وَائِلٍ ، عَنْ عَبْدِ اللہِ ، قَالَ : تَعَاہَدُوا ہَذِہِ الْمَصَاحِفَ ، فَلَہِیَ أَشَدُّ تَفَصِّیًا مِنْ صُدُورِ الرِّجَالِ مِنَ النَّعَمِ مِنْ عُقُلِہِ ، فَلاَ یَقُولُ أَحَدُکُمْ نَسِیتُ آیَۃَ کَیْتَ وَکَیْتَ ، قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : بَلْ ہُوَ نُسِّیَ۔ (مسلم 229۔ نسائی 10561)",,,8656,,
8657,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللہِ الأَسَدِیُّ ، عَنْ بُرَیْدِ بْنِ عَبْدِ اللہِ ، عَنْ أَبِی بُرْدَۃَ ، عَنْ أَبِی مُوسَی ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : تَعَاہَدُوا الْقُرْآنَ فَوَالَّذِی نَفْسِی بِیَدِہِ لَہُوَ أَشَدُّ تَفَصِّیًا مِنْ قُلُوبِ الرِّجَالِ مِنَ الإِبِلِ مِنْ عُقُلِہَا۔ (بخاری 5033۔ مسلم 545)",,,8657,,
8658,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَثَلُ الْقُرْآنِ مَثَلُ الإِبِلِ الْمُعَقَّلَۃِ إِنْ عَقَلَہَا صَاحِبُہَا أَمْسَکَہَا وَإِنْ تَرَکَہَا ذَہَبَتْ۔ (مسلم 227۔ احمد 2/36)",,,8658,,
8659,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عَنْ عَائِشَۃَ ، قَالَتْ : إنِّی لأَقْرَأُ حِزْبِی ، أَوْ عَامَّۃَ حِزْبِی وَأَنَا مُضْطَجِعَۃٌ عَلَی فِرَاشِی۔",,,8659,,
8660,"حَدَّثَنَا زَیْدُ بْنُ الْحُبابِ ، عَنْ مُوسَی بْنِ عُلِیٍّ ، قَالَ : سَمِعْتُ أَبِی یَقُولُ : سَمِعْتُ عُقْبَۃَ بْنَ عَامِرٍ یَقُولُ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : تَعَلَّمُوا الْقُرْآنَ وَاتْلُوہُ ، فَوَالَّذِی نَفْسِی بِیَدِہِ لَہُوَ أَسْرَعُ تَفَصِّیًا مِنْ قُلُوبِ الرِّجَالِ مِنَ النَّعَمِ مِنْ عُقُلِہَا۔ (احمد 4/146۔ طبرانی 802)",,,8660,,
8661,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہَمَّامٍ ، عَنْ قَتَادَۃَ ، عَنْ یَزِیدَ بْنِ عَبْدِ اللہِ بْنِ الشِّخِّیرِ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ قَرَأَ الْقُرْآنَ فِی أَقَلَّ مِنْ ثَلاَثٍ لَمْ یَفْقَہْہُ۔ (ترمذی 2949۔ ابوداؤد 1389)",,,8661,,
8662,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا مِسْعَرٌ وَسُفْیَانُ ، عَنْ عَلِیِّ بْنِ بَذِیمَۃَ ، عَنْ أَبِی عُبَیْدَۃَ ، قَالَ : قَالَ عَبْدُ اللہِ : مَنْ قَرَأَ الْقُرْآنَ فِی أَقَلَّ مِنْ ثَلاَثٍ فَہُوَ رَاجِزٌ۔",,,8662,,
8663,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حُصَیْنِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ عُبَیْدِ اللہِ بْنِ عَبْدِ اللہِ بْنِ عُتْبَۃَ ، قَالَ : کَانَ ابْنُ مَسْعُودٍ یَقْرَأُ الْقُرْآنَ فِی کُلِّ ثَلاَثٍ وَقَلَّمَا یَسْتَعِینُ بِالنَّہَارِ۔",,,8663,,
8664,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ، عَنْ أُبَیٍّ : أَنَّہُ کَانَ یَخْتِمُ الْقُرْآنَ فِی ثَمَانٍ۔",,,8664,,
8665,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ أَبِی قِلاَبَۃَ : أَنَّہُ کَانَ یَخْتِمُ الْقُرْآنَ فِی ثَمَانٍ ، وَأَنَّ تَمِیمًا الدَّارِیَّ کَانَ یَخْتِمُ الْقُرْآنَ فِی سَبْعٍ۔",,,8665,,
8666,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنْ حَفْصَۃَ ، عَنْ أَبِی الْعَالِیَۃِ ، قَالَ : کَانَ مُعَاذٌ یَکْرَہُ أَنْ یُقْرَأ الْقُرْآنَ فِی أَقَلَّ مِنْ ثَلاَثٍ۔",,,8666,,
8667,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ الأَسْوَدُ یَقْرَأُ الْقُرْآنَ فِی شَہْرِ رَمَضَانَ فِی لَیْلَتَیْنِ وَیَخْتِمُہُ فِی سِوَی رَمَضَانَ فِی سِتٍّ ، وَکَانَ عَلْقَمَۃُ یَخْتِمُہُ فِی خَمْسٍ۔",,,8667,,
8668,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا سُفْیَانُ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ : أَنَّہُ کَانَ یَقْرَأُ الْقُرْآنَ فِی خَمْسٍ، وَکَانَ الأَسْوَدُ بْنُ یَزِیدَ یَقْرَؤُہُ فِی سِتٍّ۔",,,8668,,
8669,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ عَبْدُ الرَّحْمَنِ بْنُ یَزِیدَ یَقْرَأُ الْقُرْآنَ فِی کُلِّ سَبْعٍ ، وَکَانَ عَلْقَمَۃُ وَالأَسْوَدُ یَقْرَؤُہُ أَحَدُہُمَا فِی خَمْسٍ وَالأَخَرُ فِی سِتٍّ ، وَکَانَ إبْرَاہِیمُ یَقْرَؤُہُ فِی سَبْعٍ۔",,,8669,,
8670,"حَدَّثَنَا عَبْدُ اللہِ بْنُ دَاوُد ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، قَالَ : کَانَ عُرْوَۃُ یَقْرَأُ الْقُرْآنَ فِی کُلِّ سَبْعٍ۔",,,8670,,
8671,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ عِمْرَانَ بْنِ حُدَیْرٍ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ : کَانَ یَؤُمُّ الْحَیَّ فِی رَمَضَانَ وَکَانَ یَخْتِمُ فِی سَبْعٍ۔",,,8671,,
8672,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عَبْدُ اللہِ بْنُ عَبْدِ الرَّحْمَنِ بْنِ یَعْلَی الطَّائِفِیُّ ، عَنْ عُثْمَانَ بْنِ عَبْدِ اللہِ بْنِ أَوْسٍ الثَّقَفِیِّ ، عَنْ جَدِّہِ أَوْسِ بْنِ حُذَیْفَۃَ قَالَ : قَدِمَ عَلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَفْدُ ثَقِیفٍ ، قَالَ : فَأَنْزَلَنَا فِی قُبَّۃٍ لَہُ وَنَزَلَ إخْوَانُنَا الأَحْلاَفُ عَلَی المُغِیرَۃِ بْنِ شُعْبَۃَ ، قَالَ : فَکَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَأْتِینَا بَعْدَ الْعِشَائِ فَیُحَدِّثُنَا وَکَانَ أَکْثَرُ حَدِیثِہِ تشَکّیہ قُرَیْشًا وَیَقُولُ : وَلاَ سَوَائَ کُنَّا بِمَکَّۃَ مُسْتَضْعَفِینَ مُسْتَذَلِّینَ ، فَلَمَّا أَتَیْنَا الْمَدِینَۃَ کَانَتِ الْحَرْبُ سِجَالاً عَلَیْنَا وَلَنَا۔\n\nقَالَ : فَأَبْطَأَ عَلَیْنَا ذَاتَ لَیْلَۃٍ فَأَطْوَلَ فَقُلْنَا : یَا رَسُولَ اللہِ أَبْطَأْتَ عَلَیْنَا ، قَالَ : إِنَّہُ طَرَأَ عَلَیَّ حِزْبٌ مِنَ الْقُرْآنِ فَکَرِہْتُ أَنْ أَخْرُجَ حَتَّی أَقْضِیَہُ ، فَسَأَلْنَا أَصْحَابَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَیفَ کَانَ رَسُولُ اللہِ صلی اللہ علیہ یُحَزِّبُ الْقُرْآنَ ؟ فَقَالَ : کَانَ یُحَزِّبُہُ ثَلاَثًا وَخَمْسًا وَسَبْعًا وَتِسْعًا وَإِحْدَی عَشْرَۃَ وَثَلاَثَ عَشْرَۃَ وَحِزْبَ الْمُفَصَّلِ۔ (احمد 4/343۔ ابن ماجہ 1345)",,,8672,,
8673,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ عَبْدِ رَبِّہِ بْنِ سَعِیدٍ الأَنْصَارِیِّ ، عَنِ السَّائِبِ ، عَنْ أَبِیہِ ، عَنْ زَیْدِ بْنِ ثَابِتٍ ، قَالَ : لأَنْ أَقْرَأَ الْقُرْآنَ فِی شَہْرٍ أَحَبُّ إلَیَّ مِنْ أَنْ أَقْرَأَہُ فِی خَمْسَ عَشْرَۃَ ، وَلأَنْ أَقْرَأَہُ فِی خَمْسَ عَشْرَۃَ أَحَبُّ إلَیَّ مِنْ أَنْ أَقْرَأَہُ فِی عَشْرٍ ، وَلأَنْ أَقْرَأَہُ فِی عَشْرٍ أَحَبُّ إلَیَّ مِنْ أَنْ أَقْرَأَہُ فِی سَبْعٍ أقف وَأَدْعُو۔",,,8673,,
8674,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ عُمَارَۃَ ، عَنْ أَبِی الأَحْوَص ، قَالَ : قَالَ عَبْدُ اللہِ : اقَرَإِ الْقُرْآنَ فِی سَبْعٍ وَلاَ تَقْرَأُہُ فِی ثَلاَثٍ۔",,,8674,,
8675,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ الْعَوَّامِ ، عَنِ الْمُسَیَّبِ بْنِ رَافِعٍ ، قَالَ : کَانَ یَخْتِمُ الْقُرْآنَ فِی کُلِّ ثَلاَثٍ ، ثُمَّ یُصْبِحُ الْیَوْمَ الَّذِی یَخْتِمُ فِیہِ صَائِمًا۔",,,8675,,
8676,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ مُسْلِمٍ ، قَالَ : جَائَ رَجُلٌ إلَی مَسْرُوقٍ فَقَالَ : مَا تَقُولُ فِی رَجُلٍ یَقْرَأُ الْقُرْآنَ فِی جُمُعَۃٍ ؟ فَقَالَ مَسْرُوقٌ : حَسَنٌ لَوْ أَخَذْتَ مُصْحَفًا کُلَّ جُمُعَۃٍ فَأَدْخَلْتَہُ بَیْتًا لأَوْشَکَ أَنْ تَمْلأَہ۔",,,8676,,
8677,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنِ ابْنِ سِیرِینَ : أَنَّ تَمِیمًا الدَّارِیَّ قَرَأَ الْقُرْآنَ کُلَّہُ فِی رَکْعَۃٍ۔",,,8677,,
8678,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ مُحَمَّدِ بْنِ إِبْرَاہِیمَ ، عَن عَبْدِ الرَّحْمَنِ بْنِ عُثْمَانَ ، قَالَ : قُمْتُ خَلْفَ الْمَقَامِ أُصَلِّی وَأَنَا أُرِیدُ أَنْ لاَ یَغْلِبَنِی عَلَیْہِ أَحَدٌ تِلْکَ اللَّیْلَۃَ ، فَإِذَا رَجُلٌ مِنْ خَلْفِی یَغْمِزُنِی فَلَمْ أَلْتَفِتْ إلَیْہِ ، ثُمَّ غَمَزَنِی فَالْتَفَتُّ ، فَإِذَا ہُوَ عُثْمَانَ بْنُ عَفَّانَ فَتَنَحَّیْت وَتَقَدَّمَ فَقَرَأَ الْقُرْآنَ کُلَّہُ فِی رَکْعَۃٍ ، ثُمَّ انْصَرَفَ۔",,,8678,,
8679,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ حَمَّادِ بْنِ أَبِی سُلَیْمَانَ ، قَالَ : سَمِعْتُ سَعِیدَ بْنَ جُبَیْرٍ یَقُولُ : قَرَأْتُ الْقُرْآنَ فِی الْکَعْبَۃِ فِی رَکْعَۃٍ۔",,,8679,,
8680,"حَدَّثَنَا وَکِیعٌ ، عَنْ یَزِیدَ ، عَنِ ابْنِ سِیرِینَ ، عَنْ عُثْمَانَ : أَنَّہُ قَرَأَ الْقُرْآنَ فِی رَکْعَۃٍ فِی لَیْلَۃٍ۔",,,8680,,
8681,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ : أَنَّہُ قَرَأَہُ فِی لَیْلَۃٍ بِمَکَّۃَ۔",,,8681,,
8682,حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ نَحْوَہُ۔,,,8682,,
8683,"حَدَّثَنَا مُعْتَمِرٌ، عَنْ أَبِیہِ، عَنْ صَاحِبٍ لَہُ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ، قَالَ: قرَأْتُُ الْقُرْآنَ فِی الْکَعْبَۃِ فِی رَکْعَتَیْنِ۔",,,8683,,
8684,"حَدَّثَنَا عَبِیْدَۃُ بْنُ حُمَیْدٍ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، قَالَ : کَانَ عَلِیٌّ الأَزْدِیُّ یَخْتِمُ الْقُرْآنَ فِی رَمَضَانَ فِی کُلِّ لَیْلَۃٍ۔",,,8684,,
8685,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ مُسْلِمٍ ، عَنْ شُتَیْرِ بْنِ شَکَلٍ ، عَنْ عَلِیٍّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَوْمَ الأَحْزَابِ : شَغَلُونَا عَنِ الصَّلاَۃ الْوُسْطَی صَلاَۃِ الْعَصْرِ مَلأَ اللَّہُ بُیُوتَہُمْ وَقُبُورَہُمْ نَارًا، ثُمَّ صَلاَّہَا بَیْنَ الْعِشَائَیْنِ بَیْنَ الْمَغْرِبِ وَالْعِشَائِ۔ (مسلم 205۔ احمد 1/81)",,,8685,,
8686,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ یَحْیَی بْنِ الْجَزَّارِ ، عَنْ عَلِیٍّ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ عَلَی فُرْضَۃٍ مِنْ فُرَضِ الْخَنْدَقِ ، فَقَالَ : شَغَلُونَا عَنِ الصَّلاَۃ الْوُسْطَی صَلاَۃِ الْعَصْرِ حَتَّی غَابَتِ الشَّمْسُ مَلأَ اللَّہُ بُیُوتَہُمْ وَقُبُورَہُمْ وَبُطُونَہُمْ وَأَجْوَافَہُمْ نَارًا۔ (مسلم 204۔ احمد 1/152)",,,8686,,
8687,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : الصَّلاَۃ الْوُسْطَی صَلاَۃُ الْعَصْرِ۔",,,8687,,
8688,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا أَبُو بِشْرٍ ، قَالَ : أَخْبَرَنی رَجُلٌ ، عَنْ سَالِمِ بْنِ عَبْدِ اللہِ : أَنَّ حَفْصَۃَ أُمَّ الْمُؤْمِنِینَ ، قَالَتْ : الصَّلاَۃ الْوُسْطَی صَلاَۃُ الْعَصْرِ {وَقُومُوا لِلَّہِ قَانِتِینَ} ۔",,,8688,,
8689,"حَدَّثَنَا وَکِیعٌ ، عَنْ دَاوُدَ بْنِ قَیْسٍ ، عَنْ عَبْدِ اللہِ بْنِ رَافِعٍ، عَنْ أُمِّ سَلَمَۃَ: أَنَّہَا اسْتَکْتَبَتْ مُصْحَفًا، فَلَمَّا بَلَغَتْ {حَافِظُوا عَلَی الصَّلَوَاتِ وَالصَّلاَۃ الْوُسْطَی} ، قَالَتِ : اُکْتُبِ الْعَصْرَ۔",,,8689,,
8690,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ مُعَاوِیَۃَ بْنِ صَالِحٍ ، قَالَ : أَخْبَرَنِی مُوسَی بْنُ یَزِیدَ قَالَ : سَأَلْتُ أَبَا أُمَامَۃَ عَنِ الصَّلاَۃ الْوُسْطَی ، فَقَالَ : لاَ أَحْسَبُہَا إِلاَّ الصُّبْحَ۔",,,8690,,
8691,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزِّبْرِقَانِ ، عَنْ زُہْرَۃَ ، قَالَ : کُنَّا جُلُوسًا فِی الْمَسْجِدِ مَعَ زَیْدِ بْنِ ثَابِتٍ فَسُئِلَ عَنِ صَلاَۃ الْوُسْطَی فَقَالَ : ہِیَ الظُّہْرُ ، فَمَرَّ أُسَامَۃُ فَسُئِلَ فَقَالَ : ہِیَ الظُّہْرُ ، کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّیہَا بِالْہَجِیرِ۔ (نسائی 356۔ احمد 5/206)",,,8691,,
8692,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا عَوْفٌ ، عَنْ أَبِی رَجَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : ہِیَ صَلاَۃُ الْفَجْرِ۔",,,8692,,
8693,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا عَبْدُ الْحَمِیدِ بْنُ جَعْفَرٍ ، عَمَّنْ حَدَّثَہُ عَنْ مَنْظُورِ بْنِ أَبِی ثَعْلَبَۃَ ، عَنْ زَیْدِ بْنِ ثَابِتٍ ، قَالَ : ہِیَ الظُّہْرُ۔",,,8693,,
8694,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا الْعَوَّامُ ، عَنِ الأَنْصَارِیِّ ، عَنْ زَیْدِ بْنِ ثَابِتٍ : أَنَّہُ کَانَ یَقُولُ ذَلِکَ۔",,,8694,,
8695,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ عَمْرٍو ، عَنِ الْقَاسِمِ ، عَنْ عَائِشَۃَ ، قَالَتِ : الصَّلاَۃ الْوُسْطَی صَلاَۃُ الْعَصْرِ۔",,,8695,,
8696,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ مُحَمَّدِ بْنِ طَلْحَۃَ ، عَنْ زُبَیْد ، عَنْ مُرَّۃَ ، عَنْ عَبْدِ اللہِ ، قَالَ : ہِیَ الْعَصْرُ۔",,,8696,,
8697,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَاصِمٍ ، عَنْ زِرِّ بْنِ حُبَیْشٍ : أَنَّ عَبِیْدَۃَ سَأَلَ عَلِیًّا عَنِ الصَّلاَۃ الْوُسْطَی ؟ فَذَکَرَ عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَحْوَ ہَذَا الْحَدِیثِ۔ (بخاری 2931۔ ابوداؤد 412)",,,8697,,
8698,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : الصَّلاَۃ الْوُسْطَی صَلاَۃُ الْعَصْرِ۔",,,8698,,
8699,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عُمَیْرِ بْنِ سَعِیدٍ ، قَالَ : سَمِعْتُ ابْنَ عَبَّاسٍ یَقُولُ : {حَافِظُوا عَلَی الصَّلَوَاتِ وَالصَّلاَۃ الْوُسْطَی} صَلاَۃِ الْعَصْرِ۔",,,8699,,
8700,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ مِسْعَرٍ ، عَنْ سَلَمَۃَ ، عَنْ أَبِی الأَحْوَص ، عَنْ عَلِیٍّ ، قَالَ : ہِیَ الَّتِی فَرَّطَ فِیہَا ابْنُ دَاوُد وَہِیَ الْعَصْرُ۔",,,8700,,
8701,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : الصَّلاَۃ الْوُسْطَی الَّتِی فَرَّطَ فِیہَا سُلَیْمَانُ صَلاَۃُ الْعَصْرِ۔",,,8701,,
8702,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَاصِمٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : سُئِلَ شُرَیْحٌ عَنِ الصَّلاَۃ الْوُسْطَی فَقَالَ : حَافِظُوا عَلِیہَا تُصِیبُوہَا۔",,,8702,,
8703,"حَدَّثَنَا جَعْفَرُ بْنُ عَوْنٍ ، عَنْ أَبِی حَیَّانَ ، عَن أَبِیہ ، عَن رَبِیع بن خُثَیم : سُئِلَ عَنِ الصَّلاَۃ الْوُسْطَی ، فَقَالَ : ہِیَ وَاحِدَۃٌ مِنْہُنَّ فَحَافِظُوا عَلَیْہَا۔",,,8703,,
8704,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا أَبُو بِشْرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : ہِیَ الْعَصْرُ۔",,,8704,,
8705,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، عَنْ عُبَیْدِ بْنِ عُمَیْرٍ ، أَنَّہُ کَانَ یَقُولُ : {حَافِظُوا عَلَی الصَّلَوَاتِ وَالصَّلاَۃ الْوُسْطَی} صَلاَۃِ الْعَصْرِ۔\n\nقَالَ : وَکَانَ عَطَائٌ یَرَی أَنَّ الصَّلاَۃ الْوُسْطَی صَلاَۃُ الْغَدَاۃِ۔",,,8705,,
8706,"حَدَّثَنَا شَبَابَۃُ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، قَالَ : حَدَّثَنَا حَیَّانُ الأَزْدِیُّ ، قَالَ : سَمِعْتُ ابْنَ عُمَرَ وَسُئِلَ عَنِ الصَّلاَۃ الْوُسْطَی وَقِیلَ لَہُ : إنَّ أَبَا ہُرَیْرَۃَ یَقُولُ : ہِیَ الْعَصْرُ ، فَقَالَ : إنَّ أَبَا ہُرَیْرَۃَ یُکْثِرُ ، ابْنُ عُمَر یَقُولُ : ہِیَ الصُّبْحُ۔",,,8706,,
8707,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ سَعْدِ بْنِ إِبْرَاہِیمَ ، عَن حَفْصٍ ، عَنْ عَاصِمٍ ، عَنْ زَیْدِ بْنِ ثَابِتٍ ۔ وَعَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنِ ابْنِ عُمَرَ ، عَنْ زَیْدِ بْنِ ثَابِتٍ ، قَالَ : الصَّلاَۃ الْوُسْطَی صَلاَۃُ الظُّہْرِ۔",,,8707,,
8708,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ عَبْدِ الرَّحْمَنِ الْخَیَّاطِ ، قَالَ : سَمِعْتُ عِکْرِمَۃَ یَقُولُ : ہِیَ الظُّہْرُ قَبْلَہَا صَلاَتَانِ وَبَعْدَہَا صَلاَتَانِ۔",,,8708,,
8709,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ حَبِیبٍ ، عَنْ عَمْرِو بْنِ ہَرِمٍ ، عَنْ جَابِرِ بْنِ زَیْدٍ ، قَالَ : ہِیَ الصُّبْحُ۔",,,8709,,
8710,"حَدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ ، قَالَ : الصَّلاَۃ الْوُسْطَی صَلاَۃُ الْعَصْرِ۔",,,8710,,
8711,حَدَّثَنَا شَبَابَۃُ ، عَنْ وَرْقَائَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ {حَافِظُوا عَلَی الصَّلَوَاتِ وَالصَّلاَۃ الْوُسْطَی} الصُّبْحِ۔,,,8711,,
8712,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا ہَمَّامٌ ، قَالَ : حَدَّثَنَا قَتَادَۃُ ، عَنِ الْحَسَنِ ، عَنْ سَمُرَۃََ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : الصَّلاَۃ الْوُسْطَی صَلاَۃُ الْعَصْرِ۔ (ترمذی 182۔ احمد 5/12)",,,8712,,
8713,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا وَہْبٌ ، قَالَ : حَدَّثَنَا خَالِدٌ ، عَنْ أَبِی قِلاَبَۃَ ، عَنْ أَبِی الْمُہَلَّبِ ، عَنْ أُبَیِّ بْنِ کَعْبٍ ، قَالَ : الصَّلاَۃ الْوُسْطَی صَلاَۃُ الْعَصْرِ۔",,,8713,,
8714,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ، عَنِ التَّیْمِیِّ، عَنْ أَبِی صَالِحٍ، عَنْ أَبِی ہُرَیْرَۃَ، قَالَ: صَلاَۃ الْوُسْطَی صَلاَۃُ الْعَصْرِ۔",,,8714,,
8715,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنِ التَّیْمِیِّ ، عَنْ قَتَادَۃَ ، عَنْ أَبِی أَیُّوبَ ، عَنْ عَائِشَۃَ ، قَالَتِ : صَلاَۃ الْوُسْطَی صَلاَۃُ الْعَصْرِ۔",,,8715,,
8716,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ مُحَمَّدِ بْنِ طَلْحَۃَ ، عَنْ زُبَیْدٍ ، عَنْ مُرَّۃَ ، عَنْ عَبْدِ اللہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : ہِیَ الْعَصْرُ۔ (مسلم 206۔ احمد 1/392)",,,8716,,
8717,"حَدَّثَنَا وَکِیعٌ ، عَنْ قُرَّۃَ ، قَالَ : حدَّثَنَا أَبُو رَجَائٍ ، قَالَ : صَلَّیْتُ مَعَ ابْنِ عَبَّاسٍ الصُّبْحَ فِی مَسْجِدِ الْبَصْرَۃِ ، فَقَالَ : ہَذِہِ الصَّلاَۃ الْوُسْطَی۔",,,8717,,
8718,"حَدَّثَنَا عَبْدُ الْعَزِیزِ بْنُ مُحَمَّدٍ الدَّرَاوَرْدِیُّ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، قَالَ سَمِعْتُ ابْنُ عُمَرَ یَقُولُ : الْوُسْطَی صَلاَۃُ الصُّبْحِ۔",,,8718,,
8719,"سَمِعْتُ وَکِیعًا یَقُولُ : قَالَ سُفْیَانُ فِی رَجُلٍ زَالَتِ الشَّمْسُ وَہُوَ فِی الْحَضَرِ ، ثُمَّ خَرَجَ إلَی السَّفَرِ کَیْفَ یُصَلِّی ، قَالَ : إِنْ کَانَ فِی وَقْتِ الظُّہْرِ صَلَّی رَکْعَتَیْنِ۔\n\nوَقَالَ حَسَنُ بْنُ صَالِحٍ : إذَا زَالَتَ لہ الشَّمْسُ ہَاہُنَا صَلَّی فِی السَّفَرِ أَرْبَعًا۔\n\nقَالَ : وَقَالَ سُفْیَانُ فِی مُسَافِرٍ دَخَلَ مَعَ مُقِیمٍ فَصَلَّی مَعَہُ رَکْعَۃً ، ثُمَّ رَأَی شَیْئًا فَتَکَلَّمَ فَصَلَّی الإِمَام فَقَالَ : یُعِیدُ الْمُسَافِرُ رَکْعَتَیْنِ ، ثُمَّ یَرْجِعُ إلَی الأَصْلِ الَّذِی کَانَ عَلَیْہِ۔\n\nوَقَالَ الْحَسَنُ بْنُ صَالِحٍ : یُصَلِّی أَرْبَعًا لأَنَّہُ قَدْ أَوْجَبَہَا عَلَی نَفْسِہِ۔",,,8719,,
8720,"حَدَّثَنَا وَکِیعٌ ، قَالَ : سَمِعْتُ سُفْیَانَ یَقُولُ فِی رَجُلٍ دَخَلَ مَعَ الإِمَامِ یَوْمَ الْجُمُعَۃِ فَرَعَفَ فَذَہَبَ فَتَوَضَّأَ ثُمَّ جَائَ وَقَدْ صَلَّی الإِمَام ، وَلَمْ یَتَکَلَّمِ الرَّجُلُ ، قَالَ سُفْیَانُ : یُصَلِّی صَلاَۃَ الإِمَام رَکْعَتَیْنِ۔\n\nوَقَالَ الْحَسَنُ بْنُ صَالِحٍ : یُصَلِّی أَرْبَعًا إِلاَّ أَنْ یَکُونَ قَدْ صَلَّی مَعَہُ رَکْعَۃً",,,8720,,
8721,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنِ الْحَکَمِ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ کَعْبِ بْنِ عُجْرَۃَ ، قَالَ : قلْنَا : یَا رَسُولَ اللہِ قَدْ عَلِمْنَا کَیْفَ السَّلاَمَ عَلَیْک فَکَیْفَ الصَّلاَۃ عَلَیْک ؟ قَالَ : قُولُوا اللَّہُمَّ صَلِّ عَلَی مُحَمَّدٍ وَعَلَی آلِ مُحَمَّدٍ کَمَا صَلَّیْتَ عَلَی إبْرَاہِیمَ وَآلِ إبْرَاہِیمَ إنَّکَ حَمِیدٌ مَجِیدٌ ، وَبَارِکْ عَلَی مُحَمَّدٍ وَعَلَی آلِ مُحَمَّدٍ کَمَا بَارَکْتَ عَلَی إبْرَاہِیمَ وَآلِ إبْرَاہِیمَ إنَّکَ حَمِیدٌ مَجِیدٌ۔ (بخاری 6357۔ مسلم 66)",,,8721,,
8722,حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، عَنْ کَعْبِ بْنِ عُجْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِنَحْوِہِ۔ (احمد 4/244),,,8722,,
8723,"حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ ، عَنْ عَبْدِ اللہِ بْنِ جَعْفَرٍ ، عَنْ یَزِیدَ بْنِ الْہَادِ ، عَنْ عَبْدِ اللہِ بْنِ خَبَّابٍ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ، قَالَ : قلْنَا : یَا رَسُولَ اللہِ ہَذَا السَّلاَمُ عَلَیْک قَدْ عَرَفْنَاہُ فَکَیْفَ الصَّلاَۃ ؟ قَالَ : قُولُوا : اللَّہُمَّ صَلِّ عَلَی مُحَمَّدٍ عَبْدِکَ وَرَسُولِکَ کَمَا صَلَّیْتَ عَلَی إبْرَاہِیمَ وَبَارِکْ عَلَی مُحَمَّدٍ کَمَا بَارَکْتَ عَلَی آلِ إبْرَاہِیمَ۔ (بخاری 6358۔ ابن ماجہ 903)",,,8723,,
8724,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، عَنْ مُجَمِّعِ بْنِ یَحْیَی ، عَنْ عُثْمَانَ بْنِ مَوْہَبٍ ، عَنْ مُوسَی بْنِ طَلْحَۃَ ، عَنْ أَبِیہِ ، قَالَ : قلْنَا : یَا رَسُولَ اللہِ قَدْ عَلِمْنَا السَّلاَمَ عَلَیْک فَکَیْفَ الصَّلاَۃ ؟ قَالَ : قُولُوا : اللَّہُمَّ صَلِّ عَلَی مُحَمَّدٍ وَعَلَی آلِ مُحَمَّدٍ کَمَا صَلَّیْتَ عَلَی إبْرَاہِیمَ وَآلِ إبْرَاہِیمَ إنَّکَ حَمِیدٌ مَجِیدٌ ، وَبَارِکْ عَلَی مُحَمَّدٍ وَعَلَی آلِ مُحَمَّدٍ ، کَمَا بَارَکْتَ عَلَی إبْرَاہِیمَ وَعَلَی آلِ إبْرَاہِیمَ إنَّکَ حَمِیدٌ مَجِیدٌ۔ (نسائی 1213۔ احمد 1/162)",,,8724,,
8725,"حَدَّثَنَا أَحْمَدُ بْنُ عَبْدِ اللہِ ، قَالَ : حدَّثَنَا زُہَیْرٌ ، قَالَ : حَدَّثَنَا مُحَمَّدُ بْنُ إِسْحَاقَ ، قَالَ : حَدَّثَنِی مُحَمَّدُ بْنُ إبْرَاہِیمَ بْنِ الْحَارِثِ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ اللہِ بْنِ زَیْدٍ ، عَنْ عُقْبَۃَ بْنِ عَمْرٍو ، قَالَ : أَتَی رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجُلٌ حَتَّی جَلَسَ بَیْنَ یَدَیْہِ ، فَقَالَ : یَا رَسُولَ اللہِ أَمَّا السَّلاَمُ عَلَیْک فَقَدْ عَلِمْنَاہُ۔\n\nوَأَمَّا الصَّلاَۃ فَأَخْبِرْنَا بِہَا کَیْفَ نُصَلِّی عَلَیْک ؟ قَالَ : فَصَمَتَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَتَّی وَدِدْنَا أَنَّ الرَّجُلَ الَّذِی سَأَلَہُ لَمْ یَسْأَلْہُ ، ثُمَّ قَالَ : إذَا صَلَّیْتُمْ عَلَیَّ فَقُولُوا : اللَّہُمَّ صَلِّ عَلَی مُحَمَّدٍ النَّبِیِّ الأُمِّیِّ وَعَلَی آلِ مُحَمَّدٍ کَمَا صَلَّیْتَ عَلَی إبْرَاہِیمَ وَعَلَی آلِ إبْرَاہِیمَ ، وَبَارِکْ عَلَی مُحَمَّدٍ النَّبِیِّ الأُمِّیِّ وَعَلَی آلِ مُحَمَّدٍ کَمَا بَارَکْتَ عَلَی إبْرَاہِیمَ وَعَلَی آلِ إبْرَاہِیمَ إنَّکَ حَمِیدٌ مَجِیدٌ۔ (مسلم 65۔ ابوداؤد 973)",,,8725,,
8726,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یُونُسُ وَمَنْصُورٌ وَعَوْفٌ ، عَنِ الْحَسَنِ : قَالُوا یَا رَسُولَ اللہِ قَدْ عَلِمْنَا السَّلاَمَ عَلَیْک فَکَیْفَ الصَّلاَۃ عَلَیْک ؟ قَالَ : قُولُوا اللَّہُمَّ اجْعَلْ صَلَوَاتِکَ وَبَرَکَاتِکَ عَلَی آلِ مُحَمَّدٍ کَمَا جَعَلْتہَا عَلَی آلِ إبْرَاہِیمَ إنَّکَ حَمِیدٌ مَجِیدٌ۔",,,8726,,
8727,"حَدَّثَنَا ہُشَیْمٌ ، أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إبْرَاہِیمَ : أَنَّہُ کَانَ إذَا سَلَّمَ أَقْبَلَ عَلَیْنَا بِوَجْہِہِ وَہُوَ یُہَلِّلُ یَقُولُ : لاَ إلَہَ إِلاَّ اللَّہُ وَحْدَہُ لاَ شَرِیکَ لَہُ۔",,,8727,,
8728,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی عَاصِمٍ الثَّقَفِیِّ ، عَنْ قَیْسِ بْنِ مُسْلِمٍ ، عَنْ طَارِقِ بْنِ شِہَابٍ ، قَالَ : صَلَّی بِنَا عَلِیٌّ الْعَصْرَ ، فَلَمَّا سَلَّمَ أَقْبَلَ عَلَیْنَا بِوَجْہِہِ۔",,,8728,,
8729,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ عُمَیْرِ بْنِ سَعِیدٍ ، قَالَ : سَمِعْتُ أَبَا مُوسَی قَرَأَ فِی الْجُمُعَۃِ بِـ {سَبِّحِ اسْمَ رَبِّکَ الأَعْلَی} فَقَالَ : سُبْحَانَ رَبِّی الأَعْلَی۔",,,8729,,
8730,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ مِسْعَرٍ ، عَنْ عُمَیْرِ بْنِ سَعِیدٍ ، قَالَ : صَلَّیْتُ مَعَ أَبِی مُوسَی الْجُمُعَۃَ فَقَرَأَ بِـ {سَبِّحِ اسْمَ رَبِّکَ الأَعْلَی} فَقَالَ : سُبْحَانَ رَبِّی الأَعْلَی وَہُوَ فِی الصَّلاَۃ۔",,,8730,,
8731,"حَدَّثَنَا عَبْدَۃُ ووَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ السُّدِّیِّ ، عَنْ عَبْدِ خَیْرٍ : أَنَّ عَلِیًّا قَرَأَ {سَبِّحِ اسْمَ رَبِّکَ الأَعْلَی} فَقَالَ : سُبْحَانَ رَبِّی الأَعْلَی ، قَالَ عَبْدَۃُ : وَہُوَ فِی الصَّلاَۃ۔",,,8731,,
8732,"حَدَّثَنَا عَبْدَۃُ ، عَنْ ہِشَامٍ ، قَالَ : سَمِعْتُ ابْنَ الزُّبَیْرِ یَقْرَأُ {سَبِّحِ اسْمَ رَبِّکَ الأَعْلَی} فَقَالَ : سُبْحَانَ رَبِّی الأَعْلَی وَہُوَ فِی الصَّلاَۃ۔",,,8732,,
8733,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، قَالَ : سَمِعْتُ ابْنَ الزُّبَیْرِ یَقْرَأُ {سَبِّحِ اسْمَ رَبِّکَ الأَعْلَی} فَقَالَ : سُبْحَانَ رَبِّی الأَعْلَی۔",,,8733,,
8734,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِیہِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ : أَنَّہُ قَرَأَ : {سَبِّحِ اسْمَ رَبِّکَ الأَعْلَی} فَقَالَ : سُبْحَانَ رَبِّی الأَعْلَی۔",,,8734,,
8735,حَدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ نَجِیحٍ ، عَنْ أَبِی الْمُتَوَکِّلِ ، عَنِ ابْنِ الزُّبَیْرِ مِثْلَہُ۔,,,8735,,
8736,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا عَبْدُ اللہِ بْنُ الْوَلِیدِ ، عَنْ عُبَیْدِ بْنِ الْحَسَنِ ، قَالَ : کَانَ عُرْوَۃُ بْنُ الْمُغِیرَۃِ إذَا أَمَّ النَّاسَ ہَاہُنَا فَقَرَأَ {سَبِّحِ اسْمَ رَبِّکَ الأَعْلَی} ، قَالَ : سُبْحَانَ رَبِّی الأَعْلَی۔",,,8736,,
8737,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ الأَصْبَغِ بْنِ زَیْدٍ ، عَنِ الْقَاسِمِ بْنِ أَبِی أَیُّوبَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ : أَنَّہُ کَانَ إذَا قَرَأَ : {سَبِّحِ اسْمَ رَبِّکَ الأَعْلَی} ، قَالَ : سُبْحَانَ رَبِّی الأَعْلَی۔",,,8737,,
8738,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ الْجُرَیرِیِّ ، عَنْ أَبِی نَضْرَۃَ ، عَنْ عُمَر ، أَنَّہُ کَانَ إذَا قَرَأَ : {سَبِّحِ اسْمَ رَبِّکَ الأَعْلَی} ، قَالَ سُبْحَانَ رَبِّی الأَعْلَی۔",,,8738,,
8739,"حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ مُسْلِمٍ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، عَنْ عَطَائٍ ، قَالَ : إذَا کَانَ لَکَ وِتْرٌ وَلِلإِمَامِ شَفْعٌ فَلاَ تَشَہُّدَ۔",,,8739,,
8740,"حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ مُسْلِمٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنِ ابْنِ شِہَابٍ قَالَ : تَتَشَہَّدُ۔",,,8740,,
8741,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ : فِی الرَّجُلِ یُدْرِکُ رَکْعَۃً مَعَ الإِمَامِ ، قَالَ : یَتَشَہَّدُ۔",,,8741,,
8742,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ مُحَمَّدِ بْنِ مُسْلِمٍ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، عَنْ عَطَائٍ : فِی الرَّجُلِ یُدْرِکُ مَعَ الإِمَامِ وِتْرًا مِنَ الصَّلاَۃ ، قَالَ : لاَ یَتَشَہَّدُ۔\n\nوَقَالَ عَمْرُو بْنُ دِینَارٍ : وأَنَا أَرَی ذَلِکَ۔",,,8742,,
8743,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ مَالِکِ بْنِ أَنَسٍ ، قَالَ : سَأَلْتُ نَافِعًا وَابْنَ شِہَابٍ عَنِ الرَّجُلِ یُسْبَقُ بِرَکْعَۃٍ فَیَجْلِسُ مَعَ الإِمَامِ ؟ قَالاَ : یَتَشَہَّدُ۔",,,8743,,
8744,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ أَبِی لَیْلَی ، عَنْ عَطَائٍ ، عَنْ جَابِرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ أَکَلَ مِنْ ہَذِہِ الْبَقْلَۃِ الْخَبِیثَۃِ فَلاَ یَقْرَبَنَّ مَسْجِدَنَا ، أَوِ الْمَسْجِدَ۔",,,8744,,
8745,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا عُبَیْدُ اللہِ بْنُ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ أَکَلَ ہَذِہِ الْبَقْلَۃَ فَلاَ یَقْرَبَنَّ الْمَسْجِدَ حَتَّی یَذْہَبَ رِیحُہَا ، یَعْنِی الثُّومَ۔ (بخاری 4215۔ مسلم 69)",,,8745,,
8746,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنِ الْحَکَمِ بْنِ عَطِیَّۃَ ، عَنْ أَبِی الرَّبَابِ ، عَنْ مَعْقِلِ بْنِ یَسَارٍ ، قَالَ : سَمِعْتُہُ یَقُولُ : کُنَّا مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقَالَ : مَنْ أَکَلَ مِنْ ہَذِہِ الشَّجَرَۃِ فَلاَ یَقْرَبَنَّ مُصَلاَّنَا ، یَعْنِی الثُّومَ۔ (بخاری 264۔ احمد 5/26)",,,8746,,
8747,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُلَیْمَانُ بْنُ الْمُغِیرَۃِ ، عَنْ حُمَیْدِ بْنِ ہِلاَلٍ الْعَدَوِیِّ ، عَنْ أَبِی بُرْدَۃَ ، عَنِ الْمُغِیرَۃِ بْنِ شُعْبَۃَ ، قَالَ : أَکَلْتُ ثُومًا ، ثُمَّ أَتَیْتُ مُصَلَّی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَوَجَدْتُہُ قَدْ سَبَقَنِی بِرَکْعَۃٍ ، فَلَمَّا قُمْتُ أَقْضِی وَجَدَ رِیحَ الثُّومِ ، فَقَالَ : مَنْ أَکَلَ مِنْ ہَذِہِ الْبَقْلَۃِ فَلاَ یَقْرَبَنَّ مَسْجِدَنَا حَتَّی یَذْہَبَ رِیحُہَا ، وقَالَ مُغِیرَۃُ ، فَلَمَّا قَضَیْتُ الصَّلاَۃ أَتَیْتُہُ فَقُلْتُ : یَا رَسُولَ اللہِ إنَّ لِی عُذْرًافَنَاوِلْنی یَدَکَ ، قَالَ : فَوَجَدْتُہُ وَاللَّہِ سَہْلاً ، فَنَاوَلَنِی یَدَہُ فَأَدْخَلْتہَا فِی کُمِّی إلَی صَدْرِی فَوَجَدَہُ مَعْصُوبًا فَقَالَ : إنَّ لَکَ عُذْرًا۔ (ابوداؤد 3822۔ ابن حبان 2095)",,,8747,,
8748,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا یُونُسُ بنِ أَبِی إِسْحَاقَ ، عَنْ عُمَیْرِ بْنِ قُمَیمٍ التَّغْلِبِیِّ ، عَنْ شَرِیکِ بْنِ حَنْبَلٍ الْعَبْسِیِّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ أَکَلَ مِنْ ہَذِہِ الْبَقْلَۃِ الْخَبِیثَۃِ فَلاَ یَقْرَبَنَّ مَسْجِدَنَا ، یَعْنِی الثُّومَ۔",,,8748,,
8749,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ سَالِمِ بْنِ أَبِی الْجَعْدِ الْغَطَفَانِیِّ ، عَنْ مَعْدَانَ بْنِ أَبِی طَلْحَۃَ الْیَعْمُرِیِّ : أَنَّ عُمَرَ بْنَ الْخَطَّابِ قَامَ یَوْمَ جُمُعَۃٍ خَطِیبًا ، أَوْ خَطَبَنَا یَوْمَ جُمُعَۃٍ ، فَقَالَ : یَا أَیُّہَا النَّاس إنَّکُمْ تَأْکُلُونَ شَجَرَتَیْنِ لاَ أُرَاہُمَا إِلاَّ خَبِیثَتَیْنِ ہَذَا الثُّومَ وَہَذَا الْبَصَلَ ، لَقَدْ کُنْتُ أَرَی الرَّجُلَ عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُوجَدُ رِیحُہُ مِنْہُ فَیُؤْخَذُ بِیَدِہِ حَتَّی یُخْرَجَ بِہِ إلَی الْبَقِیعِ ، فَمَنْ کَانَ آکِلَہُمَا لاَبُدَّ فَلْیُمِتْہُمَا طَبْخًا۔ (مسلم 397۔ احمد 1/27)",,,8749,,
8750,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ أَبِی یَزِیدَ ، عَنْ أَبِیہِ ، عَنْ أُمِّ أَیُّوبَ ، قَالَتْ : صَنَعْتُ لِرَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ طَعَامًا فِیہِ مِنْ بَعْض الْبُقُولِ فَلَمْ یَأْکُلْ مِنْہُ ، وَقَالَ : إنِّی أَکْرَہُ أَنْ أُوذِیَ صَاحِبِی۔ (ترمذی 1810۔ احمد 433)",,,8750,,
8751,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، قَالَتْ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : تَحَرَّوْا لَیْلَۃَ الْقَدْرِ فِی الْعَشْرِ الأَوَاخِرِ مِنْ شَہْرِ رَمَضَانَ۔ (بخاری 2020۔ ترمذی 792)",,,8751,,
8752,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عُیَیْنَۃُ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِیہِ ، عَنْ أَبِی بَکْرَۃَ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : الْتَمِسُوا لَیْلَۃَ الْقَدْرِ فِی الْعَشْرِ الأَوَاخِرِ مِنْ شَہْرِ رَمَضَانَ ؛ لِتِسْعٍ بَقَیْنَ ، أَوْ لِسَبْعٍ ، أَوْ لِخَمْسٍ ، أَوْ لِثَلاَثٍ ، أَوْ لآخِرِ لَیْلَۃٍ۔ (ترمذی 794۔ احمد 5/36)",,,8752,,
8753,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَبْدِ اللہِ بْنِ دِینَارٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : تَحَرَّوْا لَیْلَۃَ الْقَدْرِ فِی الْعَشْرِ الأَوَاخِرِ مِنْ شَہْرِ رَمَضَانَ۔ (مسلم 206۔ ابوداؤ9 1380)",,,8753,,
8754,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ جَبَلَۃَ ، وَمُحَارِبٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : تَحَیَّنُوا لَیْلَۃَ الْقَدْرِ فِی الْعَشْرِ الأَوَاخِرِ مِنْ شَہْرِ رَمَضَانَ۔ (مسلم 814۔ احمد 2/81)",,,8754,,
8755,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ الأَوْزَاعِیِّ ، عَنْ مَرْثَدِ بْنِ أَبِی مَرْثَدٍ ، عَنْ أَبِیہِ ، قَالَ : کُنْتُُ مَعَ أَبِی ذَرٍّ عِنْدَ الْجَمْرَۃِ الْوُسْطَی ، فَسَأَلْتُہُ عَنْ لَیْلَۃِ الْقَدْرِ ؟ فَقَالَ : کَانَ أَسْأَلَ النَّاسِ عَنْہَا رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنَا ، قُلْتُ : یَا رَسُولَ اللہِ ، لَیْلَۃُ الْقَدْرِ کَانَتْ تَکُونُ عَلَی عَہْدِ الأَنْبِیَائِ ، فَإِذَا ذَہَبُوا رُفِعَتْ ؟ قَالَ: لاَ ، وَلَکِنْ تَکُونُ إِلَی یَوْمِ الْقِیَامَۃِ ، قَالَ : قُلْتُ : یَا رَسُولَ اللہِ ، فَأَخْبِرْنَا بِہَا ، قَالَ : لَوْ أُذِنَ لِی فِیہَا لأَخْبَرْتُکُمْ ، وَلَکِنِ الْتَمِسُوہَا فِی أَحَدِ السَّبْعَیْنِ ، ثُمَّ لاَ تَسْأَلْنِی عَنْہَا بَعْدَ مَقَامِی ، أَوْ مَقَامِکَ ہَذَا ، ثُمَّ أَخَذَ فِی حَدِیثٍ ، فَلَمَّا انْبَسَطَ قُلْتُ : یَا رَسُولَ اللہِ ، أَقْسَمْتُ عَلَیْک إِلاَّ حَدَّثْتنِی بِہَا ، قَالَ أَبُو ذَرٍّ : فَغَضِبَ عَلَیَّ غَضْبَۃً لَمْ یَغْضَبْ عَلَیَّ قَبْلَہَا ، وَلاَ بَعْدَہَا مِثْلَہَا۔ (نسائی 3427۔ ابن خزیمۃ 2170)",,,8755,,
8756,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی یَعْفُورٍ ، عَنْ أَبِی الصَّلْتِ ، عَنْ أَبِی عَقْرَبٍ الأَسَدِیِّ ، قَالَ : أَتَیْنَا ابْنَ مَسْعُودٍ فِی دَارِہِ فَوَجَدْنَاہُ فَوْقَ الْبَیْتِ فَسَمِعْنَاہُ یَقُولُ قَبْلَ أَنْ یَنْزِلَ : صَدَقَ اللَّہُ وَرَسُولُہُ ، فَقُلْنَا لَہُ : سَمِعْنَاکَ تَقُولُ قَبْلَ أَنْ تَنْزِلَ : صَدَقَ اللَّہُ وَرَسُولُہُ ، فَقَالَ : لَیْلَۃَ الْقَدْرِ فِی السَّبْعِ مِنَ النِّصْفِ الآخِرِ ، وَذَلِکَ أَنَّ الشَّمْسَ تَطْلُعُ یَوْمَئِذٍ بَیْضَائَ لاَ شُعَاعَ لَہَا ، فَنَظَرْتُ إلَی الشَّمْسِ فَرَأَیْتہَا کَمَا حُدِّثْتُ فَکَبَّرْتُ۔ (احمد 1/406۔ طیالسی 394)",,,8756,,
8757,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ سِمَاکٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : أُتِیتُ وَأَنَا نَائِمٌ فِی رَمَضَانَ فَقِیلَ لِی : إنّ اللَّیْلَۃَ لَیْلَۃُ الْقَدْرِ ، قَالَ : فَقُمْتُ وَأَنَا نَاعِسٌ فَتَعَلَّقْتُ بِبَعْضِ أَطْنَابِ فُسْطَاطِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَأَتَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ یُصَلِّی ، فَنَظَرْتُ فِی اللَّیْلَۃِ فَإِذَا ہِیَ لَیْلَۃُ ثَلاَثٍ وَعِشْرِینَ ، قَالَ : وَقَالَ ابْنُ عَبَّاسٍ : إنَّ الشَّیْطَانَ یَطْلُعُ مَعَ الشَّمْسِ کُلَّ لَیْلَۃٍ إِلاَّ لَیْلَۃَ الْقَدْرِ ، وَذَلِکَ أَنَّہَا تَطْلُعُ یَوْمَئِذٍ بَیْضَائَ لاَ شُعَاعَ لَہَا۔ (احمد 1/255۔ طبرانی 11777)",,,8757,,
8758,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ قَنَانِ بْنِ عَبْدِ اللہِ النَّہْمِیِّ ، قَالَ : سَأَلْتُ زِرًّا عَنْ لَیْلَۃِ الْقَدْرِ ؟ فَقَالَ : کَانَ عُمَرُ وَحُذَیْفَۃُ وَنَاسٌ مِنْ أَصْحَابِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لاَ یَشُکُّونَ أَنَّہَا لَیْلَۃُ سَبْعٍ وَعِشْرِینَ ، تَبْقَی ثَلاَثٌ ، قَالَ : قَالَ زِرٌّ : فَوَاصلہَا۔",,,8758,,
8759,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنِ ابْنِ أَبِی خَالِدٍ ، عَنْ زِرٍّ ، قَالَ : سَمِعْتُ أُبَیَّ بْنَ کَعْبٍ یَقُولُ : لَیْلَۃُ الْقَدْرِ لَیْلَۃُ سَبْعٍ وَعِشْرِینَ",,,8759,,
8760,"حَدَّثَنَا عَبْدُ الأَعْلَی ، وَابْنُ نُمَیْرٍ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ یَزِیدَ بْنِ أَبِی حَبِیبٍ ، عَنْ مَرْثَدِ بْنِ عَبْدِ اللہِ الْیَزَنِیِّ ، عَنِ الصُّنَابِحِیِّ ، قَالَ : سَأَلْتُ بِلاَلاً عَنْ لَیْلَۃِ الْقَدْرِ ، قَالَ : لَیْلَۃُ الْقَدْرِ ثَلاَثٍ وَعِشْرِینَ۔",,,8760,,
8761,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ عَاصِمِ بْنِ کُلَیْبٍ ، عَنْ أَبِیہِ ، عَنِ ابْنِ عَبَّاسٍ ، عَنْ عُمَرَ ، قَالَ : لَقَدْ عَلِمْتُمْ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ فِی لَیْلَۃِ الْقَدْرِ : اُطْلُبُوہَا فِی الْعَشْرِ الأَوَاخِرِ وِتْرًا۔ (احمد 1/43۔ ابویعلی 165)",,,8761,,
8762,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عَنْ عَبْدِ اللہِ ، قَالَ : تَحَرَّوْا لَیْلَۃَ الْقَدْرِ لِسَبْعٍ تَبْقَی ، تَحَرَّوْہَا لِتِسْعٍ تَبْقَی ، تَحَرَّوْہَا لإِحْدَی عَشْرَۃَ تَبْقَی صَبِیحَۃَ بَدْرٍ ، فَإِنَّ الشَّمْسَ تَطْلُعُ کُلَّ یَوْمٍ بَیْنَ قَرْنَیْ شَیْطَانٍ إِلاَّ صَبِیحَۃَ بَدْرٍ فَإِنَّہَا تَطْلُعُ بَیْضَائَ لَیْسَ لَہَا شُعَاعٌ۔",,,8762,,
8763,"حَدَّثَنَا عَمْرُو بْنُ طَلْحَۃَ ، عَنْ أَسْبَاطِ بْنِ نَصْرٍ ، عَنْ سِمَاکٍ ، عَنْ جَابِرِ بْنِ سَمُرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : اُطْلُبُوا لَیْلَۃَ الْقَدْرِ فِی الْعَشْرِ الأَوَاخِرِ مِنْ رَمَضَانَ۔ (طبرانی 1941)",,,8763,,
8764,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ ہُبَیْرَۃَ ، عَنْ عَلِیٍّ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا دَخَلَتِ الْعَشْرُ الأَوَاخِرُ أَیْقَظَ أَہْلَہُ ، وَرَفَعَ الْمِئْزَرَ ۔ قِیلَ لأَبِی بَکْرٍ : مَا رَفْعُ الْمِئْزَرِ ؟ قَالَ : اعْتِزَالُ النِّسَائِ۔ (ترمذی 795۔ احمد 1/98)",,,8764,,
8765,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابن عُمَر قَالَ : لَیْلَۃُ الْقَدْر فِی کُل شَہْر رَمَضَانَ۔",,,8765,,
8766,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ ہُبَیْرَۃَ ، عَنْ عَلِیٍّ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُوقِظُ أَہْلَہُ فِی الْعَشْرِ الأَوَاخِرِ مِنْ رَمَضَانَ۔ (ترمذی 795۔ ابو یعلی 372)",,,8766,,
8767,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَاصِمٍ ، عَنْ زِرٍّ ، عَنْ عَبْدِ اللہِ ، قَالَ : مَنْ یَقُمِ الْحَوْلَ یُدْرِکْہَا، قَالَ : وَقَالَ أُبَیٌّ : لَقَدْ عَلِمَ عَبْدُ اللہِ أَنَّہَا فِی شَہْرِ رَمَضَانَ ، لَیْلَۃَ سَبْعٍ وَعِشْرِینَ۔ (مسلم 220۔ ابوداؤد 1373)",,,8767,,
8768,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ أَبِی خَالِدٍ ، قَالَ : سَمِعْتُ زِرَّ بْنَ حُبَیْشٍ الأَسَدِیَّ یَقُولُ : سَمِعْتُ أُبَیًّا یَقُولُ : ہِیَ لَیْلَۃُ سَبْعٍ وَعِشْرِینَ۔",,,8768,,
8769,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَبْدِ اللہِ بْنِ شَرِیکٍ الْعَامِرِیِّ ، قَالَ : سَمِعْتُ زِرَّ بْنَ حُبَیْشٍ یَقُولُ : إذَا کَانَتْ لَیْلَۃَ سَبْعٍ وَعِشْرِینَ فَاغْتَسِلُوا ، وَمَنِ اسْتَطَاعَ مِنْکُمْ أَنْ یُؤَخِّرَ فِطْرَہُ إلَی السَّحَرِ فَلْیَفْعَلْ ، وَلْیُفْطِرْ عَلَی ضَیَاح لَبَنٍ۔",,,8769,,
8770,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَیْلَۃُ الْقَدْرِ لَیْلَۃٌ بَلْجَۃٌ سَمْحَۃٌ ، تَطْلُعُ شَمْسُہَا لَیْسَ لَہَا شُعَاعٌ۔",,,8770,,
8771,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عُمَرُ بْنُ شَیْبَۃَ بْنِ قَارِظٍ ، قَالَ : سَمِعْتُ أَبَا بَکْرِ بْنَ عَبْدِ الرَّحْمَنِ بْنِ الْحَارِثِ بْنِ ہِشَامٍ یَقُولُ : لَیْلَۃُ الْقَدْرِ لَیْلَۃُ سَبْعَ عَشْرَۃَ ، لَیْلَۃَ جُمُعَۃٍ۔",,,8771,,
8772,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إسْرَائِیلُ وَأَبُوہُ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ حُجَیْرٍ التَّغْلِبِیِّ ، عَنِ الأَسْوَدِ ، عَنْ عَبْدِاللہِ، قَالَ: الْتَمِسُوا لَیْلَۃَ الْقَدْرِ لَیْلَۃَ سَبْعَ عَشْرَۃَ ، فَإِنَّہَا صَبِیحَۃُ بَدْرٍ ، یَوْمَ الْفُرْقَانِ ، یَوْمَ الْتَقَی الْجَمْعَانِ۔",,,8772,,
8773,"حَدَّثَنَا وَکِیعٌ ، عَنْ رَبِیعَۃَ بْنِ کُلْثُومٍ ، قَالَ : سَمِعْتُ الْحَسَنَ یَقُولُ : ہِیَ فِی کُلِّ رَمَضَانَ۔",,,8773,,
8774,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ حُمَیْدٍ ، عَنْ أَنَسٍ ، عَنْ عُبَادَۃَ بْنِ الصَّامِتِ ، قَالَ : خَرَجَ عَلَیْنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ یُرِیدُ أَنْ یُخْبِرَہُمْ بِلَیْلَۃِ الْقَدْرِ ، فَتَلاَحَی رَجُلاَنِ ، فَقَالَ : إنِّی خَرَجْتُ وَأَنَا أُرِیدُ أَنْ أُخْبِرَکُمْ بِلَیْلَۃِ الْقَدْرِ فَتَلاَحَی فُلاَنٌ وَفُلاَنٌ ، وَلَعَلَّ ذَلِکَ أَنْ یَکُونَ خَیْرًا ، الْتَمِسُوہَا فِی التَّاسِعَۃِ وَالسَّابِعَۃِ وَالْخَامِسَۃِ۔ (بخاری 49۔ احمد 5/313)",,,8774,,
8775,"حَدَّثَنَا شَبَابَۃُ ، عَنْ لَیْثِ بْنِ سَعْدٍ ، عَنْ یَزِیدَ بْنِ أَبِی حَبِیبٍ ، عَنْ عَبْدِ اللہِ بْنِ عَبْدِ اللہِ بْنِ خُبَیْبٍ ، عَنْ عَبْدِ اللہِ بْنِ أُنَیْسٍ صَاحِبِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ أَنَّہُ سُئِلَ عَنْ لَیْلَۃِ الْقَدْرِ ؟ فَقَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : الْتَمِسُوہَا اللَّیْلَۃ ، وَتِلْکَ اللَّیْلَۃ لَیْلَۃ ثَلاَثٍ وَعِشْرِینَ۔ (ابوداؤد 1374۔ احمد 3/495)",,,8775,,
8776,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ عَاصِمِ بْنِ کُلَیْبٍ ، عَنْ أَبِیہِ ، عَنْ خَالِہِ الْفَلَتَانِ بْنِ عَاصِمٍ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: إنِّی رَأَیْتُ لَیْلَۃَ الْقَدْرِ فَأُنْسِیتُہَا، فَاطْلُبُوہَا فِی الْعَشْرِ الأَوَاخِرِ وِتْرًا۔(طبرانی 859)",,,8776,,
8777,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ الأَجْلَحِ ، عَنِ الشَّعْبِیِّ ، عَنْ زِرِّ بْنِ حُبَیْشٍ ، قَالَ : سَمِعْتُ أُبَیَّ بْنَ کَعْبٍ یَقُولُ: ہِیَ لَیْلَۃُ سَبْعٍ وَعِشْرِینَ ، ہِیَ اللَّیْلَۃُ الَّتِی أَخْبَرَنَا بِہَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنَّ الشَّمْسَ تَطْلُعُ بَیْضَائَ تَرَقْرَقُ۔ (مسلم 179۔ ابوداؤد 1373)",,,8777,,
8778,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ سَابِطٍ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُوقِظُ أَہْلَہُ فِی الْعَشْرِ الأَوَاخِرِ مِنْ رَمَضَانَ ، وَیُشَمِّرُ فِیہِنَّ۔",,,8778,,
8779,"حَدَّثَنَا وَکِیعٌ ، قَالَ : أَخْبَرَنَا سُفْیَانُ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ بْنِ یَزِیدَ ، عَنْ عَائِشَۃَ ؛ أَنَّہَا کَانَتْ تُوقِظُ أَہْلَہَا لَیْلَۃَ ثَلاَثٍ وَعِشْرِینَ۔",,,8779,,
8780,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عُبَیْدِ اللہِ بْنِ أَبِی یَزِیدَ ؛ أَنَّ ابْنَ عَبَّاسٍ کَانَ یَرُشُّ عَلَی أَہْلِہِ الْمَائَ لَیْلَۃَ ثَلاَثٍ وَعِشْرِینَ۔,,,8780,,
8781,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : کَانَ یُوقِظُ أَہْلَہُ فِی الْعَشْرِ الأَوَاخِرِ۔",,,8781,,
8782,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُیَیْنَۃَ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِیہِ ، قَالَ : کَانَ أَبُو بَکْرَۃَ یُصَلِّی فِی رَمَضَانَ کَصَلاَتِہِ فِی سَائِرِ السَّنَۃِ ، فَإِذَا دَخَلَتِ الْعَشْرُ الأَوَاخِرُ اجْتَہَدَ۔",,,8782,,
8783,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا عَبْدُ الْوَاحِدِ بْنُ زِیَادٍ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، قَالَ : حَدَّثَنَا إبْرَاہِیمُ ، عَنِ الأَسْوَدِ ، عَنْ عَائِشَۃَ ، قَالَتْ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَجْتَہِدُ فِی الْعَشْرِ اجْتِہَادًا ، لاَ یَجْتَہِدُ فِی غَیْرِہِ۔ (مسلم8۔ ترمذی 796)",,,8783,,
8784,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ؛ {إنَّا أَنْزَلْنَاہُ فِی لَیْلَۃِ الْقَدْرِ}، قَالَ: لَیْلَۃُ الْحُکْمِ ، {وَمَا أَدْرَاک مَا لَیْلَۃُ الْقَدْرِ} ، قَالَ : لَیْلَۃُ الْحُکْمِ۔",,,8784,,
8785,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إسْرَائِیلُ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : یَوْمُہَا کَلَیْلَتِہَا ، وَلَیْلَتُہَا کَیَوْمِہَا۔",,,8785,,
8786,"حَدَّثَنَا عَبْدَۃُ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ ابْنِ الْمُسَیَّبِ ، قَالَ : مَنْ صَلَّی الْمَغْرِبَ وَالْعِشَائَ فِی جَمَاعَۃٍ لَیْلَۃَ الْقَدْرِ فَقَدْ أَخَذَ بِنَصِیبِہِ مِنْہَا۔",,,8786,,
8787,"أَخْبَرَنَا عَفَّانُ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، قَالَ : حَدَّثَنَا ثَابِتٌ ، قَالَ: قَدِمَ عَلَیْنَا سُلَیْمَانُ مَوْلَی الْحَسَنِ بْنِ عَلِیٍّ زَمَانَ الْحَجَّاجِ ، فحَدَّثَنَا عَنْ عَبْدِ اللہِ بْنِ أَبِی طَلْحَۃَ ، عَنْ أَبِیہِ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ جَائَ ذَاتَ یَوْمٍ وَالْبِشْر یُرَی فِی وَجْہِہِ فَقُلْنَا : یَا رَسُولَ اللہِ ، إنَّا لَنَرَی َالْبِشْرَ فِی وَجْہِکَ ، فَقَالَ : أَتَانِی الْمَلَکُ فَقَالَ : یَا مُحَمَّدُ ، إنَّ رَبَّکَ یَقُولُ : أَمَا یُرْضِیکَ أَنْ لاَ یُصَلِّیَ عَلَیْکَ أَحَدٌ مِنْ أُمَّتِکَ إِلاَّ صَلَّیْتُ عَلَیْہِ عَشْرًا ، وَلاَ یُسَلِّمُ عَلَیْکَ أَحَدٌ إِلاَّ سَلَّمْتُ عَلَیْہِ عَشْرًا ؟ قَالَ : بَلَی۔ (احمد 4/29۔ دارمی2773)",,,8787,,
8788,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ عَاصِمِ بْنِ عُبَیْدِ اللہِ ، عَنْ عَبْدِ اللہِ بْنِ عَامِرِ بْنِ رَبِیعَۃَ ، عَنْ أَبِیہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ صَلَّی عَلَیَّ لَمْ تَزَلِ الْمَلاَئِکَۃُ تُصَلِّی عَلَیْہِ مَا دَامَ یُصَلِّی عَلَیَّ ، فَلْیُقِلَّ الْعَبْدُ مِنْ ذَلِکَ ، أَوْ لِیُکْثِرْ۔ (احمد 3/446۔ طیالسی 1142)",,,8788,,
8789,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ عَبْدِ الرَّحْمَنِ بن یَزِیدَ بْنِ جَابِرٍ ، عَنْ أَبِی الأَشْعَثِ الصَّنْعَانِیِّ ، عَنْ أَوْسِ بْنِ أَوْسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ مِنْ أَفْضَلِ أَیَّامِکُمْ یَوْمَ الْجُمُعَۃِ ، فِیہِ خُلِقَ آدَم ، وَفِیہِ النَّفْخَۃُ ، وَفِیہِ الصَّعْقَۃُ ، فَأَکْثِرُوا عَلَیَّ مِنَ الصَّلاَۃ فِیہِ ، فَإِنَّ صَلاَتَکُمْ مَعْرُوضَۃٌ عَلَیَّ ، فَقَالَ رَجُلٌ : یَا رَسُولَ اللہِ ، کَیْفَ تُعْرَضُ صَلاَتُنَا عَلَیْکَ وَقَدْ أَرَمْتَ ؟ یَعْنِی بَلِیتَ ، فَقَالَ : إنَّ اللَّہَ حَرَّمَ عَلَی الأَرْضِ أَنْ تَأْکُلَ أَجْسَادَ الأَنْبِیَائِ۔",,,8789,,
8790,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ الْعَوَّامِ ، قَالَ : حدَّثَنَا رَجُلٌ مِنْ بَنِی أَسَدٍ ، عَنْ عَبْدِ اللہِ بْنِ عُمَرَ ، أَنَّہُ قَالَ : مَنْ صَلَّی عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کُتِبَتْ لَہُ عَشْرُ حَسَنَاتٍ، وَحُطَّ عَنْہُ عَشْرُ سَیِّئَاتٍ، وَرُفِعَ لَہُ عَشْرُ دَرَجَاتٍ۔",,,8790,,
8791,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حُصَیْنٌ ، عَنْ یَزِیدَ الرَّقَاشِیِّ ؛ أَنَّ مَلَکًا مُوَکَّلٌ بِمَنْ صَلَّی عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أَنْ یُبَلِّغَ عَنْہُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنَّ فُلاَنًا مِنْ أُمَّتِکَ صَلَّی عَلَیْکَ۔",,,8791,,
8792,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا أَبُو حُرَّۃَ ، عَنِ الْحَسَنِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَکْثِرُوا الصَّلاَۃ عَلَیَّ یَوْمَ الْجُمُعَۃِ ، فَإِنَّہَا مَعْرُوضَۃٌ عَلَیَّ۔",,,8792,,
8793,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا أَبُو حُرَّۃَ ، عَنِ الْحَسَنِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : کَفَی بِہِ شُحًّا أَنْ أُذْکَرَ عِنْدَہُ ، ثُمَّ لاَ یُصَلِّی عَلَیَّ۔",,,8793,,
8794,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنِ الشَّعْبِیِّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ صَلَّی عَلَیَّ صَلاَۃً ، صَلَّی اللَّہُ عَلَیْہِ عَشْرَ صَلَوَاتٍ۔",,,8794,,
8795,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یُونُسَ بْنِ عَمْرٍو ، عَنْ بُرَیدِ بْنِ أَبِی مَرْیَمَ ، عْن أَنَسِ بْنِ مَالِکٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ صَلَّی عَلَیَّ صَلاۃ وَاحِدَۃً صَلَّی اللَّہُ عَلَیْہِ عَشْرَ صَلَوَاتٍ ، وَحَطَّ عَنْہُ عَشْرَ سَیِّئَاتٍ۔ (بخاری 643۔ احمد 3/261)",,,8795,,
8796,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ کَعْبٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: صَلُّوا عَلَیَّ ، فَإِنَّ صَلاَۃً عَلَیَّ زَکَاۃٌ لَکُمْ۔ (ترمذی 3612۔ احمد 2/365)",,,8796,,
8797,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ السَّائِبِ ، عَنْ زَاذَانَ ، عَنْ عَبْدِ اللہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ لِلَّہِ مَلاَئِکَۃً سَیَّاحِینَ فِی الأَرْضِ یُبَلِّغُونِی عَنْ أُمَّتِی السَّلاَمَ۔ (احمد 1/387۔ دارمی 2774)",,,8797,,
8798,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ مُحَمَّدِ بْنِ عَقِیلٍ ، عَنِ الطُّفَیْلِ بْنِ أُبَیٍّ ، عَنْ أَبِیہِ ، قَالَ : قَالَ رَجُلٌ لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَرَأَیْتَ إِنْ جَعَلْتُ صَلاَتِی کُلَّہَا صَلاَۃً عَلَیْکَ ؟ قَالَ : إذًا یَکْفِیکَ اللَّہُ مَا أَہَمَّکَ مِنْ أَمْرِ دُنْیَاکَ وَآخِرَتِکَ۔ (ترمذی 2457۔ احمد 5/136)",,,8798,,
8799,"حَدَّثَنَا زَیدُ بْنُ الْحُبَابِ ، قَالَ : حدَّثَنِی مُوسَی بْنُ عُبَیْدَۃَ ، عَنْ قَیْسِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ أَبِی صَعْصَعَۃَ ، عَنْ سَعْدِ بْنِ إِبْرَاہِیمَ ، عَن أَبِیہِ ، عَنْ جَدِّہِ عَبْدِ الرَّحْمَنِ بْنِ عَوْفٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : سَجَدْتُ شُکْرًا لِرَبِّی فِیمَا أَبْلاَنِی فِی أُمَّتِی ، مَنْ صَلَّی عَلَیَّ صَلاَۃً کُتِبَتْ لَہُ عَشْرُ حَسَنَاتٍ ، وَمُحِیَ عَنْہُ عَشْرُ سَیِّئَاتٍ۔",,,8799,,
8800,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یَنْسَی التَّشَہُّدَ حَتَّی یَخْرُجَ مِنْ صَلاَتِہِ ، فَقَالَ : إِنْ کَانَ خَرَجَ مِنْہَا فَقَدْ تَمَّتْ صَلاَتُہُ ، وَإِنْ لَمْ یَخْرُجْ مِنْہَا تَشَہَّدَ ، قَالَ : کَأَنَّ الْخُرُوجَ عِنْدَہُ أَنْ یَتَکَلَّمَ ، أَوْ یَدْخُلَ فِی صَلاَۃٍ أُخْرَی ، أَوْ یُوَلِّی ظَہْرَہُ الْقِبْلَۃَ۔",,,8800,,
8801,"حَدَّثَنَا عُمَرُ بْنُ ہَارُونَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ فِی رَجُلِ نَسِیَ التَّشَہُّدَ فِی صَلاَتِہِ ، فَقَالَ : لاَ شَیْئَ عَلَیْہِ ، صَلاَتُہُ جَائِزَۃٌ۔",,,8801,,
8802,"حَدَّثَنَا شَبَابَۃُ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ وَحَمَّادًا عَنِ الرَّجُلِ یَنْسَی التَّشَہُّدَ ؟ فَقَالاَ : أَکُلُّ النَّاسِ یُحْسِنُ یَتَشَہَّد ؟ جَازَتْ صَلاَتُہُ۔",,,8802,,
8803,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ أَبِیہِ ، عَنِ الْحَارِثِ بْنِ شُبیلٍ ، عَنْ عَبْدِ اللہِ بْنِ شَدَّادٍ ؛ أَنَّ ابْنَ عُمَرَ لَمْ یَجْلِسْ فِی الرَّکْعَتَیْنِ ، فَتَشَہَّدَ فِی آخِرِ صَلاَتِہِ مَرَّتَیْنِ۔,,,8803,,
8804,"حَدَّثَنَا عَلِیُّ بْنُ الْجَعْدِ ، قَالَ : حدَّثَنَا أَبُو جَعْفَرٍ الرَّازِیّ ، عَنْ لَیْثٍ ، عَنْ غَالِبٍ ، عَنْ مُحَمَّدِ بْنِ عَلِیٍّ ، قَالَ : إذَا جَلَسَ قَدْرَ التَّشَہُّدِ ، ثُمَّ أَحْدَثَ فَقَدْ تَمَّتْ صَلاَتُہُ ، لأَنَّ لَیْسَ کُلُّ أَحَدٍ یُحْسِنَ أنْ یَتَشَہَّدَ۔",,,8804,,
8805,"حَدَّثَنَا وَکِیعٌ ، أَوْ غَیْرُہُ ، عَنْ شُعْبَۃَ ، عَنْ مُسْلِمٍ أَبِی النَّضْرِ ، عَنِ ابْنِ عَبْدِ الرَّحْمَنِ ، قَالَ : قَالَ عُمَرُ : لاَ صَلاَۃَ إِلاَّ بِتَشَہُّدٍ۔",,,8805,,
8806,"حَدَّثَنَا جَعْفَرُ بْنُ بُرْقَانَ ، عَنْ عُقْبَۃَ بْنِ نَافِعٍ ، قَالَ : سَمِعْتُ ابْنَ عُمَرَ یَقُولُ : لَیْسَ مِنْ صَلاَۃٍ إِلاَّ وَفِیہَا قِرَائَۃٌ ، وَجُلُوسٌ فِی الرَّکْعَتَیْنِ ، وَتَشَہُّدٌ وَتَسْلِیمٌ ، فَإِنْ لَمْ تَفْعَلْ ذَلِکَ سَجَدْتَ سَجْدَتَیْنِ بَعْدَ مَا تُسَلِّمُ ، وَأَنْتَ جَالِسٌ۔",,,8806,,
8807,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ مُسْلِمٍ أَبِی النَّضْرِ ، قَالَ : سَمِعْتُ حَمَلَۃَ بْنَ عَبْدِ الرَّحْمَنِ یَقُولُ : قَالَ عُمَرُ : لاَ صَلاَۃَ إِلاَّ بِتَشَہُّدٍ۔",,,8807,,
8808,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا عُثْمَانُ بْنُ حَکِیمٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : مَا أعْلَمُ الصَّلاَۃَ تَنْبَغِی مِنْ أَحَدٍ عَلَی أَحَدٍ إِلاَّ عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,8808,,
8809,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الأَسْوَدِ بْنِ قَیْسٍ ، عَنْ نُبَیْحٍ ، عَنْ جَابِرٍ ، قَالَ : أَتَیْتُُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَسْتَعِینُہُ فِی دَیْنٍ کَانَ عَلَی أَبِی ، قَالَ : انْصَرِفْ أَنَا آتِیکُمْ ، فَأَتَانَا وَقَدْ قُلْتُ لِلْمَرْأَۃِ لاَ تُکَلِّمِینَ رَسُولَ اللہِ ، وَلاَ تُؤْذِینَہُ ، فَلَمَّا خَرَجَ ، قَالَتِ الْمَرْأَۃُ : یَا رَسُولَ اللہِ ، صَلِّ عَلَیَّ وَعَلَی زَوْجِی ، فَقَالَ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : صَلَّی اللَّہُ عَلَیْکِ وَعَلَی زَوْجِکِ ، قَالَتْ : یَا رَسُولَ اللہِ ، تَأْتِینَا وَلاَ تَدْعُو لَنَا ؟ (احمد 3/303۔ دارمی45)",,,8809,,
8810,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنِ ابْنِ أَبِی أَوْفَی ، قَالَ : أَتَیْتُُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِصَدَقَۃِ أَبِی فَقَبِلَہَا ، وَقَالَ : اللَّہُمَّ صَلِّ عَلَی آلِ أَبِی أَوْفَی۔ (بخاری 1497۔ مسلم 176)",,,8810,,
8811,"حَدَّثَنَا عَبْدَۃُ بن سُلَیْمَان ، عَنْ سَعِید ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ؛ فِی الرَّجُلِ یَسْتَرْخِی إزَارُہُ وَہُوَ فِی الصَّلاَۃ ، قَالَ : لاَ یَحِلُّہُ ، وَلاَ یُفَرِّجُہُ وَلَکِنَّہُ یُدْرِجُہُ وَیَرْفَعُہُ۔",,,8811,,
8812,"حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ مُسْلِمٍ ، عَنْ إبْرَاہِیمَ بْنِ مَیْسَرَۃَ ، عَنْ مُجَاہِدٍ ، قَالَ : إذَا أَرَدْتَ أَنْ تَتَّزِرَ وَعَلَیْکَ إزَارٌ وَرِدَائٌ وَأَنْتَ فِی الصَّلاَۃ ، فَأَرْخِ رِدَائَکَ وَاتَّزِرْ ۔ قَالَ : فَذَکَرْتُہُ لِطَاوُوس ، فَقَالَ : ہُوَ خَیْرٌ ، أَوْ ذَاکَ خَیْرٌ۔",,,8812,,
8813,"حَدَّثَنَا وَکِیعٌ ، عَنْ رَبِیعِ بْنِ صُبَیْحٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَرِہَ أَنْ یُحْدِثَ الرَّجُلُ فِی الصَّلاَۃ شَیْئًا حَتَّی زَرَّ الْقَمِیصِ ۔ قَالَ : وَکَانَ إبْرَاہِیمُ لاَ یَرَی بَأْسًا إذَا اسْتَرْخَی إزَارُہُ فِی الصَّلاَۃ أَنْ یَرْفَعَہُ۔",,,8813,,
8814,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عَبْدُ السَّلاَمِ بْنُ شَدَّادٍ أَبُو طَالُوتِ الْجُرَیرِیُّ ، عَنْ غَزْوَانَ بْنِ جَرِیرٍ الضَّبِّیِّ ، عَنْ أَبِیہِ ، قَالَ: کَانَ عَلِیٌّ إذَا قَامَ فِی الصَّلاَۃ وَضَعَ یَمِینَہُ عَلَی رُسْغِہِ ، فَلاَ یَزَالُ کَذَلِکَ حَتَّی یَرْکَعَ مِثْلَ مَا رَکَعَ، إِلاَّ أَنْ یُصْلِحَ ثَوْبَہُ ، أَوْ یَحُکَّ جَسَدَہُ۔",,,8814,,
8815,حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَرِہَ أَنْ یَتَوَشَّحَ ، أَوْ یَرْتَدِیَ وَہُوَ فِی الصَّلاَۃ۔,,,8815,,
8816,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، قَالَ : قرَأْتُُ عَلَی عَبْدِ اللہِ ، فَقَالَ : رَتِّلْ فِدَاکَ أَبِی وَأُمِّی ، فَإِنَّہُ زَیْنُ الْقُرْآنِ۔",,,8816,,
8817,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ أَبِی لَیْلَی ، عَنِ الْحَکَمِ ، عَنْ مِقْسَمٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ (وَرَتِّلِ الْقُرْآنَ تَرْتِیلاً) ، قَالَ : بَیِّنْہُ تَبْیِینًا۔",,,8817,,
8818,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ؛ (وَرَتِّلَ الْقُرْآنَ تَرْتِیلاً) ، قَالَ : بَعْضُہُ عَلَی إِثْرِ بَعْضٍ۔",,,8818,,
8819,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ أَبِی وَائِلٍ ، قَالَ : جَائَ رَجُلٌ مِنْ بَنِی بَجِیلَۃَ ، یُقَالُ لَہُ : نَہِیکُ بْنُ سِنَانٍ إلَی ابْنِ مَسْعُودٍ ، فَقَالَ : یَا أَبَا عَبْدِ الرَّحْمَنِ ، کَیْفَ تَقْرَأُ ہَذَا الْحَرْفَ ، أَیَائً تَجِدُہُ ، أَمْ أَلِفًا ؟ {مِنْ مَائٍ غَیْرِ یَاسِنٍ} ، أَوْ {مِنْ مَائٍ غَیْرِ آسِنٍ} ؟ قَالَ : فَقَالَ لَہُ عَبْدُ اللہِ : وَکُلَّ الْقُرْآنِ أَحْصَیْتَ غَیْرَ ہَذَا ؟ قَالَ : فَقَالَ لَہُ : إنِّی لأَقْرَأُ الْمُفَصَّلَ فِی رَکْعَۃٍ ، قَالَ : ہَذًّا کَہَذِّ الشِّعْرِ ، إنَّ قَوْمًا یَقْرَؤُونَ الْقُرْآنَ لاَ یَتَجَاوَزُ تَرَاقِیَہُمْ ، وَلَکِنَّ الْقُرْآنَ إذَا وَقَعَ فِی الْقَلْبِ فَرَسَخَ نَفَعَ ، إنَّ أَفْضَلَ الصَّلاَۃ الرُّکُوعُ وَالسُّجُودُ ، قَالَ : وَقَالَ عَبْدُاللہِ: إنِّی لأَعْرِفُ النَّظَائِرَ الَّتِی کَانَ یَقْرَأُ بِہِنَّ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔(بخاری775۔ مسلم 276)",,,8819,,
8820,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا جَرِیرُ بْنُ حَازِمٍ الأَزْدِیُّ ، عَنْ قَتَادَۃَ ، قَالَ : سُئِلَ أَنَسٌ ، عَنْ قِرَائَۃِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ فَقَالَ : کَانَ یَمُدُّ بِہَا صَوْتَہُ مَدًّا۔ (بخاری 5045۔ احمد 3/119)",,,8820,,
8821,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، عَنْ أُمِّ سَلَمَۃَ ، قَالَتْ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقْرَأُ : بِسْمِ اللہِ الرَّحْمَن الرَّحِیمِ الْحَمْدُ لِلَّہِ رَبِّ الْعَالَمِینَ ، تَعْنِی حَرْفًا حَرْفًا۔ (ترمذی 2927۔ ابوداؤد 3997)",,,8821,,
8822,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، قَالَ : کَانَ مُحَمَّدٌ إذَا قَرَأَ مَضَی فِی قِرَائَتِہِ۔",,,8822,,
8823,"حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، قَالَ : کَانَ عَطَائٌ وَمُجَاہِدٌ یَہُذَّان الْقُرْآنَ ہَذًّا۔",,,8823,,
8824,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عُبَیْدُ اللہِ بْنُ عَبْدِ الرَّحْمَنِ بْنِ مَوْہَبٍ ، قَالَ : سَمِعْتُ مُحَمَّدَ بْنَ کَعْبٍ الْقُرَظِیَّ یَقُولُ : لأَنْ أَقْرَأَ : {إذَا زُلْزِلَت الأَرْضُ} ، {وَالْقَارِعَۃُ} لَیْلَۃً أُرَدِّدُہُمَا ، وَأَتَفَکَّرُ فِیہِمَا أَحَبُّ إلَیَّ مِنْ أَنْ أَبِیتَ أَہُذُّ الْقُرْآنَ۔",,,8824,,
8825,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عِیسَی الْحَنَّاطُ ، عَنِ الشَّعْبِیِّ ، قَالَ : قَالَ عَبْدُ اللہِ : لاَ تَہُذُّوا الْقُرْآنَ کَہَذِّ الشِّعْرِ ، وَلاَ تَنْثُرُوہُ نَثْرَ الدَّقَلِ ، وَقِفُوا عِنْدَ عَجَائِبِہِ ، وَحَرِّکُوا بِہِ الْقُلُوبَ۔",,,8825,,
8826,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا نَافِعُ بْنُ عُمَرَ الْجُمَحِیُّ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، عَنْ بَعْضِ أَزْوَاجِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ أَنَّہَا سُئِلَتْ عَنْ قِرَائَۃِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ فَقَالَتْ : إنَّکُمْ لاَ تَسْتَطِیعُونَہَا ، فَقِیلَ لَہَا : أَخْبِرِینَا بِہَا ، فَقَرَأَتْ قِرَائَۃً تَرَسَّلَتْ فِیہَا۔",,,8826,,
8827,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عُبَیْدِ الْمُکْتِبِ ، قَالَ : سُئِلَ مُجَاہِدٌ عَنْ رَجُلَیْنِ قَرَأَ أَحَدُہُمَا الْبَقَرَۃَ ، وَقَرَأَ الأَخَرُ الْبَقَرَۃَ وَآلَ عِمْرَانَ ، فَکَانَ رُکُوعُہُمَا وَسُجُودُہُمَا وَجُلُوسُہُمَا سَوَائً ، أَیُّہُمَا أَفْضَلُ ؟ قَالَ : الَّذِی قَرَأَ الْبَقَرَۃَ ، ثُمَّ قَرَأَ مُجَاہِدٌ : {وَقُرْآنًا فَرَقْنَاہُ لِتَقْرَأَہُ عَلَی النَّاسِ عَلَی مُکْثٍ وَنَزَّلْنَاہُ تَنْزِیلاً}۔",,,8827,,
8828,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ إسْمَاعِیلَ ، قَالَ : حدَّثَنَا بَیَانٌ ، عَنْ حَکِیمِ بْنِ جَابِرٍ ، قَالَ : قَالَ حُذَیْفَۃُ : إنَّ مِنْ أَقْرَأِ النَّاسِ مُنَافِقًا لاَ یَتْرُکُ وَاوًا ، وَلاَ أَلِفًا یَلْفِتُہُ بِلِسَانِہِ کَمَا تَلْفِتُ الْبَقَرَۃُ الْخَلاَ بِلِسَانِہَا ، لاَ یُجَاوِزُ تَرْقُوَتَہُ۔",,,8828,,
8829,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ طَلْحَۃَ بْنِ مُصَرِّفٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَوْسَجَۃَ ، عَنِ الْبَرَائِ بْنِ عَازِبٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : زَیِّنُوا الْقُرْآنَ بِأَصْوَاتِکُمْ۔ (ابوداؤد 1463۔ نسائی 1088)",,,8829,,
8830,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی نَہِیکٍ ، عَنْ سَعْدٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَیْسَ مِنَّا مَنْ لَمْ یَتَغَنَّ بِالْقُرْآنِ ۔ یَسْتَغْنِی بِہِ۔ (ابوداؤد 1465۔ احمد 1/179)",,,8830,,
8831,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سَعِیدُ بْنُ حَسَّانَ الْمَخْزُومِیُّ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی نَہِیکٍ ، عَنْ سَعْدِ بْنِ أَبِی وَقَّاصٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَیْسَ مِنَّا مَنْ لَمْ یَتَغَنَّ بِالْقُرْآنِ ۔ یَعْنِی یَسْتَغْنِی بِہِ۔",,,8831,,
8832,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عَبْدُ اللہِ بْنُ سَعِیدِ بْنِ أَبِی ہِنْدٍ ، قَالَ : سَمِعْتُ أَبَا سَلَمَۃَ بْنَ عَبْدِ الرَّحْمَنِ یَقُولُ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَا أَذِنَ اللَّہُ لِشَیْئٍ کَإِذْنِہِ لِنَبِیٍّ یَتَغَنَّی بِالْقُرْآنِ ، یَجْہَرُ بِالْقرائۃِ۔ (عبدالرزاق 4169)",,,8832,,
8833,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ عَمْرٍو ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، بِنَحْوِ حَدِیثِ وَکِیعٍ ، عَنْ عَبْدِ اللہِ بْنِ سَعِیدٍ۔ (بخاری5023۔ مسلم 545)",,,8833,,
8834,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مِسْعَرٌ ، عَنْ عَبْدِ الْکَرِیمِ أَبِی أُمَیَّۃَ ، عَنْ طَاوُوسٍ ، قَالَ : سُئِلَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَیُّ النَّاسِ أَحْسَنُ قِرَائَۃً ؟ قَالَ : الَّذِی إذَا سَمِعْتَہُ یَقْرَأُ رَأَیْتَ أَنَّہُ یَخْشَی اللَّہَ۔ (بزار 2336۔ عبدالرزاق 4185)",,,8834,,
8835,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، قَالَ : صَلَّیْت خَلْفَ إبْرَاہِیمَ فَمَا سَمِعْتُہُ یُمَدِّدُ ، وَلاَ یُرَجِّعُ ، وَلاَ یُحَسِّنُ صَوْتَہُ۔",,,8835,,
8836,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، قَالَ : حدَّثَنِی أَبِی ، قَالَ : کَانُوا یُخْفُونَ التَّشَہُّدَ ، وَلاَ یَجْہَرُونَ بِہِ۔",,,8836,,
8837,"حَدَّثَنَا مُلاَزِمُ بْنُ عَمْرٍو ، عَنْ عَبْدِ اللہِ بْنِ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ أَبِیہِ یَحْیَی بْنِ أَبِی کَثِیرٍ ، قَالَ : مَنْ جَہَرَ بِالتَّشَہُّدِ کَانَ کَمَنْ جَہَرَ بِالْقِرَائَۃِ فِی غَیْرِ مَوْضِعِہَا۔",,,8837,,
8838,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ صَلَّی الْمَغْرِبَ فِی السَّفَرِ رَکْعَتَیْنِ رَکْعَتَیْنِ حَتَّی یرجعَ ، قَالَ : یُعِیدُ کُلَّ صَلاَۃٍ صَلاَّہَا۔",,,8838,,
8839,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ عُلْوَانَ بْنِ أَبِی مَالِکٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : أَدْبَارَ السُّجُودِ رَکْعَتَانِ بَعْدَ الْمَغْرِبِ ، {وَإِدْبَارَ النُّجُومِ} رَکْعَتَانِ قَبْلَ صَلاَۃِ الْفَجْرِ۔",,,8839,,
8840,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ إبْرَاہِیمَ بْنِ مُہَاجِرٍ ، عَنْ إبْرَاہِیم ،َ مِثْلَہُ۔,,,8840,,
8841,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ ، عَنِ الْحَسَنِ بْنِ عَلِیٍّ ، قَالَ : {أَدْبَارَ السُّجُودِ} رَکْعَتَانِ بَعْدَ الْمَغْرِبِ۔",,,8841,,
8842,"حَدَّثَنَا وَکِیعٌ ، عَنْ یَزِیدَ بْنِ إبْرَاہِیمَ ، قَالَ : سَمِعْتُ الْحَسَنَ یَقُولُ : {إدْبَارَ النُّجُومِ} الرَّکْعَتَانِ قَبْلَ الْفَجْرِ ، {وَأَدْبَارَ السُّجُودِ} الرَّکْعَتَانِ بَعْدَ الْمَغْرِبِ۔",,,8842,,
8843,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی الْعَنْبَسِ ، قَالَ : سَمِعْتُ زَاذَانَ یَقُولُ ، مِثْلَہُ۔",,,8843,,
8844,حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ عُثْمَانَ الثَّقَفِیِّ ، عَنْ عَلِیِّ بْنِ رَبِیعَۃَ ، عَنْ عَلِیٍّ ، مِثْلَہُ۔,,,8844,,
8845,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : {أَدْبَارَ السُّجُود} رَکْعَتَانِ بَعْدَ الْمَغْرِبِ ، {وَإدْبَارَ النُّجُومِ} رَکْعَتَانِ قَبْلَ الْفَجْرِ۔",,,8845,,
8846,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ أَبِی الْعَنْبَسِ ، عَنْ زَاذَانَ ، عَنِ ابْنِ عُمَرَ ، عَنْ عُمَرَ ، قَالَ : {إدْبَارَ النُّجُومِ} رَکْعَتَانِ قَبْلَ الْفَجْرِ ، {وَأَدْبَارَ السُّجُودِ} رَکْعَتَانِ بَعْدَ الْمَغْرِبِ۔",,,8846,,
8847,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ عَلِیِّ بْنِ زَیْدٍ ، عَنْ أَوْسِ بْنِ خَالِدٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : {إدْبَارَ النُّجُومِ} رَکْعَتَانِ قَبْلَ الْفَجْرِ ، {وَأَدْبَارَ السُّجُودِ} رَکْعَتَانِ بَعْدَ الْمَغْرِبِ۔",,,8847,,
8848,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ہِشَامُ بْنُ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، قَالَتْ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّی بِاللَّیْلِ صَلاَتَہُ وَأَنَا مُعْتَرِضَۃٌ بَیْنَہُ وَبَیْنَ الْقِبْلَۃِ ، فَإِذَا أَرَادَ أَنْ یُوتِرَ أَوْقَظَنِی فَأَوْتَرْت۔ (مسلم 266)",,,8848,,
8849,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَنْظَلَۃَ الْجُمَحِیِّ ، عَنْ سَالِمِ بْنِ عَبْدِ اللہِ ، قَالَ : صَلَّی بِنَا ابْنُ الزُّبَیْرِ ، فَمَرَّتْ بَیْنَ أَیْدِینَا امْرَأَۃٌ بَعْدَ مَا قَدْ صَلَّیْنَا رَکْعَۃً ، أَوْ رَکْعَتَیْنِ فَلَمْ یُبَالِ بِہَا۔",,,8849,,
8850,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا طَلْحَۃُ بْنُ یَحْیَی ، عَنْ عُبَیْدِ اللہ بن عَبْدِ اللہِ بْنِ عُتْبَۃَ ، عَنْ عَائِشَۃَ ، قَالَتْ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّی بِاللَّیْلِ ، وَأَنَا إلَی جَنْبِہِ وَأَنَا حَائِضٌ ، وَعَلَیَّ مِرْطٌ لِی وَعَلَیْہِ بَعْضُہُ۔ (مسلم 274۔ احمد 6/67)",,,8850,,
8851,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إسْرَائِیلُ ، عَنْ أَبِی جَعْفَرٍ الْفَرَّائِ ، قَالَ : سَأَلْتُ سَعِیدَ بْنَ جُبَیْرٍ عَنِ الْمَرْأَۃِ تَمُرُّ بَیْنَ یَدَیِ الرَّجُلِ وَہُوَ یُصَلِّی ؟ قَالَ : لاَ یَقْطَعُ الصَّلاَۃ شَیْئٌ۔",,,8851,,
8852,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ سِمَاکِ بْنِ حَرْبٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : ذُکِرَ لَہُ أَنَّ الْمَرْأَۃَ وَالْحِمَارَ وَالْکَلْبَ یَقْطَعُونَ الصَّلاَۃ ، قَالَ ابْنُ عَبَّاسٍ : (إلَیْہِ یَصْعَدُ الْکَلِمُ الطَّیِّبُ وَالْعَمَلُ الصَّالِحُ یَرْفَعُہُ) لاَ یَقْطَعُ الصَّلاَۃ شَیْئٌ ، وَلَکِنَّہُ یُکْرَہُ۔",,,8852,,
8853,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ، عَنْ أَشْعَثَ، عَنِ الشَّعْبِیِّ، قَالَ: الإِمَام یَؤُمُّ الصَّفَّ، وَالصُّفُوفُ یَؤُمُّ بَعْضُہُمْ بَعْضًا۔",,,8853,,
8854,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ سُفْیَانَ ، قَالَ : بَلَغَنِی عَنْ مَسْرُوقٍ أَنَّہُ قَالَ : النَّاسُ أَئِمَّۃُ بَعْضِہِمْ لِبَعْضٍ فِی الصُّفُوفِ۔",,,8854,,
8855,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ، قَالَ : إذَا رَکَعَ رَکَعَاتٍ لَیْسَ بَیْنَہُنَّ سُجُودٌ ، فَہِیَ رَکْعَۃٌ وَاحِدَۃٌ۔",,,8855,,
8856,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ؛ فِی رَجُلٍ صَلَّی الْمَغْرِبَ أَرْبَعًا، قَالَ: یُعِیدُ الصَّلاَۃ۔",,,8856,,
8857,"حَدَّثَنَا وَکِیعٌ ، عَنْ رَبِیعٍ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ صَلَّی الْمَغْرِبَ أَرْبَعًا ، قَالَ : یَسْجُدُ سَجْدَتَیِ السَّہْوِ۔",,,8857,,
8858,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ سُلَیْمَانَ بْنِ الْمُغِیرَۃِ ، قَالَ : سَأَلَ رَجُلٌ الْحَسَنَ عَنْ رَجُلٍ لاَ یُحْسِنُ إِلاَّ {قُلْ ہُوَ اللَّہُ أَحَدٌ} أَیَؤُمُّ قَوْمَہُ وَیُعِیدُہَا ؟ قَالَ : نَعَمْ۔",,,8858,,
8859,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا لَمْ یَکُنْ مَعَ الرَّجُلِ مِنَ الْقُرْآنِ إِلاَّ سُورَۃٌ وَاحِدَۃٌ ، قَرَأَ بِہَا فِی صَلاَتِہِ وَرَدَّدَہَا۔",,,8859,,
8860,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدِ ، عَنْ سُلَیْمَانَ بْنِ مُغِیرَۃَ ؛ أَنَّ أَبَا النَّضْرِ سَأَلَ الْحَسَنَ ، فَقَالَ : أَؤُمّ قَوْمِی وَلَسْتُ أَقْرَأُ إِلاَّ : {قُلْ ہُوَ اللَّہُ أَحَدٌ} أُرَدِّدُہَا ؟ قَالَ : نَعَمْ۔",,,8860,,
8861,"حَدَّثَنَا ہَارُونُ ، عَنْ عَاصِمٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : السَّطْحُ بِمَنْزِلَۃِ الصَّحْرَائِ ، إذَا لَمْ یَکُنْ حِجَابٌ۔",,,8861,,
8862,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یُحِبُّونَ إذَا دَخَلُوا مَکَّۃَ أَنْ لاَ یَخْرُجُوا حَتَّی یَخْتِمُوا بِہَا الْقُرْآنَ۔",,,8862,,
8863,"حَدَّثَنَا جَرِیرٌ، عَنْ مَنْصُورٍ، عَنْ إبْرَاہِیمَ ، قَالَ: قَرَأَ عَلْقَمَۃُ الْقُرْآنَ فِی لَیْلَۃٍ بِمَکَّۃَ ، طَافَ بِالْبَیْتِ سُبوعا، ثُمَّ أَتَی الْمَقَامَ فَصَلَّی عِنْدَہُ ، فَقَرَأَ بِالْمِئِینَ ، ثُمَّ طَافَ سُبوعًا ، ثُمَّ أَتَی الْمَقَامَ فَصَلَّی عِنْدَہُ ، فَقَرَأَ بِالْمَثَانِی ، ثُمَّ طَافَ سبوعًا ، ثُمَّ أَتَی الْمَقَامَ فَصَلَّی عِنْدَہُ ، فَقَرَأَ بَقِیَّۃَ الْقُرْآنِ۔",,,8863,,
8864,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : کَانَ یُعْجِبُہُمْ إذَا قَدِمُوا لِلْحَجِّ ، أَوْ الْعُمْرَۃِ أَنْ لاَ یَخْرُجُوا حَتَّی یَقْرَؤُوا مَا مَعَہُمْ مِنَ الْقُرْآنِ۔",,,8864,,
8865,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ : کَانَ یُحِبُّ ، أَوْ یَسْتَحِبُّ إذَا قَدِمَ شَیْئًا مِنْ ہَذِہِ الْمَسَاجِدِ أَنْ لاَ یَخْرُجَ حَتَّی یَقْرَأَ الْقُرْآنَ فِی الْمَسْجِدِ الْحَرَامِ ، أَوْ مَسْجِدِ الْمَدِینَۃِ ، أَوْ مَسْجِدِ بَیْتِ الْمَقْدِسِ۔",,,8865,,
8866,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : لَمَّا قَدِمَ وَفْدُ ثَقِیفٍ عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَزَلُوا قُبَّۃً کَانَتْ فِی مُؤَخَّرِ الْمَسْجِدِ ، فَلَمَّا حَضَرَتِ الصَّلاَۃ ، قَالَ رَجُلٌ مِنَ الْقَوْمِ : یَا رَسُولَ اللہِ ، حَضَرَتِ الصَّلاَۃ وَہَؤُلاَئِ قَوْمٌ کُفَّارٌ وَہُمْ فِی الْمَسْجِدِ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ الأَرْضَ لاَ تَنْجُسُ ، أَوْ نَحْوَ ہَذَا۔ (ابوداؤد 17)",,,8866,,
8867,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّ وَفْدَ ثَقِیفٍ قَدِمُوا عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ فِی الْمَسْجِدِ ، فِی قُبَّۃٍ لَہُ فَقِیلَ لَہُ : یَا رَسُولَ اللہِ ، إنَّہُمْ مُشْرِکُونَ ، فَقَالَ : إنَّ الأَرْضَ لاَ یُنَجِّسُہَا شَیْئٌ۔",,,8867,,
8868,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ أَبِی عَبْدِ اللہِ الْعَسْقَلاَنِیِّ ، أَنَّہُ أَخْبَرَہُ مَنْ رَأَی ابْنَ مُحَیْرِیزٍ صَافَحَ نَصْرَانِیًّا فِی مَسْجِدِ دِمَشْقَ۔",,,8868,,
8869,حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْہَیْثُمَّ ، عَنْ طَلْحَۃَ ، عَنْ مُجَاہِدٍ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ یَجْلِسَ أَہْلُ الْکِتَابِ فِی الْمَسْجِدِ۔,,,8869,,
8870,"حَدَّثَنَا عَبَّادُ بْنُ عَوَّامٍ ، عَنْ حُصَیْنٍ ، قَالَ : کَتَبَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ : لاَ تُجلسْ قَاضیًا فِی مَسْجِدٍ ، یَدْخُلُ عَلَیْہِ الْیَہُودِیُّ وَالنَّصْرَانِیُّ فِیہِ",,,8870,,
8871,"حَدَّثَنَا ہَاشِمُ بْنُ الْقَاسِمِ ، عَنْ مُحَمَّدِ بْنِ طَلْحَۃَ ، عَنْ أَبِیہِ ، عَنْ أَبِی صَالِحٍ ، قَالَ : لَیْسَ لِلْمُشْرِکِینَ أَنْ یَدْخُلُوا الْمَسْجِدَ إِلاَّ خَائِفِینَ۔",,,8871,,
8872,"حَدَّثَنَا حُمَیْدٌ ، عَنْ عَبْدِ الرَّحْمَنِ ، عَنِ الْحَسَنِ ، عَنْ عِیسَی بْنِ أَبِی عَزَّۃَ ، قَالَ : کَانَ الشَّعْبِیُّ یُصَلِّی وَہُوَ جَالِسٌ ، وَیَقْعُدُ کَمَا تَقْعُدُونَ أَنْتُمْ فِی الصَّلاَۃ۔",,,8872,,
8873,"حَدَّثَنَا حُمَیْدٌ ، عَنِ الْحَسَنِ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطَائٍ ، قَالَ فِی صَلاَۃِ الْقَاعِدِ : یَقْعُدُ کَیْفَ شَائَ۔",,,8873,,
8874,حَدَّثَنَا حُمَیْدٌ ، عَنْ حَسَنٍ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، مِثْلَ صَنِیعِ الشَّعْبِیِّ ، أَنَّہُ کَانَ یَفْعلہ۔,,,8874,,
8875,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ الْعَبْدِیُّ ، قَالَ : حدَّثَنَا عَبْدُ اللہِ بْنُ الْوَلِیدِ ، قَالَ : حَدَّثَنِی عُمَرُ بْنُ عُمَر بْنِ مُحَمَّدِ بْنِ حَاطِبٍ ، قَالَ : قَدِمَ عَظِیمٌ مِنْ عُظَمَائِ الأَعَاجِمِ عَلَی عُمَرَ فَسَأَلَ عَنْ عُمَرَ ، فَقِیلَ لَہُ : إِنَّہُ خَارِجٌ عَنِ الْمَدِینَۃِ ، فَخَرَجَ إلَیْہِ ، قَالَ : فَلَقِیَہُ وَہُوَ مُقْبِلٌ ، فَأَہْوَی الدِّہْقَانُ فَسَجَدَ ، أَوْ لِیَسْجُدَ ، شَکَّ عَبْدُ اللہِ ، قَالَ : فَقَالَ عُمَرُ : ارْفَعْ رَأْسَک لِلْوَاحِدِ الْقَہَّارِ۔",,,8875,,
8876,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سِمَاکٍ ، عَنْ رَجُلٍ یُقَالُ لَہُ : مُثَنَّی ، قَالَ : جَائَ قَسٌّ إلَی عَلِیٍّ فَسَجَدَ لَہُ ، فَنَہَاہُ ، وَقَالَ : اُسْجُدْ لِلَّہِ۔",,,8876,,
8877,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ أَبِی ظَبْیَانَ ، عَنْ مُعَاذٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَوْ کُنْت آمِرًا أَحَدًا یَسْجُدُ لأَحَدٍ ، لأَمَرْت النِّسَائَ یَسْجُدْنَ لأَزْوَاجِہِنَّ۔\n\n(احمد 5/227۔ طبرانی373)",,,8877,,
8878,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ مَیْسَرَۃَ ؛ أَنَّ الْعَجَمَ کَانُوا إذَا سَجَدُوا لِسَلْمَانَ طَأْطَأَ رَأْسَہُ ، وَقَالَ : خَشَعْت لِلَّہِ۔",,,8878,,
8879,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ إسْمَاعِیلَ بْنِ عَبْدِ الْمَلِکِ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَوْ أَمَرْت أَحَدًا یَسْجُدُ لأَحَدٍ ، لَکَانَ النِّسَائُ لأَزْوَاجِہِنَّ۔ (ابوداؤد 2)",,,8879,,
8880,"حَدَّثَنَا عَفَّانُ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عَلِیِّ بْنِ زَیْدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ عَائِشَۃَ ، قَالَتْ : قَالَ رَسُول اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَوْ أَمَرْت أَحَدًا یَسْجُدُ لأَحَدٍ ، لأَمَرْت النِّسَائَ أَنْ یَسْجُدْنَ لأَزْوَاجِہِنَّ۔ (احمد 6/76۔ نسائی 9147)",,,8880,,
8881,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا قُرَّۃُ بْنُ خَالِدٍ السَّدُوسِیُّ ، عَنْ بَکْرِ بْنِ عَبْدِ اللہِ الْمُزَنِیّ ؛ أَنَّ عُمَرَ اسْتَأْذَنَ عَلَی عَبْدِ الرَّحْمَنِ بْنِ عَوْفٍ وَہُوَ یُصَلِّی فِی بَیْتِہِ ، فَقَالَ لَہُ عُمَرُ : أَوْجِزْ۔",,,8881,,
8882,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ رَجُلٍ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : إذَا جَلَسَ إلَی أَحَدِکُمْ رَجُلٌ وَہُوَ یُصَلِّی فَلْیَنْصَرِفْ۔",,,8882,,
8883,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا أَبُو جَنَابٍ یَحْیَی بْنُ أَبِی حَیَّۃَ الْکَلْبِیُّ، عَنْ أَبِی الْجُوَیرِیَّۃِ الْجَرْمِیِّ، قَالَ: جَلَسْنَا خَلْفَ ابْنِ عَبَّاسٍ وَہُوَ یُصَلِّی خَلْفَ الْمَقَامِ، وَعَلَیْہِ قَطِیفَۃٌ لَہُ، قَالَ: فَتَکَلَّمْنَا، فَلَمَّا سَمِعَ أَصْوَاتَنَا انْصَرَفَ۔",,,8883,,
8884,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا کَثِیرُ بْنُ زَیْدٍ ، عَنِ الْمُطَّلِبِ بْنِ عَبْدِ اللہِ بْنِ حَنْطَبٍ ، عَنْ زَیْدِ بْنِ ثَابِتٍ ؛ أَنَّہُ سُئِلَ عَنِ الْقِرَائَۃِ فِی الظُّہْرِ وَالْعَصْرِ ؟ فَقَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُطِیلُ الْقِیَامَ وَیُحَرِّکُ شَفَتَیْہِ۔ (احمد 5/186۔ طبرانی 4886)",,,8884,,
8885,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ عُمَارَۃَ ، عَنْ أَبِی مَعْمَرٍ ، قَالَ : قُلْنَا لِخَبَّابٍ : بِأَیِّ شَیْئٍ کُنْتُمْ تَعْرِفُونَ قِرَائَۃَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی الظُّہْرِ وَالْعَصْرِ ؟ قَالَ : بِاضْطِرَابِ لِحْیَتِہِ۔",,,8885,,
8886,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنِ الْحَسَنِ الْعُرَنِیِّ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقْرَأُ فِی الظُّہْرِ وَالْعَصْرِ۔ (ابوداؤد 805۔ احمد 1/234)",,,8886,,
8887,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إسْرَائِیلُ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ سَعْدِ بْنِ عِیَاضٍ الثُّمَالِیِّ ، قَالَ : مَا صَلَّیْت صَلاَۃً إِلاَّ قَرَأْت فِیہَا۔",,,8887,,
8888,حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ أَبِیہِ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَانَ یَکْرَہُ أَنْ یُحَلَّی الْمُصْحَفُ۔,,,8888,,
8889,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، قَالَ : أَتَیْتُ عَبْدَ الرَّحْمَن بْنَ أَبِی لَیْلَی بِتِبْرٍ ، فَقَالَ: ہَلْ عَسَیْت أَنـِّی أُحَلِّیَ بِہِ مُصْحَفًا۔",,,8889,,
8890,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : لاَ بَأْسَ أَنْ تُحَلَّی الْمَصَاحِفُ۔",,,8890,,
8891,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنَ ، عَنْ شُعَیْبِ بْنِ أَبِی سَعِیدٍ ، عَنْ أُبَیٍّ ، قَالَ : إذَا حَلَّیْتُمْ مَصَاحِفَکُمْ وَزَوَّقْتُمْ مَسَاجِدَکُمْ ، فَالدّبَارُ عَلَیْکُمْ۔",,,8891,,
8892,حَدَّثَنَا أَبُو أُسَامَۃَ، عَنِ الأَحْوَص بْنِ حَکِیمٍ، عَنْ أَبِی الزَّاہِرِیَّۃِ، عَنْ أَبِی أُمَامَۃَ؛ أَنَّہُ کَرِہَ أَنْ تُحَلَّی الْمَصَاحِفُ۔,,,8892,,
8893,"حَدَّثَنَا مُعَاذٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، أَنَّہُ قَالَ فِی السَّکْرَانِ یَؤُمُّ الْقَوْمَ ، قَالَ : إذَا أَتَمَّ بِہِمُ الرُّکُوعَ وَالسُّجُودَ فَقَدْ أَجْزَأَ عَنْہُ وَعَنْہُمْ ۔ وَقَالَ مُحَمَّدٌ : یُعِیدُونَ جَمِیعًا وَالإِمَام۔",,,8893,,
8894,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : حدَّثَنَا ابْنُ أَبِی ذِئْبٍ ، عَنْ مُسْلِمِ بْنِ جُنْدُبٍ ، عَنِ الْحَارِثِ بْنِ بَرْصَائَ ، قَالَ : أُتِیَ بِخُبَیْبٍ فَبِیعَ بِمَکَّۃَ ، فَأَخْرَجُوہُ مِنَ الْحَرَمِ لِیَقْتُلُوہُ ، فَقَالَ : دَعُونِی أُصَلِّی رَکْعَتَیْنِ ، فَتَرَکُوہُ ، فَصَلَّی رَکْعَتَیْنِ ، ثُمَّ قَالَ : لَوْلاَ أَنْ تَظُنُّوا بِی جَزَعًا لَزِدْتُ۔",,,8894,,
8895,"حَدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : لَمَّا اُنْطُلِقَ بِحُجْرٍ إلی مُعَاوِیَۃَ ، قَالَ : السَّلاَمُ عَلَیْک یَا أَمِیرَ الْمُؤْمِنِینَ ، قَالَ : وَأَمِیرُ الْمُؤْمِنِینَ أَنَا ؟ قَالَ : نَعَمْ ، قَالَ : لأَقْتُلَنَّکَ ، قَالَ : ثُمَّ أَمَرَ بِہِ لِیُقْتَلَ ، قَالَ : دَعُونِی أُصَلِّی رَکْعَتَیْنِ ، فَصَلَّی رَکْعَتَیْنِ تَجَوَّزَ فِیہِمَا ، فَقَالَ : لاَ تَرَوْنَ أَنِّی خَفَّفْتُہُمَا جَزَعًا ، وَلَکِنِّی کَرِہْت أَنْ أُطَوِّلَ عَلَیْکُمْ ، ثُمَّ قُتِلَ۔",,,8895,,
8896,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، قَالَ : الشَّفَقُ النَّہَارُ۔",,,8896,,
8897,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، قَالَ : کَتَبَ إلَیْنَا عُمَرُ بْنُ عَبْدِ الْعَزِیزِ : صَلُّوا الْمَغْرِبَ حِینَ فِطْر الصَّائِم ، ثُمَّ ذَکَرَ لِی : أَنَّ أُنَاسًا یُعَجِّلُونَ صَلاَۃَ الْعِشَائِ قَبْلَ أَنْ یَذْہَبَ بَیَاضُ الأُفُقِ مِنَ الْمَغْرِبِ ، فَلاَ تُصَلِّیہَا حَتَّی یَذْہَبَ بَیَاضُ الأُفُقِ مِنَ الْمَغْرِبِ ، وَتَغْشَی ظُلْمَۃُ اللَّیْلِ ، وَمَا عَجَّلْت بَعْدَ ذَہَابِ بَیَاضِ الأُفُقِ مِنَ الْمَغْرِبِ ، فَإِنَّہُ أَحْسَنُ وَأَصْوَبُ ، وَاعْلَمْ أَنَّ مِنْ تَمَامِہَا وَإِصَابَۃِ وَقْتِہَا مَا ذَکَرْتُ لَکَ فِی کِتَابِی ہَذَا مِنْ ذَہَابِ بَیَاضِ الأُفُقِ ، فَإِنَّہُ بَقِیَّۃٌ مِنْ بَقِیَّۃِ النَّہَارِ۔",,,8897,,
8898,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ مَعْمَرٍ ، عَنْ عَبْدِ اللہِ بْنِ عُثْمَانَ بْنِ خُثَیْمٍ ، عَنِ ابْنِ لبیبَۃَ ، قَالَ : قَالَ لِی أَبُو ہُرَیْرَۃَ : صَلِّ الْعِشَائَ إذَا ذَہَبَ الشَّفَقُ ، وَادْلاَمُ اللَّیْلِ مَا بَیْنَکَ وَبَیْنَ ثُلُثِ اللَّیْلِ ، وَمَا عَجَّلْت بَعْدَ ذَہَابِ بَیَاضِ الأُفُقِ فَہُوَ أَفْضَلُ۔",,,8898,,
8899,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ حَنْظَلَۃَ ، قَالَ : کَانَ طَاوُوس یُصَلِّی الْعِشَائَ قَبْلَ أَنْ یَغِیبَ الْبَیَاضُ۔",,,8899,,
8900,"حَدَّثَنَا یُونُسُ بْنُ مُحَمَّدِ بْنِ شَرِیکٍ ، عَنْ خُصَیْفٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : الشَّفَقُ مَا بَقِیَ مِنَ النَّہَارِ۔",,,8900,,
8901,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الأَسْوَدِ ؛ أَنَّ عَبْدَ اللہِ بْنَ رَبِیعَۃَ کَانَ یَؤُمُّ أَصْحَابَہُ فِی التَّطَوُّعِ ، فِی سِوَی رَمَضَانَ۔",,,8901,,
8902,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ مَحْمُودِ بْنِ رَبِیعٍ ، عَنْ عِتْبَانَ بْنِ مَالِکٍ ، أَنَّہُ قَالَ : یَا رَسُولَ اللہِ ، إنَّ السُّیُولَ تَحُولُ بَیْنِی وَبَیْنَ مَسْجِدِ قَوْمِی ، فَأُحِبُّ أَنْ تَأْتِیَ فَتُصَلِّیَ فِی مَکَان مِنْ بَیْتِی أتَّخِذُہُ مَسْجِدًا ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : سَنَفْعَلُ ، فَلَمَّا أَصْبَحَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ غَدَا عَلَی أَبِی بَکْرٍ فَاسْتَتْبَعَہُ ، فَلَمَّا دَخَلَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : أَیْنَ تُرِیدُ ؟ فَأَشَرْتُ لَہُ إلَی نَاحِیَۃٍ مِنَ الْبَیْتِ ، فَقَامَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَصَفَّفْنَا خَلْفَہُ ، فَصَلَّی بِنَا رَکْعَتَیْنِ۔ (بخاری 424۔ مسلم 455)",,,8902,,
8903,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ الرَّبِیعِ بْنِ بَدْرٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، عَنْ أَبِی مُوسَی ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : الاثْنَانِ فَمَا فَوْقَہُمَا جَمَاعَۃٌ۔ (ابن ماجہ 972۔ ابو یعلی 7188)",,,8903,,
8904,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا ہِشَامٌ الدَّسْتَوَائِیُّ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا صَلَّی الرَّجُلُ مَعَ الرَّجُلِ فَہُمَا جَمَاعَۃٌ ، لَہُمَا التَّضْعِیفُ خَمْسٌ وَعِشْرُونَ دَرَجَۃً۔",,,8904,,
8905,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : الثَّلاَثَۃُ جَمَاعَۃٌ۔",,,8905,,
8906,"حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنِ الْعَلاَئِ بْنِ عَبْدِ الْکَرِیمِ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا حَکَکْت شَیْئًا مِنْ جَسَدِکَ وَأَنْتَ رَاکِعٌ ، فَلاَ تَرْفَعْ رَأْسَک حَتَّی تُعِیدَ یَدَک إلَی مَوْضِعِہَا۔",,,8906,,
8907,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنِ الشَّعْبِیِّ ؛ فِی رَجُلٍ قَالَ : ہَاہْ فِی الصَّلاَۃ ، قَالَ : یُعِیدُ۔",,,8907,,
8908,حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَرِہَ التَّأَوُّہَ فِی الصَّلاَۃ۔,,,8908,,
8909,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ ابْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ؛ أَنَّہُ کَرِہَ الزَّفْرَ فِی الصَّلاَۃ ، قَالَ : یُشَبَّہُ بِالْکَلاَمِ۔",,,8909,,
8910,"حَدَّثَنَا حَاتِم بْنُ إسْمَاعِیلَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ حَرْمَلَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : مَرَّ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَلَی بِلاَلٍ وَہُوَ یَقْرَأُ مِنْ ہَذِہِ السُّورَۃِ ، وَمِنْ ہَذِہِ السُّورَۃِ ، فَقَالَ : مَرَرْت بِکَ یَا بِلاَلُ وَأَنْتَ تَقْرَأُ مِنْ ہَذِہِ السُّورَۃِ ، وَمِنْ ہَذِہِ السُّورَۃِ ، فَقَالَ : بِأَبِی أَنْتَ یَا رَسُولَ اللہِ ، إنِّی أَرَدْتُ أَنْ أَخْلِطَ الطَّیِّبَ بِالطَّیِّبِ ، قَالَ : اقْرَإِ السُّورَۃَ عَلَی نَحْوِہَا۔ (ابوداؤد 1324۔ عبدالرزاق 4210)",,,8910,,
8911,"حَدَّثَنَا شَرِیکٌ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : کَانَ عَمَّارٌ یَخْلِطُ مِنْ ہَذِہِ السُّورَۃِ وَمِنْ ہَذِہِ السُّورَۃِ فَقِیلَ لَہُ ؟ فَقَالَ : أَتَرَوْنی أَخْلِطُ فِیہِ مَا لَیْسَ مِنْہُ ؟",,,8911,,
8912,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : سُئِلَ مُحَمَّدٌ عَنِ الَّذِی یَقْرَأُ مِنْ ہَاہُنَا ، وَمِنْ ہَاہُنَا ؟ فَقَالَ : لِیُتقی ، لاَ یَأْثم إِثْمًا عَظِیمًا وَہُوَ لاَ یَشْعُرُ۔",,,8912,,
8913,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، قَالَ : حدَّثَنَا الْوَلِیدُ بْنُ جُمَیْعٍ ، قَالَ : حَدَّثَنِی رَجُلٌ أَثِقُ بِہِ ؛ أَنَّہُ أَمَّ النَّاسَ بِالْحِیرۃِ خَالِدُ بْنُ الْوَلِیدِ فَقَرَأَ مِنْ سُوَرٍ شَتَّی ، ثُمَّ الْتَفَتَ إلَیْنَا حِینَ انْصَرَفَ ، فَقَالَ : شَغَلَنِی الْجِہَادُ عَنْ تَعَلُّمِ الْقُرْآنِ۔",,,8913,,
8914,حَدَّثَنَا ابْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ، عَنِ الْحَسَنِ؛ أَنَّہُ کَانَ یَکْرَہُ أَنْ یَقْرَأَ مِنْ سُورَتَیْنِ حَتَّی یَخْتِمَ وَاحِدَۃً، ثُمَّ یَأْخُذَ فِی أُخْرَی۔,,,8914,,
8915,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنْ مُحَمَّدٍ ، قَالَ : کَانُوا یَقُولُونَ فِی الَّذِی یُصَلِّی بِغَیْرِ قِرَائَۃٍ قَوْلاً شَدِیدًا ، أَہَابُ أَنْ أَقُولَہُ۔",,,8915,,
8916,"حَدَّثَنَا ابْنُ أَبِی عَدِیٍّ، عَنْ أَشْعَثَ، عَنِ الْحَسَنِ، قَالَ: إذَا لَمْ یَقْرَإِ الإِمَام، وَلاَ مَنْ خَلْفَہُ أَعَادُوا الصَّلاَۃ کُلُّہُمْ۔",,,8916,,
8917,"حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنِ ابْنِ عَوْنٍ، عَنْ إبْرَاہِیمَ، قَالَ: لَوْ صَلَّیْت خَلْفَ رَجُلٍ لاَ أَعْلَمُ أَنَّہُ یَقْرَأُ أَعَدْت صَلاَتِی۔",,,8917,,
8918,"حَدَّثَنَا أَزْہَرُ السَّمَّانُ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَانَ مُحَمَّدٌ یَکْرَہُ أَنْ یَقُولَ : فَاتَتْنَا الصَّلاَۃ ، وَیَقُولُ : لَمْ أُدْرِکْ مَعَ بَنِی فُلاَنٍ۔",,,8918,,
8919,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنٍ ، عَنْ لَیْثٍ ، قَالَ : کَانَ طَاوُوس یُخَوِّی إذَا سَجَدَ ، وَیُجَافِی مِرْفَقَیْہِ عَنْ فَخِذَیْہِ إذَا رَکَعَ۔",,,8919,,
8920,"حَدَّثَنَا حُمَیْدٌ ، عَنْ حَسَنٍ ، عَنْ لَیْثٍ ، قَالَ : کَانَ نَافِعٌ یُجَافِی مِرْفَقَیْہِ عَنْ فَخِذَیْہِ۔",,,8920,,
8921,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا حُمَیْدٌ ، عَنْ حَسَنٍ ، عَنْ لَیْثٍ ، قَالَ : رَأَیْتُ مُجَاہِدًا یُجَافِی مِرْفَقَیْہِ عَنْ عَارِضِ فَخِذَیْہِ ، وَہُوَ سَاجِدٌ فِی الصَّلاَۃ ، وَرَأَیْتُ عَطَائً یَفْعَلُ مِثْلَ ذَلِکَ۔",,,8921,,
8922,"حَدَّثَنَا وَکِیعٌ، عَنْ إسْرَائِیلَ، عَنْ جَابِرٍ، عَنْ عَامِرٍ، وَمُحَمَّدِ بْنِ عَلِیٍّ، وَعَطَائٍ، وَطَاوُوس، وَالْقَاسِمِ، وَمُجَاہِدٍ، قَالُوا: لاَ بَأْسَ أَنْ یُصَلِّیَ الرَّجُلُ الْمَکْتُوبَۃَ وَغَیْرَہَا وَفِی کُمِّہِ الأَلْوَاحُ ، وَالصَّحِیفَۃُ فِیہَا الشَّعَرُ وَأَشْبَاہُہُ۔",,,8922,,
8923,"حَدَّثَنَا شَرِیکٌ، عَنْ جَابِرٍ، عَنْ أَبِی جَعْفَرٍ، قَالَ: لاَ بَأْسَ أَنْ یُصَلِّیَ الرَّجُلُ وَفِی حُجْزَتِہِ الأَلْوَاحُ وَالصَّحِیفَۃُ۔",,,8923,,
8924,حَدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ ، عَنِ الْقَاسِمِ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ یُصَلِّیَ وَفِی حُجْزَتِہِ الدَّرَاہِمُ۔,,,8924,,
8925,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الشَّیْبَانِیِّ ، عَنْ یُسَیرِ بْنِ عَمْرٍو ؛ أَنَّہُ کَانَ لاَ یَحُطُّ إذَا سَجَدَ۔,,,8925,,
8926,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا ہِشَامُ بْنُ عُرْوَۃَ ، عَنْ أَبِیہِ ؛ أَنَّ عُمَرَ أَرَادَ أَنْ لاَ یُحَصِّبَ الْمَسْجِدَ ، فَأَشَارَ عَلَیْہِ سُفْیَانُ بْنُ عَبْدِ اللہِ الثَّقَفِیُّ ، قَالَ : بَلَی ، یَا أَمِیرَ الْمُؤْمِنِینَ ، فَإِنَّہُ أَغْفَرُ لِلنُّخَامَۃِ وَأَوْطَأُ لِلْمَجْلِسِ ، فَقَالَ عُمَرُ : احْصِبُوہُ۔",,,8926,,
8927,"حَدَّثَنَا عَبْدُ الرَّزَّاقِ ، عَنْ مَعْمَرٍ ، عَنِ ابْنِ طَاوُوس ، قَالَ : کَانَ أَبِی فِی مَکَانٍ لَیْسَ بِنَظِیفٍ ، وَحَضَرَتْہُ ، فَأَمَرَ بِبِسَاطٍ فَبُسِطَ ، ثُمَّ صَلَّی عَلَیْہِ۔",,,8927,,
8928,"حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، قَالَ : رَآنِی مُجَاہِدٌ وَأَنَا أَنْضَحُ مَکَانًا مِنْ سَطْحٍ لَنَا نُصَلِّی فِیہِ ، فَقَالَ : لاَ تَنْضَحْ ، إنَّ النَّضْحَ لاَ یَزِیدُہُ إِلاَّ شَرًّا ، وَلَکِنِ انْظُرْ إلَی الْمَکَانِ الَّذِی تُرِیدُہُ تَسْجُدُ فِیہِ فَانْفُخْہُ۔",,,8928,,
8929,"حَدَّثَنَا أَبُو الأَحْوَصِ، عَنْ أَبِی إِسْحَاقَ، عَنِ الْحَارِثِ، عَنْ عَلِیٍّ، قَالَ: کَانَ عَلِیٌّ یَقُولُ بَیْنَ السَّجْدَتَیْنِ: رَبِّ اغْفِرْ لِی وَارْحَمْنِی وَاجْبُرْنِی وَارْفَعْنِی۔",,,8929,,
8930,"حَدَّثَنَا مُعْتَمِر بْنُ سُلَیْمَانَ ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ؛ أَنَّہُ کَانَ یَقُولُ بَیْنَ السَّجْدَتَیْنِ : اللَّہُمَّ اغْفِرْ لِی وَارْحَمْنِی وَاجْبُرْنِی وَارْزُقْنِی۔ (ترمذی 284۔ احمد 315)",,,8930,,
8931,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ أَبِی ہِلاَلٍ ، عَنْ قَتَادَۃَ ، عَنْ أُمِّ الْحَسَنِ ، عَنْ أُمِّ سَلَمَۃَ ، أَنَّہَا کَانَتْ تَقُولُ بَیْنَ الرَّکْعَتَیْنِ ، أَوِ السَّجْدَتَیْنِ : اللَّہُمَّ اغْفِرْ وَارْحَمْ وَاہْدِ السَّبِیلَ الأَقْوَمَ۔",,,8931,,
8932,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ طَاوُوس ، قَالَ : کَانَ أَبِی یَقْرَأُ بَیْنَ السَّجْدَتَیْنِ قُرْآنًا کَثِیرًا۔",,,8932,,
8933,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ مُحَمَّدِ بْنِ مُسْلِمٍ ، عَنْ رَجُلٍ ، عَنْ عَطَائٍ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَقُولُ بَیْنَ السَّجْدَتَیْنِ : أَسْتَغْفِرُ اللَّہَ ، أَسْتَغْفِرُ اللَّہَ۔ (ابوداؤد 870۔ نسائی 656)",,,8933,,
8934,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : لَیْسَ فِیہِ شَیْئٌ مُوقتٌ۔",,,8934,,
8935,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، قَالَ : سَأَلْتُ إبْرَاہِیمَ : أَقْرَأُ بَیْنَ السَّجْدَتَیْنِ شَیْئًا ؟ قَالَ : لاَ۔",,,8935,,
8936,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ إسْمَاعِیلَ بْنِ أُمَیَّۃَ ، عَنْ أَبِی مُحَمَّدِ بْنِ عَمْرِو بْنِ حُرَیْثٍ ، عَنْ جَدِّہِ ، سَمِعَ أَبَا ہُرَیْرَۃَ یَقُولُ : إذَا صَلَّی أَحَدُکُمْ فِی أَرْضِ فَلاَۃٍ فَلْیَنْصِبْ عَصًا ، فَإِنْ لَمْ یَکُنْ مَعَہُ عَصًا فَلْیَخُطَّ خَطًّا بِالأَرْضِ ، وَلاَ یَضُرُّہُ مَا مَرَّ بَیْنَ یَدَیْہِ ، قَالَ أَبُو الْقَاسِمِ : یَعْنِی رِوَایَۃً۔ (ابوداؤد 690۔ ابن ماجہ 943)",,,8936,,
8937,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللہِ الأَسَدِیُّ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ مُسْلِمٍ ، عَنْ إبْرَاہِیمَ بْنِ مَیْسَرَۃَ ، قَالَ : أَرَادَ إنْسَانٌ أَنْ یَنْصِبَ بَیْنَ یَدَیْ طَاوُوس شَیْئًا وَہُوَ یَؤُمُّنَا ، فَمَنَعَہُ۔",,,8937,,
8938,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حدَّثَنَا أَبُو ہِلاَلٍ ، قَالَ : حَدَّثَنَا حُمَیْدُ بْنُ ہِلاَلٍ ، عَنْ أَبِی بُرْدَۃَ ؛ أَنَّ أَبَا مُوسَی الأَشْعَرِیَّ دَخَلَ عَلَی أُخْتِہِ وَہِیَ تَسْجُدُ مِنْ غَیْرِ رُکُوعٍ ، فَلَمْ یَعِبْ ذَلِکَ عَلَیْہَا۔",,,8938,,
8939,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ مُسْلِمٍ ، عَنْ مَسْرُوقٍ ؛ أَنَّہُ رَأَی رَجُلاً یُصَلِّی فِی رَکْعَۃٍ ثَلاَثَ سَجَدَاتٍ ، فَقَالَ : إنَّ اللَّہَ رَضِیَ لِکُلِّ رَکْعَۃٍ بِسَجْدَتَیْنِ۔",,,8939,,
8940,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْحَکَمِ ، عَنْ إبْرَاہِیمَ ، قَالَ : أَرْبَعٌ لاَ یَجْہَرُ بِہِنَّ الإِمَام ؛ بِسْمِ اللہِ الرَّحْمَن الرَّحِیم ، وَالاسْتِعَاذَۃُ ، وَآمِینَ ، وَاللَّہُم رَبَّنَا لَکَ الْحَمْدُ۔",,,8940,,
8941,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : خَمْسٌ یُخْفِیہِنَّ الإِمَام ؛ الاسْتِعَاذَۃُ ، وَسُبْحَانَک اللَّہُمَّ وَبِحَمْدِکَ ، وَبِسْمِ اللہِ الرَّحْمَن الرَّحِیمِ ، وَآمِینَ ، وَاللَّہُمَّ رَبَّنَا لَکَ الْحَمْدُ۔",,,8941,,
8942,حَدَّثَنَا وَکِیعٌ ، عَنْ رَبِیعٍ ، عَنِ الْحَسَنِ ، وَابْنِ سِیرِینَ ؛ أَنَّہُمَا کَانَا یُخْفِیَانِ الاسْتِعَاذَۃَ۔,,,8942,,
8943,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، قَالَ : سَمِعْتُ عُمَرَ یَقُولُ : إذَا افْتَتَحَ الصَّلاَۃ سُبْحَانَک اللَّہُمَّ وَبِحَمْدِکَ وَتَبَارَکَ اسْمُک وَتَعَالَی جَدُّک ، وَلاَ إلَہَ غَیْرُک ، قَالَ الأَسْوَدُ : یُسْمِعَنَاہَا۔",,,8943,,
8944,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حُصَیْنٌ ، وَمُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ، قَالَ : یُخْفِی الإِمَام بِسْمِ اللہِ الرَّحْمَن الرَّحِیم ، وَالاسْتِعَاذَۃَ ، وَآمِینَ ، وَرَبَّنَا لَکَ الْحَمْدُ۔",,,8944,,
8945,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ سَعْدِ بْنِ مَرْزَبَانَ ، قَالَ : حدَّثَنَا أَبُو وَائِلٍ ، عَنْ عَبْدِ اللہِ ؛ أَنَّہُ کَانَ یُخْفِی بِسْمِ اللہِ الرَّحْمَن الرَّحِیم ، وَالاسْتِعَاذَۃَ ، وَرَبَّنَا لَکَ الْحَمْدُ۔",,,8945,,
8946,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ جَعْفَرٍ الأَحْمَر ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : مَا جَرَی عَلَی لِسَانِ الإِنْسَان فِی الصَّلاَۃ مِمَّا لَہُ أَصْلٌ فِی الْقُرْآنِ ، فَلَیْسَ بِکَلاَمٍ۔",,,8946,,
8947,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ ، قَالَ : رَأَیْتُ أَبَا قِلاَبَۃَ عَلَیْہِ جُبَّۃٌ وَمِلْحَفَۃٌ غَسِیلَۃٌ ، وَہُوَ یُصَلِّی مُضْطَبِِعًا ، قَدْ أَخْرَجَ یَدَہُ الْیُمْنَی۔",,,8947,,
8948,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : قِیلَ لِلْحَسَنِ : إنَّہُمْ یَقُولُونَ : یُکْرَہُ أَنْ یُصَلِّیَ الرَّجُلُ وَقَدْ أَخْرَجَ یَدَہُ مِنْ عِنْدِ نَحْرِہِ ، قَالَ الْحَسَنُ : لَوْ وَکَّلَ اللَّہُ دِینَہُ إلَی ہَؤُلاَئِ لَضَیَّقُوا عَلَی عِبَادِہِ۔",,,8948,,
8949,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ الْجُرَیْرِیِّ ، عَنْ حَیََّانَ بْنِ عُمَیْرٍ ، قَالَ : کُنْتُ مَعَ قَیْسِ بْنِ عُبَادٍ ، فَرَأَی رَجُلاً یُصَلِّی قَدْ أَخْرَجَ یَدَہُ مِنْ عِنْدِ نَحْرِہِ ، فَقَالَ : اذْہَبْ إلَی ذَلِکَ فَقُلْ لَہُ : یَضَعُ یَدَہُ مِنْ مَکَانِ یَدِ الْمَغْلُولِ ، فَأَتَیْتُہُ، فَقُلْتُ : إنَّ قَیْسًا یَقُولُ : ضَعْ یَدَک مِنْ مَکَانِ یَدِ الْمَغْلُولِ ، فَوَضَعَہَا۔",,,8949,,
8950,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ مُسْلِمٍ ، عَنْ إبْرَاہِیمَ بْنِ مَیْسَرَۃَ ، عَنْ طَاوُوسٍ ، قَالَ : لَقَدْ رَأَیْتُہُ یُصَلِّی ضَابِعًا بُرْدَہُ مِنْ تَحْتِ عَضُدِہِ۔",,,8950,,
8951,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَن الشَّیبَانِی ، عَنْ عِکْرِمَۃَ ، قَالَ : قَالَ عُمَرُ : لاَ یَضُرُّہُ لَوِ الْتَحَفَ بِہِ حَتَّی یُخْرِج إحْدَی یَدَیْہِ۔",,,8951,,
8952,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، قَالَ : إِنْ کَانَ عَلَیْک قَمِیصٌ وَمِلْحَفَۃٌ فَتَوَشَّحْ بِالْمِلْحَفَۃِ ، وَإِنْ کَانَ تُبَّانٌ وَمِلْحَفَۃٌ فَالْتَفِعْ بِالْمِلْحَفَۃِ",,,8952,,
8953,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ فُضَیْلٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا کَانَ عَلَیْک قَمِیصٌ دَقِیقٌ وَمِلْحَفَۃٌ فَتَوَشَّحْ بِالْمِلْحَفَۃِ ، وَإِنْ کَانَ قَمِیصٌ ضَیِّقٌ وَمِلْحَفَۃٌ فَالْتَفِعْ بِالْمِلْحَفَۃِ۔",,,8953,,
8954,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ الْعَوَّامِ ، عَنْ عَبْدِ الْمَلِکِ التَّیْمِیِّ ، عَنْ إبْرَاہِیمَ ، قَالَ : مُبْتَدَأُ الصَّفِّ قَصْدُ الإِمَام ، فَإِنْ لَمْ یَکُنْ مَعَ الإِمَامِ إِلاَّ وَاحِدٌ أَقَامَہُ خَلْفَہُ مَا بَیْنَہُ وَبَیْنَ أَنْ یَرْکَعَ ، فَإِنْ جَائَ أَحَدٌ یُصَلِّی بِہِ ، وَإِنْ لَمْ یَأْتِ أَحَدٌ حَتَّی یَرْکَعَ لَحِقَ الإِمَام فَقَامَ عَنْ یَمِینِہِ ، وَإِنْ جَائَ وَالصَّفُّ تَامٌّ فَلْیَقُمْ قَصْدَ الإِمَام ، فَإِنْ جَائَ أَحَدٌ یُصَلِّی بِہِ ، وَإِنْ لَمْ یَجِیئْ أَحَدٌ فَلْیَدْخُلْ فِی الصَّفِّ ، ثُمَّ کَذَاک وَکَذَاک۔",,,8954,,
8955,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : حدَّثَنَا یُونُسُ ، عَنِ الْحَسَنِ ، قَالَ : إذَا جَائَ وَقَدْ تَمَّ الصَّفُّ فَلْیَقُمْ بِحِذَائِ الإِمَام۔",,,8955,,
8956,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ أَبِیہِ ، قَالَ : سَأَلْتُ ابْنَ سِیرِینَ عَنِ الْمَرْأَۃِ تَکُونُ حَیْضَتُہَا أَیَّامًا مَعْلُومَۃً ، فَتَزِیدُ عَلَی ذَلِکَ ؟ قَالَ : النِّسَائُ أَعْلَمُ بِذَلِکَ۔\n\nقَالَ : وَسَأَلْت قَتَادَۃَ ، قُلْتُ : الْمَرْأَۃُ تَحِیضُ الأَیَّامَ الْمَعْلُومَۃَ ، فَتَزِیدُ عَلَی خَمْسَۃِ أَیَّامٍ ؟ قَالَ : تُصَلِّی ، قُلْتُ : فَأَرْبَعَۃُ أَیَّامٍ ؟ قَالَ : تُصَلِّی ، قُلْتُ : فَثَلاَثَۃُ أَیَّامٍ ؟ قَالَ : تُصَلِّی ، قُلْتُ : فَیَوْمَیْنِ ؟ قَالَ : ذَاکَ مِنْ حَیْضِہَا ، فَرَأَیْتُہُ قَالَ بِرَأْیِہِ۔",,,8956,,
8957,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا إبْرَاہِیمُ بْنُ الزِّبْرِقَانِ ، عَنِ الشَّیْبَانِیِّ ، عَنْ مُوسَی بْنِ أَبِی کَثِیرٍ ، عَنْ طَاوُوسٍ ، قَالَ : إذَا زَادَتِ الْمَرْأَۃُ عَلَی حَیْضِہَا فَلْتَغْتَسِلْ ۔ وَقَالَ حَمَّادٌ فِی الْمَرْأَۃ تُجَاوِزُ أَیَّامَ حَیْضَتِہَا ، قَالَ : لاَ تَغْتَسِلُ ، فَإِنَّ الْمَرْأَۃَ رُبَّمَا فَعَلَتْ ذَلِکَ۔",,,8957,,
8958,"حَدَّثَنَا حُمَیْدٌ ، عَنِ الْحَسَنِ بْنِ صَالِحٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، عَنْ عُثْمَانَ بْنِ أَبِی الْعَاصِ ، قَالَ : إذَا رَأَتِ الْمَرْأَۃُ الصُّفْرَۃَ فِی أَیَّامِ غَیْرِ حَیْضَتِہَا ، قَالَ : إذَا زَادَتْ عَلَی أَیَّامِ حَیْضَتِہَا یَوْمًا ، أَوْ یَوْمَیْنِ ، عَدَّتْہُ مِنْ حَیْضَتِہَا ، فَإِنْ زَادَتْ عَلَی یَوْمَیْنِ فَہِیَ مُسْتَحَاضَۃٌ ، إذَا کَانَتْ تَحِیضُ سِتَّۃَ أَیَّامٍ فَرَأَتِ الدَّمَ ثَمَانیَۃَ أَیَّامٍ عَدَّتْہُ مِنْ حَیْضَتِہَا ، فَإِنْ رَأَتْہُ أَکْثَرَ مِنْ ثَمَانِیَۃِ أَیَّامٍ فَہِیَ مُسْتَحَاضَۃٌ۔",,,8958,,
