metadata:
  section_id: 16
  section_name: رسول اللہ صلی اللہ علیہ وسلم کی زرہ کا بیان
  hadith_first: 106
  hadith_last: 107

hadiths[2]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
106,"""Allah’s Messenger (Allah bless him and give him peace) entered Mecca on the Day of Victory with gold and silver on his sword. An inquirer said: 'I asked him about the silver', and he said: ‘The pommel of the sword was silver'.”",,,106,"Hud (i.e. Ibn 'Abdi’llah ibn Sa'd) reports that his grandfather said:",رسول اللہ صلی اللہ علیہ وسلم کی زرہ کا بیان
107,"""I made my sword in the shape of the sword of Samura ibn Jundub."" Samura also claimed that he made his sword in the shape of the sword of Allah’s Messenger (Allah bless him and give him peace), for he was a Hanafi.",,,107,"Ibn Sirin said:",رسول اللہ صلی اللہ علیہ وسلم کی زرہ کا بیان
