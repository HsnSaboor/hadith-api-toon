{"hadithnumber": "3929", "text": "ابوزبیر نے حضرت جابر رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  رسول اللہ صلی اللہ علیہ وسلم نے خال"}
{"hadithnumber": "3930", "text": "سعید بن منصور ،  ابوبکر بن ابی شیبہ ،  عمرو ناقد اور زہیر بن حرب نے کہا :  ہمیں سفیان بن عیینہ نے حم"}
{"hadithnumber": "3931", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ،  انہوں نے کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :"}
{"hadithnumber": "3932", "text": "حضرت جابر بن عبداللہ رضی اللہ عنہ نے خبر دی کہ انہوں نے رسول اللہ صلی اللہ علیہ وسلم سے سنا ،  آپ مز"}
{"hadithnumber": "3933", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ،  انہوں نے کہا :  رسول اللہ صلی اللہ علیہ وسلم نے محاقلہ اور"}
{"hadithnumber": "3934", "text": "حضرت ابوسعید خدری رضی اللہ عنہ کہتے ہیں :  رسول اللہ صلی اللہ علیہ وسلم نے مزابنہ اور محاقلہ سے منع"}
{"hadithnumber": "3935", "text": "حماد بن زید نے ہمیں عمرو  ( بن دینار )  سے خبر دی ،  انہوں نے کہا :  میں نے حضرت ابن عمر رضی اللہ عن"}
{"hadithnumber": "3936", "text": "سفیان  ( بن عیینہ )  ،  ایوب اور سفیان  ( ثوری )  سب نے عمرو بن دینار سے اسی سند کے ساتھ اسی کے مانن"}
{"hadithnumber": "3937", "text": "مجاہد سے روایت ہے ،  انہوں نے کہا :  حضرت ابن عمر رضی اللہ عنہ نے کہا :  رافع رضی اللہ عنہ نے ہماری"}
{"hadithnumber": "3938", "text": "یزید بن زریع نے ہمیں ایوب سے خبر دی اور انہوں نے نافع سے روایت کی کہ رسول اللہ صلی اللہ علیہ وسلم کے"}
{"hadithnumber": "3939", "text": "حماد بن زید اور اسماعیل  ( ابن علیہ )  دونوں نے ایوب سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی او"}
{"hadithnumber": "3940", "text": "عبیداللہ نے ہمیں نافع سے حدیث بیان کی ،  انہوں نے کہا :  میں حضرت ابن عمر رضی اللہ عنہ کے ساتھ حضرت"}
{"hadithnumber": "3941", "text": "حکم نے نافع سے اور انہوں نے حضرت ابن عمر رضی اللہ عنہ سے روایت کی کہ وہ حضرت رافع رضی اللہ عنہ کے پا"}
{"hadithnumber": "3942", "text": "حسین بن حسن بن یسار نے ہمیں حدیث بیان کی ،  کہا :  ہمیں ابن عون نے نافع سے حدیث بیان کی کہ حضرت ابن"}
{"hadithnumber": "3943", "text": "یزید بن ہارون نے کہا :  ہمیں ابن عون نے اسی سند کے ساتھ حدیث بیان کی اور کہا :  انہوں نے اپنے بعض چچ"}
{"hadithnumber": "3944", "text": "سالم بن عبداللہ نے خبر دی کہ حضرت عبداللہ بن عمر رضی اللہ عنہ اپنی زمینیں کرائے پر دیتے تھے حتی کہ ا"}
{"hadithnumber": "3945", "text": "اسماعیل بن علیہ نے ہمیں ایوب سے حدیث بیان کی ،  انہوں نے یعلیٰ بن حکیم سے ،  انہوں نے سلیمان بن یسار"}
{"hadithnumber": "3946", "text": "حماد بن زید نے ہمیں ایوب سے خبر دی ،  انہوں نے کہا :  یعلیٰ بن حکیم نے میری طرف لکھا ،  انہوں نے کہا"}
{"hadithnumber": "3947", "text": "ابن ابی عروبہ نے یعلیٰ بن حکیم سے اسی سند کے ساتھ اسی کے مانند روایت بیان کی"}
{"hadithnumber": "3948", "text": "جریر بن حازم نے یعلیٰ بن حکیم کی اسی سند کے ساتھ روایت کی ،  انہوں نے  ( سلیمان کے واسطے سے )  رافع"}
{"hadithnumber": "3949", "text": "ابوعمرو اوزاعی نے مجھے رافع بن خدیج رضی اللہ عنہ کے آزاد کردہ غلام ابونجاشی سے حدیث بیان کی اور انہو"}
{"hadithnumber": "3950", "text": "عکرمہ بن عمار نے ابونجاشی سے ،  انہوں نے حضرت رافع رضی اللہ عنہ سے اور انہوں نے نبی صلی اللہ علیہ وس"}
{"hadithnumber": "3951", "text": "امام مالک نے ربیعہ بن ابی عبدالرحمٰن سے اور انہوں نے حنظلہ بن قیس سے روایت کی کہ انہوں نے حضرت رافع"}
{"hadithnumber": "3952", "text": "اوزاعی نے ہمیں ربیعہ بن ابی عبدالرحمٰن سے حدیث بیان کی ،  کہا :  مجھے حنظلہ بن قیس انصاری نے حدیث سن"}
{"hadithnumber": "3953", "text": "سفیان بن عیینہ نے ہمیں یحییٰ بن سعید سے حدیث بیان کی ،  انہوں نے حنظلہ زُرَقی سے روایت کی کہ انہوں ن"}
{"hadithnumber": "3954", "text": "حماد اور یزید بن ہارون نے یحییٰ بن سعید سے اسی سند کے ساتھ اسی کے ہم معنی حدیث بیان کی"}
{"hadithnumber": "3955", "text": "یحییٰ بن یحییٰ نے کہا :  ہمیں عبدالواحد بن زیاد نے خبر دی ،  نیز ابوبکر بن ابی شیبہ نے کہا :  ہمیں ع"}
{"hadithnumber": "3956", "text": "ابوعوانہ نے ہمیں سلیمان شیبانی سے خبر دی ،  انہوں نے عبداللہ بن سائب سے روایت کی ،  انہوں نے کہا :"}
{"hadithnumber": "3957", "text": "حماد بن زید نے ہمیں عمرو  ( بن دینار )  سے خبر دی کہ مجاہد نے طاوس سے کہا :  ہمارے ساتھ حضرت رافع بن"}
{"hadithnumber": "3958", "text": "سفیان نے ہمیں عمرو اور ابن طاوس سے حدیث بیان کی اور انہوں نے طاوس سے روایت کی کہ وہ  ( نقدی کے عوض )"}
{"hadithnumber": "3959", "text": "ایوب ،  سفیان ،  ابن جریج اور شعبہ سب نے عمرو بن دینار سے ،  انہوں نے طاوس سے ،  انہوں نے حضرت ابن ع"}
{"hadithnumber": "3960", "text": "معمر نے ابن طاوس سے ،  انہوں نے اپنے والد سے اور انہوں نے حضرت ابن عباس رضی اللہ عنہ سے روایت کی کہ"}
{"hadithnumber": "3961", "text": "عبدالملک بن زید نے طاوس سے ،  انہوں نے حضرت ابن عباس رضی اللہ عنہ سے اور انہوں نے نبی صلی اللہ علیہ"}
