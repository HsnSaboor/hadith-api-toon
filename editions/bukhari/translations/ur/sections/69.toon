{"hadithnumber": "5351", "text": "ہم سے آدم بن ابی ایاس نے بیان کیا، کہا ہم سے شعبہ نے بیان کیا، ان سے عدی بن ثابت نے بیان کیا کہا میں"}
{"hadithnumber": "5352", "text": "ہم سے اسماعیل بن ابی اویس نے بیان کیا، انہوں نے کہا کہ مجھ سے امام مالک نے بیان کیا، ان سے ابوالزناد"}
{"hadithnumber": "5353", "text": "ہم سے یحییٰ بن قزعہ نے بیان کیا، کہا ہم سے امام مالک نے بیان کیا، ان سے ثور بن زید نے، ان سے ابوالغی"}
{"hadithnumber": "5354", "text": "ہم سے محمد بن کثیر نے بیان کیا، کہا ہم کو سفیان ثوری نے خبر دی، انہیں سعید بن ابراہیم نے، ان سے عامر"}
{"hadithnumber": "5355", "text": "ہم سے عمرو بن حفص نے بیان کیا۔ کہا ہم سے ہمارے والد نے بیان کیا، ان سے اعمش نے بیان کیا، ان سے ابوصا"}
{"hadithnumber": "5356", "text": "ہم سے سعید بن عفیر نے بیان کیا، کہا کہ مجھ سے لیث بن سعد نے بیان کیا، کہا کہ مجھ سے عبدالرحمٰن بن خا"}
{"hadithnumber": "5357", "text": "ہم سے محمد بن سلام نے بیان کیا، کہا ہم کو وکیع نے خبر دی، ان سے ابن عیینہ نے کہا کہ مجھ سے معمر نے ب"}
{"hadithnumber": "5358", "text": "ہم سے سعید بن عفیر نے بیان کیا، کہا کہ مجھ سے لیث بن سعد نے بیان کیا، کہا کہ مجھ سے عقیل نے بیان کیا"}
{"hadithnumber": "5359", "text": "ہم سے محمد بن مقاتل نے بیان کیا، کہا ہم کو عبداللہ بن مبارک نے خبر دی، انہیں یونس بن یزید نے، انہیں"}
{"hadithnumber": "5360", "text": "ہم سے یحییٰ بن موسیٰ نے بیان کیا، کہا ہم سے عبدالرزاق نے بیان کیا، ان سے معمر بن راشد نے، ان سے ہمام"}
{"hadithnumber": "5361", "text": "ہم سے مسدد نے بیان کیا، کہا ہم سے یحییٰ نے بیان کیا، ان سے شعبہ نے، کہا کہ مجھ سے حکم نے بیان کیا، ا"}
{"hadithnumber": "5362", "text": "ہم سے عبداللہ بن زبیر حمیدی نے بیان کیا، کہا ہم سے سفیان بن عیینہ نے بیان کیا، کہا ہم سے عبیداللہ بن"}
{"hadithnumber": "5363", "text": "ہم سے محمد بن عرعرہ نے بیان کیا، کہا ہم سے شعبہ نے بیان کیا، ان سے حکم بن عتبہ نے، ان سے ابراہیم نے،"}
{"hadithnumber": "5364", "text": "ہم سے محمد بن مثنیٰ نے بیان کیا، کہا ہم سے یحییٰ نے بیان کیا، ان سے ہشام نے، کہا کہ مجھے میرے والد ("}
{"hadithnumber": "5365", "text": "ہم سے علی بن عبداللہ نے بیان کیا، کہا ہم سے سفیان بن عیینہ نے بیان کیا، کہا ہم سے عبداللہ بن طاؤس نے"}
{"hadithnumber": "5366", "text": "ہم سے حجاج بن منہال نے بیان کیا، کہا ہم سے شعبہ نے بیان، کہا کہ مجھے عبدالملک بن میسرہ نے خبر دی، کہ"}
{"hadithnumber": "5367", "text": "ہم سے مسدد بن مسرہد نے بیان کیا، کہا ہم سے حماد بن زید نے، ان سے عمرو نے اور ان سے جابر بن عبداللہ ر"}
{"hadithnumber": "5368", "text": "ہم سے احمد بن یونس نے بیان کیا، کہا ہم سے ابراہیم بن سعد نے بیان کیا، کہا ہم سے ابن شہاب نے بیان کیا"}
{"hadithnumber": "5369", "text": "ہم سے موسیٰ بن اسماعیل نے بیان کیا، کہا ہم سے وہیب نے بیان کیا، انہیں ہشام نے خبر دی، انہیں ان کے وا"}
{"hadithnumber": "5370", "text": "ہم سے محمد بن یوسف نے بیان کیا، ان سے سفیان ثوری نے بیان کیا، ان سے ہشام بن عروہ نے، ان سے ان کے وال"}
{"hadithnumber": "5371", "text": "ہم سے یحییٰ بن بکیر نے بیان کیا، کہا ہم سے لیث بن سعد نے، ان سے عقیل نے، ان سے ابن شہاب نے، ان سے اب"}
