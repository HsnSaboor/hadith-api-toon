hadiths[18]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
1633,"یحیی بن سعید رحمہ اللہ سے روایت ہے کہ مجھے یہ خبر پہنچی : بے شک آدمی اپنے اچھے اخلاق کی بدولت ساری ر",,,1633,,
1634,"سعید بن مسیب رحمہ اللہ سے روایت ہے ، فرماتے ہیں : کیا میں تمھیں بہت سی نمازوں اور صدقات سے بھی بہتر ",,,1634,,
1635,"امام مالک رحمہ اللہ کو پہنچا کہ رسول اللہ ﷺ نے فرمایا :” میں اس واسطے بھیجا گیا کہ اخلاق کی خوبیوں ک",,,1635,,
1636,زید بن طلحہ بن رُکانہ رضی اللہ عنہ نبی اکرم ﷺ سے مرفوع بیان کرتے ہیں ، کہتے ہیں کہ رسول اللہ ﷺ نے فر,,,1636,,
1637,حضرت عبداللہ بن عمر رضی اللہ عنہ سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ ایک شخص کے پاس سے گزرے اس حال میں,,,1637,,
1638,حمید بن عبدالرحمن بن عوف رحمہ اللہ سے روایت ہے کہ بے شک ایک آدمی رسول اللہ ﷺ کے پاس آیا اور کہنے لگا,,,1638,,
1639,"حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ بے شک رسول اللہ ﷺ نے فرمایا :’’ ( کامل اور اصلی ) طاقتور (",,,1639,,
1640,"حضرت ابوایوب انصاری رضی اللہ عنہ سے روایت ہے کہ بے شک رسول اللہ ﷺ نے فرمایا :’’ کسی مسلمان کے لیے جا",,,1640,,
1641,"حضرت انس بن مالک رضی اللہ عنہ سے روایت ہے کہ بے شک رسول اللہ ﷺ نے فرمایا :’’ نہ ایک دوسرے سے بغض رکھ",,,1641,,
1642,"حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ نے فرمایا :’’ اپنے آپ کو بدگمانی سے بچا",,,1642,,
1643,"عطاء بن عبداللہ خُراسانی رحمہ اللہ سے روایت ہے کہتے ہیں کہ رسول اللہ ﷺ نے فرمایا :’’ ایک دوسرے سے مص",,,1643,,
1644,"حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ بے شک رسول اللہ ﷺ نے فرمایا :’’ جنت کے ( آٹھوں ) دروازے ( ",,,1644,,
1645,"حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ، انھوں نے فرمایا : بندوں کے اعمال ہر جمعہ ( سات دنوں کے مجمو",,,1645,,
1646,حضرت جابر بن عبداللہ انصاری رضی اللہ عنہ سے روایت ہے ، کہتے ہیں کہ ہم رسول اللہ ﷺ کے ہمراہ غزوہ بنی ,,,1646,,
1647,"امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ بے شک حضرت عمر بن خطاب رضی اللہ عنہ نے فرمایا : بلاشبہ میں یہ",,,1647,,
1648,"ابن سیرین رحمہ اللہ سے روایت ہے ، کہتے ہیں کہ حضرت عمر بن خطاب رضی اللہ عنہ نے فرمایا : جب اللہ تم پ",,,1648,,
1649,نافع رحمہ اللہ سے روایت ہے کہ بے شک حضرت عبداللہ بن عمر رضی اللہ عنہ اس کپڑے کو پہنا کرتے تھے جو گیر,,,1649,,
1650,سیدہ عائشہ رضی اللہ عنہا زوجۂ پیغمبر ﷺ سے روایت ہے ، انھوں نے ( اپنے بھانجے ) حضرت عبداللہ بن زبیر ,,,1650,,
