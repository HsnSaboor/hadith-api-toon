{"hadithnumber": "1039", "text": "عمران بن حصین رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ہم لوگوں سے فرمایا: ”تمہارے"}
{"hadithnumber": "1040", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے کوئی نماز جنازہ پڑ"}
{"hadithnumber": "1041", "text": "عباد بن منصور کہتے ہیں کہ  میں نے ابوالمہزم کو کہتے سنا کہ میں دس سال ابوہریرہ کے ساتھ رہا۔ میں نے ا"}
{"hadithnumber": "1042", "text": "عامر بن ربیعہ رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جب تم جنازہ دیکھ"}
{"hadithnumber": "1043", "text": "ابو سعید خدری رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جب تم جنازہ دیکھ"}
{"hadithnumber": "1044", "text": "علی بن ابی طالب رضی الله عنہ سے روایت ہے کہ  ان سے جنازے کے لیے جب تک کہ وہ رکھ نہ دیا جائے کھڑے رہن"}
{"hadithnumber": "1045", "text": "عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”بغلی قبر ہمارے ل"}
{"hadithnumber": "1046", "text": "عبداللہ بن عمر رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم جب میت قبر میں داخل کر دی"}
{"hadithnumber": "1047", "text": "عثمان بن فرقد کہتے ہیں کہ  میں نے جعفر بن محمد سے سنا وہ اپنے باپ سے روایت کر رہے تھے جس آدمی نے رس"}
{"hadithnumber": "1048", "text": "عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کی قبر میں ایک لال چادر رکھی"}
{"hadithnumber": "1049", "text": "ابووائل شقیق بن سلمہ کہتے ہیں کہ  علی رضی الله عنہ نے ابوالہیاج اسدی سے کہا: میں تمہیں ایک ایسے کام"}
{"hadithnumber": "1050", "text": "ابومرثد غنوی رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”قبروں پر نہ بیٹھو ۱؎"}
{"hadithnumber": "1051", "text": "اس طریق سے بھی  ابومرشد غنوی رضی الله عنہ نے نبی اکرم صلی اللہ علیہ وسلم سے اسی طرح روایت کی ہے۔ الب"}
{"hadithnumber": "1052", "text": "جابر رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے اس بات سے منع فرمایا ہے کہ قبریں پختہ"}
{"hadithnumber": "1053", "text": "عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم مدینے کی چند قبروں کے پاس س"}
{"hadithnumber": "1054", "text": "بریدہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”میں نے تمہیں قبروں کی زیارت"}
{"hadithnumber": "1055", "text": "عبداللہ بن ابی ملیکہ کہتے ہیں کہ  عبدالرحمٰن بن ابی بکر حبشہ میں وفات پا گئے تو انہیں مکہ لا کر دفن"}
{"hadithnumber": "1056", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے قبروں کی زیادہ زیارت کرنے والی عو"}
{"hadithnumber": "1057", "text": "عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم ایک قبر میں رات کو داخل ہوئے"}
{"hadithnumber": "1058", "text": "انس رضی الله عنہ کہتے ہیں کہ  رسول اللہ کے پاس سے ایک جنازہ گزرا، لوگوں نے اس کی تعریف کی ۱؎ تو رسول"}
{"hadithnumber": "1059", "text": "ابوالاسود الدیلی کہتے ہیں کہ  میں مدینے آیا، تو عمر بن خطاب رضی الله عنہ کے پاس آ کر بیٹھا اتنے می"}
{"hadithnumber": "1060", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس مسلمان کے تین بچے فوت"}
{"hadithnumber": "1061", "text": "عبداللہ بن مسعود رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے تین بچوں ک"}
{"hadithnumber": "1062", "text": "عبداللہ بن عباس رضی الله عنہما بیان کرتے ہیں کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا"}
{"hadithnumber": "1063", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”شہید پانچ لوگ ہیں: جو طا"}
{"hadithnumber": "1064", "text": "ابواسحاق سبیعی کہتے ہیں کہ  سلیمان بن صرد نے خالد بن عرفطہٰ سے  ( یا خالد نے سلیمان سے )  پوچھا: کیا"}
{"hadithnumber": "1065", "text": "اسامہ بن زید رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے طاعون کا ذکر کیا، تو فرمایا: ”"}
{"hadithnumber": "1066", "text": "عبادہ بن صامت رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جو اللہ سے ملنا چ"}
{"hadithnumber": "1067", "text": "ام المؤمنین عائشہ رضی الله عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جو اللہ سے ملن"}
{"hadithnumber": "1068", "text": "جابر بن سمرہ رضی الله عنہ کہتے ہیں کہ  ایک شخص نے خودکشی کر لی، تو نبی اکرم صلی اللہ علیہ وسلم نے اس"}
{"hadithnumber": "1069", "text": "ابوقتادہ رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کے پاس ایک شخص لایا گیا تاکہ آپ اس کی"}
{"hadithnumber": "1070", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے پاس کوئی فوت شدہ شخص جس پر قرض ہو"}
{"hadithnumber": "1071", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جب میت کو یا تم میں سے ک"}
{"hadithnumber": "1072", "text": "عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جب کوئی آدمی مر"}
{"hadithnumber": "1073", "text": "عبداللہ بن مسعود رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جس نے کسی مصیب"}
{"hadithnumber": "1074", "text": "عبداللہ بن عمرو رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جو مسلمان جمعہ"}
{"hadithnumber": "1075", "text": "علی بن ابی طالب رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ان سے فرمایا: ”علی! تین چی"}
{"hadithnumber": "1076", "text": "ابوبرزہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے کسی ایسی عورت کی تع"}
{"hadithnumber": "1077", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک جنازے میں اللہ اکبر کہا تو پہ"}
{"hadithnumber": "1078", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”مومن کی جان اس کے قرض کی"}
{"hadithnumber": "1079", "text": "اس سند سے بھی  ابوہریرہ رضی الله عنہ سے روایت ہے کہ نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”مومن کی"}
