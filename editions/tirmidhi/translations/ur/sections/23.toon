{"hadithnumber": "1670", "text": "براء بن عازب رضی الله عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”میرے پاس «شانہ»"}
{"hadithnumber": "1671", "text": "عبداللہ بن عمرو رضی الله عنہما کہتے ہیں کہ  ایک آدمی جہاد کی اجازت طلب کرنے کے لیے نبی اکرم صلی الل"}
{"hadithnumber": "1672", "text": "ابن عباس رضی الله عنہما  آیت کریمہ: «أطيعوا الله وأطيعوا الرسول وأولي الأمر منكم» کی تفسیر میں کہتے"}
{"hadithnumber": "1673", "text": "عبداللہ بن عمر رضی الله عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اگر لوگ تنہائ"}
{"hadithnumber": "1674", "text": "عبداللہ بن عمرو کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اکیلا سوار شیطان ہے، دو سوار ب"}
{"hadithnumber": "1675", "text": "جابر بن عبداللہ رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”لڑائی دھوکہ و ف"}
{"hadithnumber": "1676", "text": "ابواسحاق سبیعی کہتے ہیں کہ  میں زید بن ارقم رضی الله عنہ کے بغل میں تھا کہ ان سے پوچھا گیا: نبی اکرم"}
{"hadithnumber": "1677", "text": "عبدالرحمٰن بن عوف رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے مقام بدر میں رات کے وقت ہ"}
{"hadithnumber": "1678", "text": "ابن ابی اوفی رضی الله عنہ کہتے ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم کو  ( غزوہ احزاب میں )  کف"}
{"hadithnumber": "1679", "text": "جابر رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم مکہ میں داخل ہوئے تو آپ کا پرچم سفید ت"}
{"hadithnumber": "1680", "text": "یونس بن عبید مولیٰ محمد بن قاسم کہتے ہیں کہ  مجھ کو محمد بن قاسم نے براء بن عازب رضی الله عنہما کے پ"}
{"hadithnumber": "1681", "text": "عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کا جھنڈا کالا اور پرچم سفید"}
{"hadithnumber": "1682", "text": "مہلب بن ابی صفرۃ ان لوگوں سے روایت کرتے ہیں  جنہوں نے نبی اکرم صلی اللہ علیہ وسلم سے سنا، آپ فرما رہ"}
{"hadithnumber": "1683", "text": "ابن سیرین کہتے ہیں کہ  میں نے اپنی تلوار سمرہ بن جندب رضی الله عنہ کی تلوار کی طرح بنائی، اور سمرہ ر"}
{"hadithnumber": "1684", "text": "ابو سعید خدری رضی الله عنہ کہتے ہیں کہ  فتح مکہ کے سال جب نبی اکرم صلی اللہ علیہ وسلم مرالظہران ۱؎ پ"}
{"hadithnumber": "1685", "text": "انس بن مالک رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم ابوطلحہ کے گھوڑے پر سوار ہو گئے اس"}
{"hadithnumber": "1686", "text": "انس بن مالک رضی الله عنہ کہتے ہیں کہ  مدینہ میں گھبراہٹ کا ماحول تھا، چنانچہ رسول اللہ صلی اللہ علیہ"}
{"hadithnumber": "1687", "text": "انس رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم سب سے جری  ( نڈر ) ، سب سے سخی، اور سب سے"}
{"hadithnumber": "1688", "text": "براء بن عازب رضی الله عنہما کہتے ہیں کہ  ہم سے ایک آدمی نے کہا: ابوعمارہ! ۱؎ کیا آپ لوگ رسول اللہ ص"}
{"hadithnumber": "1689", "text": "عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  غزوہ حنین کے دن ہماری صورت حالت یہ تھی کہ مسلمانوں کی دون"}
{"hadithnumber": "1690", "text": "مزیدہ رضی الله عنہ کہتے ہیں کہ  فتح مکہ کے دن رسول اللہ صلی اللہ علیہ وسلم مکہ داخل ہوئے اور آپ کی ت"}
{"hadithnumber": "1691", "text": "انس رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کی تلوار کے قبضہ کی گرہ چاندی کی تھی۔ \\r\\n\\r"}
{"hadithnumber": "1692", "text": "زبیر بن عوام رضی الله عنہ کہتے ہیں کہ  غزوہ احد کے دن نبی اکرم صلی اللہ علیہ وسلم کے جسم پر دو زرہیں"}
{"hadithnumber": "1693", "text": "انس بن مالک رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم فتح مکہ کے سال مکہ داخل ہوئے تو آپ"}
{"hadithnumber": "1694", "text": "عروہ بارقی رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”گھوڑوں کی پیشانی میں ق"}
{"hadithnumber": "1695", "text": "عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”سرخ رنگ کے گھوڑ"}
{"hadithnumber": "1696", "text": "ابوقتادہ رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”بہتر گھوڑے وہ ہیں جو ک"}
{"hadithnumber": "1697", "text": "یزید بن ابی حبیب سے اسی سند سے  اسی معنی کی اسی جیسی حدیث مروی ہے۔ \\r\\n\\r\\nامام ترمذی کہتے ہیں: یہ حدیث"}
{"hadithnumber": "1698", "text": "ابوہریرہ رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم کو گھوڑوں میں سے «شکال» گھوڑا ناپس"}
{"hadithnumber": "1699", "text": "عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے «تضمیر» کیے ہوئے گھوڑوں ک"}
{"hadithnumber": "1700", "text": "ابوہریرہ رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم فرمایا: ”مقابلہ صرف تیر، اونٹ اور"}
{"hadithnumber": "1701", "text": "عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم اللہ تعالیٰ کے حکم کے تابع"}
{"hadithnumber": "1702", "text": "ابو الدرداء رضی الله عنہ کہتے ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم کو فرماتے سنا: ”مجھے اپنے ض"}
{"hadithnumber": "1703", "text": "ابوہریرہ رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”فرشتے مسافروں کی اس ج"}
{"hadithnumber": "1704", "text": "براء رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے دو لشکر روانہ کیا ۱؎، ایک پر علی بن اب"}
{"hadithnumber": "1705", "text": "عبداللہ بن عمر رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”تم میں سے ہر ا"}
{"hadithnumber": "1706", "text": "ام حصین احمسیہ رضی الله عنہا کہتی ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو حجۃ الوداع میں خطبہ"}
{"hadithnumber": "1707", "text": "عبداللہ بن عمر رضی الله عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جب تک معصیت ک"}
{"hadithnumber": "1708", "text": "عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے جانوروں کو باہم لڑانے سے"}
{"hadithnumber": "1709", "text": "مجاہد سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے جانوروں کو باہم لڑانے سے منع فرمایا۔ \\r\\n\\r\\nامام ت"}
{"hadithnumber": "1710", "text": "جابر رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے چہرے پر مارنے اور اسے داغنے سے منع"}
{"hadithnumber": "1711", "text": "عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  ایک لشکر میں مجھے رسول اللہ صلی اللہ علیہ وسلم کے سامنے پ"}
{"hadithnumber": "1712", "text": "ابوقتادہ رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم صحابہ کے بیچ کھڑے ہو کر ان سے بیا"}
{"hadithnumber": "1713", "text": "ہشام بن عامر رضی الله عنہ کہتے ہیں کہ  احد کے دن رسول اللہ صلی اللہ علیہ وسلم سے زخموں کی شکایت کی گ"}
{"hadithnumber": "1714", "text": "عبداللہ بن مسعود رضی الله عنہ کہتے ہیں کہ  جب بدر کے دن قیدیوں کو لایا گیا تو رسول اللہ صلی اللہ علی"}
{"hadithnumber": "1715", "text": "عبداللہ بن عباس رضی الله عنہما سے روایت ہے کہ  مشرکین نے ایک مشرک کی لاش کو خریدنا چاہا تو نبی اکرم"}
{"hadithnumber": "1716", "text": "عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ہم کو ایک سریہ میں روانہ"}
{"hadithnumber": "1717", "text": "جابر رضی الله عنہ کہتے ہیں کہ  احد کے دن میری پھوپھی میرے باپ کو لے کر آئیں تاکہ انہیں ہمارے قبرستا"}
{"hadithnumber": "1718", "text": "سائب بن یزید رضی الله عنہ کہتے ہیں کہ  جب رسول اللہ صلی اللہ علیہ وسلم غزوہ تبوک سے واپس آئے تو لوگ"}
{"hadithnumber": "1719", "text": "عمر بن خطاب رضی الله عنہ کہتے ہیں کہ  اسود کے قبیلہ بنی نضیر کے اموال ان میں سے تھے جسے اللہ تعالیٰ"}
