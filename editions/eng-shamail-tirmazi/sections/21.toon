metadata:
  section_id: 21
  section_name: رسول اللہ صلی اللہ علیہ وسلم کے سر مبارک کے کپڑے کا بیان
  hadith_first: 122
  hadith_last: 122

hadiths[1]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
122,"""I have not seen anything more beautiful than Allah’s Messenger (Allah bless him and give him peace). The sun seemed to shine in his face. Nor have I seen anyone more rapid in his gait than Allah’s Messenger (Allah bless him and give him peace). The earth seemed to be folded up for him. We must strenuously exert ourselves, while he is not subject to any stress.""",,,122,"Abu Huraira said:",رسول اللہ صلی اللہ علیہ وسلم کے سر مبارک کے کپڑے کا بیان
