metadata:
  section_id: 7
  section_name: Chapter 7
  hadith_first: 49
  hadith_last: 53

hadiths[5]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
49,"""Color the edges of the eyelids with antimony ,and three times in that.",,,48764,"Ibn 'Abbas reported that the Prophet said (Allah bless him and give him peace):",Chapter 7
50,"“Allah’s Messenger (Allah bless him and give him peace) used to color the edges of his eyelids with antimony before going to sleep, three times in each eye.\nYazid ibn Harun also said in his tradition: “The Prophet (Allah bless him and give him peace) had a kohl jar from which he used to apply kohl to his eyelashes before going to sleep, three times in each eye.”",,,48765,"Ibn 'Abbas said:",Chapter 7
51,"""Allah’s Messenger said (Allah bless him and give him peace): “You must apply antimony before going to sleep, for it clears the vision and makes the eyelashes grow.”",,,48766,"Jabir (i.e. Ibn Abdillah) said:",Chapter 7
52,"""Allah’s Messenger said (Allah bless him and give him peace): 'The best of your eye salves is antimony, for it clears the vision and makes the eyelashes grow.'”",,,48767,"Ibn ""Abbas said:",Chapter 7
53,"""You must apply antimony, for it clears the vision and makes the eyelashes grow.”",,,48768,"Ibn 'Umar said:",Chapter 7
