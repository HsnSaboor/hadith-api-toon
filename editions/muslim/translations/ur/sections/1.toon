{"hadithnumber": "151", "text": "حضرت عباس بن عبدالمطلب  ‌رضی ‌اللہ ‌عنہ ‌ ‌  بیان کرتے ہیں کہ انہوں نے رسول اللہ ﷺ سے سنا ،  آپ فرما"}
{"hadithnumber": "152", "text": "سلیمان بن بلال نے عبد اللہ بن دینار سے   ،  انہوں ابو صالح سے اور انہوں نے حضرت ابوہریرہ ‌رضی ‌اللہ"}
{"hadithnumber": "153", "text": "سہیل نے عبداللہ بن دینار سے  ،  انہوں نے ابو صالح سے اور انہوں نے حضرت ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌"}
{"hadithnumber": "154", "text": "سفیان بن عیینہ نے زہری سے حدیث سنائی  ،  انہوں نے سالم سے اور انہوں نے اپنے والد حضرت عبداللہ بن عمر"}
{"hadithnumber": "155", "text": "سفیان بن عیینہ کے بجائے معمر نے زہری سے مذکورہ بالاسند کےساتھ خبر دی اور کہا کہ آپ ایک انصاری کے پاس"}
{"hadithnumber": "156", "text": "ابو سوار بیان کرتے ہیں کہ انہوں نے حضرت عمران بن حصین ‌رضی ‌اللہ ‌عنہ ‌ ‌  کو سنا  ،  وہ نبی ﷺ سے حد"}
{"hadithnumber": "157", "text": "حماد بن زید نے اسحاق بن سوید سے روایت کی کہ ابو قتادہ  (  تمیم بن نذیر )  نے حدیث بیان کی  ،  کہا کہ"}
{"hadithnumber": "158", "text": "نضر  ( بن شمیل  )  نے کہا :  ہمیں ابو نعامہ عدوی نے حدیث بیان کی  ،  انہوں نے کہا :  میں نےحجیر بن ر"}
{"hadithnumber": "159", "text": "عبد اللہ بن نمیر ،  جریر اور ابواسامہ نے ہشام بن عروہ سے حدیث سنائی  ،  انہوں نے اپنے والد ( عروہ )"}
{"hadithnumber": "160", "text": "لیث نے یزید بن ابی حبیب سے  ،  انہوں نے ابو خیر سے اور انہوں حضرت عبد اللہ بن عمر  ‌رضی ‌اللہ ‌عنہ ‌"}
{"hadithnumber": "161", "text": "عمرو بن حارث نے یزید بن ابی  حبیب سے  ،  انہوں نے ابوخیر سے روایت کی اور انہوں نے حضرت عبداللہ بن عم"}
{"hadithnumber": "162", "text": "حضرت جابر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  بیان کرتے ہیں کہ میں نے رسول اللہ ﷺ کو یہ کہتے ہوئے سنا  :  ’’ مسلما"}
{"hadithnumber": "163", "text": "یحییٰ بن سعید اموی نے کہا  :  ہمیں ابو بردہ  ( برید )  بن عبداللہ بن ابی بردہ بن ابی موسیٰ اشعری نے"}
{"hadithnumber": "164", "text": "ابراہیم بن سعید جوہری  ‘ ابو اسامہ  ‘ برید بن عبد اللہ اس روایت میں دوسری سند کے ساتھ یہ الفاظ ہیں ج"}
{"hadithnumber": "165", "text": "ابو قلابہ نےحضرت انس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  وہ نبیﷺ سے روایت کرتے ہیں کہ آپ نے فرمایا"}
{"hadithnumber": "166", "text": "قتادہ حضرت  انس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے حدیث بیان  کرتے ہیں  ،  انہوں نے کہا :  رسول اللہ ﷺ نے فرما"}
{"hadithnumber": "167", "text": "ثابت نے حضرت انس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  انہوں نے کہا  :  رسول اللہ ﷺ نے فرمایا......"}
{"hadithnumber": "168", "text": "اسماعیل بن علیہ اور عبد الوارث دونوں نے عبد العزیز سے اور انہوں نے حضرت انس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے"}
{"hadithnumber": "169", "text": "قتادہ نے حضرت انس بن مالک  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  انہوں نے کہا کہ رسول اللہ ﷺ نے فرمای"}
{"hadithnumber": "170", "text": "شعبہ نے کہا  :  میں نے قتادہ کو حضرت انس بن مالک ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے حدیث بیان کرتے ہوئے سنا  ،"}
{"hadithnumber": "171", "text": "حسن معلم نے قتادہ سے اور انہوں ن حضرت انس بن مالک  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے  ،  انہوں نے نبی کریم ﷺ س"}
{"hadithnumber": "172", "text": "حضرت ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا :  ’’ جس کی ایذا رسانی سے ا"}
{"hadithnumber": "173", "text": "ابو سلمہ بن عبد الرحمٰن نے ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے  ،  انہوں نے رسول اللہ ﷺ سے حدیث روایت"}
{"hadithnumber": "174", "text": "ابوحصین نے ابوصالح سے اور انہو ں نے حضرت ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  انہوں نے کہا"}
{"hadithnumber": "175", "text": "اعمش نے ابو صالح سے  ،  انہوں نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  انہوں نے کہا"}
{"hadithnumber": "176", "text": "ابو شریح  (  خویلد بن عمرو  )  خزاعی  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ نبی اکرم ﷺ نے فرمایا : ’’"}
{"hadithnumber": "177", "text": "ابو بکر بن ابی شیبہ نے کہا  :  ہمیں وکیع نے سفیان سے حدیث سنائی  ،  نیز محمد بن مثنیٰ نے کہا :  ہمیں"}
{"hadithnumber": "178", "text": "اعمش نے اسماعیل بن رجاء سے  ،  انہوں نے اپنے والد  ( رجاء بن  ربیعہ  )  سے اور انہوں نے حضرت ابوسعید"}
{"hadithnumber": "179", "text": "صالح بن کیسان نے حارث  (  بن فضیل )  سے  ،  انہوں نے جعفر بن عبد اللہ بن حکم سے  ،  انہوں نے عبد  ال"}
{"hadithnumber": "180", "text": "حارث بن فضیل خطمی سے  (  صالح بن کیسان کے بجائے  )  عبدالعزیز بن محمد کی سند کےساتھ رسول  اللہ ﷺ کے"}
{"hadithnumber": "181", "text": "حضرت ابو مسعود ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے  ،  انہوں نے کہا  :  نبی اکرم ﷺ نے ہاتھ سے یمن کی طر"}
{"hadithnumber": "182", "text": "ایوب نے کہا  :  ہمیں محمد  (  ابن سیرین  )  نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے حدیث سنائی  ،"}
{"hadithnumber": "183", "text": "( عبد اللہ  )  ابن عون نے محمد  (  ابن سیرین  )  سے  ، انہوں نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌"}
{"hadithnumber": "184", "text": "صالح  نے اعرج سے روایت کی  ،  انہوں نے کہا کہ حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے کہا :  رسو ل ا"}
{"hadithnumber": "185", "text": "و زناد نے اعرج سے اور انہوں نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ رسو ل اللہ ﷺ نے ف"}
{"hadithnumber": "186", "text": "علاء  (  بن عبدالرحمان  الجہنی )  نے اپنے والد سے  ،  انہوں نے ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے رو"}
{"hadithnumber": "187", "text": "یونس نے ابن شہاب سے روایت کی  ،  انہوں نے کہا  :  مجھے ابو سلمہ بن عبد الرحمٰن نے خبر دی کہ حضرت ابو"}
{"hadithnumber": "188", "text": "شعیب نے زہری سے اسی سند کے ساتھ یہی روایت کی اور  ( آخرمیں یہ  )  اضافہ کیا  : ’’ ایمان یمنی ہے اور"}
{"hadithnumber": "189", "text": "سعید بن مسیت نے حدیث بیان کی کہ حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے کہا  :  میں نے نبی اکرمﷺ کو"}
{"hadithnumber": "190", "text": "ابو معاویہ نے اعمش سے حدیث سنائی  ،  انہوں نے ابو صالح سے اور انہوں نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌ع"}
{"hadithnumber": "191", "text": "جریر نے اعمش سے اسی سند کے ساتھ حدیث بیان کی  ،  لیکن اس نے ’’ کفر کا مرکز مشرق کی طرف ہے  ‘  ‘  کے"}
{"hadithnumber": "192", "text": "شعبہ نے اعمش سے سابقہ سند کے ساتھ جریر کی طرح حدیث سنائی اور یہ ا لفاظ زائد بیان کیے کہ ’’غرور اور گ"}
{"hadithnumber": "193", "text": "حضرت جابر بن عبد اللہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے کہا کہ رسول اللہ ﷺ نے  فرمایا  :  ’’ دلوں کی سختی اور"}
{"hadithnumber": "194", "text": "ابو معاویہ اور وکیع نے اعمش سے حدیث سنائی  ،  انہوں نے ابو صالح سے اور انہوں نے حضرت ابو ہریرہ  ‌رضی"}
{"hadithnumber": "195", "text": "( ابو معاویہ اور وکیع کے بجائے  )  جریر نے اعمش سے ان کی اسی سند سے حدیث سنائی  ،  کہا  :  رسول اللہ"}
{"hadithnumber": "196", "text": "سفیان بن عیینہ نے کہا  :  میں نے سہیل سے کہا کہ عمرو نے ہمیں قعقاع کے واسطے سے آپ کے والد سے حدیث سن"}
{"hadithnumber": "197", "text": "سفیان ثوری نے سہیل بن ابی صالح سے  ،  انہوں نے عطاء بن یزید لیثی سے  ،  انہوں نے حضرت تمیم داری  ‌رض"}
{"hadithnumber": "198", "text": "ہمیں روح بن قاسم نے حدیث سنائی  ،   ( کہا :  )  ہمیں سہیل نے عطاء سے اس وقت سن کر روایت کی جب وہ ابو"}
{"hadithnumber": "199", "text": "قیس (  بن ابی حازم  )  نے حضرت جریر  (  بن عبد اللہ  )   ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  کہا  :"}
{"hadithnumber": "200", "text": "زیاد بن علاقہ  ( کوفی )  سے روایت ہے  ،  انہوں نے حضرت جریر بن عبد اللہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے سنا"}
{"hadithnumber": "201", "text": "سریج بن یونس اور یعقوب دورقی نے کہا  :  ہشیم نےہمیں سیار کے واسطے سے شعبی سے حدیث سنائی اور انہوں نے"}
{"hadithnumber": "202", "text": "یونس بن ابن شہاب سے خبر دی  ،  انہوں نے کہا  :  میں نے ابو سلمہ بن عبدالرحمٰن اور سعید بن مسیب سے سن"}
{"hadithnumber": "203", "text": "عقیل بن خالد نے حدیث سنائی کہ ابن شہاب  ( زہری )  نےکہا :  مجھے ابو بکر بن عبدالرحمن بن حارث بن ہشام"}
{"hadithnumber": "204", "text": "اوزاعی نے زہری سے حدیث بیان کی  ،  انہوں نے ابن مسیب  ،  ابو سلمہ اور ابوبکر بن عبدالرحمٰن بن حارث ب"}
{"hadithnumber": "205", "text": "صفوان بن سلیم نے حضرت میمونہ رضی اللہ عنہا کے آزاد کردہ غلام عطاء بن یسار سے اور حمید بن عبدالرحمٰن"}
{"hadithnumber": "206", "text": "قتیبہ  بن سعید  ‘ عبد العزیز دراوردی  ‘ \\n\\nعلاء بن عبدالرحمٰن نے ابو ھریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  ،  ا"}
{"hadithnumber": "207", "text": "معمر نے ہمام بن منبہ سے  ،  انہوں نے حضرت ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے اور انہوں نے نبی ﷺ سے رو"}
{"hadithnumber": "208", "text": "شعبہ نے سلیمان سے  ،  انہوں نے ذکوان سے اور انہوں نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ک"}
{"hadithnumber": "210", "text": "عبد اللہ بن نمیر اور سفیان نے اعمش سے  ،  انہوں نے نے عبد اللہ بن مرہ سے  ،  انہوں نے مسروق سے اور ا"}
{"hadithnumber": "211", "text": "نافع بن مالک بن ابی عامر نے اپنے والد سے  ،  انہوں نے حضرت ابوہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ک"}
{"hadithnumber": "212", "text": "محمد بن جعفر نے کہا  :  ہمیں حرقہ کے آزاد کردہ غلام علاء بن عبد الرحمن بن یعقوب نے اپنے والد سے خبر"}
{"hadithnumber": "213", "text": "یحییٰ بن محمد بن قیس ابو زکیر نے کہا  :  میں نے علاء بن عبدالرحمٰن کو اسی  (  مذکورہ بالا )  سند کے"}
{"hadithnumber": "214", "text": "حماد بن سلمہ نے داؤد بن ابی ہندہ سے  ،  انہوں نے سعید بن مسیب کے حوالے سے  حضرت ابو ہریرہ  ‌رضی ‌الل"}
{"hadithnumber": "215", "text": "نافع نے حضرت عبد اللہ بن عمر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ رسول اللہ ﷺ نے فرمایا  : ’’ جو شخص"}
{"hadithnumber": "216", "text": "عبد اللہ بن دینار سے روایت ہے  ،  انہوں نے حضرت ابن عمر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  کو یہ کہتے سنا کہ رسو"}
{"hadithnumber": "217", "text": "حضرت ابو ذر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ انہوں نے رسو ل اللہ ﷺ سے سنا : ’’ جس شخص نے دانستہ"}
{"hadithnumber": "218", "text": "حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا  : ’’ اپنے آباء سے بے رغبت"}
{"hadithnumber": "219", "text": "خالد نے ابو عثمان سےنقل کیا کہ جب زیاد کی نسبت  (  ابوسفیان ‌رضی ‌اللہ ‌عنہ ‌ ‌  کی طرف ہونے )  کا د"}
{"hadithnumber": "220", "text": "عاصم نے ابو عثمان سے اور انہوں نے حضرت سعد اور حضرت ابوبکر رضی اللہ عنہما سے روایت کی ہے کہ وہ دونوں"}
