metadata:

hadiths[134]{hadithnumber,arabic,bengali,english,french,indonesian,russian,urdu,grades,reference,international_number,narrator_chain,chapter_intro}:
{"hadithnumber": "2042", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا مُعَلَّى بْنُ مَنْصُورٍ، عَنْ عَبْدِ اللَّهِ بْنِ جَعْفَرٍ، عَنْ عُثْمَانَ بْنِ مُحَمَّدٍ، عَنِ الْمَقْبُرِيِّ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ مَنْ جُعِلَ قَاضِيًا بَيْنَ النَّاسِ فَقَدْ ذُبِحَ بِغَيْرِ سِكِّينٍ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“Whoever is appointed judge between the people, he has been slaughtered without a knife.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah that the Prophet (ﷺ) said:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2043", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، وَمُحَمَّدُ بْنُ إِسْمَاعِيلَ، قَالاَ حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا إِسْرَائِيلُ، عَنْ عَبْدِ الأَعْلَى، عَنْ بِلاَلِ بْنِ أَبِي مُوسَى، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنْ سَأَلَ الْقَضَاءَ وُكِلَ إِلَى نَفْسِهِ وَمَنْ جُبِرَ عَلَيْهِ نَزَلَ إِلَيْهِ مَلَكٌ فَسَدَّدَهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“Whoever asks to be appointed a judge, will be entrusted to himself, but “Whoever asks to be appointed a judge, will be entrusted to himself, but whoever is forced to accept position, an angel will come down to him and guide him.' ”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Anas bin Malik that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2044", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا يَعْلَى، وَأَبُو مُعَاوِيَةَ عَنِ الأَعْمَشِ، عَنْ عَمْرِو بْنِ مُرَّةَ، عَنْ أَبِي الْبَخْتَرِيِّ، عَنْ عَلِيٍّ، قَالَ بَعَثَنِي رَسُولُ اللَّهِ صلى الله عليه وسلم إِلَى الْيَمَنِ فَقُلْتُ يَا رَسُولَ اللَّهِ تَبْعَثُنِي وَأَنَا شَابٌّ أَقْضِي بَيْنَهُمْ وَلاَ أَدْرِي مَا الْقَضَاءُ قَالَ فَضَرَبَ فِي صَدْرِي بِيَدِهِ ثُمَّ قَالَ ‏ ‏ اللَّهُمَّ اهْدِ قَلْبَهُ وَثَبِّتْ لِسَانَهُ ‏\"\"‏ ‏.‏ قَالَ فَمَا شَكَكْتُ بَعْدُ فِي قَضَاءٍ بَيْنَ اثْنَيْنِ ‏.‏\"", "bengali": "", "english": "“The Messenger of Allah (ﷺ) sent me to Yemen. I said: 'O Messenger of Allah, you are sending me to judge between them while I am a young man, and I do not know how to judge.' He struck me on the chest with his hand and said: 'O Allah, guide his heart and make his tongue steadfast.' And after that I never doubted in passing judgment between two people.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that 'Ali said:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2045", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ خَلاَّدٍ الْبَاهِلِيُّ، حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ الْقَطَّانُ، حَدَّثَنَا مُجَالِدٌ، عَنْ عَامِرٍ، عَنْ مَسْرُوقٍ، عَنْ عَبْدِ اللَّهِ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَا مِنْ حَاكِمٍ يَحْكُمُ بَيْنَ النَّاسِ إِلاَّ جَاءَ يَوْمَ الْقِيَامَةِ وَمَلَكٌ آخِذٌ بِقَفَاهُ ثُمَّ يَرْفَعُ رَأْسَهُ إِلَى السَّمَاءِ فَإِنْ قَالَ أَلْقِهِ أَلْقَاهُ فِي مَهْوَاةٍ أَرْبَعِينَ خَرِيفًا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“The Messenger of Allah (ﷺ) said: “There is no judge who judges between the people but on the Day of Resurrection an angel will come and take hold of the back of his head towards the sky and if it said: “Throw him, “he will throw into an abyss the depth of forty autumns (years).' ”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that 'Abdullah said:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2046", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ سِنَانٍ، حَدَّثَنَا مُحَمَّدُ بْنُ بِلاَلٍ، عَنْ عِمْرَانَ الْقَطَّانِ، عَنْ حُسَيْنٍ، - يَعْنِي ابْنَ عِمْرَانَ - عَنْ أَبِي إِسْحَاقَ الشَّيْبَانِيِّ، عَنْ عَبْدِ اللَّهِ بْنِ أَبِي أَوْفَى، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ إِنَّ اللَّهَ مَعَ الْقَاضِي مَا لَمْ يَجُرْ فَإِذَا جَارَ وَكَلَهُ إِلَى نَفْسِهِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“Allah is with the judge so long as he is not unjust, but if he rules unjustly, He entrusts him to himself.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from 'Abdullah bin Abu Awfa that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2047", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا ابْنُ أَبِي ذِئْبٍ، عَنْ خَالِهِ الْحَارِثِ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ أَبِي سَلَمَةَ، عَنْ عَبْدِ اللَّهِ بْنِ عَمْرٍو، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ لَعْنَةُ اللَّهِ عَلَى الرَّاشِي وَالْمُرْتَشِي ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“The curse of Allah is upon the one who offers a bribe and the one who takes it.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from 'Abdullah bin 'Amr that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2048", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ الدَّرَاوَرْدِيُّ، حَدَّثَنَا يَزِيدُ بْنُ عَبْدِ اللَّهِ بْنِ الْهَادِ، عَنْ مُحَمَّدِ بْنِ إِبْرَاهِيمَ التَّيْمِيِّ، عَنْ بُسْرِ بْنِ سَعِيدٍ، عَنْ أَبِي قَيْسٍ، - مَوْلَى عَمْرِو بْنِ الْعَاصِ - عَنْ عَمْرِو بْنِ الْعَاصِ، أَنَّهُ سَمِعَ رَسُولَ اللَّهِ صلى الله عليه وسلم يَقُولُ ‏ ‏ إِذَا حَكَمَ الْحَاكِمُ فَاجْتَهَدَ فَأَصَابَ فَلَهُ أَجْرَانِ وَإِذَا حَكَمَ فَاجْتَهَدَ فَأَخْطَأَ فَلَهُ أَجْرٌ ‏\"\"‏ ‏.‏ قَالَ يَزِيدُ فَحَدَّثْتُ بِهِ أَبَا بَكْرِ بْنَ عَمْرِو بْنِ حَزْمٍ، فَقَالَ هَكَذَا حَدَّثَنِيهِ أَبُو سَلَمَةَ، عَنْ أَبِي هُرَيْرَة‏.‏َ\"", "bengali": "", "english": "“When the judge passes a judgement and does his best and gets it right, he will have two rewards, and if he passes a judgement and does his best and gets it wrong, he will have one reward.” (Sahih)  Yazid (one of narrators) said : “So I Narrated it to Abu Bakr bin 'Amr bin Hazm. He said: 'This is how it was narrated to me by Abu Salamah from Abu Hurairah.'”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from 'Amr bin 'As that he heard the Messenger of Allah (ﷺ) say:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2049", "arabic": "حَدَّثَنَا إِسْمَاعِيلُ بْنُ تَوْبَةَ، حَدَّثَنَا خَلَفُ بْنُ خَلِيفَةَ، حَدَّثَنَا أَبُو هَاشِمٍ، قَالَ لَوْلاَ حَدِيثُ ابْنِ بُرَيْدَةَ عَنْ أَبِيهِ، عَنْ رَسُولِ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ الْقُضَاةُ ثَلاَثَةٌ اثْنَانِ فِي النَّارِ وَوَاحِدٌ فِي الْجَنَّةِ رَجُلٌ عَلِمَ الْحَقَّ فَقَضَى بِهِ فَهُوَ فِي الْجَنَّةِ وَرَجُلٌ قَضَى لِلنَّاسِ عَلَى جَهْلٍ فَهُوَ فِي النَّارِ وَرَجُلٌ جَارَ فِي الْحُكْمِ فَهُوَ فِي النَّارِ ‏\"\"‏ ‏.‏ لَقُلْنَا إِنَّ الْقَاضِيَ إِذَا اجْتَهَدَ فَهُوَ فِي الْجَنَّةِ ‏.‏\"", "bengali": "", "english": "“Were it not for the Hadith of Ibn Buraidah from his father, from the Prophet (ﷺ) who said: 'Judges are of three types, two of whom will be in Hell and one will be in Paradise. The man who knows the truth and rules in accordance with it, will be in Paradise. The man who passes judgment on the people in ignorance will be in Hell' - we would have said that if the judge does his best he will be in Paradise.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Hashim said:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2050", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، وَمُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ يَزِيدَ، وَأَحْمَدُ بْنُ ثَابِتٍ الْجَحْدَرِيُّ، قَالُوا حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عَبْدِ الْمَلِكِ بْنِ عُمَيْرٍ، أَنَّهُ سَمِعَ عَبْدَ الرَّحْمَنِ بْنَ أَبِي بَكْرَةَ، عَنْ أَبِيهِ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ لاَ يَقْضِي الْقَاضِي بَيْنَ اثْنَيْنِ وَهُوَ غَضْبَانُ ‏\"\"‏ ‏.‏ قَالَ هِشَامٌ لاَ يَنْبَغِي لِلْحَاكِمِ أَنْ يَقْضِيَ بَيْنَ اثْنَيْنِ وَهُوَ غَضْبَانُ ‏.‏\"", "bengali": "", "english": "“Let the judge (Qadi) not pass a judgment when he is angry.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from 'Abdul-Malik bin 'Umair that he heard 'Abdur-Rahman bin Abu Bakrah (narrate) from his father that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2051", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا هِشَامُ بْنُ عُرْوَةَ، عَنْ أَبِيهِ، عَنْ زَيْنَبَ بِنْتِ أُمِّ سَلَمَةَ، عَنْ أُمِّ سَلَمَةَ، قَالَتْ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ إِنَّكُمْ تَخْتَصِمُونَ إِلَىَّ وَإِنَّمَا أَنَا بَشَرٌ وَلَعَلَّ بَعْضَكُمْ أَنْ يَكُونَ أَلْحَنَ بِحُجَّتِهِ مِنْ بَعْضٍ وَإِنَّمَا أَقْضِي بَيْنَكُمْ عَلَى نَحْوٍ مِمَّا أَسْمَعُ مِنْكُمْ فَمَنْ قَضَيْتُ لَهُ مِنْ حَقِّ أَخِيهِ شَيْئًا فَلاَ يَأْخُذْهُ فَإِنَّمَا أَقْطَعُ لَهُ قِطْعَةً مِنَ النَّارِ يَأْتِي بِهَا يَوْمَ الْقِيَامَةِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“You refer your disputes to me and I am only human. Perhaps some of you may be more eloquent in presenting your case than others, so I rule in your favor because of what I hear from you. If I pass a judgement in favor of one of you that detracts from his brother's rights, then he should not take it, because it is a piece of fire that is given to him which he will bring forth on the Day Resurrection.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Umm Salamah that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2052", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ، حَدَّثَنَا مُحَمَّدُ بْنُ عَمْرٍو، عَنْ أَبِي سَلَمَةَ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ إِنَّمَا أَنَا بَشَرٌ وَلَعَلَّ بَعْضَكُمْ أَنْ يَكُونَ أَلْحَنَ بِحُجَّتِهِ مِنْ بَعْضٍ فَمَنْ قَطَعْتُ لَهُ مِنْ حَقِّ أَخِيهِ قِطْعَةً فَإِنَّمَا أَقْطَعُ لَهُ قِطْعَةً مِنَ النَّارِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“I am only human, and some of you may be more eloquent in presenting your case than others. If I pass a judgement in his favor that detracts from his brother's rights, I am giving him a piece of fire.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2053", "arabic": "حَدَّثَنَا عَبْدُ الْوَارِثِ بْنُ عَبْدِ الصَّمَدِ بْنِ عَبْدِ الْوَارِثِ بْنِ سَعِيدٍ أَبُو عُبَيْدَةَ، حَدَّثَنِي أَبِي قَالَ، حَدَّثَنِي أَبِي، حَدَّثَنِي الْحُسَيْنُ بْنُ ذَكْوَانَ، عَنْ عَبْدِ اللَّهِ بْنِ بُرَيْدَةَ، قَالَ حَدَّثَنِي يَحْيَى بْنُ يَعْمُرَ، أَنَّ أَبَا الأَسْوَدِ الدِّيلِيَّ، حَدَّثَهُ عَنْ أَبِي ذَرٍّ، أَنَّهُ سَمِعَ رَسُولَ اللَّهِ صلى الله عليه وسلم يَقُولُ ‏ ‏ مَنِ ادَّعَى مَا لَيْسَ لَهُ فَلَيْسَ مِنَّا وَلْيَتَبَوَّأْ مَقْعَدَهُ مِنَ النَّارِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“Whoever claims something that does not belong to him; he is not one of us, so let him take his place in Hell.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Dharr that he heard the Messenger of Allah (ﷺ) say:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2054", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ ثَعْلَبَةَ بْنِ سَوَاءٍ، حَدَّثَنِي عَمِّي، مُحَمَّدُ بْنُ سَوَاءٍ عَنْ حُسَيْنٍ الْمُعَلِّمِ، عَنْ مَطَرٍ الْوَرَّاقِ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنْ أَعَانَ عَلَى خُصُومَةٍ بِظُلْمٍ - أَوْ يُعِينُ عَلَى ظُلْمٍ - لَمْ يَزَلْ فِي سَخَطِ اللَّهِ حَتَّى يَنْزِعَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“Whoever takes the wrongdoer's side in a dispute or supports wrongdoing, he will remain subject to the wrath of Allah until he gives it up.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Ibn 'Umar that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2055", "arabic": "حَدَّثَنَا حَرْمَلَةُ بْنُ يَحْيَى الْمِصْرِيُّ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، أَنْبَأَنَا ابْنُ جُرَيْجٍ، عَنِ ابْنِ أَبِي مُلَيْكَةَ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ لَوْ يُعْطَى النَّاسُ بِدَعْوَاهُمُ ادَّعَى نَاسٌ دِمَاءَ رِجَالٍ وَأَمْوَالَهُمْ وَلَكِنِ الْيَمِينُ عَلَى الْمُدَّعَى عَلَيْهِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“If the people were given what they claimed, some would have claimed the lives and property of men. But the one the claim is made against is obliged to swear an oath.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Ibn 'Abbas that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2056", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا وَكِيعٌ، وَأَبُو مُعَاوِيَةَ قَالاَ حَدَّثَنَا الأَعْمَشُ، عَنْ شَقِيقٍ، عَنِ الأَشْعَثِ بْنِ قَيْسٍ، قَالَ كَانَ بَيْنِي وَبَيْنَ رَجُلٍ مِنَ الْيَهُودِ أَرْضٌ فَجَحَدَنِي فَقَدَّمْتُهُ إِلَى النَّبِيِّ صلى الله عليه وسلم فَقَالَ لِي رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ هَلْ لَكَ بَيِّنَةٌ ‏\"‏ ‏.‏ قُلْتُ لاَ ‏.‏ قَالَ لِلْيَهُودِيِّ ‏\"‏ احْلِفْ ‏\"‏ ‏.‏ قُلْتُ إِذًا يَحْلِفَ فَيَذْهَبَ بِمَالِي ‏.‏ فَأَنْزَلَ اللَّهُ سُبْحَانَهُ ‏{إِنَّ الَّذِينَ يَشْتَرُونَ بِعَهْدِ اللَّهِ وَأَيْمَانِهِمْ ثَمَنًا قَلِيلاً}‏ إِلَى آخِرِ الآيَةِ ‏.‏", "bengali": "", "english": "“There was a dispute between myself and a Jewish man concerning some land, and he denied me my rights so I brought him to the Prophet (ﷺ). The Messenger of Allah (ﷺ) said to me: 'Do you have proof' I said: 'No.’ He said to the Jews, 'Swear an oath.' I said: 'If he swears an oath he will take my property.' Then Allah, Glorious is He, revealed: 'Verily, those who purchase a small gain at the cost of Allah's covenant and their oaths, they shall have no portion in the Hereafter (Paradise). Neither will Allah neither speak to them nor look at them on the Day of Resurrection nor will He purifies them, and they shall have a painful torment.'”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  جمیلہ بنت سلول رضی اللہ عنہا نے نبی اکرم صلی اللہ علی", "grades": "", "reference": "", "international_number": "2056", "narrator_chain": "It was narrated that Ash'ath bin Qais Said:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2057", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا وَكِيعٌ، وَأَبُو مُعَاوِيَةَ قَالاَ حَدَّثَنَا الأَعْمَشُ، عَنْ شَقِيقٍ، عَنْ عَبْدِ اللَّهِ بْنِ مَسْعُودٍ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنْ حَلَفَ عَلَى يَمِينٍ وَهُوَ فِيهَا فَاجِرٌ يَقْتَطِعُ بِهَا مَالَ امْرِئٍ مُسْلِمٍ لَقِيَ اللَّهَ وَهُوَ عَلَيْهِ غَضْبَانُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“Whoever swears a false oath in order to seize the wealth of a Muslim unlawfully, he will meet Allah when He is angry with him.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from 'Abdullah bin Mas'ud that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2058", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو أُسَامَةَ، عَنِ الْوَلِيدِ بْنِ كَثِيرٍ، عَنْ مُحَمَّدِ بْنِ كَعْبٍ، أَنَّهُ سَمِعَ أَخَاهُ عَبْدَ اللَّهِ بْنَ كَعْبٍ، أَنَّ أَبَا أُمَامَةَ الْحَارِثِيَّ، حَدَّثَهُ أَنَّهُ، سَمِعَ رَسُولَ اللَّهِ صلى الله عليه وسلم يَقُولُ ‏\"‏ لاَ يَقْتَطِعُ رَجُلٌ حَقَّ امْرِئٍ مُسْلِمٍ بِيَمِينِهِ إِلاَّ حَرَّمَ اللَّهُ عَلَيْهِ الْجَنَّةَ وَأَوْجَبَ لَهُ النَّارَ ‏\"‏ ‏.‏ فَقَالَ رَجُلٌ مِنَ الْقَوْمِ يَا رَسُولَ اللَّهِ وَإِنْ كَانَ شَيْئًا يَسِيرًا قَالَ ‏\"‏ وَإِنْ كَانَ سِوَاكًا مِنْ أَرَاكٍ ‏\"‏ ‏.‏", "bengali": "", "english": "“No man seizes the wealth of a Muslim unlawfully by means of his (false) oath, but Allah will deny Paradise to him and will doom him to Hell.” A man among the people said: “O Messenger of Allah, even if it is something small?” He said: “Even if it is a twig of an Arak tree.”", "french": "", "indonesian": "", "russian": "", "urdu": "عبادہ بن صامت رضی اللہ عنہ کہتے ہیں کہ  میں نے ربیع بنت معوذ بن عفراء رضی اللہ عنہا سے کہا: تم مجھ س", "grades": "", "reference": "", "international_number": "2058", "narrator_chain": "Abu Umamah Al-Harithi  narrated that he heard the Messenger of Allah (ﷺ) say:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2059", "arabic": "حَدَّثَنَا عَمْرُو بْنُ رَافِعٍ، حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِيَةَ، ح وَحَدَّثَنَا أَحْمَدُ بْنُ ثَابِتٍ الْجَحْدَرِيُّ، حَدَّثَنَا صَفْوَانُ بْنُ عِيسَى، قَالاَ حَدَّثَنَا هَاشِمُ بْنُ هَاشِمٍ، عَنْ عَبْدِ اللَّهِ بْنِ نِسْطَاسٍ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنْ حَلَفَ بِيَمِينٍ آثِمَةٍ عِنْدَ مِنْبَرِي هَذَا فَلْيَتَبَوَّأْ مَقْعَدَهُ مِنَ النَّارِ وَلَوْ عَلَى سِوَاكٍ أَخْضَرَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "'Whoever swears a false oath near this pulpit of mine, let him take his place in Hell, even if it is for a green twig.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Jabir bin 'Abdullah that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2060", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، وَزَيْدُ بْنُ أَخْزَمَ، قَالاَ حَدَّثَنَا الضَّحَّاكُ بْنُ مَخْلَدٍ، حَدَّثَنَا الْحَسَنُ بْنُ يَزِيدَ بْنِ فَرُّوخَ، - قَالَ مُحَمَّدُ بْنُ يَحْيَى وَهُوَ أَبُو يُونُسَ الْقَوِيُّ - قَالَ سَمِعْتُ أَبَا سَلَمَةَ، يَقُولُ سَمِعْتُ أَبَا هُرَيْرَةَ، يَقُولُ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ لاَ يَحْلِفُ عِنْدَ هَذَا الْمِنْبَرِ عَبْدٌ وَلاَ أَمَةٌ عَلَى يَمِينٍ آثِمَةٍ وَلَوْ عَلَى سِوَاكٍ رَطْبٍ إِلاَّ وَجَبَتْ لَهُ النَّارُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "I heard Abu Salamah say: I heard Abu Hurairah say: “The Messenger of Allah (ﷺ) said: 'No man or woman swears a false oath beside this pulpit, even if it is for a fresh twig, but he will be doomed to Hell.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Muhammad bin Yahya, who is Abu Yunus Al-Qawi, said:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2061", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، عَنِ الأَعْمَشِ، عَنْ عَبْدِ اللَّهِ بْنِ مُرَّةَ، عَنِ الْبَرَاءِ بْنِ عَازِبٍ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم دَعَا رَجُلاً مِنْ عُلَمَاءِ الْيَهُودِ فَقَالَ ‏ ‏ أَنْشُدُكَ بِاللَّهِ الَّذِي أَنْزَلَ التَّوْرَاةَ عَلَى مُوسَى ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“ Swear by the One Who sent the Torah (Tawrah) down to Musa.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Bara' bin 'Azib that the Messenger of Allah (ﷺ) called one of the Jewish scholars and said:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2062", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا أَبُو أُسَامَةَ، عَنْ مُجَالِدٍ، أَنْبَأَنَا عَامِرٌ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ لِيَهُودِيَّيْنِ ‏ ‏ نَشَدْتُكُمَا بِاللَّهِ الَّذِي أَنْزَلَ التَّوْرَاةَ عَلَى مُوسَى عَلَيْهِ السَّلاَمُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“Swear by Allah Who sent the Tawrah down to Musa, peace be upon him.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Jabir bin 'Abdullah that the Messenger of Allah (ﷺ) said to two Jews:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2063", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا خَالِدُ بْنُ الْحَارِثِ، حَدَّثَنَا سَعِيدُ بْنُ أَبِي عَرُوبَةَ، عَنْ قَتَادَةَ، عَنْ خِلاَسٍ، عَنْ أَبِي رَافِعٍ، عَنْ أَبِي هُرَيْرَةَ، أَنَّهُ ذَكَرَ أَنَّ رَجُلَيْنِ، ادَّعَيَا دَابَّةً وَلَمْ يَكُنْ بَيْنَهُمَا بَيِّنَةٌ فَأَمَرَهُمَا النَّبِيُّ صلى الله عليه وسلم أَنْ يَسْتَهِمَا عَلَى الْيَمِينِ ‏.‏", "bengali": "", "english": "he said that two men laid claim to an animal, and neither of them had any proof, so the Prophet (ﷺ) commanded them to cast lots as to which of them should swear an oath.", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا نے کہا  بابرکت ہے وہ ذات جو ہر چیز کو سنتی ہے، میں خولہ بنت ثعلبہ رض", "grades": "", "reference": "", "international_number": "2063", "narrator_chain": "It was narrated from Abu Hurairah that:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2064", "arabic": "حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ، وَمُحَمَّدُ بْنُ مَعْمَرٍ، وَزُهَيْرُ بْنُ مُحَمَّدٍ، قَالُوا حَدَّثَنَا رَوْحُ بْنُ عُبَادَةَ، حَدَّثَنَا سَعِيدٌ، عَنْ قَتَادَةَ، عَنْ سَعِيدِ بْنِ أَبِي بُرْدَةَ، عَنْ أَبِيهِ، عَنْ أَبِي مُوسَى، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم اخْتَصَمَ إِلَيْهِ رَجُلاَنِ بَيْنَهُمَا دَابَّةٌ وَلَيْسَ لِوَاحِدٍ مِنْهُمَا بَيِّنَةٌ فَجَعَلَهَا بَيْنَهُمَا نِصْفَيْنِ ‏.‏", "bengali": "", "english": "two men referred a dispute to the Messenger of Allah (ﷺ) concerning an animal, and neither of them had proof, so he ruled that it should be divided in half.", "french": "", "indonesian": "", "russian": "", "urdu": "سلمہ بن صخر بیاضی رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے ظہار کرنے والے شخص کے متع", "grades": "", "reference": "", "international_number": "2064", "narrator_chain": "It was narrated from Abu Musa that :", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2065", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، حَدَّثَنَا حَجَّاجٌ، عَنْ سَعِيدِ بْنِ عُبَيْدِ بْنِ زَيْدِ بْنِ عُقْبَةَ، عَنْ أَبِيهِ، عَنْ سَمُرَةَ بْنِ جُنْدُبٍ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ إِذَا ضَاعَ لِلرَّجُلِ مَتَاعٌ أَوْ سُرِقَ لَهُ مَتَاعٌ فَوَجَدَهُ فِي يَدِ رَجُلٍ يَبِيعُهُ فَهُوَ أَحَقُّ بِهِ وَيَرْجِعُ الْمُشْتَرِي عَلَى الْبَائِعِ بِالثَّمَنِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“If a man loses something, or it is stolen from him, and he finds it in the possession of a man who bought it, then he has more right to it, and the one who bought it should ask for his money back from the one who sold it to him.' ”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Samurah bin Jundub that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2066", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ الْمِصْرِيُّ، أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، عَنِ ابْنِ شِهَابٍ، أَنَّ ابْنَ مُحَيِّصَةَ الأَنْصَارِيَّ، أَخْبَرَهُ أَنَّ نَاقَةً لِلْبَرَاءِ كَانَتْ ضَارِيَةً دَخَلَتْ فِي حَائِطِ قَوْمٍ فَأَفْسَدَتْ فِيهِ فَكُلِّمَ رَسُولُ اللَّهِ صلى الله عليه وسلم فِيهَا فَقَضَى أَنَّ حِفْظَ الأَمْوَالِ عَلَى أَهْلِهَا بِالنَّهَارِ وَعَلَى أَهْلِ الْمَوَاشِي مَا أَصَابَتْ مَوَاشِيهِمْ بِاللَّيْلِ ‏.‏ حَدَّثَنَا الْحَسَنُ بْنُ عَلِيِّ بْنِ عَفَّانَ، حَدَّثَنَا مُعَاوِيَةُ بْنُ هِشَامٍ، عَنْ سُفْيَانَ، عَنْ عَبْدِ اللَّهِ بْنِ عِيسَى، عَنِ الزُّهْرِيِّ، عَنْ حَرَامِ بْنِ مُحَيِّصَةَ، عَنِ الْبَرَاءِ بْنِ عَازِبٍ، أَنَّ نَاقَةً، لآلِ الْبَرَاءِ أَفْسَدَتْ شَيْئًا فَقَضَى رَسُولُ اللَّهِ صلى الله عليه وسلم بِمِثْلِهِ ‏.‏\"", "bengali": "", "english": "Ibn Muhayyisah Al-Ansari told him that a she-camel belonging to Bara used to wander free. It entered a garden belonging to some people and caused some damage. The Messenger of Allah (ﷺ) was told of that, and he ruled that property was to be protected by its owners of livestock were responsible for any damage caused by their animals during the night.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Ibn Shihab that :", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2067", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا شَرِيكُ بْنُ عَبْدِ اللَّهِ، عَنْ قَيْسِ بْنِ وَهْبٍ، عَنْ رَجُلٍ، مِنْ بَنِي سُوَاءَةَ قَالَ قُلْتُ لِعَائِشَةَ أَخْبِرِينِي عَنْ خُلُقِ، رَسُولِ اللَّهِ صلى الله عليه وسلم ‏.‏ قَالَتْ أَوَمَا تَقْرَأُ الْقُرْآنَ ‏{وَإِنَّكَ لَعَلَى خُلُقٍ عَظِيمٍ}‏ قَالَتْ كَانَ رَسُولُ اللَّهِ صلى الله عليه وسلم مَعَ أَصْحَابِهِ فَصَنَعْتُ لَهُ طَعَامًا وَصَنَعَتْ حَفْصَةُ لَهُ طَعَامًا ‏.‏ قَالَتْ فَسَبَقَتْنِي حَفْصَةُ فَقُلْتُ لِلْجَارِيَةِ انْطَلِقِي فَأَكْفِئِي قَصْعَتَهَا فَلَحِقَتْهَا وَقَدْ هَوَتْ أَنْ تَضَعَ بَيْنَ يَدَىْ رَسُولِ اللَّهِ صلى الله عليه وسلم فَأَكْفَأَتْهَا فَانْكَسَرَتِ الْقَصْعَةُ وَانْتَشَرَ الطَّعَامُ ‏.‏ قَالَتْ فَجَمَعَهَا رَسُولُ اللَّهِ صلى الله عليه وسلم وَمَا فِيهَا مِنَ الطَّعَامِ عَلَى النِّطَعِ فَأَكَلُوا ثُمَّ بَعَثَ بِقَصْعَتِي فَدَفَعَهَا إِلَى حَفْصَةَ فَقَالَ ‏\"‏ خُذُوا ظَرْفًا مَكَانَ ظَرْفِكُمْ ‏\"‏ ‏.‏ قَالَتْ فَمَا رَأَيْتُ ذَلِكَ فِي وَجْهِ رَسُولِ اللَّهِ صلى الله عليه وسلم ‏.‏", "bengali": "", "english": "'I said to 'Aishah: Tell me about the character of the Messenger of Allah (ﷺ).' She said: 'Have you not read the Qur'an: “And verily, you (O Mohammed {SAW}) are on an exalted (standard of) character?” She said: 'The Messenger of Allah (ﷺ) was with his Companions, and I made some food for him, and Hafsah made some food for him, but Hafash got there before me. So I said to the slave girl: “Overturn her bowl.” She went and caught up with her, and she was about to put (the bowl) in front of the Messenger of Allah (ﷺ). She overturned it and the bowl broke, scattering the food. The Messenger of Allah (ﷺ) gathered the pieces and the food on the leather mat and they ate. Then he sent for my bowl and gave it to Hafsah, and said: “Take this pot in place of your pot, and eat what is in it.” And I did not see any expression of anger on the face of the Messenger of Allah (ﷺ).' ”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  ہلال بن امیہ رضی اللہ عنہ نے اپنی بیوی پر نبی اکرم صلی ا", "grades": "", "reference": "", "international_number": "2067", "narrator_chain": "It was narrated that a man from Banu Suwa'ah said:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2068", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، حَدَّثَنَا خَالِدُ بْنُ الْحَارِثِ، حَدَّثَنَا حُمَيْدٌ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ كَانَ النَّبِيُّ صلى الله عليه وسلم عِنْدَ إِحْدَى أُمَّهَاتِ الْمُؤْمِنِينَ فَأَرْسَلَتْ أُخْرَى بِقَصْعَةٍ فِيهَا طَعَامٌ فَضَرَبَتْ يَدَ الرَّسُولِ فَسَقَطَتِ الْقَصْعَةُ فَانْكَسَرَتْ فَأَخَذَ رَسُولُ اللَّهِ صلى الله عليه وسلم الْكِسْرَتَيْنِ فَضَمَّ إِحْدَاهُمَا إِلَى الأُخْرَى فَجَعَلَ يَجْمَعُ فِيهَا الطَّعَامَ وَيَقُولُ ‏ ‏ غَارَتْ أُمُّكُمْ كُلُوا ‏\"\"‏ ‏.‏ فَأَكَلُوا حَتَّى جَاءَتْ بِقَصْعَتِهَا الَّتِي فِي بَيْتِهَا فَدَفَعَ الْقَصْعَةَ الصَّحِيحَةَ إِلَى الرَّسُولِ وَتَرَكَ الْمَكْسُورَةَ فِي بَيْتِ الَّتِي كَسَرَتْهَا ‏.‏\"", "bengali": "", "english": "“The Prophet (ﷺ) was with one of the Mothers of the Believers (his wives) and another (wife) sent a bowl containing food. She (the first wife) struck the hand of the Messenger of (ﷺ) and the bowl fell and broke. The Messenger of Allah (ﷺ) took the two pieces and put them back together, then he started gathering up the food and putting it in (the bowl). He said: 'Your mother was jealous. Eat.' So they ate, and she (the wife who broke the bowl) brought the bowl that was in her house and gave the intact bowl to the Messenger (ﷺ), who left the broken bowl in the house of the one who broke it.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Anas bin Malik said:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2069", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، وَمُحَمَّدُ بْنُ الصَّبَّاحِ، قَالاَ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ الزُّهْرِيِّ، عَنْ عَبْدِ الرَّحْمَنِ الأَعْرَجِ، قَالَ سَمِعْتُ أَبَا هُرَيْرَةَ، يَبْلُغُ بِهِ النَّبِيَّ صلى الله عليه وسلم قَالَ ‏ ‏ إِذَا اسْتَأْذَنَ أَحَدَكُمْ جَارُهُ أَنْ يَغْرِزَ خَشَبَةً فِي جِدَارِهِ فَلاَ يَمْنَعْهُ ‏\"\"‏ ‏.‏ فَلَمَّا حَدَّثَهُمْ أَبُو هُرَيْرَةَ طَأْطَئُوا رُءُوسَهُمْ فَلَمَّا رَآهُمْ قَالَ مَالِي أَرَاكُمْ عَنْهَا مُعْرِضِينَ وَاللَّهِ لأَرْمِيَنَّ بِهَا بَيْنَ أَكْتَافِكُمْ ‏.‏\"", "bengali": "", "english": "“The Prophet (ﷺ): 'When anyone of you asks his neighbor for permission to fix a piece of wood to his wall, he should not refuse him. 'When Abu Hurairah told them this, they lowered their heads, and when he saw them he said: 'Why do I see you turning away from it? By Allah, I will force you to accept it.' ”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Anas bin Malik said:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2070", "arabic": "حَدَّثَنَا أَبُو بِشْرٍ، بَكْرُ بْنُ خَلَفٍ حَدَّثَنَا أَبُو عَاصِمٍ، عَنِ ابْنِ جُرَيْجٍ، عَنْ عَمْرِو بْنِ دِينَارٍ، أَنَّ هِشَامَ بْنَ يَحْيَى، أَخْبَرَهُ أَنَّ عِكْرِمَةَ بْنَ سَلَمَةَ أَخْبَرَهُ أَنَّ أَخَوَيْنِ مِنْ بَلْمُغِيرَةَ أَعْتَقَ أَحَدُهُمَا أَنْ لاَ يَغْرِزَ خَشَبًا فِي جِدَارِهِ فَأَقْبَلَ مُجَمِّعُ بْنُ يَزِيدَ وَرِجَالٌ كَثِيرٌ مِنَ الأَنْصَارِ فَقَالُوا نَشْهَدُ أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ لاَ يَمْنَعْ أَحَدُكُمْ جَارَهُ أَنْ يَغْرِزَ خَشَبَةً فِي جِدَارِهِ ‏\"\"‏ ‏.‏ فَقَالَ يَا أَخِي إِنَّكَ مَقْضِيٌّ لَكَ عَلَىَّ وَقَدْ حَلَفْتُ فَاجْعَلْ أُسْطُوَانًا دُونَ حَائِطِي أَوْ جِدَارِي فَاجْعَلْ عَلَيْهِ خَشَبَكَ ‏.‏\"", "bengali": "", "english": "there were two brothers from among the sons of Mughirah. One of them swore an oath to set a slave free if the other one fixed a piece of wood to his wall. Mujammi' bin Yazid  and many men from among the Ansar came and said: “We bear witness that the Messenger of Allah (ﷺ) said: 'None of you should refuse to let his neighbor fix a piece of wood to his wall.' ” He said: 'O my brother, judgment has been passed in your favor against me, but I have sworn an oath.' So go ahead and fix your wood to my wall.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "'Ikrimah bin Salamh narrated that :", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2071", "arabic": "حَدَّثَنَا حَرْمَلَةُ بْنُ يَحْيَى، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، أَخْبَرَنِي ابْنُ لَهِيعَةَ، عَنْ أَبِي الأَسْوَدِ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ النَّبِيَّ صلى الله عليه وسلم قَالَ ‏ ‏ لاَ يَمْنَعْ أَحَدُكُمْ جَارَهُ أَنْ يَضَعَ خَشَبَةً عَلَى جِدَارِهِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“No one of you should refuse to let his neighbor fix a piece of wood to his wall.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Ibn 'Abbas that the Prophet (ﷺ) said:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2072", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا مُثَنَّى بْنُ سَعِيدٍ الضُّبَعِيُّ، عَنْ قَتَادَةَ، عَنْ بَشِيرِ بْنِ كَعْبٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ اجْعَلُوا الطَّرِيقَ سَبْعَةَ أَذْرُعٍ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“Make the path seven forearms length wide.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2073", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، وَمُحَمَّدُ بْنُ عُمَرَ بْنِ هَيَّاجٍ، قَالاَ حَدَّثَنَا قَبِيصَةُ، حَدَّثَنَا سُفْيَانُ، عَنْ سِمَاكٍ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ إِذَا اخْتَلَفْتُمْ فِي الطَّرِيقِ فَاجْعَلُوهُ سَبْعَةَ أَذْرُعٍ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“When you dispute concerning a path, make it seven forearms length wide.' ”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Ibn 'Abbas that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2074", "arabic": "حَدَّثَنَا عَبْدُ رَبِّهِ بْنُ خَالِدٍ النُّمَيْرِيُّ أَبُو الْمُغَلِّسِ، حَدَّثَنَا فُضَيْلُ بْنُ سُلَيْمَانَ، حَدَّثَنَا مُوسَى بْنُ عُقْبَةَ، حَدَّثَنَا إِسْحَاقُ بْنُ يَحْيَى بْنِ الْوَلِيدِ، عَنْ عُبَادَةَ بْنِ الصَّامِتِ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَضَى أَنْ ‏ ‏ لاَ ضَرَرَ وَلاَ ضِرَارَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“There should be neither harming nor reciprocating harm.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from 'Ubadah bin Samit that the Messenger of Allah (ﷺ) ruled:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2075", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَنْبَأَنَا مَعْمَرٌ، عَنْ جَابِرٍ الْجُعْفِيِّ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ لاَ ضَرَرَ وَلاَ ضِرَارَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“There should be neither harming nor reciprocating harm.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Ibn 'Abbas that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2076", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، عَنْ يَحْيَى بْنِ سَعِيدٍ، عَنْ مُحَمَّدِ بْنِ يَحْيَى بْنِ حَبَّانَ، عَنْ لُؤْلُؤَةَ، عَنْ أَبِي صِرْمَةَ، عَنْ رَسُولِ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ مَنْ ضَارَّ أَضَرَّ اللَّهُ بِهِ وَمَنْ شَاقَّ شَقَّ اللَّهُ عَلَيْهِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“Whoever harms others, Allah (SWT)  will harm him; and whoever causes hardship to other Allah will cause hardship to him.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Sirmah that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2077", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، وَعَمَّارُ بْنُ خَالِدٍ الْوَاسِطِيُّ، قَالاَ حَدَّثَنَا أَبُو بَكْرِ بْنُ عَيَّاشٍ، عَنْ دَهْثَمِ بْنِ قُرَّانٍ، عَنْ نِمْرَانَ بْنِ جَارِيَةَ، عَنْ أَبِيهِ، أَنَّ قَوْمًا، اخْتَصَمُوا إِلَى النَّبِيِّ صلى الله عليه وسلم فِي خُصٍّ كَانَ بَيْنَهُمْ فَبَعَثَ حُذَيْفَةَ يَقْضِي بَيْنَهُمْ فَقَضَى لِلَّذِينَ يَلِيهِمُ الْقِمْطُ فَلَمَّا رَجَعَ إِلَى النَّبِيِّ صلى الله عليه وسلم أَخْبَرَهُ فَقَالَ ‏ ‏ أَصَبْتَ وَأَحْسَنْتَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "some people referred a dispute to the Prophet (ﷺ) about a hut, so that he could judge between them. He sent Hudhaifah to judge between them, and he ruled in favor of those who had the rope (with which the hut was blinded together). When he went back to the Prophet (ﷺ) he told him (what he had done) and he said: “You did the right thing, and you did well.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Nimran bin Jariyah, from his father, that :", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2078", "arabic": "حَدَّثَنَا يَحْيَى بْنُ حَكِيمٍ، حَدَّثَنَا أَبُو الْوَلِيدِ، حَدَّثَنَا هَمَّامٌ، عَنْ قَتَادَةَ، عَنِ الْحَسَنِ، عَنْ سَمُرَةَ بْنِ جُنْدُبٍ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ إِذَا بِيعَ الْبَيْعُ مِنْ رَجُلَيْنِ فَالْبَيْعُ لِلأَوَّلِ ‏\"\"‏ ‏.‏ قَالَ أَبُو الْوَلِيدِ فِي هَذَا الْحَدِيثِ إِبْطَالُ الْخَلاَصِ ‏.‏\"", "bengali": "", "english": "the Messenger of Allah (ﷺ) said: “If a product is sold to two men, it is for the one who was first.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from ('Uqbah bin 'Amir or) Samurah bin Jundub that :", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2079", "arabic": "حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ، وَمُحَمَّدُ بْنُ الْمُثَنَّى، قَالاَ حَدَّثَنَا عَبْدُ الأَعْلَى، حَدَّثَنَا خَالِدٌ الْحَذَّاءُ، عَنْ أَبِي قِلاَبَةَ، عَنْ أَبِي الْمُهَلَّبِ، عَنْ عِمْرَانَ بْنِ حُصَيْنٍ، أَنَّ رَجُلاً، كَانَ لَهُ سِتَّةُ مَمْلُوكِينَ لَيْسَ لَهُ مَالٌ غَيْرُهُمْ فَأَعْتَقَهُمْ عِنْدَ مَوْتِهِ فَجَزَّأَهُمْ رَسُولُ اللَّهِ صلى الله عليه وسلم فَأَعْتَقَ اثْنَيْنِ وَأَرَقَّ أَرْبَعَةً ‏.‏", "bengali": "", "english": "a man had six slaves, and he did not have any other wealth apart from them, and he set them free when he died. The Messenger of Allah (ﷺ) divided them into groups, set two free and left four as slaves.", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  لونڈی کے لیے دو", "grades": "", "reference": "", "international_number": "2079", "narrator_chain": "It was narrated from 'Imran bin Husain that :", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2080", "arabic": "حَدَّثَنَا جَمِيلُ بْنُ الْحَسَنِ الْعَتَكِيُّ، حَدَّثَنَا عَبْدُ الأَعْلَى، حَدَّثَنَا سَعِيدٌ، عَنْ قَتَادَةَ، عَنْ خِلاَسٍ، عَنْ أَبِي رَافِعٍ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَجُلَيْنِ، تَدَارَءَا فِي بَيْعٍ لَيْسَ لِوَاحِدٍ مِنْهُمَا بَيِّنَةٌ فَأَمَرَهُمَا رَسُولُ اللَّهِ صلى الله عليه وسلم أَنْ يَسْتَهِمَا عَلَى الْيَمِينِ أَحَبَّا ذَلِكَ أَمْ كَرِهَا ‏.‏", "bengali": "", "english": "two men disputed concerning a transaction, and neither of them had proof. The Messenger of Allah commanded them to draw lots as to which of them should swear an oath, whether they liked it or not.", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  لونڈی کی دو طلا", "grades": "", "reference": "", "international_number": "2080", "narrator_chain": "It was narrated from Abu Hurairah that :", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2081", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَحْيَى بْنُ يَمَانٍ، عَنْ مَعْمَرٍ، عَنِ الزُّهْرِيِّ، عَنْ عُرْوَةَ، عَنْ عَائِشَةَ، أَنَّ النَّبِيَّ صلى الله عليه وسلم كَانَ إِذَا سَافَرَ أَقْرَعَ بَيْنَ نِسَائِهِ ‏.‏", "bengali": "", "english": "when the Prophet (ﷺ) traveled, he would cast lots among his wives (to decide which one would accompany him).", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کے پاس ایک آدمی آیا، اور ا", "grades": "", "reference": "", "international_number": "2081", "narrator_chain": "It was narrated from 'Aishah that :", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2082", "arabic": "حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ، أَنْبَأَنَا عَبْدُ الرَّزَّاقِ، أَنْبَأَنَا الثَّوْرِيُّ، عَنْ صَالِحٍ الْهَمْدَانِيِّ، عَنِ الشَّعْبِيِّ، عَنْ عَبْدِ خَيْرٍ الْحَضْرَمِيِّ، عَنْ زَيْدِ بْنِ أَرْقَمَ، قَالَ أُتِيَ عَلِيُّ بْنُ أَبِي طَالِبٍ وَهُوَ بِالْيَمَنِ فِي ثَلاَثَةٍ قَدْ وَقَعُوا عَلَى امْرَأَةٍ فِي طُهْرٍ وَاحِدٍ فَسَأَلَ اثْنَيْنِ فَقَالَ أَتُقِرَّانِ لِهَذَا بِالْوَلَدِ فَقَالاَ لاَ ‏.‏ ثُمَّ سَأَلَ اثْنَيْنِ فَقَالَ أَتُقِرَّانِ لِهَذَا بِالْوَلَدِ فَقَالاَ لاَ ‏.‏ فَجَعَلَ كُلَّمَا سَأَلَ اثْنَيْنِ أَتُقِرَّانِ لِهَذَا بِالْوَلَدِ قَالاَ لاَ ‏.‏ فَأَقْرَعَ بَيْنَهُمْ وَأَلْحَقَ الْوَلَدَ بِالَّذِي أَصَابَتْهُ الْقُرْعَةُ وَجَعَلَ عَلَيْهِ ثُلُثَىِ الدِّيَةِ فَذُكِرَ ذَلِكَ لِلنَّبِيِّ صلى الله عليه وسلم فَضَحِكَ حَتَّى بَدَتْ نَوَاجِذُهُ ‏.‏", "bengali": "", "english": "“A case was brought to 'Ali bin Abu Talib when he was in Yemen, concerning three men who had intercourse with a woman during one period of being free from menses. He asked two of them: “Do you affirm that this child belongs to (the third man)?” And they said: “No.” He asked another two of them: “Do you affirm that this child belongs to (the third man)?” And they said: “No.” Every time he asked two of them whether they affirmed that the child belonged to the third, they would say no. So he cast lots between them, and attributed the child to the one whose name was chosen in this manner, and obliged him to pay two thirds of the Diyah. The Prophet (ﷺ) was told of this, and he smiled so broadly that his back teeth became visible.", "french": "", "indonesian": "", "russian": "", "urdu": "ابوالحسن مولی بنی نوفل کہتے ہیں کہ  عبداللہ بن عباس رضی اللہ عنہما سے اس غلام کے بارے میں پوچھا گیا", "grades": "", "reference": "", "international_number": "2082", "narrator_chain": "It was narrated that Zaid bin Arqam said:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2083", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَهِشَامُ بْنُ عَمَّارٍ، وَمُحَمَّدُ بْنُ الصَّبَّاحِ، قَالُوا حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ الزُّهْرِيِّ، عَنْ عُرْوَةَ، عَنْ عَائِشَةَ، قَالَتْ دَخَلَ عَلَىَّ رَسُولُ اللَّهِ صلى الله عليه وسلم ذَاتَ يَوْمٍ مَسْرُورًا وَهُوَ يَقُولُ ‏\"‏ يَا عَائِشَةُ أَلَمْ تَرَىْ أَنَّ مُجَزِّزًا الْمُدْلِجِيَّ دَخَلَ عَلَىَّ فَرَأَى أُسَامَةَ وَزَيْدًا عَلَيْهِمَا قَطِيفَةٌ قَدْ غَطَّيَا رُءُوسَهُمَا وَقَدْ بَدَتْ أَقْدَامُهُمَا فَقَالَ ‏\"‏ إِنَّ هَذِهِ الأَقْدَامَ بَعْضُهَا مِنْ بَعْضٍ ‏\"‏ ‏.‏", "bengali": "", "english": "“The Messenger of Allah (ﷺ) came in one day looking happy, and said: 'O 'Aishah, did you not see that Mujazziz Al-Mudliji entered upon me and saw Usamah and Zaid. There was a blanket over them and their faces were covered but their feet were exposed, and he said: 'These feet belong to one another'.”", "french": "", "indonesian": "", "russian": "", "urdu": "عمرو بن العاص رضی اللہ عنہ کہتے ہیں کہ  ہم پر ہمارے نبی محمد صلی اللہ علیہ وسلم کی سنت کو نہ بگاڑو،", "grades": "", "reference": "", "international_number": "2083", "narrator_chain": "It was narrated that 'Aishah said:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2084", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ، حَدَّثَنَا إِسْرَائِيلُ، حَدَّثَنَا سِمَاكُ بْنُ حَرْبٍ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ قُرَيْشًا، أَتَوُا امْرَأَةً كَاهِنَةً فَقَالُوا لَهَا أَخْبِرِينَا أَشْبَهَنَا أَثَرًا بِصَاحِبِ الْمَقَامِ ‏.‏ فَقَالَتْ إِنْ أَنْتُمْ جَرَرْتُمْ كِسَاءً عَلَى هَذِهِ السِّهْلَةِ ثُمَّ مَشَيْتُمْ عَلَيْهَا أَنْبَأْتُكُمْ ‏.‏ قَالَ فَجَرُّوا كِسَاءً ثُمَّ مَشَى النَّاسُ عَلَيْهَا فَأَبْصَرَتْ أَثَرَ رَسُولِ اللَّهِ صلى الله عليه وسلم ‏.‏ فَقَالَتْ هَذَا أَقْرَبُكُمْ إِلَيْهِ شَبَهًا ‏.‏ ثُمَّ مَكَثُوا بَعْدَ ذَلِكَ عِشْرِينَ سَنَةً أَوْ مَا شَاءَ اللَّهُ ثُمَّ بَعَثَ اللَّهُ مُحَمَّدًا صلى الله عليه وسلم ‏.‏", "bengali": "", "english": "the Quraish went to a sorceress and they said to her: “Tell us whose footprints most resemble those of the owner of Al-Maqam (the station of Ibrahim).” She said: “If you spread a piece of cloth over this soft earth and walk over it, I will tell you.” So they spread out a piece of cloth and the people walked over it. She saw the footprints of the Messenger of Allah (ﷺ) and said: “This one most closely resembles him among you.”  After that twenty years passed, of as long as Allah willed, then Allah sent Muhammad (ﷺ) (i.e., missioned him as the Prophet).", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین ام سلمہ اور ام المؤمنین ام حبیبہ رضی اللہ عنہما ذکر کرتی ہیں کہ  ایک عورت نبی اکرم صلی ا", "grades": "", "reference": "", "international_number": "2084", "narrator_chain": "It was narrated from Ibn 'Abbas that :", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2085", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ زِيَادِ بْنِ سَعْدٍ، عَنْ هِلاَلِ بْنِ أَبِي مَيْمُونَةَ، عَنْ أَبِي مَيْمُونَةَ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ النَّبِيَّ صلى الله عليه وسلم خَيَّرَ غُلاَمًا بَيْنَ أَبِيهِ وَأُمِّهِ وَقَالَ ‏ ‏ يَا غُلاَمُ هَذِهِ أُمُّكَ وَهَذَا أَبُوكَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "the Prophet (ﷺ) gave a child the choice between his father and his mother (i.e., which parent to live with). He said: “O boy, this is your mother and this is your father.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah that :", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2086", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا إِسْمَاعِيلُ ابْنُ عُلَيَّةَ، عَنْ عُثْمَانَ الْبَتِّيِّ، عَنْ عَبْدِ الْحَمِيدِ بْنِ سَلَمَةَ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، أَنَّ أَبَوَيْهِ، اخْتَصَمَا إِلَى النَّبِيِّ صلى الله عليه وسلم أَحَدُهُمَا كَافِرٌ وَالآخَرُ مُسْلِمٌ فَخَيَّرَهُ فَتَوَجَّهَ إِلَى الْكَافِرِ فَقَالَ ‏ ‏ اللَّهُمَّ اهْدِهِ ‏\"\"‏ ‏.‏ فَتَوَجَّهَ إِلَى الْمُسْلِمِ فَقَضَى لَهُ بِهِ ‏.‏\"", "bengali": "", "english": "his parents referred their dispute to the Prophet (ﷺ), and one of them was a disbeliever. He (the Prophet (ﷺ)) said: “O Allah, guide him,” and he turned towards the Muslim, and he ruled that he should go with that parent.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from 'Abdul-Hamid bin Salamah, from his father, from his grandfather, that :", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2087", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ، حَدَّثَنَا كَثِيرُ بْنُ عَبْدِ اللَّهِ بْنِ عَمْرِو بْنِ عَوْفٍ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، قَالَ سَمِعْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم يَقُولُ ‏ ‏ الصُّلْحُ جَائِزٌ بَيْنَ الْمُسْلِمِينَ إِلاَّ صُلْحًا حَرَّمَ حَلاَلاً أَوْ أَحَلَّ حَرَامًا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“I heard the Messenger of Allah (ﷺ) say: 'Reconciling between Muslims is permissible, except reconciliation that forbids something that is allowed, or allows something that is forbidden.'”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Kathir bin 'Abdullah bin 'Amr bin 'Awf narrated from his father that his grandfather said:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2088", "arabic": "حَدَّثَنَا أَزْهَرُ بْنُ مَرْوَانَ، حَدَّثَنَا عَبْدُ الأَعْلَى، حَدَّثَنَا سَعِيدٌ، عَنْ قَتَادَةَ، عَنْ أَنَسِ بْنِ مَالِكٍ، أَنَّ رَجُلاً، كَانَ فِي عَهْدِ رَسُولِ اللَّهِ صلى الله عليه وسلم فِي عُقْدَتِهِ ضَعْفٌ وَكَانَ يُبَايِعُ وَأَنَّ أَهْلَهُ أَتَوُا النَّبِيَّ صلى الله عليه وسلم فَقَالُوا يَا رَسُولَ اللَّهِ احْجُرْ عَلَيْهِ ‏.‏ فَدَعَاهُ النَّبِيُّ صلى الله عليه وسلم فَنَهَاهُ عَنْ ذَلِكَ فَقَالَ يَا رَسُولَ اللَّهِ إِنِّي لاَ أَصْبِرُ عَنِ الْبَيْعِ ‏.‏ فَقَالَ ‏ ‏ إِذَا بَايَعْتَ فَقُلْ هَا وَلاَ خِلاَبَةَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "there was a man at the time of the Messenger of Allah (ﷺ) whose mental faculties were lacking, and he used to buy and sell. His family came to the Prophet (ﷺ) and said, “O Messenger of Allah, stop him.” So The Prophet (ﷺ) called him, and told him not to do that. He said: “O Messenger of Allah (ﷺ), I cannot bear to be away from business.” He said, “If you engage in a transaction then say: “Take it (i.e., the goods) and don't cheat (me).' ”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Anas bin Malik that :", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2089", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ الأَعْلَى، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ، عَنْ مُحَمَّدِ بْنِ يَحْيَى بْنِ حَبَّانٍ، قَالَ هُوَ جَدِّي مُنْقِذُ بْنُ عَمْرٍو وَكَانَ رَجُلاً قَدْ أَصَابَتْهُ آمَّةٌ فِي رَأْسِهِ فَكَسَرَتْ لِسَانَهُ وَكَانَ لاَ يَدَعُ عَلَى ذَلِكَ التِّجَارَةَ وَكَانَ لاَ يَزَالُ يُغْبَنُ فَأَتَى النَّبِيَّ صلى الله عليه وسلم فَذَكَرَ ذَلِكَ لَهُ فَقَالَ لَهُ ‏ ‏ إِذَا أَنْتَ بَايَعْتَ فَقُلْ لاَ خِلاَبَةَ ‏.‏ ثُمَّ أَنْتَ فِي كُلِّ سِلْعَةٍ ابْتَعْتَهَا بِالْخِيَارِ ثَلاَثَ لَيَالٍ فَإِنْ رَضِيتَ فَأَمْسِكْ وَإِنْ سَخِطْتَ فَارْدُدْهَا عَلَى صَاحِبِهَا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“My grandfather was Munqidh bin 'Amr. He was a man who had suffered a head wound and lost the power of speech, but that did not stop him from engaging in trade. He was always being cheated, so he went to the Prophet (ﷺ) and told him about that. He said to him: 'When you buy something, say: “There should be no intention of cheating,” and for every product you buy, you have the choice for three nights. If you are pleased with it, keep it, and if you are displeased then return it.'”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Muhammad bin Yahya bin Habban said:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2090", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا شَبَابَةُ، حَدَّثَنَا اللَّيْثُ بْنُ سَعْدٍ، عَنْ بُكَيْرِ بْنِ عَبْدِ اللَّهِ بْنِ الأَشَجِّ، عَنْ عِيَاضِ بْنِ عَبْدِ اللَّهِ بْنِ سَعْدٍ، عَنْ أَبِي سَعِيدٍ الْخُدْرِيِّ، قَالَ أُصِيبَ رَجُلٌ فِي عَهْدِ رَسُولِ اللَّهِ صلى الله عليه وسلم فِي ثِمَارٍ ابْتَاعَهَا فَكَثُرَ دَيْنُهُ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ تَصَدَّقُوا عَلَيْهِ ‏\"‏ ‏.‏ فَتَصَدَّقَ النَّاسُ عَلَيْهِ فَلَمْ يَبْلُغْ ذَلِكَ وَفَاءَ دَيْنِهِ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ خُذُوا مَا وَجَدْتُمْ وَلَيْسَ لَكُمْ إِلاَّ ذَلِكَ ‏\"‏ ‏.‏ يَعْنِي الْغُرَمَاءَ ‏.‏", "bengali": "", "english": "“At the time of the Messenger of Allah (ﷺ), a man suffered loss of some fruit that he had purchase, and his debts increased. The Messenger of Allah (ﷺ) said: 'Give him charity.' So the people gave him charity, but that was not enough to pay off his debts. The Messenger of Allah (ﷺ) said: “Take what you find, but you have no right to more than that, meaning his creditors.”", "french": "", "indonesian": "", "russian": "", "urdu": "رفاعہ جہنی رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم جب قسم کھاتے تو یہ فرماتے: «والذي ن", "grades": "", "reference": "", "international_number": "2090", "narrator_chain": "It was narrated that Abu Sa'eed Al-Khudri said:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2091", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا أَبُو عَاصِمٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ مُسْلِمِ بْنِ هُرْمُزٍ، عَنْ سَلَمَةَ الْمَكِّيِّ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم خَلَعَ مُعَاذَ بْنَ جَبَلٍ مِنْ غُرَمَائِهِ ثُمَّ اسْتَعْمَلَهُ عَلَى الْيَمَنِ فَقَالَ مُعَاذٌ إِنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم اسْتَخْلَصَنِي بِمَالِي ثُمَّ اسْتَعْمَلَنِي ‏.‏", "bengali": "", "english": "the Messenger of Allah (ﷺ) rid Mu'adh bin Jabal of his creditors, then he appointed him governor of Yemen. Mu'adh said: “The Messenger of Allah (ﷺ) settled my debts with my creditors using what wealth I had, then he appointed me as governor.”", "french": "", "indonesian": "", "russian": "", "urdu": "رفاعہ بن عرابہ جہنی رضی اللہ عنہ کہتے ہیں کہ  میں اللہ کو گواہ بنا کر کہتا ہوں کہ رسول اللہ صلی اللہ", "grades": "", "reference": "", "international_number": "2091", "narrator_chain": "It was narrated from Jabir bin 'Abdullah that :", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2092", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ح وَحَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، جَمِيعًا عَنْ يَحْيَى بْنِ سَعِيدٍ، عَنْ أَبِي بَكْرِ بْنِ مُحَمَّدِ بْنِ عَمْرِو بْنِ حَزْمٍ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِيزِ، عَنْ أَبِي بَكْرِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ الْحَارِثِ بْنِ هِشَامٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنْ وَجَدَ مَتَاعَهُ بِعَيْنِهِ عِنْدَ رَجُلٍ قَدْ أَفْلَسَ فَهُوَ أَحَقُّ بِهِ مِنْ غَيْرِهِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“Whoever finds his exact property with a man who has become bankrupt, and then he has more right to it than anyone else.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2093", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ عَيَّاشٍ، عَنْ مُوسَى بْنِ عُقْبَةَ، عَنِ الزُّهْرِيِّ، عَنْ أَبِي بَكْرِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ الْحَارِثِ بْنِ هِشَامٍ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ النَّبِيَّ صلى الله عليه وسلم قَالَ ‏ ‏ أَيُّمَا رَجُلٍ بَاعَ سِلْعَةً فَأَدْرَكَ سِلْعَتَهُ بِعَيْنِهَا عِنْدَ رَجُلٍ وَقَدْ أَفْلَسَ وَلَمْ يَكُنْ قَبَضَ مِنْ ثَمَنِهَا شَيْئًا فَهِيَ لَهُ ‏.‏ وَإِنْ كَانَ قَبَضَ مِنْ ثَمَنِهَا شَيْئًا فَهُوَ أُسْوَةُ الْغُرَمَاءِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“Any man who sells a product with the man who has become bankrupt, and he has not taken any of its price, it belongs to him, but if he had taken any of its price, then he is like any other creditor.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah that the Prophet (ﷺ) said:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2094", "arabic": "حَدَّثَنَا إِبْرَاهِيمُ بْنُ الْمُنْذِرِ الْحِزَامِيُّ، وَعَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ الدِّمَشْقِيُّ، قَالاَ حَدَّثَنَا ابْنُ أَبِي فُدَيْكٍ، عَنِ ابْنِ أَبِي ذِئْبٍ، عَنْ أَبِي الْمُعْتَمِرِ بْنِ عَمْرِو بْنِ رَافِعٍ، عَنِ ابْنِ خَلْدَةَ الزُّرَقِيِّ، وَكَانَ، قَاضِيًا بِالْمَدِينَةِ قَالَ جِئْنَا أَبَا هُرَيْرَةَ فِي صَاحِبٍ لَنَا قَدْ أَفْلَسَ فَقَالَ هَذَا الَّذِي قَضَى فِيهِ النَّبِيُّ صلى الله عليه وسلم ‏ ‏ أَيُّمَا رَجُلٍ مَاتَ أَوْ أَفْلَسَ فَصَاحِبُ الْمَتَاعِ أَحَقُّ بِمَتَاعِهِ إِذَا وَجَدَهُ بِعَيْنِهِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "We came to Abu Hurairah and asked him about a companion of ours who had become bankrupt. He said: “This is what the Prophet (ﷺ) ruled: 'Any man who dies or becomes bankrupt, the owner of the product has more right to it, if he finds the exact thing.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Ibn Khaldah, who was a judge in Al-Madinah, said:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2095", "arabic": "حَدَّثَنَا عَمْرُو بْنُ عُثْمَانَ بْنِ سَعِيدِ بْنِ كَثِيرِ بْنِ دِينَارٍ الْحِمْصِيُّ، حَدَّثَنَا الْيَمَانُ بْنُ عَدِيٍّ، حَدَّثَنِي الزَّبِيدِيُّ، مُحَمَّدُ بْنُ عَبْدِ الرَّحْمَنِ عَنِ الزُّهْرِيِّ، عَنْ أَبِي سَلَمَةَ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ أَيُّمَا امْرِئٍ مَاتَ وَعِنْدَهُ مَالُ امْرِئٍ بِعَيْنِهِ اقْتَضَى مِنْهُ شَيْئًا أَوْ لَمْ يَقْتَضِ فَهُوَ أُسْوَةُ الْغُرَمَاءِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“Any man who dies and has the property of another man, whether he paid something towards it or not, (the owner of those goods) is like any other creditor.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2096", "arabic": "حَدَّثَنَا عُثْمَانُ بْنُ أَبِي شَيْبَةَ، وَعَمْرُو بْنُ رَافِعٍ، قَالاَ حَدَّثَنَا جَرِيرٌ، عَنْ مَنْصُورٍ، عَنْ إِبْرَاهِيمَ، عَنْ عَبِيدَةَ السَّلْمَانِيِّ، قَالَ قَالَ عَبْدُ اللَّهِ بْنُ مَسْعُودٍ سُئِلَ رَسُولُ اللَّهِ صلى الله عليه وسلم أَىُّ النَّاسِ خَيْرٌ قَالَ ‏ ‏ قَرْنِي ثُمَّ الَّذِينَ يَلُونَهُمْ ثُمَّ الَّذِينَ يَلُونَهُمْ ثُمَّ يَجِيءُ قَوْمٌ تَبْدُرُ شَهَادَةُ أَحَدِهِمْ يَمِينَهُ وَيَمِينُهُ شَهَادَتَهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“The Messenger of Allah (ﷺ) was asked, 'Which of the people are best?' He said: 'My generation, then those that follow them, then those that follow them. Then there will come people whose testimony precedes their oath and whose oath precedes their testimony.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "'Abdullah bin Mas'ud said:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2097", "arabic": "حَدَّثَنَا عَبْدُ اللَّهِ بْنُ الْجَرَّاحِ، حَدَّثَنَا جَرِيرٌ، عَنْ عَبْدِ الْمَلِكِ بْنِ عُمَيْرٍ، عَنْ جَابِرِ بْنِ سَمُرَةَ، قَالَ خَطَبَنَا عُمَرُ بْنُ الْخَطَّابِ بِالْجَابِيَةِ فَقَالَ إِنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَامَ فِينَا مِثْلَ مُقَامِي فِيكُمْ فَقَالَ ‏ ‏ احْفَظُونِي فِي أَصْحَابِي ثُمَّ الَّذِينَ يَلُونَهُمْ ثُمَّ الَّذِينَ يَلُونَهُمْ ثُمَّ يَفْشُو الْكَذِبُ حَتَّى يَشْهَدَ الرَّجُلُ وَمَا يُسْتَشْهَدُ وَيَحْلِفَ وَمَا يُسْتَحْلَفُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "'Umar bin Khattab addressed us at Jabiyah and said: “The Messenger of Allah (ﷺ)  stood up among us as I stand among you, and said: 'Honor my Companions for my sake, then those who come after them, then those who come after them. Then lying will prevail until a man will give testimony without being asked to do so, and he will swear an oath without being asked to do so.' ”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Jabir bin Samurah said:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2098", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، وَمُحَمَّدُ بْنُ عَبْدِ الرَّحْمَنِ الْجُعْفِيُّ، قَالاَ حَدَّثَنَا زَيْدُ بْنُ الْحُبَابِ الْعُكْلِيُّ، أَخْبَرَنِي أُبَىُّ بْنُ عَبَّاسِ بْنِ سَهْلِ بْنِ سَعْدٍ السَّاعِدِيِّ، حَدَّثَنِي أَبُو بَكْرِ بْنُ عَمْرِو بْنِ حَزْمٍ، حَدَّثَنِي مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ عَمْرِو بْنِ عُثْمَانَ بْنِ عَفَّانَ، حَدَّثَنِي خَارِجَةُ بْنُ زَيْدِ بْنِ ثَابِتٍ، أَخْبَرَنِي عَبْدُ الرَّحْمَنِ بْنُ أَبِي عَمْرَةَ الأَنْصَارِيُّ، أَنَّهُ سَمِعَ زَيْدَ بْنَ خَالِدٍ الْجُهَنِيَّ، يَقُولُ إِنَّهُ سَمِعَ رَسُولَ اللَّهِ صلى الله عليه وسلم يَقُولُ ‏ ‏ خَيْرُ الشُّهُودِ مَنْ أَدَّى شَهَادَتَهُ قَبْلَ أَنْ يُسْأَلَهَا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“The best of witnesses is the one who gives his testimony before he is asked for it.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Zaid bin Khalid Al-Juhani said that he heard the Messenger of Allah (ﷺ) say:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2099", "arabic": "حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ يُوسُفَ الْجُبَيْرِيُّ، وَجَمِيلُ بْنُ الْحَسَنِ الْعَتَكِيُّ، قَالاَ حَدَّثَنَا مُحَمَّدُ بْنُ مَرْوَانَ الْعِجْلِيُّ، حَدَّثَنَا عَبْدُ الْمَلِكِ بْنُ أَبِي نَضْرَةَ، عَنْ أَبِيهِ، عَنْ أَبِي سَعِيدٍ الْخُدْرِيِّ، قَالَ تَلاَ هَذِهِ الآيَةَ ‏{‏يَا أَيُّهَا الَّذِينَ آمَنُوا إِذَا تَدَايَنْتُمْ بِدَيْنٍ إِلَى أَجَلٍ مُسَمًّى ‏}‏ حَتَّى بَلَغَ ‏{‏فَإِنْ أَمِنَ بَعْضُكُمْ بَعْضًا‏}‏ فَقَالَ هَذِهِ نَسَخَتْ مَا قَبْلَهَا ‏.‏", "bengali": "", "english": "Abu Sa'eed Al-Khudri recited this Verse: “O you who believe! When you contract a debt for a fixed period...” until: “then if one of you entrusts the other.” Then he said: “This abrogates what came before.”", "french": "", "indonesian": "", "russian": "", "urdu": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے ایک آدمی کو کہتے ہوئے سنا کہ ا", "grades": "", "reference": "", "international_number": "2099", "narrator_chain": "It was narrated that :", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2100", "arabic": "حَدَّثَنَا أَيُّوبُ بْنُ مُحَمَّدٍ الرَّقِّيُّ، حَدَّثَنَا مَعْمَرُ بْنُ سُلَيْمَانَ، ح وَحَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، قَالاَ حَدَّثَنَا حَجَّاجُ بْنُ أَرْطَاةَ، عَنْ عَمْرِو بْنِ شُعَيْبٍ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ لاَ تَجُوزُ شَهَادَةُ خَائِنٍ وَلاَ خَائِنَةٍ وَلاَ مَحْدُودٍ فِي الإِسْلاَمِ وَلاَ ذِي غِمْرٍ عَلَى أَخِيهِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“The Testimony of a man or woman who is treacherous, or of one who has been subjected to one of the Haad punishments of Islam, or of one who bears a grudge against his brother, is not permissible.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from 'Amr bin Shuaib  from his father that his grandfather said:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2101", "arabic": "حَدَّثَنَا حَرْمَلَةُ بْنُ يَحْيَى، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، أَخْبَرَنِي نَافِعُ بْنُ يَزِيدَ، عَنِ ابْنِ الْهَادِ، عَنْ مُحَمَّدِ بْنِ عَمْرِو بْنِ عَطَاءٍ، عَنْ عَطَاءِ بْنِ يَسَارٍ، عَنْ أَبِي هُرَيْرَةَ، أَنَّهُ سَمِعَ رَسُولَ اللَّهِ صلى الله عليه وسلم يَقُولُ ‏ ‏ لاَ تَجُوزُ شَهَادَةُ بَدَوِيٍّ عَلَى صَاحِبِ قَرْيَةٍ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“The testimony of a Bedouin against a town-dweller is not permissible.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) say:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2102", "arabic": "حَدَّثَنَا أَبُو مُصْعَبٍ الْمَدِينِيُّ، أَحْمَدُ بْنُ عَبْدِ اللَّهِ الزُّهْرِيُّ وَيَعْقُوبُ بْنُ إِبْرَاهِيمَ الدَّوْرَقِيُّ قَالاَ حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ الدَّرَاوَرْدِيُّ، عَنْ رَبِيعَةَ بْنِ أَبِي عَبْدِ الرَّحْمَنِ، عَنْ سُهَيْلِ بْنِ أَبِي صَالِحٍ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَضَى بِالْيَمِينِ مَعَ الشَّاهِدِ ‏.‏", "bengali": "", "english": "the Messenger of Allah (ﷺ) passed judgment on the basis of an oath (from the claimant) along with a (single) witness. ", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  عیسیٰ بن مریم علیہ السلام", "grades": "", "reference": "", "international_number": "2102", "narrator_chain": "It was narrated from Abu Hurairah that:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2103", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا عَبْدُ الْوَهَّابِ، حَدَّثَنَا جَعْفَرُ بْنُ مُحَمَّدٍ، عَنْ أَبِيهِ، عَنْ جَابِرٍ، أَنَّ النَّبِيَّ صلى الله عليه وسلم قَضَى بِالْيَمِينِ مَعَ الشَّاهِدِ ‏.‏", "bengali": "", "english": "the Prophet (ﷺ) passed judgement on the basis of an oath (from the claimant) along with a (single) witness.", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  قسم یا تو حنث  (", "grades": "", "reference": "", "international_number": "2103", "narrator_chain": "It was narrated from Jabir that:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2104", "arabic": "حَدَّثَنَا أَبُو إِسْحَاقَ الْهَرَوِيُّ، إِبْرَاهِيمُ بْنُ عَبْدِ اللَّهِ بْنِ حَاتِمٍ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ الْحَارِثِ الْمَخْزُومِيُّ، حَدَّثَنَا سَيْفُ بْنُ سُلَيْمَانَ الْمَكِّيُّ، أَخْبَرَنِي قَيْسُ بْنُ سَعْدٍ، عَنْ عَمْرِو بْنِ دِينَارٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ قَضَى رَسُولُ اللَّهِ صلى الله عليه وسلم بِالشَّاهِدِ وَالْيَمِينِ ‏.‏", "bengali": "", "english": "“The Messenger of Allah (ﷺ) passed judgement on the basis of a witness along with an oath by the claimant.", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے قسم کھائی، اور «إن", "grades": "", "reference": "", "international_number": "2104", "narrator_chain": "It was narrated that Ibn 'Abbas said:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2105", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، أَنْبَأَنَا جُوَيْرِيَةُ بْنُ أَسْمَاءَ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ يَزِيدَ، - مَوْلَى الْمُنْبَعِثِ - عَنْ رَجُلٍ، مِنْ أَهْلِ مِصْرَ عَنْ سُرَّقٍ، أَنَّ النَّبِيَّ صلى الله عليه وسلم أَجَازَ شَهَادَةَ الرَّجُلِ وَيَمِينَ الطَّالِبِ ‏.‏", "bengali": "", "english": "the Prophet (ﷺ) allowed the testimony of a man along with the oath of the claimant.", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے قسم کھائی،", "grades": "", "reference": "", "international_number": "2105", "narrator_chain": "It was narrated from Surraq that :", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2106", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا مُحَمَّدُ بْنُ عُبَيْدٍ، حَدَّثَنَا سُفْيَانُ الْعُصْفُرِيُّ، عَنْ أَبِيهِ، عَنْ حَبِيبِ بْنِ النُّعْمَانِ الأَسَدِيِّ، عَنْ خُرَيْمِ بْنِ فَاتِكٍ الأَسَدِيِّ، قَالَ صَلَّى النَّبِيُّ صلى الله عليه وسلم الصُّبْحَ فَلَمَّا انْصَرَفَ قَامَ قَائِمًا فَقَالَ ‏\"‏ عُدِلَتْ شَهَادَةُ الزُّورِ بِالإِشْرَاكِ بِاللَّهِ ‏\"‏ ‏.‏ ثَلاَثَ مَرَّاتٍ ثُمَّ تَلاَ هَذِهِ الآيَةَ ‏{‏وَاجْتَنِبُوا قَوْلَ الزُّورِ حُنَفَاءَ لِلَّهِ غَيْرَ مُشْرِكِينَ بِه‏}‏‏.‏", "bengali": "", "english": "the Prophet(ﷺ) prayed the Morning prayer, and when he had finished, he stood up and said: “Bearing false witness is equivalent to associating others with Allah,” three times. Then he recited this Verse: “And shun lying speech (false statements), Hunafa' Lillah (i.e., worshiping none but Allah), not associating partners (in worship) to Him.”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  جس نے قسم کھائی اور «إن شاء الله» کہا، وہ حانث یعنی قسم ت", "grades": "", "reference": "", "international_number": "2106", "narrator_chain": "It was narrated that Khuraim bin Fatik Al-Asadi said that :", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2107", "arabic": "حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، حَدَّثَنَا مُحَمَّدُ بْنُ الْفُرَاتِ، عَنْ مُحَارِبِ بْنِ دِثَارٍ، عَنِ ابْنِ عُمَرَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏{‏لَنْ تَزُولَ قَدَمُ شَاهِدِ الزُّورِ حَتَّى يُوجِبَ اللَّهُ لَهُ النَّارَ‏}‏‏.‏", "bengali": "", "english": "'The one who bears false witness will not move away (on the Day of Resurrection) until Allah condemns him to Hell.' ”", "french": "", "indonesian": "", "russian": "", "urdu": "ابوموسیٰ اشعری رضی اللہ عنہ کہتے ہیں کہ  میں رسول اللہ صلی اللہ علیہ وسلم کے پاس اشعری قبیلہ کے چند", "grades": "", "reference": "", "international_number": "2107", "narrator_chain": "It was narrated from Ibn 'Umar that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2108", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ طَرِيفٍ، حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ، عَنْ مُجَالِدٍ، عَنْ عَامِرٍ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم أَجَازَ شَهَادَةَ أَهْلِ الْكِتَابِ بَعْضِهِمْ عَلَى بَعْضٍ ‏.‏ ‏\"", "bengali": "", "english": "the Messenger of Allah (ﷺ) allowed the People of the Book to testify against one another.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Jabir bin 'Abdullah that :", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2308", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا مُعَلَّى بْنُ مَنْصُورٍ، ‏‏‏‏‏‏عَنْ عَ", "bengali": "", "english": "It was narrated from Abu Hurairah that the Prophet (ﷺ) said:“Whoever is appointed judge between the people, he has been slaughtered without a knife.”", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جو شخص لوگوں کا قاضی  ( ف", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 13, Hadith 1", "international_number": "2308", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2309", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏ وَمُحَمَّدُ بْنُ إِسْمَاعِيل، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَا", "bengali": "", "english": "It was narrated from Anas bin Malik that the Messenger of Allah (ﷺ) said:“Whoever asks to be appointed a judge, will be entrusted to himself, but “Whoever asks to be appointed a judge, will be entrusted to himself, but whoever is forced to accept position, an angel will come down to him and guide him.' ”", "french": "", "indonesian": "", "russian": "", "urdu": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے عہدہ قضاء کا مط", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 13, Hadith 2", "international_number": "2309", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2310", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا يَعْلَى، ‏‏‏‏‏‏ وَأَبُو مُعَاوِيَةَ، ‏‏‏‏‏‏عَنِ", "bengali": "", "english": "It was narrated that 'Ali said:“The Messenger of Allah (ﷺ) sent me to Yemen. I said: 'O Messenger of Allah, you are sending me to judge between them while I am a young man, and I do not know how to judge.' He struck me on the chest with his hand and said: 'O Allah, guide his heart and make his tongue steadfast.' And after that I never doubted in passing judgment between two people.”", "french": "", "indonesian": "", "russian": "", "urdu": "علی رضی اللہ عنہ کہتے ہیں کہ  مجھے رسول اللہ صلی اللہ علیہ وسلم نے یمن بھیجا، میں نے عرض کیا: اللہ ک", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 13, Hadith 3", "international_number": "2310", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2311", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ خَلَّادٍ الْبَاهِلِيُّ، ‏‏‏‏‏‏حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ الْقَطَّا", "bengali": "", "english": "It was narrated that 'Abdullah said:“The Messenger of Allah (ﷺ) said: “There is no judge who judges between the people but on the Day of Resurrection an angel will come and take hold of the back of his head towards the sky and if it said: “Throw him, “he will throw into an abyss the depth of forty autumns (years).' ”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو حاکم بھی لوگو", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 13, Hadith 4", "international_number": "2311", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2312", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ سِنَانَ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ بِلَالٍ، ‏‏‏‏‏‏عَنْ عِمْرَانَ الْق", "bengali": "", "english": "It was narrated from 'Abdullah bin Abu Awfa that the Messenger of Allah (ﷺ) said:“Allah is with the judge so long as he is not unjust, but if he rules unjustly, He entrusts him to himself.”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن ابی اوفی رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ کی مدد", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 13, Hadith 5", "international_number": "2312", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2313", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏حَدَّثَنَا ابْنُ أَبِي ذِئْبٍ، ‏‏", "bengali": "", "english": "It was narrated from 'Abdullah bin 'Amr that the Messenger of Allah (ﷺ) said:“The curse of Allah is upon the one who offers a bribe and the one who takes it.”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  رشوت دینے والے", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 13, Hadith 6", "international_number": "2313", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2314", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ الدَّرَاوَرْدِيّ", "bengali": "", "english": "It was narrated from 'Amr bin 'As that he heard the Messenger of Allah (ﷺ) say:“When the judge passes a judgement and does his best and gets it right, he will have two rewards, and if he passes a judgement and does his best and gets it wrong, he will have one reward.” (Sahih) Yazid (one of narrators) said : “So I Narrated it to Abu Bakr bin 'Amr bin Hazm. He said: 'This is how it was narrated to me by Abu Salamah from Abu Hurairah.'”", "french": "", "indonesian": "", "russian": "", "urdu": "عمرو بن العاص رضی اللہ عنہ کہتے ہیں کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  جب حاک", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 13, Hadith 7", "international_number": "2314", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2315", "arabic": "حَدَّثَنَا إِسْمَاعِيل بْنُ تَوْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا خَلَفُ بْنُ خَلِيفَةَ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو", "bengali": "", "english": "Abu Hashim said:“Were it not for the Hadith of Ibn Buraidah from his father, from the Prophet (ﷺ) who said: 'Judges are of three types, two of whom will be in Hell and one will be in Paradise. The man who knows the truth and rules in accordance with it, will be in Paradise. The man who passes judgment on the people in ignorance will be in Hell' - we would have said that if the judge does his best he will be in Paradise.”", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہاشم کہتے ہیں کہ  اگر ابن بریدہ کی یہ روایت نہ ہوتی جو انہوں نے اپنے والد  ( بریدہ رضی اللہ عنہ )", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 13, Hadith 8", "international_number": "2315", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2316", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏ وَمُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ يَزِيدَ، ‏‏‏‏‏‏ وَأَحْ", "bengali": "", "english": "It was narrated from 'Abdul-Malik bin 'Umair that he heard 'Abdur-Rahman bin Abu Bakrah (narrate) from his father that the Messenger of Allah (ﷺ) said:“Let the judge (Qadi) not pass a judgment when he is angry.”", "french": "", "indonesian": "", "russian": "", "urdu": "ابوبکرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  قاضی غصے کی حالت میں دو ا", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 13, Hadith 9", "international_number": "2316", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2317", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏حَدَّثَنَا هِشَامُ بْنُ", "bengali": "", "english": "It was narrated from Umm Salamah that the Messenger of Allah (ﷺ) said:“You refer your disputes to me and I am only human. Perhaps some of you may be more eloquent in presenting your case than others, so I rule in your favor because of what I hear from you. If I pass a judgement in favor of one of you that detracts from his brother's rights, then he should not take it, because it is a piece of fire that is given to him which he will bring forth on the Day Resurrection.”", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین ام سلمہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم لوگ میرے", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 13, Hadith 10", "international_number": "2317", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2318", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ، ‏‏‏‏‏‏حَدَّثَنَ", "bengali": "", "english": "It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said:“I am only human, and some of you may be more eloquent in presenting your case than others. If I pass a judgement in his favor that detracts from his brother's rights, I am giving him a piece of fire.”", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  میں تو ایک انسان ہی ہوں،", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 13, Hadith 11", "international_number": "2318", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2319", "arabic": "حَدَّثَنَا عَبْدُ الْوَارِثِ بْنُ عَبْدِ الصَّمَدِ بْنِ عَبْدِ الْوَارِثِ بْنِ سَعِيدٍ أَبُو عُبَيْد", "bengali": "", "english": "It was narrated from Abu Dharr that he heard the Messenger of Allah (ﷺ) say:“Whoever claims something that does not belong to him; he is not one of us, so let him take his place in Hell.”", "french": "", "indonesian": "", "russian": "", "urdu": "ابوذر رضی اللہ عنہ کہتے ہیں کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  جو کسی ایسی چی", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 13, Hadith 12", "international_number": "2319", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2320", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ ثَعْلَبَةَ بْنِ سَوَاءٍ، ‏‏‏‏‏‏حَدَّثَنِي عَمِّي مُحَمَّدُ بْنُ سَوَاءٍ، ‏", "bengali": "", "english": "It was narrated from Ibn 'Umar that the Messenger of Allah (ﷺ) said:“Whoever takes the wrongdoer's side in a dispute or supports wrongdoing, he will remain subject to the wrath of Allah until he gives it up.”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو کسی جھگڑے میں", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 13, Hadith 13", "international_number": "2320", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2321", "arabic": "حَدَّثَنَا حَرْمَلَةُ بْنُ يَحْيَى الْمِصْرِيُّ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، ‏‏‏‏‏‏", "bengali": "", "english": "It was narrated from Ibn 'Abbas that the Messenger of Allah (ﷺ) said:“If the people were given what they claimed, some would have claimed the lives and property of men. But the one the claim is made against is obliged to swear an oath.”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اگر لوگوں کو ان", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 13, Hadith 14", "international_number": "2321", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2322", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، ‏‏‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏قَالَ", "bengali": "", "english": "It was narrated that Ash'ath bin Qais Said:“There was a dispute between myself and a Jewish man concerning some land, and he denied me my rights so I brought him to the Prophet (ﷺ). The Messenger of Allah (ﷺ) said to me: 'Do you have proof' I said: 'No.’ He said to the Jews, 'Swear an oath.' I said: 'If he swears an oath he will take my property.' Then Allah, Glorious is He, revealed: 'Verily, those who purchase a small gain at the cost of Allah's covenant and their oaths, they shall have no portion in the Hereafter (Paradise). Neither will Allah neither speak to them nor look at them on the Day of Resurrection nor will He purifies them, and they shall have a painful torment.'”", "french": "", "indonesian": "", "russian": "", "urdu": "اشعث بن قیس رضی اللہ عنہ کہتے ہیں کہ  میرے اور ایک یہودی کے درمیان ایک زمین مشترک تھی، اس نے میرے حص", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 13, Hadith 15", "international_number": "2322", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2323", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏ وَأَبُو مُع", "bengali": "", "english": "It was narrated from 'Abdullah bin Mas'ud that the Messenger of Allah (ﷺ) said:“Whoever swears a false oath in order to seize the wealth of a Muslim unlawfully, he will meet Allah when He is angry with him.”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص کسی چیز ک", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 13, Hadith 16", "international_number": "2323", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2324", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو أُسَامَةَ، ‏‏‏‏‏‏عَنِ الْوَلِيدِ", "bengali": "", "english": "Abu Umamah Al-Harithi narrated that he heard the Messenger of Allah (ﷺ) say:“No man seizes the wealth of a Muslim unlawfully by means of his (false) oath, but Allah will deny Paradise to him and will doom him to Hell.” A man among the people said: “O Messenger of Allah, even if it is something small?” He said: “Even if it is a twig of an Arak tree.”", "french": "", "indonesian": "", "russian": "", "urdu": "ابوامامہ حارثی رضی اللہ عنہ بیان کرتے ہیں کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 13, Hadith 17", "international_number": "2324", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2325", "arabic": "حَدَّثَنَا عَمْرُو بْنُ رَافِعٍ، ‏‏‏‏‏‏حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِيَةَ، ‏‏‏‏‏‏ح وَحَدَّثَنَا أ", "bengali": "", "english": "It was narrated from Jabir bin 'Abdullah that the Messenger of Allah (ﷺ) said:'Whoever swears a false oath near this pulpit of mine, let him take his place in Hell, even if it is for a green twig.”", "french": "", "indonesian": "", "russian": "", "urdu": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص میرے اس", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 13, Hadith 18", "international_number": "2325", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2326", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏ وَزَيْدُ بْنُ أَخْزَمَ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَا الضَّ", "bengali": "", "english": "Muhammad bin Yahya, who is Abu Yunus Al-Qawi, said:I heard Abu Salamah say: I heard Abu Hurairah say: “The Messenger of Allah (ﷺ) said: 'No man or woman swears a false oath beside this pulpit, even if it is for a fresh twig, but he will be doomed to Hell.”", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اس منبر کے پاس کوئی غلام", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 13, Hadith 19", "international_number": "2326", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2327", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو مُعَاوِيَةَ، ‏‏‏‏‏‏عَنِ الْأَعْمَشِ، ‏‏‏‏‏", "bengali": "", "english": "It was narrated from Bara' bin 'Azib that the Messenger of Allah (ﷺ) called one of the Jewish scholars and said:“ Swear by the One Who sent the Torah (Tawrah) down to Musa.”", "french": "", "indonesian": "", "russian": "", "urdu": "براء بن عازب رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک یہودی عالم کو بلایا،", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 13, Hadith 20", "international_number": "2327", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2328", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو أُسَامَةَ، ‏‏‏‏‏‏عَنْ مُجَالِدٍ، ‏‏‏‏‏‏أَن", "bengali": "", "english": "It was narrated from Jabir bin 'Abdullah that the Messenger of Allah (ﷺ) said to two Jews:“Swear by Allah Who sent the Tawrah down to Musa, peace be upon him.”", "french": "", "indonesian": "", "russian": "", "urdu": "جابر بن عبداللہ رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے دو یہودیوں سے فرمایا:", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 13, Hadith 21", "international_number": "2328", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2329", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ حَدَّثَنَا خَالِدُ بْنُ الْحَارِثِ، ‏‏‏‏‏‏حَدَّث", "bengali": "", "english": "It was narrated from Abu Hurairah that:he said that two men laid claim to an animal, and neither of them had any proof, so the Prophet (ﷺ) commanded them to cast lots as to which of them should swear an oath", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  انہوں نے ذکر کیا کہ ایک جانور پر دو آدمیوں نے دعویٰ کیا، اور", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 13, Hadith 22", "international_number": "2329", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2330", "arabic": "حَدَّثَنَا إِسْحَاق بْنُ مَنْصُورٍ، ‏‏‏‏‏‏ وَمُحَمَّدُ بْنُ مَعْمَرٍ، ‏‏‏‏‏‏ وَزُهَيْرُ بْنُ مُحَمَّ", "bengali": "", "english": "It was narrated from Abu Musa that :two men referred a dispute to the Messenger of Allah (ﷺ) concerning an animal, and neither of them had proof, so he ruled that it should be divided in half", "french": "", "indonesian": "", "russian": "", "urdu": "ابوموسیٰ اشعری رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم کے پاس دو آدمی جھگڑا لے کر", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 13, Hadith 23", "international_number": "2330", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2331", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو مُعَاوِيَةَ، ‏‏‏‏‏‏حَدَّثَنَا حَجَّاجٌ، ‏‏", "bengali": "", "english": "It was narrated from Samurah bin Jundub that the Messenger of Allah (ﷺ) said:“If a man loses something, or it is stolen from him, and he finds it in the possession of a man who bought it, then he has more right to it, and the one who bought it should ask for his money back from the one who sold it to him.' ”", "french": "", "indonesian": "", "russian": "", "urdu": "سمرہ بن جندب رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب آدمی کا کوئی سام", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 13, Hadith 24", "international_number": "2331", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2332", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ الْمِصْرِيُّ، ‏‏‏‏‏‏أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، ‏‏‏‏‏‏عَنِ ا", "bengali": "", "english": "It was narrated from Ibn Shihab that :Ibn Muhayyisah Al-Ansari told him that a she-camel belonging to Bara used to wander free. It entered a garden belonging to some people and caused some damage. The Messenger of Allah (ﷺ) was told of that, and he ruled that property was to be protected by its owners of livestock were responsible for any damage caused by their animals during the night", "french": "", "indonesian": "", "russian": "", "urdu": "ابن محیصہ انصاری رضی اللہ عنہ کہتے ہیں کہ  براء رضی اللہ عنہ کی ایک اونٹنی کو لوگوں کا کھیت چرنے کی", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 13, Hadith 25", "international_number": "2332", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2333", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا شَرِيكُ بْنُ عَبْدِ اللَّهِ، ‏‏‏‏‏‏عَن", "bengali": "", "english": "It was narrated that a man from Banu Suwa'ah said:'I said to 'Aishah: Tell me about the character of the Messenger of Allah (ﷺ).' She said: 'Have you not read the Qur'an: “And verily, you (O Mohammed {SAW}) are on an exalted (standard of) character?” She said: 'The Messenger of Allah (ﷺ) was with his Companions, and I made some food for him, and Hafsah made some food for him, but Hafash got there before me. So I said to the slave girl: “Overturn her bowl.” She went and caught up with her, and she was about to put (the bowl) in front of the Messenger of Allah (ﷺ). She overturned it and the bowl broke, scattering the food. The Messenger of Allah (ﷺ) gathered the pieces and the food on the leather mat and they ate. Then he sent for my bowl and gave it to Hafsah, and said: “Take this pot in place of your pot, and eat what is in it.” And I did not see any expression of anger on the face of the Messenger of Allah (ﷺ).' ”", "french": "", "indonesian": "", "russian": "", "urdu": "قبیلہ بنی سوءۃ کے ایک شخص کا بیان ہے کہ  میں نے ام المؤمنین عائشہ رضی اللہ عنہا سے کہا: مجھ سے رسول", "grades": "{'name': 'Al-Albani', 'grade': 'Daif Isnaad'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif Isnaad'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 13, Hadith 26", "international_number": "2333", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2334", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، ‏‏‏‏‏‏حَدَّثَنَا خَالِدُ بْنُ الْحَارِثِ، ‏‏‏‏‏‏حَدَّثَنَا حُ", "bengali": "", "english": "It was narrated that Anas bin Malik said:“The Prophet (ﷺ) was with one of the Mothers of the Believers (his wives) and another (wife) sent a bowl containing food. She (the first wife) struck the hand of the Messenger of (ﷺ) and the bowl fell and broke. The Messenger of Allah (ﷺ) took the two pieces and put them back together, then he started gathering up the food and putting it in (the bowl). He said: 'Your mother was jealous. Eat.' So they ate, and she (the wife who broke the bowl) brought the bowl that was in her house and gave the intact bowl to the Messenger (ﷺ), who left the broken bowl in the house of the one who broke it.”", "french": "", "indonesian": "", "russian": "", "urdu": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم امہات المؤمنین رضی اللہ عنہن میں س", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 13, Hadith 27", "international_number": "2334", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2335", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏ وَمُحَمَّدُ بْنُ الصَّبَّاحِ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَا", "bengali": "", "english": "It was narrated that Anas bin Malik said:“The Prophet (ﷺ): 'When anyone of you asks his neighbor for permission to fix a piece of wood to his wall, he should not refuse him. 'When Abu Hurairah told them this, they lowered their heads, and when he saw them he said: 'Why do I see you turning away from it? By Allah, I will force you to accept it.' ”", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں سے کسی سے اس کا", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 13, Hadith 28", "international_number": "2335", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2336", "arabic": "حَدَّثَنَا أَبُو بِشْرٍ بَكْرُ بْنُ خَلَفٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو عَاصِمٍ، ‏‏‏‏‏‏عَنِ ابْنِ جُرَيْج", "bengali": "", "english": "Ikrimah bin Salamh narrated that :there were two brothers from among the sons of Mughirah. One of them swore an oath to set a slave free if the other one fixed a piece of wood to his wall. Mujammi' bin Yazid and many men from among the Ansar came and said: “We bear witness that the Messenger of Allah (ﷺ) said: 'None of you should refuse to let his neighbor fix a piece of wood to his wall.' ” He said: 'O my brother, judgment has been passed in your favor against me, but I have sworn an oath.' So go ahead and fix your wood to my wall.”", "french": "", "indonesian": "", "russian": "", "urdu": "عکرمہ بن سلمہ کہتے ہیں  بلمغیرہ  ( بنی مغیرہ )  کے دو بھائیوں میں سے ایک نے یہ شرط لگائی کہ اگر میری", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan Lighairihi'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 13, Hadith 29", "international_number": "2336", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2337", "arabic": "حَدَّثَنَا حَرْمَلَةُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، ‏‏‏‏‏‏أَخْبَرَنِي ا", "bengali": "", "english": "It was narrated from Ibn 'Abbas that the Prophet (ﷺ) said:“No one of you should refuse to let his neighbor fix a piece of wood to his wall.”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  تم میں سے کوئی ا", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 13, Hadith 30", "international_number": "2337", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2338", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏حَدَّثَنَا مُثَنَّى بْن", "bengali": "", "english": "It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said:“Make the path seven forearms length wide.”", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  راستہ کو سات ہاتھ رکھو", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 13, Hadith 31", "international_number": "2338", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2339", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏ وَمُحَمَّدُ بْنُ عُمَرَ بْنِ هَيَّاجٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ ح", "bengali": "", "english": "It was narrated from Ibn 'Abbas that the Messenger of Allah (ﷺ) said:“When you dispute concerning a path, make it seven forearms length wide.' ”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم راستے کے", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 13, Hadith 32", "international_number": "2339", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2340", "arabic": "حَدَّثَنَا عَبْدُ رَبِّهِ بْنُ خَالِدٍ النُّمَيْرِيُّ أَبُو الْمُغَلِّسِ، ‏‏‏‏‏‏حَدَّثَنَا فُضَيْلُ", "bengali": "", "english": "It was narrated from 'Ubadah bin Samit that the Messenger of Allah (ﷺ) ruled:“There should be neither harming nor reciprocating harm.”", "french": "", "indonesian": "", "russian": "", "urdu": "عبادہ بن صامت رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے حکم دیا:  کسی کو نقصان پہنچا", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 13, Hadith 33", "international_number": "2340", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2341", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الرَّزَّاقِ، ‏‏‏‏‏‏أَنْبَأَنَا مَعْمَرٌ،", "bengali": "", "english": "It was narrated from Ibn 'Abbas that the Messenger of Allah (ﷺ) said:“There should be neither harming nor reciprocating harm.”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلیاللہ علیہ وسلم  نے فرمایا:  کسی کو نقصان پہ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih Lighairihi'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 13, Hadith 34", "international_number": "2341", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2342", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، ‏‏‏‏‏‏أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، ‏‏‏‏‏‏عَنْ يَحْيَى بْنِ س", "bengali": "", "english": "It was narrated from Abu Sirmah that the Messenger of Allah (ﷺ) said:“Whoever harms others, Allah (SWT) will harm him; and whoever causes hardship to other Allah will cause hardship to him.”", "french": "", "indonesian": "", "russian": "", "urdu": "ابوصرمہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو کسی کو نقصان پہنچائے گ", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 13, Hadith 35", "international_number": "2342", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2343", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، ‏‏‏‏‏‏ وَعَمَّارُ بْنُ خَالِدٍ الْوَاسِطِيُّ، ‏‏‏‏‏‏قَالَا:‏‏", "bengali": "", "english": "It was narrated from Nimran bin Jariyah, from his father, that :some people referred a dispute to the Prophet (ﷺ) about a hut, so that he could judge between them. He sent Hudhaifah to judge between them, and he ruled in favor of those who had the rope (with which the hut was blinded together). When he went back to the Prophet (ﷺ) he told him (what he had done) and he said: “You did the right thing, and you did well.”", "french": "", "indonesian": "", "russian": "", "urdu": "جاریہ رضی اللہ عنہ سے روایت ہے کہ  کچھ لوگ ایک جھونپڑی کے متعلق جو ان کے بیچ میں تھی جھگڑا لے کر نبی", "grades": "{'name': 'Al-Albani', 'grade': 'Very Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Very Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Very Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 13, Hadith 36", "international_number": "2343", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2344", "arabic": "حَدَّثَنَا يَحْيَى بْنُ حَكِيمٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو الْوَلِيدِ، ‏‏‏‏‏‏حَدَّثَنَا هَمَّامٌ، ‏‏‏‏‏", "bengali": "", "english": "It was narrated from ('Uqbah bin 'Amir or) Samurah bin Jundub that :the Messenger of Allah (ﷺ) said: “If a product is sold to two men, it is for the one who was first.”", "french": "", "indonesian": "", "russian": "", "urdu": "سمرہ بن جندب رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جب مال دو آدمیوں کے", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 13, Hadith 37", "international_number": "2344", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2345", "arabic": "حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ، ‏‏‏‏‏‏ وَمُحَمَّدُ بْنُ الْمُثَنَّى، ‏‏‏‏‏‏قَالَا:‏‏‏", "bengali": "", "english": "It was narrated from 'Imran bin Husain that :a man had six slaves, and he did not have any other wealth apart from them, and he set them free when he died. The Messenger of Allah (ﷺ) divided them into groups, set two free and left four as slaves", "french": "", "indonesian": "", "russian": "", "urdu": "عمران بن حصین رضی اللہ عنہما سے روایت ہے کہ  ایک شخص کے چھ غلام تھے، ان غلاموں کے علاوہ اس کے پاس کو", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 13, Hadith 38", "international_number": "2345", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2346", "arabic": "حَدَّثَنَا جَمِيلُ بْنُ الْحَسَنِ الْعَتَكِيُّ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْأَعْلَى، ‏‏‏‏‏‏حَدَّثَنَا", "bengali": "", "english": "It was narrated from Abu Hurairah that :two men disputed concerning a transaction, and neither of them had proof. The Messenger of Allah commanded them to draw lots as to which of them should swear an oath, whether they liked it or not", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  ایک بیع کے متعلق دو آدمیوں نے جھگڑا کیا، اور ان میں کسی کے پا", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 13, Hadith 39", "international_number": "2346", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2347", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا يَحْيَى بْنُ يَمَانٍ، ‏‏‏‏‏‏عَنْ مَعْم", "bengali": "", "english": "It was narrated from 'Aishah that :when the Prophet (ﷺ) traveled, he would cast lots among his wives (to decide which one would accompany him)", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم جب سفر پر جاتے تو اپنی", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 13, Hadith 40", "international_number": "2347", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2348", "arabic": "حَدَّثَنَا إِسْحَاق بْنُ مَنْصُورٍ، ‏‏‏‏‏‏أَنْبَأَنَا عَبْدُ الرَّزَّاقِ، ‏‏‏‏‏‏أَنْبَأَنَا الثَّوْر", "bengali": "", "english": "It was narrated that Zaid bin Arqam said:“A case was brought to 'Ali bin Abu Talib when he was in Yemen, concerning three men who had intercourse with a woman during one period of being free from menses. He asked two of them: “Do you affirm that this child belongs to (the third man)?” And they said: “No.” He asked another two of them: “Do you affirm that this child belongs to (the third man)?” And they said: “No.” Every time he asked two of them whether they affirmed that the child belonged to the third, they would say no. So he cast lots between them, and attributed the child to the one whose name was chosen in this manner, and obliged him to pay two thirds of the Diyah. The Prophet (ﷺ) was told of this, and he smiled so broadly that his back teeth became visible", "french": "", "indonesian": "", "russian": "", "urdu": "زید بن ارقم رضی اللہ عنہ کہتے ہیں کہ  علی بن ابی طالب رضی اللہ عنہ جب یمن میں تھے، تو ان کے پاس یہ م", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 13, Hadith 41", "international_number": "2348", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2349", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَهِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏ وَمُحَمَّدُ بْنُ", "bengali": "", "english": "It was narrated that 'Aishah said:“The Messenger of Allah (ﷺ) came in one day looking happy, and said: 'O 'Aishah, did you not see that Mujazziz Al-Mudliji entered upon me and saw Usamah and Zaid. There was a blanket over them and their faces were covered but their feet were exposed, and he said: 'These feet belong to one another'.”", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  ایک دن رسول اللہ صلی اللہ علیہ وسلم میرے پاس خوش خوش تش", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 13, Hadith 42", "international_number": "2349", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2350", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ، ‏‏‏‏‏‏حَدَّثَنَا إِسْرَا", "bengali": "", "english": "It was narrated from Ibn 'Abbas that :the Quraish went to a sorceress and they said to her: “Tell us whose footprints most resemble those of the owner of Al-Maqam (the station of Ibrahim).” She said: “If you spread a piece of cloth over this soft earth and walk over it, I will tell you.” So they spread out a piece of cloth and the people walked over it. She saw the footprints of the Messenger of Allah (ﷺ) and said: “This one most closely resembles him among you.” After that twenty years passed, of as long as Allah willed, then Allah sent Muhammad (ﷺ) (i.e., missioned him as the Prophet)", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  قریش کے لوگوں نے ایک کاہنہ کے پاس آ کرکہا: ہمیں بتاو", "grades": "{'name': 'Al-Albani', 'grade': 'Munkar Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Munkar Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 13, Hadith 43", "international_number": "2350", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2351", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏عَنْ زِيَادِ بْن", "bengali": "", "english": "It was narrated from Abu Hurairah that :the Prophet (ﷺ) gave a child the choice between his father and his mother (i.e., which parent to live with). He said: “O boy, this is your mother and this is your father.”", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے ایک لڑکے کو اختیار دیا کہ وہ اپ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 13, Hadith 44", "international_number": "2351", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2352", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا إِسْمَاعِيل ابْنُ عُلَيَّةَ، ‏‏‏‏‏‏عَن", "bengali": "", "english": "It was narrated from 'Abdul-Hamid bin Salamah, from his father, from his grandfather, that :his parents referred their dispute to the Prophet (ﷺ), and one of them was a disbeliever. He (the Prophet (ﷺ)) said: “O Allah, guide him,” and he turned towards the Muslim, and he ruled that he should go with that parent", "french": "", "indonesian": "", "russian": "", "urdu": "رافع بن سنان رضی اللہ عنہ کہتے ہیں کہ  ان کے ماں اور باپ دونوں نبی اکرم صلی اللہ علیہ وسلم کے پاس جھ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 13, Hadith 45", "international_number": "2352", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2353", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ، ‏‏‏‏‏‏حَدَّثَنَ", "bengali": "", "english": "Kathir bin 'Abdullah bin 'Amr bin 'Awf narrated from his father that his grandfather said:“I heard the Messenger of Allah (ﷺ) say: 'Reconciling between Muslims is permissible, except reconciliation that forbids something that is allowed, or allows something that is forbidden.'”", "french": "", "indonesian": "", "russian": "", "urdu": "عمرو بن عوف رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  مسلمانوں ک", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 13, Hadith 46", "international_number": "2353", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2354", "arabic": "حَدَّثَنَا أَزْهَرُ بْنُ مَرْوَانَ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْأَعْلَى، ‏‏‏‏‏‏حَدَّثَنَا سَعِيدٌ، ‏‏", "bengali": "", "english": "It was narrated from Anas bin Malik that :there was a man at the time of the Messenger of Allah (ﷺ) whose mental faculties were lacking, and he used to buy and sell. His family came to the Prophet (ﷺ) and said, “O Messenger of Allah, stop him.” So The Prophet (ﷺ) called him, and told him not to do that. He said: “O Messenger of Allah (ﷺ), I cannot bear to be away from business.” He said, “If you engage in a transaction then say: “Take it (i.e., the goods) and don't cheat (me).' ”", "french": "", "indonesian": "", "russian": "", "urdu": "انس بن مالک رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم کے زمانہ میں ایک شخص کچھ کم عق", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih Hadith'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 13, Hadith 47", "international_number": "2354", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2355", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْأَعْلَى، ‏‏‏‏‏‏عَنْ مُحَمَّد", "bengali": "", "english": "It was narrated that Muhammad bin Yahya bin Habban said:“My grandfather was Munqidh bin 'Amr. He was a man who had suffered a head wound and lost the power of speech, but that did not stop him from engaging in trade. He was always being cheated, so he went to the Prophet (ﷺ) and told him about that. He said to him: 'When you buy something, say: “There should be no intention of cheating,” and for every product you buy, you have the choice for three nights. If you are pleased with it, keep it, and if you are displeased then return it.'”", "french": "", "indonesian": "", "russian": "", "urdu": "محمد بن یحییٰ بن حبان کہتے ہیں کہ  میرے دادا منقذ بن عمرو ہیں، ان کے سر میں ایک زخم لگا تھا جس سے ان", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 13, Hadith 48", "international_number": "2355", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2356", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا شَبَابَةُ، ‏‏‏‏‏‏حَدَّثَنَا اللَّيْثُ", "bengali": "", "english": "It was narrated that Abu Sa'eed Al-Khudri said:“At the time of the Messenger of Allah (ﷺ), a man suffered loss of some fruit that he had purchase, and his debts increased. The Messenger of Allah (ﷺ) said: 'Give him charity.' So the people gave him charity, but that was not enough to pay off his debts. The Messenger of Allah (ﷺ) said: “Take what you find, but you have no right to more than that, meaning his creditors.”", "french": "", "indonesian": "", "russian": "", "urdu": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے عہد میں ایک شخص کو اس کے خری", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 13, Hadith 49", "international_number": "2356", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2357", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو عَاصِمٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ", "bengali": "", "english": "It was narrated from Jabir bin 'Abdullah that :the Messenger of Allah (ﷺ) rid Mu'adh bin Jabal of his creditors, then he appointed him governor of Yemen. Mu'adh said: “The Messenger of Allah (ﷺ) settled my debts with my creditors using what wealth I had, then he appointed me as governor.”", "french": "", "indonesian": "", "russian": "", "urdu": "جابر بن عبداللہ رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے معاذ بن جبل رضی اللہ", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 13, Hadith 50", "international_number": "2357", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2358", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏ح وَح", "bengali": "", "english": "It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said:“Whoever finds his exact property with a man who has become bankrupt, and then he has more right to it than anyone else.”", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے بعینہ اپنا مال اس", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 13, Hadith 51", "international_number": "2358", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2359", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا إِسْمَاعِيل بْنُ عَيَّاشٍ، ‏‏‏‏‏‏عَنْ مُوسَى بْنِ", "bengali": "", "english": "It was narrated from Abu Hurairah that the Prophet (ﷺ) said:“Any man who sells a product with the man who has become bankrupt, and he has not taken any of its price, it belongs to him, but if he had taken any of its price, then he is like any other creditor.”", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جس شخص نے کوئی سامان بیچا", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 13, Hadith 52", "international_number": "2359", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2360", "arabic": "حَدَّثَنَا إِبْرَاهِيمُ بْنُ الْمُنْذِرِ الْحِزَامِيُّ، ‏‏‏‏‏‏ وَعَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيم", "bengali": "", "english": "It was narrated that Ibn Khaldah, who was a judge in Al-Madinah, said:We came to Abu Hurairah and asked him about a companion of ours who had become bankrupt. He said: “This is what the Prophet (ﷺ) ruled: 'Any man who dies or becomes bankrupt, the owner of the product has more right to it, if he finds the exact thing.”", "french": "", "indonesian": "", "russian": "", "urdu": "ابن خلدہ زرقی (وہ مدینہ کے قاضی تھے) کہتے ہیں کہ  ہم اپنے ایک ساتھی کے سلسلے میں جس کا دیوالیہ ہو گی", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 13, Hadith 53", "international_number": "2360", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2361", "arabic": "حَدَّثَنَا عَمْرُو بْنُ عُثْمَانَ بْنِ سَعِيدِ بْنِ كَثِيرِ بْنِ دِينَارٍ الْحِمْصِيُّ، ‏‏‏‏‏‏حَدَّث", "bengali": "", "english": "It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said:“Any man who dies and has the property of another man, whether he paid something towards it or not, (the owner of those goods) is like any other creditor.”", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص مر جائے، اور اس ک", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 13, Hadith 54", "international_number": "2361", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2362", "arabic": "حَدَّثَنَا عُثْمَانُ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَعَمْرُو بْنُ رَافِعٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَ", "bengali": "", "english": "Abdullah bin Mas'ud said:“The Messenger of Allah (ﷺ) was asked, 'Which of the people are best?' He said: 'My generation, then those that follow them, then those that follow them. Then there will come people whose testimony precedes their oath and whose oath precedes their testimony.”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم سے پوچھا گیا: کون سے لوگ بہت", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 13, Hadith 55", "international_number": "2362", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2363", "arabic": "حَدَّثَنَا عَبْدُ اللَّهِ بنُ الْجَرَّاحِ، ‏‏‏‏‏‏حَدَّثَنَا جَرِيرٌ، ‏‏‏‏‏‏عَنْ عَبْدِ الْمَلِكِ بْن", "bengali": "", "english": "It was narrated that Jabir bin Samurah said:'Umar bin Khattab addressed us at Jabiyah and said: “The Messenger of Allah (ﷺ) stood up among us as I stand among you, and said: 'Honor my Companions for my sake, then those who come after them, then those who come after them. Then lying will prevail until a man will give testimony without being asked to do so, and he will swear an oath without being asked to do so.' ”", "french": "", "indonesian": "", "russian": "", "urdu": "جابر بن سمرہ رضی اللہ عنہ کہتے ہیں کہ  عمر بن خطاب رضی اللہ عنہ نے مقام جابیہ میں خطبہ دیا، اس خطبہ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 13, Hadith 56", "international_number": "2363", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2364", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏ وَمُحَمَّدُ بْنُ عَبدِ الرَّحْمَنِ الْجُعْفِيُّ، ‏‏‏‏‏‏قَا", "bengali": "", "english": "Zaid bin Khalid Al-Juhani said that he heard the Messenger of Allah (ﷺ) say:“The best of witnesses is the one who gives his testimony before he is asked for it.”", "french": "", "indonesian": "", "russian": "", "urdu": "زید بن خالد جہنی رضی اللہ عنہ کہتے ہیں کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  بہت", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 13, Hadith 57", "international_number": "2364", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2365", "arabic": "حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ يُوسُفَ الْجُبَيْرِيُّ، ‏‏‏‏‏‏ وَجَمِيلُ بْنُ الْحَسَنِ الْعَتَكِيّ", "bengali": "", "english": "It was narrated that :Abu Sa'eed Al-Khudri recited this Verse: “O you who believe! When you contract a debt for a fixed period...” until: “then if one of you entrusts the other.” Then he said: “This abrogates what came before.”", "french": "", "indonesian": "", "russian": "", "urdu": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  انہوں نے آیت کریمہ: «يا أيها الذين آمنوا إذا تداينتم بدين إ", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 13, Hadith 58", "international_number": "2365", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2366", "arabic": "حَدَّثَنَا أَيُّوبُ بْنُ مُحَمَّدٍ الرَّقِّيُّ، ‏‏‏‏‏‏حَدَّثَنَا مُعَمَّرُ بْنُ سُلَيْمَانَ، ‏‏‏‏‏‏ح", "bengali": "", "english": "It was narrated from 'Amr bin Shuaib from his father that his grandfather said:“The Testimony of a man or woman who is treacherous, or of one who has been subjected to one of the Haad punishments of Islam, or of one who bears a grudge against his brother, is not permissible.”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  نہ خائ", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 13, Hadith 59", "international_number": "2366", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2367", "arabic": "حَدَّثَنَا حَرْمَلَةُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، ‏‏‏‏‏‏أَخْبَرَنِي ن", "bengali": "", "english": "It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) say:“The testimony of a Bedouin against a town-dweller is not permissible.”", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  بدوی  ( دیہ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 13, Hadith 60", "international_number": "2367", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2368", "arabic": "حَدَّثَنَا أَبُو مُصْعَبٍ الْمَدِينِيُّ أَحْمَدُ بْنُ عَبْدِ اللَّهِ الزُّهْرِيُّ، ‏‏‏‏‏‏ وَيَعْقُوب", "bengali": "", "english": "It was narrated from Abu Hurairah that:the Messenger of Allah (ﷺ) passed judgment on the basis of an oath (from the claimant) along with a (single) witness. [This is in the absence of two witnesses]", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک گواہ اور  ( مدعی کی )  قسم", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 13, Hadith 61", "international_number": "2368", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2369", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْوَهَّابِ، ‏‏‏‏‏‏حَدَّثَنَا جَعْفَرُ ب", "bengali": "", "english": "It was narrated from Jabir that:the Prophet (ﷺ) passed judgement on the basis of an oath (from the claimant) along with a (single) witness", "french": "", "indonesian": "", "russian": "", "urdu": "جابر رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے ایک گواہ اور  ( مدعی کی )  قسم سے ف", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 13, Hadith 62", "international_number": "2369", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2370", "arabic": "حَدَّثَنَا أَبُو إِسْحَاق الْهَرَوِيُّ إِبْرَاهِيمُ بْنُ عَبْدِ اللَّهِ بْنِ حَاتِمٍ، ‏‏‏‏‏‏حَدَّثَن", "bengali": "", "english": "It was narrated that Ibn 'Abbas said:“The Messenger of Allah (ﷺ) passed judgement on the basis of a witness along with an oath by the claimant", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک گواہ اور  ( مدعی کی", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 13, Hadith 63", "international_number": "2370", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2371", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، ‏‏‏‏‏‏أَنْبَأَن", "bengali": "", "english": "It was narrated from Surraq that :the Prophet (ﷺ) allowed the testimony of a man along with the oath of the claimant", "french": "", "indonesian": "", "russian": "", "urdu": "سرق (ابن اسد جہنی) رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے مدعی کی قسم کے ساتھ ا", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 13, Hadith 64", "international_number": "2371", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2372", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ عُبَيْدٍ، ‏‏‏‏‏‏حَدَّثَ", "bengali": "", "english": "It was narrated that Khuraim bin Fatik Al-Asadi said that :the Prophet(ﷺ) prayed the Morning prayer, and when he had finished, he stood up and said: “Bearing false witness is equivalent to associating others with Allah,” three times. Then he recited this Verse: “And shun lying speech (false statements), Hunafa' Lillah (i.e., worshiping none but Allah), not associating partners (in worship) to Him.”", "french": "", "indonesian": "", "russian": "", "urdu": "خریم بن فاتک اسدی رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے نماز فجر پڑھائی، جب فارغ", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 13, Hadith 65", "international_number": "2372", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2373", "arabic": "حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ الْفُرَاتِ، ‏‏‏‏‏‏عَنْ مُحَارِبِ ب", "bengali": "", "english": "It was narrated from Ibn 'Umar that the Messenger of Allah (ﷺ) said:'The one who bears false witness will not move away (on the Day of Resurrection) until Allah condemns him to Hell.' ”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جھوٹی گواہی دینے", "grades": "{'name': 'Al-Albani', 'grade': 'Mawdu'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Mawdu'},{'name': 'Shuaib Al Arnaut', 'grade': 'Very Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 13, Hadith 66", "international_number": "2373", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
{"hadithnumber": "2374", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ طَرِيفٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو خَالِدٍ الْأَحْمَرُ، ‏‏‏‏‏‏عَنْ مُجَالِدٍ،", "bengali": "", "english": "It was narrated from Jabir bin 'Abdullah that :the Messenger of Allah (ﷺ) allowed the People of the Book to testify against one another", "french": "", "indonesian": "", "russian": "", "urdu": "جابر بن عبداللہ رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے اہل کتاب کی آپس میں", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 13, Hadith 67", "international_number": "2374", "narrator_chain": "", "chapter_intro": "The Chapters on Rulings"}
