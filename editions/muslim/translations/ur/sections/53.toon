{"hadithnumber": "7130", "text": "حضر ت انس بن مالک رضی اللہ تعالیٰ عنہ  سے روایت ہے ، کہا : رسول اللہ  صلی اللہ علیہ وسلم  نے فرمایا"}
{"hadithnumber": "7131", "text": "حضرت ابوہریرہ رضی اللہ تعالیٰ عنہ  نے نبی کریم صلی اللہ علیہ وسلم  سے اسی کی مانند روایت کی ۔"}
{"hadithnumber": "7132", "text": "سفیان نے ابو زناد سے ، انھوں نے اعرج سے ، انھوں نے حضرت  ابوہریرۃ رضی اللہ تعالیٰ عنہ  سے اور انھوں"}
{"hadithnumber": "7133", "text": "مالک نے ابو زناد سے  ، انھوں نے اعرج سے اور انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی"}
{"hadithnumber": "7134", "text": "ابو صالح نے حضرت ابو ہریرۃ  رضی اللہ تعالیٰ عنہ  سے روایت کی  ، کہا : رسول اللہ  صلی اللہ علیہ وسلم"}
{"hadithnumber": "7135", "text": "ابوحازم نے کہا : میں نے حضر ت سہل بن سعد ساعدی رضی اللہ تعالیٰ عنہ  کو بیان کرتے ہوئے سنا : میں رسول"}
{"hadithnumber": "7136", "text": "ابو سعید مقبری نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے ، انھوں نے رسول اللہ  صلی اللہ علیہ وسلم  س"}
{"hadithnumber": "7137", "text": "اعرج نے حضرت ابوہریرہ رضی اللہ تعالیٰ عنہ  سے  ، انھوں نے نبی کریم صلی اللہ علیہ وسلم  سے اسی کی مثل"}
{"hadithnumber": "7139", "text": "ابو حازم نے کہا : میں نے یہ حدیث نعمان بن ابی عیاش زرقی کو سنائی تو انھوں نے کہا : مجھے ابو سعید خدر"}
{"hadithnumber": "7140", "text": "حضرت ابو سعید خدری رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ نبی کریم صلی اللہ علیہ وسلم  نے فرمایا :  "}
{"hadithnumber": "7142", "text": "( ابوحازم نے )  کہا : میں نے یہ روایت نعمان بن ابی عیاش سے بیان کی تو انھوں نے کہا : میں نے حضرت ابو"}
{"hadithnumber": "7143", "text": "وہیب نے ابو حازم سے گزشتہ دونوں سندوں کے ساتھ یعقوب کی حدیث کے مانند بیان کیا ۔"}
{"hadithnumber": "7145", "text": "حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ رسول اللہ صلی اللہ علیہ وسلم  نے فرمایا :  \"  میر"}
{"hadithnumber": "7146", "text": "حضرت انس بن مالک رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ رسول اللہ  صلی اللہ علیہ وسلم  نے فرمایا :  "}
{"hadithnumber": "7147", "text": "اسماعیل بن علیہ نے کہا : ہمیں ایوب نے محمد  ( بن سیرین )  سے خبر دی کہ ( حصول علم کے لیے جمع ہونے وا"}
{"hadithnumber": "7148", "text": "سفیان نے ایوب سے اور انھوں نے ( محمد )  ابن سیرین سے روایت کی ، کہا : مردوں اور عورتوں میں بحث ہوگئی"}
{"hadithnumber": "7149", "text": "قتیبہ  سعید نے ہمیں حدیث بیان کی ، کہا ہمیں عبدالواحد بن زیاد نے عمارہ بن قعقاع  سے حدیث بیان کی ، ک"}
{"hadithnumber": "7150", "text": "ابو بکر بن ابی شیبہ اور ابو کریب نے ہمیں حدیث بیان کی  ، دونوں نے کہا : ہمیں ابو معاویہ نے اعمش سے ،"}
{"hadithnumber": "7151", "text": "معمر نے ہمیں ہمام بن منبہ سے حدیث بیان کی ، کہا :  یہ احادیث ہیں جو حضرت ابو ہریرہ رضی اللہ تعالیٰ ع"}
{"hadithnumber": "7152", "text": "جریر نے اعمش سے ،  انھوں نے ابو سفیان سے اور انھوں نے حضرت جابر رضی اللہ تعالیٰ عنہ  سے روایت کی ،"}
{"hadithnumber": "7153", "text": "ابو معاویہ نے اعمش سے اسی سند کے ساتھ آپ  صلی اللہ علیہ وسلم  کے فرمان  :  \" کستوری کے پسینے کی طرح"}
{"hadithnumber": "7154", "text": "حسن بن علی حلوانی اور حجاج بن شاعر دونوں نے مجھے ابو عاصم سے روایت کی ۔  حسن نے کہا :  ہمیں ابو عاصم"}
{"hadithnumber": "7155", "text": "یحییٰ نے کہا :  ہمیں ابن جریج نے حدیث بیان کی کہا :  مجھے ابو زبیر نے حضرت جابر رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "7156", "text": "ابو رافع نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے اور انھوں نے نبی  صلی اللہ علیہ وسلم  سے روایت کی"}
{"hadithnumber": "7157", "text": "ثوری نے کہا :  مجھے ابو اسحٰق نے حدیث بیان کی ،   ( ابو ہریرہ رضی اللہ تعالیٰ عنہ  کے آزاد کردہ غلام"}
{"hadithnumber": "7158", "text": "ابو قدامہ حارث بن عبید نے ابو عمران جونی سے ،  انھوں نے ابو بکر بن عبد اللہ بن قیس سے ،  انھوں نے اپ"}
{"hadithnumber": "7159", "text": "ابو عبد الصمد نے کہا :  ہمیں ابو عمران جونی نے ابو بکر بن عبد اللہ بن قیس سے اور انھوں نے اپنے والد"}
{"hadithnumber": "7160", "text": "ہمام نے ابو عمران جونی سے خبر دی انھوں نے ابو بکر بن ابوموسیٰ بن قیس سے انھوں نے اپنے والد  ( ابو مو"}
{"hadithnumber": "7161", "text": "حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ سے روایت ہے کہا : رسول اللہ  صلی اللہ علیہ وسلم نے فرمایا  :  "}
{"hadithnumber": "7162", "text": "حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  نے نبی  صلی اللہ علیہ وسلم  سے روایت کی کہ آپ نے فرمایا :  \" جنت"}
{"hadithnumber": "7163", "text": "ہمام بن منبہ سے روایت ہے انھوں نے کہا :  یہ وہ احادیث ہیں جو ہمیں حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "7164", "text": "حضرت عبداللہ ( بن مسعود رضی اللہ تعالیٰ عنہ  )  سے روایت ہے  ، کہا : رسول اللہ  صلی اللہ علیہ وسلم"}
{"hadithnumber": "7165", "text": "ابو زناد نے اعرج سے اور انھوں نے حضرت ابوہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی کہ نبی کریم صلی اللہ"}
{"hadithnumber": "7166", "text": "معمر نے ہمیں ہمام بن منبہ سے ، انھوں نے حضرت ابوہریرہ رضی اللہ تعالیٰ عنہ  سے  ، انھوں نے نبی کریم ص"}
{"hadithnumber": "7167", "text": "خلف بن خلیفہ نے کہا : ہمیں یزید بن کیسان نے ابو حازم سے حدیث بیان کی  ، انھوں نے حضرت ابو ہریرہ رضی"}
{"hadithnumber": "7168", "text": "مروان نے ہمیں یزید بن کیسان سے حدیث بیان کی ، انھوں نے ابوحازم سے اور انھوں نے حضرت ابو ہریرہ رضی ال"}
{"hadithnumber": "7169", "text": "شیبان بن عبدالرحمان نے ہمیں حدیث بیان کی ، کہا : قتادہ نے کہا : میں نے ابونضرہ کو حضرت سمرہ رضی اللہ"}
{"hadithnumber": "7170", "text": "عبدالوہاب بن عطاء نے ہمیں سعید سے خبر دی ، انھوں نے قتادہ سے روایت کی ، کہا :  میں نے ابو نضرہ کو سن"}
{"hadithnumber": "7171", "text": "روح نے کہا : ہمیں سعید نے اسی سند کے سا تھ حدیث بیان کی اور انھوں نے ( کمر پر ازار باندھنے کی جگہ کے"}
{"hadithnumber": "7172", "text": "سفیان نے ابو زناد سے  ، انھوں نے اعرج سے اور انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت ک"}
{"hadithnumber": "7173", "text": "ورقاء نے مجھے ابو زناد سے  ، انھوں نے اعرج سے  ، انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے اور"}
{"hadithnumber": "7174", "text": "ایوب نے ابن سیرین سے اور انھوں نے حضرت ابوہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی کہ نبی کریم صلی الل"}
{"hadithnumber": "7175", "text": "معمر نے ہمیں ہمام بن منبہ سے حدیث بیان کی ، کہا : یہ احادیث ہیں جو حضرت ابو ہریرہ رضی اللہ تعالیٰ عن"}
{"hadithnumber": "7176", "text": "حضرت ابو سعید خدری رضی اللہ تعالیٰ عنہ  سے روایت ہے  ، کہا کہ رسول اللہ  صلی اللہ علیہ وسلم  نے فرما"}
{"hadithnumber": "7177", "text": "شیبان  نے ہمیں قتادہ سے حدیث بیان کی  ، کہا : ہمیں حضرت انس بن مالک رضی اللہ تعالیٰ عنہ   نے حدیث بی"}
{"hadithnumber": "7178", "text": "ابان بن یزید عطار نے  ہمیں حدیث بیان کی ، کہا : ہمیں قتادہ نے حضرت انس رضی اللہ تعالیٰ عنہ  سے  ، ان"}
{"hadithnumber": "7179", "text": "عبدالوہاب بن عطا نے ہمیں اس ( اللہ )  عزوجل کے اس فرمان؛ \" جس دن ہم جہنم سے کہیں کے کیا تو بھر گئی ا"}
{"hadithnumber": "7180", "text": "ثابت نے کہا : میں نے حضرت انس رضی اللہ تعالیٰ عنہ  کو کہتے ہوئے سنا کہ نبی کریم صلی اللہ علیہ وسلم"}
{"hadithnumber": "7181", "text": "ابو بکر بن ابی شیبہ اور ابو کریب نے ہمیں حدیث بیان کی ۔ دونوں کے الفاظ ملتے جلتے ہیں ۔ دونوں نے کہا"}
{"hadithnumber": "7182", "text": "ہمیں جریر نے اعمش سے حدیث بیان کی ، انھوں نے ابو صالح سے ، اور انھوں نے ابو سعیدخدری  رضی اللہ تعالی"}
{"hadithnumber": "7183", "text": "نافع نے ہمیں حدیث بیان کی کہ حضرت عبداللہ ( ابن عمر رضی اللہ تعالیٰ عنہ  )  نے کہا کہ رسول اللہ صلی"}
{"hadithnumber": "7184", "text": "ابن وہب نے کہا : مجھے عمر بن محمد بن زید بن عبداللہ بن عمر بن خطاب نےحدیث بیان کی کہ انھیں ان کے وال"}
{"hadithnumber": "7185", "text": "حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت ہے  ، کہا : رسول اللہ  صلی اللہ علیہ وسلم  نے فرمایا :"}
{"hadithnumber": "7186", "text": "ابو کریب اور احمد بن عمر وکیعی نےہمیں حدیث بیان کی  ، دونوں نے کہا : ہمیں ابن فضیل نے اپنے والد سے ،"}
{"hadithnumber": "7187", "text": "معاذ عنبری نے کہا : ہمیں شعبہ نے حدیث بیان کی ، انھوں نے کہا : مجھے معبد بن خالد نے حدیث بیان کی ، ا"}
{"hadithnumber": "7188", "text": "محمد بن جعفر نے کہا : ہمیں شعبہ نے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی مگر اس میں کہا :  \" کیا"}
{"hadithnumber": "7189", "text": "سفیان نے ہمیں معبد بن خالد سے حدیث بیان کی ، انھوں نے کہا : میں نے حضرت حارثہ بن وہب خزاعی رضی اللہ"}
{"hadithnumber": "7190", "text": "حضرت ابوہریرہ رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ رسول اللہ  صلی اللہ علیہ وسلم  نے فرمایا؛ \" بسا او"}
{"hadithnumber": "7191", "text": "ابو بکر بن ابی شیبہ اور ابو کریب نے ہمیں حدیث بیان کی ، دونوں نے کہا : ہمیں ابن نمیر کےنے ہشام بن عر"}
{"hadithnumber": "7192", "text": "سہیل کے والد ( ابوصالح )  نے حضرت ابوہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا : رسول اللہ  صلی ا"}
{"hadithnumber": "7193", "text": "ابن شہاب نے کہا : میں نے سعید بن مسیب سےسنا ، وہ کہتے ہیں : بحیرہ وہ جانور ہے جس کا دودھ جھوٹے خداؤں"}
{"hadithnumber": "7194", "text": "سہیل کے والد ( ابو صالح )  نے حضرت  ابو ہریرۃ رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا : رسول اللہ  صل"}
{"hadithnumber": "7195", "text": "زید بن حباب نے کہا : ہمیں افلح بن سعید نے حدیث بیان کی  ، کہا : ہمیں حضرت ام سلمہ رضی اللہ تعالیٰ عن"}
{"hadithnumber": "7196", "text": "ابو عامر عقدی نے کہا : ہمیں افلح بن سعید نے حدیث بیان کی ، کہا  : مجھے حضرت ام سلمہ رضی اللہ تعالیٰ"}
{"hadithnumber": "7197", "text": "عبد اللہ بن ادریس محمد بن نمیر محمد بن بشیر موسیٰ بن اعین اور ابواسامہ اور یحییٰ بن سعید سب نے ہمیں"}
{"hadithnumber": "7198", "text": "و حَدَّثَنِي زُهَيْرُ بْنُ حَرْبٍ حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ عَنْ حَاتِمِ بْنِ أَبِي صَغِيرَةَ"}
{"hadithnumber": "7199", "text": "ابو خالد احمرنے ہمیں حاتم بن ابی صغیرہ سے اسی سند کے ساتھ حدیث بیان کی اور انھوں نے اپنی روایت میں"}
{"hadithnumber": "7200", "text": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ وَزُهَيْرُ بْنُ حَرْبٍ وَإِسْحَقُ بْنُ إِبْرَاهِيمَ وَاب"}
{"hadithnumber": "7201", "text": "وکیع اور معاذ دونوں نے ہمیں شعبہ سے حدیث بیان کی ،  نیز محمد بن مثنیٰ اور محمد بن بشار نے  ۔ الفاظ ا"}
{"hadithnumber": "7202", "text": "حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  نے نبی  صلی اللہ علیہ وسلم  سے روایت کی کہ آپ نے فرمایا  :  \"  ("}
{"hadithnumber": "7203", "text": "زہیر بن حرب محمد بن مثنیٰ اور عبید اللہ بن سعید نے ہمیں حدیث بیان کی ،  انھوں نے کہا :  ہمیں یحییٰ ب"}
{"hadithnumber": "7204", "text": "موسیٰ بن عقبہ ابن عون امام مالک ایوب اور صالح سب نے نافع سے ،  انھوں نے حضرت ابن عمر رضی اللہ تعالیٰ"}
{"hadithnumber": "7205", "text": "عبد العزیز بن محمد نے ثور سے انھوں نے ابو الغیث سے اور انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "7206", "text": "عبد الرحمٰن بن جابر سے روایت ہے کہا مجھے نیلم بن عامر نے حدیث بیان کی  ، کہا :  مجھے حضرت مقدادبن اس"}
{"hadithnumber": "7207", "text": "ابو غسان مسمعی محمد بن مثنیٰ اور محمد بن بشار بن عثمان نے ہمیں حدیث بیان کی ۔  الفاظ ابو غسان اور اب"}
{"hadithnumber": "7208", "text": "سعید نے قتادہ سے اسی سند کے ساتھ روایت کی اور اپنی حدیث میں یہ بیان نہیں کیا :  \" ہر مال جو میں نے ب"}
{"hadithnumber": "7209", "text": "ہمیں یحییٰ بن سعید نے دستوائی  ( کپڑے بیچنے  ) والے ہشام سے حدیث بیان کی ، انھوں نے کہا : ہمیں قتادہ"}
{"hadithnumber": "7210", "text": "مطر نے کہا :  مجھے قتادہ نے مطرف بن عبد اللہ بن شخیر سے حدیث بیان کی انھوں نے حضرت عیاض بن حماد رضی"}
{"hadithnumber": "7211", "text": "نافع نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے روایت کی کہ رسول اللہ  صلی اللہ علیہ وسلم  نے فرمایا :"}
{"hadithnumber": "7212", "text": "سالم نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہا :  کہ نبی  صلی اللہ علیہ وسلم  نے فرمای"}
{"hadithnumber": "7213", "text": "ابن علیہ نے کہا :  ہمیں سعید جریری نے ابو نضرہ سے روایت کی ،  انھوں نے حضرت ابو سعید خدری رضی اللہ ت"}
{"hadithnumber": "7214", "text": "حضرت انس رضی اللہ تعالیٰ عنہ سے روایت ہے کہ نبی  صلی اللہ علیہ وسلم نے فرمایا :  \" اگر یہ خدشہ نہ ہو"}
{"hadithnumber": "7215", "text": "حضرت براء رضی اللہ تعالیٰ عنہ نے حضرت ابو ایوب رضی اللہ تعالیٰ عنہ  سےروایت کی ،  کہا :  رسول اللہ"}
{"hadithnumber": "7216", "text": "شیبان بن عبد الرحمٰن نے قتادہ سے روایت کی کہا :  ہمیں حضرت انس بن مالک رضی اللہ تعالیٰ عنہ نے حدیث ب"}
{"hadithnumber": "7217", "text": "یزید بن زریع نے کہا :  ہمیں سعید بن ابی عروبہ نے قتادہ سے حدیث بیان کی انھوں نے حضرت انس بن مالک رضی"}
{"hadithnumber": "7218", "text": "عبدالوہاب بن عطاء نے سعید  ( بن ابی عروبہ )  سے ،  انھوں نے حضرت انس بن مالک رضی اللہ تعالیٰ عنہ  سے"}
{"hadithnumber": "7219", "text": "سعد بن عبیدہ نے حضرت براء بن عازب  رضی اللہ تعالیٰ عنہ  سے اور انھوں نے نبی  صلی اللہ علیہ وسلم  سے"}
{"hadithnumber": "7220", "text": "خیثمہ نے حضرت براءبن عازب رضی اللہ تعالیٰ عنہ سے  ( اس آیت کے بارے میں  )  روایت کی :  \" اللہ تعالیٰ"}
{"hadithnumber": "7221", "text": "مجھے عبید اللہ بن عمر قواریری نے حدیث بیان کی ،  انھوں نے کہا :  ہمیں حماد بن زید نے حدیث بیان کی ان"}
{"hadithnumber": "7222", "text": "سلیمان بن مغیرہ نے کہا : ہمیں ثابت نے حضرت انس بن مالک رضی اللہ تعالیٰ عنہ  سے حدیث بیان کی ،  انھوں"}
{"hadithnumber": "7223", "text": "حماد بن سلمہ نے ثابت بنانی سے اور انھوں نے حضرت انس بن مالک رضی اللہ تعالیٰ عنہ  سے روایت کی کہ رسول"}
{"hadithnumber": "7224", "text": "عبد الاعلی اور روح بن عبادہ نے سعید بن ابی عروبہ سے انھوں نے قتادہ سے روایت کی ،  انھوں نے کہا :  ہم"}
{"hadithnumber": "7225", "text": "اسماعیل بن علیہ نے ایوب سے انھوں نے عبد اللہ بن ابی ملیکہ سے اور انھوں نے حضرت عائشہ رضی اللہ تعالیٰ"}
{"hadithnumber": "7226", "text": "حماد بن زید نے کہا :  ہمیں ایوب نے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی ۔"}
{"hadithnumber": "7227", "text": "ابو یونس قشیری نے ہمیں حدیث بیان کی کہا :  ہمیں ابن ابی ملیکہ نے قاسم سے حدیث بیان کی انھوں نے حضرت"}
{"hadithnumber": "7228", "text": "عثمان بن اسود نے ابن ابی ملیکہ سے ، انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے اور انھوں نے نبی ک"}
{"hadithnumber": "7229", "text": "یحییٰ بن زکریا نے اعمش سے  ، انھوں نےابو سفیان سے اور انھوں نے حضرت جابر رضی اللہ تعالیٰ عنہ  سے روا"}
{"hadithnumber": "7230", "text": "جریر ، ابو معاویہ اورعیسیٰ بن یونس نے اعمش سے اسی سند کے ساتھ اسی کے مانند روایت کی ۔"}
{"hadithnumber": "7231", "text": "ابوزبیر نے حضرت جابر بن عبداللہ انصاری  رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا : میں نے  رسول اللہ ص"}
{"hadithnumber": "7232", "text": "جریر نے اعمش سے  ، انھوں نے ابو سفیان سے اور انھوں نے حضرت جابر رضی اللہ تعالیٰ عنہ  سے روایت کی ، ک"}
{"hadithnumber": "7233", "text": "سفیان نے اعمش سے اسی سند کے ساتھ  ، اسی کے مانند  روایت کی اور کہا :  \"  نبی کریم صلی اللہ علیہ وسلم"}
{"hadithnumber": "7234", "text": "حمزہ بن عبداللہ بن عمر نے بتایا کہ حضرت عبداللہ بن عمر رضی اللہ تعالیٰ عنہ  نے کہا : میں نے رسول الل"}
