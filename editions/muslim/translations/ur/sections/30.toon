{"hadithnumber": "4470", "text": "ابن جریج نے ابن ابی ملیکہ سے اور انہوں نے حضرت ابن عباس رضی اللہ عنہ سے روایت کی کہ نبی صلی اللہ علی"}
{"hadithnumber": "4471", "text": "افع بن عمر نے ابن ابی ملیکہ سے اور انہوں نے حضرت ابن عباس رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی"}
{"hadithnumber": "4472", "text": "حضرت عبداللہ بن عباس رضی اللہ عنہ سے روایت ہے کہ رسول اللہ صلی اللہ علیہ وسلم نے ایک قسم اور ایک گوا"}
{"hadithnumber": "4473", "text": "ابومعاویہ نے ہمیں ہشام بن عروہ سے خبر دی، انہوں نے اپنے والد سے، انہوں نے زینب بنت ابی سلمہ رضی اللہ"}
{"hadithnumber": "4474", "text": "ابومعاویہ نے ہمیں ہشام بن عروہ سے خبر دی ،  انہوں نے اپنے والد سے ،  انہوں نے زینب بنت ابی سلمہ رضی"}
{"hadithnumber": "4475", "text": "یونس نے مجھے ابن شہاب سے خبر دی ،  کہا :  مجھے عروہ بن زبیر نے زینب بنت ابی سلمہ رضی اللہ عنہا سے خب"}
{"hadithnumber": "4476", "text": "صالح اور معمر دونوں نے زہری سے اسی سند کے ساتھ یونس کی حدیث کی طرح حدیث بیان کی ۔ \\n\\nمعمر کی حدیث میں"}
{"hadithnumber": "4477", "text": "علی بن مسہر نے ہمیں ہشام بن عروہ سے حدیث بیان کی ،  انہوں نے اپنے والد سے اور انہوں نے حضرت عائشہ رض"}
{"hadithnumber": "4478", "text": "عبداللہ بن نمیر ،  وکیع ،  عبدالعزیز بن محمد اور ضحاک بن عثمان سب نے ہشام سے اسی سند کے ساتھ حدیث بی"}
{"hadithnumber": "4479", "text": "معمر نے زہری سے ،  انہوں نے عروہ سے اور انہوں نے حضرت عائشہ رضی اللہ عنہا سے روایت کی ،  انہوں نے کہ"}
{"hadithnumber": "4480", "text": "زہری کے بھتیجے نے ہمیں اپنے چچا سے حدیث بیان کی ،  کہا :  مجھے عروہ بن زبیر نے خبر دی کہ حضرت عائشہ"}
{"hadithnumber": "4481", "text": "جریر نے سہیل سے ،  انہوں نے اپنے والد سے اور انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  کہا"}
{"hadithnumber": "4482", "text": "ابوعوانہ نے سہیل سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی ،  مگر انہوں نے  ( ناپسند کرتا ہے کی ج"}
{"hadithnumber": "4483", "text": "جریر نے منصور سے ،  انہوں نے شعبی سے ،  انہوں نے مغیرہ بن شعبہ رضی اللہ عنہ کے آزاد کردہ غلام وراد س"}
{"hadithnumber": "4484", "text": "شیبان نے منصور سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی ،  مگر انہوں نے کہا :   \" رسول اللہ صلی"}
{"hadithnumber": "4485", "text": "شعبی سے روایت ہے ،  کہا :  مجھے مغیرہ بن شعبہ رضی اللہ عنہ کے کاتب نے حدیث بیان کی ،  انہوں نے کہا :"}
{"hadithnumber": "4486", "text": "محمد بن عبیداللہ ثفقی نے ہمیں وراد سے خبر دی ،  انہوں نے کہا :  حضرت مغیرہ  ( بن شعبہ رضی اللہ عنہ )"}
{"hadithnumber": "4487", "text": "مجھے یحییٰ بن یحییٰ تمیمی نے حدیث بیان کی ،  کہا :  ہمیں عبدالعزیز بن محمد نے یزید بن عبداللہ بن اسا"}
{"hadithnumber": "4488", "text": "اسحاق بن ابراہیم اور محمد بن ابی عمر دونوں نے عبدالعزیز بن محمد سے اسی سند کے ساتھ اسی کے مانند حدیث"}
{"hadithnumber": "4489", "text": "لیث بن سعد نے ہمیں حدیث بیان کی ،  کہا :  مجھے یزید بن عبداللہ بن اسامہ بن ہاد لیث نے  ( اپنی )  دون"}
{"hadithnumber": "4490", "text": "ابوعوانہ نے ہمیں عبدالملک بن عمیر سے حدیث بیان کی ،  انہوں نے عبدالرحمان بن ابی بکرہ سے روایت کی ،"}
{"hadithnumber": "4491", "text": "ہشیم ،  حماد بن سلمہ ،  سفیان ،  محمد بن جعفر ،  شعبہ اور زائدہ سب نے عبدالملک بن عمیر سے ،  انہوں ن"}
{"hadithnumber": "4492", "text": "ابراہیم بن سعد بن ابراہیم بن عبدالرحمان بن عوف نے ہمیں حدیث بیان کی ،  کہا :  ہمیں میرے والد نے قاسم"}
{"hadithnumber": "4493", "text": "عبداللہ بن جعفر زہری نے ہمیں سعد بن ابراہیم سے حدیث بیان کی ،  انہوں نے کہا :  میں نے قاسم بن محمد س"}
{"hadithnumber": "4494", "text": "حضرت زید بن خالد جہنی رضی اللہ عنہ سے روایت ہے کہ نبی صلی اللہ علیہ وسلم نے فرمایا :   \" کیا تمہیں ب"}
{"hadithnumber": "4495", "text": "ورقاء نے مجھے ابوزناد سے حدیث بیان کی ،  انہوں نے اعرج سے ،  انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے"}
{"hadithnumber": "4496", "text": "موسیٰ بن عقببہ اور محمد بن عجلان نے ابوزناد سے اسی سند کے ساتھ ورقاء کی حدیث کے مانند حدیث بیان کی"}
{"hadithnumber": "4497", "text": "ہمام بن منبہ سے روایت ہے ،  انہوں نے کہا :  یہ احادیث ہیں جو ہمیں حضرت ابوہریرہ رضی اللہ عنہ نے رسول"}
