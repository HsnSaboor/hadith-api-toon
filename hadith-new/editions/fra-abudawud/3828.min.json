{"metadata":{"name":"Sunan Abu Dawud","section":{"28":"Foods (Kitab Al-At'imah)"},"section_detail":{"28":{"hadithnumber_first":3736,"hadithnumber_last":3854,"arabicnumber_first":3736,"arabicnumber_last":3854}}},"hadiths":[{"hadithnumber":3828,"arabicnumber":3828,"text":"Rapporté par Ali ibn Abu Talib : Il est interdit de manger de l’ail à moins qu’il ne soit cuit. Abu Dawud a dit : Le nom complet du rapporteur Sharik est Sharik ibn Hanbal","grades":[{"name":"Al-Albani","grade":"Sahih"},{"name":"Muhammad Muhyi Al-Din Abdul Hamid","grade":"Sahih"},{"name":"Shuaib Al Arnaut","grade":"Sahih Lighairihi"},{"name":"Zubair Ali Zai","grade":"Daif"}],"reference":{"book":28,"hadith":93}}]}