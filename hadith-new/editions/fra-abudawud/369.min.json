{"metadata":{"name":"Sunan Abu Dawud","section":{"1":"Purification (Kitab Al-Taharah)"},"section_detail":{"1":{"hadithnumber_first":1,"hadithnumber_last":390,"arabicnumber_first":1,"arabicnumber_last":390}}},"hadiths":[{"hadithnumber":369,"arabicnumber":369,"text":"Rapporté par Maymouna رضي الله عنها : Le Prophète ﷺ a prié sur un drap appartenant à l’une de ses épouses qui avait ses règles. Il priait alors qu’une partie du drap était sur lui","grades":[{"name":"Al-Albani","grade":"Sahih"},{"name":"Muhammad Muhyi Al-Din Abdul Hamid","grade":"Sahih"},{"name":"Shuaib Al Arnaut","grade":"Sahih"},{"name":"Zubair Ali Zai","grade":"Isnaad Sahih"}],"reference":{"book":1,"hadith":369}}]}