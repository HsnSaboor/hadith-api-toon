{"hadithnumber": "3836", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  نذر نہ مانو، کیونکہ نذ"}
{"hadithnumber": "3837", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو اللہ کی"}
{"hadithnumber": "3838", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  جو"}
{"hadithnumber": "3839", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  جو"}
{"hadithnumber": "3840", "text": "عمران بن حصین رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم میں سے زیادہ ا"}
{"hadithnumber": "3841", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ایک ایسے شخص کے پاس سے گزرے"}
{"hadithnumber": "3842", "text": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم ایک آدمی کے پاس سے گزرے ج"}
{"hadithnumber": "3843", "text": "عمران بن حصین رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  اللہ کی نافرمان"}
{"hadithnumber": "3844", "text": "ثابت بن ضحاک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو کوئی دین اسلام کے"}
{"hadithnumber": "3845", "text": "عقبہ بن عامر رضی اللہ عنہ کہتے ہیں کہ  میری بہن نے نذر مانی کہ وہ بیت اللہ پیدل جائے گی، اس نے مجھے"}
{"hadithnumber": "3846", "text": "عقبہ بن عامر رضی اللہ عنہ کہتے ہیں کہ  انہوں نے نبی اکرم صلی اللہ علیہ وسلم سے اپنی ایک بہن کے بارے"}
{"hadithnumber": "3847", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  ایک عورت نے سمندر کا سفر کیا اور نذر مانی کہ وہ ایک مہین"}
{"hadithnumber": "3848", "text": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  سعد بن عبادہ رضی اللہ عنہ نے رسول اللہ صلی اللہ علیہ"}
{"hadithnumber": "3849", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  سعد بن عبادہ رضی اللہ عنہ نے رسول اللہ صلی اللہ علیہ وسل"}
{"hadithnumber": "3850", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  سعد بن عبادہ رضی اللہ عنہ نبی اکرم صلی اللہ علیہ وسلم کے"}
{"hadithnumber": "3851", "text": "عمر رضی اللہ عنہ سے روایت ہے کہ  انہوں نے جاہلیت میں ایک رات کی نذر مانی تھی کہ وہ اس میں اعتکاف کری"}
{"hadithnumber": "3852", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  عمر رضی اللہ عنہ کے ذمہ مسجد الحرام میں ایک رات اعتکاف کر"}
{"hadithnumber": "3853", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  عمر رضی اللہ عنہ نے جاہلیت میں  ( مسجد الحرام میں )  ا"}
{"hadithnumber": "3854", "text": "کعب بن مالک رضی اللہ عنہ سے روایت ہے کہ  جب ان کی توبہ قبول ہوئی تو رسول اللہ صلی اللہ علیہ وسلم سے"}
{"hadithnumber": "3855", "text": "کعب بن مالک رضی اللہ عنہ اپنا وہ واقعہ بیان کرتے ہیں کہ  جب وہ غزوہ تبوک میں رسول اللہ صلی اللہ علیہ"}
{"hadithnumber": "3856", "text": "کعب بن مالک رضی اللہ عنہ اپنا اس وقت کا واقعہ بیان کرتے ہیں کہ  جب وہ غزوہ تبوک میں رسول اللہ صلی ال"}
