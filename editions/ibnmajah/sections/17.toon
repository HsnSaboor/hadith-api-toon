hadiths[21]{hadithnumber,arabic,bengali,english,french,indonesian,russian,urdu,grades,reference,international_number,narrator_chain,chapter_intro}:
"2227","حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، وَمُحَمَّدُ بْنُ الصَّبَّاحِ، قَالاَ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنْ كَانَتْ لَهُ نَخْلٌ أَوْ أَرْضٌ فَلاَ يَبِيعُهَا حَتَّى يَعْرِضَهَا عَلَى شَرِيكِهِ ‏""""‏ ‏.‏""","","“The Messenger of Allah (ﷺ) said: 'Whoever has a date-palm tree or land, should not sell it until he has offered it to his partner.' ”","","","","","","","","It was narrated that Jabir said:","The Chapters on Pre-emption"
"2228","حَدَّثَنَا أَحْمَدُ بْنُ سِنَانٍ، وَالْعَلاَءُ بْنُ سَالِمٍ، قَالاَ حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، أَنْبَأَنَا شَرِيكٌ، عَنْ سِمَاكٍ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ مَنْ كَانَتْ لَهُ أَرْضٌ فَأَرَادَ بَيْعَهَا فَلْيَعْرِضْهَا عَلَى جَارِهِ ‏""""‏ ‏.‏""","","“Whoever has land and wants to sell it, let him offer it to his neighbor.”","","","","","","","","It was narrated from Ibn Abbas that the Prophet (ﷺ) said:","The Chapters on Pre-emption"
"2229","حَدَّثَنَا عُثْمَانُ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا هُشَيْمٌ، أَنْبَأَنَا عَبْدُ الْمَلِكِ، عَنْ عَطَاءٍ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ الْجَارُ أَحَقُّ بِشُفْعَةِ جَارِهِ يَنْتَظِرُ بِهَا إِنْ كَانَ غَائِبًا إِذَا كَانَ طَرِيقُهُمَا وَاحِدًا ‏""""‏ ‏.‏""","","“The neighbor has more right to preemption of his neighbor, so let him wait for him even if he is absent, if they share a path.”","","","","","","","","It was narrated from Jabir that the Messenger of Allah (ﷺ) said:","The Chapters on Pre-emption"
"2230","حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ إِبْرَاهِيمَ بْنِ مَيْسَرَةَ، عَنْ عَمْرِو بْنِ الشَّرِيدِ، عَنْ أَبِي رَافِعٍ، أَنَّ النَّبِيَّ صلى الله عليه وسلم قَالَ ‏ ‏ الْجَارُ أَحَقُّ بِسَقَبِهِ ‏""""‏ ‏.‏""","","“The neighbor has more right to property that is near.”","","","","","","","","It was narrated from Abu Rafi' that the Prophet (ﷺ) said:","The Chapters on Pre-emption"
"2231","حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو أُسَامَةَ، عَنْ حُسَيْنٍ الْمُعَلِّمِ، عَنْ عَمْرِو بْنِ شُعَيْبٍ، عَنْ عَمْرِو بْنِ الشَّرِيدِ بْنِ سُوَيْدٍ، عَنْ أَبِيهِ الشَّرِيدِ بْنِ سُوَيْدٍ، قَالَ قُلْتُ يَا رَسُولَ اللَّهِ أَرْضٌ لَيْسَ فِيهَا لأَحَدٍ قِسْمٌ وَلاَ شِرْكٌ إِلاَّ الْجِوَارُ ‏.‏ قَالَ ‏ ‏ الْجَارُ أَحَقُّ بِسَقَبِهِ ‏""""‏ ‏.‏""","","“I said: 'O Messenger of Allah, (what do you think of) land owned by only one person but this land has neighbors?' He said: 'The neighbor has more right to property that is near.' ”","","","","","","","","It was narrated that Sharid bin Suwaid said:","The Chapters on Pre-emption"
"2232","حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، وَعَبْدُ الرَّحْمَنِ بْنُ عُمَرَ، قَالاَ حَدَّثَنَا أَبُو عَاصِمٍ، حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، عَنِ الزُّهْرِيِّ، عَنْ سَعِيدِ بْنِ الْمُسَيَّبِ، وَأَبِي، سَلَمَةَ بْنِ عَبْدِ الرَّحْمَنِ عَنْ أَبِي هُرَيْرَةَ ـ رضي الله عنه ـ أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَضَى بِالشُّفْعَةِ فِيمَا لَمْ يُقْسَمْ فَإِذَا وَقَعَتِ الْحُدُودُ فَلاَ شُفْعَةَ ‏.‏","","the Messenger of Allah (ﷺ) ruled concerning preemption of land that has not been divided; if the boundaries have been set then there is no preemption.","","","","ابوایوب انصاری رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  اپنا اناج ناپ لیا ک","","","2232","It was narrated from Abu Hurairah that:","The Chapters on Pre-emption"
"2233","حَدَّثَنَا مُحَمَّدُ بْنُ حَمَّادٍ الطِّهْرَانِيُّ، حَدَّثَنَا أَبُو عَاصِمٍ، عَنْ مَالِكٍ، عَنِ الزُّهْرِيِّ، عَنْ سَعِيدِ بْنِ الْمُسَيَّبِ، وَأَبِي، سَلَمَةَ عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم نَحْوَهُ ‏.‏ قَالَ أَبُو عَاصِمٍ سَعِيدُ بْنُ الْمُسَيَّبِ مُرْسَلٌ وَأَبُو سَلَمَةَ عَنْ أَبِي هُرَيْرَةَ مُتَّصِلٌ ‏.‏","","Another chain narrates a hadith similar to the previous one.","","","","ابواسید رضی اللہ عنہ بیان کرتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نبیط کے بازار تشریف لے گئے، اس ک","","","2233","","The Chapters on Pre-emption"
"2234","حَدَّثَنَا عَبْدُ اللَّهِ بْنُ الْجَرَّاحِ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ إِبْرَاهِيمَ بْنِ مَيْسَرَةَ، عَنْ عَمْرِو بْنِ الشَّرِيدِ، عَنْ أَبِي رَافِعٍ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ الشَّرِيكُ أَحَقُّ بِسَقَبِهِ مَا كَانَ ‏""""‏ ‏.‏""","","“The partner has more right to what is near him, so long as he is still a partner.”","","","","","","","","It was narrated from Abu Rafi' that the Messenger of Allah (ﷺ) said:","The Chapters on Pre-emption"
"2235","حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، عَنْ مَعْمَرٍ، عَنِ الزُّهْرِيِّ، عَنْ أَبِي سَلَمَةَ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، قَالَ إِنَّمَا جَعَلَ رَسُولُ اللَّهِ صلى الله عليه وسلم الشُّفْعَةَ فِي كُلِّ مَا لَمْ يُقْسَمْ فَإِذَا وَقَعَتِ الْحُدُودُ وَصُرِّفَتِ الطُّرُقُ فَلاَ شُفْعَةَ ‏""‏ ‏.‏","","the Messenger of Allah (ﷺ) ruled that preemption takes effect in all cases where land has not been divided. But if the boundaries have been set and the roads laid out, then there is no preemption.”","","","","عمر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص بازار میں داخل ہوتے وق","","","2235","It was narrated from Jabir bin Abdullah that:","The Chapters on Pre-emption"
"2236","حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُحَمَّدُ بْنُ الْحَارِثِ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ الْبَيْلَمَانِيِّ، عَنْ أَبِيهِ، عَنِ ابْنِ عُمَرَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ الشُّفْعَةُ كَحَلِّ الْعِقَالِ ‏""""‏ ‏.‏""","","“Preemption is like undoing the `Iqal.”","","","","","","","","It was narrated from Ibn 'Umar that the Messenger of Allah (ﷺ) said:","The Chapters on Pre-emption"
"2237","حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، قَالَ حَدَّثَنَا مُحَمَّدُ بْنُ الْحَارِثِ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ الْبَيْلَمَانِيِّ، عَنْ أَبِيهِ، عَنِ ابْنِ عُمَرَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ لاَ شُفْعَةَ لِشَرِيكٍ عَلَى شَرِيكٍ إِذَا سَبَقَهُ بِالشِّرَاءِ وَلاَ لِصَغِيرٍ وَلاَ لِغَائِبٍ ‏""""‏ ‏.‏""","","“There is no preemption for a partner when his co-partner has beaten him to it (in another deal before), not for a minor nor one who is absent.”","","","","","","","","It was narrated from Ibn 'Umar that the Messenger of Allah (ﷺ) said:","The Chapters on Pre-emption"
"2492","حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏ وَمُحَمَّدُ بْنُ الصَّبَّاحِ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَا","","It was narrated that Jabir said:“The Messenger of Allah (ﷺ) said: 'Whoever has a date-palm tree or land, should not sell it until he has offered it to his partner.' ”","","","","جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس کے پاس کھجور کے درخت ہوں","{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}","Book 17, Hadith 1","2492","","The Chapters on Pre-emption"
"2493","حَدَّثَنَا أَحْمَدُ بْنُ سِنَانَ، ‏‏‏‏‏‏ وَالْعَلَاءُ بْنُ سَالِمٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَا يَز","","It was narrated from Ibn Abbas that the Prophet (ﷺ) said:“Whoever has land and wants to sell it, let him offer it to his neighbor.”","","","","عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جس کے پاس زمین ہ","{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih Lighairihi'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}","Book 17, Hadith 2","2493","","The Chapters on Pre-emption"
"2494","حَدَّثَنَا عُثْمَانُ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا هُشَيْمٌ، ‏‏‏‏‏‏أَنْبَأَنَا عَبْدُ الْمَل","","It was narrated from Jabir that the Messenger of Allah (ﷺ) said:“The neighbor has more right to preemption of his neighbor, so let him wait for him even if he is absent, if they share a path.”","","","","جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  پڑوسی اپنے پڑوسی کے شفعہ کا","{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}","Book 17, Hadith 3","2494","","The Chapters on Pre-emption"
"2495","حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدّ","","It was narrated from Abu Rafi' that the Prophet (ﷺ) said:“The neighbor has more right to property that is near.”","","","","ابورافع رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  پڑوسی اپنے نزدیکی مکان","{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Bukhari'}","Book 17, Hadith 4","2495","","The Chapters on Pre-emption"
"2496","حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو أُسَامَةَ، ‏‏‏‏‏‏عَنْ حُسَيْنٍ ا","","It was narrated that Sharid bin Suwaid said:“I said: 'O Messenger of Allah, (what do you think of) land owned by only one person but this land has neighbors?' He said: 'The neighbor has more right to property that is near.' ”","","","","شرید بن سوید رضی اللہ عنہ کہتے ہیں کہ  میں نے عرض کیا: اللہ کے رسول! ایک زمین ہے جس میں کسی کا حصہ ن","{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}","Book 17, Hadith 5","2496","","The Chapters on Pre-emption"
"2497","حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏ وَعَبْدُ الرَّحْمَنِ بْنُ عُمَرَ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّث","","It was narrated from ‘Ali bin Abu Talib, Abu Darda’, Abu Hurairah, Abu Umamah Al-Bahili, ‘Abdullah bin ‘Umar, ‘Abdullah bin ‘Amr, Jabir bin ‘Abdullah and ‘Imran bin Husain, all of them narrating that the Messenger of Allah (ﷺ) said:: “Whoever sends financial support in the cause of Allah and stays at home, for every Dirham he will have (the reward of) seven hundred Dirham. Whoever fights himself in the cause of Allah, and spends on that, for every Dirham he will have (the reward of) seven hundred thousand Dirham.” Then he recited the Verse: “Allah gives manifold increase to whom He wills.”","","","","ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایسی جائیداد میں شفعہ کا حکم د","{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'}","Book 17, Hadith 6","2497","","The Chapters on Pre-emption"
"2498","حَدَّثَنَا عَبْدُ اللَّهِ بْنُ الْجَرَّاحِ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏عَنْ إ","","It was narrated from Abu Rafi' that the Messenger of Allah (ﷺ) said:“The partner has more right to what is near him, so long as he is still a partner.”","","","","ابورافع رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  شریک  ( ساجھی دار )  اپنی","{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Bukhari'}","Book 17, Hadith 8","2498","","The Chapters on Pre-emption"
"2499","حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الرَّزَّاقِ، ‏‏‏‏‏‏عَنْ مَعْمَرٍ، ‏‏‏‏‏‏ع","","It was narrated from Jabir bin Abdullah that:the Messenger of Allah (ﷺ) ruled that preemption takes effect in all cases where land has not been divided. But if the boundaries have been set and the roads laid out, then there is no preemption.”","","","","جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے شفعہ ہر اس جائیداد میں ٹ","{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Bukhari'}","Book 17, Hadith 9","2499","","The Chapters on Pre-emption"
"2500","حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ الْحَارِثِ، ‏‏‏‏‏‏عَنْ مُحَمَّدِ","","It was narrated from Ibn 'Umar that the Messenger of Allah (ﷺ) said:“Preemption is like undoing the `Iqal.”","","","","عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  شفعہ اونٹ کی رسی","{'name': 'Al-Albani', 'grade': 'Very Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Very Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Very Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}","Book 17, Hadith 10","2500","","The Chapters on Pre-emption"
"2501","حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا مُحَمَّدُ بْنُ الْحَارِثِ، ‏‏‏‏‏‏عَنْ","","It was narrated from Ibn 'Umar that the Messenger of Allah (ﷺ) said:“There is no preemption for a partner when his co-partner has beaten him to it (in another deal before), not for a minor nor one who is absent.”","","","","عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  شریک کو شریک پر","{'name': 'Al-Albani', 'grade': 'Very Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Very Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Very Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}","Book 17, Hadith 11","2501","","The Chapters on Pre-emption"