{"hadithnumber": "1570", "text": "صالح بن کیسان نے عروہ بن زبیر سے اور انھوں نے نبی کریم  صلی اللہ علیہ وسلم   کی اہلیہ حضرت عائشہ  رض"}
{"hadithnumber": "1571", "text": "یونس نے ابن شہاب سے روایت کی ، انھوں نے کہا ، مجھے عروہ بن زبیر نے حدیث بیان کی ، کہ نبی اکرم  صلی ا"}
{"hadithnumber": "1572", "text": "ابن عینیہ نے زہری سے انھوں نے عروہ سے اور انھوں نے حضرت عائشہ صدیقہ  رضی اللہ تعالیٰ عنہا   سے روایت"}
{"hadithnumber": "1573", "text": "عبداللہ بن ادریس نے ابن جریج سے ، انھوں نے ابن ابی عمار سے  ، انھوں نے عبداللہ بن بابیہ سے اور انھوں"}
{"hadithnumber": "1574", "text": "یحییٰ نے ابن جریج سے سابقہ سند کے ساتھ حضرت یعلیٰ بن امیہ  رضی اللہ تعالیٰ عنہ  سے روایت  کی  ، کہا!"}
{"hadithnumber": "1575", "text": "ابو عوانہ نے بکیر بن اخنس سے ، انھوں نے مجاہد سے ، انھوں نے حضرت ابن عباس  رضی اللہ تعالیٰ عنہ  سے ر"}
{"hadithnumber": "1576", "text": "ایوب بن عائد طائی نے بکیر بن اخنس سے  ، انھوں نے م مجاہد سے  اور انھوں نے حضرت ابن عباس  رضی اللہ تع"}
{"hadithnumber": "1577", "text": "شعبہ نے کہا : میں نے قتادہ سے سنا ، وہ موسیٰ بن سلمہ ہذلی  ( بصری )  سے حدیث بیان کررہے تھے ۔ کہا :"}
{"hadithnumber": "1578", "text": "( شعبہ کی بجائے )  سعید بن ابی عروبہ اور معاذ بن ہشام نے اپنے والد کے واسطے سے قتادہ سے  ، اسی مذکور"}
{"hadithnumber": "1579", "text": "عیسیٰ بن حضص بن عاصم بن عمر بن خطاب  رضی اللہ تعالیٰ عنہ  نے اپنے والد  ( حفص )  سے روایت کی  ، انھو"}
{"hadithnumber": "1580", "text": "عمر بن محمد نے حفص بن عاصم سے روایت کی ، کہا : میں بیمار ہواتو ( عبداللہ )  بن عمر  رضی اللہ تعالیٰ"}
{"hadithnumber": "1581", "text": "ابو قلابہ نے حضرت انس بن مالک  رضی اللہ تعالیٰ عنہ  سے روایت کی کہ رسول اللہ  صلی اللہ علیہ وسلم   ن"}
{"hadithnumber": "1582", "text": "محمد بن منکدر اور ابراہیم بن میسرہ دونوں نے حضرت انس بن مالک  رضی اللہ تعالیٰ عنہ  سے سنا کہہ رہے تھ"}
{"hadithnumber": "1583", "text": "شعبہ نے یحییٰ بن یزید ہنائی سے روایت کی ، کہا :  کہا میں نے حضرت انس بن مالک رضی اللہ تعالیٰ عنہ  سے"}
{"hadithnumber": "1584", "text": "عبدالرحمان بن مہدی ،  نے حدیث بیان کی کہا : ہمیں شعبہ نے یزید بن خمیر سے حدیث سنائی ۔ انہوں نے حبیب"}
{"hadithnumber": "1585", "text": "محمد بن جعفر نے کہا :  ہمیں شعبہ نے اسی سند کے ساتھ یہ حدیث بیان کی اور کہا : ابن سمط سے روایت ہے او"}
{"hadithnumber": "1586", "text": "ہشیم نے یحییٰ بن ابی اسحاق سے  ، انھوں نے حضرت انس بن مالک  رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا :"}
{"hadithnumber": "1587", "text": "ابو عوانہ اور  ( اسماعیل )  ابن علیہ نے یحییٰ بن ابی اسحاق سے انھو ں نے حضرت انس  رضی اللہ تعالیٰ عن"}
{"hadithnumber": "1588", "text": "شعبہ نے کہا : مجھے یحییٰ بن ابی اسحاق نے حدیث سنائی ، کہا :  میں نےحضرت انس بن مالک  رضی اللہ تعالیٰ"}
{"hadithnumber": "1589", "text": "( سفیان )  ثوری نے یحییٰ بن ابی اسحاق سے ، انھوں نے حضرت انس  رضی اللہ تعالیٰ عنہ  سے اور انھوں نے ن"}
{"hadithnumber": "1590", "text": "عمرو بن حارث نے ابن شہاب سے  ، انھوں نے سالم بن عبداللہ ( بن عمر )  سے  ، انھوں نے اپنے والد  ( حضرت"}
{"hadithnumber": "1591", "text": "اوزاعی اور معمر نے ( اپنی اپنی سند سے  روایت کرتے ہوئے )  زہری سے باقی ماندہ اسی سند کے ساتھ یہی حدی"}
{"hadithnumber": "1592", "text": "ابو اسامہ نے کہا : ہمیں عبیداللہ بن عمر نے نافع سے حدیث سنائی ، انھوں نے حضرت ابن عمر  رضی اللہ تعال"}
{"hadithnumber": "1593", "text": "یحییٰ قطان ، ابن ابی زائدہ اور عقبہ بن خالد نے عبیداللہ سے اسی سند کے ساتھ اسی طرح روایت کی ۔"}
{"hadithnumber": "1594", "text": "عبیداللہ بن معاذ نے حدیث بیان کی  ، کہا : میرے والد نے ہمیں حدیث سنائی ، کہا : ہمیں شعبہ نے خبیب بن"}
{"hadithnumber": "1595", "text": "خالد بن حارث اور عبدالصمد نے کہا : ہمیں شعبہ نے ( باقی ماندہ )  اسی سند کے ساتھ یہی روایت بیان کی لی"}
{"hadithnumber": "1596", "text": "عبدالواحد نے اعمش سے حدیث بیان کی  ، کہا : ہمیں ابراہیم نے حدیث سنائی  ، کہا :  میں نے عبدالرحمان بن"}
{"hadithnumber": "1597", "text": "ابو معاویہ ، جریر اور عیسیٰ سب نے ( مختلف سندوں سے روایت کرتے ہوئے ) اعمش سے اسی سند کے ساتھ اسی طرح"}
{"hadithnumber": "1598", "text": "ابو احوص نے ابو اسحاق سے اور انھوں نے حضرت حارثہ بن وہب  رضی اللہ تعالیٰ عنہ  سے روایت  کی  ، کہا :"}
{"hadithnumber": "1599", "text": "زہیر نے حدیث بیان کی ، کہا : ہمیں ابو اسحاق نے حدیث سنائی ، کہا ، مجھ سے حارثہ بن وہب خزاعی  رضی الل"}
{"hadithnumber": "1600", "text": "امام مالک نے نافع  سے روایت کی کہ ابن عمر  رضی اللہ تعالیٰ عنہ  نے سردی اور ہوا والی ایک رات اذان کہ"}
{"hadithnumber": "1601", "text": "محمد بن عبداللہ بن نمیر نے حدیث بیان کی   ، کہا : مجھے میرے والد نے حدیث سنائی ، کہا : ہمیں عبیداللہ"}
{"hadithnumber": "1602", "text": "ابو اسامہ نے کہا : ہمیں عبیداللہ نے نافع سے حدیث سنائی ، انھوں نے حضرت ابن عمر  رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "1603", "text": "حضرت جابر  رضی اللہ تعالیٰ عنہ  سے روایت ہے انھوں نے کہا : ایک سفر  میں ہم رسول  اللہ  صلی اللہ علیہ"}
{"hadithnumber": "1604", "text": "اسماعیل ( ابن علیہ )  نے  ( ابن ابی سفیان )  الزیادی کے ساتھی عبدالحمید سے ، انھوں نے عبداللہ بن حار"}
{"hadithnumber": "1605", "text": "ابو کامل جحدری نے کہا :  ہمیں حماد  ، یعنی ابن زید نے عبدالحمید سے حدیث بیان کی  ، انھوں نے کہا :  م"}
{"hadithnumber": "1606", "text": "ابو ربیع عتکی زہرانی نے کہا : ہمیں حماد یعنی ابن زید نے حدیث سنائی  ، کہا  : ہمیں ایوب اور عاصم احول"}
{"hadithnumber": "1607", "text": "شعبہ نے کہا : ہمیں عبدالحمید صاحب الزیادی نے حدیث سنائی  ، کہا :  میں نے عبداللہ بن حارث سے سنا ، ان"}
{"hadithnumber": "1608", "text": "شعبہ اور معمر دونوں نے  ( اپنی اپنی سند سے  روایت کرتے ہوئے )  عاصم احول سے  اور انھوں نے عبداللہ بن"}
{"hadithnumber": "1609", "text": "وہیب نے کہا :  ہمیں ایوب نے عبداللہ بن حارث سے حدیث بیان کی ۔ وہیب نے کہا : ایوب نے یہ حدیث عبداللہ"}
{"hadithnumber": "1610", "text": "محمد بن عبداللہ بن نمیر نے حدیث بیان کی  ، کہا : ہمیں میرے والد نے حدیث بیان کی  ، کہا : ہمیں عبیدال"}
{"hadithnumber": "1611", "text": "ابو خالد احمر نے عبیداللہ سے انھوں نے نافع سے اور انھوں نے ابن عمر  رضی اللہ تعالیٰ عنہ  سے روایت کی"}
{"hadithnumber": "1612", "text": "یحییٰ بن سعید نے عبدالملک بن ابی سلیمان سے روایت کی  ، کہا  :  ہمیں سعید بن جبیر نے حضرت ابن عمر  رض"}
{"hadithnumber": "1613", "text": "ابن مبارک ، ابن ابی زائدہ اور ابن نمیر نے اپنے والد کے حوالے سے  ، سب نے عبدالملک سے اسی سند کے ساتھ"}
{"hadithnumber": "1614", "text": "عمرو بن یحییٰ مازنی نے سعید بن یسار سے اور انھوں نے حضرت ابن عمر  رضی اللہ تعالیٰ عنہ  سے روایت کی ،"}
{"hadithnumber": "1615", "text": "ابو بکر بن عمر بن عبدالرحمان  ، بن عبداللہ بن عمر بن خطاب  رضی اللہ تعالیٰ عنہ  نے سعید بن یسار سے"}
{"hadithnumber": "1616", "text": "امام مالکؒ نے عبداللہ بن دینار سے اور انھوں نے حضرت ابن عمر  رضی اللہ تعالیٰ عنہ  سے روایت کی کہ انھ"}
{"hadithnumber": "1617", "text": "ابن ہاد نے عبداللہ بن دینا ر سے اور انھوں نے حضرت عبداللہ بن عمر  رضی اللہ تعالیٰ عنہ  سے روایت کی ک"}
{"hadithnumber": "1618", "text": "سالم بن عبداللہ نے اپنے والد ( عبداللہ بن عمر  رضی اللہ تعالیٰ عنہ  )  سے روایت کی  ، کہا : رسول الل"}
{"hadithnumber": "1619", "text": "حضرت عبداللہ بن عامر بن ربیعہ  رضی اللہ تعالیٰ عنہ  نے خبر دی کہ انھیں ان کے والد نے بتایا کہ انھوں"}
{"hadithnumber": "1620", "text": "ہمام نے کہا :  ہمیں انس بن سیرین نے حدیث بیان کی کہ جب حضرت انس بن مالک  رضی اللہ تعالیٰ عنہ  شام سے"}
{"hadithnumber": "1621", "text": "امام مالک ؒ نے نافع سے اور ا نھوں نے حضرت ابن عمر  رضی اللہ تعالیٰ عنہ  سے روایت کی کہ رسول اللہ  صل"}
{"hadithnumber": "1622", "text": "عبیداللہ سے روایت ہےکہا :  مجھے نافع نے خبردی کہ حضرت  عمر  رضی اللہ تعالیٰ عنہ  کو جب ( سفر کے لئے"}
{"hadithnumber": "1623", "text": "سفیان نے ( ابن شہاب )  زہری سے  ، انھوں نے سالم سے اور انھوں نے اپنے والد  ( ابن عمر  رضی اللہ تعالی"}
{"hadithnumber": "1624", "text": "یونس نے ابن شہاب سے روایت کی  ، کہا :  مجھےسالم بن عبداللہ نے خبر دی کہ ان کے والد نے کہا :  میں نے"}
{"hadithnumber": "1625", "text": "مفضل بن فضالہ نے عقیل سے  ، انھوں نے ابن شہاب سے اور انھوں نے حضرت انس بن مالک  رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "1626", "text": "لیس بن سعد نے عقیل بن خالد سے باقی ماندہ اسی  سند کے ساتھ روایت کی کہ ر سول اللہ  صلی اللہ علیہ وسلم"}
{"hadithnumber": "1627", "text": "جابر بن اسماعیل نے بھی عقیل بن خالد سے باقی ماندہ اسی سند کے ساتھ روایت کی کہ نبی اکرم  صلی اللہ علی"}
{"hadithnumber": "1628", "text": "امام مالک ؒ نے ابو زبیر سے  ، انھوں نے سعید بن جبیر سے اور انھوں نے حضرت ابن عباس  رضی اللہ تعالیٰ ع"}
{"hadithnumber": "1629", "text": "زہیر نے کہا : ہمیں ابو زبیر نے سعید بن جبیر سے حدیث سنائی ، انھوں نے حضرت ابن عباس  رضی اللہ تعالیٰ"}
{"hadithnumber": "1630", "text": "قزہ بن خالد نے کہا : ہمیں ابو زبیر نے حدیث بیا ن کی ، کہا : ہمیں سعید بن جبیر نے حدیث سنائی ، انھوں"}
{"hadithnumber": "1631", "text": "زہیر نے کہا : ہمیں ابو زبیر نے ابو طفیل عامر سے حدیث سنائی اور انھوں نے حضرت معاذ  رضی اللہ تعالیٰ ع"}
{"hadithnumber": "1632", "text": "قرہ بن خالد نے کہا : ہمیں ابو زبیر نے حدیث بیا ن کی ، کہا :  ہمیں عامر بن واثلہ  ابو طفیل نے حدیث بی"}
{"hadithnumber": "1633", "text": "ابو معاویہ اور وکیع دونوں نے اعمش سے روایت کی  ، انھوں نے حبیب بن ثابت سے انھوں نے سعید بن جبیر سے ا"}
{"hadithnumber": "1634", "text": "سفیان بن عینیہ نے عمرو بن دینار سے انھوں نے  ( ابوشعشاء )  جابر بن زید سے اور انھوں نے حضرت ابن عباس"}
{"hadithnumber": "1635", "text": "حماد بن زید نے عمرو بن دینار سے انھوں نے جابر بن زید سے اور انھوں نے حضرت ا بن عباس  رضی اللہ تعالیٰ"}
{"hadithnumber": "1636", "text": "زبیر بن خریت نے عبداللہ بن شفیق سے روایت کی انھوں نے کہا : ایک دن حضرت ابن عباس  رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "1637", "text": "عمران بن خدیرنے عبداللہ بن شقیق عقیلی سے روایت کی ، انھوں نے کہا : ایک شخص نے حضرت ابن عباس  رضی الل"}
{"hadithnumber": "1638", "text": "ابو معاویہ اور وکیع نے اعمش سے  ، انھوں نے عمارہ سے ، انھوں نے اسود سے اور انھوں نے حضرت عبداللہ  رض"}
{"hadithnumber": "1639", "text": "جریراور عیسیٰ بن یونس نے اسی سند کے ساتھ سابقہ حدیث کے مانند حدیث بیان کی ۔"}
{"hadithnumber": "1640", "text": "ابو عوانہ نے ( اسماعیل بن عبدالرحمان )  سدی سے روایت کہ  ، انھوں نے کہا :  میں نے حضرت انس  رضی اللہ"}
{"hadithnumber": "1641", "text": "سفیان بن عینیہ نے سدی سے اور انھوں نے حضرت انس  رضی اللہ تعالیٰ عنہ  سے روایت کی کہ نبی کریم صلی الل"}
{"hadithnumber": "1642", "text": "ا بن ابی زائدہ نے مسعر سے  ، انھوں نے ثابت بن عبید سے انھوں نے حضرت براء  رضی اللہ تعالیٰ عنہ  کے بی"}
{"hadithnumber": "1643", "text": "وکیع نے مسعر سے اسی سند کے ساتھ یہ حدیث بیان کی اور ا نھوں نےيُقْبِلُ عَلَيْنَا بِوَجْهِهِ  ( آپ  ہم"}
{"hadithnumber": "1644", "text": "شعبہ نے ورقاء سے انھوں نے عمرو بن دینار سے ، انھوں نے عطاء بن یسار سے ، انہوں نے حضرت ابو ہریرۃ  رضی"}
{"hadithnumber": "1645", "text": "( شعبہ کی بجائے )  شبابہ نے ورقاء سے یہی روایت اسی  سند کے ساتھ بیان کی ہے ۔"}
{"hadithnumber": "1646", "text": "روح نے کہا : ہمیں زکریا بن اسحاق نے حدیث سنائی ، انھوں نے کہا ، ہمیں عمرو بن دینار نے حدیث سنائی  ،"}
{"hadithnumber": "1647", "text": "( روح کی بجائے )  عبدالرزاق نے خبر دی کہ ہمیں زکریا بن اسحاق نے اسی سند کے ساتھ اسی  طرح خبر دی ۔"}
{"hadithnumber": "1649", "text": "عبداللہ بن مسلمہ قعنبی نے  ہمیں حدیث بیان کی  ، کہا ہمیں ابراہیم بن سعد نے اپنے والد سے حدیث سنائی ۔"}
{"hadithnumber": "1650", "text": "ابو عوانہ نے سعد بن ابراہیم سے ، انہوں نے حفص بن عاصم سے ، اورانہوں نے حضرت  ( عبداللہ )  ابن بحینہ"}
{"hadithnumber": "1651", "text": "حضرت عبداللہ بن سرجس ( المزنی حلیف بنی مخزوم  رضی اللہ تعالیٰ عنہ  )  سے روایت ہے ، انھوں نے کہا : ا"}
{"hadithnumber": "1652", "text": "یحییٰ بن یحییٰ نے کہا :   ہمیں سلمان بن بلال نے ربعیہ بن عبدالرحمان سے خبر دی ، انھوں نے عبدالملک بن"}
{"hadithnumber": "1653", "text": "( سلیمان بن بلال کے بجائے )  عمارہ بن غزیہ نے ربیعہ بن ابی عبدالرحمان سے روایت کی ، انھوں نے عبدالمل"}
{"hadithnumber": "1654", "text": "عامر بن عبداللہ بن زبیر نے عمرو بن سلیم زرقی سے اور انھوں نے حضرت  ابو قتادہ  رضی اللہ تعالیٰ عنہ  س"}
{"hadithnumber": "1655", "text": "محمد بن یحییٰ بن حبان نے عمرو بن سلیم بن خلدہ انصاری سے اور انھوں نے رسول اللہ  صلی اللہ علیہ وسلم"}
{"hadithnumber": "1656", "text": "سفیان بن محارب بن وثار سے اور انھوں نے حضرت جابر بن عبداللہ  رضی اللہ تعالیٰ عنہ  سے روایت کی ، انھو"}
{"hadithnumber": "1657", "text": "شعبہ نے محارب سے روایت کی  ، انھوں نے حضرت جابر بن عبداللہ  رضی اللہ تعالیٰ عنہ  سے سنا  ، کہہ رہے ت"}
{"hadithnumber": "1658", "text": "وہب بن کیسان نے حضرت جابر بن عبداللہ  رضی اللہ تعالیٰ عنہ  سے روایت کی  ، انھوں نے کہا :  میں ایک غز"}
{"hadithnumber": "1659", "text": "حضرت کعب بن مالک  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ رسول اللہ  صلی اللہ علیہ وسلم   دن میں چاشت کے"}
{"hadithnumber": "1660", "text": "سعید جزیری نے عبداللہ بن شقیق سے  روایت کی  ، انھوں نےکہا :  میں نے حضرت عائشہ  رضی اللہ تعالیٰ عنہا"}
{"hadithnumber": "1661", "text": "کیمس بن حسن قیسی نے عبداللہ بن شقیق سے روایت کی ، انھوں نے کہا : میں نے حضرت عائشہ  رضی اللہ تعالیٰ"}
{"hadithnumber": "1662", "text": "حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے روایت ہے  ، انھوں نے کہا : میں نے کبھی ر سول اللہ  صلی اللہ عل"}
{"hadithnumber": "1663", "text": "عبدالوارث نے کہا :  ہمیں یزید رشک نے حدیث سنائی ، انھوں نے کہا ، مجھے معاذہ نے حدیث سنائی ، انھوں نے"}
{"hadithnumber": "1664", "text": "شعبہ نے یزید سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی اور یزید نے ( ماشاء کے بجائے )  ماشاء اللہ"}
{"hadithnumber": "1665", "text": "سعید نے کہا : قتادہ نے ہمیں حدیث بیان کی کہ معاذہ عدویہ نے ان  ( حدیث سننے والوں )  کو حضرت عائشہ  ر"}
{"hadithnumber": "1666", "text": "معاذ بن ہشام نے روایت کی  ، کہا :  مجھے میرے والد نے قتادہ سے اسی سند کےساتھ یہی حدیث بیان کی ۔"}
{"hadithnumber": "1667", "text": "محمد بن مثنیٰ اور ابن بشار نے ہمیں حدیث بیان کی ، کہا : ہمیں محمد بن جعفر نے حدیث سنائی  ، کہا : ہمی"}
{"hadithnumber": "1668", "text": "حرملہ بن یحیٰٰ اور محمد بن سلمہ مرادی دونوں نے مجھے حدیث بیان کی   ، کہا : ہمیں عبداللہ بن وہب نے خب"}
{"hadithnumber": "1669", "text": "ابو نضر سے روایت ہے کہ ام ہانی بنت ابی طالب  رضی اللہ تعالیٰ عنہا   کو یہ کہتے ہوئے سنا کہ میں فتح م"}
{"hadithnumber": "1670", "text": "جعفر بن محمد ؒ کے والد محمد باقرؒ نے عقیل کے آزاد کردہ غلام ابو مرہ سے اور انھوں نے حضرت ام ہانی  رض"}
{"hadithnumber": "1671", "text": "حضرت ابو زر  رضی اللہ تعالیٰ عنہ  نے نبی کریم  صلی اللہ علیہ وسلم   سے روایت کی کہ آپ نے فرمایا :  "}
{"hadithnumber": "1672", "text": "ابو تیاح نے کہا : ہمیں ابو عثمان نہدی نے حضرت ابو ہریرۃ  رضی اللہ تعالیٰ عنہ  سے حدیث سنائی ، انھوں"}
{"hadithnumber": "1673", "text": "عباس ، جریری ، اور ابو شمرضبعی ، دونوں نے کہا : ہم نے ابو عثمان نہدی سے سنا ، وہ حضرت ابوہریرۃ  رضی"}
{"hadithnumber": "1674", "text": "ابو رافع الصائغ نے کہا : میں نے حضرت ابوہریرہ  رضی اللہ تعالیٰ عنہ  سے سنا ، انھوں نے کہا ، مجھے میر"}
{"hadithnumber": "1675", "text": "حضرت ابو درداء  رضی اللہ تعالیٰ عنہ  سے روایت ہے  ، انھوں نے کہا : میرےحبیب  صلی اللہ علیہ وسلم   نے"}
{"hadithnumber": "1676", "text": "امام مالک ؒ نے نافع سے اور انھوں نے حضرت  عبداللہ بن عمر  رضی اللہ تعالیٰ عنہ  سے روایت کی کہ ام الم"}
{"hadithnumber": "1677", "text": "لیث بن سعد ، عبیداللہ اور ایوب سب نے نافع سے اسی سند کے ساتھ اسی طرح روایت بیان کی ہے جس طرح امام ما"}
{"hadithnumber": "1678", "text": "محمد بن جعفر نے کہا : ہمیں شعبہ نے زید بن محمد سے حدیث سنائی ، انھوں نے کہا : میں نے نافع سے سنا ، و"}
{"hadithnumber": "1679", "text": "( محمد بن جعفر کی بجائے ) نضر نے ہمیں خبر دی  ، کہا : شعبہ نے اسی سند کے ساتھ اسی سابقہ حدیث کی مانن"}
{"hadithnumber": "1680", "text": "سالم نے اپنے والد ( عبداللہ بن عمر  رضی اللہ تعالیٰ عنہ  ) سے روایت کی ، انھوں نے کہا : حضرت حفصہ  ر"}
{"hadithnumber": "1681", "text": "عبدہ بن سلیمان نے کہا :  ہمیں ہشام بن عروہ نے اپنے والد کے حوالے سے حضرت عائشہ  رضی اللہ تعالیٰ عنہا"}
{"hadithnumber": "1682", "text": "علی بن مسہر ، ابو اسامہ ، عبداللہ بن نمیر ، اور وکیع سب نے ہشام سے اسی سند کے ساتھ یہی حدیث روایت کی"}
{"hadithnumber": "1683", "text": "ابو سلمہ نے حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے روایت کی کہ نبی اکرم  صلی اللہ علیہ وسلم   صبح کی"}
{"hadithnumber": "1684", "text": "یحییٰ بن سعید نے کہا : مجھے محمد بن عبدالرحمان نے بتایا کہ انھوں نے عمرہ کوحضرت  عائشہ   رضی اللہ تع"}
{"hadithnumber": "1685", "text": "شعبہ نے محمد بن عبدالرحمان انصاری سے روایت کی ۔ انھوں نے عمرہ بنت عبدالرحمان سے سنا ، انھوں نے حضرت"}
{"hadithnumber": "1686", "text": "یحییٰ بن سعید نے ابن جریج سے روایت کی ، انھوں نے کہا : مجھے عطاء بن عبید بن عمیر سے حدیث  سنائی اور"}
{"hadithnumber": "1687", "text": "حفص نے ابن جریج سے باقی ماندہ اسی سند کے ساتھ حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے روایت کی ، کہا :"}
{"hadithnumber": "1688", "text": "ابو عوانہ نے قتادہ سے  ، انھوں نے زرارہ بن اوفیٰ سے  ، انھوں نے سعد بن ہشام سے  ، انھوں نے حضرت عائش"}
{"hadithnumber": "1689", "text": "معتمر کے والد سلیمان بن طرخان نے قتادہ سے اسی سند کے ساتھ حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے اور"}
{"hadithnumber": "1690", "text": "حضرت ابو ہریرہ  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ رسول اللہ  صلی اللہ علیہ وسلم   نے فجر کی دو رکع"}
{"hadithnumber": "1691", "text": "مروان بن معاویہ فزاری نے عثمان بن حکیم انصاری سے حدیث بیان کی  ، انھوں نے کہا : مجھے سعید بن یسار  ن"}
{"hadithnumber": "1692", "text": "ابو خالد احمر نے عثمان بن حکیم سے  ،  انھوں نے سعید بن  یسار سے اور  انھوں نے حضرت ابن عباس  رضی الل"}
{"hadithnumber": "1693", "text": "عیسی بن یونس نے عثمان بن حکیم سے اسی سندکے ساتھ مروان فزاری کی حدیث کی طرح حدیث بیان کی ۔"}
{"hadithnumber": "1694", "text": "ابو خالد سلیمان بن حیان نے داود بن ابی سند سے حدیث بیان کی ، انہوں نے نعمان بن سالم سے اور انھوں نے"}
{"hadithnumber": "1695", "text": "بشر بن مفضل نے کہا : ہمیں داود نے نعمان بن سالم سے اسی سندکے ساتھ یہ حدیث بیان کی ،  \" جس نے ایک دن"}
{"hadithnumber": "1696", "text": "محمد بن جعفر نے کہا : ہمیں شعبہ نے نعمان بن سالم سے حدیث سنائی ، انھوں نے عمرو بن اوس  سے انھوں نے ع"}
{"hadithnumber": "1697", "text": "بہز نے شعبہ سے باقی ماندہ سابقہ سندکے ساتھ حضرت ام حبیبہ  رضی اللہ تعالیٰ عنہا   سے روایت کی کہ رسول"}
{"hadithnumber": "1698", "text": "حضرت ابن عمر سے  رضی اللہ تعالیٰ عنہ  سے روایت ہے  ، انھوں نے کہا :  میں نے رسول اللہ  صلی اللہ علیہ"}
{"hadithnumber": "1699", "text": "خالد نے عبداللہ بن شقیق سے روایت کی ، انھوں نے کہا ، میں نے حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے رس"}
{"hadithnumber": "1700", "text": "حماد نے بدیل اورایوب سے روایت کی  ، انھوں نے عبداللہ بن شقیق سے اور انھوں نے حضرت عائشہ  رضی اللہ تع"}
{"hadithnumber": "1701", "text": "شعبہ نے بدیل سے حدیث سنائی انھوں نے عبداللہ بن شقیق سے روایت کی ، انھوں نے کہا : میں فارس ( ایران )"}
{"hadithnumber": "1702", "text": "حمید نے عبداللہ بن شقیق سے روایت کی ، انھوں نے کہا :  میں نے حضرت عائشہ  رضی اللہ تعالیٰ عنہ  سے رسو"}
{"hadithnumber": "1703", "text": "محمد بن سیرین نے عبداللہ بن شقیق عقیلی سے روایت کی ، انھوں نے کہا : ہم لوگوں نے حضرت عائشہ  رضی اللہ"}
{"hadithnumber": "1704", "text": "ہشام بن عروہ سے روایت ہے  ، کہا : مجھے میرے والد نے حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے خبر دی ، ا"}
{"hadithnumber": "1705", "text": "ابو سلمہ بن عبدالرحمان نے حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے  روایت کی کہ رسول اللہ  صلی اللہ علی"}
{"hadithnumber": "1706", "text": "عمرہ نے حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے  روایت کی ، انھوں نے کہا : رسول اللہ  صلی اللہ علیہ وس"}
{"hadithnumber": "1707", "text": "علقمہ بن وقاص سے روایت ہے  ، انھوں نے کہا : میں نے حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے پوچھا : جب"}
{"hadithnumber": "1708", "text": "سعید بن جریری نے عبداللہ بن شقیق سے روایت کی ، انھوں نے کہا : میں نے حضرت عائشہ  رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "1709", "text": "کہمس نے عبداللہ بن شقیق سے  روایت کی ، انھوں نے کہا : میں نے حضرت عائشہ   رضی اللہ تعالیٰ عنہا   سے"}
{"hadithnumber": "1710", "text": "ابو سلمہ بن عبدالرحمان نے خبر دی کہ حضرت عائشہ  رضی اللہ تعالیٰ عنہا   نے انھیں بتایا کہ رسول اللہ"}
{"hadithnumber": "1711", "text": "عبداللہ بن عروہ کے والد عروہ بن زبیر نے حضرت عائشہ  رضی اللہ تعالیٰ عنہا  سے  روایت کی انھوں نے کہا"}
{"hadithnumber": "1712", "text": "۔  امام مالک نے ابن شہاب سے  ، انھوں نے سائب بن یزید سے  ، انھوں نے مطلب بن ابی وداعہ سہمی سے اور ان"}
{"hadithnumber": "1713", "text": "یونس اور معمر دونوں نے زہری سے اسی سند کے ساتھ اس کے مانند روایت کی ، البتہ ان دونوں ( یونس اور معمر"}
{"hadithnumber": "1714", "text": "حضرت جابربن سمرہ  رضی اللہ تعالیٰ عنہ  نے خبر دی کہ رسول اللہ صلی اللہ علیہ وسلم   کی وفات نہ ہوئی ی"}
{"hadithnumber": "1715", "text": "جریر نے مجھے حدیث سنائی ، انھوں نے منصور سے  ، انھوں نے ہلال بن یساف سے  ، انھوں نے ابو یحییٰ سے اور"}
{"hadithnumber": "1716", "text": "شعبہ اور سفیان دونوں نے منصور سے اسی سابقہ سند کے ساتھ حدیث بیان کی ، البتہ شعبہ کی روایت میں ہے :"}
{"hadithnumber": "1717", "text": "مالک نے ابن شہاب سے ، انھوں نے عروہ سے ، اور انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے روایت کی"}
{"hadithnumber": "1720", "text": "عبداللہ بن نمیر نے ہمیں حدیث بیان کی اور کہا : ہمیں اپنے ہشام نے اپنے والد ( عروہ )  سے حدیث  سنائی"}
{"hadithnumber": "1721", "text": "عبدہ بن سلیمان  ، وکیع اور ابو اسامہ سب نے ہشام سے اسی سند کے ساتھ  ( یہ )  روایت بیان کی ہے ۔"}
{"hadithnumber": "1722", "text": "عروہ بن مالک نے عروہ سے روایت کی کہ حضرت عائشہ  رضی اللہ تعالیٰ عنہا   نے انھیں بتایا کہ رسول اللہ"}
{"hadithnumber": "1723", "text": "سعید بن ابی سعید مقبری نے ابو سلمہ بن عبدالرحمان سے روایت کی کہ انھوں نے حضرت عائشہ  رضی اللہ تعالیٰ"}
{"hadithnumber": "1724", "text": "ہشام نے یحییٰ سے اور انھوں نے ابو سلمہ سے ر وایت کی ، انھوں نے کہا : میں نے حضرت عائشہ  رضی اللہ تعا"}
{"hadithnumber": "1725", "text": "شیبان اور معاویہ بن سلام نے یحییٰ بن ابی کثیر سے روایت کی ، انھوں نے کہا : مجھے ابو سلمہ نے بتایا کہ"}
{"hadithnumber": "1726", "text": "عبداللہ بن ابی لبید سے روایت ہے کہ انھوں نے ابو سلمہ سے سنا ، انھوں نے کہا : میں حضرت عائشہ  رضی الل"}
{"hadithnumber": "1727", "text": "قاسم بن محمد سے روایت ہے  ، انھوں نے کہا : میں نے حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے سنا ، فرمارہ"}
{"hadithnumber": "1728", "text": "ابو خثیمہ ( زہیر بن معاویہ )  نے ابو اسحاق سے خبر دی ، کہا :  میں نے اسود بن یزید سے اس حدیث کے بارے"}
{"hadithnumber": "1729", "text": "عمار بن زریق نے ابو اسحاق سے  ، انھوں نے اسود سے اور انھوں نے حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے"}
{"hadithnumber": "1730", "text": "مسروق نے کہا : میں نے حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے رسول اللہ  صلی اللہ علیہ وسلم   کے عمل ک"}
{"hadithnumber": "1731", "text": "ابو سلمہ نے حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے ر وایت کی ، انھوں نے کہا : سحر کے آخری حصے ( جب طل"}
{"hadithnumber": "1732", "text": "ابو نضر نے ابو سلمہ سے اور انھوں نے حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے روایت کی ، کہا : نبی اکرم"}
{"hadithnumber": "1733", "text": "ابن ابی عتاب نے ابو سلمہ سے ، انھوں نے حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے اور انھوں نے نبی اکرم"}
{"hadithnumber": "1734", "text": "عروہ بن زبیر نے حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے روایت کی ، انھوں نے کہا : رسول اللہ  صلی اللہ"}
{"hadithnumber": "1735", "text": "قاسم بن محمد نے حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے روایت  کی  کہ رسول اللہ  صلی اللہ علیہ وسلم"}
{"hadithnumber": "1736", "text": "مسلم ( بن صبیح )  نے مسروق سے اور انھوں نے حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے روایت کی ، انھوں نے"}
{"hadithnumber": "1737", "text": "یحییٰ بن وثاب نے مسروق سے اور انھوں نے حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے روایت کی ، انھوں نے کہا"}
{"hadithnumber": "1738", "text": "ابو ضحیٰ نے مسروق سے اور انھوں نے حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے روایت کی  ، انھوں نے کہا :"}
{"hadithnumber": "1739", "text": "ابن ابی عدی نے سعید ( ابن ابی عروبہ )  سے ، انھوں نے قتادہ  سے اور انھوں نے زرارہ سے روایت کی کہ  ("}
{"hadithnumber": "1740", "text": "۔  معاذ بن ہشام نے قتادہ سے انھوں نے زراہ بن اوفیٰ سے اور انھوں نے سعد بن ہشام سے  روایت کی کہ انھوں"}
{"hadithnumber": "1741", "text": "محمد بن بشر نے کہا : ہمیں سعید بن ابی عروبہ نے حدیث سنائی ، کہا :  ہم سے قتادہ نے حدیث بیا ن کی ، ان"}
{"hadithnumber": "1742", "text": "معمر نے قتادہ سے اور انھوں نے زراہ بن اوفیٰ سے  روایت کی کہ سعد بن ہشام ان کے پڑوسی تھے ، انھوں نے ا"}
{"hadithnumber": "1743", "text": "ابوعوانہ نے قتادہ سے  ، انھوں نے زراہ بن اوفیٰ سے ، انھوں نے سعد بن ہشام سے اور انھوں نے حضرت عائشہ"}
{"hadithnumber": "1744", "text": "شعبہ نے قتادہ سے اسی سند کے ساتھ حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے روایت کی ، انھوں نے کہا : رسو"}
{"hadithnumber": "1745", "text": "عبدالرحمان بن عبدالقاری سے روایت ہے ، کہا : میں نے عمر بن خطاب  رضی اللہ تعالیٰ عنہ  سے سنا  ، کہہ ر"}
{"hadithnumber": "1746", "text": "ایوب نے قاسم شیبانی سے روایت کی کہ حضرت زید بن ارقم  رضی اللہ تعالیٰ عنہ  نے کچھ لوگوں کو چاشت کے وق"}
{"hadithnumber": "1747", "text": "ہشام بن ابی عبداللہ نے کہا :  ہمیں قاسم شیبانی نے حضرت زید بن ارقم  رضی اللہ تعالیٰ عنہ  سے  حدیث بی"}
{"hadithnumber": "1748", "text": "نافع اور عبداللہ بن دینار نے حضرت ا بن عمر  رضی اللہ تعالیٰ عنہ  سے روایت کی کہ ایک آدمی نے رسول الل"}
{"hadithnumber": "1749", "text": "سفیان نے زہری سے  ، انھوں نے سالم سے اور انھوں نے اپنے والد  ( عبداللہ بن عمر  رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "1750", "text": "عمرو نے کہا ابن شہاب نے اس سے بیان کہ اسے سالم بن عبداللہ بن عمر اور حمید بن عبدالرحمان بن عوف دونوں"}
{"hadithnumber": "1751", "text": "ابو ربیع زہرانی نے کہا : ہمیں حماد نے حدیث سنائی کہا :  ہمیں ایوب اور بدیل نے عبداللہ بن شقیق سے حدی"}
{"hadithnumber": "1752", "text": "ابو کامل نے کہا : ہمیں حماد نے حدیث سنائی ، کہا : ہمیں ایوب ، بدیل اور عمران بن حدیر نے عبداللہ بن ش"}
{"hadithnumber": "1753", "text": "حضرت ابن عمر  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ نبی کریم  صلی اللہ علیہ وسلم   نے فرمایا :  \" وتر"}
{"hadithnumber": "1754", "text": "لیث نے نافع سے روایت کی کہ حضرت ابن عمر  رضی اللہ تعالیٰ عنہا   رضی اللہ تعالیٰ عنہ  نے کہا : جوشخص"}
{"hadithnumber": "1755", "text": "عبیداللہ نے نافع سے ، انھوں نے حضرت ابن عمر  رضی اللہ تعالیٰ عنہ  سے اور ا نھوں نے نبی اکرم  صلی الل"}
{"hadithnumber": "1756", "text": "ابن جریج نے کہا : مجھے نافع نے بتایا کہ حضرت ابن عمر  رضی اللہ تعالیٰ عنہ  کہاکرتے تھے : جو شخص ر ات"}
{"hadithnumber": "1757", "text": "ابو تیاح نے کہا : مجھے ابو مجلز نے حضرت ابن عمر  رضی اللہ تعالیٰ عنہ  سے حدیث سنائی ، انھوں نے کہا :"}
{"hadithnumber": "1758", "text": "شعبہ نے قتادہ سے ، انھوں نے مجلز سے روایت کی ، انھوں نے کہا : میں نے حضرت ابن عمر  رضی اللہ تعالیٰ ع"}
{"hadithnumber": "1759", "text": "ہمام نے کہا : ہمیں قتادہ نے ابو مجلز سے حدیث بیان کی ، انھوں نے کہا :  میں نےحضرت ابن  عباس   رضی ال"}
{"hadithnumber": "1760", "text": "ابو کریب اور ہارون بن عبداللہ نے کہا : ہمیں ابو اسامہ نے ولید بن کثیر سے حدیث سنائی ، انھوں نے کہا :"}
{"hadithnumber": "1761", "text": "خلف بن ہشام اور ابوکامل نے کہا :  ہمیں حماد بن زیدنے انس بن سیرن سے حدیث سنائی ، انھوں نے کہا میں نے"}
{"hadithnumber": "1762", "text": "شعبہ نے انس بن سیرین سے روایت کی ، انھوں نے کہا : میں نے حضرت ابن عمر  رضی اللہ تعالیٰ عنہ  سے پوچھا"}
{"hadithnumber": "1763", "text": "عقبہ بن حریث نے کہا : میں نے حضرت ابن عمر  رضی اللہ تعالیٰ عنہ  سے سنا ، وہ حدیث بیان کررہے تھے کہ ر"}
{"hadithnumber": "1764", "text": "معمرنے یحییٰ بن ابی کثیر سے  ، انھوں نے ابو نضرہ سے اور انھوں نے حضرت ابو سعید  رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "1765", "text": "شیبان نے یحییٰ  ( بن ابی کثیر )  سے روایت کی ، انھوں نے کہا : ابو نضرۃ عوقی نے مجھے بتایا کہ حضرت اب"}
{"hadithnumber": "1766", "text": "حفص اور ابو معاویہ نے اعمش سے حدیث سنائی ، انھوں نے ابو سفیان سے اور انھوں نے حضرت جابر  رضی اللہ تع"}
{"hadithnumber": "1767", "text": "ابو زبیر نے حضرت جابر  رضی اللہ تعالیٰ عنہ  سے روایت کی ، انھوں نے کہا :  میں نے نبی کریم  صلی اللہ"}
{"hadithnumber": "1768", "text": "ابو زبیر نے حضرت جابر  رضی اللہ تعالیٰ عنہ  سے ر وایت کی ،  انھوں نے کہا : رسول اللہ  صلی اللہ علیہ"}
{"hadithnumber": "1769", "text": "ابو بکر بن ابی شیبہ اور ابو کریب دونوں نے کہا : ہمیں ابو معاویہ نے حدیث بیان کی ، انھوں نے کہا : ہمی"}
{"hadithnumber": "1770", "text": "ابو سفیان سے روایت ہے  ، انھوں نے حضرت جابر  رضی اللہ تعالیٰ عنہ  سے روایت کی  ، انھوں نے کہا : میں"}
{"hadithnumber": "1771", "text": "ابو زبیر  رضی اللہ تعالیٰ عنہ  نے حضرت جابر  رضی اللہ تعالیٰ عنہ  سے روایت کی کہ رسول اللہ  صلی اللہ"}
{"hadithnumber": "1772", "text": "ابن شہاب نے ابو عبداللہ اغز اور ابو سلمہ بن عبدالرحمان سے ، انھوں نے حضرت ابو ہریرۃ  رضی اللہ تعالیٰ"}
{"hadithnumber": "1773", "text": "سہیل کے والد ابو صالح نے حضرت ابو ہریرۃ  رضی اللہ تعالیٰ عنہ  سے اور انھوں نے رسول اللہ  صلی اللہ عل"}
{"hadithnumber": "1774", "text": "ابو بن سلمہ عبدالرحمان نے حضرت ابو ہریرہ  رضی اللہ تعالیٰ عنہ  سے حدیث بیا ن کی ، انھوں نے کہا : رسو"}
{"hadithnumber": "1775", "text": "محاضر ابومورع نے کہا : ہم سے سعد بن سعید ( بن قیس انصاری )  نے حدیث بیان کی ، انھوں نے کہا : مجھے اب"}
{"hadithnumber": "1776", "text": "سلیمان بن بلال نے سعد بن سعید سے اسی سند کے ساتھ روایت کی اور اس میں یہ اضافہ ہے :  \"  پھراللہ تعالی"}
{"hadithnumber": "1777", "text": "منصور نے ابو اسحاق سے اور انھوں نے اغر ابو مسلم سے روایت کی ، وہ حضرت ابو سعید  اور حضرت ابو ہریرہ"}
{"hadithnumber": "1779", "text": "حمید بن عبدالرحمان نے حضرت ابو ہریرۃ  رضی اللہ تعالیٰ عنہ  سے روایت  کی کہ ر سول اللہ  صلی اللہ علیہ"}
{"hadithnumber": "1780", "text": "امام زہری نے ابو سلمہ ( بن عبدالرحمان )  سے اور انھوں نے ابو ہریرۃ  رضی اللہ تعالیٰ عنہ  سے روایت کی"}
{"hadithnumber": "1781", "text": "حییٰ بن ابی کثیر نے کہا : ہمیں سلمہ بن عبدالرحمان نے حدیث بیان کی ۔ کہ حضرت ابو ہریرہ  رضی اللہ تعال"}
{"hadithnumber": "1782", "text": "اعرج نے حضرت ابو ہریرہ  رضی اللہ تعالیٰ عنہ  سے اور ا نھوں نے نبی اکرم صلی اللہ علیہ وسلم   سے روایت"}
{"hadithnumber": "1783", "text": "امام مالکؒ نے ابن  شہاب سے روایت کی ، انھوں نے عروہ سے اور انھوں نے حضرت عائشہ  رضی اللہ تعالیٰ عنہا"}
{"hadithnumber": "1784", "text": "یونس بن یزید نے ابن شہاب سے خبر دی ، انھوں نے کہا : مجھے عروہ بن زبیر نے بتایا کہ حضرت عائشہ  رضی ال"}
{"hadithnumber": "1785", "text": "اوزاعی نے کہا : مجھ سے عبدہ ( بن ابی لبابہ )  نے زر  ( بن جیش )  سے حدیث بیان کی ، انھوں نے کہا : می"}
{"hadithnumber": "1786", "text": "محمد بن جعفر نے کہا : ہم سے شعبہ نے حدیث بیان کی ، انھوں نے کہا : میں نے عبدہ بن ابی لبابہ کو زرین"}
{"hadithnumber": "1787", "text": "۔  ( عبیداللہ کے والد )  معاذ نے کہا : ہم سے شعبہ نے اسی سند کے ساتھ سابقہ روایت کی مانند حدیث بیان"}
{"hadithnumber": "1788", "text": "سلمہ بن کہیل نے کریب سے اور انھوں نے حضرت ابن عباس  رضی اللہ تعالیٰ عنہ  سے روایت کی ، انھوں نے کہا"}
{"hadithnumber": "1789", "text": "امام مالک نے مخرمہ بن سلیمان سے اور انھوں نے ابن عباس  رضی اللہ تعالیٰ عنہ  کے مولیٰ کریب سے روایت ک"}
{"hadithnumber": "1790", "text": "عیاض بن عبداللہ فہری نے مخرمہ بن سلیمان سے اسی  سند کے ساتھ یہی روایت بیان کی اور یہ اضافہ کیا : پھر"}
{"hadithnumber": "1791", "text": "عمرو نے عبدربہ بن سعید سے ، انھوں نے مخرمہ بن سلیمان سے  ، انھوں نے ابن عباس  رضی اللہ تعالیٰ عنہ  ک"}
{"hadithnumber": "1792", "text": "ضحاک نے مخرمہ بن سلیمان سے ، انھوں نے کریب مولیٰ ابن عباس  رضی اللہ تعالیٰ عنہ  سے اور انھوں نے حضرت"}
{"hadithnumber": "1793", "text": "سفیان بن عمرو بن دینار سے ، انھوں نے کریب مولیٰ ابن عباس  رضی اللہ تعالیٰ عنہ  سے روایت کی کہ انھوں"}
{"hadithnumber": "1794", "text": "محمد بن جعفر ( غندر )  نے کہا : ہم سے شعبہ نے سلمہ سے حدیث بیان کی ، انھوں نے کریب سے اور ا نھوں نے"}
{"hadithnumber": "1795", "text": "نضر بن شمیل نے کہا :  ہمیں شعبہ نے خبر دی ، کہا : ہمیں سلمہ بن کبیل نے بکیر سے حدیث سنائی ، انھوں نے"}
{"hadithnumber": "1796", "text": "۔  سعید بن مسروق نے سلمہ بن کہیل سے  ، انھوں نے ابو رشدین  ( کریب )  مولیٰ ابن عباس  رضی اللہ تعالیٰ"}
{"hadithnumber": "1797", "text": "عقیل بن خالد سے روایت ہے کہ سلمہ بن کہیل نے ان ( عقیل )  سے حدیث بیان کی کہ کریب نے ان ( سلمہ )  سے"}
{"hadithnumber": "1798", "text": "شریک بن ابی نمر نے کریب سے اور انھوں نے حضرت ابن عباس رضی اللہ تعالیٰ عنہ  سے روایت کی ، انھوں نے کہ"}
{"hadithnumber": "1799", "text": "حبیب بن ابی ثابت نے محمد بن علی بن عبداللہ بن عباس  رضی اللہ تعالیٰ عنہ سے ، انھوں نے اپنے والد سے"}
{"hadithnumber": "1800", "text": "ابن جریج نے کہا ، مجھے عطاء نے حضرت ابن عباس  رضی اللہ تعالیٰ عنہ  سے خبر دی ، انھوں نے کہا : میں نے"}
{"hadithnumber": "1801", "text": "قیس بن سعد  ، عطاء سے حدیث بیان کرتے ہیں ، انھوں نے حضرت ابن عباس  رضی اللہ تعالیٰ عنہ سے روایت کی ،"}
{"hadithnumber": "1802", "text": "عبدالملک نے عطاء سے اور انھوں نے حضرت ابن عباس  رضی اللہ تعالیٰ عنہ  سے روایت کی انھوں نے کہا : میں"}
{"hadithnumber": "1803", "text": "ابو بکر بن ابی شیبہ ابن مثنیٰ ، اور ابن بشار نے غندر ، شعبہ اور ابوجمرہ کی سند سے حدیث بیان کی کہ حض"}
{"hadithnumber": "1804", "text": "حضرت زید بن خالد جہنی  رضی اللہ تعالیٰ عنہ سے روایت ہے ۔ کہ انھوں نے ( دل میں )  کہا : میں آج رات رس"}
{"hadithnumber": "1805", "text": "حضرت جابر بن عبداللہ  رضی اللہ تعالیٰ عنہ سے روایت ہے ، انھوں نے کہا : میں ایک سفر میں رسول اللہ  صل"}
{"hadithnumber": "1806", "text": "حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے روایت ہے  ، انھوں نے کہا : رسول اللہ  صلی اللہ علیہ وسلم   جب"}
{"hadithnumber": "1807", "text": "حضرت ابو ہریرۃ  رضی اللہ تعالیٰ عنہ  نے نبی اکرم  صلی اللہ علیہ وسلم   سے  روایت کی کہ آپ نے فرمایا"}
{"hadithnumber": "1808", "text": "امام مالک ؒ نے ابو زہیر سے  ، انھوں نے طاؤس سے اور انھوں نے حضرت ابن عباس  رضی اللہ تعالیٰ عنہ  سے ر"}
{"hadithnumber": "1809", "text": "سفیان اور ابن جریج دونوں نے سلیمان ا حول  سے ، انھوں نے طاؤس سے ، انھوں نے حضرت ابن عباس  رضی اللہ ت"}
{"hadithnumber": "1810", "text": "قیس بن سعد نے طاؤس سے ، انھوں نے ابن عباس  رضی اللہ تعالیٰ عنہ  سے اور انھوں نے نبی کریم صلی اللہ عل"}
{"hadithnumber": "1811", "text": "ابو سلمہ بن عبدالرحمان نے کہا : میں نے ام المومنین حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے پوچھا : نبی"}
{"hadithnumber": "1812", "text": "یوسف ماجثون نے کہا : مجھ سے میرے والد ( یعقوب بن ابی سلمہ ماجثون )  نے عبدالرحمان اعرج سے حدیث بیان"}
{"hadithnumber": "1813", "text": "عبدالعزیز بن عبداللہ بن ابی سلمہ نے اپنے چچا الماجثون ( یعقوب )  بن  ابی سلمہ سے اور انھوں نے  ( عبد"}
{"hadithnumber": "1814", "text": "عبداللہ بن نمیر ، ابو معاویہ اور جریر سب نے اعمش سے ، انھوں نے سعد بن عبیدہ سے ، انھوں نے مستورد بن"}
{"hadithnumber": "1815", "text": "جریر نے اعمش سے اور انھوں نے ابووائل سے روایت کی ۔ انھوں نے کہا :  حضرت عبد اللہ  بن مسعود رضی اللہ"}
{"hadithnumber": "1816", "text": "علی بن مسہر نے اعمش سے اسی سند کے ساتھ اسی کے مانند روایت کی ۔"}
