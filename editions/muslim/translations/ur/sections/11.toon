{"hadithnumber": "2123", "text": "بشر بن مفضل نے کہا : ہمیں عمارہ بن غزیہ نے یحییٰ بن عمارہ سے حدیث بیان کی ، انھوں نے کہا : میں نے حض"}
{"hadithnumber": "2124", "text": "عبدالعزیز دراوردی اور سلیمان بن بلال نے اسی ( مذکورہ بالا )  سند سے ( یہی )  حدیث بیان کی ۔"}
{"hadithnumber": "2125", "text": "حضرت ابو ہریرۃ  رضی اللہ تعالیٰ عنہ  سے روایت ہے ، انھوں نے کہا : رسول اللہ  صلی اللہ علیہ وسلم  نےف"}
{"hadithnumber": "2126", "text": "اسماعیل بن جعفر نےکہا : مجھے سعد بن سعید نے عمر بن کثیر بن افلح سے خبر دی ، انھوں نے ( عمر )  ابن سف"}
{"hadithnumber": "2127", "text": "ابو اسامہ نے سعد بن سعید سے روایت کی ، انھوں نے کہا : مجھے عمر بن کثیر بن افلح نے خبر دی ، انھوں نے"}
{"hadithnumber": "2128", "text": "عبداللہ بن نمیر نے کہا : ہمیں سعد بن سعید نے حدیث سنائی ، انھوں نے کہا : مجھے عمر بن کثیر نے حضرت ام"}
{"hadithnumber": "2129", "text": "حضرت ام سلمہ  رضی اللہ تعالیٰ عنہا   سے روایت ہے ، انھوں نے کہا : رسول اللہ  صلی اللہ علیہ وسلم نے ف"}
{"hadithnumber": "2130", "text": "ابو اسحاق فزاری نے خالد حذا سے  ، انھوں نے ابو قلابہ سے  ، انھوں نے قبیصہ بن ذویب سے اور انھوں نے حض"}
{"hadithnumber": "2131", "text": "عبیداللہ بن حسن نے کہا : ہمیں خالد حذاء نے اسی  ( مذکورہ بالا ) سند کے ساتھ اس ( سابقہ حدیث )  کے ہم"}
{"hadithnumber": "2132", "text": "ابن جریج نے علاء بن یعقوب سے روایت کی ، انھوں نے کہا : مجھے میرے والد نے خبر دی کہ انھوں نے حضرت ابو"}
{"hadithnumber": "2133", "text": "عبدالعزیز دراوردی نے  ( بھی )  علاء سے اسی سند کے ساتھ ( سابقہ حدیث کے مانند )  روایت بیان کی ۔"}
{"hadithnumber": "2134", "text": "حضرت ام سلمہ   رضی اللہ تعالیٰ عنہا   نے فرمایا : جب ابو سلمہ  رضی اللہ تعالیٰ عنہ  فوت ہوئے ، میں ن"}
{"hadithnumber": "2135", "text": "حماد بن زید نے عاصم احول سے ، انھوں نے ابو عثمان نہدی سے اور انہوں نے اسامہ بن زید  رضی اللہ تعالیٰ"}
{"hadithnumber": "2136", "text": "ابن فضیل اور ابو معاویہ ہر ایک نے عاصم احول سے اسی سند کے ساتھ ( سابقہ حدیث کی مانند )   حدیث بیان ک"}
{"hadithnumber": "2137", "text": "حضرت  عبداللہ بن عمر  رضی اللہ تعالیٰ عنہ  سے روایت ہے ، انھوں نے کہا : حضرت سعد بن عبادہ  رضی اللہ"}
{"hadithnumber": "2138", "text": "حضرت عبداللہ بن عمر  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ انھوں نے کہا : ہم رسول اللہ  صلی اللہ علیہ"}
{"hadithnumber": "2139", "text": "محمد یعنی جعفر ( الصادق )  کے فرزند نے حدیث بیان کی  ، کہا : ہمیں شعبہ نے ثابت سے حدیث سنائی ، انھوں"}
{"hadithnumber": "2140", "text": "عثمان بن عمر نے کہا : ہمیں شعبہ نے ثابت بنانی کے حوالےسے حضرت انس رضی اللہ تعالیٰ عنہ  سے روایت بیان"}
{"hadithnumber": "2141", "text": "خالد بن حارث ، عبدالملک بن عمرو ، اور عبدالصمد سب نے کہا : ہمیں شعبہ نے اسی سند کے ساتھ عثمان بن عمر"}
{"hadithnumber": "2142", "text": "نافع نے حضرت عبد اللہ  ( بن عمر )  رضی اللہ تعالیٰ عنہ سے روایت کی  ، کہ حضرت حفصہ  رضی اللہ تعالیٰ"}
{"hadithnumber": "2143", "text": "شعبہ نے کہا :  میں نے قتادہ کو سعید بن مسیب سے حدیث بیان کرتے ہو ئے سنا  ،  انھوں نے حضرت ابن عمر رض"}
{"hadithnumber": "2144", "text": "سعید  ( بن ابی عروبہ  ) نے قتادہ سے انھوں نے سعید بن مسیب سے انھوں نے حضرت ابن عمر رضی اللہ تعالیٰ ع"}
{"hadithnumber": "2145", "text": "ابو صالح نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے روا یت کی ، انھوں نے کہا :  جب حضرت عمر رضی اللہ تع"}
{"hadithnumber": "2146", "text": "۔  ( ابو اسحاق  ) شیبانی نے ابو بردہ سے اور انھوں نے اپنے والد  ( حضرت ابو موسیٰ اشعری رضی اللہ تعال"}
{"hadithnumber": "2147", "text": "عبد الملک بن عمیر نے ابو بردہ بن ابی موسیٰ سے اور انھوں نے  ( اپنے والد  )  حضرت ابو موسیٰ  رضی اللہ"}
{"hadithnumber": "2148", "text": "حضرت انس  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ جب حضرت عمر رضی اللہ تعالیٰ عنہ  کو زخمی کر دیا گیا تو"}
{"hadithnumber": "2151", "text": "عمرو  ( بن دینا ر  ) نے ابن ابی ملیکہ سے روا یت کی ،  انھوں نے کہا :  ہم حضرت عثمان رضی اللہ تعالیٰ"}
{"hadithnumber": "2152", "text": "سالم نے حضرت عبد اللہ بن عمر رضی اللہ تعالیٰ عنہ  سے روایت کی کہ رسول اللہ  صلی اللہ علیہ وسلم  نے ف"}
{"hadithnumber": "2153", "text": "حماد بن زید نے ہشام بن عروہ سے انھوں نے اپنے والد سے روا یت کی انھوں نے کہا :  حضرت عائشہ رضی اللہ ت"}
{"hadithnumber": "2154", "text": "ابو اسامہ نے ہشام سے اور انھوں نے اپنے والد  ( عروہ )  سے روایت کی انھوں نے کہا :  حضرت عائشہ رضی ال"}
{"hadithnumber": "2155", "text": "وکیع نے بیان کیا کہ ہمیں ہشام بن عروہ نے اسی سند سے ابو اسامہ کی حدیث کے ہم معنی حدیث سنا ئی اور ابو"}
{"hadithnumber": "2156", "text": "عمرہ بنت عبد الرحمٰن نے خبردی کہ انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے سنا  ( اس موقع پر )"}
{"hadithnumber": "2157", "text": "وکیع نے سعید بن عبید طائی اور محمد بن قیس سے اور انھوں نے علی بن ربیعہ سے روایت کی  ، انھوں  نے کہا"}
{"hadithnumber": "2158", "text": "ہمیں علی بن مسہر نے حدیث بیان کی ،  ( کہا )  ہمیں محمد بن قیس نے علی بن ربیعہ سے خبر دی انھوں نے حضر"}
{"hadithnumber": "2159", "text": "مروان بن معاویہ فزاری نے کہا :  ہمیں سعید بن عبید طا ئی نے علی بن ربیعہ سے حدیث سنا ئی انھوں نے حضرت"}
{"hadithnumber": "2160", "text": "حضرت ابو مالک اشعری رضی اللہ تعالیٰ عنہ  نے بیان کیا کہ رسول اللہ  صلی اللہ علیہ وسلم  نے فر ما یا"}
{"hadithnumber": "2161", "text": "‏عبد الوہاب نے کہا :  میں نے یحییٰ بن سعید سے سنا وہ کہہ رہے تھے مجھے عمرہ نے بتا یا کہ انھوں نے حضر"}
{"hadithnumber": "2162", "text": "عبد اللہ بن نمیر ، معاویہ بن صالح اور عبد العزیز بن مسلم نے یحییٰ بن سعید سے اس سند کے ساتھ اسی طرح"}
{"hadithnumber": "2163", "text": "محمد  ( بن سیرین  )  نے حضرت ام عطیہ  رضی اللہ تعالیٰ عنہ  سے روایت کی انھوں نے کہا :  رسول اللہ  صل"}
{"hadithnumber": "2164", "text": "ہشام نے حفصہ سے اور انھوں نے حضرت عطیہ رضی اللہ تعالیٰ عنہا   سے روایت کی ، انھوں نے کہا :  رسول الل"}
{"hadithnumber": "2165", "text": "عاصم نے حفصہ سے اور انھوں نے حضرت اُم عطیہ رضی اللہ تعالیٰ عنہا   سے روایت کی ،  انھوں نے کہا :  جب"}
{"hadithnumber": "2166", "text": "محمد بن سیرین نے کہا :  حضرت ام عطیہ رضی اللہ تعالیٰ عنہا   نے فر ما یا ہمیں جنازوں کے ساتھ جا نے سے"}
{"hadithnumber": "2167", "text": "حفصہ نے حجرت ام عطیہ رضی اللہ تعالیٰ عنہا   سے روا یت کی ،  انھوں نے کہا :  ہمیں جنازوں کے ساتھ جا ن"}
{"hadithnumber": "2168", "text": "یزید بن زریع نے ایوب سے انھوں نے محمد بن سیرین سے اور انھوں نے حضرت ام عطیہ  رضی اللہ تعالیٰ عنہا"}
{"hadithnumber": "2169", "text": "حفصہ بنت سیرین نے حضرت ام عطیہ  رضی اللہ تعالیٰ عنہا   سے روایت کی ،  انھوں نے کہا :  ہم نے ان  ( کے"}
{"hadithnumber": "2170", "text": "مالک بن انس  ، حماد اور ابن علیہ نے ایوب سے انھوں نے محمد سے اور انھوں نے حضرت ام عطیہ رضی اللہ تعال"}
{"hadithnumber": "2171", "text": "۔  حماد نے ایوب سے  ، انھوں نے حفصہ سے اور انھوں نے حجرت ام عطیہ  رضی اللہ تعالیٰ عنہا   سے اس  ( سا"}
{"hadithnumber": "2172", "text": "( اسماعیل  ) ابن علیہ نے کہا :  ہمیں ایوب نے خبر دی  ، انھوں نے کہا :  حفصہ نے حضرت ام عطیہ  رضی الل"}
{"hadithnumber": "2173", "text": "عاصم احول نے حفصہ بنت سیرین سے اور انھوں نے حضرت ام عطیہ  رضی اللہ تعالیٰ عنہا   سے روایت کی انھوں ن"}
{"hadithnumber": "2174", "text": "ہشا م بن حسان نے حفصہ بنت سیرین سے اور انھوں نے حضرت ام عطیہ رضی اللہ تعالیٰ عنہا   سے روایت کی ،  ا"}
{"hadithnumber": "2175", "text": "ہشیم نے خالد سے خبردی انھوں نے حفصہ بنت سیرین سے اور انھوں نے حضرت ام عطیہ  رضی اللہ تعالیٰ عنہا   س"}
{"hadithnumber": "2176", "text": "اسماعیل ابن علیہ نے خالد سے انھوں نے حفصہ سے اور انھوں نے حضرت ام عطیہ رضی اللہ تعالیٰ عنہا   سے روا"}
{"hadithnumber": "2177", "text": "ابو معاویہ نے اعمش سے انھوں نے شقیق سے اور انھوں نے حضرت خباب بن ارت  رضی اللہ تعالیٰ عنہ  سے روایت"}
{"hadithnumber": "2178", "text": "جریر عیسیٰ بن یو نس علی بن مسہر اور ابن عیینہ نے اعمش سے اسی سند کے ساتھ اسی طرح حدیث بیان کی  ۔"}
{"hadithnumber": "2179", "text": "ابو معاویہ نے ہشام بن عروہ سے انھوں نے اپنے والد  ( عروہ )  سے انھوں نے حضرت عائشہ رضی اللہ تعالیٰ ع"}
{"hadithnumber": "2180", "text": "علی بن مسہر نے کہا :  ہمیں ہشام بن عروہ نے اپنے والد  ( عروہ  )  سے حدیث سنا ئی انھوں نے کہا :  رسول"}
{"hadithnumber": "2181", "text": "حفص بن غیاث ،  ابن عیینہ  ، ابن ادریس  ، عبدہ  ، وکیع اور عبد العزیز سب نے ہشام سے اسی سند کے ساتھ ر"}
{"hadithnumber": "2182", "text": "ابو سلمہ  ( عبد اللہ بن عبد الرحمان بن عوف  رضی اللہ تعالیٰ عنہ  )  سے روایت ہے کہ انھوں نے کہا  :"}
{"hadithnumber": "2183", "text": "صالح  ( بن کیسان  )  نے ابن شہاب  ( زہری سے روایت کی  ، انھیں ابو سلمہ بن عبد الرحمان نے خبردی کہ ام"}
{"hadithnumber": "2184", "text": "معمر اور شہاب نے  (  ابن شہاب  )  زہری سے اسی سند کے ساتھ بالکل اسی طرح حدیث روایت کی ۔"}
{"hadithnumber": "2185", "text": "حضرت جا بر بن عبد اللہ  رضی اللہ تعالیٰ عنہ  بیان کر تے ہیں کہ ایک دن نبی اکرم  صلی اللہ علیہ وسلم"}
{"hadithnumber": "2186", "text": "سفیان بن عیینہ نے زہری سے انھوں نے سعید  ( بن مسیب  ) سے انھوں نے حضرت ابو ہریرہ  رضی اللہ تعالیٰ عن"}
{"hadithnumber": "2187", "text": "معمر اور محمد بن ابی حفصہ دو نوں نے زہری سے ،  انھوں نے سعید  ( بن مسیب )  سے ،  انھوں نے حضرت ابو ہ"}
{"hadithnumber": "2188", "text": "ابو امامہ بن سہل بن حنیف نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روا یت کی انھوں نے کہا :  میں نے"}
{"hadithnumber": "2189", "text": "ابو طا ہر حرملہ یحییٰ اور ہارون بن سعید ایلی  ۔  ۔  ۔ اس روایت کے الفا ظ ہارون اور حرملہ کے ہیں  ۔"}
{"hadithnumber": "2190", "text": "عبد الاعلیٰ اور عبد الررزاق نے معمر سے انھوںے زہری سے ،  انھوں نے سعید بن مسیب سے انھوں نے حضرت ابو"}
{"hadithnumber": "2191", "text": "‏عقیل بن خالد نے ابن شہاب سے روایت کی کہ انھوں نے کہا :  مجھے کئی لو گوں نے حضرت ابو ہریرہ رضی اللہ"}
{"hadithnumber": "2192", "text": "سہیل کے والد ابو صالح نے حضرت ابو ہریرہ  رضی اللہ تعالیٰ عنہ  سے اور انھوں نے نبی اکرم  صلی اللہ علی"}
{"hadithnumber": "2193", "text": "ابو حازم نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے اور انھوںنے نبی  صلی اللہ علیہ وسلم  سے روایت کی"}
{"hadithnumber": "2194", "text": "نا فع نے کہا :  حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے کہا گیا کہ ابو ہریرہ رضی اللہ تعالیٰ عنہ  کہتے"}
{"hadithnumber": "2195", "text": "داودبن عامر بن سعد بن ابی وقاص نے اپنے والد (  عامر  )  سے حدیث بیان کی کہ وہ حضرت عبد اللہ بن عمر ر"}
{"hadithnumber": "2196", "text": "شعبہ نے کہا  : ہمیں قتادہ نے سالم بن ابی جعد سے حدیث سنا ئی انھوں نے معدان ابن ابی طلحہ یعمری سے اور"}
{"hadithnumber": "2197", "text": "ہشام سعید اور ابان نے قتادہ سے اسی سند کے ساتھ سابقہ حدیث کے مانند روایت کی سعید اور ہشام کی حدیث می"}
{"hadithnumber": "2198", "text": "اسلام بن ابی مطیع نے ایوب سے انھوں نے ابو قلابہ سے انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عنہا   کے دود"}
{"hadithnumber": "2199", "text": "ہارون بن معروف ہارون بن سعید ایلی اور ولید بن شجاع میں سے ولید نے کہا :  مجھے حدیث سنا ئی اور دوسرے"}
{"hadithnumber": "2200", "text": "عبد العزیز بن صہیب نے حضرت انس بن مالک  رضی اللہ تعالیٰ عنہ  سے روایت کی ، انھوں نے کہا : ایک جنازہ"}
{"hadithnumber": "2201", "text": "ثابت نے حضرت انس  رضی اللہ تعالیٰ عنہ  سے روایت کی انھوں نے کہا :  نبی اکرم  صلی اللہ علیہ وسلم  کے"}
{"hadithnumber": "2202", "text": "امام مالک بن انس نے محمد بن عمرو بن حلحلہ سے  ، انھوں نے معبد بن کعب بن مالک سے اور انھوں نے حضرت قت"}
{"hadithnumber": "2203", "text": "یحییٰ بن سعید اور عبد الرزاق نے عبد اللہ بن سعید سے انھوں نے محمد بن عمرو سے انھوں نے کعب بن مالک کے"}
{"hadithnumber": "2204", "text": "امام مالکؒ نے ابن شہاب سے ، انھوں نے سعید بن مسیب سے اور انھوں نے حضرت ابو ہریرۃ  رضی اللہ تعالیٰ عن"}
{"hadithnumber": "2205", "text": "عقیل بن خالد نے ابن شہاب سے  ، انھوں نے سعید بن مسیب اور ابو سلمہ بن عبدالرحمان سے اور ان دونوں نے ح"}
{"hadithnumber": "2206", "text": "صالح نے دونوں سندوں کے ساتھ ابن شہاب سے عقیل  ( بن خالد )  کی روایت کے مانند روایت کی ۔"}
{"hadithnumber": "2207", "text": "سعید بن میناء نے حضرت جابر بن عبداللہ  رضی اللہ تعالیٰ عنہ  سے روایت کی کہ  رسول اللہ  صلی اللہ علیہ"}
{"hadithnumber": "2208", "text": "عطاء نے حضرت جابر بن عبداللہ  رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا : رسول اللہ  صلی اللہ علیہ وسلم"}
{"hadithnumber": "2209", "text": "ابو زبیر نے حضرت جابر بن عبداللہ  رضی اللہ تعالیٰ عنہ  سے روایت کی ، انھوں نے کہا : رسول اللہ  صلی ا"}
{"hadithnumber": "2210", "text": "زہیر بن حرب ، علی بن حجر ، اور یحییٰ بن ایوب نے کہا : ہمیں اسماعیل ابن علیہ نے ایوب سے حدیث سنائی ،"}
{"hadithnumber": "2211", "text": "حسن بن ربیع اور محمد بن عبداللہ بن نمیر نے کہا : ہمیں عبداللہ بن ادریس نے شیبانی سے حدیث سنائی ،  ان"}
{"hadithnumber": "2212", "text": "ہشیم ، عبدالواحد بن زیاد ، جریر ، سفیان ، معاذ بن معاذ اور شعبہ سب نے شیبانی سے  ، انھوں نے شعبی سے"}
{"hadithnumber": "2213", "text": "اسماعیل بن ابی خالد اور ابوحصین نے شعبی سے ، انھوں نے حضرت ابن عباس رضی اللہ تعالیٰ عنہ  سے اور انھو"}
{"hadithnumber": "2214", "text": "حضرت انس  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ نبی کریم  صلی اللہ علیہ وسلم  نے ایک قبر پر نماز جنازہ"}
{"hadithnumber": "2215", "text": "حضرت ابو ہریرۃ  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ ایک سیاہ فام عورت مسجد میں جھاڑو دیا کرتی تھی ۔"}
{"hadithnumber": "2216", "text": "۔  عبدالرحمان بن ابی لیلیٰ نے کہا : زید  رضی اللہ تعالیٰ عنہ  ( بن ارقم )  ہمارے جنازوں پر چار تکبیر"}
{"hadithnumber": "2217", "text": "سفیان نے زہری سے حدیث بیان کی  ، انھوں نے  سالم سے ، انھوں نے اپنے والد ( حضرت عبداللہ بن عمر  رضی ا"}
{"hadithnumber": "2218", "text": "لیث اور یونس نے ابن شہاب سے اسی سند کے ساتھ روایت بیان کی ہے اور یونس کی حدیث میں ہے کہ انھوں ( عامر"}
{"hadithnumber": "2219", "text": "ایوب ، عبیداللہ ، ابن عون اور ابن جریج سب نے نافع سے اسی سند کے ساتھ لیث بن سعد کی حدیث کے ہم معنی ح"}
{"hadithnumber": "2220", "text": "ابو صالح  نے ابو سعید خدری  رضی اللہ تعالیٰ عنہ  سے روایت کی ، انھوں نے کہا : رسول اللہ  صلی اللہ عل"}
{"hadithnumber": "2221", "text": "ابو سلمہ بن عبدالرحمان نے حضرت ابو سعید خدری  رضی اللہ تعالیٰ عنہ  سے روایت کی کہ رسول اللہ  صلی الل"}
{"hadithnumber": "2222", "text": "عبیداللہ بن مقسم نے حضرت جابر بن عبداللہ  رضی اللہ تعالیٰ عنہ  سے روایت کی ، انھوں نے کہا : ایک جناز"}
{"hadithnumber": "2223", "text": "محمد بن  رافع نےکہا : ہمیں عبدالرزاق نے حدیث سنائی ، کہا : مجھے ابو زبیر نے خبر دی کہ انھوں نے حضر ت"}
{"hadithnumber": "2224", "text": "ابن جریج سے روایت ہے ‘ انہوں نے کہا : مجھے ابو زبیر نےیہ خبر دی کہ انھوں نے حضر ت جابر رضی اللہ تعال"}
{"hadithnumber": "2226", "text": "اعمش نے عمرو بن مرہ سے اسی سند کے ساتھ روایت کی اور اس میں ہے : ان دونوں نے کہا : ہم ر سول اللہ  صلی"}
{"hadithnumber": "2227", "text": "لیث نے یحییٰ بن سعید سے اور انھوں نے واقد بن عمرو بن سعد بن معاذ سے روایت کی ، انھوں نے کہا : نافع ب"}
{"hadithnumber": "2228", "text": "( عبد الوھاب ) نےکہا میں نےیحیٰ بن سعید سے سنا ‘ کہا : مجھے واقد بن عمروبن سعدبن معاذ انصاری نے خبر"}
{"hadithnumber": "2229", "text": "ابن ابی زائدہ نے یحییٰ بن سعید سے اسی سند کے ساتھ یہی روایت بیا ن کی ۔"}
{"hadithnumber": "2230", "text": "عبدالرحمان بن مہدی نے کہا : ہمیں شعبہ نے محمد بن منکدر سے حدیث سنائی ، کہا : میں نے مسعود بن حکم سے"}
{"hadithnumber": "2231", "text": "یحییٰ قطان نے شعبہ سے اسی سند کے ساتھ  ( یہی )  حدیث بیان کی ۔"}
{"hadithnumber": "2233", "text": "عبدالرحمان بن مہدی نے کہا : ہمیں معاویہ بن صالح نے دونوں میں سے ہر ایک سند کےساتھ ابن وہب کی حدیث کی"}
{"hadithnumber": "2234", "text": "عبدالرحمان بن جبیر بن نفیر نے اپنے والد سے اور انھوں نے حضرت عوف بن مالک اشجعی  رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "2235", "text": "عبدالوارث بن سعیدنے حسین بن ذکوان سے خبردی ، انھوں نے کہا : مجھے عبداللہ بن بریدہ نے حضرت سمرہ بن جن"}
{"hadithnumber": "2236", "text": "ابن مبارک ، یزید بن ہارون اور فضل  بن موسیٰ سب نے حسین سے اسی ( سابقہ )  سند کے ساتھ روایت بیان کی ا"}
{"hadithnumber": "2237", "text": "محمد بن مثنیٰ اور عقبہ بن مکرم عمی نے کہا : ہمیں ابن ابی عدی نے حسین ( بن ذکوان )  سے حدیث بیان کی ا"}
{"hadithnumber": "2238", "text": "مالک بن مغول سے نے سماک بن حرب سے اور انھوں نے جابر بن سمرۃ  رضی اللہ تعالیٰ عنہ  سے روایت کی ، انھو"}
{"hadithnumber": "2239", "text": "شعبہ نے سماک بن حرب سے اور انھوں نے جابر بن سمرہ  رضی اللہ تعالیٰ عنہ  سے روایت کی ، انھوں نے کہا :"}
{"hadithnumber": "2240", "text": "عامر بن سعد بن ابی وقاص سے روایت ہے کہ حضرت سعد بن ابی وقاص رضی اللہ تعالیٰ عنہ  نے اپنی اس بیماری ک"}
{"hadithnumber": "2241", "text": "ابو جمرہ نے حضرت ابن عباس  رضی اللہ تعالیٰ عنہ  سے روایت کی ، انھوں نے کہا : رسول اللہ  صلی اللہ علی"}
{"hadithnumber": "2242", "text": "اثامہ بن شفی نے بیان کیا ، کہا : ہم سرزمین روم کے جزیرہ رودس  ( Rhodes ) میں فضالہ بن عبید ( اوسی ان"}
{"hadithnumber": "2244", "text": "یحییٰ القطان نے کہا : ہمیں سفیان نے حبیب سے اسی سند کے ساتھ ( سابقہ حدیث کے مانند )  حدیث بیان کی او"}
{"hadithnumber": "2245", "text": "حفص بن غیاث نے ابن جریج سے ، انھوں نے ابو زبیر سے اور انھوں نے حضرت جابر  رضی اللہ تعالیٰ عنہ  سے رو"}
{"hadithnumber": "2246", "text": "حجاج بن محمد اور عبدالرزاق نے ابن جریج سے روایت کی ، کہا : مجھے ابو زبیر نے خبر دی کہ انھوں نے حضرت"}
{"hadithnumber": "2247", "text": "ایوب نے ابو زبیر سے اور انھوں نے حضرت جابر  رضی اللہ تعالیٰ عنہ  سے روایت کی ، انھوں نے کہا : قبروں"}
{"hadithnumber": "2248", "text": "جریری نے سہیل سے ، انہوں نے اپنے والد ( ابوصالح )  سے اور انھوں نے ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے"}
{"hadithnumber": "2249", "text": "عبدالعزیز اور سفیان دونوں نے سہیل سے اسی سند کے ساتھ اسی طرح روایت بیا ن کی ۔"}
{"hadithnumber": "2250", "text": "بسر بن عبیداللہ نے حضرت و اثلہ (  بن اسقع بن کعب رضی اللہ تعالیٰ عنہ  )  سے اور انھوں نے حضرت ابو مر"}
{"hadithnumber": "2251", "text": "ابو ادریس خولانی نے حضرت و اثلہ بن اسقع رضی اللہ تعالیٰ عنہ  سے اور انھوں نے اور حضرت ابو مرثد  غنوی"}
{"hadithnumber": "2252", "text": "عبدالعزیز بن محمد نے عبدالواحد بن حمزہ سے اور انھوں نے عباد بن عبداللہ بن زبیر سے روایت کی کہ حضرت ع"}
{"hadithnumber": "2253", "text": "موسیٰ بن عقبہ نے عبدالواحد سے اور انھوں نے عباد بن عبداللہ بن زبیر سے روایت کی ، وہ حضرت عائشہ  رضی"}
{"hadithnumber": "2254", "text": "حضرت ابوسلمہ بن عبدالرحمان سے روایت ہے کہ جب حضر ت سعد بن ابی وقاص  رضی اللہ تعالیٰ عنہ  کی وفات ہوئ"}
{"hadithnumber": "2255", "text": "یحییٰ بن یحییٰ  تمیمی ، یحییٰ بن ایوب اور قتیبہ بن سعید نے ہمیں حدیث سنائی ۔  ۔  ۔ یحییٰ بن یحییٰ نے"}
{"hadithnumber": "2256", "text": "عبداللہ بن وہب نے ہمیں حدیث سنائی اور کہا :  ابن جریج نے عبداللہ بن کثیر بن مطلب سے روایت کی ، انھوں"}
{"hadithnumber": "2257", "text": "ابو بکر بن ابی شیبہ اور زہیر بن حرب نے کہا : ہمیں محمد بن عبد اللہ اسدی نے سفیان سے حدیث سنائی ، انھ"}
{"hadithnumber": "2258", "text": "مروان بن معاویہ نے یزید ، یعنی ابن کیسان سے ، انھوں نے ابو حازم سےاور انھوں نے حضرت ابو ہریرہ  رضی ا"}
{"hadithnumber": "2259", "text": "محمد بن عبید نے یزید بن کیسان سے  ، انھوں نے  ابو حازم سے اور اور انھوں نے حضرت ابو ہریرۃ  رضی اللہ"}
{"hadithnumber": "2260", "text": "ابو بکر بن ابی شیبہ ، محمد بن عبداللہ بن نمیر اور محمد بن مثنی نے ہمیں حدیث سنائی ۔  ۔  ۔ الفاظ  ابو"}
{"hadithnumber": "2261", "text": "ابو خیثمہ نے زبید الیامی سے ، انھوں نے محارب بن دثار سے ، انھوں نے ابن بریدہ سے  ، انھوں نے ، میرا خ"}
{"hadithnumber": "2262", "text": "حضرت جابر بن سمرہ  رضی اللہ تعالیٰ عنہ  سے روایت ہے ، انھوں نے کہا : نبی اکرم صلی اللہ علیہ وسلم  کے"}
