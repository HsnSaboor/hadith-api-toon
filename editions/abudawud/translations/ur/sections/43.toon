{"hadithnumber": "5015", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم حسان رضی اللہ عنہ کے لیے م"}
{"hadithnumber": "5016", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  آیت کریمہ  «والشعراء يتبعهم الغاوون»  شاعروں کی پیروی وہ"}
{"hadithnumber": "5017", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم جب نماز فجر سے  ( سلام پھیر کر )"}
{"hadithnumber": "5018", "text": "عبادہ بن صامت رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  مومن کا خواب نبوت کے"}
{"hadithnumber": "5019", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جب زمانہ قریب ہو جائے"}
{"hadithnumber": "5020", "text": "ابورزین رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  خواب پرندے کے پیر پر ہوتا"}
{"hadithnumber": "5021", "text": "ابوقتادہ رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  خواب اللہ کی"}
{"hadithnumber": "5022", "text": "جابر رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں سے کوئی خواب دی"}
{"hadithnumber": "5023", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا: جس نے مجھے خواب م"}
{"hadithnumber": "5024", "text": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جو کوئی تصویر"}
{"hadithnumber": "5025", "text": "انس بن مالک رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  میں نے آج رات دیکھ"}
{"hadithnumber": "5026", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں سے کوئی ج"}
{"hadithnumber": "5027", "text": "سہیل سے بھی اسی طرح مروی ہے  اس میں یہ ہے   ( جب جمائی )  نماز میں ہو تو جہاں تک ہو سکے منہ بند رکھے"}
{"hadithnumber": "5028", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ تعالیٰ چھینک کو پسن"}
{"hadithnumber": "5029", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کو جب چھینک آتی تھی تو اپنا ہاتھ یا"}
{"hadithnumber": "5030", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  پانچ چیزیں ہر مسلمان پر"}
{"hadithnumber": "5031", "text": "ہلال بن یساف کہتے ہیں کہ  ہم سالم بن عبید کے ساتھ تھے کہ ایک شخص کو چھینک آئی تو اس نے کہا «السلام ع"}
{"hadithnumber": "5032", "text": "اس سند سے سالم بن عبید اشجعی سے  یہی حدیث نبی اکرم صلی اللہ علیہ وسلم سے مرفوعاً مروی ہے۔"}
{"hadithnumber": "5033", "text": "ابوہریرہ رضی اللہ عنہ کہتے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں سے کسی کو چھینک آئے"}
{"hadithnumber": "5034", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں  تین بار اپنے بھائی کی چھینک کا جواب دو اور جو اس سے زیادہ ہو تو وہ ز"}
