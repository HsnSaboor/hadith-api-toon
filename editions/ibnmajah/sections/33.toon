metadata:

hadiths[340]{hadithnumber,arabic,bengali,english,french,indonesian,russian,urdu,grades,reference,international_number,narrator_chain,chapter_intro}:
{"hadithnumber": "3393", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا شَرِيكُ بْنُ عَبْدِ اللَّهِ، عَنْ مَنْصُورٍ، عَنْ عُبَيْدِ اللَّهِ بْنِ عَلِيٍّ، عَنِ ابْنِ سَلاَمَةَ السُّلَمِيِّ، قَالَ قَالَ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏ ‏ أُوصِي امْرَأً بِأُمِّهِ أُوصِي امْرَأً بِأُمِّهِ أُوصِي امْرَأً بِأُمِّهِ - ثَلاَثًا - أُوصِي امْرَأً بِأَبِيهِ أُوصِي امْرَءًا بِمَوْلاَهُ الَّذِي يَلِيهِ وَإِنْ كَانَ عَلَيْهِ مِنْهُ أَذًى يُؤْذِيهِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"I enjoin each one to honor his mother,I enjoin each one to honor his mother,I enjoin each one to honor his mother(three times), I enjoin each one to honor his guardian who is taking care of him, even if he is causing him some annoyance.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Ibn Salamah As-Sulami narrated that the Prophet (ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3394", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، مُحَمَّدُ بْنُ مَيْمُونٍ الْمَكِّيُّ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عُمَارَةَ بْنِ الْقَعْقَاعِ، عَنْ أَبِي زُرْعَةَ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالُوا يَا رَسُولَ اللَّهِ مَنْ أَبَرُّ قَالَ ‏\"‏ أُمَّكَ ‏\"‏ ‏.‏ قَالَ ثُمَّ مَنْ قَالَ ‏\"‏ أُمَّكَ ‏\"‏ ‏.‏ قَالَ ثُمَّ مَنْ قَالَ ‏\"‏ أَبَاكَ ‏\"‏ ‏.‏ قَالَ ثُمَّ مَنْ قَالَ ‏\"‏ الأَدْنَى فَالأَدْنَى ‏\"‏ ‏.‏", "bengali": "", "english": "Allah's Messenger said: \"They said: 'O Messenger of Allah, whom should I treat kindly?' He said: 'Your mother.' He said: 'Then who?' He said :'Your mother.\" He said: 'Then who?' He said: 'Your father'. He said : 'Then who?' He said: 'The next closest and the next closest.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس کی", "grades": "", "reference": "", "international_number": "3394", "narrator_chain": "Abu Hurairah, may Allah be pleased with them, said that:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3395", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا جَرِيرٌ، عَنْ سُهَيْلٍ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لاَ يَجْزِي وَلَدٌ وَالِدَهُ إِلاَّ أَنْ يَجِدَهُ مَمْلُوكًا فَيَشْتَرِيَهُ فَيُعْتِقَهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "Allah's Messenger said: \"No child can compensate his father unless he finds a slave, and buys him and sets him free.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Hurairah, may Allah be pleased with them, narrated that:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3396", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ، عَنْ حَمَّادِ بْنِ سَلَمَةَ، عَنْ عَاصِمٍ، عَنْ أَبِي صَالِحٍ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏\"‏ الْقِنْطَارُ اثْنَا عَشَرَ أَلْفَ أُوقِيَّةٍ كُلُّ أُوقِيَّةٍ خَيْرٌ مِمَّا بَيْنَ السَّمَاءِ وَالأَرْضِ ‏\"‏ ‏.‏ وَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏\"‏ إِنَّ الرَّجُلَ لَتُرْفَعُ دَرَجَتُهُ فِي الْجَنَّةِ فَيَقُولُ أَنَّى هَذَا فَيُقَالُ بِاسْتِغْفَارِ وَلَدِكَ لَكَ ‏\"‏ ‏.‏", "bengali": "", "english": "Allah's Messenger said: \"Qintar is twelve thousand 'Uqiyah, each 'Uqiyah of which is better than what is between heaven and earth.\" And the Messenger of Allah(ﷺ) said: \"A man will be raised in status in Paradise and will say: 'Where did this come from?' And it will be said:'From your son's praying for forgiveness for you.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  پکی اور کچی کھجوریں ملا", "grades": "", "reference": "", "international_number": "3396", "narrator_chain": "Abu Hurairah, may Allah be pleased with them, narrated that:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3397", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ عَيَّاشٍ، عَنْ بَحِيرِ بْنِ سَعْدٍ، عَنْ خَالِدِ بْنِ مَعْدَانَ، عَنِ الْمِقْدَامِ بْنِ مَعْدِيكَرِبَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ إِنَّ اللَّهَ يُوصِيكُمْ بِأُمَّهَاتِكُمْ - ثَلاَثًا - إِنَّ اللَّهَ يُوصِيكُمْ بِآبَائِكُمْ إِنَّ اللَّهَ يُوصِيكُمْ بِالأَقْرَبِ فَالأَقْرَبِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "Allah's Messenger said: \"Allah enjoins you to treat your mother's kindly\"-three times- \"Allah enjoins you to treat your fathers kindly, Allah enjoins you to treat the closest and the next closest kindly.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Miqdam bin Ma'dikarib, may Allah be pleased with them, narrated that:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3398", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا صَدَقَةُ بْنُ خَالِدٍ، حَدَّثَنَا عُثْمَانُ بْنُ أَبِي الْعَاتِكَةِ، عَنْ عَلِيِّ بْنِ يَزِيدَ، عَنِ الْقَاسِمِ، عَنْ أَبِي أُمَامَةَ، أَنَّ رَجُلاً، قَالَ يَا رَسُولَ اللَّهِ مَا حَقُّ الْوَالِدَيْنِ عَلَى وَلَدِهِمَا قَالَ ‏ ‏ هُمَا جَنَّتُكَ وَنَارُكَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"O Allah's Messenger(ﷺ), what are the rights of parents over their child?\" He said:\"They are your Paradise and your Hell.\" (Daif)", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Umamah narrated that a man said that:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3399", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عَطَاءٍ، عَنْ أَبِي عَبْدِ الرَّحْمَنِ، عَنْ أَبِي الدَّرْدَاءِ، سَمِعَ النَّبِيَّ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ الْوَالِدُ أَوْسَطُ أَبْوَابِ الْجَنَّةِ فَأَضِعْ ذَلِكَ الْبَابَ أَوِ احْفَظْهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"The father is the middle door of Paradise (i.e. the best way to Paradise), so it is up to you whether you take advantage of it or not.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Darda' heard the Prophet (ﷺ) say that:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3400", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ إِدْرِيسَ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ سُلَيْمَانَ، عَنْ أَسِيدِ بْنِ عَلِيِّ بْنِ عُبَيْدٍ، مَوْلَى بَنِي سَاعِدَةَ عَنْ أَبِيهِ، عَنْ أَبِي أُسَيْدٍ، مَالِكِ بْنِ رَبِيعَةَ قَالَ بَيْنَمَا نَحْنُ عِنْدَ النَّبِيِّ ـ صلى الله عليه وسلم ـ إِذْ جَاءَهُ رَجُلٌ مِنْ بَنِي سُلَيْمٍ فَقَالَ يَا رَسُولَ اللَّهِ أَبَقِيَ مِنْ بِرِّ أَبَوَىَّ شَىْءٌ أَبَرُّهُمَا بِهِ مِنْ بَعْدِ مَوْتِهِمَا قَالَ ‏ ‏ نَعَمْ الصَّلاَةُ عَلَيْهِمَا وَالاِسْتِغْفَارُ لَهُمَا وَإِيفَاءٌ بِعُهُودِهِمَا مِنْ بَعْدِ مَوْتِهِمَا وَإِكْرَامُ صَدِيقِهِمَا وَصِلَةُ الرَّحِمِ الَّتِي لاَ تُوصَلُ إِلاَّ بِهِمَا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"While we were with the Prophet(ﷺ), a man from the Banu Salamah came to him and said: \" O messenger of Allah, is there anyway of honoring my parents that I can still do for them after they die?' He said: \"Yes offering the funeral prayer for them, praying for forgiveness for them, fulfilling their promises after their death, honoring their freinds and upholding the ties of kinship which you would not have were it nor for them.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Abu Usaid, Malik bin Rabi'ah, said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3401", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو أُسَامَةَ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، قَالَتْ قَدِمَ نَاسٌ مِنَ الأَعْرَابِ عَلَى النَّبِيِّ ـ صلى الله عليه وسلم ـ فَقَالُوا أَتُقَبِّلُونَ صِبْيَانَكُمْ قَالُوا نَعَمْ ‏.‏ فَقَالُوا لَكِنَّا وَاللَّهِ مَا نُقَبِّلُ ‏.‏ فَقَالَ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏ ‏ وَأَمْلِكُ أَنْ كَانَ اللَّهُ قَدْ نَزَعَ مِنْكُمُ الرَّحْمَةَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Some Bedouin people came to the Prophet(ﷺ) and said: 'Do you kiss your children?' He said: 'Yes'. He said: 'But we, by Allah, never kiss (our children)'. The Prophet(ﷺ) said: 'What can I do if Allah has taken away mercy from you?'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Aisha, said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3402", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَفَّانُ، حَدَّثَنَا وُهَيْبٌ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ عُثْمَانَ بْنِ خُثَيْمٍ، عَنْ سَعِيدِ بْنِ أَبِي رَاشِدٍ، عَنْ يَعْلَى الْعَامِرِيِّ، أَنَّهُ قَالَ جَاءَ الْحَسَنُ وَالْحُسَيْنُ يَسْعَيَانِ إِلَى النَّبِيِّ ـ صلى الله عليه وسلم ـ فَضَمَّهُمَا إِلَيْهِ وَقَالَ ‏ ‏ إِنَّ الْوَلَدَ مَبْخَلَةٌ مَجْبَنَةٌ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Hasan and Hussain came running to the Prophet (ﷺ) and he embraced them and said: 'Children make a man a miser and a coward.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Ya'la Al -Amir that he said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3403", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا زَيْدُ بْنُ الْحُبَابِ، عَنْ مُوسَى بْنِ عُلَىٍّ، سَمِعْتُ أَبِي يَذْكُرُ، عَنْ سُرَاقَةَ بْنِ مَالِكٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ أَلاَ أَدُلُّكُمْ عَلَى أَفْضَلِ الصَّدَقَةِ ابْنَتُكَ مَرْدُودَةً إِلَيْكَ لَيْسَ لَهَا كَاسِبٌ غَيْرُكَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Shall I not tell you of the best charity? A daughter who comes back to you and has no other breadwinner apart from you.\" (Daif)", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Suraqah bin Malik that the Prophet(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3404", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ، عَنْ مِسْعَرٍ، أَخْبَرَنِي سَعْدُ بْنُ إِبْرَاهِيمَ، عَنِ الْحَسَنِ، عَنْ صَعْصَعَةَ، عَمِّ الأَحْنَفِ قَالَ دَخَلَتْ عَلَى عَائِشَةَ امْرَأَةٌ مَعَهَا ابْنَتَانِ لَهَا فَأَعْطَتْهَا ثَلاَثَ تَمَرَاتٍ فَأَعْطَتْ كُلَّ وَاحِدَةٍ مِنْهُمَا تَمْرَةً ثُمَّ صَدَعَتِ الْبَاقِيَةَ بَيْنَهُمَا ‏.‏ قَالَتْ فَأَتَى النَّبِيُّ ـ صلى الله عليه وسلم ـ فَحَدَّثْتُهُ فَقَالَ ‏ ‏ مَا عَجَبُكِ لَقَدْ دَخَلَتْ بِهِ الْجَنَّةَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"A woman entered upon Aisha with her two daughters, and she gave her three dates. (The woman) gave each of her daughters a date, then she split the last one between them. She (Aisha) said: 'Then the Prophet(ﷺ) came and I told him about that.' He said:' Why are you surprised? She will enter Paradise because of that.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Sa'sa'ah the paternal uncle of Ahnaf, said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3405", "arabic": "حَدَّثَنَا الْحُسَيْنُ بْنُ الْحَسَنِ الْمَرْوَزِيُّ، حَدَّثَنَا ابْنُ الْمُبَارَكِ، عَنْ حَرْمَلَةَ بْنِ عِمْرَانَ، قَالَ سَمِعْتُ أَبَا عُشَّانَةَ الْمَعَافِرِيَّ، قَالَ سَمِعْتُ عُقْبَةَ بْنَ عَامِرٍ، يَقُولُ سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ مَنْ كَانَ لَهُ ثَلاَثُ بَنَاتٍ فَصَبَرَ عَلَيْهِنَّ وَأَطْعَمَهُنَّ وَسَقَاهُنَّ وَكَسَاهُنَّ مِنْ جِدَتِهِ - كُنَّ لَهُ حِجَابًا مِنَ النَّارِ يَوْمَ الْقِيَامَةِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Whoever has three daughters and is patient towards them, and feeds them, gives them to drink, and clothes them from his wealth; they will be a shield for him from the Fire on the Day of Resurrection.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Uqbah bin Amir said, I heard the Messenger of Allah(ﷺ) say:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3406", "arabic": "حَدَّثَنَا الْحُسَيْنُ بْنُ الْحَسَنِ، حَدَّثَنَا ابْنُ الْمُبَارَكِ، عَنْ فِطْرٍ، عَنْ أَبِي سَعْدٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَا مِنْ رَجُلٍ تُدْرِكُ لَهُ ابْنَتَانِ فَيُحْسِنُ إِلَيْهِمَا مَا صَحِبَتَاهُ أَوْ صَحِبَهُمَا إِلاَّ أَدْخَلَتَاهُ الْجَنَّةَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"There is no man whose two daughters reach the age of puberty and he treats them kindly for the time they are together, but they will gain him admittance to Paradise.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Ibn Abbas that the Messenger of Allah(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3407", "arabic": "حَدَّثَنَا الْعَبَّاسُ بْنُ الْوَلِيدِ الدِّمَشْقِيُّ، حَدَّثَنَا عَلِيُّ بْنُ عَيَّاشٍ، حَدَّثَنَا سَعِيدُ بْنُ عُمَارَةَ، أَخْبَرَنِي الْحَارِثُ بْنُ النُّعْمَانِ، سَمِعْتُ أَنَسَ بْنَ مَالِكٍ، يُحَدِّثُ عَنْ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ أَنَّهُ قَالَ ‏ ‏ أَكْرِمُوا أَوْلاَدَكُمْ وَأَحْسِنُوا أَدَبَهُمْ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Be kind to your children, and perfect their manners.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Anas bin Malik narrated that the Messenger of Allah(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3408", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عَمْرِو بْنِ دِينَارٍ، سَمِعَ نَافِعَ بْنَ جُبَيْرٍ، يُخْبِرُ عَنْ أَبِي شُرَيْحٍ الْخُزَاعِيِّ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ مَنْ كَانَ يُؤْمِنُ بِاللَّهِ وَالْيَوْمِ الآخِرِ فَلْيُحْسِنْ إِلَى جَارِهِ وَمَنْ كَانَ يُؤْمِنُ بِاللَّهِ وَالْيَوْمِ الآخِرِ فَلْيُكْرِمْ ضَيْفَهُ وَمَنْ كَانَ يُؤْمِنُ بِاللَّهِ وَالْيَوْمِ الآخِرِ فَلْيَقُلْ خَيْرًا أَوْ لِيَسْكُتْ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Whoever believes in the Last Day, let him treat his neighbour well. Whoever believes in Allah and Last Day, let him honor his guest. Whoever believes in Allah and the Last Day, let him say something good or else remain silent\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Shuraih Al-Khuzai that the Prophet(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3409", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، وَعَبْدَةُ بْنُ سُلَيْمَانَ، ح وَحَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، جَمِيعًا عَنْ يَحْيَى بْنِ سَعِيدٍ، عَنْ أَبِي بَكْرِ بْنِ مُحَمَّدِ بْنِ عَمْرِو بْنِ حَزْمٍ، عَنْ عَمْرَةَ، عَنْ عَائِشَةَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ مَا زَالَ جِبْرِيلُ يُوصِينِي بِالْجَارِ حَتَّى ظَنَنْتُ أَنَّهُ سَيُوَرِّثُهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Jibra'il kept enjoining good treatment of neighbours untol I thought that he would make neigbours heirs.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Aisha narrated that the Messenger of Allah(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3410", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا يُونُسُ بْنُ أَبِي إِسْحَاقَ، عَنْ مُجَاهِدٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَا زَالَ جِبْرَائِيلُ يُوصِينِي بِالْجَارِ حَتَّى ظَنَنْتُ أَنَّهُ سَيُوَرِّثُهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Jibra'il kept enjoining good treatment of neighbours until I thought he would make neighbours heirs.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurayrah that the Messenger of Allah(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3411", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ ابْنِ عَجْلاَنَ، عَنْ سَعِيدِ بْنِ أَبِي سَعِيدٍ، عَنْ أَبِي شُرَيْحٍ الْخُزَاعِيِّ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ مَنْ كَانَ يُؤْمِنُ بِاللَّهِ وَالْيَوْمِ الآخِرِ فَلْيُكْرِمْ ضَيْفَهُ وَجَائِزَتُهُ يَوْمٌ وَلَيْلَةٌ وَلاَ يَحِلُّ لَهُ أَنْ يَثْوِيَ عِنْدَ صَاحِبِهِ حَتَّى يُحْرِجَهُ الضِّيَافَةُ ثَلاَثَةُ أَيَّامٍ وَمَا أَنْفَقَ عَلَيْهِ بَعْدَ ثَلاَثَةِ أَيَّامٍ فَهُوَ صَدَقَةٌ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Whoever believes in the Last Day, let him honor his guest, and grant him reward for a day and a night. And it is not permissible for him to stay so long that he causes annoyance to his host. Hospitality is for three days, and whatever he spends on him after three days is charity.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Shuraih Al-Khuza'i that the Messenger of Allah(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3412", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، عَنْ يَزِيدَ بْنِ أَبِي حَبِيبٍ، عَنْ أَبِي الْخَيْرِ، عَنْ عُقْبَةَ بْنِ عَامِرٍ، أَنَّهُ قَالَ قُلْنَا لِرَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ إِنَّكَ تَبْعَثُنَا فَنَنْزِلُ بِقَوْمٍ فَلاَ يَقْرُونَا فَمَا تَرَى فِي ذَلِكَ ‏.‏ قَالَ لَنَا رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِنْ نَزَلْتُمْ بِقَوْمٍ فَأَمَرُوا لَكُمْ بِمَا يَنْبَغِي لِلضَّيْفِ فَاقْبَلُوا وَإِنْ لَمْ يَفْعَلُوا فَخُذُوا مِنْهُمْ حَقَّ الضَّيْفِ الَّذِي يَنْبَغِي لَهُمْ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"We said to the Messenger of Allah(ﷺ): ' You send us and we stay with people who do not show us any hospitality. WHat do you think of that?' The MEssenger of Allah (ﷺ) said: 'If you stay with people and they give you what a guest deserves, then accept it. If they do not do that , then take from them what they should have offered, which a guest is entitled to.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Uqbah bin Amir said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3413", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا سُفْيَانُ، عَنْ مَنْصُورٍ، عَنِ الشَّعْبِيِّ، عَنِ الْمِقْدَامِ أَبِي كَرِيمَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لَيْلَةُ الضَّيْفِ وَاجِبَةٌ فَإِنْ أَصْبَحَ بِفِنَائِهِ فَهُوَ دَيْنٌ عَلَيْهِ فَإِنْ شَاءَ اقْتَضَى وَإِنْ شَاءَ تَرَكَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"The Messenger of Allah(ﷺ) said: ' Putting up a guest for one night is obligatory. If you find a guest at your door in the morning, then this (hospitality) is (like) a debt that you (the host) owe him. If he (the guest) wants, he may request it, and if he wants, he may leave it'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Miqdam Abu Karimah said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3414", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ الْقَطَّانُ، عَنِ ابْنِ عَجْلاَنَ، عَنْ سَعِيدِ بْنِ سَعِيدٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ اللَّهُمَّ إِنِّي أُحَرِّجُ حَقَّ الضَّعِيفَيْنِ الْيَتِيمِ وَالْمَرْأَةِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"O Allah, bear witness that I have issued a warning concerning (failure to fulfill) the rights of the two weak ones: Orphans and women.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah that the Messenger of Allah(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3415", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا يَحْيَى بْنُ آدَمَ، حَدَّثَنَا ابْنُ الْمُبَارَكِ، عَنْ سَعِيدِ بْنِ أَبِي أَيُّوبَ، عَنْ يَحْيَى بْنِ أَبِي سُلَيْمَانَ، عَنْ زَيْدِ بْنِ أَبِي عَتَّابٍ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ خَيْرُ بَيْتٍ فِي الْمُسْلِمِينَ بَيْتٌ فِيهِ يَتِيمٌ يُحْسَنُ إِلَيْهِ وَشَرُّ بَيْتٍ فِي الْمُسْلِمِينَ بَيْتٌ فِيهِ يَتِيمٌ يُسَاءُ إِلَيْهِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"The best house among the Muslims is a house in which there is an orphan who is treated well. And the worst house among the Muslims is a house in which there is an orphan who is treated badly.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah that the Messenger of Allah(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3416", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا حَمَّادُ بْنُ عَبْدِ الرَّحْمَنِ الْكَلْبِيُّ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ إِبْرَاهِيمَ الأَنْصَارِيُّ، عَنْ عَطَاءِ بْنِ أَبِي رَبَاحٍ، عَنْ عَبْدِ اللَّهِ بْنِ عَبَّاسٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ عَالَ ثَلاَثَةً مِنَ الأَيْتَامِ كَانَ كَمَنْ قَامَ لَيْلَهُ وَصَامَ نَهَارَهُ وَغَدَا وَرَاحَ شَاهِرًا سَيْفَهُ فِي سَبِيلِ اللَّهِ وَكُنْتُ أَنَا وَهُوَ فِي الْجَنَّةِ أَخَوَيْنِ كَهَاتَيْنِ أُخْتَانِ ‏\"\"‏ ‏.‏ وَأَلْصَقَ إِصْبَعَيْهِ السَّبَّابَةَ وَالْوُسْطَى ‏.‏\"", "bengali": "", "english": "\"Whoever raises three orphans, is like the one who spends his nights in prayer and fasts during the day, and goes out morning and evening drawing his sword in the cause of Allah. In Paradise, he and I will be brothers like these two sisters,'and he held up his forefinger and middle finger together.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from `Abdullah bin `Abbas that the Messenger of Allah(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3417", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا وَكِيعٌ، عَنْ أَبَانَ بْنِ صَمْعَةَ، عَنْ أَبِي الْوَازِعِ الرَّاسِبِيِّ، عَنْ أَبِي بَرْزَةَ الأَسْلَمِيِّ، قَالَ قُلْتُ يَا رَسُولَ اللَّهِ دُلَّنِي عَلَى عَمَلٍ أَنْتَفِعُ بِهِ ‏.‏ قَالَ ‏ ‏ اعْزِلِ الأَذَى عَنْ طَرِيقِ الْمُسْلِمِينَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"O Messenger of Allah! Tell me of an action by which I may benefit.' He said: 'Remove harmful things from the path of the Muslims.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Abu Barzah Al-Aslami said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3418", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، عَنِ الأَعْمَشِ، عَنْ أَبِي صَالِحٍ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ كَانَ عَلَى الطَّرِيقِ غُصْنُ شَجَرَةٍ يُؤْذِي النَّاسَ فَأَمَاطَهَا رَجُلٌ فَأُدْخِلَ الْجَنَّةَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"There was a branch of a tree that annoyed the people. A man removed it, so he was admitted to Paradise.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurayrah that the Prophet(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3419", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، أَنْبَأَنَا هِشَامُ بْنُ حَسَّانَ، عَنْ وَاصِلٍ، مَوْلَى أَبِي عُيَيْنَةَ عَنْ يَحْيَى بْنِ عُقَيْلٍ، عَنْ يَحْيَى بْنِ يَعْمَرَ، عَنْ أَبِي ذَرٍّ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ عُرِضَتْ عَلَىَّ أُمَّتِي بِأَعْمَالِهَا حَسَنِهَا وَسَيِّئِهَا فَرَأَيْتُ فِي مَحَاسِنِ أَعْمَالِهَا الأَذَى يُنَحَّى عَنِ الطَّرِيقِ وَرَأَيْتُ فِي سَيِّئِ أَعْمَالِهَا النُّخَاعَةَ فِي الْمَسْجِدِ لاَ تُدْفَنُ ‏\"‏ ‏.‏", "bengali": "", "english": "\"My nation was shown to me with their good deeds and bad deeds. Among their good deeds I saw a harmful thing being removed from the road. And among their bad deeds I saw sputum in the mosque that had not been removed.\"", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مشک کے منہ باہر کر کے پا", "grades": "", "reference": "", "international_number": "3419", "narrator_chain": "It was narrated from Abu Dharr that the Prophet(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3420", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، عَنْ هِشَامٍ، صَاحِبِ الدَّسْتَوَائِيِّ عَنْ قَتَادَةَ، عَنْ سَعِيدِ بْنِ الْمُسَيَّبِ، عَنْ سَعْدِ بْنِ عُبَادَةَ، قَالَ قُلْتُ يَا رَسُولَ اللَّهِ أَىُّ الصَّدَقَةِ أَفْضَلُ قَالَ ‏ ‏ سَقْىُ الْمَاءِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"I said: 'O Messenger of Allah, what charity is best?' He said: 'Giving water to drink.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Sad bin Ubadah said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3421", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا وَكِيعٌ، عَنِ الأَعْمَشِ، عَنْ يَزِيدَ الرَّقَاشِيِّ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏\"‏ يَصُفُّ النَّاسُ يَوْمَ الْقِيَامَةِ صُفُوفًا - وَقَالَ ابْنُ نُمَيْرٍ أَهْلُ الْجَنَّةِ - فَيَمُرُّ الرَّجُلُ مِنْ أَهْلِ النَّارِ عَلَى الرَّجُلِ فَيَقُولُ يَا فُلاَنُ أَمَا تَذْكُرُ يَوْمَ اسْتَسْقَيْتَ فَسَقَيْتُكَ شَرْبَةً قَالَ فَيَشْفَعُ لَهُ وَيَمُرُّ الرَّجُلُ فَيَقُولُ أَمَا تَذْكُرُ يَوْمَ نَاوَلْتُكَ طَهُورًا فَيَشْفَعُ لَهُ ‏\"‏ ‏.‏ قَالَ ابْنُ نُمَيْرٍ ‏\"‏ وَيَقُولُ يَا فُلاَنُ أَمَا تَذْكُرُ يَوْمَ بَعَثْتَنِي فِي حَاجَةِ كَذَا وَكَذَا فَذَهَبْتُ لَكَ فَيَشْفَعُ لَهُ ‏\"‏ ‏.‏", "bengali": "", "english": "\"On the Day of Resurrection, people will be lined up in rows, (one of the narrators) Ibn NUmair said: i.e., the people of Paradise, and a man from among the people of Hell will pass by a man (from the people of Paradise) and say: 'O so and so! Do you not remember the day when you asked for water and I gave you water to drink?\" So he will intercede for him. And another man will come and say: \" Do you not remember the day when I gave you water with which to purify yourself?\" and he will intercede for him.\" (In his narration, one of the narrators) Ibn NUmair said: \"And he will remember the day when you sent me to do such and such for you, and I went and did it for you?' and he will intercede for him.\"  \"", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے اس بات سے منع فرمایا", "grades": "", "reference": "", "international_number": "3421", "narrator_chain": "It was narrated from Anas bin Malik that the Messenger of Allah(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3422", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، حَدَّثَنَا مُحَمَّدُ بْنُ إِسْحَاقَ، عَنِ الزُّهْرِيِّ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ جُعْشُمٍ، عَنْ أَبِيهِ، عَنْ عَمِّهِ، سُرَاقَةَ بْنِ جُعْشُمٍ قَالَ سَأَلْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ عَنْ ضَالَّةِ الإِبِلِ تَغْشَى حِيَاضِي قَدْ لُطْتُهَا لإِبِلِي فَهَلْ لِي مِنْ أَجْرٍ إِنْ سَقَيْتُهَا فَقَالَ ‏ ‏ نَعَمْ فِي كُلِّ ذَاتِ كَبِدٍ حَرَّى أَجْرٌ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"I asked the Messenger of Allah(ﷺ) about a lost camel that comes to my cisterns that I have prepared for my own camels - will I be rewarded if I give it some water to drink? He said: Yes, in every living being there is reward.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Suraqah bin Ju'shum said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3423", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، عَنِ الأَعْمَشِ، عَنْ تَمِيمِ بْنِ سَلَمَةَ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ هِلاَلٍ الْعَبْسِيِّ، عَنْ جَرِيرِ بْنِ عَبْدِ اللَّهِ الْبَجَلِيِّ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ يُحْرَمِ الرِّفْقَ يُحْرَمِ الْخَيْرَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Whoever is deprived of gentleness, he is deprived of goodness.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Jarir bin Abdullah Al-Bajali that the Messenger of Allah(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3424", "arabic": "حَدَّثَنَا إِسْمَاعِيلُ بْنُ حَفْصٍ الأُبُلِّيُّ، حَدَّثَنَا أَبُو بَكْرِ بْنُ عَيَّاشٍ، عَنِ الأَعْمَشِ، عَنْ أَبِي صَالِحٍ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ إِنَّ اللَّهَ رَفِيقٌ يُحِبُّ الرِّفْقَ وَيُعْطِي عَلَيْهِ مَا لاَ يُعْطِي عَلَى الْعُنْفِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Allah is Gentle and loves gentleness, and He grants reward for it that He does not grant for harshness.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah that the Messenger of Allah(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3425", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا مُحَمَّدُ بْنُ مُصْعَبٍ، عَنِ الأَوْزَاعِيِّ، ح وَحَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، وَعَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ، قَالاَ حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، حَدَّثَنَا الأَوْزَاعِيُّ، عَنِ الزُّهْرِيِّ، عَنْ عُرْوَةَ، عَنْ عَائِشَةَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ إِنَّ اللَّهَ رَفِيقٌ يُحِبُّ الرِّفْقَ فِي الأَمْرِ كُلِّهِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Allah is Gentle and loves gentleness in all things.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Aishah that the Prophet(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3426", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا الأَعْمَشُ، عَنِ الْمَعْرُورِ بْنِ سُوَيْدٍ، عَنْ أَبِي ذَرٍّ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِخْوَانُكُمْ جَعَلَهُمُ اللَّهُ تَحْتَ أَيْدِيكُمْ فَأَطْعِمُوهُمْ مِمَّا تَأْكُلُونَ وَأَلْبِسُوهُمْ مِمَّا تَلْبَسُونَ وَلاَ تُكَلِّفُوهُمْ مَا يَغْلِبُهُمْ فَإِنْ كَلَّفْتُمُوهُمْ فَأَعِينُوهُمْ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"The Messenger of Allah said: '(Slaves are) your brothers whom Allah has put under your control, so feed them with the same food that you eat, clothe them with the same clothes you wear, and do not burden them with so much that htey are overwhelmed; if you do burden them, then help them.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Abu Dhar said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3427", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا إِسْحَاقُ بْنُ سُلَيْمَانَ، عَنْ مُغِيرَةَ بْنِ مُسْلِمٍ، عَنْ فَرْقَدٍ السَّبَخِيِّ، عَنْ مُرَّةَ الطَّيِّبِ، عَنْ أَبِي بَكْرٍ الصِّدِّيقِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏\"‏ لاَ يَدْخُلُ الْجَنَّةَ سَيِّئُ الْمَلَكَةِ ‏\"‏ ‏.‏ قَالُوا يَا رَسُولَ اللَّهِ أَلَيْسَ أَخْبَرْتَنَا أَنَّ هَذِهِ الأُمَّةَ أَكْثَرُ الأُمَمِ مَمْلُوكِينَ وَيَتَامَى قَالَ ‏\"‏ نَعَمْ فَأَكْرِمُوهُمْ كَكَرَامَةِ أَوْلاَدِكُمْ وَأَطْعِمُوهُمْ مِمَّا تَأْكُلُونَ ‏\"‏ ‏.‏ قَالُوا فَمَا يَنْفَعُنَا فِي الدُّنْيَا قَالَ ‏\"‏ فَرَسٌ تَرْتَبِطُهُ تُقَاتِلُ عَلَيْهِ فِي سَبِيلِ اللَّهِ مَمْلُوكُكَ يَكْفِيكَ فَإِذَا صَلَّى فَهُوَ أَخُوكَ ‏\"‏ ‏.‏", "bengali": "", "english": "\"No person who mistreats his slave will enter Paradise.\" They said: \" O Messenger of Allah, did you  not tell us that this nation will have more slaves and orphans than any other nation?\" He said: \" Yes, so be as kind to them as you are to your own children, and feed them with the same food that you eat.\" They said: \"What will benefit us in this world?\" He said: \"A horse that is kept ready for fighting in the cause of Allah, and your slave to take care of you, and if he performs prayer, then he is your brother(in Islam).\"", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں سے کوئی کچھ پئ", "grades": "", "reference": "", "international_number": "3427", "narrator_chain": "It was narrated from Abu Bakr Siddiq(RA) that the Messenger of Allah(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3428", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، وَابْنُ، نُمَيْرٍ عَنِ الأَعْمَشِ، عَنْ أَبِي صَالِحٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهُ ـ صلى الله عليه وسلم ـ ‏ ‏ وَالَّذِي نَفْسِي بِيَدِهِ لاَ تَدْخُلُوا الْجَنَّةَ حَتَّى تُؤْمِنُوا وَلاَ تُؤْمِنُوا حَتَّى تَحَابُّوا ‏.‏ أَوَلاَ أَدُلُّكُمْ عَلَى شَىْءٍ إِذَا فَعَلْتُمُوهُ تَحَابَبْتُمْ أَفْشُوا السَّلاَمَ بَيْنَكُمْ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"By the One in Whose Hand is my soul, you will not enter Paradise until you believe, and you will not believe until you love one another. Shall I not tell you of something which, if you do it, you will love one another? Spread (the greeting of) peace among yourselves.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah(RA) that the Messenger of Allah(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3429", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ عَيَّاشٍ، عَنْ مُحَمَّدِ بْنِ زِيَادٍ، عَنْ أَبِي أُمَامَةَ، قَالَ أَمَرَنَا نَبِيُّنَا ـ صلى الله عليه وسلم ـ أَنْ نُفْشِيَ السَّلاَمَ ‏.‏", "bengali": "", "english": "\"Our Prophet(ﷺ) commanded us to spread (the greeting of) peace.\"", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے برتن میں پھونک مارنے سے", "grades": "", "reference": "", "international_number": "3429", "narrator_chain": "It was narrated that Abu Umamah said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3430", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا مُحَمَّدُ بْنُ فُضَيْلٍ، عَنْ عَطَاءِ بْنِ السَّائِبِ، عَنْ أَبِيهِ، عَنْ عَبْدِ اللَّهِ بْنِ عَمْرٍو، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ اعْبُدُوا الرَّحْمَنَ وَأَفْشُوا السَّلاَمَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Worship the Most Merciful and spread (the greeting of) peace.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abdullah bin 'Amr that the Messenger of Allah(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3431", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ عُمَرَ، حَدَّثَنَا سَعِيدُ بْنُ أَبِي سَعِيدٍ الْمَقْبُرِيُّ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَجُلاً، دَخَلَ الْمَسْجِدَ وَرَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ جَالِسٌ فِي نَاحِيَةِ الْمَسْجِدِ فَصَلَّى ثُمَّ جَاءَ فَسَلَّمَ فَقَالَ ‏ ‏ وَعَلَيْكَ السَّلاَمُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"a man entered the masjid, and the Messenger of Allah(ﷺ) was sitting in a corner of the mosque. He prayed, then he came and greeted him with Salam(peace), and he said: 'Wa 'alaikassalm.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah that:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3432", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ سُلَيْمَانَ، عَنْ زَكَرِيَّا، عَنِ الشَّعْبِيِّ، عَنْ أَبِي سَلَمَةَ، أَنَّ عَائِشَةَ، حَدَّثَتْهُ أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ لَهَا ‏ ‏ إِنَّ جِبْرَائِيلَ يَقْرَأُ عَلَيْكِ السَّلاَمَ ‏\"\"‏ ‏.‏ قَالَتْ وَعَلَيْهِ السَّلاَمُ وَرَحْمَةُ اللَّهِ ‏.‏\"", "bengali": "", "english": "\"Jibrail send (greetings of) Salam to you.\" She said: \"Wa 'alahisalam wa rahmatullah (and upon him be peace and mercy of Allah).\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Salamah that 'Aishah told him that the Messenger of Allah(ﷺ) said to her:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3433", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا عَبْدَةُ بْنُ سُلَيْمَانَ، وَمُحَمَّدُ بْنُ بِشْرٍ، عَنْ سَعِيدٍ، عَنْ قَتَادَةَ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِذَا سَلَّمَ عَلَيْكُمْ أَحَدٌ مِنْ أَهْلِ الْكِتَابِ فَقُولُوا وَعَلَيْكُمْ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"When any of the People of the Book greets you with Salam (peace), then say, Wa 'alaikum(and also upon you).\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Anas bin Malik said \"the Messenger of Allah(ﷺ) said\":", "chapter_intro": "Etiquette"}
{"hadithnumber": "3434", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، عَنِ الأَعْمَشِ، عَنْ مُسْلِمٍ، عَنْ مَسْرُوقٍ، عَنْ عَائِشَةَ، أَنَّهُ أَتَى النَّبِيَّ ـ صلى الله عليه وسلم ـ نَاسٌ مِنَ الْيَهُودِ فَقَالُوا السَّامُ عَلَيْكَ يَا أَبَا الْقَاسِمِ ‏.‏ فَقَالَ ‏ ‏ وَعَلَيْكُمْ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Assam o alaika (death be upon you), O Abul-Qasim!\" He said: \"Wa 'alayikum (and also upon you).\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Aishah that some of the Jews came to the Prophet(ﷺ) and said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3435", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا ابْنُ نُمَيْرٍ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ، عَنْ يَزِيدَ بْنِ أَبِي حَبِيبٍ، عَنْ مَرْثَدِ بْنِ عَبْدِ اللَّهِ الْيَزَنِيِّ، عَنْ أَبِي عَبْدِ الرَّحْمَنِ الْجُهَنِيِّ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِنِّي رَاكِبٌ غَدًا إِلَى الْيَهُودِ فَلاَ تَبْدَءُوهُمْ بِالسَّلاَمِ فَإِذَا سَلَّمُوا عَلَيْكُمْ فَقُولُوا وَعَلَيْكُمْ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"I am riding to the Jews tomorrow. Do not initiate the greeting with them, and if they greet you, then say: Wa 'alaikum (and also upon you)\".", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu 'Abdur-Rahman Al Juhani that the Messenger of Allah(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3436", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ، عَنْ حُمَيْدٍ، عَنْ أَنَسٍ، قَالَ أَتَانَا رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ وَنَحْنُ صِبْيَانٌ فَسَلَّمَ عَلَيْنَا ‏.‏", "bengali": "", "english": "\"The Messenger of Allah(ﷺ) came to us, and we were young boys, and he greeted us with (the greeting of) peace\".", "french": "", "indonesian": "", "russian": "", "urdu": "اسامہ بن شریک رضی اللہ عنہ کہتے ہیں کہ  میں نے اعرابیوں کو نبی اکرم صلی اللہ علیہ وسلم سے سوال کرتے", "grades": "", "reference": "", "international_number": "3436", "narrator_chain": "It was narrated that Anas said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3437", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ ابْنِ أَبِي حُسَيْنٍ، سَمِعَهُ مِنْ، شَهْرِ بْنِ حَوْشَبٍ يَقُولُ أَخْبَرَتْهُ أَسْمَاءُ بِنْتُ يَزِيدَ، قَالَتْ مَرَّ عَلَيْنَا رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ فِي نِسْوَةٍ فَسَلَّمَ عَلَيْنَا ‏.‏", "bengali": "", "english": "\"The Messenger of Allah(ﷺ) passed by us, among (a group of) women, and he greeted us with (the greeting of) peace.\"", "french": "", "indonesian": "", "russian": "", "urdu": "ابوخزامہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم سے عرض کیا گیا: بتائیے ان دواؤں کے", "grades": "", "reference": "", "international_number": "3437", "narrator_chain": "Asma bint Yazid said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3438", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، عَنْ جَرِيرِ بْنِ حَازِمٍ، عَنْ حَنْظَلَةَ بْنِ عَبْدِ الرَّحْمَنِ السَّدُوسِيِّ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ قُلْنَا يَا رَسُولَ اللَّهِ أَيَنْحَنِي بَعْضُنَا لِبَعْضٍ قَالَ ‏\"‏ لاَ ‏\"‏ ‏.‏ قُلْنَا أَيُعَانِقُ بَعْضُنَا بَعْضًا قَالَ ‏\"‏ لاَ وَلَكِنْ تَصَافَحُوا ‏\"‏ ‏.‏", "bengali": "", "english": "\"O Messenger of Allah! Should we bow to one another?\" He said: \"No.\" We said: \"Should we embrace one another?\" He said: \"No, but shake hands with one another.\"", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  اللہ تعالیٰ نے ای", "grades": "", "reference": "", "international_number": "3438", "narrator_chain": "It was narrated that Anas bin Malik said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3439", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ، وَعَبْدُ اللَّهِ بْنُ نُمَيْرٍ، عَنِ الأَجْلَحِ، عَنْ أَبِي إِسْحَاقَ، عَنِ الْبَرَاءِ بْنِ عَازِبٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَا مِنْ مُسْلِمَيْنِ يَلْتَقِيَانِ فَيَتَصَافَحَانِ إِلاَّ غُفِرَ لَهُمَا قَبْلَ أَنْ يَتَفَرَّقَا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"There are no two Muslims who meet and shake hands, but they will be forgiven before they part.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Bara bin Azib that the Messenger of Allah(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3440", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا مُحَمَّدُ بْنُ فُضَيْلٍ، حَدَّثَنَا يَزِيدُ بْنُ أَبِي زِيَادٍ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِي لَيْلَى، عَنِ ابْنِ عُمَرَ، قَالَ قَبَّلْنَا يَدَ النَّبِيِّ ـ صلى الله عليه وسلم ـ ‏.‏", "bengali": "", "english": "\"We kissed the hand of the Prophet(ﷺ).\"", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے ایک شخص کی عیادت فرمائ", "grades": "", "reference": "", "international_number": "3440", "narrator_chain": "It was narrated that Ibn Umar said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3441", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ إِدْرِيسَ، وَغُنْدَرٌ، وَأَبُو أُسَامَةَ عَنْ شُعْبَةَ، عَنْ عَمْرِو بْنِ مُرَّةَ، عَنْ عَبْدِ اللَّهِ بْنِ سَلِمَةَ، عَنْ صَفْوَانَ بْنِ عَسَّالٍ، أَنَّ قَوْمًا، مِنَ الْيَهُودِ قَبَّلُوا يَدَ النَّبِيِّ ـ صلى الله عليه وسلم ـ وَرِجْلَيْهِ ‏.‏", "bengali": "", "english": "\"Some people among the Jews kissed the hands and feet of the Prophet(ﷺ).\"", "french": "", "indonesian": "", "russian": "", "urdu": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم ایک مریض کی عیادت کے لیے تشریف لے", "grades": "", "reference": "", "international_number": "3441", "narrator_chain": "It was narrated from Safwan bin 'Assal that:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3442", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، أَنْبَأَنَا دَاوُدُ بْنُ أَبِي هِنْدٍ، عَنْ أَبِي نَضْرَةَ، عَنْ أَبِي سَعِيدٍ الْخُدْرِيِّ، أَنَّ أَبَا مُوسَى، اسْتَأْذَنَ عَلَى عُمَرَ ثَلاَثًا فَلَمْ يُؤْذَنْ لَهُ فَانْصَرَفَ فَأَرْسَلَ إِلَيْهِ عُمَرُ مَا رَدَّكَ قَالَ اسْتَأْذَنْتُ الاِسْتِئْذَانَ الَّذِي أَمَرَنَا بِهِ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ثَلاَثًا فَإِنْ أُذِنَ لَنَا دَخَلْنَا وَإِنْ لَمْ يُؤْذَنْ لَنَا رَجَعْنَا ‏.‏ قَالَ فَقَالَ لَتَأْتِيَنِّي عَلَى هَذَا بِبَيِّنَةٍ أَوْ لأَفْعَلَنَّ ‏.‏ فَأَتَى مَجْلِسَ قَوْمِهِ فَنَاشَدَهُمْ فَشَهِدُوا لَهُ فَخَلَّى سَبِيلَهُ ‏.‏", "bengali": "", "english": "\"Why did you go back?\" He said: \"I asked permission to enter three times, as the Messenger of Allah(ﷺ) enjoined upon us, then if we are given permission we should enter, otherwise we should go back.\" He said: \"You should bring me proof of that, or else!\" Then he came to a gathering of his people and asked them to swear by Allah concerning that, and they did so, so he let him go.\"", "french": "", "indonesian": "", "russian": "", "urdu": "ام المنذر بنت قیس انصاریہ رضی اللہ عنہا کہتی ہیں کہ  ہمارے یہاں رسول اللہ صلی اللہ علیہ وسلم تشریف ل", "grades": "", "reference": "", "international_number": "3442", "narrator_chain": "It was narrated from Abu Saeed Khudri that Abu Musa asked permission to enter upon 'Umar three times, and he did not give him permission, so he went away.'Umar sent word to him saying:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3443", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ سُلَيْمَانَ، عَنْ وَاصِلِ بْنِ السَّائِبِ، عَنْ أَبِي سَوْرَةَ، عَنْ أَبِي أَيُّوبَ الأَنْصَارِيِّ، قَالَ قُلْنَا يَا رَسُولَ اللَّهِ هَذَا السَّلاَمُ فَمَا الاِسْتِئْنَاسُ قَالَ ‏ ‏ يَتَكَلَّمُ الرَّجُلُ تَسْبِيحَةً وَتَكْبِيرَةً وَتَحْمِيدَةً وَيَتَنَحْنَحُ وَيُؤْذِنُ أَهْلَ الْبَيْتِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"We said: 'O Messenger of Allah(ﷺ), (we know) this (greeting of) Salam, but what does seeking permission to enter mean?' He said: 'It means a man saying SubhanAllah, and Allahu Akbar and Al Hamdulillah, and clearing his throat, announcing his arrival to the people in the house.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Abu Ayyub Ansari said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3444", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو بَكْرِ بْنُ عَيَّاشٍ، عَنْ مُغِيرَةَ، عَنِ الْحَارِثِ، عَنْ عَبْدِ اللَّهِ بْنِ نُجَىٍّ، عَنْ عَلِيٍّ، قَالَ كَانَ لِي مِنْ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ مُدْخَلاَنِ مُدْخَلٌ بِاللَّيْلِ وَمُدْخَلٌ بِالنَّهَارِ فَكُنْتُ إِذَا أَتَيْتُهُ وَهُوَ يُصَلِّي يَتَنَحْنَحُ لِي ‏.‏", "bengali": "", "english": "\"I had two times of visiting the Messenger of Allah(ﷺ), at night and during the day. If I came to him when he was praying, he would clear his throat (to let me know he was praying).\"", "french": "", "indonesian": "", "russian": "", "urdu": "عقبہ بن عامر جہنی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم اپنے مریضوں", "grades": "", "reference": "", "international_number": "3444", "narrator_chain": "It was narrated that Ali said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3445", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا وَكِيعٌ، عَنْ شُعْبَةَ، عَنْ مُحَمَّدِ بْنِ الْمُنْكَدِرِ، عَنْ جَابِرٍ، قَالَ اسْتَأْذَنْتُ عَلَى النَّبِيِّ ـ صلى الله عليه وسلم ـ فَقَالَ ‏\"‏ مَنْ هَذَا ‏\"‏ ‏.‏ فَقُلْتُ أَنَا فَقَالَ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏\"‏ أَنَا أَنَا ‏\"‏ ‏.‏", "bengali": "", "english": "\"I asked the Prophet(ﷺ) for permission to enter, and he said: 'Who is that?' I said: 'Me'. The Prophet(ﷺ) said \" Me, me?!\"", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے گھر والوں کو جب بخار آ", "grades": "", "reference": "", "international_number": "3445", "narrator_chain": "It was narrated that Jabir said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3446", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا عِيسَى بْنُ يُونُسَ، عَنْ عَبْدِ اللَّهِ بْنِ مُسْلِمٍ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ سَابِطٍ، عَنْ جَابِرٍ، قَالَ قُلْتُ كَيْفَ أَصْبَحْتَ يَا رَسُولَ اللَّهِ قَالَ ‏ ‏ بِخَيْرٍ مِنْ رَجُلٍ لَمْ يُصْبِحْ صَائِمًا وَلَمْ يَعُدْ سَقِيمًا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"I said: 'How are you this morning, O Messenger of Allah?' He said: 'I am better than one who did not get up fasting, and who did not visit and sick.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Jabir said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3447", "arabic": "حَدَّثَنَا أَبُو إِسْحَاقَ الْهَرَوِيُّ، إِبْرَاهِيمُ بْنُ عَبْدِ اللَّهِ بْنِ حَاتِمٍ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ عُثْمَانَ بْنِ إِسْحَاقَ بْنِ سَعْدِ بْنِ أَبِي وَقَّاصٍ، حَدَّثَنِي جَدِّي أَبُو أُمِّي، مَالِكُ بْنُ حَمْزَةَ بْنِ أَبِي أُسَيْدٍ السَّاعِدِيُّ عَنْ أَبِيهِ، عَنْ جَدِّهِ أَبِي أُسَيْدٍ السَّاعِدِيِّ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ لِلْعَبَّاسِ بْنِ عَبْدِ الْمُطَّلِبِ وَدَخَلَ عَلَيْهِمْ فَقَالَ ‏\"‏ السَّلاَمُ عَلَيْكُمْ ‏\"‏ ‏.‏ قَالُوا وَعَلَيْكَ السَّلاَمُ وَرَحْمَةُ اللَّهِ وَبَرَكَاتُهُ ‏.‏ قَالَ ‏\"‏ كَيْفَ أَصْبَحْتُمْ ‏\"‏ ‏.‏ قَالُوا بِخَيْرٍ نَحْمَدُ اللَّهَ فَكَيْفَ أَصْبَحْتَ بِأَبِينَا وَأُمِّنَا يَا رَسُولَ اللَّهِ قَالَ ‏\"‏ أَصْبَحْتُ بِخَيْرٍ أَحْمَدُ اللَّهَ ‏\"‏ ‏.‏", "bengali": "", "english": "\"The Messenger of Allah(ﷺ) said to Abbas ibn Abdul Muttalib, when he entered upon them: \"Assalamu alaikum'. They said: 'Wa alaikas salamu wa ahmatullahi wa barakatuhu.' He said: 'How are you this morning?' They said: ' Well, praise is to Allah. And how are you this morning, may our fathers and mothers be ransomed for you, O Messenger of Allah?!' He said: 'I am well, praise is to Allah.'\"(Daif)", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  کلونجی میں", "grades": "", "reference": "", "international_number": "3447", "narrator_chain": "It was narrated that Abu Usaid Sa'idi said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3448", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، أَنْبَأَنَا سَعِيدُ بْنُ مَسْلَمَةَ، عَنِ ابْنِ عَجْلاَنَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِذَا أَتَاكُمْ كَرِيمُ قَوْمٍ فَأَكْرِمُوهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"If there comes to you a man who is respected among his own people, then honor him.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Ibn Umar that the Messenger of Allah(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3449", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، عَنْ سُلَيْمَانَ التَّيْمِيِّ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ عَطَسَ رَجُلاَنِ عِنْدَ النَّبِيِّ ـ صلى الله عليه وسلم ـ فَشَمَّتَ أَحَدَهُمَا - أَوْ سَمَّتَ - وَلَمْ يُشَمِّتِ الآخَرَ فَقِيلَ يَا رَسُولَ اللَّهِ عَطَسَ عِنْدَكَ رَجُلاَنِ فَشَمَّتَّ أَحَدَهُمَا وَلَمْ تُشَمِّتِ الآخَرَ فَقَالَ ‏ ‏ إِنَّ هَذَا حَمِدَ اللَّهَ وَإِنَّ هَذَا لَمْ يَحْمَدِ اللَّهَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Two men sneezed in he presence of the Prophet(ﷺ) and he replied (said: YarhamukAllah; may Allah have mercy on you') to one and not to the other. It was said: 'O Messenger of Allah(ﷺ), two men sneezed in your presence and you replied to one and not to the other?' He said: \"'This one praised Allah(said Al-Hamdulillah fter sneezing) but that one did not.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Anas bin Malik said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3450", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، عَنْ عِكْرِمَةَ بْنِ عَمَّارٍ، عَنْ إِيَاسِ بْنِ سَلَمَةَ بْنِ الأَكْوَعِ، عَنْ أَبِيهِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ يُشَمَّتُ الْعَاطِسُ ثَلاَثًا فَمَا زَادَ فَهُوَ مَزْكُومٌ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"The Messenger of Allah(ﷺ) said: 'The one who sneezes may be responded to three times; if he sneezes more than that, he has a cold.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Ilyas bin Salamah bin Akwa' that his father said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3451", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ، عَنِ ابْنِ أَبِي لَيْلَى، عَنْ عِيسَى، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِي لَيْلَى، عَنْ عَلِيٍّ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِذَا عَطَسَ أَحَدُكُمْ فَلْيَقُلِ الْحَمْدُ لِلَّهِ ‏.‏ وَلْيَرُدَّ عَلَيْهِ مَنْ حَوْلَهُ يَرْحَمُكَ اللَّهُ ‏.‏ وَلْيَرُدَّ عَلَيْهِمْ يَهْدِيكُمُ اللَّهُ وَيُصْلِحُ بَالَكُمْ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"If anyone of you sneezes, let him say: Alhamdulillah (praise be to Allah). Those around him should respond by saying: Yarhamkullah (may Allah have mercy on you). And he should respond by saying: \"Yahdikum Allah wa yuslaha balakum (may Allah Guide you and set right your state).\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Ali that the Messenger of Allah(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3452", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، عَنْ أَبِي يَحْيَى الطَّوِيلِ، - رَجُلٌ مِنْ أَهْلِ الْكُوفَةِ - عَنْ زَيْدٍ الْعَمِّيِّ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ كَانَ النَّبِيُّ ـ صلى الله عليه وسلم ـ إِذَا لَقِيَ الرَّجُلَ فَكَلَّمَهُ لَمْ يَصْرِفْ وَجْهَهُ عَنْهُ حَتَّى يَكُونَ هُوَ الَّذِي يَنْصَرِفُ وَإِذَا صَافَحَهُ لَمْ يَنْزِعْ يَدَهُ مِنْ يَدِهِ حَتَّى يَكُونَ هُوَ الَّذِي يَنْزِعُهَا وَلَمْ يُرَ مُتَقَدِّمًا بِرُكْبَتَيْهِ جَلِيسًا لَهُ قَطُّ ‏.‏", "bengali": "", "english": "\"Whenever the Prophet(ﷺ) met a man, he would speak to him, and would not tun away until he (the other man) was the one who turned away. And if he shook hands with him, he would not withdraw his hand until he (the other man) withdrew his hand. And he was never seen sitting with his knees ahead of the knees of the one who was sitting next to him.\"", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم دو شفاوؤں یع", "grades": "", "reference": "", "international_number": "3452", "narrator_chain": "It was narrated that Anas bin Malik  said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3453", "arabic": "حَدَّثَنَا عَمْرُو بْنُ رَافِعٍ، حَدَّثَنَا جَرِيرٌ، عَنْ سُهَيْلِ بْنِ أَبِي صَالِحٍ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ إِذَا قَامَ أَحَدُكُمْ عَنْ مَجْلِسِهِ ثُمَّ رَجَعَ فَهُوَ أَحَقُّ بِهِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"When one of you gets up from his spot, then comes back, he has more right to it.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah that the Prophet(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3454", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا سُفْيَانُ، عَنِ ابْنِ جُرَيْجٍ، عَنِ ابْنِ مِينَاءَ، عَنْ جَوْدَانَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنِ اعْتَذَرَ إِلَى أَخِيهِ بِمَعْذِرَةٍ فَلَمْ يَقْبَلْهَا كَانَ عَلَيْهِ مِثْلُ خَطِيئَةِ صَاحِبِ مَكْسٍ ‏\"\"‏ ‏.‏ حَدَّثَنَا مُحَمَّدُ بْنُ إِسْمَاعِيلَ، حَدَّثَنَا وَكِيعٌ، عَنْ سُفْيَانَ، عَنِ ابْنِ جُرَيْجٍ، عَنِ الْعَبَّاسِ بْنِ عَبْدِ الرَّحْمَنِ، - هُوَ ابْنُ مِينَاءَ - عَنْ جَوْدَانَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ مِثْلَهُ ‏.‏\"", "bengali": "", "english": "\"If a man makes an excuse to his bother and he does not accept it, he will bear a burden of sin like that of the tax-collector.\"  A hadith similar to the above has been narrated through a chain differing from the first at the 4th level of narrators.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Jawdan that the Messenger of Allah(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3455", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا وَكِيعٌ، عَنْ زَمْعَةَ بْنِ صَالِحٍ، عَنِ الزُّهْرِيِّ، عَنْ وَهْبِ بْنِ عَبْدِ بْنِ زَمْعَةَ، عَنْ أُمِّ سَلَمَةَ، ح وَحَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا زَمْعَةُ بْنُ صَالِحٍ، عَنِ الزُّهْرِيِّ، عَنْ عَبْدِ اللَّهِ بْنِ وَهْبِ بْنِ زَمْعَةَ، عَنْ أُمِّ سَلَمَةَ، قَالَتْ خَرَجَ أَبُو بَكْرٍ فِي تِجَارَةٍ إِلَى بُصْرَى قَبْلَ مَوْتِ النَّبِيِّ ـ صلى الله عليه وسلم ـ بِعَامٍ وَمَعَهُ نُعَيْمَانُ وَسُوَيْبِطُ بْنُ حَرْمَلَةَ وَكَانَا شَهِدَا بَدْرًا وَكَانَ نُعَيْمَانُ عَلَى الزَّادِ وَكَانَ سُوَيْبِطٌ رَجُلاً مَزَّاحًا فَقَالَ لِنُعَيْمَانَ أَطْعِمْنِي ‏.‏ قَالَ حَتَّى يَجِيءَ أَبُو بَكْرٍ ‏.‏ قَالَ فَلأُغِيظَنَّكَ ‏.‏ قَالَ فَمَرُّوا بِقَوْمٍ فَقَالَ لَهُمْ سُوَيْبِطٌ تَشْتَرُونَ مِنِّي عَبْدًا لِي قَالُوا نَعَمْ ‏.‏ قَالَ إِنَّهُ عَبْدٌ لَهُ كَلاَمٌ وَهُوَ قَائِلٌ لَكُمْ إِنِّي حُرٌّ ‏.‏ فَإِنْ كُنْتُمْ إِذَا قَالَ لَكُمْ هَذِهِ الْمَقَالَةَ تَرَكْتُمُوهُ فَلاَ تُفْسِدُوا عَلَىَّ عَبْدِي ‏.‏ قَالُوا لاَ بَلْ نَشْتَرِيهِ مِنْكَ ‏.‏ فَاشْتَرَوْهُ مِنْهُ بِعَشْرِ قَلاَئِصَ ثُمَّ أَتَوْهُ فَوَضَعُوا فِي عُنُقِهِ عِمَامَةً أَوْ حَبْلاً ‏.‏ فَقَالَ نُعَيْمَانُ إِنَّ هَذَا يَسْتَهْزِئُ بِكُمْ وَإِنِّي حُرٌّ لَسْتُ بِعَبْدٍ ‏.‏ فَقَالُوا قَدْ أَخْبَرَنَا خَبَرَكَ ‏.‏ فَانْطَلَقُوا بِهِ فَجَاءَ أَبُو بَكْرٍ فَأَخْبَرُوهُ بِذَلِكَ ‏.‏ قَالَ فَاتَّبَعَ الْقَوْمَ وَرَدَّ عَلَيْهِمُ الْقَلاَئِصَ وَأَخَذَ نُعَيْمَانَ ‏.‏ قَالَ فَلَمَّا قَدِمُوا عَلَى النَّبِيِّ ـ صلى الله عليه وسلم ـ وَأَخْبَرُوهُ ‏.‏ قَالَ فَضَحِكَ النَّبِيُّ ـ صلى الله عليه وسلم ـ وَأَصْحَابُهُ مِنْهُ حَوْلاً ‏.‏", "bengali": "", "english": "\"Abu Bakr went out to trade in Busra, one year before the Prophet (ﷺ) died, and with him were Nu`aiman and Suwaibit the sons of Harmalah, who had been present at Badr. Nu`aiman was in charge of the provisions, and Suwaibit was a man who joked a lot. He said to Nu`aiman: 'Feed me'. He said: 'Not until Abu Bakr comes'. He said: 'Then I will have to annoy you'. Then they passed by some people, and Suwaibit said to them: 'Will you buy a slave from me?' They said: 'Yes'. He said 'He is a slave who talks a lot and he will tell you, \"I am a free man\". If you are going to let him go when he says that to you, do not bother buying him.' They said: 'We will buy him from you.' So they bought him from him in return for ten young she-camels, then they brought him and tied a turban or a rope around his neck. Nu`aiman said: 'This man is making fun of you. I am a free man, not a slave.' They said: 'He has already told us about you; and they took him off.' Then Abu Bakr came and he (Suwaibit) told him about that. So he followed those people and returned their camels to them, and took Nu`aiman back. When they came to the Prophet (ﷺ) they told him what had happened, and the Prophet (ﷺ) and his companions laughed about it for a year.\"", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  ہم لوگ رسول اللہ صلی اللہ علیہ وسلم کے پاس گفتگو کر رہے تھے کہ کھ", "grades": "", "reference": "", "international_number": "3455", "narrator_chain": "It was narrated that Umm Salamah said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3456", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، عَنْ شُعْبَةَ، عَنْ أَبِي التَّيَّاحِ، قَالَ سَمِعْتُ أَنَسَ بْنَ مَالِكٍ، يَقُولُ كَانَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ يُخَالِطُنَا حَتَّى يَقُولَ لأَخٍ لِي صَغِيرٍ ‏ ‏ يَا أَبَا عُمَيْرٍ مَا فَعَلَ النُّغَيْرُ ‏\"\"‏ ‏.‏ قَالَ وَكِيعٌ يَعْنِي طَيْرًا كَانَ يَلْعَبُ بِهِ ‏.‏\"", "bengali": "", "english": "\"I heard Anas Bin Malik say: The Messenger of Allah (ﷺ) used to mix with us so much that he said to a little brother of mine: \"O Abu `Umair, what happened to the Nughair (one of the narrators Waki` said that it means a bird that he used to play with).\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Abu Taiyah said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3457", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدَةُ بْنُ سُلَيْمَانَ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ، عَنْ عَمْرِو بْنِ شُعَيْبٍ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنْ نَتْفِ الشَّيْبِ وَقَالَ ‏ ‏ هُوَ نُورُ الْمُؤْمِنِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"The Messenger of Allah(ﷺ) forbade plucking out white hairs and said: 'It is the light of the believer.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from 'Amr bin Sh'uaib from his father, that his grandfather said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3458", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا زَيْدُ بْنُ الْحُبَابِ، عَنْ أَبِي الْمُنِيبِ، عَنِ ابْنِ بُرَيْدَةَ، عَنْ أَبِيهِ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ نَهَى أَنْ يُقْعَدَ بَيْنَ الظِّلِّ وَالشَّمْسِ ‏.‏", "bengali": "", "english": "\"forbade sitting between the shade and sun.\"", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ایک بار دوپہر کو چلے، میں بھی چلا، ت", "grades": "", "reference": "", "international_number": "3458", "narrator_chain": "It was narrated from Ibn Buraidah, from his father, that the Prophet(ﷺ) :", "chapter_intro": "Etiquette"}
{"hadithnumber": "3459", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، عَنِ الأَوْزَاعِيِّ، عَنْ يَحْيَى بْنِ أَبِي كَثِيرٍ، عَنْ قَيْسِ بْنِ طِخْفَةَ الْغِفَارِيِّ، عَنْ أَبِيهِ، قَالَ أَصَابَنِي رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ نَائِمًا فِي الْمَسْجِدِ عَلَى بَطْنِي فَرَكَضَنِي بِرِجْلِهِ وَقَالَ ‏ ‏ مَا لَكَ وَلِهَذَا النَّوْمِ هَذِهِ نَوْمَةٌ يَكْرَهُهَا اللَّهُ أَوْ يُبْغِضُهَا اللَّهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"The Messenger of Allah(ﷺ) found me sleeping in the masjid on my stomach. He nudged me with his foot and said: 'Why are you sleeping like this? This is a kind of sleep that Allah dislikes,' or 'that Allah hates.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Qais bin Tihfah Al-Ghifari that his father said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3460", "arabic": "حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ عَبْدِ اللَّهِ، حَدَّثَنَا مُحَمَّدُ بْنُ نُعَيْمِ بْنِ عَبْدِ اللَّهِ الْمُجْمِرِ، عَنْ أَبِيهِ، عَنِ ابْنِ طِخْفَةَ الْغِفَارِيِّ، عَنْ أَبِي ذَرٍّ، قَالَ مَرَّ بِيَ النَّبِيُّ ـ صلى الله عليه وسلم ـ وَأَنَا مُضْطَجِعٌ عَلَى بَطْنِي فَرَكَضَنِي بِرِجْلِهِ وَقَالَ ‏ ‏ يَا جُنَيْدِبُ إِنَّمَا هَذِهِ ضِجْعَةُ أَهْلِ النَّارِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"The Prophet(ﷺ) passed by me and I was lying on my stomach. He nudged me with his foot and said: 'O Junaidib! This is how the people of Hell lie.'\"\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Abu Dharr said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3461", "arabic": "حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، حَدَّثَنَا سَلَمَةُ بْنُ رَجَاءٍ، عَنِ الْوَلِيدِ بْنِ جَمِيلٍ الدِّمَشْقِيِّ، أَنَّهُ سَمِعَ الْقَاسِمَ بْنَ عَبْدِ الرَّحْمَنِ، يُحَدِّثُ عَنْ أَبِي أُمَامَةَ، قَالَ مَرَّ النَّبِيُّ ـ صلى الله عليه وسلم ـ عَلَى رَجُلٍ نَائِمٍ فِي الْمَسْجِدِ مُنْبَطِحٍ عَلَى وَجْهِهِ فَضَرَبَهُ بِرِجْلِهِ وَقَالَ ‏ ‏ قُمْ وَاقْعُدْ فَإِنَّهَا نَوْمَةٌ جَهَنَّمِيَّةٌ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"The Prophet(ﷺ) passed by a man who was sleeping in the masjid, lying on his face. He struck him with his foot and said: 'Get up' or; 'Sit up, fo this is a hellish kind of sleep.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Abu Umamah said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3462", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، عَنْ عُبَيْدِ اللَّهِ بْنِ الأَخْنَسِ، عَنِ الْوَلِيدِ بْنِ عَبْدِ اللَّهِ، عَنْ يُوسُفَ بْنِ مَاهَكَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنِ اقْتَبَسَ عِلْمًا مِنَ النُّجُومِ اقْتَبَسَ شُعْبَةً مِنَ السِّحْرِ زَادَ مَا زَادَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Whoever learns about the stars, he learns a branch of magic; the more he learns (of the former) the more he learns (of the latter).\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Ibn Abbas that the Messenger of Allah(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3463", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، عَنِ الأَوْزَاعِيِّ، عَنِ الزُّهْرِيِّ، حَدَّثَنَا ثَابِتٌ الزُّرَقِيُّ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لاَ تَسُبُّوا الرِّيحَ فَإِنَّهَا مِنْ رَوْحِ اللَّهِ تَأْتِي بِالرَّحْمَةِ وَالْعَذَابِ وَلَكِنْ سَلُوا اللَّهَ مِنْ خَيْرِهَا وَتَعَوَّذُوا بِاللَّهِ مِنْ شَرِّهَا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Do not curse the wind, for it is from the mercy of Allah, bringing Rahmah (i.e., rain and breezes), or destruction. But ask Allah for its goodness, and seek refuge with Allah from its evil.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah that the Messenger of Allah(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3464", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ، حَدَّثَنَا الْعُمَرِيُّ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ أَحَبُّ الأَسْمَاءِ إِلَى اللَّهِ عَزَّ وَجَلَّ عَبْدُ اللَّهِ وَعَبْدُ الرَّحْمَنِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"The most beloved of names to Allah are 'Abdullah and 'Abdur-Rahman.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Ibn 'Umar that the Prophet(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3465", "arabic": "حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ، حَدَّثَنَا أَبُو أَحْمَدَ، حَدَّثَنَا سُفْيَانُ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، عَنْ عُمَرَ بْنِ الْخَطَّابِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لَئِنْ عِشْتُ إِنْ شَاءَ اللَّهُ لأَنْهَيَنَّ أَنْ يُسَمَّى رَبَاحٌ وَنَجِيحٌ وَأَفْلَحُ وَنَافِعٌ وَيَسَارٌ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"If I live- if Allah wills - I will forbid the names Rabah(profit), Najih(saved), Aflah (Successful), Nafi (beneficial) and Yasar(prosperity).\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from 'Umar ibn Al-Khattab that the Prophet(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3466", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا الْمُعْتَمِرُ بْنُ سُلَيْمَانَ، عَنِ الرُّكَيْنِ، عَنْ أَبِيهِ، عَنْ سَمُرَةَ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ أَنْ نُسَمِّيَ رَقِيقَنَا أَرْبَعَةَ أَسْمَاءٍ أَفْلَحُ وَنَافِعٌ وَرَبَاحٌ وَيَسَارٌ ‏.‏", "bengali": "", "english": "\"The Messenger of Allah(ﷺ) forbade giving our slaves four names: Aflah (successful), Nafi' (beneficial), Rabah (profit) and Yasar(prosperity).\"", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص", "grades": "", "reference": "", "international_number": "3466", "narrator_chain": "It was narrated that Samurah said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3467", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا هَاشِمُ بْنُ الْقَاسِمِ، حَدَّثَنَا أَبُو عَقِيلٍ، حَدَّثَنَا مُجَالِدُ بْنُ سَعِيدٍ، عَنِ الشَّعْبِيِّ، عَنْ مَسْرُوقٍ، قَالَ لَقِيتُ عُمَرَ بْنَ الْخَطَّابِ فَقَالَ مَنْ أَنْتَ فَقُلْتُ مَسْرُوقُ بْنُ الأَجْدَعِ ‏.‏ فَقَالَ عُمَرُ سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ الأَجْدَعُ شَيْطَانٌ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"I met 'Umar bin Khattab and he said: 'Who are you?' I said: 'Masruq bin Adja'.' 'Umar said: 'I heard the Messenger of Allah(ﷺ) saying,\"Ajda' is a devil.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Masruq said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3468", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا غُنْدَرٌ، عَنْ شُعْبَةَ، عَنْ عَطَاءِ بْنِ أَبِي مَيْمُونَةَ، قَالَ سَمِعْتُ أَبَا رَافِعٍ، يُحَدِّثُ عَنْ أَبِي هُرَيْرَةَ، أَنَّ زَيْنَبَ، كَانَ اسْمُهَا بَرَّةَ فَقِيلَ لَهَا تُزَكِّي نَفْسَهَا فَسَمَّاهَا رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ زَيْنَبَ ‏.‏", "bengali": "", "english": "\"Zainab used to be called \"Barrah\" (good), and it was said that she was praising herself. So the Messenger of Allah(ﷺ) changed her name to Zainab.\"", "french": "", "indonesian": "", "russian": "", "urdu": "ام قیس بنت محصن رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تمہارے لیے «عود", "grades": "", "reference": "", "international_number": "3468", "narrator_chain": "It was narrated from Abu Hurairah that:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3469", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا الْحَسَنُ بْنُ مُوسَى، حَدَّثَنَا حَمَّادُ بْنُ سَلَمَةَ، عَنْ عُبَيْدِ اللَّهِ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ ابْنَةً لِعُمَرَ، كَانَ يُقَالُ لَهَا عَاصِيَةُ فَسَمَّاهَا رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ جَمِيلَةَ ‏.‏", "bengali": "", "english": "\"a daughter of 'Umar was Asiyah(disobedient) then the Messenger of Allah(ﷺ) named her 'Jamilah' (beautiful).\"", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے پاس بخار کا ذکر آیا تو ایک شخص ن", "grades": "", "reference": "", "international_number": "3469", "narrator_chain": "It was narrated from Ibn Umar that:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3470", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا يَحْيَى بْنُ يَعْلَى أَبُو الْمُحَيَّاةِ، عَنْ عَبْدِ الْمَلِكِ بْنِ عُمَيْرٍ، حَدَّثَنَى ابْنُ أَخِي عَبْدِ اللَّهِ بْنِ سَلاَمٍ، عَنْ عَبْدِ اللَّهِ بْنِ سَلاَمٍ، قَالَ قَدِمْتُ عَلَى رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ وَلَيْسَ اسْمِي عَبْدَ اللَّهِ بْنَ سَلاَمٍ فَسَمَّانِي رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَبْدَ اللَّهِ بْنَ سَلاَمٍ ‏.‏", "bengali": "", "english": "\"I came to the Messenger of Allah(ﷺ), and my name was not Abdullah bin Salam. The Messenger of Allah(ﷺ) named me Abdullah bin Salam.\"", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے بخار کے ایک مریض کی عیادت کی، آپ ک", "grades": "", "reference": "", "international_number": "3470", "narrator_chain": "It was narrated that Abdullah bin Salam said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3471", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ أَيُّوبَ، عَنْ مُحَمَّدٍ، قَالَ سَمِعْتُ أَبَا هُرَيْرَةَ، يَقُولُ قَالَ أَبُو الْقَاسِمِ ـ صلى الله عليه وسلم ـ ‏ ‏ تَسَمَّوْا بِاسْمِي وَلاَ تَكَنَّوْا بِكُنْيَتِي ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Abul Qasim(ﷺ) said: 'Call yourselves by my name but do not call yourselves by my Kunyah.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Muhammad that they heard Abu Hurairah say:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3472", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، عَنِ الأَعْمَشِ، عَنْ أَبِي سُفْيَانَ، عَنْ جَابِرٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ تَسَمَّوْا بِاسْمِي وَلاَ تَكَنَّوْا بِكُنْيَتِي ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Call yourselves by my name but do not call yourselves by my Kunyah.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Jabir that the Messenger of Allah(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3473", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ الْوَهَّابِ الثَّقَفِيُّ، عَنْ حُمَيْدٍ، عَنْ أَنَسٍ، قَالَ كَانَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ بِالْبَقِيعِ فَنَادَى رَجُلٌ رَجُلاً يَا أَبَا الْقَاسِمِ فَالْتَفَتَ إِلَيْهِ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ فَقَالَ إِنِّي لَمْ أَعْنِكَ ‏.‏ فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ تَسَمَّوْا بِاسْمِي وَلاَ تَكْتَنُوا بِكُنْيَتِي ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"The Messenger of Allah(ﷺ) was in Baqi', and a man called out to another man: 'O Abul-Qasim!' The Messenger of Allah(ﷺ) turned to him, and he said: 'I didn't mean you.' The Messenger of Allah(ﷺ) said: 'Call yourselves by my name but do not call yourselves by my Kunyah.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Anas said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3474", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَحْيَى بْنُ أَبِي بُكَيْرٍ، حَدَّثَنَا زُهَيْرُ بْنُ مُحَمَّدٍ، عَنْ عَبْدِ اللَّهِ بْنِ مُحَمَّدِ بْنِ عَقِيلٍ، عَنْ حَمْزَةَ بْنِ صُهَيْبٍ، أَنَّ عُمَرَ، قَالَ لِصُهَيْبٍ مَا لَكَ تَكْتَنِي بِأَبِي يَحْيَى وَلَيْسَ لَكَ وَلَدٌ ‏.‏ قَالَ كَنَّانِي رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ بِأَبِي يَحْيَى ‏.‏", "bengali": "", "english": "\"Why are you called Abu Yahya when you do not have a son?\" He said: \"The Messenger of Allah(ﷺ) gave me the Kunya of Abu Yahya.\"", "french": "", "indonesian": "", "russian": "", "urdu": "اسماء بنت ابی بکر رضی اللہ عنہما سے روایت ہے کہ  ان کے پاس بخار کی مریضہ ایک عورت لائی جاتی تھی، تو", "grades": "", "reference": "", "international_number": "3474", "narrator_chain": "It was narrated from Hamzah bin Suhaib that Umar said to Suhaib:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3475", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا وَكِيعٌ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ مَوْلًى، لِلزُّبَيْرِ عَنْ عَائِشَةَ، ‏.‏ أَنَّهَا قَالَتْ لِلنَّبِيِّ ـ صلى الله عليه وسلم ـ كُلُّ أَزْوَاجِكَ كَنَّيْتَهُ غَيْرِي ‏.‏ قَالَ ‏ ‏ فَأَنْتِ أُمُّ عَبْدِ اللَّهِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"All of your wives have a Kunyah except me.\" He said: \"You are Umm Abdullah\".", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Aisha that she said to the Prophet(ﷺ):", "chapter_intro": "Etiquette"}
{"hadithnumber": "3476", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا وَكِيعٌ، عَنْ شُعْبَةَ، عَنْ أَبِي التَّيَّاحِ، عَنْ أَنَسٍ، قَالَ كَانَ النَّبِيُّ ـ صلى الله عليه وسلم ـ يَأْتِينَا فَيَقُولُ لأَخٍ لِي وَكَانَ صَغِيرًا ‏ ‏ يَا أَبَا عُمَيْرٍ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"The Prophet(ﷺ) used to come to us and say to a brother of mine, who was small: 'O Abu Umair.'\".", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Anas said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3477", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ إِدْرِيسَ، عَنْ دَاوُدَ، عَنِ الشَّعْبِيِّ، عَنْ أَبِي جَبِيرَةَ بْنِ الضَّحَّاكِ، قَالَ فِينَا نَزَلَتْ مَعْشَرَ الأَنْصَارِ ‏{وَلاَ تَنَابَزُوا بِالأَلْقَابِ‏)‏ قَدِمَ عَلَيْنَا النَّبِيُّ ـ صلى الله عليه وسلم ـ وَالرَّجُلُ مِنَّا لَهُ الاِسْمَانِ وَالثَّلاَثَةُ فَكَانَ النَّبِيُّ ـ صلى الله عليه وسلم ـ رُبَّمَا دَعَاهُمْ بِبَعْضِ تِلْكَ الأَسْمَاءِ فَيُقَالُ يَا رَسُولَ اللَّهِ إِنَّهُ يَغْضَبُ مِنْ هَذَا ‏.‏ فَنَزَلَتْ ‏{وَلاَ تَنَابَزُوا بِالأَلْقَابِ}‏ ‏.‏", "bengali": "", "english": "\"(Allah's saying) \"Nor insult one another by nicknames(Surah Al Hujarat 49:11)\" was revealed concerning us, the Ansar. When the Prophet(ﷺ) came to us, a man among us would have two or three names, and the Prophet(ﷺ) might call him by one of those names, only to be told: \"O Messenger of Allah(ﷺ), he does not like that name.\" Then:\"Nor insult one another by nicknames.\" was revealed.\"", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  معراج کی رات", "grades": "", "reference": "", "international_number": "3477", "narrator_chain": "It was narrated that Abu Jabirah bin Dahhak said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3478", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، عَنْ سُفْيَانَ، عَنْ حَبِيبِ بْنِ أَبِي ثَابِتٍ، عَنْ مُجَاهِدٍ، عَنْ أَبِي مَعْمَرٍ، عَنِ الْمِقْدَادِ بْنِ عَمْرٍو، قَالَ أَمَرَنَا رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ أَنْ نَحْثُوَ فِي وُجُوهِ الْمَدَّاحِينَ التُّرَابَ ‏.‏", "bengali": "", "english": "\"The Messenger of Allah(ﷺ) commanded us to throw dust in the faces of those who praise others.\"", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  پچھنا لگانے وال", "grades": "", "reference": "", "international_number": "3478", "narrator_chain": "It was narrated that Miqdad bin 'Amr said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3479", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا غُنْدَرٌ، عَنْ شُعْبَةَ، عَنْ سَعْدِ بْنِ إِبْرَاهِيمَ بْنِ عَبْدِ الرَّحْمَنِ بْنِ عَوْفٍ، عَنْ مَعْبَدٍ الْجُهَنِيِّ، عَنْ مُعَاوِيَةَ، قَالَ سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ إِيَّاكُمْ وَالتَّمَادُحَ فَإِنَّهُ الذَّبْحُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"I heard the Messenger of Allah(ﷺ) say: 'Beware of praising one another, for it is slaughtering (one another).'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Muawiyah said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3480", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا شَبَابَةُ، حَدَّثَنَا شُعْبَةُ، عَنْ خَالِدٍ الْحَذَّاءِ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِي بَكْرَةَ، عَنْ أَبِيهِ، قَالَ مَدَحَ رَجُلٌ رَجُلاً عِنْدَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏\"‏ وَيْحَكَ قَطَعْتَ عُنُقَ صَاحِبِكَ ‏\"‏ ‏.‏ مِرَارًا ثُمَّ قَالَ ‏\"‏ إِنْ كَانَ أَحَدُكُمْ مَادِحًا أَخَاهُ فَلْيَقُلْ أَحْسِبُهُ وَلاَ أُزَكِّي عَلَى اللَّهِ أَحَدًا ‏\"‏ ‏.‏", "bengali": "", "english": "\"A man praised another man in the presence of Messenger of Allah(ﷺ). The Messenger of Allah(ﷺ) said: 'Woe to you,you have cut the neck of your companion,'several times. Then he said: 'If anyone of you praises his brother, let him say: \"I think he is lie this, but I do not sanctify anyone before Allah.\"", "french": "", "indonesian": "", "russian": "", "urdu": "جابر رضی اللہ عنہ سے روایت ہے کہ  ام المؤمنین ام سلمہ رضی اللہ عنہا نے رسول اللہ صلی اللہ علیہ وسلم", "grades": "", "reference": "", "international_number": "3480", "narrator_chain": "It was narrated from Abdur-Rahman bin Abu Bakrah that his father said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3481", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَحْيَى بْنُ أَبِي بُكَيْرٍ، عَنْ شَيْبَانَ، عَنْ عَبْدِ الْمَلِكِ بْنِ عُمَيْرٍ، عَنْ أَبِي سَلَمَةَ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ الْمُسْتَشَارُ مُؤْتَمَنٌ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"One who is consulted is entrusted.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah that the Messenger of Allah(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3482", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَسْوَدُ بْنُ عَامِرٍ، عَنْ شَرِيكٍ، عَنِ الأَعْمَشِ، عَنْ أَبِي عَمْرٍو الشَّيْبَانِيِّ، عَنْ أَبِي مَسْعُودٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ الْمُسْتَشَارُ مُؤْتَمَنٌ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"One who is consulted is entrusted.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Mas'ud that the Messenger of Allah(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3483", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا يَحْيَى بْنُ زَكَرِيَّا بْنِ أَبِي زَائِدَةَ، وَعَلِيُّ بْنُ هَاشِمٍ، عَنِ ابْنِ أَبِي لَيْلَى، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِذَا اسْتَشَارَ أَحَدُكُمْ أَخَاهُ فَلْيُشِرْ عَلَيْهِ ‏\"\"‏ ‏.\"", "bengali": "", "english": "\"If one of you consults his brother, then let him advise him.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Jabir that that the Messenger of Allah(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3484", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا عَبْدَةُ بْنُ سُلَيْمَانَ، ح وَحَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا خَالِي، يَعْلَى وَجَعْفَرُ بْنُ عَوْنٍ جَمِيعًا عَنْ عَبْدِ الرَّحْمَنِ بْنِ زِيَادِ بْنِ أَنْعُمٍ الإِفْرِيقِيِّ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ رَافِعٍ، عَنْ عَبْدِ اللَّهِ بْنِ عَمْرٍو، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ تُفْتَحُ لَكُمْ أَرْضُ الأَعَاجِمِ وَسَتَجِدُونَ فِيهَا بُيُوتًا يُقَالُ لَهَا الْحَمَّامَاتُ فَلاَ يَدْخُلْهَا الرِّجَالُ إِلاَّ بِإِزَارٍ وَامْنَعُوا النِّسَاءَ أَنْ يَدْخُلْنَهَا إِلاَّ مَرِيضَةً أَوْ نُفَسَاءَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"The Messenger of Allah(ﷺ) said: 'You will conquer the lands of the non-Arabs, where you will find houses called Hammamat (bathhouses). Men Should only enter them wearing a waist wrap, and do not let women enter them unless they are sick or bleeding following childbirth.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Abdullah bin Amr said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3485", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، ح وَحَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَفَّانُ، قَالاَ حَدَّثَنَا حَمَّادُ بْنُ سَلَمَةَ، أَنْبَأَنَا عَبْدُ اللَّهِ بْنُ شَدَّادٍ، عَنْ أَبِي عُذْرَةَ، - قَالَ وَكَانَ قَدْ أَدْرَكَ النَّبِيَّ ـ صلى الله عليه وسلم ـ - عَنْ عَائِشَةَ أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ نَهَى الرِّجَالَ وَالنِّسَاءَ مِنَ الْحَمَّامَاتِ ثُمَّ رَخَّصَ لِلرِّجَالِ أَنْ يَدْخُلُوهَا فِي الْمَيَازِرِ وَلَمْ يُرَخِّصْ لِلنِّسَاءِ ‏.‏", "bengali": "", "english": "forbade men and women to enter bathhouses, then he allowed men to enter them wearing a waist wrap, but he did not make the same allowance for women.", "french": "", "indonesian": "", "russian": "", "urdu": "جابر رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم ایک بار اپنے گھوڑے سے کھجور کے درخت کی", "grades": "", "reference": "", "international_number": "3485", "narrator_chain": "It was narrated from Aisha that the Prophet(ﷺ):", "chapter_intro": "Etiquette"}
{"hadithnumber": "3486", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، عَنْ سُفْيَانَ، عَنْ مَنْصُورٍ، عَنْ سَالِمِ بْنِ أَبِي الْجَعْدِ، عَنْ أَبِي الْمَلِيحِ الْهُذَلِيِّ، أَنَّ نِسْوَةً، مِنْ أَهْلِ حِمْصَ اسْتَأْذَنَّ عَلَى عَائِشَةَ فَقَالَتْ لَعَلَّكُنَّ مِنَ اللَّوَاتِي يَدْخُلْنَ الْحَمَّامَاتِ سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ أَيُّمَا امْرَأَةٍ وَضَعَتْ ثِيَابَهَا فِي غَيْرِ بَيْتِ زَوْجِهَا فَقَدْ هَتَكَتْ سِتْرَ مَا بَيْنَهَا وَبَيْنَ اللَّهِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Perhaps you are among those (women) who enter bathhouses? I heard the Messenger of Allah(ﷺ) say: 'Any woman who takes off her clothes anywhere but in her husband's house, has torn the screen between her and Allah.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Malih AL-HUdhail that some women from the people of Hims asked permission to enter upon Aisha. She said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3487", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ عَبْدِ اللَّهِ، حَدَّثَنَا حَمَّادُ بْنُ سَلَمَةَ، عَنْ أَبِي هَاشِمٍ الرُّمَّانِيِّ، عَنْ حَبِيبِ بْنِ أَبِي ثَابِتٍ، عَنْ أُمِّ سَلَمَةَ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ كَانَ إِذَا اطَّلَى بَدَأَ بِعَوْرَتِهِ فَطَلاَهَا بِالنُّورَةِ وَسَائِرَ جَسَدِهِ أَهْلُهُ ‏.‏", "bengali": "", "english": "he began with his private area, coating it with hair removing chemical. And his wife would do the remainder of his body.", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  انہوں نے  ( اپنے غلام )  نافع سے کہا: نافع! میرے خون میں", "grades": "", "reference": "", "international_number": "3487", "narrator_chain": "It was narrated from Umm Salamah that when the Prophet(ﷺ) would apply (it):", "chapter_intro": "Etiquette"}
{"hadithnumber": "3488", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنِي إِسْحَاقُ بْنُ مَنْصُورٍ، عَنْ كَامِلٍ أَبِي الْعَلاَءِ، عَنْ حَبِيبِ بْنِ أَبِي ثَابِتٍ، عَنْ أُمِّ سَلَمَةَ، أَنَّ النَّبِيَّ اطَّلَى وَوَلِيَ عَانَتَهُ بِيَدِهِ ‏.‏", "bengali": "", "english": "\"the Prophet(ﷺ) would coat (with hair removing chemical) and remove the pubic hairs with his hand.\"", "french": "", "indonesian": "", "russian": "", "urdu": "نافع کہتے ہیں کہ  ابن عمر رضی اللہ عنہما نے کہا: نافع! میرا خون جوش میں ہے، لہٰذا کوئی پچھنا لگانے و", "grades": "", "reference": "", "international_number": "3488", "narrator_chain": "It was narrated from Umm Salamah that:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3489", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا الْهِقْلُ بْنُ زِيَادٍ، حَدَّثَنَا الأَوْزَاعِيُّ، عَنْ عَبْدِ اللَّهِ بْنِ عَامِرٍ الأَسْلَمِيِّ، عَنْ عَمْرِو بْنِ شُعَيْبٍ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ لاَ يَقُصُّ عَلَى النَّاسِ إِلاَّ أَمِيرٌ أَوْ مَأْمُورٌ أَوْ مُرَاءٍ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"No one tells the stories to the people (for the purpose of exhortation) except a ruler, one appointed by a ruler, or a show-off.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Amr bin Shuaib, from his father, from his grandfather, that the Messenger of Allah(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3490", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، عَنِ الْعُمَرِيِّ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ لَمْ يَكُنِ الْقَصَصُ فِي زَمَنِ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ وَلاَ زَمَنِ أَبِي بَكْرٍ وَلاَ زَمَنِ عُمَرَ ‏.‏", "bengali": "", "english": "\"Stories (for the purpose of exhortation) were unknown at the time of the Messenger of Allah(ﷺ), the time of Abu Bakr and Umar.\"", "french": "", "indonesian": "", "russian": "", "urdu": "عمران بن حصین رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے  ( آگ یا لوہے سے جسم )  د", "grades": "", "reference": "", "international_number": "3490", "narrator_chain": "It was narrated that Ibn Umar said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3491", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ، عَنْ يُونُسَ، عَنِ الزُّهْرِيِّ، حَدَّثَنَا أَبُو بَكْرِ بْنُ عَبْدِ الرَّحْمَنِ بْنِ الْحَارِثِ، عَنْ مَرْوَانَ بْنِ الْحَكَمِ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ بْنِ عَبْدِ يَغُوثَ، عَنْ أُبَىِّ بْنِ كَعْبٍ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ إِنَّ مِنَ الشِّعْرِ لَحِكْمَةً ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"In some poetry there is wisdom.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Ubbay bin Ka'b that the Messenger of Allah(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3492", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا أَبُو أُسَامَةَ، عَنْ زَائِدَةَ، عَنِ سِمَاكٍ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ كَانَ يَقُولُ ‏ ‏ إِنَّ مِنَ الشِّعْرِ حِكَمًا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"In some poetry there is wisdom.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Ibn Abbas that the Prophet(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3493", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عَبْدِ الْمَلِكِ بْنِ عُمَيْرٍ، عَنْ أَبِي سَلَمَةَ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ أَصْدَقُ كَلِمَةٍ قَالَهَا الشَّاعِرُ كَلِمَةُ لَبِيدٍ أَلاَ كُلُّ شَىْءٍ مَا خَلاَ اللَّهَ بَاطِلُ وَكَادَ أُمَيَّةُ بْنُ أَبِي الصَّلْتِ أَنْ يُسْلِمَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"The truest of wods spoken by the poet are the words of Labid: Everything except Allah is false.' And Abu Umayyah bin Abu Salt nearly accepted Islam.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah that the Messenger of Allah(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3494", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عِيسَى بْنُ يُونُسَ، عَنْ عَبْدِ اللَّهِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ يَعْلَى، عَنْ عَمْرِو بْنِ الشَّرِيدِ، عَنْ أَبِيهِ، قَالَ أَنْشَدْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ مِائَةَ قَافِيَةٍ مِنْ شِعْرِ أُمَيَّةَ بْنِ أَبِي الصَّلْتِ يَقُولُ بَيْنَ كُلِّ قَافِيَةٍ ‏\"‏ هِيهِ ‏\"‏ ‏.‏ وَقَالَ ‏\"‏ كَادَ أَنْ يُسْلِمَ ‏\"‏ ‏.‏", "bengali": "", "english": "\"I recited one hundered verses of the poetry of Umayyah bin Abu Salt to the Messenger of Allah(ﷺ), and after every line he said, \"More\". And he said: \"He nearly accepted Islam.\"", "french": "", "indonesian": "", "russian": "", "urdu": "جابر بن عبداللہ رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے سعد بن معاذ رضی اللہ", "grades": "", "reference": "", "international_number": "3494", "narrator_chain": "It was narrated from Amr bin Sharid that his father said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3495", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا حَفْصٌ، وَأَبُو مُعَاوِيَةَ وَوَكِيعٌ عَنِ الأَعْمَشِ، عَنْ أَبِي صَالِحٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لأَنْ يَمْتَلِئَ جَوْفُ الرَّجُلِ قَيْحًا حَتَّى يَرِيَهُ خَيْرٌ لَهُ مِنْ أَنْ يَمْتَلِئَ شِعْرًا ‏\"\"‏ ‏.‏ إِلاَّ أَنَّ حَفْصًا لَمْ يَقُلْ يَرِيَهُ ‏.‏\"", "bengali": "", "english": "\"If a man were to fill his stomach completely with pus until it destroyed him, that would be better for him than filling (his mind) with poetry.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah that the Messenger of Allah(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3496", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، وَمُحَمَّدُ بْنُ جَعْفَرٍ، قَالاَ حَدَّثَنَا شُعْبَةُ، حَدَّثَنِي قَتَادَةُ، عَنْ يُونُسَ بْنِ جُبَيْرٍ، عَنْ مُحَمَّدِ بْنِ سَعْدِ بْنِ أَبِي وَقَّاصٍ، عَنْ سَعْدِ بْنِ أَبِي وَقَّاصٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ لأَنْ يَمْتَلِئَ جَوْفُ أَحَدِكُمْ قَيْحًا حَتَّى يَرِيَهُ خَيْرٌ لَهُ مِنْ أَنْ يَمْتَلِئَ شِعْرًا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"If a man were to fill his stomach completely with pus until it destroyed him, that would be better for him than filling (his mind) with poetry.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Sad bin Abu Waqas that the Prophet(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3497", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عُبَيْدُ اللَّهِ، عَنْ شَيْبَانَ، عَنِ الأَعْمَشِ، عَنْ عَمْرِو بْنِ مُرَّةَ، عَنْ يُوسُفَ بْنِ مَاهَكَ، عَنْ عُبَيْدِ بْنِ عُمَيْرٍ، عَنْ عَائِشَةَ، قَالَتْ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِنَّ أَعْظَمَ النَّاسِ فِرْيَةً لَرَجُلٌ هَاجَى رَجُلاً فَهَجَا الْقَبِيلَةَ بِأَسْرِهَا وَرَجُلٌ انْتَفَى مِنْ أَبِيهِ وَزَنَّى أُمَّهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"The worst of all people lying is a man who trades insults with another man, disparaging the entire tribe, and a man who denies his father and accuses his mother of adultery.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Aisha that the Messenger of Allah(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3498", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ سُلَيْمَانَ، وَأَبُو أُسَامَةَ عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ نَافِعٍ، عَنْ سَعِيدِ بْنِ أَبِي هِنْدٍ، عَنْ أَبِي مُوسَى، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ لَعِبَ بِالنَّرْدِ فَقَدْ عَصَى اللَّهَ وَرَسُولَهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"The Messenger of Allah(ﷺ) said: 'Whoever plays backgammon has disobeyed Allah and His Messenger.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Abu Musa said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3499", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، وَأَبُو أُسَامَةَ عَنْ سُفْيَانَ، عَنْ عَلْقَمَةَ بْنِ مَرْثَدٍ، عَنْ سُلَيْمَانَ بْنِ بُرَيْدَةَ، عَنْ أَبِيهِ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ مَنْ لَعِبَ بِالنَّرْدَشِيرِ فَكَأَنَّمَا غَمَسَ يَدَهُ فِي لَحْمِ خِنْزِيرٍ وَدَمِهِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Whoever plays backgammon, it is as if he dipped his hand in the flesh and blood of a pig.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Sulaiman bin Buraidah from his father that the Prophet(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3500", "arabic": "حَدَّثَنَا عَبْدُ اللَّهِ بْنُ عَامِرِ بْنِ زُرَارَةَ، حَدَّثَنَا شَرِيكٌ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو، عَنْ أَبِي سَلَمَةَ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ عَائِشَةَ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ نَظَرَ إِلَى إِنْسَانٍ يَتْبَعُ طَائِرًا فَقَالَ ‏ ‏ شَيْطَانٌ يَتْبَعُ شَيْطَانًا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"A devil chasing a devil.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from 'Aishah that the Prophet(ﷺ) looked at a man who was chasing a bird and said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3501", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا الأَسْوَدُ بْنُ عَامِرٍ، عَنْ حَمَّادِ بْنِ سَلَمَةَ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو، عَنْ أَبِي سَلَمَةَ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ رَأَى رَجُلاً يَتْبَعُ حَمَامَةً فَقَالَ ‏ ‏ شَيْطَانٌ يَتْبَعُ شَيْطَانَةً ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"A male devil following a female devil.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah that the Prophet(ﷺ) saw a man chasing a pigeon and said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3502", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا يَحْيَى بْنُ سُلَيْمٍ الطَّائِفِيُّ، حَدَّثَنَا ابْنُ جُرَيْجٍ، عَنِ الْحَسَنِ بْنِ أَبِي الْحَسَنِ، عَنْ عُثْمَانَ بْنِ عَفَّانَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ رَأَى رَجُلاً وَرَاءَ حَمَامَةٍ فَقَالَ ‏ ‏ شَيْطَانٌ يَتْبَعُ شَيْطَانَةً ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"A male devil chasing a female devil.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Uthman bin Affan that the Messenger of Allah(ﷺ) saw a man following a pigeon and said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3503", "arabic": "حَدَّثَنَا أَبُو نَصْرٍ، مُحَمَّدُ بْنُ خَلَفٍ الْعَسْقَلاَنِيُّ حَدَّثَنَا رَوَّادُ بْنُ الْجَرَّاحِ، حَدَّثَنَا أَبُو سَعْدٍ السَّاعِدِيُّ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ رَأَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ رَجُلاً يَتْبَعُ حَمَامًا فَقَالَ ‏ ‏ شَيْطَانٌ يَتْبَعُ شَيْطَانًا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"The Messenger of Allah(ﷺ) saw a man chasing a pigeon and said: 'A devil chasing a devil.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Anas bin Malik said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3504", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا وَكِيعٌ، عَنْ عَاصِمِ بْنِ مُحَمَّدٍ، عَنْ أَبِيهِ، عَنِ ابْنِ عُمَرَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لَوْ يَعْلَمُ أَحَدُكُمْ مَا فِي الْوَحْدَةِ مَا سَارَ أَحَدٌ بِلَيْلٍ وَحْدَهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"If anyone of you knew what is wrong with being alone, no one would travel at night by himself.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Ibn 'Umar that the Messenger of Allah(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3505", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ الزُّهْرِيِّ، عَنْ سَالِمٍ، عَنْ أَبِيهِ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ لاَ تَتْرُكُوا النَّارَ فِي بُيُوتِكُمْ حِينَ تَنَامُونَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Do not leave fire in your houses when you go to sleep.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Salim, from his father, that the Prophet(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3506", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو أُسَامَةَ، عَنْ بُرَيْدِ بْنِ عَبْدِ اللَّهِ، عَنْ أَبِي بُرْدَةَ، عَنْ أَبِي مُوسَى، قَالَ احْتَرَقَ بَيْتٌ بِالْمَدِينَةِ عَلَى أَهْلِهِ فَحُدِّثَ النَّبِيُّ ـ صلى الله عليه وسلم ـ بِشَأْنِهِمْ فَقَالَ ‏ ‏ إِنَّمَا هَذِهِ النَّارُ عَدُوٌّ لَكُمْ فَإِذَا نِمْتُمْ فَأَطْفِئُوهَا عَنْكُمْ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"A house burned down in Al-Madinah, with its occupants inside. The Prophet(ﷺ) was told of what had happened, and he said: 'This fire is an enemy to you. When you go to sleep, extinguish it.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Abu Musa said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3507", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، عَنْ عَبْدِ الْمَلِكِ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، قَالَ أَمَرَنَا رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ وَنَهَانَا فَأَمَرَنَا أَنْ نُطْفِئَ سِرَاجَنَا ‏.‏", "bengali": "", "english": "\"The Messenger of Allah(ﷺ) commanded us (to do some things) and forbade us (to do some things), and he commanded us to extinguish our lamps.\"", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  نظر کا لگنا حقیقت ہے ۔", "grades": "", "reference": "", "international_number": "3507", "narrator_chain": "It was narrated that Jabir said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3508", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، أَنْبَأَنَا هِشَامٌ، عَنِ الْحَسَنِ، عَنْ جَابِرٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لاَ تَنْزِلُوا عَلَى جَوَادِّ الطَّرِيقِ وَلاَ تَقْضُوا عَلَيْهَا الْحَاجَاتِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Do not camp on the middle of the road, or relieve yourselves there.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Jabir that the Messenger of Allah(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3509", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ سُلَيْمَانَ، عَنْ عَاصِمٍ، حَدَّثَنَا مُوَرِّقٌ الْعِجْلِيُّ، حَدَّثَنِي عَبْدُ اللَّهِ بْنُ جَعْفَرٍ، قَالَ كَانَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ إِذَا قَدِمَ مِنْ سَفَرٍ تُلُقِّيَ بِنَا ‏.‏ قَالَ فَتُلُقِّيَ بِي وَبِالْحَسَنِ أَوْ بِالْحُسَيْنِ ‏.‏ قَالَ فَحَمَلَ أَحَدَنَا بَيْنَ يَدَيْهِ وَالآخَرَ خَلْفَهُ حَتَّى قَدِمْنَا الْمَدِينَةَ ‏\"‏ ‏.‏", "bengali": "", "english": "\"Whenever the Messenger of Allah(ﷺ) came back from a journey, he would be met by us(children). (One day) he was met by me and Hasan or Husain. He made one of us ride in front of him and the other behind him, until we came to Al-Madinah.\"", "french": "", "indonesian": "", "russian": "", "urdu": "ابوامامہ بن سہل بن حنیف رضی اللہ عنہ کہتے ہیں کہ  عامر بن ربیعہ رضی اللہ عنہ کا گزر سہل بن حنیف رضی", "grades": "", "reference": "", "international_number": "3509", "narrator_chain": "Abdullah bin Ja'far said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3510", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، أَنْبَأَنَا بَقِيَّةُ، أَنْبَأَنَا أَبُو أَحْمَدَ الدِّمَشْقِيُّ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ تَرِّبُوا صُحُفَكُمْ أَنْجَحُ لَهَا إِنَّ التُّرَابَ مُبَارَكٌ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Put dust on your writings, because it is better, and dust is blessed (being humble in correspondence brings good results).\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Jabir that the Messenger of Allah(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3511", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، وَوَكِيعٌ، عَنِ الأَعْمَشِ، عَنْ شَقِيقٍ، عَنْ عَبْدِ اللَّهِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِذَا كُنْتُمْ ثَلاَثَةً فَلاَ يَتَنَاجَى اثْنَانِ دُونَ صَاحِبِهِمَا فَإِنَّ ذَلِكَ يُحْزِنُهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"When you are three, two should  not converse (privately) to the exclusion of their companion, because that makes him sad.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abdullah that the Messenger of Allah(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3512", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عَبْدِ اللَّهِ بْنِ دِينَارٍ، عَنِ ابْنِ عُمَرَ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ أَنْ يَتَنَاجَى اثْنَانِ دُونَ الثَّالِثِ ‏.‏", "bengali": "", "english": "\"The Messenger of Allah(ﷺ) forbade two to converse (privately) to the exclusion of a third.\"", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے انہیں نظر بد لگ جانے پر", "grades": "", "reference": "", "international_number": "3512", "narrator_chain": "It was narrated that Ibn 'Umar said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3513", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا سُفَيْانُ بْنُ عُيَيْنَةَ، قَالَ قُلْتُ لِعَمْرِو بْنِ دِينَارٍ سَمِعْتَ جَابِرَ بْنَ عَبْدِ اللَّهِ، يَقُولُ مَرَّ رَجُلٌ بِسِهَامٍ فِي الْمَسْجِدِ فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ أَمْسِكْ بِنِصَالِهَا ‏\"\"‏ ‏.‏ قَالَ نَعَمْ ‏.‏\"", "bengali": "", "english": "\"A man passed through the masjid with some arrows, and the Messenger of Allah(ﷺ) said: 'Hold them by their heads!' He said: 'Yes(ok).'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Jabir bin 'Abdullah said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3514", "arabic": "حَدَّثَنَا مَحْمُودُ بْنُ غَيْلاَنَ، حَدَّثَنَا أَبُو أُسَامَةَ، عَنْ بُرَيْدٍ، عَنْ جَدِّهِ أَبِي بُرْدَةَ، عَنْ أَبِي مُوسَى، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ إِذَا مَرَّ أَحَدُكُمْ فِي مَسْجِدِنَا أَوْ فِي سُوقِنَا وَمَعَهُ نَبْلٌ فَلْيُمْسِكْ عَلَى نِصَالِهَا بِكَفِّهِ أَنْ تُصِيبَ أَحَدًا مِنَ الْمُسْلِمِينَ بِشَىْءٍ أَوْ فَلْيَقْبِضْ عَلَى نِصَالِهَا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"When anyone of you passes through our masjid or our marketplace carrying arrows, let him hold them by their heads, lest he hurt any Muslims.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Musa that the Prophet(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3515", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا عِيسَى بْنُ يُونُسَ، حَدَّثَنَا سَعِيدُ بْنُ أَبِي عَرُوبَةَ، عَنْ قَتَادَةَ، عَنْ زُرَارَةَ بْنِ أَوْفَى، عَنْ سَعْدِ بْنِ هِشَامٍ، عَنْ عَائِشَةَ، قَالَتْ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ الْمَاهِرُ بِالْقُرْآنِ مَعَ السَّفَرَةِ الْكِرَامِ الْبَرَرَةِ وَالَّذِي يَقْرَؤُهُ يَتَتَعْتَعُ فِيهِ وَهُوَ عَلَيْهِ شَاقٌّ لَهُ أَجْرَانِ اثْنَانِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"The one who is proficient with the Qur'an will be with the noble and righteous scribes (the angels), and the one who reads it and stumbles over it, finding it difficult, will have two rewards.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Aisha that the Messenger of Allah (ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3516", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ مُوسَى، أَنْبَأَنَا شَيْبَانُ، عَنْ فِرَاسٍ، عَنْ عَطِيَّةَ، عَنْ أَبِي سَعِيدٍ الْخُدْرِيِّ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ يُقَالُ لِصَاحِبِ الْقُرْآنِ إِذَا دَخَلَ الْجَنَّةَ اقْرَأْ وَاصْعَدْ ‏.‏ فَيَقْرَأُ وَيَصْعَدُ بِكُلِّ آيَةٍ دَرَجَةً حَتَّى يَقْرَأَ آخِرَ شَىْءٍ مَعَهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"It will be said to the companion of the Qur'an, when he enters Paradise: 'Recite and rise one degree for every Verse,' until he recites the last thing that he knows.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Sa`eed Al-Khudri that the Messenger of Allah (ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3517", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، عَنْ بَشِيرِ بْنِ مُهَاجِرٍ، عَنِ ابْنِ بُرَيْدَةَ، عَنْ أَبِيهِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ يَجِيءُ الْقُرْآنُ يَوْمَ الْقِيَامَةِ كَالرَّجُلِ الشَّاحِبِ فَيَقُولُ أَنَا الَّذِي أَسْهَرْتُ لَيْلَكَ وَأَظْمَأْتُ نَهَارَكَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"The Quran will come on the Day of Resurrection, like a pale man, and will say: 'I am the one that kept you awake at night and made you thirsty during the day.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Ibn Buraidah that his father told that the Messenger of Allah(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3518", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا وَكِيعٌ، عَنِ الأَعْمَشِ، عَنْ أَبِي صَالِحٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏\"‏ أَيُحِبُّ أَحَدُكُمْ إِذَا رَجَعَ إِلَى أَهْلِهِ أَنْ يَجِدَ فِيهِ ثَلاَثَ خَلِفَاتٍ عِظَامٍ سِمَانٍ ‏\"‏ ‏.‏ قُلْنَا نَعَمْ ‏.‏ قَالَ ‏\"‏ فَثَلاَثُ آيَاتٍ يَقْرَؤُهُنَّ أَحَدُكُمْ فِي صَلاَتِهِ خَيْرٌ لَهُ مِنْ ثَلاَثِ خَلِفَاتٍ سِمَانٍ عِظَامٍ ‏\"‏ ‏.‏", "bengali": "", "english": "\"Wouldn't anyone of you like to find three great, fat pregnant she-camels when he returns to his family?\" We said: \"Yes.\" He said: \"Three verses that one of you recites during the praer are better for him than three great, fat pregnant she-camels.\"", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  ایک آدمی کو بچھو نے ڈنک مار دیا تو وہ رات بھر نہیں سو سکا، نبی ا", "grades": "", "reference": "", "international_number": "3518", "narrator_chain": "It was narrated from Abu Hurairah that the Messenger of Allah(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3519", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ الأَزْهَرِ، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَنْبَأَنَا مَعْمَرٌ، عَنْ أَيُّوبَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَثَلُ الْقُرْآنِ مَثَلُ الإِبِلِ الْمُعَقَّلَةِ إِنْ تَعَاهَدَهَا صَاحِبُهَا بِعُقُلِهَا أَمْسَكَهَا عَلَيْهِ وَإِنْ أَطْلَقَ عُقُلَهَا ذَهَبَتْ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"The likeness of the Quran is that of a hobbled camel. If its owner ties its rope, he will keep it, but if he loosens its rope it will go away.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Ibn Umar that the Messenger of Allah(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3520", "arabic": "حَدَّثَنَا أَبُو مَرْوَانَ، مُحَمَّدُ بْنُ عُثْمَانَ الْعُثْمَانِيُّ حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ أَبِي حَازِمٍ، عَنِ الْعَلاَءِ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏\"‏ قَالَ اللَّهُ عَزَّ وَجَلَّ قَسَمْتُ الصَّلاَةَ بَيْنِي وَبَيْنَ عَبْدِي شَطْرَيْنِ فَنِصْفُهَا لِي وَنِصْفُهَا لِعَبْدِي وَلِعَبْدِي مَا سَأَلَ ‏\"‏ ‏.‏ قَالَ فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏\"‏ اقْرَءُوا يَقُولُ الْعَبْدُ ‏{الْحَمْدُ لِلَّهِ رَبِّ الْعَالَمِينَ}‏ فَيَقُولُ اللَّهُ عَزَّ وَجَلَّ حَمِدَنِي عَبْدِي وَلِعَبْدِي مَا سَأَلَ ‏.‏ فَيَقُولُ ‏{الرَّحْمَنِ الرَّحِيمِ}‏ فَيَقُولُ أَثْنَى عَلَىَّ عَبْدِي وَلِعَبْدِي مَا سَأَلَ ‏.‏ يَقُولُ ‏{مَالِكِ يَوْمِ الدِّينِ }‏ فَيَقُولُ اللَّهُ مَجَّدَنِي عَبْدِي فَهَذَا لِي وَهَذِهِ الآيَةُ بَيْنِي وَبَيْنَ عَبْدِي نِصْفَيْنِ يَقُولُ الْعَبْدُ ‏{إِيَّاكَ نَعْبُدُ وَإِيَّاكَ نَسْتَعِينُ}‏ يَعْنِي فَهَذِهِ بَيْنِي وَبَيْنَ عَبْدِي وَلِعَبْدِي مَا سَأَلَ وَآخِرُ السُّورَةِ لِعَبْدِي يَقُولُ الْعَبْدُ ‏{اهْدِنَا الصِّرَاطَ الْمُسْتَقِيمَ * صِرَاطَ الَّذِينَ أَنْعَمْتَ عَلَيْهِمْ غَيْرِ الْمَغْضُوبِ عَلَيْهِمْ وَلاَ الضَّالِّينَ}‏ فَهَذَا لِعَبْدِي وَلِعَبْدِي مَا سَأَلَ ‏\"‏ ‏.‏", "bengali": "", "english": "\"Allah said: 'I have divided the prayer between Myself and My slave into two halves, and My slave shall have what he has asked for.'When the slave says: 'Al-hamdulillah i rabbil Alameen (All the praise is to Allah, the Lord of all that exists),' Allah says:'My slave has praised Me, and My slave shall have what he has asked for.' And when he says: 'Ar-Rahmanir-Rahim (The Mos Gracious, the Most Merciful),' Allah says: 'My slave has extolled Me, and My slave shall have what he has asked for.' And when he says: 'Maliki yawmiddin ,' He says: 'THis is for My slave, and My slave shall have what he has asked for.\"", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  جب رسول اللہ صلی اللہ علیہ وسلم مریض کے پاس آتے تو آپ", "grades": "", "reference": "", "international_number": "3520", "narrator_chain": "It was narrated that Abu Hurairah said, 'I heard the Messenger of Allah(ﷺ) say':", "chapter_intro": "Etiquette"}
{"hadithnumber": "3521", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا غُنْدَرٌ، عَنْ شُعْبَةَ، عَنْ خُبَيْبِ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ حَفْصِ بْنِ عَاصِمٍ، عَنْ أَبِي سَعِيدِ بْنِ الْمُعَلَّى، قَالَ قَالَ لِي رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏\"‏ أَلاَ أُعَلِّمُكَ أَعْظَمَ سُورَةٍ فِي الْقُرْآنِ قَبْلَ أَنْ أَخْرُجَ مِنَ الْمَسْجِدِ ‏\"‏ ‏.‏ قَالَ فَذَهَبَ النَّبِيُّ ـ صلى الله عليه وسلم ـ لِيَخْرُجَ فَأَذْكَرْتُهُ فَقَالَ ‏\"‏ ‏{‏ الْحَمْدُ لِلَّهِ رَبِّ الْعَالَمِينَ}‏ وَهِيَ السَّبْعُ الْمَثَانِي وَالْقُرْآنُ الْعَظِيمُ الَّذِي أُوتِيتُهُ ‏\"‏ ‏.‏", "bengali": "", "english": "\"The Messenger of Allah(ﷺ) said to me: 'Shall I not teach you the greatest Surah in the QUran before I leave the masjid?' Then the Propeht(ﷺ) went to leave, so I reminded him, and he said: Al-hamdulillahi Rabbil-Alameen (All the praise is to Allah, the Lord of all that exists). It is the Seven Oft-Recited Verses, and it is the Grand Quran that has been given to me.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم اپنی انگلی میں تھوک لگا", "grades": "", "reference": "", "international_number": "3521", "narrator_chain": "It was narrated that Abu Sa'eed bin Mu'alla said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3522", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو أُسَامَةَ، عَنْ شُعْبَةَ، عَنْ قَتَادَةَ، عَنْ عَبَّاسٍ الْجُشَمِيِّ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏\"‏ إِنَّ سُورَةً فِي الْقُرْآنِ ثَلاَثُونَ آيَةً شَفَعَتْ لِصَاحِبِهَا حَتَّى غُفِرَ لَهُ ‏{تَبَارَكَ الَّذِي بِيَدِهِ الْمُلْكُ}‏ ‏\"‏ ‏.‏", "bengali": "", "english": "\"There is a surah in the Qur'an, with thirty verses, which will intercede for its companion (the one who recites it) until he is forgiven: Tabarakal-ladhi bi yadihil mulk (Blessed is He in Whose Hand is the Dominion).\"", "french": "", "indonesian": "", "russian": "", "urdu": "عثمان بن ابی العاص رضی اللہ عنہ کہتے ہیں کہ  میں نبی اکرم صلی اللہ علیہ وسلم کی خدمت میں حاضر ہوا، م", "grades": "", "reference": "", "international_number": "3522", "narrator_chain": "It was narrated from Abu Hurairah that the Prophet (ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3523", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ، حَدَّثَنَا سُلَيْمَانُ بْنُ بِلاَلٍ، حَدَّثَنِي سُهَيْلٌ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏\"‏ ‏{قُلْ هُوَ اللَّهُ أَحَدٌ}‏ تَعْدِلُ ثُلُثَ الْقُرْآنِ ‏\"‏ ‏.‏", "bengali": "", "english": "\"Qul Huwa Allahu ahad  is equivalent to one third of the Quran.\"", "french": "", "indonesian": "", "russian": "", "urdu": "ابو سعید خدری رضی اللہ عنہ سے روایت ہے کہ  جبرائیل علیہ السلام نے نبی اکرم صلی اللہ علیہ وسلم کے پاس", "grades": "", "reference": "", "international_number": "3523", "narrator_chain": "It was narrated that Abu Hurairah said that the Messenger of Allah(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3524", "arabic": "حَدَّثَنَا الْحَسَنُ بْنُ عَلِيٍّ الْخَلاَّلُ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، عَنْ جَرِيرِ بْنِ حَازِمٍ، عَنْ قَتَادَةَ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏\"‏ ‏{قُلْ هُوَ اللَّهُ أَحَدٌ}‏ تَعْدِلُ ثُلُثَ الْقُرْآنِ ‏\"‏ ‏.‏", "bengali": "", "english": "\"The Messenger of Allah(ﷺ) said: Qul Huwa Allahu ahad  is equivalent to one third of the Quran.\"", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم میری عیادت کے لیے تشریف لائے، تو آپ ن", "grades": "", "reference": "", "international_number": "3524", "narrator_chain": "It was narrated that Anas bin Malik said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3525", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، عَنْ سُفْيَانَ، عَنْ أَبِي قَيْسٍ الأَوْدِيِّ، عَنْ عَمْرِو بْنِ مَيْمُونٍ، عَنْ أَبِي مَسْعُودٍ الأَنْصَارِيِّ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ اللَّهُ أَحَدٌ الْوَاحِدُ الصَّمَدُ تَعْدِلُ ثُلُثَ الْقُرْآنِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"The Messenger of Allah(ﷺ) said: \"Allahu ahad, Al-Wahidus-Samad  is equivalent to one third of the Quran.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Abu Masud Al Ansari said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3526", "arabic": "حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، حَدَّثَنَا الْمُغِيرَةُ بْنُ عَبْدِ الرَّحْمَنِ، عَنْ عَبْدِ اللَّهِ بْنِ سَعِيدِ بْنِ أَبِي هِنْدٍ، عَنْ زِيَادِ بْنِ أَبِي زِيَادٍ، مَوْلَى ابْنِ عَيَّاشٍ عَنْ أَبِي بَحْرِيَّةَ، عَنْ أَبِي الدَّرْدَاءِ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ ‏\"‏ أَلاَ أُنَبِّئُكُمْ بِخَيْرِ أَعْمَالِكُمْ وَأَرْضَاهَا عِنْدَ مَلِيكِكُمْ وَأَرْفَعِهَا فِي دَرَجَاتِكُمْ وَخَيْرٍ لَكُمْ مِنْ إِعْطَاءِ الذَّهَبِ وَالْوَرِقِ وَمِنْ أَنْ تَلْقَوْا عَدُوَّكُمْ فَتَضْرِبُوا أَعْنَاقَهُمْ وَيَضْرِبُوا أَعْنَاقَكُمْ ‏\"‏ ‏.‏ قَالُوا وَمَا ذَاكَ يَا رَسُولَ اللَّهِ قَالَ ‏\"‏ ذِكْرُ اللَّهِ ‏\"‏ ‏.‏ وَقَالَ مُعَاذُ بْنُ جَبَلٍ مَا عَمِلَ امْرُؤٌ بِعَمَلٍ أَنْجَى لَهُ مِنْ عَذَابِ اللَّهِ عَزَّ وَجَلَّ مِنْ ذِكْرِ اللَّهِ ‏.‏", "bengali": "", "english": "\"Shall I not tell you of the best of your deeds, the most pleasing to your Sovereign, those that raise you most in status, that are better than your gold and silver, or meeting you enemy (in battle) and you strike their necks and they strike your necks?\" They said: \" WHat is that, O Messenger of Allah?\" He said: \"Remembering Allah(Dhikr).\"", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم بخار اور ہر طرح کے درد کے", "grades": "", "reference": "", "international_number": "3526", "narrator_chain": "It was narrated from Abu Darda that the Prophet(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3527", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَحْيَى بْنُ آدَمَ، عَنْ عَمَّارِ بْنِ رُزَيْقٍ، عَنْ أَبِي إِسْحَاقَ، عَنِ الأَغَرِّ أَبِي مُسْلِمٍ، عَنْ أَبِي هُرَيْرَةَ، وَأَبِي، سَعِيدٍ يَشْهَدَانِ بِهِ عَلَى النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ مَا جَلَسَ قَوْمٌ مَجْلِسًا يَذْكُرُونَ اللَّهَ فِيهِ إِلاَّ حَفَّتْهُمُ الْمَلاَئِكَةُ وَتَغَشَّتْهُمُ الرَّحْمَةُ وَتَنَزَّلَتْ عَلَيْهِمُ السَّكِينَةُ وَذَكَرَهُمُ اللَّهُ فِيمَنْ عِنْدَهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"No people sit in a gathering remembering Allah, But the angels surround them, mercy covers them, tranquility descends upon them and Allah remembers them before those who are with Him.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Abu Hurairah and Abu Sa'eed bore witness that the Prophet(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3528", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا مُحَمَّدُ بْنُ مُصْعَبٍ، عَنِ الأَوْزَاعِيِّ، عَنْ إِسْمَاعِيلَ بْنِ عُبَيْدِ اللَّهِ، عَنْ أُمِّ الدَّرْدَاءِ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ إِنَّ اللَّهَ عَزَّ وَجَلَّ يَقُولُ أَنَا مَعَ عَبْدِي إِذَا هُوَ ذَكَرَنِي وَتَحَرَّكَتْ بِي شَفَتَاهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Allah says: 'I am with My slave when he remembers Me and his lips move saying My Name.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah that the Prophet(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3529", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا زَيْدُ بْنُ الْحُبَابِ، أَخْبَرَنِي مُعَاوِيَةُ بْنُ صَالِحٍ، أَخْبَرَنِي عَمْرُو بْنُ قَيْسٍ الْكِنْدِيُّ، عَنْ عَبْدِ اللَّهِ بْنِ بُسْرٍ، أَنَّ أَعْرَابِيًّا، قَالَ لِرَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ إِنَّ شَرَائِعَ الإِسْلاَمِ قَدْ كَثُرَتْ عَلَىَّ فَأَنْبِئْنِي مِنْهَا بِشَىْءٍ أَتَشَبَّثُ بِهِ ‏.‏ قَالَ ‏ ‏ لاَ يَزَالُ لِسَانُكَ رَطْبًا مِنْ ذِكْرِ اللَّهِ عَزَّ وَجَلَّ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"The laws of Islam are burdensome for me. Tell me of something that I will be able to adhere to. He said: 'Always keep your tongue moist with the remembrance of Allah, the Mighty and Sublime.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abdullah bin Busr that a Bedouin said to the Messenger of Allah(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3530", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا الْحُسَيْنُ بْنُ عَلِيٍّ، عَنْ حَمْزَةَ الزَّيَّاتِ، عَنْ أَبِي إِسْحَاقَ، عَنِ الأَغَرِّ أَبِي مُسْلِمٍ، أَنَّهُ شَهِدَ عَلَى أَبِي هُرَيْرَةَ وَأَبِي سَعِيدٍ أَنَّهُمَا شَهِدَا عَلَى رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ إِذَا قَالَ الْعَبْدُ لاَ إِلَهَ إِلاَّ اللَّهُ وَاللَّهُ أَكْبَرُ ‏.‏ قَالَ يَقُولُ اللَّهُ عَزَّ وَجَلَّ صَدَقَ عَبْدِي لاَ إِلَهَ إِلاَّ أَنَا وَأَنَا أَكْبَرُ ‏.‏ وَإِذَا قَالَ الْعَبْدُ لاَ إِلَهَ إِلاَّ اللَّهُ وَحْدَهُ ‏.‏ قَالَ صَدَقَ عَبْدِي لاَ إِلَهَ إِلاَّ أَنَا وَحْدِي ‏.‏ وَإِذَا قَالَ لاَ إِلَهَ إِلاَّ اللَّهُ لاَ شَرِيكَ لَهُ ‏.‏ قَالَ صَدَقَ عَبْدِي لاَ إِلَهَ إِلاَّ أَنَا وَلاَ شَرِيكَ لِي ‏.‏ وَإِذَا قَالَ لاَ إِلَهَ إِلاَّ اللَّهُ لَهُ الْمُلْكُ وَلَهُ الْحَمْدُ ‏.‏ قَالَ صَدَقَ عَبْدِي لاَ إِلَهَ إِلاَّ أَنَا لِيَ الْمُلْكُ وَلِيَ الْحَمْدُ ‏.‏ وَإِذَا قَالَ لاَ إِلَهَ إِلاَّ اللَّهُ وَلاَ حَوْلَ وَلاَ قُوَّةَ إِلاَّ بِاللَّهِ ‏.‏ قَالَ صَدَقَ عَبْدِي لاَ إِلَهَ إِلاَّ أَنَا وَلاَ حَوْلَ وَلاَ قُوَّةَ إِلاَّ بِي ‏\"\"‏ ‏.‏ قَالَ أَبُو إِسْحَاقَ ثُمَّ قَالَ الأَغَرُّ شَيْئًا لَمْ أَفْهَمْهُ ‏.‏ قَالَ فَقُلْتُ لأَبِي جَعْفَرٍ مَا قَالَ فَقَالَ مَنْ رُزِقَهُنَّ عِنْدَ مَوْتِهِ لَمْ تَمَسَّهُ النَّارُ ‏.‏\"", "bengali": "", "english": "\"If a person says: 'La ilaha illallahu wa Allahu Akbar (None has the right to be worshipped but Allah and Allah is the Most Great),'Allah says: 'My slave has spoken the truth; there is none worthy of worship except I, and I am the Most Great.' If a person says: La ilaha Illallah wahdahu (There is none worthy of worship except Allah alone), Allah says: 'My slave has spoken the truth; there is none worthy of worship except I, alone.' If he says, La ilaha illallahu la sharikalahu (There is none worthy of worship except Allah with no partner or associate),' Allah says: 'My slave has spoken the truth; there is none worthy of worship except I, with no partner or associate.' If he says: 'La illah illallah, lahul mulku wa lahul hamdu (There is none worthy of worship except Allah, all dominion is His and all praise is to Him),' Allah says: 'My slave has spoken the truth; there is none of worthy of worship except I, all dominion Mine and all praise is due to Me.' If he says: ' La illaha illallah, la hawla wa la quwwata illa billah (There is none worthy of worship and there is no power and no strength except with Allah),' Allah says: 'My slave has spoken then truth; there is none worthy of worship except I, and tehre is no power and no strength except with Me.' One of the narrators Abu Ishaq said: \"Then Agharr (another narrator) said something that I did not understand. I said to Abu Jafar: 'What did he say?' He said: 'Whoever is blessed with (the ability to say) them (these words) at the time of death, the Fire will not touch him.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah and Abu Saeed bore witness that the Messenger of Allah(ﷺ) said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3531", "arabic": "حَدَّثَنَا هَارُونُ بْنُ إِسْحَاقَ الْهَمْدَانِيُّ، حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الْوَهَّابِ، عَنْ مِسْعَرٍ، عَنْ إِسْمَاعِيلَ بْنِ أَبِي خَالِدٍ، عَنِ الشَّعْبِيِّ، عَنْ يَحْيَى بْنِ طَلْحَةَ، عَنْ أُمِّهِ، سُعْدَى الْمُرِّيَّةِ قَالَتْ مَرَّ عُمَرُ بِطَلْحَةَ بَعْدَ وَفَاةِ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ فَقَالَ مَا لَكَ مُكْتَئِبًا أَسَاءَتْكَ إِمْرَةُ ابْنِ عَمِّكَ قَالَ لاَ وَلَكِنْ سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ إِنِّي لأَعْلَمُ كَلِمَةً لاَ يَقُولُهَا أَحَدٌ عِنْدَ مَوْتِهِ إِلاَّ كَانَتْ نُورًا لِصَحِيفَتِهِ وَإِنَّ جَسَدَهُ وَرُوحَهُ لَيَجِدَانِ لَهَا رَوْحًا عِنْدَ الْمَوْتِ ‏\"\"‏ ‏.‏ فَلَمْ أَسْأَلْهُ حَتَّى تُوُفِّيَ ‏.‏ قَالَ أَنَا أَعْلَمُهَا هِيَ الَّتِي أَرَادَ عَمَّهُ عَلَيْهَا وَلَوْ عَلِمَ أَنَّ شَيْئًا أَنْجَى لَهُ مِنْهَا لأَمَرَهُ ‏.‏\"", "bengali": "", "english": "his mother Su'da Al-Murriyyah said: \"Umar bin Khattab passed by Talhah, after the Messenger of Allah(ﷺ) had died, and said: 'Why do you look so sad? Are you upset because your cousin has been appointed leader?' He said: 'No, but I heard the Messenger of Allah(ﷺ) say: \"I know a word which no one says at the time of death but it will be light in his record of deeds, and his body and soul will find comfort in it at the time of death,\" -but I did not ask him about it before he died.' He ('Umar) said: ' I know what it is. It is what he wanted his uncle (Abu Talib) to say, and if he had known anything that would be more effective in saving him, he would have told him to say it.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Yahya bin Talha that :", "chapter_intro": "Etiquette"}
{"hadithnumber": "3532", "arabic": "حَدَّثَنَا عَبْدُ الْحَمِيدِ بْنُ بَيَانٍ الْوَاسِطِيُّ، حَدَّثَنَا خَالِدُ بْنُ عَبْدِ اللَّهِ، عَنْ يُونُسَ، عَنْ حُمَيْدِ بْنِ هِلاَلٍ، عَنْ هِصَّانَ بْنِ الْكَاهِلِ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ سَمُرَةَ، عَنْ مُعَاذِ بْنِ جَبَلٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَا مِنْ نَفْسٍ تَمُوتُ تَشْهَدُ أَنْ لاَ إِلَهَ إِلاَّ اللَّهُ وَأَنِّي رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ يَرْجِعُ ذَلِكَ إِلَى قَلْبٍ مُوقِنٍ إِلاَّ غَفَرَ اللَّهُ لَهَا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "Messenger of Allah(ﷺ) said: \"There is no soul that died bearing witness to La ilaha illallah, and that I am the Messenger of Allah, from the heart with certainity, but Allah will forgive it.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Mu'adh bin Jabal that the :", "chapter_intro": "Etiquette"}
{"hadithnumber": "3533", "arabic": "حَدَّثَنَا إِبْرَاهِيمُ بْنُ الْمُنْذِرِ الْحِزَامِيُّ، حَدَّثَنَا زَكَرِيَّا بْنُ مَنْظُورٍ، حَدَّثَنِي مُحَمَّدُ بْنُ عُقْبَةَ، عَنْ أُمِّ هَانِئٍ، قَالَتْ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لاَ إِلَهَ إِلاَّ اللَّهُ لاَ يَسْبِقُهَا عَمَلٌ وَلاَ تَتْرُكُ ذَنْبًا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"The Messenger of Allah(ﷺ) said: (About saying) La ilaha illah - no deed takes precedence over it and it does not leave any sin.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Umm Hani' said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3534", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ، حَدَّثَنَا زَيْدُ بْنُ الْحُبَابِ، عَنْ مَالِكِ بْنِ أَنَسٍ، أَخْبَرَنِي سُمَىٌّ، مَوْلَى أَبِي بَكْرٍ عَنْ أَبِي صَالِحٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ قَالَ فِي يَوْمٍ مِائَةَ مَرَّةٍ لاَ إِلَهَ إِلاَّ اللَّهُ وَحْدَهُ لاَ شَرِيكَ لَهُ لَهُ الْمُلْكُ وَلَهُ الْحَمْدُ وَهُوَ عَلَى كُلِّ شَىْءٍ قَدِيرٌ كَانَ لَهُ عَدْلَ عَشْرِ رِقَابٍ وَكُتِبَتْ لَهُ مِائَةُ حَسَنَةٍ وَمُحِيَ عَنْهُ مِائَةُ سَيِّئَةٍ وَكُنَّ لَهُ حِرْزًا مِنَ الشَّيْطَانِ سَائِرَ يَوْمِهِ إِلَى اللَّيْلِ وَلَمْ يَأْتِ أَحَدٌ بِأَفْضَلَ مِمَّا أَتَى بِهِ إِلاَّ مَنْ قَالَ أَكْثَرَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "the Messenger of Allah(ﷺ) said: \"Whoever says one hundered times each day: La ilaha illahu wahdahu la sharikalahu, wa lahul-mulku wa lahul hamduwa huwa ala kulli shayin qadeer (None has the right to be worshipped but Allah alone, with no partner or associate. His is the dominion, all praise is to Him, and He is able to do all things), it will be equivalent to him freeing ten slaves, and one hundered merits will be recorded for him, and one hundered bad deeds will be erased from (his record), and it will be a protection for him against Satan all day until night comes. No one can do anything better then him except one who says more.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah that :", "chapter_intro": "Etiquette"}
{"hadithnumber": "3535", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا بَكْرُ بْنُ عَبْدِ الرَّحْمَنِ، حَدَّثَنَا عِيسَى بْنُ الْمُخْتَارِ، عَنْ مُحَمَّدِ بْنِ أَبِي لَيْلَى، عَنْ عَطِيَّةَ الْعَوْفِيِّ، عَنْ أَبِي سَعِيدٍ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ مَنْ قَالَ فِي دُبُرِ صَلاَةِ الْغَدَاةِ لاَ إِلَهَ إِلاَّ اللَّهُ وَحْدَهُ لاَ شَرِيكَ لَهُ لَهُ الْمُلْكُ وَلَهُ الْحَمْدُ بِيَدِهِ الْخَيْرُ وَهُوَ عَلَى كُلِّ شَىْءٍ قَدِيرٌ - كَانَ كَعَتَاقِ رَقَبَةٍ مِنْ وَلَدِ إِسْمَاعِيلَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "the Prophet(ﷺ) said: \"Whoever says, following the morning prayer: La ilaha illallahu wahdahu la sahrikalau, lahul mulku wa lahul hamdu, bi yadihil khair, wa huwa ala kulli shay'in qadir (None has the right to be worshipped but Allah alone, with no partner or associate. His is the dominion, all praise is to Him, in His Hand is all goodness, and He is Able to do all things), it will be as if he freed slave from among the sons of Isma'il.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Saeed that :", "chapter_intro": "Etiquette"}
{"hadithnumber": "3536", "arabic": "حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ الدِّمَشْقِيُّ، حَدَّثَنَا مُوسَى بْنُ إِبْرَاهِيمَ بْنِ كَثِيرِ بْنِ بَشِيرِ بْنِ الْفَاكِهِ، قَالَ سَمِعْتُ طَلْحَةَ بْنَ خِرَاشٍ ابْنَ عَمِّ، جَابِرٍ قَالَ سَمِعْتُ جَابِرَ بْنَ عَبْدِ اللَّهِ، يَقُولُ سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ أَفْضَلُ الذِّكْرِ لاَ إِلَهَ إِلاَّ اللَّهُ وَأَفْضَلُ الدُّعَاءِ الْحَمْدُ لِلَّهِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"I heard the Messenger of Allah (ﷺ) say: 'The best of remembrance is La ilaha illallah (None has the right to be worshipped but Allah), and the best of supplication is Al-Hamdu Lillah (praise is to Allah).'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Jabir bin 'Abdullah said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3537", "arabic": "حَدَّثَنَا إِبْرَاهِيمُ بْنُ الْمُنْذِرِ الْحِزَامِيُّ، حَدَّثَنَا صَدَقَةُ بْنُ بَشِيرٍ، مَوْلَى الْعُمَرِيِّينَ قَالَ سَمِعْتُ قُدَامَةَ بْنَ إِبْرَاهِيمَ الْجُمَحِيَّ، يُحَدِّثُ أَنَّهُ كَانَ يَخْتَلِفُ إِلَى عَبْدِ اللَّهِ بْنِ عُمَرَ بْنِ الْخَطَّابِ وَهُوَ غُلاَمٌ وَعَلَيْهِ ثَوْبَانِ مُعَصْفَرَانِ قَالَ فَحَدَّثَنَا عَبْدُ اللَّهِ بْنُ عُمَرَ أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ حَدَّثَهُمْ ‏ ‏ أَنَّ عَبْدًا مِنْ عِبَادِ اللَّهِ قَالَ يَا رَبِّ لَكَ الْحَمْدُ كَمَا يَنْبَغِي لِجَلاَلِ وَجْهِكَ وَلِعَظِيمِ سُلْطَانِكَ فَعَضَّلَتْ بِالْمَلَكَيْنِ فَلَمْ يَدْرِيَا كَيْفَ يَكْتُبَانِهَا فَصَعِدَا إِلَى السَّمَاءِ وَقَالاَ يَا رَبَّنَا إِنَّ عَبْدَكَ قَدْ قَالَ مَقَالَةً لاَ نَدْرِي كَيْفَ نَكْتُبُهَا ‏.‏ قَالَ اللَّهُ عَزَّ وَجَلَّ وَهُوَ أَعْلَمُ بِمَا قَالَ عَبْدُهُ مَاذَا قَالَ عَبْدِي قَالاَ يَا رَبِّ إِنَّهُ قَالَ يَا رَبِّ لَكَ الْحَمْدُ كَمَا يَنْبَغِي لِجَلاَلِ وَجْهِكَ وَعَظِيمِ سُلْطَانِكَ ‏.‏ فَقَالَ اللَّهُ عَزَّ وَجَلَّ لَهُمَا اكْتُبَاهَا كَمَا قَالَ عَبْدِي حَتَّى يَلْقَانِي فَأَجْزِيَهُ بِهَا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "the Messenger of Allah (ﷺ) told them: \"One of the slaves of Allah said: 'Ya Rabb! Lakal-hamdu kama yanbagi li-jalali Wajhika wa li 'azima sultanika (O Lord, to You is praise as befits the Glory of Your Face and the greatness of Your Might.)' The angels were uncertain and did not know how to write this down, so they ascended to heaven and said: 'O our Lord, Your slave has said a word that we do not know how to write down.' Allah said - and He knows best what His slave said - 'What did My slave say?' They said: 'O Lord, he said \"Ya Rabb! Lakal-hamdu kama yanbagi li-jalali Wajhika wa li'azima sultanika (O Lord, to You is praise as befits the Glory of Your Face and the greatness of your Might).'\" Allah said to them: 'Write it down as My slave said it, until he meets Me and I shall reward him for it.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from 'Abdullah bin 'Umar that :", "chapter_intro": "Etiquette"}
{"hadithnumber": "3538", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا يَحْيَى بْنُ آدَمَ، حَدَّثَنَا إِسْرَائِيلُ، عَنْ أَبِي إِسْحَاقَ، عَنْ عَبْدِ الْجَبَّارِ بْنِ وَائِلٍ، عَنْ أَبِيهِ، قَالَ صَلَّيْتُ مَعَ النَّبِيِّ ـ صلى الله عليه وسلم ـ فَقَالَ رَجُلٌ الْحَمْدُ لِلَّهِ حَمْدًا كَثِيرًا طَيِّبًا مُبَارَكًا فِيهِ ‏.‏ فَلَمَّا صَلَّى النَّبِيُّ ـ صلى الله عليه وسلم ـ قَالَ ‏\"‏ مَنْ ذَا الَّذِي قَالَ هَذَا ‏\"‏ ‏.‏ قَالَ الرَّجُلُ أَنَا وَمَا أَرَدْتُ إِلاَّ الْخَيْرَ ‏.‏ فَقَالَ ‏\"‏ لَقَدْ فُتِحَتْ لَهَا أَبْوَابُ السَّمَاءِ فَمَا نَهْنَهَهَا شَىْءٌ دُونَ الْعَرْشِ ‏\"‏ ‏.‏", "bengali": "", "english": "his father said: \"I prayed with the Prophet (ﷺ) and a man said: 'Alhamdu lillahi hamdan kathiran tayyiban mubarakan fihi (Praise is to Allah, much, good and blessed praise).' When the Prophet (ﷺ) finished praying, he said: 'Who said that?' The man said: 'It was me, but I did not mean anything but good.' He said: 'The gates of heaven were opened because of it and nothing prevented it from reaching the Throne.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  بدشگونی شرک ہے ۱", "grades": "", "reference": "", "international_number": "3538", "narrator_chain": "It was narrated from 'Abdul-Jabbar bin Wa'il that :", "chapter_intro": "Etiquette"}
{"hadithnumber": "3539", "arabic": "حَدَّثَنَا هِشَامُ بْنُ خَالِدٍ الأَزْرَقُ أَبُو مَرْوَانَ، حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، حَدَّثَنَا زُهَيْرُ بْنُ مُحَمَّدٍ، عَنْ مَنْصُورِ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ أُمِّهِ، صَفِيَّةَ بِنْتِ شَيْبَةَ عَنْ عَائِشَةَ، قَالَتْ كَانَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ إِذَا رَأَى مَا يُحِبُّ قَالَ ‏\"‏ الْحَمْدُ لِلَّهِ الَّذِي بِنِعْمَتِهِ تَتِمُّ الصَّالِحَاتُ ‏\"‏ ‏.‏ وَإِذَا رَأَى مَا يَكْرَهُ قَالَ ‏\"‏ الْحَمْدُ لِلَّهِ عَلَى كُلِّ حَالٍ ‏\"‏ ‏.‏", "bengali": "", "english": "\"When the Messenger of Allah (ﷺ) saw something he liked, he would say: 'Al-hamdu lillahil-ladhi bi ni'matihi tatimmus-salihat (Praise is to Allah by Whose grace good deeds are completed).' And if he saw something that he disliked, he would say: 'Al-hamdu lillahi 'ala kulli hal (Praise is to Allah in all circumstances).'\"", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  چھوت چھات ۱؎ او", "grades": "", "reference": "", "international_number": "3539", "narrator_chain": "It was narrated that 'Aishah said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3540", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، عَنْ مُوسَى بْنِ عُبَيْدَةَ، عَنْ مُحَمَّدِ بْنِ ثَابِتٍ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ كَانَ يَقُولُ ‏ ‏ الْحَمْدُ لِلَّهِ عَلَى كُلِّ حَالٍ رَبِّ أَعُوذُ بِكَ مِنْ حَالِ أَهْلِ النَّارِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "the Prophet (ﷺ) used to say: \"Al-hamdu lillahi 'ala kulli hal. Rabbi a'udhu bika min hali ahlin-nar (Praise is to Allah in all circumstances, O Allah, I seek refuge with You from the situation of the people of Hell).\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narratd from Abu Hurairah that :", "chapter_intro": "Etiquette"}
{"hadithnumber": "3541", "arabic": "حَدَّثَنَا الْحَسَنُ بْنُ عَلِيٍّ الْخَلاَّلُ، حَدَّثَنَا أَبُو عَاصِمٍ، عَنْ شَبِيبِ بْنِ بِشْرٍ، عَنْ أَنَسٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَا أَنْعَمَ اللَّهُ عَلَى عَبْدٍ نِعْمَةً فَقَالَ الْحَمْدُ لِلَّهِ ‏.‏ إِلاَّ كَانَ الَّذِي أَعْطَاهُ أَفْضَلَ مِمَّا أَخَذَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "the Messenger of Allah (ﷺ) said: 'Allah does not bestow a blessing upon any slave and he says: 'Al-hamdu Lillah (praise is to Allah),' except that what he gives (the praise) is better than what he received (the blessing).\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Anas that :", "chapter_intro": "Etiquette"}
{"hadithnumber": "3542", "arabic": "حَدَّثَنَا أَبُو بِشْرٍ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا مُحَمَّدُ بْنُ فُضَيْلٍ، عَنْ عُمَارَةَ بْنِ الْقَعْقَاعِ، عَنْ أَبِي زُرْعَةَ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ كَلِمَتَانِ خَفِيفَتَانِ عَلَى اللِّسَانِ ثَقِيلَتَانِ فِي الْمِيزَانِ حَبِيبَتَانِ إِلَى الرَّحْمَنِ سُبْحَانَ اللَّهِ وَبِحَمْدِهِ سُبْحَانَ اللَّهِ الْعَظِيمِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "the Messenger of Allah (ﷺ) said: 'Two words which are light on the tongue and heavy in the Balance, and beloved to the Most Merciful: Subhan-Allah wa bi hamdihi, Subhan-Allahil-'Azim (Glory and praise is to Allah, glory is to Allah the Almighty).\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah that :", "chapter_intro": "Etiquette"}
{"hadithnumber": "3543", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَفَّانُ، حَدَّثَنَا حَمَّادُ بْنُ سَلَمَةَ، عَنْ أَبِي سِنَانٍ، عَنْ عُثْمَانَ بْنِ أَبِي سَوْدَةَ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ مَرَّ بِهِ وَهُوَ يَغْرِسُ غَرْسًا فَقَالَ ‏\"‏ يَا أَبَا هُرَيْرَةَ مَا الَّذِي تَغْرِسُ ‏\"‏ ‏.‏ قُلْتُ غِرَاسًا لِي ‏.‏ قَالَ ‏\"‏ أَلاَ أَدُلُّكَ عَلَى غِرَاسٍ خَيْرٍ لَكَ مِنْ هَذَا ‏\"‏ ‏.‏ قَالَ بَلَى يَا رَسُولَ اللَّهِ ‏.‏ قَالَ ‏\"‏ قُلْ سُبْحَانَ اللَّهِ وَالْحَمْدُ لِلَّهِ وَلاَ إِلَهَ إِلاَّ اللَّهُ وَاللَّهُ أَكْبَرُ يُغْرَسْ لَكَ بِكُلِّ وَاحِدَةٍ شَجَرَةٌ فِي الْجَنَّةِ ‏\"‏ ‏.‏", "bengali": "", "english": "the Messenger of Allah (ﷺ) passed by him when he was planting a plant, and said: \"O Abu Hurairah, what are you planting?\" I said: \"A plant for me.\" He said: \"Shall I not tell you of a plant that is better than this?\" He said: \"Of course, O Messenger of Allah.\" He said: \"Say: 'Subhan-Allah, wal-hamdu-lillah, wa la ilaha illallah, wa Allahu Akbar (Glory is to Allah, praise is to Allah, none has the right to be worshiped but Allah and Allah is the Most Great.)' For each one a tree will be planted for you in Paradise.\"", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جذامیوں  ( ک", "grades": "", "reference": "", "international_number": "3543", "narrator_chain": "It was narrated from Abu Hurairah that :", "chapter_intro": "Etiquette"}
{"hadithnumber": "3544", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ، حَدَّثَنَا مِسْعَرٌ، حَدَّثَنِي مُحَمَّدُ بْنُ عَبْدِ الرَّحْمَنِ، عَنْ أَبِي رِشْدِينَ، عَنِ ابْنِ عَبَّاسٍ، عَنْ جُوَيْرِيَةَ، قَالَتْ مَرَّ بِهَا رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ حِينَ صَلَّى الْغَدَاةَ أَوْ بَعْدَ مَا صَلَّى الْغَدَاةَ وَهِيَ تَذْكُرُ اللَّهَ فَرَجَعَ حِينَ ارْتَفَعَ النَّهَارُ - أَوْ قَالَ انْتَصَفَ - وَهِيَ كَذَلِكَ فَقَالَ ‏ ‏ لَقَدْ قُلْتُ مُنْذُ قُمْتُ عَنْكِ أَرْبَعَ كَلِمَاتٍ ثَلاَثَ مَرَّاتٍ هِيَ أَكْثَرُ وَأَرْجَحُ - أَوْ أَوْزَنُ - مِمَّا قُلْتِ سُبْحَانَ اللَّهِ عَدَدَ خَلْقِهِ سُبْحَانَ اللَّهِ رِضَا نَفْسِهِ سُبْحَانَ اللَّهِ زِنَةَ عَرْشِهِ سُبْحَانَ اللَّهِ مِدَادَ كَلِمَاتِهِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"The Messenger of Allah (ﷺ) passed by her when he prayed the morning prayer, or after he prayed the morning prayer, and she was remembering Allah.  He came back when the sun had risen\" - or he (one of the narrators) said, \"at midday - and she was still doing that. He said: 'I have said four words, three times, since I left you, and they are greater and weigh more heavily than what you have said.  They are: Subhan-Allahi 'adada khalqiha, Subhan-Allahi rida nafsihi, Subhan-Allahi zinata 'arshihi, Subhan-Allah midada kalimatihi (Glory is to Allah, as much as the number of His creation, glory is to Allah as much as pleases Him, glory is to Allah as much as the weight of His Throne, glory is to Allah as much as the ink of His words'.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Juwairiyah said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3545", "arabic": "حَدَّثَنَا أَبُو بِشْرٍ، بَكْرُ بْنُ خَلَفٍ حَدَّثَنِي يَحْيَى بْنُ سَعِيدٍ، عَنْ مُوسَى بْنِ أَبِي عِيسَى الطَّحَّانِ، عَنْ عَوْنِ بْنِ عَبْدِ اللَّهِ، عَنْ أَبِيهِ، أَوْ عَنْ أَخِيهِ، عَنِ النُّعْمَانِ بْنِ بَشِيرٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِنَّ مِمَّا تَذْكُرُونَ مِنْ جَلاَلِ اللَّهِ التَّسْبِيحَ وَالتَّهْلِيلَ وَالتَّحْمِيدَ يَنْعَطِفْنَ حَوْلَ الْعَرْشِ لَهُنَّ دَوِيٌّ كَدَوِيِّ النَّحْلِ تُذَكِّرُ بِصَاحِبِهَا أَمَا يُحِبُّ أَحَدُكُمْ أَنْ يَكُونَ لَهُ - أَوْ لاَ يَزَالَ لَهُ - مَنْ يُذَكِّرُ بِهِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "the Messenger of Allah (ﷺ) said: \"What you mention of glory of Allah, of Tabsih (Subhan-Allah), Tahlil (Allahu-Akbar) and Tahmid (Al-Hamdu lillah), revolves around the Throne, buzzing like bees, reminding of the one who said it.  Wouldn't any one of you like to have, or continue to have, something that reminds of him (in the presence of Allah)?'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Nu'man bin Bashir that :", "chapter_intro": "Etiquette"}
{"hadithnumber": "3546", "arabic": "حَدَّثَنَا إِبْرَاهِيمُ بْنُ الْمُنْذِرِ الْحِزَامِيُّ، حَدَّثَنَا أَبُو يَحْيَى، زَكَرِيَّا بْنُ مَنْظُورٍ حَدَّثَنِي مُحَمَّدُ بْنُ عُقْبَةَ بْنِ أَبِي مَالِكٍ، عَنْ أُمِّ هَانِئٍ، قَالَتْ أَتَيْتُ إِلَى رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ فَقُلْتُ يَا رَسُولَ اللَّهِ دُلَّنِي عَلَى عَمَلٍ فَإِنِّي قَدْ كَبِرْتُ وَضَعُفْتُ وَبَدَّنْتُ ‏.‏ فَقَالَ ‏ ‏ كَبِّرِي اللَّهَ مِائَةَ مَرَّةٍ وَاحْمَدِي اللَّهَ مِائَةَ مَرَّةٍ وَسَبِّحِي اللَّهَ مِائَةَ مَرَّةٍ خَيْرٌ مِنْ مِائَةِ فَرَسٍ مُلْجَمٍ مُسْرَجٍ فِي سَبِيلِ اللَّهِ وَخَيْرٌ مِنْ مِائَةِ بَدَنَةٍ وَخَيْرٌ مِنْ مِائَةِ رَقَبَةٍ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"I came to the Messenger of Allah (ﷺ) and said: 'O Messenger of Allah, tell me of a (good) deed, for I have become old and weak and overweight.' He said: 'Proclaim the greatness of Allah (say Allahu Akbar) one hundred times, praise Allah (say Al-Hamdu Lillah) one hundred times, and glorify Allah (say Subhan-Allah) one hundred times. (That is) better than one hundred horses bridled and saddled for the sake of Allah, better than one hundred sacrificial camels, and better than (freeing) one hundred slaves.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Umm Hani' said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3547", "arabic": "حَدَّثَنَا أَبُو عُمَرَ، حَفْصُ بْنُ عَمْرٍو حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، حَدَّثَنَا سُفْيَانُ، عَنْ سَلَمَةَ بْنِ كُهَيْلٍ، عَنْ هِلاَلِ بْنِ يِسَافٍ، عَنْ سَمُرَةَ بْنِ جُنْدَبٍ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ أَرْبَعٌ أَفْضَلُ الْكَلاَمِ لاَ يَضُرُّكَ بِأَيِّهِنَّ بَدَأْتَ سُبْحَانَ اللَّهِ وَالْحَمْدُ لِلَّهِ وَلاَ إِلَهَ إِلاَّ اللَّهُ وَاللَّهُ أَكْبَرُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "the Prophet (ﷺ) said: \"(There are) four that are the best of words, and it does not matter with which you begin: Subhan-Allah, wal-Hamdu-Lillah, wa la ilaha illallah, wa Allahu Akbar (Glory is to Allah, praise is to Allah, none has the right to be worshiped but Allah and Allah is the Most Great).\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Samurah bin Jundab that :", "chapter_intro": "Etiquette"}
{"hadithnumber": "3548", "arabic": "حَدَّثَنَا نَصْرُ بْنُ عَبْدِ الرَّحْمَنِ الْوَشَّاءُ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ الْمُحَارِبِيُّ، عَنْ مَالِكِ بْنِ أَنَسٍ، عَنْ سُمَىٍّ، عَنْ أَبِي صَالِحٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ قَالَ سُبْحَانَ اللَّهِ وَبِحَمْدِهِ مِائَةَ مَرَّةٍ غُفِرَتْ لَهُ ذُنُوبُهُ وَلَوْ كَانَتْ مِثْلَ زَبَدِ الْبَحْرِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "the Messenger of Allah (ﷺ) said: \"Whoever says: Subhan Allahi wa bi hamdihi (Glory and praise is to Allah) one hundred times, his sins will be forgiven even if they were like the foam of the sea.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah that :", "chapter_intro": "Etiquette"}
{"hadithnumber": "3549", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، عَنْ عُمَرَ بْنِ رَاشِدٍ، عَنْ يَحْيَى بْنِ أَبِي كَثِيرٍ، عَنْ أَبِي سَلَمَةَ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ أَبِي الدَّرْدَاءِ، قَالَ قَالَ لِي رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ عَلَيْكَ بِسُبْحَانَ اللَّهِ وَالْحَمْدُ لِلَّهِ وَلاَ إِلَهَ إِلاَّ اللَّهُ وَاللَّهُ أَكْبَرُ فَإِنَّهَا - يَعْنِي - يَحْطُطْنَ الْخَطَايَا كَمَا تَحُطُّ الشَّجَرَةُ وَرَقَهَا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"The Messenger of Allah (ﷺ) said to me: 'You should recite Subhan-Allah, wal-Hamdu-Lillah, wa la ilahah illallah, wa Allahu Akbar (Glory is to Allah, praise is to Allah, none has the right to be worshiped but Allah, and Allah is the Most Great), for it sheds sins like the tree sheds its leaves.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Abu Darda' said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3550", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا أَبُو أُسَامَةَ، وَالْمُحَارِبِيُّ، عَنْ مَالِكِ بْنِ مِغْوَلٍ، عَنْ مُحَمَّدِ بْنِ سُوقَةَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ إِنْ كُنَّا لَنَعُدُّ لِرَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ فِي الْمَجْلِسِ يَقُولُ ‏ ‏ رَبِّ اغْفِرْ لِي وَتُبْ عَلَىَّ إِنَّكَ أَنْتَ التَّوَّابُ الرَّحِيمُ ‏\"\"‏ ‏.‏ مِائَةَ مَرَّةٍ ‏.‏\"", "bengali": "", "english": "\"We used to count that the Messenger of Allah (ﷺ) said one hundred times in a gathering: 'Rabbighfirli wa tub `alayya innaka Antat-Tawwabur-Rahim (O Allah forgive me and accept my repentance, for You are the Accepter of repentance, the Most Merciful).'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Ibn `Umar said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3551", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو، عَنْ أَبِي سَلَمَةَ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِنِّي لأَسْتَغْفِرُ اللَّهَ وَأَتُوبُ إِلَيْهِ فِي الْيَوْمِ مِائَةَ مَرَّةٍ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "the Messenger of Allah (saas) said: 'I seek the forgiveness of Allah and repent to Him one hundred times each day.'", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah that :", "chapter_intro": "Etiquette"}
{"hadithnumber": "3552", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، عَنْ مُغِيرَةَ بْنِ أَبِي الْحُرِّ، عَنْ سَعِيدِ بْنِ أَبِي بُرْدَةَ بْنِ أَبِي مُوسَى، عَنْ أَبِيهِ، عَنْ جَدِّهِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِنِّي لأَسْتَغْفِرُ اللَّهَ وَأَتُوبُ إِلَيْهِ فِي الْيَوْمِ سَبْعِينَ مَرَّةً ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "his grandfather said: \"The Messenger of Allah (saas) said: 'I seek the forgivenenss of Allah and repent to Him seventy times each day.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Sa'eed bin Abu Burdah bin Abu Musa, from his father, that :", "chapter_intro": "Etiquette"}
{"hadithnumber": "3553", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا أَبُو بَكْرِ بْنُ عَيَّاشٍ، عَنْ أَبِي إِسْحَاقَ، عَنْ أَبِي الْمُغِيرَةِ، عَنْ حُذَيْفَةَ، قَالَ كَانَ فِي لِسَانِي ذَرَبٌ عَلَى أَهْلِي وَكَانَ لاَ يَعْدُوهُمْ إِلَى غَيْرِهِمْ فَذَكَرْتُ ذَلِكَ لِلنَّبِيِّ ـ صلى الله عليه وسلم ـ فَقَالَ ‏ ‏ أَيْنَ أَنْتَ مِنَ الاِسْتِغْفَارِ تَسْتَغْفِرُ اللَّهَ فِي الْيَوْمِ سَبْعِينَ مَرَّةً ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"I was harsh in the way I spoke to my family, but not to others.  I mentioned that to the Prophet (saas) and he said: 'Why don't you ask for forgiveness? Ask Allah to forgive you, seventy times each day.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Hudhaifah said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3554", "arabic": "حَدَّثَنَا عَمْرُو بْنُ عُثْمَانَ بْنِ سَعِيدِ بْنِ كَثِيرِ بْنِ دِينَارٍ الْحِمْصِيُّ، حَدَّثَنَا أَبِي، حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الرَّحْمَنِ بْنِ عِرْقٍ، سَمِعْتُ عَبْدَ اللَّهِ بْنَ بُسْرٍ، يَقُولُ قَالَ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏ ‏ طُوبَى لِمَنْ وَجَدَ فِي صَحِيفَتِهِ اسْتِغْفَارًا كَثِيرًا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "the Prophet (saas) said: \"Glad tidings to those who find a lot of seeking forgiveness in the record of their deeds.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "'Abdullah bin Busr said that :", "chapter_intro": "Etiquette"}
{"hadithnumber": "3555", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، حَدَّثَنَا الْحَكَمُ بْنُ مُصْعَبٍ، عَنْ مُحَمَّدِ بْنِ عَلِيِّ بْنِ عَبْدِ اللَّهِ بْنِ عَبَّاسٍ، أَنَّهُ حَدَّثَهُ عَنْ عَبْدِ اللَّهِ بْنِ عَبَّاسٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ لَزِمَ الاِسْتِغْفَارَ جَعَلَ اللَّهُ لَهُ مِنْ كُلِّ هَمٍّ فَرَجًا وَمِنْ كُلِّ ضِيقٍ مَخْرَجًا وَرَزَقَهُ مِنْ حَيْثُ لاَ يَحْتَسِبُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "the Messenger of Allah said: \"Whoever persists in asking for forgiveness, Allah will grant him relief from every worry, and a way out from every hardship, and will grant him provision from (sources) he could never imagine.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from 'Abdullah bin 'Abbas that :", "chapter_intro": "Etiquette"}
{"hadithnumber": "3556", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، عَنْ حَمَّادِ بْنِ سَلَمَةَ، عَنْ عَلَىِّ بْنِ زَيْدٍ، عَنْ أَبِي عُثْمَانَ، عَنْ عَائِشَةَ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ كَانَ يَقُولُ ‏ ‏ اللَّهُمَّ اجْعَلْنِي مِنَ الَّذِينَ إِذَا أَحْسَنُوا اسْتَبْشَرُوا وَإِذَا أَسَاءُوا اسْتَغْفَرُوا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "the Prophet (saas) used to say: \"Allahum-maj'alni minal-ladhina idha ahsanu istabsharu, wa idha asa'u istaghfaru (O Allah, make me one of those who, if they do good deeds, they rejoice, and if they do bad deeds, they seek forgiveness).\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from 'Aishah that :", "chapter_intro": "Etiquette"}
{"hadithnumber": "3557", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، عَنِ الأَعْمَشِ، عَنِ الْمَعْرُورِ بْنِ سُوَيْدٍ، عَنْ أَبِي ذَرٍّ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ يَقُولُ اللَّهُ تَبَارَكَ وَتَعَالَى مَنْ جَاءَ بِالْحَسَنَةِ فَلَهُ عَشْرُ أَمْثَالِهَا وَأَزِيدُ وَمَنْ جَاءَ بِالسَّيِّئَةِ فَجَزَاءُ سَيِّئَةٍ مِثْلُهَا أَوْ أَغْفِرُ وَمَنْ تَقَرَّبَ مِنِّي شِبْرًا تَقَرَّبْتُ مِنْهُ ذِرَاعًا وَمَنْ تَقَرَّبَ مِنِّي ذِرَاعًا تَقَرَّبْتُ مِنْهُ بَاعًا وَمَنْ أَتَانِي يَمْشِي أَتَيْتُهُ هَرْوَلَةً وَمَنْ لَقِيَنِي بِقِرَابِ الأَرْضِ خَطِيئَةً ثُمَّ لاَ يُشْرِكُ بِي شَيْئًا لَقِيتُهُ بِمِثْلِهَا مَغْفِرَةً ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "the Messenger of Allah (saas) said: \"Allah, the Blessed and Exalted, said: 'Whoever does one good deed will have (the reward of) ten like it and more, and whoever does a bad deed will have one like it, or I will forgive him.  Whoever draws near to Me a hand span, I draw near to him an arm's length; whoever comes to Me a forearm's length, I draw near him an arm's length; whoever comes to Me walking, I come to him in a hurry.  Whoever meets Me with an earthful of sins, but does not associate anything in worship with Me, I will meet it (i.e., his sins) with forgiveness equal to that.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Dharr that :", "chapter_intro": "Etiquette"}
{"hadithnumber": "3558", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا أَبُو مُعَاوِيَةَ، عَنِ الأَعْمَشِ، عَنْ أَبِي صَالِحٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ يَقُولُ اللَّهُ سُبْحَانَهُ أَنَا عِنْدَ ظَنِّ عَبْدِي بِي وَأَنَا مَعَهُ حِينَ يَذْكُرُنِي فَإِنْ ذَكَرَنِي فِي نَفْسِهِ ذَكَرْتُهُ فِي نَفْسِي وَإِنْ ذَكَرَنِي فِي مَلإٍ ذَكَرْتُهُ فِي مَلإٍ خَيْرٍ مِنْهُمْ وَإِنِ اقْتَرَبَ إِلَىَّ شِبْرًا اقْتَرَبْتُ إِلَيْهِ ذِرَاعًا وَإِنْ أَتَانِي يَمْشِي أَتَيْتُهُ هَرْوَلَةً ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "the Messenger of Allah (saas) said: \"Allah says, 'I am as My slave thinks I am, and I am with him when he mentions Me. If he makes mention of Me to himself, I make mention of him to Myself; and if he makes mention of Me in an assembly, I make mention of him in an assembly better than it.  And if he draws to Me a hand-span length, I draw near to him a forearm's length.  And if he comes to Me walking, I go to him in a hurry.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah that :", "chapter_intro": "Etiquette"}
{"hadithnumber": "3559", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، وَوَكِيعٌ، عَنِ الأَعْمَشِ، عَنْ أَبِي صَالِحٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ كُلُّ عَمَلِ ابْنِ آدَمَ يُضَاعَفُ لَهُ الْحَسَنَةُ بِعَشْرِ أَمْثَالِهَا إِلَى سَبْعِمِائَةِ ضِعْفٍ ‏.‏ قَالَ اللَّهُ سُبْحَانَهُ إِلاَّ الصَّوْمَ فَإِنَّهُ لِي وَأَنَا أَجْزِي بِهِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "of Allah (saas) said: \"Every deed of the son of Adam will be multiplied for him, between ten and seven hundred times for each merit. Allah said: 'Except for fasting, for it is for Me and I shall reward for it.'\" (sahih)", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah that the Messenger :", "chapter_intro": "Etiquette"}
{"hadithnumber": "3560", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، أَنْبَأَنَا جَرِيرٌ، عَنْ عَاصِمٍ الأَحْوَلِ، عَنْ أَبِي عُثْمَانَ، عَنْ أَبِي مُوسَى، قَالَ سَمِعَنِي النَّبِيُّ ـ صلى الله عليه وسلم ـ وَأَنَا أَقُولُ، لاَ حَوْلَ وَلاَ قُوَّةَ إِلاَّ بِاللَّهِ ‏.‏ قَالَ ‏\"‏ يَا عَبْدَ اللَّهِ بْنَ قَيْسٍ أَلاَ أَدُلُّكَ عَلَى كَلِمَةٍ مِنْ كُنُوزِ الْجَنَّةِ ‏\"‏ ‏.‏ قُلْتُ بَلَى يَا رَسُولَ اللَّهِ ‏.‏ قَالَ ‏\"‏ قُلْ لاَ حَوْلَ وَلاَ قُوَّةَ إِلاَّ بِاللَّهِ ‏\"‏ ‏.‏", "bengali": "", "english": "\"The Prophet (saas) heard me saying: 'La hawla wa la quwwata illa billah (there is no power and no strength except with Allah).' He said: 'O 'Abdullah bin Qais! Shall I not tell you of a word which is one of the treasures of Paradise?' I said: 'Yes, O Messenger of Allah.' He said: 'Say: La hawla wa la quwwata illa billah (There is no power and no strength except with Allah).'\"", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے دو طرح کے پہناوے سے منع فرمایا", "grades": "", "reference": "", "international_number": "3560", "narrator_chain": "It was narrated that Abu Musa said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3561", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، عَنِ الأَعْمَشِ، عَنْ مُجَاهِدٍ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِي لَيْلَى، عَنْ أَبِي ذَرٍّ، قَالَ قَالَ لِي رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏\"‏ أَلاَ أَدُلُّكَ عَلَى كَنْزٍ مِنْ كُنُوزِ الْجَنَّةِ ‏\"‏ ‏.‏ قُلْتُ بَلَى يَا رَسُولَ اللَّهِ ‏.‏ قَالَ ‏\"‏ لاَ حَوْلَ وَلاَ قُوَّةَ إِلاَّ بِاللَّهِ ‏\"‏ ‏.‏", "bengali": "", "english": "\"The Messenger of Allah (saas) said to me: \"Shall I not tell you of a treasure which is one of the treasures of Paradise?' I said: 'Yes, O Messenger of Allah.' He said: 'La hawla wa la quwwata illa billah (There is no power and no strength except with Allah).'\" (sahih)", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے دو طرح کے پہناوے سے منع", "grades": "", "reference": "", "international_number": "3561", "narrator_chain": "It was narrated that Abu Dharr said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3562", "arabic": "حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدٍ الْمَدَنِيُّ، حَدَّثَنَا مُحَمَّدُ بْنُ مَعْنٍ، حَدَّثَنَا خَالِدُ بْنُ سَعِيدٍ، عَنْ أَبِي زَيْنَبَ، مَوْلَى حَازِمِ بْنِ حَرْمَلَةَ عَنْ حَازِمِ بْنِ حَرْمَلَةَ، قَالَ مَرَرْتُ بِالنَّبِيِّ ـ صلى الله عليه وسلم ـ فَقَالَ لِي ‏ ‏ يَا حَازِمُ أَكْثِرْ مِنْ قَوْلِ لاَ حَوْلَ وَلاَ قُوَّةَ إِلاَّ بِاللَّهِ فَإِنَّهَا مِنْ كُنُوزِ الْجَنَّةِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"I passed by the Prophet (saas) and he said to me: 'O Hazim, say often: \"La hawla wa la quwwata illa billah (there is no power and no strength except with Allah),\" for it is one of the treasures of Paradise.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Hazim bin Harmalah said:", "chapter_intro": "Etiquette"}
{"hadithnumber": "3657", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا شَرِيكُ بْنُ عَبْدِ اللَّهِ،‏‏‏‏ عَنْ مَ", "bengali": "", "english": "Ibn Salamah As-Sulami narrated that the Prophet (ﷺ) said:\"I enjoin each one to honor his mother,I enjoin each one to honor his mother,I enjoin each one to honor his mother(three times), I enjoin each one to honor his guardian who is taking care of him, even if he is causing him some annoyance", "french": "", "indonesian": "", "russian": "", "urdu": "ابن سلامہ سلمی رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  میں آدمی کو اپنی م", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 1", "international_number": "3657", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3658", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ مَيْمُونٍ الْمَكِّيُّ،‏‏‏‏ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ،‏‏‏‏ عَنْ", "bengali": "", "english": "Abu Hurairah, may Allah be pleased with them, said that:Allah's Messenger said: \"They said: 'O Messenger of Allah, whom should I treat kindly?' He said: 'Your mother.' He said: 'Then who?' He said :'Your mother.\" He said: 'Then who?' He said: 'Your father'. He said : 'Then who?' He said: 'The next closest and the next closest", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  لوگوں نے عرض کیا: اللہ کے رسول! حسن سلوک  ( اچھے برتاؤ )  کا سب", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 33, Hadith 2", "international_number": "3658", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3659", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا جَرِيرٌ،‏‏‏‏ عَنْ سُهَيْلٍ،‏‏‏‏ عَنْ أَب", "bengali": "", "english": "Abu Hurairah, may Allah be pleased with them, narrated that:Allah's Messenger said: \"No child can compensate his father unless he finds a slave, and buys him and sets him free", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  کوئی بھی اولاد اپنے باپ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 33, Hadith 3", "international_number": "3659", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3660", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ،", "bengali": "", "english": "Abu Hurairah, may Allah be pleased with them, narrated that:Allah's Messenger said: \"Qintar is twelve thousand 'Uqiyah, each 'Uqiyah of which is better than what is between heaven and earth.\" And the Messenger of Allah(ﷺ) said: \"A man will be raised in status in Paradise and will say: 'Where did this come from?' And it will be said:'From your son's praying for forgiveness for you", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:   «قنطار» بارہ ہزار «اوقیہ", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 33, Hadith 4", "international_number": "3660", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3661", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ،‏‏‏‏ حَدَّثَنَا إِسْمَاعِيل بْنُ عَيَّاشٍ،‏‏‏‏ عَنْ بَحِيرِ بْنِ سَ", "bengali": "", "english": "Miqdam bin Ma'dikarib, may Allah be pleased with them, narrated that:Allah's Messenger said: \"Allah enjoins you to treat your mother's kindly\"-three times- \"Allah enjoins you to treat your fathers kindly, Allah enjoins you to treat the closest and the next closest kindly", "french": "", "indonesian": "", "russian": "", "urdu": "مقدام بن معدیکرب رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  بیشک اللہ تعالیٰ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 33, Hadith 5", "international_number": "3661", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3662", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ،‏‏‏‏ حَدَّثَنَا صَدَقَةُ بْنُ خَالِدٍ،‏‏‏‏ حَدَّثَنَا عُثْمَانُ بْن", "bengali": "", "english": "Abu Umamah narrated that a man said that:\"O Allah's Messenger(ﷺ), what are the rights of parents over their child?\" He said:\"They are your Paradise and your Hell.\" (Daif)", "french": "", "indonesian": "", "russian": "", "urdu": "ابوامامہ رضی اللہ عنہ سے روایت ہے کہ  ایک شخص نے عرض کیا: اللہ کے رسول! والدین کا حق ان کی اولاد پر", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 6", "international_number": "3662", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3663", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ،‏‏‏‏ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ،‏‏‏‏ عَنْ عَطَاءٍ،‏‏", "bengali": "", "english": "Abu Darda' heard the Prophet (ﷺ) say that:\"The father is the middle door of Paradise (i.e. the best way to Paradise), so it is up to you whether you take advantage of it or not", "french": "", "indonesian": "", "russian": "", "urdu": "ابوالدرداء رضی اللہ عنہ کہتے ہیں کہ  انہوں نے نبی اکرم صلی اللہ علیہ وسلم کو فرماتے سنا:  باپ جنت کا", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 33, Hadith 7", "international_number": "3663", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3664", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ إِدْرِيسَ،‏‏‏‏ عَنْ عَبْدِ الر", "bengali": "", "english": "It was narrated that Abu Usaid, Malik bin Rabi'ah, said:\"While we were with the Prophet(ﷺ), a man from the Banu Salamah came to him and said: \" O messenger of Allah, is there anyway of honoring my parents that I can still do for them after they die?' He said: \"Yes offering the funeral prayer for them, praying for forgiveness for them, fulfilling their promises after their death, honoring their freinds and upholding the ties of kinship which you would not have were it nor for them", "french": "", "indonesian": "", "russian": "", "urdu": "ابواسید مالک بن ربیعہ رضی اللہ عنہ کہتے ہیں کہ  ہم نبی اکرم صلی اللہ علیہ وسلم کے پاس موجود تھے، اتن", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 33, Hadith 8", "international_number": "3664", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3665", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا أَبُو أُسَامَةَ،‏‏‏‏ عَنْ هِشَامِ بْنِ ع", "bengali": "", "english": "It was narrated that Aisha, said:\"Some Bedouin people came to the Prophet(ﷺ) and said: 'Do you kiss your children?' He said: 'Yes'. He said: 'But we, by Allah, never kiss (our children)'. The Prophet(ﷺ) said: 'What can I do if Allah has taken away mercy from you?", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  کچھ اعرابی نبی اکرم صلی اللہ علیہ وسلم کی خدمت میں حاضر", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 33, Hadith 9", "international_number": "3665", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3666", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَفَّانُ،‏‏‏‏ حَدَّثَنَا وُهَيْبٌ،‏‏‏‏ ح", "bengali": "", "english": "It was narrated from Ya'la Al -Amir that he said:\"Hasan and Hussain came running to the Prophet (ﷺ) and he embraced them and said: 'Children make a man a miser and a coward", "french": "", "indonesian": "", "russian": "", "urdu": "یعلیٰ عامری رضی اللہ عنہ کہتے ہیں کہ  حسن اور حسین  ( رضی اللہ عنہما )  دونوں دوڑتے ہوئے نبی اکرم صل", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 33, Hadith 10", "international_number": "3666", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3667", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا زَيْدُ بْنُ الْحُبَابِ،‏‏‏‏ عَنْ مُوسَى", "bengali": "", "english": "It was narrated from Suraqah bin Malik that the Prophet(ﷺ) said:\"Shall I not tell you of the best charity? A daughter who comes back to you and has no other breadwinner apart from you.\" (Daif)", "french": "", "indonesian": "", "russian": "", "urdu": "سراقہ بن مالک رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  کیا میں تم کو افضل ص", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 11", "international_number": "3667", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3668", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ،‏‏‏‏ عَنْ مِسْعَرٍ", "bengali": "", "english": "It was narrated that Sa'sa'ah the paternal uncle of Ahnaf, said:\"A woman entered upon Aisha with her two daughters, and she gave her three dates. (The woman) gave each of her daughters a date, then she split the last one between them. She (Aisha) said: 'Then the Prophet(ﷺ) came and I told him about that.' He said:' Why are you surprised? She will enter Paradise because of that", "french": "", "indonesian": "", "russian": "", "urdu": "احنف کے چچا صعصعہ رضی اللہ عنہ کہتے ہیں کہ  ایک عورت اپنی دو بیٹیوں کو ساتھ لے کر ام المؤمنین عائشہ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 33, Hadith 12", "international_number": "3668", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3669", "arabic": "حَدَّثَنَا الْحُسَيْنُ بْنُ الْحَسَنِ الْمَرْوَزِيُّ،‏‏‏‏ حَدَّثَنَا ابْنُ الْمُبَارَكِ،‏‏‏‏ عَنْ حَ", "bengali": "", "english": "Uqbah bin Amir said, I heard the Messenger of Allah(ﷺ) say:\"Whoever has three daughters and is patient towards them, and feeds them, gives them to drink, and clothes them from his wealth; they will be a shield for him from the Fire on the Day of Resurrection", "french": "", "indonesian": "", "russian": "", "urdu": "عقبہ بن عامر رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  جس کے پاس", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 33, Hadith 13", "international_number": "3669", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3670", "arabic": "حَدَّثَنَا الْحُسَيْنُ بْنُ الْحَسَنِ،‏‏‏‏ حَدَّثَنَا ابْنُ الْمُبَارَكِ،‏‏‏‏ عَنْ فِطْرٍ،‏‏‏‏ عَنْ", "bengali": "", "english": "It was narrated from Ibn Abbas that the Messenger of Allah(ﷺ) said:\"There is no man whose two daughters reach the age of puberty and he treats them kindly for the time they are together, but they will gain him admittance to Paradise", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس شخص کے پاس د", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 33, Hadith 14", "international_number": "3670", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3671", "arabic": "حَدَّثَنَا الْعَبَّاسُ بْنُ الْوَلِيدِ الدِّمَشْقِيُّ،‏‏‏‏ حَدَّثَنَا عَلِيُّ بْنُ عَيَّاشٍ،‏‏‏‏ حَد", "bengali": "", "english": "Anas bin Malik narrated that the Messenger of Allah(ﷺ) said:\"Be kind to your children, and perfect their manners", "french": "", "indonesian": "", "russian": "", "urdu": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم لوگ اپنی اولاد کے", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 15", "international_number": "3671", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3672", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ،‏‏‏‏ عَنْ عَمْ", "bengali": "", "english": "It was narrated from Abu Shuraih Al-Khuzai that the Prophet(ﷺ) said:\"Whoever believes in the Last Day, let him treat his neighbour well. Whoever believes in Allah and Last Day, let him honor his guest. Whoever believes in Allah and the Last Day, let him say something good or else remain silent", "french": "", "indonesian": "", "russian": "", "urdu": "ابوشریح خزاعی رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جو شخص اللہ اور ا", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 33, Hadith 16", "international_number": "3672", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3673", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ،‏‏‏‏ وَعَبْدَةُ بْ", "bengali": "", "english": "Aisha narrated that the Messenger of Allah(ﷺ) said:\"Jibra'il kept enjoining good treatment of neighbours untol I thought that he would make neigbours heirs", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مجھے جبرائیل ع", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 33, Hadith 17", "international_number": "3673", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3674", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ حَدَّثَنَا يُونُسُ بْنُ أَبِي إِسْحَا", "bengali": "", "english": "It was narrated from Abu Hurayrah that the Messenger of Allah(ﷺ) said:\"Jibra'il kept enjoining good treatment of neighbours until I thought he would make neighbours heirs", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جبرائیل برابر پڑوسی کے ب", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 33, Hadith 18", "international_number": "3674", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3675", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ،‏‏‏‏ عَنْ ابْن", "bengali": "", "english": "It was narrated from Abu Shuraih Al-Khuza'i that the Messenger of Allah(ﷺ) said:\"Whoever believes in the Last Day, let him honor his guest, and grant him reward for a day and a night. And it is not permissible for him to stay so long that he causes annoyance to his host. Hospitality is for three days, and whatever he spends on him after three days is charity", "french": "", "indonesian": "", "russian": "", "urdu": "ابوشریح خزاعی رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جو شخص اللہ اور آخر", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 33, Hadith 19", "international_number": "3675", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3676", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ،‏‏‏‏ أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ،‏‏‏‏ عَنْ يَزِيدَ بْنِ أَبِي", "bengali": "", "english": "It was narrated that Uqbah bin Amir said:\"We said to the Messenger of Allah(ﷺ): ' You send us and we stay with people who do not show us any hospitality. WHat do you think of that?' The MEssenger of Allah (ﷺ) said: 'If you stay with people and they give you what a guest deserves, then accept it. If they do not do that , then take from them what they should have offered, which a guest is entitled to", "french": "", "indonesian": "", "russian": "", "urdu": "عقبہ بن عامر رضی اللہ عنہ کہتے ہیں کہ  ہم نے رسول اللہ صلی اللہ علیہ وسلم سے عرض کیا: آپ ہم کو لوگوں", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 33, Hadith 20", "international_number": "3676", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3677", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ حَدَّثَنَا سُفْيَانُ،‏‏‏‏ عَنْ مَنْصُ", "bengali": "", "english": "It was narrated that Miqdam Abu Karimah said:\"The Messenger of Allah(ﷺ) said: ' Putting up a guest for one night is obligatory. If you find a guest at your door in the morning, then this (hospitality) is (like) a debt that you (the host) owe him. If he (the guest) wants, he may request it, and if he wants, he may leave it", "french": "", "indonesian": "", "russian": "", "urdu": "مقدام ابوکریمہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اگر کسی کے یہاں را", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 33, Hadith 21", "international_number": "3677", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3678", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ الْقَطَّانُ،‏‏‏‏ عَ", "bengali": "", "english": "It was narrated from Abu Hurairah that the Messenger of Allah(ﷺ) said:\"O Allah, bear witness that I have issued a warning concerning (failure to fulfill) the rights of the two weak ones: Orphans and women", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اے اللہ! میں دو کمزوروں", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 33, Hadith 22", "international_number": "3678", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3679", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا يَحْيَى بْنُ آدَمَ،‏‏‏‏ حَدَّثَنَا ابْنُ الْمُبَار", "bengali": "", "english": "It was narrated from Abu Hurairah that the Messenger of Allah(ﷺ) said:\"The best house among the Muslims is a house in which there is an orphan who is treated well. And the worst house among the Muslims is a house in which there is an orphan who is treated badly", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  مسلمانوں میں سب سے بہتر گ", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 23", "international_number": "3679", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3680", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ،‏‏‏‏ حَدَّثَنَا حَمَّادُ بْنُ عَبْدِ الرَّحْمَنِ الْكَلْبِيُّ،‏‏‏‏", "bengali": "", "english": "It was narrated from `Abdullah bin `Abbas that the Messenger of Allah(ﷺ) said:\"Whoever raises three orphans, is like the one who spends his nights in prayer and fasts during the day, and goes out morning and evening drawing his sword in the cause of Allah. In Paradise, he and I will be brothers like these two sisters,'and he held up his forefinger and middle finger together", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس شخص نے تین ی", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 24", "international_number": "3680", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3681", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ قَالَا:‏‏‏‏ حَدَّثَنَ", "bengali": "", "english": "It was narrated that Abu Barzah Al-Aslami said:\"O Messenger of Allah! Tell me of an action by which I may benefit.' He said: 'Remove harmful things from the path of the Muslims", "french": "", "indonesian": "", "russian": "", "urdu": "ابوبرزہ اسلمی رضی اللہ عنہ کہتے ہیں کہ  میں نے عرض کیا: اللہ کے رسول! مجھے کوئی ایسا عمل بتائیے جس س", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 33, Hadith 25", "international_number": "3681", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3682", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ،‏‏‏‏ عَنْ ا", "bengali": "", "english": "It was narrated from Abu Hurayrah that the Prophet(ﷺ) said:\"There was a branch of a tree that annoyed the people. A man removed it, so he was admitted to Paradise", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  راستے میں ایک درخت کی شاخ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 33, Hadith 26", "international_number": "3682", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3683", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ،‏‏‏‏ أَنْبَأَنَا ه", "bengali": "", "english": "It was narrated from Abu Dharr that the Prophet(ﷺ) said:\"My nation was shown to me with their good deeds and bad deeds. Among their good deeds I saw a harmful thing being removed from the road. And among their bad deeds I saw sputum in the mosque that had not been removed", "french": "", "indonesian": "", "russian": "", "urdu": "ابوذر رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  میری امت کے اچھے اور برے اعم", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 33, Hadith 27", "international_number": "3683", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3684", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ هِشَامٍ صَاحِبِ الدَّسْتُوَائِيّ", "bengali": "", "english": "It was narrated that Sad bin Ubadah said:\"I said: 'O Messenger of Allah, what charity is best?' He said: 'Giving water to drink", "french": "", "indonesian": "", "russian": "", "urdu": "سعد بن عبادہ رضی اللہ عنہ کہتے ہیں کہ  میں نے عرض کیا:  اللہ کے رسول! کون سا صدقہ افضل ہے؟ آپ صلی ال", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 28", "international_number": "3684", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3685", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ،‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ قَالَا:‏‏‏", "bengali": "", "english": "It was narrated from Anas bin Malik that the Messenger of Allah(ﷺ) said:\"On the Day of Resurrection, people will be lined up in rows, (one of the narrators) Ibn NUmair said: i.e., the people of Paradise, and a man from among the people of Hell will pass by a man (from the people of Paradise) and say: 'O so and so! Do you not remember the day when you asked for water and I gave you water to drink?\" So he will intercede for him. And another man will come and say: \" Do you not remember the day when I gave you water with which to purify yourself?\" and he will intercede for him.\" (In his narration, one of the narrators) Ibn NUmair said: \"And he will remember the day when you sent me to do such and such for you, and I went and did it for you?' and he will intercede for him", "french": "", "indonesian": "", "russian": "", "urdu": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  قیامت کے دن لوگوں کی", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Very Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 29", "international_number": "3685", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3686", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ،‏‏‏‏ حَدَّث", "bengali": "", "english": "It was narrated that Suraqah bin Ju'shum said:\"I asked the Messenger of Allah(ﷺ) about a lost camel that comes to my cisterns that I have prepared for my own camels - will I be rewarded if I give it some water to drink? He said: Yes, in every living being there is reward", "french": "", "indonesian": "", "russian": "", "urdu": "سراقہ بن جعشم رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم سے گمشدہ اونٹوں کے متعلق", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 33, Hadith 30", "international_number": "3686", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3687", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ الْأَعْمَشِ،‏‏‏‏ عَنْ تَمِيمِ بْ", "bengali": "", "english": "It was narrated from Jarir bin Abdullah Al-Bajali that the Messenger of Allah(ﷺ) said:\"Whoever is deprived of gentleness, he is deprived of goodness", "french": "", "indonesian": "", "russian": "", "urdu": "جریر بن عبداللہ بجلی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص نرمی", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 33, Hadith 31", "international_number": "3687", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3688", "arabic": "حَدَّثَنَا إِسْمَاعِيل بْنُ حَفْصٍ الْأُبُلِّيُّ،‏‏‏‏ حَدَّثَنَا أَبُو بَكْرِ بْنُ عَيَّاشٍ،‏‏‏‏ عَن", "bengali": "", "english": "It was narrated from Abu Hurairah that the Messenger of Allah(ﷺ) said:\"Allah is Gentle and loves gentleness, and He grants reward for it that He does not grant for harshness", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  بیشک اللہ تعالیٰ مہربان ہ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 33, Hadith 32", "international_number": "3688", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3689", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا مُحَمَّدُ بْنُ مُصْعَبٍ،‏‏‏‏ عَنْ الْأَو", "bengali": "", "english": "It was narrated from Aishah that the Prophet(ﷺ) said:\"Allah is Gentle and loves gentleness in all things", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  بیشک اللہ نرمی", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Bukhari And Muslim'}", "reference": "Book 33, Hadith 33", "international_number": "3689", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3690", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ حَدَّثَنَا الْأَعْمَشُ،‏‏‏‏", "bengali": "", "english": "It was narrated that Abu Dhar said:\"The Messenger of Allah said: '(Slaves are) your brothers whom Allah has put under your control, so feed them with the same food that you eat, clothe them with the same clothes you wear, and do not burden them with so much that htey are overwhelmed; if you do burden them, then help them", "french": "", "indonesian": "", "russian": "", "urdu": "ابوذر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہعلیہ وسلم  نے فرمایا:   ( حقیقت میں لونڈی اور غلام", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 33, Hadith 34", "international_number": "3690", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3691", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ قَالَا:‏‏‏‏ حَدَّثَنَ", "bengali": "", "english": "It was narrated from Abu Bakr Siddiq(RA) that the Messenger of Allah(ﷺ) said:\"No person who mistreats his slave will enter Paradise.\" They said: \" O Messenger of Allah, did you not tell us that this nation will have more slaves and orphans than any other nation?\" He said: \" Yes, so be as kind to them as you are to your own children, and feed them with the same food that you eat.\" They said: \"What will benefit us in this world?\" He said: \"A horse that is kept ready for fighting in the cause of Allah, and your slave to take care of you, and if he performs prayer, then he is your brother(in Islam)", "french": "", "indonesian": "", "russian": "", "urdu": "ابوبکر صدیق رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  بدخلق شخص جو اپنے غلا", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 35", "international_number": "3691", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3692", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا أَبُو مُعَاوِيَةَ،‏‏‏‏ وَابْنُ نُمَيْرٍ،", "bengali": "", "english": "It was narrated from Abu Hurairah(RA) that the Messenger of Allah(ﷺ) said:\"By the One in Whose Hand is my soul, you will not enter Paradise until you believe, and you will not believe until you love one another. Shall I not tell you of something which, if you do it, you will love one another? Spread (the greeting of) peace among yourselves", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  قسم ہے اس ذات کی جس کے ہ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 33, Hadith 36", "international_number": "3692", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3693", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا إِسْمَاعِيل بْنُ عَيَّاشٍ،‏‏‏‏ عَنْ مُحَ", "bengali": "", "english": "It was narrated that Abu Umamah said:\"Our Prophet(ﷺ) commanded us to spread (the greeting of) peace", "french": "", "indonesian": "", "russian": "", "urdu": "ابوامامہ رضی اللہ عنہ کہتے ہیں کہ  ہمارے نبی کریم صلی اللہ علیہ وسلم نے ہمیں حکم دیا ہے کہ ہم سلام ک", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 33, Hadith 37", "international_number": "3693", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3694", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا مُحَمَّدُ بْنُ فُضَيْلٍ،‏‏‏‏ عَنْ عَطَاء", "bengali": "", "english": "It was narrated from Abdullah bin 'Amr that the Messenger of Allah(ﷺ) said:\"Worship the Most Merciful and spread (the greeting of) peace", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  رحمن کی عبادت ک", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 33, Hadith 38", "international_number": "3694", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3695", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ،‏‏‏‏ حَدَّث", "bengali": "", "english": "It was narrated from Abu Hurairah that:\"a man entered the masjid, and the Messenger of Allah(ﷺ) was sitting in a corner of the mosque. He prayed, then he came and greeted him with Salam(peace), and he said: 'Wa 'alaikassalm", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  ایک شخص مسجد نبوی میں داخل ہوا، رسول اللہ صلی اللہ علیہ وسلم ا", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 33, Hadith 39", "international_number": "3695", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3696", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ سُلَيْمَانَ،‏‏‏‏", "bengali": "", "english": "It was narrated from Abu Salamah that 'Aishah told him that the Messenger of Allah(ﷺ) said to her:\"Jibrail send (greetings of) Salam to you.\" She said: \"Wa 'alahisalam wa rahmatullah (and upon him be peace and mercy of Allah)", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ان سے فرمایا:  جبرائیل", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 33, Hadith 40", "international_number": "3696", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3697", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا عَبْدَةُ بْنُ سُلَيْمَانَ،‏‏‏‏ وَمُحَمَّدُ بْنُ بِشْرٍ،‏‏‏‏", "bengali": "", "english": "It was narrated that Anas bin Malik said \"the Messenger of Allah(ﷺ) said\":\"When any of the People of the Book greets you with Salam (peace), then say, Wa 'alaikum(and also upon you)", "french": "", "indonesian": "", "russian": "", "urdu": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب اہل کتاب  ( یہود و", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 33, Hadith 41", "international_number": "3697", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3698", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا أَبُو مُعَاوِيَةَ،‏‏‏‏ عَنْ الْأَعْمَشِ،‏‏‏‏ عَنْ مُسْلِمٍ،‏", "bengali": "", "english": "It was narrated from Aishah that some of the Jews came to the Prophet(ﷺ) and said:\"Assam o alaika (death be upon you), O Abul-Qasim!\" He said: \"Wa 'alayikum (and also upon you)", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم کے پاس کچھ یہودی آئے، ا", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 33, Hadith 42", "international_number": "3698", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3699", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا ابْنُ نُمَيْرٍ،‏‏‏‏ عَنْ مُحَمَّدِ بْنِ إِسْحَاق،‏‏‏‏ عَنْ ي", "bengali": "", "english": "It was narrated from Abu 'Abdur-Rahman Al Juhani that the Messenger of Allah(ﷺ) said:\"I am riding to the Jews tomorrow. Do not initiate the greeting with them, and if they greet you, then say: Wa 'alaikum (and also upon you)", "french": "", "indonesian": "", "russian": "", "urdu": "ابوعبدالرحمٰن جہنی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  میں کل سوار ہو", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 33, Hadith 43", "international_number": "3699", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3700", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا أَبُو خَالِدٍ الْأَحْمَرُ،‏‏‏‏ عَنْ حُمَيْدٍ،‏‏‏‏ عَنْ أَنَس", "bengali": "", "english": "It was narrated that Anas said:\"The Messenger of Allah(ﷺ) came to us, and we were young boys, and he greeted us with (the greeting of) peace", "french": "", "indonesian": "", "russian": "", "urdu": "انس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ہمارے پاس تشریف لائے،  ( اس وقت )  ہم بچے", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 33, Hadith 44", "international_number": "3700", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3701", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ،‏‏‏‏ عَنْ ابْنِ أَبِي حُسَيْنٍ،‏‏‏", "bengali": "", "english": "Asma bint Yazid said:\"The Messenger of Allah(ﷺ) passed by us, among (a group of) women, and he greeted us with (the greeting of) peace", "french": "", "indonesian": "", "russian": "", "urdu": "اسماء بنت یزید رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ہم عورتوں کے پاس گزرے تو آپ ن", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 33, Hadith 45", "international_number": "3701", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3702", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ جَرِيرِ بْنِ حَازِمٍ،‏‏‏‏ عَنْ ح", "bengali": "", "english": "It was narrated that Anas bin Malik said:\"O Messenger of Allah! Should we bow to one another?\" He said: \"No.\" We said: \"Should we embrace one another?\" He said: \"No, but shake hands with one another", "french": "", "indonesian": "", "russian": "", "urdu": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  ہم نے عرض کیا: اللہ کے رسول! کیا  ( ملاقات کے وقت )  ہم ایک دو", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 46", "international_number": "3702", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3703", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا أَبُو خَالِدٍ الْأَحْمَرُ،‏‏‏‏ وَعَبْدُ", "bengali": "", "english": "It was narrated from Bara bin Azib that the Messenger of Allah(ﷺ) said:\"There are no two Muslims who meet and shake hands, but they will be forgiven before they part", "french": "", "indonesian": "", "russian": "", "urdu": "براء بن عازب رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب دو مسلمان آپس", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 47", "international_number": "3703", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3704", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا مُحَمَّدُ بْنُ فُضَيْلٍ،‏‏‏‏ حَدَّثَنَا", "bengali": "", "english": "It was narrated that Ibn Umar said:\"We kissed the hand of the Prophet(ﷺ)", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  ہم نے نبی اکرم صلی اللہ علیہ وسلم کا ہاتھ چوما۔", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 48", "international_number": "3704", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3705", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ إِدْرِيسَ،‏‏‏‏ وَغُنْدَرٌ،‏‏‏‏ وَأَبُو أ", "bengali": "", "english": "It was narrated from Safwan bin 'Assal that:\"Some people among the Jews kissed the hands and feet of the Prophet(ﷺ)", "french": "", "indonesian": "", "russian": "", "urdu": "صفوان بن عسال رضی اللہ عنہ سے روایت ہے کہ  یہود کے کچھ لوگوں نے نبی اکرم صلی اللہ علیہ وسلم کے ہاتھ", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 33, Hadith 49", "international_number": "3705", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3706", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ،‏‏‏‏ أَنْبَأَنَا دَاوُدُ بْنُ أَبِي هِ", "bengali": "", "english": "It was narrated from Abu Saeed Khudri that Abu Musa asked permission to enter upon 'Umar three times, and he did not give him permission, so he went away.'Umar sent word to him saying:\"Why did you go back?\" He said: \"I asked permission to enter three times, as the Messenger of Allah(ﷺ) enjoined upon us, then if we are given permission we should enter, otherwise we should go back.\" He said: \"You should bring me proof of that, or else!\" Then he came to a gathering of his people and asked them to swear by Allah concerning that, and they did so, so he let him go", "french": "", "indonesian": "", "russian": "", "urdu": "ابو سعید خدری رضی اللہ عنہ سے روایت ہے کہ  ابوموسیٰ اشعری رضی اللہ عنہ نے تین مرتبہ عمر رضی اللہ عنہ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 33, Hadith 50", "international_number": "3706", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3707", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ سُلَيْمَانَ،‏‏‏‏", "bengali": "", "english": "It was narrated that Abu Ayyub Ansari said:\"We said: 'O Messenger of Allah(ﷺ), (we know) this (greeting of) Salam, but what does seeking permission to enter mean?' He said: 'It means a man saying SubhanAllah, and Allahu Akbar and Al Hamdulillah, and clearing his throat, announcing his arrival to the people in the house", "french": "", "indonesian": "", "russian": "", "urdu": "ابوایوب انصاری رضی اللہ عنہ کہتے ہیں کہ  ہم نے عرض کیا: اللہ کے رسول! سلام تو ہمیں معلوم ہے، لیکن «ا", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 51", "international_number": "3707", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3708", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا أَبُو بَكْرِ بْنُ عَيَّاشٍ،‏‏‏‏ عَنْ مُغ", "bengali": "", "english": "It was narrated that Ali said:\"I had two times of visiting the Messenger of Allah(ﷺ), at night and during the day. If I came to him when he was praying, he would clear his throat (to let me know he was praying)", "french": "", "indonesian": "", "russian": "", "urdu": "علی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے پاس جانے کے لیے میرے دو وقت مقرر تھے:", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 52", "international_number": "3708", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3709", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ شُعْبَةَ،‏‏‏‏ عَنْ مُح", "bengali": "", "english": "It was narrated that Jabir said:\"I asked the Prophet(ﷺ) for permission to enter, and he said: 'Who is that?' I said: 'Me'. The Prophet(ﷺ) said \" Me, me?", "french": "", "indonesian": "", "russian": "", "urdu": "جابر رضی اللہ عنہ کہتے ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم سے  ( اندر آنے کی )  اجازت طلب کی", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 33, Hadith 53", "international_number": "3709", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3710", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا عِيسَى بْنُ يُونُسَ،‏‏‏‏ عَنْ عَبْدِ اللَّهِ بْنِ مُسْلِمٍ،‏", "bengali": "", "english": "It was narrated that Jabir said:\"I said: 'How are you this morning, O Messenger of Allah?' He said: 'I am better than one who did not get up fasting, and who did not visit and sick", "french": "", "indonesian": "", "russian": "", "urdu": "جابر رضی اللہ عنہ کہتے ہیں کہ  میں نے عرض کیا: اللہ کے رسول! آپ نے صبح کیسے کی؟ آپ صلی اللہ علیہ وسل", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 33, Hadith 54", "international_number": "3710", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3711", "arabic": "حَدَّثَنَا أَبُو إِسْحَاق الْهَرَوِيُّ إِبْرَاهِيمُ بْنُ عَبْدِ اللَّهِ بْنِ حَاتِمٍ،‏‏‏‏ حَدَّثَنَا", "bengali": "", "english": "It was narrated that Abu Usaid Sa'idi said:\"The Messenger of Allah(ﷺ) said to Abbas ibn Abdul Muttalib, when he entered upon them: \"Assalamu alaikum'. They said: 'Wa alaikas salamu wa ahmatullahi wa barakatuhu.' He said: 'How are you this morning?' They said: ' Well, praise is to Allah. And how are you this morning, may our fathers and mothers be ransomed for you, O Messenger of Allah?!' He said: 'I am well, praise is to Allah.'\"(Daif)", "french": "", "indonesian": "", "russian": "", "urdu": "ابواسید ساعدی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم جب عباس بن عبدالمطلب رضی اللہ ع", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 55", "international_number": "3711", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3712", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ،‏‏‏‏ أَنْبَأَنَا سَعِيدُ بْنُ مَسْلَمَةَ،‏‏‏‏ عَنْ ابْنِ عَجْل", "bengali": "", "english": "It was narrated from Ibn Umar that the Messenger of Allah(ﷺ) said:\"If there comes to you a man who is respected among his own people, then honor him", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تمہارے پاس کس", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 33, Hadith 56", "international_number": "3712", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3713", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ،‏‏‏‏ عَنْ سُلَيْمَ", "bengali": "", "english": "It was narrated that Anas bin Malik said:\"Two men sneezed in he presence of the Prophet(ﷺ) and he replied (said: YarhamukAllah; may Allah have mercy on you') to one and not to the other. It was said: 'O Messenger of Allah(ﷺ), two men sneezed in your presence and you replied to one and not to the other?' He said: \"'This one praised Allah(said Al-Hamdulillah fter sneezing) but that one did not", "french": "", "indonesian": "", "russian": "", "urdu": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کے سامنے دو آدمیوں نے چھینکا تو آ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 33, Hadith 57", "international_number": "3713", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3714", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ عِكْرِمَةَ بْنِ عَمَّارٍ،‏‏‏‏ عَ", "bengali": "", "english": "It was narrated from Ilyas bin Salamah bin Akwa' that his father said:\"The Messenger of Allah(ﷺ) said: 'The one who sneezes may be responded to three times; if he sneezes more than that, he has a cold", "french": "", "indonesian": "", "russian": "", "urdu": "سلمہ بن الاکوع رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  چھینکنے والے کو تی", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 58", "international_number": "3714", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3715", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ،‏‏‏‏ عَنْ ابْنِ أَ", "bengali": "", "english": "It was narrated from Ali that the Messenger of Allah(ﷺ) said:\"If anyone of you sneezes, let him say: Alhamdulillah (praise be to Allah). Those around him should respond by saying: Yarhamkullah (may Allah have mercy on you). And he should respond by saying: \"Yahdikum Allah wa yuslaha balakum (may Allah Guide you and set right your state)", "french": "", "indonesian": "", "russian": "", "urdu": "علی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں سے کسی کو چھینک آئ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 59", "international_number": "3715", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3716", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ أَبِي يَحْيَى الطَّوِيلِ رَجُلٌ", "bengali": "", "english": "It was narrated that Anas bin Malik said:\"Whenever the Prophet(ﷺ) met a man, he would speak to him, and would not tun away until he (the other man) was the one who turned away. And if he shook hands with him, he would not withdraw his hand until he (the other man) withdrew his hand. And he was never seen sitting with his knees ahead of the knees of the one who was sitting next to him", "french": "", "indonesian": "", "russian": "", "urdu": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کی جب کسی شخص سے ملاقات ہوتی اور آ", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 60", "international_number": "3716", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3717", "arabic": "حَدَّثَنَا عَمْرُو بْنُ رَافِعٍ،‏‏‏‏ حَدَّثَنَا جَرِيرٌ،‏‏‏‏ عَنْ سُهَيْلِ بْنِ أَبِي صَالِحٍ،‏‏‏‏ ع", "bengali": "", "english": "It was narrated from Abu Hurairah that the Prophet(ﷺ) said:\"When one of you gets up from his spot, then comes back, he has more right to it", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں سے کوئی شخص اپن", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 33, Hadith 61", "international_number": "3717", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3718", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ حَدَّثَنَا سُفْيَانُ،‏‏‏‏ عَنْ ابْنِ", "bengali": "", "english": "It was narrated from Jawdan that the Messenger of Allah(ﷺ) said:\"If a man makes an excuse to his bother and he does not accept it, he will bear a burden of sin like that of the tax-collector.\" A hadith similar to the above has been narrated through a chain differing from the first at the 4th level of narrators", "french": "", "indonesian": "", "russian": "", "urdu": "جوذان کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص اپنے بھائی سے معذرت کرے، اور پھر", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 62", "international_number": "3718", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3719", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ زَمْعَةَ بْنِ صَالِحٍ،‏‏‏‏ عَنْ الزُّهْرِي", "bengali": "", "english": "It was narrated that Umm Salamah said:\"Abu Bakr went out to trade in Busra, one year before the Prophet (ﷺ) died, and with him were Nu`aiman and Suwaibit the sons of Harmalah, who had been present at Badr. Nu`aiman was in charge of the provisions, and Suwaibit was a man who joked a lot. He said to Nu`aiman: 'Feed me'. He said: 'Not until Abu Bakr comes'. He said: 'Then I will have to annoy you'. Then they passed by some people, and Suwaibit said to them: 'Will you buy a slave from me?' They said: 'Yes'. He said 'He is a slave who talks a lot and he will tell you, \"I am a free man\". If you are going to let him go when he says that to you, do not bother buying him.' They said: 'We will buy him from you.' So they bought him from him in return for ten young she-camels, then they brought him and tied a turban or a rope around his neck. Nu`aiman said: 'This man is making fun of you. I am a free man, not a slave.' They said: 'He has already told us about you; and they took him off.' Then Abu Bakr came and he (Suwaibit) told him about that. So he followed those people and returned their camels to them, and took Nu`aiman back. When they came to the Prophet (ﷺ) they told him what had happened, and the Prophet (ﷺ) and his companions laughed about it for a year", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین ام سلمہ رضی اللہ عنہا کہتی ہیں کہ  ابوبکر رضی اللہ عنہ نبی اکرم صلی اللہ علیہ وسلم کی وف", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 63", "international_number": "3719", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3720", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ شُعْبَةَ،‏‏‏‏ عَنْ أَبِي التَّيّ", "bengali": "", "english": "It was narrated that Abu Taiyah said:\"I heard Anas Bin Malik say: The Messenger of Allah (ﷺ) used to mix with us so much that he said to a little brother of mine: \"O Abu `Umair, what happened to the Nughair (one of the narrators Waki` said that it means a bird that he used to play with)", "french": "", "indonesian": "", "russian": "", "urdu": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ہم لوگوں سے  ( یعنی بچوں سے )  می", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 33, Hadith 64", "international_number": "3720", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3721", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَبْدَةُ بْنُ سُلَيْمَانَ،‏‏‏‏ عَنْ مُحَ", "bengali": "", "english": "It was narrated from 'Amr bin Sh'uaib from his father, that his grandfather said:\"The Messenger of Allah(ﷺ) forbade plucking out white hairs and said: 'It is the light of the believer", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے سفید بال اکھیڑن", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 33, Hadith 65", "international_number": "3721", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3722", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا زَيْدُ بْنُ الْحُبَابِ،‏‏‏‏ عَنْ أَبِي ا", "bengali": "", "english": "It was narrated from Ibn Buraidah, from his father, that the Prophet(ﷺ) :\"forbade sitting between the shade and sun", "french": "", "indonesian": "", "russian": "", "urdu": "بریدہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے دھوپ اور سایہ کے درمیان میں بیٹھنے", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 33, Hadith 66", "international_number": "3722", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3723", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ،‏‏‏‏ حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ،‏‏‏‏ عَنْ الْأَوْزَاع", "bengali": "", "english": "It was narrated from Qais bin Tihfah Al-Ghifari that his father said:\"The Messenger of Allah(ﷺ) found me sleeping in the masjid on my stomach. He nudged me with his foot and said: 'Why are you sleeping like this? This is a kind of sleep that Allah dislikes,' or 'that Allah hates", "french": "", "indonesian": "", "russian": "", "urdu": "طخفہ غفاری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مجھے مسجد میں پیٹ کے بل  ( اوند", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 33, Hadith 67", "international_number": "3723", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3724", "arabic": "حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ،‏‏‏‏ حَدَّثَنَا إِسْمَاعِيل بْنُ عَبْدِ اللَّهِ،‏‏‏‏", "bengali": "", "english": "It was narrated that Abu Dharr said:\"The Prophet(ﷺ) passed by me and I was lying on my stomach. He nudged me with his foot and said: 'O Junaidib! This is how the people of Hell lie", "french": "", "indonesian": "", "russian": "", "urdu": "ابوذر رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم میرے پاس سے گزرے اس حال میں کہ میں پیٹ ک", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 33, Hadith 68", "international_number": "3724", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3725", "arabic": "حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ،‏‏‏‏ حَدَّثَنَا سَلَمَةُ بْنُ رَجَاءٍ،‏‏‏‏ عَنْ الْو", "bengali": "", "english": "It was narrated that Abu Umamah said:\"The Prophet(ﷺ) passed by a man who was sleeping in the masjid, lying on his face. He struck him with his foot and said: 'Get up' or; 'Sit up, fo this is a hellish kind of sleep", "french": "", "indonesian": "", "russian": "", "urdu": "ابوامامہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کا گزر ایک ایسے شخص کے پاس ہوا جو اون", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 33, Hadith 69", "international_number": "3725", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3726", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ،‏‏‏‏ عَنْ عُبَيْدِ اللَّهِ بْنِ الْأَخْ", "bengali": "", "english": "It was narrated from Ibn Abbas that the Messenger of Allah(ﷺ) said:\"Whoever learns about the stars, he learns a branch of magic; the more he learns (of the former) the more he learns (of the latter)", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے علم نجوم", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 33, Hadith 70", "international_number": "3726", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3727", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ،‏‏‏‏ عَنْ الْأَوْزَاعِيِّ،‏‏‏‏ عَنْ الز", "bengali": "", "english": "It was narrated from Abu Hurairah that the Messenger of Allah(ﷺ) said:\"Do not curse the wind, for it is from the mercy of Allah, bringing Rahmah (i.e., rain and breezes), or destruction. But ask Allah for its goodness, and seek refuge with Allah from its evil", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہعلیہ وسلم  نے فرمایا:  ہوا کو برا نہ کہو، کیونک", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 33, Hadith 71", "international_number": "3727", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3728", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ،‏‏‏‏ حَدَّثَنَا الْعُمَرِيُّ،‏‏‏‏ عَنْ", "bengali": "", "english": "It was narrated from Ibn 'Umar that the Prophet(ﷺ) said:\"The most beloved of names to Allah are 'Abdullah and 'Abdur-Rahman", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  اللہ تعالیٰ کے نز", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 33, Hadith 72", "international_number": "3728", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3729", "arabic": "حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ،‏‏‏‏ حَدَّثَنَا أَبُو أَحْمَدَ،‏‏‏‏ حَدَّثَنَا سُفْيَانُ،‏‏‏‏ عَنْ أَ", "bengali": "", "english": "It was narrated from 'Umar ibn Al-Khattab that the Prophet(ﷺ) said:\"If I live- if Allah wills - I will forbid the names Rabah(profit), Najih(saved), Aflah (Successful), Nafi (beneficial) and Yasar(prosperity)", "french": "", "indonesian": "", "russian": "", "urdu": "عمر بن خطاب رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اگر میں زندہ رہا تو ا", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 73", "international_number": "3729", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3730", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا الْمُعْتَمِرُ بْنُ سُلَيْمَانَ،‏‏‏‏ عَنْ الرُّكَيْنِ،‏‏‏‏ عَ", "bengali": "", "english": "It was narrated that Samurah said:\"The Messenger of Allah(ﷺ) forbade giving our slaves four names: Aflah (successful), Nafi' (beneficial), Rabah (profit) and Yasar(prosperity)", "french": "", "indonesian": "", "russian": "", "urdu": "سمرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ہمیں اپنے غلاموں کے چار نام رکھنے سے", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 33, Hadith 74", "international_number": "3730", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3731", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا هَاشِمُ بْنُ الْقَاسِمِ،‏‏‏‏ حَدَّثَنَا أَبُو عَقِيلٍ،‏‏‏‏ ح", "bengali": "", "english": "It was narrated that Masruq said:\"I met 'Umar bin Khattab and he said: 'Who are you?' I said: 'Masruq bin Adja'.' 'Umar said: 'I heard the Messenger of Allah(ﷺ) saying,\"Ajda' is a devil", "french": "", "indonesian": "", "russian": "", "urdu": "مسروق کہتے ہیں کہ  میری ملاقات عمر بن خطاب رضی اللہ عنہ سے ہوئی، تو انہوں نے پوچھا: تم کون ہو؟ میں ن", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 75", "international_number": "3731", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3732", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا غُنْدَرٌ،‏‏‏‏ عَنْ شُعْبَةَ،‏‏‏‏ عَنْ عَطَاءِ بْنِ أَبِي مَي", "bengali": "", "english": "It was narrated from Abu Hurairah that:\"Zainab used to be called \"Barrah\" (good), and it was said that she was praising herself. So the Messenger of Allah(ﷺ) changed her name to Zainab", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں  زینب کا نام بّرہ تھا   ( یعنی نیک بخت اور صالحہ )  لوگوں نے اعتراض ک", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 33, Hadith 76", "international_number": "3732", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3733", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا الْحَسَنُ بْنُ مُوسَى،‏‏‏‏ حَدَّثَنَا حَمَّادُ بْنُ سَلَمَةَ", "bengali": "", "english": "It was narrated from Ibn Umar that:\"a daughter of 'Umar was Asiyah(disobedient) then the Messenger of Allah(ﷺ) named her 'Jamilah' (beautiful)", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  عمر رضی اللہ عنہ کی ایک بیٹی کا نام  عاصیہ  تھا  ( یعنی گ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 33, Hadith 77", "international_number": "3733", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3734", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا يَحْيَى بْنُ يَعْلَى أَبُو الْمُحَيَّاةِ،‏‏‏‏ عَنْ عَبْدِ ال", "bengali": "", "english": "It was narrated that Abdullah bin Salam said:\"I came to the Messenger of Allah(ﷺ), and my name was not Abdullah bin Salam. The Messenger of Allah(ﷺ) named me Abdullah bin Salam", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن سلام رضی اللہ عنہ کہتے ہیں کہ  جب میں رسول اللہ صلی اللہ علیہ وسلم کی خدمت میں حاضر ہوا ت", "grades": "{'name': 'Al-Albani', 'grade': 'Munkar Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Munkar Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 78", "international_number": "3734", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3735", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ،‏‏‏‏ عَنْ أَيّ", "bengali": "", "english": "It was narrated from Muhammad that they heard Abu Hurairah say:\"Abul Qasim(ﷺ) said: 'Call yourselves by my name but do not call yourselves by my Kunyah", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  ابوالقاسم صلی اللہ علیہ وسلم نے فرمایا:  تم لوگ میرے نام پر نام ر", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 33, Hadith 79", "international_number": "3735", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3736", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا أَبُو مُعَاوِيَةَ،‏‏‏‏ عَنْ الْأَعْمَشِ،‏‏‏‏ عَنْ أَبِي سُفْ", "bengali": "", "english": "It was narrated from Jabir that the Messenger of Allah(ﷺ) said:\"Call yourselves by my name but do not call yourselves by my Kunyah", "french": "", "indonesian": "", "russian": "", "urdu": "جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم لوگ میرے نام پر نام رکھو،", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 33, Hadith 80", "international_number": "3736", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3737", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَبْدُ الْوَهَّابِ الثَّقَفِيُّ،‏‏‏‏ عَن", "bengali": "", "english": "It was narrated that Anas said:\"The Messenger of Allah(ﷺ) was in Baqi', and a man called out to another man: 'O Abul-Qasim!' The Messenger of Allah(ﷺ) turned to him, and he said: 'I didn't mean you.' The Messenger of Allah(ﷺ) said: 'Call yourselves by my name but do not call yourselves by my Kunyah", "french": "", "indonesian": "", "russian": "", "urdu": "انس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم مقبرہ بقیع میں تھے کہ ایک شخص نے دوسرے کو", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 33, Hadith 81", "international_number": "3737", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3738", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا يَحْيَى بْنُ أَبِي بُكَيْرٍ،‏‏‏‏ حَدَّثَ", "bengali": "", "english": "It was narrated from Hamzah bin Suhaib that Umar said to Suhaib:\"Why are you called Abu Yahya when you do not have a son?\" He said: \"The Messenger of Allah(ﷺ) gave me the Kunya of Abu Yahya", "french": "", "indonesian": "", "russian": "", "urdu": "حمزہ بن صہیب سے روایت ہے کہ  عمر رضی اللہ عنہ نے صہیب رضی اللہ عنہ سے کہا کہ تم اپنی کنیت ابویحییٰ ک", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 82", "international_number": "3738", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3739", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ هِشَامِ بْنِ عُرْوَةَ،‏‏‏‏ عَنْ مَوْلًى لِ", "bengali": "", "english": "It was narrated from Aisha that she said to the Prophet(ﷺ):\"All of your wives have a Kunyah except me.\" He said: \"You are Umm Abdullah", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  انہوں نے نبی اکرم صلی اللہ علیہ وسلم سے عرض کیا کہ آپ ن", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 33, Hadith 83", "international_number": "3739", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3740", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ شُعْبَةَ،‏‏‏‏ عَنْ أَب", "bengali": "", "english": "It was narrated that Anas said:\"The Prophet(ﷺ) used to come to us and say to a brother of mine, who was small: 'O Abu Umair", "french": "", "indonesian": "", "russian": "", "urdu": "انس رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم ہمارے پاس تشریف لائے، تو میرا ایک چھوٹا بھ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 33, Hadith 84", "international_number": "3740", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3741", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ إِدْرِيسَ،‏‏‏‏ عَنْ دَاوُدَ،‏‏‏‏ عَنْ ال", "bengali": "", "english": "It was narrated that Abu Jabirah bin Dahhak said:\"(Allah's saying) \"Nor insult one another by nicknames(Surah Al Hujarat 49:11)\" was revealed concerning us, the Ansar. When the Prophet(ﷺ) came to us, a man among us would have two or three names, and the Prophet(ﷺ) might call him by one of those names, only to be told: \"O Messenger of Allah(ﷺ), he does not like that name.\" Then:\"Nor insult one another by nicknames.\" was revealed", "french": "", "indonesian": "", "russian": "", "urdu": "ابوجبیرہ بن ضحاک رضی اللہ عنہ کہتے ہیں کہ  «ولا تنابزوا بالألقاب» ہم انصار کے بارے میں نازل ہوئی ہے،", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 33, Hadith 85", "international_number": "3741", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3742", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ،‏‏‏‏ عَنْ سُفْيَانَ،‏‏‏‏ ع", "bengali": "", "english": "It was narrated that Miqdad bin 'Amr said:\"The Messenger of Allah(ﷺ) commanded us to throw dust in the faces of those who praise others", "french": "", "indonesian": "", "russian": "", "urdu": "مقداد بن عمرو رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ہمیں تعریف کرنے والوں کے منہ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 33, Hadith 86", "international_number": "3742", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3743", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا غُنْدَرٌ،‏‏‏‏ عَنْ شُعْبَةَ،‏‏‏‏ عَنْ سَ", "bengali": "", "english": "It was narrated that Muawiyah said:\"I heard the Messenger of Allah(ﷺ) say: 'Beware of praising one another, for it is slaughtering (one another)", "french": "", "indonesian": "", "russian": "", "urdu": "معاویہ رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا:  تم آپس می", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 33, Hadith 87", "international_number": "3743", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3744", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا شَبَابَةُ،‏‏‏‏ حَدَّثَنَا شُعْبَةُ،‏‏‏‏ عَنْ خَالِدٍ الْحَذّ", "bengali": "", "english": "It was narrated from Abdur-Rahman bin Abu Bakrah that his father said:\"A man praised another man in the presence of Messenger of Allah(ﷺ). The Messenger of Allah(ﷺ) said: 'Woe to you,you have cut the neck of your companion,'several times. Then he said: 'If anyone of you praises his brother, let him say: \"I think he is lie this, but I do not sanctify anyone before Allah", "french": "", "indonesian": "", "russian": "", "urdu": "ابوبکرہ رضی اللہ عنہ کہتے ہیں کہ  ایک شخص نے رسول اللہ صلی اللہ علیہ وسلم کے سامنے ایک آدمی کی تعری", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 33, Hadith 88", "international_number": "3744", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3745", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا يَحْيَى بْنُ أَبِي بُكَيْرٍ،‏‏‏‏ عَنْ شَ", "bengali": "", "english": "It was narrated from Abu Hurairah that the Messenger of Allah(ﷺ) said:\"One who is consulted is entrusted", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس سے مشورہ لیا جائے وہ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 33, Hadith 89", "international_number": "3745", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3746", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا أَسْوَدُ بْنُ عَامِرٍ،‏‏‏‏ عَنْ شَرِيكٍ،", "bengali": "", "english": "It was narrated from Abu Mas'ud that the Messenger of Allah(ﷺ) said:\"One who is consulted is entrusted", "french": "", "indonesian": "", "russian": "", "urdu": "ابومسعود رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس سے مشورہ لیا جائے وہ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 33, Hadith 90", "international_number": "3746", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3747", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا يَحْيَى بْنُ زَكَرِيَّا بْنِ أَبِي زَائِدَةَ،‏‏‏‏ وَعَلِيُّ", "bengali": "", "english": "It was narrated from Jabir that that the Messenger of Allah(ﷺ) said:\"If one of you consults his brother, then let him advise him", "french": "", "indonesian": "", "russian": "", "urdu": "جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں سے کوئی شخص اپنے ب", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 91", "international_number": "3747", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3748", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا عَبْدَةُ بْنُ سُلَيْمَانَ . ح وحَدَّثَنَا عَلِيُّ بْنُ مُحَم", "bengali": "", "english": "It was narrated that Abdullah bin Amr said:\"The Messenger of Allah(ﷺ) said: 'You will conquer the lands of the non-Arabs, where you will find houses called Hammamat (bathhouses). Men Should only enter them wearing a waist wrap, and do not let women enter them unless they are sick or bleeding following childbirth", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تمہارے", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 92", "international_number": "3748", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3749", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ . ح وحَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَ", "bengali": "", "english": "It was narrated from Aisha that the Prophet(ﷺ):forbade men and women to enter bathhouses, then he allowed men to enter them wearing a waist wrap, but he did not make the same allowance for women", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے  ( پہلے )  مردوں اور", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 33, Hadith 93", "international_number": "3749", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3750", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ سُفْيَانَ،‏‏‏‏ عَنْ مَنْصُورٍ،‏‏", "bengali": "", "english": "It was narrated from Abu Malih AL-HUdhail that some women from the people of Hims asked permission to enter upon Aisha. She said:\"Perhaps you are among those (women) who enter bathhouses? I heard the Messenger of Allah(ﷺ) say: 'Any woman who takes off her clothes anywhere but in her husband's house, has torn the screen between her and Allah", "french": "", "indonesian": "", "russian": "", "urdu": "ابوملیح ہذلی سے روایت ہے کہ  حمص کی کچھ عورتوں نے ام المؤمنین عائشہ رضی اللہ عنہا سے ملاقات کی اجازت", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 33, Hadith 94", "international_number": "3750", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3751", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ عَبْدِ اللَّهِ،‏‏‏‏ حَدَّث", "bengali": "", "english": "It was narrated from Umm Salamah that when the Prophet(ﷺ) would apply (it):he began with his private area, coating it with hair removing chemical. And his wife would do the remainder of his body", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین ام سلمہ رضی اللہ عنہا سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم جب بال صاف کرنے کا پاو", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 95", "international_number": "3751", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3752", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنِي إِسْحَاق بْنُ مَنْصُورٍ،‏‏‏‏ عَنْ كَامِلٍ أَبِي ال", "bengali": "", "english": "It was narrated from Umm Salamah that:\"the Prophet(ﷺ) would coat (with hair removing chemical) and remove the pubic hairs with his hand", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین ام سلمہ رضی اللہ عنہا سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے اپنی شرمگاہ پر اپنے", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 96", "international_number": "3752", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3753", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ،‏‏‏‏ حَدَّثَنَا الْهِقْلُ بْنُ زِيَادٍ،‏‏‏‏ حَدَّثَنَا الْأَوْزَاعِ", "bengali": "", "english": "It was narrated from Amr bin Shuaib, from his father, from his grandfather, that the Messenger of Allah(ﷺ) said:\"No one tells the stories to the people (for the purpose of exhortation) except a ruler, one appointed by a ruler, or a show-off", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  لوگ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 33, Hadith 97", "international_number": "3753", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3754", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ الْعُمَرِيِّ،‏‏‏‏ عَنْ نَافِعٍ،‏", "bengali": "", "english": "It was narrated that Ibn Umar said:\"Stories (for the purpose of exhortation) were unknown at the time of the Messenger of Allah(ﷺ), the time of Abu Bakr and Umar", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں  یہ قصہ گوئی نہ رسول صلی اللہ علیہ وسلم کے زمانہ میں تھی، اور", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 33, Hadith 98", "international_number": "3754", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3755", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ،‏‏‏‏ عَنْ يُونُسَ،‏‏‏‏ عَنْ", "bengali": "", "english": "It was narrated from Ubbay bin Ka'b that the Messenger of Allah(ﷺ) said:\"In some poetry there is wisdom", "french": "", "indonesian": "", "russian": "", "urdu": "ابی بن کعب رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  بیشک کچھ شعر حکمت و دا", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Bukhari'}", "reference": "Book 33, Hadith 99", "international_number": "3755", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3756", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا أَبُو أُسَامَةَ،‏‏‏‏ عَنْ زَائِدَةَ،‏‏‏‏ عَنْ سِمَاكٍ،‏‏‏‏ ع", "bengali": "", "english": "It was narrated from Ibn Abbas that the Prophet(ﷺ) said:\"In some poetry there is wisdom", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم فرمایا کرتے تھے:  بعض اشعار", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 33, Hadith 100", "international_number": "3756", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3757", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ،‏‏‏‏ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ،‏‏‏‏ عَنْ عَبْدِ الْ", "bengali": "", "english": "It was narrated from Abu Hurairah that the Messenger of Allah(ﷺ) said:\"The truest of wods spoken by the poet are the words of Labid: Everything except Allah is false.' And Abu Umayyah bin Abu Salt nearly accepted Islam", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  سب سے زیادہ سچی بات جو ک", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 33, Hadith 101", "international_number": "3757", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3758", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عِيسَى بْنُ يُونُسَ،‏‏‏‏ عَنْ عَبْدِ الل", "bengali": "", "english": "It was narrated from Amr bin Sharid that his father said:\"I recited one hundered verses of the poetry of Umayyah bin Abu Salt to the Messenger of Allah(ﷺ), and after every line he said, \"More\". And he said: \"He nearly accepted Islam", "french": "", "indonesian": "", "russian": "", "urdu": "شرید ثقفی رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کے سامنے امیہ بن ابی صلت کے", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 33, Hadith 102", "international_number": "3758", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3759", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا حَفْصٌ،‏‏‏‏ وَأَبُو مُعَاوِيَةَ،‏‏‏‏ وَوَكِيعٌ،‏‏‏‏ عَنْ الْ", "bengali": "", "english": "It was narrated from Abu Hurairah that the Messenger of Allah(ﷺ) said:\"If a man were to fill his stomach completely with pus until it destroyed him, that would be better for him than filling (his mind) with poetry", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  بیماری کے سبب آدمی کے پ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 33, Hadith 103", "international_number": "3759", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3760", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ،‏‏‏‏ حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ،‏‏‏‏ وَمُحَمَّدُ بْنُ جَعْفَ", "bengali": "", "english": "It was narrated from Sad bin Abu Waqas that the Prophet(ﷺ) said:\"If a man were to fill his stomach completely with pus until it destroyed him, that would be better for him than filling (his mind) with poetry", "french": "", "indonesian": "", "russian": "", "urdu": "سعد بن ابی وقاص رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  تم میں سے کسی کے پ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 33, Hadith 104", "international_number": "3760", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3761", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عُبَيْدُ اللَّهِ،‏‏‏‏ عَنْ شَيْبَانَ،‏‏‏", "bengali": "", "english": "It was narrated from Aisha that the Messenger of Allah(ﷺ) said:\"The worst of all people lying is a man who trades insults with another man, disparaging the entire tribe, and a man who denies his father and accuses his mother of adultery", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  سب سے بڑا بہتا", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 105", "international_number": "3761", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3762", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ سُلَيْمَانَ،‏‏‏‏", "bengali": "", "english": "It was narrated that Abu Musa said:\"The Messenger of Allah(ﷺ) said: 'Whoever plays backgammon has disobeyed Allah and His Messenger", "french": "", "indonesian": "", "russian": "", "urdu": "ابوموسیٰ اشعری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے «نرد»  ( چوس", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 106", "international_number": "3762", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3763", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ،‏‏‏‏ وَأَبُو أُسَامَةَ،‏‏‏‏ عَن", "bengali": "", "english": "It was narrated from Sulaiman bin Buraidah from his father that the Prophet(ﷺ) said:\"Whoever plays backgammon, it is as if he dipped his hand in the flesh and blood of a pig", "french": "", "indonesian": "", "russian": "", "urdu": "بریدہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جس نے چوسر کھیلا گویا اس نے", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 33, Hadith 107", "international_number": "3763", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3764", "arabic": "حَدَّثَنَا عَبْدُ اللَّهِ بْنُ عَامِرِ بْنِ زُرَارَةَ،‏‏‏‏ حَدَّثَنَا شَرِيكٌ،‏‏‏‏ عَنْ مُحَمَّدِ بْ", "bengali": "", "english": "It was narrated from 'Aishah that the Prophet(ﷺ) looked at a man who was chasing a bird and said:\"A devil chasing a devil", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے ایک شخص کو دیکھا جو ا", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 33, Hadith 108", "international_number": "3764", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3765", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا الْأَسْوَدُ بْنُ عَامِرٍ،‏‏‏‏ عَنْ حَمَّادِ بْنِ سَلَمَةَ،‏‏", "bengali": "", "english": "It was narrated from Abu Hurairah that the Prophet(ﷺ) saw a man chasing a pigeon and said:\"A male devil following a female devil", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے ایک شخص کو کبوتر کے پیچھے لگا ہ", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 33, Hadith 109", "international_number": "3765", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3766", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ،‏‏‏‏ حَدَّثَنَا يَحْيَى بْنُ سُلَيْمٍ الطَّائِفِيُّ،‏‏‏‏ حَدَّثَنَا", "bengali": "", "english": "It was narrated from Uthman bin Affan that the Messenger of Allah(ﷺ) saw a man following a pigeon and said:\"A male devil chasing a female devil", "french": "", "indonesian": "", "russian": "", "urdu": "عثمان بن عفان رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک شخص کو کبوتر کے پیچھے", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 33, Hadith 110", "international_number": "3766", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3767", "arabic": "حَدَّثَنَا أَبُو نَصْرٍ مُحَمَّدُ بْنُ خَلَفٍ الْعَسْقَلَانِيُّ،‏‏‏‏ حَدَّثَنَا رَوَّادُ بْنُ الْجَر", "bengali": "", "english": "It was narrated that Anas bin Malik said:\"The Messenger of Allah(ﷺ) saw a man chasing a pigeon and said: 'A devil chasing a devil", "french": "", "indonesian": "", "russian": "", "urdu": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک شخص کو کبوتر کے پیچھے لگا", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 33, Hadith 111", "international_number": "3767", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3768", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ عَاصِمِ بْنِ مُحَمَّدٍ", "bengali": "", "english": "It was narrated from Ibn 'Umar that the Messenger of Allah(ﷺ) said:\"If anyone of you knew what is wrong with being alone, no one would travel at night by himself", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اگر تم میں سے کس", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Bukhari'}", "reference": "Book 33, Hadith 112", "international_number": "3768", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3769", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ،‏‏‏‏ عَنْ الزُّهْرِيِّ،‏‏‏‏ عَنْ س", "bengali": "", "english": "It was narrated from Salim, from his father, that the Prophet(ﷺ) said:\"Do not leave fire in your houses when you go to sleep", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جب تم سونے لگو تو", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 33, Hadith 113", "international_number": "3769", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3770", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا أَبُو أُسَامَةَ،‏‏‏‏ عَنْ بُرَيْدِ بْنِ", "bengali": "", "english": "It was narrated that Abu Musa said:\"A house burned down in Al-Madinah, with its occupants inside. The Prophet(ﷺ) was told of what had happened, and he said: 'This fire is an enemy to you. When you go to sleep, extinguish it", "french": "", "indonesian": "", "russian": "", "urdu": "ابوموسیٰ اشعری رضی اللہ عنہ کہتے ہیں کہ  مدینہ کا ایک گھر لوگوں سمیت جل گیا جب نبی اکرم صلی اللہ علی", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 33, Hadith 114", "international_number": "3770", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3771", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ،‏‏‏‏ عَنْ ع", "bengali": "", "english": "It was narrated that Jabir said:\"The Messenger of Allah(ﷺ) commanded us (to do some things) and forbade us (to do some things), and he commanded us to extinguish our lamps", "french": "", "indonesian": "", "russian": "", "urdu": "جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ہمیں بہت سی باتوں کا حکم دیا، اور بہت", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 33, Hadith 115", "international_number": "3771", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3772", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ،‏‏‏‏ أَنْبَأَنَا ه", "bengali": "", "english": "It was narrated from Jabir that the Messenger of Allah(ﷺ) said:\"Do not camp on the middle of the road, or relieve yourselves there", "french": "", "indonesian": "", "russian": "", "urdu": "جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم نہ راستہ کے درمیان قیام ک", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 116", "international_number": "3772", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3773", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ سُلَيْمَانَ،‏‏‏‏", "bengali": "", "english": "Abdullah bin Ja'far said:\"Whenever the Messenger of Allah(ﷺ) came back from a journey, he would be met by us(children). (One day) he was met by me and Hasan or Husain. He made one of us ride in front of him and the other behind him, until we came to Al-Madinah", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن جعفر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم جب سفر سے تشریف لاتے تو ہم", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 33, Hadith 117", "international_number": "3773", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3774", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ،‏‏‏‏ أَنْبَأَنَا ب", "bengali": "", "english": "It was narrated from Jabir that the Messenger of Allah(ﷺ) said:\"Put dust on your writings, because it is better, and dust is blessed (being humble in correspondence brings good results)", "french": "", "indonesian": "", "russian": "", "urdu": "جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم خط لکھنے کے بعد اس پر مٹی", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Very Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 118", "international_number": "3774", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3775", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ،‏‏‏‏ حَدَّثَنَا أَبُو مُعَاوِيَةَ،‏‏‏‏ وَوَكِ", "bengali": "", "english": "It was narrated from Abdullah that the Messenger of Allah(ﷺ) said:\"When you are three, two should not converse (privately) to the exclusion of their companion, because that makes him sad", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم تین آدمی", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 33, Hadith 119", "international_number": "3775", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3776", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ،‏‏‏‏ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ،‏‏‏‏ عَنْ عَبْدِ اللَّهِ", "bengali": "", "english": "It was narrated that Ibn 'Umar said:\"The Messenger of Allah(ﷺ) forbade two to converse (privately) to the exclusion of a third", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے اس بات سے منع فرمایا کہ ا", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 33, Hadith 120", "international_number": "3776", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3777", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ،‏‏‏‏ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ،‏‏‏‏ قَالَ:‏‏‏‏ قُلْتُ لِ", "bengali": "", "english": "Jabir bin 'Abdullah said:\"A man passed through the masjid with some arrows, and the Messenger of Allah(ﷺ) said: 'Hold them by their heads!' He said: 'Yes(ok)", "french": "", "indonesian": "", "russian": "", "urdu": "سفیان بن عیینہ کہتے ہیں کہ  میں نے عمرو بن دینار سے کہا: کیا آپ نے جابر بن عبداللہ رضی اللہ عنہما کو", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 33, Hadith 121", "international_number": "3777", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3778", "arabic": "حَدَّثَنَا مَحْمُودُ بْنُ غَيْلَانَ،‏‏‏‏ حَدَّثَنَا أَبُو أُسَامَةَ،‏‏‏‏ عَنْ بُرَيْدٍ،‏‏‏‏ عَنْ جَد", "bengali": "", "english": "It was narrated from Abu Musa that the Prophet(ﷺ) said:\"When anyone of you passes through our masjid or our marketplace carrying arrows, let him hold them by their heads, lest he hurt any Muslims", "french": "", "indonesian": "", "russian": "", "urdu": "ابوموسیٰ اشعری رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں سے کوئی ش", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 33, Hadith 122", "international_number": "3778", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3779", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ،‏‏‏‏ حَدَّثَنَا عِيسَى بْنُ يُونُسَ،‏‏‏‏ حَدَّثَنَا سَعِيدُ بْنُ أَ", "bengali": "", "english": "It was narrated from Aisha that the Messenger of Allah (ﷺ) said:\"The one who is proficient with the Qur'an will be with the noble and righteous scribes (the angels), and the one who reads it and stumbles over it, finding it difficult, will have two rewards", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص قرآن ک", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 33, Hadith 123", "international_number": "3779", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3780", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ مُوسَى،‏‏‏‏ أَنْبَأَنَا شَيْبَانُ،‏‏‏‏", "bengali": "", "english": "It was narrated from Abu Sa`eed Al-Khudri that the Messenger of Allah (ﷺ) said:\"It will be said to the companion of the Qur'an, when he enters Paradise: 'Recite and rise one degree for every Verse,' until he recites the last thing that he knows", "french": "", "indonesian": "", "russian": "", "urdu": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  قرآن والے  ( قرآن", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 33, Hadith 124", "international_number": "3780", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3781", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ بَشِيرِ بْنِ مُهَاجِرٍ،‏‏‏‏ عَنْ", "bengali": "", "english": "It was narrated from Ibn Buraidah that his father told that the Messenger of Allah(ﷺ) said:\"The Quran will come on the Day of Resurrection, like a pale man, and will say: 'I am the one that kept you awake at night and made you thirsty during the day", "french": "", "indonesian": "", "russian": "", "urdu": "بریدہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  قیامت کے دن قرآن ایک تھکے", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 33, Hadith 125", "international_number": "3781", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3782", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ قَالَا:‏‏‏‏ حَدَّثَنَ", "bengali": "", "english": "It was narrated from Abu Hurairah that the Messenger of Allah(ﷺ) said:\"Wouldn't anyone of you like to find three great, fat pregnant she-camels when he returns to his family?\" We said: \"Yes.\" He said: \"Three verses that one of you recites during the praer are better for him than three great, fat pregnant she-camels", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  کیا تم میں سے کوئی اس با", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 33, Hadith 126", "international_number": "3782", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3783", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ الْأَزْهَرِ،‏‏‏‏ حَدَّثَنَا عَبْدُ الرَّزَّاقِ،‏‏‏‏ أَنْبَأَنَا مَعْمَرٌ،‏‏", "bengali": "", "english": "It was narrated from Ibn Umar that the Messenger of Allah(ﷺ) said:\"The likeness of the Quran is that of a hobbled camel. If its owner ties its rope, he will keep it, but if he loosens its rope it will go away", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  قرآن کی مثال بن", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 33, Hadith 127", "international_number": "3783", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3784", "arabic": "حَدَّثَنَا أَبُو مَرْوَانَ مُحَمَّدُ بْنُ عُثْمَانَ الْعُثْمَانِيُّ،‏‏‏‏ حَدَّثَنَا عَبْدُ الْعَزِيز", "bengali": "", "english": "It was narrated that Abu Hurairah said, 'I heard the Messenger of Allah(ﷺ) say':\"Allah said: 'I have divided the prayer between Myself and My slave into two halves, and My slave shall have what he has asked for.'When the slave says: 'Al-hamdulillah i rabbil Alameen (All the praise is to Allah, the Lord of all that exists),' Allah says:'My slave has praised Me, and My slave shall have what he has asked for.' And when he says: 'Ar-Rahmanir-Rahim (The Mos Gracious, the Most Merciful),' Allah says: 'My slave has extolled Me, and My slave shall have what he has asked for.' And when he says: 'Maliki yawmiddin [The Only Owner (and he Ruling Judge] if the Day of Recompense],' Allahs says: 'My slave has Glorified Me. This is for Me, and this Verse is between me and My slave in two halves.' And when he says: ' Iyyaka na'budu wa iyyaka nastain [You (Alone) we worship, and You (Alone) we ask for help],' He says: 'This is between Me an My slave, and My slave shall have what he has asked for.' And the end of the Surah is for My slave.' And when he says: 'Ihdinas-siratal-mustaqeema, siratal-alldhina an'amta alayhim a lad-dallin [Guide us to the Straight Way, the way of those on whom You have bestowed Your Grace, not(the way) of those who earned Your Anger, nor of those who went astray],' He says: 'THis is for My slave, and My slave shall have what he has asked for", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا کہ  اللہ ت", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 33, Hadith 128", "international_number": "3784", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3785", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا غُنْدَرٌ،‏‏‏‏ عَنْ شُعْبَةَ،‏‏‏‏ عَنْ خُ", "bengali": "", "english": "It was narrated that Abu Sa'eed bin Mu'alla said:\"The Messenger of Allah(ﷺ) said to me: 'Shall I not teach you the greatest Surah in the QUran before I leave the masjid?' Then the Propeht(ﷺ) went to leave, so I reminded him, and he said: Al-hamdulillahi Rabbil-Alameen (All the praise is to Allah, the Lord of all that exists). It is the Seven Oft-Recited Verses, and it is the Grand Quran that has been given to me", "french": "", "indonesian": "", "russian": "", "urdu": "ابوسعید بن معلّیٰ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مجھ سے فرمایا:  کیا میں", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Bukhari'}", "reference": "Book 33, Hadith 129", "international_number": "3785", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3786", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا أَبُو أُسَامَةَ،‏‏‏‏ عَنْ شُعْبَةَ،‏‏‏‏", "bengali": "", "english": "It was narrated from Abu Hurairah that the Prophet (ﷺ) said:\"There is a surah in the Qur'an, with thirty verses, which will intercede for its companion (the one who recites it) until he is forgiven: Tabarakal-ladhi bi yadihil mulk (Blessed is He in Whose Hand is the Dominion)", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  قرآن میں ایک سورت ہے جس", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 33, Hadith 130", "international_number": "3786", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3787", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ،‏‏‏‏ حَدَّثَنَا سُلَيْمَانُ بْنُ بِلَا", "bengali": "", "english": "It was narrated that Abu Hurairah said that the Messenger of Allah(ﷺ) said:\"Qul Huwa Allahu ahad [Say: He is Allah, (the) One] is equivalent to one third of the Quran", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول صلی اللہ علیہ وسلم نے فرمایا:   «قل هو الله أحد»  ( یعنی سور", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 33, Hadith 131", "international_number": "3787", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3788", "arabic": "حَدَّثَنَا الْحَسَنُ بْنُ عَلِيٍّ الْخَلَّالُ،‏‏‏‏ حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ،‏‏‏‏ عَنْ جَرِير", "bengali": "", "english": "It was narrated that Anas bin Malik said:\"The Messenger of Allah(ﷺ) said: Qul Huwa Allahu ahad [Say: He is Allah, (the) One] is equivalent to one third of the Quran", "french": "", "indonesian": "", "russian": "", "urdu": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:   «قل هو الله أحد»  (", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 33, Hadith 132", "international_number": "3788", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3789", "arabic": "حدثنا علي بن محمد حدثنا وكيع عن سفيان عن أبي قيس الأودي عن عمرو بن ميمون عن أبي مسعود الأنصاري قال:", "bengali": "", "english": "It was narrated that Abu Masud Al Ansari said:\"The Messenger of Allah(ﷺ) said: \"Allahu ahad, Al-Wahidus-Samad [Allah (the) One, the One the Self-Sufficient Master] is equivalent to one third of the Quran", "french": "", "indonesian": "", "russian": "", "urdu": "ابومسعود انصاری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:   «الله أحد الواحد", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 33, Hadith 133", "international_number": "3789", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3790", "arabic": "حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ،‏‏‏‏ حَدَّثَنَا الْمُغِيرَةُ بْنُ عَبْدِ الرَّحْمَنِ", "bengali": "", "english": "It was narrated from Abu Darda that the Prophet(ﷺ) said:\"Shall I not tell you of the best of your deeds, the most pleasing to your Sovereign, those that raise you most in status, that are better than your gold and silver, or meeting you enemy (in battle) and you strike their necks and they strike your necks?\" They said: \" WHat is that, O Messenger of Allah?\" He said: \"Remembering Allah(Dhikr)", "french": "", "indonesian": "", "russian": "", "urdu": "ابوالدرداء رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  کیا میں تمہیں وہ عمل نہ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 134", "international_number": "3790", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3791", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا يَحْيَى بْنُ آدَمَ،‏‏‏‏ عَنْ عَمَّارِ بْ", "bengali": "", "english": "It was narrated that Abu Hurairah and Abu Sa'eed bore witness that the Prophet(ﷺ) said:\"No people sit in a gathering remembering Allah, But the angels surround them, mercy covers them, tranquility descends upon them and Allah remembers them before those who are with Him", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ اور ابوسعید رضی اللہ عنہما سے روایت ہے کہ وہ دونوں گواہی دیتے ہیں کہ  نبی اکرم صلی اللہ علی", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 33, Hadith 135", "international_number": "3791", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3792", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا مُحَمَّدُ بْنُ مُصْعَبٍ،‏‏‏‏ عَنْ الْأَوْزَاعِيِّ،‏‏‏‏ عَنْ", "bengali": "", "english": "It was narrated from Abu Hurairah that the Prophet(ﷺ) said:\"Allah says: 'I am with My slave when he remembers Me and his lips move saying My Name", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  اللہ تعالیٰ ارشاد فرماتا", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 33, Hadith 136", "international_number": "3792", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3793", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا زَيْدُ بْنُ الْحُبَابِ،‏‏‏‏ أَخْبَرَنِي مُعَاوِيَةُ بْنُ صَا", "bengali": "", "english": "It was narrated from Abdullah bin Busr that a Bedouin said to the Messenger of Allah(ﷺ) said:\"The laws of Islam are burdensome for me. Tell me of something that I will be able to adhere to. He said: 'Always keep your tongue moist with the remembrance of Allah, the Mighty and Sublime", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن بسر رضی اللہ عنہ کہتے ہیں کہ  ایک اعرابی نے رسول اللہ صلی اللہ علیہ وسلم سے عرض کیا کہ اس", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 33, Hadith 137", "international_number": "3793", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3794", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا الْحُسَيْنُ بْنُ عَلِيٍّ،‏‏‏‏ عَنْ حَمْزَةَ الزَّيَّاتِ،‏‏‏‏", "bengali": "", "english": "It was narrated from Abu Hurairah and Abu Saeed bore witness that the Messenger of Allah(ﷺ) said:\"If a person says: 'La ilaha illallahu wa Allahu Akbar (None has the right to be worshipped but Allah and Allah is the Most Great),'Allah says: 'My slave has spoken the truth; there is none worthy of worship except I, and I am the Most Great.' If a person says: La ilaha Illallah wahdahu (There is none worthy of worship except Allah alone), Allah says: 'My slave has spoken the truth; there is none worthy of worship except I, alone.' If he says, La ilaha illallahu la sharikalahu (There is none worthy of worship except Allah with no partner or associate),' Allah says: 'My slave has spoken the truth; there is none worthy of worship except I, with no partner or associate.' If he says: 'La illah illallah, lahul mulku wa lahul hamdu (There is none worthy of worship except Allah, all dominion is His and all praise is to Him),' Allah says: 'My slave has spoken the truth; there is none of worthy of worship except I, all dominion Mine and all praise is due to Me.' If he says: ' La illaha illallah, la hawla wa la quwwata illa billah (There is none worthy of worship and there is no power and no strength except with Allah),' Allah says: 'My slave has spoken then truth; there is none worthy of worship except I, and tehre is no power and no strength except with Me.' One of the narrators Abu Ishaq said: \"Then Agharr (another narrator) said something that I did not understand. I said to Abu Jafar: 'What did he say?' He said: 'Whoever is blessed with (the ability to say) them (these words) at the time of death, the Fire will not touch him", "french": "", "indonesian": "", "russian": "", "urdu": "اغر ابومسلم سے روایت ہے اور انہوں نے شہادت دی کہ ابوہریرہ اور ابوسعید رضی اللہ عنہما دونوں نے گواہی", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 138", "international_number": "3794", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3795", "arabic": "حَدَّثَنَا هَارُونُ بْنُ إِسْحَاق الْهَمْدَانِيُّ،‏‏‏‏ حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الْوَهَّابِ،", "bengali": "", "english": "It was narrated from Yahya bin Talha that :his mother Su'da Al-Murriyyah said: \"Umar bin Khattab passed by Talhah, after the Messenger of Allah(ﷺ) had died, and said: 'Why do you look so sad? Are you upset because your cousin has been appointed leader?' He said: 'No, but I heard the Messenger of Allah(ﷺ) say: \"I know a word which no one says at the time of death but it will be light in his record of deeds, and his body and soul will find comfort in it at the time of death,\" -but I did not ask him about it before he died.' He ('Umar) said: ' I know what it is. It is what he wanted his uncle (Abu Talib) to say, and if he had known anything that would be more effective in saving him, he would have told him to say it", "french": "", "indonesian": "", "russian": "", "urdu": "سعدیٰ مریہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کی وفات کے بعد عمر رضی اللہ عنہ ط", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 33, Hadith 139", "international_number": "3795", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3796", "arabic": "حَدَّثَنَا عَبْدُ الْحَمِيدِ بْنُ بَيَانٍ الْوَاسِطِيُّ،‏‏‏‏ حَدَّثَنَا خَالِدُ بْنُ عَبْدِ اللَّهِ،", "bengali": "", "english": "It was narrated from Mu'adh bin Jabal that the :Messenger of Allah(ﷺ) said: \"There is no soul that died bearing witness to La ilaha illallah, and that I am the Messenger of Allah, from the heart with certainity, but Allah will forgive it", "french": "", "indonesian": "", "russian": "", "urdu": "معاذ بن جبل رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس شخص کی موت اس گواہ", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 33, Hadith 140", "international_number": "3796", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3797", "arabic": "حَدَّثَنَا إِبْرَاهِيمُ بْنُ الْمُنْذِرِ الْحِزَامِيُّ،‏‏‏‏ حَدَّثَنَا زَكَرِيَّا بْنُ مَنْظُورٍ،‏‏‏", "bengali": "", "english": "It was narrated that Umm Hani' said:\"The Messenger of Allah(ﷺ) said: (About saying) La ilaha illah - no deed takes precedence over it and it does not leave any sin", "french": "", "indonesian": "", "russian": "", "urdu": "ام ہانی رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:   «لا إله إلا الله» سے بڑ", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 141", "international_number": "3797", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3798", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا زَيْدُ بْنُ الْحُبَابِ،‏‏‏‏ عَنْ مَالِكِ بْنِ أَنَسٍ،‏‏‏‏ أَ", "bengali": "", "english": "It was narrated from Abu Hurairah that :the Messenger of Allah(ﷺ) said: \"Whoever says one hundered times each day: La ilaha illahu wahdahu la sharikalahu, wa lahul-mulku wa lahul hamduwa huwa ala kulli shayin qadeer (None has the right to be worshipped but Allah alone, with no partner or associate. His is the dominion, all praise is to Him, and He is able to do all things), it will be equivalent to him freeing ten slaves, and one hundered merits will be recorded for him, and one hundered bad deeds will be erased from (his record), and it will be a protection for him against Satan all day until night comes. No one can do anything better then him except one who says more", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے ایک دن میں سو بار", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 33, Hadith 142", "international_number": "3798", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3799", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا بَكْرُ بْنُ عَبْدِ الرَّحْمَنِ،‏‏‏‏ حَدّ", "bengali": "", "english": "It was narrated from Abu Saeed that :the Prophet(ﷺ) said: \"Whoever says, following the morning prayer: La ilaha illallahu wahdahu la sahrikalau, lahul mulku wa lahul hamdu, bi yadihil khair, wa huwa ala kulli shay'in qadir (None has the right to be worshipped but Allah alone, with no partner or associate. His is the dominion, all praise is to Him, in His Hand is all goodness, and He is Able to do all things), it will be as if he freed slave from among the sons of Isma'il", "french": "", "indonesian": "", "russian": "", "urdu": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جو شخص نماز صبح  ( ف", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 143", "international_number": "3799", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3800", "arabic": "حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ الدِّمَشْقِيُّ،‏‏‏‏ حَدَّثَنَا مُوسَى بْنُ إِبْرَاهِ", "bengali": "", "english": "Jabir bin 'Abdullah said:\"I heard the Messenger of Allah (ﷺ) say: 'The best of remembrance is La ilaha illallah (None has the right to be worshipped but Allah), and the best of supplication is Al-Hamdu Lillah (praise is to Allah)", "french": "", "indonesian": "", "russian": "", "urdu": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا:", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 33, Hadith 144", "international_number": "3800", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3801", "arabic": "حَدَّثَنَا إِبْرَاهِيمُ بْنُ الْمُنْذِرِ الْحِزَامِيُّ،‏‏‏‏ حَدَّثَنَا صَدَقَةُ بْنُ بَشِيرٍ مَوْلَى", "bengali": "", "english": "It was narrated from 'Abdullah bin 'Umar that :the Messenger of Allah (ﷺ) told them: \"One of the slaves of Allah said: 'Ya Rabb! Lakal-hamdu kama yanbagi li-jalali Wajhika wa li 'azima sultanika (O Lord, to You is praise as befits the Glory of Your Face and the greatness of Your Might.)' The angels were uncertain and did not know how to write this down, so they ascended to heaven and said: 'O our Lord, Your slave has said a word that we do not know how to write down.' Allah said - and He knows best what His slave said - 'What did My slave say?' They said: 'O Lord, he said \"Ya Rabb! Lakal-hamdu kama yanbagi li-jalali Wajhika wa li'azima sultanika (O Lord, to You is praise as befits the Glory of Your Face and the greatness of your Might).'\" Allah said to them: 'Write it down as My slave said it, until he meets Me and I shall reward him for it", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ان سے بیان کیا کہ اللہ کے", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 33, Hadith 145", "international_number": "3801", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3802", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا يَحْيَى بْنُ آدَمَ،‏‏‏‏ حَدَّثَنَا إِسْرَائِيلُ،‏‏", "bengali": "", "english": "It was narrated from 'Abdul-Jabbar bin Wa'il that :his father said: \"I prayed with the Prophet (ﷺ) and a man said: 'Alhamdu lillahi hamdan kathiran tayyiban mubarakan fihi (Praise is to Allah, much, good and blessed praise).' When the Prophet (ﷺ) finished praying, he said: 'Who said that?' The man said: 'It was me, but I did not mean anything but good.' He said: 'The gates of heaven were opened because of it and nothing prevented it from reaching the Throne", "french": "", "indonesian": "", "russian": "", "urdu": "وائل رضی اللہ عنہ کہتے ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم کے ساتھ نماز پڑھی، ایک شخص نے  ( «", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 146", "international_number": "3802", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3803", "arabic": "حَدَّثَنَا هِشَامُ بْنُ خَالِدٍ الْأَزْرَقُ أَبُو مَرْوَانَ،‏‏‏‏ حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ", "bengali": "", "english": "It was narrated that 'Aishah said:\"When the Messenger of Allah (ﷺ) saw something he liked, he would say: 'Al-hamdu lillahil-ladhi bi ni'matihi tatimmus-salihat (Praise is to Allah by Whose grace good deeds are completed).' And if he saw something that he disliked, he would say: 'Al-hamdu lillahi 'ala kulli hal (Praise is to Allah in all circumstances)", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم جب کوئی اچھی بات دیکھتے تو", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 147", "international_number": "3803", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3804", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ مُوسَى بْنِ عُبَيْدَةَ،‏‏‏‏ عَنْ", "bengali": "", "english": "It was narratd from Abu Hurairah that :the Prophet (ﷺ) used to say: \"Al-hamdu lillahi 'ala kulli hal. Rabbi a'udhu bika min hali ahlin-nar (Praise is to Allah in all circumstances, O Allah, I seek refuge with You from the situation of the people of Hell)", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم فرمایا کرتے:   «الحمد لله على كل حال", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 148", "international_number": "3804", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3805", "arabic": "حَدَّثَنَا الْحَسَنُ بْنُ عَلِيٍّ الْخَلَّالُ،‏‏‏‏ حَدَّثَنَا أَبُو عَاصِمٍ،‏‏‏‏ عَنْ شَبِيبِ بْنِ ب", "bengali": "", "english": "It was narrated from Anas that :the Messenger of Allah (ﷺ) said: 'Allah does not bestow a blessing upon any slave and he says: 'Al-hamdu Lillah (praise is to Allah),' except that what he gives (the praise) is better than what he received (the blessing)", "french": "", "indonesian": "", "russian": "", "urdu": "انس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب اللہ تعالیٰ اپنے بندے پر ک", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 149", "international_number": "3805", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3806", "arabic": "حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ قَالَا:‏‏‏‏ حَدَّثَنَا مُحَمَّدُ بْنُ فُض", "bengali": "", "english": "It was narrated from Abu Hurairah that :the Messenger of Allah (ﷺ) said: 'Two words which are light on the tongue and heavy in the Balance, and beloved to the Most Merciful: Subhan-Allah wa bi hamdihi, Subhan-Allahil-'Azim (Glory and praise is to Allah, glory is to Allah the Almighty)", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  دو کلمے زبان پر بہت ہلکے", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 33, Hadith 150", "international_number": "3806", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3807", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَفَّانُ،‏‏‏‏ حَدَّثَنَا حَمَّادُ بْنُ س", "bengali": "", "english": "It was narrated from Abu Hurairah that :the Messenger of Allah (ﷺ) passed by him when he was planting a plant, and said: \"O Abu Hurairah, what are you planting?\" I said: \"A plant for me.\" He said: \"Shall I not tell you of a plant that is better than this?\" He said: \"Of course, O Messenger of Allah.\" He said: \"Say: 'Subhan-Allah, wal-hamdu-lillah, wa la ilaha illallah, wa Allahu Akbar (Glory is to Allah, praise is to Allah, none has the right to be worshiped but Allah and Allah is the Most Great.)' For each one a tree will be planted for you in Paradise", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  وہ ایک دن درخت لگا رہے تھے کہ رسول اللہ صلی اللہ علیہ وسلم ان", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 151", "international_number": "3807", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3808", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ،‏‏‏‏ حَدَّثَنَا مِ", "bengali": "", "english": "It was narrated that Juwairiyah said:\"The Messenger of Allah (ﷺ) passed by her when he prayed the morning prayer, or after he prayed the morning prayer, and she was remembering Allah. He came back when the sun had risen\" - or he (one of the narrators) said, \"at midday - and she was still doing that. He said: 'I have said four words, three times, since I left you, and they are greater and weigh more heavily than what you have said. They are: Subhan-Allahi 'adada khalqiha, Subhan-Allahi rida nafsihi, Subhan-Allahi zinata 'arshihi, Subhan-Allah midada kalimatihi (Glory is to Allah, as much as the number of His creation, glory is to Allah as much as pleases Him, glory is to Allah as much as the weight of His Throne, glory is to Allah as much as the ink of His words)", "french": "", "indonesian": "", "russian": "", "urdu": "جویریہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم صبح  ( فجر )  کے وقت یا صبح کے بعد ان", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 33, Hadith 152", "international_number": "3808", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3809", "arabic": "حَدَّثَنَا أَبُو بِشْرٍ بَكْرُ بْنُ خَلَفٍ،‏‏‏‏ حَدَّثَنِي يَحْيَى بْنُ سَعِيدٍ،‏‏‏‏ عَنْ مُوسَى بْن", "bengali": "", "english": "It was narrated from Nu'man bin Bashir that :the Messenger of Allah (ﷺ) said: \"What you mention of glory of Allah, of Tabsih (Subhan-Allah), Tahlil (Allahu-Akbar) and Tahmid (Al-Hamdu lillah), revolves around the Throne, buzzing like bees, reminding of the one who said it. Wouldn't any one of you like to have, or continue to have, something that reminds of him (in the presence of Allah)?", "french": "", "indonesian": "", "russian": "", "urdu": "نعمان بن بشیر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ تعالیٰ کا جل", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 33, Hadith 153", "international_number": "3809", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3810", "arabic": "حَدَّثَنَا إِبْرَاهِيمُ بْنُ الْمُنْذِرِ الْحِزَامِيُّ،‏‏‏‏ حَدَّثَنَا أَبُو يَحْيَى زَكَرِيَّا بْنُ", "bengali": "", "english": "It was narrated that Umm Hani' said:\"I came to the Messenger of Allah (ﷺ) and said: 'O Messenger of Allah, tell me of a (good) deed, for I have become old and weak and overweight.' He said: 'Proclaim the greatness of Allah (say Allahu Akbar) one hundred times, praise Allah (say Al-Hamdu Lillah) one hundred times, and glorify Allah (say Subhan-Allah) one hundred times. (That is) better than one hundred horses bridled and saddled for the sake of Allah, better than one hundred sacrificial camels, and better than (freeing) one hundred slaves", "french": "", "indonesian": "", "russian": "", "urdu": "ام ہانی رضی اللہ عنہا کہتی ہیں کہ  میں رسول اللہ صلی اللہ علیہ وسلم کی خدمت میں حاضر ہوئی، اور میں ن", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 154", "international_number": "3810", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3811", "arabic": "حَدَّثَنَا أَبُو عُمَرَ حَفْصُ بْنُ عَمْرٍو،‏‏‏‏ حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ،‏‏‏‏ ح", "bengali": "", "english": "It was narrated from Samurah bin Jundab that :the Prophet (ﷺ) said: \"(There are) four that are the best of words, and it does not matter with which you begin: Subhan-Allah, wal-Hamdu-Lillah, wa la ilaha illallah, wa Allahu Akbar (Glory is to Allah, praise is to Allah, none has the right to be worshiped but Allah and Allah is the Most Great)", "french": "", "indonesian": "", "russian": "", "urdu": "سمرہ بن جندب رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  چار کلمے تمام کلمات س", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 33, Hadith 155", "international_number": "3811", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3812", "arabic": "حَدَّثَنَا نَصْرُ بْنُ عَبْدِ الرَّحْمَنِ الْوَشَّاءُ،‏‏‏‏ حَدَّثَنَا عَبْدُ الرَّحْمَنِ الْمُحَارِب", "bengali": "", "english": "It was narrated from Abu Hurairah that :the Messenger of Allah (ﷺ) said: \"Whoever says: Subhan Allahi wa bi hamdihi (Glory and praise is to Allah) one hundred times, his sins will be forgiven even if they were like the foam of the sea", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص سو بار «سبحان الل", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 33, Hadith 156", "international_number": "3812", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3813", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا أَبُو مُعَاوِيَةَ،‏‏‏‏ عَنْ عُمَرَ بْنِ رَاشِدٍ،‏‏", "bengali": "", "english": "It was narrated that Abu Darda' said:\"The Messenger of Allah (ﷺ) said to me: 'You should recite Subhan-Allah, wal-Hamdu-Lillah, wa la ilahah illallah, wa Allahu Akbar (Glory is to Allah, praise is to Allah, none has the right to be worshiped but Allah, and Allah is the Most Great), for it sheds sins like the tree sheds its leaves", "french": "", "indonesian": "", "russian": "", "urdu": "ابوالدرداء رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مجھ سے فرمایا:  تم «سبحان الله", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 157", "international_number": "3813", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3814", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا أَبُو أُسَامَةَ،‏‏‏‏ وَالْمُحَارِبِيُّ،‏‏‏‏ عَنْ م", "bengali": "", "english": "It was narrated that Ibn `Umar said:\"We used to count that the Messenger of Allah (ﷺ) said one hundred times in a gathering: 'Rabbighfirli wa tub `alayya innaka Antat-Tawwabur-Rahim (O Allah forgive me and accept my repentance, for You are the Accepter of repentance, the Most Merciful)", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں: ہم شمار کرتے رہتے تھے کہ  رسول اللہ صلی اللہ علیہ وسلم مجلس", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 33, Hadith 158", "international_number": "3814", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3815", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ،‏‏‏‏ عَنْ مُحَمَّد", "bengali": "", "english": "It was narrated from Abu Hurairah that :the Messenger of Allah (saas) said: 'I seek the forgiveness of Allah and repent to Him one hundred times each day", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  میں تو ہر روز اللہ تعالی", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 33, Hadith 159", "international_number": "3815", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3816", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ مُغِيرَةَ بْنِ أَبِي الْحُرِّ،‏‏", "bengali": "", "english": "It was narrated from Sa'eed bin Abu Burdah bin Abu Musa, from his father, that :his grandfather said: \"The Messenger of Allah (saas) said: 'I seek the forgivenenss of Allah and repent to Him seventy times each day", "french": "", "indonesian": "", "russian": "", "urdu": "ابوموسیٰ اشعری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  میں تو ہر روز اللہ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 33, Hadith 160", "international_number": "3816", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3817", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا أَبُو بَكْرِ بْنُ عَيَّاشٍ،‏‏‏‏ عَنْ أَبِي إِسْحَا", "bengali": "", "english": "It was narrated that Hudhaifah said:\"I was harsh in the way I spoke to my family, but not to others. I mentioned that to the Prophet (saas) and he said: 'Why don't you ask for forgiveness? Ask Allah to forgive you, seventy times each day", "french": "", "indonesian": "", "russian": "", "urdu": "حذیفہ رضی اللہ عنہ کہتے ہیں کہ  میں اپنے گھر والوں پر زبان درازی کرتا تھا، لیکن اپنے گھر والوں کے سو", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 33, Hadith 161", "international_number": "3817", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3818", "arabic": "حَدَّثَنَا عَمْرُو بْنُ عُثْمَانَ بْنِ سَعِيدِ بْنِ كَثِيرِ بْنِ دِينَارٍ الْحِمْصِيُّ،‏‏‏‏ حَدَّثَن", "bengali": "", "english": "Abdullah bin Busr said that :the Prophet (saas) said: \"Glad tidings to those who find a lot of seeking forgiveness in the record of their deeds", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن بسر رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  مبارکبادی ہے اس شخص", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 33, Hadith 162", "international_number": "3818", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3819", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ،‏‏‏‏ حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ،‏‏‏‏ حَدَّثَنَا الْحَكَمُ", "bengali": "", "english": "It was narrated from 'Abdullah bin 'Abbas that :the Messenger of Allah said: \"Whoever persists in asking for forgiveness, Allah will grant him relief from every worry, and a way out from every hardship, and will grant him provision from (sources) he could never imagine", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے استغفار ک", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 33, Hadith 163", "international_number": "3819", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3820", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ،‏‏‏‏ عَنْ حَمَّادِ", "bengali": "", "english": "It was narrated from 'Aishah that :the Prophet (saas) used to say: \"Allahum-maj'alni minal-ladhina idha ahsanu istabsharu, wa idha asa'u istaghfaru (O Allah, make me one of those who, if they do good deeds, they rejoice, and if they do bad deeds, they seek forgiveness)", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم فرمایا کرتے تھے:   «اللهم ا", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 33, Hadith 164", "international_number": "3820", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3821", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ الْأَعْمَشِ،‏‏‏‏ عَنْ الْمَعْرُو", "bengali": "", "english": "It was narrated from Abu Dharr that :the Messenger of Allah (saas) said: \"Allah, the Blessed and Exalted, said: 'Whoever does one good deed will have (the reward of) ten like it and more, and whoever does a bad deed will have one like it, or I will forgive him. Whoever draws near to Me a hand span, I draw near to him an arm's length; whoever comes to Me a forearm's length, I draw near him an arm's length; whoever comes to Me walking, I come to him in a hurry. Whoever meets Me with an earthful of sins, but does not associate anything in worship with Me, I will meet it (i.e., his sins) with forgiveness equal to that", "french": "", "indonesian": "", "russian": "", "urdu": "ابوذر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ تعالیٰ فرماتا ہے: جو ش", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 33, Hadith 165", "international_number": "3821", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3822", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ قَالَا:‏‏‏‏ حَدَّثَنَ", "bengali": "", "english": "It was narrated from Abu Hurairah that :the Messenger of Allah (saas) said: \"Allah says, 'I am as My slave thinks I am, and I am with him when he mentions Me. If he makes mention of Me to himself, I make mention of him to Myself; and if he makes mention of Me in an assembly, I make mention of him in an assembly better than it. And if he draws to Me a hand-span length, I draw near to him a forearm's length. And if he comes to Me walking, I go to him in a hurry", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ تعالیٰ فرماتا ہے: م", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 33, Hadith 166", "international_number": "3822", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3823", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا أَبُو مُعَاوِيَةَ،‏‏‏‏ وَوَكِيعٌ،‏‏‏‏ عَ", "bengali": "", "english": "It was narrated from Abu Hurairah that the Messenger :of Allah (saas) said: \"Every deed of the son of Adam will be multiplied for him, between ten and seven hundred times for each merit. Allah said: 'Except for fasting, for it is for Me and I shall reward for it.'\" (sahih)", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  آدمی کا ہر عمل دس گنا س", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 33, Hadith 167", "international_number": "3823", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3824", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ،‏‏‏‏ أَنْبَأَنَا جَرِيرٌ،‏‏‏‏ عَنْ عَاصِمٍ الْأَحْوَلِ،‏‏‏‏ عَ", "bengali": "", "english": "It was narrated that Abu Musa said:\"The Prophet (saas) heard me saying: 'La hawla wa la quwwata illa billah (there is no power and no strength except with Allah).' He said: 'O 'Abdullah bin Qais! Shall I not tell you of a word which is one of the treasures of Paradise?' I said: 'Yes, O Messenger of Allah.' He said: 'Say: La hawla wa la quwwata illa billah (There is no power and no strength except with Allah)", "french": "", "indonesian": "", "russian": "", "urdu": "ابوموسیٰ اشعری رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے مجھے «لا حول ولا قوة إلا بال", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 33, Hadith 168", "international_number": "3824", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3825", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ الْأَعْمَشِ،‏‏‏‏ عَنْ مُجَاهِدٍ،", "bengali": "", "english": "It was narrated that Abu Dharr said:\"The Messenger of Allah (saas) said to me: \"Shall I not tell you of a treasure which is one of the treasures of Paradise?' I said: 'Yes, O Messenger of Allah.' He said: 'La hawla wa la quwwata illa billah (There is no power and no strength except with Allah).'\" (sahih)", "french": "", "indonesian": "", "russian": "", "urdu": "ابوذر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مجھ سے فرمایا:  کیا میں تمہیں وہ کلم", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 33, Hadith 169", "international_number": "3825", "narrator_chain": "", "chapter_intro": "Etiquette"}
{"hadithnumber": "3826", "arabic": "حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدٍ الْمَدَنِيُّ،‏‏‏‏ حَدَّثَنَا مُحَمَّدُ بْنُ مَعْنٍ،‏‏‏‏ حَدَّثَنَ", "bengali": "", "english": "It was narrated that Hazim bin Harmalah said:\"I passed by the Prophet (saas) and he said to me: 'O Hazim, say often: \"La hawla wa la quwwata illa billah (there is no power and no strength except with Allah),\" for it is one of the treasures of Paradise", "french": "", "indonesian": "", "russian": "", "urdu": "حازم بن حرملہ رضی اللہ عنہ کہتے ہیں کہ  میں  ( ایک روز )  نبی اکرم صلی اللہ علیہ وسلم کے پاس سے گزرا", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 33, Hadith 170", "international_number": "3826", "narrator_chain": "", "chapter_intro": "Etiquette"}
