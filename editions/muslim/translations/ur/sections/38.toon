{"hadithnumber": "5586", "text": "حضرت انس رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ بقیع میں ایک شخص نے دوسرے شخص کو یا ابالقاسم کہہ کر آوا"}
{"hadithnumber": "5587", "text": "حضرت عبد اللہ بن عمر رضی اللہ تعالیٰ عنہ  سے روایت ہے کہا  :  رسول اللہ  صلی اللہ علیہ وسلم  نے فرما"}
{"hadithnumber": "5588", "text": "منصور نے سالم بن ابی جعد سے ،  انھوں نے حضرت جابر بن عبداللہ  رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہ"}
{"hadithnumber": "5589", "text": "حسین نے سالم بن ابی جعد سے ، انھوں نے حضرت جابر عبد اللہ  رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہا  :"}
{"hadithnumber": "5590", "text": "خالد طحان نے حصین سے اسی سند کے ساتھ حدیث بیان کی اور  \" میں قاسم  ( تقسیم کرنے والا  )  بنا کر بھیج"}
{"hadithnumber": "5591", "text": "ابو بکر بن ابی شیبہ اور ابو سعید اشج نے کہا  :  ہمیں وکیع نے حدیث بیان کی کہا  :  ہمیں اعمش نے سالم"}
{"hadithnumber": "5592", "text": "ابو معاویہ نے اعمش سے اسی سند کے ساتھ حدیث بیان کی اور کہا  :  \" قاسم بنا یا گیا ہوں تمھا رے درمیان"}
{"hadithnumber": "5593", "text": "محمد بن مثنیٰ اور محمد بن بشار نے کہا  :  ہمیں محمد بن جعفر نے حدیث بیان کی  ، کہا  :  ہمیں شعبہ نے"}
{"hadithnumber": "5594", "text": "ابو بکر بن ابی شیبہ محمد بن مثنیٰ محمد بن عمرو بن جبلہ اور بشر بن خالد نے محمد بن جعفر سے  ۔ محمد بن"}
{"hadithnumber": "5595", "text": "سفیان بن عیینہ نے کہا  : ہمیں  ( محمد  )  بن منکدر نے حدیث سنا ئی کہ انھوں  نے حضرت جا بر بن عبد الل"}
{"hadithnumber": "5596", "text": "روح بن قاسم نے محمد بن مکدر سے ، انھوں نے حضرت جابر رضی اللہ تعالیٰ عنہ  کی حدیث کی طرح حدیث بیان کی"}
{"hadithnumber": "5597", "text": "ابو بکر بن ابی شیبہ  ، عمرو ناقد ، زہیر بن حرب ،  اور ابن نمیر نے کہا : ہمیں سفیان بن عینیہ نے ایوب"}
{"hadithnumber": "5598", "text": "سیدنا مغیرہ بن شعبہ رضی اللہ عنہ سے روایت ہے کہ جب میں نجران میں آیا ،  تو وہاں کے  ( انصاری )  لوگو"}
{"hadithnumber": "5599", "text": "معتمر بن سلیمان نے کہا : میں رُکین سے سنا ، وہ ا  پنے والد سے حدیث بیان کررہے تھے ، انھوں نے حضرت سم"}
{"hadithnumber": "5600", "text": "۔  جریر نے رکین بن ربیع سے ، انھوں نے اپنے والد سے ، انھوں نے سمرہ بن جندب رضی اللہ تعالیٰ عنہ  سے ر"}
{"hadithnumber": "5601", "text": "‏‏‏‏ سیدنا سمرہ بن جندب رضی اللہ عنہ سے روایت ہے، رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”سب سے زیا"}
{"hadithnumber": "5602", "text": "جریر ، روح بن قاسم اورشعبہ سب نے منصور سے زہیر کی سند کے ساتھ حدیث بیان کی ، جریر اورروح کی حدیث قصے"}
{"hadithnumber": "5603", "text": "ابن جریج نے کہا : مجھے ابو زبیر نے بتایا کہ انھوں نے حضرت جابر بن عبداللہ رضی اللہ تعالیٰ عنہ  کو یہ"}
{"hadithnumber": "5604", "text": "احمد بن حنبل ، زہیر بن حرب ، محمد بن مثنیٰ ، عبیداللہ بن سعید اور محمد بن بشار نے ( ان سب نے )  کہا"}
{"hadithnumber": "5605", "text": "حماد بن سلمہ نے عبیداللہ سے  ، انھوں نے نافع سے  ، انھوں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے روا"}
{"hadithnumber": "5606", "text": "عمرو ناقد اور ابن ابی عمر نے حدیث بیان  کی ۔ الفاظ عمرو کے ہیں ۔ دونوں نے کہا : ہمیں سفیان نے آل طلح"}
{"hadithnumber": "5607", "text": "ابو بکر بن ابی شیبہ ، محمد بن مثنیٰ اورمحمد بن بشار نے کہا : ہمیں محمد بن جعفر نے حدیث بیان کی ، محم"}
{"hadithnumber": "5608", "text": "ولید بن کثیر نے کہا : مجھے محمد بن عمرو بن عطاء نے حدیث بیان کی  ، کہا : مجھے حضرت زینب بنت ام سلمہ"}
{"hadithnumber": "5609", "text": "یزید بن ابی حبیب نے محمد بن عمرو بن عطاء سے روایت کی ، کہا :  میں نے اپنی بیٹی کانام برہ رکھا تو حضر"}
{"hadithnumber": "5610", "text": "سعید بن عمرو اشعشی ، احمد بن حنبل رحمۃ اللہ علیہ  اورابو بکر بن ابی شیبہ نے ہمیں حدیث بیان کی ۔ الفا"}
{"hadithnumber": "5611", "text": "ہمیں معمر ہمام بن منبہ سے خبر دی ، کہا : یہ احادیث ہمیں حضرت ابوہریر رضی اللہ تعالیٰ عنہ   رضی اللہ"}
{"hadithnumber": "5612", "text": "ثابت بنانی نے حضرت انس بن مالک رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا : جب عبداللہ بن ابی طلہ  پیدا"}
{"hadithnumber": "5613", "text": "یزید بن ہارون نے کہا : ہمیں ابن عون نے ابن سیرین سے خبر دی ، انھوں نے حضرت انس بن مالک رضی اللہ تعال"}
{"hadithnumber": "5614", "text": "حماد بن مسعدہ نے کہا : ہمیں ابن عون نے محمد ( ابن سیرین )  سے حدیث بیان کی ، انھوں نے حضرت انس رضی ا"}
{"hadithnumber": "5615", "text": "حضرت ابوموسیٰ رضی اللہ تعالیٰ عنہ سے روایت ہے  ، کہا : میرے ہاں ایک لڑکا پیدا ہوا ، میں اس کو لے کر"}
{"hadithnumber": "5616", "text": "شعیب بن اسحاق نے کہا؛مجھے ہشام بن عروہ نے بتایا  ، کہا : مجھے عروہ بن زبیر اور فاطمہ بنت منذر بن زبی"}
{"hadithnumber": "5617", "text": "ابو اسامہ نے ہشام سے ، انھوں نے ا پنے والد سے ، انھوں نے حضرت اسماء رضی اللہ تعالیٰ عنہا  سے روایت ک"}
{"hadithnumber": "5618", "text": "علی بن مسہر نے ہشام بن عروہ سے ، انھوں نے اپنے والد سے ، انھوں نے حضرت اسماء بنت ابی بکر رضی اللہ تع"}
{"hadithnumber": "5619", "text": "حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے روایت ہے کہ رسول اللہ  صلی اللہ علیہ وسلم  کے پاس بچے لائے جات"}
{"hadithnumber": "5620", "text": "حضرت عائشہ  رضی اللہ تعالیٰ عنہا  سےروایت ہے  ، کہا : ہم گھٹی دلوانے کے لئے عبداللہ بن زبیر رضی اللہ"}
{"hadithnumber": "5621", "text": "حضرت سہل بن سعد ( بن مالک رضی اللہ تعالیٰ عنہ  )  سے روایت ہے  ، کہا :  کہ ابواسید رضی اللہ عنہ کا ب"}
{"hadithnumber": "5622", "text": "ابوتیاح نے حضرت  انس بن مالک رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا : رسول اللہ  صلی اللہ علیہ وسلم"}
{"hadithnumber": "5623", "text": "حضرت انس بن مالک رضی اللہ تعالیٰ عنہ  سے روایت ہے کہا : رسول اللہ  صلی اللہ علیہ وسلم  نے مجھ سے فرم"}
{"hadithnumber": "5624", "text": "یزید بن ہارون نے اسماعیل بن ابی خالد سے ، انھوں نے قیس بن ابی حازم سے  ، انھوں نے حضرت مغیرہ بن شعبہ"}
{"hadithnumber": "5625", "text": "وکیع ، ہشیم ، جریر اور ابو اسامہ سب نے اسماعیل سے اسی سند کے ساتھ حدیث بیان کی ، ان میں سے تنہا یزید"}
{"hadithnumber": "5626", "text": "عمرو بن محمد بن بکیر ناقد نے کہا : ہمیں سفیان بن عینیہ نے حدیث بیان کی ، کہا : اللہ کی قسم!ہمیں یزید"}
{"hadithnumber": "5627", "text": "قتیبہ بن سعید اور ابن ابی عمر نے کہا :  \" ہمیں سفیان نے یزید بن خصیفہ سے اسی سند کے ساتھ حدیث بیان ک"}
{"hadithnumber": "5628", "text": "بکیر بن اشج سے روایت ہے کہ بسر بن سعید نے انھیں حدیث بیان کی ، انھوں نے حضرت ابوسعید خدری رضی اللہ ت"}
{"hadithnumber": "5629", "text": "بشر بن مفضل نے کہا :  ہمیں سعید بن یزید نے ابو نضرہ سے حدیث بیان کی ، انھوں نے حضرت ابو سعید رضی الل"}
{"hadithnumber": "5630", "text": "شعبہ نے ابو سلمہ جریری اور سعید بن یزید سے حدیث بیان کی ، جریری اور سعید بن یزید دونوں نے ابو نضر ہ"}
{"hadithnumber": "5631", "text": "یحییٰ بن سعیدقطان  نے ابن جریج سے روایت کی کہا  :  ہمیں عطاء نے عبید بن عمیر سے حدیث بیان کی کہ حضرت"}
{"hadithnumber": "5632", "text": "ابو عاصم اور نضر بن شمیل دونوں نے کہا  : ہمیں ابن جریج نے اسی سند کے ساتھ اسی طرح حدیث بیان کی ۔ اور"}
{"hadithnumber": "5633", "text": "افضل بن موسیٰ نے کہا  :  ہمیں طلحہ بن یحییٰ نے ابو بردہ سے خبر دی  ، انھوں نے حضرت ابو موسیٰ اشعری"}
{"hadithnumber": "5634", "text": "علی بن ہاشم نے طلحہ بن یحییٰ سے اسی سند کے ساتھ حدیث بیان کی  ، مگر انھوں نے کہا  :  تو انھوں  ( حضر"}
{"hadithnumber": "5635", "text": "عبد اللہ بن ادریس نے شبعہ سے انھوں نے محمد بن منکدر سے ، انھوں نے جابر بن عبداللہ  رضی اللہ تعالیٰ ع"}
{"hadithnumber": "5636", "text": "وکیع نے شعبہ سے ، انھوں نے محمد بن منکدر سے ، انھوں نے حضرت جابر بن عبد اللہ  رضی اللہ تعالیٰ عنہ  س"}
{"hadithnumber": "5638", "text": "لیث نے ابن شہاب سے روایت کی کہ حضرت سہل بن سعد ساعدی رضی اللہ تعالیٰ عنہ  نے انھیں بتا یا کہ ایک شخص"}
{"hadithnumber": "5639", "text": "یو نس نے ابن شہاب سے روایت کی کہ سہل بن سعدانصاری  رضی اللہ تعالیٰ عنہ  نے انھیں بتا یا کہ ایک شخص ن"}
{"hadithnumber": "5640", "text": "سفیان بن عیینہ اور معمر دونوں نے زہری سے انھوں نے حضرت سہل بن سعد  رضی اللہ تعالیٰ عنہ  سے  ، انھوں"}
{"hadithnumber": "5641", "text": "حضرت انس بن مالک رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ ایک شخص نے رسول اللہ  صلی اللہ علیہ وسلم کے حجر"}
{"hadithnumber": "5642", "text": "سہیل کے والد ابو صالح نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے ، انھوں نے رسول اللہ  صلی اللہ علیہ"}
{"hadithnumber": "5643", "text": "اعرج نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہ رسول اللہ  صلی اللہ علیہ وسلم  نے فر ما"}
{"hadithnumber": "5644", "text": "یزید بن زریع  ، اسماعیل بن علیہ اور ہشیم نے یو نس سے ، انھوں نے عمرو بن سعید سے  ، انھوں نے ابوزرعہ"}
{"hadithnumber": "5645", "text": "عبد الاعلیٰ اور سفیان دونوں نے یو نس سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی  ۔"}
