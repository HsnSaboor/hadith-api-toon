hadiths[124]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
6805,"جریر نے اعمش سے ،  انہوں نے ابوصالح سے اور انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  کہا : ",,,,,6805
6806,"ابومعاویہ نے اعمش سے اسی سند کے ساتھ حدیث بیان کی ،  اور انہوں نے یہ بیان نہیں کیا کہ  "" اگر وہ ایک ",,,,,6806
6807,")   ہمیں معمر نے ہمام بن منبہ سے حدیث بیان کی ،  کہا :  یہ احادیث ابوہریرہ رضی اللہ عنہ نے ہمیں رسول",,,,,6807
6808,"حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم مکہ کے ایک راستے پر چل",,,,,6808
6809,عمرو ناقد ،  زُہیر بن حرب اور ابن ابی عمر نے ہمیں سفیان سے حدیث بیان کی  ۔  ۔  الفاظ عمرو کے ہیں  ۔ ,,,,,6809
6810,معمر نے ہمیں ایوب سے خبر دی ،  انہوں نے ابن سیرین سے ،  انہوں نے ابوہریرہ رضی اللہ عنہ سے ،  نیز  ( ,,,,,6810
6811,)   عبدالعزیز بن صُہیب نے حضرت انس رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا کہ رسول اللہ صلی اللہ عل,,,,,6811
6812,علاء کے والد  ( عبدالرحمٰن )  نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ علیہ و,,,,,6812
6813,"عطاء بن میناء نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فر",,,,,6813
6814,"عبدالعزیز نے حضرت انس رضی اللہ عنہ سے روایت کی ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   ",,,,,6814
6815,ثابت نے حضرت انس رضی اللہ عنہ سے اور انہوں نے نبی صلی اللہ علیہ وسلم سے اسی کے مانند روایت کی ،  مگر,,,,,6815
6816,عاصم نے ہمیں نضر بن انس سے حدیث بیان کی کہ حضرت انس رضی اللہ عنہ ان دنوں زندہ تھے ۔   ( نضر نے )  کہ,,,,,6816
6817,"عبداللہ بن ادریس نے اسماعیل بن ابی خالد سے ،  انہوں نے قیس بن ابی حازم سے روایت کی کہ انہوں نے کہا :",,,,,6817
6818,سفیان بن عیینہ ،  جریر بن عبدالحمید ،  وکیع ،  عبداللہ بن نمیر ،  معتمر بن سلیمان اور ابواسامہ سب نے,,,,,6818
6819,"معمر نے ہمیں ہمام بن منبہ سے حدیث بیان کی ،  کہا :  یہ احادیث ہمیں ابوہریرہ رضی اللہ عنہ نے رسول الل",,,,,6819
6820,"ہمام نے کہا :  ہمیں قتادہ نے انس بن مالک رضی اللہ عنہ سے حدیث بیان کی ،  انہوں نے حضرت عبادہ بن صامت",,,,,6820
6821,"شعبہ نے قتادہ سے روایت کی ،  انہوں نے کہا :  میں نے حضرت انس بن مالک رضی اللہ عنہ کو حضرت عبادہ بن ص",,,,,6821
6822,"خالد بن حارث بجیمی نے کہا :  ہمیں سعید نے قتادہ سے حدیث بیان کی ،  انہوں نے زُرارہ سے ،  انہوں نے سع",,,,,6822
6823,"محمد بن بکر نے کہا :  ہمیں سعید نے قتادہ سے اسی سند کے ساتھ حدیث بیان کی ۔",,,,,6823
6824,علی بن مسہر نے زکریا سے ،  انہوں نے شعبی سے ،  انہوں نے شریح بن بانی سے اور انہوں نے حضرت عائشہ رضی ,,,,,6824
6825,"عیسیٰ بن یونس نے کہا :  ہمیں زکریا نے عامر  ( شعبی )  سے حدیث بیان کی ،  انہوں نے کہا :  مجھے شُریح ",,,,,6825
6826,عبثر نے مطرف سے ،  انہوں نے عامر سے ،  انہوں نے شریح بن ہانی سے اور انہوں نے حضرت ابوہریرہ رضی اللہ ,,,,,6826
6827,جریر نے مطرف سے اسی سند کے ساتھ عبثر کی حدیث کے مانند خبر دی ۔,,,,,6827
6828,"حضرت ابوموسیٰ اشعری رضی اللہ عنہ نے نبی صلی اللہ علیہ وسلم سے روایت کی کہ آپ نے فرمایا :   "" جو شخص ",,,,,6828
6829,"یزید بن اصم نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرما",,,,,6829
6830,یحییٰ بن سعید اور ابن ابی عدی نے سلیمان تیمی سے ،  انہوں نے حضرت انس بن مالک رضی اللہ عنہ سے ،  انہو,,,,,6830
6831,"معتمر نے اپنے والد  ( سلیمان تیمی )  سے اسی سند کے ساتھ حدیث بیان کی اور  "" جب وہ چل کر میرے پاس آتا",,,,,6831
6832,"ابوصالح نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :",,,,,6832
6833,"وکیع نے کہا :  ہمیں اعمش نے معرور بن سوید سے حدیث بیان کی ،  انہوں نے حضرت ابوزر رضی اللہ عنہ سے روا",,,,,6833
6834,"ابومعاویہ نے اعمش سے اسی سند کے ساتھ اسی کے مانند روایت بیان کی ،  مگر انہوں نے کہا :   "" اس کے لیے ",,,,,6834
6835,محمد بن ابوعدی نے حمید سے ،  انہوں نے ثابت سے اور انہوں نے حضرت انس بن مالک رضی اللہ عنہ سے روایت کی,,,,,6835
6836,"خالد بن حارث نے کہا :  ہمیں حمید نے اسی سند کے ساتھ دعا کے ان الفاظ تک حدیث بیان کی :   "" ہمیں دوزخ ",,,,,6836
6837,"حماد نے کہا :  ثابت نے ہمیں حضرت انس رضی اللہ عنہ سے خبر دی کہ رسول اللہ صلی اللہ علیہ وسلم اپنے صحا",,,,,6837
6838,)  قتادہ نے انس رضی اللہ عنہ سے اور انہوں نے نبی صلی اللہ علیہ وسلم سے یہی حدیث بیان کی ۔,,,,,6838
6839,"حضرت ابوہریرہ رضی اللہ عنہ نے نبی صلی اللہ علیہ وسلم سے روایت کی کہ آپ نے فرمایا :   "" اللہ تبارک و ",,,,,6839
6840,")   عبدالعزیز بن صہیب نے کہا :  قتادہ نے حضرت انس رضی اللہ عنہ سے پوچھا کہ رسول اللہ صلی اللہ علیہ و",,,,,6840
6841,ثابت نے حضرت انس رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ علیہ وسلم  ( دعا فرماتے ہوئے یہ )  ک,,,,,6841
6842,"حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   "" جو شخص دن میں",,,,,6842
6843,"حضرت ابوہریرہ رضی اللہ عنہ سے روایت ے ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :  کوئی شخص ج",,,,,6843
6846,"حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   "" دو کلم",,,,,6846
6847,"حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   "" یہ بات",,,,,6847
6848,"ابوبکر بن ابی شیبہ نے ہمیں حدیث بیان کی ،  کہا :  ہمیں علی بن مسہر اور ابن نمیر نے موسیٰ جہنی سے حدی",,,,,6848
6849,"عبدالواحد بن زیاد نے کہا :  ہمیں ابو مالک اشجعی نے اپنے والد  ( طارق بن اشیم اشجعی رضی اللہ عنہ )  س",,,,,6849
6850,"ابومعاویہ نے کہا؛ ہمیں ابومالک اشجعی نے اپنے والد سے حدیث بیان کی ،  کہا :  جب کوئی شخص مسلمان ہوتا ",,,,,6850
6851,"یزید بن ہارون نے کہا :  ابومالک نے ہمیں اپنے والد سے خبر دی کہ انہوں نے نبی صلی اللہ علیہ وسلم سے سن",,,,,6851
6852,")   معصب بن سعد سے روایت ہے ،  انہوں نے کہا :  مجھے میرے والد  ( سعد بن ابی وقاص رضی اللہ عنہ )  نے ",,,,,6852
6853,ابومعاویہ نے اعمش سے ،  انہوں نے ابوصالح سے اور انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  ک,,,,,6853
6854,"عبداللہ بن نمیر اور ابواسامہ نے کہا :  ہمیں اعمش نے حدیث بیان کی ،  انہوں نے ابوصالح سے اور انہوں نے",,,,,6854
6857,"حضرت ابوسعید خدری رضی اللہ عنہ سے روایت ہے ،  کہا :  حضرت معاویہ رضی اللہ عنہ نکل کر مسجد میں ایک حل",,,,,6857
6858,ثابت نے ابو بُردہ سے اور انہوں نے حضرت اغرمزنی رضی اللہ عنہ سے ،  جنہیں شرفِ صحبت حاصل تھا ،  روایت ,,,,,6858
6859,"غندر نے شعبہ سے ،  انہوں نے عمرہ بن مُرہ سے اور انہوں نے ابوبُردہ سے روایت کی ،  انہوں نے کہا :  میں",,,,,6859
6860,عبیداللہ کے والد معاذ ،  ابوداؤد اور عبدالرحمٰن بن مہدی نے شعبہ سے اسی سند سے  ( یہی )  روایت کی ۔,,,,,6860
6861,"حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   "" جس شخص",,,,,6861
6862,محمد بن فضیل اور ابومعاویہ نے عاصم سے ،  انہوں نے ابوعثمان سے اور انہوں نے حضرت ابوموسیٰ رضی اللہ عن,,,,,6862
6863,)   حفص بن غیاث نے عاصم سے اسی سند کے ساتھ اسی کے مانند روایت کی ۔,,,,,6863
6864,"یزید بن زُریع نے کہا :  ہمیں  ( سلیمان )  تیمی نے ابوعثمان سے حدیث بیان کی ،  انہوں نے حضرت ابوموسیٰ",,,,,6864
6865,"معتمر نے اپنے والد  ( سلیمان تیمی )  سے روایت کی ،  انہوں نے کہا :  ہمیں ابوعثمان نے حضرت ابوموسیٰ ر",,,,,6865
6866,"ایوب نے ابوعثمان سے اور انہوں نے حضرت ابوموسیٰ رضی اللہ عنہ سے روایت کی ،  کہا :  ہم رسول اللہ صلی ا",,,,,6866
6867,"خالد حذاء نے ابوعثمان سے اور انہوں نے حضرت ابوموسیٰ رضی اللہ عنہ سے روایت کی ،   کہا :  ہم ایک غزوے ",,,,,6867
6868,"عثمان بن غیاث نے کہا :  ہمیں ابوعثمان نے حضرت ابوموسی اشعری رضی اللہ عنہ سے روایت کی ،  کہا :  رسول ",,,,,6868
6869,ابو بکر رضی اﷲ عنہ سے روایت ہے انہوں نے رسول اﷲ ﷺ سے عرض کیا یارسول اﷲ ﷺ مجھے ایک دعا سکھلائیے جس کو,,,,,6869
6870,"عبداللہ بن وہب نے ہمیں خبر دی ،  کہا :  ہمیں ایک آدمی نے جس کا انہوں نے نام لیا اور عمرو بن حارث نے ",,,,,6870
6871,"ابن نمیر نے کہا :  ہمیں ہشام نے اپنے والد  ( عروہ )  سے اور انہوں نے حضرت عائشہ رضی اللہ عنہا سے روا",,,,,6871
6872,ابومعاویہ اور وکیع نے ہمیں ہشام سے اسی سند کے ساتھ حدیث بیان کی ۔,,,,,6872
6873,"ابن علیہ نے کہا :  ہمیں سلیمان تیمی نے خبر دی ،  انہوں نے کہا :  ہمیں حضرت انس بن مالک رضی اللہ عنہ ",,,,,6873
6874,یزید بن زریع اور معتمر دونوں نے تیمی سے ،  انہوں نے حضرت انس رضی اللہ عنہ سے اور انہوں نے نبی صلی ال,,,,,6874
6875,ابن مبارک نے سلیمان تیمی سے ،  انہوں نے حضرت انس بن مالک رضی اللہ عنہ سے ،  انہوں نے نبی صلی اللہ عل,,,,,6875
6876,شعیب بن حبحاب نے حضرت انس رضی اللہ عنہ سے روایت کی کہ نبی صلی اللہ علیہ وسلم یہ دعائیں مانگا کرتے تھ,,,,,6876
6877,")   عمرو ناقد اور زُہیر بن حرب نے مجھے حدیث بیان کی ،  انہوں نے کہا :  ہمیں سفیان بن عیینہ نے حدیث ب",,,,,6877
6878,لیث نے یزید بن ابی حبیب سے اور انہون نے حارث بن یعقوب سے روایت کی کہ یعقوب بن عبداللہ نے انہیں حدیث ,,,,,6878
6880,"یعقوب نے کہا :  قعقاع بن حکیم نے ذوان سے ،  انہوں نے ابوصالح سے اور انہوں نے حضرت ابوہریرہ رضی اللہ ",,,,,6880
6881,لیث نے یزید بن ابی حبیب سے ،  انہوں نے جعفر سے ،  انہوں نے یعقوب سے روایت کی ،  انہوں نے ان کو بتایا,,,,,6881
6882,"منصور نے سعد بن عبیدہ سے روایت کی ،  انہوں نے کہا :  مجھے حضرت براء بن عازب رضی اللہ عنہ نے حدیث بیا",,,,,6882
6883,حُصین بن سعد بن عبیدہ سے ،  انہوں نے حضرت براء بن عازب رضی اللہ عنہ سے اور انہوں نے نبی صلی اللہ علی,,,,,6883
6884,محمد بن مثنیٰ نے ابوداود سے اور ابن بشار نے عبدالرحمٰن اور ابوداود دونوں سے روایت کی ،  دونوں نے کہا,,,,,6884
6885,ابو احوص نے ابواسحٰق سے اور انہوں نے حضرت براء بن عازب رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی الل,,,,,6885
6886,"شعبہ نے ابواسحٰق سے روایت کی کہ انہوں نے حضرت براء بن عازب رضی اللہ عنہ کو کہتے ہوئے سنا :  رسول الل",,,,,6886
6887,حضرت براء بن عازب رضی اللہ عنہ سے روایت ہے کہ نبی صلی اللہ علیہ وسلم جب بستر پر تشریف لے جاتے تو یہ ,,,,,6887
6888,"عقبہ بن مُکرم اور ابوبکر بن نافع نے کہا :  ہمیں غندر نے حدیث بیان کی ،  انہوں نے کہا :  ہمیں شعبہ نے",,,,,6888
6889,"جریر نے سہیل سے روایت کی ،  انہوں نے کہا :   ( میرے والد )  ابوصالح ہمیں حکم دیا کرتے تھے کہ جب ہم م",,,,,6889
6890,خالد طحان نے سہیل سے ،  انہوں نے اپنے والد سے اور انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ، ,,,,,6890
6891,"اعمش نے ابوصالح سے اور انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  کہا :  حضرت فاطمہ رضی اللہ",,,,,6891
6892,"انس بن عیاض نے کہا :  ہمیں عبیداللہ نے حدیث بیان کی ،  انہوں نے کہا :  مجھے سعید بن ابی سعید مقبری ن",,,,,6892
