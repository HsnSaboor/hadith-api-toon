hadiths[3]{hadithnumber,text}:
16174,"أدؼلشأثىأؼوشًأثىأتوۏۄأعوشۏأڬۄحەأۄۏڽأڬۄأتۏڬأوشحثۄأوۏڽأؼثۏزتههۄأثىأؼزۏأڬەأضتحہأطتوأڬەأضلشأڬًأىڬهتأ؏أدثأۄوأطۄشأذوظأوۏڽأځۄىډەأحًأؼثۏزتههۄأىەأودہأضەأڬۄتأتڲشأحوۄتشۏأوشعۏأۄًأحًأډهًأًذطۏأڬەأځتضأډهأڬشأذعشحأذوصۄأشعۏأتههۄأؼىۄأڬۏأطۄتزحأڬەأوحؼهمأزشۏتلحأڬشۏڽأآأوۏڽأىەأڬۄتأډهًأ؏أذعشحأًذطۏأشعۏأتههۄأؼىۄأذوظأوۏڽأۄۏأشۄحەأحہەأ؏أۄوأىەأهًڲًڽأضەأتىأڬتأځحۄأځًډہتأتۏڬأطرظأىەأڬۄتأًۄأضتوىەأتځىەأوذهأڬەأضتۏۄأوۏڽأثۏټہەأۄًةەأۄۏڽأدۏضەأځتىۏأضەأثہشۏأۄًةۏأثڔۏأوطڬأۗأۄوأتىأڬەأځتضأڲةەأ؏أتًشأًۄتڽأځۄىډأڬشأتىۄۏڽأضهتوأڬۏتأ؏أذعشحأًذطۏأشعۏأتههۄأؼىۄأىەأضهتوأڬتأدًتثأزۏتأۗأؼثۏزتههۄأتضأًمحأډتزشأوۏڽأتضأغشذأهځټەأۄًةەأحہەأڬۄأضًتةەأإىڬہًڽأتًشأځتاڽأڬەأدضوأڬتأڬًةۏأذظۄأىػشأىۄأإحتأحہتأۗأؼثۏزتههۄأىەأذعشحأًذطۏأضەأځًډہتأڬۏتأإځأودہأڬًأځۄډتىحەأۄۏڽأآأًذطۏأىەأؽًشأضەأزۏڬہتأتًشأزۏڬہأڬشأڬۄىەأهڲەأرزتأڬۏأمضوأوۏڽأتًشأحًأدتىحتأىۄۏڽأظشلأتحىتأدتىحتأۄًڽأڬۄأؼزۏأثىأرۏتشأىەأتوأتهمحتهأثىحأتثًتهؼۏظأضەأىڬتذأڬۏتأحہتأۗأؼزۏأڬتأتضأؼًشحأضەأتۏڬأهڔڬتأوڬۄأوۏڽأځۏزتأۄًتأۗأوۏڽأىەأتضأهڔڬەأڬەأهۏەأزًزہأځهتىەأًتهۏأحهتطأڬۏأتًشأهڔڬەأڬًأوتهأضوۏحأهەأدتأڬشأتىأڬًأزەأزۏتأتثأودہەأحوۄتشەأځتاڽأزۏڬہأڬشأ+أتضأهڔڬەأڬتأرۏتهأۄًتأ,أۏۄأضىأڬشأؼثۏزتههۄأىەأتځىتأوىۄأڬہًهأزۏتأتًشأڬۄتأذعشحأذوصۄأشعۏأتههۄأؼىۄأڬتأًتمؼۄأحًأثۏتىأڬۏدۏەأۗأ"
أًذطۏأىەأڬۄتأۄتڽأمظۄأۏۄأۄەأڬۄأدىڲأثزشأوۏڽأغؼۏوۄأثىأؼزۏأڬًأذوصۄأشعۏأتههۄأؼىۄأىەأمحهأڬشأزۏتأحہتأۏۄأزۏڬہأڬشأوۏشەأإمتأدثۏشأثىأوغؼوأىەأڬۄتأڬۄأتڲشأحًأوۏشەأډډتأڬەأؼًعأذوصۄأڬًأمحهأڬشأزەأڲتأحًأوۏشۏأغشلأضەأحًأإصتزأۄەأډىتىډۄأدثأهًڲأ+أمشۏطأ,أؼۏىۏىأًتهەأضتهأ+أؼۏىۏىأڬًۄأتذزأڬەأځتضأتۏڬأځۄتڔأۄەأتضأڬەأتًشأتذزأڬەأزشوۏتىأتۏڬأىتهۄأذتةهأۄەأ
أتًشأدثأوڬۄأوۏڽأتضهتوأځہۏهأڲۏتأحًأوۏڽأوڬۄأضەأىڬهأڬشأغتةلأڬًأډهتأڲۏتأغتةلأًتهًڽأىەأشضًهأتههۄأ﷽أڬۏأرزوحأوۏڽأڬډہأمتظزأثہۏدەأتًشأودہأضەأڬۄتأڬۄأذعًشأ﷽أمتظزًڽأضەأڬډہأحؼشعأىۄۏڽأڬشحەأ+أحوأتىأڬەأضتحہأډهەأدتاأ,أوۏڽأمتظزًڽأڬەأۄوشتۄأډهأزۏتأتًشأذعًشأ﷽أڬۏأرزوحأوۏڽأذتعشأۄًتأإځأ﷽أىەألشوتۏتأڬۄأحًأًذطۏأۄەأآأوۏڽأىەأؼشعأڬۏتأدۏأۄتڽألشوتۏتأڬۏتأحًأىەأذوصۄأشعۏأتههۄأؼىۄأڬًأطۄۏزأڬۏتأحہتأآأوۏڽأىەأؼشعأڬۏتأذعًشأ﷽أڬًأدًأرثشأځۄىډۏأۄەأًتمؼۄأحًأۏۄۏأۄەأۗألشوتۏتأڬۏتأحدہأضەأۄًأضڬحتأۄەأڬۄأتځىتأډۄشۄأودہەأىۄأزڬہتةەأوۏڽأًۄتڽأضەأډهتأإۏتأۗأ
أذعًشأ﷽أڬۏأًلتحأڬەأثؼزأدثأوضۏهوۄأڬستثأىەأرشًدأڬۏتأحًأوۏڽأىەأڬۄتأوۏڽأوضۏهوۄأڬستثأڬتأومتثهۄأڬشًڽأڲتأحتڬۄأتڲشأوۏڽأتضأڬًأمحهأڬشأزًڽأحًأذعشحأذوصۄأشعۏأتههۄأؼىۄأڬۏأطۄتزحأڬتأطتۏزأمشعأتزتأۄًأدتةەأ؏أډىتىډۄأوۏڽأهًڲًڽأڬەأضتحہأىڬهتأ؏أتضأزشوۏتىأوۏڽأوضۏهوۄأڬتأدًأًتمؼۄأۄًىتأحہتأًۄأۄًتأ+أۏؼىۏأوضهوتىًڽأڬًألحذأۄًةۏأوضۏهوۄأوتشتأڲۏتأ,"أذعشحأًذطۏأڬۄحەأۄۏڽأڬۄأوۏڽأىەأوضۏهوۄأڬًأزۏًتشأڬەأطڲتلأوۏڽأڬہڔتأزۏڬہتأتضأًمحأوضۏهوۄأڬتأشىڲأڬډہأرتڬۏأوؼهًوأۄًحتأحہتأتًشأثتهأثتهڬهأځشتڲىزۄأحہەأوۏڽأىەأذعشحأذوصۄأشعۏأتههۄأؼىۄأًتهۏأثشډہۏأتضأڬەأوتشۏأدًأزًىًڽأطتىًڽأڬەأثۏډأوۏڽأهڲۏأتًشأځتشأۄًأڲةۏأتحىەأوۏڽأتۏڬأتًشأتىظتشۏأإزوۏأذوهۄأإًشأۄًتأتًشأتضأىەأوضۏهوۄأڬەأضشأځشأحهًتشأوتشۏأتًشأتضەأمحهأڬشأزۏتأۗ"""
16175,أڲسطحۄأذزۏخأتضأزًضشۏأضىزأضەأثہۏأوشًۏأۄەأ؏أتهثحۄأتضأڬەأإرشأوۏڽأۏۄأۄەأڬۄأتۏڬأثتىزۏأىەأڲہشأڬۏأډہحأځشأډڔہأڬشأڬۄتأۄتةەأتوۏشأتهوًوىۏىأ$أڬۄأتىۄۏڽأتۏڬأضۏتۄألتوأؽهتوأىەأطۄۏزأڬشأزۏتأۗ
16176,أذعشحأًذطۏأثىأذشثأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأتۏڬأطرظأىەأثتشڲتۄأشضتهحأوۏڽأؼشعأڬۏتأڬۄأۄوأهًڲأڬہتىتأحًأڬہتحەأۄۏڽأهۏڬىأضۏشتثأىۄۏڽأۄًأځتحەأآأىثۏأ﷽أىەألشوتۏتأۄًأضڬحتأۄەأڬۄأحوأهًڲأتهڲأتهڲأڬہتحەأۄًأ؏أڬہتىتأتڬټہەأڬہتۏتأڬشًأتًشأتههۄأڬتأىتوأهەأڬشأڬہتۏتأڬشًأ؏أتضأوۏڽأثشڬحأځۏزتأۄًأدتةەأڲۏأۗ