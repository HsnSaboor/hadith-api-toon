أشتًۏأثۏتىأڬشحەأۄۏڽأ=أځہشأۄوأًتځضأإأشۄەأحہەأ؏أحًأىثۏأتڬشوأ﷽أڬەأتظذتثأوۏڽأضەأتۏڬأطرظأځشىزەأڬتأڲہًىضهتأتْټہتأڬەأڬەأإۏتأدضأوۏڽأځشىزەأڬەأثډەأوًدًزأحہەأ؏أتًشأتضأڬەأوتڽأثتځأتضأطرظأڬەأځۏډہەأإأشۄەأحہەأ؏أًۄأزًىًڽأ+أځشىزەأ,أتضأطرظأڬەأۄتحہأځشأإأڬشأثۏټہأڲةەأ؏أىثۏأتڬشوأ﷽أتځىەأضتحہأوًدًزأتلشتزأڬۏأغشلأوحًدۄأۄًةەأتًشأإځأىەأتشطتزألشوتۏتأ=أتځىەأثډًڽأڬەأثتشەأوۏڽأتىأزًأځشىزًڽأڬەأغشصأؼوهأځشأڬۏتأحوأذۏشتىأىۄۏڽأۄًأشۄەأآأتضأستحأڬۏأمضوأ$أدضأىەأودہەأذمأڬەأۄوشتۄأوثؼًخأڬۏتأۄەأ؏أتههۄأحؼتهۏٳأتځىەأثىزًڽأڬەأهةەأتضأضەأصۏتزۄأشذوأڬشىەأًتهتأۄەأ؏أدحىەأۏۄأځشىزەأتځىەأثډًڽأځشأشذوأڬشىەأًتهەأۄۏڽأۗأ أشتًۏأثۏتىأڬشحەأۄۏڽأ=أځہشأدثأۄوأًتځضأإأشۄەأحہەأتًشأًتموأڬۏأځحہشۏهۏأضشصوۏىأځشأځۄىډەأ؏أحًأۄوتشەأضتوىەأًۄۏأزۏۄتحۏأؼًشحأإأڲةۏأ؏أدًأتځىەأثۏټەأڬًأهەأڬشأإةۏأحہۏأ؏أتضأڬەأځتضأتۏڬأوطڬۏصۄأحہتأ؏أدًأزًزہأڬتأحہتأتًشأتۏڬأثڬشۏأحہۏأ؏أًۄأتضأىەأىثۏأتڬشوأ﷽أڬًأحذلەأڬەأغًشأځشأځۏطأڬۏأ؏أىثۏأتڬشوأ﷽أىەأزشۏتلحأڬۏتأ=أحوۄتشەأثۏټەأڬتأڬۏتأذتهأۄەأآأتضەأدًأحڬهۏلأهتذمأۄًحۏأحہۏأ؏أڬۏتأځہشأڬًةۏأحڬهۏلأهتذمأۄًةۏأ؏أتضأؼًشحأىەأدًتثأزۏتأ=أتضأستحأڬۏأمضوأ$أدضأىەأإځأڬًأذمأڬەأۄوشتۄأوثؼًخأڬۏتأۄەأ؏أدًأډۏصأتضەأځۄهەأهتذمأۄًحۏأحہۏأ؏أتضأوۏڽأضەأڬډہأثہۏأتضەأزًثتشۄأهتذمأىۄۏڽأۄًتأ؏أىثۏأتڬشوأ﷽أىەأتضأؼًشحأڬتأحذلۄأمثًهأڬشأهۏتأۗأ
أشتًۏأڬۄحەأۄۏڽأ=أۄوأإأشۄەأحہەأ؏أدثأۄوأ““أذشۄأ‛‛أڬەأومتوأځشأىۏډەأتحشىەأًتهۏأدڲۄأځشأځۄىډەأ؏أحًأتۏڬأتًىټأإۏتأدًأډهحتأۄًتأإأشۄتأحہتأ؏أىثۏأتڬشوأ﷽أىەألشوتۏتأ=أڬۏتأحوأدتىحەأۄًأۏۄأتًىټأڬۏتأڬۄۄأشۄتأۄەأآأهًڲًڽأىەأؼشعأڬۏأ=أتههۄأتًشأتضأڬتأشضًهأصۏتزۄأثۄحشأدتىحەأۄۏڽأ؏أىثۏأتڬشوأ﷽أىەألشوتۏتأ=أۏۄأتًىټأوۏشەأځتضأإۏتأۄەأ؏أتًشأتځىەأوتهڬأڬەأرهتلأودہأضەأطڬتۏحأڬشأشۄتأۄەأ؏أتضأڬتأۏۄأڬۄىتأۄەأڬۄأتضأڬتأوتهڬأڬةۏأضتهأحڬأتضأځشأڬہۏحۏأثتڔۏأڬشحتأشۄتأ+أۏؼىۏأځتىۏأهتىەأڬەأهةەأتضحؼوتهأڬشحتأشۄتأ,أۏۄتڽأحڬأڬۄأدثأۏۄأرتشطأصزۄأۄًأڲۏتأڬوصًشأۄًأڲۏتأتًشأثًڔہتأۄًأڲۏتأ؏أحًأتضأڬەأوتهڬأىەأۏۄأتشتزۄأڬۏتأڬۄأتضەأسثذأڬشأزەأ؏أتەأدتثشأ$أحوأتضأڬەأوتهڬأڬەأځتضأدتاأتًشأتضەأهەأڬشأإاأ؏أوۏڽأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ$أوۏڽأتضأڬەأوتهڬأڬًأىۄۏڽأځۄډتىحتأۄًڽأ؏أىثۏأتڬشوأ﷽أىەألشوتۏتأ=أۏۄأتًىټأحوۄتشۏأشۄىوتةۏأڬشأزەأڲتأ؏أحًأًۄأتًىټأحۏصۏأضەأډهحتأۄًتأ؏أذعشحأدتثشأشعۏأتههۄأؼىۄأڬەأإڲەأډهىەأهڲتأ؏أۏۄتڽأحڬأڬۄأًۄأثىًأرغوۄأڬۏأوذلهأڬەأځتضأإأڬشأټہۄشأڲۏتأ؏أوۏڽأىەأڬۄتأ=أتضأتًىټأڬتأوتهڬأڬۄتڽأۄەأآأهًڲًڽأىەأثحتۏتأ=أۏۄألهتڽأثىألهتڽأڬتأتًىټأۄەأ؏أوۏڽأتضأڬەأځتضأڲۏتأتًشأڬۄتأ=أتههۄأڬەأشضًهأ﷽أڬەأځتضأدتاأ$أًۄأطرظأوۏشەأضتحہأىڬهتأ؏أۏۄتڽأحڬأڬۄأًۄأىثۏأتڬشوأ﷽أڬەأځتضأإۏتأ؏أىثۏأتڬشوأ﷽أىەأتضأضەألشوتۏتأ=أحوۄتشەأتًىټأىەأحوۄتشەأرهتلأطڬتۏحأڬۏأۄەأ؏أتضأڬتأۏۄأڬۄىتأۄەأحوأتۏڬأغًۏهأؼشظەأحڬأتضأځشأڬہۏحۏأثتڔۏأڬشحەأشۄەأۄًأ؏أۏۄتڽأحڬأڬۄأدثأۏۄأثًڔہتأتًشأڬوصًشأۄًأڲۏتأ؏أحًأحوأىەأتضەأسثذأڬشىەأڬتأتشتزۄأڬشأهۏتأ؏أتضأطرظأىەأڬۄتأ=أتضأستحأڬۏأمضوأ$أدضأىەأإځأڬًأذمأڬەأۄوشتۄأوثؼًخأڬۏتأۄەأ؏أتۏضتأۄۏأۄەأ؏أىثۏأتڬشوأ﷽أىەألشوتۏتأ=أحوأتضەأودہەألشًرحأڬشأزًأ$أتضأىەأؼشعأڬۏأټہۏڬأۄەأۏتأشضًهأتههۄأ$أځہشأىثۏأتڬشوأ﷽أىەأتضأضەأًۄأتًىټأرشۏزأهۏتأتًشأځہشأتضەأتۏڬأزشرحأوۏڽأضتةثۄأڬشأزۏتأۗ أوذوزأثىأغهذۄأثۏتىأڬشحەأۄۏڽأ=أؽصًۄأستحأتهشمتؼأڬًأؼدۏثأًأؽشۏثأتوًشأًتهتأؽصًۄأثہۏأڬۄحەأۄۏڽأۗأ
أ+أؼهتوۄأۄۏخوۏألشوتحەأۄۏڽأ=أ,"أوۏڽأۏۄأڬۄحتأۄًڽأ=أظذۏذأوۏڽأتضأشًتۏحأڬتأڬډہأذظۄأوسڬًشأۄەأۗأ أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأ؏أتًشأتوتوأثصتشأىەأثۄحأصۏتزۄأترحظتشأڬەأضتحہأىمهأڬۏأۄەأ؏أتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأؼثزتهذڬۏوأثىأضلۏتىأۄەأ؏أتثىأتثًذتحوأىەأتضأڬتأسڬشأڬۏتأۄەأ؏أڬضۏأىەأتضأځشأدشذأىۄۏڽأڬۏأۄەأ؏أتضأشًتۏحأڬەأثمۏۄأشدتهأخمۄأۄۏڽأۗ"""
14166,أذعشحأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أوڬۄأڬۏأغشلأتۏڬأضلشأوۏڽأ؏أًۄأىثۏأتڬشوأ﷽أڬەأضتحہأحہەأ؏أىثۏأتڬشوأ﷽أدثأمعتةەأذتدحأڬەأهةەأحطشۏلأهەأدتحەأحہەأ؏أحًأإځأتحىۏأزًشأډهەأدتحەأحہەأڬۄأڬًةۏأإځأڬًأىۄأزۏڬہأضڬەأ؏أشتًۏأڬۄحەأۄۏڽأ=أزًأزشرحًڽأڬًأزۏڬہتأ؏أدًأتۏڬأزًضشەأضەأزًشأحہەأ؏أحًأإځأىەألشوتۏتأ=أتەأتثىأوضؼًزأ$أتىأزًأزشرحًڽأڬەأځتضأدتاأتًشأتىأزًىًڽأضەأۏۄأڬۄًأڬۄأتههۄأڬەأشضًهأحوۄۏڽأۏۄأذڬوأزەأشۄەأۄۏڽأڬۄأحوأزًىًڽأتڬټہەأۄًأدتاأ؏أحتڬۄأًۄأحوۄتشۏأتًټأوۏڽأۄًأدتةۏڽأ؏أحًأتىأزًأوۏڽأضەأتۏڬأډهحتأۄًتأ؏أزًضشەأڬەأځتضأإۏتأ؏أىثۏأتڬشوأ﷽أىەأمعتةەأذتدحأڬۏأ؏أځہشأًۄأزًىًڽأزشرحأتځىۏأدڲۄأًتځضأډهەأڲةەأۗأ أځہشأىثۏأتڬشوأ﷽أشًتىۄأۄًةەأ؏أۏۄتڽأحڬأڬۄأۄوأوزۏىۄأوىًشۄأڬۏأڲهۏًڽأڬەأځتضأځۄىډەأ؏أحًأتۏڬأتًىټأزًڔحتأۄًتأإۏتأ؏أتًشأىثۏأتڬشوأ﷽أڬەأضتوىەأضدزەأوۏڽأډهتأڲۏتأ؏أځہشأًۄأإځأڬەأضتوىەأڬہڔتأۄًتأ؏أتضأڬۏأإىڬہًڽأضەأإىضًأدتشۏأحہەأ؏أىثۏأتڬشوأ﷽أىەأزشۏتلحأڬۏتأ=أتضأتًىټأڬتأوتهڬأڬًىأۄەأآأهًڲًڽأىەأثحتۏتأ=ألهتڽأطرظأۄەأ؏أىثۏأتڬشوأ﷽أىەألشوتۏتأ=أتضەأثهتأڬەأهتاأ؏أتضەأهتۏتأڲۏتأ؏أىثۏأتڬشوأ﷽أىەأتضأضەألشوتۏتأ=أۏۄأحوۄتشۏأطڬتۏحأڬشأشۄتأۄەأ؏أتضأىەأؼشعأڬۏأ=أتەأتههۄأڬەأشضًهأ$أتضأتًىټأځشأۄوأځتىۏأهتزأڬشأهتحەأشۄەأۄۏڽأ؏أثۏضأضتهأحڬأۄوأتۏضتأڬشحەأشۄەأۄۏڽأ؏أتثأۄوأىەأتضەأمشثتىأڬشىەأڬتأتشتزۄأڬۏتأۄەأ؏أىثۏأتڬشوأ﷽أىەألشوتۏتأ=أتضأىەأۏۄۏأطڬتۏحأڬۏأۄەأ؏أحوأتضەأثشتأثزهۄأزەأشۄەأۄًأ؏أحوأثۏضأضتهأحڬأتضەأڬتوأوۏڽأتضحؼوتهأڬشحەأشۄەأ؏أۏۄتڽأحڬأڬۄأدثأتضأڬۏأۄڋۏتڽأڬوصًشأۄًأڲةۏڽأ؏أتضأڬۏأدهزأڬوصًشأۄًأڲةۏأ؏أحًأحوأىەأتضەأمشثتىأڬشىەأڬتأتشتزۄأڬشأهۏتأ؏أحوأتضەأودہەألشًرحأڬشأزًأ$أتضأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ$أۏۄأإځأڬتأۄًتأ؏أىثۏأتڬشوأ﷽أىەأتضأڬەأثتشەأوۏڽأذڬوأزۏتأ؏أحًأتضەأتًىټًڽأڬۏأغشلأثہۏدأزۏتأڲۏتأ؏أىثۏأتڬشوأ﷽أڬەأتظذتثأىەأإځأڬۏأرزوحأوۏڽأؼشعأڬۏأ=أۏتأشضًهأتههۄأ$أتضأتًىټأىەأإځأڬًأضدزۄأڬۏتأۄەأ؏أحًأۄوأحًأضدزۄأڬشىەأڬەأصۏتزۄأذمأزتشأۄۏڽأ؏أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ= أ““أتضأثتحأضەأتههۄأڬۏأځىتۄأۄەأڬۄأڬًةۏأتۏڬأزًضشەأڬًأضدزۄأڬشەأ؏أتڲشأڬضۏأىەأڬضۏأزًضشەأڬًأضدزۄأڬشىتأۄًحتأ؏أحًأوۏڽأؼًشحأڬًأۏۄأذڬوأزۏحتأڬۄأًۄأتځىەأطًۄشأڬًأضدزۄأڬشەأۗ‛‛أ أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأ؏أتًشأوؼدوأڬثۏشأوۏڽأتضأڬۏأوتىىزأشًتۏحأترحظتشأڬەأضتحہأىمهأڬۏأۄەأ؏أحتۄوأتىۄًڽأىەأۏۄأتهلتػأىمهأڬۏەأۄۏڽأ=أۏۄأؽصًۄأذىۏىأڬتأًتمؼۄأۄەأۗأتًشأتىۄًڽأىەأتضأوۏڽأۏۄأتهلتػأصتةزأىمهأڬۏەأۄۏڽأ= أ““أځہشأهًڲًڽأڬًأطزۏزأځۏتضأهتذمأۄًأڲةۏأ؏أحًأىثۏأتڬشوأ﷽أىەأودہأضەألشوتۏتأ=أتەأؼثزتههۄأ$أوۏشەأهةەأځتىۏأحهتطأڬشًأ؏أحوأودہەأتۏڬأثشحىأوۏڽأدًأثډتأۄًتأځتىۏأوهتأحہتأ؏أًۄأهەأڬشأوۏڽأإځأڬەأځتضأإۏتأ؏أىثۏأتڬشوأ﷽أىەأتضەأهەأڬشأتۏڬأځۏتهەأوۏڽأڋتهتأ؏أځہشأإځأىەأ تځىتأزضحأوثتشڬأتضأوۏڽأشڬہتأ؏أتًشأثضوأتههۄأځڔہۏأ؏أحًأإځأڬۏأتىڲهۏًڽأڬەأزشوۏتىأوۏڽأضەأځتىۏأځہًټىەأهڲتأ؏أهًڲًڽأىەأدحىتأډتۄتأ؏أځتىۏأځۏأهۏتأتًشأًعًأڬشأهۏتأۗ أۏۄأشًتۏحأتوتوأثصتشأىەأتضأڬۏأوتىىزأىمهأڬۏأۄەأ؏أوؼدوأتًضغأڬۏأضىزأوۏڽأتۏڬأشتًۏأصوؼۄأثىأظتهذأۄەأ؏أدضأڬەأعؼۏلأۄًىەأڬەأثتًدًزأتضأڬۏأحًخۏمأڬۏأڲةۏأۄەأ؏أتضأشًتۏحأڬەأثمۏۄأشدتهأڬۏأىمهأڬشزۄأذزۏخأذضىأۄًحۏأۄەأ؏أتضأشًتۏحأڬەأزًىًڽأغشۏمأڬۏأتضتىۏزأعؼۏلأۄۏڽأۗ
14167,أضۏزۄأؼتةطۄأظزۏمۄأشعۏأتههۄأؼىۄتأثۏتىأڬشحۏأۄۏڽأ=أىثۏأتڬشوأ﷽أوۄتدشۏىأتًشأتىظتشأڬەأڲشًۄأڬەأزشوۏتىأوًدًزأحہەأ؏أتضۏأزًشتىأتۏڬأتًىټأإۏتأتًشأتضأىەأىثۏأتڬشوأ﷽أڬًأضدزۄأڬۏتأ؏أإځأڬەأتظذتثأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ$أدتىًشأتًشأزشرحأإځأڬًأضدزۄأڬشحەأۄۏڽأ؏أحًأۄوأحًأتضأثتحأڬەأصۏتزۄأذمأزتشأۄۏڽأڬۄأۄوأإځأڬًأضدزۄأڬشۏڽأ؏أىثۏأتڬشوأ﷽أىەألشوتۏتأ=أحوأتځىەأځشًشزڲتشأڬۏأؼثتزحأڬشًأ؏أتًشأتځىەأثہتةۏأڬتأتذحشتوأڬشًأۗأ
أ+أؼهتوۄأۄۏخوۏألشوتحەأۄۏڽأ=أ,"أوۏڽأۏۄأڬۄحتأۄًڽأ=أتضأڬەأثؼزأتىۄًڽأىەأځًشۏأذزۏخأسڬشأڬۏأۄەأۗأ أۏۄأشًتۏحأتوتوأتذوزأىەأىمهأڬۏأۄەأ؏أتًشأتضأڬۏأضىزأؼوزۄأۄەأۗ"""
14168,أذعشحأۏؼهۏٳأثىأتوۏۄأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أتۏڬأوشحثۄأۄوأىثۏأتڬشوأ﷽أڬەأضتحہأضلشأڬشأشۄەأحہەأ؏أتضۏأزًشتىأتۏڬأتًىټأضتوىەأإۏتأ؏أدثأتضأىەأىثۏأتڬشوأ﷽أڬًأزۏڬہتأ؏أحًأتضأىەأتځىتأضشأتًځشأڬۏتأ؏أىثۏأتڬشوأ﷽أىەألشوتۏتأ=أتەأۏؼهۏٳأ$أحوأتضأتًىټأڬەأوتهڬتىأڬەأځتضأدتاأ؏أتًشأتىأضەأتضأتًىټأڬًأرشۏزأهًأ؏أتڲشأًۄأحوۄۏڽأتضأڬًألشًرحأىۄۏڽأڬشحەأ؏أحًأحوأۏۄأڬۄىتأڬۄأتههۄأڬەأشضًهأحوۄۏڽأتضأڬەأثتشەأوۏڽأحهمۏىأڬشأشۄەأۄۏڽأ؏أتىأهًڲًڽأىەأثحتۏتأ=أتههۄأڬۏأمضوأ$أۄوأثۏضأضتهأحڬأتضأځشأځتىۏأهتزأڬشأهتحەأشۄەأۄۏڽأ؏أڬهأۄوأىەأتضەأمشثتىأڬشىەأڬتأتشتزۄأڬشأهۏتأحہتأ؏أهۏڬىأدثأىثۏأتڬشوأ﷽أىەأتضأڬەأثتشەأوۏڽأحهمۏىأڬشأزۏأۄەأ؏أحًأتثأۄوأتضأڬەأذًتهەأضەأثہهتةۏأوۏڽأڬًحتۄۏأىۄۏڽأڬشۏڽأڲەأۗأ أۏۄأشًتۏحأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأ؏أتًشأتضأڬۏأضىزأذضىأۄەأۗ
14169,أتضۏأضىزأڬەأضتحہأ؏أذعشحأۏؼهۏٳأشعۏأتههۄأؼىۄأڬەأذًتهەأضەأۏۄأثتحأوىمًهأۄەأ=أ أ““أتۏڬأوشحثۄأۄوأىثۏأتڬشوأ﷽أڬەأضتحہأضلشأڬشأشۄەأحہەأ؏أۄوتشەأضتوىەأڬہدًشأڬەأحۏىأډہًټەأزشرحأإةەأ؏أدًأتۏڬأزًضشەأضەأتهڲأتهڲأحہەأ؏أىثۏأتڬشوأ﷽أىەألشوتۏتأ=أتىأحۏىًڽأزشرحًڽأڬەأځتضأدتاأتًشأتىأضەأۏۄأڬۄًأ=أڬۄأحوۄۏڽأتههۄأڬەأشضًهأۏۄأۄزتۏحأڬشأشۄەأۄۏڽأڬۄأحوأتههۄأڬەأذڬوأڬەأحذحأتڬټہەأۄًأدتاأ؏أحًأًۄأډهحەأۄًةەأإةەأتًشأتۏڬأدڔأڬۏأوتىىزأۄًأڲةەأ؏أىثۏأتڬشوأ﷽أىەأمعتةەأذتدحأڬەأهةەأتىأڬەأسشۏؼەأځشزۄأڬشأهۏتأ؏أځہشأإځأىەألشوتۏتأ=أتەأۏؼهۏٳأحوأتىأڬەأځتضأدتاأتًشأتىۄۏڽأۏۄأۄزتۏحأڬشًأڬۄأًۄأتههۄأڬەأذڬوأڬەأحذحأًتځضأډهەأدتةۏڽأ؏أحًأًۄأډهحەأۄًةەأڲةەأ؏أۏۄتڽأحڬأڬۄأتىأوۏڽأضەأۄشأتۏڬأتځىۏأورظًظأدڲۄأځشأًتځضأډهتأڲۏتأۗأ أۏۄأشًتۏحأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأۗ
14170,أذعشحأثشۏزۄأثۏتىأڬشحەأۄۏڽأ=أتۏڬأطرظأىثۏأتڬشوأ﷽أڬەأځتضأإۏتأتًشأثًهتأ=أإځأودہەأڬًةۏأىطتىۏأزڬہتةۏەأ؏أىثۏأتڬشوأ﷽أىەألشوتۏتأ=أحوأتضأزشرحأڬەأځتضأدتاأتًشأتضەأثهتأڬەأهتاأ؏أًۄأطرظأتضأزشرحأڬەأځتضأڲۏتأتًشأثًهتأ=أتههۄأڬەأشضًهأحوۄۏڽأثهتأشۄەأۄۏڽأ؏أحًأًۄأزشرحأڬثہۏأتۏڬأغشلأدہڬحتأحہتأ؏أڬثہۏأزًضشۏأغشلأدہڬحتأحہتأ؏أۏۄتڽأحڬأڬۄأتضأىەأتځىۏأحوتوأدڔۏڽأتڬہۏڔأهۏڽأ؏أځہشأًۄأإۏتأتًشأىثۏأتڬشوأ﷽أڬەأځتضأإأڲۏتأىثۏأتڬشوأ﷽أىەأتضەأۏۄأذڬوأزۏتأڬۄأحوأًتځضأډهەأدتاأ$أًۄأطرظأڬہڔتأۄًتأ؏أتًشأتضأىەأىثۏأتڬشوأ﷽أڬەأضشأتًشأۄتحہًڽأتًشأځتاڽأڬًأثًضۄأزۏتأ؏أتًشأتضهتوأمثًهأڬشأهۏتأۗ أۏۄأشًتۏحأتوتوأثصتشأىەأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأظتهذأثىأذثتىأۄەأ؏أتًشأًۄأعؼۏلأۄەأۗ
14171,"أذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأثۏتىأڬشحەأۄۏڽأ=أثىًأؼتوشأضەأحؼهمأشڬہىەأًتهتأتۏڬأطرظأ؏أىثۏأتڬشوأ﷽أڬەأځتضأإۏتأًۄأؼهتدأوؼتهدۄأڬۏتأڬشحتأحہتأ؏أتضأىەأىثۏأتڬشوأ﷽أضەأڬۄتأ=أتەأذعشحأوذوزأ+أ﷽أ,أ$أإځأڬډہأثتحۏڽأڬۄحەأۄۏڽأ؏أحًأڬۏتأإځأتضأثتحأوۏڽأزهډځضۏأشڬہحەأۄۏڽأڬۄأوۏڽأإځأڬتأؼهتدأڬشًڽأآأشتًۏأڬۄحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتضەأثهًتۏتأتًشأتضأضەألشوتۏتأ=أڬۏتأحوأتضأثتحأوۏڽأزهډضځۏأشڬہحەأۄًأآأڬۄأوۏڽأحوۄتشتأؼهتدأڬشًڽأآأتضأىەأڬۄتأ=أڬشۏڽأ؏أتضأًمحأًۄتڽأتۏڬأزشرحأتًشأتۏڬأڬہدًشأڬتأزشرحأوًدًزأحہتأ؏أىثۏأتڬشوأ﷽أىەأتضأوۏڽأضەأتۏڬأزشرحأڬًأثهتۏتأ؏أحًأًۄأإځأڬۏأغشلأإۏتأتًشأتضأىەأضدزۄأڬۏتأ؏أځہشأتضأىەأضشأتټہتۏتأتًشأځہشأضدزۄأڬۏتأ؏أځہشأضشأتټہتۏتأتًشأضدزۄأڬۏتأ؏أۏۄتڽأحڬأڬۄأتضۏأغشذأًۄأضدزۄأڬشحتأۄًتأ؏أإځأڬەأځتضأځۄىډأڲۏتأ؏أتًشأإځأڬەأضتوىەأإأڬەأڬہڔتأۄًأڲۏتأ؏أىثۏأتڬشوأ﷽أىەأتضأضەألشوتۏتأ=أحوأتځىۏأدڲۄأځشأًتځضأډهەأدتاأ؏أًۄأتځىۏأدڲۄأًتځضأډهتأڲۏتأ؏أحًأتضأطرظأىەأڬۄتأ=أتههۄأڬۏأمضوأ$أتضأڬەأثؼزأإځأدًأثہۏأثتحأڬۄۏڽأڲەأ؏أوۏڽأڬضۏأثہۏأډۏصأڬەأذًتهەأضەأ؏أإځأڬًأدہًټتأمشتشأىۄۏڽأزًڽأڲتأۗأځہشأتضأطرظأىەأڬۄتأ=أتەأؼتوشأثىأظؼظۄأ$أتههۄأڬۏأمضوأ$أتضأڬەأثؼزأۏۄأظتذثأدًأثہۏأثتحأڬۄۏڽأڲەأ؏أوۏڽأڬضۏأډۏصأڬەأذًتهەأضەأتىۄۏڽأدہًټتأمشتشأىۄۏڽأزًڽأڲتأۗ أشتًۏأڬۄحەأۄۏڽأ=أؼسمأضەأوشتزأ؏أڬہدًشأڬتأزشرحأۄەأۗ أۏۄأشًتۏحأتوتوأتثًۏؼهۏٳأىەأىمهأڬۏأۄەأ؏أتًشأتضأڬەأشدتهأ““أظذۏذأ‛‛أڬەأشدتهأۄۏڽأ؏أظشلأتثشتۄۏوأثىأذدتدأطتوۏأڬتأوؼتوهۄأورحهلأۄەأ؏أتًشأًۄأخمۄأۄەأۗ"
14172,"أذعشحأؼوشأثىأرغتثأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أذدًىأڬەأومتوأځشأوًدًزأحہەأ؏أوطشڬۏىأىەأإځأڬۏأثتحأڬًأحضهۏوأىۄۏڽأڬۏتأحًأىثۏأتڬشوأ﷽أىەأزؼتأڬۏأ=أتەأتههۄأ$أإدأودہەأتۏضۏأىطتىۏأزڬہتأزەأڬۄأتضأڬەأثؼزأودہەأتضأطرظأڬۏأڬًةۏأځشًتۄأىۄأۄًأ؏أدًأودہەأدہټهتةەأځہشأىثۏأتڬشوأ﷽أڬەأځتضأ+ألشطحۄأإۏتأ,أتًشأإځأضەأڬۄتأڲۏتأ=أإځأڬضۏأزشرحأڬًأثهتةۏڽأ+أىثۏأتڬشوأ﷽أىەأثهتۏتأ,أحًأًۄأزشرحأصوۏىأځشأډهحتأۄًتأ؏أىثۏأتڬشوأ﷽أڬەأځتضأإۏتأ؏أتضأىەأىثۏأتڬشوأ﷽أڬًأضهتوأڬۏتأ؏أځہشأىثۏأتڬشوأ﷽أىەأتضەأذڬوأزۏتأ؏أحًأًۄأًتځضأډهتأڲۏتأ؏أۏۄتڽأزتازأىتوۏأشتًۏأىەأۏۄأهلػأىمهأڬۏەأۄۏڽأ=أتځىەأتْڲىەأڬۏأدڲۄأًتځضأډهتأڲۏتأ؏أتًشأؼلتىأىەأۏۄأهلػأىمهأڬۏەأۄۏڽأ=أتځىۏأورظًظأدڲۄأځشأًتځضأډهتأڲۏتأ؏أحًأىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ= أ““أتضأڬەأثؼزأوۏشۏأمًوأڬتأدًألشزأودہەأدہټهتةەأڲتأ؏أحًأوۏڽأتضأڬۏأڬًةۏأځشًتۄأىۄۏڽأڬشًڽأڲتأۗ‛‛أ أۏۄأشًتۏحأتوتوأثصتشأتًشأتوتوأتثًۏؼهۏٳأىەأىمهأڬۏأۄەأ؏أتًشأتوتوأتثًۏؼهۏٳأڬۏأضىزأذضىأۄەأۗ"
14173,أذعشحأصۏزأثىأختثحأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أتۏڬأزىأۄوأظثذأڬەأًمحأىثۏأتڬشوأ﷽أڬەأضتحہأدتأشۄەأحہەأ؏أۏۄتڽأحڬأڬۄأۄوأوزۏىۄأوىًشۄأورحهلأشتضحەأوهىەأڬۏأدڲۄأځشأځۄىډەأ؏أحًأًۄتڽأۄوۏڽأتۏڬأزۏۄتحۏأىػشأإۏتأ؏أدضأىەأتځىەأتًىټأڬۏأهڲتوأځڬڔۏأۄًةۏأحہۏأ؏أًۄأىثۏأتڬشوأ﷽أڬەأځتضأإأڬشأټہۄشأڲۏتأ؏أۄوأىثۏأتڬشوأ﷽أڬەأتشزڲشزأوًدًزأحہەأ؏أتضأىەأڬۄتأ=أتەأىثۏأ$أإځأځشأضهتوحۏأىتصهأۄًأ؏أتههۄأحؼتهۏٳأڬۏأشذوحۏڽأتًشأتضأڬۏأثشڬحۏڽأىتصهأۄًڽأ؏أىثۏأتڬشوأ﷽أىەأتضەأضهتوأڬتأدًتثأزۏتأ؏أىثۏأتڬشوأ﷽أىەأزشۏتلحأڬۏتأ=أحوۄتشتأڬۏتأذتهأۄەأآأشتًۏأثۏتىأڬشحەأۄۏڽأ=أتضۏأزًشتىأتًىټأإًتصۏڽأىڬتهىەأهڲتأ؏أځہشأتۏڬأطرظأإۏتأدًأذشضۏأهڲأشۄتأحہتأ؏أتضأذشضۏأىەأڬۄتأ=أۏتأشضًهأتههۄأ$أتضأزۏۄتحۏأىەأتًىټأډًشۏأڬۏتأۄەأ؏أشتًۏأڬۄحەأۄۏڽأ=أًۄأتًىټأڬډہأزۏشأإًتصۏڽأىڬتهحتأشۄتأتًشأشًحتأشۄتأ؏أىثۏأتڬشوأ﷽أدًأتضأڬتأشًىتأتًشأإًتصۏڽأضىأشۄەأحہەأ؏أإځأتضەأرتوًطأڬشًتىەأهڲەأ؏أدثأًۄأتًىټأځشضڬًىأۄًتأحًأىثۏأتڬشوأ﷽أذشضۏأڬۏأغشلأوحًدۄأۄًةەأتًشأتضأضەألشوتۏتأ=أتضەأډہًڔأزًأ$أڬۏًىڬۄأتضأتًىټأىەأحوۄتشەأرهتلأۏۄأڲًتۄۏأزۏأۄەأڬۄأحوأدہًټأثًهأشۄەأۄًأ؏أحًأًۄأذشضۏأًتځضأډهتأڲۏتأ؏أىثۏأتڬشوأ﷽أزۏۄتحۏأڬۏأغشلأوحًدۄأۄًةەأتًشألشوتۏتأ=أدثأحوأوۏشەأځتضأًتځضأإةەأحہەأ؏أحًأحوأىەأڬۏتأڬۄتأحہتأآأشتًۏأڬۄحەأۄۏڽأ=أتضأىەأڬۄتأ=أوۏڽأىەأۏۄأڬۄتأحہتأڬۄأوۏشەأوتڽأثتځأإځأځشأمشثتىأۄًڽأ؏أتەأتههۄأ$أحًأذعشحأوذوزأ﷽أځشأشذوحأىتصهألشوتأ؏أۏۄتڽأحڬأڬۄأشذوحأثتمۏأىۄأشۄەأ؏أتەأتههۄأ$أحًأذعشحأوذوزأ﷽أځشأثشڬحأىتصهألشوتأ؏أۏۄتڽأحڬأڬۄأثشڬحأثتمۏأىۄأشۄەأ؏أتەأتههۄأ$أحًأذعشحأوذوزأ﷽أځشأضهتوحۏأىتصهألشوتأ؏أۏۄتڽأحڬأڬۄأضهتوحۏأثتمۏأىۄأشۄەأ؏أتەأتههۄأ$أحًأذعشحأوذوزأ﷽أځشأشذوحألشوتأ$أۏۄتڽأحڬأڬۄأشذوحأثتمۏأىۄأشۄەأ؏أحًأىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أ أ““أتههۄأحؼتهۏٳأىەأتضەأوۏشەأهةەأػتۄشأڬۏتأتًشأتًىټأتځىەأؼسشأڬەأثتشەأوۏڽأثتحأډۏحأڬشأشۄتأحہتأ؏أتًشألشطحًڽأىەأتضەأڲہۏشتأۄًتأحہتأۗ‛‛أ أۏۄأشًتۏحأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏضەأشتًۏأۄۏڽأدىأضەأوۏڽأًتملأىۄۏڽأۄًڽأۗ
14174,"أذعشحأذڬوأثىأذتشخأضهوۏأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأودہەأتۏڬأڬتوأڬەأضهضهەأوۏڽأثہۏدتأ؏أىثۏأتڬشوأ﷽أوۏشەأځتضأضەأڲصشەأ؏أحًأوۏشۏأتًىټىۏأشڬۏأۄًةۏأحہۏأتًشأوۏڽأتْضەأوتشأشۄتأحہتأ؏أىثۏأتڬشوأ﷽أىەألشوتۏتأ=أحوأتضەأىۄأوتشًأ$أځہشأىثۏأتڬشوأ﷽أىەألشوتۏتأ=أحوأتضەأڬہًهأزًأ+أۏتأتضەأډہًڔأزًأ$أ,أحًأًۄأتځىۏأدڲۄأضەأڬہڔۏأۄًةۏأ؏أتًشأزًضشەأهًڲًڽأڬەأضتحہأډهىەأهڲۏأۗأ أۏۄأشًتۏحأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأ؏أتًشأتضأڬەأشدتهأخمۄأۄۏڽأۗ"
14175,"أذعشحأدتثشأثىأؼثزتههۄأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أتۏڬأشتحأوۏشتأتًىټأڲوأۄًأڲۏتأ؏أوۏڽأىثۏأتڬشوأ﷽أڬەأځتضأضەأڲصشتأ؏أإځأضۏزۄأؼتةطۄأشعۏأتههۄأؼىۄتأڬەأهةەأځتهتىأثتىزہأشۄەأحہەأ؏أإځأىەأودہأضەأزشۏتلحأڬۏتأ=أتەأدتثشأ$أڬۏتأۄًتأۄەأآأوۏڽأىەأؼشعأڬۏأ=أوۏشتأتًىټأڲوأۄًأڲۏتأۄەأ+أشتًۏأڬًأطڬأۄەأ؏أطتۏزأۏۄأتهلتػأۄۏڽأ=أ,أوۏشتأتًىټأډهتأڲۏتأۄەأ؏أۏۄأتۏڬأحتشۏڬأشتحأحہۏأ؏أىثۏأتڬشوأ﷽أىەألشوتۏتأ=أتزہشأحوۄتشتأتًىټأۄًأڲتأ؏أحوأدتاأتًشأتضەأهەأهًأ$أشتًۏأڬۄحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأودہەأدضأغشلأڬەأثتشەأوۏڽأثحتۏتأحہتأ؏أوۏڽأتضأغشلأڲۏتأ؏أهۏڬىأودہەأتًىټأىۄۏڽأوهتأ؏أوۏڽأإځأڬەأځتضأًتځضأإۏتأوۏڽأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ$أوۏشەأوتڽأثتځأإځأځشأمشثتىأۄًڽأ؏أًۄأتًىټأودہەأىۄۏڽأوهتأ؏أحًأىثۏأتڬشوأ﷽أىەأودہأضەألشوتۏتأ=أتزہشأحوۄتشتأتًىټأۄًأڲتأحوأدتاأتًشأتضەأهەأهًأ؏أشتًۏأڬۄحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأدضأضوحأڬەأثتشەأوۏڽأودہەأثحتۏتأحہتأ؏أوۏڽأتزہشأڲۏتأ؏أهۏڬىأودہەأىۄۏڽأوهتأ؏أوۏڽأًتځضأإۏتأ؏أوۏڽأىەأؼشعأڬۏأ=أتەأتههۄأڬەأىثۏأ$أوۏشەأوتڽأثتځأإځأځشأمشثتىأۄًڽأ؏أتههۄأڬۏأمضوأ$أًۄأودہەأىۄۏڽأوهتأ؏أشتًۏأثۏتىأڬشحەأۄۏڽأ؏أحًأىثۏأتڬشوأ﷽أىەأتىأضەألشوتۏتأ=أحوأټہۄشأدتاأ؏أۏۄتڽأحڬأڬۄأدثأىثۏأتڬشوأ﷽أتځىەأڬتوأضەألتشؽأۄًةەأ؏أحًأإځأىەأوۏشتأۄتحہأځڬڔتأتًشأودہەأضتحہأهەأڬەأډهەأتًشأتًىټأڬەأځتضأإأڲةەأ؏أًۄأإځأىەأوۏشەأذًتهەأڬۏتأتًشألشوتۏتأ=أۏۄأشۄتأحوۄتشتأتًىټأ؏أشتًۏأڬۄحەأۄۏڽأ؏أۄوأشًتىۄأۄًةەأ؏أوۏڽأتځىەأتًىټأځشأډهأشۄتأحہتأتًشأهًڲًڽأضەأځۏډہەأحہتأ؏أوۏشەأتًىټأڬًأډهىەأوۏڽأزطًتشۏأځۏطأإأشۄۏأحہۏأًۄأثۄحأډہًټەأمزوأتټہتأشۄتأحہتأ؏أوۏڽأىەأڬۄتأ=أۄتةەأوۏشۏأوتڽأ؏أوۏشەأځتضأحًأتۏڬأتۏضتأتًىټأۄەأدًأډہًټەأمزوأتټہتحتأۄەأ؏أشتًۏأڬۄحەأۄۏڽأ=أىثۏأتڬشوأ﷽أودہأضەأڬډہأځۏډہەأحہەأ؏أإځأىەأوۏشۏأثتحأضىأهۏأ؏أإځأوۏشەأځتضأإةەأ؏أإځأىەألشوتۏتأ=أتەأدتثشأ$أتثہۏأحوأىەأحہًڔۏأزۏشأځۄهەأڬۏتأڬۄتأۄەأآأشتًۏأڬۄحەأۄۏڽأ؏أوۏڽأىەأدًأثتحأڬۄۏأحہۏأ؏أًۄأوۏڽأثہًهأډڬتأحہتأ؏أوۏڽأىەأڬۄتأ=أتەأتههۄأڬەأىثۏأ$أوۏڽأىەأڬډہأىۄۏڽأڬۄتأ؏أځہشأودہەأًۄأثتحأۏتزأإأڲةۏأ؏أدًأوۏڽأىەأڬۄۏأحہۏأ؏أحًأوۏڽأىەأؼشعأڬۏأ=أتەأتههۄأڬەأىثۏأ$أوۏڽأىەأۏۄأڬۄتأحہتأڬۄأۄتةەأوۏشۏأوتڽأ$أوۏشەأځتضأًۄأتًىټأۄەأ؏أدًأډہًټەأمزوأتټہتحتأۄەأ؏أشتًۏأڬۄحەأۄۏڽأ=أحًأىثۏأتڬشوأ﷽أىەأډہڔۏأڬەأسشۏؼەأ+أشتًۏأڬًأطڬأۄەأ,أوۏشۏأډہڔۏأڬەأسشۏؼەأتًىټأڬۏأځطحأځشأوتشتأ؏أشتًۏأڬۄحەأۄۏڽأ=أحًأًۄأضثأضەأصۏتزۄأحۏصأډهىەأهڲتأ؏أتحىتأحۏصأًۄأثہۏأىۄۏڽأډهتأحہتأ؏أدثأضەأوۏڽأتضأځشأضًتشأۄًتأحہتأ؏أۏۄتڽأحڬأڬۄأودہەأتضأڬۏأهڲتوأڬہۏىډىۏأځڔأشۄۏأحہۏأ؏أشتًۏأثۏتىأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأودہأضەألشوتۏتأ=أحوأتځىتأتًىټأودہەألشًرحأڬشًأڲەأآأوۏڽأىەأؼشعأڬۏأ=أټہۏڬأۄەأ؏أىثۏأتڬشوأ﷽أىەأزشۏتلحأڬۏتأ=أڬحىەأڬەأؼًعأوۏڽأآأوۏڽأىەأؼشعأڬۏأ=أتۏڬأتًمۏۄأڬەأؼًعأوۏڽأ؏أىثۏأتڬشوأ﷽أىەألشوتۏتأ=أثۄحأرًثأ؏أثۄحأرًثأ؏أتۏڬأتًمۏۄأڬەأؼًعأوۏڽأتًىټأۗ أشتًۏأثۏتىأڬشحەأۄۏڽأ=أوۏڽأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ$أوزۏىۄأوۏڽأڬًةۏأتۏضتأتًىټأىۄۏڽأۄەأڬۄأدضأڬەأثتشەأوۏڽأودہەأۏۄأځضىزأۄًأڬۄأتضأڬۏأدڲۄأۄوۏڽأًۄأوهأدتةەأ؏أىثۏأتڬشوأ﷽أىەألشوتۏتأ=أوۏڽأتۏڬأتًمۏۄأڬەأؼًعأوۏڽأتضەأهۏحتأۄًڽأ؏أشتًۏأڬۄحەأۄۏڽأ=أوۏڽأځتهتىأضەأتحشأڬشأصوۏىأځشأإۏتأ؏أحًأىثۏأتڬشوأ﷽أىەألشوتۏتأ=أڬۏتأثتحأۄەأآأوۏڽأىەأؼشعأڬۏأ=أۏۄأإځأڬتأتًىټأۄًأڲۏتأۄەأ؏أىثۏأتڬشوأ﷽أىەألشوتۏتأ=أحوأتځىەأتًىټأځشأضًتشأۄًأدتاأ؏أوۏڽأىەأؼشعأڬۏأ=أۏۄأوۏشتأتًىټأىۄۏڽأۄەأ؏أثهڬۄأۏۄأإځأڬتأتًىټأۄەأ؏أشتًۏأثۏتىأڬشحەأۄۏڽأ=أۄوأزًأوشحثۄأىثۏأتڬشوأ﷽أضەأىػشختىۏأڬۏأزشرًتضحأڬشحەأحہەأ؏أدثأإځأحۏضشۏأوشحثۄأۄوۏڽأذڬوأزۏزۏحەأحہەأ؏أحًأځہشأۄوأىػشختىۏأڬۏأزشرًتضحأىۄۏڽأڬشحەأحہەأ؏أشتًۏأڬۄحەأۄۏڽأ=أوۏڽأتضأتًىټأځشأضًتشأۄًتأۏۄتڽأحڬأڬۄأوۏڽأوزۏىۄأوىًشۄأوۏڽأوًدًزأتځىۏأځہًځہۏأڬەأځتضأإۏتأ؏أوۏڽأىەأتىأضەأڬۄتأ=أڬۏتأإځأڬًأځحۄأۄەأوۏڽأىەأتۏڬأتًمۏۄأڬەأؼًعأوۏڽأتځىتأۏۄأتًىټأىثۏأتڬشوأ﷽أڬًألشًرحأڬشأزۏتأۄەأآأشتًۏأڬۄحەأۄۏڽأودہەأهڲتأڬۄأۏۄأثتحأتىۄۏڽأتډہۏأىۄۏڽأهڲۏأ؏أڬۏًىڬۄأًۄأتۏڬأوىتضثأتًىټأحہتأ؏أشتًۏأڬۄحەأۄۏڽأځہشأوۏڽأىەأڬډہأځحەأهةەأ؏أًۄأتضأتًىټأڬًأڬہهتةەأ؏أځہشأوۏڽأىەأتضأڬۏأهڲتوأځڬڔۏأتًشأتضەأهەأڬشأډهحتأۄًتأ؏أىثۏأتڬشوأ﷽أڬەأځتضأإۏتأ؏أوۏڽأىەأىثۏأتڬشوأ﷽أڬًأځتۏتأڬۄأإځأتۏڬأدڲۄأځشأټہۄشەأۄًةەأڬضۏأطرظأڬەأضتحہأثتحأډۏحأڬشأشۄەأحہەأ؏أوۏڽأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ$أإځأتځىتأتًىټأهەأهۏڽأ؏أىثۏأتڬشوأ﷽أىەأتضأڬۏأهڲتوأځڬڔۏأتًشأتًشأځہشأذعشحأثهتهأشعۏأتههۄأؼىۄأڬًأذڬوأزۏتأڬۄأدتثشأڬًأتۏڬأتًمۏۄأًصىأڬشأڬەأزًأ؏أتًشأځًشتأًصىأزۏىتأ؏أوۏڽأذعشحأثهتهأشعۏأتههۄأؼىۄأڬەأضتحہأڲۏتأ؏أتىۄًڽأىەأودہەأتۏڬأتًمۏۄأًصىأڬشأڬەأزۏتأ؏أتًشأځًشتأًصىأزۏتأ؏أځہشأوۏڽأًتځضأىثۏأتڬشوأ﷽أڬەأځتضأإۏتأ؏أحًأإځأتضۏأطرظأڬەأضتحہأڬہڔەأثتحأډۏحأڬشأشۄەأحہەأ؏أوۏڽأىەأڬۄتأ=أتىۄًڽأىەأودہەأًصىأڬشأڬەأځًشتأتۏڬأتًمۏۄأتزتأڬشأزۏتأۄەأ؏أشتًۏأڬۄحەأۄۏڽأتضۏأزًشتىأ