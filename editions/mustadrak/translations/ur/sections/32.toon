ألشوتحەأۄۏڽأ=أځہشأًۄأوۏشەأضتحہۏًڽأڬۏأدتىثأوحًدۄأۄًةەأ+أتًشأوۏشەأثتشەأوۏڽأتىأضەأڬۄتأڬۄأتضأثډەأڬًأحوأضودہتاأ,أتىۄًڽأىەأودہەأڬۄتأ=أتەأثډەأ$أحًأتىأڬەأۄوشتۄأىۄۏڽأشۄأضڬحتأۗأوۏڽأىەأڬۄتأ=أوۏڽأتىأڬەأثؽۏشأىۄۏڽأشۄأضڬحتأۗأتضأإزوۏأڬەأضتحہۏًڽأىەأڬۄتأ=أتەألهتڽأ$أۏۄأثډۄأۄەأتًشأتضأڬتأڬًةۏأثہشًضۄأىۄۏڽأۄەأۗأتضأىەأودہەأڬۄتأ=أحوأ+أتځىەأثتشەأوۏڽأ
أتۏڬأزلؼۄأڬتأسڬشأۄەأڬۄأتحًتشأڬەأزىأًۄأىڬهتأ؏أدثأحوتوأهًڲأتضأڬەأځتضأدوؼأۄًأڲةەأحًأتههۄأحؼتهۏٳأڬۏأذوزأًأخىتؤأڬەأثؼزأتىأڬًأىظۏذحأڬشحەأۄًةەأتځىەأغشۏمەأڬەأوغتثمأڲلحڲًألشوتةۏأۗأځہشأضثأضەأإرشأوۏڽأڬۄتأ=أتەأهًڲًأ$أوۏڽأثۄحأثًڔہتأۄًأډڬتأۄًڽأ؏أوۏشۏأۄڋۏتڽأڬوصًشأۄًأډڬۏأۄۏڽأ؏أتًشأوۏشۏأوًحأڬتأًمحأمشۏثأۄەأ/أتًشأؼشظۄأزشتصأضەأتضأڲہشأڬۏأسوۄأزتشۏأوۏڽأىەأتثہۏأحڬأڬضۏأڬًأىۄۏڽأزۏأدثڬۄأۏۄأسوۄأزتشۏأڬضۏأڬًأزۏىتأثۄحأعشًشۏأۄەأۗأحوأتضأثډەأڬەأضتحہأحؼتًىأڬشىتأڬۏًىڬۄأوۏڽأتضأڬًأثەأعششأزۏڬہأشۄتأۄًڽأۗأۏۄأضىأڬشأهًڲأشًىەأهڲأڲةەأ؏أوۏڽأىەأإدأحڬأتۏضتأشًىتأزہًىتأڬثہۏأىۄۏڽأزۏڬہتأحہتأۗأهًڲًڽأىەأ+أتۏڬأزًضشەأإزوۏأڬەأثتشەأوۏڽأڬۄتأ,أتەألهتڽأ$أحوأثًڔہەأۄًأتًشأحوأتڬۏهەأثہۏأۄًأتًشأۄوأىۄۏڽأضودہحەأڬۄأإدأۄوۏڽأدحىۏأحۏشۏأعشًشحأۄەأحوۄۏڽأتضأضەأصۏتزۄأڬثہۏأڬًةۏأځۏطڬطأڬۏأڲةۏأۄًأ؏أتضأإزوۏأىەأڬۄتأ=أحوأودہەأوۏشەأتشتزەأضەأوحأۄټتاأ؏أتضأإزوۏأڬۏأتحثتؼأعشًشۏأۄەأهۏڬىأحوأتضأثډەأڬەأضتحہأثہهتةۏأڬتأوؼتوهۄأڬشىتأحوأۏۄۏأڬشىتأ؏أحوأۏۄۏأڬشىتأۗأوۏڽأىەأڬۄتأ=أوۏڽأحوۄتشەأثؽۏشأىۄۏڽأشۄأضڬحتأۗأتضأىەأڬۄتأ=أتەأضهوتىأ$أحًأىەأوۏشۏأذتهحأزۏڬہأهۏأۄەأىتأآأوۏشەأحوتوأوؼتوهتحأثہۏأزۏڬہأهةەأۄۏڽأۗأوۏڽأضتشتأزىأشًصۄأشڬہحتأۄًڽأتًشأشتحأوۏڽأمۏتوأڬشحتأۄًڽأۗأوۏڽأتځىەأۄوشتۄأصتزأشتۄأثہۏأىۄۏڽأتټہتأضڬحتأتًشأحوأتضأڬۏأغتمحأىۄۏڽأشڬہحەأۄًأۗأوۏڽأىەأڬۄتأ=أوۏڽأحوۄۏڽأىۄۏڽأډہًڔأضڬحتأۗأتضأىەأڬۄتأټہۏڬأۄەأحوأثۄحشأدتىحەأۄًأۗأشتًۏأڬۄحەأۄۏڽأ=أهًڲًڽأىەأڬۄتأ=أتەألهتڽأ$أۄوأتضأثډەأڬەأثتشەأوۏڽأځشۏطتىأۄۏڽأۗأتضأىەأڬۄتأ=أۏۄأتځىتأذتهأثۄحشأدتىحتأۄەأ؏أوۏڽأىەأتضأڬًأحوتوأظًشحأذتهأضەأإڲتۄأڬشأزۏتأۄەأ؏أۏۄأثډۄأتضأضەأځۄهەأوۏشەأوؼتوهتحأزۏڬہأثہۏأډڬتأۄەأۗأوۏڽأىەأڬۄتأ=أوۏڽأتضأضەأتهڲأىۄۏڽأشۄًڽأڲتأۗأشتًۏأڬۄحەأۄۏڽأ=أهًڲًڽأىەأثتزۏزۄأىوأتضأڬًأتهًزتؼأڬۏتأتًشأتضأىەأهًڲًڽأضەأڬۄتأ=أهًڲًأ$أتههۄأحؼتهۏٳأضەأڋشًأتًشأوۏڽأىەأحوۄۏڽأدًأًظۏحأڬۏأۄەأتضأځشأؼوهأځۏشتأشۄًأ؏أتڲشأوۏڽأصىزۄأشۄتأحًأزًثتشۄأإاڽأڲتأتًشأتڲشأوشأڲۏتأحًأثەأطڬأتههۄأحؼتهۏٳأذۏأهتأۏوًحأۄەأ؏أۏۄأڬۄۄأڬشأتضأىەأضثأڬًأضهتوأڬۏتأتًشأًۄتڽأضەأىڬهأځڔتأتًشأوۏڽأثہۏأتضأڬەأۄوشتۄأډهأزۏتأۗ
أتضأىەأودہەأڬۄتأ=أحوأتځىەأڬہتىەأځۏىەأڬەأهةەأڬډہأتطۏتؤأتځىەأضتحہأهەأهًأ؏أ+أوۏڽأىەأڬہتىەأځۏىەأڬۏأحہًڔۏأضۏأډۏصۏڽأتځىەأضتحہأشڬہۏڽأ,أتًشأتضأڬەأۄوشتۄأډهأځڔتأۗأۄوأ+أوىصهأثۄأوىصهأ
أډهحەأشۄەأ؏أوۏڽأتضأڬەأځۏډہەأځۏډہەأحہتأ؏أًۄأوضهضهأتههۄأحؼتهۏٳأڬتأسڬشأڬشأشۄتأحہتأ؏أًۄأىۄأحًأڬضۏأدتىثأحًدۄأڬشحتأحہتأتًشأىۄأڬۄۏڽأټہۄشحتأحہتأ؏أدثأطتوأۄًحۏأحًأًۄأودہەأڬۄحتأ=أتەأضهوتىأ$أحوأىوتصأځڔہأڬشأڬہتىتأًؽۏشۄأڬہتأځۏأڬشأضًأدتاأ؏أتًشأًۄأرًزأضتشۏأشتحأىوتصأوۏڽأوطؽًهأشۄحتأ؏أډهحەأډهحەأۄوأثۏحأتهومزضأځۄىډأڲةەأۗأىڲتۄۏڽأدہڬتةەأ؏أتزثأًأتذحشتوأڬەأضتحہأۄوأوضدزأڬەأزشًتصەأحڬأځۄىډأڲةەأ؏أزشًتصەأځشأتۏڬأتځتۄدأإزوۏأثۏټہتأۄًتأحہتأ؏أتضأىەأڬۄتأ=أتەأتههۄأڬەأثىزەأ$أحوأوۏشەأذتهأڬًأزۏڬہأشۄەأۄًأ؏أحوأودہأځشأڬډہأظزمۄأڬشًأ؏أهۏڬىأًۄأتضأإزوۏأڬۏأدتىثأحًدۄأڬةەأثؽۏشأوضدزأوۏڽأزترهأۄًأڲۏتأ؏أتضأڬەأځۏډہەأځۏډہەأوۏڽأثہۏأوضدزأوۏڽأزترهأۄًأڲۏتأ؏أًۄأوضدزأوۏڽأورحهلأومتوتحأځشأىوتصأځڔہىەأهڲأڲۏتأ؏أځہشأتضأىەأڬۄتأ=أتەأضهوتىأ$أوۏڽأثۄحأؼشظەأضەأضًۏتأىۄۏڽأۄًڽأتًشأىۄأوۏڽأىەأىۏىزأڬتأستةمۄأډڬہتأۄەأتڲشأحوأۏۄأڬشأضڬًأڬۄأدثأضتۏۄألهتڽأومتوأحڬأځۄىډأدتةەأحًأحوأودہەأدڲتأزًأڲەأحًأوۏڽأضًأدتحتأۄًڽأ؏أڬۏًىڬۄأودہەأتضأوضدزأوۏڽأضًىەأڬتأثۄحأطًمأۄەأتًشأتڲشأحوأودہەأىۄۏڽأتټہتأضڬحەأحًأوۏڽأىۄۏڽأضًحتأۗأوۏڽأىەأڬۄتأ=أټہۏڬأۄەأدۏأ$أوۏڽأإځأڬًأدڲتأزًڽأڲتأۗأۏۄأڬۄۄأڬشأًۄأتځىەأغًشأځشأوغوةىأۄًأڬشأضًأڲۏتأ؏أوۏڽأىەأضًډتأڬۄأۏۄأإزوۏأثۄحأؼشظەأضەأضًۏتأىۄۏڽأۄەأ؏أډىزأزىأوۏڽأىەأثہۏأتضأڬەأضتحہأشۄأڬشأتضأڬًأزۏڬہتأۄەأ؏أودہەأإدأتضأڬًأىۄۏڽأتټہتىتأډتۄۏەأحتڬۄأۏۄأتځىۏأىۏىزأځًشۏأڬشأهەأۗأًۄأطرظأځًشەأشتضحەأوۏڽأودہەأًؼػأًأىظۏذحأڬشحتأشۄتأتًشأودہەأثحتحتأشۄتأڬۄأوۏشتأتۏڬأشثأۄەأ؏أتًشأوۏشەأضتوىەأدىحأتًشأزًصرأۄەأ؏أذضتثأڬحتثأۄەأ؏أًۄأإزوۏأدۏضەأتحًتشأڬەأزىأهًڲًڽأڬًأىظۏذحۏڽأڬۏتأڬشحتأحہتأتضۏأغشذأودہەأثہۏأىظۏذحۏڽأڬشحتأشۄتأ؏أتضأىەأودہەأڬۄتأ=أتەأضهوتىأ$أثەأطڬأتههۄأحثتشڬأًأحؼتهۏٳأؼىمشۏثأتۏڬأشضًهأوثؼًخألشوتةەأڲتأ؏أتضأڬتأىتوأ““أتذوزأ‛‛أۄًأڲتأ؏أًۄأحۄوۄأضەأىڬهەأڲتأۗأًۄأؼدوۏأطرظأحہتأ؏أؼشثۏأظذۏذأغًشأځشأىۄۏڽأثًهأځتأشۄتأحہتأ+أحۄتوۄأڬًأحۄوۄأڬۄۄأشۄتأحہتأ,أ؏أتضأىەأثحتۏتأڬۄأتضأڬۏأىطتىۏأۏۄأۄًأڲۏأڬۄأًۄأ““أۄزۏۄأ‛‛أ+أڬۏأډۏصأ
أڬہتأهەأڲتأوڲشأ““أظزمۄأ‛‛أ+أڬۏأډۏصأ,أىۄۏڽأڬہتةەأڲتأ؏أتضأڬەأزًىًڽأڬىزہًڽأڬەأزشوۏتىأوۄشأىثًحأۄًأڲۏأ؏أتًشأتضأىثۏأڬەأػتۄشأۄًىەأڬتأصوتىۄأثتهڬهأمشۏثأۄەأۗأوۏڽأثۄحأثًڔہتأۄًأډڬتأۄًڽأ؏أځحتأىۄۏڽأوۏڽأتضأڬۏأظذثحأضەألۏعۏتثأۄًأځتحتأۄًڽأۏتأىۄۏڽأۗأتڲشأحًأتضأڬًأځتةەأحًأتضأڬۏأحظزۏمأڬشىتأتًشأتضأڬۏأتحثتؼأڬشىتأۗأوۏڽأىەأڬۄتأ=أتڲشأًۄأودہەأحوۄتشتأزۏىأتًشأحوۄتشۏأحؼهۏوتحأډہًڔىەأڬتأذڬوأزەأ؏أ+أحًأڬۏتأحثأثہۏأوۏڽأتضأڬۏأتحثتؼأڬشًڽأآأ
أتضأىەأڬۄتأ=أحوأتضأڬەأڬۄىەأځشأضثأڬډہأډہًڔأزۏىتأڬۏًىڬۄأذمأتضۏأوۏڽأۄەأدًأًۄأذڬوأزەأتًشأتههۄأحؼتهۏٳأڬۏأشعتأتضۏأوۏڽأۄەأدًأًۄأڬۄەأۗأ+أذعشحأضهوتىأ,ألشوتحەأۄۏڽأ=أ+أًۄأإزوۏأدڲتىەأڬۏأسوۄأزتشۏأودہەأضًىځأڬشأضًأڲۏتأ
أتثہۏأصۏتزۄأًمحأىۄۏڽأڲصشتأحہتأڬۄأًۄأتههۄأحؼتهۏٳأڬتأسڬشأڬشحەأۄًةەأۄڔثڔتأڬشأتټہأثۏټہتأ؏أتضأىەأودہەأڬۄتأ=أتەأضهوتىأ$أضتۏۄأحًأتضأدڲۄأضەأإڲەأڲصشأڲۏتأۄەأتًشأحوأىەأودہەأدڲتۏتأڬۏًڽأىۄۏڽأآأوۏڽأىەأڬۄتأ=أحًأىەأودہەأثحتۏتأحہتأڬۄأحوأتحىەأؼشظەأضەأضًةەأىۄۏڽأۄًأتًشأډىزأشًصأحۏشەأۄوشتۄأشۄأڬشأتضأڬتأىػتشۄأوۏڽأىەأرًزأتځىۏأإىڬہًڽأضەأثہۏأڬشأهۏتأۄەأ؏أوۏڽأىەأضًډتأڬۄأإدأإځأڬۏأىۏىزأځًشۏأۄًأدتةەأ؏أتضأىەأتههۄأحؼتهۏٳأڬۏأذوزأثۏتىأڬۏأ؏أتټہأڬشأڬہڔتأۄًتأتًشأوضدزأضەأثتۄشأىڬهتأ؏أتضأڬەأځۏډہەأوۏڽأثہۏأوضدزأضەأثتۄشأإأڲۏتأ؏أزشًتصەأځشأًۄأتځتۄدأإزوۏأتثہۏأحڬأثۏټہتأۄًتأحہتأ؏أدثأۏۄأإزوۏأتضأڬەأمشۏثأضەأڲصشتأحًأتضأىەأڬۄتأ=أتەأتههۄأڬەأثىزەأ$أحوأدثأتىزشأڲةەأ؏أوۏڽأىەأتضأًمحأثہۏأضًتهأڬۏتأحہتأهۏڬىأحًأىەأودہەأڬډہأىۄۏڽأزۏتأتثأحوأثتۄشأإأشۄەأۄًأ؏أتثأځہشأوۏڽأىەأضًتهأڬۏتأ؏أتثأثہۏأحوأىەأودہەأڬډہأىۄۏڽأزۏتأۗأًۄأًۄۏڽأشڬأڲۏتأتًشأڬډہأزۏشأزۏڬہحتأشۄتأڬۄأڬًةۏأطرظأتضەأزۏڬہأحًأىۄۏڽأشۄتأ+أدثأتضأڬًأۏمۏىأۄًأڲۏتأڬۄأڬًةۏأىۄۏڽأزۏڬہأشۄتأحًأ,أًۄأتضأوتىڲىەأًتهەأڬەأمشۏثأۄًتأتًشأتضەأڬۄتأ=أتځىتأۄتحہأوۏشۏأغشلأثڔہتةۏەأ؏أتضأىەأتځىتأۄتحہأثڔہتۏتأ؏أتضأىەأڬۄتأ““أثضوأتههۄأ‛‛ۗأۏۄأهلػأضىحەأۄۏأًۄأإزوۏأۏًڽأتټہأڬشأڬہڔتأۄًتأدۏضەأًۄأشضۏأضەأثىزہتأۄًتأ؏أتثہۏأڬہهتأۄًأ؏أتًشأتضأوۏڽأڬًةۏأؼۏثأىۄۏڽأحہتأۗأځہشأۏۄأطرظأډهأزۏتأ؏أتثأثہۏأۏۄأىۄأڬضۏأڬۏأغشلأحًدۄأڬشحتأتًشأىۄأڬضۏأڬەأځتضأڬہڔتأۄًحتأ؏أتضأتځتۄدأإزوۏأىەأودہەأڬۄتأ=أتەأثډەأ$أوۏشەأڬځڔەأتټہتأهًأتًشأودہەأڲہشأحڬأډہًڔأإاأ+أإځألشوتحەأۄۏڽأ
