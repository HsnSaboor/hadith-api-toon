{"hadithnumber": "2270", "text": "ابوہریرہ رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جب زمانہ قریب ہو جائے"}
{"hadithnumber": "2271", "text": "عبادہ بن صامت رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”مومن کا خواب نبوت"}
{"hadithnumber": "2272", "text": "انس بن مالک رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”رسالت اور نبوت کا سلس"}
{"hadithnumber": "2273", "text": "عطاء بن یسار مصر کے ایک آدمی سے روایت کرتے ہیں، وہ کہتے ہیں کہ  میں نے ابو الدرداء رضی الله عنہ سے"}
{"hadithnumber": "2274", "text": "ابو سعید خدری رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”سچے خواب وہ ہیں ج"}
{"hadithnumber": "2275", "text": "عبادہ بن صامت رضی الله عنہ سے روایت ہے کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم سے اللہ تعالیٰ کے آی"}
{"hadithnumber": "2276", "text": "عبداللہ بن مسعود رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جس نے مجھے خوا"}
{"hadithnumber": "2277", "text": "ابوقتادہ رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اچھے خواب اللہ کی طرف"}
{"hadithnumber": "2278", "text": "ابورزین عقیلی رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”مومن کا خواب نبوت ک"}
{"hadithnumber": "2279", "text": "ابورزین رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”مسلمان کا خواب نبوت کا"}
{"hadithnumber": "2280", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”خواب تین قسم کے ہوتے ہیں"}
{"hadithnumber": "2281", "text": "علی رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جو شخص جھوٹا خواب بیان کرے، قی"}
{"hadithnumber": "2282", "text": "اس سند سے بھی  علی رضی الله عنہ نبی اکرم صلی اللہ علیہ وسلم کے واسطہ سے اسی جیسی حدیث روایت کرتے ہیں"}
{"hadithnumber": "2283", "text": "عبداللہ بن عباس سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جو شخص جھوٹا خواب بیان کرے ت"}
{"hadithnumber": "2284", "text": "عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا: ”میں س"}
{"hadithnumber": "2285", "text": "ابوامامہ بن سہل بن حنیف رضی الله عنہما بعض صحابہ سے روایت کرتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم ن"}
{"hadithnumber": "2286", "text": "اس سند سے  ابو سعید خدری رضی الله عنہ نبی اکرم صلی اللہ علیہ وسلم سے اسی جیسی اور اسی معنی کی حدیث ر"}
{"hadithnumber": "2287", "text": "ابوبکرہ رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے ایک دن فرمایا: ”تم میں سے کس نے خوا"}
{"hadithnumber": "2288", "text": "ام المؤمنین عائشہ رضی الله عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم سے ورقہ  ( ورقہ بن نوفل )"}
{"hadithnumber": "2289", "text": "عبداللہ بن عمر رضی الله عنہما سے  نبی اکرم صلی اللہ علیہ وسلم کے اس خواب کے بارے میں مروی ہے جس میں"}
{"hadithnumber": "2290", "text": "عبداللہ بن عمر رضی الله عنہ سے  نبی اکرم صلی اللہ علیہ وسلم کے خواب کے بارے میں روایت ہے، آپ صلی الل"}
{"hadithnumber": "2291", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”آخر وقت میں مومن کے خواب"}
{"hadithnumber": "2292", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”میں نے خواب میں دیکھا کہ"}
{"hadithnumber": "2293", "text": "عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  ابوہریرہ رضی الله عنہ بیان کرتے تھے: ایک آدمی نے نبی اک"}
{"hadithnumber": "2294", "text": "سمرہ بن جندب رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم جب ہمیں فجر پڑھا کر فارغ ہوتے"}
