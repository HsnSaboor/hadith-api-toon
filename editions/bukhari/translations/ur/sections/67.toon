{"hadithnumber": "5224", "text": "ہم سے محمود بن غیلان نے بیان کیا، کہا ہم سے ابواسامہ نے بیان کیا، کہا ہم سے ہشام بن عروہ نے بیان کیا"}
{"hadithnumber": "5225", "text": "ہم سے علی بن عبداللہ مدینی نے بیان کیا، کہا ہم سے اسماعیل بن علیہ نے، ان سے حمید نے، ان سے انس نے بی"}
{"hadithnumber": "5226", "text": "ہم سے محمد بن ابی بکر مقدمی نے بیان کیا، انہوں نے کہا ہم سے معتمر بن سلیمان نے بیان کیا، انہوں نے کہ"}
{"hadithnumber": "5227", "text": "ہم سے عبدان نے بیان کیا، کہا ہم کو عبداللہ بن مبارک نے خبر دی، انہیں یونس نے، انہیں زہری نے، کہا کہ"}
{"hadithnumber": "5228", "text": "ہم سے عبید بن اسماعیل نے بیان کیا، کہا ہم سے ابواسامہ نے بیان کیا، ان سے ہشام نے، ان سے ان کے والد ن"}
{"hadithnumber": "5229", "text": "مجھ سے احمد بن ابی رجاء نے بیان کیا، کہا ہم سے نضر بن شمیل نے بیان کیا، ان سے ہشام بن عروہ نے، کہا ک"}
{"hadithnumber": "5230", "text": "ہم سے قتیبہ بن سعید نے بیان کیا، کہا ہم سے لیث بن سعد نے بیان کیا، ان سے ابن ابی ملیکہ نے اور ان سے"}
{"hadithnumber": "5231", "text": "ہم سے حفص بن عمر حوضی نے بیان کیا، کہا ہم سے ہشام بن عروہ نے بیان کیا، ان سے قتادہ نے اور ان سے انس"}
{"hadithnumber": "5232", "text": "ہم سے قتیبہ بن سعید نے بیان کیا، کہا ہم سے لیث بن سعد نے بیان کیا، ان سے یزید بن ابی حبیب نے، ان سے"}
{"hadithnumber": "5233", "text": "ہم سے علی بن عبداللہ مدینی نے بیان کیا، کہ ہم سے سفیان بن عیینہ نے بیان کیا، ان سے عمرو بن دینار نے"}
{"hadithnumber": "5234", "text": "ہم سے محمد بن بشار نے حدیث بیان کی، ان سے غندر نے حدیث بیان کی، ان سے شعبہ نے حدیث بیان کی، ان سے ہش"}
{"hadithnumber": "5235", "text": "ہم سے عثمان بن ابی شیبہ نے بیان کیا، کہا ہم سے عبدہ بن سلیمان نے بیان کیا، ان سے ہشام بن عروہ نے، ان"}
{"hadithnumber": "5236", "text": "ہم سے اسحاق بن ابراہیم حنظلی نے بیان کیا، ان سے عیسیٰ بن یونس نے بیان کیا، ان سے اوزاعی نے، ان سے زہ"}
{"hadithnumber": "5237", "text": "ہم سے فروہ بن ابی المغراء نے بیان کیا، کہا ہم سے علی بن مسہر نے بیان کیا، ان سے ہشام بن عروہ نے، ان"}
{"hadithnumber": "5238", "text": "ہم سے علی بن عبداللہ نے بیان کیا، کہا ہم سے سفیان ثوری نے بیان کیا، کہا ہم سے زہری نے، ان سے سالم نے"}
{"hadithnumber": "5239", "text": "ہم سے عبداللہ بن یوسف تینسی نے بیان کیا، کہا ہم کو امام مالک رحمہ اللہ نے خبر دی، انہیں ہشام بن عروہ"}
{"hadithnumber": "5240", "text": "ہم سے محمد بن یوسف فریابی نے بیان کیا، کہا ہم سے سفیان ثوری رحمہ اللہ نے بیان کیا، ان سے منصور بن مع"}
{"hadithnumber": "5241", "text": "ہم سے عمر بن حفص بن غیاث نے بیان کیا، کہا ہم سے ہمارے والد نے بیان کیا، ان سے اعمش نے بیان کیا، کہا"}
{"hadithnumber": "5242", "text": "مجھ سے محمود بن غیلان نے بیان کیا، کہا ہم سے عبدالرزاق نے، کہا ہم کو معمر نے خبر دی، انہیں عبداللہ ب"}
{"hadithnumber": "5243", "text": "ہم سے آدم بن ابی ایاس نے بیان کیا، کہا ہم سے شعبہ نے بیان کیا، کہا ہم سے محارب بن دثار نے بیان کیا،"}
{"hadithnumber": "5244", "text": "ہم سے محمد بن مقاتل مروزی نے بیان کیا، کہا ہم کو عبداللہ بن مبارک نے خبر دی، کہا ہم کو عاصم بن سلیما"}
{"hadithnumber": "5245", "text": "ہم سے مسدد بن مسرہد نے بیان کیا، ان سے ہشیم بن بشیر نے، ان سے سیار بن دروان نے، ان سے عامر شعبی نے ا"}
