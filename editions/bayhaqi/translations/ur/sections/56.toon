17609,"أتثًتهۄۏخوألشوتحەأۄۏڽأڬۄأؼمثۄأثىأؼتوشأڬًأڬۄتأڲۏتأڬۄأۄوتشتأتۏڬأځڔًضۏأۄەأدًأطشتثأځۏحتأۄەأتًشأۏۄأۏۄأڬشحتأۄەأۗألشوتۏتأ=أوۏڽأىەأىثۏأ﷽أضەأضىتأدًأڬضۏأڬۏأځشزەأًتهۏأثتحأزۏڬہەأتًشأتضأڬۏأځشزۄأځًطۏأڬشەأحًأًۄأتۏضەأۄەأدۏضەأتضأىەأمثشأضەأصىزۄأزشڲًشأڬًأصىزۄأڬشأزۏتأۗ

[تخریج]: [ ضعیف ]"
17610,حمزوأمثهۄ
17611,"أؼثزتههۄأثىأؼوشًأثىأؼتظأڬۄحەأۄۏڽأڬۄأىثۏأ﷽أىەألشوتۏتأ=أتځىەأزشوۏتىأذزًزأڬًأوؼتلأڬشأهًأتڲشأودہأحڬأثتحأځۄىډأڲةۏأحًأذزأًتدثأۄًأڲۏأۗ

[تخریج]: [ ضعیف ]"
17612,أحمزوأثشموأ4:85:
17613,أحمزوأثشموأ4:85:
17614,"أتثًودصتٗۄأڬۄحەأۄۏڽأڬۄأدضأضەأڬًةۏأڲىتۄأۄًأۄوتشەأځتضأهتاأۗأۄوأتضەأځتڬأڬشۏڽأڲەأۗأتۏڬأمًوأإةۏأتضەأتىہًڽأىەأوتشتأحًأذعشحأضهوتىألتشضۏأؽظۄأڬۏأذتهحأوۏڽأإةەأتًشألشوتۏتأ=أڬۏتأتههۄأىەأحًثۄأڬًأڬًةۏأډۏصأثىتۏتأۄەأآأڬۄتأ=أىۄۏڽأۗألشوتۏتأ=أڬًڔتأځہۏىڬأزًأتههۄأڬەأڋتهەأۄًةەأځشزەأڬًأىۄأڬہًهًأۗأؼڬشوۄأڬۄحەأۄۏڽأڬۄأؼوتشأثىأۏتضشأڬۏأڬًةۏأډًشۏأۄًأڲةۏأحًأډًشأڬًأځڬڔأهۏتأهۏڬىأإځأىەأتضەأوؼتلأڬشأزۏتأتًشأڬۄحەأۄۏڽأڬۄأتثىأؼثتضأڬەأځتضأثہۏأتۏڬأؽهتوأډًشأڬًأهتۏتأڲۏتأحًأإځأىەأثہۏأتضەأډہًڔأزۏتأۗ

[تخریج]: [ ضعیف ]"
17615,"أوۏضشۄأڬۄحەأۄۏڽأڬۄأتۏڬأوتڽأثۏټتأذعشحأؼهۏأڬەأځتضأإةەأتًشأڬۄىەأهڲەأ=أتضأىەأوۏشەأرتًىزأڬًأمحهأڬۏتأۄەأتًشأًۄأثۏټتأڬۄىەأهڲتأ=أوۏشتأؽهتوأوۏشۏأوتڽأځشأًتمؼأۄًتأۄەأحًأذعشحأؼهۏأىەألشوتۏتأ=أحوأزًىًڽأثشثتزأۄًأڲةەأۗأتڲشأحًأضډۏأۄەأحًأۄوأتضەأمحهأڬشۏڽأڲەأۗأتڲشأحۏشتأثۏټتأضډتأۄەأحًأحدہەأشدوأۗأځہشأذعشحأؼهۏأىوتصأڬەأهۏەأډهەأڲةەأحًأتضأهڔڬەأىەأتځىۏأوتڽأڬًأڬۄتأڬۄأإځأڬتأڬۏتأرۏتهأۄەأڬۄأودہەأمحهأڬۏتأدتةەأۏتأحدہەأشدوأآأًۄأزًىًڽأډهەأڲةەأ؏أدثأإځأىوتصأضەألتشؽأۄًأڬشأإةەأتًشأتىأڬەأثتشەأوۏڽأځًډہتأحًأثحتۏتأڲۏتأڬۄأًۄأډهەأڲةەأۄۏڽأۗ

[تخریج]: [ ضعیف ]"
17616,"أذعشحأؼتةطۄألشوتحۏأۄۏڽأڬۄأمشۏطأىەأتشتزۄأڬۏتأڬۄأورصًوۏۄأؼًشحأدضأىەأډًشۏأڬشأهۏأحہۏأڬەأثتشەأوۏڽأڬًةۏأىثۏأ﷽أضەأثتحأڬشەأحًألۏظهۄأۄًتأڬۄأتحىۏأۄوحأظشلأتضتوۄأثىأصۏزأۄۏأڬشأضڬحەأۄۏڽأ؏أًۄأوذثًثأشضًهأۄۏڽأحًأذعشحأتضتوۄأىەأإځأضەأثتحأڬۏأحًأإځأىەألشوتۏتأ=†أتەأتضتوۄأ$أڬۏتأتههۄأڬۏأذزًزأوۏڽأحًأضلتشطأڬشأشۄتأۄەأآ‟أځہشأإځأىەأرغثۄأزۏحەأۄًةەألشوتۏتأ=أحوأضەأځۄهەأهًڲأتضۏأهۏەأۄهتڬأۄًةەأڬۄأتىأوۏڽأڬًةۏأتوۏشأډًشۏأڬشحتأحًأتضەأډہًڔأزۏحەأتًشأؽشۏثأځشأذزأمتةوأڬشحەأۗأتههۄأڬۏأمضوأ$أتڲشألتغوۄأثىحأوذوزأ﷽أثہۏأډًشۏأڬشحۏأحًأوۏڽأتضأڬەأثہۏأۄتحہأڬتټأزۏحتأۗ

[تخریج]: [ صحیح ]"
17617,"أۏذۏۏأثىأشتطزأزوطمۏأڬۄحەأۄۏڽأڬۄأذعشحأؼثزتههۄأثىأؼوشأشعۏأتههۄأؼىۄوتأۄوتشەأځتضأإأڬشأثۏټہەأۗأۄوأرتوًطأحہەأحًأإځأشعۏأتههۄأؼىۄوتأىەألشوتۏتأ=أرتوًطأڬۏًڽأۄًأآأثًهحەأڬۏًڽأىۄۏڽأ$أحوأضثذتىأتههۄأًثذوزۄأڬۏًڽأىۄۏڽأڬۄحەأۗأۏۄأتۏڬأزضأتًشأزضأضًأتًشأضًأۄصتشأڬەأثشتثشأۄەأتًشأدحىتأصۏتزۄأځڔہًأڲەأتههۄأصۏتزۄأڬشحەأدتةۏڽأڲەأۗأوۏڽأىەأىثۏأ﷽أضەأضىتأ=†أدضأڬۏأطلتؼحأذزًزأتههۄأوۏڽأضەأڬضۏأذزأڬەأؼهتًۄأوۏڽأذتةهأۄًأڲةۏأۗأتضأىەأتځىەأوؼتوهەأوۏڽأتههۄأضەأعزأڬۏأۄەأتًشأدًأوشأڲۏتأتًشأتضأځشأمشعأۄەأحًأًۄأىۏڬۏًڽأتًشأثشتةۏًڽأڬۏأظًشحأوۏڽأتزتأۄًأڲتأتًشأدًأڬضۏأثتغهأڬەأهۏەأهڔحتأۄەأتًشأًۄأدتىحتأثہۏأۄەأحًأًۄأۄوۏطۄأتههۄأڬۏأىتشتعڲۏأوۏڽأشۄحتأۄەأۗأدثأحڬأڬۄأتضأضەأځۏډہەأىۄأۄټأدتةەأتًشأدًأڬضۏأوًوىأڬەأهۏەأىتذمأثتحأڬۄحتأۄەأحًأتههۄأتضەأدۄىوأڬەأڬۏډڔأوۏڽأڋتهۏڽأڲەأۗأۏۄتڽأحڬأڬۄأًۄأىڬهأدتةەأڲتأدًأتضأىەأڬۄتأۗ

[تخریج]: [ صحیح ]"
17618,"أتثىأؼوشأشعۏأتههۄأؼىۄوتألشوتحەأۄۏڽأڬۄأىثۏأ﷽أىەألشوتۏتأتًشأظذتثۄأڬشتوأثۏټہەأۄًةەأحہەأحوأڬډہأثًهحەأڬۏًڽأىۄۏڽأۗأدضأىەأضثذتىأتههۄأًثذوزۄأڬۄتأتههۄأتضأڬەأهۏەأزضأىۏڬۏتڽأهڬہأزۏحتأۄەأتًشأدضأىەأزضأزضأوشحثۄأڬۄتأتضأڬەأضًأتًشأدضأىەأضًأوشحثۄأڬۄتأتضأڬەأهۏەأۄصتشأىۏڬۏتڽأهڬہأزۏحتأۄەأۗأدًأصۏتزۄأڬشەأڲتأتههۄأثہۏأصۏتزۄأڬشأزەأڲتأتًشأدًأتههۄأضەأتضحؽلتشأڬشەأڲتأتههۄأتضەأثرطأزەأڲتأدضأڬۏأطلتؼحأذزًزأتههۄأوۏڽأضەأڬضۏأذزأڬەأؼهتًۄأوۏڽأذتةهأۄًأڲةۏأحًأتضأىەأتځىەأوؼتوهەأوۏڽأتههۄأضەأعزأڬۏأتًشأدًأوشأڲۏتأتًشأتضأځشأمشعأۄەأحًأًۄأىۏڬۏًڽأتًشأثشتةۏًڽأڬۏأظًشحأوۏڽأتزتأۄًأڲتأتًشأدًأڬضۏأثتغهأڬەأهۏەأهڔحتأۄەأتًشأًۄأدتىحتأثہۏأۄەأحًأًۄأۄوۏطۄأتههۄأڬۏأىتشتعڲۏأوۏڽأشۄحتأۄەأدثأحڬأڬۄأتضأضەأځۏډہەأىۄأۄټأدتةەأتًشأدًأڬضۏأوًوىأڬەأهۏەأىتذمأثتحأڬۄحتأۄەأحًأتههۄأتضەأدۄىوأڬەأڬۏډڔأوۏڽأڋتهۏڽأڲەأۏۄتڽأحڬأڬۄأًۄأىڬهأدتةەأڲتأ؏أدًأتضأىەأڬۄتأ=أدًأزىۏتأوۏڽأتځىەأثډەأڬتأتىڬتشأڬشەأڲتأتضأڬًأشضًتأڬشىەأڬەأهۏەأحًأتههۄأتضەأحوتوأورهًمتحأڬەأضتوىەأمۏتوحأڬەأزىأشضًتأڬشەأڲتأۗ

[تخریج]: [ ضعیف ]"
17619,أذعشحأصثۏشأثىأؼًتوألشوتحەأۄۏڽأ=أذزًزأوۏڽأضلتشطأڬشًأدثأحڬأثتزطتۄأحڬأوؼتوهۄأىۄأځۄىډتأۄًأۗأتًشأدثأثتزطتۄأحڬأوؼتوهۄأځۄىډأدتةەأحًأځہشأضلتشطأىۄأڬشًأۗ
17620,"ألشتلظۄأذىلۏأڬۄحەأۄۏڽأڬۄأذعشحأصثۏشأشعۏأتههۄأؼىۄأۄوتشەأځتضأضەأڲصشەأ؏أۄوأىەأتۏڬأډًشأڬًأځڬڔتأۄًتأحہتأۗأإځأىەأتضأڬۏأضلتشطأڬۏأڬۄأتضەأډہًڔأزًأۗأۄوأىەأڬۄتأ=أتەأتثًؼثزتههۄأ$أإځأۄوۏڽأډہًڔىەأڬتأڬۄۄأشۄەأۄًأ$ألشوتۏتأ=أضهغتىأضەأځۄهەأۏۄأڬۄتأدتأضڬحتأۄەأۗأتڲشأضهغتىأحڬأثتحأډهۏأڲةۏأځہشأڬًةۏأوؼتلۏأىۄۏڽأۗأځہشأتههۄأۄۏأډتۄەأحًأتضەأوؼتلأڬشەأۗ

[تخریج]: [ صحیح ]"
17621,"أذعشحأتىضألشوتحەأۄۏڽأڬۄأوۏڽأىثۏأ﷽أڬەأضتحہأحہتأڬۄأتۏڬأطرظأإۏتأتًشأڬۄتأ=أتەأتههۄأڬەأشضًهأ﷽أ$أوۏڽأذزأڬًأځۄىډأڲۏتأۄًڽأودہأځشأذزأمتةوأڬۏدةەأۗأإځأ﷽أىەأتضأضەأڬډہأىۄأځًډہتأڬۄأىوتصأڬتأًمحأۄًأڲۏتأحًأتضأىەأثہۏأىثۏأ﷽أڬەأضتحہأىوتصأځڔہۏأۗأدثأىوتصأضەألتشؽأۄًةەأحًأًۄأطرظأځہشأڬہڔتأۄًأڲۏتأتًشأځۄهۏأثتحأزۄشتةۏأحًأإځأ﷽أىەألشوتۏتأ=أڬۏتأحًأىەأۄوتشەأضتحہأىوتصأىۄۏڽأځڔہۏأآأڬۄتأ=أدۏأۄتڽأحًألشوتۏتأ=أتههۄأىەأحۏشەأڲىتۄأڬًأوؼتلأڬشأزۏتأۗ

[تخریج]: [ صحیح ]"
17622,"أذعشحأتثًۄشۏشۄألشوتحەأۄۏڽأڬۄأىثۏأ﷽أىەألشوتۏتأ=أثۄحأصۏتزۄأڲوتىأضەأثډًأ؏أثۏطڬأڲوتىأدہًټۏأثتحأۄەأۗأىۄأدتضًضۏأڬشًأىۄأڬضۏأڬۏأټًۄأهڲتاأتًشأىۄأڬضۏأضەأومتثهۄأڬشًأۗأىۄأذضزأڬشًأتًشأىۄأثؽعأڬشًأتًشأىۄأتۏڬأزًضشەأضەأوىۄأوًڔًأتًشأتههۄأڬەأثىزًأ$أثہتةۏأثہتةۏأۄًأدتاأۗ

[تخریج]: [ صحیح ]"
17623,"أذعشحأوؼتًۏۄأڬۄحەأۄۏڽأ=أوۏڽأىەأىثۏأ﷽أضەأضىتأ؏ألشوتۏتأ=†أتڲشأحًأهًڲًڽأڬەأؼۏثأحهتطأڬشحتأځہشەأڲتأحًأحًأىەأتىأڬًأثشثتزأڬشأزۏتأۏتأتىأڬًأرشتثأڬشىەأڬۏأڬًططأڬۏأۗ‟أتثًزشزتؤأڬۄحەأحہەأڬۄأوؼتًۏۄأشعۏأتههۄأؼىۄأىەأىثۏأ﷽أضەأۏۄأڬهوۄأضىتأڬۄأتههۄأىەأتضەأتضأڬەأضتحہأىلؼأزۏتأۗ

[تخریج]: [ صحیح ]"
17624,"أتثًتوتوۄأىثۏأ﷽أضەأىمهألشوتحەأۄۏڽأڬۄأدثأتوتوأهًڲًڽأڬەأؼۏثأحهتطأڬشىەأهڲەأڲتأحًأتىہۏڽأرشتثأڬشأزەأڲتأۗ

[تخریج]: [ ضعیف ]"
17625,"أؼثزتهشذوىأثىأؼًلأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأتۏڬأشتحأوۏڽأذعشحأؼوشأشعۏأتههۄأؼىۄأڬەأضتحہأوزۏىۄأوۏڽأځۄشۄأزەأشۄتأحہتأحًأۄوأىەأتۏڬأڲہشأوۏڽأډشتؽأڬۏأشًطىۏأزۏڬہۏأۗأدثأۄوأڲہشأڬەأزشًتصەأڬەأزشوۏتىأوۏڽأځۄىډەأحًأتىأڬۏأإًتصأثهىزأتًشأرشتثأحہۏأۗأذعشحأؼوشأىەأوۏشتأۄتحہأځڬڔتأتًشأڬۄتأ=أدتىحەأۄًأڬضأڬتأڲہشأۄەأآأوۏڽأىەأڬۄتأ=أىۄۏڽألشوتۏتأ=أشثۏؼۄأثىأتوۏۄأثىأرهلأڬتأۗأًۄأتضأًمحأطشتثأځۏأشۄەأۄۏڽأۗأإځأڬۏأڬۏتأشتةەأۄەأ؏أڬۏتأڬۏتأدتةەأآأحًأؼثزتهشذوىأىەأڬۄتأ=أۄوأىەأتههۄأڬۏأوىؼأڬشزۄأډۏصأڬتأتشحڬتثأڬۏتأۄەأ؏أ®~أًّهّتأحّدّضّٔضًْٕتأ¾أ^أتهذدشتحأ45أ`أۄوأىەأدتضًضۏأڬۏأۄەأحًأذعشحأؼوشأًتځضأإأڲةەأتًشأتىہۏڽأډہًڔأزۏتأۗ

[تخریج]: [ صحیح ]"
17626,"أصۏزأثىأًۄثأڬۄحەأۄۏڽأڬۄأذعشحأؼثزتههۄأڬًأڬۄتأڲۏتأڬۄألهتڽأڬۏأزتڔہۏأضەأطشتثأټځڬأشۄۏأحہۏأۗأإځأىەأزۏڬہتأآألشوتۏتأ=أتههۄأىەأۄوۏڽأدتضًضۏأضەأوىؼأڬۏتأۄەأدثأػتۄشأۄًأڲتأحًأځڬڔأهۏڽأڲەأۗ

[تخریج]: [ ضعیف ]"
17627,أحمزوأثشموأ4:57<
17628,أحمزوأثشموأ4:57<
17629,"أتوتوأطتلؼۏألشوتحەأۄۏڽأڬۄأ®سًۏأتهۄۏةتح¾أضەأوشتزأًۄأۄۏڽأدًأوؼشًلأثتهطشأىۄأۄًڽأۗ

[تخریج]: [ صحیح ۔ للشافعی ]"
17630,"ؼشًۄأثىأصثۏشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأدثأذعشحأتثًثڬشأىەأرتهزأثىأًهۏزأشعۏأتههۄأؼىۄأڬًأوشحزۏىأڬۏأغشلأوحًدۄأڬۏتأحًأهًڲًڽأىەأتىأوۏڽأؼۏثأىڬتهەأحًأتىأڬەأضتحہأتثًثڬشأشعۏأتههۄأؼىۄأثہۏأىڬهەأۗأدثأوزۏىۄأضەأسۏأتهمظۄأىتوۏأدڲۄأځشأځۄىډەأدًأوزۏىۄأضەأ5أثشۏزأڬەألتظهەأځشأۄەأحًأًۄتڽأحوتوأهطڬشأدوؼأۄًةەأتًشأتىأضەأؼۄزأهۏتأتًشأتىظتشأځشأختثحأثىأمۏضأثىأطوتضأڬًأتًشأځًشۏأدوتؼحأځشأرتهزأثىأًهۏزأڬًأتوۏشأومششألشوتۏتأتًشأذڬوأزۏتأڬۄأځۄهەأغهۏذۄأثىأرًۏهزأتضزۏأڬەأومتثهەأوۏڽأختثحأمزوأشۄىتأۗأځہشأتضأضەألتشؽأۄًأڬشأثىًأحوۏوأڬۏأصوۏىأڬۏأغشلأثڔہىتأۗأتىأڬًأوؽهًثأڬشأڬەأثتمۏأهًڲأرتهزأضەأرۏثشأوۏڽأوهۏڽأۗأذعشحأرتهزأشعۏأتههۄأؼىۄأڬۏأغهۏذۄأضەأدىڲأثىًأتضزأڬەأځتىۏأځشأۄًةۏأۗأدضأڬتأىتوأمغىأحہتأتًشأتضأڬەأضتحہأثىًألصتشۄأضەأؼۏۏىۄأثىأثزشأ:33أهًڲًڽأڬەأضتحہأحہەأۗأدثأدىڲأثہڔأڲةۏأحًأغهۏذۄأڬەأځتضأإةەأتًشأځًډہتأ=أحۏشتأثتځأىۄأۄًأ؏أڬۏتأتضأڬەأثؼزأثہۏألشطحۄأدثشتةۏهأإۏتأۄەأآأڬۄتأ=أىۄۏڽأۗأځہشأزًثتشۄأځًډہتأحًأڬۄتأ=أۄتڽأډڬۏأڬۏأغشذأإًتصأحہۏأتًشأتۏضۏأثتحأدضأڬًأحًأىۄۏڽأثہًهأضڬحتأحًألشوتۏتأ=أوۏشتأرۏتهأۄەأڬۄأحۏشەأهۏەأتۏضۏأثتحأۄًأڲۏأدضەأحًأثہًهأىۄۏڽأضڬەأڲتأتًشأڬۄتأ=أتەأثىًألصتشۄأ$أۏۄأدہًټتأۄەأ؏أتځىتأڬتوأڬشًأۗطۏرألشوتحەأۄۏڽأڬۄأڬحتثأمحتهأتۄهأتهثؽۏأوۏڽأۄوأۏۄأضثأحلظۏهتَأثۏتىأڬشأإةەأۄۏڽأۗ

[تخریج]: [ صحیح ]"
17631,"أوذوزأثىأوًضۏٳأثىأوذوزأحۏوۏأتځىەأًتهزأضەأشًتۏحأڬشحەأۄۏڽأڬۄأدثأغهۏذۄأڬەأهطڬشأوۏڽأثہڲزڔأوډأڲةۏأحًأغهۏذۄأطتوأثہتڲأڲۏتأۗأدثأرهتلحأؼوشأوۏڽأًۄأوڬۄأًتځضأإۏتأحًأذعشحأؼوشأىەألشوتۏتأ=أتەأغهۏذۄأ$أحًأىەأزًأظتهذأإزوۏًڽأؼڬتطۄأثىأوذظىأتًشأختثحأثىأتمشوأڬًأطۄۏزأڬۏتأۄەأۗأتضأهۏەأودہەأحدہأضەأوذثحأىۄۏڽأحًأتضأىەأدًتثأزۏتأ=أتەأؼوشأ$أتههۄأىەأتىأزًىًڽأڬًأوۏشەأۄتحہًڽأؼصحأثرطۏأتًشأودہەأتىأڬەأۄتحہًڽأشضًتأۄًىەأضەأثډتأهۏتأۗأضتشەأڲہشأوذثحأځشأىۄۏڽأثىتةەأڲةەأ؏أۄتڽأوظتلذۄأدًأزًأزطوىأثہۏأوظتلذۄأڬشأهۏحەأۄۏڽأۗأتضأڬەأثؼزأغهۏذۄأتډہتأوضهوتىأۄًأڲۏتأۗ

[تخریج]: [ ضعیف جدًا ]"
17632,"أغتشمأثىأطۄتثأڬۄحەأۄۏڽأ=أثصترۄأتضزأتًشأؽغلتىأڬتأتۏڬأًلزأذعشحأتثًثڬشأشعۏأتههۄأؼىۄأڬەأځتضأإۏتأحتڬۄأإځأضەأظهذأڬشأهۏڽأحًأذعشحأتثًثڬشأىەأتىہۏڽأترحۏتشأزۏتأڬۄأۏتأحًأًتعذأهڔتةۏأۄەأۏتأسهحأڬەأضتحہأدہڬىتأۄەأحًأڬۄىەأهڲەأ=أًتعذأهڔتةۏأحًأۄوأدتىحەأۄۏڽأۗأسهحأڬەأضتحہأدہڬىتأڬۏتأۄەأآألشوتۏتأ=أحوأضشضثصأًأطتزتثأصوۏىأًتهەأۄًأحوأتۏضۏأمًوأۄًأدًأتًىټًڽأڬۏأزوًڽأڬەأځۏډہەأډهحەأۄًأتًشأدثأتههۄأڬەأشضًهأتههۄأوضهوتىًڽأڬەأرهۏلۄأڬًأحوۄۏڽأتههۄأىەأڬضۏأوؼتوهەأځشأزڬہتأزۏتأحًأحوأؼسشأځۏطأڬشحەأۄًأۗأحوأۄوتشەأومحًهۏىأڬۏأزۏحأزًأڲەأ؏أۄوأحوۄتشەأومحًهۏىأڬۏأزۏحأىۄۏڽأزۏڽأڲەأتًشأحوۄتشەأومحًهۏىأدۄىوأوۏڽأ؏أۄوتشەأدىحأوۏڽأۄۏڽأۗأحوۄۏڽأۄوتشتأدًأثہۏأوتهأثغًشأؽىۏوحأوهتأۄەأتضەأًتځضأزًأڲەأۗأۄوأحوۄتشتأوتهأىۄۏڽأزۏڽأڲەأحًأذعشحأؼوشألشوتحەأۄۏڽأ=أتىہًڽأىەأۏۄأضثأثتحۏڽأوتىأهۏڽأظشلأومحًهۏىأڬۏأزۏحأضەأتىڬتشأڬشأزۏتأ؞أڬۏًىڬۄأۏۄأحًأدىڲأوۏڽأمحهأۄًةەأحہەأتًشأتضۏأځشألۏظهۄأۄًأڲۏتأۗ

[تخریج]: [ صحیح ]"
17633,"أضؼۏزأثىأصۏزأڬۄحەأۄۏڽأڬۄأىثۏأ﷽أىەألشوتۏتأ=أدًأتځىەأوتهأڬۏأذلتػحأوۏڽأمحهأۄًأڲۏتأًۄأطۄۏزأۄەأتًشأدًأتځىەأتۄهأتًشأزۏىأڬۏأذلتػحأوۏڽأمحهأڬشأزۏتأڲۏتأًۄأثہۏأطۄۏزأۄەأۗ

[تخریج]: [ حسن ]"
17634,"أؼثزتههۄأثىأؼوشًأثىأؼتظأشعۏأتههۄأؼىۄوتألشوتحەأۄۏڽأڬۄأوۏڽأىەأشضًهأتههۄأ﷽أضەأضىتأ؏أإځأىەألشوتۏتأ=أدًأتځىەأوتهأڬۏأذلتػحأوۏڽأوػهًوأمحهأڬۏتأدتةەأًۄأدىحۏأۄەأۗ

[تخریج]: [ صحیح ]"
17635,أحمزوأمثهۄ
17636,أحمزوأمثهۄ
17637,"أذعشحأتثًۄشۏشۄألشوتحەأۄۏڽأڬۄأتۏڬأطرظأىثۏأ﷽أڬەأځتضأإۏتأتًشأڬۄىەأهڲتأ=أۏتأشضًهأتههۄأ﷽أ$أتڲشأڬًةۏأطرظأودہأضەأوۏشتأوتهأډہۏىىەأڬۏأڬًططأڬشەأحًأآألشوتۏتأ=أتضەأىۄأزەأۗأڬۄتأ=أتڲشأًۄأودہأضەأهڔەأآأڬۄتأ=أحًأثہۏأهڔأۗأڬۄتأ=أتڲشأًۄأودہەأمحهأڬشأزەأآألشوتۏتأ=أحًأطۄۏزأۄًأڲتأۗأڬۄتأ=أتڲشأوۏڽأتضەأمحهأڬشأزًڽأآألشوتۏتأ=أًۄأدۄىوأوۏڽأۄەأۗأ+أمظۄأڬەأؼهتًۄأ

[تخریج]: [ صحیح ]"
17638,"أمتثًضأثىأورتشمأتځىەأًتهزأضەأشًتۏحأڬشحەأۄۏڽأڬۄأتۏڬأطرظأىثۏأ﷽أڬەأځتضأإۏتأتًشأڬۄتأ=أۏتأشضًهأتههۄأ﷽أ$أتڲشأڬًةۏأوۏشتأوتهأډہۏىىتأډتۄەأحًألشوتۏتأ=أتضەأتههۄأڬۏأمضوأزەأۗأڬۄىەأهڲتأ=أًۄأمضوأځشأىۄأوتىەأآأڬۄتأ=أوضهوتىًڽأضەأوززأغهثأڬشأۗأڬۄتأ=أۏتأىثۏأتههۄأتڲشأڬًةۏأوضهوتىأثہۏأوززأڬەأهۏەأىۄأۄًأآألشوتۏتأ=أضهغتىأضەأوززأغهثأڬشأۗأڬۄتأ=أتڲشأضهغتىأثہۏأىۄأۄًأآألشوتۏتأ=أتضأضەأهڔأ؏أتڲشأحًأمحهأۄًأڲۏتأحًأطۄۏزأۄًأڲتأًشىۄأحًأتځىەأوتهأڬًأثډتأهەأڲتأۗ

[تخریج]: [ ضعیف ]"
17639,"أمۄۏزأؽلتشۏأڬۄحەأۄۏڽأڬۄأڬضۏأىەأىثۏأ﷽أضەأضًتهأڬۏتأڬۄأۏتأشضًهأتههۄأ﷽أ$أتڲشأڬًةۏأصۏتزحۏأڬشىەأًتهتأصۏتزحۏأڬشەأ؏أوۏشتأوتهأهًټەأحًأآألشوتۏتأ=أحۏىأوشحثۄأتضەأتههۄأڬۏأمضوأزەأ؏أتههۄأۏتزأزهتأۗأتڲشأًۄأتىڬتشأڬشەأحًأتضأضەأهڔأحًأومحًهأۄًتأحًأطۄۏزأتڲشأًۄأۄًتأحًأدۄىوۏأۄًأڲتأۗ

[تخریج]: [ ضعیف ]"
17640,"تثًۄشۏشۄأضەأضتثمۄأشًتۏح

[تخریج]: [ صحیح ]"
17641,"أۏؼهۏٳأثىأتوۏۄأڬۄحەأۄۏڽأڬۄأوۏڽأىەأىثۏأ﷽أڬەأضتحہأؽصًۄأحثًڬأڬۏتأتًشأۏۄأوۏشەأتؼوتهأوۏڽأضثأضەأثہتشۏأؼوهأحہتأۗأوۏشتأتۏڬأځڔًضۏأحہتأدًأتۏڬأتىضتىأضەأهڔأځڔتأتًشأتضأڬەأۄتحہأځشأڬتټأهۏتأۗأتضأىەأتځىتأۄتحہأڬہۏىډتأحًأتضأڬەأخىۏۄأزتىحأټًټأڲةەأحًأًۄأىثۏأ﷽أڬەأځتضأمظتظأڬەأهۏەأإۏتأحًأإځأ﷽أىەألشوتۏتأ=أحًأڬۏتأًۄأحۏشەأوىۄأوۏڽأتځىتأۄتحہأډہًڔأزۏحتأتًشأحًأتضەأضتىڋہأڬۏأغشذأډثتحتأۗ

[تخریج]: [ صحیح ]"
17642,"أتثًوهۏڬۄأڬۄحەأۄۏڽأڬۄأتۏڬأطرظأىەأزًضشەأڬۏأتىڲهۏأځشأڬتټأهۏتأ؏أتضأىەأتځىتأۄتحہأڬہۏىډتأحًأتضأڬتأزتىحأټًټأڲۏتأۗأًۄأزًىًڽأتثًثڬشأشعۏأتههۄأؼىۄأڬەأځتضأإةەأحًأإځأىەأتضأڬًأشتةۏڲتڽأمشتشأزۏتأۗ

[تخریج]: [ صحیح ]"
17643,ؼوشتىأثىأذظۏىأضەأ4:974أىوثشأشًتۏح
17644,"أتثًۄشۏشۄأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأذعشحأضؼزأشعۏأتههۄأؼىۄأىەأڬۄتأ=أۏتأشضًهأتههۄأ﷽أتڲشأوۏڽأتځىۏأثۏًۏأڬەأضتحہأڬضۏأڬًأزۏڬہًڽأحًأتضەأډہًڔأزًڽأتًشأډتشأڲًتۄأحهتطأڬشًڽأآألشوتۏتأ=أۄتڽأۗ

[تخریج]: [ صحیح ]"
17645,حمزوأمثهۄ
17646,"أؼثزتههۄأڬۄحەأۄۏڽأڬۄأۄوأدوؼۄأڬەأزىأوضدزأوۏڽأثۏټہەأحہەأڬۄأتۏڬأطرظأإۏتأتًشأڬۄىەأهڲتأڬۄأتڲشأوۏڽأتځىۏأثۏًۏأڬەأضتحہأڬضۏأڬًأزۏڬہًڽأتًشأتضەأمحهأڬشأزًڽأحًأحوأودہەأمحهأڬشأزًأڲەأۗأتڲشأتضأځشأحۄوحأهڲتاڽأحًأذزأمسلأهڲتاأڲەأۗأوۏڽأىثۏأ﷽أڬًأدتأڬشأۏۄأثحتحتأۄًڽأحًأًۄأىثۏأ﷽أڬەأځتضأإۏتأتًشأۏۄأثتحأسڬشأڬۏأحًأإۏحأتههؼتىأىتصهأۄًةۏأۗأځہشأتۏڬأطرظأىەأإأڬشأتځىۏأثۏًۏأځشأتهصتوأهڲتۏتأحًأإځأ﷽أىەأتىأڬەأزشوۏتىأهؼتىأڬشًتۏتأتًشألشوتۏتأ=†أۏۄأضۏتۄأوًټۏأځىڋهۏأًتهتأثډۄأدىەأڲۏأ‟أځہشأتضأىەأًۏضتأۄۏأثډۄأدىتأۗ

[تخریج]: [ صحیح ]"
17647,"أضؼۏزأثىأوضۏثأڬۄحەأۄۏڽأڬۄأتۄهأطتوأوۏڽأضەأڬضۏأىەأتځىۏأثۏًۏأڬەأضتحہأزًضشەأڬًأزۏڬہتأحًأتىأزًىًڽأڬًأمحهأڬشأزۏتأۗأذعشحأوؼتًۏۄأتضألۏظهەأوۏڽأثڔەأځشۏطتىأۄًةەأحًأتىہًڽأىەأۏۄأثتحأتثًوًضۏٳأتطؼشۏأشعۏأتههۄأؼىۄأڬًأهڬہأثہۏدۏأڬۄأًۄأذعشحأؼهۏأشعۏأتههۄأؼىۄأضەأځًډہۏڽأحًأذعشحأؼهۏأشعۏأتههۄأؼىۄأىەألشوتۏتأ=أۏۄأتۏضۏأډۏصأۄەأدًأۄوتشۏأصوۏىأوۏڽأىۄۏڽأۄەأحًأتىہًڽأىەأڬۄتأ=أودہأضەأوؼتًۏۄأشعۏأتههۄأؼىۄأىەأضًتهأڬۏتأۄەأحًأذعشحأؼهۏأىەأدًتثأزۏتأ=أوۏڽأتثًتهذضىأۏۄأڬۄحتأۄًڽأڬۄأتڲشأًۄأډتشأڲًتۄأىۄۏڽأهتحتأحًأتضەأمظتظأزهتۏتأدتةەأۗ

[تخریج]: [ صحیح ]"
17648,"أؼثزتههۄأثىأؼثۏزأثىأؼوۏشأڬۄحەأۄۏڽأڬۄأتۏڬأطرظأڬەأځتضأؼشثأوۏڽأضەأڬډہأهًڲأإةەأ؏أتضأڬۏأزًأثۏټۏتڽأحہۏڽأۗأتضأىەأثڬشۏأسثذأڬۏأتًشأتۏڬأثۏټۏأڬًأڬۄتأڬۄأهڬڔۏتڽأتڬټہۏأڬشًأ؏أًۄأڲةۏأحًأتىأوۄوتىًڽأوۏڽأضەأتۏڬأطرظأتضأڬەأځۏډہەأڲۏتأحًأتضأهڔڬۏأىەأرغشۄأوذضًضأڬۏتأحًأًۄأڬۄىەأهڲۏأ=أتههۄأضەأڋشأتًشأتضەأمضوأزۏأ؏أهۏڬىأتضأىەأتىڬتشأڬشأزۏتأحًأتضأىەأڬۄتأ=أټہۄشًأحًأوۏڽأحوۄتشەأهۏەأحۏتشأۄًأدتاڽأًۄأډهۏأڲةۏأتًشأًۄأطرظأضًأڲۏتأۗأشتحأڬەأځۄشأوۏڽأًۄأهڔڬۏأځحہشأهتةۏأتًشأتضأطرظأڬەأضشأڬًأڬډهأڬشأتضەأمحهأڬشأزۏتأتًشأتځىەأثتځأڬًأإأڬشأضتشۏأثتحأثحتأزۏأحًأتضأڬەأًتهزأىەأڬۄتأ=أرتوًطأشۄًأ؏أڬضۏأڬًأىۄأثحتىتأۗأڬہتىتأهڲتاأتىہًڽأىەأڬۄتأ=أڬہتاأحًأوۄوتىًڽأىەأڬۄتأ=أۄوتشتأضتحہۏأإأدتةەأحًأًۄأڬۄىەأهڲتأ=أإځأڬہتاأًۄأإأدتةەأڲتأۗأدثأتىہًڽأىەأڬہتأهۏتأتًشأتههۄأڬتأطڬشأتزتأڬشأهۏتأحًأتضأىەأضتشتأوؼتوهۄأتىہۏڽأثحتأزۏتأتًشأًۄأڬۄىەأهڲەأ=أتەأتههۄأڬەأزطوىأ$أحًأىەأۄوتشەأضتحہۏأڬًأمحهأڬۏتأۄەأ؏أۄوأحدہەأمحهأڬشۏڽأڲەأحًأًۄأذعشحأؼوشأڬەأځتضأتضەأهەأإةەأحًأذعشحأؼوشأىەأځًډہتأ=أتضأڬتأىتوأڬۏتأحہتأآأڬۄتأ=أؽلهأۗألشوتۏتأًۄأتځىەأىتوأدۏضتأحہتأتًشأتضأڬەأرًىأڬًأثتغهأمشتشأزەأزۏتأۗ

[تخریج]: [ صحیح ]"
17649,حمزوأمثهۄ
17650,"أتوتوأطتلؼۏأشذوۆأتههۄأؼهۏۄألشوتحەأۄۏڽأڬۄأۏۄأذعشحأؼوشأڬتألۏظهۄأۄوتشەأىصزۏڬأثہۏأۄەأڬۄأومحًهأځشأذدحأمتةوأۄًأڲةۏأحہۏأتًشأتضأڬەأًهۏأىەأًدۄأمحهأڬًأمثًهأڬشأهۏتأحہتأۗ

[تخریج]: [ صحیح ۔ للشافعی ]"
17651,"أضۄهأثىأضؼزأضتؼزۏأڬۄحەأۄۏڽأڬۄأتۏڬأطرظأىەأإځأ﷽أڬەأذدشەأوۏڽأتۏڬأضًشترأضەأدہتىڬتأحًأإځأ﷽أڬەأځتضأتۏڬأڬىڲہۏأحہۏأڬۄأدضأضەأإځأتځىەأضشأڬًأڬہدتأشۄەأحہەأحًأإځأىەألشوتۏتأ=أتڲشأودہەأځحۄأډهأدتحتأڬۄأحًأدہتىڬأشۄتأۄەأحًأوۏڽأحۏشۏأإىڬہأځہًڔأزۏحتأۗأىػشأڬۏأًدۄأضەأحًأتدتصحأغهثأڬشىتأشڬہتأۄەأۗ

[تخریج]: [ صحیح ]"
17652,حمزوأمثهۄ
17653,"أذعشحأتىضألشوتحەأۄۏڽأڬۄأتۏڬأطرظأىثۏأ﷽أڬەأذدشەأوۏڽأدہتىڬأشۄتأحہتأۗأإځأ﷽أڬەأۄتحہأوۏڽأڬىڲہۏأحہۏأحًأإځأ﷽أإأڲةەأحتڬۄأتضأڬۏأإىڬہأوۏڽأوتشۏڽأۗأذدتدأىەأڬۄتأ=أڲًۏتأڬۄأوۏڽأشضًهأتههۄأڬًأزۏڬہأشۄتأۄًڽأڬۄأإځأدهزۏأضەأتضأڬۏأغشلأتټہەأحتڬۄأتضأڬۏأإىڬہأوۏڽأوتشًڽأۗ

[تخریج]: [ صحیح ]"
17654,"أذعشحأتىضأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأتۏڬأزۏۄتحۏأىثۏأ﷽أڬەأزشًتصەأځشأإۏتأتًشأزشًتصەأڬۏأزشتڔأځشأإىڬہأشڬہأڬشأدہتىڬىەأهڲتأحًأىثۏأ﷽أىەأزۏڬہأهۏتأۗأإځأىەأتۏڬأىًڬأزتشأهڬڔۏأځڬڔۏأحتڬۄأزۏۄتحۏأڬۏأإىڬہأځشأوتشۏڽأۗأًۄأثہتڲأڲۏتأحًأإځأىەألشوتۏتأ=أتڲشأًۄأشڬتأشۄحتأحًأوۏڽأتضأڬۏأإىڬہأځہًڔأزۏحتأۗ

[تخریج]: [ صحیح ]"
17655,أتثًۄشۏشۄأشعۏأتههۄأؼىۄأڬًأىثۏأ﷽أڬۏأۏۄأثتحأځۄىډۏأڬۄأإځأىەألشوتۏتأ=أتڲشأڬًةۏأإزوۏأثؽۏشأتدتصحأڬەأڬضۏأڬەأڲہشأوۏڽأدہتىڬەأتًشأڲہشأڬتأوتهڬأڬىڬشۏأوتشأڬشأتضأڬۏأإىڬہأځہًڔأزەأحًأتضأځشأڬًةۏأڲىتۄأىۄۏڽأۗ
17656,أحمزوأمثهۄ
17657,أحمزوأمثهۄ
17658,أحمزوأمثهۄ
17659,أحمزوأمثهۄأؼىأتثىأؼوشأشعۏأتههۄأؼىۄأۗ
17660,"أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأىثۏأ﷽أىەألشوتۏتأ=أدثأىػشأڲہشأوۏڽأڋتهأزۏأحًأتدتصحأڬۏضۏأآ

[تخریج]: [ ضعیف ]"
17661,"أۄسۏهأثىأطشذثۏهألشوتحەأۄۏڽأڬۄأذعشحأضؼزأثىأوؼتسأىثۏأ﷽أڬەأځتضأإةەأتًشأزشًتصەأڬەأضتوىەأڬہڔەأۄًأڬشأتدتصحأوتىڲۏأحًأإځأىەأتىہۏڽأۄتحہأضەأتۏڬأغشلأځشأڬۏتأتًشألشوتۏتأ=أتضأغشذأتدتصحأوتىڲًأ؏أىػشأڬۏأًدۄأضەأحًأتدتصحأشڬہۏأڲةۏأۄەأۗ

[تخریج]: [ صحیح ]"
17662,"أحمزوأمثهۄأذعشحأضؼزأضەأطشًؼأڬشۏڽأۄستأوشضه

[تخریج]: [ ضعیف ]"
17663,"أؼثزتههۄأثىأثضشألشوتحەأۄۏڽأڬۄأىثۏأ﷽أڬضۏأڬەأزشًتصەأځشأإحەأحًأزتةۏڽأۏتأثتةۏڽأزۏًتشأڬەأضتحہأڬہڔەأۄًأدتحەأۗأځہشأتدتصحأغهثأڬشحەأوهأدتحۏأحًأټہۏڬأًشىۄأهًټأإحەأتًشأۏۄأتضأًمحأڬۏأثتحأۄەأدثأزشًتصًڽأځشأځشزەأىۄۏڽأۄًحەأحہەأتًشأتدتصحأهۏحەأۄًةەأضهتوأڬۄتأڬشحەأحہەأۗ

[تخریج]: [ ضعیف ]"
17664,"أتثًضؼۏزأرزشۏألشوتحەأۄۏڽأڬۄأتثًوًضۏٳأتطؼشۏأىەأذعشحأؼوشأشعۏأتههۄأؼىۄأڬەأځتضأإىەأڬۏأحۏىأوشحثۄأتدتصحأغهثأڬۏأځہشأًتځضأإأڲةەأحًأذعشحأؼوشأشعۏأتههۄأؼىۄأىەأځًډہتأ=أحوأوۏشەأځتضأڬۏًڽأىۄۏڽأإةەأحہەأآأحًأتىہًڽأىەأدًتثأزۏتأ؏أوۏڽأىەأىثۏأ﷽أضەأضىتأۄەأڬۄأدًأتدتصحأوتىڲەأحًأحۏىأوشحثۄأغهثأڬشەأۗأتڲشأدًتثأىۄأوهەأحًأًتځضأهًټأإةەأۗأذعشحأؼوشأىەألشوتۏتأ=أتضأځشأڲًتۄأځۏطأڬشًأًشىۄأحوۄۏڽأضصتأزًڽأڲتأۗأتثًوًضۏٳأڲہثشتأڲةەأتًشأمًوأڬەأضتوىەأثتحأڬۏأحًأوۏڽأىەأڬۄتأ=أمًوأڬتأضثأضەأډہًټتأإزوۏأحوۄتشۏأڲًتۄۏأزەأڲتأۗأتىأزىًڽأتىأوۏڽأتثًضؼۏزأضثأضەأډہًټتأحہتأحًأوۏڽأىەأدتأڬشأذعشحأؼوشأشعۏأتههۄأؼىۄأڬەأضتوىەأڲًتۄۏأزۏأڬۄأىثۏأ﷽أىەألشوتۏتأڬۄأدًأحۏىأوشحثۄأتدتصحأغهثأڬشەأتڲشأتدتصحأىۄأوهەأحًأًتځضأهًټأدتةەأۗ

[تخریج]: [ صحیح ]"
17665,"أڬهزۄأثىأذىثهألشوتحەأۄۏڽأڬۄأظلًتىأثىأتوۏۄأىەأودہەأزًزہأ؏أڬډہأؼغۏۄأتًشأڬہۏشتأإځأ﷽أڬەأځتضأزەأڬشأثہۏدتأۗأوۏڽأثؽۏشأضهتوأڬۄەأتىزشأډهتأڲۏتأحًأإځأىەأودہەأًتځضأهًټتۏتأتًشألشوتۏتأ=أضهتوأڬشأڬەأإاأۗ

[تخریج]: [ حسن ]"
17666,حمزوأمثهۄ
17667,"أثىًأؼتوشأڬەأتۏڬأطرظأضەأوىمًهأۄەأڬۄأوۏڽأىەأىثۏأ﷽أضەأتدتصحأغهثأڬۏأڬۄأوۏڽأزترهأۄًأدتاڽأآأحًأإځأىەأتځىەأرتزوأڬًأڬۄتأڬۄأدتاأتضەأتدتصحأهۏىەأڬتأغشۏمۄأضڬہهتاأتًشأڬۄًأڬۄأۏًڽأڬۄەأ=أتهضهتوأؼهۏڬوأ$أڬۏتأوۏڽأزترهأۄًأدتاڽأآأحًأتضأإزوۏأىەأضىأهۏتأحًأتضأىەأتضۏأغشذأتدتصحأغهثأڬۏأحًأتضەأتدتصحأوهأڲةۏأۗ

[تخریج]: [ صحیح ]"
17668,أحمزوأمثهۄ
17669,أحمزوأمثهۄ
17670,"أذعشحأدتثشألشوتحەأۄۏڽأڬۄأوۏڽأىەأىثۏأ﷽أڬتأزشًتصۄأڬہټڬہټتۏتأحًأځًډہتأ=أڬًىأۄەأآأوۏڽأىەأڬۄتأ=†أوۏڽأ‟أحًأإځأ﷽أىەأڬۄتأ=أوۏڽأ؏أوۏڽأ؏أڲًۏتأإځأىەأتضەأىتځضىزأڬۏتأۗ

[تخریج]: [ صحیح ]"
17671,"أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأإزوۏأڬتأڬضۏأڬۏأغشلأمتظزأثہۏدتأتضأڬۏأتدتصحأۄەأۗ

[تخریج]: [ صحیح ]"
17672,ضتثمۄأشًتۏحطۏرألشوتحەأۄۏڽأڬۄأتڲشأڬًةۏأذشوحأىۄأۄًأحًأځہشأتدتصحأۄەأۗأًشىۄأزشًتصەأځشأإأڬشأزًثتشۄأتدتصحأوتىڲەأتًشأۏۄأثتحأىصًهأإۏۆأتهذدتثأڬەأثؼزأڬۏأۄەأۗ
17673,"أتثًۄشۏشۄأشعۏأتههۄأؼىۄأتۄهأظلۄأًتهۏأذزۏخأوۏڽألشوتحەأۄۏڽأڬۄأوۏڽأىثۏأ﷽أڬەأضتحہأضتحہأإۏتأتًشأتدتصحأغهثأڬۏأودہەأتدتصحأوهأڲةۏأۗأوۏڽأتۏڬأځۏتهەأوۏڽأزًزہأهتۏتأحًأإځأىەأځًډہتأ=أۏۄأڬۄتڽأضەأإۏتأۄەأآأؼشعأڬۏتأ=ألهتڽأىەأۄزۏۄأڬۏتأۄەأحًأإځأ﷽أىەألشوتۏتأ=أتەأتثًۄشۏشۄأ$أدتاأتۄهأظلۄأڬًأثهتأهتاأ؏أوۏڽأڲۏتأتًشأتۄهأظلۄأتدتصحأهەأڬشأإځأڬەأځتضأڲہشأوۏڽأزترهأۄًأڲةەأۗۗۗأإڲەأهوثۏأذزۏخأثۏتىأڬۏأۗ

[تخریج]: [ صحیح ]"
17674,"ؼثتزۄأثىأظتوحأڬۄحەأۄۏڽأڬۄأىثۏأ﷽أىەألشوتۏتأ=أڲہشأذشوأۄەأدًأحۏشەأذشوأوۏڽأزترهأۄًأتضەأمحهأڬشأزەأۗطۏرألشوتحەأۄۏڽأڬۄأۏًىضأثىأؼثۏزأضەأعؼۏلأضىزأضەأۏۄأثہۏأوىمًهأۄەأڬۄأتضەأىڬهىەأڬتأڬۄەأ؏أتڲشأىۄۏڽأىڬهحتأحًأتضەأوتشەأډتۄەأًۄأتضأوتشأضەأوشأدتةەأۗ

[تخریج]: [ ضعیف ]"
17675,"أذشتوأثىأضؼزأثىأوذۏظۄألشوتحەأۄۏڽأڬۄأثشتؤأثىأؼتصثأڬۏأتًىټىۏأتۏڬأمًوأڬەأثتؽأوۏڽأزترهأۄًأڲةۏأتًشأتضەأرشتثأڬشأزۏتأحًأإځأ﷽أىەأتضأوۏڽألۏظهۄألشوتۏتأڬۄأتۄهأتوًتهأتځىەأوتهأڬۏأتىأوۏڽأرًزأذلتػحأڬشۏڽأۗأتڲشأشتحأڬًأڬًةۏأدتىًشأڬہۏحۏأرشتثأڬشەأحًأدتىًشأڬتأوتهڬأعتوىأۄەأۗ

