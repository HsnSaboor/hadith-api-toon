{"hadithnumber": "1137", "text": "ام عطیہ رضی اللہ عنہا کہتی ہیں: ہم کو رسول اللہ صلی اللہ علیہ وسلم نے حکم دیا کہ  ہم پردہ نشین عورتو"}
{"hadithnumber": "1138", "text": "اس سند سے بھی ام عطیہ رضی اللہ عنہا سے یہی حدیث مروی ہے  اس میں ہے: حائضہ عورتیں مسلمانوں کی نماز کی"}
{"hadithnumber": "1139", "text": "اس طریق سے بھی ام عطیہ رضی اللہ عنہا سے یہی حدیث مروی ہے  اس میں ہے کہ انہوں نے کہا: ہمیں حکم دیا جا"}
{"hadithnumber": "1140", "text": "ام عطیہ رضی اللہ عنہا سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم جب مدینہ تشریف لائے تو آپ نے انصا"}
{"hadithnumber": "1141", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  مروان عید کے روز منبر لے کر گئے اور نماز سے پہلے خطبہ شروع ک"}
{"hadithnumber": "1142", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم عید الفطر کے دن کھڑے ہوئے تو"}
{"hadithnumber": "1143", "text": "عطاء کہتے ہیں: میں ابن عباس رضی اللہ عنہما کے بارے میں گواہی دیتا ہوں اور ابن عباس نے رسول اللہ صلی"}
{"hadithnumber": "1144", "text": "اس سند سے بھی ابن عباس رضی اللہ عنہما سے اسی مفہوم کی روایت مروی ہے  اس میں یہ ہے: آپ صلی اللہ علیہ"}
{"hadithnumber": "1145", "text": "عبداللہ بن عباس رضی اللہ عنہما سے مروی اسی حدیث میں ہے  عورتیں بالی اور انگوٹھی  ( صدقہ میں )  دینے"}
{"hadithnumber": "1146", "text": "براء رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کو عید کے دن ایک کمان دی گئی تو آپ صلی ال"}
{"hadithnumber": "1147", "text": "عبدالرحمٰن بن عابس کہتے ہیں کہ  ایک شخص نے ابن عباس رضی اللہ عنہما سے پوچھا: کیا آپ رسول اللہ صلی ال"}
{"hadithnumber": "1148", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے عید کی نماز بغیر اذان او"}
{"hadithnumber": "1149", "text": "جابر بن سمرہ رضی اللہ عنہ کہتے ہیں  میں نے نبی اکرم صلی اللہ علیہ وسلم کے ساتھ ایک دو بار نہیں  ( با"}
{"hadithnumber": "1150", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں  رسول اللہ صلی اللہ علیہ وسلم عید الفطر اور عید الاضحی کی پ"}
{"hadithnumber": "1151", "text": "اس طریق سے بھی ابن شہاب سے اسی سند سے اسی مفہوم کی روایت مروی ہے  ، اس میں ہے  ( یہ تکبیریں )  رکوع"}
{"hadithnumber": "1152", "text": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  اللہ کے نبی کریم صلی اللہ علیہ وسلم نے فرمایا:"}
{"hadithnumber": "1153", "text": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم عید الفطر کی پہلی ر"}
{"hadithnumber": "1154", "text": "مکحول کہتے ہیں کہ  ابوہریرہ رضی اللہ عنہ کے ہم نشیں ابوعائشہ نے مجھے خبر دی ہے کہ سعید بن العاص نے ا"}
{"hadithnumber": "1155", "text": "عبیداللہ بن عبداللہ بن عتبہ بن مسعود سے روایت ہے کہ  عمر بن خطاب رضی اللہ عنہ نے ابوواقد الیثی رضی ا"}
{"hadithnumber": "1156", "text": "عبداللہ بن سائب رضی اللہ عنہ کہتے ہیں  میں رسول اللہ صلی اللہ علیہ وسلم کے ساتھ عید میں حاضر ہوا تو"}
{"hadithnumber": "1157", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم عید کے دن ایک راستے سے گئے پ"}
{"hadithnumber": "1158", "text": "ابو عمیر بن انس کے ایک چچا سے جو نبی اکرم صلی اللہ علیہ وسلم کے اصحاب میں سے ہیں، روایت ہے کہ  کچھ س"}
{"hadithnumber": "1159", "text": "بکر بن مبشر انصاری رضی اللہ عنہ کہتے ہیں کہ  میں عید الفطر اور عید الاضحی کے دن رسول اللہ صلی اللہ ع"}
