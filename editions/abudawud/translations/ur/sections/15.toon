{"hadithnumber": "2496", "text": "بریدہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مجاہدین کی بیویوں کی حرمت ج"}
{"hadithnumber": "2497", "text": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مجاہدین کی کوئی"}
{"hadithnumber": "2498", "text": "معاذ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:   ( دوران جہاد )  نماز، روزہ"}
{"hadithnumber": "2499", "text": "ابو مالک اشعری رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا:  جو"}
{"hadithnumber": "2500", "text": "فضالہ بن عبید رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ہر میت کا عمل مرنے"}
{"hadithnumber": "2501", "text": "سہل بن حنظلیہ رضی اللہ عنہ سے روایت ہے کہ  لوگ رسول اللہ صلی اللہ علیہ وسلم کے ساتھ حنین کے دن چلے ا"}
{"hadithnumber": "2502", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جو شخص مر گیا اور اس نے ن"}
{"hadithnumber": "2503", "text": "ابوامامہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جس نے جہاد نہیں کیا یا"}
{"hadithnumber": "2504", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  مشرکوں سے اپنے اموال، اپنی جان"}
{"hadithnumber": "2505", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں  «إلا تنفروا يعذبكم عذابا أليما»  اگر تم جہاد کے لیے نہیں نک"}
{"hadithnumber": "2506", "text": "نجدہ بن نفیع کہتے ہیں کہ  میں نے آیت کریمہ «إلا تنفروا يعذبكم عذابا أليما»  اگر تم جہاد کے لیے نہیں"}
{"hadithnumber": "2507", "text": "زید بن ثابت رضی اللہ عنہ کہتے ہیں کہ  میں رسول اللہ صلی اللہ علیہ وسلم کے پہلو میں تھا تو آپ کو سکین"}
{"hadithnumber": "2508", "text": "انس بن مالک رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم مدینہ میں کچھ ا"}
{"hadithnumber": "2509", "text": "زید بن خالد جہنی رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے اللہ کے"}
{"hadithnumber": "2510", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے بنو لحیان کی طرف ایک لشکر بھ"}
{"hadithnumber": "2511", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا:  آدم"}
{"hadithnumber": "2512", "text": "اسلم ابوعمران کہتے ہیں کہ  ہم مدینہ سے جہاد کے لیے چلے، ہم قسطنطنیہ کا ارادہ کر رہے تھے، اور جماعت"}
{"hadithnumber": "2513", "text": "عقبہ بن عامر رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا:  اللہ"}
{"hadithnumber": "2514", "text": "عقبہ بن عامر جہنی رضی اللہ عنہ سے روایت ہے کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو منبر پر فرماتے"}
{"hadithnumber": "2515", "text": "معاذ بن جبل رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جہاد دو طرح کے ہیں"}
{"hadithnumber": "2516", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  ایک شخص نے کہا: اللہ کے رسول! ایک شخص اللہ کی راہ میں جہاد کا ارا"}
{"hadithnumber": "2517", "text": "ابوموسیٰ رضی اللہ عنہ کہتے ہیں کہ  ایک دیہاتی رسول اللہ صلی اللہ علیہ وسلم کے پاس آیا اور اس نے عرض"}
{"hadithnumber": "2518", "text": "عمرو کہتے ہیں کہ  میں نے اپنے والد وائل سے ایک حدیث سنی جو مجھے پسند آئی، پھر راوی نے اسی مفہوم کی ح"}
{"hadithnumber": "2519", "text": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  انہوں نے کہا: اللہ کے رسول! مجھے جہاد اور غزوہ کے بارے م"}
{"hadithnumber": "2520", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تمہارے بھائی"}
{"hadithnumber": "2521", "text": "حسناء بنت معاویہ کے چچا رضی اللہ عنہ کہتے ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم سے پوچھا: جنت م"}
{"hadithnumber": "2522", "text": "نمران بن عتبہ ذماری کہتے ہیں: ہم ام الدرداء رضی اللہ عنہا کے پاس گئے  اور ہم یتیم تھے، انہوں نے کہا:"}
{"hadithnumber": "2523", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  جب نجاشی کا انتقال ہو گیا تو ہم کہا کرتے تھے کہ ان کی ق"}
{"hadithnumber": "2524", "text": "عبید بن خالد سلمی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے دو آدمیوں میں بھائی چارہ"}
{"hadithnumber": "2525", "text": "ابوایوب رضی اللہ عنہ سے روایت ہے کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا:  عنقر"}
{"hadithnumber": "2526", "text": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جہاد کرنے والے"}
{"hadithnumber": "2527", "text": "یعلیٰ بن منیہ رضی اللہ عنہ کہتے ہیں  رسول اللہ صلی اللہ علیہ وسلم نے غزوہ کا اعلان کیا اور میں بہت ب"}
