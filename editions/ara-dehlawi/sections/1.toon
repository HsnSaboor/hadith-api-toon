metadata:
  section_id: 1
  section_name: Forty Hadith of Shah Waliullah Dehlawi
  hadith_first: 1
  hadith_last: 40
  arabic_first: 1
  arabic_last: 40

hadiths[40]{hadithnumber,text,reference_book,reference_hadith}:
1,لَیْسَ الْخَبَرُ کَالْمُعَایَنَةِ,1,1
2,الْحَرْبُ خُدَعَةٌ,1,2
3,الْمُسْلِمُ مِرْآةُ الْمُسْلِمِ,1,3
4,الْمُسْتَشَارُ مُؤتَمَنٌ,1,4
5,الدَّالُّ عَلَی الْخَیْرِ کَفَاعِلِهِ,1,5
6,إِسْتَعِیْنُوْا عَلَی الْحَوَائِجِ بِالْکِتْمَانِ,1,6
7,إِتَّقُوْا النَّارَ وَلَوْ بِشِقِّ تَمْرَةٍ,1,7
8,الدُّنْیَا سِجْنُ الْمُؤمِنِ وَ جَنَّةُ الْکَافِرِ,1,8
9,الْحَیَاءُ خَیْرٌ کُلُّهُ,1,9
10,عِدَةُ الْمُؤمِنِ کَاَخْذِ الْکَفِّ,1,10
11,لَا یَحِلُّ لِمُؤمِنٍ اَنْ یَّجُهْرَ أخَاهُ فَوقَ ثَلَاثَةِ أیَّامٍ,1,11
12,لَیْسَ مِنَّا مَنْ غَشَّنَا,1,12
13,مَا قَلَّ وَكَفَى خَيْرٌ مِمَّا كَثُرَ وَأَلْهَى,1,13
14,الرَّاجِعُ فِيْ هِبَتِهِ کَالرَّاجِعِ فِيْ قَیْئِهِ,1,14
15,الْبَلَاءُ مُوَکِّلٌ بِالْمَنْطِقِ,1,15
16,النَّاسُ کَأسْنَانِ الْمُشْطِ,1,16
17,الْغِنَى غِنَى النَّفْسِ,1,17
18,الْسَّعِیْدُ مَنْ وُّعِظَ بِغَیْرِهِ,1,18
19,وَ إِنَّ مِنَ الشِّعْرِ لَحِکْمَةً وَاِنَّ مِنَ الْبَیَانِ لَسِحْرًا,1,19
20,عَفْوُ الْمُلُوْكِ إِبْقَاءٌ لِلْمُلْكِ,1,20
21,اَلْمَرْءُ مَعَ مَنْ أَحَبَّ,1,21
22,مَا هَلَكَ إمْرُؤٌ عَرَفَ قَدْرَهُ,1,22
23,اَلْوَلَدُ لِلْفِرَاشِ وَ لِلْعَاهِرِ الْحَجَرُ,1,23
24,الْیَدُ الْعُلْیَا خَیْرٌ مِّنَ الْیَدِ السُّفْلَی,1,24
25,لَا شَکَرَ اللهَ مَنْ لَّا یَشْکُرُ النَّاسَ,1,25
26,حُبُّكَ الشَّيْءَ یُعْمِيْ وَ یُصِمُّ,1,26
27,جُبِلَتِ الْقُلُوبُ عَلی حُبَّ مَنْ اَحْسَنَ اِلَیْهَا وَ بُغْضِ مَنْ اَسَاءَ اِلَیْهَا,1,27
28,الْتَّائِبُ مِنَ الذَّنْبِ کَمَنْ لَا ذَنْبَ لَهُ,1,28
29,الشَّاهِدُ یَرَی مَا لَا یَرَاهُ الْغَائِبُ,1,29
30,اِذا جَاءَکُمْ کَرِیْمُ قَوْمٍ فَاَکْرِمُوهُ,1,30
31,الْیَمِینُ الْفَاجِرَةُ تَدَعُ الدِّیَارَ الْبَلَاقِعَ,1,31
32,مَنْ قُتِلَ دُونَ مَالِهِ فَهُوَ شَهِیْدٌ,1,32
33,الْاَعْمَالُ بِالنِّیَّةِ,1,33
34,سَیِّدُ الْقَوْمِ خَادِمُهُمْ,1,34
35,خَیْرُ الْأُمُوْرِ أَوْسَطُهَا,1,35
36,اَللَّهُمَّ بَارِكْ فِیْ أُمَّتِیْ فِی بُکُوْرِهَا یَوْمَ الْخَمِیْسِ,1,36
37,کَادَ الْفَقْرُ أَنْ یَکُوْنَ کُفْرًا,1,37
38,الْسَّفَرُ قِطْعَةٌ مِّنَ الْعَذَابِ,1,38
39,خَیْرُ زَّادِ الْتَّقْوَی,1,39
40,الْمَجَالِسُ بِالْاَمَانَةِ,1,40
