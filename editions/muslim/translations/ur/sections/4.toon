{"hadithnumber": "1129", "text": "۔   ابن ہلال ،  یعنی حمید نے کہا :  ایک دن میں اور  میرا ایک ساتھی ایک حدیث کے بارے میں مذاکرہ کر رہ"}
{"hadithnumber": "1130", "text": "اسماعیل بن ابی فدیک نے ضحاک بن عثمان سے ،  انہوں نے صدقہ بن یسار سے ،  اور انہوں نے حضرت عبد اللہ بن"}
{"hadithnumber": "1131", "text": "۔   ( ابن ابی فدیک کے بجائے )  ابو بکر حنفی نے ضحاک بن عثمان سے اسی  ( مذکورہ )  سند کےساتھ روایت کی"}
{"hadithnumber": "1132", "text": "۔  امام مالک کے ابو نضر سے اور انہوں نے بسر بن سعید سے روایت کی کہ زید بن خالد جہنی  ‌رضی ‌اللہ ‌عنہ"}
{"hadithnumber": "1133", "text": "سفیان نے ابو نضر سالم سے اور انہوں نے بسر بن سعید سے روایت کی کہ زید بن خالد جہنی  ‌رضی ‌اللہ ‌عنہ ‌"}
{"hadithnumber": "1134", "text": "حضرت سہل بن سعد ساعدی ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے ،  انہوں نے کہا :  رسول اللہﷺ کے سجدے کی جگہ"}
{"hadithnumber": "1135", "text": "۔  حماد بن مسعدہ نے یزید بن ابی عبید سے اور انہوں نے حضرت سلمہ بن اکوع  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روای"}
{"hadithnumber": "1136", "text": "۔  مکی  ( بن ابراہیم )  نے کہا :  ہمیں یزید بن ابی عبید نے خبر دی ،  انہوں نے کہا :  حضرت سلمہ  ( بن"}
{"hadithnumber": "1137", "text": "۔  یونس نے حمید بن ہلال سے ،  انہوں نے عبد اللہ بن صامت سے اور انہوں نے حضرت ابو ذر  ( غفاری )   ‌رض"}
{"hadithnumber": "1138", "text": "سلیمان بن مغیرہ ،  شعبہ ،  جریر ،  سلم بن ابو ذیال اور عاصم  احول سب نے حمید بن ہلال سے یونس کی سند"}
{"hadithnumber": "1139", "text": "حضرت ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے ،  انہوں نے کہا کہ رسول اللہﷺ نے فرمایا :  ’’ عورت ،"}
{"hadithnumber": "1140", "text": "زہری نے عروہ سے اور انہوں نے حضرت عائشہ رضی اللہ عنہا سے روایت کی کہ نبی اکرمﷺ رات کو نماز پڑھتے تھے"}
{"hadithnumber": "1141", "text": "۔  ہشام نے اپنے والد عروہ سے اور انہوں نے حضرت عائشہ  رضی اللہ عنہا سے روایت کی ،  انہوں نے کہا :  ن"}
{"hadithnumber": "1142", "text": "ابو بکر بن حفص نے عروہ سے روایت کی ،  انہوں نے کہا :  حضرت عائشہ رضی اللہ عنہا  نے پوچھا :  کون سی چ"}
{"hadithnumber": "1143", "text": "اعمش نے ہمیں حدیث سنائی ،  کہا :  مجھے ابراہیم نے حدیث بیان کی ،  انہوں نے اسود سے اور اسود نے عائشہ"}
{"hadithnumber": "1144", "text": "منصور نے ابراہیم  ( نخعی )  سے ،  انہوں نے اسود سے اور  انہوں نے حضرت عائشہ رضی اللہ عنہا سے روایت ک"}
{"hadithnumber": "1145", "text": "ابو سلمہ  بن عبد الرحمن  نے حضرت عائشہ رضی اللہ عنہا سے روایت کی ،  انہوں نے کہا :  میں رسول اللہﷺ ک"}
{"hadithnumber": "1146", "text": "۔  نبی اکرمﷺ کی زوجہ حضرت میمونہ رضی اللہ عنہا سے روایت ہے ،   انہوں نے کہا :  رسول اللہﷺ نماز پڑھتے"}
{"hadithnumber": "1147", "text": "حضرت عائشہ  رضی اللہ عنہا سے روایت ہے کہ رسول اللہ ﷺ رات کو نماز پڑھتے اور میں  حیض کی حالت میں آپ ک"}
{"hadithnumber": "1148", "text": "۔  امام مالک نے ابن شہاب  ( زہری )  سے  ،   انہوں نے سعید بن  مسیب سے اور انہوں نے حضرت ابو ہریرہ ‌ر"}
{"hadithnumber": "1149", "text": "۔  یونس اور عقیل بن خالد دونوں نے ابن شہاب  ( زہری )  سے ،  انہوں نے سعید بن مسیب اور ابو سلمہ سے ،"}
{"hadithnumber": "1150", "text": "۔  محمد بن سیرین نے حضرت ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی ،  انہوں نے کہا :  ایک آدمی نے ن"}
{"hadithnumber": "1151", "text": "۔  حضرت ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ رسول اللہﷺ نے فرمایا :  ’’ تم میں سے کوئی شخص"}
{"hadithnumber": "1152", "text": "ابو اسامہ نے ہشام بن عروہ سے ،  انہوں نے اپنے والد سے اور انہوں نے حضرت عمر بن ابی سلمہ  ‌رضی ‌اللہ"}
{"hadithnumber": "1153", "text": "۔  وکیع نے ہشام بن عروہ کی مذکورہ بالا سند سے حدیث سنائی ،  ہاں یہ فرق ہے کہ اس نے متوشحا کہا مشتملا"}
{"hadithnumber": "1154", "text": "حماد بن زید نے ہشام بن عروہ سے ،   انہوں نے  اپنے والد  سے اور انہوں نے حضرت عمر بن ابی سلمہ  ‌رضی ‌"}
{"hadithnumber": "1155", "text": "قتیبہ بن سعید اور عیسیٰ بن حماد نے کہا :  ہمیں لیث نے یحییٰ بن سعید سے حدیث سنائی انہوں نے ابو امامہ"}
{"hadithnumber": "1156", "text": "۔   وکیع نے کہا :  ہمیں سفیان نے ابو زبیر سے حدیث سنائی ،  انہوں نے حضرت جابر  ‌رضی ‌اللہ ‌عنہ ‌ ‌"}
{"hadithnumber": "1157", "text": "۔   محمد بن عبد اللہ بن نمیر نے اپنے والد سے حدیث بیان کی ،  نیز محمد بن مثنیٰ نے عبد الرحمان  سے حد"}
{"hadithnumber": "1158", "text": "عمرو نے کہا کہ ابو زبیر مکی نے مجھے حدیث سنائی کہ انہوں نے جابر بن عبد اللہ رضی اللہ عنہما کو ایک کپ"}
{"hadithnumber": "1159", "text": "۔  عیسیٰ بن یونس نے کہا :  ہمیں اعمش نے ابو سفیان سے حدیث سنائی ،  انہوں نے حضرت جابر  ‌رضی ‌اللہ ‌ع"}
{"hadithnumber": "1160", "text": "۔  ابو بکر بن  ابی شیبہ اور ابو کریب نے کہا :  ہم سے ابو معاویہ نے بیان کیا ،  نیز سوید بن سعید نے ک"}
