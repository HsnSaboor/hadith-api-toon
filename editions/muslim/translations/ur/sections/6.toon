{"hadithnumber": "1818", "text": "حضرت علی بن ابی طالب رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ نبی اکرم صلی اللہ علیہ وسلم نے رات کے وقت ا"}
{"hadithnumber": "1819", "text": "حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روا یت ہے انھوں نے یہ فرمان نبی صلی اللہ علیہ وسلم کی طرف منس"}
{"hadithnumber": "1820", "text": "عبیداللہ نے کہا :  مجھے نافع نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ سے بیان کیا انھوں نے نبی اکرم صلی ا"}
{"hadithnumber": "1821", "text": "ایوب نے نافع سے انھوں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے اور انھوں نے نبی اکرم صلی اللہ علیہ وس"}
{"hadithnumber": "1822", "text": "حضرت جابر رضی اللہ تعالیٰ عنہ  سے روایت ہے انھوں نے کہا :  رسول اللہ صلی اللہ علیہ وسلم  نے فر ما یا"}
{"hadithnumber": "1823", "text": "حضرت ابو موسیٰ  رضی اللہ تعالیٰ عنہ نے نبی اکرم  صلی اللہ علیہ وسلم  سے روایت کی کہ آپ  صلی اللہ علی"}
{"hadithnumber": "1824", "text": "حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روا یت ہے کہ رسول اللہ  صلی اللہ علیہ وسلم  نے فر ما یا  :  "}
{"hadithnumber": "1825", "text": "عبد اللہ سعید نے کہا :  عمر بن عبید اللہ  رضی اللہ تعالیٰ عنہ  کے آزاد کردہ غلام سالم ابو نضرنے ہمیں"}
{"hadithnumber": "1826", "text": "موسیٰ بن عقبہ نے ہمیں حدیث بیان کی  ، کہا :  میں نے ابو نضرسے سنا انھوں نے بسر بن سعید سے اور انھوں"}
{"hadithnumber": "1827", "text": "سعید بن ابی نے ابو سلمہ  ( نم عبد الرحمان بن عوف ) سے انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے"}
{"hadithnumber": "1828", "text": "سعد بن ابرا ہیم سے روایت ہے کہ انھوں نے ابو سلمہ سے سنا  ، وہ حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے ح"}
{"hadithnumber": "1829", "text": "علقمہ سے روایت ہے کہا میں نے ام المومنین !عائشہ رضی اللہ تعالیٰ عنہا  سے سوال کیا اور کہا ام المومنی"}
{"hadithnumber": "1830", "text": "قاسم بن محمد نے حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے روا یت کی ،  انھوں نے کہا : رسول اللہ  صلی اللہ"}
