metadata:
  section_id: 26
  section_name: رسول اللہ صلی اللہ علیہ وسلم کی روٹی کابیان
  hadith_first: 139
  hadith_last: 146

hadiths[8]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
139,"حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، وَمُحَمَّدُ بْنُ بَشَّارٍ، قَالَا: حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ قَالَ: حَدَّثَنَا شُعْبَةُ، عَنْ أَبِي إِسْحَاقَ قَالَ: سَمِعْتُ عَبْدَ الرَّحْمَنِ بْنَ يَزِيدَ، يُحَدِّثُ عَنِ الْأَسْوَدِ بْنِ يَزِيدَ، عَنْ عَائِشَةَ، أَنَّهَا قَالَتْ: ((مَا شَبِعَ آلُ مُحَمَّدٍ صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ مِنْ خُبْزِ الشَّعِيرِ يَوْمَيْنِ مُتَتَابِعَيْنِ حَتَّى قُبِضَ رَسُولُ اللَّهِ صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ))",,,139,,رسول اللہ صلی اللہ علیہ وسلم کی روٹی کابیان
140,"حَدَّثَنَا عَبَّاسُ بْنُ مُحَمَّدٍ الدُّورِيُّ، حَدَّثَنَا يَحْيَى بْنُ أَبِي بُكَيْرٍ ، حَدَّثَنَا حَرِيزُ بْنُ عُثْمَانَ، عَنْ سُلَيْمِ بْنِ عَامِرٍ قَالَ: سَمِعْتُ أَبَا أُمَامَةَ الْبَاهِلِيَّ يَقُولُ: ((مَا كَانَ يَفْضُلُ عَنِ أَهْلِ بَيْتِ رَسُولِ اللَّهِ صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ خُبْزُ الشَّعِيرِ))",,,140,,رسول اللہ صلی اللہ علیہ وسلم کی روٹی کابیان
141,"حَدَّثَنَا عَبْدُ اللَّهِ بْنُ مُعَاوِيَةَ الْجُمَحِيُّ، حَدَّثَنَا ثَابِتُ بْنُ زَيْدٍ، عَنْ هِلَالِ بْنِ خَبَّابٍ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ قَالَ: ((كَانَ رَسُولُ اللَّهِ صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ يَبِيتُ اللَّيَالِيَ الْمُتَتَابِعَةَ طَاوِيًا هُوَ وَأَهْلُهُ لَا يَجِدُونُ عِشَاءً وَكَانَ أَكْثَرُ خُبْزِهِمْ خُبْزَ الشَّعِيرِ))",,,141,,رسول اللہ صلی اللہ علیہ وسلم کی روٹی کابیان
142,"حَدَّثَنَا عَبْدُ اللَّهِ بْنُ عَبْدِ الرَّحْمَنِ ، حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ عَبْدِ الْمَجِيدِ الْحَنَفِيُّ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ عَبْدِ اللَّهِ بْنِ دِينَارٍ ، حَدَّثَنَا أَبُو حَازِمٍ، عَنْ سَهْلِ بْنِ سَعْدٍ، أَنَّهُ قِيلَ لَهُ: أَكَلَ رَسُولُ اللَّهِ صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ النَّقِيَّ؟ - يَعْنِي الْحُوَّارَى - فَقَالَ سَهْلٌ: ((مَا رَأَى رَسُولُ اللَّهِ صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ النَّقِيَّ حَتَّى لَقِيَ اللَّهَ عَزَّ وَجَلَّ تَعَالَى)) ، فَقِيلَ لَهُ: هَلْ كَانَتْ لَكُمْ مَنَاخِلُ عَلَى عَهْدِ رَسُولِ اللَّهِ صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ؟ قَالَ: ((مَا كَانَتْ لَنَا مَنَاخِلُ)) . قِيلَ: كَيْفَ كُنْتُمْ تَصْنَعُونَ بِالشَّعِيرِ؟ قَالَ: ((كُنَّا نَنْفُخُهُ فَيَطِيرُ مِنْهُ مَا طَارَ ثُمَّ نَعْجِنُهُ))",,,142,,رسول اللہ صلی اللہ علیہ وسلم کی روٹی کابیان
143,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ ، حَدَّثَنَا مُعَاذُ بْنُ هِشَامٍ قَالَ: حَدَّثَنِي أَبِي، عَنْ يُونُسَ، عَنْ قَتَادَةَ، عَنْ أَنَسِ بْنِ مَالِكٍ قَالَ: ((مَا أَكَلَ نَبِيُّ اللَّهِ صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ عَلَى خِوَانٍ وَلَا فِي سُكُرَّجَةٍ، وَلَا خُبِزَ لَهُ مُرَقَّقٌ)) قَالَ: فَقُلْتُ لِقَتَادَةَ: فَعَلَامَ كَانُوا يَأْكُلُونَ؟ قَالَ: ((عَلَى هَذِهِ السُّفَرِ)) قَالَ مُحَمَّدُ بْنُ بَشَّارٍ: ((يُونُسُ هَذَا الَّذِي رَوَى عَنْ قَتَادَةَ هُوَ يُونُسُ الْإِسْكَافُ))",,,143,,رسول اللہ صلی اللہ علیہ وسلم کی روٹی کابیان
144,"حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ ، حَدَّثَنَا عَبَّادُ بْنُ عَبَّادٍ الْمُهَلَّبِيُّ، عَنْ مُجَالِدٍ، عَنِ الشَّعْبِيِّ، عَنْ مَسْرُوقٍ قَالَ: دَخَلْتُ عَلَى عَائِشَةَ، فَدَعَتْ لِي بِطَعَامٍ وَقَالَتْ: ((مَا أَشْبَعُ مِنْ طَعَامٍ فَأَشَاءُ أَنْ أَبْكِيَ إِلَّا بَكِيتُ)) . قَالَ: قُلْتُ لِمَ؟ قَالَتْ: ((أَذْكُرُ الْحَالَ الَّتِي فَارَقَ عَلَيْهَا رَسُولُ اللَّهِ صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ الدُّنْيَا، وَاللَّهِ مَا شَبِعَ مِنْ خُبْزٍ وَلَحْمٍ مَرَّتَيْنِ فِي يَوْمٍ وَاحِدٍ))",,,144,,رسول اللہ صلی اللہ علیہ وسلم کی روٹی کابیان
145,"حَدَّثَنَا مَحْمُودُ بْنُ غَيْلَانَ ، حَدَّثَنَا أَبُو دَاوُدَ قَالَ: حَدَّثَنَا شُعْبَةُ، عَنْ أَبِي إِسْحَاقَ قَالَ: سَمِعْتُ عَبْدَ الرَّحْمَنِ بْنَ يَزِيدَ، يُحَدِّثُ، عَنِ الْأَسْوَدِ بْنِ يَزِيدَ، عَنْ عَائِشَةَ، قَالَتْ: ((مَا شَبِعَ رَسُولُ اللَّهِ صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ مِنْ خُبْزِ الشَّعِيرِ يَوْمَيْنِ مُتَتَابِعَيْنِ حَتَّى قُبِضَ))",,,145,,رسول اللہ صلی اللہ علیہ وسلم کی روٹی کابیان
146,"حَدَّثَنَا عَبْدُ اللَّهِ بْنُ عَبْدِ الرَّحْمَنِ ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ عَمْرٍو- أَبُو مَعْمَرٍ-حَدَّثَنَا عَبْدُ الْوَارِثِ، عَنْ سَعِيدِ بْنِ أَبِي عَرُوبَةَ، عَنْ قَتَادَةَ، عَنْ أَنَسٍ قَالَ: ((مَا أَكَلَ رَسُولُ اللَّهِ صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ عَلَى خِوَانٍ وَلَا أَكَلَ خُبْزًا مُرَقَّقًا حَتَّى مَاتَ))",,,146,,رسول اللہ صلی اللہ علیہ وسلم کی روٹی کابیان
