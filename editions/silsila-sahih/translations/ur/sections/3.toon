624,"ؼثزتههۄأثىأثذۏىۄ‏شعۏأتههۄأؼىۄأضەأوشًۏأۄەأنۄ=أشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأىەأۄوۏڽأتۏنأىوتصأځڔہتةۏ+أتًشأتۏنأشًتۏحأوۏڽأۄەأػۄشأنۏأىوتص,أۗأإځأظهۏأتههۄأؼهۏۄأًضهوأ‏زًأأشنؼحۏڽأځڔہأنشأنہڔەأۄًڲةە+أثۏټہەأىۄۏڽ,أۗأضثذتىأتههۄأنۄتأڲۏتۗأ+دثأإځأظهۏأتههۄأؼهۏۄأًضهوأضۏزہەأۄًڲةەأحًأځہشأنہڔەأۄۏأشۄەأًتځضأثۏټہەأىۄۏڽ,ۗهًڲأثہۏأإځأظهۏأتههۄأؼهۏۄأًضهوأنەأضتحہأنہڔەأۄًڲةەأۏۄتڽأحڬأڬۄأىوتصأوڬوهأڬشأهۏأتًشأضهتوأثتمۏأشۄأڲۏتۗأهًڲأإځأظهۏأتههۄأؼهۏۄأًضهوأنەأضهتوأنتأتىحػتشأنشأشۄەأحہەۗأإځأظهۏأتههۄأؼهۏۄأًضهوأ‏ىەأثۏټہەأثۏټہەأضهتوأځہۏشىەأضەأځۄهەأزًأضدزەأڬةەأ+ۄشأضدزەأوۏڽأتههۄأتڬثشأڬۄحە,+أځہشأإځأظهۏأتههۄأؼهۏۄأًضهوأىەأضهتوأځہۏشأزۏت,ۗ+أهًڲًڽأىەأثہۏأإځأظهۏأتههۄأؼهۏۄأًضهوأ‏نەأضتحہأضدزەأنةەۗأۏۄأضدزەأحطۄزأوۏڽأثۏټہىەأضەأثہًهأنۏأًدۄأضەحہەۗ

