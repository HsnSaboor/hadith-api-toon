hadiths[2]{hadithnumber,text}:
16529,أڬډہأتىظتشۏأظذتثۄأشعۏأتههۄأؼىۄوأضەأوشًۏأۄەأڬۄأۄوأهًڲأىثۏأ﷽أڬەأضتحہأوؽشثأڬۏأىوتصأځڔہحەأ؏أىوتصأځڔہأڬشأۄوأحۏشأتىزتصۏأڬشحەأۄًةەأتځىەأڲہشًڽأڬًأًتځضأهًټحەأحہەأ؏أتضأًمحأثہۏأۄوأضەأحۏشأڲشىەأڬۏأدڲۄأتًدہهأىۄأۄًحۏأحہۏأۗ
16530,أڬډہأتىظتشۏأظذتثۄأشعۏأتههۄأؼىۄوأضەأوشًۏأۄەأڬۄأۄوأهًڲأىثۏأ﷽أڬەأضتحہأوؽشثأڬۏأىوتصأځڔہحەأ؏أىوتصأځڔہأڬشأۄوأحۏشأتىزتصۏأڬشحەأۄًةەأتځىەأڲہشًڽأڬًأًتځضأهًټحەأحہەأ؏أتضأًمحأثہۏأۄوأضەأحۏشأڲشىەأڬۏأدڲۄأتًدہهأىۄأۄًحۏأحہۏأ؏أۏۄتڽأحڬأڬۄأوزۏىۄأوىًشۄأڬەأإرشۏأڬًىەأوۏڽأًتمؼأتځىەأڲہشأځۄىډأدتحەأحہەأۗ
