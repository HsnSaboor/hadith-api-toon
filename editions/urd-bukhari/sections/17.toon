hadiths[13]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
1067,ہم سے محمد بن بشار نے بیان کیا، کہا کہ ہم سے غندر محمد بن جعفر نے بیان کیا کہا کہ ہم سے شعبہ نے بیان,,,,,1067
1068,ہم سے محمد بن یوسف فریابی نے بیان کیا، انہوں نے کہا کہ ہم سے سفیان ثوری نے بیان کیا، انہوں نے سعد بن,,,,,1068
1069,ہم سے سلیمان بن حرب اور ابوالنعمان بن فضل نے بیان کیا، ان دونوں نے کہا کہ ہم سے حماد بن زید نے بیان ,,,,,1069
1070,ہم سے حفص بن عمر نے بیان کیا، کہا کہ ہم سے شعبہ نے، ابواسحاق سے بیان کیا، ان سے اسود نے، ان سے عبدال,,,,,1070
1071,ہم سے مسدد بن مسرہد نے بیان کیا، کہا کہ ہم سے عبدالوارث نے بیان کیا، کہا ہم سے ایوب سختیانی نے بیان ,,,,,1071
1072,ہم سے سلیمان بن داؤد ابوالربیع نے بیان کیا، انہوں نے کہا کہ ہم سے اسماعیل بن جعفر نے بیان کیا، کہا ک,,,,,1072
1073,ہم سے آدم بن ابی ایاس نے بیان کیا، کہا کہ ہم سے ابن ابی ذئب نے بیان کیا، کہا کہ ہم سے یزید بن عبدالل,,,,,1073
1074,ہم سے مسلم بن ابراہیم اور معاذ بن فضالہ نے بیان کیا، انہوں نے کہا کہ ہم سے ہشام بن ابی عبداللہ دستوا,,,,,1074
1075,ہم سے مسدد بن مسرہد نے بیان کیا، کہا کہ ہم سے یحییٰ بن سعید قطان نے بیان کیا، کہا کہ ہم سے عبیداللہ ,,,,,1075
1076,ہم سے بشر بن آدم نے بیان کیا، کہا کہ ہم سے علی بن مسہر نے بیان کیا، کہا کہ ہمیں عبیداللہ عمری نے خبر,,,,,1076
1077,ہم سے ابراہیم بن موسیٰ نے بیان کیا، انہوں نے کہا کہ ہمیں ہشام بن یوسف نے خبر دی اور انہیں ابن جریج ن,,,,,1077
1078,ہم سے مسدد بن مسرہد نے بیان کیا، کہا کہ ہم سے معتمر بن سلیمان نے بیان کیا، کہا کہ میں نے اپنے باپ سے,,,,,1078
1079,ہم سے صدقہ بن فضل نے بیان کیا، ان سے یحییٰ بن سعیدقطان نے بیان کیا، ان سے عبیداللہ نے، ان سے نافع نے,,,,,1079
