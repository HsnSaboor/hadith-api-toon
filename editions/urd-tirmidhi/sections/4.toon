metadata:

hadiths[42]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
488,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”سب سے بہتر دن جس میں سورج",,,,,488
489,"انس بن مالک رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جمعہ کے روز اس گھڑی",,,,,489
490,"عمرو بن عوف مزنی رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جمعہ میں ایک گ",,,,,490
491,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”سب سے بہتر دن جس میں سور",,,,,491
492,"عبداللہ بن عمر رضی الله عنہما سے روایت کہ  انہوں نے نبی اکرم صلی اللہ علیہ وسلم کو فرماتے سنا: ”جو ج",,,,,492
493,"نیز ابن شہاب زہری سے یہ حدیث بطریق: «الزهري عن عبد الله بن عبد الله بن عمر عن أبيه عن النبي صلى الله",,,,,493
494,عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  عمر بن خطاب رضی الله عنہ جمعہ کے روز خطبہ دے رہے تھے کہ ا,,,,,494
495,"اس سند سے بھی  زہری سے یہی حدیث مروی ہے۔ اور مالک نے بھی یہ حدیث بطریق: «عن الزہری عن سالم» ‏‏‏‏ روا",,,,,495
496,"اوس بن اوس رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے جمعہ کے دن غسل ک",,,,,496
497,"سمرہ بن جندب رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے جمعہ کے دن وضو",,,,,497
498,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم فرمایا: ”جس نے وضو کیا اور اچھی طرح ",,,,,498
499,"ابوہریرہ رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے جمعہ کے روز جنا",,,,,499
500,"ابوالجعد ضمری رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جو جمعہ تین بار ",,,,,500
501,اہل قباء میں سے ایک شخص اپنے والد سے روایت کرتا ہے - اس کے والد صحابہ میں سے ہیں - وہ کہتے ہیں کہ  ن,,,,,501
502,میں نے احمد بن حسن کو کہتے سنا کہ  ہم لوگ احمد بن حنبل کے پاس تھے تو لوگوں نے ذکر کیا کہ جمعہ کس پر ,,,,,502
503,انس بن مالک رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم جمعہ کی نماز اس وقت پڑھتے جب سو,,,,,503
504,اس سند سے بھی  انس رضی الله عنہ نبی اکرم صلی اللہ علیہ وسلم سے اسی طرح روایت کرتے ہیں۔ \r\n\r\nامام ترمذ,,,,,504
505,عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کھجور کے ایک تنے پر  ( کھڑے ہ,,,,,505
506,عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  اکرم صلی اللہ علیہ وسلم جمعہ کے دن خطبہ دیتے پھر  ( بیچ م,,,,,506
507,جابر بن سمرہ رضی الله عنہ کہتے ہیں کہ  میں نبی اکرم صلی اللہ علیہ وسلم کے ساتھ نماز پڑھتا تھا تو آپ ,,,,,507
508,"یعلیٰ بن امیہ رضی الله عنہ کہتے ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم کو منبر پر پڑھتے سنا: «ون",,,,,508
509,عبداللہ بن مسعود رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم جب منبر پر بیٹھتے تو ہم اپنا,,,,,509
510,جابر بن عبداللہ رضی الله عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم جمعہ کے دن خطبہ دے رہے تھے ک,,,,,510
511,عیاض بن عبداللہ بن ابی سرح سے روایت ہے کہ  ابو سعید خدری رضی الله عنہ جمعہ کے دن  ( مسجد میں )  داخل,,,,,511
512,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جس نے جمعہ کے دن امام کے ",,,,,512
513,"معاذ بن انس جہنی رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جمعہ کے دن جس نے",,,,,513
514,معاذ بن انس جہنی رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے جمعہ کے دن جب کہ امام خطبہ,,,,,514
515,حصین کہتے ہیں کہ  بشر بن مروان خطبہ دے رہے تھے، انہوں نے دعا ۱؎ کے لیے اپنے دونوں ہاتھ اٹھائے، تو می,,,,,515
516,سائب بن یزید رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم اور ابوبکر و عمر رضی الله عنہما ,,,,,516
517,انس بن مالک رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم ضرورت کی بات اس وقت کرتے جب آپ منب,,,,,517
518,انس رضی الله عنہ کہتے ہیں کہ  نماز کھڑی ہو جانے کے بعد میں نے نبی اکرم صلی اللہ علیہ وسلم کو دیکھا ک,,,,,518
519,"عبیداللہ بن ابی رافع کہتے ہیں:  مروان نے ابوہریرہ رضی الله عنہ کو مدینے میں اپنا نائب مقرر کیا اور و",,,,,519
520,عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم جمعہ کے دن فجر کی نماز میں ,,,,,520
521,عبداللہ بن عمر رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم جمعہ کے بعد دو رکعت  ( سنت,,,,,521
522,نافع سے روایت ہے  ابن عمر رضی الله عنہما جب جمعہ پڑھ لیتے تو  ( گھر )  واپس آتے اور دو رکعت اپنے گھ,,,,,522
523,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جو تم میں سے جمعہ کے بعد",,,,,523
524,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جس نے نماز میں ایک رکعت پ",,,,,524
525,سہل بن سعد رضی الله عنہ کہتے ہیں  ہم لوگ رسول اللہ صلی اللہ علیہ وسلم کے زمانے میں جمعہ کے بعد ہی کھ,,,,,525
526,"عبداللہ بن عمر رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جب تم میں سے ک",,,,,526
527,عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے عبداللہ بن رواحہ رضی الله,,,,,527
528,"براء بن عازب رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”مسلمانوں پر لازم ہ",,,,,528
529,"اس سند سے بھی  اسی طرح مروی ہے۔ \r\n\r\nامام ترمذی کہتے ہیں: ۱- براء رضی الله عنہ کی حدیث حسن ہے، ۲- ہشی",,,,,529
