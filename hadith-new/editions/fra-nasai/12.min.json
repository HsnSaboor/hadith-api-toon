{"metadata":{"name":"Sunan an Nasai","section":{"1":"The Book of Purification"},"section_detail":{"1":{"hadithnumber_first":1,"hadithnumber_last":324,"arabicnumber_first":1,"arabicnumber_last":324}}},"hadiths":[{"hadithnumber":12,"arabicnumber":12,"text":"Rapporté par Ibn 'Umar : Le Messager d’Allah (ﷺ) a dit : \"Les actes liés à la fitrah sont : couper les ongles, tailler la moustache et raser le pubis","grades":[{"name":"Abu Ghuddah","grade":"Sahih"},{"name":"Al-Albani","grade":"Sahih"},{"name":"Zubair Ali Zai","grade":"Sahih Bukhari"}],"reference":{"book":1,"hadith":12}}]}