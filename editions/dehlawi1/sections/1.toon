metadata:
  section_id: 1

hadiths[40]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}:
1,لیس الخبر کالمعاینة,,,,,
2,الحرب خدعة,,,,,
3,المسلم مراة المسلم,,,,,
4,المستشار موتمن,,,,,
5,الدال علی الخیر کفاعله,,,,,
6,استعینوا علی الحوايج بالکتمان,,,,,
7,اتقوا النار ولو بشق تمرة,,,,,
8,الدنیا سجن المومن و جنة الکافر,,,,,
9,الحیاء خیر کله,,,,,
10,عدة المومن کاخذ الکف,,,,,
11,لا یحل لمومن ان یجهر اخاه فوق ثلاثة ایام,,,,,
12,لیس منا من غشنا,,,,,
13,ما قل وكفى خير مما كثر والهى,,,,,
14,الراجع في هبته کالراجع في قیيه,,,,,
15,البلاء موکل بالمنطق,,,,,
16,الناس کاسنان المشط,,,,,
17,الغنى غنى النفس,,,,,
18,السعید من وعظ بغیره,,,,,
19,و ان من الشعر لحکمة وان من البیان لسحرا,,,,,
20,عفو الملوك ابقاء للملك,,,,,
21,المرء مع من احب,,,,,
22,ما هلك امرو عرف قدره,,,,,
23,الولد للفراش و للعاهر الحجر,,,,,
24,الید العلیا خیر من الید السفلی,,,,,
25,لا شکر الله من لا یشکر الناس,,,,,
26,حبك الشيء یعمي و یصم,,,,,
27,جبلت القلوب علی حب من احسن الیها و بغض من اساء الیها,,,,,
28,التايب من الذنب کمن لا ذنب له,,,,,
29,الشاهد یری ما لا یراه الغايب,,,,,
30,اذا جاءکم کریم قوم فاکرموه,,,,,
31,الیمین الفاجرة تدع الدیار البلاقع,,,,,
32,من قتل دون ماله فهو شهید,,,,,
33,الاعمال بالنیة,,,,,
34,سید القوم خادمهم,,,,,
35,خیر الامور اوسطها,,,,,
36,اللهم بارك فی امتی فی بکورها یوم الخمیس,,,,,
37,کاد الفقر ان یکون کفرا,,,,,
38,السفر قطعة من العذاب,,,,,
39,خیر زاد التقوی,,,,,
40,المجالس بالامانة,,,,,
