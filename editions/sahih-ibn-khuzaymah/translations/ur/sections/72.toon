hadiths[7]{hadithnumber,text}:
2293,"ذعشحأتثًضؼۏزأرزشۏأشعۏأتههۄأؼىۄأىثۏأڬشۏوأ﷽أضەأشًتۏحأڬشحەأۄۏڽأڬۄأإځأىەألشوتۏتأ=““أځتىډأتًمۏۄأضەأڬوأډتىزۏأوۏڽأصڬًٳۆأىۄۏڽأۄەأۗ‛‛

[تخریج]: ( 2293 ) اسنادہ صحیح ، تقدم تخریجہ برقم : 2263 ۔"
2294,"ذعشحأتثًضؼۏزأرزشۏأشعۏأتههۄأؼىۄأضەأشًتۏحأۄەأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أځتىډأتًمۏۄأضەأڬوأډتىزۏأوۏڽأصڬًٳۆأًتدثأىۄۏڽأۄەأتًشأځتىډأضەأڬوأتًىټًڽأوۏڽأصڬًٳۆألشعأىۄۏڽأۄەأتًشأىۄأځتىډأًضمأضەأڬوأتىتدأوۏڽأصڬًٳۆأۄەأۗ‛‛

[تخریج]: (2294) اسنادہ صحیح ، تقدم تخریجہ برقم : 2263 ۔"
2295,"ذعشحأتثًضؼۏزأرزشۏأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أځتىډأًضمأضەأڬوأؽهەأوۏڽأصڬًٳۆأىۄۏڽأۄەأتًشأىۄأځتىډأتًمۏۄأضەأڬوأډتىزۏأوۏڽأصڬًٳۆأۄەأتًشأ+أځتىډأ,أتًمۏەأزًأضًأزشۄوأۄۏڽأۗ‛‛

[تخریج]: (2295) اسنادہ صحیح ، تقدم تخریجہ برقم : 2263 ۔"
2296,"ذعشحأتىضأثىأوتهڬأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأڬۄأدثأذعشحأتثًثڬشأظزۏمأشعۏأتههۄأؼىۄأرهۏلۄأومششأۄًةەأحًأتىۄًڽأىەأوۏشەأهۏەأۏۄأحذشۏشأهڬہًتةۏأ=““أ®ثٓضٕوٓأتههٔٳۄٓأتهشّٔذٕوٳىٓأتهشّٔذٓۏٕوٓ¾أ‛‛أۏۄأصڬًٳۆأڬەأًۄألشتةعأۄۏڽأدًأشضًهأتههۄأ﷽أىەأوضهوتىًڽأځشألشعأڬۏەأۄۏڽأتًشأدىأڬتأذڬوأتههۄأحؼتهۏٳأىەأتځىەأشضًهأڬًأزۏتأۄەأۗ‛‛أځہشأشتًۏًڽأىەأوڬوهأذزۏخأثۏتىأڬۏأتًشأۏۄأتهلتػأشًتۏحأڬۏەأ““أډتىزۏأوۏڽأډتهۏضًتڽأذظۄأصڬًٳۆأًتدثأۄەأهۏڬىأتڲشأظشلأتۏڬأضًأىًەأزشۄوأۄًڽأحًأتىأوۏڽأصڬًٳۆأًتدثأىۄۏڽأۄەأ®تهتٔ¾أۏۄأڬۄأډتىزۏأڬتأوتهڬأتځىۏأرًطۏأضەأڬډہأتزتأڬشأزەأۗأدىتثأتثًوًضۏٳأڬۄحەأۄۏڽأ=““أتڲشأوتهأظشلأتۏڬأضًأىًەأزشۄوأۄًڽأۗ‛‛

[تخریج]: (2296) اسنادہ صحیح ، تقدم تخریجہ برقم : 2261 ۔"
2297,"ذعشحأؼهۏأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أۄشأډتهۏضأزشۄوًڽأوۏڽأضەأتۏڬأزشۄوأصڬًٳۆأتزتأڬشًأتًشأزًأضًأضەأڬوأزشۄوًڽأوۏڽأصڬًٳۆأىۄۏڽأۄەأځہشأدثأزًأضًأزشۄوأۄًأدتةۏڽأحًأتىأوۏڽأځتىډأزشۄوأصڬًٳۆأۄەأتًشأدًأتضأضەأصتةزأۄًأحًأتضأځشأثہۏأتضۏأذضتثأضەأ+أډتهۏضًتڽأذظۄأ,أصڬًٳۆأًتدثأۄەأۗ‛‛

[تخریج]: (2297) اسنادہ حسن ، تقدم تخریجہ برقم : 2262 ۔"
2298,"ذعشحأتثًضؼۏزأرزشۏأشعۏأتههۄأؼىۄأشضًهأتههۄأ﷽أضەأشًتۏحأڬشحەأۄۏڽأڬۄأإځأىەألشوتۏتأ=““أځتىډأتًمۏۄأضەأڬوأډتىزۏأوۏڽأصڬًٳۆأًتدثأىۄۏڽأۄەأۗ‛‛أځہشأوڬوهأذزۏخأثۏتىأڬۏأۗ

[تخریج]: (2298) اسنادہ صحیح ، تقدم تخریجہ من حدیث ابی سعید الخدری رضی اللہ عنہ ، برقم : 2263 ۔"
2299,"ذعشحأدتثشأثىأؼثزتههۄأشعۏأتههۄأؼىۄوتأشضًهأتههۄأ﷽أضەأشًتۏحأڬشحەأۄۏڽأڬۄأځتىډأتًمۏۄأضەأڬوأډتىزۏأوۏڽأصڬًٳۆأىۄۏڽأۄەأتًشأځتىډأضەأڬوأتًىټًڽأوۏڽأثہۏأصڬًٳۆأىۄۏڽأۄەأتًشأځتىډأًضمأضەأڬوأڬہدًشًڽأوۏڽأثہۏأصڬًٳۆأىۄۏڽأۄەأۗ‛‛أأتثًثڬشأتثىأرصۏوۄأڬۄحەأۄۏڽأۏۄأذزۏخأتثىأًۄثأڬۏأڬحتثأوۏڽأوتهڬأؼىأوذوزأ أؼىأتثۏأضؼۏزأؼىأتهىثۏأڬەأثؼزأۄەأۗأؼۏتعأًتهۏأذزۏخأثہۏأتثًضؼۏزأڬۏأذزۏخأڬەأوخهأۄەأۗ

[تخریج]: (2299) صحیح مسلم ، کتاب الزکاۃ ، باب لیس فیما دون خمسۃ اوسق صدقۃ ، حدیث : 980 ۔"
