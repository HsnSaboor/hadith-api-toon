3862,حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ بَكْرٍ السَّهْمِيُّ،‏‏‏‏ عَنْ هِشَامٍ ال,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan Lighairihi; Zubair Ali Zai: Hasan,takhreej: «سنن ابی داود/الصلاة ۳۶۴ (۱۵۳۶)، سنن الترمذی/البروالصلة ۷ (۱۹۰۵)،(تحفة الأشراف:۱۴۸۷۳)، وقد أخرجہ: مسند احمد (۲/۲۵۸،۳۴۸،۴۷۸،۵۱۷،۵۲۳),3862,,Supplication
3863,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى،‏‏‏‏ حَدَّثَنَا أَبُو سَلَمَةَ،‏‏‏‏ حَدَّثَتْنَا حُبَابَةُ ابْنَةُ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۸۳۱۵، ومصباح الزجاجة:۱۳۵۶),3863,,Supplication
3864,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَفَّانُ،‏‏‏‏ حَدَّثَنَا حَمَّادُ بْنُ س,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن ابی داود/الطہارة ۴۵ (۹۶)،(تحفة الأشراف:۹۶۶۴)، وقد أخرجہ: مسند احمد (۴/۸۶،۱۸۷،۵/۵۵),3864,,Supplication
3865,حَدَّثَنَا أَبُو بِشْرٍ بَكْرُ بْنُ خَلَفٍ،‏‏‏‏ حَدَّثَنَا ابْنُ أَبِي عَدِيٍّ،‏‏‏‏ عَنْ جَعْفَرِ بْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Hasan,takhreej: «سنن ابی داود/الصلاة ۳۵۸ (۱۴۸۸)، سنن الترمذی/الدعوات ۱۰۵ (۳۵۵۶)،(تحفة الأشراف:۴۴۹۴)، وقد أخرجہ: مسند احمد (۵/۴۳۸),3865,,Supplication
3866,حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ،‏‏‏‏ حَدَّثَنَا عَائِذُ بْنُ حَبِيبٍ،‏‏‏‏ عَنْ صَالِحِ بْنِ حَ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: «(یہ حدیث مکرر ہے، ملاحظہ ہو: نمبر:۱۱۸۱),3866,,Supplication
3867,حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا الْحَسَنُ بْنُ مُوسَى،‏‏‏‏ حَدَّثَنَا حَمَّادُ بْنُ سَلَمَةَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن ابی داود/الأدب ۱۱۰ (۵۰۷۷)،(تحفة الأشراف:۱۲۰۷۶)، وقد أخرجہ: مسند احمد (۵/۳۵۶،۴۲۰),3867,,Supplication
3868,حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ،‏‏‏‏ حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ أَبِي حَازِمٍ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۶۹۵)، وقد أخرجہ: سنن ابی داود/الأدب ۱۱۰ (۵۰۶۸)، سنن الترمذی/الدعوات ۱۳ (۳۳۹۱)، مسند احمد (۲/۳۵۴،۵۲۲),3868,,Supplication
3869,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ،‏‏‏‏ حَدَّثَنَا أَبُو دَاوُدَ،‏‏‏‏ حَدَّثَنَا ابْنُ أَبِي الزِّنَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الأدب ۱۱۰ (۵۰۸۸،۵۰۸۹)، سنن الترمذی/الدعوات ۱۳ (۳۳۸۸)،(تحفة الأشراف:۹۷۷۸)، وقد أخرجہ: مسند احمد (۱/۶۲،۷۲),3869,,Supplication
3870,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ،‏‏‏‏ حَدَّثَنَا مِ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۰۵۰، ومصباح الزجاجة:۱۳۵۷)، وقد أخرجہ: سنن ابی داود/الأدب ۱۱۰ (۵۰۷۲)، مسند احمد (۴/۳۳۷،۵/۳۶۷),3870,,Supplication
3871,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ الطَّنَافِسِيُّ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ حَدَّثَنَا عُبَادَةُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن ابی داود/الأدب ۱۱۰ (۵۰۷۴)، سنن النسائی/الاستعاذة ۵۹ (۵۵۳۱)، عمل الیوم واللیلة ۱۸۱ (۵۶۶)،(تحفة الأشراف:۶۶۷۳)وقد أخرجہ: مسند احمد (۲/۲۵),3871,,Supplication
3872,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا إِبْرَاهِيمُ بْنُ عُيَيْنَةَ،‏‏‏‏ حَدَّثَنَا الْوَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن ابی داود/الأدب ۱۱۰ (۵۰۷۰)،(تحفة الأشراف:۲۰۰۴)، وقد أخرجہ: مسند احمد (۵/۳۵۶),3872,,Supplication
3873,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الْمَلِكِ بْنِ أَبِي الشَّوَارِبِ،‏‏‏‏ حَدَّثَنَا عَبْدُ الْعَزِيزِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۷۳۳)، وقد أخرجہ: صحیح مسلم/الذکر والدعاء ۱۷ (۲۷۱۳)، سنن ابی داود/الأدب ۱۰۷ (۵۰۵۱)، سنن الترمذی/الدعوات ۱۹ (۳۴۰۰)، مسند احمد (۲/۳۸۱),3873,,Supplication
3874,حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ،‏‏‏‏ عَنْ عُبَيْدِ اللَّهِ،‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الدعوات ۱۳ (۶۳۲۰ تعلیقاً)، التوحید ۱۳ (۷۳۹۳ تعلیقاً)،(تحفة الأشراف:۱۲۹۸۴)، وقد أخرجہ: صحیح مسلم/الذکروالدعاء ۱۷ (۲۷۱۴)، مسند احمد (۲/۲۸۳،۴۳۲،۲۹۵)، سنن الدارمی/الاستئذان ۵۱ (۲۷۲۶),3874,,Supplication
3875,حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا يُونُسُ بْنُ مُحَمَّدٍ،‏‏‏‏ وَسَعِيدُ بْنُ شُرَحْبِيلَ،‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الدعوات ۱۲ (۶۳۱۹)، سنن الترمذی/الدعوات ۲۱ (۳۴۰۲)، سنن ابی داود/الأدب ۱۰۷ (۵۰۵۶)،(تحفة الأشراف:۱۶۵۳۷)، وقد أخرجہ: مسند احمد (۶/۱۱۶،۱۵۴),3875,,Supplication
3876,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ حَدَّثَنَا سُفْيَانُ،‏‏‏‏ عَنْ أَبِي,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۸۵۲)، وقد أخرجہ: صحیح البخاری/الوضوء ۷۵ (۲۴۷)، صحیح مسلم/الذکر والدعاء ۱۷ (۲۷۱۰)، سنن الترمذی/الدعوات ۱۶ (۳۳۹۴)، مسند احمد (۴/ ۲۸۹،۲۹۸،۳۰۳)، سنن الدارمی/ الاستئذان ۵۱ (۲۷۲۵),3876,,Supplication
3877,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ إِسْرَائِيلَ،‏‏‏‏ عَنْ أَبِي إِس,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۶۱۷، ومصباح الزجاجة:۱۳۵۸)، وقد أخرجہ: مسند احمد (۱/۳۹۴،۴۰۰،۴۱۴،۴۴۳),3877,,Supplication
3878,حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ الدِّمَشْقِيُّ،‏‏‏‏ حَدَّثَنَا الْوَلِيدُ بْنُ مُسْل,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/التہجد ۲۱ (۱۱۵۴)، سنن ابی داود/الأدب ۱۰۸ (۵۰۶۰)، سنن الترمذی/الدعوات ۲۶ (۳۴۱۴)،(تحفة الأشراف:۵۰۷۴)، وقد أخرجہ: سنن الدارمی/الاستئذان ۵۳ (۲۷۲۹),3878,,Supplication
3879,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا مُعَاوِيَةُ بْنُ هِشَامٍ،‏‏‏‏ أَنْبَأَنَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: «صحیح مسلم/الصلاة ۴۳ (۴۸۹)، سنن ابی داود/الصلاة ۳۱۲ (۱۳۲۰)، سنن الترمذی/الدعوات ۷ (۳۴۱۶)، سنن النسائی/التطبیق ۷۹ (۱۱۳۹)،(تحفة الأشراف:۳۶۰۳)، وقد أخرجہ: مسند احمد (۴/۴۹،۵۷),3879,,Supplication
3880,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ حَدَّثَنَا سُفْيَانُ،‏‏‏‏ عَنْ عَبْدِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الدعوات ۷ (۶۳۱۲)، التوحید ۱۳ (۷۳۹۴)، سنن ابی داود/الأدب ۱۰۷ (۵۰۴۹)، سنن الترمذی/الدعوات ۲۸ (۳۴۱۷)،(تحفة الأشراف:۳۳۰۸)، وقد أخرجہ: مسند احمد (۵/۱۵۴،۳۸۵،۳۸۷،۳۹۷،۳۹۹،۴۰۷)، سنن الدارمی/الاستئذان ۵۳ (۲۷۲۸),3880,,Supplication
3881,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا أَبُو الْحُسَيْنِ،‏‏‏‏ عَنْ حَمَّادِ بْنِ سَلَمَةَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الأدب ۱۰۵ (۵۰۴۲)،(تحفة الأشراف:۱۱۳۷۱)، وقد أخرجہ: مسند احمد (۵/ ۲۳۴،۲۳۵،۲۴۴),3881,,Supplication
3882,حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ . ح وحَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الصلاة ۳۶۱ (۱۵۲۵)،(تحفة الأشراف:۱۵۷۵۷)، وقد أخرجہ: مسند احمد (۶/۳۶),3882,,Supplication
3883,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ هِشَامٍ صَاحِبِ الدَّسْتُوَائِيّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الدعوات ۲۷ (۶۴۵،۶۳۴۶)، صحیح مسلم/الذکروالدعاء ۲۱ (۲۷۳۰)، سنن الترمذی/الدعوات ۴۰،(۳۴۳۵)،(تحفة الأشراف:۵۴۲۰)، وقد أخرجہ: مسند احمد (۱/۲۲۸،۲۵۴،۲۵۸،۲۵۹،۲۶۸،۲۸۰،۲۸۴،۳۳۹،۲۵۶),3883,,Supplication
3884,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَبِيدَةُ بْنُ حُمَيْدٍ،‏‏‏‏ عَنْ مَنْصُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الأدب ۱۱۲ (۵۰۹۴)، سنن الترمذی/الدعوات ۳۵ (۳۴۲۷)، سنن النسائی/الاستعاذة ۲۹ (۵۴۸۸)،۶۴ (۵۵۴۱)،(تحفة الأشراف:۱۸۱۶۸)، وقد أخرجہ: مسند احمد (۶/۳۰۶،۳۱۸،۳۲۲),3884,,Supplication
3885,حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ،‏‏‏‏ حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِيل،‏‏‏‏ عَنْ ع,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۶۸۹، ومصباح الزجاجة:۱۳۵۹),3885,,Supplication
3886,حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ الدِّمَشْقِيُّ،‏‏‏‏ حَدَّثَنَا ابْنُ أَبِي فُدَيْكٍ،,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۳۹۷۲، ومصباح الزجاجة:۱۳۶۰),3886,,Supplication
3887,حَدَّثَنَا أَبُو بِشْرٍ بَكْرُ بْنُ خَلَفٍ،‏‏‏‏ حَدَّثَنَا أَبُو عَاصِمٍ،‏‏‏‏ عَنْ ابْنِ جُرَيْجٍ،‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الأشربة ۱۳ (۲۰۱۸)، سنن ابی داود/الأطعمة ۱۶ (۳۷۶۵)،(تحفة الأشراف:۲۷۹۷)، وقد أخرجہ: مسند احمد (۳/۳۴۶،۳۸۳),3887,,Supplication
3888,حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ سُلَيْمَانَ،‏‏‏‏ وَأَبُو مُعَاوِيَةَ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/المناسک ۷۵ (۱۳۴۳)، سنن الترمذی/الدعوات ۴۲ (۳۴۳۹)، سنن النسائی/الاستعاذة ۴۱ (۵۵۰۰)،(تحفة الأشراف:۵۳۲۰)، وقد أخرجہ: مسند احمد (۵/۸۲،۸۳)، سنن الدارمی/الاستئذان ۴۲ (۲۷۱۴),3888,,Supplication
3889,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا يَزِيدُ بْنُ الْمِقْدَامِ بْنِ شُرَيْحٍ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن ابی داود/الأدب ۱۱۳ (۵۰۹۹)، سنن النسائی/الاستسقاء ۱۵ (۱۵۲۲)،(تحفة الأشراف:۱۶۱۴۶)، وقد أخرجہ: صحیح البخاری/بدء الخلق ۵ (۳۲۰۶)، تفسیرسورةالأحقاف ۲ (۴۸۲۹)، الأدب ۶۸ (۵۰۹۹)، صحیح مسلم/الاستسقاء ۳ (۸۹۹)، سنن الترمذی/تفسیرالقرآن ۴۶ (۳۲۵۷)، مسند احمد (۶/۱۹۰),3889,,Supplication
3890,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ،‏‏‏‏ حَدَّثَنَا عَبْدُ الْحَمِيدِ بْنُ حَبِيبِ بْنِ أَبِي الْعِشْرِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الاستسقاء ۲۳ (۱۰۳۲)،(تحفة الأشراف:۱۷۵۵۸)، وقد أخرجہ: مسند احمد (۶/۹۰،۱۱۹،۱۲۹),3890,,Supplication
3891,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ،‏‏‏‏ عَنْ ابْنِ جُر,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/ الاستسقاء ۳ (۸۹۹)، سنن الترمذی/الدعوات ۴۲ (۳۴۴۹)،(تحفة الأشراف:۱۷۳۸۵)، وقد أخرجہ: مسند احمد (۶/۲۴۰),3891,,Supplication
3892,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ خَارِجَةَ بْنِ مُصْعَبٍ،‏‏‏‏ عَن,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/الدعوات ۳۸ (۳۴۳۱)،(تحفة الأشراف:۶۷۸۷،۱۰۵۲۸),3892,,Supplication
