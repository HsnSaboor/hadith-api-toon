{"hadithnumber": "5064", "text": "ابوخثیمہ زہیر (  بن معاویہ )  نے اسود بن قیس سے حدیث بیان کی ، کہا : مجھے حضرت جندب بن سفیان ( بجلی"}
{"hadithnumber": "5065", "text": "ابو احوص سلام بن سلیم نے اسود بن قیس سے ، انھوں نے حضرت جندب بن سفیان  رضی اللہ تعالیٰ عنہ  سے  روای"}
{"hadithnumber": "5066", "text": "ابو عوانہ اور ابن عینیہ نے اسود بن قیس سے اسی سند کے ساتھ روایت کی اور دونوں نے کہا؛ \" اللہ کے نام پ"}
{"hadithnumber": "5067", "text": "عبیداللہ کے والد معاذ نے کہا :  ہمیں شعبہ نے اسود بن قیس سے حدیث بیا ن کی ، انھوں نے جندب بجلی  رضی"}
{"hadithnumber": "5068", "text": "محمد بن جعفر نے کہا : ہمیں شعبہ نے اسی سند کے ساتھ اسی کے مانند روایت کی ۔"}
{"hadithnumber": "5069", "text": "مطرف نے عامر ( شعبی )  سے  ، انھوں نے حضرت براء رضی اللہ تعالیٰ عنہ  سے روایت کی  ، کہا :  میرے مامو"}
{"hadithnumber": "5070", "text": "ہشیم نے داود سے  ، انھوں نے  ( عامر )  شعبی سے  ، انھوں نے حضرت براء بن عازب رضی اللہ تعالیٰ عنہ  سے"}
{"hadithnumber": "5071", "text": "ابن ابی عدی داؤد سے ،  انھوں نے  ( عامر )  شعبی سے اور انھوں نے حضرت ابراء بن عازب رضی اللہ تعالیٰ ع"}
{"hadithnumber": "5072", "text": "فراس نے عامر سے ،  انھوں نے حضرت براء  رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہا  :  رسول اللہ  صلی ال"}
{"hadithnumber": "5073", "text": "محمد بن جعفر نے کہا  :  ہمیں شعبہ نے زبید یا می سے حدیث بیان کی  ، انھوں نے حضرت براء بن عازب رضی ال"}
{"hadithnumber": "5074", "text": "عبید اللہ کے والد معاذ نے کہا  :  ہمیں شعبہ نے زبید سے حدیث بیان کی  ، انھوں نے شعبی سے سنا  ، انھوں"}
{"hadithnumber": "5075", "text": "منصور نے شعبی سے ،  انھوں نے حضرت برا ء بن عازب  رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہا  :  رسول ال"}
{"hadithnumber": "5076", "text": "عاصم احول  نے شعبی سے روایت کی ،  کہا  :  مجھے حضرت برا ء بن عازب  رضی اللہ تعالیٰ عنہ  نے حدیث سنا"}
{"hadithnumber": "5077", "text": "محمد بن جریر نے کہا  :  ہمیں شعبہ نے سلمہ سے حدیث بیان کی ،  انھوں نے ابو جحیفہ  رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "5078", "text": "وَحَدَّثَنَاهُ ابْنُ الْمُثَنَّى ،  حَدَّثَنِي وَهْبُ بْنُ جَرِيرٍ ،  ح وحَدَّثَنَا إِسْحَاقُ بْنُ إ"}
{"hadithnumber": "5079", "text": "اسماعیل بن ابرا ہیم  ( ابن علیہ )  نے ایوب سے ،  انھوں نے محمد  ( بن سیرین )  سے انھوں نے حضرت انس"}
{"hadithnumber": "5080", "text": "حماد بن زید نے کہا  :  ہمیں ایوب  اور ہشام نے محمد سے حدیث بیان کی  ،  انھوں نے حضرت انس بن ما لک رض"}
{"hadithnumber": "5081", "text": "حاتم بن وردان نے کہا  :  ہمیں ایو ب نے محمد بن سیرین سے حدیث بیان کی  ، انھوں نے حضرت انس بن مالک رض"}
{"hadithnumber": "5082", "text": "حضرت جا بر  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ رسول اللہ  صلی اللہ علیہ وسلم  نے فر ما یا  : صرف مس"}
{"hadithnumber": "5083", "text": "ابو زبیر نے حضرت جابر بن عبد اللہ  رضی اللہ تعالیٰ عنہ کو کہتے ہوئے سنا کہ رسول اللہ  صلی اللہ علیہ"}
{"hadithnumber": "5084", "text": "قتیبہ بن سعید اور محمد بن رمح نے لیث سے انھوں نے یزید بن ابی حبیب سے انھوں نے ابو خیر سے انھوں نے حض"}
{"hadithnumber": "5085", "text": "ہشام دستوائی یحییٰ بن ابی کیثر سے انھوں نے بعجہ جہنی سے انھوں نے حضرت عقبہ بن عامر رضی اللہ تعالیٰ ع"}
{"hadithnumber": "5086", "text": "معاویہ بن سلام نے کہا  :  مجھے یحییٰ بن ابی کثیر نے حدیث بیان کی ،  کہا مجھے بعجہ بن عبد اللہ نے بتا"}
{"hadithnumber": "5087", "text": "ابو عوانہ نے قتادہ سے انھوں نے حضرت انس رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہا  : نبی  صلی اللہ علی"}
{"hadithnumber": "5088", "text": "وکیع نے شعبہ سے ،  انھوں نے قتادہ سے انھوں نے حضرت انس  رضی اللہ تعالیٰ عنہ  سے روایت کی :  کہا رسول"}
{"hadithnumber": "5089", "text": "خالد بن حارث نے کہا  :  ہمیں شعبہ نے حدیث بیان کی :  کہا  :  مجھے قتادہ نے بتا یا کہا  :  میں نے حضر"}
{"hadithnumber": "5090", "text": "سعید نے قتادہ سے ، انھوں نے حضرت  انس رضی اللہ تعالیٰ عنہ  سے ، انھوں نے نبی اکرم صلی اللہ علیہ وسلم"}
{"hadithnumber": "5091", "text": "عروہ بن  زبیر نے حضرت  عائشہ  رضی اللہ تعالیٰ عنہا   سے روایت کی کہ رسول اللہ صلی اللہ علیہ وسلم نے"}
{"hadithnumber": "5092", "text": "یحییٰ بن سعید نے سفیان ( بن سعید )  سے رویت کی ، کہا مجھے میرے والد ( سعید بن مسروق )  نے عبایہ بن ر"}
{"hadithnumber": "5093", "text": "وکیع نے کہا :  ہمیں سفیان بن سعید بن مسروق نے اپنے والد سے حدیث سنائی ، انھوں نے عبایہ بن  رفاعہ  بن"}
{"hadithnumber": "5094", "text": "۔  اسماعیل بن مسلم اور عمربن سعید نے سعید بن مسروق سے ،  انھوں نے عبایہ بن رفاعہ بن رافع بن خدیج سے"}
{"hadithnumber": "5095", "text": "زائدہ نے سعید بن مسروق سے اسی سند کے ساتھ یہ حدیث آخر تک پوری بیان کی اور اس میں کہا ( ہم نے عرض کی"}
{"hadithnumber": "5096", "text": "زائد ہ نے سعید بن مسروق سے اسی سند کے ساتھ یہ حدیث آخر تک پو ری بیان کی اور اس میں کہا  :   (  ہم نے"}
{"hadithnumber": "5097", "text": "سفیان نے کہا  :  ہمیں زہری نے ابو عبید سے روایت کی کہا  :  میں عید کے مو قع پر حضرت علی بن ابی طا لب"}
{"hadithnumber": "5098", "text": "یو نس نے ابن شہاب سے روایت کی  ، کہا  :  مجھے ابن ازہر کے مو لیٰ ابو عبید نے حدیث بیان کی کہ انھوں ن"}
{"hadithnumber": "5099", "text": "ابن شہاب کے بھتیجے صالح اور معمر سب نے زہری سے اسی سند کے ساتھ اسی کے مانند روایت کی  ۔"}
{"hadithnumber": "5100", "text": "لیث نے نافع سے  ،  انھوں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے انھوں نے رسول اللہ  صلی اللہ علیہ و"}
{"hadithnumber": "5101", "text": "ابن جریج اور ضحاک بن عثمان دونوں نے نافع سے ،  انھوں نے ابن عمر رضی اللہ تعالیٰ عنہ  سے انھوں نے نبی"}
{"hadithnumber": "5102", "text": "ابن ابی عمر اور عبد بن حمید نے ہمیں حدیث بیان کی  ، کہا  :  عبد الرزاق نے کہا  :  معمر نے ہمیں زہری"}
{"hadithnumber": "5103", "text": "عبد اللہ بن ابی بکر نے حضرت عبد اللہ بن واقد  رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہا :  رسول اللہ"}
{"hadithnumber": "5104", "text": "۔  ابو زبیر نے حضرت جابر رضی اللہ تعالیٰ عنہ سے اور انھوں نے رسول اللہ  صلی اللہ علیہ وسلم  سے روایت"}
{"hadithnumber": "5105", "text": "۔  ابن جریج نے کہا :  ہمیں  عطاء نے حدیث بیان کی  ، انھوں نے کہا : میں نے حضرت جابربن عبداللہ رضی ال"}
{"hadithnumber": "5106", "text": "زید بن ابی انیسہ نے عطاء بن ابی رباح سے ، انھوں نے جابر بن عبداللہ  رضی اللہ تعالیٰ عنہ  سے روایت کی"}
{"hadithnumber": "5107", "text": "عمرو (  بن دینار )  نے عطاء سے  ، انھوں نے حضرت جابر  رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا : ہم رس"}
{"hadithnumber": "5108", "text": "ابو بکر بن ابی شیبہ نے کہا : ہمیں عبدالاعلیٰ نے جریری سے حدیث بیان کی ، انھوں نے ابونضرہ سے  ، انھوں"}
{"hadithnumber": "5109", "text": "حضرت سلمہ بن اکوع  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ رسول اللہ  صلی اللہ علیہ وسلم  نے فرمایا :  "}
{"hadithnumber": "5110", "text": "معن بن عیسیٰ نے کہا : ہمیں معاویہ بن صالح نے ابوزاہریہ سے حدیث بیان کی  ، انھوں نے جبیر بن نفیر سے ،"}
{"hadithnumber": "5111", "text": "زید بن حباب اور عبدالرحمان بن مہدی دونوں نے معاویہ بن صالح سے  اسی سند کے ساتھ رویت کی ۔"}
{"hadithnumber": "5116", "text": "یحییٰ بن یحییٰ تمیمی ، ابو بکر بن ابی شیبہ ، عمرو ناقد اور زہیر بن حرب نے ہمیں سفیان بن عینیہ سے حدی"}
{"hadithnumber": "5117", "text": "ابن ابی عمر مکی نے کہا : ہمیں سفیان نے عبدالرحمان بن حمید بن عبدالرحمان بن عوف سے حدیث سنائی : انھوں"}
{"hadithnumber": "5118", "text": "اسحاق بن ابراہیم نے کہا : سفیان نے ہمیں خبر دی  ، کہا : مجھے عبدالرحمان بن حمید بن عبدالرحمان بن عوف"}
{"hadithnumber": "5119", "text": "یحییٰ بن کثیر عنبری ابو غسان نے کہا : ہمیں شعبہ نے مالک بن انس سے حدیث بیان کی ، انھوں نے عمر بن مسل"}
{"hadithnumber": "5120", "text": "محمد بن جعفر نے کہا : ہمیں شعبہ نے مالک بن انس سے حدیث بیا ن کی ، انھوں نے عمر یا عمرو بن مسلم سے اس"}
{"hadithnumber": "5121", "text": "معاذ عنبری نے کہا : ہمیں محمد بن عمر ولیثی نے عمر بن مسلم بن عمارہ بن اُکیمہ لیثی سے حدیث بیان کی ،"}
{"hadithnumber": "5122", "text": "ابواسامہ نے کہا : مجھے محمد بن عمرو نے حدیث بیان کی ، کہا : ہمیں عمرو بن مسلم بن عمارہ لیثی نے حدیث"}
{"hadithnumber": "5123", "text": "سعید بن ابی ہلال نے عمرو بن مسلم جندعی سے روایت کی کہ حضرت سعید بن مسیب نے انھیں خبر دی کہ نبی اکرم"}
{"hadithnumber": "5124", "text": "مروان بن معاویہ فزاری نے کہا  :  ہمیں منصور بن حیان نے حدیث بیان کی کہا  :  ابو طفیل عامر بن واثلہ"}
{"hadithnumber": "5125", "text": "ابوخالد احمر سلیمان بن حیان نے منصور بن حیان سے انھوں نے ابو طفیل  رضی اللہ تعالیٰ عنہ  سے روایت کی"}
{"hadithnumber": "5126", "text": "شعبہ نے کہا  :  میں نے قاسم بن ابی بزہ کو ابو طفیل  رضی اللہ تعالیٰ عنہ  سے حدیث بیان کرتے ہو ئے سنا"}
