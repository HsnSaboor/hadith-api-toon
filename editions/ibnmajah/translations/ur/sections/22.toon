{"hadithnumber": "2695", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے  ( اپنی وفات کے وقت )"}
{"hadithnumber": "2696", "text": "طلحہ بن مصرف کہتے ہیں کہ  میں نے عبداللہ بن ابی اوفی رضی اللہ عنہ سے پوچھا: کیا رسول اللہ صلی اللہ ع"}
{"hadithnumber": "2697", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کی وفات کے قریب جب آپ کا سانس اٹک"}
{"hadithnumber": "2698", "text": "علی بن ابی طالب رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کی آخری بات یہ تھی:  نماز کا"}
{"hadithnumber": "2699", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس مسلمان کے پاس"}
{"hadithnumber": "2700", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  محروم وہ ہے جو وصیت ک"}
{"hadithnumber": "2701", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص وصیت کر"}
{"hadithnumber": "2702", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  مسلمان کے لیے یہ"}
{"hadithnumber": "2703", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص اپنے وارث کو م"}
{"hadithnumber": "2704", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  آدمی ستر سال تک نیک عمل"}
{"hadithnumber": "2705", "text": "قرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے موت کے وقت اللہ کی کتاب"}
{"hadithnumber": "2706", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  ایک شخص رسول اللہ صلی اللہ علیہ وسلم کے پاس آیا اور اس نے عرض کی"}
{"hadithnumber": "2707", "text": "بسر بن جحاش قرشی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے اپنی ہتھیلی پر لعاب مبارک"}
{"hadithnumber": "2708", "text": "سعد بن ابی وقاص رضی اللہ عنہ کہتے ہیں کہ  میں فتح مکہ کے سال ایسا بیمار ہوا کہ موت کے کنارے پہنچ گیا"}
{"hadithnumber": "2709", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ تعالیٰ نے تمہاری وف"}
{"hadithnumber": "2710", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ تعالیٰ فرما"}
{"hadithnumber": "2711", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  میری تمنا ہے کہ لوگ تہائی مال کے بجائے چوتھائی مال میں و"}
{"hadithnumber": "2712", "text": "عمرو بن خارجہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے لوگوں کو اس حال میں خطبہ د"}
{"hadithnumber": "2713", "text": "ابوامامہ باہلی رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم سے سنا، آپ حجۃ الوداع ک"}
{"hadithnumber": "2714", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  میں رسول اللہ صلی اللہ علیہ وسلم کی اونٹنی کے نیچے کھڑا تھا، ا"}
{"hadithnumber": "2715", "text": "علی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے وصیت سے پہلے قرض  ( کی ادائیگی )  کا ف"}
{"hadithnumber": "2716", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  ایک شخص نے رسول اللہ صلی اللہ علیہ وسلم سے پوچھا: میرے والد کا"}
{"hadithnumber": "2717", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  ایک شخص نبی اکرم صلی اللہ علیہ وسلم کی خدمت میں آیا"}
{"hadithnumber": "2718", "text": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے پاس ایک شخص آی"}
