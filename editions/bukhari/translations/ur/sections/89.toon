{"hadithnumber": "6940", "text": "ہم سے یحییٰ بن بکیر نے بیان کیا، انہوں نے کہا ہم سے لیث بن سعد نے بیان کیا، ان سے خالف بن یزید نے بی"}
{"hadithnumber": "6941", "text": "ہم سے محمد بن عبداللہ بن حوشب الطائفی نے بیان کیا، انہوں نے کہا ہم سے عبدالوہاب ثقفی نے بیان کیا، ان"}
{"hadithnumber": "6942", "text": "ہم سے سعید بن سلیمان نے بیان کیا، کہا ہم سے عباد نے، ان سے اسماعیل نے، انہوں نے قیس سے سنا، انہوں نے"}
{"hadithnumber": "6943", "text": "ہم سے مسدد نے بیان کیا، کہا ہم سے یحییٰ نے بیان کیا، ان سے اسماعیل نے، کہا ہم سے قیس نے بیان کیا، ان"}
{"hadithnumber": "6944", "text": "ہم سے عبدالعزیز بن عبداللہ نے بیان کیا، انہوں نے کہا ہم سے لیث بن سعد نے بیان کیا، ان سے سعید مقبری"}
{"hadithnumber": "6945", "text": "ہم سے یحییٰ بن قزعہ نے بیان کیا، کہا ہم سے امام مالک نے بیان کیا، ان سے عبدالرحمٰن بن القاسم نے، ان"}
{"hadithnumber": "6946", "text": "ہم سے محمد بن یوسف نے بیان کیا، کہا ہم سے سفیان نے بیان کیا، ان سے ابن جریج نے، ان سے ابن ابی ملیکہ"}
{"hadithnumber": "6947", "text": "ہم سے ابونعمان نے بیان کیا، کہا ہم سے حماد بن زید نے بیان کیا، ان سے عمرو بن دینار نے اور ان سے جابر"}
{"hadithnumber": "6948", "text": "ہم سے حسین بن منصور نے بیان کیا، کہا ہم سے اسباط بن محمد نے بیان کیا، کہا ہم سے شیبانی سلیمان بن فیر"}
{"hadithnumber": "6949", "text": "اور لیث بن سعد نے بیان کیا کہ مجھ سے نافع نے بیان کیا، انہیں صفیہ بنت ابی عبید نے خبر دی کہ  حکومت ک"}
{"hadithnumber": "6950", "text": "ہم سے ابوالیمان نے بیان کیا، کہا ہم سے شعیب نے بیان کیا، ان سے ابوالزناد نے، ان سے اعرج نے اور ان سے"}
{"hadithnumber": "6951", "text": "ہم سے یحییٰ بن بکیر نے بیان کیا، کہا ہم سے لیث بن سعد نے بیان کیا، ان سے عقیل نے، ان سے ابن شہاب نے،"}
{"hadithnumber": "6952", "text": "ہم سے محمد بن عبدالرحیم نے بیان کیا، انہوں نے کہا ہم سے سعید بن سلیمان واسطی نے بیان کیا، انہوں نے ک"}
