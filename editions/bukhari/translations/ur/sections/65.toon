{"hadithnumber": "4947", "text": "ہم سے یحییٰ بن موسیٰ بلخی نے بیان کیا، کہا ہم سے وکیع نے بیان کیا، ان سے اعمش نے، ان سے سعد بن عبیدہ"}
{"hadithnumber": "4948", "text": "ہم سے عثمان بن ابی شیبہ نے بیان کیا، انہوں نے کہا ہم سے جریر بن عبدالحمید نے بیان کیا، ان سے منصور ن"}
{"hadithnumber": "4949", "text": "ہم سے آدم بن ابی ایاس نے بیان کیا، کہا ہم سے شعبہ نے بیان کیا، ان سے اعمش نے بیان کیا، کہا کہ میں نے"}
{"hadithnumber": "4950", "text": "ہم سے احمد بن یونس نے بیان کیا، کہا ہم سے زہیر نے بیان کیا، ان سے اسود بن قیس نے بیان کیا کہ میں نے"}
{"hadithnumber": "4951", "text": "ہم سے محمد بن بشار نے بیان کیا، کہا ہم سے محمد بن جعفر غندر نے، کہا ہم سے شعبہ نے، ان سے اسود بن قیس"}
{"hadithnumber": "4952", "text": "ہم سے حجاج بن منہال نے بیان کیا، انہوں نے کہا ہم سے شعبہ نے بیان کیا، انہوں نے کہا مجھے عدی بن ثابت"}
{"hadithnumber": "4953", "text": "ہم سے یحییٰ بن بکیر نے بیان کیا، کہا ہم سے لیث بن سعد نے بیان کیا، ان سے عقیل نے، ان سے ابن شہاب نے"}
{"hadithnumber": "4954", "text": "محمد بن شہاب نے بیان کیا، انہیں ابوسلمہ رضی اللہ عنہ نے خبر دی اور ان سے جابر بن عبداللہ انصاری رضی"}
{"hadithnumber": "4955", "text": "ہم سے ابن بکیر نے بیان کیا، کہا ہم سے لیث بن سعد نے بیان کیا، ان سے عقیل نے بیان کیا، ان سے ابن شہاب"}
{"hadithnumber": "4956", "text": "ہم سے عبداللہ بن محمد نے بیان کیا، انہوں نے کہا ہم سے عبدالرزاق نے بیان کیا، انہوں نے کہا ہم کو معمر"}
{"hadithnumber": "4957", "text": "ہم سے عبداللہ بن یوسف نے بیان کیا، کہا ہم سے لیث بن سعد نے بیان کیا اور ان سے عقیل نے، ان سے ابن شہا"}
{"hadithnumber": "4958", "text": "ہم سے یحییٰ بن موسیٰ نے بیان کیا، کہا ہم سے عبدالرزاق نے بیان کیا، ان سے معمر نے، ان سے عبدالکریم جز"}
{"hadithnumber": "4959", "text": "ہم سے محمد بن بشار نے بیان کیا، کہا کہ ہم سے غندر نے بیان کیا، کہا ہم سے شعبہ نے بیان کیا، میں نے قت"}
{"hadithnumber": "4960", "text": "ہم سے حسان بن حسان نے بیان کیا، کہا ہم سے ہمام نے بیان کیا، ان سے قتادہ نے اور ان سے انس رضی اللہ عن"}
{"hadithnumber": "4961", "text": "ہم سے احمد بن ابی داؤد ابو جعفر منادی نے بیان کیا، کہا ہم سے روح نے بیان کیا، کہا ہم سے سعید بن ابی"}
{"hadithnumber": "4962", "text": "ہم سے اسماعیل بن عبداللہ نے بیان کیا، کہا ہم سے امام مالک نے بیان کیا، ان سے زید بن اسلم نے، ان سے ا"}
{"hadithnumber": "4963", "text": "ہم سے یحییٰ بن سلیمان نے بیان کیا، انہوں نے کہا کہ مجھ سے ابن وہب نے بیان کیا، انہوں نے کہا مجھ کو ا"}
{"hadithnumber": "4964", "text": "ہم سے آدم بن ابی ایاس نے بیان کیا، کہا ہم سے شیبان بن عبدالرحمٰن نے بیان کیا، ان سے قتادہ نے بیان کی"}
{"hadithnumber": "4965", "text": "ہم سے خالد بن یزید کاہلی نے بیان کیا، انہوں نے کہا ہم سے اسرائیل نے بیان کیا، ان سے ابواسحاق نے بیان"}
{"hadithnumber": "4966", "text": "ہم سے یعقوب بن ابراہیم نے بیان کیا، انہوں نے کہا ہم سے ہشیم نے بیان کیا، ان سے ابوالبشر نے بیان کیا،"}
{"hadithnumber": "4967", "text": "ہم سے حسن بن ربیع نے بیان کیا، کہا ہم سے ابوالاحوص نے بیان کیا، ان سے اعمش نے، ان سے ابوالضحیٰ نے، ا"}
{"hadithnumber": "4968", "text": "ہم سے عثمان بن ابی شیبہ نے بیان کیا، کہا ہم سے جریر نے بیان کیا، ان سے منصور نے، ان سے ابوالضحیٰ نے،"}
{"hadithnumber": "4969", "text": "ہم سے عبداللہ بن ابی شیبہ نے بیان کیا، کہا ہم سے عبدالرحمٰن بن مہدی نے بیان کیا، ان سے سفیان ثوری نے"}
{"hadithnumber": "4970", "text": "ہم سے موسیٰ بن اسماعیل نے بیان کیا، کہا ہم سے ابوعوانہ نے بیان کیا، ان سے ابوبشر نے، ان سے سعید بن ج"}
{"hadithnumber": "4971", "text": "ہم سے یوسف بن موسیٰ نے بیان کیا، کہا ہم سے ابواسامہ نے بیان کیا، کہا ہم سے اعمش نے بیان کیا، ان سے ع"}
{"hadithnumber": "4972", "text": "ہم سے محمد بن سلام نے بیان کیا، کہا ہم کو ابومعاویہ نے خبر دی، ان سے اعمش نے بیان کیا، ان سے عمرو بن"}
{"hadithnumber": "4973", "text": "ہم سے عمر بن حفص نے بیان کیا، کہا مجھ سے میرے والد نے بیان کیا، کہا ہم سے اعمش نے بیان کیا، ان سے عم"}
{"hadithnumber": "4974", "text": "ہم سے ابوالیمان نے بیان کیا، انہوں نے کہا ہم سے شعیب نے بیان کیا، انہوں نے کہا ہم سے ابوالزناد نے بی"}
{"hadithnumber": "4975", "text": "ہم سے اسحاق بن منصور نے بیان کیا، انہوں نے کہا کہ ہم سے عبدالرزاق نے بیان کیا، انہوں نے کہا ہمیں معم"}
{"hadithnumber": "4976", "text": "ہم سے قتیبہ بن سعید نے بیان کیا، کہا کہ ہم سے سفیان نے بیان کیا، ان سے عاصم اور عبدہ نے، ان سے زر بن"}
{"hadithnumber": "4977", "text": "ہم سے علی بن عبداللہ نے بیان کیا، ان سے سفیان ثوری نے بیان کیا، ان سے عبدہ بن ابی لبابہ نے بیان کیا،"}
