hadiths[count]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}:
1052,[1052] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ یَزِیدَ بْنِ عَبْدِ اللّٰہِ بْنِ قُسَیْطٍ، عَنْ مُحَمَّدِ بْن,"{'name': 'Salim al-Hilali', 'grade': 'Mauquf Sahih'}","Book 25, Hadith 1",1052,,Game
1053,[1053] حَدَّثَنِی یَحْیَی، عَنْ مَالِکٍ، عَنْ زَیْدِ بْنِ أَسْلَمَ، عَنْ رَجُلٍ مِنْ بَنِی ضَمْرَۃَ,"{'name': 'Salim al-Hilali', 'grade': 'Maqtu Daif'}","Book 25, Hadith 2",1053,,Game
1054,[1054] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ جَعْفَرِ بْنِ مُحَمَّدٍ، عَنْ أَبِیہِ أَ نَّہُ قَالَ : وَزَ,"{'name': 'Salim al-Hilali', 'grade': 'Maqtu Daif'}","Book 25, Hadith 3",1054,,Game
1055,[1055] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ رَبِیعَۃَ بْنِ أبِی عَبْدِ الرَّحْمَنِ، عَنْ مُحَمَّدِ بْنِ,"{'name': 'Salim al-Hilali', 'grade': 'Mauquf Sahih'}","Book 25, Hadith 4",1055,,Game
1056,[1056] حَدَّثَنِی یَحْیَی، عَنْ مَالِکٍ، عَنْ نَافِعٍ : أَنَّ عَبْدَ اللّٰہِ بْنَ عُمَرَ لَمْ یَکُن,"{'name': 'Salim al-Hilali', 'grade': 'Mauquf Sahih'}","Book 25, Hadith 5",1056,,Game
1057,[1057] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ رَبِیعَۃَ بْنِ أبِی عَبْدِ الرَّحْمَنِ، عَنْ مُحَمَّدِ بْنِ,"{'name': 'Salim al-Hilali', 'grade': 'Mauquf Hasan'}","Book 25, Hadith 6",1057,,Game
1058,[1058] وَحَدَّثَنِی عَنْ مَالِکٍ، أَ نَّہُ بَلَغَہُ : أَ نَّہُ عُقَّ عَنْ حَسَنٍ وَحُسَیْنٍ ابْنَی,"{'name': 'Salim al-Hilali', 'grade': 'Mauquf Sahih'}","Book 25, Hadith 7",1058,,Game
1059,[1059] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ : أَنَّ أَبَاہُ عُرْوَۃَ بْنَ الزُّبَ,"{'name': 'Salim al-Hilali', 'grade': 'Mauquf Hasan'}","Book 25, Hadith 8",1059,,Game
1060,[1060] حَدَّثَنِی یَحْیَی، عَنْ مَالِکٍ، عَنْ عَمْرِو بْنِ الْحَارِثِ، عَنْ عُبَیْدِ بْنِ فَیْرُوزٍ،,"{'name': 'Salim al-Hilali', 'grade': 'Mauquf Sahih'}","Book 25, Hadith 9",1060,,Game
1061,[1061] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ نَافِعٍ : أَنَّ عَبْدَ اللّٰہِ بْنَ عُمَرَ کَانَ یَتَّقِی مِ,"{'name': 'Salim al-Hilali', 'grade': 'Mauquf Sahih'}","Book 25, Hadith 10",1061,,Game
1062,[1062] حَدَّثَنِی یَحْیَی، عَنْ مَالِکٍ، عَنْ یَحْیَی بْنِ سَعِیدٍ، عَنْ بُشَیْرِ بْنِ یَسَارٍ : أَ,"{'name': 'Salim al-Hilali', 'grade': 'Shadh'}","Book 25, Hadith 11",1062,,Game
1063,[1063] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ یَحْیَی بْنِ سَعِیدٍ، عَنْ عَبَّادِ بْنِ تَمِیمٍ، أَنَّ عُوَ,"{'name': 'Salim al-Hilali', 'grade': 'Sahih'}","Book 25, Hadith 12",1063,,Game
1064,[1064] حَدَّثَنِی یَحْیَی، عَنْ مَالِکٍ، عَنْ نَافِعٍ : أَنَّ عَبْدَ اللّٰہِ بْنَ عُمَرَ ضَحَّی مَر,"{'name': 'Salim al-Hilali', 'grade': 'Sahih'}","Book 25, Hadith 13",1064,,Game
1065,[1065] حَدَّثَنِی یَحْیَی، عَنْ مَالِکٍ، عَنْ أبِی الزُّبَیْرِ الْمَکِّیِّ عَنْ جَابِرِ بْنِ عَبْدِ,"{'name': 'Salim al-Hilali', 'grade': 'Sahih'}","Book 25, Hadith 14",1065,,Game
1066,[1066] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ عَبْدِ اللّٰہِ بْنِ أبِی بَکْرٍ، عَنْ عَبْدِ اللّٰہِ بْنِ وَ,"{'name': 'Salim al-Hilali', 'grade': 'Daif'}","Book 25, Hadith 15",1066,,Game
1098,حَدَّثَنِي يَحْيَى، عَنْ مَالِكٍ، عَنْ نَافِعٍ، أَنَّهُ قَالَ رَمَيْتُ طَائِرَيْنِ بِحَجَرٍ وَأَنَا بِالْجُرْفِ، فَأَصَبْتُهُمَا فَأَمَّا أَحَدُهُمَا فَمَاتَ فَطَرَحَهُ عَبْدُ اللَّهِ بْنُ عُمَرَ وَأَمَّا الآخَرُ فَذَهَبَ عَبْدُ اللَّهِ بْنُ عُمَرَ يُذَكِّيهِ بِقَدُومٍ فَمَاتَ قَبْلَ أَنْ يُذَكِّيَهُ فَطَرَحَهُ عَبْدُ اللَّهِ أَيْضًا ‏.‏,,,1098,,Game
1099,وَحَدَّثَنِي عَنْ مَالِكٍ، أَنَّهُ بَلَغَهُ أَنَّ الْقَاسِمَ بْنَ مُحَمَّدٍ، كَانَ يَكْرَهُ مَا قَتَلَ الْمِعْرَاضُ وَالْبُنْدُقَةُ ‏.‏,,,1099,,Game
1100,سَعِيدَ بْنَ الْمُسَيَّبِ، كَانَ يَكْرَهُ أَنْ تُقْتَلَ الإِنْسِيَّةُ، بِمَا يُقْتَلُ بِهِ الصَّيْدُ مِنَ الرَّمْىِ وَأَشْبَاهِهِ ‏.‏ قَالَ مَالِكٌ وَلاَ أَرَى بَأْسًا بِمَا أَصَابَ الْمِعْرَاضُ إِذَا خَسَقَ وَبَلَغَ الْمَقَاتِلَ أَنْ يُؤْكَلَ قَالَ اللَّهُ تَبَارَكَ وَتَعَالَى ‏{‏يَا أَيُّهَا الَّذِينَ آمَنُوا لَيَبْلُوَنَّكُمُ اللَّهُ بِشَىْءٍ مِنَ الصَّيْدِ تَنَالُهُ أَيْدِيكُمْ وَرِمَاحُكُمْ ‏}‏ قَالَ فَكُلُّ شَىْءٍ نَالَهُ الإِنْسَانُ بِيَدِهِ أَوْ رُمْحِهِ أَوْ بِشَىْءٍ مِنْ سِلاَحِهِ فَأَنْفَذَهُ وَبَلَغَ مَقَاتِلَهُ فَهُوَ صَيْدٌ كَمَا قَالَ اللَّهُ تَعَالَى,,,1100,,Game
1101,وَحَدَّثَنِي عَنْ مَالِكٍ أَنَّهُ سَمِعَ أَهْلَ الْعِلْمِ يَقُولُونَ إِذَا أَصَابَ الرَّجُلُ الصَّيْدَ فَأَعَانَهُ عَلَيْهِ غَيْرُهُ مِنْ مَاءٍ أَوْ كَلْبٍ غَيْرِ مُعَلَّمٍ لَمْ يُؤْكَلْ ذَلِكَ الصَّيْدُ إِلاَّ أَنْ يَكُونَ سَهْمُ الرَّامِي قَدْ قَتَلَهُ أَوْ بَلَغَ مَقَاتِلَ الصَّيْدِ حَتَّى لاَ يَشُكَّ أَحَدٌ فِي أَنَّهُ هُوَ قَتَلَهُ وَأَنَّهُ لاَ يَكُونُ لِلصَّيْدِ حَيَاةٌ بَعْدَهُ ‏.‏ قَالَ وَسَمِعْتُ مَالِكًا يَقُولُ لاَ بَأْسَ بِأَكْلِ الصَّيْدِ - وَإِنْ غَابَ عَنْكَ مَصْرَعُهُ - إِذَا وَجَدْتَ بِهِ أَثَرًا مِنْ كَلْبِكَ أَوْ كَانَ بِهِ سَهْمُكَ مَا لَمْ يَبِتْ فَإِذَا بَاتَ فَإِنَّهُ يُكْرَهُ أَكْلُهُ ‏.,,,1101,,Game
1102,وَحَدَّثَنِي يَحْيَى، عَنْ مَالِكٍ، عَنْ نَافِعٍ، عَنْ عَبْدِ اللَّهِ بْنِ عُمَرَ، أَنَّهُ كَانَ يَقُولُ فِي الْكَلْبِ الْمُعَلَّمِ كُلْ مَا أَمْسَكَ عَلَيْكَ إِنْ قَتَلَ وَإِنْ لَمْ يَقْتُلْ ‏.‏,,,1102,,Game
1103,وَحَدَّثَنِي عَنْ مَالِكٍ، عَمَّنْ سَمِعَ نَافِعًا، يَقُولُ قَالَ عَبْدُ اللَّهِ بْنُ عُمَرَ وَإِنْ أَكَلَ وَإِنْ لَمْ يَأْكُلْ ‏.‏,,,1103,,Game
1104,وَحَدَّثَنِي عَنْ مَالِكٍ، أَنَّهُ بَلَغَهُ عَنْ سَعْدِ بْنِ أَبِي وَقَّاصٍ، أَنَّهُ سُئِلَ عَنِ الْكَلْبِ الْمُعَلَّمِ، إِذَا قَتَلَ الصَّيْدَ فَقَالَ سَعْدٌ كُلْ وَإِنْ لَمْ تَبْقَ إِلاَّ بِضْعَةٌ وَاحِدَةٌ ‏.‏ وَحَدَّثَنِي عَنْ مَالِكٍ، أَنَّهُ بَلَغَهُ عَنْ سَعْدِ بْنِ أَبِي وَقَّاصٍ، أَنَّهُ سُئِلَ عَنِ الْكَلْبِ الْمُعَلَّمِ، إِذَا قَتَلَ الصَّيْدَ فَقَالَ سَعْدٌ كُلْ وَإِنْ لَمْ تَبْقَ إِلاَّ بِضْعَةٌ وَاحِدَةٌ ‏.,,,1104,,Game
1105,.‏ وَحَدَّثَنِي عَنْ مَالِكٍ أَنَّهُ سَمِعَ بَعْضَ أَهْلِ الْعِلْمِ يَقُولُونَ فِي الْبَازِي وَالْعُقَابِ وَالصَّقْرِ وَمَا أَشْبَهَ ذَلِكَ أَنَّهُ إِذَا كَانَ يَفْقَهُ كَمَا تَفْقَهُ الْكِلاَبُ الْمُعَلَّمَةُ فَلاَ بَأْسَ بِأَكْلِ مَا قَتَلَتْ مِمَّا صَادَتْ إِذَا ذُكِرَ اسْمُ اللَّهِ عَلَى إِرْسَالِهَا ‏.‏ قَالَ مَالِكٌ وَأَحْسَنُ مَا سَمِعْتُ فِي الَّذِي يَتَخَلَّصُ الصَّيْدَ مِنْ مَخَالِبِ الْبَازِي أَوْ مِنَ الْكَلْبِ ثُمَّ يَتَرَبَّصُ بِهِ فَيَمُوتُ أَنَّهُ لاَ يَحِلُّ أَكْلُهُ ‏.‏ قَالَ مَالِكٌ وَكَذَلِكَ كُلُّ مَا قُدِرَ عَلَى ذَبْحِهِ وَهُوَ فِي مَخَالِبِ الْبَازِي أَوْ فِي الْكَلْبِ فَيَتْرُكُهُ صَاحِبُهُ وَهُوَ قَادِرٌ عَلَى ذَبْحِهِ حَتَّى يَقْتُلَهُ الْبَازِي أَوِ الْكَلْبُ فَإِنَّهُ لاَ يَحِلُّ أَكْلُهُ ‏.‏ قَالَ مَالِكٌ وَكَذَلِكَ الَّذِي يَرْمِي الصَّيْدَ فَيَنَالُهُ وَهُوَ حَىٌّ فَيُفَرِّطُ فِي ذَبْحِهِ حَتَّى يَمُوتَ فَإِنَّهُ لاَ يَحِلُّ أَكْلُهُ ‏.‏ قَالَ مَالِكٌ الأَمْرُ الْمُجْتَمَعُ عَلَيْهِ عِنْدَنَا أَنَّ الْمُسْلِمَ إِذَا أَرْسَلَ كَلْبَ الْمَجُوسِيِّ الضَّارِيَ فَصَادَ أَوْ قَتَلَ إِنَّهُ إِذَا كَانَ مُعَلَّمًا فَأَكْلُ ذَلِكَ الصَّيْدِ حَلاَلٌ لاَ بَأْسَ بِهِ وَإِنْ لَمْ يُذَكِّهِ الْمُسْلِمُ وَإِنَّمَا مَثَلُ ذَلِكَ مَثَلُ الْمُسْلِمِ يَذْبَحُ بِشَفْرَةِ الْمَجُوسِيِّ أَوْ يَرْمِي بِقَوْسِهِ أَوْ بِنَبْلِهِ فَيَقْتُلُ بِهَا فَصَيْدُهُ ذَلِكَ وَذَبِيحَتُهُ حَلاَلٌ لاَ بَأْسَ بِأَكْلِهِ وَإِذَا أَرْسَلَ الْمَجُوسِيُّ كَلْبَ الْمُسْلِمِ الضَّارِيَ عَلَى صَيْدٍ فَأَخَذَهُ فَإِنَّهُ لاَ يُؤْكَلُ ذَلِكَ الصَّيْدُ إِلاَّ أَنْ يُذَكَّى  وَإِنَّمَا مَثَلُ ذَلِكَ مَثَلُ قَوْسِ الْمُسْلِمِ وَنَبْلِهِ يَأْخُذُهَا الْمَجُوسِيُّ فَيَرْمِي بِهَا الصَّيْدَ فَيَقْتُلُهُ وَبِمَنْزِلَةِ شَفْرَةِ الْمُسْلِمِ يَذْبَحُ بِهَا الْمَجُوسِيُّ فَلاَ يَحِلُّ أَكْلُ شَىْءٍ مِنْ ذَلِكَ ‏.,,,1105,,Game
1106,وَحَدَّثَنِي يَحْيَى، عَنْ مَالِكٍ، عَنْ نَافِعٍ، أَنَّ عَبْدَ الرَّحْمَنِ بْنَ أَبِي هُرَيْرَةَ، سَأَلَ عَبْدَ اللَّهِ بْنَ عُمَرَ عَمَّا لَفَظَ الْبَحْرُ فَنَهَاهُ عَنْ أَكْلِهِ، ‏.‏ قَالَ نَافِعٌ ثُمَّ انْقَلَبَ عَبْدُ اللَّهِ فَدَعَا بِالْمُصْحَفِ فَقَرَأَ ‏{‏أُحِلَّ لَكُمْ صَيْدُ الْبَحْرِ وَطَعَامُهُ‏}‏ قَالَ نَافِعٌ فَأَرْسَلَنِي عَبْدُ اللَّهِ بْنُ عُمَرَ إِلَى عَبْدِ الرَّحْمَنِ بْنِ أَبِي هُرَيْرَةَ إِنَّهُ لاَ بَأْسَ بِأَكْلِهِ ‏.‏,,,1106,,Game
1107,وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ زَيْدِ بْنِ أَسْلَمَ، عَنْ سَعْدٍ الْجَارِيِّ، مَوْلَى عُمَرَ بْنِ الْخَطَّابِ أَنَّهُ قَالَ سَأَلْتُ عَبْدَ اللَّهِ بْنَ عُمَرَ عَنِ الْحِيتَانِ، يَقْتُلُ بَعْضُهَا بَعْضًا أَوْ تَمُوتُ صَرَدًا فَقَالَ لَيْسَ بِهَا بَأْسٌ ‏.‏ قَالَ سَعْدٌ ثُمَّ سَأَلْتُ عَبْدَ اللَّهِ بْنَ عَمْرِو بْنِ الْعَاصِ فَقَالَ مِثْلَ ذَلِكَ ‏.‏,,,1107,,Game
1108,وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ أَبِي الزِّنَادِ، عَنْ أَبِي سَلَمَةَ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ أَبِي هُرَيْرَةَ، وَزَيْدِ بْنِ ثَابِتٍ، أَنَّهُمَا كَانَا لاَ يَرَيَانِ بِمَا لَفَظَ الْبَحْرُ بَأْسًا ‏.‏,,,1108,,Game
1109,"وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ أَبِي الزِّنَادِ، عَنْ أَبِي سَلَمَةَ بْنِ عَبْدِ الرَّحْمَنِ، أَنَّ نَاسًا، مِنْ أَهْلِ الْجَارِ قَدِمُوا فَسَأَلُوا مَرْوَانَ بْنَ الْحَكَمِ عَمَّا لَفَظَ الْبَحْرُ فَقَالَ لَيْسَ بِهِ بَأْسٌ وَقَالَ اذْهَبُوا إِلَى زَيْدِ بْنِ ثَابِتٍ وَأَبِي هُرَيْرَةَ فَاسْأَلُوهُمَا عَنْ ذَلِكَ ثُمَّ ائْتُونِي فَأَخْبِرُونِي مَاذَا يَقُولاَنِ فَأَتَوْهُمَا فَسَأَلُوهُمَا فَقَالاَ لاَ بَأْسَ بِهِ ‏.‏ فَأَتَوْا مَرْوَانَ فَأَخْبَرُوهُ ‏.‏ فَقَالَ مَرْوَانُ قَدْ قُلْتُ لَكُمْ ‏.‏ قَالَ مَالِكٌ لاَ بَأْسَ بِأَكْلِ الْحِيتَانِ يَصِيدُهَا الْمَجُوسِيُّ لأَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ فِي الْبَحْرِ ‏ ‏ هُوَ الطَّهُورُ مَاؤُهُ الْحِلُّ مَيْتَتُهُ ‏""""‏ ‏.‏ قَالَ مَالِكٌ وَإِذَا أُكِلَ ذَلِكَ مَيْتًا فَلاَ يَضُرُّهُ مَنْ صَادَهُ ‏.‏""",,,,,Game
1110,"حَدَّثَنِي يَحْيَى، عَنْ مَالِكٍ، عَنِ ابْنِ شِهَابٍ، عَنِ أَبِي إِدْرِيسَ الْخَوْلاَنِيِّ، عَنْ أَبِي ثَعْلَبَةَ الْخُشَنِيِّ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ أَكْلُ كُلِّ ذِي نَابٍ مِنَ السِّبَاعِ حَرَامٌ ‏""""‏ ‏.‏""",,,,,Game
1111,"وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ إِسْمَاعِيلَ بْنِ أَبِي حَكِيمٍ، عَنْ عَبِيدَةَ بْنِ سُفْيَانَ الْحَضْرَمِيِّ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ أَكْلُ كُلِّ ذِي نَابٍ مِنَ السِّبَاعِ حَرَامٌ ‏""""‏ ‏.‏""",,,,,Game
1112,[1112] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ إِبْرَاہِیمَ بْنِ أبِی عَبْلَۃَ، عَنْ عَبْدِ الْمَلِکِ بْنِ,,,1112,,Game
1114,"وَحَدَّثَنِي مَالِكٌ، عَنْ زَيْدِ بْنِ أَسْلَمَ، عَنِ ابْنِ وَعْلَةَ الْمِصْرِيِّ، عَنْ عَبْدِ اللَّهِ بْنِ عَبَّاسٍ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ إِذَا دُبِغَ الإِهَابُ فَقَدْ طَهُرَ ‏""""‏ ‏.‏""",,,,,Game
1115,وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ يَزِيدَ بْنِ عَبْدِ اللَّهِ بْنِ قُسَيْطٍ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ ثَوْبَانَ، عَنْ أُمِّهِ، عَنْ عَائِشَةَ، زَوْجِ النَّبِيِّ صلى الله عليه وسلم أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم أَمَرَ أَنْ يُسْتَمْتَعَ بِجُلُودِ الْمَيْتَةِ إِذَا دُبِغَتْ ‏.‏,,,1115,,Game
1116,[1116] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنِ ابْنِ شِہَابٍ، عَنْ عُرْوَۃَ بْنِ الزُّبَیْرِ : أَنَّ خَوْلَ,,,1116,,Game