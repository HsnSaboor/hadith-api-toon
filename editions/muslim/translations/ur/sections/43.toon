{"hadithnumber": "384", "text": "ابو اویس نے بھی زہری سے اسی طرح روایت کی ہے جس طرح مالک نے کی ہے البتہ اس نے  ( حتی جازھا )  حتی کہ"}
{"hadithnumber": "5938", "text": "5938 ۔ ابو عمار شدادسے رویت ہے کہ انھوں نے حضرت واثلہ بن اسقع رضی اللہ تعالیٰ عنہ  سے سنا ، وہ کہہ ر"}
{"hadithnumber": "5939", "text": "حضرت جابر بن سمرہ رضی اللہ تعالیٰ عنہ  سے روایت ہے  ، کہا : رسول اللہ  صلی اللہ علیہ وسلم نے فرمایا"}
{"hadithnumber": "5940", "text": "عبداللہ بن  فروخ نے کہا : مجھے حضرت ابوہریرہ رضی اللہ تعالیٰ عنہ  نے حدیث بیان کی ، کہا : رسول اللہ"}
{"hadithnumber": "5941", "text": "ثابت نے حضرت انس رضی اللہ تعالیٰ عنہ  سے روایت کی  نبی کریم صلی اللہ علیہ وسلم  نے پانی طلب فرمایا ت"}
{"hadithnumber": "5942", "text": "اسحاق بن عبداللہ بن ابی طلحہ نے حضرت انس بن مالک رضی اللہ تعالیٰ عنہ  سے روایت کی ، انھوں نے کہا : م"}
{"hadithnumber": "5943", "text": "معاذ کے والد ہشام نے قتادہ سے روایت کی ، کہا : ہمیں حضرت انس بن مالک رضی اللہ تعالیٰ عنہ  نے حدیث بی"}
{"hadithnumber": "5944", "text": "سعید نے قتادہ سے  حدیث بیان کی ، انھوں نے حضرت انس  رضی اللہ تعالیٰ عنہ سے روایت کی کہ نبی کریم صلی"}
{"hadithnumber": "5945", "text": "سیدنا جابر رضی اللہ عنہ سے روایت ہے کہ ام مالک رضی اللہ عنہا رسول اللہ صلی اللہ علیہ وسلم کو ایک کپی"}
{"hadithnumber": "5946", "text": "حضرت جابر رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ ایک شخص نبی کریم صلی اللہ علیہ وسلم  کی خدمت میں کھانا"}
{"hadithnumber": "5947", "text": "ہمیں ابو علی حنفی نے حدیث سنائی  ، کہا :  ہمیں مالک بن انس نے ابو زبیر مکی سے حدیث بیان کی کہ ابو طف"}
{"hadithnumber": "5948", "text": "۔  سلیمان بن بلال نے عمرو بن یحییٰ سے حدیث بیان کی ، انہوں نے عباس بن سہل بن سعد ساعدی سے  ، انھوں ن"}
{"hadithnumber": "5949", "text": "عفان اور مغیرہ بن سلمہ مخزومی دونوں نے کہا : ہمیں وہیب نے حدیث بیان کی ، کہا : ہمیں عمر وبن یحییٰ نے"}
{"hadithnumber": "5950", "text": "معمر نے زہری سے ، انھوں نے ابو سلمہ سے اور انھوں نے حضرت جابر رضی اللہ تعالیٰ عنہ  سے روایت کی ، نیز"}
{"hadithnumber": "5951", "text": "شعیب نے زہری سے روایت کی  ، کہا : مجھے سنان بن ابی سنان دؤلی اور ابو سلمہ بن عبدالرحمان نے حدیث بیان"}
{"hadithnumber": "5952", "text": "یحییٰ بن ابی کثیر نے ابو سلمہ سے ، انھوں نے حضرت جابر  رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا : ہم"}
{"hadithnumber": "5953", "text": "سیدنا ابوموسیٰ اشعری رضی اللہ عنہ نبی کریم صلی اللہ علیہ وسلم سے روایت کرتے ہیں کہ آپ صلی اللہ علیہ"}
{"hadithnumber": "5954", "text": "سیدنا ابوموسیٰ رضی اللہ عنہ نبی کریم صلی اللہ علیہ وسلم سے روایت کرتے ہیں کہ آپ صلی اللہ علیہ وسلم ن"}
{"hadithnumber": "5955", "text": "مغیرہ بن عبدالرحمان قرشی نے ہمیں ابو زناد سے حدیث بیان کی ، انھوں نے اعرج سے ، انھوں نے حضرت ابوہریر"}
{"hadithnumber": "5956", "text": "سفیان نے ابو زناد سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی ۔"}
{"hadithnumber": "5957", "text": "ہمام بن منبہ نے کہا : یہ احادیث ہیں جو ابوہریرہ رضی اللہ تعالیٰ عنہ  نے ہمیں رسول  سے بیان کیں ۔ انھ"}
{"hadithnumber": "5958", "text": "حضرت جابر رضی اللہ تعالیٰ عنہ  سے روایت ہے  ، کہا : رسول اللہ  صلی اللہ علیہ وسلم    نے فرمایا؛ \" می"}
{"hadithnumber": "5959", "text": "اعرج نے حضرت ابوہریرہ رضی اللہ تعالیٰ عنہ  سے  ، انھوں نے نبی کریم صلی اللہ علیہ وسلم  سے روایت کی ک"}
{"hadithnumber": "5960", "text": "معمر نے ہمیں ہمام بن منبہ سے حدیث بیان کی  ، کہا : یہ ( احادیث )  ہمیں ابو ہریرہ رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "5961", "text": "ابو صالح سمان نے حضرت  ابوہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی کہ رسول اللہ  صلی اللہ علیہ وسلم  ن"}
{"hadithnumber": "5962", "text": "حضرت ابو سعید خدری رضی اللہ تعالیٰ عنہ  سے روایت ہے  ، کہا : رسول اللہ  صلی اللہ علیہ وسلم  نے فرمای"}
{"hadithnumber": "5963", "text": "عفان نے ہمیں حدیث بیان کی ، کہا : ہمیں سلیم بن حیان نے حدیث بیان کی ، کہا : ہمیں سعید بن میناء نے حض"}
{"hadithnumber": "5964", "text": "ابن مہدی نے کہا : ہمیں سلیم نے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی ۔ اور \" اسے پورا کیا \"  کے"}
{"hadithnumber": "5965", "text": "حضرت ابوموسیٰ  رضی اللہ تعالیٰ عنہ  سے روایت ہے  ، انھوں نے نبی کریم صلی اللہ علیہ وسلم  سے روایت کی"}
{"hadithnumber": "5966", "text": "ہمیں زائدہ نے حدیث سنائی ، کہا : ہمیں عبدالمطلب بن عمیر نے حدیث بیان کی ، کہا : میں نے حضرت جندب ( ب"}
{"hadithnumber": "5967", "text": "مسعر اور شعبہ دونوں نے عبدالملک بن عمیر سے  ، انھوں نے حضرت جندب  رضی اللہ تعالیٰ عنہ  سے ، انھوں نے"}
{"hadithnumber": "5969", "text": "انھوں ( نعمان بن ابی عیاش  )  نے کہا : اور میں گواہی دیتا ہوں کہ میں نے حضرت ابو سعید خدری سے سنا ،"}
{"hadithnumber": "5970", "text": "ابو اسامہ نے ابو حازم سے ، انھوں نے سہل  رضی اللہ تعالیٰ عنہ  سے  ، انھوں نے نبی کریم صلی اللہ علیہ"}
{"hadithnumber": "5972", "text": "حضرت اسماءبنت ابی بکر رضی اللہ تعالیٰ عنہا   نے کہا  :  کہ رسول اللہ  صلی اللہ علیہ وسلم  نے فرمایا"}
{"hadithnumber": "5973", "text": "حضرت عائشہ رضی اللہ تعالیٰ عنہا   کہتی ہیں کہ میں نے رسول اللہ  صلی اللہ علیہ وسلم  سے سنا ،  آپ صحا"}
{"hadithnumber": "5974", "text": "بکیر نے قاسم بن عباس ہاشمی سے روایت کی  ، انھوں نےحضرت ام سلمہ  رضی اللہ تعالیٰ عنہا  کے مولیٰ عبید"}
{"hadithnumber": "5975", "text": "ہمیں افلح بن سعید نے حدیث بیان کی کہا  :  ہمیں عبد اللہ بن رافع نے حدیث سنائی  ، کہا؛ حضرت ام سلمہ ر"}
{"hadithnumber": "5976", "text": "لیث نے یزید بن ابی حبیب سے ،  انھوں نے  ابو الخیر سے ، انھوں نے  حضرت عقبہ بن عامر  رضی اللہ تعالیٰ"}
{"hadithnumber": "5977", "text": "ہمیں ابو معاویہ نے اعمش سے حدیث سنائی  ، انھوں نے شقیق  ( بن سلمہ اسدی ) سے ،  انھوں نے حضرت عبد الل"}
{"hadithnumber": "5978", "text": "ہمیں ابو معاویہ نے اعمش سے حدیث سنائی  ، انھوں نے شقیق  ( بن سلمہ اسدی ) سے ،  انھوں نے حضرت عبد الل"}
{"hadithnumber": "5979", "text": "جریر اعمش سے اسی سند کے ساتھ روایت کی اور  \" میرے ساتھی ہیں  ۔ میرے ساتھی ہیں  ،  کے الفاظ بیان  نہی"}
{"hadithnumber": "5980", "text": "جریر اور شعبہ نے مغیرہ سے ، انھوں نے ابو وائل سے ، انھوں نے حضرت عبد اللہ  ( بن مسعود رضی اللہ تعالی"}
{"hadithnumber": "5981", "text": "عبثراور ابن فضیل دونوں نے حصین سے انھوں نے ابو وائل سے ، انھون نے حضرت حذیفہ رضی اللہ تعالیٰ عنہ  سے"}
{"hadithnumber": "5982", "text": "ابن ابی عدی  نے شعبہ سے ،  انھوں نے معبد بن خالد سے ، انھوں نے حضرت حارثہ  ( بن وہب خزاعی )  رضی الل"}
{"hadithnumber": "5983", "text": "حرمی بن عمارہ نے کہا  :  ہمیں  شعبہ نے معبد بن  خالد سے حدیث بیان کی کہ انھوں نے حضرت حارثہ بن وہب خ"}
{"hadithnumber": "5984", "text": "ایوب نے نافع سے ،  انھوں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے روایت کی  ، کہا رسول اللہ  صلی اللہ"}
{"hadithnumber": "5985", "text": "زہیر بن حرب محمد بن مثنیٰ اور عبید اللہ بن سعید نے کہا  :  ہمیں یحییٰ قطان نے عبید اللہ سے حدیث بیان"}
{"hadithnumber": "5986", "text": "عبد اللہ  بن نمیر اور محمد بن بشر نے کہا  : ہمیں عبید اللہ نے اسی سند کے ساتھ اسی کی مانند روایت کی"}
{"hadithnumber": "5987", "text": "موسیٰ بن عقبہ نے نافع سے ، انھوں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے ، انھوں نے نبی اکرم  صلی ال"}
{"hadithnumber": "5988", "text": "عمر بن نافع سے ، انھوں نے حضرت عبد اللہ  ( بن عمر رضی اللہ تعالیٰ عنہ  )  سے روایت کی ،  رسول اللہ"}
{"hadithnumber": "5989", "text": "عبد اللہ بن صامت نے حضرت ابو ذر رضی اللہ تعالیٰ عنہ سے روایت کی کہا  :  میں نے پو چھا  :  اللہ کے رس"}
{"hadithnumber": "5992", "text": "محمد بن بشار نے کہا  :  ہمیں یحییٰ بن حماد نے حدیث بیان کی  ، کہا :  ہمیں شعبہ نے قتادہ سے حدیث بیان"}
{"hadithnumber": "5993", "text": "ربیع بن مسلم نے محمد بن زیاد سے ،  انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی کہ نبی"}
{"hadithnumber": "5994", "text": "شعبہ نے محمد بن زیاد سےروایت کی ،  انھوں نے حضرت ابوہریرہ رضی اللہ تعالیٰ عنہ  سے سنا ،  وہ کہہ رہے"}
{"hadithnumber": "6004", "text": "مسعرنے سعد بن ابرا ہیم سے ،  انھوں نے اپنے والد سے ،  انھوں نے حضرت سعد رضی اللہ تعالیٰ عنہ  سے روای"}
{"hadithnumber": "6005", "text": "ابرا ہیم بن سعد نے کہا  :  ہمیں سعد نے اپنے والد  ( ابراہیم  ) سے انھوں نے حضرت سعد بن ابی وقاص  رضی"}
{"hadithnumber": "6006", "text": "ثابت نے حضرت انس بن مالک رضی اللہ تعالیٰ عنہ  سے روایت کی کہا  :  رسول اللہ  صلی اللہ علیہ وسلم  تما"}
{"hadithnumber": "6007", "text": "وکیع نے شعبہ سے ،  انھوں نے قتادہ سے ،  انھوں نے حضرت انس رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا  :"}
{"hadithnumber": "6008", "text": "محمد بن جعفر اور خالد بن حارث نے کہا  :  ہمیں شعبہ نے اسی سند کے ساتھ حدیث بیان کی ،  اور ابن جعفر ک"}
{"hadithnumber": "6009", "text": "ابرا ہیم  ( بن سعد )  نے ابن شہاب سے ،  انھوں نے عبید اللہ بن عبد اللہ بن عتبہ بن مسعود سے ،  انھوں"}
{"hadithnumber": "6010", "text": "یو نس اور معمر دونوں نے زہری سے اسی سند کے ساتھ اسی طرح روایت کی ۔"}
{"hadithnumber": "6011", "text": "سعید بن منصور اور ابو ربیع نے ہمیں حدیث بیان کی  ، دونوں نے کہا  :  ہمیں حماد بن زید نے ثابت بنانی س"}
{"hadithnumber": "6012", "text": "سلام بن مسکین نے کہا  :  ہمیں ثابت بنا نی نے حضرت انس رضی اللہ تعالیٰ عنہ  سے اسی کے مانند روایت کی"}
{"hadithnumber": "6013", "text": "ہمیں عبد العزیز نے حضرت انس رضی اللہ تعالیٰ عنہ  سے حدیث سنائی کہا  :  جب رسول اللہ  صلی اللہ علیہ و"}
{"hadithnumber": "6014", "text": "سعید بن ابی بردہ نے حضرت انس رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہا  :   میں نے نو سال رسول اللہ  ص"}
{"hadithnumber": "6016", "text": "حضرت انس رضی اللہ تعالیٰ عنہ  نے کہا :  اللہ کی قسمً میں نے نوسال آپ کی خدمت کی ،  میں نے آپ کو کبھی"}
{"hadithnumber": "6017", "text": "ابو تیاح نے حضرت انس بن مالک  رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہا  :  رسول اللہ  صلی اللہ علیہ و"}
{"hadithnumber": "6018", "text": "ابو بکر بن ابی شیبہ اور عمرو ناقد نے کہا  :  ہمیں سفیان بن عیینہ نے ابن منکدر سے حدیث بیان کی ،  انھ"}
{"hadithnumber": "6019", "text": "اشجعی اور عبد الرحمٰن بن مہدی دونوں نے سفیان سے انھوں نے محمد بن منکدر سے روایت کی ،  انھوں نے کہا :"}
{"hadithnumber": "6020", "text": "موسیٰ بن انس نے اپنے والد سے روایت کی ،  کہا  :  رسول اللہ  صلی اللہ علیہ وسلم  سے اسلام  ( لا نے )"}
{"hadithnumber": "6021", "text": "ثابت نے حضرت انس  رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہ ایک  شخص  نے نبی  صلی اللہ علیہ وسلم  سے دوپ"}
{"hadithnumber": "6022", "text": "یو نس نے مجھے ابن شہاب سے خبر دی کہا  :  رسول اللہ  صلی اللہ علیہ وسلم  نے غزوہ فتح یعنی فتح مکہ کے"}
{"hadithnumber": "6023", "text": "سفیان بن عیینہ  نے محمد بن منکدر سے روایت کی کہ انھوں نے جابر بن عبد اللہ رضی اللہ تعالیٰ عنہ  سے سن"}
{"hadithnumber": "6024", "text": "ابن جریج نے کہا  :  مجھے عمرو بن دینار نے محمد بن علی سے خبر دی  ، انھو ں  نے جابر بن عبد اللہ  رضی"}
{"hadithnumber": "6025", "text": "ثابت بنانی نے حضرت انس رضی اللہ تعالیٰ عنہ  سے حدیث بیان کی ،  کہا :  رسول اللہ  صلی اللہ علیہ وسلم"}
{"hadithnumber": "6026", "text": "عمرو بن سعید نے حضرت انس بن مالک رضی اللہ تعالیٰ عنہ  سے روایت کی  ، کہا : میں نے رسول اللہ  صلی الل"}
{"hadithnumber": "6027", "text": "ابو اسامہ اور ابن نمیر نے ہشام ( بن عروہ )  سے  ، انھوں نے اپنے والد سے ، انھوں نے حضرت عائشہ رضی ال"}
{"hadithnumber": "6028", "text": "سفیان بن عیینہ نے زہری سے  ، انھوں نے ابو سلمہ سے  ، انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ سے"}
{"hadithnumber": "6029", "text": "معمر نے زہری سے روایت کی  ، کہا : مجھے ابو سلمہ نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے  ، انھوں ن"}
{"hadithnumber": "6030", "text": "جریر ، عیسیٰ بن یونس ، ابو معاویہ اور حفص بن غیاث سب نے اعمش سے  ، انھوں نے زید بن وہب اور ابوظبیان"}
{"hadithnumber": "6031", "text": "قیس اور نافع بن جبیر نے جریر سے ، انھوں نے نبی کریم صلی اللہ علیہ وسلم  سے اعمش کی حدیث کے مانند حدی"}
{"hadithnumber": "6032", "text": "عبداللہ بن ابی عتبہ نے کہا : میں نے ابو سعید خدری رضی اللہ تعالیٰ عنہ  سے سنا ، کہہ رہے تھے : رسول ا"}
{"hadithnumber": "6033", "text": "زہری بن حرب اور عثمان بن ابی شیبہ نے ہمیں حدیث بیان کی ، دونوں نے کہا : ہمیں جریر نے اعمش سے ، انھوں"}
