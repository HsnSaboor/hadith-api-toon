metadata:
  section_id: 24
  section_name: رسول اللہ صلی اللہ علیہ وسلم کا کسی کے سہارے ٹیک لگانا
  hadith_first: 131
  hadith_last: 132

hadiths[2]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
131,’’سیدنا انس بن مالک رضی اللہ عنہ سے مروی ہے کہ نبی اکرم صلی اللہ علیہ وسلم بیمار تھے تو اسامہ بن زید رضی اللہ عنہ پر ٹیک لگائے باہر تشریف فرما ہوئے، آپ صلی اللہ علیہ وسلم یمنی چادر اپنے کندھوں پر اوڑھے ہوئے تھے اسی حالت میں آپ صلی اللہ علیہ وسلم نے صحابہ کرام رضی الله عنہم کو نماز پڑھائی۔‘‘,,,131,,رسول اللہ صلی اللہ علیہ وسلم کا کسی کے سہارے ٹیک لگانا
132,"سیدنا فضل بن عباس رضی اللہ عنہ فرماتے ہیں میں رسول اللہ صلی اللہ علیہ وسلم کے پاس آپ صلی اللہ علیہ وسلم کی اس مرض میں گیا جس میں آپ صلی اللہ علیہ وسلم وفات پاگئے آپ صلی اللہ علیہ وسلم کے سر مبارک پر زرد رنگ کی پگڑی تھی میں نے سلام عرض کیا تو آپ صلی اللہ علیہ وسلم نے ارشاد فرمایا : اے فضل ! میں نے عرض کیا : اللہ کے رسول صلی اللہ علیہ وسلم ! حاضر ہوں۔ ارشادفرمایا : اس پگڑی کو میرے سر پر اچھی طرح باندھ دو۔ میں نے ایسا ہی کیا۔ پھر آپ صلی اللہ علیہ وسلم بیٹھ گئے اور اپنے دونوں ہاتھ میرے کندھوں پر رکھ کر کھڑے ہوگئے اور مسجد میں تشریف لے گئے۔ اور حدیث میں مفصل قصّہ ہے۔",,,132,,رسول اللہ صلی اللہ علیہ وسلم کا کسی کے سہارے ٹیک لگانا
