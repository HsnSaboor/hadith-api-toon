{"hadithnumber": "3412", "arabic": "حَدَّثَنَا عِصْمَةُ بْنُ الْفَضْلِ،‏‏‏‏ حَدَّثَنَا حَرَمِيُّ بْنُ عُمَارَةَ بْنِ أَبِي حَفْصَةَ،‏‏‏‏", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 30, Hadith 42", "international_number": "3412", "narrator_chain": ""}
{"hadithnumber": "3413", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ،‏‏‏‏ أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ،‏‏‏‏ عَنْ نَافِعٍ،‏‏‏‏ عَنْ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 30, Hadith 43", "international_number": "3413", "narrator_chain": ""}
