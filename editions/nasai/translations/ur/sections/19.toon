{"hadithnumber": "1556", "text": "ابوبکرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے ان لوگوں کو جو آپ کے پیچھے تھے انہی"}
{"hadithnumber": "1557", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  جاہلیت کے لوگوں کے لیے سال میں دو دن ایسے ہوتے تھے جن میں وہ ک"}
{"hadithnumber": "1558", "text": "ابو عمیر بن انس اپنے ایک چچا سے روایت کرتے ہیں کہ  کچھ لوگوں نے عید کا چاند دیکھا تو وہ لوگ نبی اکرم"}
{"hadithnumber": "1559", "text": "حفصہ بنت سرین کہتی ہیں کہ  ام عطیہ رضی اللہ عنہا جب بھی رسول اللہ صلی اللہ علیہ وسلم کا ذکر کرتیں تو"}
{"hadithnumber": "1560", "text": "محمد بن سیرین کہتے ہیں کہ  میں نے ام عطیہ رضی اللہ عنہا سے ملاقات کی اور میں نے ان سے پوچھا: کیا آپ"}
{"hadithnumber": "1561", "text": "عبداللہ بن عمر رضی اللہ عنہم کہتے ہیں کہ  عمر بن خطاب رضی اللہ عنہ نے بازار میں موٹے ریشمی کپڑے کا ا"}
{"hadithnumber": "1562", "text": "ثعلبہ بن زہدم سے روایت ہے کہ  علی رضی اللہ عنہ نے ابومسعود رضی اللہ عنہ کو لوگوں پر اپنا نائب مقرر ک"}
{"hadithnumber": "1563", "text": "جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ہمیں بغیر اذان اور بغیر اقامت کے خطبہ"}
{"hadithnumber": "1564", "text": "شعبی (عامر بن شراحیل) کہتے ہیں کہ  ہم سے براء بن عازب رضی اللہ عنہم نے مسجد کے ستونوں میں سے ایک ستو"}
{"hadithnumber": "1565", "text": "عبداللہ بن عمر رضی اللہ عنہم سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم، ابوبکر اور عمر رضی اللہ ع"}
{"hadithnumber": "1566", "text": "عبداللہ بن عمر رضی اللہ عنہم سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم عید الفطر اور عید الاضحی د"}
{"hadithnumber": "1567", "text": "عمر بن خطاب رضی اللہ عنہ کہتے ہیں کہ  عید الاضحی کی نماز دو رکعت ہے، عید الفطر کی نماز دو رکعت ہے، م"}
{"hadithnumber": "1568", "text": "عبیداللہ بن عبداللہ کہتے ہیں کہ   ( ایک دفعہ )  عید کے دن عمر رضی اللہ عنہ نکلے تو انہوں نے ابوواقد"}
{"hadithnumber": "1569", "text": "نعمان بن بشیر رضی اللہ عنہم سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم عیدین میں اور جمعہ کے دن «س"}
{"hadithnumber": "1570", "text": "عبداللہ بن عباس رضی اللہ عنہم کہتے ہیں کہ  میں گواہی دیتا ہوں کہ میں رسول اللہ صلی اللہ علیہ وسلم کے"}
{"hadithnumber": "1571", "text": "براء بن عازب رضی اللہ عنہم کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ہمیں قربانی کے دن نماز کے بع"}
{"hadithnumber": "1572", "text": "عبداللہ بن سائب رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے عید کی نماز پڑھی، پھر فر"}
{"hadithnumber": "1573", "text": "ابورمثہ رضی اللہ عنہ کہتے ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم کو دیکھا کہ آپ خطبہ دے رہے تھے"}
{"hadithnumber": "1574", "text": "ابو کاہل احمسی رضی اللہ عنہ کہتے ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم کو دیکھا کہ آپ ایک اونٹن"}
{"hadithnumber": "1575", "text": "سماک کہتے ہیں کہ  میں نے جابر رضی اللہ عنہ سے پوچھا: کیا رسول اللہ صلی اللہ علیہ وسلم کھڑے ہو کر خطب"}
{"hadithnumber": "1576", "text": "جابر رضی اللہ عنہ کہتے ہیں کہ  میں عید کے دن نماز میں رسول اللہ صلی اللہ علیہ وسلم کے ساتھ موجود تھا"}
{"hadithnumber": "1577", "text": "ابو سعید خدری رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم عید الفطر اور عید الاضحی کے"}
{"hadithnumber": "1578", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم نے اپنے ساتھی س"}
{"hadithnumber": "1579", "text": "جابر بن عبداللہ رضی اللہ عنہم کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم اپنے خطبہ میں اللہ کی حمد و"}
{"hadithnumber": "1580", "text": "ابو سعید خدری رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم عید کے دن نکلتے تو دو رکعتیں"}
{"hadithnumber": "1581", "text": "حسن بصری سے روایت ہے کہ  ابن عباس رضی اللہ عنہم نے بصرہ میں خطبہ دیا تو کہا: تم لوگ اپنے روزوں کی زک"}
{"hadithnumber": "1582", "text": "براء رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے قربانی کے دن نماز کے بعد خطبہ دیا، پھ"}
{"hadithnumber": "1583", "text": "جابر بن سمرہ رضی اللہ عنہ کہتے ہیں کہ  میں نبی اکرم صلی اللہ علیہ وسلم کے ساتھ نماز پڑھتا تھا، تو آپ"}
{"hadithnumber": "1584", "text": "جابر بن سمرہ رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو کھڑے ہو کر خطبہ دیتے د"}
{"hadithnumber": "1585", "text": "جابر بن سمرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کھڑے ہو کر خطبہ دیتے، پھر بیٹھتے،"}
{"hadithnumber": "1586", "text": "بریدہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم منبر پر خطبہ دے رہے تھے کہ اسی دوران حس"}
{"hadithnumber": "1587", "text": "عبدالرحمٰن بن عابس کہتے ہیں  میں نے ابن عباس رضی اللہ عنہم سے سنا کہ ایک آدمی نے ان سے پوچھا: کیا آپ"}
{"hadithnumber": "1588", "text": "عبداللہ بن عباس رضی اللہ عنہم سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم عید کے دن نکلے، تو آپ نے د"}
{"hadithnumber": "1589", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے عید الاضحی کے دن ہمیں خطبہ دیا"}
{"hadithnumber": "1590", "text": "عبداللہ بن عمر رضی اللہ عنہم کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم عید گاہ ہی میں ذبح یا نحر کرت"}
{"hadithnumber": "1591", "text": "نعمان بن بشیر رضی اللہ عنہم کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم جمعہ اور عید دونوں میں «سبح اس"}
{"hadithnumber": "1592", "text": "ایاس بن ابی رملہ کہتے ہیں کہ  میں نے معاویہ رضی اللہ عنہ کو سنا، انہوں نے زید بن ارقم رضی اللہ عنہ س"}
{"hadithnumber": "1593", "text": "وہب بن کیسان کہتے ہیں کہ  ابن زبیر رضی اللہ عنہم کے دور میں دونوں عیدیں ایک ہی دن میں جمع ہو گئیں، ت"}
{"hadithnumber": "1594", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  ان کے پاس دو لڑکیاں دف بجا رہی تھیں اور رسول اللہ صل"}
{"hadithnumber": "1595", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  عید کے دن حبشی لوگ آئے وہ نبی اکرم صلی اللہ علیہ وسلم ک"}
{"hadithnumber": "1596", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو دیکھا کہ آپ مجھے"}
{"hadithnumber": "1597", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  عمر رضی اللہ عنہ  ( مسجد میں )  داخل ہوئے، حبشی لوگ مسجد میں کھیل"}
