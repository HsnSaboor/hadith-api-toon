{"metadata":{"name":"Sunan Ibn Majah","section":{"9":"The Chapters on Marriage"},"section_detail":{"9":{"hadithnumber_first":1845,"hadithnumber_last":2015,"arabicnumber_first":1845,"arabicnumber_last":2015}}},"hadiths":[{"hadithnumber":1982,"arabicnumber":1982,"text":"Rapporté par 'Aishah : Je jouais à la poupée quand j’étais avec le Messager d’Allah, et il faisait venir mes amies pour jouer avec moi","grades":[{"name":"Al-Albani","grade":"Sahih"},{"name":"Muhammad Fouad Abd al-Baqi","grade":"Sahih"},{"name":"Zubair Ali Zai","grade":"Sahih - Bukhari And Muslim"}],"reference":{"book":9,"hadith":138}}]}