{"hadithnumber": "706", "text": "عبداللہ بن زید (عبداللہ بن زید بن عبدربہ) رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے"}
{"hadithnumber": "707", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے لوگوں سے اس مسئلہ میں مشور"}
{"hadithnumber": "708", "text": "عبداللہ بن محیریز جو یتیم تھے اور ابومحذورہ بن معیر کے زیر پرورش تھے، کہتے ہیں کہ  جس وقت ابومحذورہ"}
{"hadithnumber": "709", "text": "ابومحذورہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مجھے اذان کے لیے انیس کلمات اور"}
{"hadithnumber": "710", "text": "مؤذن رسول اللہ صلی اللہ علیہ وسلم سعد رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے"}
{"hadithnumber": "711", "text": "ابوجحیفہ رضی اللہ عنہ کہتے ہیں کہ  میں وادی بطحاء میں رسول اللہ صلی اللہ علیہ وسلم کے پاس آیا، آپ ا"}
{"hadithnumber": "712", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مسلمانوں کے دو ک"}
{"hadithnumber": "713", "text": "جابر بن سمرہ رضی اللہ عنہ کہتے ہیں کہ  بلال رضی اللہ عنہ اذان وقت سے مؤخر نہ کرتے، اور اقامت کبھی ک"}
{"hadithnumber": "714", "text": "عثمان بن ابی العاص ثقفی رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے مجھے آخری وصیت یہ"}
{"hadithnumber": "715", "text": "بلال رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مجھے حکم دیا کہ میں فجر کی اذان میں «"}
{"hadithnumber": "716", "text": "بلال رضی اللہ عنہ سے روایت ہے کہ  وہ نبی اکرم صلی اللہ علیہ وسلم کے پاس نماز فجر کی اطلاع دینے کے لی"}
{"hadithnumber": "717", "text": "زیاد بن حارث صدائی رضی اللہ عنہ کہتے ہیں کہ  میں رسول اللہ صلی اللہ علیہ وسلم کے ساتھ ایک سفر میں تھ"}
{"hadithnumber": "718", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب مؤذن اذان دے تو تم ب"}
{"hadithnumber": "719", "text": "ام المؤمنین ام حبیبہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم جب ان کی باری کے دن و ر"}
{"hadithnumber": "720", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم مؤذن کی اذان"}
{"hadithnumber": "721", "text": "سعد بن ابی وقاص رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس شخص نے مؤذن ک"}
{"hadithnumber": "722", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس شخص نے اذان"}
{"hadithnumber": "723", "text": "عبدالرحمٰن بن ابوصعصعہ (جو ابو سعید خدری رضی اللہ عنہ کے زیر پرورش تھے) کہتے ہیں کہ  مجھ سے ابوسعید"}
{"hadithnumber": "724", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا:  مؤذن کی"}
{"hadithnumber": "725", "text": "معاویہ بن ابی سفیان رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مؤذنوں کی"}
{"hadithnumber": "726", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم میں سے اچھے"}
{"hadithnumber": "727", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس شخص نے طلب ث"}
{"hadithnumber": "728", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس شخص نے بار"}
{"hadithnumber": "729", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  لوگوں کو ایسی چیز کی تلاش ہوئی جس کے ذریعہ لوگوں کو نماز کے او"}
{"hadithnumber": "730", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  بلال رضی اللہ عنہ کو حکم دیا گیا کہ وہ اذان کے کلمات دو دو بار، اور اق"}
{"hadithnumber": "731", "text": "رسول اللہ صلی اللہ علیہ وسلم کے مؤذن سعد رضی اللہ عنہ سے روایت ہے کہ  بلال رضی اللہ عنہ اذان کے کلم"}
{"hadithnumber": "732", "text": "ابورافع کہتے ہیں کہ  میں نے بلال رضی اللہ عنہ کو رسول اللہ صلی اللہ علیہ وسلم کے سامنے اذان دیتے دیک"}
{"hadithnumber": "733", "text": "ابوالشعثاء کہتے ہیں کہ  ہم مسجد میں ابوہریرہ رضی اللہ عنہ کے ساتھ بیٹھے ہوئے تھے کہ اتنے میں مؤذن ن"}
{"hadithnumber": "734", "text": "عثمان رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص مسجد میں ہو، اور اذا"}
