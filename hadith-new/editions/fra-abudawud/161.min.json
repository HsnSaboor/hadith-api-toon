{"metadata":{"name":"Sunan Abu Dawud","section":{"1":"Purification (Kitab Al-Taharah)"},"section_detail":{"1":{"hadithnumber_first":1,"hadithnumber_last":390,"arabicnumber_first":1,"arabicnumber_last":390}}},"hadiths":[{"hadithnumber":161,"arabicnumber":161,"text":"Rapporté par Al-Mughirah ibn Shu'bah رضي الله عنه : Le Messager d’Allah ﷺ a passé la main mouillée sur ses chaussettes. Une autre version ajoute : « Sur le dessus des chaussettes. »","grades":[{"name":"Al-Albani","grade":"Hasan Sahih"},{"name":"Muhammad Muhyi Al-Din Abdul Hamid","grade":"Hasan Sahih"},{"name":"Shuaib Al Arnaut","grade":"Hasan"},{"name":"Zubair Ali Zai","grade":"Isnaad Hasan"}],"reference":{"book":1,"hadith":161}}]}