{"hadithnumber": "1773", "text": "ہم سے عبداللہ بن یوسف نے بیان کیا، انہوں نے کہا کہ ہم کو امام مالک نے خبر دی، انہیں ابوبکر بن عبدالر"}
{"hadithnumber": "1774", "text": "ہم سے احمد بن محمد نے بیان کیا، انہیں عبداللہ بن مبارک نے خبر دی، انہیں ابن جریج نے خبر دی کہ  عکرمہ"}
{"hadithnumber": "1776", "text": "مجاہد نے بیان کیا کہ  ہم نے ام المؤمنین عائشہ رضی اللہ عنہا کے حجرہ سے ان کے مسواک کرنے کی آواز سنی"}
{"hadithnumber": "1777", "text": "ہم سے ابوعاصم نے بیان کیا، کہا ہم کو ابن جریج نے خبر دی، کہا کہ مجھے عطاء بن ابی رباح نے خبر دی، ان"}
{"hadithnumber": "1778", "text": "ہم سے حسان بن حسان نے بیان کیا کہ ہم سے ہمام بن یحییٰ نے بیان کیا، ان سے قتادہ نے کہ  میں نے انس رضی"}
{"hadithnumber": "1779", "text": "ہم سے ابوالولید ہشام بن عبدالملک نے بیان کیا، کہا کہ ہم سے ہمام نے بیان کیا، ان سے قتادہ نے بیان کیا"}
{"hadithnumber": "1780", "text": "ہم سے ہدبہ بن خالد نے بیان کیا، کہا ہم سے ہمام نے بیان کیا، اس روایت میں یوں ہے کہ  جو عمرہ نبی کریم"}
{"hadithnumber": "1781", "text": "ہم سے احمد بن عثمان نے بیان کیا، انہوں نے کہا ہم سے شریح بن مسلمہ نے بیان کیا، انہوں نے کہا کہ ہم سے"}
{"hadithnumber": "1782", "text": "ہم سے مسدد نے بیان کیا، کہا ہم سے یحییٰ بن قطان نے بیان کیا، ان سے ابن جریج نے، ان سے عطاء بن ابی رب"}
{"hadithnumber": "1783", "text": "ہم سے محمد بن سلام بیکندی نے بیان کیا، کہا کہ ہم کو ابومعاویہ نے خبر دی، ان سے ہشام نے بیان کیا، ان"}
{"hadithnumber": "1784", "text": "ہم سے علی بن عبداللہ نے بیان کیا، کہا ہم سے سفیان بن عیینہ نے بیان کیا، ان سے عمرو بن دینار نے، انہو"}
{"hadithnumber": "1785", "text": "ہم سے محمد بن مثنی نے بیان کیا، ان سے عبدالوہاب بن عبدالمجید نے، ان سے حبیب معلم نے، ان سے عطاء بن ا"}
{"hadithnumber": "1786", "text": "ہم سے محمد بن مثنیٰ نے بیان کیا، کہا کہ ہم سے یحییٰ بن قطان نے بیان کیا، ان سے ہشام بن عروہ نے بیان"}
{"hadithnumber": "1787", "text": "ہم سے مسدد نے بیان کیا، کہا ان سے یزید بن زریع نے بیان کیا، ان سے ابن عون نے بیان کیا، ان سے قاسم بن"}
{"hadithnumber": "1788", "text": "ہم سے ابونعیم نے بیان کیا، کہا ہم سے افلح بن حمید نے بیان کیا، ان سے قاسم بن محمد نے اور ان سے عائشہ"}
{"hadithnumber": "1789", "text": "ہم سے ابونعیم نے بیان کیا، کہا کہ ہم سے ہمام نے بیان کیا، ان سے عطا بن ابی رباح نے بیان کیا، انہوں ن"}
{"hadithnumber": "1790", "text": "ہم سے عبداللہ بن یوسف نے بیان کیا، انہوں نے کہا ہم کو امام مالک نے خبر دی، انہیں ہشام بن عروہ نے، ان"}
{"hadithnumber": "1792", "text": "کہا انہوں نے پھر پوچھا کہ  نبی کریم صلی اللہ علیہ وسلم نے خدیجہ رضی اللہ عنہا کے متعلق کیا کچھ فرمای"}
{"hadithnumber": "1794", "text": "انہوں نے بیان کیا کہ  ہم نے جابر بن عبداللہ رضی اللہ عنہما سے بھی اس کے متعلق سوال کیا تو آپ نے فرما"}
{"hadithnumber": "1795", "text": "ہم سے محمد بن بشار نے بیان کیا، ان سے غندر بن محمد بن جعفر نے بیان کیا، ان سے شعبہ نے بیان کیا، ان س"}
{"hadithnumber": "1796", "text": "ہم سے احمد بن عیسیٰ نے بیان کیا، انہوں نے کہا ہم سے ابن وہب نے بیان کیا، انہیں عمرو نے خبر دی، انہیں"}
{"hadithnumber": "1797", "text": "ہم سے عبداللہ بن یوسف نے بیان کیا، انہوں نے کہا ہمیں امام مالک نے خبر دی، انہیں نافع نے اور انہیں عب"}
{"hadithnumber": "1798", "text": "ہم سے معلی بن اسد نے بیان کیا، کہا ہم سے یزید بن زریع نے بیان کیا، ان سے خالد نے بیان کیا، ان سے عکر"}
{"hadithnumber": "1799", "text": "ہم سے احمد بن حجاج نے بیان کیا، انہوں نے کہا ہم سے انس بن عیاض نے بیان کیا، ان سے عبیداللہ نے، ان سے"}
{"hadithnumber": "1800", "text": "ہم سے موسیٰ بن اسماعیل نے بیان کیا، کہا ہم سے ہمام نے بیان کیا، ان سے اسحاق بن عبداللہ بن ابی طلحہ ن"}
{"hadithnumber": "1801", "text": "ہم سے مسلم بن ابراہیم نے بیان کیا، کہا ہم سے شعبہ نے بیان کیا، ان سے محارب بن دثار نے اور ان سے جابر"}
{"hadithnumber": "1802", "text": "ہم سے سعید بن ابی مریم نے بیان کیا، کہا کہ ہم کو محمد بن جعفر نے خبر دی، کہا کہ مجھے حمید طویل نے خب"}
{"hadithnumber": "1803", "text": "ہم سے ابوالولید نے بیان کیا، کہا ہم سے شعبہ نے بیان کیا، ان سے ابواسحاق نے کہ میں نے براء بن عازب رض"}
{"hadithnumber": "1804", "text": "ہم سے عبداللہ بن مسلمہ قعنبی نے بیان کیا، ان سے سمی نے، ان سے ابوصالح نے اور ان سے ابوہریرہ رضی اللہ"}
{"hadithnumber": "1805", "text": "ہم سے سعید بن ابی مریم نے بیان کیا، انہوں نے کہا ہم کو محمد بن جعفر نے خبر دی، انہوں نے کہا کہ مجھے"}
