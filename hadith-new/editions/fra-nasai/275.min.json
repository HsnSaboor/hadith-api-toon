{"metadata":{"name":"Sunan an Nasai","section":{"1":"The Book of Purification"},"section_detail":{"1":{"hadithnumber_first":1,"hadithnumber_last":324,"arabicnumber_first":1,"arabicnumber_last":324}}},"hadiths":[{"hadithnumber":275,"arabicnumber":275,"text":"Rapporté par 'Aishah : Le Prophète (ﷺ) sortait sa tête pendant qu’il était en retraite spirituelle et je la lavais, alors que j’avais mes règles","grades":[{"name":"Abu Ghuddah","grade":"Sahih"},{"name":"Al-Albani","grade":"Sahih"},{"name":"Zubair Ali Zai","grade":"Sahih - Agreed Upon"}],"reference":{"book":1,"hadith":276}}]}