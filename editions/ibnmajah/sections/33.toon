3738,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا يَحْيَى بْنُ أَبِي بُكَيْرٍ،‏‏‏‏ حَدَّثَ,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۹۵۹، ومصباح الزجاجة:۱۳۰۷)، وقد أخرجہ: مسند احمد (۶/۱۶),3738,,Etiquette
3739,حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ هِشَامِ بْنِ عُرْوَةَ،‏‏‏‏ عَنْ مَوْلًى لِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۷۸۱۷)، وقد أخرجہ: سنن ابی داود/الأدب ۷۸ (۴۹۷۰),3739,,Etiquette
3740,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ شُعْبَةَ،‏‏‏‏ عَنْ أَب,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «أنظرحدیث رقم:۳۷۲۰،(تحفة الأشراف:۱۶۹۲),3740,,Etiquette
3741,حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ إِدْرِيسَ،‏‏‏‏ عَنْ دَاوُدَ،‏‏‏‏ عَنْ ال,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن ابی داود/الأدب ۷۱ (۴۹۶۲)، سنن الترمذی/تفسیر القرآن ۴۹ (۳۲۶۸)،(تحفة الأشراف:۱۱۸۸۲)، وقد أخرجہ: مسند احمد (۴/۶۹،۲۶۰،۵/۳۸۰),3741,,Etiquette
3742,حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ،‏‏‏‏ عَنْ سُفْيَانَ،‏‏‏‏ ع,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الزہد ۱۴ (۳۰۰۲)، سنن ابی داود/الأدب ۱۰ (۴۸۰۴)، سنن الترمذی/الزہد ۵۴ (۲۳۹۲)،(تحفة الأشراف:۱۱۵۴۵),3742,,Etiquette
3743,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا غُنْدَرٌ،‏‏‏‏ عَنْ شُعْبَةَ،‏‏‏‏ عَنْ سَ,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۴۴۱، ومصباح الزجاجة:۱۳۰۸)، وقد أخرجہ: مسند احمد (۴/۹۲،۹۳،۹۸،۹۹),3743,,Etiquette
3744,حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا شَبَابَةُ،‏‏‏‏ حَدَّثَنَا شُعْبَةُ،‏‏‏‏ عَنْ خَالِدٍ الْحَذّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الشہادات ۱۶ (۲۶۶۲)، الأدب ۹۵ (۶۱۶۲)، صحیح مسلم/الزہد ۱۴ (۳۰۰۰)، سنن ابی داود/الأدب ۱۰ (۴۸۰۵)،(تحفة الأشراف:۱۱۶۷۸)، وقد أخرجہ: مسند احمد (۵/۴۱،۴۶،۴۷،۵۰),3744,,Etiquette
3745,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا يَحْيَى بْنُ أَبِي بُكَيْرٍ،‏‏‏‏ عَنْ شَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Hasan,takhreej: «سنن ابی داود/الأدب ۱۲۳ (۵۱۲۸)، سنن الترمذی/الأدب ۵۷ (۸۸۲۲)،(تحفة الأشراف:۱۴۹۷۷)، وقد أخرجہ: مسند احمد (۲/۲۸۹),3745,,Etiquette
3746,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا أَسْوَدُ بْنُ عَامِرٍ،‏‏‏‏ عَنْ شَرِيكٍ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۹۸۸، ومصباح الزجاجة:۱۳۰۹)، وقد أخرجہ: مسند احمد (۵/۲۷۴)، سنن الدارمی/السیر ۱۳ (۲۴۹۳),3746,,Etiquette
3747,حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا يَحْيَى بْنُ زَكَرِيَّا بْنِ أَبِي زَائِدَةَ،‏‏‏‏ وَعَلِيُّ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۹۳۹),3747,,Etiquette
3748,حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا عَبْدَةُ بْنُ سُلَيْمَانَ . ح وحَدَّثَنَا عَلِيُّ بْنُ مُحَم,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الحمام ۱ (۴۰۱۱)،(تحفة الأشراف:۸۸۷۷),3748,,Etiquette
3749,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ . ح وحَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۷۷۹۸، ومصباح الزجاجة:۱۳۱۰)، وقد أخرجہ: سنن ابی داود/الحمام ۱ (۴۰۰۹)، سنن الترمذی/الأدب۴۳ (۲۸۰۲)، ولم یذکرا: ''ولم يرخص للنساء'' مسند احمد (۶/۱۳۲،۱۳۹،۱۷۹),3749,,Etiquette
3750,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ سُفْيَانَ،‏‏‏‏ عَنْ مَنْصُورٍ،‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الحمام ۱ (۴۰۱۰)، سنن الترمذی/الأدب ۴۳ (۲۸۰۳)،(تحفة الأشراف:۱۷۸۰۴)، وقد أخرجہ: مسند احمد (۶/ ۱۷۳،۱۹۸، سنن الدارمی/الاستئذان ۲۳ (۲۶۹۳),3750,,Etiquette
3751,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ عَبْدِ اللَّهِ،‏‏‏‏ حَدَّث,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۸۱۴۶، ومصباح الزجاجة:۱۳۱۱),3751,,Etiquette
3752,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنِي إِسْحَاق بْنُ مَنْصُورٍ،‏‏‏‏ عَنْ كَامِلٍ أَبِي ال,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۸۱۴۷، ومصباح الزجاجة:۱۳۱۲),3752,,Etiquette
3753,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ،‏‏‏‏ حَدَّثَنَا الْهِقْلُ بْنُ زِيَادٍ،‏‏‏‏ حَدَّثَنَا الْأَوْزَاعِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۷۲۷، ومصباح الزجاجة:۱۳۱۳)، وقد أخرجہ: مسند احمد (۲/۱۷۸،۱۸۳)، سنن الدارمی/الرقاق ۶۳ (۲۸۲۱),3753,,Etiquette
3754,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ الْعُمَرِيِّ،‏‏‏‏ عَنْ نَافِعٍ،‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۷۳۸، ومصباح الزجاجة:۱۳۱۴),3754,,Etiquette
3755,حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ،‏‏‏‏ عَنْ يُونُسَ،‏‏‏‏ عَنْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الأدب ۹۰ (۶۱۴۵)، سنن ابی داود/الأدب ۹۵ (۵۰۰۹،۵۰۱۰)،(تحفة الأشراف:۵۹)، وقد أخرجہ: مسند احمد (۵/ ۱۲۵،۱۲۶)، سنن الدارمی/الاستئذان ۶۸ (۲۷۴۶),3755,,Etiquette
3756,حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا أَبُو أُسَامَةَ،‏‏‏‏ عَنْ زَائِدَةَ،‏‏‏‏ عَنْ سِمَاكٍ،‏‏‏‏ ع,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Hasan,takhreej: «سنن ابی داود/الأدب ۹۵ (۵۰۱۱)، سنن الترمذی/الأدب ۶۹ (۲۸۴۵)،(تحفة الأشراف:۶۱۰۶)، وقد أخرجہ: مسند احمد (۱/۲۶۹،۲۷۳،۳۰۳،۳۰۹،۳۱۳،۳۲۷،۳۳۲),3756,,Etiquette
3757,حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ،‏‏‏‏ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ،‏‏‏‏ عَنْ عَبْدِ الْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/مناقب الأنصار ۲۶ (۳۸۴۱)، صحیح مسلم/الشعر (۲۲۵۶)، سنن الترمذی/الأدب ۷۰ (۲۸۴۹)،(تحفة الأشراف:۱۴۹۷۶)، وقد أخرجہ: مسند احمد (۲/۲۴۸،۳۹۱،۳۹۳،۴۴۴،۴۵۸،۴۷۰،۴۸۰),3757,,Etiquette
3758,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عِيسَى بْنُ يُونُسَ،‏‏‏‏ عَنْ عَبْدِ الل,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الشعر (۲۲۵۵)، سنن الترمذی/الشمائل (۲۴۹)، سنن النسائی/الیوم و للیلة (۹۹۸)،(تحفة الأشراف:۴۸۳۶)، وقد أخرجہ: مسند احمد (۴/۳۸۸،۳۸۹),3758,,Etiquette
3759,حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا حَفْصٌ،‏‏‏‏ وَأَبُو مُعَاوِيَةَ،‏‏‏‏ وَوَكِيعٌ،‏‏‏‏ عَنْ الْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الأدب ۹۲ (۶۱۵۵)، صحیح مسلم/الشعر (۲۲۵۷)، سنن الترمذی/الأدب ۷۱ (۲۸۵۱)،(تحفة الأشراف:۱۲۳۶۴،۱۲۴۶۸،۱۲۵۲۳)، وقد أخرجہ: مسند احمد (۲/۲۸۸،۳۵۵،۳۹۱،۴۸۰),3759,,Etiquette
3760,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ،‏‏‏‏ حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ،‏‏‏‏ وَمُحَمَّدُ بْنُ جَعْفَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الشعر (۲۲۵۸)، سنن الترمذی/الأدب ۷۱ (۲۸۵۲)،(تحفة الأشراف:۳۹۱۹)، وقد أخرجہ: مسند احمد (۱/۱۷۵،۱۷۷،۱۸۱),3760,,Etiquette
