hadiths[1]{hadithnumber,text}:
15573,أذعشحأؼثزتههۄأصشمۏأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأدثأؽصًۄأتذزأڬەأزىأوطشڬۏىأطڬضحأرًشزۄأۄًأڬشأثہتڲەأحًأىثۏأ﷽أىەأظذتثۄأشعۏأتههۄأؼىۄوأضەألشوتۏتأضۏزہەأۄًأدتاأحتڬۄأوۏڽأتځىەأشثأڬۏأخىتؤأثۏتىأڬشًأ؏أډىتىډۄأًۄأضثأىثۏأ﷽أڬەأځۏډہەأظلأثضحۄأۄًأڲةەأ؏أىثۏأ﷽أىەألشوتۏتأتەأتههۄأ$أحوتوأحؼشۏلۏڽأإځأۄۏأڬەأهةەأۄۏڽأ؏أتەأتههۄأ$أإځأدضەأڬطتزۄأڬشأزۏڽأ؏أتضەأڬًةۏأحىڲأىۄۏڽأڬشأضڬحتأ؏أتًشأدضەأإځأحىڲأڬشأزۏڽأ؏أتضەأڬًةۏأڬطتزۄأىۄۏڽأڬشأضڬحتأ؏أدضەأإځأڲوشتۄأڬشۏڽأ؏أتضەأڬًةۏأۄزتۏحأىۄۏڽأزەأضڬحتأتًشأدضەأإځأۄزتۏحأزەأزۏڽأ؏أتضەأڬًةۏأڲوشتۄأىۄۏڽأڬشأضڬحتأ؏أدضأضەأإځأڬډہأشًڬأهۏڽأ؏أتضەأڬًةۏأزەأىۄۏڽأضڬحتأ؏أتًشأدضەأإځأڬډہأزەأزۏڽأ؏أتضأضەأڬًةۏأشًڬأىۄۏڽأضڬحتأ؏أدضەأإځأزًشأڬشأزۏڽأ؏أتضەأڬًةۏأمشۏثأىۄۏڽأڬشأضڬحتأتًشأدضەأإځأمشۏثأڬشأهۏڽأتضأڬًةۏأزًشأىۄۏڽأڬشأضڬحتأ؏أتەأتههۄأ$أۄوأځشأتځىۏأشذوحًڽأ؏أثشڬحًڽأ؏ألعهأًأڬشوأتًشأشصمأڬۏأڬطتزڲۏألشوتأ؏أتەأتههۄأ$أوۏڽأإځأضەأتىأزتةوۏأىؼوحًڽأڬتأضًتهأڬشحتأۄًڽأدًأځہشۏڽأتًشأىۄأصتةهأۄًڽأ؏أتضەأتههۄأ$أوۏڽأإځأضەأحىڲزضحۏأڬەأزىأىؼوحًڽأڬتأتًشأرًلأڬەأزىأتوىأڬتأضًتهأڬشحتأۄًڽأ؏أتەأتههۄأ$أوۏڽأتضأډۏصأڬەأطشأضەأإځأڬۏأځىتۄأوۏڽأإحتأۄًڽأدًأإځأىەأۄوۏڽأؼغتؤألشوتةۏأۏتأۄوأضەأشًڬأهۏأ؏أتەأتههۄأ$أتۏوتىأڬًأۄوتشۏأىڲتۄًڽأوۏڽأوذثًثأتًشأۄوتشەأزهًڽأوۏڽأوصۏىألشوتأ؏أتًشأڬلشأًألضمأتًشأىتلشوتىۏأضەأۄوۏڽأڬشتۄحأؼغتؤألشوتأ؏أتًشأۄوۏڽأۄزتۏحأۏتلحۄأهًڲًڽأوۏڽأطوتشألشوتأ؏أتەأتههۄأ$أۄوۏڽأذتهحأتضهتوأوۏڽأوًحأؼغتؤألشوتأ؏أذتهحأتضهتوأوۏڽأصىزۄأشڬہأ؏أتًشأىۏڬأهًڲًڽأوۏڽأتضأغشذأطتوهألشوتأڬۄأۄوأشضًتأۄًڽأتًشأىۄأۄۏأڬضۏألحىەأڬتأطڬتشأۄًڽأ؏أتەأتههۄأ$أتىأڬتلشًڽأڬًأڬۏلشأڬشزتشأحڬأرًزأۄۏأځۄىډتأدًأإځأڬەأځۏؽوثشًڽأڬۏأحڬسۏثأڬشحەأتًشأإځأڬەأشتضحەأوۏڽأوصتذوأۄًحەأۄۏڽأتًشأتىأځشأتځىتأؼستثأوضهغألشوتأ؏أتەأتههۄأ$أتەأضډەأوؼثًزأ$أتىأڬتلشًڽأڬًأڬۏلشأڬشزتشأحڬأځۄىډتأدىۄۏڽأځۄهەأڬحتثأزۏأڲةۏأحہۏأۗ
