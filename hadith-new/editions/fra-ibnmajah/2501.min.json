{"metadata":{"name":"Sunan Ibn Majah","section":{"17":"The Chapters on Pre-emption"},"section_detail":{"17":{"hadithnumber_first":2492,"hadithnumber_last":2501,"arabicnumber_first":2492,"arabicnumber_last":2501}}},"hadiths":[{"hadithnumber":2501,"arabicnumber":2501,"text":"Rapporté par Ibn 'Umar : Le Messager d'Allah (ﷺ) a dit : \"Il n'y a pas de préemption pour un associé si son co-associé l'a précédé (dans une autre affaire avant), ni pour un mineur ni pour un absent","grades":[{"name":"Al-Albani","grade":"Very Daif"},{"name":"Muhammad Fouad Abd al-Baqi","grade":"Very Daif"},{"name":"Shuaib Al Arnaut","grade":"Very Daif"},{"name":"Zubair Ali Zai","grade":"Daif"}],"reference":{"book":17,"hadith":11}}]}