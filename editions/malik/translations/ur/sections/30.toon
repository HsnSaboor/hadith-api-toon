{"hadithnumber": "1272", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ حضرت عمر بن خطاب رضی اللہ عنہ نے فرمایا : جو کوئی"}
{"hadithnumber": "1273", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ بے شک حضرت عمر بن خطاب رضی اللہ عنہ کے پاس ایک لونڈی آئی جسے"}
{"hadithnumber": "1274", "text": "حضرت عمر بن حکم سے روایت ہے ، انھوں نے کہا کہ میں رسول اللہ ﷺ کے پاس آیا ، میں نے عرض کیا کہ اے اللہ"}
{"hadithnumber": "1275", "text": "عبیداللہ بن عبداللہ بن عتبہ بن مسعود رحمہ اللہ سے روایت ہے کہ انصار میں سے ایک آدمی رسول اللہ ﷺ کے پ"}
{"hadithnumber": "1276", "text": "( سعید بن ابی سعید ) مقبری رحمہ اللہ سے روایت ہے کہ حضرت ابوہریرہ رضی اللہ عنہ سے اس شخص کے متعلق سو"}
{"hadithnumber": "1277", "text": "حضرت فضالہ بن عبید انصاری رضی اللہ عنہ سے روایت ہے جو کہ رسول اللہ ﷺ کے اصحاب میں سے تھے ، ان سے اس"}
{"hadithnumber": "1278", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ حضرت عبداللہ بن عمر رضی اللہ عنہما سے واجب گردن کے متعلق سوال"}
{"hadithnumber": "1279", "text": "عبدالرحمن بن ابی عمرہ انصاری رحمہ اللہ سے روایت ہے کہ ان کی والدہ نے وصیت کرنے کا ارادہ کیا ، پھر ان"}
{"hadithnumber": "1280", "text": "یحیی بن سعید رحمہ اللہ سے روایت ہے کہ حضرت عبدالرحمن بن ابی بکر رضی اللہ عنہما نیند کے درمیان فوت ہو"}
{"hadithnumber": "1281", "text": "سیدہ عائشہ رضی اللہ عنہا زوجہ رسول ﷺ سے روایت ہے کہ بے شک رسول اللہ ﷺ سے واجب گردنوں کے متعلق سوال ک"}
{"hadithnumber": "1282", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ انھوں نے زنا والے بچے اور اس کی ( زانیہ ) ماں کو آ"}
{"hadithnumber": "1283", "text": "سیدہ عائشہ رضی اللہ عنہا زوجہ رسول ﷺ سے روایت ہے ، انھوں نے کہا کہ ( میرے پاس ) حضرت بریرہ رضی اللہ"}
{"hadithnumber": "1284", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ بے شک سیدہ عائشہ رضی اللہ عنہا نے ایک لونڈی خریدنے"}
{"hadithnumber": "1285", "text": "عمرہ بنت عبدالرحمن رحمہ اللہ سے روایت ہے کہ حضرت بریرہ رضی اللہ عنہا آئیں ، وہ ام المومنین سیدہ عائش"}
{"hadithnumber": "1286", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ بے شک رسول اللہ ﷺ نے ولاء کو بیچنے اور اسے ہبہ کرن"}
{"hadithnumber": "1287", "text": "ربیعہ بن ابی عبدالرحمن رحمہ اللہ سے روایت ہے کہ حضرت زبیر بن عوام رضی اللہ عنہ نے ایک غلام خریدا ، پ"}
{"hadithnumber": "1288", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ سعید بن مسیب رحمہ اللہ سے اس غلام کے متعلق سوال کیا گیا جس کی"}
{"hadithnumber": "1289", "text": "عبدالملک بن ابی بکر رحمہ اللہ اپنے والد ابوبکر بن عبدالرحمن بن حارث بن ہشام رحمہ اللہ سے روایت کرتے"}
