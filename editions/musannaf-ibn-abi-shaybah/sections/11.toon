hadiths[1628]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}:
18021,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، وَوَکِیعٌ ، وَحَفْصٌ ، وَأَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِِ ، عَنْ مَالِکِ بْنِ الْحَارِثِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، عَنْ عَبْدِ اللہِ ؛ {فَطَلِّقُوہُنَّ لِعِدَّتِہِنَّ} قَالَ : فِی غَیْرِ جِمَاعٍ۔",,,18021,,
18022,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الأَحْوَصِ ، عَنْ عَبْدِ اللہِ ، قَالَ : إذَا أَرَادَ الرَّجُلُ أَنْ یُطَلِّقَ امْرَأَتَہُ ، فَلْیُطَلِّقْہَا طَاہِرًا فِی غَیْرِ جِمَاعٍ۔",,,18022,,
18023,"حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ یَزِیدَ الدَّالاَنِیِّ ، عَنْ أَبِی الْعَلاَئِ ، عَنْ حُمَیْدِ بْنِ عَبْدِ الرَّحْمَنِ الْحِمْیَرِیِّ ، قَالَ : بَلَغَ أَبَا مُوسَی أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَجَدَ عَلَیْہِمْ ، فَأَتَاہُ فَذَکَرَ ذَلِکَ لَہُ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : یَقُولُ أَحَدُکُمْ : قَدْ تَزَوَّجْتُ ، قَدْ طَلَّقْتُ وَلَیْسَ کَذَا عِدَّۃُ الْمُسْلِمِینَ ، طَلِّقُوا الْمَرْأَۃَ فِی قُبُلِ عِدَّتِہَا۔ (ابن ماجہ 2017۔ ابن حبان 4265)",,,18023,,
18024,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، قَالَ : سَمِعْتُ مُجَاہِدًا یُحَدِّثُ عَنِ ابْنِ عَبَّاسٍ ؛ فِی ہَذَا الْحَرْفِ : {یَا أَیُّہَا النَّبِیُّ إذَا طَلَّقْتُمُ النِّسَائَ فَطَلِّقُوہُنَّ لِعِدَّتِہِنَّ} قَالَ : فِی قُبُلِ عِدَّتِہِنَّ۔",,,18024,,
18025,"حَدَّثَنَا وَکِیعٌ ، عَنْ یَزِیدَ ، عَنِ ابْنِ سِیرِینَ قَالَ : قَالَ رَجُلٌ ، یَعْنِی عَلِیًّا ، لَوْ أَنَّ النَّاسَ أَصَابُوا حَدَّ الطَّلاَقِ مَا نَدِمَ رَجُلٌ عَلَی امْرَأَۃٍ ، یُطَلِّقُہَا وَہِیَ حَامِلٌ قَدْ تَبَیَّنَ حَمْلُہَا ، أَوْ طَاہِرٌ لَمْ یُجَامِعْہَا مُنْذُ طَہُرَت ، یَنْتَظِرُ حَتَّی إذَا کَانَ فِی قُبُلِ عِدَّتِہَا طَلَّقَہَا ، فَإِنْ بَدَا لَہُ أَنْ یُرَاجِعَہَا رَاجَعَہَا ، وَإِنْ بَدَا لَہُ أَنْ یُخَلِّیَ سَبِیلَہَا خَلَّی سَبِیلَہَا۔",,,18025,,
18026,"حدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَابْنِ سِیرِینَ ؛ أَنَّہُمَا قَالاَ : طَلاَقُ السُّنَّۃِ فِی قُبُلِ الْعِدَّۃِ ، یُطَلِّقُہَا طَاہِرًا فِی غَیْرِ جِمَاعٍ ، وَإِنْ کَانَ بِہَا حَمْلٌ طَلَّقَہَا مَتَی شَائَ۔",,,18026,,
18027,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ قَالَ : طَلَّقْتُ امْرَأَتِی وَہِیَ حَائِضٌ ، فَذَکَرَ ذَلِکَ عُمَرُ لِرَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : مُرْہُ فَلْیُرَاجِعْہَا حَتَّی تَطْہُرَ ، ثُمَّ تَحِیضَ ، ثُمَّ تَطْہُرَ ، ثُمَّ إِنْ شَائَ طَلَّقَہَا قَبْلَ أَنْ یُجَامِعَہَا ، وَإِنْ شَائَ أَمْسَکَہَا ، فَإِنَّہَا الْعِدَّۃُ الَّتِی قَالَ اللَّہُ۔\n\n(مسلم 1094۔ مالک 53)",,,18027,,
18028,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ مَنْصُورٍ ، عَنْ أَبِی وَائِلٍ قَالَ : طَلَّقَ ابْنُ عُمَرَ امْرَأَتَہُ وَہِیَ حَائِضٌ ، فَأَتَی عُمَرُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَأَخْبَرَہُ ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مُرْہُ فَلْیُرَاجِعْہَا ، ثُمَّ لِیُطَلِّقْہَا طَاہِرًا فِی غَیْرِ جِمَاعٍ۔",,,18028,,
18029,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ ، مَوْلَی آلِ طَلْحَۃَ ، عَنْ سَالِمٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ طَلَّقَ امْرَأَتَہُ وَہِیَ حَائِضٌ ، فَذَکَرَ ذَلِکَ عُمَرُ لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقَالَ : مُرْہُ فَلْیُرَاجِعْہَا ثُمَّ لِیُطَلِّقْہَا طَاہِرًا ، أَوْ حَامِلاً۔ (مسلم 5۔ ابوداؤد 2174)",,,18029,,
18030,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ قَالَ : إذَا طَلَّقَہَا فِی طُہْرٍ قَدْ جَامَعَہَا فِیہِ ، لَمْ تَعْتَدَّ فِیہِ بِتِلْکَ الْحَیْضَۃِ۔",,,18030,,
18031,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، عَنْ بَیَانٍ ، عَنِ الشَّعْبِیِّ قَالَ : إذَا طَلَّقَہَا وَہِیَ طَاہِرٌ فَقَدْ طَلَّقَہَا لِلسُّنَّۃِ ، وَإِنْ کَانَ قَدْ جَامَعَہَا۔",,,18031,,
18032,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عِکْرِمَۃَ ، وَمُجَاہِدٍ ؛ (فَطَلِّقُوہُنَّ لِعِدَّتِہِنَّ) قَالاَ : طَاہِرًا فِی غَیْرِ جِمَاعٍ۔",,,18032,,
18033,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ خَالِدِ ، عَنْ مُحَمَّدٍ ؛ (فَطَلِّقُوہُنَّ لِعِدَّتِہِنَّ) قَالَ : طَاہِرًا ، أَوْ حَامِلاً۔",,,18033,,
18034,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ، عَنْ عَبِیدَۃَ ، عَنْ عَلِیٍّ قَالَ : مَا طَلَّقَ رَجُلٌ طَلاَقَ السُّنَّۃِ فَنَدِمَ۔",,,18034,,
18035,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، عَنْ إبْرَاہِیمَ بْنِ مُہَاجِرٍ ، عَنْ إبْرَاہِیمَ ، عَنْ عَبْدِ اللہِ قَالَ : طَلاَقُ السُّنَّۃِ فِی قُبُلِ الطُّہْرِ مِنْ غَیْرِ جِمَاعٍ",,,18035,,
18036,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الأَحْوَصِ ، عَنْ عَبْدِ اللہِ قَالَ : مَنْ أَرَادَ الطَّلاَقَ الَّذِی ہُوَ الطَّلاَقُ فَلْیُطَلِّقْہَا تَطْلِیقَۃً ، ثُمَّ یَدَعَہَا حَتَّی تَحِیضَ ثَلاَثَ حِیَضٍ۔",,,18036,,
18037,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ ہِشَامِ بْنِ حُجَیْرٍ ، عَنْ طَاوُوسٍ قَالَ : طَلاَقُ السُّنَّۃِ أَنْ یُطَلِّقَ الرَّجُلُ امْرَأَتَہُ طَاہِرًا فِی غَیْرِ جِمَاعٍ ، ثُمَّ یَدَعَہَا حَتَّی تَنْقَضِیَ عِدَّتُہَا۔",,,18037,,
18038,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ خَالِدٍ الْحَذَّائِ ، عَنْ أَبِی قِلاَبَۃَ ؛ أَنَّہُ کَانَ یَقُولُ فِی طَلاَقِ السُّنَّۃِ : أَنْ یُطَلِّقَہَا وَاحِدَۃً ، ثُمَّ یَدَعَہَا حَتَّی تَبِینَ بِہَا۔",,,18038,,
18039,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ زَیْدٍ ، عَنْ یَحْیَی بْنِ عَتِیقٍ ، عَنِ ابْنِ سِیرِینَ قَالَ : قَالَ عَلِیٌّ : لَوْ أَنَّ النَّاسَ أَصَابُوا حَدَّ الطَّلاَقِ ، مَا نَدِمَ رَجُلٌ عَلَی امْرَأَۃٍ ، یُطَلِّقُہَا وَاحِدَۃً ، ثُمَّ یَتْرُکُہَا حَتَّی تَحِیضَ ثَلاَثَ حِیَضٍ۔",,,18039,,
18040,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : کَانُوا یَسْتَحِبُّونَ أَنْ یُطَلِّقَہَا وَاحِدَۃً ، ثُمَّ یَتْرُکَہَا حَتَّی تَحِیضَ ثَلاَثَ حِیَضٍ۔",,,18040,,
18041,"حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، وَحَمَّادٌ ؛ فِی طَلاَقِ السُّنَّۃِ قَالاَ : یُطَلِّقُ الرَّجُلُ امْرَأَتَہُ ، ثُمَّ یَدَعَہَا حَتَّی تَنْقَضِیَ عِدَّتُہَا۔",,,18041,,
18042,"حَدَّثَنَا أَبُو عَامِرٍ الْعَقَدِیُّ ، عَنْ عَبْدِ الْحَکِیمِ بْنِ أَبِی فَرْوَۃَ ، قَالَ : سَمِعْتُ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ یَقُولُ : مَا بَالُ رِجَالٍ یَقُولُ أَحَدُہُمْ لاِمْرَأَتِہِ : اذْہَبِی إلَی أَہْلِکِ ، فَیُطَلِّقُہَا فِی أَہْلِہَا ، فَنَہَی عَنْ ذَلِکَ أَشَدَّ النَّہْیِ ، قَالَ عَبْدُ الْحَکِیمِ : یَعْنِی بِذَلِکَ الْعِدَّۃَ۔",,,18042,,
18043,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ قَالَ : سُئِلَ جَابِرٌ عَنْ حَامِلٍ کَیْفَ تُطْلَقُ ؟ فَقَالَ : یُطَلِّقُہَا وَاحِدَۃً ، ثُمَّ یَدَعُہَا حَتَّی تَضَعَ۔",,,18043,,
18044,"حَدَّثَنَا أَبُو بَکْرٍ الْحَنَفِیُّ ، عَنِ ابْنِ أَبِی ذِئْبٍ قَالَ : سَأَلْتُ عَنْ ذَلِکَ الزُّہْرِیَّ ؟ فَقَالَ : کُلُّ ذَلِکَ لَہَا وَقْتٌ۔",,,18044,,
18045,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَمُحَمَّدٍ قَالاَ : إذَا کَانَتْ حَامِلاً طَلَّقَہَا مَتَی شَائَ۔",,,18045,,
18046,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ حَمَّادٍ قَالَ: کَانَ یَسْتَحِبُّ أَنْ یُطَلِّقَ الْحَامِلَ وَاحِدَۃً، ثُمَّ یَدَعَہَا حَتَّی تَضَعَ۔",,,18046,,
18047,"حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ سُفْیَانَ ، عَنْ أَشْعَثَ ، عَنْ عَامِرٍ قَالَ : تُطْلَقُ الْحَامِلُ بِالأَہِلَّۃِ۔",,,18047,,
18048,"حَدَّثَنَا عَبْدُ الرَّزَّاقِ ، عَنْ مَعْمَرٍ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ قَالَ : إذَا طَلَّقَ الرَّجُلُ امْرَأَتَہُ وَہِیَ حَائِضٌ ، فَلاَ تَعْتَدُّ بِہَا ، وَقَالَ الزُّہْرِیُّ وَقَتَادَۃُ مِثْلَہُ۔",,,18048,,
18049,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ فِی الَّذِی یُطَلِّقُ امْرَأَتَہُ وَہِیَ حَائِضٌ ، قَالَ : لاَ تَعْتَدُّ بِتِلْکَ الْحَیْضَۃِ۔",,,18049,,
18050,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنِ الشَّعْبِیِّ ، عَنْ شُرَیْحٍ قَالَ : إذَا طَلَّقَ الرَّجُلُ امْرَأَتَہُ وَہِیَ حَائِضٌ ، لَمْ تَعْتَدَّ بِتِلْکَ الْحَیْضَۃِ۔",,,18050,,
18051,"حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنْ لَیْثٍ، عَنْ طَاوُوسٍ قَالَ: إذَا طَلَّقَ الرَّجُلُ امْرَأَتَہُ وَہِیَ حَائِضٌ، لَمْ تَعْتَدَّ بِتِلْکَ الْحَیْضَۃِ۔",,,18051,,
18052,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ قَالَ : لاَ تَعْتَدُّ بِہَا",,,18052,,
18053,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، وَعَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : لاَ تَعْتَدُّ بِہَا۔",,,18053,,
18054,"حَدَّثَنَا عَبدَۃ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ قَالَ : لاَ تَعْتَدُّ بِہَا۔",,,18054,,
18055,"حَدَّثَنَا وَکِیعٌ، عَنْ إسْرَائِیلَ، عَنْ جَابِرٍ، عَنْ عَامِرٍ قَالَ: إذَا طَلَّقَہَا وَہِیَ حَائِضٌ، لَمْ تَعْتَدَّ بِتِلْکَ الْحَیْضَۃِ۔",,,18055,,
18056,"حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ فِی الرَّجُلِ یُطَلِّقُ امْرَأَتَہُ سَاعَۃَ حَاضَتْ ، قَالَ : لاَ تَعْتَدُّ بِہَا۔",,,18056,,
18057,"حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ ، عَنْ ہَمَّامٍ ، عَنْ مَالِکِ بْنِ دِینَارٍ ، عَنْ جَابِرِ بْنِ زَیْدٍ قَالَ : لاَ تَعْتَدُّ بِتِلْکَ الْحَیْضَۃِ۔",,,18057,,
18058,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ ہَمَّامٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدٍ ، وَخِلاَسٍ قَالاَ : لاَ تَعْتَدُّ بِتِلْکَ الْحَیْضَۃِ۔",,,18058,,
18059,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حُمَیْدِ بْنِ الأَسْوَدِ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ قَالَ : لاَ تَعْتَدُّ بِہَا۔",,,18059,,
18060,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، قَالَ : ہُوَ قُرْئٌ مِنْ أَقْرَائِہَا۔",,,18060,,
18061,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ قَالَ : کَانَ یَقُولُ : تَعْتَدُّ بِتِلْکَ الْحَیْضَۃِ۔",,,18061,,
18062,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ أَنَسِ بْنِ سِیرِینَ ، قَالَ : قُلْتُ لابْنِ عُمَرَ : احْتَسَبْتَ بِہَا ؟ قَالَ : فَقَالَ : فَمَہْ ، یَعْنِی بِالتَّطْلِیقَۃِ۔",,,18062,,
18063,"حَدَّثَنَا وَکِیعٌ ، عَنْ یَزِیدَ بْنِ إبْرَاہِیمَ ، عَنِ ابْنِ سِیرِینَ ، عَنْ یُونُسَ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ طَلَّقَ امْرَأَتَہُ وَہِیَ حَائِضٌ ، فَقِیلَ لَہُ : احْتَسَبْتَ بِہَا ؟ یَعْنِی التَّطْلِیقَۃَ ، قَالَ : فَقَالَ : فَمَا یَمْنَعُنِی إِنْ کُنْتُ عَجَزْتُ وَاسْتَحْمَقْتُ ؟۔",,,18063,,
18064,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ، عَنِ الأَعْمَشِِ، عَنْ أَبِی إِسْحَاقَ، عَنْ أَبِی الأَحْوَصِ، عَنْ عَبْدِاللہِ قَالَ: إذَا أَرَادَ الرَّجُلُ أَنْ یُطَلِّقَہَا ثَلاَثًا لِلسُّنَّۃِ ، طَلَّقَہَا عِنْدَ کُلِّ طُہْرٍ وَاحِدَۃً ، وَتَعْتَدُّ بِحَیْضَۃٍ أُخْرَی عِنْدَ آخِرِ طَلاَقِہَا۔",,,18064,,
18065,"حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ ، قَالَ : عَلَیْہَا حَیْضَۃٌ أُخْرَی بَعْدَ آخِرِ تَطْلِیقَۃٍ۔",,,18065,,
18066,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ؛ أَنَّہُ کَانَ یَکْرَہُ أَنْ یُطَلِّقَ امْرَأَتَہُ عِنْدَ کُلِّ حَیْضَۃٍ ، وَإِنَّمَا یَفْعَلُ ذَلِکَ لِیُطَوِّلَ عَلَیْہَا ، فَإِذَا فَعَلَ ذَلِکَ ، فَعِدَّتُہَا مِنْ أَوَّلِ الْعِدَّۃِ مَا لَمْ یُرَاجِعْہَا۔,,,18066,,
18067,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَقُولُ : إذَا طَلَّقَ الرَّجُلُ امْرَأَتَہُ فَمَکَثَتْ شَہْرًا ، ثُمَّ طَلَّقَہَا تَطْلِیقَۃً أُخْرَی ، فَإِنَّ عِدَّتَہَا مِنْ أَوَّلِ الطَّلاَقِ مَا لَمْ یُرَاجِعْہَا۔",,,18067,,
18068,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ فِی الرَّجُلِ یُطَلِّقُ امْرَأَتَہُ عِنْدَ کُلِّ حَیْضَۃٍ تَطْلِیقَۃً ، قَالَ : تَعْتَدُّ مِنْ أَوَّلِ طَلاَقِہَا ، مَا لَمْ تَکُنْ مُرَاجَعَۃً۔",,,18068,,
18069,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ ، وَخَیْثَمَۃَ ؛ أَنَّہُمَا قَالاَ : کُلَّمَا حَاضَتْ وَقَعَتْ تَطْلِیقَۃٌ ، وَتَعْتَدُّ حَیْضَۃً أُخْرَی بَعْدَ الثَّلاَثِ ۔ قَالَ وَکِیعٌ : وَالنَّاسُ عَلَیْہِ۔",,,18069,,
18070,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ ہِشَامٍ ، عَنْ قَتَادَۃَ ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ ، وَخِلاَسِ بْنِ عَمْرٍو ، أَنَّہُمَا قَالاَ : تَعْتَدُّ مِنْ آخِرِ طَلاَقِہَا ۔ قَالَ سَعِیدُ بْنُ الْمُسَیَّبِ : وَلاَ یُعْجِبُنَا ذَلِکَ۔",,,18070,,
18071,حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ، عَنْ عُبَیْدِ اللہِ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ؛ أَنَّہُ أَشْہَدَ عَلَی رَجْعَۃِ صَفِیَّۃَ حِینَ رَاجَعَہَا۔,,,18071,,
18072,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ؛ أَنَّہُ سُئِلَ عَنْ رَجُلٍ طَلَّقَ امْرَأَتَہُ ثُمَّ رَاجَعَہَا ، فَیَجْہَلُ أَنْ یُشْہِدَ ؟ قَالَ : یُشْہِدُ إذَا عَلِمَ۔",,,18072,,
18073,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مُغِیرَۃَ ، عَنْ عَامِرٍ ؛ فِی الرَّجُلِ یُطَلِّقُ امْرَأَتَہُ ثُمَّ یُجَامِعُہَا قَبْلَ أَنْ یُشْہِدَ عَلَی رَجْعَتِہَا ، قَالَ : کَیْفَ تَقُولُ یَا مُغِیرَۃُ فِی رَجُلٍ فَعَلَ بِامْرَأَۃِ قَوْمٍ لَیْسَ مِنْہَا بِسَبِیلٍ ؟۔",,,18073,,
18074,"حَدَّثَنَا مُحَمَّدُ بْنُ عُبَیْدٍ ، عَنْ خَالِدٍ النِّیْلِی ، عَنْ أَبِی مَعْشَرٍ، عَنْ إبْرَاہِیمَ؛ فِی رَجُلٍ طَلَّقَ امْرَأَتَہُ فَأَشْہَدَ، ثُمَّ رَاجَعَہَا وَلَمْ یُشْہِدْ ، قَالَ : لَمْ یَکُنْ یُکْرَہُ ذَلِکَ تَأَثُّمًا ، وَلَکِنْ کَانَ یُخَافُ أَنْ یَجْحَدَ۔",,,18074,,
18075,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یُطَلِّقُ امْرَأَتَہُ ثُمَّ یَغْشَاہَا وَلَمْ یُشْہِدْ ، قَالَ : غِشْیَانُہُ لَہَا مُرَاجَعَۃٌ ، فَلْیُشْہِدْ۔",,,18075,,
18076,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ (ح) وَعَنْ جَابِرٍ ، عَنِ الشَّعْبِیِّ (ح) وَعَنْ سَلَیْمَانَ التَّیْمِیِّ ، عَنْ طَاوُوسٍ ، قَالُوا : الْجِمَاعُ رَجْعَۃٌ فَلْیُشْہِدْ۔",,,18076,,
18077,"حَدَّثَنَا یَحْیَی بْنُ عَبْدِ الْمَلِکِ بْنِ أَبِی غَنِیَّۃَ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ ؛ فِی قَوْلِہِ : {وَأَشْہِدُوا ذَوَیْ عَدْلٍ مِنْکُمْ} قَالَ : أُمِرُوا أَنْ یُشْہِدُوا عِنْدَ الطَّلاَقِ وَالرَّجْعَۃِ۔",,,18077,,
18078,"حَدَّثَنَا ابْنُ أَبِی غَنِیَّۃَ، عَنْ أَبِیہِ، عَنِ الْحَکَمِ؛ فِی رَجُلٍ یُرَاجِعُ امْرَأَتَہُ وَلاَ یُشْہِدُ، قَالَ: فَلْیُشْہِدْ عَلَی رَجْعَتِہَا۔",,,18078,,
18079,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : الْفُرْقَۃُ وَالرَّجْعَۃُ بِالشُّہُودِ۔",,,18079,,
18080,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ؛ فِی رَجُلٍ طَلَّقَ امْرَأَتَہُ ، فَحَنَثَ وَقَدْ غَشِیَہَا فِی عِدَّتِہَا ، وَقَدْ عَلِمَ بِذَلِکَ بَعْدَ انْقِضَائِ الْعِدَّۃِ ، قَالَ : غِشْیَانُہُ لَہَا مُرَاجَعَۃٌ۔",,,18080,,
18081,حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ مِثل ذَلِکَ۔,,,18081,,
18082,"حدَّثَنَا الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ ، عَنْ عِمْرَانَ بْنِ حُصَیْنٍ ؛ أَنَّہُ سُئِلَ عَنْ رَجُلٍ طَلَّقَ وَلَمْ یُشْہِدْ ، وَرَاجَعَ وَلَمْ یُشْہِدْ ؟ فَقَالَ : طَلَّقَ فِی غَیْرِ عِدَّۃٍ ، وَرَاجَعَ فِی غَیْرِ سُنَّۃٍ ، لِیُشْہِدْ عَلَی مَا صَنَعَ۔",,,18082,,
18083,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ؛ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ کَتَبَ : أَنَّہَا وَاحِدَۃٌ بَائِنَۃٌ ۔ وَہُوَ قَوْلُ قَتَادَۃَ۔",,,18083,,
18084,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، عَنْ أَبِی الشَّعْثَائِ قَالَ : إذَا رَاجَعَ فِی نَفْسِہِ فَلَیْسَ بِشَیْئٍ۔",,,18084,,
18085,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ قَالَ : سُئِلَ عَنْ رَجُلٍ قَالَ لامْرَأَتِہِ : إِنْ دَخَلْتِ دَارَ فُلاَنٍ فَأَنْتِ طَالِقٌ ، فَدَخَلَتْ وَہُوَ لاَ یَشْعُرُ ، حَتَّی مَضَی لِذَلِکَ أَشْہُرٌ ؟ فَحَدَّثَنَا عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، وَسَعِیدٍ ، وَخِلاَسٍ قَالُوا : إذَا عَلِمَ أَشْہَدَ عَلَی مُرَاجَعَتِہَا۔",,,18085,,
18086,"حَدَّثَنَا عَبْدُ الأَعْلَی، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ قَالَ : إِنْ دَخَلْتِ دَارَ فُلاَنٍ فَأَنْتِ طَالِقٌ وَاحِدَۃً، فَدَخَلَتْ وَہُوَ لاَ یَشْعُرُ ، قَالَ: إِنْ کَانَ غَشِیَہَا فِی الْعِدَّۃِ فَغِشْیَانُہُ لَہَا مُرَاجَعَۃٌ ، وَإِلاَّ فَقَدْ بَانَتْ مِنْہُ بِوَاحِدَۃٍ۔",,,18086,,
18087,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ حُمَیْدٍ ، عَنْ وَاقِعِ بْنِ سَحْبَانَ قَالَ : سُئِلَ عِمْرَانُ بْنُ حُصَیْنٍ عَنْ رَجُلٍ طَلَّقَ امْرَأَتَہُ ثَلاَثًا فِی مَجْلِسٍ ؟ قَالَ : أَثِمَ بِرَبِّہِ ، وَحُرِّمَتْ عَلَیْہِ امْرَأَتُہُ۔",,,18087,,
18088,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنِ الأَعْمَشِِ ، عَنْ مَالِکِ بْنِ الْحَارِثِ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : أَتَاہُ رَجُلٌ فَقَالَ : إنَّ عَمِّی طَلَّقَ امْرَأَتَہُ ثَلاَثًا ، فَقَالَ : إنَّ عَمَّک عَصَی اللَّہَ ، فَأَنْدَمَہُ اللَّہُ ، فَلَمْ یَجْعَلْ لَہُ مَخْرَجًا۔",,,18088,,
18089,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ شَقِیقِ بْنِ أَبِی عَبْدِ اللہِ ، عَنْ أَنَسٍ قَالَ : کَانَ عُمَرُ إذَا أُتِیَ بِرَجُلٍ قَدْ طَلَّقَ امْرَأَتَہُ ثَلاَثًا فِی مَجْلِسٍ ، أَوْجَعَہُ ضَرْبًا ، وَفَرَّقَ بَیْنَہُمَا۔",,,18089,,
18090,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، قَالَ : قُلْتُ لِلْقَاسِمِ بْنِ مُحَمَّدٍ : الرَّجُلُ یُرِیدُ أَنْ یُطَلِّقَ امْرَأَتَہُ ثَلاَثًا ؟ قَالَ : یُطَلِّقُہَا فِی مَقَاعِدَ مُخْتَلِفَۃٍ۔",,,18090,,
18091,"حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ أَشْعَثَ ، عَنْ نَافِعٍ قَالَ : قَالَ ابْنُ عُمَرَ : مَنْ طَلَّقَ امْرَأَتَہُ ثَلاَثًا ، فَقَدْ عَصَی رَبَّہُ ، وَبَانَتْ مِنْہُ امْرَأَتُہُ۔",,,18091,,
18092,"حَدَّثَنَا عَبْدُ الأَعْلَیْ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ؛ فِی رَجُلٍ یُطَلِّقَ امْرَأَتَہُ ثَلاَثًا جَمِیعًا ، قَالَ : إنَّ فَعَلَ فَقَدْ عَصَی رَبَّہُ ، وَبَانَتْ مِنْہُ امْرَأَتُہُ۔",,,18092,,
18093,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنِ الْحَسَنِ ، قَالَ : کَانُوا یُنَکِّلُونَ مَنْ طَلَّقَ ثَلاَثًا فِی مَقْعَدٍ وَاحِدٍ۔",,,18093,,
18094,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ قَالَ : سُئِلَ مُحَمَّدٌ عَنِ الرَّجُلِ یُطَلِّقُ امْرَأَتَہُ ثَلاَثًا فِی مَقْعَدٍ وَاحِدٍ ؟ قَالَ : لاَ أَعْلَمُ بِذَلِکَ بَأْسًا ، قَدْ طَلَّقَ عَبْدُ الرَّحْمَنِ بْنُ عَوْفٍ امْرَأَتَہُ ثَلاَثًا ، فَلَمْ یُعَبْ ذَلِکَ عَلَیْہِ۔",,,18094,,
18095,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ قَالَ : کَانَ لاَ یَرَی بِذَلِکَ بَأْسًا۔",,,18095,,
18096,"حَدَّثَنَا غُنْدَرٌ، عَنْ شُعْبَۃَ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی السَّفَرِ ، عَنِ الشَّعْبِیِّ ؛ فِی رَجُلٍ أَرَادَ أَنْ تَبِینَ مِنْہُ امْرَأَتُہُ، قَالَ: یُطَلِّقُہَا ثَلاَثًا۔",,,18096,,
18097,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ ، عَنْ عَلْقَمَۃَ ، عَنْ عَبْدِ اللہِ ، قَالَ : أَتَاہُ رَجُلٌ فَقَالَ : إنِّی طَلَّقْت امْرَأَتِی تِسْعَۃً وَتِسْعِینَ مَرَّۃً ؟ قَالَ : فَمَا قَالُوا لَکَ ؟ قَالَ : قَالُوا : قَدْ حُرِّمَتْ عَلَیْک ، قَالَ : فَقَالَ عَبْدُ اللہِ : لَقَدْ أَرَادُوا أَنْ یُبْقُوا عَلَیْک ، بَانَتْ مِنْک بِثَلاَثٍ وَسَائِرُہُنَّ عُدْوَانٌ۔",,,18097,,
18098,"حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ ، عَنْ عَلْقَمَۃَ ، عَنْ عَبْدِ اللہِ ؛ أَنَّہُ سُئِلَ عَنْ رَجُلٍ طَلَّقَ امْرَأَتَہُ مِئَۃَ تَطْلِیقَۃٍ ؟ قَالَ : حرَّمَتْہَا ثَلاَثٌ ، وَسَبْعَۃٌ وَتِسْعُونَ عُدْوَانٌ۔",,,18098,,
18099,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، وَالأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَنْ عَلْقَمَۃَ ، قَالَ : جَائَ رَجُلٌ إلَی عَبْدِ اللہِ ، فَقَالَ : إنِّی طَلَّقْت امْرَأَتِی مِئَۃً ؟ فَقَالَ : بَانَتْ مِنْک بِثَلاَثٍ ، وَسَائِرُہُنَّ مَعْصِیَۃٌ۔",,,18099,,
18100,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنْ زَیْدِ بْنِ وَہْبٍ ؛ أَنَّ رَجُلاً بَطَّالاً کَانَ بِالْمَدِینَۃِ طَلَّقَ امْرَأَتَہُ أَلْفًا ، فَرُفِعَ إلَی عُمَرَ فَقَالَ : إنَّمَا کُنْت أَلْعَبُ ، فَعَلاَ عُمَرُ رَأْسَہُ بِالدُّرَّۃِ ، وَفَرَّقَ بَیْنَہُمَا۔",,,18100,,
18101,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِِ ، عَنْ حَبِیبٍ ، قَالَ : جَائَ رَجُلٌ إلَی عَلِیٍّ ، فَقَالَ : إنِّی طَلَّقْتُ امْرَأَتِی أَلْفًا ؟ قَالَ : بَانَتْ مِنْک بِثَلاَثٍ ، وَاقْسِمْ سَائِرہُنَّ بَیْنَ نِسَائِک۔",,,18101,,
18102,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ ہَارُونَ بْنِ عَنْتَرَۃَ ، عَنْ أَبِیہِ ، قَالَ : کُنْتُ جَالِسًا عِنْدَ ابْنِ عَبَّاسٍ فَأَتَاہُ رَجُلٌ فَقَالَ : یَا ابْنَ عَبَّاسٍ ، إنَّہُ طَلَّقَ امْرَأَتَہُ مِئَۃَ مَرَّۃٍ ، وَإِنَّمَا قُلْتُہَا مَرَّۃً وَاحِدَۃً فَتَبِینُ مِنِّی بِثَلاَثٍ ، ہِیَ وَاحِدَۃٌ ؟ فَقَالَ : بَانَتْ مِنْک بِثَلاَثٍ ، وَعَلَیْک وِزْرُ سَبْعَۃٍ وَتِسْعِینَ۔",,,18102,,
18103,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، قَالَ : حَدَّثَنِی عَمْرُو بْنُ مُرَّۃَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ قَالَ : جَائَ رَجُلٌ إلَی ابْنِ عَبَّاسٍ ، فَقَالَ : إنِّی طَلَّقْت امْرَأَتِی أَلْفًا ، أَوَ مِئَۃً ، قَالَ : بَانَتْ مِنْک بِثَلاَثٍ ، وَسَائِرُہُنَّ وِزْرٌ ، اتَّخَذْت آیَاتِ اللہِ ہُزُوًا۔",,,18103,,
18104,"حَدَّثَنَا وَکِیعٌ ، وَالْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنْ مُعَاوِیَۃَ بْنِ أَبِی تِحْیَی قَالَ : جَائَ رَجُلٌ إلَی عُثْمَانَ فَقَالَ : إنِّی طَلَّقْت امْرَأَتِی مِئَۃً ، قَالَ : ثَلاَثٌ یُحَرِّمْنَہَا عَلَیْک ، وَسَبْعَۃٌ وَتِسْعُونَ عُدْوَانٌ۔",,,18104,,
18105,"حَدَّثَنَا غُنْدَرٌ، عَنْ شُعْبَۃَ، عَنْ طَارِقٍ ، عَنْ قَیْسِ بْنِ أَبِی حَازِمٍ ؛ أَنَّہُ سَمِعَہُ یُحَدِّثُ عَنِ الْمُغِیرَۃِ بْنِ شُعْبَۃَ؛ أَنَّہُ سُئِلَ عَنْ رَجُلٍ طَلَّقَ امْرَأَتَہُ مِئَۃً ؟ فَقَالَ : ثَلاَثٌ یُحَرِّمْنَہَا عَلَیْہِ ، وَسَبْعَۃٌ وَتِسْعُونَ فَضْلٌ۔",,,18105,,
18106,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، عَنْ أَبِی مَعْشَرَ ، قَالَ : حدَّثَنَا سَعِیدٌ الْمَقْبُرِیُّ ، قَالَ : جَائَ رَجُلٌ إلَی عَبْدِ اللہِ بْنِ عُمَرَ وَأَنَا عِنْدَہُ ، فَقَالَ : یَا أَبَا عَبْدِ الرَّحْمَنِ ، إنَّہُ طَلَّقَ امْرَأَتَہُ مِئَۃَ مَرَّۃٍ ؟ قَالَ : بَانَتْ مِنْک بِثَلاَثٍ ، وَسَبْعَۃٌ وَتِسْعُونَ یُحَاسِبُک اللَّہُ بِہَا یَوْمَ الْقِیَامَۃِ۔",,,18106,,
18107,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ ، عَنْ شُرَیْحٍ : قَالَ : إنِّی طَلَّقْتہَا مِئَۃً ؟ قَالَ : بَانَتْ مِنْک بِثَلاَثٍ ، وَسَائِرُہُنَّ إسْرَافٌ وَمَعْصِیَۃٌ۔",,,18107,,
18108,"حَدَّثَنَا وَکِیعٌ ، عَنِ الْفَضْلِ بْنِ دَلْہَمٍ ، عَنِ الْحَسَنِ ، قَالَ : جَائَ رَجُلٌ إلَی الْحَسَنِ ، فَقَالَ : إنِّی طَلَّقْت امْرَأَتِی أَلْفًا قَالَ : بَانَتْ مِنْک الْعَجُوزُ۔",,,18108,,
18109,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِِ ، عَنْ حَبِیبٍ ، عَنْ رَجُلٍ مِنْ أَہْلِ مَکَّۃَ ، قَالَ : جَائَ رَجُلٌ إلَی عَلِیٍّ فَقَالَ: إنِّی طَلَّقْت امْرَأَتِی أَلْفًا ؟ قَالَ : الثَّلاَثُ تُحَرِّمُہَا عَلَیْک ، وَاقْسِمْ سَائِرَہُنَّ بَیْنَ أَہْلِک۔",,,18109,,
18110,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عَاصِمٍ ، عَنِ ابْنِ سِیرِینَ ، عَنْ عَلْقَمَۃَ ، عَنْ عَبْدِ اللہِ قَالَ : أَتَاہُ رَجُلٌ فَقَالَ: إنَّہُ کَانَ بَیْنِی وَبَیْنَ امْرَأَتِی کَلاَمٌ ، فَطَلَّقْتُہَا عَدَدَ النُّجُومِ ، قَالَ : تَکَلَّمْتَ بِالطَّلاَقِ ؟ قَالَ : نَعَمْ ، قَالَ : قَالَ عَبْدُ اللہِ : قَدْ بَیَّنَ اللَّہُ الطَّلاَقَ ، فَمَنْ أَخَذ بِہِ فَقَدْ بُیِّنَ لَہُ ، وَمَنْ لَبَّسَ عَلَی نَفْسِہِ جَعَلْنَا بِہِ لَبْسَہُ ، وَاللَّہِ لاَ تُلَبِّسُوا عَلَی أَنْفُسِکُمْ وَنَتَحَمَّلُہُ عَنْکُمْ ، ہُوَ کَمَا تَقُولُونَ ، ہُوَ کَمَا تَقُولُونَ۔",,,18110,,
18111,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَاصِمٍ ، عَنِ ابْنِ سِیرِینَ ، عَنْ شُرَیْحٍ ، قَالَ : لَوْ قَالَہَا لِنِسَائِ الْعَالَمِینَ بَعْدَ أَنْ یَمْلِکَہُنَّ ، کُنَّ عَلَیْہِ حَرَامًا۔",,,18111,,
18112,"حدَّثَنَا إسْمَاعِیلُ بْنُ إبْرَاہِیمَ ، عَنْ أَیُّوبَ ، عَنْ عَمْرٍو ؛ سُئِلَ ابْنُ عَبَّاسٍ عَنْ رَجُلٍ طَلَّقَ امْرَأَتَہُ عَدَدَ النُّجُومِ ؟ فَقَالَ : یَکْفِیہِ مِنْ ذَلِکَ رَأْسُ الْجَوْزَائِ۔",,,18112,,
18113,"حَدَّثَنَا عَبْدُ الْعَزِیزِ بْنُ عَبْدِ الصَّمَدِ الْعَمِّیِّ ، عَنْ عَامِرٍ الأَحْوَلِ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ طَلاَقَ إلاَّ بَعْدَ نِکَاحٍ۔ (ترمذی 1181۔ احمد 2/207)",,,18113,,
18114,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُحَمَّدِ بْنِ الْمُنْکَدِرِ ، عَمَّنْ سَمِعَ طَاوُوسًا یَقُولُ : قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ طَلاَقَ إلاَّ بَعْدَ نِکَاحٍ ، وَلاَ عِتْقَ قَبْلَ مِلْکٍ۔ (عبدالرزاق 11455)",,,18114,,
18115,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ مَیْسَرَۃَ ، عنِ النَّزَّالِ ، عَنْ عَلِیٍّ ، قَالَ : لاَ طَلاَقَ إلاَّ مِنْ بَعْدِ النِّکَاحِ۔ (ابوداؤد 2865۔ عبدالرزاق 1145)",,,18115,,
18116,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ طَلاَقَ إلاَّ بَعْدَ نِکَاحِ ، وَلاَ عِتْقَ إلاَّ بَعْدَ مِلْکِ۔",,,18116,,
18117,"حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنْ ہِشَامِ بْنِ سَعْدٍ ، عَنِ الزُّہْرِیِّ ، عَنْ عُرْوَۃَ ، عَنْ عَائِشَۃَ قَالَتْ : لاَ طَلاَقَ إلاَّ بَعْدَ نِکَاحٍ۔وَقَالَ الزُّہْرِیُّ : إذَا وَقَعَ النِّکَاحُ وَقَعَ الطَّلاَقُ۔ (حاکم 419)",,,18117,,
18118,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا حَسَنُ بْنُ صَالِحٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : مَا أُبَالِی تَزَوَّجْتُہَا ، أَوْ وَضَعْتُ یَدِی عَلَی ہَذِہِ السَّارِیَۃِ ، یَعْنِی أَنَّہَا حَلاَلٌ۔",,,18118,,
18119,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ أَبِی ذِئْبٍ ، عَنْ عَطَائٍ ، وَعَنْ مُحَمَّدِ بْنِ الْمُنْکَدِرِ ، عَنْ جَابِرٍ ، رَفََعَہُ ؛ قَالَ : لاَ طَلاَقَ قَبْلَ نِکَاحٍ۔ (بیہقی 319)",,,18119,,
18120,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الأَعْلَی ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ أَنَّ مَرْوَانَ سَأَلَ عَنْہَا ابْنَ عَبَّاسٍ ؟ فَقَالَ : لاَ طَلاَقَ قَبْلَ نِکَاحٍ ، وَلاَ عِتْقَ قَبْلَ مِلْکٍ۔",,,18120,,
18121,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ فِی رَجُلٍ قَالَ : یَوْمَ أَتَزَوَّجُ فُلاَنَۃً ، فَہِیَ طَالِقٌ ، قَالَ : لَیْسَ بِشَیْئٍ۔",,,18121,,
18122,"حدَّثَنَا خَلَفُ بْنُ خَلِیفَۃَ ، قَالَ : سَأَلْتُ مَنْصُورًا عَنِ الرَّجُلِ تُذْکَرُ لَہُ الْمَرْأَۃُ ، فَیَقُولُ : یَوْمَ أَتَزَوَّجُہَا فَہِیَ طَالِقٌ ؟ قَالَ : کَانَ الْحَسَنُ لاَ یَرَاہُ طَلاَقًا۔",,,18122,,
18123,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ یَتَزَوَّجَ الَّتِی یَقُولَ : یَوْمَ أَتَزَوَّجُہَا فَہِیَ طَالِقٌ۔",,,18123,,
18124,حَدَّثَنَا مُعْتَمِرٌ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُوسٍ ؛ مِثْلَہُ۔,,,18124,,
18125,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ أَبِی سُلَیْمَانَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ فِی الرَّجُلِ یَقُولُ : یَوْمَ أَتَزَوَّجُ فُلاَنَۃً فَہِیَ طَالِقٌ ، قَالَ : لَیْسَ بِشَیْئٍ ، إنَّمَا الطَّلاَقُ بَعْدَ النِّکَاحِ۔",,,18125,,
18126,"حَدَّثَنَا وَکِیعٌ، عَنْ مُعَرِّفِ بْنِ وَاصِلٍ، عَنْ حَبِیبِ بْنِ أَبِی ثَابِتٍ؛ أَنَّ عَلِیَّ بْنَ حُسَیْنٍ قَالَ: لاَ طَلاَقَ قَبْلَ نِکَاحٍ۔",,,18126,,
18127,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ عَلِیِّ بْنِ حُسَیْنٍ ؛ أَنَّہُ قَالَ : لاَ طَلاَقَ إلاَّ بَعْدَ نِکَاحٍ۔",,,18127,,
18128,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، قَالَ : أَخْبَرَنِی عَبْدُ اللہِ بْنُ رِفَاعَۃَ الأَنْصَارِیُّ ، أَنَّہُ ذَکَرَ لِسَعِیدِ بْنِ الْمُسَیَّبِ أَنَّ رَجُلاً مِنَ الأَنْصَارِ ، قِیلَ لَہُ : ذُکِرَ لَنَا أَنَّک تَخْطُبُ فُلاَنَۃً ، امْرَأَۃً سَمَّوْہَا ، فَقَالَ الأَنْصَارِیُّ : ہِیَ طَالِقٌ إِنْ تَزَوَّجَہَا ، فَزَعَمَ عَبْدُ اللہِ أَنَّہُ سَأَلَ سَعِیدًا ؟ فَقَالَ : أَمَّا أَنَا فَلاَ أَرَاہُ شَیْئًا ، قَالَ یَحْیَی : وَبَلَغَنِی أَنَّ عُرْوَۃَ کَانَ یَقُولُ فِی ذَلِکَ مِثْلَ قَوْلِ سَعِیدٍ۔",,,18128,,
18129,"حَدَّثَنَا أَبُو أُسَامَۃَ ، وَوَکِیعٌ ، قَالاَ : حدَّثَنَا شُعْبَۃُ ، عَنْ أَبِی بِشْرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ عَنْ شُرَیْحٍ ؛ قَالَ : لاَ طَلاَقَ إلاَّ بَعْدَ نِکَاحٍ۔",,,18129,,
18130,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُعَرِّفٍ ، عَنْ عَمْرٍو ، عَنْ طَاوُوسٍ ؛ أَنَّہُ قَالَ : لاَ طَلاَقَ قَبْلَ نِکَاحٍ ، قَالَ : وَسَأَلْتُ الْقَاسِمَ بْنَ عَبْدِ الرَّحْمَنِ ؟ فَقَالَ : لَیْسَ بِشَیْئٍ۔",,,18130,,
18131,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُعَرِّفِ بْنِ وَاصِلٍ ، عَنِ الْحَسَنِ بْنِ رَوَاحٍ الضَّبِّیِّ ، قَالَ : سَأَلْتُ سَعِیدَ بْنَ الْمُسَیَّبِ، وَمُجَاہِدًا ، وَعَطَائً عَنْ رَجُلٍ قَالَ : یَوْمَ أَتَزَوَّجُ فُلاَنَۃً فَہِیَ طَالِقٌ ؟ فَقَالُوا : لَیْسَ بِشَیْئٍ ، قَالَ : وَقَالَ سَعِیدٌ : أَیَکُونُ سَیْلٌ قَبْلَ مَطَرٍ ؟۔",,,18131,,
18132,"حَدَّثَنَا قَبِیصَۃُ ، قَالَ : حدَّثَنَا یُونُسُ بْنُ أَبِی إِسْحَاقَ ، عَنْ آدَمَ ، مَوْلَی خَالِدٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : قَالَ ابْنُ عَبَّاسٍ : قَالَ اللَّہُ تَعَالَی {یَا أَیُّہَا الَّذِینَ آمَنُوا إذَا نَکَحْتُمُ الْمُؤْمِنَاتِ ثُمَّ طَلَّقْتُمُوہُنَّ مِنْ قَبْلِ أَنْ تَمَسُّوہُنَّ} ، فَلاَ یَکُونُ طَلاَقٌ حَتَّی یَکُونَ نِکَاحٌ۔ (سعید بن منصور 1028)",,,18132,,
18133,"حَدَّثَنَا جَعْفَرُ بْنُ عَوْنٍ، عَنْ أُسَامَۃَ، عَنْ مُحَمَّدِ بْنِ کَعْبٍ، وَنَافِعِ بْنِ جُبَیْرٍ، قَالاَ: لاَ طَلاَقَ إلاَّ بَعْدَ نِکَاحٍ۔",,,18133,,
18134,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، وَأَبُو أُسَامَۃَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، قَالَ : کَانَ سَالِمٌ ، وَقَاسِمٌ ، وَعُمَرُ بْنُ عَبْدِ الْعَزِیزِ ؛ یَرَوْنَہُ جَائِزًا عَلَیْہِ۔",,,18134,,
18135,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : یُکَفُّ عَنْہَا۔",,,18135,,
18136,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ (ح) وَعَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالاَ : إذَا وَقَّتَ وَقَعَ۔",,,18136,,
18137,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ مُطَرِّفٍ ، عَنِ الشَّعْبِیِّ ؛ أَنَّہُ سُئِلَ عَنْ رَجُلٍ قَالَ لامْرَأَتِہِ : کُلُّ امْرَأَۃٍ أَتَزَوَّجُہَا عَلَیْک فَہِیَ طَالِقٌ ، قَالَ : فَکُلُّ امْرَأَۃٍ یَتَزَوَّجُہَا عَلَیْہَا ، فَہِیَ طَالِقٌ۔",,,18137,,
18138,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنْ حَبِیبِ بْنِ أَبِی مَرْزُوقٍ ، عَنْ عَطَائٍ قَالَ : إذَا الرَّجُلُ شَرَطَ لِلْمَرْأَۃِ عِنْدَ عَقْدِ النِّکَاحِ أَنَّ کُلَّ امْرَأَۃٍ یَتَزَوَّجُہَا عَلَیْہَا فَہِیَ طَالِقٌ ، وَکُلَّ سُرِّیَّۃٍ یَتَسَرَّی فَہِیَ حُرَّۃٌ ، جَازَ عَلَیْہِ۔",,,18138,,
18139,"حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنْ ہِشَامِ بْنِ سَعْدٍ ، قَالَ : قَالَ الزُّہْرِیُّ : إِذَا وَقَعَ النِّکَاحُ وَقَعَ الطَّلاَقُ۔",,,18139,,
18140,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ حَمَّادٍ ؛ فِی رَجُلٍ قَالَ لامْرَأَتِہِ : کُلُّ امْرَأَۃٍ أَتَزَوَّجُہَا عَلَیْک فَہِیَ طَالِقٌ ، قَالَ : ہَذَا وَقْتٌ ہُوَ دَاخِلٌ عَلَیْہِ۔",,,18140,,
18141,"حدَّثَنَا حَفْصٌ ، عَنْ حَنْظَلَۃَ قَالَ : سُئِلَ الْقَاسِمُ ، وَسَالِمٌ عَنْ رَجُلٍ قَالَ : یَوْمَ أَتَزَوَّجُ فُلاَنَۃً فَہِیَ طَالِقٌ ؟ قَالاَ : ہِیَ کَمَا قَالَ۔",,,18141,,
18142,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، قَالَ : سَأَلْتُ الْقَاسِمَ عَنْ رَجُلٍ قَالَ : یَوْمَ أَتَزَوَّجُ فُلاَنَۃً فَہِیَ طَالِقٌ ؟ قَالَ : ہِیَ طَالِقٌ ، سُئِلَ عُمَرُ عَنْ رَجُلٍ قَالَ : یَوْمَ أَتَزَوَّجُ فُلاَنَۃً فَہِیَ عَلَیَّ کَظَہْرِ أُمِّی ؟ قَالَ : لاَ یَتَزَوَّجُہَا حَتَّی یُکَفِّرَ۔",,,18142,,
18143,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُحَمَّدِ بْنِ قَیْسٍ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ؛ أَنَّہُ وَقَّتَ امْرَأَۃً إِنْ تَزَوَّجَہَا ، فَسَأَلَ ابْنَ مَسْعُودٍ ؟ فَقَالَ : أَعْلِمْہَا الطَّلاَقَ ثُمَّ تَزَوَّجْہَا۔",,,18143,,
18144,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُمَرَ بْنِ حَمْزَۃَ ؛ أَنَّہُ سَأَلَ سَالِمًا ، وَالْقَاسِمَ ، وَأَبَا بَکْرِ بْنَ عَبْدِ الرَّحْمَنِ ، وَأَبَا بَکْرِ بْنَ عَمْرِو بْنِ حَزْمٍ ، وَعَبْدَ اللہِ بْنَ عَبْدِ الرَّحْمَنِ ، عَنْ رَجُلٍ قَالَ : یَوْمَ أَتَزَوَّجُ فُلاَنَۃً فَہِیَ طَالِقٌ اَلْبَتَّۃَ ؟ فَقَالُوا کُلُّہُمْ : لاَ یَتَزَوَّجُہَا۔",,,18144,,
18145,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ رَجُل ، عَنْ شُرَیْحٍ ؛ أَنَّ رَجُلاً سَأَلَہُ عَنْ رَجُلٍ قَالَ : یَوْمَ أَتَزَوَّجُ فُلاَنَۃً فَہِیَ طَالِقٌ ؟ فَقَالَ شُرَیْحٌ : إذَا سَمِعْتَ بَوَادِیَ النِّوْکَاء حُلَّ بِہ ، یَعْنِی أَنَّہَا طَالِقٌ۔",,,18145,,
18146,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ سُوَیْد بْنِ نَجِیحٍ الْکِنْدِیِّ ، قَالَ : سَأَلْتُ الشَّعْبِیَّ عَنْ رَجُلٍ قَالَ : إِنْ تَزَوَّجْتُ فُلاَنَۃً فَہِیَ طَالِقٌ ، أَوْ یَوْمَ أَتَزَوَّجُ فُلاَنَۃً فَہِیَ طَالِقٌ ؟ قَالَ الشَّعْبِیُّ : ہُوَ کَمَا قَالَ ، فَقُلْتُ : إنَّ عِکْرِمَۃَ یَزْعُمُ أَنَّ الطَّلاَقَ بَعْدَ النِّکَاحِ ، فَقَالَ : جَرْمِزٌ مولی ابن عباس۔",,,18146,,
18147,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ قُدَامَۃَ ، قَالَ : قُلْتُ لِسَالِمِ بْنِ عَبْدِ اللہِ : رَجُلٌ قَالَ : کُلُّ امْرَأَۃٍ یَتَزَوَّجُہَا فَہِیَ طَالِقٌ ، وَکُلُّ جَارِیَۃٍ یَشْتَرِیہَا فَہِیَ حُرَّۃٌ ، فَقَالَ : أَمَّا أَنَا فَلَوْ کُنْتُ لَمْ أَنْکِحْ وَلَمْ أَتَسَرَّ۔",,,18147,,
18148,"حدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ (ح) وَعَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالاَ : إذَا قَالَ کُلُّ فَلَیْسَ بِشَیْئٍ۔",,,18148,,
18149,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، عَنِ الزُّہْرِیِّ ، وَمَکْحُولٍ ؛ فِی الرَّجُلِ یَقُولُ : کُلُّ امْرَأَۃٍ أَتَزَوَّجُہَا فَہِیَ طَالِقٌ ، أَنَّہُمَا کَانَا یُوجِبَانِ ذَلِکَ عَلَیْہِ۔",,,18149,,
18150,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حدَّثَنَا عَبْدُ الْمَلِکِ بْنُ أَبِی سُلَیْمَانَ ، قَالَ : سَأَلْتُ سَعِیدَ بْنَ جُبَیْرٍ عَنِ الرَّجُلِ یَقُولُ : کُلُّ امْرَأَۃٍ أَتَزَوَّجُہَا فَہِیَ طَالِقٌ ؟ قَالَ : کَیْفَ تُطَلِّقُ مَا لاَ تَمْلِکُ ؟ إنَّمَا الطَّلاَقُ بَعْدَ النِّکَاحِ۔",,,18150,,
18151,"حَدَّثَنَا ابْنُ فُضَیْلٍ، عَنْ مُطَرِّفٍ، عَنِ الْحَکَمِ، عَنِ ابْنِ عَبَّاسٍ، وَابْنِ مَسْعُودٍ، قَالاَ: فِی رَجُلٍ طَلَّقَ امْرَأَتَہُ ثَلاَثًا قَبْلَ أَنْ یَدْخُلَ بِہَا ، لاَ تَحِلُّ لَہُ حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ۔",,,18151,,
18152,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ عَلِیٍّ قَالَ : إذَا طَلَّقَ الْبِکْرَ وَاحِدَۃً فَقَدْ بَتَّہَا ، وَإِذَا طَلَّقَہَا ثَلاَثًا لَمْ تَحِلَّ لَہُ حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ۔",,,18152,,
18153,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ بُکَیْرِ بْنِ عَبْدِ اللہِ بْنِ الأَشَجِّ ، عَنْ عَطَائِ بْنِ یَسَارٍ ، قَالَ : کُنْتُ جَالِسًا عِنْدَ عَبْدِ اللہِ بْنِ عَمْرٍو ، فَسَأَلَہُ رَجُلٌ عَنْ رَجُلٍ طَلَّقَ امْرَأَتَہُ بِکْرًا ثَلاَثًا ؟ قَالَ عَطَائٌ : فَقُلْتُ : ثَلاَثٌ فِی الْبِکْرِ وَاحِدَۃٌ ، وَقَالَ عَبْدُ اللہِ بْنُ عَمْرٍو : مَا یُدْرِیْکَ ؟ إنَّمَا أَنْتَ قَاصٍّ وَلَسْتَ بِمُفْتٍ ، الْوَاحِدَۃُ تُبَینُہَا وَالثَّلاَثُ تُحَرِّمُہَا حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ۔",,,18153,,
18154,"حَدَّثَنَا عَبْدَۃُ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ بُکَیْرِ بْنِ عَبْدِ اللہِ بْنِ الأَشَجِّ ، عَنْ رَجُلٍ مِنَ الأَنْصَارِ یُقَالُ لَہُ : مُعَاوِیَۃُ ؛ أَنَّ ابْنَ عَبَّاسٍ ، وَأَبَا ہُرَیْرَۃَ ، وَعَائِشَۃَ قَالُوا : لاَ تَحِلُّ لَہُ حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ۔",,,18154,,
18155,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ خَالِدٍ ، عَنِ الْحَکَمِ ، عَنْ أَبِی سَعِیدٍ ؛ فِی الَّذِی یُطَلِّقُ امْرَأَتَہُ ثَلاَثًا قَبْلَ أَنْ یَدْخُلَ بِہَا ، فَقَالَ : لاَ تَحِلُّ لَہُ حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ۔",,,18155,,
18156,"حدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ أَشْعَثَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : سَمِعْتُ أُمَّ سَلَمَۃَ سُئِلَتْ عَنْ رَجُلٍ طَلَّقَ امْرَأَتَہُ ثَلاَثًا قَبْلَ أَنْ یَدْخُلَ بِہَا ؟ فَقَالَتْ : لاَ تَحِلُّ لَہُ حَتَّی یَطَأَہَا غَیْرَہُ۔",,,18156,,
18157,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَاصِمٍ ، عَنْ زِرٍّ ، عَنْ عَبْدِ اللہِ ، قَالَ : إذَا طَلَّقَہَا ثَلاَثًا قَبْلَ أَنْ یَدْخُلَ بِہَا، فَہِیَ بِمَنْزِلَۃِ الْمَدْخُولِ بِہَا۔",,,18157,,
18158,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَاصِمٍ ، عَنْ أَبِی وَائِلٍ ، عَنْ عَبْدِ اللہِ ؛ بِمِثْلِہِ۔,,,18158,,
18159,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حدَّثَنَا عُبَیْدُ اللہِ بْنُ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمْر ۔(ح) وَعَنْ مُحَمَّدِ بْنِ إیَاسِ بْنِ بُکَیْر ، عَنْ أَبِی ہُرَیْرَۃَ ، وَابْنِ عَبَّاسٍ ، وَعَائِشَۃَ ؛ فِی الرَّجُلِ یُطَلِّقُ امْرَأَتَہُ ثَلاَثًا قَبْلَ أَنْ یَدْخُلَ بِہَا ، قَالُوا: لاَ تَحِلُّ لَہُ حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ۔",,,18159,,
18160,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ إسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ ، عَنِ ابْنِ مَعقلٍ ؛ فِی رَجُلٍ یُطَلِّقُ امْرَأَتَہُ ثَلاَثًا قَبْلَ أَنْ یَدْخُلَ بِہَا ، قَالَ : لاَ تَحِلُّ لَہُ حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ۔",,,18160,,
18161,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ فِی الرَّجُلِ یَتَزَوَّجُ الْمَرْأَۃَ فَیُطَلِّقُہَا ثَلاَثًا قَبْلَ أَنْ یَدْخُلَ بِہَا ، قَالَ : إِنْ قَالَ طَالِقٌ ثَلاَثًا ، کَلِمَۃً وَاحِدَۃً ، لَمْ تَحِلَّ لَہُ حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ ، وَإِذَا طَلَّقَہَا ثَلاَثًا طَلاَقًا مُتَّصِلاً فَہُوَ کَذَلِکَ۔",,,18161,,
18162,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا طَلَّقَہَا ثَلاَثًا قَبْلَ أَنْ یَدْخُلَ بِہَا ، لَمْ تَحِلَّ لَہُ حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ۔",,,18162,,
18163,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ عَاصِمٍ ، عَنِ الشَّعْبِیِّ ؛ فِی الرَّجُلِ یُطَلِّقُ امْرَأَتَہُ ثَلاَثًا قَبْلَ أَنْ یَدْخُلَ بِہَا ، قَالَ : لاَ تَحِلُّ لَہُ حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ۔",,,18163,,
18164,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ خَالِدٍ ، عَنْ مُحَمَّدٍ ، قَالَ : لاَ تَحِلُّ لَہُ حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ۔",,,18164,,
18165,حَدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَنْ بُرْد ، عَنْ مَکْحُولٍ ؛ فِیمَنْ طَلَّقَ امْرَأَتَہُ قَبْلَ أَنْ یَدْخُلَ بِہَا ، إنَّہَا لاَ تَحِلُّ لَہُ حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ۔,,,18165,,
18166,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ، عَنْ شَقِیقِ بْنِ أَبِی عَبْدِ اللہِ، عَنْ أَنَسٍ، قَالَ: لاَ تَحِلُّ لَہُ حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ۔",,,18166,,
18167,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، وَسَعِیدِ بْنِ جُبَیْرٍ ، وَحُمَیْدِ بْنِ عَبْدِ الرَّحْمَنِ ، قَالُوا : لاَ تَحِلُّ لَہُ حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ۔",,,18167,,
18168,"حدَّثَنَا عَبْدُ الأَعْلَی، عَنْ دَاوُدَ، عَنْ عَامِرٍ؛ فِی رَجُلٍ طَلَّقَ امْرَأَتَہُ ثَلاَثًا قَبْلَ أَنْ یَدْخُلَ بِہَا ، قَالَ: أَکْرَہُہُ۔",,,18168,,
18169,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ عَبْدِ الأَعْلَی ، عَنْ إبْرَاہِیمَ ، عَنْ عَبِیدَۃَ (ح) وَعَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالاَ : إذَا طَلَّقَہَا ثَلاَثًا قَبْلَ أَنْ یَدْخُلَ بِہَا ، فَلاَ تَحِلُّ لَہُ حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ۔",,,18169,,
18170,"حَدَّثَنَا ابْنُ عَیّاشٍ ، عَنْ مُطَرِّفٍ ، عَنِ الْحَکَمِ ؛ فِی الرَّجُلِ یَقُولُ لامْرَأَتِہِ : أَنْتِ طَالِقٌ أَنْتِ طَالِقٌ ، أَنْتِ طَالِقٌ ، قَالَ : بَانَتْ بِالأُولَی وَالأُخْرَیَانِ لَیْسَ بِشَیْئٍ ، قَالَ : قُلْتُ : مَنْ یَقُولُ ہَذَا ؟ قَالَ : عَلِیٌّ ، وَزَیْدٌ ، وَغَیْرُہُمَا ، یَعْنِی قَبْلَ أَنْ یَدْخُلَ بِہَا۔",,,18170,,
18171,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، وَحَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا قَالَ لامْرَأَتِہِ قَبْلَ أَنْ یَدْخُلَ بِہَا أَنْتِ طَالِقٌ ، أَنْتِ طَالِقٌ ، أَنْتِ طَالِقٌ ، فَقَد بَانَتْ بِوَاحِدَۃٍ وَسَقَطَتِ اثْنَتَانِ۔",,,18171,,
18172,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الْفُقَیْمِیِّ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا قَالَ قَبْلَ أَنْ یَدْخُلَ بِہَا أَنْتِ طَالِقٌ ، أَنْتِ طَالِقٌ ، أَنْتِ طَالِقٌ ، بَانَتْ بِالأُولَی ، وَالأُخْرَیَانِ لَیْسَ بِشَیْئٍ۔",,,18172,,
18173,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ ہَمَّام ، عَنْ قَتَادَۃَ ، عَنْ خِلاَسٍ ، قَالَ : بَانَتْ بِالأُولَی۔",,,18173,,
18174,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، وَحَمَّادٍ ، قَالاَ : بَانَتْ بِالأُولَی ، وَثِنْتَانِ لَیْسَتَا بِشَیْئٍ۔",,,18174,,
18175,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ، قَالَ : إذَا قَالَ لَہَا أَنْتِ طَالِقٌ ، أَنْتِ طَالِقٌ ، أَنْتِ طَالِقٌ ، قَبْلَ أَنْ یَدْخُلَ بِہَا ، فَقَدْ حُرِّمَتْ علیہ۔",,,18175,,
18176,"حدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إذَا طَلَّقَہَا ثَلاَثًا قَبْلَ أَنْ یَدْخُلَ بِہَا ، لَمْ تَحِلَّ لَہُ حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ ، وَلَوْ قَالَہَا تَتْرَی بَانَتْ بِالأُولَی۔",,,18176,,
18177,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، وَعَطَائٍ ، أَنَّہُمَا قَالاَ : إذَا طَلَّقَ الرَّجُلُ امْرَأَتَہُ ثَلاَثًا قَبْلَ أَنْ یَدْخُلَ بِہَا ، فَہِیَ وَاحِدَۃٌ۔",,,18177,,
18178,"حَدَّثَنَا عَفَّانُ بْنُ مُسْلِمٍ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ زَیْدٍ ، قَالَ : حَدَّثَنَا أَیُّوبُ ؛ أَنَّ طَاوُوسًا قَالَ : جَائَ أَبُو الصَّہْبَائِ إلَی ابْنِ عَبَّاسٍ فَقَالَ لَہُ : ہَاتِ مِنْ ہُنْیَّاتِکَ : إنَّ الثَّلاَثَ کُنَّ یُحْسَبْنَ عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَأَبِی بَکْرٍ وَصَدْرِ إمَارَۃِ عُمَرَ وَاحِدَۃً ، فَلَمَّا رَأَی عُمَرُ النَّاسَ قَدْ تَتَابَعُوا فِی الطَّلاَقِ ، فَأَجَازَہُنَّ عَلَیْہِ۔ (مسلم 1099۔ ابوداؤد 2192)",,,18178,,
18179,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا سَعِیدٌ ، عَنْ قَتَادَۃَ ، عَنْ طَاوُوسٍ ، وَعَطَائٍ ، وَجَابِرِ بْنِ زَیْدٍ ؛ أَنَّہُمْ قَالُوا : إذَا طَلَّقَہَا ثَلاَثًا قَبْلَ أَنْ یَدْخُلَ بِہَا فَہِیَ وَاحِدَۃٌ۔",,,18179,,
18180,"حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبِ ، عَنْ مُغِیرَۃ ، عَنْ إبْرَاہِیمَ ؛ فِی رَجُلٍ طَلَّقَ امْرَأَتَہُ وَاحِدَۃً ، فَلَقِیَہُ رَجُلٌ فَیَقُولُ : طَلَّقْتَ امْرَأَتَکَ ؟ فَقَالَ : نَعَمْ ، ثُمَّ لَقِیَہُ آخَرُ ، فَقَالَ : طَلَّقْتَ ؟ قَالَ : نَعَمْ ، فَقَالَ : إِنْ کَانَ نَوَی الأُولَی فَہِیَ وَاحِدَۃٌ۔",,,18180,,
18181,"حَدَّثَنَا شَرِیکٌ ، عَنِ الرَّجُلِ یُطَلِّقُ الْمَرْأَۃَ فَیَلْقَاہُ الرَّجُلُ ، فَیَقُولُ : طَلَّقْتَ ؟ فَیَقُولُ : نَعَمْ ، ثُمَّ یَلْقَاہُ آخَرُ فَیَقُولُ: طَلَّقْتَ؟ فَیَقُولُ: نَعَمْ ، فَحَدَّثَنَا عَنْ أَبِی إِسْحَاقَ، عَنِ ابْنِ مَعْقِل، والشَّعْبِیِّ قَالاَ: إذَا أَرَادَ الأُولَی فَلاَ بَأْسَ۔",,,18181,,
18182,"حدَّثَنَا عَبدَۃ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ طَلَّقَ امْرَأَتَہُ فَلُقِیَ ، فَقِیلَ لَہُ : طَلَّقْتَ امْرَأَتَکَ؟ فَقَالَ: نَعَمْ، فَقِیلَ لَہُ: طَلَّقْتَ امْرَأَتَکَ؟ فَقَالَ: نَعَمْ ، فَرُفِعَ ذَلِکَ إلَی عُمَرَ بْنِ الْخَطَّابِ، فَقَالَ: مَا نَوَی۔",,,18182,,
18183,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ عَبْدِ رَبِّہِ ، عَنْ جَابِرِ بْنِ زَیْدٍ ، قَالَ : سَأَلْتُہُ عَنْ رَجُلٍ طَلَّقَ امْرَأَتَہُ تَطْلِیقَۃً، ثُمَّ طَلَّقَہَا أُخْرَی ، فَکَانَتَا اثْنَتَیْنِ ، ثُمَّ لَقِیَہُ رَجُلٌ ، فَقَالَ : طَلَّقْتَ امْرَأَتَکَ ؟ فَقَالَ : نَعَمْ ، قَالَ : فَقَالَ : إِنْ کَانَ إنَّمَا أَرَادَ مَا کَانَ طَلَّقَ ، فَلَیْسَ عَلَیْہِ شَیْئٌ۔",,,18183,,
18184,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الشَّیْبَانِیِّ ، عَنْ حَمَّادٍ ؛ فِی رَجُلٍ قَالَ لامْرَأَتِہِ : أَنْتِ طَالِقٌ فَقَالَتْ : أَیُّ شَیْئٍ تَقُولُ ؟ ، فَقَالَ : أَنْتِ طَالِقٌ الْبَتَّۃَ ، فَقَالَ حَمَّادٌ : إِنْ کَانَ أَرَادَ أَنْ یُفَہِّمَہَا فَلاَ بَأْسَ۔",,,18184,,
18185,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ ، وَحَمَّاداً عَنِ الرَّجُلِ یَقُولُ لامْرَأَتِہِ : أَنْتِ طَالِقٌ ، أَنْتِ طَالِقُ ، أَنْتِ طَالِقٌ ؟ قَالاَ : ہِی ثَلاَثٌ ، إلاَّ أَنْ یَکُونَ نَوَی الأُولَی ، وَإِذَا قَالَ اعْتَدِّی ، فَمِثْلُ ذَلِکَ۔",,,18185,,
18186,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عُقْبَۃَ بْنُ أَبِی العَیزَارِ ، قَالَ : سَأَلْتُ إبْرَاہِیمَ عَنْ رَجُلٍ طَلَّقَ امْرَأَتَہُ تَطْلِیقَۃً ، أَوْ تَطْلِیقَتَیْنِ ، فَسَأَلَہُ رَجُلٌ : طَلَّقْتَ امْرَأَتَکَ کَذَا وَکَذَا ، ثَلاَثًا ، أَوْ أَرْبَعًا ؟ فَقَالَ الرَّجُلُ : نَعَمْ ؟ قَالَ إبْرَاہِیمُ : بَانَتْ مِنْہُ۔",,,18186,,
18187,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یَقُولُ لامْرَأَتِہِ : أَنْتِ طَالِقٌ إلَی سَنَۃٍ ، قَالَ : یَقَعُ عَلَیْہَا یَوْمَ قَالَ۔",,,18187,,
18188,حَدَّثَنَا ہُشَیْمٌ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّہُ کَانَ لاَ یُؤَجِّلُ فِی الطَّلاَقِ۔,,,18188,,
18189,حَدَّثَنَا ہُشَیْمٌ ، عَنْ مَنْصُورٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ لاَ یُؤَجِّلُ فِی الطَّلاَقِ۔,,,18189,,
18190,"حدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : إذَا طَلَّقَ إلَی أَجَلٍ وَقَعَ۔",,,18190,,
18191,"حدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ فُرَاتٍ ، عَنْ عَبْدِ الْکَرِیمِ ، قَالَ : کَانَ الزُّہْرِیُّ یَقُولُ : تَعْتَدُّ یَوْمَ قَالَ۔",,,18191,,
18192,"حَدَّثَنَا ہُشَیْمٌ، عَنْ مُغِیرَۃَ، عَنْ إبْرَاہِیمَ قَالَ: مَنْ وَقَّتَ فِی الطَّلاَقِ وَقْتًا، فَدَخَلَ ذَلِکَ الْوَقْتُ، وَقَعَ الطَّلاَقُ۔",,,18192,,
18193,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ، عَنْ عُبَیْدِ اللہِ بْنِ عُبَیْدٍ، عَنْ مَکْحُولٍ؛ أَنَّہُ کَانَ یَقُولُ: حتَّی یَجِیئَ الأَجَلُ۔",,,18193,,
18194,"حَدَّثَنَا مُعَمَّرُ بْنُ سُلَیْمَانَ الرَّقِّیُّ ، عَنْ عَبْدِ اللہِ بْنِ بِشْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إلَی أَجَلہ۔",,,18194,,
18195,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَبِیبٍ ، عَنْ عَمْرٍو ، قَالَ : سُئِلَ جَابِرُ بْنُ زَیْدٍ عَنْ رَجُلٍ قَالَ لامْرَأَتِہِ : إذَا أَہْلَلْتُ شَہْرَ کَذَا وَکَذَا ، فَامْرَأَتِی طَالِقٌ إلَی رَأْسِ السَّنَۃِ ؟ قَالَ : أرَی أَنَّہَا طَالِقٌ إلَی الأَجَلِ الَّذِی سَمَّی ، وَتَحِلُّ لَہُ فِیمَا دُونَ ذَلِکَ۔",,,18195,,
18196,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ عَاصِمِ بْنِ کُلَیْبٍ ، عَنْ سَلَمَۃَ بْنِ نَبَاتَۃَ ، عَنْ أَبِی ذَرٍّ ؛ أَنَّہُ قَالَ لِغُلاَمٍ لَہُ : ہُوَ عَتِیقٌ إلَی الْحَوْلِ۔",,,18196,,
18197,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ؛ فِی رَجُلٍ قَالَ لامْرَأَتِہِ : اعْتَدِّی ، قَالَ : ہِیَ تَطْلِیقَۃٌ إذَا عَنَی الطَّلاَقَ۔",,,18197,,
18198,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ رَبِّہِ ، عَنْ جَابِرِ بْنِ زَیْدٍ ، قَالَ : ہِیَ تَطْلِیقَۃٌ۔",,,18198,,
18199,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : اعْتَدِّی وَاحِدَۃً۔",,,18199,,
18200,"حدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، قَالَ : ہِیَ وَاحِدَۃٌ ، وَہُوَ أَحَقُّ بِہَا۔",,,18200,,
18201,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، قَالَ: سَأَلْتُ الْحَکَمَ ، وَحَمَّادًا عَنْ رَجُلٍ قَالَ لامْرَأَتِہِ: أَنْتِ طَالِقٌ ، أَنْتِ طَالِقٌ، أَنْتِ طَالِقٌ ، وَنَوَی الأُولَی ؟ قَالاَ : ہِیَ وَاحِدَۃٌ ، وَکَذَلِکَ إِذَا قَالَ اعتَدّی ، اعتَدّی۔",,,18201,,
18202,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، وَحَمَّادٍ ، قَالاَ : إذَا قَالَ الرَّجُلُ لامْرَأَتِہِ : اعْتَدِّی ، اعْتَدِّی ، وَقَالَ : إنِّی نَوَیْت وَاحِدَۃً ، فَہِی وَاحِدَۃٌ۔",,,18202,,
18203,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ، عَنْ عَامِرٍ؛ فِی رَجُلٍ قَالَ لامْرَأَتِہِ: اعْتَدِّی ، اعْتَدِّی ، یَنْوِی ثَلاَثًا، قَالَ : ہِیَ وَاحِدَۃٌ۔",,,18203,,
18204,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ؛ وَہُوَ قَوْلُ قَتَادَۃَ ، أَنَّہُمَا قَالاَ : إذَا قَالَ الرَّجُلُ لامْرَأَتِہِ : اعْتَدِّی ثَلاَثًا ، لَمْ تَحِلَّ لَہُ حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ۔",,,18204,,
18205,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ؛ مِثْلَہُ۔,,,18205,,
18206,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، وَأَبِی حَرَّۃَ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ قَالَ لامْرَأَتِہِ : أَنْتِ طَالِقٌ فَاعْتَدِّی ، قَالَ: ہِیَ وَاحِدَۃٌ ، وَإِذَا قَالَ : أَنْتِ طَالِقٌ وَاعْتَدِّی ، فَہِیَ اثْنَتَانِ۔",,,18206,,
18207,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ قَالَ : لاَ یَجُوزُ طَلاَقُ الْمَجْنُونِ۔",,,18207,,
18208,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ، قَالَ : الْمَجْنُونُ لاَ یَجُوزُ طَلاَقُہُ۔",,,18208,,
18209,"حدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، عَنْ أَبَانَ بْنِ عُثْمَانَ ، عَنْ عُثْمَانَ ، قَالَ : لَیْسَ لِمَجْنُونٍ وَلاَ لِسَکْرَانَ طَلاَقٌ۔",,,18209,,
18210,"حدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ ہَارُونَ ، قَالَ : سَأَلْتُ ابْنَ سِیرِینَ عَنْ طَلاَقِ الْمَجْنُونِ ؟ فَقَالَ : لَیْسَ بِشَیْئٍ ، وَالسُّلْطَانُ یَنْظُرُ فِیہِ ، یُسْأَلُ الْبَیِّنَۃَ أَنَّہُ طَلَّقَ وَتُصْبِر یَمِینَہُ۔",,,18210,,
18211,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَبِیبٍ ، عَنْ عَمْرٍو ، قَالَ : سُئِلَ جَابِرٌ عَنْ رَجُلٍ طَلَّقَ امْرَأَتَہُ وَہُوَ مَجْنُونٌ ، حِینَ أَخَذَہُ جُنُونُہُ ؟ قَالَ : لاَ یَجُوزُ۔",,,18211,,
18212,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : لاَ یَجُوزُ طَلاَقُ الْمَجْنُونِ إذَا أُخِذَ بِہِ ، فَإِذَا صَحَّ فَہُوَ جَائِزٌ۔",,,18212,,
18213,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ ، عَنْ عَابِسِ بْنِ رَبِیعَۃَ ، عَنْ عَلِیٍّ ، قَالَ : کُلُّ طَلاَقٍ جَائِزٌ ، إلاَّ طَلاَقَ الْمَعْتُوہِ۔",,,18213,,
18214,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ ، عَنْ عَابِسِ بْنِ رَبِیعَۃَ ، قَالَ : سَمِعْتُ عَلِیًّا یَقُولُہُ۔",,,18214,,
18215,"حَدَّثَنَا أَبُو الأَحْوَصِِ، عَنْ أَبِی إِسْحَاقَ، عَنْ إبْرَاہِیمَ، قَالَ: قَالَ عَلِیٌّ: کُلُّ طَلاَقٍ جَائِزٌ، إلاَّ طَلاَقَ الْمَعْتُوہِ۔",,,18215,,
18216,"حدَّثَنَا أَبُو بَکْرٍ الْحَنَفِیُّ ، عَنْ أُسَامَۃَ ، عَنْ نَافِعٍ ؛ أَنَّ الْمُجَبِّرَ بْنَ عَبْدِ الرَّحْمَنِ طَلَّقَ امْرَأَتَہُ ، وَہُوَ مَعْتُوہٌ ، فَأَمَرَہَا ابْنُ عُمَرَ أَنْ تَعْتَدَّ ، فَقِیلَ لَہُ : إنَّہُ مَعْتُوہٌ ، فَقَالَ : إنِّی لَمْ أَسْمَعِ اللَّہَ اسْتَثْنَی لِمَعْتُوہٍ طَلاَقًا ، وَلاَ غَیْرَہُ۔",,,18216,,
18217,"حدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ إسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ ، قَالَ : لَیْسَ لِمَعْتُوہٍ ، وَلاَ لِصَبِیٍّ طَلاَقٌ۔",,,18217,,
18218,"حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا طَلَّقَ الْمَعْتُوہُ فِی حَالِ إفَاقَتِہِ ، جَازَ۔",,,18218,,
18219,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : طَلاَقُہُ لَیْسَ بِشَیْئٍ۔",,,18219,,
18220,"حدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ إسْرَائِیلَ ، عَنْ أَبِی حَصِینٍ ، عَنْ شُرَیْحٍ ، قَالَ : لاَ یَجُوزُ طَلاَقُہُ۔",,,18220,,
18221,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ ، قَالَ : لاَ یَجُوزُ طَلاَقُہُ۔",,,18221,,
18222,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : لَیْسَ لَہُ طَلاَقٌ۔",,,18222,,
18223,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ یُقَالُ : کُلُّ الطَّلاَقِ جَائِزٌ ، إلاَّ طَلاَقَ الْمَعْتُوہِ۔",,,18223,,
18224,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ، قَالَ : لَیْسَ لِمَعْتُوہٍ طَلاَقٌ۔",,,18224,,
18225,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیِّبِ ؛ فِی الَّذِی بِہِ الْمَوْتَۃُ ، قَالَ : إذَا طَلَّقَ عِنْدَ أَخْذِہَا إِیَّاہُ فَلَیْسَ بِشَیْئٍ ، وَإِذَا أَفَاقَ فَطَلاَقُہُ جَائِزٌ۔",,,18225,,
18226,حدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ؛ مِثْلَہُ۔,,,18226,,
18227,"حَدَّثَنَا وَکِیعٌ ، عَنْ یَزِیدَ ، عَنْ إبْرَاہِیمَ ، عَنِ الْحَسَنِ ؛ فِی الَّذِی تُصِیبُہُ الخَطْرَۃَ مِنَ الْجُنُونِ یُطَلِّقُ ، قَال الْحَسَنُ : لاَ یَلْزَمُہُ ، وَقَالَ قَتَادَۃُ : إذَا اشْتَرَی وَبَاعَ لَزِمَہُ ، وَإِذَا طَلَّقَ فِی حَالِ جُنُونِہِ لَمْ یَلْزَمْہُ۔",,,18227,,
18228,"حَدَّثَنَا ابْنُ نُمَیْرٍ، عَنْ أَشْعَثَ، عَنِ الشَّعْبِیِّ؛ فِی الْمُصَابِ الَّذِی یُصِیبُہُ الْحَینُ قَالَ: طَلاَقُہُ وَعِتَاقُہُ جَائِزٌ۔",,,18228,,
18229,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی الْمُعْتَمِرِ، عَنْ قَتَادَۃَ ، قَالَ: الْجُنُونُ جُنُونَانِ، فَإِنْ کَانَ لاَ یُفِیقُ لَمْ یَجُزْ لَہُ طَلاَقٌ، وَإِنْ کَانَ یُفِیقُ فَطَلَّقَ فِی حَالِ إفَاقَتِہِ لَزِمَہُ ذَلِکَ۔",,,18229,,
18230,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ حَبِیبٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، قَالَ : وَجَدْنَا فِی کِتَابِ عَبْدِ اللہِ بْنِ عَمْرٍو ، عَنْ عَمْرٍو : إذَا عَبِثَ الْمَجْنُونُ بِامْرَأَتِہِ ، طَلَّقَ عَنْہُ وَلِیُّہُ۔",,,18230,,
18231,"حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : یُطَلِّقُ وَلِیُّ الْمُوَسْوِسِ ، وَلْیَنْتَظِرْ عَسَی أَنْ یُفِیقَ۔",,,18231,,
18232,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : طَلاَقُ الْمَعْتُوہِ الْمَغْلُوبِ عَلَی عَقْلِہِ لَیْسَ بِشَیْئٍ ، طَلاَقُہُ إلَی وَلِیِّہِ۔",,,18232,,
18233,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، قَالَ : کَتَبْتُ إلَی أَبِی قِلاَبَۃَ فِی امْرَأَۃٍ زَوْجُہَا مَجْنُونٌ ، لاَ یَرْجُون أَنْ یَبْرَأَ ، یُطَلِّقُ عَنْہُ وَلِیُّہُ ؟ فَکَتَبَ إلَیَّ : لاَ ، إِنَّہَا امْرَأَۃٌ ابْتَلاَہَا اللَّہُ بِالْبَلاَئِ ، فَلْتَصْبِرْ۔",,,18233,,
18234,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیّ ، قَالَ : لاَ یَجُوزُ عَلَیْہِ طَلاَقُ وَلِیِّہِ۔",,,18234,,
18235,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، قَالَ : کَتَبْتُ إلَی عُمَرَ فِی رَجُلٍ مَجْنُونٍ یُخَافُ أَنْ یَقْتُلَ امْرَأَتَہُ ، فَکَتَبَ إلَیَّ : أَنْ أَجِّلْہُ سَنَۃً یَتَدَاوَی۔",,,18235,,
18236,"حَدَّثَنَا حَفْصٌ ، عَنْ غِیَاثٍ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ یَجُوزُ طَلاَقُ الصَّبِیِّ۔",,,18236,,
18237,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ إسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ ، قَالَ : لاَ یَجُوزُ طَلاَقُ الصَّبِیِّ۔",,,18237,,
18238,"حدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : إذَا عَقَلَ الصَّبِیُّ الصَّلاَۃَ وَالصَّوْمَ ، فَطَلاَقُہُ جَائِزٌ۔ قَالَ : وَقَالَ الْحَسَنُ : لاَ یَجُوزُ طَلاَقُہُ حَتَّی یَحْتَلِمَ۔",,,18238,,
18239,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہَمَّامٍ ، عَنْ قَتَادَۃَ ، عَنْ إسْمَاعِیلَ بْنِ عِمْرَانَ الْعَنْزِیّ ، قَالَ : طَلَّقْتُ وَأَنَا غُلاَمٌ لَمْ أَحْتَلِمْ ، فَسَأَلْتُ سَعِیدَ بْنَ الْمُسَیَّبِ ؟ فَقَالَ : إذَا حَفِظْتِ الصَّلاَۃَ وَصُمْتَ رَمَضَانَ ، فَقَدْ جَازَ طَلاَقُکَ۔",,,18239,,
18240,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ مَالِکٍ ، قَالَ : سَأَلْتُ الشَّعْبِیَّ عَنْ غُلاَمٍ طَلَّقَ ثَلاَثًا ؟ فَقَالَ : مَا أُرَاہُ إِذًا عَقلَ أَنَّ الثَّلاَثَ تُبِینُ أَنْ یَجْتَمِعَا۔",,,18240,,
18241,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَمَّنْ سَمِعَ عَلِیًّا یَقُولُ : اُکْتُمُوا الصِّبْیَانَ النِّکَاحَ۔",,,18241,,
18242,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ أَشْعَثَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمٍ ، عَنْ عَلِیٍّ ؛ بِنَحْوِ حَدِیثِ وَکِیعٍ۔,,,18242,,
18243,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ ، قَالَ : اُکْتُمُوا الصِّبْیَانَ النِّکَاحَ ، وَقَالَ : کُل طَلاَقٍ جَائِزٌ، إلاَّ طَلاَقَ الْمُبَرْسَمِ وَالْمَعْتُوہِ۔",,,18243,,
18244,"حَدَّثَنَا أَبوُ بَکْرِ بْنُ عَیَّاشٍ ، عَنْ مُطَرِّفٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : لَیْسَ عِتْقُ الصَّبِیِّ ، وَلاَ نِکَاحُہُ ، وَلاَ شَیْئٌ مِنْ أَمْرِہِ بِشَیْئٍ۔",,,18244,,
18245,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سُفْیَانَ ، عَنِ الْقَعْقَاعِ ، قَالَ : سَأَلْتُ إبْرَاہِیمَ عَنْ طَلاَقِ الصَّبِیِّ ؟ قَالَ : النِّسَائُ کَثِیرٌ۔",,,18245,,
18246,"حَدَّثَنَا وَکِیعٌ ، حدَّثَنَا سُفْیَانُ ، عَنِ الْقَعْقَاعِ ، عَنْ إبْرَاہِیمَ ؛ فِی طَلاَقِ الصَّبِیِّ قَالَ : لَیْسَ بِشَیْئٍ ، وَالنِّسَائُ کَثِیرٌ۔",,,18246,,
18247,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یُزَوِّجُونَہُمْ وَہُمْ صِغَارٌ ، وَیَکْتُمُونَہُمُ النِّکَاحَ مَخَافَۃَ أَنْ یَقَعَ الطَّلاَقُ عَلَی أَلْسِنَتِہِمْ۔ قَالَ سُفْیَانُ : فَإِذَا وَقَعَ لَمْ یَرَوْہُ شَیْئًا۔",,,18247,,
18248,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ شُعْبَۃَ ، عَنْ مُصْعَبٍ ، عَنِ الشَّعْبِیِّ ؛ فِی طَلاَقِ الصَّبِیِّ : لَیْسَ بِشَیْئٍ۔",,,18248,,
18249,"حدَّثَنَا أَبُو دَاوُدَ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ ، وَحَمَّادًا عَنْ طَلاَقِ الصَّبِیِّ ؟ فَقَالاَ : لاَ یَجُوزُ۔",,,18249,,
18250,"حَدَّثَنَا إِسْمَاعِیِلُ بْنُ عُلَیَّۃَ ، عَنْ یُونُس ، قَالَ : حدَثَنِیِ رَجُلٌ مِنْ أَہْلِ الشَّامِ ، لَمْ أَرَ بِہِ بَأْسًا ، قَالَ : کُنَّا فِی غَزَاۃٍ ، فَبَرْسَمَ صَاحِبٌ لَنَا ، فَطلَّّقَ امْرَأَتَہُ ثَلاثَا ، فَلَمَا أفَاَقَ قَالُوا لَہُ : قُلْتَ کَذَا وَکذَا ، قَالَ : مَاَ أَعْلَمَنِی ، قُلْتُ : مِنْ ہَذَا قَلِیلاً ، وَلاَ کَثِیِرًا ، وَمَا أَعْرِفْہُ ، فَرَکِبَ رَجُلٌ مِنَّا إِلی عُمَرَ بْنُ عَبْدِ العَزِیزِ فِی حَاجَۃٍ ، فلَمَّا قضَی حَاجتَہُ سَأَلَہُ عَنْ ذَلِکَ ، فَدَیَّنَہُ۔",,,18250,,
18251,حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ یُونُسَ ، عَنْ مَیْمُونِ بْنِ مَہْرَانِ ، عَنْ عُمَرَ بْنِ عَبْدِ العَزِیزِ ؛ بِنَحْوِ حَدِیثِ ابْنِ عُلَیَّۃَ ، عَنْ یُونُس۔,,,18251,,
18252,"حَدَّثَنَا أَبوُ مُعَاویَۃَ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَم ، قَالَ : کَانَ یَقُولُ : طَلاَقُ الْمُبَرْسَمِ وَالْمَحْمومِ الَّذِی یَہْذِی ، ونِکَاحُ الْمَجْنُونِ لَیْسَ بِشَیْئٍ۔",,,18252,,
18253,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ ، قَالَ : لاَ یَجُوزُ طَلاَق الْمُبَرْسَمِ ، وَالْمَغْلُوبِ عَلَی عَقْلِہِ فِی مَرَضِہِ۔",,,18253,,
18254,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَبِیبٍ ، عَنْ عَمْرِو بْنِ ہَرِمٍ ، عَنْ جَابِرِ بْنِ زَیْدٍ ؛ فِی طَلاَقِ الْمُبَرْسَمِ الَّذِی یَہْذِی وَلاَ یَعْقِلُ ، مَا یَقُولُ ، قَالَ : لاَ طَلاَقَ لَہُ ، وَلاَ عِتَاقَ لَہُ مَا دَام عَلَی ذَلِک۔",,,18254,,
18255,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِر ، عَنْ عَامِرٍ (ح) وَعَنْ شَرِیکٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالاَ : لاَ یَجُوز طَلاَق الْمُبَرْسَمِ۔",,,18255,,
18256,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ زُہَیْرٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : لاَ یَجُوزُ طَلاَق الْمُبَرْسَمِ ، أَوْ مَنْ نَزلَ بِہِ بَلائٌ فِی غَیر نَشْوَی۔",,,18256,,
18257,"حَدَّثَنَا أَبُو أُسَامَۃَ، عَنْ حَمَّادِ بْنِ زَیْدٍ، عَنْ أَیُّوبَ، قَالَ: کَتَبْتُ إِلَی أَبِی قِلاَبَۃَ أَسْأَلَہُ عَنْ طَلاَقِ الْمُبَرْسَمِ؟ فَکَتَبَ إِلَیَّ : إِنَّہُ مَا شَہِدَتْ بِہِ الشُّہُودُ إِنْ کَانَ یَعْقِلُ فَطَلاَقُہُ جَائِزٌ ، وَإِنْ کَانَ لاَ یَعْقِلُ فَطَلاَقُہُ لاَ یَجُوزُ۔",,,18257,,
18258,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، قَالَ : طَلاَقُ السَّکْرَانِ جَائِزٌ۔",,,18258,,
18259,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ قَالَ : طَلاَقُ النَّشْوَانِ جَائِزٌ۔",,,18259,,
18260,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ؛ أَنَّہُ کَانَ لاَ یُجِیزُ طَلاَقَ السَّکْرَانِ۔,,,18260,,
18261,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ، عَنْ أَیُّوبَ، عَنِ الْحَسَنِ، وَمُحَمَّدٍ، أَنَّہُمَا قَالاَ: طَلاَقُہُ جَائِزٌ، وَیُوجَعُ ظَہْرُہُ۔",,,18261,,
18262,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَمُحَمَّدٍ ؛ قَالاَ : طَلاَقُہُ جَائِزٌ۔",,,18262,,
18263,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : طَلاَقُ السَّکْرَانِ جَائِزٌ۔",,,18263,,
18264,حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ لَیْثٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَنْبَسَۃَ ؛ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ أَجَازَ طَلاَقَ السَّکْرَانِ وَجَلَدَہ۔,,,18264,,
18265,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ حَرْمَلَۃَ ، قَالَ : طَلَّقَ جَارٌ لِی سَکْرَان ، فَأَمَرَنِی أَنْ أَسْأَلَ سَعِیدَ بْنَ الْمُسَیَّبِ ؟ فَقَالَ : إِنْ أُصیْب فِیہِ الْحَقَّ ، فرِّقْ بَیْنَہُ وَبَیْنَ امْرَأَتِہِ ، وَضُرِبَ ثَمَانِینَ۔",,,18265,,
18266,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : طَلاَقُہُ جَائِزٌ۔",,,18266,,
18267,"حَدَّثَنَا وَکِیعٌ ، عَنْ جَعْفَرٍ ، عَنْ مَیْمُونٍ ، قَالَ : یَجُوزُ طَلاَقُہُ۔",,,18267,,
18268,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ ہَمَّامٍ ، عَنْ قَتَادَۃَ ، عَنْ حُمَیْدِ بْنِ عَبْدِ الرَّحْمَنِ ، قَالَ : یَجُوزُ طَلاَقُ السَّکْرَانِ۔",,,18268,,
18269,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، قَالَ : قُلْتُ لِمَالِکٍ : حُدِّثْتَ أَنَّ سُلَیْمَانَ بْنَ یَسَارٍ ، وَسَعِیدَ بْنَ الْمُسَیَّبِ ، قَالاَ : طَلاَقُہُ جَائِزٌ ؟ قَالَ : نَعَمْ۔",,,18269,,
18270,حدَّثَنَا وَکِیعٌ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، عَنِ الزُّبَیْرِ بْنِ الْخِرِّیتِ ، عَنْ أَبِی لَبِیدٍ ؛ أَنَّ عُمَرَ أَجَازَ طَلاَقَ السَّکْرَانِ بِشَہَادَۃِ نِسْوَۃ۔,,,18270,,
18271,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ، عَنِ الأَوْزَاعِیِّ، عَنِ الزُّہْرِیِّ قَالَ: إذَا طَلَّقَ، أَوْ أَعْتَقَ جَازَ عَلَیْہِ، وَأُقِیمَ عَلَیْہِ الْحَدُّ۔",,,18271,,
18272,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ عَبْدِ الْعَزِیزِ ، عَنِ الشَّعْبِیِّ ، قَالَ : یَجُوزُ طَلاَقُہُ ،وَالْحَدُّ فِی ظَہْرِہِ۔",,,18272,,
18273,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ إسْمَاعِیلَ بْنِ سَالِمٍ ، عَنِ الْحَکَمِ ، قَالَ : مَنْ طَلَّقَ فِی سُکْرٍ مِنَ اللہِ ، فَلَیْسَ طَلاَقُہُ بِشَیْئٍ ، وَمَنْ طَلَّقَ فِی سُکْرٍ مِنَ الشَّیْطَانِ فَطَلاَقُہُ جَائِزٌ۔",,,18273,,
18274,"حَدَّثَنَا عَمْرُو بْنُ مُحَمَّدٍ، عَنْ أَبِی حَنِیفَۃَ، عَنِ الْہَیْثُمِ، عَنْ عَامِرٍ، عَنْ شُرَیْحٍ، قَالَ: طَلاَقُ السَّکْرَانِ جَائِزٌ۔",,,18274,,
18275,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، عَنْ أَبَانَ بْنِ عُثْمَانَ ، عَنْ عُثْمَانَ ، قَالَ : کَانَ لاَ یُجِیزُ طَلاَقَ السَّکْرَانِ وَالْمَجْنُونِ۔ قَالَ : وَکَانَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ یُجِیزُ طَلاَقَہُ ،وَیُوجِعُ ظَہْرَہُ ، حَتَّی حَدَّثَہُ أَبَانُ بِذَلِکَ۔",,,18275,,
18276,"حَدَّثَنَا مُحَمَّدُ بْنُ سَوَائٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ جَابِرِ بْنِ زَیْدٍ ، وَعِکْرِمَۃَ ، وَعَطَائٍ ، وَطَاوُسٍ ، قَالُوا : لَیْسَ بِجَائِزٍ۔",,,18276,,
18277,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ؛ أَنَّ الْقَاسِمَ ، وَعُمَرَ بْنَ عَبْدِ الْعَزِیزِ ، کَانَا لاَ یُجِیزَانِ طَلاَقَ السَّکْرَانِ۔,,,18277,,
18278,حَدَّثَنَا وَکِیعٌ ، عَنْ رَبَاحٍ ، عَنْ عَطَائٍ ؛ أَِنَّہُ کَانَ لاَ یُجِیزُہُ۔,,,18278,,
18279,حَدَّثَنَا وَکِیعٌ ، عَنْ حَنْظَلَۃَ ، أَوْ غَیْرِہِ ، عَنْ طَاوُوسٍ ؛ أَنَّہُ کَانَ لاَ یُجِیزُہُ۔,,,18279,,
18280,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنِ السُّمَیْطِ السَّدُوسِیِّ ، قَالَ : خَطَبْتُ امْرَأَۃً ، فَقَالُوا لِی : لاَ نُزَوِّجُک حَتَّی تُطَلِّقَ امْرَأَتَکَ ثَلاَثًا ، فَقُلْتُ : قَدْ طَلَّقْتہَا ثَلاَثًا ، قَالَ : فَزَوَّجُونِی ثُمَّ نَظَرُوا ، فَإِذَا امْرَأَتِی عِنْدِی، فَقَالُوا: أَلَیْسَ قَدْ طَلَّقْتَ امْرَأَتَکَ ؟ قُلْتُ : بَلی ، کَانَتْ تَحْتِی فُلاَنَۃُ بِنْتُ فُلاَنٍ ، فَطَلَّقْتہَا ، فَأَمَّا ہَذِہِ فَلَمْ أُطَلِّقْہَا ، فَأَتَیْت شَقِیقَ بْنَ مَجْزَأَۃَ بْنِ ثَوْرٍ وَہُوَ یُرِیدُ الْخُرُوجَ إلَی عُثْمَانَ ، فَقُلْتُ : سَلْ أَمِیرَ الْمُؤْمِنِینَ عَنْ ہَذِہِ ، فَسَأَلَہُ ؟ فَقَالَ : نِیَّتُہُ۔",,,18280,,
18281,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُحَمَّدِ بْنِ مُسْلِم ، عَنْ إبْرَاہِیمَ بْنِ مَیْسَرَۃَ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ ؛ أَنَّ رَجُلاً کَانَ جَالِسًا مَعَ امْرَأَتِہِ عَلَی وِسَادَۃٍ ، وَکَانَ الرَّجُلُ رضا ، فَقَالَ لامْرَأَتِہِ : أَنْتِ طَالِقٌ ، یَعْنِی الْوِسَادَۃَ ، فَقَالَ طَاوُوسٌ : مَا أَرَی عَلَیْک شَیْئًا۔",,,18281,,
18282,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ قَالَ : الطَّلاَقُ مَا عُنِیَ بِہِ الطَّلاَقَ۔",,,18282,,
18283,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ فِی رَجُلٍ یَقُولُ لامْرَأَتِہِ : قدْ أَعْتَقْتُکِ ، قَالَ : لاَ یَکُونُ طَلاَقًا ، إلاَّ أَنْ یَکُونَ نَوَی ذَلِکَ۔",,,18283,,
18284,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ إسْمَاعِیلَ بْنِ رَجَائٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : قَالَ مَسْرُوقٌ : إنَّمَا الطَّلاَقُ مَا عُنِیَ بِہِ الطَّلاَقَ۔",,,18284,,
18285,"حَدَّثَنَا بِشْرُ بْنُ مُفَضَّلٍ ، عَنْ سَوَّارٍ ، قَالَ : حدَّثَنَا أَبُو ثُمَامَۃَ ، وَامْرَأَتُہُ مِنْ أَہْلِنَا ؛ أَنَّ کِنَانَۃَ بْنَ نَقْبٍ کَانَتْ عِنْدَہُ امْرَأَۃٌ ، وَقَدْ وَلَدَتْ لَہُ أَوْلاَدًا فِی الْجَاہِلِیَّۃِ ، فَقَالَ لَہَا : مَا فَوْقَ نِطَاقِکَ مُحَرَّرٌ ، فَخَاصَمَتْہُ إلَی الأَشْعَرِیِّ ، فَقَالَ : أَرَدْتَ بِمَا قُلْتَ الطَّلاَقَ ؟ قَالَ : نَعَمْ ، قَالَ : فَقَدْ أَبَنَّاہَا مِنْک۔",,,18285,,
18286,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مَنْصُورٍ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ قَالَ لامْرَأَتِہِ : أَنْتِ عَتِیقَۃٌ ، قَالَ : ہِیَ تَطْلِیقَۃٌ ، وَہُوَ أَحَقُّ بِہَا۔",,,18286,,
18287,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ الْمَلِکِ بْنِ مُسْلِمٍ الْحَنَفِیِّ ، عَنْ عِیسَی بْنِ حِطَّانَ ، عَنِ الریَّانِ بْنِ صَبِرَۃَ الْحَنَفِیِّ ؛ أَنَّہُ کَانَ جَالِسًا فِی مَسْجِدِ قَوْمِہِ ، فَأَخَذَ نَوَاۃً ، فَقَالَ : نَوَاۃٌ طَالِقٌ ، نَوَاۃٌ طَالِقٌ ، ثَلاَثًا ، قَالَ : فَرُفِعَ إلَی عَلِیٍّ ، فَقَالَ : مَا نَوَیْتَ ؟ ، قَالَ : نَوَیْتُ امْرَأَتِی ، قَالَ : فَفَرَّقَ بَیْنَہُمَا۔",,,18287,,
18288,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ أَبِی سُلَیْمَانَ ، عَنْ عَطَائٍ ، قَالَ : أُتِیَ ابْنُ مَسْعُودٍ فِی رَجُلٍ قَالَ لامْرَأَتِہِ : حَبْلُکِ عَلَی غَارِبِکَ ، فَکَتَبَ ابْنُ مَسْعُودٍ إلَی عُمَرَ ، فَکَتَبَ عُمَرُ : مُرْہُ فَلْیُوَافِینِی بِالْمَوْسِمِ ، فَوَافَاہُ بِالْمَوْسِمِ ، فَأَرْسَلَ إلَی عَلِیٍّ ، فَقَالَ لَہُ عَلِیٌّ : أَنْشُدُک بِاللَّہِ ، مَا نَوَیْتَ ؟ قَالَ : امْرَأَتِی ، قَالَ: فَفَرَّقَ بَیْنَہُمَا۔",,,18288,,
18289,"حَدَّثَنَا ہُشَیْمٌ، عَنْ مُغِیرَۃَ، عَنْ إبْرَاہِیمَ؛ فِی رَجُلٍ قَالَ لامْرَأَتِہِ: قدْ أَذِنْتُ لَکَ فَتَزَوَّجِی، قَالَ: إِنْ لَمْ یَنْوِ طَلاَقًا فَلَیْسَ بِشَیْئٍ، فَذُکِرَ ذَلِکَ لِلشَّعْبِیِّ، فَقَالَ الشَّعْبِیُّ: وَالَّذِی یُحْلَفُ بِہِ إنَّ أَہْوَنَ مِنْ ہَذَا لَیَکُونُ طَلاَقًا۔",,,18289,,
18290,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ أَبِی حَرَّۃَ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ قَالَ لامْرَأَتِہِ : اُخْرُجِی مِنْ بَیْتِی ، مَا یُجْلِسُک فِی بَیْتِی ؟ لَسْتِ لِی بِامْرَأَۃٍ ، یَقُولُ ذَلِکَ ثَلاَثَ مَرَّاتٍ ، قَالَ الْحَسَنُ : ہَذِہِ وَاحِدَۃٌ ، وَیَنْظُرُ مَا نَوَی۔",,,18290,,
18291,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ إسْمَاعِیلَ ، عَنْ إبْرَاہِیمَ ؛ فِی الرَّجُلِ یَقُولُ لامْرَأَتِہِ : لاَ حَاجَۃَ لِی فِیکِ ، قَالَ : نِیَّتُہُ۔",,,18291,,
18292,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ عَبْیدِ اللہِ بْنِ عُبَیْدٍ ، عَنْ مَکْحُولٍ ؛ فِی رَجُلٍ قَالَ لامْرَأَتِہِ : لاَ حَاجَۃَ لِی فِیکِ ، قَالَ مَکْحُولٌ : لَیْسَ بِشَیْئٍ۔",,,18292,,
18293,"حَدَّثَنَا وَکِیعٌ ، عَنْ شعبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ ، وَحَمَّادًا عَنْ رَجُلٍ قَالَ لامْرَأَتِہِ : اذْہَبِی حَیْثُ شِئْتِ ، لاَ حَاجَۃَ لِی فِیکِ ؟ قَالاَ : إِنْ نَوَی طَلاَقًا فَوَاحِدَۃٌ ، وَہُوَ أَحَقُّ بِہَا۔",,,18293,,
18294,"حَدَّثَنَا حَفْصٌ ، عَنِ عَمرو ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ قَالَ لامْرَأَتِہِ : اُخْرُجِی ، اسْتَتِرِی ، اذْہَبِی ، لاَ حَاجَۃَ لِی فِیکِ ، فَہِیَ تَطْلِیقَۃٌ ، إِنْ نَوَی الطَّلاَقَ۔",,,18294,,
18295,"حدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ ہِشَامٍ ، عَنْ مَطَرٍ ، عَنْ عِکْرِمَۃَ ؛ فِی رَجُلٍ قَالَ لامْرَأَتِہِ : إِلْحَقِی بِأَہْلِکِ، قَالَ : ہَذِہِ وَاحِدَۃٌ ، وَقَالَ قَتَادَۃُ : مَا أَعُدُّ ہَذَا شَیْئًا۔",,,18295,,
18296,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، عَنْ مُطَرِّفٍ ، عَنِ الْحَکَمِ ؛ فِی رَجُلٍ قَالَ لامْرَأَتِہِ : قدْ خَلَّیْتُ سَبِیلَکِ ، قَالَ : نِیَّتُہُ ، قَالَ : أَرَأَیْتَ إِنْ نَوَی ثَلاَثًا ، قَالَ : أَخَافُ أَنْ یَکُونَ ذَلِکَ۔",,,18296,,
18297,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حَجَّاجٍ ، عَنْ فُضَیْلٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا قَالَ : لاَ سَبِیلَ لِی عَلَیْکِ ، فَہِیَ تَطْلِیقَۃٌ بَائِنَۃٌ۔",,,18297,,
18298,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ؛ مِثْلَہُ۔,,,18298,,
18299,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ (ح) وَعَنْ جَابِرٍ ، عَنْ عَامِرٍ (ح) وَعَنْ عِمْرَانَ بْنِ مُسْلِمٍ ، عَنِ ابْنِ عِقَال ، عَنْ مُصْعَبِ بْنِ سَعْدٍ ، وَأَبِی مَالِکٍ ، وَعَبْدِ اللہِ بْنِ شَدَّادٍ قَالُوا : إذَا طَلَّقَ الرَّجُلُ امْرَأَتَہُ ثَلاَثًا وَہِیَ حَامِلٌ ، لَمْ تَحِلَّ لَہُ حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ۔",,,18299,,
18300,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا کَتَبَ الطَّلاَقَ بِیَدِہِ ، وَجَبَ عَلَیْہِ۔",,,18300,,
18301,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ عَلِیِّ بْنِ الْحَکَمِ الْبُنَانِیِّ ، قَالَ : حدَّثَنِی رَجُلٌ أَنَّ رَجُلاً کَتَبَ طَلاَقَ امْرَأَتِہِ عَلَی وِسَادَۃٍ ، فَسُئِلَ عَنْ ذَلِکَ الشَّعْبِیُّ ، فَرَآہُ طَلاَقًا۔",,,18301,,
18302,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ أَنَّہُ سُئِلَ عنْ رَجُلٍ کَتَبَ بِطَلاَقَ امْرَأَتِہِ ثُمَّ نَدِمَ، فَأَمْسَکَ الْکِتَابَ ؟ قَالَ : إِنْ أَمْسَکَ فَلَیْسَ بِشَیْئٍ ، وَإِنْ أَمْضَاہُ فَہُوَ طَلاَقٌ۔",,,18302,,
18303,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یَکْتُبُ إلَی امْرَأَتِہِ بِطَلاَقِہَا ، ثُمَّ یَبْدُو لَہُ أَنْ یُمْسِکَ الْکِتَابَ ، قَالَ : لَیْسَ بِشَیْئٍ مَا لَمْ یَتَکَلَّمْ ، وَإِنْ بَعَثَ بِہِ إلَیْہَا ، اعْتَدَّتْ مِنْ یَوْمِ یَأْتِیہَا الْکِتَابُ۔",,,18303,,
18304,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَبْدِ الْخَالِقِ ، عَنْ حَمَّادٍ قَالَ : إذَا کَتَبَ الرَّجُلُ إلَی امْرَأَتِہِ : إذَا أَتَاکِ کِتَابِی ہَذَا فَأَنْتِ طَالِقٌ ، فَإِنْ لَمْ یَأْتِہَا الْکِتَابُ ، فَلَیْسَ ہِی بِطَالِقٍ ، وَإِنْ کَتَبَ : أَمَّا بَعْدُ فَأَنْتِ طَالِقٌ ، فَہِیَ طَالِقٌ ، وَقَالَ ابْنُ شُبْرُمَۃُ : ہِیَ طَالِقٌ۔",,,18304,,
18305,"حَدَّثَنَا ہُشَیْمُ بْن بَشِیر ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ (ح) وَعَنْ مُحَمَّدِ بْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ (ح) وَعَنْ یُونُسَ، عَنِ الْحَسَنِ؛ فِی الْجَارِیَۃِ إذَا طُلِّقَتْ وَلَمْ تَبْلُغ الْمَحِیضَ، قَالُوا: تَعْتَدُّ بِالشُّہُورِ، فَإِنْ حَاضَتْ مِنْ قَبْلِ أَنْ تَمْضِیَ الشُّہُورُ ، اسْتَأْنَفَتِ الْعِدَّۃَ بِالْحَیْضِ ، فَإِنْ حَاضَتْ بَعْدَ مَا مَضَتِ الشُّہُورُ ، فَقَدِ انْقَضَتْ عِدَّتُہَا۔",,,18305,,
18306,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ فِی الرَّجُلِ یَتَزَوَّجُ الْجَارِیَۃَ فَیُطَلِّقُہَا قَبْلَ أَنْ تَبْلُغَ الْمَحِیضَ، قَالَ: تَعْتَدُّ ثَلاَثَۃَ أَشْہُرٍ ، فَإِنْ ہِیَ حَاضَتْ قَبْلَ أَنْ تَقْضِیَ الثَّلاَثَۃُ الأَشْہُرُ ، انْہَدَمَتْ عِدَّۃُ الشُّہُورِ، وَاسْتَأْنَفَتْ عِدَّۃَ الْحَیْضِ۔",,,18306,,
18307,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَبِیبٍ ، عَنْ عَمْرٍو ، قَالَ : سُئِلَ جَابِرُ بْنُ زَیْدٍ عَنْ جَارِیَۃٍ طُلِّقَتْ بَعْدَ مَا دَخَلَ بِہَا زَوْجُہَا ، وَہِیَ لاَ تَحِیضُ ، فَاعْتَدَّتْ شَہْرَیْنِ وَخَمْسَۃً وَعِشْرِینَ لَیْلَۃً ، ثُمَّ إنَّہَا حَاضَتْ ؟ قَالَ : تَعْتَدُّ بَعْدَ ذَلِکَ ثَلاَثَۃَ قُرُوئٍ ، وَکَذَلِکَ قَالَ ابْنُ عَبَّاسٍ۔",,,18307,,
18308,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : إذَا کَانَتْ عِنْدَ الرَّجُلِ الْمَرْأَۃُ قَدْ أَیِسَتْ مِنَ الْمَحِیضِ ، أَوِ الْجَارِیَۃُ الَّتِی لَمْ تَحِضْ ، فَمَتَی مَا شَائَ طَلَّقَہَا۔",,,18308,,
18309,"حدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، عَنْ أَیُّوبَ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : کَانَ یُعْجِبُہُ أَنْ یُطَلِّقَ الَّتِی لَمْ تَحِضْ عِنْدَ الإِہلاَل۔",,,18309,,
18310,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ لَیْثٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : یُطَلِّقُہَا عِنْدَ الأَہِلَّۃِ۔",,,18310,,
18311,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضیل ، عَنْ عُبَیْدَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : إذَا کَانَتِ الْمَرْأَۃُ قَدْ قَعَدَتْ مِنَ الْمَحِیضِ ، وَالْجَارِیَۃُ لَمْ تَحِضْ، فَأَرَادَ الرَّجُلُ أَنْ یُطَلِّقَ، فَیُطَلِّق عِنْدَ غُرَّۃِ الْہِلاَلِ، وَلاَ یُطَلِّقُ غَیْرَہَا حَتَّی تَنْقَضِیَ عِدَّتُہَا۔",,,18311,,
18312,"حَدَّثَنَا ابْنُ الْمُبَارَکِ ، عَنْ مَعْمَرٍ ، عَنْ حَمَّادٍ ، قَالَ : سَأَلْتُہُ عَنْ رَجُلٍ قَالَ : امْرَأَتُہُ طَالِقٌ ، وَلَہُ أَرْبَعُ نِسْوَۃٍ ؟ قَالَ : یَضَعُ یَدَہُ عَلَی أَیَّتِہِنَّ شَائَ۔ قَالَ مَعْمَرٌ : وَکَانَ الْحَسَنُ یَقُولُ ذَلِکَ۔",,,18312,,
18313,حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ اللہِ بْنِ حُمَیْدٍ ، عَنْ أَبِی جَعْفَرٍ ؛ أَنَّ عَلِیًّا أَقْرَعَ بَیْنَہُنَّ۔,,,18313,,
18314,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ (ح) وعَنْ رَجُلٍ ، عَنِ الشَّعْبِیِّ ، قَالاَ : إِنْ کَانَ سَمَّی شَیْئًا فَہُوَ مَا سَمَّی ، وَإِنْ لَمْ یَکُنْ سَمَّی مِنْہُنَّ شَیْئًا ، دَخَلَ عَلَیْہِنَّ الطَّلاَقُ۔",,,18314,,
18315,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ؛ أَنَّ عَرِیفًا لِبَنِی سَعْدٍ سَأَلَ الْحَسَنَ ، وَکَانَ السُّلْطَانُ اسْتَخْلَفَہُ ؟ فَقَالَ: لَکَ مَا نَوَیْتَ۔",,,18315,,
18316,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ عُمَرَ بْنِ عَامِرٍ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ؛ فِی رَجُلٍ قَالَ : امْرَأَتُہُ طَالِقٌ ثَلاَثًا، وَلَہُ نِسْوَۃٌ ، فَقَالَ : إِنْ کَانَ نَوَی مِنْہُنَّ شَیْئًا فَہِیَ الَّتِی نَوَی ، وَإِنْ لَمْ یَکُنْ نَوَی مِنْہُنَّ شَیْئًا فَلْیَخْتَرْ أَیَّتَہنَّ شَائَ ، وَکَذَلِکَ الإِیلاَئُ وَالظِّہَارُ۔",,,18316,,
18317,"حَدَّثَنَا رَوْحُ بْنُ عُبَادَۃَ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ الْعَدْنِِی ، قَالَ : سُئِلَ أَبُو جَعْفَرٍ عَنْ رَجُلٍ لَہُ أَرْبَعُ نِسْوَۃٍ ، فَاطَّلَعَتْ مِنْہُنَّ امْرَأَۃٌ ، فَقَالَ : أَنْتِ طَالِقٌ الْبَتَّۃَ ، فَدَخَلَ عَلَیْہِنَّ فَإِذَا کُلُّ وَاحِدَۃٍ مِنْہُنَّ تَقُولُ : ہِیَ ہَذِہِ ، وَتَقُولُ ہَذِہِ : ہِیَ ، فَلَمْ یَعْرِفْہَا ؟ قَالَ أَبُو جَعْفَرٍ : بِنَّ مِنْہُ جَمِیعًا۔",,,18317,,
18318,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : قَالَ شُرَیْحٌ : إذَا بَدَأَ بِالطَّلاَقِ وَالْعَتَاقِ قَبْلَ الْمَثنویَّۃ وَقَعَ الطَّلاَقُ وَالْعَتَاقُ ، حَنِثَ ، أَوْ لَمْ یَحْنَثْ۔ وَقَالَ سَعِیدُ بْنُ جُبَیْرٍ : إذَا لَمْ یَحْنَثْ لَمْ یَقَعْ عَلَیْہ۔",,,18318,,
18319,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ (ح) وَإِسْمَاعِیلَ بْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ، قَالاَ : إِذَا قَدَّمَ الطَّلاَقَ أَوْ أَخَّرَہُ ، فَہُوَ سَوَائٌ إِذَا وَصَلَہُ بِکَلاَمِہِ۔",,,18319,,
18320,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، وَالْحَسَنِ ، قَالاَ : لَہُ ثُنْیَاہُ قَدَّمَ الطَّلاَقَ ، أَوْ أَخَّرَہُ۔",,,18320,,
18321,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ؛ فِی الاِسْتِثْنَائِ فِی الطَّلاَقِ وَالْعِتْقِ ، قَالَ : لَہُ ثُنْیَاہُ قَدَّمَ الطَّلاَقَ ، أَوْ أَخَّرَہُ۔",,,18321,,
18322,"حَدَّثَنَا أَبُو مُعَاوِیَۃُ ، عَنِ الأَعْمَشِِ ، عَنْ إِبْرَاہِیمَ ، عَنْ شُرَیْحٍ قَالَ : إِذَا بَدَأَ بِالطَّلاَقِ وَقَعَ ، حَنِثَ ، أَوْ لَمْ یَحْنَثْ ، وَکَانَ یَقُولُ إِبْرَاہِیمُ : وَمَا یُدْرِی شُرَیْحًا۔",,,18322,,
18323,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ، عَنْ سَعِیدٍ الزُّبَیْدِیِّ، قَالَ: أَتَیْتُ امْرَأَتِی طُرُوقًا، فَقَالَتْ لِی: مَا جِئْتَ بِہَذِہِ السَّاعَۃِ إِلاَّ وَلَک امْرَأَۃٌ غَیْرِی ، فَقُلْتُ: کُلُّ امْرَأَۃٍ لِی فَہِیَ طَالِقٌ ثَلاَثًا غَیْرَک ، فَسَأَلْتُ إِبْرَاہِیمَ ؟ فَقَالَ: لَیْسَ بِشَیْئٍ۔",,,18323,,
18324,حَدَّثَنَا شَرِیکٌ ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَانَ یَرَی الاِسْتِثْنَائَ فِی الطَّلاَقِ۔,,,18324,,
18325,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُوسٍ ، وَمُجَاہِدٍ ، وَالنَّخَعِیِّ ، وَالزُّہْرِیِّ ، قَالُوا: إِذَا قَالَ الرَّجُلُ لامْرَأَتِہِ : أَنْتِ طَالِقٌ ، إِنْ لَمْ أَفْعَلْ کَذَا وَکَذَا إِنْ شَائَ اللَّہُ ، فَلَہُ ثُنْیَاہُ۔",,,18325,,
18326,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْہَیْثُمِ ، عَنْ حَمَّادٍ ؛ فِی الرَّجُلِ قَالَ لامْرَأَتِہِ : أَنْتِ طَالِقٌ إِنْ شَائَ اللَّہُ ، قَالَ : لَہُ ثُنْیَاہُ ، وَقَالَ الْحَکَمُ مِثْلُ ذَلِکَ۔",,,18326,,
18327,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ قَتَادَۃَ ، وَإِیَاسِ بْنِ مُعَاوِیَۃَ ؛ فِی رَجُلٍ قَالَ لامْرَأَتِہِ : ہِیَ طَالِقٌ إِنْ شَائَ اللَّہُ ، قَالاَ : ذَہَبَتْ مِنْہُ۔",,,18327,,
18328,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، قَالَ : إِذَا قَالَ لامْرَأَتِہِ : ہِیَ طَالِقٌ إِنْ شَائَ اللَّہُ ، فَہِیَ طَالِقٌ ، وَلَیْسَ اسْتِثْنَاؤُہُ بِشَیْئٍ۔",,,18328,,
18329,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ مُعَاذِ بْنِ رِفَاعَۃَ ، عَنْ مَکْحُولٍ ، عَنْ مُعَاذِ بْنِ جَبَلٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إِذَا قَالَ الرَّجُلُ لامْرَأَتِہِ : أَنْتِ طَالِقٌ إِنْ شَائَ اللَّہُ ، فَلَیْسَتْ بِطَالِقٍ ، وَإِذا قَالَ لِعَبْدِہِ : أَنْتَ حُرٌّ إِنْ شَائَ اللَّہُ ، فَہُوَ حُرٌّ۔ (دارقطنی 94۔ بیہقی 361)",,,18329,,
18330,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ عَبْدِ اللہِ بْنِ طَلْحَۃَ الْخُزَاعِیِّ ، عَنِ أَبِی یَزِیدَ الْمَدِینِیِّ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لَیْسَ لِمُکْرَہٍ وَلاَ لِمُضْطَہَدٍ طَلاَقٌ۔",,,18330,,
18331,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، وَوَکِیعٌ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حُمَیْدٍ ، عَنِ الْحَسَنِ ، عَنْ عَلِیٍّ ؛ أَنَّہُ کَانَ لاَ یَرَی طَلاَقَ الْمُکْرَہِ شَیْئًا۔,,,18331,,
18332,حَدَّثَنَا وَکِیعٌ ، عَنِ الأَوْزَاعِیِّ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ أَلْغَاہ۔,,,18332,,
18333,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عبْیدِ اللہِ بْن عُمَرَ ، عَنْ ثَابِت، مَولَی أَہْلِ المَدِینَۃ ، عَنِ ابن عُمَرَ، وَابن الزُّبَیْرِ، قَالَ : کَانَا لاَ یَرَیَانِ طَلاَقَ الْمُکْرَہِ شَیْئًا۔",,,18333,,
18334,حَدَّثَنَا وَکِیعٌ ، عَنِ الأَوْزَاعِیِّ ، عَنْ رَجُلٍ ، عَنْ عُمَرَ بْنِ الْخَطَّابِ ؛ أَنَّہُ لَمْ یَرَہُ شَیْئًا۔,,,18334,,
18335,"حَدَّثَنَا یَحْیَی بْنُ بَشِیرٍ، عَنْ زَیْدِ بْنِ رُفَیْعٍ، عَنْ عُمَرَ بْنِ عَبْدِالْعَزِیزِ، قَالَ: لاَ طَلاَقَ وَلاَ عَتَاقَ عَلَی مُکْرَہٍ۔",,,18335,,
18336,حَدَّثَنَا ہُشَیْمٌ ، عَنْ مَنْصُورٍ ، وَیُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ لاَ یَرَی طَلاَقَ الْمُکْرَہِ شَیْئًا۔,,,18336,,
18337,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ أَنَّہُ کَانَ لاَ یَرَاہُ شَیْئًا۔ قَالَ عَبْدُ الْمَلِکِ فِی حَدِیثِہِ : قَالَ عَطَائٌ : الشِّرْکُ أَعْظَمُ مِنَ الطَّلاَقِ۔",,,18337,,
18338,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَوْزَاعِیِّ ، قَالَ : سَأَلْتُ عَطَائً عَنْ طَلاَقِ الْمُکْرَہِ ؟ فَقَالَ : لَیْسَ بِشَیْئٍ۔",,,18338,,
18339,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ ، قَالَ : کَانَ لاَ یَرَی طَلاَقَ الْمُکْرَہِ وَعَتَاقَہُ جَائِزًا۔",,,18339,,
18340,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ اللَّہَ تَجَاوَزَ لَکُمْ عَنْ ثَلاَثٍ : الْخَطَأُ ، وَالنِّسْیَانُ ، وَمَا أُکْرِہْتُمْ عَلَیْہِ۔ (عبدالرزاق 11416۔ سعید بن منصور 1145)",,,18340,,
18341,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حَدَّثَنَا شُعْبَۃُ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ ؛ أَنَّ عَامِلاً مِنَ الْعُمَّالِ ضَرَبَ رَجُلاً حَتَّی طَلَّقَ امْرَأَتَہُ ، قَالَ : فَکُتِبَ فِیہِ إلَی عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : فَلَمْ یُجِزْ ذَلِکَ۔",,,18341,,
18342,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ ثَوْرٍ ، عَنْ عُبَیْدِ اللہِ بْنِ أَبِی صَالِحٍ ، عَنْ صَفِیَّۃَ بِنْتِ شَیْبَۃَ ، عَنْ عَائِشَۃَ ، قَالَتْ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ طَلاَقَ وَلاَ عَتَاقَ فِی إغْلاَقٍ۔\n\n(ابوداؤد 2187۔ احمد 6/276)",,,18342,,
18343,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ سَیَّارٍ قَالَ : قُلْتُ لِلشَّعْبِیِّ : إنَّہُمْ یَزْعُمُونَ أَنَّک لاَ تَرَی طَلاَقَ الْمُکْرَہِ شَیْئًا ؟ قَالَ : إنَّہُمْ یَکْذِبُونَ عَلَیَّ۔",,,18343,,
18344,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : طَلاَقُ الْمُکْرَہِ جَائِزٌ۔",,,18344,,
18345,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ الأَعْمَشِِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : ہُوَ جَائِزٌ ، إِنَّمَا ہُوَ شَیْئٌ افْتَدَی بِہِ نَفْسَہُ۔",,,18345,,
18346,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عَلِیِّ بْنِ زَیْدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّہُ کَانَ یُجِیزُ طَلاَقَ الْمُکْرَہِ۔,,,18346,,
18347,"حَدَّثَنَا عَبْدُاللہِ بْنُ الْمُبَارَکِ، عَنْ رَجُلٍ، قَدْ سَمَّاہُ، عَنِ ابْنِ سِیرِینَ، عَنْ شُرَیْحٍ، قَالَ: طَلاَقُ الْمُکْرَہِ جَائِزٌ۔",,,18347,,
18348,حَدَّثَنَا حُسَیْنُ بْنُ مُحَمَّدٍ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ؛ إِنَّ طَلاَقَ الْمُکْرَہِ جَائِزٌ۔,,,18348,,
18349,"حدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ لَیْثٍ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لَوْ وُضِعَ السَّیْفُ عَلَی مَفْرِقِہِ ، ثُمَّ طَلَّقَ ، لأَجَزْتُ طَلاَقَہُ۔",,,18349,,
18350,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنِ الشَّعْبِیِّ ؛ فِی الرَّجُلِ یُکْرَہُ عَلَی أَمْرٍ مِنْ أَمْرِ الْعَتَاقِ ، أَوِ الطَّلاَقِ قَالَ : إِذَا أَکْرَہَہُ السُّلْطَانُ جَازَ ، وَإِذَا أَکْرَہَہُ اللُّصُوصُ لَمْ یَجُزْ۔",,,18350,,
18351,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ لَہُ امْرَأَتَانِ ، نَہَی إحْدَاہُمَا عَنِ الْخُرُوجِ ، فَخَرَجَتِ الَّتِی لَمْ یَنْہَ ، فَظَنَّ أَنَّہَا الَّتِی نَہَاہَا أَنْ تَخْرُجَ ، فَقَالَ : فُلاَنَۃُ خَرَجْتِ ؟ أَنْتِ طَالِقٌ ، قَالَ : تُطْلَقُ الَّتِی أَرَادَ وَنَوَی۔",,,18351,,
18352,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : تُطْلَقَانِ جَمِیعًا ، تُطْلَقُ الَّتِی أَرَادَ بِتَسْمِیَتِہِ إِیَّاہَا ، وَتُطْلَقُ ہَذِہِ بِقَوْلِہِ لَہَا : أَنْتِ طَالِقٌ۔",,,18352,,
18353,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ؛ أَنَّہُ قَالَ فِی رَجُلٍ قَالَ لامْرَأَتِہِ : إِنْ خَرَجْتِ فَأَنْتِ طَالِقٌ، فَاسْتَعَارَتِ امْرَأَۃٌ ثِیَابَہَا فَلَبِسَتْہَا ، فَأَبْصَرَہَا زَوْجُہَا حِینَ خَرَجَتْ مِنَ الْبَابِ ، فَقَالَ : قَدْ فَعَلْتِ ؟ أَنْتِ طَالِقٌ، قَالَ : یَقَعُ طَلاَقُہُ عَلَی امْرَأَتِہِ۔",,,18353,,
18354,"حَدَّثَنَا عُمَرُ، عَنِ ابْنِ جُرَیْجٍ، عَنْ عَطَائٍ ، قَالَ: سَمِعْتُہُ یَقُولُ: إِنْ حَلَفَ رَجُلٌ عَلَی امْرَأَتِہِ أَنَّہَا لاَ تَخْرُجُ، فَخَرَجَتِ امْرَأَۃٌ لَہُ أُخْرَی ، فَقِیلَ لَہُ : ہَذِہِ امْرَأَتُک ، فَحَسِبَہَا الأُخْرَی فَطَلَّقَہَا ، قَالَ عَطَائٌ : لَیْسَ بِشَیْئٍ۔",,,18354,,
18355,"حَدَّثَنَا مُحَمَّدُ بْنُ یَزِیدَ ، عَنْ أَبِی الْعَلاَئِ ، عَنْ قَتَادَۃَ ؛ فِی رَجُلٍ کَانَتْ لَہُ امْرَأَتَانِ ، فَخَرَجَتْ إحْدَاہُمَا ، قَالَ : مَنْ ہَذِہِ ؟ قِیلَ : فُلاَنَۃُ ، قَالَ : إِنَّہَا طَالِقٌ ، وَکَانَتِ الَّتِی لَمْ یُسَمِّ ، قَالَ : قَدْ وَقَعَ الطَّلاَقُ عَلَیْہِمَا جَمِیعًا۔",,,18355,,
18356,"حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ؛ فِی رَجُلٍ کَانَتْ لَہُ امْرَأَتَانِ ، أوْ مَمْلُوکَتَانِ فَدَعَا إِحْدَاہُمَا ، فَقَالَ : أَنْتِ طَالِقٌ ، فَأَجَابَتْہُ الأُخْرَی ، قَالَ : تُطْلَقُ الَّتِی سَمَّی ، وَإِنْ قَالَ لِعَبْدِہِ ، فَمِثْلُ ذَلِکَ۔",,,18356,,
18357,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ، عَنْ أَشْعَثَ، عَنِ الْحَسَنِ؛ فِی رَجُلٍ قَالَ لامْرَأَتِہِ: اِلْحَقِی بِأَہْلِکِ، قَالَ: نِیَّتُہُ۔",,,18357,,
18358,"حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ؛ فِی الرَّجُلِ یَقُولُ لامْرَأَتِہِ : اِلْحَقِی بِأَہْلِکِ ، قَالَ : لَیْسَ بِشَیْئٍ ، إِلاَّ أَنْ یَنْوِیَ طَلاَقًا فِی غَضَبٍ۔",,,18358,,
18359,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ ہِشَامٍ ، عَنْ قَتَادَۃَ ، عَنْ عِکْرِمَۃَ ، قَالَ : إِذَا قَالَ : اِلْحَقِی بِأَہْلِکِ ، قَالَ : ہَذِہِ وَاحِدَۃٌ ، وَقَالَ قَتَادَۃُ : مَا أَعُدُّ ہَذَا شَیْئًا۔",,,18359,,
18360,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ ، وَحَمَّادًا عَنْ رَجُلٍ قَالَ لامْرَأَتِہِ : اُخْرُجِی، اِلْحَقِی بِأَہْلِکِ یَنْوِی الطَّلاَقَ ؟ قَالاَ : ہِیَ وَاحِدَۃٌ ، وَہُوَ أَحَقُّ بِرَجْعَتِہَا۔",,,18360,,
18361,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مُغِیرَۃَ ، عَنِ الْحَارِثِ الْعُکْلِیِّ ؛ فِی رَجُلٍ لَہُ أَرْبَعُ نِسْوَۃٍ فَقَالَ لَہُنَّ : بَیْنَکُنَّ ثَلاَثُ تَطْلِیقَاتٍ ، قَالَ : بَانَتْ کُلُّ وَاحِدَۃٍ مِنْہُنَّ بِثَلاَثِ تَطْلِیقَاتٍ ، وَالرَّجُلُ یُطَلِّقُ نِصْفَ تَطْلِیقَۃٍ ، قَالَ : ہِیَ تَطْلِیقَۃٌ تَامَّۃٌ۔",,,18361,,
18362,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مَنْصُورٍ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ کَانَ لَہُ أَرْبَعُ نِسْوَۃٍ ، فَقَالَ لَہُنَّ : بَیْنَکُنَّ تَطْلِیقَۃٌ ، قَالَ : لِکُلِّ وَاحِدَۃٍ تَطْلِیقَۃٌ۔",,,18362,,
18363,"حَدَّثَنَا أَبُو عَاصِمٍ رَوَّادُ بْنُ جَرَّاحٍ ، عَنِ الأَوْزَاعِیِّ ، قَالَ : قِیلَ لِعُمَرَ بْنِ عَبْدِ الْعَزِیزِ : الرَّجُلُ یُطَلِّقُ امْرَأَتَہُ نِصْفَ تَطْلِیقَۃٍ ؟ قَالَ : ہِیَ تَطْلِیقَۃٌ۔",,,18363,,
18364,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حَمَّادٍ ، وَقَتَادَۃَ ؛ فِی رَجُلٍ کَانَ لَہُ أَرْبَعُ نِسْوَۃٍ ، فَقَالَ لَہُنَّ: بَیْنَکُنَّ تَطْلِیقَۃٌ ، قَالَ : عَلَی کُلِّ وَاحِدَۃٍ مِنْہُنَّ تَطْلِیقَۃٌ۔",,,18364,,
18365,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ رَجُلٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : إِذَا قَالَ : أَنْتِ طَالِقٌ نِصْفَ ، أَوْ ثُلُثَ تَطْلِیقَۃٍ فَہِیَ تَطْلِیقَۃٌ۔",,,18365,,
18366,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، وَعَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ زُرَارَۃَ بْنِ أَوْفَی ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنَّ اللَّہَ تَجَاوَزَ ِلأَمَّتِی عَمَّا حَدَّثَتْ بِہِ أَنْفُسَہَا ، مَا لَمْ تَکَلَّمْ بِہِ ، أَوْ تَعْمَلْ بِہِ۔ (بخاری 2528۔ مسلم 202)",,,18366,,
18367,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنِ ابْنِ سِیرِینَ ، وَالْحَسَنِ ، أَنَّہُمَا قَالاَ : حدِیثُ النَّفْسِ بِالطَّلاَقِ لَیْسَ بِشَیْئٍ ، وَقَالَ ابْنُ سِیرِینَ : لَوْ لَمْ یُسْأَلْ کَانَ أَحَبَّ إلَیَّ۔",,,18367,,
18368,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، عَنْ إِسْمَاعِیلَ بْنِ آدَمَ ، قَالَ : سَأَلْتُ مُحَمَّدَ بْنَ سِیرِینَ عَنِ الرَّجُلِ یُحَدِّثُ نَفْسَہُ بِالطَّلاَقِ ؟ قَالَ : لَیْسَ حَدِیثُ النَّفْسِ بِشَیْئٍ۔",,,18368,,
18369,حَدَّثَنَا حَفْصٌ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ مِثْلَہُ۔,,,18369,,
18370,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، عَنْ جَابِرِ بْنِ زَیْدٍ (ح) وَعَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالاَ : لَیْسَ بِشَیْئٍ۔",,,18370,,
18371,حَدَّثَنَا عُمَرُ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ (ح) وَعَنْ عَمْرٍو ، عَنْ جَابِرِ بْنِ زَیْدٍ ؛ بِنَحْوِہِ۔,,,18371,,
18372,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : إِذَا حَدَّثَ نَفْسُہُ بِالطَّلاَقِ ، أَوِ العَتَاقِ ، فَلَیْسَ بِشَیْئٍ۔",,,18372,,
18373,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا جَعَلَ الرَّجُلُ أَمْرَ امْرَأَتِہِ بِیَدِ غَیْرِہِ ، فَمَا طَلَّقَ مِنْ شَیْئٍ فَہِیَ وَاحِدَۃٌ بَائِنَۃٌ۔",,,18373,,
18374,"حدَّثَنَا عَبْدُالأَعْلَی، عَنْ یُونُسَ، عَنِ الْحَسَنِ؛ فِی الرَّجُلِ یَجْعَلُ أَمْرَ امْرَأَتِہِ بِیَدِ رَجُلٍ، قَالَ: ہُوَ کَمَا قَالَ۔",,,18374,,
18375,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ فِی الرَّجُلِ یَقُولُ لِلرَّجُلِ : انْطَلِقْ فَطَلِّقْ عَنِّی فُلاَنَۃً ، قَالَ : ہُوَ جَائِزٌ ، ِإنْ طَلَّقَ جَازَ۔",,,18375,,
18376,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ زَکَرِیَّا ، قَالَ : سُئِلَ عَامِرٌ عَنْ رَجُلٍ جَعَلَ أَمْرَ امْرَأَتِہِ بِیَدِ رَجُلٍ آخَرَ ، فَطَلَّقَہَا الرَّجُلُ ثَلاَثًا ؟ فَقَالَ : ہِیَ وَاحِدَۃٌ ، إِنَّمَا جَعَلَ أَمْرَہَا بِیَدِہِ مَرَّۃً وَاحِدَۃً۔",,,18376,,
18377,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ حَمَّادٍ ، قَالَ : إِذَا جَعَلَ الرَّجُلُ أَمْرَ امْرَأَتِہِ بِیَدِ رَجُلٍ ، فَطَلَّقَ ، فَہِیَ وَاحِدَۃٌ بَائِنَۃٌ۔",,,18377,,
18378,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، قَالَ : سَمِعْتُ مَعْمَرًا یَذْکُرُ عَنِ الزُّہْرِیِّ ؛ فِی الرَّجُلِ یَجْعَلُ طَلاَقَ امْرَأَتِہِ بِیَدِہَا ، أَوْ بِیَدِ أَخِیہَا ، أَوْ أَبِیہَا ، أَوْ بِیَدِ أَحَدٍ ، فَالْقَوْلُ مَا قَالَ ، إِنْ طَلَّقَہَا وَاحِدَۃً فَوَاحِدَۃً ، وَإِنْ طَلَّقَہَا ثِنْتَیْنِ فَثِنْتَیْنِ ، وَإِنْ طَلَّقَ ثَلاَثًا فَثَلاَثًا۔",,,18378,,
18379,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِِ ، عَنْ إِبْرَاہِیمَ ، عَنْ مَسْرُوقٍ ، قَالَ : جَائَ رَجُلٌ إِلَی عُمَرَ فَقَالَ : إِنِّی جَعَلْت أَمْرَ امْرَأَتِی بِیَدِہَا ، فَطَلَّقَتْ نَفْسَہَا ثَلاَثًا ، فَقَالَ عُمَرُ لِعَبْدِ اللہِ : مَا تَقُولُ ؟ فَقَالَ عَبْدُ اللہِ : أَرَاہَا وَاحِدَۃً، وَہُوَ أَمْلَکُ بِہَا ، فَقَالَ عُمَرُ : وَأَنَا أَیْضًا أَرَی ذَلِکَ۔",,,18379,,
18380,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ أَبَانَ بْنِ عُثْمَانَ ، عَنْ زَیْدِ بْنِ ثَابِتٍ ؛ أَنَّہُ قَالَ فِی رَجُلٍ قَالَ لامْرَأَتِہِ : إِنْ جُزْتِ عَتَبَۃَ ہَذَا الْبَابِ ، فَأَمْرُک بِیَدِکِ ، فَجَازَتْ ، فَطَلَّقَتْ نَفْسَہَا طَلاَقًا کَثِیرًا ، قَالَ زَیْدٌ : ہِیَ وَاحِدَۃٌ۔",,,18380,,
18381,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ غَیْلاَنَ بْنِ جَرِیرٍ ، عَنْ أَبِی الْحَلاَلِ الْعَتَکِیِّ ؛ أَنَّہُ وَفَدَ إلَی عُثْمَانَ ، فَقَالَ : قُلْتُ : رَجُلٌ جَعَلَ أَمْرَ امْرَأَتِہِ بِیَدِہَا ، قَالَ : فَأَمْرُہَا بِیَدِہَا۔",,,18381,,
18382,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی طَلْحَۃَ شَدَّادٍ ، عَنْ غَیْلاَنَ بْنِ جَرِیرٍ ، عَنْ أَبِی الْحَلاَلِ ، قَالَ : سَأَلْتُ عُثْمَانَ عَنْ رَجُلٍ جَعَلَ أَمْرَ امْرَأَتِہِ بِیَدِہَا ؟ قَالَ : الْقَضَائُ مَا قَضَتْ۔",,,18382,,
18383,"حَدَّثَنَا ابْنُ أَبِی زَائِدَۃَ ، وَعَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْحَکَمِ ، عَنْ مِقْسَمٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : الْقَضَائُ مَا قَضَتْ۔",,,18383,,
18384,"حَدَّثَنَا ابْنُ أَبِی زَائِدَۃَ ، عن عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنْ ابْنِ عُمَرَ ، قَالَ : الْقَضَائُ مَا قَضَتْ۔",,,18384,,
18385,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ فَضَالَۃَ بْنِ عُبَیْدٍ (ح) وَعَنْ قَتَادَۃَ ، عَنْ عَبْدِ رَبِّہِ ، عَنْ أَبِی عِیَاضٍ ، قَالَ : الْقَضَائُ مَا قَضَتْ۔",,,18385,,
18386,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ قَتَادَۃَ ، عَنِ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : الْقَضَائُ مَا قَضَتْ۔",,,18386,,
18387,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنٍ ، عَنْ مُجَالِدٍ ، عَنِ الشَّعْبِیِّ ؛ فِی رَجُلٍ جَعَلَ أَمْرَ امْرَأَتِہِ بِیَدِہَا ، فَطَلَّقَتْ نَفْسَہَا ثَلاَثًا ، قَالَ : ہِیَ ثَلاَثٌ۔",,,18387,,
18388,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عُبَیْد اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ فِی الرَّجُلِ یَجْعَلُ أَمْرَ امْرَأَتِہِ بِیَدِہَا ، قَالَ : الْقَضَائُ مَا قَضَتْ ، فَإِن تناکرا حُلِّف۔",,,18388,,
18389,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ، وَالزُّہْرِیِّ ، قَالاَ : الْقَضَائُ مَا قَضَتْ۔",,,18389,,
18390,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : قُلْتُ لِلْحَکَمِ : قالَتْ : قَدْ طَلَّقْت نَفْسِی ثَلاَثًا ؟ قَالَ : قَدْ بَانَتْ مِنْہُ بِثَلاَثٍ ، یَعْنِی إِذَا جَعَلَ أَمْرَہَا بِیَدِہَا۔",,,18390,,
18391,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَنْ عَلْقَمَۃَ ، عَنْ عَبْدِ اللہِ ؛ أَنَّ رَجُلاً جَعَلَ أَمْرَ امْرَأَتِہِ بِیَدِہَا ، فَطَلَّقَتْ نَفْسَہَا ثَلاَثًا ، قَالَ : ہِیَ وَاحِدَۃٌ ، ثُمَّ لَقِیَ عُمَرَ فَقَالَ : نِعْمَ مَا رَأَیْتَ۔",,,18391,,
18392,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، قَالَ : حُدِّثْنَا إِذْ ذَاکَ ، أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ کَتَبَ فِی رَجُلٍ مِنْ بَنِی تَمِیمٍ جَعَلَ أَمْرَ امْرَأَتِہِ بِیَدِہَا ، قَالَ : إِنْ رَدَّتِ الأَمْرَ إِلَیْہِ فَلاَ شَیْئَ ، وَإِنْ طَلَّقَتْ نَفْسَہَا فَہِیَ وَاحِدَۃٌ ، وَہُوَ أَحَقُّ بِہَا۔",,,18392,,
18393,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مَنْصُورٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ فِی رَجُلٍ قَالَ لامْرَأَتِہِ : أَمْرُک بِیَدِکِ ، فَقَالَتْ : أَنْتَ طَالِقٌ ثَلاَثًا ، فَقَالَ ابْنُ عَبَّاسٍ : خَطَّأَ اللَّہُ نَوْئَہَا ، لَوْ قَالَتْ : أَنَا طَالِقٌ ثَلاَثًا ، لَکَانَ کَمَا قَالَتْ۔",,,18393,,
18394,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، قَالَ : ذَکَرْتُہُ ِلإِبْرَاہِیمَ ، فَقَالَ : سَوَائٌ ہِیَ وَاحِدَۃٌ ، وَہُوَ أَمْلَکُ بِہَا إِنْ قَالَتْ : طَلَّقْتُکَ ، أَوْ طَلَّقْتُ نَفْسِی۔",,,18394,,
18395,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : خَطَّأَ اللَّہُ نَوْئَہَا۔",,,18395,,
18396,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنِ الأَعْمَشِِ ، عَنْ حَبِیبٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ فِی رَجُلٍ جَعَلَ أَمْرَ امْرَأَتِہِ بِیَدِہَا ، فَقَالَتْ : أَنْتَ طَالِقٌ ثَلاَثًا ، قَالَ : خَطَّأَ اللَّہُ نَوْئَہَا۔",,,18396,,
18397,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ الْعَبْدِیُّ ، قَالَ: حدَّثَنَا زَکَرِیَّا بْنُ أَبِی زَائِدَۃَ ، قَالَ: قَالَ مَنْصُورٌ ، حَدَّثَنِی إِبْرَاہِیمُ، عَنْ عَلْقَمَۃَ ، قَالَ : کُنْتُ عِنْدَ عَبْدِ اللہِ بْنِ مَسْعُودٍ فَأَتَاہُ رَجُلٌ ، فَقَالَ : یَا أَبَا عَبْدَ الرَّحْمَنِ ، إِنَّہُ کَانَ بَیْنِی وَبَیْنَ أَہْلِی بَعْضُ مَا یَکُونُ بَیْنَ النَّاسِ ، وَإِنَّہَا قَالَتْ : لَوْ کَانَ مَا بِیَدِکَ مِنَ الأَمْرِ بِیَدِی لَعَلِمْتَ مَا أَصْنَعُ؟ فَقُلْتُ لَہَا : ہُوَ بِیَدِکِ ، قَالَتْ : فَإِنِّی قَدْ طَلَّقْتُکَ ثَلاَثًا ، قَالَ عَبْدُ اللہِ : ہِیَ تَطْلِیقَۃٌ وَاحِدَۃٌ ، وَأَنْتَ أَحَقُّ بِہَا ، قَالَ : ثُمَّ ذَکَرْتُ ذَلِکَ لِعُمَرَ ، فَقَالَ : لَوْ قُلْتَ غَیْرَ ذَلِکَ لَرَأَیْتُ أَنَّک لَمْ تُصِبْ۔",,,18397,,
18398,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ، قَالَ : قَالَ عبْدُ اللہِ : إِذَا خَیَّرَ الرَّجُلُ امْرَأَتَہُ فَاخْتَارَتْ نَفْسَہَا ، فَوَاحِدَۃٌ بَائِنَۃٌ ، وَإِنِ اخْتَارَتْ زَوْجَہَا فَلاَ شَیْئَ ، وَقَالَ عَلِیٌّ : إِنِ اخْتَارَتْ نَفْسَہَا فَوَاحِدَۃٌ بَائِنَۃٌ ، وَإِنِ اخْتَارَتْ زَوْجَہَا فَوَاحِدَۃٌ ، وَہُوَ أَمْلَکُ بِرجعَتِہَا ۔",,,18398,,
18399,"حدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ إسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ ، عَنْ مَسْرُوقٍ ، قَالَ : مَا أُبَالِی خَیَّرْتُ امْرَأَتِی وَاحِدَۃً ، أَوْ مِئَۃً ، أَوْ أَلْفًا ، بَعْدَ أَنْ تَخْتَارَنِی ، وَلَقَدْ أَتَیْتُ عَائِشَۃَ فَسَأَلْتہَا عَنْ ذَلِکَ ؟ فَقَالَتْ : قَدْ خَیَّرَنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَاخْتَرْنَاہُ ، أَفَکَانَ طَلاَقًا ؟۔ (بخاری 5263۔ مسلم 1154)",,,18399,,
18400,"حَدَّثَنَا عَبْدُ اللہِ بْنُ مُبَارَکٍ ، عَنْ یَحْیَی بْنِ بِشْرٍ ، قَالَ : سَمِعْتُ عِکْرِمَۃَ یُحَدِّثُ ؛ أَنَّ أَبَا الدَّرْدَائِ أُتِیَ وَہُوَ بِالشَّامِ فِی رَجُلٍ خَیَّرَ امْرَأَتَہُ فَاخْتَارَتْ زَوْجَہَا ، قَالَ : لَیْسَ بِشَیْئٍ ، قَالَ : وَکَانَ ابْنُ عَبَّاسٍ یُفْتِی بِذَلِکَ ، وَقَضَی بِہِ أَبَانُ بْنُ عُثْمَانَ بِالْمَدِینَۃِ۔",,,18400,,
18401,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ مُوسَی بْنِ مُسْلِمٍ ، عَنْ مُجَاہِدٍ ، قَالَ : قَالَ عَلِیٌّ : إِذَا خَلَعَ الرَّجُلُ أَمْرَ امْرَأَتِہِ مِنْ عُنُقِہِ ، فَہِیَ وَاحِدَۃٌ وَإِنِ اخْتَارَتْہُ۔",,,18401,,
18402,"حَدَّثَنَا وَکِیعٌ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، عَنْ عِیسَی بْنِ عَاصِمٍ ، عَنْ زَاذَانَ ، قَالَ : کُنَّا جُلُوسًا عِنْدَ عَلِیٍّ ، فَسُئِلَ عَنِ الْخِیَارِ ؟ فَقَالَ : سَأَلَنِی عَنْہَا أَمِیرُ الْمُؤْمِنِینَ عُمَرُ ، فَقُلْتُ : إِنِ اخْتَارَتْ نَفْسَہَا فَوَاحِدَۃٌ بَائِنَۃٌ ، وَإِنِ اخْتَارَتْ زَوْجَہَا فَوَاحِدَۃٌ ، وَہُوَ أَحَقُّ بِہَا ، فَقَالَ : لَیْسَ کَمَا قُلْتَ : إِنِ اخْتَارَتْ نَفْسَہَا فَوَاحِدَۃٌ ، وَہُوَ أَحَقُّ بِہَا ، وَإِنِ اخْتَارَتْ زَوْجَہَا فَلاَ شَیْئَ ، وَہُوَ أَحَقُّ بِہَا ، فَلَمْ أَجِدْ بُدًّا مِنْ مُتَابَعَۃِ أَمِیرِ الْمُؤْمِنِینَ ۔ فَلَمَّا وُلِّیتُ وَأَتَیْتُ فِی الْفُرُوجِ رَجَعْت إلَی مَا کُنْت أَعْرِفُ ، فَقِیلَ لَہُ : رَأْیُکُمَا فِی الْجَمَاعَۃِ أَحَبُّ إِلَیْنَا مِنْ رَأْیِکَ فِی الْفُرْقَۃِ ، فَضَحِکَ عَلِیٌّ وَقَالَ : أَمَا إِنَّہُ أَرْسَلَ إِلَی زَیْدِ بْنِ ثَابِتٍ ، فَسَأَلَہُ ؟ فَقَالَ : إِنِ اخْتَارَتْ نَفْسَہَا فَثَلاَثٌ ، وَإِنِ اخْتَارَتْ زَوْجَہَا فَوَاحِدَۃٌ بَائِنَۃٌ۔",,,18402,,
18403,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ فِی الرَّجُلِ یَقُولُ لامْرَأَتِہِ : اخْتَارِی ، قَالَ : إِنِ اخْتَارَتْ نَفْسَہَا فَوَاحِدَۃٌ ، وَإِنِ اخْتَارَتْ زَوْجَہَا فَلاَ شَیْئَ۔",,,18403,,
18404,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، عَنِ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، عَنْ زَیْدِ بْنِ ثَابِتٍ ، قَالَ : إِنِ اخْتَارَتْ نَفْسَہَا فَثَلاَثٌ ، وَإِنِ اخْتَارَتْ زَوْجَہَا فَوَاحِدَۃٌ۔",,,18404,,
18405,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ سُفْیَانَ ، عَنْ أَبِی الزِّنَادِ ، عَنْ خَارِجَۃَ بْنِ زَیْدٍ ، وَأَبَانَ بْنِ عُثْمَانَ ، عَنْ زَیْدِ بْنِ ثَابِتٍ ، قَالَ : إِنِ اخْتَارَتْ نَفْسَہَا فَوَاحِدَۃٌ ، وَہُوَ أَمْلَکُ بِہَا ، وَإِنِ اخْتَارَتْ زَوْجَہَا فَلاَ شَیْئَ۔",,,18405,,
18406,"حدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِِ ، عَنْ مُسْلِمٍ ، عَنْ مَسْرُوقٍ ، عَنْ عَائِشَۃَ ، قَالَتْ : خَیَّرَنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَاخْتَرْنَاہُ ، فَلَمْ یَعْدُدْہَا عَلَیْنَا شَیْئًا۔ (بخاری 5262۔ مسلم 28)",,,18406,,
18407,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : سَأَلْتُ أَبَا جَعْفَرٍ عَنْ الرَّجُلِ یُخَیِّرُ امْرَأَتَہُ ، فَتَخْتَارُ زَوْجَہَا ؟ قَالَ : لَیْسَ بِشَیْئٍ ، قُلْتُ : فَإِنِ اخْتَارَتْ نَفْسَہَا ؟ قَالَ : تَطْلِیقَۃٌ ، وَہُوَ أَحَقُّ بِرَجْعَتِہَا۔",,,18407,,
18408,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ فِی رَجُلٍ خَیَّرَ امْرَأَتَہُ ، فَرَدَّتْ ذَلِکَ إلَیْہِ ، وَلَمْ تَقْضِ فِیہِ شَیْئًا ، قَالَ : لَیْسَ ذَلک بِشَیْء ۔",,,18408,,
18409,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ کَانَ یَقُولُ فِی الْخِیَارِ ، مِثْلَ قَوْلِ عُمَرَ ، وَعَبْدِ اللہِ۔,,,18409,,
18410,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ الأَعْمَشِِ ، عَنْ إِبْرَاہِیمَ ، عَنْ عُمَرَ ، وَعَبْدِ اللہِ ؛ أَنَّہُمَا قَالاَ : أَمْرُک بِیَدِکِ وَاخْتَارِی ، سَوَائٌ۔",,,18410,,
18411,"حَدَّثَنَا حَفْصٌ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ، عَنْ مَسْرُوقٍ ، قَالَ : فِی قَوْلِہِمْ أَمْرُکِ بِیَدِکِ وَاخْتَارِی ، سَوَائٌ۔",,,18411,,
18412,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الشَّعْبِیِّ ، عَنْ عَلِیٍّ ، وَعَبْدِ اللہِ ، وَزَیْدٍ ، قَالُوا : أَمْرُک بِیَدِکِ وَاخْتَارِی ، سَوَائٌ۔",,,18412,,
18413,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ (ح) وَعَنْ بَیَانٍ ، عَنِ الشَّعْبِیِّ ، قَالاَ : أَمْرُک بِیَدِکِ وَاخْتَارِی ، سَوَائٌ۔",,,18413,,
18414,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ؛ أَنَّہُ بَلَغَہُ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ جَعَلَ أَمْرَکِ بِیَدِکِ وَاخْتَارِی ، سَوَائً۔,,,18414,,
18415,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَمْرو ، عَنْ جَابِرِ بْنِ زَیْدٍ ، قَالَ : إِذَا خَیَّرَ الرَّجُلُ امْرَأَتَہُ ، فَہُوَ مَا قَالَتْ فِی مَجْلِسِہَا ، فَإِنْ تَفَرَّقَا فَلاَ شَیْئَ۔",,,18415,,
18416,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنِ الْمُثَنَّی ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ؛ أَنَّ عُمَرَ بْنَ الْخَطَّابِ ، وَعُثْمَانَ بْنَ عَفَّانَ ، قَالاَ : أَیُّمَا رَجُلٍ مَلَّکَ امْرَأَتَہُ أَمْرَہَا ، أَوَ خَیَّرَہَا ، فَافْتَرَقَا مِنْ ذَلِکَ الْمَجْلِسِ، فَلَمْ تُحْدِثْ فِیہِ شَیْئًا ، فَأَمْرُہَا إلَی زَوْجِہَا۔",,,18416,,
18417,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، قَالَ : قَالَ عَبْدُ اللہِ : إِذَا جَعَلَ الرَّجُلُ أَمْرَ امْرَأَتِہِ بِیَدِ رَجُلٍ ، فَقَامَ قَبْلَ أَنْ یَقْضِیَ فِی ذَلِکَ شَیْئًا ، فَلاَ أَمْرَ لَہُ۔",,,18417,,
18418,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ أَشْعَثَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : إِذَا خَیَّرَ الرَّجُلُ امْرَأَتَہُ ، فَلَمْ تَخْتَرْ فِی مَجْلِسِہَا ذَلِکَ ، فَلاَ خِیَارَ لَہَا۔",,,18418,,
18419,"حَدَّثَنَا ابْنُ عَیَّاشٍ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ قَالَ : إِذَا خَیَّرَ الرَّجُلُ امْرَأَتَہُ ، فَإِنِ اخْتَارَتْ ، وَإِلاَّ فَلَیْسَ لَہَا أَنْ تَخْتَارَ کُلَّمَا شَائَتْ۔",,,18419,,
18420,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، قَالَ : إِذَا قَامَتْ مِنْ مَجْلِسِہَا فَلاَ شَیْئَ۔",,,18420,,
18421,"حَدَّثَنَا یَحْیَی بْنُ بَشِیر ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ عَطَائٍ ، وَعَمْرِو بْنِ دِینَارٍ ، قَالاَ : إِذَا افْتَرَقَا فِی التَّمْلِیکِ وَالتَّخْیِیرِ ، فَلاَ خِیَارَ لَہَا۔",,,18421,,
18422,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ عبد اللہِ بْنِ عَمْرٍو ؛ فِی الرَّجُلِ یُخَیِّرُ امْرَأَتَہُ ، قَالَ : ذَلِکَ لَہَا مَا دَامَتْ فِی مَجْلِسِہَا۔",,,18422,,
18423,"حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُسٍ ، وَمُجَاہِدٍ ؛ فِی الرَّجُلِ یُخَیِّرُ امْرَأَتَہُ ، قَالُوا : إِنْ قَامَتْ مِنْ مَجْلِسِہَا قَبْلَ أَنْ تَخْتَارَ ، فَلاَ خِیَارَ لَہَا۔",,,18423,,
18424,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنِی إِسْمَاعِیلُ بْنُ أَبِی خَالِدٍ ، عَنْ عَامِرٍ ، قَالَ : إِذَا خَیَّرَ الرَّجُلُ امْرَأَتَہُ ، فَلَمْ تَخْتَرْ فِی ذَلِکَ الْمَجْلِسِ ، فَلَیْسَ لَہَا فِی ذَلِکَ خِیَار۔",,,18424,,
18425,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مَنْصُورٍ ، عَنِ الْحَکَمِ ، عَنْ عَلِیٍّ ؛ فِی رَجُلٍ جَعَلَ أَمْرَ امْرَأَتِہِ بِیَدِہَا، قَالَ : ہُوَ لَہَا حَتَّی تَتَکَلَّمَ ، أَوْ جَعَلَ أَمْرَ امْرَأَتِہِ بِیَدِ رَجُلٍ ، قَالَ : ہُوَ بِیَدِہِ حَتَّی یَتَکَلَّمَ۔",,,18425,,
18426,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حُمَیْدٍ ، عَنِ الْحَسَنِ بْنِ مُسْلِمٍ ؛ أَنَّ رَجُلاً جَعَلَ أَمْرَ امْرَأَتِہِ بِیَدِہَا ، فَقَامَتْ وَلَمْ تَقْضِ شَیْئًا ، فَرُفِعَ إلَی ابْنِ الزُّبَیْرِ ، فَقَالَ : عَلَی مَا قُمْتِ ؟ قَالَتْ : عَلَی أَنْ لاَ أَرْجِعَ إلَیْہِ ، فَأَبَانَہَا عَنْہُ۔",,,18426,,
18427,"حَدَّثَنَا وَکِیعٌ ، عَنْ زَکَرِیَّا ، عَنِ الشَّعْبِیِّ ؛ فِی رَجُلٍ خَیَّرَ امْرَأَتَہُ ، قَالَ : لَہُ أَنْ یَرْجِعَ مَا لَمْ تَتَکَلَّمْ۔",,,18427,,
18428,"حَدَّثَنَا عُمَرُ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، عَنْ جَابِرِ بْنِ زَیْدٍ ، قَالَ : لَہُ ذَلِکَ۔",,,18428,,
18429,"حَدَّثَنَا عُمَرُ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ فِی الرَّجُلِ یُخَیِّرُ امْرَأَتَہُ ، أَوْ یَجْعَلُ أَمْرَہَا بِیَدِہَا ، ثُمَّ یَرُدُّ ذَلِکَ مِنْ قَبْلِ أَنْ تَقُولَ شَیْئًا ، قَالَ : لَہُ ذَلِکَ۔",,,18429,,
18430,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ قَالَ : قَالَ ابْنُ مَسْعُودٍ : إِذَا خَیَّرَ الرَّجُلُ امْرَأَتَہُ ، فَقَامَتْ مِنْ مَجْلِسِہَا ، فَلاَ أَمْرَ لَہَا ، فَإِنِ ارْتَجَعَ فِیہَا قَبْلَ أَنْ تَخْتَارَ ، فَلاَ شَیْئَ لَہَا۔",,,18430,,
18431,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، عَنْ مَسْرُوقٍ ، عَنْ عَبْدِ اللہِ ، قَالَ : إِذَا خَیَّرَہَا ثَلاَثًا ، فَاخْتَارَتْ نَفْسَہَا مَرَّۃً فَہِیَ ثَلاَثٌ۔",,,18431,,
18432,"حدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ مُغِیرَۃَ ، عَنِ الشَّعْبِیِّ ؛ فِی رَجُلٍ خَیَّرَ امْرَأَتَہُ ثَلاَثَ مِرَارٍٍ ، فَاخْتَارَتْ نَفْسَہَا مَرَّۃً وَاحِدَۃً ، قَالَ : بَانَتْ مِنْہُ بِثَلاَثٍ۔",,,18432,,
18433,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ إِسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنِ الشَّعْبِیِّ قَالَ : سُئِلَ عَنْ رَجُلٍ قَالَ لامْرَأَتِہِ : اخْتَارِی ، فَسَکَتَتْ ، ثُمَّ قَالَ : اخْتَارِی ، فَسَکَتَتْ ، ثُمَّ قَالَ : اخْتَارِی ، فَاخْتَارَتْ نَفْسَہَا عِنْدَ الثَّالِثَۃِ ؟ فَأَبَانَہَا مِنْہُ ، فَجَعَلَہَا ثَلاَثًا۔",,,18433,,
18434,"حُدِّثْتُ عَنْ جَرِیرٍ، عَنْ مُغِیرَۃَ، عَنْ حَمَّادٍ، عَنْ إِبْرَاہِیمَ، قَالَ: إِذَا خَیَّرَہَا ثَلاَثًا فَاخْتَارَتْ مَرَّۃً، فَہِیَ ثَلاَثٌ۔",,,18434,,
18435,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ زُہَیْرٍ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، عَنْ مَسْرُوقٍ ، عَنْ عَبْدِ اللہِ ، قَالَ : سُکُوتُہَا رِضًا بِالزَّوْجِ ، إِذَا خَیَّرَہَا فَسَکَتَتْ۔",,,18435,,
18436,"حَدَّثَنَا حُمَیْدُ ، عَنْ حَسَنٍ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : سُکُوتُہَا رِضًا بِالزَّوْجِ۔",,,18436,,
18437,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا جَرِیرُ بْنُ حَازِمٍ ، عَنِ الزُّبَیْرِ بْنِ سَعِیدٍ ، عَنْ عَبْدِ اللہِ بْنِ عَلِیِّ بْنِ یَزِیدَ بْنِ رُکَانَۃَ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ؛ أَنَّہُ طَلَّقَ امْرَأَتَہُ اَلْبَتَّۃَ ، فَأَتَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَسَأَلَہُ ؟ فَقَالَ : مَا أَرَدْتَ بِہَا ؟ فَقَالَ : وَاحِدَۃً ، قَالَ : آللَّہِ مَا أَرَدْتُ بِہَا إلاَّ وَاحِدَۃً ؟ قَالَ : آللَّہِ مَا أَرَدْتُ بِہَا إِلاَّ وَاحِدَۃً ، قَالَ : فَرَدَّہَا عَلَیْہِ۔ (ابوداؤد 2201۔ بیہقی 342)",,,18437,,
18438,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنِ الْحَسَنِ ، عَنْ عَلِیٍّ ، قَالَ : ہِیَ ثَلاَثٌ۔",,,18438,,
18439,حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ فِی الْبَتَّۃِ ثَلاَثُ تَطْلِیقَاتٍ۔,,,18439,,
18440,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِِ ، عَنْ إِبْرَاہِیمَ ، عَنْ عُمَرَ ، وَعَبْدِ اللہِ ، قَالاَ : تَطْلِیقَۃٌ ، وَہُوَ أَمْلَکُ بِہَا۔",,,18440,,
18441,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ مُحَمَّدِ بْنِ عَبَّادٍ ، عَنِ الْمُطَّلِبِ بْنِ حَنْطَبٍ ، عَنْ عُمَرَ ؛ أَنَّہُ جَعَلَ اَلْبَتَّۃَ تَطْلِیقَۃً ، وَزَوْجُہَا أَمْلَکُ بِہَا۔,,,18441,,
18442,حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ عَبْدِ اللہِ بْنِ أَبِی سَلَمَۃَ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ (ح) وَعَنِ ابْنِ أَبِی خَالِدٍ ، عَنِ الشَّعْبِیِّ ، عَنْ عَبْدِ اللہِ بْنِ شَدَّادٍ ، عَنْ عُمَرَ ؛ مِثْلَہُ۔,,,18442,,
18443,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ خَالِدٍ ، عَنْ حُمَیْدِ بْنِ ہِلاَلٍ ، عَنْ عُمَرَ ؛ فِی قَوْلِ الرَّجُلِ لامْرَأَتِہِ أَنْتِ طَالِقٌ اَلْبَتَّۃَ ، إِنَّہَا وَاحِدَۃٌ بَائِنٌ ، وَقَالَ عَلِیٌّ : ہِیَ ثَلاَثٌ ، وَقَالَ شُرَیْحٌ : نَقِفُہُ عَلَی بِدْعَتِہِ۔",,,18443,,
18444,"حَدَّثَنَا ابْنُ إِدْرِیسَ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ، قَالَ : شَہِدَ عَبْدُ اللہِ بْنُ شَدَّادٍ عِنْدَ عُرْوَۃَ بْنِ الْمُغِیرَۃِ، أَنَّ عُمَرَ جَعَلَہَا وَاحِدَۃً ، وَہُوَ أَحَقُّ بِہَا ، وَأَنَّ الْرَائِشَ بْنَ عَدِیٍّ شَہِدَ عَلَی عَلِیٍّ ، أَنَّہُ جَعَلَہَا ثَلاَثًا ، وَأَنَّ شُرَیْحًا قَالَ : نِیَّتُہُ۔",,,18444,,
18445,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ، قَالَ : لَمَّا أَرْسَلَ عُرْوَۃُ إِلَی شُرَیْحٍ اعْتَلَّ عَلَیْہِ فَعَزَمَ عَلَیْہِ لَیَقُولَنَّ ، فَقَالَ : إِنَّ اللَّہَ سَنَّ سُنَنًا ، وَإِنَّ النَّاسَ قَدِ ابْتَدَعُوا ، وَإِنَّہُمْ عَمَدُوا إِلَی بِدَعِہِمْ فَخَلَطُوہَا بِالسُّنَنِ ، فَإِذَا انْتَہَی إلَیْک مِنْ ذَلِکَ شَیْئٌ ، فَمَیِّزُوا السُّنَنَ فَأَمْضُوہَا عَلَی وَجْہِہَا ، وَأَلْحِقُوا الْبِدَعَ بِأَہْلِہَا ، أَمَّا طَالِقٌ : فَمَعْرُوفَۃٌ ، وَأَمَّا اَلْبَتَّۃَ : فَبِدْعَۃٌ یُوقَفُ عَلَی بِدْعَتِہِ ، فَإِنْ شَائَ تَقَدَّمَ ، وَإِنْ شَائَ تَأَخَّرَ۔",,,18445,,
18446,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ؛ أَنَّ ابْنَ عُمَرَ جَائَ بِظِئْرٍ لَہُ إِلَی عَاصِمِ بْنِ عُمَرَ ، وَابْنِ الزُّبَیْر ، فَقَالَ : إِنَّ ظِئْرِی ہَذَا طَلَّقَ امْرَأَتَہُ اَلْبَتَّۃَ قَبْلَ أَنْ یَدْخُلَ بِہَا ، فَہَلْ عِنْدَکُمَا بِذَلِکَ عِلْمٌ ؟ أَوْ ہَلْ تَجِدَانِ لَہُ رُخْصَۃً ؟ فَقَالاَ : لاَ ، وَلَکِنَّا تَرَکْنَا ابْنَ عَبَّاسٍ ، وَأَبَا ہُرَیْرَۃَ عِنْدَ عَائِشَۃَ ، فَأْتِہِمْ فَسَلْہُمْ ثُمَّ ارْجِعْ إلَیْنَا فَأَخْبِرْنَا، فَأَتَاہُمْ فَسَأَلَہُمْ ؟ فَقَالَ أَبُو ہُرَیْرَۃَ : لاَ تَحِلُّ لَہُ حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ ، وَقَالَ ابْنُ عَبَّاسٍ : بُتَّتْ ، وَذَکَرَ مِنْ عَائِشَۃَ مُتَابَعَۃً لَہُمَا۔",,,18446,,
18447,"حَدَّثَنَا شَرِیکٌ ، عَنْ سَالِمٍ ، عَنْ سَعِیدٍ ؛ فِی اَلْبَتَّۃَ : إِنْ نَوَی وَاحِدَۃً فَوَاحِدَۃٌ ، وَإِنْ نَوَی ثَلاَثًا فَثَلاَثٌ۔",,,18447,,
18448,"حدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِنْ نَوَی طَلاَقًا فَأَدْنَی مَا یَکُونُ مِنْ نِیَّتِہِ فِی ذَلِکَ وَاحِدَۃٌ بَائِنٌ ، إِنْ شَائَ وَشَائَتْ تَزَوَّجَہَا ، وَإِنْ نَوَی ثَلاَثًا فَثَلاَثٌ۔",,,18448,,
18449,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : یُسْأَلُ عَنْ نِیَّتِہِ۔",,,18449,,
18450,"حَدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ، قَالَ : ہِیَ ثَلاَثٌ۔",,,18450,,
18451,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُبَیْدٍ ، عَنْ مَکْحُولٍ ، وَالزُّہْرِیِّ ، قَالاَ : ثَلاَثٌ۔",,,18451,,
18452,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، قَالَ : قَالَ أَبُو بَکْرٍ : سَأَلَنِی عُمَرُ بْنُ عَبْدِ الْعَزِیزِ عَنْ اَلْبَتَّۃَ ؟ فَقُلْتُ لَہُ : إِنَّ أَبَانَ بْنَ عُثْمَانَ کَانَ یَقُولُ : ہِیَ وَاحِدَۃٌ ، فَقَالَ عُمَرُ : لَوْ کَانَ الطَّلاَقُ أَلْفًا ، مَا أَبْقَت اَلْبَتَّۃَ مِنْہُ شَیْئًا۔",,,18452,,
18453,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ أَبِی بَکْرِ بْنِ عَمْرِو بْنِ حَزْمٍ ، قَالَ : قَالَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ : یَا أَبَا بَکْرٍ ، اَلْبَتَّۃَ ، مَا یَقُولُ النَّاسُ فِیہَا ؟ فَقُلْتُ لَہُ : کَانَ أَبَانُ بْنُ عُثْمَانَ یَجْعَلُہَا وَاحِدَۃً ، فَقَالَ عُمَرُ : لَوْ أَنْ الطَّلاَقُ أَلْف ، مَا أَبْقَت اَلْبَتَّۃَ مِنْہُ شَیْئًا ، مَنْ قَالَ اَلْبَتَّۃَ ، فَقَدْ رَمَی بِالْغَایَۃِ الْقُصْوَی۔",,,18453,,
18454,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ؛ أَنَّ زَیْدَ بْنَ ثَابِتٍ کَانَ یَقُولُ فِی اَلْبَتَّۃَ : ثَلاَثٌ۔",,,18454,,
18455,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِِ ، عَنْ إِبْرَاہِیمَ ، عَنْ عُمَرَ ، وَعَبْدِ اللہِ قَالاَ : فِی الْخَلِیَّۃِ تَطْلِیقَۃٌ، وَہُوَ أَمْلَکُ بِرَجْعَتِہَا۔",,,18455,,
18456,"حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنْ کُرْدُوسٍ ، عَنْ أَبِیہِ ، عَنْ عَبْدِ اللہِ ؛ فِی الْخَلِیَّۃِ قَالَ : نِیَّتُہُ۔",,,18456,,
18457,"حدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنِ الْحَسَنِ ، عَنْ عَلِیٍّ ، قَالَ : ہِیَ ثَلاَثٌ۔",,,18457,,
18458,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : ہِیَ ثَلاَثٌ۔",,,18458,,
18459,"حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ ، عَنْ وُہَیْبٍ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ ، قَالَ : الْخَلِیَّۃُ مَا نَوَی۔",,,18459,,
18460,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ؛ فِی الْخَلِیَّۃِ : إِنْ نَوَی طَلاَقًا فَأَدْنَی مَا یَکُونُ تَطْلِیقَۃٌ بَائِنًا ، إِنْ شَائَتْ وَشَائَ تَزَوَّجَہَا ، وَإِنْ نَوَی ثَلاَثًا فَثَلاَثٌ۔",,,18460,,
18461,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِِ ، عَنْ إِبْرَاہِیمَ ، عَنْ عُمَرَ ، وَعَبْدِ اللہِ ؛ فِی الْبَرِیَّۃِ: قَالاَ : تَطْلِیقَۃٌ، وَہُوَ أَمْلَکُ بِہَا۔",,,18461,,
18462,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنِ الْحَسَنِ ، عَنْ عَلِیٍّ ، قَالَ : ہِیَ ثَلاَثٌ۔",,,18462,,
18463,"حَدَّثَنَا ہُشَیْمُ بْنُ بَشِیرٍ ، عَنْ مَنْصُورٍ ، عَنِ الْحَسَنِ ، قَالَ : ہِیَ ثَلاَثٌ۔",,,18463,,
18464,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ ابْنِ أَبِی خَالِدٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : کَانَ یَقُولُ : ہِیَ وَاحِدَۃٌ۔",,,18464,,
18465,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : ہُوَ کَمَا قَالَ۔",,,18465,,
18466,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِنْ نَوَی وَاحِدَۃً فَوَاحِدَۃٌ ، وَإِنْ نَوَی ثِنْتَیْنِ فَثِنْتَانِ ، وَإِنْ نَوَی ثَلاَثًا فَثَلاَثٌ۔",,,18466,,
18467,"حَدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ؛ فِی الْبَرِیَّۃِ قَالَ : ہِیَ ثَلاَثٌ۔",,,18467,,
18468,"حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ، عَنْ وُہَیْبٍ، عَنِ ابْنِ طَاوُوسٍ، عَنْ أَبِیہِ؛ فِی الْبَرِیَّۃِ ، قَالَ: مَا نَوَی۔",,,18468,,
18469,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی الْمِنْہَالِ الطَّائِیِّ ، قَالَ : سَأَلْتُ الشَّعْبِیَّ عَنْ رَجُلٍ قَالَ لامْرَأَتِہِ : بَرِئْتُ مِنْکِ ؟ قَالَ : نِیَّتُہُ۔",,,18469,,
18470,"حدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَبِیبٍ ، عَنْ عَمْرٍو ، قَالَ : سُئِلَ جَابِرُ بْنُ زَیْدٍ عَنْ رَجُلٍ لَزِمَتْہُ امْرَأَتُہُ تَسْأَلُہُ الطَّلاَقَ ، فَقَالَ : اذْہَبِی فَأَنَا مِنْک بَرِیئٌ ، وَأَنْتِ مِنِّی بَرِیئَۃٌ ، وَلاَ یَنْوِی الطَّلاَقَ حِینَئِذٍ ؟ فَقَالَ : إِنْ لَمْ یَکُنْ نَوَی الطَّلاَقَ فَلَیْسَ بِطَلاَقٍ ، وَإِنْ کَانَ نَوَی الطَّلاَقَ فَہِیَ وَاحِدَۃٌ ، وَلَہُ أَنْ یُرَاجِعَہَا فِی عِدَّتِہَا۔",,,18470,,
18471,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ؛ قَالَ فِی الْبَرِیَّۃِ : إِنْ نَوَی الطَّلاَقَ فَأَدْنَی مَا یَکُونُ مِنْ نِیَّتِہِ فِی ذَلِکَ وَاحِدَۃٌ بَائِنَۃٌ ، إِنْ شَائَتْ وَشَائَ تَزَوَّجَہَا ، وَإِنْ نَوَی ثَلاَثًا فَثَلاَثٌ۔",,,18471,,
18472,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : ہِیَ ثَلاَثٌ لاَ تَحِلُّ لَہُ حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ۔",,,18472,,
18473,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ؛ أَنْ زَیْدَ بْنَ ثَابِتٍ کَانَ یَقُولُ : الْبَرِیَّۃُ ثَلاَثٌ۔",,,18473,,
18474,حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِِ ، عَنْ إِبْرَاہِیمَ ، عَنْ عُمَرَ ، وَعَبْدِ اللہِ ؛ فِی الْبَائِنِ تَطْلِیقَۃٌ ، وَہُوَ أَمْلَکُ بِرَجْعَتِہَا۔,,,18474,,
18475,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنِ الْحَسَنِ ، عَنْ عَلِیٍّ ، قَالَ : ہِیَ ثَلاَثٌ۔",,,18475,,
18476,"حَدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ؛ فِی الْبَائِنِ قَالَ : ہِیَ ثَلاَثٌ۔",,,18476,,
18477,"حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ ، عَنْ وُہَیْبٍ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ ؛ فِی الْبَائِنِ : مَا نَوَی۔",,,18477,,
18478,"حَدَّثَنَا ابْنُ عُلیَۃَ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ؛ فِی الْبَائِنَۃِ : ثَلاَثٌ۔",,,18478,,
18479,"حَدَّثَنَا أَبُو أَُسَامَۃَ ، قَالَ : حدَّثَنَا عُبَیدُ اللہِ بْنُ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : الْبَائِنُ ثَلاَثٌ ، لاَ تَحِلُّ لَہُ حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ۔",,,18479,,
18480,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ؛ أَنَّ زَیْدَ بْنَ ثَابِتٍ کَانَ یَقُولُ فِی الْبَائِنَۃِ : ثَلاَثٌ۔",,,18480,,
18481,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِِ ، عَنِ الْمِنْہَالِ بْنِ عَمْرٍو ، عَنْ نُعَیْمِ بْنِ دَجَاجَۃَ ؛ فِی رَجُلٍ طَلَّقَ امْرَأَتَہُ تَطْلِیقَتَیْنِ ، ثُمَّ قَالَ : أَنْتِ عَلَیَّ حَرَجٌ ، فَقَالَ عُمَرُ : مَا ہِیَ بِأَہْوَنِہِنَّ۔",,,18481,,
18482,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ خِلاَسٍ ، وَأَبِی حَسَّانَ ؛ أَنَّ عَلِیًّا کَانَ یَقُولُ : ثَلاَثٌ ، قَالَ قَتَادَۃُ : وَکَانَ ذَلِکَ رَأْیَ الْحَسَنِ یُفْتِی بِہِ۔",,,18482,,
18483,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ معمر ، عَنِ الزُّہْرِیِّ ؛ فِی طَلاَقِ الْحَرَجِ : ثَلاَثٌ۔",,,18483,,
18484,"حَدَّثَنَا عَبْدُالصَّمَدِ بْنُ عَبْدِالْوَارِثِ، عَنْ وُہَیْبٍ، عَنِ ابْنِ طَاوُوسٍ، عَنْ أَبِیہِ؛ فِی طَلاَقِ الْحَرَجِ: مَا نَوَی۔",,,18484,,
18485,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ ہِشَامٍ ، عَنْ قَتَادَۃَ ؛ أَنَّ عَلِیًّا قَالَ فِی طَلاَقِ الْحَرَجِ : ثَلاَثًا ، قَالَ : وَکَذَلِکَ قَالَ الْحَسَنُ۔",,,18485,,
18486,"حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ عَلِیٍّ ، قَالَ : إِذَا قَالَ الرَّجُلُ لامْرَأَتِہِ : أَنْتِ عَلَیَّ حَرَامٌ ، فَہِیَ ثَلاَثٌ۔",,,18486,,
18487,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنِ الْحَسَنِ ، عَنْ عَلِیٍّ ، قَالَ : ثَلاَثٌ۔",,,18487,,
18488,"حدَّثَنَا شَرِیکٌ ، عَنْ مُخَوَّلٍ ، عَنْ عَامِرٍ ، عَنْ عَبْدِ اللہِ ، قَالَ : الْحَرَامُ إِنْ نَوَی طَلاَقًا فَہِیَ وَاحِدَۃٌ ، وَہُوَ أَمْلَکُ بِرَجْعَتِہَا ، وَإِنْ لَمْ یَنْوِ طَلاَقًا ، فَہِیَ یَمِینٌ یُکَفِّرُہَا۔",,,18488,,
18489,حَدَّثَنَا شَرِیکٌ ، عَنْ مُخَوَّلٍ ، عَنْ أَبِی جَعْفَرٍ ؛ مِثْلَہُ۔,,,18489,,
18490,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، عَنْ إِبْرَاہِیمَ ، عَن عَبْدِ اللہِ ؛ فِی الْحَرَامِ : إِنْ نَوَی یَمِینًا فَیَمِینٌ ، وَإِنْ نَوَی طَلاَقًا فَمَا نَوَی۔",,,18490,,
18491,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَبْدِ الْخَالِقِ ، عَنْ حَمَّادٍ ، قَالَ : الْحَرَامُ وَاحِدَۃٌ بَائِنَۃٌ۔",,,18491,,
18492,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنِ الأَعْمَشِِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا قَالَ الرَّجُلُ لامْرَأَتِہِ : ہِیَ عَلَیْہِ حَرَامٌ ، یَنْوِی الطَّلاَقَ ، فَأَدْنَی مَا یَکُونُ تَطْلِیقَۃٌ بَائِنَۃٌ۔",,,18492,,
18493,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِنْ نَوَی طَلاَقًا ، فَأَدْنَی مَا یَکُونُ منْ نِیَّتُہُ فِی ذَلِکَ وَاحِدَۃٌ بَائِنَۃٌ ، إِنْ شَائَ وَشَائَتْ تَزَوَّجَہَا ، وَإِنْ نَوَی ثَلاَثًا فَثَلاَثٌ۔",,,18493,,
18494,"حَدَّثَنَا عَبْدُ الْوَہَّابِ ، عَنْ سَعِیدٍ ، عَنْ مَطَر ، عَنْ حُمَیْدِ بْنِ ہِلاَلٍ ، عَنْ سَعْدِ بْنِ ہِشَامٍ ؛ أَنَّ زَیْدَ بْنَ ثَابِتٍ قَالَ : ہِیَ ثَلاَثٌ ، لاَ تَحِلُّ لَہُ حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ۔",,,18494,,
18495,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ؛ أَنَّ زَیْدَ بْنَ ثَابِتٍ کَانَ یَقُولُ فِی الْحَرَامِ : ثَلاَثٌ۔",,,18495,,
18496,"حَدَّثَنَا عَبْدُ اللہِ بْنُ مُبَارَکٍ ، عَنْ خَالِدٍ ، عَنْ عِکْرِمَۃَ ، عَنْ عُمَرَ ، قَالَ : الْحَرَامُ یَمِینٌ۔",,,18496,,
18497,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ عِکْرِمَۃَ ، عَنْ عُمَرَ ؛ مِثْلَہُ۔,,,18497,,
18498,"حدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ مَطَرٍ ، عَنْ عَطَائٍ ، عَنْ عَائِشَۃَ ، أَنَّہَا قَالَتْ : یَمِینٌ۔",,,18498,,
18499,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ (ح) وَعَنْ جَابِرِ بْنِ زَیْدٍ ، وَسَعِیدِ بْنِ جُبَیْرٍ ، وَسَعِیدِ بْنِ الْمُسَیَّبِ ، وَسُلَیْمَانَ بْنِ یَسَارٍ ؛ أَنَّہُمْ قَالُوا : الْحَرَامُ یَمِینٌ۔",,,18499,,
18500,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ مَطَرٍ ، عَنْ أَبِی سَلَمَۃَ ، قَالَ : مَا أُبَالِی إِیَّاہَا حَرَّمْتُ ، أَوْ مائً فُرَاتاً۔",,,18500,,
18501,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ عَطَائٍ ، وَطَاوُسٍ ، قَالاَ : یَمِینٌ۔",,,18501,,
18502,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ، قَالَ : قَالَ أُناسٌ : ثَلاَثٌ ، وَقَالَ آخَرُونَ : کَفَّارَۃُ یَمِینٍ ، وَأَنَا أَرَی عَلَیْہِ کَفَّارَۃَ الظِّہَارِ۔",,,18502,,
18503,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدٍ (ح) وَعَنْ حَجَّاجٍ ، عَنْ أَبِی جَعْفَرٍ ، قَالاَ : الْحَرَامُ یَمِینٌ۔",,,18503,,
18504,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ مُبَارَکٍ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، قَالَ : حدَّثَنِی مَنْ لاَ أَتَّہِمُ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : الْحَرَامُ یَمِینٌ ، (قَدْ فَرَضَ اللَّہُ لَکُمْ تَحِلَّۃَ أَیْمَانِکُمْ)۔",,,18504,,
18505,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ، وَسُلَیْمَانَ بْنِ یَسَارٍ ، قَالاَ : الْحَرَامُ یَمِینٌ۔",,,18505,,
18506,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ إسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ ، عَنْ مَسْرُوقٍ ، قَالَ : مَا أُبَالِی حَرَّمْتُہَا ، أَوْ حَرَّمْتُ جَفْنَۃً مِنْ ثَرِیدٍ۔",,,18506,,
18507,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ ؛ أَنَّ أَبَا بَکْرٍ ، وَعُمَرَ ، وَابْنَ مَسْعُودٍ ، قَالُوا: مَنْ قَالَ لامْرَأَتِہِ : ہِیَ عَلَیْہِ حَرَامٌ فَلَیْسَتْ عَلَیْہِ بِحَرَامٍ ، وَعَلَیْہِ کَفَّارَۃُ یَمِینٍ۔",,,18507,,
18508,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ إِسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ ، قَالَ: إذَا قَالَ الرَّجُلُ لامْرَأَتِہِ: أَنْتِ عَلَیَّ حَرَامٌ، فَلَیْسَ بِشَیْئٍ۔",,,18508,,
18509,"حَدَّثَنَا یَعْلَی ، عَنْ إِسْمَاعِیلَ ، قَالَ : قَالَ عَامِرٌ : زَعَمَ أُنَاسٌ أَنَّ عَلِیًّا کَانَ یَجْعَلُہَا عَلَیْہِ حَرَامًا ، حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ ، وَاللَّہِ مَا قَالَہَا عَلِیٌّ قَطُّ ، وَلأَنَا أَعْلَمُ بِہَا مَنِ الَّذِی قَالَہَا ؟ إنَّمَا قَالَ : مَا أَنَا بِمُحِلِّہَا لَہُ ، وَلاَ بِمُحَرِّمِہَا عَلَیْہِ ، إِنْ شَائَ فَلْیَتَقَدَّمْ ، وَإِنْ شَائَ فَلْیَتَأَخَّرْ۔",,,18509,,
18510,"حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ خُصَیْفٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ فِی الرَّجُلِ یَقُولُ لامْرَأَتِہِ : أَنْتِ عَلَیَّ حَرَامٌ ، قَالَ : یُعْتِقُ رَقَبَۃً ، وَإِنْ قَالَ ذَلِکَ ِلأَرْبَعٍ ، فَأَرْبَعُ رِقَابٍ۔",,,18510,,
18511,"حَدَّثَنَا ابْنُ عَیَّاشٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ فِی رَجُلٍ قَالَ : کُلُّ حِلٍّ عَلَیَّ فَہُوَ حَرَامٌ ، قَالَ : لَوْلاَ امْرَأَتُہُ ، لأَمَرْتُہُ أَنْ یُکَفِّرَ یَمِینَہُ۔",,,18511,,
18512,"حَدَّثَنَا وَکِیعٌ ، عَنْ عُمَرَ بْنِ ذَرٍّ ، قَالَ : سَأَلْتُ الشَّعْبِیَّ عَنْ رَجُلٍ قَالَ : کُلُّ حِلٍّ عَلَیَّ فَہُو حَرَامٌ ؟ قَالَ : لاَ یُوجِبُ طَلاَقًا ، وَلاَ یُحَرِّمُ حَلاَلاً ، یُکَفِّرُ یَمِینَہُ۔",,,18512,,
18513,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ حَجَّاجٍ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ قَالَ : إذَا قَالَ : کُلُّ حِلٍّ عَلَیَّ حَرَامٌ ، إِنْ نَوَی طَلاَقًا فَہِیَ تَطْلِیقَۃٌ ، وَہُوَ أَمْلَکُ بِہَا ، وَإِنْ لَمْ یَنْوِ طَلاَقًا فَہِیَ یَمِینٌ یُکَفِّرُہَا۔",,,18513,,
18514,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی جَعْفَرٍ قَالَ : إذَا قَالَ : کُلُّ حِلٍّ عَلَیَّ حَرَامٌ ، أَطْعَمَ عَشْرَۃَ مَسَاکِینَ۔",,,18514,,
18515,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، وَجَابِرِ بْنِ زَیْدٍ ، قَالاَ: کُلُّ حِلٍّ عَلَیَّ حَرَامٌ ، کَفَّارَۃُ یَمِینٍ۔",,,18515,,
18516,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِالرَّحْمَنِ، عَنْ حَسَنِ بْنِ صَالِحٍ، عَنْ جَابِرٍ، عَنْ عَلِیٍّ؛ فِی الرَّجُلِ یَقُولُ لامْرَأَتِہِ: کُلُّ حِلٍّ عَلَیَّ فَہُوَ حَرَامٌ، قَالَ: تَحْرُمُ عَلَیْہِ امْرَأَتُہُ ، وَلاَ تَحِلُّ لَہُ حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ ، وَیُکَفِّرَ یَمِینَہُ مِنْ مَالِہِ۔",,,18516,,
18517,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مَنْصُورٍ ، عَنِ الشَّعْبِیِّ ، عَنْ مَسْرُوقٍ ، عَنْ عَبْدِ اللہِ ؛ فِی الرَّجُلِ یَہَبُ امْرَأَتَہُ ِلأَہْلِہَا ، قَالَ : إِنْ قَبِلَہَا أَہْلُہَا فَتَطْلِیقَۃٌ یَمْلِکُ رَجْعَتَہَا ، وَإِنْ لَمْ یَقْبَلُوہَا فَلاَ شَیْئَ۔",,,18517,,
18518,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ قَالَ : إِنْ قَبِلُوہَا فَتَطْلِیقَۃٌ یَمْلِکُ رَجْعَتَہَا۔",,,18518,,
18519,"حَدَّثَنَا شَرِیکٌ ، عَنْ أَبِی حَصِینٍ ، عَنْ یَحْیَی بْنِ وَثَّابٍ ، قَالَ بَعْضُ أَصْحَابِنَا : ہُوَ عَنْ مَسْرُوقٍ ، عَنْ عَبْدِ اللہِ قَالَ: إذَا قَالَ الرَّجُلُ لامْرَأَتِہِ: اسْتَفْلِحِی بِأَمْرِکِ، أَوِ اخْتَارِی، أَوْ قَدْ وَہَبْتُکِ ِلأَہْلِکِ ، فَہِیَ تَطْلِیقَۃٌ۔",,,18519,,
18520,"حَدَّثَنَا وَکِیعٌ ، عَنْ یَزِیدَ بْنِ إبْرَاہِیمَ ، عَنِ الْحَسَنِ ، عَنْ رَجُلٍ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : إِنْ قَبِلُوہَا فَوَاحِدَۃٌ بَائِنَۃٌ ، وَإِنْ لَمْ یَقْبَلُوہَا فَوَاحِدَۃٌ ، وَہُوَ أَحَقُّ بِرَجْعَتِہَا۔",,,18520,,
18521,"حَدَّثَنَا عَبْدُ الأَعْلَی، عَنْ سَعِیدٍ، عَنْ قَتَادَۃَ، عَنِ الْحَسَنِ، عَنْ زَیْدِ بْنِ ثَابِتٍ قَالَ: إذَا وَہَبَہَا ِلأَہْلِہَا فَقَبِلُوہَا فَثَلاَثٌ ، لاَ تَحِلُّ لَہُ حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ ، وَإِنْ رَدُّوہَا فَوَاحِدَۃٌ ، وَہُوَ أَحَقُّ بِہَا ، وَبِہِ کَانَ یَأْخُذُ الْحَسَنُ۔",,,18521,,
18522,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ عَطَائٍ ؛ فِی رَجُلٍ تَزَوَّجَ امْرَأَۃً ثُمَّ وَہَبَہَا ِلأَہْلِہَا ، قَالَ عَطَائٌ : إِنْ قَبِلُوہَا فَہِیَ تَطْلِیقَۃٌ بَائِنَۃٌ ، وَإِنْ رَدُّوہَا فَلاَ شَیْئَ۔",,,18522,,
18523,"حَدَّثَنَا یُونُسُ بْنُ مُحَمَّدٍ ، عَنْ عَبْدِ الْوَاحِدِ بْنِ زِیَادٍ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ؛ فِی الَّتِی تُوہَبُ ِلأَہْلِہَا : تَطْلِیقَۃٌ ، وَہُوَ أَحَقُّ بِرَجْعَتِہَا۔",,,18523,,
18524,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا سُفْیَانُ ، عَنْ مُطَرِّفٍ ، عَنِ الْحَکَمِ ، عَنْ یَحْیَی بْنِ الْجَزَّارِ ، عَنْ عَلِیٍّ ؛ فِی الْمَوْہُوبَۃِ ِلأَہْلِہَا : إِنْ قَبِلُوہَا فَتَطْلِیقَۃٌ بَائِنَۃٌ ، وَإِنْ رَدُّوہَا فَہِیَ وَاحِدَۃٌ ، وَہُوَ أَحَقُّ بِہَا۔",,,18524,,
18525,حَدَّثَنَا عَبْدُالسَّلاَمِ بْنُ حَرْبٍ ، عَنْ مُطَرِّفٍ ، عَنِ الْحَکَمِ ، عَنْ یَحْیَی بْنِ الْجَزَّارِ ، عَنْ عَلِیٍّ ؛ بِنَحْوٍ مِنْہُ۔,,,18525,,
18526,"حَدَّثَنَا وَکِیعٌ : إذَا وَہَبَہَا ِلأَہْلِہَا وَہُوَ لاَ یُرِیدُ بِذَلِکَ طَلاَقاً ، فَلَیْسَ بِشَیْئٍ قَبِلُوہَا ، أَوْ رَدُّوہَا ، وَإِنْ نَوَی طَلاَقًا ، فَہُوَ مَا نَوَی مِنَ الطَّلاَقِ قَبِلُوہَا ، أَوْ رَدُّوہَا۔",,,18526,,
18527,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ حُمَیْدٍ الطَّوِیلِ ، عَنِ الْحَسَنِ ، قَالَ : قالَتِ امْرَأَۃٌ لِزَوْجِہَا : أَرَاحَنِی اللَّہُ مِنْک ، قَالَ حُمَیْدٌ : أَوْ نَحْوًا مِنْ ہَذَا ، قَالَ : فَقَالَ : نَعَمْ ، فَنَعَمْ ، فَنَعَمْ ، قَالَ : فَأَتَی عُمَرَ بْنَ الْخَطَّابِ فَذَکَرَ ذَلِکَ لَہُ ، فَقَالَ عُمَرُ : تُرِیدُ أَنْ أَتَحَمَّلَہَا عَنْک ؟ ہِیَ بِکَ ، ہِیَ بِک۔",,,18527,,
18528,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ عَلِیِّ بْنِ عُمَرَ بْنِ حُسَیْنٍ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ عَلِیٍّ ؛ فِی رَجُلٍ طَلَّقَ امْرَأَتَہُ حِمْلَ بَعِیرٍ ، قَالَ : لاَ تَحِلُّ لَہُ حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ۔",,,18528,,
18529,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، عَنْ أُسَیْدٍ ، عَنْ عَرْفَجَۃَ ، عَنْ عَائِشَۃَ ؛ فِی رَجُلٍ طَلَّقَ امْرَأَتَہُ وَاحِدَۃً کَأَلْفٍ ، قَالَتْ : لاَ تَحِلُّ لَہُ حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ۔",,,18529,,
18530,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ فِی الرَّجُلِ یُطَلِّقُ امْرَأَتَہُ ثَلاَثًا ثُمَّ یَجْحَدُہَا ، قَالَ : أَحَبُّ إلَیَّ أَنْ تُرَافِعَہُ إلَی السُّلْطَانِ ، فَإِنْ حَلَفَ فَأَحَبُّ إلَیَّ أَنْ تَفْتَدِیَ مِنْہُ إذَا ہُوَ حَلَفَ۔",,,18530,,
18531,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : إِنْ کَانَتْ صَادِقَۃً ، فَقَدْ حَلَّت لَہَا الْفِدْیَۃُ۔",,,18531,,
18532,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : تُقَدِّمُہُ إلَی السُّلْطَانِ فَتَسْتَحْلِفُہُ۔",,,18532,,
18533,"حَدَّثَنَا جَرِیرٌ ، عَنْ سُلَیْمَانَ التَّیْمِیِّ ، عَنِ الْحَسَنِ ؛ فِی الْمَرْأَۃِ تَدَّعِی أَنَّ زَوْجَہَا طَلَّقَہَا ثَلاَثًا وَلَیْسَ لَہَا بَیِّنَۃٌ ، قَالَ : کَانَ یَأْمُرُہَا أَنْ تَقَرَّ عِنْدَہُ وَلاَ تَفِرُّ۔",,,18533,,
18534,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ دَاوُدَ ، عَنْ جَابِرِ بْنِ زَیْدٍ قَالَ : ہُمَا زَانِیَانِ مَا اجْتَمَعَا۔",,,18534,,
18535,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ إبْرَاہِیمَ بْنِ مُہَاجِرٍ ، عن مجاہد قَالَ : کَانَتْ لابْنِ عُمَرَ سَبِیَّۃٌ ، فَکَانَ زَوْجُہَا یُسَارُّہَا بِالطَّلاَقِ ، فَقَالَتْ لابْنِ عُمَرَ : إنَّہُ یَکُونُ مِنْہُ الشَّیْئُ فِی السِّرِّ ، فَأَحْلَفَہُ وَتَرَکَہُ۔",,,18535,,
18536,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنِ الْہُذَیْلِ بْنِ بِلاَلٍ ، عَنْ شَیْخٍ یُکَنَّی : أَبَا عَمْرٍو ، قَالَ : کُنْتُ جَالِسًا عِنْدَ ابْنِ عَبَّاسٍ ، فَأَتَتْہُ امْرَأَۃٌ فَقَالَتْ : إنَّ زَوْجَہَا یُطَلِّقُہَا فِی السِّرِّ وَیَجْحَدُہا فِی الْعَلاَنِیَۃِ ، فَقَالَ : عَلَیْہِ أَنْ یَحْلِفَ أَرْبَعَ شَہَادَاتٍ بِاللَّہِ مَا طَلَّقَ ، وَالْخَامِسَۃَ أَنَّ لَعْنَۃَ اللہِ عَلَیْہِ إِنْ کَانَ فَعَلَ۔",,,18536,,
18537,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنِ الْحَکَمِ بْنِ عَطِیَّۃَ ، قَالَ : سَمِعْتُ مُحَمَّدَ بْنَ سِیرِینَ ، وَسُئِلَ عَنِ الرَّجُلِ یُطَلِّقُ امْرَأَتَہُ ثَلاَثًا ، ثُمَّ یَجْحَدُہَا ؟ قَالَ : تَہْرُبُ مِنْہُ۔",,,18537,,
18538,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ قَالَ : تَسْتَحْلِفُہُ دُبُرَ الصَّلاَۃِ ، فَإِنْ حَلَفَ رُدَّتْ عَلَیْہِ۔",,,18538,,
18539,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ حَمَّادٍ قَالَ : سَأَلْتُُہُ عَنْ رَجُلٍ طَلَّقَ امْرَأَتَہُ ثَلاَثًا ، وَلَیْسَ لَہَا بَیِّنَۃٌ ؟ قَالَ : تَفْتَدِی بِمَالِہَا ، قَالَ : قُلْتُ : فَإِنْ أَبَی ؟ قَالَ : تَہْرُبُ مِنْہُ وَلاَ تَقَارُّہُ۔",,,18539,,
18540,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ سَوَّارِ ، عَنْ مُحَمَّدٍ قَالَ : کَانَ یَأْمُرُ مِثْلَ ہَذِہِ أَنْ تَہْرُبَ۔",,,18540,,
18541,"حَدَّثَنَا مُحَمَّدُ بْنُ مَرْوَانَ ، عَنْ عُمَارَۃَ قَالَ : سُئِلَ جَابِرُ بْنُ زَیْدٍ عَنْ رَجُلٍ غَلِطَ بِطَلاَقِ امْرَأَتِہِ ؟ فَقَالَ : لَیْسَ عَلَی الْمُؤْمِنِ غَلَطٌ۔",,,18541,,
18542,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، وَالْحَکَمِ ؛ فِی رَجُلٍ أَرَادَ أَنْ یَتَکَلَّمَ بِشَیْئٍ ، فَغَلِطَ فَطَلَّقَ ، فَقَالَ الشَّعْبِیُّ : لَیْسَ بِشَیْئٍ ، وَقَالَ الْحَکَمُ : یَلْزَمُہُ۔",,,18542,,
18543,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ قَالَ : إذَا طَلَّقَ الرَّجُلُ امْرَأَتَہُ وَاحِدَۃً بَائِنًا ، وَقَعَ عَلَیْہِ طَلاَقُہُ مَا کَانَتْ فِی الْعِدَّۃِ۔",,,18543,,
18544,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ فِی الرَّجُلِ یُطَلِّقُ امْرَأَتَہُ طَلاَقًا بَائِنًا ، ثُمَّ یُتْبِعُہَا بِطَلاَقٍ فِی عِدَّتِہَا ، قَالَ : یَلْحَقُہَا طَلاَقُہُ مَا کَانَتْ فِی الْعِدَّۃِ۔",,,18544,,
18545,حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ؛ مِثْلَہُ۔,,,18545,,
18546,"حَدَّثَنَا أَبُو عِصَامٍ رَوَّادُ بْنُ الْجَرَّاحِ ، عَنِ الأَوْزَاعِیِّ ، عَنِ الزُّہْرِیِّ ، وَعَنْ مَکْحُولٍ ، وَعَطَائٍ ؛ فِی الرَّجُلِ یُطَلِّقُ امْرَأَتَہُ تَطْلِیقَۃً بَائِنَۃً ، ثُمَّ یُطَلِّقُہَا فِی عِدَّتِہَا ، قَالوا : یَقَعُ عَلَیْہَا الطَّلاَقُ۔",,,18546,,
18547,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ، عَنْ إسْمَاعِیلَ، عَنِ الشَّعْبِیِّ، عَنْ شُرَیْحٍ قَالَ: یَلْزَمُ الْمُطَلَّقَۃَ الطَّلاَقُ فِی الْعِدَّۃِ۔",,,18547,,
18548,حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ ، عَنْ شُرَیْحٍ ؛ مِثْلَہُ۔,,,18548,,
18549,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ (ح) وَحَمَّادٍ ، عَنْ إبْرَاہِیمَ قَالاَ : یَلْزَمُہَا الطَّلاَقُ فِی الْعِدَّۃِ۔",,,18549,,
18550,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ قَالَ : قَالَ عَلِیٌّ : الطَّلاَقُ وَالْعِدَّۃُ بِالنِّسَائِ۔",,,18550,,
18551,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، عَنْ عَبْدِ اللہِ قَالَ : السُّنَّۃُ بِالْمَرْأَۃِ فِی الطَّلاَقِ ، أَوِ الْعِدَّۃِ۔",,,18551,,
18552,"حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ قَالَ : الطَّلاَقُ وَالْعِدَّۃُ بِالنِّسَائِ۔",,,18552,,
18553,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنِ الْحَسَنِ ، وَمُحَمَّدٍ ، أَنَّہُمَا قَالاَ : الطَّلاَقُ وَالْعِدَّۃُ بِالنِّسَائِ۔",,,18553,,
18554,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ قَالَ : نُبِّئْتُ عَنِ ابْنِ عَبَّاسٍ ؛ بِمِثْلِ ذَلِکَ۔",,,18554,,
18555,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ قَالَ : تَبِینُ الأَمَۃُ مِنَ الْحُرِّ وَالْعَبْدِ بِتَطْلِیقَتَیْنِ۔",,,18555,,
18556,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ سَیْفٍ ، عَنْ مُجَاہِدٍ قَالَ : إذَا کَانَتِ الأَمَۃُ تَحْتَ الْحُرِّ فَطَلاَقُہَا ثِنْتَانِ ، وَعِدَّتُہَا حَیْضَتَانِ ، وَإِذَا کَانَتِ الْحُرَّۃُ تَحْتَ الْعَبْدِ ، فَطَلاَقُہَا ثَلاَثٌ ، وَعِدَّتُہَا ثَلاَثُ حِیَضٍ۔",,,18556,,
18557,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ ؛ أَنَّ نُفَیْعًا فَتی أَمِّ سَلَمَۃَ ، طَلَّقَ امْرَأَتَہُ وَہِیَ حُرَّۃٌ تَطْلِیقَتَیْنِ ، فَحَرَصُوا عَلَی أَنْ یَرُدُّوہَا عَلَیْہِ ، فَأَبَی عُثْمَانُ وَزَیْدٌ ، قَالَ سُلَیْمَانُ : وَیَقُولُ أَحَدٌ غَیْرَ ہَذَا؟ فَلَمَّا قَدِمْتُ الْمَدِینَۃَ ، کَتَبْتُ إلَی أَبِی قِلاَبَۃَ ، فَکَتَبَ إلَیَّ : إِنَّہُ حَدَّثَنِی مَنْ أَطْمَئِنُّ إلَی حَدِیثِہِ : أَنَّ زَیْدَ بْنَ ثَابِتٍ، وَقَبِیصَۃَ بْنَ ذُؤَیْبٍ ، قَالاَ : إذَا کَانَ زَوْجُہَا حُرًّا وَہِیَ أَمَۃٌ ، فَطَلاَقُہُ طَلاَقُ حُرٍّ ، وَعِدَّتُہَا عِدَّۃُ أَمَۃٍ ، وَإِنْ کَانَ زَوْجُہَا عَبْدًا وَہِیَ حُرَّۃٌ ، فَطَلاَقُہُ طَلاَقُ عَبْدٍ ، وَعِدَّتُہَا عِدَّۃُ حُرَّۃٍ۔",,,18557,,
18558,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، قَالَ : حَدَّثَنِی عَبْدُ اللہِ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ قَالَ : الطَّلاَقُ بِالرِّجَالِ ، وَالْعِدَّۃُ بِالنِّسَائِ۔",,,18558,,
18559,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ عِکْرِمَۃَ ؛ مِثْلَہُ۔,,,18559,,
18560,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ قَتَادَۃَ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ (ح) وَعَنِ الشَّعْبِیِّ ، عَنْ مَکْحُولٍ (ح) وَسُفْیَانُ ، عَمَّنْ سَمِعَ إبْرَاہِیمَ ، وَالشَّعْبِیَّ ، قَالُوا : الطَّلاَقُ بِالرِّجَالِ ، وَالْعِدَّۃُ بِالنِّسَائِ۔",,,18560,,
18561,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ أَبِی سَلَمَۃَ قَالَ : حدَّثَنَا نُفَیْعٌ أَنَّہُ کَانَ مَمْلُوکًا وَتَحْتَہُ حُرَّۃٌ ، فَطَلَّقَہَا تَطْلِیقَتَیْنِ ، فَسَأَلَ عُثْمَانَ ، وَزَیْدًا ؟ فَقَالاَ : طَلاَقُکَ طَلاَقُ عَبْدٍ ، وَعِدَّتُہَا عِدَّۃُ حُرَّۃٍ۔",,,18561,,
18562,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ قَالَ : إذَا کَانَتِ الْحُرَّۃُ تَحْتَ الْعَبْدِ ، فَقَدْ بَانَتْ بِتَطْلِیقَتَیْنِ ، وَعِدَّتُہَا ثَلاَثُ حِیَضٍ ، وَإِذَا کَانَتِ الأَمَۃُ تَحْتَ الْحُرِّ ، فَقَدْ بَانَتْ مِنْہُ بِثَلاَثٍ ، وَعِدَّتُہَا حَیْضَتَانِ۔",,,18562,,
18563,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنِ ابْنِ الْمُسَیَّبِ قَالَ : الطَّلاَقُ لِلرِّجَالِ ،وَالْعِدَّۃُ لِلنِّسَائِ۔",,,18563,,
18564,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، وَأَبُو أُسَامَۃَ ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ قَالَ : قَالَ عَبْدُ اللہِ : بَیْعُ الأَمَۃِ طَلاَقُہَا۔",,,18564,,
18565,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ (ح) وَعَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، عَنْ أَُبَی قَالَ : بَیْعُ الأَمَۃِ طَلاَقُہَا۔",,,18565,,
18566,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، وَجَابِرٌ ، وَأَنَسٌ ، قَالوا : بَیْعُ الأَمَۃِ طَلاَقُہَا۔",,,18566,,
18567,"حَدَّثَنَا عَبْدَۃُ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ قَالَ : أَیُّہُمَا بِیعَ ، فَذَاکَ لَہَا طَلاَقٌ۔",,,18567,,
18568,"حَدَّثَنَا عَبدَۃ ، عَنْ سَعِیدٍ ، عَنْ یَعْلَی بْنِ حَکِیمٍ ، عَنْ عِکْرِمَۃَ قَالَ : أیُّہُمَا بِیعَ ، فَذَاکَ لَہَا طَلاَقٌ۔",,,18568,,
18569,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنِ الْحَکَمِ ، عَنْ عَبْدِ اللہِ قَالَ : بُضَعُہَا فِی بَیْعِ أَیِّہِمَا کَانَ۔",,,18569,,
18570,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ عَوْفٍ ، عَنِ الْحَسَنِ قَالَ : بَیْعُہُ طَلاَقُہَا۔",,,18570,,
18571,"حَدَّثَنَا یَعْلَی ، عَنْ إسْمَاعِیلَ قَالَ : سَأَلْتُ عَامِرًا عَنْ رَجُلٍ اشْتَرَیْ وَلِیْدَۃً وَلَہَا زَوْجٌ ، أَیَقَعُ عَلَیْہَا ؟ قَالَ : إِنْ وَقَعَ عَلَیْہَا لَمْ یُغَیَّر ذَلِکَ عَلَیْہِ أَحَدٌ ، قَاْلَ : وَإِنْ یَتَنَزَّہ خَیْرٌ لَہُ۔",,,18571,,
18572,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ قَالَ : إذَا بِیعَتِ الأَمَۃُ ، أَوْ وُہِبَتْ ، أَوْ وُرِثَتْ ، أَوْ أُعْتِقَتْ ، فَہُوَ فِرَاقٌ۔",,,18572,,
18573,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ أَبِی سَلَمَۃَ ؛ أَنَّ عَبْدَ الرَّحْمَنِ بْنَ عَوْفٍ اشْتَرَی جَارِیَۃً مِنْ عَاصِمِ بْنِ عَدِیٍّ ، فَأُخْبِرَ أَنَّ لَہَا زَوْجًا ، فَرَدَّہَا۔,,,18573,,
18574,حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ ؛ أَنَّ عَاصِمَ بْنَ عَدِیٍّ وَہَبَ لِعَبْدِ الرَّحْمَنِ بْنِ عَوْفٍ جَارِیَۃً ، فَلَمَّا دَنَا مِنْہَا أَخْبَرَتْہُ أَنَّ لَہَا زَوْجًا ، فَرَدَّہَا عَلَیْہِ۔,,,18574,,
18575,"حَدَّثَنَا شَرِیکٌ ، عَنْ عُبَیْدِ اللہِ بْنِ سَعْدٍ ، عَنْ یَسَارٍ بْنِ نمیر ، عَنْ عُمَرَ ، قَالَ : اشْتَرَی بُضْعَہَا۔",,,18575,,
18576,حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ مُصْعَبِ بْنِ سَعْدٍ ؛ أَنَّ سَعْدًا اشْتَرَی جَارِیَۃً لَہَا زَوْجٌ ، فَلَمْ یَقْرَبْہَا حَتَّی اشْتَرَی بُضْعَہَا مِنْ زَوْجِہَا بِخَمْسِ مِئَۃٍ۔,,,18576,,
18577,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا یُونُسُ بْنُ أَبِی إِسْحَاقَ ، عَنْ أَبِیہِ ، عَنْ مُصْعَبِ بْنِ سَعْدٍ ؛ أَنَّ سَعْدًا زَوَّجَ جَارِیَۃً لَہُ مَمْلُوکًا لَہُ ، فَتَبِعَتْہَا نَفْسُہُ ، قَالَ : فَجَعَلَ لِغُلاَمِہِ جُعْلاً عَلَی أَنْ یُطَلِّقَہَا۔",,,18577,,
18578,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ؛ أَنَّ رَجُلاً أَہْدَی إلَی عُثْمَانَ جَارِیَۃً ، فَلَمَّا جَرَّدَہَا ، قَالَتْ : إنَّ لِی زَوْجًا ، فَرَدَّہَا إلَی مَوْلاَہَا ، وَقَالَ : أَہْدَیْتَ لِی جَارِیَۃً لَہَا زَوْجٌ۔",,,18578,,
18579,"حَدَّثَنَا عَلِیُّ بْنُ ہَاشم ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الشَّعْبِیِّ قَالَ : أہْدَی رَجُلٌ مِنْ ہَمْدَانَ لِعَلِیٍّ جَارِیَۃً ، فَلَمَّا أَتَتْہُ سَأَلَہَا عَلِیٌّ : أَفَارِغَۃٌ ، أَمْ مَشْغُولَۃٌ ؟ فَقَالَتْ : مَشْغُولَۃٌ یَا أَمِیرَ الْمُؤْمِنِینَ ، قَالَ : فَاعْتَزَلَہَا ، وَأَرْسَلَ إلَی زَوْجِہَا فَاشْتَرَی بُضْعَہَا مِنْہُ بِعِشْرِینَ وَأَرْبَعِ مِئَۃٍ۔",,,18579,,
18580,"حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : الْعَبْدُ أَحَقُّ بِامْرَأَتِہِ أَیْنَمَا وَجَدَہَا ، إلاَّ أَنْ یَکُونَ طَلَّقَہَا طَلاَقًا بَائِنًا۔",,,18580,,
18581,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنِ ابْنِ سِیرِینَ قَالَ : نُبِّئْتُ أَنَّ عَبْدَ الرَّحْمَنِ رَأَی امْرَأَۃً فَأَعْجَبَتْہُ ، فَسَأَلَ عَنْہَا ؟ قَالُوا : ہَذِہِ أَمَۃٌ لِفُلاَنٍ ، فَاشْتَرَاہَا بِأَرْبَعَۃِ آلاَفٍ دِرْہَمٍ ، وَإِذَا لَہَا زَوْجٌ ، فَأَعْطَاہُ مِئَۃَ دِرْہَمٍ عَلَی أَنْ یُطَلِّقَہَا فَأَبَی ، فَزَادَہُ فَأَبَی ، فَزَادَہُ فَأَبَی حَتَّی بَلَغَ خَمْسَ مِئَۃِ دِرْہَمٍ فَأَبَی ، فَرَدَّہَا عَلَیْہِ۔",,,18581,,
18582,حَدَّثَنَا وَکِیعٌ، عَنْ مِسْعَرٍ، عَنْ مَعْبَدِ بْنِ خَالِدٍ، أَوْ عَنْ أَبِی حُصَیْنٍ؛ أَنَّ أَبَا مَسْعُودٍ کَرِہَ أَنْ یَطَأَہَا وَلَہَا زَوْجٌ۔,,,18582,,
18583,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ رَجُلٍ ، عَنْ شُرَیْحٍ قَالَ : إنِّی لأَکْرَہُ أَنْ أَطَأَ فَرْجَ امْرَأَۃٍ ، لَوْ وَجَدْتُ مَعَہَا رَجُلاً لَمْ أُقِمْ عَلَیْہِ الْحَدَّ۔",,,18583,,
18584,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، وَعَلِیُّ بْنُ صَالِحٍ ، عَنْ قَیْسِ بْنِ وَہْبٍ الْہَمْدَانِیِّ ، عَنْ أَبِی سَلَمَۃَ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَوْفٍ ؛ أَنَّہُ کَرِہَ أَنْ یَطَأَہَا وَلَہَا زَوْجٌ ۔ وَزَادَ فِیہِ عَلِیُّ بْنُ صَالِحٍ : وَقَالَ عَبْدُ الرَّحْمَنِ بْنُ عَوْفٍ : لاَ یَصْلُحُ زَوْجَانِ فِی الإِسْلاَمِ۔",,,18584,,
18585,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ أَبِی سُلَیْمَانَ ، عَنْ أَنَسِ بْنِ سِیرِینَ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ عَبْدَ الرَّحْمَنِ بْنَ عَوْفٍ اشْتَرَی جَارِیَۃً لَہَا زَوْجٌ ، قَالَ : فَرَدَّہَا ، وَقَالَ : دَلَّسَتْ لِی إذَنْ۔",,,18585,,
18586,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ الْمَکِّیِّ ، عَنْ سَالِمٍ ، وَالْقَاسِمِ ، وَعُبَیْدِ اللہِ بْنِ عَبْدِ اللہِ بْنِ عُمَرَ ، قَالُوا : قَالَ عُمَرُ : إنَّمَا الطَّلاَقُ بِیَدِ مَنْ یَحِلُّ لَہُ الْفَرْجُ۔",,,18586,,
18587,"حَدَّثَنَا عَبْدُ اللہِ بْنُ مُبَارَکٍ ، عَنْ أَبِی سَعِیدِ بن عَوْذ ، قَالَ : سَمِعْتُ سَعِیدَ بْنَ جُبَیْرٍ سَأَلَہُ رَجُلٌ فَقَالَ : أَنْکَحْتُ أَمَتِی عَبْدِی ؟ ثُمَّ أَرَدْتُ أَنْ أُفَرِّقَ بَیْنَہُمَا ؟ قَالَ : لَیْسَ لَکَ ذَلِکَ۔",,,18587,,
18588,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا أَذِنَ السَّیِّدُ ، فَالطَّلاَقُ بِیَدِ الْعَبْدِ۔",,,18588,,
18589,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنِ الشَّعْبِیِّ قَالَ : إذَا تَزَوَّجَ بِإِذْنِ سَیِّدِہِ ، فَالطَّلاَقُ بِیَدِ الْعَبْدِ",,,18589,,
18590,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ مُبَارَکِ بْنِ فَضَالَۃَ ، عَنْ إبْرَاہِیمَ أَبِی إسْمَاعِیلَ ، عَنْ عَلِیٍّ ، وَعَبْدِ الرَّحْمَنِ بْنِ عَوْفٍ ، وَحُذَیْفَۃَ ، قَالُوا فِی الْعَبْدِ یَتَزَوَّجُ بِإِذْنِ مَوَالِیہِ : الطَّلاَقُ بِیَدِ الْعَبْدِ۔",,,18590,,
18591,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُوسٍ ، وَمُجَاہِدٍ قَالُوا : إذَا کَانَتِ الْمَمْلُوکَۃُ لِغَیْرِہِ ، أَوْ کَانَتْ عِنْدَہُ ، وَقَدْ أَذِنَ لَہُ أَنْ یَتَزَوَّجَہَا ، فَالطَّلاَقُ بِیَدِ الْمَمْلُوکِ۔",,,18591,,
18592,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، قَالَ : قُلْتُ ِلأَبِی : الرَّجُلُ یُنْکِحُ مَمْلُوکَہُ مَمْلُوکَتَہُ ، ہَلْ یَصِحُّ لَہُ أَنْ یَنْزِعَہَا مِنْہُ بِغَیْرِ طِیبِ نَفْسٍ مِنْہُ ؟ قَالَ : بِئْسَ مَا صَنَعَ۔",,,18592,,
18593,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَقُولُ : إذَا نَکَحَ الْعَبْدُ بِإِذْنِ سَیِّدِہِ ، فَإِنَّ الطَّلاَقَ بِیَدِ الْعَبْدِ ، إِنْ شَائَ طَلَّقَ ، وَإِنْ شَائَ أَمْسَکَ۔",,,18593,,
18594,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، قَالَ : قُلْتُ لِسَعِیدِ بْنِ جُبَیْرٍ : إنَّ جَابِرَ بْنَ زَیْدٍ کَانَ یَقُولُ : إذَا زَوَّجَ السَّیِّدُ ، فَإِنَّ الطَّلاَقَ بِیَدِہِ ، فَقَالَ : کَذَبَ جَابِرُ بْنُ زَیْدٍ۔",,,18594,,
18595,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ قَالَ : الطَّلاَقُ بِیَدِ مَنْ یَمْلِکُ الْبُضْعَ۔",,,18595,,
18596,"حَدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ قَالَ : إذَا تَزَوَّجَ الْعَبْدُ بِإِذْنِ مَوْلاَہُ ، فَطَلاَقُہُ بِیَدِ الْعَبْدِ ، لَیْسَ لِلِسَیِّدِ أَنْ یُطَلِّقَ عَنْہُ۔",,,18596,,
18597,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ قَالَ : إذَا زَوَّجَ الرَّجُلُ عَبْدَہُ ، أَوْ أَذِنَ لَہُ فِی التَّزْوِیجِ ، فَإِنَّ الطَّلاَقَ بِیَدِ الْعَبْدِ۔",,,18597,,
18598,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ قَالَ : مَنْ زَوَّجَ عَبْدَہُ أَمَتَہُ بِمَہْرٍ وَبَیِّنَۃٍ ، لاَ یَصْلُحُ لَہُ أَنْ یَنْزِعَہَا مِنْہُ ، وَلاَ یَحِلُّ لَہُ فَرْجُہَا حَتَّی یَمُوتَ۔",,,18598,,
18599,"حَدَّثَنَا عَبِیدَۃُ بْنُ حُمَیْدٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ قَالَ : إذَا أَذِنَ السَّیِّدُ لِعَبْدِہِ أَنْ یَتَزَوَّجَ، فَالطَّلاَقُ بِیَدِ الْعَبْدِ۔",,,18599,,
18600,"حَدَّثَنَا عَبْدُ الْوَہَّابِ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسِ بْنِ مَالِکٍ ، وَابْنِ عَبَّاسٍ ، وَجَابِرِ بْنِ عَبْدِ اللہِ أَنَّہُمْ قَالُوا : الطَّلاَقُ بِیَدِ السَّیِّدِ۔",,,18600,,
18601,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : إذَا زَوَّجْتَ عَبْدَکَ أَمَتَکَ ، ثُمَّ بِعْتَہُ ، فَلَیْسَ لَکَ أَنْ تَمْنَعَہُ۔",,,18601,,
18602,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، وَالْحَسَنِ قَالاَ : إذَا تَزَوَّجَ الْعَبْدُ بِإِذْنِ سَیِّدِہِ ، فَالطَّلاَقُ بِیَدِ الْعَبْدِ۔",,,18602,,
18603,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنْ عَامِرٍ قَالَ : إذَا تَزَوَّجَ الْعَبْدُ بِغَیْرِ إذْنِ سَیِّدِہِ ، فَالطَّلاَقُ بِیَدِ سَیِّدِہِ۔",,,18603,,
18604,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا إسْرَائِیلُ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ؛ فِی الْعَبْدِ یَتَزَوَّجُ بِغَیْرِ إذْنِ سَیِّدِہِ ، قَالَ : إِنْ شَائَ السَّیِّدُ أَبْطَلَ ذَلِکَ ، وَإِنْ شَائَ سَکَتَ۔",,,18604,,
18605,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : إذَا تَزَوَّجَ الْعَبْدُ بِغَیْرِ إذْنِ سَیِّدِہِ ، فَالطَّلاَقُ بِیَدِ السَّیِّدِ ، وَإِذَا تَزَوَّجَ بِإِذْنِہِ ، فَالطَّلاَقُ بِیَدِ الْعَبْدِ۔",,,18605,,
18606,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا الْعُمَرِیُّ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، مِثْلَہُ۔",,,18606,,
18607,"حَدَّثَنَا أَبُو عَبْدِ الرَّحْمَنِ بَقِیُّ بْنُ مَخْلَدٍ ، قَالَ : حدَّثَنَا أَبُو بَکْرٍ عَبْدُ اللہِ بْنُ مُحَمَّدِ بْنِ أَبِی شَیْبَۃَ قَالَ:\n حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ خَالِدٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إذَا أَسْلَمَتِ النَّصْرَانِیَّۃُ قَبْلَ زَوْجِہَا فَہِیَ أَمْلَکُ بِنَفْسِہَا۔",,,18607,,
18608,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ أَبِیہِ ؛ أَنَّ الْحَسَنَ ، وَعُمَرَ بْنَ عَبْدِ الْعَزِیزِ قَالاَ فِی النَّصْرَانِیَّۃِ تُسْلِمُ تَحْتَ زَوْجِہَا ، قَالاَ : الإِسْلاَمُ أَخْرَجَہَا مِنْہُ۔",,,18608,,
18609,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ؛ فِی النَّصْرَانِیَّۃِ تُسْلِمُ تَحْتَ زَوْجِہَا قَالَ : یُفَرَّقُ بَیْنَہُمَا۔",,,18609,,
18610,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مُحَمَّدٍ الْمُحَارِبِیُّ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُوسٍ ، وَمُجَاہِدٍ ؛ فِی نَصْرَانِیٍّ تَکُونُ تَحْتَہُ نَصْرَانِیَّۃٌ فَتُسْلِمُ ، قَالُوا : إِنْ أَسْلَمَ مَعَہَا فَہِیَ امْرَأَتُہُ ، وَإِنْ لَمْ یُسْلِمْ فُرِّقَ بَیْنَہُمَا۔",,,18610,,
18611,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنِ السَّفَّاحِ بْنِ مَطَرٍ ، عَنْ دَاوُدَ بْنِ کُرْدُوسٍ قَالَ : کَانَ رَجُلٌ مِنْ بَنِی تَغْلِبَ یُقَالُ لَہُ : عُبَادَۃَ بْنُ النُّعْمَانِ بْنِ زُرْعَۃَ ، عِنْدَہُ امْرَأَۃٌ مِنْ بَنِی تَمِیمٍ ، وَکَانَ عُبَادَۃَ نَصْرَانِیًّا ، فَأَسْلَمَتِ امْرَأَتُہُ وَأَبَی أَنْ یُسْلِمَ ، فَفَرَّقَ عُمَرُ بَیْنَہُمَا۔",,,18611,,
18612,"حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنْ یُونُسَ، عَنِ الْحَسَنِ قَالَ: إذَا أَسْلَمَتِ الْمَرْأَۃُ قَبْلَ زَوْجِہَا انْقَطَعَ مَا بَیْنَہُمَا مِنَ النِّکَاحِ۔",,,18612,,
18613,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنِ الشَّیْبَانِیِّ ، عَنْ یَزِیدَ بْنِ عَلْقَمَۃَ ؛ أَنَّ رَجُلاً مِنْ بَنِی تَغْلِبَ یُقَالُ لَہُ : عُبَادَۃُ بْنُ النُّعْمَانِ ، وَکَانَ تَحْتَہُ امْرَأَۃٌ مِنْ بَنِی تَمِیمٍ فَأَسْلَمَتْ ، فَدَعَاہُ عُمَرُ فَقَالَ : إمَّا أَنْ تُسْلِمَ وَإِمَّا أَنْ أَنْزِعَہَا مِنْک، فَأَبَی أَنْ یُسْلِمَ ، فَنَزَعَہَا مِنْہُ عُمَرُ۔",,,18613,,
18614,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ مُطَرِّفٍ ، عَنِ الْحَکَمِ ؛ فِی الْیَہُودِیِّ ، أَوِ النَّصْرَانِیِّ تُسْلِمُ امْرَأَتُہُ عِنْدَہُ ، قَالَ : یُفَرَّقُ بَیْنَہُمَا۔",,,18614,,
18615,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ ابْنِ شُبْرُمَۃَ ، عَنْ عَمْرِو بْنِ مُرَّۃَ قَالَ : سَأَلْتُ سَعِیدَ بْنَ جُبَیْرٍ عَنْ رَجُلٍ نَصْرَانِیٍّ وَامْرَأَتُہُ نَصْرَانِیَّۃٌ ، فَأَسْلَمَتْ ؟ قَالَ : فرِّق ، فرِّق۔",,,18615,,
18616,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سَالِمٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : یُفَرَّقُ بَیْنَہُمَا۔",,,18616,,
18617,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ مُطَرِّفٍ ، عَنْ عَامِرٍ ، عَنْ عَلِیٍّ قَالَ : إذَا أَسْلَمَتِ النَّصْرَانِیَّۃُ امْرَأَۃُ الْیَہُودِیِّ ، أَوِ النَّصْرَانِیِّ کَانَ أَحَقَّ بِبُضْعِہَا ، لأَنَّ لَہُ عَہْدًا۔",,,18617,,
18618,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، وَشُعْبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ عَلِیٍّ قَالَ : ہُوَ أَحَقُّ بِہَا مَا دَامَ فِی دَارِ الْہِجْرَۃِ۔",,,18618,,
18619,"حَدَّثَنَا وَکِیعٌ ، عَنْ یَزِیدَ ، عَنِ ابْنِ سِیرِینَ ، عَنْ عَبْدِ اللہِ بْنِ یَزِیدَ الْخِطْمِیِّ ؛ أَنَّ عُمَرَ کَتَبَ : یُخَیَّرْنَ۔",,,18619,,
18620,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ قَالَ : ہُوَ أَحَقُّ بِہَا مَا کَانَتْ فِی الْمِصْرِ۔",,,18620,,
18621,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : یُقَرَّانِ عَلَی نِکَاحِہِمَا",,,18621,,
18622,حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ؛ أَنَّ ہَانِیئَ بْنَ قَبِیصَۃَ الشَّیْبَانِیَّ ، وَکَانَ نَصْرَانِیًّا عِنْدَہُ أَرْبَعُ نِسْوَۃٍ فَأَسْلَمْنَ ، فَکَتَبَ عُمَرُ بْنُ الْخَطَّابِ أَنْ یُقَرّن عِنْدَہُ۔,,,18622,,
18623,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّ نَصْرَانِیَّۃً أَسْلَمَتْ تَحْتَ نَصْرَانِیٍّ فَأَرَادُوا أَہْلَہَا أَنْ یَنْزِعُوہَا مِنْہُ ، فَتَرَحَّلُوا إلَی عُمَرَ فَخَیَّرَہَا۔,,,18623,,
18624,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ أَبِیہِ ؛ أَنَّ الْحَسَنَ ، وَعُمَرَ بْنَ عَبْدِ الْعَزِیزِ قَالاَ : تَطْلِیقَۃٌ بَائِنَۃٌ۔",,,18624,,
18625,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ قَالَ : إِذَا کَانَ الرَّجُلُ وَامْرَأَتُہُ مُشْرِکَیْنِ فَأَسْلَمَتْ وَأَبَی أَنْ یُسْلِمَ بَانَتْ مِنْہُ بِوَاحِدَۃٍ ، وَقَالَ عِکْرِمَۃُ مِثْلَ ذَلِکَ",,,18625,,
18626,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ قَالَ : تَفْرِیقُ الإِمَامِ تَطْلِیقَۃٌ۔",,,18626,,
18627,حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ إِسْحَاقَ بْنِ عَبْدِ اللہِ بْنِ أَبِی فَرْوَۃَ ، عَنِ الزُّہْرِیِّ ؛ أَنَّ امْرَأَۃَ عِکْرِمَۃَ بْنِ أَبِی جَہْلٍ أَسْلَمَتْ قَبْلَہُ ، ثُمَّ أَسْلَمَ وَہِیَ فِی الْعِدَّۃِ ، فَرُدَّتْ إلَیْہِ ، وَذَلِکَ عَلَی عَہْدِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔ (مالک 46),,,18627,,
18628,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ، عَنْ سَعِیدٍ، عَنْ قَتَادَۃَ، عَنْ مُجَاہِدٍ قَالَ: إذَا أَسْلَمَ وَہِیَ فِی عِدَّتِہَا فَہِیَ امْرَأَتُہُ۔",,,18628,,
18629,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ عَطَائٍ قَالَ : إِنْ أَسْلَمَ وَہِیَ فِی الْعِدَّۃِ فَہُوَ أَحَقُّ بِہَا۔",,,18629,,
18630,"حَدَّثَنَا عُبَیْدُ اللہِ ، عَنْ سُفْیَانَ ، عَنْ عَمْرِو بْنِ مَیْمُونٍ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ قَالَ : ہُوَ أَحَقُّ بِہَا مَا دَامَتْ فِی الْعِدَّۃِ۔",,,18630,,
18631,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ قَالَ : إِنْ أَسْلَمَ وَہِیَ فِی الْعِدَّۃِ فَہِیَ امْرَأَتُہُ",,,18631,,
18632,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ قَالَ : حُدِّثْنَا عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ قَالَ : إذَا أَسْلَمَ الزَّوْجُ بَعْدَ امْرَأَتِہِ خَیَّرَہَا مَا دَامَتْ فِی الْعِدَّۃِ ، أَوْ قَالَ : ہُوَ أَحَقُّ بِہَا مَا دَامَتْ فِی الْعِدَّۃِ۔",,,18632,,
18633,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ قَالَ : أَیُّمَا یَہُودِیٍّ ، أَوْ نَصْرَانِیٍّ أَسْلَمَ ، ثُمَّ أَسْلَمَتِ امْرَأَتُہُ فَہُمَا عَلَی نِکَاحِہِمَا ، إلاَّ أَنْ یَکُونَ فَرَّقَ بَیْنَہُمَا سُلْطَانٌ۔",,,18633,,
18634,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، وَالْحَسَنِ أَنَّہُمَا قَالاَ : لَیْسَ فِی الظِّہَارِ وَقْتٌ ، وَلاَ یَدْخُلُ فِیہِ إیلاَئٌ ، وَإِنْ تَطَاوَلَ ذَلِکَ۔",,,18634,,
18635,حَدَّثَنَا عَبَّادٌ عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ، مِثْلَہُ۔,,,18635,,
18636,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ فِی الرَّجُلِ یُظَاہِرُ مِنِ امْرَأَتِہِ ، وَلاَ یُوَقِّتُ أَجَلاً قَالَ : لاَ تَبِینُ مِنْہُ امْرَأَتُہُ وَإِنْ لَمْ یَقَعْ عَلَیْہَا ، مَا دَامَ یَتَلَوَّمُ فِی الْکَفَّارَۃِ۔",,,18636,,
18637,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : لَیْسَ فِی الظِّہَارِ وَقْتٌ۔",,,18637,,
18638,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ قَالَ : لَیْسَ فِی الظِّہَارِ وَقْتٌ۔",,,18638,,
18639,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ قَالَ : لَیْسَ فِی الظِّہَارِ وَقْتٌ۔",,,18639,,
18640,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ؛ فِی رَجُلٍ قَالَ لامْرَأَتِہِ : إِنْ قَرَبْتُہَا سَنَۃً فَہِیَ عَلَیْہِ کَظَہْرِ أُمِّہِ ، قَالَ : فَقَالَ الشَّعْبِیُّ : لاَ یَدْخُلُ الإِیلاَئُ فِی الظِّہَارِ۔",,,18640,,
18641,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، وَحَمَّادٍ قَالاَ : إذَا قَالَ الرَّجُلُ لامْرَأَتِہِ : ہِیَ عَلَیْہِ کَظَہْرِ أُمِّہِ أَرْبَعَۃَ أَشْہُرٍ ، فَمَضَتْ أَرْبَعَۃُ أَشْہُرٍ فَہُوَ إیلاَئٌ ، وَإِذَا قَالَ : ہِیَ عَلَیَّ کَظَہْرِ أُمِّی ، فَتَرَکَہَا سَنَۃً فَلَیْسَ بِإیلاَئٍ۔",,,18641,,
18642,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ إبْرَاہِیمَ ، عَنْ رَجُلٍ ، عَنْ عَلِیٍّ ، قَالَ : لاَ یَدْخُلُ إِیلاَئٌ فِی ظِہَارٍ ، وَلاَ ظِہَارٌ فِی إِیلاَئٍ۔",,,18642,,
18643,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : لَیْسَ فِی الظِّہَارِ وَقْتٌ ، إلاَّ أَنْ یَقُولَ : إِنْ قَرَبْتُکِ ، فَإِنْ قَالَ فَتَرَکَہَا أَرْبَعَۃَ أَشْہُرٍ بَانَتْ مِنْہُ بِالإِیلاَئِ۔",,,18643,,
18644,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنِ ابْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ قَالَ : إذَا قَالَ الرَّجُلُ لامْرَأَتِہِ : أَنْتِ عَلَیَّ کَظَہْرِ أُمِّی إِنْ قَرَبْتُکِ ، فَإِنْ قَرَبَہَا وَقَعَ الظِّہَارُ ، وَإِنْ تَرَکَہَا أَرْبَعَۃَ أَشْہُرٍ بَانَتْ مِنْہُ بِالإِیلاَئِ۔",,,18644,,
18645,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ قَالَ : ہُوَ إیلاَئٌ۔",,,18645,,
18646,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ عَنْ عَطَائٍ ؛ فِی رَجُلٍ قَالَ لامْرَأَتِہِ : إِنْ قَرَبْتُکِ فَأَنْتِ عَلَیَّ کَظَہْرِ أُمِّی ، فَتَرَکَہَا أَرْبَعَۃَ أَشْہُرٍ ، قَالَ : لَیْسَ بِشَیْئٍ۔",,,18646,,
18647,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ (ح) وَعَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ قَالاَ : إذَا قَالَ الرَّجُلُ لامْرَأَتِہِ : إِنْ قَرَبْتُکِ فَأَنْتِ عَلَیَّ کَظَہْرِ أُمِّی ، فَإِنْ قَرَبَہَا فِی الأَرْبَعَۃِ الأَشْہُرِ فَہُوَ ظِہَارٌ ، وَقَدْ ثبت عَلَیْہِ ، وَإِنْ لَمْ یَقْرَبْہَا حَتَّی تَمْضِیَ أَرْبَعَۃُ أَشْہُرٍ فَہُوَ إیلاَئٌ ، وَقَدْ بَانَتْ مِنْہُ بِوَاحِدَۃٍ۔",,,18647,,
18648,"حَدَّثَنَا شَبَابَۃُ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنِ الْحَکَمِ ، وَحَمَّادٍ قَالاَ : سَأَلْتُہُمَا عنْ رَجُلٍ قَالَ لامْرَأَتِہِ : إِنْ قَرَبْتُکِ سَنَۃً فَأَنْتِ عَلَیَّ کَظَہْرِ أُمِّی ؟ قَالاَ : إذَا مَضَتْ أَرْبَعَۃُ أَشْہُرٍ فَہِیَ تَطْلِیقَۃٌ بَائِنۃٌ ، وَبِہِ یَأْخُذُ أَبُو بَکْرٍ۔",,,18648,,
18649,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : الْخُلْعُ تَطْلِیقَۃٌ بَائِنٌ ، وَالإِیلاَئُ وَالْمُبَارَأَۃُ کَذَلِکَ۔",,,18649,,
18650,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قَالَ عَطَائٌ : کُلُّ طَلاَقٍ کَانَ نِکَاحُہُ مُسْتَقِیمًا ، إذَا تَفَرَّقَا فِی ذَلِکَ النِّکَاحِ ، وَإِنْ لَمْ یَتَکَلَّمْ بِالطَّلاَقِ فَہِیَ وَاحِدَۃٌ ، الْمُبَارَأَۃُ وَأَخْذُہُ الْفِدَائَ۔",,,18650,,
18651,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرٍ ، قَالَ : قُلْتُ لِعَبْدِ الْکَرِیمِ : بَلَغَنِی أَنَّ الزُّہْرِیَّ کَانَ یَقُولُ : الْمُبَارَأَۃُ أَشَدُّ الطَّلاَقِ ؟ قَالَ : مَا نَرَاہُ إذَا أَخَذَ مِنْہَا شَیْئًا افْتَدَتْ بِہِ إلاَّ بِمَنْزِلَۃِ الْخُلْعِ۔",,,18651,,
18652,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ عُمَرَ بْنِ عَامِرٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، وَالْحَسَنِ قَالاَ : کُلُّ فُرْقَۃٍ تَطْلِیقَۃٌ۔",,,18652,,
18653,"حَدَّثَنَا عَبْدُالسَّلاَمِ بْنُ حَرْبٍ، عَنْ مُغِیرَۃَ، عَنْ إبْرَاہِیمَ قَالَ: کُلُّ فُرْقَۃٍ کَانَتْ مِنْ قِبَلِ الرِّجَال فَہِیَ طَلاَقٌ۔",,,18653,,
18654,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، قَالَ : کُلُّ فُرْقَۃٍ فَہِیَ طَلاقٌ۔",,,18654,,
18655,"حَدَّثَنَا مُحَمَّدُ بْنُ یَزِیدَ ، عَنْ أَبِی الْعَلاَئِ ، عَنْ قَتَادَۃَ ، قَالَ : کُلُّ فُرْقَۃٍ فَہِیَ تَطْلِیقَۃٌ۔",,,18655,,
18656,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ قَالَ : کُلُّ فُرْقَۃٍ فَہِیَ تَطْلِیقَۃٌ۔",,,18656,,
18657,"حَدَّثَنَا وَکِیعٌ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ قَالَ : کُلُّ فُرْقَۃٍ فَہِیَ تَطْلِیقَۃٌ بَائِنٌ۔",,,18657,,
18658,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ سُفْیَانَ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ : لَیس کُلُّ فُرْقَۃٍ طَلاَقًا۔",,,18658,,
18659,"حَدَّثَنَا شَرِیکٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ (ح) وَعَنْ لَیْثٍ ، عَنْ طَاوُوسٍ (ح) وَعَنْ مُحَمَّدِ بْنِ سَالِمٍ ، عَنْ عَامِرٍ ، قَالُوا : إذَا کَانَتِ الأَمَۃُ تَحْتَ الْحُرِّ ، فَأُعْتِقَتْ فَاخْتَارَتْ نَفْسَہَا ، کَانَتْ فُرْقَۃً بِغَیْرِ طَلاَقٍ۔",,,18659,,
18660,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ حَمَّاد (ح) وعَنْ عُبَیدَۃَ ، عَنْ إبْرَاہِیمَ ، قَالاَ : إذَا أُعْتِقَتْ فَخُیِّرَتْ فَاخْتَارَتْ نَفْسَہَا ، فَہِیَ فُرْقَۃٌ بِغَیْرِ طَلاَقٍ۔",,,18660,,
18661,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ قَالَ : ہِیَ تَطْلِیقَۃٌ بَائِنٌ۔",,,18661,,
18662,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنْ مُحَمَّدٍ ، قَالَ : إذَا اخْتَارَتْ نَفْسَہَا فَہِیَ تَطْلِیقَۃٌ بَائِنٌ۔",,,18662,,
18663,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ فِی الرَّجُلِ یَقُولُ لامْرَأَتِہِ : إِنْ شِئْتِ فَأَنْتِ طَالِقٌ ، قَالَ : إِنْ شَائَتْ فَہِیَ طَالِقٌ ، وَإِنْ لَمْ تَشَأْ فَلاَ شَیْئَ۔",,,18663,,
18664,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ زَیْدٍ ، عَنْ حَفْصِ بْنِ سُلَیْمَانَ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ قَالَ لامْرَأَتِہِ : أَنْتِ طَالِقٌ إِنْ شِئْتِ ، فَقَالَتْ : قَدْ شِئْتُ ، فَقَالَ : ہِیَ طَالِقٌ وَہُوَ أَحَقُّ بِالرَّجْعَۃِ ، وَإِذَا قَالَ : إِنْ شِئْتُ طَلَّقْتُکِ ، فَقَالَتْ : قَدْ شِئْتُ ، قَالَ : إِنْ شَائَ لَمْ یُطَلِّقْہَا۔",,,18664,,
18665,"حَدَّثَنَا وَکِیعٌ ، عَنْ إبْرَاہِیمَ بْنِ مَیْمُونٍ ، مَوْلَی آلِ سَمُرَۃَ ، عَنْ عُرْوَۃَ بْنِ فَائِدٍ ؛ أَنَّ رَجُلاً قَالَ لامْرَأَتِہِ : إِنْ فَعَلْتِ کَذَا وَکَذَا فَلَسْتِ لِی بِامْرَأَۃٍ ، فَفَعَلَتْہُ ، فَانْطَلَقَتْ مَعَہُ إلَی عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، فَقَالَ : مَا نَوَی ، وَأَتَتْ مَعَہُ أَبَا عَبْدِ اللہِ الْجَدَلِیَّ فَقَالَ : مَا نَوَی ، وَقَالَ سَعِیدُ بْنُ جُبَیْرٍ : لَیْسَ بِشَیْئٍ۔",,,18665,,
18666,"حَدَّثَنَا غُنْدَرٌ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ قَتَادَۃَ ، قَالَ : قُلْتُ لِسَعِیدِ بْنِ الْمُسَیَّبِ : إنَّ الْحَجَّاجَ یُحَدِّثُ عَنْ أَبِیہِ ؛ أَنَّہُ قَالَ فِی رَجُلٍ قَالَ لامْرَأَتِہِ : لَسْتِ لِی بِامْرَأَۃٍ ، فَقَالَ : تَطْلِیقَۃٌ ، فَقَالَ سَعِیدٌ : مَا أَبْعَدَ۔",,,18666,,
18667,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ سُئِلَ عَنْ رَجُلٍ قَالَ لامْرَأَتِہِ : مَا أَنْتِ لِی بِامْرَأَۃٍ مِرَارًا ، وَہُوَ غَضْبَانُ ؟ قَالَ إبْرَاہِیمُ : مَا أُرَاہُ بَلَغَ ہَذَا ، إلاَّ وَہُوَ یُرِیدُ الطَّلاَقَ۔",,,18667,,
18668,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ؛ أَنَّہُ قَالَ فِی رَجُلٍ قَالَ لامْرَأَتِہِ : لَسْتِ لِی بِامْرَأَۃٍ ، قَالَ: مَا نَوَی۔",,,18668,,
18669,"حَدَّثَنَا مُحَمَّدُ بْنُ سَوَائٍ ، عَنْ سَعِیدٍ ، عَنْ مَطَرٍ ، عَنِ الْحَسَنِ ، وَ عطَائٍ ؛ فِی رَجُلٍ قَالَ لامْرَأَتِہِ : لَسْت لِی بِامْرَأَۃٍ ، قَالاَ : کِذْبَۃٌ ، لَیْسَتْ بِشَیْئٍ۔",,,18669,,
18670,"حَدَّثَنَا مُحَمَّدُ بْنُ سَوَائٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، قَالَ : إذَا وَاجَہَہَا بِہِ ، وَأَرَادَ الطَّلاَقَ ، فَہِیَ وَاحِدَۃٌ۔",,,18670,,
18671,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِِ ، عَنْ إِبرَاہِیمَ ، أَنَّہُ سُئِلَ عَنْ رَجُلٍ قِیلَ لَہُ : أَلَکَ امْرَأَۃٌ ؟ وَلَہُ امْرَأَۃٌ ، فَقَالَ : لاَ ، فَقَالَ إِبرَاہِیم : کِذْبَۃٌ کَذَبَہَا۔",,,18671,,
18672,"حَدَّثَنَا ابْنُ أَبِی زَائِدَۃَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، عَنْ عُمَرَ ، أَنَّہُ قَالَ : کِذْبَۃٌ ؛ فِی الرَّجُلِ لَہُ امْرَأَۃٌ فَیُسأَل : أَلَکَ امْرَأَۃٌ ؟ فَیَقُولُ : لاَ۔",,,18672,,
18673,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ سیار ، عَنِ الشَّعْبِیِّ ، قَالَ : ہُوَ کَاذِبٌ۔",,,18673,,
18674,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ قَالَ : لَیْسَ بِشَیْئٍ۔",,,18674,,
18675,"حَدَّثَنَا غُنْدَرٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ قَالَ : ہُوَ کَاذِبٌ۔",,,18675,,
18676,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ فِی رَجُلٍ قِیلَ لَہُ : طَلَّقْتَ امْرَأَتَکَ ؟ وَلَمْ یَکُنْ فَعَلَ ، فَقَالَ : نَعَمْ ، فَقَالَ : یَقَعُ عَلَیْہَا الطَّلاَقُ۔",,,18676,,
18677,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ أَبِی حُرَّۃَ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ قِیلَ لَہُ : طَلَّقْتَ امْرَأَتَکَ ؟ وَلَمْ یَکُنْ طَلَّقَہَا ، فَقَالَ : نَعَمْ ، فَقَالَ الْحَسَنُ : فَقَدْ طُلِّقَتْ۔",,,18677,,
18678,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ؛ فِی الرَّجُلِ یُقَالُ لَہُ : طَلَّقْتَ ؟ وَلَمْ یَکُنْ طَلَّقَ ، فَیَقُولُ : نَعَمْ ، فَقَالَ : کِذْبَۃٌ۔",,,18678,,
18679,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ ابْنِ شُبْرُمَۃُ ، عَنِ الشَّعْبِیِّ قَالَ : النِّیَّۃُ فِیمَا خَفِیَ ، فَأَمَّا مَا ظَہَرَ ، فَلاَ نِیَّۃَ فِیہِ۔",,,18679,,
18680,"حَدَّثَنَا مُحَمَّدُ بْنُ عُبَیْدٍ ، عَنْ خَالِدِ بْنِ دِینَارٍ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ طَلَّقَ امْرَأَتَہُ وَاحِدَۃً یَنْوِی ثَلاَثًا ، قَالَ : ہِیَ وَاحِدَۃٌ۔",,,18680,,
18681,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ جَعْفَرٍ الأَحْمَرِ ، عَنْ مُطَرِّفٍ ، عَنِ الْحَکَمِ ، قَالَ : ہِیَ وَاحِدَۃٌ۔",,,18681,,
18682,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنِ الْحَکَمِ ؛ فِی رَجُلٍ قَالَ لامْرَأَتِہِ : أَنْتِ طَالِقٌ ، وَأَشَارَ بِیَدِہِ ثَلاَثًا ، قَالَ : فَسَأَلُوا لَہُ عَنْ ذَلِکَ ؟ فَقِیلَ : ہِیَ وَاحِدَۃٌ۔",,,18682,,
18683,"حَدَّثَنَا جَرِیرٌ ، عَنْ بَیَانٍ ، قَالَ : سُئِلَ الشَّعْبِیُّ عَنْ أَبْوَابِ الطَّلاَقِ ؟ فَقَالَ الشَّعْبِیُّ : سُئِلَ رَجُلٌ مَرَّۃً : أَطَلَّقْتَ امْرَأَتَکَ ؟ قَالَ : فَأَوْمَأَ بِیَدِہِ بِأَرْبَعِ أَصَابِعَ ، وَلَمْ یَتَکَلَّمْ ، فَفَارَقَ امْرَأَتَہُ۔",,,18683,,
18684,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ مَعْمَرٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیِّبِ ، قَالَ : اللِّعَانُ تَطْلِیقَۃٌ بَائِنَۃٌ۔",,,18684,,
18685,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ أَبِی حَنِیفَۃَ ، عَنْ حماد ، عَنْ إبْرَاہِیمَ ، قَالَ : اللِّعَانُ تَطْلِیقَۃٌ بَائِنَۃٌ۔",,,18685,,
18686,"حَدَّثَنَا ہُشَیم ، عَنْ مُغِیرَۃَ ، قَالَ : قُلْتُ ِلإِبْرَاہِیمَ : الْمُلاَعِنُ أَشَدُّ مِنَ الَّذِی یُطَلِّقُ ثَلاَثًا ؟ فَقَالَ : نَعَمْ۔",,,18686,,
18687,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ إسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ ، قَالَ : الْمُلاَعَنَۃُ أَشَدُّ مِنَ الرَّجْمِ۔",,,18687,,
18688,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عُبَیْدِ اللہِ ، وَسُلَیْمَانَ بْنِ یَسَارٍ ، وَحُمَیْدِ بْنِ عَبْدِ الرَّحْمَنِ؛ سَمِعْنَا أَبَا ہُرَیْرَۃَ یَقُولُ : سَأَلْتُ عُمَرَ عَنْ رَجُلٍ مِنْ أَہْلِ الْبَحْرَیْنِ طَلَّقَ امْرَأَتَہُ تَطْلِیقَۃً ، أَوْ تَطْلِیقَتَیْنِ فَتَزَوَّجَتْ ، ثُمَّ إنَّ زَوْجَہَا طَلَّقَہَا ، ثُمَّ إنَّ الأَوَّلَ تَزَوَّجَہَا ، عَلَی کَمْ ہِیَ عِنْدَہُ ؟ قَالَ : ہِیَ عَلَی مَا بَقِیَ مِنَ الطَّلاَقِ۔",,,18688,,
18689,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، وَحَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، عَنْ أُبَی ، قَالَ : تَرْجِعُ إلَیْہِ بِمَا بَقِیَ مِنَ الطَّلاَقِ۔",,,18689,,
18690,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ؛ أَنَّ زِیَادًا سَأَلَ عِمْرَانَ بْنَ حُصَیْنٍ ،وَشُرَیْحًا عَنِ الرَّجُلِ یُطَلِّقُ امْرَأَتَہُ تَطْلِیقَۃً ، أَوْ تَطْلِیقَتَیْنِ ، فَتَبِینُ ، فَیَتَزَوَّجُہَا رَجُلٌ فَیُطَلِّقُہَا ، أَوْ یَمُوتُ عَنْہَا ، فَیَتَزَوَّجُہَا الأَوَّلُ ، عَلَی کَمْ تَکُونُ عِنْدَہُ؟ فَقَالَ عِمْرَانُ : عَلَی مَا بَقِیَ مِنَ الطَّلاَقِ ، وَقَالَ شُرَیْحٌ: نِکَاحٌ جَدِیدٌ ، وَطَلاَقٌ جَدِیدٌ۔",,,18690,,
18691,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ حَجَّاجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، قَالَ : کَانَ عُمَرُ ، وَأُبَیُّ ، وَأَبُو الدَّرْدَائِ، وَمُعَاذٌ ، یَقُولُونَ : تَرْجِعُ إلَیْہِ عَلَی مَا بَقِیَ۔",,,18691,,
18692,"حَدَّثَنَا وَکِیعٌ ، وَعَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ مَزِیدَۃَ بْنِ جَابِرٍ ، عَنْ أَبِیہِ ، عَنْ عَلِیٍّ ، قَالَ : لاَ یَہْدِمُ الزَّوَاجَ ، إلاَّ الثَّلاَثُ۔",,,18692,,
18693,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ مَزِیدَۃَ بْنِ جَابِرٍ ، عَنْ أَبِیہِ ، عَنْ عَلِیٍّ قَالَ : عَلَی مَا بَقِیَ۔",,,18693,,
18694,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ أُبی قَالَ : عَلَی مَا بَقِیَ۔",,,18694,,
18695,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ حَجَّاجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، قَالَ : قضَی عُمَرُ ، وَمُعَاذٌ ، وَزَیْدٌ ، وَأُبَیٌّ ، وَعَبْدُ اللہِ بْنُ عُمَرَ ؛ أَنَّہَا عَلَی مَا بَقِیَ مِنَ الطَّلاَقِ۔",,,18695,,
18696,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنْ عُمَرَ ، قَالَ : عَلَی مَا بَقِیَ مِنَ الطَّلاَقِ۔",,,18696,,
18697,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ ، عَنِ ابْنِ عُمَرَ قَالَ : ہِیَ عِنْدَہُ عَلَی طَلاَقٍ مُسْتَقْبَلٍ۔",,,18697,,
18698,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، وَسُفْیَانُ ، عَنْ حَمَّادٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، وَابْنِ عُمَرَ قَالاَ : ہِیَ عِنْدَہُ عَلَی طَلاَقٍ جَدِیدٍ۔",,,18698,,
18699,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ إبْرَاہِیمَ ، قَالَ : ہِیَ عِنْدَہُ عَلَی ثَلاَثٍ۔",,,18699,,
18700,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ قَالَ : کَانَ أَصْحَابُ عَبْدِ اللہِ یَقُولُونَ : یَہْدِمُ الثَّلاَثَ ، وَلاَ یَہْدِمُ الْوَاحِدَۃَ وَالثِّنْتَیْنِ ، یَعْنِی طَلاَقًا جَدِیدًا۔",,,18700,,
18701,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ قَالَ : کَانَ أَصْحَابُ عَبْدِ اللہِ یَقُولُونَ : یَہْدِمُ الثَّلاَثَ ، وَلاَ یَہْدِمُ الْوَاحِدَۃَ وَالثِّنْتَیْنِ۔",,,18701,,
18702,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ طَلْحَۃَ ، عَنْ إبْرَاہِیمَ ؛ أَنَّ أَصْحَابَ عَبْدِ اللہِ کَانُوا یَقُولُونَ : یَہْدِمُ الْوَاحِدَۃَ وَالثِّنْتَیْنِ کَمَا یَہْدِمُ الثَّلاَثَ ، إلاَّ عَبِیْدَۃَ فَإِنَّہُ قَالَ : ہِیَ عَلَی مَا بَقِیَ۔",,,18702,,
18703,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ، عَنْ شُرَیْحٍ قَالَ : عَلَی طَلاَقٍ جَدِیدٍ ، وَعَلَی نِکَاحٍ جَدِیدٍ۔",,,18703,,
18704,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرٍ ، عَنْ مَیْمُونٍ ، قَالَ : ہِیَ عِنْدَہُ عَلَی طَلاَقٍ جَدِیدٍ۔",,,18704,,
18705,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ رَجَائٍ ، عَنْ قَبِیصَۃَ ، قَالَ : قُلْتُ : رَجُلٌ طَلَّقَ امْرَأَتَہُ تَطْلِیقَۃ فَبَانَتْ مِنْہُ ، فَحَلَّتْ فَتَزَوَّجَتْ زَوْجًا ، فَدَخَلَ بِہَا ثُمَّ مَاتَ عَنْہَا ، أَوْ طَلَّقَہَا ، فَرَجَعَتْ إلَی الأَوَّلِ ، عَلَی کَمْ ہِیَ عِنْدَہُ ؟ قَالَ : عَلَی مَا بَقِیَ مِنَ الطَّلاَقِ ۔ قَالَ : قُلْتُ : فَطَلَّقَہَا أُخْرَی فَبَانَتْ مِنْہُ ، فَتَزَوَّجَتْ زَوْجًا فَدَخَلَ بِہَا ثُمَّ مَاتَ عَنْہَا ، أَوْ طَلَّقَہَا ، فَرَجَعَتْ إلَی زَوْجِہَا الأَوَّلِ ، عَلَی کَمْ ہِیَ عِنْدَہُ ؟ قَالَ : ہِیَ عَلَی مَا بَقِیَ ۔ قُلْتُ : فَطَلَّقَہَا أُخْرَی ، فَحَلَّتْ فَتَزَوَّجَتْ زَوْجًا ، ثُمَّ دَخَلَ بِہَا ثُمَّ مَاتَ عَنْہَا ، أَوْ طَلَّقَہَا ، فَرَجَعَتْ إلَی زَوْجِہَا الأَوَّلِ ، عَلَی کَمْ ہِیَ عِنْدَہُ ؟ قَالَ : ہِیَ عَلَی ثَلاَثٍ۔",,,18705,,
18706,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : إِنْ دَخَلَ بِہَا فَإِنَّہَا عِنْدَہُ عَلَی ثَلاَثِ تَطْلِیقَاتٍ ، وَإِنْ لَمْ یَدْخُلْ بِہَا فَإِنَّہَا عِنْدَہُ عَلَی بَقِیَّۃِ الطَّلاَقِ۔",,,18706,,
18707,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، قَالَ : یَقَعُ عَلَیْہَا عِنْدَ کُلِّ طُہْرٍ مَرَّۃً ، ثُمَّ یُمْسِکُ حَتَّی تَطْہُرَ ، فَإِذَا اسْتَبَانَ حَمْلُہَا بَانَتْ۔",,,18707,,
18708,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ قَالَ فِی رَجُلٍ قَالَ لامْرَأَتِہِ : إذَا حَمَلْتِ فَأَنْتِ طَالِقٌ ، قَالَ : یَغْشَاہَا إذَا طَہُرَتْ مِنَ الْحَیْضِ ، ثُمَّ یُمْسِکُ عَنْہَا إلَی مِثْلِ ذَلِکَ ، وَقَالَ ابْنُ سِیرِینَ : یَغْشَاہَا حَتَّی تَحْمِلَ۔",,,18708,,
18709,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، وَعِکْرِمَۃَ ، وَکِتَابِ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ أَنَّہُمْ قَالُوا : إذَا سَبَقَ أَحَدُہُمَا صَاحِبَہُ بِالإِسْلاَمِ ، فَلاَ سَبِیلَ لَہُ عَلَیْہَا إلاَّ بِخِطْبَۃٍ۔",,,18709,,
18710,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی الْمَجُوسِیَّیْنِ إذَا أَسْلَمَا فَہُمَا عَلَی نِکَاحِہِمَا ، فَإِنْ أَسْلَمَ أَحَدُہُمَا قَبْلَ صَاحِبِہِ ، فَقَدِ انْقَطَعَ مَا بَیْنَہُمَا مِنَ النِّکَاحِ۔,,,18710,,
18711,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ مِثْلَہُ إلاَّ أَنَّہُ قَالَ : بَانَتْ مِنْہُ۔",,,18711,,
18712,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ فِی الرَّجُلِ وَامْرَأَتِہِ یَکُونَانِ مُشْرِکَیْنِ فَیُسْلِمَانِ ، قَالَ: یَثْبُتُ نِکَاحُہُمَا ، فَإِنْ أَسْلَمَ أَحَدُہُمَا قَبْلَ الآخَرِ انْقَطَعَ مَا بَیْنَہُمَا ، یَعْنِی بِذَلِکَ الْمَجُوسَ وَالْمُشْرِکِینَ غَیْرَ أَہْلِ الْکِتَابِ۔",,,18712,,
18713,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنِ الْحَکَمِ ؛ فِی الْمَجُوسِیَّیْنِ : إذَا أَسْلَمَ أَحَدُہُمَا قَبْلَ صَاحِبِہِ فُرِّقَ بَیْنَہُمَا۔",,,18713,,
18714,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، عَنْ أَبِی الدَّرْدَائِ ، قَالَ : ثَلاَثٌ لاَ یُلْعَبُ بِہِنَّ : النِّکَاحُ ، وَالْعَتَاقُ ، وَالطَّلاَقُ۔",,,18714,,
18715,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ سُلَیْمَانَ بْنِ سُحَیْمٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ عُمَرَ ، قَالَ : أَرْبَعٌ جَائِزَاتٌ عَلَی کُلِّ حَالٍ : الْعِتْقُ ، وَالطَّلاَقُ ، وَالنِّکَاحُ ، وَالنَّذْرُ۔",,,18715,,
18716,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی کِبْرَان ، عَنِ الضَّحَّاکِ ؛ قَالَ سَمِعْتُہُ یَقُولُ : ثَلاَثٌ لاَ یُلْعَبُ بِہِنَّ : الطَّلاَقُ ، وَالنِّکَاحُ ، وَالنَّذْرُ۔",,,18716,,
18717,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ عَمْرِو بْنِ مُہَاجِرٍ ، قَالَ : کَتَبَ عَبْدُ الْمَلِکِ بْنُ مَرْوَانَ ، وَسُلَیْمَانُ ، وَعُمَرُ بْنُ عَبْدِ الْعَزِیزِ ، وَیَزِیدُ بْنُ عَبْدِ الْمَلِکِ : مَا أَقَلْتُمُ السُّفَہَائَ عَنْ شَیْئٍ ، فَلاَ تُقِیلُوہُمُ الطَّلاَقَ وَالْعَتَاقَ۔",,,18717,,
18718,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : ثَلاَثٌ لاَ لَعِبَ فِیہِنَّ : النِّکَاحُ ، وَالطَّلاَقُ ، وَالْعِتَاقُ۔",,,18718,,
18719,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ، عَنِ أَبی الدَّردَاء ، قَالَ : کَانَ الرَّجُلُ فِی الْجَاہِلِیَّۃِ یُطَلِّقُ ثُمَّ یَرْجِعُ ، یَقُولُ : کُنْتُ لاَعِبًا ، وَیُعْتِقُ ثُمَّ یَرْجِعُ ، یَقُولُ : کُنْتُ لاَعِبًا ، فَأَنْزَلَ اللَّہُ تَعَالَی: {وَلاَ تَتَّخِذُوا آیَاتِ اللہِ ہُزُوًا} ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ طَلَّقَ ، أَوْ حَرَّرَ ، أَوْ أَنْکَحَ ، أَوْ نَکَحَ ، فَقَالَ إنِّی کُنْتُ لاَعِبًا فَہُوَ جَائِزٌ۔ (طبری 482۔ طبرانی 780)",,,18719,,
18720,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، عَنْ سُلَیْمَانَ بْنِ حَبِیبٍ الْمُحَارِبِیِّ ، قَالَ : کَتَبَ إلَیَّ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ : مَہْمَا أَقَلْتَ السُّفَہَائَ مِنْ أَیْمَانِہِمْ ، فَلاَ تُقِلْہُمُ الْعَتَاقَ وَالطَّلاَقَ۔",,,18720,,
18721,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ، عَنْ یَحْیَی، عَنْ سَعِیدٍ، قَالَ: ثَلاَثٌ لَیْسَ فِیہِنَّ لَعِبٌ: الْعِتَاقُ، وَالطَّلاَقُ، وَالنِّکَاحُ۔",,,18721,,
18722,"حدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ مُطَرِّفٍ ، عَنِ الشَّعْبِیِّ ؛ فِی الرَّجُلِ یَقُولُ لامْرَأَتِہِ : بہشتم ، قَالَ : تَطْلِیقَۃٌ۔",,,18722,,
18723,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : طَلاَقُ الْعَجَمِیِّ بِلِسَانِہِ جَائِزٌ۔",,,18723,,
18724,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی شِہَابٍ ، عَنْ جَبَلَۃَ بْنِ دَعْلَجٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : إذَا طَلَّقَ الرَّجُلُ بِالْفَارِسِیَّۃِ قَالَ : یَلْزَمُہُ۔",,,18724,,
18725,"حَدَّثَنَا وَکِیعٌ ، عَنْ رَبِیعٍ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یَقُولُ لامْرَأَتِہِ : بہشتم ، قَالَ : یَلْزَمُہُ الطَّلاَقُ۔",,,18725,,
18726,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ ، عَنْ أَبِی حَصِینٍ ، عَنْ إبْرَاہِیمَ ؛ فِی الرَّجُلِ یَقُولُ لامْرَأَتِہِ: بہشتم ، بہشتم، بہشتم ، قَالَ : قَدْ قَالَہَا بِلِسَانِہِ ، ذَہَبَتْ مِنْہُ۔",,,18726,,
18727,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ أَبِیہِ ، عَنْ أَبِی قِلاَبَۃَ ، وَابْنِ سِیرِینَ ، قَالاَ : لاَ یَحِلُّ الْخُلْعُ حَتَّی یُوجَدَ رَجُلٌ عَلَی بَطْنِہَا ، لأَنَّ اللَّہَ یَقُولُ : {إلاَّ أَنْ یَأْتِینَ بِفَاحِشَۃٍ مُبَیِّنَۃٍ}۔",,,18727,,
18728,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ یَحِلُّ لِلِرَّجُلِ أَنْ یَأْخُذَ فِدْیَۃً مِنَ امْرَأَتِہِ أَنْ لاَ تُطِیعَہُ ، وَلاَ تَبَرَّ لَہُ قَسَمًا ، فَإِنْ فَعَلَتْ ذَلِکَ ، فَکَانَ مِنْ قِبَلِہَا شَیْئٌ ، حَلَّتْ لَہُ الْفِدْیَۃُ ، فَإِنْ أَبَی أَنْ یَقْبَلَ مِنْہَا الْفِدْیَۃَ ، وَأَبَتْ أَنْ تُطِیعَہُ ، بَعَثَا حَکَمَیْنِ : حَکَمًا مِنْ أَہْلِہِ ، وَحَکَمًا مِنْ أَہْلِہَا۔",,,18728,,
18729,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ ، قَالَ : إذَا کَرِہَتِ الْمَرْأَۃُ زَوْجَہَا ، فَلْیَأْخُذْ مِنْہَا وَلْیَدَعْہَا۔",,,18729,,
18730,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ مَرْوَانَ الأَصْفَرِ ، عَنْ حُمَیْدِ بْنِ عَبْدِ الرَّحْمَنِ الْحِمْیَرِیِّ ، قَالَ: یَطِیبُ لَکَ الْخُلْعُ إذَا قَالَتْ : لاَ أَغْتَسِلُ لَکَ مِنَ جَنَابَۃٍ ، وَلاَ أَبَرُّ لَکَ قَسَمًا ، وَلاَ أُطِیعُ لَکَ أَمْرًا۔",,,18730,,
18731,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَبْدِ اللہِ بْنِ نُجَیّ ، عَنْ عَلِیٍّ ، قَالَ : یَطِیبُ لِلرَّجُلِ الْخُلْعُ إذَا قَالَتْ : لاَ أَغْتَسِلُ لَکَ مِنَ جَنَابَۃٍ ، وَلاَ أُطِیعُ لَکَ أَمْرًا ، وَلاَ أَبَرُّ لَکَ قَسَمًا ، وَلاَ أَکْرُمُ نَفْسًا۔",,,18731,,
18732,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَلِیِّ بْنِ بَذِیمَۃَ ، عَنْ مِقْسَمٍ قَالَ : إذَا عَصَتْکَ ، وَآذَتْکَ۔",,,18732,,
18733,"حَدَّثَنَا وَکِیعٌ ، عَنِ یَزِید ، عَنِ الْحَسَنِ ؛ فِی قَوْلِہِ : (لاَ جُنَاحَ) قَالَ : ذَلِکَ فِی الْخُلْعِ ، إذَا قَالَتْ : لاَ أَغْتَسِلُ لَکَ مِنَ جَنَابَۃٍ۔",,,18733,,
18734,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُطَرِّفٍ ، عَنْ خَالِدٍ السِّجِسْتَانِیِّ ، عَنِ الضَّحَّاکِ ؛ فِی قولہ تعالی : {لِتَذْہَبُوا بِبَعْضِ مَا آتَیْتُمُوہُنَّ إلاَّ أَنْ یَأْتِینَ بِفَاحِشَۃٍ مُبَیِّنَۃٍ} قَالَ : إذَا فَعَلَتْ ذَلِکَ ، حَلَّ لَہُ أَنْ یَأْخُذَ مِنْہَا۔",,,18734,,
18735,"حَدَّثَنَا ابْنُ أَبِی غَنِیَّۃَ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ فِی الرَّجُلِ یَخْلَعُ الْمَرْأَۃَ ، قَالَ : إذَا أَتَی ذَلِکَ مِنْ قِبَلِہَا فَلاَ بَأْسَ۔",,,18735,,
18736,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، قَالَ : قَالَ جَابِرُ بْنُ زَیْدٍ : إذَا کَانَ النُّشُوزُ مِنْ قِبَلِہَا حَلَّ لَہُ فِدَاؤُہَا۔",,,18736,,
18737,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ ہِشَامٍ ؛ أَنَّ عُرْوَۃَ کَانَ یَقُولُ : لاَ یَحِلُّ لَہُ الْفِدَائُ حَتَّی یَکُونَ الْفَسَادُ مِنْ قِبَلِہَا ، وَلَمْ یَکُنْ یَقُولُ : لاَ تَحِلُّ لَہُ حَتَّی تَقُولَ : لاَ أَبَرُّ لَکَ قَسَمًا ، وَلاَ أَغْتَسِلُ لَکَ مِنْ جَنَابَۃٍ۔",,,18737,,
18738,"حدَّثَنَا ابْنُ عُلَیَّۃَ، عَنِ ابْنِ جُرَیْجٍ قَالَ: کَانَ طَاوُوسٌ یَقُولُ: یَحِلُّ لَہُ الْفِدَائُ مَا قَالَ اللَّہُ: { إلاَّ أَنْ یَخَافَا أَلاَّ یُقِیمَا حُدُودَ اللہِ } وَلَمْ یَکُنْ یَقُولُ قَوْلَ السُّفَہَائِ : حَتَّی تَقُولَ : لاَ أَغْتَسِلُ لَکَ مِنْ جَنَابَۃٍ ، وَلَکِنَّہُ کَانَ یَقُولُ: { إلاَّ أَنْ یَخَافَا أَلاَّ یُقِیمَا حُدُودَ اللہِ } فِیمَا افْتَرَضَ لِکُلِّ وَاحِدٍ مِنْہُمَا عَلَی صَاحِبِہِ ، فِی الْعِشْرَۃِ وَالصُّحْبَۃِ۔",,,18738,,
18739,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ قَالَ : سَأَلْتُ الْحَکَمَ عَنْ قَوْلِ الْمَرْأَۃِ لِزَوْجِہَا ، لاَ أَغْتَسِلُ لَکَ مِنْ جَنَابَۃٍ ، وَلاَ أَبَرُّ لَکَ قَسَمًا ، وَلاَ أُطِیعُ لَکَ أَمْرًا ؟ قَالَ : لَیْسَ بِشَیْئٍ ، یُمْسِکُہَا۔",,,18739,,
18740,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، قَالَ : سُئِلَ الْقَاسِمُ بْنُ مُحَمَّدٍ : {إلاَّ أَنْ یَخَافَا أَلاَّ یُقِیمَا حُدُودَ اللہِ} قَالَ : مَا اُفْتُرِضَ عَلَیْہِمَا فِی الْعِشْرَۃِ وَالصُّحْبَۃِ۔",,,18740,,
18741,"حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنْ أَیُّوبَ، عَنْ کَثِیرٍ، مَوْلَی ابْنِ سَمُرَۃَ؛ أَنَّ عُمَرَ أُتِیَ بِامْرَأَۃٍ نَاشِزٍ، فَقَالَ لِزَوْجِہَا: اِخْلَعْہَا۔",,,18741,,
18742,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، عَنِ الزُّہْرِیِّ ، وَعَطَائٍ ، وَعَمْرِو بْنِ شُعَیْبٍ ، أَنَّہُم قَالُوا : لاَ یَحِلُّ الْخُلْعُ إلاَّ مِنَ النَّاشِزِ۔",,,18742,,
18743,حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ جُمْہَانَ ؛ أَنَّ امْرَأَۃً اخْتَلَعَتْ مِنْ زَوْجِہَا ، فَجَعَلہَا عُثْمَانُ تَطْلِیقَۃً ، وَمَا سَمَّی۔,,,18743,,
18744,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ قَالَ : خَلَعَ جُمْہَانُ الأَسْلَمِیُّ امْرَأَۃً ، ثُمَّ نَدِمَ وَنَدِمَتْ، فَأَتَوْا عُثْمَانَ فَذَکَرُوا ذَلِکَ لَہُ ، قَالَ : فَقَالَ عُثْمَانُ : ہِیَ تَطْلِیقَۃٌ ، إلاَّ أَنْ تَکُونَ سَمَّیْتَ شَیْئًا ، فَہُوَ عَلَی مَا سَمَّیْتَ۔ (شافعی 165۔ بیہقی 316)",,,18744,,
18745,"حَدَّثَنَا حَفْصٌ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، عَنْ جُمْہَانَ ، عَنْ عُثْمَانَ قَالَ : الْخُلْعُ تَطْلِیقَۃٌ۔",,,18745,,
18746,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ ہِشَامٍ قَالَ : کَانَ أَبِی یَجْعَلُ الْخُلْعَ تَطْلِیقَۃً بَائِنَۃً۔",,,18746,,
18747,حَدَّثَنَا وَکِیعٌ ، عَنْ إبْرَاہِیمَ بْنِ یَزِیْدٍ ، عَنْ دَاوُدَ بْنِ أَبِی عَاصِمٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ جَعَلَ الْخُلْعَ تَطْلِیقَۃً۔ (عبدالرزاق 11758),,,18747,,
18748,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ مُبَارَکٍ ، عَنْ یَحْیَی ، عَنْ أَبِی سَلَمَۃَ قَالَ : الْخُلْعُ تَطْلِیقَۃٌ بَائِنَۃٌ۔",,,18748,,
18749,"حَدَّثَنَا وَکِیعٌ ، وَابْنُ عُیَیْنَۃَ ، وَعَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ طَلْحَۃَ ، عَنْ إِبْرَاہِیمَ ، عَن عَبْدِاللہِ قَالَ: لاَ تَکُونُ تَطْلِیقَۃً بَائِنَۃً ، إلاَّ فِی فِدْیَۃٍ ، أَوْ إیلاَئٍ ، إلاَّ أَنَّ عَلِیَّ بْنَ ہَاشِمٍ قَالَ : عَنْ عَلْقَمَۃَ ، عَنْ عَبْدِ اللہِ۔",,,18749,,
18750,"حَدَّثَنَا شَرِیکٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ (ح) وَجَابِرٌ ، عَنْ عَامِرٍ۔ (ح) وَعَطَائٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالُوا : الْخُلْعُ تَطْلِیقَۃٌ بَائِنَۃٌ۔",,,18750,,
18751,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : الْخُلْعُ تَطْلِیقَۃٌ بَائِنَۃٌ ، وَالإِیلاَئُ وَالْمُبَارَأَۃُ کَذَلِکَ۔",,,18751,,
18752,"حَدَّثَنَا عَبَّادٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، وَسَعِیدِ بْنِ الْمُسَیَّبِ۔ (ح)وَیُونُسَ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یَخْلَعُ امْرَأَتَہُ قَالاَ : أَخْذُہُ الْمَالَ تَطْلِیقَۃٌ بَائِنَۃٌ۔",,,18752,,
18753,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ مُوسَی بْنِ مُسْلِمٍ ، عَنْ مُجَاہِدٍ قَالَ : قَالَ عَلِیٌّ : إذَا خَلَعَ الرَّجُلُ أَمْرَ امْرَأَتِہِ مِنْ عُنُقِہِ ، فَہِیَ وَاحِدَۃٌ ، وَإِنِ اخْتَارَتْہُ۔",,,18753,,
18754,"حَدَّثَنَا الْحَسَنُ بْنُ مُوسَی ، عَنْ شَیْبَانَ ، عَنْ یَحْیَی قَالَ : قَالَ قَبِیصَۃُ بْنُ ذُؤَیْبٍ : الْخُلْعُ تَطْلِیقَۃٌ ، إِنْ شَائَتْ تَزَوَّجَتْہُ بِصَدَاقٍ جَدِیدٍ۔",,,18754,,
18755,"حَدَّثَنَا ابْنُ إدْرِیسَ، عَنْ مُطَرِّفٍ، عَنِ الشَّعْبِیِّ قَالَ: کُلُّ خُلْعٍ أُخِذَ عَلَیْہِ فِدَائٌ فَہُوَ طَلاَقٌ، وَہُوَ تَطْلِیقَۃٌ بَائِنَۃٌ۔",,,18755,,
18756,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، عَنْ شُرَیْحٍ قَالَ : کُلُّ خُلْعٍ تَطْلِیقَۃٌ بَائِنَۃٌ۔",,,18756,,
18757,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : الْخُلْعُ تَطْلِیقَۃٌ بَائِنَۃٌ۔",,,18757,,
18758,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ قَالَ : ہُوَ تَطْلِیقَۃٌ بَائِنَۃٌ۔",,,18758,,
18759,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : ہُوَ تَطْلِیقَۃٌ بَائِنَۃٌ۔",,,18759,,
18760,"حَدَّثَنَا عُمَرُ بْنُ ہَارُونَ ، عَنْ ثَوْرٍ ، عَنْ مَیْمُونٍ قَالَ : فِی قِرَائَۃِ أُبَیٍّ : الْخُلْعُ تَطْلِیقَۃٌ بَائِنَۃٌ۔",,,18760,,
18761,"حَدَّثَنَا الثَّقَفِیُّ، عَنْ بُرْدٍ، عَنْ مَکْحُولٍ، قَالَ: کُلُّ مُفْتَدِیَۃٍ أَحَقُّ بِنَفْسِہَا، لاَ تَرْجِعُ إلَی زَوْجِہَا إلاَّ أَنْ تَشَائَ۔",,,18761,,
18762,"حَدَّثَنَا مَخلَد بْنُ یَزِیدَ ، عَنْ سَعِیدِ بْنِ عَبْدِ الْعَزِیزِ ، عَنْ مَکْحُولٍ قَالَ : الْخُلْعُ تَطْلِیقَۃٌ۔",,,18762,,
18763,حَدَّثَنَا حَفْصٌ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ؛ أَنَّ عُثْمَانَ بْنَ عَفَّانَ جَعَلَ الْخُلْعَ تَطْلِیقَۃً بَائِنَۃً۔,,,18763,,
18764,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنْ یَحْیَی ، عَنْ أَبِی سَلَمَۃَ ؛ أَنَّہُ کَانَ یَقُولُ : الْخُلْعُ تَطْلِیقَۃٌ بَائِنَۃٌ۔",,,18764,,
18765,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : الْخُلْعُ تَطْلِیقَۃٌ بَائِنَۃٌ ، وَمَا اشْتَرَطَتْ عَلَیْہِ مِنَ الطَّلاَقِ فَہُوَ لَہَا۔",,,18765,,
18766,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ طَاوُوسٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إنَّمَا ہُوَ فُرْقَۃٌ وَفَسْخٌ ، لَیْسَ بِطَلاَقٍ ، ذَکَرَ اللَّہُ الطَّلاَقَ فِی أَوَّلِ الآیَۃِ ، وَفِی آخِرِہَا ، وَالْخُلْعَ بَیْنَ ذَلِکَ ، فَلَیْسَ بِطَلاَقٍ قَالَ اللہ : {الطَّلاَقُ مَرَّتَانِ فَإِمْسَاکٌ بِمَعْرُوفٍ ، أَوْ تَسْرِیحٌ بِإِحْسَانٍ} ۔",,,18766,,
18767,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدِ بْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ (ح) وَعَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ قَالاَ : عِدَّۃُ الْمُخْتَلِعَۃِ عِدَّۃُ الْمُطَلَّقَۃِ۔",,,18767,,
18768,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، قَالَ : کَانَ أَبِی یَقُولُ : تَعْتَدُّ ثَلاَثَ حِیَضٍ ، وَہُوَ أَوْلَی بِخِطْبَتِہَا فِی الْعِدَّۃِ۔",,,18768,,
18769,"حَدَّثَنَا جَرِیرٌ ، وَہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کُلُّ فُرْقَۃٍ کَانَتْ بَیْنَ الرَّجُلِ وَالْمَرْأَۃِ ، فَعِدَّتُہَا عِدَّۃُ الْمُطَلَّقَۃِ۔",,,18769,,
18770,حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَقُولُہُ۔,,,18770,,
18771,"حَدَّثَنَا عَبْدُ الْوَہَّابِ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ سَالِمٍ ، قَالَ : عِدَّتُہَا ثَلاَثَ حِیَضٍ۔",,,18771,,
18772,"حَدَّثَنَا وَکِیعٌ ، وَہُشَیْمٌ ، عَنْ مَالِکِ بْنِ مِغْوَلٍ ، عَنِ الشَّعْبِیِّ قَالَ : عِدَّتُہَا ثَلاَثَ قُرُوئٍ۔",,,18772,,
18773,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ عَبْدِ الأَعْلَی ، عَنِ ابْنِ الْحَنَفِیَّۃِ ، عَنْ عَلِیٍّ ، قَالَ : عِدَّۃُ الْمُخْتَلِعَۃِ ، عِدَّۃُ الْمُطَلَّقَۃِ۔",,,18773,,
18774,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ ہِشَامٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدٍ ، وَأَبِی عِیَاضٍ ، وَخِلاَسٍ ، قَالُوا : عِدَّۃُ الْمُخْتَلِعَۃِ عِدَّۃُ الْمُطَلَّقَۃِ ، وَعِدَّۃُ الْمُلاَعَنَۃ عِدَّۃُ الْمُطَلَّقَۃِ۔",,,18774,,
18775,"حَدَّثَنَا شَبَابَۃُ ، عَنْ مَالِکِ بْنِ أَنَسٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیِّبِ ، وَسُلَیْمَانَ بْنِ یَسَارٍ ، وَغَیْرِہِم ، أَنَّہُمْ کَانُوا یَقُولُونَ : عِدَّۃُ الْمُخْتَلِعَۃِ عِدَّۃُ الْمُطَلَّقَۃِ : ثَلاَثَۃُ قُرُوئٍ۔",,,18775,,
18776,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ حَجَّاجٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، عَنْ عُثْمَانَ ؛ أَنَّہُ قَالَ : عِدَّۃُ الْمُخْتَلِعَۃِ حَیْضَۃٌ۔",,,18776,,
18777,"حَدَّثَنَا عَبْدَۃُ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : عِدَّۃُ الْمُخْتَلِعَۃِ حَیْضَۃٌ۔",,,18777,,
18778,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ الرُّبَیِّعَ اخْتَلَعَتْ مِنْ زَوْجِہَا ، فَأَتَی عَمُّہَا عُثْمَانَ فَقَالَ : تَعْتَدُّ بِحَیْضَۃٍ ؟ قَالَ : تَعْتَدُّ بِحَیْضَۃٍ ، وَکَانَ ابْنُ عُمَرَ یَقُولُ : تَعْتَدُّ ثَلاَثَ حِیَضٍ ، حَتَّی قَالَ ہَذَا عُثْمَانُ ، فَکَانَ یُفْتِی بِہِ وَیَقُولُ : خَیْرُنَا وَأَعْلَمُنَا۔",,,18778,,
18779,"حَدَّثَنَا مُحَمَّدُ بْنُ سَوَائٍ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ أَبِی الطُّفَیْلِ سَعِیدِ بْنِ حَمَلٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : عِدَّۃُ الْمُخْتَلِعَۃِ حَیْضَۃٌ ، قَضَاہَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی جَمِیلَۃَ ابِنْۃِ سَلُولٍ۔\n\n(ابوداؤد 2206۔ عبدالرزاق 11858)",,,18779,,
18780,"حَدَّثَنَا عَبْدُالرَّحْمَنِ بْنُ مُحَمَّدٍ الْمُحَارِبِیِّ، عَنْ لَیْثٍ، عَنْ طَاوُوسٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: عِدَّتُہَا حَیْضَۃٌ۔",,,18780,,
18781,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ ، مَوْلَی آلِ طَلْحَۃَ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ ؛ أَنَّ الرُّبَیِّعَ اخْتَلَعَتْ فَأُمِرَتْ بِحَیْضَۃٍ۔,,,18781,,
18782,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ مُطَرِّفٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : الْمُخْتَلِعَۃِ تَعْتَدُّ فِی بَیْتِ زَوْجِہَا ، لأَنَّہُ إِنْ شَائَ رَاجَعَہَا۔",,,18782,,
18783,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ الرُّبَیِّعَ اخْتَلَعَتْ مِنْ زَوْجِہَا ، فَأَتَی مُعَوِّذٌ عُثْمَانَ فَسَأَلَہُ فَقَالَ : أَتَنْتَقِلُ ؟ قَالَ : نَعَمْ ، تَنْتَقِلُ۔",,,18783,,
18784,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ خَیْثَمَۃَ ، قَالَ : أُتِیَ بِشر بْنُ مَرْوَانَ فِی خُلْعٍ کَانَ بَیْنَ رَجُلٍ وَامْرَأَۃٍ ، فَلَمْ یُجِزْہُ ، فَقَالَ لَہُ عَبْدُ اللہِ بْنُ شِہَابٍ الْخَوْلاَنِیُّ : شَہِدْتُ عُمَرَ بْنَ الْخَطَّابِ أُتِیَ فِی خُلْعٍ کَانَ بَیْنَ رَجُلٍ وَامْرَأَتِہِ ، فَأَجَازَہُ۔",,,18784,,
18785,حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنِ الشَّعْبِیِّ ؛ أَنَّ شُرَیْحًا أَجَازَ خُلْعًا دُونَ السُّلْطَانِ۔,,,18785,,
18786,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، عَنِ الرُّبَیِّعِ بِنْتِ مُعَوِّذِ ابْنِ عَفْرَائَ ؛ أَنَّ عَمَّہَا خَلَعَہَا مِنْ زَوْجِہَا ، وَکَانَ یَشْرَبُ الْخَمْرَ ، دُونَ عُثْمَانَ ، فَأَجَازَ ذَلِکَ عُثْمَانُ۔,,,18786,,
18787,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : الْخُلْعُ جَائِزٌ دُونُ السُّلْطَانِ۔",,,18787,,
18788,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ؛ أَنَّہُ قَالَ : الْخُلْعُ جَائِزٌ دُونَ السُّلْطَانِ۔",,,18788,,
18789,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، سَمِعَہُ یَقُولُ : کَانُوا یَخْتَلِعُونَ عِنْدَنَا دُونَ السُّلْطَانِ ، فَإِذَا رُفِعَ إلَی السُّلْطَانِ أَجَازَہُ۔",,,18789,,
18790,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ قَالَ : ہُوَ عِنْدَ السُّلْطَانِ۔",,,18790,,
18791,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ فِی الْمُخْتَلِعَۃِ قَالَ : إِنْ کَانَتْ نَاشِزًا ، أَمَرَہُ السُّلْطَانُ أَنْ یَخْلَعَ۔",,,18791,,
18792,"حَدَّثَنَا وَکِیعُ بْنُ الْجَرَّاحِ ، عَنْ عَلِیِّ بْنِ الْمُبَارَکِ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، قَالَ : کَانَ عِمْرَانُ بْنُ حُصَیْنٍ ، وَابْنُ مَسْعُودٍ یَقُولاَنِ فِی الَّتِی تَفْتَدِی مِنْ زَوْجِہَا : لَہَا طَلاَقٌ مَا کَانَتْ فِی عِدَّتِہَا۔",,,18792,,
18793,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی فَضَالَۃَ ، عَنْ عَلِیِّ بْنِ أَبِی طَلَحْۃَ ، عَنْ أَبِی عَوْنٍ الأَعْوَرِ ، عَنْ أَبِی الدَّرْدَائِ ، قَالَ : لِلْمُخْتَلِعَۃِ طَلاَقٌ مَا دَامَتْ فِی الْعِدَّۃِ۔",,,18793,,
18794,"حَدَّثَنَا عَبْدُ اللہِ بْنُ مُبَارَکٍ ، عَنِ الْحَسَنِ بْنِ یَحْیَی ، عَنِ الضَّحَّاکِ ، قَالَ : اخْتَلَفَ ابْنُ مَسْعُودٍ ، وَابْنُ عَبَّاسٍ فِی الرَّجُلِ یَخْلَعُ امْرَأَتَہُ ثُمَّ یُطَلِّقُہَا ، قَالَ أَحَدُہُمَا : لَیْسَ طَلاَقُہُ بِشَیْئٍ ، وَقَالَ الآخَرُ : مَا دَامَتْ فِی الْعِدَّۃِ فَإِنَّ الطَّلاَقَ یَلْحَقُہَا۔",,,18794,,
18795,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ مَعْمَرٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : یَلْحَقُہَا الطَّلاَقُ۔",,,18795,,
18796,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : یَجْرِی عَلَیْہَا الطَّلاَقُ مَا کَانَتْ فِی الْعِدَّۃِ۔",,,18796,,
18797,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ فِی الرَّجُلِ یَخْلَعُ امْرَأَتَہُ ثُمَّ یُطَلِّقُہَا ، قَالَ : أَخْذُہُ الْمَالَ تَطْلِیقَۃٌ ، وَکَلاَمُہُ بِالطَّلاَقِ تَطْلِیقَۃٌ۔",,,18797,,
18798,"حَدَّثَنَا عَبْدُ الأَعْلَی بْنُ عَبْدِ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، وَخِلاَسٍ قَالاَ : یَلْحَقُہَا الطَّلاَقُ مَا کَانَتْ فِی الْعِدَّۃِ۔",,,18798,,
18799,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ قَالَ : الْخُلْعُ تَطْلِیقَۃٌ بَائِنٌ ، وَمَا أَتْبَعَ مِنَ الطَّلاَقِ ، فَإِنَّہُ یَلْحَقُہَا مَا کَانَتْ فِی الْعِدَّۃِ۔",,,18799,,
18800,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنِ الشَّعْبِیِّ ، عَنْ مَسْرُوقٍ ؛ فِی الرَّجُلِ یَخْلَعُ امْرَأَتَہُ ثُمَّ یُطَلِّقُہَا ، قَالَ : ذَلِکَ أَبْعَدُ لَہُ مِنْہَا۔",,,18800,,
18801,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ، عَنْ إسْمَاعِیلَ، عَنِ الشَّعْبِیِّ، عَنْ شُرَیْحٍ، قَالَ: یَلْزَمُ الْمُطَلَّقَۃَ الطَّلاَقُ فِی الْعِدَّۃِ۔",,,18801,,
18802,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، وَمُغِیرَۃَ ، عَنْ إبْرَاہِیمَ (ح) وَعَنْ بَیَانٍ ، عَنِ الشَّعْبِیِّ ؛ فِی الْمَرْأَۃِ تُبَارِئُ زَوْجَہَا فَیُطَلِّقُہَا ، قَالاَ : یَقَعُ عَلَیْہَا مَا کَانَتْ فِی عِدَّتِہَا ۔ قَالَ سُفْیَانُ : نَرَی أَنَّہُ یَقَعُ۔",,,18802,,
18803,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، عَنْ عَطَائٍ ؛ فِی الْمُخْتَلِعَۃِ ، قَالَ : یَلْحَقُہَا الطَّلاَقُ۔",,,18803,,
18804,"حَدَّثَنَا ابْنُ الْمُبَارَکِ، عَنِ ابْنِ جُرَیْجٍ، عَنْ عَطَائٍ، عَنِ ابْنِ عَبَّاسٍ، وَابْنِ الزُّبَیْرِ ؛ أَنَّہُمَا قَالاَ : لَیْسَ بِشَیْئٍ۔",,,18804,,
18805,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مَنْصُورٍ ، عَنْ عَمْرِو بْنِ ہَرِمٍ ، عَنْ جَابِرِ بْنِ زَیْدٍ ؛ أَنَّہُ کَانَ یَقُولُ : لاَ یَلْحَقُہَا طَلاَقُہُ إیَّاہَا ، مَا کَانَتْ فِی عِدَّۃٍ مِنْہُ بَائِنَۃً۔",,,18805,,
18806,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، وَمَنْصُورٍ ، عَنِ الْحَسَنِ ، وَحَجَّاجٍ ، عَنْ عَطَائٍ ؛ فِی الْمُخْتَلِعَۃِ : لاَ یَقَعُ عَلَیْہَا طَلاَقُ زَوْجِہَا مَا کَانَتْ فِی عِدَّۃٍ مِنْہُ بَائِنَۃً۔",,,18806,,
18807,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَسَنٍ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ قَالَ : لاَ یَقَعُ عَلَیْہَا الطَّلاَقُ مَا کَانَتْ فِی الْعِدَّۃ۔",,,18807,,
18808,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنِ الْحَسَنِ ، عَنْ لَیْثٍ ، عَنِ الشَّعْبِیِّ ، وَطَاوُوسٍ قَالاَ : إذَا خَلَعَ ثُمَّ طَلَّقَ ، لَمْ یَقَعْ طَلاَقُہُ۔",,,18808,,
18809,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ مَطَرٍ ، عَنْ عِکْرِمَۃَ ؛ أَنَّ الْمُخْتَلِعَۃَ لاَ یَلْحَقُہَا الطَّلاَقُ فِی عِدَّتِہَا۔,,,18809,,
18810,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ مُبَارَکٍ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ أَبِی سَلَمَۃَ ، وَابْنِ ثَوْبَانَ ، قَالاَ : إِنْ طَلَّقَہَا فِی مَجْلِسِہِ لَزِمَہُ ، وَإِلاَّ فَلاَ۔",,,18810,,
18811,"حَدَّثَنَا یَحْیَی بْنُ زَکَرِیَّا بْنِ أَبِی زَائِدَۃَ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ إبْرَاہِیمَ ، قَالَ : لِلْمُخْتَلِعَۃِ السُّکْنَی وَالنَّفَقَۃُ۔",,,18811,,
18812,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَن ، عَنْ مُطَرِّفٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : لِلْمُخْتَلِعَۃِ السُّکْنَی وَالنَّفَقَۃُ ، لأَنَّہَا لَوْ شَائَتْ تَزَوَّجَتْ زَوْجَہَا فِی عِدَّتِہِا تَزَوَّجَتْہُ۔",,,18812,,
18813,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَمَّادٍ ، قَالَ : الْمُخْتَلِعَۃِ لَہَا النَّفَقَۃُ۔",,,18813,,
18814,"حَدَّثَنَا وَکِیعٌ ، وَعَبْدَۃُ ، عَنْ إسْمَاعِیلَ ، عَنْ إبْرَاہِیمَ الْبَصْرِیَّ ، عَنِ الشَّعْبِیِّ ؛ سُئِلَ عَنِ الْمُخْتَلِعَۃِ : لَہَا نَفَقَۃٌ ؟ فَقَالَ : کَیْفَ یُنْفِقُ عَلَیْہَا وَہُوَ یَأْخُذُ مِنْہَا ؟۔",,,18814,,
18815,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَقُولُ : لَیْسَ لِلْمُخْتَلِعَۃِ وَلاَ لِلْمُطَلَّقَۃِ ثَلاَثًا سُکْنَی وَلاَ نَفَقَۃٌ۔",,,18815,,
18816,"حَدَّثَنَا مُحَمَّدُ بْنُ یَزِید ، عَنْ أَبِی الْعَلاَئِ ، عَنْ قَتَادَۃَ ، قَالَ : لَیْسَ لِلْمُخْتَلِعَۃِ وَالْمُبَارِئَۃِ نَفَقَۃٌ۔",,,18816,,
18817,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : لِلْمُمَلَّکَۃِ ، وَالْمُخَیِّرۃ ،وَالْمُخْتَلِعَۃِ ، مُتْعَۃٌ۔",,,18817,,
18818,"حَدَّثَنَا عَبْدُ الرَّزَّاقِ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : لِلْمُخْتَلِعَۃِ مُتْعَۃٌ۔",,,18818,,
18819,"حَدَّثَنَا ابْنُ فُضَیْلٍ، عَنْ مُطَرِّفٍ، عَنِ الشَّعْبِیِّ، قَالَ: لَیْسَ لِلْمُخْتَلِعَۃِ مُتْعَۃٌ، کَیْفَ یُمَتِّعُہَا وَہُوَ یَأْخُذُ مِنْہَا؟",,,18819,,
18820,"حَدَّثَنَا عَبْدُ الْوَہَّابِ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، قَالَ : لِکُلِّ مُطَلَّقَۃٍ مَتَاعٌ ، إلاَّ الْمُخْتَلِعَۃَ۔",,,18820,,
18821,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ، عَنْ شَرِیکٍ، عَنْ لَیْثٍ، عَنْ طَاوُوسٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: لَیْسَ لِلْمُخْتَلِعَۃِ مُتْعَۃٌ۔",,,18821,,
18822,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ حَبیب بْنِ مِہْرَانَ التَّیمِیِّ ، قَالَ : سَأَلْتُ عَبْدَ اللہِ بْنَ أَبِی أَوْفَی عَنِ امْرَأَۃٍ اخْتَلَعَتْ مِنْ زَوْجِہَا بِبَقِیَّۃِ مَہْرٍ کَانَ لَہَا عَلَیْہِ ، فَہَلْ لَہُمَا أَنْ یَتَرَاجَعَا ؟ قَالَ : نَعَمْ ، إِنْ لَمْ یَکُنْ ذَکَرَ فِیہَا طَلاَقًا بِمَہْرٍ جَدِیدٍ ، قَالَ : وَسَأَلْتُ مَاہَانَ ؟ فَقَالَ : نَعَمْ ، وَلَوْ بِکُوزٍ مِنَ الْمَائِ۔",,,18822,,
18823,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ عَامِرٍ ، وَعَنْ إبْرَاہِیمَ ، قَالاَ : إذَا طَلَّقَ الرَّجُلُ امْرَأَتَہُ وَاحِدَۃً عَلَی جُعْلٍ ، فَلاَ یَمْلِکُ الرَّجْعَۃَ وَہُوَ خَاطِبٌ مِنَ الْخُطَّابِ۔",,,18823,,
18824,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ ہِشَامٍ ، قَالَ : کَانَ أَبِی یَقُولُ : صَاحِبُہَا أَوْلیَ بِخِطْبَتِہَا فِی الْعِدَّۃِ",,,18824,,
18825,"حَدَّثَنَا عَبدَۃ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا خَلَعَہَا ثُمَّ نَدِمَا وَہِیَ فِی عِدَّتِہَا ، لَمْ تَرْجِعْ إلَیْہِ ، إلاَّ بِخِطْبَۃٍ۔",,,18825,,
18826,"حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : لاَ یَتَزَوَّجُہَا بِأَقَلَّ مِمَّا أَخَذَ مِنْہَا۔",,,18826,,
18827,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، قَالَ : سَمِعْتُ مَیْمُونَ بْنَ مِہْرَانَ یَقُولُ فِی الْمُخْتَلِعَۃِ : إذَا قَبِلَ مِنْہَا زَوْجُہَا الْفِدْیَۃَ ، ثُمَّ خَطَبَہَا بَعْدَ ذَلِکَ قَالَ : یَتَزَوَّجُہَا وَیُسَمِّی لَہَا مَہْرًا جَدِیدًا۔",,,18827,,
18828,"حَدَّثَنَا إبْرَاہِیمُ بْنُ صَدَقَۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی الْمُخْتَلِعَۃِ إذَا أَرَادَ زَوْجُہَا مُرَاجَعَتَہَا ، قَالَ : یَخْطُبُہَا بِمَہْرٍ جَدِیدٍ۔ (دارقطنی 276۔ بیہقی 314)",,,18828,,
18829,"حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ أَنَّ امْرَأَۃً أَتَتِ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ تَشْکُو زَوْجَہَا ، قَالَ : تَرُدِّینَ عَلَیْہِ مَا أَخَذْتِ مِنْہُ ؟ قَالَتْ : نَعَمْ ، وَأَزِیدُہُ ، قَالَ : أَمَّا زِیَادَۃً فَلاَ۔",,,18829,,
18830,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنِ الْحَکَمِ ، عَنْ عَلِیٍّ ، قَالَ : لاَ یَأْخُذُ مِنْہَا أَکْثَرَ مِمَّا أَعْطَاہَا۔",,,18830,,
18831,حَدَّثَنَا ابن إدْرِیسُ ، عَنْ لَیْثٍ ، عَنِ الْحَکَمِ ، عَنْ عَلِیٍّ ؛ مِثْلَہُ۔,,,18831,,
18832,"حَدَّثَنَا عَبْدُ الرَّزَّاقِ، عَنْ مَعْمَرٍ، عَنِ ابْنِ طَاوُوسٍ، عَنْ أَبِیہِ قَالَ: لاَ یَحِلُّ لَہُ أَنْ یَأْخُذَ مِنْہَا أَکْثَرَ مِمَّا أَعْطَاہَا۔",,,18832,,
18833,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ یَحْیَی بْنِ بِشْرٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : لاَ یَأْخُذُ مِنْہَا أَکْثَرَ مِمَّا أَعْطَاہَا ، فَإِنَّ أَخْذ رَدَّ عَلَیْہا۔",,,18833,,
18834,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حُمَیْدٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَرِہَ أَنْ یَأْخُذَ مِنْہَا أَکْثَرَ مِمَّا أَعْطَاہَا۔,,,18834,,
18835,"حَدَّثَنَا مُحَمَّدُ بْنُ یَزِیدَ ، عَنْ سُفْیَانَ بْنِ حُسَیْنٍ ، عَنِ الزُّہْرِیِّ ، وَالْحَسَنِ قَالاَ : لاَ یَأْخُذُ مِنْہَا أَکْثَرَ مِمَّا أَعْطَاہَا۔",,,18835,,
18836,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، عَنِ الزُّہْرِیِّ ، وَعَطَائٍ ، وَعَمْرِو بْنِ شُعَیْبٍ قَالُوا : لاَ یَأْخُذُ مِنْہَا زَوْجُہَا إلاَّ مَا أَعْطَاہَا۔",,,18836,,
18837,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی حَصِینٍ ، عَنِ الشَّعْبِیِّ ؛ أَنَّہُ کَرِہَ أَنْ یَأْخُذَ مِنْہَا أَکْثَرَ مِمَّا أَعْطَاہَا۔,,,18837,,
18838,حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ عَبْدِالْکَرِیمِ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ؛ أَنَّہُ کَرِہَ أَنْ یَأْخُذَ أَکْثَرَ مِمَّا أَعْطَاہَا۔,,,18838,,
18839,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ ، وَحَمَّادًا ؟ فَکَرِہَا أَنْ یَأْخُذَ مِنْہَا أَکْثَرَ مِمَّا أَعْطَاہَا۔",,,18839,,
18840,"حَدَّثَنَا عُمَرُ بْنُ أَیُّوبَ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنْ مَیْمُونٍ ، قَالَ : مَنْ خَلَعَ امْرَأَتَہُ فَأَخَذَ مِنْہَا أَکْثَرَ مِمَّا أَعْطَاہَا ، فَلَمْ یُسَرِّحْ بِإِحْسَانٍ۔",,,18840,,
18841,حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی حَنِیفَۃَ ، عَنْ عَمَّارِ بْنِ عِمْرَانَ الْہَمْدَانِیِّ ، عَنْ أَبِیہِ ، عَنْ عَلِیٍّ ؛ أَنَّہُ کَرِہَ أَنْ یَأْخُذَ مِنْہَا أَکْثَرَ مِمَّا أَعْطَاہَا۔,,,18841,,
18842,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حُمَیْدٍ ، عَنْ رَجَائِ بْنِ حَیْوَۃَ ؛ أَنَّہُ سَأَلَہُ : کَیْفَ کَانَ الْحَسَنُ یَقُولُ فِی الْمُخْتَلِعَۃِ ؟ فَقَالَ : إنَّہُ کَانَ یَکْرَہُ أَنْ یَأْخُذَ مِنْہَا فَوْقَ مَا أَعْطَاہَا ، فَقَالَ رَجَائٌ : قَالَ قَبِیصَۃُ بْنُ ذُؤَیْبٍ : اقْرَاِ الآیَۃَ الَّتِی بَعْدَہَا : {فَإِنْ خِفْتُمْ أَنْ لاَّ یُقِیمَا حُدُودَ اللہِ فَلاَ جُنَاحَ عَلَیْہِمَا فِیمَا افْتَدَتْ بِہِ}۔",,,18842,,
18843,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ کَثِیرٍ ، مَوْلَی ابْنِ سَمُرَۃَ ؛ أَنَّ عُمَرَ أُتِیَ بِامْرَأَۃٍ نَاشِزٍ ، فَأَمَرَ بِہَا إلَی بَیْتٍ کَثِیرِ الزِّبْلِ ثَلاَثَاً ، ثُمَّ دَعَاہَا ، فَقَالَ : کَیْفَ وَجَدْتِ ؟ فَقَالَتْ : مَا وَجَدْتُ رَاحَۃً مُذْ کُنْتُ عِنْدَہُ ، إلاَّ ہَذِہِ اللَّیَالِیَ الَّتِی حُبِسْتُہَا ، قَالَ : اخْلَعْہَا وَلَوْ مِنْ قُرْطِہَا۔",,,18843,,
18844,"حَدَّثَنَا عَفَّانُ بْنُ مُسْلِمٍ ، قَالَ : حدَّثَنَا ہَمَّامٌ ، قَالَ : حَدَّثَنَا مَطَرٌ ، عَنْ ثَابِتٍ ، عَنْ عَبْدِ اللہِ بْنِ رَبَاحٍ ؛ أَنَّ عُمَرَ قَالَ : اخْلَعْہَا بِمَا دُونَ عِقَاصِہَا۔",,,18844,,
18845,حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ؛ أَنَّ مَوْلاَۃً لِصَفِیَّۃَ بِنْتِ أَبِی عُبَیْدٍ اخْتَلَعَتْ مِنْ زَوْجِہَا بِکُلِّ شَیْئٍ لَہَا ، حَتَّی اخْتَلَعَتْ بِبَعْضِ ثِیَابِہَا ، فَبَلَغَ ذَلِکَ ابْنَ عُمَرَ فَلَمْ یُنْکِرْہُ۔,,,18845,,
18846,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنْ عَمْرٍو ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : تَخْتَلِعُ حَتَّی بِعِقَاصِہَا۔",,,18846,,
18847,حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ؛ مِثْلَہُ۔,,,18847,,
18848,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ إبْرَاہِیمَ ، قَالَ : یَأْخُذُ مِنْہَا حَتَّی عِقَاصِہَا۔",,,18848,,
18849,"حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ ، قَالَ : لاَ بَأْسَ أَنْ تَخْتَلِعَ الْمَرْأَۃُ مِنْ زَوْجِہَا ، وَإِنْ کَانَ أَکْثَرَ مِمَّا أَعْطَاہَا۔",,,18849,,
18850,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ؛ فِی رَجُلٍ بَانَتْ مِنْہُ امْرَأَتُہُ بِخُلْعٍ ، أَوْ إیلاَئٍ ، فَتَزَوَّجَہَا ، ثُمَّ طَلَّقَہَا قَبْلَ أَنْ یَدْخُلَ بِہَا ، قَالَ : لَہَا الصَّدَاقُ کَامِلاً۔",,,18850,,
18851,"حَدَّثَنَا یَحْیَی بْنُ زَکَرِیَّا بْنِ أَبِی زَائِدَۃَ ، عَنْ إسْمَاعِیلَ ، وَأَشْعَثَ ، عَنِ الشَّعْبِیِّ ؛ فِی الرَّجُلِ یُطَلِّقُ امْرَأَتَہُ تَطْلِیقَۃً بَائِنَۃً ، ثُمَّ یَتَزَوَّجُہَا فِی عِدَّتِہَا ، ثُمَّ یُطَلِّقُہَا قَبْلَ أَنْ یَدْخُلَ بِہَا ، قَالَ : لَہَا الصَّدَاقُ ، وَعَلَیْہَا عِدَّۃٌ مُسْتَقْبَلَۃٌ۔",,,18851,,
18852,"حَدَّثَنَا ابْنُ أَبِی زَائِدَۃَ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ؛ مِثْلَہُ ، وَقَالَ : وَہُوَ أَمْلَکُ بِرَجْعَتِہَا۔",,,18852,,
18853,حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ إبْرَاہِیمَ ؛ لَہَا الصَّدَاقُ کَامِلاً ، وَعَلَیْہَا الْعِدَّۃُ کَامِلَۃً۔,,,18853,,
18854,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ دَاوُدَ بْنِ أَبِی ہِنْدٍ ، عَنِ الشَّعْبِیِّ ؛ فِی الْمَرْأَۃِ تَبِینُ مِنْ زَوْجِہَا بِتَطْلِیقَۃٍ ، أَوْ تَطْلِیقَتَیْنِ ، ثُمَّ یَتَزَوَّجُہَا ، ثُمَّ یُطَلِّقُہَا قَبْلَ أَنْ یَدْخُلَ بِہَا ، قَالَ : لَہَا نِصْفُ الصَّدَاقِ۔",,,18854,,
18855,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ سُئِلَ عَنْ رَجُلٍ آلَی مِنِ امْرَأَتِہِ فَبَانَتْ مِنْہُ ، ثُمَّ تَزَوَّجَہَا فِی عِدَّتِہَا ، ثُمَّ طَلَّقَہَا قَبْلَ أَنْ یَدْخُلَ بِہَا ؟ قَالَ : لَہَا نِصْفُ الصَّدَاقِ ، وَلَیْسَ عَلَیْہَا عِدَّۃٌ۔",,,18855,,
18856,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ، وَمُحَمَّدُ بْنُ سَوَائٍ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ عِکْرِمَۃَ ، وَالْحَسَنِ، قَالاَ : إذَا خَلَعَہَا ثُمَّ تَزَوَّجَہَا فِی عِدَّتِہَا ، ثُمَّ طَلَّقَہَا قَبْلَ أَنْ یَدْخُلَ بِہَا ، فَلَہَا نِصْفُ الصَّدَاقِ ، وَتُکْمِلُ مَا بَقِیَ عَلَیْہَا مِنَ الْعِدَّۃِ۔",,,18856,,
18857,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَسَنٍ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ : لَہَا نِصْفُ الصَّدَاقِ۔",,,18857,,
18858,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرٍ ، عَنْ مَیْمُونٍ ؛ فِی الْمُخْتَلِعَۃِ إذَا قَبِلَ مِنْہَا زَوْجُہَا الْفِدْیَۃَ ، ثُمَّ خَطَبَہَا بَعْدَ ذَلِکَ ، قَالَ : یَتَزَوَّجُہَا وَیُسَمِّی لَہَا صَدَاقًا ، فَإِنْ طَلَّقَہَا قَبْلَ أَنْ یَدْخُلَ بِہَا ، فَلَہَا نِصْفُ الصَّدَاقِ ، قَالَ جَعْفَرٌ : وَکَانَ غَیْرُ مَیْمُونٍ یَقُولُ : لَہَا الصَّدَاقُ کَامِلاً۔",,,18858,,
18859,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنِ الْحَارِثِ الْعُکْلِیِّ ؛ أَنَّہُ قَالَ : إذَا اخْتَلَعَتِ الْمَرْأَۃُ مِنْ زَوْجِہَا وَہُوَ مَرِیضٌ ، ثُمَّ مَاتَ فِی الْعِدَّۃِ ، فَلاَ مِیرَاثَ لَہَا۔",,,18859,,
18860,حدَّثَنَا ہُشَیْمٌ ، عَنْ مُحَمَّدِ بْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ؛ مِثْلُ ذَلِک۔,,,18860,,
18861,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ، عَنِ ابْنِ لَہِیعَۃَ، عَنْ جَعْفَرِ بْنِ رَبِیعَۃَ الْقُرَشِیِّ، عَنْ تَوْبَۃَ بْنِ نَمِرٍ، عَنْ سِمَاک ابْنِ عِمْرَانَ ؛ أَنَّ عَبْدَ الْمَلِکَ سَأَلَ قَبِیصَۃَ عَنِ الْمُخْتَلِعَۃِ یَتَوَارِثَانِ؟ قَالَ: لاَ، ِلأَنَّہَا افْتَدَتْ بِمَالِہَا طَیِّبۃً بِہِ نَفْسُہَا۔",,,18861,,
18862,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ مَعْمَرٍ ، عَنْ عَطَائٍ الْخُرَاسَانِیِّ ، عَنْ أَبِی سَلَمَۃَ ؛ أَنَّ عُثْمَانَ بْنَ عَفَّانَ ، وَزَیْدَ بْنَ ثَابِتٍ قَالاَ فِی الإِیلاَئِ : إذَا مَضَتْ أَرْبَعَۃُ أَشْہُرٍ فَہِیَ تَطْلِیقَۃٌ ، وَہِیَ أَمْلَکُ بِنَفْسِہَا۔",,,18862,,
18863,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ؛ أَنَّ النُّعْمَانَ بْنَ بَشِیرٍ آلَی مِنَ امْرَأَتِہِ ، فَقَالَ ابْنُ مَسْعُودٍ : إذَا مَضَتْ أَرْبَعَۃُ أَشْہُرٍ فَقَدْ بَانَتْ مِنْہُ بِتَطْلِیقَۃٍ۔",,,18863,,
18864,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، عَن عَبْدِ اللہِ قَالَ : إذَا آلَی ، فَمَضَتْ أَرْبَعَۃُ أَشْہُرٍ فَقَدْ بَانَتْ مِنْہُ بِتَطْلِیقَۃٍ۔",,,18864,,
18865,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِِ ، عَنْ حَبِیبٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عُمَرَ ، وَابْنِ عَبَّاسٍ قَالاَ : إذَا آلَی فَلَمْ یَفِیئْ حَتَّی تَمْضِیَ الأَرْبَعَۃُ الأَشْہُرُ فَہِیَ تَطْلِیقَۃٌ بَائِنَۃٌ۔",,,18865,,
18866,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِِ ، عَنْ حَبِیبٍ قَالَ : سَأَلْتُ سَعِیدًا أَمِیرَ مَکَّۃَ عَنِ الإِیلاَئِ ؟ فَقَالَ : کَانَ ابْنُ عَبَّاسٍ یَقُولُ : إذَا مَضَتْ أَرَبَعَۃُ أَشْہُرٍ مَلَکَتْ أَمْرَہَا ، وَکَانَ ابْنُ عُمَرَ یَقُولُ ذَلِکَ۔",,,18866,,
18867,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ مِقْسَمٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : عَزِیمَۃُ الطَّلاَقِ انْقِضَائُ الأَرْبَعَۃِ الأَشْہُرِ ، وَالْفَیْئُ الْجِمَاعُ۔ (بیہقی 379)",,,18867,,
18868,"حَدَّثَنَا حَفْصٌ ، وَیَزِیدُ بْنُ ہَارُونَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، عَنْ عَلِیٍّ قَالَ : إذَا مَضَتْ أَرْبَعَۃُ أَشْہُرٍ فَہِیَ تَطْلِیقَۃٌ بَائِنَۃٌ۔",,,18868,,
18869,"حَدَّثَنَا عَبْدُالأَعْلَی، عَنْ مَعْمَرٍ، عَنِ الزُّہْرِیِّ، عَنْ قَبِیصَۃَ قَالَ: إذَا مَضَتْ أَرْبَعَۃُ أَشْہُرٍ فَہِیَ تَطْلِیقَۃٌ بَائِنَۃٌ۔",,,18869,,
18870,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنْ مِقْسَمٍ ، عَنِ ابْنِ عَبَّاسٍ (ح) وَعَنِ سَالِم ، عَن ابْنِ الْحَنَفِیَّۃِ ، قَالاَ : إذَا مَضَتْ أَرْبَعَۃُ أَشْہُرٍ فَہِیَ تَطْلِیقَۃٌ بَائِنَۃٌ۔",,,18870,,
18871,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنْ إبْرَاہِیمَ قَالَ : إذَا مَضَتْ أَرْبَعَۃُ أَشْہُرٍ فَہِیَ تَطْلِیقَۃٌ بَائِنَۃٌ، وَہِیَ أَمْلَکُ بِنَفْسِہَا۔",,,18871,,
18872,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُجَالِدٍ ، عَنِ الشَّعْبِیِّ ، عَنْ مَسْرُوقٍ قَالَ : إذَا مَضَتْ أَرْبَعَۃُ أَشْہُرٍ فِی الإِیلاَئِ کَانَتْ تَطْلِیقَۃً بَائِنَۃً ، فَأَخْبَرْتُ شُرَیْحًا بِقَوْلِ مَسْرُوقٍ ، فَقَالَ بِہِ۔",,,18872,,
18873,"حَدَّثَنَا وَکِیعٌ ، عَنْ یَزِیدَ بْنِ إبْرَاہِیمَ ، عَنِ الْحَسَنِ ، وَابْنِ سِیرِینَ قَالاَ : إذَا مَضَتْ أَرْبَعَۃُ أَشْہُرٍ فَہِیَ تَطْلِیقَۃٌ بَائِنَۃٌ۔",,,18873,,
18874,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ مَالِکِ بْنِ أَنَسٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، وَأَبِی بَکْرِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ الْحَارِثِ بْنِ ہِشَامٍ ، قَالاَ : إذَا مَضَتْ أَرْبَعَۃُ أَشْہُرٍ فِی الإِیلاَئِ فَہِیَ تَطْلِیقَۃٌ ، وَہُوَ أَحَقُّ بِرَجْعَتِہَا۔",,,18874,,
18875,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ إسْمَاعِیلَ بْنِ أُمَیَّۃَ ، عَنْ مَکْحُولٍ قَالَ : إذَا مَضَتْ أَرْبَعَۃُ أَشْہُرٍ فَہِیَ وَاحِدَۃٌ ، وَہُوَ أَمْلَکُ بِہَا۔",,,18875,,
18876,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، عَنْ عَلْقَمَۃَ قَالَ : آلَی ابْنُ أَنَسٍ مِنَ امْرَأَتِہِ ، فَلَبِثَتْ سِتَّۃَ أَشْہُرٍ ، فَبَیْنَمَا ہُوَ جَالِسٌ فِی الْمَجْلِسِ إذْ ذکر ، فَأَتَی ابْنُ مَسْعُودٍ فَقَالَ : أَعْلِمْہَا أَنَّہَا قَدْ مَلَکَتْ أَمْرَہَا ، فَأَتَاہَا فَأَخْبَرَہَا ، فَقَالَتْ : فَأَنَا أَہْلُکَ ، وَأَصْدَقَہَا رِطْلاً۔",,,18876,,
18877,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ جَرِیرٍ ، قَالَ : قرَأْتُ فِی کِتَابِ أَبِی قِلاَبَۃَ عِنْدَ أَیُّوبَ : سَأَلْتُ أَبَا سَلَمَۃَ ، وَسَالِمًا عَنِ الإِیلاَئِ ؟ فَقَالاَ : إذَا مَضَتْ أَرْبَعَۃُ أَشْہُرٍ فَہِیَ تَطْلِیقَۃٌ۔",,,18877,,
18878,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، عَنْ قَیْسِ بْنِ سَعْدٍ ، عَنْ عَطَائٍ قَالَ : إذَا مَضَتْ أَرْبَعَۃُ أَشْہُرٍ فَہِیَ تَطْلِیقَۃٌ بَائِنَۃٌ ، وَیَخْطُبُہَا زَوْجُہَا فِی عِدَّتِہَا ، وَلاَ یَخْطُبُہَا غَیْرُہُ۔",,,18878,,
18879,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الشَّیْبَانِیِّ ، عَنْ الشَّعْبِیِّ ، عَنْ عَمْرِو بْنِ سَلِمَۃَ بْنِ حَرْبٍ ؛ أَنَّ عَلِیًّا کَانَ یُوقِفُہُ بَعْدَ الأَرْبَعَۃِ حَتَّی یُبَیِّنَ رَجْعَۃً ، أَوْ طَلاَقًا۔,,,18879,,
18880,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الشَّیْبَانِیِّ ، عَنْ بُکَیْرِ بْنِ الأَخْنَسِ ، عَنْ مُجَاہِدٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ؛ أَنَّ عَلِیًّا أَوْقَفَہُ۔,,,18880,,
18881,"حَدَّثَنَا ابْنُ إدْرِیسَ ؛ عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، عَنْ مَرْوَانَ ، عَنْ عَلِیٍّ ، قَالَ : یُوقَفُ عِنْدَ الأَرْبَعَۃِ حَتَّی یُبَیِّنَ طَلاَقًا ، أَوْ رَجْعَۃً۔",,,18881,,
18882,"حَدَّثَنَا شَرِیکٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، عَنْ مَرْوَانَ ، عَنْ عَلِیٍّ قَالَ : أَمَّا أَنَا فَکُنْتُ أُوقِفُہُ بَعْدَ الأَرْبَعَۃِ ، فَإِمَّا أَنْ یَفِیئَ ، وَإِمَّا أَنْ یُطَلِّقَ ، وَقَالَ مَرْوَانُ : لَوْ وُلِّیتُ لَفَعَلْتُ مِثْلَ مَا یَفْعَلُ۔",,,18882,,
18883,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، وَوَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ حَبِیبِ بْنِ أَبِی ثَابِتٍ ، عَنْ طَاوُوسٍ ، عَنْ عُثْمَانَ ؛ أَنَّہُ کَانَ یَقُولُ بِقَوْلِ أَہْلِ الْمَدِینَۃِ : یُوقَفُ۔",,,18883,,
18884,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ أَیُّوبَ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ ؛ أَنَّ مَرْوَانَ أَوْقَفَہُ بَعْدَ سِتَّۃَ أَشْہُرٍ۔,,,18884,,
18885,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ ، عَنْ بِضْعَۃَ عَشَرَ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالُوا : یُوقَفُ۔",,,18885,,
18886,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ أَیُّوبَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ قَالَ : سَأَلْتُ ابْنَ عُمَرَ عَنِ الإِیلاَئِ ؟ فَقَالَ : الأُمَرَائُ یَقْضُونَ فِی ذَلِکَ۔",,,18886,,
18887,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ، عَنِ ابْنِ أَبِی نَجِیحٍ، عَنْ مُجَاہِدٍ (ح) وَعَنِ ابْنِ طَاوُوسٍ عَنْ أَبِیہِ، قالُوا: فِی الإِیلاَئِ یُوقَفُ۔",,,18887,,
18888,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ دَاوُدَ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ؛ فِی الْمُوْلِی : یُوقَفُ۔",,,18888,,
18889,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ قَالَ : لاَ یَحِلُّ لَہُ أَنْ یَفْعَلَ إلاَّ مَا أَمَرَہُ اللَّہُ ، إمَّا أَنْ یَفِیئَ ، وَإِمَّا أَنْ یَعْزِمَ۔",,,18889,,
18890,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَسَنِ بْنِ فُرَاتٍ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، قَالَ : سَمِعْتُ عَائِشَۃَ تَقُولُ : یُوقَفُ الْمُوْلِی۔",,,18890,,
18891,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنِ الشَّعْبِیِّ قَالَ : إذَا آلَی الرَّجُلُ مِنِ امْرَأَتِہِ وُقِفَ قَبْلَ أَنْ تَمْضِیَ الأَرْبَعَۃُ الأَشْہُرِ فَیُقَالُ لَہُ : اتَّقِ اللَّہَ فَإِمَّا أَنْ یَفِیئَ ، وَإِمَّا أَنْ تُطَلِّقَ طَلاَقًا یُعْرَفُ۔",,,18891,,
18892,حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، بِنَحْوِہِ۔,,,18892,,
18893,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ قَالَ : یُوقَفُ الْمُوْلِی عِنْدَ انْقِضَائِ الأَرْبَعَۃِ ، فَإِنْ فَائَ فَہِیَ امْرَأَتُہُ ، وَإِنْ لَمْ یَفِیئْ فَہِیَ تَطْلِیقَۃٌ بَائِنَۃٌ۔",,,18893,,
18894,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ دَاوُدَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : إذَا مَضَتْ أَرْبَعَۃُ أَشْہُرٍ فَإِمَّا أَنْ یَفِیئَ ، وَإِمَّا أَنْ یُطَلِّقَ۔",,,18894,,
18895,"حَدَّثَنَا وَکِیعٌ ، عَنْ فِطَرٍ ، عَنْ مُحَمَّدِ بْنِ کَعْبٍ قَالَ : الإِیلاَئُ لَیْسَ بِشَیْئٍ ، یُوقَفُ۔",,,18895,,
18896,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ حَنْظَلَۃَ ، قَالَ : سَمِعْتُ الْقَاسِمَ بْنَ مُحَمَّدٍ وَسُئِلَ عَنِ الإِیلاَئِ ؟ قَالَ : یُوقَفُ فَیُقَالُ لِلَّذِی یَسْأَلُہُ : ہَلْ طَلَّقْتَ ؟ قَالَ : لاَ ، وَلَکِنْ یَدْعُو الإِمَامُ فَإِمَّا أَنْ یَفِیئَ ، وَإِمَّا أَنْ یُفَارِقَ۔",,,18896,,
18897,حَدَّثَنَا وَکِیعٌ ، عَنْ عِمْرَانَ بْنِ حُدَیْرٍ ، عَنْ أَبِی مِجْلِزٍ ؛ أَنَّہُ کَانَ لاَ یَجْعَلُ فِی الإِیلاَئِ طَلاَقًا۔,,,18897,,
18898,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو قَالَ : سَأَلْتُ سَعِیدَ بْنَ الْمُسَیَّبِ عَنِ الإِیلاَئِ ؟ فَقَالَ : لَیْسَ بِشَیْئٍ۔",,,18898,,
18899,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ أَبَانَ الْعَطَّارِ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ أَبِی الدَّرْدَائِ قَالَ : الإِیلاَئُ مَعْصِیَۃٌ ، وَلاَ تَحْرُم عَلَیْہِ امْرَأَتَہُ۔",,,18899,,
18900,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ جَرِیرِ بْنِ حَازِمٍ قَالَ : قرَأْتُ فِی کِتَابِ أَبِی قِلاَبَۃَ عِنْدَ أَیُّوبَ : سَأَلْتُ عُرْوَۃَ بْنَ الزُّبَیْرِ ، وَسَعِیدَ بْنَ الْمُسَیَّبِ ؟ فَقَالاَ : مَعْصِیَۃٌ ، وَلَیْسَ بِطَلاَقٍ۔",,,18900,,
18901,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنْ مِقْسَمٍ ، عَنِ ابْنِ عَبَّاسٍ (ح) وَعَنْ سَالِمٍ ، عَنِ ابْنِ الْحَنَفِیَّۃِ ، قَالاَ : إذَا مَضَتْ أَرْبَعَۃُ أَشْہُرٍ فِی الإِیلاَئِ فَہِیَ تَطْلِیقَۃٌ بَائِنَۃٌ ، وَعَلَیْہَا أَنْ تَعْتَدَّ ثَلاَثَۃَ قُرُوئٍ۔",,,18901,,
18902,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ عَلِیِّ بْنِ بَذِیمَۃَ ، عَنْ أَبِی عُبَیْدَۃَ ، عَنْ عَبْدِ اللہِ قَالَ : إذَا مَضَتْ أَرْبَعَۃُ أَشْہُرٍ فَہِیَ تَطْلِیقَۃٌ بَائِنٌ ، وَتَعْتَدُّ بَعْدَ ذَلِکَ ثَلاَثَ حِیَضٍ۔",,,18902,,
18903,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ وَمُحَمَّدٍ قَالاَ : تَعْتَدُّ بَعْدَ أَرْبَعَۃِ أَشْہُرٍ عِدَّۃَ الْمُطَلَّقَۃِ۔",,,18903,,
18904,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ وَحَمَّادٍ قَالاَ : إذَا آلَی الرَّجُلُ مِنِ امْرَأَتِہِ فَمَضَتْ أَرْبَعَۃُ أَشْہُرٍ ، فَإِنَّہَا تَعْتَدُّ بَعْدَ ذَلِکَ ثَلاَثَۃَ أَشْہُرٍ ، إذَا کَانَتْ لاَ تَحِیضُ۔",,,18904,,
18905,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ قَالَ : إذَا آلَی الرَّجُلُ مِنِ امْرَأَتِہِ فَمَضَتْ أَرْبَعَۃُ أَشْہُرٍ فَہِیَ تَطْلِیقَۃٌ ، وَتَسْتَقْبِلُ الْعِدَّۃَ۔",,,18905,,
18906,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ جَابِرِ بْنِ زَیْدٍ قَالَ : لَیْسَ عَلَیْہَا عِدَّۃٌ۔",,,18906,,
18907,"حَدَّثَنَا یَعْلَی بْنُ عُبَیْدَ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ فِی رَجُلٍ آلَی مِنِ امْرَأَتِہِ حَتَّی مَضَتْ أَرْبَعَۃُ أَشْہُرٍ کَیْفَ تَعْتَدُّ ؟ قَالَ : تَعْتَدُّ ثَلاَثَۃَ قُرُوئٍ۔",,,18907,,
18908,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ سَعِیدٍ ، عَنْ عَامِرٍ الأَحْوَلِ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ قَالَ : إذَا آلَی مِنِ امْرَأَتِہِ شَہْرًا ، أَوْ شَہْرَیْنِ ، أَوْ ثَلاَثَۃً ، مَا لَمْ یَبْلُغِ الْحَدَّ فَلَیْسَ بِإِیلاَئٍ۔",,,18908,,
18909,"حَدَّثَنَا حَفْصٌ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ قَالَ : إذَا حَلَفَ عَلَی دُونِ الأَرْبَعَۃِ فَلَیْسَ بِإِیلاَئٍ۔",,,18909,,
18910,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، وَعَنْ مُحَمَّدِ بْنِ زَیْدٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ قَالاَ : إذَا حَلَفَ عَلَی دُونِ الأَرْبَعَۃِ فَلَیْسَ بِإِیلاَئٍ۔",,,18910,,
18911,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنِ الشَّعْبِیِّ ؛ فِی رَجُلٍ حَلَفَ أَنْ لاَ یَقْرَبَ امْرَأَتَہُ ثَلاَثَۃَ أَشْہُرٍ ، فَتَرَکَہَا حَتَّی مَضَتْ أَرْبَعَۃُ أَشْہُرٍ ، قَالَ : لاَ یَکُونُ مُولِیًا۔",,,18911,,
18912,حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ وَبَرَۃَ ، عَنْ عَبْدِ اللہِ ؛ أَنَّ رَجُلاً آلَی مِنِ امْرَأَتِہِ عشرًا ، فَأَوْقَعَہُ عَلَیْہِ عَبْدُ اللہِ۔,,,18912,,
18913,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ وَمُحَمَّدٍ قَالاَ : إذَا آلَی الرَّجُلُ مِنِ امْرَأَتِہِ شَہْرًا ، ثُمَّ تَرَکَہَا حَتَّی تَمْضِیَ أَرْبَعَۃُ أَشْہُرٍ ، إنَّہَا تَطْلِیقَۃٌ بَائِنَۃٌ",,,18913,,
18914,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ حَمَّادٍ قَالَ : إذَا قَالَ الرَّجُلُ لامْرَأَتِہِ : وَاللَّہِ لاَ أَقْرَبُک الْیَوْمَ ، فَتَرَکَہَا أَرْبَعَۃَ أَشْہُرٍ فَہُوَ إیلاَئٌ۔",,,18914,,
18915,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : إذَا حَلَفَ عَلَی دُونِ أَرْبَعَۃٍ فَہُوَ مُولٍ۔",,,18915,,
18916,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ؛ فِی الرَّجُلِ یَحْلِفُ أَنْ لاَ یَقْرَبَ امْرَأَتَہُ شَہْرًا قَالَ : ہُوَ مُولٍ۔",,,18916,,
18917,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، عَن أَبِی الشَّعْثَائِ قَالَ : آلَی رَجُلٌ مِنَ الْحَیِّ فَنُفِسَتِ امْرَأَتُہُ قَالَ : فَسَأَلَت عَلْقَمَۃَ وَالأَسْوَدَ وَمَسْرُوقًا فَقَالُوا : إذَا فَائَ بِلِسَانِہِ فَقَدْ فَائَ۔",,,18917,,
18918,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ رَجُلٍ ، عَنْ إبْرَاہِیمَ قَالَ : إذَا آلَی الرَّجُلُ مِنِ امْرَأَتِہِ فَمَنَعَہُ مِنْ جِمَاعِہَا مَرَضٌ ، أَوْ شُغْلٌ ، أَوْ عُذْرٌ مِنْہُ ، أَوْ مِنْہَا ، وَأَشْہَدَ عَلَی فَیْئِہِ أَجْزَأَہُ ذَلِکَ۔",,,18918,,
18919,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ قَالَ : إذَا رَاجَعَ بِلِسَانِہِ فَہِی رَجْعَۃٌ۔",,,18919,,
18920,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ قَالَ فِی الْمُولِی : إذَا کَانَ مَرِیضًا ، أَوْ کَانَ مُسَافِرًا ، أَوْ کَانَتْ حَائِضًا أَشْہَدَ عَلَی فَیْئِہِ۔",,,18920,,
18921,"حَدَّثَنَا عَبْدُ الْوَہَّابِ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، وَعِکْرِمَۃَ قَالاَ : إذَا کَانَ لَہُ عُذْرٌ یُعْذَرُ بِہِ فَأَشْہَدَ أَنَّہُ قَدْ فَائَ إلیہا فَذَلِکَ لَہُ۔",,,18921,,
18922,"حَدَّثَنَا عَبْدَۃُ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ قَالَ : إذَا آلَی الرَّجُلُ مِنَ امْرَأَتِہِ فَأَشْہَدَ أَنَّہُ قَدْ فَائَ فَذَلِکَ لَہُ۔",,,18922,,
18923,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ مُطَرِّفٍ ، عَنِ الشَّعْبِیِّ ، عَنِ ابْنِ عَبَّاسٍ قَالَ : الْفَیْئُ الْجِمَاعُ۔",,,18923,,
18924,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ مِقْسَمٍ ، عَنِ ابْنِ عَبَّاسٍ قَالَ : عَزِیمَۃُ الطَّلاَقِ انْقِضَائُ أَرْبَعَۃِ أَشْہُرٍ وَالْفَیْئُ الْجِمَاعُ۔",,,18924,,
18925,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مَنْصُورٍ ، عَنِ الشَّعْبِیِّ وَالْحَکَمِ قَالاَ : لاَ فَیْئَ إِلاَّ الْجِمَاعُ۔",,,18925,,
18926,"حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ قَالَ : لاَ فَیْئَ إلاَّ الْجِمَاعُ۔",,,18926,,
18927,"حَدَّثَنَا حَفْصٌ ، عَنْ إسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ قَالَ : لاَ فَیْئَ إلاَّ الْجِمَاعُ۔",,,18927,,
18928,"حَدَّثَنَا حَفْصٌ ، عَنْ إسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ قَالَ : الْفَیْئُ الْجِمَاعُ۔",,,18928,,
18929,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَلِیِّ بْنِ بَذِیمَۃَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ قَالَ : الْفَیْئُ الْجِمَاعُ۔",,,18929,,
18930,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ مُحَمَّدِ بْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ، عَنْ عَلِیٍّ ، وَابْنِ مَسْعُودٍ ، وَابْنِ عَبَّاسٍ قَالُوا : الْفَیْئُ الْجِمَاعُ ، وَقَالَ ابْنُ مَسْعُودٍ : فَإِنْ کَانَ بِہِ عِلَّۃٌ مِنْ کِبَرٍ ، أَوْ مَرَضٍ ، أَوْ حَبْسٍ یَحُولُ بَیْنَہُ وَبَیْنَ الْجِمَاعِ ، فَإِنَّ فَیْئِہِ أَنْ یَفِیئَ بِقَلْبِہِ وَلِسَانِہِ۔",,,18930,,
18931,حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ خُصَیْفٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ أَنَّہُ سَأَلَہُ عَنْ رَجُلٍ آلَی مِنَ امْرَأَتِہِ فَقَالَ یَنَالُ مِنْہَا مَا یَنَالُ الرَّجُلُ مِنَ امْرَأَتِہِ إلاَّ أَنَّہ لم یُجَامِعَہَا فَإِنْ مَضَتْ أَرْبَعَۃُ أَشْہُرٍ قَبْلَ أَنْ یُجَامِعَہَا فَہِیَ طَالِقٌ بَائِنٌ۔,,,18931,,
18932,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حُصَیْنٍ ، عَنِ الشَّعْبِیِّ ، عَنْ مَسْرُوقٍ قَالَ : الْفَیْئُ الْجِمَاعُ۔",,,18932,,
18933,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ أَنَّہُ کَانَ یَقُولُ فِی الإِیلاَئِ مِنَ الأَمَۃِ : إذَا مَضَی شَہْرَانِ ، وَلَمْ یَفِیئْ زَوْجُہَا ، فَقَدْ وَقَعَ الإِیلاَئُ۔",,,18933,,
18934,"حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ فِیمَنْ آلَی مِنْ أَمَۃٍ قَالَ : إیلاَؤُہَا شَہْرَانِ۔",,,18934,,
18935,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ قَالَ : إِیلاَئُ الأَمَۃِ نِصْفُ إِیلاَئِ الْحُرَّۃِ۔",,,18935,,
18936,حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، عَنْ إبْرَاہِیمَ مِثْلَہُ۔,,,18936,,
18937,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ فِی الْحُرِّ إذَا آلَی مِنَ الْأَمَۃِ ، أَوْ طَلَّقَہا فَعِدَّتُہَا نِصْفُ عِدَّۃِ الْحُرَّۃِ۔,,,18937,,
18938,"حَدَّثَنَا شَبَابَۃُ قَالَ : حدَّثَنَا شُعْبَۃُ قَالَ : سَأَلْتُ الْحَکَمَ عَمَّنْ یُولِی مِنَ الْأَمَۃِ فَقَالَ : قَالَ إبْرَاہِیمُ : عِدَّتُہَا شَہْرَانِ ، وَسَأَلْت حَمَّادًا فَقَالَ مِثْلَ ذَلِکَ۔",,,18938,,
18939,"حَدَّثَنَا ہُشَیْمٌ، عَنْ مُغِیرَۃَ، عَنْ إبْرَاہِیمَ قَالَ: إذَا آلَی، ثُمَّ طَلَّقَ، أَوْ طَلَّقَ، ثُمَّ آلَی ہَدَمَ الطَّلاَقُ الإِیلاَئَ۔",,,18939,,
18940,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنِ الشَّعْبِیِّ قَالَ : ہُمَا کَفَرَسَیْ رِہَانٍ ، أَیُّہُمَا سَبَقَ أُخِذَتْ بِہِ ، وَإِنْ وَقَعَا جَمِیعًا أُخِذَتْ بِہِما۔",,,18940,,
18941,حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ أَنَّہُ کَانَ یَقُولُ مِثْلَ قَوْلِ الشَّعْبِیِّ۔,,,18941,,
18942,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ ؛ فِی الرَّجُلِ یُولِی مِنِ امْرَأَتِہِ ، ثُمَّ یُطَلِّقُ قَالَ : إذَا مَضَتْ أَرْبَعَۃُ أَشْہُرٍ ، قَبْلَ أَنْ تَحِیضَ ثَلاَثَ حِیَضٍ ، فَقَدْ بَانَتْ۔",,,18942,,
18943,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ قَالَ : یَہْدِمُ الطَّلاَقُ الإِیلاَئَ۔",,,18943,,
18944,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ قَالَ : یَہْدِمُ الطَّلاَقُ الإِیلاَئَ۔",,,18944,,
18945,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَجَّاجٍ ، عَنِ الشَّعْبِیِّ ، عَنْ عَبْدِ اللہِ قَالَ : یَہْدِمُ الطَّلاَقُ الإِیلاَئَ وَقَالَ عَلِیٌّ: ہُمَا کَفَرَسَیْ رِہَانٍ۔",,,18945,,
18946,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرِو بْنِ مُرَّۃَ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ أَبِی عُبَیْدَۃَ ، عَنْ عَبْدِ اللہِ قَالَ : الإِیلاَئُ فِی الرِّضَا وَالْغَضَبِ۔",,,18946,,
18947,"حَدَّثَنَا أَبُو الْأَحْوَصِ ، عَنْ سِمَاکٍ ، عَنْ حُرَیْث بن عَمِیرَۃَ ، عَنْ أُمِّ عَطِیَّۃَ قَالَتْ : قَالَ جُبَیْرٌ لامْرَأَتِہِ : إن ابْنَ أَخِی مَعَ ابْنِکَ ، فَقَالَتْ : مَا أَسْتَطِیعُ أَنْ أُرْضِعَ اثْنَیْنِ ، قَالَ : فَحَلَفَ أَنْ لاَ یَقْرَبَہَا حَتَّی تَفْطِمَہُ قَالَ : فَلَمَّا فَطَمُوہُ مُرَّ بِہِ عَلَی الْمَجْلِسِ فَقَالَ الْقَوْمُ : حَسَنٌ مَا غَذَوْتُمُوہُ قَالَ : فَقَالَ جُبَیْرٌ : إنِّی حَلَفْت أَنْ لاَ أَقْرَبَہَا حَتَّی تَفْطِمَہُ ، قَالَ : فَقَالَ الْقَوْمُ : ہَذَا إیلاَئٌ ، فَقَالَ لَہُ عَلِیٌّ : إِنْ کُنْتَ فَعَلْتَ ذَلِکَ غَضَبًا ، فَلاَ تَحِلُّ لَکَ امْرَأَتُکَ ، وَإِلاَّ فَہِیَ امْرَأَتُکَ۔",,,18947,,
18948,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ زُبَیْدٍ عَمَّنْ حَدَّثَہُ ، عَنْ عَلِیٍّ قَالَ : إنَّمَا الإِیلاَئُ فِی الْغَضَبِ۔",,,18948,,
18949,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ الْقَعْقَاعِ بْنِ یَزِیدَ قَالَ : سَأَلْتُ الْحَسَنَ ، عَنِ الإِیلاَئِ فَقَالَ : إنَّمَا الإِیلاَئُ مَا کَانَ فِی الْغَضَبِ ، قَالَ : وَسَأَلْتُ ابْنَ سِیرِینَ فَقَالَ : مَا أَدْرِی مَا ہَذَا ؟ وَتَلاَ آیَۃَ الإِیلاَئِ۔",,,18949,,
18950,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، وَعَنْ مُطَرِّفٍ ، عَنِ الشَّعْبِیِّ فِی رَجُلٍ حَلَفَ أَلاَّ یَقْرَبُ امْرَأَتَہُ حَتَّی تَفْطِمَ صَبِیَّہَا ، قَالاَ : إذَا مَضَتْ أَرْبَعَۃُ أَشْہُرٍ فَقَدْ دَخَلَ الإِیلاَئُ۔",,,18950,,
18951,"حَدَّثَنَا عُمَرُ بْنُ ہَارُونَ ، عَنْ إسْمَاعِیلَ بْنِ عَبْدِ الْمَلِکِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ قَالَ : الإِیلاَئُ فِی الرِّضَی وَالْغَضَبِ سَوَائٌ۔",,,18951,,
18952,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ، عَنْ سَعِیدٍ، عَنْ قَتَادَۃَ، عَنْ جَابِرِ بْنِ زَیْدٍ، عَنِ ابْنِ عَبَّاسٍ قَالَ: لاَ إیلاَئَ إلاَّ بِحَلَفٍ۔",,,18952,,
18953,"حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ قَالَ : الإِیلاَئُ لاَ یَکُونُ إلاَّ بِحَلَفٍ عَلَی الْجِمَاعِ۔",,,18953,,
18954,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ أَبِی حُرَّۃَ قَالَ : سَأَلْتُ الْحَسَنَ عَنْ رَجُلٍ ہَجَرَ امْرَأَتَہُ سَبْعَۃَ أَشْہُرٍ قَالَ : قَدْ َطَالَ الْہِجْرَانَ ، قُلْتُ : یَدْخُلُ عَلَیْہِ الإِیلاَئُ ؟ قَالَ : حَلَفَ ؟ قُلْتُ : لاَ ، قَالَ : لاَ إیلاَئَ إلاَّ بِیَمِین۔",,,18954,,
18955,حدَّثَنَا وَکِیعٌ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ قَالَ لاَ إیلاَئَ إلاَّ أَنْ یَحْلِفَ۔,,,18955,,
18956,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ قَالَ : کُلُّ یَمِینٍ مَنَعَتْ جِمَاعًا حَتَّی تَمْضِیَ أَرْبَعَۃُ أَشْہُرٍ فَہِیَ إیلاَئٌ۔",,,18956,,
18957,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَبِیبٍ ، عَنْ عَمْرِو بْنِ ہَرِمٍ قَالَ : سُئِلَ جَابِرُ بْنُ زَیْدٍ ، عَنْ رَجُلٍ ہَجَرَ امْرَأَتَہُ فَمَضَتْ أَرْبَعَۃُ أَشْہُرٍ قَالَ : لاَ تَحْرِمُ عَلَیْہِ إلاَّ أَنْ یَکُونَ أَقْسَمَ بِاللَّہِ لاَ یَمَسُّہَا ، وَلاَ یُصَالِحُہَا ، فَإِنْ أَقْسَمَ عَلَی ذَلِکَ وَلَمْ یُرَاجِعْ حَتَّی تَمْضِیَ أَرْبَعَۃُ أَشْہُرٍ فَقَدْ بَانَتْ مِنْہُ ، وَہِیَ الْأَلِیَّۃُ۔",,,18957,,
18958,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ ہِشَامٍ ، عَنْ قَتَادَۃَ قَالَ : لاَ إیلاَئَ إلاَّ أَنْ یَحْلِفَ۔",,,18958,,
18959,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی السَّفَرِ ، عَنِ الشَّعْبِیِّ قَالَ : کُلُّ یَمِینٍ مَنَعَتْ جِمَاعًا فَہِیَ إیلاَئٌ۔",,,18959,,
18960,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مَنْصُورٍ ، وَمُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : کُلُّ یَمِینٍ مَنَعَتْ جِمَاعًا فَہِیَ إیلاَئٌ۔",,,18960,,
18961,"حَدَّثَنَا عَبْدُ الأَعْلَی، عَنْ یُونُسَ ، عَنِ الْحَسَنِ قَالَ: إذَا انْقَضَتْ عِدَّۃُ الإِیلاَئِ فطلق ، فَإِنَّہُ لاَ یَعُدُّہُ شَیْئًا۔",,,18961,,
18962,"حَدَّثَنَا جَرِیرٌ، عَنْ مُغِیرَۃَ، عَنْ إبْرَاہِیمَ قَالَ: إذَا قَالَ الرَّجُلُ لاِمْرَأَتِہِ وَہِیَ تَعْتَدُّ مِنْہُ فِی الإیلاَئِ، أَوْ طَلاَقٍ: ہِیَ طَالِقٌ ، فَإِنَّ طلاقہ ذَلِکَ جَائِزٌ عَلَیْہَا ، فَإِذَا قَالَ : أَنْتِ طَالِقٌ بَعْدَ مَا انْقَضَتْ عِدَّتُہَا فَلَیْسَ بِشَیْئٍ ، یُطَلِّقُ مَا لاَ یَمْلِکُ۔",,,18962,,
18963,"حَدَّثَنَا عَبْدُالأَعْلَی، عَنْ یُونُسَ، عَنِ الْحَسَنِ سُئِلَ عَنْ إیلاَئِ الْعَبْدِ مِنَ الْحُرَّۃِ فَقَالَ: تَرَبُّصُ أَرْبَعَۃَ أَشْہُرٍ۔",,,18963,,
18964,"حَدَّثَنَا أَبُو عِصَامٍ ، عَنِ الأَوْزَاعِیِّ ، عَنِ الزُّہْرِیِّ قَالَ : إیلاَئُ الْعَبْدِ عَلَی النِّصْفِ مِنْ إیلاَئِ الْحُرِّ۔",,,18964,,
18965,"حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ عَلِیِّ بْنِ بَذِیمَۃَ ، عَنْ أَبِی عُبَیْدَۃَ ، عَنْ عَبْدِ اللہِ قَالَ : لاَ یَخْطُبُہَا فِی عِدَّتِہَا غَیْرُہُ فَإِذَا انْقَضَتْ عِدَّتُہَا کَانَ ہُوَ وَالنَّاسُ سَوَائً۔",,,18965,,
18966,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ومحمد قَالَ : یَخْطُبُہَا ہُوَ فِی عِدَّتِہَا وَلاَ یَخْطُبُہَا غَیْرُہُ۔",,,18966,,
18967,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ قَالَ : کَانُوا یَقُولُونَ ، أَوْ یَتَحَدَّثُونَ فِی الإِیلاَئِ : إذَا مَضَتْ أَرْبَعَۃُ أَشْہُرٍ فَہِیَ تَطْلِیقَۃٌ بَائِنَۃٌ وَیَخْطُبُہَا فِی عِدَّتِہَا إِنْ شَائَ ، قَالَ ابْنُ عَوْنٍ : فَقُلْت لِمُحَمَّدٍ إنَّ عَامِرًا یَقُولُ : یَخْطُبُہَا فِی عِدَّتِہَا وَلاَ یَخْطُبُہَا غَیْرُہُ ، قَالَ : صَدَقَ عَامِرٌ۔",,,18967,,
18968,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مُغِیرَۃَ أَنَّہُ سَمِعَ الشَّعْبِیَّ یُحَدِّثُ أَنَّہُ سَمِعَ مَسْرُوقًا قَالَ : إذَا مَضَتْ أَرْبَعَۃُ أَشْہُرٍ فَہِیَ وَاحِدَۃٌ بَائِنَۃٌ وَیَخْطُبُہَا زَوْجُہَا فِی عِدَّتِہَا وَلاَ یَخْطُبُہَا غَیْرُہُ۔",,,18968,,
18969,"حَدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ قَالَ : لاَ تَعْتَدُّ مِنْ زَوْجِہَا إذَا أَرَادَ أَنْ یَتَزَوَّجَہَا وَلَکِنْ تَعْتَدُّ مِنَ النَّاسِ ثَلاَثَۃَ قُرُوئٍ۔",,,18969,,
18970,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ أَنَّہُ کَانَ یَقُولُ : لِلْمُطَلَّقَۃِ ثَلاَثًا وَہِیَ حَامِلٌ وَلِلْمُولَی عَنْہَا وَہِیَ حَامِلٌ النَّفَقَۃُ۔",,,18970,,
18971,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ قَالَ : لِلْمُطَلَّقَۃِ ثَلاَثًا وَالْمُولَی عَنْہَا وَالْمُخْتَلِعَۃِ وَالْمُلاَعَنَۃِ وَہُنَّ حَوَامِلُ لَہُنَّ النَّفَقَۃُ إلاَّ أَنْ یُشْتَرَطَ ذَلِکَ عَلَی الْمُخْتَلِعَۃِ۔",,,18971,,
18972,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ فِی رَجُلٍ تَزَوَّجَ امْرَأَۃً فَعَاسَرَہُ أَہْلُہَا فَحَلَفَ أَنْ لاَ یَبْنِیَ بِہَا ، قَالَ الزُّہْرِیُّ : لاَ إیلاَئَ إلاَّ بَعْدَ دُخُولٍ۔",,,18972,,
18973,"حَدَّثَنَا أَبُو عَاصِمٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ قَالَ : إذَا آلَی مِنْہَا قَبْلَ أَنْ یَدْخُلَ بِہَا فَلَیْسَ بِإِیلاَئٍ ، قُلْتُ : وَإِنْ کَانَ عَلَی جِمَاعِہَا قَادِرًا ؟ قَالَ ، وَإِنْ کَانَ عَلَی جِمَاعِہَا قَادِرًا۔",,,18973,,
18974,"حَدَّثَنَا مُحَمَّدُ بْنُ یَزِیدَ ، عَنْ أَبِی الْعَلاَئِ ، عَنْ أَبِی ہَاشِمٍ فِی رَجُل قَالَ لامْرَأَتِہِ : وَاللَّہِ لاَ أَبْنِی بِامْرَأَتِی فِی ہَذَا الْبَیْتِ ، ثُمَّ تَرَکَہَا حَتَّی مَضَتْ أَرْبَعَۃُ أَشْہُرٍ ، قَالَ : ہُوَ إیلاَئٌ وَقَالَ حَمَّادٌ : لَیْسَ بِإِیلاَئٍ۔",,,18974,,
18975,"حَدَّثَنَا وَکِیعٌ حدَّثَنَا إسْمَاعِیلُ ، عَنْ إِبْرَاہِیمَ ، عَن أَبِیہِ ، عَنْ مُجَاہِدٍ أَنَّ ابْنَ الزُّبَیْرِ تَزَوَّجَ امْرَأَۃً فَاسْتَزَادُوہُ فِی الْمَہْرِ فَحَلَفَ أَنْ لاَ یَزِیدَہُمْ وَلاَ یَدْخُلَ بِہَا حَتَّی یَکُونُوا ہُمَ الَّذِینَ یَطْلُبُونَ ذَلِکَ مِنْہُ قَالَ : فَتَرَکَہَا سِنِینَ ، ثُمَّ طَلَبُوا إلَیْہِ فَدَخَلَ بِہَا فَلَمْ یَرَہُ إیلاَئً ، قَالَ وَکِیعٌ : وَہُوَ قَوْلُ سُفْیَانَ وَکَذَلِکَ نَقُولُ۔",,,18975,,
18976,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ وَمُحَمَّدُ بْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عَنْ عُمَرَ قَالَ: لاَ نجیز قَوْلُ الْمَرْأَۃِ فِی دِینِ اللہِ ، الْمُطَلَّقَۃُ ثَلاَثًا لَہَا السُّکْنَی وَالنَّفَقَۃُ ، زَادَ ابْنُ فُضَیْلٍ : وَقَالَتْ عَائِشَۃُ : مَا لَہَا فِی أَنْ تَذْکُرَ ہَذَا خَیْرٌ۔",,,18976,,
18977,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ ، عَنْ عُمَرَ ، وَعَبْدِ اللہِ قَالاَ : لَہَا السُّکْنَی وَالنَّفَقَۃُ۔",,,18977,,
18978,"حَدَّثَنَا أَبُو بَكْرٍ قَالَ: نا فُضَيْلُ بْنُ عِيَاضٍ، عَنْ سُلَيْمَانَ، عَنْ إِبْرَاهِيمَ قَالَ: «لَهَا السُّكْنَى وَالنَّفَقَةُ»",,,18978,,
18979,"حَدَّثَنَا حُمَیْدٌ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، عَنِ السُّدِّیِّ ، عَنْ إبْرَاہِیمَ والشَّعْبِیِّ قَالَ : لَہَا السُّکْنَی وَالنَّفَقَۃُ۔",,,18979,,
18980,"حَدَّثَنَا غُنْدَرٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ قَالَ : لِلْمُطَلَّقَۃِ النَّفَقَۃُ مَا لَمْ تَحْرُمْ فَإِذَا حَرُمَتْ فَلَہَا مَتَاعٌ بِالْمَعْرُوفِ۔",,,18980,,
18981,"حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ أَشْعَثِ ، عَنِ الْحَسَنِ ، وَعَطَائٍ وَالشَّعْبِیِّ قَالُوا فِی الْمُطَلَّقَۃِ ثَلاَثًا : لَہَا السُّکْنَی وَلاَ نَفَقَۃَ۔",,,18981,,
18982,"حَدَّثَنَا جَرِیرٌ، عَنْ مُغِیرَۃَ قَالَ: ذَکَرْتُ لِإِبْرَاہِیمَ حَدِیثَ فَاطِمَۃَ بِنْتِ قَیْسٍ، فَقَالَ إبْرَاہِیمُ: قَالَ عُمَرُ: لاَنَدَعُ کِتَابَ اللہِ وَسُنَّۃَ رَسُولِہِ لِقَوْلِ امْرَأَۃٍ لاَ نَدْرِی حَفِظَتْ، أَوْ نَسِیَتْ، وَکَانَ عُمَرُ یَجْعَلُ لَہَا السُّکْنَی وَالنَّفَقَۃَ۔",,,18982,,
18983,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ قَالَ : سَأَلْتُ سَعِیدَ بْنَ الْمُسَیَّبِ ، عَنْ رَجُلٍ یُطَلِّقُ امْرَأَتَہُ وَہِیَ فی بَیْتٍ بِکِرَائٍ عَلَی مَنِ الْکِرَائُ ؟ قَالَ : عَلَی زَوْجِہَا ، قَالَ : فَإِنْ لَمْ یَکُنْ عِنْدَ زَوْجِہَا قَالَ : فَعَلَیْہَا ، قَالَ : فَإِنْ لَمْ یَکُنْ عِنْدَہَا ؟ قَالَ : فَعَلَی الأَمِیرِ۔",,,18983,,
18984,"حَدَّثَنَا شَبَابَۃُ قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنِ الْحَکَمِ ، عَنْ إبْرَاہِیمَ ، عَنْ شُرَیْحٍ قَالَ : الْمُطَلَّقَۃُ ثَلاَثًا لَہَا السُّکْنَی وَالنَّفَقَۃُ۔",,,18984,,
18985,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنْ إبْرَاہِیمَ قَالَ : قَالَ عُمَرُ بْنُ الْخَطَّابِ : لاَ نَدَعُ کِتَابَ رَبِّنَا وَسُنَّۃَ نَبِیِّنَا لِقَوْلِ الْمَرْأَۃِ ، الْمُطَلَّقَۃُ ثَلاَثًا لَہَا السُّکْنَی وَالنَّفَقَۃُ۔",,,18985,,
18986,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا جَعْفَرُ بْنُ بُرْقَانَ ، عَنْ مَیْمُونِ بْنِ مِہْرَانَ قَالَ : قَالَ عُمَرُ : لاَ نَدَعُ کِتَابَ رَبِّنَا وَسُنَّۃَ نَبِیِّنَا صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لِقَوْلِ امْرَأَۃٍ۔",,,18986,,
18987,"حَدَّثَنَا وَکِیعٌ ، عَنِ الْمَسْعُودِیِّ ، عَنِ الْحَکَمِ أَنَّ شُرَیْحًا قَالَ : الْمُطَلَّقَۃُ ثَلاَثًا لَہَا السُّکْنَی وَالنَّفَقَۃُ۔",,,18987,,
18988,"حَدَّثَنَا وَکِیعٌ قَالَ: حَدَّثَنَا شُعْبَۃُ، عَنِ الْحَکَمِ وَحَمَّادٍ، عَنْ إبْرَاہِیمَ قَالَ: الْمُطَلَّقَۃُ ثَلاَثًا لَہَا السُّکْنَی وَالنَّفَقَۃُ.",,,18988,,
18989,"حَدَّثَنَا وَکِیعٌ قَالَ : حَدَّثَنَا سُفْیَانُ ، عَنْ أَبِی بَکْرِ بْنِ أَبِی الْجَہْمِ بْنِ صُخَیْرٍ الْعَدَوِیِّ ، قَالَ : سَمِعْتُ فَاطِمَۃَ بِنْتَ قَیْسٍ تَقُولُ : إنَّ زَوْجَہَا طَلَّقَہَا ثَلاَثًا فَلَمْ یَجْعَلْ لَہَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سُکْنَی وَلاَ نَفَقَۃً۔ (مسلم48۔ ترمذی 1135)",,,18989,,
18990,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنِ الشَّعْبِیِّ قَالَ : قالَتْ فَاطِمَۃُ بِنْتُ قَیْسٍ : طَلَّقَنِی زَوْجِی عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ثَلاَثًا فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ سُکْنَی لَکِ وَلاَ نَفَقَۃَ۔\n\n(مسلم 1117۔ ترمذی 1180)",,,18990,,
18991,"حَدَّثَنَا فُضَیْلُ بْنُ عِیَاضٍ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ قَالَ : الْمُطَلِّقُ ثَلاَثًا لاَ یُجْبَرُ عَلَی النَّفَقَۃِ۔",,,18991,,
18992,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ عِکْرِمَۃَ ، وَالْحَسَنِ قَالَ سَمِعْتہمَا یَقُولاَنِ : الْمُطَلَّقَۃُ ثَلاَثًا وَالْمُتَوَفَّی عَنْہَا لَیْسَ لَہُمَا سُکْنَی وَلاَ نَفَقَۃٌ۔",,,18992,,
18993,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ، عَنْ شُعْبَۃَ، عَنْ یَعْلَی بْنِ مُسْلِمٍ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ فِی الْمُطَلَّقَۃِ ثَلاَثًا لاَ نَفَقَۃَ لَہَا۔,,,18993,,
18994,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ سَعِیدٍ ، عَنْ یَعْلَی بْنِ حَکِیمٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ قَالَ : لاَ نَفَقَۃَ لَہَا۔",,,18994,,
18995,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ قَالَ : سَأَلْتُہ عَنِ الرَّجُلِ یُطَلِّقُ امْرَأَتَہُ الْبَتَّۃَ ہل لَہَا مِنْ نَفَقَۃٍ ؟ قَالَ : لاَ نَفَقَۃَ لَہَا۔",,,18995,,
18996,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الأَحْوَصِ ، عنْ عَبْدِ اللہِ قَالَ : لاَ یُطَلِّقُہَا وَہِیَ حَامِلٌ فَیُنَدِّمَہُ اللَّہُ فَیُنْفِقَ عَلَیْہَا حَمْلِہَا وَرَضَاعِہَا حَتَّی تَفْطِمَہُ۔",,,18996,,
18997,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ أَنَّہُ کَانَ یَقُولُ : إذَا طَلَّقَ الرَّجُلُ امْرَأَتَہُ ثَلاَثًا وَہِیَ حَامِلٌ فَلَہَا عَلَیْہِ النَّفَقَۃُ حُرَّۃً کَانَتْ ، أَوْ أَمَۃً۔",,,18997,,
18998,"حَدَّثَنَا حَاتِمٌ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ؛ فِی الرَّجُلِ یُطَلِّقُ امْرَأَتَہُ الْبَتَّۃَ قَالَ : لاَ نَفَقَۃَ لَہَا إلاَّ أَنْ تَکُونَ حُبْلَی فَیُنْفِقَ عَلَیْہَا حَتَّی تَضَعَ حَمْلَہَا۔",,,18998,,
18999,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ ہِشَامٍ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ قَالَ : الْمُطَلَّقَۃُ ثَلاَثًا وَالْمُولَی عَنْہَا وَالْمُخْتَلِعَۃُ وَالْمُلاَعَنَۃُ وَہُنَّ حَوَامِلُ لَہُنَّ النَّفَقَۃُ۔",,,18999,,
19000,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَاصِمٍ ، عَنِ الشَّعْبِیِّ ، وَعَنْ یُونُسَ ، عَنِ ابْنِ سِیرِینَ قَالاَ : لِکُلِّ حَامِلٍ نَفَقَۃٌ۔",,,19000,,
19001,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ زَکَرِیَّا قَالَ : سُئِلَ عَامِرٌ عَنِ الْمَرْأَۃِ یُطَلِّقُہَا زَوْجُہَا وَہِیَ حَامِلٌ أَیُنْفِقُ عَلَیْہَا ؟ قَالَ : نَعَمْ ، إذَا کَانَ حُرًّا۔",,,19001,,
19002,"حَدَّثَنَا ابْنُ أَبِی غَنِیۃَ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ : {فَأَنْفِقُوا عَلَیْہِنَّ حَتَّی یَضَعْنَ حَمْلَہُنَّ} قَالَ : إذَا طَلَّقَہَا وَہِیَ حَامِلٌ أنفق عَلَیْہَا حَتَّی تَضَعَ۔",,,19002,,
19003,"حَدَّثَنَا عَبْدُ اللہِ بْنُ مُبَارَکٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ أَنَّ أَبَا الْعَالِیَۃِ وَشُرَیْحًا قَالاَ : فِی الْمُخْتَلِعَۃِ الْحَامِلِ : لَہَا النَّفَقَۃُ۔",,,19003,,
19004,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ قَالَ : لَہَا النَّفَقَۃُ إلاَّ أَنْ یَشْتَرِطَ۔",,,19004,,
19005,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ قَالَ : لَہَا النَّفَقَۃُ إلاَّ أَنْ یَشْتَرِطَ عَلَیْہَا قَالَ وَقَالَ ابْنُ طَاوُوسٍ ، عَنْ أَبِیہِ : لَہَا النَّفَقَۃُ وَقَالَ عَمْرُو بْنُ دِینَارٍ : لَہَا النَّفَقَۃُ ، إنَّمَا یُنْفِقُ عَلَی وَلَدِہِ۔",,,19005,,
19006,"حَدَّثَنَا أَبُو دَاوُدَ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ، عَنْ یَحْیَی، عَنِ الْقَاسِمِ فِی الْمُخْتَلِعَۃِ الْحَامِلِ: لاَ بُدَّ لَہَا مِنْ نَفَقَۃٍ۔",,,19006,,
19007,"حدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ حَمَّادٍ قَالَ : لَہَا النَّفَقَۃُ۔",,,19007,,
19008,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ قَالَ : کَانَ یَجْعَلُ لَہَا النَّفَقَۃَ إذَا کَانَتْ حَامِلاً۔",,,19008,,
19009,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ، عَنْ عَاصِمٍ، عَنِ الشَّعْبِیِّ، وَعَنْ یُونُسَ، عَنِ ابْنِ سِیرِینَ قَالاَ: لِکُلِّ حَامِلٍ نَفَقَۃٌ۔",,,19009,,
19010,"حَدَّثَنَا عَبْدُ الْوَہَّابِ ، عَنْ سَعِیدٍ ، عَنْ عَاصِمٍ ، عَنِ الشَّعْبِیِّ ، أَنَّہُ قَالَ فِی الْمُخْتَلِعَۃِ الْحَامِلِ : لَہَا النَّفَقَۃُ۔",,,19010,,
19011,"حَدَّثَنَا عَبْدُ اللہِ بْنُ مُبَارَکٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، وَالْحَسَنِ وَجَابِرِ بْنِ عَبْدِ اللہِ قَالُوا : لاَ نَفَقَۃَ لَہَا۔",,,19011,,
19012,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی الْحُرَّۃِ تَحْتَ الْعَبْدِ وَالأَمَۃِ تَحْتَ الْحُرِّ یُطَلَّقَانِ وَہُمَا حَامِلاَنِ ، لَہُمَا النَّفَقَۃُ۔,,,19012,,
19013,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مُحَمَّدٍ الْمُحَارِبِیُّ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ فِی الْعَبْدِ یُطَلِّقُ امْرَأَتَہُ وَہِیَ حَامِلٌ قَالَ : عَلَیْہِ النَّفَقَۃُ حَتَّی تَضَعَ۔",,,19013,,
19014,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ قَالَ : إذَا طَلَّقَ الْعَبْدُ امْرَأَتَہُ وَہِیَ حرۃ أَنْفَقَ عَلَیْہَا حَتَّی تَضَعَ فَإِذَا وَضَعَتْ لَمْ یُنْفِقْ عَلَیْہَا۔",,,19014,,
19015,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ قَالَ : الْحُرُّ إذَا کَانَتْ تَحْتَہُ الأَمَۃُ فَطَلَّقَہَا ، فَإِنَّ عَلَیْہِ النَّفَقَۃَ حَتَّی تَضَعَ وَلَیْسَ عَلَیْہِ أَجْرُ الرَّضَاعِ۔",,,19015,,
19016,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الزُّبَیْرِ بْنِ عَدِیٍّ ، عَنْ زَیْدِ بْنِ الْحَارِثِ ، عَنْ شُرَیْحٍ أَنَّ رَجُلاً طَلَّقَ وَلَمْ یَفْرِضْ وَلَمْ یَدْخُلْ فَجَبَرَہُ شُرَیْحٌ عَلَی الْمُتْعَۃِ۔,,,19016,,
19017,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ حَجَّاجٍ عَمَّنْ حَدَّثَہُ ، عَنِ ابْنِ مغفل قَالَ : إنَّمَا یُجْبَرُ عَلَی الْمُتْعَۃِ مَنْ طَلَّقَ وَلَمْ یَفْرِضْ وَلَمْ یَدْخُلْ۔",,,19017,,
19018,"حَدَّثَنَا حُمَیْدٌ ، عَنْ حَسَنٍ ، عَنْ مُطَرِّفٍ ، عَنِ الشَّعْبِیِّ قَالَ : إذَا طَلَّقَ الرَّجُلُ امْرَأَتَہُ وَلَمْ یَفْرِضْ لَہَا وَلَمْ یَدْخُلْ بِہَا جُبِرَ عَلَی أَنْ یُمَتِّعَہَا۔",,,19018,,
19019,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ الْحَجَّاجِ ، عَنِ الْحَکَمِ ، عَنْ إبْرَاہِیمَ قَالَ : إنَّمَا یُجْبَرُ عَلَی الْمُتْعَۃِ مَنْ طَلَّقَ وَلَمْ یَفْرِضْ وَلَمْ یَدْخُلْ۔",,,19019,,
19020,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَمَّادٍ قَالَ : یُمَتِّعُہَا بِمِثْلِ نِصْفِ مَہْرِ مِثْلِہَا۔",,,19020,,
19021,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ قَالَ : إذَا طَلَّقَ الرَّجُلُ امْرَأَتَہُ قَبْلَ أَنْ یَدْخُلَ بِہَا ، وَقَبْلَ أَنْ یَفْرِضَ لَہَا فَلَیْسَ لَہَا إلاَّ الْمَتَاعُ۔",,,19021,,
19022,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ فِیمَنْ طَلَّقَ وَلَمْ یَفْرِضْ قَبْلَ أَنْ یَدْخُلَ قَالَ : لَہَا الْمُتْعَۃُ ، وَقَالَ ابْنُ سِیرِینَ : لَہَا مَعَ الْمُتْعَۃِ شَیْئٌ۔",,,19022,,
19023,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ قَالَ : لِکُلِّ مُطَلَّقَۃٍ مُتْعَۃٌ إلاَّ الَّتِی طُلِّقَتْ قَبْلَ أَنْ یَدْخُلَ بِہَا ، فَإِنَّ لَہَا نِصْفَ الصَّدَاقِ۔",,,19023,,
19024,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ قَالَ : لِکُلِّ مُطَلَّقَۃٍ متعۃ دَخَلَ بِہَا ، أَوْ لَمْ یَدْخُلْ ، فَرَضَ لَہَا ، أَوْ لَمْ یَفْرِضْ لَہَا۔",,,19024,,
19025,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی جَعْفَرٍ الرَّازِیّ ، عَنْ الربیع عن أَبِی الْعَالِیَۃِ قَالَ : لِکُلِّ مُطَلَّقَۃٍ مَتَاعٌ۔",,,19025,,
19026,"حَدَّثَنَا عَبْدُ الرَّزَّاقِ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ قَالَ : لِکُلِّ مُطَلَّقَۃٍ مُتْعَۃٌ۔",,,19026,,
19027,"حَدَّثَنَا یَزِیدُ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ قَالَ : قُلْتُ لِسَعِیدِ بْنِ الْمُسَیَّبِ : إنَّ الْحَسَنَ وَأَبَا الْعَالِیَۃِ یَجْعَلاَنِ لِلْمُطَلَّقَۃِ الَّتِی قَدْ دُخِلَ بِہَا الْمَتَاعَ وَالَّتِی لَمْ یُدْخَلْ بِہَا الْمَتَاعَ ، فَقَالَ سَعِیدٌ : إنَّمَا کَانَ لَہَا فِی سُورَۃِ الأَحْزَابِ فَلَمَّا نَزَلَتْ سُورَۃُ الْبَقَرَۃِ جُعِلَ لِلَّتِی فُرِضَ لَہَا نِصْفُ الصَّدَاقِ وَلاَ مُتْعَۃَ لَہَا۔",,,19027,,
19028,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ قَالَ : لِکُلِّ مُطَلَّقَۃٍ مَتَاعٌ إلاَّ الَّتِی طُلِّقَتْ وَقَدْ فُرِضَ لَہَا۔",,,19028,,
19029,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ عَطَائٍ قَالَ : سُئِلَ : الرَّجُلُ یُطَلِّقُ امْرَأَتَہُ وَقَدْ فَرَضَ قَبْلَ أَنْ یَدْخُلَ بِہَا ، لَہَا مَتَاعٌ ؟ قَالَ : کَانَ عَطَائٌ یَقُولُ : لاَ مَتَاعَ لَہَا۔",,,19029,,
19030,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ قَالَ : إذَا طَلَّقَ الرَّجُلُ الْمَرْأَۃَ وَقَدْ فَرَضَ لَہَا فَلَہَا نِصْفُ الصَّدَاقِ وَلاَ مَتَاعَ لَہَا۔",,,19030,,
19031,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْمَسْعُودِیِّ ، عَنِ الْحَکَمِ ، عَنْ إبْرَاہِیمَ ، عَنْ شُرَیْحٍ قَالَ : إنَّ لَہَا فِی النِّصْفِ لَمَتَاعًا یَعْنِی الَّتِی لَمْ یُدْخَلْ بِہَا۔",,,19031,,
19032,حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ صَالِحِ بْنِ إبْرَاہِیمَ أَنَّ عَبْدَ الرَّحْمَنِ بْنَ عَوْفٍ حَمَّم امْرَأَتَہُ الَّتِی طَلَّقَ جَارِیَۃً سَوْدَائَ۔,,,19032,,
19033,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ أَنَّہُ بَلَغَہُ أَنَّ أَنَسَ بْنَ مَالِکٍ مَتَّعَ امْرَأَتَہُ بِثَلاَثِ مِئَۃٍ۔,,,19033,,
19034,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ أَبِی الْعُمَیْسِ ، عَنِ الْحَسَنِ بْنِ سَعْدٍ ، عَنْ أَبِیہِ أَنَّ الْحَسَنَ بْنَ عَلِیٍّ مَتَّعَ امْرَأَتَہُ بِعَشَرَۃِ آلاَفٍ۔,,,19034,,
19035,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ إیَاسٍ ، عَنْ أَبِی مجلَز قَالَ : سَأَلْتُ ابْنَ عُمَرَ ، عَنِ الْمُتْعَۃِ قَالَ : عَدَّ کَذَا عَدَّ کَذَا حَتَّی عَدَّ ثَلاَثِینَ۔",,,19035,,
19036,حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ، عَنْ شُرَیْحٍ أَنَّہُ طَلَّقَ امْرَأَتَہُ فَمَتَّعَہَا بِثَلاَثِ مِئَۃٍ۔,,,19036,,
19037,حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ أَنَّہُ طَلَّقَ امْرَأَتَہُ فَمَتَّعَہَا بِثَلاَثِ مِئَۃٍ۔,,,19037,,
19038,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاْہِیْمَ ، عَنِ الأَسْوَدِ أَنَّہُ مَتَّعَ بِثَلاَثِ مِئَۃٍ۔,,,19038,,
19039,حدَّثَنَا ابْنُ الدَّرَاوَرْدِیِّ ، عَنْ ہِشَامٍ أَنَّ أباہ طَلَّقَ فَمَتَّعَ بواحدۃ۔,,,19039,,
19040,حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ عَبْدِ اللہِ بْنِ عَبْدِ اللہِ أَنَّہُ طَلَّقَ فَمَتَّعَ بِوَلِیدَۃٍ۔,,,19040,,
19041,حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنِ الْعُمَرِیِّ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ أَنَّہُ مَتَّعَ بِوَلِیدَۃٍ۔,,,19041,,
19042,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ إسْمَاعِیلَ بْنِ أُمیَۃ ، عَنْ عکرمۃ ، عَنِ ابْنِ عَبَّاسٍ قَالَ : أَرْفَعُ الْمُتْعَۃِ الْخَادِمُ ، ثُمَّ دُونَ ذَلِکَ : الْکِسْوَۃُ ، ثُمَّ دُونَ ذَلِکَ : النَّفَقَۃُ۔",,,19042,,
19043,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : أَوْضَعُ الْمُتْعَۃِ الثَّوْبُ وَأَرْفَعُہَا الْخَادِمُ۔",,,19043,,
19044,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ قَالَ : مِنْ أَوْسَطِ الْمُتْعَۃِ الدِّرْعُ وَالْخِمَارُ وَالْمِلْحَفَۃُ۔",,,19044,,
19045,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ داود ، عَنِ الشَّعْبِیِّ فِی مَتَاعِ الْمُطَلَّقَۃِ : ثِیَابُہَا فِی بَیْتِہَا ، الدِّرْعُ وَالْخِمَارُ وَالْمِلْحَفَۃُ وَالْجِلْبَابُ۔",,,19045,,
19046,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ قَالَ: کَانَ النَّاسُ یُمَتِّعُونَ فَمِنْہُمْ مَنْ یُمَتِّعُ بِالْخَادِمِ وَمِنْہُمْ مَنْ کَانَ یُعْطِی الْمِائَتَیْنِ وَمِنْہُمْ مَنْ کَانَ یُعْطِی الدِّرْعَ وَالْخِمَارَ وَالْمِلْحَفَۃَ وَمِنْہُمْ مَنْ کَانَ یُعْطِی النَّفَقَۃَ۔",,,19046,,
19047,"حَدَّثَنَا أَبُو عَبْدِ الرَّحْمَنِ الْمُقْرِیء ، عَنْ سَعِیدِ بْنِ أَبِی أَیُّوبَ قَالَ : حدَّثَنِی عَقِیلٌ ، عَنِ ابْنِ شِہَابٍ قَالَ: أَعْلاَہُ الْخَادِمُ ، ثُمَّ الْکِسْوَۃُ ، ثُمَّ النَّفَقَۃُ۔",,,19047,,
19048,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ قَالَ : الْمُسْتَحَاضَۃُ تَعْتَدُّ بِالأَقْرَائِ۔",,,19048,,
19049,حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ، عَنْ رَوْحِ بْنِ الْقَاسِمِ، عَنْ عَمْرُو بْنُ دِینَارٍ، عَنْ جَابِرَ بْنِ زَیْدٍ قَالَ تَعْتَدُّ بِالأَقْرَائِ۔,,,19049,,
19050,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ رَوْحِ بْنِ الْقَاسِمِ ، عَنْ عَمْرِو بْنِ دِینَارٍ قَالَ طَاوُوسٌ : تَعْتَدُّ بِالشُّہُورِ۔",,,19050,,
19051,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ سَعِیدٍ ، عَنْ أَبِی رَجَائٍ ، عَنِ الْحَکَمِ ، وَعَطَائٍ أَنَّہُمَا قَالاَ : الْمُسْتَحَاضَۃُ تَعْتَدُّ بِالأَقْرَائِ۔",,,19051,,
19052,"حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ سَعِیدٍ ، عَنْ مَطَرٍ ، عَنْ عَطَائٍ وَالْحَکَمِ ، وَالْحَسَنِ فِی الْمُسْتَحَاضَۃِ قَالُوا : تَعْتَدُّ بِأَیَّامِ أَقْرَائِہَا۔",,,19052,,
19053,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ قَالَ : تَعْتَدُّ بِالأَقْرَائِ۔",,,19053,,
19054,"حَدَّثَنَا مُحَمَّدُ بْنُ مُیَسَّرٍ ، عَنْ إبْرَاہِیمَ بْن طَہْمَانَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : الْمُسْتَحَاضَۃُ تَعْتَدُّ بِالأَقْرَائِ۔",,,19054,,
19055,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مُغِیرَۃَ ، عَنْ حَمَّادٍ قَالَ : إذَا طَلَّقَ الرَّجُلُ الْمُسْتَحَاضَۃَ فَحَاضَتِ الثَّالِثَۃَ أَدْنَی مَا کَانَتْ تَحِیضُ فَلاَ یَمْلِکُ زَوْجُہَا الرَّجْعَۃَ وَلاَ تَغْتَسِلُ وَلاَ تُصَلِّی حَتَّی یَأْتِیَ عَلَیْہَا أَکْثَرُ مِمَّا کَانَتْ تَحِیضُ۔",,,19055,,
19056,"حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنْ مَالِکٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : عِدَّۃُ الْمُسْتَحَاضَۃِ سَنَۃٌ۔",,,19056,,
19057,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ، عَنْ عِکْرِمَۃَ قَالَ إِنَّ مِنْ رِیبَۃِ الْمُسْتَحَاضَۃُ وَالَّتِی لاَ تَسْتَقِیمُ لَھَا حَیْضَۃٌ تَحِیضُ فِی الشَّہْرِ مَرَّتَیْنِ وَفِی الأَشْہُرِ مَرَّۃً عِدَّتُہَا ثَلاَثَۃُ أَشْہُرٍ قَالَ : فَکَانَ قَتَادَۃُ ذَلِکَ رَأْیُہُ۔",,,19057,,
19058,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ جَعْفَرِ بْنِ أَبِی وَحْشِیَّۃَ ، عَنْ جَابِرِ بْنِ زَیْدٍ قَالَ : تَذَاکَرَ ابْنُ عَبَّاسٍ ، وَابْنُ عُمَرَ امْرَأَۃَ الْمَفْقُودِ فَقَالاَ : جَمِیعًا : تَرَبَّصُ أَرْبَعَ سِنِینَ ، ثُمَّ یُطَلِّقُہَا وَلِیُّ زَوْجِہَا ، ثُمَّ تَرَبَّصُ أَرْبَعَۃَ أَشْہُرٍ وَعَشْرًا ، ثُمَّ تَذَاکَرَا النَّفَقَۃَ فَقَالَ ابْنُ عُمَرَ : لَہَا النَّفَقَۃُ فِی مَالِہِ بِحَبْسِہَا نَفْسَہَا فِی سَبَبِہِ ، فَقَالَ ابْنُ عَبَّاسٍ : لَیْسَ کَذَلِکَ ، إذَنْ تُجْحِفُ بِالْوَرَثَۃِ وَلَکِنَّہَا تَأْخُذُ عَلَیْہِ فِی مَالِہِ فَإِنْ قَدِمَ فَذَلِکَ لَہَا عَلَیْہِ فِی مَالِہِ وَإِلاَّ فَلاَ شَیْئَ لَہَا۔",,,19058,,
19059,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنْ قَیْسِ بْنِ سَعْدٍ ، عَنْ بُکَیْرِ بْنِ عَبْدِ اللہِ بْنِ الأَشَجِّ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ ، عَنْ زَیْدِ بْنِ ثَابِتٍ قَالَ : إذَا طُلِّقَتِ النُّفَسَائُ لاَ تَعْتَدُّ بِذَلِکَ الدَّمِ۔",,,19059,,
19060,"حَدَّثَنَا غُنْدَرٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ قَالَ : سُئِلَ عَنِ الْمَرْأَۃِ النُّفَسَائِ ہَلْ تَعْتَدُّ بِالنِّفَاسِ ؟ قَالَ : لاَ تَعْتَدُّ بِنِفَاسِہَا۔",,,19060,,
19061,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ قَالَ : إذَا طَلُقَتْ وَہِیَ نُفَسَائُ لَمْ تَعْتَدَّ بِدَمِ نِفَاسِہَا فی عدتہا۔",,,19061,,
19062,"حَدَّثَنَا وَکِیعٌ قَالَ: حدَّثَنَا جَرِیرُ بْنُ حَازِمٍ ، عَنْ قَیْسِ بْنِ سَعْدٍ ، عَنْ بُکَیْرِ بْنِ عَبْدِ اللہِ بْنِ الأَشَجِّ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ، عَنْ زَیْدِ بْنِ ثَابِتٍ قَالَ: إذَا طَلَّقَ الرَّجُلُ امْرَأَتَہُ وَہِیَ نُفَسَائُ لَمْ تَعْتَدَّ بِدَمِ نِفَاسِہَا فِی عِدَّتِہَا۔",,,19062,,
19063,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مُغِیرَۃَ ، عَنِ الْحَارِثِ قَالَ : تَسْتَبِینُ الْمُسْتَحَاضَۃُ أَنَّہَا مُسْتَحَاضَۃٌ إذَا جَاوَزَتْ حَیْضَتُہَا آخِرَ مَا تَطْہُرُ فِیہِ النِّسَائُ۔",,,19063,,
19064,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُطَرِّفٍ ، عَنِ الْحَکَمِ قَالَ : إذَا أَدْرَکَ قُرْئٌ قُرْئًا فَہِیَ مُسْتَحَاضَۃٌ۔",,,19064,,
19065,"حَدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عُرْوَۃَ ، عَنْ عَائِشَۃَ قَالَتْ : إنَّمَا الأَقْرَائُ الأَطْہَارُ۔",,,19065,,
19066,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ مَالِکِ بْنِ أَنَسٍ قَالَ : کَانَ الْقَاسِمُ وَسَالِمٌ یَقُولاَنِ : إن الأَقْرَائَ الأَطْہَارُ۔",,,19066,,
19067,"حَدَّثَنَا ابْنُ أَبِی غَنِیَۃَ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ قَالَ : الأَقْرَائُ الْحِیَضُ۔",,,19067,,
19068,"حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ قَالَ : عِدَّۃُ أُمِّ الْوَلَدِ ثَلاَثُ حِیَضٍ۔",,,19068,,
19069,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ قَالَ : ثَلاَثُ حِیَضٍ۔",,,19069,,
19070,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ وَأَشْعَثُ ، عَنِ الْحَکَمِ ، عَنْ عَلِیٍّ قَالَ : ثَلاَثُ حِیَضٍ۔",,,19070,,
19071,حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ عَامِرٍ ، عَنْ عَلِیٍّ مِثْلَہُ۔,,,19071,,
19072,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنِ الشَّعْبِیِّ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، وَعَبْدِ اللہِ قَالاَ : ثَلاَثُ حِیَضٍ إذَا مَاتَ عَنْہَا۔",,,19072,,
19073,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ قَالَ : ثَلاَثَۃُ قُرُوئٍ۔",,,19073,,
19074,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ مَطَرٍ ، عَنْ رَجَائِ بْنِ حَیْوَۃَ ، عَنْ قَبِیصَۃَ ، عَنْ عَمْرِو بْنِ الْعَاصِ أَنَّہُ قَالَ : لاَ تُلْبِسُوا عَلَیْنَا سُنَّۃَ نَبِیِّنَا ، عِدَّتُہَا عِدَّۃُ الْمُتَوَفَّی عَنْہَا زَوْجُہَا۔ (ابوداؤد 2302۔ ابویعلی 7300)",,,19074,,
19075,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ عَنْ فَضَالَۃَ بْنِ عُبَیْد ، وَعَنْ عَبْدِ رَبِّہِ ، عَنْ أَبِی عِیَاضٍ أَنَّہُما قَالاَ : عِدَّتُہَا إذَا تُوُفِّیَ عَنْہَا زوجہا عِدَّۃُ الْحُرَّۃِ۔",,,19075,,
19076,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ دَاوُدَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : عِدَّۃُ أُمِّ الْوَلَدِ إذَا تُوُفِّیَ عَنْہَا زوجہا أَرْبَعَۃُ أَشْہُرٍ وَعَشْرًا۔",,,19076,,
19077,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ حُمَیْدٍ ، عَنِ الْحَسَنِ ، وَسَعِیدِ بْنِ جُبَیْرٍ أَنَّہُمَا قَالاَ : عدۃ أُمِّ الْوَلَدِ إذَا تُوُفِّیَ عَنْہَا سَیِّدُہَا أَرْبَعَۃُ أَشْہُرٍ وَعَشْرًا۔",,,19077,,
19078,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ قَالَ : سَأَلَ الحَکَم بن عُتَیْبََۃَ الزُّہْرِیَّ ، عَنْ عِدَّۃِ أُمِّ الْوَلَدِ إذَا تُوُفِّیَ عَنْہَا سَیِّدُہَا ، فَقَالَ : السَّنَۃُ ، فقَالَ : وما السَّنَۃُ ؟ قَالَ : بَرِیرَۃُ أُعْتِقَتْ فَاعْتَدَّتْ عِدَّۃَ الْحُرَّۃِ۔\n\n(ابن ماجہ 2007۔ بیہقی 251)",,,19078,,
19079,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : عِدَّۃُ أُمِّ الْوَلَدِ أَرْبَعَۃُ أَشْہُرٍ وَعَشْرًا۔",,,19079,,
19080,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، وَسَعِیدِ بْنِ الْمُسَیَّبِ مِثْلَ ذَلِکَ۔,,,19080,,
19081,حَدَّثَنَا یَزِیدُ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ خِلاَسٍ ، عَنْ عَلِیٍّ مِثْلَ ذَلِکَ۔,,,19081,,
19082,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، وَابْنُ عُلَیَّۃَ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ، عَنِ ابْنِ عُمَرَ قَالَ : عِدَّتُہَا حَیْضَۃٌ۔",,,19082,,
19083,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ ، عَنْ أَبِی قِلاَبَۃَ قَالَ : عِدَّۃُ أُمِّ الْوَلَدِ إذَا تُوُفِّیَ عنہا سَیِّدُہَا حَیْضَۃٌ۔",,,19083,,
19084,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ أَنَّہُ کَانَ یَقُولُ : عِدَّتُہَا حَیْضَۃٌ إذَا تُوُفِّیَ عَنْہَا سَیِّدُہَا۔",,,19084,,
19085,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ ابْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ، عَنْ زَیْدٍ قَالَ : عِدَّتُہَا حَیْضَۃٌ۔",,,19085,,
19086,"حَدَّثَنَا عَبْدُ الْوَہَّابِ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ قَالَ : عِدَّتُہَا حَیْضَۃٌ۔",,,19086,,
19087,"حَدَّثَنَا حَفْصٌ، عَنْ إسْمَاعِیلَ، عَنِ الشَّعْبِیِّ قَالَ: عِدَّتُہَا حَیْضَۃٌ فَلِمَ لاَ تُوَرِّثُونَہَا إذَا جَعَلْتُمُوہَا ثَلاَثَ حِیَضٍ۔",,,19087,,
19088,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ وَطَاوُسٍ قَالاَ : عِدَّۃُ أُمِّ الْوَلَدِ وَالسُّرِّیَّۃِ إذَا تُوُفِّیَ عَنْہَا سَیِّدُہَا شَہْرَانِ وَخَمْسُ لَیَالٍ۔",,,19088,,
19089,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، قَالَ : سَمِعْتُ الْقَاسِمَ وَذُکِرَ لَہُ أَنَّ عَبْدَ الْمَلِکِ بْنَ مَرْوَانَ فَرَّقَ بَیْنَ رِجَالٍ وَنِسَائِہِمْ کُنَّ أُمَّہَاتِ أَوْلاَدٍ نُکِحْنَ بَعْدَ حَیْضَۃٍ ، أَوْ حَیْضَتَیْنِ حَتَّی یَعْتَدِدْنَ أَرْبَعَۃَ أَشْہُرٍ وَعَشْرًا فَقَالَ : سُبْحَانَ اللہِ ، یَقُولُ اللَّہُ فِی کِتَابِہِ : {وَالَّذِینَ یُتَوَفَّوْنَ مِنْکُمْ وَیَذَرُونَ أَزْوَاجًا} أَتُرَاہُنَّ مِنَ الأزْوَاج۔",,,19089,,
19090,حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ أنَّ عَمْرَو بْنَ الْعَاصِ أَمَرَ أُمَّ وَلَدٍ أُعْتِقَتْ أَنْ تَعْتَدَّ ثَلاَثَ حِیَضٍ وَکَتَبَ إلَی عُمَرَ فَکَتَبَ یُحَسِّن رَأْیہ۔,,,19090,,
19091,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ أَنَّہُ کَانَ یَقُولُ : إذَا أَعْتَقَہَا فَعِدَّتُہَا ثَلاَثُ حِیَضٍ۔",,,19091,,
19092,"حَدَّثَنَا وَکِیعٌ، عَنْ شُعْبَۃَ، عَنِ الْحَکَمِ، عَنْ إبْرَاہِیمَ قَالَ: إذَا أَعْتَقَہَا، أَوْ مَاتَ عَنْہَا فَعِدَّتُہَا ثَلاَثُ حِیَضٍ۔",,,19092,,
19093,"حَدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ قَالَ : إذَا أَعْتَقَ الرَّجُلُ أُمَّ وَلَدِہِ اعْتَدَّتْ بِحَیْضَتَیْنِ : وَقَالَ الزُّہْرِیُّ : ثَلاَثَۃَ قُرُوئٍ۔",,,19093,,
19094,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ، عَنْ حَبِیبٍ، عَنْ عَمْرٍو قَالَ: سُئِلَ جَابِرُ بْنُ زَیْدٍ عَنِ الرَّجُلِ إذَا أَعْتَقَ سُرِّیَّتَہُ وَہُوَ صَحِیحٌ اعْتَدَّتْ ثَلاَثَۃَ قُرُوئٍ إذا کَانَتْ تَحِیضُ ، وَإِنْ لَمْ تَکُنْ تَحِیضُ فَعِدَّتُہَا ثَلاَثَۃُ أَشْہُرٍ إِنْ تَزَوَّجَہَا غَیْرُہُ۔",,,19094,,
19095,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ أَنَّہُ کَانَ یَقُولُ : عِدَّتُہَا حَیْضَۃٌ إذَا أَعْتَقَہَا ، أَوْ مَاتَ عَنْہَا۔",,,19095,,
19096,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ سَعِیدٍ ، عَنْ حَبِیبٍ الْمُعَلِّمِ ، عَنِ الْحَسَنِ ، عَنْ عَلِیٍّ : عِدَّۃُ الأَمَۃِ حَیْضَتَانِ فَإِنْ لَمْ تَکُنْ تَحِیضُ فَشَہْرٌ وَنِصْفٌ۔",,,19096,,
19097,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : عِدَّۃُ الأَمَۃِ حَیْضَتَانِ فَإِنْ لَمْ تَکُنْ تَحِیضُ فَشَہْرٌ وَنِصْفٌ۔",,,19097,,
19098,حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ مِثْلَہُ۔,,,19098,,
19099,"حَدَّثَنَا وَکِیعٌ ، عَنْ دَاوُدَ بْنِ قَیْسٍ قَالَ : سَأَلْتُ سَالِمَ بْنَ عَبْدِ اللہِ ، عَنْ عِدَّۃِ الأَمَۃِ فَقَالَ : حَیْضَتَانِ فَإِنْ لَمْ تَکُنْ تَحِیضُ فَشَہْرٌ وَنِصْفٌ۔",,,19099,,
19100,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ قَالَ : عِدَّۃُ الأَمَۃِ حَیْضَتَانِ۔",,,19100,,
19101,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ قَالَ : إِنْ کَانَتْ تَحِیضُ فَحَیْضَتَانِ ، وَإِنْ کَانَتْ ممن لاَ تَحِیضُ فَشَہْرٌ وَنِصْفٌ۔",,,19101,,
19102,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ مَطَرٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عُمَرَ قَالَ : عِدَّۃُ الأَمَۃِ حَیْضَتَانِ إِنْ کَانَتْ تَحِیضُ فَإِنْ لَمْ تَکُنْ تَحِیضُ فَشَہْرٌ وَنِصْفٌ۔",,,19102,,
19103,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرِو سَمع عَمْرَو بْنَ أَوْسٍ یَقُولُ : أَخْبَرَنِی رَجُلٌ مِنْ ثَقِیفٍ یَقُولُ : سَمِعْت عُمَرَ بْنَ الْخَطَّابِ یَقُولُ : لَوِ اسْتَطَعْت أَنْ أَجْعَلَ عِدَّۃَ الأَمَۃِ حَیْضَۃً وَنِصْفًا فَعَلْت فَقَالَ لَہُ رَجُلٌ : لَوْ جَعَلْتہَا شَہْرًا وَنِصْفًا فَسَکَتَ۔",,,19103,,
19104,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ قَالَ : عِدَّۃُ الأَمَۃِ حَیْضَتَانِ فَإِنْ لَمْ تَکُنْ تَحِیضُ فَشَہْرَانِ۔",,,19104,,
19105,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ فِی الأَمَۃِ الَّتِی لَمْ تَحِضْ وَقَدْ رَاہَقَتْ : عِدَّتُہَا خَمْسَۃٌ وَأَرْبَعُونَ یَوْمًا فَإِنْ کَانَتْ تَحِیضُ فَعِدَّتُہَا حَیْضَۃٌ۔",,,19105,,
19106,"حَدَّثَنَا أَبُو سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ فِی عِدَّۃِ الأَمَۃِ قَالَ : إِنْ کَانَتْ تَحِیضُ فَحَیْضَتَانِ ، وَإِنْ لَمْ تَکُنْ تَحِیضُ فَعِدَّتُہَا خَمْسَۃٌ وَأَرْبَعُونَ یَوْمًا۔",,,19106,,
19107,"حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ قَالَ : عِدَّۃُ الأَمَۃِ مِثْلُ نِصْفِ عِدَّۃِ الْحُرَّۃِ۔",,,19107,,
19108,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ فِی الأَمَۃِ الَّتِی تُوطَأُ : إذَا بِیعَتْ ، أَوْ وُہِبَتْ ، أَوْ أُعْتِقَتْ فَلْتُسْتَبْرَأْ بِحَیْضَۃٍ۔",,,19108,,
19109,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ أَبِیہِ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ فِی الأَمَۃِ إذَا أُعْتِقَتْ قَالَ : عِدَّتُہَا ثَلاَثُ حِیَضٍ۔",,,19109,,
19110,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنْ عَلِیٍّ فِی الأَمَۃِ إذَا أُعْتِقَتْ قَالَ: تَعْتَدُّ ثَلاَثَۃَ قُرُوئٍ۔",,,19110,,
19111,"حَدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ قَالَ : الأَمَۃُ إذَا أُعْتِقَتِ اعْتَدَّتْ بِحَیْضَتَیْنِ ، وَقَالَ الزُّہْرِیُّ : ثَلاَثَۃَ قُرُوئٍ۔",,,19111,,
19112,"حَدَّثَنَا عُمَرُ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ قَالَ : تَعْتَدُّ ثَلاَثَ حِیَضٍ۔",,,19112,,
19113,حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَمَرَ بَرِیرَۃَ أَنْ تَعْتَدَّ عِدَّۃَ الْحُرَّۃِ۔,,,19113,,
19114,حَدَّثَنَا ہُشَیْمٌ ، عَنْ خَالِدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ أَنَّ بَرِیرَۃَ اعْتَدَّتْ عِدَّۃَ الْحُرَّۃِ۔,,,19114,,
19115,حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنِ الزُّہْرِیِّ قَالَ بَرِیرَۃُ أُعْتِقَتْ فَاعْتَدَّتْ عِدَّۃَ الْحُرَّۃِ۔,,,19115,,
19116,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ فِی الأَمَۃِ طَلُقَتْ تَطْلِیقَتَیْنِ لَمْ یُدْرِکْہَا عَتَاقُہُ قَبْلَ أَنْ تَنْقَضِیَ قَالَ : تَعْتَدُّ عِدَّۃَ الأَمَۃِ۔",,,19116,,
19117,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : إذَا طُلِّقَتْ تَطْلِیقَۃً ، ثُمَّ أَدْرَکَہَا عَتَاقُہُ قَبْلَ أَنْ تَنْقَضِیَ عِدَّتُہَا اعْتَدَّتْ عِدَّۃَ الْحُرَّۃِ وَإِذَا طَلُقَتْ تَطْلِیقَتَیْنِ ، ثُمَّ أَدْرَکَتہَا عَتَاقُہُ اعْتَدَّتْ عِدَّۃَ الأَمَۃِ لَمَّا بَانَتْ مِنْہُ ، وَالْمُتَوَفَّی عَنْہَا کَذَلِکَ۔",,,19117,,
19118,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ أَنَّہُ قَالَ : إذَا طَلَّقَ الرَّجُلُ امْرَأَتَہُ وَہِیَ أَمَۃٌ تَطْلِیقَۃً ، ثُمَّ أُعْتِقَتْ فِی الْعِدَّۃِ فَعِدَّتُہَا عِدَّۃُ حُرَّۃٍ وَإِذَا طَلَّقَہَا تَطْلِیقَتَیْنِ ، ثُمَّ أُعْتِقَتْ قَالَ : لاَ یَتَزَوَّجُہَا حَتَّی تَزَوَّجَ زَوْجًا غَیْرَہُ ، وَعِدَّتُہَا عِدَّۃُ أَمَۃِ۔",,,19118,,
19119,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ زَیْدٍ ، عَنْ عَلِیِّ بْنِ الْحَکَمِ ، عَنِ الضَّحَّاکِ فِی الأَمَۃِ إذَا طُلِّقَتْ تَطْلِیقَتَیْنِ ، ثُمَّ أُعْتِقَتْ فِی عِدَّتِہَا قَالَ : تَعْتَدُّ حَیْضَتَیْنِ ، وَإِنْ طَلُقَتْ وَاحِدَۃً فَأُعْتِقَتْ فِی عِدَّتِہَا قَالَ : تَعْتَدُّ ثَلاَثَ حِیَضٍ وَزَوْجُہَا أَحَقُّ بِہَا۔",,,19119,,
19120,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ أَنَّہُ قَالَ : عِدَّتُہَا عِدَّۃُ الْحُرَّۃِ۔",,,19120,,
19121,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ قَالَ: حدَّثَنَا إسْمَاعِیلُ بْنُ أَبِی خَالِدٍ ، عَنْ عَامِرٍ قَالَ : إذَا طُلِّقَتِ الأَمَۃُ تَطْلِیقَتَیْنِ، ثُمَّ أُعْتِقَتْ عِنْدَ ذَلِکَ فَعِدَّتُہَا عِدَّۃُ الأَمَۃِ ، وَإِذَا طُلِّقَتْ وَاحِدَۃً ، ثُمَّ أُعْتِقَتْ عِنْدَ ذَلِکَ فَعِدَّتُہَا عِدَّۃُ الْحُرَّۃِ۔",,,19121,,
19122,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ فِی امْرَأَۃٍ مَاتَ عَنْہَا زَوْجُہَا ، ثُمَّ أُعْتِقَتْ قَالَ : تَمْضِی عَلَی عِدَّۃِ الأَمَۃِ وَلَیْسَ لَہَا إلاَّ عِدَّۃُ الأَمَۃِ۔",,,19122,,
19123,"حَدَّثَنَا عُمَرُ بْنُ زُرْعَۃَ ، عَنِ ابْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ، أَنَّہُ کَانَ یَقُولُ : إذَا تُوُفِّیَ عَنْہَا زَوْجُہَا وَہِیَ مَمْلُوکَۃٌ فَأَدْرَکَہَا الْعِتْقُ وَہِیَ فِی عِدَّتِہَا فتتم أَرْبَعَۃُ أَشْہُرٍ وَعَشْرًا۔",,,19123,,
19124,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ صَالِحِ بْنِ مُسْلِمٍ قَالَ : قُلْتُ لِلشَّعْبِیِّ : رَجُلٌ طَلَّقَ امْرَأَتَہُ فَجَائَ آخَرُ فَتَزَوَّجَہَا ؟ قَالَ عُمَرُ : یُفَرَّقُ بَیْنَہُمَا وَتُکْمِلُ عِدَّتَہَا الأُولَی ، وَتأْتنِف مِنْ ہَذَا عِدَّۃً جَدِیدَۃً وَیُجْعَلُ الصَّدَاقُ فِی بَیْتِ الْمَالِ وَلاَ یَتَزَوَّجُہَا الثَّانِی أَبَدًا ، وَیَصِیرُ الأَوَّلُ خَاطِبًا ، وَقَالَ عَلِیٌّ : یُفَرَّقُ بَیْنَہَا وَبَیْنَ زَوْجِہَا ، وَتُکْمِلُ عِدَّتَہَا الأُولَی ، وَتَعْتَدُّ مِنْ ہَذَا عِدَّۃً جَدِیدَۃً ، وَیُجْعَلُ لَہَا الصَّدَاقُ بِمَا اسْتَحَلَّ مِنْ فَرْجِہَا ، وَیَصِیرَانِ کِلاَہُمَا خَاطِبَیْنِ۔",,,19124,,
19125,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنْ إبْرَاہِیمَ وَالشَّعْبِیِّ فِی امْرَأَۃٍ تَزَوَّجَتْ فِی عِدَّتِہَا قَالَ الشَّعْبِیُّ : تَسْتَأْنِفُ ثَلاَثَۃَ قُرُوئٍ وَتُکْمِلُ مَا بَقِیَ عَلَیْہَا مِنَ الأَوَّلِ ، وَقَالَ إبْرَاہِیمُ : تُکْمِلُ مَا بَقِیَ مِنَ الأَوَّلِ وَتَسْتَأْنِفُ ثَلاَثَۃَ قُرُوئٍ۔",,,19125,,
19126,"حَدَّثَنَا یَحْیَی بْنُ عَبْدِ الْمَلِکِ بْنِ أَبِی غَنِیَّۃَ ، عَنْ أَبِیہِ ، عَنِ الْحَکَمِ قَالَ : یُفَرَّقُ بَیْنَہُمَا وَتُکْمِلُ عِدَّتَہَا مِنَ الأَوَّلِ ، وَتَعْتَدُّ مِنْ مَائِ الآخَرِ ، وَیَکُونُ لَہَا الْمَہْرُ بِمَا اسْتَحَلَّ مِنْ فَرْجِہَا ، فَإِذَا انْقَضَتْ عِدَّتُہَا فَلْتَزَوَّجْہُ ، أَوْ غَیْرَہُ إِنْ شَائَتْ۔",,,19126,,
19127,"حَدَّثَنَا عبد اللہ بْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنْ قَتَادَۃَ ، عَنْ خِلاَسٍ ، عَنْ عَلِیٍّ ؛ فِی الرَّجُلِ یَتَزَوَّجُ الأَمَۃَ وَلَہَا وَلَدٌ مِنْ غَیْرِہِ فَیَمُوتُ قَالَ : لاَ یَقْرَبُہَا حَتَّی یَتَبَیَّنَ لَہُ مَا فِی بَطْنِہَا ، أَوْ تَحِیضَ حَیْضَۃً۔",,,19127,,
19128,"حَدَّثَنَا یَحْیَی بْنُ زَکَرِیَّا ، عَنْ مُحَمَّدِ بْنِ مُسْلِمٍ ، عَنْ إبْرَاہِیمَ بْنِ مَیْسَرَۃَ ، عَنْ عُمَرَ قَالَ : لاَ یَقْرَبُہَا حَتَّی یَنْظُرَ ہل بہا حَبْلٌ ، أَوْ لاَ۔",,,19128,,
19129,"حَدَّثَنَا یحیی بْنُ عَیَّاشٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ حَسَّانِ بْنِ الْمُخَارِقِ أَنَّ الْحَسَنَ بْنَ عَلِیٍّ قَالَ : لاَ یَقْرَبُہَا حَتَّی تَعْتَدَّ ، أَوْ قَالَ : حَتَّی تَحِیضَ۔",,,19129,,
19130,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ أَنَّ الْحَسَنَ بْنَ عَلِیٍّ صَلَّی عَلَی جِنَازَۃٍ فَقَالَ لِلزَّوْجِ وَلِلْمَرْأَۃِ وَلَدٌ مِنْ غَیْرِہِ : لَیْسَ لَکَ أَنْ تَسْتَلْحِقَ سَہْمًا لَیْسَ لَک۔",,,19130,,
19131,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ وَعُمَارَۃَ قَالاَ : لاَ یَقْرَبُہَا حَتَّی یبین حَمْلٌ أَمْ لاَ۔",,,19131,,
19132,"حَدَّثَنَا ابْنُ أَبِی زَائِدَۃَ ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ قَالَ : لاَ یَقْرَبُہَا حَتَّی تَحِیضَ حَیْضَۃً۔",,,19132,,
19133,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدٍ ، وَالْحَسَنِ قَالاَ : أَجَّلَ عُمَرُ بْنُ الْخَطَّابِ الْعِنِّینَ سَنَۃً فَإِنِ اسْتَطَاعَہَا وَإِلاَّ فَرَّقَ بَیْنَہُمَا وَعَلَیْہَا الْعِدَّۃُ۔",,,19133,,
19134,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ قَالَ : إذَا مَضَتِ السَّنَۃُ اعْتَدَّتْ بَعْدَ السَّنَۃِ عِدَّۃَ الْمُطَلَّقَۃِ ، وَإِنْ لَمْ یُطَلِّقْہَا۔",,,19134,,
19135,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی امْرَأَۃِ الْعِنِّینِ قَالَ : عَلَیْہَا الْعِدَّۃُ إذَا فُرِّقَ بَیْنَہُمَا۔",,,19135,,
19136,"حَدَّثَنَا أَسْوَدُ بْنُ عَامِرٍ قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ ہِشَامِ بن عُرْوَۃَ ، عَنْ أَبِیہِ قَالَ : عَلَیْہَا الْعِدَّۃُ۔",,,19136,,
19137,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُوسَی بْنِ أَبِی کَثِیرٍ أَبِی الصَّبَّاحِ قَالَ : قُلْتُ لِسَعِیدِ بْنِ الْمُسَیَّبِ : کَمْ تَعْتَدُّ امْرَأَتُہُ ؟ یَعْنِی الْمُرْتَدَّ ، قَالَ : ثَلاَثَۃَ قُرُوئٍ ، قُلْتُ : فَإِنْ قُتِلَ ؟ قَالَ : أَرْبَعَۃَ أَشْہُرٍ وَعَشْرًا۔",,,19137,,
19138,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ وَالْحَکَمِ قَالاَ : ؛ فِی الرَّجُلِ الْمُسْلِمِ یَرْتَدُّ ، عَنِ الإِسْلاَمِ وَیَلْحَقُ بِأَرْضِ الْعَدُوِّ قَالاَ : تَعْتَدُّ امرأتہ ثَلاَثَۃَ قُرُوئٍ إِنْ کَانَتْ تَحِیضُ ، وَإِنْ کَانَتْ لاَ تَحِیضُ فَثَلاَثَۃَ أَشْہُرٍ ، وَإِنْ کَانَتْ حَامِلاً أن َتَضَعُ حَمْلَہَا ، ثُمَّ تَزَوَّجُ إِنْ شَائَتْ ، وَإِنْ ہُوَ رَجَعَ فَتَابَ قَبْلَ أَنْ تَنْقَضِیَ عِدَّتُہَا یَثْبُتَانِ عَلَی نِکَاحِہِمَا۔",,,19138,,
19139,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ إسْمَاعِیلَ ، عَنِ الْحَسَنِ قَالَ : إذَا ارْتَدَّ الرَّجُلُ ، عَنِ الإِسْلاَمِ فَقَدْ بَانَتْ مِنْہُ امْرَأَتُہُ بِتَطْلِیقَۃٍ بَائِنَۃٍ وَلَیْسَ عَلَیْہَا سَبِیلٌ إِنْ رَجَعَ وَتَعْتَدُّ عِدَّۃَ الْمُطَلَّقَۃِ۔",,,19139,,
19140,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ إسْمَاعِیلَ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ قَالَ : ہُوَ أَحَقُّ بہا مَا دَامَتْ فِی الْعِدَّۃِ، إِنْ رَجَعَ وَہِیَ فِی عِدَّتِہَا فَہِیَ امْرَأَتُہُ ، قَالَ أَبُو مَعْشَرٍ : فَکَتَبَ بِذَلِکَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ إلَی عَبْدِ الْحَمِیدِ بْنِ عَبْدِ الرَّحْمَنِ فِی الْمُرْتَدِّ۔",,,19140,,
19141,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ زِیَادٍ ، عَنْ عَبْدِ الرَّحْمَنِ قَالَ : سَأَلْتُ الشَّعْبِیَّ ، عَنِ امْرَأَۃٍ ذِمِّیَّۃٍ طُلِّقَتْ فَأَسْلَمَتْ فِی عِدَّتِہَا ، قَالَ : إذَا أَسْلَمَتْ فِی عِدَّتِہَا لَزِمَہَا مَا لَزِمَ الْمُسْلِمَاتِ۔",,,19141,,
19142,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ أَبِی حُرَّۃَ قَالَ : سُئِلَ الْحَسَنُ ، عَنْ نَصْرَانِیَّۃٍ تحت نَصْرَانِیٍّ فَأَسْلَمَتْ یُفَرَّقُ بَیْنَہُمَا ؟ قَالَ : نَعَمْ ، قَالَ : عَلَیْہَا عِدَّۃٌ قَالَ : نَعَمْ ، عَلَیْہَا عِدَّۃُ ثَلاَثِ حِیَضٍ ، أَوْ ثَلاَثَۃِ أَشْہُرٍ۔",,,19142,,
19143,"حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ عَبْدِ الْمَلِکِ قَالَ : سُئِلَ عَطَائٌ ، عَنِ الْمَرْأَۃِ یَمُوتُ زَوْجُہَا وَہو نَصْرَانِیّ ، ثُمَّ تُسْلِمُ کَمْ تَعْتَدُّ ؟ قَالَ : أَرْبَعَۃَ أَشْہُرٍ وَعَشْرًا۔",,,19143,,
19144,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ أَنَّہُ کَانَ یَقُولُ : طَلاَقُ الْیَہُودِیَّۃِ وَالنَّصْرَانِیَّۃ طَلاَقُ الْمُسْلِمَۃِ وَعِدَّتُہُمَا عِدَّۃُ الْحُرَّۃِ الْمُسْلِمَۃِ۔",,,19144,,
19145,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، وَالْحَسَنِ فِیمَنْ تَزَوَّجَ الْیَہُودِیَّۃَ ، أَوِ النَّصْرَانِیَّۃَ عَلَی الْمُسْلِمَۃِ قَالَ : یَقْسِمُ بَیْنَہُمَا سَوَائً وَطَلاَقُہَا طَلاَقُ حُرَّۃٍ وَعِدَّتُہَا کَذَلِکَ۔",,,19145,,
19146,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ عُبَیْدَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : طَلاَقُ الْیَہُودِیَّۃِ وَالنَّصْرَانِیَّۃ طَلاَقُ الْحُرَّۃِ وَعِدَّتُہُمَا عِدَّۃُ الْحُرَّۃِ وَیَقْسِمُ لَہُمَا کَمَا یَقْسِمُ لِلْحُرَّۃِ۔",,,19146,,
19147,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ قَالَ : عِدَّۃُ النَّصْرَانِیَّۃِ مِثْلُ عِدَّۃِ الْمُسْلِمَۃِ وَقِسْمَتُہُمَا سَوَائٌ۔",,,19147,,
19148,"حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ مُطَرِّفٍ ، عَنْ عَامِرٍ ؛ فِی الرَّجُلِ یَتَزَوَّجُ الْمُسْلِمَۃَ وَالْیَہُودِیَّۃَ ، أَوِ النَّصْرَانِیَّۃَ قَالَ : یُسَوِّی بَیْنَہُمَا فی الْقَسم مِنْ مَالِہِ وَنَفْسِہِ۔",,,19148,,
19149,"حَدَّثَنَا شَبَابَۃُ ، عَنْ شُعْبَۃَ قَالَ : سَأَلْتُ الْحَکَمَ وَحَمَّادًا عَنِ الرَّجُلِ یَتَزَوَّجُ النَّصْرَانِیَّۃَ فَقَالاَ : قِسْمَتُہُمَا سَوَائٌ۔",,,19149,,
19150,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ لَیْثٍ ، عَنْ أَبِی عَمْرٍو الْعَبْدِیِّ ، عَنْ عَلِیٍّ قَالَ : إذَا وَضَعَتْ وَلَدًا وَبَقِیَ فِی بَطْنِہَا وَلَدٌ فَہُوَ أَحَقُّ بِہَا مَا لَمْ تَضَعِ الآخَرَ۔",,,19150,,
19151,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائِ بْنِ مَیْسَرَۃَ ، عَنِ ابْنِ عَبَّاسٍ قَالَ : إذَا وَضَعَتْ وَلَدًا وَبَقِیَ فِی بَطْنِہَا وَلَدٌ فَہُوَ أَحَقُّ بِرَجْعَتِہَا مَا لَمْ تَضَعِ الآخَرَ۔",,,19151,,
19152,حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ مِثْلَہُ۔,,,19152,,
19153,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدِ بْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، وَعَطَائٍ وَسُلَیْمَانَ بْنِ یَسَارٍ ؛ فِی الرَّجُلِ یُطَلِّقُ امْرَأَتَہُ تَطْلِیقَۃً فَتَضَعُ وَلَدًا ، ویکون فِی بَطْنِہَا آخَرُ ، فَیُرَاجِعُہَا زَوْجُہَا فِیمَا بَیْنَ ذَلِکَ قَالُوا : إِنْ شَائَ رَاجَعَہَا حَتَّی تَضَعَ الآخَرَ مِنْہما۔",,,19153,,
19154,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ ہِشَامٍ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ فِی رَجُلٍ طَلَّقَ امْرَأَتَہُ وَفِی بَطْنِہَا وَلَدَانِ ، قَالَ ہُوَ أَحَقُّ بِرَجْعَتِہَا مَا لَمْ تَضَعَ الآخَرَ وَتَلاَ : {وَأُولاَتُ الأَحْمَالِ أَجَلُہُنَّ أَنْ یَضَعْنَ حَمْلَہُنَّ}۔",,,19154,,
19155,حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ فِی الَّذِی یُطَلِّقُ وَفِی بَطْنِہَا الولدان قَالَ لَہُ الرَّجْعَۃُ حَتَّی تَضَعَ مَا فِی بَطْنِہَا۔,,,19155,,
19156,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ قَالَ ہُوَ أَحَقُّ بِہَا مَا لَمْ تَضَعِ الآخَرَ۔,,,19156,,
19157,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ وَالحَسَن وَسُلَیْمَانَ بْنِ یَسَارٍ وَعَطَائِ بْنِ أَبِی رَبَاحٍ قَالُوا : ہُوَ أَحَقُّ بِہَا مَا لَمْ تَضَعَ الآخَرَ۔",,,19157,,
19158,"حَدَّثَنَا ابْنُ أَبِی زَائِدَۃَ ، عَنْ زَکَرِیَّا ، عَنْ عَامِرٍ قَالَ : کَانُوا یَقُولُونَ : لَوْ کَانَ وَلَدٌ وَاحِدٌ خَرَجَ مِنْہُ طَائِفَۃٌ کان یَمْلِکُ الرَّجْعَۃَ مَا لَمْ یَخْرُجْ کُلُّہُ۔",,,19158,,
19159,"حَدَّثَنَا وَکِیعٌ قَالَ: حدَّثَنَا ابْنُ أَبِی خَالِد، عَنِ أَبِی حَنْظَلَۃَ، عَنِ الشَّعْبِیِّ قَالَ: ہُوَ أَحَقُّ بِہَا مَا لَمْ تَضَعِ الآخَرَ۔",,,19159,,
19160,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ قَالَ : إذَا تُوُفِّیَ الرَّجُلُ ، أَوْ طَلَّقَ امْرَأَتَہُ وَہِیَ حَامِلٌ فَوَضَعَتْ وَلَدًا وَبَقِیَ فِی بَطْنِہَا آخَرُ فَقَدِ انْقَضَتْ عِدَّتُہَا بِالأَوَّلِ۔",,,19160,,
19161,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، عَنْ إبْرَاہِیمَ قَالَ : إذَا وَضَعَتْ أَحَدَہُمَا فَقَدْ بَانَتْ۔",,,19161,,
19162,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ عِکْرِمَۃَ قَالَ : إذَا وَضَعَتِ الأَوَّلَ فَقَدْ بَانَتْ ، قَالَ : قِیلَ لَہُ : تُزَوَّجُ ؟ قَالَ : لاَ ، قَالَ قَتَادَۃُ : خُصِم الْعَبْدُ۔",,,19162,,
19163,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : تَعْتَدُّ الْمُطَلَّقَۃُ فِی بَیْتِ زَوْجِہَا ، وَلاَ تَکْتَحِلُ بِکُحْلٍ زِینَۃً۔",,,19163,,
19164,"حَدَّثَنَا ابْنُ أَبِی زَائِدَۃَ ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ ، عَنْ مَسْرُوقٍ قَالَ : جَائَ رَجُلٌ إلَی عَبْدِ اللہِ فَقَالَ : إنِّی طَلَّقْتُ امْرَأَتِی ثَلاَثًا ، وَإِنَّہَا تُرِیدُ أَنْ تَخْرُجَ ، قَالَ : احْبِسْہَا ، قَالَ : لاَ تجلس قَالَ : قَیِّدْہَا قَالَ : إنَّ لَہَا إخْوَۃً غَلِیظَۃٌ رِقَابُہُمْ ، قَالَ : اسْتَعْدِ الأَمِیرَ۔",,,19164,,
19165,"حَدَّثَنَا جَرِیرٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ قَالَ : الْمُطَلَّقَۃُ تَزُورُ وَلاَ تَبِیتُ۔",,,19165,,
19166,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدِ بْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : الْمُطَلَّقَۃُ ثَلاَثًا لاَ تَخْرُجُ مِنْ بَیْتِ زَوْجِہَا وَلاَ تَمَسُّ طِیبًا إلاَّ عِنْدَ الطُّہْرِ بنُبذۃ مِنْ قُسْطٍ وَأَظْفَارٍ۔",,,19166,,
19167,"حَدَّثَنَا أَبُو زُکَیر یَحْیَی بْنُ مُحَمَّدٍ الْقُرَشِیُّ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ نَضْلَۃَ قَالَ : طَلَّقْتُ بِنْت عَمٍّ لِی ثَلاَثًا الْبَتَّۃَ فَأَتَیْت سَعِیدَ بْنَ الْمُسَیَّبِ أَسْأَلُہُ فَقَالَ : تَعْتَدُّ فِی بَیْتِ زَوْجِہَا حَیْثُ طُلِّقَتْ ، قَالَ : وَسَأَلْت الْقَاسِمَ وَسَالِمًا وَأَبَا بَکْرِ بْنَ عَبْدِ الرَّحْمَنِ بْنِ الْحَارِثِ وَخَارِجَۃَ بْنَ زَیْدٍ وَسُلَیْمَانَ بْنَ یَسَارٍ فکُلُّہُمْ یَقُولُ مِثْلَ قَوْلِ سَعِیدٍ۔",,,19167,,
19168,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ فِی الْمُطَلَّقَۃِ ثَلاَثًا وَالْمُتَوَفَّی عَنْہَا زَوْجُہَا : تَعْتَدَّانِ فِی بَیْتِ زَوْجَیْہِمَا وَتُحِدَّانِ۔",,,19168,,
19169,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنِ الْقَاسِمِ أَنَّ یَحْیَی بْنَ سَعِیدِ بْنِ الْعَاصِ طَلَّقَ امْرَأَتَہُ بِنْتَ عَبْدِ الرَّحْمَنِ بْنِ الْحَکَمِ ، فَانْطَلَقَتْ إلَی أَہْلِہَا ، فَأَرْسَلَتْ عَائِشَۃُ إلَی مَرْوَانَ : اتَّقِ اللَّہَ وَرُدَّ الْمَرْأَۃَ إلَی بَیْتِہَا ، فَقَالَ مَرْوَانُ : إنَّ عَبْدَ الرَّحْمَنِ غَلَبَنِی۔",,,19169,,
19170,"حَدَّثَنَا عَبْدَۃُ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ قَالَ : لاَ تَبِیتُ الْمَبْتُوتَۃُ وَلاَ الْمُتَوَفَّی عَنْہَا زَوْجُہَا إلاَّ فِی بَیْتِہَا حَتَّی تَنْقَضِیَ عِدَّتُہَا۔",,,19170,,
19171,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ یَحْیَی بْنِ سَعِیدٍ قَالَ : طُلِّقَتِ امْرَأَۃٌ بِالْمَدِینَۃِ فَسُئِلَ فُقَہَائُ أَہْلِ الْمَدِینَۃِ فَقَالُوا : تَمْکُثُ فِی بَیْتِہَا ، فَسُئِلَ سَعِیدٌ : فَقَالَ : تَمْکُثُ۔",,,19171,,
19172,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ قَالَ : قالَتْ فَاطِمَۃُ بِنْتُ قَیْسٍ : یَا رَسُولَ اللہِ ، إنِّی أَخَافُ أَنْ یُقْتَحَمَ عَلَیَّ قَالَ : فَأَمَرَہَا أَنْ تَحَوَّلَ۔ (مسلم 1121۔ ابن ماجہ 2033)",,,19172,,
19173,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُس ، عَنِ الْحَسَنِ ؛ فِی الْمُطَلَّقَۃِ ثَلاَثًا : تَعْتَدُّ فِی غَیْرِ بَیْتِہَا إِنْ شَائَتْ۔",,,19173,,
19174,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ، عَنْ حَبِیبٍ قَالَ: سَأَلْتُ عَطَائً فَقَالَ: تَعْتَدُّ حَیْثُ شَائَتْ، وَقَالَہُ الْحَسَنُ أَیْضًا۔",,,19174,,
19175,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ قَالَ: حَدَّثَنَا مُحَمَّدُ بن عَمرو قَالَ : حدَّثَنَا أَبُو سَلَمَۃَ ، عَنْ فَاطِمَۃَ بِنْتِ قَیْسٍ قَالَ : کَتَبْتُ ذَلِکَ مِنْ فِیہَا کِتَابًا ، قَالَتْ: کُنْتُ عِنْدَ رَجُلٍ مِنْ بَنِی مَخْزُومٍ فَطَلَّقَنِی الْبَتَّۃَ، فَقَالَ لِی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: انْتَقِلِی إلَی ابْنِ أُمِّ مَکْتُومٍ، فَإِنَّہُ رَجُلٌ قَدْ ذَہَبَ بَصَرُہُ، فَإِنْ وَضَعْت شَیْئًا لَمْ یَرَ شَیْئًا۔\n\n(مسلم 1116۔ ابوداؤد 2278)",,,19175,,
19176,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ سُئِلَ عَنِ امْرَأَۃٍ طُلِّقَتْ وَہِیَ سَاکِنَۃٌ فِی بَیْتٍ بِکِرَائٍ فَقَالَ : إِنْ أَحْسَنَ أَنْ یُعْطِیَ أَجْرًا وَتَمْکُثَ فِی بَیْتِہَا حَتَّی تَنْقَضِیَ عِدَّتُہَا۔",,,19176,,
19177,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ یَحْیَی بْنِ سَعِیدٍ قَالَ : سُئِلَ سعید بْنُ الْمُسَیَّبِ ، عَنِ امْرَأَۃٍ طُلِّقَتْ وَہِیَ فِی بَیْتٍ بِکِرَائٍ عَلَی مَنِ الْکِرَائُ ؟ قَالَ : عَلَی زَوْجِہَا۔",,,19177,,
19178,حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ حَبِیبِ بْنِ أَبِی ثَابِتٍ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ، وَعَنْ سُفْیَانَ، عَنْ مَنْصُورٍ، عَنْ مُجَاہِدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ أَنَّ عُمَرَ رَدَّ نِسْوَۃً حَاجَّاتٍ ، أَوْ مُعْتَمِرَاتٍ خَرَجْنَ فِی عِدَّتِہِنَّ۔,,,19178,,
19179,حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ حُمَیْدٍ الأَعْرَجِ عن مجاہد أَنَّ عُمَرَ وَعُثْمَانَ رَدَّا نِسْوَۃً حَوَاجَّ أوْ مُعْتَمِرَاتٍ حَتَّی اعْتَدَدْنَ فِی بُیُوتِہِنَّ۔,,,19179,,
19180,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ أَنَّ ابْنَ مَسْعُودٍ رَدَّ نِسْوَۃً حَاجَّاتٍ أو مُعْتَمِرَاتٍ خَرَجْنَ فِی عِدَّتِہِنَّ۔,,,19180,,
19181,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی الْمِقْدَامِ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : الْمُتَوَفَّی عَنْہَا وَالْمُطَلَّقَۃُ لاَ تَحُجُّ وَلاَ تَعْتَمِرُ وَلاَ تَلْبَسُ مُجْسَدًا۔",,,19181,,
19182,حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ مُبَارَکٍ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ أَنَّ ابْنَ عُمَرَ زَجَرَ امْرَأَۃً تَحُجُّ فِی عِدَّتِہَا۔,,,19182,,
19183,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ أَشْعَثَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ قَالَ : رَدَّ عُمَرُ بْنُ الْخَطَّابِ نِسْوَۃً مِنْ ذِی الْحُلَیْفَۃِ حَاجَّاتٍ قُتِلَ أَزْوَاجُہُنَّ فِی بَعْضِ تِلْکَ الْمِیَاہِ۔",,,19183,,
19184,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ مَالِکِ بْنِ أَنَسٍ ، عَنْ حُمَیْدِ بْنِ قَیْسٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : رَدَّ عُمَرُ نِسْوَۃَ الْمُتَوَفَّی عَنْہُنَّ أَزْوَاجُہُنَّ مِنَ الْبَیْدَائِ ، فَمَنَعَہُنَّ الْحَجَّ۔",,,19184,,
19185,حَدَّثَنَا وَکِیعٌ ، عَنْ أُسَامَۃَ ، عَنِ الْقَاسِمِ ، وَعَنْ جَرِیرِ بْنِ حَازِمٍ ، عَنْ عَطَائٍ أَنَّ عَائِشَۃَ أَحَجَّتْ أُمَّ کُلْثُومٍ فِی عِدَّتِہَا۔,,,19185,,
19186,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا لِلْمُطَلَّقَاتِ ثَلاَثًا وَالْمُتَوَفَّی عَنْہُنَّ أَزْوَاجُہُنَّ أَنْ یَحْجُجْنَ فِی عِدَّتِہِنَّ۔,,,19186,,
19187,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ حَبِیبٍ الْمُعَلِّمِ قَالَ : سَأَلْتُ عَطَائً عَنِ الْمُطَلَّقَۃِ ثَلاَثًا وَالْمُتَوَفَّی عَنْہَا : تَحُجَّانِ عَنْہُمَا فِی عِدَّتِہِمَا ؟ قَالَ : نَعَمْ ، وَقَالَ حَبِیبٌ : وَکَانَ الْحَسَنُ یَقُولُ مِثْلَ ذَلِکَ۔",,,19187,,
19188,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ سَعْدِ بْنِ إِسْحَاقَ ، عَنْ زَیْنَبَ بِنْتِ کَعْبِ بْنِ عُجْرَۃَ وَکَانَتْ تَحْتَ أَبِی سَعِیدٍ الْخُدْرِیِّ أَنَّ أُخْتَہُ الفُرَیْعَۃَ ابْنَۃَ مَالِکٍ قَالَتْ : خَرَجَ زَوْجِی فِی طَلَبِ أَعْلاَجٍ لَہُ فَأَدْرَکَہُمْ بِطَرَفِ الْقَدُوم فَقَتَلُوہُ فَجَائَ نَعْیُ زَوْجِی وَأَنَا فِی دَارٍ مِنْ دُورِ الأَنْصَارِ شَاسِعَۃٍ عَنْ دُورِ أَہْلِی فَأَتَیْت النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقُلْت : یَا رَسُولَ اللہِ ، إنَّہُ أَتَانِی نَعْیُ زَوْجِی وَأَنَا فِی دَارٍ شَاسِعَۃٌ ، عَنْ دَارِ أَہْلِی وَدَارِ إخْوَتِی وَلَمْ یَدَعْ مَالاً یُنْفَقُ عَلَیَّ وَلاَ مَالَ وَرِثْتہ وَلاَ دَارَ یَمْلِکُہَا فَإِنْ رَأَیْت أَنْ تَأْذَنَ فَأَلْحَقَ بدَارِ أَہْلِی ، ودَارِ إخْوَتِی ، فَإِنَّہُ أَحَبُّ إلَیَّ وَأَجْمَعُ إلَیَّ بَعْضَ أَمْرِی قَالَ : فَافْعَلِی إِنْ شِئْتِ ، قَالَتْ : فَخَرَجْت قَرِیرَۃَ عَیْنٍ لِمَا قَضَی اللَّہُ عَلَی لِسَانِ رَسُولِہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَتَّی إذَا کُنْتُ فِی الْمَسْجِدِ ، أَوْ فِی بَعْضِ الْحُجْرَۃِ دَعَانِی فقال : کَیْفَ زَعَمْت ؟ قَالَتْ : فَقَصَصْت عَلَیْہِ الْقِصَّۃَ ، قَالَ : امْکُثِی فِی بَیْتِکَ الَّذِی کَانَ فِیہِ نعی زَوْجُک حَتَّی یَبْلُغَ الْکِتَابُ أَجَلَہُ ، قَالَتْ : فَاعْتَدَدْت فِیہِ أَرْبَعَۃَ أَشْہُرٍ وَعَشْرًا۔ (ترمذی 1204۔ ابوداؤد 2294)",,,19188,,
19189,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، عَنْ عَلْقَمَۃَ أَنَّ نِسْوَۃً مِنْ ہَمْدَانَ قُتِلَ عَنْہُنَّ أَزْوَاجُہُنَّ فَقَالَ عَبْدُ اللہِ : یَجْتَمِعْنَ بِالنَّہَارِ وَیَبِتْنَ فِی بُیُوتِہِنَّ۔",,,19189,,
19190,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ قَالَ : تُوُفِّیَ عَنْ نِسْوَۃٍ مِنْ ہَمْدَانَ أَزْوَاجُہُنَّ فَأَرَدْنَ أَنْ یَجْتَمِعْنَ فِی بَیْتِ امْرَأَۃٍ مِنْہُمْ یَعْتَدِدْنَ فَأَرْسَلْنَ إلَی ابْنِ مَسْعُودٍ یَسْأَلْنَہُ قَالَ : تَعْتَدُّ کُلُّ امْرَأَۃٍ فِی بَیْتِہَا۔",,,19190,,
19191,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ یُوسُفَ بْنِ مَاہَکَ ، عَنْ أُمِّہِ مُسَیْکَۃَ أَنَّ امْرَأَۃً زَارَتْ أَہْلَہَا وَہِیَ فِی عِدَّۃٍ فَتَمَخَّضَتْ عِنْدَہُم فَبَعَثُونِی إلَی عُثْمَانَ بَعْدَ ما صَلَّی الْعِشَائَ وَأَخَذَ مَضْجَعَہُ فَقُلْت : إنَّ فُلاَنَۃَ زَارَتْ أَہْلَہَا وَہِیَ فِی عِدَّتِہَا وَہِیَ تَمْخُضُ فَمَا تَأْمُرُنِی ؟ قَالَ : فَأَمَرَ بِہَا أَنْ تُحْمَلَ إلَی بَیْتِہَا فِی تِلْکَ الْحَالِ۔",,,19191,,
19192,حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ مُبَارَکٍ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنِ ابْنِ ثَوْبَانَ أَنَّ امْرَأَۃً تُوُفِّیَ عَنْہَا زَوْجُہَا وَبِہَا فَاقَۃٌ فَسَأَلَتْ عُمَرَ أَنْ تَأْتِیَ أَہْلَہَا ؟ فَرَخَّصَ لَہَا أَنْ تَأْتِیَ أَہْلَہَا بَیَاضَ یَوْمِہَا۔,,,19192,,
19193,حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ مُبَارَکٍ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ أَنَّ امْرَأَۃً مِنَ الأَنْصَارِ تُوُفِّیَ عَنْہَا زَوْجُہَا فَسَأَلَتْ زَیْدَ بْنَ ثَابِتٍ فَلَمْ یُرَخِّصْ لَہَا إلاَّ فِی بَیَاضِ یَوْمِہَا أَو لَیْلَتِہَا۔,,,19193,,
19194,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ قَالَ : کَانَتِ امْرَأَۃٌ تَعْتَدُّ مِنْ زَوْجِہَا ، تُوُفِّیَ عَنْہَا ، فَاشْتَکَی أَبُوہَا، فَأَرْسَلَتْ إلَی أُمِّ سَلَمَۃَ تَسْأَلُہَا: تَأْتِی أَبَاہَا تُمَرِّضُہُ؟ فَقَالَتْ: إذَا کُنْتِ إِحَدَی طَرَفَیِ النَّہَارِ فِی بَیْتِکِ۔",,,19194,,
19195,"حَدَّثَنَا وَکِیعٌ، عَنْ إسْمَاعِیلَ، قَالَ: سَمِعْتُ إبْرَاہِیمَ یَقُولُ: الْمُتَوَفَّی عَنْہَا زَوْجُہَا لاَ تَبِیتُ فِی غَیْرِ بَیْتِہَا۔",,,19195,,
19196,حَدَّثَنَا وَکِیعٌ ، عَنْ أُسَامَۃَ بْنِ زَیْدٍ ، عَنْ نَافِعٍ أَنَّ امْرَأَۃً تُوُفِّیَ زَوْجُہَا فَاعْتَدَّتْ فِی غیر بَیْتِہَا یَوْمًا فَأَمَرَہَا ابْنُ عُمَرَ أَنْ تَقْضِیَہُ۔,,,19196,,
19197,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ قَالَ : سَأَلْتُ أَبِی ، عَنِ الْمُتَوَفَّی عَنْہَا زَوْجُہَا ، أَتَنْتَقِلُ ؟ قَالَ : لاَ ، إلاَّ أَنْ یَنْتَقِلَ أَہْلُہَا فَتَنْتَقِلَ مَعَہُمْ۔",,,19197,,
19198,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ خُصَیْفٍ قَالَ : سَأَلْتُ سَعِیدَ بْنَ الْمُسَیَّبِ ، عَنِ الْمُتَوَفَّی عَنْہَا زَوْجُہَا تَخْرُجُ مِنْ بَیْتِہَا ؟ قَالَ : لاَ۔",,,19198,,
19199,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ قَالَ : کَانَ عُمَرُ وَعَبْدُ اللہِ یَقُولاَنِ : لاَ تَنْتَقِلُ۔",,,19199,,
19200,"حَدَّثَنَا عَبْدَۃُ ، عَنْ إسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ قَالَ : کَانَ أَصْحَابُ عَبْدِ اللہِ یَقُولُونَ : لاَ تَخْرُجُ حَتَّی تُوَفِّیَ أَجَلَہَا فِی بَیْتِ زَوْجِہَا۔",,,19200,,
19201,حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ أَنَّ امْرَأَۃً مِنَ الأَنْصَارِ تُوُفِّیَ عَنْہَا زَوْجُہَا وَأَنَّ أَبَاہَا اشْتَکَی فَاسْتَأْذَنَتْ عُمَرَ فَلَمْ یُرَخِّصْ لَہَا إلاَّ فِی لَیلۃ۔,,,19201,,
19202,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنَ ، عَنْ عَوْفِ بْنِ أَبِی جمیلۃ قَالَ : تُوُفِّیَ صَدِیقٌ لِی وَتَرَکَ زرعا لَہُ بِقُبَائَ فَجَائَتِ امْرَأَتُہُ فَقَالَتْ : سَلِ ابْنَ عُمَرَ أَخْرُجُ فَأَقُومُ عَلَیْہِ ؟ فَأَتَیْت ابْنَ عُمَرَ فَقَالَ : تَخْرُجُ بِالنَّہَارِ وَلاَ تَبِیتُ بِاللَّیْلِ۔",,,19202,,
19203,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : أَخْبَرَنَا ابْنُ عَوْنٍ ، عَنْ أَنَسِ بْنِ سِیرِینَ أَنَّ ابْنَۃً لِعَبْدِ اللہِ بْنُ عُمَرَ تُوُفِّیَ زَوْجُہَا فَأَتَتْہُمْ فَأَرَادَتْ أَنْ تَبِیتَ عِنْدَہُمْ فَمَنَعَہَا عَبْدُ اللہِ بْنُ عُمَرَ وَقَالَ : ارْجِعِی إلَی بَیْتِکَ فَبِیتِی فِیہِ۔",,,19203,,
19204,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مَنْصُورٍ ، عَنِ الْحَکَمِ قَالَ : نَقَلَ عَلِیُّ أُمَّ کُلْثُومٍ حِیَن قُتِلَ عُمَرُ وَنَقَلَتْ عَائِشَۃُ أُخْتَہَا حِینَ قُتِلَ طَلْحَۃُ۔",,,19204,,
19205,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ قَالَ : تَخْرُجُ۔",,,19205,,
19206,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ عَطَائٍ وَأَبِی الشَّعْثَائِ فِی الْمُتَوَفَّی عَنْہَا قَالاَ : تَخْرُجُ۔",,,19206,,
19207,"حَدَّثَنَا مُحَمَّدُ بْنُ مُیَسَّرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، وَعَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ أنہما قَالاَ : تَعْتَدُّ الْمُتَوَفَّی عَنْہَا زَوْجُہَا حَیْثُ شَائَتْ۔",,,19207,,
19208,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ إسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ قَالَ : کَانَ عَلِیٌّ یُرَحِّلُ الْمُتَوَفَّی عَنْہَا زَوْجُہَا۔",,,19208,,
19209,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ فِرَاسٍ ، عَنِ الشَّعْبِیِّ أَنَّ عَلِیًّا نَقَلَ أُمَّ کُلْثُومٍ بَعْدَ سَبْعٍ۔,,,19209,,
19210,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ فِی رَجُلٍ طَلَّقَ امْرَأَتَہُ فَحَاضَتْ حَیْضَۃً ، أَوْ حَیْضَتَیْنِ وَتَزَوَّجَتْ فِی عِدَّتِہَا فَانْقَضَتْ عِدَّتُہَا عِنْدَ زَوْجِہَا فَقَالَ : بَانَتْ مِنْہُ بِتَطْلِیقَۃٍ۔",,,19210,,
19211,"حَدَّثَنَا عَبْدُ الأَعْلَی قَالَ : سُئِلَ سَعِیدٌ عَنْ رَجُلٍ تَزَوَّجَ امْرَأَۃً فِی عِدَّتِہَا ، ثُمَّ عَلِمَ إِنَّہُ تَزَوَّجَہَا فِی عِدَّتِہَا وَقَدِ انْقَضَتْ عِدَّتُہَا عِنْدَہُ ، ہَلْ لِزَوْجِہَا الأَوَّلِ عَلَیْہَا رَجْعَۃٌ فَحَدَّثَنَا عَنْ عَلِیِّ بْنِ الْحَکَمِ ، عَنْ مُحَمَّدِ بْنِ زَیدٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ أَنَّہُ قَالَ : یُفَرَّقُ بَیْنَہُمَا وَلاَ رَجْعَۃَ لَہُ عَلَیْہَا لأَنَّ عِدَّتَہَا قَدِ انْقَضَتْ عِنْدَ ہَذَا۔",,,19211,,
19212,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ أَنَّہُ قَالَ : زَوْجُہَا أَحَقُّ بِہَا وَلاَ یَقْرَبُہَا حَتَّی تَنْقَضِیَ عِدَّتُہَا۔",,,19212,,
19213,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ فِی رَجُلٍ طَلَّقَ امْرَأَتَہُ تَطْلِیقَۃً ، أَوْ تَطْلِیقَتَیْنِ فَحَاضَتْ عِنْدَہُ حَیْضَتَیْنِ ، ثُمَّ تزَوَّجَہَا رَجُلٌ فَحَاضَتْ عِنْدَہُ حَیْضَتَیْنِ قَالَ : بَانَتْ مِنَ الأَوَّلِ وَلاَ تُحْتَسَبُ بِہِ لِمَنْ بَعْدَہُ۔",,,19213,,
19214,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ قَالَ : تُحْتَسَبُ بِہِ۔",,,19214,,
19215,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَن قَالَ : إِنْ تُوُفِّیَ عَنْہَا زَوْجُہَا یَعْنِی الأَمَۃَ اعْتَدَّتْ شَہْرَیْنِ وَخَمْسَ لَیَالٍ۔",,,19215,,
19216,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ قَالَ : عِدَّۃُ الأَمَۃِ إذَا مَاتَ عَنْہَا زَوْجُہَا نِصْفُ عِدَّۃِ الْحُرَّۃِ شَہْرَانِ وَخَمْسَۃُ أَیَّامٍ۔",,,19216,,
19217,حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ شَیْبَانَ ، عَنْ فِرَاسٍ ، عَنِ الشَّعْبِیِّ فِی مَمْلُوکَۃٍ تُوُفِّیَ عَنْہَا زَوْجُہَا حُرًّا فَعِدَّتُہَا شَہْرَانِ وَخَمْسَۃُ أَیَّامٍ۔,,,19217,,
19218,"حَدَّثَنَا شَبَابَۃُ ، عَنْ لَیْثِ بْنِ سَعْدٍ ، عَنْ بُکَیْر ، عَنِ ابْنِ الْمُسَیَّبِ ، وَابْنِ قُسَیْطٍ فِی الأَمَۃِ : إذَا تُوُفِّیَ عَنْہَا زَوْجُہَا حُرًّا فَعِدَّتُہَا شَہْرَانِ وَخَمْسَۃُ أَیَّامٍ۔",,,19218,,
19219,"حَدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ فِی الأَمَۃِ : إذَا مَاتَ عَنْہَا زَوْجُہَا اعْتَدَّتْ عِدَّۃَ الْحُرَّۃِ۔",,,19219,,
19220,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ أَنَّ مُعَاوِیَۃَ سَأَلَ زَیْدَ بْنَ ثَابِتٍ فَقَالَ : إذَا طَعَنَتْ فِی الْحَیْضَۃِ الثَّالِثَۃِ فَقَدْ بَرِئَتْ مِنْہُ۔",,,19220,,
19221,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مُغِیرَۃَ ، عَنْ مُوسَی بْنِ شَدَّادٍ ، عَنْ عُمَرَ بْنِ ثَابِتٍ قَالَ : کَانَ زَیْدُ بْنُ ثَابِتٍ یَقُولُ : إذَا حَاضَتِ المطلقۃ الْحَیْضَۃَ الثَّالِثَۃَ قَبْلَ أَنْ یُرَاجِعَہَا زَوْجُہَا فَلاَ یَمْلِکُ الرَّجْعَۃَ۔",,,19221,,
19222,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ أَشْعَثَ ، عَنِ الزُّہْرِیِّ ، عَنْ أَبِی بَکْرِ بْنِ عَبْدِ الرَّحْمَنِ أَنَّ عَائِشَۃَ وَزَیْدًا کَانَا یَقُولاَنِ : إذَا دَخَلَتْ فِی الدَّمِ الثَّالِثِ فَلَیْسَ لَہُ عَلَیْہَا الرَّجْعَۃُ۔",,,19222,,
19223,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَبْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ وَزَیْدِ بْنِ ثَابِتٍ أَنَّہُمَا قَالاَ : إذَا حَاضَتِ الثَّالِثَۃَ فَقَدْ بَانَتْ۔",,,19223,,
19224,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ أَبَانَ بْنِ عُثْمَانَ وَسَالِمِ بْنِ عَبْدِ اللہِ قَالاَ : إذَا دَخَلَتْ فِی الْحَیْضَۃِ الثَّالِثَۃِ فَقَدْ بَانَتْ۔",,,19224,,
19225,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی الزِّنَادِ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ ، عَنْ زَیْدِ بْنِ ثَابِتٍ قَالَ : إذَا دَخَلَتْ فِی الْحَیْضَۃِ الثَّالِثَۃِ فَقَدْ بَانَتْ مِنْہُ۔",,,19225,,
19226,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ ، عَنْ عَمْرٍو ، وَعَبْدِ اللہِ أَنَّہُمَا قَالاَ : مَنْ طَلَّقَ امْرَأَتَہُ فَہُوَ أَحَقُّ بِرَجْعَتِہَا مَا لَمْ تَغْتَسِلْ مِنْ حَیْضَتِہَا الثَّالِثَۃِ۔",,,19226,,
19227,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ جَعْفَرِ ، عَنْ أَبِیہِ ، عَنْ عَلِیٍّ وَابْنِ عَبَّاسٍ قَالاَ : ہُوَ أَحَقُّ بِہا مَا لَمْ تَغْتَسِلْ مِنْ حَیْضَتِہَا الثَّالِثَۃِ۔",,,19227,,
19228,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ إبْرَاہِیمَ ، عَنِ الاَسْوَدِ ، عَنْ عُمَرَ ، وَعَبْدِ اللہِ أنہما قَالاَ : ہُوَ أَحَقُّ بِہَا۔",,,19228,,
19229,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، عَنْ عَلْقَمَۃَ ، عَنْ عُمَرَ ، وَعَبْدِ اللہِ قَالاَ : ہُوَ أَحَقُّ بِہَا حَتَّی تَغْتَسِلَ مِنَ الْحَیْضَۃِ الثَّالِثَۃِ۔",,,19229,,
19230,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ، عَنْ عُبَیْدِاللہِ الْکَلاَعِیِّ، عَنْ مَکْحُولٍ أَنَّ أَبَا بَکْرٍ وَعُمَرَ وَعَلِیًّا، وَابْنَ مَسْعُودٍ وَأَبَا الدَّرْدَائِ وَعُبَادَۃَ بْنَ الصَّامِتِ ، وَعَبْدَ اللہِ بْنَ قَیْسٍ الأَشْعَرِیَّ کَانُوا یَقُولُونَ ؛ فِی الرَّجُلِ یُطَلِّقُ امْرَأَتَہُ تَطْلِیقَۃً ، أَوْ تَطْلِیقَتَیْنِ : إنَّہُ أَحَقُّ بِہَا مَا لَمْ تَغْتَسِلْ مِنْ حَیْضَتِہَا الثَّالِثَۃِ ، یَرِثُہَا وَتَرِثُہُ مَا دَامَتْ فِی الْعِدَّۃِ۔",,,19230,,
19231,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُبَیْدٍ ، عَنْ مَکْحُولٍ قَالَ : قَالَ عُمَرُ : إِنْ دَخَلَ عَلَیْہَا الْمُغْتَسَلَ قَبْلَ أَنْ تُفِیضَ عَلَیْہَا الْمَائَ فَہُوَ أَحَقُّ بِہَا۔ (سعید بن منصور 1223)",,,19231,,
19232,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ عَلِیٍّ قَالَ : ہُوَ أَحَقُّ بِہَا حَتَّی تَغْتَسِلَ مِنَ الْحَیْضَۃِ الثَّالِثَۃِ۔",,,19232,,
19233,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ مَکْحُولٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : لَوْ أَنَّ رَجُلاً دَخَلَ عَلَی امْرَأَتِہِ وَہِیَ تَغْتَسِلُ فَقَالَ : قَدْ رَاجَعْتُک فَقَالَتْ : کَذَبْت کَذَبْت ، وَصَبَّتِ الْمَائَ عَلَی رَأْسِہَا کَانَ أَحَقَّ بِہَا۔",,,19233,,
19234,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ بْنِ مُزَاحِمٍ أَنَّ امْرَأَۃً تَزَوَّجَتْ شَابًّا فَطَلَّقَہَا تَطْلِیقَۃً ، أَوْ تَطْلِیقَتَیْنِ قَالَ : فَأَتَاہَا وَہِیَ تَغْتَسِلُ مِنَ الْحَیْضَۃِ الثَّالِثَۃِ فَقَالَ : یَا فُلاَنَۃُ إنِّی قَدْ رَاجَعْتُک ، فَقَالَتْ : کَذَبْت، لَیْسَ ذَلِکَ إلَیْک ، فَارْتَفَعُوا إلَی عُمَرَ بْنِ الْخَطَّابِ ، وَعِنْدَہُ عَبْدُ اللہِ بْنُ مَسْعُودٍ ، فَقَالَ عُمَرُ : مَا تَرَی یَا أَبَا عَبْدِ الرَّحْمَنِ ؟ قَالَ : فَقَالَ : أَنْشُدُک بِاَللَّہِ ، ہَلْ کُنْت لَطَمْتِیہِ بِالْمَائِ ؟ قَالَتْ : مَا فَعَلْت ، قَالَ : فَقَالَ : خُذْ بِیَدِہَا۔",,,19234,,
19235,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنِ الْحَکَمِ أَنَّ أَبَا کَنَفٍ طَلَّقَ امْرَأَتَہُ وَلَمْ یُعْلِمْہَا فَأَشْہَدَ عَلَی رَجْعَتِہَا ولم یعلمہا ، قَالَ : فَقَالَ لَہُ عُمَرُ : إِنْ أَدْرَکْتہَا قَبْلَ أَنْ تَتَزَوَّجَ فَأَنْتَ أَحَقُّ بِہَا۔",,,19235,,
19236,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ قَالَ : قَالَ عَلِیٌّ : إذَا طَلَّقَہَا ، ثُمَّ أَشْہَدَ عَلَی رَجْعَتِہَا فَہِیَ امْرَأَتُہُ أَعْلَمَہَا ، أَوْ لَمْ یُعْلِمْہَا۔",,,19236,,
19237,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ مُطَرَّف ، عَنِ الشَّعْبِیِّ ، عَنْ عُمَیْرِ بْنِ یَزِیدَ قَالَ : کُنْتُ قَاعِدًا عِنْدَ شُرَیْحٍ فَجَائَ رَجُلٌ یُخَاصِمُ امْرَأَتہ فَقَالَتْ : طَلَّقَنِی وَلَمْ یُعْلِمْنِی الرَّجْعَۃَ حَتَّی مَضَتْ عِدَّتِی وَتَزَوَّجْت وَدَخَلَ بِی زَوْجِی فَقَالَ شُرَیْحٌ : أَلاَ أَعْلَمْتہَا الرَّجْعَۃَ کَمَا أَعْلَمْتہَا الطَّلاَقَ ؟ فَلَمْ یَرُدَّہَا عَلَیْہِ۔",,,19237,,
19238,"حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرٍو ، عَنْ جَابِرِ بْنِ زَیْدٍ قَالَ : إذَا طَلَّقَہَا ، ثُمَّ لَمْ یُخْبِرْہَا بِالرَّجْعَۃِ حَتَّی تَنْقَضِیَ الْعِدَّۃُ فَتَزَوَّجَتْ فَدَخَلَ بِہَا الزَّوْجُ الثَّانِی ، فَلاَ شَیْئَ لَہُ۔",,,19238,,
19239,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ فِی رَجُلٍ طَلَّقَ امْرَأَتَہُ ، ثُمَّ رَاجَعَہَا فَکَتَمَہَا الرَّجْعَۃَ حَتَّی انْقَضَتْ عِدَّتُہَا ، قَالَ : إِنْ أَدْرَکَہَا قَبْلَ أَنْ تَزَوَّجَ فَہُوَ أَحَقُّ بِہَا ، وَإِلاَّ فَہُوَ ضَیَّعَ۔",,,19239,,
19240,"حَدَّثَنَا عَبدَۃ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ؛ أَنَّ أَبَا کَنَفٍ طَلَّقَ امْرَأَتَہُ ، ثُمَّ سَافَرَ وَرَاجَعَہَا ، وَکَتَبَ إلَیْہَا بِذَلِکَ ، وَأَشْہَدَ عَلَی ذَلِکَ ، فَلَمْ یَبْلُغْہَا الْکِتَابُ حَتَّی انْقَضَتِ الْعِدَّۃُ ، فَتَزَوَّجَتِ الْمَرْأَۃُ فَرَکِبَ إلَی عُمَرَ ، فَقَصَّ عَلَیْہِ الْقِصَّۃَ فَقَالَ : أَنْتَ أَحَقُّ بِہَا مَا لَمْ یَدْخُلْ بِہَا۔",,,19240,,
19241,"حَدَّثَنَا عَبدَۃ ، عَنْ سَعِیدٍ ، عَنْ عُمَرَ بْنِ عَامِرٍ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ أَنَّ عَلِیًّا کَانَ یَقُولُ : ہُوَ أَحَقُّ بِہَا دُخِلَ بِہَا ، أَوْ لَمْ یُدْخَلْ۔",,,19241,,
19242,حَدَّثَنَا عَبدَۃ ، عَنْ سَعِیدٍ ، عَنْ عُمَرَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ أَنَّہُ کَانَ یَرَی ذَلِکَ۔,,,19242,,
19243,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ قَالَ : حدَّثَنَا إسْمَاعِیلُ ، قَالَ : سَمِعْتُ الْحَکَمَ بْنَ عُتَیْبَۃَ یَذْکُرُ ، عَنْ أَبِی کَنَفٍ أَنَّہُ طَلَّقَ امْرَأَتَہُ ، ثُمَّ رَاجَعَہَا وَلَمْ یُعْلِمْہَا الرَّجْعَۃَ فَتَزَوَّجَتْ فَرَکِب فِی ذَلِکَ إلَی عُمَرَ فَقَالَ : ارْجِعْ ، فإنْ وَجَدْتہَا لَمْ تَأْتِ زَوْجَہَا الَّذِی نَکَحَتْ فَہِیَ امْرَأَتُک ، فَرَجَعَ فَلَمْ یَجِدْہَا أَتَتْ زَوْجَہَا فَقَبَضَہَا۔",,,19243,,
19244,"حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ فِی رَجُلٍ طَلَّقَ امْرَأَتَہُ، ثُمَّ بَعَثَ إلَیْہَا بِالرَّجْعَۃِ فَلَمْ تَأْتِہَا الرَّجْعَۃُ حَتَّی تَزَوَّجَتْ قَالَ : بَانَتْ مِنْہُ ، وَإِنْ أَدْرَکَتْہَا الرَّجْعَۃُ قَبْلَ أَنْ تَزَوَّجَ فَہِیَ امْرَأَتُہُ۔",,,19244,,
19245,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرو ، عَنْ جَابِرِ بْنِ زَیْدٍ قَالَ : إذَا رَاجَعَ فِی نَفْسِہِ فَلَیْسَ بِشَیْئٍ۔",,,19245,,
19246,"حَدَّثَنَا أَبُو عَبْدِ الرَّحْمَنِ قَالَ : حدَّثَنَا عَبْدُ اللہِ بْنُ مُحَمَّدِ بْنِ أَبِی شَیْبَۃَ قَالَ :\n\n حَدَّثَنَا أسْمَاعِیلُ بْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ قَالَ : سَأَلْتُ سَعِیدَ بْنَ جُبَیْرٍ وَمُجَاہِدًا وَعَطَائً عَنِ الْمُتَوَفَّی عَنْہَا زَوْجُہَا ، مِنْ أَیِّ یَوْمٍ تَعْتَدُّ ؟ فَقَالُوا : مِنْ یَوْمِ یَمُوتُ قَالَ : وَسَمِعْت عِکْرِمَۃَ وَنَافِعًا وَمُحَمَّدَ بْنَ سِیرِینَ یَقُولُونَ : عِدَّتُہَا من یَوْمَ یَمُوتُ : وَقَالَ طَلْقُ بْنُ حَبِیبٍ : مِنْ یَوْمِ یَمُوتُ۔",,,19246,,
19247,"حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنْ أَیُّوبَ، عَنْ عَمْرِو بْنِ دِینَارٍ، عَنْ جَابِرِ بْنِ زَیْدٍ یَحْسِبُہُ، عَنِ ابْنِ عَبَّاسٍ قَالَ: یَوْمَ یَمُوتُ۔",,,19247,,
19248,حدَّثَنَا أَبُوالأَحْوَصِ، عَنْ أَبِی إِسْحَاقَ، عَنْ أَبِی الأَحْوَصِ، عَنْ عَبْدِ اللہِ قَالَ الْعِدَّۃُ مِنْ یَوْمِ یَمُوتُ وَیُطَلِّقُ۔,,,19248,,
19249,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ، عَنْ عُبَیْدِاللہِ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ قَالَ: عِدَّتُہَا مِنْ یَوْمِ طَلَّقَہَا وَمِنْ یَوْمِ یَمُوتُ عَنْہَا۔",,,19249,,
19250,"حَدَّثَنَا ہُشَیْمٌ ، عن خالد عَنْ أَبِی قِلاَبَۃَ ، وَابْنِ سِیرِینَ ، وَأَبِی الْعَالِیَۃِ ، قَالُوا : الْعِدَّۃُ مِنْ یَوْمِ یَمُوتُ وَمِنْ یَوْمِ طَلَّقَ ، فَمَنْ أَکَلَ مِنَ الْمِیرَاثِ شَیْئًا فَہُوَ مِنْ نَصِیبِہِ۔",,,19250,,
19251,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنِ الشَّعْبِیِّ ، عَنْ مَسْرُوقٍ ، قَالَ : تَعْتَدُّ الْمَرْأَۃُ مِنْ زَوْجِہَا وَہُوَ غَائِبٌ مِنْ یَوْمِ یَمُوتُ ، أَوْ مِنْ یَوْمِ یُطَلِّقُ۔",,,19251,,
19252,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ، عَنْ بُرْدٍ، عَنْ مَکْحُولٍ وَالزُّہْرِیِّ قَالاَ: تَعْتَدُّ الْمَرْأَۃُ مِنْ یَوْمِ مَاتَ ، أَوْ طَلَّقَ۔",,,19252,,
19253,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : تَقَعُ الْعِدَّۃُ مِنْ یَوْمِ یَمُوتُ وَیَوْمِ یَتَکَلَّمُ بِالطَّلاَقِ۔",,,19253,,
19254,"حَدَّثَنَا ابْنُ عُلَیَّۃَ عن لیث ، عَنِ الْحَکَمِ ، عَنْ عَبْدِ اللہِ قَالَ : مِنْ یَوْمِ یَمُوتُ۔",,,19254,,
19255,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ قَالَ : تَعْتَدُّ مِنْ یَوْمِ تُوُفِّیَ عَنْہَا زَوْجُہَا۔",,,19255,,
19256,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی الأَشْہَبِ قَالَ : قَالَ جَابِرُ بْنُ زَیْدٍ : مِنْ یَوْمٍ یَمُوتُ ، أَوْ یُطَلِّقُ۔",,,19256,,
19257,حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ مِنْ یَوْمِ مَاتَ أَو طَلَّقَ۔,,,19257,,
19258,"حَدَّثَنَا وَکِیعٌ ، وَیَحْیَی بْنُ آدَمَ ، عَنْ شَرِیکٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ زَیْدٍ ، عَنْ عَبْدِ اللہِ قَالَ : الْعِدَّۃُ مِنْ یَوْمِ یَمُوتُ ، ویوم یُطَلِّقُ۔",,,19258,,
19259,"حدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ زَیْدٍ أَوْقَفَہُ قَالَ : الْعِدَّۃُ مِنْ یَوْمِ یَمُوتُ وَیُطَلِّقُ۔",,,19259,,
19260,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنِ الْحَکَمِ أَنَّ عَلِیًّا قَالَ : مِنْ یَوْمِ یَأْتِیہَا الْخَبَرُ۔",,,19260,,
19261,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ قَالَ : مِنْ یَوْمِ یَأْتِیہَا الْخَبَرُ۔",,,19261,,
19262,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی الأَشْہَبِ ، عَنِ الْحَسَنِ قَالَ : تَعْتَدُّ مِنْ یَوْمِ یَأْتِیہَا الْخَبَرُ۔",,,19262,,
19263,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ قَتَادَۃَ قَالَ مِنْ یَوْمِ یَأْتِیہَا الْخَبَرُ۔,,,19263,,
19264,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ قَالَ مِنْ یَوْمِ یَأْتِیہَا الْخَبَرُ۔,,,19264,,
19265,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ وَخِلاَسٍ ؛ فِی الرَّجُلِ یُطَلِّقُ امْرَأَتَہُ وَہُوَ غَائِبٌ عَنْہَا قَالاَ : تَعْتَدُّ مِنْ یَوْمِ یَأْتِیہَا الْخَبَرُ۔",,,19265,,
19266,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ قَالَ : إذَا شَہِدَتِ الشُّہُودُ عَلَی طَلاَقٍ ، أَوْ مَوْتٍ فَعِدَّتُہَا مِنْ ذَلِکَ الْیَوْمِ۔",,,19266,,
19267,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ دَاوُدَ بْنِ أَبِی الْفُرَاتِ ، عَنْ مُحَمَّدِ بْنِ زَیْدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : الْمُتَوَفَّی عَنْہَا زَوْجُہَا إذَا کَانَ غَائِبًا مِنْ یَوْمِ تُوُفِّیَ إذَا شَہِدَتْ عَلَی ذَلِکَ الشُّہُودُ۔",,,19267,,
19268,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، قَالَ : سَمِعْتُ الْحَکَمَ یَقُولُ : سألت سَعِیدَ بْنَ جُبَیْرٍ ، عَنِ الْمُتَوَفَّی عَنْہَا زَوْجُہَا وَہُوَ غَائِبٌ مِنْ أی یوم تَعْتَدُّ ؟ قَالَ : مِنْ یَوْمِ مَاتَ زَوْجُہَا ، تَعْتَدُّ إذَا قَامَتِ الْبَیِّنَۃُ وَإِذَا طُلِّقَتْ فَمِثْلُ ذَلِکَ۔",,,19268,,
19269,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، عَنِ ابْنَ عُمَرَ قَالَ : تَعْتَدُّ مِنْ یَوْمِ مَاتَ ، أَوْ طَلَّقَ إذَا قَامَتِ الْبَیِّنَۃُ۔",,,19269,,
19270,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ وَسُلَیْمَانَ بْنِ یَسَارٍ أَنَّہُمَا قَالاَ : تَعْتَدُّ مِنْ یَوْمِ مَاتَ ، أَوْ طَلَّقَ إذَا قَامَتِ الْبَیِّنَۃُ۔",,,19270,,
19271,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ قَالَ : تَعْتَدُّ مِنْ یَوْمِ مَاتَ ، أَوْ طَلَّقَ إذَا قَامَتِ الْبَیِّنَۃُ۔",,,19271,,
19272,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنْ مُحَمَّدٍ قَالَ : تَعْتَدُّ الْمَرْأَۃُ مِنْ یَوْمِ مَاتَ ، أَوْ طَلَّقَ إذَا قَامَتِ الْبَیِّنَۃُ۔",,,19272,,
19273,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ دَاوُدَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ وَالشَّعْبِیِّ قَالاَ : إذَا قَامَتِ الْبَیِّنَۃُ فَالْعِدَّۃُ مِنْ یَوْمِ یَمُوتُ ، وَإِنْ لَمْ تَقُمْ فَیَوْمَ یَأْتِیہَا الْخَبَرُ۔",,,19273,,
19274,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ؛ فِی الرَّجُلِ یُطَلِّقُ ، أَوْ یَمُوتُ وَہُوَ غَائِبٌ قَالَ : إِنْ قَامَتْ بَیِّنَۃٌ عَادِلَۃٌ إذَا اعْتَدَّتْ مِنْ یَوْمِ یَمُوتُ وَإِلاَّ فَمِنْ یَوْمِ یَأْتِیہَا الْخَبَرُ۔",,,19274,,
19275,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ عَمْرٍو ، عَنْ رَجُلٍ ، عَنْ جَابِرِ بْنِ زَیْدٍ قَالَ : إذَا شَہِدَتِ الشُّہُودُ فَمِنْ یَوْمِ مَاتَ یَعْنِی فِی الْعِدَّۃِ۔",,,19275,,
19276,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ قَالَ : إبَاقُ الْعَبْدِ لَیْسَ بِطَلاَقٍ۔",,,19276,,
19277,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ قَالَ : لَیْسَ ذَلِکَ لَہُ بِطَلاَقٍ۔",,,19277,,
19278,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ عَوْفٍ ، عَنِ الْحَسَنِ قَالَ : إبَاقُہُ طَلاَقُہَا۔",,,19278,,
19279,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنْ حَوْشَبٍ ، عَنِ الْحَسَنِ سُئِلَ عَنْ عَبْدٍ آبِقٍ وَلَہُ امْرَأَۃٌ فَقَالَ : إِنْ جَائَ قَبْلَ أَنْ تَنْقَضِیَ الْعِدَّۃُ فَہِیَ امْرَأَتُہُ ، وَإِنْ جَائَ بَعْدَ مَا انْقَضَتِ الْعِدَّۃُ فَقَدْ بَانَتْ مِنْہُ بِتَطْلِیقَۃٍ۔",,,19279,,
19280,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ أَنَّہُ کَانَ إذَا طَلَّقَ طَلاَقًا یَمْلِکُ الرَّجْعَۃَ لَمْ یَدْخُلْ حَتَّی یَسْتَأْذِنَ ، وَقَالَ الشَّعْبِیُّ : کَانَ أَصْحَابُنَا یَقُولُونَ : یَخْفِقُ بِنَعْلَیْہِ۔",,,19280,,
19281,حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ عُبَیْدِ اللہِ بن عمر ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ أَنَّہُ طَلَّقَ امْرَأَتَہُ تَطْلِیقَۃً ، أَوْ تَطْلِیقَتَیْنِ ، فَکَانَ یَسْتَأْذِنُ عَلَیْہَا۔,,,19281,,
19282,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : تَعْتَدُّ الْمُطَلَّقَۃُ فِی بَیْتِ زَوْجِہَا وَلاَ تَکْتَحِلُ بِکُحْلٍ زِینَۃً وَلاَ یَدْخُلُ عَلَیْہَا إلاَّ بِإِذْنٍ وَلاَ یَکُونُ مَعَہَا فِی بَیْتِہَا۔",,,19282,,
19283,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ أَنَّہُ کَانَ یَقُولُ : إذَا دَخَلَ عَلَیْہَا فَلْیَسْتَأْنس وَلْیَتَنَحْنَحْ وَلاَ یغترنہا بِدُخُولٍ۔",,,19283,,
19284,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : إذَا طَلَّقَہَا تَطْلِیقَۃً ، فَإِنَّہُ یَسْتَأْذِنُ عَلَیْہَا۔",,,19284,,
19285,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، وَعَنْ جَابِرٍ ، عَنْ مُجَاہِدٍ قَالاَ : یُشْعِرُ بِالتَّنَحْنُحِ۔",,,19285,,
19286,"حَدَّثَنَا وَکِیعٌ ، عَنْ رَبِیعٍ ، عَنِ الْحَسَنِ ، وَعَنْ طَلْحَۃَ ، عَنْ عَطَائٍ قَالَ : یُشْعِرُہَا بِالتَّنَحْنُحِ۔",,,19286,,
19287,"حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ ، عَنْ ہِشَامٍ ، عَنْ قَتَادَۃَ سُئِلَ عَنْ رَجُلٍ طَلَّقَ امْرَأَتَہُ تَطْلِیقَۃً یَسْتَأْذِنُ عَلَیْہَا ؟ قَالَ : یُصَوِّتُ وَیَتَنَحْنَحُ قَالَ : وَقَالَ ابْنُ عَبَّاسٍ : لاَ یَصْلُحُ أَنْ یَرَی شَعْرَہَا۔",,,19287,,
19288,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ أَنَّہُ کَانَ یَقُولُ : إذَا طَلَّقَ الرَّجُلُ امْرَأَتَہُ تَطْلِیقَۃً ، أَوْ تَطْلِیقَتَیْنِ لَمْ تَخْرُجْ مِنْ بَیْتِہِ إلاَّ بِإِذْنِہِ۔",,,19288,,
19289,"حَدَّثَنَا یَحْیَی بْنُ عَبْدِ الْمَلِکِ بْنِ أَبِی غَنِیَّۃَ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ فِی قَوْلِہِ : {لاَ تُخْرِجُوہُنَّ مِنْ بُیُوتِہِنَّ وَلاَ یَخْرُجْنَ} ۔ قَالَ : لاَ تَخْرُجُ مِنْ بَیْتِہَا مَا کَانَ لَہُ عَلَیْہَا رَجْعَۃٌ۔",,,19289,,
19290,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ فِی الرَّجُلِ یُطَلِّقُ امْرَأَتَہُ طَلاَقًا یَمْلِکُ الرَّجْعَۃَ قَالَ : تَکْتَحِلُ وَتَلْبَسُ الْمُصَبَّغ وَتَشَوَّفُ لَہُ ، وَلاَ تَضَعُ ثِیَابَہَا۔",,,19290,,
19291,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِِ ، عَنْ إبْرَاہِیمَ ؛ إذَا طَلَّقَ الرَّجُلُ امْرَأَتَہُ تَطْلِیقَۃً یَمْلِکُ الرَّجْعَۃَ تَزَیَّنَتْ لَہُ وَتَعَرَّضَتْ لَہُ وَاسْتَتَرَتْ۔,,,19291,,
19292,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ قَالَ : إذَا طَلَّقَ الرَّجُلُ امْرَأَتَہُ تَطْلِیقَۃً ، أَوْ تَطْلِیقَتَیْنِ فَإِنَّہَا تَزَیَّنُ وَتَشَوَّفُ لَہُ مِنْ غَیْرِ أَنْ تَضَعَ خِمَارَہَا عِنْدَہُ۔",,,19292,,
19293,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدٍ قَالَ : إذَا طَلَّقَ الرَّجُلُ امْرَأَتَہُ تَطْلِیقَۃً ، فَإِنَّہُ یَسْتَأْذِنُ عَلَیْہَا ، وَتَلْبَسُ مَا شَائَتْ مِنَ الثِّیَابِ وَالْحُلِیِّ ، فَإِنْ لَمْ یَکُنْ لَہُمَا إلاَّ بَیْتٌ وَاحِدٌ ، فَلْیَجْعَلاَ بَیْنَہُمَا سِتْرًا ، وَیُسَلِّمُ إذَا دَخَلَ۔",,,19293,,
19294,"حَدَّثَنَا عَبْدُ الرَّزَّاقِ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ وَقَتَادَۃَ قَالاَ فِی الرَّجُلِ یُطَلِّقُ امْرَأَتَہُ تَطْلِیقَۃً ، أَوْ تَطْلِیقَتَیْنِ قَالاَ : تَشَوَّفُ لَہُ۔",,,19294,,
19295,"حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ ، عَنْ ہِشَامٍ ، عَنْ قَتَادَۃَ قَالَ : قَالَ عَلِیٌّ : لتَشَوَّفُ لَہُ ، وَقَالَ ابْنُ عَبَّاسٍ : لاَ یَحِلُّ لَہُ أَنْ یَرَی شَعْرَہَا۔",,,19295,,
19296,"حَدَّثَنَا وَکِیعٌ ، عَنْ طَلْحَۃَ ، عَنْ عَطَاء قَالَ : تَزَیَّنُ لَہُ وَتَضَعُ لَہُ إذَا طَلَّقَہَا تَطْلِیقَۃً۔",,,19296,,
19297,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ أَیُّوبَ قَالَ : کَتَبَ إلَیَّ عَطَائٌ الْخُرَاسَانِیُّ ، أَنَّہُ سَأَلَ سَعِیدَ بْنَ الْمُسَیَّبِ، وَفُقَہَائَ أَہْلِ الْمَدِینَۃِ ، قَالَ : وَأَحْسِبُہُ قَالَ : وَسُلَیْمَانَ بْنَ یَسَارٍ ، عنِ الْمُطَلَّقَۃِ وَالْمُتَوَفَّی عَنْہَا ، فَقَالُوا: تَحِدَّانِ وَتَتْرُکَانِ الْکُحْلَ وَالتَّخْضِیبَ وَالتَّطَیُّبَ وَالتَّمَشُّطَ۔",,,19297,,
19298,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الْعَزِیزِ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : الْمُطَلَّقَۃُ ثَلاَثًا وَالْمُتَوَفَّی عَنْہَا سَوَائٌ فِی الزِّینَۃِ۔",,,19298,,
19299,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : الْمُطَلَّقَۃُ ثَلاَثًا لاَ تَکْتَحِلُ بِکُحْلٍ زِینَۃً۔",,,19299,,
19300,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ قَالَ : الْمُطَلَّقَۃُ ثَلاَثًا وَالْمُتَوَفَّی عَنْہَا لاَ تَکْتَحِلاَنِ وَلاَ تَخْتَضِبَانِ۔",,,19300,,
19301,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ فِی الْمُطَلَّقَۃِ ثَلاَثًا : لاَ تَکْتَحِلُ وَلاَ تَزَیَّنُ ، وَہُوَ أَشَدُّ عِنْدَہُ مِنَ الْمُتَوَفَّی عِنْدَہُ۔",,,19301,,
19302,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ مَعْمَرٍ ، عَنْ عَطَائٍ الْخُرَاسَانِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : الْمُطَلَّقَۃُ ثَلاَثًا وَالْمُتَوَفَّی عَنْہَا سَوَائٌ فِی الزِّینَۃِ۔",,,19302,,
19303,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَاصِمٍ ، عَنْ حَفْصَۃَ ابْنَۃِ سِیرِینَ ، عَنْ أُمِّ عَطِیَّۃَ أَنَّہَا قَالَتْ : لاَ تَکْتَحِلُ وَلاَ تَخْتَضِبُ وَلاَ تَلْبَسُ ثَوْبًا مَصْبُوغًا ، إلاَّ ثَوْبَ عَصْبٍ ، وَلاَ تَطَیَّبُ إلاَّ عِنْدَ غُسْلِہَا مِنْ حَیْضَتِہَا بِنَبْذَۃٍ مِنْ قُسْطٍ ، وَأَظْفَارٍ ، تَقُولُ : فِی الْمُتَوَفَّی عَنْہَا۔",,,19303,,
19304,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ قَالَ : کَانَ یَنْہَی الْمُتَوَفَّی عَنْہَا ، عَنِ الطِّیبِ وَالزِّینَۃِ۔",,,19304,,
19305,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ أَیُّوبَ بْنِ مُوسَی ، عَنْ نَافِعٍ قَالَ : اشْتَکَتْ صَفِیَّۃُ عَیْنَہَا لَمَّا تُوُفِّیَ ابْنُ عُمَرَ ، فَکَانَتْ تَقْطُرُ فِیہَا الصَّبِرَ۔",,,19305,,
19306,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، عَنْ عَاصِمٍ ، عَنْ لاَحِقِ بْنِ حُمَیْدٍ ، عَنِ ابْنِ عُمَرَ قَالَ : تَتْرُکُ الْمُتَوَفَّی عَنْہَا الْکُحْلَ وَالطِّیبَ ، وَالْحُلِیَّ وَالْمُصَبَّغَۃَ۔",,,19306,,
19307,حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، عَنْ عَاصِمٍ ، عَنِ الحسن مِثْلَہُ۔,,,19307,,
19308,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ قَالَ : الْمُتَوَفَّی عَنْہَا زَوْجُہَا لاَ تَکْتَحِلُ ، وَلاَ تَخْتَضِبُ ، وَلاَ تَلْبَسُ ثَوْبًا إلاَّ ثَوْبَ عَصْبٍ ، وَلاَ تَبِینُ عَنْ بَیْتِہَا ، وَلَکِنْ تَزُورُ بِالنَّہَارِ۔",,,19308,,
19309,حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ أَنَّ أمینۃ بِنْتَ عُثْمَانَ تُوُفِّیَ زَوْجُہَا فَرَمِدَتْ عَیْنُہَا ، فَبَعَثَتْ إلَی عَائِشَۃَ تَسْأَلُہَا ، فَنَہَتْہَا أَنْ تَکْتَحِلَ بِالإِثْمِدِ ، فَبَعَثَتْ إلَیہَا إنِّی قَد کُنت عَودتہ عَینِی ، وَإِنی قَد خَشَیت عَلَیہَا ، فَبَعَثَتُ إِلَیہَا لاَ تَکْتَحِلْ بِالإِثْمِدِ ، وَإِنِ أنْفَضَختْ عَیْنُک۔,,,19309,,
19310,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ قَالَ : سَأَلَتِ امْرَأَۃٌ فَقَالَتْ : إنِّی امْرَأَۃُ عَطَّارَۃٌ ، وَإِنَّ زَوْجِی قَدْ مَاتَ ، فَنَہَاہَا وَقَالَ : لاَ تَکْتَحِلِی إلاَّ مِنْ ضَرُورَۃٍ۔",,,19310,,
19311,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَعْمَر ، عَنْ بُدَیْلِ بْنِ مَیْسَرَۃَ ، عَنِ الْحَسَنِ بْنِ مُسْلِمِ بْنِ یَنَّاق ، عَنْ صَفِیَّۃَ ابْنَۃِ شَیْبَۃَ ، عَنْ أُم سَلَمۃ قَالَتْ : لاَ تَلْبَسُ الْمُتَوَفَّی عَنْہَا فِی عِدَّتِہَا حَلْیًا۔",,,19311,,
19312,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَبِیبٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، وَعَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ قَالاَ : لاَ نَفَقَۃَ لَہَا ، یُنْفَقُ عَلَیْہَا مِنْ نَصِیبِہَا۔",,,19312,,
19313,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ وَجَابِرِ بْنِ عَبْدِ اللہِ ، وَالْحَسَنِ قَالَ : کَانُوا یَقُولُونَ : لَیْسَ لَہَا نَفَقَۃٌ ، حَسْبُہَا الْمِیرَاثُ۔",,,19313,,
19314,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ قَالَ : مِنْ نَصِیبِہَا۔\n\n حَدَّثَنَا وَکِیعٌ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ قَالَ : مِنْ نَصِیبِہَا۔",,,19314,,
19315,"حَدَّثَنَا وَکِیعٌ ، عَنْ جَعْفَرٍ ، عَنِ الزُّہْرِیِّ قَالَ : قَالَ قَبِیصَۃُ بْنُ ذُؤَیْبٍ : لَوْ أَنْفَقْت عَلَیْہَا مِنْ غَیْرِ نَصِیبِہَا ، أَنْفَقْت عَلَیْہَا مِنْ نَصِیبِ الَّذِی فِی بَطْنِہَا۔",,,19315,,
19316,"حَدَّثَنَا ہُشَیْمٌ وابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ قَالَ : یُنْفَقُ عَلَیْہَا مِنْ نَصِیبِہَا۔",,,19316,,
19317,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ شُعْبَۃَ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، أَنَّ ابْنَ عَبَّاسٍ قَالَ : فی الْمُتَوَفَّی عَنْہَا وَہِیَ حَامِلٌ لاَ نَفَقَۃَ لَہَا وَقَضَی بِہِ فِینَا ابْنُ الزُّبَیْرِ۔",,,19317,,
19318,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ قَالَ : یُنْفَقُ عَلَیْہَا مِنْ نَصِیبِہَا وَسَمِعْت وَکِیعًا یَقُولُ : کَانَ سُفْیَانُ یَقُولُ : یُنْفَقُ عَلَیْہَا مِنْ نَصِیبِہَا۔",,,19318,,
19319,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ قَالَ : نَفَقَتُہَا مِنْ نَصِیبِہَا۔",,,19319,,
19320,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، عَنْ عَلِیٍّ ، وَعَبْدِ اللہِ وَشُرَیْحٍ قَالُوا : یُنْفَقُ عَلَیْہَا مِنْ جَمِیعِ الْمَالِ۔",,,19320,,
19321,حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، عَنْ عَبْدِ اللہِ وَشُرَیْحٍ قَالاَ یُنْفَقُ عَلَیْہَا مِنْ جَمِیعِ الْمَالِ۔,,,19321,,
19322,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ سُفْیَانَ بْنِ حُسَیْنٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ ، عَنِ ابْنِ عُمَرَ قَالَ : یُنْفَقُ عَلَیْہَا مِنْ جَمِیعِ الْمَالِ۔",,,19322,,
19323,حَدَّثَنَا ہُشَیْمٌ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنِ الشَّعْبِیِّ وَإِبْرَاہِیمَ قَالاَ یُنْفَقُ عَلَیْہَا مِنْ جَمِیعِ الْمَالِ۔,,,19323,,
19324,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : یُنْفَقُ عَلَیْہَا مِنْ جَمِیعِ الْمَالِ۔",,,19324,,
19325,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ شُرَیْحٍ قَالَ : یُنْفَقُ عَلَیْہَا مِنْ جَمِیعِ الْمَالِ۔",,,19325,,
19326,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ زَکَرِیَّا ، عَنِ ابْنِ أَشْوَعَ قَالَ : کَانَ شُرَیْحٌ وَقُضَاۃُ أَہْلِ الْکُوفَۃِ یَقُولُونَ : یُنْفَقُ عَلَیْہَا مِنْ جَمِیعِ الْمَالِ۔",,,19326,,
19327,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ قَالَ : کَانَ أَصْحَابُنَا یَقُولُونَ : إِنْ کَانَ الْمَالُ لَہُ أُنْفِقَ عَلَیْہَا مِنْ جَمِیعِ الْمَالِ۔",,,19327,,
19328,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنْ إبْرَاہِیمَ قَالَ : کَانَ أَصْحَابُ عَبْدِ اللہِ یَقُولُونَ فِی الْمُتَوَفَّی عَنْہَا زَوْجُہَا : إِنْ کَانَ الْمَالُ کَثِیرًا فَنَفَقَتُہَا مِنْ نَصِیبِ الْغُلاَمِ ، وَإِنْ کَانَ الْمَالُ قَلِیلاً ، مِنْ جَمِیعِ الْمَالِ۔",,,19328,,
19329,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ قَتَادَۃَ وَحَمَّادٍ ، وَعَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالُوا الحَامِل : الْمُتَوَفَّی عَنْہَا یُنْفَقُ عَلَیْہَا مِنْ جَمِیعِ الْمَالِ۔",,,19329,,
19330,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، أن ابْنَ سِیرِینَ قَالَ : کَانَ یَرَی لِکُلِّ حَامِلٍ نَفَقَۃً قَالَ : فولی أُمِّ وَلَدٍ یَعْلَی بْنُ خَالِدٍ ، فَکَانَ یَرَی لَہَا النَّفَقَۃَ فَکَرِہَ أَنْ یُنْفِقَ دُونَ الْقَاضِی ، فَأَرْسَلَ إلَی عَبْدِ الْمَلِکِ بْنِ یَعْلَی فَمَنَعَہَا ہو ، قَالَ : کَانَ الْحَسَنُ یَقُولُ : یُنْفَقُ عَلَیْہَا فَإِنْ وَلَدَتْہُ حَیًّا فَنَفَقَتُہَا مِنْ نَصِیبِ وَلَدِہَا ، وَإِنْ وَلَدَتْہُ مَیِّتًا أُلْغِیَ ذَلِکَ۔",,,19330,,
19331,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ قَالَ : إذَا کَانَتْ أُمُّ وَلَدٍ فَتُوُفِّیَ عَنْہَا سَیِّدُہَا فَنَفَقَتُہَا مِنْ نَصِیبِ الَّذِی فِی بَطْنِہَا۔",,,19331,,
19332,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : قَالَ عَبْدُ اللہِ : عِدَّۃُ الْمُطَلَّقَۃِ بِالْحَیْضِ ، وَإِنْ طَالَتْ ، قَالَ حَفْصٌ : فَذَکَرَ السَّنَۃَ وَأَکْثَرَ۔",,,19332,,
19333,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ، وَعَنْ عُبَیْدَۃَ ، عَنْ إبْرَاہِیمَ أَنَّہُمَا قَالاَ : تَعْتَدُّ بِالْحَیْضِ۔",,,19333,,
19334,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : قَالَ عُمَرُ : إذَا طُلِّقَتِ الْمَرْأَۃُ فَحَاضَتْ حَیْضَۃً ، أَوْ حَیْضَتَیْنِ ، ثُمَّ رَفَعَتْہَا حَیْضَتُہَا اعْتَدَّتْ لِلْحَیضِ ثَلاَثَۃَ أَشْہُرٍ ، ثُمَّ اعْتَدَّتْ لِلْحَمْلِ تِسْعَۃَ أَشْہُرٍ ، ثُمَّ حَلَّتْ لِلرِّجَالِ۔",,,19334,,
19335,حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی الْمَرْأَۃِ إذَا طَلَّقَہَا فَحَاضَتْ حَیْضَۃً ، أَوْ حَیْضَتَیْنِ تَرَبَّصُ سَنَۃً ، ثُمَّ تَمْکُثُ بَعْدَ السَّنَۃِ ثَلاَثَۃَ أَشْہُرٍ ، ثُمَّ تَزَوَّجَ۔,,,19335,,
19336,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَبْدِ الْحَمِیدِ بْنِ جَعْفَرٍ ، عَنْ یَزِیدَ بْنِ أَبِی حَبِیبٍ قَالَ : کَتَبَ إلَیَّ الزُّہْرِیُّ إنَّ رَجُلاً طَلَّقَ امْرَأَتَہُ وَہِیَ تُرْضِعُ ابْنًا لَہُ ، فَمَکَثَتْ سَبْعَۃَ أَشْہُرٍ ، أَوْ ثَمَانِیَۃَ أَشْہُرٍ لاَ تَحِیضُ فَقِیلَ لَہُ : إِنْ مِتَّ وَرِثَتْک فَقَالَ : احْمِلُونِی إلَی عُثْمَانَ فَحَمَلُوہُ فَأَرْسَلَ عُثْمَانُ إلَی عَلِیٍّ وَزَیْدٍ فَسَأَلَہُمَا فَقَالاَ : نَرَی أَنْ تَرِثَہُ ، فَقَالَ : وَلِمَ ؟ فَقَالاَ : لأَنَّہَا لَیْسَتْ مِنَ اللاَّئِی یَئِسْنَ مِنَ الْمَحِیضِ ، وَلاَ من اللاَّئِی لم یَحِضْنَ ، وَإِنَّمَا یَمْنَعُہَا مِنَ الْمَحِیضِ الرَّضَاعُ فَأَخَذَ الرَّجُلُ ابْنَہُ فَلَمَّا فَقَدَتْہُ حَاضَتْ حَیْضَۃً ، ثُمَّ حَاضَتْ فِی الشَّہْرِ الثَّانِی حَیْضَۃً أُخْرَی ، ثُمَّ مَاتَ قَبْلَ أَنْ تَحِیضَ الثَّالِثَۃ فَوَرِثَتْہُ",,,19336,,
19337,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ أَنَّ الأَحْوَصَ ، رَجُلاً مِنْ أَہْلِ الشَّامِ ، طَلَّقَ امْرَأَتَہُ تَطْلِیقَۃً ، أَوْ تَطْلِیقَتَیْنِ فَمَاتَ وَہِیَ فِی الْحَیْضَۃِ الثَّالِثَۃِ مِنَ الدَّمِ فَرُفِعَ ذَلِکَ إلَی مُعَاوِیَۃَ فَسَأَلَ عَنْہَا فَضَالَۃَ بْنَ عُبَیْدٍ وَمَنْ ہُنَاکَ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَلَمْ یُوجَدْ عِنْدَہُمْ فِیہَا عِلْمٌ فَبَعَثَ فیہا رَاکِبًا إلَی زَیْدِ بْنِ ثَابِتٍ فَقَالَ : لاَ تَرِثُہُ ، وَإِنْ مَاتَتْ لَمْ یَرِثْہَا قَالَ : کَانَ ابْنُ عُمَرَ یَرَی ذَلِکَ۔",,,19337,,
19338,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعمَش ، عَنْ إبْرَاہِیمَ ، عَنْ عَلْقَمَۃَ أَنَّہُ طَلَّقَ امْرَأَتَہُ تَطْلِیقَۃً ، أَوْ تَطْلِیقَتَیْنِ فَحَاضَتْ حَیْضَۃً ، أَوْ حَیْضَتَیْنِ فِی سِتَّۃَ عَشَرَ شَہْرًا أَو سَبعَۃ عَشَرَ شَہْرًا ، ثُمَّ لَمْ تَحِضِ الثَّالِثَۃَ حَتَّی مَاتَتْ فَأَتَی عَبْدَ اللہِ فَذَکَرَ ذَلِکَ لَہُ فَقَالَ عَبْدُ اللہِ : حبَسَ اللَّہُ عَلَیْک مِیرَاثَہَا وَوَرَّثَہُ مِنْہَا۔",,,19338,,
19339,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ مُحَمَّدِ بْنِ یَحْیَی بْنِ حَبَّانَ أَنَّ جدہ حبان بْنِ مُنْقِذٍ کَانَتْ عِنْدَہُ امْرَأَتَانِ امْرَأَۃٌ مِنْ بَنِی ہَاشِمٍ وَامْرَأَۃٌ مِنَ الأَنْصَارِ وَأَنَّہُ طَلَّقَ الأَنْصَارِیَّۃَ وَہِیَ تُرْضِعُ وَکَانَتْ إذَا أَرْضَعَتْ مَکَثَتْ سَنَۃً لاَ تَحِیضُ ، فَمَاتَ حِبَّانُ عِنْدَ رَأْسِ السَّنَۃِ فَوَرِثَہَا عُثْمَانُ وَقَالَ لِلْہَاشِمِیَّۃِ : ہَذَا رَأْیُ ابْنِ عَمِّکَ عَلِیِّ بْنِ أَبِی طَالِبٍ۔",,,19339,,
19340,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَر ، عَنِ الزُّہْرِیِّ فِی الَّتِی لاَ تَحِیضُ إلاَّ فِی الأَشْہُرِ قَالَ : تَعْتَدُّ بِالْحَیْضِ ، وَإِنْ تَطَاوَلَ۔",,,19340,,
19341,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ خِلاَسٍ أَنَّ رَجُلاً طَلَّقَ امْرَأَتَہُ وَأَشْہَدَ رَجُلَیْنِ فِی السِّرِّ وَقَالَ : اکْتُمَا عَلَیّ ، فَکَتَمَا عَلَیْہِ ، حَتَّی انْقَضَتِ الْعِدَّۃُ فَارْتَفَعَا إلَی عَلِیٍّ فَاتَّہَمَ الشَّاہِدَیْنِ وَجَلَدَہُمَا وَلَمْ یَجْعَلْ لَہُ عَلَیْہَا رَجْعَۃً۔",,,19341,,
19342,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ أَنَّ ابْنَ الزُّبَیْرِ طَلَّقَ امْرَأَتَہُ فَلَمْ یُعْلِمْہَا سَنَۃً فَقَالَ ابْنُ عُمَرَ : بِئْسَ مَا صَنَعَ۔",,,19342,,
19343,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ قَیْسِ بْنِ مُسْلِمٍ ، عَنْ مُحَمَّدِ بْنِ الْمُنْتَشِرِ أَنَّ شُرَیْحًا طَلَّقَ امْرَأَتَہُ فَکَتَمَہَا الطَّلاَقَ حَتَّی انْقَضَتْ عِدَّتُہَا ، فَعَابُوا ذَلِکَ عَلَیْہِ۔,,,19343,,
19344,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ مُحَمَّدِ بْنِ کَعْبٍ قَالَ : قَالَ عَلِیٌّ : الْحَکَمَانِ بِہِمَا یَجْمَعُ اللَّہُ وَبِہِمَا یُفَرِّقُ۔",,,19344,,
19345,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ قَالَ : مَا قَضَی الْحَکَمَانِ جَائِزٌ۔",,,19345,,
19346,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ مُبَارَکٍ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ أَبِی سَلَمَۃَ قَالَ : الْحَکَمَانِ إِنْ شَائَا جَمَعَا ، وَإِنْ شَائَا فَرَّقَا۔",,,19346,,
19347,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی ہَاشِمٍ ، عَنْ مُجَاہِدٍ فِی قولہ تعالی : {إنْ یُرِیدَا إصْلاَحًا یُوَفِّقَ اللَّہُ بَیْنَہُمَا} قَالَ : ہُمَا الْحَکَمَانِ۔",,,19347,,
19348,"حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ مُطَرِّفٍ ، عَنِ الْحَکَمِ قَالَ : إذَا الْحَکَمَانِ اخْتَلَفَا ، فَلاَ : حُکِمَ لَہُمَا وَیُجْعَلُ غَیْرُہُ وَإِنِ اتَّفَقَا جَازَ حُکْمُہُمَا۔",,,19348,,
19349,"حَدَّثَنَا مُعْتَمِرٌ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ فِی الْحَکَمَیْنِ : إذَا حَکَمَا فَخُذْ بِحُکْمِہِمَا وَلاَ تَتْبَعْ أَثَرَ غَیْرِہِمَا، وَإِنْ کَانَ قَدْ حُکِمَ قَبْلَہُمَا عَلَیْک۔",,,19349,,
19350,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عَطَائٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ : {إنْ یُرِیدَا إصْلاَحًا یُوَفِّقَ اللَّہُ بَیْنَہُمَا} قَالَ : ہُمَا الْحَکَمَانِ۔",,,19350,,
19351,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ أَبِی الزِّنَادِ قَالَ : سَأَلْتُ سَعِیدَ بْنَ الْمُسَیَّبِ عَنِ الرَّجُلِ یَعْجِزُ عَنْ نَفَقَۃِ امْرَأَتِہِ فَقَالَ : یُفَرَّقُ بَیْنَہُمَا فَقُلْت : سُنَّۃً ؟ فَقَالَ : سُنَّۃً۔",,,19351,,
19352,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : سَأَلْتُہ عَنِ الرَّجُلِ یُعْسِرُ عَنْ نَفَقَۃِ امْرَأَتِہِ ، فَقَالَ : لاَ بُدَّ مِنْ أَنْ یُنْفِقَ ، أَوْ یُطَلِّقَ۔",,,19352,,
19353,"حَدَّثَنَا عَبْدُ الرَّزَّاقِ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ قَالَ : یُسْتَأْنَی بِہِ ، قَالَ : وَبَلَغَنِی أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ قَالَ ذَلِکَ۔",,,19353,,
19354,"حَدَّثَنَا حَفْصٌ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ قَالَ : إذَا عَجَزَ الرَّجُلُ عَنْ نَفَقَۃِ امْرَأَتِہِ لَمْ یُفَرَّقْ بَیْنَہُمَا۔",,,19354,,
19355,"حَدَّثَنَا عُمَرُ بْنُ ہَارُونَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ فِی الرَّجُلِ یَعْجِزُ ، عَنْ نَفَقَۃِ امْرَأَتِہِ ، قَالَ : لاَ یُفَرَّقُ بَیْنَہُمَا ، امْرَأَۃً ابْتُلِیَتْ فَلْتَصْبِرْ۔",,,19355,,
19356,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ قَالَ : سَأَلْتُ حَمَّادًا ، عَنْ رَجُلٍ تَزَوَّجَ امْرَأَۃً وَلَمْ یَکُنْ عِنْدَہُ مَا یُنْفِقُ قَالَ : یُؤَجَّلُ سَنَۃً ، قُلْتُ : فَإِنْ لَمْ یَجِدْ ؟ قَالَ : یُطَلِّقُہَا۔",,,19356,,
19357,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ سُفْیَانَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : یُفَرَّقُ بَیْنَہُمَا۔",,,19357,,
19358,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ قَالَ : حدَّثَنَا عُبَیْدُ اللہِ بْنُ عُمَرَ ، عَنْ نَافِعٍ ، قَالَ : کَتَبَ عُمَرُ إلَی أُمَرَائِ الأَجْنَادِ فِیمَنْ غَابَ عَنْ نِسَائِہِ مِنْ أَہْلِ الْمَدِینَۃِ یَأْمُرُہُمْ أَنْ یَرْجِعُوا إلَی نِسَائِہِمْ ، إمَّا أَنْ یُفَارِقُوا ، وَإِمَّا أَنْ یَبْعَثُوا بِالنَّفَقَۃِ ، فَمَنْ فَارَقَ مِنْہُمْ فَلْیَبْعَثْ بِنَفَقَۃِ مَا تَرَکَ۔",,,19358,,
19359,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی مَکِینٍ قَالَ : کَتَبَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ : مَنْ غَابَ ، عَنِ امْرَأَتِہِ سَنَتَیْنِ فَلْیُطَلِّقْ ، أَوْ لِیَقْفِلْ إلَیْہَا۔",,,19359,,
19360,حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی مَکِینٍ ، عَنْ عِکْرِمَۃَ قَالَ مَنْ غَابَ عَنِ امْرَأَتِہِ سَنَتَیْنِ فَلْیُطَلِّقْ ، أَوْ لِیَقْفِلْ إلَیْہَا۔,,,19360,,
19361,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ قَالَ : إذَا طَالَتْ غَیْبَۃُ الرَّجُلِ ، عَنِ امْرَأَتِہِ أَنْفَقَ عَلَی امْرَأَتِہِ ، أَوْ طَلَّقَہَا۔",,,19361,,
19362,حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ أَبِیہِ ، عَنِ الْحَکَمِ ؛ أَنَّہُ کَانَ لاَ یَرَی عَلَی الْغَائِبِ نَفَقَۃً۔,,,19362,,
19363,"حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ مُطَرِّفٍ ، عَنِ الشَّعْبِیِّ قَالَ : إذَا طَالَتْ غَیْبَۃُ الرَّجُلِ عَنِ امْرَأَتِہِ فَلْیُرْسِلْ إلَیْہَا نَفَقَۃً ، أَوْ لِیُطَلِّقْہَا۔",,,19363,,
19364,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ فِی الرَّجُلِ یَتَزَوَّجُ الْمَرْأَۃَ ، قَالَ : لاَ نَفَقَۃَ لَہَا حَتَّی یَدْخُلَ بِہَا۔",,,19364,,
19365,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ کَامِلِ بْنِ فُضَیْلٍ قَالَ : سَأَلْتُ الشَّعْبِیَّ عَنْ رَجُلٍ تَزَوَّجَ امْرَأَۃً فَلَمْ یَدْخُلْ بِہَا ، ثُمَّ غَابَ عَنْہَا فَلَمَّا قَدِمَ أَخَذَتْہُ بِالنَّفَقَۃِ ، فَقَالَ الشَّعْبِیُّ : لاَ نَفَقَۃَ لَہَا حَتَّی یَدْخُلَ بِہَا۔",,,19365,,
19366,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ قَالَ : سُئِلَ یُونُسُ عَنْ رَجُلٍ تَزَوَّجَ امْرَأَۃً ، ثُمَّ غَابَ عَنْہَا قَبْلَ أَنْ یَدْخُلَ بِہَا ، ہَلْ لَہَا نَفَقَۃٌ ؟ فَقَالَ : کَانَ الْحَسَنُ لاَ یَرَی لَہَا عَلَیْہِ نَفَقَۃً حَتَّی یَدْخُلَ بِہَا إلاَّ أَنْ یَقُولُوا لَہُ : خُذْہَا فَلاَ یَأْخُذُہَا۔",,,19366,,
19367,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ حُسَامِ بْنِ مِصَکٍّ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ قَالَ : لَیْسَ لِلْمَرْأَۃِ عَلَی زَوْجِہَا نَفَقَۃٌ إلاَّ مِنْ یَوْمِ تَطْلُبُ ذَلِکَ۔",,,19367,,
19368,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ عَنْ مُطَرِّف ، عَنْ عَامِرٍ قَالَ : لَیْسَ لِلرَّجُلِ أَنْ یُنْفِقَ عَلَی امْرَأَتِہِ إذَا کَانَ الْحَبْس مِنْ قِبَلِہَا۔",,,19368,,
19369,"حَدَّثَنَا أَبُو أُسَامَۃَ قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ طَارِقٍ ، عَنِ الشَّعْبِیِّ ، أَنَّہُ سُئِلَ عَنِ امْرَأَۃٍ خَرَجَتْ مِنْ بَیْتِہَا عَاصِیَۃً لِزَوْجِہَا ، أَلَہَا نَفَقَۃٌ ؟ قَالَ : لاَ ، وَإِنْ مَکَثَتْ عِشْرِینَ سَنَۃً۔",,,19369,,
19370,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ قَالَ : سَأَلْتُ الْحَکَمَ عَنِ امْرَأَۃٍ خَرَجَتْ مِنْ بَیْتِ زَوْجِہَا عَاصِیَۃً ، ہَلْ لَہَا نَفَقَۃٌ؟ قَالَ : نَعَمْ : وَسَأَلْت حَمَّادًا فَقَالَ : لَیْسَ لَہَا نَفَقَۃٌ۔",,,19370,,
19371,"حَدَّثَنَا بَہْز بْنُ أَسَدٍ ، عَنْ أَبِی ہِلاَلٍ ، عَنْ ہَارُونَ قَالَ : سَأَلْتُ الْحَسَنَ عَنِ امْرَأَۃٍ خَرَجَتْ مُرَاغِمَۃً لِزَوْجِہَا ، لَہَا نَفَقَۃٌ ؟ قَالَ : لَہَا جَوَالِقُ مِنْ تُرَابٍ۔",,,19371,,
19372,حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ صَالِحٍ أَنَّ عُثْمَانَ وَرَّثَ امْرَأَۃَ عَبْدِ الرَّحْمَنِ بْنِ عَوْفٍ حِینَ طَلَّقَہَا فِی مَرَضِہِ بَعْدَ انْقِضَائِ الْعِدَّۃِ۔,,,19372,,
19373,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَبِیبٍ ، عَنْ رَجُلٍ مِنْ قُرَیْشٍ ، عَنْ أُبَیِّ بْنِ کَعْبٍ قَالَ : إذَا طَلَّقَہَا وَہُوَ مَرِیضٌ وَرَّثْتُہَا مِنْہُ وَلَوْ مَضَی سَنَۃٌ مَا لَمْ یَبْرَأْ ، أَوْ تتزوج۔",,,19373,,
19374,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ، عَنِ ابْنِ جُرَیْجٍ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ قَالَ: سَأَلْتُ ابْنَ الزُّبَیْرِ عَنْ رَجُلٍ طَلَّقَ امْرَأَتَہُ وَہُوَ مَرِیضٌ ، ثُمَّ مَاتَ ، فَقَالَ : قَدْ وَرَّثَ عُثْمَانُ ابْنَۃَ الأَصْبَغِ الْکَلْبِیَّۃَ ، وَأَمَّا أَنَا فَلاَ أَرَی أَنْ تَرِثَ مَبْتُوتَۃٌ۔",,,19374,,
19375,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ حُمَیْدٍ ، عَنْ بَکْرٍ أَنَّ خَالِدَ بْنَ عَبْدِ اللہِ سَأَلَ الْحَسَنَ عَنْ رَجُلٍ طَلَّقَ امْرَأَتَہُ ثَلاَثًا فِی مَرَضِہِ فَمَاتَ ، وَقَدِ انْقَضَتْ عِدَّتُہَا ، قَالَ : تَرِثُ۔",,,19375,,
19376,"حَدَّثَنَا عُبَید اللہِ ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنْ عَطَاء قَالَ : لَوْ مَرِضَ سَنَۃً وَرَّثْتُہَا مِنْہُ۔",,,19376,,
19377,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، عَنْ شُرَیْحٍ قَالَ : أَتَانِی عُرْوَۃُ الْبَارِقِیُّ مِنْ عِنْدِ عُمَرَ ؛ فِی الرَّجُلِ یُطَلِّقُ امْرَأَتَہُ ثَلاَثًا فِی مَرَضِہِ : أَنَّہَا تَرِثُہُ مَا دَامَتْ فِی الْعِدَّۃِ وَلاَ یَرِثُہَا۔",,,19377,,
19378,"حَدَّثَنَا أَبُو بَکْرٍ ، عَنْ جَرِیرٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : تَرِثُہُ وَلاَ یَرِثُہَا مَا دَامَتْ فِی الْعِدَّۃِ۔",,,19378,,
19379,حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ أَنَّ الْحَسَنَ بْنَ عَلِیٍّ طَلَّقَ امْرَأَتَہُ وَہُوَ مَرِیضٌ فَمَاتَ فَوَرِثَتْہُ۔,,,19379,,
19380,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ دَاوُدَ وَأَشْعَثَ ، عَنِ الشَّعْبِیِّ ، عَنْ شُرَیْحٍ قَالَ : إذَا طَلَّقَ ثَلاَثًا فِی مَرَضِہِ وَرِثَتْہُ مَا دَامَتْ فِی الْعِدَّۃِ۔",,,19380,,
19381,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ أَنَّ أُمَّ الْبَنِینَ بِنْتَ عُیَیْنَۃَ بْنِ حِصْنٍ کَانَتْ تَحْتَ عُثْمَانَ بْنِ عَفَّانَ فَلَمَّا حُصِرَ طَلَّقَہَا وَقَدْ کَانَ أَرْسَلَ إلَیْہَا لِیَشْتَرِیَ مِنْہَا ثُمْنَہَا فَأَبَتْ فَلَمَّا قُتِلَ أَتَتْ عَلِیًّا فَذَکَرَتْ ذَلِکَ لَہُ فَقَالَ : تَرَکَہَا حَتَّی إذَا أَشْرَفَ عَلَی الْمَوْتِ طَلَّقَہَا ، فَوَرَّثَہَا۔",,,19381,,
19382,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ أَنَّ ہِشَامَ بْنَ ہُبَیْرَۃَ کَتَبَ إلَی شُرَیْحٍ یَسْأَلُہُ عَنِ الرَّجُلِ یُطَلِّقُ امْرَأَتَہُ ثَلاَثًا فِی مَرَضِہِ ، فَکَتَبَ إلَیْہِ شُرَیْحٌ : أنَّہُ فَارٌّ مِنْ کِتَابِ اللہِ ، تَرِثُہُ۔",,,19382,,
19383,"حَدَّثَنَا حُمَید بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنٍ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ؛ فِی الرَّجُلِ طَلَّقَ امْرَأَتَہُ ثَلاَثًا فِی مَرَضِہِ قَالَ : تَرِثُہُ مَا دَامَتْ فِی الْعِدَّۃِ۔",,,19383,,
19384,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ ہِشَامٍ قَالَ : سَأَلْتُ عُرْوَۃَ عَنِ الرَّجُلِ یُطَلِّقُ امْرَأَتَہُ الْبَتَّۃَ ، أَیَرِثُ أَحَدُہُمَا الآخَرَ ؟ وَہَلْ لَہَا نَفَقَۃٌ ؟ فَقَالَ : لاَ یَرِثُ أَحَدُہُمَا الآخَرَ وَلاَ نَفَقَۃَ لَہَا إلاَّ أَنْ تَکُونَ حُبْلَی ، فَیُنْفِقَ عَلَیْہَا حَتَّی تَضَعَ ، أَوْ یُطَلِّقَ مُضَارًّا فِی مَرَضِہِ۔",,,19384,,
19385,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ أَخْبَرَنَا سَعِیدُ بْنُ أَبِی عَرُوبَۃَ ، عَنْ ہِشَامِ بن عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ أَنَّہَا قَالَتْ فِی الْمُطَلَّقَۃِ ثَلاَثًا وَہُوَ مَرِیضٌ : تَرِثُہُ مَا دَامَتْ فِی الْعِدَّۃِ۔",,,19385,,
19386,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ قَالَ : کَانُوا یَقُولُونَ : لاَ تَخْتَلِفُونَ مَنْ فَرَّ مِنْ کِتَابِ اللہِ رُدَّ إلَیْہِ یَعْنِی ؛ فِی الرَّجُلِ یُطَلِّقُ امْرَأَتَہُ وَہُوَ مَرِیضٌ۔",,,19386,,
19387,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنِ الْحَارِثِ فِی رَجُلٍ کَانَتْ تَحْتَہُ امْرَأَۃٌ عَلَی تَطْلِیقَۃٍ وَقَدْ کَانَ طَلَّقَہَا قَبْلَ ذَلِکَ تَطْلِیقَتَیْنِ فَیُطَلِّقُہَا فِی مَرَضِہِ فَمَاتَ فِی الْعِدَّۃِ : لاَ یَرِثُہَا وَلاَ تَرِثُہُ۔",,,19387,,
19388,"حَدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَنْ یُونُسَ قَالَ : کَانَ الْحَسَنُ یَقُولُ : لَوْ أَنَّ رَجُلاً قَالَ : إِنْ دَخَلْتُ دَارَ بَنِی فُلاَنٍ فَامْرَأَتِی طَالِقٌ ، فَیَنْسَی فَیَدْخُلُہَا ، أَوْ دَخَلَہَا وَہُوَ لاَ یَعْلَمُ ، قَالَ : کَانَ یَجْعَلُہُ مِثْلَ العمد إلاَّ أَنْ یَشْتَرِطَ فَیَقُولُ : إلاَّ أَنْ أَنْسَی۔",,,19388,,
19389,"حَدَّثَنَا یَحْیَی بْنُ سُلَیْمٍ ، عَنْ عَبْدِ اللہِ بْنِ عُثْمَانَ قَالَ : حلَفَ أَخِی عُمَرُ بْنُ عُثْمَانَ : بِعْتِقِ جَارِیَۃٍ لَہُ أَلاَّ یَشْرَبَ مِنْ یدہا ، إلَی أَجَلٍ ضَرَبَہُ ، فَنَسِیَ قَبْلَ الأَجَلِ فَشَرِبَ ، فَاسْتَفْتَیْت لَہُ عَطَائً وَمُجَاہِدًا وَسَعِیدَ بْنَ جُبَیْرٍ ، وَعَلِیًّا الأَزْدِیَّ ، فَکُلُّہُمْ رَأَی أَنَّہَا حُرَّۃٌ۔",,,19389,,
19390,"حَدَّثَنَا یَحْیَی بْنُ سُلَیْمٍ قَالَ : حدَّثَنَا بِہَذَا الْحَدِیثِ ابْنُ جُرَیْجٍ فَأَنْکَرَ أَنْ یَکُونَ کان عَطَائٌ یَرَی فِی النِّسْیَانِ شَیْئًا ، قَالَ وَقَالَ عَطَائٌ : بَلَغَنِی أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : إنَّ اللَّہَ تَجَاوَزَ لأَمَّتِی ، عَنْ ثَلاَثٍ : عَنِ الْخَطَإِ وَالنِّسْیَانِ وَمَا اسْتُکْرِہُوا عَلَیْہِ۔ (حاکم 362)",,,19390,,
19391,حُدِّثْتُ عَنِ ابْنِ مُبَارَکٍ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ (ح) ، وَعَنْ مَعْمَرٍ ، عَنْ سَعِیدِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ عمر بن عَبْدِ الْعَزِیزِ ، أَنَّہُمَا کَانَا یُوجِبَانِ طَلاَقَ النِّسْیَانِ۔,,,19391,,
19392,حَدَّثَنَا عُمَرُ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَبْدِ الکَرِیم أَبِی أُمَیَّۃَ ، عَنْ أَصْحَابِ عَبْدِ اللہِ بْنِ مَسْعُودٍ أنَّہُ جَائِزٌ عَلَیْہِ۔,,,19392,,
19393,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ عَطَائٍ ، عَنِ الشَّعْبِیِّ قَالَ: سُئِلَ عَنِ الرَّجُلِ قَالَ لآخَرَ: إنَّک لَحَسُودٌ، فَقَالَ الآخَرُ : أَحْسَدُنَا امْرَأَتُہُ طَالِقٌ ثَلاَثًا ، قَالَ : نَعَمْ ، قَالَ : قَدْ خِبْتُمَا وَخَسِرْتُمَا وَبَانَتْ مِنْکُمَا امْرَأَتُکُمَا۔",,,19393,,
19394,"حَدَّثَنَا جَرِیرٌ ، عَنِ الْمُغِیرَۃِ ، عَنِ الْحَارِثِ قَالَ : أُدَیِّنُہما وَآمُرُہُمَا بِتَقْوَی اللہِ وَأَقُولُ : أَنْتُمَا أَعْلَمُ بِمَا حَلَفْتُمَا عَلَیْہِ قَالَ : وباب التدین فِی ہَذَا وَشِبْہِہِ۔",,,19394,,
19395,"حَدَّثَنَا عَبْدُ الأَعْلَی قَالَ : سُئِلَ سَعِیدٌ ، عَنْ رَجُلَیْنِ قَالَ أَحَدُہُمَا لِطَائِرٍ : إِنْ لَمْ یَکُنْ غُرَابًا فَامْرَأَتُہُ طَالِقٌ ثَلاَثًا ، وَقَالَ الآخَرُ : إِنْ لَمْ یَکُنْ حَمَامًا فَامْرَأَتُہُ طَالِقٌ ثَلاَثًا فَحَدَّثَنَا عَنْ قَتَادَۃَ قَالَ : إذَا طَارَ الطَّائِرُ وَلاَ تَدْرِی مَا ہُوَ فَلاَ یَقْرَبُہَا ہَذَا وَلاَ یَقْرَبُہَا ہَذَا۔",,,19395,,
19396,"حَدَّثَنَا وَکِیعٌ ، عَنْ عُمَرَ بْنِ بَشِیرٍ ، عَنِ الشَّعْبِیِّ فِی رَجُلَیْنِ مَرَّ عَلَیْہِمَا طَائِرٌ فَقَالَ أَحَدُہُمَا : امْرَأَتُہُ طَالِقٌ إِنْ لَمْ یَکُنْ طیرًا ، وَقَالَ الآخَرُ : امْرَأَتُہُ طَالِقٌ إِنْ لَمْ یَکُنْ غُرَابًا ، وَطَارَ الطیر قَالَ : یَعْتَزِلاَنِ نِسَائَہُمَا۔",,,19396,,
19397,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ ابْنِ أَبِی ذِئْبٍ قَالَ : حدَّثَنَا الْحَارِثُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَمْزَۃَ بْنِ عَبْدِ اللہِ بْنِ عُمَرَ قَالَ : کَانَتْ تَحْتَ ابْنِ عُمَرَ امْرَأَتُہُ ، وَکَانَ یُعْجَبُ بِہَا ، وَکَانَ عُمَرُ یَکْرَہُہَا فَقَالَ لَہُ : طَلِّقْہَا ، فَأَبَی فَذَکَرَہَا عُمَرُ لِرَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَطِعْ أَبَاک وَطَلِّقْہَا۔ (ترمذی 1189۔ ابوداؤد 5095)",,,19397,,
19398,"حَدَّثَنَا جَرِیرٌ ، عَنِ الرُّکَیْنِ ، عَنْ أَبِی طَلْحَۃَ الأَسَدِیِّ قَالَ : کُنْتُ جَالِسًا عِنْدَ ابْنِ عَبَّاسٍ فَأَتَاہُ أَعْرَابِیَّانِ فَاکْتَنَفَاہُ فَقَالَ أَحَدُہُمَا : إنِّی کُنْت أَبْغِی إبِلاً لِی فَنَزَلْت بِقَوْمٍ فَأَعْجَبَتْنِی فَتَاۃٌ لَہُمْ فَتَزَوَّجْتہَا فَحَلَفَ أَبَوَایَ أَنْ لاَ یَضُمَّاہَا أَبَدًا ، وَحَلَفَ الْفَتَی فَقَالَ : عَلَیْہِ أَلْفُ مُحَرَّرٍ وَأَلْفُ ہَدِیَّۃٍ وَأَلْفُ بَدَنَۃٍ إِنْ طَلَّقَہَا ، فَقَالَ ابْنُ عَبَّاسٍ : مَا أَنَا بِالَّذِی آمُرُک أَنْ تُطَلِّقَ امْرَأَتَکَ وَلاَ أَنْ تَعُقَّ وَالِدَیْک ، قَالَ : فَمَا أَصْنَعُ بِہَذِہِ الْمَرْأَۃِ ؟ قَالَ : ابْرِرْ وَالِدَیْک۔",,,19398,,
19399,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ قَالَ : کَانَ مِنَ الْحَیِّ فَتًی فِی بَیْتٍ لَمْ تَزَلْ بِہِ أُمُّہُ حَتَّی زَوَّجَتْہُ ابْنَۃَ عَمٍّ لَہُ فَعَلِقَ مِنْہَا مَعْلَقًا ، ثُمَّ قَالَتْ لَہُ أُمُّہُ : طَلِّقْہَا ، فَقَالَ : لاَ أَسْتَطِیعُ ، عَلِقَتْ مِنِّی مَا لاَ أَسْتَطِیعُ أَنْ أُطَلِّقَہَا مَعَہُ ، قَالَتْ : فَطَعَامُک وَشَرَابُک عَلَیَّ حَرَامٌ حَتَّی تُطَلِّقَہَا ، فَرَحَلَ إلَی أَبِی الدَّرْدَائِ إلَی الشَّامِ، فَذَکَرَ لَہُ شَأْنَہُ ، فَقَالَ : مَا أَنَا بِالَّذِی آمُرُک أَنْ تُطَلِّقَ امْرَأَتَکَ ، وَلاَ أَنَا بِالَّذِی آمُرُک أَنْ تَعُقَّ وَالِدَتک۔",,,19399,,
19400,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ حُمَیْدٍ ، عَنِ الْحَسَنِ قَالَ : جَائَہُ رَجُلٌ فَقَالَ : إنَّ أُمَّہُ أَمَرَتْہُ أَنْ یَتَزَوَّجَ ، ثُمَّ أَمَرَتْہُ بَعدَ ذلِکَ أَنْ یُطَلِّقَ فَقَالَ الْحَسَنُ لَیسَ طَلاَقہ امرَأَتہ مِنْ بَرِّ أُمِّہ فِی شَیْئٍ۔",,,19400,,
19401,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی بِشْرٍ ، عَنْ عَمْرِو بْنِ ہَرِمٍ ، عَنْ جَابِرِ بْنِ زَیْدٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ فِی رَجُلٍ کُنَّ لَہُ نِسْوَۃٌ فَطَلَّقَ إحْدَاہُنَّ ، ثُمَّ مَاتَ ، لَمْ یَعْلَمْ أَیَّتَہنَّ طَلَّقَ ؟ قَالَ : فَقَالَ ابْنُ عَبَّاسٍ : یَنَالُہُنَّ مِنَ الطَّلاَقِ مَا یَنَالُہُنَّ مِنَ الْمِیرَاثِ۔",,,19401,,
19402,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ إسْمَاعِیلَ بْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ فِی رَجُلٍ کُنَّ لَہُ أَرْبَعُ نِسْوَۃٍ فَطَلَّقَ إحْدَاہُنَّ ، ثُمَّ تَزَوَّجَ أُخْرَی ، ثُمَّ مَاتَ وَلَمْ یُدْرَ أَیَّتَہنَّ الَّتِی طَلَّقَ ، قَالَ : فَقَالَ الشَّعْبِیُّ : للأربع الأول ثَلاَثَۃُ أَرْبَاعِ الْمِیرَاثِ وَلِلْخَامِسَۃِ الرُّبُعُ۔",,,19402,,
19403,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ فِی رَجُلٍ کُنَّ لَہُ أَرْبَعُ نِسْوَۃٍ فَطَلَّقَ إحْدَاہُنَّ لاَ یَدْرِی أَیَّتَہنَّ طَلَّقَ ؟ ، ثُمَّ تَزَوَّجَ خَامِسَۃً ، ثُمَّ مَاتَ ، قَالَ : یُکْمَلُ لِہَذِہِ الَّتِی زَوَّجَ رُبُعُ الْمِیرَاثِ وَمَا بَقِیَ بَیْنَ ہَؤُلاَئِ الأَرْبَعِ۔",,,19403,,
19404,"حَدَّثَنَا عَبْدُالأَعْلَی، عَنْ بُرْدٍ، عَنْ مَکْحُولٍ فِی رَجُلٍ کُنَّ لَہُ أَرْبَعُ نِسْوَۃٍ فَطَلَّقَ إحْدَاہُنَّ، ثُمَّ تَزَوَّجَ خَامِسَۃً، ثُمَّ مَاتَ وَلاَ یَعْلَمْ أَیَّتَہنَّ طَلَّقَ ؟ قَالَ : رُبُعُ الثُّمُنِ لِلَّتِی تَزَوَّجَ أَخِیرًا وَثَلاَثَۃُ أَرْبَاعٍ بَیْنَ ہَؤُلاَئِ الأَرْبَعِ۔",,,19404,,
19405,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ أَبِی عُثْمَانَ قَالَ : سُئِلَ عَطَائٌ عَنْ ذَلِکَ فَقَالَ : رُبُعُ الرُّبُعِ ، أَوْ رُبُعُ الثُّمُنِ لِلَّتِی تَزَوَّجَہَا آخِرًا وَیَقْسِمُ مَا بَقِیَ بَیْنَہُنَّ۔",,,19405,,
19406,"حَدَّثَنَا عَبْدُالْوَہَّابِ بْنُ عَطَائٍ، عَنْ سَعِیدٍ، عَنْ قَتَادَۃَ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ، وَالْحَسَنِ قَالاَ: یُقْرَعُ بَیْنَہُنَّ۔",,,19406,,
19407,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ بِشْرِ بْنِ مَنْصُورٍ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ قَالَ لامْرَأَتِہِ : ہِیَ طَالِقٌ إِنْ لَمْ یَتَزَوَّجْ عَلَیْہَا ، قَالَ : ہِیَ امْرَأَتُہُ حَتَّی یَتَزَوَّجَ ، فَإِنْ مَاتَ وَاحِدٌ مِنْہُمَا فَلاَ مِیرَاثَ بَیْنَہُمَا۔",,,19407,,
19408,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ فِی رَجُلٍ حَلَفَ : امْرَأَتُہُ طَالِقٌ إِنْ لَمْ یَضْرِبْ غُلاَمَہُ مِئَۃَ سَوْطٍ ، قَالَ : ہِیَ امْرَأَتُہُ حَتَّی یَمُوتَ الْغُلاَمُ۔",,,19408,,
19409,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ غَیْلاَنَ ، عَنِ الْحَکَمِ قَالَ : امْرَأَتُہُ طَالِقٌ إِنْ لَمْ یَضْرِبْ غُلاَمَہُ ، فَأَبَقَ ، قَالَ : یُجَامِعُہَا وَیَتَوَارَثَانِ۔",,,19409,,
19410,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ حَمَّادٍ فِی رَجُلٍ قَالَ : إِنْ لَمْ آتِ الْبَصْرَۃَ فَامْرَأَتُہُ طَالِقٌ ، قَالَ : فَلَمْ یَأْتِہَا حَتَّی مَاتَتْ ، ثُمَّ أَتَاہَا بَعْدُ ، قَالَ : لاَ مِیرَاثَ لَہُ مِنْہَا ، إنَّمَا اسْتَبَانَ حنثہ الآنَ۔",,,19410,,
19411,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنِ الشَّعْبِیِّ قَالَ : إِنْ أتی البصرۃ بَعْدَ الْمَوْتِ وَرِثَہَا۔",,,19411,,
19412,"حَدَّثَنَا مُحَمَّدُ بْنُ یَزِیدَ ، عَنْ أَبِی الْعَلاَئِ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، وَالْحَسَنِ قَالاَ ؛ فِی الرَّجُلِ یَقُولُ لامْرَأَتِہِ : إِنْ لَمْ أَتَزَوَّجْ عَلَیْہَا ، وَإِنْ لَمْ أُخْرِجْک فَأَنْتِ طَالِقٌ ، قَالاَ : لاَ یَقْرَبُہَا ، وَإِنْ مَاتَ قَبْلَ ذَلِکَ لَمْ یَتَوَارَثَا۔",,,19412,,
19413,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ أَشْعَثَ ، عَنِ الحسن ؛ فِی رَجُلٍ قَالَ : إِنْ لَمْ أَخْرُجْ إلَی وَاسِطَ فَامْرَأَتُہُ طَالِقٌ، قَالَ : یَغْشَاہَا وَلاَ یَتَوَارَثَانِ ، وَقَالَ ابْنُ سِیرِینَ : لاَ یَغْشَاہَا حَتَّی یَفْعَلَ مَا قَالَ۔",,,19413,,
19414,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : قَالَ شُرَیْحٌ : أَتَانِی عُرْوَۃُ الْبَارِقِیُّ مِنْ عِنْدِ عُمَرَ فِی الْمُطَلِّقِ ثَلاَثًا فِی مَرَضِہِ : ترثہ مَا دَامَتْ فِی الْعِدَّۃِ لاَ یَرِثُہَا وَعَلَیْہَا عِدَّۃُ الْمُتَوَفَّی عَنْہَا زَوْجُہَا۔",,,19414,,
19415,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : عَلَیْہَا عِدَّۃُ الْمُتَوَفَّی عَنْہَا زَوْجُہَا۔",,,19415,,
19416,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ وَمُحَمَّدٍ قَالاَ : إِنْ مَاتَ الرَّجُلُ فِی عِدَّتِہَا اعْتَدَّتْ عِدَّۃَ الْمُتَوَفَّی عَنْہَا زَوْجُہَا أَرْبَعَۃَ أَشْہُرٍ وَعَشْرًا۔",,,19416,,
19417,"حَدَّثَنَا وَکِیعٌ ، عَنْ زَکَرِیَّا ، عَنِ الشَّعْبِیِّ قَالَ : بَابٌ مِنَ الطَّلاَقِ جَسِیمٌ : إذَا وَرِثَتِ اعْتَدَّتْ۔",,,19417,,
19418,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ حَبِیبٍ ، عَنْ عَمْرٍو ، عَنْ عِکْرِمَۃَ أَنَّہُ قَالَ : لَوْ لَمْ یَبْقَ مِنْ عِدَّتِہَا إلاَّ یَوْمٌ وَاحِدٌ ، ثُمَّ مَاتَ ، وَرِثَتْہُ وَاسْتَأْنَفَتْ عِدَّۃَ الْمُتَوَفَّی عَنْہَا۔",,,19418,,
19419,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ شَیْبَانَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، عَنْ شُرَیْحٍ قَالَ : تَسْتَأْنِفُ الْعِدَّۃَ۔",,,19419,,
19420,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ، عَنْ مَسْرُوقٍ قَالَ : حرَّمَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أُمَّ وَلَدِہِ وَحَلَفَ : أن لاَ یَقْرَبُہَا فَأَنْزَلَ اللَّہُ تَعَالَی : {یَا أَیُّہَا النَّبِیُّ لِمَ تُحَرِّمُ مَا أَحَلَّ اللَّہُ لَکَ تَبْتَغِی مَرْضَاۃَ أَزْوَاجِکَ} إلَی آخِرِ الآیَۃِ فَقِیلَ لَہُ : أَمَّا الْحَرَامُ فَحَلاَلٌ وَأَمَّا الْیَمِینُ الَّتِی حَلَفت عَلَیْہَا فَقَدْ فَرَضَ اللَّہُ لکم تَحِلَّۃَ أَیْمَانِکُمْ فِی الْیَمِینِ الَّتِی حَلَفت عَلَیْہَا۔ (نسائی 8907۔ ابن جریر 156)",,,19420,,
19421,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ قَالَ لأُمِّ وَلَدِہِ : أَنْتِ عَلَیَّ حَرَامٌ ، قَالَ :یُکَفِّرُ یَمِینَہُ وَیَأْتِی أَمَتَہُ۔",,,19421,,
19422,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنِ الْحَسَنِ بْنِ صَالِحٍ ، عَنِ ابْنِ أَبِی لَیْلَی قَالَ : إِنْ قَالَ : أَمَتُہُ عَلَیْہِ حَرَامٌ قَالَ : یُکَفِّرُ یَمِینَہُ وَیَأْتِی أَمَتَہُ۔",,,19422,,
19423,حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ عَطَائٍ الْخُرَاسَانِیِّ أَنَّ رَجُلاً طَلَّقَ امْرَأَتَہُ فَشَہِدَ عَلَیْہِ ثَلاَثَۃُ نَفَرٍ ، کُلُّ رَجُلٍ یَشْہَدُ فِی مَوْطِنٍ غَیْرِ مَوْطِنِ صَاحِبِہِ فَقَضَی عَبْدُ اللہِ بْنُ مَوْہَبٍ أَنَّہَا تَطْلِیقَۃٌ۔,,,19423,,
19424,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ حَمَّادٍ قَالَ : إذَا قَالَ الرَّجُلُ لامْرَأَتِہِ : أَنْتِ طَالِقٌ إِنْ دَخَلْت بَیْتَ فُلاَنٍ ، فَأَدْخَلَتْ بَعْضَ جَسَدِہَا فَقَدْ وَقَعَ الطَّلاَقُ عَلَیْہَا۔",,,19424,,
19425,"حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ فِی رَجُلٍ قَالَ لامْرَأَتِہِ : لاَ تَحِلِّینَ لِی قَالَ : نِیَّتُہُ إِنْ نَوَی وَاحِدَۃً فَوَاحِدَۃٌ ، وَإِنْ نَوَی ثَلاَثًا فَثَلاَثٌ۔",,,19425,,
19426,حَدَّثَنَا شَرِیکٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ مِثْلَہُ۔,,,19426,,
19427,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ وَاقِدٍ مَوْلَی بَنِی حَنْظَلَۃَ قَالَ : سُئِلَ عَطَائُ بْنُ أَبِی رَبَاحٍ عَنْ رَجُلٍ أَخَذَ لِصًّا فَاجْتَمَعَ عَلَیْہِ النَّاسُ فَطَلَبُوا إلَیْہِ أَنْ یَتْرُکَہُ ، فَقَالَ : إِنْ تَرَکْتہ فَامْرَأَتہ طَالِقٌ ثَلاَثًا ، فَغَلَبَہُ عَلَی نَفْسِہِ فأُفْلِتَ مِنْہُ قَالَ : فَقَالَ عَطَائٌ : لَیْسَ عَلَیْہِ شَیْئٌ ، إِنَّمَا غَلَبَہ عَلَی نَفْسِہِ۔",,,19427,,
19428,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ أَنَّہُ کَانَ یَقُولُ : إذَا زَوَّجَ الرَّجُلُ ابْنَتَہُ وَہِیَ صَغِیرَۃٌ فَرَأَی أَنْ یَخْلَعَہَا فَذَلِکَ جَائِزٌ عَلَیْہَا ، فَقَالَ یُونُسُ : وَکَانَ غَیْرُ الْحَسَنِ لاَ یَرَی ذَلِکَ۔",,,19428,,
19429,"حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، عَنْ شُرَیْحٍ أَنَّ رَجُلاً خَلَعَ ابْنَتَہُ فَلَمْ تَرْضَ ، قَالَ : وَقَعَ عَلَیْہَا الطَّلاَقُ وَأَبُوہَا ضَامِنٌ لِمَا افْتَدَی بِہِ۔",,,19429,,
19430,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ قَالَ : حدَّثَنَا زُہَیْرٌ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ وَالْحَکَمِ فِی امْرَأَۃٍ قَالَ لَہَا زَوْجُہَا : إذَا حِضْت فَأَنْتِ طَالِقٌ ، فَارْتَفَعَتْ حَیْضَتُہَا وحبلت قَالاَ : لیُجَامِعُہَا حَتَّی تَحِیضَ ، وَقَالَ عَامِرٌ : إِنْ صَلَحَ فِی الْقَرِیبِ ، فَإِنَّہُ یَصْلُحُ فِی الْبَعِیدِ۔",,,19430,,
19431,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا شُعْبَۃُ قَالَ : سَأَلْتُ الْحَکَمَ وَحَمَّادًا عَنْ رَجُلٍ قَالَ لامْرَأَتِہِ : أَنْتِ طَالِقٌ کُلَّمَا شِئْت ، قَالَ الْحَکَمُ : کُلَّمَا شَائَتْ فَہِیَ طَالِقٌ ، وَقَالَ حَمَّادٌ : مَرَّۃً۔",,,19431,,
19432,"حَدَّثَنَا عَفَّانُ قَالَ : حدَّثَنَا أَبُو عَوَانَۃَ ، عَنِ أَبِی بِشْرٍ ، عَنْ عَطَائٍ قَالَ : إذَا زَوَّجَ الأَبُ فَالطَّلاَقُ بِیَدِ الأَبِ، وَقَالَ مُجَاہِدٌ : مَنْ مَلَکَ النِّکَاحَ ، فَإِنَّ فِی یَدِہِ الطَّلاَقَ۔",,,19432,,
19433,حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ أَنَّہُ کَانَ یَرَاہُ جَائِزًا۔,,,19433,,
19434,حَدَّثَنَا ہُشَیْمٌ، عَنْ حَجَّاجٍ، عَنْ عَطَائٍ وَعَنِ ابْنِ سَالِمٍ، عَنِ الشَّعْبِیِّ أَنَّہُمَا کَانَا یَرَیَانِ طَلاَقَ الشِّرْکِ جَائِزًا۔,,,19434,,
19435,حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ أَنَّہُ کَانَ لاَ یَرَاہُ جَائِزًا۔,,,19435,,
19436,"حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ قَالَ : قُلْتُ لِعَطَائٍ : أَبَلَغَک ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ تَرَکَ أَہْلَ الْجَاہِلِیَّۃِ عَلَی مَا کَانُوا عَلَیْہِ مِنْ نِکَاحٍ ، أَوْ طَلاَقٍ ؟ قَالَ : نَعَمْ۔",,,19436,,
19437,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ قَالَ : سَأَلْتُ الْحَکَمَ وَحَمَّادًا فَقَالاَ : جَائِزٌ یَعْنِی طَلاَقَ الشِّرْکِ۔",,,19437,,
19438,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ فِرَاسٍ ، عَنْ عَامِرٍ قَالَ : لَمْ یَزِدْہُ الإِسْلاَمُ إلاَّ شِدَّۃً۔",,,19438,,
19439,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ أَنَّ رَجُلاً طَلَّقَ امْرَأَتَہُ فِی الْجَاہِلِیَّۃِ تَطْلِیقَتَیْنِ ، ثُمَّ أَسْلَمَ فَطَلَّقَہَا فِی الإِسْلاَمِ تَطْلِیقَۃً فَسَأَلَ عُمَرُ عَبْدَ الرَّحْمَنِ بْنَ عَوْفٍ فَقَالَ : طَلاَقُہُ فِی الشِّرْکِ لَیْسَ بِشَیْئٍ۔",,,19439,,
19440,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ الْحَذَّائِ ، عَنْ عِکْرِمَۃَ فِی قَوْلِہِ تعالی : {وَلاَ یَحِلُّ لَہُنَّ أَنْ یَکْتُمْنَ مَا خَلَقَ اللَّہُ فِی أَرْحَامِہِنَّ} قَالَ : الْحَیْضُ ، ثُمَّ قَالَ خَالِدٌ : الدَّمُ۔",,,19440,,
19441,"حدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ مُطَرِّفٍ ، عَنِ الْحَکَمِ ، عَنْ مُجَاہِدٍ وَإِبْرَاہِیمَ قَالَ أَحَدُہُمَا : الْحَبَلُ ، والحیض وَقَالَ الآخَرُ الْحَیْضُ۔",,,19441,,
19442,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ قَالَ : أَنْ تَقُولَ : أَنَا حَامِلٌ ، وَلَیْسَتْ بِحَامِلٍ ، أَوْ تَقُولَ : أَنَا حَائِلٌ ، وَلَیْسَتْ بِحَائِلٍ۔",,,19442,,
19443,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ عُبَیْدَۃَ ، عَنِ ابْنِ سَعِیدِ بْنِ جُبَیْرٍ ، عَنْ أَبِیہِ ، عَنِ ابْنِ عَبَّاسٍ قَالَ : الْحَیْضُ وَالْحَبَلُ ، وَقَالَ إبْرَاہِیمُ الْحَبَلُ۔",,,19443,,
19444,"حَدَّثَنَا عَبْدَۃُ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ قَالَ : الْوَلَدُ وَالْحَیْضُ۔",,,19444,,
19445,"حَدَّثَنَا شَبَابَۃُ ، عَنْ وَرْقَائَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ : {وَلاَ یَحِلُّ لَہُنَّ أَنْ یَکْتُمْنَ مَا خَلَقَ اللَّہُ فِی أَرْحَامِہِنَّ} قَالَ : لاَ یَحِلُّ لِلْمُطَلَّقَۃِ أَنْ تَقُولَ : أنا حَائِضٌ ، وَلَیْسَتْ بِحَائِضٍ ، وَلاَ تَقُولُ : إنِّی حُبْلَی ، وَلَیْسَتْ بِحُبْلَی وَلاَ تَقُولُ : لَسْت بِحُبْلَی ، وَہِیَ حُبْلَی۔",,,19445,,
19446,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ خَالِدٍ ، عَنْ عِکْرِمَۃَ (وَلاَ یَحِلُّ لَہُنَّ أَنْ یَکْتُمْنَ مَا خَلَقَ اللَّہُ فِی أَرْحَامِہِنَّ) قَالَ : الْحَیْضُ۔",,,19446,,
19447,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُطَرِّفٍ ، عَنِ الْحَکَمِ ، عَنْ مُجَاہِدٍ {وَلاَ یَحِلُّ لَہُنَّ أَنْ یَکْتُمْنَ مَا خَلَقَ اللَّہُ فِی أَرْحَامِہِنَّ} قَالَ : الْحَبَلُ وَالْحَیْضُ قَالَ : وَقَالَ إبْرَاہِیمُ : الْحَیْضُ وَحْدَہُ۔",,,19447,,
19448,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ جَعْفَرِ بْنِ مُحَمَّدٍ ، عَنْ سَعْدِ بْنِ إبْرَاہِیمَ أَنَّ رَجُلاً قَالَ لامْرَأَتِہِ : أَنْتِ طَالِقٌ فَسَأَلَ الْقَاسِمَ وَسَالِمًا فَقَالاَ : نَرَی أَنْ نُحَلِّفَہُ مَا أَرَادَ البَتَّۃَ۔",,,19448,,
19449,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ، عَنِ ابْنِ لَہِیعَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ أَبِی جَعْفَرٍ ، عَنْ بُکَیْرِ بْنِ عَبْدِ اللہِ بْنِ الأَشَجِّ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ فِی رَجُلٍ قَالَ لامْرَأَتِہِ : أَنْتِ طَالِقٌ ، ولَمْ یُسَمِّ عَدَدَ الطَّلاَقِ قَالَ : نحملہ ذَلِکَ ، إِنْ نَوَی وَاحِدَۃً ، أَوِ اثْنَتَیْنِ ، أَوْ ثَلاَثَۃً۔",,,19449,,
19450,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : نَفَقَۃُ الْمُطَلَّقَۃِ کُلَّ یَوْمٍ نِصفُ صَاعٍ مِنْ بُرٍّ۔",,,19450,,
19451,حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنِ الشَّعْبِیِّ فِی امْرَأَۃٍ أَضَرَّ بِہَا زَوْجُہَا فَفَرَضَ لَہَا الشَّعْبِیُّ فِی کُلِّ شَہْرٍ خَمْسَۃَ عَشَرَ صَاعًا مِنْ حِنْطَۃٍ وَدِرْہَمَیْنِ۔,,,19451,,
19452,"حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ مِنْہَالِ بْنِ خَلِیفَۃَ ، عَنْ حَجَّاجٍ ، عَنْ قَتَادَۃَ ، عَنْ خِلاَسٍ ، عَنْ عَلِیٍّ أنَّہُ فَرَضَ لاِمْرَأَۃٍ وَخَادِمِہَا اثْنَیْ عَشَرَ دِرْہَمًا کُلَّ شَہْرٍ : أَرْبَعَۃً لِلْخَادِمِ وَثَمَانِیَۃً لِلْمَرْأَۃِ۔",,,19452,,
19453,حَدَّثَنَا أَبُو خَالِدٍ الأحمر ، عَنْ أُمِّ خَصِیبٍ الْوَابِشِیَّۃِ أَنَّ زَوْجَہَا تُوُفِّیَ وَتَرَکَہَا حَامِلاً ، فَخَاصَمَتْ إلَی شُرَیْحٍ ، فَقَضَی أَنْ یُنْفَقَ عَلَیْہَا مِنْ جَمِیعِ الْمَالِ خَمْسَۃَ عَشَرَ۔,,,19453,,
19454,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، قَالَ : یُنْفِقُ عَلَی خَادِمٍ وَاحِدَۃً۔",,,19454,,
19455,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنْ عِکْرِمَۃَ قَالَ : خَاصَمَ عُمَرُ أُمَّ عَاصِمٍ فِی عَاصِمٍ إلَی أَبِی بَکْرٍ فَقَضَی لَہَا بِہِ مَا لَمْ یَکْبَرْ ، أَوْ یَتَزَوَّجْ فَیَخْتَارُ لِنَفْسِہِ قَالَ : ہِیَ أَعْطَفُ وَأَلْطَفُ وَأَرَقُّ وَأَحْنَی وَأَرْحَمُ۔",,,19455,,
19456,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ یَزِیدَ بْنِ یَزِیدَ بْنِ جَابِرٍ ، عَنْ إسْمَاعِیلَ بْنِ عُبَیْدِ اللہِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ غَنم قَالَ : شَہِدْت عُمَرَ خَیَّرَ صَبِیًّا بَیْنَ أَبِیہِ وَأُمِّہِ۔",,,19456,,
19457,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ وَیُونُسَ ، عَنِ ابْنِ سِیرِینَ ، عَنْ شُرَیْحٍ قَالَ : الأَبُ أَحَقُّ ، وَالأُمُّ أَرْفَقُ۔",,,19457,,
19458,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ زِیَادِ بْنِ سَعْدٍ ، أَوْ حُدِّثْت عَنْہُ ، عَنْ ہِلاَلِ بْنِ أَبِی مَیْمُونَۃَ ، عَنْ أَبِیہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ خَیَّرَ صَبِیًّا بَیْنَ أَبَوَیْہِ۔ (ترمذی 1357۔ احمد 2/246),,,19458,,
19459,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ قَالَ : ہِیَ أَحَقُّ بِوَلَدِہَا ، وَإِنْ تَزَوَّجَتْ۔",,,19459,,
19460,"حَدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنْ عُبَیْدَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : إذَا طَلَّقَ الرَّجُلُ امْرَأَتَہُ فَہِیَ أَحَقُّ بِوَلَدِہَا مَا لَمْ تَتَزَوَّجْ ، أَوْ تَخْرُجْ بِہِ مِنَ الأَرْضِ۔",,,19460,,
19461,حَدَّثَنَا عُبَد اللہِ، عَنْ إسْرَائِیلَ، عَنْ جَابِرٍ، عَنْ عَامِرٍ، عَنْ مَسْرُوقٍ أنَّہُ خَیَّرَ صَبِیًّا بَیْنَ أَبَوَیْہِ أَیَّہُمَا یَخْتَارُ۔,,,19461,,
19462,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ مُبَارَکٍ ، عَنْ یَحْیَی بن أبی کثیر ، عَنْ سلمان أَبِی مَیْمُونَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ قَالَ : جَائَتِ امْرَأَۃٌ إلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَدْ طَلَّقَہَا زَوْجُہَا فَأَرَادَتْ أَنْ تَأْخُذَ وَلَدَہَا قَالَ : فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : اسْتَہِمَا فِیہِ فَقَالَ الرَّجُلُ : مَنْ یَحُولُ بَیْنِی وَبَیْنَ ابْنِی ؟ فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لِلاِبْنِ : اخْتَرْ أَیَّہُمَا شِئْت قَالَ : فَاخْتَارَ أُمَّہُ فَذَہَبَتْ بِہِ۔\n\n(احمد 2/447۔ طحاوی 3088)",,,19462,,
19463,حَدَّثَنَا حَفْصٌ ، عَنْ مُجَالِدٍ ، عَنِ الشَّعْبِیِّ أَنَّ أَبَا بَکْرٍ قَضَی بِعَاصِمِ بْنِ عُمَرَ لأُمِّہِ ، وَقَضَی عَلَی عُمَرَ بِالنَّفَقَۃِ۔,,,19463,,
19464,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ قَالَ : حدَّثَنَا سَعِیدُ بْنُ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ أَنَّ عُمَرَ بْنَ الْخَطَّابِ طَلَّقَ أُمَّ عَاصِمٍ ، ثُمَّ أَتی عَلَیْہَا ، وَفِی حِجْرِہَا عَاصِمٌ ، فَأَرَادَ أَنْ یَأْخُذَہُ مِنْہَا ، فَتَجَاذَبَاہُ بَیْنَہُمَا حَتَّی بَکَی الْغُلاَمُ ، فَانْطَلَقَا إلَی أَبِی بَکْرٍ فَقَالَ لَہُ أَبُو بَکْرٍ : یَا عُمَرُ ، مَسْحُہَا وَحِجْرُہَا وَرِیحُہَا خَیْرٌ لَہُ مِنْک حَتَّی یَشِبَّ الصَّبِیُّ فَیَخْتَارَ۔",,,19464,,
19465,"حدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ یَحْیَی ، عَنِ الْقَاسِمِ أَنَّ عُمَرَ بْنَ الْخَطَّابِ طَلَّقَ امرأتہ جَمِیلَۃَ بِنْتَ عَاصِمِ بْنِ ثَابِتِ بْنِ أَبِی الأَقْلَحِ فَتَزَوَّجَتْ ، فَجَائَ عُمَرُ فَأَخَذَ ابْنَہُ فَأَدْرَکَتْہُ الشَّمُوسُ ابْنَۃُ أَبِی عَامِرٍ الأَنْصَارِیَّۃُ ، وَہِیَ أُمُّ جَمِیلَۃَ ، فَأَخَذَتْہُ ، فَتَرَافَعَا إلَی أَبِی بَکْرٍ وَہُمَا مُتَشَبِّثَانِ ، فَقَالَ لِعُمَرَ : خَلِّ بَیْنَہَا وَبَیْنَ ابْنِہَا ، فأخذتہ۔",,,19465,,
19466,"حَدَّثَنَا وَکِیعُ بْنُ الْجَرَّاحِ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ مُحَمَّدِ بْنِ کَعْبٍ أَنَّ امْرَأَۃً مِنْ أَہْلِ الْبَادِیَۃِ کَانَتْ عِنْدَ رَجُلٍ مِنْ بَنِی عَمِّہَا فَمَاتَ عَنْہَا فَتَزَوَّجَہَا رَجُلٌ مِنَ الأَنْصَارِ فَجَائَ بَنُو عَمِّ الْجَارِیَۃِ فَقَالُوا : إنا أَخِذُو ابْنَتَنَا قَالَتْ : إنِّی أَنْشُدُکُمُ اللَّہَ أَنْ تَفَرقُوا بَیْنِی وَبَیْنَ ابْنَتِی فَأَنَا الْحَامِلُ وَأَنَا الْمُرْضِعُ وَلَیْسَ أَحَدٌ أخیر لقرب ابْنَتِی مِنِّی فَأَبَوا ، فَقَالَت : مَوْعِدُکُمْ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، ثُمَّ قَالَ : إذَا خَیَّرَک رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقُولِی : أَخْتَارُ اللَّہَ وَالإِیمَانَ وَدَارَ الْمُہَاجِرِینَ وَالأَنْصَارِ فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : وَالَّذِی نَفْسِی بِیَدِہِ ، لاَ تَذْہَبُونَ بِہَا مَا بَقِیَتْ عُنُقِی فِی مَکَانِہَا وَجَاؤُوا إلَی أَبِی بَکْرٍ فَقَضَی لَہُمْ بِہَا فَقَالَ بِلاَلٌ : یَا خَلِیفَۃَ رَسُولِ اللہِ ، شَہِدْت ہَؤُلاَئِ النَّفَرُ وَہَذِہِ الْمَرْأَۃُ عِنْدَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ اخْتَصَمُوا فَقَضَی بِہَا لأُمِّہَا ، فَقَالَ أَبُو بَکْرٍ : وَأَنَا وَالَّذِی نَفْسِی بِیَدِہِ ، لاَ یَذْہَبُونَ بِہَا مَا دَامَتْ عُنُقِی فِی مَکَانِہَا فَدَفَعَہَا إلَی أُمِّہَا۔",,,19466,,
19467,"حَدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنْ زَکَرِیَّا ، عَنِ الشَّعْبِیِّ فِی جَارِیَۃٍ أَرَادَتْ أُمُّہَا أَنْ تَخْرُجَ بِہَا مِنَ الْکُوفَۃِ فَقَالَ : عَصَبَتُہَا أَحَقُّ بِہَا مِنْ أُمِّہَا إِنْ خَرَجَتْ۔",,,19467,,
19468,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ یُونُسَ بْنِ عَبْدِ اللہِ بْنِ رَبِیعَۃَ ، عَنْ عُمَارَۃَ بْنِ رَبِیعَۃَ الْجَرْمِیِّ قَالَ : غَزَا أَبِی نَحْوَ الْبَحْرِ فِی بَعْضِ تِلْکَ الْمَغَازِی قَالَ : فَقُتِلَ فَجَائَ عَمِّی لِیَذْہَبَ بِی فَخَاصَمَتْہُ أُمِّی إلَی عَلِیٍّ قَالَ : وَمَعِی أَخٌ لِی صَغِیرٌ قَالَ : فَخَیَّرَنِی عَلِیٌّ ثَلاَثًا فَاخْتَرْت أُمِّی فَأَبَی عَمِّی أَنْ یَرْضَی قَالَ : فَوَکَزَہُ عَلِیٌّ بِیَدِہِ وَضَرَبَہُ بِدِرَّتِہِ وَقَالَ : وَہَذَا أَیْضًا لو قَدْ بَلَغَ خُیِّر۔",,,19468,,
19469,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ قَالَ : خَیَّرَ شُرَیْحٌ غُلاَمًا وَجَارِیَۃً یَتِیمَیْنِ فَاخْتَارَتِ الْجَارِیَۃُ مَوَالِیَہَا وَاخْتَارَ الْغُلاَمُ عَمَّتَہُ فِیمَا یَحْسَبُ فَأَجَازَہُ شُرَیْحٌ۔",,,19469,,
19470,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی السَّفَرِ ، عَنِ الشَّعْبِیِّ فِی رَضَاعِ الصَّبِیِّ قَالَ : أُمُّہُ أَحَقُّ بِہِ مَا کَانَتْ فِی الْمِصْرِ فَإِذَا أَرَادَتْ أَنْ تَخْرُجَ بِہِ إلَی السَّوَادِ فَالأَوْلِیَائُ۔",,,19470,,
19471,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ حَمَّادٍ ، قَالَ : سَمِعْتُہُ یَقُولُ : قُلْتُ لإبْرَاہِیمَ : مَا الإِیلاَئُ ؟ قَالَ : أَنْ یَحْلِفَ : لاَ یُکَلِّمُہَا وَلاَ یُجَامِعُہَا وَلاَ یَجْمَعُ رَأْسَہُ وَرَأْسَہَا وَلَیُغِیظَنَّہَا ، أَوْ لَیَسُوؤَنَّہَا۔",,,19471,,
19472,"حَدَّثَنَا عَبْدُ اللہِ بْنُ مُبَارَکٍ ، عَنْ مَعْمَرٍ ، عَنْ خُصَیْفٍ ، عَنِ الشَّعْبِیِّ فِی رَجُلٍ قَالَ لامْرَأَتِہِ : وَاللَّہِ لأسُوئَنَّکِ قَالَ : إِنْ کَانَ یَعْنِی بِذَلِکَ امْرَأَۃً یَتَزَوَّجُہَا ، أَوْ جَارِیَۃً یَتَسَرَّاہَا فَلَیْسَ بِشَیْئٍ ، وَإِنْ کَانَ یَعْنِی الْجِمَاعَ فَہُوَ إیلاَئٌ۔",,,19472,,
19473,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ شُعْبَۃَ ، قَالَ : سَمِعْتُ الْحَکَمَ یَقُولُ ؛ فِی الرَّجُلِ قَالَ لامْرَأَتِہِ : وَاللَّہِ لأسُوئَنَّکِ ، فَتَرَکَہَا أَرْبَعَۃَ أَشْہُرٍ قَالَ : فَہُوَ إیلاَئٌ۔",,,19473,,
19474,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ أَنَّ رَجُلاً ادَّعَی مَتَاعَ الْبَیْتِ فَجِئْنَ أَرْبَعُ نِسْوَۃٍ إلَی شُرَیْحٍ فَشَہِدْنَ قُلْنَ : دَفَعْنَا إلَیہ الصَّدَاقَ وَقُلْنَا : جَہِّزْہَا فَجَہَّزَہَا فَقَضَی عَلَیْہِ بِالْمَتَاعِ وَقَالَ : إنَّ عُقْرَہَا مِنْ مَالِک۔",,,19474,,
19475,"حَدَّثَنَا عَبْدُ الْوَہَّابِ ، عَنْ أَیُّوبَ قَالَ : کَتَبْت إلَی أَبِی قِلاَبَۃَ أَسْأَلُہُ عَنِ الرَّجُلِ یُحَدِّثُ : الْبَیْتُ فِی مَتَاعِ الْمَرْأَۃِ ، لِمَنْ ہُوَ ؟ قَالَ : ہُوَ لَہُ مَا لَمْ یُعْطِہَا۔",,,19475,,
19476,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ قَالَ : مَا کَانَ لِلرِّجَالِ فَہُوَ لِلرِّجَالِ ، وَمَا کَانَ لِلنِّسَائِ فَہُوَ لِلنِّسَائِ ، وَمَا بَقِیَ فَہُوَ لِمَنْ أَقَامَ الْبَیِّنَۃَ۔",,,19476,,
19477,"حَدَّثَنَا حَفْصٌ ، عَنْ عُبَیدۃ ، عَنْ إبْرَاہِیمَ قَالَ : مَا کَانَ لِلرِّجَالِ فَہُوَ لِلرِّجَالِ وَمَا کَانَ لِلنِّسَائِ فَہُوَ لِلنِّسَائِ ، وَمَا بَقِیَ بَیْنَہُمْ۔",,,19477,,
19478,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ؛ فِی الَّتِی یُتَوَفَّی عَنْہَا زَوْجُہَا قَالَ : لَہَا مَا أَغْلَقَتْ عَامَّۃَ مَالِہَا إلاَّ مَا کَانَ مِنْ مَتَاعِ الرَّجُلِ الطَّیْلَسَانُ وَالْقَمِیصُ وَنَحْوُہُ۔",,,19478,,
19479,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ حَمَّادٍ أنَّہُ سُئِلَ عَنْ مَتَاعِ الْبَیْتِ فَقَالَ : ثِیَابُ الْمَرْأَۃِ لِلْمَرْأَۃِ وَثِیَابُ الرَّجُلِ لِلرَّجُلِ وَمَا تَشَاجَرَا فَلَمْ یَکُنْ لِہَذَا وَلاَ لِہَذَا فَہُوَ لِلَّذِی فِی یَدِیہِ۔",,,19479,,
19480,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ إسْمَاعِیلَ بْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ، أَنَّہُ سَمِعَہُ یَقُولُ : إذَا دَخَلَتِ الْمَرْأَۃُ عَلَی زَوْجِہَا وَمَعَہَا حُلِیٌّ وَمَتَاعٌ فَمَکَثَتْ عِنْدَ زَوْجِہَا حَتَّی تَمُوتَ فَہُوَ مِیرَاثٌ ، وَإِنْ أَقَامَ أَہْلُہَا الْبَیِّنَۃَ أَنَّہُ کَانَ عَارِیَّۃً عِنْدَہَا إلاَّ أَنْ یَکُونُوا قَدْ أَعْلَمُوا بذَلِکَ الزَّوْجَ فِی حَیَاتِہَا قَبْلَ مَوْتِہَا۔",,,19480,,
19481,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، قَالَ : سَمِعْتُ شَیْخًا کَانَ أَدْرَکَ شُرَیْحًا یَذْکُرُ عَنْ شُرَیْحٍ أَنَّہُ قَالَ فِی مَتَاعِ الْبَیْتِ : فَمَا کَانَ مِنْ سِلاَحِ ، أَوْ مَتَاعِ الرَّجُلِ فَہُوَ لِلرَّجُلِ۔",,,19481,,
19482,"حَدَّثَنَا یَحْیَی بْنُ أَبِی غَنِیۃَ ، عَنْ أَبِیہِ ، عَنِ الْحَکَمِ قَالَ : إذَا مَاتَ الرَّجُلُ وَتَرَکَ مَتَاعًا مِنْ مَتَاعِ الْبَیْتِ فَمَا کَانَ لِلرَّجُلِ لاَ یَکُونُ لِلْمَرْأَۃِ فَہُوَ لِلرَّجُلِ وَمَا یَکُونُ لِلْمَرْأَۃِ لاَ یَکُونُ لِلرَّجُلِ ، ہُوَ لِلْمَرْأَۃِ ، وَمَا یَکُونُ لِلرِّجَالِ وَالنِّسَائِ فَہُوَ لِلرَّجُلِ إلاَّ أَنْ تُقِیمَ الْمَرْأَۃُ الْبَیِّنَۃَ أنَّہُ لَہَا۔",,,19482,,
19483,"حَدَّثَنَا ہُشَیْمٌ وَعَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنِ الشَّیْبَانِیِّ ، عَنِ ابْنِ مَعْقِلٍ قَالَ : رَضَاعُ الصَّبِیِّ مِنْ نَصِیبِہِ۔",,,19483,,
19484,حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ قَالَ رَضَاعُہُ مِنْ نَصِیبِہِ۔,,,19484,,
19485,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ قَالَ : أُتِیَ عَبْدُ اللہِ بْنُ عُتْبَۃَ فِی رَضَاعِ صَبِیٍّ فَجَعَلَ رَضَاعَہُ فی مَالِہِ وَقَالَ لِوَلِیِّہِ : لَوْ لَمْ یَکُنْ لَہُ مَالٌ لَجَعَلْنَا رَضَاعَہُ فِی مَالِکَ ، أَلاَ تَرَاہُ یَقُولُ : {وَعَلَی الْوَارِثِ مِثْلُ ذَلِکَ}",,,19485,,
19486,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ کَانَ یَقُولُ : إِنْ وَفَّی رَضَاعَہُ نَصِیبُہُ فَہُوَ مِنْ نَصِیبِہِ ، وَإِنْ لَمْ یَفِ فَہُوَ مِنْ جَمِیعِ الْمَالِ۔",,,19486,,
19487,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنْ إبْرَاہِیمَ ، عَنْ شُرَیْحٍ فِی الرَّضِیعِ : یُنْفَقُ عَلَیْہِ مِنْ نَصِیبِہِ قَلِیلاً کَانَ ، أَوْ کَثِیرًا۔",,,19487,,
19488,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ قَالَ : کَانَ أَصْحَابُنَا یَقُولُونَ : إِنْ کَانَ الْمَالُ لَہُ أُنْفِقَ عَلَیْہِ مِنْ جَمِیعِ الْمَالِ۔",,,19488,,
19489,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، عَنْ شُرَیْحٍ قَالَ کَانَ یَقُولُ : النَّفَقَۃُ وَالرَّضَاعُ مِنْ جَمِیعِ الْمَالِ۔",,,19489,,
19490,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ : {وَعَلَی الْوَارِثِ مِثْلُ ذَلِکَ} قَالَ : عَلَی الْوَارِثِ مِثْلُ مَا عَلَی أَبِیہِ أَنْ یَسْتَرْضِعَ لَہُ۔",,,19490,,
19491,حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مَنْصُورٍ ، وَمُغِیرَۃَ ، عَنْ إبْرَاہِیمَ {وَعَلَی الْوَارِثِ مِثْلُ ذَلِکَ} مثل مَا عَلَی أَبِیہِ مِنَ الرَّضَاعِ۔,,,19491,,
19492,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ وَحَمَّادٌ ، عَنْ إبْرَاہِیمَ قَالاَ : رَضَاعُ الصَّبِیِّ۔",,,19492,,
19493,"حَدَّثَنَا عَبْدُاللہِ بْنُ إدْرِیسَ، عَنْ أَشْعَثَ وَہِشَامٍ، عَنِ الْحَسَنِ: {وَعَلَی الْوَارِثِ مِثْلُ ذَلِکَ} فَقَالَ: الرَّضَاعُ۔",,,19493,,
19494,حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ قَالَ عَلَیْہِ الرَّضَاعُ وَلَیْسَ عَلَیْہِ نَفَقَۃُ الحَامِلِ۔,,,19494,,
19495,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ أَشْعَثَ وَعَنِ الْحَکَمِ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عَبَّاسٍ قَالَ : لاَ یُضَارُّ۔",,,19495,,
19496,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ، عَنْ جُوَیْبِرٍ، عَنِ الضَّحَّاکِ فِی ہَذِہِ الآیَۃِ: {وَعَلَی الْوَارِثِ مِثْلُ ذَلِکَ} قَالَ: الْوَالِدُ یَمُوتُ وَیَتْرُکُ وَلَدًا صَغِیرًا فَإِنْ کَانَ لَہُ مَالٌ فَرَضَاعُہُ فِی مَالِہِ ، وَإِنْ لَمْ یَکُنْ لَہُ مَالٌ فَرَضَاعُہُ عَلَی عَصَبَتِہِ۔",,,19496,,
19497,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : جَاؤُوا بِیَتِیمٍ إلَی عُمَرَ فَقَالَ : أَنْفِقْ عَلَیْہِ ، قَالَ : لَوْ لَمْ أَجِدْ إلاَّ أَقْصَی عَشِیرَتِہِ لَفَرَضْت عَلَیْہِمْ۔",,,19497,,
19498,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ قَالَ : شَہِدْت عَبْدَ اللہِ بْنَ عُتْبَۃَ قَالَ لِوَلِیِّ یَتِیمٍ: لَوْ لَمْ یَکُنْ لَہُ مَالٌ لَقَضَیْت عَلَیْک بِنَفَقَتِہِ لأَنَّ اللَّہَ تَعَالَی یَقُولُ : {وَعَلَی الْوَارِثِ مِثْلُ ذَلِکَ}",,,19498,,
19499,"حدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ {وَعَلَی الْوَارِثِ مِثْلُ ذَلِکَ} قَالَ : ہُوَ الْوَالِدُ ، یعنی : النَّفَقَۃُ عَلَی الْوَالِدِ فَإِنْ لَمْ یَکُنْ عِنْدَہُ فَعَلَی الْعَصَبَۃِ ، فَإِنْ لَمْ یَکُنْ عِنْدَہُ جُبِرَتِ الأُمُّ عَلَی رَضَاعِہِ ، وَإِذَا عَرَفَہَا الْوَلَدُ فَلَمْ یَأْخُذْ مِنْ غَیْرِہَا ، جُبِرَتْ عَلَی رَضَاعِہِ۔",,,19499,,
19500,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، عَنِ ابْنِ عَبَّاسٍ : {وَعَلَی الْوَارِثِ مِثْلُ ذَلِکَ} قَالَ: عَلَی الْوَارِثِ أَنْ لاَ یُضَارَّ۔",,,19500,,
19501,"حَدَّثَنَا یُونُسُ بْنُ مُحَمَّدٍ قَالَ : حدَّثَنَا حَمَّادُ بْنُ زَیْدٍ ، عَنْ عَلِیِّ بْنِ الْحَکَمِ ، عَنِ الضَّحَّاکِ : {وَعَلَی الْوَارِثِ مِثْلُ ذَلِکَ} قَالَ : لاَ یُضَارُّ۔",,,19501,,
19502,حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ أَنَّ عُمَرَ بْنَ الْخَطَّابِ أَوْقَفَ بَنِی عَمِّ مَنْفُوسٍ کَلاَلَۃً بِرَضَاعِہِ عَلَی ابْنِ عَمٍّ لَہُ۔ (ابن جریر 500),,,19502,,
19503,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ : وَعَلَی الْوَارِثِ مِثْلُ ذَلِکَ قَالَ : عَلَی الرِّجَالِ دُونَ النِّسَائِ۔",,,19503,,
19504,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ : سُئِلَ عَنْ صَبِیٍّ لَہُ أُمٌّ وَعَمٌّ وَالأُمُّ مُوسِرَۃٌ وَالْعَمُّ مُعْسِرٌ فَقَالَ : النَّفَقَۃُ عَلَی الْعَمِّ۔",,,19504,,
19505,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنٍ ، عَنْ مُطَرِّفٍ ، عَنْ إسْمَاعِیلَ ، عَنِ الْحَسَنِ ، عَنْ زَیْدِ بْنِ ثَابِتٍ قَالَ : إذَا کَانَ عَمٌّ وَأُمٌّ فَعَلَی الأُمِّ بِقَدْرِ مِیرَاثِہَا وَعَلَی الْعَمِّ بِقَدْرِ مِیرَاثِہِ۔",,,19505,,
19506,"حَدَّثَنَا ابْنُ أَبِی زَائِدَۃَ ، عَنْ مُجَالِدٍ ، عَنِ الشَّعْبِیِّ ، عَنْ مَسْرُوقٍ قَالَ : إذَا طَلَّقَ الرَّجُلُ امْرَأَتَہُ وَلَہَا مِنْہُ وَلَدٌ فَعَلَیْہِ الرَّضَاعُ۔",,,19506,,
19507,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الأَحْوَصِ ، عَنْ عَبْدِ اللہِ قَالَ : عَلَیْہِ رَضَاعُہُ حَتَّی تَفْطِمَہُ۔",,,19507,,
19508,"حَدَّثَنَا أبو بکر الْحَنَفِیُّ ، عَنِ الضَّحَّاکِ بْنِ عُثْمَانَ قَالَ : سَأَلْتُ الْقَاسِمَ بْنَ مُحَمَّدٍ ، عَنِ الْمَرْأَۃِ یُفْرَضُ لَہَا مِنْ مَالِ ابْنَتِہَا ؟ قَالَ : نَعَمْ ، أَراہ حَقًّا۔",,,19508,,
19509,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْر ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ قَالَ : قُلْتُ لِعَطَائٍ : الْیَتِیمُ أُمُّہُ مُحْتَاجَۃٌ أَیُنْفَقُ عَلَیْہَا مِنْ مَالِہِ ؟ قَالَ عَطَائٌ : لَیْسَ لَہَا شَیْئٌ ؟ قُلْتُ : لاَ ، قَالَ : نَعَمْ۔",,,19509,,
19510,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ قَالَ : یَتَوَارَثَانِ مَا لَمْ یَتَلاَعَنَا۔",,,19510,,
19511,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : یَتَوَارَثَانِ مَا لَمْ یَتَلاَعَنَا۔",,,19511,,
19512,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ قَالَ : إذَا مَاتَ أَحَدُہُمَا قَبْلَ اللِّعَانِ تَوَارَثَا۔",,,19512,,
19513,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ إبْرَاہِیمَ قَالَ : یَرِثُہَا ، وَقَالَ الْحَکَمُ : یُضْرَبُ وَیَرِثُہَا۔",,,19513,,
19514,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ ، عَنْ عِکْرِمَۃَ قَالَ فِی رَجُلٍ قَذَفَ امْرَأَتَہُ فَمَاتَتْ قَبْلَ أَنْ یُلاَعِنَہَا قَالَ : إِنْ أکْذَبَ نَفْسَہُ جُلِدَ وَوَرِثَ ، وَإِنْ أَقَامَ شُہُودًا وَرِثَ ، وَإِنْ حَلَفَ لَمْ یَرِثْ۔",,,19514,,
19515,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ جَابِرِ بْنِ زَیْدٍ أَنَّہُ قَالَ : إذَا مَاتَ أَحَدُہُمَا قَبْلَ الْمُلاَعَنَۃِ إِنْ ہِیَ أَقَرَّتْ بِہَا رُجِمَتْ وَصَارَ إلَیْہَا الْمِیرَاثُ وَإِنِ الْتَعَنَتْ وَرِثَتْ ، وَإِنْ لَمْ تُقِرَّ بِوَاحِدَۃٍ مِنْہُمَا فَلاَ مِیرَاثَ لَہَا وَلاَ عِدَّۃَ عَلَیْہَا۔",,,19515,,
19516,"حدثنا إسْمَاعِیلَ بْنِ عُلَیَّۃَ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ فِی رَجُلٍ قَذَفَ امْرَأَتَہُ ، ثُمَّ مَاتَتْ قَالاَ : یَرِثُہَا وَلاَ مُلاَعَنَۃَ بَیْنَہُمَا۔",,,19516,,
19517,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ قَالَ : یُجْلَدُ وَلاَ مُلاَعَنَۃَ بَعْدَ الْمَوْتِ۔",,,19517,,
19518,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ قَالَ : إذَا قَذَفَہَا ، ثُمَّ مَاتَتْ قَبْلَ أَنْ یُلاَعِنَہَا قَالَ : إِنْ شَائَ أَکْذَبَ نَفْسَہُ وَوَرِثَ ، وَإِنْ شَائَ لاَعَنَ وَلَمْ یَرِثْ۔",,,19518,,
19519,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، عَنْ إبْرَاہِیمَ قَالَ : یَتَوَارَثَانِ مَا لَمْ یَتَلاَعَنَا۔",,,19519,,
19520,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ سَیَّارٍ ، عَنِ الشَّعْبِیِّ فِی الْمُتَوَفَّی عَنْہَا وَہِیَ حَامِلٌ قَالَ : یُنْفَقُ عَلَیْہَا مِنْ جَمِیعِ الْمَالِ حَتَّی تَضَعَ ، ثُمَّ یُقْسَمُ الْمِیرَاثُ۔",,,19520,,
19521,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : إذَا مَاتَ الرَّجُلُ وَامْرَأَتُہُ حُبْلَی لَمْ یُقْسَمِ الْمِیرَاثُ حَتَّی تَضَعَ۔",,,19521,,
19522,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ قَالَ : یُقْسَمُ وَیُتْرَکُ نَصِیبُ ذَکَرٍ فَإِنْ کَانَتْ أُنْثَی رُدَّ عَلَی الْوَرَثَۃِ ، وَإِنْ کَانَ ذَکَرًا کَانَ لَہُ۔",,,19522,,
19523,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنِ الشَّیْبَانِیِّ ، عَنْ حَمَّادٍ قَالَ : یُجْبَرُ کُلُّ ذِی مَحْرَمٍ عَلَی أَنْ یُنْفِقَ عَلَی مَحْرَمِہِ۔",,,19523,,
19524,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ قَالَ : یُجْبَرُ عَلَی نَفَقَۃِ کُلِّ وَارِثٍ۔",,,19524,,
19525,حَدَّثَنَا حَفْصٌ ، عَنْ إسْمَاعِیلَ ، عَنِ الْحَسَنِ أَنَّ عُمَرَ جَبَرَ رَجُلاً عَلَی نَفَقَۃِ ابْنِ أَخِیہِ۔,,,19525,,
19526,"حَدَّثَنَا عَبْدُالأَعْلَی، عَنْ مَعْمَرٍ، عَنِ الزُّہْرِیِّ قَالَ: یُجْبَرُ الرَّجُلُ عَلَی نَفَقَۃِ وَالِدَیہِ، یُنْفِقُ عَلَیْہِمَا بِالْمَعْرُوفِ۔",,,19526,,
19527,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ ہِشَامٍ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ قَالَ : یُجْبَرُ عَلَی نَفَقَۃِ أَخِیہِ ، إذَا کَانَ مُعْسِرًا۔",,,19527,,
19528,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ قَالَ : أَخْبَرَنَا أَشْعَثُ ، عَنِ الْحَسَنِ أَنَّہُ کَانَ یُلْزِمُ وَلَدَ ابْنِہِ إذَا کَانَ فَقِیرًا ، وَکَانَ الْجَدُّ غَنِیًّا۔",,,19528,,
19529,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو قَالَ رَجُلٌ لِجَابِرِ بْنِ زَیْدٍ : إنَّ أَبِی یَحْرِمُنِی مَالَہُ فَیَقُولُ : لاَ أُنْفِقُ عَلَیْک شَیْئًا ، فَقَالَ : خُذْ مِنْ مَالِ أَبِیک بِالْمَعْرُوفِ۔",,,19529,,
19530,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یَقُولُ لامْرَأَتِہِ : یَا أُخَیَّۃُ : قَالَ : مَا ہَذَا وَتَمْرتَانِ إلاَّ وَاحِدٌ۔",,,19530,,
19531,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ قَالَ : سَمِعَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجُلاً یَقُولُ لامْرَأَتِہِ یَا أُخَیَّۃُ قَالَ : لاَ تَقُلْ لَہَا : یَا أُخَیَّۃُ۔ (ابوداؤد 2203)",,,19531,,
19532,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ مُحَمَّدِ بْنِ سَلَمَۃَ ، عَنْ زِیَادٍ الأَعْلَمِ ، عَنِ الْحَسَنِ ؛ فِی امْرَأَۃٍ غَیَّبَتْ صِککَ رَجُلٍ فَقَالَ : أَنْتِ طَالِقٌ ثَلاَثًا إِنْ لَمْ تَکُنْ قد غَیَّبْتہَا ، فَقَالَ الْحَسَنُ : إِنْ کَانَ صَادِقًا فَہِیَ امْرَأَتُہُ ، وَسَمِعْت حَمَّادًا یَقُولُ : یُدَیَّنُ فِی ذَلِکَ۔",,,19532,,
19533,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حُمَیْدٍ ، عَنِ الْحَسَنِ فِی رَجُلٍ ادَّعَتِ امْرَأَتُہُ أنَّہُ طَلَّقَہَا فَرَافَعَتْہُ إلَی السُّلْطَانِ فَاسْتَحْلَفَہُ إِنَّہُ لَمْ یُطَلِّقْ ، ثُمَّ رُدَّتْ عَلَیْہِ وَمَاتَ ، قَالَ الْحَسَنُ : تَرِثُہُ۔",,,19533,,
19534,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ زَکَرِیَّا ، عَنِ الشَّعْبِیِّ ، أَنَّہُ سُئِلَ عَنْ رَجُلٍ طَلَّقَ امْرَأَتَہُ عِنْدَ رَجُلَیْنِ وَامْرَأَۃٍ فَشَہِدَ أَحَدُ الرَّجُلَیْنِ وَالْمَرْأَۃُ وَغَابَ الآخَرُ قَالَ : تُعْزَلُ عَنْہُ حَتَّی یَجِیئَ الْغَائِبُ۔",,,19534,,
19535,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ أَبِی الْعَلاَئِ ، وَسَعِیدٌ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ قَالَ : إذَا قَالَ الرَّجُلُ : إِنْ کَلَّمَ أَخَاہُ فَامْرَأَتُہُ طَالِقٌ ثَلاَثًا ، فَإِنْ شَائَ طَلَّقَہَا وَاحِدَۃً ، ثُمَّ تَرَکَہَا حَتَّی تَنْقَضِیَ عِدَّتُہَا ، فَإِذَا بَانَتْ کَلَّمَ أَخَاہُ ، ثُمَّ تَزَوَّجَہَا إِنْ شَائَ بَعْدُ۔",,,19535,,
19536,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ شَہْرِ بْنِ حَوْشَبٍ قَالَ : تَزَوَّجَ رَجُلٌ امْرَأَۃً عَلَی عَہْدِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَطَلَّقَہَا فَقَالَ لَہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : طَلَّقْتہَا ؟ قَالَ : نَعَمْ ، قَالَ : مِنْ بَأْسٍ ؟ قَالَ : لاَ یَا رَسُولَ اللہِ ، ثُمَّ تَزَوَّجَ أُخْرَی ، ثُمَّ طَلَّقَہَا فَقَالَ لَہُ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : طَلَّقْتہَا ؟ قَالَ: نَعَمْ، قَالَ: مِنْ بَأْسٍ؟ قَالَ : لاَ یَا رَسُولَ اللہِ ، ثُمَّ تَزَوَّجَ أُخْرَی ، ثُمَّ طَلَّقَہَا فَقَالَ لَہُ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: أَطَلَّقْتَہَا؟ قَالَ : نَعَمْ ، قَالَ: مِنْ بَأْسٍ؟ قَالَ: لاَ یَا رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی الثَّالِثَۃِ : إنَّ اللَّہَ لاَ یُحِبُّ کُلَّ ذَوَّاقٍ مِنَ الرِّجَالِ وَلاَ کُلَّ ذَوَّاقَۃٍ مِنَ النِّسَائِ۔\n\n(دارقطنی 5167۔ بزار 1498)",,,19536,,
19537,"حَدَّثَنَا وَکِیعُ بْنُ الْجَرَّاحِ ، عَنْ معَرِّفٍ ، عَنْ مُحَارِبِ بْنِ دِثَارٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَیْسَ شَیْئٌ مِمَّا أَحَلَّ اللَّہُ أَبْغَضَ إلَیْہِ مِنَ الطَّلاَقِ۔ (ابوداؤ د2170)",,,19537,,
19538,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ قَالَ : قَالَ عَلِیٌّ : یَا أَہْلَ الْعِرَاقِ ، أَوْ یَا أَہْلَ الْکُوفَۃِ لاَ تُزَوِّجُوا حَسَنًا ، فَإِنَّہُ رَجُلٌ مِطْلاَقٌ۔",,,19538,,
19539,"حَدَّثَنَا حَاتِمُ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ قَالَ : قَالَ عَلِیٌّ : مَا زَالَ الْحَسَنُ یَتَزَوَّجُ وَیُطَلِّقُ حَتَّی حَسِبْت أَنْ یَکُونَ عَدَاوَۃً فِی الْقَبَائِلِ۔",,,19539,,
19540,"حَدَّثَنَا عَبْدُ الأَعْلَی قَالَ : سُئِلَ عَنْ رَجُلٍ قَالَ لامْرَأَتِہِ : إِنْ لَمْ أَکُنْ دَفَعْت إلَیْک کَذَا وَکَذَا فَأَنْتِ طَالِقٌ ثَلاَثًا ، قَالَ : فَحَدَّثَنَا سَعِیدٌ ، عَنْ قَتَادَۃَ أَنَّہُ قَالَ : إِنْ کَانَتْ لَہُ بَیِّنَۃٌ وَإِلاَّ فَقَدْ بَانَتْ مِنْہُ۔",,,19540,,
19541,"حَدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ أَبِی سُلَیْمَانَ ، عَنْ عَطَائٍ ؛ فِی امْرَأَۃٍ قَالَ لَہَا زَوْجُہَا : إِنْ لَمْ أُنْفِقْ عَلَیْک عَشَرَۃَ دَرَاہِمَ کُلَّ شَہْرٍ فَأَنْتِ طَالِقٌ ثَلاَثًا ، فَقَالَتِ الْمَرْأَۃُ : قَدْ مَضَتْ ثَلاَثَۃُ أَشْہُرٍ لَمْ تُنْفِقْ عَلَیَّ شَیْئًا، قَالَ : الْقَوْلُ مَا قَالَ الرَّجُلُ إلاَّ أَنْ تُقِیمَ الْمَرْأَۃُ الْبَیِّنَۃَ أَنَّہُ لَمْ یُنْفِقْ عَلَیْہَا۔",,,19541,,
19542,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی إِسْحَاقَ الْکُوفِیِّ ، عَنِ الشَّعْبِیِّ فِی رَجُلٍ قَالَ لِغَرِیمِہِ : إِنْ لَمْ أَقْضِکَ حَقَّک قَبْلَ غُرُوبِ الشَّمْسِ فَامْرَأَتُہُ طَالِقٌ ، قَالَ : فَلَقِیَہُ مِنَ الْغَدِ فَزَعَمَ أنَّہُ لَمْ یُعْطِہِ شَیْئًا قَالَ : فَقَالَتْ لَہُ امْرَأَتُہُ : قَدْ طَلَّقْتنِی قَالَ : فَخَاصَمْتہ إلَی الشَّعْبِیِّ فَقَالَ الشَّعْبِیُّ : أَمَّا امْرَأَتُک فَنُدِینُک فِیہَا ، وَأَمَّا الرَّجُلُ فَبَیِّنَتُک فیہا أَنَّک دَفَعْت إلَیْہِ مَالَہُ وَإِلاَّ فَأَعْطِہِ حَقَّہُ۔",,,19542,,
19543,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ أنہ قَالَ ؛ فِی الرَّجُلِ یَقُولُ لامْرَأَتِہِ : قدْ خَلَعْتُک ، وَلَمْ یَکُنْ خَلَعَہَا قَالَ : قَدْ خَلَعَہَا وَلاَ شَیْئَ عَلَیْہِ۔",,,19543,,
19544,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ أَنَّہُ قَالَ: لاَ تُجْبَرُ الحرۃ عَلَی الرَّضَاعِ وَتُجْبَرُ أُمُّ الْوَلَدِ۔",,,19544,,
19545,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ قَالَ : إذَا کَانَ لِلْمَرْأَۃِ صَبِیٌّ مُرْضَعٌ فَہِیَ أَحَقُّ بِہِ وَلَہَا أَجْرُ الرَّضَاعِ مِثْلُہَا إِنْ قَبِلَتْہُ ، وَإِنْ لَمْ تَقْبَلْہُ اسْتَرْضَعَ لَہُ مِنْ غَیْرِہَا إِنْ قَبِلَ الصَّبِیُّ مِنْ غَیْرِہَا فَذَلِکَ ، وَإِنْ لَمْ یَقْبَلْ جُبِرَتْ عَلَی رَضَاعِہِ وَأُعْطِیَتْ أَجْرَ مِثْلِہَا۔",,,19545,,
19546,"حَدَّثَنَا وَکِیعٌ ، عَنْ شَرِیکٍ ، عَنْ عَطَائٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ : {وَإِنْ تَعَاسَرْتُمْ فَسَتُرْضِعُ لَہُ أُخْرَی} قَالَ : إذَا قَامَ الرَّضَاعُ عَلَی شَیْئٍ فَالأُمُّ أَحَقُّ بِہِ۔",,,19546,,
19547,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا سُفْیَانُ : إذَا کَانَ الْوَلَدُ لاَ یَأْخُذُ مِنْ غَیْرِہَا وَخَشِیَ عَلَیْہِ جُبِرَتْ۔",,,19547,,
19548,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ مُحَمَّدِ بْنِ أبْرَاہِیمَ قَالَ : قَالَ ابْنُ عَبَّاسٍ : {إلاَّ أَنْ یَأْتِینَ بِفَاحِشَۃٍ مُبَیِّنَۃٍ} قَالَ : الْفَاحِشَۃُ أَنْ تَبْذُوَ عَلَی أَہْلِہَا ، فإذَا فَعَلَتْ ذَلِکَ حَلَّ لَہُمْ أَنْ یُخْرِجُوہَا۔",,,19548,,
19549,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ مُوسَی بْنِ عُقْبَۃَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ فِی قَوْلِ اللہِ تعالی : (إلاَّ أَنْ یَأْتِینَ بِفَاحِشَۃٍ مُبَیِّنَۃٍ) قَالَ : خُرُوجُہَا مِنْ بَیْتِہا فَاحِشَۃٌ۔",,,19549,,
19550,"حدَّثَنَا إِسْحَاقُ بْنُ سُلَیْمَانَ ، عَنْ أَبِی سِنَانٍ ، عَنْ حَمَّادِ {وَلاَ یَخْرُجْنَ إلاَّ أَنْ یَأْتِینَ بِفَاحِشَۃٍ مُبَیِّنَۃٍ} قَالَ : إلاَّ أَنْ تَخْرُجَ لِحَدٍّ۔",,,19550,,
19551,"حَدَّثَنَا ابْنُ أَبِی غَنِیَّۃَ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ فِی قَوْلِہِ تعالی : {إلاَّ أَنْ یَأْتِینَ بِفَاحِشَۃٍ مُبَیِّنَۃٍ} الْفَاحِشَۃُ الْمُبَیِّنَۃُ عِصیان الزَّوج۔",,,19551,,
19552,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، عَنْ رَجُلٍ ، عَنِ الشَّعْبِیِّ : {إلاَّ أَنْ یَأْتِینَ بِفَاحِشَۃٍ مُبَیِّنَۃٍ} قَالَ : خُرُوجُہَا فَاحِشَۃٌ۔",,,19552,,
19553,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عَطَائٍ ، عَنِ الشَّعْبِیِّ فِی رَجُلٍ أَخَذَ لُقْمَۃً ، فَقَالَ رَجُلٌ : إِنْ لَمْ تَأْکُلْہَا فَامْرَأَتُہُ طَالِقٌ فَجَازَتْ سِنَّوْرٌ فَأَخَذَتِ اللُّقْمَۃَ فَقَالَ : طُلِّقَتِ امْرَأَتُہُ۔",,,19553,,
19554,"حَدَّثَنَا عَبِیدَۃُ بْنُ حُمَیْدٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ قَالَ : جَائَ إلَی الشَّعْبِیِّ رَجُلٌ فَقَالَ رَجُلٌ قَالَ لامْرَأَتِہِ : إِنْ لَمْ تَأْکُلِی ہَذَا الْعِرْقَ ، فَامْرَأَتُہُ طَالِقٌ ثَلاَثًا ، فَجَائَتِ السِّنَّوْرُ ، فَأَخَذَتِ الْعِرْقَ ، فَقَالَ الشَّعْبِیُّ : لَمْ یَجْعَلْ لَہَا مَخْرَجًا ، لاَ جَعَلَ اللَّہُ لَہُ مَخْرَجًا۔",,,19554,,
19555,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَجَّاجٍ قَالَ : أَخْبَرَنِی مَنْ سَمِعَ إبْرَاہِیمَ وَأَتَاہُ رَجُلٌ بِکِتَابٍ ، فَقَالَ : إنَّ رَجُلاً کَتَبَ إلَی امْرَأَتِہِ فَجَعَلَ أَمْرَہَا بِیَدِہَا فَقَرَأَتِ الْکِتَابَ ، ثُمَّ وَضَعَتْہُ تَحْتَ الْفِرَاشِ ، فَقَامَتْ وَلَمْ تَقُلْ شَیْئًا ، قَالَ : لاَ شَیْئَ لَہَا۔",,,19555,,
19556,"حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ قَالَ : إذَا طَلَّقَ الْعَبْدُ طَلاَقًا یَمْلِکُ الرَّجْعَۃَ فَعَلَیْہِ النَّفَقَۃُ۔",,,19556,,
19557,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : إذَا ادَّعَی الرَّجْعَۃَ بَعد انْقِضَائِ الْعِدَّۃِ فَعَلَیْہِ الْبَیِّنَۃُ۔",,,19557,,
19558,"حَدَّثَنَا عَبْدُ الرَّزَّاقِ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ قَالَ : إذَا ادَّعَی الرَّجْعَۃَ بَعد انْقِضَائِ الْعِدَّۃِ لَمْ یُصَدَّقْ ، وَإِنْ جَائَ بِبَیِّنَۃٍ۔",,,19558,,
19559,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ ، عَنْ عَبْدِ اللہِ قَالَ : إِنْ قَالَ بَعْدَ انْقِضَائِ الْعِدَّۃِ : قَدْ رَاجَعْتُک لَمْ یُصَدَّقْ۔",,,19559,,
19560,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یَزِیدَ بْنِ زَادِیٍّ مَوْلَی بُجَیْلَۃَ ، عَنِ الشَّعْبِیِّ ، أَنَّہُ سُئِلَ عَنْ رَجُلٍ شَہِدَ عَلَیْہِ رَجُلاَنِ بِطَلاَقِ امْرَأَتِہِ ، فَفَرَّقَ الْقَاضِی بَیْنَہُمَا فَرَجَعَ أَحَدُ الشَّاہِدَیْنِ وَتَزَوَّجَہَا الآخَرُ ، قَالَ : فَقَالَ الشَّعْبِیُّ : مَضَی الْقَضَائُ ، وَلاَ یَلْتَفِتُ إلَی رُجُوعِ الَّذِی رَجَعَ۔",,,19560,,
19561,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ قَالَ : حدَّثَنَا إسْمَاعِیلُ بْنُ سُمَیْعٍ ، عَنْ أَبِی رَزِینٍ قَالَ : أَتَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجُلٌ فَقَالَ : یَا رَسُولَ اللہِ ، أَرَأَیْت قَوْلَ اللہِ تَعَالَی : {الطَّلاَقُ مَرَّتَانِ فَإِمْسَاکٌ بِمَعْرُوفٍ أَوْ تَسْرِیحٌ بِإِحْسَانٍ} فَأَیْنَ الثَّالِثَۃُ ؟ فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : {إمْسَاکٌ بِمَعْرُوفٍ أَوْ تَسْرِیحٌ بِإِحْسَانٍ} ہِیَ الثَّالِثَۃُ۔ (ابوداؤد 220۔ بیہقی 340)",,,19561,,
19562,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ قَالَ : قَالَ رَجُلٌ لامْرَأَتِہِ عَلَی عَہْدِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ أَقْرَبُک وَلاَ تَحِلِّینَ مِنِّی قَالَتْ : فَکَیْفَ تَصْنَعُ ؟ قَالَ : أُطَلِّقُک حَتَّی إذَا دَنَا مُضِیُّ عِدَّتِکَ رَاجَعْتُک ، فجزعت فَأَتَتِ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَأَنْزَلَ اللَّہُ تَعَالَی : {إمْسَاکٌ بِمَعْرُوفٍ أَوْ تَسْرِیحٌ بِإِحْسَانٍ} قَالَ : فَاسْتَقْبَلَہُ النَّاسُ جَدِیدًا ، مَنْ کَانَ طَلَّقَ وَمَنْ لَمْ یَکُنْ طَلَّقَ۔ (ترمذی 1192۔ مالک 80)",,,19562,,
19563,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ سِمَاکٍ ، عَنْ عِکْرِمَۃَ قَالَ : {الطَّلاَقُ مَرَّتَانِ فَإِمْسَاکٌ بِمَعْرُوفٍ أَوْ تَسْرِیحٌ بِإِحْسَانٍ} قَالَ : إذَا أَرَادَ الرَّجُلُ أَنْ یُطَلِّقَ امْرَأَتَہُ فَیُطَلِّقُہَا تَطْلِیقَتَیْنِ ، فَإِنْ أَرَادَ أَنْ یُرَاجِعَہَا کَانَتْ لَہُ عَلَیْہَا رَجْعَۃٌ ، وَإِنْ شَائَ طَلَّقَہَا أُخْرَی فَلاَ تَحِلُّ لَہُ حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ۔",,,19563,,
19564,"حَدَّثَنَا عُبَید اللہ قَال أَخْبَرَنَا حَسَنُ بْنُ صَالِحٍ ، عَنْ سِمَاکٍ ، قَالَ : سَمِعْتُ عِکْرِمَۃَ یَقُولُ : {الطَّلاَقُ مَرَّتَانِ فَإِمْسَاکٌ بِمَعْرُوفٍ أَوْ تَسْرِیحٌ بِإِحْسَانٍ} قَالَ : إذَا طَلَّقَ الرَّجُلُ امْرَأَتَہُ وَاحِدَۃً فَإِنْ شَائَ نَکَحَہَا ، وَإِذَا طَلَّقَہَا ثِنْتَیْنِ فَإِنْ شَائَ نَکَحَہَا ، فَإِذَا طَلَّقَہَا ثَلاَثًا ، فَلاَ تَحِلُّ لَہُ حَتَّی تَنْکِحَ زَوْجًا غَیْرَہُ۔",,,19564,,
19565,"حَدَّثَنَا شَبَابَۃُ ، عَنْ وَرْقَائَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ : {الطَّلاَقُ مَرَّتَانِ فَإِمْسَاکٌ بِمَعْرُوفٍ أَوْ تَسْرِیحٌ بِإِحْسَانٍ} قَالَ : یُطَلِّقُ الرَّجُلُ امْرَأَتَہُ طَاہِرًا مِنْ غَیْرِ جِمَاعٍ ، فَإِذَا حَاضَتْ ، ثُمَّ طَہُرَتْ فَقَدْ تَمَّ الْقُرْئُ ، ثُمَّ طَلَّقَ الثَّانِیَۃَ کَمَا طَلَّقَ الأُولَی إِنْ أَحَبَّ أَنْ یَفْعَلَ ، فَإِذَا طَلَّقَ الثَّانِیَۃَ ، ثُمَّ حَاضَتِ الْحَیْضَۃَ الثَّانِیَۃَ ، فَہَاتَانِ تَطْلِیقَتَانِ وَقُرْئَانِ ، ثُمَّ قَالَ اللَّہُ تَعَالَی لِلثَّالِثَۃِ : {فَإِمْسَاکٌ بِمَعْرُوفٍ أَوْ تَسْرِیحٌ بِإِحْسَانٍ} فَیُطَلِّقُہَا فِی ذَلِکَ الْقُرْئِ کُلِّہِ إِنْ شَائَ حِینَ تَجْمَعُ عَلَیْہَا ثِیَابَہَا۔",,,19565,,
19566,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ طَاوُوسٍ ، عَنِ ابْنِ عَبَّاسٍ قَالَ : إنَّمَا ہُوَ فُرْقَۃٌ وَفَسْخٌ ، لَیْسَ بِطَلاَقٍ ، ذَکَرَ اللَّہُ الطَّلاَقَ فِی أَوَّلِ الآیَۃِ وَفی آخرہا وَالْخُلْعَ بَیْنَ ذَلِکَ فَلَیْسَ بِطَلاَقٍ ، قَالَ اللَّہُ تَعَالَی : {الطَّلاَقُ مَرَّتَانِ فَإِمْسَاکٌ بِمَعْرُوفٍ ، أَوْ تَسْرِیحٌ بِإِحْسَانٍ}۔",,,19566,,
19567,"حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنْ أَیُّوبَ قَالَ: قَالَ عِکْرِمَۃُ: لَعَلَّ اللَّہَ یُحْدِثُ بَعْدَ ذَلِکَ أَمْرًا قَالَ: مَا یُحْدِثُ بَعْدَ الثَّلاَثِ۔",,,19567,,
19568,"حَدَّثَنَا ابْنُ أَبِی غَنِیَّۃ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ : {لَعَلَّ اللَّہَ یُحْدِثُ بَعْدَ ذَلِکَ أَمْرًا} قَالَ : لَعَلَّہُ أَنْ یُرَاجِعَہَا فِی الْعِدَّۃِ۔",,,19568,,
19569,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ دَاوُدَ الأَوْدِیِّ ، عَنِ الشَّعْبِیِّ قَالَ : {لاَ تَدْرِی لَعَلَّ اللَّہَ یُحْدِثُ بَعْدَ ذَلِکَ أَمْرًا} قَالَ : لاَ نَدْرِی لَعَلَّک تَنْدَمُ فَیَکُونُ لَکَ سَبِیلٌ إلَی الرَّجْعَۃِ۔",,,19569,,
19570,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ ، عَنْ عَبْدِ اللہِ قَالَ : إذَا طَلَّقَ سِرًّا رَاجَعَ سِرًّا فتلک رَجْعَۃٌ ، فَإِنْ وَاقَعَ فَلاَ بَأْسَ ، وَإِنْ طَلَّقَ عَلانِیَۃً وَرَاجَعَ فَلْیُشْہِدْ عَلَی رَجْعَتِہِ۔",,,19570,,
19571,"حَدَّثَنَا شَرِیکٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : إذَا طَلَّقَ سِرًّا رَاجَعَ سِرًّا۔",,,19571,,
19572,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنِ الشَّعْبِیِّ قَالَ : آلَی رَجُلٌ مِنِ امْرَأَتِہِ ، ثُمَّ مَاتَ عَنْہَا فِی آخِرِ عِدَّتِہَا قَالَ : تَعْتَدُّ أَحَدَ عَشَرَ شَہْرًا۔",,,19572,,
19573,"حَدَّثَنَا عَبْدُ الأَعْلَی، عَنْ یُونُسَ، عَنِ الْحَسَنِ قَالَ : الْخُلْعُ تَطْلِیقَۃٌ بَائِنٌ وَمَا اشْتَرَطَتْ عَلَیْہِ مِنَ الطَّلاَقِ فَہُوَ لَہَا۔",,,19573,,
19574,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ مُغِیرَۃَ، عَنْ إبْرَاہِیمَ قَالَ: الْمُکَاتَبَۃُ طَلاَقُہَا طَلاَقُ الأَمَۃِ وَعِدَّتُہَا عِدَّۃُ الأَمَۃِ۔",,,19574,,
19575,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ قَالَ : النَّفَقَۃُ عَلَی مَنْ تَعْتَدُّ مِنْ مَائِہِ۔",,,19575,,
19576,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشام ، عَنِ الْحَسَنِ قَالَ : أَیُّہُمَا رُجِمَ الزَّوْجُ ، أَوِ الْمَرْأَۃُ فَلِصَاحِبِہِ مِنْہُ الْمِیرَاثُ۔",,,19576,,
19577,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ قَتَادَۃَ ، عَنْ عَلِیٍّ قَالَ : إذَا رُجِمَ فَلَہَا الْمِیرَاثُ۔",,,19577,,
19578,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ قَالَ : إذَا تَزَوَّجَ الرَّجُلُ الْمَرْأَۃَ ، ثُمَّ فَجَرَتْ أُقِیمَ عَلَیْہَا الْحَدُّ ، وَإِنْ مَاتَتْ تَحْتَ السِّیَاطِ وَرِثَہَا۔",,,19578,,
19579,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَنْ زُہَیْرٍ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ فِی رَجُلٍ أَقَامَ أَرْبَعَۃَ شُہَدَائَ عَلَی امْرَأَتِہِ أَنَّہَا زَنَتْ قَالَ : تُرْجَمُ وَیَرِثُہَا۔",,,19579,,
19580,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ قَالَ : أَخْبَرَنَا أَشْعَثُ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ قَذَفَ امْرَأَتَہُ وَہِیَ صَغِیرَۃٌ قَالَ : لَیْسَ عَلَیْہِ حَدٌّ وَلاَ لِعَانٌ۔",,,19580,,
19581,"حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنِ الْحَکَمِ وَالزُّہْرِیِّ فِی رَجُلٍ تَزَوَّجَ امْرَأَۃً عَلَی أَنَّ أَمْرَہَا بِیَدِ رَجُلٍ، قَالَ الْحَکَمُ: لَیْسَ بِشَیْئٍ، وَقَالَ الزُّہْرِیُّ: بَلَی، وَقَالَ سُفْیَانُ: رَأْیِی رَأْیُ الزُّہْرِیِّ۔",,,19581,,
19582,"حَدَّثَنَا حَکَّامُ الرَّازِیّ ، عَنْ عَنبَسَۃَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، عَنْ مَسْرُوقٍ قَالَ : إذَا قَالَ الرَّجُلُ لامْرَأَتِہِ : أَنْتِ طَالِقٌ إذَا شِئْت ، فَقَدْ خَیَّرَہَا۔",,,19582,,
19583,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ زَکَرِیَّا ، عَنِ الشَّعْبِیِّ فِی امْرَأَۃٍ تَزَوَّجَتْ رَجُلاً فَمَکَثَتْ عِنْدَہُ سِنِینَ ، ثُمَّ قَدِمَ زَوْجُہَا فَأَخَذَہَا فَطَلَّقَہَا الآخَرُ قَالَ : لاَ طَلاَقَ لَہُ۔",,,19583,,
19584,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنِ ابْنِ جُرَیْجٍ، عَنْ عَطَائٍ قَالَ : کُلُّ نِکَاحٍ فَاسِدٍ لاَ یَثْبُتُ فَلَیْسَ طَلاَقُہُ فِیہِ طَلاَق۔",,,19584,,
19585,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ صَالِحِ بْنِ مُسْلِمٍ قَالَ : سَأَلْتُ الشَّعْبِیَّ قُلْتُ : رَجُلٌ وَامْرَأَتُہُ حَکَّمَا رَجُلَیْنِ ، ثُمَّ بَدَا لَہُمَا أَنْ یَرْجِعَا ، قَالَ : ذَلِکَ لَہُمَا مَا لَمْ یَتَکَلَّمَا فَإِذَا تَکَلَّمَا فَلَیْسَ لَہُمَا أَنْ یَرْجِعَا۔",,,19585,,
19586,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ قَالَ : قُلْتُ لِسَعِیدِ بْنِ جُبَیْرٍ : کَیْفَ اللِّعَانُ ؟ قَالَ : خُذْ مَا فِی الْقُرْآنِ : أَشْہَدُ بِاللَّہِ أَشْہَدُ بِاَللَّہِ۔",,,19586,,
19587,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ الْعَبْدِیُّ قَالَ : حدَّثَنَا عَمْرُو بْنُ مَیْمُونٍ ، عَنْ أَبِیہِ قَالَ : کَانَتْ أُمُّ کُلْثُومٍ تَحْتَ الزُّبَیْرِ بْنِ الْعَوَّامِ ، وَکَانَ رَجُلاً شَدِیدًا عَلَی النِّسَائِ فکرہتہ فَسَأَلَتْہُ أَنْ یُطَلِّقَہَا وَہِیَ حَامِلٌ ، فَأَبَی ، فَلَمَّا ضَرَبَہَا الطَّلْقُ أَلَحَّتْ عَلَیْہِ فِی تَطْلِیقَۃٍ ، فَطَلَّقَہَا وَاحِدَۃً وَہُوَ یَتَوَضَّأُ ، ثُمَّ خَرَجَ فَأَدْرَکَہُ إنْسَانٌ فَأَخْبَرَہُ أَنَّ أُمَّ کُلْثُومٍ قَدْ وَضَعَتْ حَمْلَہَا ، قَالَ : خَدَعَتْنِی خَدَعَہَا اللَّہُ ، فَأَتَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَذَکَرَ ذَلِکَ لَہُ وَأَخْبَرَہُ بِالَّذِی صَنَعَتْ فَقَالَ : سَبَقَ کِتَابُ اللہِ فِیہَا ، اخْطُبْہَا فَقَالَ : إنہا لاَ تَرْجِعُ لِی أَبَدًا۔\n\n(ابن ماجہ 2026۔ بیہقی 421)",,,19587,,
19588,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ قَالَ : إذَا طَلَّقَ الْمَمْلُوکُ فَلَیْسَ عَلَیْہِ مُتْعَۃٌ۔",,,19588,,
19589,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، وَعَنْ جَابِرٍ ، عَنْ عَامِرٍ قَالَ : إذَا طَلَّقَ ، أَوْ أَعْتَقَ فِی مَنَامِہِ فَلَیْسَ بِشَیْئٍ۔",,,19589,,
19590,"حَدَّثَنَا أَبُو بَکْر بْنُ عَیَّاشٍ ، عَنْ أَبِی حَصِینٍ ، عَنْ أَبِی ظَبْیَانَ ، عَنْ عَلِیٍّ قَالَ : رُفِعَ الْقَلَمُ ، عَنِ النَّائِمِ حَتَّی یَسْتَیْقِظَ۔ (ابوداؤد 4401۔ نسائی 7345)",,,19590,,
19591,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عَنْ عَائِشَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : رُفِعَ الْقَلَمُ ، عَنْ ثَلاَثَۃٍ ، عَنِ النَّائِمِ حَتَّی یَسْتَیْقِظَ۔\n\n(ابن ماجہ 2041۔ احمد 100)",,,19591,,
19592,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ فِی رَجُلٍ کُنَّ لَہُ أَرْبَعُ نِسْوَۃٍ فَلَحِقَتْ إحْدَاہُنَّ بِدَارِ الْحَرْبِ ، قَالَ : یُتْبِعُہَا الطَّلاَقَ ، ثُمَّ یَتَزَوَّجُ۔",,,19592,,
19593,"حَدَّثَنَا إِسْحَاقُ الأَزْرَقُ ، عَنْ أَبِی الْعَلاَئِ ، عَنِ الْحَسَنِ فِی رَجُلٍ قَالَ لامْرَأَتِہِ : إِنْ دَخَلْت دَارَ فُلاَنٍ فَأَنْتِ طَالِقٌ فَہُدِمَتِ الدَّارُ قَالَ : إذَا ہُدِمَتِ الدَّارُ فَلَیْسَ بِطَلاَقٍ وَقَالَ ابْنُ ہَاشِمٍ : إذَا کَانَتِ الدَّارُ فِی مِلْکِ الرَّجُلِ فَہُدِمَتْ ، أَوْ کَانَتْ طَرِیقًا فَدَخَلَتْہُ فَقَدْ وَقَعَ عَلَیْہَا الطَّلاَقُ۔",,,19593,,
19594,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا إسْرَائِیلُ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ قَالَ : أَشْہَدُ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَدْ طَلَّقَ۔",,,19594,,
19595,"حَدَّثَنَا وَکِیعٌ قَالَ : حَدَّثَنَا إسْرَائِیلُ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ قَالَ : طَلَّقَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ امْرَأَتَیْنِ إحْدَاہُمَا مِنْ بَنِی عَامِرٍ۔",,,19595,,
19596,"حَدَّثَنَا وَکِیعٌ، قَالَ: حَدَّثَنَا إسْرَائِیلُ، عَنْ جَابِرٍ، عَنْ مُجَاہِدٍ قَالَ: لَمْ یَکُنِ النَّبِیُّ یُطَلِّقُ، إنَّمَا کَانَ یَعْتَزِلُ۔",,,19596,,
19597,"حَدَّثَنَا وَکِیعٌ قَالَ حَدَّثَنَا ہِشَامٌ ، عَنْ أَبِیہِ ، عَنْ عُمَرَ ، أَنَّہُ تَزَوَّجَ امْرَأَۃً مِنْ بَنِی مَخْزُومٍ عَاقِرًا فَطَلَّقَہَا ، ثُمَّ قَالَ : مَا آتِی النِّسَائَ عَلَی لَذَّۃٍ ، فَلَوْلاَ الْوَلَدُ مَا أَرَدْتہنَّ۔",,,19597,,
19598,"حَدَّثَنَا وَکِیعٌ قَالَ : حَدَّثَنَا أََبُو ہِلال ، عَنْ قَتَادَۃَ أَنَّ عُمَرَ تَزَوَّجَ امْرَأَۃً فَإِذَا ہِیَ شَمْطَائُ فَطَلَّقَہَا۔",,,19598,,
19599,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا إسْمَاعِیلُ بْنُ أَبِی خَالِدٍ ، عَنْ قَیْسِ بْنِ أَبِی حَازِمٍ قَالَ : طَلَّقَ خَالِدُ بْنُ الْوَلِیدِ امْرَأَتَہُ فَقَالَ : أَمَا إنِّی لَمْ أُطَلِّقْہَا مِنْ أَمْرٍ سَائَنِی وَلَکِنْ لَمْ یُصِبْہَا عِنْدِی بَلاَئٌ۔",,,19599,,
19600,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا مُوسَی بْنُ عُبَیْدَۃَ ، عَنْ مُحَمَّدِ بْنِ کَعْبٍ الْقُرَظِیِّ ، وَعَبْدِ اللہِ بْنِ عُبَیْدَۃَ وَعُمَرَ بْنِ الْحَکَمِ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ تَزَوَّجَ امْرَأَۃً مِنْ بَنِی الْجَوْنِ فَطَلَّقَہَا وَہِیَ الَّتِی اسْتَعَاذَتْ مِنْہُ۔\n\n(بخاری 5254۔ ابن ماجہ 2037)",,,19600,,
19601,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا سَلاَّمُ بْنُ قَاسِمٍ الثَّقَفِیُّ ، عَنْ أُمِّہِ ، عَنْ أُمِّ سَعِیدٍ : سُرِّیَّۃٌ کَانَتْ لِعَلِیٍّ قَالَتْ : قَالَ عَلِیٌّ : یَا أُمَّ سَعِیدٍ ، قَدِ اشْتَقْت أَنْ أَکُونَ عَرُوسًا ، قَالَتْ : وَعِنْدَہُ یَوْمَئِذٍ أَرْبَعُ نِسْوَۃٍ فَقُلْت : طَلِّقْ إحْدَاہُنَّ وَاسْتَبْدِلْ ، فَقَالَ : الطَّلاَقُ قَبِیحٌ ، أَکْرَہُہُ۔",,,19601,,
19602,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا أَبُو الأَشْہَبِ ، عَنِ الْحَسَنِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ الْمُخْتَلِعَاتِ الْمُنْتَزِعَاتِ ہُنَّ الْمُنَافِقَاتُ۔ (احمد 2/414۔ بیہقی 316)",,,19602,,
19603,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ خَالِدٍ وَأَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَیُّمَا امْرَأَۃٍ سَأَلَتْ زَوْجَہَا الطَّلاَقَ مِنْ غَیْرِ مَا بَأْسٍ لَمْ تَرِحْ رَائِحَۃَ الْجَنَّۃِ۔",,,19603,,
19604,حَدَّثَنَا أَبُو أُسَامَۃَ عن حَمَّادِ بْنُ سَلَمۃ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ، عَنْ أَبِی أَسْمَائَ ، عَنْ ثَوْبَانَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِنَحْوِہِ۔ (ابوداؤد 2221۔ احمد 5/283),,,19604,,
19605,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا حَمَّادُ بْنُ زَیْدٍ ، عَنْ أَبِی عَبْدِ اللہِ الشَقَرِیِّ أَنَّ امْرَأَۃً اخْتَلَعَتْ مِنْ زَوْجِہَا فَقَالَ إبْرَاہِیمُ : أَمَا إنَّہَا مُخَاصِمَتُک عِنْدَ اللہِ یَوْمَ الْقِیَامَۃِ۔",,,19605,,
19606,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا أَبُو ہِلاَلٍ ، عَنْ عَبْدِ اللہِ بْنِ بُرَیْدَۃَ قَالَ : قَالَ عُمَرُ بْنُ الْخَطَّابِ : إذَا أَرَادَ النِّسَائُ الْخُلْعَ فَلاَ تَکْفُرُوہُنَّ۔",,,19606,,
19607,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا ہِشَامُ بْنُ عُرْوَۃَ ، عَنْ أَبِیہِ قَالَ : قَالَ عُمَرُ : لاَ تُکْرِہُوا فَتَیَاتِکُمْ عَلَی الرَّجُلِ الدَّمِیمِ فَإِنَّہُنَّ یُحْبِبْنَ مِنْ ذَلِکَ مَا تُحِبُّونَ۔",,,19607,,
19608,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا بَشِیرُ بْنُ سَلْمَانَ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عبَّاسٍ قَالَ : إنِّی أُحِبُّ أَنْ أَتَزَیَّنَ لِلْمَرْأَۃِ ، کَمَا أُحِبُّ أَنْ تَتَزَیَّنَ لِی الْمَرْأَۃُ ، لأَنَّ اللَّہَ تَعَالَی یَقُولُ : (وَلَہُنَّ مِثْلُ الَّذِی عَلَیْہِنَّ بِالْمَعْرُوفِ) وَمَا أُحِبُّ أَنْ أَسْتَنْطِفَ حَقِّی عَلَیْہَا ، لأَنَّ اللَّہَ تَعَالَی یَقُولُ : {وَلِلرِّجَالِ عَلَیْہِنَّ دَرَجَۃٌ}۔",,,19608,,
19609,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ زَیْدِ بْنِ أَسْلَمَ : {وَلِلرِّجَالِ عَلَیْہِنَّ دَرَجَۃٌ} قَالَ : إِمَارَۃٌ۔",,,19609,,
19610,"حَدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ : (وَلِلرِّجَالِ عَلَیْہِنَّ دَرَجَۃٌ) قَالَ : لاَ أَعْلَمُ إلاَّ أَنَّ : (وَلَہُنَّ مِثْلُ الَّذِی عَلَیْہِنَّ) إذَا عَرَفْنَ تِلْکَ الدَّرَجَۃَ۔",,,19610,,
19611,"حَدَّثَنَا عُبَیْدُ اللہِ ، عَنْ إسْرَائِیلَ ، عَنِ السُّدِّیِّ ، عَنْ أَبِی مَالِکٍ : (وَلِلرِّجَالِ عَلَیْہِنَّ دَرَجَۃٌ) قَالَ : یُطَلِّقُہَا وَلَیْسَ لَہَا مِنَ الأَمْرِ شَیْئٌ۔",,,19611,,
19612,"حَدَّثَنَا شَبَابَۃُ ، عَنْ وَرْقَائَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ : (وَلِلرِّجَالِ عَلَیْہِنَّ دَرَجَۃٌ) قَالَ فَضْلُ اللہِ ، مَا فَضَّلَہُ اللَّہُ بِہِ عَلَیْہَا مِنَ الْجِہَادِ ، وَفَضَّلَ مِیرَاثَہُ عَلَی مِیرَاثِہَا ، وَکُلُّ مَا فُضِّلَ بِہِ عَلَیْہَا۔",,,19612,,
19613,"حَدَّثَنَا وَکِیعٌ قَالَ : حَدَّثَنَا عَبْدُ اللہِ بْنُ حَبِیبِ بْنِ أَبِی ثَابِتٍ قَالَ : سَأَلْتُ الْحَکَمَ وَمُجَاہِدًا عَنْ رَجُلٍ کَانَتْ عِنْدَہُ امْرَأَۃٌ قَدْ دَخَلَ بِہَا ، فَتَزَوَّجَ عَلَیْہَا امْرَأَۃً ، فَقَالَتِ امْرَأَتُہُ الأُولَی : أَجْعَلُ لَکَ جُعْلاً عَلَی أَنْ تُطَلِّقَنِی تَطْلِیقَۃً ، وَتُطَلِّقَ امْرَأَتَکَ ہَذِہِ تَطْلِیقَۃً ، فَفَعَلَ فَقَالَ الْحَکَمُ : بَانَتَا جَمِیعًا ، وقَالَ مُجَاہِدٌ : بَانَتِ الَّتِی لَمْ یَدْخُلْ بِہَا ، وَوَقَعَ عَلَی الأُخْرَی تَطْلِیقَۃٌ۔\n\nوَقَالَ وَکِیعٌ : والناس عَلَی قَوْلِ الْحَکَمِ۔",,,19613,,
19614,"حَدَّثَنَا أَبُو أُسَامَۃَ قَالَ : حدَّثَنَا مِسْعَرٌ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ أَبِی الْبَخْتَرِیِّ قَالَ : اشْتَکَی إبْرَاہِیمُ إلَی رَبِّہِ دَرْئًا فِی خُلُقِ سَارَۃَ ، فَأَوْحَی اللَّہُ تَعَالَی إلَیْہِ إِنَّ الْمَرْأَۃَ کَالضِّلَعِ ، فَإِنْ قَوَّمْتہَا کَسَرْتہَا ، وَإِنْ تَرَکْتہَا اعْوَجَّتْ ، فَالْبَسْ عَلَی مَا کَانَ فِیہَا۔",,,19614,,
19615,"حَدَّثَنَا ہَوْذَۃُ بْنُ خَلِیفَۃَ قَالَ : حدَّثَنَا عَوْفٌ ، عَنْ رَجُلٍ ، قَالَ : سَمِعْتُ سَمُرَۃَ بْنَ جُنْدُبٍ یَخْطُبُ عَلَی مِنْبَرِ الْبَصْرَۃِ یَقُولُ : سَمِعْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : إنَّ الْمَرْأَۃَ خُلِقَتْ مِن ضِلَعٍ ، وَإِنَّک إِنْ تُرِدْ إقَامَۃَ الضِّلْعِ تَکْسِرْہ ، فَدَارِہَا تَعِشْ بِہَا ، فَدَارِہَا تَعِشْ بِہَا۔ (ابن حبان 4178۔ حاکم 174)",,,19615,,
19616,"حَدَّثَنَا أَبُو أُسَامَۃَ، عَنْ أَبِی طَلْقٍ، عَنْ أَبِیہِ، عَنْ أَوْسِ بْنِ ثُرَیْبٍ قَالَ: أَکْرَیْتُ الْحُجَّاجَ، فَدَخَلْت الْمَسْجِدَ الْحَرَامَ، فَإِذَا عُمَرُ وَجَرِیرٌ ، قَالَ : فَقَالَ عُمَرُ لِجَرِیرٍ : یَا أَبَا عمْرٍو کَیْفَ تَصْنَعُ مَعَ نِسَائِکَ؟ فَقَالَ: یَا أَمِیرَ الْمُؤْمِنِینَ ، إنِّی أَلْقَی مِنْہُنَّ شِدَّۃً ، مَا أَسْتَطِیعُ أَنْ أَدْخُلَ بَیْتَ إحْدَاہُنَّ فِی غَیْرِ یَوْمِہَا ، وَلاَ أُقَبِّلُ ابْنَ إحْدَاہُنَّ فِی غَیْرِ یَوْم أُمِّہِ إلاَّ غَضِبْنَ : قَالَ : فَقَالَ عُمَرُ : إنَّ کَثِیرًا مِنْہُنَّ لاَ یُؤْمِنَّ بِاللَّہِ وَلاَ یُؤْمِنَّ لِلْمُؤْمِنِینَ ، لَعَلَّکَ أَنْ تَکُونَ فِی حَاجَۃِ إحْدَاہُنَّ فَتَتَّہِمُک ، قَالَ : فَقَالَ عَبْدُ اللہِ بْنُ مَسْعُودٍ ، وَہُوَ فِی الْقَوْمِ : یَا أَمِیرَ الْمُؤْمِنِینَ ، أَمَا تَعْلَمُ أَنَّ إبْرَاہِیمَ شَکَا إلَی اللہ دَرْئًا فِی خُلُقِ سَارَۃَ قَالَ : فَقِیلَ لَہُ : إنَّ الْمَرْأَۃَ مِثْلُ الضِّلَعِ إِنْ أَقَمْتہَا کَسَرْتہَا ، وَإِنْ تَرَکْتہَا اعْوَجَّتْ ، فَالْبَسْ أَہْلَک عَلَی مَا فِیہِمْ ، قَالَ : فَقَالَ عُمَرُ لِعَبْدِ اللہِ : إنَّ فِی قَلْبِکَ مِنَ الْعِلْمِ غَیْرَ قَلِیلٍ ، قَالَہَا ثَلاَثَ مَرَّاتٍ ، زَادَ فِیہِ بَعْضُ أَصْحَابِہِ ، أَظُنُّہُ سُفْیَانَ : مَا لَمْ یَرَ عَلَیْہَا خَرَبۃ فِی دِینِہَا۔",,,19616,,
19617,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ مَیْسَرَۃَ ، عَنْ أَبِی حَازِمٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : اسْتَوْصُوا بِالنِّسَائِ ، فَإِنَّ الْمَرْأَۃَ خُلِقَتْ مِنْ ضِلَعٍ ، وَإِنَّ أَعْوَجَ شَیْئٍ فِی الضِّلَعِ أَعْلاَہُ ، إِنْ ذَہَبْت تُقِیمُہُ کَسَرْتہ ، وَإِنْ تَرَکْتہ لَمْ یَزَلْ أَعْوَجَ ، اسْتَوْصُوا بِالنِّسَائِ۔ (بخاری 3331۔ مسلم 60)",,,19617,,
19618,"حَدَّثَنَا عَبِیْدَۃُ بْنُ حُمَیْدٍ ، عَنْ رُکَیْنٍ ، عَنْ نُعَیْمِ بْنِ حَنْظَلَۃَ قَالَ : قدِمَ جَرِیرُ بْنُ عَبْدِ اللہِ عَلَی عُمَرَ فَشَکَا إلَیْہِ مَا یَلْقَی مِنَ النِّسَائِ مِنْ سُوئِ أَخْلاَقِہِنَّ ، قَالَ : فَقَالَ عُمَرُ : إنِّی أَلْقَی مِثْلَ مَا تَلْقَی مِنْہُنَّ ، إنِّی لأَتِی قَالَ : السُّوقَ أَوِ النَّاسَ ، أَشْتَرِی مِنْہُمَ الدَّابَّۃَ ، أَوِ الثَّوْبَ فَتَقُولُ الْمَرْأْۃُ : إنَّمَا انْطَلَقَ یَنْظُرُ إلَی فَتَاتِہِمْ ، أَوْ یَخْطُبُ إلَیْہِمْ ، قَالَ : فَقَالَ عَبْدُ اللہِ بْنُ مَسْعُودٍ : أَوَمَا تَعْلَمُ ما شَکَا إبْرَاہِیمُ مِنْ دَرْئٍ فِی خُلُقِ سَارَۃَ ، فَأَوْحَی اللَّہُ إلَیْہِ : إنَّمَا ہِیَ مِن ضِلَعٍ فَخُذِ الضِّلْعَ فَأَقِمْہُ ، فَإِنِ اسْتَقَامَ وَإِلاَّ فَالْبَسْہَا عَلَی مَا فِیہَا۔",,,19618,,
19619,"حَدَّثَنَا سُفْیَانُ ، عَنْ مُغِیرَۃَ قَالَ : سَأَلْتُ إبْرَاہِیمَ عَنِ السِّقْطِ فَقَالَ : تَنْقَضِی بِہِ الْعِدَّۃُ۔",,,19619,,
19620,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا حَسَنٌ ، عَنْ مُطَرِّفٍ ، عَنْ عَامِرٍ قَالَ : السِّقْطُ بِمَنْزِلَۃِ الْوَلَدِ التَّامِّ۔",,,19620,,
19621,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ وَمُحَمَّدٍ قَالاَ : إِنْ أَسْقَطَتِ الْحُرَّۃُ ، فَقَدِ انْقَضَتْ عِدَّتُہَا۔",,,19621,,
19622,"حَدَّثَنَا عَلِیُّ بْنُ الْحَسَنِ بْنِ شَقِیقٍ قَالَ : أَخْبَرَنَا حُسَیْنُ بْنُ وَاقِدٍ قَالَ : حدَّثَنَا أَبُو مُنَازِل ، قَالَ : سَمِعْتُ شُرَیْحًا یَقُولُ : إذَا أَسْقَطَتِ الْمَرْأَۃُ سِقْطًا تَمَّ عِدَّۃُ الْحُرَّۃِ ، وَأُعْتِقَتِ السُّرِّیۃُ۔",,,19622,,
19623,"حَدَّثَنَا إِسْحَاقُ الأَزْرَقُ، عَنْ أَبِی الْعَلاَئِ، عَنْ حَجَّاجٍ، عَنِ الْحَارِثِ أَنَّہُ قَالَ فِی الْمُطَلَّقَۃِ وَالْمُتَوَفَّی عَنْہَا إذَا رَمَتْ بِوَلَدِہَا قَبْلَ أَنْ یَتِمَّ خَلْقُہُ قَالَ : إذَا اسْتَبَانَ مِنْہُ شَیْئٌ حَلَّتْ لِلزَّوْجِ ، قَالَ وَقَالَ ابْنُ شُبْرُمَۃَ : حَتَّی یَسْتَبِینَ وَیَعْرِفَ إِنَّہُ وَلَدُہُ۔",,,19623,,
19624,"حَدَّثَنَا ابْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ قَالَ : کَانَ الْحَسَنُ یَقُولُ : إذَا أَلْقَتْہُ عَلَقَۃً ، أَوْ مُضْغَۃً بَعْدَ أَنْ یُعْلَمَ أَنَّہُ حَمْلٌ فَفِیہِ الْغُرَّۃُ وَتَنْقَضِی بِہِ الْعِدَّۃُ ، وَإِنْ کَانَتْ أُمَّ وَلَدٍ أُعْتِقَتْ۔",,,19624,,
19625,"حَدَّثَنَا جَعْفَرُ بْنُ عَوْنٍ ، قَالَ : أَخْبَرَنَا خَالِدُ بْنُ وَرْدَانَ قَالَ : سَأَلْتُ عَطَائً ، عَنْ رَجُلَیْنِ حَلَفَ کُلُّ وَاحِدٍ مِنْہُمَا : إنَّ مَا قُلْتُ کَذَلِکَ ، وَتَحْتَ أَحَدِہِمَا خَالَتِی قَالَ : یُدَیَّنَان۔",,,19625,,
19626,"حَدَّثَنَا مُحَمَّدُ بْنُ سَوَاء ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ جَابِرِ بْنِ زَیْدٍ فِی رَجُلٍ قَالَ لامْرَأَتِہِ : إِنْ قَرُبْتُک سَنَۃً فَأَنْتِ طَالِقٌ ، قَالَ : إِنْ قَرَبَہَا قَبْلَ أَنْ تَمْضِیَ الأَرْبَعَۃُ أَشْہُرٍ فَہِیَ طَالِقٌ ثَلاَثًا ، وَإِنْ تَرَکَہَا حَتَّی تَمْضِیَ الأَرْبَعَۃُ أَشْہُرٍ ، فَقَدْ بَانَتْ مِنْہُ بِوَاحِدَۃٍ ، وَیَتَزَوَّجُہَا إِنْ شَائَ ، وَلاَ یَقْرَبُہَا حَتَّی تَمْضِیَ السَّنَۃُ۔",,,19626,,
19627,"حَدَّثَنَا مُحَمَّدُ بْنُ سَوَاء ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ قَالَ : إِنْ قَرَبَہَا قَبْلَ أَنْ تَمْضِیَ أَرْبَعَۃُ أَشْہُرٍ ، فَہِیَ طَالِقٌ ثَلاَثًا ، فَإِنْ تَرَکَہَا حَتَّی تَمْضِیَ أَرْبَعَۃُ أَشْہُرٍ ، فَقَدْ بَانَتْ مِنْہُ بِوَاحِدَۃٍ ، وَیَتَزَوَّجُہَا إِنْ شَائَ ، وَیَدْخُلُ بِہَا قَبْلَ أَنْ تَمْضِیَ السَّنَۃُ۔",,,19627,,
19628,"حَدَّثَنَا مُحَمَّدُ بْنُ سَوَاء ، عَنْ سَعِیدٍ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ قَالَ : إِنْ قَرُبَہَا قَبْلَ أَنْ تَمْضِیَ الأَرْبَعَۃُ أَشْہُرٍ فَہِیَ طَالِقٌ ثَلاَثًا ، وَإِنْ تَرَکَہَا حَتَّی تَمْضِیَ الأَرْبَعَۃُ أَشْہُرٍ ، فَقَدْ بَانَتْ مِنْہُ بِوَاحِدَۃٍ ، وَلاَ یَتَزَوَّجُہَا حَتَّی یَمْضِیَ مِنَ السَّنَۃِ أَقَلُّ مِمَّا یَدْخُلُ عَلَیْہِ الإِیلاَئُ ، شَہْرَانِ ، أَوْ ثَلاَثَۃٌ ، وَیَتَزَوَّجُہَا وَلاَ یَقْرَبُہَا حَتَّی تَمْضِیَ السَّنَۃُ وَذَلِکَ رَأْیُ سَعِیدٍ۔",,,19628,,
19629,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عُرْوَۃَ ، عَنْ عَائِشَۃَ تُبَلِّغُ بِہِ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : لاَ یَحِلُّ لاِمْرَأَۃٍ تُحِدُّ عَلَی مَیِّتٍ فَوْقَ ثَلاَثٍ إلاَّ عَلَی زَوْجٍ۔ (مسلم 65۔ احمد 6/37)",,,19629,,
19630,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ حُمَیْدِ بْنِ نَافِعٍ أَنَّہُ سَمِعَ زَیْنَبَ بِنْتَ أُمِّ سَلَمَۃَ تُحَدِّثُ أَنَّہَا سَمِعَتْ أُمَّ سَلَمَۃَ وَأَمَّ حَبِیبَۃَ تَذْکُرَانِ أَنَّ امْرَأَۃً أَتَتِ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَذَکَرَتْ أَنَّ ابْنَۃً لَہَا تُوُفِّیَ عَنْہَا زَوْجُہَا فَاشْتَکَتْ عَیْنُہَا فَہِیَ تُرِیدُ أَنْ تَکْحُلہَا ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : قدْ کَانَتْ إحْدَاکُنَّ تَرْمِی بِالْبَعْرَۃِ عِنْدَ رَأْسِ الْحَوْلِ ، وَإِنَّمَا ہِیَ أَرْبَعَۃُ أَشْہُرٍ وَعَشْرًا ، قَالَ حُمَیْدٌ : فَسَأَلْت زَیْنَبَ : مَا رَمْیُہَا بِالْبَعْرَۃِ ؟ فَقَالَتْ : کَانَتِ امْرَأَۃٌ فِی الْجَاہِلِیَّۃِ عَمَدَتْ إلَی شَرِّ بَیْتٍ لَہَا ، فَجَلَسَتْ فِیہِ سَنَۃً ، فَإِذَا مَرَّتِ السَّنَۃُ خَرَجَتْ ، وَرَمَتْ بِبَعْرَۃٍ مِنْ وَرَائَہَا۔ (مسلم 61۔ ترمذی 1197)",,,19630,,
19631,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ وَیَزِیدُ بْنُ ہَارُونَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ نَافِعٍ ، عَنْ صَفِیَّۃَ بِنْتِ أَبِی عُبَیْدٍ أَنَّہَا سَمِعَتْ حَفْصَۃَ زَوْجَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ تُحَدِّثُ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : لاَ یَحِلُّ لاِمْرَأَۃٍ تُؤْمِنُ بِاللَّہِ وَالْیَوْمِ الآخِرِ أَنْ تَحِدَّ عَلَی مَیِّتٍ فَوْقَ ثَلاَثٍ إلاَّ عَلَی زَوْجٍ۔ (احمد 6/286۔ طبرانی 361)",,,19631,,
19632,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ ہِشَامٍ ، عَنْ حَفْصَۃَ ، عَنْ أُمِّ عَطِیَّۃَ قَالَتْ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یُحَدُّ عَلَی مَیِّتٍ فَوْقَ ثَلاَثٍ إلاَّ الْمَرْأَۃُ تَحِدُّ عَلَی زَوْجِہَا أَرْبَعَۃَ أَشْہُرٍ وَعَشْرًا وَلاَ تَلْبَسُ ثَوْبًا مَصْبُوغًا إلاَّ ثَوْبَ عَصْبٍ وَلاَ تَکْتَحِلُ وَلاَ تَطَیَّبُ إلاَّ عِنْدَ أَدْنَی طُہْرِہَا بِنُبْذَۃٍ مِنْ قُسْطٍ ، أَوْ أَظْفَارٍ۔\n\n(بخاری 5342۔ مسلم 1128)",,,19632,,
19633,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ، عَنِ التَّیْمِیِّ، عَنْ أَبِی مجلز قَالَ: قَالَ ابْنُ عُمَرَ: الْمُتَوَفَّی عَنْہَا زَوْجُہَا تَعْتَدُّ أَرْبَعَۃَ أَشْہُرٍ وَعَشْرًا ، فَقَالَ رَجُلٌ : إنَّ ہَذَا لَکَثِیرٌ فَقَالَ ابْنُ عُمَرَ : قَدْ کُنَّ فِی الْجَاہِلِیَّۃِ یُحْدِدْنَ أَکْثَرَ مِنْ ہَذَا۔",,,19633,,
19634,"حَدَّثَنَا عَبِیْدَۃُ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ نَافِعٍ ، عَنْ صَفِیَّۃَ بِنْتِ أَبِی عُبَیْدٍ أَنَّہَا أَخْبَرَتْہُ أَنَّہَا سَمِعَتْ أُمَّ سَلَمَۃَ وَعَائِشَۃَ وَحَفْصَۃَ یَقُلْنَ قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَحِلُّ لامْرَأَۃٍ تُؤْمِنُ بِاللَّہِ وَالْیَوْمِ الآخِرِ تَحُدُّ عَلَی مَیِّتٍ فَوْقَ ثَلاَثَۃِ أَیَّامٍ إلاَّ عَلَی بَعْلِہَا فَإِنَّہَا تَحِدُّ عَلَیْہِ أَرْبَعَۃَ أَشْہُرٍ وَعَشْرًا۔ (مسلم 1128)",,,19634,,
19635,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ أَنَّہُ کَانَ لاَ یَرَی الإِحْدَادَ شَیْئًا۔,,,19635,,
19636,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، وَعَلِیُّ بْنُ ہِشَامٍ ، عَنِ الأَعْمَشِِ ، عَنْ أَبِی الضُّحَی ، عَنْ مَسْرُوقٍ ، عَنْ أُبَیٍّ قَالَ : إنَّ مِنَ الأَمَانَۃِ أَنَّ الْمَرْأَۃَ اؤْتُمِنَتْ عَلَی فَرْجِہَا۔",,,19636,,
19637,"حَدَّثَنَا وَکِیعٌ قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ الأَعْمَشِِ ، عَنْ أَبِی الضُّحَی ، عَنْ مَسْرُوقٍ ، عَنْ أُبَیٍّ قَالَ : إنَّ مِنَ الأَمَانَۃِ أَنَّ الْمَرْأَۃَ اؤْتُمِنَتْ عَلَی فَرْجِہَا۔",,,19637,,
19638,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ أَبِیہِ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو قَالَ : الْفَرْجُ أَمَانَۃٌ۔",,,19638,,
19639,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ عُبَیْدِ بْنِ عُمَیْرٍ قَالَ : مِنَ الأَمَانَۃِ أَنَّ الْمَرْأَۃَ اؤْتُمِنَتْ عَلَی فَرْجِہَا۔",,,19639,,
19640,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ زَیْدٍ ، عَنْ أَیُّوبَ السِّخْتِیَانِیِّ ، عَنْ سلَیْمَانَ بْنِ یَسَارٍ قَالَ : ذُکِرَ عِنْدَہُ عِدَدُ النِّسَائِ فَقَالَ : إِنَّا لَمْ نُؤْمَرْ أَنْ نُفَتّحہنّ۔",,,19640,,
19641,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنْ عَامِرٍ قَالَ : جَائَتِ امْرَأَۃٌ إلَی عَلِیٍّ طَلَّقَہَا زَوْجُہَا فَزَعَمَتْ أَنَّہَا حَاضَتْ فِی شَہْرٍ ثَلاَثَ حِیَضٍ ، وَطَہُرَتْ عِنْدَ کُلِّ قُرْئٍ وَصَلَّتْ ، فَقَالَ عَلِیٌّ لِشُرَیْحٍ : قُلْ فِیہَا فَقَالَ شُرَیْحٌ : إِنْ جَائَتْ بَیِّنَۃٌ مِنْ بِطَانَۃِ أَہْلِہَا مِمَّنْ یُرْضَی بِدِینِہِ وَأَمَانَتِہِ یَشْہَدُونَ أَنَّہَا حَاضَتْ فِی شَہْرٍ ثَلاَثَ حِیَضٍ وَطَہُرَتْ عِنْدَ کُلِّ قُرْئٍ وَصَلَّتْ فَہِیَ صَادِقَۃٌ وَإِلاَّ فَہِیَ کَاذِبَۃٌ فَقَالَ عَلِیٌّ : قالون ، وَعَقَدَ ثَلاَثِینَ بِیَدِہِ یَعْنِی بِالرُّومِیَّۃِ۔",,,19641,,
19642,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عُلَیَۃَ ، عَنِ الجَلْدِ بْنِ أَیُّوبَ ، عَنْ مُعَاوِیَۃَ بْنِ قُرَّۃَ ، عَنْ أَنَسٍ قَالَ : قرُوئُ الْحَیْضِ : أَرْبَعٌ ، خَمْسٌ ، سِتٌّ ، سَبْعٌ ، ثَمَانٍ ، تِسْعٌ ، عَشَرٌ ، ثُمَّ تَغْتَسِلُ وَتُصَلِّی۔",,,19642,,
19643,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ، عَنْ أَشْعَثَ، عَنْ قَیْسٍ، عَنِ الحَسَن، عَنْ عُثْمَانَ بْنِ أَبِی الْعَاصِ قَالَ: لاَ تَکُونُ الْمُسْتَحَاضَۃُ یَوْمًا وَلاَ یَوْمَیْنِ وَلاَ ثَلاَثَۃً حَتَّی تَبْلُغَ عَشَرَۃَ أَیَّامٍ ، فَإِذَا بَلَغَتْ عَشَرَۃَ أَیَّامٍ کَانَتْ مُسْتَحَاضَۃً۔",,,19643,,
19644,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنِ أُمّ الضَّحَّاکِ بِنْتِ رَاشِدٍ قَالَتْ : سَمِعْت خَالِدَ بْنَ مَعْدَانَ یقول : أَقَلُّ مَا تَکُونُ حَیْضَۃُ الْمَرْأَۃِ ثَلاَثَۃَ أَیَّامٍ ، وَآخِرُہَا عَشَرَۃٌ۔",,,19644,,
19645,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عَلِیِّ بْنِ ثَابِتٍ ، عَنْ مُحَمَّدِ بْنِ زَیْدٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ قَالَ : الْحَیْضُ ثِنْتَا عَشْرَۃَ۔",,,19645,,
19646,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنْ عَطَائٍ قَالَ : أَقْصَی مَا تَجْلِسُ الْحَائِضُ خَمْسَ عَشْرَۃَ لَیْلَۃً۔",,,19646,,
19647,"حَدَّثَنَا وَکِیعٌ ، عَنْ رَبِیعٍ ، عَنْ عَطَائٍ قَالَ : الْحَیْضُ خَمْسَ عَشْرَۃَ۔",,,19647,,
19648,"حَدَّثَنَا وَکِیعٌ ، عَنْ رَبِیعٍ ، عَنِ الْحَسَنِ قَالَ : أَقْرَاؤُہَا مَا کَانَتْ تَحِیضُ۔",,,19648,,
