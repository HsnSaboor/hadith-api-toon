hadiths[count]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}: 2111,"أَخْبَرَنَا يَزِيدُ بْنُ هَارُونَ  ، أَنْبَأَنَا عَاصِمٌ  ، عَنْ مُوَرِّقٍ الْعِجْلِيِّ  ، قَالَ : قَالَ عُمَرُ بْنُ الْخَطَّابِ   :"" تَعَلَّمُوا الْفَرَائِضَ وَاللَّحْنَ وَالسُّنَنَ كَمَا تَعَلَّمُونَ الْقُرْآنَ """,,takhreej: !صحیح مسلم، کتاب الأطعمۃ، باب مایفعل الضیف اذا تبعۃ غیر (5280) والنسائی، کتاب الطلاق، باب الطلاق بالاشارۃ المفھومۃ (3436), 2112,"حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ  ، حَدَّثَنَا سُفْيَانُ  ، عَنْ الْأَعْمَشِ  ، عَنْ إِبْرَاهِيمَ  ، قَالَ : قَالَ عُمَرُ   :"" تَعَلَّمُوا الْفَرَائِضَ فَإِنَّهَا مِنْ دِينِكُمْ """,,takhreej: !متفق علیہ: البخاری، کتاب البیوع، باب ماقیل فی اللحام والجزار (2081) ومسلم،کتاب الأطعمۃ، باب مایفعل الضیف إذا تبعۃ (5277), 2113,"حَدَّثَنَا مُحَمَّدُ بْنُ عِيسَى ، حَدَّثَنَا يُوسُفُ الْمَاجِشُونُ ، قَالَ : قَالَ ابْنُ شِهَابٍ  :"" لَوْ هَلَكَ عُثْمَانُ، وَزَيْدٌ فِي بَعْضِ الزَّمَانِ، لَهَلَكَ عِلْمُ الْفَرَائِضِ، لَقَدْ أَتَى عَلَى النَّاسِ زَمَانٌ، وَمَا يَعْلَمُهَا غَيْرُهُمَا """,,takhreej: @متفق علیہ: البخاری، کتاب فضائل الصحابہ، باب فضل عائشۃ رضی اللہ عنہا (3770) ومسلم، کتاب فضائل الصحابۃ، باب فضل عائشۃ رضی اللہ عنہا (6249), 2114,"حَدَّثَنَا أَبُو نُعَيْمٍ  ، حَدَّثَنَا الْمَسْعُودِيُّ  ، عَنْ الْقَاسِمِ  ، قَالَ : قَالَ عَبْدُ اللَّهِ   :"" تَعَلَّمُوا الْقُرْآنَ وَالْفَرَائِضَ، فَإِنَّهُ يُوشِكُ أَنْ يَفْتَقِرَ الرَّجُلُ إِلَى عِلْمٍ كَانَ يَعْلَمُهُ، أَوْ يَبْقَى فِي قَوْمٍ لَا يَعْلَمُونَ",,takhreej: !اسنادہ ضعیف: دارمی منفرد ہیں۔, 2115,"حَدَّثَنَا أَبُو نُعَيْمٍ  ، حَدَّثَنَا زِيَادُ بْنُ أَبِي مُسْلِمٍ  ، عَنْ أَبِي الْخَلِيلِ  ، قَالَ : قَالَ أَبُو مُوسَى   :"" مَنْ عَلِمَ الْقُرْآنَ وَلَمْ يَعْلَمْ الْفَرَائِضَ، فَإِنَّ مَثَلَهُ مَثَلُ الْبُرْنُسِ لَا وَجْهَ لَهُ، أَوْ : لَيْسَ لَهُ وَجْهٌ """,,takhreej: @صحیح البخاری، کتاب الأطعمۃ، باب الأکل مثکئًا (5398) وابوداؤد، کتاب الأطعمۃ، باب ماجاء فی الأکل (متکئًا (3769), 2116,"حَدَّثَنَا أَحْمَدُ بْنُ عَبْدِ اللَّهِ ، حَدَّثَنَا أَبُو شِهَابٍ ، عَنْ الْأَعْمَشِ ، عَنْ إِبْرَاهِيمَ ، قَال : قُلْتُ لِعَلْقَمَةَ  : مَا أَدْرِي مَا أَسْأَلُكَ عَنْهُ؟ قَالَ :"" أَمِتْ جِيرَانَكَ """,,takhreej: !صحیح مسلم،کتاب الحج، باب فضل المدینہ (3322) وابن ماجہ، کتاب الأطعمۃ، باب اذا أتی بأول الثمرۃ (3329), 2117,"حَدَّثَنَا أَبُو نُعَيْمٍ  ، حَدَّثَنَا مُحَمَّدُ بْنُ طَلْحَةَ  ، عَنْ الْقَاسِمِ بْنِ الْوَلِيدِ الْهَمْدَانِيِّ  ، عَنْ عَبْدِ اللَّهِ بْنِ مَسْعُودٍ  ، قَالَ :"" تَعَلَّمُوا الْفَرَائِضَ، وَالطَّلاقَ، وَالْحَجَّ، فَإِنَّهُ مِنْ دِينِكُمْ """,,takhreej: @صحیح البخاری، کتاب الأطعمۃ، باب الأکل مع الخادم (5460) والترمذی، کتاب الأطعمۃ، باب ماجاء فی الأکل مع المملوک والعیال (1853), 2118,"حَدَّثَنَا سُلَيْمَانُ بْنُ حَرْبٍ  ، حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ  ، عَنْ كَثِيرٍ  ، عَنْ الْحَسَنِ  ، قَالَ :"" كَانُوا يُرَغِّبُونَ فِي تَعْلِيمِ الْقُرْآنِ وَالْفَرَائِضِ وَالْمَنَاسِكِ """,,takhreej: !صحیح: سابقہ ہی مکرر ہے۔, 2119,"أَخْبَرَنَا مُحَمَّدُ بْنُ يُوسُفَ  ، عَنْ سُفْيَانَ  ، عَنْ أَبِي إِسْحَاق  ، عَنْ أَبِي عُبَيْدَةَ  ، عَنْ عَبْدِ اللَّهِ  ، قَالَ :"" مَنْ قَرَأَ الْقُرْآنَ، فَلْيَتَعَلَّمْ الْفَرَائِضَ، فَإِنْ لَقِيَهُ أَعْرَابِيٌّ، قَالَ : يَا مُهَاجِرُ، أَتَقْرَأُ الْقُرْآنَ؟ فَإِنْ قَالَ : نَعَمْ، قَالَ : تَفْرِضُ؟ فَإِنْ قَالَ : نَعَمْ، فَهُوَ زِيَادَةٌ وَخَيْر، وَإِنْ قَالَ : لَا، قَالَ : فَمَا فَضْلُكَ عَلَيَّ يَا مُهَاجِرُ؟ !",,takhreej: @متفق علیہ: البخاری، کتاب الأطعمۃ، باب الحلواء والعسل (5431) ومسلم، کتاب الطلاق، باب وجوب الکفارۃ علی من حرم امرأتہ (3664), 2120,"حَدَّثَنَا عَبْدُ اللَّهِ بْنُ سَعِيدٍ  ، حَدَّثَنَا عُقْبَةُ بْنُ خَالِدٍ  ، عَنْ الْأَعْمَشِ  ، عَنْ مُسْلِمٍ  ، قَالَ : سَأَلْنَا مَسْرُوقًا  : كَانَتْ عَائِشَةُ   تُحْسِنُ الْفَرَائِضَ؟ قَالَ :"" وَالَّذِي لَا إِلَهَ غَيْرُهُ، لَقَدْ رَأَيْتُ الْأَكَابِرَ مِنْ أَصْحَابِ مُحَمَّدٍ يَسْأَلُونَهَا عَنْ الْفَرَائِضِ """,,takhreej: !صحیح مسلم، کتاب الحیض، باب جواز أکل المحدث الطعام وأنہ (825), 2121,"أَخْبَرَنَا سَعِيدُ بْنُ عَامِرٍ  ، عَنْ شُعْبَةَ  ، عَنْ عَاصِمٍ  ، عَنْ أَبِي عُثْمَانَ  ،  عَنْ سَعْدِ بْنِ أَبِي وَقَّاصٍ  ، وَعَنْ أَبِي بَكْرَةَ   قَالَ شُعْبَةُ : هَذَا أَوَّلُ مَنْ رَمَى بِسَهْمٍ فِي سَبِيلِ اللَّهِ، وَهَذَا تَدَلَّى مِنْ حِصْنِ الطَّائِفِ إِلَى رَسُولِ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّم إِنَّهُمَا حَدَّثَا : أَنَّ رَسُولَ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ، قَالَ :"" مَنْ ادَّعَى إِلَى غَيْرِ أَبِيهِ وَهُوَ يَعْلَمُ أَنَّهُ غَيْرُ أَبِيهِ، فَالْجَنَّةُ عَلَيْهِ حَرَامٌ """,,takhreej: @صحیح: سابقہ ہی مکرر ہے۔, 2122,"حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ  ، حَدَّثَنَا سُفْيَانُ  ، عَنْ الْأَعْمَشِ  ، عَنْ عَبْدِ اللَّهِ بْنِ مُرَّةَ  ، عَنْ أَبِي مَعْمَرٍ  ، عَنْ أَبِي بَكْرٍ الصِّدِّيقِ  ، قَالَ :"" كُفْرٌ بِاللَّهِ ادِّعَاءٌ إِلَى نَسَبٍ لَا يُعْرَفُ، وَكُفْرٌ بِاللَّهِ تَبَرُّؤٌ مِنْ نَسَبٍ وَإِنْ دَقَّ. حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ  ، حَدَّثَنَا سُفْيَانُ  ، عَنْ زَكَرِيَّا أَبِي يَحْيَى  ، قَالَ : سَمِعْتُ أَبَا وَائِلٍ  يُحَدِّثُ، عَنْ ابْنِ مَسْعُودٍ  ، نَحْوًا مِنْهُ",,takhreej: #صحیح: سابقہ دونوں حدیثوں کا تکرار ہے۔, 2123,"حَدَّثَنَا مُحَمَّدُ بْنُ الْعَلَاءِ  ، حَدَّثَنَا إِسْحَاق بْنُ مَنْصُورٍ السَّلُولِيُّ  ، عَنْ جَعْفَرٍ الْأَحْمَرِ  ، عَنْ السَّرِيِّ بْنِ إِسْمَاعِيل  ، عَنْ قَيْسِ بْنِ أَبِي حَازِمٍ  ، قَالَ : أَتَيْتُ النَّبِيَّ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ لِأُبَايِعَهُ، فَجِئْتُ وَقَدْ قُبِض، وَأَبُو بَكْرٍ   قَائِمٌ فِي مَقَامِهِ، فَأَطَالَ الثَّنَاءَ وَأَكْثَرَ الْبُكَاءَ، فَقَالَ : سَمِعْتُ رَسُولَ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ، يَقُولُ :"" كُفْرٌ بِاللَّهِ انْتِفَاءٌ مِنْ نَسَبٍ وَإِنْ دَقَّ، وَادِّعَاءُ نَسَبٍ لَا يُعْرَفُ """,,takhreej: !صحیح مسلم، کتاب الحیض، باب جواز أکل الجنب واستحباب (698) ابوداؤد، کتاب الطھارۃ، باب من قال یتوضأ الجنب (224), 2124,"حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ  ، حَدَّثَنَا عَبْدُ الْحَمِيدِ بْنُ بَهْرَامَ  ، عَنْ شَهْرِ بْنِ حَوْشَبٍ  ،  عَنْ ابْنِ عَبَّاسٍ  ، قَالَ : قَالَ رَسُولُ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ :"" أَيُّمَا رَجُلٍ ادَّعَى إِلَى غَيْرِ وَالِدِه، أَوْ تَوَلَّى غَيْرَ مَوَالِيهِ الَّذِينَ أَعْتَقُوهُ، فَإِنَّ عَلَيْهِ لَعْنَةَ اللَّه، وَالْمَلائِكَةِ، وَالنَّاسِ أَجْمَعِينَ إِلَى يَوْمِ الْقِيَامَة، لا يُقْبَلُ مِنْهُ صَرْفٌ وَلَا عَدْلٌ",,takhreej: @صحیح مسلم، کتاب البروالصلۃ، باب الوصیۃ بالجار والإحسان الیہ (6631) والترمذی، کتاب الأطعمۃ، باب ماجاء فی إکـثار ماء المرقۃ (1833), 2125,"أَخْبَرَنَا يَزِيدُ بْنُ هَارُونَ  ، أَنْبَأَنَا شَرِيكٌ  ، عَنْ الْأَعْمَشِ  ، عَنْ إِبْرَاهِيمَ  ، قَالَ : قَالَ عَبْدُ اللَّهِ  : كَانَ عُمَرُ   إِذَا سَلَكَ بِنَا طَرِيقًا وَجَدْنَاهُ سَهْلًا، وَإِنَّهُ قَالَ فِي زَوْجٍ وَأَبَوَيْنِ :"" لِلزَّوْجِ النِّصْفُ، وَلِلْأُمِّ ثُلُثُ مَا بَقِيَ",,takhreej: !ضعیف جدًا: أخرجہ الطبرانی فی الاوسط (3226) والحاکم 4/119, 2126,"أَخْبَرَنَا يَزِيدُ بْنُ هَارُونَ  ، حَدَّثَنَا هَمَّامٌ  ، حَدَّثَنَا يَزِيدُ الرِّشْكُ  ، قَالَ : سَأَلْتُ سَعِيدَ بْنَ الْمُسَيِّبِ   عَنْ رَجُلٍ تَرَكَ امْرَأَتَهُ، وَأَبَوَيْهِ، فَقَالَ :"" قَسَّمَهَا زَيْدُ بْنُ ثَابِتٍ   مِنْ أَرْبَعَةٍ """,,takhreej: @صحیح: اس کے شواہد بھی موجود ہیں۔, 2127,"حَدَّثَنَا سَعِيدُ بْنُ عَامِرٍ  ، عَنْ شُعْبَةَ  ، عَنْ أَيُّوبَ  ، عَنْ أَبِي قِلَابَةَ  ، عَنْ أَبِي الْمُهَلَّبِ  : أَنَّ عُثْمَانَ بْنَ عَفَّانَ   قَالَ فِي امْرَأَةٍ وَأَبَوَيْنِ :"" لِلْمَرْأَةِ الرُّبُعُ، وَلِلْأُمِّ ثُلُثُ مَا بَقِيَ """,,takhreej: !متفق علیہ: البخاری، کتاب النکاح، باب اجابۃ الداعی فی العرس وغیرہ (5179) ومسلم، کتاب النکاح باب الأمر باجابۃ الداعی إلی دعوۃ (3502), 2128,"حَدَّثَنَا حَجَّاجُ بْنُ مِنْهَالٍ  ، حَدَّثَنَا حَمَّادُ بْنُ سَلَمَةَ  ، عَنْ أَيُّوبَ  ، عَنْ أَبِي قِلَابَةَ  ، عَنْ أَبِي الْمُهَلَّبِ  ، عَنْ عُثْمَانَ بْنِ عَفَّانَ   أَنَّهُ قَالَ :"" لِلْمَرْأَةِ الرُّبُعُ سَهْمٌ مِنْ أَرْبَعَةٍ، وَلِلْأُمِّ ثُلُثُ مَا بَقِيَ سَهْم، وَلِلأَبِّ سَهْمَانِ "". أَخْبَرَنَا حَجَّاجٌ  ، حَدَّثَنَا حَمَّادٌ  ، عَنْ حَجَّاجٍ  ، عَنْ عُمَيْرِ بْنِ سَعِيدٍ  : أَنَّهُ سَأَلَ الْحَارِثَ الْأَعْوَرَ   عَنْ امْرَأَةٍ، وَأَبَوَيْنِ، فَقَالَ مِثْلَ قَوْلِ عُثْمَانَ",,takhreej: @صحیح البخاری، کتاب الوضوئ، باب مایقع من النجاسات فی السمن والماء (235) وابوداؤد، کتاب الأطعمۃ، باب فی الفأرۃ تقع فی السمن (3841), 2129,"حَدَّثَنَا أَبُو نُعَيْمٍ  ، حَدَّثَنَا هِشَامٌ  ، عَنْ قَتَادَةَ  ، عَنْ سَعِيدِ بْنِ الْمُسَيِّبِ  ، عَنْ زَيْدِ بْنِ ثَابِتٍ  ، أَنَّهُ قَالَ فِي امْرَأَةٍ تَرَكَتْ زَوْجَهَا وَأَبَوَيْهَا :"" لِلزَّوْجِ النِّصْفُ، وَلِلْأُمِّ ثُلُثُ مَا بَقِيَ """,,takhreej: !صحیح: سابقہ ہی مکرر ہے۔, 2130,"أَخْبَرَنَا عُبَيْدُ اللَّهِ بْنُ مُوسَى  ، عَنْ ابْنِ أَبِي لَيْلَى  ، عَنْ عَامِرٍ الشَّعْبِيِّ  ، عَنْ عَلِيٍّ   : فِي امْرَأَةٍ وَأَبَوَيْنِ، قَالَ :"" مِنْ أَرْبَعَةٍ : لِلْمَرْأَةِ الرُّبُعُ، وَلِلْأُمِّ ثُلُثُ مَا بَقِي، وَمَا بَقِيَ فَلِلْأَبِ """,,takhreej: @متفق علیہ : دیکھئے سابقہ (765), 2131,"حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ  ، عَنْ سُفْيَانَ  ، عَنْ الْأَعْمَشِ  ، وَمَنْصُورٍ  ، عَنْ إِبْرَاهِيمَ  ، عَنْ عَبْدِ اللَّهِ  ، قَالَ : كَانَ عُمَرُ   إِذَا سَلَكَ بِنَا طَرِيقًا اتَّبَعْنَاهُ فِيهِ، وَجَدْنَاهُ سَهْلًا، وَإِنَّهُ"" قَضَى فِي امْرَأَةٍ وَأَبَوَيْنِ مِنْ أَرْبَعَةٍ : فَأَعْطَى الْمَرْأَةَ الرُّبُع، وَالأُمَّ ثُلُثَ مَا بَقِيَ، وَالْأَبَ سَهْمَيْنِ. حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ  ، حَدَّثَنَا سُفْيَانُ  عَنْ عِيسَى  ، عَنْ الشَّعْبِيِّ  ، عَنْ زَيْدِ بْنِ ثَابِتٍ   مِثْلَ ذَلِكَ",,takhreej: #متفق علیہ: سابقہ ہی مکرر ہے۔, 2132,"أَخْبَرَنَا مُحَمَّدٌ  ، حَدَّثَنَا سُفْيَانُ  ، عَنْ أَبِيهِ  ، عَنْ الْمُسَيَّبِ بْنِ رَافِعٍ  ، عَنْ عَبْدِ اللَّهِ  ، قَالَ : كَانَ يَقُولُ :"" مَا كَانَ اللَّهُ لِيَرَانِي أَنْ أُفَضِّلَ أُمًّا عَلَى أَبٍ """,,takhreej: $حسن: (689) میں مطولاً گزر چکی ہے۔, 2133,"أَخْبَرَنَا سَعِيدُ بْنُ عَامِرٍ  ، أَنْبَأَنَا شُعْبَةُ  ، عَنْ الْحَكَمِ  ، عَنْ عِكْرِمَةَ  ، قَالَ :"" أَرْسَلَ ابْنُ عَبَّاسٍ إِلَى زَيْدِ بْنِ ثَابِتٍ   : أَتَجِدُ فِي كِتَابِ اللَّهِ لِلْأُمِّ ثُلُثُ مَا بَقِي؟ فَقَالَ زَيْدٌ : إِنَّمَا أَنْتَ رَجُلٌ تَقُولُ بِرَأْيِكَ، وَأَنَا رَجُلٌ أَقُولُ بِرَأْيِي """,,takhreej: !صحیح مسلم، کتاب الأشربۃ، باب جواز شرب اللبن (5208) والبخاری، کتاب الأشربۃ، باب قولہ تعالیٰ (انما الخمر والمیسر… ) (5576), 2134,"حَدَّثَنَا حَجَّاجُ بْنُ مِنْهَالٍ  ، حَدَّثَنَا حَمَّادُ بْنُ سَلَمَةَ  ، عَنْ حَجَّاجٍ  ، عَنْ الشَّعْبِيِّ  ، وَحَجَّاجٍ  ، عَنْ عَطَاءٍ  ، عَنْ ابْنِ عَبَّاسٍ   : أَنَّهُمَا قَالَا فِي زَوْجٍ وَأَبَوَيْنِ :"" لِلزَّوْجِ النِّصْفُ، وَلِلْأُمِّ ثُلُثُ جَمِيعِ الْمَالِ، وَمَا بَقِيَ فَلِلْأَبِ """,,takhreej: !متفق علیہ: البخاری، کتاب البیوع، باب ماقیل فی الصواغ (2089) ومسلم، کتاب الأشربۃ، باب تحریم الخمر وبیان أنھا تکون(5103), 2135,"حَدَّثَنَا حَجَّاجُ بْنُ مِنْهَالٍ  ، أَنْبَأَنَا أَبُو عَوَانَةَ  ، عَنْ الْأَعْمَشِ  ، عَنْ إِبْرَاهِيمَ  ، عَنْ عَلِيٍّ  ، قَالَ :"" لِلْأُمِّ ثُلُثُ جَمِيعِ الْمَالِ فِي امْرَأَةٍ وَأَبَوَيْنِ، وَفِي زَوْجٍ وَأَبَوَيْنِ """,,takhreej: !متفق علیہ: البخاری، کتاب الأشربۃ، باب قول اللّٰہ تعالیٰ (انما الخمر والمیسر…) (5575) ومسلم،کتاب الاشربۃ باب عقوبۃ من شرب الخمر اذا (5191), 2136,"حَدَّثَنَا مُحَمَّدُ بْنُ عِيسَى  ، حَدَّثَنَا ابْنُ إِدْرِيسَ  ، عَنْ أَبِيهِ  ، عَنْ الْفُضَيْلِ بْنِ عَمْرٍو  ، عَنْ إِبْرَاهِيمَ  ، قَالَ : خَالَفَ ابْنُ عَبَّاسٍ   أَهْلَ الْقِبْلَةِ فِي امْرَأَةٍ وَأَبَوَيْنِ :"" جَعَلَ لِلْأُمِّ الثُّلُثَ مِنْ جَمِيعِ الْمَالِ """,,takhreej: !صحیح: النسائی، کتاب الأشربۃ، باب ذکر الروایۃ المبینۃ عن (5680) وابن ماجہ، کتاب الأشربۃ، باب من شرب الخمر لم تقبل لہ صلاۃ (3377), 2137,"أَخْبَرَنَا مُحَمَّدُ بْنُ يُوسُفَ  ، عَنْ سُفْيَانَ الثَّوْرِيِّ  ، عَنْ أَشْعَثَ بْنِ أَبِي الشَّعْثَاءِ  ، عَنْ الْأَسْوَدِ بْنِ يَزِيدَ  ، قَالَ : "" قَضَى مُعَاذُ بْنُ جَبَلٍ   بِالْيَمَنِ فِي بِنْتٍ وَأُخْتٍ،فَأَعْطَى الْبِنْتَ النِّصْفَ، وَالْأُخْتَ النِّصْفَ """,,takhreej: @صحیح: الترمذی، کتاب الأدب، باب ماجاء فی دخول الحمام (2810), 2138,"أَخْبَرَنَا مُحَمَّدُ بْنُ يُوسُفَ  ، حَدَّثَنَا سُفْيَانُ  ، عَنْ الْأَعْمَشِ  ، عَنْ إِبْرَاهِيمَ  ، عَنْ الْأَسْوَدِ بْنِ يَزِيدَ  : أَنَّ ابْنَ الزُّبَيْرِ كَانَ لَا يُوَرِّثُ الْأُخْتَ مِنْ الْأَبِ، وَالْأُمِّ مَعَ الْبِنْتِ حَتَّى حَدَّثَهُ الْأَسْوَدُ أَنَّ مُعَاذَ بْنَ جَبَلٍ  جَعَلَ لِلْبِنْتِ النِّصْفَ، وَلِلْأُخْتِ النِّصْفَ ""، فَقَالَ : أَنْتَ رَسُولِي إِلَى عَبْدِ اللَّهِ بْنِ عُتْبَة، فَأَخْبِرْهُ بِذَاكَ، وَكَانَ قَاضِيَهُ بِالْكُوفَةِ",,takhreej: !صحیح: النسائی، کتاب الأشربۃ، باب الروایۃ فی المدمنین فی الخمر (5688), 2139,"حَدَّثَنَا بِشْرُ بْنُ عُمَرَ  ، قَالَ : سَأَلْتُ ابْنَ أَبِي الزِّنَادِ  ، عَنْ رَجُلٍ تَرَكَ بِنْتًا وَأُخْتًا؟ فَقَالَ : "" لِابْنَتِهِ النِّصْف، وَلأُخْتِهِ مَا بَقِيَ "" قَالَ : وَقَالَ : أَخْبَرَنِي أَبِي  ، عَنْ خَارِجَةَ بْنِ زَيْدٍ  : أَنَّ زَيْدَ بْنَ ثَابِتٍ   كَانَ"" يَجْعَلُ الْأَخَوَاتِ مَعَ الْبَنَاتِ عَصَبَةً، لَا يَجْعَلُ لَهُنَّ إِلَّا مَا بَقِيَ """,,takhreej: @اسنادہ جیّد, 2140,"حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ  ، حَدَّثَنَا سُفْيَانُ  ، عَنْ مَنْصُورٍ  ، وَالْأَعْمَشِ  ، عَنْ إِبْرَاهِيمَ   : فِي زَوْجٍ، وَأُمٍّ، وَإِخْوَةٍ لِأَبٍ وَأُم، وَإِخْوَةٍ لِأُمٍّ، قَالَ :كَانَ عُمَر  ، وَعَبْدُ اللَّه  ، ِوَزَيْدٌ   يُشَرِّكُونَ، وَقَالَ عُمَرُ : "" لَمْ يَزِدْهُمْ الْأَبُ إِلَّا قُرْبًا """,,takhreej: !صحیح مسلم، کتاب الأشربۃ، باب تحریم، التداول بالخمر (5112) الترمذی، کتاب الطب، باب ماجاء فی کراھیۃ التداوی بالمسکر (2046), 2141,"حَدَّثَنَا مُحَمَّدٌ  ، حَدَّثَنَا سُفْيَانُ  ، عَنْ أَبِي إِسْحَاق  ، عَنْ الْحَارِثِ  ،  عَنْ عَلِيٍّ   : أَنَّهُ كَانَ"" لَا يُشَرِّكُ """,,takhreej: @صحیح مسلم، کتاب الأشربۃ، باب بیان أن جمیع ماینبذ مما یتخذ… (5114) وابوداؤد، کتاب الأشربۃ، باب الخمر مماھی (3678), 2142,"أَخْبَرَنَا مُحَمَّدٌ  ، حَدَّثَنَا سُفْيَانُ  ، عَنْ سُلَيْمَانَ التَّيْمِيِّ  ، عَنْ أَبِي مِجْلَزٍ   :أَنَّ عُثْمَانَ  كَانَ يُشَرِّك، وَعَلِيٌّ   كَانَ لا يُشَرِّكُ """,,takhreej: !متفق علیہ: البخاری، کتاب الوضوئ، باب لایجوز الوضوء بالنبیذ ولا المسکر (242) ومسلم، کتاب الأشربۃ، باب بیان أن کل مسکر خمر وأن کل خمر حرام (5180), 2143,"حَدَّثَنَا مُحَمَّدٌ  ، حَدَّثَنَا سُفْيَانُ  ، عَنْ ابْنِ ذَكْوَانَ  : "" أَنَّ زَيْدًا   كَانَيُشَرِّكُ """,,takhreej: !متفق علیہ: البخاری، کتاب المغازی، باب بعث ابی موسیٰ ومعاذ الی الیمن قبل حجۃ الوداع۔ (4343) ومسلم،کتاب الأشربۃ، باب بیان أن کل مسکر خمر وأن کل خمر حرام (5182), 2144,"حَدَّثَنَا مُحَمَّدٌ ، حَدَّثَنَا سُفْيَانُ ، عَنْ عَبْدِ الْمَلِكِ بْنِ عُمَيْرٍ ، عَنْ شُرَيْح  : "" أَنَّهُ كَانَيُشَرِّكُ",,takhreej: @حسن: أخرجہ النسائی، کتاب الأشریۃ، باب تحریم کل شراب أسکر کثیرہ (5624), 2145,"حَدَّثَنَا مُحَمَّدُ بْنُ الصَّلْتِ  ، حَدَّثَنَا أَبُو شِهَابٍ  ، عَنْ الْحَجَّاجِ  ، عَنْ عَبْدِ الْمَلِكِ بْنِ الْمُغِيرَةِ  ، عَنْ سَعِيدِ بْنِ فَيْرُوزَ  ، عَنْ أَبِيه  : أَنَّ عُمَرَ   قَالَ فِي الْمُشَرَّكَة :"" لَمْ يَزِدْهُمْ الْأَبُ إِلَّا قُرْبًا",,takhreej: !حسن: الحاکم، 4/147، وسنن البیہقی، کتاب الشراب، باب الدلیل علی أن الطبخ لایخرج … 8/194, 2146,"أَخْبَرَنَا أَبُو نُعَيْمٍ  ، حَدَّثَنَا زُهَيْرٌ  ، عَنْ أَبِي إِسْحَاق  ، عَنْ الْحَارِثِ الْأَعْوَرِ  ، قَالَ : أُتِيَ عَبْدُ اللَّهِ  فِي فَرِيضَةِ بَنِي عَمٍّ، أَحَدُهُمْ أَخٌ لِأُمٍّ، فَقَالَ : الْمَالُ أَجْمَعُ لِأَخِيهِ لِأُمِّه، فَأَنْزَلَهُ بِحِسَابِ، أَوْ بِمَنْزِلَةِ الْأَخِ مِنْ الْأَبِ وَالْأُمِّ، فَلَمَّا قَدِمَ عَلِيٌّ  ، سَأَلْتُهُ عَنْهَا، وَأَخْبَرْتُهُ بِقَوْلِ عَبْدِ اللَّهِ، فَقَالَ : "" يَرْحَمُهُ اللَّهُ، إِنْ كَانَ لَفَقِيهًا، أَمَّا أَنَافَلَمْ أَكُنْ لِأَزِيدَهُ عَلَى مَا فَرَضَ اللَّهُ لَهُ : سَهْمٌ السُّدُسُ، ثُمَّ يُقَاسِمُهُمْ كَرَجُلٍ مِنْهُمْ """,,takhreej: @منقطع: مکحول نے ابوثعلبہ کو نہیں پایا۔, 2147,"حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ  ، حَدَّثَنَا سُفْيَانُ  ، عَنْ أَبِي إِسْحَاق  ، عَنْ الْحَارِثِ  ، عَنْ عَلِي : أَنَّهُ أُتِيَ فِي ابْنَيْ عَمٍّ أَحَدُهُمَا أَخٌ لِأُمٍّ، فَقِيلَ لِعَلِيٍّ : إِنَّ ابْنَ مَسْعُودٍ كَانَ يُعْطِيهِ الْمَالَ كُلَّهُ، فَقَالَ عَلِيٌّ   رَضِيَ اللَّهُ عَنْهُ : إِنْ كَانَ لَفَقِيهًا، وَلَوْ كُنْتُ أَنَا"" أَعْطَيْتُهُ السُّدُسَ، وَمَا بَقِيَ كَانَ بَيْنَهُمْ """,,takhreej: !صحیح: ابوداود، کتاب الإجارۃ، باب فی ثمن الخمر والمیتۃ (3489), 2148,"حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ  ، حَدَّثَنَا سُفْيَانُ الثَّوْرِيُّ  ، عَنْ أَبِي قَيْسٍ الْأَوْدِيِّ  ، عَنْ هُزَيْلِ بْنِ شُرَحْبِيلَ  ، قَالَ : جَاءَ رَجُلٌ إِلَى أَبِي مُوسَى الْأَشْعَرِيِّ، وَإِلَى سَلْمَانَ بْنِ رَبِيعَةَ فَسَأَلَهُمَا عَنْ بِنْتٍ، وَبِنْتِ ابْنٍ، وَأُخْتٍ لِأُمٍّ وَأَبٍ، فَقَالَا : لِلِابْنَةِ النِّصْفُ، وَمَا بَقِيَ فَلِلْأُخْتِ، وَأْتِ ابْنَ مَسْعُودٍ فَإِنَّهُ سَيُتَابِعُنَا، فَجَاءَ الرَّجُلُ إِلَى عَبْدِ اللَّهِ  ، فَسَأَلَهُ عَنْ ذَلِكَ، فَقَالَ : لَقَدْ ضَلَلْتُ إِذًا، وَمَا أَنَا مِنْ الْمُهْتَدِينَ، وَإِنِّي أَقْضِي بِمَا "" قَضَى بِهِ رَسُولُ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ :لِلِابْنَةِ النِّصْفُ، وَلِابْنَةِ الِابْنِ السُّدُسُ، وَمَا بَقِيَ فَلِلْأُخْتِ """,,takhreej: @صحیح مسلم، کتاب المساۃ، باب تحریم بیع الخمر (4020) والنسائی، کتاب البیوع، باب بیع الخمر (4678), 2149,"أَخْبَرَنَا أَحْمَدُ بْنُ عَبْدِ اللَّهِ  ، حَدَّثَنَا أَبُو شِهَابٍ  ، عَنْ الْأَعْمَشِ  ، عَنْ مُسْلِمٍ  ، عَنْ مَسْرُوقٍ  ،  عَنْ عَبْدِ اللَّهِ   : أَنَّهُ كَانَ يَقُولُ فِي أَخَوَاتٍ لِأَبٍ وَأُمٍّ، وَإِخْوَةٍ وَأَخَوَاتٍ لِأَبٍ : قَالَ :"" لِلْأَخَوَاتِ لِلْأَبِ وَالْأُمِّ الثُّلُثَانِ، وَمَا بَقِيَ فَلِلذُّكُورِ دُونَ الْإِنَاثِ ""، فَقَدِمَ مَسْرُوقٌ الْمَدِينَةَ ، فَسَمِعَ قَوْلَ زَيْدٍ   فِيهَا فَأَعْجَبَهُ، فَقَالَ لَهُ بَعْضُ أَصْحَابِهِ : أَتَتْرُكُ قَوْلَ عَبْدِ اللَّهِ؟ قَالَ : إِنِّي أَتَيْتُ الْمَدِينَةَ فَوَجَدْتُ زَيْدَ بْنَ ثَابِتٍ مِنْ الرَّاسِخِينَ فِي الْعِلْمِ. قَالَ أَحْمَدُ : فَقُلْتُ لِأَبِي شِهَاب : وَكَيْفَ قَالَ زَيْدٌ فِيهَا؟ قَالَ : شَرَّكَ بَيْنَهُمْ",,takhreej: no data available, 2150,"حَدَّثَنَا سَعِيدُ بْنُ الْمُغِيرَةِ  ، عَنْ عِيسَى بْنِ يُونُسَ  ، عَنْ إِسْمَاعِيل  ، قَالَ : ذَكَرْنَا عِنْدَ حَكِيمِ بْنِ جَابِر : أَنَّ ابْنَ مَسْعُودٍ  قَالَ فِي أَخَوَاتٍ لِأَبٍ وَأُمٍّ وَإِخْوَةٍ وَأَخَوَاتٍ لِأَبٍ : أَنَّهُ كَانَ يُعْطِي لِلْأَخَوَاتِ مِنْ الْأَبِ وَالْأُمِّ الثُّلُثَيْنِ، وَمَا بَقِيَ فَلِلذُّكُورِ دُونَ الْإِنَاثِ، فَقَالَ حَكِيمٌ  : قَالَ زَيْدُ بْنُ ثَابِتٍ   :"" هَذَا مِنْ عَمَلِ الْجَاهِلِيَّةِ أَنْ يَرِثَ الرِّجَالُ دُونَ النِّسَاءِ إِنَّ إِخْوَتَهُنَّ قَدْ رُدُّوا عَلَيْهِنَّ """,,takhreej: !متفق علیہ: البخاری، کتاب البیوع، باب لایذاب شحم المیتۃ ولا یباع دکہ (2223) ومسلم، کتاب المساقاۃ، باب تحریم بیع الخمر والمیتۃ والخنزیر والأصنام (4026), 2151,"حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ  ، حَدَّثَنَا سُفْيَانُ  ، عَنْ مَعْبَدِ بْنِ خَالِدٍ  ، عَنْ مَسْرُوقٍ  ، عَنْ عَائِشَةَ   : "" أَنَّهَا كَانَتْتُشَرِّكُ بَيْنَ ابْنَتَيْنِ وَابْنَةِ ابْن، وَابْنِ ابْن : تُعْطِي الِابْنَتَيْنِ الثُّلُثَيْنِ، وَمَا بَقِيَ فَشَرِيكُهُمْ",,takhreej: @صحیح: ابوداؤد، کتاب الحدود، باب اذا تتابع فی شرب الخمر (4484) والنسائی، کتاب الأشربۃ، باب ذکر الروایات المغلظات فی شرب الخمر (5678), 2152,"وَكَانَ عَبْدُ اللَّهِ   لَا يُشَرِّكُ، يُعْطِي الذُّكُورَ دُونَ الْإِنَاثِ، وَقَالَ :"" الْأَخَوَاتُ بِمَنْزِلَةِ الْبَنَاتِ """,,takhreej: !متفق علیہ: البخاری، کتاب المحابین، باب اثم الزناۃ (4886) ومسلم، کتاب الإیمان، باب بیان نقصان الإیمان بالمعاصی ونفیہٖ عن المتلبس بالمعصیۃ (205), 2153,"أَخْبَرَنَا مُحَمَّدُ بْنُ يُوسُفَ  ، حَدَّثَنَا سُفْيَانُ  ، عَنْ أَبِي سَهْلٍ  ، عَنْ الشَّعْبِيِّ  : أَنَّ ابْنَ مَسْعُودٍ   كَانَ يَقُولُ فِي بِنْتٍ وَبَنَاتِ ابْنٍ، وَابْنِ ابْنٍ :"" إِنْ كَانَتِ الْمُقَاسَمَةُ بَيْنَهُمْ أَقَلَّ مِنْ السُّدُسِ، أَعْطَاهُمْ السُّدُسَ، وَإِنْ كَانَ أَكْثَرَ مِنَ السُّدُس، ِأَعْطَاهُمُ السُّدُسَ """,,takhreej: @صحیح مسلم، کتاب الاشربۃ، باب بیان النھی عن الانتباذ فی المزفت … (5173) وابوداؤد، کتاب الأشربۃ، باب فی الأوعیۃ (3702), 2154,"حَدَّثَنَا مُحَمَّدٌ  ، حَدَّثَنَا سُفْيَانُ  ، عَنْ الْأَعْمَشِ  ، عَنْ إِبْرَاهِيمَ  ، عَنْ مَسْرُوقٍ  : أَنَّهُ كَانَ يُشَرِّكُ فَقَالَ لَهُ عَلْقَمَةُ : هَلْ أَحَدٌ مِنْهُمْ أَثْبَتُ مِنْ عَبْدِ اللَّهِ؟ فَقَالَ : لَا، وَلَكِنِّي رَأَيْتُ زَيْدَ بْنَ ثَابِتٍ  ، وَأَهْلَ الْمَدِينَةِ"" يُشَرِّكُونَ فِي ابْنَتَيْنِ وَبِنْتِ ابْن، ٍوَابْنِ ابْن، وَأُخْتَيْنِ """,,takhreej: !صحیح بالشاھد: ابوداؤد، کتاب الأشربۃ، باب صفۃ النبیذ (3710) والنسائی، کتاب الأشربۃ، باب ذکر مایجوز شربہ من الأنبذۃ ومالایجوز (5752) واحمد 4/332, 2155,"حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ ، حَدَّثَنَا سُفْيَانُ ، عَنْ هِشَامٍ ، عَنْ مُحَمَّدِ بْنِ سِيرِينَ ، عَنْ شُرَيْحٍ  : "" فِي امْرَأَةٍ تَرَكَتْ زَوْجَهَا، وَأُمَّهَا، وَأُخْتَهَا لِأَبِيهَا وَأُمِّهَا، وَأُخْتَهَا لِأَبِيهَا، وَإِخْوَتَهَا لِأُمِّهَا،جَعَلَهَا مِنْ سِتَّةٍ، ثُمَّ رَفَعَهَا فَبَلَغَتْ عَشْرَةً، لِلزَّوْجِ النِّصْفُ ثَلَاثَةُ أَسْهُمٍ، وَلِلْأُخْتِ مِنْ الْأَبِ وَالْأُمِّ النِّصْفُ ثَلَاثَةُ أَسْهُمٍ، وَلِلْأُمِّ السُّدُسُ سَهْمٌ، وَلِلْإِخْوَةِ مِنْ الْأُمِّ الثُّلُثُ سَهْمَانِ، وَلِلْأُخْتِ مِنْ الْأَبِ سَهْمٌ تَكْمِلَةُ الثُّلُثَيْنِ """,,takhreej: !صحیح مسلم، کتاب الأشربۃ، باب النھی عن الإنتباذ فی المزفت والد باء والحنتم (5156) وابوداؤد، کتاب الأشربۃ، باب فی الاوعیۃ (3691), 2156,"حَدَّثَنَا مُحَمَّدُ بْنُ عُيَيْنَةَ  ، عَنْ عَلِيِّ بْنِ مُسْهِرٍ  ، عَنْ أَشْعَثَ  ، عَنْ الشَّعْبِيِّ  : أَنَّ عَلِيًّا  ، وَزَيْدًا   كَانَا"" لَا يَحْجُبَانِ بِالْكُفَّار، وَلا بِالْمَمْلُوكِينَ، وَلَا يُوَرِّثَانِهِمْ شَيْئًا """,,takhreej: @صحیح البخاری، کتاب الأشربۃ، باب الخمر من العسل (5587) ومسلم، کتاب الأشربۃ، باب النھی عن الانتباذ فی المزفت (1992), 2157,"وَكَانَ عَبْدُ اللَّهِ  "" يَحْجُبُ بِالْكُفَّارِ وَبِالْمَمْلُوكِينَ، وَلَا يُوَرِّثُهُمْ """,,takhreej: !صحیح: احمد، 1/229، والطبرانی، فی الکبیر 12/152۔ 153 (12738), 2158,"حَدَّثَنَا سُلَيْمَانُ بْنُ حَرْبٍ  ، حَدَّثَنَا شُعْبَةُ  ، عَنْ الْحَكَمِ  ، عَنْ إِبْرَاهِيمَ  : أَنَّ عَلِيًّا  ، وَزَيْدًا  ، قَالَا :"" الْمَمْلُوكُونَ، وَأَهْلُ الْكِتَابِ لا يَحْجُبُونَ وَلا يَرِثُونَ",,takhreej: @صحیح :احمد 5/57، والطبرانی فی الاوسط (5276), 2159,"وَقَالَ عَبْدُ اللَّهِ   :"" يَحْجُبُونَ وَلَا يَرِثُونَ """,,takhreej: !متفق علیہ : البخاری، کتاب الاشربۃ، باب من رأی أن لایخلط البسر والتمر اذا کان … (5602) ومسلم، کتاب الأشربۃ، باب تحریم التداوی بالخمر (5215), 2160,"أَخْبَرَنَا يَزِيدُ بْنُ هَارُونَ  ، أَخْبَرَنَا يَحْيَى  ، عَنْ سَعِيدٍ  : أَنَّ عُمَرَ   "" كَانَكَتَبَ مِيرَاثَ الْجَدِّ، حَتَّى إِذَا طُعِنَ دَعَا بِهِ فَمَحَاهُ، ثُمّ قَالَ : سَتَرَوْنَ رَأْيَكُمْ فِيهِ """,,takhreej: @صحیح مسلم، کتاب الألفاظ، باب کراھۃ تسمیۃ العنب کرما (5833), 2161,"أَخْبَرَنَا يَزِيدُ ، أنبأنا أَشْعَثُ ، عَنْ ابْنِ سِيرِينَ ، قَالَ : قُلْتُ لِعَبِيدَةَ  : حَدِّثْنِي عَنِ الْجَدِّ، فَقَالَ :"" إِنِّي لَأَحْفَظُ فِي الْجَدِّ ثَمَانِينَ قَضِيَّةً مُخْتَلِفَةً """,,takhreej: !متفق علیہ :البخاری، کتاب البیوع، باب ما قیل فی الصواغ (2089) ومسلم، کتاب النکاح، باب تحریم الخمر وبیان أنھا تکون (5102), 2162,"أَخْبَرَنَا أَبُو غَسَّانَ  ، حَدَّثَنَا إِسْرَائِيلُ  ، عَنْ أَبِي إِسْحَاق  ، عَنْ عُبَيْدِ بْنِ عَمْرٍو  ، عَنْ عَلِيٍّ  ، قَالَ : أَتَاهُ رَجُلٌ فَسَأَلَهُ عَنْ فَرِيضَة، فَقَالَ :"" إِنْ لَمْ يَكُنْ فِيهَا جَدٌّ، فَهَاتِهَا """,,takhreej: !متفق علیہ :البخاری، کتاب الأشربۃ، باب الأیمن فالأیمن فی الشرب (5619) ومسلم، کتاب الأشربۃ، باب استحباب ادارۃ الماء اواللبن (5257), 2163,"حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ  ، حَدَّثَنَا سُفْيَانُ  ، عَنْ أَبِي إِسْحَاق  ، عَنْ عُبَيْدِ بْنِ عَمْرٍو  قَالَ : جَاءَ رَجُلٌ إِلَى عَلِيٍّ   فَسَأَلَهُ عَنْ فَرِيضَةٍ، فَقَالَ :"" إِنْ لَمْ يَكُنْ فِيهَا جَدٌّ، فَهَاتِهَا """,,takhreej: @صحیح البخاری، کتاب الاشر بۃ، باب الشرب من خم السقاء (5629) وابوداؤد، کتاب الأشربۃ، باب فی الشراب من فی السقاء (3719), 2164,"حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ  ، حَدَّثَنَا سُفْيَانُ  ، عَنْ أَيُّوبَ السَّخْتِيَانِيِّ  ، عَنْ سَعِيدِ بْنِ جُبَيْرٍ  ، عَنْ رَجُلٍ  مِنْ مُرَادٍ ، ٍسَمِعَ عَلِيًّا  ، يَقُولُ :"" مَنْ سَرَّهُ أَنْ يَتَقَحَّمَ جَرَاثِيمَ جَهَنَّمَ، فَلْيَقْضِ بَيْنَ الْجَدِّ وَالْإِخْوَةِ",,takhreej: #صحیح البخاری، کتاب الأشربۃ، باب الشرب من قم السقاء (5628), 2165,"أَخْبَرَنَا مُسْلِمُ بْنُ إِبْرَاهِيمَ  ، حَدَّثَنَا وُهَيْبٌ  ، حَدَّثَنَا خَالِدٌ  ، عَنْ أَبِي نَضْرَةَ  ، عَنْ أَبِي سَعِيدٍ الْخُدْرِيِّ  . ح وَعَنْ عِكْرِمَةَ  : أَنَّ أَبَا بَكْرٍ الصِّدِّيقَ  "" جَعَلَ الْجَدَّ أَبًا "". حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ  ، حَدَّثَنَا سُفْيَانُ  ، عَنْ سُلَيْمَانَ الشَّيْبَانِيِّ  ، عَنْ كُرْدُوسٍ  ، عَن أبِى بُرْدَةَ  ، عَنْ أَبِي مُوسَى  : أنَّ أَبَا بَكْرٍ الصِّدِّيقِ   جَعَلَ الْجَدَّ أَبًا",,takhreej: $صحیح البخاری، کتاب الأشربۃ، باب اختناث الأسقیۃ (5625) و مسلم، کتاب الأشربۃ، باب آداب الطعام والشراب وأحکامھا (5239), 2166,"حَدَّثَنَا أَحْمَدُ بْنُ عَبْدِ اللَّهِ  ، حَدَّثَنَا أَبُو شِهَابٍ  ، عَنْ الشَّيْبَانِيِّ  ، عَنْ أَبِي بُرْدَةَ بْنِ أَبِي مُوسَى  ، عَنْ كُرْدُوسٍ  ، عَنْ أَبِي مُوسَى  ، أَنَّ أَبَا بَكْرٍ  "" جَعَلَ الْجَدَّ أَبًا """,,takhreej: !صحیح البخاری، کتاب الأشربۃ، باب الشرب بنفسین أو ثلاثۃ (5631) ومسلم، کتاب الاشربۃ، باب کراھۃ التفنس فی نفس الإناء (5254), 2167,"أَخْبَرَنَا الْأَسْوَدُ بْنُ عَامِرٍ  ، حَدَّثَنَا شُعْبَةُ  ، عَنْ عَمْرِو بْنِ مُرَّةَ  ، عَنْ أَبِي بُرْدَةَ  ، عَنْ مَرْوَانَ  ، عَنْ عُثْمَانَ  : أَنَّ أَبَا بَكْرٍ   كَانَ"" يَجْعَلُ الْجَدَّ أَبًا """,,takhreej: @صحیح : احمد 3/57، والترمذی، کتاب الأشربۃ، باب ماجاء فی کراھیۃ النفخ فی الشراب (1887), 2168,"حَدَّثَنَا عُبَيْدُ اللَّهِ  ، وَمُحَمَّدُ بْنُ يُوسُفَ  ، عَنْ إِسْرَائِيلَ  ، عَنْ أَبِي إِسْحَاق  ، عَنْ عُثْمَانَ  : أَنَّ أَبَا بَكْرٍ   كَانَ"" يَجْعَلُ الْجِدَّ أَبًا """,,takhreej: !متفق علیہ :البخاری، کتاب الوضوئ، باب النھی عن الاستنجاء بالیمین (153) ومسلم، کتاب الطھارۃ، باب النھی عن الاستنجاء بالیمین (612), 2169,"أَخْبَرَنَا الْأَسْوَدُ بْنُ عَامِرٍ  ، حَدَّثَنَا شُعْبَةُ  ، عَنْ عَمْرِو بْنِ مُرَّةَ  ، عَنْ أَبِي بُرْدَةَ  ، قَالَ : لَقِيتُ مَرْوَانَ بْنَ الْحَكَمِ بِالْمَدِينَةِ ، فَقَالَ : يَا ابْنَ أَبِي مُوسَى، أَلَمْ أُخْبَرْ أَنَّ الْجَدَّ لَا يُنَزَّلُ فِيكُمْ مَنْزِلَةَ الْأَبِ، وَأَنْتَ لَا تُنْكِرُ؟ قَالَ : قُلْتُ : وَلَوْ كُنْتَ أَنْتَ لَمْ تُنْكِرْ، قَالَ مَرْوَانُ  : فَأَنَا أَشْهَدُ عَلَى عُثْمَانَ بْنِ عَفَّانَ  أَنَّهُ شَهِدَ عَلَى أَبِي بَكْرٍ   أَنَّهُ"" جَعَلَ الْجَدَّ أَبًا، إِذَا لَمْ يَكُنْ دُونَهُ أَبٌ """,,takhreej: @صحیح البخاری، کتاب الأشربۃ، باب شرب اللبن بالماء (5613), 2170,"حَدَّثَنَا الْأَسْوَدُ بْنُ عَامِرٍ  ، أَنْبَأَنَا شُعْبَةُ  ، عَنْ خَالِدٍ الْحَذَّاءِ  ، عَنْ أَبِي نَضْرَةَ  ، وَعَنْ عِكْرِمَةَ  ، عَنْ ابْنِ عَبَّاسٍ  : أَنَّ أَبَا بَكْرٍ   كَانَ"" يَجْعَلُ الْجَدَّ أَبًا """,,takhreej: !حسن : احمد، 6/376، والترمذی فی الشمائل (215), 2171,"حَدَّثَنَا مُسْلِمُ بْنُ إِبْرَاهِيمَ  ، حَدَّثَنَا وُهَيْبٌ  ، حَدَّثَنَا أَيُّوبُ  ، عَنْ عِكْرِمَةَ  ، عَنْ ابْنِ عَبَّاسٍ  ، قَالَ : جَعَلَهُ الَّذِي قَالَ رَسُولُ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ :"" لَوْ كُنْتُ مُتَّخِذًا أَحَدًا خَلِيلًا، لَاتَّخَذْتُهُ خَلِيلًا، وَلَكِنْ أُخُوَّةُ الْإِسْلَامِ أَفْضَلُ، يَعْنِي أَبَا بَكْرٍ   جَعَلَهُ أَبًا، يَعْنِي : الْجَدَّ """,,takhreej: @صحیح : ابن ابی شیبہ 8/205 (4167) نیز آئندہ سند دیکھئے, 2172,"حَدَّثَنَا مُسْلِمٌ  ، حَدَّثَنَا وُهَيْبٌ  ، حَدَّثَنَا أَيُّوبُ  ، عَنْ ابْنِ أَبِي مُلَيْكَةَ  ، عَنْ ابْنِ الزُّبَيْر  : أَنَّ أَبَا بَكْرٍ  "" جَعَلَ الْجَدَّ أَبًا """,,takhreej: #صحیح : سابقہ دیکھئے۔, 2173,"حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ  ، أَنْبَأَنَا الْأَشْعَثُ  ، عَنْ الْحَسَنِ  ، قَالَ : إِنَّ الْجَدَّ قَدْ مَضَتْ سُنَّتُهُ، وَإِنَّ أَبَا بَكْرٍ  "" جَعَلَ الْجَدَّ أَبًا ""، وَلَكِنَّ النَّاسَ تَحَيَّرُوا",,takhreej: !صحیح مسلم، کتاب الأشربۃ، باب کراھیۃ الشرب قائما (5243) والترمذی کتاب الأشربۃ، باب ماجاء فی النھی عن الشرب قائماً (3424), 2174,"أَخْبَرَنَا مُحَمَّدُ بْنُ عُيَيْنَةَ ، عَنْ عَلِيِّ بْنِ مُسْهِرٍ ، عَنْ عَاصِمٍ ،  عَنْ الشَّعْبِيِّ ، قَالَ :"" إِنَّ أَوَّلَ جَدٍّ وَرِثَ فِي الْإِسْلَامِ عُمَرُ",,takhreej: @متفق علیہ : البخاری، کتاب الأشربۃ، باب اٰنیۃ الفضۃ (5634) مسلم، کتاب اللباس والزینۃ، باب تحریم استعمال أوانی الذھب … (5353), 2175,"حَدَّثَنَا أَبُو نُعَيْمٍ  ، حَدَّثَنَا حَسَنٌ  ، عَنْ عَاصِمٍ  ، عَنْ الشَّعْبِيِّ  ، قَالَ :"" أَوَّلُ جَدٍّ وَرِثَ فِي الْإِسْلَامِ عُمَر، فَأَخَذَ مَالَهُ، فَأَتَاهُ عَلِيٌّ  ، وَزَيْدٌ  ، فَقَالَا : لَيْسَ لَكَ ذَاكَ، إِنَّمَا أَنْتَ كَأَحَدِ الْأَخَوَيْنِ """,,takhreej: !متفق علیہ : البخاری، کتاب الأطعمۃ، باب الأکل فی إناء مفضض (5426) ومسلم، کتاب اللباس، والزینۃ، باب تحریم، استعمال إناء الذھب … (5361), 2176,"حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ مُوسَى  ، عَنْ عِيسَى الْخياط  ، عَنْ الشَّعْبِيِّ  ، قَالَ : كَانَ عُمَرُ  "" يُقَاسِمُ بِالْجَدِّ مَعَ الْأَخِ وَالْأَخَوَيْنِ، فَإِذَا زَادُوا أَعْطَاهُ الثُّلُثَ، وَكَانَ يُعْطِيهِ مَعَ الْوَلَدِ السُّدُسَ",,takhreej: @متفق علیہ : البخاری، کتاب الأطعمۃ، باب الأکل فی إناء مفضض (5426) ومسلم، کتاب اللباس، والزینۃ، باب تحریم استعمال إناء الذھب والفضۃ (5361), 2177,"حَدَّثَنَا مُسْلِمُ بْنُ إِبْرَاهِيمَ  ، حَدَّثَنَا وُهَيْبٌ  ، حَدَّثَنَا هِشَامُ بْنُ عُرْوَةَ  ، عَنْ أَبِيهِ  ، عَنْ مَرْوَانَ بْنِ الْحَكَمِ  : أَنَّ عُمَرَ بْنَ الْخَطَّابِ   لَمَّا طُعِنَ، اسْتَشَارَهُمْ فِي الْجَدِّ، فَقَالَ :"" إِنِّي كُنْتُ رَأَيْتُ فِي الْجَدِّ رَأْيًا، فَإِنْ رَأَيْتُمْ أَنْ تَتَّبِعُوهُ، فَاتَّبِعُوهُ، فَقَالَ لَهُ عُثْمَانُ   : إِنْ نَتَّبِعْ رَأْيَكَ فَإِنَّهُ رَشَدٌ، وَإِنْ نَتَّبِعْ رَأْيَ الشَّيْخِ، فَنِعْمَ ذُو الرَّأْيِ كَانَ",,takhreej: !صحیح مسلم، کتاب الأشربۃ، باب جواز شرب الخمر (5210), 2178,"أَخْبَرَنَا مُحَمَّدُ بْنُ عُيَيْنَةَ  ، عَنْ عَلِيِّ بْنِ مُسْهِرٍ  ، عَنْ الشَّيْبَانِيِّ  ، عَنْ الشَّعْبِيِّ  ، قَالَ : كَتَبَ ابْنُ عَبَّاسٍ إِلَى عَلِيّ وَابْنُ عَبَّاسٍ بِالْبَصْرَةِ : إِنِّي أُتِيتُ بِجَدٍّ وَسِتَّةِ إِخْوَةٍ، فَكَتَبَ إِلَيْهِ عَلِيٌّ   :"" أَنْ أَعْطِ الْجَدَّ سُدسا، وَلَا تُعْطِهِ أَحَدًا بَعْدَهُ",,takhreej: @صحیح : ابن ماجہ، کتاب الأشربۃ، باب تخمیر الاناء (3411), 2179,"حَدَّثَنَا أَبُو نُعَيْمٍ ، حَدَّثَنَا حَسَنٌ ، عَنْ إِسْمَاعِيل ، عَنْ الشَّعْبِيِّ  فِي سِتَّةِ إِخْوَةٍ وَجَدٍّ، قَالَ :"" أَعْطِ الْجَدَّ السُّدُسَ. قَالَ أَبُو مُحَمَّد : كَأَنَّهُ يَعْنِي : عَلِيًّا رِضْوَانُ اللَّهِ عَلَيْهِ الشَّعْبِيُّ يَرْوِيهِ عَنْ عَلِيٍّ رِضْوَانُ اللَّهِ عَلَيْهِ",,takhreej: #صحیح : دیکھئے گزشتہ (2167), 2180,"حَدَّثَنَا سُلَيْمَانُ بْنُ حَرْبٍ  ، حَدَّثَنَا شُعْبَةُ  ، عَنْ عَمْرِو بْنِ مُرَّةَ  ، عَنْ عَبْدِ اللَّهِ بْنِ سَلَمَةَ  : أَنَّ عَلِيًّا   كَانَ"" يَجْعَلُ الْجَدَّ أَخًا مَتَى يَكُونَ سَادِسًا",,takhreej: !صحیح : ابوداؤد، کتاب الأشربۃ، باب فی التفخ فی الشراب (3728) والترمذی، کتاب الأشربۃ، باب ماجاء فی کراھیۃ النفخ فی الشراب (1888), 2181,"أَخْبَرَنَا أَبُو النُّعْمَانِ  ، حَدَّثَنَا وُهَيْبٌ  ، حَدَّثَنَا يُونُسُ  ، عَنْ الْحَسَنِ  : أَنَّ عَلِيًّا   كَانَ"" يُشَرِّكُ الْجَدَّ مَعَ الْإِخْوَةِ إِلَى السُّدُسِ",,takhreej: @صحیح مسلم، کتاب المساجد، باب قضاء الصلاۃ، الفائتۃ واستحباب تعجیلھا (681) وابن ماجہ، کتاب الأشربۃ، باب ساقی القوم آخرھم شربا (3434), 2182,"حَدَّثَنَا هَاشِمُ بْنُ الْقَاسِمِ  ، حَدَّثَنَا شُعْبَةُ  ، عَنْ عَمْرِو بْنِ مُرَّةَ  ، عَنْ عَبْدِ اللَّهِ بْنِ سَلَمَةَ  ، قَالَ : كَانَ عَلِيٌّ  "" يُشَرِّكُ بَيْنَ الْجَدِّ وَالْإِخْوَةِ حَتَّى يَكُونَ سَادِسًا",,takhreej: !صحیح : احمد، 5/315، والترمذی، کتاب الرؤیا، باب قولہ (لھم البشری فی الحیاۃ الدنیا), 2183,"حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ  ، حَدَّثَنَا سُفْيَانُ  ، عَنْ الْأَعْمَشِ  ، عَنْ إِبْرَاهِيمَ  ، قَالَ : كَانَ عَلِيٌّ  "" يُشَرِّكُ الْجَدَّ إِلَى سِتَّةٍ مَعَ الْإِخْوَةِ، يُعْطِي كُلَّ صَاحِبِ فَرِيضَةٍ فَرِيضَتَهُ، وَلَا يُوَرِّثُ أَخًا لِأُمٍّ مَعَ جَدٍّ، وَلَا أُخْتًا لِأُمٍّ، وَلَا يَزِيدُ الْجَدَّ مَعَ الْوَلَدِ عَلَى السُّدُسِ، إِلَّا أَنْ يَكُونَ غَيْرُهُ، وَلَا يُقَاسِمُ بِأَخٍ لِأَبٍ مَعَ أَخٍ لِأَبٍ وَأُمٍّ، وَإِذَا كَانَتْ أُخْتٌ لِأَبٍ وَأُمٍّ، وَأَخٌ لِأَبٍ، أَعْطَى الْأُخْتَ النِّصْفَ، وَالنِّصْفَ الْآخَرَ بَيْنَ الْجَدِّ وَالْأَخِ نِصْفَيْنِ، وَإِذَا كَانُوا إِخْوَةً وَأَخَوَاتٍ، شَرَّكَهُمْ مَعَ الْجَدِّ إِلَى السُّدُسِ",,takhreej: !متفق علیہ: البخاری، کتاب التفسیر، باب الرؤیا الصالحۃ جزء من ستۃ واربعین جزئً ا من النبوۃ (6988) ومسلم، کتاب الرؤیا باب کون الرؤیا من اللّٰہ وأنھا جزء من النبوۃ, 2184,"حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ  ، عَنْ سُفْيَانَ  ، عَنْ الْعَبْسِيِّ هُوَ عَبْدُ اللَّهِ بْنُ خَالِدٍ  ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ مَعْقِلٍ  ، قَالَ : سُئِلَ ابْنُ عَبَّاسٍ   عَنْ الْجَد؟ فَقَالَ :"" أَيُّ أَبٍ لَكَ أَكْبَر؟ فَقُلْتُ أَنَا : آدَمُ ، قَالَ : أَلَمْ تَسْمَعْ إِلَى قَوْلِ اللَّهِ تَعَالَى : # يَا بَنِي آدَمَ سورة الأعراف آية 26 #",,takhreej: ! صحیح: ابن ماجہ، کتاب تعبیر الرؤیا، باب الرؤیا الصالحہ یراھا المسلم أو تری لہ (3496), 2185,"أَخْبَرَنَا مُحَمَّدُ بْنُ يُوسُفَ  ، حَدَّثَنَا سُفْيَانُ  ، عَنْ إِسْمَاعِيل بْنِ سُمَيْعٍ  ، عَنْ رَجُلٍ  ، عَنْ ابْنِ عَبَّاسٍ  ، قَالَ :"" لَوَدِدْتُ أَنِّي وَالَّذِينَ يُخَالِفُونِي فِي الْجَدِّ تَلَاعَنَّا، أَيُّنَا أَسْوَأُ قَوْلًا",,takhreej: @صحیح: الترمذی، کتاب الرؤیا، باب ماجاء فی قول النبی من رأنی فی المنام فقد رأنی) (2279) وابن ماجہ، کتاب تعبیر الرؤیا، باب رؤیۃ النبی ﷺ (3900), 2186,"حَدَّثَنَا مُسْلِمُ بْنُ إِبْرَاهِيمَ  ، حَدَّثَنَا وُهَيْبٌ  ، حَدَّثَنَا ابْنُ طَاوُسٍ  ، عَنْ أَبِيهِ  ، عَنْ ابْنِ عَبَّاسٍ   : أَنَّهُ"" جَعَلَ الْجَدَّ أَبًا """,,takhreej: !متفق علیہ: البخاری، کتاب التعبیر، باب من رأی النبی فی المنام (6996) ومسلم، کتاب الرؤیا، باب قول النبی ﷺ (5880), 2187,"أَخْبَرَنَا أَبُو نُعَيْمٍ  ، حَدَّثَنَا زُهَيْرٌ  ، عَنْ أَبِي إِسْحَاق  قَالَ : دَخَلْتُ عَلَى شُرَيْحٍ وَعِنْدَهُ عَامِرٌ، وَإِبْرَاهِيمُ، وَعَبْدُ الرَّحْمَنِ بْنُ عَبْدِ اللَّهِ فِي فَرِيضَةِ امْرَأَةٍ مِنَّا : الْعَالِيَةِ ، تَرَكَتْ زَوْجَهَا، وَأُمَّهَا، وَأَخَاهَا لِأَبِيهَا، وَجَدَّهَا، فَقَالَ لِي : هَلْ مِنْ أُخْتٍ؟ قُلْتُ : لَا، قَالَ : لِلْبَعْلِ الشَّطْرُ وَلِلْأُمِّ الثُّلُثُ، قَالَ : فَجَهِدْتُ عَلَى أَنْ يُجِيبَنِي، فَلَمْ يُجِبْنِي إِلَّا بِذَلِكَ، فَقَالَ إِبْرَاهِيمُ، وَعَامِرٌ، وَعَبْدُ الرَّحْمَنِ بْنُ عَبْدِ اللَّهِ : مَا جَاءَ أَحَدٌ بِفَرِيضَةٍ أَعْضَلَ مِنْ فَرِيضَةٍ جِئْتَ بِهَا، قَالَ : فَأَتَيْتُ عَبِيدَةَ السَّلْمَانِيَّ وَكَانَ يُقَال : لَيْسَ بِالْكُوفَةِ أَحَدٌ أَعْلَمَ بِفَرِيضَةٍ مِنْ عَبِيدَةَ، وَالْحَارِثِ الْأَعْوَرَ، وَكَانَ عَبِيدَةُ يَجْلِسُ فِي الْمَسْجِدِ، فَإِذَا وَرَدَتْ عَلَى شُرَيْحٍ فَرِيضَةٌ فِيهَا جَدٌّ، رَفَعَهُمْ إِلَى عَبِيدَةَ، فَفَرَضَ فَسَأَلْتُهُ، فَقَالَ : إِنْ شِئْتُمْ نَبَّأْتُكُمْ بِفَرِيضَةِ عَبْدِ اللَّهِ بْنِ مَسْعُودٍ   فِي هَذَا :"" جَعَلَ لِلزَّوْجِ ثَلَاثَةَ أَسْهُمٍ النِّصْفَ، وَلِلْأُمِّ ثُلُثُ مَا بَقِيَ، وَهُوَ السُّدُسُ مِنْ رَأْسِ الْمَالِ، وَلِلْأَخِ سَهْمٌ، وَلِلْجَدِّ سَهْمٌ، قَالَ أَبُو إِسْحَاقَ : الْجَدُّ أَبُو الْأَبِ",,takhreej: @متفق علیہ: البخاری، کتاب الطب، باب النفث فی الرقیۃ (5747) ومسلم، کتاب الرؤیا، باب فی کون الرؤیا من اللّٰہ (5863), 2188,"أَخْبَرَنَا أَبُو النُّعْمَانِ  ، حَدَّثَنَا وُهَيْبٌ  ، حَدَّثَنَا يُونُسُ  ، عَنْ الْحَسَنِ  : أَنَّ زَيْدًا   كَانَ"" يُشَرِّكُ الْجَدَّ مَعَ الْإِخْوَةِ إِلَى الثُّلُثِ """,,takhreej: !صحیح: سابقہ تخریج ملاحظہ کیجئے۔, 2189,"حَدَّثَنَا عُمَرُ بْنُ حَفْصِ بْنِ غِيَاثٍ  ، حَدَّثَنَا أَبِي  ، حَدَّثَنَا الْأَعْمَشُ  ، عَنْ إِبْرَاهِيمَ  ، عَنْ زَيْدِ بْنِ ثَابِتٍ   : أَنَّهُ كَانَ"" يُقَاسِمُ بِالْجَدِّ مَعَ الْإِخْوَةِ إِلَى الثُّلُثِ، ثُمَّ لَا يُنْقِصُهُ """,,takhreej: !متفق علیہ: البخاری، کتاب التعبیر، باب القید فی المنام (7017) ومسلم، کتاب الرؤیا، باب فی کون الرؤیا من اللّٰہ (5865), 2190,"حَدَّثَنَا سَعِيدُ بْنُ الْمُغِيرَةِ  ، عَنْ عِيسَى بْنِ يُونُسَ  ، عَنْ إِسْمَاعِيل  ، قَالَ : قَالَ عَامِرٌ   :"" خُذْ مِنْ أَمْرِ الْجَدِّ مَا اجْتَمَعَ النَّاسُ عَلَيْهِ، قَالَ أَبُو مُحَمَّدٍ : يَعْنِي قَوْلَ زَيْدٍ",,takhreej: @صحیح: سابقہ حدیث کی ایک طرف ہے۔, 2191,"أَخْبَرَنَا سَعِيدُ بْنُ عَامِرٍ  ، عَنْ هَمَّامٍ  ، عَنْ قَتَادَةَ  : أَنَّ زَيْدَ بْنَ ثَابِتٍ   قَالَ فِي أُخْتٍ، وَأُمٍّ، ٍّوَزَوْجٍ، وَجَدٍّ، قَالَ :"" جَعَلَهَا مِنْ سَبْعٍ وَعِشْرِينَ : لِلْأُمِّ سِتَّةٌ، وَلِلزَّوْجِ تِسْعَةٌ، وَلِلْجَدِّ ثَمَانِيَةٌ، وَلِلْأُخْتِ أَرْبَعَةٌ",,takhreej: #صحیح بالشواھد: تاریخ بغداد للخطیب 11/93 الترمذی، کتاب الرؤیا، باب فی الذی یکذب فی حلمہ (2281), 2192,"أَخْبَرَنَا يَزِيدُ بْنُ هَارُونَ  ، حَدَّثَنَا الْأَشْعَثُ  ، عَنْ ابْنِ سِيرِينَ  ، عَنْ ابْنِ مَسْعُودٍ  ، قَالَ :"" إِنَّ أَوَّلَ جَدَّةٍ أُطْعِمَتْ فِي الْإِسْلَامِ سَهْمًا أَمُّ أَبٍ، وَابْنُهَا حَيٌّ",,takhreej: !ضعیف: الترمذی، کتاب الرؤیا، باب (بھم البشری فی الحیاۃ الدنیا), 2193,"حَدَّثَنَا أَبُو نُعَيْمٍ  ، حَدَّثَنَا شَرِيكٌ  ، عَنْ لَيْثٍ  ، عَنْ طَاوُسٍ  ، عَنْ ابْنِ عَبَّاسٍ   : "" أَنَّ النَّبِيَّ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَأَطْعَمَ جَدَّةً سُدُسًا """,,takhreej: @صحیح : الترمذی، کتاب الرؤیاء باب فی تأویل مایستحب منھا ومایکرہ (2280), 2194,"حَدَّثَنَا أَبُو نُعَيْمٍ  ، حَدَّثَنَا سُفْيَانُ  ، عَنْ ابْنِ جُرَيْجٍ  ، عَنْ إِبْرَاهِيمَ بْنِ مَيْسَرَةَ  ، عَنْ سَعِيدِ بْنِ الْمُسَيِّبِ  : أَنَّ عُمَرَ  "" وَرَّثَ جَدَّةً مَعَ ابْنِهَا """,,takhreej: !صحیح : ابوداؤد، کتاب الأدب، باب ماجاء فی الرؤیاء (5020) والترمذی، کتاب الرؤیا باب اذا رأی فی المنام مایکرہ (2278), 2195,"حَدَّثَنَا حَجَّاجُ بْنُ مِنْهَالٍ  ، حَدَّثَنَا شُعْبَةُ  ، أَخْبَرَنِي مَنْصُورُ بْنُ الْمُعْتَمِرِ  ، قَالَ : سَمِعْتُ إِبْرَاهِيمَ  ، قَالَ :"" أَطْعَمَ رَسُولُ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ ثَلَاثَ جَدَّاتٍ سُدُسًا. قَالَ : قُلْتُ لِإِبْرَاهِيمَ : مَنْ هُنَّهْ؟ قَالَ : جَدَّتَاكَ مِنْ قِبَلِ أَبِيكَ، وَجَدَّتُكَ مِنْ قِبَلِ أُمِّكَ """,,takhreej: !حسن بالشواھد: السنۃ لابن ابی عاصم (465) واحمد 243/5، والترمذی، کتاب التفسیر، باب ومن سورۃ (ص) 3233, 2196,"حَدَّثَنَا حَجَّاجُ بْنُ مِنْهَالٍ  ، حَدَّثَنَا يَزِيدُ بْنُ إِبْرَاهِيمَ  ، قَالَ : أَنْبَأَنِي الْحَسَنُ  ، قَالَ :"" تَرِثُ الْجِدَّةُ وَابْنُهَا حَيٌّ """,,takhreej: !ضعیف: الکامل لابن عدی (2622/7), 2197,"حَدَّثَنَا سُلَيْمَانُ بْنُ حَرْبٍ ، حَدَّثَنَا حَمَّادُ بْنُ سَلَمَةَ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِيِّ ، قَالَ :"" لَا تَرِثُ أُمُّ أَبِ الْأُمِّ، ابْنُهَا الَّذِي تُدْلِي بِهِ لَا يَرِثُ، فَكَيْفَ تَرِثُ هِيَ؟ """,,takhreej: !متفق علیہ: البخاری، کتاب الإیمان والشرائعہ، باب تفاضل أھل الإیمان فی الأعمال (23) ومسلم، کتاب فضائل الصحابہ، باب مناقب عمرؓ بن خطاب ابی حفص القرشی العدوی رضی اللہ عنہ (3691), 2198,"أَخْبَرَنَا أَبُو مَعْمَرٍ  ، عَنْ إِسْمَاعِيل بْنِ عُلَيَّةَ  ، عَنْ سَلَمَةَ بْنِ عَلْقَمَةَ  ، عَنْ حُمَيْدِ بْنِ هِلَالٍ  ، عَنْ أَبِي الدَّهْمَاءِ  ، عَنْ عِمْرَانَ بْنِ حُصَيْنٍ  ، قَالَ :"" تَرِثُ الْجِدَّةُ وَابْنُهَا حَيٌّ """,,takhreej: @متفق علیہ: البخاری، التھجد، باب فضل قیام اللیل (1131) ومسلم، کتاب فضائل الصحابہ، باب من فضائل عبداللّٰہ بن عمر رضی اللہ عنہ (6320), 2199,أَخْبَرَنَا يَزِيدُ بْنُ هَارُونَ  ، أَنْبَأَنَا الْأَشْعَثُ  ، عَنْ الزُّهْرِيِّ  ، قَالَ : جَاءَتْ إِلَى أَبِي بَكْرٍ جَدَّةٌ أُمُّ أَبٍ، أَوْ أُمُّ أُمٍّ، فَقَالَتْ : إِنَّ ابْنَ ابْنِي أَوْ ابْنَ ابْنَتِي تُوُفِّيَ، وَبَلَغَنِي أَنَّ لِي نَصِيبًا، فَمَا لِي؟ فَقَالَ أَبُو بَكْرٍ : مَا سَمِعْتُ رَسُولَ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ قَالَ فِيهَا شَيْئًا، وَسَأَسْأَلُ النَّاسَ، فَلَمَّا صَلَّى الظُّهْر، قَالَ : أَيُّكُمْ سَمِعَ رَسُولَ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ قَالَ فِي الْجَدَّةِ شَيْئًا؟ فَقَالَ الْمُغِيرَةُ بْنُ شُعْبَةَ   : أَنَا، قَالَ : مَاذَا؟ قَالَ :أَعْطَاهَا رَسُولُ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ سُدُسًا، قَالَ : أَيَعْلَمُ ذَاكَ أَحَدٌ غَيْرُكَ؟ فَقَالَ مُحَمَّدُ بْنُ مَسْلَمَةَ   : صَدَقَ، فَأَعْطَاهَا أَبُو بَكْرٍ السُّدُسَ، فَجَاءَتْ إِلَى عُمَرَ مِثْلُهَا، فَقَال : مَا أَدْرِي، مَا سَمِعْتُ مِنْ رَسُولِ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ فِيهَا شَيْئًا، وَسَأَسْأَلُ النَّاسَ، فَحَدَّثُوهُ بِحَدِيثِ الْمُغِيرَةِ بْنِ شُعْبَةَ، وَمُحَمَّدِ بْنِ مَسْلَمَةَ، فَقَالَ عُمَرُ : أَيُّكُمَا خَلَتْ بِهِ فَلَهَا السُّدُسُ، فَإِنْ اجْتَمَعْتُمَا، فَهُوَ بَيْنَكُمَا,,takhreej: !اسنادہ جیّد: سابقہ کا تکرار ہے۔, 2200,"أَخْبَرَنَا يَزِيدُ بْنُ هَارُونَ  ، حَدَّثَنَا الْأَشْعَثُ  ، عَنْ الشَّعْبِيِّ  ، عَنْ عَلِيٍّ  ، وَزَيْدٍ   قَالَا :"" إِذَا كَانَتْ الْجَدَّاتُ سَوَاءً، وَرِثَ ثَلَاثُ جَدَّاتٍ جَدَّتَا أَبِيهِ أُمُّ أُمِّهِ، وَأُمُّ أَبِيهِ، وَجَدَّةُ أُمِّهِ، فَإِنْ كَانَتْ إِحَدَاهُنَّ أَقْرَب، فَالسَّهْمُ لِذَوِي الْقُرْبَى",,takhreej: @متفق علیہ: البخاری، کتاب العلم، باب فضل العلم( 82) ومسلم، کتاب فضائل الصحابہ، باب من فضائل عمر رضی اللہ عنہ ( 6140), 2201,"أَخْبَرَنَا أَبُو نُعَيْمٍ  ، حَدَّثَنَا حَسَنٌ  ، عَنْ أَشْعَثَ  ، عَنْ الشَّعْبِيِّ  ، عَنْ عَلِيٍّ  ، وَزَيْدٍ   : "" أَنَّهُمَا كَانَالا يُوَرِّثَانِ الْجِدَّةَ أُمَّ الأَبِ مَعَ الأَبِ """,,takhreej: !اسنادہ ضعیف, 2202,"حَدَّثَنَا سَعِيدُ بْنُ الْمُغِيرَةِ  ، عَنْ ابْنِ الْمُبَارَكِ  ، عَنْ مَعْمَرٍ  ، عَنْ الزُّهْرِيِّ  : أَنَّ عُثْمَانَ   كَانَ"" لَا يُوَرِّثُ الْجَدَّةَ وَابْنُهَا حَيٌّ """,,takhreej: !متفق علیہ: البخاری، کتاب التعبیر، باب من لم یراء الرؤیا لأول عابر اذا لم یصب (7046) ومسلم، کتاب الرؤیا، باب فی تاؤیل الرؤیا (5887), 2203,"أَخْبَرَنَا يَزِيدُ بْنُ هَارُونَ  ، أَنْبَأَنَا الْأَشْعَثُ  ، عَنْ ابْنِ سِيرِينَ  ، عَنْ ابْنِ مَسْعُودٍ  ، قَالَ :"" إِنَّ الْجَدَّاتِ لَيْسَ لَهُنَّ مِيرَاثٌ، إِنَّمَا هِيَ طُعْمَةٌ أُطْعِمْنَهَا، وَالْجَدَّاتُ أَقْرَبُهُنَّ وَأَبْعَدُهُنَّ سَوَاءٌ """,,takhreej: !اسنادہ صحیح: کشف الأستار للبزار 1/397 (844) مزید دیکھئے مجمع الزوائد 9/24-23, 2204,"أَخْبَرَنَا حَجَّاجُ بْنُ مِنْهَالٍ  ، أَنْبَأَنَا أَبُو عَوَانَةَ  ، عَنْ الْمُغِيرَةِ  ، عَنْ إِبْرَاهِيمَ  ، قَالَ : قَالَ عَبْدُ اللَّهِ   :"" تَرِثُ الْجَدَّةُ وَابْنُهَا حَيٌّ """,,takhreej: @متفق علیہ: البخاری، کتاب المناقب، باب علامات النبوۃ فی الاسلام (36222) ومسلم، کتاب الرؤیا، باب رؤیاالنبی ﷺ (5893), 2205,"أَخْبَرَنَا يَزِيدُ بْنُ هَارُونَ  ، أَنْبَأَنَا الْأَشْعَثُ  ، عَنْ الشَّعْبِيِّ  ، قَالَ : "" جِئْنَ أَرْبَعُ جَدَّاتٍ يَتَسَاوَقْنَ إِلَى مَسْرُوقٍ  ،فَأَلْغَى أَمَّ أَبِ الْأَبِ، وَوَرَّثَ ثَلَاثًا : جَدَّتَيْ أَبِيهِ : أُمَّ أُمِّهِ، وَأُمَّ أَبِيهِ، وَجَدَّةَ أُمِّهِ """,,takhreej: !صحیح علی شرط مسلم : احمد3/351، والطبقات لابن سعد 2/1/32-31, 2206,"أَخْبَرَنَا يَزِيدُ بْنُ هَارُونَ  ، أَنْبَأَنَا شَرِيكٌ  ، عَنْ الْأَعْمَشِ  ، عَنْ إِبْرَاهِيمَ  ، عَنْ عَبْدِ اللَّهِ   فِي ابْنَةٍ، وَابْنَةِ ابْنٍ، قَالَ :"" النِّصْفُ وَالسُّدُسُ، وَمَا بَقِيَ، فَرَدٌّ عَلَى الْبِنْتِ """,,takhreej: !متفق علیہ: البخاری، کتاب التعبیر، باب القید فی المنام (7017) ومسلم، فی الرؤیا (2263), 2207,"حَدَّثَنَا مُحَمَّدُ بْنُ عِيسَى  ، حَدَّثَنَا جَرِيرٌ  ، عَنْ مَنْصُورٍ  ، عَنْ إِبْرَاهِيمَ  ، عَنْ عَلْقَمَةَ  ، عَنْ عَبْدِ اللَّه   : "" أَنَّهُ أُتِيَ فِي إِخْوَةٍ لِأُمٍّ، وَأُمٍّ،فَأَعْطَى الْإِخْوَةَ مِنَ الْأُمِّ الثُّلُثَ، وَالْأُمَّ سَائِرَ الْمَالِ، وَقَالَ : الْأُمُّ عَصَبَةُ مَنْ لَا عَصَبَةَ لَهُ """,,takhreej: @صحیح البخاری، کتاب التعبیر الرؤیا، باب اذا رأی انہ أخرج الشیٔ من کوۃ … (7038) واحمد (2/137), 2208,"حَدَّثَنَا أَبُو نُعَيْمٍ ، حَدَّثَنَا حَسَنٌ ، عَنْ أَبِيهِ ، قَالَ : سَأَلْتُ الشَّعْبِيَّ  عَنْ رَجُلٍ مَاتَ وَتَرَكَ ابْنَتَهُ، لَا يُعْلَمُ لَهُ وَارِثٌ غَيْرُهَا، قَالَ :"" لَهَا الْمَالُ كُلُّهُ """,,takhreej: !ضعیف: مجالد بن سعید ضعیف ہے۔ احمد3/399, 2209,حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ  ، حَدَّثَنَا سُفْيَانُ  ، عَنْ مُحَمَّدِ بْنِ سَالِمٍ  ، عَنْ الشَّعْبِيِّ  ، أَنَّ ابْنَ مَسْعُودٍ   كَانَلَا يَرُدُّ عَلَى أَخٍ لِأُمٍّ مَعَ أُمٍّ، وَلا عَلَى جَدَّةٍ، إِذَا كَانَ مَعَهَا غَيْرُهَا مَنْ لَهُ فَرِيضَةٌ، وَلَا عَلَى ابْنَةِ ابْنٍ، مَعَ ابْنَةِ الصُّلْبِ، وَلَا عَلَى امْرَأَةٍ وَزَوْج,,takhreej: !رجالہ ثقات: لیکن ابن اسحاق مدلس عن سے بیان کرتے ہیں، اس کے باوجود حافظ ابن حجر رحمہ اللہ نے اسے حسن قرار دیا ہے۔ دیکھئے الفتح (12/432), 2210,"وَكَانَ عَلِيٌّ  "" يَرُدُّ عَلَى كُلِّ ذِي سَهْمٍ، إِلَّا الْمَرْأَةَ وَالزَّوْجَ """,,takhreej: !مرسل ضعیف: اس کی مکمل تخریج ’’مجمع الزوائد‘‘ میں 7396 کے تحت مذکور ہے۔ نیز مراسیل لابی داؤد 202:, 2211,"أَخْبَرَنَا مُحَمَّدٌ  ، حَدَّثَنَا سُفْيَانُ  ، قَالَ : أَخْبَرَنِي مُحَمَّدُ بْنُ سَالِمٍ  ، عَنْ خَارِجَةَ بْنِ زَيْدٍ  ، عَنْ زَيْدِ بْنِ ثَابِت   : "" أَنَّهُأُتِيَ فِي ابْنَةٍ، أَوْ أُخْت، فَأَعْطَاهَا النِّصْفَ، وَجَعَلَ مَا بَقِيَ فِي بَيْتِ الْمَالِوقَالَ يَزِيدُ بْنُ هَارُونَ  : عَنْ مُحَمَّدِ بْنِ سَالِمٍ  ، عَنْ الشَّعْبِيِّ  ، عَنْ خَارِجَةَ",,takhreej: !أخرجہ البخاری، کتاب النکاح، باب من لم یستطع الباء ۃ فلیصم (الحدیث5066) وأخرجہ مسلم، کتاب النکاح، باب استحباب النکاح لمن تاقت الیہ نفسہ ووجد مؤنہ (الحدیث 3386), 2212,"أَخْبَرَنَا مُحَمَّدُ بْنُ عُيَيْنَةَ  ، عَنْ عَلِيِّ بْنِ مُسْهِرٍ  ، عَنْ سَعِيدٍ  ، عَنْ أَبِي مَعْشَرٍ  ، عَنْ إِبْرَاهِيمَ  ، عَنْ عَبْدِ اللَّهِ  ، قَالَ فِي ابْنِ الْمُلَاعَنَةِ، قَالَ :"" مِيرَاثُهُ لِأُمِّهِ """,,takhreej: !أخرجہ البخاری،کتاب النکاح ،باب قول النبی ﷺ من استطاع منکم البائۃ فلیتزوج (الحدیث5065 -واخرجہ مسلم،کتاب النکاح،باب استحباب النکاح لمن تاقت نفسہ الیہ ووجد مؤنہ(الحدیث3384), 2213,"أَخْبَرَنَا مُعَاذُ بْنُ هَانِئٍ  ، حَدَّثَنَا إِبْرَاهِيمُ بْنُ طَهْمَانَ  ، قَالَ : سَمِعْتُ رَجُلًا  سَأَلَ عَطَاءَ بْنَ أَبِي رَبَاحٍ   عَنْ وَلَدِ الْمُتَلَاعِنَيْنِ لِمَنْ مِيرَاثُهُ؟ قَالَ :"" لِأُمِّهِ وَأَهْلِهَا",,takhreej: @أخرجہ البخاری،کتاب النکاح،باب مایکرہ من التبتل والخصائ(الحدیث5073)واخرجہ مسلم،کتاب النکاح،باب استحباب النکاح لمن تاقت الیہ نفسہ ووجد مؤنہ واشتغال من عجز عن المؤن بالصوم(الحدیث3390), 2214,"أَخْبَرَنَا أَبُو نُعَيْمٍ  ، حَدَّثَنَا حَسَنٌ  ، عَنْ أَبِي سَهْلٍ  ، عَنْ الشَّعْبِيِّ  قَالَ : قَالَ عَلِيٌّ   فِي ابْنِ الْمُلَاعَنَةِ :"" تَرَكَ أَخَاهُ لِأُمِّهِ، وَأُمَّهُ لِأَخِيهِ السُّدُسُ، وَلِأُمِّهِ الثُّلُثُ، ثُمَّ يُرَدُّ عَلَيْهِمْ، فَيَصِيرُ لِلْأَخِ الثُّلُثُ، وَلِلْأُمِّ الثُّلُثَانِ "". وَقَالَ ابْنُ مَسْعُودٍ   : لِأَخِيهِ السُّدُسُ، وَمَا بَقِيَ فَلِلْأُمِّ",,takhreej: ! اسنادہ صحیح: حسن کا تابعی سے’’عن‘‘کے صیغے سے روایت کرنا نقصان دہ نہیں ہے۔اخرجہ ترمذی،کتاب النکاح، باب ماجاء فی النہی عن التبتل(الحدیث1082)والنسائی،فی کتاب النکاح،باب النہی عن التبتل(الحدیث3216)وابن ماجہ فی کتاب النکاح،باب النہی عن التبتل(الحدیث1849), 2215,"أَخْبَرَنَا أَبُو نُعَيْمٍ ، حَدَّثَنَا حَسَنٌ ، عَنْ أَبِي سَهْلٍ ، عَنْ الشَّعْبِيِّ  فِي ابْنِ الْمُلَاعَنَةِ : تَرَكَ ابْنَ أَخٍ وَجَدًّا، قَالَ :"" الْمَالُ لِابْنِ الْأَخِ """,,takhreej: @ اسنادہ صحیح: یہ حدیث متفق علیہ ہے اس کی تخریج(حدیث2213کے تحت گزر چکی ہے۔, 2216,"حَدَّثَنَا مُحَمَّدُ بْنُ عِيسَى  ، حَدَّثَنَا سَالِمُ بْنُ نُوحٍ  ، عَنْ عُمَرَ بْنِ عَامِرٍ  ، عَنْ قَتَادَةَ  ، عَنْ سَعِيدِ بْنِ الْمُسَيِّبِ  ، عَنْ زَيْدِ بْنِ ثَابِتٍ   فِي مِيرَاثِ ابْنِ الْمُلَاعَنَة :"" لِأُمِّهِ الثُّلُثُ، وَالثُّلُثَانِ لِبَيْتِ الْمَالِ """,,takhreej: !اخرجہ البخاری،کتاب النکاح،باب الأکفاء فی الدین(الحدیث5090)ومسلم،فی کتاب الرضاع،باب استحباب النکاح ذات الدین(الحدیث3620), 2217,"حَدَّثَنَا مُحَمَّدُ بْنُ عِيسَى  ، حَدَّثَنَا سَالِمُ بْنُ نُوحٍ  ، عَنْ عُمَرَ بْنِ عَامِرٍ  ، عَنْ حَمَّادٍ  ، عَنْ إِبْرَاهِيمَ  ، عَنْ عَبْدِ اللَّهِ  ، قَالَ :"" مِيرَاثُهُ لِأُمِّهِ تَعْقِلُ عَنْهُ عَصَبَةُ أُمِّهِ ""، وَقَالَ قَتَادَةُ  ، عَنْ الْحَسَنِ   : لِأُمِّهِ الثُّلُثُ، وَبَقِيَّةُ الْمَالِ لِعَصَبَةِ أُمِّهِ",,takhreej: @ اسنادہ صحیح: اس کی تخریج بھی سابقہ حدیث کے مطابق ہے۔, 2218,"أَخْبَرَنَا حَجَّاجُ بْنُ مِنْهَالٍ  ، حَدَّثَنَا حَمَّادُ بْنُ سَلَمَةَ  ، أَخْبَرَنَا قَتَادَةُ  : أَنَّ عَلِيًّا  ، وَابْنَ مَسْعُودٍ   قَالَا فِي وَلَدِ المُلَاعَنَةٍ تَرْكُ جَدَّتِهِ وَإِخْوَتِهِ لأُمِّهِ، قَالَ :"" لِلْجَدَّةِ الثُّلُثُ، وَلِلْإِخْوَةِ الثُّلُثَانِ ""، وَقَالَ زَيْدُ بْنُ ثَابِتٍ   : لِلْجَدَّةِ السُّدُسُ، وَلِلْإِخْوَةِ لِلْأُمِّ الثُّلُثُ، وَمَا بَقِيَ فَلِبَيْتِ الْمَالِ",,takhreej: ! اسنادہ صحیح اس کی مکمل تخریج مججمع الزوائد(حدیث7418)کے تحت مذکور ہے۔ اخرجہ الترمذی،کتاب النکاح،باب ماجاء فی النظرالی المخطوبۃ(الحدیث1087)والنسائی،فی الکتاب النکاح،باب إباحۃ النظر قبل التزویج(الحدیث3235), 2219,"حَدَّثَنَا حَجَّاجٌ  ، حَدَّثَنَا حَمَّادٌ  ، أَنْبَأَنَا يُونُسُ  ، وَحُمَيدٌ  ، عَنْ الْحَسَنِ  ، قَالَ :"" تَرِثُهُ أُمُّهُ يَعْنِي : ابْنَ الْمُلَاعَنَةِ """,,takhreej: @ صحیح : أخرجہ النسائی،کتاب النکاح،باب کیف یدرو للرجل اذا تزوج(الحدیث3371)وابن ماجہ فی کتاب النکاح،باب تھنئۃ النکاح(الحدیث1906), 2220,"أَخْبَرَنَا حَجَّاجٌ ، حَدَّثَنَا حَمَّادٌ ، حَدَّثَنَا حَجَّاجٌ : أَنَّ النَّخَعِيَّ ، وَالشَّعْبِيّ ، قَالَا :"" تَرِثُهُ أُمُّهُ """,,takhreej: !حسن نعیم بن حماد کے سبب جبکہ ثقہ راویوں سے اس کی متابعت بھی موجود ہے۔ اخرجہ ابوداؤد،کتاب النکاح، باب میقال للمتزوج (الحدیث3130)والترمذی فی کتاب النکاح،باب ماجاء ما یقال للمتزوج (الحدیث1091) وصحیح ابن حبان(الحدیث4052), 2221,"أَخْبَرَنَا مُحَمَّدُ بْنُ يُوسُفَ  ، حَدَّثَنَا سُفْيَانُ  ، عَنْ دَاوُدَ بْنِ أَبِي هِنْدٍ  ، عَنْ عَبْدِ اللَّهِ بْنِ عُبَيْدِ بْنِ عُمَيْرٍ  ، قَالَ : كَتَبْتُ إِلَى أَخٍ لِي   مِنْ بَنِي زُرَيْقٍ أَسْأَلُهُ : لِمَنْ قَضَى النَّبِيُّ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ فِي ابْنِ الْمُلَاعَنَةِ؟ فَكَتَبَ إِلَيَّ : "" أَنَّ النَّبِيَّ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّم :قَضَى بِهِ لِأُمِّهِ هِيَ بِمَنْزِلَةِ أُمِّهِ وَأَبِيهِ. وقَالَ سُفْيَانُ : الْمَالُ كُلُّهُ لِلْأُمِّ هِيَ بِمَنْزِلَةِ أَبِيهِ وَأُمِّهِ",,takhreej: @متفق علیہ: أخرجہ البخاری،کتاب البیوع،باب لا یبیع علی بیع اخیہ ولا یسوم علی سوم اخیہ حتی یأذن لہ أو یترک (الحدیث 2140) ومسلم،فی کتاب النکاح،باب تحریم الخطیۃ علی خطیۃ اخیہ حتی یازن أویترک(الحدیث3444), 2222,"أَخْبَرَنَا مُحَمَّدٌ  ، حَدَّثَنَا سُفْيَانُ  ، عَنْ هِشَامٍ  ، عَنْ الْحَسَنِ   فِي ابْنِ الْمُلَاعَنَةِ تَرَكَ أُمَّهُ وَعَصَبَةَ أُمِّهِ، قَالَ :"" الثُّلُثُ لِأُمِّهِ، وَمَا بَقِيَ فَلِعَصَبَةِ أُمِّهِ """,,takhreej: ! متفق علیہ: اخرجہ البخاری،کتاب النکاح،باب لا یخطب علی خطبۃ اخیہ حتی ینکح او یدع (الحدیث 5142) ومسلم، فی کتاب النکاح باب تحریم الخطبۃ علی خطبۃ اخیہ حتی یاذن أویترک(الحدیث3441), 2223,"أَخْبَرَنَا عُبَيْدُ اللَّهِ بْنُ مُوسَى  ، عَنْ ابْنِ أَبِي لَيْلَى  ، عَنْ عَامِرٍ  ، عَنْ عَلِيٍّ  ، وَعَبْدِ اللَّهِ   فِي ابْنِ الْمُلاعَنَةِ، قَالا :"" عَصَبَتُهُ عَصَبَةُ أُمِّهِ """,,takhreej: ! صحیح اخرجہ مسلم،کتاب الطلاق،باب المطلقہ ثلاثا لا نفقۃ لہا(الحدیث3681)وابوداؤد،فی کتاب الطلاق،باب فی نفقۃ المبتوتۃ (الحدیث2284), 2224,"حَدَّثَنَا أَبُو الْوَلِيدِ الْحَلَبِيُّ مُوسَى بْنُ خَالِدٍ ، حَدَّثَنَا المُعْتَمِر ، عَنْ يُونُسَ ، عَنِ الْحَسَنِ ، أَنَّهُ كَانَ يَقُول :"" مِيرَاثُ وَلَدِ الْمُلَاعَنَةِ لِأُمِّه، قُلْتُ : فَإِنْ كَانَ لَهُ أَخٌ مِنْ أُمِّه؟ قَالَ : لَهُ السُّدُسُ """,,takhreej: !متفق علیہ: اخرجہ البخاری،کتاب النکاح،باب لتنکح المرأۃ علی عمتہا (الحدیث 5109) و (الحدیث5110) ومسلم، فی کتاب النکاح،باب تحریم الجمع بین المرأۃ وعمتہا وخالتہا فی النکاح(الحدیث3429), 2225,"حَدَّثَنَا أَبُو الْمُغِيرَةِ ، حَدَّثَنَا الْأَوْزَاعِيُّ ، حَدَّثَنَا الزُّهْرِيُّ ، قَالَ :"" وَلَدُ الْمُلَاعَنَةِ لِأُمِّه، تَرِثُ فَرِيضَتَهَا مِنْهُ، وَسَائِرُ ذَلِكَ فِي بَيْتِ الْمَالِ """,,takhreej: !متفق علیہ: اخرجہ البخاری،کتاب النکاح،باب لا تنکح المرأۃ علی عمتہا(الحدیث5109)ومسلم،فی کتاب النکاح،باب تحریم الجمع ین المرأۃ وعمتہا أو خالتھا فی النکاح(الحدیث3422), 2226,"أَخْبَرَنَا عُبَيْدُ اللَّهِ بْنُ مُوسَى  ، عَنْ مُوسَى بْنِ عُبَيْدَةَ  ، عَنْ نَافِعٍ  ، عَنْ ابْنِ عُمَرَ  ، قَالَ :"" إِذَا تَلَاعَنَا، فُرِّقَ بَيْنَهُمَا وَلَمْ يَجْتَمِعَا، وَدُعِيَ الْوَلَدُ لِأُمِّهِ، يُقَالُ : ابْنُ فُلَانَةَ، هِيَ عَصَبَتُهُ يَرِثُهَا وَتَرِثُهُ، وَمَنْ دَعَاهُ لِزِنْيَةٍ، جُلِدَ """,,takhreej: @متفق علیہ: أخرجہ البخاری،کتاب النکاح،باب الشغار (الحدیث5113) ومسلم،فی کتاب النکاح،باب تحریم النکاح الشغار وبطلانہ(الحدیث3450), 2227,"حَدَّثَنَا مُعَاذُ بْنُ هَانِئٍ ، حَدَّثَنَا إِبْرَاهِيمُ بْنُ طَهْمَانَ ، حَدَّثَنَا الشَّيْبَانِيُّ ، عَنْ الشَّعْبِيِّ  فِي وَلَدِ الْمُتَلَاعِنَيْنِ : "" أَنَّهُتَرِثُهُ عَصَبَةُ أُمِّهِ، وَهُمْ يَعْقِلُونَ عَنْهُ """,,takhreej: ! اسنادہ حسن: اس کی سند میں عمر بن کیسان راوی ہے جس کو امام بخاری نے ’’تاریخ کبیر‘‘6/189 اور ابن ابی حاتم نے ’’الجرح والتعدیل‘‘9/24 میں ذکر کیا ہے۔لیکن اس پر جرح تاتعدیل نہیں کی جب کہ ابن حبان الثقات7/182میں اسے ثقہ قرار دیا ہے۔, 2228,"حَدَّثَنَا سَهْلُ بْنُ حَمَّادٍ  ، أَنْبَأَنَا هَمَّامٌ  ، عَنْ قَتَادَةَ  ، عَنْ عَزْرَةَ  ، عَنْ سَعِيدِ بْنِ جُبَيْرٍ  ، عَنْ ابْنِ عَبَّاسٍ   فِي وَلَدِ الْمُلَاعَنَةِ هُوَ الَّذِي لَا أَبَ لَهُ"" تَرِثُهُ أُمُّهُ وَإِخْوَتُهُ مِنْ أُمِّهِ، ِوَعَصَبَةُُ أُمِّهِ، فَإِنْ قَذَفَهُ قَاذِف، جُلِدَ قَاذِفُهُ """,,takhreej: @صحیح: اخرجہ ابوداؤد،کتاب النکاح،باب فی الولی (الحدیث5085)والترمذی،فی کتاب النکاح،باب ماجاء لانکاح الابولی(الحدیث1101), 2229,"أَخْبَرَنَا مُحَمَّدُ بْنُ الْمُبَارَكِ  ، حَدَّثَنَا يَحْيَى بْنُ حَمْزَةَ  ، عَنْ النُّعْمَانِ  ، عَنْ مَكْحُولٍ   : أَنَّهُ سُئِلَ عَنْ مِيرَاثِ وَلَدِ الْمُلَاعَنَةِ لِمَنْ هُوَ؟ قَالَ : جَعَلَهُ رَسُولُ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ :"" لِأُمِّهِ فِي سَبَبِهِ لِمَا لَقِيَتْ مِنْ الْبَلَاءِ، وَلِإِخْوَتِهِ مِنْ أُمِّهِ، وقَالَ مَكْحُول : فَإِنْ مَاتَتْ الْأُمُّ، وَتَرَكَتْ ابْنَهَا، ثُمَّ تُوُفِّيَ ابْنُهَا الَّذِي جُعِلَ لَهَا، كَانَ مِيرَاثُهُ لِإِخْوَتِهِ مِنْ أُمِّهِ كُلُّهُ، لِأَنَّهُ كَانَ لِأُمِّهِمْ وَجَدِّهِمْ، وَكَانَ لِأَبِيهَا السُّدُسُ مِنْ ابْنِ ابْنَتِهِ، وَلَيْسَ يَرِثُ الْجَدُّ إِلَّا فِي هَذِهِ الْمَنْزِلَةِ، لِأَنَّهُ إِنَّمَا هُوَ أَبُ الْأُمِّ، وَإِنَّمَا وَرِثَ الْإِخْوَةُ مِنْ الْأُمِّ أُمَّهُمْ، وَوَرِثَ الْجَدُّ ابْنَتَهُ لِأَنَّهُ جُعِلَ لَهَا، فَالْمَالُ الَّذِي لِلْوَلَدِ لِوَرَثَةِ الْأُمِّ وَهُوَ بِحَوْزَةِ الْجَدُّ وَحْدَهُ إِذَا لَمْ يَكُنْ غَيْرُهُ """,,takhreej: ! اسنادہ ضعیف: لیکن سابقہ حدیث کے شاہد کی بناء پر معنی صحیح ہے۔, 2230,"أَخْبَرَنَا مُحَمَّدُ بْنُ الْعَلَاءِ  ، حَدَّثَنَا يَحْيَى بْنُ أَبِي بُكَيْرٍ  ، حَدَّثَنَا إِبْرَاهِيمُ بْنُ طَهْمَانَ  ، عَنْ سِمَاكِ بْنِ حَرْبٍ  ، عَنْ عِكْرِمَةَ  ، عَنْ ابْنِ عَبَّاسٍ  : أَنَّ قَوْمًا اخْتَصَمُوا إِلَى عَلِيٍّ   رَضِيَ اللَّهُ تَعَالَى عَنْه فِي وَلَدِ الْمُتَلَاعِنَيْنِ، فَجَاءَ عَصَبَةُ أَبِيهِ يَطْلُبُونَ مِيرَاثَه، فَقَالَ :"" إِنَّ أَبَاهُ كَانَ تَبَرَّأَ مِنْهُ، فَلَيْسَ لَكُمْ مِنْ مِيرَاثِهِ شَيْءٌ، فَقَضَى بِمِيرَاثِهِ لِأُمِّهِ، وَجَعَلَهَا عَصَبَتَهُ """,,takhreej: @ اسنادہ حسن: سلیمان بن موسیٰ کی بناء پر۔ اخرجہ ابوداؤد،کتاب النکاح،باب فی الولی (الحدیث 2083) والترمذی، فی الکتاب النکاح،باب ماجاء لا نکاح الابولی(الحدیث1102), 2231,"أَخْبَرَنَا عُبَيْدُ اللَّهِ بْنُ مُوسَى  ، عَنْ إِسْرَائِيلَ  ، عَنْ عَبْدِ الْأَعْلَى  : أَنَّهُ سَمِعَ مُحَمَّدَ بْنَ عَلِيٍّ  يُحَدِّثُ، عَنْ عَلِيٍّ   : فِي الرَّجُلِ يَكُونُ لَهُ مَا لِلرَّجُلِ وَمَا لِلْمَرْأَةِ مِنْ أَيِّهِمَا يُوَرَّثُ، فَقَالَ :"" مِنْ أَيِّهِمَا بَالَ """,,takhreej: !اسنادہ صحیح: ابن حبان(الحدیث4085) موارد الظمآن (الحدیث1298), 2232,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ  ، حَدَّثَنَا هُشَيْمٌ  ، عَنْ مُغِيرَةَ  ، عَنْ شِبَاكٍ  ، عَنْ الشَّعْبِيِّ  ، عَنْ عَلِيٍّ   فِي الْخُنْثَى، قَالَ :"" يُوَرَّثُ مِنْ قِبَلِ مَبَالِهِ """,,takhreej: @متفق علیہ: البخاری،کتاب النکاح،باب لاینکح الأدب وغیر البکروالثیب إلا برضاہما (الحدیث5136) ومسلم،کتاب النکاح باب استئذان الثیب فی النکاح بالنطق والبکر بالسکوت(الحدیث3458), 2233,"حَدَّثَنَا أَبُو نُعَيْمٍ  ، حَدَّثَنَا أَبُو هَانِئٍ  ، قَالَ : سُئِلَ عَامِرٌ   عَنْ مَوْلُودٍ وُلِدَ، وَلَيْسَ بِذَكَرٍ، وَلَا أُنْثَى، لَيْسَ لَهُ مَا لِلذَّكَرِ، وَلَيْسَ لَهُ مَا لِلْأُنْثَى، يُخْرِجُ مِنْ سُرَّتِهِ كَهَيْئَةِ الْبَوْلِ وَالْغَائِطِ، سُئِلَ عَنْ مِيرَاثِهِ، فَقَالَ :"" نِصْفُ حَظِّ الذَّكَرِ، وَنِصْفُ حَظِّ الْأُنْثَى """,,takhreej: !متفق علیہ یہی سابقہ حدیث والی تخریج ہی ہے۔, 2234,"أَخْبَرَنَا يَزِيدُ بْنُ هَارُونَ  ، حَدَّثَنَا عَاصِمٌ  ، عَنْ الشَّعْبِيِّ  ، قَالَ : سُئِلَ أَبُو بَكْرٍ   عَنْ الْكَلَالَةِ، فَقَالَ : "" إِنِّي سَأَقُولُ فِيهَا بِرَأْيِي، فَإِنْ كَانَ صَوَابًا فَمِنْ اللَّهِ، وَإِنْ كَانَ خَطَأً فَمِنِّي، وَمِنَ الشَّيْطَانِ : أُرَاهُمَا خَلَا الْوَالِدَ وَالْوَلَدِ ""، َفَلَمَّا اسْتُخْلِفَ عُمَرُ  ، قَالَ : إِنِّي لَأَسْتَحْيِي اللَّهَ أَنْ أَرُدَّ شَيْئًا قَالَهُ أَبُو بَكْرٍ",,takhreej: @صحیح مسلم،کتاب النکاح،باب استئذان الثیب فی النکاح بالنطق(الحدیث3461)وابوداؤد،کتاب النکاح،باب فی الثیب (الحدیث2098)و(الحدیث2100), 2235,"حَدَّثَنَا عَبْدُ اللَّهِ بْنُ يَزِيدَ  ، حَدَّثَنَا سَعِيدٌ هُوَ ابْنُ أَبِي أَيُّوبَ  ، قَالَ : حَدَّثَنِي يَزِيدُ بْنُ أَبِي حَبِيبٍ  ، عَنْ مَرْثَدِ بْنِ عَبْدِ اللَّهِ الْيَزَنِيِّ  ، عَنْ عُقْبَةَ بْنِ عَامِرٍ الْجُهَنِيِّ  ، أَنَّهُ قَالَ :"" مَا أَعْضَلَ بِأَصْحَابِ رَسُولِ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ شَيْءٌ مَا أَعْضَلَتْ بِهِمْ الْكَلَالَةُ """,,takhreej: !اسنادہ صحیح: (2231) کے تحت اس کی تخریج گزر چکی ہے۔, 2236,"حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ  ، حَدَّثَنَا سُفْيَانُ  ، عَنْ عَمْرِو بْنِ دِينَارٍ  ، عَنْ الْحَسَنِ بْنِ مُحَمَّدٍ  ، عَنْ ابْنِ عَبَّاسٍ  ، قَالَ :"" الْكَلَالَةُ مَا خَلَا الْوَالِدَ وَالْوَلَدَ """,,takhreej: @حسن: عبداللہ بن عبدالرحمن بن موہب کے سبب(2231)کے تحت تخریج گزر چکی ہے۔, 2237,"أَخْبَرَنَا مُحَمَّدٌ  ، حَدَّثَنَا سُفْيَانُ  ، عَنْ يَعْلَى بْنِ عَطَاءٍ  ، عَنْ الْقَاسِمِ بْنِ عَبْدِ اللَّهِ L1584 ، عَنْ سَعْدٍ   : "" أَنَّهُ كَانَ يَقْرَأُ هَذِهِ الْآيَةَ : # وَإِنْ كَانَ رَجُلٌ يُورَثُ كَلالَةً أَو امْرَأَةٌ وَلَهُ أَخٌ أَوْ أُخْتٌ سورة النساء آية 12 #لِأُمٍّ """,,takhreej: #صحیح البخاری،کتاب النکاح،باب اذا زوج الرجل ابنتہ وہی کارہۃ من نکاحہ مردود (الحدیث5138) وابوداؤد، کتاب النکاح، باب فی الثیب (الحدیث2101) ابن ماجہ،کتاب النکاح،باب من زوج ابنتہ وہی کا رہۃ (الحدیث 1873), 2238,"أَخْبَرَنَا عَبْدُ اللَّهِ بْنُ يَزِيدَ  ، حَدَّثَنَا حَيْوَةُ  ، حَدَّثَنَا أَبُو الْأَسْوَدِ مُحَمَّدُ بْنُ عَبْدِ الرَّحْمَنِ بْنِ نَوْفَلٍ  : أَنَّ عَاصِمَ بْنَ عُمَرَ بْنِ قَتَادَةَ الْأَنْصَارِيَّ  أَخْبَرَهُ : أَنَّ عُمَرَ بْنَ الْخَطَّابِ   "" الْتَمَسَ مَنْ يَرِثُ ابْنَ الدَّحْدَاحَةِ، فَلَمْ يَجِدْ وَارِثًا،فَدَفَعَ مَالَ ابْنِ الدَّحْدَاحَةِ إِلَى أَخْوَالِ ابْنِ الدَّحْدَاحَةِ """,,takhreej: ! اسنادہ قوی: البخاری،کتاب النکاح،باب اذا زوج الرجل ابنتہ وہی کارہۃ(الحدیث5138)ومالک،کتاب النکاح،باب جامع مالا یجوز فی النکاح(الحدیث25), 2239,"أَخْبَرَنَا أَبُو عَاصِمٍ  ، عَنْ ابْنِ جُرَيْجٍ  ، عَنْ عَمْرِو بْنِ مُسْلِمٍ  ، عَنْ طَاوُسٍ  ، عَنْ عَائِشَةَ  ، قَالَتْ :"" اللَّهُ وَرَسُولُهُ مَوْلَى مَنْ لَا مَوْلَى لَهُ، وَالْخَالُ وَارِثُ مَنْ لَا وَارِثَ لَهُ """,,takhreej: @اسنادہ ضعیف: حسن کا سمرۃ سے سماع ثابت نہیں۔ ابوداؤد،کتاب النکاح، باب اِذا أنکح الولیان (الحدیث 2280) الترمذی، کتاب النکاح،باب ماجاء فی الولیین یزوجان(الحدیث1110), 2240,"أَخْبَرَنَا مُحَمَّدُ بْنُ يُوسُفَ  ، حَدَّثَنَا سُفْيَانُ  ، عَنْ فِرَاسٍ  ، عَنْ الشَّعْبِيِّ  ، عَنْ زِيَادٍ  ، قَالَ : "" أُتِيَ عُمَرُ   فِي عَمٍّ لِأُمٍّ، وَخَالَة،فَأَعْطَى الْعَمَّ لِلْأُمِّ الثُّلُثَيْنِ، وَأَعْطَى الْخَالَةَ الثُّلُثَ """,,takhreej: !منقطع ضعیف: ابوداؤد،کتاب النکاح(الحدیث2088)الطبرانی الکبییر7/203(الحدیث6839)البیہقی،کتاب النکاح، باب الوکالۃ فی النکاح7/139, 2241,"أَخْبَرَنَا مُحَمَّدُ بْنُ يُوسُفَ  ، حَدَّثَنَا سُفْيَانُ  ، عَنْ يُونُسَ  ،  عَنِ الْحَسَنِ  : أَنَّ عُمَرَ بْنَ الْخَطَّابِ  "" أَعْطَى الْخَالَةَ الثُّلُثَ، وَالْعَمَّةَ الثُّلُثَيْنِ """,,takhreej: !صحیح مسلم،کتاب النکاح،باب نکاح المتعۃ(الحدیث2406)وابوداؤد،کتاب النکاح،باب فی النکاح المتعۃ (الحدیث 2072) النسائی،کتاب النکاح،باب تحریم المتعۃ(الحدیث3368), 2242,"أَخْبَرَنَا مُحَمَّدُ بْنُ يُوسُفَ  ، حَدَّثَنَا سُفْيَانُ  ، عَنْ الْحَسَنِ بْنِ عَمْرٍو  ، عَنْ غَالِبِ بْنِ عَبَّادٍ  ، عَنْ قَيْسِ بْنِ حَبْتَرٍ النَّهْشَلِيِّ  ، قَالَ : أُتِيَ عَبْدُ الْمَلِكِ بْنُ مَرْوَانَ فِي خَالَةٍ وَعَمَّةٍ، فَقَامَ شَيْخٌ  ، فَقَالَ : شَهِدْتُ عُمَرَ بْنَ الْخَطَّابِ  "" أَعْطَى الْخَالَةَ الثُّلُثَ، وَالْعَمَّةَ الثُّلُثَيْنِ ""، قَالَ : فَهَمَّ أَنْ يَكْتُبَ بِهِ، ثُمَّ قَالَ : أَيْنَ زَيْدٌ عَنْ هَذَا",,takhreej: @صحیح: اخرجہ الحمیدی فی المسند(الحدیث869)مسلم(الحدیث1406), 2243,"أَخْبَرَنَا مُحَمَّدُ بْنُ يُوسُفَ  ، حَدَّثَنَا سُفْيَانُ  ، عَنْ مُحَمَّدِ بْنِ سَالِمٍ  ، عَنْ الشَّعْبِيِّ  ، عَنْ مَسْرُوقٍ  ، عَنْ عَبْدِ اللَّهِ   قَالَ :"" الْخَالَةُ بِمَنْزِلَةِ الْأُمِّ، وَالْعَمَّةُ بِمَنْزِلَةِ الْأَبِ، وَبِنْتُ الْأَخِ بِمَنْزِلَةِ الْأَخِ، وَكُلُّ ذِي رَحِمٍ بِمَنْزِلَةِ رَحِمِهِ الَّتِي يُدْلِي بِهَا إِذَا لَمْ يَكُنْ وَارِثٌ ذُو قَرَابَةٍ """,,takhreej: # متفق علیہ : (2033) نمبر حدیث کے تحت اس کی تخریج گزر چکی ہے۔, 2244,"أَخْبَرَنَا يَزِيدُ بْنُ هَارُونَ  ، أَنْبَأَنَا هِشَامٌ  ، عَنْ مُحَمَّدٍ  ، عَنْ عَبْدِ اللَّهِ بْنِ عُتْبَةَ  ، قَالَ : حَدَّثَنِي الضَّحَّاكُ بْنُ قَيْسٍ  : أَنَّ عُمَرَ   قَضَى فِي أَهْلِ طَاعُونِ عَمَوَاسَ أَنَّهُمْ كَانُواإِذَا كَانُوا مِنْ قِبَلِ الْأَبِ سَوَاءً، فَبَنُو الْأُمِّ أَحَقُّ، وَإِذَا كَانَ بَعْضُهُمْ أَقْرَبَ مِنْ بَعْضٍ بِأَبٍ، فَهُمْ أَحَقُّ بِالْمَالِ """,,takhreej: !صحیح مسلم،کتاب النکاح،باب تحریم النکاح المحرم(الحدیث3433)وابوداؤد،کتاب المناسک،باب المحرم یتزوج (الحدیث1841) وابن ماجہ،کتاب النکاح،باب المحرم یتزوج(الحدیث1966), 2245,"حَدَّثَنَا أَحْمَدُ بْنُ عَبْدِ اللَّهِ  ، حَدَّثَنَا أَبُو شِهَابٍ  ، حَدَّثَنِي أَبُو إِسْحَاق الشَّيْبَانِيُّ  ، عَنْ عُبَيْدِ بْنِ أَبِي الْجَعْدِ  ، عَنْ عَبْدِ اللَّهِ بْنِ شَدَّادِ بْنِ الْهَادِ  ، قَالَ : أُصِيبَ سَالِمٌ مَوْلَى أَبِي حُذَيْفَةَ يَوْمَ الْيَمَامَة، فَبَلَغَ مِيرَاثُهُ مِائَتَيْ دِرْهَمٍ، فَقَالَ عُمَرُ   :"" احْبِسُوهَا عَلَى أُمِّهِ حَتَّى تَأْتِيَ عَلَى آخِرِهَا """,,takhreej: @ صحیح مسلم،کتاب النکاح،باب الصداق وجواز کو نہ تعلیم قران(الحدیث3474)ابوداؤد،کتاب النکاح،باب الصداق (الحدیث2105)ابن ماجہ،کتاب النکاح،باب صداق النسائ(الحدیث1886), 2246,"حَدَّثَنَا أَبُو نُعَيْمٍ  ، حَدَّثَنَا زُهَيْرٌ  ، عَنْ أَبِي إِسْحَاق  ، عَنْ الْحَارِثِ  ، عَنْ عَلِيٍّ  ، عَنِ النَّبِيِّ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ، قَالَ :"" الْإِخْوَةُ مِنْ الْأُمِّ يَتَوَارَثُونَ دُونَ بَنِي الْعَلَّاتِ، يَرِثُ الرَّجُلُ أَخَاهُ لِأَبِيهِ وَأُمِّهِ، دُونَ أَخِيهِ لِأَبِيهِ """,,takhreej: !صحیح: ابوداؤد،کتاب النکاح، باب الصداق (الحدیث2106) ترمذی،کتاب النکاح،باب منہ(الحدیث1114) وابن ماجہ، کتاب النکاح،باب صداق النسائ(الحدیث1887), 2247,"حَدَّثَنَا سَهْلُ بْنُ حَمَّادٍ  ، حَدَّثَنَا شُعْبَةُ  ، عَنْ النُّعْمَانِ بْنِ سَالِمٍ  ، قَالَ : قُلْتُ لِابْنِ عُمَرَ   : "" أَرَأَيْتَرَجُلًا تَرَكَ ابْنَ ابْنَتِهِ، أَيَرِثُهُ؟ قَالَ : لا """,,takhreej: ! متفق علیہ: البخاری،کتاب النکاح،باب ترویج المعسرم(الحدیث5087)ومسلم،کتاب النکاح،باب الصداق وجواز کونہ تعلیم قران وخاتم حدید…(الحدیث3472), 2248,"حَدَّثَنَا يَعْلَى  ، حَدَّثَنَا الْأَعْمَشُ  ، عَنْ إِبْرَاهِيمَ  ، قَالَ : قَالَ عَبْدُ اللَّهِ   :"" الْأُمُّ عَصَبَةُ مَنْ لَا عَصَبَةَ لَهُ، وَالْأُخْتُ عَصَبَةُ مَنْ لَا عَصَبَةَ لَهُ """,,takhreej: !اسنادہ منقطع: لیکن حدیث صحیح ہے۔ ابوداؤد،کتاب النکاح،باب فی خطبۃ النکاح (الحدیث 2118) والنسائی، کتاب الجمعۃ، باب کیفیۃ الخطبۃ(الحدیث1403), 2249,"حَدَّثَنَا مُسْلِمُ بْنُ إِبْرَاهِيمَ  ، حَدَّثَنَا وُهَيْبٌ  ، حَدَّثَنَا ابْنُ طَاوُسٍ  ، عَنْ أَبِيهِ  ، عَنْ ابْنِ عَبَّاسٍ  ، عَنِ النَّبِيِّ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ، قَالَ :"" أَلْحِقُوا الْفَرَائِضَ بِأَهْلِهَا، فَمَا بَقِي، فَهُوَ لِأَوْلَى رَجُلٍ ذَكَرٍ """,,takhreej: ! متفق علیہ: البخاری،کتاب الشروط،باب الشروط فی المہر عند عقدۃ النکاح(الحدیث2721)ومسلم،کتاب النکاح، باب الوفاء بالشروط فی النکاح(الحدیث3457), 2250,"أَخْبَرَنَا يَزِيدُ بْنُ هَارُونَ  ، حَدَّثَنَا يَحْيَى  : أَنَّ سُلَيْمَانَ بْنَ يَسَارٍ  أَخْبَرَهُ، عَنْ مُحَمَّدِ بْنِ الْأَشْعَثِ  : أَنَّ عَمَّةً لَهُ تُوُفِّيَتْ يَهُودِيَّةً بِالْيَمَنِ ، فَذَكَرَ ذَلِكَ لِعُمَرَ بْنِ الْخَطَّابِ   فَقَالَ :"" يَرِثُهَا أَقْرَبُ النَّاسِ إِلَيْهَا مِنْ أَهْلِ دِينِهَا """,,takhreej: @متفق علیہ: البخاری،کتاب النکاح،باب کیف یدعی للمتزوج(الحدیث5155)ومسلم،کتاب النکاح،باب الصداق وجواز کونہ تعلیم قران وخاتم الحدید(الحدیث3475), 2251,"حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ  ، حَدَّثَنَا سُفْيَانُ  ، عَنْ قَيْسِ بْنِ مُسْلِمٍ  ، عَنْ طَارِقِ بْنِ شِهَابٍ  ، قَالَ : مَاتَتْ عَمَّةُ الْأَشْعَثِ بْنِ قَيْسٍ وَهِيَ يَهُودِيَّة، فَأَتَى عُمَرَ بْنَ الْخَطَّاب  ، فَقَالَ :"" أَهْلُ دِينِهَا يَرِثُونَهَا """,,takhreej: ! متفق علیہ: البخاری،کتاب النکاح،باب حق اجابۃ الولیمۃ والدعوۃ(الحدیث5173)ومسلم،کتاب النکاح،باب الأمر باجابۃ الداعی إلیٰ دعوۃ(الحدیث2495)ابوداؤد،کتاب الأطعمۃ،باب ماجاء فی اجابۃ الدعوۃ(الحدیث3736), 2252,"حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ  ، حَدَّثَنَا سُفْيَانُ  ، عَنْ حَمَّادٍ  ، عَنْ إِبْرَاهِيمَ  ، قَالَ : قَالَ عُمَرُ بْنُ الْخَطَّابِ   :"" أَهْلُ الشِّرْكِ لَا نَرِثُهُمْ، وَلَا يَرِثُونَا """,,takhreej: !صحیح کتاب النکاح،باب فی القسم بین النساء (الحدیث3133)الترمذی،کتاب النکاح،باب ماجاء فی التسویۃ بین الضوائر (الحدیث1141)صحیح ابن حباین(الحدیث4207), 2253,"حَدَّثَنَا أَبُو نُعَيْمٍ  ، حَدَّثَنَا حَسَنٌ  ، عَنْ عِيسَى الْخياط  ، عَنْ الشَّعْبِيِّ   : "" أَنَّ رَسُولَ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ، وَأَبَا بَكْرٍ، وَعُمَرَ، قَالُوا :لَا يَتَوَارَثُ أَهْلُ دِينَيْنِ """,,takhreej: !صحیح: ابوداؤد،کتاب النکاح،باب فی القسم بین النسائ(الحدیث2134)النسائی،فی عشرۃ النسائ… (الحدیث 5) وصحیح ابن حبان(الحدیث4205), 2254,"حَدَّثَنَا أَبُو نُعَيْمٍ  ، حَدَّثَنَا زُهَيْرٌ  ، عَنْ مُطَرِّفٍ  ، عَنْ عَامِرٍ  ، عَنْ عُمَرَ  ، قَالَ :"" لَا يَتَوَارَثُ أَهْلُ مِلَّتَيْنِ """,,takhreej: @متفق علیہ : البخاری،کتاب النکاح،باب الترمذی،بین النسائی اذا اراد سفرا(الحدیث5211)ومسلم فی التوبۃ،باب فی حدیث الافک وقبول توبۃ القازف(الحدیث2770), 2255,"أَخْبَرَنَا أَبُو نُعَيْمٍ  ، حَدَّثَنَا شَرِيكٌ  ، عَنْ الْأَشْعَثِ  ، عَنْ الْحَسَنِ  ، عَنْ جَابِرٍ  ، قَالَ :"" لَا نَرِثُ أَهْلَ الْكِتَابِ وَلَا يَرِثُونَا، إِلَّا أَنْ يَمُوتَ لِلرَّجُلِ عَبْدُهُ أَوْ أَمَتُهُ """,,takhreej: !متفق علیہ: اخرجہ البخاریکتاب النکاح،باب اذا تزوج البکر علی الثیب(الحدیث5213)ومسلم،کتاب الرضائ،باب قدر ما تستحقہ البکرو الثیب من إقامۃ الزوج عندہا عقب الزفاف (الحدیث1461), 2256,"حَدَّثَنَا مُحَمَّدُ بْنُ عِيسَى  ، حَدَّثَنَا شَرِيكٌ  ، عَنْ الْأَشْعَثِ  ، عَنْ الْحَسَنِ  ، عَنْ جَابِرٍ  ، قَالَ : قَالَ رَسُولُ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ :"" لَا نَرِثُ أَهْلَ الْكِتَابِ وَلَا يَرِثُونَا، إِلَّا الرَّجُلُ يَرِثُ عَبْدَهُ، أَوْ أَمَتَهُ """,,takhreej: @صحیح مسلم،کتاب الرضاع،باب قدر ماتستحقہ البکروا الشیب…(الحدیث3606)وابن ماجہ،کتاب النکاح،باب الاقامۃ علی البکر والثیب(الحدیث1917), 2257,"حَدَّثَنَا سُلَيْمَانُ بْنُ حَرْبٍ  ، حَدَّثَنَا حَمَّادُ بْنُ سَلَمَةَ  ، عَنْ دَاوُدَ  ، عَنْ الشَّعْبِيِّ  ، عَنْ مَسْرُوقٍ  ، قَالَ : "" كَانَ مُعَاوِيَةُ  يُوَرِّثُ الْمُسْلِمَ مِنْ الْكَافِرِ، وَلَا يُوَرِّثُ الْكَافِرَ مِنْ الْمُسْلِمِ، قَالَ : قَالَ مَسْرُوقٌ : وَمَا حَدَثَ فِي الْإِسْلَامِ قَضَاءٌ أَحَبُّ إِلَيَّ مِنْهُ، قِيلَ لِأَبِي مُحَمَّدٍ : تَقُولُ بِهَذَا؟ قَالَ : لا",,takhreej: !صحیح مسلم،کتاب النکاح،باب استحباب التزوج والتزویج فی شوال(الحدیث3468)والنسائی،کتاب النکاح،باب التزویج فی شوال(الحدیث3236), 2258,"حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ  ، عَنْ دَاوُدَ بْنِ أَبِي هِنْدٍ  ، عَنْ عَامِرٍ  : أَنَّ الْمُعْزِلَةَ بِنْتَ الْحَارِثِ تُوُفِّيَتْ بِالْيَمَنِ وَهِيَ يَهُودِيَّةٌ، فَرَكِبَ الْأَشْعَثُ بْنُ قَيْسٍ، وَكَانَتْ عَمَّتَهُ، إِلَى عُمَرَ فِي مِيرَاثِهَا، فَقَالَ عُمَرُ   : "" لَيْسَ ذَاكَ لَكَ،يَرِثُهَا أَقْرَبُ النَّاسِ مِنْهَا مِنْ أَهْلِ دِينِهَا، لَا يَتَوَارَثُ مِلَّتَانِ """,,takhreej: @ متفق علیہ: البخاری، کتاب بدء الخلق،باب ابلیس وجنودہ (الحدیث3271) ومسلم،کتاب النکاح،باب مایستحب أیقولہ عند الجماع(الحدیث3591), 2259,"حَدَّثَنَا سُلَيْمَانُ بْنُ حَرْبٍ  ، حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ  ، حَدَّثَنَا أَنَسُ بْنُ سِيرِينَ  ، قَالَ : قَالَ عُمَرُ بْنُ الْخَطَّابِ   :"" لَا يَتَوَارَثُ مِلَّتَانِ شَتَّى، وَلَا يَحْجُبُ مَنْ لَا يَرِثُ """,,takhreej: ! اسنادہ جید: صحیح ابن حبان(الحدیث4200-4198)ابن ماجہ ،کتاب النکاح،باب النہی عن اتیان النساء فی ادبار ہن (الحدیث1934), 2260,"حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ  ، حَدَّثَنَا عَبْدُ الْأَعْلَى  ، عَنْ مَعْمَرٍ  ، عَنْ الزُّهْرِيِّ  ، عَنْ عَلِيِّ بْنِ حُسَيْنٍ  ، عَنْ عَمْرِو بْنِ عُثْمَانَ  ، عَنْ أُسَامَةَ بْنِ زَيْدٍ   أَنّ رَسُولَ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ، قَالَ :"" لَا يَرِثُ الْمُسْلِمُ الْكَافِرَ، وَلَا الْكَافِرُ الْمُسْلِمَ """,,takhreej: @متفق علیہ : البخاری،کتاب التفسیر،باب( نساء و کم حرث لکم…)(الحدیث4528)ومسلم،کتاب النکاح،باب جواز جماعہ امراتہ فی قبلہ(الحدیث3421), 2261,"حَدَّثَنَا جَعْفَرُ بْنُ عَوْنٍ ، عَنْ سَعِيدٍ ، عَنْ أَبِي مَعْشَرٍ ،  عَنْ إِبْرَاهِيمَ ، قَالَ :"" إِذَا مَاتَ الْمَيِّتُ وَجَبَتْ الْحُقُوقُ لِأَهْلِهَا، وَلَمْ يَجْعَلْ لِمَنْ أَسْلَمَ أَوْ أُعْتِقَ قَبْلَ أَنْ يُقْسَمَ الْمِيرَاثُ شَيْئًا """,,takhreej: ! اسنادہ حسن: عبداللہ بن حلام کو بخاری نے’’تاریخ کبیر‘‘5/69میں اور ابن ابی حاتم نے ’’الجرح والتعدیل‘‘ 5/40میں اس کا تذکرہ کیا ہے۔لیکن کوئی جرح یاتعدیل ذکر نہیں کی جبکہ ابن حبان نے اسے الثقات5/27 میں ذکر کیا ہے۔, 2262,"أَخْبَرَنَا مُحَمَّدُ بْنُ يُوسُفَ  ، حَدَّثَنَا سُفْيَانُ  ، عَنْ عَبْدِ اللَّهِ بْنِ عِيسَى  ، عَنْ الزُّهْرِيِّ  ، عَنْ عَلِيِّ بْنِ حُسَيْنٍ  ، عَنْ أُسَامَةَ بْنِ زَيْدٍ  ، قَالَ : قَالَ رَسُولُ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ :"" لَا يَرِثُ الْمُسْلِمُ الْكَافِرَ، وَلَا الْكَافِرُ الْمُسْلِمَ """,,takhreej: !صحیح مسلم،کتاب الرضاع،باب استحباب النکاح ذات الدین(الحدیث3621)والبخاری،کتاب المغاز،باب(اذا ہمت طائفتان منکم إن تقشلا…(الحدیث4052), 2263,"حَدَّثَنَا عَمْرُو بْنُ عَوْنٍ  ، حَدَّثَنَا سُفْيَانُ  ، عَنْ الزُّهْرِيِّ  ، عَنْ عَلِيِّ بْنِ حُسَيْنٍ  ، عَنْ عَمْرِو بْنِ عُثْمَانَ  ، عَنْ أُسَامَةَ بْنِ زَيْدٍ  ، عَنِ النَّبِيِّ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ، قَالَ :"" لَا يَرِثُ الْمُسْلِمُ الْكَافِرَ، وَلَا الْكَافِرُ الْمُسْلِمَ """,,takhreej: ! صحیح مسلم،کتاب النکاح،باب جواز الغیلۃ وہی وطء المرضع وکراہۃ العزل (الحدیث3549)ومالک فی الرضاع،باب ماجاء فی الرضاعتہ(16), 2264,"حَدَّثَنَا أَبُو النُّعْمَانِ ، حَدَّثَنَا أَبُو عَوَانَةَ ، عَنْ مُغِيرَةَ ،  عَنْ إِبْرَاهِيمَ ، قَالَ :"" لَيْسَ لِلْمُكَاتَبِ مِيرَاثٌ، مَا بَقِيَ عَلَيْهِ شَيْءٌ مِنْ مُكَاتَبَتِهِ """,,takhreej: @ صحیح مسلم،کتاب الفضائل،باب مباعدتہ ﷺ للآثام واختیارہ من المباح أسہلہ(الحدیث6004), 2265,"حَدَّثَنَا يَعْلَى  ، حَدَّثَنَا عَبْدُ الْمَلِكِ  ، عَنْ عَطَاءٍ   : "" فِي رَجُلٍ لَهُ بَنُونَ قَدْ أَعْتَقَ مِنْ بَعْضِهِمْ النِّصْفَ، وَمِنْ بَعْضٍ الثُّلُثَ، وَمِنْ بَعْضٍ الرُّبُعَ، قَالَ :لَا يَرِثُونَ حَتَّى يُعْتَقُوا """,,takhreej: ! صحیح: ابوداؤد،کتاب النکاح،باب فی ضرب النسائ(الحدیث2146)صحیح ابن حبان(4189), 2266,"حَدَّثَنَا عبد الله بن جعفر الرقي ، وَسَعِيدُ بْنُ الْمُغِيرَةِ ، عَنْ ابْنِ الْمُبَارَكِ ، عَنْ مَعْمَرٍ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاهِيمَ  : "" فِي رَجُلٍ اشْتَرَى ابْنَهُ فِي مَرَضِهِ، قَالَ :إِنْ خَرَجَ مِنْ الثُّلُثِ وَرِثَهُ، وَإِنْ وَقَعَتْ عَلَيْهِ السِّعَايَةُ لَمْ يَرِثْ """,,takhreej: @متفق علیہ: البخاری،کتاب التفسیر،باب (والشمس وضحاہا)(الحدیث4942)ومسلم،کتاب الجنۃ وصفۃ نعیمہا، باب النار یدخلہا الجبارون والجنۃ یدخلہا الضعفائ(الحدیث7120), 2267,"حَدَّثَنَا أَبُو نُعَيْمٍ ، حَدَّثَنَا حَسَنٌ ، عَنْ أَبِيهِ ، عَنْ الشَّعْبِيِّ ، قَالَ :"" حَدُّ الْمُكَاتَبِ حَدُّ الْمَمْلُوكِ، حَتَّى يُعْتَقَ """,,takhreej: ! اسنادہ صحیح: اخرجہ احمد5/151والنسائی فی ععشرۃ النسائ(270), 2268,"حَدَّثَنَا مُحَمَّدُ بْنُ عِيسَى  ، حَدَّثَنَا سَعِيدُ بْنُ عَبْدِ الرَّحْمَنِ  ، حَدَّثَنَا يُونُسُ  ، عَنْ الزُّهْرِيِّ  ، قَالَ : قَالَ النَّبِيُّ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ :"" الْمَوْلَى أَخٌ فِي الدِّينِ وَنِعْمَةٌ، أَحَقُّ النَّاسِ بِمِيرَاثِهِ أَقْرَبُهُمْ مِنْ الْمُعْتِقِ """,,takhreej: @متفق علیہ : البخاری،کتاب النکاح،باب الوصاۃ بالنسائ(الحدیث5185)ومسلم،کتاب الرضاع،باب الوصیۃ بالنسائ(الحدیث3631), 2269,"حَدَّثَنَا مُحَمَّدُ بْنُ عِيسَى ، حَدَّثَنَا هُشَيْمٌ ، حدثنا مَنْصُورٌ ، عَنْ الْحَسَنِ ، وَمُحَمَّدُ بْنُ سَالِمٍ ، عَنْ الشَّعْبِيِّ  فِي رَجُلٍ أَعْتَقَ مَمْلُوكًا، ثُمَّ مَاتَ الْمَوْلَى وَالْمَمْلُوكُ، وَتَرَكَ الْمُعْتِقُ أَبَاهُ وَابْنَهُ، قَالَا :"" الْمَالُ لِلِابْنِ """,,takhreej: ! متفق علیہ : البخاری،کتاب التوحید،باب قول اللہ تعالیٰ(ہو اللہ الخالق الباری المصور) (الحدیث7409) ومسلم، کتاب النکاح ، باب حکم العزل(الحدیث3538), 2270,"حَدَّثَنَا مُحَمَّدُ بْنُ عِيسَى  ، حَدَّثَنَا عَبَّادٌ  ، عَنْ عُمَرَ بْنِ عَامِرٍ  ، عَنْ قَتَادَةَ  ، عَنْ سَعِيدِ بْنِ الْمُسَيِّبِ  ، عَنْ زَيْدِ بْنِ ثَابِتٍ   فِي رَجُلٍ تَرَكَ أَبَاهُ وَابْنَ ابْنِهِ، فَقَالَ :"" الْوَلَاءُ لِابْنِ الِابْنِ """,,takhreej: !صحیح مسلم،کتاب النکاح،باب حکم العزل(الحدیث3535)النسائی،کتاب النکاح،باب العزل(الحدیث3327), 2271,"حَدَّثَنَا مُحَمَّدُ بْنُ عِيسَى  ، حَدَّثَنَا مُعَمَّرٌ  ، حَدَّثَنَا خُصَيْفٌ  ، عَنْ زِيَادِ بْنِ أَبِي مَرْيَمَ   : أَنَّ امْرَأَةً أَعْتَقَتْ عَبْدًا لَهَا، ثُمَّ تُوُفِّيَتْ وَتَرَكَتْ ابْنَهَا وَأَخَاهَا، ثُمَّ تُوُفِّيَ مَوْلَاهَا، فَأَتَى النَّبِيَّ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ ابْنُ الْمَرْأَةِ وَأَخُوهَا فِي مِيرَاثِهِ، فَقَالَ النَّبِيُّ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ :"" مِيرَاثُهُ لِابْنِ الْمَرْأَةِ، فَقَالَ أَخُوهَا : يَا رَسُولَ اللَّه، ِلَوْ أَنَّهُ جَرَّ جَرِيرَةً، عَلَى مَنْ كَانَتْ؟ قَالَ : عَلَيْكَ """,,takhreej: @متفق علیہ: البخاری،کتاب النکاح،باب الغیرۃ(الحدیث5220)ومسلم،کتاب التوبۃ،باب غیرۃ اللہ تعالیٰ وتحریم الفواحش(الحدیث6926), 2272,"حَدَّثَنَا مُحَمَّدُ بْنُ الصَّلْتِ ، حَدَّثَنَا هُشَيْمٌ ، أَخْبَرَنَا مُغِيرَةُ ، قَالَ : سَأَلْتُ إِبْرَاهِيمَ  "" عَنْ رَجُلٍ أَعْتَقَ مَمْلُوكًا لَهُ، فَمَاتَ وَمَاتَ الْمَوْلَى، فَتَرَكَ الْمُعْتِقُ أَبَاهُ وَابْنَهُ، فَقَالَ لِأَبِيهِ :كَذَا، وَمَا بَقِيَ فَلِابْنِهِ """,,takhreej: !جیدصحیح: ابن حبان(الحدیث295)وابوداؤد،کتاب الجہاد،باب فی الخیلاء فی الحرب(الحدیث2659), 2273,"حَدَّثَنَا مُحَمَّدُ بْنُ الصَّلْتِ  ، حَدَّثَنَا هُشَيْمٌ  ، عَنْ شُعْبَةَ  قَالَ : سَمِعْتُ الْحَكَمَ  ، وَحَمَّادًا   ، يَقُولَانِ :"" هُوَ لِلِابْنِ """,,takhreej: @ متفق علیہ: البخاری،کتاب التوحید،باب قولہ النبی ﷺ لاشخص اغیر من اللہ (الحدیث7416)ومسلم فی اللعان (الحدیث1499)واحمد4/248, 2274,"أَخْبَرَنَا يَزِيدُ بْنُ هَارُونَ  ، أَنْبَأَنَا الْأَشْعَثُ  ، عَنْ الْحَسَن   "" : أَنَّ النَّبِيَّ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ "" خَرَجَ إِلَى الْبَقِيعِ ، فَرَأَى رَجُلًا يُبَاعُ، فَأَتَاهُ فَسَاوَمَ بِهِ، ثُمَّ تَرَكَهُ فَرَآهُ رَجُلٌ فَاشْتَرَاهُ فَأَعْتَقَهُ، ثُمَّ جَاءَ بِهِ إِلَى النَّبِيِّ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ فَقَالَ : إِنِّي اشْتَرَيْتُ هَذَا فَأَعْتَقْتُهُ، فَمَا تَرَى فِيهِ؟ فَقَالَ :هُوَ أَخُوكَ وَمَوْلَاكَ، قَالَ : مَا تَرَى فِي صُحْبَتِهِ؟ قَالَ : إِنْ شَكَرَكَ فَهُوَ خَيْرٌ لَهُ وَشَرٌّ لَكَ، وَإِنْ كَفَرَكَ فَهُوَ خَيْرٌ لَكَ وَشَرٌّ لَهُ، قَالَ : مَا تَرَى فِي مَالِهِ؟ قَالَ : إِنْ مَاتَ وَلَمْ يَتْرُكْ عَصَبَةً فَأَنْتَ وَارِثُهُ """,,takhreej: !متفق علیہ : البخاری،کتاب النکاح،باب اذا باتت المرأۃ مجاہرۃ فراش زوجہا (الحدیث4194)ومسلم،کتاب النکاح،باب تحریم امتنا عہا من فراش زوجہا(الحدیث3524), 2275,"أَخْبَرَنَا يَزِيدُ بْنُ هَارُونَ  ، أَنْبَأَنَا أَشْعَثُ  ، عَنْ الْحَكَمِ  ، وَسَلَمَةَ بْنِ كُهَيْلٍ  ، عَنْ عَبْدِ اللَّهِ بْنِ شَدَّادٍ   : أَنَّ ابْنَةَ حَمْزَةَ أَعْتَقَتْ عَبْدًا لَهَا، فَمَاتَ وَتَرَكَ ابْنَتَهُ وَمَوْلَاتَهُ بِنْتَ حَمْزَةَ ، ""فَقَسَمَ رَسُولُ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ مِيرَاثَهُ بَيْنَ ابْنَتِهِ وَمَوْلَاتِهِ بِنْتِ حَمْزَةَ نِصْفَيْنِ """,,takhreej: ! متفق علیہ: البخاری،کتاب الأحکام،باب من قضی فی المسجد(الحدیث7165)ومسلم،کتاب اللعان،فی فاتحتہ (الحدیث3723) وابوداؤد،کتاب الطلاق،باب فی اللعان(الحدیث2245), 2276,"حَدَّثَنَا مُحَمَّدُ بْنُ عُيَيْنَةَ  ، عَنْ عَلِيِّ بْنِ مُسْهِرٍ  ، عَنْ الشَّيْبَانِيِّ  ، عَنْ الْحَكَمِ  ، عَنْ شَمُوسَ الْكِنْدِيَّةِ L1465 ، قَالَتْ : "" قَاضَيْتُ إِلَى عَلِيٍّ   فِي أَبٍ مَاتَ فَلَمْ يَدَعْ أَحَدًا غَيْرِي، وَمَوْلَاهُ،فَأَعْطَانِي النِّصْفَ، َوَأَعْطَى مَوْلَاهُ النِّصْفَ """,,takhreej: @صحیح: سابقہ حدیث ہی مکرر آئی ہے۔, 2277,"أَخْبَرَنَا مُحَمَّدُ بْنُ عُيَيْنَةَ  ، عَنْ عَلِيِّ بْنِ مُسْهِرٍ  ، عَنْ ابْنِ أَبِي لَيْلَى  ، عَنْ الْحَكَمِ  ، عَنْ أَبِي الْكَنُودِ  ، عَنْ عَلِيٍّ   : "" أَنَّهُ أُتِيَ بِابْنَةٍ وَمَوْلًى،فَأَعْطَى الِابْنَةَ النِّصْفَ، وَالْمَوْلَى النِّصْفَ، قَالَ الْحَكَمُ : فَمَنْزِلِي هَذَا نَصِيبُ الْمَوْلَى الَّذِي وَرِثَهُ عَنْ مَوْلَاهُ",,takhreej: !صحیح : اخرجہ مسلم،کتاب اللعان، کے شروع میں (الحدیث3726)والترمذی،کتاب الطلاق،باب ماجاء فی اللعان (الحدیث1202), 2278,"أَخْبَرَنَا إِبْرَاهِيمُ بْنُ مُوسَى  ، عَنْ ابْنِ إِدْرِيسَ  ، عَنْ أَشْعَثَ  ، عَنْ الْحَكَمِ  ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ مُدْلِجٍ : أَنَّهُ مَاتَ وَتَرَكَ ابْنَتَهُ وَمَوَالِيَهُ،فَأَعْطَى عَلِيٌّ   ابْنَتَهُ النِّصْفَ وَمَوَالِيَهُ النِّصْفَ """,,takhreej: !متفق علیہ : البخاری،کتاب الطلاق،باب یلحق ابو لد بالملاعنۃ(الحدیث5315)ومسلم،کتاب اللعان کے شروع میں ہی(الحدیث1831)وابن ماجہ،کتاب الطلاق،باب اللعان(الحدیث2069), 2279,"حَدَّثَنَا إِبْرَاهِيمُ  ، عَنْ ابْنِ إِدْرِيسَ  ، عَنْ الشَّيْبَانِيِّ  ، عَنْ الْحَكَمِ  ، عَنْ الشَّمُّوسِ L1465  : "" أَنَّ أَبَاهَا مَاتَ،فَجَعَلَ عَلِيٌّ   لَهَا النِّصْفَ وَلِمَوَالِيهِ النِّصْفَ """,,takhreej: @حسن : ابوداؤد،کتاب النکاح،باب فی نکاح العید بغیر اذن سیدہ(الحدیث2078)وابن ابی شیبہ4/261باب من کرہ للعبد أیتزج بغیر اذن سیدہ, 2280,"حَدَّثَنَا مُحَمَّدُ بْنُ عِيسَى ، حَدَّثَنَا حَفْصُ بْنُ غِيَاثٍ ، حَدَّثَنَا أَشْعَثُ ، عَنْ جَهْمِ بْنِ دِينَارٍ ، عَنْ إِبْرَاهِيمَ  : أَنَّهُ "" سُئِلَ عَنْ أُخْتَيْنِ اشْتَرَتْ إِحْدَاهُمَا أَبَاهَا فَأَعْتَقَتْهُ، ثُمَّ مَاتَ، قَالَ لَهُمَا :الثُّلُثَانِ فَرِيضَتُهُمَا فِي كِتَابِ اللَّهِ، وَمَا بَقِيَ فَلِلْمُعْتِقَةِ دُونَ الْأُخْرَى """,,takhreej: #ضعیف ابوداؤد: میں اس معنی کی حدیث ہے جسے ابوداؤد مرفوعًا ضعیف قرار دیتے ہیں صحیح یہ ہے کہ وہ موقوف ہے جیسا کہ بیہقی میں بھی ابوداؤد کی سند سے ہے۔کتاب النکاح،باب نکاح العبد بغیراذن مالکہ(7/127نیز مصنف عبدالرزاق(12982) میں بھی ابن عمر رضی اللہ عنہما سے موقوفًا یہ روایت مروی ہے۔, 2281,"حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ ، حَدَّثَنَا إِسْرَائِيلُ ، حَدَّثَنَا الْأَشْعَثُ ، عَنْ الشَّعْبِيِّ  : "" فِي امْرَأَةٍ أَعْتَقَتْ أَبَاهَا، فَمَاتَ الْأَبُ وَتَرَكَ أَرْبَعَ بَنَاتٍ هِيَ إِحْدَاهُنَّ، قَالَ :لَيْسَ عَلَيْهِ مِنَّةٌ، لَهُنَّ الثُّلُثَانِ، وَهِيَ مَعَهُنَّ """,,takhreej: !صحیح مسلم،کتاب الرضاع،باب الولد للفراش(الحدیث3600), 2282,"حَدَّثَنَا أَبُو نُعَيْمٍ  ، حَدَّثَنَا زُهَيْرٌ  ، عَنْ حَيَّانَ بْنِ سَلْمَانَ L2590 ، قَالَ : كُنْتُ عِنْدَ سُوَيْدِ بْنِ غَفَلَةَ  ، فَجَاءَهُ رَجُلٌ، فَسَأَلَهُ عَنْ "" فَرِيضَةِ رَجُلٍ تَرَكَ ابْنَتَهُ وَامْرَأَتَه، فَقَالَ : أَنَا أُنْبِئُكَ قَضَاءَ عَلِيٍّ  ، قَالَ : حَسْبِي قَضَاءُ عَلِيٍّ، قَالَ : قَضَى عَلِيٌّلِامْرَأَتِهِ الثُّمُنَ، وَلِابْنَتِهِ النِّصْفَ، ثُمَّ رَدَّ الْبَقِيَّةَ عَلَى ابْنَتِهِ """,,takhreej: @صحیح البخاری،کتاب البیوع،باب شراء المملوک من الحربی وہبتہ وعتقہ(الحدیث2218)والنسائی،کتاب الطلاق،باب الحاق الولد بالفراش اذا لم ینفہ (الحدیث3484), 2283,"حَدَّثَنَا عُبَيْدُ اللَّهِ ، عَنْ إِسْرَائِيلَ ، عَنْ أَبِي الْهَيْثَمِ ،  عَنْ إِبْرَاهِيمَ  : أَنَّ مَوْلَاةً لِإِبْرَاهِيمَ تُوُفِّيَتْ وَتَرَكَتْ مَالًا، فَقُلْتُ لِإِبْرَاهِيمَ، فَقَالَ :"" إِنَّ لَهَا ذَا قَرَابَةٍ """,,takhreej: !صحیح: (1179) حدیث ہی مطول دوبارہ واردہوئی ہے۔, 2284,"أَخْبَرَنَا يَزِيدُ بْنُ هَارُونَ  ، حَدَّثَنَا أَشْعَثُ  ، عَنْ الشَّعْبِيِّ  ، عَنْ عُمَرَ  ، وَعَلِيٍّ  ، وَزَيْدٍ  ، قَالَ : وَأَحْسَبُهُ قَدْ ذَكَرَ عَبْدَ اللَّهِ   أَيْضًا : أَنَّهُمْ قَالُوا :"" الْوَلَاءُ لِلْكُبْرِ. يَعْنُونَ بِالْكُبْرِ : مَا كَانَ أَقْرَبَ بِأَبٍ أَوْ أُمٍّ """,,takhreej: @اسنادہ جید: صحیح ابن حبان(الحدیث4108)والنسائی،کتاب الطلاق،باب التغلیظ فی الانتفاء من الولد (الحدیث3481), 2285,"حَدَّثَنَا يَزِيدُ  ، حَدَّثَنَا أَشْعَثُ  ، عَنْ ابْنِ سِيرِينَ  ، عَنْ عَبْدِ اللَّهِ بْنِ عُتْبَةَ  ، قَالَ : "" كَتَبَ إِلَيَّ عُمَرُ فِي شَأْنِ فُكَيْهَةَ بِنْتِ سَمْعَانَ أَنَّهَا مَاتَتْ وَتَرَكَتْ ابْنَ أَخِيهَا لِأَبِيهَا وَأُمِّهَا، وَابْنَ أَخِيهَا لِأَبِيهَا، فَكَتَبَ عُمَرُ   :إِنَّ الْوَلَاءَ لِلْكُبْرِ """,,takhreej: !حسن: اس کی سند شرط پر ہے۔ صحیح : ابن حبان (الحدیث4112) والنسائی،کتاب النکاح،باب نکاح مانکح الآباء (الحدیث 3332), 2286,"حَدَّثَنَا أَحْمَدُ بْنُ عَبْدِ اللَّهِ  ، حَدَّثَنَا أَبُو شِهَابٍ  ، عَنْ الشَّيْبَانِيِّ  ، عَنْ الشَّعْبِيِّ  : أَنَّ عَلِيًّا  ، وَزَيْدًا   قَالَا :"" الْوَلَاءُ لِلْكُبْر "". وَقَالَ عَبْدُ اللَّهِ  ، وَشُرَيْحٌ   : لِلْوَرَثَةِ",,takhreej: !ضعیف: عبداللہ بن احمد نے اسے مسند کی زوائد میں5/133اور بخاری نے تاریخ الکبیر میں3/360-359میں اسے روایت کیا ہے۔, 2287,"حَدَّثَنَا مُحَمَّدُ بْنُ عُيَيْنَةَ  ، عَنْ عَلِيِّ بْنِ مُسْهِرٍ  ، عَنْ أَشْعَثَ  ، عَنِ الشَّعْبِيِّ  ، قَالَ : "" قَضَى عُمَر  ، وَعَبْدُ اللَّهِ  ، وَعَلِيٌّ  ، وَزَيْدٌ  لِلْكُبْرِ بِالْوَلَاءِ """,,takhreej: @صحیح: ابن جریج سے صراحت سماع بھی طبری کے ہاں موجود ہے۔ ابن حبان(6366)وموارد الظمآن(2126), 2288,"حَدَّثَنَا أَبُو نُعَيْمٍ  ، حَدَّثَنَا شَرِيكٌ  ، عَنْ أَشْعَثَ  ، عَنْ ابْنِ سِيرِينَ  ، قَالَ : "" تُوُفِّيَتْ فُكَيْهَةُ بِنْتُ سَمْعَانَ وَتَرَكَتْ ابْنَ أَخِيهَا لِأَبِيهَا، وَبَنِي بَنِي أَخِيهَا لِأَبِيهَا وَأُمِّهَا،فَوَرَّثَ عُمَرُ   بَنِي أَخِيهَا لِأَبِيهَا """,,takhreej: # متفق علیہ: البخاری،کتاب النکاح،باب من جعل عتق الامۃ صداقہا(الحدیث5086)ومسلم،کتاب النکاح،باب فضیلۃ اعتاقہ أمۃ ثم یتزوجہا(الحدیث2054)ابن ماجہ،کتاب النکاح،باب الرجل یعتق امتہ ثم یتزوجہا (الحدیث1957), 2289,"حَدَّثَنَا مُحَمَّدُ بْنُ عِيسَى  ، حَدَّثَنَا عَبْدُ السَّلَامِ بْنُ حَرْبٍ  ، عَنْ الْأَعْمَشِ  ، عَنْ إِبْرَاهِيمَ  ،  عَنْ عُمَرَ  ، وَعَلِيٍّ  ، وَزَيْدٍ   : أَنَّهُمْ قَالُوا :"" الْوَلَاءُ لِلْكُبْرِ """,,takhreej: ! صحیح: تخریج ابھی گزر چکی ہے۔, 2290,"حَدَّثَنَا مُحَمَّدُ بْنُ عِيسَى  ، حَدَّثَنَا أَبُو عَوَانَةَ  ، عَنْ مُغِيرَةَ  ، عَنْ إِبْرَاهِيمَ  : "" فِي أَخَوَيْنِ وَرِثَا مَوْلًى كَانَ أَعْتَقَهُ أَبُوهُمَا، فَمَاتَ أَحَدُهُمَا وَتَرَكَ وَلَدًا، قَالَ : كَانَ عَلِيٌّ  ، وَزَيْدٌ  ، وَعَبْدُ اللَّهِ   ، يَقُولُونَ :"" الْوَلاءُ لِلْكَبِر """,,takhreej: !متفق علیہ: البخاری،کتاب العلم،باب تعلیم الرجل امتہ وأہلہ(الحدیث97)ومسلم،کتاب وجوب الایمان برسالۃ…(الحدیث385)والترمذی،کتاب النکاح،باب ماجاء فی الفضل فی ذلک(الحدیث116), 2291,"حَدَّثَنَا مُحَمَّدُ بْنُ عِيسَى  ، حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ  ، قَالَ : سَمِعْتُ مَطَرًا الْوَرَّاقَ  ، يَقُولُ : قَالَ عُمَرُ  ، وَعَلِيٌّ   :"" الْوَلاءُ لِلْكِبَرِ """,,takhreej: @سابقہ حدیث کے مطابق تخریج ہے۔, 2292,"أَخْبَرَنَا مُحَمَّدُ بْنُ عِيسَى ، عَنْ رَوْحٍ ، عَنْ ابْنِ جُرَيْجٍ ، عَنْ عَطَاءٍ ، وَابْنِ جُرَيْجٍ ، عَنْ ابْنِ طَاوُسٍ ، عَنْ أَبِيهِ ، قَالَ :"" الْوَلَاءُ لِلْكُبْرِ """,,takhreej: !صحیح: ابن حبان(4099-1498) والنسائی،کتاب النکاح،باب اباحتہ التزویج بغیر صداق(الحدیث3354), 2293,"أَخْبَرَنَا عُبَيْدُ اللَّهِ بْنُ مُوسَى ، عَنْ إِسْرَائِيلَ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاهِيمَ ، قَالَ :"" الْوَلَاءُ لِلْكُبْرِ """,,takhreej: !متفق علیہ: البخاری،کتاب الشہادات،باب الشہادۃ علی الأنساب والرضاع المستفیض والموت القدیم (الحدیث 2646) ومسلم،کتاب الرضاع،باب یحرم من الرضاعتہ ما یحرم من الولادۃ(الحدیث3553), 2294,"حَدَّثَنَا أَبُو نُعَيْمٍ  ، حَدَّثَنَا سُفْيَانُ  ، عَنْ مُطَرِّفٍ  ، عَنْ الشَّعْبِيِّ  ، وَسُفْيَانُ  ، عَنْ يُونُسَ  ، عَنْ الْحَسَنِ   فِي الرَّجُلِ يُوَالِي الرَّجُلَ، قَالَا :"" هُوَ بَيْنَ الْمُسْلِمِينَ "". قَالَ سُفْيَانُ : وَكَذَلِكَ نَقُولُ",,takhreej: @متفق علیہ: البخاری،کتاب الشہادات،باب الشہادۃ علی الأنساب والرضاع المستفیض… (الحدیث 2346) ومسلم، کتاب الرضاع،باب تحریم الرضاعتہ من ماء الفحل(الحدیث3560), 2295,"حَدَّثَنَا أَبُو نُعَيْمٍ  ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ عُمَرَ بْنِ عَبْدِ الْعَزِيزِ  ، عَنْ عَبْدِ اللَّهِ بْنِ مَوْهَبٍ  ، قَالَ : سَمِعْتُ تَمِيمًا الدَّارِيَّ  ، يَقُولُ : سَأَلْتُ رَسُولَ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ، فَقُلْتُ : يَا رَسُولَ اللَّهِ، مَا السُّنَّةُ فِي الرَّجُلِ مِنْ أَهْلِ الْكُفْرِ يُسْلِمُ عَلَى يَدَيْ رَجُلٍ مِنْ الْمُسْلِمِينَ؟ فَقَالَ رَسُولُ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ :"" هُوَ أَوْلَى النَّاسِ بِمَحْيَاهُ وَمَمَاتِهِ """,,takhreej: !صحیح : مؤطا امام مالک ،کتاب الرضاع،باب جامع ماجاء فی الرضاعۃ(15)ومسلم،کتاب الرضاع،باب یحرم من الرضاعۃ ما یحریم من الولادۃ(الحدیث3554), 2296,"حَدَّثَنَا عُبَيْدُ اللَّهِ ، عَنْ إِسْرَائِيلَ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاهِيمَ ، قَالَ : سُئِلَ عَنْ رَجُلٍ مِنْ أَهْلِ السَّوَادِ، أَسْلَمَ عَلَى يَدَيْ رَجُلٍ، قَالَ :"" يَعْقِلُ عَنْهُ، وَيَرِثُهُ """,,takhreej: @صحیح: (2293) کے تحت اس کی تخریج گزر چکی ہے۔, 2297,"حَدَّثَنَا سُلَيْمَانُ بْنُ حَرْبٍ ، حَدَّثَنَا شُعْبَةُ ، عَنْ مُغِيرَةَ ،  عَنْ إِبْرَاهِيمَ ، قَالَ :"" تَرِثُ الْمَرْأَةُ مِنْ دِيَةِ زَوْجِهَا فِي الْعَمْدِ وَالْخَطَإِ """,,takhreej: #اسنادہ ضعیف: لیکن حدیث صحیح ہے۔ اخرجہ مسلم فی کتاب الرضاع،باب فی المصۃ والمصتان (الحدیث:3575) وابن ماجہ،کتاب النکاح،باب لاتحیم المصۃ والمصتان(الحدیث1941), 2298,"حَدَّثَنَا أَبُو النُّعْمَانِ ، حَدَّثَنَا أَبُو عَوَانَةَ ، عَنْ مُغِيرَةَ ، عَنْ إِبْرَاهِيمَ ، قَالَ :"" الدِّيَةُ عَلَى فَرَائِضِ اللَّهِ """,,takhreej: !صحیح مسلم،کتاب الرضاع،باب فی المصۃ والمصتان(الحدیث2576)والنسائی،کتاب النکاح،باب القدر الذی یحرم من الرضاعۃ(الحدیث3308), 2299,"حَدَّثَنَا مُسْلِمُ بْنُ إِبْرَاهِيمَ  ، حَدَّثَنَا وُهَيْبٌ  ، حَدَّثَنَا أَيُّوبُ  ، عَنْ أَبِي قِلَابَةَ  ، قَالَ :"" الدِّيَةُ سَبِيلُهَا سَبِيلُ الْمِيرَاثِ """,,takhreej: !صحیح مسلم،کتاب الرضاع،باب التحریم بخمس رضعات(الحدیث3582)والترمذی،کتاب الرضاع،باب ماجاء لا تحرم المصۃ والمصتان(الحدیث1150)وابن ماجہ،کتاب النکاح،باب رضاع الکبیر(الحدیث1944), 2300,"حَدَّثَنَا سُلَيْمَانُ بْنُ حَرْبٍ ، حَدَّثَنَا حَمَّادُ بْنُ سَلَمَةَ ، عَنْ حُمَيْدٍ ، وَدَاوُدَ بْنِ أَبِي هِنْدٍ : أن عمر بن عبد العزيز  كتب أن :"" يورث الإخوة من الأم من الدية """,,takhreej: @صحیح: ابن حبان(4231-4230)وابوداؤد،کتاب النکاح،باب فی الرضح عند الفصال (الحدیث2064) والنسائی، کتاب النکاح،باب حق الرضاع وحرمتہ(الحدیث3329), 2301,"حَدَّثَنَا عَبْدُ اللَّهِ بْنُ صَالِحٍ  ، حَدَّثَنِي اللَّيْثُ  ، حَدَّثَنِي يُونُسُ  ، عَنْ ابْنِ شِهَابٍ  ، قَالَ :"" الْعَقْلُ مِيرَاثٌ بَيْنَ وَرَثَةِ الْقَتِيلِ عَلَى كِتَابِ اللَّهِ وَفَرَائِضِهِ """,,takhreej: !صحیح: لیکن یہ سنداً ضعیف ہے،ابن جریج کے عنعنہ کی وجہ سے۔ البخاری،کتاب العلم،باب الرحلۃ فی المسألۃ النازلۃ وتعلیم اہلہ (الحدیث88) وابوداؤد،کتاب الأقضیۃ،باب الشہادۃ علی الرضاع(الحدیث3603)والنسائی،کتاب النکاح، باب الشہادۃ فی الرضاع(الحدیث3330), 2302,"حَدَّثَنَا قَبِيصَةُ  ، حَدَّثَنَا سُفْيَانُ  ، عَنْ عَمْرِو بْنِ دِينَارٍ  ، عَنْ بَعْضِ  وَلَدِ ابْنِ الْحَنَفِيَّةِ، عَنْ عَلِيٍّ  ، قَالَ :"" لَقَدْ ظَلَمَ مَنْ لَمْ يُوَرِّثْ الْإِخْوَةَ مِنْ الْأُمِّ مِنْ الدِّيَةِ """,,takhreej: !متفق علیہ: البخاری،کتاب النکاح،باب من قال لارضاع بعدحولین(الحدیث5103)ومسلم،کتاب الرضاع،باب انما الرضاعۃ من المجاعۃ(الحدیث3591), 2303,"حَدَّثَنَا عَبْدُ اللَّهِ بْنُ سَعِيدٍ  ، حَدَّثَنَا أَبُو خَالِدٍ  ، أَنْبَأَنَا ابْنُ سَالِمٍ  ، عَنْ الشَّعْبِيِّ  ، عَنْ عُمَرَ  ، وَعَلِيٍّ  ، وَزَيْدٍ   ، قَالُوا :"" الدِّيَةُ تُورَثُ كَمَا يُورَثُ الْمَالُ خَطَؤُهُ وَعَمْدُهُ """,,takhreej: !متفق علیہ: البخاری،کتاب النکاح،باب الأکفائ(الحدیث5088)ومسلم،کتاب الرضاع،باب رضاعۃ الکبیر (3585) رضاعتہ کبیر کے مسئلہ میں امام ابن تیمیہ کا مسلک قابل توجہ محسوس ہوتا ہے کہ ضرورت اشد ہوتو یہ حدیث قابل عمل ورنہ نہیں۔, 2304,"حَدَّثَنَا جَعْفَرُ بْنُ عَوْنٍ  ، حَدَّثَنَا إِسْمَاعِيل  ، عَنْ عَامِرٍ  ، قَالَ : "" كَانَ عَلِيٌّ  لَا يُوَرِّثُ الْإِخْوَةَ مِنْ الْأُمِّ، وَلَا الزَّوْجَ، وَلَا الْمَرْأَةَ، مِنْ الدِّيَةِ شَيْئًا "". قَالَ عَبْد اللَّهِ : بَعْضُهُمْ يُدْخِلُ بَيْنَ إِسْمَاعِيل، وَعَامِرٍ رَجُلًا",,takhreej: @اسنادہ صحیح: الترمذی،کتاب النکاح،باب ماجاء فی المحل ولمحلل لہ(الحدیث1120)والنسائی،کتاب الطلاق،باب احلال المطلقۃ ثلاثا ومافیہ من التغلیظ(3416), 2305,"حَدَّثَنَا سُلَيْمَانُ بْنُ حَرْبٍ ، عَنْ حَمَّادِ بْنِ سَلَمَةَ ، عَنْ زِيَادٍ الْأَعْلَمِ ،  عَنْ الْحَسَنِ ، قَالَ :"" لَا تُوَرَّثُ الْإِخْوَةُ مِنْ الْأُمِّ مِنْ الدِّيَةِ """,,takhreej: !متفق علیہ: البخاری،کتاب النفقات،باب اذا لم ینفق الرجل للمرأۃ أن تأخذ بغیر علمہ مایکفیہا وولد ہا بالمعروف (الحدیث5334) مسلم،کتاب الأقضیۃ،باب قضیۃ الہند(4452), 2306,"حَدَّثَنَا يَحْيَى بْنُ حَسَّانَ  ، حَدَّثَنَا ابْنُ أَبِي الزِّنَادِ  ، عَنْ أَبِيهِ  ، عَنْ خَارِجَةَ بْنِ زَيْدٍ  ، عَنْ زَيْدِ بْنِ ثَابِتٍ  ، قَالَ :"" كُلُّ قَوْمٍ مُتَوَارِثِينَ عَمِيَ مَوْتُهُمْ فِي هَدْمٍ، أَوْ غَرَقٍ، فَإِنَّهُمْ لَا يَتَوَارَثُونَ، يَرِثُهُمْ الْأَحْيَاءُ """,,takhreej: !صحیح : ابن حبان(4188)والترمذی،کتاب المناقب باب فضل ازواج النبی ﷺ (الحدیث3895), 2307,"حَدَّثَنَا يَحْيَى بْنُ حَسَّانَ ، حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ ، عَنْ يَحْيَى بْنِ عَتِيقٍ ، قَالَ : قَرَأْتُ فِي بَعْضِ كُتُبِ عُمَرَ بْنِ عَبْدِ الْعَزِيزِ  فِي الْقَوْمِ يَقَعُ عَلَيْهِمْ الْبَيْتُ، لَا يُدْرَى أَيُّهُمَا مَاتَ قَبْلُ؟ قَالَ :"" لَا يُوَرَّثُ الْأَمْوَاتُ بَعْضُهُمْ مِنْ بَعْضٍ، وَيُوَرَّثُ الْأَحْيَاءُ مِنْ الْأَمْوَاتِ """,,takhreej: !متفق علیہ: البخاری،کتاب مناقب الأنصار،باب تزویج النبی ﷺ عائشۃ ؓوقدومہا المدینۃ (الحدیث 3896) ومسلم، کتاب النکاح، باب تزویج الأب الیکر الصغیرۃ(الحدیث3464), 2308,"حَدَّثَنَا نُعَيْمُ بْنُ حَمَّادٍ  ، عَنْ عَبْدِ الْعَزِيزِ بْنِ مُحَمَّدٍ  ، حَدَّثَنَا جَعْفَرٌ  ، عَنْ أَبِيهِ   : أَنَّ أُمَّ كُلْثُومٍ ، وَابْنَهَا زَيْدًا مَاتَا فِي يَوْمٍ وَاحِدٍ، فَالْتَقَتْ الصَّائِحَتَانِ فِي الطَّرِيقِ،فَلَمْ يَرِثْ كُلُّ وَاحِدٍ مِنْهُمَا مِنْ صَاحِبِهِ، وَأَنَّ أَهْلَ الْحَرَّةِ لَمْ يَتَوَارَثُوا، وَأَنَّ أَهْلَ صِفِّينَ لَمْ يَتَوَارَثُوا """,,takhreej: تخریج الحدیث: «إسناده قوي وهو عند مالك في الطلاق، [مكتبه الشامله نمبر: 2308]» اس روایت کی سند صحیح اور حدیث متفق علیہ ہے۔ دیکھئے: [بخاري 5251]، [مسلم 1471]، [أبوداؤد 2179]، [نسائي 3390]، [أبويعلی 5440]، [ابن حبان 4263]، [معرفة السنن و الآثار للبيهقي 1573], 2309,"أَخْبَرَنَا جَعْفَرُ بْنُ عَوْنٍ  ، أَنْبَأَنَا ابْنُ أَبِي لَيْلَى  ، عَنْ الشَّعْبِيِّ   : "" أَنَّ بَيْتًا بِالشَّامِ وَقَعَ عَلَى قَوْمٍ،فَوَرَّثَ عُمَرُ   بَعْضَهُمْ مِنْ بَعْضٍ """,,takhreej: !متفق علیہ : البخاری،کتاب الطلاق،باب قول اللہ تعالیٰ(یایہا النبی إذ طلقتم…)(الحدیث5251)ومسلم،کتاب الطلاق،باب تحریم الطلاق الحائض بغیر رضاہا (الحدیث 3637), 2310,"حَدَّثَنَا أَبُو نُعَيْمٍ  ، حَدَّثَنَا سُفْيَانُ  ، عَنْ حُرَيْسٍ  ، عَنْ أَبِيهِ  ، عَنْ عَلِيٍّ   : "" أَنَّهُوَرَّثَ أَخَوَيْنِ قُتِلَا بِصِفِّينَ، أَحَدَهُمَا مِنْ الْآخَرِ """,,takhreej: !صحیح :ابن حبان(4275)ابوداؤد،کتاب الطلاق،باب فی المراجعۃ(2283)وابن ماجہ،کتاب الطلاق،باب حد ثنا سوید بن سعید(2016), 2311,"أَخْبَرَنَا يَزِيدُ بْنُ هَارُونَ  ، أَنْبَأَنَا حُمَيْدٌ  ، عَنْ بَكْرِ بْنِ عَبْدِ اللَّهِ الْمُزَنِيِّ   : "" أَنَّ رَجُلًا هَلَكَ، وَتَرَكَ عَمَّتَهُ، وَخَالَتَهُ،فَأَعْطَى عُمَرُ الْعَمَّةَ نَصِيبَ الْأَخِ، وَأَعْطَى الْخَالَةَ نَصِيبَ الْأُخْتِ """,,takhreej: @صحیح :اخرجہ الحاکم2/197وقال علی شرط الشیخین امام ذہبی ؒنے بھی ان کی موافقت کی ہے اور واقعی ہے بھی یہ صحیح روایت۔, 2312,"أَخْبَرَنَا أَحْمَدُ بْنُ عَبْدِ اللَّهِ ، حَدَّثَنَا أَبُو شِهَابٍ ، عَنْ الْأَعْمَشِ ، عَنْ إِبْرَاهِيمَ ، قَالَ :"" مَنْ أَدْلَى بِرَحِمٍ، أُعْطِيَ بِرَحِمِهِ الَّتِي يُدْلِي بِهَا """,,takhreej: !ضعیف : صحیح ابن حبان(6559)وموارد الظمآن(793), 2313,"حَدَّثَنَا أَحْمَدُ بْنُ عَبْدِ اللَّهِ ، حَدَّثَنَا أَبُو شِهَابٍ ، قَالَ : حَدَّثَنِي أَبُو إِسْحَاق الشَّيْبَانِيُّ ، عَنْ الشَّعْبِيِّ  : "" فِي رَجُلٍ تَرَكَ عَمَّتَهُ، وَابْنَةَ أَخِيهِ، قَالَ :الْمَالُ لِابْنَةِ أَخِيهِ """,,takhreej: @ متفق علیہ : البخاری،کتاب الشہادات،باب الشہادۃ المختبیٔ(الحدیث2639)ومسلم،کتاب النکاح،باب لا تحل المطلقۃ ثلاثا لمطلقہا حتی تنکح زوجًا(الحدیث3512), 2314,"حَدَّثَنَا أَبُو نُعَيْمٍ  ، حَدَّثَنَا شَرِيكٌ  ، عَنْ لَيْثٍ  ، عَنْ مُحَمَّدِ بْنِ الْمُنْكَدِرِ  ، عَنْ أَبِي هُرَيْرَةَ  ، عَنِ النَّبِيِّ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ، قَالَ :"" الْخَالُ وَارِثٌ """,,takhreej: !متفق علیہ: سابقہ تخریج ہی ہے۔, 2315,"حَدَّثَنَا أَبُو نُعَيْمٍ  ، حَدَّثَنَا حَسَنٌ  ، عَنْ عُبَيْدَةَ  ، عَنْ إِبْرَاهِيمَ  : أَنَّ عُمَرَ  ، وَعَبْدَ اللَّهِ   رَأَيَا أَنْيُوَرِّثَا خَالًا """,,takhreej: @متفق علیہ: البخاری،کتاب الطلاق،باب من خیرا زواجہ (الحدیث5263)ومسلم،کتاب الطلاق،باب بیان أ تخییر امرٔتہ لا یکون طلاقا الا بالنیۃ (الحدیث3629), 2316,"حَدَّثَنَا أَبُو نُعَيْمٍ ، حَدَّثَنَا حَسَنٌ ، عَنْ سُلَيْمَانَ أَبِي إِسْحَاق ، عَنْ الشَّعْبِيِّ  : فِي عَمَّةٍ، وَبِنْتِ أَخٍ، قَالَ :"" الْمَالُ لِابْنَةِ الْأَخِ """,,takhreej: !صحیح ابن حبان (4184)وابوداؤد،کتاب الطلاق،باب الخلع(الحدیث2226)وابن ماجہ،کتاب الطلاق،باب کراہیۃ الخلع للمرأۃ(الحدیث2055), 2317,"حَدَّثَنَا أَبُو نُعَيْمٍ ، أنبأنا حَسَنٌ ، عَنْ سُلَيْمَانَ ، عَنْ بَعْضِهِمْ ، عَنْ إِبْرَاهِيمَ ، قَالَ :"" لِلْعَمَّةِ """,,takhreej: !صحیح : ابن حبان(4280)وموارد الظمآن(1326), 2318,"حَدَّثَنَا أَبُو نُعَيْمٍ ، حَدَّثَنَا سُفْيَانُ ، عَنْ الشَّيْبَانِيِّ ، عَنْ الشَّعْبِيِّ  : فِي بِنْتِ أَخٍ، وَعَمَّةٍ، قَالَ :"" أَعْطِي الْمَالَ لِابْنَةِ الْأَخِ """,,takhreej: !ضعیف : صحیح ابن حبان(4274)وابوداؤد،کتاب الطلاق باب فی البتۃ(الحدیث2206)ونیل الأوطار7/20-11, 2319,"حَدَّثَنَا يَعْلَى  ، حَدَّثَنَا زَكَرِيَّا  ، عَنْ عَامِرٍ  ، عَنْ مَسْرُوقٍ   : فِي رَجُلٍ تُوُفِّيَ وَلَيْسَ لَهُ وَارِثٌ إِلَّا ابْنَةُ أَخِيهِ وَخَالُهُ، قَالَ :"" لِلْخَالِ نَصِيبُ أُخْتِهِ، وَلِابْنَةِ الْأَخِ نَصِيبُ أَبِيهَا """,,takhreej: !منقطع ،ضعیف: ابوداؤد،کتاب الطلاق باب فی الظہار(الحدیث2213)وابن ماجہ،کتاب الطلاق باب الظہار (الحدیث2062) لیکن اس باب میں ابن عباس رضی اللہ عنہما کی حدیث جو کہ ابوداؤد،ترمذی،نسائی وغیرہ میں صحیح سند سے مروی اس کی شاہد ہے۔, 2320,"حَدَّثَنَا أَبُو نُعَيْمٍ  ، حَدَّثَنَا يُونُسُ  ، عَنْ عَامِرٍ  ، قَالَ : "" كَانَ مَسْرُوقٌ  يُنَزِّلُ الْعَمَّةَ بِمَنْزِلَةِ الْأَبِ، إِذَا لَمْ يَكُنْ أَبٌ، وَالْخَالَةَ بِمَنْزِلَةِ الْأُمِّ، إِذَا لَمْ تَكُنْ أُمٌّ """,,takhreej: ! صحیح مسلم،کتاب الطلاق،باب المطلقۃ ثلاثا لا نفقۃ لہا(الحدیث3689)والنسائی،کتاب الطلاق،باب الرخصۃ فی ذلک (الحدیث2403)وابن ماجہ،کتاب الطلاق،باب من طلق ثلاثا فی مجلس واحد(2024), 2321,"حَدَّثَنَا يَعْلَى  ، عَنْ مُحَمَّدِ بْنِ إِسْحَاق  ، عَنْ مُحَمَّدِ بْنِ حَبَّانَ  نَسَبَهُ إِلَى جَدِّهِ ، عَنْ عَمِّهْ وَاسِعِ بْنِ حَبَّانَ  ، قَالَ : تُوُفِّيَ ابْنُ الدَّحْدَاحَةِ، وَكَانَ أَتِيًّا، وَهُوَ الَّذِي لَا يُعْرَفُ لَهُ أَصْلٌ، فَكَانَ فِي بَنِي الْعَجْلَانِ، وَلَمْ يَتْرُكْ عَقِبًا، فَقَالَ رَسُولُ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ لِعَاصِمِ بْنِ عَدِيٍّ :"" هَلْ تَعْلَمُونَ لَهُ فِيكُمْ نَسَبًا؟ قَالَ : مَا نَعْرِفُهُ يَا رَسُولَ اللَّهِ، فَدَعَا ابْنَ أُخْتِهِ، فَأَعْطَاهُ مِيرَاثَهُ",,takhreej: @صحیح : یہ سابقہ حدیث کا ہی ایک ٹکڑاہے۔, 2322,"حَدَّثَنَا عُمَرُ بْنُ حَفْصِ بْنِ غِيَاثٍ  ، حَدَّثَنَا أَبِي  ، عَنِ الْأَعْمَشِ  ، عَنْ إِبْرَاهِيمَ  ، عَنْ عُمَرَ   : "" أَنَّهُأَعْطَى خَالًا الْمَالَ """,,takhreej: !صحیح: لیکن یہ حدیث سنداً ضعیف ہے۔اسے مسلم نے باب المطلقۃ ثلاثًا لانفقۃ لہا(1480) کے تحت نکالا ہے۔, 2323,"حَدَّثَنَا أَبُو نُعَيْمٍ  ، حَدَّثَنَا أَبُو هَانِئٍ  ، قَالَ : سُئِلَ عَامِرٌ  عَنْ امْرَأَةٍ أَوْ رَجُلٍ، تُوُفِّيَ وَتَرَكَ خَالَةً وَعَمَّةً، قَالَ : "" لَيْسَ لَهُ وَارِثٌ وَلَا رَحِمٌ غَيْرُهُمَا ""، فَقَالَ : كَانَ عَبْدُ اللَّهِ بْنُ مَسْعُودٍ  يُنَزِّلُ الْخَالَةَ بِمَنْزِلَةِ أُمِّهِ، وَيُنَزِّلُ الْعَمَّةَ بِمَنْزِلَةِ أَخِيهَا",,takhreej: @ صحیح: تخریج پیچھے گزر چکی ہے۔, 2324,"حَدَّثَنَا أَحْمَدُ بْنُ عَبْدِ اللَّهِ  ، حَدَّثَنَا أَبُو شِهَابٍ  ، عَنْ عَمْرٍو  ، عَنِ الْحَسَنِ   : فِي رَجُلٍ اعْتَرَفَ عِنْدَ مَوْتِهِ بِأَلْفِ دِرْهَمٍ لِرَجُلٍ، وَأَقَامَ آخَرُ بَيِّنَةً بِأَلْفِ دِرْهَمٍ، وَتَرَكَ الْمَيِّتُ أَلْفَ دِرْهَمٍ، فَقَالَ :"" الْمَالُ بَيْنَهُمَا نِصْفَيْنِ، إِلَّا أَنْ يَكُونَ مُفْلِسًا، فَلَا يَجُوزُ إِقْرَارُهُ """,,takhreej: #صحیح: تخریج پیچھے گزر چکی ہے۔, 2325,"أَخْبَرَنَا أَبُو نُعَيْمٍ  ، قَالَ : قُلْتُ لِشَرِيكٍ   : كَيْفَ ذَكَرْتَ فِي الْأَخَوَيْنِ يَدَّعِي أَحَدُهُمَا أَخًا؟ قَالَ :"" يَدْخُلُ عَلَيْهِ فِي نَصِيبِهِ ""، قُلْتُ : مَنْ ذَكَرَهُ؟ قَالَ : جَابِرٌ  ، عَنْ عَامِرٍ  ، عَنْ عَلِيٍّ",,takhreej: !متفق علیہ : البخاری،کتاب التفسیر،باب(وأولات الأحمال أجلہن أن یضعن…)(4909‘ومسلم،کتاب الطلاق باب التقضاء عد المتوفی عنہا…(3707), 2326,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مُحَمَّدٍ الْمُحَارِبِيُّ ، عَنْ الْأَعْمَشِ ، عَنْ إِبْرَاهِيمَ  : فِي الْإِخْوَةِ يَدَّعِي بَعْضُهُمْ الْأَخَ، وَيُنْكِرُ الْآخَرُونَ، قَالَ :"" يَدْخُلُ مَعَهُمْ بِمَنْزِلَةِ عَبْدٍ يَكُونُ بَيْنَ الْإِخْوَةِ، فَيَعْتِقَ أَحَدُهُمْ نَصِيبَهُ، قَالَ : وَكَانَ عَامِرٌ ، وَالْحَكَمُ ، وَأَصْحَابُهُمَا يَقُولُونَ : لَا يَدْخُلُ إِلَّا فِي نَصِيبِ الَّذِي اعْتَرَفَ بِهِ",,takhreej: !صحیح: سابقہ حدیث کا اختصار ہے۔, 2327,"حَدَّثَنَا أَبُو بَكْرِ ابْنُ أَبِي شَيْبَةَ  ، عَنْ وَكِيعٍ  ، قَالَ : إِذَا كَانَا أَخَوَيْنِ، فَادَّعَى أَحَدُهُمَا أَخًا وَأَنْكَرَهُ الْآخَرُ؟ قَالَ : كَانَ ابْنُ أَبِي لَيْلَى  ، يَقُولُ :"" هِيَ مِنْ سِتَّةٍ : لِلَّذِي لَمْ يَدَّعِ ثَلَاثَةٌ، وَلِلْمُدَّعِي سَهْمَانِ، وَلِلْمُدَّعَى سَهْمٌ """,,takhreej: @متفق علیہ: البخاری،کتاب المغازی،باب(10)(الحدیث3991)ومسلم،کتاب الطلاق باب انقضاء عدۃ المتوفیٰ عنہا زوجہا وغیرہا بوضع الحمل(3706), 2328,"حَدَّثَنَا يُونُسُ بْنُ مُحَمَّدٍ  ، حَدَّثَنَا أَبُو عَوَانَةَ  ، عَنْ مُغِيرَةَ  ، عَنْ حَمَّادٍ   : "" فِي الرَّجُلِ يَكُونُ لَهُ ثَلَاثَةُ بَنِينَ، فَقَالَ :ثُلُثِي لِأَصْغَرِ بَنِيَّ، فَقَالَ الْأَوْسَطُ : أَنَا أُجِيزُ، وَقَالَ الْأَكْبَرُ : أَنَا لَا أُجِيزُ، قَالَ : هِيَ مِنْ تِسْعَةٍ يُخْرِجُ ثَلاثَةً فَلَهُ سَهْمُهُ، وَسَهْمُ الَّذِي أَجَاز "". وَقَالَ حَمَّادٌ : يَرُدُّ السَّهْمَ عَلَيْهِمْ جَمِيعًا، وَقَالَ عَامِرٌ   : الَّذِي رَدَّ إِنَّمَا رَدَّ عَلَى نَفْسِهِ",,takhreej: #صحیح: سابقہ حدیث مکرر آئی ہے۔, 2329,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، حَدَّثَنَا يَحْيَى بْنُ آدَمَ ، عَنْ شَرِيكٍ ، عَنْ خَالِدٍ ، عَنْ ابْنِ سِيرِينَ ، عَنْ شُرَيْحٍ  : فِي رَجُلٍ أَقَرَّ بِأَخٍ، قَالَ :"" بَيِّنَتُهُ أَنَّهُ أَخُوهُ """,,takhreej: ! صحیح مسلم،کتاب الطلاق،باب وجوب الاحداد فی عدۃ الوفاۃ،وتحریمہ…(الحدیث3791)وابن ماجہ،کتاب الطلاق، باب ہل تحدالمرأۃ علی غیر زوجہا(الحدیث 2085), 2330,"أَخْبَرَنَا أَبُو النُّعْمَانِ  ، حَدَّثَنَا أَبُو عَوَانَةَ  ، عَنْ مُغِيرَةَ  ، عَنْ الْحَارِثِ الْعُكْلِيِّ   : فِي رَجُلٍ أَقَرَّ عِنْدَ مَوْتِهِ بِأَلْفِ دِرْهَمٍ مُضَارَبَةً، وَأَلْفٍ دَيْنًا، وَلَمْ يَدَعْ إِلَّا أَلْفَ دِرْهَمٍ، قَالَ :"" يُبْدَأُ بِالدَّيْنِ، فَإِنْ فَضَلَ فَضْلٌ كَانَ لِصَاحِبِ الْمُضَارَبَةِ """,,takhreej: @صحیح مسلم،کتاب الطلاق،باب وجوب الاحداد فی عدۃ الوفاۃ،وتحریمہ…(الحدیث3791)وابن ماجہ،کتاب الطلاق،باب ہل تحدالمرأۃ علی غیر زوجہا(الحدیث 2085), 2331,"حَدَّثَنَا أَبُو نُعَيْمٍ ، حَدَّثَنَا حَسَنٌ ، عَنْ مُطَرِّفٍ ، عَنْ الشَّعْبِيِّ  : "" فِي رَجُلٍ مَاتَ وَتَرَكَ ثَلَاثَ مِئَةِ دِرْهَمٍ، وَثَلَاثَةَ بَنِينَ، فَجَاءَ رَجُلٌ يَدَّعِي مِائَةَ دِرْهَمٍ عَلَى الْمَيِّتِ، فَأَقَرَّ لَهُ أَحَدُهُمْ، قَالَ :يَدْخُلُ عَلَيْهِ بِالْحِصَّةِ ""، ثُمَّ قَالَ الشَّعْبِيُّ : مَا أُرَى أَنْ يَكُونَ مِيرَاثًا، حَتَّى يُقْضَى الدَّيْنُ",,takhreej: !صحیح سابقہ حدیث ہی مکرر آئی ہے۔, 2332,"حَدَّثَنَا أَبُو خَيْثَمَةَ مُصْعَبُ بْنُ سَعِيدٍ الْحَرَّانِيُّ  ، حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ  ، عَنْ الْأَشْعَثِ  ، عَنْ الْحَسَنِ   : فِي رَجُلٍ هَلَكَ وَتَرَكَ ابْنَيْنِ، وَتَرَكَ أَلْفَيْ دِرْهَمٍ، فَاقْتَسَمَا الْأَلْفَيْ دِرْهَمٍ، وَغَابَ أَحَدُ الِابْنَيْنِ، فَجَاءَ رَجُلٌ، فَاسْتَحَقَّ عَلَى الْمَيِّتِ أَلْفَ دِرْهَمٍ، قَالَ :"" يَأْخُذُ جَمِيعَ مَا فِي يَدِ هَذَا الشَّاهِدِ، وَيُقَالُ لَهُ : اتَّبِعْ أَخَاكَ الْغَائِبَ، وَخُذْ نِصْفَ مَا فِي يَدِهِ """,,takhreej: @ متفق علیہ : البخاری،کتاب الحیض،باب الطب للمرأۃ عند غسلہا من المحیض(313)ومسلم،کتاب الطلاق،باب وجوب الاحداد فی عدۃ الوفاۃ…(3722), 2333,"حَدَّثَنَا سُلَيْمَانُ بْنُ حَرْبٍ  ، عَنْ حَمَّادِ بْنِ سَلَمَةَ  ، عَنْ زِيَادٍ الْأَعْلَمِ  ، عَنْ الْحَسَنِ  ، قَالَ :"" إِذَا أَقَرَّ بَعْضُ الْوَرَثَةِ بِدَيْنٍ، فَهُوَ عَلَيْهِ بِحِصَّتِهِ """,,takhreej: !صحیح : ابن حبان(4293-4292)واخرجہ ابن حرم فی المحلی10/302-301وابوداؤد،کتاب الطلاق باب فی المتوفی عنہا تنتقل(2300)وابن ماجہ،کتاب الطلاق،باب أین تعتد المتوفیٰ عنہا زوجہا(2031), 2334,"حَدَّثَنَا سُلَيْمَانُ بْنُ حَرْبٍ ، عَنْ حَمَّادِ بْنِ سَلَمَةَ ، عَنْ أَبِي هَاشِمٍ ،  عَنْ إِبْرَاهِيمَ ، قَالَ :"" إِذَا شَهِدَ اثْنَانِ مِنْ الْوَرَثَةِ بِدَيْنٍ، فَهُوَ مِنْ جَمِيعِ الْمَالِ إِذَا كَانُوا عُدُولًا ""، وَقَالَ الشَّعْبِيُّ  : عَلَيْهِمَا فِي بَاب فِي مِيرَاثِ الْمُرْتَدِّ",,takhreej: !صحیح: احمد کے ہاں ابن جریج کے سماع کی صراحت موجود ہے۔مسلم،کتاب الطلاق،باب جواز خروج المعتدۃ البائن… (3705)وابوداؤد،کتاب الطلاق،باب فی المبتوتۃ تخرج بالنہار(1197), 2335,"حَدَّثَنَا مُحَمَّدُ بْنُ عِيسَى  ، حَدَّثَنَا ثَابِتُ بْنُ الْوَلِيدِ بْنِ جُمَيْعٍ  ، قَالَ : أَخْبَرَنِي أَبِي  ، عَنْ الْقَاسِمِ بْنِ عَبْدِ الرَّحْمَنِ  ، قَالَ : كَانَ ابْنُ مَسْعُودٍ  "" يُوَرِّثُ أَهْلَ الْمُرْتَدِّ إِذَا قُتِلَ """,,takhreej: @متفق علیہ : البخاری،کتاب البیو۲،باب اذا اشترط شروطا فی البیع(2168)ومسلم،کتاب الزکاۃ،باب اباحۃ الہدیۃ للنبی ﷺ (2468)وصحیح ابن حبان(4272-4271-4269), 2336,"حَدَّثَنَا الْحَجَّاجُ بْنُ مِنْهَالٍ  ، حَدَّثَنَا أَبُو عَوَانَةَ  ، عَنْ الْأَعْمَشِ  ، عَنْ أَبِي عَمْرٍو الشَّيْبَانِيِّ  : أَنَّ عَلِيَّ بْنَ أَبِي طَالِبٍ  "" جَعَلَ مِيرَاثَ الْمُرْتَدِّ لِوَرَثَتِهِ مِنَ الْمُسْلِمِينَ """,,takhreej: !صحیح :سابقہ حدیث کی ہی ایک جانب ہے۔, 2337,"أَخْبَرَنَا يَزِيدُ بْنُ هَارُونَ  ، حَدَّثَنَا الْحَجَّاجُ  ، عَنِ الْحَكَمِ  : أَنَّ عَلِيًّا  "" قَضَى فِي مِيرَاثِ الْمُرْتَدِّ لِأَهْلِهِ مِنْ الْمُسْلِمِينَ """,,takhreej: @صحیح : پہلے گزرنے والی حدیث کی ایک طرف ہے۔, 2338,"حَدَّثَنَا زَكَرِيَّا بْنُ عَدِيٍّ  ، حَدَّثَنَا عُبَيْدُ اللَّهِ هُوَ ابْنُ عَمْرٍو  ، عَنْ عَبْدِ الْكَرِيمِ  ، عَنْ الْحَكَمِ  ، قَالَ :"" إِذَا قَتَلَ الرَّجُلُ أَخَاهُ عَمْدًا، لَمْ يُوَرَّثْ مِنْ مِيرَاثِهِ، وَلَا مِنْ دِيَتِهِ، فَإِذَا قَتَلَهُ خَطَأً، وُرِّثَ مِنْ مِيرَاثِهِ، وَلَمْ يُوَرَّثْ مِنْ دِيَتِهِ. قَالَ : وَكَانَ عَطَاءٌ   يَقُولُ ذَلِكَ",,takhreej: !متفق علیہ: البخاری،کتاب الطلاق،باب شفاعۃ النبی ﷺ فی زوج بریرۃ(2583)صحیح ابن حبان(4270)وابن ماجہ،کتاب الطلاق،باب خیار الأمۃ إذا أعتقت(2075), 2339,"حَدَّثَنَا مُحَمَّدُ بْنُ عُيَيْنَةَ  ، عَنْ عَلِيِّ بْنِ مُسْهِرٍ  ، عَنْ سَعِيدٍ  ، عَنْ قَتَادَةَ  ، عَنْ خِلَاسٍ  ، عَنْ عَلِيٍّ  ، قَالَ : رَمَى رَجُلٌ أُمَّهُ بِحَجَرٍ فَقَتَلَهَا، فَطَلَبَ مِيرَاثَهُ مِنْ إِخْوَتِهِ، فَقَالَ لَهُ إِخْوَتُهُ : لَا مِيرَاثَ لَكَ، فَارْتَفَعُوا إِلَى عَلِيٍّ،"" فَجَعَلَ عَلَيْهِ الدِّيَةَ، وَأَخْرَجَهُ مِنْ الْمِيرَاثِ """,,takhreej: !صحیح :مسند حمیدی (1113)وابوداؤد،کتاب الطلاق،باب من احق بالولد(2277)وابن ماجہ،کتاب الأحکام، باب تخییر الصبیی بن والدیہ(2351), 2340,"حَدَّثَنَا أَبُو نُعَيْمٍ  ، حَدَّثَنَا زُهَيْرٌ  ، عَنْ الْحَسَنِ بْنِ الْحُرِّ  ، عَنْ الْحَكَمِ   : أَنَّ الرَّجُلَ إِذَا قَتَلَ امْرَأَتَهُ خَطَأً، "" أَنَّهُيُمْنَعُ مِيرَاثَهُ مِنْ الْعَقْلِ وَغَيْرِهِ """,,takhreej: !ضعیف : الترمذی،کتاب الطلاق باب ماجاء أن طلاق الأمۃتطلیقتان(1182)والبیہقی فی(معرفتہ السنن والآثا (14884) والحاکم2/205 ابن عمر رضی اللہ عنہما کی حدیث بطور شاہد آتی ہے لیکن مرفوعًا اس کی سند بھی ضعف ہے جبکہ موقوفًا صحیح ہے۔دیکھئے تلخیص الجبیر3/213-212ونیل الأوطار7/27-26), 2341,"أَخْبَرَنَا أَبُو نُعَيْمٍ  ، حَدَّثَنَا سُفْيَانُ  ، عَنْ لَيْثٍ  ، عَنْ مُجَاهِدٍ  ، عَنْ ابْنِ عَبَّاسٍ  ، قَالَ :"" لَا يَرِثُ الْقَاتِلُ مِنْ الْمَقْتُولِ شَيْئًا """,,takhreej: @سندہ حسن: لیکن یہ حدیث صحیح ہے اسے مسلم نے کتاب الرضاع،باب جواز وطء السبایا (1456) والحکام 3/195, 2342,"حَدَّثَنَا سَعِيدُ بْنُ الْمُغِيرَةِ ، عَنْ ابْنِ الْمُبَارَكِ ، عَنْ مَعْمَرٍ ، عَنْ قَتَادَةَ  : "" فِي رَجُلٍ قَذَفَ امْرَأَتَهُ، وَجَاءَ بِشُهُودٍ فَرُجِمَتْ؟ قَالَ :يَرِثُهَا """,,takhreej: !صحیح : ابن حبان(142)وأخرجہ ابن ابی شیبہ5/268)ابوداؤد،کتاب الحدود،باب فی المجنون یسرق أو یصیب حداً (الحدیث4398), 2343,"حَدَّثَنَا أَبُو النُّعْمَانِ  ، حَدَّثَنَا أَبُو عَوَانَةَ  ، عَنْ حَمَّادٍ   : "" فِي رَجُلٍ جُلِدَ الْحَدَّ أَرَاهُ مَاتَ، شَكَّ أَبُو النُّعْمَانِ ؟ قَالَ :يَتَوَارَثَانِ """,,takhreej: !صحیح: ابوداؤد،کتاب الدیات،باب الامام یأمر بالعفو فی الدم(4502)والنسائی،کتاب التحریم،باب مایحل بہ دم المسلم(4031)والبیہقی،کتاب المرتد،باب قتل من ارتدعن الاسلام8/194, 2344,"حَدَّثَنَا أَبُو النُّعْمَانِ  ، حَدَّثَنَا أَبُو عَوَانَةَ  ، عَنْ مُحَمَّدِ بْنِ سَالِمٍ  ، عَنْ عَامِرٍ  ، عَنْ عَلِيٍّ  ، قَالَ :"" الْقَاتِلُ لَا يَرِثُ، وَلَا يَحْجُبُ """,,takhreej: @متفق علیہ: البخاری،کتاب الدیات،باب قول اللہ تعالیٰ(ان النفس بالنفس والعین بالعین)(6878)ومسلم،کتاب القسامۃ والمحاربین،باب ما یباح بہ دم المسلم(4351), 2345,"حَدَّثَنَا أَبُو نُعَيْمٍ  ، حَدَّثَنَا حَسَنٌ  ، عَنْ لَيْثٍ  ، عَنْ أَبِي عَمْرٍو الْعَبْدِيِّ  ، عَنْ عَلِيٍّ  ، قَالَ :"" لَا يُوَرَّثُ الْقَاتِلُ """,,takhreej: ! اسنادہ ضعیف لیکن صحیح سند سے اس کی متابعت ملتی ہے مثلاً طبرانی کییر (7326) والحاکم 4/380 والبخاری فی الکبیر4/304واخرجہ ابوداؤد،کتاب الحدود،باب من سرق من حرز(4394), 2346,"حَدَّثَنَا زَكَرِيَّا بْنُ عَدِيٍّ  ، حَدَّثَنَا أَبُو بَكْرٍ  ، عَنْ مُطَرِّفٍ  ، عَنْ الشَّعْبِيِّ  ، قَالَ : قَالَ عُمَرُ   :"" لَا يَرِثُ قَاتِلٌ خَطَأً، وَلَا عَمْدًا """,,takhreej: !متفق علیہ: البخاری،کتاب الحدود،قول اللہ تعالیٰ(السارق والسارقۃ فا قطعوا ایدیہما)وفی کم یقطع (6789)ومسلم،کتاب الحدود،باب حد السرقۃ ونصابہا(4374), 2347,"أَخْبَرَنَا مُحَمَّدُ بْنُ يُوسُفَ  ، عَنْ سُفْيَانَ  ، عَنْ لَيْثٍ  ، عَنْ طَاوُسٍ  ، عَنْ ابْنِ عَبَّاسٍ  ، قَالَ :"" لَا يَرِثُ الْقَاتِلُ """,,takhreej: @متفق علیہ: البخاری،کتاب الحدود،باب قولہ اللہ تعالیٰ(والسارق والسارقۃ فاقطعوا اید یہما)وفی کم یقطع (6795) ومسلم، کتاب الحدود،باب وحد الر قۃ ونصابہا(4382), 2348,"أَخْبَرَنَا مُحَمَّدُ بْنُ عِيسَى ، حَدَّثَنَا عَبْدُ الْأَعْلَى ، عَنْ مَعْمَرٍ ، عَنْ الزُّهْرِيِّ ، قَالَ :"" إِذَا اجْتَمَعَ نَسَبَانِ، وُرِّثَ بِأَكْبَرِهِمَا، يَعْنِي الْمَجُوسَ """,,takhreej: !متفق علیہ: لبخاری،کتاب احادیث الأنبیائ،باب54(الحدیث3475)ومسلم،کتاب الحدود،باب قطع السارق الشریف وغیرہا (4386), 2349,"حَدَّثَنَا حَجَّاجُ بْنُ مِنْهَالٍ  ، حَدَّثَنَا حَمَّادُ بْنُ سَلَمَةَ  ، عَنْ حَمَّادِ بْنِ أَبِي سُلَيْمَانَ  ، قَالَ :"" يَرِثُ مِنْ الْجَانِبِ الَّذِي يَصْلُحُ، وَلَا يَرِثُ مِنْ الْجَانِبِ الَّذِي لَا يَصْلُحُ """,,takhreej: !صحیح :اس سند میں ابو منذر راوی کو کسی نے ثقہ قرار نہیں دیا۔بہر حال حاکم 4/381، الدرقطنی 3/102) البیہقی8/271 میں ابوہریرہ رضی اللہ عنہ کی حدیث بطور شاہد صحیح ثابت ہے امام حاکم نے اس کے رجال کو شیخین کے رجال قرار دیا ہے۔اور ابن قطان نے ان کی موافقت کی ہے۔, 2350,"حَدَّثَنَا حَجَّاجٌ  ، حَدَّثَنَا حَمَّادٌ  ، عَنْ سُفْيَانَ الثَّوْرِيِّ  ، عَنْ رَجُلٍ  ، عَنْ الشَّعْبِيِّ  : أَنَّ عَلِيًّا  ، وَابْنَ مَسْعُودٍ  ، قَالَا فِي الْمَجُوسِ :"" إِذَا أَسْلَمُوا، يَرِثُونَ مِنْ الْقَرَابَتَيْنِ جَمِيعًا """,,takhreej: @صحیح: طبرانی کبیر4/260،ابوداؤد،کتاب الحدود،باب مالا قطع فیہ(4388)والنسائی،کتاب السارق،باب مالا قطع فیہ(4976), 2351,"أَخْبَرَنَا يَحْيَى بْنُ حَسَّانَ ، حَدَّثَنَا ابْنُ أَبِي الزِّنَادِ ، عَنْ أَبِيهِ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِيزِ  فِي امْرَأَةِ الْأَسِيرِ : "" أَنَّهَاتَرِثُهُ وَيَرِثُهَا """,,takhreej: !اسنادہ ضعیف: اس میں ابو اسامہ مجہول راوی ہے جبکہ حدیث سابقہ کے مطابق ہونے کی وجہ سے صحیح ہے۔, 2352,"حَدَّثَنَا مُحَمَّدُ بْنُ الْفَضْلِ ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ ، حَدَّثَنِي مَعْمَرٌ ، عَنْ إِسْحَاق بْنِ رَاشِدٍ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِيزِ  فِي الْأَسِيرِ يُوصِي، قَالَ :"" أُجيزُ لَهُ وَصِيَّتَهُ مَا دَامَ عَلَى دِينِهِ لَمْ يَتَغَيَّرْ عَنْ دِينِهِ """,,takhreej: @اسنادہ صحیح: سابقہ حدیث ہی ہے۔, 2353,"أَخْبَرَنَا مُحَمَّدُ بْنُ يُوسُفَ ، حَدَّثَنَا سُفْيَانُ ، عَنْ دَاوُدَ ، عَنْ الشَّعْبِيِّ ، عَنْ شُرَيْحٍ ، قَالَ :"" يُوَرَّثُ الْأَسِيرُ إِذَا كَانَ فِي أَيْدِي الْعَدُوِّ """,,takhreej: #اسنادہ صحیح: سابقہ حدیث ہی ہے۔, 2354,"حَدَّثَنَا مُحَمَّدٌ ، قَالَ : حَدَّثَنَا سُفْيَانُ ، حَدَّثَنِي مَنْ سَمِعَ إِبْرَاهِيمَ ، يَقُولُ :"" يُوَرَّثُ الْأَسِيرُ """,,takhreej: $اسنادہ صحیح: سابقہ حدیث ہی ملاحظہ ہو۔, 2355,"حَدَّثَنَا الْمُعَلَّى بْنُ أَسَدٍ ، حَدَّثَنَا وُهَيْبٌ ، عَنْ دَاوُدَ ، عَنْ سَعِيدِ بْنِ الْمُسَيِّبِ  : أَنَّهُ كَانَ"" لَا يُوَرِّثُ الْأَسِيرَ """,,takhreej: !اسنادہ ضعیف : اس میں ابو میمون مجہول ہے جبکہ سابقہ حدیث کی بناء پر یہ حدیث صحیح ہے۔, 2356,"أَخْبَرَنَا يَزِيدُ بْنُ هَارُونَ  ، حَدَّثَنَا الْأَشْعَثُ  ، عَنْ الشَّعْبِيِّ  ، قَالَ : كَتَبَ عُمَرُ بْنُ الْخَطَّابِ   إِلَى شُرَيْحٍ : أَنْ"" لَا يُوَرِّثَ الْحَمِيلَ إِلَّا بِبَيِّنَةٍ، وَإِنْ جَاءَتْ بِهِ فِي خِرَقِهَا """,,takhreej: @صحیح: ابن حبان(4457-4456)وابوداؤد،کتاب الحدود،باب القطع فی الخلسۃ والخیانۃ(4391)وابن ماجہ،کتاب الحدود،باب الخائن،المنتہب،المختلس(2591), 2357,"أَخْبَرَنَا عُبَيْدُ اللَّهِ ، عَنْ إِسْرَائِيلَ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاهِيمَ ، قَالَ :"" وَرِّثْ الْحَمِيلَ """,,takhreej: !متفق علیہ: کتاب الحدود،باب الضرب بالجریدو النعال(6776)ومسلم،کتاب الحدود،باب حد الخمر(4429), 2358,"حَدَّثَنَا أَبُو سَعِيدٍ مِنْ بَنِي أُمَيَّةَ، عَنْ أَبِي بَكْرِ بْنِ عَبْدِ اللَّهِ بْنِ أَبِي مَرْيَمَ ، عَنْ ضَمْرَةَ ، وَالْفُضَيْلِ بْنِ فَضَالَةَ ، وَابْنِ أَبِي عَوْفٍ ، وراشد ، وعطية ، قَالُوا :"" لَا يُوَرَّثُ الْحُمَلَاءُ """,,takhreej: @صحیح مسلم،کتاب الحدود،باب حد الخمر(4432)وابوداؤد،کتاب الحدود،باب الحد فی الخمر(4480)وابن ماجہ کتاب الحدود،باب حد السکران(2571), 2359,"حَدَّثَنَا سَعِيدُ بْنُ الْمُغِيرَةِ ، قَالَ : قَالَ ابْنُ الْمُبَارَكِ : حَدَّثَنَا ابْنُ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : ذُكِرَ عِنْدَهُ قَوْلُ مَنْ يَقُولُ فِي الْحَمِيلِ، فَأَنْكَرَ ذَلِكَ، وَقَالَ :"" قَدْ تَوَارَثَ الْمُهَاجِرُونَ، وَالْأَنْصَارُ بِنَسَبِهِمْ الَّذِي كَانَ فِي الْجَاهِلِيَّةِ """,,takhreej: !ضعیف: لیکن شواہد کی بناء پر یہ حدیث صحیح ہے جیسا کہ ابوہریرۃ رضی اللہ عنہ کی حدیث صحیح ابن حبان(4447)اور معاویہ رضی اللہ عنہ کی حدیث مسند موصلی(7363)میں ہے۔, 2360,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، عَنْ ابْنِ إِدْرِيسَ ، عَنْ هِشَامٍ ، عَنْ الْحَسَنِ ، وَابْنِ سِيرِينَ ، قَالَا :"" لَا يُوَرَّثُ الْحَمِيلُ إِلَّا بِبَيِّنَةٍ """,,takhreej: @متفق علیہ: البخاری،کتاب الحدود،باب کم التعزیروالأدب(9848)ومسلم،کتاب الحدود،باب قدرأسواط التعزیر (1708), 2361,"حَدَّثَنَا أَبُو بَكْرٍ ، حَدَّثَنَا جَرِيرٌ ، عَنْ لَيْثٍ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاهِيمَ ، قَالَ :"" لَمْ يَكُنْ أَبُو بَكْرٍ، وَعُمَرُ، وَعُثْمَانُ يُوَرِّثُونَ الْحَمِيلَ """,,takhreej: ! صحیح: اخرجہ البخاری،فی النکاح،باب الطلاق فی الإغلاق(5270)ومسلم،کتاب الحدود،باب من اعترف علی نفسہ الزنی (1691), 2362,"حَدَّثَنَا أَبُو بَكْرٍ ، حَدَّثَنَا عَبْدُ الرَّحِيمِ الْمُحَارِبِيُّ ، عَنْ زَائِدَةَ ، عَنْ أَشْعَثَ بْنِ أَبِي الشَّعْثَاءِ ، قَالَ :"" أَقَرَّتْ امْرَأَةٌ مِنْ مُحَارِبٍ جَلِيبَةٌ بِنَسَبٍ لَهَا جَلِيبٍ، فَوَرَّثَهُ عَبْدُ اللَّهِ بْنُ عُتْبَةَ  مِنْ أُخْتِهِ """,,takhreej: !صحیح مسلم،کتاب الحدود،باب من اعترف علی نفسہ بالزنا(1693)صحیح ابن حبان(4436), 2363,"حَدَّثَنَا عَبْدُ اللَّهِ بْنُ صَالِحٍ ، حَدَّثَنِي اللَّيْثُ ، حَدَّثَنِي يُونُسُ ، عَنْ ابْنِ شِهَابٍ ، عَنْ رَجُلٍ قَالَ عِنْدَ فِرَاقِ الدُّنْيَا : أَنَا مَوْلَى فُلَانٍ، قَالَ :"" يُرَدُّ مِيرَاثَهُ لِمَنْ سَمَّى أَنَّهُ مَوْلَاهُ عِنْدَ فِرَاقِ الدُّنْيَا، إِلَّا أَنْ يَأْتُوا عَلَيْهِ بِبَيِّنَةٍ بِغَيْرِ ذَلِكَ يَرُدُّونَ بِهِ قَوْلَهُ، فَيُرَدُّ مِيرَاثُهُ إِلَى مَا قَامَتْ بِهِ الْبَيِّنَةُ """,,takhreej: !متفق علیہ: البخاری،کتاب الوکالۃ،باب الوکالۃ فی الحدود(2314)ومسلم،کتاب الحدود،باب من اعترف علی نفسہ بالزنا(4410)وابن ماجہ،کتاب الحدود،باب حد الزنا(2549), 2364,"أَخْبَرَنَا أَبُو نُعَيْمٍ  ، حَدَّثَنَا شَرِيكٌ  ، عَنْ مُحَمَّدِ بْنِ سَالِمٍ  ، عَنْ الشَّعْبِيِّ  ، عَنْ عَلِيٍّ  ، وَعَبْدِ اللَّهِ   ، قَالَا :"" وَلَدُ الزِّنَا بِمَنْزِلَةِ ابْنِ الْمُلَاعَنَةِ """,,takhreej: !حسن: اس کی سند میں ایک راوی ابو الہیثم بن نصر ہے جس کا امام بخاری وابن ابی حاتم نے تکذکرہ تو کیا ہے لیکن کوئی جرح وتعدیل نہیں کی جب کہ حافظ ابن حجر رحمہ اللہ نے تقریب میں اسے’’مقبول‘‘کہا ہے بقیہ حدیث کے رجال ثقہ ہیں۔ أخرجہ احمد 4/431 والنسائی فی الکبریٰ(7207), 2365,"أَخْبَرَنَا أَبُو نُعَيْمٍ ، حَدَّثَنَا زُهَيْرٌ ، عَنْ الْحَسَنِ بْنِ الْحُرِّ ، حَدَّثَنِي الْحَكَمُ  : أَنَّ"" وَلَدَ الزِّنَا لَا يَرِثُهُ الَّذِي يَدَّعِيهِ، وَلَا يَرِثُهُ الْمَوْلُودُ """,,takhreej: ! صحیح: اخرجہ مسلم،کتاب الحدود،باب من اعترف علی نفسہ بالزنا(1694)وصحیح ابن حبان(4438), 2366,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، حَدَّثَنَا رَوْحٌ ، عَنْ مُحَمَّدِ بْنِ أَبِي حَفْصَةَ ، عَنْ الزُّهْرِيِّ ، عَنْ عَلِيِّ بْنِ حُسَيْنٍ  أَنَّهُ كَانَ"" لَا يُوَرِّثُ وَلَدَ الزِّنَا، وَإِنْ ادَّعَاهُ الرَّجُلُ """,,takhreej: @حسن: أخرجہ احمد5/348-347ومسلم فی الحدود،باب من اعترف علی نفسہ بالزنا(1695), 2367,"حَدَّثَنَا عَبْدُ اللَّهِ بْنُ صَالِحٍ  ، حَدَّثَنِي بَكْرُ بْنُ مُضَرَ  ، عَنْ عَمْرٍو يَعْنِي ابْنَ الْحَارِثِ  ، عَنْ بُكَيْرٍ  ، عَنْ سُلَيْمَانَ بْنِ يَسَارٍ  ، قَالَ : "" أَيُّمَا رَجُلٍ أَتَى إِلَى غُلَامٍ يَزْعُمُ أَنَّهُ ابْنٌ لَهُ، وَأَنَّهُ زَنَى بِأُمِّهِ، وَلَمْ يَدَّعِ ذَلِكَ الْغُلَامَ أَحَدٌ، فَهُوَ يَرِثُهُ "". قَالَ بُكَيْرٌ : وَسَأَلْتُ عُرْوَةَ عَنْ ذَلِكَ، فَقَالَ مِثْلَ قَوْلِ سُلَيْمَانَ بْنِ يَسَارٍ وَقَالَ عُرْوَةُ   : بَلَغَنَا أَنَّ رَسُولَ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ، قَالَ :"" الْوَلَدُ لِلْفِرَاشِ، وَلِلْعَاهِرِ الْحَجَرُ """,,takhreej: !متفق علیہ: البخاری،کتاب الحدود،باب أحکام اہل الذمہ…(6841)ومسلم،کتاب الحدود،باب رجم الیہود أہل الذمۃ فی الزنا(4414-4413-4412), 2368,"حَدَّثَنَا إِبْرَاهِيمُ بْنُ مُوسَى  ، عَنْ حَفْصِ بْنِ غِيَاثٍ  ، عَنْ عَمْرٍو  ، عَنْ الْحَسَنِ  ، قَالَ :"" ابْنُ الْمُلَاعَنَةِ مِثْلُ وَلَدِ الزِّنَا، تَرِثُهُ أُمُّهُ، وَوَرَثَتُهُ، وَرَثَةُ أُمِّهِ """,,takhreej: ! متفق علیہ: البخاری،کتاب الحدود،باب الاعتراف بالزنا(6829)ومسلم،کتاب الحدود،باب رجم الثیب فی الزنا (4394) وابوداؤد،کتاب الحدود،باب فی الرجم(4418), 2369,"حَدَّثَنَا أَبُو النُّعْمَانِ ، حَدَّثَنَا أَبُو عَوَانَةَ ، عَنْ مُغِيرَةَ ، عَنْ إِبْرَاهِيمَ ، قَالَ :"" لَا يُوَرَّثُ وَلَدُ الزِّنَا """,,takhreej: ! متفق علیہ: اس کی ایک طرف حدیث(2366)میں ذکر ہوئی وہیں اس کی تخریج مذکور ہے۔, 2370,"حَدَّثَنَا سَعِيدُ بْنُ الْمُغِيرَةِ ، عَنْ ابْنِ الْمُبَارَكِ ، عَنْ مَعْمَرٍ ، أَوْ يُونُسَ ، عَنْ الزُّهْرِيِّ  : فِي أَوْلَادِ الزِّنَا، قَالَ :"" يَتَوَارَثُونَ مِنْ قِبَلِ الْأُمَّهَاتِ، وَإِنْ وَلَدَتْ تَوْءَمًا فَمَاتَ، وَرِثَ السُّدُسَ """,,takhreej: !صحیح مسلم،کتاب الحدود،باب من اعترف علی نفسہ بالزنا(4408)وابوداؤد،کتاب الحدود،باب المرأۃ التی أمر النبی صلعم یر جمہا سن جھینۃ(4440)والترمذی،کتاب الحدود،باب تربص الرجم بالحبلی حتی تضع(1435), 2371,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، قَالَ : حَدَّثَنَا هُشَيْمٌ ، عَنْ مُغِيرَةَ ، عَنْ شِبَاكٍ ، عَنْ إِبْرَاهِيمَ ، قَالَ :"" لَا يَرِثُ وَلَدُ الزِّنَا، إنما يرث من لم يقم على أبيه الحد، أو تملك أمه بنكاح 3، أو شراء """,,takhreej: @متفق علیہ: البخاری،کتاب العتق،باب کراہیۃ التطاول علی الرقیق(2556-2555) ومسلم،کتاب الحدود،باب رجم الیہود أہل الذمۃ فی الزنا(4423), 2372,"حَدَّثَنَا إِسْمَاعِيل بْنُ أَبَانَ  ، عَنْ مُوسَى بْنِ مُحَمَّدٍ الْأَنْصَارِيِّ  ، عَنْ إِسْمَاعِيل  ، عَنْ الْحَسَنِ   فِي الرَّجُلِ يَفْجُرُ بِالْمَرْأَةِ، ثُمَّ يَتَزَوَّجُهَا، قَالَ :"" لَا بَأْسَ، إِلَّا أَنْ تَكُونَ حُبْلَى، فَإِنَّ الْوَلَدَ لَا يَلْحَقُهُ """,,takhreej: !صحیح مسلم،کتاب الحدود،باب حد الزنا(4390)والترمذی،کتاب الحدود،باب الرجم علی الثیب(1434) وابن ماجہ، کتاب الحدود،باب حدالزنا(2550), 2373,"حَدَّثَنَا زَيْدُ بْنُ يَحْيَى  ، عَنْ مُحَمَّدِ بْنِ رَاشِدٍ  ، عَنْ سُلَيْمَانَ بْنِ مُوسَى  ، عَنْ عَمْرِو بْنِ شُعَيْبٍ  ، عَنْ أَبِيهِ  ، عَنْ جَدِّهِ   : أَنّ رَسُولَ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ : قَضَى أَنَّ"" كُلَّ مُسْتَلْحَقٍ اسْتُلْحِقَ بَعْدَ أَبِيهِ الَّذِي ادَّعَاهُ وَرَثَتُهُ بَعْدَهُ، فَقَضَى إِنْ كَانَ مِنْ أَمَةٍ يَمْلِكُهَا يَوْمَ يَطَؤُهَا، فَقَدْ لَحِقَ بِمَنْ اسْتَلْحَقَهُ، وَلَيْسَ لَهُ فِيمَا قُسِمَ قَبْلَهُ مِنْ الْمِيرَاثِ شَيْءٌ، وَمَا أَدْرَكَ مِنْ مِيرَاثٍ لَمْ يُقْسَمْ، فَلَهُ نَصِيبُهُ، وَلَا يَلْحَقُ إِذَا كَانَ الَّذِي يُدْعَى لَهُ أَنْكَرَهُ، وَإِنْ كَانَ مِنْ أَمَةٍ لَا يَمْلِكُهَا، أَوْ حُرَّةٍ عَاهَرَهَا، فَإِنَّهُ لَا يَلْحَقُ وَلَا يَرِثُ، وَإِنْ كَانَ الَّذِي يُدْعَى لَهُ هُوَ ادَّعَاهُ، فَهُوَ وَلَدُ زِنَا لِأَهْلِ أُمِّهِ مَنْ كَانُوا : حُرَّةً، أَوْ أَمَةً """,,takhreej: !صحیح: سابقہ حدیث ہی مکرر آئی ہے۔, 2374,"حَدَّثَنَا أَبُو نُعَيْمٍ ، عَنْ الْحَسَنِ ، عَنْ عُمَيْرِ بْنِ يَزِيدَ ، قَالَ : سَأَلْتُ الشَّعْبِيَّ  عَنْ مَمْلُوكٍ لِي وَلَدُ زِنًا، قَالَ :"" لَا تَبِعْهُ، وَلَا تَأْكُلْ ثَمَنَهُ، وَاسْتَخْدِمْهُ """,,takhreej: @موقوفاً ضعیف: اخرجہ احمد4/276والنسائی،کتاب النکاح،باب احلال الفر(3360)وابن ماجہ،کتاب الحدود، باب من وقع علی جاریۃ امرأتہ(2551), 2375,"حَدَّثَنَا مَرْوَانُ بْنُ مُحَمَّدٍ ، عَنْ سَعِيدٍ ، عَنْ الزُّهْرِيِّ  : سُئِلَ عَنْ وَلَدِ زِنَا يَمُوتُ، قَالَ :"" إِنْ كَانَ ابْنَ عَرَبِيَّةٍ، وَرِثَتْ أُمُّهُ الثُّلُثَ، وَجُعِلَ بَقِيَّةُ مَالِهِ فِي بَيْتِ الْمَالِ، وَإِنْ كَانَ ابْنَ مَوْلَاةٍ، وَرِثَتْ أُمُّهُ الثُّلُثَ، وَوَرِثَ مَوَالِيهَا الَّذِينَ أَعْتَقُوهَا مَا بَقِيَ. قَالَ مَرْوَانُ : سَمِعْتُ مَالِكًا  يَقُولُ ذَلِكَ",,takhreej: #ضعیف: اس میں خالد بن عرفطۃ ضعیف ہے۔ اخرجہ احمد4/277والطیالس1/300والترمذی فی الحدود (1451) وابن ماجہ فی الحدود،باب من وقع علی جاریۃ امرأتہ(3551), 2376,"حَدَّثَنَا مَرْوَانُ بْنُ مُحَمَّدٍ  ، حَدَّثَنَا الْهَيْثَمُ بْنُ حُمَيْدٍ  ، عَنْ الْعَلَاءِ بْنِ الْحَارِثِ  ، حَدَّثَنِي عَمْرُو بْنُ شُعَيْبٍ   : أَنَّ النَّبِيَّ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ :"" قَضَى بِمِيرَاثِ ابْنِ الْمُلَاعَنَةِ لِأُمِّهِ كُلِّهِ، لِمَا لَقِيَتْ فِيهِ مِنْ الْعَنَاءِ """,,takhreej: !حسن : اخرجہ طبرانی فی الکبیر4/88(حدیث3731)والدار قطنی3/214جب کہ عبادہ بن صامت رضی اللہ عنہ کی متفق علیہ حدیث بطور شاہد موجود ہے۔, 2377,"حَدَّثَنَا إِسْمَاعِيل بْنُ أَبَانَ  ، عَنْ مُوسَى بْنِ مُحَمَّدٍ الْأَنْصَارِيِّ  ، قَالَ : حَدَّثَنِي الْحَارِثُ بْنُ حَصِيرَةَ  ، عَنْ زَيْدِ بْنِ وَهْبٍ  ، عَنْ عَلِيٍّ   : أَنَّهُ قَالَ فِي وَلَدِ الزِّنَا لِأَوْلِيَاءِ أُمِّهِ :"" خُذُوا ابْنَكُمْ تَرِثُونَهُ وَتَعْقِلُونَهُ، وَلَا يَرِثُكُمْ """,,takhreej: !صحیح البخاری،کتاب الأیمان والنذر،باب من مات علیہ نذر(6699), 2378,"أَخْبَرَنَا أَبُو نُعَيْمٍ  ، وَعَبْدُ اللَّهِ بْنُ يَزِيدَ  ، قَالَا : حَدَّثَنَا شُعْبَةُ  ، عَنْ سَلَمَةَ بْنِ كُهَيْلٍ  ، عَنْ أَبِي عَمْرٍو الشَّيْبَانِيِّ  ، قَالَ : َقَالَ عَبْدُ اللَّهِ   :"" السَّائِبَةُ يَضَعُ مَالَهُ حَيْثُ شَاءَ "". قَالَ عَبْدُ اللَّهِ بْنُ يَزِيدَ : قَالَ شُعْبَةُ : لَمْ يَسْمَعْ هَذَا مِنْ سَلَمَةَ أَحَدٌ غَيْرِي",,takhreej: @متفق علیہ: البخاری،کتاب الایمان والنذور،باب اذا نذر أوحلف أن لایکلم انسانا فی الجاہلیۃ (6697) ومسلم، کتاب الأیمان، باب نذر الکافر،وما یفعل فیہ اذا اسلم(4269-4268), 2379,"أَخْبَرَنَا الْحَكَمُ بْنُ الْمُبَارَكِ  ، حَدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ  ، عَنْ يُونُسَ  ، عَنْ الْحَسَنِ   : سُئِلَ عَنْ مِيرَاثِ السَّائِبَةِ، فَقَالَ :"" كُلُّ عَتِيقٍ سَائِبَةٌ """,,takhreej: !متفق علیہ: البخاری،کتاب جزاء الصید،باب من نذر المشی الی الکعبۃ(1866(ومسلم،کتاب النذر،باب من نذر أن یمشی الی الکعبۃ(4227-4226), 2380,"أَخْبَرَنَا يَزِيدُ بْنُ هَارُونَ  ، أَنْبَأَنَا سُلَيْمَانُ  ، عَنْ أَبِي عُثْمَانَ  ، قَالَ : قَالَ عُمَرُ   :"" الصَّدَقَةُ وَالسَّائِبَةُ لِيَوْمِهِمَا، أَوْ لِوَقْتِهِمَا """,,takhreej: @صحیح: ابوداؤد،کتاب الأیمان والنذور،باب من رأی علیہ کفارۃ اذا کان فی معصیۃ (3297-3296 -3295) والبیہقی،کتاب النذور،باب الہدی فیہا رکب10/79واخرجہ احمد1/239, 2381,"حَدَّثَنَا أَبُو نُعَيْمٍ ، حَدَّثَنَا زَكَرِيَّا ، قَالَ : سُئِلَ عَامِرٍ  عَنْ الْمَمْلُوكِ يُعْتَقُ سَائِبَةً لِمَنْ وَلَاؤُهُ؟ قَالَ :"" لِلَّذِي أَعْتَقَهُ """,,takhreej: ! صحیح مسلم،کتاب النذور،باب من نذر أن قلشی الی الکعبۃ(4224)وابن ماجہ،کتاب الکفارات ، باب من نذر أن یحج ماشیا(2135), 2382,"حَدَّثَنَا أَبُو حَاتِمٍ الْبَصْرِيُّ هُوَ رَوْحُ بْنُ أَسْلَمَ  ، حَدَّثَنَا بِشْرُ بْنُ الْمُفَضَّلِ  ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِسْحَاق  ، عَنْ أَبِيهِ  ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَمْرٍو  ، قَالَ : "" مَاتَ مَوْلًى عَلَى عَهْدِ عُثْمَانَ   وَلَيْسَ لَهُ وَالٍ،فَأَمَرَ بِمَالِهِ، فَأُدْخِلَ بَيْتَ الْمَالِ """,,takhreej: @صحیح مسلم،کتاب النذور،باب لاوفاء لنذر فی معصیۃاللہ ولا فیہا لا یملک العبد(4221)وابن ماجہ،کتاب الکفارات،باب النذر فی المعصیۃ(2124), 2383,"حَدَّثَنَا يَعْلَى ، حَدَّثَنَا إِسْمَاعِيل ، عَنْ عَامِرٍ ، عَنْ مَسْرُوقٍ  : فِي رَجُلٍ مَاتَ وَلَمْ يَكُنْ لَهُ مَوْلَى عَتَاقَةٍ، قَالَ :"" مَالُهُ حَيْثُ أَوْصَى بِهِ، فَإِنْ لَمْ يَكُنْ أَوْصَى، فَهُوَ فِي بَيْتِ الْمَالِ """,,takhreej: #صحیح البخاری،کتاب الأیمان والنذور،باب النذور،باب ماجاء فی النذر فی معصیۃ(3289)والنسائی کتاب الأیمان والنذور،باب النذر فی المعصیۃ (3812), 2384,"حَدَّثَنَا أَبُو سَعِيدِ بْنُ عَمْرٍو ، عَنْ أَبِي بَكْرِ بْنِ أَبِي مَرْيَمَ ، عَنْ ضَمْرَةَ ، وَرَاشِدِ بْنِ سَعْدٍ ، وَغَيْرِهِمَا، قَالُوا فِيمَنْ أُعْتِقَ سَائِبَةً :"" إِنَّ وَلَاءَهُ لِمَنْ أَعْتَقَهُ، إِنَّمَا سَيَّبَهُ مِنْ الرِّقِّ، وَلَمْ يُسَيِّبْهُ مِنْ الْوَلَاءِ """,,takhreej: !صحیح : اخرجہ الحاکم4/305-304والبیہقی فی النذور،باب من لم یرو جوب بالنذر10/82, 2385,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ شُعْبَةَ ، قَالَ : أَخْبَرَنِي مَنْصُورٌ ، عَنْ إِبْرَاهِيمَ ، وَالشَّعْبِيِّ ، قَالَا :"" لَا بَأْسَ بِبَيْعِ وَلَاءِ السَّائِبَةِ وَهِبَتِهِ """,,takhreej: @متفق علیہ: البخاری،کتاب القدر،باب إلقاء العبد النذر الی القدر(6608)ومسلم،کتاب النذر،باب النہی عند النذر وأنہ لا یرد شیئًا (4212) وابن ماجہ ، کتاب الکفارات با النہی عن النذر (2122), 2386,"حَدَّثَنَا أَبُو نُعَيْمٍ  ، حَدَّثَنَا الْمَسْعُودِيُّ  ، عَنْ الْقَاسِمِ  ، قَالَ : "" أَعْتَقَ رَجُلٌ غُلَامًا سَائِبَةً، فَأَتَى عَبْدَ اللَّهِ  ، وَقَالَ : إِنِّي أَعْتَقْتُ غُلَامًا لِي سَائِبَةً، وَهَذِهِ تَرِكَتُهُ، قَالَ : هِيَ لَكَ، قَالَ :لَا حَاجَةَ لِي فِيهَا، قَالَ : فَضَعْهَا، فَإِنَّ هَهُنَا وَارِثًا كَثِيرًا """,,takhreej: ! متفق علیہ :البخاری،کتاب الأدب،باب من لم یریا کفار من قال ذلک متأولا اوجاہلا(6108)ومسلم،کتاب الأیمان،باب النہی عن الحلف بغیر اللہ تعالیٰ(4233), 2387,"أَخْبَرَنَا يَزِيدُ بْنُ هَارُونَ  ، أَنْبَأَنَا الْأَشْعَثُ  ، عَنْ أَبِي الزُّبَيْرِ  ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ  ، قَالَ :"" إِذَا اسْتَهَلَّ الصَّبِيُّ، وُرِّثَ وَصُلِّيَ عَلَيْهِ """,,takhreej: @صحیح: ابن حبان (4339) اخرجہ ابوداؤد،کتاب الأیمان،باب الاستشناء فی الیمین(1531)والنسائی،فی الکتاب الأیمان ، باب من حلف فاستشنیٰ(3702), 2388,"حَدَّثَنَا أَبُو نُعَيْمٍ  ، حَدَّثَنَا شَرِيكٌ  ، عَنْ أَبِي إِسْحَاق  ، عَنْ عَطَاءٍ  ، عَنْ ابْنِ عَبَّاسٍ  ، قَالَ :"" إِذَا اسْتَهَلَّ الصَّبِيُّ، وَرِثَ وَوُرِثَ وَصُلِّيَ عَلَيْهِ """,,takhreej: #صحیح: تخریج گزر چکی ہے۔, 2389,"حَدَّثَنَا مَالِكُ بْنُ إِسْمَاعِيل  ، حَدَّثَنَا إِسْرَائِيلُ  ، عَنْ سِمَاكٍ  ، عَنْ عِكْرِمَةَ  ، عَنْ ابْنِ عَبَّاسٍ  ، قَالَ :"" لَيْسَ مِنْ مَوْلُودٍ إِلَّا يَسْتَهِلُّ، وَاسْتِهْلَالُهُ بِعَصْرِ الشَّيْطَانُ بَطْنَهُ، فَيَصِيحُ، إِلَّا عِيسَى ابْنَ مَرْيَمَ """,,takhreej: !اسنادہ صغیف: لیکن حدیث متفق علیہ ہے یہ حدیث(2202)نمبر حدیث کے تحت مکمل گزر چکی ہے۔, 2390,"حَدَّثَنَا يَحْيَى بْنُ حَسَّانَ  ، حَدَّثَنَا يَحْيَى هُوَ ابْنُ حَمْزَةَ  ، عَنْ زَيْدِ بْنِ وَاقِدٍ  ، عَنْ مَكْحُولٍ  ، قَالَ : قَالَ رَسُولُ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ :"" لَا يَرِثُ الْمَوْلُودُ حَتَّى يَسْتَهِلَّ صَارِخًا، وَإِنْ وَقَعَ حَيًّا """,,takhreej: @ صحیح مسلم،کتاب الأیمان،باب ندب من حلف یمینافر أی غیرہا خیراً منہا…(1651)والنسائی،کتاب الأیمان،باب الکفارۃ بعد الحنث(3794), 2391,"حَدَّثَنَا يَعْلَى  ، حَدَّثَنَا مُحَمَّدُ بْنُ إِسْحَاق  ، عَنْ عَطَاءٍ  ، عَنْ جَابِرٍ  ، قَالَ :"" إِذَا اسْتَهَلَّ الْمَوْلُودُ، صُلِّيَ عَلَيْهِ وَوُرِثَ """,,takhreej: !متفق علیہ: البخاری،کتاب کفارات الأیمان،باب الکفارۃ بعد الحنث وبعدہ(6722)ومسلم،کتاب الأیمان،باب ندب من حلف یمینا(4258-4257), 2392,"حَدَّثَنَا عَبْدُ اللَّهِ بْنُ مُحَمَّدٍ ، حَدَّثَنَا مَعْنٌ ، عَنْ ابْنِ أَبِي ذِئْبٍ ، عَنْ الزُّهْرِيِّ ، قَالَ : أَرَى"" الْعُطَاسَ اسْتِهْلَالًا """,,takhreej: @متفق علیہ: سابقہ حدیث ہی مکرر آئی ہے۔, 2393,"حَدَّثَنَا أَبُو النُّعْمَانِ ، حَدَّثَنَا أَبُو عَوَانَةَ ، عَنْ مُغِيرَةَ ، عَنْ إِبْرَاهِيمَ ، قَالَ :"" لَا يُوَرَّثُ الْمَوْلُودُ حَتَّى يَسْتَهِلَّ، وَلَا يُصَلَّى عَلَيْهِ حَتَّى يَسْتَهِلَّ، فَإِذَا اسْتَهَلَّ، صُلِّيَ عَلَيْهِ وَوُرِّثَ، وَكُمِّلَتْ الدِّيَةُ """,,takhreej: # اسنادہ حسن : محمد بن عمرو کی وجہ سے،صحیح ابن حبان(189), 2394,"حَدَّثَنَا عَبْدُ اللَّهِ بْنُ صَالِحٍ ، حَدَّثَنِي اللَّيْثُ ، حَدَّثَنِي يُونُسُ ، عَنْ ابْنِ شِهَابٍ  : وَسَأَلْنَاهُ عَنْ السِّقْطِ، فَقَالَ :"" لَا يُصَلَّى عَلَيْهِ، وَلَا يُصَلَّى عَلَى مَوْلُودٍ حَتَّى يَسْتَهِلَّ صَارِخًا """,,takhreej: ! صحیح مسلم،کتاب الأیمان،باب یمین الحالف علی نیۃ المستحلف(4260-4259)والترمذی،کتاب الأحکام، باب ماجاء أن الیمین علی ما یصدقہ صاحبہ(1354)وابن ماجہ،کتاب الکفارات،باب من وری فی یمینہ (6120), 2395,"حَدَّثَنَا هَارُونُ بْنُ مُعَاوِيَةَ ، عَنْ أَبِي سُفْيَانَ ، عَنْ مَعْمَرٍ ،  عَنْ قَتَادَةَ ، قَالَ :"" إِذَا ابْتَاعَ الْمُكَاتَبَانِ أَحَدُهُمَا الْآخَرَ : هَذَا هَذَا مِنْ سَيِّدِهِ، وَهَذَا هَذَا مِنْ سَيِّدِهِ، فَالْبَيْعُ لِلْأَوَّلِ. وَيَقُولُ أَهْلُ الْمَدِينَةِ : الْوَلَاءُ لِسَيِّدِ الْبَائِعِ، وَيَقُولُونَ : إِنَّمَا ابْتَاعَ هَذَا مَا عَلَى الْمُكَاتَبِ، فَالْوَلَاءُ لِلسَّيِّدِ",,takhreej: @ صحیح البخاری،کتاب الأیمان والنذور،باب کیف کانت یمین النبی صلعم(6628)ابوداؤد،کتاب الأیمان والنذور،باب ماجاء فی یمین النبی صلعم ماکانت؟(3263), 2396,"حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ  ، حَدَّثَنَا يَحْيَى  ، عَنْ سَعِيدٍ  ، أَنَّ عُمَرَ  ، قَالَ :"" أَيُّمَا حُرٍّ تَزَوَّجَ أَمَةً، فَقَدْ أَرَقَّ نِصْفَهُ، وَأَيُّمَا عَبْدٍ تَزَوَّجَ حُرَّةً، فَقَدْ أَعْتَقَ نِصْفَهُ، قَالَ أَبُو مُحَمَّد : يَعْنِي الْوَلَدَ",,takhreej: !ضعیف ، منکر: ابوداؤد،کتاب الدیات،باب الإمام یأمر بالعفو فی الدم(4496)وابن ماجہ،کتاب الدیات،باب من قتل لہ قتیل فہو بالخیار بین أحدی ثلاث(2623), 2397,"حَدَّثَنَا أَحْمَدُ بْنُ عَبْدِ اللَّهِ ، حَدَّثَنَا أَبُو شِهَابٍ ، عَنْ الشَّيْبَانِيِّ ،  عَنْ الشَّعْبِيِّ  : فِي الْعَبْدِ يَتَزَوَّجُ الْمَرْأَةَ، ثُمَّ يُطَلِّقُهَا وَلَهُ مِنْهَا وَلَدٌ؟ قَالَ :"" إِنْ كَانَتْ حُرَّةً، فَالنَّفَقَةُ عَلَى أُمِّهِ، وَإِنْ كَانَ عَبْدًا، يَعْنِي : الصَّبِيَّ، فَعَلَى مُوَالِيهِ """,,takhreej: ! اسنادہ ضعیف: لیکن بخاری میںابو ہریرہ رضی اللہ عنہ کی حدیث سے ایک شاہد موجود ہے۔کتاب العلم،باب کتابۃ العلم, 2398,"حَدَّثَنَا مُحَمَّدُ بْنُ عِيسَى ، حَدَّثَنَا هُشَيْمٌ ، حَدَّثَنَا زَكَرِيَّا ، عَنْ عَامِرٍ . ح وحَدَّثَنَا جَرِيرٌ ، عَنْ مُغِيرَةَ ، عَنْ إِبْرَاهِيمَ  : أَنَّهُمَا قَالَا :"" وَلَاؤُهُ لِمَنْ بَدَأَ بِالْعِتْقِ أَوَّلَ مَرَّةٍ """,,takhreej: !متتفق علیہ: البخاری،کتاب الجزیۃ ، باب الموادۃ والمصالحۃ مع المشرکین بالمال وغیرہ… (3173) ومسلم ، کتاب الفسامتہ،باب القسامۃ (4334), 2399,"حَدَّثَنَا مُحَمَّدُ بْنُ عِيسَى ، حَدَّثَنَا هُشَيْمٌ ، أنبأنا يُونُسُ ، عَنْ الْحَسَنِ . ح وحَدَّثَنَا جَرِيرٌ ، عَنْ أَبَانَ بْنِ تَغْلِبَ ، عَنْ الْحَكَمِ ، عَنْ إِبْرَاهِيمَ ، أَنَّهُمَا قَالَا :"" إِنْ ضَمِنَ، كَانَ الْوَلَاءُ لَهُ، وَإِنْ اسْتَسْعَى الْعَبْدُ، كَانَ الْوَلَاءُ بَيْنَهُمْ """,,takhreej: @ضعیف: لیکن اگلی متفق علیہ حدیث اس کی شاہد ہے۔, 2400,"حَدَّثَنَا يَعْلَى ، وَأَبُو نُعَيْمٍ ، قَالَا : حَدَّثَنَا زَكَرِيَّا ، عَنْ عَامِرٍ  : فِي عَبْدٍ بَيْنَ رَجُلَيْنِ أَعْتَقَ أَحَدُهُمَا نَصِيبَهُ، فَقَالَ :"" يُتَمَّمُ عِتْقُهُ، فَإِنْ لَمْ يَكُنْ لَهُ مَالٌ، اسْتُسْعِيَ الْعَبْدُ فِي النِّصْفِ بِقِيمَةِ عَدْلٍ، وَالْوَلَاءُ لِمَنْ أَعْتَقَ """,,takhreej: !متفق علیہ: البخاری،کتاب الخصومات،ما یذر فی الأشخاص،الخصومۃ بین المسلم والیہود (2413) ومسلم ، کتاب القسامۃ،باب ثبوت القصاص فی القتل بالحجر وغیرہ(4341), 2401,"حَدَّثَنَا هَارُونُ بْنُ مُعَاوِيَةَ ، عَنْ أَبِي سُفْيَانَ الْمَعْمَرِيِّ ، عَنْ مَعْمَرٍ ، عَنْ ابْنِ طَاوُسٍ ، عَنْ أَبِيهِ  : فِي عَبْدٍ بَيْنَ رَجُلَيْنِ، أَعْتَقَ أَحَدَهُمَا نَصِيبَهُ وَأَمْسَكَهُ الْآخَرُ، قَالَ :"" مِيرَاثُهُ بَيْنَهُمَا """,,takhreej: @صحیح البخاری،کتاب الدیات،باب لا یقتل المسلم بالکافر (6915)والترمذی،کتاب الدیات،باب ماجاء لایقتل مسلم یکافر (1413) وابن ماجہ ، کتاب الدیات ، باب لایقتل مسلم یکافر (2658), 2402,"حَدَّثَنَا هَارُونُ ، عَنْ أَبِي سُفْيَانَ ، عَنْ مَعْمَرٍ ، عَنْ الزُّهْرِيِّ ، قَالَ :"" مِيرَاثُهُ لِلَّذِي أَمْسَكَهُ. وقال قَتَادَةُ  : هُوَ لِلْمُعْتِقِ كُلُّهُ، وَثَمَنُهُ عَلَيْهِ، وَيَقُولُهُ أَهْلُ الْكُوفَةِ",,takhreej: !ضعیف: لیکن حدیث طرق اور شواہد کی بناء پر صحیح ہے۔ دیکھئے: نصب الرایۃ4/341-340والتلخیص الجبیر4/77, 2403,"حَدَّثَنَا يَعْلَى بْنُ عُبَيْدٍ ، حَدَّثَنَا عَبْدُ الْمَلِكِ ، عَنْ عَطَاءٍ  : فِي الرَّجُلِ يَمُوتُ وَيَتْرُكُ مُكَاتَبًا، وَلَهُ بَنُونَ وَبَنَاتٌ، أَيَكُونُ لِلنِّسَاءِ مِنْ الْوَلَاءِ شَيْءٌ؟ قَالَ :"" تَرِثُ النِّسَاءُ مِمَّا عَلَى ظَهْرِهِ مِنْ مُكَاتَبَتِهِ، وَيَكُونُ الْوَلَاءُ لِلرِّجَالِ دُونَ النِّسَاءِ، إِلَّا مَا كَاتَبْنَ، أَوْ أَعْتَقْنَ """,,takhreej: ! منقطع، ضعیف: حسن کا ثمرۃ سے سماع ثابت نہیں۔ واخرجہ ابوداؤد،کتاب الدیات،باب من قتل عبدہ (4515) والنسائی، کتاب القسامۃ،باب القدر من السید للمولی(4750)وابن ابی شیبہ14/187والحاکم4/367, 2404,"حَدَّثَنَا أَبُو نُعَيْمٍ ، حَدَّثَنَا شَرِيكٌ ، عَنْ لَيْثٍ ، عَنْ طَاوُسٍ ، قَالَ :"" لَا تَرِثُ النِّسَاءُ مِنْ الْوَلَاءِ إِلَّا مَا أَعْتَقْنَ، أَوْ أَعْتَقَ مَنْ أَعْتَقْنَ """,,takhreej: @ صحیح مسلم،کتاب القسامۃ،باب صحۃ الإقرار بالقتل…(4364-4363)والبیہقی فی الجنایات،باب ماجاء فی الترغیب فی العفو عن القصاص8/55وابوداؤد،کتاب الدیات،باب الإمام یأمر بالعفو فی الدم(4499), 2405,"حَدَّثَنَا مُحَمَّدُ بْنُ عِيسَى ، حَدَّثَنَا أَبُو سُفْيَانَ ، عَنْ مَعْمَرٍ ، عَنْ يَحْيَى بْنِ أَبِي كَثِيرٍ ، قَالَ :"" تُوُفِّيَ رَجُلٌ وَتَرَكَ مُكَاتَبًا، ثُمَّ مَاتَ الْمُكَاتَبُ وَتَرَكَ مَالًا، فَجَعَلَ ابْنُ الْمُسَيَّبِ ، وَأَبُو سَلَمَةَ بْنُ عَبْدِ الرَّحْمَنِ  مَا بَقِيَ مِنْ مُكَاتَبَتِهِ بَيْنَ بَنِي مَوْلَاهُ الرِّجَالُ وَالنِّسَاءُ عَلَى مِيرَاثِهِمْ، وَمَا فَضَلَ مِنْ الْمَالِ بَعْدَ كِتَابَتِهِ، فَلِلرِّجَالِ مِنْهُمْ مِنْ بَنِي مَوْلَاهُ، دُونَ النِّسَاءِ """,,takhreej: !صحیح البخاری،کتاب الأیمان والنذور،باب الیمین الغموس(6675)والترمذی،کتاب التفسیر،باب ومن سورۃ النساء (3021) والنسائی،کتاب التحریم الدم،باب الکبائر(4022), 2406,"أَخْبَرَنَا مُحَمَّدُ بْنُ عِيسَى  ، حَدَّثَنَا عَبْدُ السَّلَامِ بْنُ حَرْبٍ  ، عَنْ الْأَعْمَشِ  ، عَنْ إِبْرَاهِيمَ  ، عَنْ عُمَرَ  ، وَعَلِيٍّ  ، وَزَيْدٍ   ، أَنَّهُمْ قَالُوا :"" الْوَلَاءُ لِلْكُبْرِ، وَلَا يَرِثُونَ النِّسَاءَ مِنْ الْوَلَاءِ إِلَّا مَا أَعْتَقْنَ، أَوْ كَاتَبْنَ """,,takhreej: @متفق علیہ: البخاری،کتاب الادب،باب ماینہی عن السباب واللعن(6047)ومسلم،کتاب الإیمان،باب غلظ تحریم قتل الانسان نفسہ … (300-299-298), 2407,"حَدَّثَنَا مُحَمَّدُ بْنُ عِيسَى ، حَدَّثَنَا إِسْمَاعِيل بْنُ إِبْرَاهِيمَ ، عَنْ خَالِدٍ ، عَنْ أَبِي قِلَابَةَ . ح وحَدَّثَنَا ابْنُ وَهْبٍ ، عَنْ يُونُسَ ، عَنْ الزُّهْرِيِّ ، عَنْ سَعِيدِ بْنِ الْمُسَيِّبِ . ح وحَدَّثَنَا ابْنُ أَبِي الزِّنَادِ ، عَنْ أَبِيهِ ، عَنْ سُلَيْمَانَ بْنِ يَسَارٍ  : أَنَّهُمْ قَالُوا :"" لَا يَرِثُ النِّسَاءُ مِنْ الْوَلَاءِ إِلَّا مَا أَعْتَقْنَ، أَوْ كَاتَبْنَ """,,takhreej: !متفق علیہ: البخاری،کتاب الطب،باب شرب السم،والدواء بہ وما یخاف منہ(5778)ومسلم،کتاب الإیمان،باب غلظ تحریم قتل الإنسان نفسہ(296), 2408,"حَدَّثَنَا مُحَمَّدُ بْنُ عِيسَى ، عن مُعَاذٌ ، عَنْ أَشْعَثَ ، عَنْ الْحَسَنِ ، قَالَ :"" لَا تَرِثُ النِّسَاءُ مِنْ الْوَلَاءِ إِلَّا مَا أَعْتَقْنَ، أَوْ أَعْتَقَ مَنْ أَعْتَقْنَ، إِلَّا الْمُلَاعَنَةُ، فَإِنَّهَا تَرِثُ مَنْ أَعْتَقَ ابْنُهَا، وَالَّذِي انْتَفَى مِنْهُ أَبُوهُ """,,takhreej: @مرسل : اخرجہ ابوداؤد،کتاب الدیات،باب الدیۃ کم ہی(4546)والترمذی،کتاب الدیات،باب الدیۃ کم ہی من الدراہم (1389-1388) والنسائی،کتاب القسامۃ باب ذکر الدیۃ من الورق(4818-4817), 2409,"حَدَّثَنَا مُحَمَّدُ بْنُ عِيسَى  ، حَدَّثَنَا ابْنُ وَهْبٍ  ، عَنْ يُونُسَ  ، عَنْ الزُّهْرِيِّ  ، عَنْ سَالِمٍ  ، عَنْ أَبِيهِ   : أَنَّهُ كَانَ"" يَرِثُ مَوَالِيَ عُمَرَ دُونَ بَنَاتِ عُمَرَ """,,takhreej: !ضعیف: صحیح ابن حبان(6559)ونیل الاوطار لشوکانی7/164-163, 2410,"أَخْبَرَنَا عَمْرُو بْنُ عَوْنٍ ، عَنْ خَالِدِ بْنِ عَبْدِ اللَّهِ ، عَنْ خَالِدٍ الْحَذَّاءِ ، عَنْ أَبِي قِلَابَةَ  فِي امْرَأَةٍ مَاتَتْ، وَتَرَكَتْ بَنِيهَا، فَوَرِثُوهَا مَالًا وَمَوَالِيَ، قَالَ :"" يَرْجِعُ الْوَلَاءُ إِلَى عَصَبَةِ الْمَرْأَةِ """,,takhreej: ! اسنادہ ضعیف: لیکن ابوداؤد،کتاب الدیات،باب الدیۃ کم ہی؟ (4541)والنسائی فی القسامۃ،باب کم دیۃ شبہ العمد میں اس روایت کا شاہد موجود ہے۔, 2411,"حَدَّثَنَا عُبَيْدُ اللَّهِ ، عَنْ إِسْرَائِيلَ ، عَنْ مَنْصُورٍ ، قَالَ : سَأَلْتُ إِبْرَاهِيمَ  عَنْ رَجُلٍ كَاتَبَ عَبْدًا لَهُ، ثُمَّ مَاتَ وَتَرَكَ وَلَدًا رِجَالًا وَنِسَاءً، قَالَ :"" لِلذُّكُورِ دُونَ الْإِنَاثِ """,,takhreej: @اسنادہ ضعیف: سابقہ تعلیقات ملاحظہ کریں۔, 2412,"حَدَّثَنَا أَبُو النُّعْمَانِ ، حَدَّثَنَا وُهَيْبٌ ، حَدَّثَنَا يُونُسُ ، عَنْ الْحَسَنِ ، أَنَّهُ كَانَ يَقُولُ فِي امْرَأَةٍ مَاتَتْ وَتَرَكَتْ مَوْلًى، قَالَ :"" الْوَلَاءُ لِبَنِيهَا، فَإِذَا مَاتُوا، رَجَعَ إِلَى عَصَبَتِهَا """,,takhreej: !ضعیف: اس میں حجاج ضعیف ہے۔ اخرجہ احمد1/384والبیہقی فی الدیات،باب من قال ہی أخماس8/75, 2413,"حَدَّثَنَا سَعِيدُ بْنُ عَامِرٍ ، أَخْبَرَنَا شُعْبَةُ ، عَنْ مُغِيرَةَ ، عَنْ إِبْرَاهِيمَ  قَالَ :"" لَيْسَ لِلنِّسَاءِ مِنْ الْوَلَاءِ شَيْءٌ، إِلَّا مَا أَعْتَقَتْ هِيَ فيَ نَفْسِهَا """,,takhreej: @حسن: ابوداؤد،کتاب الدیات،باب جنابۃ العید یکون للفقرائ(4590)والنسائی،کتاب القسامۃ،باب سقوط القود بین الممالیک فیما دون النفس(4765), 2414,"حَدَّثَنَا سَعِيدُ بْنُ عَامِرٍ  ، عَنْ ابْنِ عَوْنٍ  ، عَنْ مُحَمَّدٍ  ، قَالَ : مَاتَ مَوْلًى لِعُمَرَ، فَسَأَلَ ابْنُ عُمَرَ زَيْدَ بْنَ ثَابِتٍ  ، فَقَالَ : هَلْ لِبَنَاتِ عُمَرَ مِنْ مِيرَاثِهِ شَيْءٌ؟ قَالَ :"" مَا أَرَى لَهُنَّ شَيْئًا، وَإِنْ شِئْتَ أَنْ تُعْطِيَهُنَّ، أَعْطَيْتَهُنَّ """,,takhreej: !جید،صحیح: ابوداؤد،کتاب الدیات،باب دیات الأعضائ(4557)والنسائی،کتاب القسامۃ،باب عقل الأصابع (4860) وابن ماجہ،کتاب الدیات،باب دیۃ الأصابع(2654), 2415,"حَدَّثَنَا عَبْدُ اللَّهِ بْنُ سَعِيدٍ ، حَدَّثَنَا أَبُو أُسَامَةَ ، عَنْ هِشَامٍ ، عَنْ أَبِيهِ ، قَالَ :"" يُحْرِزُ الْوَلَاءَ مَنْ يُحْرِزُ الْمِيرَاثَ """,,takhreej: @صحیح البخاری،کتاب الدیات،باب دیۃ الأصابع(6895)کتاب الدیات،باب ماجاء فی دیۃ الأصابع(1392)وابن ماجہ کتاب الدیات،باب دیۃ الأصابع(2652), 2416,"حَدَّثَنَا عَبْدُ اللَّهِ بْنُ سَعِيدٍ  ، حَدَّثَنَا أَبُو خَالِدٍ  ، حَدَّثَنَا يَحْيَى  ، عَنْ أَبِي بَكْرِ بْنِ عَمْرِو بْنِ حَزْمٍ   :"" أَنَّ امْرَأَةً مِنْ مُحَارِبٍ وَهَبَتْ وَلَاءَ عَبْدِهَا لِنَفْسِهِ، فَأَعْتَقَتْهُ، فَوَهَبَ وَلاءَ نَفْسِهِ لِعَبْدِ الرَّحْمَنِ بْنِ عَمْرِو بْنِ حَزْمٍ، وَمَاتَتْ، فَخَاصَمَتِ الْمَوَالِيَ إِلَى عُثْمَانَ، فَدَعَا عُثْمَانُ الْبَيِّنَةَ عَلَى مَا قَالَ، قَالَ : فَأَتَى الْبَيِّنَةُ، فَقَالَ لَهُ عُثْمَانُ   : اذْهَبْ، فَوَالِ مَنْ شِئْتَ "". قَالَ أَبُو بَكْرٍ : فَوَالَى عَبْدَ الرَّحْمَنِ بْنَ عَمْرِو بْنِ حَزْمٍ",,takhreej: #ضعیف: صحیح ابن حبان(6559), 2417,"حَدَّثَنَا أَبُو نُعَيْمٍ  ، حَدَّثَنَا سُفْيَانُ  ، عَنْ عَبْدِ اللَّهِ بْنِ دِينَارٍ  ، عَنْ ابْنِ عُمَرَ  ، قَالَ : "" نَهَى رَسُولُ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ عَنْبَيْعِ الْوَلَاءِ، وَعَنْ هِبَتِهِ """,,takhreej: ! اسنادہ حسن: ابوداؤد،کتاب الدیات،باب دیات الاعضائ(4566)والترمذی،کتاب الدیات،باب ماجاء فی الموضحۃ (1390) والنسائی،کتاب القسامۃ،باب المواضح(4867), 2418,"حَدَّثَنَا مُسْلِمٌ  ، حَدَّثَنَا شُعْبَةُ  ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ دِينَارٍ  ، عَنْ ابْنِ عُمَرَ   : "" أَنّ النَّبِيَّ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَنَهَى عَنْ بَيْعِ الْوَلَاءِ، وَعَنْ هِبَتِهِ """,,takhreej: @اسنادہ ضعیف: لیکن اس حدیث کے شواہد موجود ہیں دیکھئے حدیث نمبر (2416-2410-2409-2399)ان میں اس حدیث کے اطراف گزر چکے ہیں۔, 2419,"حَدَّثَنَا يَعْلَى  ، حَدَّثَنَا عَبْدُ الْمَلِكِ  ، عَنْ عَطَاءٍ  ، قَالَ : سَمِعْتُ ابْنَ عَبَّاسٍ  ، يَقُولُ :"" لَا يُبَاعُ الْوَلَاءُ وَلَا يُوهَبُ، وَالْوَلَاءُ لِمَنْ أَعْتَقَ """,,takhreej: ! اسنادہ حسن: اخرجہ ابوداؤد،کتاب الدیات،باب دیات الأعضائ(4563) والنسائی،کتاب القسامۃ،باب عقل الأسنان (4856) وابن ماجہ،کتاب الدیات،باب دیۃ الأسنان(2651), 2420,"حَدَّثَنَا جَعْفَرُ بْنُ عَوْنٍ  ، عَنْ سَعِيدٍ  ، عَنْ أَبِي مَعْشَرٍ  ، عَنْ إِبْرَاهِيمَ  ، قَالَ : قَالَ عَبْدُ اللَّهِ   :"" الْوَلَاءُ لُحْمَةٌ كَلُحْمَةِ النَّسَبِ، لَا يُبَاعُ وَلَا يُوهَبُ """,,takhreej: @اسنادہ ضعیف: لیکن سابقہ ہدیث اس کی شاہد ہے۔, 2421,"حَدَّثَنَا مُسْلِم ، حَدَّثَنَا هَمَّامٌ ، حَدَّثَنَا قَتَادَةُ ، عَنْ الْحَسَنِ ، وَسَعِيدِ بْنِ الْمُسَيِّبِ  : "" أنهماكرها بيع الولاء """,,takhreej: #متفق علیہ: البخاری،کتاب الدیات،باب اذا عض رجلًا فوقعت ثنایاہ(6892)ومسلم،کتاب القسامۃ،باب القود من العضۃ (4773), 2422,"حَدَّثَنَا عَبْدُ اللَّهِ بْنُ سَعِيدٍ  ، حَدَّثَنَا ابْنُ إِدْرِيسَ  ، عَنْ ابْنِ جُرَيْجٍ  ، عَنْ عَطَاءٍ  ، قَالَ : قَالَ ابْنُ عَبَّاسٍ   :"" لَا يُبَاعُ الْوَلَاءُ، أَيُؤْكَلُ بِرَقَبَةِ رَجُلٍ مَرَّتَيْنِ؟ """,,takhreej: ! متفق علیہ: البخاری،کتاب الدیات،باب المعدن جبار والبٔر جبار(6912)ومسلم،کتاب الحدود،باب جرح العجماء والمعدن والبئر(440), 2423,"حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ  ، حَدَّثَنَا سُفْيَانُ  ، عَنْ ابْنِ جُرَيْجٍ  ، عَنْ عَطَاءٍ  ، عَنْ ابْنِ عَبَّاسٍ  ، قَالَ :"" الْفَرَائِضُ مِنْ سِتَّةٍ، لَا نُعِيلُهَا """,,takhreej: @ اسنادہ حسن: لیکن حدیث متفق علیہ ہے(1710)کے تحت یہ حدیث گزر چکی ہے۔, 2424,"حَدَّثَنَا مُحَمَّدُ بْنُ عِمْرَانَ ، عَنْ مُعَاوِيَةَ بْنِ مَيْسَرَةَ بْنِ شُرَيْحٍ ، عَنْ شريح بْنِ الْحَارِثِ ، قَالَ : "" اخْتُصِمَ إِلَى شُرَيْحٍ فِي بِنْتَيْنِ، وَأَبَوَيْنِ، وَزَوْجٍ، فَقَضَى فِيهَا، فَأَقْبَلَ الزَّوْجُ يَشْكُوهُ فِي الْمَسْجِدِ، فَأَرْسَلَ إِلَيْهِ عَبْدَ اللَّهِ بْنَ رَبَاحٍ فَأَخَذَهُ، وَبَعَثَ إِلَى شُرَيْحٍ، فَقَالَ : مَا يَقُولُ هَذَا؟ قَالَ : هَذَا يَخَالُنِي امْرَأً جَائِرًا، وَأَنَا إِخَالُهُ امْرَأً فَاجِرًا، يُظْهِرُ الشَّكْوَى وَيَكْتُمُ قَضَاءً سَائِرًا، فَقَالَ لَهُ الرَّجُلُ : مَا تَقُولُ فِي بِنْتَيْنِ، وَأَبَوَيْنِ، وَزَوْجٍ؟ فَقَالَ :لِلزَّوْجِ الرُّبُعُ مِنْ جَمِيعِ الْمَالِ، وَلِلْأَبَوَيْنِ السُّدُسَانِ، وَمَا بَقِيَ فَلِلِابْنَتَيْنِ، قَالَ : فَلِأَيِّ شَيْءٍ نَقَصْتَنِي؟ قَالَ : لَيْسَ أَنَا نَقَصْتُكَ، اللَّهُ نَقَصَكَ، لِلِابْنَتَيْنِ الثُّلُثَانِ، وَلِلْأَبَوَيْنِ السُّدُسَانِ، وَلِلزَّوْجِ الرُّبُعُ، فَهِيَ مِنْ سَبْعَةٍ وَنِصْفٍ فَرِيضَةً، فَرِيضَتُكَ عَائِلَةٌ """,,takhreej: #صحیح: سابقہ حدیث مکرر آئی ہے۔, 2425,"حَدَّثَنَا مُحَمَّدُ بْنُ عُيَيْنَةَ  ، عَنْ عَلِيِّ بْنِ مُسْهِرٍ  ، عَنْ أَشْعَثَ  ، عَنْ الشَّعْبِيِّ  ، عَنْ عَلِيٍّ  ، وَعُمَرَ  ، وَزَيْدٍ   ، قَالُوا :"" الْوَالِدُ يَجُرُّ وَلَاءَ وَلَدِهِ """,,takhreej: !متفق علیہ: البخاری،کتاب الدیات،باب جنین المرأۃ(6905)ومسلم،کتاب القسامۃ،باب دیۃ الجنین ووجوب الدیۃ… (4369)و(4370), 2426,"حَدَّثَنَا مُحَمَّدُ بْنُ عُيَيْنَةَ ، عَنْ عَلِيِّ بْنِ مُسْهِرٍ ، عَنْ أَشْعَثَ ، عَنْ الشَّعْبِيِّ ، قَالَ :"" الْجَدُّ يَجُرُّ الْوَلَاءَ """,,takhreej: @ اسنادہ صحیح: ابوداؤد میں این جریج تحدیث کے صیغہ سے روایت بیان کرتے ہیں۔ أخرجہ ابوداؤد،کتاب الدیات،باب دیۃ الجنبن (4572)والنسائی،کتاب القسامۃ،باب قتل المرأۃ بالمرأۃ(4753)وابن ماجہ،کتاب الدیات،باب دیۃ الجنین (2641), 2427,"حَدَّثَنَا مُحَمَّدُ بْنُ عُيَيْنَةَ ، عَنْ عَلِيِّ بْنِ مُسْهِرٍ ، عَنْ أَشْعَثَ ، عَنْ ابْنِ سِيرِينَ ، عَنْ شُرَيْحٍ ، قَالَ :"" الْوَالِدُ يَجُرُّ وَلَاءَ وَلَدِهِ """,,takhreej: !متفق علیہ: البخاری،کتاب الدیات،باب جنین المرأۃ وأن العفل علی الوالد…(6909)ومسلم،کتاب القسامۃ باب الدیۃ الجنین ووجوب الدیۃ فی قتل الخطائ…(4367), 2428,"حَدَّثَنَا أَبُو نُعَيْمٍ ، حَدَّثَنَا زَكَرِيَّا ، عَنْ عَامِرٍ  : "" فِي مَمْلُوكٍ تُوُفِّيَ وَلَهُ أَبٌ حُرٌّ، وَلَهُ بَنُونَ مِنْ امْرَأَةٍ حُرَّةٍ، لِمَنْ وَلَاءُ وَلَدِهِ؟ قَالَ :لِمَوَالِي الْجَدِّ """,,takhreej: !صحیح: ابن حبان(6011)وأخرجہ ابوداؤد،کتاب الدیات،باب فی الخطاء شبہ العمد(4547(والنسائی فی القسامۃ،باب ذکر الدیۃ من الورق(4817), 2429,"حَدَّثَنَا أَبُو نُعَيْمٍ ، حَدَّثَنَا إِسْرَائِيلُ ، عَنْ مُغِيرَةَ ، عَنْ إِبْرَاهِيمَ  : "" فِي مُكَاتَبٍ مَاتَ وَقَدْ أَدَّى نِصْفَ مُكَاتَبَتِهِ، وَلَهُ وَلَدٌ مِنْ امْرَأَةٍ حُرَةٍ، قَالَ :مَا أُرَاهُ إِلَّا قَدْ جَرَّ وَلَاءَ وَلَدِهِ """,,takhreej: @متفق علیہ: البخاری،کتاب الدیات،باب من اطلع من بیت قو م ففقأ عینہ فلا دیۃ لہ(6901)ومسلم،کتاب الآداب باب تحریم النظر فی بیت غیرہ(5603), 2430,"حَدَّثَنَا سُلَيْمَانُ بْنُ حَرْبٍ  ، حَدَّثَنَا شُعْبَةُ  ، عَنْ الْحَكَمِ  ،  عَنْ إِبْرَاهِيمَ  ، قَالَ : "" كَانَ شُرَيْحٌ لَا يَرْجِعُ عَنْ قَضَاءٍ يَقْضِي بِهِ، فَحَدَّثَهُ الْأَسْوَدُ  : أَنَّ عُمَرَ  ، قَالَ :إِذَا تَزَوَّجَ الْمَمْلُوكُ الْحُرَّةَ، فَوَلَدَتْ أَوْلَادًا أَحْرَارًا، ثُمَّ عُتِقَ بَعْدَ ذَلِكَ، رَجَعَ الْوَلَاءُ لِمَوَالِي أَبِيهِمْ ""، فَأَخَذَ بِهِ شُرَيْحٌ",,takhreej: !متفق علیہ: سابقہ حدیث مکرر ذکر ہوئی ہے۔, 2431,"حَدَّثَنَا يَعْلَى  ، عَنْ الْأَعْمَشِ  ، عَنْ إِبْرَاهِيمَ  ، قَالَ : قَالَ عُمَر   : "" الْمَمْلُوكِ يَكُونُ تَحْتَهُ الْحُرَّةُ،يُعْتَقُ الْوَلَدُ بِعِتْقِ أُمِّهِ، فَإِذَا عُتِقَ الْأَبُ، جَرَّ الْوَلَاءَ """,,takhreej: @ صحیح مسلم،کتاب الجہاد،باب لایقتل قرشی صیرا بعد الفتح(4203), 2432,"حَدَّثَنَا مُسْلِمٌ ، حَدَّثَنَا عَبْدُ الْوَارِثِ ، عَنْ كَثِيرِ بْنِ شِنْظِيرٍ ، عَنْ عَطَاءٍ  : "" فِي الْحُرَّةِ تَحْتَ الْعَبْدِ، قَالَ :أَمَّا مَا وَلَدَتْ مِنْهُ وَهُوَ عَبْدٌ، فَوَلَاؤُهُمْ لِأَهْلِ نِعْمَتِهَا، وَمَا وَلَدَتْ مِنْهُ وَهُوَ حُرٌّ، فَوَلَاؤُهُمْ لِأَهْلِ نِعْمَتِهِ """,,takhreej: !صحیح: سابقہ حدیث ہی مکرر آئی ہے۔, 2433,"حَدَّثَنَا جَعْفَرُ بْنُ عَوْنٍ  ، عَنْ الْأَعْمَشِ  ، عَنْ إِبْرَاهِيمَ  ، قَالَ : قَالَ عُمَرُ   :"" إِذَا كَانَتْ الْحُرَّةُ تَحْتَ الْمَمْلُوكِ، فَوَلَدَتْ لَهُ غُلَامًا، فَإِنَّهُ يُعْتَقُ بِعِتْقِ أُمِّهِ، وَوَلَاؤُهُ لِمَوَالِي أُمِّهِ، فَإِذَا أُعْتِقَ الْأَبُ، جَرَّ الْوَلَاءَ إِلَى مَوَالِي أَبِيهِ """,,takhreej: @اسنادہ صحیح: ابن حبان(5995), 2434,"حَدَّثَنَا الْحَكَمُ بْنُ الْمُبَارَكِ  ، حَدَّثَنَا مُحَمَّدُ بْنُ سَلَمَةَ  ، عَنْ ابْنِ إِسْحَاق  ، عَنْ الْعَلَاءِ بْنِ عَبْدِ الرَّحْمَنِ  ، عَنْ أَبِيهِ  ، قَالَ :"" كَانَتْ أُمِّي مَوْلَاةً لِلْحُرَقَةِ، وَكَانَ أَبِي يَعْقُوبُ مُكَاتَبًا لِمَالِكِ بْنِ أَوْسِ بْنِ الْحَدَثَانِ النَّصْرِيِّ، ثُمَّ إِنَّ أَبِي أَدَّى كِتَابَتَهُ، فَدَخَلَ الْحُرَقِيُّ عَلَى عُثْمَانَ، يَسْأَلُ الْحَقَّ يَعْنِي : الْعَطَاءَ ، وَعِنْدَهُ مَالِكُ بْنُ أَوْسٍ، فَقَالَ : ذَاكَ مَوْلَايَ، فَاخْتَصَمَا إِلَى عُثْمَانَ  ، فَقَضَى بِهِ لِلْحُرَقِيِّ """,,takhreej: ! اسنادہ صحیح: سابقہ حدیث ہی مکرر آئی ہے۔, 2435,"حَدَّثَنَا عَبْدُ اللَّهِ بْنُ يَزِيدَ ، حَدَّثَنَا حَيْوَةُ ، أَخْبَرَنِي سَهْمُ بْنُ يَزِيدَ الْحَمْرَاوِيُّ : "" أَنَّ رَجُلًا تُوُفِّيَ وَلَيْسَ لَهُ وَارِثٌ، فَكُتِبَ فِيهِ إِلَى عُمَرَ بْنِ عَبْدِ الْعَزِيزِ  وَهُوَ خَلِيفَةٌ، فَكَتَبَ : أَنْاقْتَسِمُوا مِيرَاثَهُ عَلَى مَنْ كَانَ يَأْخُذُ مَعَهُمْ الْعَطَاءَ، فَقُسِمَ مِيرَاثُهُ عَلَى مَنْ كَانَ يَأْخُذُ مَعَهُمْ الْعَطَاءَ فِي عِرَافَتِهِ """,,takhreej: !اسنادہ ضعیف: محمد بن کثیر راوی کی بناء پر لیکن ولید ابن مسلم کی متابعت کی بناء پر یہ ضعف دور ہوجاتا ہے۔ اخرجہ الترمذی ، کتاب التفسیر،باب ومن سورۃ الصف(3309),
