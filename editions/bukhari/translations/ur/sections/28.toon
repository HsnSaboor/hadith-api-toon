{"hadithnumber": "1821", "text": "ہم سے معاذ بن فضالہ نے بیان کیا، کہا ہم سے ہشام نے بیان کیا، ان سے یحییٰ ابن کثیر نے، ان سے عبداللہ"}
{"hadithnumber": "1822", "text": "ہم سے سعید بن ربیع نے بیان کیا، کہا ہم سے علی بن مبارک نے بیان کیا، ان سے یحییٰ بن ابی کثیر نے، ان س"}
{"hadithnumber": "1823", "text": "ہم سے عبداللہ بن محمد نے بیان کیا، کہ ہم سے سفیان بن عیینہ نے بیان کیا، کہا ہم سے صالح بن کیسان نے ب"}
{"hadithnumber": "1824", "text": "ہم سے موسیٰ بن اسماعیل نے بیان کیا، کہا ہم سے ابوعوانہ نے بیان کیا، ان سے عثمان بن موہب نے بیان کیا،"}
{"hadithnumber": "1825", "text": "ہم سے عبداللہ بن یوسف نے بیان کیا، کہا کہ ہم کو امام مالک نے خبر دی، انہیں ابن شہاب نے، انہیں عبیدال"}
{"hadithnumber": "1826", "text": "ہم سے عبداللہ بن یوسف نے بیان کیا، انہوں نے کہا کہ ہم کو امام مالک نے خبر دی، انہیں نافع نے خبر دی،"}
{"hadithnumber": "1827", "text": "(تیسری سند) اور ہم سے مسدد نے بیان کیا، کہا ہم سے ابوعوانہ نے بیان کیا، ان سے زید بن جبیر نے بیان کی"}
{"hadithnumber": "1828", "text": "(چوتھی سند) اور ہم سے اصبغ نے بیان کیا انہوں نے کہا کہ مجھ سے عبداللہ بن وہب نے بیان کیا، انہوں نے ک"}
{"hadithnumber": "1829", "text": "ہم سے یحییٰ بن سلیمان نے بیان کیا، انہوں نے کہا مجھ سے ابن وہب نے بیان کیا، انہوں نے کہا مجھے یونس ن"}
{"hadithnumber": "1830", "text": "ہم سے عمر بن حفص بن غیاث نے بیان کیا، کہا ہم سے میرے والد نے بیان کیا، ان سے اعمش نے بیان کیا، کہا ک"}
{"hadithnumber": "1831", "text": "ہم سے اسماعیل بن ابی اویس نے بیان کیا، کہا مجھ سے امام مالک نے بیان کیا، ان سے ابن شہاب نے، ان سے عر"}
{"hadithnumber": "1832", "text": "ہم سے قتیبہ بن سعید نے بیان کیا، کہا ہم سے لیث بن سعد نے بیان کیا، ان سے سعید بن ابی سعید مقبری نے،"}
{"hadithnumber": "1833", "text": "ہم سے محمد بن مثنی نے بیان کیا، کہا ہم سے عبدالوہاب نے بیان کیا، کہا ہم سے خالد نے بیان کیا، ان سے ع"}
{"hadithnumber": "1834", "text": "ہم سے عثمان بن ابی شیبہ نے بیان کیا، کہا ہم سے جریر نے بیان کیا، ان سے منصور نے، ان سے مجاہد نے، ان"}
{"hadithnumber": "1835", "text": "ہم سے علی بن عبداللہ نے بیان کیا، کہا ہم سے سفیان بن عیینہ نے بیان کیا کہ عمرو بن دینار نے بیان کیا"}
{"hadithnumber": "1836", "text": "ہم سے خالد بن مخلد نے بیان کیا، کہا کہ ان سے سلیمان بن بلال نے بیان کیا، ان سے علقمہ بن ابی علقمہ نے"}
{"hadithnumber": "1837", "text": "ہم سے ابوالمغیرہ عبدالقدوس بن حجاج نے بیان کیا، انہوں نے کہا ہم سے اوزاعی نے بیان کیا، ان سے عطاء بن"}
{"hadithnumber": "1838", "text": "ہم سے عبداللہ بن یزید نے بیان کیا، انہوں نے کہا ہم سے لیث نے بیان کیا، ان سے نافع نے بیان کیا اور ان"}
{"hadithnumber": "1839", "text": "ہم سے قتیبہ نے بیان کیا، کہا کہ ہم سے جریر نے بیان کیا، ان سے منصور نے، ان سے حکم نے، ان سے سعید بن"}
{"hadithnumber": "1840", "text": "ہم سے عبداللہ بن یوسف نے بیان کیا، کہا کہ ہم کو امام مالک نے خبر دی، انہیں زید بن اسلم نے، انہیں ابر"}
{"hadithnumber": "1841", "text": "ہم سے ابوالولید نے بیان کیا، انہوں نے کہا ہم سے شعبہ نے بیان کیا، انہوں نے کہا کہ مجھے عمرو بن دینار"}
{"hadithnumber": "1842", "text": "ہم سے احمد بن یونس نے بیان کیا، انہوں نے کہا کہ ہم سے ابراہیم بن سعد نے بیان کیا، انہوں نے کہا کہ ہم"}
{"hadithnumber": "1843", "text": "ہم سے آدم بن ابی ایاس نے بیان کیا، کہا ہم سے شعبہ نے بیان کیا، ان سے عمرو بن دینار نے بیان کیا، ان س"}
{"hadithnumber": "1844", "text": "ہم سے عبیداللہ بن موصلی نے بیان کیا، انہوں نے کہا کہ ہم سے اسرائیل نے، انہوں نے کہا کہ ہم سے ابواسحا"}
{"hadithnumber": "1845", "text": "ہم سے مسلم بن ابراہیم نے بیان کیا، کہا ہم سے وہیب نے بیان کیا ان سے عبداللہ بن عباس رضی اللہ عنہما ن"}
{"hadithnumber": "1846", "text": "ہم سے عبداللہ بن یوسف نے بیان کیا، کہا ہم کو امام مالک نے خبر دی، انہیں ابن شہاب زہری نے اور انہیں ا"}
{"hadithnumber": "1847", "text": "ہم سے ابوالولید نے بیان کیا، کہا ہم سے ہمام نے بیان کیا ہم سے عطاء نے بیان کیا، کہا مجھ سے صفوان بن"}
{"hadithnumber": "1848", "text": "ایک شخص نے دوسرے شخص کے ہاتھ میں دانت سے کاٹا تھا، دوسرے نے جو اپنا ہاتھ کھینچا تو اس کا دانت اکھڑ گ"}
{"hadithnumber": "1849", "text": "ہم سے سلیمان بن حرب نے بیان کیا، انہوں نے کہا کہ ہم سے حماد بن زید نے بیان کیا، ان سے عمرو بن دینار"}
{"hadithnumber": "1850", "text": "ہم سے سلیمان بن حرب نے بیان کیا، انہوں نے کہا کہ ہم سے حماد بن زید نے بیان کیا، ان سے ایوب نے بیان ک"}
{"hadithnumber": "1851", "text": "ہم سے یعقوب بن ابراہیم نے بیان کیا، انہوں نے کہا ہم سے ہشیم نے بیان کیا، انہوں نے کہا ہمیں ابوبشر نے"}
{"hadithnumber": "1852", "text": "ہم سے موسیٰ بن اسماعیل نے بیان کیا، کہا ہم سے ابوعوانہ وضاح شکری نے بیان کیا، ان سے ابوبشر جعفر بن ا"}
{"hadithnumber": "1853", "text": "ہم سے ابوعاصم نے ابن جریج سے بیان کیا، انہوں نے کہا ان سے ابن شہاب نے، ان سے سلیمان بن یسار نے، ان س"}
{"hadithnumber": "1854", "text": "(دوسری سند سے امام بخاری رحمہ اللہ نے) کہا ہم سے موسیٰ بن اسماعیل نے بیان کیا، کہا کہ ہم سے عبدالعزی"}
{"hadithnumber": "1855", "text": "ہم سے عبداللہ بن مسلمہ نے بیان کیا، ان سے امام مالک نے، ان سے ابن شہاب زہری نے، ان سے سلیمان بن یسار"}
{"hadithnumber": "1856", "text": "ہم سے ابوالنعمان نے بیان کیا، کہا ہم سے حماد بن زید نے بیان کیا، ان سے عبیداللہ بن ابی یزید رضی اللہ"}
{"hadithnumber": "1857", "text": "ہم سے اسحٰق بن منصور نے بیان کیا، انہوں نے کہا ہمیں یعقوب بن ابراہیم نے خبر دی، ان سے ان کے بھتیجے ا"}
{"hadithnumber": "1858", "text": "ہم سے عبدالرحمٰن بن یونس نے بیان کیا، ان سے حاتم بن اسماعیل نے بیان کیا، ان سے محمد بن یوسف نے اور ا"}
{"hadithnumber": "1859", "text": "ہم سے عمرو بن ذرارہ نے بیان کیا، کہا کہ ہمیں قاسم بن مالک نے خبر دی، انہیں جعید بن عبدالرحمٰن نے، ان"}
{"hadithnumber": "1860", "text": "امام بخاری رحمہ اللہ نے کہا کہ مجھ سے احمد بن محمد نے کہا کہ ان سے ابراہیم بن سعد نے بیان کیا، ان سے"}
{"hadithnumber": "1861", "text": "ہم سے مسدد نے بیان کیا، کہا ہم سے عبدالواحد نے بیان کیا، ان سے حبیب بن عمرہ نے بیان کیا، انہوں نے کہ"}
{"hadithnumber": "1862", "text": "ہم سے ابوالنعمان نے بیان کیا، کہا ہم سے حماد بن زید نے بیان کیا، ان سے عمرو بن دینار نے بیان کیا، ان"}
{"hadithnumber": "1863", "text": "ہم سے عبدان نے بیان کیا، کہا ہم کو یزید بن زریع نے خبر دی، کہا ہم کو حبیب معلم نے خبر دی، انہیں عطاء"}
{"hadithnumber": "1864", "text": "ہم سے سلیمان بن حرب نے بیان کیا، کہا کہ ہم سے شعبہ نے، ان سے عبدالملک بن عمر نے، ان سے زیاد کے غلام"}
{"hadithnumber": "1865", "text": "ہم سے محمد بن سلام نے بیان کیا، کہا ہمیں مروان فزاری نے خبر دی، انہیں حمید طویل نے، انہوں نے بیان کی"}
{"hadithnumber": "1866", "text": "ہم سے ابراہیم بن موسیٰ نے بیان کیا، کہا کہ ہم کو ہشام بن یوسف نے خبر دی کہ ابن جریج نے انہیں خبر دی،"}
