hadiths[251]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
705,سعید بن مسیب رحمہ اللہ سے روایت ہے کہ یقیناً حضرت اسماء بنت عُمیس رضی اللہ عنہا نے محمد بن ابی بکر ک,,,705,,
706,نافع رحمہ اللہ سے روایت ہے کہ حضرت عبداللہ بن عمر رضی اللہ عنہما ( تین مواقع پر ) غسل ( کا خصوصی اہت,,,706,,
707,ابراہیم بن عبداللہ بن حنین رحمہ اللہ اپنے والد ( عبداللہ بن حنین رحمہ اللہ ) سے روایت کرتے ہیں کہ حض,,,707,,
708,عطاء بن ابی رباح رحمہ اللہ سے روایت ہے کہ بے شک حضرت عمر بن خطاب رضی اللہ عنہ نے حضرت یعلیٰ بن منیہ ,,,708,,
709,نافع رحمہ اللہ سے روایت ہے کہ بے شک حضرت عبداللہ بن عمر رضی اللہ عنہما جب ( حج و عمرہ کے سفر میں ) م,,,709,,
710,نافع رحمہ اللہ سے روایت ہے کہ بلاشبہ حضرت عبداللہ بن عمر رضی اللہ عنہما ( اس وقت ) اپنا سر نہیں دھوت,,,710,,
711,حضرت عبداللہ بن عمر رضی اللہ عنہ سے روایت ہے کہ ایک آدمی نے رسول اللہ ﷺ سے سوال کیا کہ حالت احرام وا,,,711,,
712,حضرت عبداللہ بن عمر رضی اللہ عنہ سے روایت ہے ، انھوں نے کہا کہ رسول اللہ ﷺ نے اس سے منع فرمایا کہ مح,,,712,,
713,نافع رحمہ اللہ سے روایت ہے ، انھوں نے حضرت عمر بن خطاب رضی اللہ عنہ کے آزاد کردہ غلام اسلم رحمہ اللہ,,,713,,
714,حضرت اسماء بنت ابی بکر رضی اللہ عنہ سے روایت ہے کہ بلاشبہ وہ خوب گہرے کُسُبھ سے رنگے ہوئے کپڑے اس حا,,,714,,
715,نافع رحمہ اللہ سے روایت ہے کہ بے شک حضرت عبداللہ بن عمر رضی اللہ عنہ پیٹی پہننے کو ناپسند جانتے تھے ,,,715,,
716,یحیی بن سعید رحمہ اللہ سے روایت ہے کہ انھوں نے سعید بن مسیب رحمہ اللہ کو اس پیٹی جسے احرام والا اپنے,,,716,,
717,فُرَافِصَہ بن عمیر حنفی رحمہ اللہ سے روایت ہے ، انھوں نے حضرت عثمان بن عفان رضی اللہ عنہ کو عَرْج نا,,,717,,
718,"نافع رحمہ اللہ سے روایت ہے کہ حضرت عبداللہ بن عمر رضی اللہ عنہ کہا کرتے تھے : ٹھوڑی سے اوپر اوپر ( س",,,718,,
719,نافع رحمہ اللہ سے روایت ہے کہ حضرت عبداللہ بن عمر رضی اللہ عنہ نے اپنے بیٹے واقد بن عبداللہ رحمہ الل,,,719,,
720,"نافع رحمہ اللہ سے روایت ہے کہ حضرت عبداللہ بن عمر رضی اللہ عنہ فرمایا کرتے تھے : احرام والی عورت نہ ",,,720,,
721,فاطمہ بنت منذر رحمہ اللہ سے روایت ہے ، کہتی ہیں کہ ہم اپنے چہروں کو ڈھانپ لیا کرتی تھیں اس حال میں ک,,,721,,
722,سیدہ عائشہ رضی اللہ عنہا زوجہ رسول ﷺ سے روایت ہے ، کہتی ہیں کہ میں رسول اللہ ﷺ کو آپ کے احرام باندھن,,,722,,
723,عطاء بن ابی رباح رحمہ اللہ سے روایت ہے کہ بلاشبہ ایک اعرابی ( بدوی ) صحابی رضی اللہ عنہ رسول اللہ ﷺ ,,,723,,
724,اسلم رحمہ اللہ جو حضرت عمر بن خطاب رضی اللہ عنہ کے آزاد کردہ غلام ہیں ، سے روایت ہے کہ حضرت عمر بن خ,,,724,,
725,صلت بن زُیید رحمہ اللہ اپنے گھر والوں میں سے کئی ایک افراد سے روایت کرتے ہیں کہ بلاشبہ حضرت عمر بن خ,,,725,,
726,یحیی بن سعید رحمہ اللہ ، عبداللہ بن ابی بکر رحمہ اللہ اور ربیعہ بن ابی عبدالرحمن رحمہ اللہ سے روایت ,,,726,,
727,"حضرت عبداللہ بن عمر رضی اللہ عنہ سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا :’’ اہل مدینہ ذوالحلیفہ سے احر",,,727,,
728,حضرت عبداللہ بن عمر رضی اللہ عنہ سے روایت ہے ، کہتے ہیں کہ رسول اللہ ﷺ نے مدینہ والوں کو حکم دیا کہ ,,,728,,
729,نافع رحمہ اللہ سے روایت ہے کہ حضرت عبداللہ بن عمر رضی اللہ عنہ نے ’’ فُرْع ‘‘ نامی جگہ سے احرام باند,,,729,,
730,امام مالک رحمہ اللہ نے ایک ثقہ راوی سے روایت کیا ہے کہ حضرت عبداللہ بن عمر رضی اللہ عنہ نے ایلیاء یع,,,730,,
731,امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ بے شک رسول اللہ ﷺ نے جِعِرَّانہ مقام سے عمرے کا احرام باندھا ,,,731,,
732,نافع رحمہ اللہ حضرت عبداللہ بن عمر رضی اللہ عنہ سے روایت کرتے ہیں کہ بے شک رسول اللہ ﷺ کا تلبیہ یہ ت,,,732,,
733,ہشام بن عروہ رحمہ اللہ اپنے والد ( عروہ بن زبیر رحمہ اللہ ) سے روایت کرتے ہیں کہ بے شک رسول اللہ ﷺ ذ,,,733,,
734,سالم بن عبداللہ رحمہ اللہ سے روایت ہے ، انھوں نے اپنے والد ( حضرت عبداللہ بن عمر رضی اللہ عنہ ) کو س,,,734,,
735,عبید بن جُریج رحمہ اللہ سے روایت ہے ، انھوں نے حضرت عبداللہ بن عمر رضی اللہ عنہ ( کو ان کی کنیت سے م,,,735,,
736,نافع رحمہ اللہ سے روایت ہے کہ حضرت عبداللہ بن عمر رضی اللہ عنہ ذوالحلیفہ کی مسجد میں نماز پڑھتے ، پھ,,,736,,
737,امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ ( خلیفہ وقت ) عبدالملک بن مروان رحمہ اللہ نے ذوالحلیفہ کی مسج,,,737,,
738,خلاد بن سائب رحمہ اللہ اپنے والد ( سائب بن خلاد رضی اللہ عنہ ) سے روایت کرتے ہیں کہ بلاشبہ رسول اللہ,,,738,,
739,ابوالاسود محمد بن عبدالرحمن بن نوفل رحمہ اللہ سے روایت ہے جو کہ یتیم تھے اور عُروہ بن زبیر رحمہ اللہ,,,739,,
740,عبدالرحمن بن قاسم رحمہ اللہ اپنے والد ( قاسم بن محمد بن ابی بکر رحمہ اللہ ) سے اور وہ اُمّ المومنین ,,,740,,
741,عروہ بن زبیرؒ بھی سیدہ عائشہ رضی اللہ عنہا سے روایت کرتے ہیں کہ رسول اللہ ﷺ نے حج افراد کیا تھا ۔,,,741,,
742,جعفر بن محمد رحمہ اللہ اپنے والد ( محمد باقر رحمہ اللہ ) سے روایت کرتے ہیں کہ حضرت مقداد بن اسود رضی,,,742,,
743,سلیمان بن یسار رحمہ اللہ سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ حجۃ الوداع کے سال حج کی طرف نکلے ، آپ ﷺ ک,,,743,,
744,محمد بن ابی بکر ثقفی رحمہ اللہ سے روایت ہے ، انھوں نے حضرت انس بن مالک رضی اللہ عنہ سے سوال کیا ، اس,,,744,,
745,جعفر بن محمد رحمہ اللہ اپنے والد ( محمد باقر رحمہ اللہ ) سے روایت کرتے ہیں کہ حضرت علی بن ابی طالب ر,,,745,,
746,سیدہ عائشہ رضی اللہ عنہا زوجہ رسول اللہ ﷺ سے روایت ہے کہ بلاشبہ وہ اس وقت تلبیہ ختم کرتیں جب وہ ٹھہر,,,746,,
747,نافع رحمہ اللہ سے روایت ہے کہ حضرت عبداللہ بن عمر رضی اللہ عنہ حج کے موقع پر ( پہلی بار ) اس وقت تلب,,,747,,
748,ابن شہاب رحمہ اللہ سے روایت ہے ، وہ کہتے تھے کہ حضرت عبداللہ بن عمر رضی اللہ عنہ جب بیت اللہ کا طواف,,,748,,
749,علقمہ بن ابی علقمہ اپنی والدہ ( اُم علقمہ ، مرجانہ رحمۃ اللہ علیہما ) سے روایت کرتے ہیں کہ سیدہ عائش,,,749,,
750,یحیی بن سعید رحمہ اللہ سے روایت ہے کہ حضرت عمر بن عبدالعزیز رحمہ اللہ ( اپنے دور خلافت میں حج کے دور,,,750,,
751,عبدالرحمن بن قاسم رحمہ اللہ اپنے والد ( قاسم بن محمد رحمہ اللہ ) سے روایت کرتے ہیں کہ حضرت عمر بن خط,,,751,,
752,ہشام بن عروہ رحمہ اللہ اپنے والد ( عروہ بن زبیر رحمہ اللہ ) سے روایت کرتے ہیں کہ ( ان کے بھائی ) حضر,,,752,,
