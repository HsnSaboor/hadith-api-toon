{"hadithnumber": "428", "text": "نافع رحمہ اللہ سے روایت ہے کہ حضرت عبداللہ بن عمر رضی اللہ عنہما عیدالفطر کے دن عیدگاہ کی طرف جانے س"}
{"hadithnumber": "429", "text": "ابن شہاب زہری رحمہ اللہ سے روایت ہے کہ بے شک رسول اللہ ﷺ عیدالفطر اور عیدالاضحی کے دن خطبے سے پہلے ن"}
{"hadithnumber": "430", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ حضرت ابوبکر رضی اللہ عنہ اور حضرت عمر بن خطاب رضی اللہ عنہ بھ"}
{"hadithnumber": "431", "text": "ابوعبید رضی اللہ عنہ جو حضرت عبدالرحمن بن ازہر رضی اللہ عنہ کے آزاد کردہ غلام ہیں ، روایت کرتے ہیں ک"}
{"hadithnumber": "432", "text": "ہشام بن عروہ رحمہ اللہ اپنے والد عروہ رحمہ اللہ سے روایت کرتے ہیں کہ وہ ( عروہ بن زبیر رحمہ اللہ ) ع"}
{"hadithnumber": "433", "text": "ابن شہاب رحمہ اللہ سے روایت ہے کہ سعید بن مسیب رحمہ اللہ نے ان کو خبر دی کہ لوگوں کو عیدالفطر کے دن"}
{"hadithnumber": "434", "text": "عبید اللہ بن عبداللہ بن عتبہ بن مسعود رحمہ اللہ سے روایت ہے کہ حضرت عمر بن خطاب رضی اللہ عنہ نے حضرت"}
{"hadithnumber": "435", "text": "نافع رحمہ اللہ جو کہ حضرت عبداللہ بن عمر رضی اللہ عنہما کے آزاد کردہ غلام ہیں ، سے روایت ہے ، کہتے ہ"}
{"hadithnumber": "436", "text": "نافع رحمہ اللہ سے روایت ہے کہ حضرت عبداللہ بن عمر رضی اللہ عنہما عیدالفطر کے دن نماز عید سے پہلے بھی"}
{"hadithnumber": "437", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ سعید بن مسیب رحمہ اللہ صبح کی نماز پڑھنے کے بعد سورج طلوع ہون"}
{"hadithnumber": "438", "text": "عبدالرحمن بن قاسم رحمہ اللہ روایت کرتے ہیں کہ ان کے والد قاسم رحمہ اللہ ( بن محمد بن ابی بکر ) عیدگا"}
{"hadithnumber": "439", "text": "ہشام بن عروہ رحمہ اللہ سے روایت ہے کہ ان کے والد عروہ رحمہ اللہ عیدالفطر کے دن نماز عید سے پہلے مسجد"}
{"hadithnumber": "440", "text": "صالح بن خوات رحمہ اللہ اس صحابی ( یعنی اپنے والد حضرت خوات بن جبیر ) رضی اللہ عنہ سے روایت کرتے ہیں"}
