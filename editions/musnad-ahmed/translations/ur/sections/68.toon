hadiths[2]{hadithnumber,text}:
15524,أؼوشًأثىأڬخۏشأشذوۆأتههۄأؼهۏۄأڬۄحەأۄۏڽأڬۄأوۏڽأىەأؼثزتهشذوىأثىأڬۏضتىأضەأڬۄتأڬۄأإځأودہەأتځىەأًتهزأڬەأذًتهەأضەأڬًةۏأذزۏخأڬۏًڽأىۄۏڽأضىتحەأآأتىۄًڽأىەأڬۄتأڬۄأحوأىەأودہأضەأتضأڬۏأزشرًتضحأۄۏأڬثأڬۏأۄەأآأځہشأڬۄىەأهڲەأڬۄأوۏشەأًتهزأظتذثأىەأودہەأثحتۏتأڬۄأتىۄًڽأىەأتۏڬأوشحثۄأزۏڬہتأڬۄأىثۏأ﷽أوغثرأضەأىڬهەأ؏أڬىًۏڽأځشأځۄىډەأ؏أتضأًمحأإځأ﷽أىەأظشلأحۄثىزأثتىزہأشڬہتأحہتأ؏أتًځشأڬۏأډتزشأإځأ﷽أڬەأدضوأوثتشڬأځشأىۄأحہۏأ؏أڬىًۏڽأڬەأځتضأإځأ﷽أىەأډىزأؽهتوًڽأڬًأىوتصأځڔہحەأۄًةەأزۏڬہتأ؏أإځأ﷽أىەأحۄثىزأڬۏأڲشۄأڬہًهأڬشأځتىۏأڬەأډہۏىټەأوتشەأتًشأزًأشڬؼحۏڽأځڔہۏڽأ؏أتهثحۄأودہەأۏۄأۏتزأىۄۏڽأڬۄأًۄأػۄشأڬۏأىوتصأحہۏأۏتأؼظشأڬۏأۗ
15525,أؼثزتهشذوىأڬۄحەأۄۏڽأڬۄأوۏڽأىەأتځىەأًتهزأڬۏضتىأضەأځًډہتأڬۄأإځأىەأىثۏأ﷽أڬًأڬضأغشذأځتۏتأحہتأآأتىۄًڽأىەأدًتثأزۏتأڬۄأوۏڽأىەأتۏڬأوشحثۄأىثۏأ﷽أڬًأ““أثةشأثىۏأوغۏؼأ‛‛أىتوۏأتًىډەأڬىًۏڽأځشأتۏڬأڬځڔەأوۏڽأهځټأڬشأػۄشأۏتأؼظشأڬۏأىوتصأځڔہحەأۄًةەأزۏڬہتأحہتأ؏أإځأ﷽أىەأتضأًمحأزًأشڬؼحۏڽأځڔہۏأحہۏڽأۗ
