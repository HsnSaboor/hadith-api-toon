{"hadithnumber": "6169", "text": "حضرت انس بن مالک  رضی اللہ تعالیٰ عنہ  نے حدیث بیان کی کہ حضرت  ابو بکر صدیق  رضی اللہ تعالیٰ عنہ  ن"}
{"hadithnumber": "6170", "text": "امام مالک نے ابو نضر سے  ، انھوں نے عبید بن حنین سے  ، انھوں نے حضرت ابو سعید خدری رضی اللہ تعالیٰ ع"}
{"hadithnumber": "6171", "text": "سالم نےابو نضر سے ، انھوں نے عبید بن حنین اور بسر بن سعید سے  ، انھوں نے ابو سعید خدری رضی اللہ تعال"}
{"hadithnumber": "6172", "text": "اسماعیل بن رجاء نے کہا : میں نے عبداللہ بن ابی ہذیل کو ابواحوص سے حدیث بیان کرتے ہوئے سنا ، انھوں نے"}
{"hadithnumber": "6173", "text": "شعبہ نے ابو اسحاق سے ، انھوں نے ابو احوص سے  ، انھوں نے عبداللہ بن مسعود رضی اللہ تعالیٰ عنہ  سے ، ا"}
{"hadithnumber": "6174", "text": "سفیان نے ابو اسحاق سے ، انھوں نے ابو احوص سے  ، انھوں نے عبداللہ سے روایت کی ، ابو عمیس نے ابن ابی م"}
{"hadithnumber": "6175", "text": "واصل بن حیان نے عبداللہ بن ابی ہذیل سے ، انھوں نے ابو احوص سے  ، انھوں نے عبداللہ ( بن مسعود )  رضی"}
{"hadithnumber": "6176", "text": "عبداللہ بن مرہ نے ابو احوص سے  ، انھوں نے عبداللہ ( بن مسعود )  رضی اللہ تعالیٰ عنہ  سے روایت کی  ،"}
{"hadithnumber": "6177", "text": "عمرو بن عاصؓ سے روایت ہے رسول اﷲ ﷺ نے ان کو ذات السلاسل کے لشکر کے ساتھ بھیجا  ( ذات السلاسل نواحی ش"}
{"hadithnumber": "6178", "text": "ابن ابی ملیکہ کہتے ہیں کہ میں نے ام المؤمنین عائشہ صدیقہ رضی اللہ عنہا سے سنا ،  ان سے پوچھا گیا کہ"}
{"hadithnumber": "6181", "text": "حضرت عائشہ صدیقہ رضی اللہ تعالیٰ عنہا   سے روایت ہے ، کہا : رسول اللہ  صلی اللہ علیہ وسلم    نے ا پن"}
{"hadithnumber": "6182", "text": "حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ سے روایت ہے ،  کہا :  رسول اللہ  صلی اللہ علیہ وسلم   نے دریا فت"}
{"hadithnumber": "6183", "text": "یو نس نے ابن شہاب سے روایت کی ،  کہا :  مجھے سعد بن مسیب اور ابو سلمہ بن عبد الرحمان  ( بن عوف  )  ن"}
{"hadithnumber": "6184", "text": "عقیل بن خالد نے ابن شہاب سے اسی سند کے ساتھ بکری اور بھیڑیے کا واقعہ بیان کیا اور گا ئے کا واقعہ بیا"}
{"hadithnumber": "6185", "text": "سفیان بن عیینہ اور سفیان  ( ثوری ) دونوں نے ابو زناد سے ،  انھوں نے اعرج سے ،  انھوں نے ابو سلمہ سے"}
{"hadithnumber": "6186", "text": "شعبہ اور مسعر دونوں نے سعد بن ابرا ہیم سے انھوں نے ابو سلمہ سے ،  انھوں نے حضرت ابو ہریرہ رضی اللہ ت"}
{"hadithnumber": "6187", "text": "ابن مبارک نے عمر بن سعید بن ابو حسین سے  ، انھوں نے ابن ابی ملیکہ سے روایت کی ،  انھوں نے کہا  :  می"}
{"hadithnumber": "6188", "text": "عیسیٰ بن یونس نے عمربن سعید سے اسی سند سے اسی کے مانند روایت کی ۔"}
{"hadithnumber": "6189", "text": "ابو امامہ بن سہل نے حضرت ابو سعید خدری رضی اللہ تعالیٰ عنہ  سے سنا ،  کہتے تھے کہ رسول اللہ  صلی الل"}
{"hadithnumber": "6190", "text": "یو نس نے کہا  :  کہ ابن شہاب نے انھیں بتا یا  ، انھوں نےحمزہ بن عبد اللہ بن عمربن خطاب سے روایت کی ،"}
{"hadithnumber": "6191", "text": "صالح نے یونس کی سند کے ساتھ اسی کی حدیث کے مانند حدیث بیان کی ۔"}
{"hadithnumber": "6192", "text": "یو نس نے ابن شہاب سے روایت کی کہ سعید بن مسیب نے انھیں خبر دی ، انھوں نے ابو ہریرہ رضی اللہ تعالیٰ ع"}
{"hadithnumber": "6193", "text": "صالح نے یو نس کی سند کے ساتھ انھی کی حدیث کے مانند حدیث بیان کی ،"}
{"hadithnumber": "6194", "text": "صالح نے کہا  :  اعرج وغیرہ نے کہا :  کہ ابو ہریرہ رضی اللہ تعالیٰ عنہ  نے کہا  :  رسول اللہ  صلی الل"}
{"hadithnumber": "6195", "text": "ابو ہریرہ رضی اللہ تعالیٰ عنہ  کے آزاد کردہ غلام ابو یونس نے ابوہریرہ رضی اللہ تعالیٰ عنہ سے حدیث بی"}
{"hadithnumber": "6196", "text": "ابو بکر بن سالم نے سالم بن عبد اللہ سے ،  انھوں نے عبد اللہ بن عمر رضی اللہ تعالیٰ عنہ  سے روایت کی"}
{"hadithnumber": "6197", "text": "موسیٰ بن عقبہ نے سالم بن عبداللہ سے ،  انھوں نے اپنے والد سے حضرت ابو بکر اور عمربن خطاب رضی اللہ تع"}
{"hadithnumber": "6198", "text": "محمد بن عبد اللہ بن نمیر اور زہیر بن حرب نے کہا  :   ۔ الفاظ انھی  ( زہیر )  کے ہیں  ۔ ہمیں سفیان بن"}
{"hadithnumber": "6199", "text": "اسحٰق بن ابرا ہیم  ، ابو بکر بن ابی شیبہ اور عمرو ناقد نے سفیان بن عیینہ سے حدیث بیان کی ،  انھوں نے"}
{"hadithnumber": "6202", "text": "ابرا ہیم بن سعد نے صالح سے ،  انھوں نے ابن شہاب سے روایت کی ،  کہا  :  مجھے عبد الحمید بن عبد الرحمٰ"}
{"hadithnumber": "6203", "text": "سہیل نے اپنے والد صالح سے ، انھوں نے ابو ہریرہ رضی اللہ تعالیٰ عنہ سے روایت کی کہ عمر بن خطاب  رضی ا"}
{"hadithnumber": "6204", "text": "ابرا ہیم سعد نے اپنے والد سعد بن ابرا ہیم سے ،  انھوں نے ابو سلمہ سے ،  انھوں نے حضرت عائشہ رضی اللہ"}
{"hadithnumber": "6205", "text": "سعید ابرا ہیم نے اسی سند کے ساتھ اسی کے مانند روایت کی ۔"}
{"hadithnumber": "6206", "text": "نافع نے ابن عمر رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہا : حضرت عمر  رضی اللہ تعالیٰ عنہ نے کہا :   "}
{"hadithnumber": "6207", "text": "ابو اسامہ نے کہا :  ہمیں عبید اللہ نے نافع سے حدیث بیان کی ، انھوں نے ابن عمر رضی اللہ تعالیٰ عنہ  س"}
{"hadithnumber": "6208", "text": "یحییٰ قطان نے عبید اللہ سے اسی سند کے ساتھ ابو اسامہ کی حدیث کے ہم معنی روایت کی اور مزید بیان کیا :"}
{"hadithnumber": "6209", "text": "محمد بن ابی حرملہ نے یسار کے دونوں بیٹوں عطاء اور سلیمان اور ابوسلمہ بن عبدالرحمان سے روایت کی کہ حض"}
{"hadithnumber": "6210", "text": "عقیل بن خالد نے ابن شہاب سے ، انھوں نے یحییٰ بن سعید بن عاص سے روایت کی ، انھیں سعید بن عاص نے بتایا"}
{"hadithnumber": "6211", "text": "صالح بن کیسان نے ابن شہاب سے روایت کی ، انھوں نے کہا : مجھے یحییٰ بن سعید بن عاص نے بتایا ، انھیں سع"}
{"hadithnumber": "6212", "text": "عثمان بن غیاث نے ابو عثمان نہدی سے ، انھوں نے حضرت ابو موسیٰ اشعری رضی اللہ تعالیٰ عنہ  سے  روایت کی"}
{"hadithnumber": "6213", "text": "ایوب نے ابو عثمان نہدی سے ، انھوں نے حضرت ابو موسیٰ اشعری رضی اللہ تعالیٰ عنہ  سے روایت کی  کہ رسول"}
{"hadithnumber": "6214", "text": "یحییٰ  بن حسان نے کہا : ہمیں سلیمان بن بلال نے شریک بن ابی نمر سے ، انھوں نے سعید بن مسیب سے روایت ک"}
{"hadithnumber": "6215", "text": "سعید بن  عفیر نے کہا : مجھے سلیمان بن بلال نے حدیث بیان کی ، کہا : مجھے شریک بن عبداللہ بن ابی نمر ن"}
{"hadithnumber": "6216", "text": "محمد بن جعفر بن ابی کثیر نے ہمیں حدیث بیان کی  ، کہا : مجھے شریک بن عبداللہ بن ابی نمر نے سعید بن مس"}
{"hadithnumber": "6217", "text": "سعید بن مسیب نے عامر بن سعد بن ابی وقاص سے ، انھوں نے ا پنے والد سے روایت کی  ، کہا : رسول اللہ صلی"}
{"hadithnumber": "6218", "text": "محمد بن جعفر ( غندر )  نے کہا : ہمیں شعبہ نے حکم سے حدیث بیان کی ، انھوں نے مصعب بن سعد بن ابی وقاص"}
{"hadithnumber": "6219", "text": "معاذ نے کہا : ہمیں شعبہ نے اسی سند سے حدیث بیان کی ۔"}
{"hadithnumber": "6220", "text": "بکیر بن مسمار نے عامر بن سعد بن ابی وقاص سے  ، انھوں نے اپنے والد سے روایت کی کہ حضرت معاویہ بن ابی"}
{"hadithnumber": "6221", "text": "ابراہیم بن سعد نے حضرت سعد رضی اللہ تعالیٰ عنہ   سے اور انھوں نے رسول اللہ  صلی اللہ علیہ وسلم  سے ر"}
{"hadithnumber": "6222", "text": "سہیل کے والد ( ابو صالح )  نے ابو ہریرہ رضی اللہ تعالیٰ عنہ   سے روایت کی کہ ر سول اللہ صلی اللہ علی"}
{"hadithnumber": "6223", "text": "ابوحازم نے کہا : مجھے حضرت سہل بن سعد رضی اللہ تعالیٰ عنہ   نے کہ خیبر کے دن رسول اللہ  صلی اللہ علی"}
{"hadithnumber": "6224", "text": "حضرت سلمہ بن اکوع رضی اللہ تعالیٰ عنہ   سے روایت ہے  ، کہا : غزوہ خیبر میں حضرت علی رضی اللہ تعالیٰ"}
{"hadithnumber": "6225", "text": "زہیر بن حرب اور شجاع بن مخلد نے اسماعیل بن ابراہیم ( ابن علیہ )  سے روایت کی ، انھوں نے کہا : مجھے ا"}
{"hadithnumber": "6226", "text": "سعید بن مسروق نے یزید بن حیان سے  ، انھوں نے زید بن ارقم رضی اللہ تعالیٰ عنہ   سے ، انھوں نے نبی کری"}
{"hadithnumber": "6227", "text": "ابو بکر بن ابی شیبہ نے کہا : ہمیں محمد بن فضیل نے حدیث بیان کی ، اسحاق بن ابراہیم نے کہا : ہمیں جریر"}
{"hadithnumber": "6228", "text": "سعید بن مسروق نے یزید بن حیان سے  ، انھوں نے زید بن ارقم رضی اللہ تعالیٰ عنہ   سے روایت کی ، کہا : ہ"}
{"hadithnumber": "6229", "text": "ابو حازم نے حضرت سہل بن سعد رضی اللہ تعالیٰ عنہ   سے روایت کی ، کہا :  کہ مدینہ میں مروان کی اولاد م"}
{"hadithnumber": "6230", "text": "سلیمان بن بلال نے یحییٰ بن سعید سے  ، انھوں نے عبداللہ بن عامر بن ربیعہ سے ، انھوں نے حضرت عائشہ رضی"}
{"hadithnumber": "6231", "text": "قتیبہ بن سعید اور محمد بن رمح نے لیث سے حدیث بیان کی ، انھوں نے  یحییٰ بن سعید سے ، انھوں نے عبداللہ"}
{"hadithnumber": "6232", "text": "عبد الواہاب نے کہا  :  میں نے یحییٰ بن سعید کو کہتے ہو ئے سنا کہا :  میں نے عبد اللہ بن عامر بن ربیع"}
{"hadithnumber": "6233", "text": "منصور بن ابی مزاحم نے کہا  :  ہمیں ابرا ہیم بن سعد نے اپنے والد سے حدیث بیان کی ،  انھوں نے عبد اللہ"}
{"hadithnumber": "6234", "text": "شعبہ  ، وکیع اور مسعر  ، سب نے سعد بن ابرا ہیم سے ، انھوں نے عبد اللہ بن شدادسے ، انھوں نے حضرت علی"}
{"hadithnumber": "6235", "text": "سلیمان بن بلال نے یحییٰ بن سعید سے انھوں نے سعید سے انھوں نے حضرت سعد بن ابی وقاص رضی اللہ تعالیٰ عن"}
{"hadithnumber": "6236", "text": "لیث بن سعد اور عبد الوہاب دونوں نے یحییٰ بن سعید سے اسی سند کے ساتھ حدیث بیان کی ۔"}
{"hadithnumber": "6237", "text": "عامر بن سعد نے اپنے والد سے روایت کی ،  کہ جنگ اُحد کےدن رسول اللہ  صلی اللہ علیہ وسلم  نے ان کے لیے"}
{"hadithnumber": "6238", "text": "ابو بکر بن ابی شیبہ اور زہیر بن حرب نے کہا :  ہمیں حسن بن موسیٰ نے حدیث بیان کی ،  کہا :  ہمیں زہیر"}
{"hadithnumber": "6239", "text": "محمد بن جعفر نے کہا :  ہمیں شعبہ نے سماک بن حرب سے حدیث بیان کی ،  انھوں نے مصعب بن سعد سے ،  انھوں"}
{"hadithnumber": "6240", "text": "سفیان نے مقدام بن شریح سے انھوں نے اپنے والد سے انھوں نے حضرت سعد  رضی اللہ تعالیٰ عنہ  سے  ( آیت  )"}
{"hadithnumber": "6241", "text": "اسرائیل نے مقدام بن شریح سے انھوں نے اپنے والد سے انھوں نے حضرت سعد  رضی اللہ تعالیٰ عنہ  سےروایت کی"}
{"hadithnumber": "6242", "text": "معتمر کے والد سلیمان نے کہا :  میں نے حضرت ابو عثمان سے سنا ، کہا :  ان ایام میں سے ایک میں جب رسول"}
{"hadithnumber": "6243", "text": "سفیان بن عیینہ نے محمد بن منکدر سے انھوں نے حضرت جابر رضی اللہ تعالیٰ عنہ   بن عبد اللہ  رضی اللہ تع"}
{"hadithnumber": "6244", "text": "ہشام بن عروہ اور سفیان بن عیینہ نے محمد بن منکدر سے ،  انھوں نے جا بر رضی اللہ تعالیٰ عنہ   سے انھوں"}
{"hadithnumber": "6245", "text": "علی بن مسہر نے ہشام بن عروہ سے انھوں نے اپنے والد سے ،  انھوں نے حضرت عبد اللہ بن زبیر رضی اللہ تعال"}
{"hadithnumber": "6246", "text": "ابو اسامہ نے ہشام سے انھوں نے اپنے والد سے انھوں نے حضرت عبد اللہ بن زبیر  رضی اللہ تعالیٰ عنہ   سے"}
{"hadithnumber": "6247", "text": "عبد العزیزبن محمد نے سہیل  ( بن ابی صالح  )  سے ،  انھوں نے اپنے والد سے ،  انھوں نے حضرت ابو ہریرہ"}
{"hadithnumber": "6248", "text": "یحییٰ بن سعید نے سہیل بن ابی صالح  سے ،  انھوں نے اپنے والد سے ،  انھوں نے حضرت ابو ہریرہ رضی اللہ ت"}
{"hadithnumber": "6249", "text": "ابن نمیر اور عبدہ نے کہا :  ہمیں ہشام نے اپنے والد عروہ )  سے حدیث بیان کی کہا :  حضرت عائشہ  رضی ال"}
{"hadithnumber": "6250", "text": "ابو اسامہ نے کہا :  ہمیں ہشام نے اسی سند کے ساتھ حدیث بیان کی اور یہ اضافہ کیا کہ وہ ابو بکر  رضی ال"}
{"hadithnumber": "6251", "text": "بہی نے عروہ سے روایت کی کہ حضرت عائشہ رضی اللہ تعالیٰ عنہا    نے مجھ سے فرمایا  :  \"  تمھا رے دونوں"}
{"hadithnumber": "6252", "text": "حضرت انس  رضی اللہ تعالیٰ عنہ   نے کہا :  کہ رسول اللہ  صلی اللہ علیہ وسلم  نے فر ما یا  :  \"  ہر ام"}
{"hadithnumber": "6253", "text": "ثابت نے حضرت انس  رضی اللہ تعالیٰ عنہ   سے روایت کی کہ یمن کے لوگ رسول اللہ  صلی اللہ علیہ وسلم  کے"}
{"hadithnumber": "6254", "text": "شعبہ نے کہا :  میں نے ابو اسحٰق کو صلہ بن زفر سے حدیث بیان کرتے ہو ئے سنا ، انھوں نے حضرت حذیفہ رضی"}
{"hadithnumber": "6255", "text": "سفیان نے ابو اسحٰق سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی ۔"}
{"hadithnumber": "6256", "text": "احمد بن حنبل نے کہا : ہمیں سفیان بن عیینہ نے حدیث بیان کی ، کہا :  مجھے عبیداللہ بن ابی یزید نے نافع"}
{"hadithnumber": "6257", "text": "ابن ابی عمر نے کہا : ہمیں سفیان نے عبیداللہ بن ابی یزید سے ، انھوں نے نافع بن جبیر بن معطم سے ، انھو"}
{"hadithnumber": "6258", "text": "عبیداللہ کے والد معاذ نے کہا : ہمیں شعبہ نے عدی بن ثابت سے حدیث بیان کی ، انھوں نے کہا : ہمیں حضرت ب"}
{"hadithnumber": "6259", "text": "۔  ( محمد بن جعفر )  غندر نے کہا : ہمیں شعبہ نے عدی بن ثابت سے حدیث بیان کی ، انھوں نے حضرت براء  رض"}
{"hadithnumber": "6260", "text": "ہمیں ایاس نے اپنے والد سے حدیث سنائی ، کہا : میں نبی کریم صلی اللہ علیہ وسلم  اور حضرت حسن اور حسین"}
{"hadithnumber": "6261", "text": "۔  ام المؤمنین عائشہ صدیقہ رضی اللہ عنہا کہتی ہیں کہ رسول اللہ صلی اللہ علیہ وسلم صبح کو نکلے اور آپ"}
{"hadithnumber": "6262", "text": "قتیبہ بن سعید نے ہمیں حدیث بیان کی  ، کہا : ہمیں یعقوب بن عبدالرحمان القاری نے موسیٰ بن عقبہ سے حدیث"}
{"hadithnumber": "6263", "text": "وہیب نے کہا : موسیٰ بن عقبہ نےہمیں حدیث بیان کی ، کہا : مجھے سالم نے عبداللہ  رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "6264", "text": "عبداللہ بن دینار سے روایت ہے  ، انھوں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ   سے سنا ، کہہ رہے تھے : ر"}
{"hadithnumber": "6265", "text": "سالم نے اپنے والد ( حضرت ابن عمر رضی اللہ تعالیٰ عنہ   )  سے روایت کی کہ رسول اللہ  صلی اللہ علیہ وس"}
{"hadithnumber": "6266", "text": "اسماعیل بن علیہ نے حبیب بن شہید سے ، انھوں نے عبداللہ بن ابی ملیکہ سے روایت کی ، کہا : حضرت عبداللہ"}
{"hadithnumber": "6267", "text": "ابو اسامہ نے حبیب بن شہید سے ابن علیہ کی حدیث کے مانند اور اسی کی سند سے حدیث بیان کی ۔"}
{"hadithnumber": "6268", "text": "ابو معاویہ نے عاصم احول سے  ، انھوں نے مورق عجلی سے ، انھوں نے حضرت عبداللہ بن جعفررضی اللہ تعالیٰ ع"}
{"hadithnumber": "6269", "text": "عبدالرحیم بن سلیمان نے عاصم سے روایت کی  ، کہا : مجھے مورق عجلی  نے حدیث بیان کی ، کہا : مجھے حضرت ع"}
{"hadithnumber": "6270", "text": "حضرت حسن بن علی رضی اللہ تعالیٰ عنہ  کے آزاد کردہ غلام حسن بن سعد نے حضرت عبداللہ بن جعفر رضی اللہ ت"}
{"hadithnumber": "6271", "text": "ابوبکر بن ابی شیبہ اور ابوکریب نے ابو اسامہ ، ابن نمیر ، وکیع اور ابو معاویہ سے حدیث بیان کی ۔ اسحاق"}
{"hadithnumber": "6272", "text": "حضرت ابو موسیٰ  رضی اللہ تعالیٰ عنہ  سے روایت ہے  ، کہا : رسول اللہ صلی اللہ علیہ وسلم نے فرمایا؛ "}
{"hadithnumber": "6273", "text": "ابو بکر بن ابی شیبہ ، ابو کریب اور ابن نمیر نے کہا : ہمیں ابن فضیل نے عمارہ سے حدیث بیان کی ، انھوں"}
{"hadithnumber": "6274", "text": "عبداللہ بن نمیر اور محمد بن بشر عبدی نے اسماعیل سے روایت کی  ، کہا : میں نے حضرت عبداللہ بن ابی اوفی"}
{"hadithnumber": "6275", "text": "ابو معاویہ  ، وکیع ، معتمر بن سلیمان  ، جریر اور سفیان سب نے اسماعیل بن ابی خالد سے  ، انھوں نے ابن"}
{"hadithnumber": "6276", "text": "عبدہ نے ہشام بن عروہ سے ، انھوں نے اپنے والد سے ، انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے روای"}
{"hadithnumber": "6277", "text": "ابواسامہ نے ہمیں  حدیث بیان کی ، کہا : ہمیں ہشام نے اپنے والد سے حدیث بیا ن کی ، انھوں نے حضرت عائشہ"}
{"hadithnumber": "6278", "text": "حفص بن غیاث نے ہشام بن عروہ سے ، انھوں نے اپنے والد سے  ، انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عنہا"}
{"hadithnumber": "6279", "text": "ابو معاویہ نے کہا : ہمیں ہشام نے اسی سند کے ساتھ بکری ( ذبح کرنے )  کے قصے تک ابو اسامہ کی حدیث کی ط"}
{"hadithnumber": "6280", "text": "زہری نے عروہ سے ، انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے روایت کی ، کہا : مجھے رسول  اللہ  صل"}
{"hadithnumber": "6281", "text": "عروہ نے حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے روایت کی ، کہا : رسول اللہ صلی اللہ علیہ وسلم نے حضرت خ"}
{"hadithnumber": "6282", "text": "علی بن مسہر نے ہشام سے ، انھوں نے اپنے والد سے ، انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے  روای"}
{"hadithnumber": "6283", "text": "حماد نے کہا : ہمیں ہشام نے اپنے والد  سے ، انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے روایت کی  ،"}
{"hadithnumber": "6284", "text": "ابن ادریس اور ابو اسامہ نے ہشام سے ، اسی سند کے ساتھ اسی کے مانند حدیث بیان کی ۔"}
{"hadithnumber": "6285", "text": "ابو اسامہ نے ہشام سے  ، انھوں نے اپنے والد سے  ، انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے روایت"}
{"hadithnumber": "6286", "text": "عبدہ نے ہشام بن عروہ سے اسی سند کے ساتھ آپ صلی اللہ علیہ وسلم کے فرمان؛ \" نہیں ، حضرت ابراہیم علیہ ا"}
{"hadithnumber": "6287", "text": "عبدالعزیز بن محمد نے ہشام بن عروہ سے ، انھوں نے اپنے والد سے ، انھوں نے حضرت عائشہ رضی اللہ تعالیٰ ع"}
{"hadithnumber": "6288", "text": "ابو اسامہ ، جریر اور محمد بن بشر سب نے ہشام سے اسی سند کے ساتھ روایت کی ، اور جریر کی حدیث میں کہا :"}
{"hadithnumber": "6289", "text": "عروہ نے حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے روایت کی کہ لوگ اپنے ہدیے بھیجنے کے لئے حضرت عائشہ رضی"}
{"hadithnumber": "6290", "text": "صالح نے ابن شہاب سے روایت کی ، کہا : مجھے محمد بن عبدالرحمان بن حارث بن ہشام نے بتایا کہ نبی کریم صل"}
{"hadithnumber": "6291", "text": "یونس نے زہری سے اسی سند کے ساتھ  ، معنی میں بالکل اسی کے مانند روایت کی ، مگر انھوں نے یوں کہا : جب"}
{"hadithnumber": "6292", "text": "عروہ نے حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے روایت کی ، کہا : رسول اللہ صلی اللہ علیہ وسلم  ( بیماری"}
{"hadithnumber": "6293", "text": "مالک بن انس نے ہشام بن عروہ سے  ، انھوں نے عباد بن عبداللہ بن زبیر سے ، انھوں نے حضرت عائشہ رضی اللہ"}
{"hadithnumber": "6294", "text": "ابواسامہ ، عبداللہ بن نمیر اورعبدہ بن سلیمان ، سب نے ہشام سے اسی سند کے ساتھ اسی کے مانند روایت کی ۔"}
{"hadithnumber": "6295", "text": "محمد بن جعفر نے کہا :  ہمیں شعبہ نے سعد بن ابرا ہیم سے حدیث بیان کی ،  انھوں نے عروہ سے ،  انھوں نے"}
{"hadithnumber": "6296", "text": "وکیع اور معاذ نے کہا :  ہمیں شعبہ نےسعد  ( بنابرا ہیم )  سے اسی سند کے ساتھ اسکے مانند روایت کی ۔"}
{"hadithnumber": "6297", "text": "ابن شہاب نے کہا :  مجھے سعید بن مسیب اور عروہ بن زبیر نے بہت سے اہل علم لوگوں کی مو جو دگی میں خبردی"}
{"hadithnumber": "6298", "text": "قاسم بن محمد نے حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے روایت کی  ، کہا :  جب رسول اللہ  صلی اللہ علیہ"}
{"hadithnumber": "6299", "text": "سلیمان بن بلال نے عبد اللہ بن عبد الرحمٰن سے ،  انھوں نے حضرت انس بن مالک رضی اللہ تعالیٰ عنہ سے روا"}
{"hadithnumber": "6300", "text": "اسماعیل بن جعفر اور عبد العزیز بن محمد دونوں نے عبد اللہ بن عبدالرحمٰن سے  ، انھوں نے حضرت انس رضی ا"}
{"hadithnumber": "6301", "text": "عبد الرحیم بن سلیمان اور یعلیٰ بن عبید نے زکریا سے حدیث بیان کی ، انھوں نےس  ( عامر )  شعبی سے ،  ان"}
{"hadithnumber": "6302", "text": "۔  ( ابو بکر کو فی )  ملائی نے کہا :  ہمیں زکریا بن ابی زائد ہ نے حدیث بیان کی ۔ انھوں نے کہا :  میں"}
{"hadithnumber": "6303", "text": "اسباط بن محمد نے زکریا سے اسی سند کے ساتھ اسی کے مانند خبر دی"}
{"hadithnumber": "6304", "text": "زہری نے کہا :  مجھے ابو سلمہ بن عبد الرحمٰن نے حدیث بیان کی کہ نبی  صلی اللہ علیہ وسلم کی اہلیہ حضرت"}
{"hadithnumber": "6305", "text": "عیسیٰ بن یونس نے کہا : ہمیں ہشام بن عروہ نے اپنے بھائی عبداللہ بن عروہ سے حدیث بیان کی ، انھوں نے عر"}
{"hadithnumber": "6306", "text": "سعید بن سلمہ نے یہ حدیث ہشام بن عروہ سے اسی سند کے ساتھ بیان کی ،  مگر  ( ساتویں کے خاوندکے متعلق  )"}
{"hadithnumber": "6307", "text": "لیث بن سعد نے کہا :  ہمیں عبد اللہ بن عبید اللہ بن ابی ملیکہ قرشی تیمی نے حدیث بیان کی کہ حضرت مسورب"}
{"hadithnumber": "6308", "text": "عمرو نے ابن ابی ملیکہ سے ،  انھوں نے حضرت مسور بن مخرمہ رضی اللہ تعالیٰ عنہ سے روایت کی ،  کہا :  رس"}
{"hadithnumber": "6309", "text": "محمد بن عمرو بن حلحلہ دؤلی نے کہا :  ابن شہاب نے انھیں حدیث بیان کی ، انھیں علی بن حسین  ( زین العاب"}
{"hadithnumber": "6310", "text": "شعیب نے زہری سے روایت کی ،  انھوں نے کہا :  مجھے علی بن حسین  ( زین العابدین )  نے خبر دی کہ مسور بن"}
{"hadithnumber": "6311", "text": "نعمان بن راشد نے زہری سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی ۔"}
{"hadithnumber": "6312", "text": "عروہ بن زبیر نے کہا :  حضرت عائشہ رضی اللہ تعالیٰ عنہا   نے انھیں حدیث بیان کی کہ رسول اللہ  صلی الل"}
{"hadithnumber": "6313", "text": "ابو عوانہ نے فراس سے ،  انھوں نے عامر سے ، انھوں نے مسروق سے ،  انھوں نے حضرت عائشہ رضی اللہ تعالیٰ"}
{"hadithnumber": "6314", "text": "زکریا نے فراس سے  ، انھوں نے عامر سے ، انھوں نے مسروق سے  ، انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عنہا"}
{"hadithnumber": "6315", "text": "معتمر بن سلیمان نے ہمیں حدیث بیان کی ، کہا : میں نے اپنے والد سے سنا ، کہا : ہمیں ابو عثمان نے حضرت"}
{"hadithnumber": "6316", "text": "عائشہ بنت طلحہ نے ام المومنین حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے روایت کی ، کہا : رسول اللہ  صلی ا"}
{"hadithnumber": "6317", "text": "ثابت نے حضرت انس رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا : رسول اللہ صلی اللہ علیہ وسلم حضرت ام ایمن"}
{"hadithnumber": "6318", "text": "ثابت نے حضرت انس رضی اللہ تعالیٰ عنہ  سے روایت کی ، انھوں نے کہا :  کہ سیدنا ابوبکر رضی اللہ عنہ نے"}
{"hadithnumber": "6319", "text": "اسحاق بن عبداللہ نے حضرت انس رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا : رسول اللہ صلی اللہ علیہ وسلم ا"}
{"hadithnumber": "6320", "text": "ثابت نے حضرت انس رضی اللہ تعالیٰ عنہ  سے ، انھوں نے نبی کریم صلی اللہ علیہ وسلم سے روایت کی کہ  آپ ص"}
{"hadithnumber": "6321", "text": "محمد بن منکدر نے حضرت جابر بن عبداللہ رضی اللہ تعالیٰ عنہ  سے روایت کی کہ رسول اللہ صلی اللہ علیہ وس"}
{"hadithnumber": "6322", "text": "بہز نے کہا : ہمیں سلیمان بن مغیرہ نے ثابت سے حدیث بیان کی ، انھوں نے حضرت انس بن مالک رضی اللہ تعالی"}
{"hadithnumber": "6323", "text": "عمرو بن عاص نے کہا : ہمیں سلیمان بن مغیرہ نے حدیث بیان کی ، انھوں نے کہا : ہمیں ثابت نے حدیث سنائی ،"}
{"hadithnumber": "6324", "text": "حضرت ابو ہریرۃ  رضی اللہ تعالیٰ عنہ  سے روایت ہے  ، کہا :  سیدنا ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ ر"}
{"hadithnumber": "6325", "text": "حضرت عبد اللہ بن مسعود  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہا :  جب یہ آیت نازل ہو ئی  :  \"  جو لوگ ا"}
{"hadithnumber": "6326", "text": "ابو زائدہ نے ابو اسحٰق سے ،  انھوں نے اسود بن یزید سے ،  انھوں نے حضرت موسی  ( اشعری )  رضی اللہ تعا"}
{"hadithnumber": "6327", "text": "یو سف نے ابو اسحاق سے روایت  کی کہ انھوں نے اسود کو یہ کہتے ہوئے سنا ،  میں نے حضرت ابو موسیٰ رضی ال"}
{"hadithnumber": "6328", "text": "سفیان نے ابو اسحٰق سے ،  انھوں نے اسود سے ،  انھوں نے حضرت ابو موسیٰ رضی اللہ تعالیٰ عنہ سے روایت کی"}
{"hadithnumber": "6329", "text": "ابو اسحٰق سے روایت ہے انھوں نے کہا :  میں نے ابو حوص سے سنا ،  انھوں نے کہا :  جس وقت حضرت ابن مسعود"}
{"hadithnumber": "6330", "text": "قطبہ بن عبدالعزیز نے اعمش سے ، انھوں نے مالک بن حارث سے ، انھوں نے ابو احوص سے روایت کی ، کہا :  ہم"}
{"hadithnumber": "6331", "text": "ابو عبیدہ نے اعمش سے  ، انھوں نے زید بن وہب سے روایت کی ، کہا : میں حضرت حذیفہ اورابو موسیٰ رضوان ال"}
{"hadithnumber": "6332", "text": "شقیق نے حضرت عبداللہ ( بن مسعود )  رضی اللہ تعالیٰ عنہ  سے روایت کی کہ انھوں نے پڑھا :  \"\"  ”اور جو"}
{"hadithnumber": "6333", "text": "مسروق نے حضرت عبداللہ ( بن مسعود )   رضی اللہ تعالیٰ عنہ  سے روایت کی ، انھوں نے کہا : اس ذات کی قسم"}
{"hadithnumber": "6334", "text": "ابو بکر بن ابی شیبہ اور محمد بن عبداللہ بن نمیر نے کہا : ہمیں وکیع نے حدیث بیان کی ، کہا : ہمیں اعمش"}
{"hadithnumber": "6335", "text": "قتیبہ بن سعید ، زہیر بن حرب اور عثمان بن ابی شیبہ نے کہا : ہمیں جریر نے اعمش سے حدیث بیان کی ، انھوں"}
{"hadithnumber": "6336", "text": "ابو بکر بن ابی شیبہ اور ابو کریب نے کہا : ہمیں ابو معاویہ نے اعمش سے جریر اور وکیع کی سند کے ساتھ حد"}
{"hadithnumber": "6337", "text": "ابن ابی عدی اور محمد بن جعفر دونوں نے شعبہ سے  ، انھوں نے اعمش سے انھی کی سندکے ساتھ روایت کی ، شعبہ"}
{"hadithnumber": "6338", "text": "ابراہیم نے مسروق سے روایت کی ، کہا : لوگوں نےحضرت عبداللہ بن عمرو رضی اللہ تعالیٰ عنہ  کے سامنے حضرت"}
{"hadithnumber": "6339", "text": "ہمیں عبیداللہ بن معاذ نے حدیث سنائی ، کہا : ہمیں میرے والد نے حدیث بیان کی ، کہا : ہمیں شعبہ نے اسی"}
{"hadithnumber": "6340", "text": "شعبہ نے قتادہ سے روایت کی  ، کہا : میں نے حضرت انس بن مالک رضی اللہ تعالیٰ عنہ  کو یہ کہتے ہوئے سنا"}
{"hadithnumber": "6341", "text": "ہمام نے کہا : قتادہ نے ہمیں حدیث سنائی  ، کہا : میں نے حضرت انس بن مالک رضی اللہ تعالیٰ عنہ  سے پوچھ"}
{"hadithnumber": "6342", "text": "ہمام نے کہا  : ہمیں قتادہ نے حضرت انس بن مالک رضی اللہ تعالیٰ عنہ  سے حدیث بیان کی کہ رسول اللہ  صلی"}
{"hadithnumber": "6343", "text": "محمد بن جعفر نے کہا : ہمیں شعبہ نے حدیث بیان کی ، انھوں نے کہا : میں نے قتادہ سے سنا ، وہ حضرت انس ب"}
{"hadithnumber": "6344", "text": "خالد بن حارث نے کہا : ہمیں شعبہ نے قتادہ سے حدیث بیان کی ، کہا : میں نے حضرت انس رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "6345", "text": "ابو زبیر نے بتایا کہ انھوں نے حضرت جابر بن عبداللہ رضی اللہ تعالیٰ عنہ  کو یہ کہتے ہوئےسنا  : رسول ا"}
{"hadithnumber": "6346", "text": "ابو سفیان نے حضرت جابر رضی اللہ تعالیٰ عنہ  سے  روایت کی ، کہا : رسول اللہ  صلی اللہ علیہ وسلم  نے ف"}
{"hadithnumber": "6347", "text": "حضرت انس بن مالک رضی اللہ تعالیٰ عنہ  نے حدیث بیان کی کہ نبی کریم صلی اللہ علیہ وسلم  نے فرمایا جبکہ"}
{"hadithnumber": "6348", "text": "محمد بن جعفر نے کہا : ہمیں شعبہ نے ابو اسحاق سے حدیث بیان کی ، انھوں نے کہا : میں نے حضرت براء رضی ا"}
{"hadithnumber": "6349", "text": "احمد بن عبدہ ضبی نے کہا : ہمیں ابو داود نے حدیث بیان کی ، کہا : ہمیں شعبہ نے حدیث سنائی  ، کہا : مجھ"}
{"hadithnumber": "6350", "text": "امیہ بن خالد نے کہا : ہمیں شعبہ نے یہ حدیث دونوں سندوں سے ابو داود کی روایت کی طرح بیان کی ۔"}
{"hadithnumber": "6351", "text": "شیبان نے قتادہ سے روایت کی  ، کہا : ہمیں حضرت انس بن مالک رضی اللہ تعالیٰ عنہ  نے حدیث بیان کی کہ رس"}
{"hadithnumber": "6352", "text": "عمر بن عامر نے قتادہ سے ، انھوں نے حضرت انس  رضی اللہ تعالیٰ عنہ  سے روایت کی کہ دومۃ الجندل کے ( با"}
{"hadithnumber": "6353", "text": "ثابت نے ہمیں حضرت  انس رضی اللہ تعالیٰ عنہ  سے روایت کی  ،  کہ رسول اللہ صلی اللہ علیہ وسلم نے احد ک"}
{"hadithnumber": "6354", "text": "سفیان بن عیینہ نے کہا : میں نے ابن منکدر کو یہ کہتے ہوئے سنا : میں نے حضرت جابر بن عبداللہ رضی اللہ"}
{"hadithnumber": "6355", "text": "شعبہ نے محمد بن منکدر سے  ، انھوں نے حضرت جابر بن عبداللہ رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا :"}
{"hadithnumber": "6356", "text": "ابن جریج اور معمر دونوں نے محمد بن منکدر سے ، انھوں نے حضرت جابر رضی اللہ تعالیٰ عنہ  سے یہی حدیث بی"}
{"hadithnumber": "6357", "text": "عبدالکریم نے محمد بن منکدر سے  ، انھوں نے حضرت جابر  رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا : اُحد ک"}
{"hadithnumber": "6358", "text": "حضرت ابو برزہ رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ نبی کریم صلی اللہ علیہ وسلم  اپنی ایک جنگ میں تھے"}
{"hadithnumber": "6359", "text": "ہداب بن خالد ازدی نے کہا : ہمیں سلیمان بن مغیرہ نے حدیث بیان کی  ، کہا : ہمیں حمید بن ہلال نے عبدالل"}
{"hadithnumber": "6360", "text": "ہمیں نضر بن شمیل نے خبر دی  ، کہا : ہمیں سلیمان بن مغیرہ نے حدیث بیان کی ، کہا : ہمیں حمید بن ہلال ن"}
{"hadithnumber": "6361", "text": "ابن عون نے حمید بن ہلال سے ، انھوں نے عبداللہ بن صامت سے روایت کی  ، کہا : حضرت ابوزر رضی اللہ تعالی"}
{"hadithnumber": "6362", "text": "ابو جمرہ نے حضرت ابن عباس رضی اللہ تعالیٰ عنہ  سے روایت کی  ، کہا :  کہ جب سیدنا ابوذر رضی اللہ عنہ"}
{"hadithnumber": "6363", "text": "یحییٰ بن یحییٰ تمیمی اور عبد الحمید بن بیان واسطی نے خالد بن عبد اللہ سے ،  انھوں نے بیان سے روایت ک"}
{"hadithnumber": "6364", "text": "بو بکربن ابی شیبہ نے کہا  :  ہمیں وکیع اور ابو اسامہ نے اسماعیل سے حدیث بیان کی ،  نیز ابن نمیر نے ک"}
{"hadithnumber": "6365", "text": "عبد الحمید بن بیان نے کہا  :  ہمیں خ رحمۃ اللہ علیہ الد نے بیان سے خبر دی  ، انھوں نے  قیس سے ،  انھ"}
{"hadithnumber": "6366", "text": "جریر نے اسماعیل بن ابی خالد سے انھوں نے قیس بن ابی حازم سے ،  انھوں نے حضرت جریر بن عبد اللہ بجلی رض"}
{"hadithnumber": "6367", "text": "وکیع عبد اللہ بن نمیر  ، سفیان  ، مروان فرازی اور ابو اسامہ سب نے اسماعیل سے اسی سند کے ساتھ روایت ک"}
{"hadithnumber": "6368", "text": "زہیر بن حرب اور ابو بکر بن نضر نے کہا :  ہمیں ہاشم بن قاسم نے حدیث بیان کی ،  کہا :  ہمیں ورقا ء بن"}
{"hadithnumber": "6369", "text": "نافع نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا :  میں نے خواب میں دیکھا کہ میرے ہاتھ می"}
{"hadithnumber": "6370", "text": "زہری نے سالم سے ،  انھوں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہا :  رسول اللہ  صلی ا"}
{"hadithnumber": "6371", "text": "عبید اللہ بن عمر نے نافع سے ،  انھوں نے حضرت عبد اللہ بن عمر رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہا"}
{"hadithnumber": "6372", "text": "محمد بن جعفر نے کہا  :  ہمیں شعبہ نے حدیث سنائی  ، انھوں نے کہا :  میں نے قتادہ سے سنا  ، وہ حضرت ان"}
{"hadithnumber": "6373", "text": "ابو داود نے کہا : ہمیں شعبہ نے قتادہ سے حدیث بیان کی  ،  میں نے حضرت انس رضی اللہ تعالیٰ عنہ  کو کہت"}
{"hadithnumber": "6374", "text": "محمد بن جعفر نے کہا  :  ہمیں شعبہ نے ہشام بن زید سے حدیث بیان کی ، انھوں نے کہا :  میں نے حضرت انس ب"}
{"hadithnumber": "6375", "text": "ثابت نے حضرت انس  رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہا :  نبی  صلی اللہ علیہ وسلم  ہمارے ہاں تشری"}
{"hadithnumber": "6376", "text": "اسحٰق نے کہا :  مجھے حضرت انس رضی اللہ تعالیٰ عنہ  نے حدیث سنائی کہا :  میری والدہ ام انس رضی اللہ ت"}
{"hadithnumber": "6377", "text": "حضرت انس بن مالک  رضی اللہ تعالیٰ عنہ  نے حدیث بیان کی کہ رسول اللہ  صلی اللہ علیہ وسلم   ( ہمارے گھ"}
{"hadithnumber": "6378", "text": "ثابت نے حضرت انس رضی اللہ تعالیٰ عنہ سے حدیث بیان کی کہا :  رسول اللہ  صلی اللہ علیہ وسلم میرے پاس ت"}
{"hadithnumber": "6379", "text": "معتمر بن سلیمان نے کہا :  میں نے اپنے والد سے سنا ،  وہ حضرت انس بن مالک رضی اللہ تعالیٰ عنہ  سے حدی"}
{"hadithnumber": "6380", "text": "عامر بن سعد نے کہا :  میں نے اپنے والد کو یہ کہتے ہو ئے سنا ، میں نے حضرت عبد اللہ بن سلام  رضی اللہ"}
{"hadithnumber": "6381", "text": "معاذ بن معاذ نے کہا : ہمیں عبداللہ بن عون نے محمد بن سیرین سے حدیث بیان کی ، انھوں نے قیس بن عباد سے"}
{"hadithnumber": "6382", "text": "قرہ بن خالد نے ہمیں محمد بن سیرین سے حدیث سنائی انھوں نے کہا :  قیس بن عباد نے کہا :  میں ایک مجلس م"}
{"hadithnumber": "6383", "text": "خرشہ بن حر سے روایت ہے ، انھوں نے کہا : میں مدینہ منورہ کی مسجد کے اندر ایک حلقے میں بیٹھا ہوا تھا ،"}
{"hadithnumber": "6384", "text": "سفیان بن عیینہ نے زہری سے ، انھوں نے سعید ( بن مسیب )  سے  ، انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ"}
{"hadithnumber": "6385", "text": "معمر نے زہری سے ، انھوں نے ابن مسیب سے روایت کی کہ حضرت حسان رضی اللہ تعالیٰ عنہ  نے ایک حلقے میں کہ"}
{"hadithnumber": "6386", "text": "زہری نے کہا : مجھے ابو سلمہ بن عبدالرحمان نے بتایا کہ انھوں نے حضرت  حسان بن ثابت انصاری رضی اللہ تع"}
{"hadithnumber": "6387", "text": "معاذ نے کہا : ہمیں شعبہ نے عدی بن ثابت سے حدیث بیان کی ، انھوں نے کہا : میں نے حضرت براء بن عاذب رضی"}
{"hadithnumber": "6388", "text": "محمد بن جعفر غندر اور عبدا الرحمان ( بن مہدی )  دونوں نے شعبہ سے اسی سندک سا تھ اسی کے مانند  روایت"}
{"hadithnumber": "6389", "text": "ابو اسامہ نے ہشام ( بن عروہ )  سے ، انھوں نے اپنے والد سے روایت کی کہ حضرت حسان بن ثابت رضی اللہ تعا"}
{"hadithnumber": "6390", "text": "عبدہ نے ہشام سے اسی سند کے ساتھ حدیث بیان کی ۔"}
{"hadithnumber": "6391", "text": "محمد بن جعفر نے شعبہ سے  ، انھوں نے سلیمان سے ، انھوں نے ابو ضحیٰ سے ، انھوں نے مسروق سے روایت کی کہ"}
{"hadithnumber": "6392", "text": "ابن ابی عدی نے شعبہ سے اسی سند کے ساتھ حدیث بیان کی اورکہا : حضرت عائشہ رضی اللہ تعالیٰ عنہا   نے فر"}
{"hadithnumber": "6393", "text": "یحییٰ بن زکریا نے ہمیں ہشام بن عروہ سے خبر دی ، انھوں نے اپنے والد سے اور انھوں نے حضرت عائشہ رضی ال"}
{"hadithnumber": "6394", "text": "عبدہ نے ہشام بن عروہ سے اسی سند کے ساتھ حدیث بیان کی کہ حضرت عائشہ رضی اللہ تعالیٰ عنہا   نے کہا : ح"}
{"hadithnumber": "6395", "text": "ابو سلمہ بن عبدالرحمان نے حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے روایت کی کہ رسول اللہ  صلی اللہ علیہ"}
{"hadithnumber": "6396", "text": "حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ نے کہا :  کہ میں اپنی والدہ کو اسلام کی طرف بلاتا تھا اور وہ مشرک"}
{"hadithnumber": "6397", "text": "سفیان بن عیینہ نے زہری سے ، انھوں نے اعرج سےروایت کی ، کہا : میں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ ع"}
{"hadithnumber": "6398", "text": "مالک بن انس اور معمر نے زہری سے ، انھوں نے اعرج سے اور انھوں نے ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے یہ"}
{"hadithnumber": "6399", "text": "یو نس نے ابن شہاب سے روایت کی عروہ بن زبیر نے انھیں حدیث بیان کی کہ حضرت عائشہ رضی اللہ تعالیٰ عنہا"}
{"hadithnumber": "6400", "text": "شعیب نے زہری سے روایت کی ،  انھوں نے کہا :  مجھے سعید بن مسیب اور ابو سلمہ بن عبد الرحمٰن نے بتا یا"}
{"hadithnumber": "6401", "text": "ابو بکر  بن ابی شیبہ ، عمرو ناقد ، زہیر بن حرب ، اسحاق بن ابراہیم اور ابن ابی عمر نے ہمیں حدیث بیان"}
{"hadithnumber": "6402", "text": "ابو عبد الرحمٰن سلمی نے حضرت علی رضی اللہ تعالیٰ عنہ  سے روایت کی کہا :  رسول اللہ  صلی اللہ علیہ وس"}
{"hadithnumber": "6403", "text": "حضرت جا بر رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ حضرت حاطب  رضی اللہ تعالیٰ عنہ  کا ایک غلام رسول اللہ"}
{"hadithnumber": "6404", "text": "ابو زبیر نے خبر دی کہا :  انھوں نے جابر بن عبد اللہ  رضی اللہ تعالیٰ عنہ  سے سنا ، کہہ رہے تھے ۔ مجھ"}
{"hadithnumber": "6405", "text": "ابو بردہ نے حضرت ابو موسیٰ اشعری رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہا :  میں رسول اللہ  صلی اللہ"}
{"hadithnumber": "6406", "text": "برید نے ابو بردہ سے اور انھوں نے اپنے والد  ( حضرت ابو موسیٰ اشعری رضی اللہ تعالیٰ عنہ  )  سے روایت"}
{"hadithnumber": "6407", "text": "ابو بردہ نے حضرت ابو موسیٰ  رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہا :  رسول اللہ  صلی اللہ علیہ وسلم"}
{"hadithnumber": "6408", "text": "ابو بردہ نے حضرت ابو موسیٰ اشعری رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہا :  رسول اللہ  صلی اللہ علیہ"}
{"hadithnumber": "6409", "text": "عکرمہ نے کہا :  ہمیں ابو زمیل نے حدیث بیان کی ،  انھوں نے کہا :  مجھے حضرت ابن عباس رضی اللہ تعالیٰ"}
{"hadithnumber": "6411", "text": "کہا :  ( تو ایسا ہوا کہ حضرت جعفر رضی اللہ تعالیٰ عنہ  کی بیوی )  اسماء بن عمیس  رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "6412", "text": "معاویہ بن قرہ نے عائذ بن عمرو  رضی اللہ تعالیٰ عنہ  سے روایت کی کہ ابوسفیان  رضی اللہ تعالیٰ عنہ  چن"}
{"hadithnumber": "6413", "text": "عمرو  ( بن دینار ) نے حضرت جا بر بن عبد اللہ  رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہا :  یہ آیت ہمار"}
{"hadithnumber": "6416", "text": "عکرمہ بن عمار نے کہا :  ہمیں اسحٰق بن عبد اللہ بن ابی طلحہ نے حدیث بیان کی ، کہا :  حضرت انس رضی الل"}
{"hadithnumber": "6417", "text": "عبد العزیز بن صہیب نے حضرت انس رضی اللہ تعالیٰ عنہ سے روایت کی کہ نبی  صلی اللہ علیہ وسلم  نے  ( انص"}
{"hadithnumber": "6418", "text": "محمد بن جعفر نے کہا :  ہمیں شعبہ نے ہشام بن زید سے حدیث بیان کی ،  انھوں نے کہا :  میں نے حضرت انس ب"}
{"hadithnumber": "6419", "text": "خالد بن حارث اور ابن ادریس نے شعبہ سے اسی سند کے ساتھ حدیث بیان کی ،"}
{"hadithnumber": "6420", "text": "ہمیں شعبہ نے حدیث سنائی  ، کہا :  میں نے قتادہ سے سنا ، وہ حجرت انس بن مالک  رضی اللہ تعالیٰ عنہ سے"}
{"hadithnumber": "6421", "text": "محمد بن جعفر نے کہا :  شعبہ نے حدیث بیان کی ،  انھوں نے کہا :  میں نے قتادہ سے سنا ،  حضرت انس رضی ا"}
{"hadithnumber": "6422", "text": "ابو داؤد نے کہا :  ہمیں شعبہ نے قتادہ سے حدیث بیان کی ،  انھوں نے کہا :  میں نے حضرت انس رضی اللہ تع"}
{"hadithnumber": "6423", "text": "یحییٰ بن سعید نے حضرت انس رضی اللہ تعالیٰ عنہ  سے اسی کے مانند روایت کی مگر انھوں نے حضرت سعد  رضی ا"}
{"hadithnumber": "6424", "text": "ابرا ہیم بن محمد بن طلحہ سے روایت ہے کہا :  میں نے حضرت ابواُسید  رضی اللہ تعالیٰ عنہ  کو  ( ولید  )"}
{"hadithnumber": "6425", "text": "ابو زناد نے کہا :  ابو سلمہ نے گواہی دی کہ انھوں نے حضرت ابواسید انصاری رضی اللہ تعالیٰ عنہ  کو یہ گ"}
{"hadithnumber": "6426", "text": "یحییٰ بن ابی کثیر نے  کہا  : مجھے ابو سلمہ نے حدیث بیان کی ، انھیں حضرت ابو اسید انصاری رضی اللہ تعا"}
{"hadithnumber": "6427", "text": "ابو سلمہ اور عبید اللہ بن عبد اللہ بن عتبہ بن مسعود نے کہا :  کہ ان دونوں نے حضرت ابو ہریرہ رضی اللہ"}
{"hadithnumber": "6428", "text": "نصر بن علی جہضمی  ، محمد بن مثنیٰ اور ابن بشار نے ابن عرعرہ سے روایت کی ۔ الفاظ جہضمی کے ہیں  ۔ انھو"}
{"hadithnumber": "6429", "text": "حضرت ابو ذر رضی اللہ تعالیٰ عنہ  نے کہا :  رسول اللہ  صلی اللہ علیہ وسلم  نے فرما یا  :  \"  غفار  ،"}
{"hadithnumber": "6430", "text": "عبد الرحمٰن بن مہدی نے کہا :  ہمیں شعبہ نے ابو عمران جونی سے حدیث بیان کی  ، انھوں نے عبد اللہ بن صا"}
{"hadithnumber": "6431", "text": "ابو داؤد نے کہا :  ہمیں شعبہ نے یہ حدیث اسی سند سے بیان کی ۔"}
{"hadithnumber": "6432", "text": "محمد  ( بن سیرین )  محمد بن زیاد اور اعرج نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی ،  نیز"}
{"hadithnumber": "6433", "text": "خثیم بن عراک نے اپنے والد سے ،  انھوں نے حضرت ابوہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی کہ رسول اللہ"}
{"hadithnumber": "6434", "text": "حنظلہ بن علی نے حضرت خفاف بن ایماء غفاری رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہا :  رسول اللہ  صلی ا"}
{"hadithnumber": "6435", "text": "عبد اللہ بن دینار سے روایت ہے کہ انھوں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے سنا ، انھوں نے کہا :"}
{"hadithnumber": "6436", "text": "عبید اللہ  ، اسامہ اور ابو صالح سب نے نافع سے ،  انھوں نے  حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سےانھوں"}
{"hadithnumber": "6437", "text": "ابو سلمہ نے کہا :  مجھے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  نے حدیث بیان کی ،  کہا :  میں نے رسول اللہ"}
{"hadithnumber": "6438", "text": "حضرت ابو ایوب رضی اللہ تعالیٰ عنہ  سے روایت ہے کہا :  رسول اللہ  صلی اللہ علیہ وسلم  نے فر ما یا  :"}
{"hadithnumber": "6439", "text": "سفیان  ( بن سعید  )  نے سعد بن ابرا ہیم سے ،  انھوں نے عبد الرحمان بن ہر مز اعرج سے ،  انھوں نے حضرت"}
{"hadithnumber": "6440", "text": "عبید اللہ بن معاذ کے والد نے کہا :  ہمیں شعبہ نے سعد بن ابرا ہیم سے اسی سند کے ساتھ اسی کے مانند روا"}
{"hadithnumber": "6441", "text": "سعد بن ابرا ہیم  سے روایت ہے  ، کہا :  میں نے ابو سلمہ سے سنا ، وہ حضرت ابو ہریرہ رضی اللہ تعالیٰ عن"}
{"hadithnumber": "6442", "text": "ابو زناد اور صالح نے اعرج سے ،  انھوں نے حضرت ابوہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہا :  رس"}
{"hadithnumber": "6443", "text": "ایوب نے محمد  ( بن سیرین )  سے ،  انھوں نے حضرت ابوہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہا :"}
{"hadithnumber": "6444", "text": "ابو بکربن ابی شیبہ نے ہمیں حدیث بیان کی  ، کہا :  ہمیں غندر نے شعبہ سے حدیث بیان کی ،  اسی طرح محمد"}
{"hadithnumber": "6445", "text": "عبد الصمد نے ہمیں حدیث بیان کی  ،  کہا :  ہمیں شعبہ نے حدیث سنائی کہا :  مجھے بنو تمیم کے سردار محمد"}
{"hadithnumber": "6446", "text": "6446     نصر بن علی جہضمی کے والد نے ہمیں حدیث بیان کی  ، کہا :  ہمیں شعبہ نے ابو بشر سے ،  انھوں نے"}
{"hadithnumber": "6447", "text": "عبد الصمد اور شبابہ بن سوار نے کہا :  ہمیں شعبہ نے ابوبشر سے اسی سند کے ساتھ حدیث بیان کی ۔"}
{"hadithnumber": "6448", "text": "ابو بکر بن ابی شیبہ اور کریب نے ۔  ۔  ۔ اور الفاظ ابو بکر کے ہیں  ۔  ۔  ۔ حدیث بیان کی  ، دونوں نے ک"}
{"hadithnumber": "6449", "text": "عدی بن حاتم سے روایت ہے ، کہا :  میں حضرت عمر بن خطاب رضی اللہ تعالیٰ عنہ  کے پاس آیا تو انھوں نے مج"}
{"hadithnumber": "6450", "text": "حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ سے روایت ہے کہا :  حضرت طفیل  ( بن عمرو دوسی )  رضی اللہ تعالیٰ ع"}
{"hadithnumber": "6451", "text": "حارث نے ابو زرعہ سے روایت کی ،  انھوں نے کہا :  حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  نے کہا :  میں بن"}
{"hadithnumber": "6452", "text": "عمارہ نے ابو زرعہ سے ،  انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ سے روایت کی ،  کہا :  تین باتوں"}
{"hadithnumber": "6453", "text": "۔ شعبی نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ سے روایت کی ،  کہا :  تین صفات ہیں جو میں نے بنوتمیم کے"}
{"hadithnumber": "6454", "text": "ابن شہاب نے کہا : مجھے سعید بن مسیب نے حضرت ابوہریرہ رضی اللہ تعالیٰ عنہ  سے حدیث بیان کی کہ رسول ال"}
{"hadithnumber": "6455", "text": "ابو زرعہ اور اعرج نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا : رسول اللہ  صلی اللہ علی"}
{"hadithnumber": "6456", "text": "ابن ابی عمر نے کہا : ہمیں سفیان بن عیینہ نے ابو زناد سے حدیث بیان کی ، انھوں نے اعرج سے ، انھوں نے ح"}
{"hadithnumber": "6457", "text": "عمرو ناقد نےکہا : ہمیں سفیان نے ابو زناد سے حدیث بیان کی ، انھوں نے اعرض سے  اور انھوں نے حضرت ابو ہ"}
{"hadithnumber": "6458", "text": "یونس نے ابن شہاب سے روایت کی ، انھوں نے کہا : مجھے سعید بن مسیب نے حدیث بیان کی کہ حضرت ابو ہریرہ رض"}
{"hadithnumber": "6459", "text": "معمر نے زہری سے ، انھوں نے ابن مسیب سے  ، انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی ک"}
{"hadithnumber": "6460", "text": "معمر نے ابن طاوس سے اورانھوں نے اپنے والد سے روایت کی ، نیز معمر نے ہمام بن منبہ سے  ، انھوں نے حضرت"}
{"hadithnumber": "6461", "text": "سہیل ( بن ابی صالح )  نے اپنے والد سے ، انھوں نے حضرت ابو ہریرۃ رضی اللہ تعالیٰ عنہ  سے ، انھوں نے ن"}
{"hadithnumber": "6462", "text": "ثابت نے حضرت انس  رضی اللہ تعالیٰ عنہ  سے  روایت کی کہ رسول اللہ  صلی اللہ علیہ وسلم  نے حضرت ابوعبی"}
{"hadithnumber": "6463", "text": "حفص بن غیاث نے کہا : ہمیں عاصم احول نے حدیث بیان کی ، انھوں نے کہا : حضرت انس بن مالک رضی اللہ تعالی"}
{"hadithnumber": "6464", "text": "عبدہ بن سلیمان نے عاصم سے ، انھوں نے حضرت انس رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا : رسول اللہ  صل"}
{"hadithnumber": "6465", "text": "سعد بن ابراہیم نے ا پنے والد سے  ، انھوں نے حضرت جبیربن مطعم رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا"}
{"hadithnumber": "6466", "text": "سعید بن ابی بردہ نے ابو ہریرۃ رضی اللہ تعالیٰ عنہ  سے  ، انھوں نے ا پنے والد ( ابوموسیٰ اشعری رضی ال"}
{"hadithnumber": "6467", "text": "عمرو ( بن دینار )  نے حضرت جابر ( بن عبداللہ رضی اللہ تعالیٰ عنہ  )  سے سنا ،  وہ حضرت ابوسعید خدری"}
{"hadithnumber": "6468", "text": "ابو زبیر نے حضرت جابر رضی اللہ تعالیٰ عنہ  سے روایت کی ، انھوں نے کہا : حضرت ابو سعید خدری رضی اللہ"}
{"hadithnumber": "6469", "text": "قتیبہ بن سعید اور ہناد بن سری نے کہا : ہمیں ابواحوص نے منصور سے حدیث بیان کی ، انھوں نے ابراہیم بن ی"}
{"hadithnumber": "6470", "text": "جریر نے منصور سے ، انھوں نے ابراہیم سے ، انھوں نے حضرت عبداللہ بن مسعود رضی اللہ تعالیٰ عنہ  سے روای"}
{"hadithnumber": "6471", "text": "شعبہ اور سفیان دونوں نے منصور سے ابو احوص اور جریر کی سند کے ساتھ انھی دونوں کی حدیث کے ہم معنی حدیث"}
{"hadithnumber": "6472", "text": "ابن عون نے ابراہیم سے  ، انھوں نے عبیدہ سے  ، انھوں نے حضرت عبداللہ بن مسعود رضی اللہ تعالیٰ عنہ  سے"}
{"hadithnumber": "6473", "text": "ہشیم نے ابو بشر سے  ، انھوں نے عبداللہ بن شقیق سے ، انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے"}
{"hadithnumber": "6474", "text": "شعبہ اور ابو عوانہ دونوں نے ابو بشر سے اسی سند کے ساتھ اسی کے مانند روایت کی ، مگر شعبہ کی حدیث میں"}
{"hadithnumber": "6475", "text": "محمد بن جعفر نے کہا : ہمیں شعبہ نے حدیث بیان کی ، انھوں نے کہا : میں نے ابو جمرہ سے سنا ، انھوں نےکہ"}
{"hadithnumber": "6476", "text": "یحییٰ بن سعید  ، بہز اور شبابہ سب نے شعبہ سے اسی سند کے ساتھ حدیث بیان کی اور ان سب کی حدیث میں ہے ("}
{"hadithnumber": "6477", "text": "ابو عوانہ اور ہشام دونوں نے قتادہ سے  ، انھوں نے زرارہ بن اوفیٰ سے ، انھوں نے حضرت عمران بن حصین رضی"}
{"hadithnumber": "6478", "text": "عبداللہ بہی نے حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے روایت کی  ، کہا : ایک آدمی نے نبی کریم صلی اللہ"}
{"hadithnumber": "6479", "text": "معمر نے زہری سے روایت کی ،  انھوں نے کہا :  مجھے سالم بن عبداللہ اور ابو بکر بن سلیمان نے بتا یا کہ"}
{"hadithnumber": "6480", "text": "شعیب اور عبد الرحمٰن بن خالد بن مسافر دونوں نے زہری سے معمر کی سند کے ساتھ انھی کی حدیث کے مانند روا"}
{"hadithnumber": "6481", "text": "حجاج بن محمد نے کہا :  ابن جریج نے کہا :  مجھے ابو زبیر نے بتا یا  ، انھوں  نے حضرت جا بر بن عبد الل"}
{"hadithnumber": "6482", "text": "ابن جریج نے اسی سند کے ساتھ ہمیں خبر دی اور اس بات کا ذکر نہیں کیا کہ  ( آپ نے ) اپنی وفات سے ایک ما"}
{"hadithnumber": "6483", "text": "معتمر بن سلیمان نے کہا :  میں نے اپنے والد سے سنا ، کہا :  ابو نضرہ نے ہمیں حضرت جابر بن عبد اللہ  ر"}
{"hadithnumber": "6484", "text": "یزید بن ہارون نے کہا :  ہمیں سلیمان تیمی نے دونوں سندوں سے اسی کے مانند حدیث بیان کی ۔"}
{"hadithnumber": "6485", "text": "ابو نضر ہ نے حضرت ابو سعید  رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہا :  جب نبی  صلی اللہ علیہ وسلم  غ"}
{"hadithnumber": "6486", "text": "حصین نے سالم سے ،  انھوں نے حضرت جابر بن عبد اللہ  رضی اللہ تعالیٰ عنہ  سے روایت کی  ، کہا :  نبی  ص"}
{"hadithnumber": "6487", "text": "ابو معاویہ نے اعمش سے ،  انھوں نے ابو صالح سے ،  انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ سے روای"}
{"hadithnumber": "6488", "text": "جریر نے اعمش سے ، انھوں نے ابو صالح سے ،  انھوں نے حضرت ابو سعید  ( خدری )  رضی اللہ تعالیٰ عنہ  سے"}
{"hadithnumber": "6489", "text": "وکیع اور شعبہ نے اعمش سے جریر اور ابو معاویہ کی سند کے ساتھ ان دونوں کی حدیث کے مانند روایت کی ،  لی"}
{"hadithnumber": "6490", "text": "سلیمان بن مغیرہ نے کہا : مجھے سعید جریری نے ابو نضرہ سے حدیث بیان کی ، انھوں نے اُسیر بن جابر رضی ال"}
{"hadithnumber": "6491", "text": "حماد بن سلمہ نے سعید جریری سے اسی سند کےساتھ حدیث بیان کی ، کہا :  سیدنا عمر بن خطاب رضی اللہ عنہ سے"}
{"hadithnumber": "6492", "text": "زرارہ بن اوفیٰ نے اُسیر بن جابر رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا :  کہ سیدنا عمر بن خطاب رضی ا"}
{"hadithnumber": "6493", "text": "ابن وہب نے کہا : ہمیں حرملہ بن عمران تحبیی نے عبدالرحمٰن بن شماسہ مہری سے حدیث بیان کی ، انھوں نے کہ"}
{"hadithnumber": "6494", "text": "حَدَّثَنِي زُهَيْرُ بْنُ حَرْبٍ ،  وَعُبَيْدُ اللهِ بْنُ سَعِيدٍ ،  قَالَا :  حَدَّثَنَا وَهْبُ بْنُ"}
{"hadithnumber": "6495", "text": "جابر بن عمرو راسبی نے کہا : میں نے حضرت ابو برزہ رضی اللہ تعالیٰ عنہ  کو یہ کہتے ہوئے سنا  : رسول ال"}
{"hadithnumber": "6496", "text": "ہمیں اسود بن شیبان نے ابو نوافل سے خبردی ، کہا :  میں نے حضرت عبداللہ بن زبیر رضی اللہ تعالیٰ عنہ  ("}
{"hadithnumber": "6497", "text": "یزید بن اصم جزری نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا : رسول اللہ صلی اللہ علیہ"}
{"hadithnumber": "6498", "text": "ابو غیث نے حضرت ابو ہریر رضی اللہ تعالیٰ عنہ  سے روایت کی  ، کہا : جب نبی کریم صلی اللہ علیہ وسلم  پ"}
{"hadithnumber": "6499", "text": "سالم نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا : رسول اللہ  صلی اللہ علیہ وسلم  نے فرما"}
