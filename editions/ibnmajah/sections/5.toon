{"hadithnumber": "1430", "arabic": "حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، ‏‏‏‏‏‏حَدَّثَنَا الْمُغِيرَةُ بْنُ عَبْدِ الرَّحْمَ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Bukhari And Muslim'}", "reference": "Book 5, Hadith 628", "international_number": "1430", "narrator_chain": ""}
{"hadithnumber": "1431", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، ‏‏‏‏‏‏عَنْ ابْنِ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 5, Hadith 629", "international_number": "1431", "narrator_chain": ""}
{"hadithnumber": "1432", "arabic": "حَدَّثَنَا إِسْحَاق بْنُ إِبْرَاهِيمَ بْنِ حَبِيبٍ، ‏‏‏‏‏‏ وَمُحَمَّدُ بْنُ إِسْمَاعِيل، ‏‏‏‏‏‏قَالَ", "grades": "{'name': 'Al-Albani', 'grade': 'Very Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Very Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Very Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 5, Hadith 630", "international_number": "1432", "narrator_chain": ""}
