{"hadithnumber": "4861", "text": "عمرو بن فغواء خزاعی رضی اللہ عنہ کہتے ہیں کہ  مجھے رسول اللہ صلی اللہ علیہ وسلم نے بلایا، آپ مجھے کچ"}
{"hadithnumber": "4862", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  مومن ایک سوراخ سے دو بار"}
{"hadithnumber": "4863", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم جب چلتے تو ایسا لگتا گویا آپ آگے کی جانب ج"}
{"hadithnumber": "4864", "text": "سعید جریری کی روایت ہے کہ  ابوالطفیل رضی اللہ عنہ کہتے ہیں کہ میں نے رسول اللہ صلی اللہ علیہ وسلم کو"}
{"hadithnumber": "4865", "text": "جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے منع فرمایا کہ آدمی اپنا ایک پاؤں دوسر"}
{"hadithnumber": "4866", "text": "عباد بن تمیم اپنے چچا (عبداللہ بن زید بن عاصم رضی اللہ عنہ) سے روایت کرتے ہیں کہ  انہوں نے رسول اللہ"}
{"hadithnumber": "4867", "text": "سعید بن مسیب کہتے ہیں کہ  عمر بن خطاب اور عثمان بن عفان رضی اللہ عنہما بھی اسے کیا کرتے تھے۔"}
{"hadithnumber": "4868", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب کوئی شخص کوئ"}
{"hadithnumber": "4869", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مجلسیں امانت دا"}
{"hadithnumber": "4870", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  قیامت کے دن اللہ کے"}
{"hadithnumber": "4871", "text": "حذیفہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  چغل خور جنت میں داخل نہیں ہ"}
{"hadithnumber": "4872", "text": "ابوہریرہ رضی اللہ عنہ کہ  نبی کریم صلی اللہ علیہ وسلم نے فرمایا:  لوگوں میں برا وہ شخص ہے جو دورخا ہ"}
{"hadithnumber": "4873", "text": "عمار رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس شخص کے دنیا میں دو رخ ہوں"}
{"hadithnumber": "4874", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  عرض کیا گیا: اللہ کے رسول! غیبت کیا ہے؟ آپ صلی اللہ علیہ وسلم"}
{"hadithnumber": "4875", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم سے عرض کیا: آپ کے لی"}
{"hadithnumber": "4876", "text": "سعید بن زید رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  سب سے بڑی زیادتی یہ ہے"}
{"hadithnumber": "4877", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  بڑے گناہوں میں سب سے بڑا"}
{"hadithnumber": "4878", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب مجھے معراج کرائی گ"}
{"hadithnumber": "4879", "text": "ابومغیرہ سے بھی اسی طرح مروی ہے  جیسا کہ ابن مصفیٰ نے روایت کیا ہے۔"}
{"hadithnumber": "4880", "text": "ابوبرزہ اسلمی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اے وہ لوگو! جو ایما"}
{"hadithnumber": "4881", "text": "مستورد رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جو شخص کسی مسلمان کا عیب بی"}
{"hadithnumber": "4882", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مسلمان کی ہر چیز اس کا م"}
{"hadithnumber": "4883", "text": "معاذ بن انس جہنی رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جو کسی مومن کی عز"}
{"hadithnumber": "4884", "text": "جابربن عبداللہ اور ابوطلحہ بن سہل انصاری رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے"}
{"hadithnumber": "4885", "text": "ابوعبداللہ جشمی کہتے ہیں کہ  ہم سے جندب رضی اللہ عنہ نے بیان کیا کہ ایک اعرابی آیا اس نے اپنی سواری"}
{"hadithnumber": "4886", "text": "قتادہ کہتے ہیں  کیا تم میں سے کوئی شخص ابوضیغم یا ضمضم کی طرح ہونے سے عاجز ہے، وہ جب صبح کرتے تو کہت"}
{"hadithnumber": "4887", "text": "عبدالرحمٰن بن عجلان کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  کیا تم میں سے کوئی اس بات"}
{"hadithnumber": "4888", "text": "معاویہ رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا: اگر تم لوگو"}
{"hadithnumber": "4889", "text": "جبیر بن نفیر، کثیر بن مرہ، عمرو بن اسود، مقدام بن معد یکرب اور ابوامامہ رضی اللہ عنہم سے روایت ہے کہ"}
