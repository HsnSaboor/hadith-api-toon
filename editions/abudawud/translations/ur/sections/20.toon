{"hadithnumber": "3071", "text": "اسمر بن مضرس رضی اللہ عنہ کہتے ہیں  میں نبی اکرم صلی اللہ علیہ وسلم کے پاس آیا اور میں نے آپ سے بیعت"}
{"hadithnumber": "3072", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے زبیر رضی اللہ عنہ کو اتنی"}
{"hadithnumber": "3073", "text": "سعید بن زید رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جو شخص بنجر زمین کو"}
{"hadithnumber": "3074", "text": "عروہ بن زبیر سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص بنجر زمین کو آباد کرے ت"}
{"hadithnumber": "3075", "text": "ابن اسحاق اسی سند سے اسی مفہوم کی حدیث روایت کرتے ہیں  مگر اس میں «الذي حدثني هذا» کی جگہ یوں ہے، رس"}
{"hadithnumber": "3076", "text": "عروہ کہتے ہیں کہ  میں اس بات کی گواہی دیتا ہوں کہ رسول اللہ صلی اللہ علیہ وسلم نے  ( فیصلہ )  فرمایا"}
{"hadithnumber": "3077", "text": "سمرہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جو شخص کسی بنجر زمین پر دی"}
{"hadithnumber": "3078", "text": "مالک نے خبر دی کہ ہشام بن عروہ کہتے ہیں کہ  ظالم رگ سے مراد یہ ہے کہ ایک شخص کسی غیر کی زمین میں درخ"}
{"hadithnumber": "3079", "text": "ابوحمید ساعدی رضی اللہ عنہ کہتے ہیں کہ  میں رسول اللہ صلی اللہ علیہ وسلم کے ساتھ تبوک  ( جہاد کے لیے"}
{"hadithnumber": "3080", "text": "زینب رضی اللہ عنہا فرماتی ہیں کہ  وہ رسول اللہ صلی اللہ علیہ وسلم کے سر مبارک سے جوئیں نکال رہی تھیں"}
{"hadithnumber": "3081", "text": "معاذ رضی اللہ عنہ کہتے ہیں  جس نے اپنی گردن میں جزیہ کا قلادہ ڈالا  ( یعنی اپنے اوپر جزیہ مقرر کرایا"}
{"hadithnumber": "3082", "text": "ابوالدرداء رضی اللہ عنہ کا بیان ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے جزیہ والی زمین"}
{"hadithnumber": "3083", "text": "صعب بن جثامہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ اور اس کے رسول"}
{"hadithnumber": "3084", "text": "صعب بن جثامہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے نقیع کو چراگاہ بنایا، اور فرما"}
{"hadithnumber": "3085", "text": "ابوہریرہ رضی اللہ عنہ بیان کرتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  دفینہ میں خمس  ( پان"}
{"hadithnumber": "3086", "text": "حسن بصری کہتے ہیں کہ  رکاز سے مراد جاہلی دور کا مدفون خزانہ ہے ۲؎۔"}
{"hadithnumber": "3087", "text": "ضباعۃ بنت زبیر بن عبدالمطلب بن ہاشم سے روایت ہے، وہ کہتی ہیں  مقداد اپنی ضرورت سے بقیع خبخبہ ۱؎ گئے"}
{"hadithnumber": "3088", "text": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  جب ہم رسول اللہ صلی اللہ علیہ وسلم کے ساتھ طائف کی طرف ن"}
