{"hadithnumber": "1658", "arabic": "حَدَّثَنَا مُجَاهِدُ بْنُ مُوسَى، ‏‏‏‏‏‏حَدَّثَنَا الْقَاسِمُ بْنُ مَالِكٍ الْمُزَنِيُّ، ‏‏‏‏‏‏حَدَّ", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 7, Hadith 21", "international_number": "1658", "narrator_chain": ""}
{"hadithnumber": "1659", "arabic": "حَدَّثَنَا حُمَيْدُ بْنُ مَسْعَدَةَ، ‏‏‏‏‏‏حَدَّثَنَا يَزِيدُ بْنُ زُرَيْعٍ، ‏‏‏‏‏‏حَدَّثَنَا خَالِد", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Bukhari'}", "reference": "Book 7, Hadith 22", "international_number": "1659", "narrator_chain": ""}
{"hadithnumber": "1660", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عُمَرَ بْنِ أَبِي عُمَرَ الْمُقْرِئُ، ‏‏‏‏‏‏حَدَّثَنَا إِسْحَاق بْنُ عِيسَ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 7, Hadith 23", "international_number": "1660", "narrator_chain": ""}
{"hadithnumber": "1661", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏عَنْ سُفْيَانَ، ‏‏‏‏‏‏عَنْ مَنْصُ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 7, Hadith 24", "international_number": "1661", "narrator_chain": ""}
