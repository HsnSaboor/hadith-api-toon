hadiths[355]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}: 24758,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہَارُونَ بْنِ أَبِی إِبْرَاہِیمَ ، عَن عَبْدِ اللہِ بْنِ عُبَیْدِ بْنِ عُمَیْرٍ ؛ أَنَّ رَجُلاً سَأَلَہُ عَنِ الأَرْنَبِ ؟ فَقَالَ : لاَ بَأْسَ بِہَا ، قَالَ : إِنَّہَا تَحِیضُ ، قَالَ : إِنَّ الَّذِی یَعْلَمُ حَیْضَہَا یَعْلَمُ طُہْرَہَا ، وَإِنَّمَا ہِیَ حَامِلٌ مِنَ الْحَوَامِلِ۔",,,24758 24759,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ ہِشَامِ بْنِ زَیْدِ بْنِ أَنَسٍ ، عَنْ أَنَسٍ ، قَالَ : سَمِعْتُہُ یَقُولُ : أَنْفَجْنَا أَرْنَبًا بِمَرِّ الظَّہْرَانِ ، فَسَعَی عَلَیْہَا الْغِلْمَانُ حَتَّی لَغِبُوا ، ثُمَّ أَدْرَکْتُہَا ، فَأَتَیْتُ بِہَا أَبَا طَلْحَۃَ فَذَبَحَہَا ، ثُمَّ بَعَثَ مَعِی إِلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِوَرَکِہَا ، فَقَبِلَہَا۔",,,24759 24760,"حَدَّثَنَا وَکِیعٌ ، عَنْ طَلْحَۃَ بْنِ یَحْیَی ، عَنْ مُوسَی بْنِ طَلْحَۃَ ؛ أَنَّ رَجُلاً سَأَلَ عُمَرَ عَنِ الأَرْنَبِ ؟ فَقَالَ عُمَرُ : لَوْلاَ أَنِّی أَکْرَہُ أَنْ أَزِیدَ فِی الْحَدِیثِ ، أَوْ أَنْقُصَ مِنْہُ ، وَسَأُرْسِلُ لَکَ إِلَی رَجُلٍ ، فَأَرْسَلَ إِلَی عَمَّارٍ فَجَائَ ، فَقَالَ : کُنَّا مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَنَزَلْنَا فِی مَوْضِعِ کَذَا وَکَذَا ، قَالَ : فَأَہْدَی إِلَیْہِ رَجُلٌ مِنَ الأَعْرَابِ أَرْنَبًا فَأَکَلْنَاہَا ، فَقَالَ الأَعْرَابِیُّ : إِنِّی رَأَیْتُ دَمًا ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ بَأْسَ۔\n\n(احمد 1/31۔ ابو یعلی 1612)",,,24760 24761,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہَمَّامٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ سَعْدٍ ؛ أَنَّہُ أَکَلَہَا ، قَالَ : فَقُلْت لِسَعِیدٍ : مَا تَقُولُ فِیہَا ؟ قَالَ : کُنْتُ آکُلُہَا۔",,,24761 24762,حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ مُحَمَّدِ بْنِ مُسْلِمٍ ، عَنْ إِبْرَاہِیمَ بْنِ مَیْسَرَۃَ ، عَنْ عُبَیْدِ بْنِ سَعْدٍ ؛ أَنَّ بِلاَلاً رَمَی أَرْنَبًا بِعَصی ، فَکَسَرَ قَوَائِمَہَا ، فَذَبَحَہَا فَأَکَلَہَا۔,,,24762 24763,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنْ الْحَسَن ، قَالَ : کَانَ لاَ یَرَی بِأَکْلِ الأَرْنَبِ بَأْسًا۔",,,24763 24764,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ زَمْعَۃَ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ ، قَالَ : الأَرْنَبُ حَلاَلٌ۔",,,24764 24765,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ أَبِی الْوَسِیمِ ، قَالَ : سَأَلْتُ حَسَنَ بْنَ حَسَنِ بْنِ عَلِیٍّ عَنِ الأَرْنَبِ ؟ فَقَالَ : أَعَافُہَا ، وَلاَ أُحَرِّمُہَا عَلَی الْمُسْلِمِینَ۔",,,24765 24766,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ عَاصِمٍ ، عَنِ الشَّعْبِیِّ ، عَنْ مُحَمَّدِ بْنِ صَیفِی ، قَالَ : أَتَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِأَرْنَبَیْنِ قد َذَبَحْتُہُمَا بِمَرْوَۃَ ، فَأَمَرَنِی بِأَکْلِہِمَا۔",,,24766 24767,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا دَاوُد بْنُ أَبِی ہِنْدٍ ، عَنِ الشَّعْبِیِّ ، عَنْ مُحَمَّدِ بْنِ صَفْوَانَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ مِثْلَ حَدِیثِ أَبِی الأَحْوَص۔",,,24767 24768,حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ؛ أَنَّہُ کَرِہَ أَکْلَہَا۔,,,24768 24769,حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی مَکِینٍ ، عَنْ عِکْرِمَۃَ ؛ أَنَّہُ کَرِہَہَا۔,,,24769 24770,حَدَّثَنَا وَکِیعٌ، عَنْ ہَمَّامٍ، عَنْ قَتَادَۃَ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ، عَنِ ابْنِ عَمْرٍو، أَوِ ابْنِ عُمَرَ؛ أَنَّہُ کَرِہَہَا۔,,,24770 24771,"حَدَّثَنَا یَحْیَی بْنُ وَاضِحٍ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ عَبْدِ الْکَرِیمِ بْنِ أَبِی الْمُخَارِقِ ، عَنْ حِبَّانَ بْنِ جَزْئٍ ، عَنْ أَخِیہِ خُزَیْمَۃَ بْنِ جَزْئٍ ، قَالَ : قُلْتُ : یَا رَسُولَ اللہِ ، جِئْتُکَ لأَسْأَلَکَ عَنْ أَحْنَاشِ الأَرْضِ ، مَا تَقُولُ فِی الأَرْنَبِ ؟ قَالَ : لاَ آکُلُہُ ، وَلاَ أُحَرِّمُہُ ، قُلْتُ : فَإِنِّی آکُلُ مِمَا لَمْ تُحَرِّمْہُ ، وَلِمَ یَا رَسُولَ اللہِ ؟ قَالَ : أُنْبِئْتُ أَنَّہَا تَدْمَی۔ (بخاری 705۔ ابن ماجہ 3245)",,,24771 24772,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی نَافِعٌ ، قَالَ : قِیلَ لابْنِ عُمَرَ : إِنَّ سَعْدًا یَأْکُلُ الضِّبَاعَ ، فَلَمْ یُنْکِرْ ذَلِکَ۔",,,24772 24773,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ بَأْسَ بِأَکْلِہَا ، وَقَالَ : ہِیَ صَیْدٌ۔",,,24773 24774,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی الْمِنْہَالِ نَصْرِ بْنِ أَوْسٍ ، عَنْ عَمِّہِ عَبْدِ اللہِ بْنِ زَیْدٍ ، قَالَ : سَأَلْتُ أَبَا ہُرَیْرَۃَ عَنِ الضَّبُعِ ؟ قَالَ : نَعْجَۃٌ مِنَ الْغَنَمِ۔",,,24774 24775,"حَدَّثَنَا وَکِیعٌ ، عَنْ مَعْقِلٍ ، عَنْ عَطَائٍ ، عَنْ جَابِرٍ ، قَالَ : لضَبُعٌ أَحَبُّ إِلَیَّ مِنْ کَبْشٍ۔",,,24775 24776,"حَدَّثَنَا إِسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ عُبَیْدِ اللہِ بْنِ إِبْرَاہِیمَ الْمَکِّیِّ ، عَنْ مَوْلًی لَہُمْ ، عَنْ جَابِرٍ ، قَالَ : الضَّبُعُ صَیْدٌ فَکُلْہَا ، وَلاَ تَصِدْہَا فِی الْحَرَمِ۔",,,24776 24777,"حَدَّثَنَا یَحْیَی بْنُ وَاضِحٍ ، عَنِ ابْنِ إِسْحَاقَ ، عَنْ عَبْدِ الْکَرِیمِ بْنِ أَبِی الْمُخَارِقِ ، عَنْ حِبَّانَ بْنِ جَزْئٍ ، عَنْ أَخِیہِ خُزَیْمَۃَ بْنِ جَزْئٍ ، قَالَ : قُلْتُ یَا رَسُولَ اللہِ ، مَا تَقُولُ فِی الضَّبُعِ ؟ قَالَ : وَمَنْ یَأْکُلُ الضَّبُعَ ؟۔",,,24777 24778,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، قَالَ : کَانَتِ الْعَرَبُ تَأْکُلُ الضَّبُعَ۔",,,24778 24779,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی ہَارُونَ ، عَنْ أَبِی سَعِیدٍ ، قَالَ : کَانَ أَحَدُنَا لأَنْ یُہْدَی إِلَیْہِ الضَّبُعُ الْمُلَوَّنَۃُ ، أَحَبَّ إِلَیْہِ مِنَ الدَّجَاجَۃِ السَّمِینَۃِ۔",,,24779 24780,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لاَ فَرَعَۃَ ، وَلاَ عَتِیرَۃَ۔ (بخاری 5474۔ مسلم 1562)",,,24780 24781,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ أَبِی ہُرَیْرَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لاَ فَرَعَۃَ ، وَلاَ عَتِیرَۃَ۔\n\nقَالَ الزُّہْرِیُّ : أَمَّا الْفَرَعُ ؛ فَإِنَّہُ أَوَّلُ نِتَاجٍ یُنْتِجُونَہُ مِنْ مَوَاشِیہِمْ یَذْبَحُونَہُ لآلِہَتِہِمْ ، وَالْعَتِیرَۃُ فِی رَجَبٍ۔\n\n(بخاری 5473۔ مسلم 38)",,,24781 24782,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی إِسْحَاقَ ؛ أَنَّ عَلِیًّا ، وَابْنَ مَسْعُودٍ کَانَا لاَ یَرَیَانِ الْعَتِیرَۃَ۔,,,24782 24783,"حَدَّثَنَا وَکِیعٌ ، عَنْ أُسَامَۃَ بْنِ زَیْدٍ ، عَنِ الْقَاسِمِ ، قَالَ : سَأَلْتُہُ عَنِ الْعَتِیرَۃِ ؟ قَالَ : تِلْکَ الرَّجَبِیَّۃُ ذَبَائِحُ أَہْلِ الْجَاہِلِیَّۃِ۔",,,24783 24784,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : سَأَلْتُ الشَّعْبِیَّ عَنِ الْعَتِیرَۃِ ؟ فَقَالَ : جِیرَانُک أَفْعَلُ النَّاسِ لَہَا ، قُلْتُ : مَا ہِیَ ؟ قَالَ : فِی عَشْرٍ بقینَ مِنْ رَجَبٍ۔",,,24784 24785,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُبَارَکٍ ، عَنِ الْحَسَنِ ، قَالَ : الْعَتِیرَۃُ ذَبَائِحُ أَہْلِ الْجَاہِلِیَّۃِ۔",,,24785 24786,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، قَالَ : حَدَّثَنَا ابْنُ عَوْنٍ ، قَالَ : أَنْبَأَنِی أَبُو رَمْلَۃَ ، عَنْ مِخْنَفِ بْنِ سُلَیْمٍ ؛ ذَکَرَ وُقُوفًا مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِعَرَفَۃَ ، فَقَالَ : یَا أَیُّہَا النَّاسُ ، إِنَّ عَلَی کُلِّ بَیْتٍ فِی کُلِّ عَامٍ أَضْحَی وَعَتِیرَۃٌ ، أَتَدْرُونَ مَا الْعَتِیرَۃُ ؟ قَالَ : ہِیَ الَّتِی یُسَمِّیہَا النَّاسُ الرَّجَبِیَّۃُ۔ (ابوداؤد 2781۔ ترمذی 1518)",,,24786 24787,"حَدَّثَنَا مُعَاذٌ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : کَانَ یَذْبَحُ فِی کُلِّ رَجَبٍ ، قَالَ مُعَاذٌ : وَرَأَیْتُ عَتِیرَۃَ ابْنِ عَوْنٍ۔",,,24787 24788,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا دَاوُد بْنُ قَیْسٍ ، قَالَ : حَدَّثَنِی عَمْرُو بْنُ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، قَالَ : سُئِلَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الْفَرَعِ ؟ قَالَ : الْفَرَعُ حَقٌّ ، وَلأَنْ تَتْرُکَہُ حَتَّی یَکُونَ شُغْزُبَا ابْنَ مَخَاضٍ ، أَوِ ابْنَ لَبُونٍ ، فَتَحْمِلَ عَلَیْہِ فِی سَبِیلِ اللہِ ، أَوْ تُعْطِیَہُ أَرْمَلَۃً ، خَیْرٌ مِنْ أَنْ تَذْبَحَہُ تُلْصِقُ لَحْمَہُ بِوَبَرِہِ ، وَتَکْفَء إِنَائَک ، وَتُوَلِّہِ نَاقَتَک۔ \n\nوَسَأَلَہُ عَنِ الْعَتِیرَۃِ ؟ فَسَکَتَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَسَأَلَ بَعْضُ الْقَوْمِ عُمَرَ عَنِ الْعَتِیرَۃِ ؟ فَقَالَ : کُنَّا نُسَمِّیہَا الرَّجَبِیَّۃَ ، وَیَذْبَحُ أَہْلُ الْبَیْتِ الشَّاۃَ فِی رَجَب فَیَأْکُلُونَہَا۔ (ابوداؤد 2835۔ حاکم 236)",,,24788 24789,"حَدَّثَنَا عَفَّانُ ، قَالَ : حَدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، قَالَ : أَخْبَرَنَا عَبْدُ اللہِ بْنُ عُثْمَانَ بْنِ خُثَیْمٍ ، عَنْ یُوسُفَ بْنِ مَاہِکٍ ، عَنْ حفْصَۃَ بِنْتِ عَبْدِ الرَّحْمَنِ ، عَنْ عَائِشَۃَ ؛ أَنَّہَا قَالَتْ : أَمَرَنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِالْفَرَعِ فِی کُلِّ خَمْسِ شِیَاہٍ شَاۃٌ۔ (ابوداؤد 2826۔ عبدالرزاق 7997)",,,24789 24790,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ إِبْرَاہِیمَ بْنِ مَیْسَرَۃَ ، وَابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ ، قَالَ : سُئِلَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الْفَرَعِ ؟ فَقَالَ : فَرِّعُوا إِنْ شِئْتُمْ ، وَأَنْ تُغَذُّوہُ حَتَّی یَبْلُغَ فَتَحْمِلُوا عَلَیْہِ فِی سَبِیلِ اللہِ ، أَوْ تَصِلُوا بِہِ قَرَابَۃً ، خَیْرٌ مِنْ أَنْ تَذْبَحُوا ، یَخْتَلِطُ لَحْمُہُ بِشَعْرِہِ۔",,,24790 24791,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا أَبُو عَوَانَۃَ ، قَالَ : حَدَّثَنَا یَعْلَی بْنُ عَطَائٍ ، عَنْ وَکِیعٍ الْعُقَیْلِیِّ ، عَنْ عَمِّہِ أَبِی رَزِینٍ ، وَہُوَ لَقِیطُ بْنُ عَامِرٍ ؛ أَنَّہُ قَالَ : یَا رَسُولَ اللہِ ، إِنَّا کُنَّا نَذْبَحُ فِی رَجَبٍ ذَبَائِحَ فَنَأْکُلُ مِنْہَا ، وَنُطْعِمُ مَنْ جَائَنَا ؟ فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ بَأْسَ بِذَلِکَ ۔ قَالَ : فَقَالَ وَکِیعٌ : لاَ أَدَعُہَا أَبَدًا۔\n\n(احمد 13۔ دارمی 1965)",,,24791 24792,"حَدَّثَنَا أَبُو خَالِدٍ ، وَوَکِیعٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ فَاطِمَۃَ بِنْتِ الْمُنْذِرِ ، عَنْ أَسْمَائَ بِنْتِ أَبِی بَکْرٍ ، قَالَتْ : نَحَرْنَا فَرَسًا عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَأَکَلْنَا مِنْ لَحْمِہِ ، أَوْ أَصَبْنَا مِنْ لَحْمِہِ۔\n\n(بخاری 5510۔ مسلم 345)",,,24792 24793,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : أَکَلْنَا لُحُومَ الْخَیْلِ یَوْمَ خَیْبَرَ ، وَلُحُومَ الْحُمُرِ الْوَحْشِیَّۃِ۔ (مسلم 1541۔ ابن ماجہ 3191)",,,24793 24794,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ ، قَالَ : أَطْعَمَنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لُحُومَ الْخَیْلِ ، وَنَہَانَا عَنْ لُحُومِ الْحُمُرِ۔ (ترمذی 1793۔ نسائی 4840)",,,24794 24795,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : کَانَ أَصْحَابُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَأْکُلُونَ لُحُومَ الْخَیْلِ فِی مَغَازِیہِمْ۔",,,24795 24796,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : نَحَرَ أَصْحَابُ عَبْدِ اللہِ فَرَسًا فَقَسَمُوہُ بَیْنَہُمْ۔",,,24796 24797,"حَدَّثَنَا سَلاَّمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانَ أَصْحَابُنَا یَأْکُلُونَ لُحُومَ الْخَیْلِ۔",,,24797 24798,حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّ الأَسْوَدَ أَکَلَ لَحْمَ فَرَسٍ۔,,,24798 24799,حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ؛ أَنَّ شُرَیْحًا أَکَلَ لَحْمَ فَرَسٍ۔,,,24799 24800,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : سَأَلْتُ مُحَمَّدًا عَنْ لُحُومِ الْخَیْلِ ؟ فَلَمْ یَرَ بِہَا بَأْسًا۔",,,24800 24801,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ حَجَّاجٍ ، عَنْ عَطَاء ، قَالَ : لاَ بَأْسَ بِہَا۔",,,24801 24802,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : أَدْرَکْتہمْ یَقْتَسِمُونَ لُحُومَ الْخَیْلِ۔",,,24802 24803,"حَدَّثَنَا وَکِیعٌ ، وَعَلِیُّ بْنُ ہَاشِمٍ، عَنِ ابْنِ أَبِی لَیْلَی، عَنِ الْمِنْہَالِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ، قَالَ : سَأَلَہُ رَجُلٌ عَنْ أَکْلِ الْفَرَسِ ؟ وَقَالَ وَکِیعٌ : عَنْ أَکْلِ الْخَیْلِ ، فَقَرَأَ ہَذِہِ الآیَۃَ : {وَالأَنْعَامَ خَلَقَہَا لَکُمْ فِیہَا دِفْئٌ} الآیَۃَ ، قَالَ : فَکَرِہَہَا۔",,,24803 24804,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : لاَ بَأْسَ بِلَحْمِ الْفَرَسِ۔",,,24804 24805,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ مَوْلَی نَافِعِ بْنِ عَلْقَمَۃَ ؛ أَنَّ ابْنَ عَبَّاسٍ کَانَ یَکْرَہُ لُحُومَ الْخَیْلِ ، وَالْبِغَالِ ، وَالْحَمِیرِ ، وَکَانَ یَقُولُ : قَالَ اللَّہُ جَلَّ ثَنَاؤُہُ : {وَالأَنْعَامَ خَلَقَہَا لَکُمْ فِیہَا دِفْئٌ وَمَنَافِعُ وَمِنْہَا تَأْکُلُونَ} فَہَذِہِ لِلْأَکْلِ {وَالْخَیْلَ وَالْبِغَالَ وَالْحَمِیرَ لِتَرْکَبُوہَا} فَہَذِہِ لِلرُّکُوبِ۔",,,24805 24806,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الْکَرِیمِ الْجَزَرِیِّ ، عَنْ عَطَائٍ ، عَنْ جَابِرٍ ، قَالَ : کُنَّا نَأْکُلُ لُحُومَ الْخَیْلِ ، فَأَمَّا الْبِغَالُ فَلاَ۔ (بیہقی 327۔ ابن جریر 83)",,,24806 24807,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الزُّبَیْرِ بْنِ عَدِیٍّ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّہُ کَرِہَ لَحْمَ الْبَغْلِ۔,,,24807 24808,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ مُجَاہِدٍ ؛ أَنَّہُ سُئِلَ عَنْ لُحُومِ الْخَیْلِ ؟ فَقَالَ : {وَالْخَیْلَ وَالْبِغَالَ وَالْحَمِیرَ لِتَرْکَبُوہَا} ، کَأَنَّہُ کَرِہَ لُحُومَہَا۔",,,24808 24809,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ إِبْرَاہِیمَ بْنِ حُمَیْدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ بَأْسَ بَِأْکْلِ لَحْمِ الْبَغْلِ۔",,,24809 24810,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ إِسْحَاقَ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرِو بْنِ ضَمْرَۃَ الْفَزَارِیِّ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی سَلِیطٍ ، عَنْ أَبِیہِ أَبِی سَلِیطٍ ، وَکَانَ بَدْرِیًّا ، قَالَ : لَقَدْ أَتَانَا نَہْیُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ أَکْلِ الْحُمُرِ وَنَحْنُ بِخَیْبَرَ ، وَإِنَّ الْقُدُورَ لَتَفُورُ بِہَا ، فَکَفَأْنَاہَا عَلَی وُجُوہِہَا۔\n\n(طبرانی 580۔ احمد 3/419)",,,24810 24811,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، عَنْ جَابِرٍ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ لُحُومِ الْحُمُرِ۔",,,24811 24812,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ لُحُومِ الْحُمُرالأَہْلِیَّۃِ۔",,,24812 24813,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عَبْدِ اللہِ ، وَالْحَسَنِ ابْنَیْ مُحَمَّدٍ ، عَنْ أَبِیہِمَا ؛ أَنَّ عَلِیًّا قَالَ لابْنِ عَبَّاسٍ : أَمَا عَلِمْت أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی عَنِ الْمُتْعَۃِ ، وَعَنْ لُحُومِ الْحُمُرِ الأَہْلِیَّۃِ۔",,,24813 24814,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْبَرَائِ ، قَالَ : أَصَابَ النَّاسَ یَوْمَ خَیْبَرَ جُوعٌ شَدِیدٌ ، فَأَصَابُوا حُمُرًا أَہْلِیَّۃً ، فَطَبَخُوا مِنْہَا ، فَأَمَرَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِالْقُدُورِ فَأُکْفِئَتْ۔ \n\n(بخاری 4222۔ مسلم 29)",,,24814 24815,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا عُبَیْدُ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ أَنَّہُ نَہَی عَنْ لُحُومِ الْحُمُرِ الأَہْلِیَّۃِ یَوْمَ خَیْبَرَ۔ (بخاری 4218۔ مسلم 24)",,,24815 24816,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ مُعَاوِیَۃَ بْنِ صَالِحٍ ، قَالَ : حدَّثَنِی الْحَسَنُ بْنُ جَابِرٍ ، عَنِ الْمِقْدَامِ بْنِ مَعْدِی کَرْبَ الْکِنْدِیِّ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَرَّمَ أَشْیَائَ ، حَتَّی ذَکَرَ الْحُمُرَ الإِنْسِیَّۃَ۔\n\n(ابوداؤد 4594۔ ترمذی 2664)",,,24816 24817,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا ہِشَامُ بْنُ حَسَّانَ ، عَنْ مُحَمَّدِ بْنِ سِیرِینَ ، عَنْ أَنَسِ بْنِ مَالِکٍ ، قَالَ : لَمَّا کَانَ یَوْمُ خَیْبَرَ ذَبَحَ النَّاسُ الْحُمُرَ ، فَأَغْلَوْا بِہَا الْقُدُورَ ، فَأَمَرَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَبَا طَلْحَۃَ فَنَادَی ، إِنَّ اللَّہَ وَرَسُولَہُ یَنْہَیانکُمْ عَنْ لُحُومِ الْحُمُرِ الأَہْلِیَّۃِ ، فَإِنَّہَا رِجْسٌ ، فَأُکْفِئَتِ الْقُدُورُ۔\n\n(مسلم 34۔ احمد 3/111)",,,24817 24818,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ بْنِ جَابِرٍ ، قَالَ : حَدَّثَنَا الْقَاسِمُ ، وَمَکْحُولٌ ، عَنْ أَبِی أُمَامَۃَ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی یَوْمَ خَیْبَرَ عَنْ أَکْلِ الْحِمَارِ الأَہْلِیِّ۔",,,24818 24819,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، قَالَ : سَأَلْتُ عَبْدَ اللہِ بْنَ أَبِی أَوْفَی عَنْ لُحُومِ الْحُمُرِ الأَہْلِیَّۃِ ؟ فَقَالَ : أَصَابَتْنَا مَجَاعَۃٌ یَوْمَ خَیْبَرَ ، وَنَحْنُ مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَقَدْ أَصَبْنَا لِلْقَوْمِ حُمُرًا خَارِجَۃً مِنَ الْمَدِینَۃِ ، فَنَحَرْنَاہَا ، وَإِنَّ قُدُورَنَا لَتَغْلِی ، إِذْ نَادَی مُنَادِی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ أَنْ أَکْفِئُوا الْقُدُورَ ، وَلاَ تَطْعَمُوا مِنْ لُحُومِ الْحُمُرِ شَیْئًا ، فَقُلْتُ : حَرَّمَہَا تَحْرِیمَ مَاذَا ؟ فَقَالَ : تَحَدَّثْنَا بَیْنَنَا ، فَقُلْنَا : حَرَّمَہَا الْبَتَّۃَ ، وَحَرَّمَہَا مِنْ أَجْلِ أَنَّہَا لَمْ تُخَمَّسْ۔ (بخاری 4220۔ مسلم 1538)",,,24819 24820,حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَرَّمَ یَوْمَ خَیْبَرَ الْحِمَارَ الإِنْسِیَّ۔ (ترمذی 1795۔ احمد 2/366),,,24820 24821,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ یُونُسَ بْنِ أَبِی إِسْحَاقَ ، قَالَ : حدَّثَنَا أَبُو الْوَدَّاکِ ، قَالَ : حَدَّثَنَا أَبُو سَعِیدٍ الْخُدْرِیِّ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ أَنَّہُ مَرَّ بِالْقُدُورِ وَہِیَ تَغْلِی فَقَالَ لَنَا : مَا ہَذِہِ الْحُمُرُ ، أَہْلِیَّۃٌ ، أَمْ وَحْشِیَّۃٌ ؟ فَقُلْنَا : لاَ ، بَلْ أَہْلِیَّۃٌ ، قَالَ : فَأَکْفِؤہَا ، قَالَ : فَأَکْفَأْنَاہَا ، وَإِنَّا لَجِیَاعٌ نَشْتَہِیہِ۔ (ابو یعلی 1178)",,,24821 24822,"حَدَّثَنَا شَرِیکٌ ، عَنْ سَالِمٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : لُحُومُہَا وَأَلْبَانُہَا حَرَامٌ۔",,,24822 24823,"حَدَّثَنَا یَحْیَی بْنُ وَاضِحٍ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ عُمَرَ بْنِ قَتَادَۃَ الظَّفَرِیِّ ، عَنْ سلْمَی بِنْتِ نَصْرٍ ، عَنْ رَجُلٍ مِنْ بَنِی مُرَّۃَ ، قَالَ : أَتَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقُلْتُ : یَا رَسُولَ اللہِ ، إِنَّ جَلَّ مَالِی الْحُمُرُ ، أَفَأُصِیبُ مِنْہَا ؟ قَالَ : أَلَیْسَ تَرْعَی الْفَلاَۃَ ، وَتَأْکُلُ الشَّجَرَ ؟ قُلْتُ : بَلَی ، قَالَ : فَأَصِبْ مِنْہَا۔ (مسند 656)",,,24823 24824,"حَدَّثَنَا شَرِیکٌ ، عَنْ مَنْصُورٍ ، عَنْ عُبَیْدِ بْنِ الْحَسَنِ ، عَنْ غَالِبِ بْنِ ذیخ ، قَالَ : قُلْتُ : یَا رَسُولَ اللہِ ، أَصَابَتْنَا سَنَۃٌ ، وَسَمِینُ مَالِی فِی الْحُمُرِ ، فَقَالَ : کُلْ مِنْ سَمِینِ مَالِکَ ، فَإِنَّمَا قَذِرْتُہَا مِنْ جَوالِّ الْقَرْیَۃِ۔\n\n(ابوداؤد 3803۔ طبرانی 670)",,,24824 24825,"حَدَّثَنَا شَرِیکٌ ، عَنِ الأَعْمَشِ ، عَنِ الْحَکَمِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، قَالَ : إِنَّمَا کُرِہَتْ إِبْقَائً عَلَی الظَّہْرِ ، یَعْنِی لُحُومَ الْحُمُرِ۔",,,24825 24826,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ عُبَیْدِ بْنِ الْحَسَنِ ، عَنِ ابْنِ مَعْقِلٍ ، عَنْ أُنَاسٍ مِنْ مُزَیْنَۃَ الظَّاہِرَۃِ ، قَالَ : قَالَ غَالِبُ بْنُ أَبْجَرَ : سَأَلْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قُلْتُ : لَمْ یَبْقَ مِنْ مَالِی إِلاَّ أَحَمِرَۃٌ ؟ قَالَ : أَطْعِمْ أَہْلَک مِنْ سَمِینِ مَالِکَ ، قَالَ : إِنَّمَا کَرِہْتُ لَکُمْ جَوالَّ الْقَرْیَۃِ۔",,,24826 24827,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ زَیْدِ بْنِ وَہْبٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ حَسَنَۃَ ، قَالَ : کُنْتُ مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی سَفَرٍ فَأَصَبْنَا ضِبَابًا ، فَکَانَتِ الْقُدُورُ تَغْلِی ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَا ہَذَا ؟ فَقُلْنَا : ضِبَابٌ أَصَبْنَاہَا ، قَالَ : إِنَّ أُمَّۃً مِنْ بَنِی إِسْرَائِیلَ مُسِخَتْ ، وَأَنَا أَخْشَی أَنْ تَکُونَ ہَذِہِ ، قَالَ : فَأَکْفَأَہَا وَإِنَّا لَجِیَاعٌ۔ (احمد 4/196۔ ابویعلی 931)",,,24827 24828,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حدَّثَنَا عُبَیْدُ اللہِ بْنُ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : سُئِلَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ عَلَی الْمِنْبَرِ عَنِ الضَّبِّ؟ فَقَالَ: لاَ آکُلُہُ، وَلاَ أُحَرِّمُہُ۔ (مسلم 1542۔ احمد 2/13)",,,24828 24829,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : حدَّثَنَا دَاوُد بْنُ أَبِی ہِنْدٍ ، عَنْ أَبِی نَضْرَۃَ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ، قَالَ: جَائَ رَجُلٌ إِلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقَالَ : إِنَّا بِأَرْضٍ مُضِبَّۃٍ ، فَمَا تَأْمُرُنِی ؟ فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنَّ أُمَّۃً مِنْ بَنِی إِسْرَائِیلَ مُسِخَتْ دَوَابَّ ، وَلاَ أَدْرِی فِی أَیِّ الدَّوَابِّ ہِیَ ، فَلَمْ یَأْمُرْ ، وَلَمْ یَنْہَ۔ (مسلم 50۔ ابن ماجہ 3240)",,,24829 24830,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ زَیْدِ بْنِ وَہْبٍ ، عَنِ الْبَرَائِ بْنِ عَازِبٍ ، عَنْ ثَابِتِ بْنِ وَدِیعَۃَ، قَالَ : أُتِیَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِضَبٍّ ، فَقَالَ : أُمَّۃٌ مُسِخَتْ ، وَاللَّہُ أَعْلَمُ۔\n\n(احمد 4/220۔ طیالسی 1220)",,,24830 24831,"حَدَّثَنَا عُبَیْدُ بْنُ سَعِیدٍ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عَنْ عَائِشَۃَ ، قَالَتْ : أُہْدِیَ لِرَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ضَبٌّ ، فَلَمْ یَأْکُلْ مِنْہُ ، قَالَتْ : فَقُلْتُ : یَا رَسُولَ اللہِ ، أَلاَ أُطْعِمُہُ السُّؤَّالَ ؟ قَالَ : لاَ تُطْعِمِی السُّؤَّالَ إِلاَّ مِمَّا تَأْکُلِینَ۔ (احمد 6/105)",,,24831 24832,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنْ یَزِیدَ بْنِ الأَصَمِّ ، عَنْ مَیْمُونَۃَ زَوْجِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَتْ : أُہْدِیَ لَنَا ضَبٌّ فَصَنَعْتُہُ ، فَدَخَلَ عَلَیْہَا رَجُلاَنِ مِنْ قَوْمِہَا ، فَأَتْحَفَتْہُمَا بِہِ ، فَدَخَلَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُمَا یَأْکُلاَنِ ، فَوَضَعَ یَدَہُ ، ثُمَّ رَفَعَہَا ، فَطَرَحَا مَا فِی أَیْدِیہِمَا ، فَقَالَ لَہُمَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : کُلاَ ، فَإِنَّکُمَا أَہْلُ نَجْدٍ تَأْکُلُونَہَا ، وَإِنَّا أَہْلُ الْمَدِینَۃِ نَعَافُہَا۔\n\n(ابویعلی 7048)",,,24832 24833,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا أَبُو عَوَانَۃَ ، قَالَ : حَدَّثَنَا عَبْدُ الْمَلِکِ بْنُ عُمَیْرٍ ، عَنْ حُصَیْنٍ رَجُلٍ مِنْ بَنِی فَزَارَۃَ ، عَنْ سَمُرَۃََ بْنِ جُنْدُبٍ ، قَالَ : أَتَی نَبِیَّ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَعْرَابِیٌّ وَہُوَ یَخْطُبُ ، فَقَطَعَ عَلَیْہِ خُطْبَتَہُ ، فَقَالَ : یَا رَسُولَ اللہِ ، کَیْفَ تَقُولُ فِی الضَّبِّ ؟ قَالَ : إِنَّ أُمَّۃً مِنْ بَنِی إِسْرَائِیلَ مُسِخَتْ ، فَلاَ أَدْرِی أَیَّ الدَّوَابِّ مُسِخَتْ۔ (طبرانی 2224)",,,24833 24834,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ یَزِیدَ بْنِ الأَصَمِّ ، قَالَ : دَعَانَا عَرُوسٌ بِالْمَدِینَۃِ ، فَقَرَّبَ إِلَیْنَا ثَلاَثَۃَ عَشَرَ ضَبًّا ، فَآکِلٌ وَتَارِکٌ ، فَلَقِیتُ ابْنَ عَبَّاسٍ مِنَ الْغَدِ فَأَخْبَرْتہ ، فَأَکْثَرَ الْقَوْمُ حَوْلَہُ حَتَّی قَالَ بَعْضُہُمْ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ آکُلُہُ ، وَلاَ أَنْہَی عَنْہُ ، وَلاَ أُحِلُّہُ ، وَلاَ أُحَرِّمُہُ ، فَقَالَ ابْنُ عَبَّاسٍ : فَبِئْسَ مَا قُلْتُمْ ، إِنَّمَا بُعِثَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مُحِلاًّ وَمُحَرِّمًا ، بَیْنَمَا ہُوَ عِنْدَ مَیْمُونَۃَ، وَعِنْدَہُ الْفَضْلُ بْنُ عَبَّاسٍ، وَخَالِدُ بْنُ الْوَلِیدِ ، وَامْرَأَۃٌ أُخْرَی ، إِذْ قُرِّبَ إِلَیْہِ خِوَانٌ عَلَیْہِ لَحْمٌ ، فَلَمَّا أَرَادَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یَأْکُلَ ، قَالَتْ لَہُ مَیْمُونَۃُ : إِنَّہُ لَحْمُ ضَبٍّ ، فَکَفَّ یَدَہُ وَقَالَ : إِنَّ ہَذَا اللَّحْمَ لَمْ آکُلْہُ قَطُّ ، وَقَالَ لَہُمْ: کُلُوا، فَأَکَلَ مِنْہُ الْفَضْلُ بْنُ عَبَّاسٍ، وَخَالِدُ بْنُ الْوَلِیدِ، وَالْمَرْأَۃُ، وَقَالَتْ مَیْمُونَۃُ: لاَ آکُلُ إِلاَّ مِنْ شَیْئٍ یَأْکُلُ مِنْہُ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔(مسلم 1545۔ احمد 1/294)",,,24834 24835,"حَدَّثَنَا عَبْدُالرَّحِیمِ بْنُ سُلَیْمَانَ، عَنِ الزِّبْرِقَانِ، قَالَ: أُہْدِیَ لِشَقِیقِ بْنِ سَلَمَۃَ ضَبٌّ مَشْوِیٌّ، فَأَکَلْتُ مِنْہُ۔",,,24835 24836,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : خَرَجَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَخْرَجًا ، فَأَصَابَتْہُمْ مَجَاعَۃٌ ، فَأَتَاہُ رَجُلٌ وَمَعَہُ ضِبَابٌ ، فَأَہْدَاہَا لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَنَظَرَ إِلَیْہَا فَقَالَ : مُسِخَ سِبْطٌ مِنْ بَنِی إِسْرَائِیلَ دَوَابَّ فِی الأَرْضِ ، فَلَمْ یَأْکُلْہُ ، وَلَمْ یَنْہَ عَنْہُ۔",,,24836 24837,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا مِسْعَرٌ ، عَنْ أَبِی عَوْنٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَجَدَ رِیحَ ضَبٍّ فَرَخَّصَ لَہُمْ فِی أَکْلِہِ۔",,,24837 24838,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا مِسْعَرٌ ، عَنْ زِیَادِ بْنِ عِلاَقَۃَ ؛ أَنَّ عُمَرَ رَأَی رَجُلاً حَسَنَ الْجِسْمِ ، فَسَأَلَہُ أَوْ أَخَبَرہُ ، فَقَالَ : مَنْ أَکَلَ الضِّبَابَ ، فَقَالَ عُمَرُ : وَدِدْتُ أَنَّ فِی کُلِّ جُحْرِ ضَبٍّ ضَبَّیْنِ۔",,,24838 24839,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، قَالَ : سُئِلَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الضَّبِّ ؟ فَقَالَ : لاَ آکُلُہُ ، وَلاَ أُحَرِّمُہُ۔ (عبدالرزاق 8673)",,,24839 24840,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا دَاوُدُ ، عَنْ أَبِی نَضْرَۃَ ، قَالَ : قَالَ عُمَرُ : إِنَّ اللَّہَ لَیَنْفَعُ بِالضَّبِّ ، فَإِنَّہُ لَطَعَامُ عَامَّۃِ الرُّعَاۃِ ، وَلَوْ کَانَ عِنْدِی لَطَعِمْتُ مِنْہُ۔",,,24840 24841,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ زِیَادِ بْنِ عِلاَقَۃَ ، عَنْ سَعْدِ بْنِ مَعْبَدٍ ؛ أَنَّ عُمَرَ رَأَی رَجُلاً مِنْ مُحَارِبٍ سَمِینًا فِی عَامِ سَنَۃٍ ، فَقَالَ : مَا طَعَامُکَ ؟ قَالَ : الضِّبَابُ ، قَالَ : وَدِدْتُ أَنَّ فِی کُلِّ جُحْرِ ضَبٍّ ضَبَّیْنِ۔",,,24841 24842,"حَدَّثَنَا وَکِیعٌ، عَنْ شُعْبَۃَ، عَنْ قَتَادَۃَ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ، قَالَ: قَالَ عُمَرُ: ضَبٌّ أَحَبَّ إِلَیَّ مِنْ دَجَاجَۃٍ۔",,,24842 24843,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ تَوْبَۃَ الْعَنْبَرِیِّ ، عَنِ الشَّعْبِیِّ ، قَالَ : سُئِلَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الضَّبِّ ؟ فَقَالَ : حَلاَلٌ لاَ بَأْسَ بِہِ ، وَلَکِنِّی أَعَافُہُ۔",,,24843 24844,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی الْمِنْہَالِ ، عَنْ عَمِّہِ ، قَالَ : سَأَلْتُ أَبَا ہُرَیْرَۃَ عَنِ الضَّبِّ ؟ فَقَالَ : لَسْت بِآکِلِہِ ، وَلاَ زَاجِر عَنْہُ۔",,,24844 24845,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ أَبِی عَوْنٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَجَدَ رِیحَ ضَبٍّ ، فَقَالَ : إِنِّی ، أَوْ إِنَّا مِنْ قَوْمٍ لاَ نَأْکُلُہُ ، وَرَخَّصَ لَہُمْ فِی أَکْلِہِ۔",,,24845 24846,حَدَّثَنَا وَکِیعٌ، عَنْ عَبْدِالْجَبَّارِ بْنِ عَبَّاسٍ، عَنْ عرَیْبٍ الْہَمْدَانِیِّ، عَنِ الْحَارِثِ، عَنْ عَلِیٍّ؛ أَنَّہُ کَرِہَ الضَّبَّ۔,,,24846 24847,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ عَبْدِ الأَعْلَی ، قَالَ : سَأَلْتُ ابْنَ الْحَنَفِیَّۃِ عَنِ الضَّبِّ ؟ فَقَالَ : إِنْ أَعْجَبَکَ فَکُلْہُ۔",,,24847 24848,"حَدَّثَنَا عَبْدَۃُ ، عَنِ الرُّکَیْنِ ، عَنْ عِصْمَۃَ بْنِ رِبْعِیٍّ ، قَالَ : قدِمْنَا عَلَی عُمَرَ وَنَحْنُ أُنَاسٌ سِمَانٌ حَسَنَۃٌ ہَیْئَتُنَا ، قَالَ : فَقَالَ : مَا طَعَامُکُمْ ؟ قُلْنَا : الضِّبَابُ ، قَالَ : فَقَالَ عُمَرُ : وَتُجْزِیکُمْ ؟ قُلْنَا : نَعَمْ ، فَقَالَ : وَدِدْت أَنَّ مَعَ کُلِّ ضَبٍّ ، مِثْلَہُ۔",,,24848 24849,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ سِمَاکٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : جَائَ رَجُلٌ إِلَی ابْنِ عَبَّاسٍ فَقَالَ : آکُلُ الطِّحَالَ ؟ قَالَ : نَعَمْ ، إِنَّمَا حُرِّمَ الدَّمُ الْمَسْفُوحُ۔",,,24849 24850,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ زَکَرِیَّا ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی مَیْسَرَۃَ ، قَالَ : إِنِّی آکُلُ الطِّحَالَ وَمَا یُعْجِبُنِی ، وَلَکِنِّی أَکْرَہُ أَنْ أُحَرِّمَہُ۔",,,24850 24851,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ لاَ یَرَی بِالطِّحَالِ بَأْسًا۔,,,24851 24852,"حَدَّثَنَا عَبْدُالرَّحِیمِ، وَوَکِیعٌ، عَنْ فِطْرٍ، عَنْ مُنْذِرٍ، عَنْ مُحَمَّدِ بْنِ الْحَنَفِیَّۃِ؛ أَنَّہُ کَانَ إِذَا سُئِلَ عَنِ الْجِرِّی، وَالطِّحَالِ ، قَالَ وَکِیعٌ : وَأَشْیَائَ مِمَّا یُکْرَہُ ؟ تَلاَ ہَذِہِ الآیَۃَ : {قُلْ لاَ أَجِدُ فِیمَا أُوحِیَ إِلَیَّ مُحَرَّمًا}۔",,,24852 24853,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، أَوْ غَیْرِہِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ بِالطِّحَالِ۔",,,24853 24854,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ أَبِی جَعْفَرٍ ، عَنْ عَلِیِّ بْنِ أَبِی طَالِبٍ ، قَالَ : کَانَ لاَ یَأْکُلُ الْجِرِّیثَ وَالطِّحَالَ۔",,,24854 24855,"حَدَّثَنَا وَکِیعٌ، عَنْ إِسْرَائِیلَ، عَنْ أَبِی إِسْحَاقَ، عَنِ الْحَارِثِ، عَنْ عَلِیٍّ، قَالَ: الطِّحَالُ لُقْمَۃُ الشَّیْطَانِ۔",,,24855 24856,"حَدَّثَنَا جَرِیرٌ ، عَنْ قَابُوسَ ، عَنْ أَبِیہِ ؛ أَنَّ امْرَأَۃً سَأَلَتْ عَائِشَۃَ قَالَتْ : إِنَّ لَنَا أَظْآرًا مِنَ الْمَجُوسِ ، وَإِنَّہُ یَکُونُ لَہُمُ الْعِیدُ فَیُہْدُونَ لَنَا ؟ فَقَالَتْ : أَمَّا مَا ذُبِحَ لِذَلِکَ الْیَوْمِ فَلاَ تَأْکُلُوا ، وَلَکِنْ کُلُوا مِنْ أَشْجَارِہِمْ۔",,,24856 24857,"حَدَّثَنَا وَکِیعٌ، عَنِ الْحَسَنِ بْنِ حَکِیمٍ، عَنْ أُمِّہِ، عَنْ أَبِی بَرْزَۃَ؛ أَنَّہُ کَانَ لَہُ سُکَّانٌ مَجُوسٌ، فَکَانُوا یُہْدُونَ لَہُ فِی النَّیْرُوزِ وَالْمِہْرَجَانِ ، فَکَانَ یَقُولُ لأَہْلِہِ : مَا کَانَ مِنْ فَاکِہَۃٍ فَکُلُوہُ ، وَمَا کَانَ مِنْ غَیْرِ ذَلِکَ فَرُدُّوہُ۔",,,24857 24858,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ أَبِی وَائِلٍ ، وَإِبْرَاہِیمَ ، قَالاَ : لَمَّا قَدِمَ الْمُسْلِمُونَ أَصَابُوا مِنْ أَطْعِمَۃِ الْمَجُوسِ ؛ مِنْ جُبْنِہِمْ وَمِنْ خُبْزِہِمْ ، فَأَکَلُوا وَلَمْ یَسْأَلُوا عَنْ شَیْئٍ مِنْ ذَلِکَ۔",,,24858 24859,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : کَانَ یَکْرَہُ أَنْ یَأْکُلَ مِمَّا طَبَخَ الْمَجُوسُ فِی قُدُورِہِمْ ، وَلَمْ یَکُنْ یَرَی بَأْسًا أَنْ یَأْکُلَ مِنْ طَعَامِہِمْ مِمَّا سِوَی ذَلِکَ ؛ خُبْزًا ، أَوْ سَمْنًا ، أَوْ کَامِخًا ، أَوْ شِیرَازًا ، أَوْ لَبَنًا۔",,,24859 24860,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ بَأْسَ بِخُبْزِ الْمَجُوسِ۔",,,24860 24861,"حَدَّثَنَا وَکِیعٌ ، عَنْ شَرِیکٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : لاَ تَأْکُلْ مِنْ طَعَامِ الْمَجُوسِ إِلاَّ الْفَاکِہَۃَ۔",,,24861 24862,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، عَنْ أَبِی بَرْزَۃَ ، قَالَ : کُنَّا فِی غَزَاۃٍ لَنَا فَلَقِینَا أُنَاسًا مِنَ الْمُشْرِکِینَ ، فَأَجْہَضْنَاہُمْ عَنْ مَلَّۃٍ لَہُمْ ، فَوَقَعْنَا فِیہَا فَجَعَلْنَا نَأْکُلُ مِنْہَا ، وَکُنَّا نَسْمَعُ فِی الْجَاہِلِیَّۃِ أَنَّہُ مَنْ أَکَلَ الْخُبْزَ سَمِنَ ، فَلَمَّا أَکَلْنَا تِلْکَ الْخُبْزَۃَ جَعَلَ أَحَدُنَا یَنْظُرُ فِی عِطْفَیْہِ ، ہَلْ سَمِنَ ؟۔",,,24862 24863,"حَدَّثَنَا یَزِیدُ ، قَالَ : أَخْبَرَنَا ہِشَامٌ ، عَنِ الْحَسَنِ ، وَمُحَمَّدٍ ، قَالاَ : کَانَ الْمُشْرِکُونَ یَجِیئُونَ بِالسَّمْنِ فِی ظُرُوفِہِمْ ، فَیَشْتَرِیہِ أَصْحَابُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَالْمُسْلِمُونَ فَیَأْکُلُونَہُ ، وَنَحْنُ نَأْکُلُہُ۔",,,24863 24864,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، قَالَ : سَأَلْتُ إِبْرَاہِیمَ عَنِ السَّمْنِ الْجَبَلِیِّ ؟ فَقَالَ : الْعَرَبِیُّ أَحَبَّ إِلَیَّ مِنْہُ ، وَإِنَّا لَنَأْکُلُ مِنَ الْجَبَلِیِّ۔",,,24864 24865,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدِ ؛ أَنَّہُ کَانَ لاَ یَرَی بِالسَّمْنِ الْجَبَلِیِّ بَأْسًا۔,,,24865 24866,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ عَاصِمٍ ، عَنْ أَبِی عُثْمَانَ ، قَالَ : کُنَّا نَأْکُلُ السَّمْنَ ، وَلاَ نَأْکُلُ الْوَدَکَ ، وَلاَ نَسْأَلُ عَنِ الظُّرُوفِ۔",,,24866 24867,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنْ مُحَمَّدٍ ؛ أَنَّ عَامِرَ بْنَ عَبْدِ اللہِ کَانَ یَکْرَہُ مِنَ السَّمْنِ مَا یَجِیئُ مِنْ ہَذَا ، یَعْنِی الْجَبَلَ ، وَلاَ یَرَی بَأْسًا بِمَا یَجِیئُ مِنْ ہَاہُنَا ، یَعْنِی الْبَادِیَۃَ۔,,,24867 24868,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : کَانَ لاَ یَرَی بِأَکْلِ السَّمْنِ الْمَائِیِّ بَأْسًا۔",,,24868 24869,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ أَبِی رَزِینٍ ، قَالَ : کَانُوا یَنْقُلُونَ السَّمْنَ الْجَبَلِیَّ بِمَائِ الْجُبْنِ۔",,,24869 24870,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ حَجَّاجٍ ، عَنْ مَکْحُولٍ ، عَنْ أَبِی إِدْرِیسَ ، عَنْ أَبِی ثَعْلَبَۃَ الْخُشَنِیِّ ، قَالَ : قُلْتُ : یَا رَسُولَ اللہِ ، إِنَّا نَغْزُو أَرْضَ الْعَدُوِّ فَنَحْتَاجُ إِلَی آنِیَتِہِمْ ، قَالَ : اسْتَغْنُوا عنہا مَا اسْتَطَعْتُمْ ، فَإِنْ لَمْ تَجِدُوا غَیْرَہَا فَاغْسِلُوہَا ، وَکُلُوا فِیہَا وَاشْرَبُوا۔ (طبرانی 568)",,,24870 24871,"حَدَّثَنَا إِسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ بُرْدٍ ، عَنْ عَطَائٍ ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ ، قَالَ : کُنَّا نَغْزُو مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَرْضَ الْمُشْرِکِینَ ، فَلاَ نَمْتَنِعُ أَنْ نَأْکُلَ فِی آنِیَتِہِمْ ، وَنَشْرَبَ فِی أَسْقِیَتِہِمْ۔ (ابوداؤد 3834۔ احمد 3/327)",,,24871 24872,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عُرْوَۃَ بْنِ عَبْدِ اللہِ الْقُشَیْرِیِّ أَبِی الْمِنْہَالِ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : کَانَ أَصْحَابُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَظْہَرُونَ عَلَی الْمُشْرِکِینَ ، فَیَأْکُلُونَ فِی أَوْعِیَتِہِمْ ، وَیَشْرَبُونَ فِی أَسْقِیَتِہِمْ۔",,,24872 24873,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانُ ، عَنْ جَابِرِ ، عَنِ عَبْدِ اللہِ بْنِ نُجَیّ ؛ أَنَّ حُذَیْفَۃَ اسْتَسْقَی ، فَأتَاہُ دِہْقَانُ بِبَاطِیَّۃً فِیہَا خَمْرٌ ، فَغَسَلَہَا وَشَرِبَ فِیہَا۔,,,24873 24874,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : کَانُوا یَکْرَہُونَ آنِیَۃَ الْکُفَّارِ ، فَإِنْ لَمْ یَجِدُوا مِنْہَا بُدًّا غَسَلُوہَا وَطَبَخُوا فِیہَا۔",,,24874 24875,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : إِذَا احْتَجْتُمْ إِلَی قُدُورِ الْمَجُوسِ وَآنِیَتِہِمْ ، فَاغْسِلُوہَا وَاطْبُخُوا فِیہَا۔",,,24875 24876,"حَدَّثَنَا وَکِیعٌ ، عَنْ عُمَرَ بْنِ الْوَلِیدِ الشَّنِّی ، قَالَ : سَأَلْتُ سَعِیدَ بْنَ جُبَیْرٍ عَنْ قُدُورِ الْمَجُوسِ ؟ فَقَالَ : اغْسِلْہَا وَاطْبُخْ فِیہَا۔",,,24876 24877,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عُبَیْدِ اللہِ ، عَنِ ابْنِ عَبَّاسٍ ، عَنْ مَیْمُونَۃَ ؛ سُئِلَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ فَأْرَۃٍ وَقَعَتْ فِی سَمْنٍ ، فَمَاتَتْ ؟ فَقَالَ : أَلْقُوہَا وَمَا حَوْلَہَا ، وَکُلُوہُ۔ (بخاری 5538۔ ابوداؤد 3837)",,,24877 24878,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدٍ ، عَنْ أَبِی ہُرَیْرَۃَ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سُئِلَ عَنْ فَأْرَۃٍ مَاتَتْ فِی سَمْنٍ ؟ فَقَالَ : فَأَمَرَ بِہَا أَنْ تُؤْخَذَ وَمَا حَوْلَہَا فَتُطْرَحَ۔ (ابوداؤد 3838)",,,24878 24879,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ مَیْسَرَۃَ ، عَنْ عَلِیٍّ ؛ فِی الْفَأْرَۃِ تَقَعُ فِی السَّمْنِ ، قَالَ : إِنْ کَانَ ذَائِبًا فَأَہْرِقْہُ ، وَإِنْ کَانَ جَامِدًا فَأَلْقِہَا وَمَا حَوْلَہَا ، وَکُلْ بَقِیَّتَہُ۔",,,24879 24880,"حَدَّثَنَا ہُشَیمٌ ، عَنْ یُونُسَ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّ الأَشْعَرِیَّ سُئِلَ عَنْ سَمْنٍ مَاتَ فِیہِ وَزَغٌ ؟ فَقَالَ : بِیعُوہ بَیْعًا ، وَلاَ تَبِیعُوہُ مِنْ مُسْلِمٍ۔",,,24880 24881,"حَدَّثَنَا ہُشَیمٌ ، عَنْ أَبِی بِشْرٍ ، عَنْ نَافِعٍ ؛ أَنَّ جُرَذًا وَقَعَ فِی قِدْرٍ لآلِ ابْنِ عُمَرَ ، فَسُئِلَ ؟ فَقَالَ : انْتَفِعُوا بِہِ ، وَادْہِنُوا بِہِ الأَدَمَ۔",,,24881 24882,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، عَنْ صَفِیَّۃَ بِنْتِ أَبِی عُبَیْدٍ ؛ أَنَّ جَرًّا لآلِ ابْنِ عُمَرَ فِیہِ عِشْرُونَ فَرْقًا مِنْ سَمْنٍ ، أَوْ زِیَادَۃٌ ، وَقَعَتْ فِیہِ فَأْرَۃٌ فَمَاتَتْ ، فَأَمَرَہُمَ ابْنُ عُمَرَ أَنْ یَسْتَصْبِحُوا بِہِ۔,,,24882 24883,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حُمْرَانَ بْنِ أَعْیُنٍ ، عَنْ أَبِی حَرْبِ بْنِ أَبِی الأَسْوَدِ ، قَالَ : سُئِلَ ابْنُ مَسْعُودٍ عَنْ فَأْرَۃٍ وَقَعَتْ فِی سَمْنٍ فَمَاتَتْ ؟ فَقَالَ : إِنَّمَا حَرَّمَ اللَّہُ مِنَ الْمَیْتَۃِ لَحْمَہَا وَدَمَہَا۔",,,24883 24884,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ یَحْیَی بْنِ أَیُّوبَ ، قَالَ : أَخْبَرَنِی أَبُو قُبَیْلٍ ، عَنْ تُبَیعٍ بْنِ امْرَأَۃِ کَعْبٍ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ، قَالَ فِی الزَّیْتِ تَقَعُ فِیہِ الْفَأْرَۃُ ، فَتَمُوتُ : إِنَّہُ لاَ یَحِلُّ أَکْلُہُ لِمُسْلِمٍ ، وَلاَ لِیَہُودِیٍّ ، وَلاَ لِنَصْرَانِیٍّ۔",,,24884 24885,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ جُمَیْلِ بْنِ عُبَیْدٍ الطَّائِیِّ ، قَالَ : حدَّثَنِی ثُمَامَۃُ بْنُ عَبْدِ اللہِ بْنِ أَنَسٍ ، عَنْ جَدِّہِ أَنَسٍ ؛ أَنَّہُ سُئِلَ عَنِ الْفَأْرَۃِ تَقَعُ فِی السَّمْنِ ، أَوِ الزَّیْتِ؟ قَالَ: إِنْ کَانَ جَامِدًا أُخِذَتْ وَمَا حَوْلَہَا فَأُلْقِیَ، وَأُکِلَ مَا بَقِیَ ، وَإِنْ کَانَ ذَائِبًا اسْتَصْبِحُوا بِہِ۔",,,24885 24886,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنْ ثَابِتِ بْنِ الْحَجَّاجِ ، قَالَ : قالَتْ عَائِشَۃُ : إِنْ کَانَ جَامِدًا فَأَلْقِہَا وَمَا یَلِیہَا ، وَکُلْ مَا بَقِیَ ، وَإِنْ کَانَ مَائِعًا فَلاَ تَأْکُلْہُ۔",,,24886 24887,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إذَا وَقَعَ الْجُرَدُ فِی السَّمْنِ الذَّائِبِ فَمَاتَتْ فِیہِ لَمْ یُؤْکَلْ ، وَإِنْ کَانَ جَامِدًا أُلْقِیَ الْجُرَدُ وَمَا حَوْلَہُ ، وأَُکِلَ مَا سِوَی ذَلِکَ۔",,,24887 24888,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنِی یُونُسُ ، أَنَّ الْحَسَنَ وَمُحَمَّدًا ، قَالاَ : لَہُ ذَلِکَ۔",,,24888 24889,حَدَّثَنَا ہُشَیْمٌ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنِ الشَّعْبِیِّ ، مِثْلَ ذَلِکَ۔,,,24889 24890,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : إِنْ کَانَ جَامِدًا فَأَلْقِہَا وَمَا یَلِیہَا وَکُلْ مَا بَقِیَ ، وَإِنْ کَانَ ذَائِبًا فَاسْتَصْبِحْ بِہِ وَلاَ تَأْکُلْہُ۔",,,24890 24891,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ؛ أَنَّ فَأْرَۃً وَقَعَتْ فِی زَیْتٍ ، فَسَأَلُوا النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ فَقَالَ : اسْتَصْبِحُوا بِہِ وَلاَ تَأْکُلُوہُ ۔ وَکَانَ مَکْحُولٌ یَقُولُ : إذَا وَقَعَتْ فِی السَّمْنِ ، فَکَانَ جَامِدًا أُلْقِیَ وَمَا حَوْلَہُ وَأُکِلَ مَا سِوَی ذَلِکَ ، وَإِنْ کَانَ ذَائِبًا لَمْ یُؤْکَلْ مِنْہُ شَیْئٌ۔",,,24891 24892,حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ سِمَاکٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ سُئِلَ عَنْ فَأْرَۃٍ وَقَعَتْ فِی سَمْنٍ جَامِدٍ ؟ فَأَمَرَ أَنْ یُلْقَی مَا حَوْلَہَا ، وَیُؤْکَلُ بَقِیَّتُہُ۔,,,24892 24893,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا أَبُو حَمْزَۃَ ، قَالَ : سَمِعْتُ ابْنَ عَبَّاسٍ وَسُئِلَ عَنِ الْجُبْنِ ؟ قَالَ : ضَعِ السِّکِّینَ فِیہِ ، وَاذْکُرِ اسْمَ اللہِ ، وَکُلْ۔",,,24893 24894,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی حَیَّانَ الأَزْدِیِّ ، قَالَ ، سَأَلْتُ ابْنَ عُمَرَ عَنِ الْجُبْنِ ؟ فَقَالَ : مَا یَأْتِینَا مِنَ الْعِرَاقِ شَیْئٌ ہُوَ أَعْجَبُ إِلَیْنَا مِنْہُ۔",,,24894 24895,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ قَرْظَۃَ ، قَالَ : قَالَ عُمَر : کُلُوا الْجُبْنَ فَإِنَّہ لَبَأٌ وَلَبَنٌ۔",,,24895 24896,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ تَمْلِکَ ، قَالَتْ : سَأَلْتُ أُمَّ سَلَمَۃَ ؟ فَقَالَتْ : ضَعِی فِیہِ سِکِّینَکِ ، وَاذْکُرِی اسْمَ اللہِ جَلَّ وَعَزَّ ، وَکُلِی۔",,,24896 24897,"حَدَّثَنَا سَلاَّمٌ ، عَنْ سَعِیدِ بْنِ مَسْرُوقٍ ، عَنْ مُنْذِرٍ ، عَنِ ابْنِ الْحَنَفِیَّۃِ ، قَالُوا : کُلُوا الْجُبْنَ عَرْضًا۔",,,24897 24898,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ رَبِیعَۃَ ، عَنْ خَالَتِہِ ، قَالَتْ : جَائَنَا جُبْنٌ مِنَ الْعِرَاقِ ، فَأَرْسَلَتْ إِلَی عَائِشَۃَ ، فَقَالَتْ : کُلِی وَأَطْعِمِینِی۔",,,24898 24899,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : حدَّثَنَا مُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَتَبَ عُمَرُ : اُذْکُرُوا اسْمَ اللہِ عَلَی الْجُبْنِ وَکُلُوا ، قَالَ إبْرَاہِیمُ : فَلَمَّا سَافَرْنَا إلَی ہَذِہِ الْجِبَالِ فَرَأَیْنَا مِنْ صَنِیعِ الأَعَاجِمِ مَا رَأَیْنَا کَرِہْنَاہُ ، إِلاَّ أَنْ نسْأَلَ عَنْہُ۔",,,24899 24900,"حَدَّثَنَا عَبِیدَۃُ بْنُ حُمَیْدٍ ، عَنْ مَنْصُورٍ ، عَنْ عُبَیْدِ بْنِ أَبِی الْجَعْدِ ، عَنْ قَیْسِ بْنِ السَّکَنِ ، قَالَ : قَالَ عَبْدُ اللہِ : لاَ تَأْکُلُوا مِنَ الْجُبْنِ إِلاَّ مَا صَنَعَ الْمُسْلِمُونَ وَأَہْلُ الْکِتَابِ۔",,,24900 24901,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی جَعْفَرٍ الرَّازِیّ ، عَنِ الرَّبِیعِ ، عَنْ أَبِی الْعَالِیَۃِ ، عَنْ سُوَیْد ، غُلاَمٍ کَانَ لِسَلْمَانَ وَأَثْنَی عَلَیْہِ خَیْرًا ، قَالَ : لَمَّا افْتَتَحْنَا الْمَدَائِنَ خَرَجَ النَّاسُ فِی طَلَبِ الْعَدُوِّ ، قَالَ : قَالَ سَلْمَانُ : وَقَدْ أَصَبْنَا سَلَّۃً ، فَقَالَ : افْتَحُوہَا فَإِنْ کَانَ طَعَامًا أَکَلْنَاہُ ، وَإِنْ کَانَ مَالاً دَفَعْنَاہُ إِلَی ہَؤُلاَئِ ، قَالَ : فَفَتَحْنَاہَا فَإِذَا أَرْغِفَۃٌ حُوَّارَی ، وَإِذَا جُبْنَۃٌ وَسِکِّینٌ ، قَالَ : وَکَانَ أَوَّلُ مَا رَأَتِ الْعَرَبُ الْحُوَّاری ، فَجَعَلَ سَلْمَانُ یَصِفُ لَہُمْ کَیْفَ یُعْمَلُ ، ثُمَّ أَخَذَ السِّکِّینَ وَجَعَلَ یَقْطَعُ ، وَقَالَ : بِسْمِ اللہِ کُلُوا۔",,,24901 24902,"حَدَّثَنَا أَبُو أُسَامَۃَ، عَنْ ہِشَامٍ، عَنِ الْحَسَنِ، وَابْنِ سِیرِینَ، قَالاَ: لاَ بَأْسَ بِمَا صَنَعَ أَہْلُ الْکِتَابِ مِنَ الْجُبْنِ۔",,,24902 24903,"حَدَّثَنَا عَبَّادٌ ، عَنْ عَبْدِ الْمَلِکِ ، قَالَ : سَأَلْتُ سَعِیدَ بْنَ جُبَیْرٍ عَنِ الْجُبْنِ ؟ فَقَالَ : مَا صَنَعَ الْمُسْلِمُونَ وَأَہْلُ الْکِتَابِ۔",,,24903 24904,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَبْدِ الْمَلِکِ ، قَالَ : سَمِعْتُ سَعِیدَ بْنَ جُبَیْرٍ یَقُولُ : لاَ تَأْکُلْ مِنَ الْجُبْنِ إِلاَّ مَا صَنَعَ الْمُسْلِمُونَ ، وَالْیَہُودُ ، وَالنَّصَارَی ، فَأَمَّا الْمَجُوسُ فَلاَ تَحِلُّ لَنَا ذَبَائِحُہُمْ ، فَکَیْفَ یَحِلُّ لَنَا جُبْنُہُمْ ؟۔",,,24904 24905,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ أَبِی وَائِلٍ ، وَإِبْرَاہِیمَ ، قَالاَ : لَمَّا قَدِمَ الْمُسْلِمُونَ أَصَابُوا مِنْ أَطْعِمَۃِ الْمَجُوسِ ، مِنْ خُبْزِہِمْ وَجُبْنِہِمْ ، فَأَکَلُوا وَلَمْ یَسْأَلُوا عَنْ ذَلِکَ ، وَوُصِفَ الْجُبْنُ لِعُمَرَ ، فَقَالَ : اُذْکُرُوا اسْمَ اللہِ عَلَیْہِ ، وَکُلُوہُ۔",,,24905 24906,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لَمَّا أَتَیْنَا الْجَبَلَ فَرَأَیْنَا صَنِیعَہُمْ ،کَرِہْنَاہُ۔",,,24906 24907,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ أُمِّ مُوسَی ، عَنْ عَلِیٍّ ، قَالَ : إِذَا لَمْ تَدْرُوا مَنْ صَنَعَہُ ، فَاذْکُرُوا اسْمَ اللہِ عَلَیْہِ ، وَکُلُوہُ۔",,,24907 24908,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ شَقِیقٍ ، عَنْ عَمْرِو بْنِ شُرَحْبِیلَ ، قَالَ : ذَکَرْنَا الْجُبْنَ عِنْدَ عُمَرَ، فَقُلْنَا لَہُ : إِنَّہُ یُصْنَعُ فِیہِ أَنَافِح الْمَیْتَۃِ ، فَقَالَ : سَمُّوا عَلَیْہِ وَکُلُوہُ۔",,,24908 24909,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَحْشٍ ، عَنْ مُعَاوِیَۃَ بْنِ قُرَّۃَ ، عَنِ الْحَسَنِ بْنِ عَلِیٍّ ؛ أَنَّہُ سُئِلَ عَنِ الْجُبْنِ ؟ فَقَالَ : لاَ بَأْسَ بِہِ ، ضَعِ السِّکِّینَ ، وَاذْکُرِ اسْمَ اللہِ عَلَیْہِ وَکُلْ۔",,,24909 24910,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ عَمْرِو بْنِ عُثْمَانَ ، عَنْ مُوسَی بْنِ طَلْحَۃَ ، قَالَ : سَمِعْتُہُ یَذْکُرُ : أَنَّ طَلْحَۃَ کَانَ یَضَعُ السِّکِّینَ ، وَیَذْکُرُ اسْمَ اللہِ ، وَیَقْطَعُ وَیَأْکُلُ۔",,,24910 24911,"حَدَّثَنَا حَفْصٌ ، عَنِ الزِّبْرِقَانِ ، عَنْ أَبِی رَزِینٍ ، قَالَ : لاَ بَأْسَ بِالْجُبْنِ۔",,,24911 24912,"حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، عَنْ عُمَارَۃَ ، عَنْ أَبِی بَکْرِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ الْحَارِثِ ، قَالَ : کَانُوا یَتَزَوَّدُونَ الْجُبْنَ فِی أَسْفَارِہِمْ۔",,,24912 24913,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ عَمْرِو بْنِ مَنْصُورٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : أُتِیَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی غَزْوَۃِ تَبُوکَ بِجُبْنَۃٍ ، فَقِیلَ : إِنَّ ہَذَا طَعَامٌ یَصْنَعُہُ الْمَجُوسُ ، فَقَالَ : اُذْکُرُوا اسْمَ اللہِ عَلَیْہِ ، وَکُلُوہُ۔\n\n(ابوداؤد 3815)",,,24913 24914,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ سَالِمٍ ؛ أَنَّہُ کَانَ یَأْکُلُ الْجُبْنَ الْکُوفِیَّ۔,,,24914 24915,"حَدَّثَنَا وَکِیعٌ ، عَنْ عُثْمَانَ الشَّحَّامِ ، قَالَ : حدَّثَنَا النَّوْشَجَانُ أَبُو الْمُغِیرَۃِ ، قَالَ : سَأَلْتُ ابْنَ عَبَّاسٍ عَنِ الْجُبْنِ ؟ فَقَالَ : مَا یَأْتِینَا مِنَ الْعِرَاقِ فَاکِہَۃ أَعْجَبُ إِلَیْنَا مِنَ الْجُبْنِ۔",,,24915 24916,"حَدَّثَنَا عَبِیدَۃُ بْنُ حُمَیْدٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ سَعِیدِ بْنِ عُبَیْدَۃَ ، قَالَ : سَأَلَ رَجُلٌ ابْنَ عُمَرَ عَنِ الْجُبْنِ ؟ فَقَالَ لَہُ ابْنُ عُمَرَ : وَمَا الْجُبْنُ ؟ قَال : مِن اللَّبَن ، فَقَالَ لَہُ ابْنُ عُمَرَ : کُلِ الْجُبْنَ وَاشْرَبْہُ ، فَقَالَ : إِنَّ فِیہِ مَیْتَۃً ؟ فَقَالَ لَہُ ابْنُ عُمَرَ : فَلاَ تَأْکُلِ الْمَیْتَۃَ۔",,,24916 24917,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، عَنْ عَلِیٍّ الأَزْدِیِّ ، قَالَ : قُلْتُ لابْنِ عُمَرَ : إِنَّا نُسَافِرُ فَنَمُرُّ بِالرُّعْیَانِ ، وَالصَّبِیِّ ، وَالْمَرْأَۃِ ، فَیُطْعِمُونَا لَحْمًا مَا نَدْرِی مَا جِنْسہ ؟ فَقَالَ : مَا أَطْعَمَکَ الْمُسْلِمُونَ فَکُلْ۔",,,24917 24918,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنَ ، عَنْ سَعِیدِ بْنِ أَبِی سَعِیدٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : إِذَا دَخَلْتَ عَلَی أَخِیکَ الْمُسْلِمِ فَأَطْعَمَک طَعَامًا فَکُلْ وَلاَ تَسْأَلْ ، فَإِنْ سَقَاکَ شَرَابًا فَاشْرَبْ وَلاَ تَسْأَلْ ، فَإِنْ رَابَکَ مِنْہُ شَیْئٌ فَشُجَّہُ بِالْمَائِ۔",,,24918 24919,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عُمَرَ الأَنْصَارِیِّ ، قَالَ : سَمِعْتُ أَنَسَ بْنَ مَالِکٍ یَقُولُ : إِذَا دَخَلْتَ عَلَی رَجُلٍ لاَ تَتَّہِمُہُ فِی بَطْنِہِ ، فَکُلْ مِنْ طَعَامِہِ ، وَاشْرَبْ مِنْ شَرَابِہِ۔",,,24919 24920,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِبْرَاہِیمَ بْنِ إِسْمَاعِیلَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : مَا وَجَدْتَ فِی بَیْتِ الْمُسْلِمِ ، فَکُلْ۔",,,24920 24921,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، قَالَ : دَخَلْنَا عَلَی رَاعٍ دَعَانَا لِطَعَامٍ ، وَأَتَانَا بِنَبِیذٍ فَکَرِہْتُہُ ، فَأَخَذَہُ عَلِیٌّ ، قَالَ أَبُو بَکْرٍ : یَنْبَغِی أَنْ یَکُونَ ابْنُ الْحُسَیْنِ بْنُ عَلِیٍّ فَشَرِبَہُ ، وَقَالَ : إِذَا دَخَلْتَ عَلَی أَخِیکَ الْمُسْلِمِ فَکُلْ مِنْ طَعَامِہِ ، وَاشْرَبْ مِنْ شَرَابِہِ۔",,,24921 24922,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُوسَی بْنِ عُمَیْرٍ ، قَالَ : سَمِعْتُ الشَّعْبِیَّ یَقُولُ : إِذَا دَخَلْتَ بَیْتَ مُسْلِمٍ فَکُلْ مِنْ طَعَامِہِ ، وَاشْرَبْ مِنْ شَرَابِہِ۔",,,24922 24923,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، قَالَتْ : قالُوا : یَا رَسُولَ اللہِ ، إِنَّ الأَعْرَابَ یَأْتُونَنَا بِلَحْمٍ لاَ نَدْرِی مَا ہُوَ ، ذُکِرَ اسْمُ اللہِ عَلَیْہِ ، أَمْ لاَ ؟ فَقَالَ : سَمُّوا عَلَیْہِ ، وَکُلُوہُ۔ (بخاری 2057۔ دارمی 1976)",,,24923 24924,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، سَمِعَ أَبَا بَکْرِ بْنَ عُبَیْدِ اللہِ بن عَبْدِ اللہِ ، یُخْبِرُ عَنْ جَدِّہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إِنَّ الشَّیْطَانَ یَأْکُلُ بِشِمَالِہِ وَیَشْرَبُ بِشِمَالِہِ ، فَإِذَا أَکَلَ أَحَدُکُمْ فَلْیَأْکُلْ بِیَمِینِہِ ، وَلِیَشْرَبْ بِیَمِینِہِ۔ (مسلم 105۔ ابوداؤد 3770)",,,24924 24925,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا ہِشَامُ بْنُ حَسَّانَ ، عَنْ عَبْدِ اللہِ بْنِ دِہْقَانَ ، عَنْ أَنَسِ بْنِ مَالِکٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِذَا أَکَلَ أَحَدُکُمْ فَلْیَأْکُلْ بِیَمِینِہِ ، وَلْیَشْرَبْ بِیَمِینِہِ ، فَإِنَّ الشَّیْطَانَ یَأْکُلُ بِشِمَالِہِ ، وَیَشْرَبُ بِشِمَالِہِ۔ (احمد 3/202۔ ابویعلی 4256)",,,24925 24926,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ، عَنْ عَبْدِالْمَلِکِ، عَنْ عُبَیْدِ بْنِ سَلْمَان، عَنِ الضَّحَّاکِ بْنِ مُزَاحِمٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ : لاَ تَأْکُلُوا بِشَمَائِلِکُمْ ، وَلا تَشرَبُوا بِشَمَائِلِکُمْ ، فَإِنَّ آدَمَ أَکَلَ بِشِمَالِہِ وَنَسِیَ ، فَأَوْرَثَہُ ذَلِکَ النِّسْیَانَ۔",,,24926 24927,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الْوَلِیدِ بْنِ کَثِیرٍ ، عَنْ وَہْبِ بْنِ کَیْسَانَ ، سَمِعَہُ مِنْ عُمَرَ بْنِ أَبِی سَلَمَۃَ ، قَالَ : کُنْتُ غُلاَمًا فِی حِجْرِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَکَانَتْ یَدِی تَطِیشُ فِی الصَّحْفَۃِ ، فَقَالَ لِی : یَا غُلاَمُ ، سَمِّ اللَّہَ ، وَکُلْ بِیَمِینِکَ ، وَکُلْ مِمَّا یَلِیکَ۔ (بخاری 5376۔ مسلم 108)",,,24927 24928,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ ہِشَامِ بن عُروَۃَ ، عْن أَبِیہِ ، عَنْ أَبِی وَجْزَۃَ السَّعْدِیِّ ، عَن رَجُلٍ مِنْ مُزَیْنَۃَ ، عَن عُمَرَ بْنِ أَبِی سَلَمَۃَ ، قَالَ : دَخَلتُ عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ یَأْکُل ، فَقَالَ : اجْلِسْ یَابُنَی ، وَقُلْ : بِسْمِ اللہِ ، وَکُلْ بِیَمِینِکَ ، وَکُلْ مِمَّا یَلِیکَ۔ (ابوداؤد 3771۔ نسائی 6756)",,,24928 24929,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ الْقَطَّانُ ، عَنْ عُمَارَۃَ بْنِ مُطَرِّفٍ ، عَنْ بُرَیْد بْنِ أَبِی مَرْیَمَ ، عْن أَبِیہِ ، قَالَ : رَأَی عُمَرُ بْنُ الْخَطَّابِ رَجُلاً وَقَدْ ضَرَبَ بِیَدِہِ الْیُسْرَی لِیَأْکُلَ بِہَا، قَالَ: لاَ، إِلاَّ أَنْ تَکُونَ یَدُکَ عَلِیلَۃً، أَوْ مُعْتَلَّۃً۔",,,24929 24930,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ جَابِرِ بْنِ صُبْحٍ ، عَنْ عُبَیْدِ اللہِ بْنِ أَبِی جَرْوَۃَ ، عَنْ عَمَّتِہِ ؛ أَنَّ عَائِشَۃَ رَأَتِ امْرَأَۃً تَأْکُلُ بِشِمَالِہَا ، فَنَہَتْہَا۔,,,24930 24931,"حَدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : شَرِبْتُ عِنْدَ مُحَمَّدٍ بِشِمَالِی ، فَلَمْ یَنْہَنِی۔",,,24931 24932,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ عِکْرِمَۃَ بْنِ عَمَّارٍ ، عَنْ إِیَاسِ بْنِ سَلَمَۃَ ؛ أَنَّ أَبَاہُ حَدَّثَہُ : أَنَّ رَجُلاً أَکَلَ عِنْدَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِشِمَالِہِ ، فَقَالَ : کُلْ بِیَمِینِکَ ، قَالَ : لاَ أَسْتَطِیعُ ، قَالَ : لاَ اسْتَطَعْتَ ، مَا مَنَعَہُ إِلاَّ الْکِبْرُ ، قَالَ : فَمَا رَفَعَہَا إِلَی فِیہِ۔ (مسلم 107۔ احمد 4/45)",,,24932 24933,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ أَبِی سُلَیْمَانَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یَأْکُلَ أَحَدُنَا بِشِمَالِہِ۔ (مسلم 104۔ ابوداؤد 4134)",,,24933 24934,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی سُفْیَانَ ، عَنْ جَابِرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِذَا طَعِمَ أَحَدُکُمْ فَلاَ یَمْسَحْ یَدَہُ حَتَّی یَمُصَّہَا ، فَإِنَّہُ لاَ یَدْرِی فِی أَیِّ طَعَامِہِ یُبَارَکُ لَہُ فِیہِ۔\n\n(مسلم 1607۔ ابن ماجہ 3270)",,,24934 24935,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو بْنِ دِینَار ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِذَا أَکَلَ أَحَدُکُمْ طَعَامًا ، فَلاَ یَمْسَحْہَا حَتَّی یَلْعَقَہَا ، أَوْ یُلْعِقَہَا۔ (بخاری 5456۔ مسلم 129)",,,24935 24936,"حَدَّثَنَا سُوَیْد بْنُ عَمْرٍو ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ ثَابِتٍ ، عَنْ أَنَسٍ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إِذَا أَکَلَ لَعِقَ أَصَابِعَہُ الثَّلاَثَ ، وَقَالَ : أَمَرَنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ نَسْلُتَ الصَّحْفَۃَ ، وَقَالَ : إِنَّ أَحَدَکُمْ لاَ یَدْرِی فِی أَیِّ طَعَامِہِ یُبَارَکُ لَہُ فِیہِ۔ (مسلم 1607۔ ابوداؤد 3841)",,,24936 24937,"حَدَّثَنَا ابْنُ مَہْدِیٍّ، عَنْ سُفْیَانَ ، عَنْ سَعْدِ بْنِ إِبْرَاہِیمَ ، عَن عَبْدِ الرَّحْمَنِ بْنِ کَعْبِ بْنِ مَالِکٍ، عَنْ أَبِیہِ، قَالَ : رَأَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لَعِقَ أَصَابِعَہُ الثَّلاَثَ مِنَ الطَّعَامِ۔ (مسلم 131۔ نسائی 6752)",,,24937 24938,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ سَالِمٍ ، عَنْ عَطَائٍ ، قَالَ : قَالَ عُمَرُ : لاَ یَصْلُحُ لِمُسْلِمٍ إِذَا أَکَلَ طَعَامًا أَنْ یَمْسَحَ یَدَہُ حَتَّی یَلْعَقَہَا ، أَوْ یُلْعِقَہَا۔",,,24938 24939,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حُصَیْنٌ ، عَنْ مُجَاہِدٍ ، قَالَ : مَا رَأَیْتُ ابْنَ عُمَرَ یَتَوَضَّأُ مِنْ طَعَامٍ قَطُّ ، وَکَانَ یَلْعَقُ أَصَابِعَہُ الثَّلاَثَ ، ثُمَّ یَمْسَحُ یَدَہُ بِالتُّرَابِ۔",,,24939 24940,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ إِسْمَاعِیلَ بْنِ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : کَانَ أَصْحَابُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إِذَا قُرِّبَ الطَّعَامُ لاَ یَمْسَحُونَ أَیْدِیَہُمْ ، حَتَّی یُنَقُّوہَا بِاللَّعْقِ۔",,,24940 24941,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، قَالَ : قُلْتُ لِعُبَیْدِ اللہِ بْنِ أَبِی یَزِیدَ : کُنْتَ تَشْہَدُ طَعَامَ ابْنِ عَبَّاسٍ ؟ قَالَ : نَعَمْ ، قُلْتُ : فَأَیْش کُنْتَ تَرَاہُ یَصْنَعُ ؟ قَالَ : کُنْتُ أَرَاہُ یَلْعَقُ أَصَابِعَہُ الثَّلاَثَ۔",,,24941 24942,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَمَرَ بِلَعْقِ الأَصَابِعِ وَالصَّحْفَۃِ ، وَقَالَ : إِنَّکُمْ لاَ تَدْرُونَ فِی أَیِّہِ الْبَرَکَۃُ۔ (مسلم 133)",,,24942 24943,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی صَالِحٍ ، وَأَبِی سُفْیَانَ ، عَنْ جَابِرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِذَا فَرَغَ أَحَدُکُمْ مِنْ طَعَامِہِ ، فَلْیَلْعَقْ أَصَابِعَہُ ، فَإِنَّہُ لاَ یَدْرِی فِی أَیِّ طَعَامِہِ یُبَارَکُ لَہُ۔\n\n(مسلم 136)",,,24943 24944,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَلْعَقُ أَصَابِعَہُ الثَّلاَثَ إِذَا أَکَلَ ، وَقَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنَّہُ لاَ یَدْرِی فِی أَیِّ طَعَامِہِ الْبَرَکَۃُ۔ (احمد 2/7)",,,24944 24945,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی سُفْیَانَ ، عَنْ جَابِرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِذَا وَقَعَتِ اللُّقْمَۃُ مِنْ یَدِ أَحَدِکُمْ ، فَلْیَمْسَحْ مَا عَلَیْہَا مِنَ الأَذَی وَلْیَأْکُلْہَا۔\n\n(مسلم 1607۔ ابن ماجہ 3279)",,,24945 24946,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ حُمَیْدٍ ، عَنْ أَنَسٍ ؛ أَنَّ لُقْمَۃً سَقَطَتْ مِنْ یَدِہِ فَطَلَبَہَا حَتَّی وَجَدَہَا ، وَقَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِذَا سَقَطَتْ لُقْمَۃُ أَحَدِکُمْ ، فَلْیُمِطْ مَا عَلَیْہَا ، ثُمَّ لِیَأْکُلْہَا ، وَلاَ یَدَعْہَا لِلشَّیْطَانِ۔ (احمد 100)",,,24946 24947,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِذَا وُضِعَ الطَّعَامُ فَکُلُوا مِنْ حَافَّتِہِ وَدَعُوا وَسَطَہُ ، فَإِنَّ البَرَکَۃَ تَنْزِلُ فِی وَسَطِہِ۔ (ابوداؤد 3766۔ ترمذی 1805)",,,24947 24948,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِید ، عَن مِقْسَمٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إِذَا وُضِعَتِ القَصْعَۃُ ، فَکُلُوا مِنْ حَوَالِیْہَا ، وَذَرُوا ذِرْوَتَہَا ، فَإِنَّ فِی ذِرْوَتِہَا الْبَرَکَۃُ۔",,,24948 24949,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ سَعِیدِ بْنِ حُوَیْرِثٍ ، سَمِعْت ابْنَ عَبَّاسٍ یَقُولُ : کُنَّا عِنْدَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَجَائَ مِنَ الْغَائِطِ وَأُتِیَ بِطَعَامٍ ، فَقِیلَ لَہُ : أَلاَ تَتَوَضَّأُ ؟ قَالَ : لَمْ أُصَلِّ فَأَتَوَضَّأَ۔\n\n(مسلم 119۔ احمد 1/221)",,,24949 24950,"حَدَّثَنَا حَفْصٌ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، قَالَ : خَرَجَ عُمَرُ بْنُ الْخَطَّابِ مِنَ الْخَلاَئِ وَأُتِیَ بِطَعَامٍ ، فَقَالُوا : نَدْعُو بِوَضُوئٍ ، فَقَالَ : إِنَّمَا آکُلُ بِیَمِینِی ، وَأَسْتَطِیبُ بِشِمَالِی ، فَأَکَلَ وَلَمْ یَمَسَّ مَائً۔",,,24950 24951,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ سَالِمِ بْنِ أَبِی الْجَعْدِ ، عَنْ أَبِیہِ ؛ أَنَّ ابْنَ مَسْعُودٍ دَعَا رَجُلاً إِلَی طَعَامِہِ ، فَقَالَ : إِنِّی قَدْ بُلْتُ ، قَالَ : إِنَّک لَمْ تَبُلْ فِی یَدِک۔",,,24951 24952,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ شُعْبَۃَ ، عَنْ مَنْصُورٍ ، عَنْ سَالِمِ بْنِ أَبِی الْجَعْدِ ، عَنْ أَبِیہِ ، قَالَ : دَعَا عَبْدُ اللہِ رَجُلاً إِلَی طَعَامِہِ ، فَقَالَ : إِنِّی قَدْ بُلْتُ ، قَالَ : بَوْلُک لَیْسَ فِی یَدِک۔",,,24952 24953,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ مُحَمَّدِ بْنِ عَبْدِ اللہِ بْنِ أَخِی الزُّہْرِیِّ ، قَالَ : أَخْبَرَتْنِی أُخْتِی ؛ أَنَّہَا رَأَتِ الزُّہْرِیَّ یَأْکُلُ بِخَمْسٍ ، فَسَأَلَتْہُ عَنْ ذَلِکَ ؟ فَقَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَأْکُلُ بِالْخَمْسِ۔",,,24953 24954,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ خَالِدِ بْنِ أَبِی بَکْرٍ ، قَالَ : رَأَیْتُ الْقَاسِمَ ، وَسَالِمًا یَأْکُلاَنِ بِثَلاَثِ أَصَابِعَ۔",,,24954 24955,حَدَّثَنَا عَبْدَۃُ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنِ ابْنٍ لِکَعْبٍ ، عَنْ أَبِیہِ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَأْکُلُ بِأَصَابِعِہِ الثَّلاَثِ ، وَیَلْعَقُہُنَّ۔ (مسلم 1605۔ ابوداؤد 3844),,,24955 24956,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنْ عِیسَی بْنِ حِطَّانَ ، عَنْ مُصْعَبِ بْنِ سَعْدٍ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ إِذَا اشْتَکَی صَدْرَہُ ، صُنِعَ لَہُ الْحَسْوُ فِیہِ الثُّومُ فَیَحْسُوہُ۔,,,24956 24957,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنْ عَبْدِ اللہِ بْنِ الْحَارِثِ ، عَنْ نَافِعٍ ؛ أَنَّ ابْنَ عُمَرَ کَانَ إِذَا اشْتَکَی صَدْرَہُ ، صُنِعَ لَہُ الْحَسَائُ فِیہِ الثُّومُ ، فَیَحْسُوہُ۔,,,24957 24958,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، عَنْ أَبِی عُبَیْدٍ حَاجِبِ سُلَیْمَانَ ، عَنْ نُعَیْمِ بْنِ سَلاَمۃ ، قَالَ : دَخَلْتُ عَلَی عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، فَوَجَدْتہ یَأْکُلُ ثُومًا مَسْلُوقًا بِمِلْحٍ وَزَیْتٍ۔",,,24958 24959,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ عِمْرَانَ بْنِ حُدَیْرٍ ، قَالَ : سُئِلَ عِکْرِمَۃُ عَنْہُ ؟ فَقَالَ : إِنَّا لَنَأْکُلُہُ الأسْبُوعَ وَالأسْبُوعَیْنِ ، وَلَکِنَّا نَخْرُجُ مِنَ الْمَدِینَۃِ۔",,,24959 24960,حَدَّثَنَا خَلَفُ بْنُ خَلِیفَۃَ ، عَنْ مَنْصُورٍ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّہُ کَانَ لاَ یَرَی بِالثُّومِ وَالْبَصَلِ نِیْئًا بَأْسًا۔,,,24960 24961,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : إِنَّا لَنَأْکُلُ الثُّومَ ،وَالْبَصَلَ ، وَالْکُرَّاثَ۔",,,24961 24962,"حدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ بِالثُّومِ فِی الطَّبِیخِ۔",,,24962 24963,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : قَالَ عُمَرُ : مَنْ أَکَلَ مِنْ ہَاتَیْنِ الشَّجَرَتَیْنِ شَیْئًا ، فَلْیُذْہِبْ رِیحَہُمَا نضجًا ، یَعْنِی الْبَصَلَ ، وَالْکُرَّاثَ۔",,,24963 24964,"حَدَّثَنَا عَبْدُ الأَعْلَی، عَنْ ہِشَامٍ، عَنْ مُحَمَّدٍ، قَالَ: مَا أَعْلَمُ بِأَکْلِ الثُّومِ بَأْسًا ، إِلاَّ أَنْ یَکْرَہَ رَجُلٌ رِیحَہُ۔",,,24964 24965,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یُنْضِجُہُ فِی الْقُدُورِ وَیَأْکُلُہُ۔,,,24965 24966,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ أَبِی یَزِیدَ ، عَنْ أَبِیہِ ، عَنْ أُمِّ أَیُّوبَ ، قَالَتْ : نَزَلَ عَلَیْنَا النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَصَنَعْنَا لَہُ طَعَامًا فِیہِ مِنْ بَعْضِ الْبُقُولِ ، فَکَرِہَہُ ، وَقَالَ : إِنِّی لَسْتُ مِثْلَکُمْ ، إِنِّی أَخَافُ أَنْ أُوذِیَ صَاحِبِی۔",,,24966 24967,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا عُبَیْدُ اللہِ بْنُ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : مَنْ أَکَلَ مِنْ ہَذِہِ الْبَقْلَۃِ ، فَلاَ یَقْرَبَ الْمَسْجِدَ حَتَّی یَذْہَبَ رِیحُہَا ، یَعْنِی الثُّومَ۔",,,24967 24968,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ سَالِمِ بْنِ عَبْدِ اللہِ بْنِ یَزِیدَ ، عَنْ طَبَّاخِ حُذَیْفَۃَ ، قَالَ : کَانَ حُذَیْفَۃُ یَأْمُرُنِی أَنْ لاَ أَجْعَلَ فِی طَعَامِہِ کُرَّاثًا۔",,,24968 24969,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ عَدِیٍّ ، عَنْ زِرِّ بْنِ حُبَیْشٍ ، عَنْ حُذَیْفَۃَ ، قَالَ : مَنْ أَکَلَ الثُّومَ ، فَلاَ یَقْرَبْنَا ثَلاَثًا۔",,,24969 24970,"حَدَّثَنَا إِسْمَاعِیلُ ابْنُ عُلَیَّۃَ، عَنْ أَیُّوبَ، عَنْ حُمَیْدِ بْنِ ہِلاَلٍ، عَنْ أَبِی بُرْدَۃَ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَجَدَ مِنَ الْمُغِیرَۃِ رِیحَ ثُومٍ، فَقَالَ: أَلَمْ أَنْہَکُمْ عَنْ ہَذِہِ الشَّجَرَۃِ؟ فَقَالَ: یَا رَسُولَ اللہِ، أَقْسَمْتُ عَلَیْک لَتُدْخِلَنَّ یَدَک ، قَالَ : وَعَلَیْہِ جُبَّۃٌ ، أَوْ قَمِیصٌ ، فَأَدْخَلَ یَدَہُ فَإِذَا عَلَی صَدْرِہِ عِصَابٌ ، قَالَ : أَرَی لَکَ عُذْرًا۔",,,24970 24971,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ، عَنِ الْحَکَمِ بْنِ عَطِیَّۃَ، عَنْ أَبِی الرَّبَاب، عَنْ مَعْقِلِ بْنِ یَسَارٍ، قَالَ: سَمِعْتُہُ یَقُولُ: کُنَّا مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی مَسِیرَۃٍ فَقَالَ : مَنْ أَکَلَ مِنْ ہَذِہِ الشَّجَرَۃِ ، فَلاَ یَقْرَبَنَّ مُصَلاَّنَا۔",,,24971 24972,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مُعْتَمِرٌ ، عَنْ أَبِیہِ ، قَالَ : رَأَی الْحَسَنُ مَعَ أُمِّہِ کُرَّاثًا ، فَقَالَ : یَا أُمَّتَاہُ ، أَلْقِ ہَذِہِ الشَّجَرَۃَ الْخَبِیثَۃَ۔",,,24972 24973,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطَائٍ ، عَنْ جَابِرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ أَکَلَ مِنْ ہَذِہِ الْبَقْلَۃِ ، فَلاَ یَقْرَبَنَّ مَسْجِدَنَا ، أَوْ قَالَ : الْمَسْجِدَ۔",,,24973 24974,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُلَیْمَانَ بْنِ الْمُغِیرَۃِ ، عَنْ حُمَیْدِ بْنِ ہِلاَلٍ ، عَنْ أَبِی بُرْدَۃَ ، عَنِ الْمُغِیرَۃِ بْنِ شُعْبَۃَ ، قَالَ : أَکَلْتُ ثُومًا ثُمَّ أَتَیْتُ مُصَلَّی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَوَجَدْتہ قَدْ سَبَقَنِی بِرَکْعَۃٍ ، فَلَمَّا صَلَّی قُمْتُ أَقْضِی ، فَوَجَد الرِّیحَ ، فَقَالَ : مَنْ أَکَلَ مِنْ ہَذِہِ الْبَقْلَۃَ ، فَلاَ یَقْرَبَنَّ مَسْجِدَنَا حَتَّی یَذْہَبَ رِیحُہَا ، قَالَ الْمُغِیرَۃُ : فَلَمَّا قَضَیْتُ الصَّلاَۃَ أَتَیْتہُ ، فَقُلْتُ : یَا رَسُولَ اللہِ ، إِنَّ لِی عُذْرًا ، نَاوِلْنِی یَدَک ، قَالَ : فَوَجَدْتُہُ وَاللَّہِ سَہْلاً ، فَنَاوَلَنِی یَدَہُ ، فَأَدْخَلْتُہَا إِلَی صَدْرِی فَوَجَدَہُ مَعْصُوبًا ، فَقَالَ : إِنَّ لَکَ عُذْرًا۔",,,24974 24975,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ، عَنْ یُونُسَ بْنِ أَبِی إِسْحَاقَ ، عَنْ عُمَیْرِ بْنِ قُمَیْمٍ ، عَنْ شَرِیکِ بْنِ حَنْبَلٍ ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ أَکَلَ مِنْ ہَذِہِ الْبَقْلَۃِ الْخَبِیثَۃِ فَلاَ یَقْرَبَنَّ مَسْجِدَنَا ، یَعْنِی الثُّومَ۔",,,24975 24976,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَالِمِ بْنِ أَبِی الْجَعْدِ ، عَنْ مَعْدَانَ بْنِ أَبِی طَلْحَۃَ ؛ أَنَّ عُمَرَ بْنَ الْخَطَّابِ قَالَ : إِنَّکُمْ لَتَأْکُلُونَ شَجَرَتَیْنِ لاَ أَرَاہُمَا إِلاَّ خَبِیثَتَیْنِ ، ہَذَا الثُّومُ ، وَہَذَا الْبَصَلُ ، کُنْت أَرَی الرَّجُلَ عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُوجَدُ رِیحُہُ مِنْہُ ، فَیُؤْخَذُ بِیَدِہِ حَتَّی یُخْرَجَ بِہِ إِلَی الْبَقِیعِ ، فَمَنْ کَانَ آکِلَہُمَا لاَ بُدَّ فَلْیُمِتْہُمَا طَبْخًا۔ (مسلم 397۔ احمد 1/27)",,,24976 24977,"حَدَّثَنَا یُونُسُ بْنُ مُحَمَّدٍ ، عَنْ لَیْثٍ ، عَنْ یَزِیدَ بْنِ أَبِی حَبِیبٍ، عَنْ أَبِی الْخَیْرِ، عَنْ أَبِی رُہْمٍ السَّمَاعِیِّ؛ أَنَّ أَبَا أَیُّوبَ حَدَّثَہُ عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : إِنَّ فِیہِ بَصَلاً فَکُلُوہُ ، وَکَرِہْت أَکْلَہُ مِنْ أَجْلِہِ ، یَعْنِی الْمَلَکَ ، وَأَمَّا أَنْتُمْ فَکُلُوہُ۔ (مسلم 170۔ احمد 5/413)",,,24977 24978,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَرِہَ أَکْلَ الثُّومِ ، وَالْبَصَلِ ،وَالْکُرَّاثِ۔,,,24978 24979,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَبْدِ الْکَرِیمِ أَبِی أُمَیَّۃَ ، عَنِ الْحَسَنِ ، قَالَ : مَا یَسُرُّنِی أَنِّی أَکَلْتُہُ ، یَعْنِی الثُّومَ ، وَلاَ أَنَّ لِی زِنَتَہُ ذَہَبًا۔",,,24979 24980,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ جَبَلَۃَ بْنِ سُحَیْمٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الْقِرَانِ ، إِلاَّ أَنْ تَسْتَأْذِنَ أَصْحَابَکَ۔ (بخاری 5446۔ ترمذی 1814)",,,24980 24981,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُوسَی بْنِ دِہْقَانَ ، قَالَ : رَأَیْتُ سَالِمَ بْنَ عَبْدِ اللہِ یَأْکُلُ التَّمْرَ کَفًّا کَفًّا۔",,,24981 24982,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ أَبِی جَحْشٍ ، عَنْ أَبِی ہُرَیْرَۃَ ؛ أَنَّہُ أَکَلَ مَعَ أَصْحَابِہِ تَمْرًا ، فَقَالَ : إِنِّی قَدْ قَارَنْتُ فَقَارِنُوا۔",,,24982 24983,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَبِیبَۃَ بِنْتِ عَبَّادٍ ، عَنْ أُمِّہَا ، قَالَتْ : سَأَلْتُ عَائِشَۃَ عَنِ الْقِرَانِ بَیْنَ التَّمْرَتَیْنِ ؟ فَقَالَتْ : لَوْ کَانَ حَلاَلاً کَانَ دَنَائَۃً۔",,,24983 24984,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، قَالَ : حدَّثَنَا یَعْقُوبُ بْنُ مُحَمَّدِ بْنِ طَحْلاَئَ ، قَالَ : حَدَّثَنَا أَبُو الرِّجَالِ ، عَنْ أُمِّہِ عَمْرَۃَ ، عَنْ عَائِشَۃَ ، قَالَتْ : قَالَ لِی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : یَا عَائِشَۃُ ، بَیْتٌ لَیْسَ فِیہِ تَمْرٌ جِیَاعٌ أَہْلُہُ۔ (مسلم 153۔ ابوداؤد 3827)",,,24984 24985,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ أَبِی مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانُوا یَسْتَحِبُّونَ أَنْ لاَ یُفَارِقَ بُیُوتَہُمُ التَّمْرُ ، قَالَ إِبْرَاہِیمُ : وَسَأُفَسِّرُہُ : کَانَ إِذَا دَخَلَ عَلَیْہِمُ الدَّاخِلُ فَأَرَادُوا کَرَامَتَہُ ، فَحَبَسُوہُ وَقَرَّبُوہُ مِنْ قَرِیبٍ ، فَإِنْ أَکَلَ مِنْہُ أَکْرَمُوہُ ، وَإِنْ لَمْ یَأْکُلْ فَقَدْ أَجْزَأَ عَنْہُمْ۔قَالَ إِبْرَاہِیمُ : وَأُخْرَی ؛ یَجِیئُ السَّائِلُ وَلَیْسَ عِنْدَ أَہْلِ الْبَیْتِ خُبْزٌ ، وَلاَ یُوَاتِی أَنْفُسَہُمْ أَنْ یَحْثُوا لَہُ مِنَ الدَّقِیقِ وَالْحِنْطَۃِ ، فَیُعْطُونَہُ التَّمْرَۃَ وَالتَّمْرَتَیْنِ وَنَحْوَ ذَلِکَ ، فَیُغْنِی عَنْ أَہْلِ الْبَیْتِ ، وَیَسْتَقِیمُ بِہِ السَّائِلُ۔",,,24985 24986,"حَدَّثَنَا حَفْصٌ ، عَنْ مُصْعَبٍ بْنِ سُلَیْمٍ ، عَنْ أَنَسٍ ، قَالَ : رَأَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَأْکُلُ مُفْعیًا تَمْرًا۔ (مسلم 1616۔ ابوداؤد 3765)",,,24986 24987,"حَدَّثَنَا أَبُو أُسَامَۃَ ، وَمُحَمَّدُ بْنُ بِشْرٍ ، عَنْ زَکَرِیَّا بْنِ أَبِی زَائِدَۃَ ، عَنْ سَعِیدِ بْنِ أَبِی بُرْدَۃَ ، عَنْ أَنَسِ بْنِ مَالِکٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنَّ اللَّہَ لَیَرْضَی عَنِ الْعَبْدِ أَنْ یَأْکُلَ الأَکْلَۃَ فَیَحْمَدَہُ عَلَیْہَا ، أَوْ یَشْرَبَ الشَّرْبَۃَ فَیَحْمَدَہُ عَلَیْہَا۔ (مسلم 89۔ ترمذی 1816)",,,24987 24988,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ: حدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ یَزِیدَ بْنُ جَابِرٍ ، قَالَ: حَدَّثَنَا بِشْرُ بْنُ زِیَادٍ ، عَنْ سُلَیْمَانَ بْنِ عَبْدِ اللہِ، عَنْ عِتْرِیسِ بْنِ عُرْقُوبٍ، قَالَ: قَالَ عَبْدُ اللہِ: مَنْ قَالَ حِینَ یُوضَعُ طَعَامُہُ: بِسْمِ اللہِ خَیْرُ الأَسْمَائِ، لِلَّہِ مِا فِی الأَرْضِ وَفِی السَّمَائِ، لاَ یَضُرُّ مَعَ اسْمِہِ دَائٌ، اللَّہُمَّ اجْعَلْ فِیہِ بَرَکَۃً وَعَافِیَۃً وَشِفَائً ، فَلاَ یَضُرُّہُ ذَلِکَ الطَّعَامُ مَا کَانَ۔",,,24988 24989,"حَدَّثَنَا أَبُو الأَحْوَص ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : إِذَا طَعِمْتَ فَنَسِیتَ أَنْ تُسَمِّیَ ، فَقُلْ : بِسْمِ اللہِ فِی أَوَّلِہِ وَآخِرِہِ۔",,,24989 24990,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَن تَمِیمِ بْنِ سَلَمَۃَ ، قَالَ : حُدِّثْتُ أَنَّ الرَّجُلَ إِذَا ذَکَرَ اسْمَ اللَّہَ عَلَی طَعَامِہِ وَحَمِدَہُ عَلَی آخِرِہِ ، لَمْ یُسْأَلْ عَنْ نَعِیمِ ذَلِکَ الطَّعَامِ۔",,,24990 24991,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ التَّیْمِیِّ ، عَنِ الْحَارِثِ بْنِ سُوَیْد ، قَالَ : کَانَ سَلْمَانُ إِذَا طَعِمَ یَقُول : الْحَمْدُ لِلَّہِ الَّذِی کَفَانَا الْمُؤْونَۃَ ، وَأَوْسَعَ لَنَا الرِّزْقَ۔",,,24991 24992,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ، عَنْ حَجَّاجٍ، عَنْ رِیَاحِ بْنِ عَبِیدَۃَ، عَنْ مَوْلًی لأَبِی سَعِیدٍ، عَنْ أَبِی سَعِیدٍ، قَالَ: کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إِذَا أَکَلَ طَعَامًا، قَالَ: الْحَمْدُ لِلَّہِ الَّذِی أَطْعَمَنَا وَسَقَانَا ، وَجَعَلَنَا مُسْلِمِینَ۔ (ترمذی 3457۔ ابوداؤد 3846)",,,24992 24993,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا مِسْعَرٌ ، عَنْ ہِلاَلٍ ، عَنْ عُرْوَۃَ ؛ أَنَّہُ کَانَ إِذَا وُضِعَ الطَّعَامُ ، قَالَ : سُبْحَانَکَ مَا أَحْسَنَ مَا تُبْلِینَا ، سُبْحَانَکَ مَا أَحْسَنَ مَا تُعْطِینَا ، رَبَّنَا وَرَبَّ أَبْنَائِنَا ، وَرَبَّ آبَائِنَا الأَوَّلِینَ ، قَالَ: ثُمَّ یُسَمِّی اللَّہَ جَلَّ ثَنَاؤُہُ ، وَیَضَعُ یَدَہُ۔",,,24993 24994,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَاصِمِ بْنِ أَبِی النَّجُودِ ، عَنْ ذَکْوَانَ أَبِی صَالِحٍ ، عَنْ عَائِشَۃَ ؛ أَنَّہُ قَدَّمَ إِلَیْہَا طَعَامٌ ، فَقَالَتْ : ائْتدِمُوہُ ، فَقَالُوا : وَمَا إِدَامُہُ ؟ قَالَتْ : تَحْمَدُونَ اللَّہَ عَلَیْہِ إِذَا فَرَغْتُمْ۔",,,24994 24995,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إِدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنْ إِسْمَاعِیلَ بْنِ أَبِی سَعِیدٍ ، قَالَ : کَانَ أَبُو سَعِیدٍ الْخُدْرِیِّ إِذَا وُضِعَ الطَّعَامُ ، قَالَ : الْحَمْدُ لِلَّہِ الَّذِی أَطْعَمَنَا وَسَقَانَا ، وَجَعَلَنَا مُسْلِمِینَ۔",,,24995 24996,حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنْ إِسْمَاعِیلَ بْنِ أَبِی سَعِیدٍ ، عَنْ أَبِیہِ ؛ بِمِثْلِہِ۔,,,24996 24997,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الْجُرَیْرِیِّ ، عَنْ أَبِی الْوَرْدِ ، عَنِ ابْنِ أَعْبَدَ ، أَوِ ابْنِ مَعْبَدٍ ، قَالَ : قَالَ عَلِیٌّ : تَدْرِی مَا حَقُّ الطَّعَامِ ؟ قُلْتُ : وَمَا حَقُّہُ ؟ قَالَ : تَقُولُ بِسْمِ اللہِ ، اللَّہُمَّ بَارِکْ لَنَا فِیمَا رَزَقْتَنَا ، قَالَ : تَدْرِی مَا شُکْرُہُ ؟ قُلْتُ : وَمَا شُکْرُہُ ؟ قَالَ : تَقُولُ : الْحَمْدُ لِلَّہِ الَّذِی أَطْعَمَنَا وَسَقَانَا۔",,,24997 24998,"( حَدَّثَنَا عَبْدُ اللہِ بْنُ إِدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنْ إِبْرَاہِیمَ التَّیْمِیِّ ؛ أَنَّہُ کَانَ یَقُولُ : الْحَمْدُ لِلَّہِ الَّذِی أَطْعَمَنَا وَسَقَانَا۔",,,24998 24999,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إِدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنْ إِبْرَاہِیمَ التَّیْمِیِّ ؛ أَنَّہُ کَانَ یَقُولُ : الْحَمْدُ لِلَّہِ الَّذِی کَفَانَا الْمُؤْونَۃَ ، وَأَحْسَنَ لَنَا الرِّزْقَ۔",,,24999 25000,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، قَالَ : کَانَ أَبِی لاَ یُؤْتَی بِطَعَامٍ وَلاَ شَرَابٍ ، حَتَّی الشَّرْبَۃَ مِنَ الدَّوَائِ ، فَیَطْعَمُہُ ، أَوْ یَشْرَبُہُ حَتَّی یَقُولَ : الْحَمْدُ لِلَّہِ الَّذِی ہَدَانَا ، وَأَطْعَمَنَا ، وَسَقَانَا وَنَعَّمَنَا ، اللَّہُ أَکْبَرُ ، اللَّہُمَّ أَلْفَتْنَا نِعْمَتُکَ بِکُلِّ شَرٍّ ، وَأَصْبَحْنَا وَأَمْسَیْنَا مِنْہَا بِکُلِّ خَیْرٍ ، نَسْأَلُک تَمَامَہَا وَشُکْرَہَا ، لاَ خَیْرَ إِلاَّ خَیْرُک ، وَلاَ إِلَہَ غَیْرُک ، إِلَہَ الصَّالِحِینَ ، وَرَبَّ الْعَالَمِینَ ، الْحَمْدُ لِلَّہِ رَبِّ الْعَالَمِینَ ، لاَ إِلَہَ إِلاَّ اللَّہُ ، مَا شَائَ اللَّہُ ، لاَ قُوَّۃَ إِلاَّ بِاللَّہِ ، اللَّہُمَّ بَارِکْ لَنَا فِیمَا رَزَقْتنَا ، وَقِنَا عَذَابَ النَّارِ۔",,,25000 25001,"حَدَّثَنَا الْحَسَنُ بْنُ مُوسَی ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ أَنَّہُ کَانَ إِذَا فَرَغَ مِنْ طَعَامِہِ ، قَالَ : اللَّہُمَّ أَشْبَعْتَ وَأَرْوَیْتَ فَہَنِّئْنَا ، وَرَزَقْتَنَا فَأَکْثَرْتَ وَأَطْیَبْتَ فَزِدْنَا۔",,,25001 25002,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، قَالَ : أَخْبَرَنَا عَمَّارُ بْنُ رُزَیْقٍ ، عَنْ إِبْرَاہِیمَ بْنِ أَبِی حَفْصَۃَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ أَنَّہُ قَالَ : إِذَا وُضِعَ الطَّعَامُ فَسَمَّیْتَ فَکُلْ مَا جِیئَ بِہِ ، فَإِنَّہُ یُجْزِئُک التَّسْمِیَۃُ الأُولَی۔",,,25002 25003,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، قَالَ : أَخْبَرَنِی مَنْ رَأَی ابْنَ عَبَّاسٍ یَأْکُلُ مُتَّکِئًا۔",,,25003 25004,"حَدَّثَنَا فُضَیْلُ بْنُ عِیَاضٍ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ رُفَیْعٍ ، عَنْ مُجَاہِدٍ ، قَالَ : مَا أَکَلَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مُتَّکِئًا قَط إِلاَّ مَرَّۃً ، قَالَ : اللَّہُمَّ إِنِّی عَبْدُک وَرَسُولُک۔",,,25004 25005,"حَدَّثَنَا ہِشَامٌ ، عَنْ حُصَیْنٍ ، قَالَ : لَمَّا قدِمَ خَالِدُ بْنُ الْوَلِیدِ ہَاہُنَا ، إِذَا ہُوَ بِمَسْلَحَۃٍ لآلِ فَارِسٍ ، عَلَیْہِمْ رَجُلٌ یُقَالُ لَہُ : ہزارمرد ، قَالَ : فَذَکَرُوا مِنْ عِظَمِ خَلْقِہِ وَشَجَاعَتِہِ ، قَالَ : فَقَتَلَہُ خَالِدُ بْنُ الْوَلِیدِ ، ثُمَّ دَعَا بِغَدَائِہِ فَتَغَدَّی وَہُوَ مُتَّکِئٌ عَلَی جِیفَتِہِ ، یَعْنِی جَسَدَہُ۔",,,25005 25006,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : إِنْ کُنَّا نَأْکُلُ وَنَحْنُ مُتَّکِئُونَ۔",,,25006 25007,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانُوا یَکْرَہُونَ أَنْ یَأْکُلُوا تُکَاۃً ، مَخَافَۃَ أَنْ تَعْظُمَ بُطُونُہُمْ۔",,,25007 25008,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ أَبِی ہِلاَلٍ ، قَالَ : رَأَیْتُ ابْنَ سِیرِینَ یَأْکُلُ مُتَّکِئًا۔",,,25008 25009,"حَدَّثَنَا شَرِیکٌ ، عَنْ عَلِیِّ بْنِ الأَقْمَرِ ، عَنْ أَبِی جُحَیْفَۃَ ، یَرْفَعُہُ ، قَالَ : أَمَّا أَنَا فَلاَ آکُلُ مُتَّکِئًا۔ (بخاری 5398۔ ترمذی 1830)",,,25009 25010,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : حدَّثَنَا حُسَامُ بْنُ مِصَکٍّ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : دَخَلْتُ عَلَی عَبِیدَۃَ فَسَأَلْتُہُ عَنِ الرَّجُلِ یَأْکُلُ مُتَّکِئًا ؟ فَأَکَلَ مُتَّکِئًا۔",,,25010 25011,"حَدَّثَنَا وَکِیعٌ ، وَأَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ أَبِی عَمْرٍو الشَّیْبَانِیِّ ، قَالَ : رَأَی عَبْدُ اللہِ بْنُ مَسْعُودٍ مَعَ رَجُلٍ دَرَاہِمَ ، فَقَالَ : أَیُّ شَیْئٍ تَصْنَعُ بِہَذِہِ الدَّرَاہِمِ ؟ فَقَالَ : ہَذِہِ یَا أَبَا عَبْدِ الرَّحْمَنِ ثَلاَثُونَ دِرْہَمًا ، أُرِیدُ أَنْ أَشْتَرِیَ بِہَا سَمْنًا لِرَمَضَانَ ، فَقَالَ : تَجْعَلُہُ فِی السُّکُرُّجَۃِ وَتَأْکُلُہُ ؟ قَالَ : نَعَمْ ، قَالَ : اذْہَبْ فَادْفَعْہَا إِلَی امْرَأَتِکَ ، وَمُرْہَا أَنْ تَشْتَرِیَ کُلَّ یَوْمٍ بِدِرْہَمٍ لَحْمًا ، فَہُوَ خَیْرٌ لَک۔",,,25011 25012,"حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، عَمَّنْ حَدَّثَہُ ، قَالَ : مَرَّ جَابِرٌ عَلَی عُمَرَ بِلَحْمٍ قَدِ اشْتَرَاہُ بِدِرْہَمٍ ، قَالَ : فَقَالَ لَہُ عُمَرُ : مَا ہَذَا ؟ قَالَ : اشْتَرَیْتُہُ بِدِرْہَمٍ ، قَالَ : أَکُلَّمَا اشْتَہَیْتَ شَیْئًا اشْتَرَیْتَہُ ؟ لاَ تَکُنْ مِنْ أَہْلِ ہَذِہِ الآیَۃِ : {أَذْہَبْتُمْ طَیِّبَاتِکُمْ فِی حَیَاتِکُمَ الدُّنْیَا}۔",,,25012 25013,حَدَّثَنَا ابْنُ عُلَیۃ ، عَنْ حَمْزَۃَ بْنِ عَبْدِ اللہِ ؛ أَنَّ الْحَسَنَ کَانَ لَہُ کُلَّ یَوْمٍ نِصْفُ دِرْہَمٍ لَحْمًا۔,,,25013 25014,"حَدَّثَنَا ابْنُ عُلَیۃ ، عَنْ رَجَائِ بْنِ أَبِی سَلَمَۃَ ، قَالَ : کَانَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ یَصنَعُ طَعَامًا یَحْضُرُہُ ، فَلاَ یَأْکُلُ مِنْہُ فَلاَ یَأْکُلُونَ ، فَقَالَ : مَا شَأْنُہُمْ لاَ یَأْکُلُونَ ؟ فَقَالُوا : إِنَّک لاَ تَأْکُلُ فَلاَ یَأْکُلُونَ ، فَأَمَرَ بِدِرْہَمٍ کُلَّ یَوْمٍ مِنْ صُلْبِ مَالِہِ فَأَنْفَقَہَا فِی الطَّبْخِ ، فَأَکَلَ وَأَکَلُوا۔",,,25014 25015,"حَدَّثَنَا حُمَیْدٌ، وَالْفَضْلُ، عَنْ زُہَیْرٍ، عَنْ أَبِی إِسْحَاقَ، قَالَ: کَانَ الشَّعْبِیُّ یَشْتَرِی کُلَّ جُمُعَۃٍ بِدِرْہَمٍ لَحْمًا۔",,,25015 25016,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ زُہَیْرٍ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : قَالَ عُمَرُ : یَکْفِی أَہْلَ الْبَیْتِ فِی الشَّہْرِ بِثَلاَثَۃِ دَرَاہِمَ لَحْمٍ۔",,,25016 25017,"حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ سَعِیدِ بْنِ عُبَیْدٍ ، عَنْ عَلِیِّ بْنِ رَبِیعَۃَ ، قَالَ : کَانَ لِعَلِیٍّ امْرَأَتَانِ ، کَانَ یَشْتَرِی کُلَّ یَوْمٍ لِہَذِہِ بِنِصْفِ دِرْہَمٍ لَحْمًا ، وَلِہَذِہِ بِنِصْفِ دِرْہَمٍ لَحمًا۔",,,25017 25018,"حَدَّثَنَا وَکِیعٌ ، عَنْ حِزَامِ بْنِ ہِشَامٍ ، عَنْ أَبِیہِ ، قَالَ : قَالَ عُمَرُ لِبَنِیہِ : لاَ تُدِیمُوا أَکْلَ اللَّحْمِ ، وَلاَ تُلَظُوا بِالْمَائِ الْعَذْبِ ، وَلاَ تُدِیمُوا لبْسَ الْقَمِیصِ۔",,,25018 25019,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْمَاعِیلَ بْنِ رَافِعٍ ، عَنِ الْقَعْقَاعِ بْنِ حَکِیمٍ ، قَالَ : قَالَتْ عَائِشَۃُ : یَا بَنِی تَمِیمٍ ، لاَ تُدِیمُوا أَکْلَ اللَّحْمِ ، فَإِنَّ لَہُ ضَرَاوَۃً کَضَرَاوَۃِ الْخَمْرِ۔",,,25019 25020,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ، عَنْ أَبِیہِ، قَالَ: إِنْ کَانَ الرَّجُلُ لَیُعَابُ بِأَنْ لاَ یَصْبِرَ عَن اللَّحْمِ۔",,,25020 25021,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ حَبِیبِ بْنِ شَہِیدٍ ، عَنِ ابْنِ بُرَیْدَۃَ ؛ أَنَّ سَلْمَانَ کَانَ یَصْنَعُ الطَّعَامَ مِنْ کَسْبِہِ، فَیَدْعُو الْمَجْذُومِینَ فَیَأْکُلُ مَعَہُمْ۔,,,25021 25022,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ رَجُلٍ ؛ أَنَّہُ رَأَی ابْنَ عُمَرَ یَأْکُلُ مَعَ مَجْذُومٍ ، فَجَعَلَ یَضَعُ یَدَہُ مَوْضِعَ یَدِ الْمَجْذُومِ۔,,,25022 25023,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، عَنْ أَبِیہِ ، قَالَ : قدِمَ عَلَی أَبِی بَکْرٍ وَفْدٌ مِنْ ثَقِیفٍ ، فَأُتِیَ بِطَعَامٍ ، فَدَنَا الْقَوْمُ وَتَنَحَّی رَجُلٌ بِہِ ہَذَا الدَّائُ ، یَعْنِی : الْجُذَامَ ، فَقَالَ لَہُ أَبُو بَکْرٍ : اُدْنُہُ ، فَدَنَا ، فَقَالَ : کُلْ ، فَأَکَلَ وَجَعَلَ أَبُو بَکْرٍ یَضَعُ یَدَہُ مَوْضِعَ یَدِہِ۔",,,25023 25024,"حَدَّثَنَا یُونُسُ بْنُ مُحَمَّدٍ ، عَنْ مُفَضَّلِ بْنِ فَضَالَۃَ ، عَنْ حَبِیبِ بْنِ شَہِیدٍ ، عَنْ مُحَمَّدِ بْنِ الْمُنْکَدِرِ ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَخَذَ بِیَدِ مَجْذُومٍ فَوَضَعَہَا مَعَہُ فِی قَصْعَۃٍ ، فَقَالَ : کُلْ ، بِسْمِ اللہِ ثِقَۃً بِاللَّہِ ، وَتَوَکُّلاً عَلَی اللہِ۔ (ابوداؤد 3921۔ ابن ماجہ 3542)",,,25024 25025,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ یَحْیَی بْنِ جَعْدَۃَ ، قَالَ : جَائَ رَجُلٌ أَسْوَدُ بِہِ جُدَرِیٌّ قَدْ تَقَشَّرَ ، لاَ یَجْلِسُ إِلَی جَنْبِ أَحَدٍ إِلاَّ أَقَامَہُ ، فَأَخَذَہُ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَأَجْلَسَہُ إِلَی جَنْبِہِ۔",,,25025 25026,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی بُکَیْر ، عَنْ عِکْرِمَۃَ ، قَالَ : لَزِقَ بِابْنِ عَبَّاسٍ مَجْذُومٌ ، فَقُلْت لَہُ : تَلْزَقُ بِمَجْذُومٍ ؟ قَالَ : فَامْضِی ، فَلَعَلَّہُ خَیْرٌ مِنِّی وَمِنْک۔",,,25026 25027,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ قَیْسٍ ، عَنْ مِقْسَمٍ ، قَالَ : کَانُوا یَتَّقُونَ أَنْ یَأْکُلُوا مَعَ الأَعْمَی وَالأَعْرَجِ وَالْمَرِیضِ ، حَتَّی نَزَلَتْ ہَذِہِ الآیَۃُ : {لَیْسَ عَلَی الأَعْمَی حَرَجٌ وَلاَ عَلَی الأَعْرَجِ حَرَجٌ وَلاَ عَلَی الْمَرِیضِ حَرَجٌ}۔",,,25027 25028,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ مُنْذِرٍ ، عَنِ الرَّبِیعِ بْنِ خُثَیْمٍ ؛ أَنَّہُ قَالَ لأَہْلِہِ : اصْنَعُوا لِی خَبِیصًا ، قَالَ : فَصَنَعُوا ، قَالَ : فَدَعَا رَجُلاً کَانَ بِہِ خَبَلٌ ، قَالَ : فَجَعَلَ الرَّبِیعُ یُلْقِمُہُ وَلُعَابُہُ یَسِیلُ ، فَلَمَّا أَکَلَ وَخَرَجَ، قَالَتْ لَہُ أَہْلُہُ : تَکَلَّفْنَا وَصَنَعْنَا فِیہِ ، أَطْعَمْتَہُ ؟ مَا یَدْرِی ہَذَا مَا أَکَلَ ، قَالَ الرَّبِیعُ : لَکِنَ اللَّہُ یَدْرِی۔",,,25028 25029,"حَدَّثَنَا وَکِیعٌ ، عَنْ نَافِعِ بْنِ الْقَاسِمِ ، عَنْ جَدَّتِہِ أُمِّ الْقَاسِمِ ، عَنْ عَائِشَۃَ ، قَالَتْ : کَانَ لِی مَوْلًی مَجْذُومٌ، فَکَانَ یَنَامُ عَلَی فِرَاشِی ، وَیَأْکُلُ فِی صِحَافِی ، وَلَوْ کَانَ عَاشَ کَانَ بَقِی عَلَی ذَلِکَ۔",,,25029 25030,"حَدَّثَنَا ہُشَیْمٌ ، وَشَرِیکٌ ، عَنْ یَعْلَی بْنِ عَطَائٍ ، عَنْ عَمْرِو بْنِ الشَّرِیدِ ، عَنْ أَبِیہِ ، قَالَ : کَانَ فِی وَفْدِ ثَقِیفٍ رَجُلٌ مَجْذُومٌ ، فَأَرْسَلَ إِلَیْہِ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنَّا قَدْ بَایَعْنَاک فَارْجِعْ۔ (مسلم 126۔ احمد 4/389)",,,25030 25031,"حَدَّثَنَا وَکِیعٌ ، عَنِ النَّہَّاسِ بْنِ قَہْمٍ ، عَنْ شَیْخٍ ، قَالَ : سَمِعْتُ أَبَا ہُرَیْرَۃَ یَقُولُ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : فِرَّ مِنَ الْمَجْذُومِ ، فِرَارَک مِنَ الأَسَدِ۔ (بخاری 417۔ احمد 2/443)",,,25031 25032,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ اللہِ بْنِ سَعِیدٍ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ اللہِ بْنِ عَمْرِو بْنِ عُثْمَانَ ، عَنْ أُمِّہِ فَاطِمَۃَ بِنْتِ حُسَیْنٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: لاَ تُدِیمُوا النَّظَرَ إِلَی الْمَجْذُومِینَ۔\n\n(بخاری 417۔ احمد 1/233)",,,25032 25033,"حَدَّثَنَا مُحَمَّدُ بْنُ سَوَائٍ ، عَنْ خَالِدٍ ، عَنْ أَبِی قِلاَبَۃَ ؛ أَنَّہُ کَانَ یُعْجِبُہُ أَنْ یُتَّقَی الْمَجْذُومُ۔\n\n(عبدالرزاق 20331)",,,25033 25034,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حدَّثَنَا عُبَیْدُ اللہِ بْنُ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْمُؤْمِنُ یَأْکُلُ فِی مِعًی وَاحِدٍ ، وَالْکَافِرُ یَأْکُلُ فِی سَبْعَۃِ أَمْعَائٍ۔ (بخاری 5394۔ مسلم 1631)",,,25034 25035,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ سُفْیَانَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: الْمُؤْمِنُ یَأْکُلُ فِی مِعًی وَاحِدٍ ، وَالْکَافِرُ یَأْکُلُ فِی سَبْعَۃِ أَمْعَائٍ۔ (مسلم 1631۔ احمد 3/333)",,,25035 25036,"حَدَّثَنَا مُحَمَّدُ بْنُ کَثِیرٍ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْمُؤْمِنُ یَأْکُلُ فِی مِعًی وَاحِدٍ ، وَالْکَافِرُ یَأْکُلُ فِی سَبْعَۃِ أَمْعَائٍ۔\n\n(ترمذی 1819۔ احمد 2/435)",,,25036 25037,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، قَالَ : أَظُنُّ أَبَا خَالِدٍ الْوَالِبِیَّ ذَکَرَہُ عَنْ مَیْمُونَۃَ ، قَالَتْ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْکَافِرُ یَأْکُلُ فِی سَبْعَۃِ أَمْعَائٍ ، وَالْمُؤْمِنُ یَأْکُلُ فِی مِعًی وَاحِدٍ۔\n\n(احمد 6/335۔ طبرانی 13)",,,25037 25038,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، قَالَ : حدَّثَنِی عُبَیْدٌ الأَغَرُّ ، عَنْ عَطَائِ بْنِ یَسَارٍ ، عَنْ جَہْجَاہٍ الْغِفَارِیِّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْکَافِرُ یَأْکُلُ فِی سَبْعَۃِ أَمْعَائٍ ، وَالْمُؤْمِنُ یَأْکُلُ فِی مِعًی وَاحِدٍ۔ (طبرانی 2152)",,,25038 25039,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی سُفْیَانَ ، عَنْ جَابِرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : طَعَامُ الْوَاحِدِ یَکْفِی الاِثْنَیْنِ ، وَطَعَامُ الاِثْنَیْنِ یَکْفِی الأَرْبَعَۃَ۔ (مسلم 181۔ ترمذی 1820)",,,25039 25040,"حَدَّثَنَا حَفْصٌ، عَنْ إِسْمَاعِیلَ بْنِ أَبِی خَالِدٍ، عَنْ أَبِیہِ، قَالَ: دَخَلْتُ عَلَی رَجُلٍ وَہُوَ یَأْکُلُ تَمْرًا وَیَتَمَجَّعُ لَبَنًا ، فَقَالَ : ہَلُمَّ وَسَمِّ ، فَإِنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُسَمِّیہِمَا الأَطْیَبَیْنِ۔(احمد 3/474)",,,25040 25041,"حَدَّثَنَا أَبُو الأَحْوَص ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ أَبِیہِ ، قَالَ : دَخَلْتُ عَلَی عَلِیٍّ فِی یَوْمٍ شَاتٍ ، وَفِی یَدِہِ شَرَابٌ ، فَنَاوَلَنِی فَقَالَ : اشْرَبْ ، قُلْتُ : وَمَا ہُوَ ؟ قَالَ : ثُلُثٌ عَسَلٌ ، وَثُلُثٌ سَمْنٌ ، وَثُلُثٌ لَبَنٌ ، فَقُلْتُ: لاَ أُرِیدُہُ ، فَقَالَ : أَمَا إِنَّک لَوْ شَرِبْتَہُ لَمْ تَزَلْ دَفِیئًا شَبْعَانًا سَائِرَ یَوْمِکَ۔",,,25041 25042,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنِ الْعَلاَئِ بْنِ الْمُسَیَّبِ ، قَالَ: رَأَیْتُ إِبْرَاہِیمَ ، وَخَیْثَمَۃَ یَأْکُلاَنِ أَلْیَۃً بِعَسَلٍ۔",,,25042 25043,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا إِبْرَاہِیمُ بْنُ سَعْدٍ ، عَنْ أَبِیہِ ، عَنْ عَبْدِ اللہِ بْنِ جَعْفَرٍ ، قَالَ : رَأَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَأْکُلُ الرُّطَبَ بِالْقِثَّائِ۔",,,25043 25044,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَأْکُلُ الْبِطِّیخَ بِالرُّطَبِ۔\n\n(ترمذی 200۔ احمد 3/142)",,,25044 25045,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی خَلْدَۃَ ، قَالَ : أَتَیْنَا ابْنَ سِیرِینَ ، فَقَالَ : مَا أَدْرِی مَا أُطْعِمُک ، لَیْسَ مِنْکُمْ رَجُلٌ إِلاَّ وَفِی بَیْتِہِ ، ثُمَّ أَخْرَجَ لَنَا شُہْدَۃً فَجَعَلَ یُطْعِمُنَا۔",,,25045 25046,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ مُجَاہِدٍ ، قَالَ : لَیْسَ الْقِرْدُ مِنْ بَہِیمَۃِ الأَنْعَامِ۔",,,25046 25047,حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ؛ أَنَّہُ کَرِہَ الْقُنْفُذَ۔,,,25047 25048,حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ مَعْمَرٍ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ لاَ یَرَی بِأَکْلِ الوَبْرِ بَأْسًا۔,,,25048 25049,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ أَبِی یَعْفُورَ ، عَنِ ابْنِ أَبِی أَوْفَی ، قَالَ : غَزَوْتُ مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سَبْعَ غَزَوَاتٍ نَأْکُلُ الْجَرَادَ۔ (مسلم 1546۔ ترمذی 1821)",,,25049 25050,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ شَبِیبٍ ، عَنْ جُنْدُبٍ ، رَجُلٌ مِنْہُمْ ، سَأَلَ ابْنَ عَبَّاسٍ عَنْ أَکْلِ الْجَرَادِ ؟ فَقَالَ : لاَ بَأْسَ بِہِ۔",,,25050 25051,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : ذُکِرَ لِعُمَرَ جَرَادٌ بِالرَّبَذَۃِ ، فَقَالَ : لَوَدِدْتُ أَنَّ عِنْدَنَا مِنْہُ قَفْعَۃً ، أَوْ قَفْعَتَیْنِ۔",,,25051 25052,"حَدَّثَنَا حَفْصٌ، عَنِ الْحَسَنِ بْنِ عُبَیْدِاللہِ، قَالَ: سَمِعْتُ إِبْرَاہِیمَ قَالَ: کُنَّ أُمَّہَاتُ الْمُؤْمِنِینَ یَتَہَادَیْنَ الْجَرَادَ۔\n\n(ابن ماجہ 3220)",,,25052 25053,حَدَّثَنَا عَبْدَۃُ، عَنْ عُثْمَانَ بْنِ حَکِیمٍ، عَنِ الْحَسَنِ بْنِ سَعْدٍ، عَنْ أَبِیہ؛ أَنَّہُ کَانَ یُنَقِی لِعَلِیٍّ الْجَرَادَ، فَیَأْکُلُہُ۔,,,25053 25054,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، وَیَزِیدُ بْنُ ہَارُونَ ، عَنْ دَاوُدَ بْنِ أَبِی ہِنْدٍ ، قَالَ : سَأَلْتُ سَعِیدَ بْنَ الْمُسَیَّبِ عَنِ الْجَرَادِ ؟ فَقَالَ : أَکَلَہُ عُمَرُ ، وَالْمِقْدَادُ بْنُ الأَسْوَدِ ، وَصُہَیْبٌ ، وَعَبْدُ اللہِ بْنُ عُمَرَ ، قَالَ : وَقَالَ عُمَرُ : وَدِدْت أَنَّ عِنْدِی قَفْعَۃً ، أَوْ قَفْعَتَیْنِ۔",,,25054 25055,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنِ الشَّیْبَانِیِّ ، عَنْ حَبِیبِ بْنِ أَبِی ثَابِتٍ ، عَنْ أَبِی وَائِلٍ ، عَنْ عُمَرَ؛ أَنَّہُ ذَکَرَ الْجَرَادَ ، فَقَالَ : وَدِدْتُ أَنَّ عِنْدِی مِنْہُ قَفْعَۃً ، أَوْ قَفْعَتَیْنِ۔",,,25055 25056,حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَن الشَّیْبَانِیِّ ، عَن حَبِیبِ بْنِ أَبِی ثَابِتٍ ، عَنْ أَبِی وَائِلٍ ، عَنْ عُمَرَ ؛ بِنَحْوِ حَدِیثِ زَائِدَۃَ ، عَنِ الشَّیْبَانِیِّ۔,,,25056 25057,حَدَّثَنَا عُبَیْدُ اللہِ ، وَالْفَضْلُ ، عَنْ إِسْرَائِیلَ ، عَنْ سِمَاکٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ عُمَرَ کَانَ یَأْکُلُ الْجَرَادَ۔,,,25057 25058,"حَدَّثَنَا زَکَرِیَّا ، عَنِ الشَّعْبِیِّ ، عَنِ ابْنِ عُمَرَ ، قَالَ : رَأَیْتُ عُمَرَ یَتَحَلَّبُ فُوہُ ، قَالَ : قُلْتُ : یَا أَمِیرَ الْمُؤْمِنِینَ ، قَالَ : أَشْتَہِی جَرَادًا مَقْلِیًّا۔",,,25058 25059,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُثَنَّی بْنِ سَعِیدٍ أَبِی غِفَارٍ ، قَالَ : سَمِعْتُ جَابِرَ بْنَ زَیْدٍ یَقُولُ : لَقَصْعَۃٌ مِنْ جَرَادٍ أَحَبَّ إِلَیَّ مِنْ قَصْعَۃٍ مِنْ ثَرِیدٍ۔",,,25059 25060,"حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، قَالَ : رَأَیْتُ أَبِی یَأْکُلُ الْجَرَادَ۔",,,25060 25061,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللہِ الأَسَدِیُّ ، عَنْ مُحَمَّدِ بْنِ خَالِدٍ الضَّبِّیِّ ، عَنِ الأَخْضَرِ بْنِ الْعَجْلاَنِ ، قَالَ : سَأَلْتُ سَعِیدَ بْنَ جُبَیْرٍ عَنِ الْجَرَادِ ؟ فَقَالَ : کُلْہُ مَقْلِیًّا بِزَیْتٍ۔",,,25061 25062,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَلْقَمَۃَ بْنِ مَرْثَدٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ الْحَارِثِ ، عَنْ أَبِیہِ ، قَالَ : سُئِلَ عَلِیٌّ عَنِ الْجَرَادِ ؟ فَقَالَ : ہُوَ طَیِّبٌ کَصَیْدِ الْبَحْرِ۔",,,25062 25063,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : کَانَ لاَ یَرَی بِأَکْلِ الْجَرَادِ بَأْسًا۔",,,25063 25064,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سَعْدِ بْنِ إِسْحَاقَ ، عَنْ زَیْنَبَ امْرَأَۃِ أَبِی سَعِیدٍ ، قَالَتْ : کَانَ أَبُو سَعِیدٍ یَرَانَا وَنَحْنُ نَأْکُلُ الْجَرَادَ فَلاَ یَنْہَانَا ، وَلاَ یَأْکُلُہُ ، فَلاَ أَدْرِی تَقَذُّرًا مِنْہُ ، أَوْ یَکْرَہُہُ ؟۔",,,25064 25065,"حَدَّثَنَا عَبْدَۃُ ، عَنْ عُثْمَانَ بْنِ حَکِیمٍ ، عَنْ سَعِیدِ بْنِ مَرْجَانَۃَ ، قَالَ : کَانَ ابْنُ عُمَرَ لاَ یَأْکُلُ الْجَرَادَ ، قُلْتُ : مَا یَمْنَعُک مِنْ أَکْلِہِ ؟ قَالَ : أَسْتَقْذِرہُ۔",,,25065 25066,حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ؛ أَنَّہُ کَانَ لاَ یَأْکُلُ الْجَرَادَ۔,,,25066 25067,حَدَّثَنَا جَعْفَرُ بْنُ عَوْنٍ، عَنْ ہِشَامِ بْنِ سَعْدٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ؛ أَنَّہُ کَانَ لاَ یَأْکُلُ الْجَرَادَ یَتَقَذَّرُہُ۔,,,25067 25068,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی عُثْمَانَ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سُئِلَ عَنِ الْجَرَادِ ؟ فَقَالَ : أَکْثَرُ جُنُودِ اللہِ ، لاَ آکُلُہُ ، وَلاَ أَنْہَی عَنْہُ۔ (ابوداؤد 3807۔ ابن ماجہ 3219)",,,25068 25069,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ أَبِی سَلَمَۃَ ، عَنْ کَعْبٍ ، قَالَ : الْجَرَادُ نَثْرَۃُ حُوتٍ۔",,,25069 25070,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، قَالَ : ہُوَ نَثْرَۃُ حُوتٍ۔",,,25070 25071,"حَدَّثَنَا مُعَاذٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ قَالَ فِی طَیْرٍ وَقَعَ فِی قِدْرٍ فَمَاتَ فِیہَا ، قَالَ: یُصَبُّ الْمَرَقُ، وَیُؤْکَلُ اللَّحْمُ۔",,,25071 25072,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ عِکْرِمَۃَ ، قَالَ : سَأَلْتُہُ عَنْ طَیْرٍ وَقَعَ فِی قِدْرٍ وَہِیَ تَغْلِی ، فَمَاتَ ؟ فَقَالَ : یُہْرَاقُ الْمَرَقُ ، وَیُؤْکَلُ اللَّحْمُ۔",,,25072 25073,"حَدَّثَنَا وَکِیعٌ ، عَنْ عُمَرَ بْنِ شَوْذَبٍ ، عَنْ عَمْرَۃَ بِنْتِ الطَّبِیخِ ، قَالَتْ : أَرْسَلَتْنِی أُمِّی فَاشْتَرَیْتُ جَرِّیًّا فَجَعَلْتہ فِی زِنْبِیلٍ ، فَخَرَجَ رَأْسُہُ مِنْ جَانِبٍ وَذَنَبُہُ مِنْ جَانِبٍ ، فَمَرَّ بِی عَلِیٌّ أَمِیرُ الْمُؤْمِنِینَ فَرَآہُ ، فَقَالَ : ہَذَا کَثِیرٌ طَیِّبٌ یُشْبِعُ الْعِیَالَ۔",,,25073 25074,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُجَاشِعٍ أَبِی الرَّبِیعِ ، عَنْ کُہَیْلٍ ، عَنْ أَبِیہِ ، قَالَ : کَانَ عَلِیٌّ یَمُرُّ عَلَیْنَا ، وَالْجَرِّیُّ عَلَی سَفَرِنَا وَنَحْنُ نَأْکُلُہُ ، لاَ یَرَی بِہِ بَأْسًا۔",,,25074 25075,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ عِکْرِمَۃَ ، قَالَ : سُئِلَ ابْنُ عَبَّاسٍ عَنِ الْجَرِّیِّ ؟ فَقَالَ : لاَ بَأْسَ بِہِ ، إِنَّمَا تُحَرِّمُہُ الْیَہُودُ وَنَحْنُ نَأْکُلُہُ۔",,,25075 25076,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الْحَسَنِ بْنِ عَمْرٍو ، عَنْ فُضَیْلٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ بِالْجَرِّیِّ ، إِنَّمَا ہَذَا شَیْئٌ یَرْوُونَہُ عَنْ عَلِیٍّ رَحِمَہُ اللَّہُ فِی الصُّحُفِ۔",,,25076 25077,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ عَبْدِ الأَعْلَی ، قَالَ : سَأَلْتُ سَعِیدَ بْنَ جُبَیْرٍ عَنِ الْجَرِّیِّ ؟ فَقَالَ : ہُوَ مِنَ السَّمَکِ ، إِنْ أَعْجَبَک فَکُلْہُ۔",,,25077 25078,"حَدَّثَنَا وَکِیعٌ ، عَنْ فِطْرٍ ، عَنْ مُنْذِرٍ الثَّوْرِیِّ أَبِی یَعْلَی ، قَالَ : سُئِلَ ابْنُ الْحَنَفِیَّۃِ عَنِ الْجَرِّیِّ، وَالطِّحَالِ، وَأَشْبَاہَہُمَا مِمَا یُکْرَہُ ؟ فَتَلاَ ہَذِہِ الآیَۃَ : {قُلْ لاَ أَجِدُ فِیمَا أُوحِیَ إِلَیَّ مُحَرَّمًا}۔",,,25078 25079,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی سَلَمَۃَ الصَّائِغِ ، قَالَ : سَأَلْتُ عَطَائَ بْنَ أَبِی رَبَاحٍ عَنِ الْجَرِّیِّ ؟ قَالَ : کُلْ ذنْبٍ سَمِینٍ مِنْہُ۔",,,25079 25080,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی حَمْزَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : عَلَیْک بِأَذْنَابِہِ۔",,,25080 25081,"حَدَّثَنَا وَکِیعٌ، عَنْ فُضَیْلِ بْنِ مَرْزُوقٍ، عَنْ إِبْرَاہِیمَ بْنِ عَبْدِاللہِ بْنِ الْحَسَنِ، قَالَ: الْجَرِّیُّ مِنْ صَیْدِ الْبَحْرِ۔",,,25081 25082,"حَدَّثَنَا وَکِیعٌ ، عَنْ رَبِیع ، عن الْحَسَنِ ، قَالَ : لاَ بَأْسَ بالْجَرِّیّ ، وَالمارماہیک۔",,,25082 25083,"حَدَّثَنَا حَفْصٌ ، قَالَ : سَمِعْتُ جَعْفَرًا یَقُولُ : مَا لَیْسَ فِیہِ قِشْرٌ مِنَ السَّمَکِ فَإِنَّا نَعَافُہُ ، وَلاَ نَأْکُلُہُ۔",,,25083 25084,"حَدَّثَنَا أَبو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ بِالْجَرِّیثِ۔",,,25084 25085,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ لاَ یَرَی بِأَکْلِ الْجِرِّیثِ بَأْسًا۔,,,25085 25086,حَدَّثَنَا وَکِیعٌ، عَنْ حَسَنِ بْنِ صَالِحٍ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنْ أَبِی جَعْفَرٍ ؛ أَنَّہُ أُتِیَ بِسُلَحْفَاۃٍ فَأَکَلَہَا۔,,,25086 25087,"حَدَّثَنَا حَفْصٌ ، عَنِ أَشْعَث ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : کَانَ فُقَہَائُ الْمَدِینَۃِ یَشْتَرُونَ الرَّقَّ ، وَیُغَالُونَ بِہَا حَتَّی بَلَغَ ثَمَنُہَا دِینَارًا۔",,,25087 25088,"حَدَّثَنَا عَائِذُ بْنُ حَبِیبٍ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ بَأْسَ بِأَکْلِہَا ، یَعْنِی السُّلَحْفَاۃَ۔",,,25088 25089,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ زَمْعَۃَ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ لاَ یَرَی بِأَکْلِ السُّلَحْفَاۃِ بَأْسًا۔,,,25089 25090,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ مُبَارَکٍ ، عَنِ الْحَسَنِ ، قَالَ : لاَ بَأْسَ بِأَکْلِہَا۔",,,25090 25091,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : کَانَ ابْنُ عمَرَ یَأْمُرُ بِالتَّخَلُّلِ ، وَیَقُولُ : إِنَّ ذَلِکَ إِذَا تُرِکَ وَہَّنَ الأَضْرَاسَ۔",,,25091 25092,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنْ عَطَائٍ ؛ أَنَّہُ کَانَ یَکْرَہُ لُحُومَ الْجَلاَّلَۃِ ، وَأَلْبَانَہَا۔,,,25092 25093,حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنْ لَیْثٍ، عَنْ مُجَاہِدٍ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی عَنْ لُحُومِ الْجَلاَّلَۃِ وَأَلْبَانِہَا۔,,,25093 25094,"حَدَّثَنَا شَبَابَۃُ ، قَالَ : حدَّثَنَا مُغِیرَۃُ بْنُ مُسْلِمٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الْجَلاَّلَۃِ أَنْ یُؤْکَلَ لَحْمُہَا ، أَوْ یُشْرَبَ لَبَنُہَا۔ (مسند 2347)",,,25094 25095,"حَدَّثَنَا یَحْیَی بْنُ سُلَیْمٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : کَانَ عَطَائٌ لاَ یَرَی بِالْجَلاَّلَۃِ بَأْسًا أَنْ یُحَجَّ عَلَیْہَا ، وَتُؤْکَلَ إِذَا کَانَ أَکْثَرُ عَلَفِہَا غَیْرَ الْجِلَّۃِ ، وَإِن کَانَ أَکْثَرُ عَلَفِہَا الْجِلَّۃُ ، فَإِنَّہ کَرِہَہَا۔",,,25095 25096,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ، قَالَ : کَانَ لاَ یَرَی بِأَکْلِہَا بَأْسًا۔",,,25096 25097,"حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنْ عِکْرِمَۃَ بْنِ خَالِدٍ ، قَالَ : نُہِیَ عَنْ أَلْبَانِ الْجَلاَّلَۃِ وَلُحُومِہَا ، وَأَنْ یُحَجَّ عَلَیْہَا وَأَنْ یُعْتَمَرَ۔",,,25097 25098,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَمْرِو بْنِ مَیْمُونٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَحْبِسُ الدَّجَاجَۃَ الْجَلاَّلَۃَ ثَلاَثًا۔,,,25098 25099,"حَدَّثَنَا وَکِیعٌ ، عَنْ أُسَامَۃَ بْنِ زَیْدٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ لَبَنِ الشَّاۃِ الْجَلاَّلَۃِ۔ (ترمذی 1825۔ ابوداؤد 3780)",,,25099 25100,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ لَحْمِ الشَّاۃِ الْجَلاَلَۃِ۔",,,25100 25101,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ إِبْرَاہِیمَ بْنِ مُہَاجِرٍ ، عَنْ مُجَاہِدٍ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ أَلْبَانِ الْجَلاَّلَۃِ۔",,,25101 25102,حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی رَوَّادٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ عِنْدَہُ إِبِلٌ جَلاَّلَۃٌ ، فَأَصْدَرَہَا إِلَی الْحِمَی ثُمَّ رَدَّہَا ، فَحَمَلَ عَلَیْہَا الزَّوَامِلَ إِلَی مَکَّۃَ۔,,,25102 25103,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا حَجَّاجُ بْنُ أَبِی زَیْنَبَ ، قَالَ : حَدَّثَنَا أَبُو سُفْیَانَ طَلْحَۃُ بْنُ نَافِعٍ ، عَنْ جَابِرٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : نِعْمَ الإِدَامُ الْخَلُّ۔ (ترمذی 1839۔ ابوداؤد 3817)",,,25103 25104,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مُحَارِبِ بْنِ دِثَارٍ ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : نِعْمَ الإِدَامُ الْخَلُّ۔ (ابوداؤد 3816۔ ترمذی 1839)",,,25104 25105,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ عَبْدِ اللہِ بْنِ الْمُؤَمِّلِ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، عَنْ عَائِشَۃَ ، قَالَتْ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : نِعْمَ الإِدَامُ الْخَلُّ۔ (مسلم 164۔ ابن ماجہ 3316)",,,25105 25106,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ أَبِی حَمْزَۃَ، عَنْ إِبْرَاہِیمَ؛ فِی الْمُضْطَرِّ إِلَی الْمَیْتَۃِ، قَالَ: یَأْکُلُ مَا یُقِیمُہُ۔",,,25106 25107,"حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : إِذَا اضْطُرَّ إِلَی مَا حُرِّمَ عَلَیْہِ ، فَہُوَ لَہُ حَلاَلٌ۔",,,25107 25108,"حَدَّثَنَا وَکِیعٌ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، عَنْ قَیْسِ بْنِ سَعْدٍ ، عَنْ عَطَائٍ ؛ فِی رَجُلٍ أُکْرِہَ عَلَی لَحْمِ الْخِنْزِیرِ وَشُرْبِ الْخَمْرِ ، قَالَ : إِنْ أَکَلَ فَرُخْصَۃٌ ، وَإِنْ لَمْ یَأْکُلْ فَقُتِلَ دَخَلَ الْجَنَّۃَ۔",,,25108 25109,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ سَلاَّمِ بْنِ مِسْکِینٍ ، قَالَ : دَخَلْتُ عَلَی جَابِرِ بْنِ زَیْدٍ وَہُوَ یَأْکُلُ عَلَی خِوَانٍ خَلْنَجٍ۔",,,25109 25110,حَدَّثَنَا الثَّقَفِیُّ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَقُولُ فِی الْخَادِمِ الْمَجُوسِیَّۃِ تَکُونُ لِلرَّجُلِ الْمُسْلِم، فَتَطْبُخُ لَہُ وَتَعْمَلُ لَہُ ، فَلَمْ یَرَ بِذَلِکَ بَأْسًا۔,,,25110 25111,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ سُلَیْمَانَ بْنِ مَیْسَرَۃَ ، وَالْمُغِیرَۃِ بْنِ شُبْیلٍ ، عَنْ طَارِقِ بْنِ شِہَابٍ ، قَالَ: دَخَلْتُ عَلَی سَلْمَانَ وَعِنْدَہُ عِلْجَۃٌ تُعَاطِیہ۔",,,25111 25112,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ طَلْحَۃَ بْنِ یَحْیَی ، قَالَ : دَخَلْتُ عَلَی عُمَرَ بْنِ عَبْدِ الْعَزِیزِ فَرَأَیْتُ عَلَی إِخْوَانِہِ أَلْوَانَ السِّبَاعِ ، أَوْ قَالَ : سِبَاعٌ مِنَ الطَّیْرِ۔",,,25112
