hadiths[39]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
2606,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”مجھے حکم دیا گیا ہے کہ م",,,,,2606
2607,ابوہریرہ رضی الله عنہ کہتے ہیں کہ  جب رسول اللہ صلی اللہ علیہ وسلم کی وفات ہوئی اور آپ کے بعد ابوبکر,,,,,2607
2608,"انس بن مالک رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”مجھے لوگوں سے اس و",,,,,2608
2609,"عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اسلام کی بنیاد پ",,,,,2609
2610,یحییٰ بن یعمر کہتے ہیں کہ  سب سے پہلے جس شخص نے تقدیر کے انکار کی بات کی وہ معبد جہنی ہے، میں اور حم,,,,,2610
2611,عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  عبدقیس کا وفد رسول اللہ صلی اللہ علیہ وسلم کے پاس آیا، ,,,,,2611
2612,"ام المؤمنین عائشہ رضی الله عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”سب سے زیادہ کا",,,,,2612
2613,ابوہریرہ رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے لوگوں کے سامنے خطبہ دیا تو اس ,,,,,2613
2614,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”ایمان کی تہتر شاخیں  ( س",,,,,2614
2615,عبداللہ بن عمر رضی الله عنہما بیان کرتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ایک شخص کے پاس سے گزرے ,,,,,2615
2616,معاذ بن جبل رضی الله عنہ کہتے ہیں کہ  میں ایک سفر میں نبی اکرم صلی اللہ علیہ وسلم کے ساتھ تھا، ایک د,,,,,2616
2617,"ابو سعید خدری رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جب تم کسی شخص کو مس",,,,,2617
2618,"جابر رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”کفر اور ایمان کے درمیان فر",,,,,2618
2619,"جابر رضی الله عنہ سے اس سند سے مروی ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”بندے اور شرک یا ب",,,,,2619
2620,"جابر رضی الله عنہ سے اس سند بھی مروی ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”بندے اور کفر کے",,,,,2620
2621,"بریدہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”ہمارے اور منافقین کے درمیان",,,,,2621
2622,عبداللہ بن شقیق عقیلی کہتے ہیں کہ  صحابہ کرام  ( رضی الله عنہم )  نماز کے سوا کسی عمل کے چھوڑ دینے ک,,,,,2622
2623,عباس بن عبدالمطلب رضی الله عنہ سے روایت ہے کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے ,,,,,2623
2624,"انس بن مالک رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس میں تین خصلتیں ہوں",,,,,2624
2625,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جب زنا کرنے والا زنا کرت",,,,,2625
2626,"علی بن ابی طالب رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جس نے کوئی جرم ",,,,,2626
2627,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”مسلمان  ( کامل )  وہ ہے ",,,,,2627
2628,ابوموسیٰ اشعری رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم سے پوچھا گیا کہ مسلمانوں میں,,,,,2628
2629,"عبداللہ بن مسعود رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اسلام اجنبی حالت",,,,,2629
2630,"عمرو بن عوف رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ” ( ایک وقت آئے گا",,,,,2630
2631,"اس سند سے بھی  ابوہریرہ رضی الله عنہ سے اسی جیسی حدیث مروی ہے۔ \r\n\r\nامام ترمذی کہتے ہیں: یہ حدیث صحیح",,,,,2631
2632,"عبداللہ بن عمرو رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”چار خصلتیں جس",,,,,2632
2633,"زید بن ارقم رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جب آدمی کسی سے وعدہ ",,,,,2633
2634,"عبداللہ بن مسعود رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”مسلمان کا اپنے ک",,,,,2634
2635,"عبداللہ بن مسعود رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”مسلمان کو گالی گ",,,,,2635
2636,"ثابت بن ضحاک رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”بندہ جس چیز کا مال",,,,,2636
2637,"عبداللہ بن عمر رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”اگر کسی نے اپن",,,,,2637
2638,صنابحی سے روایت ہے کہ  میں عبادہ بن صامت رضی الله عنہ کے پاس اس وقت گیا جب وہ موت کی حالت میں تھے، م,,,,,2638
2639,"عبداللہ بن عمرو بن عاص رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اللہ تعا",,,,,2639
2640,"ابوہریرہ رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”یہود اکہتر یا بہتر فر",,,,,2640
2641,"عبداللہ بن عمرو رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”میری امت کے ساتھ ",,,,,2641
2642,"عبداللہ بن عمرو رضی الله عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا: ”ا",,,,,2642
2643,"معاذ بن جبل رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”کیا تمہیں معلوم ہے کہ",,,,,2643
2644,"ابوذر رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”میرے پاس جبرائیل  ( علیہ",,,,,2644
