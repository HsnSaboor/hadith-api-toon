{"metadata":{"name":"Sunan an Nasai","section":{"1":"The Book of Purification"},"section_detail":{"1":{"hadithnumber_first":1,"hadithnumber_last":324,"arabicnumber_first":1,"arabicnumber_last":324}}},"hadiths":[{"hadithnumber":261,"arabicnumber":261,"text":"Rapporté par 'Ali : Le Prophète (ﷺ) a dit : \"Les anges n’entrent pas dans une maison où il y a une image, un chien ou une personne en état de grande impureté","grades":[{"name":"Abu Ghuddah","grade":"Daif"},{"name":"Al-Albani","grade":"Daif"},{"name":"Zubair Ali Zai","grade":"Isnaad Hasan"}],"reference":{"book":1,"hadith":262}}]}