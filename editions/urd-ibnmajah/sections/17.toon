hadiths[10]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
2492,"جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس کے پاس کھجور کے درخت ہوں ",,,,,2492
2493,"عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جس کے پاس زمین ہ",,,,,2493
2494,"جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  پڑوسی اپنے پڑوسی کے شفعہ کا ",,,,,2494
2495,"ابورافع رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  پڑوسی اپنے نزدیکی مکان ",,,,,2495
2496,"شرید بن سوید رضی اللہ عنہ کہتے ہیں کہ  میں نے عرض کیا: اللہ کے رسول! ایک زمین ہے جس میں کسی کا حصہ ن",,,,,2496
2497,ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایسی جائیداد میں شفعہ کا حکم د,,,,,2497
2498,"ابورافع رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  شریک  ( ساجھی دار )  اپنی",,,,,2498
2499,جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے شفعہ ہر اس جائیداد میں ٹ,,,,,2499
2500,"عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  شفعہ اونٹ کی رسی",,,,,2500
2501,"عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  شریک کو شریک پر ",,,,,2501
