hadiths[2]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
1596,حضرت جابر بن عبداللہ رضی اللہ عنہ سے روایت ہے کہ بے شک ایک اعرابی نے رسول اللہ ﷺ سے اسلام پر بیعت کی,,,1596,,
1597,"حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا :’’ مجھے ایک ایسی بستی ( کی طرف ہجرت",,,1597,,
