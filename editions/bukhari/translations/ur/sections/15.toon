{"hadithnumber": "1005", "text": "ہم سے ابونعیم فضل بن دکین نے بیان کیا، انہوں نے کہا کہ ہم سے سفیان ثوری نے عبداللہ بن ابی بکر سے بیا"}
{"hadithnumber": "1006", "text": "ہم سے قتیبہ بن سعید نے بیان کیا انہوں نے کہا کہ ہم سے مغیرہ بن عبدالرحمٰن نے بیان کیا، ان سے ابوالزن"}
{"hadithnumber": "1007", "text": "ہم سے امام حمیدی نے بیان کیا، کہا کہ ہم سے سفیان ثوری نے بیان کیا، ان سے سلیمان اعمش نے، ان سے ابوال"}
{"hadithnumber": "1009", "text": "اور عمر بن حمزہ نے بیان کیا کہ ہم سے سالم نے اپنے والد سے بیان کیا وہ کہا کرتے تھے کہ  اکثر مجھے شاع"}
{"hadithnumber": "1010", "text": "ہم سے حسن بن محمد بن صباح نے بیان کیا، کہا کہ ہم سے محمد بن عبداللہ بن مثنی انصاری نے بیان کیا، کہا"}
{"hadithnumber": "1011", "text": "ہم سے اسحاق بن ابراہیم نے بیان کیا، انہوں نے کہا کہ ہم سے وہب بن جریر نے بیان کیا، انہوں نے کہا ہمیں"}
{"hadithnumber": "1012", "text": "ہم سے علی بن عبداللہ مدینی نے بیان کیا، انہوں نے کہا کہ ہم سے سفیان بن عیینہ نے عبداللہ بن ابی بکر س"}
{"hadithnumber": "1013", "text": "ہم سے محمد بن مرحوم بیکندی نے بیان کیا، انہوں نے کہا کہ ہم سے ابوضمرہ انس بن عیاض نے بیان کیا، انہوں"}
{"hadithnumber": "1014", "text": "ہم سے قتیبہ بن سعید نے بیان کیا، انہوں نے کہا کہ ہم سے اسماعیل بن جعفر نے بیان کیا، ان سے شریک نے بی"}
{"hadithnumber": "1015", "text": "ہم سے مسدد بن مسرہد نے بیان کیا، انہوں نے کہا کہ ہم سے ابوعوانہ نے بیان کیا، ان سے قتادہ نے بیان کیا"}
{"hadithnumber": "1016", "text": "ہم سے عبداللہ بن مسلمہ قعنبی نے بیان کیا، ان سے امام مالک نے بیان کیا، ان سے شریک بن عبداللہ بن ابی"}
{"hadithnumber": "1017", "text": "ہم سے اسماعیل بن ابی ایوب نے بیان کیا، انہوں نے کہا کہ مجھ سے امام مالک نے بیان کیا، انہوں نے شریک ب"}
{"hadithnumber": "1018", "text": "ہم سے حسن بن بشر نے بیان کیا، انہوں نے کہا کہ ہم سے معافی بن عمران نے بیان کیا کہ ان سے امام اوزاعی"}
{"hadithnumber": "1019", "text": "ہم سے عبداللہ بن یوسف تنیسی نے بیان کیا، انہوں نے کہا کہ ہمیں امام مالک رحمہ اللہ نے شریک بن عبداللہ"}
{"hadithnumber": "1020", "text": "ہم سے محمد بن کثیر نے بیان کیا، ان سے سفیان ثوری نے، انہوں نے بیان کیا کہ ہم سے منصور اور اعمش نے بی"}
{"hadithnumber": "1021", "text": "مجھ سے محمد بن ابی بکر نے بیان کیا، کہا کہ ہم سے معتمر بن سلیمان نے عبیداللہ عمری سے بیان کیا، ان سے"}
{"hadithnumber": "1022", "text": "ہم سے ابونعیم فضل بن دکین نے بیان کیا، ان سے زہیر نے، ان سے ابواسحاق نے کہ  عبداللہ بن یزید انصاری ر"}
{"hadithnumber": "1023", "text": "ہم سے ابوالیمان حکیم بن نافع نے بیان کیا، انہوں نے کہا کہ ہمیں شعیب نے خبر دی، انہیں زہری نے، انہوں"}
{"hadithnumber": "1024", "text": "ہم سے ابونعیم فضل بن دکین نے بیان کیا، کہا کہ ہم سے ابن ابی ذئب نے زہری سے بیان کیا، ان سے عباد بن ت"}
{"hadithnumber": "1025", "text": "ہم سے آدم بن ابی ایاس نے بیان کیا، انہوں نے کہا کہ ہم سے ابن ابی ذئب نے زہری سے بیان کیا، ان سے عباد"}
{"hadithnumber": "1026", "text": "مجھ سے قتیبہ بن سعید نے بیان کیا، انہوں نے کہا کہ ہم سے سفیان بن عیینہ نے عبداللہ بن ابی بکر سے بیان"}
{"hadithnumber": "1027", "text": "ہم سے عبداللہ بن محمد مسندی نے بیان کیا، انہوں نے کہا کہ ہم سے سفیان بن عیینہ نے عبداللہ بن ابی بکر"}
{"hadithnumber": "1028", "text": "ہم سے محمد بن سلام بیکندی نے بیان کیا، کہا کہ ہمیں عبدالوہاب ثقفی نے خبر دی، انہوں نے کہا کہ ہمیں یح"}
{"hadithnumber": "1029", "text": "ایوب بن سلیمان نے کہا کہ مجھ سے ابوبکر بن ابی اویس نے بیان کیا، انہوں نے سلیمان بن بلال سے بیان کیا"}
{"hadithnumber": "1030", "text": "عبدالعزیز اویسی نے کہا کہ مجھ سے محمد بن جعفر نے بیان کیا ان سے یحییٰ بن سعید اور شریک نے، انہوں نے"}
{"hadithnumber": "1031", "text": "ہم سے محمد بن بشار نے بیان کیا، انہوں نے کہا کہ ہم سے یحییٰ بن سعید قطان اور محمد بن ابراہیم بن عدی"}
{"hadithnumber": "1032", "text": "ہم سے محمد بن مقاتل نے بیان کیا، انہوں نے کہا کہ ہمیں عبداللہ بن مبارک نے خبر دی، کہا کہ ہمیں عبیدال"}
{"hadithnumber": "1033", "text": "ہم سے محمد بن مقاتل نے بیان کیا، انہوں نے کہا کہ ہمیں عبداللہ بن مبارک نے خبر دی، انہوں نے کہا کہ ہم"}
