{"hadithnumber": "1232", "text": "قاسم بن محمد رحمہ اللہ کہتے ہیں کہ ( اموی بادشاہ ) یزید بن عبدالملک نے کچھ مردوں اور ان کی بیویوں کے"}
{"hadithnumber": "1233", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے ، انھوں نے فرمایا کہ جب ام ولد لونڈی کا آقا فوت ہو جا"}
{"hadithnumber": "1234", "text": "قاسم بن محمد سے روایت ہے ، وہ کہا کرتے تھے کہ ام ولد لونڈی کا آقا جب فوت ہو جائے تو اس کی عدت ایک حی"}
{"hadithnumber": "1235", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ سعید بن مسیب اور سلیمان بن یسار رحمہ اللہ فرمایا کرتے تھے کہ"}
{"hadithnumber": "1236", "text": "امام مالک کہتے ہیں کہ امام ابن شہاب سے بھی اسی کی مثل قول منقول ہے ۔"}
{"hadithnumber": "1237", "text": "ابن محیریز رحمہ اللہ سے روایت ہے ، کہتے ہیں کہ میں مسجد ( نبوی ) میں داخل ہوا تو میں نے حضرت ابوسعید"}
{"hadithnumber": "1238", "text": "عامر بن سعد بن ابی وقاص رحمہ اللہ اپنے والد ( حضرت سعد بن ابی وقاص رضی اللہ عنہ ) سے روایت کرتے ہیں"}
{"hadithnumber": "1239", "text": "حضرت ابوایوب انصاری رضی اللہ عنہ کی ام ولد سے روایت ہے کہ وہ ( حضرت ابوایوب رضی اللہ عنہ ) عزل کر لی"}
{"hadithnumber": "1240", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ وہ عزل کو مکروہ جانتے تھے اور عزل نہیں کرتے تھے ۔"}
{"hadithnumber": "1241", "text": "حضرت حجاج بن عمرو بن غزیہ رضی اللہ عنہ سے روایت ہے کہ وہ حضرت زید بن ثابت رضی اللہ عنہ کے ہمراہ بیٹھ"}
{"hadithnumber": "1242", "text": "حمید بن قیس مکی اس شخص سے روایت کرتے ہیں جسے ذفیف کہا جاتا تھا ، وہ کہتے ہیں کہ حضرت ابن عباس رضی ال"}
{"hadithnumber": "1243", "text": "حمید بن نافع رحمہ اللہ سے روایت ہے کہ حضرت زینب بنت ابی سلمہ رضی اللہ عنہا نے انھیں تین احادیث کی خب"}
{"hadithnumber": "1244", "text": "سیدہ عائشہ اور سیدہ حفصہ رضی اللہ عنہما ازواج رسول ﷺ سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا :’’ وہ عور"}
{"hadithnumber": "1245", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ سیدہ ام سلمہ رضی اللہ عنہا زوجہ رسول ﷺ نے ایک عورت سے فرمایا"}
{"hadithnumber": "1246", "text": "سالم بن عبداللہ اور سلیمان بن یسار رحمۃ اللہ علیہما سے روایت ہے ، وہ دونوں اس عورت جس کا خاوند فوت ہ"}
{"hadithnumber": "1247", "text": "صفیہ بنت ابی عبید سے روایت ہے کہ ان کی آنکھ دکھنے لگی ، اس حال میں کہ وہ اس وقت اپنے خاوند حضرت عبدا"}
{"hadithnumber": "1248", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ رسول اللہ ﷺ سیدہ ام سلمہ رضی اللہ عنہا زوجہ پیغمبر ﷺ کے پاس گ"}
{"hadithnumber": "1249", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ بے شک سیدہ ام سلمہ رضی اللہ عنہا زوجہ رسول ﷺ فرمایا کرتی تھیں"}
{"hadithnumber": "1250", "text": "اُمّ المومنین سیدہ عائشہ رضی اللہ عنہا سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ ان کے پاس موجود تھے اور ( ا"}
{"hadithnumber": "1251", "text": "ام المومنین سیدہ عائشہ رضی اللہ عنہا سے روایت ہے ، کہتی ہیں کہ میرے رضاعی چچا جان آئے ، وہ میرے پاس"}
{"hadithnumber": "1252", "text": "ام المومنین سیدہ عائشہ رضی اللہ عنہا سے روایت ہے کہ بے شک ( ان کے رضاعی والد ) ابوالقعیس کے بھائی حض"}
{"hadithnumber": "1253", "text": "حضرت عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے ، وہ فرمایا کرتے تھے کہ جو ( دودھ ) دو سال میں ( پلا"}
{"hadithnumber": "1254", "text": "عمرو بن شرید رحمہ اللہ سے روایت ہے کہ حضرت عبداللہ بن عباس رضی اللہ عنہما سے ایک مرد کے متعلق سوال ک"}
{"hadithnumber": "1255", "text": "حضرت نافع سے روایت ہے کہ حضرت عبداللہ بن عمر رضی اللہ عنہما فرمایا کرتے تھے کہ کوئی رضاعت ثابت نہیں"}
{"hadithnumber": "1256", "text": "سالم بن عبداللہ رحمہ اللہ سے روایت ہے کہ سیدہ عائشہ رضی اللہ عنہا نے انھیں اپنی ہمشیرہ ام کلثوم بنت"}
{"hadithnumber": "1257", "text": "صفیہ بنت ابی عبید رحمہ اللہ سے روایت ہے کہ ام المومنین سیدہ حفصہ رضی اللہ عنہا نے عاصم بن عبداللہ بن"}
{"hadithnumber": "1258", "text": "عبدالرحمن بن قاسم اپنے والد ( قاسم بن محمد بن ابی بکر ) سے روایت کرتے ہیں کہ سیدہ عائشہ رضی اللہ عنہ"}
{"hadithnumber": "1259", "text": "ابراہیم بن عقبہ سے روایت ہے کہ انھوں نے سعید بن مسیب سے رضاعت کے متعلق سوال کیا تو سعید نے فرمایا :"}
{"hadithnumber": "1260", "text": "یحیی بن سعید رحمہ اللہ سے روایت ہے ، انھوں نے کہا کہ میں نے سعید بن مسیب رحمہ اللہ کو یہ فرماتے ہوئے"}
{"hadithnumber": "1261", "text": "ابن شہاب رحمہ اللہ سے روایت ہے ، وہ فرمایا کرتے تھے : دودھ پلانا خواہ قلیل ہو یا کثیر ، وہ حرمت ثابت"}
{"hadithnumber": "1262", "text": "ابن شہاب رحمہ اللہ سے روایت ہے ، ان سے ’’ رضاعت کبیر ‘‘ کے متعلق سوال کیا گیا تو انھوں نے فرمایا : م"}
{"hadithnumber": "1263", "text": "عبداللہ بن دینار رحمہ اللہ سے روایت ہے کہ ایک آدمی حضرت عبداللہ بن عمر رضی اللہ عنہما کے پاس آیا اس"}
{"hadithnumber": "1264", "text": "یحیی بن سعید رحمہ اللہ سے روایت ہے کہ ایک آدمی نے حضرت ابو موسیٰ اشعری رضی اللہ عنہ سے سوال کیا ، کہ"}
{"hadithnumber": "1265", "text": "سیدہ عائشہ رضی اللہ عنہا سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا :’’ رضاعت سے وہ ( سب ) کچھ حرام ہو جات"}
{"hadithnumber": "1266", "text": "ام المومنین سیدہ عائشہ رضی اللہ عنہا حضرت جدامہ بنت وہب اسدیہ رضی اللہ عنہا سے روایت کرتی ہیں کہ انھ"}
{"hadithnumber": "1267", "text": "سیدہ عائشہ رضی اللہ عنہا زوجہ رسول ﷺ سے روایت ہے انھوں نے کہا کہ قرآن مجید میں سے جو کچھ نازل ہوا تھ"}
{"hadithnumber": "1268", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا :’’ جو شخص ( مشترک ) غلام می"}
{"hadithnumber": "1269", "text": "حسن بن ابی الحسن بصری اور محمد بن سیرین رحمۃ اللہ علیہما سے روایت ہے کہ بے شک ایک آدمی نے رسول اللہ"}
{"hadithnumber": "1270", "text": "ربیعہ بن ابی عبدالرحمن رحمہ اللہ سے روایت ہے کہ ( خلیفہ عبدالملک بن مروان کی جانب سے مدینہ منورہ پر"}
{"hadithnumber": "1271", "text": "ابن شہاب رحمہ اللہ سے روایت ہے ، وہ کہتے ہیں کہ سنت یہی جاری ہو چکی ہے کہ بے شک غلام جب آزاد کیا جائ"}
