{"hadithnumber": "5385", "text": "امام مالک نے نافع سے ،  انھوں نے زید بن عبد اللہ سے ،  انھوں نے عبد اللہ بن عبد الرحمٰن بن ابوبکرصدی"}
{"hadithnumber": "5386", "text": "قتیبہ اور محمد بن رمح نے ہمیں لیث بن سعد سے یہی حدیث بیان کی ۔ یہی حدیث مجھے علی بن حجر سعدی نے بیان"}
{"hadithnumber": "5387", "text": "عثمان بن مرہ نے کہا  :  ہمیں عبد اللہ بن عبد الرحمٰن نے اپنی خالہ حضرت ام سلمہ  رضی اللہ تعالیٰ عنہا"}
{"hadithnumber": "5388", "text": "ابو خیثمہ  )  زہیر نے کہا  :  ہمیں اشعث نے حدیث بیان کی ،  کہا  :  مجھے معاویہ بن سوید بن مقرن نے حد"}
{"hadithnumber": "5389", "text": "ابو عوانہ نے ہمیں اشعث بن سلیم سے اسی سند کے ساتھ اسی کے مانند حدیث سنا ئی ،  سوائے  \" اپنی قسم یا ق"}
{"hadithnumber": "5390", "text": "علی مسہر اور جریر دونوں نے شیبانی سے انھوں نے اشعث بن ابی شعثاء سے اسی سندکے ساتھ زہیر کی حدیث کے ما"}
{"hadithnumber": "5391", "text": "ابن ادریس نے کہا  :  ہمیں ابو اسحٰق شیبانی اور لیث بن ابی سلیم نے اشعث بن ابی شعثاء سے ان سب کی سند"}
{"hadithnumber": "5392", "text": "شعبہ نے اشعث بن سلیم سے ان سب کی سند کے ساتھ ان کی حدیث کے ہم معنی حدیث بیان کی ، سوائے ان کے روایت"}
{"hadithnumber": "5394", "text": "سعید بن عمرو بن سہل بن اسحٰق بن محمد بن اشعث بن قیس نے کہا  :  ہمیں سفیان بن عیینہ  نے حدیث بیان کی"}
{"hadithnumber": "5395", "text": "ابن ابی عمر نے ہمیں یہی حدیث بیان کی کہا  :  ہمیں سفیان نے ابو فروہ جہنی سے حدیث سنائی ،  کہا  :  می"}
{"hadithnumber": "5396", "text": "ابن ابی نجيح نے پہلے ہمیں مجا ہد سے  ، انھوں نے ابن ابی لیلیٰ سے ،  انھوں نے حضرت حذیفہ سے روایت کی"}
{"hadithnumber": "5397", "text": "عبید اللہ کے والد معاذ عنبری نے کہا  :  ہمیں شعبہ نے حکم سے حدیث بیان کی انھوں نے عبد الرحمٰن بن ابی"}
{"hadithnumber": "5398", "text": "وکیع محمد بن جعفر ابن ابی عدی اور بہز  ، ان سب نے شعبہ سے معاذ کی حدیث کے مانند انھی کی سند کے ساتھ"}
{"hadithnumber": "5399", "text": "منصور اور ابن عون دونوں نے مجا ہد سے  ،  انھوں نے عبد الرحمٰن بن ابی لیلیٰ سے  ، انھوں نے حضرت حذیفہ"}
{"hadithnumber": "5400", "text": "‏سیف نے کہا کہ میں نے مجا ہد کو کہتے و ئے سنا ،  عبد اللہ الرحمن بن ابی لیلیٰ سے سنا ،  حضرت حذیفہ"}
{"hadithnumber": "5401", "text": "مالک نے نافع سے ،  انھوں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے روایت کی کہ حضرت عمر بن خطاب  رضی ا"}
{"hadithnumber": "5402", "text": "عبید اللہ اور موسیٰ بن عقبہ دونوں نے نا فع سے ،  انھوں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے ،  ان"}
{"hadithnumber": "5403", "text": "جریر بن حازم نے کہا  :  ہمیں نافع نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سےروایت بیان کی کہا :  حضرت ع"}
{"hadithnumber": "5404", "text": "یو نس نے ابن شہاب سے روایت کی ،  کہا  :  مجھے سالم بن عبد اللہ نے حدیث بیان کی کہ حضرت عبد اللہ بن ع"}
{"hadithnumber": "5405", "text": "عمرو بن حارث نے ابن شہاب سے اسی سند کے ساتھ اسی کے مانند روایت بیان کی ۔"}
{"hadithnumber": "5406", "text": "یحییٰ بن سعید نے شعبہ سے روایت کی ، کہا :  مجھے ابو بکر بن حفص نے سالم سے خبر دی ، انھوں نے حضرت ابن"}
{"hadithnumber": "5407", "text": "روح نے کہا : ہمیں شعبہ نے حدیث بیان کی ، کہا : ہمیں ابو بکر بن حفص نے سالم بن عبداللہ بن عمر سے حدیث"}
{"hadithnumber": "5408", "text": "یحییٰ بن ابی اسحاق نے حدیث بیان کی ، کہا : سالم بن عبداللہ نے مجھ سے استبرق کے متعلق دریافت کیا ، کہ"}
{"hadithnumber": "5409", "text": "حضرت  اسماء بنت ابو بکر صدیق  رضی اللہ تعالیٰ عنہ  کے آزاد  کردہ غلام عبداللہ ( کیسان )  سے روایت ہے"}
{"hadithnumber": "5410", "text": "شعبہ نے خلیفہ بن کعب ابی زبیان سے روایت کی  ، کہا : میں نے حضرت عبداللہ بن زبیر رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "5411", "text": "احمد بن عبداللہ بن یونس نے  ہمیں حدیث بیان کی  ، کہا : ہمیں زہیر نے حدیث بیان کی  ، کہا : ہمیں عاصم"}
{"hadithnumber": "5412", "text": "جریر بن عبدالحمید اور حفص بن غیاث دونوں نے عاصم سے اسی سند کے ساتھ نبی کریم صلی اللہ علیہ وسلم  سے ر"}
{"hadithnumber": "5413", "text": "جریر نے سلیمان تیمی سے  ، انھوں نے ابو عثمان سے  روایت کی ، کہا : ہم عتبہ بن فرقد  رضی اللہ تعالیٰ ع"}
{"hadithnumber": "5414", "text": "معتمر نے اپنے والد ( سلیمان تیمی )  سے حدیث بیان کی ، کہا : ہمیں ابو عثمان نے حدیث بیان کی  ، کہا :"}
{"hadithnumber": "5415", "text": "شعبہ نے قتادہ سے روایت کی ، کہا : میں نے ابوعثمان نہدی سے سنا ، کہا : ہمارے پاس حضرت عمر رضی اللہ تع"}
{"hadithnumber": "5416", "text": "ہشام نے قتادہ سے اسی سند کے ساتھ ، اسی کے مانند حدیث بیان کی اور ابو عثمان کا قول ذکر نہیں کیا ۔"}
{"hadithnumber": "5417", "text": "معاذ کے والد ہشام نےقتادہ سے ، انھوں نے عامر شعبی سے  روایت کی ، انھوں نے حضرت سوید بن غفلہ رضی اللہ"}
{"hadithnumber": "5418", "text": "سعید نے قتادہ سے اسی سند کے ساتھ اسی کے مانند روایت کی ۔"}
{"hadithnumber": "5419", "text": "ابو زبیر نے کہا کہ انھوں نے حضرت جابر بن عبداللہ رضی اللہ تعالیٰ عنہ  سے سنا ، کہہ رہے تھے  : نبی کر"}
{"hadithnumber": "5420", "text": "عبدالرحمان بن مہدی نے کہا : ہمیں شعبہ نے ابو عون سے حدیث بیان کی ، کہا : میں نے ابو صالح سے سنا ،  و"}
{"hadithnumber": "5421", "text": "عبیداللہ کے والد معاذ اور محمد بن جعفر  ، دونوں نے کہا : ہمیں شعبہ نے ابو عون سے اسی سند کے ساتھ حدی"}
{"hadithnumber": "5422", "text": "ابو بکر بن ابی شیبہ ، ابو کریب اور زہیر بن حرب نے ہمیں حدیث بیان کی ۔ الفاظ زہیر کے ہیں ۔ کہا :  ہیں"}
{"hadithnumber": "5423", "text": "زید بن وہب نے حضرت علی بن ابی طالب  رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا :  رسول اللہ  صلی اللہ عل"}
{"hadithnumber": "5424", "text": "حضرت انس بن مالک رضی اللہ تعالیٰ عنہ  سے روایت کہ رسول اللہ  صلی اللہ علیہ وسلم  نے حضرت عمر رضی الل"}
{"hadithnumber": "5425", "text": "حضرت انس  رضی اللہ تعالیٰ عنہ سے روایت ہے کہ رسول اللہ  صلی اللہ علیہ وسلم  نے فرمایا؛ \" جس شخص نے د"}
{"hadithnumber": "5426", "text": "حضرت ابو امامہ  رضی اللہ تعالیٰ عنہ  نے حدیث سنائی کہ رسول اللہ  صلی اللہ علیہ وسلم  نے فرمایا؛ \"  ج"}
{"hadithnumber": "5427", "text": "لیث نے یزید بن ابی حبیب سے ، انھوں نے ابو الخیر سے  ، انھوں نے حضرت عقبہ بن عامر رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "5428", "text": "عبدالحمید نے جعفر نے کہا :  مجھے یزید بن ابی حبیب نے اسی سند کے ساتھ حدیث بیان کی ۔"}
{"hadithnumber": "5429", "text": "ابو اسامہ نے ہمیں سعید بن ابی عروبہ سے حدیث بیان کی ،  کہا  :  قتادہ نے ہمیں حدیث سنائی کہ انس بن ما"}
{"hadithnumber": "5430", "text": "محمد بن بشر نے کہا  : ہمیں سعید نے اسی سند کے ساتھ حدیث بیان کی اور سفر میں  \"  کا ذکر کیا ۔"}
{"hadithnumber": "5431", "text": "وکیع نے شعبہ سے  ، انھوں نے قتادہ سے  ، انھوں نے حضرت انس رضی اللہ تعالیٰ عنہ  سے روایت کی  ،  کہا"}
{"hadithnumber": "5432", "text": "محمد بن جعفر نے ہمیں حدیث بیان کی کہا  :  ہمیں شعبہ نے اسی سند کے ساتھ اسی مانند حدیث بیان کی  ۔"}
{"hadithnumber": "5433", "text": "ہمام نے حدیث بیان کی کہا  :  ہمیں قتادہ نے حدیث سنا ئی کہ حضرت انس رضی اللہ تعالیٰ عنہ  نے انھیں بتا"}
{"hadithnumber": "5434", "text": "معاذ بن ہشام نے ہمیں بیان کیا  ، کہا  : مجھے میرے والد نے یحییٰ ( بن ابی کثیر ) سے حدیث بیان کی ،  ک"}
{"hadithnumber": "5435", "text": "یزید بن ہارون نے کہا  :  ہمیں ہشام نے خبر دی وکیع نے علی بن مبارک سے بیان کیا  ، ہشام اور علی بن مبا"}
{"hadithnumber": "5436", "text": "طاوس نے حضرت عبد اللہ بن عمرو  رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہا  :  رسول اللہ  صلی اللہ علیہ"}
{"hadithnumber": "5437", "text": "نافع نے ابرا ہیم بن عبد اللہ حنین سے انھوں نے اپنے والد سے ،  انھوں نے حضرت علی بن ابی طالب رضی اللہ"}
{"hadithnumber": "5438", "text": "یونس نے ابن شہاب سے روایت کی ،  کہا  : مجھے ابرا ہیم بن عبد اللہ بن حنین نے حدیث بیان کی ان کے والد"}
{"hadithnumber": "5439", "text": "معمر نے زہری سے ،  انھوں نے ابرا ہیم بن عبد اللہ حنین سے انھوں نے اپنے والد حضرت علی بن ابی طا لب  ر"}
{"hadithnumber": "5440", "text": "ہمام نے کہا  :  ہمیں قتادہ نے حدیث بیان کی  ، کہا  :  ہم نے حضرت انس بن ما لک رضی اللہ تعالیٰ عنہ  س"}
{"hadithnumber": "5441", "text": "ہشام نے قتادہ سے انھوں نے حضرت انس  رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہا  رسول اللہ  صلی اللہ علی"}
{"hadithnumber": "5442", "text": "سلیمان بن مغیرہ نے کہا  :  ہمیں حمید نے ابو بردہ سے حدیث سنائی  ، کہا  :  میں حضرت عائشہ رضی اللہ تع"}
{"hadithnumber": "5443", "text": "علی بن حجر سعدی محمد بن حاتم اور یعقوب بن ابرا ہیم نے  ( اسماعیل )  ابن علیہ سے حدیث بیان کی  ، انھو"}
{"hadithnumber": "5444", "text": "معمرنے ایوب سے اسی سند کے ساتھ اسی کے مانند روایت کی اور کہا  :  \" موٹا تہبند  ۔  "}
{"hadithnumber": "5445", "text": "صفیہ بنت شیبہ رضی اللہ تعالیٰ عنہا   نے حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے روایت کی ،  کہا  :  ایک"}
{"hadithnumber": "5446", "text": "عبد ہ بن سلیمان نے ہمیں ہشام بن عروہ سے حدیث سنائی  ، انھوں نے اپنے والد سے ،  انھوں نے حضرت عائشہ"}
{"hadithnumber": "5447", "text": "علی بن مسہر نے ہمیں ہشام بن عروہ سے خبر دی  ، انھوں نے اپنے والد سے انھوں نے حضرت عائشہ  رضی اللہ تع"}
{"hadithnumber": "5448", "text": "ابن نمیر اور ابو معاویہ دونوں نے ہمیں ہشام بن عروہ سے اسی سند کے ساتھ خبر دی اور کہا  :  \"  رسول الل"}
{"hadithnumber": "5449", "text": "قتیبہ بن سعید  ، عمروناقد اور اسحٰق بن ابرا ہیم نے کہا  :  ہمیں سفیان نے ابن منکدرسے حدیث بیان کی  ،"}
{"hadithnumber": "5450", "text": "وکیع نے ہمیں سفیان سے حدیث بیان کی ، انھوں نے محمد  بن منکدرسےانھوں نے حضرت جابر عبد اللہ   رضی اللہ"}
{"hadithnumber": "5451", "text": "عبد الرحمن نے کہا  :  ہمیں سفیان نے اسی سند کے ساتھ حدیث بیان کی اور اور یہ اضا فہ کیا  :  تو میں اس"}
{"hadithnumber": "5452", "text": "حضرت جابر بن عبد اللہ  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ رسول اللہ  صلی اللہ علیہ وسلم  نے ان سے ف"}
{"hadithnumber": "5453", "text": "امام مالک نے نافع عبد اللہ بن دینا اور زید بن اسلم سے روایت کی ،  ان سب نے انھیں حضرت ابن عمر رضی ال"}
{"hadithnumber": "5454", "text": "عبید اللہ ایوب لیث بن سعد اور اسامہ ان سب نے نافع سے انھوں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے م"}
{"hadithnumber": "5455", "text": "عمربن محمد نے اپنے والد سالم بن عبد اللہ اور نافع سے روایت کی ،  انھوں نے نے حضرت عبد اللہ بن عمر رض"}
{"hadithnumber": "5456", "text": "محارب بن دثاراور جبلہ بن سحیم نے ابن عمر  رضی اللہ تعالیٰ عنہ  سے  ،  انھوں نے نبی اکرم  صلی اللہ عل"}
{"hadithnumber": "5457", "text": "عبد اللہ بن نمیر نے کہا  :  ہمیں حنظلہ نے حدیث بیان کی ،  کہا  :  میں نے سالم سے انھوں نے حضرت ابن ع"}
{"hadithnumber": "5458", "text": "اسحق بن سلیمان نے کہا  :  ہمیں حنظلہ بن ابی سفیان نے حدیث بیان کی ،  کہا  :  میں نے سالم سے سنا ،  ا"}
{"hadithnumber": "5459", "text": "شعبہ نے کہا  :  میں نے مسلم بن یناق سے سنا ،  وہ حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے حدیث بیان کررہ"}
{"hadithnumber": "5460", "text": "عبد الملک بن ابی سلیمان ابو یو نس اور ابرا ہیم بن نافع ان سب نے مسلم بن یناق سے ،  انھوں نے حضرت ابن"}
{"hadithnumber": "5461", "text": "ہمیں ابن جریج نے حدیث بیان کی ،  کہا  :  میں نے محمد بن عباد بن جعفر سے سنا ،  کہہ رہے تھے  :  میں ن"}
{"hadithnumber": "5462", "text": "عبد اللہ بن واقد نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہا  :  میں رسول اللہ  صلی اللہ"}
{"hadithnumber": "5463", "text": "عبید اللہ کے والد معاذ نے کہا  :  ہمیں شعبہ نے محمد بن زیاد  سے روایت کی  ، کہا  :  میں نے حضرت ابو"}
{"hadithnumber": "5464", "text": "محمد بن بشار نے کہا  :  ہمیں محمد بن جعفر نے حدیث بیان کی  ۔ اور ابن مثنیٰ نے کہا  :  ہمیں ابن ابی ع"}
{"hadithnumber": "5465", "text": "ربیع  بن مسلم نے محمد بن زیا د سے ، انھوں نے حضرت ابوہریرہ رضی اللہ تعالیٰ عنہ  سے انھوں نے نبی  صلی"}
{"hadithnumber": "5466", "text": "شعبہ نے ہمیں محمد بن زیاد سے حدیث بیان کی ،  انھوں نے ابوہریرہ رضی اللہ تعالیٰ عنہ  سے انھوں نے نبی"}
{"hadithnumber": "5467", "text": "عرج نے حضرت ابو ہریرہ  رضی اللہ تعالیٰ عنہ  سے روایت کی کہ رسول اللہ  صلی اللہ علیہ وسلم  نے فرما یا"}
{"hadithnumber": "5468", "text": "معمر نے ہمام بن منبہ سے خبر دی کہا  :  یہ اھادیث ہیں جو حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ نے ہمیں س"}
{"hadithnumber": "5469", "text": "ابو رفع نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی کہا میں نے رسول اللہ  صلی اللہ علیہ وسلم"}
{"hadithnumber": "5470", "text": "عبید اللہ کے والد معاذ نے کہا  :  ہمیں شعبہ نے قتادہ سے حدیث بیان کی  ، انھوں نے نضر بن انس سے ،  ان"}
{"hadithnumber": "5471", "text": "محمد بن مثنیٰ اور ابن بشار نے کہا  :  ہمیں محمد بن جعفر نے حدیث بیان کی ،  کہا  :  ہمیں شعبہ نے اسی"}
{"hadithnumber": "5472", "text": "حضرت ابن عباس رضی اللہ تعالیٰ عنہ  کے آزاد غلام کریب نے حضرت عبد اللہ بن عباس رضی اللہ تعالیٰ عنہ  س"}
{"hadithnumber": "5473", "text": "یحییٰ بن یحییٰ تمیمی محمد بن رمح اور قتیبہ نے کہا  :  ہمیں لیث نے نافع سے خبر دی  ، انھوں نے حضرت عب"}
{"hadithnumber": "5474", "text": "محمد بن بشر یحییٰ بن سعید خالد بن حارث اور عقبہ بن خا لد سب نے عبید اللہ سے ،  انھوں نے نافع سے ،  ا"}
{"hadithnumber": "5475", "text": "ایو ب مو سیٰ بن عقبہ اور اسامہ سب نے نافع سے ،  انھوں نے ابن عمر رضی اللہ تعالیٰ عنہ  سے ،  انھوں نے"}
{"hadithnumber": "5476", "text": "عبد اللہ بن نمیر نے عبید اللہ سے ،  انھوں نے نافع سے ،  انھوں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  س"}
{"hadithnumber": "5477", "text": "نافع نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے ر وایت کی ، کہا : رسول اللہ  صلی اللہ علیہ وسلم  نے سون"}
{"hadithnumber": "5478", "text": "حماد نے ہمیں عبدالعزیز بن صہیب سے خبر دی ، انھوں نے حضرت انس بن مالک رضی اللہ تعالیٰ عنہ  سے روایت ک"}
{"hadithnumber": "5479", "text": "اسماعیل ( ابن علیہ )  نے عبدالعزیز بن صہیب سے حدیث بیان کی ، انھوں نے حضرت انس رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "5480", "text": "شعبہ نے ہمیں حدیث بیان کی ، کہا :  میں نے قتادہ کو حضرت انس بن مالک رضی اللہ تعالیٰ عنہ  سے حدیث بیا"}
{"hadithnumber": "5481", "text": "معاذ بن ہشام نے ہمیں حدیث بیان کی ، کہا : مجھے میرے والد نے قتادہ سے حدیث سنائی ، انھوں نے حضرت انس"}
{"hadithnumber": "5482", "text": "خالد بن قیس نے قتادہ سے ، انھوں نے حضرت انس رضی اللہ تعالیٰ عنہ  سے روایت کی کہ نبی کریم صلی اللہ عل"}
{"hadithnumber": "5483", "text": "ابراہیم بن سعد نے ہمیں ابن شہاب سے خبر دی ، انھوں نے حضرت  انس رضی اللہ تعالیٰ عنہ  بن مالک سے روایت"}
{"hadithnumber": "5484", "text": "روح نے ہمیں حدیث بیان کی ، کہا : ہمیں ان جریج نے خبر دی ، کہا : مجھے زیاد نے بتایا کہ ابن شہاب نے ان"}
{"hadithnumber": "5485", "text": "ابو عاصم نے ابو جریج سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی ۔"}
{"hadithnumber": "5486", "text": "عبداللہ بن وہب مصری نے کہا : مجھے یونس بن یزید نے ابن شہاب سے خبر دی ، کہا : مجھے حضرت انس بن مالک ر"}
{"hadithnumber": "5487", "text": "طلحٰہ بن یحییٰ انصاری نے یونس سے ، انھوں نے ابن شہاب سے ، انھوں نے حضرت انس بن مالک رضی اللہ تعالیٰ"}
{"hadithnumber": "5488", "text": "سلیمان بن بلال نے یونس بن یزید سے  اسی سندکے ساتھ طلحہ بن یحییٰ کی حدیث کے مانند بیان کیا ۔"}
{"hadithnumber": "5489", "text": "ثابت نے حضرت انس رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا : نبی کریم صلی اللہ علیہ وسلم  کی انگوٹھی اس"}
{"hadithnumber": "5490", "text": "ابن ادریس نے کہا : میں نے عاصم بن کلیب سے سنا ، انھوں نے ابو بردہ  رضی اللہ تعالیٰ عنہ  سے  ، انھوں"}
{"hadithnumber": "5491", "text": "سفیان نے عاصم بن کلیب سے ، انھوں نے ابو موسیٰ ( اشعری رضی اللہ تعالیٰ عنہ  )  کے ایک بیٹے سے روایت ک"}
{"hadithnumber": "5492", "text": "شعبہ نے عاصم بن کلیب سے روایت کی  ، کہا : میں نے ابو بردہ  رضی اللہ تعالیٰ عنہ  سے سنا ، انھوں نے کہ"}
{"hadithnumber": "5493", "text": "ابو احوص نے عاصم بن کلیب سے ، انھوں نے ابو بردہ رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا : حضر علی رضی"}
{"hadithnumber": "5494", "text": "ابو زبیرنے حضرت  جابر   رضی اللہ تعالیٰ عنہ  سے  روایت کی ، کہا : میں نے ایک غزوے کے دوران میں  ، جو"}
{"hadithnumber": "5495", "text": "محمد بن زیاد نے ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی کہ رسول اللہ  صلی اللہ علیہ وسلم  نے فرما"}
{"hadithnumber": "5496", "text": "اعرج نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے  روایت کی کہ رسول اللہ  صلی اللہ علیہ وسلم  نے فرمایا"}
{"hadithnumber": "5497", "text": "ابن ادریس نے اعمش سے  ، انھوں نے ابو رزین سے روایت کی  ، کہا :  حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "5498", "text": "علی بن مسہر نے کہا : ہمیں اعمش نے ابو رزین اور ابو صالح سے خبردی ، انھوں نے حضرت ابو ہریرہ رضی اللہ"}
{"hadithnumber": "5499", "text": "مالک بن انس نے ابو زبیر سے ، انھوں نے حضرت جابر  رضی اللہ تعالیٰ عنہ  سے  روایت کی کہ رسول اللہ  صلی"}
{"hadithnumber": "5500", "text": "ابو خیثمہ ( زہیر )  نے ابو زبیر سے ، انھوں نے حضرت جابر رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا : رسو"}
{"hadithnumber": "5501", "text": "لیث نے ابو زبیر سے ، انھوں نے حضرت جابر رضی اللہ تعالیٰ عنہ  سے  روایت کی کہ رسول اللہ  صلی اللہ علی"}
{"hadithnumber": "5502", "text": "ابن جریج نے کہا : مجھے ابو زبیر نے بتایا کہ انھوں نے حضرت  جابر بن عبداللہ   رضی اللہ تعالیٰ عنہ  سے"}
{"hadithnumber": "5503", "text": "عبیداللہ بن اخنس نے ابو زبیر سے ، انھوں نے حضرت جابر  بن عبداللہ  رضی اللہ تعالیٰ عنہ  سے روایت کی ک"}
{"hadithnumber": "5504", "text": "مالک نے ابن شہاب سے ، انہوں نے عباد بن تمیم سے ، انھوں نے اپنے چچا ( عبداللہ بن زید بن عاصم انصاری ر"}
{"hadithnumber": "5505", "text": "ابن عینیہ ، یونس اور معمر سب نے زہری سے اسی سند کے ساتھ اسی کے مانند روایت کی ۔"}
{"hadithnumber": "5506", "text": "یحییٰ بن یحییٰ  ، ابو ربیع اور قتیبہ بن سعید نے ہمیں حدیث بیان کی ۔ یحییٰ نے کہا : ہمیں خبر دی اور د"}
{"hadithnumber": "5507", "text": "اسماعیل بن علیہ نے ہمیں عبدالعزیز بن صہیب سے حدیث بیان کی ، انھوں نے حضرت انس رضی اللہ تعالیٰ عنہ  س"}
{"hadithnumber": "5508", "text": "ابوخیثمہ نے ابو زبیر سے ، انھوں نے حضرت جابر  رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا : فتح مکہ کے سا"}
{"hadithnumber": "5509", "text": "ابن جریج نے ابو زبیر سے ، انھوں نے حضرت جابر بن عبداللہ  رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا : فت"}
{"hadithnumber": "5510", "text": "حضرت ابو ہریرۃ رضی اللہ تعالیٰ عنہ سے روایت ہے کہ نبی  صلی اللہ علیہ وسلم نے فرمایا  :  \" یہود اوراو"}
{"hadithnumber": "5511", "text": "عبد العزیز بن ابی حازم نے اپنے والد سے ، انھوں نے ابو سلمہ بن عبد الرحمٰن سے ،  انھوں نے حضرت  عائشہ"}
{"hadithnumber": "5512", "text": "ہمیں وہب نے اسی سند کے ساتھ ابو حازم سے حدیث سنا ئی کہ جبرا ئیل  علیہ السلام نے رسول اللہ  صلی اللہ"}
{"hadithnumber": "5513", "text": "عبد اللہ بن عباس رضی اللہ تعالیٰ عنہ  نے کہا  :  حضرت میمونہ رضی اللہ تعالیٰ عنہا   نے مجھے بتا یا ک"}
{"hadithnumber": "5514", "text": "سفیان بن عیینہ نے زہری سے ،  انھوں نے عبید اللہ سے ،  انھوں نے ابن عباس رضی اللہ تعالیٰ عنہ  سے ،  ا"}
{"hadithnumber": "5515", "text": "یو نس نے مجھے ابن شہا ب سے  ،  خبر دی انھوں نے عبید اللہ بن عبد اللہ بن عتبہ سئے روایت کی کہ انھوں ن"}
{"hadithnumber": "5516", "text": "معمر نے زہری سے اسی سند کے ساتھ یو نس کی حدیث کے مانند اور سند میں خبر دینے کی صرا حت کرتے ہو ئے روا"}
{"hadithnumber": "5517", "text": "لیث نے ہمیں بکیر سے حدیث سنا ئی انھوں نے بسربن سعید سے ،  انھوں نے زید بن خالد سے ،  انھوں نے رسول ا"}
{"hadithnumber": "5518", "text": "مجھے عمرو بن حارث نے خبر دی کہ انھیں بکیر بن اشج نے حدیث سنا ئی  ، انھیں بسر بن سعید نے حدیث سنائی ک"}
{"hadithnumber": "5520", "text": "۔  ( سعید بن یسار نے )  کہا  :   ( یہ حدیث سن کر  )  میں حضرت عائشہ  رضی اللہ تعالیٰ عنہا   کے پاس گ"}
{"hadithnumber": "5523", "text": "ابو اسامہ نے ہشام ( بن عروہ )  سے  ، انھوں نے اپنے والد سے  ، انھوں نے حضرت عائشہ  رضی اللہ تعالیٰ ع"}
{"hadithnumber": "5524", "text": "عبدہ اور وکیع نے اسی سند کے ساتھ ہمیں ( ہشام بن عروہ سے )  حدیث بیان کی  ، عبدہ کی حدیث میں  \" آپ صل"}
{"hadithnumber": "5525", "text": "ابراہیم بن سعد نے زہری سے ، انہوں نے قاسم بن محمد سے ، انہوں نے حضرت عائشہ  رضی اللہ تعالیٰ عنہا   س"}
{"hadithnumber": "5526", "text": "یونس نے ابن شہاب سے  ، انھوں نے قاسم بن محمد سے ، انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عنہ  سے روایت"}
{"hadithnumber": "5527", "text": "سفیان بن عینیہ اور معمر نے زہری سے اسی سند کے ساتھ حدیث بیان کی ، ان دونوں کی حدیث میں ہے :  \" لوگوں"}
{"hadithnumber": "5528", "text": "ابو بکر بن ابی شیبہ اور زہیر بن حرب نے کہا : ہمیں سفیان بن عینیہ نے عبدالرحمان بن قاسم سے حدیث بیان"}
{"hadithnumber": "5529", "text": "محمد بن جعفر نے کہا : ہمیں شعبہ نے عبدالرحمان بن قاسم سے حدیث بیان کی ، انھوں نے کہا : میں نے قاسم س"}
{"hadithnumber": "5530", "text": "سعید بن عامر اور ابو عامر عقدی نے شعبہ سے اسی سند کے ساتھ حدیث بیان کی ۔"}
{"hadithnumber": "5531", "text": "وکیع نے سفیان سے ، انھوں نے عبدالرحمان بن قاسم سے ، انھوں نے اپنے والد سے ، انھوں نے حضرت عائشہ  رضی"}
{"hadithnumber": "5532", "text": "بکیر نے کہا : عبدالرحمان بن قاسم نے انھیں حدیث بیان کی ، انھیں ان کے والد نے نبی کریم صلی اللہ علیہ"}
{"hadithnumber": "5533", "text": "اما مالک  رحمۃ اللہ علیہ  نے نافع سے  ، انھوں نے قاسم بن محمد سے ، انھوں نے حضرت عائشہ سے روایت کی ک"}
{"hadithnumber": "5534", "text": "قتیبہ اور ابن رمح نے لیث سے حدیث بیان کی ، اسحاق بن ابراہیم نے کہا : ہمیں ثقفی نے خبر دی ، کہا : ہمی"}
{"hadithnumber": "5535", "text": "عبید اللہ نے نافع سے حدیث بیان کی  ، حضرت ابن عمر رضی اللہ تعالیٰ عنہ  نے انھیں خبر دیا کہ رسول اللہ"}
{"hadithnumber": "5536", "text": "ایو ب نے نافع سے ،  انھوں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے ،  انھوں نے رسول اللہ  صلی اللہ عل"}
{"hadithnumber": "5537", "text": "عثمان  بن ابی شیبہ نے کہا  :  ہمیں جریر نے اعمش سے حدیث بیان کی  ، ابو سعید اشج نے کہا  :  ہمیں وکیع"}
{"hadithnumber": "5538", "text": "یحییٰ بن یحییٰ ابو بکر بن ابی شیبہ اور ابو کریب سب نے ابو معاویہ سے حدیث بیان کی ،  کہا  :  ہمیں سفی"}
{"hadithnumber": "5546", "text": "بشر بن مفضل نے کہا  :  ہمیں سہیل نے اپنے والد سے حدیث بیان کی ،  انھوں نے حضرت ابو ہریرہ رضی اللہ تع"}
{"hadithnumber": "5547", "text": "جریر اور عبد العزیز دراوردی دونوں نے سہل سے اسی سند کے ساتھ حدیث بیان کی ۔"}
{"hadithnumber": "5548", "text": "حضرت ابوہریرہ رضی اللہ تعالیٰ عنہ سے روایت ہے کہ رسول اللہ صلی اللہ علیہ وسلم  نے فرمایا  :  \" گھنٹی"}
{"hadithnumber": "5549", "text": "امام مالک نے عبد اللہ بن ابی بکر سے ، انھوں نے عباد بن تمیم سے روایت کی کہ حضرت ابو بشیر انصاری رضی"}
{"hadithnumber": "5550", "text": "‏علی بن مسہر نے ابن جریج سے ، انھوں نے ابو زبیر سے ، انھوں نے حضرت جابر رضی اللہ تعالیٰ عنہ  سے روای"}
{"hadithnumber": "5551", "text": "حجاج بن محمد اور محمد بن بکر دونوں نے ابن جریج سے روایت کی  ، انھوں نے کہا  :  مجھے ابو زبیر نے بتا"}
{"hadithnumber": "5552", "text": "معقل نے ابو ہریرہ سے انھوں نے حضرت جا بر رضی اللہ تعالیٰ عنہ سے روایت کی کہ نبی  صلی اللہ علیہ وسلم"}
{"hadithnumber": "5553", "text": "حضرت ام سلمہ  رضی اللہ تعالیٰ عنہا   کے آزاد کردہ غلا م ناعم ابو عبد اللہ نے حدیث بیان کی کہ انھوں ن"}
{"hadithnumber": "5554", "text": "محمد  ( ابن سیرین  )  نے حضرت انس رضی اللہ تعالیٰ عنہ  سےروایت کی ،  کہا  :  جب حضرت ام سلیم  رضی ال"}
{"hadithnumber": "5555", "text": "محمد بن جعفر نے کہا  :  ہمیں شعبہ نے ہشام بن زید سے حدیث بیان کی ،  انھوں نے کہا :  میں نے حضرت انس"}
{"hadithnumber": "5558", "text": "اسحٰق بن عبد اللہ بن ابی طلحہ نے حضرت انس رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہا  :  میں نے رسول ال"}
{"hadithnumber": "5559", "text": "یحییٰ بن  سعید نے عبید اللہ سے روایت کی کہا  :  مجھے عمر بن نافع نے اپنے والد سے خبردی  ۔ انھوں نے ح"}
{"hadithnumber": "5560", "text": "ابو اسامہ اور عبد اللہ بن نمیر دونوں نے کہا  :  ہمیں عبید اللہ نے اسی سند کے ساتھ حدیث بیان کی  ، او"}
{"hadithnumber": "5561", "text": "عثمان بن عثمان غطفانی اور روح  ( بن قاسم )  نے عمر بن نافع سے عبید اللہ کی سند سے اسی کے مانند حدیث"}
{"hadithnumber": "5562", "text": "ایوب اور عبد الرحمٰن سراج نے نافع سے ، انھوں نے ابن عمر رضی اللہ تعالیٰ عنہ سے ، انھوں نے رسول اللہ"}
{"hadithnumber": "5563", "text": "حفص بن میسرہ نے زید بن اسلم سے ، انھوں نے عطاء بن یسار سے ، انھوں نے حضرت ابو سعید خدری رضی اللہ تعا"}
{"hadithnumber": "5564", "text": "عبد العزیز بن محمد مدنی اور ہشام بن سعید ان دونوں نے زید بن اسلم سے اسی سند کے ساتھ اسی کے مانند روا"}
{"hadithnumber": "5565", "text": "ابومعاویہ نے ہشام بن عروہ سے  ، انھوں نے فاطمہ بنت منذر رضی اللہ تعالیٰ عنہا   سے ، انھوں نے حضرت اس"}
{"hadithnumber": "5566", "text": "عبداللہ بن نمیر  ، عبدہ ، وکیع اور شعبہ سب نے ہشام بن عروہ سے اسی سند کے ساتھ ابو معاویہ کی حدیث کی"}
{"hadithnumber": "5567", "text": "منصور کی والدہ نے حضرت اسماء بنت ابی بکر  رضی اللہ تعالیٰ عنہا   سے روایت کی کہ ایک عورت نبی اکرم صل"}
{"hadithnumber": "5568", "text": "عمرو بن مر ہ نے کہا :  میں نے حسن بن مسلم سے سنا ، وہ صفیہ بنت شیبہ سے حدیث بیان کررہے تھے ، انھوں ن"}
{"hadithnumber": "5573", "text": "جریر نے منصور سے  ، انھوں نے ابراہیم سے ، انھوں نے علقمہ سے ، انھوں نے حضرت عبداللہ ( بن مسعود رضی ا"}
{"hadithnumber": "5574", "text": "سفیان اور مفضل بن مہلہل دونوں نے منصور سے  ، اسی سند میں جریر کی حدیث کے ہم معنی روایت بیان کی مگر س"}
{"hadithnumber": "5575", "text": "شعبہ نے منصور سے اسی سند کے ساتھ یہی حدیث رسول اللہ  صلی اللہ علیہ وسلم  سے  ، ام یعقوب  رضی اللہ تع"}
{"hadithnumber": "5576", "text": "اعمش نے ابراہیم سے ، انھوں نے علقمہ سے  ، انھون نے حضرت عبداللہ بن مسعود رضی اللہ تعالیٰ عنہ  سے  ،"}
{"hadithnumber": "5577", "text": "۔  ابو زبیر نے بتایا کہ انھوں نے حضرت  جابر بن عبداللہ  رضی اللہ تعالیٰ عنہ  کویہ کہتے ہوئے سنا کہ ن"}
{"hadithnumber": "5578", "text": "امام مالک رحمۃ اللہ علیہ  نے ابن شہاب سے ، انھوں نے حمید بن عبدالرحمان بن عوف سے   روایت کی ، انھوں"}
{"hadithnumber": "5579", "text": "سفیان بن عینیہ  ، یونس اور معمر ، ان سب نے زہری سے  مالک کی حدیث کے مانند بیان کیا مگر معمر کی حدیث"}
{"hadithnumber": "5580", "text": "عمرو بن مرہ نے سعید بن مسیب سے روایت کی ، کہا : حضرت معاویہ  رضی اللہ تعالیٰ عنہ مدینے آئے ، ہمیں خط"}
{"hadithnumber": "5581", "text": "قتادہ نے سعید بن مسیب سے روایت کی کہ ایک دن حضرت معاویہ  رضی اللہ تعالیٰ عنہ  نے فرمایا  : تم لوگوں"}
{"hadithnumber": "5582", "text": "سیدنا ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :  دوزخیوں کی دو قسمی"}
{"hadithnumber": "5583", "text": "حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے روایت ہے  کہ ایک عورت نے کہا : اللہ کے رسول صلی اللہ علیہ وسلم"}
{"hadithnumber": "5584", "text": "عبدہ نے کہا : ہمیں ہشام نے فاطمہ سے حدیث بیان کی ، انھوں نے حضرت اسماء رضی اللہ تعالیٰ عنہا   سے روا"}
{"hadithnumber": "5585", "text": "ابو اسامہ اورابو معاویہ  ، دونوں نے ہشام سے ، اس سند کے ساتھ روایت کی ۔"}
