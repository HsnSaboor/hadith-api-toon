{"hadithnumber": "4254", "text": "یونس نے ابن شہاب سے ،  انہوں نے سالم بن عبداللہ سے اور انہوں نے اپنے والد سے روایت کی ،  انہوں نے کہ"}
{"hadithnumber": "4255", "text": "عقیل بن خالد اور معمر دونوں نے زہری سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی ،  البتہ عقیل کی حد"}
{"hadithnumber": "4256", "text": "سفیان بن عیینہ نے زہری سے ،  انہوں نے سالم سے اور انہوں نے اپنے والد سے روایت کی ،  انہوں نے کہا :"}
{"hadithnumber": "4257", "text": "لیث نے نافع سے ،  انہوں نے حضرت عبداللہ رضی اللہ عنہ سے اور انہوں نے رسول اللہ صلی اللہ علیہ وسلم سے"}
{"hadithnumber": "4258", "text": "عبداللہ بن نمیر ،  عبیداللہ ،  ایوب ،  ولید بن کثیر ،  اسماعیل بن امیہ ،  ضحاک ،  ابن ابی ذئب اور عب"}
{"hadithnumber": "4259", "text": "عبداللہ بن دینار سے روایت ہے کہ انہوں نے حضرت ابن عمر رضی اللہ عنہ سے سنا ،  انہوں نے کہا :  رسول ال"}
{"hadithnumber": "4260", "text": "یونس نے ابن شہاب سے روایت کی ،  کہا :  مجھے حمید بن عبدالرحمان بن عوف نے بتایا کہ حضرت ابوہریرہ رضی"}
{"hadithnumber": "4261", "text": "اوزاعی اور معمر دونوں نے زہری سے اسی سند کے ساتھ حدیث بیان کی اور معمر کی حدیث یونس کی حدیث کے مانند"}
{"hadithnumber": "4262", "text": "حضرت عبدالرحمان بن سمرہ رضی اللہ عنہ سے روایت ہے ،  انہوں نے کہا :  رسول اللہ صلی اللہ علیہ وسلم نے"}
{"hadithnumber": "4263", "text": "غیلان بن جریر نے ابو بردہ سے اور انہوں نے حضرت ابوموسیٰ اشعری رضی اللہ عنہ سے روایت کی ،  انہوں نے ک"}
{"hadithnumber": "4264", "text": "بُرید نے ابوبردہ سے اور انہوں نے حضرت ابوموسیٰ رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  میرے ساتھ"}
{"hadithnumber": "4265", "text": "حماد بن زید نے ہمیں ایوب سے حدیث بیان کی ،  انہوں نے ابوقلابہ اور قاسم بن عاصم سے اور انہوں نے زَہدم"}
{"hadithnumber": "4266", "text": "عبدالوہاب ثقفی نے ہمیں ایوب سے حدیث بیان کی ،  انہوں نے ابوقلابہ اور قاسم تمیمی سے اور انہوں نے زہدم"}
{"hadithnumber": "4267", "text": "اسماعیل بن علیہ ،  سفیان اور وہیب ،  سب نے ایوب سے حدیث بیان کی ،  انہوں نے ابوقلابہ اور قاسم سے اور"}
{"hadithnumber": "4268", "text": "مطروراق نے ہمیں حدیث بیان کی ،  کہا :  ہمیں زہدم جرمی نے حدیث بیان کی ،  انہوں نے کہا :  میں حضرت اب"}
{"hadithnumber": "4269", "text": "جریر نے ہمیں سلیمان تیمی سے خبر دی ،  انہوں نے ضرب بن نقیر قیسی سے ،  انہوں نے زہدم سے اور انہوں نے"}
{"hadithnumber": "4270", "text": "معتمر نے اپنے والد سے روایت کی ،  کہا :  ہمیں ابو سلیل  ( ضریب )  نے زہدم سے حدیث بیان کی ،  وہ حضرت"}
{"hadithnumber": "4271", "text": "ابو حازم نے حضرت ابو ہریرہ رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  ایک آدمی رات کی تاریکی گہری ہ"}
{"hadithnumber": "4272", "text": "امام مالک نے سہیل بن ابی صالح سے خبر دی ،  انہوں نے اپنے والد سے اور انہوں نے حضرت ابوہریرہ رضی اللہ"}
{"hadithnumber": "4273", "text": "عبدالعزیز بن مطلب نے سہیل بن ابی صالح سے روایت کی ،  انہوں نے اپنے والد سے اور انہوں نے حضرت ابوہریر"}
{"hadithnumber": "4274", "text": "سلیمان بن بلال نے مجھے سہیل سے اسی سند کے ساتھ امام مالک کی حدیث کے ہم معنی حدیث  ( ان الفاظ میں )"}
{"hadithnumber": "4275", "text": "جریر نے عبدالعزیز بن رفیع سے ،  انہوں نے تمیم بن طرفہ سے روایت کی ،  انہوں نے کہا :  حضرت عدی بن حات"}
{"hadithnumber": "4276", "text": "شعبہ نے عبدالعزیز بن رفیع سے ،  انہوں نے تمیم بن طرفہ سے اور انہوں نے حضرت عدی بن حاتم رضی اللہ عنہ"}
{"hadithnumber": "4277", "text": "اعمش نے عبدالعزیز بن رفیع سے ،  انہوں نے تمیم طائی سے اور انہوں نے حضرت عدی رضی اللہ عنہ سے روایت کی"}
{"hadithnumber": "4278", "text": "شیبانی نے عبدالعزیز بن رفیع سے ،  انہوں نے تمیم طائی سے اور انہوں نے حضرت عدی بن حاتم رضی اللہ عنہ س"}
{"hadithnumber": "4279", "text": "محمد بن جعفر نے کہا :  ہمیں شعبہ نے سماک بن حرب سے حدیث بیان کی اور انہوں نے تمیم بن طرفہ سے روایت ک"}
{"hadithnumber": "4280", "text": "بہز نے کہا :  ہمیں شعبہ نے حدیث سنائی اور کہا :  ہمیں سماک بن حرب نے حدیث بیان کی ،  انہوں نے کہا :"}
{"hadithnumber": "4281", "text": "شیبان بن فروخ نے کہا :  ہمیں جریر بن حازم نے حدیث بیان کی ،   ( کہا :   )  ہمیں حسن نے حدیث سنائی ،"}
{"hadithnumber": "4282", "text": "یونس ،  منصور ،  حمید ،  سماک بن عطیہ ، ہشام بن حسان ،  معتمر کے والد  ( سلیمان طرخان )  اور قتادہ ،"}
{"hadithnumber": "4283", "text": "یحییٰ بن یحییٰ اور عمرو الناقد نے ہمیں حدیث بیان کی  ۔  ۔  یحییٰ نے کہا :  ہمیں ہشیم بن بشیر نے عبدا"}
{"hadithnumber": "4284", "text": "یزید بن ہارون نے ہشیم سے ،  انہوں نے عباد بن ابی صالح سے ،  انہوں نے اپنے والد سے اور انہوں نے حضرت"}
{"hadithnumber": "4285", "text": "محمد  ( بن سیرین )  نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  حضرت سلیمان علیہ ال"}
{"hadithnumber": "4286", "text": "ہشام بن حجیر نے طاوس سے ،  انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے اور انہوں نے نبی صلی اللہ علیہ وسل"}
{"hadithnumber": "4287", "text": "سفیان نے ابوزناد سے ،  انہوں نے اعرج سے ،  انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے اور انہوں نے نبی ص"}
{"hadithnumber": "4288", "text": "طاوس کے بیٹے نے اپنے والد سے اور انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :"}
{"hadithnumber": "4289", "text": "ورقاء نے ابوزناد سے ،  انہوں نے اعرج سے ،  انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے اور انہوں نے نبی ص"}
{"hadithnumber": "4290", "text": "موسیٰ بن عقبہ نے ابوزناد سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی ،  البتہ انہوں نے کہا :   \" ان"}
{"hadithnumber": "4291", "text": "ہمام بن منبہ سے روایت ہے ،  انہوں نے کہا :  یہ احادیث ہیں جو ہمیں حضرت ابوہریرہ رضی اللہ عنہ نے رسول"}
{"hadithnumber": "4292", "text": "یحییٰ بن سعید قطان نے ہمیں عبیداللہ سے حدیث بیان کی ،  انہوں نے کہا :  مجھے نافع نے حضرت ابن عمر رضی"}
{"hadithnumber": "4293", "text": "ابواسامہ ،  عبدالوہاب ثقفی ،  حفص بن غیاث اور شعبہ ،  ان سب نے عبیداللہ سے حدیث بیان کی ،  انہوں نے"}
{"hadithnumber": "4294", "text": "جریر بن حازم نے ہمیں حدیث سنائی کہ ایوب نے انہیں حدیث بیان کی ،  انہیں نافع نے حدیث سنائی ،  انہیں ح"}
{"hadithnumber": "4295", "text": "معمر نے ہمیں ایوب سے خبر دی ،  انہوں نے نافع سے اور انہوں نے حضرت ابن عمر رضی اللہ عنہ سے روایت کی ،"}
{"hadithnumber": "4296", "text": "حماد بن زید نے ہمیں حدیث بیان کی ،  کہا :  ہمیں ایوب نے نافع سے حدیث بیان کی ،  انہوں نے کہا :  حضرت"}
{"hadithnumber": "4297", "text": "ایوب اور محمد بن اسحاق دونوں نے نافع سے اور انہوں نے حضرت ابن عمر رضی اللہ عنہ سے نذر کے بارے میں یہ"}
{"hadithnumber": "4298", "text": "ابوعوانہ نے فراس سے ،  انہوں نے ابوصالح ذکوان سے اور انہوں نے ابو عمر زاذان سے روایت کی ،  انہوں نے"}
{"hadithnumber": "4299", "text": "شعبہ نے ہمیں فراس سے باقی ماندہ سابقہ سند سے حدیث بیان کی کہ حضرت ابن عمر رضی اللہ عنہ نے اپنے غلام"}
{"hadithnumber": "4300", "text": "وکیع اور عبدالرحمان  ( بن مہدی )  دونوں نے سفیان سے حدیث بیان کی ،  انہوں نے فراس سے شعبہ اور ابو عو"}
{"hadithnumber": "4301", "text": "معاویہ بن سوید  ( بن مُقرن )  سے روایت ہے ،  انہوں نے کہا :  میں نے اپنے ایک غلام کو طمانچہ مارا اور"}
{"hadithnumber": "4302", "text": "ابن ادریس نے ہمیں حصین سے حدیث بیان کی ،  انہوں نے ہلال بن یساف سے روایت کی ،  انہوں نے کہا :  ایک ب"}
{"hadithnumber": "4303", "text": "ہلال ‌بن ‌یساف ‌رضی ‌اللہ ‌عنہ ‌سے ‌روایت ‌ہے ‌ہم ‌كپڑا ‌بیچتے ‌تھے ‌سوید ‌بن ‌مقرن ‌كے ‌گھر ‌میں ‌ج"}
{"hadithnumber": "4304", "text": "عبدالصمد نے ہمیں حدیث سنائی ،  کہا :  ہمیں شعبہ نے حدیث سنائی ،  کہا :  مجھ سے محمد بن منکدر نے کہا"}
{"hadithnumber": "4305", "text": "وہب بن جریر نے کہا :  ہمیں شعبہ نے خبر دی کہ محمد بن منکدر نے مجھ سے پوچھا :  تمہارا نام کیا ہے؟ آگے"}
{"hadithnumber": "4306", "text": "عبدالواحد بن زیاد نے ہمیں حدیث بیان کی ،  کہا :  ہمیں اعمش نے ابراہیم تیمی سے حدیث سنائی ،  انہوں نے"}
{"hadithnumber": "4307", "text": "جریر ،  سفیان اور ابوعوانہ سب نے اعمش سے عبدالواحد کی  ( سابقہ )  سند کے ساتھ اس کی حدیث کے ہم معنی"}
{"hadithnumber": "4308", "text": "ابومعاویہ نے ہمیں حدیث بیان کی ،  کہا :  ہمیں اعمش نے ابراہیم تیمی سے حدیث بیان کی ،  انہوں نے اپنے"}
{"hadithnumber": "4309", "text": "ابن ابی عدی نے شعبہ سے ،  انہوں نے سلیمان سے ،  انہوں نے ابراہیم تیمی سے ،  انہوں نے اپنے والد سے او"}
{"hadithnumber": "4310", "text": "محمد بن جعفر نے ہمیں شعبہ سے ،  اسی سند کے ساتھ خبر دی اور انہوں نے یہ الفاظ بیان نہیں کیے :   \" میں"}
{"hadithnumber": "4311", "text": "عبداللہ بن نمیر نے کہا :  ہمیں فضیل بن غزوان نے حدیث بیان کی ،  انہوں نے کہا :  میں نے عبدالرحمان بن"}
{"hadithnumber": "4312", "text": "وکیع اور اسحاق بن یوسف ازرق دونوں نے فضیل بن غزوان سے اسی سند کے ساتھ حدیث بیان کی اور ان دونوں کی ح"}
{"hadithnumber": "4313", "text": "وکیع نے کہا :  ہمیں اعمش نے معرور بن سوید سے حدیث بیان کی ،  انہوں نے کہا :  ہم زَبذہ  ( کے مقام )"}
{"hadithnumber": "4314", "text": "زہیر ،  ابومعاویہ اور عیسیٰ بن یونس سب نے اعمش سے اسی سند کے ساتھ حدیث بیان کی ،  زہیر اور ابو معاوی"}
{"hadithnumber": "4315", "text": "واصل احدب نے معرور بن سوید سے روایت کی ،  انہوں نے کہا :  میں نے حضرت ابوذر رضی اللہ عنہ کو اس حالت"}
{"hadithnumber": "4316", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ،  انہوں نے رسول اللہ صلی اللہ علیہ وسلم سے روایت کی کہ آپ نے"}
{"hadithnumber": "4317", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ،  انہوں نے کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :"}
{"hadithnumber": "4318", "text": "امام مالک نے نافع سے اور انہوں نے حضرت ابن عمر رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ علیہ و"}
{"hadithnumber": "4319", "text": "عبیداللہ اور اسامہ نے نافع سے ،  انہوں نے حضرت ابن عمر رضی اللہ عنہ سے اور انہوں نے نبی صلی اللہ علی"}
{"hadithnumber": "4320", "text": "ابوطاہر اور حرملہ بن یحییٰ نے ہمیں حدیث بیان کی ،  دونوں نے کہا :  ہمیں ابن وہب نے خبر دی ،  کہا :"}
{"hadithnumber": "4321", "text": "ابوصفوان اموی نے ہمیں حدیث بیان کی  ( کہا :   )  مجھے یونس نے ابن شہاب سے اسی سند کے ساتھ خبر دی ،"}
{"hadithnumber": "4322", "text": "ابو معاویہ نے اعمش سے ،  انہوں نے ابوصالح سے اور انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،"}
{"hadithnumber": "4323", "text": "جریر نے اعمش سے اسی سند کے ساتھ حدیث بیان کی"}
{"hadithnumber": "4324", "text": "ہمام بن منبہ نے کہا :  یہ احادیث ہیں جو حضرت ابوہریرہ رضی اللہ عنہ نے ہمیں رسول اللہ صلی اللہ علیہ و"}
{"hadithnumber": "4325", "text": "امام مالک نے نافع سے اور انہوں نے حضرت ابن عمر رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  رسول اللہ"}
{"hadithnumber": "4326", "text": "عبیداللہ نے نافع سے ،  انہوں نے حضرت ابن عمر رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  رسول اللہ ص"}
{"hadithnumber": "4327", "text": "جریر بن حازم نے عبداللہ بن عمر رضی اللہ عنہ کے مولیٰ نافع سے ،  انہوں نے حضرت عبداللہ بن عمر رضی الل"}
{"hadithnumber": "4328", "text": "لیث بن سعد ،  یحییٰ بن سعید ،  ایوب ،  اسماعیل بن امیہ ،  ابن ابی ذئب اور اسامہ بن زید سب نے نافع سے"}
{"hadithnumber": "4329", "text": "عمرو نے سالم بن عبداللہ سے اور انہوں نے اپنے والد سے روایت کی کہ رسول اللہ صلی اللہ علیہ وسلم نے فرم"}
{"hadithnumber": "4330", "text": "زہری نے سالم سے اور انہوں نے حضرت ابن عمر رضی اللہ عنہ سے روایت کی کہ نبی صلی اللہ علیہ وسلم نے فرما"}
{"hadithnumber": "4331", "text": "محمد بن جعفر نے کہا :  ہمیں شعبہ نے قتادہ سے حدیث بیان کی ،  انہوں نے نضر بن انس سے ،  انہوں نے بشیر"}
{"hadithnumber": "4332", "text": "عبیداللہ کے والد معاذ عنبری نے کہا :  ہمیں شعبہ نے اسی سند کے ساتھ حدیث بیان کی ،  آپ نے فرمایا :"}
{"hadithnumber": "4333", "text": "اسماعیل بن ابراہیم نے ابن ابی عروبہ سے ،  انہوں نے قتادہ سے ،  انہوں نے نضر بن انس سے ،  انہوں نے بش"}
{"hadithnumber": "4334", "text": "علی بن مسہر ،  محمد بن بشر اور عیسیٰ بن یونس سب نے ابن ابی عروبہ سے اسی سند کے ساتھ حدیث بیان کی اور"}
{"hadithnumber": "4335", "text": "اسماعیل بن علیہ نے ایوب سے ،  انہوں نے ابوقلابہ سے ،  انہوں نے ابومہلب سے اور انہوں نے حضرت عمران بن"}
{"hadithnumber": "4336", "text": "حماد اور  ( عبدالوہاب )  ثقفی دونوں نے ایوب سے اسی سند کے ساتھ حدیث بیان کی ،  حماد کی حدیث ابن عُلی"}
{"hadithnumber": "4337", "text": "یزید بن زریع نے ہمیں حدیث بیان کی ،  کہا :  ہمیں ہشام بن حسان نے محمد بن سیرین سے حدیث بیان کی ،  ان"}
{"hadithnumber": "4338", "text": "حماد بن زید نے عمرو بن دینار سے ،  انہوں نے حضرت جابر بن عبداللہ رضی اللہ عنہ سے روایت کی کہ انصار م"}
{"hadithnumber": "4339", "text": "سفیان بن عیینہ نے کہا :  عمرو  ( بن دینار )  نے حضرت جابر رضی اللہ عنہ سے سنا ،  وہ کہہ رہے تھے :  ا"}
{"hadithnumber": "4340", "text": "لیث بن سعد نے ابوزبیر سے ،  انہوں نے حضرت جابر رضی اللہ عنہ سے اور انہوں نے نبی صلی اللہ علیہ وسلم س"}
{"hadithnumber": "4341", "text": "عبدالمجید بن سہیل اور حسین بن ذکوان معلم نے عطاء سے ،  انہوں نے حضرت جابر رضی اللہ عنہ سے روایت کی ،"}
