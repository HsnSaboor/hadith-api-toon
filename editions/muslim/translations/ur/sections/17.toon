{"hadithnumber": "3568", "text": "یحییٰ بن یحییٰ نے کہا :  میں نے امام مالک کے سامنے قراءت کی ،  عبداللہ بن ابوبکر سے روایت ہے ،  انہو"}
{"hadithnumber": "3569", "text": "ہشام بن عروہ نے عبداللہ بن ابوبکر سے ،  انہوں نے عمرہ سے ،  انہوں نے حضرت عائشہ رضی اللہ عنہا سے روا"}
{"hadithnumber": "3570", "text": "ابن جریج نے ہمیں خبر دی ،  کہا : مجھے عبداللہ بن ابوبکر نے اسی سند سے ہشام بن عروہ کی حدیث کے مانند"}
{"hadithnumber": "3571", "text": "امام مالک نے ابن شہاب سے ،  انہوں نے عروہ بن زبیر سے ،  انہوں نے حضرت عائشہ رضی اللہ عنہا سے روایت ک"}
{"hadithnumber": "3572", "text": "سفیان بن عیینہ نے ہمیں زہری سے حدیث بیان کی ،  انہوں نے عروہ سے ،  انہوں نے حضرت عائشہ رضی اللہ عنہا"}
{"hadithnumber": "3573", "text": "یونس نے مجھے ابن شہاب سے خبر دی ،  انہوں نے عروہ سے روایت کی ،  حضرت عائشہ رضی اللہ عنہا نے انہیں خب"}
{"hadithnumber": "3574", "text": "معمر نے ہمیں زہری سے اسی سند کے ساتھ خبر دی کہ ابوقعیس کے بھائی افلح آئے ،  وہ ان کے پاس گھر کے اندر"}
{"hadithnumber": "3575", "text": "ابن نمیر نے ہشام سے حدیث بیان کی ،  انہوں نے اپنے والد  ( عروہ بن زبیر )  سے ،  انہوں نے حضرت عائشہ"}
{"hadithnumber": "3576", "text": "حماد ،  یعنی ابن زید نے ہمیں حدیث بیان کی ،  کہا :  ہمیں ہشام نے اسی سند سے حدیث بیان کی کہ ابوقعیس"}
{"hadithnumber": "3577", "text": "ابومعاویہ نے ہشام سے اسی سند کے ساتھ اسی کی طرح حدیث بیان کی مگر انہوں نے کہا :  ابوقیس نے ان کے ہاں"}
{"hadithnumber": "3578", "text": "عطاء سے روایت ہے ،  کہا :  مجھے عروہ بن زبیر نے خبر دی کہ انہیں حضرت عائشہ رضی اللہ عنہا نے خبر دی ،"}
{"hadithnumber": "3579", "text": "یزید بن ابی حبیب نے عراک  ( بن مالک غفاری )  سے ،  انہوں نے عروہ سے ،  انہوں نے سیدہ عائشہ رضی اللہ"}
{"hadithnumber": "3580", "text": "حکم نے عراک بن مالک سے ،  انہوں نے عروہ سے ،  انہوں نے حضرت عائشہ رضی اللہ عنہا سے روایت کی ،  انہوں"}
{"hadithnumber": "3581", "text": "ابومعاویہ نے ہمیں اعمش سے خبر دی ،  انہوں نے سعد بن عبیدہ سے ،  انہوں نے ابوعبدالرحمٰن سے اور انہوں"}
{"hadithnumber": "3582", "text": "جریر ،  عبداللہ بن نمیر اور سفیان سب نے اعمش سے اسی سند کے ساتھ اسی کے مانند روایت کی"}
{"hadithnumber": "3583", "text": "ہمام نے ہمیں حدیث بیان کی ،  کہا :  ہمیں قتادہ نے جابر بن زید سے حدیث بیان کی ،  انہوں نے ابن عباس ر"}
{"hadithnumber": "3584", "text": "یحییٰ قطان اور بشر بن عمر نے شعبہ سے حدیث بیان کی ،  شعبہ اور سعید بن ابی عروبہ دونوں نے قتادہ سے ہم"}
{"hadithnumber": "3585", "text": "نبی صلی اللہ علیہ وسلم کی زوجہ محترمہ حضرت ام سلمہ رضی اللہ عنہا فرماتی ہیں کہ رسول اللہ صلی اللہ عل"}
{"hadithnumber": "3586", "text": "ابواسامہ نے ہمیں حدیث بیان کی ،  کہا :  ہمیں ہشام نے خبر دی ،  کہا :  مجھے میرے والد  ( عروہ بن زبیر"}
{"hadithnumber": "3587", "text": "یحییٰ بن زکریا بن ابی زائدہ اور زہیر دونوں نے ہشام بن عروہ سے اسی سند کے ساتھ بالکل اسی طرح حدیث بیا"}
{"hadithnumber": "3588", "text": "یزید بن ابوحبیب سے روایت ہے کہ محمد بن شہاب  ( زہری )  نے  ( ان کی طرف )  یہ بیان کرتے ہوئے لکھا کہ"}
{"hadithnumber": "3589", "text": "عقیل بن خالد اور محمد بن عبداللہ بن مسلم دونوں نے زہری سے ابن ابی حبیب کی  ( سابقہ )  سند کے ساتھ اس"}
{"hadithnumber": "3590", "text": "زہیر بن حرب ،  محمد بن عبداللہ بن نمیر اور سوید بن سعید نے ،  اپنی اپنی سندوں سے حضرت عائشہ رضی اللہ"}
{"hadithnumber": "3591", "text": "یحییٰ بن یحییٰ  ،  عمرو ناقد اور اسحاق بن ابراہیم سب نے معتمر سے حدیث بیان کی  ۔  ۔  الفاظ یحییٰ کےہ"}
{"hadithnumber": "3592", "text": "ہشام نے مجھے قتادہ سے حدیث بیان کی ،  انہوں نے ابوخلیل صالح بن ابی مریم سے ،  انہوں نے عبداللہ بن حا"}
{"hadithnumber": "3593", "text": "ہمیں محمد بن بشر نے حدیث بیان کی ،  کہا :  ہمیں سعید بن ابی عروبہ نے قتادہ سے باقی ماندہ سابقہ سند ک"}
{"hadithnumber": "3594", "text": "ابوبکر بن ابی شیبہ اور اسحاق بن ابراہیم دونوں نے عبدہ بن سلیمان سے اور انہوں نے ابن ابو عروبہ سے اسی"}
{"hadithnumber": "3595", "text": "حماد بن سلمہ نے ہمیں قتادہ سے باقی ماندہ اسی سند کے ساتھ ام فضل رضی اللہ عنہا سے اور انہوں نے نبی صل"}
{"hadithnumber": "3596", "text": "ہمام نے ہمیں حدیث بیان کی ،  کہا :  ہمیں قتادہ نے باقی ماندہ اسی سند کے ساتھ ام فضل رضی اللہ عنہا سے"}
{"hadithnumber": "3597", "text": "عبداللہ بن ابی بکرہ نے عمرہ سے ،  انہوں نے حضرت عائشہ رضی اللہ عنہا سے روایت کی ،  انہوں نے کہا :  ق"}
{"hadithnumber": "3598", "text": "سلیمان بن بلال نے ہمیں یحییٰ بن سعید سے حدیث بیان کی ،  انہوں نے عمرہ سے روایت کی کہ انہوں نے حضرت ع"}
{"hadithnumber": "3599", "text": "عبدالوہاب نے ہمیں حدیث بیان کی ،  کہا :  میں نے یحییٰ بن سعید سے سنا ،  انہوں نے کہا :  مجھے عمرہ نے"}
{"hadithnumber": "3600", "text": "عمرو ناقد اور ابن ابی عمر نے کہا :  ہمیں سفیان بن عیینہ نے عبدالرحمٰن بن قاسم سے حدیث بیان کی ،  انہ"}
{"hadithnumber": "3601", "text": "ایوب نے ابن ابی مُلیکہ سے ،  انہوں نے قاسم سے اور انہوں نے حضرت عائشہ رضی اللہ عنہا سے روایت کی کہ ا"}
{"hadithnumber": "3602", "text": "ابن جریج نے ہمیں خبر دی ،  کہا :  ہمیں ابن ابی ملیکہ نے بتایا ،  انہیں قاسم بن محمد بن ابی بکر نے خب"}
{"hadithnumber": "3603", "text": "شعبہ نے حُمَید بن نافع سے حدیث بیان کی ،  انہوں نے زینب بنت ام سلمہ رضی اللہ عنہا سے روایت کی ،  انہ"}
{"hadithnumber": "3604", "text": "بُکَیر سے روایت ہے ،  انہوں نے کہا :  میں نے حمید بن نافع سے سنا وہ کہہ رہے تھے ،  میں نے زینب بنت ا"}
{"hadithnumber": "3605", "text": "ابوعبیدہ بن عبداللہ بن زمعہ نے مجھے خبر دی کہ ان کی والدہ زینب بنت ابی سلمہ رضی اللہ عنہا نے انہیں ب"}
{"hadithnumber": "3606", "text": "ابواحوص نے ہمیں اشعث سے حدیث بیان کی ،  انہوں نے اپنے والد سے ،  اور انہوں نے مسروق سے روایت کی ،  ا"}
{"hadithnumber": "3607", "text": "شعبہ ،  سفیان اور زائدہ سب نے اشعث بن ابو شعثاء سے ابواحوص کی سند کے ساتھ اسی کی حدیث کے ہم معنی حدی"}
{"hadithnumber": "3608", "text": "یزید بن زُرَیع نے ہمیں حدیث بیان کی ،  کہا :  ہمیں سعید بن ابوعروبہ نے قتادہ سے حدیث بیان کی ،  انہو"}
{"hadithnumber": "3609", "text": "عبدالاعلی نے ہمیں سعید سے حدیث بیان کی ،  انہوں نے قتادہ سے ،  انہوں نے ابوخلیل سے روایت کی کہ ابوعل"}
{"hadithnumber": "3610", "text": "شعبہ نے قتادہ سے اسی سند کے ساتھ اسی کے ہم معنی حدیث بیان کی"}
{"hadithnumber": "3611", "text": "شعبہ نے ہمیں قتادہ سے حدیث بیان کی ،  انہوں نے ابوخلیل سے اور انہوں نے حضرت ابوسعید رضی اللہ عنہ سے"}
{"hadithnumber": "3612", "text": "سعید نے قتادہ سے اسی سند کے ساتھ اسی طرح حدیث بیان کی"}
{"hadithnumber": "3613", "text": "قتیبہ بن سعید اور محمد بن رُمح نے کہا :  لیث نے ہمیں ابن شہاب سے خبر دی ،  انہوں نے عروہ سے ،  انہوں"}
{"hadithnumber": "3614", "text": "سفیان بن عیینہ اور معمر نے زہری سے اسی سند کے ساتھ اسی کے ہم معنی حدیث بیان کی ۔  لیکن معمر اور ابن"}
{"hadithnumber": "3615", "text": "معمر نے زہری سے خبر دی ،  انہوں نے ابن مسیب اور ابوسلمہ سے ،  انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے"}
{"hadithnumber": "3616", "text": "سعید بن منصور ،  زہیر بن حرب ،  عبدالاعلیٰ بن حماد اور عمرو ناقد سب نے کہا :  ہمیں سفیان نے زہری سے"}
{"hadithnumber": "3617", "text": "لیث نے ہمیں ابن شہاب سے حدیث بیان کی ،  انہوں نے عروہ سے اور انہوں نے حضرت عائشہ رضی اللہ عنہا سے رو"}
{"hadithnumber": "3618", "text": "سفیان نے ہمیں زہری سے حدیث بیان کی ،  انہوں نے عروہ سے ،  انہوں نے حضرت عائشہ رضی اللہ عنہا سے روایت"}
{"hadithnumber": "3619", "text": "ابراہیم بن سعد نے ہمیں زہری سے حدیث بیان کی ،  انہوں نے عروہ سے ،  انہوں نے حضرت عائشہ رضی اللہ عنہا"}
{"hadithnumber": "3620", "text": "یونس ،  معمر اور ابن جریج سب نے زہری سے اسی سند کے ساتھ ،  ان  ( لیث ،  سفیان اور ابراہیم بھی سعد )"}
{"hadithnumber": "3621", "text": "محمد بن ابوبکر نے عبدالملک بن ابوبکر بن عبدالرحمٰن بن حارث بن ہشام سے ،  انہوں نے اپنے والد سے ،  ان"}
{"hadithnumber": "3622", "text": "عبداللہ بن ابوبکر نے عبدالملک بن ابوبکر سے ،  انہوں نے ابوبکر بن عبدالرحمٰن سے روایت کی کہ جب رسول ا"}
{"hadithnumber": "3623", "text": "سلیمان بن بلال نے ہمیں عبدالرحمٰن بن حُمَید سے حدیث بیان کی ،  انہوں نے عبدالملک بن ابوبکر سے ،  انہ"}
{"hadithnumber": "3624", "text": "ابوضمرہ نے عبدالرحمٰن بن حمید سے اسی سند کے ساتھ اسی کے مانند روایت کی"}
{"hadithnumber": "3625", "text": "عبدالواحد بن ایمن نے ابوبکر بن عبدالرحمٰن سے ،  انہوں نے ام سلمہ رضی اللہ عنہا سے روایت کی ،  انہوں"}
{"hadithnumber": "3626", "text": "ہشیم نے ہمیں خالد سے خبر دی ،  انہوں نے ابوقلابہ سے ،  انہوں نے انس بن مالک رضی اللہ عنہ سے روایت کی"}
{"hadithnumber": "3627", "text": "سفیان نے ایوب اور خالد حذاء سے خبر دی ،  انہوں نے ابوقلابہ سے ،  انہوں نے حضرت انس رضی اللہ عنہ سے ر"}
{"hadithnumber": "3628", "text": "حضرت انس رضی اللہ عنہ سے روایت ہے ،  انہوں نے کہا :  نبی صلی اللہ علیہ وسلم کی نو بیویاں تھیں ،  جب"}
{"hadithnumber": "3629", "text": "جریر نے ہمیں ہشام بن عروہ سے حدیث بیان کی ،  انہوں نے اپنے والد  ( عروہ بن زبیر )  سے ،  انہوں نے حض"}
{"hadithnumber": "3630", "text": "عقبہ بن خالد ،  زہیر اور شریک ،  ان سب نے ہشام سے اسی سند کے ساتھ روایت کی کہ حضرت سودہ رضی اللہ عنہ"}
{"hadithnumber": "3631", "text": "ابواسامہ نے ہمیں ہشام سے حدیث بیان کی ،  انہوں نے اپنے والد  ( عروہ )  سے ،  انہوں نے حضرت عائشہ رضی"}
{"hadithnumber": "3632", "text": "عبدہ بن سلیمان نے ہشام سے حدیث بیان کی ،  انہوں نے اپنے والد  ( عروہ )  سے ،  انہوں نے حضرت عائشہ رض"}
{"hadithnumber": "3633", "text": "محمد بن بکر نے ہمیں حدیث بیان کی ،  کہا :  ہمیں ابن جریج نے خبر دی ،  کہا :  مجھے عطاء نے خبر دی ،"}
{"hadithnumber": "3634", "text": "عبدالرزاق نے ابن جریج سے اسی سند کے ساتھ روایت کی اور یہ اضافہ کیا کہ عطاء نے کہا :  وہ ان سب میں سے"}
{"hadithnumber": "3635", "text": "حضرت ابوہریرہ رضی اللہ عنہ نے نبی صلی اللہ علیہ وسلم سے روایت کی ،  آپ نے فرمایا :   \" عورت کے ساتھ"}
{"hadithnumber": "3636", "text": "عطاء سے روایت ہے ،  کہا :  مجھے جابر بن عبداللہ رضی اللہ عنہ نے خبر دی ،  انہوں نے کہا :  میں نے رسو"}
{"hadithnumber": "3637", "text": "شعبہ نے ہمیں محارب سے حدیث بیان کی ،  انہوں نے حضرت جابر بن عبداللہ رضی اللہ عنہ سے روایت کی ،  انہو"}
{"hadithnumber": "3638", "text": "یحییٰ بن یحییٰ اور ابو ربیع زہرانی نے ہمیں حدیث بیان کی ،  یحییٰ نے کہا :  حماد بن زید نے ہمیں عمرو"}
{"hadithnumber": "3639", "text": "سفیان نے ہمیں عمرو سے حدیث بیان کی ،  انہوں نے حضرت جابر بن عبداللہ رضی اللہ عنہ سے روایت کی ،  انہو"}
{"hadithnumber": "3640", "text": "شعبی نے حضرت جابر بن عبداللہ رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  ہم رسول اللہ صلی اللہ علیہ"}
{"hadithnumber": "3641", "text": "وہب بن کیسان نے حضرت جابر بن عبداللہ رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  میں رسول اللہ صلی ا"}
{"hadithnumber": "3642", "text": "ابونضرہ نے ہمیں حضرت جابر بن عبداللہ رضی اللہ عنہ سے حدیث بیان کی ،  انہوں نے کہا :  ہم رسول اللہ صل"}
{"hadithnumber": "3643", "text": "اعرج نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فر"}
{"hadithnumber": "3644", "text": "ابوحازم نے حضرت ابوہریرہ رضی اللہ عنہ سے ،  انہوں نے نبی صلی اللہ علیہ وسلم سے روایت کی کہ آپ صلی ال"}
{"hadithnumber": "3645", "text": "عیسیٰ بن یونس نے ہمیں حدیث بیان کی ،  کہا :  ہمیں عبدالحمید بن جعفر نے عمران بن ابی انس سے حدیث سنائ"}
{"hadithnumber": "3646", "text": "ابوعاصم نے ہمیں حدیث بیان کی ،  کہا :  ہمیں عبدالحمید بن جعفر نے سابقہ سند کے ساتھ حضرت ابوہریرہ رضی"}
{"hadithnumber": "3647", "text": "ابوہریرہ رضی اللہ عنہ کے آزاد کردہ غلام ابو یونس نے حضرت ابوہریرہ رضی اللہ عنہ سے حدیث بیان کی ،  ان"}
{"hadithnumber": "3648", "text": "ہمام بن منبہ سے روایت ہے ،  انہوں نے کہا :  یہ احادیث ہیں جو حضرت ابوہریرہ رضی اللہ عنہ نے ہمیں رسول"}
{"hadithnumber": "3649", "text": "حضرت عبداللہ بن عمرو رضی اللہ عنہ سے روایت ہے کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   \" دنیا م"}
{"hadithnumber": "3650", "text": "یونس نے مجھے ابن شہاب سے خبر دی ،  کہا :  مجھے ابن مسیب نے حضرت ابوہریرہ رضی اللہ عنہ سے حدیث بیان ک"}
{"hadithnumber": "3651", "text": "زہری کے بھتیجے نے اپنے چچا  ( زہری )  سے اسی سند کے ساتھ بالکل اسی کے مانند روایت کی"}
