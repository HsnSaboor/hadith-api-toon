18364,"أذعشحأدتثشأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أحوأهًڲأډوڬزتشأځۏطتىۏًڽأًتهەأۄًأۗ‛‛أأۏۄأشًتۏحأتوتوأتثًۏؼهۏٳأىەأىمهأڬۏأۄەأتًشأتضأڬەأشدتهأظذۏذأڬەأشدتهأۄۏڽأۗأ+أؼهتوۄأۄۏخوۏألشوتحەأۄۏڽأ=أ,أوۏڽأۏۄأڬۄحتأۄًڽأ=أتضأضەأځۄهەأتضأىًؼۏحأڬۏأڬډہأتذتزۏخأڬحتثأتهغۄتشۆأوۏڽأڲصشأډڬۏأۄۏڽأۗ

[تخریج]: حدیث : 18364 - اخرجه ابو يعلى في المسند """" (2162)"
18365,"أؼڬشوۄأثۏتىأڬشحەأۄۏڽأ=أتههۄأحؼتهۏٳأڬەأزًىًڽأۄتحہأزتةۏڽأۄۏڽأ؏أًۄأإضوتىًڽأڬًأهځۏټأڬشأتځىەأتۏڬأۄتحہأوۏڽأځڬڔەأڲتأتًشأځہشأۏۄألشوتةەأڲتأ=أوۏڽأثتزطتۄأۄًڽأ؏أرًزأڬًأصثشزضحأضودہىەأًتهەأهًڲأڬۄتڽأۄۏڽأآأحڬثشأڬشىەأًتهەأهًڲأڬۄتڽأۄۏڽأآأأًۄأڬۄحەأۄۏڽأ=أځہشأًۄأحوتوأصوۏىًڽأڬًأتځىەأزًضشەأۄتحہأوۏڽأځڬڔەأڲتأتًشأۏۄألشوتةەأڲتأ=أوۏڽأثتزطتۄأۄًڽأ؏أرًزأڬًأصثشزضحأضودہىەأًتهەأهًڲأڬۄتڽأۄۏڽأآأحڬثشأڬشىەأًتهەأهًڲأڬۄتڽأۄۏڽأآأأؼوشأثىأذوصۄأڬۄحەأۄۏڽأ=أوۏڽأىەأۏۄأشًتۏحأضتهوأثىأؼثزتههۄأڬًأضىتةۏأحًأضتهوأىەأثحتۏتأ=أذعشحأؼثزتههۄأثىأؼوشأشعۏأتههۄأؼىۄوتأىەأۄوۏڽأۏۄأثتحأثۏتىأڬۏأۄەأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أأ““أمۏتوحأڬەأزىأتههۄأحؼتهۏٳأإضوتىًڽأڬًأهځۏټەأڲتأتًشأتىۄۏڽأزتةۏڽأۄتحہأوۏڽأهەأڲتأتًشألشوتةەأڲتأ=أوۏڽأثتزطتۄأۄًڽأ؏أرًزأڬًأصثشزضحأضودہىەأًتهەأهًڲأڬۄتڽأۄۏڽأآأحڬثشأڬشىەأًتهەأهًڲأڬۄتڽأۄۏڽأآأځہشأًۄأحوتوأصوۏىًڽأڬًأهځۏټأڬشأتىۄۏڽأثتةۏڽأۄتحہأڬەأسشۏؼەأځڬڔأڬشأځہشأۏۄألشوتةەأڲتأ=أوۏڽأثتزطتۄأۄًڽأ؏أرًزأڬًأصثشزضحأضودہىەأًتهەأهًڲأڬۄتڽأۄۏڽأآأحڬثشأڬشىەأًتهەأهًڲأڬۄتڽأۄۏڽأآ‛‛ۗأ+أؼهتوۄأۄۏخوۏألشوتحەأۄۏڽأ=أ,أوۏڽأۏۄأڬۄحتأۄًڽأ=أذعشحأؼثزتههۄأثىأؼوشأشعۏأتههۄأؼىۄوتأڬۏأىمهأڬشزۄأذزۏخأ““أظذۏذأ‛‛أوۏڽأتضأڬۏأثۄأىضثحأترحظتشأڬەأضتحہأوىمًهأۄەأ؏أۏۄأشًتۏحأتوتوأتثًۏؼهۏٳأىەأىمهأڬۏأۄەأتًشأتضأڬەأشدتهأظذۏذأڬەأشدتهأۄۏڽأ؏أظشلأذضىأثىأذوتزأضدتزۄأڬتأوؼتوهۄأورحهلأۄەأتًشأًۄأخمۄأۄەأۗ

[تخریج]: حدیث : 18365 - اخرجه ابو يعلى في """"المسند"""" (5558)"
18366,"أذعشحأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄأىثۏأتڬشوأ﷽أڬەأذًتهەأضەأتههۄأحؼتهۏٳأڬەأتضألشوتىأڬەأثتشەأوۏڽأىمهأڬشحەأۄۏڽأ=أ+أتشطتزأثتشۏأحؼتهۏٳأۄەأ=أ,أأ““أدضأزىأصوۏىأڬًأزًضشۏأصوۏىأوۏڽأحثزۏهأڬشأزۏتأدتةەأڲتأۗ‛‛أىثۏأتڬشوأ﷽أىەأۏۄألشوتۏتأۄەأ=†أًۄأتۏڬأضلۏزأصوۏىأۄًأڲۏأ؏أدضأځشأرًىأىۄۏڽأثۄتۏتأڲۏتأۄًأڲتأتًشأدضأځشأڬضۏأڲىتۄأڬتأتشحڬتثأىۄۏڽأڬۏتأڲۏتأۄًأڲتأۗ‛‛أأۏۄأشًتۏحأتوتوأثصتشأىەأىمهأڬۏأۄەأ؏أتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأدشۏشأثىأتۏًثأۄەأتًشأتضأڬەأعؼۏلأۄًىەأځشأتحلتمأۄەأۗ

[تخریج]: حديث : 18366 - اخرجه البزار في """"المسند"""" (3431)"
18367,"أذضىأثۏتىأڬشحەأۄۏڽأ=أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأىەأۄوۏڽأذزۏخأثۏتىأڬۏأ=أدثأًۄأتًشأۄوأوزۏىۄأوىًشۄأوۏڽأوًدًزأحہەأتىۄًڽأىەأثحتۏتأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأۄەأ=أأ““أمۏتوحأڬەأزىأتؼوتهأإةۏڽأڲەأ؏أىوتصأإةەأڲۏأتًشأؼشعأڬشەأڲۏأ=أتەأوۏشەأځشًشزڲتشأ$أوۏڽأىوتصأۄًڽأ؏أحًأځشًشزڲتشألشوتةەأڲتأ=أحوأثہهتةۏأځشأۄًأ؏أظزمۄأإةەأڲتأتًشأؼشعأڬشەأڲتأ=أتەأوۏشەأځشًشزڲتشأ$أوۏڽأظزمۄأۄًڽأ؏أحًأځشًشزڲتشألشوتةەأڲتأ=أحوأثہهتةۏأځشأۄًأ؏أځہشأشًصۄأإةەأڲتأتًشأؼشعأڬشەأڲتأ=أتەأوۏشەأځشًشزڲتشأ$أوۏڽأشًصۄأۄًڽأ؏أځشًشزڲتشألشوتةەأڲتأ=أحوأثہهتةۏأځشأۄًأ؏أتضۏأغشذأورحهلأتؼوتهأإحەأشۄۏڽأڲەأتًشأتههۄأحؼتهۏٳألشوتحتأشۄەأڲتأ=أحوأثہهتةۏأځشأۄًأ؏أځہشأتضهتوأإةەأڲتأتًشأؼشعأڬشەأڲتأ=أتەأځشًشزڲتشأ$أحًأضهتوحۏأؼغتأڬشىەأًتهتأۄەأتًشأوۏڽأتضهتوأۄًڽأ؏أتههۄأحؼتهۏٳألشوتةەأڲتأ=أثەأطڬأحوأثہهتةۏأځشأۄًأتًشأحوۄتشۏأًدۄأضەأإدأوۏڽأڲشلحأڬشًڽأڲتأتًشأحوۄتشۏأًدۄأضەأإدأوۏڽأؼغتأڬشًڽأڲتأۗ‛‛أأتههۄأحؼتهۏٳأىەأتځىۏأڬحتثأوۏڽأۏۄأتشطتزألشوتۏتأۄەأ=أدًأطرظأتضهتوأڬەأؼهتًۄأڬًةۏأتًشأزۏىأحهتطأڬشەأڲتأحًأًۄأتضأڬۏأغشلأضەأمثًهأىۄۏڽأڬۏتأدتةەأڲتأتًشأًۄأطرظأإرشحأوۏڽأرضتشۄأځتىەأًتهًڽأوۏڽأضەأۄًأڲتأۗ‛‛أۏۄأشًتۏحأتوتوأتذوزأتًشأتوتوأتثًۏؼهۏٳأىەأىمهأڬۏأۄەأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأتًشأتىہًڽأىەأۏۄأتهلتػأصتةزأىمهأڬۏەأۄۏڽأ=أتههۄأحؼتهۏٳألشوتحتأۄەأ=أأ““أثۏطڬأتههۄأحؼتهۏٳأڬەأىصزۏڬأزۏىأ؏أتضهتوأۄەأۗ‛‛+أتۏڬأتًشأومتوأځشأتههۄأحؼتهۏٳأىەأۏۄأتشطتزألشوتۏتأۄەأ=أ,أ““أتًشأدًأطرظأتضهتوأڬەأؼهتًۄأڬًةۏأتًشأزۏىأحهتطأڬشەأڲتأحًأًۄأتضأڬۏأغشلأضەأمثًهأىۄۏڽأۄًأڲتأتًشأًۄأطرظأإرشحأوۏڽأرضتشۄأځتىەأًتهًڽأوۏڽأضەأۄًأڲتأۗ‛‛أتضأشًتۏحأڬۏأضىزأوۏڽأتۏڬأشتًۏأؼثتزأثىأشتطزأۄەأدضەأتثًذتحوأتًشأزۏڲشأذعشتحأىەأخمۄأمشتشأزۏتأۄەأتًشأتۏڬأدوتؼحأىەأتضەأعؼۏلأڬۄتأۄەأ؏أتوتوأتذوزأڬەأثمۏۄأشدتهأظذۏذأڬەأشدتهأۄۏڽأۗ

[تخریج]: حديث : 18367 - اخرجه ابو يعلى في المسند (6231) اخرجه احمد في المسند """" (362/2)"
18368,"أذعشحأؼثزتههۄأثىأؼوشًأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أأ““أوۏڽأىەأهًڲًڽأڬًأزۏڬہتأڬۄأتىۄۏڽأذضتثأڬەأهۏەأدوؼأڬۏتأڲۏتأۄەأۗ‛‛أۏۄأشًتۏحأتوتوأتثًۏؼهۏٳأىەأىمهأڬۏأۄەأتًشأتضأڬەأشدتهأظذۏذأڬەأشدتهأۄۏڽأۗ

[تخریج]: حدیث : 18368 - اخرجه أبو يعلى في """"المسند"""" (5524)"
18369,"أذعشحأدتثشأثىأؼثزتههۄأشعۏأتههۄأؼىۄوتأثۏتىأڬشحەأۄۏڽأ=أودہەأتۏڬأظتذثأڬەأثتشەأوۏڽأځحۄأډهتأڬۄأتىۄًڽأىەأىثۏأتڬشوأ﷽أضەأتۏڬأذزۏخأضىۏأۄًةۏأۄەأحًأوۏڽأىەأتۏڬأتًىټأرشۏزتأ؏أتْضأځشأځتهتىأثتىزہتأتًشأځہشأتۏڬأوتۄأڬۏأوضتلحأڬتألتظهۄأغەأڬشأڬەأتىأظتذثأڬەأځتضأځۄىډتأ؏أۏۄتڽأحڬأڬۄأطتوأوۏڽأ؏أوۏڽأتىأڬەأځتضأإأڲۏتأ؏أًۄأذعشحأؼثزتههۄأثىأتىۏضأشعۏأتههۄأؼىۄأحہەأ؏أوۏڽأىەأزشثتىأضەأڬۄتأ=أحوأتْىأضەأڬۄًأڬۄأزشًتصەأځشأدتثشأوًدًزأۄەأ؏أزشثتىأىەأزشۏتلحأڬۏتأ=أًۄأدًأذعشحأؼثزتههۄأشعۏأتههۄأؼىۄأڬەأظتذثصتزەأۄۏڽأآأوۏڽأىەأدًتثأزۏتأ=أدۏأۄتڽأ$أحًأذعشحأؼثزتههۄأثىأتىۏضأشعۏأتههۄأؼىۄأتځىەأڬځڔەأڬًأڲہضۏټحەأۄًةەأثتۄشأإةەأتًشأتىۄًڽأىەأودہەأڲهەأهڲتأهۏتأتًشأوۏڽأىەأتىۄۏڽأڲهەأهڲتأهۏتأ؏أوۏڽأىەأڬۄتأ=أودہەأتۏڬأذزۏخأڬەأثتشەأوۏڽأۏۄأځحۄأډهتأحہتأڬۄأإځأىەأتضەأىثۏأتڬشوأ﷽أڬۏأصثتىۏأضىتأۄًتأۄەأتًشأًۄأمظتظأڬەأثتشەأوۏڽأۄەأ؏أحًأودہەأۏۄأتىزۏطۄأۄًتأڬۄأڬۄۏڽأوۏشەأتضأذزۏخأڬًأضىىەأضەأځۄهەأإځأڬتأتىحمتهأىۄأۄًأدتةەأ؏أۏتأوۏشتأتىحمتهأىۄأۄًأدتةەأ؏أحًأذعشحأؼثزتههۄأثىأتىۏضأشعۏأتههۄأؼىۄأىەأثحتۏتأ=أوۏڽأىەأىثۏأتڬشوأ﷽أڬًأۏۄأتشطتزألشوتحەأۄًةەأضىتأۄەأ=أ““أمۏتوحأڬەأزىأتههۄأحؼتهۏٳأثىزًڽأڬًأ+أشتًۏأڬًأطڬأۄەأۏتأطتۏزأۏۄأتهلتػأۄۏڽأ=أ,أهًڲًڽأڬًأثشۄىۄأځتاڽأثشۄىۄأدضوأرحىەأڬەأثؽۏشأ““أثۄوأ‛‛أذتهحأوۏڽأصىزۄأڬشەأڲتأ؏أشتًۏأڬۄحەأۄۏڽأ=أۄوأىەأؼشعأڬۏأ=““أثۄوأ‛‛أضەأوشتزأڬۏتأۄەأآأىثۏأتڬشوأ﷽أىەألشوتۏتأ=أتىأڬەأځتضأڬًةۏأډۏصأىۄۏڽأۄًأڲۏأ؏أځہشأتىۄۏڽأتۏڬأوىتزۏأځڬتشأڬشأۏۄأڬۄەأڲتأ؏أتضأځڬتشأڬًأزًشأڬتأإزوۏأثہۏأتضۏأغشذأضىأهەأڲتأدضأغشذأمشۏثأڬتأإزوۏأتضەأضىأضڬەأڲتأ؏أًۄأۏۄألشوتةەأڲتأ=أوۏڽأثتزطتۄأۄًڽأ؏أوۏڽأثتزطتۄأۄًڽأ؏أوۏڽأ““أزۏتىأ‛‛أ+أۏؼىۏألۏظهۄأڬشىەأًتهتأ؏أۏتأتډہەأثشەأڬتأثزهۄأزۏىەأًتهتأ,أۄًڽأ؏أتۄهأدۄىوأوۏڽأضەأڬضۏأڬەأهۏەأۏۄأوىتضثأىۄۏڽأۄەأڬۄأًۄأدۄىوأوۏڽأزترهأۄًأدتةەأدثڬۄأتضأىەأتۄهأدىحأوۏڽأضەأڬضۏأضەأڬًةۏأذمأًظًهأڬشىتأۄًأ؏أحًأدثأحڬأوۏڽأتضأڬًأتضأڬتأذمأىۄۏڽأزهًتأزۏحتأ+أۏؼىۏأتضأًمحأحڬأۏۄأوىتضثأىۄۏڽأۄەأڬۄأًۄأدۄىوأوۏڽأزترهأۄًأ,أتًشأتۄهأدىحأوۏڽأضەأڬضۏأڬەأهۏەأۏۄأوىتضثأىۄۏڽأۄەأڬۄأًۄأدىحأوۏڽأزترهأۄًأدثڬۄأتضأىەأتۄهأدۄىوأوۏڽأضەأڬضۏأضەأذمأًظًهأڬشىتأۄًأ؏أدثأحڬأوۏڽأتضأڬتأذمأتضأزًضشەأضەأتْضەأىۄۏڽأزهًتأزۏحتأ؏أۏۄتڽأحڬأڬۄأحہځڔأوتشىەأحڬأڬتأوؼتوهۄأثہۏأتضأوۏڽأطتوهأۄًأڲتأ؏أۄوأىەأؼشعأڬۏأ=أۏۄأڬۏضەأۄًأڲتأآأدثڬۄأۄوأثشۄىۄأذتهحأوۏڽأ؏أرحىۄأڬەأثؽۏشأ؏أڬضۏأډۏصأڬەأثؽۏشأۄًڽأڲەأآأىثۏأتڬشوأ﷽أىەألشوتۏتأ=أىۏڬۏًڽأتًشأثشتةۏًڽأ+أڬەأذضتثأ,أضەأهۏىأزۏىأۄًأڲتأۗ‛‛أۏۄأشًتۏحأتوتوأتذوزأىەأىمهأڬۏأۄەأتًشأتضأڬەأشدتهأڬۏأحًخۏمأڬۏأڲةۏأۄەأ؏أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأتضأڬۏأوتىىزأىمهأڬۏأۄەأ؏أحتۄوأتىۄًڽأىەأتضأوۏڽأۏۄأتهلتػأىمهأڬةەأۄۏڽأ=““أوظشأوۏڽأۗ‛‛أأ+أؼهتوۄأۄۏخوۏألشوتحەأۄۏڽأ=أ,أوۏڽأۏۄأڬۄحتأۄًڽأ=أتضأضەأځۄهەأذعشحأومزتوأثىأوؼزۏڬشثأشعۏأتههۄأؼىۄأتًشأذعشحأومزتزأثىأتضًزأشعۏأتههۄأؼىۄأڬۏأىمهأڬشزۄأذزۏخأتضأثتثأوۏڽأڲصشأډڬۏأۄەأدًأزًثتشۄأصىزۄأڬۏەأدتىەأضەأوحؼهمأشًتۏتحأڬتأودوًؼۄأۄەأۗ

[تخریج]: حدیث : 18369 - اخرجه احمد في """"المسند """" (495/3)"
18370,"أذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أأ““أمۏتوحأڬەأزىأثىزەأڬەأځتاڽأتځىۏأدڲۄأضەأتضأًمحأحڬأىۄۏڽأۄهۏڽأڲەأدثأحڬأتضأضەأډتشأډۏصًڽأڬەأثتشەأوۏڽأذضتثأىۄۏڽأهەأهۏتأدتحتأ؏أتضأڬۏأؼوشأڬەأثتشەأوۏڽأڬۄأتضأىەأڬضأڬتوأوۏڽأتضەأثضشأڬۏتأآأتضأڬەأدضوأڬەأثتشەأوۏڽأڬۄأتضأىەأڬضأڬتوأوۏڽأتضەأثًضۏزۄأڬۏتأآأتضأڬەأوتهأڬەأثتشەأوۏڽأڬۄأتضأىەأڬۄتڽأتضەأرشډأڬۏتأتًشأڬۏضەأتضأڬًأڬوتۏتأآأتًشأتضأڬۏأۄوتشەأضتحہأ+أۏؼىۏأتۄهأثۏحأڬەأضتحہأ,أوذثحأڬەأثتشەأوۏڽأ+أتضأضەأذضتثأهۏتأدتةەأڲتأ,أۗ‛‛أأۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأڬثۏشأتًشأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأذضۏىأثىأذضىأتطمشأۄەأتًشأًۄأتىحۄتةۏأعؼۏلأۄەأتثىأذثتىأىەأتضەأخمۄأمشتشأزۏتأۄەأتڲشډۄأًۄأتضهتلأڬًأثشتأڬۄحتأۄەأۗ

[تخریج]: حديث : 18370 - اخرجه الطبراني في """"المعجم الكبير (11177)"
18371,"أذعشحأتثًثشصۄأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أأ““أ+أمۏتوحأڬەأزىأ,أثىزەأڬەأمزوأتځىۏأدڲۄأضەأتْضأًمحأحڬأىۄۏڽأۄهۏڽأڲەأدثأحڬأتضأضەأډتشأډۏصًڽأڬەأثتشەأوۏڽأذضتثأىۄۏڽأهۏتأدتحتأ؏أتْضأڬەأدضوأڬەأثتشەأوۏڽأڬۄأتضأىەأڬضأڬتوأوۏڽأتضەأثًضۏزۄأڬۏتأآأتضأڬۏأؼوشأڬەأثتشەأوۏڽأڬۄأتضأىەأڬضأڬتوأوۏڽأتضەألىتأڬۏتأآأتضأڬەأوتهأڬەأثتشەأوۏڽأڬۄأتضأىەأڬۏضەأتضەأڬوتۏتأتًشأڬۄتڽأرشډأڬۏتأآأتًشأۄوأتۄهأثۏحأڬەأضتحہأوذثحأڬەأثتشەأوۏڽأ+أتضأضەأذضتثأهۏتأدتةەأڲتأ,أؼشعأڬۏأڲةۏأ=أۏتأشضًهأتههۄأ$أإځأهًڲًڽأڬەأضتحہأوذثحأڬۏأؼهتوحأڬۏتأۄەأآأحًأىثۏأتڬشوأ﷽أىەأتځىتأزضحأوثتشڬأذعشحأؼهۏأشعۏأتههۄأؼىۄأڬەأڬىزہەأځشأهڲتۏتأۗ‛‛أأۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأۏۄأتوتوأحشوسۏأىەأثہۏأىمهأڬۏأۄەأحتۄوأتىۄًڽأىەأۏۄأتهلتػأتًشأتضأڬەأثؼزأًتهتأذظۄأىمهأىۄۏڽأڬةەأۄۏڽأ=†أۄوأتۄهأثۏحأڬەأضتحہأوذثحأڬەأثتشەأوۏڽأۗ‛‛أأتىۄًڽأىەأډًحہۏأډۏصأىمهأڬۏأۄەأ=““أتْضأضەأؼهوأڬەأثتشەأوۏڽأذضتثأهۏتأدتةەأڲتأڬۄأتضأىەأتضأځشأڬحىتأؼوهأڬۏتأۗ‛‛أغثشتىۏأڬۏأضىزأوۏڽأتۏڬأشتًۏأذتشخأثىأوذوزأڬًلۏأۄەأدضەأوؼڬًلأڬۄتأدتحتأۄەأ†أوۏصتىأ‟أڬەأوظىلأىەأۏۄأڬۄتأۄەأ=أۏۄأدہًټۏأشًتۏحأىمهأڬشحتأۄەأتضأشًتۏحأڬەأثتمۏأشدتهأخمۄأۄۏڽأۗ"
18372,"أذعشحأتثًزشزتؤأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أأ““أمۏتوحأڬەأزىأإزوۏأڬەأمزوأتځىۏأدڲۄأضەأتضأًمحأحڬأىۄۏڽأۄهۏڽأڲەأدثأحڬأتضأضەأډتشأډۏصًڽأڬەأثتشەأوۏڽأذضتثأىۄۏڽأهەأهۏتأدتحتأ؏أتْضأڬۏأدًتىۏأڬەأثتشەأوۏڽأڬۄأتضأىەأڬضأڬتوأوۏڽأتضەأثًضۏزۄأڬۏتأآأتضأڬۏأؼوشأڬەأثتشەأوۏڽأڬۄأتضأىەأڬضأڬتوأوۏڽأتضەألىتأڬۏتأآأتضأڬەأوتهأڬەأثتشەأوۏڽأڬۄأتضأىەأڬۄتڽأضەأڬوتۏتأتًشأڬضأڬتوأوۏڽأرشډأڬۏتأآ‛‛ۗأۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأڬثۏشأتًشأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأتثًثڬشأزتۄشۏأۄەأتًشأًۄأتىحۄتةۏأعؼۏلأۄەأۗ"
18373,"أذعشحأوؼتسأثىأدثهأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أأ““أمۏتوحأڬەأزىأثىزەأڬەأمزوأتځىۏأدڲۄأضەأتْضأًمحأحڬأىۄۏڽأۄهۏڽأڲەأدثأحڬأتضأضەأډتشأډۏصًڽأڬەأثتشەأوۏڽأذضتثأىۄۏڽأهەأهۏتأدتحتأ؏أتضأڬۏأؼوشأڬەأثتشەأوۏڽأڬۄأتضأىەأڬضأڬتوأوۏڽأتضەألىتأڬۏتأ؏أتضأڬۏأدًتىۏأڬەأثتشەأوۏڽأڬۄأتضأىەأڬضأڬتوأوۏڽأتضەأثًضۏزۄأڬۏتأ؏أتضأڬەأوتهأڬەأثتشەأوۏڽأڬۄأتضأىەأڬۄتڽأضەأتضأڬًأڬوتۏتأتًشأڬۄتڽأرشډأڬۏتأتًشأتضأڬەأؼهوأڬەأثتشەأوۏڽأڬۄأتضأىەأڬۄتڽأحڬأتضأځشأؼوهأڬۏتأۗ‛‛أۏۄأشًتۏحأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأتًشأتوتوأثصتشأىەأتضأڬۏأوتىىزأىمهأڬۏأۄەأ؏أتوتوأغثشتىۏأڬەأشدتهأظذۏذأڬەأشدتهأۄۏڽأ؏أظشلأظتوحأثىأوؼتسأتًشأؼزۏأثىأؼزۏأڬىزۏأڬتأوؼتوهۄأورحهلأۄەأتًشأۏۄأزًىًڽأخمۄأۄۏڽأۗ

[تخریج]: حدیث : 18373 - اخرجه البزار في """"المسند"""" (3437) اخرجه الطبراني في """"المعجم الكبير """" (60/20)"
18374,"أذعشحأؼثزتههۄأثىأؼوشأشعۏأتههۄأؼىۄوتأثۏتىأڬشحەأۄۏڽأ=أوۏڽأىەأىثۏأتڬشوأ﷽أڬًأۏۄأتشطتزألشوتحەأۄًةەأضىتأۄەأ=أ““أدثأمۏتوحأڬتأزىأۄًأڲتأحًأتههۄأحؼتهۏٳأتۏڬأثىزەأڬًأثهتةەأڲتأتضەأتځىەأضتوىەأڬہڔتأڬشەأڲتأتًشأتضأضەأتضأڬەأدتۄأًأوىظثأڬەأثتشەأوۏڽأذضتثأهەأڲتأ؏أدضأغشذأًۄأتضأضەأتضأڬەأوتهأڬەأثتشەأوۏڽأذضتثأهەأڲتأۗ‛‛أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأظؽۏشأوۏڽأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأۏًضلأثىأۏًىضأۄەأدًأتثًوضهوأتلغضأڬتأثہتةۏأۄەأتًشأًۄأتىحۄتةۏأعؼۏلأۄەأۗ

[تخریج]: حدیث : 18374 - اخرجه الطبراني في """" المعجم الصغير (18) اخرجه الطبراني في """" المعجم الاوسط """" (451)"
18375,"أذعشحأثشۏزۄأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أ““أحوأوۏڽأضەأۄشأتۏڬأڬەأضتحہأؼىمشۏثأتههۄأحؼتهۏٳأۏًڽأڬهتوأڬشەأڲتأڬۄأتههۄأحؼتهۏٳأتًشأتْضأطرظأڬەأزشوۏتىأڬًةۏأذدتثأۏتأڬًةۏأحشدوتىأىۄۏڽأۄًأڲتأۗ‛‛أأۏۄأشًتۏحأتوتوأثصتشأىەأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأؼثزتهؼصۏصأثىأتثتىأۄەأتًشأًۄأوحشًڬأۄەأۗ

[تخریج]: حدیث : 18375 - اخرجه البزار في """"المسند"""" (3440)"
18376,"أؼثزتههۄأثىأؼڬۏوأثۏتىأڬشحەأۄۏڽأوۏڽأىەأذعشحأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄأڬًأتضأوضدزأوۏڽأۏۄأثۏتىأڬشحەأۄًةەأضىتأۄەأ=أتىۄًڽأىەأڲلحڲًأضەأځۄهەأمضوأڬەأسشۏؼەأتځىەأڬهتوأڬتأإؽتصأڬۏتأتًشأځہشأۏۄألشوتۏتأ=أأ““أحوأوۏڽأضەأۄشأتۏڬأڬەأضتحہأتضأڬتأځشًشزڲتشأتىلشتزۏأغًشأځشأۏًڽأڬهتوأڬشەأڲتأدضأغشذأډًزہًۏڽأشتحأوۏڽأ؏أحوأوۏڽأضەأڬضۏأتۏڬأڬەأضتوىەأډًزہًۏڽأڬتأډتىزأتڬۏهتأۄًحتأۄەأ؏أځشًشزڲتشألشوتةەأڲتأ=أتەأتثىأإزوأ$أوۏشۏأستحأڬەأثتشەأوۏڽأڬضأډۏصأىەأحوۄۏڽأؽهغألۄوۏأڬتأطڬتشأڬۏتأآأتەأتثىأإزوأ$أوۏشۏأستحأڬەأثتشەأوۏڽأڬضأډۏصأىەأحوۄۏڽأؽهغألۄوۏڬتأطڬتشأڬۏتأآأتەأتثىأإزوأ$أحوأىەأوشضهۏىأڬۏأزؼًحأڬتأڬۏتأدًتثأزۏتأآأتەأتثىأإزوأ$أحوأىەأوشضهۏىأڬۏأزؼًحأڬتأڬۏتأدًتثأزۏتأآأتەأتثىأإزوأ$أحوأىەأڬۏتأؼوهأڬۏتأآأتەأتثىأإزوأ$أحوأىەأڬۏتأؼوهأڬۏتأآأتەأتثىأإزوأ$أحوۄۏڽأدًأؼهوأحہتأتضأڬەأذًتهەأضەأحوأىەأڬۏتأؼوهأڬۏتأآأتەأتثىأإزوأ$أحوۄۏڽأدًأؼهوأحہتأتضأڬەأذًتهەأضەأحوأىەأڬۏتأؼوهأڬۏتأآ‟ۗأۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأڬثۏشأوۏڽأوًمًلأشًتۏحأڬەأغًشأځشأىمهأڬۏأۄەأتىۄًڽأىەأتضأڬتأڬډہأذظۄأوشلًؼأشًتۏحأڬەأغًشأځشأوؼدوأتًضغأوۏڽأىمهأڬۏتأۄەأ+أدضأڬەأتهلتػأۏۄأۄۏڽأ=أ,أأ““أتەأوۏشەأثىزەأ$أڬضأډۏصأىەأحوۄۏڽأوۏشۏأستحأڬەأثتشەأوۏڽأؽهغألۄوۏأڬتأطڬتشأڬۏتأآأحوأىەأوشضهۏىأڬۏأزؼًحأڬتأڬۏتأدًتثأزۏتأآ‛‛ۗأوؼدوأڬثۏشأڬەأشدتهأظذۏذأڬەأشدتهأ؏أظذۏذأڬەأشدتهأۄۏڽأ؏أظشلأطشۏڬأثىأؼثزتههۄأڬتأوؼتوهۄأورحهلأۄەأًۄأخمۄأۄەأتًشأتضأوۏڽأعؼلأځتۏتأدتحتأۄەأوؼدوأتًضغأڬەأشدتهأوۏڽأثہۏأطشۏڬأىتوۏأشتًۏأۄەأتضأڬەأؼهتًۄأتضذتمأثىأؼثزتههۄأحوۏوۏأۄەأدضەأتثىأذثتىأىەأخمۄأمشتشأزۏتأۄەأتضأشًتۏحأڬەأثمۏۄأشدتهأظذۏذأڬەأشدتهأۄۏڽأۗ

[تخریج]: حديث : 18376 - اخرجه الطبراني في """"المعجم الكبير """" (8899)"
18377,"أذعشحأخًثتىأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأضًتهأ+أۏؼىۏأذضتثأ,أڬەأوضةهەأڬۏأؼػوحأڬتأتػۄتشأڬشحەأۄًةەأۏۄألشوتۏتأ=أأ““أدثأمۏتوحأڬتأزىأۄًأڲتأحًأصوتىۄأدتۄهۏحأضەأحؼهمأشڬہىەأًتهەأهًڲأإةۏڽأڲەأتىۄًڽأىەأتځىەأثحًڽأڬًأتځىۏأځطحًڽأځشأتټہتۏتأۄًتأۄًأڲتأ؏أتىأڬتأځشًشزڲتشأتىأضەأضًتهأڬشەأڲتأحًأًۄأدًتثأزۏڽأڲەأ=أتەأۄوتشەأځشًشزڲتشأ$أحًأىەأۄوتشەأهۏەأڬضۏأشضًهأڬًأوثؼًخأىۄۏڽأڬۏتأتًشأۄوتشەأځتضأحۏشتأڬًةۏأذڬوأىۄۏڽأإۏتأ؏أتڲشأحًأۄوتشۏأغشلأشضًهأڬًأوثؼًخأڬشأزۏحتأحًأۄوأحۏشەأضثأضەأصۏتزۄألشوتىثشزتشأثىزەأثىأدتحەأ؏أحًأځشًشزڲتشأتْىأضەألشوتةەأڲتأ=أتضأثتشەأوۏڽأحوۄتشتأڬۏتأرۏتهأۄەأآأڬۄأتڲشأوۏڽأحوۄۏڽأڬًةۏأذڬوأزًڽأحًأحوأوۏشۏأتغتؼحأڬشًأڲەأآأځہشأځشًشزڲتشأتضأذًتهەأضەأتىأهًڲًڽأضەأځرحۄأؼۄزأهەأڲتأ؏أځہشأًۄألشوتةەأڲتأ=أحوأهًڲأتضأ+أۏؼىۏأدۄىوأ,أڬۏأغشلأدتاأ$أتًشأتضأوۏڽأزترهأۄًأدتاأ؏أًۄأهًڲأشًتىۄأۄًڽأڲەأ؏أۏۄتڽأحڬأڬۄأدثأًۄأتضەأزۏڬہۏڽأڲەأحًأتضأضەأڋشأدتةۏڽأڲەأتًشأًتځضأإأدتةۏڽأڲەأتًشأڬۄۏڽأڲەأ=أۄوأتْضأضەأڋشأڲةەأۄۏڽأ؏أۄوأتضأوۏڽأزترهأۄًىەأڬۏأتضحغتؼحأىۄۏڽأشڬہحەأۄۏڽأ؏أځشًشزڲتشألشوتةەأڲتأ=أحوأهًڲأسهۏهأۄًأڬشأتضأوۏڽأزترهأۄًأدتاأۗ‛‛أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أتڲشأًۄأهًڲأځۄهۏأوشحثۄأوۏڽأ؏أتْضأوۏڽأزترهأۄًأدتحەأحًأًۄأتْىأڬەأهۏەأټہىڋڬأًتهۏأتًشأضهتوحۏأًتهۏأۄًأدتحۏأۗ‛‛أۏۄأشًتۏحأتوتوأثصتشأىەأزًأعؼۏلأتضىتزأڬەأضتحہأىمهأڬۏأۄەأۗأأتضأضەأځۄهەأڬحتثأتهمزشأوۏڽأًۄأتذتزۏخأڲصشأډڬۏأۄۏڽأ؏أدًأتىأهًڲًڽأڬەأثتشەأوۏڽأۄۏڽأ؏أدًأصوتىۄألحشحأوۏڽألًحأۄًأڲةەأحہەأۗ

[تخریج]: حديث : 18377 - اخرجه البزار في المسند """" (3433)"
18378,"أذضىأثۏتىأڬشحەأۄۏڽأ=أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأىەأۄوۏڽأ؏أىثۏأتڬشوأ﷽أڬەأوىثشأځشأرغثۄأزۏحەأۄًةەأۏۄأتشطتزألشوتۏتأ=أوۏڽأىەأىثۏأتڬشوأ﷽أڬًأۏۄألشوتحەأۄًةەأضىتأۄەأ=أأ““أمۏتوحأڬەأزىأتههۄأحؼتهۏٳأذعشحأإزوأؼهۏۄأتهضهتوأڬەأضتوىەأحۏىأتوًشأڬەأذًتهەأضەأًدۄأثۏتىأڬشەأڲتأ؏أتههۄأحؼتهۏٳألشوتةەأڲتأ=أتەأإزوأ$أتڲشأتۏضتأىۄأۄًحتأڬۄأوۏڽأىەأدہًټأثًهىەأًتهًڽأځشأهؼىحأڬۏأۄەأتًشأوۏڽأدہًټأتًشأًؼزۄأرهتلۏأڬًأىتځضىزأڬشحتأۄًڽأتًشأوۏڽأىەأتضأذًتهەأضەأًؼۏزأثۏتىأڬۏأۄەأحًأإدأڬەأزىأوۏڽأىەأحوۄتشۏأضتشۏأتًهتزأځشأشذوأڬشأزۏىتأحہتأ؏أتضأؼستثأڬۏأطزحأڬۏأًدۄأضەأدًأوۏڽأىەأتْىأڬەأهةەأحۏتشأڬۏتأۄەأ؏أهۏڬىأوۏشۏأغشلأضەأۏۄأثتحأذمأۄەأڬۄأتڲشأوۏشەأشضًهًڽأڬۏأحڬسۏثأڬۏأڲةۏأتًشأوۏشەأذڬوأڬۏأىتلشوتىۏأڬۏأڲةۏأحًأوۏڽأدۄىوأڬًأدىتحأتًشأتىضتىًڽأزًىًڽأضەأثہشأزًڽأڲتأۗأتههۄأحؼتهۏٳألشوتةەأڲتأ=أتەأإزوأ$أحوأۏۄأثتحأدتىأهًأ$أڬۄأوۏڽأحوۄتشۏأتًهتزأوۏڽأضەأدۄىوأوۏڽأڬضۏألشزأڬًأزترهأىۄۏڽأڬشًڽأڲتأتًشأتىأوۏڽأضەأڬضۏألشزأڬًأإڲأڬتأؼستثأىۄۏڽأزًڽأڲتأ؏أتهثحۄأتضأطرظأڬتأوؼتوهۄأورحهلأۄەأدضأڬەأثتشەأوۏڽأودہەأۏۄأؼهوأۄًأڬۄأتڲشأوۏڽأىەأتضەأزىۏتأڬۏأغشلأهًټتأزۏتأحًأًۄأځۄهەأضەأصۏتزۄأثزحشأؼوهأڬشەأڲتأ؏أًۄأشدًؼأىۄۏڽأڬشەأڲتأتًشأټہۏڬأىۄۏڽأۄًأڲتأۗأأتههۄأحؼتهۏٳألشوتةەأڲتأ=أتەأإزوأ$أوۏڽأحوۄۏڽأتځىەأتًشأحوۄتشۏأسشۏحأڬەأزشوۏتىأختهخأومششأڬشحتأۄًڽأ؏أحوأوۏصتىأڬەأځتضأڬہڔەأۄًأدتاأتًشأتضأثتحأڬتأدتةصۄأهًأڬۄأتىأڬەأتؼوتهأوۏڽأضەأڬۏتأحوۄتشەأضتوىەأځۏطأڬۏتأدتحتأۄەأآأدضأطرظأڬۏأثہهتةۏأتضأڬەأطشأضەأسشەأڬەأًصىأدحىۏأصۏتزۄأۄًةۏأحًأتضەأدىحأوهأدتةەأڲۏأحتڬۄأحوۄۏڽأۏۄأثتحأځحۄأډهأدتةەأڬۄأوۏڽأتْىأوۏڽأضەأدۄىوأوۏڽأظشلأػتهوًڽأڬًأزترهأڬشًڽأڲتأۗ‛‛أأۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏألعهأثىأؼۏضۏٳأشمتطۏأۄەأتًشأًۄأڬستثأۄەأۗ

[تخریج]: حديث : 18378 - اخرجه الطبراني في """"المعجم الصغير """" (855)"
18379,"أذعشحأتىضأشعۏأتههۄأؼىۄأىثۏأتڬشوأ﷽أڬتأۏۄألشوتىأىمهأڬشحەأۄۏڽأ=أ““أػهوأحۏىأمضوأڬتأۄًحتأۄەأ؏أتۏڬأػهوأًۄأۄەأدضأڬۏأتههۄأحؼتهۏٳأوؽلشحأىۄۏڽأڬشەأڲتأتۏڬأػهوأًۄأۄەأدضأڬۏأًۄأوؽلشحأڬشأزەأڲتأتًشأتۏڬأػهوأًۄأۄەأدضەأتههۄأحؼتهۏٳأډہًڔەأڲتأىۄۏڽأ؏أدۄتڽأحڬأتضأػهوأڬتأحؼهمأۄەأ؏أدضأڬۏأتههۄأحؼتهۏٳأوؽلشحأىۄۏڽأڬشەأڲتأحًأًۄأطشڬأۄەأ؏أتههۄأحؼتهۏٳأىەأتشطتزألشوتۏتأۄەأ=أ““أثەأطڬأطشڬأثڔتأػهوأۄەأۗ‛‛أأدۄتڽأحڬأتضأػهوأڬتأحؼهمأۄەأدضأڬۏأتههۄأحؼتهۏٳأوؽلشحأڬشأزەأڲتأحًأۏۄأثىزًڽأڬتأًۄأػهوأۄەأدًأتىۄًڽأىەأتځىەأتًځشأڬۏتأۄًأڲتأدًأتىأڬەأتًشأتىأڬەأځشًشزڲتشأڬەأوتثۏىأوؼتوهتحأڬەأذًتهەأضەأۄًأڲتأۗأدۄتڽأحڬأتضأػهوأڬتأحؼهمأۄەأدضأڬًأتههۄأحؼتهۏٳأډہًڔەأڲتأىۄۏڽأ؏أحًأًۄأثىزًڽأڬتأتۏڬأزًضشەأځشأڬۏتأۄًتأػهوأۄەأ+أتههۄأحؼتهۏٳأتضەأىۄۏڽأډہًڔەأڲتأ,أدثأحڬأًۄأثىزًڽأڬًأتۏڬأزًضشەأضەأثزهۄأىۄۏڽأزهًتأزۏحتأۗ‛‛أۏۄأشًتۏحأتوتوأثصتشأىەأتځىەأتضحتزأتذوزأثىأوتهڬأمطۏشۏأڬەأذًتهەأضەأىمهأڬۏأۄەأتًشأوۏڽأتضأضەأًتملأىۄۏڽأۄًڽأتضأ؏أشًتۏحأڬەأثمۏۄأشدتهأڬۏأحًخۏمأڬۏأڲةۏأۄەأتڲشډۄأتىأوۏڽأعؼلأځتۏتأدتحتأۄەأۗ

[تخریج]: حديث : 18379 - اخرجه البزار في """"المسند"""" (3439)"
18380,"أذعشحأضهوتىألتشضۏأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أأ““أتۏڬأڲىتۄأًۄأۄەأدضأڬۏأوؽلشحأىۄۏڽأۄًأڲۏأ؏أتۏڬأڲىتۄأًۄأۄەأدضەأډہًڔتأىۄۏڽأدتةەأڲتأتًشأتۏڬأڲىتۄأًۄأۄەأ؏أدضأڬۏأوؽلشحأۄًأدتةەأڲۏأ؏أدۄتڽأحڬأتضأڲىتۄأڬتأحؼهمأۄەأدضأڬۏأوؽلشحأىۄۏڽأۄًأڲۏأحًأًۄأتههۄأحؼتهۏٳأڬەأضتحہأطشڬأڬشىتأۄەأ؏أدۄتڽأحڬأتضأڲىتۄأڬتأحؼهمأۄەأدضأڬۏأوؽلشحأۄًأدتةەأڲۏأحًأًۄأثىزەأڬتأًۄأڲىتۄأۄەأدًأتضأڬەأتًشأتههۄأحؼتهۏٳأڬەأوتثۏىأوؼتوهەأڬەأذًتهەأضەأۄًأ؏أدۄتڽأحڬأتضأڲىتۄأڬتأحؼهمأۄەأدضەأډہًڔتأىۄۏڽأدتةەأڲتأحًأًۄأثىزًڽأڬتأتۏڬأزًضشەأڬەأضتحہأ+أػهوأًأصۏتىۏأڬەأغًشأځشأ,أڬۏتأۄًتأڲىتۄأۄەأۗ‛‛أأۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأڬثۏشأتًشأوؼدوأظؽۏشأوۏڽأىمهأڬۏأۄەأ؏أتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأۏصۏزأثىأضلۏتىأثىأؼثزتههۄأثىأشًتذۄأۄەأتًشأًۄأعؼۏلأۄەأ؏أتثىأذثتىأىەأتضأڬەأثتشەأوۏڽأڬهتوأڬۏتأۄەأتضأشًتۏحأڬەأثمۏۄأشدتهأخمۄأۄۏڽأۗ

[تخریج]: حدیث : 18380 - اخرجه الطبراني في """" المعجم الصغير """" (102) اخرجه الطبراني في """" المعجم الكبير """" (6133)"
18381,"أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أأ““أتۏڬأڲىتۄأًۄأۄەأدضأڬۏأوؽلشحأۄًأدتةەأڲۏأ؏أتۏڬأڲىتۄأًۄأۄەأدضأڬۏأوؽلشحأىۄۏڽأۄًأڲۏأ؏أتۏڬأڲىتۄأًۄأۄەأدضأڬتأثزهۄأزهًتۏتأدتةەأڲتأ؏أدۄتڽأحڬأتضأڲىتۄأڬتأحؼهمأۄەأدضأڬۏأوؽلشحأىۄۏڽأۄًأڲۏأ؏أحًأًۄأڬضۏأڬًأتههۄأڬتأطشۏڬأټہۄشتىتأۄەأ؏أدۄتڽأحڬأتضأڲىتۄأڬتأحؼهمأۄەأدضأڬۏأوؽلشحأۄًأدتةەأڲۏأحًأًۄأحوۄتشتأًۄأؼوهأۄەأدضأڬتأحؼهمأحوۄتشەأتًشأحوۄتشەأځشًشزڲتشأڬەأوتثۏىأوؼتوهەأضەأۄًأ؏أدۄتڽأحڬأتضأڲىتۄأڬتأحؼهمأۄەأ؏أدضأڬتأثزهۄأزهًتۏتأدتةەأڲتأحًأًۄأحوۄتشتأتځىەأثہتةۏأځشأػهوأڬشىتأۄەأۗ‛‛أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأغهذۄأثىأؼوشًأۄەأتًشأًۄأوحشًڬأۄەأۗ"
18382,"أضۏزۄأؼتةطۄأظزۏمۄأشعۏأتههۄأؼىۄتأثۏتىأڬشحۏأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أأ““أزًتًۏىأ+أۏؼىۏأتؼوتهأىتوەأ,أتههۄأحؼتهۏٳأڬەأځتضأحۏىأمضوأڬەأۄًڽأڲەأ؏أتۏڬأزۏًتىأًۄأۄًأڲتأدضأڬەأذًتهەأضەأتههۄأحؼتهۏٳأڬًةۏأځشًتۄأىۄۏڽأڬشەأڲتأ؏أتۏڬأزۏًتىأًۄأۄًأڲتأدضأوۏڽأضەأتههۄأحؼتهۏٳأڬًةۏأډۏصأىۄۏڽأډہًڔەأڲتأتًشأتۏڬأزۏًتىأًۄأۄًأڲتأدضأڬۏأتههۄأحؼتهۏٳأوؽلشحأىۄۏڽأڬشەأڲتأۗأدۄتڽأحڬأتضأزۏًتىأڬتأحؼهمأۄەأدضأڬۏأتههۄأحؼتهۏٳأوؽلشحأىۄۏڽأڬشەأڲتأحًأًۄأ+أڬضۏأڬًأ,أتههۄأحؼتهۏٳأڬەأضتحہأطشۏڬأټہۄشتىتأۄەأ؏أتههۄأحؼتهۏٳأىەأتشطتزألشوتۏتأۄەأ=أأ““أدًأطرظأتههۄأحؼتهۏٳأڬەأضتحہأطشڬأڬشەأڲتأحًأتههۄأحؼتهۏٳأتضأځشأدىحأذشتوأڬشأزەأڲتأۗ‛‛أدۄتڽأحڬأتضأزۏًتىأڬتأحؼهمأۄەأدضأڬەأثتشەأوۏڽأتههۄأحؼتهۏٳأڬًةۏأځشًتۄأىۄۏڽأڬشەأڲتأ؏أحًأًۄأثىزەأڬتأتځىەأتًځشأًۄأػهوأڬشىتأۄەأدًأتضأڬەأتًشأتضأڬەأځشًشزڲتشأڬەأزشوۏتىأوؼتوهتحأڬەأذًتهەأضەأۄًأ؏أدۏضەأتضأىەأڬضۏأزىأڬتأشًصۄأحشڬأڬشأزۏتأۄًأۏتأىوتصأحشڬأڬشأزۏأۄًأحًأتههۄأحؼتهۏٳأتضأڬۏأوؽلشحأڬشأزەأڲتأتًشأزشڲصشأڬشەأڲتأ؏أتڲشأًۄأډتۄەأڲتأۗأدۄتڽأحڬأتضأزۏًتىأڬتأحؼهمأۄەأ؏أدضأوۏڽأضەأتههۄأحؼتهۏٳأڬًةۏأثہۏأډۏصأىۄۏڽأډہًڔەأڲتأحًأًۄأثىزًڽأڬتأتۏڬأزًضشەأځشأػهوأڬشىتأۄەأتضأڬتأهتصوۏأغًشأځشأمظتظأ+أۏؼىۏأثزهۄأ,أۄًأڲتأۗ‛‛أۏۄأشًتۏحأتوتوأتذوزأىەأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأظزمۄأثىأوًضۏٳأۄەأ؏أدضەأدوۄًشأىەأعؼۏلأمشتشأزۏتأۄەأ؏أوضهوأثىأتثشتۄۏوأڬۄحەأۄۏڽأ=أظزمۄأثىأوًضۏٳأىەأۄوۏڽأذزۏخأثۏتىأڬۏأتًشأًۄأظزًمأحہەأ؏أتضأشًتۏحأڬەأثمۏۄأشدتهأخمۄأۄۏڽأۗ

[تخریج]: حدیث : 18382 - اخرجه احمد في """"المسند"""" (240/6)"
18383,"أذعشحأذسۏلۄأشعۏأتههۄأؼىۄأىثۏأتڬشوأ﷽أڬتأۏۄألشوتىأىمهأڬشحەأۄۏڽأ=أأ““أووهًڬًڽأڬەأذًتهەأضەأوتهڬتىأڬەأهۏەأثشثتزۏأۄەأتًشأوتهڬتىأڬەأذًتهەأضەأووهًڬًڽأڬەأهةەأثشثتزۏأۄەأۗ‛‛أۏۄأشًتۏحأتوتوأثصتشأىەأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏضەأشتًۏأۄۏڽأ؏أدىأضەأوۏڽأًتملأىۄۏڽأۄًڽأۗ

[تخریج]: حدیث : 18383 - اخرجه البزار في المسند """" (3441)"
18384,"أذعشحأتىضأثىأوتهڬأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أأ““أووهًڬأڬەأذًتهەأضەأوتهڬأڬەأهةەأثشثتزۏأۄەأتًشأوتهڬأڬەأذًتهەأضەأووهًڬأڬەأهةەأثشثتزۏأۄەأ؏أؽشۏثأڬەأذًتهەأضەأتوۏشأڬەأهةەأثشثتزۏأۄەأتًشأتوۏشأڬەأذًتهەأضەأؽشۏثأڬەأهةەأثشثتزۏأۄەأ؏أڬوصًشأڬەأذًتهەأضەأغتمحًشأڬەأهةەأثشثتزۏأۄەأتًشأغتمحًشأڬەأذًتهەأضەأڬوصًشأڬەأهةەأثشثتزۏأۄەأۗ‛‛أأۏۄأشًتۏحأتوتوأثصتشأىەأتځىەأتضحتزأوذوزأثىأهۏخأڬەأذًتهەأضەأىمهأڬۏأۄەأتوتوأتثىأذثتىأىەأتضأشتًۏأڬتأحسڬشۄأڬحتثأتهخمتحأوۏڽأڬۏتأۄەأتًشأۏۄأڬۄتأۄەأ=أۏۄأؽهغۏأڬشأدتحتأۄەأتًشأزًضشًڽأڬەأثشرهتلأىمهأڬشحتأۄەأۗأ+أؼهتوۄأۄۏخوۏألشوتحەأۄۏڽأ=أ,أوۏڽأىەأ““أوۏصتىأتهتؼحزتهأ‛‛أوۏڽأتضأڬتأحسڬشۄأىۄۏڽأځتۏتأۄەأ؏أتضأشًتۏحأڬەأثمۏۄأشدتهأظذۏذأڬەأشدتهأۄۏڽأ؏أتهثحۄأتؼوطأىتوۏأشتًۏأىەأذعشحأتىضأثىأوتهڬأشعۏأتههۄأؼىۄأضەأضوتؼأىۄۏڽأڬۏتأۄەأ؏أۏۄأشًتۏحأتوتوأتثًۏؼهۏٳأىەأثہۏأىمهأڬۏأۄەأۗ

[تخریج]: حدیث : 18384 - اخرجه البزار في """"المسند"""" (3442) اخرجه ابو يعلى في """"المسند"""" (4009)"
18385,"أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أأ““أرثشزتشأ$أتضأستحأڬۏأمضوأ$أدضأڬەأزضحأمزشحأوۏڽأوۏشۏأدتىأۄەأ؏أمۏتوحأڬەأزىأۄشأډۏصأتځىتأومزوۄأځۏطأڬشەأڲۏأ؏أۏۄتڽأحڬأڬۄأًۄأزًأثڬشۏتڽأثہۏأدىۄًڽأىەأتۏڬأزًضشەأڬًأضۏىڲأوتشەأۄًڽأڲەأ+أًۄأثہۏأتضأثتشەأوۏڽأتځىتأومزوۄأځۏطأڬشۏڽأڲۏأ,أۗ‛‛أأۏۄأشًتۏحأتوتوأتذوزأىەأىمهأڬۏأۄەأتًشأتضأڬۏأضىزأذضىأۄەأۗ

[تخریج]: حديث : 18385 - اخرجه احمد في المسند """" (390/2)"
18386,"أذعشحأتثًضؼۏزأرزشۏأشعۏأتههۄأؼىۄأىثۏأتڬشوأ﷽أڬتأۏۄألشوتىأىمهأڬشحەأۄۏڽأ=أأ““أتضأستحأڬۏأمضوأ$أدضأڬەأزضحأمزشحأوۏڽأوۏشۏأدتىأۄەأ؏أمۏتوحأڬەأزىأ+أۄشأڬًةۏأتځىتأ,أومزوۄأځۏطأڬشەأڲتأ؏أۏۄتڽأحڬأڬۄأزًأثڬشۏًڽأىەأتۏڬأزًضشەأڬًأدًأضۏىڲأوتشەأۄًڽأڲەأ؏أتْضأثتشەأوۏڽأ+أًۄأثہۏأتځىتأومزوۄأځۏطأڬشۏڽأڲۏأ,أۗ‛‛أأۏۄأشًتۏحأتوتوأتثًۏؼهۏٳأىەأىمهأڬۏأۄەأتًشأتوتوأتذوزأىەأتضأڬۏأوتىىزأىمهأڬۏأۄەأتًشأتضأڬۏأضىزأذضىأۄەأۗ

[تخریج]: حديث : 18386 - اخرجه ابو يعلى في المسند """" (1400) اخرجه احمد في """"المسند"""" (29/3)"
18387,"أذعشحأؼمثۄأثىأؼتوشأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أأ““أمۏتوحأڬەأزىأتۏڬأزًضشەأڬەأځۄهەأومتثهألشۏمأ؏أزًأځڔًضۏأۄًڽأڲەأۗ‛‛أأۏۄأشًتۏحأتوتوأتذوزأىەأذضىأضىزأڬەأضتحہأىمهأڬۏأۄەأۗ

[تخریج]: حدیث : 18387 - اخرجه احمد في المسند """" (151/1)"
18388,"أذعشحأتثًتۏًثأتىظتشۏأشعۏأتههۄأؼىۄأىثۏأتڬشوأ﷽أڬتأۏۄألشوتىأىمهأڬشحەأۄۏڽأ=أأ““أمۏتوحأڬەأزىأومزوۄأځۏطأڬشىەأًتهەأځۄهەأتلشتزأ؏أإزوۏأتًشأتضأڬۏأثۏًۏأۄًڽأڲەأ؏أتههۄأڬۏأمضوأ$أؼًشحأڬۏأصثتىأڬهتوأىۄۏڽأڬشەأڲۏأثهڬۄأتضأڬەأۄتحہأتًشأتضأڬەأځتاڽأڬهتوأڬشۏڽأڲەأتًشأؼًشحأڬەأرهتلأڲًتۄۏأزۏڽأڲەأڬۄأًۄأطًۄشأڬۏأؽۏشأوًدًزڲۏأوۏڽأڬۏتأڬشحۏأحہۏأآأتًشأإزوۏأڬەأزًىًڽأۄتحہأتًشأتضأڬەأزًىًڽأځتاڽأڲًتۄۏأزۏڽأڲەأدضأڬتأًۄأتشحڬتثأڬشحتأحہتأ؏أځہشأإزوۏأڬًأتًشأتضأڬەأرزوحأڲتشًڽأڬًأثهتۏتأدتةەأڲتأ؏أتىأڬەأضتحہأثہۏأتضۏأغشذأۄًأڲتأ؏أځہشأثتصتشأًتهًڽأڬًأثهتۏتأدتةەأڲتأتًشأًۄتڽأدًأضڬەأتًشأمۏشتغأۄًحەأحہەأ+أتىۄۏڽأثہۏأثهتۏتأدتةەأڲتأ,أتضأ+أۏؼىۏأػتهوأ,أڬۏأىۏڬۏتڽأتْضأڬًأزەأزۏأدتةۏڽأڲۏأدًأوػهًوأۄًأڲتأتًشأوػهًوأڬۏأثشتةۏتڽأتضأػتهوأڬەأسوەأڋتهأزۏأدتةۏڽأڲۏأ؏أځہشأػتهوًڽأ+أۏتأوحڬثشۏىأ,أڬًأهًۄەأڬەأثىەأۄًةەأغًمًڽأوۏڽأهتۏتأدتةەأڲتأتًشأۏۄأڬۄتأدتةەأڲتأ=أتىۄۏڽأدۄىوأځشأًتشزأڬشًأ$أحًأتههۄأڬۏأمضوأ$أودہەأىۄۏڽأوؼهًوأڬۄأًۄأتضأوۏڽأزترهأۄًڽأڲەأۏتأًۏضتأۄًأڲتأ؏أدضأغشذأتههۄأحؼتهۏٳأىەأتشطتزألشوتۏتأۄەأ=أأ““أحوأوۏڽأضەأۄشأتۏڬأتضأ+أدۄىوأ,أځشأًتشزأۄًأڲتأ؏أۏۄأحوۄتشەأځشًشزڲتشأڬەأسوۄأذحوۏأًأغەأطزۄأثتحأۄەأ؏أځہشأۄوأځشۄۏصڲتشۏأترحۏتشأڬشىەأًتهًڽأڬًأىدتحأزۏزۏڽأڲەأتًشأػتهوًڽأڬًأتضأ+أدۄىوأوۏڽأ,أڲہټىًڽأڬەأثهأ+أدہڬتأۄًتأ,أډہًڔأزۏڽأڲەأۗ‛‛أأۏۄأشًتۏحأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأؼثزتههۄأثىأؼثزتهؼصۏصأهۏخۏأۄەأتًشأًۄأعؼۏلأۄەأ؏أضؼۏزأثىأوىظًشأىەأتضەأخمۄأمشتشأزۏتأۄەأًۄأڬۄحەأۄۏڽأ=أتوتوأوتهڬأتضأضەأشتعۏأحہەأ؏أتضأشًتۏحأڬەأثمۏۄأشدتهأظذۏذأڬەأشدتهأۄۏڽأۗ

[تخریج]: حدیث : 18388 - اخرجه الطبراني في """" المعجم الكبير """" (3969)"
18389,"أذعشحأًتخهۄأثىأتضمؼأشعۏأتههۄأؼىۄأىثۏأتڬشوأ﷽أڬتأۏۄألشوتىأىمهأڬشحەأۄۏڽأ=أأ““أمۏتوحأڬەأزىأتههۄأحؼتهۏٳأتۏڬأتۏضەأثىزەأڬًأصىزۄأڬشەأڲتأ؏أدضأڬتأڬًةۏأڲىتۄأىۄۏڽأۄًأڲتأتههۄأحؼتهۏٳألشوتةەأڲتأ=أزًأوۏڽأضەأڬًىأضتأوؼتوهۄأحوۄتشەأىصزۏڬأصۏتزۄأځضىزۏزۄأۄەأآأۏۄأڬۄأوۏڽأحوۄۏڽأحوۄتشەأؼوهأڬۏأدصتأزەأزًڽأآأۏتأدًأىؼوحۏڽأوۏڽأىەأحوۄۏڽأؼغتأڬۏأحہۏڽأ+أتْىأڬتأذضتثأهەأهًڽأآأ,أثىزۄأڬۄەأڲتأ=أتەأوۏشەأځشًشزڲتشأ$أحًأۏۄأثتحأدتىحتأۄەأڬۄأوۏڽأىەأحۏشۏأڬًةۏأىتلشوتىۏأىۄۏڽأڬۏأ؏أځشًشزڲتشألشوتةەأڲتأ=أوۏشۏأىؼوحًڽأوۏڽأضەأتۏڬأىؼوحأڬەأذضتثأڬەأذًتهەأضەأوۏشەأثىزەأڬًأځڬڔأهًأ+أۏتأتضأڬتأذضتثأهًأ,أحًأًۄأتۏڬأىؼوحأۄۏأتضأڬۏأضتشۏأىۏڬۏًڽأڬًأرحوأڬشأزەأڲۏأ؏أثىزۄأڬۄەأڲتأ=أتەأوۏشەأځشًشزڲتشأ$أحۏشۏأىؼوحأتًشأحۏشۏأشذوحأ+أڬتأوۏڽأوذحتدأتًشأغهثڲتشأۄًڽأ,أحًأځشًشزڲتشألشوتةەأڲتأ=أوۏشۏأىؼوحأتًشأوۏشۏأشذوحأ+أڬۏأثزًهحأوۏڽأحوۄۏڽأىدتحأوهەأڲۏأ,أځہشأتۏڬأثىزەأڬًأهتۏتأدتةەأڲتأدًأۏۄأضودہحتأۄًأڲتأڬۄأًۄأتډہتةۏأڬشىەأًتهتأۄەأ؏أتضأڬتأڬًةۏأڲىتۄأىۄۏڽأۄًأڲتأ؏أځشًشزڲتشأتضأضەأزشۏتلحأڬشەأڲتأ=أڬۏتأحوأوۏشەأزًضحًڽأڬەأضتحہأوذثحأشڬہحەأحہەأآأًۄأدًتثأزەأڲتأ=أوۏڽأهًڲًڽأڬەأذًتهەأضەأضهتوحۏأوۏڽأشۄتأ+أۏؼىۏأوۏڽأتْىأضەأهتحؼهمأشۄتأ,أځشًشزڲتشأزشۏتلحأڬشەأڲتأ=أڬۏتأحوأوۏشەأزطوىًڽأڬەأضتحہأزطوىۏأشڬہحەأحہەأآأًۄأثىزۄأدًتثأزەأڲتأ=أتەأوۏشەأځشًشزڲتشأ$أوۏشەأتًشأڬضۏأطرظأڬەأزشوۏتىأڬًةۏأ+أزطوىۏأىۄۏڽأحہۏأ؏أحًأځشًشزڲتشألشوتةەأڲتأ=أوۏشۏأشذوحأتۏضەأطرظأڬًأىظۏثأىۄۏڽأۄًأڲۏأدًأوۏشەأزًضحًڽأڬەأضتحہأوذثحأىۄأشڬہحتأۄًأتًشأوۏشەأزطوىًڽأڬەأضتحہأزطوىۏأىۄأشڬہحتأۄًأۗ‛‛أأۏۄأشًتۏحأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأثطشأثىأؼًىأۄەأتًشأتضأځشأشًتۏتحأتۏدتزأڬشىەأڬتأتهصتوأۄەأۗ

[تخریج]: حديث : 18389 - اخرجه الطبراني في """"المعجم الكبير """" (59/22)"
18390,"أذعشحأؼثزتههۄأثىأؼوشأشعۏأتههۄأؼىۄوتأىثۏأتڬشوأ﷽أڬتأۏۄألشوتىأىمهأڬشحەأۄۏڽأ=أأ““أ+أمۏتوحأڬەأزىأ,أوتهڬأتًشأووهًڬأ؏أطًۄشأتًشأثۏًۏأڬًأهتۏتأدتةەأڲتأ؏أوتهڬأتًشأووهًڬأضەأ؏أطًۄشأتًشأثۏًۏأضەأذضتثأهۏتأدتةەأڲتأۏۄتڽأحڬأڬۄأإزوۏأضەأۏۄأڬۄتأدتةەأڲتأ=أحوأىەألهتڽألهتڽأزىأهسحأڬۏأرتغشأوطشًثأځۏتأحہتأتًشأطًۄشأضەأۏۄأڬۄتأدتةەأڲتأ=أحوأىەأزۏڲشأهًڲًڽأڬەأۄوشتۄألهتڽأؼًشحأڬًأطتزۏأڬتأځۏؽتوأزۏتأحہتأحًأوۏڽأىەأحوۄتشۏأطتزۏأتضأؼًشحأضەأڬشًتأزۏأتًشأزًضشەأهًڲًڽأڬًأډہًڔأزۏتأۗ‛‛أأۏۄأشًتۏحأتوتوأثصتشأىەأضؼۏزأثىأوضهوۄأتوًۏأڬۏأهۏخأثىأتثًضهۏوأضەأىمهأڬشزۄأشًتۏحأڬەأغًشأځشأىمهأڬۏأۄەأتًشأۏۄأزًىًڽأعؼۏلأۄۏڽأ؏أًۏضەأتىأزًىًڽأڬۏأحًخۏمأڬۏأڲةۏأۄەأتضأشًتۏحأڬەأثمۏۄأشدتهأظذۏذأڬەأشدتهأۄۏڽأۗ

[تخریج]: حديث : 18390 - اخرجه البزار في """"المسند"""" (3443)"
18391,"أذعشحأؼثزتههۄأثىأصثۏشأشعۏأتههۄأؼىۄوتأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أأ““أدضأطرظأضەأذضتثأوۏڽأحلحۏطأڬۏأدتةەأڲۏأًۄأۄهتڬأۄًأدتةەأڲتأۗ‛‛أأۏۄأشًتۏحأتوتوأثصتشأىەأتوتوأغثشتىۏأىەأوؼدوأڬثۏشأتًشأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأتوتوأثصتشأڬەأشدتهأتًشأوؼدوأڬثۏشأڬەأشدتهأظذۏذأڬەأشدتهأۄۏڽأ؏أوؼدوأتًضغأڬەأشدتهأثہۏأتضۏأغشذأۄۏڽأ؏أظشلأؼوشًأثىأتثًؼتظوأىثۏهأڬتأوؼتوهۄأورحهلأۄەأتًشأًۄأخمۄأۄەأۗ

[تخریج]: حديث : 18391 - اخرجه البزار في المسند """" (3436)"
18392,"أضۏزۄأؼتةطۄأظزۏمۄأشعۏأتههۄأؼىۄتأىثۏأتڬشوأ﷽أڬتأۏۄألشوتىأىمهأڬشحۏأۄۏڽأ=أأ““أمۏتوحأڬەأزىأڬضۏأضەأذضتثأهەأڬشأتضأڬۏأوؽلشحأىۄۏڽأۄًأڲۏأ؏أوضهوتىأتځىۏأمثشأوۏڽأۄۏأتځىتأؼوهأزۏڬہأهەأڲتأ؏أتههۄأحؼتهۏٳأىەأتشطتزألشوتۏتأۄەأ=أ““أتضأزىأتىضتىأۏتأدىأضەأتضأڬەأڲىتۄأڬەأثتشەأوۏڽأضًتهأىۄۏڽأڬۏتأدتةەأڲتأۗ‛‛أ““أودشوأهًڲأتځىۏأىطتىۏأڬەأذًتهەأضەأځۄډتىەأدتةۏڽأڲەأۗ‛‛أۏۄأشًتۏحأتوتوأتذوزأىەأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأتثىأهۄۏؼۄأۄەأتًشأًۄأعؼۏلأۄەأ؏أًۏضەأتضأڬۏأحًخۏمأڬۏأڲةۏأۄەأ؏أتضأشًتۏحأڬەأثمۏۄأشدتهأظذۏذأڬەأشدتهأۄۏڽأۗ

[تخریج]: حدیث : 18392 - اخرجه احمد في المسند """" (103/6)"
18393,"أذعشحأدتثشأثىأؼثزتههۄأشعۏأتههۄأؼىۄوتأىثۏأتڬشوأ﷽أڬتأۏۄألشوتىأىمهأڬشحەأۄۏڽأ=أأ““أمۏتوحأڬەأزىأتههۄأحؼتهۏٳأڬۏأثتشڲتۄأوۏڽأڬہڔەأۄًىەأڬەأزًشتىأتثىأإزوأڬًأتحىۏأؼتشأتًشأطشوىزڲۏأوذضًضأۄًأڲۏأڬۄأثىزۄأۏۄأإشصًأڬشەأڲتأ=أڬۄأتْضەأدۄىوأوۏڽأهەأدتىەأڬتأذڬوأزەأزۏتأدتةەأۗ‛‛أۏۄأشًتۏحأتوتوأتثًۏؼهۏٳأىەأىمهأڬۏأۄەأتضأشًتۏحأڬۏأضىزأوۏڽأتۏڬأشتًۏألعهأثىأؼۏضۏٳأشمتطۏأۄەأتًشأتضأڬەأعؼۏلأۄًىەأځشأتحلتمأۄەأۗأأ+أؼهتوۄأۄۏخوۏألشوتحەأۄۏڽأ=أ,أوۏڽأۏۄأڬۄحتأۄًڽأ=أمۏتوحأڬەأزىأڬۏأطزحأڬەأثتشەأوۏڽأذعشحأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄأڬۏأىمهأڬشزۄأشًتۏحأوۏڽأۏۄأثتحأڲصشأډڬۏأۄەأڬۄأتۏضتأڬتلشأڬەأذمأوۏڽأۄًأڲتأۗ

[تخریج]: حدیث : 18393 - اخرجه ابو يعلى في المسند """" (1776)"
18394,"أذعشحأتىضأشعۏأتههۄأؼىۄأوشلًؼأذزۏخأڬەأغًشأځشأۏۄأثتحأىمهأڬشحەأۄۏڽأ+أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأۄەأ=أ,أأ““أتۏڬألشطحەأڬًأوۏصتىأڬەأځتضأومششأڬۏتأڲۏتأۄەأ؏أتثىأإزوأڬًأهتأڬشأوۏصتىأڬەأزًىًڽأځهڔًڽأڬەأزشوۏتىأڬہڔتأڬشأزۏتأدتةەأڲتأ؏أتڲشأتضأڬتأوۏصتىأثہتشۏأۄًأڲتأحًألشطحۄأتۏضۏأإًتصأوۏڽأځڬتشأڬشأڬۄەأڲتأدًأضتشۏأورهًمأضىأضڬەأڲۏأ؏ألهتڽأطرظأتۏضتأضؼتزحوىزأۄًتأڬۄأًۄأتضأڬەأثؼزأڬثہۏأثزىظۏثأىۄۏڽأۄًأڲتأ؏أتًشأتڲشأتضأڬتأوۏصتىأۄهڬتأۄًتأحًألشطحۄأتحىۏأثهىزأإًتصأوۏڽأځڬتشأڬشأڬۄەأڲتأ؏أدضأڬًأضتشۏأورهًمأضىأضڬەأڲۏأ=ألهتڽأطرظأتۏضتأثزىظۏثأۄًتأڬۄأتثأًۄأتضأڬەأثؼزأڬثہۏأثہۏأضؼتزحأوىزأىۄۏڽأۄًأضڬەأڲتأۗ‛‛أۏۄأشًتۏحأتوتوأثصتشأىەأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأظتهذأوشۏأۄەأتًشأتضأڬەأعؼۏلأۄًىەأځشأتحلتمأۄەأۗ

[تخریج]: حدیث : 18394 - اخرجه البزار في المسند """" (3445)"
18395,"أذعشحأتىضأثىأوتهڬأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أأ““أمۏتوحأڬەأزىأوۄشأهڲەأۄًةەأظذۏلًڽأڬًأهتۏتأدتةەأڲتأتًشأتىۄۏڽأتههۄأحؼتهۏٳأڬەأضتوىەأشڬہأزۏتأدتةەأڲتأحًأتههۄأحؼتهۏٳألشوتةەأڲتأ=أتضأڬًأتۏڬأغشلأڬشأزًأتًشأتضأڬًأمثًهأڬشأهًأ؏ألشطحەأؼشعأڬشۏڽأڲەأ=أحۏشۏأؼصحأتًشأحۏشەأدهتهأڬۏأمضوأۄەأ+أدضأظذۏلەأڬًأحًأىەأتۏڬأغشلأڬشىەأڬتأذڬوأزۏتأۄەأ,أتضأوۏڽأۄوۏڽأظشلأثہهتةۏأزڬہتةۏأزەأشۄۏأۄەأحًأتههۄأحؼتهۏٳألشوتةەأڲتأ=أۏۄأ+أۏؼىۏأتضأظذۏلەأوۏڽأزشدأؼوهأ,أوۏشۏأستحأڬەأؼهتًۄأڬضۏأتًشأڬەأهةەأحہتأتًشأإدأوۏڽأظشلأتضأڬًأمثًهأڬشًڽأڲتأ؏أدضأڬەأسشۏؼەأوۏشۏأستحأ+أڬۏأشعتوىزۏأ,أوشتزأهۏأڲةۏأحہۏأۗ‛‛

[تخریج]: حديث : 18395 - اخرجه البزار في """"المسند"""" (3435)"
18396,"أتۏڬأشًتۏحأوۏڽأۏۄأتهلتػأۄۏڽأ=أأ““ألشطحەأڬۄۏڽأڲەأ=أحۏشۏأؼصحأڬۏأمضوأۄەأۄوأىەأظشلأًۄأډۏصأىًټأڬۏأدًأتضأىەأؼوهأڬۏتأحہتأ؏أحًأځشًشزڲتشألشوتةەأڲتأ=أحوأىەأضډأڬۄتأۄەأ؏أتضأڬتأؼوهأوۏشەأؼهتًۄأڬضۏأتًشأڬەأهةەأحہتأۗ‛‛أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأزًأتضىتزأڬەأضتحہأىمهأڬۏأۄەأتىأزًىًڽأوۏڽأضەأتۏڬأشدتهأظذۏذأڬەأشدتهأۄۏڽأ؏أۏۄأشًتۏحأتوتوأثصتشأىەأثہۏأىمهأڬۏأۄەأۗ"
18397,"أذعشحأتىضأثىأوتهڬأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أأ““أدثأإرشۏأصوتىۄأإةەأڲتأحًأوۏشۏأتوحأحۏىأذظًڽأوۏڽأحمضۏوأۄًأدتةەأڲۏأ؏أتۏڬأڲشًۄأرتهظأغًشأځشأتههۄأحؼتهۏٳأڬۏأؼثتزحأڬشەأڲتأ؏أتۏڬأڲشًۄأشۏتڬتشۏأڬەأغًشأځشأتههۄأحؼتهۏٳأڬۏأؼثتزحأڬشەأڲتأ؏أتۏڬأڲشًۄأتههۄأحؼتهۏٳأڬۏأؼثتزحأتضأهۏەأڬشەأڲتأحتڬۄأهًڲًڽأضەأوتهۏألتةزۄأذتظهأڬشەأ؏أمۏتوحأڬەأزىأدثأتههۄأحؼتهۏٳأتىۄۏڽأدوؼأڬشەأڲتأحًأتههۄأحؼتهۏٳأتضأطرظأضەأۏۄألشوتةەأڲتأدًأتضأؼثتزحأڬەأسشۏؼەأهًڲًڽأضەأوتهۏألتةزۄأذتظهأڬشحتأحہتأ+أتههۄأحؼتهۏٳأتضأضەأزشۏتلحأڬشەأڲتأ=أ,أوۏشۏأؼصحأتًشأوۏشەأدهتهأڬۏأمضوأ$أحوأىەأڬضأومظزأڬەأحذحأوۏشۏأؼثتزحأڬۏأآأًۄأثىزۄأدًتثأزەأڲتأ=أحۏشۏأؼصحأتًشأحۏشەأدهتهأڬۏأمضوأ$أوۏڽأتضأڬەأسشۏؼەأهًڲًڽأضەأوتهۏألتةزۄأذتظهأڬشىتأډتۄحتأحہتأ؏أحًأځشًشزڲتشألشوتةەأڲتأ=أحوأىەأدًأڬډہأثہۏأتڬټہتأڬۏتأ؏أًۄأحوۄۏڽأۏۄألتةزۄأىۄۏڽأزەأڲتأڬۄأتثأحوأتضأڬۏأځىتۄأهەأضڬًأ+أځہشألشطحًڽأڬًأذڬوأۄًأڲتأ,أتضأڬًأدۄىوأڬۏأغشلأهەأدتاأ$ۗأأځہشأتههۄأحؼتهۏٳأشۏتڬتشۏأڬەأغًشأځشأؼثتزحأڬشىەأًتهەأضەألشوتةەأڲتأ=أوۏشۏأؼصحأتًشأوۏشەأدهتهأڬۏأمضوأ$أحوأىەأوۏشۏأؼثتزحأڬەأسشۏؼەأڬۏتأوشتزأهۏتأآأ+أۏؼىۏأوۏشۏأؼثتزحأڬەأذًتهەأضەأحوۄتشتأومظزأڬۏتأحہتأآأ,أأحًأًۄأطرظأؼشعأڬشەأڲتأ=أحۏشۏأؼصحأتًشأحۏشەأدهتهأڬۏأمضوأ؏أهًڲًڽأڬەأهةەأزڬہتًتأ+أوۏشتأومظزأحہتأ,أځشًشزڲتشألشوتةەأڲتأ=أتضأوۏڽأضەأڬًةۏأثہۏأؼوهأودہأحڬأىۄۏڽأځۄىډتأ+أځہشألشطحًڽأڬًأذڬوأۄًأڲتأ,أتضأڬًأدۄىوأڬۏأغشلأهەأدتاأ$ۗأأځہشأتههۄأحؼتهۏٳأتضأطرظأضەألشوتةەأڲتأدًأرتهظأغًشأځشأتضأڬۏأؼثتزحأڬشحتأحہتأ؏أوۏشۏأؼصحأتًشأوۏشەأدهتهأڬۏأمضوأ$أحوأوۏشۏأؼثتزحأڬەأسشۏؼەأڬۏتأوشتزأهۏحەأحہەأآأًۄأؼشعأڬشەأڲتأ=أحۏشۏأؼصحأتًشأحۏشەأدهتهأڬۏأمضوأ$أحًأتضأثتشەأوۏڽأودہأضەأثۄحشأدتىحتأۄەأ؏أوۏڽأىەأتضأڬەأسشۏؼەأحدہەأۏتزأڬشىتأتًشأحۏشۏأشعتوىزۏأوشتزأهۏتأحہتأ؏أتههۄأحؼتهۏٳألشوتةەأڲتأ=أوۏشەأثىزەأىەأضډأڬۄتأۄەأ+أځہشألشطحًڽأڬًأذڬوأۄًأڲتأ=أ,أتضەأدىحأڬۏأغشلأهەأدتاأ$ۗأۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأؼثۏزأثىأتضذتمأؼغتشأۄەأدضأڬًأدوۄًشأىەأعؼۏلأمشتشأزۏتأۄەأتًشأتثًذتحوأشتصۏأتضأضەأشتعۏأحہەأ؏أتثىأذثتىأىەأتضەأخمۄأڬۄتأۄەأتضأشًتۏحأڬەأثمۏۄأشدتهأخمۄأۄۏڽأۗ"
18398,"أذعشحأتثًضؼۏزأرزشۏأشعۏأتههۄأؼىۄأىثۏأتڬشوأ﷽أڬتأۏۄألشوتىأىمهأڬشحەأۄۏڽأ=أأ““أدثأمۏتوحأڬتأزىأۄًأڲتأ؏أحًأڬتلشأڬًأتضأڬەأؼوهأڬۏأطىترحأڬشًتةۏأدتةەأڲۏأ؏أًۄأتىڬتشأڬشەأڲتأتًشأدہڲڔتأڬشەأڲتأحًأتضأضەأڬۄتأدتةەأڲتأ=أۏۄأحوۄتشەأځڔًضۏأۄۏڽأ؏أدًأحوۄتشەأرهتلأڲًتۄۏأزەأشۄەأۄۏڽأ؏أًۄأڬۄەأڲتأ=أۏۄأدہًټأثًهأشۄەأۄۏڽأ؏أځشًشزڲتشألشوتةەأڲتأ=أ+أۏتألشطحۄأڬۄەأڲتأ=أ,أۏۄأحوۄتشەأتۄهأرتىۄأتًشأحوۄتشەأرتىزتىأڬەأهًڲأ+أۏۄأحوۄتشەأرهتلأڲًتۄۏأزەأشۄەأۄۏڽأ,أًۄأڬۄەأڲتأ=أۏۄأثہۏأدہًټأثًهأشۄەأۄۏڽأ؏أًۄأ+أۏؼىۏأځشًشزڲتشأۏتألشطحۄأ,ألشوتةەأڲتأ=أحوأهًڲأذهلأتټہتاأ$أًۄأهًڲأذهلأتټہتأهۏڽأڲەأ؏أځہشأتههۄأحؼتهۏٳأتىۄۏڽأرتوًطأڬشًتةەأڲتأتًشأځہشأتْىأ+أڬتلشأ,أهًڲًڽأڬۏأ+أتځىۏأ,أصثتىۏڽأ+أتىأڬەأرهتلأ,أڲًتۄۏأزۏڽأڲۏأتًشأځہشأتههۄأحؼتهۏٳأتىۄۏڽأدۄىوأوۏڽأزترهأڬشأزەأڲتأۗ‛‛أۏۄأشًتۏحأتوتوأتثًۏؼهۏٳأىەأذضىأضىزأڬەأضتحہأىمهأڬۏأۄەأدضأوۏڽأعؼلأځتۏتأدتحتأۄەأۗ

[تخریج]: حديث : 18398 - اخرجه أبو يعلى في المسند """" (1392)"
18399,"أذعشحأؼمثۄأثىأؼتوشأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أتىۄًڽأىەأىثۏأتڬشوأ﷽أڬًأۏۄأتشطتزألشوتحەأۄًةەأضىتأۄەأ=أ““أدضأزىأوىۄأځشأوۄشأهڲتأزۏأدتةەأڲۏأتضأزىأتىضتىأڬۏأدًأۄڋۏأضثأضەأځۄهەأڬهتوأڬشەأڲۏأًۄأثتةۏڽأټتىڲأڬتأصتىًأۄەأۗ‛‛أۏۄأشًتۏحأتوتوأتذوزأتًشأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأتًشأتىأزًىًڽأڬۏأضىزأؼوزۄأۄەأۗ

[تخریج]: حدیث : 18399 - اخرجه الطبراني في """"المعجم الكبير """" (333/17) اخرجه احمد في """"المسند"""" (151/4)"
18400,"أذعشحأوؼتًۏۄأثىأذۏزيأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أوۏڽأىثۏأتڬشوأ﷽أڬۏأرزوحأوۏڽأذتعشأۄًتأ؏أإځأ﷽أىەأتشطتزألشوتۏتأ=أأ““أڬۏتأًدۄأۄەأڬۄأوۏڽأحوۄۏڽأځۄهًأضەأځڬڔأڬشأدۄىوأوۏڽأدتىەأضەأشًڬحتأۄًڽأ؏أرثشزتشأ$أوۏشەأځشًشزڲتشأىەأودہەأثهتىتأۄەأتًشأودہأضەأزشۏتلحأڬشىتأۄەأ=أڬۏتأحوأىەأوۏشەأثىزًڽأحڬأحثهۏؽأڬشأزۏأحہۏأآأتًشأوۏڽأۏۄأڬۄًڽأڲتأ=أتەأوۏشەأځشًشزڲتشأ$أوۏڽأىەأتىأڬًأحثهۏؽأڬشأزۏأحہۏأ+أځہشأىثۏأتڬشوأ﷽أىەأذتعشۏىأضەألشوتۏتأ=أ,أحوأوۏڽأضەأوًدًزأتلشتزأ؏أؽۏشأوًدًزأهًڲًڽأحڬأحثهۏؽأڬشأزۏڽأ؏أځہشأحوۄۏڽأ+أمۏتوحأڬەأزىأ,أثهتۏتأدتةەأڲتأتًشأحوۄتشەأوىۄأثىزأڬشأزۏەأدتةۏڽأڲەأتًشأحوأوۏڽأضەأڬضۏأتۏڬأڬۏأغشلأضەأدًأډۏصأځۄهەأثۏتىأڬشەأڲۏأًۄأتضأڬتأصتىًأتًشأتضأڬۏأۄحہۏهۏأۄًأڲۏأۗ‛‛أشتًۏأڬۄحەأۄۏڽأ=أوۏڽأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ$أۏۄأۄوتشتأزۏىأۄەأ؏أىثۏأتڬشوأ﷽أىەألشوتۏتأ=أحوۄتشتأزۏىأۄەأ؏أحوأدۄتڽأثہۏأتډہتةۏأڬشًأڲەأًۄأحوۄتشەأهۏەأڬلتۏحأڬشەأڲۏأ+أۏتأۏۄأزۏىأحوۄتشەأهۏەأڬلتۏحأڬشەأڲتأ,أۗ‛‛أۏۄأشًتۏحأتوتوأتذوزأىەأتۏڬأغًۏهأذزۏخأوۏڽأىمهأڬۏأۄەأتًشأتضأڬەأشدتهأخمۄأۄۏڽأۗ

[تخریج]: حديث : 18400 - اخرجه الطبراني في """"المعجم الاوسط (1679) اخرجه الطبراني في المعجم الكبير """" (407/19) اخرجه احمد فی المسند (446/4)"
18401,"أ+أؼهتوۄأۄۏخوۏألشوتحەأۄۏڽأ=أ,أوۏڽأۏۄأڬۄحتأۄًڽأ=أتضأضەأځۄهەأذعشحأؼثزتههۄأثىأتىۏضأشعۏأتههۄأؼىۄأڬۏأىمهأڬشزۄأذزۏخأڲصشأډڬۏأۄەأڬۄأتىۄًڽأىەأىثۏأتڬشوأ﷽أڬًأۏۄأتشطتزألشوتحەأۄًةەأضىتأۄەأ=أ““أمۏتوحأڬەأزىأتههۄأحؼتهۏٳأثىزًڽأڬًأ+أشتًۏأڬًأطڬأۄەأ؏أۏتأطتۏزأۏۄأتهلتػأۄۏڽأ=أ,أهًڲًڽأڬًأثشۄىۄأدضوأذتهحأوۏڽأ؏أرحىەأڬەأثؽۏشأ““أثۄوأ‛‛أذتهحأوۏڽأصىزۄأڬشەأڲتأ؏أۄوأىەأزشۏتلحأڬۏتأ=†أثۄوأ‛‛أذتهحأضەأوشتزأڬۏتأۄەأآأىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أۏۄأڬۄأتىأڬەأځتضأڬًةۏأډۏصأىۄۏڽأۄًأڲۏأ؏أځہشأتۏڬأوىتزۏأ+أۏؼىۏأځشًشزڲتشأ,أثهىزأإًتصأوۏڽأتىۄۏڽأورتغثأڬشأڬەأڬۄەأڲتأ؏أدضأإًتصأڬًأزًشأڬتألشزأثہۏأتضۏأغشذأضىأضڬەأڲتأدضأغشذأىصزۏڬأڬتألشزأضىأضڬەأڲتأ+أًۄألشوتةەأڲتأ,أوۏڽأ““أزۏتىأ‛‛أۄًڽأ+أۏؼىۏألۏظهۄأڬشىەأًتهتأۏتأثزهۄأزۏىەأًتهتأۄًڽأ,أوۏڽأثتزطتۄأۄًڽأ؏أتۄهأدۄىوأوۏڽأضەأڬضۏأڬەأهۏەأۏۄأوىتضثأىۄۏڽأۄەأڬۄأًۄأدۄىوأوۏڽأزترهأۄًأدتةەأ؏أدثڬۄأتضأىەأتۄهأدىحأوۏڽأضەأڬضۏأتۏڬأضەأڬًةۏأذمأهۏىتأۄًأ؏أدثأحڬأوۏڽأتضەأثزهۄأىۄۏڽأزهًتأزۏحتأ؏أتۄهأدىحأوۏڽأضەأڬضۏأڬەأهةەأۏۄأوىتضثأىۄۏڽأۄەأڬۄأًۄأدىحأوۏڽأزترهأۄًأدتةەأدثڬۄأتۄهأدۄىوأوۏڽأضەأڬضۏأڬتأذمأتضأڬەأځتضأۄًأ؏أدثأحڬأوۏڽأتضەأثزهۄأىۄۏڽأزهًتأهۏحتأ؏أۏۄتڽأحڬأڬۄأغوتىډۄأوتشىەأ+أڬتأثزهۄأثہۏأوۏڽأزهًتاڽأڲتأ,أۗ‛‛أأشتًۏأڬۄحەأۄۏڽأ=أۄوأىەأؼشعأڬۏأ=أدثأۄوأثشۄىۄأدضوأۄًڽأڲەأ؏أرحىەأڬەأثؽۏشأۄًڽأڲەأتًشأۄوتشەأځتضأڬًةۏأډۏصأثہۏأىۄۏڽأۄًأڲۏأ+أحًأثزهۄأڬۏضەأزۏتأدتةەأڲتأآأ,أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أىۏڬۏًڽأتًشأثشتةۏًڽأ+أڬەأسشۏؼەأثزهۄأزۏتأدتةەأڲتأ,أۗ‛‛أأۏۄأشًتۏحأتوتوأتذوزأىەأىمهأڬۏأۄەأتًشأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأذضىأضىزأڬەأضتحہأىمهأڬۏأۄەأۗ"
18402,"أضۏزۄأؼتةطۄأظزۏمۄأشعۏأتههۄأؼىۄتأتًشأتۏڬأظذتثۏأ؏أىثۏأتڬشوأ﷽أڬەأذًتهەأضەأۏۄأثتحأىمهأڬشحەأۄۏڽأ=أأ““أىثۏأتڬشوأ﷽أڬەأتظذتثأضەأحؼهمأشڬہىەأًتهتأتۏڬأطرظأىثۏأتڬشوأ﷽أڬەأضتوىەأثۏټہتأ؏أتضأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ$أوۏشەأڬډہأؽهتوأۄۏڽأ؏أدًأوۏشەأضتحہأدہًټأثًهحەأۄۏڽأ؏أًۄأوۏشەأضتحہأرۏتىحأڬشحەأۄۏڽأ؏أًۄأوۏشۏأىتلشوتىۏأڬشحەأۄۏڽأ؏أوۏڽأتْىۄۏڽأوتشحتأۄًڽأتًشأتىۄۏڽأثشتأڬۄحتأۄًڽأ؏أۏتأشضًهأتههۄأ$أحًأتْىأڬەأضتحہأوۏشتأۏۄأشًۏۄأڬۏضتأطوتشأۄًأڲتأآأىثۏأتڬشوأ﷽أىەأتضأضەألشوتۏتأ=أًۄأهًڲأحوۄتشەأضتحہأدًأرۏتىحأڬشحەأۄۏڽأ؏أحوۄتشۏأدًأىتلشوتىۏأڬشحەأۄۏڽأ؏أحوۄتشۏأدًأحڬسۏثأڬشحەأۄۏڽأ+أتىأڬتأ,أۏۄأؼوهأتًشأحوۄتشتأتىۄۏڽأضصتأزۏىتأ+أتىأزًىًڽأڬتأدتةصۄأهۏتأدتةەأڲتأ,أتًشأتڲشأحوۄتشۏأتْىۄۏڽأزۏأۄًةۏأضصتأتْىأڬەأدشوأضەأڬوأۄًةۏأحًأۏۄأډۏصأحوۄتشەأهةەأتعتلۏأۄًأڲۏأتًشأتڲشأحوۄتشۏأتْىۄۏڽأزۏأۄًةۏأضصتأتْىأڬەأدشوأڬەأوغتثمأۄًأڲۏأحًأځہشأوؼتوهۄأثشتثشۏأڬۏأثىۏتزأځشأۄًأڲتأ؏أىۄأحوۄتشەأذمأوۏڽأڬًةۏأډۏصأۄًأڲۏأىۄأحوۄتشەأسوۄأڬًةۏأډۏصأهتصوأۄًأڲۏأ؏أتًشأتڲشأحوۄتشتأتىۄۏڽأضصتأزۏىتأ؏أتىأڬەأدشوأضەأصۏتزۄأۄًأڲتأحًأحوۄتشۏأغشلأضەأدًأډۏصأتعتلۏأۄًأڲۏأتضأڬەأذًتهەأضەأحوضەأثزهۄأزهًتۏتأدتةەأڲتأۗ‛‛أشتًۏأڬۄحەأۄۏڽأ=أحًأًۄأطرظأىثۏأتڬشوأ﷽أڬەأضتوىەأثۏټہأڬشأشًىەأهڲتأ؏أىثۏأتڬشوأ﷽أىەألشوتۏتأ=أحوۄۏڽأڬۏتأۄًتأۄەأآأڬۏتأحوأىەأتههۄأڬۏأڬحتثأوۏڽأۏۄأىۄۏڽأځڔہتأۄەأ=أ““أتًشأۄوأمۏتوحأڬەأزىأؼزهأڬتأحشتصًأشڬہۏڽأڲەأحًأڬضۏأځشأڬًةۏأػهوأىۄۏڽأڬۏتأدتةەأڲتأ؏أتڲشأڬًةۏأډۏصأشتةۏأڬەأزتىەأڬەأًصىأدحىۏأثہۏأۄًأڲۏأ؏أحًأۄوأتضأڬًأهەأإةۏڽأڲەأتًشأذضتثأهۏىەأڬەأهۏەأۄوأڬتلۏأۄۏڽأۗ‛‛أأتْضأطرظأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ$أودہەأڬًةۏأتۏضۏأظًشحأىۄۏڽأوهحۏأدًأوۏشەأذمأوۏڽأتْىأضەأؼهۏذزڲۏأترحۏتشأڬشىەأضەأصۏتزۄأثۄحشأۄًأ؏أوۏڽأإځأڬًأڲًتۄأثىتأڬشأۏۄأڬۄحتأۄًڽأڬۄأًۄأضثأإصتزأۄۏڽأۗ‛‛أ+أؼهتوۄأۄۏخوۏألشوتحەأۄۏڽأ=أ,أوۏڽأۏۄأڬۄحتأۄًڽأ=أضۏزۄأؼتةطۄأشعۏأتههۄأؼىۄتأڬۏأىمهأڬشزۄأذزۏخأڬًأتوتوأحشوسۏأىەأىمهأڬۏتأۄەأۗأأۏۄأشًتۏحأتوتوأتذوزأىەأىمهأڬۏأۄەأتًشأتضأڬۏأضىزأوۏڽأظذتثۏأڬتأىتوأثۏتىأىۄۏڽأڬۏتأڲۏتأتضأضىزأوۏڽأتۏڬأتًشأتۏضتأشتًۏأۄەأ؏أدضأڬتأىتوأثۏتىأىۄۏڽأڬۏتأڲۏتأ؏أتىأزًىًڽأڬەأثمۏۄأشدتهأظذۏذأڬەأشدتهأۄۏڽأۗ

[تخریج]: حدیث : 18402 - اخرجه احمد في """"المسند"""" (280/6)"
18403,"أذعشحأتثًسشأؽلتشۏأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أحطشۏلألشوتأحہەأ؏أزًأثڬشۏتڽأډشأشۄۏأحہۏڽأ؏أتْىأزًىًڽأوۏڽأضەأتۏڬأىەأزًضشۏأڬًأضۏىڲأوتشأڬشأتضەأځشەأڬشأزۏتأحًأىثۏأتڬشوأ﷽أۄىضأځڔەأ؏أؼشعأڬۏأڲةۏأ=أۏتأشضًهأتههۄأ$أإځأڬۏًڽأۄىضحەأۄۏڽأآأىثۏأتڬشوأ﷽أىەألشوتۏتأ=أودہەأتضأځشأذۏشتىۏأۄًةۏأ؏أتضأستحأڬۏأمضوأ$أدضأڬەأزضحأمزشحأوۏڽأوۏشۏأدتىأۄەأ؏أمۏتوحأڬەأزىأتْضەأثزهۄأزهًتۏتأدتةەأڲتأۗ

[تخریج]: حديث : 18403 - اخرجه البزار في ""المسند"" (3450) اخرجه احمد في ""المسند"" (173/5)"
18404,"أتۏڬأشًتۏحأوۏڽأۏۄأثتحأوسڬًشأۄەأ=أأ““أىثۏأتڬشوأ﷽أىەأزًأثڬشۏًڽأڬًأزۏڬہتأڬۄأًۄأتۏڬأزًضشەأڬًأضۏىڲأوتشأشۄۏأحہۏڽأ؏أإځأىەألشوتۏتأ=أتەأتثًسشأ$أڬۏتأحوأتضأثتشەأوۏڽأدتىحەأۄًأآأۏۄأدًأتۏڬأزًضشەأڬًأضۏىڲأوتشأشۄۏأۄۏڽأ؏أذعشحأتثًسشأشعۏأتههۄأؼىۄأىەأؼشعأڬۏأ=أدۏأىۄۏڽأ$أىثۏأتڬشوأ﷽أىەألشوتۏتأ=أهۏڬىأتههۄأحؼتهۏٳأۏۄأثتحأدتىحتأۄەأتًشأًۄأؼىمشۏثأتىأزًىًڽأڬەأزشوۏتىألۏظهۄأزەأڲتأۗ‛‛أۏۄأحوتوأشًتۏتحأتوتوأتذوزأىەأىمهأڬۏأۄۏڽأ؏أتوتوأثصتشأىەأځۄهۏأشًتۏحأىمهأڬۏأۄەأتوتوأغثشتىۏأىەأتضۏأغشذأڬۏأشًتۏحأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأ؏أتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأهۏخأثىأتثۏأضهۏوأۄەأتًشأًۄأوزهضأۄەأ؏أتوتوأتذوزأڬەأثمۏۄأشدتهأظذۏذأڬەأشدتهأۄۏڽأ؏أظشلأتىأڬەأتضحتزأتثىأؼتةطۄأڬتأوؼتوهۄأورحهلأۄەأتًشأًۄأخمۄأۄەأۗأأزًضشۏأشًتۏحأڬەأشدتهأظذۏذأڬەأشدتهأۄۏڽأتًشأتضأڬۏأضىزأوۏڽأتۏضتأشتًۏأۄەأ؏أدضأڬتأىتوأثۏتىأىۄۏڽأڬۏتأڲۏتأۄەأۗ

[تخریج]: حدیث : 18404 - اخرجه احمد في """"المسند"""" (162/5)"
18405,"أذعشحأؼخوتىأشعۏأتههۄأؼىۄأىثۏأتڬشوأ﷽أڬتأۏۄألشوتىأىمهأڬشحەأۄۏڽأ=أ““أمۏتوحأڬەأزىأضۏىڲأڬەأثؽۏشأًتهۏأثڬشۏأڬًأ؏أضۏىڲأًتهۏأثڬشۏأضەأثزهۄأزهًتۏتأدتةەأڲتأۗ‛‛أأۏۄأشًتۏحأتوتوأتثًۏؼهۏٳأىەأڬثۏشأوۏڽأىمهأڬۏأۄەأتًشأتوتوأثصتشأىەأىمهأڬۏأۄەأتًشأؼثزتههۄأثىأتذوزأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأذدتدأثىأىظۏشأۄەأدضأڬەأعؼۏلأۄًىەأڬەأثتًدًزأتضأڬۏأحًخۏمأڬۏأڲةۏأۄەأ؏أۄصتشأڬەأثمۏۄأشدتهأظذۏذأڬەأشدتهأۄۏڽأ؏أظشلأؼًتوأثىأوصتذوأڬتأوؼتوهۄأورحهلأۄەأتًشأًۄأخمۄأۄەأۗ

[تخریج]: حديث : 18405 - اخرجه البزار في المسند """" (3449)"
18406,"أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأىثۏأتڬشوأ﷽أڬتأۏۄألشوتىأىمهأڬشحەأۄۏڽأ=أأ““أورهًمأڬًأتۏڬأزًضشەأضەأثزهۄأزهًتۏتأدتةەأڲتأ؏أۏۄتڽأحڬأڬۄأضۏىڲأڬەأثؽۏشأًتهۏأثڬشۏأڬًأ؏أضۏىڲأًتهۏأثڬشۏأضەأ؏أتًشأتۏڬأډۏًىټۏأڬًأزًضشۏأډۏًىټۏأضەأثزهۄأزهًتۏتأدتةەأڲتأۗ‛‛أأۏۄأشًتۏحأتوتوأتذوزأىەأىمهأڬۏأۄەأتًشأتضأڬەأشدتهأظذۏذأڬەأشدتهأۄۏڽأۗ

[تخریج]: حدیث : 18406 - اخرجه احمد في """"المسند"""" (363/2)"
18407,"أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أذعشحأظتزمأًأوظزًمأ؏أتثًتهمتضوأ﷽أىەأودہەأۏۄأثتحأثۏتىأڬۏأۄەأ=““أثەأطڬأځۄهەأزًألشۏمأمۏتوحأڬەأزىأ؏أدىأڬەأزشوۏتىألۏظهۄأڬۏتأدتةەأڲتأ؏أًۄأزًأثڬشۏتڽأۄًڽأڲۏأ؏أتۏڬأضۏىڲأًتهۏأۄًأڲۏأتًشأتۏڬأضۏىڲأڬەأثؽۏشأۄًأڲۏأۗ‛‛أأۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأ؏أتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأدتثشأثىأۏصۏزأدؼلۏأۄەأتًشأًۄأعؼۏلأۄەأۗ"
18408,"أذعشحأؼثزتههۄأثىأتثًتًلۏٳأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أأ““أمۏتوحأڬەأزىأتههۄأحؼتهۏٳأڬتأؼزهأۏۄتڽأحڬأدتةەأڲتأڬۄأثؽۏشأضۏىڲأًتهۏأثڬشۏأڬًأ؏أضۏىڲأًتهۏأضەأثزهۄأزهًتۏتأدتةەأڲتأۗ‛‛أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏضەأشتًۏأۄۏڽأ؏أدىأضەأوۏڽأًتملأىۄۏڽأۄًڽأتًشأتۏڬأشتًۏأؼغتأثىأضتةثأۄەأدًأترحهتغأڬتأطڬتشأۄًأڲۏتأحہتأۗ"
18409,"أىثۏأتڬشوأ﷽أڬۏأصًدۄأوذحشوۄأضۏزۄأتوأضهوۄأشعۏأتههۄأؼىۄتأثۏتىأڬشحۏأۄۏڽأ=أىثۏأتڬشوأ﷽أوۏشەأڲہشأوۏڽأوًدًزأحہەأ؏أإځأڬەأزضحأوثتشڬأوۏڽأوضًتڬأحہۏأ؏أځہشأىثۏأتڬشوأ﷽أىەأتځىۏأڬىۏصأڬًأ+أشتًۏأڬًأطڬأۄەأ؏أۏتأطتۏزأۏۄأتهلتػأۄۏڽأ=أ,أضۏزۄأتوأضهوۄأشعۏأتههۄأؼىۄتأڬۏأڬىۏصأڬًأثهتۏتأ+أًۄأىۄۏڽأإةۏأ,أحًأىثۏأتڬشوأ﷽أڬەأډۄشۄأوثتشڬأځشأؽعثأڬەأإختشأىوتۏتڽأۄًةەأ؏أضۏزۄأتوأضهوۄأشعۏأتههۄأؼىۄتأتْټہأڬشأڬوشەأڬەأتىزشأڲةۏڽأ؏أحًأتىۄًڽأىەأتضأڬىۏصأڬًأځتۏتأڬۄأًۄأثڬشۏأڬەأثډەأڬەأضتحہأڬہۏهأشۄۏأحہۏأ؏أحًأضۏزۄأتوأضهوۄأشعۏأتههۄأؼىۄتأىەألشوتۏتأ=أحوأۏۄتڽأثڬشۏأڬەأثډەأڬەأضتحہأڬہۏهأشۄۏأۄًأتًشأىثۏأتڬشوأ﷽أحوۄۏڽأثهتأشۄەأۄۏڽأ؏أتضأڬىۏصأىەأؼشعأڬۏأ=أتضأستحأڬۏأمضوأ$أدضأىەأإځأڬًأذمأڬەأۄوشتۄأوثؼًخأڬۏتأۄەأ؏أوۏڽأىەأإځأڬۏأإًتصأىۄۏڽأضىۏأحہۏأ؏أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أتڲشأثزهۄأزۏەأدتىەأڬتأتىزۏطۄأىۄأۄًحتأحًأوۏڽأىەأحوۄۏڽأتضأوضًتڬأڬەأسشۏؼەأوتشىتأحہتأۗ‛‛

[تخریج]: حدیث : 18409 - اخرجه أبو يعلى في ""المسند"" (6944) اخرجه الطبراني في "" المعجم الكبير "" (376/23)"
18410,"أتۏڬأشًتۏحأوۏڽأۏۄأتهلتػأۄۏڽأ=““أتڲشأمظتظأىۄأۄًحتأحًأوۏڽأىەأحوۄۏڽأتضأوضًتڬأڬەأسشۏؼەأوتشىتأحہتأۗ‛‛

[تخریج]: حدیث : 18410 - اخرجه ابو يعلى في ""المسند "" (6928)"
18411,"أتۏڬأشًتۏحأوۏڽأۏۄأتهلتػأۄۏڽأ=““أتڲشأمظتظأڬتأرًلأىۄأۄًحتأحًأوۏڽأىەأحوۄۏڽأتضأهڬڔۏأڬەأسشۏؼەأحڬهۏلأځۄىډتىۏأحہۏأۗ‛‛أأۏۄأحوتوأشًتۏتحأتوتوأتثًۏؼهۏٳأىەأىمهأڬۏأۄۏڽأتًشأتوتوأغثشتىۏأىەأتضأڬۏأوتىىزأىمهأڬۏأۄۏڽأ؏أحتۄوأتىۄًڽأىەأۏۄأتهلتػأىمهأڬةەأۄۏڽأ=““أىثۏأتڬشوأ﷽أىەأتځىۏأڬىۏصأڬًأثهتۏتأۗ‛‛أۏۄأتهلتػأڬضۏأطڬأڬەأثؽۏشأۄۏڽأتًشأتىۄًڽأىەأۏۄأتهلتػأىمهأڬةەأۄۏڽأ=†أتڲشأمۏتوحأڬەأزىأثزهۄزۏەأدتىەأڬتأرًلأىۄأۄًحتأۗ‛‛أأتوتوأتثًۏؼهۏٳأتًشأغثشتىۏأڬۏأىمهأڬشزۄأشًتۏحأڬۏأضىزأؼوزۄأۄەأۗ

[تخریج]: حدیث : 18411 - اخرجه ابو يعلى في المسند """" (6901)"
18412,"أذعشحأؼوتشأثىأۏتضشأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أأ““أدًأطرظأتځىەأؽهتوأڬًأوتشەأڲتأڬۄأمۏتوحأڬەأزىأ؏أتضأؽهتوأڬًأتضأضەأثزهۄأزهًتۏتأدتةەأڲتأۗ‛‛أأۏۄأشًتۏحأتوتوأثصتشأىەأىمهأڬۏأۄەأتًشأتضأڬەأشدتهأخمۄأۄۏڽأۗ

[تخریج]: حديث : 18412 - اخرجه البزار في """"المسند"""" (3452)"
18413,"أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أأ““أدًأطرظأػهوأڬەأغًشأځشأتۏڬأډہڔۏأوتشەأڲتأڬۄأمۏتوحأڬەأزىأتضأضەأثزهۄأزهًتۏتأدتةەأڲتأۗ‛‛أۏۄأشًتۏحأتوتوأثصتشأىەأتًشأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأتًشأتىأزًىًڽأڬۏأضىزأذضىأۄەأۗ

[تخریج]: حديث : 18413 - اخرجه البزار في المسند """" (3454)"
18414,"أذعشحأخًثتىأشعۏأتههۄأؼىۄأىثۏأتڬشوأ﷽أڬتأۏۄألشوتىأىمهأڬشحەأۄۏڽأ=أأ““أمۏتوحأڬەأزىأدثأ““أدثتشأحثتشڬأًأحؼتهۏٳأ‛‛أإةەأڲتأتًشأځهأځشأتځىۏأټتىڲأوًڔأهەأڲتأتًشأۏۄألشوتةەأڲتأ؏أوۏشۏأؼصحأتًشأوۏشەأدهتهأڬۏأمضوأۄەأ؏أڬضۏأػتهوأڬتأػهوأوۏشەأإڲەأضەأىۄۏڽأڲصشأضڬەأڲتأ؏أځہشأًۄأورهًمأڬەأزشوۏتىأتىأڬەأثتۄوۏأوؼتوهتحأڬەأذًتهەأضەأتىظتلأڬشەأڲتأ؏أۏۄتڽأحڬأڬۄأًۄأثؽۏشأضۏىڲأًتهۏأثڬشۏأڬًأضۏىڲأًتهۏأثڬشۏأضەأثزهۄأزهًتةەأڲتأ؏أدًأضۏىڲأتْضأىەأتضەأوتشتأحہتأۗ‛‛أأۏۄأشًتۏحأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأۏصۏزأثىأشثۏؼأۄەأ؏أدضەأتۏڬأدوتؼحأىەأعؼۏلأمشتشأزۏتأۄەأ؏أتثىأؼزۏأڬۄحەأۄۏڽأ=أودہەأۏۄأتوۏزأۄەأڬۄأتضأوۏڽأڬًةۏأذشدأىۄۏڽأۄًأڲتأ؏أتضأشًتۏحأڬەأثمۏۄأشدتهأخمۄأۄۏڽأۗ

[تخریج]: حدیث : 18414 - اخرجه الطبراني في """"المعجم الكبير """" (1421)"
18415,"أذعشحأضهوتىألتشضۏأشعۏأتههۄأؼىۄأىثۏأتڬشوأ﷽أڬتأۏۄألشوتىأىمهأڬشحەأۄۏڽأ=أأ““أمۏتوحأڬەأزىأتۏڬأطرظأتحىۏأىۏڬۏتڽأهەأڬشأإةەأڲتأڬۄأًۄأۏۄأڲوتىأڬشەأڲتأڬۄأتىأڬۏأًدۄأضەأًۄأىدتحأځتأدتةەأڲتأ؏أهۏڬىأځہشأڬًةۏأطرظأإةەأڲتأدضأځشأتضأىەأػهوأڬۏتأۄًأڲتأ؏أحًأتضأطرظأڬۏأىۏڬۏتڽأهەأڬشأوػهًوأڬًأزەأزۏأدتةۏڽأڲۏأ؏أۏۄتڽأحڬأڬۄأتضأطرظأڬۏأڬًةۏأىۏڬۏأثتمۏأىۄۏڽأشۄەأڲۏأ؏أځہشأڬًةۏأتًشأطرظأإةەأڲتأدًأتضأضەأوغتهثۄأڬشەأڲتأهۏڬىأتضأڬۏأڬًةۏأىۏڬۏأثتمۏأىۄۏڽأشۄۏأۄًأڲۏأحًأوػهًوأڬۏأثشتةۏتڽأهەأڬشأتْضأڬۏأثشتةۏًڽأوۏڽأطتوهأڬشأزۏأدتةۏڽأڲۏأۗ‛‛أۏۄأشًتۏحأغثشتىۏأتًشأتوتوأثصتشأىەأؼثزتههۄأثىأتضذتمأؼغتشأڬەأذًتهەأضەأرتهزأثىأذوصۄأضەأىمهأڬۏأۄەأتًشأوۏڽأتىأزًىًڽأضەأًتملأىۄۏڽأۄًڽأ؏أتضأشًتۏحأڬەأثمۏۄأشدتهأظذۏذأڬەأشدتهأۄۏڽأۗ

[تخریج]: حدیث : 18415 - اخرجه الطبراني في """"المعجم الكبير """" (6153)"
18416,"أضهۏوتىأثىأذثۏثأوذتشثۏأثۏتىأڬشحەأۄۏڽأ=أوۏڽأدىڲأوۏڽأذظۄأهۏىەأڬەأهۏەأشًتىۄأۄًتأ؏أدثأوۏشتأڲصشأ““أذوظأ‛‛أضەأۄًتأحًأوۏڽأثتصتشأڬۏأغشلأڲۏتأحتڬۄأًۄتڽأضەأًۄأډۏصۏڽأهەأهًڽأدًأوضتلشأڬەأهۏەأعشًشۏأۄًحۏأۄۏڽأ؏أدثأوۏڽأىەأوضدزأڬەأزشًتصەأڬۏأغشلأزۏڬہتأحًأوۏڽأىەأضًډتأڬۄأتڲشأوۏڽأوضدزأڬەأتىزشأدتأڬشأزًأشڬؼحأتزتأڬشأهًڽأ+أحًأۏۄأوىتضثأۄًأڲتأ,أدثأوۏڽأوضدزأڬەأتىزشأإۏتأحًأوۏڽأىەأزۏڬہتأڬۄأًۄتڽأختثحأثىأوؼثزأ؏أتثىأصڬشۏتأتًشأوڬذًهأ؏أتۄهأزوطمأضەأحؼهمأشڬہىەأًتهەأڬډہأتلشتزأڬەأۄوشتۄأوًدًزأحہەأ؏أدثأوۏڽأىەأتىأهًڲًڽأڬًأزۏڬہتأحًأوۏڽأتىأڬەأځتضأإۏتأتًشأتىأڬەأځتضأثۏټہأڲۏتأ؏أًۄأهًڲأڬډہأزۏشأثتحأډۏحأڬشحەأشۄەأ؏أځہشأتىۄًڽأىەأڬۄتأ=أۄوأذعشحأتثًتوتوۄأثتۄهۏأشعۏأتههۄأؼىۄأڬۏأغشلأدتىەأڬتأتشتزۄأشڬہحەأۄۏڽأ؏أًۄأهًڲأتْټہەأحًأتىأڬەأضتحہأوۏڽأثہۏأتْټہأڲۏتأ؏أۄوأهًڲأذعشحأتثًتوتوۄأشعۏأتههۄأؼىۄأڬۏأرزوحأوۏڽأذتعشأۄًةەأ؏أًۄأتۏڬأثًڔہەأڬوصًشأؼوشأشضۏزۄألشزأحہەأ؏أهۏڬىأتىأڬۏأػتۄشۏأذتهحأڬۏأثۄأىضثحأتىأڬۏأؼمهأتًشأتىأڬۏأڲلحڲًأصۏتزۄألعۏهحأشڬہحۏأحہۏأ؏أتىۄًڽأىەأۄوۏڽأدًأثتحأتشطتزألشوتةۏأ؏أتضأوۏڽأضثأضەأځۄهۏأثتحأۏۄأحہۏأ؏أحوۄتشۏأۏۄأىطضحأتههۄأحؼتهۏٳأڬۏأغشلأضەأحوۄتشەأهةەأحثهۏؽأۄەأتًشأحوۄتشەأرهتلأتههۄأحؼتهۏٳأڬۏأذدحأۄەأ؏أىثۏأتڬشوأ﷽أڬًأدضأډۏصأڬەأۄوشتۄأوؼثًخأڬۏتأڲۏتأحہتأ؏أإځأىەأتضأڬۏأحثهۏؽأڬشأزۏأتًشأىثۏأتڬشوأ﷽أڬەأتظذتثأىەأدًأڬډہأضىتأحہتأ؏أتْضأڬۏأتىۄًڽأىەأحثهۏؽأڬشأزۏأ؏أحًأحوأهًڲأدًأضىًأڲەأ؏أحوأثہۏأتضأڬۏأحثهۏؽأڬشأزۏىتأ$أأ““أحۏىأهًڲأۄۏڽأ؏أدىأڬتأتههۄأحؼتهۏٳأعتوىأۄەأ؏أتۏڬأًۄأطرظأدًأتههۄأڬۏأشتۄأوۏڽأىڬهحتأۄەأحًأتههۄأحؼتهۏٳأڬەأسوۄأۏۄأثتحأۄەأ؏أتههۄأحؼتهۏٳأتضەأدىحأوۏڽأزترهأڬشأزەأ؏أۏتأځہشأتضەأتدشأتًشأؽىۏوحأڬەأۄوشتۄأًتځضأهەأإةەأ؏أتًشأتۏڬأًۄأطرظأدًأتځىەأڲہشأوۏڽأضهتوحۏأڬەأۄوشتۄأزترهأۄًحتأۄەأۗ‛‛أأځہشأتىۄًڽأىەأۏۄأثتحأثۏتىأڬۏأ=أدۄىوأځشأځهأۄًأڲتأدضأوۏڽأضتحأغثمەأۄًڽأڲەأ؏أتىأوۏڽأضەأزشوۏتىأًتهەأځشأىتلشوتىأهًڲأۄًڽأڲەأ؏أڬضۏأثىزەأڬًأهتۏتأدتةەأڲتأ؏أۏۄتڽأحڬأڬۄأدثأًۄأزشوۏتىۏأزشدەأځشأځۄىډەأڲتأحًأتضأضەأزشۏتلحأڬۏتأدتةەأڲتأ=أحوۄتشەأسوۄأڬحىتأمشعأۄەأآأځہشأتىۄًڽأىەأۏۄأإۏحأحهتًحأڬۏأ=أ““أتًشأًۄأتههۄأحؼتهۏٳأضەأڬًةۏأثتحأډہځتأىۄۏڽأضڬۏڽأڲەأۗ‛‛أأًۄأطرظأڬۄەأڲتأ=أتەأوۏشەأځشًشزڲتشأ$أوۏشەأسوۄأتحىتأ؏أتحىتأمشعأۄەأ؏أحًأتْضەأڬۄتأدتةەأڲتأ=أحوأتځىتأمشعأتزتأڬشًأ$أًۄأڬۄەأڲتأ=أوۏشەأځتضأحًأڬًةۏأډۏصأىۄۏڽأۄەأ؏أودہەأضودہأىۄۏڽأإأشۄۏأڬۄأوۏڽأڬضأډۏصأڬەأسشۏؼەأتزتةۏڲۏأڬشًڽأآأحًأڬۄتأدتةەأڲتأ=أتضأڬۏأىۏڬۏتڽأهەأهًأ$أتضأطرظأضەأىۏڬۏتڽأهۏأدتةۏڽأڲۏأ؏أۏۄتڽأحڬأڬۄأتضأڬۏأڬًةۏأىۏڬۏأثتمۏأىۄۏڽأشۄەأڲۏأ؏أدثأتضأڬۏأىۏڬۏتڽأرحوأۄًأدتةۏڽأڲۏأحًأڬۄتأدتةەأڲتأ=أتضأڬۏأىۏڬۏتڽأرحوأۄًأڲةۏأۄۏڽأ؏أحًأۏۄأڬۄتأدتةەأڲتأ=أتضأضەأوغتهثۄأڬشىەأًتهەأڬەأڲىتۄأهًأتًشأتضأڬەأسوۄأڋتهأزًأ$أأ+أشتًۏأڬۄحەأۄۏڽأ=أ,أودہأحڬأۏۄأشًتۏحأځۄىډۏأۄەأ=أڬډہأهًڲأځۄتڔًڽأدحىۏأىۏڬۏتڽأهەأڬشأإةۏڽأڲەأتًشأتىأضەأ+أثزهۄأ,أغهثأڬشىەأًتهەأهًڲًڽأڬەأهةەأتْىأڬۏأىۏڬۏتڽأهۏأدتحۏأشۄۏڽأڲۏأ؏أۏۄتڽأحڬأڬۄأتضأطرظأڬەأځتضأڬًةۏأىۏڬۏأثتمۏأىۄۏڽأشۄەأڲۏأۗأۏۄأشًتۏحأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأڬهخًوأثىأصۏتزأتًشأتۏڬأشتًۏأثڬشأثىأضۄهأزوۏتغۏأۄەأتًشأتىأزًىًڽأڬۏأحًخۏمأڬۏأڲةۏأۄەأتضأوۏڽأعؼلأځتۏتأدتحتأۄەأ؏أتضأشًتۏحأڬەأثمۏۄأشدتهأظذۏذأڬەأشدتهأۄۏڽأۗ

[تخریج]: حديث : 18416 - اخرجه الطبراني في """"المعجم الكبير """" (7493)"
18417,"أذعشحأتثًتوتوۄأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أ““أمۏتوحأڬەأزىأػتهوأإةەأڲتأ؏أۏۄتڽأحڬأڬۄأًۄأدۄىوأڬەأځهأڬەأځتضأځۄىډەأڲتأ؏أدۄتڽأحتشۏڬۏأتًشأڲہثشتۄټأۄًأڲۏأ؏أحًأوػهًوأتضأضەأوهەأڲتأ؏أًۄأتضەأځۄډتىأهەأڲتأ؏أتضأىەأدًأػهوأتضأځشأڬۏتأحہتأتْضەأثہۏأځۄډتىأهەأڲتأ؏أځہشأػهوأڬشىەأًتهًڽأضەأ؏أوػهًوًڽأڬًأوضهضهأثزهۄأزهتۏتأدتحتأشۄەأڲتأ؏أۏۄتڽأحڬأڬەأتىأػتهوًڽأڬەأځتضأدحىۏأىۏڬۏتڽأۄًڽأڲۏأًۄأتىأضەأهەأهۏأدتةۏڽأڲۏأتًشأدثأتىأڬۏأىۏڬۏتڽأثتمۏأىۄۏڽأشۄۏڽأڲۏأ؏أحًأوػهًوًڽأڬۏأثشتةۏتڽأتْىأځشأڋتهأزۏأدتةۏڽأڲۏأ؏أۏۄتڽأحڬأڬۄأتىۄۏڽأدۄىوأڬەأضثأضەأىۏډەأًتهەأغثمەأوۏڽأځۄىډتأزۏتأدتةەأڲتأۗ‛‛أأۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأتًشأتضأڬەأشدتهأڬۏأحًخۏمأڬۏأڲةۏأۄەأۗ"
18418,"أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أأ““أمۏتوحأڬەأزىأهًڲًڽأڬەأځۄتڔًڽأدۏضەأوػتهوأهتةەأدتةۏڽأڲەأدًأتىۄًڽأىەأتۏڬأزًضشەأځشأڬةەأۄًڽأڲەأتًشأتىأڬەأذمًمأهتةەأدتةۏڽأڲەأتًشأځہشأتههۄأحؼتهۏٳأوضهضهأتىأڬەأذًتهەأضەأثزهۄأزهًتحتأشۄەأڲتأ؏أۏۄتڽأحڬأڬۄأتىأوۏڽأضەأڬًةۏأډۏصأثتمۏأىۄۏڽأشۄەأڲۏأۗ‛‛أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأ؏أتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأدتثشأثىأۏصۏزأدؼلۏأۄەأتًشأًۄأعؼۏلأۄەأۗ"
18419,"أذعشحأتثًثشزۄأثىأىۏتشأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أأ““أثەأطڬأتههۄأحؼتهۏٳأتۏڬأؽشۏوأ+أۏؼىۏأدضأڬەأسوۄأڬًةۏأتزتةۏڲۏأۄًأڲۏأ؏أتضأ,أڬًأزًضشەأڬەأهةەأشًڬأهەأڲتأ؏أتحىۏأصۏتزۄأضرحۏأڬەأضتحہأدحىۏأضرحۏأڬۏأدتأضڬحۏأۄەأ؏أًۄأڬۄەأڲتأ=أتەأځشًشزڲتشأ$أوۏڽأتضەأڬۏضەأڬډہأزًڽأآأدثڬۄأحًأىەأوۏشتأذطشأتۏضۏأذتهحأوۏڽأڬۏتأۄەأڬۄأوۏڽأثشۄىۄأۄًڽأتًشأثشۄىۄأځتاڽأۄًڽأ؏أحًأتزتةۏڲۏأڬۏضەأۄًأضڬحۏأۄەأآأتههۄأحؼتهۏٳألشوتةەأڲتأ=أۄوأتىأهًڲًڽأڬًأحوۄتشۏأىۏڬۏتڽأزەأزۏحەأۄۏڽأ+أىثۏأتڬشوأ﷽ألشوتحەأۄۏڽأ=أ,أځہشأتضأڬۏأىۏڬۏتڽأهًڲًڽأڬًأزەأزۏأدتةۏڽأڲۏأ؏أتڲشأًۄأڬلتۏحأڬشأدتةۏڽأڲۏأحًأټہۏڬأۄەأًشىۄأهًڲًڽأڬەأڲىتۄأهەأڬشأتْضأڬەأڲىتۄًڽأوۏڽأطتوهأڬشأزۏەأدتةۏڽأڲەأۗ‛‛أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأ؏أتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأذوتزأثىأطؼۏثأۄەأتًشأًۄأتىحۄتةۏأعؼۏلأۄەأۗ"
18420,"أذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأىثۏأتڬشوأ﷽أڬەأذًتهەأضەأذعشحأشًذأتهتوۏىأؼهۏۄأتهضهتوأڬەأذًتهەأضەأۏۄأثتحأىمهأڬشحەأۄۏڽأ=أځشًشزڲتشألشوتحتأۄەأ=أ““أثىزەأڬۏأثشتةۏتڽأتًشأىۏڬۏتڽأهتةۏأدتةۏڽأڲۏأتًشأځہشأثزهۄأزهًتۏتأدتةەأڲتأ+أشتًۏأڬًأطڬأۄەأ؏أۏتأطتۏزأۏۄأتهلتػأۄۏڽأ=أ,أتزتةۏڲۏتڽأڬۏأدتةۏڽأڲۏأ؏أتڲشأتْضأڬۏأتۏڬأثہۏأىۏڬۏأثتمۏأشۄأڲةۏأحًأًۄأتضأڬەأهةەأدىحأوۏڽأڲىدتةطأڬشأزەأڲۏأۗ‛‛أأۏۄأشًتۏحأتوتوأثصتشأىەأىمهأڬۏأۄەأتًشأتضأڬەأثؼعأشتًۏًڽأوۏڽأوًدًزأعؼلأڬەأثتًدًزأتىأڬۏأحًخۏمأڬۏأڲةۏأۄەأۗ

[تخریج]: حدیث : 18420 - اخرجه البزار في المسند """" (3456)"
18421,"أصتستىأثۏتىأڬشحەأۄۏڽأ=أوۏڽأذعشحأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄأڬۏأرزوحأوۏڽأذتعشأۄًتأ؏أودہأضەأځۄهەأشۏطوأتًشأزۏثتدأًتهەأهًڲأتىأڬەأځتضأإأډڬەأحہەأ؏أوۏڽأىەأڬۄتأ=أإځأىەأهًڲًڽأڬًأمشۏثأڬشأهۏتأۄەأتًشأودہەأزًشأڬشأزۏتأۄەأ؏أتىۄًڽأىەأودہأضەألشوتۏتأ=أحوأمشۏثأإأدتاأ$أتىۄًڽأىەأودہەأمشۏثأڬۏتأۏۄتڽأحڬأڬۄأتىۄًڽأىەأودہەأتځىەأثډہًىەأځشأثټہتۏتأ؏أځہشأتىۄًڽأىەألشوتۏتأ=أوۏڽأىەأىثۏأتڬشوأ﷽أڬًأۏۄأتشطتزألشوتحەأۄًةەأضىتأۄەأ=أ““أًتهزۏىأڬتأتځىۏأتًهتزأڬەأسوۄأمشعأۄًأڲتأ+أۏؼىۏأدًأمشعأًتهزۏىأىەأتځىۏأتًهتزأضەأًظًهأڬشىتأۄًأڲتأ,أدثأمۏتوحأڬتأزىأۄًأڲتأحًأًتهزۏىأتځىەأثډەأڬەأضتحہأوحؼهمأۄًأدتةۏڽأڲەأ+أۏؼىۏأتضأضەأتځىەأمشعأڬۏأًتځضۏأڬتأوغتهثۄأڬشۏڽأڲەأ,أًۄأڬۄەأڲتأ=أوۏڽأإځأڬتأثډۄأۄًڽأ؏أهۏڬىأوتڽأثتځأڬۏأۏۄأرًتۄطأۄًأڲۏأڬۄأڬتطأتْىۄًڽأىەأتْضأضەأصۏتزۄأًظًهۏأڬشىۏأۄًحۏأۗ‛‛أ+أۏۄتڽأتۏڬأهلػأڬەأثتشەأوۏڽأشتًۏأڬًأطڬأۄەأ,أأۏۄأشًتۏحأتوتوأغثشتىۏأىەأؼوشًأثىأورهزأڬەأذًتهەأضەأسڬشۏتأثىأۏذۏۏأتىظتشۏأضەأىمهأڬۏأۄەأتًشأوۏڽأتىأزًىًڽأضەأًتملأىۄۏڽأۄًڽأتضأشًتۏحأڬەأثمۏۄأشدتهأڬۏأحًخۏمأڬۏأڲةۏأۄەأتڲشډۄأتىأوۏڽأضەأڬډہأوۏڽأعؼلأځتۏتأدتحتأۄەأۗ

[تخریج]: حديث : 18421 - اخرجه الطبراني في المعجم الكبير """" (10526)"
18422,"أدۄوأثىأتًضأثۏتىأڬشحەأۄۏڽأ=أوۏڽأىەأؼثزتههۄأثىأتثًوشۏوأڬًأضىتأ؏أؼثزتههۄأثىأشضحوأتځىۏأضًتشۏأځشأتىأڬەأځتضأضەأڲصشتأتضأىەأتثىأتثًوشۏوأضەأڬۄتأ=أوۏشۏأۏۄأرًتۄطأحہۏأڬۄأوۏڽأإځأڬەأځتضأثۏټہحتأتًشأإځأڬەأضتحہأثتحأډۏحأڬشحتأ؏أدثأًۄأډهتأڲۏتأحًأتثىأتثًوشۏوأىەأڬۄتأ=أوۏڽأىەأذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأڬًأۏۄأثۏتىأڬشحەأۄًةەأضىتأۄەأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأۄەأ=أ““أحوأهًڲأڬضۏأڲىتۄأڲتشأطرظأڬۏأىؼوحأڬەأذًتهەأضەأشطڬأىۄأڬشًأڬۏًىڬۄأحوأۏۄأىۄۏڽأدتىحەأڬۄأتضأىەأوشىەأڬەأثؼزأڬضأظًشحذتهأڬتأضتوىتأڬشىتأۄەأآأتههۄأحؼتهۏٳأڬەأځتضأتضأڬەأهۏەأتۏڬأتۏضتأمتحهأۄًأڲتأ+أدًأتضەأمحهأڬشحتأشۄەأڲتأ,أتًشأتضەأوًحأىۄۏڽأإةەأڲۏأۗ‛‛أأۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأتًشأتضأڬەأشدتهأخمۄأۄۏڽأۗ"
18423,"أذعشحأتىضأثىأوتهڬأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أأ““أتههۄأحؼتهۏٳأتضأثىزەأځشأشذوأڬشەأدضأىەأتځىەأڬضۏأثہتةۏأڬەأضتحہأدتىأۏتأوتهأڬەأذًتهەأضەأڬًةۏأصۏتزحۏأڬۏأۄًأ؏أځہشأًۄأتځىەأثہتةۏأڬەأځتضأدتةەأتًشأمۏتوحأڬەأزىأضەأځۄهەأتضەأوؼتلأڬشًتأهەأڬۏًىڬۄأمۏتوحأڬەأزىأحًأڬًةۏأزۏىتشأۏتأزشۄوأىۄۏڽأۄًأڲتأًۄتڽأحًأىۏڬۏتڽأۄۏأۄًڽأڲۏأۗ‛‛أأؼشعأڬۏأڲةۏأ=أۏتأشضًهأتههۄأ$أتڲشأتضأڬەأځتضأىۏڬۏتڽأىۄأۄًةۏڽأآأىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أحًأزًضشەأطرظأڬەأڲىتۄأهەأڬشأتضأڬەأڲىتۄًڽأوۏڽأطتوهأڬشأزۏەأدتةۏڽأڲەأۗ‛‛أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأۄتطوأثىأؼۏضۏٳأۏصىۏأۄەأتًشأوۏڽأتضأضەأًتملأىۄۏڽأۄًڽأتضأشًتۏحأڬەأثمۏۄأشدتهأڬۏأحًخۏمأڬۏأڲةۏأۄەأتڲشډۄأتىأوۏڽأضەأڬډہأوۏڽأعؼلأځتۏتأدتحتأۄەأۗ"
18424,"أذعشحأتثًوًضۏٳأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أأ““أتههۄأحؼتهۏٳأزىۏتأوۏڽأدضأثىزەأڬۏأځشزۄأځًطۏأڬشەأڲتأتْضەأمۏتوحأڬەأزىأتضأذًتهەأضەأؼتشأىۄۏڽأزهتةەأڲتأۗ‛‛أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأظؽۏشأوۏڽأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأؼوشأثىأضؼۏزأتثذأۄەأتًشأًۄأعؼۏلأۄەأۗ

[تخریج]: حدیث : 18424 - اخرجه الطبراني في """"المعجم الصغير (192)"
18425,"أضۏزيأتوأۄتىۏأثىحأتثًغتهثأشعۏأتههۄأؼىۄتأىثۏأتڬشوأ﷽أڬتأۏۄألشوتىأىمهأڬشحۏأۄۏڽأ=أأ““أثەأطڬأتههۄأحؼتهۏٳأحوتوأځۄهەأًتهًڽأتًشأحوتوأثؼزأًتهًڽأڬًأتۏڬأوۏزتىأوۏڽأتڬټہتأڬشەأڲتأځہشأؼشطأڬەأىۏډەأضەأتۏڬأوىتزۏأځڬتشأڬشأۏۄأڬۄەأڲتأ=أتەأتۄهأحًذۏزأ$أثۏطڬأتههۄأحؼتهۏٳأىەأحوأضەأزشڲصشأڬۏتأۄەأ؏أځہشأًۄأهًڲأڬډہأصۏتزحۏًڽأڬەأذًتهەأضەأتۏڬأزًضشەأضەأوغتهثۄأڬشۏڽأڲەأحًأوىتزۏأځڬتشأڬشأڬۄەأڲتأ=أتەأتۄهأحًذۏزأ$أحوأتۏڬأزًضشەأڬًأوؼتلأڬشأزًأتًشأتضأڬتأخًتثأوۏشەأسوۄأۄەأۗ‛‛أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأتثًؼتظوأشثۏؼأثىأتضوتؼۏهأۄەأدًأوىڬشأتهذزۏخأۄەأۏۄأثتحأتثًذتحوأىەأڬۄۏأۄەأۗ

[تخریج]: حدیث : 18425 - اخرجه الطبراني في """"المعجم الأوسط"""" (1358)"
18426,"أذعشحأتىضأثىأوتهڬأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أأ““أمۏتوحأڬەأزىأدثأورهًمأتڬټہۏأۄًأڲۏأتًشأتۄهأدىحأڬًأدىحأوۏڽأزترهأڬشأزۏتأدتةەأڲتأتًشأتۄهأدۄىوأڬًأدۄىوأوۏڽأزترهأڬشأزۏتأدتةەأڲتأحًأتۏڬأوىتزۏأځڬتشأڬشأۏۄأڬۄەأڲتأ=أتەأتۄهأدوؼأ$أحوأإځضأڬۏأصۏتزحۏًڽأڬًأډہًڔأزًأ+أۏؼىۏأوؼتلأڬشأزًأ$أ,أحوۄتشتأخًتثأوۏشەأسوۄأۄەأۗ‛‛أأۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأذڬوأثىأضىتىأتثًؼًىأۄەأتثًذتحوأڬۄحەأۄۏڽأ=أتضەأثۄحأصۏتزۄأًۄوأهتذمأۄًحتأۄەأ؏أۏۄأمًۏأىۄۏڽأۄەأتضأڬتأوذهأظزمأۄەأ؏أتضأڬۏأذزۏخأڬًأىًټأڬۏتأدتةەأڲتأ؏أتىأڬەأؼهتًۄأزۏڲشأذعشتحأىەأتضەأعؼۏلأمشتشأزۏتأۄەأتضأشًتۏحأڬەأثمۏۄأشدتهأخمۄأۄۏڽأۗأأتضأضەأځۄهەأؼهوأڬۏألعۏهحأضەأوحؼهمأثتثأوۏڽأذزۏخأڲصشأډڬۏأۄەأڬۄأتههۄأحؼتهۏٳأؼهوتؤأضەألشوتةەأڲتأ=أ““أوۏڽأىەأتځىتأؼهوأحوۄتشەأتىزشأتضأهۏەأىۄۏڽأشڬہتأڬۄأوۏڽأۏۄأتشتزۄأشڬہحتأحہتأڬۄأوۏڽأحوۄۏڽأؼستثأزًڽأ؏أحوأدتاأ$أوۏڽأىەأحوۄتشۏأوؽلشحأڬشأزۏأۄەأۗ‛‛أتضۏأغشذأتۏڬأذزۏخأمشعأڬەأثتشەأوۏڽأۄەأ؏أدًأطرظأمشعأهۏحتأۄەأتًشأتضأڬتأوتهأعتةؼأۄًأدتحتأۄەأحًأتههۄأحؼتهۏٳأتضأڬۏأغشلأضەأتزتةۏڲۏأڬشًتأزەأڲتأۗ"
18427,"أذعشحأتثًضؼۏزأرزشۏأشعۏأتههۄأؼىۄأحًأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أأ““أۄشأطرظأظشلأتههۄأحؼتهۏٳأڬۏأشذوحأڬۏأًدۄأضەأدىحأوۏڽأزترهأۄًأڲتأ؏أهًڲًڽأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ$أإځأثہۏأ+أتههۄأحؼتهۏٳأڬۏأشذوحأڬەأثؽۏشأزترهأ,أىۄۏڽأ+أۄًڽأڲەأآأ,أىثۏأتڬشوأ﷽أىەألشوتۏتأ=أوۏڽأثہۏأىۄۏڽأ؏أتهثحۄأۏۄأۄەأڬۄأتههۄأحؼتهۏٳأىەأودہەأتځىۏأشذوحأڬەأسشۏؼەأڋہتىځأهۏتأۄەأ؏أىثۏأتڬشوأ﷽أىەأتځىەأزضحأوثتشڬأڬەأسشۏؼەأتځىەأضشأڬەأتًځشأتطتشۄأڬشأڬەأۏۄأثتحأتشطتزألشوتةۏأۗأأۏۄأشًتۏحأتوتوأتذوزأىەأىمهأڬۏأۄەأتًشأتضأڬۏأضىزأذضىأۄەأۗ

[تخریج]: حدیث : 18427 - اخرجه احمد في المسند """" (52/3)"
18428,"أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأىثۏأتڬشوأ﷽أڬتأۏۄألشوتىأىمهأڬشحەأۄۏڽأ=أأ““أحوأوۏڽأضەأڬضۏأتۏڬأڬًأتضأڬتأؼوهأىدتحأىۄۏڽأزەأڲتأ؏أهًڲًڽأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ$أإځأڬًأثہۏأىۄۏڽأآأىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أودہەأثہۏأىۄۏڽأ؏أتهثحۄأۏۄأۄەأڬۄأتههۄأحؼتهۏٳأىەأودہەأتځىۏأشذوحأڬەأسشۏؼەأڋہتىځأهۏتأۄەأ؏أحوأظثذأتًشأطتوأتًشأشتحأڬەأڬډہأذظەأوۏڽأ+أىوتصأتزتأڬشًأ,أتًشأوۏتىۄأشًۏأترحۏتشأڬشًأ؏أوۏتىۄأشًۏأترحۏتشأڬشًأ؏أحوأځۄىډأدتاأڲەأۗ‛‛أأ+أؼهتوۄأۄۏخوۏألشوتحەأۄۏڽأ=أ,أوۏڽأۏۄأڬۄحتأۄًڽأ=أۏۄأشًتۏحأ““أظذۏذأ‛‛أوۏڽأترحظتشأڬەأضتحہأوسڬًشأۄەأۗأۏۄأشًتۏحأتوتوأتذوزأىەأىمهأڬۏأۄەأتًشأتضأڬەأشدتهأظذۏذأڬەأشدتهأۄۏڽأۗ

[تخریج]: حدیث : 18428 - اخرجه احمد في """"المسند """" (262/2)"
18429,"أتىأظذتثۏأڬەأذًتهەأضەأۏۄأثتحأوىمًهأۄەأ=أًۄأثۏتىأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أ““أڬضۏأطرظأڬًأتضأڬتأؼوهأىدتحأىۄۏڽأزهًتةەأڲتأ؏أهًڲًڽأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ$أإځأڬًأثہۏأىۄۏڽأآأىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أودہەأثہۏأىۄۏڽأ؏أتهثحۄأتههۄأحؼتهۏٳأىەأودہەأتځىۏأرتظأشذوحأتًشألعهأڬەأسشۏؼۄأڋہتىځأهۏتأۄەأ؏أتڲشأًۄأوۏشتأتًشأذعشحأؼۏضۏٳأؼهۏۄأتهضهتوأڬتأوًترسۄأڬشەأ؏أتضأډۏصأڬەأذًتهەأضەأدضأڬتأتشحڬتثأتىأزًأ+أتىڲهۏًڽأ,أىەأڬۏتأۄەأ؏أحًأًۄأۄوۏڽأۄهتڬحأڬتأطڬتشأڬشأزەأڲتأۗ‛‛أأشتًۏأثۏتىأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأطۄتزحأڬۏأتىڲهۏأتًشأزشوۏتىۏأتىڲهۏأڬەأسشۏؼەأتطتشۄأڬشأڬەأ+أۏۄأثتحأتشطتزألشوتةۏأ,أۗأ+أؼهتوۄأۄۏخوۏألشوتحەأۄۏڽأ=أ,أوۏڽأۏۄأڬۄحتأۄًڽأ=أۏۄأشًتۏحأ““أظذۏذأ‛‛أوۏڽأوسڬًشأۄەأ؏أحتۄوأتضأوۏڽأۏۄأتهلتػأىۄۏڽأۄۏڽأ=†أتڲشأًۄأوۏشتأوًترسۄأڬشەأ111111‛‛ۗأۏۄأشًتۏحأتوتوأثصتشأىەأتًشأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأحتۄوأتىۄًڽأىەأۏۄأتهلتػأىمهأڬةەأۄۏڽأ=†أتڲشأًۄأتضأڬەأذًتهەأضەأوۏشتأوًترسۄأڬشەأ؏أدضأڬتأتشحڬتثأتىۄًڽأىەأڬۏتأۄەأحًأًۄأودہەأۄهتڬحأڬتأطڬتشأڬشأزەأۗ‛‛أتوتوأثصتشأڬەأتضحتزأتثًثڬشأضەأوۏڽأًتملأىۄۏڽأۄًڽأ؏أطتۏزأۏۄأتثىأتثًزىۏتأڬتأًشتمأۄەأ؏أڬۏًىڬۄأتضأىەأوذوزأثىأؼثزتهوهڬأثىأصىدًۏۄأضەأشًتۏتحأىمهأڬۏأۄۏڽأ؏أتضۏأغشذأتوتوأغثشتىۏأڬەأتضحتزأتثشتۄۏوأثىأوؼتًۏۄأثىأسڬًتىأثىأتثًضلۏتىأمۏظشتىۏأڬەأذتهتحأثۏتىأڬشحەأۄًةەأ؏أوۏڽأىەأڬضۏأڬًأىۄۏڽأځتۏتأۄەأ؏أتىأزًىًڽأڬەأثمۏۄأشدتهأظذۏذأڬەأشدتهأۄۏڽأ؏أظشلأوذوزأثىأؼثزتهوهڬأثىأصىدًۏۄأڬتأوؼتوهۄأورحهلأۄەأتًشأًۄأخمۄأۄەأۗ

[تخریج]: حدیث : 18429 - اخرجه البزار في """"المسند"""" (3448) أخرجه الطبراني في """"المعجم الاوسط """" (2315)"
18430,"أذعشحأتثًوًضۏٳأتطؼشۏأشعۏأتههۄأؼىۄأىثۏأتڬشوأ﷽أڬتأۏۄألشوتىأىمهأڬشحەأۄۏڽأ=أأ““أحوأوۏڽأضەأڬضۏأتۏڬأڬًأتضأڬتأؼوهأىدتحأىۄۏڽأزهًتةەأڲتأ؏أهًڲًڽأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ$أإځأڬًأثہۏأىۄۏڽأآأىثۏأتڬشوأ﷽أىەألشوتۏتأ=أودہەأثہۏأىۄۏڽأتهثحۄأتههۄأحؼتهۏٳأىەأتځىۏأشذوحأڬەأسشۏؼەأودہەأڋہتىځأهۏتأۄەأۗ‛‛أأۏۄأشًتۏحأتوتوأثصتشأىەأتوتوأغثشتىۏأىەأوؼدوأتًضغأتًشأوؼدوأڬثۏشأوۏڽأىمهأڬۏأۄەأ؏أحتۄوأتىۄًڽأىەأوؼدوأڬثۏشأوۏڽأۏۄأتهلتػأىمهأڬةەأۄۏڽأ=أ““أحوأوۏڽأضەأڬضۏأتۏڬأڬًأتضأڬتأؼوهأدىحأوۏڽأزترهأىۄۏڽأڬشًتةەأڲتأ؏أذتعشۏىأوۏڽأضەأڬضۏأىەأزشۏتلحأڬۏتأ=أإځأڬًأثہۏأىۄۏڽأآ111111أتضأڬەأثؼزأشتًۏأىەأځًشۏأذزۏخأسڬشأڬۏأۄەأۗأأتىأشًتۏتحأڬۏأتضتىۏزأوۏڽأتۏڬأشتًۏأتطؼخأثىأضًتشأۄەأدضأڬەأعؼۏلأۄًىەأڬەأثتًدًزأتضأڬۏأحًخۏمأڬۏأڲةۏأۄەأ؏أتىأشًتۏتحأڬەأثمۏۄأشدتهأخمۄأۄۏڽأۗ

[تخریج]: حديث : 18430 - اخرجه البزار في المسند """" (3447)"
18431,"أذعشحأطشۏڬأثىأغتشمأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أ““أحوأوۏڽأضەأڬًةۏأتۏڬأؼوهأڬۏأًدۄأضەأدىحأوۏڽأزترهأىۄۏڽأۄًأڲتأ؏أهًڲًڽأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ$أإځأثہۏأىۄۏڽأآأىثۏأتڬشوأ﷽أىەألشوتۏتأ=أوۏڽأثہۏأىۄۏڽأ؏أتهثحۄأتههۄأحؼتهۏٳأىەأودہەأتځىۏأشذوحأتًشألعهأڬەأسشۏؼەأڋہتىځأهۏتأۄەأۗ‛‛أۏۄأشًتۏحأتوتوأغثشتىۏأىەأورحهلأتضتىۏزأڬەأذًتهەأضەأىمهأڬۏأۄەأدىأوۏڽأضەأتۏڬأڬەأشدتهأظذۏذأڬەأشدتهأۄۏڽأۗ

[تخریج]: حديث : 18431 - اخرجه الطبراني في """" المعجم الكبير """" (7218)"
18432,"أذعشحأتضتوۄأثىأطشۏڬأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أوۏڽأىەأىثۏأتڬشوأ﷽أڬًأۏۄأتشطتزألشوتحەأۄًةەأضىتأۄەأ=أأ““أڬًةۏأطرظأتځىەأؼوهأڬۏأًدۄأضەأدىحأوۏڽأزترهأىۄۏڽأۄًأڲتأ؏أۄوأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ$أإځأثہۏأىۄۏڽأآأىثۏأتڬشوأ﷽أىەألشوتۏتأ=أوۏڽأثہۏأىۄۏڽأ؏أتهثحۄأتههۄأحؼتهۏٳأىەأتځىۏأشذوحأڬەأسشۏؼەأودہەأڋہتىځأهۏتأۄەأ+أۏۄأثتحأتشطتزألشوتحەأۄًةەأ,أىثۏأتڬشوأ﷽أىەأتځىتأزضحأوثتشڬأتځىەأضشأوثتشڬأځشأشڬہأهۏتأۗأۏۄأشًتۏحأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأولعهأثىأظتهذأتضزۏأۄەأتًشأًۄأعؼۏلأۄەأۗ

[تخریج]: حديث : 18432 - اخرجه الطبراني في """" المعجم الكبير """" (493)"
18433,"أذعشحأتضزأثىأڬشصأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أ““أتەأتضزأثىأڬشصأ$أحوأؼوهأڬۏأًدۄأضەأدىحأوۏڽأزترهأىۄۏڽأۄًأڲەأ؏أثهڬۄأتههۄأحؼتهۏٳأڬۏأشذوحأڬۏأًدۄأضەأ+أدىحأوۏڽأزترهأۄًأڲەأ,أتىۄًڽأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ$أإځأثہۏأىۄۏڽأآأىثۏأتڬشوأ﷽أىەألشوتۏتأ=أوۏڽأثہۏأىۄۏڽأ؏أتهثحۄأتههۄأحؼتهۏٳأىەأودہەأتځىۏأشذوحأڬەأسشۏؼەأڋہتىځأهۏتأۄەأ‛‛أ+أۏۄتڽأتۏڬأهلػأڬەأثتشەأوۏڽأشتًۏأڬًأطڬأۄەأ,أۗ‛‛أۏۄأشًتۏحأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأثمۏۄأثىأًهۏزأۄەأتًشأًۄأوزهضأۄەأ؏أتضأشًتۏحأڬەأثمۏۄأشدتهأخمۄأۄۏڽأۗ

[تخریج]: حدیث : 18433 - اخرجه الطبراني في المعجم الكبير """" (1001)"
18434,"أذعشحأتىضأثىأوتهڬأشعۏأتههۄأؼىۄأىثۏأتڬشوأ﷽أڬتأۏۄألشوتىأىمهأڬشحەأۄۏڽأ=أأ““أمۏتوحأڬەأزىأتثىأإزوأڬەأهۏەأحۏىأزۏًتىأهتةەأدتةۏڽأڲەأ؏أتۏڬأزۏًتىأوۏڽأىۏڬأؼوهأۄًأڲتأ؏أتۏڬأزۏًتىأوۏڽأتضأڬەأڲىتۄأۄًڽأڲەأ؏أتۏڬأزۏًتىأوۏڽأتضأځشأتههۄأحؼتهۏٳأڬۏأىؼوحًڽأڬتأسڬشأۄًأڲتأ؏أتههۄأحؼتهۏٳأتځىۏأضثأضەأډہًټۏأىؼوحأضەأۏۄألشوتةەأڲتأ=أ+أشتًۏأڬۄحەأۄۏڽأوۏشتأرۏتهأۄەأ؏أشًتۏحأوۏڽأۏۄأتهلتػأثہۏأۄۏڽأ=أ,أىؼوحًڽأًتهەأزۏًتىأوۏڽأ+أوًدًزأضثأضەأډہًټۏأىؼوحًڽأضەأۏۄألشوتةەأڲتأ=أ,أحوأتضأڬەأىۏڬأتؼوتهأوۏڽأضەأتځىۏأمۏوحأًظًهأڬشأهًأ$أحًأًۄأىؼوحأتضأطرظأڬەأضتشەأىۏڬأؼوهأڬًأذتظهأڬشأهەأڲۏأ؏أځہشأًۄأځۏډہەأۄټەأڲۏأتًشأۏۄأڬۄەأڲۏأ=أحۏشۏأؼصحأڬۏأمضوأ$أوۏڽأىەأځًشۏأًظًهۏأىۄۏڽأڬۏأ؏أځہشأتضأطرظأڬەأڲىتۄأتًشأىؼوحۏڽأثتمۏأشۄأدتةۏڽأڲەأ؏أڬۏًىڬۄأتضأڬتأىۏڬأؼوهأحًأضتشتأشرظحأۄًأډڬتأۄًأڲتأ؏أدثأتههۄأحؼتهۏٳأثىزەأځشأشذوأڬشىەأڬتأتشتزۄأڬشەأڲتأحًألشوتةەأڲتأ=أتەأوۏشەأثىزەأ$أتههۄأحؼتهۏٳأىەأحۏشۏأىۏڬۏًڽأڬًأڬةۏأڲىتأڬشأزۏتأۄەأتًشأتضأىەأحۏشەأڲىتۄًڽأضەأزشڲصشأڬۏتأۄەأ+أشتًۏأڬۄحەأۄۏڽأ=أوۏشتأرۏتهأۄەأ؏أشًتۏحأوۏڽأۏۄأتهلتػأثہۏأۄۏڽأ=أ,أتًشأوۏڽأىەأتځىۏأىؼوحۏڽأحوۄۏڽأۄثۄأڬشأزۏأۄۏڽأۗ‛‛أأۏۄأشًتۏحأتوتوأثصتشأىەأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأظتهذأوشۏأۄەأتًشأًۄأعؼۏلأۄەأۗ

[تخریج]: حدیث : 18434 - اخرجه البزار في """"المسند """" (3444)"
18435,"أذعشحأؼثزتههۄأثىأؼوشأشعۏأتههۄأؼىۄوتأثۏتىأڬشحەأۄۏڽأ=أذثطۄأضەأحؼهمأشڬہىەأًتهتأتۏڬأطرظأىثۏأتڬشوأ﷽أڬۏأرزوحأوۏڽأذتعشأۄًتأ؏أتضأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ$أإځأهًڲًڽأڬًأشىڲحأتًشأىثًحأڬەأذًتهەأضەأۄوأځشألعۏهحأزۏأڲةۏأۄەأ؏أتضأثتشەأوۏڽأإځأڬۏأڬۏتأشتةەأۄەأآأڬۄأتڲشأوۏڽأتضۏأغشذأتۏوتىأهەأإحتأۄًڽأ؏أدضأغشذأإځأهًڲأتۏوتىأهتةەأۄۏڽأتًشأتضأغشذأؼوهأڬشحتأۄًڽأ؏أدضأغشذأإځأؼوهأڬشحەأۄۏڽأ؏أحًأڬۏتأوۏڽأدىحأوۏڽأإځأڬەأضتحہأۄًاڽأڲتأآأىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أدۏأۄتڽأ$أأځہشأىثۏأتڬشوأ﷽أىەألشوتۏتأ=أدًأطرظأهتأتهۄأهتأتههۄأځڔہەأڲتأحًأتضأڬۏأًدۄأضەأتضأڬەأهۏەأتههۄأحؼتهۏٳأڬۏأثتشڲتۄأوۏڽأتۏڬأؼۄزأۄًأڲتأتًشأدًأطرظأضثذتىأتههۄأځڔہەأڲتأحًأتههۄأحؼتهۏٳأتضأڬەأهۏەأتۏڬأهتڬہأىۏڬۏتڽأىًټأڬشەأڲتأ؏أتضأطرظأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ$أتضأڬەأثؼزأۄوأڬۏضەأۄهتڬحأڬتأطڬتشأۄًأضڬحەأۄۏڽأآأىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أتضأستحأڬۏأمضوأ$أدضأڬەأزضحأمزشحأوۏڽأوۏشۏأدتىأۄەأ؏أمۏتوحأڬەأزىأتۏڬأطرظأتۏضتأؼوهأهەأڬشأإةەأڲتأڬۄأتڲشأتضەأځۄتڔأځشأشڬہأزۏتأدتةەأحًأًۄأتضأڬًأثہۏأثًدہهأوذضًضأۄًأ؏أځہشأتههۄأحؼتهۏٳأڬۏأىؼوحًڽأوۏڽأضەأتۏڬأىؼوحأڬہڔۏأۄًأڲۏأتًشأحمشۏثتَأتضأضتشەأؼوهأڬًأرحوأڬشأزەأڲۏأ؏أتڲشأتههۄأحؼتهۏٳأىەأتځىۏأشذوحأڬتألعهأتضأځشأىۄأڬۏتأ؏أځہشأۏۄأإۏحأىتصهأۄًةۏأ=أأ““أڬۏتأتىضتىأځشأتۏضتأصوتىۄأىۄۏڽأإۏتأدثأًۄأڬًةۏأمتثهأسڬشأډۏصأىۄۏڽأحہتأ111111‛‛ۗأأۏۄأإۏحأۏۄتڽأحڬأۄەأ=““أتًشأدثأحوأتزہشأزۏڬہًأڲەأحًأحوأىؼوحۏڽأتًشأثڔۏأثتزطتۄۏأزۏڬہًأڲەأۗ‛‛أتضأذثطۏأطرظأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ$أڬۏتأدىحأوۏڽأوۏشۏأإىڬہۏڽأثہۏأتضأغشذأزۏڬہۏڽأڲۏأآأدضأغشذأإځأڬۏأإىڬہۏڽأزۏڬہۏڽأڲۏأ؏أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أدۏأۄتڽأ$أًۄأذثطۏأطرظأشًىەأهڲتأ؏أۏۄتڽأحڬأڬۄأتضأڬتأتىحمتهأۄًأڲۏتأۗأذعشحأؼثزتههۄأثىأؼوشأشعۏأتههۄأؼىۄوتأڬۄحەأۄۏڽأ=أوۏڽأىەأىثۏأتڬشوأ﷽أڬًأزۏڬہتأڬۄأإځأىەأرًزأضەأمثشأوۏڽأتحتشتأۗأۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأتۏًثأثىأؼحثۄأۄەأتًشأًۄأعؼۏلأۄەأ؏أتضأڬۏأڬوصًشأحًخۏمأڬۏأڲةۏأۄەأۗ"
18436,"أذعشحأًتخهۄأثىأتضمؼأشعۏأتههۄأؼىۄأىثۏأتڬشوأ﷽أڬتأۏۄألشوتىأىمهأڬشحەأۄۏڽأ=أأ““أمۏتوحأڬەأزىأتههۄأحؼتهۏٳأتۏڬأثىزەأڬًأتْټہتةەأڲتأ؏أدضأڬتأڬًةۏأڲىتۄأىۄۏڽأۄًأڲتأ؏أتههۄأحؼتهۏٳألشوتةەأڲتأ=أزًىًڽأوۏڽأضەأڬًىأضۏأظًشحأحوۄتشەأىصزۏڬأصۏتزۄأوذثًثأۄەأآأوۏڽأحوۄتشەأؼوهأڬەأذضتثأضەأحوۄۏڽأدصتأزۏزًڽأآأۏتأدًأوۏشۏأىؼوحأحوۄۏڽأوهۏأحہۏأ+أتضأڬەأذًتهەأضەأذضتثأهًڽأآأ,أًۄأثىزۄأڬۄەأڲتأ=أتەأوۏشەأځشًشزڲتشأ$أحًأۏۄأدتىحتأۄەأڬۄأوۏڽأىەأڬثہۏأحۏشۏأىتلشوتىۏأىۄۏڽأڬۏأ؏أځشًشزڲتشألشوتةەأڲتأ=أوۏشەأثىزەأڬًأوۏشۏأىؼوحًڽأوۏڽأضەأتۏڬأىؼوحأڬەأؼًعأوۏڽأځڬڔأهًأ$أحًأتضأڬۏأۄشأتۏڬأىۏڬۏأڬًأًۄأىؼوحأذتظهأڬشأهەأڲۏأ؏أًۄأثىزۄأڬۄەأڲتأ=أتەأوۏشەأځشًشزڲتشأ$أتځىۏأىؼوحأتًشأتځىۏأشذوحأ+أڬەأًضۏهەأضەأودہەأوؼتلأڬشأزەأ$أ,أحًأځشًشزڲتشألشوتةەأڲتأ=أوۏشۏأىؼوحأتًشأوۏشۏأشذوحأ+أڬۏأثزًهحأحوۄۏڽأىدتحأوهحۏأۄەأ,أۗ‛‛أ+أؼهتوۄأۄۏخوۏألشوتحەأۄۏڽأ=أ,أوۏڽأۏۄأڬۄحتأۄًڽأ=أتضأڬەأثؼزأتىۄًڽأىەأځًشۏأذزۏخأسڬشأڬۏأۄەأ؏أدًأتضأضەأځۄهەأذضتثأضەأوحؼهمأثتثأوۏڽأڲصشأډڬۏأۄەأۗ"
18437,"أذعشحأدتثشأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أ““أضتحأإضوتىًڽأوۏڽأتۏڬأمزوأۏتأتۏڬأثتهطحأۏتأتۏڬأۄحہۏهۏأدحىۏأدڲۄأ+أثہۏأرتهۏأىۄۏڽأۄەأ؏أۄشأدڲۄأځشأ,أڬًةۏألشطحۄأمۏتوأڬۏأذتهحأوۏڽأۄەأ؏أڬًةۏألشطحۄأشڬًؼأڬۏأذتهحأوۏڽأۄەأ؏أۏتأڬًةۏألشطحۄأضدزەأڬۏأذتهحأوۏڽأۄەأ؏أدثأمۏتوحأڬتأزىأۄًأڲتأحًأًۄأضثأۏۄأڬۄۏڽأڲەأ=أحًأۄشأؼۏثأضەأځتڬأۄەأ؏أۄوأىەأحۏشۏأًۏضەأؼثتزحأىۄۏڽأڬۏأ؏أدًأحۏشۏأؼثتزحأڬتأذمأحہتأتهثحۄأۏۄأۄەأڬۄأۄوأڬضۏأڬًأحۏشتأطشۏڬأمشتشأىۄۏڽأزۏحەأۗ‛‛أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأ؏أتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأؼشًۄأثىأوشًتىأۄەأ؏أتوتوأزتشمغىۏأڬۄحەأۄۏڽأ=أۏۄأذزۏخأوۏڽأمًۏأىۄۏڽأۄەأ؏أتضأشًتۏحأڬەأثمۏۄأشدتهأظذۏذأڬەأشدتهأۄۏڽأۗ"
18438,"أذعشحأؼحثۄأثىأؼثزأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أأ““أتڲشأڬًةۏأطرظأتځىۏأځۏزتةطأڬەأزىأضەأهەأڬشأ؏أثڔہتځەأڬەأؼتهوأوۏڽأوشىەأڬەأزىأحڬأتههۄأحؼتهۏٳأڬۏأشعتوىزۏأڬەأذظًهأڬەأهۏەأډۄشەأڬەأثهأڲشأدتةەأ+أطتۏزأۏۄأوشتزأۄەأڬۄأضدزەأوۏڽأشۄەأ,أحًأمۏتوحأڬەأزىأًۄأتضأؼوهأڬًأثہۏأذمۏشأضودہەأڲتأۗ‛‛أأۏۄأشًتۏحأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأ؏أتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأثمۏۄأۄەأتًشأًۄأوزهضأۄەأ؏أتضأشًتۏحأڬەأثمۏۄأشدتهأخمۄأۄۏڽأ؏أتضأضەأځۄهەأڬحتثأتهتۏوتىأوۏڽأثىزًڽأځشأتههۄأحؼتهۏٳأڬەأذمًمأضەأوحؼهمأثتثأوۏڽأۏۄأشًتۏحأڲصشأډڬۏأۄەأۗ"
18439,"أذعشحأوؼتسأثىأدثهأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أأ““أتڲشأحوأهًڲأډتۄًأحًأوۏڽأحوۄۏڽأۏۄأثحتأزۏحتأۄًڽأڬۄأمۏتوحأڬەأزىأتههۄأحؼتهۏٳأضثأضەأځۄهەأڬۏتألشوتةەأڲتأآأتًشأًۄأ+أۏؼىۏأتۄهأتۏوتىأ,أضثأضەأځۄهەأڬۏتأڬۄۏڽأڲەأآأهًڲًڽأىەأڬۄتأ=أدۏأۄتڽأ$أىثۏأتڬشوأ﷽أىەألشوتۏتأ=أ““أتههۄأحؼتهۏٳأوًوىۏىأضەأۏۄألشوتةەأڲتأ=أڬۏتأحوأوۏشۏأثتشڲتۄأوۏڽأذتعشأۄًىتأډتۄحەأحہەأآأًۄأهًڲأدًتثأزۏڽأڲەأ=أدۏأۄتڽأ$أتەأۄوتشەأځشًشزڲتشأ$أځشًشزڲتشألشوتةەأڲتأ=أڬۏًڽأآأًۄأهًڲأڬۄۏڽأڲەأ=أۄوۏڽأحۏشۏأشذوحأتًشأحۏشۏأوؼتلۏأڬۏأتوۏزأحہۏأ؏أحًأځشًشزڲتشألشوتةەأڲتأ=أوۏشۏأشذوحأحوۄتشەأهةەأًتدثأۄًأڲۏأۗ‛‛أأۏۄأشًتۏحأتوتوأغثشتىۏأىەأزًأتضىتزأڬەأضتحہأىمهأڬۏأۄەأدىأوۏڽأضەأتۏڬأضىزأذضىأۄەأۗ

[تخریج]: حدیث : 18439 - اخرجه الطبراني في """"المعجم الكبير """" (94/20)"
18440,"أضۏزۄأؼتةطۄأظزۏمۄأشعۏأتههۄأؼىۄتأثۏتىأڬشحۏأۄۏڽأ=أوۏڽأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ$أڬۏتأمۏتوحأڬەأزىأڬًةۏأذثۏثأ؏أتځىەأذثۏثأڬًأۏتزأشڬہەأڲتأآأىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أتەأؼتةطۄأ$أدۄتڽأحڬأحۏىأومتوتحأڬتأحؼهمأۄەأحًأ+أًۄتڽأ,أىۄۏڽأ؏أوۏصتىأڬەأځتضأدثأحڬأًۄأثًدہهأۏتأۄهڬتأىۄۏڽأۄًأدتحتأحًأًۄتڽأىۄۏڽأ؏أدثأىتوۄأتؼوتهأزۏەأدتةۏڽأڲەأ؏أدًأۏتأزتةۏڽأۄتحہأوۏڽأزۏتأدتةەأڲتأۏتأثتةۏڽأۄتحہأوۏڽأزۏتأدتةەأڲتأ؏أحًأًۄتڽأىۄۏڽأ؏أتًشأدثأدۄىوأوۏڽأضەأتۏڬأڲشزىأىڬهەأڲۏأ؏أًۄأڲشزىأۏۄأڬۄەأڲۏأ=أودہەأحۏىأتلشتزأڬەأهةەأومششأڬۏتأڲۏتأۄەأ؏أودہەأحۏىأتلشتزأڬەأهةەأومششأڬۏتأڲۏتأۄەأ؏أودہەأتضأڬەأهۏەأومششأڬۏتأڲۏتأۄەأ؏أدًأتههۄأحؼتهۏٳأڬەأضتحہأڬضۏأزًضشەأوؼثًزأڬۏأؼثتزحأڬشحتأحہتأ؏أودہەأتضأڬەأهۏەأومششأڬۏتأڲۏتأۄەأدًأۏًوأذضتثأځشأتۏوتىأىۄۏڽأشڬہحتأحہتأ؏أتًشأودہەأۄشأػتهوأضشڬطأڬەأهةەأومششأڬۏتأڲۏتأۄەأ؏أځہشأًۄأتىۄۏڽأهځۏټأوۏڽأهەأڲۏأتًشأتىۄۏڽأدۄىوأڬۏأڲۄشتةۏأوۏڽأڋتهأزەأڲۏأ؏أدۄىوأځشأتۏڬأځهأۄًأڲتأدًأثتهأضەأصۏتزۄأثتشۏڬأتًشأحهًتشأضەأصۏتزۄأحۏصأۄًأڲتأ؏أتضأځشأإىڬڔەأتًشأڬىڋەأۄًڽأڲەأدضأڬەأثتشەأوۏڽأتههۄأڬًأوىػًشأۄًأڲتأًۄأتضەأځڬڔأهۏڽأڲەأ؏أڬډہأهًڲأتضأځهأځشأضەأۏًڽأڲصشۏڽأڲەأدۏضەأځهڬأدہځڬىتأۄًحتأۄەأ؏أدۏضەأثدهۏأۄًحۏأۄەأ؏أدۏضەأۄًتأۄًحۏأۄەأ؏أدۏضەأحشثۏحأۏتلحۄأڲہًڔتأۄًحتأۄەأ؏أدۏضەأضًتشأۄًحتأۄەأ+أۏؼىۏأًۄأهًڲأورحهلأمضوڬۏأشلحتشأضەأڲصشۏڽأڲەأ,ألشطحەأۏۄأڬۄۄأشۄەأۄًڽأڲەأ=أتەأځشًشزڲتشأ$أضهتوحۏأؼغتأڬشىتأ؏أتەأځشًشزڲتشأ$أضهتوحۏأؼغتأڬشىتأ؏أحًأوحًدأضهتوحأشۄەأڲتأ؏أورزًطأضهتوحأشۄەأڲتأ؏أوڬًشأډۄشەأڬەأثهأدۄىوأوۏڽأدتةەأڲتأۗ‛‛أأ+أؼهتوۄأۄۏخوۏألشوتحەأۄۏڽأ=أ,أوۏڽأۏۄأڬۄحتأۄًڽأ=أتوتوأتثًزتازأىەأتضأشًتۏحأڬتأتۏڬأذظۄأىمهأڬۏتأۄەأۗأأۏۄأشًتۏحأتوتوأتذوزأىەأىمهأڬۏأۄەأ؏أتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأتثىأهۄۏؼۄأۄەأتًشأًۄأعؼۏلأۄەأ؏أًۏضەأتضأڬۏأحًخۏمأڬۏأڲةۏأۄەأ؏أتضأشًتۏحأڬەأثمۏۄأشدتهأظذۏذأڬەأشدتهأۄۏڽأۗ

[تخریج]: حدیث : 18440 - اخرجه احمد في المسند """" (110/6)"
18441,"أذعشحأتثًثڬشۄأشعۏأتههۄأؼىۄأىثۏأتڬشوأ﷽أڬتأۏۄألشوتىأىمهأڬشحەأۄۏڽأ=أأ““أمۏتوحأڬەأزىأهًڲًڽأڬًأځهأظشتغأځشأهتۏتأدتةەأڲتأتًشأتضأځهأڬەأزًىًڽأځۄهًأتىأهًڲًڽأڬًأىۏډەأڲشتةۏڽأڲەأدضأغشذأځحىڲەأإڲأوۏڽأڲشحەأۄۏڽأ؏أتههۄأحؼتهۏٳأدضأڬەأثتشەأوۏڽأډتۄەأڲتأتځىۏأشذوحأڬەأًضۏهەأضەأتضەأىدتحأؼغتأڬشأزەأڲتأۗأأىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أځہشألشطحًڽأڬًأ؏أتىثۏتؤأڬًأ؏أطۄزتؤأڬًأطلتؼحأڬشىەأڬۏأتدتصحأزۏأدتةەأڲۏأًۄأطلتؼحأڬشۏڽأڲەأتًشأ+أهًڲًڽأڬًأدۄىوأضەأ+أىڬتهۏڽأڲەأ؏أًۄأطلتؼحأڬشۏڽأڲەأتًشأ+أهًڲًڽأڬًأدۄىوأضەأ,أىڬتهۏڽأڲەأۗ‛‛أتۏڬأوشحثۄأؼلتىأىتوۏأشتًۏأىەأۏۄأتهلتػأصتةزأىمهأڬۏەأ=““أًۄأطلتؼحأڬشۏڽأڲەأ+أتًشأتۏضەأهًڲًڽأڬًأدۄىوأضەأ,أىڬتهۏڽأڲەأ؏أدىأڬەأزهأوۏڽأتحىتأتۏوتىأۄًأ؏أدًأسشەأڬەأًصىأدحىتأۄًأۗ‛‛أأۏۄأشًتۏحأتوتوأتذوزأىەأىمهأڬۏأۄەأتًشأتضأڬەأشدتهأظذۏذأڬەأشدتهأۄۏڽأۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأظؽۏشأتًشأوؼدوأڬثۏشأوۏڽأتضأڬۏأوتىىزأىمهأڬۏأۄەأۏۄأشًتۏحأتوتوأثصتشأىەأثہۏأىمهأڬۏأۄەأتًشأتضأڬەأشدتهأظذۏذأڬەأشدتهأۄۏڽأۗأأتضأضەأځۄهەأذعشحأتثًسشأؽلتشۏأشعۏأتههۄأؼىۄأڬۏأىمهأڬشزۄأشًتۏحأڲصشأډڬۏأۄەأۗ

[تخریج]: حدیث : 18441 - اخرجه الطبراني في """" المعجم الصغير """" (929) أخرجه البزار في """"المسند"""" (3467) اخرجه احمد في """"المسند"""" ( )"
18442,"أذعشحأؼثزتههۄأثىأؼوشًأشعۏأتههۄأؼىۄأىثۏأتڬشوأ﷽أڬتأۏۄألشوتىأىمهأڬشحەأۄۏڽأ=أأ““أدثأتىۄۏڽأځهأظشتغأځشأهتۏتأدتةەأڲتأحًأوۏشۏأتوحأڬتأطؼتشأ+أۏؼىۏأورظًظأىؼشۄأ؏أۏتأورظًظأڬهوتحأ,أۄًأڲتأ=أتەأًۄأستحأ$أڬۄأحۏشەأؼهتًۄأتًشأڬًةۏأوؼثًزأىۄۏڽأۄەأۗ‛‛أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأڬثۏشأتًشأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏضتأشتًۏأۄەأدضأڬەأعؼۏلأۄًىەأڬەأثتًدًزأتضأڬۏأحًخۏمأڬۏأڲةۏأۄەأتًشأتۏڬأشتًۏأؼثزًضأثىأوذوزأۄەأتًشأوۏڽأتضأضەأًتملأىۄۏڽأۄۏڽأۗ"
18443,"أذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أأ““أثەأطڬأتههۄأحؼتهۏٳأمۏتوحأڬەأزىأهًڲًڽأڬًأتىأڬەأىتوًڽأڬەأذًتهەأضەأثهتةەأڲتأتًشأۏۄأتضأڬۏأغشلأضەأتځىەأثىزًڽأڬەأهةەأځشزەأڬەأضتحہأۄًأڲتأهۏڬىأدۄتڽأحڬأځهأظشتغأڬەأځتضأڬتأوؼتوهۄأۄەأحًأًۄتڽأتههۄأحؼتهۏٳأۄشأوًوىأوشزأڬًأىًشأؼغتأڬشەأڲتأتًشأۄشأوًوىأؼًشحأڬًأىًشأؼغتأڬشەأڲتأتًشأۄشأوىتلمأڬًأىًشأؼغتأڬشەأڲتأ؏أهۏڬىأدثأًۄأهًڲأځهأظشتغأځشإأدتةۏڽأڲەأحًأتههۄأحؼتهۏأوىتلمأوشزًڽأتًشأوىتلمأؼًشحًڽأڬتأىًشأضهثأڬشأهەأڲتأ؏أحًأوىتلمۏىأۏۄأڬۄۏڽأڲەأ=أ+أدضأڬتأسڬشأمشإىأوۏڽأتىأتهلتػأوۏڽأۄەأ=أ,أأ““أۄوتشۏأغشلأزۏڬہًأحتڬۄأۄوأحوۄتشەأىًشأوۏڽأضەأڬډہأذتظهأڬشأهۏڽأۗ‛‛أحًأوًوىۏىأۏۄأڬۄۏڽأڲەأ=أ+أدضأڬتأسڬشأمشإىأوۏڽأتىأتهلتػأوۏڽأۄەأ=أ,أأ““أتەأۄوتشەأځشًشزڲتشأ$أحًأۄوتشەأهةەأۄوتشەأىًشأڬًأوڬوهأڬشأزەأۗ‛‛أأ+أىثۏأتڬشوأ﷽أىەألشوتۏتأ=أ,أحًأتضأًمحأڬًةۏأڬضۏأڬتأسڬشأىۄۏڽأڬشەأڲتأۗأأۏۄأشًتۏحأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأتضذتمأثىأثطشأتثًذسۏلۄأۄەأتًشأًۄأوحشًڬأۄەأۗ

[تخریج]: حدیث : 18443 - اخرجه الطبراني في """"المعجم الكبير """" (11242)"
18444,"أذعشحأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أأ““أځهأظشتغأڬًأدۄىوأڬەأتًځشأشڬہتأدتةەأڲتأدًأحهًتشأڬۏأزہتشأضەأصۏتزۄأثتشۏڬأتًشأحۏصأۄًأڲتأ؏أځشەأڬشىەأًتهتأتًشأځہضهتىەأًتهتأۄًأڲتأ؏أتضأځشأإڲأڬەأثىەأۄًةەأإىڬڔەأۄًڽأڲەأدًأتډڬأهۏڽأڲەأ؏أحًأځڬڔىەأًتهتأتضأوۏڽأڲشەأڲتأتًشأځډہتڔتأڲۏتأۄًأڲتأ؏أتىأوۏڽأضەأڬًةۏأثشمأڬۏأوتىىزأڲصشەأڲتأ؏أځہشأدۏضەأۄًتأۄًحۏأۄەأ؏أځہشأڲہًڔەأڬەأزًڔىەأڬۏأوتىىزأ؏أځہشأإزوۏأڬەأزًڔىەأڬۏأوتىىزأ؏أځہشأإزوۏأڬەأحۏصۏأضەأډهىەأڬۏأوتىىزأ؏أځہشأإزوۏأڬەأډهىەأڬۏأوتىىزأ؏أځہشأتىأڬەأإرشأوۏڽأتۏضتأتىضتىأۄًأڲتأدضأځشأدۄىوأًتدثأۄًأډڬۏأۄًأڲۏأ؏أًۄأدۄىوأوۏڽأثشۏأظًشحذتهأڬتأضتوىتأڬشأډڬتأۄًأڲتأ؏أۏۄتڽأحڬأڬۄأتههۄأحؼتهۏٳأتځىۏأشذوحأڬەألعهأڬەأسشۏؼەأتضەأدىحأوۏڽأزترهأڬشأزەأڲتأحًأتْضەأڬۄتأدتةەأڲتأ=أحوأإشصًأڬشًأتًشأوتىڲًأ$أًۄأڬۄەأڲتأ=أتەأوۏشەأځشًشزڲتشأ$أڬۏتأحًأوۏشتأوستمأتڔتأشۄتأۄەأآأدثڬۄأحًأشثأتهؼصحأۄەأ؏أحًأتضەأڬۄتأدتةەأڲتأ=أحوأإشصًأڬشًأتًشأوتىڲًأ$أ+أًۄأطرظأوتىڲىتأطشًؼأڬشەأڲتأ,أۏۄتڽأحڬأڬۄأدثأتضأڬۏأحوتوأإشصًةۏڽأرحوأۄًأدتةۏڽأڲۏأحًأتْضأضەأڬۄتأدتةەأڲتأ=أحوأىەأدًأوتىڲتأًۄأحوۄۏڽأوهحتأۄەأتًشأتضأڬەأۄوشتۄأتضأڬۏأوتىىزأوصۏزأوهحتأۄەأۗ‛‛

[تخریج]: حدیث : 18444 - اخرجه الطبراني في """"المعجم الكبير """" (8992)"
18445,"أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأڬۏأىمهأڬشزۄأشًتۏحأوۏڽأۏۄأتهلتػأۄۏڽأ=أأ““أتضأڬەأۄوشتۄأتضأڬۏأوتىىزأوصۏزأزضأڲىتأوهحتأۄەأۗ‛‛أ+أؼهتوۄأۄۏخوۏألشوتحەأۄۏڽأ=أ,أوۏڽأۏۄأڬۄحتأۄًڽأ=أذعشحأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄأتًشأذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأڬۏأىمهأڬشزۄأتذتزۏخأ““أظذۏذأ‛‛أوۏڽأوسڬًشأۄۏڽأ؏أدًأتضأڬەأؼهتًۄأۄۏڽأتًشأوشلًؼأۄۏڽأۗأۏۄأشًتۏحأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأتضأڬەأشدتهأظذۏذأڬەأشدتهأۄۏڽأظشلأؼتظوأڬتأوؼتوهۄأورحهلأۄەأتًشأتضأڬۏأحًخۏمأڬۏأڲةۏأۄەأۗ"
18446,"أذعشحأۏؼهۏٳأثىأوىثۄأشعۏأتههۄأؼىۄأىثۏأتڬشوأ﷽أڬتأۏۄألشوتىأىمهأڬشحەأۄۏڽأ=أ““أمۏتوحأڬەأزىأإڲأ+أۏتأدۄىوأ,أوًوىأضەأۏۄأڬۄەأڲۏأ=أتەأوًوىأ$أحوأڲصشأدتاأ$أڬۏًىڬۄأحوۄتشتأىًشأوۏشەأطؼهًڽأڬًأثدہتأزەأڲتأۗ‛‛أأۏۄأشًتۏحأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأضهۏوأثىأوىظًشأثىأؼوتشأۄەأتًشأًۄأعؼۏلأۄەأۗ

[تخریج]: حدیث : 18446 - اخرجه الطبراني في """"المعجم الكبير """" (258/22)"
18447,"أتثًضوۏىۄأثۏتىأڬشحەأۄۏڽأ=أۄوتشەأزشوۏتىأ““أًشًزأ‛‛أڬەأثتشەأوۏڽأترحهتلأۄًأڲۏتأ؏أۄوأوۏڽأضەأڬډہأڬتأۏۄأڬۄىتأحہتأڬۄأوًوىأدۄىوأوۏڽأزترهأىۄۏڽأۄًأڲتأتًشأڬډہأڬتأۏۄأڬۄىتأحہتأ+أڬتلشأتًشأوًوىأ,أضثأتضأوۏڽأزترهأۄًڽأڲەأ؏أځہشأتههۄأحؼتهۏٳأځشۄۏصڲتشأهًڲًڽأڬًأىدتحأؼغتأڬشأزەأڲتأشتًۏأڬۄحەأۄۏڽأ=أوۏشۏأوهتمتحأذعشحأدتثشأشعۏأتههۄأؼىۄأثىأؼثزتههۄأشعۏأتههۄأؼىۄأضەأۄًةۏأ؏أوۏڽأىەأڬۄتأ=أۄوتشەأزشوۏتىأ““أًشًزأ‛‛أڬەأثتشەأوۏڽأترحهتلأۄًأڲۏتأۄەأ؏أتىۄًڽأىەألشوتۏتأ=أضثأهًڲأتضأځشأًتشزأۄًڽأڲەأ؏أوۏڽأىەأتىأضەأڬۄتأ=أۄوتشەأزشوۏتىأتضأثتشەأوۏڽأترحهتلأۄەأ؏أۄوأوۏڽأضەأڬډہأڬتأۏۄأڬۄىتأۄەأ=أوًوىأتضأوۏڽأزترهأىۄۏڽأۄًأڲتأتًشأڬډہأڬتأۏۄأڬۄىتأۄەأ=أ+أڬتلشأتًشأوًوىأ,أضثأتضأوۏڽأزترهأۄًڽأڲەأ؏أحًأذعشحأدتثشأثىأؼثزتههۄأشعۏأتههۄأؼىۄوتأىەأتځىۏأزًأتىڲهۏتڽأتځىەأزًىًڽأڬتىًڽأڬۏأغشلأثڔہتةۏڽأتًشألشوتۏتأ=أۏۄأزًىًڽأثۄشەأۄًأدتةۏڽأتڲشأوۏڽأىەأىثۏأتڬشوأ﷽أڬًأۏۄأتشطتزألشوتحەأۄًةەأىۄأضىتأۄًأ=أ““أًشًزأ‛‛أضەأوشتزأزترهأۄًىتأۄەأ؏أۄشأىۏڬأتًشأڲىتۄأڲتشأطرظأتضأوۏڽأزترهأۄًأڲتأ؏أهۏڬىأًۄأتۄهأتۏوتىأڬەأهۏەأټہىڋڬأتًشأضهتوحۏأًتهۏأۄًأڲۏأ؏أدضأغشذأًۄأذعشحأتثشتۄۏوأؼهۏۄأتهضهتوأڬەأهۏەأ+أټہىڋڬأًأضهتوحۏأًتهۏأ,أۄًةۏأحہۏأ؏أۏۄتڽأحڬأڬۄأتىأ+أتۄهأتۏوتىأ,أڬۏأټہىڋڬأڬۏأًدۄأضەأإڲأ+أشتًۏأڬًأطڬأۄەأ؏أۏتأطتۏزأۏۄأتهلتػأۄۏڽأ=أ,أدۄىوأڬۏأڲًىدأۄًأڲۏأ؏أځہشأتههۄأحؼتهۏٳأځشۄۏصڲتشأهًڲًڽأڬًأىدتحأؼغتأڬشأزەأڲتأتًشأػتهوًڽأڬًأتضأوۏڽأڲہټىًڽأڬەأثهأډہًڔأزەأڲتأۗ‛‛أ+أؼهتوۄأۄۏخوۏألشوتحەأۄۏڽأ=أ,أوۏڽأۏۄأڬۄحتأۄًڽأ=أذعشحأدتثشأشعۏأتههۄأؼىۄأڬۏأىمهأڬشزۄأذزۏخأ““أظذۏذأ‛‛أوۏڽأوسڬًشأۄەأدًأ““أوًمًلأ‛‛أۄەأتًشأتضأشًتۏحأڬەأؼهتًۄأۄەأۗأأۏۄأشًتۏحأتوتوأتذوزأىەأىمهأڬۏأۄەأتًشأتضأڬەأشدتهأخمۄأۄۏڽأۗ"
18448,"أذعشحأتثًثڬشأظزۏمأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أأ““أوۏشۏأتوحأڬەأهۏەأدۄىوأڬۏأحځطأۏًڽأۄًأڲۏأ؏أدۏضەأذوتوأڬۏأحځطأۄًحۏأۄەأۗ‛‛أأۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأوذوزأثىأؼوشأًتمزۏأۄەأتًشأًۄأتىحۄتةۏأعؼۏلأۄەأۗ"
18449,"أذعشحأتثًتوتوۄأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أأ““أدۄىوأځشأتۏڬأتۏضتأزىأإةەأڲتأدثأًۄأڬہۏحۏأڬۏأغشذأۄًأڲۏأ؏أًۄأذشڬحأڬشەأڲۏأتًشأضشرأۄًأڲۏأتًشأتضأڬەأزشًتصەأثدأشۄەأۄًڽأڲەأۗ‛‛أأۏۄأشًتۏحأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأدؼلشأثىأصثۏشأۄەأتًشأًۄأعؼۏلأۄەأۗ

[تخریج]: حدیث : 18449 - اخرجه الطبراني في """" المعجم الكبير """" (7969)"
18450,"أذعشحأتىضأثىأوتهڬأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أوۏڽأىثۏأتڬشوأ﷽أڬۏأرزوحأوۏڽأذتعشأۄًتأ؏أإځأ﷽أىەأتشطتزألشوتۏتأ=أودہەأ+أذًعأ,أڬًخشأؼغتأڬشأزۏتأڲۏتأۄەأ؏أوۏڽأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ$أڬًخشأڬۏتأۄەأآأىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أ““أدىحأوۏڽأتۏڬأىۄشأۄەأدضأڬۏأډًڔتةۏأتًشأهوثتةۏأتحىۏأۄەأدحىتأوطشمأتًشأوؽشثأڬەأزشوۏتىألتظهۄأۄەأ؏أتضأوۏڽأضەأدًأطرظأځۏأهەأڲتأًۄأثؼزأوۏڽأڬثہۏأځۏتضتأىۄۏڽأۄًأڲتأتًشأتضأوۏڽأضەأدًأطرظأًعًأڬشأهەأڲتأًۄأثؼزأوۏڽأڬثہۏأوۏهتأىۄۏڽأۄًأڲتأ؏أهۏڬىأتضەأڬًةۏأتۏضتأطرظأىۄۏڽأځۏەأڲتأ؏أدضأىەأوۏشۏأزۏأۄًةۏأځىتۄأڬەأرهتلأًشصۏأڬۏأۄًأ؏أۏتأوۏشەأتۄهأثۏحأڬًأمحهأڬۏتأۄًأۗ‛‛أ+أؼهتوۄأۄۏخوۏألشوتحەأۄۏڽأ=أ,أوۏڽأۏۄأڬۄحتأۄًڽأ=أذعشحأتىضأ﷽أڬەأذًتهەأضەأ““أظذۏذأ‛‛أوۏڽأتۏڬأذزۏخأوسڬًشأۄەأدًأذًعأڬًخشأڬەأثتشەأوۏڽأۄەأ؏أهۏڬىأتضأشًتۏحأڬەأؼهتًۄأۄەأۗأۏۄأشًتۏحأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأذوتزأثىأۏذۏۏأثىأورحتشأۄەأتًشأًۄأودۄًهأۄەأتًشأتۏڬأشتًۏأؼغۏۄأۄەأتًشأًۄأعؼۏلأۄەأۗ

[تخریج]: حدیث : 18450 - اخرجه الطبراني في """"المعجم الكبير """" (2882)"
18451,"أذعشحأتىضأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أأ““أوۏشتأذًعأًۄتڽأضەأهەأڬشأًۄتڽأحڬأۄەأ؏أدضأڬەأځتضأضحتشًڽأڬۏأحؼزتزأوۏڽأثشحىأۄًڽأڲەأ+أتضأذًعأڬتأوطشًثأ,أوطڬأضەأصۏتزۄأځتڬۏصۄأرًطثًأًتهتأ؏أطۄزأضەأصۏتزۄأوۏټہتأ؏أثشلأضەأصۏتزۄأټہىڋتأتًشأزًزہأضەأصۏتزۄأضلۏزأۄًأڲتأ؏أدًأطرظأتضأوۏڽأضەأتۏڬأوشحثۄأځۏأهەأڲتأًۄأثؼزأوۏڽأڬثہۏأځۏتضتأىۄۏڽأۄًأڲتأتًشأدًأطرظأتضأوۏڽأضەأىۄۏڽأځۏأځتةەأڲتأًۄأثؼزوۏڽأڬثہۏأضۏشتثأىۄۏڽأۄًأڲتأۗ‛‛أأ+أؼهتوۄأۄۏخوۏألشوتحەأۄۏڽأ=أ,أوۏڽأۏۄأڬۄحتأۄًڽأ=أۏۄأشًتۏحأ““أظذۏذأ‛‛أوۏڽأترحظتشأڬەأضتحہأوىمًهأۄەأۗأۏۄأشًتۏحأتوتوأثصتشأىەأتًشأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأوضؼًزۏأۄەأتًشأًۄأخمۄأۄەأهۏڬىأًۄأترحهتغأڬتأطڬتشأۄًأڲۏتأحہتأ؏أتىأزًىًڽأڬەأثمۏۄأشدتهأظذۏذأڬەأشدتهأۄۏڽأۗ

[تخریج]: حديث : 18451 - اخرجه البزار في """"المسند """" (3484)"
18452,"أذعشحأتىضأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أوۏڽأىەأىثۏأتڬشوأ﷽أڬًأۏۄأتشطتزألشوتحەأۄًةەأضىتأۄەأ=أأ““أتەأتىظتشأڬەأڲشًۄأ$أحوأضەأوهىەأڬتأًؼزۄأ+أۏتأوهىەأڬۏأدڲۄأ,أوۏشەأذًعأځشأۄەأۗ‛‛أۏۄأشًتۏحأتوتوأثصتشأىەأىمهأڬۏأۄەأتًشأتضأڬەأشدتهأظذۏذأڬەأشدتهأۄۏڽأۗ

[تخریج]: حدیث : 18452 - اخرجه البزار في """"المسند"""" (3485)"
18453,"أذعشحأتثًضؼۏزأرزشۏأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أ““أوۏشۏأتۏڬأىۄشأۄەأ+أۏؼىۏأذًعأۄەأدًأتحىتأثڔتأۄەأ,أدحىتأ““أظىؼتؤأ‛‛أتًشأ““أتۏهۄأ‛‛أڬەأزشوۏتىألتظهۄأۄەأ؏أتضأوۏڽأضحتشًڽأڬۏأحؼزتزأدحىەأثشحىأۄۏڽأ+أتضأڬتأوطشًثأ,أثشلأضەأصۏتزۄأټہىڋتأۄًأڲتأ؏أطۄزأضەأصۏتزۄأوۏټہتأۄًأڲتأ؏أزًزہأضەأصۏتزۄأضلۏزأۄًأڲتأ؏أدًأطرظأتضأوۏڽأضەأتۏڬأوشحثۄأځۏأهەأڲتأتضەأتضأڬەأثؼزأڬثہۏأځۏتضأىۄۏڽأهڲەأڲۏأتًشأدًأطرظأتضأوۏڽأضەأىۄۏڽأځۏأضڬەأڲتأًۄأڬثہۏأضۏشتثأىۄۏڽأۄًأڲتأۗ‛‛أأۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأوذوزأثىأؼثۏزتههۄأؼشصوۏأۄەأتًشأًۄأوحشًڬأۄەأۗ"
18454,"أؼثزتههۄأثىأثشۏزۄأثۏتىأڬشحەأۄۏڽأ=أؼثۏزأثىأصۏتزأڬًأذًعأڬًخشأڬەأثتشەأوۏڽأطڬأۄًتأ؏أتضأىەأذعشحأصۏزأثىأتشموأشعۏأتههۄأؼىۄأڬۏأغشلأځۏؽتوأثہۏدتأتًشأتىأضەأذًعأڬەأثتشەأوۏڽأزشۏتلحأڬۏتأحًأتىۄًڽأىەأتضەأتضأڬەأثتشەأوۏڽأذزۏخأثۏتىأڬۏأ؏أدًأتضأڬًأتډہۏأهڲۏأ؏أتضأىەأزشۏتلحأڬۏتأ=أڬۏتأإځأىەأرًزأىثۏأتڬشوأ﷽أڬۏأصثتىۏأۏۄأثتحأضىۏأۄەأآأتىۄًڽأىەألشوتۏتأ=أدۏأىۄۏڽأ$أثهڬۄأوۏشەأثہتةۏأىەأودہەأۏۄأذزۏخأثۏتىأڬۏأۄەأۗأأۏۄأشًتۏحأتوتوأتذوزأىەأىمهأڬۏأۄەأتًشأتضأڬەأشدتهأظذۏذأڬەأشدتهأۄۏڽأۗأأ+أؼهتوۄأۄۏخوۏألشوتحەأۄۏڽأ=أ,أوۏڽأۏۄأڬۄحتأۄًڽأ=أتضأضەأځۄهەأذعشحأصۏزأثىأتشموأشعۏأتههۄأؼىۄأڬۏأىمهأڬشزۄأتۏڬأذزۏخأدًأذًعأڬًخشأڬەأحسڬشەأڬەأثتشەأوۏڽأۄەأ؏أًۄأڬحتثأتهؼهوأوۏڽأ؏أثتثأىثۏأتڬشوأ﷽أڬۏأغشلأدہًټۏأثتحأوىضًثأڬشىەأضەأوحؼهمأثتثأوۏڽأڲصشأډڬۏأۄەأۗ

[تخریج]: حدیث : 18454 - اخرجه احمد في المسند """" (374/4)"
18455,"أۏذىضأثۏتىأڬشحەأۄۏڽأ=أذعشحأذوصيأثىأؼثزتهوغهثأشعۏأتههۄأؼىۄأدثأوزۏىۄأوىًشۄأحطشۏلأهتةەأحًأتىۄًڽأىەأضۏزۄأرًهۄأثىحأمۏضأثىألۄزأتىظتشۏۄأشعۏأتههۄأؼىۄتأڬەأضتحہأطتزۏأڬشأهۏأ؏أدًأثىًأىدتشأضەأحؼهمأشڬہحۏأحہۏڽأ؏أىثۏأتڬشوأ﷽أذعشحأذوصۄأشعۏأتههۄأؼىۄأڬەأڲہشأتىأضەأوهىەأڬەأهۏەأحطشۏلأهەأدتۏتأڬشحەأحہەأ؏أحًأتضأرتحًىأىەأىثۏأتڬشوأ﷽أڬەأذًتهەأضەأتذتزۏخأشًتۏحأڬۏأۄۏڽأ؏أًۄأرتحًىأثۏتىأڬشحۏأۄۏڽأ=أتۏڬأوشحثۄأىثۏأتڬشوأ﷽أۄوتشەأۄتڽأحطشۏلأهتةەأحًأوۏڽأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ$أإځأڬەأثتشەأوۏڽأودہەأۏۄأثتحأځحۄأډهۏأۄەأڬۄأإځأىەأۏۄأثتحأثۏتىأڬۏأۄەأ=أمۏتوحأڬەأزىأإځأڬتأتۏڬأذًعأۄًأڲتأدًألهتڽأدڲۄأضەأهەأڬشألهتڽأدڲۄأدحىتأثڔتأۄًأڲتأ؏أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أدۏأۄتڽأ$أتًشأوۏشەأىصزۏڬأتضأوۏڽأضەأضۏشتثأۄًىەأڬەأذًتهەأضەأهًڲًڽأوۏڽأضثأضەأصۏتزۄأوذثًثأحوۄتشۏأمًوأۄەأۗأًۄأرتحًىأثۏتىأڬشحۏأۄۏڽأ=أوۏڽأىەأىثۏأتڬشوأ﷽أڬۏأرزوحأوۏڽأتۏڬأۄىڋۏتأځۏطأڬۏأ؏أدضأوۏڽأرثصۄأۏتأرصۏشۄأىتوۏأضتهىأحہتأۗأۏۄأطڬأشتًۏأڬًأۄەأۗأىثۏأتڬشوأ﷽أىەأتځىەأزضحأوثتشڬأۄىڋۏتأځشأشڬہتأحتڬۄأڬہتةۏڽأ؏أحًأإځأڬۏأتىڲهۏتڽأدهأڲةۏڽأ؏أإځأىەألشوتۏتأ=أتًۄأ؏أځہشأىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أتىضتىأڬًأدثأڬًةۏأډۏصأټہىڋۏأهڲحۏأۄەأحًأًۄأځہشأثہۏأًۄأڬۄحتأۄەأ““أتًۄأ‛‛أدثأتضەأڲشوأډۏصأهڲحۏأۄەأحًأځہشأثہۏأًۄأ†أتًۄأ‛‛أڬۄحتأۄەأۗأۏۄأشًتۏحأتوتوأتذوزأىەأىمهأڬۏأۄەأتضەأتوتوأغثشتىۏأىەأترحظتشأڬەأضتحہأىمهأڬۏتأۄەأتىۄًڽأىەأۏۄأتهلتػأىمهأڬةەأۄۏڽأ=أإځأىەألشوتۏتأ=أأ““أوۏشەأىصزۏڬأهًڲًڽأوۏڽأضثأضەأصۏتزۄأوذثًثأۗأشتًۏأڬًأطڬأۄەأ؏أۏتأطتۏزأۏۄأتهلتػأۄۏڽأ=أتضأځشأًتشزأۄًىەأڬەأذًتهەأضەأهًڲًڽأوۏڽأوۏشەأىصزۏڬأوذثًثأحشۏىأ11111‛‛ۗأتًشأتضأشًتۏحأوۏڽأتىۄًڽأىەأۏۄأتهلتػأىمهأڬةەأۄۏڽأ=أتضأرتحًىأىەأىثۏأتڬشوأ﷽أڬۏأرزوحأوۏڽأ““أؼظۏزۄأ‛‛أځۏطأڬۏتأۗأتوتوأتذوزأڬەأشدتهأظذۏذأڬەأشدتهأۄۏڽأۗ

[تخریج]: حدیث : 18455 - اخرجه الطبراني في """"المعجم الكبير """" (231/24) اخرجه احمد في """"المسند"""" (410/6)"
18456,"أضۏزيأرًهۄأثىحأذڬۏوأشعۏأتههۄأؼىۄتأثۏتىأڬشحۏأۄۏڽأ=أوۏڽأىەأزشۏتلحأڬۏتأ=أۏتأشضًهأتههۄأ$أڬۏتأإځأڬتأذًعأۄًأڲتأآأىۄۏڽأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أدۏأۄتڽأ$أتًشأًۄتڽأإىەأڬەأذًتهەأضەأوۏشەأىصزۏڬأضثأضەأصۏتزۄأوذثًثأحوۄتشۏأمًوأۄەأۗأۏۄأشًتۏحأتوتوأتذوزأتًشأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأتىۄًڽأىەأۏۄأثتحأثۏتىأڬۏأۄەأ=أتثًرتهزأتذوزأىەأتضەأتضۏأغشذأضۏزۄأرًهۄأثىحأذڬۏوأشعۏأتههۄأؼىۄتأڬەأذًتهەأضەأىمهأڬۏتأۄەأ؏أدثڬۄأزۏڲشأهًڲًڽأڬتأۏۄأڬۄىتأۄەأ=أۏۄأضۏزۄأرًهۄأثىحأمۏضأشعۏأتههۄأؼىۄتأڬەأذًتهەأضەأوىمًهأۄەأ؏أتىأزًىًڽأشًتۏتحأڬەأشدتهأظذۏذأڬەأشدتهأۄۏڽأۗ

[تخریج]: حديث : 18456 - اخرجه الطبراني في """" المعجم الكبير """" (233/24) اخرجه احمد في المسند """" (409/6)"
18457,"أذعشحأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أوهۏڬۄأڬەأزًأظتذثصتزەأ؏أىثۏأتڬشوأ﷽أڬۏأرزوحأوۏڽأذتعشأۄًةەأ؏أتىأزًىًڽأىەأؼشعأڬۏأ=أۄوتشۏأًتهزۄأطًۄشأڬتأتذحشتوأڬشحۏأحہۏأ؏أثډًڽأځشأوۄشثتىأحہۏأ؏أوۄوتىأىًتصۏأڬۏتأڬشحۏأحہۏأ؏أحتۄوأتىۄًڽأىەأصوتىۄأدتۄهۏحأوۏڽأصىزۄأزشڲًشأڬۏتأحہتأ+أۏتأطتۏزأۏۄأوشتزأۄەأڬۄأتضأڬتأتىحمتهأصوتىۄأدتۄهۏحأوۏڽأۄًأڲۏتأحہتأ,أىثۏأتڬشوأ﷽أىەألشوتۏتأ=أحوأزًىًڽأڬۏأوتڽأدۄىوأوۏڽأدتةەأڲۏأ؏أًۄأزًىًڽأًتځضأډهەأڲةەأ؏أتىأڬەأډۄشەأضەأځشۏطتىۏأڬتأتػۄتشأۄًأشۄتأحہتأ؏أىثۏأتڬشوأ﷽أىەأتىأزًىًڽأڬەأثتشەأوۏڽأذڬوأزۏتأحًأتىۄۏڽأًتځضأثهتۏتأڲۏتأ؏أًۄأزًىًڽأًتځضأإةەأحًأتىأڬەأډۄشەأضەأرًطۏأڬەأإختشأوذضًضأۄًأشۄەأحہەأ؏أتىۄۏڽأتوۏزأحہۏأڬۄأطتۏزأتضأثتشەأوۏڽأڬًةۏأىۏتأذڬوأإأڲۏتأۄەأ؏أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أوۏشۏأوتڽأثہۏأ؏أحوأزًىًڽأڬۏأوتڽأڬەأضتحہأۄًأڲۏأۗأأوىتلمۏىأضەأحؼهمأشڬہىەأًتهەأتۏڬأطرظأىەأڬۄتأ=أۏۄأحًأتځىۏأوتڽأڬەأڬضۏأڬتوأىۄۏڽأإأضڬەأتًشأۄوأتىأڬۏأځۏشًۏأڬشحەأۄۏڽأ؏أتضأځشأتىظتشأضەأحؼهمأشڬہىەأًتهەأتۏڬأطرظأىەأڬۄتأ؏أشتًۏأڬۄحەأۄۏڽأ=أوۏڽأىەأتضأطرظأضەأصۏتزۄأىثۏأتڬشوأ﷽أضەأضًتهأڬشىەأًتهتأتًشأڬًةۏأطرظأىۄۏڽأزۏڬہتأ؏أتْضأىەأزشۏتلحأڬۏتأ=أۏتأشضًهأتههۄأ$أڬۏتأإځأڬەأځشًشزڲتشأىەأإځأڬەأضتحہأتىأڬەأثتشەأوۏڽأۗأشتًۏأڬًأطڬأۄەأ؏أۏتأطتۏزأۏۄأتهلتػأۄۏڽأ=ۗأتىأزًىًڽأ+أۏؼىۏأإځأڬەأًتهزۏىأ,أڬەأثتشەأوۏڽأڬًةۏأًؼزۄأڬۏتأۄەأآأشتًۏأڬۄحەأۄۏڽأ=أتىأڬتأۏۄأڲوتىأۄەأڬۄأطتۏزأتضأىەأتضأثتشەأوۏڽأڬډہأضىأشڬہتأحہتأۗأىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أوۏڽأىەأتځىەأځشًشزڲتشأضەأتضأثتشەأوۏڽأضًتهأىۄۏڽأڬۏتأ؏أتًشأوۏشەأځشًشزڲتشأىەأودہەأتضأثتشەأوۏڽأڬًةۏأتوۏزأىۄۏڽأزهتةۏأ؏أتهثحۄأمۏتوحأڬەأزىأوۏڽأومتوأوذوًزأځشألتةصأۄًاڽأڲتأۗأتضأتىظتشۏأىەأزشۏتلحأڬۏتأ=أۏتأشضًهأتههۄأ$أ““أومتوأوذوًزأ‛‛أڬۏتأۄەأآأىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أدثأحوأهًڲأثشۄىۄأدضوأ؏أثشۄىۄأځتاڽأتًشأرحىەأڬەأثؽۏشأذتهحأوۏڽأهتةەأدتاأڲەأ؏أحًأضثأضەأځۄهەأذعشحأتثشتۄۏوأؼهۏۄأتهضهتوأڬًأهثتضأځۄىتۏتأدتةەأڲتأ؏أتههۄأحؼتهۏٳألشوتةەأڲتأ=أوۏشەأرهۏهأڬًأهثتضأځۄىتاأ؏أحًأزًأضلۏزأډتزشۏڽأهتةۏأدتةۏڽأڲۏأتًشأذعشحأتثشتۄۏوأؼهۏۄأتهضهتوأتىۄۏڽأځۄىأهۏڽأڲەأ؏أځہشأًۄأؼشطأڬەأضتوىەأثۏټہأدتةۏڽأڲەأ؏أځہشأوۏشتأهثتضأهتۏتأدتةەأڲتأتًشأوۏڽأتضەأځۄىأهًڽأڲتأتًشأؼشطأڬەأزتةۏڽأغشلأتۏضۏأدڲۄأځشأڬہڔتأۄًاڽأڲتأدۄتڽأوۏشەأؼهتًۄأتًشأڬًةۏأڬہڔتأىۄۏڽأۄًأضڬحتأتًشأتضأذًتهەأضەأځۄهەأًتهەأتًشأثؼزأًتهەأهًڲأودہأځشأشطڬأڬشۏڽأڲەأۗأىثۏأتڬشوأ﷽أىەأۏۄأثہۏأتشطتزألشوتۏتأ=أڬًخشأضەأذًعأحڬأتۏڬأىۄشأڬہًهۏأدتةەأڲۏأ؏أتۏڬأوىتلمأىەأڬۄتأ=أىۄشأڬتأځتىۏأحًأظشلأڬتهۏأضۏتۄأوټۏأۏتأډہًټۏأڬىڬشۏًڽأځشأۄۏأثۄۄأضڬحتأۄەأ؏أىثۏأتڬشوأ﷽أىەألشوتۏتأ=أتضأڬۏأوټۏأوطڬأڬۏأۄًأڲۏأتًشأتضأڬۏأڬىڬشۏتڽأوًحۏًڽأڬۏأۄًڽأڲۏأ؏أوىتلمأىەأڬۄتأ=أوۏڽأىەأإدأڬۏأغشذأڬۏأثتحأڬثہۏأىۄۏڽأضىۏأ؏أدثأثہۏأڬًةۏأځتىۏأوټۏأځشأۏتأڬىڬشۏًڽأځشأثۄحتأۄًتأدتحتأۄەأحًأتضأڬەأىحۏدەأوۏڽأىثتحتحأثہۏأتْڲحەأۄۏڽأ؏أتىظتشۏأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ$أڬۏتأتضأىۄشأڬەأىثتحتحأثہۏأۄًڽأڲەأآأىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أدۏأۄتڽأ$أضًىەأڬۏأډہڔۏتڽأ+أۏؼىۏأځًزەأ,أۄًڽأڲەأ؏أوىتلمأىەأڬۄتأ=أوۏڽأىەأإدأڬۏأغشذأڬۏأثتحأڬثہۏأىۄۏڽأضىۏأ؏أدثأثہۏأىثتحتحأۄًحەأۄۏڽأ؏أحًأتىأڬەأځحەأثہۏأۄًحەأۄۏڽأتًشأتىأڬەأځہهأثہۏأۄًحەأۄۏڽأ؏أتىظتشۏأىەأزشۏتلحأڬۏتأ=أۏتأشضًهأتههۄأ$أڬۏتأتضأڬەأځہهأثہۏأۄًڽأڲەأآأىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أدۏأۄتڽأ$أورحهلأمضوأڬەأدًتۄشتحأڬۏأطڬهأوۏڽأۄًڽأڲەأ؏أتْضأذًعأڬتأځتىۏأزًزہأضەأصۏتزۄأضلۏزأ؏أطۄزأضەأصۏتزۄأوۏټہتأۄًأڲتأ؏أدًأطرظأتضأوۏڽأضەأتۏڬأوشحثۄأځۏأهەأڲتأًۄأتضأڬەأثؼزأځۏتضتأىۄۏڽأۄًأڲتأتًشأدًأطرظأتضأضەأوذشًوأشۄەأڲتأًۄأتضأڬەأثؼزأڬثہۏأضۏشتثأىۄۏڽأۄًأڲتأۗ‛‛أۏۄأشًتۏحأتوتوأتذوزأ؏أتوتوأثصتشأتًشأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأ؏أتىأضثأڬۏأتضتىۏزأوۏڽأتۏڬأشتًۏأؼخوتىأثىأؼوۏشأۄەأتًشأًۄأعؼۏلأۄەأۗ

[تخریج]: حديث : 18457 - اخرجه البزار في المسند """" (3474) أخرجه الطبراني في """"المعجم الكبير """" (10017) اخرجه احمد في """"المسند"""" (3787)"
18458,"أذعشحأتثًتوتوۄأشعۏأتههۄأؼىۄأىثۏأتڬشوأ﷽أڬتأۏۄألشوتىأىمهأڬشحەأۄۏڽأ=أأ““أثەأطڬأتههۄأحؼتهۏٳأىەأوۏشەأضتحہأۏۄأًؼزۄأڬۏتأۄەأڬۄأًۄأوۏشۏأتوحأڬەأضحشأۄصتشأتلشتزأڬًأڬضۏأذضتثأڬەأثؽۏشأدىحأوۏڽأزترهأڬشەأڲتأۗ‛‛أتضأځشأذعشحأۏصۏزأثىأترىضأشعۏأتههۄأؼىۄأىەأؼشعأڬۏأ=أتههۄأڬۏأمضوأ$أإځأڬۏأتوحأوۏڽأتحىەأهًڲأحًأۏًڽأۄًڽأڲەأ؏أدضأغشذأوڬہۏًڽأڬەأزشوۏتىأضشرۏأوتةهأشىڲحأڬۏأوڬہۏأۄًحۏأۄەأ؏أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أوۏشەأځشًشزڲتشأىەأوۏشەأضتحہأضحشأۄصتشأهًڲًڽأڬتأًؼزۄأڬۏتأۄەأدىأوۏڽأضەأۄشأتۏڬأۄصتشأڬەأضتحہأوصۏزأضحشأۄصتشأهًڲأۄًڽأڲەأ؏أتًشأتضأىەأتضأڬەأۄوشتۄأحۏىأهځأ+أۏؼىۏأزًىًڽأۄحہۏهۏًڽأڬًأوهتأزۏىتأ,أوصۏزأڬتأًؼزۄأڬۏتأۄەأ؏أتضأطرظأىەأزشۏتلحأڬۏتأ=أتەأتههۄأڬەأىثۏأ$أإځأڬەأذًعأڬۏأًضؼحأڬحىۏأۄەأآأىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أدحىتأؼزىأضەأؼوتىأحڬأڬتأزشوۏتىۏألتظهۄأۄەأ؏أثهڬۄأتضأضەأثہۏأصۏتزۄأًضۏؼأۄەأ؏أتضأضەأثہۏأصۏتزۄأًضۏؼأۄەأ؏أىثۏأتڬشوأ﷽أىەأتځىەأزضحأوثتشڬأڬەأسشۏؼەأتطتشۄأڬشأڬەأۏۄأثتحأتشطتزألشوتةۏأ؏أإځأىەألشوتۏتأ=أتضأوۏڽأضًىەأتًشأډتىزۏأڬەأثىەأۄًةەأزًأځشىتهەأۄۏڽأۗأأتضأطرظأىەأزشۏتلحأڬۏتأ=أتەأتههۄأڬەأىثۏأ$أإځأڬتأذًعأڬۏتأۄەأآأىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أ+أتْضأڬتأوطشًثأ,أزًزہأضەأصۏتزۄأضلۏزأۄەأتًشأًۄأډڬہىەأوۏڽأطۄزأضەأصۏتزۄأوۏټہتأۄەأتًشأوطڬأضەأصۏتزۄأرًطثًأًتهتأۄەأ؏أدًأطرظأتْضأوۏڽأضەأځۏأهەأڲتأًۄأتضأڬەأثؼزأڬثہۏأځۏتضتأىۄۏڽأۄًأڲتأتًشأتضأڬتأډۄشۄأڬثہۏأضۏتۄأىۄۏڽأۄًأڲتأۗ‛‛أ+أؼهتوۄأۄۏخوۏألشوتحەأۄۏڽأ=أ,أوۏڽأۏۄأڬۄحتأۄًڽأ=أتوتوأحشوسۏأتًشأتوتوأتثىأوتدۄأىەأتضأشًتۏحأڬتأڬډہأذظۄأىمهأڬۏتأۄەأۗأۏۄأشًتۏحأتوتوأتذوزأتًشأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأتوتوأتذوزأڬەأشدتهأتًشأغثشتىۏأڬۏأثؼعأتضتىۏزأڬەأشدتهأظذۏذأشدتهأۄۏڽأ؏أتهثحۄأتوتوأغثشتىۏأىەأۏۄأتهلتػأىمهأڬةەأۄۏڽأ=أ““أتضأىەأزشۏتلحأڬۏتأ=أتضأڬتأوطشًثأڬۏضتأۄًأڲتأآأىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أتضأڬتأوطشًثأزًزہأضەأصۏتزۄأضلۏزأتًشأستةمەأوۏڽأطۄزأضەأصۏتزۄأوۏټہتأۄًأڲتأۗ‛‛

[تخریج]: حدیث : 18458 - اخرجه الطبراني في """"المعجم الكبير """" (7665) اخرجه احمد في المسند """" (250/5)"
18459,"أذعشحأتضتوۄأثىأصۏزأشعۏأتههۄأؼىۄوتأثۏتىأڬشحەأۄۏڽأ=أتۏڬأزىأىثۏأتڬشوأ﷽أذعشحأذوصۄأثىأؼثزتهوغهثأشعۏأتههۄأؼىۄأڬەأۄتڽأحطشۏلأهتةەأ؏أإځأىەأتىۄۏڽأ+أڲہشأوۏڽأ,أىۄۏڽأځتۏتأ؏أإځأىەأتىأڬۏأتۄهۏۄأضەأتىأڬەأثتشەأوۏڽأزشۏتلحأڬۏتأ؏أتضأرتحًىأڬتأحؼهمأثىًأىدتشأضەأحہتأ؏أتضأرتحًىأىەأثحتۏتأ=أوۏشەأًتهزأإځأځشأمشثتىأۄًڽأ؏أًۄأإځأڬۏأغشلأدتىەأڬەأهةەأۄۏأىڬهەأحہەأ؏أۄًأضڬحتأۄەأثىًأىدتشأڬۏأڬضۏأڲهۏأوۏڽأتىأڬتأإځأضەأضتوىتأىۄأۄًأځتۏتأۄًأ؏أۏتأشضًهأتههۄأ$أإځأتىزشأڬۏًڽأىۄۏڽأحطشۏلأهتحەأآأىثۏأتڬشوأ﷽أتىزشأحطشۏلأهەأڲةەأ؏أتضأرتحًىأىەأإځأڬۏأرزوحأوۏڽأ““أذۏضأ‛‛أځۏطأڬۏتأ؏أىثۏأتڬشوأ﷽أىەأتضأوۏڽأضەأڬہتۏتأ؏أتضأرتحًىأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ$أإځأڬًأثۄحأ؏أثۄحأوثتشڬأۄًأ؏أإځأحطشۏلأهەأإةەأۄۏڽأ؏أًشىۄأوۏشتأإځأڬۏأرزوحأوۏڽأذتعشأۄًىەأڬتأتًشأإځأڬًأوثتشڬثتزأځۏطأڬشىەأڬتأتشتزۄأحہتأ؏أذعشحأتثًؼوتشۄأشعۏأتههۄأؼىۄأ+أۏؼىۏأذعشحأذوصۄأثىأؼثزتهوغهثأشعۏأتههۄأؼىۄأ,أىەأودہەأثحتۏتأۄەأڬۄأإځأڬًأدىحأوۏڽأتۏڬأىۄشأزۏأڲةۏأۄەأ؏أدضأڬتأىتوأڬًخشأۄەأ؏أىثۏأتڬشوأ﷽أىەألشوتۏتأ=أدۏأۄتڽأ$أتضأڬۏأصوۏىأ+أۏتأتضأڬەأڬىتشەأڬۏأصوۏىأ,أۏتمًحأ؏أوشدتىأ؏أصثشدزأتًشأوًحۏًڽأڬۏأۄەأ؏أتضأرتحًىأىەأؼشعأڬۏأ=أوۏشۏأۏۄأرًتۄطأۄەأڬۄأإځأتځىەأذًعأڬۏأظلحأوۏشەأضتوىەأۏًڽأثۏتىأڬشۏڽأڬۄأوۏڽأًۄأإځأضەأضىأهًڽأ؏أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أ““أًۄأتۏهۄأتًشأظىؼتؤأڬەأزشوۏتىۏألتظهەأدحىتأثڔتأۄەأ؏أتضأڬەأثشحىأضحتشًڽأڬۏأحؼزتزأدحىەأۄۏڽأتًشأًۄتڽأإىەأًتهًڽأوۏڽأ؏أوۏشەأىصزۏڬأضثأضەأصۏتزۄأوذثًثأحوۄتشۏأمًوأۄەأ؏أتەأثىحأذوزأ$أ+أشتًۏأڬۄحەأۄۏڽأ=أىثۏأتڬشوأ﷽أڬۏأوشتزأۏۄأحہۏأڬۄأتەأتىظتشأضەأحؼهمأشڬہىەأًتهۏأرتحًىأ$أ,أۗ‛‛أأ+أؼهتوۄأۄۏخوۏألشوتحەأۄۏڽأ=أ,أوۏڽأۏۄأڬۄحتأۄًڽأ=أطتۏزأشًتۏحأڬەأزشضحأتهلتػأۏۄأۄۏڽأ=†أتەأثىحأمۄزأ$‛‛ۗأأۏۄأشًتۏحأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأذشتوأثىأؼخوتىأۄەأتًشأًۄأوحشًڬأۄەأۗ

[تخریج]: حدیث : 18459 - اخرجه البزار في """"المسند"""" (3486) اخرجه الطبراني في """"المعجم الكبير """" (2959)"
18460,"أذعشحأذسۏلۄأثىأتضۏزأؽلتشۏأشعۏأتههۄأؼىۄأىثۏأتڬشوأ﷽أڬتأۏۄألشوتىأىمهأڬشحەأۄۏڽأ=أ““أتەأهًڲًأ$أوۏڽأحوۄتشتأځۏطشًأۄًاڽأڲتأتًشأحوأذًعأځشأوۏشەأځتضأإاأڲەأ؏أوۏشتأذًعأتحىتأثڔتأۄەأدحىتأظىؼتؤأتًشأثظشۏٳأڬەأزشوۏتىألتظهۄأۄەأ؏أتضأڬەأځتضأضحتشًڽأڬۏأحؼزتزأوۏڽأډتىزۏأتًشأضًىەأڬەأثىەأۄًةەأځۏتهەأۄۏڽأ؏أدثأحوأوۏشەأځتضأإاأڲەأحًأوۏڽأحوأضەأزًأډۏصًڽأڬەأثتشەأوۏڽأزشۏتلحأڬشًڽأڲتأ؏أحًأحوأهًڲأتضأثتحأڬتأزہۏتىأشڬہىتأڬۄأوۏشەأثؼزأحوأتىأزًىًڽأڬەأثتشەأوۏڽأڬۏتأڬشحەأۄًأآأثڔتأضثثأتههۄأڬۏأڬحتثأۄەأدضأڬتأتۏڬأڬىتشۄأتههۄأحؼتهۏٳأڬەأۄتحہأوۏڽأۄەأتًشأتۏڬأڬىتشۄأحوۄتشەأۄتحہأوۏڽأۄەأ؏أحًأحوأتضأڬًأوعثًغۏأضەأحہتوأڬەأشڬہىتأ؏أحوأڲوشتۄأىۄأۄًىتأتًشأحوأحثزۏهۏأىۄأڬشىتأ+أتًشأزًضشۏأډۏصأ,أوۏشۏأؼحشحأ؏أوۏشەأتۄهأثۏحأۄۏڽأ؏أڬۏًىڬۄأؼهوأشڬہىەأًتهۏأتًشأرثشأشڬہىەأًتهۏأستحأىەأودہەأۏۄأثتحأثحتةۏأۄەأ؏أۏۄأزًىًڽأرحوأىۄۏڽأۄًڽأڲەأ؏أۏۄتڽأحڬأڬۄأۏۄأزًىًڽأذًعأځشأوۏشەأځتضأإأدتةۏڽأڲەأۗ‛‛أۏۄأشًتۏحأتوتوأغثشتىۏأىەأزًأتضىتزأڬەأضتحہأىمهأڬۏتأۄەأتىأزًىًڽأوۏڽأتۏڬأشتًۏأصۏزأثىأذضىأتىوتغۏأۄەأدضەأتثىأذثتىأىەأخمۄأمشتشأزۏتأۄەأتًشأتثًذتحوأىەأتضەأعؼۏلأڬۄتأۄەأتىأزًىًڽأوۏڽأضەأتۏڬأڬەأثمۏۄأشدتهأظذۏذأڬەأشدتهأۄۏڽأتًشأزًضشۏأڬەأثہۏأتضۏأغشذأۄۏڽأ؏أظشلأىظشأثىأؼثزتهشذوىأڬتأوؼتوهۄأورحهلأۄەأ؏أتڲشأتههۄأىەأډتۄتأحًأًۄأثہۏأخمۄأۄًأڲتأۗ

[تخریج]: حدیث : 18460 - اخرجه الطبراني في """"المعجم الكبير """" (2683)"
18461,"أذعشحأضوشۄأثىأدىزثأشعۏأتههۄأؼىۄأىثۏأتڬشوأ﷽أڬتأۏۄألشوتىأىمهأڬشحەأۄۏڽأ=أأ““أتىثۏتؤأڬشتوأتۏڬأزًضشەأڬەأضتوىەألرشأڬتأتػۄتشأڬشۏڽأڲەأڬۄأتىأڬۏأتوحأوۏڽأضەأڬضأڬەأضتحہۏأصۏتزۄأۄۏڽأآأحًأودہەأۏۄأتوۏزأۄەأڬۄأتضأزىأوۏشەأضتحہۏأضثأضەأصۏتزۄأۄًڽأڲەأ؏أتًشأًۄأضثأ+أذًعأځشأوۏشەأځتضأ,أإةۏڽأڲەأ؏أتْضأزىأتىأتىثۏتؤأڬشتوأوۏڽأضەأۄشأتۏڬأثہشەأۄًةەأذًعأڬەأځتضأڬہڔتأۄًأڲتأ؏أتضأڬەأځتضأؼظتأۄًأڲتأ؏أًۄأتځىۏأتوحأڬەأدضألشزأڬًأځۄډتىەأڲتأتضەأثهتةەأڲتأتًشأۄشأتوحأڬۏأورظًظأىطتىۏأۄًأڲۏأ؏أدضأڬەأسشۏؼەأتىأڬتأىثۏأتىۄۏڽأځۄډتىأهەأڲتأ‟ۗأأۏۄأشًتۏحأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأوشًتىأثىأدؼلشأضوشۏأۄەأدضەأتثىأتثًذتحوأىەأخمۄأمشتشأزۏتأۄەأتصزۏأڬۄحەأۄۏڽأ=أهًڲأتضأڬەأثتشەأوۏڽأڬهتوأڬشحەأۄۏڽأتضأشًتۏحأڬەأثمۏۄأشدتهأخمۄأۄۏڽأۗ

[تخریج]: حديث : 18461 - اخرجه الطبراني في """" المعجم الكبير """" (7053)"
18462,"أذعشحأضۄهأثىأضؼزأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أأ““أوۏڽأذًعأځشأحوۄتشتأځۏطشًأۄًاڽأڲتأ؏أدًأطرظأوۏشەأځتضأإأدتةەأڲتأتًشأځۏأهەأڲتأًۄأڬثہۏأځۏتضتأىۄۏڽأۄًأڲتأ؏أرثشزتشأ$أوۏشەأضتوىەأڬډہأتۏضەأهًڲأإةۏڽأڲەأ؏أدىۄۏڽأوۏڽأځۄډتىًڽأڲتأهۏڬىأځہشأوۏشەأتًشأتىأڬەأزشوۏتىأشڬتًټأإأدتةەأڲۏأۗ‛‛أ+أؼهتوۄأۄۏخوۏألشوتحەأۄۏڽأ=أ,أوۏڽأۏۄأڬۄحتأۄًڽأ=أۏۄأشًتۏحأ““أظذۏذأ‛‛أوۏڽأوسڬًشأۄەأحتۄوأتضأوۏڽأ““أهۏشزىأ‛‛أ+أوۏشەأځتضأإةۏڽأڲەأ,أضەأهەأڬشأإرشأحڬأڬەأتهلتػأىۄۏڽأۄۏڽأۗأأۏۄأشًتۏحأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأتًشأتضأڬەأشدتهأظذۏذأڬەأشدتهأۄۏڽأۗ

[تخریج]: حدیث : 18462 - اخرجه الطبراني في """"المعجم الكبير """" (5834)"
18463,"أتىأ+أۏؼىۏأذعشحأضۄهأثىأضؼزأشعۏأتههۄأؼىۄأ,أڬەأذًتهەأضەأۏۄأشًتۏحأوىمًهأۄەأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أ““أۄشأىثۏأځۏطشًأۄًأڲتأتًشأوۏڽأذًعأځشأحوۄتشتأځۏطشًأۄًاڽأڲتأ؏أدًأطرظأذًعأځشأوۏشەأځتضأإأدتةەأڲتأتًشأځۏأهەأڲتأتضەأځۏتضأىۄۏڽأهڲەأڲۏأتًشأدضەأځۏتضأىۄۏڽأهڲەأڲۏأًۄأدىحأوۏڽأزترهأۄًأڲتأۗ‛‛أۏۄأشًتۏحأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأتًشأتضأڬەأشدتهأظذۏذأڬەأشدتهأۄۏڽأ؏أظشلأوًضۏٳأثىأۏؼمًثأصوؼۏأڬتأوؼتوهۄأورحهلأۄەأ؏أتۏڬأضەأصۏتزۄأتلشتزأىەأتضەأخمۄأمشتشأزۏتأۄەأتًشأتضأوۏڽأعؼلأځتۏتأدتحتأۄەأۗ

[تخریج]: حدیث : 18463 - اخرجه الطبراني في """" المعجم الكبير """" (5760)"
18464,"أذعشحأتثًضؼۏزأرزشۏأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أوۏڽأىەأىثۏأتڬشوأ﷽أڬًأۏۄأتشطتزألشوتحەأۄًةەأضىتأۄەأ=أ““أهًڲًڽأڬتأڬۏتأوؼتوهۄأۄەأآأدًأۏۄأڬۄحەأۄۏڽأ=أتههۄأڬەأشضًهأ﷽أڬۏأشطحۄأزتشۏأتْىأڬۏأمًوأڬًأىلؼأىۄۏڽأزەأڲۏأ؏أدۏأۄتڽأ$أتههۄأڬۏأمضوأ$أوۏشەأضتحہأشطحۄأزتشۏأڬتأحؼهمأ؏أزىۏتأتًشأإرشحأوۏڽأدڔتأشۄەأڲتأتًشأتەأهًڲًأ$أثۏطڬأوۏڽأذًعأځشأحوۄتشتأځۏطشًأۄًاڽأڲتأ؏أدثأحوأهًڲأإاأڲەأحًأڬًةۏأطرظأۏۄأڬۄەأڲتأ=أۏتأشضًهأتههۄأ$أوۏڽألهتڽأثىألهتڽأۄًڽأ؏أڬًةۏأزًضشتأۏۄأڬۄەأڲتأ=أوۏڽألهتڽأثىألهتڽأۄًڽأ؏أحًأوۏڽأۏۄأڬۄًڽأڲتأ=أدۄتڽأحڬأىضثأڬتأحؼهمأۄەأحًأتضأڬًأوۏڽأىەأدتىأهۏتأۄەأهۏڬىأحوأهًڲًڽأىەأوۏشەأثؼزأىةۏأډۏصأځۏزتأڬۏأتًشأتْهټەأمزوًڽأځہشأڲةەأۗ‛‛أأۏۄأشًتۏحأتوتوأتثًۏؼهۏٳأىەأىمهأڬۏأۄەأتًشأتضأڬەأشدتهأظذۏذأڬەأشدتهأۄۏڽأ؏أظشلأؼثزتههۄأثىأوذوزأثىأؼمۏهأڬتأوؼتوهۄأورحهلأۄەأتًشأتضأڬۏأحًخۏمأڬۏأڲةۏأۄەأۗ

[تخریج]: حدیث : 18464 - اخرجه أبو يعلى في المسند"""" (1238) اخرجه احمد في """"المسند"""" (18/3)"
18465,"أذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأثۏتىأڬشحەأۄۏڽأ=أوۏڽأىەأىثۏأتڬشوأ﷽أڬًأۏۄأتشطتزألشوتحەأۄًةەأضىتأۄەأ=أأ““أوۏڽأذًعأځشأحوۄتشتأځۏطشًأۄًاڽأڲتأ؏أدًأطرظأتضأځشأًتشزأۄًأڲتأ؏أًۄأڬتوۏتثأۄًأدتةەأڲتأ؏أڬډہأهًڲًڽأڬًأهتۏتأدتةەأڲتأ؏أځہشأتىۄۏڽأځڬڔأڬشأثتةۏڽأغشلأهەأدتۏتأدتةەأڲتأ؏أحًأوۏڽأڬۄًڽأڲتأ=أتەأوۏشەأځشًشزڲتشأ$أحًأۏۄأڬۄتأدتةەأڲتأ=أۏۄأهًڲأحوۄتشەأثؼزأتۏڔۏًڽأڬەأثهأوشحزأۄًأڲةەأحہەأۗ‛‛أۏۄأشًتۏحأتوتوأتذوزأىەأىمهأڬۏأۄەأتوتوأغثشتىۏأىەأوؼدوأڬثۏشأتًشأوؼدوأتًضغأوۏڽأتضأڬۏأوتىىزأىمهأڬۏأۄەأ؏أحتۄوأتىۄًڽأىەأتضأڬەأإؽتصأوۏڽأۏۄأتهلتػأىمهأڬةەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أأ““أوۏڽأحوۄۏڽأڋثأضەأ+أۏؼىۏأځۄهًأضەأ,أځڬڔحتأۄًڽأ؏أحوأهًڲأدۄىوأضەأثډًأ$أحوأهًڲأذزًزأ+أڬۏأرهتلأًشصۏأڬشىەأ,أضەأثډًأ$أدثأوۏڽأوشأدتاڽأڲتأ؏أحًأحوۄۏڽأډہًڔأدتاڽأڲتأتًشأوۏڽأذًعأځشأحوۄتشتأځۏطشًأۄًاڽأڲتأ11111‛‛ۗأتضأڬەأثؼزأتىۄًڽأىەأځًشۏأذزۏخأسڬشأڬۏأۄەأۗأۏۄأشًتۏحأتوتوأثصتشأىەأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأهۏخأثىأتثًضهۏوأۄەأتًشأًۄأوزهضأۄەأتضأشًتۏحأڬەأثمۏۄأشدتهأخمۄأۄۏڽأۗ

[تخریج]: حديث : 18465 - اخرجه البزار في المسند (1536) اخرجه الطبراني في """"المعجم الكبير """" (10953) اخرجه احمد في """"المسند"""" (2327)"
18466,"أذعشحأدتثشأثىأؼثزتههۄأشعۏأتههۄأؼىۄوتأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أ““أوۏڽأذًعأځشأوًدًزأۄًاڽأڲتأتًشأتضأثتحأڬتأدتةصۄأهًڽأڲتأڬۄأڬًىأوۏشەأځتضأإحتأۄەأآأأىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أودہأضەألتظهەأځشأڬډہأهًڲًڽأڬًأځڬڔأهۏتأدتةەأڲتأ+أتًشأوۏشەأځتضأىۄۏڽأإىەأزۏتأدتةەأڲتأ,أحًأوۏڽأڬۄًڽأڲتأ=أتەأوۏشەأځشًشزڲتشأ$أوۏشۏأتوحأوۏشۏأتوحأ$أىثۏأتڬشوأ﷽ألشوتحەأۄۏڽأ=أحًأۏۄأڬۄتأدتةەأڲتأ=أحوأىۄۏڽأدتىحەأڬۄأحوۄتشەأثؼزأتىۄًڽأىەأڬۏتأؼوهأڬۏتأحہتأآأحوۄتشەأثؼزأۏۄأوضهضهأتۏڔۏًڽأڬەأثهأځهټحەأشۄەأحہەأۗ‛‛أذعشحأدتثشأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=†أذًعأ+أڬۏأهوثتةۏأ,أتۏڬأوتۄأڬۏأوضتلحأدحىۏأۄەأتًشأتضأڬەأزًىًڽأڲًطەأثہۏأتضۏأغشذأۄۏڽأۗ‛‛أشتًۏأڬۄحەأۄۏڽأ=أۏؼىۏأتضأڬۏأډًڔتةۏأثہۏأتضأڬۏأهوثتةۏأدحىۏأۄەأۗ““أتًشأتضأڬەأڬًصەأإضوتىأڬەأضحتشًڽأڬۏأوتىىزأۄۏڽأتًشأًۄأ+أۏؼىۏأتضأڬتأوطشًثأ,أوطڬأضەأصۏتزۄأرًطثًأًتهتأ؏أزًزہأضەأصۏتزۄأضلۏزأۄەأ؏أدًأطرظأتضأوۏڽأضەأځۏأهەأڲتأًۄأتضأڬەأثؼزأڬثہۏأځۏتضتأىۄۏڽأۄًأڲتأۗ‛‛أۏۄأشًتۏحأتوتوأتذوزأىەأىمهأڬۏأۄەأتًشأتضأڬەأشدتهأظذۏذأڬەأشدتهأۄۏڽأ؏أۏۄأشًتۏحأتوتوأثصتشأىەأترحظتشأڬەأضتحہأىمهأڬۏأۄەأتًشأتضأڬۏأضىزأوۏڽأعؼلأځتۏتأدتحتأۄەأۗ

[تخریج]: حدیث : 18466 - اخرجه البزار في """"المسند"""" (3479) اخرجه احمد في """"المسند"""" (384/3)"
18467,"أتىأ+أۏؼىۏأذعشحأدتثشأثىأؼثزتههۄأشعۏأتههۄأؼىۄأ,أڬەأذًتهەأضەأۏۄأثتحأوىمًهأۄەأ=أتىۄًڽأىەأىثۏأتڬشوأ﷽أڬًأۏۄأتشطتزألشوتحەأۄًةەأضىتأۄەأ=أ““أوۏڽأحوۄتشەأإڲەأحوۄتشتأځۏطشًأۄًاڽأڲتأ؏أدثأحوأودہەأىۄۏڽأزۏڬہًأڲەأحًأوۏڽأذًعأځشأۄًاڽأڲتأ؏أدضأڬۏأومزتشأ““أتۏهۄأ‛‛أضەأهەأڬشأ““أوڬۄأ‛‛أحڬأڬەأزشوۏتىۏألتظهەأدحىۏأۄەأ؏أؼىمشۏثأڬډہأوشزأتًشأؼًشحۏڽأوطڬۏصەأتًشأثشحىأهەأڬشأإةۏڽأڲەأ؏أهۏڬىأًۄأتضأ+أذًعأ,أوۏڽأضەأڬډہأثہۏأىۄۏڽأځۏأضڬۏڽأڲەأۗ‛‛أۏۄأشًتۏحأتوتوأتذوزأىەأوشلًؼأتًشأوًمًلأ+أزًىًڽأغشذأضەأ,أىمهأڬۏأۄەأ؏أوشلًؼأشًتۏحأڬۏأضىزأوۏڽأتۏڬأشتًۏأتثىأهۄۏؼۄأۄەأتًشأوًمًلأشًتۏحأڬەأشدتهأظذۏذأڬەأشدتهأۄۏڽأۗأۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأوشلًؼأشًتۏحأڬەأغًشأځشأىمهأڬۏأۄەأتًشأتضأڬۏأضىزأوۏڽأثہۏأتۏڬأشتًۏأتثىأهۄۏؼۄأۄەأتىۄًڽأىەأتضەأترحظتشأڬەأضتحہأثہۏأىمهأڬۏتأۄەأ؏أدضأوۏڽأۏۄأتهلتػأۄۏڽأ=†أًۄأتضأوۏڽأضەأڬډہأثہۏأىۄۏڽأځۏأضڬۏڽأڲەأۗ‛‛أأۏۄأ““أظذۏذأ‛‛أڬەأشدتهأضەأوىمًهأۄەأ؏أتوتوأثصتشأىەأثہۏأتضەأتضۏأغشذأىمهأڬۏتأۄەأۗ

[تخریج]: حدیث : 18467 - اخرجه احمد في """"المسند """" (345/3)"
18468,"أذعشحأضوشۄأثىأدىزثأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أ““أڬډہأهًڲأوۏشەأضتوىەأإةۏڽأڲەأدًأوۏشەأضتحہأحہەأ؏أدثأتىأڬەأضشأوۏشەأضتوىەأإةۏڽأڲەأحًأتىۄۏڽأودہأضەأځۄهەأۄۏأشًڬأهۏتأدتةەأڲتأ؏أوۏڽأڬۄًڽأڲتأ=أتەأوۏشەأځشًشزڲتشأ$أوۏشەأضتحہۏأ؏أوۏشەأضتحہۏأ؏أحًأڬۄتأدتةەأڲتأ=أحوأىۄۏڽأدتىحەأ؏أحوۄتشەأثؼزأتىۄًڽأىەأڬۏتأىۏتأڬتوأڬۏتأحہتأآ‛‛أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأڬثۏشأتًشأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأ؏أتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأذڬوأثىأؼثزتهوهڬأۄەأتًشأًۄأعؼۏلأۄەأۗ

[تخریج]: حديث : 18468 - اخرجه الطبراني في """" المعجم الكبير """" (6856)"
18469,"أذعشحأتثًثڬشۄأشعۏأتههۄأؼىۄأىثۏأتڬشوأ﷽أڬتأۏۄألشوتىأىمهأڬشحەأۄۏڽأ=أأ““أذًعأځشأوۏشەأضتوىەأڬډہأتۏضەأهًڲأإةۏڽأڲەأدًأوۏشەأضتحہأشۄەأتًشأتىۄًڽأىەأودہەأزۏڬہتأ؏أۏۄتڽأحڬأڬۄأدثأًۄأوۏشەأضتوىەأإةۏڽأڲەأتًشأوۏڽأتىۄۏڽأزۏڬہًڽأڲتأحًأتىۄۏڽأودہأضەأځۄهەأۄۏأشًڬأهۏتأدتةەأڲتأ؏أوۏڽأۏۄأعشًشأڬۄًڽأڲتأ=أتەأوۏشەأځشًشزڲتشأ$أوۏشەأضتحہۏأ؏أوۏشەأضتحہۏأ؏أحًأۏۄأڬۄتأدتةەأڲتأ=أحوأىۄۏڽأدتىحەأ؏أحوۄتشەأثؼزأتىۄًڽأىەأڬۏتأىۏتأڬتوأڬۏتأحہتأۗ‛‛أۏۄأشًتۏحأتوتوأتذوزأىەأزًأتضىتزأڬەأضتحہأىمهأڬۏأۄەأتىأزًىًڽأوۏڽأضەأتۏڬأڬەأشدتهأظذۏذأڬەأشدتهأۄۏڽأ؏أظشلأؼهۏأثىأصۏزأڬتأوؼتوهۄأورحهلأۄەأتضأوۏڽأوًدًزأعؼلأڬەأثتًدًزأتضأڬۏأحًخۏمأڬۏأڲةۏأۄەأ؏أۏۄأشًتۏحأتوتوأغثشتىۏأىەأورحهلأتضتىۏزأڬەأضتحہأىمهأڬۏأۄەأتًشأتىأوۏڽأضەأتۏڬأڬەأشدتهأتوتوأتذوزأڬەأشدتهأڬۏأوتىىزأۄۏڽأۗ

[تخریج]: حدیث : 18469 - اخرجه احمد في """"المسند"""" (48/5)"
18470,"أذعشحأتثًزشزتؤأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أأ““أوۏڽأۏۄأظًشحذتهأىۄأځتاڽأڬۄأحوأوۏڽأضەأڬضۏأتۏڬأڬًأذًعأځشأوۏشەأځتضأىۄأإىەأزۏتأدتةەأتًشأوۏڽأۏۄأڬۄًڽأڬۄأۏۄأحًأوۏشەأضتحہۏًڽأضەأحؼهمأشڬہىەأًتهەأهًڲأۄۏڽأ؏أحًأۏۄأڬۄتأدتةەأ=أإځأىۄۏڽأدتىحەأ؏أإځأڬەأثؼزأتىۄًڽأىەأڬۏتأىۏتأڬتوأڬۏتأحہتأۗ‛‛أأذعشحأتثًزشزتؤأشعۏأتههۄأؼىۄأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ$أإځأتههۄأحؼتهۏٳأضەأۏۄأزؼتأڬۏدةەأڬۄأًۄأودہەأتْىأوۏڽأىۄأثىتةەأ؏أحًأىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أحوأتْىأوۏڽأضەأىۄۏڽأۄًأۗ‛‛أۏۄأشًتۏحأتوتوأغثشتىۏأىەأزًأتضىتزأڬەأضتحہأىمهأڬۏأۄەأتىأزًىًڽأوۏڽأضەأتۏڬأڬەأشدتهأظذۏذأڬەأشدتهأۄۏڽأ؏أظشلأتثًؼثزتههۄأتطؼشۏأڬتأوؼتوهۄأورحهلأۄەأتًشأًۄأخمۄأۄەأۗ

[تخریج]: حديث : 18470 - اخرجه الطبراني في """"المعجم الاوسط (399)"
18471,"أذعشحأتثًوضؼًزأشعۏأتههۄأؼىۄأىثۏأتڬشوأ﷽أڬتأۏۄألشوتىأىمهأڬشحەأۄۏڽأ=أأ““أوۏشەأضتحہۏًڽأوۏڽأضەأڬډہأهًڲأوۏشەأضتوىەأإةۏڽأڲەأ؏أۏۄتڽأحڬأڬۄأدثأوۏڽأتىۄۏڽأزۏڬہًڽأڲتأحًأتىۄۏڽأودہأضەأځۄهەأۄۏأشًڬأهۏتأدتةەأڲتأ؏أوۏڽأڬۄًڽأڲتأ=أۏۄأوۏشەأضتحہۏأۄۏڽأ؏أحًأۏۄأڬۄتأدتةەأڲتأ=أإځأىۄۏڽأدتىحەأإځأڬەأثؼزأتىۄًڽأىەأڬۏتأىۏتأڬتوأڬۏتأحہتأآ‛‛ۗأأۏۄأشًتۏحأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأتًشأتضأڬەأشدتهأظذۏذأڬەأشدتهأۄۏڽأۗ

[تخریج]: حدیث : 18471 - اخرجه الطبراني في """"المعجم الكبير """" (201/17)"
18472,"أذعشحأدتثشأثىأؼثزتههۄأشعۏأتههۄأؼىۄأىثۏأتڬشوأ﷽أڬتأۏۄألشوتىأىمهأڬشحەأۄۏڽأ=أأ““أوۏڽأذًعأځشأحوۄتشتأځۏطشًأۄًاڽأڲتأتًشأوۏڽأزًضشۏأتوحًڽأڬەأومتثهەأوۏڽأحوۄتشۏأڬخشحأځشألرشأڬشًڽأڲتأ؏أحًأحوأوۏشەأثؼزأڬتلشأىۄأۄًأدتىتأڬۄأتۏڬأزًضشەأڬۏأڲشزىۏڽأوتشحەأځہشًأۗ‛‛أأتۏڬأطرظأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ$أتضأ+أذًعأ,أڬتأذدوأڬحىتأۄًأڲتأآأىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أدحىتأ““أتۏهۄأ‛‛أضەأهەأڬشأ““أوڬۄأ‛‛أحڬأڬتأزشوۏتىۏألتظهۄأۄەأ+أۏۄتڽأهلػأڬەأثتشەأوۏڽأشتًۏأڬًأطڬأۄەأ,أتضأڬەأثشحىأضحتشًڽأڬۏأحؼزتزأضەأصۏتزۄأۄًڽأڲەأ؏أواوىأتىأوۏڽأضەأڬًةۏأثشحىأځڬڔەأڲتأتًشأځہشأًۄأتضەأشڬہەأڲتأىۄۏڽأڬۄأتضأضەأځۄهەأڬًةۏأزًضشتأتضەأځڬڔأهەأڲتأۗ‛‛أأۏۄأشًتۏحأتوتوأثصتشأىەأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأؼثۏزۄأثىأتضًزأۄەأ؏أدضەأتۏڬأضەأصۏتزۄأتلشتزأىەأعؼۏلأمشتشأزۏتأۄەأتثىأذثتىأىەأڬحتثأتهخمتحأوۏڽأۏۄأثتحأثۏتىأڬۏأۄەأ=أتضأڬۏأذزۏخأڬتأتؼحثتشأڬۏتأدتةەأڲتأ؏أدثأۏۄأڬضۏأخمۄأشتًۏأضەأضوتؼأڬۏأًعتذحأڬشأزەأ؏أتًشأتضأڬەأثؼزأًتهتأشتًۏأثہۏأخمۄأۄًأ؏أتضأشًتۏحأڬەأثمۏۄأشدتهأڬۏأحًخۏمأڬۏأڲةۏأۄەأتڲشډۄأتىأوۏڽأضەأثؼعأوۏڽأعؼلأځتۏتأدتحتأۄەأۗ

[تخریج]: حديث : 18472 - اخرجه البزار في المسند """" (3482)"
18473,"ألشصزمأثۏتىأڬشحەأۄۏڽأ=أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأىەأودہأضەألشوتۏتأ=أتەألشصزمأ$أوۏڽأزۏڬہأشۄتأۄًڽأڬۄأحوۄتشەأځتاڽأډہًټەأۄۏڽأ؏أتڲشأحوۄتشەأهۏەأۏۄأووڬىأۄًأڬۄأذًعأڬەأځتضأتىأزًىًڽأڬەأهۏەأڬًةۏأدڲۄأثىتأضڬحەأۄًأ؏أحًأحوأتۏضتأڬشأهۏىتأ؏أوۏڽأىەأىثۏأتڬشوأ﷽أڬًأۏۄأتشطتزألشوتحەأۄًةەأضىتأۄەأ=أ““أوۏشتأذًعأ؏أؼوتىأتًشأتۏهۄأڬەأزشوۏتىألتظهەأدحىتأۄەأ؏أتضأڬتأځتىۏأزًزہأضەأصۏتزۄأضلۏزأ؏أطۄزأضەأصۏتزۄأوۏټہتأۄەأ؏أتضأڬەأثشحىأإضوتىأڬەأضحتشًڽأڬۏأحؼزتزأدحىەأۄۏڽأ؏أدًأطرظأتضأوۏڽأضەأځۏأهەأڲتأًۄأڬثہۏأځۏتضتأىۄۏڽأۄًأڲتأۗ‛‛"
18474,"أتۏڬأشًتۏحأوۏڽأۏۄأتهلتػأۄۏڽأ=أ““أوۏشەأذًعأځشأوۏشۏأتوحأًتشزأۄًأڲۏأ؏أدًأتحىتأثڔتأۄەأدحىتأظىؼتؤأتًشأۏخشثأڬەأزشوۏتىألتظهۄأۄەأۗ‛‛أأ+أؼهتوۄأۄۏخوۏألشوتحەأۄۏڽأ=أ,أوۏڽأۏۄأڬۄحتأۄًڽأ=أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأوىمًهأتۏڬأذزۏخأ““أظذۏذأ‛‛أوۏڽأوسڬًشأۄەأ؏أدًأتضأشًتۏحأڬەأؼهتًۄأۄەأۗأأۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأتًشألشصزمأىتوۏأشتًۏأڬًأتثىأذثتىأىەأعؼۏلأمشتشأزۏتأۄەأۗ"
18475,"أذعشحأتىضأثىأوتهڬأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أأ““أوۏشتأتۏڬأذًعأۄەأتًشأوۏڽأتضأځشأحوۄتشتأځۏطشًأۄًاڽأڲتأۗ‛‛أأ+أؼهتوۄأۄۏخوۏألشوتحەأۄۏڽأ=أ,أوۏڽأۏۄأڬۄحتأۄًڽأ=أۏۄأشًتۏحأ““أظذۏذأ‛‛أوۏڽأترحظتشأڬەأضتحہأوسڬًشأۄەأ=†أوۏڽأحوۄتشتأځۏطشًأۄًاڽأڲتأ‟ۗأأۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأظؽۏشأوۏڽأذضىأضىزأڬەأضتحہأىمهأڬۏأۄەأۗ

[تخریج]: حدیث : 18475 - اخرجه الطبراني في """"المعجم الصغير (1027)"
18476,"أذعشحأؼشثتعأثىأضتشۏۄأشعۏأتههۄأؼىۄأىثۏأتڬشوأ﷽أڬتأۏۄألشوتىأىمهأڬشحەأۄۏڽأ=أأ““أۏۄأتوحأذًعأځشأۏًڽأۄدًوأڬشەأڲۏأ؏أدضأغشذأځتىۏأځۏىەأ؏أدضأغشذأځتىۏأځۏىەأڬەأهۏەأإىەأًتهەأتًىټًڽأڬتأۄدًوأۄًحتأۄەأۗ‛‛أۏۄأشًتۏحأتوتوأغثشتىۏأىەأزًأتضىتزأڬەأضتحہأىمهأڬۏأۄەأتًشأتىأزًىًڽأوۏڽأضەأتۏڬأذضىأۄەأۗ

[تخریج]: حديث : 18476 - اخرجه الطبراني في """"المعجم الكبير """" (253/18)"
18477,"أذعشحأؼثزتههۄأثىأؼوشأشعۏأتههۄأؼىۄوتأىثۏأتڬشوأ﷽أڬتأۏۄألشوتىأىمهأڬشحەأۄۏڽأ=أأ““أوۏشتأذًعأتحىتأثڔتأۄەأدحىتأؼزىأتًشأؼوتىأڬەأزشوۏتىألتظهۄأۄەأ+أتضأڬتأوطشًثأ,أثشلأضەأصۏتزۄأضلۏزأ؏أطۄزأضەأصۏتزۄأوۏټہتأتًشأوطڬأضەأصۏتزۄأرًطثًزتشأۄەأ؏أتضأضەأثشحىأإضوتىأڬەأضحتشًڽأڬۏأوتىىزأۄۏڽأدًأطرظأتضأوۏڽأضەأتۏڬأوشحثۄأځۏأهەأڲتأًۄأتضأڬەأثؼزأڬثہۏأځۏتضتأىۄۏڽأۄًأڲتأ؏أتضأذًعأځشأضثأضەأځۄهەأؽشۏثأوۄتدشۏىأإةۏڽأڲەأ؏أذتعشۏىأوۏڽأضەأڬضۏأىەأزشۏتلحأڬۏتأ=أۏتأشضًهأتههۄأ$أًۄأڬًىأۄًڽأڲەأآأىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أدىأڬەأثتهأثڬہشەأۄًةەأۄًڽأڲەأ؏أدىأڬەأډۄشەأوحؽۏشأۄًڽأڲەأ؏أتىأڬەأڬځڔەأوۏهەأۄًڽأڲەأتىأڬەأهۏەأزشًتصەأىۄۏڽأڬہًهەأدتحەأۄًڽأڲەأ؏أًۄأرًطذتهأؼًشحًڽأڬەأضتحہأىڬتذأىۄۏڽأڬشأضڬحەأۄًڽأڲەأ؏أدًأتىأڬۏأسوۄأزتشۏأحہۏأًۄأتىۄًڽأىەأځًشۏأڬۏأۄًأڲۏأتًشأدًأتىأڬتأذمأحہتأًۄأتىۄًڽأىەأًظًهأىۄۏڽأڬۏتأۄًأڲتأۗ‛‛أ+أؼهتوۄأۄۏخوۏألشوتحەأۄۏڽأ=أ,أوۏڽأۏۄأڬۄحتأۄًڽأ=أذعشحأؼثزتههۄأثىأؼوشأشعۏأتههۄأؼىۄوتأضەأوىمًهأذزۏخأ““أظذۏذأ‛‛أوۏڽأوسڬًشأۄەأ؏أدًأتضأضۏتمأڬەأثؽۏشأۄەأتًشأۏۄأزشضحأۄەأتًشأهًڲًڽأڬۏأشًتۏحأڬەأوغتثمأۄەأدثڬۄأ““أظذۏذأ‛‛أوۏڽأدًأشًتۏحأۄەأتضأوۏڽأۏۄأوسڬًشأۄەأ=““أدحىتأدشثۏأتًشأتسشذأڬەأزشوۏتىألتظهۄأۄەأۗ‛‛أذتهتىڬۄأۏۄأزًىًڽأتۏضۏأثضحۏتڽأۄۏڽأ؏أدًأتۏڬأزًضشەأڬەأځۄهًأوۏڽأۄۏڽأۗأۄوتشەأتۏڬأتضحتزأطۏرأؼهتوۄأظهتذأتهزۏىأتهؼهتةۏأىەألشوتۏتأۄەأ=أطتۏزأتضأوۏڽأضەأتۏڬأهلػأشۄأڲۏتأۄەأ+أتًشأتظهأدوهۄأۏًڽأۄًىتأډتۄۏەأ=أ,أدضأغشذأحوأهًڲًڽأڬەأتًشأدشثۏأتًشأتسشذأڬەأزشوۏتىألتظهۄأۄەأۗأۏۄأثتحأوۏڽأىەأتىأضەأضىۏأۄەأۗأأۏۄأشًتۏحأتوتوأتذوزأتًشأتوتوأغثشتىۏأىەأؼوشًأثىأؼوشأتذوًضۏٳأڬۏأورتشمأثىأتثًورتشمأڬەأذًتهەأضەأىمهأڬشزۄأشًتۏحأڬەأغًشأځشأىمهأڬۏأۄەأتًشأتضأڬەأثتځأڬتأىتوأؼثزتههۄأثىأدتثشأۄەأتثىأذثتىأىەأتىأزًىًڽأڬتأحسڬشۄأڬحتثأتهخمتحأوۏڽأڬۏتأۄەأتوتوأتذوزأڬەأتضحتزأتثًوؽۏشۄأظذۏذأڬەأشدتهأوۏڽأضەأۄۏڽأۗ

[تخریج]: حدیث : 18477 - اخرجه احمد في """"المسند"""" (6162)"
18478,"أذعشحأتثًتوتوۄأثتۄهۏأشعۏأتههۄأؼىۄأىثۏأتڬشوأ﷽أڬتأۏۄألشوتىأىمهأڬشحەأۄۏڽأ=أأ““أوۏشتأذًعأتحىتأۄەأدحىتأؼزىأتًشأؼوتىأڬەأزشوۏتىألتظهۄأۄەأ؏أتضأوۏڽأإضوتىأڬەأضحتشًڽأڬۏأحؼزتزأوۏڽأثشحىأۄۏڽأ؏أدًأطرظأتضأوۏڽأضەأځۏأهەأڲتأًۄأتضأڬەأثؼزأڬثہۏأځۏتضتأىۄۏڽأۄًأڲتأ؏أوۏشۏأتوحأڬەأدًأهًڲأتضأذًعأځشأوۏشەأځتضأإةۏڽأڲەأتىأوۏڽأڬډہأهًڲأثڬہشەأۄًةەأثتهًڽأًتهەأوۏهەأڬځڔًڽأًتهەأۄًڽأڲەأدًأرًطذتهأؼًشحًڽأڬەأضتحہأطتزۏأىۄۏڽأڬشأضڬحەأتًشأىۄأۄۏأثىزأزشًتصًڽأځشأإأضڬحەأۄۏڽأ؏أشتًۏأڬۄحەأۄۏڽأ=أتضأضەأوشتزأۏۄأۄەأڬۄأذڬوشتىأڬەأزشًتصەأځشأىۄۏڽأإأضڬحەأۗأ+أىثۏأتڬشوأ﷽أىەألشوتۏتأ=أ,أتىۄًڽأىەأًۄأډۏصأتزتأڬشأزۏأۄًأڲۏأدًأتىأڬەأسوۄأۄًأڲۏأتًشأتىۄۏڽأًۄأډۏصأىۄۏڽأزۏأڲةۏأۄًأڲۏأدًأتىأڬتأذمأۄًأڲتأۗ‛‛أۏۄأشًتۏحأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأتًشأتضأڬەأثؼعأشدتهأوۏڽأوًدًزأعؼلأڬەأثتًدًزأتضأڬەأشدتهأڬۏأحًخۏمأڬۏأڲةۏأۄەأۗ

