{"metadata":{"name":"Sunan Ibn Majah","section":{"9":"The Chapters on Marriage"},"section_detail":{"9":{"hadithnumber_first":1845,"hadithnumber_last":2015,"arabicnumber_first":1845,"arabicnumber_last":2015}}},"hadiths":[{"hadithnumber":1992,"arabicnumber":1992,"text":"Rapporté par 'Aishah : Le Messager d’Allah lui a dit d’emmener une femme chez son mari avant qu’il ne lui ait rien donné (c’est-à-dire la dot). (Da'if)","grades":[{"name":"Al-Albani","grade":"Daif"},{"name":"Muhammad Fouad Abd al-Baqi","grade":"Daif"},{"name":"Shuaib Al Arnaut","grade":"Daif"},{"name":"Zubair Ali Zai","grade":"Daif"}],"reference":{"book":9,"hadith":148}}]}