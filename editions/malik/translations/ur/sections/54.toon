{"hadithnumber": "1763", "text": "عبیداللہ بن عبداللہ بن عتبہ بن مسعود رحمہ اللہ سے روایت ہے کہ بلاشبہ وہ حضرت ابوطلحہ انصاری رضی اللہ"}
{"hadithnumber": "1764", "text": "سیدہ عائشہ رضی اللہ عنہا زوجہ پیغمبر ﷺ سے روایت ہے کہ انھوں نے ایک چھوٹا تکیہ خریدا جس میں تصویریں ت"}
{"hadithnumber": "1765", "text": "سلیمان بن یسار رحمہ اللہ سے روایت ہے ، کہتے ہیں : رسول اللہ ﷺ ( اپنی زوجہ محترہ ) سیدہ میمونہ بنت حا"}
{"hadithnumber": "1766", "text": "حضرت خالد بن ولید بن مغیرہ رضی اللہ عنہ سے روایت ہے ، وہ رسول اللہ ﷺ کے ہمراہ سیدہ میمونہ رضی اللہ ع"}
{"hadithnumber": "1767", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ ایک آدمی نے رسول اللہ ﷺ کو پکارا اور عرض کیا کہ اے"}
{"hadithnumber": "1768", "text": "حضرت سفیان بن ابی زہیر رضی اللہ عنہ جو کہ اَزْدِشنُوء ہ قبیلے میں سے ایک فرد ( تھے اور ) رسول اللہ ﷺ"}
{"hadithnumber": "1769", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ نے فرمایا :’’ جس شخص نے کوئی بھ"}
{"hadithnumber": "1770", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ بے شک رسول اللہ ﷺ نے کتوں کے قتل کرنے کا حکم فرمای"}
{"hadithnumber": "1771", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ بے شک رسول اللہ ﷺ نے فرمایا :’’ کفر کا سر ( بڑا کفر ) مشرق"}
{"hadithnumber": "1772", "text": "حضرت ابوسعید خدری رضی اللہ عنہ سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا :’’ قریب ہے کہ مسلمان کا بہترین"}
{"hadithnumber": "1773", "text": "حضرت ابن عمر رضی اللہ عنہما سے روایت ہے کہ یقیناً رسول اللہ ﷺ نے فرمایا :’’ کوئی بھی شخص کسی دوسرے ش"}
{"hadithnumber": "1774", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ بلاشبہ رسول اللہ ﷺ نے فرمایا :’’ کوئی نبی ایسا نہیں ہوا جس نے"}
{"hadithnumber": "1775", "text": "نافع رحمہ اللہ سے روایت ہے کہ بیشک حضرت ابن عمر رضی اللہ عنہما کے سامنے شام کا کھانا پیش کر دیا جاتا"}
{"hadithnumber": "1776", "text": "سیدہ میمونہ رضی اللہ عنہا زوجہ پیغمبر ﷺ سے روایت ہے کہ یقیناً رسول اللہ ﷺ سے چوہے کے متعلق سوال کیا"}
{"hadithnumber": "1777", "text": "سہل بن سعد ساعدی رضی اللہ عنہ سے روایت ہے کہ بیشک رسول اللہ ﷺ نے فرمایا :’’ اگر وہ ہوتی تو گھوڑے ، ع"}
{"hadithnumber": "1778", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ نے فرمایا :’’ نحوست تو گھر ، عو"}
{"hadithnumber": "1779", "text": "یحیی بن سعید رحمہ اللہ سے روایت ہے ، کہتے ہیں کہ ایک عورت رسول اللہ ﷺ کے پاس آئی اور کہنے لگی کہ اے"}
{"hadithnumber": "1780", "text": "یحیی بن سعید رحمہ اللہ سے روایت ہے کہ بے شک رسول اللہ ﷺ نے بہت دودھ دینے والی ( دودھیل ) اونٹنی جس ک"}
{"hadithnumber": "1781", "text": "یحیی بن سعید رحمہ اللہ سے روایت ہے کہ بلاشبہ حضرت عمر بن خطاب رضی اللہ عنہ نے ایک آدمی سے کہا : تمھا"}
