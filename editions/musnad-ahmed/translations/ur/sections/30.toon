9858,"أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأدىتثأشضًهأتههۄأ﷽أىەأتشطتزألشوتۏتأدتىًشأضەأوشىەأًتهەأڬتأرًىأشتةۏڲتڽأۄەأ؏أڬىًۏڽأوۏڽأڲشأڬشأوشىەأًتهەأڬتأرًىأشتةۏڲتڽأۄەأ؏أڬتىأوۏڽأوشىەأًتهەأڬتأرًىأثہۏأشتةۏڲتڽأۄەأ؏أتًشأًۄأزلۏىۄأدًأڬضۏأڬەأۄتحہأهڲأدتةەأ؏أتضأوۏڽأروضأ+أځتىډًتڽأذظۄأ,أًتدثأۄەأۗ"
