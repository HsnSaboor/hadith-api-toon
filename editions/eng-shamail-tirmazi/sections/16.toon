metadata:
  section_id: 16
  section_name: Chapter 16
  hadith_first: 110
  hadith_last: 114

hadiths[5]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
110,“The Prophet (Allah bless him and give him peace) entered Mecca on the Day of Victory wearing a black turban.”,,,48825,"Jabir said:",Chapter 16
111,"""I saw a black turban on the head of Allah’s Messenger (Allah bless him and give him peace).”",,,48826,"'Amr ibn Huraith reported that his father said:",Chapter 16
112,"""The Prophet (Allah bless him and give him peace) addressed the people while wearing a black turban.”",,,48827,"'Amr ibn Huraith reported that his father said:",Chapter 16
113,"""When the Prophet (Allah bless him and give him peace) donned a turban, he let his turban hang down between his shoulders.”",,,48828,"Ibn 'Umar said:",Chapter 16
114,“The Prophet (Allah bless him and give him peace) addressed the people while wearing a turban that was dasma’ .,,,48829,"Ibn 'Abbas said:",Chapter 16
