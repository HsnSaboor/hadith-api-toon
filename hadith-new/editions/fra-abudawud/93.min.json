{"metadata":{"name":"Sunan Abu Dawud","section":{"1":"Purification (Kitab Al-Taharah)"},"section_detail":{"1":{"hadithnumber_first":1,"hadithnumber_last":390,"arabicnumber_first":1,"arabicnumber_last":390}}},"hadiths":[{"hadithnumber":93,"arabicnumber":93,"text":"Rapporté par Jabir ibn Abdullah رضي الله عنه : Le Prophète ﷺ prenait un bain rituel avec un sa‘ (de l’eau) et faisait ses ablutions avec un mudd (de l’eau)","grades":[{"name":"Al-Albani","grade":"Sahih"},{"name":"Muhammad Muhyi Al-Din Abdul Hamid","grade":"Sahih"},{"name":"Zubair Ali Zai","grade":"Sahih"}],"reference":{"book":1,"hadith":93}}]}