{"hadithnumber": "948", "text": "ہم سے ابوالیمان نے بیان کیا، انہوں نے کہا کہ ہمیں شعیب نے زہری سے خبر دی، انہوں نے کہا کہ مجھے سالم"}
{"hadithnumber": "950", "text": "اور یہ عید کا دن تھا۔ حبشہ کے کچھ لوگ ڈھالوں اور برچھوں سے کھیل رہے تھے۔ اب خود میں نے کہا یا نبی کر"}
{"hadithnumber": "951", "text": "ہم سے حجاج بن منہال نے بیان کیا، کہا کہ ہم سے شعبہ نے بیان کیا، انہیں زبید بن حارث نے خبر دی، انہوں"}
{"hadithnumber": "952", "text": "ہم سے عبید بن اسماعیل نے بیان کیا، انہوں نے کہا کہ ہم سے ابواسامہ نے بیان کیا، ان سے ہشام بن عروہ نے"}
{"hadithnumber": "953", "text": "ہم سے محمد بن عبدالرحیم نے بیان کیا کہ ہم کو سعید بن سلیمان نے خبر دی کہ ہمیں ہشیم بن بشیر نے خبر دی"}
{"hadithnumber": "954", "text": "ہم سے مسدد بن مسرہد نے بیان کیا، کہا کہ ہم سے اسماعیل بن علیہ نے ایوب سختیانی سے، انہوں نے محمد بن س"}
{"hadithnumber": "955", "text": "ہم سے عثمان بن ابی شیبہ نے بیان کیا، انہوں نے کہا کہ ہم سے جریر نے بیان کیا، ان سے منصور نے، ان سے ش"}
{"hadithnumber": "956", "text": "ہم سے سعید بن ابی مریم نے بیان کیا، انہوں نے کہا کہ ہم سے محمد بن جعفر نے بیان کیا، انہوں نے کہا کہ"}
{"hadithnumber": "957", "text": "ہم سے ابراہیم بن المنذر حزامی نے بیان کیا، انہوں نے کہا کہ ہم سے انس بن عیاض نے بیان کیا، انہوں نے ع"}
{"hadithnumber": "961", "text": "اور جابر بن عبداللہ سے روایت ہے کہ   ( عید کے دن )  نبی کریم صلی اللہ علیہ وسلم کھڑے ہوئے، پہلے آپ ص"}
{"hadithnumber": "962", "text": "ہم سے ابوعاصم نے بیان کیا، انہوں نے کہا کہ ہمیں ابن جریج نے خبر دی، انہوں نے کہا مجھے حسن بن مسلم نے"}
{"hadithnumber": "963", "text": "ہم سے یعقوب بن ابراہیم نے بیان کیا، انہوں نے کہا کہ ہم سے ابواسامہ حماد بن ابواسامہ نے بیان کیا، انہ"}
{"hadithnumber": "964", "text": "ہم سے سلیمان بن حرب نے بیان کیا، کہا ہم سے شعبہ نے، انہوں نے عدی بن ثابت سے، انہوں نے سعید بن جبیر س"}
{"hadithnumber": "965", "text": "ہم سے آدم بن ابی ایاس نے بیان کیا کہ ہم سے شعبہ نے بیان کیا، کہا کہ ہم سے زبید نے بیان کیا، کہا کہ م"}
{"hadithnumber": "966", "text": "ہم سے زکریا بن یحییٰ ابوالسکین نے بیان کیا، انہوں نے کہا کہ ہم سے عبدالرحمٰن محاربی نے بیان کیا، کہا"}
{"hadithnumber": "967", "text": "ہم سے احمد بن یعقوب نے بیان کیا، کہا کہ ہم سے اسحاق بن سعید بن عمرو بن سعید بن عاص نے اپنے باپ سے بی"}
{"hadithnumber": "968", "text": "ہم سے سلیمان بن حرب نے بیان کیا، کہا کہ ہم سے شعبہ نے زبید سے بیان کیا، ان سے شعبی نے، ان سے براء بن"}
{"hadithnumber": "969", "text": "ہم سے محمد بن عرعرہ نے بیان کیا، انہوں نے کہا کہ ہم سے شعبہ نے سلیمان کے واسطے سے بیان کیا، ان سے مس"}
{"hadithnumber": "970", "text": "ہم سے ابونعیم نے بیان کیا، کہا کہ ہم سے امام مالک بن انس نے بیان کیا، کہا کہ مجھ سے محمد بن ابی بکر"}
{"hadithnumber": "971", "text": "ہم سے محمد نے بیان کیا، کہا کہ ہم سے عمر بن حفص بن غیاث نے بیان کیا، کہا کہ مجھ سے میرے باپ نے عاصم"}
{"hadithnumber": "972", "text": "ہم سے محمد بن بشار نے بیان کیا، کہا کہ ہم سے عبدالوہاب ثقفی نے بیان کیا، کہا کہ ہم سے عبیداللہ عمری"}
{"hadithnumber": "973", "text": "ہم سے ابراہیم بن المنذر حزامی نے بیان کیا، کہا کہ ہم سے ولید بن مسلم نے بیان کیا، کہا کہ ہم سے ابوعم"}
{"hadithnumber": "974", "text": "ہم سے عبداللہ بن عبدالوہاب نے بیان کیا، کہا کہ ہم سے حماد بن زید نے بیان کیا، ان سے ایوب سختیانی نے،"}
{"hadithnumber": "975", "text": "ہم سے عمرو بن عباس نے بیان کیا، انہوں نے کہا کہ ہم سے عبدالرحمٰن بن مہدی نے بیان کیا، انہوں نے کہا ک"}
{"hadithnumber": "976", "text": "ہم سے ابونعیم فضل بن دکین نے بیان کیا، کہا کہ ہم سے محمد بن طلحہ نے بیان کیا، ان سے زبید نے، ان سے ش"}
{"hadithnumber": "977", "text": "ہم سے مسدد نے بیان کیا، کہا کہ ہم سے یحییٰ بن سعید قطان نے سفیان ثوری سے بیان کیا، کہا کہ مجھ سے عبد"}
{"hadithnumber": "978", "text": "ہم سے اسحاق بن ابراہیم بن نصر نے بیان کیا، کہا کہ ہم سے عبدالرزاق نے بیان کیا، کہا کہ ہمیں ابن جریج"}
{"hadithnumber": "979", "text": "ابن جریج نے کہا کہ حسن بن مسلم نے مجھے خبر دی، انہیں طاؤس نے، انہیں عبداللہ بن عباس رضی اللہ عنہما ن"}
{"hadithnumber": "980", "text": "ہم سے ابومعمر نے بیان کیا، انہوں نے کہا کہ ہم سے عبدالوارث نے بیان کیا، انہوں نے کہا کہ ہم سے ایوب س"}
{"hadithnumber": "981", "text": "ہم سے محمد بن مثنی نے بیان کیا، انہوں نے کہا کہ ہم سے محمد بن ابراہیم ابن ابی عدی نے بیان کیا، ان سے"}
{"hadithnumber": "982", "text": "ہم سے عبداللہ بن یوسف تنیسی نے بیان کیا، کہا کہ ہم سے لیث نے بیان کیا، کہا کہ مجھ سے کثیر بن فرقد نے"}
{"hadithnumber": "983", "text": "ہم سے مسدد بن مسرہد نے بیان کیا، کہا کہ ہم سے ابوالاحوص سلام بن سلیم نے بیان کیا، کہا کہ ہم سے منصور"}
{"hadithnumber": "984", "text": "ہم سے حامد بن عمر نے بیان کیا، ان سے حماد بن زید نے، ان سے ایوب سختیانی نے، ان سے محمد نے، ان سے انس"}
{"hadithnumber": "985", "text": "ہم سے مسلم بن ابراہیم نے بیان کیا، کہا کہ ہم سے شعبہ نے بیان کیا، ان سے اسود بن قیس نے، ان سے جندب ن"}
{"hadithnumber": "986", "text": "ہم سے محمد بن سلام نے بیان کیا، انہوں نے کہا کہ ہمیں ابوتمیلہ یحییٰ بن واضح نے خبر دی، انہیں فلیح بن"}
{"hadithnumber": "988", "text": "اور عائشہ رضی اللہ عنہا نے کہا  میں نے  ( ایک دفعہ )  نبی کریم صلی اللہ علیہ وسلم کو دیکھا کہ آپ صلی"}
{"hadithnumber": "989", "text": "ہم سے ابوولید نے بیان کیا، کہا کہ ہم سے شعبہ نے بیان کیا، کہا کہ مجھے عدی بن ثابت نے خبر دی، انہوں ن"}
