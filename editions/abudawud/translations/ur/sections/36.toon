{"hadithnumber": "4214", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے بعض شاہان عجم کو خط لکھنے کا ا"}
{"hadithnumber": "4215", "text": "اس سند سے بھی انس سے عیسیٰ بن یونس کی روایت کے ہم معنی حدیث مروی ہے، اور اس میں یہ اضافہ ہے کہ  پھر"}
{"hadithnumber": "4216", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کی انگوٹھی چاندی کی تھی، اس کا نگینہ حبشی"}
{"hadithnumber": "4217", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کی پوری انگوٹھی چاندی کی تھی، اس ک"}
{"hadithnumber": "4218", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے سونے کی انگوٹھی بنائی، اس"}
{"hadithnumber": "4219", "text": "اس سند سے بھی ابن عمر رضی اللہ عنہما سے اس روایت میں مرفوعاً مروی ہے اس میں ہے کہ  نبی اکرم صلی اللہ"}
{"hadithnumber": "4220", "text": "اس سند سے بھی ابن عمر رضی اللہ عنہما سے مرفوعاً یہی حدیث مروی ہے، اس میں یہ اضافہ ہے کہ  لوگوں نے اس"}
{"hadithnumber": "4221", "text": "انس بن مالک رضی اللہ عنہ سے روایت ہے کہ  انہوں نے ایک دن رسول اللہ صلی اللہ علیہ وسلم کے ہاتھ میں چا"}
{"hadithnumber": "4222", "text": "عبداللہ بن مسعود رضی اللہ عنہ کہتے تھے کہ  اللہ کے نبی کریم صلی اللہ علیہ وسلم دس خصلتیں ناپسند فرما"}
{"hadithnumber": "4223", "text": "بریدہ رضی اللہ عنہ کہتے ہیں کہ  ایک شخص نبی اکرم صلی اللہ علیہ وسلم کی خدمت میں آیا، وہ پتیل کی انگو"}
{"hadithnumber": "4224", "text": "معیقیب رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کی انگوٹھی لوہے کی تھی اس پر چاندی کی پ"}
{"hadithnumber": "4225", "text": "علی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مجھ سے فرمایا:  کہو: اے اللہ! مجھے ہدا"}
{"hadithnumber": "4226", "text": "علی رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم سے ابوسلمہ بن عبدالرحمٰن نے بھی بیان کیا ہ"}
{"hadithnumber": "4227", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم انگوٹھی اپنے بائیں ہاتھ میں پ"}
{"hadithnumber": "4228", "text": "نافع سے روایت ہے کہ  ابن عمر رضی اللہ عنہما انگوٹھی اپنے بائیں ہاتھ میں پہنتے تھے۔"}
{"hadithnumber": "4229", "text": "محمد بن اسحاق کہتے ہیں کہ میں نے صلت بن عبداللہ بن نوفل بن عبدالمطلب کو اپنے داہنے ہاتھ کی چھنگلی می"}
{"hadithnumber": "4230", "text": "عامر بن عبداللہ بن زبیر کہتے ہیں کہ  ان کی ایک لونڈی زبیر کی ایک بچی کو عمر بن خطاب رضی اللہ عنہ کے"}
{"hadithnumber": "4231", "text": "عبدالرحمٰن بن حسان کی لونڈی بنانہ کہتی ہیں کہ  وہ ام المؤمنین عائشہ رضی اللہ عنہا کے پاس تھیں کہ اسی"}
{"hadithnumber": "4232", "text": "عبدالرحمٰن بن طرفہ کہتے ہیں کہ  کے دادا عرفجہ بن اسعد کی ناک جنگ کلاب ۱؎ کے دن کاٹ لی گئی، تو انہوں"}
{"hadithnumber": "4233", "text": "اس سند سے بھی عرفجہ بن اسعد سے اسی مفہوم کی حدیث مروی ہے، یزید کہتے ہیں  میں نے ابواشہب سے پوچھا: عب"}
{"hadithnumber": "4234", "text": "اس سند سے بھی اسی مفہوم کی  حدیث مروی ہے۔"}
{"hadithnumber": "4235", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کے پاس نجاشی کی طرف سے کچھ"}
{"hadithnumber": "4236", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو اپنے محبوب کو آگ کا ب"}
{"hadithnumber": "4237", "text": "حذیفہ کی بہن سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اے عورتوں کی جماعت! کیا زیور ب"}
{"hadithnumber": "4238", "text": "اسماء بنت یزید رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس عورت نے سونے ک"}
{"hadithnumber": "4239", "text": "معاویہ بن ابی سفیان رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے چیتوں کی کھال پر"}
