{"hadithnumber": "2260", "text": "ہم سے محمد بن یوسف نے بیان کیا، کہا کہ ہم سے سفیان ثوری نے بیان کیا، ان سے ابوبردہ یزید بن عبداللہ ن"}
{"hadithnumber": "2261", "text": "ہم سے مسدد نے بیان کیا کہا کہ ہم سے یحییٰ بن سعید قطان نے بیان کیا، ان سے قرۃ بن خالد نے کہا کہ مجھ"}
{"hadithnumber": "2262", "text": "ہم سے احمد بن محمد مکی نے بیان کیا، کہا کہ ہم سے عمرو بن یحییٰ نے بیان کیا، ان سے ان کے دادا سعید بن"}
{"hadithnumber": "2263", "text": "ہم سے ابراہیم بن موسیٰ نے بیان کیا، کہا کہ ہم کو ہشام بن عروہ نے خبر دی، انہیں معمر نے، انہیں زہری ن"}
{"hadithnumber": "2264", "text": "ہم سے یحییٰ بن بکیر نے بیان کیا، کہا کہ ہم سے لیث نے بیان کیا، انہوں نے کہا کہ ہم سے عقیل نے کہ ابن"}
{"hadithnumber": "2266", "text": "ابن جریج نے کہا اور مجھ سے عبداللہ بن ابی ملیکہ نے بیان کیا اور ان سے ان کے دادا نے بالکل اسی طرح کا"}
{"hadithnumber": "2267", "text": "ہم سے ابراہیم بن موسیٰ نے بیان کیا، کہا کہ ہم کو ہشام بن یوسف نے خبر دی، کہا کہ مجھے یعلیٰ بن مسلم ا"}
{"hadithnumber": "2268", "text": "ہم سے سلیمان بن حرب نے بیان کیا، ان سے حماد بن زید نے بیان کیا، ان سے ایوب سختیانی نے، ان سے نافع نے"}
{"hadithnumber": "2269", "text": "ہم سے اسماعیل بن ابی اویس نے بیان کیا، انہوں نے کہا کہ مجھ سے امام مالک نے بیان کیا، ان سے عبداللہ ب"}
{"hadithnumber": "2270", "text": "ہم سے یوسف بن محمد نے بیان کیا، کہا کہ مجھ سے یحییٰ بن سلیم نے بیان کیا، ان سے اسماعیل بن امیہ نے، ا"}
{"hadithnumber": "2271", "text": "ہم سے محمد بن علاء نے بیان کیا، کہا کہ ہم سے ابواسامہ نے بیان کیا، ان سے یزید بن عبداللہ نے، ان سے ا"}
{"hadithnumber": "2272", "text": "ہم سے ابوالیمان نے بیان کیا، انہوں نے کہا کہ ہم کو شعیب نے خبر دی، انہیں زہری نے خبر دی، ان سے سالم"}
{"hadithnumber": "2273", "text": "ہم سے سعید بن یحییٰ بن سعید نے بیان کیا، کہا کہ مجھ سے میرے باپ (یحییٰ بن سعید قریش) نے بیان کیا، ان"}
{"hadithnumber": "2274", "text": "ہم سے مسدد نے بیان کیا، کہا کہ ہم سے عبدالواحد بن زیاد نے بیان کیا، ان سے معمر نے بیان کیا، ان سے اب"}
{"hadithnumber": "2275", "text": "ہم سے عمر بن حفص بن غیاث نے بیان کیا، کہا کہ مجھ سے میرے باپ نے بیان کیا، ان سے اعمش نے بیان کیا، ان"}
{"hadithnumber": "2276", "text": "ہم سے ابوالنعمان نے بیان کیا، انہوں نے کہا ہم سے ابوعوانہ نے بیان کیا، ان سے ابوبشر نے بیان کیا، ان"}
{"hadithnumber": "2277", "text": "ہم سے محمد بن یوسف بیکندی نے بیان کیا، کہا کہ ہم سے سفیان بن عیینہ نے بیان کیا، ان سے حمید طویل نے ا"}
{"hadithnumber": "2278", "text": "ہم سے موسیٰ بن اسماعیل نے بیان کیا، کہا کہ ہم سے وہیب نے بیان کیا، کہا کہ ہم سے ابن طاؤس نے بیان کیا"}
{"hadithnumber": "2279", "text": "ہم سے مسدد نے بیان کیا، کہا کہ ہم سے یزید بن زریع نے بیان کیا، ان سے خالد نے، ان سے عکرمہ نے اور ان"}
{"hadithnumber": "2280", "text": "ہم سے ابونعیم نے بیان کیا، انہوں نے کہا کہ ہم سے مسعر نے بیان کیا، ان سے عمرو بن عامر نے بیان کیا کہ"}
{"hadithnumber": "2281", "text": "ہم سے آدم بن ابی ایاس نے بیان کیا، کہا کہ ہم سے شعبہ نے بیان کیا، ان سے حمید طویل نے بیان کیا، اور ا"}
{"hadithnumber": "2282", "text": "ہم سے قتیبہ بن سعید نے بیان کیا، انہوں نے کہا کہ ہم سے امام مالک نے بیان کیا، ان سے ابن شہاب نے بیان"}
{"hadithnumber": "2283", "text": "ہم سے مسلم بن ابراہیم نے بیان کیا، کہا ہم سے شعبہ نے بیان کیا، ان سے محمد بن حجادہ نے بیان کیا، ان س"}
{"hadithnumber": "2284", "text": "ہم سے مسدد بن مسرہد نے بیان کیا، کہا کہ ہم سے عبدالوارث اور اسماعیل بن ابراہیم نے بیان کیا، ان سے عل"}
{"hadithnumber": "2286", "text": "اور رافع بن خدیج رضی اللہ عنہ نے بیان کیا کہ  نبی کریم صلی اللہ علیہ وسلم نے زمینوں کو کرایہ پر دینے"}
