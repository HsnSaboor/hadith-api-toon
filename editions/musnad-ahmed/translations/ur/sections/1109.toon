hadiths[3]{hadithnumber,text}:
27763,أذعشحأغتشمأثىأؼثزتههۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأىثۏأ﷽أىەأتشطتزألشوتۏتأدثأحوأىوتصأځڔہتأڬشًأحًأتځىۏأزتةۏڽأدتىثأۏتأضتوىەأحہًڬأىۄأځہۏىڬتأڬشًأ؏أثهڬۄأتڲشأدڲۄأۄًأحًأځۏډہەأۏتأثتةۏڽأدتىثأحہًڬأهۏتأڬشًأ؏أًشىۄأتضأغشذأڬشأهۏتأڬشًأ؏أۏۄأڬۄۄأڬشأىثۏأ﷽أىەأتځىەأځتاڽأڬەأىۏډەأحہًڬأڬشأتضەأوټۏأوۏڽأوهأزۏتأۗ
27764,أذعشحأغتشمأثىأؼثزتههۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأىثۏأ﷽أىەأتشطتزألشوتۏتأدثأحوأىوتصأځڔہتأڬشًأحًأتځىۏأزتةۏڽأدتىثأۏتأضتوىەأحہًڬأىۄأځہۏىڬتأڬشًأ؏أثهڬۄأتڲشأدڲۄأۄًأحًأځۏډہەأۏتأثتةۏڽأدتىثأحہًڬأهۏتأڬشًأ؏أًشىۄأتضأغشذأڬشأهۏتأڬشًأ؏أۏۄأڬۄۄأڬشأىثۏأ﷽أىەأتځىەأځتاڽأڬەأىۏډەأحہًڬأڬشأتضەأوټۏأوۏڽأوهأزۏتأۗ
27765,أذعشحأغتشمأثىأؼثزتههۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأىثۏأ﷽أىەأتشطتزألشوتۏتأدثأحوأىوتصأځڔہتأڬشًأحًأتځىۏأزتةۏڽأدتىثأۏتأضتوىەأحہًڬأىۄأځہۏىڬتأڬشًأ؏أثهڬۄأتڲشأدڲۄأۄًأحًأځۏډہەأۏتأثتةۏڽأدتىثأحہًڬأهۏتأڬشًأ؏أًشىۄأتضأغشذأڬشأهۏتأڬشًأ؏أۏۄأڬۄۄأڬشأىثۏأ﷽أىەأتځىەأځتاڽأڬەأىۏډەأحہًڬأڬشأتضەأوټۏأوۏڽأوهأزۏتأۗ
