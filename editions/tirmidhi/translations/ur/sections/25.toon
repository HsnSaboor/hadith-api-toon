{"hadithnumber": "1788", "text": "انس رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے کبھی خوان  ( میز وغیرہ )  پر نہیں کھای"}
{"hadithnumber": "1789", "text": "انس رضی الله عنہ کہتے ہیں کہ  ہم نے مقام مرالظہران میں ایک خرگوش کا پیچھا کیا، صحابہ کرام اس کے پیچھ"}
{"hadithnumber": "1790", "text": "عبداللہ بن عمر رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم سے ضب  ( گوہ )  کھانے کے ب"}
{"hadithnumber": "1791", "text": "ابن ابی عمار کہتے ہیں کہ  میں نے جابر رضی الله عنہ سے پوچھا: کیا لکڑبگھا بھی شکار ہے؟ انہوں نے کہا:"}
{"hadithnumber": "1792", "text": "خزیمہ بن جزء رضی الله عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم سے لکڑبگھا کھانے کے بارے"}
{"hadithnumber": "1793", "text": "رسول اللہ صلی اللہ علیہ وسلم نے ہمیں گھوڑے کا گوشت کھلایا، اور گدھے کا گوشت کھانے سے منع فرمایا ۱؎۔"}
{"hadithnumber": "1794", "text": "علی رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے غزوہ خیبر کے موقع پر عورتوں سے نکاح مت"}
{"hadithnumber": "1795", "text": "ابوہریرہ رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے غزوہ خیبر کے دن ہر کچلی دانت و"}
{"hadithnumber": "1796", "text": "ابوثعلبہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم سے مجوس کی ہانڈیوں  ( برتنوں )  کے ب"}
{"hadithnumber": "1797", "text": "ابوثعلبہ خشنی رضی الله عنہ سے روایت ہے کہ  انہوں نے سوال کیا: اللہ کے رسول! ہم لوگ اہل کتاب کی سر زم"}
{"hadithnumber": "1798", "text": "ام المؤمنین میمونہ رضی الله عنہا سے روایت ہے کہ  ایک چوہیا گھی میں گر کر مر گئی، رسول اللہ صلی اللہ"}
{"hadithnumber": "1799", "text": "نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”تم میں سے کوئی آدمی نہ بائیں ہاتھ سے کھائے اور نہ بائیں ہات"}
