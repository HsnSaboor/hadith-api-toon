hadiths[311]{hadithnumber,text}:
299,ہم سے قبیصہ بن عقبہ نے بیان کیا، انہوں نے کہا ہم سے سفیان ثوری نے منصور بن معمر کے واسطے سے، وہ ابرا
300,اور آپ صلی اللہ علیہ وسلم مجھے حکم فرماتے، پس میں ازار باندھ لیتی، پھر آپ صلی اللہ علیہ وسلم میرے سا
329,ہم سے معلی بن اسد نے بیان کیا، کہا ہم سے وہیب بن خالد نے عبداللہ بن طاؤس کے حوالہ سے، وہ اپنے باپ طا
395,ہم سے حمیدی نے بیان کیا، انہوں نے کہا ہم سے سفیان بن عیینہ نے بیان کیا، کہا ہم سے عمرو بن دینار نے،
408,ہم سے سعید بن اسماعیل نے بیان کیا، انہوں نے کہا ہم سے ابراہیم بن سعد نے بیان کیا، انہوں نے کہا ہمیں
410,ہم سے یحییٰ بن بکیر نے بیان کیا، انہوں نے کہا ہم سے لیث بن سعد نے بیان کیا، انہوں نے عقیل بن خالد کے
435,ہم سے ابوالیمان نے بیان کیا، انہوں نے کہا ہم کو شعیب نے خبر دی زہری سے، انہوں نے کہا کہ مجھے عبیدالل
454,ہم سے عبدالعزیز بن عبداللہ نے بیان کیا، انہوں نے کہا ہم سے ابراہیم بن سعد نے بیان کیا، انہوں نے کہا
478,ہم سے حامد بن عمر نے بشر بن مفضل کے واسطہ سے بیان کیا، کہا ہم سے عاصم بن محمد نے، کہا ہم سے واقد بن
521,ہم سے عبداللہ بن مسلمہ نے بیان کیا، انہوں نے کہا کہ میں نے امام مالک رحمہ اللہ علیہ کو پڑھ کر سنایا
533,ہم سے ایوب بن سلیمان مدنی نے بیان کیا، کہا ہم سے ابوبکر عبدالحمید بن ابی اویس نے سلیمان بن بلال کے و
536,ہم سے علی بن عبداللہ مدینی نے بیان کیا، کہا ہم سے سفیان بن عیینہ نے بیان کیا، کہا اس حدیث کو ہم نے ز
570,ہم سے محمود نے بیان کیا، انہوں نے کہا ہم سے عبدالرزاق نے بیان کیا، انہوں نے کہا ہمیں ابن جریج نے خبر
582,ہم سے مسدد نے بیان کیا، کہا ہم سے یحییٰ بن سعید قطان نے ہشام بن عروہ سے، انہوں نے کہا کہ مجھے میرے و
622,مجھ سے اسحاق بن راہویہ نے بیان کیا، انہوں نے کہا ہمیں ابواسامہ حماد بن اسامہ نے خبر دی، کہا ہم سے عب
652,ہم سے قتیبہ بن سعید نے امام مالک سے بیان کیا، انہوں نے ابوبکر بن عبدالرحمٰن کے غلام سمی نامی سے، انہ
653,پھر آپ نے فرمایا کہ  شہداء پانچ قسم کے ہوتے ہیں۔ طاعون میں مرنے والے، پیٹ کے عارضے  ( ہیضے وغیرہ )
655,ہم سے محمد بن عبداللہ بن حوشب نے بیان کیا، انہوں نے کہا کہ ہم سے عبدالوہاب ثقفی نے بیان کیا، انہوں ن
720,ہم سے ابوعاصم ضحاک بن مخلد نے امام مالک کے واسطہ سے بیان کیا، انہوں نے سمی سے، انہوں نے ابوصالح ذکوا
818,ہم سے ابوالنعمان محمد بن فضل نے بیان کیا، کہا کہ ہم سے حماد بن زید نے ایوب سختیانی سے بیان کیا، انہو
832,ہم سے ابوالیمان نے بیان کیا، انہوں نے کہا کہ ہمیں شعیب نے زہری سے خبر دی، انہوں نے کہا کہ ہمیں عروہ
839,ہم سے عبدان نے بیان کیا، کہا کہ ہمیں عبداللہ بن مبارک نے خبر دی کہا کہ ہمیں معمر نے زہری سے خبر دی ک
849,ہم سے ابوالولیدہشام بن عبدالملک نے بیان کیا، انہوں نے کہا کہ ہم سے ابراہیم بن سعد نے بیان کیا انہوں
896,ہم سے مسلم بن ابراہیم نے بیان کیا، کہا کہ ہم سے وہیب بن خالد نے بیان کیا، کہا کہ ہم سے عبداللہ بن طا
949,ہم سے احمد بن عیسیٰ نے بیان کیا، کہا کہ ہم سے عبداللہ بن وہب نے بیان کیا، کہا کہ مجھے عمرو بن حارث ن
958,ہم سے ابراہیم بن موسیٰ نے بیان کیا، کہا کہ ہمیں ہشام نے خبر دی کہ ابن جریج نے انہیں خبر دی، انہوں نے
959,پھر ابن جریج نے کہا کہ مجھے عطاء نے خبر دی کہ  ابن عباس رضی اللہ عنہما نے ابن زبیر رضی اللہ عنہ کے پ
960,اور مجھے عطاء نے ابن عباس اور جابر بن عبداللہ رضی اللہ عنہما کے واسطہ سے خبر دی کہ  عیدالفطر اور عید
987,ہم سے یحییٰ بن بکیر نے بیان کیا، کہا کہ ان سے لیث بن سعد نے بیان کیا، ان سے عقیل نے، ان سے ابن شہاب
1008,ہم سے عمرو بن علی نے بیان کیا، انہوں نے کہا کہ ہم سے ابو قتیبہ نے بیان کیا، کہا کہ ہم سے عبدالرحمٰن
1049,ہم سے عبداللہ بن مسلمہ قعنبی نے بیان کیا، ان سے امام مالک رحمہ اللہ نے، ان سے یحییٰ بن سعید نے، ان س
1055,ہم سے اسماعیل بن عبداللہ بن ابی اویس نے بیان کیا، انہوں نے کہا کہ مجھ سے امام مالک رحمہ اللہ نے یحیی
1065,ہم سے محمد بن مہران نے بیان کیا، انہوں نے کہا کہ ہم سے ولید بن سلم نے بیان کیا، انہوں نے کہا کہ ہم س
1091,ہم سے ابوالیمان نے بیان کیا، انہوں نے کہا کہ ہمیں شعیب نے خبر دی، زہری سے انہوں نے کہا کہ مجھے سالم
1121,ہم سے عبداللہ بن محمد مسندی نے بیان کیا، انہوں نے کہا کہ ہم سے ہشام بن یوسف صنعانی نے بیان کیا، انہو
1156,ہم سے ابوالنعمان نے بیان کیا، کہا کہ ہم سے حماد بن زید نے بیان کیا، ان سے ایوب سختیانی نے، ان سے ناف
1157,میری بہن (ام المؤمنین) حفصہ رضی اللہ عنہا نے رسول اللہ صلی اللہ علیہ وسلم سے میرا ایک خواب بیان کیا
1172,ہم سے مسدد بن مسرہد نے بیان کیا، انہوں نے کہا کہ ہم سے یحییٰ بن سعید قطان نے بیان کیا، ان سے عبیدالل
1180,ہم سے سلیمان بن حرب نے بیان کیا، انہوں نے کہا کہ ہم سے حماد بن زید نے بیان کیا، ان سے ایوب سختیانی ن
1186,محمود نے کہا کہ میں نے عتبان بن مالک انصاری رضی اللہ عنہ سے سنا  جو بدر کی لڑائی میں رسول اللہ صلی ا
1191,ہم سے یعقوب بن ابراہیم نے بیان کیا، انہوں نے کہا کہ ہم سے اسماعیل بن علیہ نے بیان کیا، انہوں نے کہا
1241,ہم سے بشر بن محمد نے بیان کیا، انہیں عبداللہ بن مبارک نے خبر دی، کہا کہ مجھے معمر بن راشد اور یونس ن
1249,ہم سے مسلم بن ابراہیم نے بیان کیا، کہا کہ ہم سے شعبہ نے، ان سے عبدالرحمٰن بن عبداللہ اصبہانی نے، ان
1258,ہم سے حامد بن عمر نے بیان کیا، کہا کہ ہم سے حماد بن زید نے بیان کیا، ان سے ایوب نے، ان سے محمد نے او
1281,ہم سے اسماعیل بن ابی اویس نے بیان کیا ‘ انہوں نے کہا کہ مجھ سے امام مالک نے بیان کیا ‘ ان سے عبداللہ
1286,ہم سے عبد ان نے بیان کیا ‘ انہوں نے کہا کہ ہم سے عبداللہ بن مبارک نے بیان کیا ‘ انہوں نے کہا کہ ہم ک
1287,اس پر عبداللہ بن عباس رضی اللہ عنہما نے بھی تائید کی کہ  عمر رضی اللہ عنہ نے بھی ایسا ہی فرمایا تھا۔
1312,ہم سے آدم بن ابی ایاس نے بیان کیا ‘ کہا کہ ہم سے شعبہ نے بیان کیا ‘ کہا کہ ہم سے عمرو بن مرہ نے بیان
1323,ہم سے ابوالنعمان نے بیان کیا ‘ ان سے جریر بن حازم نے بیان کیا ‘ کہا کہ میں نے نافع سے سنا ‘ آپ نے بی
1327,ہم سے یحییٰ بن بکیر نے بیان کیا ‘ انہوں نے کہا ہم سے لیث نے بیان کیا ‘ ان سے عقیل نے بیان کیا ‘ ان س
1347,ہم سے محمد بن مقاتل نے بیان کیا ‘ انہوں نے کہا کہ ہمیں عبداللہ بن مبارک نے خبر دی ‘ انہوں نے کہا کہ
1354,ہم سے عبدان نے بیان کیا ‘ کہا کہ ہمیں عبداللہ بن مبارک نے خبر دی ‘ انہیں یونس نے ‘ انہیں زہری نے ‘ ک
1363,ہم سے مسدد نے بیان کیا ‘ کہا کہ ہم سے یزید بن زریع نے بیان کیا ‘ کہا کہ ہم سے خالد حذاء نے بیان کیا
1399,ہم سے ابوالیمان حکم بن نافع نے بیان کیا ‘ کہا کہ ہمیں شعیب بن ابی حمزہ نے خبر دی ‘ ان سے زہری نے کہا
1407,ہم سے عیاش بن ولید نے بیان کیا ‘ انہوں نے کہا کہ ہم سے عبدالاعلیٰ نے بیان کیا ‘ کہا کہ ہم سے سعید جر
1427,ہم سے موسیٰ بن اسماعیل نے بیان کیا ‘ کہا کہ ہم سے وہیب نے بیان کیا ‘ کہا کہ ہم سے ہشام بن عروہ نے اپ
1456,ہم سے ابوالیمان نے بیان کیا کہ ہمیں شعیب نے خبر دی اور انہیں زہری نے (دوسری سند) اور لیث بن سعد نے ب
1474,ہم سے یحییٰ بن بکیر نے بیان کیا ‘ انہوں نے کہا کہ ہم سے لیث نے بیان کیا ‘ ان سے عبیداللہ بن ابی جعفر
1481,ہم سے سہل بن بکار نے بیان کیا ‘ کہا کہ ہم سے وہیب بن خالد نے ‘ ان سے عمرو بن یحییٰ نے ‘ ان سے عباس ب
1537,ہم سے محمد بن یوسف فریابی نے بیان کیا، کہا کہ ہم سے سفیان ثوری نے بیان کیا، ان سے منصور نے، ان سے سع
1543,ہم سے عبداللہ بن محمد نے بیان کیا، ان سے وہب بن جریر نے بیان کیا، انہوں نے کہا کہ مجھ سے میرے والد ج
1614,ہم سے اصبغ بن فرج نے بیان کیا، ان سے عبداللہ بن وہب نے بیان کیا کہ مجھے عمرو بن حارث نے محمد بن عبدا
1623,ہم سے قتیبہ بن سعید نے بیان کیا، انہوں نے کہا کہ ہم سے سفیان بن عیینہ نے بیان کیا، ان سے عمرو نے بیا
1630,ہم سے حسن بن محمد زعفرانی نے بیان کیا، کہا کہ ہم سے عبیدہ بن حمیدنے بیان کیا، کہا کہ مجھ سے عبدالعزی
1641,ہم سے احمد بن عیسیٰ نے بیان کیا، انہوں نے کہا کہ ہم سے عبداللہ بن وہب نے بیان کیا، انہوں نے کہا کہ م
1645,ہم سے علی بن عبداللہ مدینی نے بیان کیا، کہا کہ ہم سے سفیان بن عیینہ نے عمرو بن دینار سے بیان کہ  ہم
1669,ہم سے قتیبہ نے بیان کیا، انہوں نے کہا ہم سے اسماعیل بن جعفر نے بیان کیا، ان سے محمد بن حرملہ نے، ان
1687,ہم سے زہیر بن حرب نے بیان کیا، ان سے وہب بن جریر نے بیان کیا، ان سے ان کے باپ نے بیان کیا، ان سے یون
1695,ہم سے احمد بن محمد نے بیان کیا، انہوں نے کہا ہم کو عبداللہ نے خبر دی، انہوں نے کہا کہ ہم کو معمر نے
1758,ہم سے ابوالنعمان نے بیان کیا، ان سے ایوب نے، ان سے عکرمہ نے کہ  مدینہ کے لوگوں نے ابن عباس رضی اللہ
1760,ہم سے مسلم نے بیان کیا، کہا کہ ہم سے وہیب نے بیان کیا، کہا کہ ہم سے ابن طاؤس نے بیان کیا، ان سے ان ک
1771,ہم سے عمرو بن حفص نے بیان کیا، کہا کہ ہم سے ہمارے والد نے بیان کیا، ان سے اعمش نے بیان کیا، ان سے اب
1775,ہم سے قتیبہ بن سعید نے بیان کیا، ان سے جریر نے بیان کیا، ان سے منصور نے، ان سے مجاہد نے بیان کیا کہ
1791,ہم سے اسحاق بن ابراہیم نے بیان کیا، ان سے جریر نے، ان سے اسماعیل نے، ان سے عبداللہ بن ابی اوفی نے بی
1793,ہم سے حمیدی نے بیان کیا، ان سے سفیان بن عیینہ نے بیان کیا، ان سے عمرو بن دینار نے کہا کہ  ہم نے ابن
1918,ہم سے عبید بن اسماعیل نے بیان کیا، کہا ہم سے ابواسامہ نے، ان سے عبیداللہ نے، ان سے نافع نے اور ان سے
1925,ہم سے عبداللہ بن مسلمہ نے بیان کیا، کہا ہم سے امام مالک نے، ان سے ابوبکر بن عبدالرحمٰن بن حارث بن ہش
1931,ہم سے اسماعیل بن ابی اویس نے بیان کیا، کہا کہ مجھ سے امام مالک نے بیان کیا، ان سے ابوبکر بن عبدالرحم
1991,ہم سے موسیٰ بن اسماعیل نے بیان کیا، ان سے وہیب نے بیان کیا، کہا کہ ہم سے عمرو بن یحییٰ نے بیان کیا،
1997,ہم سے محمد بن بشار نے بیان کیا، کہا کہ ہم سے غندر نے بیان کیا، کہا کہ ہم سے شعبہ نے بیان کیا، انہوں
2030,ہم سے محمد بن یوسف فریابی نے بیان کیا، کہا کہ ہم سے سفیان بن عیینہ نے بیان کیا، ان سے منصور نے بیان
2060,ہم سے ابوعاصم نے بیان کیا، انہوں نے کہا کہ ہم سے ابن جریج نے بیان کیا، کہ مجھے عمرو بن دینار نے خبر
2123,ہم سے ابراہیم بن المنذر نے بیان کیا، کہا کہ ہم سے ابوضمرہ انس بن عیاض نے بیان کیا، کہا کہ ہم سے موسی
2153,ہم سے اسماعیل نے بیان کیا، کہا کہ مجھ سے امام مالک رحمہ اللہ نے بیان کیا، ان سے ابن شہاب نے، ان سے ع
2172,ہم سے ابوالنعمان نے بیان کیا، کہا کہ ہم سے حماد بن زید نے، ان سے ایوب نے، ان سے نافع نے اور ان سے اب
2178,ہم سے علی بن عبداللہ نے بیان کیا، کہا کہ ہم سے ضحاک بن مخلد نے بیان کیا، کہا کہ ہم سے ابن جریج نے بی
