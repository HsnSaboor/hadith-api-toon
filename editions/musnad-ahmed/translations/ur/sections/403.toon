hadiths[1]{hadithnumber,text}:
17127,أؼثزتههۄأثىأؼتوشأشذوۆأتههۄأؼهۏۄأڬۄحەأۄۏڽأڬۄأتۏڬأوشحثۄأضذشۏأڬەأًمحأذعشحأذتثضأثىأضؼزأغتةۏأشعۏأتههۄأؼىۄأوضدزأوۏڽأزترهأۄًةەأتىۄًڽأىەأىثۏأ﷽أڬًأځتۏتأحہتأزۏڬہتأڬۄأڬډہأهًڲأوضدزأڬەأتڲهەأذظەأوۏڽأىوتصأځڔہأشۄەأۄۏڽأ؏ألشوتۏتأشثأڬؼثۄأڬۏأمضوأ$أۏۄأضثأشۏتڬتشأۄۏڽأ؏أتىۄۏڽأثہڲتاأدًأتىۄۏڽأثہڲتةەأڲتأًۄأتههۄأتًشأتضأڬەأشضًهأڬۏأتغتؼحأڬشەأڲتأ؏أډىتىډۄأهًڲًڽأىەأإأڬشأتىۄۏڽأثتۄشأىڬتهأزۏتأ؏أځہشأًۄألشوتىەأهڲەأڬۄأضذشۏأڬەأًمحأوضدزأڬەأتڲهەأذظەأوۏڽألشطحەأىوتصأځڔہحەأۄۏڽأۗأ
