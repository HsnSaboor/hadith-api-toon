{"metadata":{"name":"Sunan Abu Dawud","section":{"21":"Funerals (Kitab Al-Jana'iz)"},"section_detail":{"21":{"hadithnumber_first":3089,"hadithnumber_last":3241,"arabicnumber_first":3089,"arabicnumber_last":3241}}},"hadiths":[{"hadithnumber":3175,"arabicnumber":3175,"text":"Rapporté par Ali ibn Abi Talib رضي الله عنه : Le Prophète ﷺ s’est levé pour un cortège funèbre (par respect), puis il s’est assis","grades":[{"name":"Al-Albani","grade":"Sahih"},{"name":"Muhammad Muhyi Al-Din Abdul Hamid","grade":"Sahih"},{"name":"Shuaib Al Arnaut","grade":"Sahih"},{"name":"Zubair Ali Zai","grade":"Sahih Muslim (962)"}],"reference":{"book":21,"hadith":87}}]}