{"hadithnumber": "1198", "text": "ہم سے عبداللہ بن یوسف تنیسی نے بیان کیا، انہیں امام مالک رحمہ اللہ نے خبر دی، انہیں مخرمہ بن سلیمان"}
{"hadithnumber": "1199", "text": "ہم سے عبداللہ بن نمیر نے بیان کیا، کہا کہ ہم سے محمد بن فضیل نے بیان کیا، کہا کہ ہم سے اعمش نے بیان"}
{"hadithnumber": "1199", "text": "ہم سے عبداللہ بن نمیر نے بیان کیا، کہا کہ ہم سے محمد بن فضیل نے بیان کیا، کہا کہ ہم سے اعمش نے بیان"}
{"hadithnumber": "1200", "text": "ہم سے ابراہیم بن موسیٰ نے بیان کیا، انہوں نے کہا ہم کو عیسیٰ بن یونس نے خبر دی، انہیں اسماعیل بن ابی"}
{"hadithnumber": "1201", "text": "ہم سے عبداللہ بن مسلمہ قعنبی نے بیان کیا، کہا کہ ہم سے عبدالعزیز بن ابی حازم نے بیان کیا، ان سے ان ک"}
{"hadithnumber": "1202", "text": "ہم سے عمرو بن عیسیٰ نے بیان کیا، انہوں نے کہا کہ ہم سے ابوعبدالصمد العمی عبدالعزیز بن عبدالصمد نے بی"}
{"hadithnumber": "1203", "text": "ہم سے علی بن عبداللہ مدینی نے بیان کیا، کہا کہ ہم سے سفیان بن عیینہ نے بیان کیا، کہا کہ ہم سے زہری ن"}
{"hadithnumber": "1204", "text": "ہم سے یحییٰ بلخی نے بیان کیا، کہا کہ ہم کو وکیع نے خبر دی، انہیں سفیان ثوری نے، انہیں ابوحازم سلمہ ب"}
{"hadithnumber": "1205", "text": "ہم سے بشر بن محمد نے بیان کیا، انہیں امام عبداللہ بن مبارک نے خبر دی، کہا کہ ہم سے یونس نے بیان کیا،"}
{"hadithnumber": "1206", "text": "اور لیث بن سعد نے کہا کہ مجھ سے جعفر بن ربیعہ نے بیان کیا، ان سے عبدالرحمٰن بن ہرمز اعرج نے کہ ابوہر"}
{"hadithnumber": "1207", "text": "ہم سے ابونعیم نے بیان کیا، کہا کہ ہم سے شیبان نے بیان کیا، ان سے یحییٰ بن کثیر نے، ان سے ابوسلمہ نے،"}
{"hadithnumber": "1208", "text": "ہم سے مسدد بن مسرہد نے بیان کیا، کہا کہ ہم سے بشر بن مفضل نے بیان کیا، کہا کہ ہم سے غالب بن قطان نے"}
{"hadithnumber": "1209", "text": "ہم سے عبداللہ بن مسلمہ قعنبی نے بیان کیا، کہا کہ ہم سے امام مالک رحمہ اللہ نے بیان کیا، ان سے ابوالن"}
{"hadithnumber": "1210", "text": "ہم سے محمود بن غیلان نے بیان کیا، کہا کہ ہم سے شبابہ نے بیان کیا، کہا کہ ہم سے شعبہ نے بیان کیا، ان"}
{"hadithnumber": "1211", "text": "ہم سے آدم بن ابی ایاس نے بیان کیا، کہا کہ ہم سے شعبہ نے بیان کیا، ان سے ارزق بن قیس نے بیان کیا، کہا"}
{"hadithnumber": "1212", "text": "ہم سے محمد بن مقاتل نے بیان کیا، کہا کہ ہم کو عبداللہ بن مبارک نے خبر دی، کہا کہ ہم کو یونس نے خبر د"}
{"hadithnumber": "1213", "text": "ہم سے سلیمان بن حرب نے بیان کیا، انہوں نے کہا کہ ہم سے حماد بن زید نے بیان کیا، ان سے ایوب سختیانی ن"}
{"hadithnumber": "1214", "text": "ہم سے محمد بن بشار نے بیان کیا، کہا کہ ہم سے غندر نے بیان کیا، ان سے شعبہ نے، انہوں نے کہا کہ میں نے"}
{"hadithnumber": "1215", "text": "ہم سے محمد بن کثیر نے بیان کیا، کہا کہ ہم کو سفیان ثوری نے خبر دی، انہیں ابوحازم نے، ان کو سہل بن سع"}
{"hadithnumber": "1216", "text": "ہم سے عبداللہ بن ابی شیبہ نے بیان کیا، کہا کہ ہم سے ابن فضیل نے بیان کیا، ان سے اعمش نے، ان سے ابراہ"}
{"hadithnumber": "1217", "text": "ہم سے ابومعمر نے بیان کیا، کہا کہ ہم سے عبدالوارث نے بیان کیا، کہا کہ ہم سے کثیر بن شنظیر نے بیان کی"}
{"hadithnumber": "1218", "text": "ہم سے قتیبہ بن سعید نے بیان کیا، انہوں نے کہا کہ ہم سے عبدالعزیز بن ابی حازم نے بیان کیا، ان سے ابوح"}
{"hadithnumber": "1219", "text": "ہم سے ابوالنعمان نے بیان کیا، کہا کہ ہم سے حماد بن زید نے بیان کیا، ان سے ایوب سختیانی نے، ان سے محم"}
{"hadithnumber": "1220", "text": "ہم سے عمرو بن علی فلاس نے بیان کیا، کہا کہ ہم سے یحییٰ بن سعید قطان نے بیان کیا، ان سے ہشام بن حسان"}
{"hadithnumber": "1221", "text": "ہم سے اسحاق بن منصور نے بیان کیا، کہا کہ ہم سے روح بن عبادہ نے، کہا کہ ہم سے عمر نے جو سعید کے بیٹے"}
{"hadithnumber": "1222", "text": "ہم سے یحییٰ بن بکیر نے بیان کیا، کہا کہ ہم سے لیث نے، ان سے جعفر بن ربیعہ نے اور ان سے اعرج نے اور ا"}
{"hadithnumber": "1223", "text": "ہم سے محمد بن مثنی نے بیان کیا، کہا کہ ہم سے عثمان بن عمر نے کہا کہ مجھے ابن ابی ذئب نے خبر دی، انہی"}
