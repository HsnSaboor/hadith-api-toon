{"metadata":{"name":"Sunan Ibn Majah","section":{"9":"The Chapters on Marriage"},"section_detail":{"9":{"hadithnumber_first":1845,"hadithnumber_last":2015,"arabicnumber_first":1845,"arabicnumber_last":2015}}},"hadiths":[{"hadithnumber":1868,"arabicnumber":1868,"text":"Rapporté par Ibn Umar : Le Messager d’Allah ﷺ a dit : « Un homme ne doit pas demander en mariage une femme à qui son frère a déjà fait une demande. »","grades":[{"name":"Al-Albani","grade":"Sahih"},{"name":"Muhammad Fouad Abd al-Baqi","grade":"Sahih"},{"name":"Shuaib Al Arnaut","grade":"Sahih"},{"name":"Zubair Ali Zai","grade":"Sahih Muslim"}],"reference":{"book":9,"hadith":24}}]}