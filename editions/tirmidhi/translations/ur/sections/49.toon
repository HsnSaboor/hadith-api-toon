{"hadithnumber": "3932", "text": "ابوہریرہ رضی الله عنہ کا بیان ہے کہ  نبی اکرم صلی اللہ علیہ وسلم کے پاس عجم کا ذکر کیا گیا تو آپ نے"}
{"hadithnumber": "3933", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  جس وقت سورۃ الجمعہ نازل ہوئی ہم رسول اللہ صلی اللہ علیہ وسلم کے پ"}
{"hadithnumber": "3934", "text": "زید بن ثابت رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے یمن کی طرف دیکھا اور فرمایا:"}
{"hadithnumber": "3935", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”تمہارے پاس اہل یمن آئے"}
{"hadithnumber": "3936", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”سلطنت  ( حکومت )  قریش م"}
{"hadithnumber": "3937", "text": "انس رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ” «ازد»  ( اہل یمن )  زمین میں"}
{"hadithnumber": "3938", "text": "انس بن مالک رضی الله عنہ کہتے ہیں کہ  اگر ہم ازدی  ( یعنی قبیلہ ازد کے )  نہ ہوں تو ہم آدمی ہیں ہی"}
{"hadithnumber": "3939", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  ہم نبی اکرم صلی اللہ علیہ وسلم کے پاس تھے کہ اتنے میں ایک شخص آی"}
{"hadithnumber": "3940", "text": "ابوایوب انصاری رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”انصار، مزینہ، جہین"}
{"hadithnumber": "3941", "text": "عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”بنی اسلم کو اللہ"}
{"hadithnumber": "3942", "text": "جابر رضی الله عنہ کہتے ہیں کہ  لوگوں نے عرض کیا: اللہ کے رسول! ثقیف کے تیروں نے ہمیں زخمی کر دیا، تو"}
{"hadithnumber": "3943", "text": "عمران بن حصین رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کی وفات ہوئی اور آپ تین قبیلوں ث"}
{"hadithnumber": "3944", "text": "عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”ثقیف میں ایک جھو"}
