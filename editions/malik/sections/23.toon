hadiths[count]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}:
1028,[1028] حَدَّثَنِی یَحْیَی عَنْ مَالِکٍ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ، عَنْ أَبِیہِ، أَ نَّہُ قَالَ:,"{'name': 'Salim al-Hilali', 'grade': 'Sahih'}","Book 23, Hadith 1",1028,,Sacrificial Animals
1029,[1029] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ یَحْیَی بْنِ سَعِیدٍ، أَنَّ عَبْدَ اللّٰہِ بْنَ عَیَّاشِ بْن,"{'name': 'Salim al-Hilali', 'grade': 'Mauquf Sahih'}","Book 23, Hadith 2",1029,,Sacrificial Animals
1030,"[1030] حَدَّثَنِی یَحْیَی، عَنْ مَالِکٍ, عَنْ زَیْدِ بْنِ أَسْلَم َ, عَنْ عَطَائِ بْنِ یَسَارٍ: أَ","{'name': 'Salim al-Hilali', 'grade': 'Mauquf Sahih'}","Book 23, Hadith 3",1030,,Sacrificial Animals
1031,[1031] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ نَافِعٍ، عَنْ رَجُلٍ مِنَ الْأَنْصَارِ، عَنْ مُعَاذِ بْنِ سَ,"{'name': 'Salim al-Hilali', 'grade': 'Sahih'}","Book 23, Hadith 4",1031,,Sacrificial Animals
1032,[1032] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ ثَوْرِ بْنِ زَیْدٍ الدِّیلِیِّ، عَنْ عَبْدِ اللّٰہِ بْنِ عَبّ,"{'name': 'Salim al-Hilali', 'grade': 'Sahih Lighairihi'}","Book 23, Hadith 5",1032,,Sacrificial Animals
1033,[1033] وَحَدَّثَنِی عَنْ مَالِکٍ، أَ نَّہُ بَلَغَہُ أَنَّ عَبْدَ اللّٰہِ بْنَ عَبَّاسٍ کَانَ یَقُو,"{'name': 'Salim al-Hilali', 'grade': 'Sahih'}","Book 23, Hadith 6",1033,,Sacrificial Animals
1034,[1034] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ یَحْیَی بْنِ سَعِیدٍ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ، أَ نَّ,"{'name': 'Salim al-Hilali', 'grade': 'Sahih'}","Book 23, Hadith 7",1034,,Sacrificial Animals
1035,[1035] حَدَّثَنِی یَحْیَی، عَنْ مَالِکٍ، عَنْ یَحْیَی بْنِ سَعِیدٍ، عَنْ أبِی مُرَّۃَ مَوْلَی عَقِی,"{'name': 'Salim al-Hilali', 'grade': 'Sahih Lighairihi'}","Book 23, Hadith 8",1035,,Sacrificial Animals
1036,[1036] حَدَّثَنِی یَحْیَی، عَنْ مَالِکٍ، عَنْ نَافِعٍ، عَنْ عَبْدِ اللّٰہِ بْنِ عُمَرَ، أَ نَّہُ کَ,"{'name': 'Salim al-Hilali', 'grade': 'Sahih'}","Book 23, Hadith 9",1036,,Sacrificial Animals
1037,[1037] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ یَزِیدَ بْنِ عَبْدِ اللّٰہِ بْنِ قُسَیْطٍ اللَّیْثِیِّ، عَنْ,"{'name': 'Salim al-Hilali', 'grade': 'Mauquf Sahih'}","Book 23, Hadith 10",1037,,Sacrificial Animals
1038,[1038]  حَدَّثَنِی یَحْیَی، عَنْ مَالِکٍ، عَنْ نَافِعٍ، أَ نَّہُ قَالَ : رَمَیْتُ طَائِرَیْنِ بِحَج,"{'name': 'Salim al-Hilali', 'grade': 'Sahih Lighairihi'}","Book 23, Hadith 11",1038,,Sacrificial Animals
1039,[1039] وَحَدَّثَنِی عَنْ مَالِکٍ، أَ نَّہُ بَلَغَہُ، أَنَّ الْقَاسِمَ بْنَ مُحَمَّدٍ کَانَ یَکْرَہ,"{'name': 'Salim al-Hilali', 'grade': 'Mauquf Sahih'}","Book 23, Hadith 12",1039,,Sacrificial Animals
1041,[1041] وَحَدَّثَنِی یَحْیَی، عَنْ مَالِکٍ، عَنْ نَافِعٍ، عَنْ عَبْدِ اللّٰہِ بْنِ عُمَرَ، أَ نَّہُ,"{'name': 'Salim al-Hilali', 'grade': 'Mauquf Sahih'}","Book 23, Hadith 1",1041,,Sacrificial Animals
1075,"حَدَّثَنِي يَحْيَى، عَنْ مَالِكٍ، عَنْ عَمْرِو بْنِ الْحَارِثِ، عَنْ عُبَيْدِ بْنِ فَيْرُوزَ، عَنِ الْبَرَاءِ بْنِ عَازِبٍ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم سُئِلَ مَاذَا يُتَّقَى مِنَ الضَّحَايَا فَأَشَارَ بِيَدِهِ وَقَالَ ‏""‏ أَرْبَعًا ‏""‏ ‏.‏ وَكَانَ الْبَرَاءُ يُشِيرُ بِيَدِهِ وَيَقُولُ يَدِي أَقْصَرُ مِنْ يَدِ رَسُولِ اللَّهِ صلى الله عليه وسلم ‏""‏ الْعَرْجَاءُ الْبَيِّنُ ظَلْعُهَا وَالْعَوْرَاءُ الْبَيِّنُ عَوَرُهَا وَالْمَرِيضَةُ الْبَيِّنُ مَرَضُهَا وَالْعَجْفَاءُ الَّتِي لاَ تُنْقِي ‏""‏ ‏.‏",,,1075,,Sacrificial Animals
1076,وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ نَافِعٍ، أَنَّ عَبْدَ اللَّهِ بْنَ عُمَرَ، كَانَ يَتَّقِي مِنَ الضَّحَايَا وَالْبُدْنِ الَّتِي لَمْ تُسِنَّ وَالَّتِي نَقَصَ مِنْ خَلْقِهَا ‏.‏ قَالَ مَالِكٌ وَهَذَا أَحَبُّ مَا سَمِعْتُ إِلَىَّ ‏.‏,,,1076,,Sacrificial Animals
1077,حَدَّثَنِي يَحْيَى، عَنْ مَالِكٍ، عَنْ نَافِعٍ، أَنَّ عَبْدَ اللَّهِ بْنَ عُمَرَ، ضَحَّى مَرَّةً بِالْمَدِينَةِ ‏.‏ قَالَ نَافِعٌ فَأَمَرَنِي أَنْ أَشْتَرِيَ لَهُ كَبْشًا فَحِيلاً أَقْرَنَ ثُمَّ أَذْبَحَهُ يَوْمَ الأَضْحَى فِي مُصَلَّى النَّاسِ ‏.‏ قَالَ نَافِعٌ فَفَعَلْتُ ثُمَّ حُمِلَ إِلَى عَبْدِ اللَّهِ بْنِ عُمَرَ فَحَلَقَ رَأْسَهُ حِينَ ذُبِحَ الْكَبْشُ وَكَانَ مَرِيضًا لَمْ يَشْهَدِ الْعِيدَ مَعَ النَّاسِ ‏.‏ قَالَ نَافِعٌ وَكَانَ عَبْدُ اللَّهِ بْنُ عُمَرَ يَقُولُ لَيْسَ حِلاَقُ الرَّأْسِ بِوَاجِبٍ عَلَى مَنْ ضَحَّى ‏.‏ وَقَدْ فَعَلَهُ ابْنُ عُمَرَ ‏.‏,,,1077,,Sacrificial Animals
1078,"حَدَّثَنِي يَحْيَى، عَنْ مَالِكٍ، عَنْ يَحْيَى بْنِ سَعِيدٍ، عَنْ بُشَيْرِ بْنِ يَسَارٍ، أَنَّ أَبَا بُرْدَةَ بْنَ نِيَارٍ، ذَبَحَ ضَحِيَّتَهُ قَبْلَ أَنْ يَذْبَحَ، رَسُولُ اللَّهِ صلى الله عليه وسلم يَوْمَ الأَضْحَى فَزَعَمَ أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم أَمَرَهُ أَنْ يَعُودَ بِضَحِيَّةٍ أُخْرَى ‏.‏ قَالَ أَبُو بُرْدَةَ لاَ أَجِدُ إِلاَّ جَذَعًا يَا رَسُولَ اللَّهِ ‏.‏ قَالَ ‏ ‏ وَإِنْ لَمْ تَجِدْ إِلاَّ جَذَعًا فَاذْبَحْ ‏""""‏ ‏.‏""",,,,,Sacrificial Animals
1079,وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ يَحْيَى بْنِ سَعِيدٍ، عَنْ عَبَّادِ بْنِ تَمِيمٍ، أَنَّ عُوَيْمِرَ بْنَ أَشْقَرَ، ذَبَحَ ضَحِيَّتَهُ قَبْلَ أَنْ يَغْدُوَ، يَوْمَ الأَضْحَى وَأَنَّهُ ذَكَرَ ذَلِكَ لِرَسُولِ اللَّهِ صلى الله عليه وسلم فَأَمَرَهُ أَنْ يَعُودَ بِضَحِيَّةٍ أُخْرَى ‏.‏,,,1079,,Sacrificial Animals
1080,"حَدَّثَنِي يَحْيَى، عَنْ مَالِكٍ، عَنْ أَبِي الزُّبَيْرِ الْمَكِّيِّ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم نَهَى عَنْ أَكْلِ لُحُومِ الضَّحَايَا بَعْدَ ثَلاَثَةِ أَيَّامٍ ثُمَّ قَالَ بَعْدُ ‏ ‏ كُلُوا  وَتَصَدَّقُوا وَتَزَوَّدُوا وَادَّخِرُوا ‏""""‏ ‏.‏""",,,,,Sacrificial Animals
1081,"وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ عَبْدِ اللَّهِ بْنِ أَبِي بَكْرٍ، عَنْ عَبْدِ اللَّهِ بْنِ وَاقِدٍ، أَنَّهُ قَالَ نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم عَنْ أَكْلِ لُحُومِ الضَّحَايَا بَعْدَ ثَلاَثَةِ أَيَّامٍ ‏.‏ قَالَ عَبْدُ اللَّهِ بْنُ أَبِي بَكْرٍ فَذَكَرْتُ ذَلِكَ لِعَمْرَةَ بِنْتِ عَبْدِ الرَّحْمَنِ فَقَالَتْ صَدَقَ سَمِعْتُ عَائِشَةَ زَوْجَ النَّبِيِّ صلى الله عليه وسلم تَقُولُ دَفَّ نَاسٌ مِنْ أَهْلِ الْبَادِيَةِ حَضْرَةَ الأَضْحَى فِي زَمَانِ رَسُولِ اللَّهِ صلى الله عليه وسلم فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏""‏ ادَّخِرُوا لِثَلاَثٍ وَتَصَدَّقُوا بِمَا بَقِيَ ‏""‏ ‏.‏ قَالَتْ فَلَمَّا كَانَ بَعْدَ ذَلِكَ قِيلَ لِرَسُولِ اللَّهِ صلى الله عليه وسلم لَقَدْ كَانَ النَّاسُ يَنْتَفِعُونَ بِضَحَايَاهُمْ وَيَجْمِلُونَ مِنْهَا الْوَدَكَ وَيَتَّخِذُونَ مِنْهَا الأَسْقِيَةَ فَقَالَ رَسُولُ اللَّهِ ‏""‏ وَمَا ذَلِكَ ‏""‏ ‏.‏ أَوْ كَمَا قَالَ ‏.‏ قَالُوا نَهَيْتَ عَنْ لُحُومِ الضَّحَايَا بَعْدَ ثَلاَثٍ ‏.‏ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏""‏ إِنَّمَا نَهَيْتُكُمْ مِنْ أَجْلِ الدَّافَّةِ الَّتِي دَفَّتْ عَلَيْكُمْ فَكُلُوا وَتَصَدَّقُوا وَادَّخِرُوا ‏""‏ ‏.‏",,,1081,,Sacrificial Animals
1082,"وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ رَبِيعَةَ بْنِ أَبِي عَبْدِ الرَّحْمَنِ، عَنْ أَبِي سَعِيدٍ الْخُدْرِيِّ، أَنَّهُ قَدِمَ مِنْ سَفَرٍ فَقَدَّمَ إِلَيْهِ أَهْلُهُ لَحْمًا ‏.‏ فَقَالَ انْظُرُوا أَنْ يَكُونَ هَذَا مِنْ لُحُومِ الأَضْحَى ‏.‏ فَقَالُوا هُوَ مِنْهَا ‏.‏ فَقَالَ أَبُو سَعِيدٍ أَلَمْ يَكُنْ رَسُولُ اللَّهِ صلى الله عليه وسلم نَهَى عَنْهَا فَقَالُوا إِنَّهُ قَدْ كَانَ مِنْ رَسُولِ اللَّهِ صلى الله عليه وسلم بَعْدَكَ أَمْرٌ ‏.‏ فَخَرَجَ أَبُو سَعِيدٍ فَسَأَلَ عَنْ ذَلِكَ فَأُخْبِرَ أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ نَهَيْتُكُمْ عَنْ لُحُومِ الأَضْحَى بَعْدَ ثَلاَثٍ فَكُلُوا وَتَصَدَّقُوا وَادَّخِرُوا وَنَهَيْتُكُمْ عَنْ الاِنْتِبَاذِ فَانْتَبِذُوا وَكُلُّ مُسْكِرٍ حَرَامٌ وَنَهَيْتُكُمْ عَنْ زِيَارَةِ الْقُبُورِ فَزُورُوهَا وَلاَ تَقُولُوا هُجْرًا ‏""""‏ ‏.‏ يَعْنِي لاَ تَقُولُوا سُوءًا ‏.‏""",,,,,Sacrificial Animals
1083,حَدَّثَنِي يَحْيَى، عَنْ مَالِكٍ، عَنْ أَبِي الزُّبَيْرِ الْمَكِّيِّ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، أَنَّهُ قَالَ نَحَرْنَا مَعَ رَسُولِ اللَّهِ صلى الله عليه وسلم عَامَ الْحُدَيْبِيَةِ الْبَدَنَةَ عَنْ سَبْعَةٍ وَالْبَقَرَةَ عَنْ سَبْعَةٍ ‏.‏,,,1083,,Sacrificial Animals
1084,وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ عُمَارَةَ بْنِ صَيَّادٍ، أَنَّ عَطَاءَ بْنَ يَسَارٍ، أَخْبَرَهُ أَنَّ أَبَا أَيُّوبَ الأَنْصَارِيَّ أَخْبَرَهُ قَالَ كُنَّا نُضَحِّي بِالشَّاةِ الْوَاحِدَةِ يَذْبَحُهَا الرَّجُلُ عَنْهُ وَعَنْ أَهْلِ بَيْتِهِ ثُمَّ تَبَاهَى النَّاسُ بَعْدُ فَصَارَتْ مُبَاهَاةً ‏.‏,,,1084,,Sacrificial Animals
1085,وَحَدَّثَنِي عَنْ مَالِكٍ، عَنِ ابْنِ شِهَابٍ، أَنَّهُ قَالَ مَا نَحَرَ رَسُولُ اللَّهِ صلى الله عليه وسلم عَنْهُ وَعَنْ أَهْلِ بَيْتِهِ إِلاَّ بَدَنَةً وَاحِدَةً أَوْ بَقَرَةً وَاحِدَةً ‏.‏ قَالَ مَالِكٌ لاَ أَدْرِي أَيَّتَهُمَا قَالَ ابْنُ شِهَابٍ ‏.‏,,,1085,,Sacrificial Animals
1086,"وَحَدَّثَنِي يَحْيَى، عَنْ مَالِكٍ، عَنْ نَافِعٍ، أَنَّ عَبْدَ اللَّهِ بْنَ عُمَرَ، قَالَ الأَضْحَى يَوْمَانِ بَعْدَ يَوْمِ الأَضْحَى ‏.‏ وَحَدَّثَنِي عَنْ مَالِكٍ، أَنَّهُ بَلَغَهُ عَنْ عَلِيِّ بْنِ أَبِي طَالِبٍ، مِثْلُ ذَلِكَ ‏.""",,,,,Sacrificial Animals
1087,وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ نَافِعٍ، أَنَّ عَبْدَ اللَّهِ بْنَ عُمَرَ، لَمْ يَكُنْ يُضَحِّي عَمَّا فِي بَطْنِ الْمَرْأَةِ ‏.‏ قَالَ مَالِكٌ الضَّحِيَّةُ سُنَّةٌ وَلَيْسَتْ بِوَاجِبَةٍ وَلاَ أُحِبُّ لأَحَدٍ مِمَّنْ قَوِيَ عَلَى ثَمَنِهَا أَنْ يَتْرُكَهَا ‏.‏,,,1087,,Sacrificial Animals