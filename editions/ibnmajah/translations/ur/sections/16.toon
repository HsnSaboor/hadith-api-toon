{"hadithnumber": "2436", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک یہودی سے ایک مقر"}
{"hadithnumber": "2437", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مدینہ میں اپنی زرہ ایک یہودی کے پاس گر"}
{"hadithnumber": "2438", "text": "اسماء بنت یزید رضی اللہ عنہا سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم کی وفات ہوئی، اور آپ کی زر"}
{"hadithnumber": "2439", "text": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم کی وفات ہوئی، اور آپ کی"}
{"hadithnumber": "2440", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جانور پر سواری کی جائے گ"}
{"hadithnumber": "2441", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  رہن روکا نہیں جا سکتا  ۱"}
{"hadithnumber": "2442", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تین شخص ایسے ہیں کہ قیام"}
{"hadithnumber": "2443", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مزدور کو اس کا پ"}
{"hadithnumber": "2444", "text": "عتبہ بن ندر رضی اللہ عنہ کہتے ہیں کہ  ہم رسول اللہ صلی اللہ علیہ وسلم کے پاس تھے تو آپ نے سورۃ «طسم»"}
{"hadithnumber": "2445", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  میری پرورش یتیمی کی حالت میں ہوئی، اور ہجرت کرنے کے وقت میں مسکین"}
{"hadithnumber": "2446", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کو ایک بار بھوک لگی یہ خبر ع"}
{"hadithnumber": "2447", "text": "علی رضی اللہ عنہ کہتے ہیں کہ  میں ایک کھجور کے بدلے ایک ڈول پانی نکالتا تھا، اور یہ شرط لگا لیتا تھا"}
{"hadithnumber": "2448", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  ایک انصاری نے آ کر عرض کیا: اللہ کے رسول! کیا وجہ ہے کہ میں آپ ک"}
{"hadithnumber": "2449", "text": "رافع بن خدیج رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے محاقلہ بیع و مزابنہ سے منع کی"}
{"hadithnumber": "2450", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  ہم مزارعت  ( بٹائی کھیتی )  کیا کرتے تھے، اور اس میں کوئی"}
{"hadithnumber": "2451", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  ہم میں سے کچھ لوگوں کے پاس زائد زمینیں تھیں، جنہیں وہ تہ"}
{"hadithnumber": "2452", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس کے پاس زمین ہو وہ خود"}
{"hadithnumber": "2453", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  وہ اپنی زمین کرایہ پر کھیتی کے لیے دیا کرتے تھے، ان کے"}
{"hadithnumber": "2454", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے خطبہ دیا تو فرمایا:  جس"}
{"hadithnumber": "2455", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے محاقلہ سے منع کیا ہے، اور مح"}
{"hadithnumber": "2456", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  جب انہوں نے سنا کہ لوگ زمین کو کرائیے پر دینے کے سلسلے م"}
{"hadithnumber": "2457", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم میں سے کوئی"}
{"hadithnumber": "2458", "text": "حنظلہ بن قیس کہتے ہیں کہ  میں نے رافع بن خدیج رضی اللہ عنہ سے پوچھا تو انہوں نے کہا کہ ہم زمین کو اس"}
{"hadithnumber": "2459", "text": "رافع بن خدیج رضی اللہ عنہ سے روایت ہے کہ  انہوں نے اپنے چچا ظہیر رضی اللہ عنہ کو کہتے سنا کہ رسول ال"}
{"hadithnumber": "2460", "text": "رافع بن خدیج رضی اللہ عنہ کہتے ہیں کہ  کسی کو زمین کی حاجت نہیں ہوتی تھی تو اسے تہائی یا چوتھائی یا"}
{"hadithnumber": "2461", "text": "عروہ بن زبیر کہتے ہیں کہ  زید بن ثابت رضی اللہ عنہ نے کہا: اللہ رافع بن خدیج رضی اللہ عنہ کو بخشے، ا"}
{"hadithnumber": "2462", "text": "عمرو بن دینار کہتے ہیں کہ  میں نے طاؤس سے کہا: اے ابوعبدالرحمٰن! کاش آپ اس بٹائی کو چھوڑ دیتے، اس لی"}
{"hadithnumber": "2463", "text": "طاؤس سے روایت ہے کہ  معاذ بن جبل رضی اللہ عنہ نے رسول اللہ صلی اللہ علیہ وسلم، ابوبکرو عمر اور عثمان"}
{"hadithnumber": "2465", "text": "رافع بن خدیج رضی اللہ عنہ کہتے ہیں کہ  ہم رسول اللہ صلی اللہ علیہ وسلم کے عہد میں محاقلہ کیا کرتے تھ"}
{"hadithnumber": "2466", "text": "رافع بن خدیج رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص کسی کی زمین م"}
{"hadithnumber": "2467", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے خیبر والوں سے پھل اور"}
{"hadithnumber": "2468", "text": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے خیبر والوں کو خیبر کی"}
{"hadithnumber": "2469", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے جب خیبر کو فتح کیا، تو اسے نصف"}
{"hadithnumber": "2470", "text": "طلحہ بن عبیداللہ رضی اللہ عنہ کہتے ہیں کہ  میں رسول اللہ صلی اللہ علیہ وسلم کے ساتھ کھجور کے باغ میں"}
{"hadithnumber": "2471", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے کچھ آوازیں سنیں تو پ"}
{"hadithnumber": "2472", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تین چیزوں میں س"}
{"hadithnumber": "2473", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تین چیزیں ایسی ہیں جن سے"}
{"hadithnumber": "2474", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  انہوں نے پوچھا: اللہ کے رسول! کون سی ایسی چیز ہے جس"}
{"hadithnumber": "2475", "text": "ابیض بن حمال رضی اللہ عنہ سے روایت ہے کہ  انہوں نے اس نمک کو جو  نمک سدمآرب  کے نام سے جانا جاتا ہے"}
{"hadithnumber": "2478", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  تم میں سے کوئی شخص ضرورت"}
{"hadithnumber": "2479", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ضرورت سے زائد"}
{"hadithnumber": "2480", "text": "عبداللہ بن زبیر رضی اللہ عنہما سے روایت ہے کہ  ایک انصاری ۱؎ نے رسول اللہ صلی اللہ علیہ وسلم کے پاس"}
{"hadithnumber": "2481", "text": "ثعلبہ بن ابی مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے وادی مہزور کے نالہ کے سل"}
{"hadithnumber": "2482", "text": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے وادی مہزور ک"}
