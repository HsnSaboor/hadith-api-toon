{"hadithnumber": "2512", "text": "جابر رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے مدبر غلام بیچا ۱؎۔"}
{"hadithnumber": "2513", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  ہم میں سے ایک شخص نے غلام کو مدبر بنا دیا، اس کے پاس اس"}
{"hadithnumber": "2514", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  مدبر غلام میت کے"}
{"hadithnumber": "2515", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو لونڈی اپنے م"}
{"hadithnumber": "2516", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے بیٹے ابراہیم کی ماں کا ت"}
{"hadithnumber": "2517", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  ہم لوگ اپنی لونڈیاں اور «امہات الاولاد» بیچا کرتے تھے، ا"}
{"hadithnumber": "2518", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تین قسم کے لوگ ایسے ہیں"}
{"hadithnumber": "2519", "text": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس غلا"}
{"hadithnumber": "2520", "text": "ام المؤمنین ام سلمہ رضی اللہ عنہا کہتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  اگر تم میں سے"}
{"hadithnumber": "2521", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  ان کے پاس بریرہ رضی اللہ عنہا آئیں جو مکاتب  ( لونڈ"}
{"hadithnumber": "2522", "text": "شرحبیل بن سمط کہتے ہیں کہ  میں نے کعب رضی اللہ عنہ سے کہا: کعب بن مرہ! ہم سے رسول اللہ صلی اللہ علیہ"}
{"hadithnumber": "2523", "text": "ابوذر رضی اللہ عنہ کہتے ہیں کہ  میں نے عرض کیا: اللہ کے رسول! کون سا غلام آزاد کرنا سب سے زیادہ بہت"}
{"hadithnumber": "2524", "text": "سمرہ بن جندب رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جو کسی محرم رشتے دار"}
{"hadithnumber": "2525", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو کسی محرم رشتے"}
{"hadithnumber": "2527", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو کوئی کسی  ( مشترک )"}
{"hadithnumber": "2529", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص کسی ایسے"}
{"hadithnumber": "2530", "text": "عمیر مولی عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  ابن مسعود رضی اللہ عنہما نے ان سے کہا: عمیر! می"}
{"hadithnumber": "2531", "text": "نبی اکرم صلی اللہ علیہ وسلم کی لونڈی میمونہ بنت سعد رضی اللہ عنہا سے روایت ہے کہ  رسول اللہ صلی اللہ"}
{"hadithnumber": "2532", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  ان کے پاس ایک غلام اور ایک لونڈی میاں بیوی تھے، انہو"}
