{"hadithnumber": "1674", "text": "عبداللہ بن عمر رضی اللہ عنہم کہتے ہیں کہ  ایک شخص نے رسول اللہ صلی اللہ علیہ وسلم سے رات کی نماز کے"}
{"hadithnumber": "1675", "text": "عبداللہ بن عمر رضی اللہ عنہم کہتے ہیں کہ  ایک شخص نے کھڑے ہو کر پوچھا: اللہ کے رسول! رات کی نماز کیس"}
{"hadithnumber": "1676", "text": "علی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے وتر پڑھی، پھر فرمایا:  اے اہل قرآن! وت"}
{"hadithnumber": "1677", "text": "علی رضی اللہ عنہ کہتے ہیں کہ  وتر فرض نماز کی طرح کوئی حتمی و واجبی چیز نہیں ہے، البتہ وہ رسول اللہ"}
{"hadithnumber": "1678", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  میرے خلیل صلی اللہ علیہ وسلم نے مجھے تین باتوں کی وصیت کی ہے: وتر"}
{"hadithnumber": "1679", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  میرے خلیل صلی اللہ علیہ وسلم نے مجھے تین باتوں کی نصیحت کی: شروع"}
{"hadithnumber": "1680", "text": "قیس بن طلق کہتے ہیں  ہمارے والد طلق بن علی رضی اللہ عنہ نے رمضان میں ایک دن ہماری زیارت کی اور ہمارے"}
{"hadithnumber": "1681", "text": "اسود بن یزید کہتے ہیں کہ  میں نے ام المؤمنین عائشہ رضی اللہ عنہا سے رسول اللہ صلی اللہ علیہ وسلم کی"}
{"hadithnumber": "1682", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے شروع، اخیر اور بیچ رات"}
{"hadithnumber": "1683", "text": "عبداللہ بن عمر رضی اللہ عنہم کہتے ہیں کہ  جو رات کو نماز پڑھے تو وہ اپنی آخری نماز وتر کو بنائے، اس"}
