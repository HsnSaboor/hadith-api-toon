{"hadithnumber": "1029", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  رکوع اور سجدے میں سیدھے رہو ۱"}
{"hadithnumber": "1030", "text": "علقمہ اور اسود سے روایت ہے کہ  وہ دونوں عبداللہ بن مسعود رضی اللہ عنہ کے ساتھ ان کے گھر میں تھے، تو"}
{"hadithnumber": "1031", "text": "اسود اور علقمہ کہتے ہیں کہ  ہم نے عبداللہ بن مسعود رضی اللہ عنہ کے ساتھ ان کے گھر میں نماز پڑھی، وہ"}
{"hadithnumber": "1032", "text": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ہمیں نماز سکھائی، آپ کھڑے"}
{"hadithnumber": "1033", "text": "مصعب بن سعد کہتے ہیں کہ  میں نے اپنے والد  ( سعد بن ابی وقاص رضی اللہ عنہ )  کے پہلو میں نماز پڑھی،"}
{"hadithnumber": "1034", "text": "مصعب بن سعد کہتے ہیں کہ  میں نے رکوع کیا، تو اپنے دونوں ہاتھوں کی انگلیوں کو ایک دوسرے میں پیوست کر"}
{"hadithnumber": "1035", "text": "عمر رضی اللہ عنہ کہتے ہیں کہ  ہتھیلیوں سے گھٹنوں کو پکڑے رکھنا تمہارے لیے مسنون قرار دیا گیا ہے، لہٰ"}
{"hadithnumber": "1036", "text": "ابوعبدالرحمٰن سلمی کہتے ہیں کہ  عمر رضی اللہ عنہ نے کہا: سنت تو گھٹنوں کو پکڑنا ہی ہے۔"}
{"hadithnumber": "1037", "text": "سالم البراد کہتے ہیں کہ  ہم ابومسعود  ( عقبہ بن عمرو )  کے پاس آئے تو ہم نے ان سے کہا: آپ ہم سے رسول"}
{"hadithnumber": "1038", "text": "ابوعبداللہ سالم بن البرد سے روایت ہے کہ  عقبہ بن عمرو رضی اللہ عنہ کہتے ہیں کہ کیا میں تمہارے سامنے"}
{"hadithnumber": "1039", "text": "ابوعبداللہ سالم براد کہتے ہیں کہ  ابومسعود  ( عقبہ بن عمرو )  رضی اللہ عنہ کہنے لگے کہ کیا میں تمہیں"}
{"hadithnumber": "1040", "text": "ابو حمید ساعدی رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم جب رکوع کرتے تو پیٹھ اور سر کو"}
{"hadithnumber": "1041", "text": "علی رضی اللہ عنہ کہتے ہیں کہ  مجھے نبی اکرم صلی اللہ علیہ وسلم نے قسی ۱؎ اور حریر ۲؎ اور سونے کی انگ"}
{"hadithnumber": "1042", "text": "علی رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے مجھے سونے کی انگوٹھی پہننے سے، رکوع کی"}
{"hadithnumber": "1043", "text": "علی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مجھے سونے کی انگوٹھی پہننے سے، قسی کے"}
{"hadithnumber": "1044", "text": "علی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مجھے سونے کی انگوٹھی سے اور قسی کے بنے"}
{"hadithnumber": "1045", "text": "علی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مجھے قسی کے بنے ریشمی کپڑے، اور کسم می"}
{"hadithnumber": "1046", "text": "عبداللہ بن عباس رضی اللہ عنہم کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے اپنے حجرے کا پردہ اٹھایا،"}
{"hadithnumber": "1047", "text": "حذیفہ رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کے ساتھ نماز پڑھی، آپ نے رکوع کی"}
