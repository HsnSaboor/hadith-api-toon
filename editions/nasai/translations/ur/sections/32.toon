{"hadithnumber": "3688", "text": "سعد بن عبادہ رضی الله عنہ سے روایت ہے کہ  انہوں نے نبی اکرم صلی اللہ علیہ وسلم سے ایک نذر کے بارے می"}
{"hadithnumber": "3689", "text": "عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  سعد بن عبادہ رضی اللہ عنہ نے رسول اللہ صلی اللہ علیہ وسل"}
{"hadithnumber": "3690", "text": "عبداللہ بن عباس رضی الله عنہما سے روایت ہے کہ  سعد بن عبادہ رضی اللہ عنہ نے نبی اکرم صلی اللہ علیہ و"}
{"hadithnumber": "3691", "text": "سعد بن عبادہ رضی الله عنہ کہتے ہیں کہ  میری ماں مر گئیں اور ان کے ذمہ ایک نذر تھی تو میں نے نبی اکرم"}
{"hadithnumber": "3692", "text": "عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  سعد بن عبادہ انصاری رضی اللہ عنہ نے رسول اللہ صلی اللہ ع"}
{"hadithnumber": "3693", "text": "عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  سعد بن عبادہ رضی اللہ عنہ نے نبی اکرم صلی اللہ علیہ وسلم"}
{"hadithnumber": "3694", "text": "سعد بن عبادہ رضی الله عنہ کہتے ہیں کہ  میں نے کہا: اللہ کے رسول! میری ماں مر گئیں ہیں، کیا میں ان کی"}
{"hadithnumber": "3695", "text": "سعد بن عبادہ رضی الله عنہ کہتے ہیں کہ  میں نے کہا: اللہ کے رسول! کون سا صدقہ سب سے بہتر ہے؟ آپ نے فر"}
{"hadithnumber": "3696", "text": "سعد بن عبادہ رضی الله عنہ سے روایت ہے کہ  ان کی ماں مر گئیں تو انہوں نے عرض کیا: اللہ کے رسول! میری"}
{"hadithnumber": "3697", "text": "ابوذر رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مجھ سے فرمایا: ”ابوذر! میں تمہیں کمز"}
{"hadithnumber": "3698", "text": "عبداللہ بن عمرو بن عاص رضی الله عنہما سے روایت ہے کہ  ایک شخص نے نبی اکرم صلی اللہ علیہ وسلم کے پاس"}
{"hadithnumber": "3699", "text": "عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  جب آیت کریمہ: «‏ولا تقربوا مال اليتيم إلا بالتي هي أحسن»"}
{"hadithnumber": "3700", "text": "عبداللہ بن عباس رضی الله عنہما  آیت کریمہ: «إن الذين يأكلون أموال اليتامى ظلما» کے سلسلہ میں کہتے ہی"}
{"hadithnumber": "3701", "text": "ابوہریرہ رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”سات ہلاک کر دینے والی"}
{"hadithnumber": "3702", "text": "نعمان بن بشیر رضی الله عنہما سے روایت ہے کہ  انہیں ان کے والد نے ایک غلام ہبہ کیا، تو نبی اکرم صلی ا"}
{"hadithnumber": "3703", "text": "نعمان بن بشیر رضی الله عنہما سے روایت ہے کہ  ان کے والد انہیں ساتھ لے کر رسول اللہ صلی اللہ علیہ وسل"}
{"hadithnumber": "3704", "text": "نعمان بن بشیر رضی الله عنہما سے روایت ہے کہ  ان کے والد بشیر بن سعد اپنے بیٹے نعمان کو لے کر آئے اور"}
{"hadithnumber": "3705", "text": "بشیر بن سعد رضی الله عنہ سے روایت ہے کہ  وہ نبی اکرم صلی اللہ علیہ وسلم کے پاس  ( اپنے بیٹے )  نعمان"}
