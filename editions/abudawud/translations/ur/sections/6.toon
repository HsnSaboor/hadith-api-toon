{"hadithnumber": "1390", "text": "عبداللہ بن عمرو رضی اللہ عنہما سے روایت ہے کہ  انہوں نے عرض کیا: اللہ کے رسول! میں قرآن کتنے دنوں می"}
{"hadithnumber": "1391", "text": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مجھ سے فرمایا:  قرآن ایک"}
{"hadithnumber": "1392", "text": "ابن الہاد کہتے ہیں کہ  مجھ سے نافع بن جبیر بن مطعم نے پوچھا: تم کتنے دنوں میں قرآن پڑھتے ہو؟ تو میں"}
{"hadithnumber": "1393", "text": "اوس بن حذیفہ رضی اللہ عنہ کہتے ہیں کہ  ہم لوگ ثقیف کے ایک وفد میں رسول اللہ صلی اللہ علیہ وسلم کے پا"}
{"hadithnumber": "1394", "text": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص قرآن کو"}
{"hadithnumber": "1395", "text": "عبداللہ بن عمرو رضی اللہ عنہما سے روایت ہے کہ  انہوں نے نبی اکرم صلی اللہ علیہ وسلم سے پوچھا: قرآن ک"}
{"hadithnumber": "1396", "text": "علقمہ اور اسود کہتے ہیں کہ  ابن مسعود رضی اللہ عنہ کے پاس ایک شخص آیا اور کہنے لگا: میں ایک رکعت میں"}
{"hadithnumber": "1397", "text": "عبدالرحمٰن بن یزید کہتے ہیں کہ  میں نے ابو مسعود رضی اللہ عنہ سے پوچھا آپ بیت اللہ کا طواف کر رہے تھ"}
{"hadithnumber": "1398", "text": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص"}
