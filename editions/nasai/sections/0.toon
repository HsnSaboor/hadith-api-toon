hadiths[count]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}:
3857,أَخْبَرَنَا مُحَمَّدُ بْنُ مَعْدَانَ بْنِ عِيسَى،‏‏‏‏ قَالَ:‏‏‏‏ حَدَّثَنَا الْحَسَنُ بْنُ أَعْيَنَ،,Abu Ghuddah: Daif Muquf; Al-Albani: Daif Muquf; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ النسائي (تحفة الأشراف: ۱۱۱۶۰) (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3857,,
3858,قَالَ الْحَارِثُ بْنُ مِسْكِينٍ قِرَاءَةً عَلَيْهِ وَأَنَا أَسْمَعُ:‏‏‏‏ عَنْ ابْنِ الْقَاسِمِ،‏‏‏‏,Abu Ghuddah: Sahih Maqtu; Al-Albani: Sahih Maqtu; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: صحیح البخاری/المغازي ۳۸ (۴۲۳۴)، الأیمان ۳۳ (۶۷۰۷)، صحیح مسلم/الإیمان ۴۸ (۱۱۵)، سنن ابی داود/الجہاد ۱۴۳ (۲۷۱۱)، موطا امام مالک/الجہاد ۱۳ (۲۵)، (تحفة الأشراف: ۱۲۹۱۶) (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3858,,
3859,أَخْبَرَنَا يُونُسُ بْنُ عَبْدِ الْأَعْلَى،‏‏‏‏ قَالَ:‏‏‏‏ حَدَّثَنَا ابْنُ وَهْبٍ،‏‏‏‏ قَالَ:‏‏‏‏ أ,Abu Ghuddah: Sahih Maqtu; Al-Albani: Sahih Maqtu; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ النسائي (تحفة الأشراف: ۸۲۶۵) (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3859,,
3860,أَخْبَرَنَا مُحَمَّدُ بْنُ مَنْصُورٍ،‏‏‏‏ قَالَ:‏‏‏‏ حَدَّثَنَا سُفْيَانُ،‏‏‏‏ عَنْ أَيُّوبَ،‏‏‏‏ عَ,Abu Ghuddah: Sahih Isnaad Maqtu; Al-Albani: Sahih Isnaad Maqtu; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: انظر حدیث رقم: ۳۸۲۴ (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3860,,
3861,أَخْبَرَنَا أَحْمَدُ بْنُ سُلَيْمَانَ،‏‏‏‏ قَالَ:‏‏‏‏ حَدَّثَنَا عَفَّانُ،‏‏‏‏ قَالَ:‏‏‏‏ حَدَّثَنَا,Abu Ghuddah: Sahih Isnaad Maqtu; Al-Albani: Sahih Isnaad Maqtu; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: انظر حدیث رقم: ۳۸۲۴ (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3861,,
3862,أَخْبَرَنَا عِمْرَانُ بْنُ بَكَّارٍ،‏‏‏‏ قَالَ:‏‏‏‏ حَدَّثَنَا عَلِيُّ بْنُ عَيَّاشٍ،‏‏‏‏ قَالَ:‏‏‏‏,Abu Ghuddah: Daif Isnaad; Al-Albani: Daif Isnaad; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأیمان ۳ (۶۶۳۹)، تحفة الأشراف: ۱۳۷۳۱)، صحیح مسلم/الأیمان ۵ (۱۶۵۴)، سنن الترمذی/الأیمان ۷ (۱۵۳۲- تعلیقاً)، مسند احمد (۲/۲۲۹، ۲۷۵، ۵۰۶) (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3862,,
3863,أَخْبَرَنَا يُونُسُ بْنُ عَبْدِ الْأَعْلَى،‏‏‏‏ قَالَ:‏‏‏‏ حَدَّثَنَا ابْنُ وَهْبٍ،‏‏‏‏ قَالَ:‏‏‏‏ أ,Abu Ghuddah: Sahih Isnaad; Al-Albani: Sahih Isnaad; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ النسائي (تحفة الأشراف: ۸۲۶۵) (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3863,,
3864,أَخْبَرَنَا كَثِيرُ بْنُ عُبَيْدٍ،‏‏‏‏ قَالَ:‏‏‏‏ حَدَّثَنَا مُحَمَّدُ بْنُ حَرْبٍ،‏‏‏‏ عَنْ الزُّبَ,Abu Ghuddah: Sahih; Al-Albani: Sahih; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ النسائي (تحفة الأشراف: ۱۷۵۶۷) (صحیح) (سند میں زہری اور قاسم کے درمیان انقطاع ہے، مگر سند متصل ہے، ملاحظہ ہو اگلی حدیث)  (بمطابق الشیخ ناصر الدین البانی)؛,3864,,
3865,أَخْبَرَنَا يُونُسُ بْنُ عَبْدِ الْأَعْلَى،‏‏‏‏ قَالَ:‏‏‏‏ حَدَّثَنَا ابْنُ وَهْبٍ،‏‏‏‏ قَالَ:‏‏‏‏ أ,Abu Ghuddah: Sahih; Al-Albani: Sahih; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: سنن ابی داود/الأیمان ۲۳ (۳۲۹۱)، سنن الترمذی/الأیمان۱(۱۵۲۴)، سنن ابن ماجہ/الکفارات۱۶(۲۱۲۵)، (تحفة الأشراف: ۱۷۷۷۰)، مسند احمد (۶/۲۴۷)، ویأتی فیما یلي: ۳۸۶۶-۳۸۶۹ (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3865,,
3866,أَخْبَرَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ الْمُبَارَكِ الْمُخَرِّمِيُّ،‏‏‏‏ قَالَ:‏‏‏‏ حَدَّثَن,Abu Ghuddah: Sahih; Al-Albani: Sahih; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: انظر ماقبلہ (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3866,,
3867,أَخْبَرَنَا إِسْحَاق بْنُ مَنْصُورٍ،‏‏‏‏ قَالَ:‏‏‏‏ أَنْبَأَنَا عُثْمَانُ بْنُ عُمَرَ،‏‏‏‏ قَالَ:‏‏‏,Abu Ghuddah: Sahih; Al-Albani: Sahih; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: انظر حدیث رقم: ۳۸۶۵ (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3867,,
3868,أَخْبَرَنَا قُتَيْبَةُ،‏‏‏‏ قَالَ:‏‏‏‏ حَدَّثَنَا أَبُو صَفْوَانَ،‏‏‏‏ عَنْ يُونُسَ،‏‏‏‏ عَنِ الزُّه,Abu Ghuddah: Sahih; Al-Albani: Sahih; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: انظر حدیث رقم: ۳۸۶۵ (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3868,,
3869,أَخْبَرَنَا هَارُونُ بْنُ مُوسَى الْفَرَوِيُّ،‏‏‏‏ قَالَ:‏‏‏‏ حَدَّثَنَا أَبُو ضَمْرَةَ،‏‏‏‏ عَنْ يُ,Abu Ghuddah: Daif Isnaad; Al-Albani: Daif Isnaad; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: انظر حدیث رقم: ۳۸۶۵ (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3869,,
3870,أَخْبَرَنَا مُحَمَّدُ بْنُ إِسْمَاعِيل التِّرْمِذِيُّ،‏‏‏‏ قَالَ:‏‏‏‏ حَدَّثَنَا أَيُّوبُ بْنُ سُلَي,Abu Ghuddah: Sahih Lighairihi; Al-Albani: Sahih; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: سنن ابی داود/الأیمان ۲۳ (۳۲۹۲)، سنن الترمذی/الأیمان ۱ (۱۵۲۵)، (تحفة الأشراف: ۱۷۷۸۲) (صحیح) (اس کے راوی ’’ سلیمان بن ارقم ‘‘ ضعیف ہیں، لیکن اس کی پچھلی سندیں صحیح ہیں)  (بمطابق الشیخ ناصر الدین البانی)؛,3870,,
3871,أَخْبَرَنَا هَنَّادُ بْنُ السَّرِيِّ،‏‏‏‏ عَنْ وَكِيعٍ،‏‏‏‏ عَنِ ابْنِ الْمُبَارَكِ وَهُوَ عَلِيٌّ،‏,Abu Ghuddah: Sahih Lighairihi; Al-Albani: Sahih; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ النسائي (تحفة الأشراف: ۱۰۸۲۲)، مسند احمد (۴/۴۳۳، ۴۳۹، ۴۴۰، ۴۴۳)، ویأتي بأرقام: ۳۸۷۲-۳۸۷۵) (صحیح) (اس کے راوی ’’محمد بن زبیر‘‘ ضعیف الحدیث ہیں، لیکن عائشہ رضی الله عنہا کی حدیث سے تقویت پاکر یہ حدیث صحیح ہے)  (بمطابق الشیخ ناصر الدین البانی)؛,3871,,
3872,أَخْبَرَنِي عَمْرُو بْنُ عُثْمَانَ،‏‏‏‏ قَالَ:‏‏‏‏ حَدَّثَنَا بَقِيَّةُ،‏‏‏‏ عَنْ أَبِي عَمْرٍو وَهُ,Abu Ghuddah: Sahih Lighairihi; Al-Albani: Sahih; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: انظر ما قبلہ (صحیح) (سابقہ روایت سے تقویت پاکر یہ حدیث صحیح لغیرہ ہے)  (بمطابق الشیخ ناصر الدین البانی)؛,3872,,
3873,أَخْبَرَنَا عَلِيُّ بْنُ مَيْمُونٍ،‏‏‏‏ قَالَ:‏‏‏‏ حَدَّثَنَا مَعْمَرُ بْنُ سُلَيْمَانَ،‏‏‏‏ عَنْ عَ,Abu Ghuddah: Sahih; Al-Albani: Sahih; Takhreej-Group: Daif,takhreej: تخریج دارالدعوہ: انظر حدیث رقم: ۳۸۷۱ (ضعیف) (اس کے راوی ’’محمد بن زبیر‘‘ ضعیف الحدیث ہیں، اور اس حدیث کے مضمون کا کوئی شاہد موجود نہیں)  (بمطابق الشیخ ناصر الدین البانی)؛,3873,,
3874,أَخْبَرَنِي إِبْرَاهِيمُ بْنُ يَعْقُوبَ،‏‏‏‏ قَالَ:‏‏‏‏ حَدَّثَنَا الْحَسَنُ بْنُ مُوسَى،‏‏‏‏ قَالَ:,Abu Ghuddah: Sahih; Al-Albani: Sahih; Takhreej-Group: Daif,takhreej: تخریج دارالدعوہ: انظر حدیث رقم: ۳۸۷۱ (ضعیف) (دیکھئے پچھلی حدیث پر کلام)  (بمطابق الشیخ ناصر الدین البانی)؛,3874,,
3875,أَخْبَرَنَا قُتَيْبَةُ،‏‏‏‏ أَنْبَأَنَا حَمَّادٌ،‏‏‏‏ عَنْ مُحَمَّدٍ،‏‏‏‏ عَنْ أَبِيهِ،‏‏‏‏ عَنْ عِم,Abu Ghuddah: Sahih; Al-Albani: Sahih; Takhreej-Group: Daif,takhreej: تخریج دارالدعوہ: انظر حدیث رقم: ۳۸۷۱ (ضعیف)  (بمطابق الشیخ ناصر الدین البانی)؛,3875,,
3876,أَخْبَرَنِي مُحَمَّدُ بْنُ وَهْبٍ،‏‏‏‏ قَالَ:‏‏‏‏ حَدَّثَنَا مُحَمَّدُ بْنُ سَلَمَةَ،‏‏‏‏ قَالَ:‏‏‏‏,Abu Ghuddah: Sahih; Al-Albani: Sahih; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ النسائي (تحفة الأشراف: ۱۰۸۹۱) (صحیح) (شواہد سے تقویت پاکر یہ حدیث صحیح ہے، ورنہ اس کی سند میں بھی محمد اور ان کے باپ زبیر ضعیف ہیں، نیز ایک راوی مبہم بھی ہے)  (بمطابق الشیخ ناصر الدین البانی)؛,3876,,
3877,أَخْبَرَنِي إِبْرَاهِيمُ بْنُ يَعْقُوبَ،‏‏‏‏ قَالَ:‏‏‏‏ حَدَّثَنَا مُسَدَّدٌ،‏‏‏‏ قَالَ:‏‏‏‏ حَدَّثَ,Abu Ghuddah: Sahih Lighairihi; Al-Albani: Sahih; Takhreej-Group: Daif,takhreej: تخریج دارالدعوہ: انظر ما قبلہ (ضعیف)  (بمطابق الشیخ ناصر الدین البانی)؛,3877,,
3878,أَخْبَرَنَا أَحْمَدُ بْنُ حَرْبٍ،‏‏‏‏ قَالَ:‏‏‏‏ حَدَّثَنَا أَبُو دَاوُدَ،‏‏‏‏ قَالَ:‏‏‏‏ حَدَّثَنَا,Abu Ghuddah: Sahih Lighairihi; Al-Albani: Sahih; Takhreej-Group: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ النسائي (تحفة الأشراف: ۱۰۸۰۸)، مسند احمد (۴/۴۳۹، ۴۴۳) (ضعیف) (لفظ ’’ غضب ‘‘ میں اس حدیث کا کوئی شاہد نہیں ہے)  (بمطابق الشیخ ناصر الدین البانی)؛,3878,,
3879,أَخْبَرَنَا هِلَالُ بْنُ الْعَلَاءِ،‏‏‏‏ قَالَ:‏‏‏‏ حَدَّثَنَا أَبُو سُلَيْمٍ وَهُوَ عُبَيْدُ بْنُ ي,Abu Ghuddah: Sahih; Al-Albani: Sahih Hadith; Takhreej-Group: Daif,takhreej: تخریج دارالدعوہ: انظر ما قبلہ (ضعیف)  (بمطابق الشیخ ناصر الدین البانی)؛,3879,,
3880,أَخْبَرَنَا يَعْقُوبُ بْنُ إِبْرَاهِيمَ،‏‏‏‏ قَالَ:‏‏‏‏ أَنْبَأَنَا هُشَيْمٌ،‏‏‏‏ قَالَ:‏‏‏‏ أَنْبَأ,Abu Ghuddah: Sahih; Al-Albani: Sahih Hadith; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ النسائي (تحفة الأشراف: ۱۰۸۱۱)، مسند احمد (۴/۴۲۹) (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3880,,
3881,أَخْبَرَنِي عَلِيُّ بْنُ مُحَمَّدِ بْنِ عَلِيٍّ،‏‏‏‏ قَالَ:‏‏‏‏ حَدَّثَنَا خَلَفُ بْنُ تَمِيمٍ،‏‏‏‏,Abu Ghuddah: Sahih; Al-Albani: Sahih; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ النسائي (تحفة الأشراف: ۹۷۰۰) (صحیح) (اس کے راوی ’’علی بن زید بن جدعان‘‘ ضعیف ہیں، لیکن سابقہ سند سے تقویت پاکر یہ صحیح ہے)  (بمطابق الشیخ ناصر الدین البانی)؛,3881,,
3882,أَخْبَرَنَا مُحَمَّدُ بْنُ مَنْصُورٍ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا سُفْيَانُ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّث,Abu Ghuddah: Sahih; Al-Albani: Sahih; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: انظر حدیث رقم: ۳۸۴۳ (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3882,,
3883,أَخْبَرَنَا إِسْحَاق بْنُ إِبْرَاهِيمَ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ أَنْبَأَنَا حَمَّادُ بْنُ مَسْعَدَةَ، ‏‏‏‏‏,Abu Ghuddah: Sahih; Al-Albani: Sahih; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: صحیح البخاری/جزء الصید ۲۷ (۱۸۶۵)، الأیمان ۳۱ (۶۷۰۱)، صحیح مسلم/النذور ۴ (۱۶۴۲)، سنن ابی داود/الأیمان ۲۳ (۳۳۰۱)، سنن الترمذی/الأیمان ۹ (۱۵۳۷)، (تحفة الأشراف: ۳۹۲)، مسند احمد (۳/۱۰۶، ۱۱۴، ۱۸۳، ۱۸۳، ۲۳۵، ۲۷۱) (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3883,,
3884,أَخْبَرَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا خَالِدٌ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّث,Abu Ghuddah: Sahih; Al-Albani: Sahih; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: انظر ما قبلہ (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3884,,
3885,أَخْبَرَنَا أَحْمَدُ بْنُ حَفْصٍ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنِي أَبِي، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنِي إِب,Abu Ghuddah: Hasan Sahih Isnaad; Al-Albani: Hasan Sahih Isnaad; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ النسائي (تحفة الأشراف: ۷۹۹) (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3885,,
3886,أَخْبَرَنَا نُوحُ بْنُ حَبِيبٍ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ أَنْبَأَنَا عَبْدُ الرَّزَّاقِ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ أَ,Abu Ghuddah: Sahih; Al-Albani: Sahih; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: سنن الترمذی/الأیمان ۷ (۱۵۳۲)، سنن ابن ماجہ/الکفارات ۶ (۲۱۰۴)، (تحفة الأشراف: ۱۳۵۲۳)، مسند احمد (۲/۳۰۹) (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3886,,
3887,أَخْبَرَنَا الْعَبَّاسُ بْنُ عَبْدِ الْعَظِيمِ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا عَبْدُ الرَّزَّاقِ، ‏‏‏‏,Abu Ghuddah: Sahih Isnaad; Al-Albani: Sahih Isnaad; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: صحیح البخاری/النکاح ۱۹ (۵۲۴۲)، صحیح مسلم/الأیمان ۵ (۱۶۵۴)، (تحفة الأشراف: ۱۳۵۱۸)، مسند احمد (۲/۲۷۵) (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3887,,
3888,أَخْبَرَنَا مُحَمَّدُ بْنُ حَاتِمٍ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ أَنْبَأَنَا حِبَّانُ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ أَنْبَأَ,Abu Ghuddah: Sahih Isnaad; Al-Albani: Sahih Isnaad; Takhreej-Group: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ النسائي (تحفة الأشراف: ۳۹۵۸)، مسند احمد (۳/۵۹، ۶۸، ۷۱)، مرفوعاً (ضعیف) (اس کے راوی ’’ابرہیم نخعی‘‘ کا ابو سعید خدری سے سماع نہیں ہے، یعنی سند میں انقطاع ہے لیکن اس اثر کا معنی صحیح ہے، آگے کے آثار دیکھیں)  (بمطابق الشیخ ناصر الدین البانی)؛,3888,,
