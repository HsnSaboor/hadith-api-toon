{"hadithnumber": "1080", "text": "ہم سے موسیٰ بن اسماعیل نے بیان کیا، کہا کہ ہم سے ابوعوانہ وضاح یشکری نے بیان کیا، ان سے عاصم احول او"}
{"hadithnumber": "1081", "text": "ہم سے ابومعمر نے بیان کیا، انہوں نے کہا کہ ہم سے عبدالوارث نے بیان کیا، انہوں نے کہا کہ مجھ سے یحییٰ"}
{"hadithnumber": "1082", "text": "ہم سے مسدد بن مسرہد نے بیان کیا، کہا کہ ہم سے یحییٰ نے عبیداللہ عمری سے بیان کیا، کہا کہ مجھے نافع ن"}
{"hadithnumber": "1083", "text": "ہم سے ابوالولید نے بیان کیا، کہا کہ ہم سے شعبہ نے بیان کیا، کہا کہ ہمیں ابواسحاق نے خبر دی، انہوں نے"}
{"hadithnumber": "1084", "text": "ہم سے قتیبہ نے بیان کیا، انہوں نے کہا کہ ہم سے عبدالواحد بن زیاد نے بیان کیا، ان سے اعمش نے، انہوں ن"}
{"hadithnumber": "1085", "text": "ہم سے موسیٰ بن اسماعیل نے بیان کیا کہا کہ ہم سے وہیب نے بیان کیا کہا کہ ہم سے ایوب نے بیان کیا ان سے"}
{"hadithnumber": "1086", "text": "ہم سے اسحاق بن راہویہ نے بیان کیا، انہوں نے ابواسامہ سے، میں نے پوچھا کہ کیا آپ سے عبیداللہ عمری نے"}
{"hadithnumber": "1087", "text": "ہم سے مسدد بن مسرہد نے بیان کیا، کہا کہ ہم سے یحییٰ بن سعید قطان نے، عبیداللہ عمری سے بیان کیا، انہو"}
{"hadithnumber": "1088", "text": "ہم سے آدم نے بیان کیا انہوں نے کہا کہ ہم سے ابن ابی ذئب نے بیان کیا، انہوں نے کہا کہ ہم سے سعید مقبر"}
{"hadithnumber": "1089", "text": "ہم سے ابونعیم نے بیان کیا، انہوں نے کہا کہ ہم سے سفیان نے، محمد بن منکدر اور ابراہیم بن میسرہ سے بیا"}
{"hadithnumber": "1090", "text": "ہم سے عبداللہ بن محمد مسندی نے بیان کیا، کہا کہ ہم سے سفیان بن عیینہ نے زہری سے بیان کیا، ان سے عروہ"}
{"hadithnumber": "1092", "text": "لیث بن سعد نے اس روایت میں اتنا زیادہ کیا کہ مجھ سے یونس نے ابن شہاب سے بیان کیا، کہ سالم نے بیان کی"}
{"hadithnumber": "1093", "text": "ہم سے علی بن عبداللہ مدینی نے بیان کیا، انہوں نے کہا کہ ہم سے عبدالاعلیٰ نے بیان کیا، کہا کہ ہم سے م"}
{"hadithnumber": "1094", "text": "ہم سے ابونعیم نے بیان کیا، انہوں نے کہا کہ ہم سے شیبان نے کہا، ان سے یحییٰ نے بیان کیا، ان سے محمد ب"}
{"hadithnumber": "1095", "text": "ہم سے ابوالاعلیٰ بن حماد نے بیان کیا، انہوں نے کہا کہ ہم سے وہیب نے بیان کیا، انہوں نے کہا کہ ہم سے"}
{"hadithnumber": "1096", "text": "ہم سے موسیٰ بن اسماعیل نے بیان کیا، انہوں نے کہا کہ ہم سے عبدالعزیز بن مسلم نے بیان کیا، انہوں نے کہ"}
{"hadithnumber": "1097", "text": "ہم سے یحییٰ بن بکیر نے بیان کیا انہوں نے کہا کہ ہم سے لیث نے بیان کیا، ان سے عقیل نے بیان کیا، ان سے"}
{"hadithnumber": "1098", "text": "اور لیث بن سعد نے بیان کیا کہ مجھ سے یونس نے بیان کیا، انہوں نے ابن شہاب کے واسطہ سے بیان کیا انہوں"}
{"hadithnumber": "1099", "text": "ہم سے معاذ بن فضالہ نے بیان کیا کہا کہ ہم سے ہشام نے یحییٰ سے بیان کیا ان سے محمد بن عبدالرحمٰن بن ث"}
{"hadithnumber": "1100", "text": "ہم سے احمد بن سعید نے بیان کیا، کہا کہ ہم سے حبان بن ہلال نے بیان کیا، کہا کہ ہم سے ہمام بن یحییٰ نے"}
{"hadithnumber": "1101", "text": "ہم سے یحییٰ بن سلیمان کوفی نے بیان کیا، کہا کہ مجھ سے عبداللہ بن وہب نے بیان کیا، کہا کہ مجھ سے عمر"}
{"hadithnumber": "1102", "text": "ہم سے مسدد بن مسرہد نے بیان کیا، کہا کہ ہم سے یحییٰ بن سعید قطان نے بیان کیا، ان سے عیسیٰ بن حفص بن"}
{"hadithnumber": "1103", "text": "ہم سے حفص بن عمر نے بیان کیا، کہا کہ ہم سے شعبہ نے بیان کیا، ان سے عمرو بن مرہ نے، ان سے ابن ابی لیل"}
{"hadithnumber": "1104", "text": "اور لیث بن سعد رحمہ اللہ نے کہا کہ مجھ سے یونس نے بیان کیا، ان سے ابن شہاب نے، انہوں نے کہا کہ مجھ س"}
{"hadithnumber": "1105", "text": "ہم سے ابوالیمان نے بیان کیا، انہوں نے کہا کہ ہمیں شعیب نے خبر دی، انہیں زہری نے اور انہیں سالم بن عب"}
{"hadithnumber": "1106", "text": "ہم سے علی بن عبداللہ مدینی نے بیان کیا، کہا کہ ہم سے سفیان بن عیینہ نے بیان کیا، انہوں نے کہا کہ میں"}
{"hadithnumber": "1107", "text": "اور ابراہیم بن طہمان نے کہا کہ ان سے حسین معلم نے بیان کیا، ان سے یحییٰ بن ابی کثیر نے بیان کیا، ان"}
{"hadithnumber": "1108", "text": "اور ابن طہمان ہی نے بیان کیا کہ ان سے حسین نے، ان سے یحییٰ بن ابی کثیر نے، ان سے حفص بن عبیداللہ بن"}
{"hadithnumber": "1109", "text": "ہم سے ابوالیمان نے بیان کیا، کہا کہ ہمیں شعیب نے زہری سے خبر دی، انہوں نے کہا کہ مجھے سالم نے عبدالل"}
{"hadithnumber": "1110", "text": "ہم سے اسحاق نے بیان کیا، انہوں نے کہا کہ ہم سے عبدالصمد بن عبدالوارث نے بیان کیا۔ انہوں نے کہا ہم سے"}
{"hadithnumber": "1111", "text": "ہم سے حسان واسطی نے بیان کیا، انہوں نے کہا کہ ہم سے مفضل بن فضالہ نے بیان کیا، ان سے عقیل نے بیان کی"}
{"hadithnumber": "1112", "text": "ہم سے قتیبہ بن سعید نے بیان کیا، انہوں نے کہا کہ ہم سے مفضل بن فضالہ نے بیان کیا، ان سے عقیل نے، ان"}
{"hadithnumber": "1113", "text": "ہم سے قتیبہ بن سعید نے بیان کیا، ان سے امام مالک رحمہ اللہ نے، ان سے ہشام بن عروہ نے، ان سے ان کے با"}
{"hadithnumber": "1114", "text": "ہم سے ابونعیم نے بیان کیا، انہوں نے کہا کہ ہم سے سفیان بن عیینہ نے زہری سے بیان کیا اور ان سے انس رض"}
{"hadithnumber": "1115", "text": "ہم سے اسحاق بن منصور نے بیان کیا، انہوں نے کہا ہمیں روح بن عبادہ نے خبر دی، انہوں نے کہا ہمیں حسین ن"}
{"hadithnumber": "1116", "text": "ہم سے ابومعمر نے بیان کیا، کہا کہ ہم سے عبدالوارث نے بیان کیا، کہا کہ ہم سے حسین معلم نے بیان کیا او"}
{"hadithnumber": "1117", "text": "ہم سے عبدان نے بیان کیا، ان سے امام عبداللہ بن مبارک نے، ان سے ابراہیم بن طہمان نے، انہوں نے کہا کہ"}
{"hadithnumber": "1118", "text": "ہم سے عبداللہ بن یوسف تنیسی نے بیان کیا، انہوں نے کہا کہ ہمیں امام مالک رحمہ اللہ نے خبر دی، انہیں ہ"}
{"hadithnumber": "1119", "text": "ہم سے عبداللہ بن یوسف تنیسی نے بیان کیا، انہوں نے کہا کہ ہمیں امام مالک رحمہ اللہ نے عبداللہ بن یزید"}
