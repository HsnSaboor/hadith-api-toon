{"metadata":{"name":"Sunan Abu Dawud","section":{"23":"Commercial Transactions (Kitab Al-Buyu)"},"section_detail":{"23":{"hadithnumber_first":3326,"hadithnumber_last":3415,"arabicnumber_first":3326,"arabicnumber_last":3415}}},"hadiths":[{"hadithnumber":3367,"arabicnumber":3367,"text":"Rapporté par ‘Abdullah bin ‘Umar : Le Messager d’Allah ﷺ a interdit la vente de fruits tant qu’ils ne sont pas manifestement en bon état, interdisant cela aussi bien au vendeur qu’à l’acheteur","grades":[{"name":"Al-Albani","grade":"Sahih"},{"name":"Muhammad Muhyi Al-Din Abdul Hamid","grade":"Sahih"},{"name":"Zubair Ali Zai","grade":"Sahih Bukhari (2194) Sahih Muslim (1534)"}],"reference":{"book":23,"hadith":42}}]}