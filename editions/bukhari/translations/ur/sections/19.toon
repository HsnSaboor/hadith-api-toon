{"hadithnumber": "1120", "text": "ہم سے علی بن عبداللہ مدینی نے بیان کیا، کہا کہ ہم سے سفیان بن عیینہ نے بیان کیا، کہا کہ ہم سے سلیمان"}
{"hadithnumber": "1122", "text": "یہ خواب میں نے  ( اپنی بہن )  حفصہ رضی اللہ عنہا کو سنایا اور انہوں نے رسول اللہ صلی اللہ علیہ وسلم"}
{"hadithnumber": "1123", "text": "ہم سے ابوالیمان نے بیان کیا، انہوں نے کہا کہ ہمیں شعیب نے زہری سے خبر دی، انہوں نے کہا کہ مجھے عروہ"}
{"hadithnumber": "1124", "text": "ہم سے ابونعیم نے بیان کیا، کہا کہ ہم سے سفیان ثوری نے اسود بن قیس سے بیان کیا، کہا کہ میں نے جندب رض"}
{"hadithnumber": "1125", "text": "ہم سے محمد بن کثیر نے بیان کیا، انہوں نے کہا کہ ہمیں سفیان ثوری نے اسود بن قیس سے خبر دی، ان سے جندب"}
{"hadithnumber": "1126", "text": "ہم سے محمد بن مقاتل نے بیان کیا، انہیں عبداللہ بن مبارک نے خبر دی، انہیں معمر نے خبر دی، انہیں زہری"}
{"hadithnumber": "1127", "text": "ہم سے ابوالیمان نے بیان کیا، کہا کہ ہمیں شعیب نے زہری سے خبر دی، کہا کہ مجھے زین العابدین علی بن حسی"}
{"hadithnumber": "1128", "text": "ہم سے عبداللہ بن یوسف تنیسی نے بیان کیا، انہوں نے کہا کہ ہم سے امام مالک نے ابن شہاب زہری سے بیان کی"}
{"hadithnumber": "1129", "text": "ہم سے عبداللہ بن یوسف تنیسی نے بیان کیا، انہوں نے کہا کہ ہمیں امام مالک رحمہ اللہ نے خبر دی، انہیں ا"}
{"hadithnumber": "1130", "text": "ہم سے ابونعیم نے بیان کیا، کہا کہ ہم سے مسعر نے بیان کیا، ان سے زیاد بن علاقہ نے، انہوں نے بیان کیا"}
{"hadithnumber": "1131", "text": "ہم سے علی بن عبداللہ نے بیان کیا، کہا کہ ہم سے سفیان بن عیینہ نے بیان کیا، کہا کہ ہم سے عمرو بن دینا"}
{"hadithnumber": "1132", "text": "ہم سے عبدان نے بیان کیا، کہا کہ مجھے میرے باپ عثمان بن جبلہ نے شعبہ سے خبر دی، انہیں اشعث نے۔ اشعث ن"}
{"hadithnumber": "1132", "text": "ہم سے عبدان نے بیان کیا، کہا کہ مجھے میرے باپ عثمان بن جبلہ نے شعبہ سے خبر دی، انہیں اشعث نے۔ اشعث ن"}
{"hadithnumber": "1133", "text": "ہم سے موسیٰ بن اسماعیل نے بیان کیا، کہا کہ ہم سے ابراہیم بن سعد نے بیان کیا، کہا کہ میرے باپ سعد بن"}
{"hadithnumber": "1134", "text": "ہم سے یعقوب بن ابراہیم نے بیان کیا، کہا کہ ہم سے روح بن عبادہ نے بیان کیا، کہا کہ ہم سے سعید بن ابی"}
{"hadithnumber": "1135", "text": "ہم سے سلیمان بن حرب نے بیان کیا، کہا کہ ہم سے شعبہ نے اعمش سے بیان کیا، ان سے ابووائل نے اور ان سے ع"}
{"hadithnumber": "1136", "text": "ہم سے حفص بن عمر نے بیان کیا، کہا کہ ہم سے خالد بن عبداللہ نے بیان کیا، ان سے حصین بن عبدالرحمٰن نے"}
{"hadithnumber": "1137", "text": "ہم سے ابوالیمان نے بیان کیا، کہا کہ ہمیں شعیب نے زہری سے خبر دی، کہا کہ مجھے سالم بن عبداللہ نے خبر"}
{"hadithnumber": "1138", "text": "ہم سے مسدد نے بیان کیا، کہا کہ ہم سے یحییٰ بن سعید قطان نے بیان کیا، ان سے شعبہ نے کہا کہ مجھ سے ابو"}
{"hadithnumber": "1139", "text": "ہم سے اسحاق بن راہویہ نے بیان کیا، کہا کہ ہم سے عبیداللہ بن موسیٰ نے بیان کیا، کہا کہ ہمیں اسرائیل ن"}
{"hadithnumber": "1140", "text": "ہم سے عبیداللہ بن موسیٰ نے بیان کیا، کہا کہ ہمیں حنظلہ بن ابی سفیان نے خبر دی، انہیں قاسم بن محمد نے"}
{"hadithnumber": "1141", "text": "ہم سے عبدالعزیز بن عبداللہ نے بیان کیا، کہا کہ مجھ سے محمد بن جعفر نے بیان کیا، ان سے حمید طویل نے،"}
{"hadithnumber": "1142", "text": "ہم سے عبداللہ بن یوسف تنیسی نے بیان کیا، کہا کہ ہمیں امام مالک رحمہ اللہ نے خبر دی، انہیں ابوالزناد"}
{"hadithnumber": "1143", "text": "ہم سے مؤمل بن ہشام نے بیان کیا، کہا کہ ہم سے اسماعیل بن علیہ نے بیان کیا، کہا کہ ہم سے عوف اعرابی نے"}
{"hadithnumber": "1144", "text": "ہم سے مسدد نے بیان کیا، کہا کہ ہم سے ابوالاحوص سلام بن سلیم نے بیان کیا، کہا کہ ہم سے منصور بن معتمر"}
{"hadithnumber": "1145", "text": "ہم سے عبداللہ بن مسلمہ قعنبی نے بیان کیا، ان سے امام مالک رحمہ اللہ نے، ان نے ابن شہاب نے، ان سے ابو"}
{"hadithnumber": "1146", "text": "ہم سے ابوالولید نے بیان کیا، کہا کہ ہم سے شعبہ نے بیان کیا، (دوسری سند) اور مجھ سے سلیمان بن حرب نے"}
{"hadithnumber": "1147", "text": "ہم سے عبداللہ بن یوسف تنیسی نے بیان کیا، انہوں نے کہا کہ ہمیں امام مالک رحمہ اللہ نے خبر دی، انہیں س"}
{"hadithnumber": "1148", "text": "ہم سے محمد بن مثنی نے بیان کیا، انہوں نے کہا کہ ہم سے یحییٰ بن سعید قطان نے بیان کیا اور انہوں نے کہ"}
{"hadithnumber": "1149", "text": "ہم سے اسحاق بن نصر نے بیان کیا، انہوں نے کہا کہ ہم سے ابواسامہ حماد بن اسابہ نے بیان کیا، ان سے ابوح"}
{"hadithnumber": "1150", "text": "ہم سے ابو معمرعبداللہ بن عمرو نے بیان کیا، کہا کہ ہم سے عبدالوارث بن سعد نے بیان کیا، کہا کہ ہم سے ع"}
{"hadithnumber": "1151", "text": "اور امام بخاری رحمہ اللہ نے فرمایا کہ ہم سے عبداللہ بن مسلمہ قعنبی نے بیان کیا، ان سے مالک رحمہ اللہ"}
{"hadithnumber": "1152", "text": "ہم سے عباس بن حسین نے بیان کیا، کہا کہ ہم سے مبشر بن اسماعیل حلبی نے، اوزاعی سے بیان کیا (دوسری سند)"}
{"hadithnumber": "1153", "text": "ہم سے علی بن عبداللہ مدینی نے بیان کیا، کہا کہ ہم سے سفیان بن عیینہ نے بیان کیا، ان سے عمرو بن دینار"}
{"hadithnumber": "1154", "text": "ہم سے صدقہ بن فضل نے بیان کیا، کہا کہ ہم کو ولید بن مسلم نے امام اوزاعی سے خبر دی، کہا کہ مجھ کو عمی"}
{"hadithnumber": "1155", "text": "ہم سے یحییٰ بن بکیر نے بیان کیا، کہا کہ ہم سے لیث بن سعد نے بیان کیا، ان سے یونس نے، ان سے ابن شہاب"}
{"hadithnumber": "1158", "text": "بہت سے صحابہ رضوان اللہ علیہم اجمعین نے نبی کریم صلی اللہ علیہ وسلم سے اپنے خواب بیان کئے کہ شب قدر"}
{"hadithnumber": "1159", "text": "ہم سے عبداللہ بن یزید نے بیان کیا، کہا کہ ہم سے سعید بن ابی ایوب نے بیان کیا، کہا کہ مجھ سے جعفر بن"}
{"hadithnumber": "1160", "text": "ہم سے عبداللہ بن یزید نے بیان کیا، انہوں نے کہا کہ ہم سے سعید بن ابی ایوب نے بیان کیا، انہوں نے کہا"}
{"hadithnumber": "1161", "text": "ہم سے بشر بن حکم نے بیان کیا، انہوں نے کہا کہ ہم سے سفیان نے بیان کیا، انہوں نے کہا کہ مجھ سے سالم ا"}
{"hadithnumber": "1162", "text": "ہم سے قتیبہ نے بیان کیا، کہا کہ ہم سے عبدالرحمٰن بن ابی الموال نے بیان کیا، ان سے محمد بن منکدر نے ا"}
{"hadithnumber": "1163", "text": "ہم سے مکی بن ابراہیم نے بیان کیا، ان سے عبداللہ بن سعید نے، ان سے عامر بن عبداللہ بن زبیر نے بیان کی"}
{"hadithnumber": "1164", "text": "ہم سے عبداللہ بن یوسف تنیسی نے بیان کیا، کہا کہ ہمیں امام مالک نے خبر دی، انہیں اسحاق بن عبداللہ بن"}
{"hadithnumber": "1165", "text": "ہم سے یحییٰ بن بکیر نے بیان کیا، انہوں نے کہا کہ ہم سے لیث نے عقیل سے بیان کیا، عقیل سے ابن شہاب نے،"}
{"hadithnumber": "1166", "text": "ہم سے آدم بن ابی ایاس نے بیان کیا، کہا کہ ہمیں شعبہ نے خبر دی، انہیں عمرو بن دینار نے خبر دی، کہا کہ"}
{"hadithnumber": "1167", "text": "ہم سے ابونعیم نے بیان کیا، کہا کہ ہم سے سیف بن سلیمان نے بیان کیا کہ میں نے مجاہد سے سنا، انہوں نے ف"}
{"hadithnumber": "1168", "text": "ہم سے علی بن عبداللہ مدینی نے بیان کیا، ان سے سفیان بن عیینہ نے بیان کیا، ان سے ابوالنضر سالم نے بیا"}
{"hadithnumber": "1169", "text": "ہم سے بیان بن عمرو نے بیان کیا، انہوں نے کہا کہ ہم سے یحییٰ بن سعید قطان نے بیان کیا، انہوں نے کہا ک"}
{"hadithnumber": "1170", "text": "ہم سے عبداللہ بن یوسف تنیسی نے بیان کیا، انہوں نے کہا کہ ہمیں امام مالک رحمہ اللہ نے خبر دی، انہیں ہ"}
{"hadithnumber": "1171", "text": "مجھ سے محمد بن بشار نے بیان کیا، انہوں نے کہا کہ ہم سے محمد بن جعفر نے بیان کیا، ان سے شعبہ نے بیان"}
{"hadithnumber": "1173", "text": "ان سے (ابن عمر رضی اللہ عنہما نے بیان کیا کہ) میری بہن حفصہ رضی اللہ عنہا نے مجھ سے بیان کیا کہ  نبی"}
{"hadithnumber": "1174", "text": "ہم سے علی بن عبداللہ مدینی نے بیان کیا، کہا کہ ہم سے سفیان بن عیینہ نے عمرو بن دینار سے بیان کیا، ان"}
{"hadithnumber": "1175", "text": "ہم سے مسدد بن مسرہد نے بیان کیا، کہا کہ ہم سے یحییٰ بن سعید قطان نے بیان کیا، ان سے شعبہ بن حجاج نے،"}
{"hadithnumber": "1176", "text": "ہم سے آدم بن ابی ایاس نے بیان کیا، کہا کہ ہم سے شعبہ نے بیان کیا، کہا کہ ہم سے عمرو بن مرہ نے بیان ک"}
{"hadithnumber": "1177", "text": "ہم سے آدم بن ابی ایاس نے بیان کیا، انہوں نے کہا کہ ہم سے ابن ابی ذئب نے بیان کیا، ان سے زہری نے بیان"}
{"hadithnumber": "1178", "text": "ہم سے مسلم بن ابراہیم نے بیان کیا، انہوں نے کہا ہمیں شعبہ نے خبر دی، انہوں نے کہا ہم سے عباس جریری ن"}
{"hadithnumber": "1179", "text": "ہم سے علی بن جعد نے بیان کیا کہ ہم کو شعبہ نے خبر دی، ان سے انس بن سیرین نے بیان کیا کہ میں نے انس ب"}
{"hadithnumber": "1181", "text": "مجھ کو ام المؤمنین حفصہ رضی اللہ عنہا نے بتلایا کہ  مؤذن جب اذان دیتا اور فجر ہو جاتی تو آپ صلی اللہ"}
{"hadithnumber": "1182", "text": "ہم سے مسدد بن مسرہد نے بیان کیا، کہا کہ ہم سے یحییٰ بن سعید قطان نے بیان کیا، کہا کہ ہم سے شعبہ نے،"}
{"hadithnumber": "1183", "text": "ہم سے ابومعمر نے بیان کیا، کہا کہ ہم سے عبدالوارث نے بیان کیا، ان سے حسین معلم نے، ان سے عبداللہ بن"}
{"hadithnumber": "1184", "text": "ہم سے عبداللہ بن یزید نے بیان کیا، کہا کہ ہم سے سعید بن ابی ایوب نے بیان کیا، کہا کہ مجھ سے یزید بن"}
{"hadithnumber": "1185", "text": "ہم سے اسحاق بن راہویہ نے بیان کیا، کہا کہ ہم سے یعقوب بن ابراہیم نے بیان کیا، کہا کہ ہم سے ہمارے باپ"}
{"hadithnumber": "1187", "text": "ہم سے عبدالاعلی بن حماد نے بیان کیا، کہا کہ ہم سے وہیب بن خالد نے بیان کیا، ان سے ایوب سختیانی اور ع"}
