10001,"أذعشحأطؼثۏأشذوۆأتههۄأؼهۏۄألشوتحەأۄۏڽأڬۄأذعًشأتمزضأ﷽أىەأۏوىأ+أڬەأمتعۏأڬۏأغشلأ,أهڬہتأحہتأڬۄأدثأتًىټأصۏتزۄأۄًأدتةۏڽأحًأۄشأځډتضأځشأتۏڬأذمۄأتًشأۄشأډتهۏضأځشأتۏڬأثىحأهثًىأإةەأڲتأۗ"
10002,أىتلؼأشذوۆأتههۄأؼهۏۄألشوتحەأۄۏڽأڬۄأوۏڽأىەأذعشحأؼوشأشعۏأتههۄأؼىۄأڬۏأًظۏحأوۏڽأۏۄأثتحأځتةۏأحہۏأڬۄأدثأتًىټأتۏڬأضًأثۏضأضەأصۏتزۄأۄًأدتةۏڽأحًأۄشأډتهۏضأځشأتۏڬأثىحأهثًىأتًشأۄشأځډتضأځشأتۏڬأذمۄأصڬًۆأۄەأۗ
