hadiths[486]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}:
37203,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، وَوَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ عَبْدِ اللہِ بْنِ مُرَّۃَ ، عَنِ الْبَرَائِ بْنِ عَازِبٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجَمَ یَہُودِیًّا۔,,,37203
37204,حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ مُجَالِدٍ ، عَنْ عَامِرٍ ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجَمَ یَہُودِیًّا وَیَہُودِیَّۃً۔,,,37204
37205,حَدَّثَنَا ابْنُ نُمَیْرٍ ، حَدَّثَنَا عُبَیْدُ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجَمَ یَہُودِیَّیْنِ ، أَنَا فِیمَنْ رَجَمَہُمَا۔,,,37205
37206,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنِ الشَّعْبِیِّ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجَمَ یَہُودِیًّا وَیَہُودِیَّۃً۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لَیْسَ عَلَیْہِمَا رَجْمٌ۔",,,37206
37207,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ الأَعْمَشِ ، عَنْ عَبْدِ اللہِ بْنِ عَبْدِ اللہِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، عَنِ الْبَرَائِ بْنِ عَازِبٍ ، قَالَ : جَائَ رَجُلٌ إلَی النَّبِیٍِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : أُصَلِّی فِی مَرَابِضِ الْغَنَمِ ؟ قَالَ: نَعَمْ، قَالَ: أَتَوَضَّأُ مِنْ لُحُومِہَا ؟ قَالَ: لاَ ، قَالَ: فَأُصَلِّی فِی مَبَارِکِ الإِبِلِ؟ قَالَ: لاَ ، قَالَ: أَفَأَتَوَضَّأُ مِنْ لُحُومِہَا؟ قَالَ : نَعَمْ۔",,,37207
37208,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، عَنْ عَبْدِ اللہِ بْنِ مُغَفَّلٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : صَلُّوا فِی مَرَابِضِ الْغَنَمِ ، وَلاَ تُصَلُّوا فِی أَعْطَانِ الإِبِلِ ، فَإِنَّہَا خُلِقَتْ مِنَ الشَّیْطَانِ۔",,,37208
37209,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ إِسْرَائِیلَ ، عَنْ أَشْعَثَ بْنِ أَبِی الشَّعْثَائِ ، عَنْ جَعْفَرِ بْنِ أَبِی ثَوْرٍ ، عَنْ جَابِرِ بْنِ سَمُرَۃَ ، قَالَ : أَمَرَنَا النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ نَتَوَضَّأَ مِنْ لُحُومِ الإِبِلِ ، وَلاَ نَتَوَضَّأَ مِنْ لُحُومِ الْغَنَمِ ، وَأَنْ نُصَلِّیَ فِی دِمَنِ الْغَنَمِ ، وَلاَ نُصَلِّیَ فِی أَعْطَانِ الإِبِلِ۔",,,37209
37210,"حَدَّثَنَا یَزِیدُ ،عَنْ ہِشَامٍ ، عَنْ مُحَمَّدِ بْنِ سِیرِینَ ، عَنْ أَبِی ہُرَیْرَۃَ ؛ عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ: إِذَا لَمْ تَجِدُوا إِلاَّ مَرَابِضَ الْغَنَمِ وَأَعْطَانَ الإِبِلِ، فَصَلُّوا فِی مَرَابِضِ الْغَنَمِ، وَلاَ تُصَلُّوا فِی أَعْطَانِ الإِبِلِ۔",,,37210
37211,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ عَبْدِ الْمَلِکِ بْنِ الرَّبِیعِ بْنِ سَبْرَۃَ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لاَ یُصَلَّی فِی أَعْطَانِ الإِبِلِ۔\n\nوَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ بَأْسَ بِذَلِکَ۔",,,37211
37212,حَدَّثَنَا ابْنُ نُمَیْرٍ ، وَأَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ أَنَّہُ قَسَمَ لِلْفَرَسِ سَہْمَیْنِ ، وَلِلرَّجُلِ سَہْمًا۔,,,37212
37213,"حَدَّثَنَا حَفْصُ بْنِ غِیَاثٍ ، عَنْ حَجَّاجٍ ، عَنْ مَکْحُولٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ جَعَلَ لِلْفَارِسِ ثَلاَثَۃَ أَسْہُمٍ : سَہْمَیْنِ لِفَرَسِہِ ، وَسَہْمًا لَہُ۔",,,37213
37214,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ أُسَامَۃَ بْنِ زَیْدٍ ، عَنْ مَکْحُولٍ ، قَالَ : أَسْہَمَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَوْمَ خَیْبَرَ لِلْفَرَسِ سَہْمَیْنِ ، وَلِلرَّجُلِ سَہْمًا۔",,,37214
37215,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی صَالِحٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ جَعَلَ لِلْفَارِسِ ثَلاَثَۃَ أَسْہُمٍ : سَہْمًا لَہُ ، وَسَہْمَیْنِ لِفَرَسِہِ۔",,,37215
37216,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ صَالِحِ بْنِ کَیْسَانَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَسْہَمَ یَوْمَ خَیْبَرَ لِمِئَتَیْ فَرَسٍ ، لِکُلِّ فَرَسٍ سَہْمَیْنِ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : سَہْمٌ لِلْفَرَسِ ، وَسَہْمٌ لِصَاحِبِہِ۔",,,37216
37217,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، وَأَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی أَنْ یُسَافَرَ بِالْقُرْآنِ إلَی أَرْضِ الْعَدُوِّ ، مَخَافَۃَ أَنْ یَنَالَہُ الْعَدُوُّ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ بَأْسَ بِذَلِکَ۔ (احمد 55۔ مالک 7)",,,37217
37218,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ حُمَیْدِ بْنِ عَبْدِ الرَّحْمَنِ ، وَعَنْ مُحَمَّدِ بْنِ النُّعْمَانِ ، عَنْ أَبِیہِ ؛ أَنَّ أَبَاہُ نَحَلَہُ غُلاَمًا ، وَأَنَّہُ أَتَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لِیُشْہِدَہُ ، فَقَالَ : أَکُلَّ وَلَدِکَ نَحَلْتَہُ مِثْلَ ہَذَا ؟ قَالَ : لاَ ، قَالَ : فَارْدُدْہُ۔",,,37218
37219,"حَدَّثَنَا عَبَّادٌ ، عَنْ حُصَیْنٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : سَمِعْتُ النُّعْمَانَ بْنَ بَشِیرٍ ، یَقُولُ : أَعْطَانِی أَبِی عَطِیَّۃً ، فَقَالَتْ أُمِّی عَمْرَۃُ بِنْتُ رَوَاحَۃَ : لاَ أَرْضَی حَتَّی تُشْہِدَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : فَأَتَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : إِنِّی أَعْطَیْتُ ابْنِی مِنْ عَمْرَۃَ عَطِیَّۃً ، فَأَمَرَتْنِی أَنْ أُشْہِدَک ، قَالَ : أَعْطَیْتَ کُلَّ وَلَدِکَ مِثْلَ ہَذَا ؟ قَالَ : لاَ ، قَالَ : فَاتَّقُوا اللَّہَ ، وَاعْدِلُوا بَیْنَ أَوْلاَدِکُمْ۔",,,37219
37220,"حَدَّثَنَا ابْنُ مُسْہِرٍ ، عَنْ أَبِی حَیَّانَ ، عَنِ الشَّعْبِیِّ ، عَنِ النُّعْمَانِ بْنِ بَشِیرٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أَنَّہُ قَالَ : لاَ أَشْہَدُ عَلَی جَوْرٍ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ بَأْسَ بِہِ۔",,,37220
37221,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، سَمِعَ جَابِرًا ، یَقُولُ : دَبَّرَ رَجُلٌ مِنَ الأَنْصَارِ غُلاَمًا لَہُ ، وَلَمْ یَکُنْ لَہُ مَالٌ غَیْرُہُ، فَبَاعَہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، فَاشْتَرَاہُ النَّحَّامُ عَبْدًا قِبْطِیًّا مَاتَ عَامَ الأَوَّلِ فِی إِمَارَۃِ ابْنِ الزُّبَیْرِ۔",,,37221
37222,"حَدَّثَنَا شَرِیکٌ، عَنْ سَلَمَۃَ، عَنْ عَطَائٍ، وَأَبِی الزُّبَیْرِ، عَنْ جَابِرٍ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَاعَ مُدَبَّرًا۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ یُبَاعُ۔",,,37222
37223,"حَدَّثَنَا حَفْصٌ ، وَابْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : صَلَّی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَلَی قَبْرٍ بَعْدَ مَا دُفِنَ۔",,,37223
37224,حَدَّثَنَا ہُشَیْمٌ ، عَنْ عُثْمَانَ بْنِ حَکِیمٍ ، عَنْ خَارِجَۃَ بْنِ زَیْدٍ ، عَنْ عَمِّہِ یَزِیدَ بْنِ ثَابِتٍ ، وَکَانَ أَکْبَرَ مِنْ زَیْدٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی عَلَی امْرَأَۃٍ بَعْدَ مَا دُفِنَتْ ، فَصَلَّی عَلَیْہَا أَرْبَعًا۔,,,37224
37225,"حَدَّثَنَا سَعِیدُ بْنُ یَحْیَی الْحِمْیَرِیُّ ، عَنْ سُفْیَانَ بْنِ حُسَیْنٍ ، عَنِ الزُّہْرِیِّ ، عَنْ أَبِی أُمَامَۃَ بْنِ سَہْلٍ ، عَنْ أَبِیہِ ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَعُودُ فُقَرَائَ أَہْلِ الْمَدِینَۃِ ، وَیَشْہَدُ جَنَائِزَہُمْ إِذَا مَاتُوا ، قَالَ : فَتُوُفِّیَتِ امْرَأَۃٌ مِنْ أَہْلِ الْعَوَالِی ، قَالَ : فَمَشَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إِلَی قَبْرِہَا وَکَبَّرَ أَرْبَعًا۔",,,37225
37226,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ، عَنْ أَبِی الْمُہَلَّبِ ، عَنْ عِمْرَانَ بْنِ حُصَیْنٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إِنَّ أَخًا لَکُمْ قَدْ مَاتَ فَصَلُّوا عَلَیْہِ ، یَعْنِی النَّجَّاشِیَّ۔",,,37226
37227,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ أَبِی ہُرَیْرَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی عَلَی النَّجَاشِیِّ ، فَکَبَّرَ عَلَیْہِ أَرْبَعًا۔,,,37227
37228,حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، حَدَّثَنَا سُفْیَانُ ، عَنْ أَبِی سِنَانٍ ، عَنْ عَبْدِ اللہِ بْنِ الْحَارِثِ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی عَلَی مَیِّتٍ بَعْدَ مَا دُفِنَ۔,,,37228
37229,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، أَخْبَرَنَا سُلَیْمُ بْنُ حَیَّانَ ، عَنْ سَعِیدِ بْنِ مِینَائَ ، عَنْ جَابِرٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی عَلَی أَصْحَمَۃَ ، وَکَبَّرَ عَلَیْہِ أَرْبَعًا۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ یُصَلَّی عَلَی مَیِّتٍ مَرَّتَیْنِ۔",,,37229
37230,حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ قَتَادَۃَ ، عَنْ أَبِی حَسَّانَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَشْعَرَ فِی الأَیْمَنِ ، وَسَلَتَ الدَّمَ بِیَدِہِ۔,,,37230
37231,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عُرْوَۃَ ، عَنِ الْمِسْوَرِ بْنِ مَخْرَمَۃَ ، وَمَرْوَانَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَامَ الْحُدَیْبِیَۃِ خَرَجَ فِی بِضْعَ عَشْرَۃَ مِئَۃٍ مِنْ أَصْحَابِہِ ، فَلَمَّا کَانَ بِذِی الْحُلَیْفَۃِ قَلَّدَ الْہَدْیَ ، وَأَشْعَرَ ، وَأَحْرَمَ۔,,,37231
37232,"حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنْ أَفْلَحَ ، عَنِ الْقَاسِمِ ، عَنْ عَائِشَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَشْعَرَ۔\n\nوَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : الإِشْعَارُ مُثْلَۃٌ۔",,,37232
37233,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنْ ہِلاَلِ بْنِ یَِسَافٍ ، قَالَ : أَخَذَ بِیَدِی زِیادُ بْنُ أَبِی الْجَعْدِ فَأَوْقَفَنِی عَلَی شَیْخٍ بِالرَّقَّۃِ ، یُقَالُ لَہُ : وَابِصَۃُ بْنُ مَعْبَدٍ ، قَالَ : صَلَّی رَجُلٌ خَلْفَ الصَّفِّ وَحْدَہُ ، فَأَمَرَہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یُعِیدَ۔",,,37233
37234,"حَدَّثَنَا مُلاَزِمُ بْنُ عَمْرٍو ، عَنْ عَبْدِ اللہِ بْنِ بَدْرٍ ، قَالَ : حدَّثَنِی عَبْدُ الرَّحْمَنِ بْنُ عَلِیِّ بْنِ شَیْبَانَ ، عَنْ أَبِیہِ عَلِیِّ بْنِ شَیْبَانَ ، وَکَانَ مِنَ الْوَفْدِ ، قَالَ : خَرَجْنَا حَتَّی قَدِمْنَا عَلَی نَبِیِّ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَبَایَعَنَاہُ وَصَلَّیْنَا خَلْفَہُ ، فَرَأَی رَجُلاً یُصَلِّی خَلْفَ الصَّفِّ ، قَالَ : فَوَقَفَ عَلَیْہِ نَبِیُّ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَتَّی انْصَرَفَ ، فَقَالَ : اسْتَقْبِلْ صَلاَتَکَ ، فَلاَ صَلاَۃَ لِلَّذِی خَلْفَ الصَّفِّ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : تُجْزِئُہُ صَلاَتُہُ۔",,,37234
37235,"حَدَّثَنَا عَبْدَۃُ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، عَنْ عَبْدِ اللہِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لاَعَنْ بَیْنَ رَجُلٍ وَامْرَأَتِہِ ، وَقَالَ : عَسَی أَنْ تَجِیئَ بِہِ أَسْوَدَ جَعْدًا ، فَجَائَتْ بِہِ أَسْوَدَ جَعْدًا۔",,,37235
37236,حَدَّثَنَا وَکِیعٌ ، عَنْ عَبَّادِ بْنِ مَنْصُورٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لاَعَنَ بِالْحَمْلِ۔ (احمد 355),,,37236
37237,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی خَالِدٍ ، عَنِ الشَّعْبِیِّ ؛ فِی رَجُلٍ تَبَرَّأَ مِمَّا فِی بَطْنِ امْرَأَتِہِ ، قَالَ : یُلاَعَنْہَا۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ کَانَ لاَ یَرَی الْمُلاعَنْۃ بِالْحَمْلِ۔",,,37237
37238,حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنْ أَیُّوبَ، عَنْ أَبِی قِلاَبَۃَ، عَنْ أَبِی الْمُہَلَّبِ، عَنْ عِمْرَانَ بْنِ حُصَیْنٍ؛ أَنَّ رَجُلاً کَانَ لَہُ سِتَّۃُ أَعْبُدٍ ، فَأَعْتَقَہُمْ عِنْدَ مَوْتِہِ ، فَأَقْرَعَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَیْنَہُمْ ، فَأَعْتَقَ اثْنَیْنِ ، وَأَرَقَّ أَرْبَعَۃً۔,,,37238
37239,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ إِسْرَائِیلَ ، عَنْ عَبْدِ اللہِ بْنِ الْمُخْتَارِ ، عَنْ مُحَمَّدِ بْنِ زِیَادٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، نَحْوَہُ ، أَوْ مِثْلَہُ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لَیْسَ ہَذَا بِشَیْئٍ ، وَلاَ یَرَی فِیہِ قُرْعَۃً۔",,,37239
37240,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عُبَیْدِ اللہِ بْنِ عَبْدِ اللہِ ، عَنْ زَیْدِ بْنِ خَالِدٍ ، وَشِبْلٍ ، وَأَبِی ہُرَیْرَۃَ ، قَالُوا: کُنَّا عِنْدَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَأَتَاہُ رَجُلٌ فَسَأَلَہُ عَنِ الأَمَۃِ تَزْنِی قَبْلَ أَنْ تُحْصِنَ ؟ قَالَ: اجْلِدُوہَا ، فَإِنْ عَادَتْ فَاجْلِدُوہَا ، قَالَ فِی الثَّالِثَۃِ ، أَوِ الرَّابِعَۃِ : فَبِیعُوہَا وَلَوْ بِضَفِیرٍ۔",,,37240
37241,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ عَبْدِ الأَعْلَی ، عَنْ أَبِی جَمِیلَۃَ ، عَنْ عَلِیٍّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَقِیمُوا الْحُدُودَ عَلَی مَا مَلَکَتْ أَیْمَانُکُمْ۔",,,37241
37242,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ أَیُّوبَ بْنِ مُوسَی ، عَنْ سَعِیدٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِذَا زَنَتْ أَمَۃُ أَحَدِکُمْ فَلْیَجْلِدْہَا ، وَلاَ یُثَرِّبْ عَلَیْہَا ، فَإِنْ عَادَتْ فَلْیَجْلِدْہَا ، فَإِنْ عَادَتْ فَلْیَبِعْہَا ، وَلَوْ بِضَفِیرٍ مِنْ شَعْرٍ۔ (نسائی 7247)",,,37242
37243,"حَدَّثَنَا شَبَابَۃُ ، عَنْ لَیْثِ بْنِ سَعْدٍ ، عَنْ یَزِیدَ بْنِ أَبِی حَبِیبٍ ، عَنْ عُمَارَۃَ بْنِ أَبِی فَرْوَۃَ ، عَنْ عُرْوَۃَ ، عَنْ عَائِشَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إذَا زَنَتِ الأَمَۃُ فَاجْلِدُوہَا ، فَإِنْ عَادَتْ فَاجْلِدُوہَا ، فَإِنْ عَادَتْ فَاجْلِدُوہَا ، فَإِنْ زَنَتْ فَاجْلِدُوہَا ، ثُمَّ بِیعُوہَا وَلَوْ بِضَفِیرٍ ۔ وَالضَّفِیرُ الْحَبْلُ۔ (احمد 65)",,,37243
37244,"حَدَّثَنَا مُعَلَّی بْنُ مَنْصُورٍ ، عَنْ أَبِی أُوَیْسٍ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی بَکْرٍ ، عَنْ عَبَّادِ بْنِ تَمِیمٍ ، عَنْ عَمِّہِ ، وَکَانَ بَدْرِیًّا ، قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِذَا زَنَتِ الأَمَۃُ فَاجْلِدُوہَا ، ثُمَّ إِنْ زَنَتْ فَاجْلِدُوہَا ، ثُمَّ إِنْ زَنَتْ فَاجْلِدُوہَا ، ثُمَّ بِیعُوہَا وَلَوْ بِضَفِیرٍ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ یَجْلِدْہَا سَیِّدُہَا۔ (نسائی 7238۔ دارقطنی 197)",,,37244
37245,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ الْوَلِیدِ بْنِ کَثِیرٍ ، عَنْ مُحَمَّدِ بْنِ کَعْبٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عَبْدِ اللہِ بْنِ رَافِعِ بْنِ خَدِیجٍ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ؛ قِیلَ : یَا رَسُولَ اللہِ ، أَنَتَوَضَّأُ مِنْ بِئْرِ بُضَاعَۃَ ، وَہِیَ بِئْرٌ یُلْقَی فِیہَا الْحِیَضُ وَلُحُومُ الْکِلاَبِ وَالنَّتِنُ ؟ فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْمَائُ طَہُورٌ ، لاَ یُنَجِّسُہُ شَیْئٌ۔",,,37245
37246,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ سِمَاکٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : اغْتَسَلَ بَعْضُ أَزْوَاجِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی جَفْنَۃٍ ، فَجَائَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لِیَغْتَسِلَ مِنْہَا ، أَوْ لِیَتَوَضَّأَ ، فَقَالَتْ : یَا رَسُولَ اللہِ ، إِنِّی کُنْتُ جُنُبًا ، قَالَ : إِنَّ الْمَائَ لاَ یُجْنِبُ۔",,,37246
37247,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ الْوَلِیدِ بْنِ کَثِیرٍ ، عَنْ مُحَمَّدِ بْنِ جَعْفَرِ بْنِ الزُّبَیْرِ ، عَنْ عَبْدِ اللہِ بْنِ عَبْدِ اللہِ بْنِ عُمَرَ ، عَنْ أَبِیہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِذَا کَانَ الْمَائُ قُلَّتَیْنِ لَمْ یَحْمِلْ نَجَسًا۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : یَنْجُسُ الْمَائُ۔",,,37247
37248,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَیُّوبَ أَبِی الْعَلاَئِ ، حَدَّثَنَا قَتَادَۃُ ، عَنْ أَنَسٍ ، قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ نَسِیَ صَلاَۃً ، أَوْ نَامَ عْنہَا فَکَفَّارَتُہُ أَنْ یُصَلِّیَہَا إِذَا ذَکَرَہَا۔",,,37248
37249,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ جَامِعِ بْنِ شَدَّادٍ ، قَالَ : سَمِعْتُ عَبْدَ الرَّحْمَن بْنَ أَبِی عَلْقَمَۃَ ، قَالَ : سَمِعْتُ عَبْدَ اللہِ بْنَ مَسْعُودٍ ، قَالَ : أَقْبَلْنَا مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِنَ الْحُدَیْبِیَۃِ فَذَکَرُوا أَنَّہُمْ نَزَلُوا دَہَاسًا مِنَ الأَرْضِ ، یَعْنِی بِالدَّہَاسِ الرَّمْلَ ، قَالَ : فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ یَکْلَؤُنَا ؟ قَالَ : فَقَالَ بِلاَلٌ : أَنَا ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِذًا نَنَامُ ، قَالَ : فَنَامُوا حَتَّی طَلَعَتِ الشَّمْسُ ، قَالَ: فَاسْتَیْقَظَ أُنَاسٌ ، فِیہِمْ فُلاَنٌ وَفُلاَنٌ وَفِیہِمْ عُمَرُ بْنُ الْخَطَّابِ ، قَالَ : فَقُلْنَا : اِہْضِبُوا ، یَعْنِی تَکَلَّمُوا ، قَالَ : فَاسْتَیْقَظَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : افْعَلُوا کَمَا کُنْتُمْ تَفْعَلُونَ ، قَالَ : فَفَعَلْنَا ، قَالَ : فَقَالَ : کَذَلِکَ لِمَنْ نَامَ ، أَوْ نَسِیَ۔",,,37249
37250,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ عَبْدِ الْجَبَّارِ بْنِ عَبَّاسٍ ، عَنْ عَوْنِ بْنِ أَبِی جُحَیْفَۃَ ، عَنْ أَبِیہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لِلَّذِینَ نَامُوا مَعَہُ حَتَّی طَلَعَتِ الشَّمْسُ ، فَقَالَ : إِنَّکُمْ کُنْتُمْ أَمْوَاتًا فَرَدَّ اللَّہُ إِلَیْکُمْ أَرْوَاحَکُمْ ، فَمَنْ نَامَ عَنْ صَلاَۃٍ ، أَوْ نَسِیَ صَلاَۃً ، فَلْیُصَلِّہَا إِذَا ذَکَرَہَا ، وَإِذَا اسْتَیْقَظَ۔",,,37250
37251,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَبِی إِسْمَاعِیلَ ، عَنْ أَبِی حَازِمٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : عَرَّسْنَا مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ذَاتَ لَیْلَۃٍ ، فَلَمْ نَسْتَیْقِظْ حَتَّی آذَتْنَا الشَّمْسُ ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لِیَأْخُذْ کُلُّ رَجُلٍ مِنْکُمْ بِرَأْسِ رَاحِلَتِہِ ، ثُمَّ یَتَنَحَّ عَنْ ہَذَا الْمَنْزِلِ ، ثُمَّ دَعَا بِالْمَائِ فَتَوَضَّأَ ، فَسَجَدَ سَجْدَتَیْنِ ، ثُمَّ أُقِیمَتِ الصَّلاَۃُ فَصَلَّی۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ یُجْزِئُہُ أَنْ یُصَلِّیَ إِذَا اسْتَیْقَظَ عِنْدَ طُلُوعِ الشَّمْسِ ، أَوْ عِنْدَ غُرُوبِہَا۔",,,37251
37252,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنِ الْحَکَمِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، عَنْ کَعْبِ بْنِ عُجْرَۃَ ، عَنْ بِلاَلٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَسَحَ عَلَی الْخُفَّیْنِ وَالْخِمَارِ۔,,,37252
37253,"حَدَّثَنَا یُونُسُ ، عَنْ دَاوُدَ بْنِ أَبِی الْفُرَاتِ ، عَنْ مُحَمَّدِ بْنِ زَیْدٍ ، عَنْ أَبِی شُرَیْحٍ ، عَنْ أَبِی مُسْلِمٍ مَوْلَی زَیْدِ بْنِ صُوحَانَ ، قَالَ : کُنْتُ مَعَ سَلْمَانَ فَرَأَی رَجُلاً یَنْزِعُ خُفَّیْہِ لِلْوُضُوئِ ، فَقَالَ لَہُ سَلْمَانُ : امْسَحْ عَلَی خُفَّیْک وَعَلَی خِمَارِکَ ، وَامْسَحْ بِنَاصِیَتِکَ ، فَإِنِّی رَأَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَمْسَحُ عَلَی الْخُفَّیْنِ وَالْخِمَارِ۔",,,37253
37254,"حَدَّثَنَا یَزِیدُ ، عَنِ التَّیْمِیِّ ، عَنْ بَکْرٍ ، عَنِ ابْنِ الْمُغِیرَۃِ بْنِ شُعْبَۃَ ، عَنْ أَبِیہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ أَنَّہُ مَسَحَ مُقَدَّمَ رَأْسِہِ ، وَعَلَی الْخُفَّیْنِ ، وَوَضَعَ یَدَہُ عَلَی الْعِمَامَۃِ ، وَمَسَحَ عَلَی الْعِمَامَۃِ۔\n\n- وذُکِرَ أَنَّ أبَا حَنِیفَۃَ قَالَ : لاَ یجزِئُ الْمَسْحُ عَلَیْہِِمَا۔",,,37254
37255,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، عَنْ عَبْدِ اللہِ ، قَالَ : صَلَّی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلاَۃً فَزَادَ ، أَوْ نَقَصَ ، فَلَمَّا سَلَّمَ وَأَقْبَلَ عَلَی الْقَوْمِ بِوَجْہِہِ ، قَالُوا : یَا رَسُولَ اللہِ ، حَدَثَ فِی الصَّلاَۃِ شَیْئٌ ؟ قَالَ : وَمَا ذَاکَ ؟ قَالُوا : صَلَّیْت کَذَا وَکَذَا ، فَثَنَی رِجْلَہُ فَسَجَدَ سَجْدَتَیْنِ ، ثُمَّ سَلَّمَ وَأَقْبَلَ عَلَی الْقَوْمِ بِوَجْہِہِ ، فَقَالَ : إِنَّہُ لَوْ حَدَثَ فِی الصَّلاَۃِ شَیْئٌ أَنْبَأْتُکُمْ بِہِ ، وَلَکِنِّی بَشَرٌ أَنْسَی کَمَا تَنْسَوْنَ ، فَإِذَا نَسِیتُ فَذَکِّرُونِی ، وَإِذَا شَکَّ أَحَدُکُمْ فِی صَلاَتِہِ فَلْیَتَحَرَّ الصَّوَابَ فَلْیُتِمَّ عَلَیْہِ ، فَإِذَا سَلَّمَ سَجَدَ سَجْدَتَیْنِ۔ (بخاری 404۔ مسلم 401)",,,37255
37256,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، عَنْ عَبْدِ اللہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ أَنَّہُ صَلَّی الظُّہْرَ خَمْسًا ، فَقِیلَ لَہُ : إِنَّک صَلَّیْتَ خَمْسًا ؟ فَسَجَدَ سَجْدَتَیْنِ بَعْدَ مَا سَلَّمَ۔\n\n- وذُکِرَ أنَّ أبَا حَنِیفَۃَ قَالَ : إِذَا لَمْ یَجْلِس فِی الرَّابِعۃِ أَعَاَد الصَّلاَۃ۔",,,37256
37257,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو؛ سَمِعَ جَابِرًا، یَقُولُ: سَمِعْتُ ابْنَ عَبَّاسٍ، یَقُولُ: سَمِعْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، یَقُولُ : إِذَا لَمْ یَجِدَ الْمُحْرِمُ إِزَارًا ، فَلْیَلْبَسْ سَرَاوِیلَ ، وَإِذَا لَمْ یَجِدْ نَعْلَیْنِ ، فَلْیَلْبَسْ خُفَّیْنِ۔",,,37257
37258,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ زُہَیْرٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ لَمْ یَجِدْ نَعْلَیْنِ فَلْیَلْبَسْ خُفَّیْنِ ، وَمَنْ لَمْ یَجِدْ إِزَارًا فَلْیَلْبَسْ سَرَاوِیلَ۔",,,37258
37259,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ رَجُلٌ : یَا رَسُولَ اللہِ ، مَا یَلْبَسُ الْمُحْرِمُ ؟ أَوْ مَا یَتْرُکُ الْمُحْرِمُ ؟ قَالَ : لاَ یَلْبَسُ الْقَمِیصَ ، وَلاَ السَّرَاوِیلَ ، وَلاَ الْعِمَامَۃَ ، وَلاَ الْخُفَّیْنِ ، إِلاَّ أَنْ لاَ یَجِدَ نَعْلَیْنِ ، فَمَنْ لَمْ یَجِدَ نَعْلَیْنِ ، فَلْیَلْبَسْہُمَا أَسْفَلَ مِنَ الْکَعْبَیْنِ۔\n\n- وذُکِرَ أنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ یَفْعَلُ ، فَإِن فَعَلَ فَعَلَیْہِ دَمٌ۔",,,37259
37260,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ جَابِرِ بْنِ زَیْدٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : صَلَّیْتُ مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، ثَمَانِیًا جَمِیعًا ، وَسَبْعًا جَمِیعًا ، قَالَ : قُلْتُ : یَا أَبَا الشَّعْثَائِ ، أَظُنُّہُ أَخَّرَ الظُّہْرَ وَعَجَّلَ الْعَصْرَ ، وَأَخَّرَ الْمَغْرِبَ وَعَجَّلَ الْعِشَائَ ، قَالَ : وَأَنَا أَظُنُّ ذَلِکَ۔",,,37260
37261,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ ، عَنْ أَبِیہِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ إِذَا جَدَّ بِہِ السَّیْرُ جَمَعَ بَیْنَ الْمَغْرِبِ وَالْعِشَائِ۔,,,37261
37262,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ أَبِی الطُّفَیْلِ ، عَنْ مُعَاذِ بْنِ جَبَلٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ جَمَعَ بَیْنَ الظُّہْرِ وَالْعَصْرِ ، وَالْمَغْرِبِ وَالْعِشَائِ فِی السَّفَرِ ، فِی غَزْوَۃِ تَبُوکَ۔,,,37262
37263,"حَدَّثَنَا ابْنُ مُسْہِرٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطَائٍ ، عَنْ جَابِرٍ ، قَالَ : جَمَعَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی غَزْوَۃِ تَبُوکَ بَیْنَ الظُّہْرِ وَالْعَصْرِ ، وَبَیْنَ الْمَغْرِبِ وَالْعِشَائِ۔",,,37263
37264,"حَدَّثَنَا یَزِیدُ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ حَفْصِ بْنِ عُبَیْدِ اللہِ بْنِ أَنَسٍ ، قَالَ : کُنَّا نُسَافِرُ مَعَ أَنَسٍ إِلَی مَکَّۃَ ، فَکَانَ إِذَا زَالَتِ الشَّمْسُ ، وَہُوَ فِی مَنْزِلٍ ، لَمْ یَرْکَبْ حَتَّی یُصَلِّیَ الظُّہْرَ ، فَإِذَا رَاحَ ، فَحَضَرَتِ الْعَصْرُ صَلَّی الْعَصْرَ ، فَإِنْ سَارَ مِنْ مَنْزِلِہِ قَبْلَ أَنْ تَزُولَ الشَّمْسُ فَحَضَرَتِ الصَّلاَۃُ ، قُلْنَا : الصَّلاَۃَ ، فَیَقُولُ: سِیرُوا ، حَتَّی إِذَا کَانَ بَیْنَ الصَّلاَتَیْنِ نَزَلَ ، فَجَمَعَ بَیْنَ الظُّہْرِ وَالْعَصْرِ ، ثُمَّ قَالَ : رَأَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إِذَا وَصَلَ ضَحْوَتہُ بِرَوْحَتِہِ صَنَعَ ہَکَذَا۔",,,37264
37265,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ حَجَّاجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ جَمَعَ بَیْنَ الصَّلاَتَیْنِ فِی غَزْوَۃِ بَنِی الْمُصْطَلِقِ۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ یُجْزِئْہُ أَنْ یَفْعَلَ ذَلِک۔",,,37265
37266,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : أَصَابَ عُمَرُ أَرْضًا بِخَیْبَرَ ، فَأَتَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَسَأَلَہُ عَنْہَا ، فَقَالَ : أَصَبْتُ أَرْضًا بِخَیْبَرَ لَمْ أُصِبْ مَالاً قَطُّ عِنْدِی أَنْفَسَ مِنْہُ ، فَمَا تَأْمُرُنَا ؟ قَالَ : إِنْ شِئْتَ حَبَّسْتَ أَصْلَہَا ، وَتَصَدَّقْت بِہَا ، قَالَ : فَتَصَدَّقَ بِہَا عُمَرُ ، غَیْرَ أَنَّہُ لاَ یُبَاعُ أَصْلُہَا ، وَلاَ یُوہَبُ، وَلاَ یُورَثُ، فَتَصَدَّقَ بِہَا فِی الْفُقَرَائِ ، وَالْقُرْبَی ، وَفِی الرِّقَابِ ، وَفِی سَبِیلِ اللہِ ، وَابْنِ السَّبِیلِ، وَالضَّیْفِ ، لاَ جُنَاحَ عَلَی مَنْ وَلِیَہَا أَنْ یَأْکُلَ مِنْہَا بِالْمَعْرُوفِ ، أَوْ یُطْعِمَ صَدِیقًا غَیْرَ مُتَمَوِّلٍ فِیہِ۔",,,37266
37267,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ ؛ أَلَمْ تَرَ أَنَّ حُجْرًا الْمَدَرِیَّ أَخْبَرَنِی ، أَنَّ فِی صَدَقَۃِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : یَأْکُلُ مِنْہَا أَہْلُہَا بِالْمَعْرُوفِ غَیْرِ الْمُنْکَرِ۔\n\n- وذُکِرَ أنَّ أَبَا حَنِیفَۃَ قَالَ : یَجُوزُ لِلوَرَثَۃِ أَنْ یَرُدُّوا ذلِک۔",,,37267
37268,"حَدَّثَنَا حَفْصٌ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، عَنْ عُمَرَ ، قَالَ : نَذَرْتُ نَذْرًا فِی الْجَاہِلِیَّۃِ ، فَسَأَلْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَعْدَ مَا أَسْلَمْتُ ، فَأَمَرَنِی أَنْ أَفِیَ بِنَذْرِی۔",,,37268
37269,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ؛ فِی رَجُلٍ نَذَرَ فِی الْجَاہِلِیَّۃِ ، ثُمَّ أَسْلَمَ ، قَالَ : یَفِی بِنَذْرِہِ۔\n\n- وذُکِرَ أنَّ أَبَا حَنِیفَۃَ قَالَ : یَسْقُطُ الْیَمِینُ إِذَا أَسْلَمَ۔",,,37269
37270,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، قَالَ : أَخْبَرَنَا ابْنُ جُرَیْجٍ ، عَنْ سُلَیْمَانَ بْنِ مُوسَی ، عَنِ الزُّہْرِیِّ ، عَنْ عُرْوَۃَ ، عَنْ عَائِشَۃَ ، قَالَتْ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَیُّمَا امْرَأَۃٍ لَمْ یُنْکِحْہَا الْوَلِیُّ ، أَوِ الْوُلاَۃُ فَنِکَاحُہَا بَاطِلٌ، قَالَہَا ثَلاَثًا، فَإِنْ أَصَابَہَا فَلَہَا مَہْرُہَا بِمَا أَصَابَ مِنْہَا، فَإِنْ تَشَاجَرُوا فَإِنَّ السُّلْطَانَ وَلِیُّ مَنْ لاَ وَلِیَّ لَہُ۔",,,37270
37271,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی بُرْدَۃَ ، قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ نِکَاحَ إِلاَّ بِوَلِیٍّ۔",,,37271
37272,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ إِسْرَائِیلَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی بُرْدَۃَ ، عَنْ أَبِیہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ نِکَاحَ إِلاَّ بِوَلِیٍّ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ کَانَ یَقُولُ : جَائِزٌ إِذًَا کَانَ الزَّوْجُ کُفْأً۔",,,37272
37273,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عُبَیْدِ اللہِ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ سَعْدَ بْنَ عُبَادَۃَ اسْتَفْتَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی نَذْرٍ کَانَ عَلَی أُمِّہِ ، وَتُوُفِّیَتْ قَبْلَ أَنْ تَقْضِیَہُ ، فَقَالَ : اقْضِہِ عَنْہَا۔",,,37273
37274,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ اللہِ بْنِ عَطَائٍ ، عَنِ ابْنِ بُرَیْدَۃَ ، عَنْ أَبِیہِ ، قَالَ : کُنْتُ جَالِسًا عِنْدَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إِذْ جَائَتْہُ امْرَأَۃٌ، فَقَالَتْ: إِنَّہُ کَانَ عَلَی أُمِّی صَوْمُ شَہْرَیْنِ، أَفَأَصُومُ عَنْہَا؟ قَالَ: صُومِی عَنْہَا ، أَرَأَیْتِ لَوْ کَانَ عَلَی أُمِّکَ دَیْنٌ قَضَیْتِیہِ ، أَکَانَ یُجْزِئُ عَنْہَا ؟ قَالَتْ : بَلَی ، قَالَ : فَصُومِی عَنْہَا۔",,,37274
37275,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ مُحَمَّدِ بْنِ کُرَیْبٍ ، عَنْ کُرَیْبٍ ، عَنِ ابْنِ عَبَّاسٍ ، عَنْ سِنَانِ بْنِ عَبْدِ اللہِ الْجُہَنِیِّ ، أَنَّہُ حَدَّثَتْہُ عَمَّتُہُ ؛ أَنَّہَا أَتَتِ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَتْ : یَا رَسُولَ اللہِ ، تُوُفِّیَتْ أُمِّی وَعَلَیْہَا مَشْیٌ إِلَی الْکَعْبَۃِ نَذْرًا ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَتَسْتَطِیعِینَ تَمْشِینَ عَنْہَا ؟ قَالَتْ : نَعَمْ ، قَالَ : فَامْشِی عَنْ أُمِّکِ ، قَالَتْ : أَوَ یُجْزِئُ ذَلِکَ عَنْہَا ؟ قَالَ : نَعَمْ ، قَالَ : أَرَأَیْتِ لَوْ کَانَ عَلَیْہَا دَیْنٌ قَضَیْتِیہِ ، ہَلْ کَانَ یُقْبَلُ مِنْہا ؟ قَالَتْ : نَعَمْ ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : اللہ أَحَقَّ۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ یُجْزِئُ ذَلِک۔",,,37275
37276,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عُبَیْدِ اللہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، وَزَیْدِ بْنِ خَالِدٍ ، وَشِبْلٍ ؛ أَنَّہُمْ کَانُوا عِنْدَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَامَ رَجُلٌ ، فَقَالَ : أَنْشُدُک اللَّہَ إِلاَ قَضَیْتَ بَیْنَنَا بِکِتَابِ اللہِ ، فَقَالَ خَصْمُہُ ، وَکَانَ أَفْقَہَ مِنْہُ : اقْضِ بَیْنَنَا بِکِتَابِ اللہِ ، وَأْذَنْ لِی حَتَّی أَقُولَ ، قَالَ : قُلْ ، قَالَ : إِنَّ ابْنِی کَانَ عَسِیفًا عَلَی ہَذَا ، وَإِنَّہُ زَنَی بِامْرَأَتِہِ ، فَافْتَدَیْتُ مِنْہُ بِمِئَۃِ شَاۃٍ وَخَادِمٍ ، فَسَأَلْتُ رِجَالاً مِنْ أَہْلِ الْعِلْمِ ، فَأُخْبِرْتُ أَنَّ عَلَی ابْنِی جَلْدَ مِئَۃٍ وَتَغْرِیبَ عَامٍ ، وَأَنَّ عَلَی امْرَأَۃِ ہَذَا الرَّجْمَ ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : وَالَّذِی نَفْسِی بِیَدِہِ ، لأَقْضِیَنَّ بَیْنَکُمَا بِکِتَابِ اللہِ : الْمِئَۃُ شَاۃٍ وَالْخَادِمُ رَدٌّ عَلَیْک ، وَعَلَی ابْنِکَ جَلْدُ مِئَۃٍ وَتَغْرِیبُ عَامٍ ، وَاغْدُ یَا أُنَیْسُ عَلَی امْرَأَۃِ ہَذَا ، فَإِنَ اعْتَرَفَتْ فَارْجُمْہَا۔",,,37276
37277,"حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ ، عَنْ شُعْبَۃَ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، عَنْ حِطَّانَ بْنِ عَبْدِ اللہِ ، عَنْ عُبَادَۃَ بْنِ الصَّامِتِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : خُذُوا عَنِّی ، قَدْ جَعَلَ اللَّہُ لَہُنَّ سَبِیلاً : الْبِکْرُ بِالْبِکْرِ ، وَالثَّیِّبُ بِالثَّیِّبِ ، الْبِکْرُ یُجْلَدُ وَیُنْفَی ، وَالثَّیِّبُ یُجْلَدُ وَیُرْجَمُ۔\n\n- وذُکِرَ أنَّ أبَا حَنِیفَۃَ قَالَ : لاَ یُنْفَی۔",,,37277
37278,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عُبَیْدِ اللہِ ، عَنْ أُمِّ قَیْسٍ ابْنَۃِ مِحْصَنٍ ، قَالَتْ : دَخَلْتُ بِابْنٍ لِی عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لَمْ یَأْکُلَ الطَّعَامَ ، فَبَالَ عَلَیْہِ ، فَدَعَا بِمَائٍ فَرَشَّہُ۔",,,37278
37279,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ سِمَاکٍ ، عَنْ قَابُوسَ بْنِ الْمُخَارِقِ ، عَنْ لُبَابَۃَ ابِنْۃِ الْحَارِثِ ، قَالَتْ : بَالَ الْحُسَیْنُ بْنُ عَلِیٍّ عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقُلْتُ : أَعْطِنِی ثَوْبَک وَالْبَسْ غَیْرَہُ ، فَقَالَ : إِنَّمَا یُنْضَحُ مِنْ بَوْلِ الذَّکَرِ ، وَیُغْسَلُ مِنْ بَوْلِ الأُنْثَی۔",,,37279
37280,حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أُتِیَ بِصَبِیٍّ فَبَالَ عَلَیْہِ، فَأَتْبَعَہُ الْمَائَ وَلَمْ یَغْسِلْہُ۔,,,37280
37281,"حَدَّثَنَا وَکِیعٌ، عَنِ ابْنِ أَبِی لَیْلَی، عَنْ عِیسَی، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، عَنْ جَدِّہِ أَبِی لَیْلَی، قَالَ: کُنَّا عِنْدَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ جُلُوسًا ، فَجَائَ الْحُسَیْنُ بْنُ عَلِیٍّ یَحْبُو حَتَّی جَلَسَ عَلَی صَدْرِہِ، فَبَالَ عَلَیْہِ ، قَالَ : فَابْتَدَرْنَاہُ لِنَأْخُذَہُ ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : ابْنِی ابْنِی ، ثُمَّ دَعَا بِمَائٍ ، فَصَبَّہُ عَلَیْہِ۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : یُغْسَلُ۔",,,37281
37282,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، سَمِعَ سَہْلُ بْنُ سَعْدٍ ؛ شَہِدَ الْمُتَلاعَنْیْن عَلَی عَہْدِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَرَّقَ بَیْنَہُمَا ، قَالَ : یَا رَسُولَ اللہِ ، کَذَبْتُ عَلَیْہَا إِنْ أَنَا أَمْسَکْتُہَا۔",,,37282
37283,"حَدَّثَنَا یَزِیدُ ، عَنْ عَبَّادِ بْنِ مَنْصُورٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : فَرَّقَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَیْنَہُمَا۔",,,37283
37284,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، وَأَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : لاَعَنَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَیْنَ رَجُلٍ مِنَ الأَنْصَارِ وَامْرَأَتِہِ ، فَفَرَّقَ بَیْنَہُمَا۔ (بخاری 5314۔ مسلم 1133)",,,37284
37285,حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَرَّقَ بَیْنَہُمَا۔ (مسلم 1130۔ دارمی 2231),,,37285
37286,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَرَّقَ بَیْنَ الْمُتَلاعَنْیْن ، فَقَالَ : یَا رَسُولَ اللہِ ، مَالِی ، فَقَالَ : لاَ مَالَ لَک ، إِنْ کُنْتَ صَادِقًا فَبِمَا اسْتَحْلَلْتَ مِنْ فَرْجِہَا ، وَإِنْ کُنْت کَاذِبًا فَذَاکَ أَبْعَدُ لَک مِنْہَا۔\n\n- وذُکِرَ أنَّ أبَا حَنِیفَۃَ قَالَ : یَتَزَوَّجَہَا إِذَا أَکْذَّبَ نَفْسَہُ۔",,,37286
37287,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، قَالَ : سَمِعْتُ أَنَسَ بْنَ مَالِکٍ ، یَقُولُ : سَقَطَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ فَرَسٍ فَجُحِشَ شِقُّہُ الأَیْمَنُ ، فَدَخَلْنَا عَلَیْہِ نَعُودُہُ ، فَحَضَرَتِ الصَّلاَۃُ ، فَصَلَّی بِنَا قَاعِدًا ، فَصَلَّیْنَا وَرَائَہُ قُعُودًا ، فَلَمَّا قَضَی الصَّلاَۃَ ، قَالَ : إِنَّمَا جُعِلَ الإِمَامُ لِیُؤْتَمَّ بِہِ ، فَإِذَا کَبَّرَ فَکَبِّرُوا ، وَإِذَا رَکَعَ فَارْکَعُوا ، وَإِذَا سَجَدَ فَاسْجُدُوا ، وَإِذَا رَفَعَ فَارْفَعُوا ، وَإِذَا قَالَ : سَمِعَ اللَّہُ لِمَنْ حَمِدَہُ ، فَقُولُوا : اللَّہُمَّ رَبَّنَا وَلَک الْحَمْدُ ، وَإِنْ صَلَّی قَاعِدًا فَصَلُّوا قُعُودًا أَجْمَعُونَ۔",,,37287
37288,"حَدَّثَنَا عَبْدَۃُ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، قَالَتْ : اشْتَکَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَدَخَلَ عَلَیْہِ نَاسٌ مِنْ أَصْحَابِہِ یَعُودُونَہُ ، فَصَلَّی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ جَالِسًا ، فَصَلُّوا بِصَلاَتِہِ قِیَامًا ، فَأَشَارَ إِلَیْہِمْ أَنَ اجْلِسُوا ، فَجَلَسُوا ، فَلَمَّا انْصَرَفَ ، قَالَ : إِنَّمَا جُعِلَ الإِمَامُ لِیُؤْتَمَّ بِہِ ، فَإِذَا رَکَعَ فَارْکَعُوا ، وَإِذَا رَفَعَ فَارْفَعُوا ، وَإِذَا صَلَّی جَالِسًا فَصَلُّوا جُلُوسًا۔",,,37288
37289,"حَدَّثَنَا وَکِیعٌ، عَنِ الأَعْمَشِ، عَنْ أَبِی سُفْیَانَ، عَنْ جَابِرٍ، قَالَ: صُرِعَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ فَرَسٍ لَہُ ، فَوَقَعَ عَلَی جِذْعٍ نَخْلَۃِ ، فَانْفَکَّتْ قَدَمُہُ ، قَالَ : فَدَخَلْنَا عَلَیْہِ نَعُودُہُ وَہُوَ یُصَلِّی فِی مَشْرُبَۃٍ لِعَائِشَۃَ جَالِسًا ، فَصَلَّیْنَا بِصَلاَتِہِ وَنَحْنُ قِیَامٌ ، ثُمَّ دَخَلْنَا عَلَیْہِ مَرَّۃً أُخْرَی وَہُوَ یُصَلِّی جَالِسًا ، فَصَلَّیْنَا بِصَلاَتِہِ وَنَحْنُ قِیَامٌ ، فَأَوْمَأَ إِلَیْنَا أَنَ اجْلِسُوا ، فَلَمَّا صَلَّی ، قَالَ : إِنَّمَا جُعِلَ الإِمَامُ لِیُؤْتَمَّ بِہِ ، فَإِذَا صَلَّی قَائِمًا فَصَلُّوا قِیَامًا ، وَإِذَا صَلَّی جَالِسًا فَصَلُّوا جُلُوسًا ، وَلاَ تَقُومُوا وَہُوَ جَالِسٌ کَمَا تَفْعَلُ أَہْلُ فَارِسَ بِعُظَمَائِہَا۔",,,37289
37290,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنَ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، عْن أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنَّمَا جُعِلَ الإِمَامُ لِیُؤْتَمَّ بِہِ ، فَإِذَا کَبَّرَ فَکَبِّرُوا ، وَإِذَا قَرَأَ فَأَنْصِتُوا ، وَإذَا قَالَ : {غَیْرِ الْمَغْضُوبِ عَلَیْہِمْ ، وَلاَ الضَّالِّینَ} فَقُولُوا : آمِینَ ، وَإِذَا رَکَعَ فَارْکَعُوا ، وَإِذَا قَالَ : سَمِعَ اللَّہُ لِمَنْ حَمِدَہُ ، فَقُولُوا : اللَّہُمَّ رَبَّنَا وَلَک الْحَمْدُ ، وَإِذَا سَجَدَ فَاسْجُدُوا ، وَإِذَا صَلَّی جَالِسًا فَصَلُّوا جُلُوسًا۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ یَؤُمُّ الإِمَامُ وَہُوَ جَالِسٌ۔",,,37290
37291,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ عُمَرَ بْنِ سَعِیدِ بْنِ أَبِی حُسَیْنٍ ، قَالَ : حدَّثَنَا ابْنُ أَبِی مُلَیْکَۃَ ، قَالَ : حَدَّثَنَا عُقْبَۃُ بْنُ الْحَارِثِ ، قَالَ : تَزَوَّجْتُ ابْنَۃَ أَبِی إِہَابٍ التَّمِیمِیِّ ، فَلَمَّا کَانَتْ صَبِیحَۃَ مِلْکِہَا ، جَائَتْ مَوْلاَۃٌ لأَہْلِ مَکَّۃَ ، فَقَالَتْ : إِنِّی قَدْ أَرْضَعْتُکُمَا ، فَرَکِبَ عُقْبَۃُ إِلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِالْمَدِینَۃِ ، فَذَکَرَ لَہُ ذَلِکَ ، وَقَالَ : سَأَلْتُ أَہْلَ الْجَارِیَۃِ فَأَنْکَرُوا ، فَقَالَ : وَکَیْفَ وَقَدْ قِیلَ ؟ فَفَارَقَہَا ، وَنَکَحَتْ غَیْرَہُ۔",,,37291
37292,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ مُحَمَّدِ بْنِ عُثَیْمٍ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ الْبَیْلَمَانِیِّ ، عَنْ أَبِیہِ ، عَنِ ابْنِ عُمَرَ ، قَالَ : سُئِلَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَا یَجُوزُ فِی الرَّضَاعَۃِ مِنَ الشُّہُودِ ؟ قَالَ : رَجُلٌ ، أَوِ امْرَأَۃٌ۔\n\n- وذُکِرَ أنَّ أبَا حَنِیفَۃَ قَالَ : لاَ یَجُوزُ إِلاَّ أَکْثَرُ۔",,,37292
37293,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ دَاوُدَ بْنِ حُصَیْنٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَدَّ ابْنَتَہُ زَیْنَبَ عَلَی أَبِی الْعَاصِ بَعْدَ سَنَتَیْنِ بِنِکَاحِہَا الأَوَّلِ۔\n\n(ابوداؤد 2233۔ حاکم 200)",,,37293
37294,"حَدَّثَنَا أَبُو أُسَامَۃَ، عَنْ إِسْمَاعِیلَ، عَنِ الشَّعْبِیِّ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَدَّہَا عَلَیْہِ بِنِکَاحِہَا الأَوَّلِ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : یَسْتَأْنِفُ النِّکَاحَ۔ (عبدالرزاق 12640۔ سعید بن منصور 2107)",,,37294
37295,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عِیسَی بْنِ طَلْحَۃَ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ، قَالَ : أَتَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجُلٌ ، فَقَالَ : حَلَقْتُ قَبْلَ أَنْ أَذْبَحَ ؟ قَالَ : فَاذْبَحْ ، وَلاَ حَرَجَ ، قَالَ : ذَبَحْتُ قَبْلَ أَنْ أَرْمِیَ؟ قَالَ : ارْمِ ، وَلاَ حَرَجَ۔",,,37295
37296,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ خَالِدٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ سَائِلاً سَأَلَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : رَمَیْتُ بَعْدَ مَا أَمْسَیْتُ ؟ قَالَ : لاَ حَرَجَ ، قَالَ : وَقَالَ : حَلَقْتُ قَبْلَ أَنْ أَنْحَرَ ؟ قَالَ : لاَ حَرَجَ۔",,,37296
37297,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، حَدَّثَنَا سُفْیَانُ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَیَّاشٍ ، عَنْ زَیْدِ بْنِ عَلِیٍّ ، عَنْ أَبِیہِ ، عَنْ عُبَیْدِ اللہِ بْنِ أَبِی رَافِعٍ ، عَنْ عَلِیٍّ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أَتَاہُ رَجُلٌ ، فَقَالَ : إِنِّی أَفَضْتُ قَبْلَ أَنْ أَحْلِقَ ؟ فَقَالَ : اِحْلِقْ ، أَوْ قَصِّرْ ، وَلاَ حَرَجَ۔",,,37297
37298,"حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ زِیَادِ بْنِ عِلاَقَۃَ ، عَنْ أُسَامَۃَ بْنِ شَرِیکٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سَأَلَہُ رَجُلٌ ، فَقَالَ : حلَقْتُ قَبْلَ أَنْ أَذْبَحَ ؟ قَالَ : لاَ حَرَجَ۔",,,37298
37299,"حَدَّثَنَا وَکِیعٌ ، عَنْ أُسَامَۃَ بْنِ زَیْدٍ ، عَنْ عَطَائٍ ، عَنْ جَابِرٍ ، قَالَ : قَالَ رَجُلٌ : یَا رَسُولَ اللہِ ، حَلَقْت قَبْلَ أَنْ أَنْحَرَ ؟ قَالَ : لاَ حَرَجَ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : عَلَیْہِ دَمٌ۔",,,37299
37300,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ السُّدِّیِّ ، عَنْ یَحْیَی بْنِ عَبَّادٍ ، عَنْ أَنَسِ بْنِ مَالِکٍ ؛ أَنَّ أَیْتَامًا وَرِثُوا خَمْرًا ، فَسَأَلَ أَبُو طَلْحَۃَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یَجْعَلَہُ خَلاًّ ، قَالَ : لاَ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ بَأْسَ بِہِ۔",,,37300
37301,حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنْ عَدِیِّ بْنِ ثَابِتٍ ، عَنِ الْبَرَائِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَرْسَلَہُ إِلَی رَجُلٍ تَزَوَّجَ امْرَأَۃَ أَبِیہِ ، فَأَمَرَہُ أَنْ یَأْتِیَہُ بِرَأْسِہِ۔,,,37301
37302,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، عَنِ السُّدِّیِّ ، عَنْ عَدِیِّ بْنِ ثَابِتٍ ، عَنِ الْبَرَائِ ، قَالَ : لَقِیتُ خَالِی وَمَعَہُ الرَّایَۃُ ، فَقُلْتُ : أَیْنَ تَذْہَبُ ؟ فَقَالَ : أَرْسَلَنِی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إِلَی رَجُلٍ تَزَوَّجَ امْرَأَۃَ أَبِیہِ أَنْ أَقْتُلَہُ ، أَوْ أَضْرِبَ عُنُقَہُ۔\n\nوذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لَیْسَ عَلَیْہِ إِلاَّ الْحَدُّ۔",,,37302
37303,"حَدَّثَنَا حَفْصٌ ، وَعَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنِ الْمُجَالِدِ ، عَنْ أَبِی الْوَدَّاکِ جَبْرِ بْنِ نُوفٍ ، عَنْ أَبِی سَعِیدٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : ذَکَاۃُ الْجَنِینِ ، ذَکَاۃُ أُمِّہِ إِذَا أَشْعَرَ۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ تَکُونُ ذَکَاتُہُ ذَکَاۃَ أُمِّہِ۔ (ترمذی 1476۔ ابوداؤد 2820)",,,37303
37304,"حَدَّثَنَا وَکِیعٌ، وَأَبُو خَالِدٍ الأَحْمَرُ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ، عَنْ فَاطِمَۃَ ابْنَۃِ الْمُنْذِرِ، عَنْ أَسْمَائَ ابْنَۃِ أَبِی بَکْرٍ، قَالَتْ: نَحَرْنَا فَرَسًا عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، فَأَکَلْنَا مِنْ لَحْمِہِ، أَوْ أَصَبْنَا مِنْ لَحْمِہِ۔",,,37304
37305,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرِو ، عَنْ جَابِرٍ ، قَالَ : أَطْعَمَنَا النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لُحُومَ الْخَیْلِ ، وَنَہَانَا عَنْ لُحُومِ الْحُمُرِ۔",,,37305
37306,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : أَکَلْنَا لُحُومَ الْخَیْلِ یَوْمَ خَیْبَرَ۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ تُؤْکَلُ۔",,,37306
37307,"حَدَّثَنَا وَکِیعٌ ، عَنْ زَکَرِیَّا ، عَنْ عَامِرٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الظَّہْرُ یُرْکَبُ إِذَا کَانَ مَرْہُونًا ، وَلَبَنُ الدَّرِّ یُشْرَبُ إِذَا کَانَ مَرْہُونًا ، وَعَلَی الَّذِی یَرْکَبُ وَیَشْرَبُ نَفَقَتُہُ۔",,,37307
37308,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا الأَعْمَشُ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : الرَّہْنُ مَحْلُوبٌ وَمَرْکُوبٌ۔",,,37308
37309,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ مَنْصُورٍ، عَنْ إِبْرَاہِیمَ، عَن أَبِی ہُرَیْرَۃَ، قَالَ: الرَّہْنُ مَحْلُوبٌ وَمَرْکُوبٌ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ یُنْتَفَعُ بِہِ وَلاَ یُرْکَبُ۔",,,37309
37310,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَبْدِ اللہِ بْنِ دِینَارٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْبَیِّعَانِ بِالْخِیَارِ فِی بَیْعِہِمَا مَا لَمْ یَتَفَرَّقَا ، إِلاَّ أَنْ یَکُونَ بَیْعُہُمَا عَنْ خِیَارٍ۔",,,37310
37311,"حَدَّثَنَا یَزِیدُ ، عَنْ شُعْبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ صَالِحٍ أَبِی الْخَلِیلِ ، عَنْ عَبْدِ اللہِ بْنِ الْحَارِثِ ، عَنْ حَکِیمِ بْنِ حِزَامٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : الْبَیِّعَانِ بِالْخِیَارِ مَا لَمْ یَتَفَرَّقَا۔",,,37311
37312,"حَدَّثَنَا ہَاشِمُ بْنُ الْقَاسِمِ ، حَدَّثَنَا أَیُّوبُ بْنُ عُتْبَۃَ ، حَدَّثَنَا أَبُو کَثِیرٍ السَّحَیْمِیِّ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْبَیِّعَانِ بِالْخِیَارِ فِی بَیْعِہِمَا مَا لَمْ یَتَفَرَّقَا ، أَوْ یَکُنْ بَیْعُہُمَا عَنْ خِیَارٍ۔",,,37312
37313,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ حَمَّادِ بْنِ زَیْدٍ ، عَنْ جَمِیلِ بْنِ مُرَّۃَ ، عَنْ أَبِی الْوَضِیئِ ، عَنْ أَبِی بَرْزَۃَ ، قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْبَیِّعَانِ بِالْخِیَارِ مَا لَمْ یَتَفَرَّقَا۔",,,37313
37314,"حَدَّثَنَا عَفَّانُ ، حَدَّثَنَا ہَمَّامٌ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، عَنْ سَمُرَۃََ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : الْبَیِّعَانِ بِالْخِیَارِ مَا لَمْ یَتَفَرَّقَا۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : یَجُوزُ الْبَیْعُ وَإِنْ لَمْ یَتَفَرَّقَا۔ (ابن ماجہ 2183۔ احمد 17)",,,37314
37315,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، عَنْ عَبْدِ اللہِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سَجَدَ سَجْدَتَیِ السَّہْوِ بَعْدَ الْکَلاَمِ۔,,,37315
37316,حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ ہِشَامٍ ، عَنْ مُحَمَّدٍ ، عَنْ أَبِی ہُرَیْرَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ تَکَلَّمَ ، ثُمَّ سَجَدَ سَجْدَتَیِ السَّہْوِ۔,,,37316
37317,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ ، عَنْ أَبِی قِلاَبَۃَ ، عَنْ أَبِی الْمُہَلَّبِ ، عَنْ عِمْرَانَ بْنِ حُصَیْنٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی ثَلاَثِ رَکَعَاتٍ ، ثُمَّ انْصَرَفَ ، فَقَامَ إِلَیْہِ رَجُلٌ یُقَالُ لَہُ : الْخِرْبَاقُ ، فَقَالَ : یَا رَسُولَ اللہِ ، أَنَقَصَتِ الصَّلاَۃُ ؟ قَالَ : وَمَا ذَاکَ ؟ قَالَ : صَلَّیْتَ ثَلاَثَ رَکَعَاتٍ ، فَصَلَّی رَکْعَۃً ، ثُمَّ سَلَّمَ ، ثُمَّ سَجَدَ سَجْدَتِی السَّہْوِ ، ثُمَّ سَلَّمَ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : إِذَا تَکَلَّمَ فَلاَ یَسْجُدُہُمَا۔",,,37317
37318,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَاصِمٍ ، عَنْ عَبْدِ اللہِ بْنِ عَامِرِ بْنِ رَبِیعَۃَ ، عَنْ أَبِیہِ ؛ أَنَّ رَجُلاً تَزَوَّجَ عَلَی عَہْدِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَلَی نَعْلَیْنِ ، فَأَجَازَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نِکَاحَہُ۔,,,37318
37319,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ أَبِی حَازِمٍ ، عَنْ سَہْلِ بْنِ سَعْدٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ لِرَجُلٍ : انْطَلِقْ فَقَدْ زَوَّجْتُکُہَا ، فَعَلِّمْہَا سُورَۃً مِنَ الْقُرْآنِ۔",,,37319
37320,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَبِیبَۃَ ، عَنْ جَدِّہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنِ اسْتَحَلَّ بِدِرْہَمٍ فَقَدِ اسْتَحَلَّ۔",,,37320
37321,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ الْمُغِیرَۃِ الطَّائِفِیِّ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْبَیْلَمَانِیِّ ، قَالَ : خَطَبَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : {أَنْکِحُوا الأَیَامَی مِنْکُمْ} ، فَقَامَ إِلَیْہِ رَجُلٌ ، فَقَالَ : یَا رَسُولَ اللہِ ، مَا الْعَلاَئِقُ بَیْنَہُمْ ؟ قَالَ : مَا تَرَاضَی عَلَیْہِ أَہْلُوہُمْ۔",,,37321
37322,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسٍ ، قَالَ : تَزَوَّجَ عَبْدُ الرَّحْمَنِ بْنُ عَوْفٍ عَلَی وَزْنِ نَوَاۃٍ مِنْ ذَہَبٍ ، قُوِّمَتْ ثَلاَثَۃَ دَرَاہِمَ وَثُلُثًا۔",,,37322
37323,"حَدَّثَنَا حَفْصٌ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ، قَالَ : مَا تَرَاضَی عَلَیْہِ الزَّوْجُ وَالْمَرْأَۃُ فَہُوَ مَہْرٌ۔",,,37323
37324,"حَدَّثَنَا مُعْتَمِرٌ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : سَأَلْتُ الْحَسَنَ : مَا أَدْنَی مَا یَتَزَوَّجُ عَلَیْہِ الرَّجُلُ ؟ قَالَ : وَزْنُ نَوَاۃٍ مِنْ ذَہَبٍ۔",,,37324
37325,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ إِسْمَاعِیلَ بْنِ أُمَیَّۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : لَوْ رَضِیَتْ بِسَوْطٍ کَانَ مَہْرًا۔",,,37325
37326,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عُمَیْرٍ الْخَثْعَمِیِّ ، عَنْ عَبْدِ الْمَلِکِ بْنِ الْمُغِیرَۃِ الطَّائِفِیِّ ، عَنِ ابْنِ الْبَیْلَمَانِیِّ ، قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : {وَآتُوا النِّسَائَ صَدُقَاتِہِنَّ نِحْلَۃً} ، قَالَ : قَالُوا : یَا رَسُولَ اللہِ ، فَمَا الْعَلاَئِقُ بَیْنَہُمْ ؟ قَالَ : مَا تَرَاضَی عَلَیْہِ أَہْلُوہُمْ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ یَتَزَوَّجُہَا عَلَی أَقَلَّ مِنْ عَشْرَۃِ دَرَاہِمَ۔",,,37326
37327,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ صُہَیْبٍ ، عَنْ أَنَسِ بْنِ مَالِکٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَعْتَقَ صَفِیَّۃَ وَتَزَوَّجَہَا ، قَالَ : فَقِیلَ لَہُ : مَا أَصْدَقَہَا ؟ قَالَ : أَصْدَقَہَا نَفْسَہَا ، جَعَلَ عِتْقَہَا صَدَاقَہَا۔",,,37327
37328,"حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِیلَ ، عَنْ جَعْفَرِ بْنِ مُحَمَّدٍ ، عَنْ أَبِیہِ ، قَالَ : قَالَ عَلِیٌّ : إِنْ شَائَ أَعْتَقَ الرَّجُل أُمَّ وَلَدِہِ ، وَجَعَلَ عِتْقَہَا مَہْرَہَا۔",,,37328
37329,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، قَالَ : قَالَ سَعِیدُ بْنُ الْمُسَیَّبِ : مَنْ أَعْتَقَ وَلِیدَتَہُ ، أَوْ أُمَّ وَلَدِہِ وَجَعَلَ ذَلِکَ لَہَا صَدَاقًا ، رَأَیْتُ ذَلِکَ جَائِزًا لَہُ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ یَجُوزُ إِلاَّ بِمَہْرٍ۔",,,37329
37330,"حَدَّثَنَا ہُشَیْمٌ ، أَخْبَرَنَا یَعْلَی بْنُ عَطَائٍ ، قَالَ : حدَّثَنِی جَابِرُ بْنُ الأَسْوَدِ ، عَنْ أَبِیہِ ، قَالَ : شَہِدْتُ مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَجَّتَہُ ، قَالَ : فَصَلَّیْتُ مَعَہُ صَلاَۃَ الصُّبْحِ فِی مَسْجِدِ الْخَیْفِ ، فَلَمَّا قَضَی صَلاَتَہُ وَانْحَرَفَ ، إِذَا ہُوَ بِرَجُلَیْنِ فِی آخِرِ الْقَوْمِ لَمْ یُصَلِّیَا مَعَہُ ، فَقَالَ : عَلَیَّ بِہِمَا ، فَأُتِیَ بِہِمَا تَرْعَدُ فَرَائِصُہُمَا ، فَقَالَ : مَا مَنَعَکُمَا أَنْ تُصَلِّیَا مَعَنا ؟ قَالاَ : یَا رَسُولَ اللہِ ، کُنَّا قَدْ صَلَّیْنَا فِی رِحَالِنَا ، قَالَ : فَلاَ تَفْعَلا ، إِذَا صَلَّیْتُمَا فِی رِحَالِکُمَا ، ثُمَّ أَتَیْتُمَا مَسْجِدَ جَمَاعَۃٍ ، فَصَلِّیَا مَعَہُمْ ، فَإِنَّہَا لَکُمَا نَافِلَۃٌ۔",,,37330
37331,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، عْن بِشْرِ ، أَوْ بُسْرِ بْنِ مِحْجَنٍ الدُّئَلِیِّ ، عَنْ أَبِیہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ بِنَحْوِہِ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ تُعَادُ الْفَجْرُ۔ (احمد 34۔ مالک 132)",,,37331
37332,"حَدَّثَنَا عَبْدَۃُ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ سُلَیْمَانَ النَّاجِی ، عَنْ أَبِی الْمُتَوَکِّلِ ، عَنْ أَبِی سَعِیدٍ ، قَالَ : جَائَ رَجُلٌ وَقَدْ صَلَّی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : فَقَالَ لَہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَیُّکُمْ یَتَّجِرُ عَلَی ہَذَا ؟ قَالَ : فَقَامَ رَجُلٌ مِنَ الْقَوْمِ فَصَلَّی مَعَہُ۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ ، قَالَ : لاَ تَجْمَعُوا فِیہِ۔",,,37332
37333,"حَدَّثَنَا عَبْدُ الرَّحِیمِ، حَدَّثَنَا ابْنُ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ، عَنِ الْحَسَنِ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، قَالَ : مَنْ قَتَلَ عَبْدَہُ قَتَلْنَاہُ ، وَمَنْ جَدَعَ عَبْدَہُ جَدَعْنَاہُ۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ یُقْتَلُ بِہِ۔",,,37333
37334,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : مَنْ أَدْرَکَ رَکْعَۃً مِنَ الْعَصْرِ قَبْلَ أَنْ تَغْرُبَ الشَّمْسُ فَقَدْ أَدْرَکَ الصَّلاَۃَ ، مَنْ أَدْرَکَ مِنْ صَلاَۃِ الْفَجْرِ رَکْعَۃً قَبْلَ أَنْ تَطْلُعَ الشَّمْسُ فَقَدْ أَدْرَکَ الصَّلاَۃَ۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : إِذَا صَلَّی رَکْعَۃً مِنْ الْفَجْرِِ ثُمَّ طَلَعَتِ الشَّمْسُ لَمْ تُجْزِِْئُہ۔ (مالک 5۔ احمد 462)",,,37334
37335,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ حُمَیْدٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : جَائَ رَجُلٌ إِلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : ہَلَکْتُ ، قَالَ : وَمَا أَہْلَکَک ؟ قَالَ : وَقَعْتُ عَلَی امْرَأَتِی فِی رَمَضَانَ ، قَالَ : أَعْتِقْ رَقَبَۃً ، قَالَ : لاَ أَجِدُ ، قَالَ : صُمْ شَہْرَیْنِ ، قَالَ : لاَ أَسْتَطِیعُ ، قَالَ ، أَطْعِمْ سِتِّینَ مِسْکِینًا ، قَالَ : لاَ أَجِدُ ، قَالَ : اجْلِسْ ، فَجَلَسَ ، فِینَمَا ہُوَ کَذَلِکَ إِذْ أُتِیَ بِعَرَقٍ فِیہِ تَمْرٌ ، قَالَ لَہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : اذْہَبْ فَتَصَدَّقْ بِہِ ، قَالَ : وَالَّذِی بَعَثَک بِالْحَقِ ، مَا بَیْنَ لاَبَتَیِ الْمَدِینَۃِ أَہْلُ بَیْتٍ أَفْقَرُ إِلَیْہِ مِنَّا ، فَضَحِکَ حَتَّی بَدَتْ أَنْیَابُہُ ، ثُمَّ قَالَ : انْطَلِقْ ، فَأَطْعِمْہُ عِیَالَک۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ یَجُوزُ أَنْ یُطْعِمْہُ عِیَالَہُ۔",,,37335
37336,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی بِشْرٍ ، عَنْ أَبِی عُمَیْرِ بْنِ أَنَسٍ ، قَالَ : حدَّثَنِی عُمُومَتِی مِنَ الأَنْصَارِ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : أُغْمِیَ عَلَیْنَا ہِلاَلُ شَوَّالٍ ، فَأَصْبَحْنَا صِیَامًا ، فَجَائَ رَکْبٌ مِنْ آخِرِ النَّہَارِ فَشَہِدُوا عِنْدَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنَّہُمْ رَأَوْا الْہِلاَلَ بِالأَمْسِ ، فَأَمَرَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یُفْطِرُوا ، وَأَنْ یَخْرُجُوا إِلَی عِیدِہِمْ مِنَ الْغَدِ۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ یَخْرُجُونَ مِنَ الْغَدِ۔",,,37336
37337,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ مُحَمَّدِ بْنِ زِیَادٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنِ اشْتَرَی مُصَرَّاۃً فَہُوَ فِیہَا بِالْخِیَارِ ، إِنْ شَائَ رَدَّہَا وَرَدَّ مَعَہَا صَاعًا مِنْ تَمْرٍ۔",,,37337
37338,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، عَنْ رَجُلٍ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنِ اشْتَرَی مُصَرَّاۃً فَہُوَ فِیہَا بِخَیْرِ النَّظَرَیْنِ ، إِنْ رَدَّہَا رَدَّ مَعَہَا صَاعًا مِنْ تَمْرٍ ، أَوْ صَاعًا مِنْ طَعَامٍ۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ بِخِلافِہِ۔",,,37338
37339,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، عَنْ جَابِرٍ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یُنْبَذَ التَّمْرُ وَالزَّبِیبُ جَمِیعًا ، وَالْبُسْرُ وَالتَّمْرُ جَمِیعًا۔",,,37339
37340,"حَدَّثَنَا ابْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ حَبِیبٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یُخْلَطَ التَّمْرُ وَالزَّبِیبُ جَمِیعًا ، وَأَنْ یُخْلَطَ الْبُسْرُ وَالزَّبِیبُ جَمِیعًا ، وَکَتَبَ بِذَلِکَ إِلَی أَہْلِ جُرَشَ۔",,,37340
37341,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، عَنْ حَجَّاجِ بْنِ أَبِی عُثْمَانَ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی قَتَادَۃَ ، عَنْ أَبِیہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لاَ تَنْبِذُوا التَّمْرَ وَالزَّبِیبَ جَمِیعًا ، وَلاَ تَنْبِذُوا الزَّہْوَ وَالرُّطَبَ ، وَانْبِذُوا کُلَّ وَاحِدٍ مِنْہُمَا عَلَی حِدَۃٍ۔",,,37341
37342,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنِ الأَعْمَشِ ، عَنْ حَبِیبٍ ، عَنْ أَبِی أَرْطَاۃَ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الزَّہْوِ وَالتَّمْرِ ، وَالزَّبِیبِ وَالتَّمْرِ۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ بَأْسَ بِہِ۔",,,37342
37343,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ سُفْیَانَ ، عَنْ أَبِی قَیْسٍ ، عَنْ ہُزَیْلٍ ، عَنْ عَبْدِ اللہِ ، قَالَ : لَعَنَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْمُحَلِّلَ وَالْمُحَلَّلَ لَہُ۔",,,37343
37344,"حَدَّثَنَا أَبٌو مُعَاوِیۃ ، عَنِ الأَعْمَش ، عَنِ الْمُسَیب بْنِ رَافِع ، عَنْ قَبِیصَۃَ بْنِ جَابِرٍ ، قَالَ ، قَالَ عُمَرُ : لاَ أُوتِیَ بِمُحَلِّلٍ ، وَلاَ مُحَلَّلٍ لَہُ ، إِلاَّ رَجَمْتہمَا۔",,,37344
37345,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ الْحَذَّائِ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ رَجُلٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : لَعَنَ اللَّہُ الْمُحَلِّلَ وَالْمُحَلَّلَ لَہُ۔",,,37345
37346,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ مُجَالِدٍ ، عَنْ عَامِرٍ ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ ، عَنْ عَلِیٍّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَعَنَ اللَّہُ الْمُحَلِّلَ وَالْمُحَلَّلَ لَہُ۔",,,37346
37347,"حَدَّثَنَا عَائِذُ بْنُ حَبِیبٍ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : لَعَنَ اللَّہُ الْمُحَلِّلَ وَالْمُحَلَّلَ لَہُ۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : إِذَا تَزَوَّجَہَا لِیُحِلَّہَا ، فَرَغِبَ فِیْہَا فَلاَ بَأْسَ أَنْ یُمْسِکْہُا۔",,,37347
37348,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ رَبِیعَۃَ بْنِ أَبِی عَبْدِ الرَّحْمَنِ الرَّأْیِ ، عَنْ یَزِیدَ مَوْلَی الْمُنْبَعِثِ ، عَنْ زَیْدِ بْنِ خَالِدٍ الْجُہَنِیِّ ، قَالَ : سُئِلَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ اللُّقَطَۃِ ، فَقَالَ : عَرِّفْہَا سَنَۃً ، فَإِنْ جَائَ صَاحِبُہَا وَإِلاَّ فَاسْتَنْفِقْہَا۔",,,37348
37349,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنْ سُوَیْد بْنِ غَفَلَۃَ ، قَالَ : خَرَجْتُ أَنَا ، وَزَیْدُ بْنُ صُوحَانَ ، وَسَلْمَانُ بْنُ رَبِیعَۃَ حَتَّی إِذَا کُنَّا بِالْعُذَیْبِ الْتَقَطْتُ سَوْطًا ، فَقَالاَ لِی : أَلْقِہِ ، فَأَبَیْتُ ، فَلَمَّا أَتَیْنَا الْمَدِینَۃَ أَتَیْتُ أُبَیَّ بْنَ کَعْبٍ ، فَسَأَلْتُہُ ، فَقَالَ : الْتَقَطْتُ مِئَۃَ دِینَارٍ عَلَی عَہْدِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَذَکَرْتُ ذَلِکَ لَہُ ، فَقَالَ : عَرِّفْہَا سَنَۃً ، فَعَرَّفْتُہَا سَنَۃً ، فَلَمْ أَجِدْ أَحَدًا یَعْرِفُہَا ، فَأَتَیْتُہُ ، فَقَالَ : عَرِّفْہَا سَنَۃً ، فَإِنْ وَجَدْتَ صَاحِبَہَا فَادْفَعْہَا إِلَیْہِ ، وَإِلاَّ فَاعْرِفْ عَدَدَہَا ، وَوِعَائَہَا ، وَوِکَائَہَا ، ثُمَّ تَکُونُ کَسَبِیلِ مَالِکَ۔ \n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : إِنْ جَائَ صَاحِبُہَا غَرِمَ لَہُ۔",,,37349
37350,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : نَہَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ بَیْعِ الثَمَرِ حَتَّی یَبْدُوَ صَلاَحُہُ۔",,,37350
37351,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، عَنْ جَابِرٍ ، قَالَ : نَہَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ بَیْعِ الثَمَرَۃِ حَتَّی یَبْدُوَ صَلاَحُہَا۔ (بخاری 2381۔ مسلم 81)",,,37351
37352,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ زَیْدِ بْنِ جُبَیْرٍ ، قَالَ : سَأَلَ رَجُلٌ ابْنَ عُمَرَ عَنْ شِرَائِ الثَمَرِ ؟ فَقَالَ : نَہَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ بَیْعِ الثَمَرَۃِ حَتَّی یَبْدُوَ صَلاَحُہَا۔",,,37352
37353,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ شُعْبَۃَ ، عَنْ یَزِیدَ بْنِ خُمَیْرٍ ، عَنْ مَوْلًی لِقُرَیْشٍ ، قَالَ : سَمِعْتُ أَبَا ہُرَیْرَۃَ یُحَدِّثُ مُعَاوِیَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی عَنْ بَیْعِ الثَمَرَۃِ حَتَّی تُحْرَزَ مِنْ کُلِّ عَارِضٍ۔",,,37353
37354,"حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطِیَّۃَ ، عَنْ أَبِی سَعِیدٍ ، قَالَ : نَہَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ بَیْعِ الثَمَرَۃِ حَتَّی یَبْدُوَ صَلاَحُہَا، قَالُوا: وَمَا بُدُوُّ صَلاَحِہَا؟ قَالَ: تَذْہَبُ عَاہَاتُہَا وَیَخْلُصُ طَیِّبُہَا۔",,,37354
37355,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ أَبِی الْبَخْتَرِیِّ ، قَالَ : سَأَلْتُ ابْنَ عَبَّاسٍ عَنْ بَیْعِ النَّخْلِ ؟ فَقَالَ : نَہَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ بَیْعِ النَّخْلِ حَتَّی یَأْکُلَ مِنْہُ ، أَوْ یُؤْکَلَ مِنْہُ ، وَحَتَّی یُوزَنَ ، قُلْتُ : وَمَا یُوزَنُ ؟ فَقَالَ رَجُلٌ عِنْدَہُ : حَتَّی یُحْرَزَ۔ (بخاری 2250۔ مسلم 1167)",,,37355
37356,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ حُمَیْدٍ ، عَنْ أَنَسٍ ، قَالَ : نَہَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ بَیْعِ ثَمَرِ النَّخْلِ حَتَّی یَزْہُوَ ، فَقِیلَ لأَنَسٍ : مَا زَہْوُہُ ؟ قَالَ : یَحْمَرُّ ، أَوْ یَصْفَرُّ۔",,,37356
37357,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ بْنِ جَابِرٍ ، قَالَ : حدَّثَنَا الْقَاسِمُ ، وَمَکْحُولٌ ، عَنْ أَبِی أُمَامَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی عَنْ بَیْعِ الثَمَرَۃِ حَتَّی یَبْدُوَ صَلاَحُہَا۔",,,37357
37358,"حَدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، حَدَّثَنَا فُضَیْلٍ بْنُ غَزْوَانٍ ، عَنِ ابْنِ أَبِی نُعْمٍ ، عَنْ أَبِی ہُرَیْرَۃَ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی عَنْ بَیْعِ الثَمَرَۃِ حَتَّی یَبْدُوَ صَلاَحُہَا۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ بَأْسَ بِبیعِہِ بَلَحًا ، وَہُوَ خِلاَفُ الأَثَرِِ۔",,,37358
37359,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : عُرِضْتُ عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَوْمَ أُحُدٍ ، وَأَنَا ابْنُ أَرْبَعَ عَشْرَۃَ فَاسْتَصْغَرَنِی ، وَعُرِضْتُ عَلَیْہِ یَوْمَ الْخَنْدَقِ وَأَنَا ابْنُ خَمْسَ عَشْرَۃَ فَأَجَازَنِی ، قَالَ نَافِعٌ : فَحَدَّثْتُ بِہِ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ ، قَالَ : فَقَالَ : ہَذَا حَدٌّ بَیْنَ الصَّغِیرِ وَالْکَبِیرِ ، قَالَ : فَکَتَبَ إِلَی عُمَّالِہِ أَنْ یَفْرِضُوا لاِبْنِ خَمْسَ عَشْرَۃَ فِی الْمُقَاتِلَۃِ ،وَلاِبْنِ أَرْبَعَ عَشْرَۃَ فِی الذُّرِّیَّۃِ۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لَیْسَ عَلَی الْجَارِیَۃِ شَیْئٌ حَتَّی تَبْلُغَ ثَمَانَ عَشْرَۃَ ، أَوْ سَبْعَ عَشْرَۃَ۔",,,37359
37360,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ إِسْحَاقَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَمَرَ عَتَّابَ بْنَ أُسَیْدٍ أَنْ یَخْرُصَ الْعَنْبِ کَمَا یُخْرَصُ النَّخْلُ ، فَتُؤَدَّی زَکَاتَہُ زَبِیبًا ، کَمَا تُؤَدَّی زَکَاۃُ النَّخْلِ تَمْرًا ، فَتِلْکَ سُنَّۃُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی النَّخْلِ وَالْعِنَبِ۔,,,37360
37361,حَدَّثَنَا حَفْصٌ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَعَثَ عَبْدَ اللہِ بْنَ رَوَاحَۃَ إِلَی أَہْلِ الْیَمَنِ ، فَخَرَصَ عَلَیْہِمَ النَّخْلَ۔,,,37361
37362,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ شُعْبَۃَ ، عَنْ خُبَیْبِ بْنِ عَبْدِ الرَّحْمَنِ ، قَالَ : سَمِعْتُ عَبْدَ الرَّحْمَنِ بْنَ مَسْعُودٍ ، یَقُولُ : جَائَ سَہْلُ بْنُ أَبِی حَثْمَۃَ إِلَی مَجْلِسَنا ، فَحَدَّثَ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إِذَا خَرَصْتُمْ ، فَخُذُوا وَدَعُوا۔",,,37362
37363,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، أَنَّہُ سَمِعَہُ ، یَقُولُ : خَرَصَہَا ابْنُ رَوَاحَۃَ ، یَعْنِی خَیْبَرَ ، أَرْبَعِینَ أَلْفَ وَسْقٍ ، وَزَعَمَ أَنَّ الْیَہُودَ لَمَّا خَیَّرَہُمُ ابْنُ رَوَاحَۃَ أَخَذُوا التَّمْرَ ، وَعَلَیْہِمْ عِشْرُونَ أَلْفَ وَسْقٍ۔",,,37363
37364,"حَدَّثَنَا أَبُوخَالِدٍ، عَنْ یَحْیَی بْنِ سَعِیدٍ، عَنْ بُشَیْرِ بْنِ یَسَارٍ؛ أَنَّ عُمَرَ کَانَ یَبْعَثُ أَبَا حَثْمَۃَ خَارِصًا لِلنَّخْلِ۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ کَانَ لاَ یَرَی الْخَرْصَ۔",,,37364
37365,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عَنْ عَائِشَۃَ ، قَالَتْ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَطْیَبُ مَا أَکَلَ الرَّجُلُ : مِنْ کَسْبِہِ ، وَوَلَدُہُ مِنْ کَسْبِہِ۔",,,37365
37366,"حَدَّثَنَا ابْنُ أَبِی زَائِدَۃَ ، عَنِ الأَعْمَشِ ، عَنْ عُمَارَۃَ بْنِ عُمَیْرٍ ، عَنْ عَمَّتِہِ ، عَنْ عَائِشَۃَ ، قَالَتْ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنَّ أَطْیَبَ مَا أَکَلْتُمْ مِنْ کَسْبِکُمْ ، وَإِنَّ أَوْلاَدَکُمْ مِنْ کَسْبِکُمْ۔",,,37366
37367,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الشَّعْبِیِّ ، قَالَ : جَائَ رَجُلٌ مِنَ الأَنْصَارِ إِلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : یَا رَسُولَ اللہِ ، إِنَّ أَبِی غَصَبَنِی مَالِی ، فَقَالَ : أَنْتَ وَمَالُک لأَبِیک۔",,,37367
37368,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُحَمَّدِ بْنِ الْمُنْکَدِرِ ، قَالَ : جَائَ رَجُلٌ إِلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، فَقَالَ : یَا رَسُولَ اللہِ ، إِنَّ لِی مَالاً ، وَلأَبِی مَالٌ ، قَالَ : أَنْتَ وَمَالُک لأَبِیک۔ (عبدالرزاق 16628)",,,37368
37369,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ إِبْرَاہِیمَ بْنِ عَبْدِ الأَعْلَی ، عَنْ سُوَیْد بْنِ غَفَلَۃَ ، عَنْ عَائِشَۃَ ، قَالَتْ : یَأْکُلُ الرَّجُلُ مِنْ مَالِ وَلَدِہِ مَا شَائَ ، وَلاَ یَأْکُلُ الْوَلَدُ مِنْ مَالِ وَالِدِہِ إِلاَّ بِإِذْنِہِ۔",,,37369
37370,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، قَالَ : جَائَ رَجُلٌ إِلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : إِنَّ أَبِی اجْتَاحَ مَالِی ، قَالَ : أَنْتَ وَمَالُک لأَبِیک۔\n\n- وذُکِرَ أَنَّ أََبَا حَنِیفَۃَ قَالَ : لاَ یَأْخُذُ مِنْ مالِہِ إِلاَّ أَنْ یَکُونَ مُحْتَاجًا فَیُنْفِقُ عَلَیْہِ۔",,,37370
37371,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ صُہَیْبٍ ، عَنْ أَنَسِ بْنِ مَالِکٍ ، قَالَ : قَدِمَ نَاسٌ مِنْ عُرَیْنَۃَ الْمَدِینَۃَ فَاجْتَوَوْہَا ، فَقَالَ لَہُمَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنْ شِئْتُمْ أَنْ تَخْرُجُوا إِلَی إبِلِ الصَّدَقَۃِ فَتَشْرَبُوا مِنْ أَبْوَالِہَا وَأَلْبَانِہَا ، فَافْعَلُوا۔",,,37371
37372,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ حَجَّاجِ بْنِ أَبِی عُثْمَانَ ، قَالَ : حدَّثَنَا أَبُو رَجَائٍ مَوْلَی أَبِی قِلاَبَۃَ ، عَنْ أَبِی قِلاَبَۃَ ، عَنْ أَنَسٍ ؛ أَنَّ نَفَرًا مِنْ عُکْلٍ ثَمَانِیَۃً ، قَدِمُوا عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَبَایَعُوہُ عَلَی الإِسْلاَمِ ، فَاسْتَوْخَمُوا الأَرْضَ ، وَسَقِمَتْ أَجْسَامُہُمْ ، فَشَکَوْا ذَلِکَ إِلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : أَلاَ تَخْرُجُونَ مَعَ رَاعِینَا فِی إبِلِہِ فَتُصِیبُوا مِنْ أَبْوَالِہَا وَأَلْبَانِہَا؟ قَالُوا: بَلَی، فَخَرَجُوا فَشَرِبُوا مِنْ أَبْوَالِہَا وَأَلْبَانِہَا۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ کَرِہَ شُرْبَ أَبْوالِ الإِبِلِ۔",,,37372
37373,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عُثْمَانَ بْنِ حَکِیمٍ ، عَنْ عَامِرِ بْنِ سَعْدٍ ، عَنْ أَبِیہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنِّی أُحَرِّمُ مَا بَیْنَ لاَبَتَیِ الْمَدِینَۃِ ؛ أَنْ تُقْطَعَ عِضَاہُہَا ، أَوْ یُقْتَلَ صَیْدُہَا ، وَقَالَ : الْمَدِینَۃُ خَیْرٌ لَہُمْ لَوْ کَانُوا یَعْلَمُونَ۔ (مسلم 992۔ احمد 181)",,,37373
37374,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ التَّیْمِیِّ ، عَنْ أَبِیہِ ، قَالَ : خَطَبَنَا عَلِیٌّ ، فَقَالَ : مَنْ زَعَمَ أَنَّ عِنْدَنَا شَیْئًا نَقْرَؤُہُ إِلاَّ کِتَابَ اللہِ ، وَہَذِہِ الصَّحِیفَۃَ ، صَحِیفَۃٌ فِیہَا أَسْنَانُ الإِبِلِ ، وَأَشْیَائُ مِنَ الْجِرَاحَاتِ ، قَالَ : وَفِیہَا ، قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْمَدِینَۃُ حَرَمٌ مَا بَیْنَ عَیْرٍ إِلَی ثَوْرٍ۔",,,37374
37375,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ یُسَیْرِ بْنِ عَمْرٍو ، عَنْ سَہْلِ بْنِ حُنَیْفٍ ، قَالَ : أَہْوَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إِلَی الْمَدِینَۃِ ، فَقَالَ : إِنَّہَا حَرَمٌ آمِنٌ۔",,,37375
37376,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ إِسْحَاقَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : قَالَ أَبُو ہُرَیْرَۃَ : حَرَّمَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَا بَیْنَ لاَبَتَیْہَا ، یُرِیدُ الْمَدِینَۃَ ، قَالَ أَبُو ہُرَیْرَۃَ : لَوْ وَجَدْتُ الظِّبَائَ سَاکِنَۃً لَمَا ذَعَرْتُہَا۔ (ترمذی 3921۔ احمد 487)",,,37376
37377,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ سَعِیدِ بْنِ أَبِی سَعِیدٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنَّ اللَّہَ حَرَّمَ عَلَی لِسَانِی مَا بَیْنَ لاَبَتَیِ الْمَدِینَۃِ۔ (بخاری 1869۔ احمد 286)",,,37377
37378,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ الْوَلِیدِ بْنِ کَثِیرٍ ، قَالَ : حدَّثَنِی شُرَحْبِیلُ أَبُو سَعْدٍ ؛ أَنَّہُ دَخَلَ الأَسْوَافَ ، فَصَادَ بِہَا نُہَسًا ، یَعْنِی طَائِرًا ، فَدَخَلَ عَلَیْہِ زَیْدُ بْنُ ثَابِتٍ ، وَہُوَ مَعَہُ ، فَعَرَکَ أُذُنَہُ ، وَقَالَ : خَلِّ سَبِیلَہُ ، لاَ أُمَّ لَک ، أَمَا عَلِمْتَ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَرَّمَ مَا بَیْنَ لاَبَتَیْہَا۔ (احمد 181۔ طبرانی 4911)",,,37378
37379,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ الْوَلِیدِ بْنِ کَثِیرٍ ، عَنْ سَعِیدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ أَبِی سَعِیدٍ الْخُدْرِیِّ ، أَنَّ عَبْدَ الرَّحْمَن حَدَّثَہُ ، عَنْ أَبِیہِ أَبِی سَعِیدٍ ؛ أَنَّہُ سَمِعَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، یَقُولُ : إِنِّی حَرَّمْت مَا بَیْنَ لاَبَتَیِ الْمَدِینَۃِ کَمَا حَرَّمَ إِبْرَاہِیمُ مَکَّۃَ ، قَالَ : ثُمَّ کَانَ أَبُو سَعِیدٍ یَجِدُ أَحَدَنَا فِی یَدِہِ الطَّیْرُ قَدْ أَخَذَہُ ، فَیَفُکُّہُ مِنْ یَدِہِ فَیُرْسِلُہُ۔ (مسلم 1003۔ ابویعلی 1006)",,,37379
37380,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ عَاصِمٍ الأَحْوَلِ ، قَالَ : سَأَلْتُ أَنَسَ بْنَ مَالِکٍ : أَحَرَّمَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْمَدِینَۃَ ؟ قَالَ : نَعَمْ ، ہِیَ حَرَامٌ ، حَرَّمَہَا اللَّہُ وَرَسُولُہُ ، لاَ یُخْتَلَی خَلاَہَا ، فَمَنْ فَعَلَ ذَلِکَ فَعَلَیْہِ لَعَنْۃُ اللہِ وَالْمَلاَئِکَۃِ وَالنَّاسِ أَجْمَعِینَ۔ (بخاری 1867۔ مسلم 994)",,,37380
37381,"حَدَّثَنَا ابْنُ أَبِی غَنِیَّۃَ ، عَنْ دَاوُدَ بْنِ عِیسَی ، عَنِ الْحَسَنِ ، قَالَ : أَخْبَرَنِی ابْنُ عَبَّاسٍ ؛ أَنَّہُ سَمِعَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، یَقُوْلَ : اللَّہُمَّ إِنِّی حَرَّمْتُ الْمَدِینَۃَ بِمَا حَرَّمْتَ بِہِ مَکَّۃَ۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لَیْسَ عَلَیْہِ شَیْئٌ۔ (احمد 318)",,,37381
37382,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ أَبِی بَکْرٍ ، عَنْ أَبِی مَسْعُودٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی عَنْ مَہْرِ الْبَغِیِّ ، وَثَمَنِ الْکَلْبِ۔,,,37382
37383,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطَائٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ مَہْرِ الْبَغِیِّ ، وَثَمَنِ الْکَلْبِ۔",,,37383
37384,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ أَشْعَثَ ، عَنْ مُحَمَّدِ بْنِ سِیرِینَ ، قَالَ : أَخْبَثُ الْکَسْبِ ثَمَنُ الْکَلْبِ ، وَکَسْبُ الزَّمَّارَۃِ۔",,,37384
37385,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، قَالَ : أَرَی أَبَا سُفْیَانَ ذَکَرَہُ ، عَنْ جَابِرٍ ، قَالَ : نَہَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ ثَمَنِ الْکَلْبِ وَالسِّنَّوْرِ۔",,,37385
37386,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ عَبْدِ الْجَبَّارِ بْنِ عَبَّاسٍ ، عَنْ عَوْنِ بْنِ أَبِی جُحَیْفَۃَ ، عَنْ أَبِیہِ ، قَالَ : نَہَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ ثَمَنِ الْکَلْبِ۔",,,37386
37387,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ قَیْسِ بْنِ حَبْتَرٍ ، عَنِ ابْنِ عَبَّاسٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : ثَمَنُ الْکَلْبِ ، وَمَہْرُ الْبَغِیِّ ، وَثَمَنُ الْخَمْرِ حَرَامٌ۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ رخّصَ فِی ثَمَنِ الْکَلْبِ۔",,,37387
37388,"حَدَّثَنَا ابْنُ مُسْہِرٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قطَعَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی مِجَنٍّ ، قُوِّمَ ثَلاَثَۃَ دَرَاہِمَ۔",,,37388
37389,"حَدَّثَنَا یَزِیدُ ، عَنْ سُلَیْمَانَ بْنِ کَثِیرٍ ، وَإِبْرَاہِیمَ بْنِ سَعْدٍ ، قَالاَ جَمِیعًا : أَخْبَرَنَا الزُّہْرِیُّ ، عنْ عَمْرَۃَ ، عَنْ عَائِشَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : یُقْطَعُ فِی رُبُعِ دِینَارٍ فَصَاعِدًا۔",,,37389
37390,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ عِیسَی بْنِ أَبِی عَزَّۃَ ، عَنِ الشَّعْبِیِّ ، عَنْ عَبْدِ اللہِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَطَعَ فِی خَمْسَۃِ دَرَاہِمَ۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ ، قَالَ : لاَ یُقْطَعُ فِی أَقَلِّ مِنْ عَشْرِۃِ دَرَاہِم۔",,,37390
37391,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی رَزِینٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِذَا قَامَ أَحَدُکُمْ مِنَ اللَّیْلِ ، فَلاَ یَغْمِسْ یَدَہُ فِی الإِنَائِ حَتَّی یَغْسِلَہَا ثَلاَثَ مَرَّاتٍ ، فَإِنَّہُ لاَ یَدْرِی أَیْنَ بَاتَتْ یَدُہُ۔",,,37391
37392,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِذَا قَامَ أَحَدُکُمْ مِنْ نَوْمِہِ فَلْیُفْرِغْ عَلَی یَدِہِ مِنْ إِنَائِہِ ثَلاَثَ مَرَّاتٍ ، فَإِنَّہُ لاَ یَدْرِی أَیْنَ بَاتَتْ یَدُہُ۔",,,37392
37393,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ ہِشَامٍ ، عَنْ مُحَمَّدِ بْنِ سِیرِینَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِذَا قَامَ أَحَدُکُمْ مِنَ اللَّیْلِ فَلاَ یَغْمِسْ یَدَہُ فِی الإِنَائِ حَتَّی یَغْسِلَہَا۔",,,37393
37394,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا اسْتَیْقَظَ الرَّجُلُ مِنْ نَوْمِہِ ، فَلاَ یُدْخِلْ یَدَہُ فِی الإِنَائِ حَتَّی یَغْسِلَہَا۔\n\n- وذُکِرَ أنَّ أبَا حَنِیفَۃَ قَالَ : لاَ بَأْسَ بِہِ۔",,,37394
37395,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ: طَہُورُ إِنَائِ أَحَدِکُمْ إِذَا وَلَغَ فِیہِ الْکَلْبُ أَنْ یَغْسِلَہُ سَبْعَ مَرَّاتٍ ، أُولاَہُنَّ بِالتُّرَابِ۔",,,37395
37396,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی رَزِینٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، یَقُولُ : إِذَا وَلَغَ الْکَلْبُ فِی إِنَائِ أَحَدِکُمْ فَلْیَغْسِلْہُ سَبْعَ مَرَّاتٍ۔",,,37396
37397,"حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی التَّیَّاحِ ، قَالَ : سَمِعْتُ مُطَرِّفًا ، یُحَدِّثُ عَنِ ابْنِ الْمُغَفَّلِ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَمَرَ بِقَتْلِ الْکِلاَبِ ، وَقَالَ : إِذَا وَلَغَ الْکَلْبُ فِی الإِنَائِ فَاغْسِلُوہُ سَبْعَ مَرَّاتٍ ، وَعَفِّرُوہُ الثَّامِنَۃَ بِالتُّرَابِ۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ ، قَالَ : یُجْزِئْہُ أَنْ یَغْسِل مَرَّۃً۔",,,37397
37398,"حَدَّثَنَا وَکِیعٌ ، عَنْ مَالِکِ بْنِ أَنَسٍ ، عَنْ عَبْدِ اللہِ بْنِ یَزِیدَ ، عَنْ زَیْدٍ أَبِی عَیَّاشٍ ، قَالَ : سَأَلْتُ سَعْدًا عَنِ السُّلْتِ بِالذُّرَۃِ ، فَکَرِہَہُ ، وَقَالَ سَعْدٌ : سُئِلَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الرُّطَبِ بِالتَّمْرِ ، فَقَالَ : أَیَنْقُصُ إِذَا جَفَّ ؟ قُلْنَا : نَعَمْ ، قَالَ : فَنَہَی عَنْہُ۔",,,37398
37399,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ زَائِدَۃَ ، عَنْ سِمَاکٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ کَرِہَ الرُّطَبَ بِالتَّمْرِ ، وَقَالَ : ہُوَ أَقَلُّہُمَا فِی الْمِکْیَالِ ، أَوْ فِی الْقَفِیزِ۔",,,37399
37400,حَدَّثَنَا ابْنُ أَبِی زَائِدَۃَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی عَنْ بَیْعِ الْعَنْب بِالزَّبِیبِ کَیْلاً۔,,,37400
37401,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ طَارِقٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أنَّہُ کَرِہَ الرُّطَبَ بِالتَّمْرِ مِثْلاً بِمِثْلٍ ، وَقَالَ : الرُّطَبُ مُنْتَفِخٌ ، وَالتَّمْرُ ضَامِرٌ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ ، قَالَ : لاَ بَأْسَ بِہِ۔",,,37401
37402,حَدَّثَنَا عَبْدُ اللہِ بْنُ مُبَارَکٍ ، عَنْ سُلَیْمَانَ التَّیْمِیِّ ، عَنْ أَبِی عُثْمَانَ النَّہْدِیِّ ، عَنْ عَبْدِ اللہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ أَنَّہُ نَہَی عَنْ تَلَقِّی الْبُیُوعِ۔,,,37402
37403,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ سِمَاکٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تَسْتَقْبِلُوا ، وَلاَ تُحَلِّفُوا۔",,,37403
37404,"حَدَّثَنَا ابْنُ أَبِی زَائِدَۃَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : نَہَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ التَّلَقِّی۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ بَأْسَ بِہِ۔ (مسلم 14۔ احمد 20)",,,37404
37405,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی بِشْرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ رَجُلاً کَانَ مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ مُحْرِمٌ ، فَوَقَصَتْہُ نَاقَتُہُ فَمَاتَ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : اغْسِلُوہُ بِمَائٍ وَسِدْرٍ ، وَکَفِّنُوہُ فِی ثَوْبَیْہِ ، وَلاَ تُخَمِّرُوا رَأْسَہُ ، فَإِنَّ اللَّہَ یَبْعَثُہُ یَوْمَ الْقِیَامَۃِ مُلَبِّیًا۔",,,37405
37406,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : خَرَّ رَجُلٌ عَنْ بَعِیرِہِ فَمَاتَ ، فَقَالَ : اغْسِلُوہُ بِمَائٍ وَسِدْرٍ ، وَکَفِّنُوہُ فِی ثَوْبَیْہِ ، وَلاَ تُخَمِّرُوا رَأْسَہُ ، فَإِنَّ اللَّہَ یَبْعَثُہُ یَوْمَ الْقِیَامَۃِ مُلَبِّیًا۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : یُغَطَّی رَأْسُہُ۔",,,37406
37407,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، سَمِعَ سَہْلَ بْنَ سَعْدٍ ، یَقُولُ : اطَّلَعَ رَجُلٌ مِنْ جُحْرٍ فِی حُجْرَۃِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَمَعَہُ مِدْرًی یَحُکُّ بِہِ رَأْسَہُ ، فَقَالَ : لَوْ أَعْلَمُ أَنَّک تَنْظُرُ لَطَعَنْتُ بِہِ فِی عَیْنَیْک ، إِنَّمَا الاِسْتِئْذَانُ مِنَ الْبَصَرِ۔ (طبرانی 5585)",,,37407
37408,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حُمَیْدٍ ، عَنْ أَنَسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ فِی بَیْتِہِ ، فَاطَّلَعَ رَجُلٌ مِنْ خَلَلِ الْبَابِ ، فَسَدَّدَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَحْوَہُ بِمِشْقَصٍ ، فَتَأَخَّرَ۔,,,37408
37409,"حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ ، عَنْ سُلَیْمَانَ بْنِ بِلاَلٍ ، عَنْ سُہَیْلٍ ، عَنْ أَبِیہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَوْ أَنَّ رَجُلاً اطَّلَعَ عَلَی قَوْمٍ بِغَیْرِ إِذْنِہِمْ ، حَلَّ لَہُمْ أَنْ یَفْقَؤُوا عَیْنَہُ۔",,,37409
37410,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی قَیْسٍ عَبْدِ الرَّحْمَنِ بْنِ ثَرَوَانَ ، عَنْ ہُزَیْلٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَوْ أَنَّ رَجُلاً اطَّلَعَ فِی دَارِ قَوْمٍ مِنْ کَوَّۃٍ ، فَرُمِیَ بِنَوَاۃٍ ،فَفُقِئَتْ عَیْنُہُ ، لَبَطُلَتْ۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : یَضْمَنُ۔",,,37410
37411,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ ، عَنْ أَبِیہِ ، قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنِ اقْتَنَی کَلْبًا إِلاَّ کَلْبَ صَیْدٍ ، أَوْ مَاشِیَۃٍ ، نَقَصَ مِنْ أَجْرِہِ کُلَّ یَوْمٍ قِیرَاطَانِ۔",,,37411
37412,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَبْدِ اللہِ بْنِ دِینَارٍ ، قَالَ : ذَہَبْتُ مَعَ ابْنِ عُمَرَ إِلَی بَنِی مُعَاوِیَۃَ ،فَنَبَحَتْ عَلَیْنَا کِلاَبٌ ، فَقَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنِ اقْتَنَی کَلْبًا إِلاَّ کَلْبَ ضَارِیَۃٍ ، أَوْ مَاشِیَۃٍ ، نَقَصَ مِنْ أَجْرِہِ کُلَّ یَوْمٍ قِیرَاطَانِ۔",,,37412
37413,"حَدَّثَنَا عَفَّانُ، عَنْ سُلَیْمِ بْنِ حَیَّانَ، قَالَ: سَمِعْتُ أَبِی یُحَدِّثُ، عَنْ أَبِی ہُرَیْرَۃَ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ: مَنِ اتَّخَذَ کَلْبًا لَیْسَ بِکَلْبِ زَرْعٍ، وَلاَ صَیْدٍ، وَلاَ مَاشِیَۃٍ، فَإِنَّہُ یَنْقُصُ مِنْ أَجْرِہِ کُلَّ یَوْمٍ قِیرَاطٌ۔",,,37413
37414,"حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ ، عَنْ مَالِکِ بْنِ أَنَسٍ ، عَنْ یَزِیدَ بْنِ خُصَیْفَۃَ ، عَنِ السَّائِبِ بْنِ یَزِیدَ ، عَنْ سُفْیَانَ بْنِ أَبِی زُہَیْرٍ ، قَالَ : سَمِعْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : مَنِ اقْتَنَی کَلْبًا لاَ یُغْنِی عَنْہُ زَرْعًا ، وَلاَ ضَرْعًا ، نَقَصَ مِنْ عَمَلِہِ کُلَّ یَوْمٍ قِیرَاطٌ ، فَقِیلَ لَہُ : أَنْتَ سَمِعْتَہُ مِنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ قَالَ: إِی وَرَبِّ ہَذَا الْمَسْجِدِ۔",,,37414
37415,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سُفْیَانَ ، عَنْ عَاصِمٍ ، عَنْ زِرٍّ ، عَنْ عَبْدِ اللہِ ، قَالَ : مَنِ اقْتَنَی کَلْبًا إِلاَّ کَلْبَ قَنْصٍ ، أَوْ کَلْبَ مَاشِیَۃٍ ، نَقَصَ مِنْ عَمَلِہِ کُلَّ یَوْمٍ قِیرَاطٌ۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ بَأْسَ بِاِتِّخاذِہِ۔",,,37415
37416,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْحَکَمِ ، قَالَ : بَعَثَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مُعَاذًا ، وَأَمَرَہُ أَنْ یَأْخُذَ مِنْ کُلِّ ثَلاَثِینَ تَبِیعًا ، أَوْ تَبِیعَۃً ، وَمِنْ کُلِّ أَرْبَعِینَ مُسِنَّۃً ، فَسَأَلُوہُ عَنْ فَضْلِ مَا بَیْنَہُمَا ، فَأَبَی أَنْ یَأْخُذَ حَتَّی سَأَلَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : لاَ تَأْخُذْ شَیْئًا۔",,,37416
37417,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ دَاوُدَ بْنِ أَبِی ہِنْدٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : لَیْسَ فِیہَا شَیْئٌ۔",,,37417
37418,"حَدَّثَنَا غُنْدَرٌ، عَنْ شُعْبَۃَ، قَالَ: سَأَلْتُ الْحَکَمَ، قُلْتُ: إِنْ کَانَتْ خَمْسِینَ بَقَرَۃً؟ قَالَ الْحَکَمُ: فِیہَا مُسِنَّۃٌ۔",,,37418
37419,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ مُحَمَّدِ بْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ، عَنْ عَلِیٍّ ، قَالَ : لَیْسَ فِی الشَّنَقِ شَیْئٌ۔",,,37419
37420,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ؛ أَنَّ مُعَاذًا قَالَ : لَیْسَ فِی الأَوْقَاصِ شَیْئٌ۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : فِیہَا بِحِسَابِ مَا زَادَ۔",,,37420
37421,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ عَاصِمِ بْنِ کُلَیْبٍ ، عَنْ أَبِیہِ ، قَالَ : کُنَّا فِی الْمَغَازِی لاَ یُؤَمَّرُ عَلَیْنَا إِلاَّ أَصْحَابُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَکُنَّا بِفَارِسَ عَلَیْنَا رَجُلٌ مِنْ مُزَیْنَۃَ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَغَلَتْ عَلَیْنَا الْمَسَانُّ ، حَتَّی کُنَّا نَشْتَرِی الْمُسِنَّ بِالْجَذَعَتَیْنِ وَالثَّلاَثِ ، فَقَامَ فِینَا ہَذَا الرَّجُلُ فَقَالَ : إِنَّ ہَذَا الْیَوْمَ أَدْرَکَنَا فَغَلَتْ عَلَیْنَا الْمَسَانُّ ، حَتَّی کُنَّا نَشْتَرِی الْمُسِنَّ بِالْجَذَعَتَیْنِ وَالثَّلاَثِ ، فَقَامَ فِینَا النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، فَقَالَ: إِنَّ الْمُسِنَّ یُوفِی مِمَّا یُوفِی مِنْہُ الثَّنِیُّ۔ (احمد 368۔ حاکم 226)",,,37421
37422,حَدَّثَنَا قَاسِمُ بْنُ مَالِکٍ ، عَنْ عَاصِمِ بْنِ کُلَیْبٍ ، عَنْ أَبِیہِ ، عَنْ رَجُلٍ مِنْ مُزَیْنَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ضَحَّی فِی السَّفَرِ۔,,,37422
37423,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا ، إِذَا سَافَرَ الرَّجُلُ أَنْ یُوصِیَ أَہْلَہُ أَنْ یُضَحُّوا عَنْہُ۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لَیْسَ عَلَی الْمُسَافِرِ أُضْحِیَّۃٌ۔",,,37423
37424,"حَدَّثَنَا عَبْدَۃُ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، قَالَتْ : خَرَجْنَا مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی حَجَّۃِ الْوَدَاعِ مُوَافِینَ لِہِلاَلِ ذِی الْحِجَّۃِ ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ أَرَاْدَ مِنْکُمْ أَنْ یُہِلَّ بِعُمْرَۃٍ فَلْیُہِلَ ، فَإِنِّی لَوْلاَ أَنِّی أَہْدَیْتُ لأَہْلَلْتُ بِعُمْرَۃٍ ، قَالَتْ : فَکَانَ مِنَ الْقَوْمِ مَنْ أَہَلَّ بِعُمْرَۃٍ ، وَمِنْہُمْ مَنْ أَہَلَّ بِحَجٍّ ، قَالَتْ : فَکُنْت أَنَا مِمَّنْ أَہَلَّ بِعُمْرَۃٍ ، قَالَتْ : فَخَرَجْنَا حَتَّی قَدِمْنَا مَکَّۃَ ، فَأَدْرَکَنِی یَوْمُ عَرَفَۃَ وَأَنَا حَائِضٌ ، لَمْ أَحِلَّ مِنْ عُمْرَتِی ، فَشَکَوْتُ ذَلِکَ إِلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : دَعِی عُمْرَتَکَ، وَانْقُضِی رَأْسَک ، وَامْتَشِطِی ، وَأَہِلِّی بِالْحَجِّ ، قَالَتْ : فَفَعَلْتُ ، فَلَمَّا کَانَتْ لَیْلَۃُ الْحَصْبَۃِ وَقَدْ قَضَی اللَّہُ حَجَّنَا ، أَرْسَلَ مَعِی عَبْدَ الرَّحْمَن بْنَ أَبِی بَکْرٍ ، فَأَرْدَفَنِی وَخَرَجَ بِی إِلَی التَّنْعِیمِ ، فَأَہْلَلْتُ بِعُمْرَۃٍ ، فَقَضَی اللَّہُ حَجَّنَا وَعُمْرَتَنَا ، لَمْ یَکُنْ فِی ذَلِکَ ہَدْیٌ ، وَلاَ صَدَقَۃٌ ، وَلاَ صَوْمٌ۔ (بخاری 317۔ مسلم 872)",,,37424
37425,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، وَعَطَائٍ ، قَالَ : سَأَلْتُہمَا عَنِ امْرَأَۃٍ قَدِمَتْ مَکَّۃَ بِعُمْرَۃٍ فَحَاضَتْ ، فَخَشِیَتْ أَنْ یَفُوتَہَا الْحَجُّ ؟ فَقَالاَ : تُہِلُّ بِالْحَجِّ وَتَمْضِی۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : تَکُونُ رَافِضَۃً لِلْحَجِّ ، وَعَلَیْہَا دَمٌ وَعُمْرَۃٌ مَکَانِہَا۔",,,37425
37426,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : التَّسْبِیحُ لِلرِّجَالِ ، وَالتَّصْفِیقُ لِلنِّسَائِ۔",,,37426
37427,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ الْجُرَیْرِیِّ ، عَنْ أَبِی نَضْرَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : صَلَّی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِالنَّاسِ ذَاتَ یَوْمٍ ، فَلَمَّا قَامَ لِیُکَبِّرَ ، قَالَ : إِنْ أَنْسَانِی الشَّیْطَانُ شَیْئًا مِنْ صَلاَتِی ، فَالتَّسْبِیحُ لِلرِّجَالِ ، وَالتَّصْفِیقُ لِلنِّسَائِ۔",,,37427
37428,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ عَبْدِ الْحَمِیدِ بْنِ جَعْفَرٍ ، عَنْ أَبِی حَازِمٍ ، عَنْ سَہْلِ بْنِ سَعْدٍ ، عنِ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : التَّسْبِیحُ لِلرِّجَالِ ، وَالتَّصْفِیقُ لِلنِّسَائِ۔",,,37428
37429,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِیہِ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : التَّسْبِیحُ فِی الصَّلاَۃِ لِلرِّجَالِ ، وَالتَّصْفِیقُ لِلنِّسَائِ۔",,,37429
37430,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ ، قَالَ : اسْتَأْذَنْتُ عَلَی عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی وَہُوَ یُصَلِّی ، فَسَبَّحَ بِالْغُلاَمِ فَفَتَحَ لِی۔",,,37430
37431,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : اسْتَأْذَنَ رَجُلٌ عَلَی جَابِرِ بْنِ عَبْدِ اللہِ فَسَبَّحَ ، فَدَخَلَ فَجَلَسَ حَتَّی انْصَرَفَ۔\n\n- وُذُکِرَ أَنَّ أَبَا حَنِیفَۃَ کَانَ یَقُولُ : لاَ یَفْعَل ذَلِکَ ، وَکَرِہَہُ۔",,,37431
37432,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنِ الشَّعْبِیِّ ، قَالَ : کَانَ رَجُلٌ مِنَ الْمُسْلِمِینَ أَعْمَی ، فَکَانَ یَأْوِی إِلَی امْرَأَۃٍ یَہُودِیَّۃٍ ، فَکَانَتْ تُطْعِمُہُ ، وَتَسْقِیہِ ، وَتُحْسِنُ إِلَیْہِ ، وَکَانَتْ لاَ تَزَالُ تُؤْذِیہِ فِی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَلَمَّا سَمِعَ ذَلِکَ مِنْہَا لَیْلَۃً مِنَ اللَّیَالِیِ ، قَامَ فَخَنَقَہَا حَتَّی قَتَلَہَا ، فَرُفِعَ ذَلِکَ إِلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَنَشَدَ النَّاسَ فِی أَمْرِہَا ، فَقَامَ الرَّجُلُ ، فَأَخْبَرَ أَنَّہَا کَانَتْ تُؤْذِیہِ فِی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَتَسُبُّہُ وَتَقَعُ فِیہِ ، فَقَتَلَہَا لِذَلِکَ ، فَأَبْطَلَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ دَمَہَا۔ \n\n(ابوداؤد 4361۔ نسائی 3533)",,,37432
37433,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حُصَیْنٍ ، عَنْ شَیْخٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ تَغَلَّبَ عَلَی رَاہِبٍ سَبَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِالسَّیْفِ ، وَقَالَ : إِنَّا لَمْ نُصَالِحْکُمْ عَلَی شَتْمِ نَبِیِّنَا صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ یُقْتَل۔",,,37433
37434,"حَدَّثَنَا شَرِیکٌ ، عَنْ قَیْسِ بْنِ وَہْبٍ ، عَنْ رَجُلٍ مِنْ بَنِی سُوَائَۃَ ، قَالَ : قُلْتُ لِعَائِشَۃَ : أَخْبِرِینِی عَنْ خُلُقِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ فَقَالَتْ : أَوَ مَا تَقْرَأُ الْقُرْآنَ ؟ {وَإِنَّک لَعَلَی خُلُقٍ عَظِیمٍ} ، قَالَتْ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَعَ أَصْحَابِہِ ، فَصَنَعْتُ لَہُ طَعَامًا ، وَصَنَعَتْ لَہُ حَفْصَۃُ طَعَامًا ، فَسَبَقَتْنِی حَفْصَۃُ ، قَالَتْ : فَقُلْتُ لِلْجَارِیَۃِ : انْطَلِقِی فَأَکْفِئِی قَصْعَتَہَا ، قَالَتْ : فَأَہْوَتْ أَنْ تَضَعَہَا بَیْنَ یَدَیَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَکَفَأَتْہَا ، فَانْکَسَرَتِ الْقَصْعَۃُ ، وَانْتَثَرَ الطَّعَامُ ، قَالَتْ : فَجَمَعَہَا النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَمَا فِیہَا مِنَ الطَّعَامِ عَلَی الأَرْضِ فَأَکَلُوا ، ثُمَّ بَعَثَ بِقَصْعَتِی ، فَدَفَعَہَا النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إِلَی حَفْصَۃَ، فَقَالَ: خُذُوا ظَرْفًا مَکَانَ ظَرْفِکُمْ ، وَکُلُوا مَا فِیہَا ، قَالَتْ : فَمَا رَأَیْتُہُ فِی وَجْہِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔ (ابن ماجہ 2333۔ احمد 111)",,,37434
37435,"حَدَّثَنَا یَزِیدُ ، عَنْ حُمَیْدٍ ، عَنْ أَنَسٍ ، قَالَ : أَہْدَی بَعْضُ أَزْوَاجِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إِلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَصْعَۃً فِیہَا ثَرِیدٌ ، وَہُوَ فِی بَیْتِ بَعْضِ أَزْوَاجِہِ ، فَضَرَبَتِ الْقَصْعَۃَ فَوَقَعَتْ فَانْکَسَرَتْ ، فَجَعَلَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَأْخُذُ الثَّرِیدَ فَیَرُدُّہُ إِلَی الْقَصْعَۃِ بِیَدِہِ ، وَیَقُولُ : کُلُوا ، غَارَتْ أُمُّکُمْ ، ثُمَّ انْتَظَرَ حَتَّی جَائَتْ قَصْعَۃٌ صَحِیحَۃٌ ، فَأَخَذَہَا فَأَعْطَاہَا صَاحِبَۃَ الْقَصْعَۃِ الْمَکْسُورَۃِ۔\n\n(بخاری 2481۔ ابوداؤد 3562)",,,37435
37436,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ ، عَنْ شُرَیْحٍ ، قَالَ : مَنْ کَسَرَ عُودًا فَہُوَ لَہُ ، وَعَلَیْہِ مِثْلُہُ۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ بِخِلاَفِہِ ، وَقَالَ : عَلَیْہِ قِیَمتُہَا۔",,,37436
37437,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : أَخْبَرَنِی زَیْدُ بْنُ ثَابِتٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَخَّصَ فِی الْعَرَایَا۔ (مسند 120)",,,37437
37438,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ الْوَلِیدِ بْنِ کَثِیرٍ ، قَالَ : حدَّثَنِی بُشَیْرُ بْنُ یَسَارٍ ؛ أَنَّہُ سَمِعَ سَہْلَ بْنَ أَبِی حَثْمَۃَ ، وَرَافِعَ بْنَ أَبِی خَدِیجٍ ، یَقُولاَنِ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الْمُحَاقَلَۃِ ، وَالْمُزَابَنَۃِ ، إِلاَّ أَصْحَابَ الْعَرَایَا ، فَإِنَّہُ قَدْ أَذِنَ لَہُمْ۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ یَصْلُحُ ذَلِک۔",,,37438
37439,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، وَمَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ غَیْلاَنَ بْنَ سَلَمَۃَ أَسْلَمَ وَعِنْدَہُ ثَمَانِ نِسْوَۃٍ ، فَأَمَرَہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یَخْتَارَ مِنْہُنَّ أَرْبَعًا۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : الأَرْبَعُ الأُوَلُ۔",,,37439
37440,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عَنْ عَائِشَۃَ ، قَالَتْ : أَرَادَ أَہْلُ بَرِیرَۃَ أَنْ یَبِیعُوہَا وَیَشْتَرِطُوا الْوَلاَئَ ، فَذَکَرَتُ ذَلِکَ لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : اشْتَرِیہَا وَأَعْتِقِیہَا ، فَإِنَّمَا الْوَلاَئَ لِمَنْ أَعْتَقَ۔ (بخاری 1493۔ ترمذی 1256)",,,37440
37441,حَدَّثَنَا عَفَّانُ ، حَدَّثَنَا ہَمَّامُ ، عَنْ قَتَادَۃَ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ مَوَالِیَہَا اشْتَرَطُوا الْوَلاَئَ ، فَقَضَی أَنَّ الْوَلاَئَ لِمَنْ أَعْتَقَ۔,,,37441
37442,"حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ ، عَنْ مَالِکِ بْنِ أَنَسٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : أَرَادَتْ عَائِشَۃُ أَنْ تَشْتَرِیَ بَرِیرَۃَ ، فَقَالُوا : أَتَبْتَاعِینِہَا عَلَی أَنَّ وَلاَئَہَا لَنَا ؟ فَذَکَرَتْ ذَلِکَ لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَمْنَعَنَّکِ ذَلِکَ مِنْہَا ، فَإِنَّمَا الْوَلاَئُ لِمَنْ أَعْتَقَ۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : ہَذَا الشِّرَائُ فَاسِدٌ لاَ یَجُوز۔ (بخاری 2562۔ ابوداؤد 2907)",,,37442
37443,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ عَزْرَۃَ ، عَنْ سَعِیدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ أَبْزَی ، عَنْ أَبِیہِ ، عَنْ عَمَّارٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أَنَّہُ قَالَ : التَّیَمُّمُ ضَرْبَۃٌ لِلْوَجْہِ وَالْکَفَّیْنِ۔",,,37443
37444,حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ بُرْدٍ ، عَنْ سُلَیْمَانَ بْنِ مُوسَی ، عَنْ أَبِی ہُرَیْرَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَالَ ، ثُمَّ ضَرَبَ بِیَدِہِ إِلَی الأَرْضِ ، فَمَسَحَ بِہَا وَجْہَہُ وَکَفَّیْہِ۔,,,37444
37445,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا الأَعْمَشِ ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنِ ابْنِ أَبْزَی ، عَنْ أَبِیہِ ، قَالَ : قَالَ عُمَرُ لِعَمَّارٍ: أَمَا تَذْکُرُ یَوْمَ کُنَّا فِی کَذَا وَکَذَا ، فَأَجْنَبْنَا ، فَلَمْ نَجِدَ الْمَائَ ، فَتَمَعَّکْنَا فِی التُّرَابِ ، فَلَمَّا قدِمْنَا عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ذَکَرْنَا ذَلِکَ لَہُ ، فَقَالَ : إِنَّمَا کَانَ یَکْفِیکُمَا ہَکَذَا ، وَضَرَبَ الأَعْمَشُ بِیَدَیْہِ ضَرْبَۃً ، ثُمَّ نَفَخَہُمَا ، ثُمَّ مَسَحَ بِہِمَا وَجْہَہُ وَکَفَّیْہِ۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : ضَرْبَتَینِ ، لاَ تُجْزِئُہُ ضَرْبَۃٌ۔",,,37445
37446,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ شُبَیْبِ بْنِ غَرْقَدَۃَ ، عَنْ عُرْوَۃَ الْبَارِقِیِّ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَعْطَاہُ دِینَارًا یَشْتَرِی لَہُ بِہِ شَاۃً ، فَاشْتَرَی بِہِ شَاتَیْنِ ، فَبَاعَ إِحْدَاہُمَا بِدِینَارٍ ، وَأَتَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِدِینَارٍ وَشَاۃٍ ، فَدَعَا لَہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِالْبَرَکَۃِ فِی بَیْعِہِ ، فَکَانَ لَوِ اشْتَرَی تُرَابًا لَرَبِحَ فِیہِ۔\n\n(بخاری 3642۔ ابوداؤد 377)",,,37446
37447,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی حَصِینٍ ، عَنْ رَجُلٍ ، عَنْ حَکِیمِ بْنِ حِزَامٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَعَثَہُ یَشْتَرِی لَہُ أُضْحِیَّۃً بِدِینَارٍ ، فَاشْتَرَاہَا ، ثُمَّ بَاعَہَا بِدِینَارَیْنِ ، فَاشْتَرَی شَاۃً بِدِینَارٍ ، وَجَائَہُ بِدِینَارٍ ، فَدَعَا لَہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِالْبَرَکَۃِ ، وَأَمَرَہُ أَنْ یَتَصَدَّقَ بِالدِّینَارِ۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : یَضْمَنُ إِذَا بَاعَ بِغَیْرِ أَمْرِہِ۔ (ابوداؤد 3379۔ ترمذی 1257)",,,37447
37448,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، وَوَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ عُمَارَۃَ بْنِ عُمَیْرٍ ، عَنْ أَبِی مَعْمَرٍ ، عَنْ أَبِی مَسْعُودٍ ، قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تُجْزِئُ صَلاَۃٌ ، لاَ یُقِیمُ الرَّجُلُ صُلْبَہُ فِیہَا فِی الرُّکُوعِ وَالسُّجُودِ۔",,,37448
37449,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ عَلِیِّ بْنِ یَحْیَی بْنِ خَلاَّدٍ ، عَنْ أَبِیہِ ، عَنْ عَمِّہِ ، وَکَانَ بَدْرِیًّا ، قَالَ : کُنَّا جُلُوسًا مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، إِذْ دَخَلَ رَجُلٌ یُصَلِّی ، فَصَلَّی صَلاَۃً خَفِیفَۃً ، لاَ یُتِمُّ رُکُوعًا ، وَلاَ سُجُودًا ، وَرَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَرْمُقُہُ وَلاَ یَشْعُرُ ، فَصَلَّی ، ثُمَّ جَائَ فَسَلَّمَ عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَرَدَّ عَلَیْہِ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : أَعِدْ ، فَإِنَّک لَمْ تُصَلِ ، فَفَعَلَ ذَلِکَ ثَلاَثًا ، کُلُّ ذَلِکَ یَقُولُ : أَعِدْ فَإِنَّک لَمْ تُصَلِّ۔",,,37449
37450,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عَلِیِّ بْنِ زَیْدٍ ، عَنِ الْمِسْوَرِ بْنِ مَخْرَمَۃَ ؛ أَنَّہُ رَأَی رَجُلاً لاَ یُتِمُّ رُکُوعَہُ وَلاَ سُجُودَہُ ، فَقَالَ لَہُ : أَعِد ، فَأَبَی ، فَلَمْ یَدَعْہُ حَتَّی أَعَادَ۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : تُجْزِئْہُ ، وَقَدْ أَسَائَ۔",,,37450
37451,"حَدَّثَنَا شَرِیکٌ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَطَائٍ ، عَنْ رَافِعِ بْنِ خَدِیجٍ ، رَفَعَہُ ، قَالَ : مَنْ زَرَعَ فِی أَرْضِ قَوْمٍ بِغَیْرِ إِذْنِہِمْ ، رُدَّتْ إِلَیْہِ نَفَقَتُہُ ، وَلَمْ یَکُنْ لَہُ مِنَ الزَّرْعِ شَیْئٌ۔",,,37451
37452,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ أَبِی جَعْفَرٍ الْخِطْمِیِّ ، قَالَ : بَعَثَنِی عَمِّی وَغُلاَمًا لَہُ إِلَی سَعِیدِ بْنِ الْمُسَیَّبِ، فَقَالَ : مَا تَقُولُ فِی الْمُزَارَعَۃِ ؟ فَقَالَ : کَانَ ابْنُ عُمَرَ لاَ یَرَی بِہَا بَأْسًا ، حَتَّی حُدِّثَ فِیہَا بِحَدِیثِ: أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَتَی بَنِی حَارِثَۃَ ، فَرَأَی زَرْعًا فِی أَرْضِ ظُہَیْرٍ ، فَقَالُوا : إِنَّہُ لَیْسَ لِظُہَیْرٍ ، قَالَ : أَلَیْسَتِ الأَرْضُ أَرْضَ ظُہَیْرٍ ؟ قالَوا : بَلَی ، وَلَکِنَّہُ زَارَعَ فُلاَنًا ، قَالَ : فَرُدُّوا عَلَیْہِ نَفَقَتَہُ ، وَخُذُوا زَرْعَکُمْ ، قَالَ رَافِعٌ : فَأَخَذْنَا زَرْعَنَا ، وَرَدَدْنَا عَلَیْہِ نَفَقَتَہُ۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : یُقْلَعُ زَرْعَہُ۔",,,37452
37453,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدٍ ، وَحَرَامِ بْنِ سَعْدٍ ؛ أَنَّ نَاقَۃً لِلْبَرَائِ بْنِ عَازِبٍ دَخَلَتْ حَائِطًا فَأَفْسَدَتْ عَلَیْہِمْ ، فَقَضَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَنَّ حِفْظَ الأَمْوَالِ عَلَی أَہْلِہَا بِالنَّہَارِ ، وَأَنَّ عَلَی أَہْلِ الْمَاشِیَۃِ مَا أَصَابَتِ الْمَاشِیَۃُ بِاللَّیْلِ۔",,,37453
37454,حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ عِیسَی ، عَنِ الزُّہْرِیِّ ، عَنْ حَرَامِ بْنِ مُحَیِّصَۃَ ، عَنِ الْبَرَائِ ؛ أَنَّ نَاقَۃً لآلِ الْبَرَائِ أَفْسَدَتْ شَیْئًا ، فَقَضَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أَنَّ حِفْظَ الأَمْوَالِ عَلَی أَہْلِہَا بِالنَّہَارِ ، وَضَمَّنَ أَہْلُ الْمَاشِیَۃِ مَا أَفْسَدَتْ مَاشِیَتُہُمْ بِاللَّیْلِ۔ (ابن ماجہ 2332۔ نسائی 5786),,,37454
37455,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ (ح) وَعَنِ ابْنِ أَبِی خَالِدٍ ، عَنِ الشَّعْبِیِّ ؛ أَنَّ شَاۃً أَکَلَتْ عَجِینًا ، وَقَالَ الآخَرُ : غَزْلاً نَہَارًا ، فَأَبْطَلَہُ وَقَرَأَ : {إِذْ نَفَشَتْ فِیہِ غَنَمُ الْقَوْمِ}۔ وَقَالَ فِی حَدِیثِ ابْنِ أَبِی خَالِدٍ : إِنَّمَا کَانَ النَّفْشُ بِاللَّیْلِ۔",,,37455
37456,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ طَارِقٍ ، عَنِ الشَّعْبِیِّ ؛ أَنَّ شَاۃً دَخَلَتْ عَلَی نَسَّاجٍ فَأَفْسَدَتْ غَزْلَہُ، فَلَمْ یُضَمِّنِ الشَّعْبِیُّ مَا أَفْسَدَتْ بِالنَّہَارِ۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : یضمَّن۔",,,37456
37457,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ أَبِی یَزِیدَ ، عَنْ أَبِیہِ ، عَنْ سِبَاعِ بْنِ ثَابِتٍ ، عَنْ أُمِّ کُرْزٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : عَنِ الْغُلاَمِ شَاتَانِ ، وَعَنِ الْجَارِیَۃِ شَاۃٌ ، لاَ یَضُرُّکُمْ ذُکْرَانًا کُنَّ ، أَمْ إِنَاثًا۔",,,37457
37458,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ عَطَائٍ ، عَنْ حَبِیبَۃَ ابْنَۃِ مَیْسَرَۃَ ، عَنْ أُمِّ کُرْزٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : عَنِ الْغُلاَمِ شَاتَانِ مُکَافِئَتَانِ ، وَعَنِ الْجَارِیَۃِ شَاۃٌ۔",,,37458
37459,حَدَّثَنَا شَبَابَۃُ ، عَنِ الْمُغِیرَۃِ بْنِ مُسْلِمٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَقَّ عَنِ الْحَسَنِ وَالْحُسَیْنِ۔,,,37459
37460,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ الْعَبْدِیُّ ، عَنْ سَعِیدِ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، عَنْ سَمُرَۃََ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : الْغُلاَمُ رَہِینَۃٌ بِعَقِیقَتِہِ ، تُذْبَحُ عَنْہُ یَوْمَ سَابِعِہِ ، وَیُحْلَقُ رَأْسُہُ ، وَیُسَمَّی۔\n\nوذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : إِنْ لَمْ یَعُقَّ عَنْہُ ، فَلَیْسَ عَلَیْہِ فِی ذَلِکَ شَیْئٌ۔",,,37460
37461,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ أَبِی ہُرَیْرَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لاَ یَمْنَعُ أَحَدُکُمْ أَخَاہُ أَنْ یَضَعَ خَشَبَۃً عَلَی جِدَارِہِ ، ثُمَّ قَالَ أَبُو ہُرَیْرَۃَ : مَالِی أَرَاکُمْ عَنْہَا مُعْرِضِینَ ؟ وَاللہِ لأَرْمِیَنَّ بِہَا بَیْنَ أَکْتَافِکُمْ۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لَیْسَ لَہُ ذَلِکَ۔",,,37461
37462,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ عَمْرو بِنْ خُزَیْمَۃَ ، عَنْ عُمَارَۃَ بْنِ خُزَیْمَۃَ ، عَنْ خُزَیْمَۃَ بْنِ ثَابِتٍ ، قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی الاِسْتِطَابَۃِ : ثَلاَثَۃُ أَحْجَارٍ لَیْسَ فِیہَا رَجِیعٌ۔",,,37462
37463,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَبْدِ الرَّحْمَنِ بْنِ یَزِیْدٍ ، عَنْ سَلْمَانَ ، قَالَ : قَالَ لَہُ بَعْضُ الْمُشْرِکِینَ وَہُمْ یَسْتَہْزِئُونَ : إِنَّ صَاحِبَکُمْ یُعَلِّمُکُمْ حَتَّی الْخِرَائَۃَ ، فَقَالَ سَلْمَانُ : أَجَلْ ، أَمَرَنَا أَنْ لاَ نَسْتَقْبِلَ الْقِبْلَۃَ ، وَلاَ نَسْتَنْجِیَ بِأَیْمَانِنَا ، وَلاَ نَکْتَفِیَ بِدُونِ ثَلاَثَۃِ أَحْجَارٍ لَیْسَ فِیہَا رَجِیعٌ ، وَلاَ عَظْمٌ۔",,,37463
37464,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی عُبَیْدَۃَ ، عَنْ عَبْدِ اللہِ ، قَالَ : خَرَجَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لِحَاجَتِہِ ، فَقَالَ : الْتَمِسْ لِی ثَلاَثَۃَ أَحْجَارٍ ، فَأَتَیْتُہُ بِحَجَرَیْنِ وَرَوْثَۃٍ ، فَأَخَذَ الْحَجَرَیْنِ وَأَلْقَی الرَّوْثَۃَ ، وَقَالَ : إِنَّہَا رِکْسٌ۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ: لاَ یُجْزِئُہُ ذَلِکَ حَتَّی یَتَوَضَّأْ إِذَا بَقِی بَعْد الثَّلاَثَۃِ الأَحْجَارِ أَکْثَر مِنْ مِقْدَارِ الدِّرہمِ۔",,,37464
37465,"حَدَّثَنَا عَبْدُ الْعَزِیزِ بْنُ عَبْدِ الصَّمَدِ الْعَمِّیِّ ، عَنْ مَطَرٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ طَلاَقَ إِلاَّ بَعْدَ نِکَاحٍ ، وَلاَ عِتْق إِلاَ بَعْدِ مِلْکٍ۔ (ابوداد 2184۔ احمد 189)",,,37465
37466,"حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنْ ہِشَامِ بْنِ سَعْدٍ ، عَنِ الزُّہْرِیِّ ، عَنْ عُرْوَۃَ ، عَنْ عَائِشَۃَ ، قَالَتْ : لاَ طَلاَقَ إِلاَّ بَعْدَ نِکَاحٍ۔",,,37466
37467,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُحَمَّدِ بْنِ الْمُنْکَدِرِ ، عَمَّنْ سَمِعَ طَاوُوسًا ، یَقُولُ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ طَلاَقَ إِلاَّ بَعْدَ نِکَاحٍ۔",,,37467
37468,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ مَیْسَرَۃَ ، عَنِ النِّزَالِ بْنِ سَبْرَۃَ ، عَنْ عَلِیٍّ ، قَالَ : لاَ طَلاَقَ إِلاَّ بَعْدَ نِکَاحٍ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : إِنْ حَلَفَ بِطَلاَقِہَا ، ثُمَّ تَزَوَّجَہَا ، طُلِّقَتْ۔",,,37468
37469,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَعْفَرِ بْنِ مُحَمَّدٍ ، عَنْ أَبِیہِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَضَی بِیَمِینٍ وَشَاہِدٍ ، قَالَ : قَضَی بِہَا عَلِیٌّ بَیْنَ أَظْہُرِکُمْ۔",,,37469
37470,حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ سَیْفِ بْنِ سُلَیْمَانَ ، عَنْ قَیْسِ بْنِ سَعْدٍ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَضَی بِیَمِینٍ وَشَاہِدٍ۔,,,37470
37471,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ سَوَّارٍ ، عَنْ رَبِیعَۃَ ، قَالَ : قُلْتُ لَہُ : فِی شَہَادَۃِ شَاہِدٍ وَیَمِینِ الطَّالِبِ ؟ قَالَ : وُجِدَ فِی کُتُبِ سَعْدٍ۔",,,37471
37472,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنَ ، عَنْ أَبِی الزِّنَادِ ؛ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ کَتَبَ إِلَی عَبْدِ الْحَمِیدِ : أَنْ یَقْضِیَ بِالْیَمِینِ مَعَ الشَّاہِدِ۔\n\nقَالَ أَبُو الزِّنَادِ : وَأَخْبَرَنِی شَیْخُ مِنْ مَشْیَخَتِہِمْ ، أَوْ مِنْ کُبَرَائِہِمْ ؛ أَنَّ شُرَیْحًا قَضَی بِذَلِکَ۔",,,37472
37473,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ شُعْبَۃَ ، عَنْ حُصَیْنٍ ، قَالَ : قضِیَ عَلَیَّ عَبْدُ اللہِ بْنُ عُتْبَۃَ بِشَہَادَۃِ شَاہِدٍ ، وَیَمِینِ الطَّالِبِ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ یَجُوزُ ذَلِکَ۔",,,37473
37474,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ ، عَنْ أَبِیہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : مَنْ بَاعَ عَبْدًا وَلَہُ مَالٌ ، فَمَالُہُ لِلْبَائِعِ ، إِلاَّ أَنْ یَشْتَرِطَ الْمُبْتَاعُ۔",,,37474
37475,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ ، عَمَّنْ سَمِعَ جَابِرَ بْنَ عَبْدِ اللہِ ، یَقُولُ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ بَاعَ عَبْدًا وَلَہُ مَالٌ ، فَمَالُہُ لِلْبَائِعِ ، إِلاَّ أَنْ یَشْتَرِطَ الْمُبْتَاعُ۔",,,37475
37476,"حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، قَالَ : قَالَ عَلِیٌّ: مَنْ بَاعَ عَبْدًا وَلَہُ مَالٌ، فَمَالُہُ لِلْبَائِعِ، إِلاَّ أَنْ یَشْتَرِطَ الْمُبْتَاعُ ، قَضَی بِہِ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ۔",,,37476
37477,"حَدَّثَنَا عَبْدَۃُ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ بَاعَ عَبْدًا وَلَہُ مَالٌ ، فَمَالُہُ لِسَیِّدِہِ ، إِلاَّ أَنْ یَشْتَرِطَ الَّذِی اشْتَرَاہُ۔",,,37477
37478,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ رُفَیْعٍ ، عَنْ عَطَائٍ ، وَابْنِ أَبِی مُلَیْکَۃَ ، قَالاَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ بَاعَ عَبْدًا فَمَالُہُ لِلْبَائِعِ ، إِلاَّ أَنْ یَشْتَرِطَ الْمُبْتَاعُ ، یَقُولُ : أَشْتَرِیہِ مِنْک وَمَالَہُ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : إِنْ کَانَ مَالُ الْعَبْدِ أَکْثَرَ مِنَ الثَمَّنِ ، لَمْ یَجِزِ ذَلِکَ۔",,,37478
37479,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ سَعِیدِ بْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، عَنْ عُقْبَۃَ بْنِ عَامِرٍ ، قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : عُہْدَۃُ الرَّقِیقِ ثَلاَثَۃُ أَیَّامٍ۔ (احمد 152۔ حاکم 21)",,,37479
37480,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ عُہْدَۃَ فَوْقَ أَرْبَعٍ۔ (ابن ماجہ 2245۔ احمد 143)",,,37480
37481,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ مُحَمَّدِ بْنِ یَحْیَی بْنِ حَبَّانَ ، قَالَ : إِنَّمَا جَعَلَ ابْنُ الزُّبَیْرِ عُہْدَۃَ الرَّقِیقِ ثَلاَثَۃً ، لِقَوْلِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لِمُنْقِذِ بْنِ عَمْرٍو : قُلْ : لاَ خِلاَبَۃَ ، إِذَا بِعْتَ بَیْعًا ، فَأَنْتَ بِالْخِیَارِ ثَلاَثًۃ۔ (بخاری 2117۔ ابوداؤد 3494)",,,37481
37482,"حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنْ مَالِکٍ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی بَکْرٍ ، قَالَ : سَمِعْتُ أَبَانَ بْنَ عُثْمَانَ ، وَہِشَامَ بْنَ إِسْمَاعِیلَ یُعَلِّمَانِ الْعُہْدَۃُ فِی الرَّقِیقِ : الْحُمَّی ، وَالْبَطْنِ ثَلاَثَۃَ أَیَّامٍ ، وَعُہْدَۃٌ سَنَۃٌ فِی الْجُنُونِ وَالْجُذَامِ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : إِذَا افْتَرَقَا فَلَیْسَ لَہُ أَنْ یَرُدَّ إِلاَّ بِعَیْبٍ کَانَ بِہَا۔",,,37482
37483,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : ارْکَبُوا الْہَدْیَ بِالْمَعْرُوفِ ، حَتَّی تَجِدُوا ظَہْرًا۔",,,37483
37484,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی الزِّنَادِ ، عَنِ الأَعْرَجِ ، عَنْ أَبِی ہُرَیْرَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَأَی رَجُلاً یَسُوقُ بَدَنَۃً ، فَقَالَ : ارْکَبْہَا ، قَالَ : إِنَّہَا بَدَنَۃٌ ، قَالَ : ارْکَبْہَا وَإِنْ کَانَتْ بَدَنَۃً۔",,,37484
37485,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ حُمَیْدٍ ، عَنْ أَنَسٍ ، قَالَ : رَأَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجُلاً یَسُوقُ بَدَنَۃً ، فَقَالَ : ارْکَبْہَا ، قَالَ : إِنَّہَا بَدَنَۃٌ ؟ قَالَ : ارْکَبْہَا۔",,,37485
37486,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنِ الْعَلاَئِ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ عِکْرِمَۃَ ، قَالَ : قَالَ رَجُلٌ لاِبْنِ عَبَّاسٍ : أَنَرْکَبُ الْبَدَنَۃَ ؟ قَالَ : غَیْرَ مُثْقِلٍ ، قَالَ : فَتَحْلُبُہَا ؟ قَالَ : غَیْرَ مُجْہِدٍ۔",,,37486
37487,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنِ ابْنِ جُرَیْجٍ ، عَمَّنْ حَدَّثَہُ ، عَنْ أَنَسٍ ، قَالَ : ارْکَبْہَا ، قَالَ : إِنَّہَا بَدَنَۃٌ ، قَالَ : ارْکَبْہَا۔",,,37487
37488,"حَدَّثَنَا أَبُو مَالِکٍ الْجَنْبِیُّ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَلِیٍّ ، قَالَ : یَرْکَبُ بَدَنَتَہُ بِالْمَعْرُوفِ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ تُرْکَبُ إِلاَ أَنْ یُصِیبَ صَاحِبہَا جہدٌ۔",,,37488
37489,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطَائٍ (ح) وَعَنْ عَبْدِ الْکَرِیمِ ، عَنْ مُعَاذِ بْنِ سَعْوَۃَ ، عَنْ سِنَانِ بْنِ سَلَمَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ لَہُ فِی الْہَدْیِ التَّطَوُّعِ : لاَ یَأْکُلْ ، فَإِنْ أَکَلَ غَرِمَ۔",,,37489
37490,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، عَنْ عُمَرَ ، قَالَ : مَنْ أَہْدَی ہَدْیًا تَطَوُّعًا فَعَطِبَ ، نَحَرَہُ دُونَ الْحَرَمِ وَلَمْ یَأْکُلْ مِنْہُ ، وَإِنْ أَکَلَ مِنْہُ فَعَلَیْہِ الْبَدَلُ۔",,,37490
37491,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَبِی التَّیَّاحِ ، عَنْ مُوسَی بْنِ سَلَمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَعَثَ بِثَمَانِ عَشْرَۃَ بَدَنَۃً مَعَ رَجُلٍ ، وَأَمَّرَہُ فِیہَا بِأَمْرِہِ ، فَانْطَلَقَ ، ثُمَّ رَجَعَ إِلَیْہِ ، فَقَالَ : أَرَأَیْتَ إِنْ أَزْحَفَ عَلَیْنَا مِنْہَا شَیْئٌ ؟ قَالَ : انْحَرْہَا ، ثُمَّ اغْمِسْ نَعْلَہَا فِی دَمِہَا ، ثُمَّ اجْعَلْہَا عَلَی صَفْحَتِہَا ، وَلاَ تَأْکُلْ مِنْہَا أَنْتَ ، وَلاَ أَحَدٌ مِنْ أَہْلِ رُفْقَتِک۔",,,37491
37492,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، عَنْ نَاجِیَۃَ الْخُزَاعِیِّ ، قَالَ : قُلْتُ : یَا رَسُولَ اللہِ ، کَیْفَ نَصْنَعُ بِمَا عَطِبَ مِنَ الْبُدْنِ ؟ قَالَ : انْحَرْہُ ، وَاغْمِسْ نَعْلَہُ فِی دَمِہِ ، وَخَلِّ بَیْنَ النَّاسِ وَبَیْنَہُ فَلْیَأْکُلُوہ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : یَأْکُلُ مِنْہَا أَہْلُ الرَّفِقَۃِ۔",,,37492
37493,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، قَالَ : کَانَ صَفْوَانُ بْنُ أُمَیَّۃَ مِنَ الطُّلَقَائِ ، فَأَتَی رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَأَنَاخَ رَاحِلَتَہُ ، وَوَضَعَ رِدَائَہُ عَلَیْہَا ، ثُمَّ تَنَحَّی لِیَقْضِیَ الْحَاجَۃَ ، فَجَائَ رَجُلٌ فَسَرَقَ رِدَائَہُ ، فَأَخَذَہُ فَأَتَی بِہِ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَأَمَرَ بِہِ أَنْ تُقْطَعَ یَدُہُ ، قَالَ : یَا رَسُولَ اللہِ ، تَقْطَعُہُ فِی رِدَائٍ ؟ أَنَا أَہَبُہُ لَہُ ، قَالَ : فَہَلاَّ قَبْلَ أَنْ تَأْتِیَنِی بِہِ۔",,,37493
37494,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ طَاوُوسٍ ، قَالَ : قِیلَ لِصَفْوَانَ بْنِ أُمَیَّۃَ ، وَہُوَ بِأَعْلَی مَکَّۃَ : لاَ دِینَ لِمَنْ لَمْ یُہَاجِرْ ، فَقَالَ : وَاللہِ ، لاَ أَصِلُ إِلَی أَہْلِی حَتَّی آتِیَ الْمَدِینَۃَ ، فَأَتَی الْمَدِینَۃَ ، فَنَزَلَ عَلَی الْعَبَّاسِ ، فَاضْطَجَعَ فِی الْمسْجِدِ ، وَخَمِیصَتُہُ تَحْتَ رَأْسِہِ ، فَجَائَ سَارِقٌ فَسَرَقَہَا مِنْ تَحْتِ رَأْسِہِ ، فَأَتَی بِہِ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : إِنَّ ہذَا سَارِقٌ ، فَأَمَرَ بِہِ فَقُطِعَ ، فَقَالَ : ہِیَ لَہُ ، فَقَالَ : فَہَلاَّ قَبْلَ أَنْ تَأْتِیَنِی بِہِ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : إِذَا وَہَبَہَا لَہُ دُرِِئَ عَنْہُ الْحَدّ۔",,,37494
37495,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ صَلَّی عَلَی رَاحِلَتِہِ وَأَوْتَرَ عَلَیْہَا ، قَالَ : وَکَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَفْعَلُہُ۔",,,37495
37496,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ عَبَّادِ بْنِ مَنْصُورٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ أَوْتَرَ ، وَقَالَ : الْوِتْرُ عَلَی الرَّاحِلَۃِ۔",,,37496
37497,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ ثُوَیْرٍ ، عَنْ أَبِیہِ ؛ أَنَّ عَلِیًّا کَانَ یُوتِرُ عَلَی رَاحِلَتِہِ۔,,,37497
37498,"حَدَّثَنَا ابْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، قَالَ : کَانَ الْحَسَنُ لاَ یَرَی بَأْسًا أَنْ یُوتِرَ الرَّجُلُ عَلَی رَاحِلَتِہِ۔",,,37498
37499,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عُمَرِ بْنِ نَافِعٍ ؛ أَنَّ أَبَاہُ کَانَ یُوتِرُ عَلَی الْبَعِیرِ۔,,,37499
37500,"حَدَّثَنَا عَمْرُو بْنُ مُحَمَّدٍ ، عَنِ ابْنِ أَبِی رَوَّادٍ ، عَنْ مُوسَی بْنِ عُقْبَۃَ ، قَالَ : صَحِبْتُ سَالِمًا فَتَخَلَّفْتُ عَنْہُ بِالطَّرِیقِ ، فَقَالَ : مَا خَلَّفَکَ ؟ فَقُلْتُ : أَوْتَرْتُ ، قَالَ : فَہَلاَّ عَلَی رَاحِلَتِکَ ؟۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ یُجْزِِئہ أَنْ یَوْتِر عَلَیْہَا۔",,,37500
37501,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ، عَنْ مَالِکِ بْنِ أَنَسٍ، عَنْ إِسْحَاقَ بْنِ عَبْدِاللہِ بْنِ أَبِی طَلْحَۃَ الأَنْصَارِیِّ، عَنْ حُمَیْدَۃَ ابْنَۃِ عُبَیْدِ بْنِ رَافِعٍ ، عَنْ کَبْشَۃَ ابْنَۃِ کَعْبٍ ، وَکَانَتْ تَحْتَ بَعْضِ وَلَدِ أَبِی قَتَادَۃَ ؛ أَنَّہَا صَبَّتْ لأَبِی قَتَادَۃَ مَائً یَتَوَضَّأُ بِہِ ، فَجَائَتْ ہِرَّۃٌ تَشْرَبُ ، فَأَصْغَی لَہَا الإِنَائَ ، فَجَعَلْتُ أَنْظُرُ ، فَقَالَ : یَا ابْنَۃِ أَخِی ، تَعْجَبِینَ؟ قَالَ صرَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنَّہَا لَیْسَتْ بِنَجَسٍ ، ہِیَ مِنَ الطَّوَّافِینَ عَلَیْکُمْ ، أَوْ مِنَ الطَّوَّافَاتِ۔",,,37501
37502,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ أَیُّوبَ ، عَنْ عِکْرِمَۃَ ، قَالَ : کَانَ أَبُو قَتَادَۃَ یُدْنِی الإِنَائَ مِنَ الْہِرِّ فَیَلِغُ فِیہِ ، ثُمَّ یَتَوَضَّأُ بِسُؤْرِہِ۔",,,37502
37503,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : الْہِرُّ مِنْ مَتَاعِ الْبَیْتِ۔",,,37503
37504,"حَدَّثَنَا شَرِیکٌ ، عَنِ الرُّکَیْنِ ، عَنْ صَفِیَّۃَ ابْنَۃِ دَابٍّ ، قَالَتْ : سَأَلْتُ حُسَیْنَ بْنَ عَلِیٍّ عَنِ الْہِرِّ ؟ فَقَالَ : ہُوَ مِنْ أَہْلِ الْبَیْتِ۔",,,37504
37505,"حَدَّثَنَا الْبَکْرَاوِیُّ ، عَنِ الْجُرَیْرِیِّ ، قَالَ : وَلَغَتْ ہِرَّۃٌ فِی طَہُورٍ لأَبِی الْعَلاَئِ ، فَتَوَضَّأَ بِفَضْلِہَا۔\n\n- وَذکِرَ أَنَّ أَبَا حَنِیفَۃَ ، أَنَّہُ کَرِہَ سُؤْرِ السِّنَّوْرِ۔",,,37505
37506,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی قَیْسٍ الأَوْدِیِّ ، عَنِ الْہُزَیْلِ بْنِ شُرَحْبِیلَ الأَوْدِیِّ ، عَنِ الْمُغِیرَۃِ بْنِ شُعْبَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَالَ ثُمَّ تَوَضَّأَ ، وَمَسَحَ عَلَی الْجَوْرَبَیْنِ وَالنَّعْلَیْنِ۔,,,37506
37507,"حَدَّثَنَا ابْنُ إِدْرِیسَ، عَنْ حُصَیْنٍ، عَنْ أَبِی ظَبْیَانَ، قَالَ: رَأَیْتُ عَلِیًّا بَالَ قَائِمًا، ثُمَّ تَوَضَّأَ، وَمَسَحَ عَلَی نَعْلَیْہِ۔",,,37507
37508,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَبِیبٍ ، عَنْ زَیْدٍ ؛ أَنَّ عَلِیًّا بَالَ ، وَمَسَحَ عَلَی النَّعْلَیْنِ۔,,,37508
37509,حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنِ الزُّبَیْرِ، عَنْ أُکَیْلٍ، عَنْ سُوَیْد بْنِ غَفَلَۃَ؛ أَنَّ عَلِیًّا بَالَ، وَمَسَحَ النَّعْلَیْنِ۔,,,37509
37510,"حَدَّثَنَا شَرِیکٌ ، عَنْ یَعْلَی بْنِ عَطَائٍ ، عَنْ أَوْسِ بْنِ أَبِی أَوْسٍ ، عَنْ أَبِیہِ ، قَالَ : کُنْتُ مَعَ أَبِی فَانْتَہَی إِلَی مَائٍ مِنْ مِیَاہِ الأَعْرَابِ ، فَتَوَضَّأَ وَمَسَحَ عَلَی نَعْلَیْہِ ، فَقُلْتُ لَہُ فِی ذَلِکَ ، فَقَالَ : لاَ أَزِیدُک عَلَی مَا رَأَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَنَعَ۔",,,37510
37511,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ وَاصِلٍ ، عَنْ سَعِیدِ بْنِ عَبْدِ اللہِ بْنِ ضِرَارٍ ؛ أَنَّ أَنَسَ بْنَ مَالِکٍ تَوَضَّأَ فَمَسَحَ عَلَی جَوْرَبَیْنِ مِنْ مِرْعِزَّی۔,,,37511
37512,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ عَبْدِ اللہِ بْنِ سَعِیدٍ ، عَنْ خِلاَسٍ ، قَالَ : رَأَیْتُ عَلِیًّا بَالَ بِالرَّحْبَۃِ ، ثُمَّ مَسَحَ عَلَی جَوْرَبَیْہِ وَنَعْلَیْہِ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ کَانَ یَکْرَہ الْمَسْحِ عَلَی الْجَوْرَبَیْنِ وَالنَّعْلَیْنِ ، إِلاَ أَنْ یَکُوَن أَسْفَلْہُمَا جُلُودٌ۔",,,37512
37513,"حَدَّثَنَا یَزِیدُ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ؛ أَنَّ مُحَمَّدَ بْنَ یَحْیَی بْنِ حِبَّانَ أَخْبَرَہُ ، عَنِ ابْنِ مُحَیْرِیزٍ الْقُرَشِیِّ ، أَنَّہُ أَخْبَرَہُ ، عَنِ الْمُخْدَجِیِّ ، رَجُلٌ مِنْ بَنِی کِنَانَۃَ ، أَنَّہُ أَخْبَرَہُ ، أَنَّ رَجُلاً مِنَ الأَنْصَارِ کَانَ بِالشَّامِ یُکَنَّی أَبَا مُحَمَّدٍ ، وَکَانَتْ لَہُ صُحْبَۃٌ ، فَأَخْبَرَہُ أَنَّ الْوِتْرَ وَاجِبٌ ، فَذَکَرَ الْمُخْدَجِیُّ ، أَنَّہُ رَاحَ إِلَی عُبَادَۃَ بْنِ الصَّامِتِ فَأَخْبَرَہُ ، فَقَالَ عُبَادَۃُ : کَذَبَ أَبُو مُحَمَّدٍ ، سَمِعْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : خَمْسُ صَلَوَاتٍ کَتَبَہُنَّ اللَّہُ عَلَی الْعِبَاد ، مَنْ جَائَ بِہِنَّ لَمْ یُضَیِّعْ مِنْ حَقِّہِنَّ شَیْئًا ، جَائَ وَلَہُ عِنْدَ اللہِ عَہْدٌ أَنْ یُدْخِلَہُ الْجَنَّۃَ ، وَمَنَ انْتَقَصَ مِنْ حَقِّہِنَّ ، جَائَ وَلَیْسَ لَہُ عِنْدَ اللہِ عَہْدٌ ، إِنْ شَائَ عَذَّبَہُ ، وَإِنْ شَائَ أَدْخَلَہُ الْجَنَّۃَ۔",,,37513
37514,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُسْلِمٍ مَوْلَی عَبْدِ الْقَیْسِ ، قَالَ : قَالَ رَجُلٌ لابْنِ عُمَرَ : أَرَأَیْتَ الْوِتْرَ ، سُنَّۃٌ ہُوَ ؟ قَالَ : مَا سُنَّۃٌ ؟ أَوْتَرَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَأَوْتَرَ الْمُسْلِمُونَ ، قَالَ : لاَ ، أَسُنَّۃٌ ہُوَ؟ قَالَ : مَہْ ، أَتَعْقِلُ ؟ أَوْتَرَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَأَوْتَرَ الْمُسْلِمُونَ۔",,,37514
37515,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ ، عَنْ عَلِیٍّ ، قَالَ : قِیْلَ لَہُ : الْوِتْرُ فَرِیضَۃٌ ہِیَ ؟ قَالَ : قَدْ أَوْتَرَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَثَبَتَ عَلَیْہِ الْمُسْلِمُونَ۔",,,37515
37516,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ ، قَالَ : قَالَ عَلِیٌّ : الْوِتْرُ لَیْسَ بِحَتْمٍ کَالصَّلاَۃِ الْمَکْتُوبَۃِ۔",,,37516
37517,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : سَنَّ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْوِتْرَ کَمَا سَنَّ الْفِطْرَ وَالأَضْحَی۔",,,37517
37518,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : الْوِتْرُ سُنَّۃٌ۔",,,37518
37519,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُطَرِّفٍ ، عَنِ الشَّعْبِیِّ ؛ أَنَّہُ سُئِلَ عَنْ رَجُلٍ نَسِیَ الْوِتْرَ ، قَالَ : لاَ یَضُرُّہُ ، کَأَنَّمَا ہِیَ فَرِیضَۃٌ۔",,,37519
37520,حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ لاَ یَرَی الْوِتْرَ فَرِیضَۃً۔,,,37520
37521,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَطَائٍ ، وَمُحَمَّدِ بْنِ عَلِیٍّ ، قَالاَ : الأَضْحَی وَالْوِتْرُ سُنَّۃٌ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : الوِتْرُ فَرِیِضَۃٌ۔",,,37521
37522,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ سِمَاکٍ ، عَنْ جَابِرِ بْنِ سَمُرَۃَ ، قَالَ : کَانَتْ لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ خُطْبَتَانِ یَجْلِسُ بَیْنَہُمَا ، یَقْرَأُ الْقُرْآنَ وَیُذَکِّرُ النَّاسَ۔",,,37522
37523,"حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ، قَالَ: کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَخْطُبُ قَائِمًا، ثُمَّ یَجْلِسُ ، ثُمَّ یَقُومُ فَیَخْطُبُ خُطْبَتَیْنِ۔",,,37523
37524,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنْ صَالِحٍ مَوْلَی التَّوْأَمَۃِ ، قَالَ : اسْتَخْلَفَ مَرْوَانُ أَبَا ہُرَیْرَۃَ عَلَی الْمَدِینَۃِ ، فَکَانَ یُصَلِّی بِنَا الْجُمُعَۃَ ، فَیَخْطُبُ خُطْبَتَیْنِ ، وَیَجْلِسُ جِلْسَتَیْنِ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ یَجْلِسُ إِلاَّ جِلْسَۃً وَاحِدَۃً۔",,,37524
37525,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ سَعْدِ بْنِ سَعِیدٍ ، عَنْ مُحَمَّدِ بْنِ إِبْرَاہِیمَ التَّیْمِیِّ ، عَنْ قَیْسِ بْنِ عَمْرٍوَ ، قَالَ : رَأَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجُلاً یُصَلِّی بَعْدَ صَلاَۃِ الصُّبْحِ رَکْعَتَیْنِ ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: أَصَلاَۃُ الصُّبْحِ مَرَّتَیْنِ؟ فَقَالَ الرَّجُلُ: إِنِّی لَمْ أَکُنْ صَلَّیْتُ الرَّکْعَتَیْنِ اللَّتَیْنِ قَبْلَہُمَا ، فَصَلَّیْتُہُمَا الآنَ، فَسَکَتَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,37525
37526,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ أَنَّ رَجُلاً صَلَّی مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلاَۃَ الصُّبْحِ ، فَلَمَّا قَضَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الصَّلاَۃَ ، قَامَ الرَّجُلُ فَصَلَّی رَکْعَتَیْنِ ، فَقَالَ لَہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَا ہَاتَانِ الرَّکْعَتَانِ ؟ فَقَالَ : یَا رَسُولَ اللہِ ، جِئْتُ وَأَنْتَ فِی الصَّلاَۃِ ، وَلَمْ أَکُنْ صَلَّیْتُ الرَّکْعَتَیْنِ قَبْلَ الْفَجْرِ ، فَکَرِہْتُ أَنْ أُصَلِّیَہُمَا وَأَنْتَ تُصَلِّی ، فَلَمَّا قَضَیْتَ الصَّلاَۃَ قُمْتُ فَصَلَّیْتُہُمَا ، قَالَ : فَلَمْ یَأْمُرْہُ ، وَلَمْ یَنْہَہُ۔",,,37526
37527,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُسَمِّعُ بْنُ ثَابِتٍ ، قَالَ : رَأَیْتُ عَطَائً فَعَلَ مِثْلَ ذَلِکَ۔",,,37527
37528,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : إِذَا فَاتَتْہُ رَکْعَتَا الْفَجْرِ ، صَلاَہُمَا بَعْدَ صَلاَۃِ الْفَجْرِ۔",,,37528
37529,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، قَالَ : سَمِعْتُ الْقَاسِمَ ، یَقُولُ : إِذَا لَمْ أُصَلِّہِمَا حَتَّی أُصَلِّیَ الْفَجْرَ ، صَلَّیْتہمَا بَعْدَ طُلُوعِ الشَّمْسِ۔",,,37529
37530,"حَدَّثَنَا وَکِیعٌ ، عَنْ فُضَیْلٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ صَلَّی رَکْعَتَیَ الْفَجْرِ بَعْدَ مَا أَضْحَی۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لَیْسَ عَلَیْہِ أَنْ یَقْضِیہمَا۔",,,37530
37531,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الصَّلاَۃِ بَیْنَ الْقُبُورِ۔",,,37531
37532,"حَدَّثَنَا حَفْصٌ ، عَنْ حُمَیْدٍ ، عَنْ أَنَسٍ ، قَالَ: أَبْصَرَنِی عُمَرُ وَأَنَا أُصَلِّی إِلَی قَبْرٍ ، فَجَعَلَ یَقُولُ: یَا أَنَسُ، الْقَبْرَ ، فَجَعَلْتُ أَرْفَعُ رَأْسِی أَنْظُرُ إِلَی الْقَمَرِ ، فَقَالُوا : إِنَّمَا ، یَعْنِی الْقَبْرَ۔",,,37532
37533,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ أَبِی ظَبْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ عَمْروَ ، قَالَ : لاَ یُصَلَّی إِلَی الْقَبْرِ۔",,,37533
37534,"حَدَّثَنَا ابْنُ فُضَیْلٍ، عَنِ الْعَلاَئِ، عَنْ أَبِیہِ ، وَخَیْثَمَۃ ، قَالاَ: لاَ یُصَلَّی إِلَی حَائِطِ حَمَّامٍ، وَلاَ وَسَطِ مَقْبَرَۃٍ۔",,,37534
37535,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَاجٍ ، عَنِ الْحَکَمِ ، عَنِ الْحَسَنِ الْعُرَنِیِّ ، قَالَ : الأَرْضُ کُلُّہَا مَسَاجِدُ إِلاَّ ثَلاَثَۃً : الْمَقْبَرَۃَ ، وَالْحَمَّامَ ، وَالْحُشَّ۔",,,37535
37536,حَدَّثَنَا حَفْصٌ، وَأَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنِ ابْنِ سِیرِینَ ، عَنْ أَنَسٍ؛ أَنَّہُ کَرِہَ أَنْ یُصَلَّی عَلَی الْجِنَازَۃِ فِی الْمَقْبَرَۃِ۔,,,37536
37537,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْمُغِیرَۃِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانُوا یَکْرَہُونَ أَنْ یُصَلُّوا بَیْنَ الْقُبُورِ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : إِنْ صَلَّی أَجْزَأَتْہُ صَلاَتُہُ۔",,,37537
37538,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، رِوَایَۃً ، قَالَ : قدْ تَجَاوَزْتُ لَکُمْ عَنْ صَدَقَۃِ الْخَیْلِ وَالرَّقِیقِ۔",,,37538
37539,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَبْدِ اللہِ بْنِ دِینَارٍ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ، عَنْ عِرَاکِ بْنِ مَالِکٍ، عَنْ أَبِی ہُرَیْرَۃَ، یَبْلُغُ بِہِ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لَیْسَ عَلَی الْمُسْلِمِ فِی عَبْدِہِ ، وَلاَ فَرَسِہِ صَدَقَۃٌ۔",,,37539
37540,"حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِیلَ ، عَنِ ابْنِ عِرَاکٍ ، قَالَ : سَمِعْتُ أَبِی یَقُولُ : سَمِعْتُ أَبَا ہُرَیْرَۃَ ، یَقُولُ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ صَدَقَۃَ عَلَی الْمُؤْمِنِ فِی عَبْدِہِ ، وَلاَ فَرَسِہِ۔",,,37540
37541,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنِ ابْنِ أَبِی خَالِدٍ ، عَنْ شُبَیْلِ بْنِ عَوْفٍ ، وَکَانَ قَدْ أَدْرَکَ الْجَاہِلِیَّۃَ ، قَالَ : أَمَرَ عُمَرُ بْنُ الْخَطَّابِ النَّاسَ بِالصَّدَقَۃِ ، فَقَالَ النَّاسُ : یَا أَمِیرَ الْمُؤْمِنِینَ ، خَیْلُنَا وَرَقِیقُنَا ، اِفْرِضْ عَلَیْنَا عَشَرَۃً عَشَرَۃً ، قَالَ : أَمَّا أَنَا ، فَلَسْتُ أَفْرِضُ ذَلِکَ عَلَیْکُمْ۔",,,37541
37542,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لَیْسَ عَلَی الْفَرَسِ الْغَازِی فِی سَبِیلِ اللہِ صَدَقَۃٌ۔",,,37542
37543,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَبْدِ اللہِ بْنِ دِینَارٍ ، قَالَ : سُئِلَ سَعِیدُ بْنُ الْمُسَیَّبِ : أَفِی الْبَرَاذِینِ صَدَقَۃٌ ؟ قَالَ : أَوَفِی الْخَیْلِ صَدَقَۃٌ ؟۔",,,37543
37544,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ أُسَامَۃَ ، عَنْ نَافِعٍ ؛ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ ، قَالَ : لَیْسَ فِی الْخَیْلِ صَدَقَۃٌ۔",,,37544
37545,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ، قَالَ : لَیْسَ فِی الْخَیْلِ وَالرَّقِیقِ صَدَقَۃٌ ، إِلاَّ صَدَقَۃُ الْفِطْرِ۔\n\nوَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : إِنْ کَانَتْ خَیْلٌ فِیْہَا ذُکُورٌ وَإَِِناثٌ یُطْلَبُ نَسْلَہَا ، فَفِیْہَا صَدَقَۃٌ۔",,,37545
37546,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، رَفَعَہُ ، قَالَ : إِذَا أَمَّنَ الْقَارِئُ فَأَمِّنُوا ، فَمَنْ وَافَقَ تَأْمِینُہُ تَأْمِینَ الْمَلاَئِکَۃِ غُفِرَ لَہُ مَا تَقَدَّمَ مِنْ ذَنْبِہِ۔",,,37546
37547,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ الْجَبَّارِ بْنِ وَائِلٍ ، عَنْ أَبِیہِ ، قَالَ : صَلَّیْتُ مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَلَمَا قَالَ : {غَیْرِ الْمَغْضُوبِ عَلَیْہِمْ ، وَلاَ الضَّالِّینَ} ، قَالَ : آمِینَ۔",,,37547
37548,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سَلَمَۃَ ، عَنْ حُجْرِ بْنِ عَنْبَسٍ ، عَنْ وَائِلِ بْنِ حُجْرٍ ، قَالَ : سَمِعْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَرَأَ : {وَلاَ الضَّالِّینَ} ، فَقَالَ : آمِینَ ، یَمُدُّ بِہَا صَوْتَہُ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ یَرْفَعُ الإِمَامُ صَوْتَہُ بِآمِین ، وَیَقُولُہَا مَنْ خَلَفَہُ۔",,,37548
37549,"حَدَّثَنَا ہُشَیْمٌ ، أَخْبَرَنَا خَالِدٌ ، عَنْ عَبْدِ اللہِ بْنِ شَقِیقٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : صَلاَۃُ اللَّیْلِ مَثْنَی مَثْنَی ، وَالْوِتْرُ وَاحِدَۃٌ ، وَسَجْدَتَانِ قَبْلَ طُلُوعِ الْفَجْرِ۔",,,37549
37550,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ ، عَنِ ابْنِ عُمَرَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : صَلاَۃُ اللَّیْلِ مَثْنَی مَثْنَی ، فَإِذَا خَشِیتَ الصُّبْحَ فَأَوْتِرْ بِرَکْعَۃٍ۔",,,37550
37551,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَبْدِ اللہِ بْنِ دِینَارٍ ، عَنِ ابْنِ عُمَرَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : صَلاَۃُ اللَّیْلِ مَثْنَی مَثْنَی ، فَإِذَا خَشِیتَ الصُّبْحَ فَأَوْتِرْ بِرَکْعَۃٍ ، تُوتِرُ لَک مَا مَضَی مِنْ صَلاَتِک۔",,,37551
37552,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ مَوْلَی آلِ طَلْحَۃَ ، عَنْ أَبِی سَلَمَۃَ ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُسَلِّمُ فِی کُلِّ رَکْعَتَیْنِ مِنْ صَلاَۃِ اللَّیْلِ۔",,,37552
37553,"حَدَّثَنَا یَزِیدُ ، عَنِ ابْنِ عَوْنٍ ، عَنْ رَجَائٍ ، عَنْ قَبِیصَۃَ بْنِ ذُؤَیْبٍ ، قَالَ : مَرَّ عَلَیَّ أَبُو ہُرَیْرَۃَ وَأَنَا أُصَلِّی ، فَقَالَ: اِفْصِلْ، فَلَمْ أَدْرِ مَا قَالَ، فَلَمَّا انْصَرَفْتُ، قُلْتُ: مَا أَفْصِلُ؟ قَالَ: افْصِلْ بَیْنَ صَلاَۃِ اللَّیْلِ، وَصَلاَۃِ النَّہَارِ۔",,,37553
37554,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ حَبِیبِ بْنِ أَبِی عَمْرَۃَ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ، قَالَ: فِی کُلِّ رَکْعَتَیْنِ فَصْلٌ۔",,,37554
37555,"حَدَّثَنَا وَکِیعٌ ، عَنْ عُمَرَ بْنِ الْوَلِیدِ ، عَنْ عِکْرِمَۃَ ، قَالَ : بَیْنَ کُلِّ رَکْعَتَیْنِ تَسْلِیمَۃٌ۔",,,37555
37556,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ خَالِدِ بْنِ دِینَارٍ ، عَنْ سَالِمٍ ؛ أَنَّہُ قَالَ : صَلاَۃُ اللَّیْلِ مَثْنَی مَثْنَی۔",,,37556
37557,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : صَلاَۃُ اللَّیْلِ مَثْنَی مَثْنَی ، وَالْوِتْرُ رَکْعَۃٌ مِنْ آخِرِ اللَّیْلِ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : إِنْ شِئْتَ صَلَّیْتَ رَکْعَتَیْنِ ، وَإِنْ شِئْتَ أَرْبَعًا ، وَإِنْ شِئْتَ سِتًّا، لاَ تَفْصِل بَیْنَہُنَّ۔",,,37557
37558,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ خَالِدٍ ، عَنْ عَبْدِ اللہِ بْنِ شَقِیقٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : الْوِتْرُ وَاحِدَۃٌ۔",,,37558
37559,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ ، عَنْ أَبِیہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إِذَا خَشِیتَ الصُّبْحَ فَأَوْتِرْ بِرَکْعَۃٍ۔",,,37559
37560,"حَدَّثَنَا ہُشَیْمٌ ، أَخْبَرَنَا حَجَّاجٌ ، عَنْ عَطَائٍ ؛ أَنَّ مُعَاوِیَۃَ أَوْتَرَ بِرَکْعَۃٍ ، فَأُنْکِرَ ذَلِکَ عَلَیْہِ ، فَسُئِلَ عَنْہُ ابْنُ عَبَّاسٍ ، فَقَالَ : أَصَابَ السُّنَّۃَ۔",,,37560
37561,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ حُصَیْنٍ ، عَنْ مُصْعَبِ بْنِ سَعْدٍ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یُوتِرُ بِرَکْعَۃٍ ،فَقِیلَ لَہُ ؟ فَقَالَ : إِنَّمَا اسْتَقْصَرتُہَا۔",,,37561
37562,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، قَالَ : سَأَلْتُ عَطَائً : أُوتِرُ بِرَکْعَۃٍ ؟ قَالَ : نَعَمْ ، إِنْ شِئْتَ۔",,,37562
37563,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : سَمَرَ ابْنُ مَسْعُودٍ ، وَحُذَیْفَۃُ عِنْدَ الْوَلِیدِ بْنِ عُقْبَۃَ ، ثُمَّ خَرَجَا فَتَقَاوَمَا ، فَلَمَّا أَصْبَحَا رَکَعَ کُلُّ وَاحِدٍ مِنْہُمَا رَکْعَۃً۔",,,37563
37564,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : صَلاَۃُ اللَّیْلِ مَثْنَی مَثْنَی ، فَإِذَا خَشِیتَ الصُّبْحَ فَأَوْتِرْ بِوَاحِدَۃٍ۔ (مسلم 164۔ ابن ماجہ 1320)",,,37564
37565,حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ لَیْثٍ ؛ أَنَّ أَبَا بَکْرٍ کَانَ یُوتِرُ بِرَکْعَۃٍ ، وَیَتَکَلَّمُ فِیمَا بَیْنَ الرَّکْعَتَیْنِ وَالرَّکْعَۃِ۔,,,37565
37566,"حَدَّثَنَا ابْنُ أَبِی عَدِیٍّ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : الْوِتْرُ رَکْعَۃٌ مِنْ آخِرِ اللَّیْلِ۔",,,37566
37567,حَدَّثَنَا مَرْحُومٌ ، عَنْ عِسْلِ بْنِ سُفْیَانَ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ أَوْتَرَ بِرَکْعَۃٍ۔,,,37567
37568,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ، قَالَ : کَانَ آلُ سَعْدٍ ، وَآلُ عَبْدِ اللہِ یُسَلِّمُونَ فِی رَکْعَتَی الْوِتْرِ ، وَیُوتِرُونَ بِرَکْعَۃٍ۔",,,37568
37569,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ سَعِیدٍ ، وَنَافِعٍ ، قَالاَ : رَأَیْنَا مُعَاذًا الْقَارِئَ یُسَلِّمُ فِی رَکْعَتَی الْوِتْرِ۔",,,37569
37570,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَانَ الْحَسَنُ یُسَلِّمُ فِی رَکْعَتیِ الْوِتْرِ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ یَجُوزُ أَنْ یُوْتِرَ بِرَکْعَۃٍ۔",,,37570
37571,"حَدَّثَنَا عَبْدُ اللہِ بْنُ مُبَارَکٍ ، وَیَزِیدُ بْنُ ہَارُونَ ، عَنْ سَعِیدِ بْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ أَبِی الْمَلِیحِ ، عَنْ أَبِیہِ ، قَالَ : نَہَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ جُلُودِ السِّبَاعِ ، قَالَ یَزِیدُ : أَنْ تُفْتَرَشَ۔ \n\n(ترمذی 1770۔ ابوداؤد 4129)",,,37571
37572,حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّ ابْنَ مَسْعُودٍ اسْتَعَارَ دَابَّۃً ، فَأُتِیَ بِہَا عَلَیْہَا صُفَّۃُ نُمُورٍ ، فَنَزَعَہَا ثُمَّ رَکِبَ۔,,,37572
37573,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَلِیِّ بْنِ الْحَکَمِ ، قَالَ : سَأَلْتُ الْحَکَمَ عْن جُلُودِ النُّمُورِ ؟ فَقَالَ : تُکْرَہُ جُلُودُ السِّبَاعِ۔",,,37573
37574,حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ؛ أَنَّ عُمَرَ کَتَبَ إِلَی أَہْلِ الشَّامِ یَنْہَاہُمْ أَنْ یَرْکَبُوا عَلَی جُلُودِ السِّبَاعِ۔,,,37574
37575,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یَزِیدَ الرِّشْکِ ، عَنْ أَبِی الْمَلِیحِ ، قَالَ : نَہَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ جُلُودِ السِّبَاعِ أَنْ تُفْتَرَشَ۔ (ترمذی 1771۔ عبدالرزاق 215)",,,37575
37576,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مَنْصُورٍ ، عَنِ الْحَسَنِ ، عَنْ عَلِیٍّ ؛ أَنَّہُ کَرِہَ الصَّلاَۃَ فِی جُلُودِ الثَّعَالِبِ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ بَأْسِ بِالْجُلُوسِ عَلَیْہَا۔",,,37576
37577,"حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَخْطُبُ ، فَقَالَ لِلنَّاسِ : اجْلِسُوا ، فَسَمِعَہُ عَبْدُ اللہِ بْنُ مَسْعُودٍ وَہُوَ عَلَی الْبَابِ فَجَلَسَ ، فَقَالَ : یَا عَبْدَ اللہِ ، اُدْخُلْ۔",,,37577
37578,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ إِسْمَاعِیلَ ، عَنْ قَیْسٍ ، قَالَ : جَائَ أَبِی وَالنَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَخْطُبُ ، فَقَامَ بَیْنَ یَدَیْہِ فِی الشَّمْسِ ، فَأَمَرَ بِہِ فَحُوِّلَ إِلَی الظِّلِّ۔",,,37578
37579,"حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : إِنْ کَانُوا لَیُسَلِّمُونَ عَلَی الإِمَامِ وَہُوَ عَلَی الْمِنْبَرِ ، فَیَرُدُّ۔",,,37579
37580,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ خَالِدٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : کَانُوا یَسْتَأْذِنُونَ الإِمَامَ وَہُوَ عَلَی الْمِنْبَرِ ، فَلَمَّا کَانَ زِیَادٌ وَکَثُرَ ذَلِکَ ، قَالَ : مَنْ وَضَعَ یَدَہُ عَلَی أَنْفِہِ فَہُوَ إِذْنُہُ۔",,,37580
37581,"حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی سُفْیَانَ ، عَنْ جَابِرٍ ، قَالَ : جَائَ سُلَیْکٌ الْغَطَفَانِیُّ ، وَالنَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَخْطُبُ یَوْمَ الْجُمُعَۃِ ، فَقَالَ لَہُ : صَلَّیْتَ ؟ قَالَ : لاَ ، قَالَ : صَلِّ رَکْعَتَیْنِ تَجَوَّزْ فِیہِمَا۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ یُکَلِّم الإِمَامُ أَحَدًا فِی خِطْبَتِہِ۔",,,37581
37582,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ ہِشَامِ بْنِ إِسْحَاقَ بْنِ عَبْدِ اللہِ بْنِ کِنَانَۃَ ، عَنْ أَبِیہِ ، قَالَ : أَرْسَلَنِی أَمِیرٌ مِنَ الأُمَرَائِ إِلَی ابْنِ عَبَّاسٍ أَسْأَلُہُ عَنِ الاِسْتِسْقَائِ ، فَقَالَ ابْنُ عَبَّاسٍ : مَا مَنَعَہُ أَنْ یَسْأَلَنِی ؟ خَرَجَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مُتَوَاضِعًا ، مُتَبَذِّلاً ، مُتَخَشِّعًا ، مُتَضَرِّعًا ، مُتَرَسِّلاً ، فَصَلَّی رَکْعَتَیْنِ کَمَا یُصَلِّی فِی الْعِیدِ ، وَلَمْ یَخْطُبْ خُطَبَتکُمْ ہَذِہِ۔",,,37582
37583,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ، قَالَ: خَرَجْنَا مَعَ عَبْدِ اللہِ بْنِ یَزِیدَ الأَنْصَارِیِّ نَسْتَسْقِی، فَصَلَّی رَکْعَتَیْنِ وَخَلْفَہُ زَیْدُ بْنُ أَرْقَمَ۔",,,37583
37584,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ مُحَمَّدِ بْنِ ہِلاَلٍ ؛ أَنَّہُ شَہِدَ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ فِی الاِسْتِسْقَائِ بَدَأَ بِالصَّلاَۃِ قَبْلَ الْخُطْبَۃِ ، قَالَ : وَاسْتَسْقَی فَحَوَّلَ رِدَائَہُ۔",,,37584
37585,"حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، عَنْ عَبَّادِ بْنِ تَمِیمٍ ، عَنْ عَبْدِ اللہِ بْنِ زَیْدٍ ، وَکَانَ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ أَنَّہُ رَأَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَوْمَ خَرَجَ یَسْتَسْقِی فَحَوَّلَ إِلَی النَّاسِ ظَہْرَہُ یَدْعُو ، وَاسْتَقْبَلَ الْقِبْلَۃَ ، ثُمَّ حَوَّلَ رِدَائَہُ ، ثُمَّ صَلَّی رَکْعَتَیْنِ ، وَقَرَأَ فِیہِمَا وَجَہَرَ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ تُصَلَّی صَلاَۃِ الاِسْتِسْقَائِ فِی جَمَاعَۃٍ ، وَلاَ یُخْطَبُ فِیْہَا۔",,,37585
37586,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْحَارِثِ بْنِ عَیَّاشِ بْنِ أَبِی رَبِیعَۃَ ، عَنْ حَکِیمِ بْنِ حَکِیمِ بْنِ عَبَّادِ بْنِ حُنَیْفٍ ، عَنْ نَافِعِ بْنِ جُبَیْرِ بْنِ مُطْعِمٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَمَّنِی جِبْرِیلُ عِنْدَ الْبَیْتِ مَرَّتَیْنِ ، فَصَلَّی بِی الْعِشَائَ حِینَ غَابَ الشَّفَقُ ، وَصَلَّی بِی مِنَ الْغَدِ الْعِشَائَ ثُلُثَ اللَّیْلِ الأَوَّلِ ، وَقَالَ : ہَذَا الْوَقْتُ وَقْتُ النَّبِیُّینَ قَبْلَک ، الْوَقْتُ بَیْنَ ہَذَیْنِ الْوَقْتَیْنِ۔",,,37586
37587,"حَدَّثَنَا وَکِیعٌ ، عَنْ بَدْرِ بْنِ عُثْمَانَ ، سَمِعَہُ مِنْ أَبِی بَکْرِ بْنِ أَبِی مُوسَی ، عَنْ أَبِیہِ ؛ أَنَّ سَائِلاً أَتَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَسَأَلَہُ عَنْ مَوَاقِیتِ الصَّلاَۃِ ، فَلَمْ یَرُدَّ عَلَیْہِ شَیْئًا ، ثُمَّ أَمَرَ بِلاَلاً فَأَقَامَ الْعِشَائَ الآخِرَۃَ عِنْدَ سُقُوطِ الشَّفَقِ ، ثُمَّ صَلَّی مِنَ الْغَدِ الْعِشَائَ ثُلُثَ اللَّیْلِ ، ثُمَّ قَالَ : أَیْنَ السَّائِلُ عَنِ الْوَقْتِ ؟ مَا بَیْنَ ہَذَیْنِ الْوَقْتَیْنِ وَقْتٌ۔",,,37587
37588,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ خَارِجَۃَ بْنِ عَبْدِ اللہِ بْنِ سُلَیْمَانَ بْنِ زَیْدِ بْنِ ثَابِتٍ ، قَالَ : حدَّثَنِی حُسَیْنُ بْنُ بَشِیر بْن سَلْمَانَ ، عَنْ أَبِیہِ ، قَالَ : دَخَلْتُ أَنَا ، وَمُحَمَّدُ بْنُ عَلِیٍّ عَلَی جَابِرِ بْنِ عَبْدِ اللہِ ، فَقُلْنَا لَہُ : حَدِّثْنَا کَیْفَ کَانَتِ الصَّلاَۃُ مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ فَقَالَ : صَلَّی بِنَا النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْعِشَائَ حِینَ غَابَ الشَّفَقُ ، ثُمَّ صَلَّی بِنَا مِنَ الْغَدِ الْعِشَائَ حِینَ ذَہَبَ ثُلُثُ اللَّیْلِ۔",,,37588
37589,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنْ صَفِیَّۃَ ابْنَۃِ أَبِی عُبَیْدٍ ؛ أَنَّ عُمَرَ بْنَ الْخَطَّابِ کَتَبَ إِلَی أُمَرَائِ الأَجْنَادِ یُوَقِّتُ لَہُمَ الصَّلاَۃَ ، قَالَ : صَلُّوا صَلاَۃَ الْعِشَائِ إِذَا غَابَ الشَّفَقُ ، فَإِنْ شُغِلْتُمْ فَمَا بَیْنَکُمْ وَبَیْنَ أَنْ یَذْہَبَ ثُلُثُ اللَّیْلِ ، وَلاَ تَشَاغَلُوا عَنِ الصَّلاَۃِ ، فَمَنْ رَقَدَ بَعْدَ ذَلِکَ فَلاَ أَرْقَدَ اللَّہُ عَیْنَہُ ، یَقُولُہَا ثَلاَثَ مِرَارٍ۔",,,37589
37590,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : وَقْتُ الْعِشَائِ إِلَی رُبُعِ اللَّیْلِ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : وَقْتُ الْعِشَائِ إِلَی نِصْفِ اللَّیْلِ۔",,,37590
37591,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدٍ ؛ أَنَّ الْقَسَامَۃَ کَانَتْ فِی الْجَاہِلِیَّۃِ ، فَأَقَرَّہَا النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی قَتِیلٍ مِنَ الأَنْصَارِ وُجِدَ فِی جُبِّ الْیَہُودِ ، قَالَ : فَبَدَأَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِالْیَہُودِ ، فَکَلَّفَہُمْ قَسَامَۃَ خَمْسِینَ ، فَقَالَتِ الْیَہُودُ : لَنْ نَحْلِفَ ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لِلأَنْصَارِ : أَفَتَحْلِفُونَ ؟ قَالَتِ الأَنْصَارُ : لَنْ نَحْلِفَ ، فَأَغْرَمَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْیَہُودَ دِیَتَہُ لأَنَّہُ قُتِلَ بَیْنَ أَظْہُرِہِمْ۔",,,37591
37592,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ: دَعَانِی عُمَرُ بْنُ عَبْدِ الْعَزِیزِ، فَسَأَلَنِی عَنِ الْقَسَامَۃِ، فَقَالَ : إِنَّہُ قَدْ بَدَا لِی أَنْ أَرُدَّہَا ، إِنَّ الأَعْرَابِیَّ یَشْہَدُ ، وَالرَّجُلُ الْغَائِبُ یَجِیئُ فَیَشْہَدُ ، فَقُلْتُ : یَا أَمِیرَ الْمُؤْمِنِینَ ، إِنَّک لَنْ تَسْتَطِیعَ رَدَّہَا ، قَضَی بِہَا النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَالْخُلَفَائُ بَعْدَہُ۔",,,37592
37593,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ سَعِیدِ بْنِ عُبَیْدٍ الطَّائِیِّ ، عَنْ بُشَیْرِ بْنِ یَسَارٍ ؛ أَنَّ رَجُلاً مِنَ الأَنْصَارِ ، یُقَالُ لَہُ : سَہْلُ بْنُ أَبِی حَثْمَۃَ أَخْبَرَہُ ، أَنَّ نَفَرًا مِنْ قَوْمِہِ انْطَلَقُوا إِلَی خَیْبَرَ ، فَتَفَرَّقُوا فِیہَا ، فَوَجَدُوا أَحَدَہُمْ قَتِیلاً ، فَقَالُوا لِلَّذِینَ وَجَدُوہُ عِنْدَہُمْ : قَتَلْتُمْ صَاحِبَنَا ، قَالُوا : مَا قَتَلْنَا ، وَلاَ عَلِمْنَا قَاتِلاً ، قَالَ : فَانْطَلَقُوا إِلَی نَبِیِّ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالُوا : یَا نَبِیَّ اللہِ ، انْطَلَقْنَا إِلَی خَیْبَرَ فَوَجَدْنَا أَحَدَنَا قَتِیلاً ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْکُبْرُ الْکُبْرُ ، فَقَالَ لَہُمْ : تَأْتُونَ بِالْبَیِّنَۃِ عَلَی مَنْ قَتَلَ ؟ قَالُوا : مَا لَنَا بَیِّنَۃٌ ، قَالَ : فَیَحْلِفُونَ لَکُمْ ، قَالُوا : لاَ نَرْضَی بِأَیْمَانِ الْیَہُودِ ، فَکَرِہَ نَبِیُّ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یُبْطِلَ دَمَہُ ، فَوَدَاہُ بِمِئَۃٍ مِنْ إبِلِ الصَّدَقَۃِ۔",,,37593
37594,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ حَجَّاجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ؛ أَنَّ حُوَیِّصَۃَ ، وَمُحَیِّصَۃَ ابْنَیْ مَسْعُودٍ ، وَعَبْدَ اللہِ ، وَعَبْدَ الرَّحْمَن ابْنَیْ فُلاَنٍ ، خَرَجُوا یَمْتَارُونَ بِخَیْبَرَ ، فَعُدِیَ عَلَی عَبْدِ اللہِ ، فَقُتِلَ ، قَالَ : فَذَکَرُوا ذَلِکَ لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : تُقْسِمُونَ بِخَمْسِینَ وَتَسْتَحِقُّونَ ؟ فَقَالُوا : یَا رَسُولَ اللہِ ، کَیْفَ نُقْسِمُ وَلَمْ نَشْہَدْ ؟ قَالَ : فَتُبَرِّئُکُمْ یَہُودُ ؟ قَالُوا : یَا رَسُولَ اللہِ ، إِذًا تَقْتُلُنَا یَہُودُ ۔ قَالَ : فَوَدَاہُ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِنْ عِنْدِہِ۔",,,37594
37595,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، حَدَّثَنَا سَعِیدٌ ، عَنْ قَتَادَۃَ ؛ أَنَّ سُلَیْمَانَ بْنَ یَسَارٍ ، قَالَ : الْقَسَامَۃُ حَقٌّ ، قَضَی بِہَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، بَیْنَمَا الأَنْصَارُ عِنْدَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إِذْ خَرَجَ رَجُلٌ مِنْہُمْ ، ثُمَّ خَرَجُوا مِنْ عِنْدِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَإِذَا ہُمْ بِصَاحِبِہِمْ یَتَشَحَّطُ فِی دَمِہِ ، فَرَجَعُوا إِلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالُوا : قَتَلَتْنَا الْیَہُودُ ، وَسَمَّوْا رَجُلاً مِنْہُمْ ، وَلَمْ تَکُنْ لَہُمْ بَیِّنَۃٌ ، فَقَالَ لَہُمَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : شَاہِدَانِ مِنْ غَیْرِکُمْ ، حَتَّی أَدْفَعَہُ إِلَیْکُمْ بِرُمَّتِہِ ، فَلَمْ تَکُنْ لَہُمْ بَیِّنَۃٌ ، فَقَالَ : اسْتَحِقُّوا بِخَمْسِینَ قِسَامَۃٍ أَدْفَعْہُ إِلَیْکُمْ بِرُمَّتِہِ ؟ فَقَالُوا : یَا رَسُولَ اللہِ ، إِنَّا نَکْرَہُ أَنْ نَحْلِفَ عَلَی غَیْبٍ ، فَأَرَادَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یَأْخُذَ قَسَامَۃَ الْیَہُودِ بِخَمْسِینَ مِنْہُمْ ، فَقَالَتِ الأَنْصَارُ : یَا رَسُولَ اللہِ ، إِنَّ الْیَہُودَ لاَ یُبَالُونَ الْحَلِفَ ، مَتَی مَا نَقْبَلُ ہَذَا مِنْہُمْ یَأْتُون عَلَی آخِرِنَا ، فَوَدَاہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِنْ عِنْدِہِ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ تُقْبَل أَیْمَان الَّذِین یَدَّعُون الدَّم۔",,,37595
37596,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ، عَنْ أَبِی الزُّبَیْرِ، عَنْ عَبْدِاللہِ بْنِ بَابَاہُ، عَنْ جُبَیْرِ بْنِ مُطْعِمٍ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ؛ أَنَّہُ قَالَ : یَا بَنِی عَبْدِ مَنَافٍ ، لاَ تَمْنَعُوا أَحَدًا طَافَ بِہَذَا الْبَیْتِ وَصَلَّی أَیَّ سَاعَۃٍ مِنْ لَیْلٍ، أَوْ نَہَارٍ۔",,,37596
37597,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَطَائٍ ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ طَافَ بِالْبَیْتِ بَعْدَ الْفَجْرِ ، وَصَلَّی رَکْعَتَیْنِ قَبْلَ طُلُوعِ الشَّمْسِ۔",,,37597
37598,"حَدَّثَنَا أَبُو الأَحْوَصِِ، عَنْ لَیْثٍ، عَنْ عَطَائٍ، قَالَ: رَأَیْتُ ابْنَ عُمَرَ، وَابْنَ عَبَّاسٍ طَافَا بَعْدَ الْعَصْرِ وَصَلَّیَا۔",,,37598
37599,حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ أَبِی شُعْبَۃِ ؛ أَنَّہُ رَأَی الْحَسَنَ وَالْحُسَیْنَ قَدِمَا مَکَّۃَ فَطَافَا بِالْبَیْتِ بَعْدَ الْعَصْرِ وَصَلَّیَا۔,,,37599
37600,حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الْوَلِیدِ بْنِ جُمَیْعٍ ، عَنْ أَبِی الطُّفَیْلِ ؛ أَنَّہُ کَانَ یَطُوفُ بَعْدَ الْعَصْرِ وَیُصَلِّی حَتَّی تَصْفَارَّ الشَّمْسُ۔,,,37600
37601,"حَدَّثَنَا یَعْلَی ، عَنِ الأَجْلَحِ ، عَنْ عَطَائٍ ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ ، وَابْنَ الزُّبَیْرِ طَافَا بِالْبَیْتِ قَبْلَ صَلاَۃِ الْفَجْرِ ، ثُمَّ صَلَّیَا رَکْعَتَیْنِ قَبْلَ طُلُوعِ الشَّمْسِ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ یُصَلِّی حَتَّی تَغِیبَ أَوْ تَطْلُعَ ، وَتُمَکِن الصَّلاَۃ۔",,,37601
37602,"حَدَّثَنَا عَبْدُ اللہِ بْن مُبَارَکِ ، عَنْ سَعِیدِ بْنِ یَزِیدَ ، قَالَ : سَمِعْتُ خَالِدَ بْنَ أَبِی عِمْرَانَ ،یُحَدِّثُ عَنْ حَنَشٍ، عَنْ فَضَالَۃَ بْنِ عُبَیْدٍ ، قَالَ : أُتِیَ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَوْمَ خَیْبَرَ بِقِلاَدَۃٍ فِیہَا خَرَزٌ مُعَلَّقَۃٌ بِذَہَبٍ ، ابْتَاعَہَا رَجُلٌ بِسَبْعَۃِ دَنَانِیرَ ، أَوْ بِتِسْعَۃِ دَنَانِیرَ ، فَأُتِیَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَذَکَرَ ذَلِکَ لَہُ ، فَقَالَ : لاَ، حَتَّی تُمَیِّزَ مَا بَیْنَہُمَا ، قَالَ : إِنَّمَا أَرَدْتُ الْحِجَارَۃَ ، قَالَ : لاَ ، حَتَّی تُمَیِّزَ مَا بَیْنَہُمَا ، قَالَ : فَرَدَّہُ حَتَّی مَیَّزَ۔",,,37602
37603,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ اللہِ ، عَنْ أَبِی قِلاَبَۃَ ، عَنْ أَنَسٍ ، قَالَ : أَتَانَا کِتَابُ عُمَرَ وَنَحْنُ بِأَرْضِ فَارِسَ : أَلاَّ تَبِیعُوا السُّیُوفَ فِیہَا حَلَقَۃُ فِضَّۃٍ بِدِرْہَمٍ۔",,,37603
37604,"حَدَّثَنَا وَکِیعٌ ، عَنْ زَکَرِیَّا ، عَنِ الشَّعْبِیِّ ، قَالَ : سُئِلَ شُرَیْحٌ عَنْ طَوْقٍ مِنْ ذَہَبٍ فِیہِ فُصُوصٌ ، قَالَ : تُنْزَعُ الْفُصُوصُ ، ثُمَّ یُبَاعُ الذَّہَبُ وَزْنًا بِوَزْنٍ۔",,,37604
37605,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ ؛ کَانَ یَکْرَہُ شِرَائَ السَّیْفِ الْمُحَلَّی إِلاَّ بِعَرَضٍ۔,,,37605
37606,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ؛ أَنَّہُ کَانَ یَکْرَہُ شِرَائَ السَّیْفِ الْمُحَلَّی بِفِضَّۃٍ ، وَیَقُولُ : اشْتَرِہِ بِذَہَبٍ یَدًا بِیَدٍ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ بَأْسَ أَنْ یَشْتَرِیہِ بِالدَّرَاہِمِ۔",,,37606
37607,"حَدَّثَنَا شَرِیکٌ ، عَنْ ہِلاَلٍ الْوَزَّانِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إِذَا فَاتَتْہُ أَرْبَعٌ قَبْلَ الظُّہْرِ صَلاَہَا بَعْدَہَا۔",,,37607
37608,"حَدَّثَنَا جَرِیرٌ، عَنْ أَبِی جَعْفَرٍ، عَنْ مَنْصُورٍ، عَنْ إِبْرَاہِیمَ، قَالَ: إِذَا فَاتَتْہُ أَرْبَعٌ قَبْلَ الظُّہْرِ صَلاَہَا بَعْدَہَا۔",,,37608
37609,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ رَجُلٍ مِنْ بَنِی أَوْدٍ ، عَنْ عَمْرِو بْنِ مَیْمُونٍ ، قَالَ : مَنْ فَاتَتْہُ أَرْبَعٌ قَبْلَ الظُّہْرِ ، فَلْیُصَلِّہَا بَعْدَ الرَّکْعَتَیْنِ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ یُصَلِّیہَا وَلاَ یُقْضِیہَا۔",,,37609
37610,حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ ، عَنْ لَیْثِ بْنِ سَعْدٍ ، عَنِ ابْنِ شِہَابٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ کَعْبِ بْنِ مَالِکٍ ؛ أَنَّ جَابِرَ بْنَ عَبْدِ اللہِ أَخْبَرَہُ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَجْمَعُ بَیْنَ الرَّجُلَیْنِ مِنْ قَتْلَی أُحُدٍ فِی قَبْرٍ وَاحِدٍ ، وَأَمَرَ بِدَفْنِہِمْ بِدِمَائِہِمْ ، وَلَمْ یُصَلِّ عَلَیْہِمْ ، وَلَمْ یُغَسَّلُوا۔,,,37610
37611,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ أُسَامَۃَ بْنِ زَیْدٍ ، عَنِ الزُّہْرِیِّ ، عَنْ أَنَسٍ ، قَالَ : لَمَّا کَانَ یَوْمُ أُحُدٍ ، مَرَّ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِحَمْزَۃَ وَقَدْ جُدِعَ وَمُثِّلَ بِہِ ، فَقَالَ : لَوْلاَ أَنْ تَجِدَ صَفِیَّۃُ لَتَرَکْتُہُ حَتَّی یَحْشُرَہُ اللَّہُ مِنْ بُطُونِ السِّبَاعِ وَالطَّیْرِ ، وَلَمْ یُصَلِّ عَلَی أَحَدٍ مِنَ الشُّہَدَائِ ، وَقَالَ : أَنَا شَہِیدٌ عَلَیْکُمَ الْیَوْمَ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : یُصَلَّی عَلَی الشَّہِیدِ۔",,,37611
37612,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ حَسَّانَ بْنِ بِلاَلٍ ، قَالَ : رَأَیْتُ عَمَّارَ بْنَ یَاسِرٍ تَوَضَّأَ وَخَلَّلَ لِحْیَتَہُ ، فَقُلْتُ لَہُ ؟ فَقَالَ : رَأَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَعَلَہُ۔",,,37612
37613,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ إِسْرَائِیلَ ، عَنْ عَامِرِ بْنِ شَقِیقٍ ، عَنْ أَبِی وَائِلٍ ، قَالَ : رَأَیْتُ عُثْمَانَ تَوَضَّأَ فَخَلَّلَ لِحْیَتَہُ ثَلاَثًا ، ثُمَّ قَالَ : رَأَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَفْعَلُہُ۔",,,37613
37614,حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یُخَلِّلُ لِحْیَتَہُ۔,,,37614
37615,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی حَمْزَۃَ ، قَالَ : رَأَیْتُ ابْنَ عَبَّاسٍ یُخَلِّلُ لِحْیَتَہُ۔",,,37615
37616,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ أَبِی مَعْنٍ ، قَالَ : رَأَیْتُ أَنَسًا یُخَلِّلُ لِحْیَتَہُ۔",,,37616
37617,حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یُخَلِّلُ لِحْیَتَہُ۔,,,37617
37618,"حَدَّثَنَا زَیْدُ بْنُ حَبَّابٍ ، عَنْ عُمَرَ بْنِ سُلَیْمِ الْبَاہِلِیِّ ، عَنْ أَبِی غَالِبٍ ، قَالَ : رَأَیْتُ أَبَا أُمَامَۃَ تَوَضَّأَ ثَلاَثًا ثَلاَثًا ، وَخَلَّلَ لِحْیَتَہُ ، وَقَالَ : رَأَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَعَلَہُ۔",,,37618
37619,حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، حَدَّثَنَا حَسَنُ بْنُ صَالِحٍ ، عَنْ مُوسَی بْنِ أَبِی عَائِشَۃَ ، عَنْ رَجُلٍ ، عَنْ یَزِیدَ الرَّقَاشِیِّ ، عَنْ أَنَسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ خَلَّلَ لِحْیَتَہُ۔,,,37619
37620,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا الْہَیْثَم بْنُ جَمَّازٍ ، عَنْ یَزِیدَ بْنِ أَبَانَ ، عَنْ أَنَسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : أَتَانِی جِبْرِیلُ ، فَقَالَ : إِذَا تَوَضَّأْتَ فَخَلِّلْ لِحْیَتَک۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ کَانَ لاَ یَرَی تَخْلِیلَ اللِّحْیَۃِ۔",,,37620
37621,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ سَعِیدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ أَبْزَی ، عَنْ أَبِیہِ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقْرَأُ فِی الْوِتْرِ بِـ : {سَبِّحِ اسْمَ رَبِّکَ الأَعْلَی} ، وَ{قُلْ یَا أَیُّہَا الْکَافِرُونَ} ، وَ{قُلْ ہُوَ اللَّہُ أَحَدٌ)۔",,,37621
37622,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عُبَیْدَۃَ ، حَدَّثَنَا أَبِی ، عَنِ الأَعْمَشِ ، عَنْ طَلْحَۃَ ، عَنْ ذَرٍّ ، عَنْ سَعِیدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ أَبْزَی ، عَنْ أَبِیہِ ، عَنْ أُبَیِّ بْنِ کَعْبٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُوتِرُ بِـ : {سَبِّحِ اسْمَ رَبِّکَ الأَعْلَی} ، وَ{قُلْ یَا أَیُّہَا الْکَافِرُونَ} ، وَ{قُلْ ہُوَ اللَّہُ أَحَدٌ}۔",,,37622
37623,"حَدَّثَنَا شَبَابَۃُ ، عَنْ یُونُسَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُوتِرُ بِثَلاَثٍ ، یَقْرَأُ فِیہِنَّ بِـ : {سَبِّحِ اسْمَ رَبِّکَ الأَعْلَی} ، وَ{قُلْ یَا أَیُّہَا الْکَافِرُونَ} ، وَ{قُلْ ہُوَ اللَّہُ أَحَدٌ}۔",,,37623
37624,"حَدَّثَنَا شَبَابَۃُ ، عَنْ شُعْبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ زُرَارَۃَ بْنِ أَوْفَی ، عَنْ عِمْرَانَ بْنِ حُصَیْنٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَوْتَرَ بـ : {سَبِّحِ اسْمَ رَبِّکَ الأَعْلَی}۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ کَرِہَ أَنْ یَخُصَّ سُوَرۃً یَقْرَأُ بِہَا فِی الْوِتْرِ۔",,,37624
37625,"حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ عُبَیْدِ اللہِ بْنِ أَبِی رَافِعٍ ، قَالَ : اسْتَخْلَفَ مَرْوَانُ أَبَا ہُرَیْرَۃَ عَلَی الْمَدِینَۃِ وَخَرَجَ إِلَی مَکَّۃَ ، فَصَلَّی بِنَا أَبُو ہُرَیْرَۃَ الْجُمُعَۃَ ، فَقَرَأَ بِسُورَۃِ الْجُمُعَۃِ فِی السَّجْدَۃِ الأُولَی ، وَفِی الآخِرَۃِ : (إِذَا جَائَک الْمُنَافِقُونَ)۔ قَالَ عُبَیْدُ اللہِ : فَأَدْرَکْتُ أَبَا ہُرَیْرَۃَ حِینَ انْصَرَفَ ، فَقُلْتُ : إِنَّک قَرَأْتَ بِسُورَتَیْنِ کَانَ عَلِیٌّ رَحِمَہُ اللہِ یَقْرَأُ بِہِمَا فِی الْکُوفَۃِ ، فَقَالَ أَبُو ہُرَیْرَۃَ : إِنِّی سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقْرَأُ بِہِمَا۔",,,37625
37626,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنِ الْحَکَمِ ، عَنْ أُنَاسٍ مِنْ أَہْلِ الْمَدِینَۃِ ، أُرَی فِیہِمْ أَبَا جَعْفَرٍ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقْرَأُ فِی الْجُمُعَۃِ بِسُورَۃِ الْجُمُعَۃِ ، وَالْمُنَافِقِینَ ، فَأَمَّا سُورَۃُ الْجُمُعَۃِ : فَیُبَشِّرُ بِہَا الْمُؤْمِنِینَ وَیُحَرِّضُہُمْ ، وَأَمَّا سُورَۃُ الْمُنَافِقِینَ : فَیُؤْیِسُ بِہَا الْمُنَافِقِینَ وَیُوَبِّخُہُمْ۔",,,37626
37627,"حَدَّثَنَا جَرِیرٌ ، عَنْ إِبْرَاہِیمَ بْنِ مُحَمَّدِ بْنِ الْمُنْتَشِرِ ، عَنْ أَبِیہِ ، عَنْ حَبِیبِ بْنِ سَالِمٍ ، عَنِ النُّعْمَانِ بْنِ بَشِیرٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَقْرَأُ فِی الْعِیدَیْنِ ، وَفِی الْجُمُعَۃِ بـ : {سَبِّحِ اسْمَ رَبِّکَ الأَعْلَی} ، وَ {ہَلْ أَتَاکَ حَدِیثُ الْغَاشِیَۃِ} ، وَإِذَا اجْتَمَعَ الْعِیدَانِ فِی یَوْمٍ قَرَأَ بِہِمَا فِیہِمَا۔",,,37627
37628,حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا سُفْیَانُ ، عَنْ إِبْرَاہِیمَ بْنِ مُحَمَّدِ بْنِ الْمُنْتَشِرِ ، عَنْ أَبِیہِ ، عَنْ حَبِیبِ بْنِ سَالِمٍ ، عَنِ النُّعْمَانِ بْنِ بَشِیرٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ بِنَحْوِ حَدِیثِ جَرِیرٍ۔,,,37628
37629,"حَدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنْ مِسْعَرٍ ، عَنْ مَعْبَدِ بْنِ خَالِدٍ ، عَنْ زَیْدٍ ، عَنْ سَمُرَۃََ ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقْرَأُ فِی الْجُمُعَۃِ بـ : {سَبِّحِ اسْمَ رَبِّکَ الأَعْلَی} ، وَ {ہَلْ أَتَاک حَدِیثُ الْغَاشِیَۃِ}۔",,,37629
37630,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ ضَمْرَۃَ بْنِ سَعِیدٍ ، قَالَ : سَمِعْتُ عُبَیْدَ اللہِ بْنَ عَبْدِ اللہِ بْنِ عُتْبَۃَ ، یَقُولُ : خَرَجَ عُمَرُ یَوْمَ عِیدٍ ، فَسَأَلَ أَبَا وَاقِدٍ اللَّیْثِیَّ : بِأَیِّ شَیْئٍ قَرَأَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی ہَذَا الْیَوْمِ ؟ فَقَالَ : بِـ : (ق) وَ (اقْتَرَبَتْ)۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ کَرِہَ أَنْ تُخَصَّ سُورَۃٌ لِیَومِ الْجُمُعَۃِ وَالْعِیدَیْنِ۔",,,37630
37631,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، حَدَّثَنَا مُحَمَّدُ بْنُ إِسْحَاقَ ، عَنْ سَعِیدِ بْنِ السَّبَّاقِ ، عَنْ أَبِیہِ ، عَنْ سَہْلِ بْنِ حُنَیْفٍ ، قَالَ : کُنْتُ أَلْقَی مِنَ الْمَذْیِ شِدَّۃً ، فَکُنْتُ أُکْثِرُ الْغُسْلَ مِنْہُ ، فَذَکَرْتُ ذَلِکَ لِرَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : إِنَّمَا یَکْفِیَک مِنْ ذَلِکَ الْوُضُوئُ ، قَالَ : قُلْتُ : یَا رَسُولَ اللہِ ، فَکَیْفَ بِمَا یُصِیبُ ثَوْبِی ؟ قَالَ : إِنَّمَا یَکْفِیَک کَفٌّ مِنْ مَائٍ تَنْضَحُ بِہِ مِنْ ثَوْبِکَ حَیْثُ تَرَی أَنَّہُ أَصَابَ۔",,,37631
37632,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ سِمَاکٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إِذَا أَجْنَبَ الرَّجُلُ فِی ثَوْبِہِ ، فَرَأَی فِیہِ أَثَرًا فَلْیَغْسِلْہُ ، فَإِنْ لَمْ یَرَ فِیہِ أَثَرًا فَلْیَنْضَحْہُ بِالْمَائِ۔",,,37632
37633,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : قَالَ رَجُلٌ مِنَ الْحَیِّ لأَبِی مَیْسَرَۃَ : إِنِّی أُجْنِبُ فِی ثَوْبِی، فَأَنْظُرُ فَلاَ أَرَی شَیْئًا ؟ قَالَ : إِذَا اغْتَسَلْتَ فَتَلَفَّفَ بِہِ وَأَنْتَ رَطْبٌ ، فَإِنَّ ذَلِکَ یُجْزِئُک۔",,,37633
37634,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ؛ فِی الرَّجُلِ یَحْتَلِمُ فِی الثَّوْبِ فَلاَ یَدْرِی أَیْنَ مَوْضِعَہُ ، قَالَ : یَنْضَحُ الثَّوْبَ بِالْمَائِ۔",,,37634
37635,"حَدَّثَنَا مَحْبُوبٌ الْقَوَارِیرِیُّ ، عَنْ مَالِکِ بْنِ حَبِیبٍ ، عَنْ سَالِمٍ ، قَالَ : سَأَلَہُ رَجُلٌ ، قَالَ : إِنِّی أَحْتَلِم فِی ثَوْبِی ؟ قَالَ : اغْسِلْہُ ، قَالَ : خَفِیَ عَلَیَّ ، قَالَ : رُشَّہُ بِالْمَائِ۔",,,37635
37636,حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، عَنْ زُیَیْدِ بْنِ الصَّلْتِ ؛ أَنَّ عُمَرَ نَضَحَ مَا لَمْ یَرَ۔,,,37636
37637,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : إِنْ أَضْلَلْتَ فَانْضَحْ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ یَنْضَحَہُ ، وَلاَ یَزِیدَہ الْمَائُ إِلاَ شَرًّا۔",,,37637
37638,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی سُفْیَانَ ، عَنْ جَابِرٍ ، قَالَ : جَائَ سُلَیْکٌ الْغَطَفَانِیُّ ، وَالنَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَخْطُبُ یَوْمَ جُمُعَۃٍ، فَقَالَ لَہُ: صَلَّیْتَ؟ قَالَ: لاَ، قَالَ: صَلِّ رَکْعَتَیْنِ تَجَوَّزْ فِیہِمَا۔",,,37638
37639,"حَدَّثَنَا وَکِیعٌ ، عَنْ عِمْرَانَ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ : إِذَا جِئْتَ یَوْمَ الْجُمُعَۃِ وَالإِمَامُ یَخْطُبُ ، فَإِنْ شِئْتَ صَلَّیْتَ رَکْعَتَیْنِ ، وَإِنْ شِئْتَ جَلَسْتَ۔",,,37639
37640,"حَدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَانَ الْحَسَنُ یَجِیئُ وَالإِمَامُ یَخْطُبُ فَیُصَلِّی رَکْعَتَیْنِ۔",,,37640
37641,"حَدَّثَنَا ہُشَیْمٌ ، أَخْبَرَنَا مَنْصُورٌ ، وَأَبُو حُرَّۃَ ، وَیُونُسُ ، عَنِ الْحَسَنِ ، قَالَ : جَائَ سُلَیْکٌ الْغَطَفَانِیُّ ، وَالنَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَخْطُبُ یَوْمَ الْجُمُعَۃِ ، وَلَمْ یَکُنْ صَلَّی الرَّکْعَتَیْنِ ، فَأَمَرَہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یُصَلِّیَ رَکْعَتَیْنِ یَتَجَوَّزُ فِیہِمَا۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ یُصَلِّیَ۔",,,37641
37642,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ زَیْنَبَ ابْنَۃِ أُمِّ سَلَمَۃَ ، عَنْ أُمِّ سَلَمَۃَ ، قَالَتْ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنَّکُمْ تَخْتَصِمُونَ إِلَیَّ ، وَلَعَلَّ بَعْضَکُمْ أَنْ یَکُونَ أَلْحَنَ بِحُجَّتِہِ مِنْ بَعْضٍ، وَإِنَّمَا أَقْضِی بَیْنَکُمْ عَلَی نَحْوٍ مِمَّا أَسْمَعُ مِنْکُمْ ، فَمَنْ قَضَیْتُ لَہُ مِنْ حَقِّ أَخِیہِ شَیْئًا فَلاَ یَأْخُذْہُ ، فَإِنَّمَا أَقْطَعُ لَہُ قِطْعَۃً مِنْ نَارٍ ، یَأْتِی بِہَا یَوْمَ الْقِیَامَۃِ۔",,,37642
37643,"حَدَّثَنَا وَکِیعٌ ، عَنْ أُسَامَۃَ بْنِ زَیْدٍ ، عَنْ عَبْدِ اللہِ بْنِ رَافِعٍ ، عَنْ أُمِّ سَلَمَۃَ ، قَالَتْ : جَائَ رَجُلاَنِ مِنَ الأَنْصَارِ یَخْتَصِمَانِ إِلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی مَوَارِیثَ بَیْنَہُمَا قَدْ دَرَسَتْ ، لَیْسَتْ بَیْنَہُمَا بَیِّنَۃٌ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنَّکُمْ تَخْتَصِمُونَ إِلَیَّ ، وَإِنَّمَا أَنَا بَشَرٌ ، وَلَعَلَّ بَعْضَکُمْ أَنْ یَکُونَ أَلْحَنَ بِحُجَّتِہِ مِنْ بَعْضٍ ، وَإِنَّمَا أَقْضِی بَیْنَکُمْ ، فَمَنْ قَضَیْتُ لَہُ مِنْ حَقِّ أَخِیہِ شَیْئًا فَلاَ یَأْخُذْہُ ، فَإِنَّمَا أَقْطَعُ لَہُ قِطْعَۃً مِنَ النَّارِ ، یَأْتِی بِہِا یَوْمِ الْقِیَامَۃِ ، قَالَتْ : فَبَکَی الرَّجُلاَنِ ، وَقَالَ کُلُّ وَاحِدٍ مِنْہُمَا : حَقِّی لأَخِی یَا رَسُولَ اللہِ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَمَا إِذْ فَعَلْتُمَا ، فَاذْہَبَا فَاقْتَسِمَا ، وَتَوَخَّیَا الْحَقَّ ، ثُمَّ اسْتَہمَا ، ثُمَّ لِیُحَلِّلْ کُلّ وَاحِدٍ مِنْکُمَا صَاحِبَہُ۔",,,37643
37644,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ الْعَبْدِیُّ ، حَدَّثَنَا مُحَمَّدُ بْنُ عَمْرٍو ، حَدَّثَنَا أَبُو سَلَمَۃَ ، عَنْ أبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنَّمَا أَنَا بَشَرٌ ، وَلَعَلَّ بَعْضَکُمْ أَنْ یَکُونَ أَلْحَنَ بِحُجَّتِہِ مِنْ بَعْضٍ ، فَمَنْ قَضَیْتُ لَہُ مِنْ حَقِّ أَخِیہِ ، فَإِنَّمَا أَقْطَعُ لَہُ قِطْعَۃً مِنَ النَّارِ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لَوْ أَنَّ شَاہِدَیْ زَورٍ شَہِدَا عِنْدَ الْقَاضِی عَلَی رَجُلٍ بِطَلاَقِ امْرَأَتِہِ ، فَفَرَّقَ الْقَاضِی بَیْنَہُمَا بِشَہَادَتِہِمَا ، أَنَّہُ لاَ بَأْسَ أَنْ یَتَزَوَّجَہَا أَحَدُہُمَا۔",,,37644
37645,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ أَیُّوبَ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ بَدَّلَ دِینَہُ فَاقْتُلُوہُ۔",,,37645
37646,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، وَأَبُو مُعَاوِیَۃَ ، وَوَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ عَبْدِ اللہِ بْنِ مُرَّۃَ ، عَنْ مَسْرُوقٍ ، عَنْ عَبْدِ اللہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَحِلُّ دَمُ امْرِئٍ مُسْلِمٍ یَشْہَدُ أَنْ لاَ إِلَہَ إلاَّ اللَّہُ، وَأَنِّی رَسُولُ اللہِ إِلاَّ بِإِحْدَی ثَلاَثٍ : الثَّیِّبُ الزَّانِی ، وَالنَّفْسُ بِالنَّفْسِ ، وَالتَّارِکُ لِدِینِہِ الْمُفَارِقُ لِلْجَمَاعَۃِ۔",,,37646
37647,"حَدَّثَنَا عَبْدُاللہِ بْنُ إِدْرِیسَ، عَنْ ہِشَامٍ، عَنِ الْحَسَنِ، قَالَ فِی الْمُرْتَدَّۃِ: تُسْتَتَابُ، فَإِنْ تَابَتْ، وَإِلاَّ قُتِلَتْ۔",,,37647
37648,"حَدَّثَنَا حَفْصٌ ، عَنْ عُبَیْدَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : تُقْتَلُ۔",,,37648
37649,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حَمَّادٍ ، قَالَ : تُقْتَلُ۔\n\n- وَذَکَروا أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ تُقْتَلُ إِذَا ارْتَدَتْ۔",,,37649
37650,"حَدَّثَنَا ہُشَیْمٌ ، أَخْبَرَنَا یُونُسُ ، عَنِ الْحَسَنِ ، عَنْ أَبِی بَکْرَۃَ ، قَالَ : انْکَسَفَتِ الشَّمْسُ ، أَوِ الْقَمَرُ عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : إِنَّ الشَّمْسَ وَالْقَمَرَ آیَتَانِ مِنْ آیَاتِ اللہِ ، لاَ یَنْکَسِفَانِ لِمَوْتِ أَحَدٍ مِنَ النَّاسِ ، فَإِذَا کَانَ ذَلِکَ فَصَلُّوا حَتَّی تَنْجَلِیَ۔",,,37650
37651,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ، عَنْ یَزِیدَ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی، قَالَ: حدَّثَنِی فُلاَنُ بْنُ فُلاَنٍ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، قَالَ: إِنَّ کُسُوفَ الشَّمْسِ آیَۃٌ مِنْ آیَاتِ اللہِ، فَإِذَا رَأَیْتُمْ ذَلِکَ فَافْزَعُوا إِلَی الصَّلاَۃِ۔",,,37651
37652,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ قَتَادَۃَ ، عَنْ عَطَائٍ ، عَنْ عُبَیْدِ بْنِ عُمَیْرٍ ، عَنْ عَائِشَۃَ ، قَالَتْ : صَلاَۃُ الآیَاتِ سِتُّ رَکَعَاتٍ فِی أَرْبَعِ سَجَدَاتٍ۔",,,37652
37653,حَدَّثَنَا جَرِیرٌ، عَنِ الأَعْمَشِ، عَنْ إِبْرَاہِیمَ، عَن عَلْقَمَۃَ؛ إِذَا فَزِعْتُم مِنْ أُفُقٍ مِنْ آفَاقِ السَّمَائِ، فَافْزَعُوا إِلَی الصَّلاَۃِ۔,,,37653
37654,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَاصِمِ بْنِ أَبِی النَّجُودِ ، عَنْ أَبِی قِلاَبَۃَ ، عَنِ النُّعْمَانِ بْنِ بَشِیرٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی فِی کُسُوفٍ نَحْوًا مِنْ صَلاَتِکُمْ ، یَرْکَعُ وَیَسْجُدُ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ یُصَلَّی فِی کُسُوفِ الْقَمَرِ۔",,,37654
37655,"حَدَّثَنَا ہُشَیْمٌ ، أَخْبَرَنَا أَبُو الزُّبَیْرِ ، عَنْ نَافِعِ بْنِ جُبَیْرٍ ، عَنْ أَبِی عُبَیْدَۃَ ، عَنْ عَبْدِ اللہِ ، قَالَ : شَغَلَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْمُشْرِکُونَ یَوْمَ الْخَنْدَقِ عَنْ أَرْبَعِ صَلَوَاتٍ ، قَالَ : فَأَمَرَ بِلاَلاً ، فَأَذَّنَ وَأَقَامَ فَصَلَّی الظُّہْرَ ، ثُمَّ أَقَامَ فَصَلَّی الْعَصْرَ ، ثُمَّ أَقَامَ فَصَلَّی الْمَغْرِبَ ، ثُمَّ أَقَامَ فَصَلَّی الْعِشَائَ۔",,,37655
37656,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، أَخْبَرَنَا ابْنُ أَبِی ذِئْبٍ ، عَنِ الْمَقْبُرِیِّ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی سَعِیدٍ الْخُدْرِیِّ ، عَنْ أَبِیہِ ، قَالَ : حُبِسْنَا یَوْمَ الْخَنْدَقِ عَنِ الظُّہْرِ ، وَالْعَصْرِ ، وَالْمَغْرِبِ ، وَالْعِشَائِ ، حَتَّی کُفِینَا ذَلِکَ ، وَذَلِکَ قَوْلُ اللہِ تَبَارَکَ وَتَعَالَی : {وَکَفَی اللَّہُ الْمُؤْمِنِینَ الْقِتَالَ وَکَانَ اللَّہُ قَوِیًّا عَزِیزًا} ، فَقَامَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَأَمَرَ بِلاَلاً فَأَقَامَ ، فَصَلَّی الظُّہْرَ کَمَا کَانَ یُصَلِّیہَا قَبْلَ ذَلِکَ ، ثُمَّ أَقَامَ ، فَصَلَّی الْعَصْرَ کَمَا کَانَ یُصَلِّیہَا قَبْلَ ذَلِکَ ، ثُمَّ أَقَامَ الْمَغْرِبَ ، فَصَلاَہَا کَمَا کَانَ یُصَلِّیہَا قَبْلَ ذَلِکَ ، ثُمَّ أَقَامَ الْعِشَائَ ، فَصَلاَہَا کَمَا کَانَ یُصَلِّیہَا قَبْلَ ذَلِکَ ، وَذَلِکَ قَبْلَ أَنْ یَنْزِلَ : {فَإِنْ خِفْتُمْ فَرِجَالاً ، أَوْ رُکْبَانًا}۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : إِذَا فَاتَتْہُ الصَّلَوَاتُ لَمْ یُؤَذِّن فِی شَیئٍ مِنْہَا ، وَلَمْ یُقِم۔",,,37656
37657,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ، عَنِ الزُّہْرِیِّ، سَمِعَ مَالِکَ بْنَ أَوْسِ بْنِ الْحَدَثَانِ، یَقُولُ: سَمِعْتُ عُمَرَ ، یَقُولُ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْبُرُّ بِالْبُرِّ رِبًا ، إِلاَّ ہَائَ وَہَائَ ، وَالشَّعِیرُ بِالشَّعِیرِ رِبًا ، إِلاَّ ہَائَ وَہَائَ۔",,,37657
37658,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ خَالِدٍ ، عَنْ أَبِی قِلاَبَۃَ ، عَنْ أَبِی الأَشْعَثِ ، عَنْ عُبَادَۃَ بْنِ الصَّامِتِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الشَّعِیرُ بِالشَّعِیرِ ، مِثْلاً بِمِثْلٍ ، یَدًا بِیَدٍ۔",,,37658
37659,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا إِسْمَاعِیلُ بْنُ مُسْلِمٍ الْعَبْدِیُّ ، حَدَّثَنَا أَبُو الْمُتَوَکِّلِ النَّاجِی ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: الْبُرُّ بِالْبُرِّ، وَالشَّعِیرُ بِالشَّعِیرِ، مِثْلاً بِمِثْلٍ، یَدًا بِیَدٍ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃ کَاَن یَقُولَ : لاَ بَأْسَ بِبیعِ الْحِنطَۃِ الغَائِبَۃِ بِعَینِہا بِالْحِنطَۃِ الْحَاضِرَۃِ۔",,,37659
37660,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ مُجَالِدٍ ، عَنْ عَامِرٍ ، عَنْ حَبَشِیِّ بْنِ جُنَادَۃَ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، یَقُولُ : الصَّدَقَۃُ لاَ تَحِلُّ لِغَنِیٍّ ، وَلاَ لِذِی مِرَّۃٍ سَوِیٍّ۔",,,37660
37661,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ أَبِی حَصِینٍ ، عَنْ سَالِمٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تَحِلُّ الصَّدَقَۃُ لِغَنِیٍّ ، وَلاَ لِذِی مِرَّۃٍ سَوِیٍّ۔",,,37661
37662,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سَعْدِ بْنِ إِبْرَاہِیمَ ، عَن رَیْحَانَ بْنِ یَزِیدَ ، عَنْ عَبْدِ اللہِ بْنِ عَمْروَ ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تَحِلُّ الصَّدَقَۃُ لِغَنِیٍّ ، وَلاَ لِذِی مِرَّۃٍ سَوِیٍّ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃ رَخَّصَ فِی الصَّدَقَۃِ عَلَیْہِ ، وَقَالَ : جَائِزَۃٌ۔",,,37662
37663,"حَدَّثَنَا یَحْیَی بْنُ زَکَرِیَّا بْنُ أَبِی زَائِدَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، عَنْ جَابِرٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ لَہُ : قدْ أَخَذْتُ جَمَلَکَ بِأَرْبَعَۃِ دَنَانِیرَ ، وَلَک ظَہْرُہُ إِلَی الْمَدِینَۃِ۔ (مسلم 1224۔ احمد 397)",,,37663
37664,"حَدَّثَنَا یَحْیَی بْنُ زَکَرِیَّا ، عَنْ زَکَرِیَّا ، عَنِ الشَّعْبِیِّ ، عَنْ جَابِرٍ ، قَالَ : بَعَثَہُ مِنْہُ بِأُوقِیَّۃٍ ، وَاسْتَثْنَیْتُ حُمْلاَنَہُ إِلَی أَہْلِی ، فَلَمَّا بَلَغْتُ الْمَدِینَۃَ أَتَیْتہُ ، فَنَقَدَنِی ، وَقَالَ : أَتُرَانِی إِنَّمَا مَاکَسْتُکَ لآخُذَ جَمَلَک وَمَالَک؟ فَہُمَا لَک۔\n\n- وَذَکَرُوا أَنَّ أَبَا حَنِیفَۃ کَانَ لاَ یَرَاہُ۔",,,37664
37665,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ أَبِی بَکْرِ بْنِ مُحَمَّدِ بْنِ عَمْرِو بْنِ حَزْمٍ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، عَنْ أَبِی بَکْرِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ الْحَارِثِ بْنِ ہِشَامٍ ، عَنْ أَبِی ہُرَیْرَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : مَنْ وَجَدَ مَتَاعَہُ عِنْدَ رَجُلٍ قَدْ أَفْلَسَ ، فَہُوَ أَحَقُّ بِہِ۔\n\n- وَذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : ہُوَ أُسْوَۃُ الْغُرَمَائِ۔",,,37665
37666,حَدَّثَنَا أَبُو أُسَامَۃَ ، حَدَّثَنَا عُبَیْدُ اللہِ بْنُ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَامَلَ أَہْلَ خَیْبَرَ بِشَطْرِ مَا خَرَجَ مِنْ زَرْعٍ ، أَوْ ثَمَرٍ۔ (مسلم 1186),,,37666
37667,حَدَّثَنَا ابْنُ أَبِی زَائِدَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَامَلَ أَہْلَ خَیْبَرَ بِالشَّطْرِ۔,,,37667
37668,"حَدَّثَنَا إِسْمَاعِیلُ بْنِ عُلِّیَۃ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ إِسْحَاقَ ، عَنْ أَبِی عُبَیْدَۃَ بْنِ مُحَمَّدِ بْنِ عَمَّارٍ ، عَنِ الْوَلِیدِ بْنِ أَبِی الْوَلِیدِ ، عَنْ عُرْوَۃَ بْنِ الزُّبَیْرِ ، قَالَ : قَالَ زَیْدُ بْنُ ثَابِتٍ : یَغْفِرُ اللَّہُ لِرَافِعِ بْنِ خَدِیجٍ ، إِنَّمَا أَتَاہُ رَجُلاَنِ قَدَ اقْتَتَلاَ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنْ کَانَ ہَذَا شَأْنُکُمْ فَلاَ تُکْرُوا الْمَزَارِعَ۔",,,37668
37669,"حَدَّثَنَا شَرِیکٌ ، عَنْ إِبْرَاہِیمَ بْنِ الْمُہَاجِرِ ، عَنْ مُوسَی بْنِ طَلْحَۃَ ، قَالَ : کِلاَ جَارَیَّ قَدْ رَأَیْتُہُ یُعْطِی أَرْضَہُ بِالثُّلُثِ وَالرُّبُعِ : عَبْدَ اللہِ ، وَسَعْدًا۔",,,37669
37670,"حَدَّثَنَا فُضَیْلُ بْنُ عِیَاضٍ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ : قدِمَ عَلَیْنَا مُعَاذٌ وَنَحْنُ نُعْطِی أَرْضَنَا بِالثُّلُثِ وَالنِّصْفِ ، فَلَمْ یَعِبْ ذَلِکَ عَلَیْنَا۔",,,37670
37671,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الْحَارِثِ بْنِ حَصِیرَۃَ الأَزْدِیِّ ، عَنْ صَخْرِ بْنِ وَلِیَدٍ ، عَنْ عَمْرِو بْنِ صُلَیْعٍ ، عَنْ عَلِیٍّ ، قَالَ : لاَ بَأْسَ بِالْمُزَارَعَۃِ بِالنِّصْفِ۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ کَانَ یَکْرَہُ ذَلِک۔",,,37671
37672,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ أَبِی الزُّبَیْرِ ، سَمِعَ جَابِرًا ، یَقُولُ عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَبِیعَنَّ حَاضِرٌ لِبَادٍ۔",,,37672
37673,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا ابْنُ أَبِی لَیْلَی ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَبِیعَنَّ حَاضِرٌ لِبَادٍ۔",,,37673
37674,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا سُفْیَانُ ، عَنْ صَالِحٍ مَوْلَی التَّوْأَمَۃِ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لاَ یَبِیعَنَّ حَاضِرٌ لِبَادٍ۔ (احمد 481)",,,37674
37675,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لاَ یَبِیعَنَّ حَاضِرٌ لِبَادٍ۔ (بخاری 2723۔ مسلم 1033)",,,37675
37676,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا سُفْیَانُ ، عَنْ یُونُسَ بْنِ عُبَیْدٍ ، عَنِ ابْنِ سِیرِینَ ، عَنْ أَنَسٍ ، قَالَ : نُہِینَا أَنْ یَبِیعَ حَاضِرٌ لِبَادٍ ، وَإِنْ کَانَ أَخَاہُ لأَبِیہِ وَأُمِّہِ۔",,,37676
37677,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ مُسْلِمٍ الْخَبَّاطِ، عَنْ أَبِی ہُرَیْرَۃَ ، وَابْنِ عُمَرَ ، قَالَ أَحَدُہُمَا: نُہِیَ ، وَقَالَ الآخَرُ: لاَ یَبِیعَنَّ حَاضِرٌ لِبَادٍ۔\n\n- وُذُکِِرَ أَنَّ أَبَا حَنِیفَۃَ رَخَّصَ فِیہِ۔",,,37677
37678,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ مُحَمَّدِ بْنِ زِیَادٍ ، عَنْ أَبِی ہُرَیْرَۃَ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَأَی الْحَسَنَ بْنَ عَلِیٍّ أَخَذَ تَمْرَۃً مِنَ الصَّدَقَۃِ ، فَلاَکَہَا فِی فِیہِ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : کَخْ کَخْ ، إِنَّا لاَ تَحِلُّ لَنَا الصَّدَقَۃُ۔",,,37678
37679,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنِ ابْنِ أَبِی رَافِعٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَعَثَ رَجُلاً مِنْ بَنِی مَخْزُومٍ عَلَی الصَّدَقَۃِ ، فَأَرَادَ أَبُو رَافِعٍ أَنْ یَتْبَعَہُ ، فَسَأَلَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : أَمَا عَلِمْتَ أَنَّا لاَ تَحِلُّ لَنَا الصَّدَقَۃُ ، وَأَنَّ مَوْلَی الْقَوْمِ مِنْ أَنْفُسِہِمْ ؟۔",,,37679
37680,"حَدَّثَنَا الْحَسَنُ بْنُ مُوسَی ، حَدَّثَنَا زُہَیْرٌ ، عَنْ عَبْدِ اللہِ بْنِ عِیسَی ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، عَنْ أَبِی لَیْلَی ، قَالَ : کُنْتُ عِنْدَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقَامَ ، فَدَخَلَ بَیْتَ الصَّدَقَۃِ ، فَدَخَلَ مَعَہُ الْغُلاَمُ ، یَعْنِی حَسَنًا ، أَوْ حُسَیْنًا ، فَأَخَذَ تَمْرَۃً فَجَعَلَہَا فِی فِیہِ ، فَاسْتَخْرَجَہَا النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَقَالَ : إِنَّ الصَّدَقَۃَ لاَ تَحِلُّ لَنَا۔",,,37680
37681,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، حَدَّثَنَا مُعَرِّفٌ ، حَدَّثَتْنِی حَفْصَۃُ ابْنَۃُ طَلْقٍ ، امْرَأَۃٌ مِنَ الْحَیِّ سَنَۃَ تِسْعِینَ ، عَنْ جَدِّی أَبِی عَمِیرَۃَ رُشَیْدِ بْنِ مَالِکٍ ، قَالَ : کُنْتُ عِنْدَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ جَالِسًا ذَاتَ یَوْمٍ ، فَجَائَ رَجُلٌ بِطَبَقٍ عَلَیْہِ تَمْرٌ ، فَقَالَ : مَا ہَذَا ، صَدَقَۃٌ أَمْ ہَدِیَّۃٌ ؟ فَقَالَ الرَّجُلُ : بَلْ صَدَقَۃٌ ، فَقَدَّمَہَا إِلَی الْقَوْمِ، وَالْحَسَنُ مُتَعَفِّرٌ بَیْنَ یَدَیْہِ ، فَأَخَذَ تَمْرَۃً فَجَعَلَہَا فِی فِیہِ ، فَنَظَرَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إِلَیْہِ ، فَأَدْخَلَ إِصْبَعَہُ فِی فِیہِ ، ثُمَّ قَالَ بِہَا ، ثُمَّ قَالَ : إِنَّا آَلُ مُحَمَّدٍ لاَ نَأْکُلُ الصَّدَقَۃَ۔",,,37681
37682,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُحَمَّدِ بْنِ شَرِیکٍ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ؛ أَنَّ خَالِدَ بْنَ سَعِیدِ بْنِ الْعَاصِ بَعَثَ إِلَی عَائِشَۃَ بِبَقَرَۃٍ ، فَرَدَّتْہَا ، وَقَالَتْ : إِنَّا آلُ مُحَمَّدٍ لاَ نَأْکُلُ الصَّدَقَۃَ۔",,,37682
37683,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ حُسَیْنِ بْنِ وَاقِدٍ ، قَالَ : حدَّثَنِی عَبْدُ اللہِ بْنُ بُرَیْدَۃَ ، عَنْ أَبِیہِ ؛ أَنَّ سَلْمَانَ لَمَّا قَدِمَ الْمَدِینَۃَ أَتَی رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِہَدِیَّۃٍ عَلَی طَبَقٍ ، فَوَضَعَہَا بَیْنَ یَدَیْہِ ، فَقَالَ : مَا ہَذَا؟ فَذَکَرَہُ بِطُولِہِ۔",,,37683
37684,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَجَدَ تَمْرَۃً ، فَقَالَ : لَوْلاَ أَنْ تَکُونِی مِنَ الصَّدَقَۃِ لأَکَلْتُکِ۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : الصَّدَقَۃُ تَحِلُّ لِمَوَالِی بَنِی ہَاشِمٍ وَغَیْرِہِم۔ (مسلم 752۔ ابوداؤد 1649)",,,37684
37685,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ، عَنْ زَیْدِ بْنِ أَسْلَمَ، عَنِ ابْنِ عُمَرَ، قَالَ: دَخَلَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَسْجِدَ بَنِی عَمْرِو بْنِ عَوْفٍ یُصَلِّی فِیہِ، وَدَخَلَتْ عَلَیْہِ رِجَالٌ مِنَ الأَنْصَارِ، وَدَخَلَ مَعَہُمْ صُہَیْبٌ، فَسَأَلْتُ صُہَیْبًا: کَیْفَ کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَصْنَعُ حَیْثُ کَانَ یُسَلَّمُ عَلَیْہِ، قَالَ: کَانَ یُشِیرُ بِیَدِہِ۔\n\n- وذُکِرَ أَنَّ أَبَا حَنِیفَۃَ قَالَ : لاَ یَفْعَلُ۔",,,37685
37686,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عَمْرِو بْنِ یَحْیَی بْنِ عُمَارَۃَ ، عَنْ أَبِیہِ ، عَنْ أَبِی سَعِیدٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَیْسَ فِی أَقَلَّ مِنْ خَمْسَۃِ أَوْسَاقٍ صَدَقَۃٌ۔",,,37686
37687,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حَدَّثَنِی الْوَلِیدُ بْنُ کَثِیرٍ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ أَبِی صَعْصَعَۃَ ، عَنْ یَحْیَی بْنِ عُمَارَۃَ ، وَعَبَّادِ بْنِ تَمِیمٍ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ، أَنَّہُ سَمِعَ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، یَقُولُ : لاَ صَدَقَۃَ فِیمَا دُونَ خَمْسَۃِ أَوْسَاقٍ مِنَ التَّمْرِ۔ (ابن ماجہ 1793۔ بیہقی 134)",,,37687
37688,"حَدَّثَنَا عَلِیُّ بْنُ إِسْحَاقَ ، عَنِ ابْنِ مُبَارَکٍ ، عَنْ مَعْمَرٍ ، قَالَ : حدَّثَنِی سُہَیْلٌ ، عَنْ أَبِیہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لَیْسَ فِیمَا دُونَ خَمْسَۃِ أَوْسَاقٍ صَدَقَۃٌ۔\n\n- وذُکِرَ أَنَّ أبَا حَنِیفَۃَ قَالَ : فِی قلِیلِ مَا یَخْرُجُ وَکَثِیرِہِ صَدَقَۃٌ۔ (احمد 402۔ عبدالرزاق 7249)",,,37688
