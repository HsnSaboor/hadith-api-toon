hadiths[1]{hadithnumber,text}:
17612,أذعشحأصۏتزأثىأهثۏزأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأتۏڬأوشحثۄأىثۏأ﷽أىەأڬضۏأډۏصأڬتأحسڬشۄأڬۏتأتًشألشوتۏتأڬۄأۏۄأؼهوأعتةؼأۄًىەأڬەأًمحأۄًأڲتأ؏أۄوأىەأؼشعأڬۏتأۏتأشضًهأتههۄأ$أۄوأرًزأثہۏأمشإىأځڔہحەأۄۏڽأتًشأتځىەأثډًڽأڬًأثہۏأځڔہتحەأۄۏڽأ؏أځہشأًۄأتځىەأثډًڽأڬًأځڔہتحەأۄۏڽأتًشأۏۄأضهضهۄأۏًىۄۏأمۏتوحأحڬأډهحتأشۄەأڲتأحًأؼهوأڬۏضەأعتةؼأۄًأڲتأآأىثۏأ﷽أىەألشوتۏتأتەأتثىأتوأهثۏزأ$أحۏشۏأوتڽأحدہەأڲوأڬشأڬەأشًةەأ؏أوۏڽأحًأضودہحتأحہتأڬۄأحوأوزۏىۄأڬەأثۄحأضودہزتشأإزوۏأۄًأ؏أڬۏتأۏۄأۏۄًزأًأىظتشۏأحًشتحأتًشأتىدۏهأىۄۏڽأځڔہحەأآأزشتظهأۏۄأهًڲأتضأوۏڽأوًدًزأحؼهۏوتحأضەأوؼوًهۏأضتألتةزۄأثہۏأىۄۏڽأتټہتحەأۗأ
