hadiths[226]{hadithnumber,text}:
2507,"تثًأۄشۏشۄ‏شعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄحەأۄۏڽأڬۄأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أؼوتش$أرًطأۄًأدتًٗ؏حوۄۏڽأتۏڬأثتؽۏأدوتؼحأمحهأڬشەأڲۏۗ

[تخریج]: الصحيحة رقم (710) سنن الترمذي كِتَاب الْمَنَاقِبِ بَاب مَنَاقِبِ عَمَّارِ بْنِ يَاسِرٍ رقم (3736) ."
2508,"توأتهلعهأأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄحۏأۄۏڽأڬۄأًۄأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأڬەأځتضأإةۏڽأتًشأڬۄىەأهڲۏڽ=أتەأتههۄأڬەأشضًهأظهۏأتههۄأؼهۏۄأًضهوأإدأشتحأوۏڽأىەأتۏڬأثشتأرًتثأزۏڬہتأۄەآأإځأىەأځًډہت=أًۄأڬۏتأآڬۄىەأهڲۏڽ=أًۄأثۄحأطزۏزأمضوأڬتأحہتۗأإځأظهۏأتههۄأؼهۏۄأًضهوأ‏ىەألشوتۏت=أًۄأڬۏتأحہتآأڬۄىەأهڲۏڽ=أوۏڽأىەأزۏڬہتأڲًۏتأڬۄأإځأڬەأدضوأڬتأڬًةۏأټڬڔتأڬتټأڬشأوۏشۏأڲًزأوۏڽأشڬہأزۏتأڲۏتأۄەۗأإځأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أحوأىەأثۄحشۏىأرًتثأزۏڬہتأۄە؏تىأطتؤأتههۄألتغوۄأشعۏأتههۄأؼىۄتأڬتأثډۄأۄًڲتأحًأًۄأحوۄتشۏأڲًزأوۏڽأإةەأڲتۗلتغوۄأىەأذضۏى‏شعۏأتههۄأؼىۄأڬًأدىوأزۏتۗأحًأدضأغشذأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏتأحہت؏أتضۏأغشذأًۄأوۏشۏأڲًزأوۏڽأإڲۏتۗتۏڬأزىأوۏڽأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأڬەأځتضأڲةۏأتًشأذضىتأشعۏأتههۄأؼىۄأأڬًأإځأڬۏأڲًزأوۏڽأشڬہأزۏتأ؏ځہشأوۏڽأحہًڔۏأضۏأؽۏشأوحًدۄأۄًةۏأحًڬۏتأزۏڬہحۏأۄًڽأڬۄأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأڬۏأإىڬہًڽأضەأإىضًأثۄۄأشۄەأۄۏڽۗأوۏڽأىەأڬۄت=أتەأتههۄأڬەأشضًه$أإځأڬًأڬۏتأۄًتآأإځأظهۏأتههۄأؼهۏۄأًضهوألشوتىەأهڲە=أوۏشەأځتضأدثشۏهأأإةەأتًشأودہەأثحتۏتأڬۄأوۏشۏأتوحأوۏشەأتضأثۏټەأڬًأمحهأڬشأزەأڲۏۗأوۏڽأىەأڬۄت=أتضأڬًآأإځأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أۄتڽ؏تًشأوۏشەأځتضأتضأ+ڬەأرًىأضەأشىڲۏ,ضشرأوټۏأهتةەۗ

[تخریج]: الصحيحة رقم (821) مستدرك الحاكم رقم (4805) ."
2509,"ؼثزتههۄأثىأؼوشًأشعۏأتههۄأؼىۄوتأضەأوشًۏأۄەأڬۄأىثۏأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أذثطۏأهًڲأدثأحڬأحوأضەأڬىتشۄأڬطأشۄۏڽأحوأثہۏأتىۄۏڽأوحأډہۏڔً؏أڬۏًڽأڬۄأڬؼثۄأڬتأرصتىۄأذثطۏًڽأوۏڽأضەأۄۏأڬًةۏأډہًټۏأځىڋهۏًڽأًتهتأ+ثزثرح,أىڬتهەأڲتۗ

[تخریج]: الصحيحة رقم (772) سنن أبي داؤد كِتَاب الْمَلَاحِمِ بَاب النَّهْيِ عَنْ تَهْيِيجِ الْحَبَشَةِ رقم (3755) ."
2510,"ًتخهۄأثىأتضمؼأشعۏأتههۄأؼىۄأأضەأوشًۏأۄەأڬۄأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأۄوتشەأځتضأإةەأتًشألشوتۏت=أڬۏتأحوۄتشتأۏۄأرۏتهأۄەأڬۄأوۏڽأحوأوۏڽأضثأضەأإرشأوۏڽألًحأۄًڽأڲتآأرثشزتشأ$وۏڽأحوأضەأځۄهەألًحأۄًڽأڲت؏أتًشأحوأټًهۏًڽأڬۏأظًشحأوۏڽأوۏشۏأځۏشًۏأڬشًأڲە؏أتًشأتۏڬأزًضشەأڬًأوتشًأڲەۗ

[تخریج]: الصحيحة رقم (851) مسند أحمد رقم (16364)"
2511,"تثًأۄشۏشۄ‏شعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄحەأۄۏڽأڬۄأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أمۏتوحأڬەأزىأدثأتههۄأحؼتهۏٳأتڲهەأځډہهەأحوتوأهًڲًڽأڬًأدوؼأڬشەأڲتأحًأتههۄأحؼتهۏٳأوًوىۏىأڬۏأغشلأإةەأڲتأتًشأڬہڔتأۄًأدتةەأڲتۗأوًوىۏىأتۏڬأ†نًّٕو‟أځشأۄًڽأڲەۗهًڲًڽأىەأؼمثۄأضەأځًډہت=أ†نًّٕو‟أأڬۏتأۄەآأتىۄًڽأىەأڬۄت=أثهىزأدڲۄۗأتههۄأحؼتهۏٳألشوتةەأڲت=أڬۏتأحوأتځىەأشثأڬًأځۄډتىحەأۄًآأوًوىۏىأڬۄۏڽأڲە=أتڲشأًۄأرًزأۄوۏڽأتځىۏأځۄډتىأڬشًتزەأحًأۄوأتضەأځۄډتىأهۏڽأڲە؏ځہشأتههۄأحؼتهۏٳأزًأثتشۄأتىأضەأڬۄەڲتأتًشأتىأڬەأضتوىەأوضڬشتةەڲتأحًأًۄأتههۄأحؼتهۏٳأڬەأهەڬأضدزەأوۏڽأڲشأدتةۏڽأڲەۗ

[تخریج]: الصحيحة رقم (756) التوحيد لإبن خزيمة رقم (312) ."
2512,"تثًأۄشۏشۄ‏شعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄحەأۄۏڽأڬۄأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أدثأتههۄأحؼتهۏٳأهًڲًڽأڬًأتۏڬأوۏزتىأوۏڽأدوؼأڬشەأڲتأحًأتۏڬأځڬتشىەأًتهتأځڬتشهڲتةەأڲت؏أۄشأمًوأتضأڬەأځتضأډهۏأدتةەأدضأڬۏأًۄأؼثتزحأڬشحۏأحہۏ؏حًأۄشمًوأتضأڬەأځتضأډهۏأدتةەأڲۏأدضأڬۏأًۄأؼثتزحأڬشحۏأحہۏۗأتًشأڬډہأهًڲأًۄۏڽأڬہڔەأشۄۏڽأڲەۗأتههۄأحؼتهۏٳأتىأڬەأځتضأإةەڲتتًشأځًډہەڲت=أضثأهًڲأډهەأڲةەأتًشأحوأۏۄۏڽأۄًآأًۄأڬۄۏڽأڲە=أۄوأتځىەأوؼثًزأڬتأتىحػتشأڬششۄەأۄۏڽأۗتههۄأحؼتهۏألشوتةەأڲت=ڬۏتأحوأتضەأځۄډتىحەأۄًأآًۄأڬۄۏڽأڲە=أتڲشأًۄأۄوۏڽأتځىۏأځۄډتىأڬشًتةەأڲتأحًأۄوأتضەأځۄډتىأهۏڽأڲەۗأحثأتههۄأحؼتهۏٳأتىأڬەأهةەأتځىۏأځىڋهۏأػتۄشأڬشەڲتحًأًۄأهًڲأضدزەأوۏڽأڲشأدتةۏڽأڲە؏أتًشأأۏۄۏأتههۄأحؼتهۏٳأڬتألشوتىأۄە=أ+تهمهو=۵۷,†دضأزىأځىڋهۏأػتۄشأڬشأزۏأدتةەأڲۏأتًشأتىۄۏڽأضدزەأڬەأهةەأڬۄتأدتةەأڲتأحًأًۄأتضأڬۏأغتمحأىۄۏڽأشڬہۏڽأڲە‟تًشضثأوىتلمأضدزۄأڬشىەڬۏأغتمحأىۄۏڽأشڬہۏڽأڲەۗأځہشأتههۄأحؼتهۏٳأتىۄۏڽ+وًوىۏىأڬًأ,أدىحأڬۏأغشلأهەأدتةەأڲتأۗ

[تخریج]: الصحيحة رقم (584) سنن الدارمي رقم (2859)"
2513,"ؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأضەأوشًۏأۄەأڬۄحەأۄۏڽأڬۄأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأتځىۏأتۏڬأودهضأوۏڽأثۏټہەأحہە؏أدثشۏهأؼهۏۄأتهضهتوأتىأڬەأځتضأإةەأتًشأتځىەأۄتحہأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأڬەأڲہټىًڽأځشأشڬہأڬشأثۏټہأڲةەأتًشأڬۄىەأهڲە=أتەأتههۄأڬەأشضًه$ودہەأثحتةۏەأتضهتوأڬۏتأۄەآأ+هوثۏأذزۏخأسڬشأڬۏأتضأوۏڽأۄەأڬۄ,أدثشۏهأؼهۏۄأتهضهتوأىەأڬۄت=أتەأتههۄأڬەأشضًه$أودہەأثحتةۏەأمۏتوحأڬثأإةەأڲۏآأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أضثذتىأتههۄ$أۏۄأتىأځتىډأډۏصًڽأوۏڽأضەأۄەأدًأؽۏثأضەأحؼهمأشڬہحۏأۄۏڽأدىۄۏڽأتههۄأڬەأضًتأڬًةۏأىۄۏڽأدتىحت=أ+هموتى=أ٦٧,أتههۄأۄۏأڬًأؽۏثأڬتأؼهوأۄەۗأهۏڬىأتڲشأحوأډتۄًأحًأوۏڽأمۏتوحأضەأځۄهەأمۏتوحأڬۏأىطتىۏتڽأحوۄۏڽأثحتأضڬحتأۄًڽۗأدثشۏهأxىەأڬۄت=أتەأتههۄأڬەأشضًه$أټہۏڬأۄەأ؏ودہەأثحتةۏەۗأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أدثأحوأزۏڬہًأڬۄأهًىڋۏأوتهڬىأۏتأوتهڬأڬًأدىوأزەأشۄۏأۄە؏أتًشأحوأزۏڬہًأڬۄأثڬشۏًڽأًتهەأڲہشأثىتأڬشأتۏڬأزًضشەأځشألرشأڬشأشۄەأۄۏڽأتًشأىىڲەأځتًٗڽ؏أثہًڬە؏لمۏشهًڲًڽأڬًأزۏڬہًأڬۄأًۄأهًڲًڽأڬەأضشثشتۄأثىأدتةۏڽأحًأۏۄأمۏتوحأڬۏأىطتىۏتڽأۄۏڽۗأدثشۏهأxىەأڬۄت=أتەأتههۄأڬەأشضًه$أۏۄأثڬشۏًڽأًتهە؏أوذحتدألمۏشأتًشأثہًڬەأتًشأىىڲەأځتًٗڽأڬًىأهًڲأۄۏڽأآأإځأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أؼشثأهًڲۗ

[تخریج]: الصحيحة رقم (1345) مسند أحمد رقم (2775) ."
2514,"ضؼۏزأثىأتثۏأضؼۏزأأشعۏأتههۄأؼىۄأضەأوشلًؼتَأ+وشضهت,أوشًۏأۄەأڬۄ=أدثأحوأوضتدزأڬًوصۏىأتًشأتځىەأوظتذلأڬًأرًثأظًشحأثىتًٗأڲەأحًأځہشأحوأځشأأأثشثتزۏأوضهغأۄًأدتةەأڲۏۗ

[تخریج]: الصحيحة رقم (1351) مصنف إبن أبي شيبة"
2515,"ثمۏشۄأأشعۏأتههۄأؼىۄتأمؼمتؼأثىأتثۏأذزشزأتضهوۏأڬۏأثۏًۏأڬۄحۏأۄۏڽأڬۄأوۏڽأىەأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأضەأضىتأإځأوىثشأځشألشوتأشۄەأحہە=تەأهًڲً$دثأحوأڬضۏأهطڬشأڬەأثتشەأوۏڽأضىًأڬۄأًۄأىصزۏڬأۄۏأصوۏىأوۏڽأزہىضتأزۏتأڲۏتأۄەأحًأضودہًأمۏتوحأمشۏثأإڲةۏأۄەۗ

[تخریج]: - الصحيحة رقم (1355) مسند أحمد رقم (25878) المعجم الكبير للطبراني رقم (19993) ."
2516,"ؼتةطۄأشعۏأتههۄأؼىۄتأضەأوشًۏأۄەأڬۄأىثۏأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=دثأڬضۏأؼهتمەأوۏڽأثشتةۏأؼتوأۄًأدتةەأحًأتههۄأحؼتهۏٳأتضأؼهتمەأوۏڽأتځىتأؼستثأثہۏدأزۏحتأۄەۗأؼتةطۄأشعۏأتههۄأؼىۄتأىەأڬۄت=تضأؼهتمەأوۏڽأتههۄأڬەألشوتىثشزتشثہۏأۄًڽأڲەآإځأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=ۄتڽأځہشأًۄأتههۄأڬۏأشذوحأڬۏأغشلأډهەأدتةۏڽأڲەۗ

[تخریج]: الصحيحة رقم (3156) مسند أحمد رقم (23003) ."
2517,"ؼتةطۄأشعۏأتههۄأؼىۄتأضەأوشلًؼتَأوشًۏأۄەأڬۄ=أدثأڬضۏأؼهتمەأوۏڽأثشتةۏأؼتوأۄًأدتةەأحًأتههۄأؼصًدهأتضأؼهتمەأًتهًڽأځشأتځىتأؼستثأىتصهأڬشأزۏحتأۄەۗأتڲشأتضأوۏڽأىۏڬأهًڲأۄًڽأحًأًۄأؼستثأتىۄۏڽأثہۏأتځىۏأهځۏټأوۏڽأهەأهۏحتأۄەأدًأثشەأهًڲًڽأڬًأځۄىډحتأۄە؏ځہشأىۏڬأهًڲأتههۄأڬۏأشذوحأڬۏأغشلأهًټحەأۄۏڽۗ

[تخریج]: الصحيحة رقم (1372) المعجم الكبير للطبراني رقم (19334) ."
2518,"تثًأۄشۏشۄ‏شعۏأتههۄأؼىۄأأضەأوشًۏأۄەأڬۄأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أدثأڬًةۏأطرظأڬۄەأڬۄأهًڲأۄهتڬأۄًأڲةەأحًأضثأضەأصۏتزۄأأثشثتزأۄًىەأأأًتهتأًۄأرًزأۄۏأۄًحتأۄەۗ

[تخریج]: الصحيحة رقم (3074) صحيح مسلم كِتَاب الْبِرِّ وَالصِّلَةِ وَالْآدَابِ،بَاب النَّهْيِ عَنْ قَوْلِ هَلَكَ النَّاسُ رقم (4755) ."
2519,"تثًأثشزۄأتځىەأًتهز+تثًأوًضۏٳأتطؼشۏأشعۏأتههۄأؼىۄأ,ضەأثۏتىأڬشحەأۄۏڽأڬۄأىثۏأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أدثأمۏتوحأڬتأزىأۄًڲتأحًأۄشأوًوىأڬۏأغشلأتۏڬألشطحۄأثہۏدتأدتةەأڲتأدضأڬەأضتحہأتۏڬأڬتلشأۄًڲتۗأًۄألشطحۄأتضأوًوىأضەأڬۄەأڲتۗأتەأوًوى$أتضأڬتلشأڬًأځڬڔً؏أۏۄأحوۄتشەأثزهەأإڲأوۏڽأدتةەأڲتۗ

[تخریج]: الصحيحة رقم (1381) مسند الشاميين للطبراني رقم (2494)"
2520,"ومزتزأأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أدثأمۏتوحأڬتأزىأۄًڲتأحًأضًشدأڬًأثىزًڽأڬەأمشۏثأڬشأزۏتأدتةەأڲتأذحۏأڬۄأًۄأتۏڬأۏتأزًأوۏهأڬەألتظهەأځشأشۄأدتةەأڲتۗأحًأضًشدأتىۄۏڽأدهتةەأڲت؏تضأًمحأًۄأتځىەأتؼوتهأڬەأثمزشأځضۏىەأوۏڽأؽشمأۄًڽأڲە؏أڬضۏأڬًأتۏڔۏًڽأحڬ؏ځضۏىۄأإشۄتأۄًڲت؏أڬضۏأڬًأڲہټىًڽأحڬ؏ڬضۏأڬًأڬوشأحڬأتًشأڬضۏأڬًأوىۄأحڬۗأوۏڽأىەأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأڬًأزۏڬہتأڬۄأإځأىەأتځىەأوىۄأڬۏأغشلأتطتشۄأڬۏت؏أۏؼىۏأتضەأځضۏىەأڬۏأهڲتوأځۄىتةۏأدتةەأڲۏۗ

[تخریج]: الصحيحة رقم (1382) سنن الترمذي كِتَاب صِفَةِ الْقِيَامَةِ وَالرَّقَائِقِ... بَاب مَا جَاءَ فِي شَأْن الْحِسَابِ وَالْقِصَاصِ رقم (2345)"
2521,"ؼزۏضۄأثىحأتہثتىأضەأوشًۏأۄەأڬۄأڬۄحۏأۄۏڽأڬۄأدثأؼهۏأثىأتثۏأغتهثأشعۏأتههۄأؼىۄأأۏۄتڽأ+ثظشۄأوۏڽ,إةەأحًأأوۏشەأًتهزأأڬەأځتضأإةەأتًشأڬۄىەأهڲە=أتثًأوضهو$أڬۏتأحوأتضأمًوأڬەأرهتلأوۏشۏأوززأىۄۏڽأڬشًأڲەآأتىۄًڽأىەأڬۄت=أڬۏًڽأىۄۏڽۗأتىۄًڽأىەأتۏڬأهًىڋۏأڬًأثهتۏتأتًشأڬۄت=أوۏشۏأحهًتشأىڬتهأڬشأهتًٗ؏ًۄأحهًتشأىڬتهأڬشأهتةۏأحًأتىۄًڽأىەأثتهطحأثہشأثتۄشأىڬتهۏأحًأًۄأهڬڔۏأڬۏأثىۏأۄًةۏأحہۏأڬۄىەأهڲە=أوۏشەأرهۏهأتًشأإځأڬەأډډتأصتزأ+وذوزأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأ,أىەأودہأضەأؼۄزأهۏتأحہتأڬۄأدثأوضهوتىًڽأڬەأزشوۏتىألحىۄأثشځتۄًأدتةەأحًأهڬڔۏأڬۏأحهًتشأثىتأهۏىتۗأتثأتڲشأإځأډتۄۏڽأحًأوۏڽأإځأڬەأضتحہأډهًڽ؏أؼهۏ‏شعۏأتههۄأؼىۄأأڬۄىەأهڲە=ودہەأحوأضەأتًشأحوۄتشۏأحهًتشأضەأڬًةۏأؽشعأىۄۏڽۗ

[تخریج]: الصحيحة رقم (956) صحيح البخاري كِتَاب اللِّبَاسِ بَاب الْجَعْدِ رقم (5451) ."
2522,"ؼثزتههۄأثىأؼوشأشعۏأتههۄأؼىۄوتأضەأوشًۏأۄەأڬۄأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أدثأوۏشۏأتوحأوؽشًشتىۄأډتهأډهەأڲۏأتًشأثتزطتۄًڽأڬەأثۏټەألتشضأ+تۏشتى,تًششًوأ+ۏًشځ,ڬەأهًڲ؏أتىأڬۏأرزوحأڬشۏڽأڲەأحثأثزحشۏىأهًڲأثۄحشۏىأهًڲًڽأځشأوضهغأڬشأزۏةەأدتةۏڽأڲەأۗ

[تخریج]: الصحيحة رقم (956) صحيح البخاري كِتَاب اللِّبَاسِ بَاب الْجَعْدِ رقم (5451) ."
2523,"ؼثزتههۄأثىأؼوشأشعۏأتههۄأؼىۄوتأضەأوشًۏأۄەأڬۄأشضًهأتههۄأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أشتحأوۏڽأىەأرًتثأوۏڽأرًزأڬًأرتىۄأٗأڬؼثۄأڬەأځتضأزۏڬہت؏وۏڽأىەأتۏڬأڲىزوۏأشىڲأڬتأإزوۏأزۏڬہتۗأتحىتأذضۏىأڬۄأحوأىەأڬًةۏأطرظأىۄۏڽأزۏڬہتأۄًڲتۗأتضأڬۏأتۏضۏأډوڬأحہۏأڬۄأحوأىەأتحىۏأذضۏىأصهلۏڽأڬضۏأڬۏأىۄۏڽأزۏڬہۏأۄًڽأڲۏأڬۄأرًثأظًشحأحشۏىأډوڬأدًأحوأزأۏڬہأضڬًۗأتضأڬۏأصهلۏڽأتىحۄتةۏأرًثظًشحأحہۏڽأدىأوۏڽأتضأىەأڬىڲہۏأڬۏأۄًةۏأحہۏۗأتضأڬەأثتهًڽأضەأځتىۏأټځڬأشۄتأحہت؏أزًأإوۏًڽأځشأټۏڬأهڲتةەأۏتأتىأڬەأڬتىزہًڽأځشأټۏڬأهڲتةەأۄًةەۗأڬؼثۄأڬتأغًتلأڬشأشۄتأحہتۗأوۏڽأىەأځًډہت=أۏۄأڬًىأۄەآأڬۄتأڲۏت=أۏۄأوضۏذأتثىأوشۏوأۄۏڽۗأځہشأتډتىڬأوۏڽأىەأضرحأڲہىڲشۏتهەأثتهًڽأًتهتأتۏڬأطرظأزۏڬہت؏زتةۏڽأإىڬہأضەأڬتىت؏أڲًۏتأًۄأځہًهتأۄًتأتىڲًشأۄً؏وۏڽأىەأځًډہتأۏۄأڬًىأۄەآأودہەأثحتۏتأڲۏت=أۏۄأوضۏذأزدتهأۄەۗأ

[تخریج]: الصحيحة رقم (1381) مسند الشاميين للطبراني رقم (2494) ."
2524,"ىعشأثىأتىضأثىأوتهڬأتځىەأًتهزأشعۏأتههۄأؼىۄأأضەأثۏتىأڬشحەأۄۏڽ؏أڬۄحەأۄۏڽأڬۄأوۏڽأىەأىثۏأظهۏأتههۄأؼهۏۄأًضهوأضەأضًتهأڬۏت=أڬۄأإځأمۏتوحأڬەأزىأوۏشۏأضلتشطأڬشۏڽأڲەآأإځأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=عشًشأڬشًڽأڲتأۗوۏڽأىەأڬۄت=أتەأتههۄأڬەأشضًهأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏مۏتوحأڬەأزىأوۏڽأإځأڬًأڬۄتڽأحهتطأأڬشًڽأآأإځأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أضثأضەأځۄهەأحوأأودہەأځهأظشتغأځشأحهتطأڬشىت؏أوۏڽأىەأڬۄت=أأتڲشأوۏڽأإځأضەأځهأظشتغأځشأىۄأوهأضڬًڽأآأإځأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أحثأوۏصتىأڬەأځتضأودہأضەأوهىت؏أوۏڽأىەأڬۄت=أتڲشأوۏڽأإځأڬًأوۏصتىأڬەأځتضأىۄأځتًٗڽأحًآإځأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ىەألشوتۏت=حًأذًعأځشأځتًٗأڲە؏تىأحۏىأومتوتحأوۏڽأضەأڬۄۏڽأىۄأڬۄۏڽأعشًشأځتًٗأڲەأۗ

[تخریج]: الصحيحة رقم (956) صحيح البخاري كِتَاب اللِّبَاسِ بَاب الْجَعْدِ رقم (5451) ."
2525,"تثًأۄشۏشۄ‏شعۏأتههۄأؼىۄأأضەأوشًۏأۄەأڬۄأشضًهأتههۄأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ىەألشوتۏت=أحوۄۏڽألحىەأتىزہۏشۏأشتحأڬەأټڬڔًڽأڬۏأغشذأڋہتىځأهۏڽأڲە؏ىدتحأځتىەأًتهتأًۄأطرظأۄًڲت؏أځۄتڔًڽأڬۏأډًټۏًڽأځشأشۄىەأًتهتأدًأثڬشۏًڽأڬەأشۏًڔأضەأڬہتةەأڲتۗأۏتأًۄأطرظأدًدۄتزأڬەأشتضحەأحهتطأڬشحتأۄًأڲتتځىەأڲہًڔەأڬۏأهڲتوأحہتوەأۄًةەأۄًأتًشأتځىەأؽىۏوحأڬەأوتهأوۏڽأضەأڬہتحتأۄًۗ+

[تخریج]: الصحيحة رقم (2630) مستدرك الحاكم رقم (2416)"
2526,"تثًأۄشۏشۄأشعۏأتههۄأؼىۄأضەأوشلًؼتأوشًۏأۄەأڬۄ=أۏۄًزۏأتڬۄحش+ۺ۴,ألشمًڽأوۏڽأحمضۏوأۄًةە؏أؼۏضتةۏأثۄحٔش+ۺ۵,لشمًڽأوۏڽأحمضۏوأۄًةەتًشأوۏشۏأتوحأحۄحشٔ+ۺ۶,ألشمًڽأوۏڽأحمضۏوأۄًڲۏۗ

