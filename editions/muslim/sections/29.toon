metadata:

hadiths[142]{hadithnumber,arabic,bengali,english,french,indonesian,russian,urdu,grades,reference,international_number,narrator_chain,chapter_intro}:
{"hadithnumber": "4268", "arabic": "حَدَّثَنَا يَحْيَى بْنُ يَحْيَى، وَإِسْحَاقُ بْنُ إِبْرَاهِيمَ، وَابْنُ أَبِي عُمَرَ، - وَاللَّفْظُ لِيَحْيَى - قَالَ ابْنُ أَبِي عُمَرَ حَدَّثَنَا وَقَالَ الآخَرَانِ، أَخْبَرَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ الزُّهْرِيِّ، عَنْ عَمْرَةَ، عَنْ عَائِشَةَ، قَالَتْ كَانَ رَسُولُ اللَّهِ صلى الله عليه وسلم يَقْطَعُ السَّارِقَ فِي رُبْعِ دِينَارٍ فَصَاعِدًا.", "bengali": "", "english": "'A'isha reported that Allah's Messenger (ﷺ) cut off the hand of a thief for a quarter of a dinar rid upwards.", "french": "", "indonesian": "", "russian": "", "urdu": "مطروراق نے ہمیں حدیث بیان کی ،  کہا :  ہمیں زہدم جرمی نے حدیث بیان کی ،  انہوں نے کہا :  میں حضرت اب", "grades": "", "reference": "", "international_number": "4268", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4269", "arabic": "وَحَدَّثَنَا إِسْحَاقُ بْنُ إِبْرَاهِيمَ، وَعَبْدُ بْنُ حُمَيْدٍ، قَالاَ أَخْبَرَنَا عَبْدُ الرَّزَّاقِ، أَخْبَرَنَا مَعْمَرٌ، ح وَحَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، أَخْبَرَنَا سُلَيْمَانُ بْنُ كَثِيرٍ، وَإِبْرَاهِيمُ بْنُ سَعْدٍ كُلُّهُمْ عَنِ الزُّهْرِيِّ، ‏.‏ بِمِثْلِهِ فِي هَذَا الإِسْنَادِ ‏.‏", "bengali": "", "english": "This hadith has been transmitted on the authority of Zuhri.", "french": "", "indonesian": "", "russian": "", "urdu": "جریر نے ہمیں سلیمان تیمی سے خبر دی ،  انہوں نے ضرب بن نقیر قیسی سے ،  انہوں نے زہدم سے اور انہوں نے", "grades": "", "reference": "", "international_number": "4269", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4270", "arabic": "وَحَدَّثَنِي أَبُو الطَّاهِرِ، وَحَرْمَلَةُ بْنُ يَحْيَى، وَحَدَّثَنَا الْوَلِيدُ بْنُ شُجَاعٍ، - وَاللَّفْظُ لِلْوَلِيدِ وَحَرْمَلَةَ - قَالُوا حَدَّثَنَا ابْنُ وَهْبٍ، أَخْبَرَنِي يُونُسُ، عَنِ ابْنِ شِهَابٍ، عَنْ عُرْوَةَ، وَعَمْرَةَ، عَنْ عَائِشَةَ، عَنْ رَسُولِ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ لاَ تُقْطَعُ يَدُ السَّارِقِ إِلاَّ فِي رُبْعِ دِينَارٍ فَصَاعِدًا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "The hand of a thief should not be cut off but for a quarter of a dinar and upwards.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "'A'isha reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4271", "arabic": "وَحَدَّثَنِي أَبُو الطَّاهِرِ، وَهَارُونُ بْنُ سَعِيدٍ الأَيْلِيُّ، وَأَحْمَدُ بْنُ عِيسَى، - وَاللَّفْظُ لِهَارُونَ وَأَحْمَدَ - قَالَ أَبُو الطَّاهِرِ أَخْبَرَنَا وَقَالَ الآخَرَانِ، حَدَّثَنَا ابْنُ وَهْبٍ، أَخْبَرَنِي مَخْرَمَةُ، عَنْ أَبِيهِ، عَنْ سُلَيْمَانَ بْنِ يَسَارٍ، عَنْ عَمْرَةَ، أَنَّهَا سَمِعَتْ عَائِشَةَ، تُحَدِّثُ أَنَّهَا سَمِعَتْ رَسُولَ اللَّهِ صلى الله عليه وسلم يَقُولُ ‏ ‏ لاَ تُقْطَعُ الْيَدُ إِلاَّ فِي رُبْعِ دِينَارٍ فَمَا فَوْقَهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "I heard Allah's Messenger (ﷺ) as saying: The hand (of a thief) should not be cut off but for a quarter of a dinar and what is above that.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "'A'isha reported:", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4272", "arabic": "حَدَّثَنِي بِشْرُ بْنُ الْحَكَمِ الْعَبْدِيُّ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ، عَنْ يَزِيدَ بْنِ عَبْدِ اللَّهِ، بْنِ الْهَادِ عَنْ أَبِي بَكْرِ بْنِ مُحَمَّدٍ، عَنْ عَمْرَةَ، عَنْ عَائِشَةَ، أَنَّهَا سَمِعَتِ النَّبِيَّ صلى الله عليه وسلم يَقُولُ ‏ ‏ لاَ تُقْطَعُ يَدُ السَّارِقِ إِلاَّ فِي رُبْعِ دِينَارٍ فَصَاعِدًا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "The hand of the thief may not be cut off but for a quarter of a dinar and upwards.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "'A'isha reported that she heard Allah's Apostle (ﷺ) as saying:", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4273", "arabic": "وَحَدَّثَنَا إِسْحَاقُ بْنُ إِبْرَاهِيمَ، وَمُحَمَّدُ بْنُ الْمُثَنَّى، وَإِسْحَاقُ بْنُ مَنْصُورٍ، جَمِيعًا عَنْ أَبِي عَامِرٍ الْعَقَدِيِّ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ جَعْفَرٍ، - مِنْ وَلَدِ الْمِسْوَرِ بْنِ مَخْرَمَةَ - عَنْ يَزِيدَ بْنِ، عَبْدِ اللَّهِ بْنِ الْهَادِ بِهَذَا الإِسْنَادِ مِثْلَهُ ‏.‏", "bengali": "", "english": "A hadith like this has been narrated on the authority of Yazid b. 'Abdullah b. al-Had with the same chain of transmitters.", "french": "", "indonesian": "", "russian": "", "urdu": "عبدالعزیز بن مطلب نے سہیل بن ابی صالح سے روایت کی ،  انہوں نے اپنے والد سے اور انہوں نے حضرت ابوہریر", "grades": "", "reference": "", "international_number": "4273", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4274", "arabic": "وَحَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا حُمَيْدُ بْنُ عَبْدِ الرَّحْمَنِ الرُّؤَاسِيُّ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، قَالَتْ لَمْ تُقْطَعْ يَدُ سَارِقٍ فِي عَهْدِ رَسُولِ اللَّهِ صلى الله عليه وسلم فِي أَقَلَّ مِنْ ثَمَنِ الْمِجَنِّ حَجَفَةٍ أَوْ تُرْسٍ وَكِلاَهُمَا ذُو ثَمَنٍ ‏.‏", "bengali": "", "english": "'A'isha reported that during the lifetime of Allah's Messenger (ﷺ) the hand of the thief was not cut off for less than the price of a shield, iron coat or armour and both of them are valuable.", "french": "", "indonesian": "", "russian": "", "urdu": "سلیمان بن بلال نے مجھے سہیل سے اسی سند کے ساتھ امام مالک کی حدیث کے ہم معنی حدیث  ( ان الفاظ میں )", "grades": "", "reference": "", "international_number": "4274", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4275", "arabic": "وَحَدَّثَنَا عُثْمَانُ بْنُ أَبِي شَيْبَةَ، أَخْبَرَنَا عَبْدَةُ بْنُ سُلَيْمَانَ، وَحُمَيْدُ بْنُ عَبْدِ الرَّحْمَنِ، ح وَحَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ سُلَيْمَانَ، ح وَحَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا أَبُو أُسَامَةَ، كُلُّهُمْ عَنْ هِشَامٍ، بِهَذَا الإِسْنَادِ ‏.‏ نَحْوَ حَدِيثِ ابْنِ نُمَيْرٍ عَنْ حُمَيْدِ بْنِ عَبْدِ الرَّحْمَنِ، الرُّؤَاسِيِّ وَفِي حَدِيثِ عَبْدِ الرَّحِيمِ وَأَبِي أُسَامَةَ وَهُوَ يَوْمَئِذٍ ذُو ثَمَنٍ ‏.‏", "bengali": "", "english": "\" That (the shield) was valuable those days.\"", "french": "", "indonesian": "", "russian": "", "urdu": "جریر نے عبدالعزیز بن رفیع سے ،  انہوں نے تمیم بن طرفہ سے روایت کی ،  انہوں نے کہا :  حضرت عدی بن حات", "grades": "", "reference": "", "international_number": "4275", "narrator_chain": "This hadith has been narrated on the authority of Hisham through another chain of transmitters, and in the hadith narrated by 'Abd al-Rahim and Abu Usama (the words are):", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4276", "arabic": "حَدَّثَنَا يَحْيَى بْنُ يَحْيَى، قَالَ قَرَأْتُ عَلَى مَالِكٍ عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَطَعَ سَارِقًا فِي مِجَنٍّ قِيمَتُهُ ثَلاَثَةُ دَرَاهِمَ ‏.‏", "bengali": "", "english": "Ibn 'Umar reported that Allah's Messenger (may peace upon him) cut off the hand of a thief (in case of the theft) of a shield the price of which was three dirhams.", "french": "", "indonesian": "", "russian": "", "urdu": "شعبہ نے عبدالعزیز بن رفیع سے ،  انہوں نے تمیم بن طرفہ سے اور انہوں نے حضرت عدی بن حاتم رضی اللہ عنہ", "grades": "", "reference": "", "international_number": "4276", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4277", "arabic": "حَدَّثَنَا قُتَيْبَةُ بْنُ سَعِيدٍ، وَابْنُ، رُمْحٍ عَنِ اللَّيْثِ بْنِ سَعْدٍ، ح وَحَدَّثَنَا زُهَيْرُ بْنُ حَرْبٍ، وَابْنُ الْمُثَنَّى قَالاَ حَدَّثَنَا يَحْيَى، وَهُوَ الْقَطَّانُ ح وَحَدَّثَنَا ابْنُ نُمَيْرٍ، حَدَّثَنَا أَبِي ح، وَحَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ، كُلُّهُمْ عَنْ عُبَيْدِ اللَّهِ، ح وَحَدَّثَنِي زُهَيْرُ بْنُ حَرْبٍ، حَدَّثَنَا إِسْمَاعِيلُ يَعْنِي ابْنَ عُلَيَّةَ، ح وَحَدَّثَنَا أَبُو الرَّبِيعِ، وَأَبُو كَامِلٍ قَالاَ حَدَّثَنَا حَمَّادٌ، ح وَحَدَّثَنِي مُحَمَّدُ بْنُ رَافِعٍ، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَخْبَرَنَا سُفْيَانُ، عَنْ أَيُّوبَ السَّخْتِيَانِيِّ، وَأَيُّوبَ، بْنِ مُوسَى وَإِسْمَاعِيلَ بْنِ أُمَيَّةَ ح. وَحَدَّثَنِي عَبْدُ اللَّهِ بْنُ عَبْدِ الرَّحْمَنِ الدَّارِمِيُّ، أَخْبَرَنَا أَبُو نُعَيْمٍ، حَدَّثَنَا سُفْيَانُ، عَنْ أَيُّوبَ، وَإِسْمَاعِيلَ بْنِ أُمَيَّةَ، وَعُبَيْدِ اللَّهِ، وَمُوسَى بْنِ عُقْبَةَ، ح وَحَدَّثَنَا مُحَمَّدُ بْنُ رَافِعٍ، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَخْبَرَنَا ابْنُ جُرَيْجٍ، أَخْبَرَنِي إِسْمَاعِيلُ بْنُ أُمَيَّةَ، ح وَحَدَّثَنِي أَبُو الطَّاهِرِ، أَخْبَرَنَا ابْنُ وَهْبٍ، عَنْ حَنْظَلَةَ بْنِ أَبِي سُفْيَانَ الْجُمَحِيِّ، وَعُبَيْدِ اللَّهِ بْنِ عُمَرَ، وَمَالِكِ بْنِ أَنَسٍ، وَأُسَامَةَ، بْنِ زَيْدٍ اللَّيْثِيِّ كُلُّهُمْ عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، عَنِ النَّبِيِّ صلى الله عليه وسلم ‏.‏ بِمِثْلِ حَدِيثِ يَحْيَى عَنْ مَالِكٍ غَيْرَ أَنَّ بَعْضَهُمْ قَالَ قِيمَتُهُ وَبَعْضُهُمْ قَالَ ثَمَنُهُ ثَلاَثَةُ دَرَاهِمَ ‏.‏\"", "bengali": "", "english": "This hadith has been narrated on the authority of Ibn 'Umar through some other chains of transmitters but with a slight variation of words.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4278", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَأَبُو كُرَيْبٍ قَالاَ حَدَّثَنَا أَبُو مُعَاوِيَةَ، عَنِ الأَعْمَشِ، عَنْ أَبِي صَالِحٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ لَعَنَ اللَّهُ السَّارِقَ يَسْرِقُ الْبَيْضَةَ فَتُقْطَعُ يَدُهُ وَيَسْرِقُ الْحَبْلَ فَتُقْطَعُ يَدُهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "Let there be the curse of Allah upon the thief who steals an egg and his hand is cut off, and steals a rope and his hand is cut off.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4279", "arabic": "حَدَّثَنَا عَمْرٌو النَّاقِدُ، وَإِسْحَاقُ بْنُ إِبْرَاهِيمَ، وَعَلِيُّ بْنُ خَشْرَمٍ، كُلُّهُمْ عَنْ عِيسَى، بْنِ يُونُسَ عَنِ الأَعْمَشِ، بِهَذَا الإِسْنَادِ ‏.‏ مِثْلَهُ غَيْرَ أَنَّهُ يَقُولُ ‏ ‏ إِنْ سَرَقَ حَبْلاً وَإِنْ سَرَقَ بَيْضَةً ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "This hadith is narrated on the authority of A'mash with the same chain of transmitters with a slight variation of words.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4280", "arabic": "حَدَّثَنَا قُتَيْبَةُ بْنُ سَعِيدٍ، حَدَّثَنَا لَيْثٌ، ح وَحَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، أَخْبَرَنَا اللَّيْثُ، عَنِ ابْنِ شِهَابٍ، عَنْ عُرْوَةَ، عَنَ عَائِشَةَ، أَنَّ قُرَيْشًا، أَهَمَّهُمْ شَأْنُ الْمَرْأَةِ الْمَخْزُومِيَّةِ الَّتِي سَرَقَتْ فَقَالُوا مَنْ يُكَلِّمُ فِيهَا رَسُولَ اللَّهِ صلى الله عليه وسلم فَقَالُوا وَمَنْ يَجْتَرِئُ عَلَيْهِ إِلاَّ أُسَامَةُ حِبُّ رَسُولِ اللَّهِ صلى الله عليه وسلم ‏.‏ فَكَلَّمَهُ أُسَامَةُ ‏.‏ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ أَتَشْفَعُ فِي حَدٍّ مِنْ حُدُودِ اللَّهِ ‏\"‏ ‏.‏ ثُمَّ قَامَ فَاخْتَطَبَ فَقَالَ ‏\"‏ أَيُّهَا النَّاسُ إِنَّمَا أَهْلَكَ الَّذِينَ قَبْلَكُمْ أَنَّهُمْ كَانُوا إِذَا سَرَقَ فِيهِمُ الشَّرِيفُ تَرَكُوهُ وَإِذَا سَرَقَ فِيهِمُ الضَّعِيفُ أَقَامُوا عَلَيْهِ الْحَدَّ وَايْمُ اللَّهِ لَوْ أَنَّ فَاطِمَةَ بِنْتَ مُحَمَّدٍ سَرَقَتْ لَقَطَعْتُ يَدَهَا ‏\"‏ ‏.‏ وَفِي حَدِيثِ ابْنِ رُمْحٍ ‏\"‏ إِنَّمَا هَلَكَ الَّذِينَ مِنْ قَبْلِكُمْ ‏\"‏ ‏.‏", "bengali": "", "english": "Who will speak to Allah's Messenger (ﷺ) about her? They said: Who dare it, but Usama, the loved one of Allah's Messenger (ﷺ)? So Usama spoke to him. Thereupon Allah's Messenger (ﷺ) said: Do you intercede regarding one of the punishments prescribed by Allah? He then stood up and addressed (people) saying: O people, those who have gone before you were destroyed, because if any one of high rank committed theft amongst them, they spared him; and it anyone of low rank committed theft, they inflicted the prescribed punishment upon him. By Allah, if Fatima, daughter of Muhammad, were to steal, I would have her hand cut off. In the hadith transmitted on the authority of Ibn Rumh (the words are):\" Verily those before you perished.\"", "french": "", "indonesian": "", "russian": "", "urdu": "بہز نے کہا :  ہمیں شعبہ نے حدیث سنائی اور کہا :  ہمیں سماک بن حرب نے حدیث بیان کی ،  انہوں نے کہا :", "grades": "", "reference": "", "international_number": "4280", "narrator_chain": "'A'isha reported that the Quraish had been anxious about the Makhzumi woman who had committed theft, and said:", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4281", "arabic": "وَحَدَّثَنِي أَبُو الطَّاهِرِ، وَحَرْمَلَةُ بْنُ يَحْيَى، - وَاللَّفْظُ لِحَرْمَلَةَ - قَالاَ أَخْبَرَنَا ابْنُ، وَهْبٍ قَالَ أَخْبَرَنِي يُونُسُ بْنُ يَزِيدَ، عَنِ ابْنِ شِهَابٍ، قَالَ أَخْبَرَنِي عُرْوَةُ بْنُ الزُّبَيْرِ، عَنْ عَائِشَةَ، زَوْجِ النَّبِيِّ صلى الله عليه وسلم أَنَّ قُرَيْشًا أَهَمَّهُمْ شَأْنُ الْمَرْأَةِ الَّتِي سَرَقَتْ فِي عَهْدِ النَّبِيِّ صلى الله عليه وسلم فِي غَزْوَةِ الْفَتْحِ فَقَالُوا مَنْ يُكَلِّمُ فِيهَا رَسُولَ اللَّهِ صلى الله عليه وسلم فَقَالُوا وَمَنْ يَجْتَرِئُ عَلَيْهِ إِلاَّ أُسَامَةُ بْنُ زَيْدٍ حِبُّ رَسُولِ اللَّهِ صلى الله عليه وسلم ‏.‏ فَأُتِيَ بِهَا رَسُولُ اللَّهِ صلى الله عليه وسلم فَكَلَّمَهُ فِيهَا أُسَامَةُ بْنُ زَيْدٍ فَتَلَوَّنَ وَجْهُ رَسُولِ اللَّهِ صلى الله عليه وسلم فَقَالَ ‏\"‏ أَتَشْفَعُ فِي حَدٍّ مِنْ حُدُودِ اللَّهِ ‏\"‏ ‏.‏ فَقَالَ لَهُ أُسَامَةُ اسْتَغْفِرْ لِي يَا رَسُولَ اللَّهِ ‏.‏ فَلَمَّا كَانَ الْعَشِيُّ قَامَ رَسُولُ اللَّهِ صلى الله عليه وسلم فَاخْتَطَبَ فَأَثْنَى عَلَى اللَّهِ بِمَا هُوَ أَهْلُهُ ثُمَّ قَالَ ‏\"‏ أَمَّا بَعْدُ فَإِنَّمَا أَهْلَكَ الَّذِينَ مِنْ قَبْلِكُمْ أَنَّهُمْ كَانُوا إِذَا سَرَقَ فِيهِمُ الشَّرِيفُ تَرَكُوهُ وَإِذَا سَرَقَ فِيهِمُ الضَّعِيفُ أَقَامُوا عَلَيْهِ الْحَدَّ وَإِنِّي وَالَّذِي نَفْسِي بِيَدِهِ لَوْ أَنَّ فَاطِمَةَ بِنْتَ مُحَمَّدٍ سَرَقَتْ لَقَطَعْتُ يَدَهَا ‏\"‏ ‏.‏ ثُمَّ أَمَرَ بِتِلْكَ الْمَرْأَةِ الَّتِي سَرَقَتْ فَقُطِعَتْ يَدُهَا ‏.‏ قَالَ يُونُسُ قَالَ ابْنُ شِهَابٍ قَالَ عُرْوَةُ قَالَتْ عَائِشَةُ فَحَسُنَتْ تَوْبَتُهَا بَعْدُ وَتَزَوَّجَتْ وَكَانَتْ تَأْتِينِي بَعْدَ ذَلِكَ فَأَرْفَعُ حَاجَتَهَا إِلَى رَسُولِ اللَّهِ صلى الله عليه وسلم ‏.‏", "bengali": "", "english": "Who would speak to Allah's Messenger (ﷺ) about her? They (again) said: Who can dare do this but Usama b. Zaid, the loved one of Allah's Messenger (ﷺ)? She was brought to Allah's Messenger (ﷺ) and Usama b. Zaid spoke about her to him (interceded on her behalf). The color of the face of Allah's Messenger (ﷺ) changed, and he said: Do you intercede in one of the prescribed punishments of Allah? He (Usama) said: 'Messenger of Allah, seek forgiveness for me.' When it was dusk. Allah's Messenger (ﷺ) stood up and gave an address. He (first) glorified Allah as He deserves, and then said: Now to our topic. This (injustice) destroyed those before you that when any one of (high) rank committed theft among them, they spared him, and when any weak one among them committed theft, they inflicted the prescribed punishment upon him. By Him in Whose Hand is my life, even if Fatima daughter of Muhammad were to commit theft, I would have cut off her hand. He (the Holy Prophet) then commanded about that woman who had committed theft, and her hand was cut off. `A'isha (further) said: Hers was a good repentance, and she later on married and used to come to me after that, and I conveyed her needs (and problems) to Allah's Messenger (ﷺ).", "french": "", "indonesian": "", "russian": "", "urdu": "شیبان بن فروخ نے کہا :  ہمیں جریر بن حازم نے حدیث بیان کی ،   ( کہا :   )  ہمیں حسن نے حدیث سنائی ،", "grades": "", "reference": "", "international_number": "4281", "narrator_chain": "`A'isha, the wife of Allah's Apostle (ﷺ), reported that the Quraish were concerned about the woman who had committed theft during the lifetime of Allah's Apostle (ﷺ), in the expedition of Victory (of Mecca). They said:", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4282", "arabic": "وَحَدَّثَنَا عَبْدُ بْنُ حُمَيْدٍ، أَخْبَرَنَا عَبْدُ الرَّزَّاقِ، أَخْبَرَنَا مَعْمَرٌ، عَنِ الزُّهْرِيِّ، عَنْ عُرْوَةَ، عَنْ عَائِشَةَ، قَالَتْ كَانَتِ امْرَأَةٌ مَخْزُومِيَّةٌ تَسْتَعِيرُ الْمَتَاعَ وَتَجْحَدُهُ فَأَمَرَ النَّبِيُّ صلى الله عليه وسلم أَنْ تُقْطَعَ يَدُهَا فَأَتَى أَهْلُهَا أُسَامَةَ بْنَ زَيْدٍ فَكَلَّمُوهُ فَكَلَّمَ رَسُولَ اللَّهِ صلى الله عليه وسلم فِيهَا ‏.‏ ثُمَّ ذَكَرَ نَحْوَ حَدِيثِ اللَّيْثِ وَيُونُسَ ‏.‏", "bengali": "", "english": "'A'isha reported that a woman from the tribe of Makhzum used to borrow things (from people) and then denied (having taken them). Allah's Apostle (ﷺ) commanded her hand to be cut off. Her relatives came to Usama b. Zaid and spoke to him (requesting him to intercede on her behalf). He spoke to Allah's Messenger (ﷺ) about her. The rest of the hadith is the same.", "french": "", "indonesian": "", "russian": "", "urdu": "یونس ،  منصور ،  حمید ،  سماک بن عطیہ ، ہشام بن حسان ،  معتمر کے والد  ( سلیمان طرخان )  اور قتادہ ،", "grades": "", "reference": "", "international_number": "4282", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4283", "arabic": "وَحَدَّثَنِي سَلَمَةُ بْنُ شَبِيبٍ، حَدَّثَنَا الْحَسَنُ بْنُ أَعْيَنَ، حَدَّثَنَا مَعْقِلٌ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، أَنَّ امْرَأَةً، مِنْ بَنِي مَخْزُومٍ سَرَقَتْ فَأُتِيَ بِهَا النَّبِيُّ صلى الله عليه وسلم فَعَاذَتْ بِأُمِّ سَلَمَةَ زَوْجِ النَّبِيِّ صلى الله عليه وسلم فَقَالَ النَّبِيُّ صلى الله عليه وسلم ‏ ‏ وَاللَّهِ لَوْ كَانَتْ فَاطِمَةُ لَقَطَعْتُ يَدَهَا ‏\"\"‏ ‏.‏ فَقُطِعَتْ ‏.‏\"", "bengali": "", "english": "By Allah, even if she were Fatima, I would have her hand cut off. And thus her hand was cut off.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Jaibir reported that a woman from the tribe of Makhzum committed theft. She was brought to Allah's Apostle (ﷺ) and she sought refuge (intercession) from Umm Salama, the wife of Allah's Apostle (ﷺ). Thereupon Allah's Apostle (ﷺ) said:", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4284", "arabic": "وَحَدَّثَنَا يَحْيَى بْنُ يَحْيَى التَّمِيمِيُّ، أَخْبَرَنَا هُشَيْمٌ، عَنْ مَنْصُورٍ، عَنِ الْحَسَنِ، عَنْ حِطَّانَ، بْنِ عَبْدِ اللَّهِ الرَّقَاشِيِّ عَنْ عُبَادَةَ بْنِ الصَّامِتِ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ خُذُوا عَنِّي خُذُوا عَنِّي قَدْ جَعَلَ اللَّهُ لَهُنَّ سَبِيلاً الْبِكْرُ بِالْبِكْرِ جَلْدُ مِائَةٍ وَنَفْىُ سَنَةٍ وَالثَّيِّبُ بِالثَّيِّبِ جَلْدُ مِائَةٍ وَالرَّجْمُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "Allah's Messenger (ﷺ) as saying: Receive (teaching) from me, receive (teaching) from me. Allah has ordained a way for those (women). When an unmarried male commits adultery with an unmarried female (they should receive) one hundred lashes and banishment for one year. And in case of married male committing adultery with a married female, they shall receive one hundred lashes and be stoned to death.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "'Ubada b. as-Samit reported:", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4285", "arabic": "وَحَدَّثَنَا عَمْرٌو النَّاقِدُ، حَدَّثَنَا هُشَيْمٌ، أَخْبَرَنَا مَنْصُورٌ، بِهَذَا الإِسْنَادِ مِثْلَهُ ‏.‏", "bengali": "", "english": "The above hadith is likewise narrated through another chain of transmitters.", "french": "", "indonesian": "", "russian": "", "urdu": "محمد  ( بن سیرین )  نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  حضرت سلیمان علیہ ال", "grades": "", "reference": "", "international_number": "4285", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4286", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، وَابْنُ، بَشَّارٍ جَمِيعًا عَنْ عَبْدِ الأَعْلَى، قَالَ ابْنُ الْمُثَنَّى حَدَّثَنَا عَبْدُ الأَعْلَى، حَدَّثَنَا سَعِيدٌ، عَنْ قَتَادَةَ، عَنِ الْحَسَنِ، عَنْ حِطَّانَ بْنِ عَبْدِ اللَّهِ الرَّقَاشِيِّ، عَنْ عُبَادَةَ بْنِ الصَّامِتِ، قَالَ كَانَ نَبِيُّ اللَّهِ صلى الله عليه وسلم إِذَا أُنْزِلَ عَلَيْهِ كُرِبَ لِذَلِكَ وَتَرَبَّدَ لَهُ وَجْهُهُ - قَالَ - فَأُنْزِلَ عَلَيْهِ ذَاتَ يَوْمٍ فَلُقِيَ كَذَلِكَ فَلَمَّا سُرِّيَ عَنْهُ قَالَ ‏ ‏ خُذُوا عَنِّي فَقَدْ جَعَلَ اللَّهُ لَهُنَّ سَبِيلاً الثَّيِّبُ بِالثَّيِّبِ وَالْبِكْرُ بِالْبِكْرِ الثَّيِّبُ جَلْدُ مِائَةٍ ثُمَّ رَجْمٌ بِالْحِجَارَةِ وَالْبِكْرُ جَلْدُ مِائَةٍ ثُمَّ نَفْىُ سَنَةٍ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "Take from me. Verily Allah has ordained a way for them (the women who commit fornication),: (When) a married man (commits adultery) with a married woman, and an unmarried male with an unmarried woman, then in case of married (persons) there is (a punishment) of one hundred lashes and then stoning (to death). And in case of unmarried persons, (the punishment) is one hundred lashes and exile for one year.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "'Ubada b. as-Samit reported that whenever Allah's Apostle (ﷺ) received revelation, he felt its rigour and the complexion of his face changed. One day revelation descended upon him, he felt the same rigour. When it was over and he felt relief, he said:", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4287", "arabic": "وَحَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، وَابْنُ، بَشَّارٍ قَالاَ حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، حَدَّثَنَا شُعْبَةُ، ح وَحَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُعَاذُ بْنُ هِشَامٍ، حَدَّثَنِي أَبِي كِلاَهُمَا، عَنْ قَتَادَةَ، بِهَذَا الإِسْنَادِ ‏.‏ غَيْرَ أَنَّ فِي، حَدِيثِهِمَا ‏ ‏ الْبِكْرُ يُجْلَدُ وَيُنْفَى وَالثَّيِّبُ يُجْلَدُ وَيُرْجَمُ ‏\"\"‏ ‏.‏ لاَ يَذْكُرَانِ سَنَةً وَلاَ مِائَةً ‏.\"", "bengali": "", "english": "This hadith has been reported on the authority of Qatada with the same chain of transmitters except with this variation that the unmarried is to be lashed and exiled, and the married one is to be lashed and stoned. There is neither any mention of one year nor that of one hundred.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4288", "arabic": "حَدَّثَنِي أَبُو الطَّاهِرِ، وَحَرْمَلَةُ بْنُ يَحْيَى، قَالاَ حَدَّثَنَا ابْنُ وَهْبٍ، أَخْبَرَنِي يُونُسُ، عَنِ ابْنِ شِهَابٍ، قَالَ أَخْبَرَنِي عُبَيْدُ اللَّهِ بْنُ عَبْدِ اللَّهِ بْنِ عُتْبَةَ، أَنَّهُ سَمِعَ عَبْدَ اللَّهِ بْنَ عَبَّاسٍ، يَقُولُ قَالَ عُمَرُ بْنُ الْخَطَّابِ وَهُوَ جَالِسٌ عَلَى مِنْبَرِ رَسُولِ اللَّهِ صلى الله عليه وسلم إِنَّ اللَّهَ قَدْ بَعَثَ مُحَمَّدًا صلى الله عليه وسلم بِالْحَقِّ وَأَنْزَلَ عَلَيْهِ الْكِتَابَ فَكَانَ مِمَّا أُنْزِلَ عَلَيْهِ آيَةُ الرَّجْمِ قَرَأْنَاهَا وَوَعَيْنَاهَا وَعَقَلْنَاهَا فَرَجَمَ رَسُولُ اللَّهِ صلى الله عليه وسلم وَرَجَمْنَا بَعْدَهُ فَأَخْشَى إِنْ طَالَ بِالنَّاسِ زَمَانٌ أَنْ يَقُولَ قَائِلٌ مَا نَجِدُ الرَّجْمَ فِي كِتَابِ اللَّهِ فَيَضِلُّوا بِتَرْكِ فَرِيضَةٍ أَنْزَلَهَا اللَّهُ وَإِنَّ الرَّجْمَ فِي كِتَابِ اللَّهِ حَقٌّ عَلَى مَنْ زَنَى إِذَا أَحْصَنَ مِنَ الرِّجَالِ وَالنِّسَاءِ إِذَا قَامَتِ الْبَيِّنَةُ أَوْ كَانَ الْحَبَلُ أَوْ الاِعْتِرَافُ ‏.‏", "bengali": "", "english": "Verily Allah sent Muhammad (ﷺ) with truth and He sent down the Book upon him, and the verse of stoning was included in what was sent down to him. We recited it, retained it in our memory and understood it. Allah's Messenger (ﷺ) awarded the punishment of stoning to death (to the married adulterer and adulteress) and, after him, we also awarded the punishment of stoning, I am afraid that with the lapse of time, the people (may forget it) and may say: We do not find the punishment of stoning in the Book of Allah, and thus go astray by abandoning this duty prescribed by Allah. Stoning is a duty laid down in Allah's Book for married men and women who commit adultery when proof is established, or it there is pregnancy, or a confession.", "french": "", "indonesian": "", "russian": "", "urdu": "طاوس کے بیٹے نے اپنے والد سے اور انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :", "grades": "", "reference": "", "international_number": "4288", "narrator_chain": "'Abdullah b. 'Abbas reported that 'Umar b. Khattab sat on the pulpit of Allah's Messenger (ﷺ) and said:", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4289", "arabic": "وَحَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَزُهَيْرُ بْنُ حَرْبٍ، وَابْنُ أَبِي عُمَرَ، قَالُوا حَدَّثَنَا سُفْيَانُ، عَنِ الزُّهْرِيِّ، بِهَذَا الإِسْنَادِ ‏.‏", "bengali": "", "english": "This hadith has been narrated on the authority of Zuhri with the same chain of transmitters.", "french": "", "indonesian": "", "russian": "", "urdu": "ورقاء نے ابوزناد سے ،  انہوں نے اعرج سے ،  انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے اور انہوں نے نبی ص", "grades": "", "reference": "", "international_number": "4289", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4290", "arabic": "وَحَدَّثَنِي عَبْدُ الْمَلِكِ بْنُ شُعَيْبِ بْنِ اللَّيْثِ بْنِ سَعْدٍ، حَدَّثَنِي أَبِي، عَنْ جَدِّي، قَالَ حَدَّثَنِي عُقَيْلٌ، عَنِ ابْنِ شِهَابٍ، عَنْ أَبِي سَلَمَةَ بْنِ عَبْدِ الرَّحْمَنِ بْنِ عَوْفٍ، وَسَعِيدِ بْنِ الْمُسَيَّبِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّهُ قَالَ أَتَى رَجُلٌ مِنَ الْمُسْلِمِينَ رَسُولَ اللَّهِ صلى الله عليه وسلم وَهُوَ فِي الْمَسْجِدِ فَنَادَاهُ فَقَالَ يَا رَسُولَ اللَّهِ إِنِّي زَنَيْتُ ‏.‏ فَأَعْرَضَ عَنْهُ فَتَنَحَّى تِلْقَاءَ وَجْهِهِ فَقَالَ لَهُ يَا رَسُولَ اللَّهِ إِنِّي زَنَيْتُ ‏.‏ فَأَعْرَضَ عَنْهُ حَتَّى ثَنَى ذَلِكَ عَلَيْهِ أَرْبَعَ مَرَّاتٍ فَلَمَّا شَهِدَ عَلَى نَفْسِهِ أَرْبَعَ شَهَادَاتٍ دَعَاهُ رَسُولُ اللَّهِ صلى الله عليه وسلم فَقَالَ ‏\"‏ أَبِكَ جُنُونٌ ‏\"‏ ‏.‏ قَالَ لاَ ‏.‏ قَالَ ‏\"‏ فَهَلْ أَحْصَنْتَ ‏\"‏ ‏.‏ قَالَ نَعَمْ ‏.‏ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ اذْهَبُوا بِهِ فَارْجُمُوهُ ‏\"‏ ‏.‏", "bengali": "", "english": "Allah's Messenger. I have committed adultery. He (the Holy Prophet) turned away from him, He (again) came round facing him and said to him: Allah's Messenger, I have committed adultery. He (the Holy Prophet) turned away until he did that four times, and as he testified four times against his own self, Allah's Messenger (ﷺ) called him and said: Are you mad? He said: No. He (again) said: Are you married? He said: Yes. Thereupon Allah's Messenger (ﷺ) said: Take him and stone him.", "french": "", "indonesian": "", "russian": "", "urdu": "موسیٰ بن عقبہ نے ابوزناد سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی ،  البتہ انہوں نے کہا :   \" ان", "grades": "", "reference": "", "international_number": "4290", "narrator_chain": "Abu Huraira reported that a person from amongst the Muslims came to Allah's Messenger (ﷺ) while he was in the mosque. He called him saying:", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4291", "arabic": "قَالَ ابْنُ شِهَابٍ فَأَخْبَرَنِي مَنْ، سَمِعَ جَابِرَ بْنَ عَبْدِ اللَّهِ، يَقُولُ فَكُنْتُ فِيمَنْ رَجَمَهُ فَرَجَمْنَاهُ بِالْمُصَلَّى فَلَمَّا أَذْلَقَتْهُ الْحِجَارَةُ هَرَبَ فَأَدْرَكْنَاهُ بِالْحَرَّةِ فَرَجَمْنَاهُ ‏.‏", "bengali": "", "english": "One who had heard Jabir b. 'Abdullah saying this informed me thus: I was one of those who stoned him. We stoned him at the place of prayer (either that of 'Id or a funeral). When the stones hurt him, he ran away. We caught him in the Harra and stoned him (to death).", "french": "", "indonesian": "", "russian": "", "urdu": "ہمام بن منبہ سے روایت ہے ،  انہوں نے کہا :  یہ احادیث ہیں جو ہمیں حضرت ابوہریرہ رضی اللہ عنہ نے رسول", "grades": "", "reference": "", "international_number": "4291", "narrator_chain": "Ibn Shihab (one of the narrators) said:", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4292", "arabic": "وَرَوَاهُ اللَّيْثُ أَيْضًا عَنْ عَبْدِ الرَّحْمَنِ بْنِ خَالِدِ بْنِ مُسَافِرٍ، عَنِ ابْنِ شِهَابٍ، بِهَذَا الإِسْنَادِ ‏.‏ مِثْلَهُ ‏.‏ وَحَدَّثَنِيهِ عَبْدُ اللَّهِ بْنُ عَبْدِ الرَّحْمَنِ الدَّارِمِيُّ، حَدَّثَنَا أَبُو الْيَمَانِ، أَخْبَرَنَا شُعَيْبٌ، عَنِ الزُّهْرِيِّ، بِهَذَا الإِسْنَادِ أَيْضًا وَفِي حَدِيثِهِمَا جَمِيعًا قَالَ ابْنُ شِهَابٍ أَخْبَرَنِي مَنْ سَمِعَ جَابِرَ بْنَ عَبْدِ اللَّهِ كَمَا ذَكَرَ عُقَيْلٌ ‏.‏\"", "bengali": "", "english": "This hadith has been narrated through another chain of transmitters.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4293", "arabic": "وَحَدَّثَنِي أَبُو الطَّاهِرِ، وَحَرْمَلَةُ بْنُ يَحْيَى، قَالاَ أَخْبَرَنَا ابْنُ وَهْبٍ، أَخْبَرَنِي يُونُسُ، ح وَحَدَّثَنَا إِسْحَاقُ بْنُ إِبْرَاهِيمَ، أَخْبَرَنَا عَبْدُ الرَّزَّاقِ، أَخْبَرَنَا مَعْمَرٌ، وَابْنُ، جُرَيْجٍ كُلُّهُمْ عَنِ الزُّهْرِيِّ، عَنْ أَبِي سَلَمَةَ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، عَنِ النَّبِيِّ صلى الله عليه وسلم ‏.‏ نَحْوَ رِوَايَةِ عُقَيْلٍ عَنِ الزُّهْرِيِّ عَنْ سَعِيدٍ وَأَبِي سَلَمَةَ عَنْ أَبِي هُرَيْرَةَ ‏.‏", "bengali": "", "english": "This hadith has been narrated on the authority of Abu Huraira through other chains of transmitters.", "french": "", "indonesian": "", "russian": "", "urdu": "ابواسامہ ،  عبدالوہاب ثقفی ،  حفص بن غیاث اور شعبہ ،  ان سب نے عبیداللہ سے حدیث بیان کی ،  انہوں نے", "grades": "", "reference": "", "international_number": "4293", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4294", "arabic": "وَحَدَّثَنِي أَبُو كَامِلٍ، فُضَيْلُ بْنُ حُسَيْنٍ الْجَحْدَرِيُّ حَدَّثَنَا أَبُو عَوَانَةَ، عَنْ سِمَاكِ بْنِ، حَرْبٍ عَنْ جَابِرِ بْنِ سَمُرَةَ، قَالَ رَأَيْتُ مَاعِزَ بْنَ مَالِكٍ حِينَ جِيءَ بِهِ إِلَى النَّبِيِّ صلى الله عليه وسلم رَجُلٌ قَصِيرٌ أَعْضَلُ لَيْسَ عَلَيْهِ رِدَاءٌ فَشَهِدَ عَلَى نَفْسِهِ أَرْبَعَ مَرَّاتٍ أَنَّهُ زَنَى فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ فَلَعَلَّكَ ‏\"‏ ‏.‏ قَالَ لاَ وَاللَّهِ إِنَّهُ قَدْ زَنَى الأَخِرُ - قَالَ - فَرَجَمَهُ ثُمَّ خَطَبَ فَقَالَ ‏\"‏ أَلاَ كُلَّمَا نَفَرْنَا غَازِينَ فِي سَبِيلِ اللَّهِ خَلَفَ أَحَدُهُمْ لَهُ نَبِيبٌ كَنَبِيبِ التَّيْسِ يَمْنَحُ أَحَدُهُمُ الْكُثْبَةَ أَمَا وَاللَّهِ إِنْ يُمْكِنِّي مِنْ أَحَدِهِمْ لأُنَكِّلَنَّهُ عَنْهُ ‏\"‏ ‏.‏", "bengali": "", "english": "As he was being brought to Allah's Apostle (ﷺ) I saw Ma'iz b. Malik-a short-statured person with strong sinews, having no cloak around him. He bore witness against his own self four times that he had committed adultery, whereupon Allah's Messenger (ﷺ) said: Perhaps (you kissed her or embraced her). He said: No. by God, one deviating (from the path of virtue) has committed adultery. He then got him stoned (to death), and then delivered the address: Behold, as we set out for Jihad in the cause of Allah, one of you lagged behind and shrieked like the bleating of a male goat, and gave a small quantity of milk. By Allah, in case I get hold of him, I shall certainly punish him.", "french": "", "indonesian": "", "russian": "", "urdu": "جریر بن حازم نے ہمیں حدیث سنائی کہ ایوب نے انہیں حدیث بیان کی ،  انہیں نافع نے حدیث سنائی ،  انہیں ح", "grades": "", "reference": "", "international_number": "4294", "narrator_chain": "Jabir b. Samura reported:", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4295", "arabic": "وَحَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، وَابْنُ، بَشَّارٍ - وَاللَّفْظُ لاِبْنِ الْمُثَنَّى - قَالاَ حَدَّثَنَا مُحَمَّدُ، بْنُ جَعْفَرٍ حَدَّثَنَا شُعْبَةُ، عَنْ سِمَاكِ بْنِ حَرْبٍ، قَالَ سَمِعْتُ جَابِرَ بْنَ سَمُرَةَ، يَقُولُ أُتِيَ رَسُولُ اللَّهِ صلى الله عليه وسلم بِرَجُلٍ قَصِيرٍ أَشْعَثَ ذِي عَضَلاَتٍ عَلَيْهِ إِزَارٌ وَقَدْ زَنَى فَرَدَّهُ مَرَّتَيْنِ ثُمَّ أَمَرَ بِهِ فَرُجِمَ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ كُلَّمَا نَفَرْنَا غَازِينَ فِي سَبِيلِ اللَّهِ تَخَلَّفَ أَحَدُكُمْ يَنِبُّ نَبِيبَ التَّيْسِ يَمْنَحُ إِحْدَاهُنَّ الْكُثْبَةَ إِنَّ اللَّهَ لاَ يُمْكِنِّي مِنْ أَحَدٍ مِنْهُمْ إِلاَّ جَعَلْتُهُ نَكَالاً ‏\"\"‏ ‏.‏ أَوْ نَكَّلْتُهُ ‏.‏ قَالَ فَحَدَّثْتُهُ سَعِيدَ بْنَ جُبَيْرٍ فَقَالَ إِنَّهُ رَدَّهُ أَرْبَعَ مَرَّاتٍ ‏.‏\"", "bengali": "", "english": "We set out for Jihad in the cause of Allah and one of you lagged behind and shrieked like the bleating of a male goat and one of then (goats' gave a small quantity of milk. In case Allah gives me power over one of them, I will punish him (in such a way that it may have a deterrent effect upon others). In another narration transmitted on the authority of Sa'id b Jubair (the words are), that He (the Holy Prophet) turned him away four times.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Jabir b. Samura reported that there was brought to Allah's Messenger (ﷺ) a short-statured person with thick uncombed hair, muscular body, having a mantle around him and he had committed adultery. He turned him away twice and then made pronouncement about him and he was stoned. Then Allah's Messenger (ﷺ) said:", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4296", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا شَبَابَةُ، ح وَحَدَّثَنَا إِسْحَاقُ بْنُ إِبْرَاهِيمَ، أَخْبَرَنَا أَبُو عَامِرٍ الْعَقَدِيُّ، كِلاَهُمَا عَنْ شُعْبَةَ، عَنْ سِمَاكٍ، عَنْ جَابِرِ بْنِ سَمُرَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم ‏.‏ نَحْوَ حَدِيثِ ابْنِ جَعْفَرٍ وَوَافَقَهُ شَبَابَةُ عَلَى قَوْلِهِ فَرَدَّهُ مَرَّتَيْنِ ‏.‏ وَفِي حَدِيثِ أَبِي عَامِرٍ فَرَدَّهُ مَرَّتَيْنِ أَوْ ثَلاَثًا ‏.‏", "bengali": "", "english": "This hadith has been narrated on the authority of Jabir b. Samura through another chain of transmitters with the difference that along with the mentioning (of the fact) that he (the Holy Prophet) turned him away twice, or thrice.", "french": "", "indonesian": "", "russian": "", "urdu": "حماد بن زید نے ہمیں حدیث بیان کی ،  کہا :  ہمیں ایوب نے نافع سے حدیث بیان کی ،  انہوں نے کہا :  حضرت", "grades": "", "reference": "", "international_number": "4296", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4297", "arabic": "حَدَّثَنَا قُتَيْبَةُ بْنُ سَعِيدٍ، وَأَبُو كَامِلٍ الْجَحْدَرِيُّ - وَاللَّفْظُ لِقُتَيْبَةَ - قَالاَ حَدَّثَنَا أَبُو عَوَانَةَ عَنْ سِمَاكٍ، عَنْ سَعِيدِ بْنِ جُبَيْرٍ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ النَّبِيَّ صلى الله عليه وسلم قَالَ لِمَاعِزِ بْنِ مَالِكٍ ‏\"‏ أَحَقٌّ مَا بَلَغَنِي عَنْكَ ‏\"‏ ‏.‏ قَالَ وَمَا بَلَغَكَ عَنِّي قَالَ ‏\"‏ بَلَغَنِي أَنَّكَ وَقَعْتَ بِجَارِيَةِ آلِ فُلاَنٍ ‏\"‏ ‏.‏ قَالَ نَعَمْ ‏.‏ قَالَ فَشَهِدَ أَرْبَعَ شَهَادَاتٍ ‏.‏ ثُمَّ أَمَرَ بِهِ فَرُجِمَ ‏.‏", "bengali": "", "english": "Is it true what has reached me about you? He said: What has reached you about me? He said: It has reached me that you have committed (adultery) with the slave-girl of so and so? He said: Yes. He (the narrator) said: He testified four times. He (the Holy Prophet) then made pronouncement about him and he was stoned (to death).", "french": "", "indonesian": "", "russian": "", "urdu": "ایوب اور محمد بن اسحاق دونوں نے نافع سے اور انہوں نے حضرت ابن عمر رضی اللہ عنہ سے نذر کے بارے میں یہ", "grades": "", "reference": "", "international_number": "4297", "narrator_chain": "Ibn Abbas reported that Allah's Apostle (ﷺ) said to Ma'iz b. Malik:", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4298", "arabic": "حَدَّثَنِي مُحَمَّدُ بْنُ الْمُثَنَّى، حَدَّثَنِي عَبْدُ الأَعْلَى، حَدَّثَنَا دَاوُدُ، عَنْ أَبِي نَضْرَةَ، عَنْ أَبِي، سَعِيدٍ أَنَّ رَجُلاً، مِنْ أَسْلَمَ يُقَالُ لَهُ مَاعِزُ بْنُ مَالِكٍ أَتَى رَسُولَ اللَّهِ صلى الله عليه وسلم فَقَالَ إِنِّي أَصَبْتُ فَاحِشَةً فَأَقِمْهُ عَلَىَّ ‏.‏ فَرَدَّهُ النَّبِيُّ صلى الله عليه وسلم مِرَارًا قَالَ ثُمَّ سَأَلَ قَوْمَهُ فَقَالُوا مَا نَعْلَمُ بِهِ بَأْسًا إِلاَّ أَنَّهُ أَصَابَ شَيْئًا يَرَى أَنَّهُ لاَ يُخْرِجُهُ مِنْهُ إِلاَّ أَنْ يُقَامَ فِيهِ الْحَدُّ - قَالَ - فَرَجَعَ إِلَى النَّبِيِّ صلى الله عليه وسلم فَأَمَرَنَا أَنْ نَرْجُمَهُ - قَالَ - فَانْطَلَقْنَا بِهِ إِلَى بَقِيعِ الْغَرْقَدِ - قَالَ - فَمَا أَوْثَقْنَاهُ وَلاَ حَفَرْنَا لَهُ - قَالَ - فَرَمَيْنَاهُ بِالْعَظْمِ وَالْمَدَرِ وَالْخَزَفِ - قَالَ - فَاشْتَدَّ فَاشْتَدَدْنَا خَلْفَهُ حَتَّى أَتَى عُرْضَ الْحَرَّةِ فَانْتَصَبَ لَنَا فَرَمَيْنَاهُ بِجَلاَمِيدِ الْحَرَّةِ - يَعْنِي الْحِجَارَةَ - حَتَّى سَكَتَ - قَالَ - ثُمَّ قَامَ رَسُولُ اللَّهِ صلى الله عليه وسلم خَطِيبًا مِنَ الْعَشِيِّ فَقَالَ ‏ ‏ أَوَكُلَّمَا انْطَلَقْنَا غُزَاةً فِي سَبِيلِ اللَّهِ تَخَلَّفَ رَجُلٌ فِي عِيَالِنَا لَهُ نَبِيبٌ كَنَبِيبِ التَّيْسِ عَلَىَّ أَنْ لاَ أُوتَى بِرَجُلٍ فَعَلَ ذَلِكَ إِلاَّ نَكَّلْتُ بِهِ ‏\"\"‏ ‏.‏ قَالَ فَمَا اسْتَغْفَرَ لَهُ وَلاَ سَبَّهُ ‏.‏\"", "bengali": "", "english": "I have committed immorality (adultery), so inflict punishment upon me. Allah's Apostle (ﷺ) turned him away again and again. He then asked his people (about the state of his mind). They said: We do not know of any ailment of his except that he has committed something about which he thinks that he would not be able to relieve himself of its burden but with the Hadd being imposed upon him. He (Ma'iz) came back to Allah's Apostle (ﷺ) and he commanded us to stone him. We took him to the Baqi' al-Gharqad (the graveyard of Medina). We neither tied him nor dug any ditch for him. We attacked him with bones, with clods and pebbles. He ran away and we ran after him until he came upon the ston ground (al-Harra) and stopped there and we stoned him with heavy stones of the Harra until he became motionless (lie died). He (the Holy Prophet) then addressed (us) in the evening saying Whenever we set forth on an expedition in the cause of Allah, some one of those connected with us shrieked (under the pressure of sexual lust) as the bleating of a male goat. It is essential that if a person having committed such a deed is brought to me, I should punish him. He neither begged forgiveness for him nor cursed him.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Sa'id reported that a person belonging to the clan of Aslam, who was called Ma, iz b. Malik, came to Allah's Messenger (ﷺ) and said:", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4299", "arabic": "حَدَّثَنِي مُحَمَّدُ بْنُ حَاتِمٍ، حَدَّثَنَا بَهْزٌ، حَدَّثَنَا يَزِيدُ بْنُ زُرَيْعٍ، حَدَّثَنَا دَاوُدُ، بِهَذَا الإِسْنَادِ ‏.‏ مِثْلَ مَعْنَاهُ ‏.‏ وَقَالَ فِي الْحَدِيثِ فَقَامَ النَّبِيُّ صلى الله عليه وسلم مِنَ الْعَشِيِّ فَحَمِدَ اللَّهَ وَأَثْنَى عَلَيْهِ ثُمَّ قَالَ ‏\"‏ أَمَّا بَعْدُ فَمَا بَالُ أَقْوَامٍ إِذَا غَزَوْنَا يَتَخَلَّفُ أَحَدُهُمْ عَنَّا لَهُ نَبِيبٌ كَنَبِيبِ التَّيْسِ ‏\"‏ ‏.‏ وَلَمْ يَقُلْ ‏\"‏ فِي عِيَالِنَا ‏\"‏ ‏.‏", "bengali": "", "english": "Allah's Apostle (ﷺ) stood tip (to address the audience) in the evening and praised Allah, glorified Him and then said: What about the people, that as we set out on an expedition, one of you remained behind us and he shrieked like the bleating of a male goat? But he did not mention (these words): People connected with us.\"", "french": "", "indonesian": "", "russian": "", "urdu": "شعبہ نے ہمیں فراس سے باقی ماندہ سابقہ سند سے حدیث بیان کی کہ حضرت ابن عمر رضی اللہ عنہ نے اپنے غلام", "grades": "", "reference": "", "international_number": "4299", "narrator_chain": "Dawud narrated the hadith with the same chain of transmitters (and the words are):", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4300", "arabic": "وَحَدَّثَنَا سُرَيْجُ بْنُ يُونُسَ، حَدَّثَنَا يَحْيَى بْنُ زَكَرِيَّاءَ بْنِ أَبِي زَائِدَةَ، ح وَحَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ حَدَّثَنَا مُعَاوِيَةُ بْنُ هِشَامٍ، حَدَّثَنَا سُفْيَانُ، كِلاَهُمَا عَنْ دَاوُدَ، بِهَذَا الإِسْنَادِ ‏.‏ بَعْضَ هَذَا الْحَدِيثِ ‏.‏ غَيْرَ أَنَّ فِي حَدِيثِ سُفْيَانَ فَاعْتَرَفَ بِالزِّنَى ثَلاَثَ مَرَّاتٍ ‏.‏", "bengali": "", "english": "\" He made a confession of having committed adultery, thrice.\"", "french": "", "indonesian": "", "russian": "", "urdu": "وکیع اور عبدالرحمان  ( بن مہدی )  دونوں نے سفیان سے حدیث بیان کی ،  انہوں نے فراس سے شعبہ اور ابو عو", "grades": "", "reference": "", "international_number": "4300", "narrator_chain": "This hadith has been narrated on the authority of Dawud with the same chain of transmitters but with this variation that in the hadith narrated by Sufyan (the words are):", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4301", "arabic": "وَحَدَّثَنَا مُحَمَّدُ بْنُ الْعَلاَءِ الْهَمْدَانِيُّ، حَدَّثَنَا يَحْيَى بْنُ يَعْلَى، - وَهُوَ ابْنُ الْحَارِثِ الْمُحَارِبِيُّ - عَنْ غَيْلاَنَ، - وَهُوَ ابْنُ جَامِعٍ الْمُحَارِبِيُّ - عَنْ عَلْقَمَةَ بْنِ مَرْثَدٍ، عَنْ سُلَيْمَانَ، بْنِ بُرَيْدَةَ عَنْ أَبِيهِ، قَالَ جَاءَ مَاعِزُ بْنُ مَالِكٍ إِلَى النَّبِيِّ صلى الله عليه وسلم فَقَالَ يَا رَسُولَ اللَّهِ طَهِّرْنِي ‏.‏ فَقَالَ ‏\"‏ وَيْحَكَ ارْجِعْ فَاسْتَغْفِرِ اللَّهَ وَتُبْ إِلَيْهِ ‏\"‏ ‏.‏ قَالَ فَرَجَعَ غَيْرَ بَعِيدٍ ثُمَّ جَاءَ فَقَالَ يَا رَسُولَ اللَّهِ طَهِّرْنِي ‏.‏ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ وَيْحَكَ ارْجِعْ فَاسْتَغْفِرِ اللَّهَ وَتُبْ إِلَيْهِ ‏\"‏ ‏.‏ قَالَ فَرَجَعَ غَيْرَ بَعِيدٍ ثُمَّ جَاءَ فَقَالَ يَا رَسُولَ اللَّهِ طَهِّرْنِي ‏.‏ فَقَالَ النَّبِيُّ صلى الله عليه وسلم مِثْلَ ذَلِكَ حَتَّى إِذَا كَانَتِ الرَّابِعَةُ قَالَ لَهُ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ فِيمَ أُطَهِّرُكَ ‏\"‏ ‏.‏ فَقَالَ مِنَ الزِّنَى ‏.‏ فَسَأَلَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ أَبِهِ جُنُونٌ ‏\"‏ ‏.‏ فَأُخْبِرَ أَنَّهُ لَيْسَ بِمَجْنُونٍ ‏.‏ فَقَالَ ‏\"‏ أَشَرِبَ خَمْرًا ‏\"‏ ‏.‏ فَقَامَ رَجُلٌ فَاسْتَنْكَهَهُ فَلَمْ يَجِدْ مِنْهُ رِيحَ خَمْرٍ ‏.‏ قَالَ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ أَزَنَيْتَ ‏\"‏ ‏.‏ فَقَالَ نَعَمْ ‏.‏ فَأَمَرَ بِهِ فَرُجِمَ فَكَانَ النَّاسُ فِيهِ فِرْقَتَيْنِ قَائِلٌ يَقُولُ لَقَدْ هَلَكَ لَقَدْ أَحَاطَتْ بِهِ خَطِيئَتُهُ وَقَائِلٌ يَقُولُ مَا تَوْبَةٌ أَفْضَلَ مِنْ تَوْبَةِ مَاعِزٍ أَنَّهُ جَاءَ إِلَى النَّبِيِّ صلى الله عليه وسلم فَوَضَعَ يَدَهُ فِي يَدِهِ ثُمَّ قَالَ اقْتُلْنِي بِالْحِجَارَةِ - قَالَ - فَلَبِثُوا بِذَلِكَ يَوْمَيْنِ أَوْ ثَلاَثَةً ثُمَّ جَاءَ رَسُولُ اللَّهِ صلى الله عليه وسلم وَهُمْ جُلُوسٌ فَسَلَّمَ ثُمَّ جَلَسَ فَقَالَ ‏\"‏ اسْتَغْفِرُوا لِمَاعِزِ بْنِ مَالِكٍ ‏\"‏ ‏.‏ قَالَ فَقَالُوا غَفَرَ اللَّهُ لِمَاعِزِ بْنِ مَالِكٍ ‏.‏ - قَالَ - فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ لَقَدْ تَابَ تَوْبَةً لَوْ قُسِمَتْ بَيْنَ أُمَّةٍ لَوَسِعَتْهُمْ ‏\"‏ ‏.‏ قَالَ ثُمَّ جَاءَتْهُ امْرَأَةٌ مِنْ غَامِدٍ مِنَ الأَزْدِ فَقَالَتْ يَا رَسُولَ اللَّهِ طَهِّرْنِي ‏.‏ فَقَالَ ‏\"‏ وَيْحَكِ ارْجِعِي فَاسْتَغْفِرِي اللَّهَ وَتُوبِي إِلَيْهِ ‏\"‏ ‏.‏ فَقَالَتْ أَرَاكَ تُرِيدُ أَنْ تُرَدِّدَنِي كَمَا رَدَّدْتَ مَاعِزَ بْنَ مَالِكٍ ‏.‏ قَالَ ‏\"‏ وَمَا ذَاكِ ‏\"‏ ‏.‏ قَالَتْ إِنَّهَا حُبْلَى مِنَ الزِّنَا ‏.‏ فَقَالَ ‏\"‏ آنْتِ ‏\"‏ ‏.‏ قَالَتْ نَعَمْ ‏.‏ فَقَالَ لَهَا ‏\"‏ حَتَّى تَضَعِي مَا فِي بَطْنِكِ ‏\"‏ ‏.‏ قَالَ فَكَفَلَهَا رَجُلٌ مِنَ الأَنْصَارِ حَتَّى وَضَعَتْ قَالَ فَأَتَى النَّبِيَّ صلى الله عليه وسلم فَقَالَ قَدْ وَضَعَتِ الْغَامِدِيَّةُ ‏.‏ فَقَالَ ‏\"‏ إِذًا لاَ نَرْجُمَهَا وَنَدَعَ وَلَدَهَا صَغِيرًا لَيْسَ لَهُ مَنْ يُرْضِعُهُ ‏\"‏ ‏.‏ فَقَامَ رَجُلٌ مِنَ الأَنْصَارِ فَقَالَ إِلَىَّ رَضَاعُهُ يَا نَبِيَّ اللَّهِ ‏.‏ قَالَ فَرَجَمَهَا ‏.‏", "bengali": "", "english": "Messenger of Allah, purify me, whereupon he said: Woe be upon you, go back, ask forgiveness of Allah and turn to Him in repentance. He (the narrator) said that he went back not far, then came and said: Allah's Messenger, purify me. whereupon Allah's Messenger (ﷺ) said: Woe be upon you, go back and ask forgiveness of Allah and turn to Him in repentance. He (the narrator) said that he went back not far, when he came and said: Allah's Messenger, purify me. Allah's Apostle (ﷺ) said as he had said before. When it was the fourth time, Allah's Messenger (may, peace be upon him) said: From what am I to purify you? He said: From adultery, Allah's Messenger (ﷺ) asked if he had been mad. He was informed that he was not mad. He said: Has he drunk wine? A person stood up and smelt his breath but noticed no smell of wine. Thereupon Allah's Messenger (ﷺ) said: Have you committed adultery? He said: Yes. He made pronouncement about him and he was stoned to death. The people had been (divided) into two groups about him (Ma'iz). One of them said: He has been undone for his sins had encompassed him, whereas another said: There is no repentance more excellent than the repentance of Ma'iz, for he came to Allah's Apostle (ﷺ) and placing his hand in his (in the Holy Prophet's) hand said: Kill me with stones. (This controversy about Ma'iz) remained for two or three days. Then came Allah's Messenger (ﷺ) to them (his Companions) as they were sitting. He greeted them with salutation and then sat down and said: Ask forgiveness for Ma'iz b. Malik. They said: May Allah forgive Ma'iz b. Malik. Thereupon Allah's Messenger (ﷺ) said: He (Ma'iz) has made such a repentance that if that were to be divided among a people, it would have been enough for all of them. He (the narrator) said: Then a woman of Ghamid, a branch of Azd, came to him and said: Messenger of of Allah, purify me, whereupon he said: Woe be upon you; go back and beg forgiveness from Allah and turn to Him in repentance. She said: I find that you intend to send me back as you sent back Ma'iz. b. Malik. He (the Holy, Prophet) said: What has happened to you? She said that she had become pregnant as a result of fornication. He (the Holy Prophet) said: Is it you (who has done that)? She said: Yes. He (the Holy Prophet) said to her: (You will not be punished) until you deliver what is there in your womb. One of the Ansar became responsible for her until she was delivered (of the child). He (that Ansari) came to Allah's Apostle (ﷺ) and said the woman of Ghamid has given birth to a child. He (the Holy Prophet) said: In that case we shall not stone her and so leave her infant with none to suckle him. One of the Ansar got up and said: Allah's Apostle, let the responsibility of his suckling be upon me. She was then stoned to death.", "french": "", "indonesian": "", "russian": "", "urdu": "معاویہ بن سوید  ( بن مُقرن )  سے روایت ہے ،  انہوں نے کہا :  میں نے اپنے ایک غلام کو طمانچہ مارا اور", "grades": "", "reference": "", "international_number": "4301", "narrator_chain": "Sulaiman b. Buraida reported on the authority of his father that Ma, iz b. Malik came to Allah's Apostle (ﷺ) and said to him:", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4302", "arabic": "وَحَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، ح وَحَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ، اللَّهِ بْنِ نُمَيْرٍ - وَتَقَارَبَا فِي لَفْظِ الْحَدِيثِ - حَدَّثَنَا أَبِي، حَدَّثَنَا بَشِيرُ بْنُ الْمُهَاجِرِ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ بُرَيْدَةَ، عَنْ أَبِيهِ، أَنَّ مَاعِزَ بْنَ مَالِكٍ الأَسْلَمِيَّ، أَتَى رَسُولَ اللَّهِ صلى الله عليه وسلم فَقَالَ يَا رَسُولَ اللَّهِ إِنِّي قَدْ ظَلَمْتُ نَفْسِي وَزَنَيْتُ وَإِنِّي أُرِيدُ أَنْ تُطَهِّرَنِي ‏.‏ فَرَدَّهُ فَلَمَّا كَانَ مِنَ الْغَدِ أَتَاهُ فَقَالَ يَا رَسُولَ اللَّهِ إِنِّي قَدْ زَنَيْتُ ‏.‏ فَرَدَّهُ الثَّانِيَةَ فَأَرْسَلَ رَسُولُ اللَّهِ صلى الله عليه وسلم إِلَى قَوْمِهِ فَقَالَ ‏\"‏ أَتَعْلَمُونَ بِعَقْلِهِ بَأْسًا تُنْكِرُونَ مِنْهُ شَيْئًا ‏\"‏ ‏.‏ فَقَالُوا مَا نَعْلَمُهُ إِلاَّ وَفِيَّ الْعَقْلِ مِنْ صَالِحِينَا فِيمَا نُرَى فَأَتَاهُ الثَّالِثَةَ فَأَرْسَلَ إِلَيْهِمْ أَيْضًا فَسَأَلَ عَنْهُ فَأَخْبَرُوهُ أَنَّهُ لاَ بَأْسَ بِهِ وَلاَ بِعَقْلِهِ فَلَمَّا كَانَ الرَّابِعَةَ حَفَرَ لَهُ حُفْرَةً ثُمَّ أَمَرَ بِهِ فَرُجِمَ ‏.‏ قَالَ فَجَاءَتِ الْغَامِدِيَّةُ فَقَالَتْ يَا رَسُولَ اللَّهِ إِنِّي قَدْ زَنَيْتُ فَطَهِّرْنِي ‏.‏ وَإِنَّهُ رَدَّهَا فَلَمَّا كَانَ الْغَدُ قَالَتْ يَا رَسُولَ اللَّهِ لِمَ تَرُدُّنِي لَعَلَّكَ أَنْ تَرُدَّنِي كَمَا رَدَدْتَ مَاعِزًا فَوَاللَّهِ إِنِّي لَحُبْلَى ‏.‏ قَالَ ‏\"‏ إِمَّا لاَ فَاذْهَبِي حَتَّى تَلِدِي ‏\"‏ ‏.‏ فَلَمَّا وَلَدَتْ أَتَتْهُ بِالصَّبِيِّ فِي خِرْقَةٍ قَالَتْ هَذَا قَدْ وَلَدْتُهُ ‏.‏ قَالَ ‏\"‏ اذْهَبِي فَأَرْضِعِيهِ حَتَّى تَفْطِمِيهِ ‏\"‏ ‏.‏ فَلَمَّا فَطَمَتْهُ أَتَتْهُ بِالصَّبِيِّ فِي يَدِهِ كِسْرَةُ خُبْزٍ فَقَالَتْ هَذَا يَا نَبِيَّ اللَّهِ قَدْ فَطَمْتُهُ وَقَدْ أَكَلَ الطَّعَامَ ‏.‏ فَدَفَعَ الصَّبِيَّ إِلَى رَجُلٍ مِنَ الْمُسْلِمِينَ ثُمَّ أَمَرَ بِهَا فَحُفِرَ لَهَا إِلَى صَدْرِهَا وَأَمَرَ النَّاسَ فَرَجَمُوهَا فَيُقْبِلُ خَالِدُ بْنُ الْوَلِيدِ بِحَجَرٍ فَرَمَى رَأْسَهَا فَتَنَضَّحَ الدَّمُ عَلَى وَجْهِ خَالِدٍ فَسَبَّهَا فَسَمِعَ نَبِيُّ اللَّهِ صلى الله عليه وسلم سَبَّهُ إِيَّاهَا فَقَالَ ‏\"‏ مَهْلاً يَا خَالِدُ فَوَالَّذِي نَفْسِي بِيَدِهِ لَقَدْ تَابَتْ تَوْبَةً لَوْ تَابَهَا صَاحِبُ مَكْسٍ لَغُفِرَ لَهُ ‏\"‏ ‏.‏ ثُمَّ أَمَرَ بِهَا فَصَلَّى عَلَيْهَا وَدُفِنَتْ ‏.‏", "bengali": "", "english": "Allah's Messenger, I have wronged myself; I have committed adultery and I earnestly desire that you should purify me. He turned him away. On the following day, he (Ma'iz) again came to him and said: Allah's Messenger, I have committed adultery. Allah's Messenger (ﷺ) turned him away for the second time, and sent him to his people saying: Do you know if there is anything wrong with his mind. They denied of any such thing in him and said: We do not know him but as a wise good man among us, so far as we can judge. He (Ma'iz) came for the third time, and he (the Holy Prophet) sent him as he had done before. He asked about him and they informed him that there was nothing wrong with him or with his mind. When it was the fourth time, a ditch was dug for him and he (the Holy Prophet) pronounced judg- ment about him and he wis stoned. He (the narrator) said: There came to him (the Holy Prophet) a woman from Ghamid and said: Allah's Messenger, I have committed adultery, so purify me. He (the Holy Prophet) turned her away. On the following day she said: Allah's Messenger, Why do you turn me away? Perhaps, you turn me away as you turned away Ma'iz. By Allah, I have become pregnant. He said: Well, if you insist upon it, then go away until you give birth to (the child). When she was delivered she came with the child (wrapped) in a rag and said: Here is the child whom I have given birth to. He said: Go away and suckle him until you wean him. When she had weaned him, she came to him (the Holy Prophet) with the child who was holding a piece of bread in his hand. She said: Allah's Apostle, here is he as I have weaned him and he eats food. He (the Holy Prophet) entrusted the child to one of the Muslims and then pronounced punishment. And she was put in a ditch up to her chest and he commanded people and they stoned her. Khalid b Walid came forward with a stone which he flung at her head and there spurted blood on the face of Khalid and so he abused her. Allah's Apostle (ﷺ) heard his (Khalid's) curse that he had huried upon her. Thereupon he (the Holy Prophet) said: Khalid, be gentle. By Him in Whose Hand is my life, she has made such a repentance that even if a wrongful tax-collector were to repent, he would have been forgiven. Then giving command regarding her, he prayed over her and she was buried.", "french": "", "indonesian": "", "russian": "", "urdu": "ابن ادریس نے ہمیں حصین سے حدیث بیان کی ،  انہوں نے ہلال بن یساف سے روایت کی ،  انہوں نے کہا :  ایک ب", "grades": "", "reference": "", "international_number": "4302", "narrator_chain": "'Abdullah b. Buraida reported on the authority of his father that Ma'iz b. Malik al-Aslami came to Allah's Messenger (ﷺ) and said:", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4303", "arabic": "حَدَّثَنِي أَبُو غَسَّانَ، مَالِكُ بْنُ عَبْدِ الْوَاحِدِ الْمِسْمَعِيُّ حَدَّثَنَا مُعَاذٌ، - يَعْنِي ابْنَ هِشَامٍ - حَدَّثَنِي أَبِي، عَنْ يَحْيَى بْنِ أَبِي كَثِيرٍ، حَدَّثَنِي أَبُو قِلاَبَةَ، أَنَّ أَبَا الْمُهَلَّبِ، حَدَّثَهُ عَنْ عِمْرَانَ، بْنِ حُصَيْنٍ أَنَّ امْرَأَةً، مِنْ جُهَيْنَةَ أَتَتْ نَبِيَّ اللَّهِ صلى الله عليه وسلم وَهِيَ حُبْلَى مِنَ الزِّنَى فَقَالَتْ يَا نَبِيَّ اللَّهِ أَصَبْتُ حَدًّا فَأَقِمْهُ عَلَىَّ فَدَعَا نَبِيُّ اللَّهِ صلى الله عليه وسلم وَلِيَّهَا فَقَالَ ‏\"‏ أَحْسِنْ إِلَيْهَا فَإِذَا وَضَعَتْ فَائْتِنِي بِهَا ‏\"‏ ‏.‏ فَفَعَلَ فَأَمَرَ بِهَا نَبِيُّ اللَّهِ صلى الله عليه وسلم فَشُكَّتْ عَلَيْهَا ثِيَابُهَا ثُمَّ أَمَرَ بِهَا فَرُجِمَتْ ثُمَّ صَلَّى عَلَيْهَا فَقَالَ لَهُ عُمَرُ تُصَلِّي عَلَيْهَا يَا نَبِيَّ اللَّهِ وَقَدْ زَنَتْ فَقَالَ ‏\"‏ لَقَدْ تَابَتْ تَوْبَةً لَوْ قُسِمَتْ بَيْنَ سَبْعِينَ مِنْ أَهْلِ الْمَدِينَةِ لَوَسِعَتْهُمْ وَهَلْ وَجَدْتَ تَوْبَةً أَفْضَلَ مِنْ أَنْ جَادَتْ بِنَفْسِهَا لِلَّهِ تَعَالَى ‏\"‏ ‏.‏", "bengali": "", "english": "Allah's Apostle, I have done something for which (prescribed punishment) must be imposed upon me, so impose that. Allah's Apostle (ﷺ) called her master and said: Treat her well, and when she delivers bring her to me. He did accordingly. Then Allah's Apostle (ﷺ) pronounced judgment about her and her clothes were tied around her and then he commanded and she was stoned to death. He then prayed over her (dead body). Thereupon Umar said to him: Allah's Apostle, you offer prayer for her, whereas she had committed adultery! Thereupon he said: She has made such a repentance that if it were to be divided among seventy men of Medina, it would be enough. Have you found any repentance better than this that she sacr ficed her life for Allah, the Majestic?", "french": "", "indonesian": "", "russian": "", "urdu": "ہلال ‌بن ‌یساف ‌رضی ‌اللہ ‌عنہ ‌سے ‌روایت ‌ہے ‌ہم ‌كپڑا ‌بیچتے ‌تھے ‌سوید ‌بن ‌مقرن ‌كے ‌گھر ‌میں ‌ج", "grades": "", "reference": "", "international_number": "4303", "narrator_chain": "Imran b. Husain reported that a woman from Juhaina came to Allah's Apostle (ﷺ) and she had become pregnant because of adultery. She said:", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4304", "arabic": "وَحَدَّثَنَاهُ أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَفَّانُ بْنُ مُسْلِمٍ، حَدَّثَنَا أَبَانٌ الْعَطَّارُ، حَدَّثَنَا يَحْيَى بْنُ أَبِي كَثِيرٍ، بِهَذَا الإِسْنَادِ مِثْلَهُ ‏.‏", "bengali": "", "english": "This hadith has been transmitted on the authority of Yahya b. Abu Kathir.", "french": "", "indonesian": "", "russian": "", "urdu": "عبدالصمد نے ہمیں حدیث سنائی ،  کہا :  ہمیں شعبہ نے حدیث سنائی ،  کہا :  مجھ سے محمد بن منکدر نے کہا", "grades": "", "reference": "", "international_number": "4304", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4305", "arabic": "حَدَّثَنَا قُتَيْبَةُ بْنُ سَعِيدٍ، حَدَّثَنَا لَيْثٌ، ح وَحَدَّثَنَاهُ مُحَمَّدُ بْنُ رُمْحٍ، أَخْبَرَنَا اللَّيْثُ، عَنِ ابْنِ شِهَابٍ، عَنْ عُبَيْدِ اللَّهِ بْنِ عَبْدِ اللَّهِ بْنِ عُتْبَةَ بْنِ مَسْعُودٍ، عَنْ أَبِي هُرَيْرَةَ، وَزَيْدِ بْنِ خَالِدٍ، الْجُهَنِيِّ أَنَّهُمَا قَالاَ إِنَّ رَجُلاً مِنَ الأَعْرَابِ أَتَى رَسُولَ اللَّهِ صلى الله عليه وسلم فَقَالَ يَا رَسُولَ اللَّهِ أَنْشُدُكَ اللَّهَ إِلاَّ قَضَيْتَ لِي بِكِتَابِ اللَّهِ ‏.‏ فَقَالَ الْخَصْمُ الآخَرُ وَهُوَ أَفْقَهُ مِنْهُ نَعَمْ فَاقْضِ بَيْنَنَا بِكِتَابِ اللَّهِ وَائْذَنْ لِي ‏.‏ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ قُلْ ‏\"‏ ‏.‏ قَالَ إِنَّ ابْنِي كَانَ عَسِيفًا عَلَى هَذَا فَزَنَى بِامْرَأَتِهِ وَإِنِّي أُخْبِرْتُ أَنَّ عَلَى ابْنِي الرَّجْمَ فَافْتَدَيْتُ مِنْهُ بِمِائَةِ شَاةٍ وَوَلِيدَةٍ فَسَأَلْتُ أَهْلَ الْعِلْمِ فَأَخْبَرُونِي أَنَّمَا عَلَى ابْنِي جَلْدُ مِائَةٍ وَتَغْرِيبُ عَامٍ وَأَنَّ عَلَى امْرَأَةِ هَذَا الرَّجْمَ ‏.‏ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ وَالَّذِي نَفْسِي بِيَدِهِ لأَقْضِيَنَّ بَيْنَكُمَا بِكِتَابِ اللَّهِ الْوَلِيدَةُ وَالْغَنَمُ رَدٌّ وَعَلَى ابْنِكَ جَلْدُ مِائَةٍ وَتَغْرِيبُ عَامٍ وَاغْدُ يَا أُنَيْسُ إِلَى امْرَأَةِ هَذَا فَإِنِ اعْتَرَفَتْ فَارْجُمْهَا ‏\"‏ ‏.‏ قَالَ فَغَدَا عَلَيْهَا فَاعْتَرَفَتْ فَأَمَرَ بِهَا رَسُولُ اللَّهِ صلى الله عليه وسلم فَرُجِمَتْ ‏.‏", "bengali": "", "english": "Messenger of Allah, I beg of you in the name of Allah that you pronounce judgment about me according to the Book of Allah. The second claimant who was wiser than him said: Well, decide amongst us according to the Book of Allah, but permit me (to say something). Thereupon Allah's Messenger (may peace be upon ham) said: Say. He said: My son was a servant in the house of this person and he committed adultery with his wife. I was informed that my son deserved stoning to death (as punishment for this offence). I gave one hundred goats and a slave girl as ransom for this. I asked the scholars (if this could serve as an expiation for this offence). They informed me that my son deserved one hundred lathes and exile for one year. and this woman deserved stoning (as she was married). Thereupon Allah's Messenger (may peace he upon him) said: By Him in Whose Hand is my life. I will decide between you according to the Book of Allah. The slave-girl and the goats should be given back, and your son is to be punished with one hundred lashes and exile for one year. And, O Unais (b. Zuhaq al-Aslami), go to this woman in the morning, and if she makes a confession, then stone her. He (the narrator) said: He went to her in the morning and she made a confession. And Allah's Messenger (ﷺ) made pronouncement about her and she was stoned to death.", "french": "", "indonesian": "", "russian": "", "urdu": "وہب بن جریر نے کہا :  ہمیں شعبہ نے خبر دی کہ محمد بن منکدر نے مجھ سے پوچھا :  تمہارا نام کیا ہے؟ آگے", "grades": "", "reference": "", "international_number": "4305", "narrator_chain": "Abu Huraira and Zaid b Khalid al-Juhani reported that one of the desert tribes came to Allah's Messenger (ﷺ) and said:", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4306", "arabic": "وَحَدَّثَنِي أَبُو الطَّاهِرِ، وَحَرْمَلَةُ، قَالاَ أَخْبَرَنَا ابْنُ وَهْبٍ، أَخْبَرَنِي يُونُسُ، ح وَحَدَّثَنِي عَمْرٌو النَّاقِدُ، حَدَّثَنَا يَعْقُوبُ بْنُ إِبْرَاهِيمَ بْنِ سَعْدٍ، حَدَّثَنَا أَبِي، عَنْ صَالِحٍ، ح وَحَدَّثَنَا عَبْدُ، بْنُ حُمَيْدٍ أَخْبَرَنَا عَبْدُ الرَّزَّاقِ، عَنْ مَعْمَرٍ، كُلُّهُمْ عَنِ الزُّهْرِيِّ، بِهَذَا الإِسْنَادِ ‏.‏ نَحْوَهُ ‏.‏", "bengali": "", "english": "This hadith has been narrated on the authority of Zuhri with the same chain of transmitters.", "french": "", "indonesian": "", "russian": "", "urdu": "عبدالواحد بن زیاد نے ہمیں حدیث بیان کی ،  کہا :  ہمیں اعمش نے ابراہیم تیمی سے حدیث سنائی ،  انہوں نے", "grades": "", "reference": "", "international_number": "4306", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4307", "arabic": "حَدَّثَنِي الْحَكَمُ بْنُ مُوسَى أَبُو صَالِحٍ، حَدَّثَنَا شُعَيْبُ بْنُ إِسْحَاقَ، أَخْبَرَنَا عُبَيْدُ اللَّهِ، عَنْ نَافِعٍ، أَنَّ عَبْدَ اللَّهِ بْنَ عُمَرَ، أَخْبَرَهُ أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم أُتِيَ بِيَهُودِيٍّ وَيَهُودِيَّةٍ قَدْ زَنَيَا فَانْطَلَقَ رَسُولُ اللَّهِ صلى الله عليه وسلم حَتَّى جَاءَ يَهُودَ فَقَالَ ‏\"‏ مَا تَجِدُونَ فِي التَّوْرَاةِ عَلَى مَنْ زَنَى ‏\"‏ ‏.‏ قَالُوا نُسَوِّدُ وُجُوهَهُمَا وَنُحَمِّلُهُمَا وَنُخَالِفُ بَيْنَ وُجُوهِهِمَا وَيُطَافُ بِهِمَا ‏.‏ قَالَ ‏\"‏ فَأْتُوا بِالتَّوْرَاةِ إِنْ كُنْتُمْ صَادِقِينَ ‏\"‏ ‏.‏ فَجَاءُوا بِهَا فَقَرَءُوهَا حَتَّى إِذَا مَرُّوا بِآيَةِ الرَّجْمِ وَضَعَ الْفَتَى الَّذِي يَقْرَأُ يَدَهُ عَلَى آيَةِ الرَّجْمِ وَقَرَأَ مَا بَيْنَ يَدَيْهَا وَمَا وَرَاءَهَا فَقَالَ لَهُ عَبْدُ اللَّهِ بْنُ سَلاَمٍ وَهْوَ مَعَ رَسُولِ اللَّهِ صلى الله عليه وسلم مُرْهُ فَلْيَرْفَعْ يَدَهُ فَرَفَعَهَا فَإِذَا تَحْتَهَا آيَةُ الرَّجْمِ فَأَمَرَ بِهِمَا رَسُولُ اللَّهِ صلى الله عليه وسلم فَرُجِمَا ‏.‏ قَالَ عَبْدُ اللَّهِ بْنُ عُمَرَ كُنْتُ فِيمَنْ رَجَمَهُمَا فَلَقَدْ رَأَيْتُهُ يَقِيهَا مِنَ الْحِجَارَةِ بِنَفْسِهِ ‏.‏", "bengali": "", "english": "What do you find in Torah for one who commits adultery? They said: We darken their faces and make them ride on the donkey with their faces turned to the opposite direction (and their backs touching each other), and then they are taken round (the city). He said: Bring Torah if you are truthful. They brought it and recited it until when they came to the verse pertaining to stoning, the person who was reading placed his hand on the verse pertaining to stoning, and read (only that which was) between his hands and what was subsequent to that. Abdullah b. Salim who was at that time with the Messenger of Allah (ﷺ) said: Command him (the reciter) to lift his hand. He lifted it and there was, underneath that, the verse pertaining to stoning. Allah's Messenger (ﷺ) pronounced judgment about both of them and they were stoned. Abdullah b. 'Umar said: I was one of those who stoned them, and I saw him (the Jew) protecting her (the Jewess) with his body.", "french": "", "indonesian": "", "russian": "", "urdu": "جریر ،  سفیان اور ابوعوانہ سب نے اعمش سے عبدالواحد کی  ( سابقہ )  سند کے ساتھ اس کی حدیث کے ہم معنی", "grades": "", "reference": "", "international_number": "4307", "narrator_chain": "Abdullah b. 'Umar reported that a Jew and a Jewess were brought to Allah's Messenger (ﷺ) who had committed adultery. Allah's Messenger (ﷺ) came to the Jews and said:", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4308", "arabic": "وَحَدَّثَنَا زُهَيْرُ بْنُ حَرْبٍ، حَدَّثَنَا إِسْمَاعِيلُ، - يَعْنِي ابْنَ عُلَيَّةَ - عَنْ أَيُّوبَ، ح وَحَدَّثَنِي أَبُو الطَّاهِرِ، أَخْبَرَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، أَخْبَرَنِي رِجَالٌ، مِنْ أَهْلِ الْعِلْمِ مِنْهُمْ مَالِكُ بْنُ أَنَسٍ أَنَّ نَافِعًا، أَخْبَرَهُمْ عَنِ ابْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم رَجَمَ فِي الزِّنَى يَهُودِيَّيْنِ رَجُلاً وَامْرَأَةً زَنَيَا فَأَتَتِ الْيَهُودُ إِلَى رَسُولِ اللَّهِ صلى الله عليه وسلم بِهِمَا ‏.‏ وَسَاقُوا الْحَدِيثَ بِنَحْوِهِ ‏.‏", "bengali": "", "english": "Ibn Umar reported that Allah's Messenger (ﷺ) stoned to death the Jews, both male and female, who had committed adultery. The Jews brought them to Allah's Messenger (may peace he upon him). The rest of the hadith is the same.", "french": "", "indonesian": "", "russian": "", "urdu": "ابومعاویہ نے ہمیں حدیث بیان کی ،  کہا :  ہمیں اعمش نے ابراہیم تیمی سے حدیث بیان کی ،  انہوں نے اپنے", "grades": "", "reference": "", "international_number": "4308", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4309", "arabic": "وَحَدَّثَنَا أَحْمَدُ بْنُ يُونُسَ، حَدَّثَنَا زُهَيْرٌ، حَدَّثَنَا مُوسَى بْنُ عُقْبَةَ، عَنْ نَافِعٍ، عَنِ ابْنِ، عُمَرَ أَنَّ الْيَهُودَ، جَاءُوا إِلَى رَسُولِ اللَّهِ صلى الله عليه وسلم بِرَجُلٍ مِنْهُمْ وَامْرَأَةٍ قَدْ زَنَيَا ‏.‏ وَسَاقَ الْحَدِيثَ بِنَحْوِ حَدِيثِ عُبَيْدِ اللَّهِ عَنْ نَافِعٍ ‏.‏", "bengali": "", "english": "Ibn 'Umar reported that the Jews brought to Allah's Messenger (ﷺ) a man and a woman who had committed adultery. The rest of the hadith is the same.", "french": "", "indonesian": "", "russian": "", "urdu": "ابن ابی عدی نے شعبہ سے ،  انہوں نے سلیمان سے ،  انہوں نے ابراہیم تیمی سے ،  انہوں نے اپنے والد سے او", "grades": "", "reference": "", "international_number": "4309", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4310", "arabic": "حَدَّثَنَا يَحْيَى بْنُ يَحْيَى، وَأَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ كِلاَهُمَا عَنْ أَبِي مُعَاوِيَةَ، قَالَ يَحْيَى أَخْبَرَنَا أَبُو مُعَاوِيَةَ، عَنِ الأَعْمَشِ، عَنْ عَبْدِ اللَّهِ بْنِ مُرَّةَ، عَنِ الْبَرَاءِ بْنِ عَازِبٍ، قَالَ مُرَّ عَلَى النَّبِيِّ صلى الله عليه وسلم بِيَهُودِيٍّ مُحَمَّمًا مَجْلُودًا فَدَعَاهُمْ صلى الله عليه وسلم فَقَالَ ‏\"‏ هَكَذَا تَجِدُونَ حَدَّ الزَّانِي فِي كِتَابِكُمْ ‏\"‏ ‏.‏ قَالُوا نَعَمْ ‏.‏ فَدَعَا رَجُلاً مِنْ عُلَمَائِهِمْ فَقَالَ ‏\"‏ أَنْشُدُكَ بِاللَّهِ الَّذِي أَنْزَلَ التَّوْرَاةَ عَلَى مُوسَى أَهَكَذَا تَجِدُونَ حَدَّ الزَّانِي فِي كِتَابِكُمْ ‏\"‏ ‏.‏ قَالَ لاَ وَلَوْلاَ أَنَّكَ نَشَدْتَنِي بِهَذَا لَمْ أُخْبِرْكَ نَجِدُهُ الرَّجْمَ وَلَكِنَّهُ كَثُرَ فِي أَشْرَافِنَا فَكُنَّا إِذَا أَخَذْنَا الشَّرِيفَ تَرَكْنَاهُ وَإِذَا أَخَذْنَا الضَّعِيفَ أَقَمْنَا عَلَيْهِ الْحَدَّ قُلْنَا تَعَالَوْا فَلْنَجْتَمِعْ عَلَى شَىْءٍ نُقِيمُهُ عَلَى الشَّرِيفِ وَالْوَضِيعِ فَجَعَلْنَا التَّحْمِيمَ وَالْجَلْدَ مَكَانَ الرَّجْمِ ‏.‏ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ اللَّهُمَّ إِنِّي أَوَّلُ مَنْ أَحْيَا أَمْرَكَ إِذْ أَمَاتُوهُ ‏\"‏ ‏.‏ فَأَمَرَ بِهِ فَرُجِمَ فَأَنْزَلَ اللَّهُ عَزَّ وَجَلَّ ‏{‏ يَا أَيُّهَا الرَّسُولُ لاَ يَحْزُنْكَ الَّذِينَ يُسَارِعُونَ فِي الْكُفْرِ‏}‏ إِلَى قَوْلِهِ ‏{‏ إِنْ أُوتِيتُمْ هَذَا فَخُذُوهُ‏}‏ يَقُولُ ائْتُوا مُحَمَّدًا صلى الله عليه وسلم فَإِنْ أَمَرَكُمْ بِالتَّحْمِيمِ وَالْجَلْدِ فَخُذُوهُ وَإِنْ أَفْتَاكُمْ بِالرَّجْمِ فَاحْذَرُوا ‏.‏ فَأَنْزَلَ اللَّهُ تَعَالَى ‏{‏ وَمَنْ لَمْ يَحْكُمْ بِمَا أَنْزَلَ اللَّهُ فَأُولَئِكَ هُمُ الْكَافِرُونَ‏}‏ ‏{‏ وَمَنْ لَمْ يَحْكُمْ بِمَا أَنْزَلَ اللَّهُ فَأُولَئِكَ هُمُ الظَّالِمُونَ‏}‏ ‏{‏ وَمَنْ لَمْ يَحْكُمْ بِمَا أَنْزَلَ اللَّهُ فَأُولَئِكَ هُمُ الْفَاسِقُونَ‏}‏ فِي الْكُفَّارِ كُلُّهَا ‏.‏", "bengali": "", "english": "There happened to pass by Allah's Apostle (ﷺ) a Jew blackened and lashed. Allah's Apostle (ﷺ) called them (the Jews) and said: Is this the punishment that you find in your Book (Torah) as a prescribed punishment for adultery? They said: Yes. He (the Holy Prophet) called one of the scholars amongst them and said: I ask you in the name of Allah Who sent down the Torah on Moses if that is the prescribed punishment for adultery that you find in your Book. He said: No. Had you not asked me in the name of Allah, I would not have given you this information. We find stoning to death (as punishment prescribed in the Torah). But this (crime) became quite common amongst our aristocratic class. So when we caught hold of any rich person (indulging in this offence) we spared him, but when we caught hold of a helpless person we imposed the prescribed punishment upon him. We then said: Let us argree (on a punishment) which we can inflict both upon the rich and the poor. So We decided to blacken the face with coal and flog as a substitute punishment for stoning. Thereupon Allah's Messenger (ﷺ) said: O Allah, I am the first to revive Thy command when they had made it dead. He then commanded and he (the offender) was stoned to death. Allah, the Majestic and Glorious, sent down (this verse):\" O Messenger, (the behaviour of) those who vie with one another in denying the truth should not grieve you...\" up to\" is vouchsafed unto you, accept it\" (v. 41) 2176 It was said (by the Jews): Go to Muhammad; it he commands you to blacken the face and award flogging (as punishment for adultery), then accept it, but it he gives verdict for stoning, then avoid it. It was (then) that Allah, the Majestic and Great, sent down (these verses):\" And they who do not judge in accordance with what Allah has revealed are, indeed, deniers of the truth\" (v. 44) ;\" And they who do not judge in accordance with what Allah has revealed-they, they indeed are the wrongdoers\" (v. 45) ;\" And they who do not judge in accordance with what God has revealed-they are the iniquitous (v. 47). (All these verses) were revealed in connection with the non-believers.", "french": "", "indonesian": "", "russian": "", "urdu": "محمد بن جعفر نے ہمیں شعبہ سے ،  اسی سند کے ساتھ خبر دی اور انہوں نے یہ الفاظ بیان نہیں کیے :   \" میں", "grades": "", "reference": "", "international_number": "4310", "narrator_chain": "Al-Bara' b. 'Azib reported:", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4311", "arabic": "حَدَّثَنَا ابْنُ نُمَيْرٍ، وَأَبُو سَعِيدٍ الأَشَجُّ قَالاَ حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا الأَعْمَشُ، بِهَذَا الإِسْنَادِ ‏.‏ نَحْوَهُ إِلَى قَوْلِهِ فَأَمَرَ بِهِ النَّبِيُّ صلى الله عليه وسلم فَرُجِمَ ‏.‏ وَلَمْ يَذْكُرْ مَا بَعْدَهُ مِنْ نُزُولِ الآيَةِ ‏.‏", "bengali": "", "english": "\" Allah's Apostle (ﷺ) pronounced judgment and he was stoned (to death)\" And he mentioned nothing subsequent to that pertaining to the revelation of verses.", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن نمیر نے کہا :  ہمیں فضیل بن غزوان نے حدیث بیان کی ،  انہوں نے کہا :  میں نے عبدالرحمان بن", "grades": "", "reference": "", "international_number": "4311", "narrator_chain": "This hadith has been narrated on the authority of A'mash up to the words:", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4312", "arabic": "وَحَدَّثَنِي هَارُونُ بْنُ عَبْدِ اللَّهِ، حَدَّثَنَا حَجَّاجُ بْنُ مُحَمَّدٍ، قَالَ قَالَ ابْنُ جُرَيْجٍ أَخْبَرَنِي أَبُو الزُّبَيْرِ، أَنَّهُ سَمِعَ جَابِرَ بْنَ عَبْدِ اللَّهِ، يَقُولُ رَجَمَ النَّبِيُّ صلى الله عليه وسلم رَجُلاً مِنْ أَسْلَمَ وَرَجُلاً مِنَ الْيَهُودِ وَامْرَأَتَهُ ‏.‏", "bengali": "", "english": "Jabir b. 'Abdullah reported that Allah's Apostle (ﷺ) stoned (to death) a person from Banu Aslam, and a Jew and his wife.", "french": "", "indonesian": "", "russian": "", "urdu": "وکیع اور اسحاق بن یوسف ازرق دونوں نے فضیل بن غزوان سے اسی سند کے ساتھ حدیث بیان کی اور ان دونوں کی ح", "grades": "", "reference": "", "international_number": "4312", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4313", "arabic": "حَدَّثَنَا إِسْحَاقُ بْنُ إِبْرَاهِيمَ، أَخْبَرَنَا رَوْحُ بْنُ عُبَادَةَ، حَدَّثَنَا ابْنُ جُرَيْجٍ، بِهَذَا الإِسْنَادِ مِثْلَهُ ‏.‏ غَيْرَ أَنَّهُ قَالَ وَامْرَأَةً ‏.‏", "bengali": "", "english": "This hadith has been transmitted on the authority of Juraij with a slight variation of words.", "french": "", "indonesian": "", "russian": "", "urdu": "وکیع نے کہا :  ہمیں اعمش نے معرور بن سوید سے حدیث بیان کی ،  انہوں نے کہا :  ہم زَبذہ  ( کے مقام )", "grades": "", "reference": "", "international_number": "4313", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4314", "arabic": "وَحَدَّثَنَا أَبُو كَامِلٍ الْجَحْدَرِيُّ، حَدَّثَنَا عَبْدُ الْوَاحِدِ، حَدَّثَنَا سُلَيْمَانُ الشَّيْبَانِيُّ، قَالَ سَأَلْتُ عَبْدَ اللَّهِ بْنَ أَبِي أَوْفَى ح. وَحَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، - وَاللَّفْظُ لَهُ - حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ، عَنْ أَبِي، إِسْحَاقَ الشَّيْبَانِيِّ قَالَ سَأَلْتُ عَبْدَ اللَّهِ بْنَ أَبِي أَوْفَى هَلْ رَجَمَ رَسُولُ اللَّهِ صلى الله عليه وسلم قَالَ نَعَمْ ‏.‏ قَالَ قُلْتُ بَعْدَ مَا أُنْزِلَتْ سُورَةُ النُّورِ أَمْ قَبْلَهَا قَالَ لاَ أَدْرِي ‏.‏\"", "bengali": "", "english": "I asked 'Abdullah b. Abu Aufi if Allah's Messenger (ﷺ) awarded (the punishment) of stoning (to death). He said: Yes. I said: After Sura al-Nur was revealed or before that? He said: I do not know.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Ishaq Shaibani said:", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4315", "arabic": "وَحَدَّثَنِي عِيسَى بْنُ حَمَّادٍ الْمِصْرِيُّ، أَخْبَرَنَا اللَّيْثُ، عَنْ سَعِيدِ بْنِ أَبِي سَعِيدٍ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّهُ سَمِعَهُ يَقُولُ سَمِعْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم يَقُولُ ‏ ‏ إِذَا زَنَتْ أَمَةُ أَحَدِكُمْ فَتَبَيَّنَ زِنَاهَا فَلْيَجْلِدْهَا الْحَدَّ وَلاَ يُثَرِّبْ عَلَيْهَا ثُمَّ إِنْ زَنَتْ فَلْيَجْلِدْهَا الْحَدَّ وَلاَ يُثَرِّبْ عَلَيْهَا ثُمَّ إِنْ زَنَتِ الثَّالِثَةَ فَتَبَيَّنَ زِنَاهَا فَلْيَبِعْهَا وَلَوْ بِحَبْلٍ مِنْ شَعَرٍ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "When the slave-woman of any of you commits adultery and this (offence of hers) becomes clear, she should be flogged (as the prescribed) punishment, but hurl no reproach at her. If she commits adultery again, she should (again be punished) by flogging, but hurl no reproach upon her. If she commits fornication for the third time and it becomes clear, then he should sell her, even if only for a rope of hair.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira reported that he heard Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4316", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَإِسْحَاقُ بْنُ إِبْرَاهِيمَ، جَمِيعًا عَنِ ابْنِ عُيَيْنَةَ، ح وَحَدَّثَنَا عَبْدُ بْنُ حُمَيْدٍ، أَخْبَرَنَا مُحَمَّدُ بْنُ بَكْرٍ الْبُرْسَانِيُّ، أَخْبَرَنَا هِشَامُ بْنُ حَسَّانَ، كِلاَهُمَا عَنْ أَيُّوبَ بْنِ مُوسَى، ح وَحَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو أُسَامَةَ، وَابْنُ، نُمَيْرٍ عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، ح وَحَدَّثَنِي هَارُونُ بْنُ سَعِيدٍ الأَيْلِيُّ، حَدَّثَنَا ابْنُ وَهْبٍ، حَدَّثَنِي أُسَامَةُ، بْنُ زَيْدٍ ح وَحَدَّثَنَا هَنَّادُ بْنُ السَّرِيِّ، وَأَبُو كُرَيْبٍ وَإِسْحَاقُ بْنُ إِبْرَاهِيمَ عَنْ عَبْدَةَ بْنِ سُلَيْمَانَ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ، كُلُّ هَؤُلاَءِ عَنْ سَعِيدٍ الْمَقْبُرِيِّ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم إِلاَّ أَنَّ ابْنَ إِسْحَاقَ قَالَ فِي حَدِيثِهِ عَنْ سَعِيدٍ عَنْ أَبِيهِ عَنْ أَبِي هُرَيْرَةَ عَنِ النَّبِيِّ صلى الله عليه وسلم فِي جَلْدِ الأَمَةِ إِذَا زَنَتْ ثَلاَثًا ‏ ‏ ثُمَّ لْيَبِعْهَا فِي الرَّابِعَةِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "This hadith his been narrated on the authority of Abu Huraira through another chain of transmitters with a slight variation of words.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4317", "arabic": "حَدَّثَنَا عَبْدُ اللَّهِ بْنُ مَسْلَمَةَ الْقَعْنَبِيُّ، حَدَّثَنَا مَالِكٌ، ح وَحَدَّثَنَا يَحْيَى بْنُ يَحْيَى، - وَاللَّفْظُ لَهُ - قَالَ قَرَأْتُ عَلَى مَالِكٍ عَنِ ابْنِ شِهَابٍ عَنْ عُبَيْدِ اللَّهِ بْنِ عَبْدِ اللَّهِ عَنْ أَبِي هُرَيْرَةَ أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم سُئِلَ عَنِ الأَمَةِ إِذَا زَنَتْ وَلَمْ تُحْصِنْ قَالَ ‏ ‏ إِنْ زَنَتْ فَاجْلِدُوهَا ثُمَّ إِنْ زَنَتْ فَاجْلِدُوهَا ثُمَّ إِنْ زَنَتْ فَاجْلِدُوهَا ثُمَّ بِيعُوهَا وَلَوْ بِضَفِيرٍ ‏\"\"‏ ‏.‏ قَالَ ابْنُ شِهَابٍ لاَ أَدْرِي أَبَعْدَ الثَّالِثَةِ أَوِ الرَّابِعَةِ ‏.‏ وَقَالَ الْقَعْنَبِيُّ فِي رِوَايَتِهِ قَالَ ابْنُ شِهَابٍ وَالضَّفِيرُ الْحَبْلُ ‏.‏\"", "bengali": "", "english": "If she commits adultery, then flog her and if she commits adultery again, then flog her and then sell her even for a rope. Ibn Shihab said: I do not know whether he said this (his statement pertaining to the sale of slave-woman) at the third or the fourth time. Ibn Shihab said that the word dafir (used in the text) means rope.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira reported that Allah's Messenger (ﷺ) was asked about the slave-woman who committed adultery and was not protected (married). He said:", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4318", "arabic": "وَحَدَّثَنَا أَبُو الطَّاهِرِ، أَخْبَرَنَا ابْنُ وَهْبٍ، قَالَ سَمِعْتُ مَالِكًا، يَقُولُ حَدَّثَنِي ابْنُ شِهَابٍ، عَنْ عُبَيْدِ اللَّهِ بْنِ عَبْدِ اللَّهِ بْنِ عُتْبَةَ، عَنْ أَبِي هُرَيْرَةَ، وَزَيْدِ بْنِ خَالِدٍ الْجُهَنِيِّ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم سُئِلَ عَنِ الأَمَةِ ‏.‏ بِمِثْلِ حَدِيثِهِمَا وَلَمْ يَذْكُرْ قَوْلَ ابْنِ شِهَابٍ وَالضَّفِيرُ الْحَبْلُ ‏.‏", "bengali": "", "english": "This hadith has been narrated on the authority of Abu Huraira and Zaid b. Khalid al-Jubani, but in this no merition is made of the words of Ibn Shihab that dafir means rope.", "french": "", "indonesian": "", "russian": "", "urdu": "امام مالک نے نافع سے اور انہوں نے حضرت ابن عمر رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ علیہ و", "grades": "", "reference": "", "international_number": "4318", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4319", "arabic": "حَدَّثَنِي عَمْرٌو النَّاقِدُ، حَدَّثَنَا يَعْقُوبُ بْنُ إِبْرَاهِيمَ بْنِ سَعْدٍ، حَدَّثَنِي أَبِي، عَنْ صَالِحٍ، ح وَحَدَّثَنَا عَبْدُ بْنُ حُمَيْدٍ، أَخْبَرَنَا عَبْدُ الرَّزَّاقِ، أَخْبَرَنَا مَعْمَرٌ، كِلاَهُمَا عَنِ الزُّهْرِيِّ، عَنْ عُبَيْدِ، اللَّهِ عَنْ أَبِي هُرَيْرَةَ، وَزَيْدِ بْنِ خَالِدٍ الْجُهَنِيِّ، عَنِ النَّبِيِّ صلى الله عليه وسلم ‏.‏ بِمِثْلِ حَدِيثِ مَالِكٍ وَالشَّكُّ فِي حَدِيثِهِمَا جَمِيعًا فِي بَيْعِهَا فِي الثَّالِثَةِ أَوِ الرَّابِعَةِ ‏.‏", "bengali": "", "english": "This hadith has been transmitted on the authority of Abu Huraira and Zaid b. Khalid al-Juhani in the same way as transmitted by Malik with this (difference) tnat there is a doubt whether her sale (that of the slave-girl committing adultery) was mentioned after the third or the fourth time.", "french": "", "indonesian": "", "russian": "", "urdu": "عبیداللہ اور اسامہ نے نافع سے ،  انہوں نے حضرت ابن عمر رضی اللہ عنہ سے اور انہوں نے نبی صلی اللہ علی", "grades": "", "reference": "", "international_number": "4319", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4320", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ أَبِي بَكْرٍ الْمُقَدَّمِيُّ، حَدَّثَنَا سُلَيْمَانُ أَبُو دَاوُدَ، حَدَّثَنَا زَائِدَةُ، عَنِ السُّدِّيِّ، عَنْ سَعْدِ بْنِ عُبَيْدَةَ، عَنْ أَبِي عَبْدِ الرَّحْمَنِ، قَالَ خَطَبَ عَلِيٌّ فَقَالَ يَا أَيُّهَا النَّاسُ أَقِيمُوا عَلَى أَرِقَّائِكُمُ الْحَدَّ مَنْ أَحْصَنَ مِنْهُمْ وَمَنْ لَمْ يُحْصِنْ فَإِنَّ أَمَةً لِرَسُولِ اللَّهِ صلى الله عليه وسلم زَنَتْ فَأَمَرَنِي أَنْ أَجْلِدَهَا فَإِذَا هِيَ حَدِيثُ عَهْدٍ بِنِفَاسٍ فَخَشِيتُ إِنْ أَنَا جَلَدْتُهَا أَنْ أَقْتُلَهَا فَذَكَرْتُ ذَلِكَ لِلنَّبِيِّ صلى الله عليه وسلم فَقَالَ ‏ ‏ أَحْسَنْتَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "O people, impose the prescribed punishment upon your slaves, those who are married and those not married, for a slave-woman belonging to Allah's Messenger (ﷺ) had committed adultery, and he committed me to flog her. But she had recently given birth to a child and I was afraid that if I flogged her I might kill her. So I mentioned that to Allah's Apostle (ﷺ) and he said: You have done well.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abd al-Rahman reported that 'Ali, while delivering the address said:", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4321", "arabic": "وَحَدَّثَنَاهُ إِسْحَاقُ بْنُ إِبْرَاهِيمَ، أَخْبَرَنَا يَحْيَى بْنُ آدَمَ، حَدَّثَنَا إِسْرَائِيلُ، عَنِ السُّدِّيِّ، بِهَذَا الإِسْنَادِ وَلَمْ يَذْكُرْ مَنْ أَحْصَنَ مِنْهُمْ وَمَنْ لَمْ يُحْصِنْ ‏.‏ وَزَادَ فِي الْحَدِيثِ ‏ ‏ اتْرُكْهَا حَتَّى تَمَاثَلَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\" Those who are married and those who are not married.\" There is also an addition in it:\" I spare her until she is all right.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "This hadith has been narrated on the authority of as-Suddi with the same chain of trznsmitters, but he did not mention:", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4322", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، وَمُحَمَّدُ بْنُ بَشَّارٍ، قَالاَ حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، حَدَّثَنَا شُعْبَةُ، قَالَ سَمِعْتُ قَتَادَةَ، يُحَدِّثُ عَنْ أَنَسِ بْنِ مَالِكٍ، أَنَّ النَّبِيَّ صلى الله عليه وسلم أُتِيَ بِرَجُلٍ قَدْ شَرِبَ الْخَمْرَ فَجَلَدَهُ بِجَرِيدَتَيْنِ نَحْوَ أَرْبَعِينَ ‏.‏ قَالَ وَفَعَلَهُ أَبُو بَكْرٍ فَلَمَّا كَانَ عُمَرُ اسْتَشَارَ النَّاسَ فَقَالَ عَبْدُ الرَّحْمَنِ أَخَفَّ الْحُدُودِ ثَمَانِينَ ‏.‏ فَأَمَرَ بِهِ عُمَرُ ‏.‏", "bengali": "", "english": "The mildest punishment (for drinking) is eighty (stripes) and 'Umar their prescribed this punishment.", "french": "", "indonesian": "", "russian": "", "urdu": "ابو معاویہ نے اعمش سے ،  انہوں نے ابوصالح سے اور انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،", "grades": "", "reference": "", "international_number": "4322", "narrator_chain": "Anas b. Malik reported that a person who had drink wine was brought to Allah's Apostle (ﷺ). He gave him forty stripes with two lashes. Abu Bakr also did that, but when Umar (assumed the responsibilities) of the Caliphate, he consulted people and Abd al-Rahman said:", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4323", "arabic": "وَحَدَّثَنَا يَحْيَى بْنُ حَبِيبٍ الْحَارِثِيُّ، حَدَّثَنَا خَالِدٌ، - يَعْنِي ابْنَ الْحَارِثِ - حَدَّثَنَا شُعْبَةُ، حَدَّثَنَا قَتَادَةُ، قَالَ سَمِعْتُ أَنَسًا، يَقُولُ أُتِيَ رَسُولُ اللَّهِ صلى الله عليه وسلم بِرَجُلٍ ‏.‏ فَذَكَرَ نَحْوَهُ ‏.‏", "bengali": "", "english": "This hadith has been narrated on the authority of Anas through another chain of transmitters.", "french": "", "indonesian": "", "russian": "", "urdu": "جریر نے اعمش سے اسی سند کے ساتھ حدیث بیان کی", "grades": "", "reference": "", "international_number": "4323", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4324", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، حَدَّثَنَا مُعَاذُ بْنُ هِشَامٍ، حَدَّثَنِي أَبِي، عَنْ قَتَادَةَ، عَنْ أَنَسِ، بْنِ مَالِكٍ أَنَّ نَبِيَّ اللَّهِ صلى الله عليه وسلم جَلَدَ فِي الْخَمْرِ بِالْجَرِيدِ وَالنِّعَالِ ثُمَّ جَلَدَ أَبُو بَكْرٍ أَرْبَعِينَ ‏.‏ فَلَمَّا كَانَ عُمَرُ وَدَنَا النَّاسُ مِنَ الرِّيفِ وَالْقُرَى قَالَ مَا تَرَوْنَ فِي جَلْدِ الْخَمْرِ فَقَالَ عَبْدُ الرَّحْمَنِ بْنُ عَوْفٍ أَرَى أَنْ تَجْعَلَهَا كَأَخَفِّ الْحُدُودِ ‏.‏ قَالَ فَجَلَدَ عُمَرُ ثَمَانِينَ ‏.‏", "bengali": "", "english": "My opinion is that you fix it as the mildest punishment. Then 'Umar inflicted eighty stripes.", "french": "", "indonesian": "", "russian": "", "urdu": "ہمام بن منبہ نے کہا :  یہ احادیث ہیں جو حضرت ابوہریرہ رضی اللہ عنہ نے ہمیں رسول اللہ صلی اللہ علیہ و", "grades": "", "reference": "", "international_number": "4324", "narrator_chain": "Anas b. Malik reported that Allah's Apostle (ﷺ) gave a beating with palm branches and shoes, and that Abu Bakr gave forty lashes. When Umar (became the Commander of the Faithful) and the people went near to pastures and towns, he said (to the Companions of the Holy Prophet). What is your opinion about lashing for drinking? Thereupon Abd al-Rahman b. Auf said:", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4325", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، حَدَّثَنَا هِشَامٌ، بِهَذَا الإِسْنَادِ مِثْلَهُ.", "bengali": "", "english": "This hadith has been narrated on the authority of Hisham with the same chain of transmitters.", "french": "", "indonesian": "", "russian": "", "urdu": "امام مالک نے نافع سے اور انہوں نے حضرت ابن عمر رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  رسول اللہ", "grades": "", "reference": "", "international_number": "4325", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4326", "arabic": "وَحَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا وَكِيعٌ، عَنْ هِشَامٍ، عَنْ قَتَادَةَ، عَنْ أَنَسٍ، أَنَّوسلم كَانَ يَضْرِبُ فِي الْخَمْرِ بِالنِّعَالِ وَالْجَرِيدِ أَرْبَعِينَ ‏.‏ ثُمَّ ذَكَرَ نَحْوَ حَدِيثِهِمَا وَلَمْ يَذْكُرِ الرِّيفَ وَالْقُرَى ‏.‏", "bengali": "", "english": "Anas reported that Allah's Apostle (ﷺ) used to strike forty times with shoes and palm branches (in case of drinking of) wine. The rest of the hadith is the same and there is no mention of pastures and towns.", "french": "", "indonesian": "", "russian": "", "urdu": "عبیداللہ نے نافع سے ،  انہوں نے حضرت ابن عمر رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  رسول اللہ ص", "grades": "", "reference": "", "international_number": "4326", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4327", "arabic": "وَحَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَزُهَيْرُ بْنُ حَرْبٍ، وَعَلِيُّ بْنُ حُجْرٍ، قَالُوا حَدَّثَنَا إِسْمَاعِيلُ، - وَهُوَ ابْنُ عُلَيَّةَ - عَنِ ابْنِ أَبِي عَرُوبَةَ، عَنْ عَبْدِ اللَّهِ الدَّانَاجِ، ح وَحَدَّثَنَا إِسْحَاقُ، بْنُ إِبْرَاهِيمَ الْحَنْظَلِيُّ - وَاللَّفْظُ لَهُ - أَخْبَرَنَا يَحْيَى بْنُ حَمَّادٍ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ الْمُخْتَارِ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ فَيْرُوزَ، مَوْلَى ابْنِ عَامِرٍ الدَّانَاجِ حَدَّثَنَا حُضَيْنُ بْنُ الْمُنْذِرِ أَبُو سَاسَانَ، قَالَ شَهِدْتُ عُثْمَانَ بْنَ عَفَّانَ وَأُتِيَ بِالْوَلِيدِ قَدْ صَلَّى الصُّبْحَ رَكْعَتَيْنِ ثُمَّ قَالَ أَزِيدُكُمْ فَشَهِدَ عَلَيْهِ رَجُلاَنِ أَحَدُهُمَا حُمْرَانُ أَنَّهُ شَرِبَ الْخَمْرَ وَشَهِدَ آخَرُ أَنَّهُ رَآهُ يَتَقَيَّأُ فَقَالَ عُثْمَانُ إِنَّهُ لَمْ يَتَقَيَّأْ حَتَّى شَرِبَهَا فَقَالَ يَا عَلِيُّ قُمْ فَاجْلِدْهُ ‏.‏ فَقَالَ عَلِيٌّ قُمْ يَا حَسَنُ فَاجْلِدْهُ ‏.‏ فَقَالَ الْحَسَنُ وَلِّ حَارَّهَا مَنْ تَوَلَّى قَارَّهَا - فَكَأَنَّهُ وَجَدَ عَلَيْهِ - فَقَالَ يَا عَبْدَ اللَّهِ بْنَ جَعْفَرٍ قُمْ فَاجْلِدْهُ ‏.‏ فَجَلَدَهُ وَعَلِيٌّ يَعُدُّ حَتَّى بَلَغَ أَرْبَعِينَ فَقَالَ أَمْسِكْ ‏.‏ ثُمَّ قَالَ جَلَدَ النَّبِيُّ صلى الله عليه وسلم أَرْبَعِينَ وَجَلَدَ أَبُو بَكْرٍ أَرْبَعِينَ وَعُمَرُ ثَمَانِينَ وَكُلٌّ سُنَّةٌ وَهَذَا أَحَبُّ إِلَىَّ ‏.‏ زَادَ عَلِيُّ بْنُ حُجْرٍ فِي رِوَايَتِهِ قَالَ إِسْمَاعِيلُ وَقَدْ سَمِعْتُ حَدِيثَ الدَّانَاجِ مِنْهُ فَلَمْ أَحْفَظْهُ ‏.‏", "bengali": "", "english": "I saw that Walid was brought to Uthmin b. 'Affan as he had prayed two rak'ahs of the dawn prayer, and then he said: I make an increase for you. And two men bore witness against him. One of them was Humran who said that he had drunk wine. The second one gave witness that he had seen him vomiting. Uthman said: He would not have vomited (wine) unless he had drunk it. He said: 'Ali, stand up and lash him. 'Ali said: Hasan, stand up and lash him. Thereupon Hasan said: Let him suffer the heat (of Caliphate) who has enjoyed its coolness. ('Ali felt annoyed at this remark) and he said: 'Abdullah b. Ja'far, stand up and flog him, and he began to flog him and 'Ali counted the stripes until these were forty. He (Hadrat 'Ali) said: Stop now, and then said: Allah's Apostle (ﷺ) gave forty stripes, and Abu Bakr also gave forty stripes, and Umar gave eighty stripes, and all these fall under the category of the Sunnab, but this one (forty stripes) is dearer to me.", "french": "", "indonesian": "", "russian": "", "urdu": "جریر بن حازم نے عبداللہ بن عمر رضی اللہ عنہ کے مولیٰ نافع سے ،  انہوں نے حضرت عبداللہ بن عمر رضی الل", "grades": "", "reference": "", "international_number": "4327", "narrator_chain": "Hudain b. al-Mundhir Abu Sasan reported:", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4328", "arabic": "حَدَّثَنِي مُحَمَّدُ بْنُ مِنْهَالٍ الضَّرِيرُ، حَدَّثَنَا يَزِيدُ بْنُ زُرَيْعٍ، حَدَّثَنَا سُفْيَانُ الثَّوْرِيُّ، عَنْ أَبِي حَصِينٍ، عَنْ عُمَيْرِ بْنِ سَعِيدٍ، عَنْ عَلِيٍّ، قَالَ مَا كُنْتُ أُقِيمُ عَلَى أَحَدٍ حَدًّا فَيَمُوتَ فِيهِ فَأَجِدَ مِنْهُ فِي نَفْسِي إِلاَّ صَاحِبَ الْخَمْرِ لأَنَّهُ إِنْ مَاتَ وَدَيْتُهُ لأَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم لَمْ يَسُنَّهُ ‏.‏", "bengali": "", "english": "If I impose Hadd on anyone, and he (in course of punish ment) dies, I would not mind except in case of a drunkard. If he dies. I would pay indemnity for him because the Messenger of Allah (ﷺ) has laid down no rule for it.", "french": "", "indonesian": "", "russian": "", "urdu": "لیث بن سعد ،  یحییٰ بن سعید ،  ایوب ،  اسماعیل بن امیہ ،  ابن ابی ذئب اور اسامہ بن زید سب نے نافع سے", "grades": "", "reference": "", "international_number": "4328", "narrator_chain": "Ali reported:", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4329", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، حَدَّثَنَا عَبْدُ الرَّحْمَنِ، حَدَّثَنَا سُفْيَانُ، بِهَذَا الإِسْنَادِ مِثْلَهُ ‏.‏", "bengali": "", "english": "This hadith is narrated on the authority of Sufyan.", "french": "", "indonesian": "", "russian": "", "urdu": "عمرو نے سالم بن عبداللہ سے اور انہوں نے اپنے والد سے روایت کی کہ رسول اللہ صلی اللہ علیہ وسلم نے فرم", "grades": "", "reference": "", "international_number": "4329", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4330", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ عِيسَى، حَدَّثَنَا ابْنُ وَهْبٍ، أَخْبَرَنِي عَمْرٌو، عَنْ بُكَيْرِ بْنِ الأَشَجِّ، قَالَ بَيْنَا نَحْنُ عِنْدَ سُلَيْمَانَ بْنِ يَسَارٍ إِذْ جَاءَهُ عَبْدُ الرَّحْمَنِ بْنُ جَابِرٍ فَحَدَّثَهُ فَأَقْبَلَ، عَلَيْنَا سُلَيْمَانُ فَقَالَ حَدَّثَنِي عَبْدُ الرَّحْمَنِ بْنُ جَابِرٍ، عَنْ أَبِيهِ، عَنْ أَبِي بُرْدَةَ الأَنْصَارِيِّ، أَنَّهُ سَمِعَ رَسُولَ اللَّهِ صلى الله عليه وسلم يَقُولُ ‏ ‏ لاَ يُجْلَدُ أَحَدٌ فَوْقَ عَشَرَةِ أَسْوَاطٍ إِلاَّ فِي حَدٍّ مِنْ حُدُودِ اللَّهِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "None should be given more than ten lashes, but in case of any Hadd out of the Huded of Allah.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Barda Ansari reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4331", "arabic": "حَدَّثَنَا يَحْيَى بْنُ يَحْيَى التَّمِيمِيُّ، وَأَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ وَعَمْرٌو النَّاقِدُ وَإِسْحَاقُ بْنُ إِبْرَاهِيمَ وَابْنُ نُمَيْرٍ كُلُّهُمْ عَنِ ابْنِ عُيَيْنَةَ، - وَاللَّفْظُ لِعَمْرٍو قَالَ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ الزُّهْرِيِّ، عَنْ أَبِي إِدْرِيسَ، عَنْ عُبَادَةَ بْنِ الصَّامِتِ، قَالَ كُنَّا مَعَ رَسُولِ اللَّهِ صلى الله عليه وسلم فِي مَجْلِسٍ فَقَالَ ‏ ‏ تُبَايِعُونِي عَلَى أَنْ لاَ تُشْرِكُوا بِاللَّهِ شَيْئًا وَلاَ تَزْنُوا وَلاَ تَسْرِقُوا وَلاَ تَقْتُلُوا النَّفْسَ الَّتِي حَرَّمَ اللَّهُ إِلاَّ بِالْحَقِّ فَمَنْ وَفَى مِنْكُمْ فَأَجْرُهُ عَلَى اللَّهِ وَمَنْ أَصَابَ شَيْئًا مِنْ ذَلِكَ فَعُوقِبَ بِهِ فَهُوَ كَفَّارَةٌ لَهُ وَمَنْ أَصَابَ شَيْئًا مِنْ ذَلِكَ فَسَتَرَهُ اللَّهُ عَلَيْهِ فَأَمْرُهُ إِلَى اللَّهِ إِنْ شَاءَ عَفَا عَنْهُ وَإِنْ شَاءَ عَذَّبَهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "While we were in the company of Allah's Messenger (may peace be upoi him) he said: Swear allegiance to me that you will not associate anything with Allah, that you will not commit adultery, that you will not steal, that you will not take any life which it is forbidden by Allah to take but with (legal) justification; and whoever among you fulfils it, his reward is with Allah and he who commits any such thing and is punished for it, that will be all atonement for it And if anyone commits anything and Allah conceals (his faultfls), his matter rests with Allah. He may forgive if He likes, and He may punish him if He likes.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Ubida b. as-Samit reported:", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4332", "arabic": "حَدَّثَنَا عَبْدُ بْنُ حُمَيْدٍ، أَخْبَرَنَا عَبْدُ الرَّزَّاقِ، أَخْبَرَنَا مَعْمَرٌ، عَنِ الزُّهْرِيِّ، بِهَذَا الإِسْنَادِ وَزَادَ فِي الْحَدِيثِ فَتَلاَ عَلَيْنَا آيَةَ النِّسَاءِ ‏{‏ أَنْ لاَ يُشْرِكْنَ بِاللَّهِ شَيْئًا‏}‏ الآيَةَ ‏.‏", "bengali": "", "english": "\" He recited to us the verse pertaining to women, viz, that they will not associate anything with Allah.", "french": "", "indonesian": "", "russian": "", "urdu": "عبیداللہ کے والد معاذ عنبری نے کہا :  ہمیں شعبہ نے اسی سند کے ساتھ حدیث بیان کی ،  آپ نے فرمایا :", "grades": "", "reference": "", "international_number": "4332", "narrator_chain": "This hadith has been narrated on the authority of Zuhri with the same chain of transmitters with this addition:", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4333", "arabic": "وَحَدَّثَنِي إِسْمَاعِيلُ بْنُ سَالِمٍ، أَخْبَرَنَا هُشَيْمٌ، أَخْبَرَنَا خَالِدٌ، عَنْ أَبِي قِلاَبَةَ، عَنْ أَبِي الأَشْعَثِ الصَّنْعَانِيِّ، عَنْ عُبَادَةَ بْنِ الصَّامِتِ، قَالَ أَخَذَ عَلَيْنَا رَسُولُ اللَّهِ صلى الله عليه وسلم كَمَا أَخَذَ عَلَى النِّسَاءِ أَنْ لاَ نُشْرِكَ بِاللَّهِ شَيْئًا وَلاَ نَسْرِقَ وَلاَ نَزْنِيَ وَلاَ نَقْتُلَ أَوْلاَدَنَا وَلاَ يَعْضَهَ بَعْضُنَا بَعْضًا ‏ ‏ فَمَنْ وَفَى مِنْكُمْ فَأَجْرُهُ عَلَى اللَّهِ وَمَنْ أَتَى مِنْكُمْ حَدًّا فَأُقِيمَ عَلَيْهِ فَهُوَ كَفَّارَتُهُ وَمَنْ سَتَرَهُ اللَّهُ عَلَيْهِ فَأَمْرُهُ إِلَى اللَّهِ إِنْ شَاءَ عَذَّبَهُ وَإِنْ شَاءَ غَفَرَ لَهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "Allah's Messenger (ﷺ) took (a pledge) from us as he took from the women that we will not associate anything with Allah and we will not steal, and we will not commit adultery, and we will not kill our children, and we will not bring calumny upon one another. And he who amongst you fulfils (this pledge), his reward rests with Allah, and he upon whom amongst you is imposed the prescribed punishment and that is carried out, that is his expiation (for that sin), and he whose (sins) were covered by Allah, his matter rests with Allah. He may punish him if He likes or may forgive him if He so likes.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "'Ubida b. as-Samit reported:", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4334", "arabic": "حَدَّثَنَا قُتَيْبَةُ بْنُ سَعِيدٍ، حَدَّثَنَا لَيْثٌ، ح وَحَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، أَخْبَرَنَا اللَّيْثُ، عَنْ يَزِيدَ بْنِ أَبِي حَبِيبٍ، عَنْ أَبِي الْخَيْرِ، عَنِ الصُّنَابِحِيِّ، عَنْ عُبَادَةَ بْنِ الصَّامِتِ، أَنَّهُ قَالَ إِنِّي لَمِنَ النُّقَبَاءِ الَّذِينَ بَايَعُوا رَسُولَ اللَّهِ صلى الله عليه وسلم وَقَالَ بَايَعْنَاهُ عَلَى أَنْ لاَ نُشْرِكَ بِاللَّهِ شَيْئًا وَلاَ نَزْنِيَ وَلاَ نَسْرِقَ وَلاَ نَقْتُلَ النَّفْسَ الَّتِي حَرَّمَ اللَّهُ إِلاَّ بِالْحَقِّ وَلاَ نَنْتَهِبَ وَلاَ نَعْصِيَ فَالْجَنَّةُ إِنْ فَعَلْنَا ذَلِكَ فَإِنْ غَشِينَا مِنْ ذَلِكَ شَيْئًا كَانَ قَضَاءُ ذَلِكَ إِلَى اللَّهِ ‏.‏ وَقَالَ ابْنُ رُمْحٍ كَانَ قَضَاؤُهُ إِلَى اللَّهِ ‏.‏", "bengali": "", "english": "I was one of those headmen who swore allegiance to Allah's Messenger (ﷺ) that we will not associate anything with Allah, and will not commit adultery, and will not steal, and will not kill any soul which Allah has forbidden, but with justice nor plunder, nor disobey (Allah and His Apostle), then Paradise (will be the reward) in case we do these (acts) ; and if we commit any outrage (and that goes unpunished in the world), it is Allah Who would decide about it. Ibn Rumh said: Its judgment lies with Allah.", "french": "", "indonesian": "", "russian": "", "urdu": "علی بن مسہر ،  محمد بن بشر اور عیسیٰ بن یونس سب نے ابن ابی عروبہ سے اسی سند کے ساتھ حدیث بیان کی اور", "grades": "", "reference": "", "international_number": "4334", "narrator_chain": "Ubida b. as-Samit repnrted:", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4335", "arabic": "حَدَّثَنَا يَحْيَى بْنُ يَحْيَى، وَمُحَمَّدُ بْنُ رُمْحٍ، قَالاَ أَخْبَرَنَا اللَّيْثُ، ح وَحَدَّثَنَا قُتَيْبَةُ بْنُ، سَعِيدٍ حَدَّثَنَا لَيْثٌ، عَنِ ابْنِ شِهَابٍ، عَنْ سَعِيدِ بْنِ الْمُسَيَّبِ، وَأَبِي، سَلَمَةَ عَنْ أَبِي هُرَيْرَةَ، عَنْ رَسُولِ اللَّهِ صلى الله عليه وسلم أَنَّهُ قَالَ ‏ ‏ الْعَجْمَاءُ جَرْحُهَا جُبَارٌ وَالْبِئْرُ جُبَارٌ وَالْمَعْدِنُ جُبَارٌ وَفِي الرِّكَازِ الْخُمْسُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "No requital is payable for a wound caused by an animal, for (falling into) a well and a mine, and one-fifth (is the share of the government) in the buried treasure (treasure-trove).", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4336", "arabic": "وَحَدَّثَنَا يَحْيَى بْنُ يَحْيَى، وَأَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ وَزُهَيْرُ بْنُ حَرْبٍ وَعَبْدُ الأَعْلَى بْنُ حَمَّادٍ كُلُّهُمْ عَنِ ابْنِ عُيَيْنَةَ، ح وَحَدَّثَنَا مُحَمَّدُ بْنُ رَافِعٍ، حَدَّثَنَا إِسْحَاقُ، - يَعْنِي ابْنَ عِيسَى - حَدَّثَنَا مَالِكٌ، كِلاَهُمَا عَنِ الزُّهْرِيِّ، بِإِسْنَادِ اللَّيْثِ ‏.‏ مِثْلَ حَدِيثِهِ ‏.‏", "bengali": "", "english": "A hadith like this has been transmitted on the authority of Zuhri.", "french": "", "indonesian": "", "russian": "", "urdu": "حماد اور  ( عبدالوہاب )  ثقفی دونوں نے ایوب سے اسی سند کے ساتھ حدیث بیان کی ،  حماد کی حدیث ابن عُلی", "grades": "", "reference": "", "international_number": "4336", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4337", "arabic": "وَحَدَّثَنِي أَبُو الطَّاهِرِ، وَحَرْمَلَةُ، قَالاَ أَخْبَرَنَا ابْنُ وَهْبٍ، أَخْبَرَنِي يُونُسُ، عَنِ ابْنِ، شِهَابٍ عَنِ ابْنِ الْمُسَيَّبِ، وَعُبَيْدِ اللَّهِ بْنِ عَبْدِ اللَّهِ، عَنْ أَبِي هُرَيْرَةَ، عَنْ رَسُولِ اللَّهِ صلى الله عليه وسلم بِمِثْلِهِ ‏.‏", "bengali": "", "english": "A hadith like this has been transmitted on the authority of Abu Huraira.", "french": "", "indonesian": "", "russian": "", "urdu": "یزید بن زریع نے ہمیں حدیث بیان کی ،  کہا :  ہمیں ہشام بن حسان نے محمد بن سیرین سے حدیث بیان کی ،  ان", "grades": "", "reference": "", "international_number": "4337", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4338", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحِ بْنِ الْمُهَاجِرِ، أَخْبَرَنَا اللَّيْثُ، عَنْ أَيُّوبَ بْنِ مُوسَى، عَنِ الأَسْوَدِ، بْنِ الْعَلاَءِ عَنْ أَبِي سَلَمَةَ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ أَبِي هُرَيْرَةَ، عَنْ رَسُولِ اللَّهِ صلى الله عليه وسلم أَنَّهُ قَالَ ‏ ‏ الْبِئْرُ جَرْحُهَا جُبَارٌ وَالْمَعْدِنُ جَرْحُهُ جُبَارٌ وَالْعَجْمَاءُ جَرْحُهَا جُبَارٌ وَفِي الرِّكَازِ الْخُمْسُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "The wound caused (by falling) in the well, in the mine, and caused bv the animal has no requital for it; and there is one-fifth (for the government) in the buried treasure.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4339", "arabic": "وَحَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ سَلاَّمٍ الْجُمَحِيُّ، حَدَّثَنَا الرَّبِيعُ يَعْنِي ابْنَ مُسْلِمٍ، ح وَحَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ مُعَاذٍ، حَدَّثَنَا أَبِي ح، وَحَدَّثَنَا ابْنُ بَشَّارٍ، حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، قَالاَ حَدَّثَنَا شُعْبَةُ، كِلاَهُمَا عَنْ مُحَمَّدِ بْنِ زِيَادٍ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم بِمِثْلِهِ ‏.‏", "bengali": "", "english": "A hadith like this has been transmitted on the authority of Abu Huraira.", "french": "", "indonesian": "", "russian": "", "urdu": "سفیان بن عیینہ نے کہا :  عمرو  ( بن دینار )  نے حضرت جابر رضی اللہ عنہ سے سنا ،  وہ کہہ رہے تھے :  ا", "grades": "", "reference": "", "international_number": "4339", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4398", "arabic": "حَدَّثَنَا  يَحْيَى بْنُ يَحْيَى ،  وَإِسْحَاقُ بْنُ إِبْرَاهِيمَ ،  وَابْنُ أَبِي عُمَرَ وَاللَّفْظ", "bengali": "", "english": "A'isha reported that Allah's Messenger (ﷺ) cut off the hand of a thief for a quarter of a dinar rid upwards", "french": "", "indonesian": "", "russian": "", "urdu": "سفیان بن عیینہ نے زہری سے ،  انہوں نے عمرہ سے اور انہوں نے حضرت عائشہ رضی اللہ عنہا سے روایت کی ،  ا", "grades": "", "reference": "Book 29, Hadith 1", "international_number": "4398", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4399", "arabic": "وحَدَّثَنَا  إِسْحَاقُ بْنُ إِبْرَاهِيمَ ،  وَعَبْدُ بْنُ حُمَيْدٍ ، قَالَا: أَخْبَرَنَا  عَبْدُ الر", "bengali": "", "english": "This hadith has been transmitted on the authority of Zuhri", "french": "", "indonesian": "", "russian": "", "urdu": "،  سلیمان بن کثیر اور ابراہیم بن سعد سب نے زہری سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی", "grades": "", "reference": "Book 29, Hadith 2", "international_number": "4399", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4400", "arabic": "وحَدَّثَنِي  أَبُو الطَّاهِرِ ،  وَحَرْمَلَةُ بْنُ يَحْيَى ، وَحَدَّثَنَا  الْوَلِيدُ بْنُ شُجَاعٍ و", "bengali": "", "english": "A'isha reported Allah's Messenger (ﷺ) as saying:The hand of a thief should not be cut off but for a quarter of a dinar and upwards", "french": "", "indonesian": "", "russian": "", "urdu": "ابن شہاب نے عروہ اور عمرہ سے ،  انہوں نے حضرت عائشہ رضی اللہ عنہا سے اور انہوں نے رسول اللہ صلی اللہ", "grades": "", "reference": "Book 29, Hadith 3", "international_number": "4400", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4401", "arabic": "وحَدَّثَنِي  أَبُو الطَّاهِرِ ،  وَهَارُونُ بْنُ سَعِيدٍ الْأَيْلِيُّ ،  وَأَحْمَدُ بْنُ عِيسَى وَال", "bengali": "", "english": "A'isha reported:I heard Allah's Messenger (ﷺ) as saying: The hand (of a thief) should not be cut off but for a quarter of a dinar and what is above that", "french": "", "indonesian": "", "russian": "", "urdu": "سلیمان بن یسار نے عمرہ سے روایت کی کہ انہوں نے حضرت عائشہ رضی اللہ عنہا سے سنا ،  وہ بیان کر رہی تھی", "grades": "", "reference": "Book 29, Hadith 4", "international_number": "4401", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4402", "arabic": "حَدَّثَنِي  بِشْرُ بْنُ الْحَكَمِ الْعَبْدِيُّ ، حَدَّثَنَا  عَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ ، عَنْ", "bengali": "", "english": "A'isha reported that she heard Allah's Apostle (ﷺ) as saying:The hand of the thief may not be cut off but for a quarter of a dinar and upwards", "french": "", "indonesian": "", "russian": "", "urdu": "عبدالعزیز بن محمد نے یزید بن عبداللہ بن ہاد سے ،  انہوں نے ابوبکر بن محمد سے ،  انہوں نے عمرہ سے اور", "grades": "", "reference": "Book 29, Hadith 5", "international_number": "4402", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4403", "arabic": "وحَدَّثَنَا  إِسْحَاقُ بْنُ إِبْرَاهِيمَ ،  وَمُحَمَّدُ بْنُ الْمُثَنَّى ،  وَإِسْحَاقُ بْنُ مَنْصُو", "bengali": "", "english": "A hadith like this has been narrated on the authority of Yazid b. 'Abdullah b. al-Had with the same chain of transmitters", "french": "", "indonesian": "", "russian": "", "urdu": "مسور بن مخرمہ رضی اللہ عنہ کی اولاد میں سے عبداللہ بن جعفر نے یزید بن عبداللہ بن ہاد سے  ( باقی ماند", "grades": "", "reference": "Book 29, Hadith 6", "international_number": "4403", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4404", "arabic": "وحَدَّثَنَا  مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ ، حَدَّثَنَا  حُمَيْدُ بْنُ عَبْدِ الرَّحْم", "bengali": "", "english": "A'isha reported that during the lifetime of Allah's Messenger (ﷺ) the hand of the thief was not cut off for less than the price of a shield, iron coat or armour and both of them are valuable", "french": "", "indonesian": "", "russian": "", "urdu": "محمد بن عبداللہ بن نمیر نے کہا :  حمید بن عبدالرحمان رؤاسی نے ہمیں ہشام بن عروہ سے حدیث بیان کی ،  ا", "grades": "", "reference": "Book 29, Hadith 7", "international_number": "4404", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4405", "arabic": "وحَدَّثَنَا  عُثْمَانُ بْنُ أَبِي شَيْبَةَ ، أَخْبَرَنَا  عَبْدَةُ بْنُ سُلَيْمَانَ ،  وَحُمَيْدُ بْ", "bengali": "", "english": "This hadith has been narrated on the authority of Hisham through another chain of transmitters, and in the hadith narrated by 'Abd al-Rahim and Abu Usama (the words are):\" That (the shield) was valuable those days", "french": "", "indonesian": "", "russian": "", "urdu": "عبدہ بن سلیمان ،  حمید بن عبدالرحمٰن ،  عبدالرحیم بن سلیمان اور ابواسامہ سب نے ہشام سے اسی سند کے سا", "grades": "", "reference": "Book 29, Hadith 8", "international_number": "4405", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4406", "arabic": "حَدَّثَنَا  يَحْيَى بْنُ يَحْيَى ، قَالَ: قَرَأْتُ عَلَى  مَالِكٍ ، عَنْ  نَافِعٍ ، عَنْ  ابْنِ عُمَ", "bengali": "", "english": "Ibn 'Umar reported that Allah's Messenger (may peace upon him) cut off the hand of a thief (in case of the theft) of a shield the price of which was three dirhams", "french": "", "indonesian": "", "russian": "", "urdu": "یحییٰ بن یحییٰ نے کہا :  میں نے امام مالک کے سامنے قراءت کی ،  انہوں نے نافع سے اور انہوں نے حضرت اب", "grades": "", "reference": "Book 29, Hadith 9", "international_number": "4406", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4407", "arabic": "حَدَّثَنَا  قُتَيْبَةُ بْنُ سَعِيدٍ ،  وَابْنُ رُمْحٍ ، عَنْ  اللَّيْثِ بْنِ سَعْدٍ . ح وحَدَّثَنَا", "bengali": "", "english": "This hadith has been narrated on the authority of Ibn 'Umar through some other chains of transmitters but with a slight variation of words", "french": "", "indonesian": "", "russian": "", "urdu": "لیث بن سعد ،  عبیداللہ  ( بن عمر بن حفص العمری )  ،  ایوب سختیانی ،  ایوب بن موسیٰ ،  اسماعیل بن امی", "grades": "", "reference": "Book 29, Hadith 10", "international_number": "4407", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4408", "arabic": "حَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ،  وَأَبُو كُرَيْبٍ ، قَالَا: حَدَّثَنَا  أَبُو مُعَاوِ", "bengali": "", "english": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:Let there be the curse of Allah upon the thief who steals an egg and his hand is cut off, and steals a rope and his hand is cut off", "french": "", "indonesian": "", "russian": "", "urdu": "ابومعاویہ نے اعمش سے ،  انہوں نے ابوصالح سے اور انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  ا", "grades": "", "reference": "Book 29, Hadith 11", "international_number": "4408", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4409", "arabic": "حَدَّثَنَا  عَمْرٌو النَّاقِدُ ،  وَإِسْحَاقُ بْنُ إِبْرَاهِيمَ ،  وَعَلِيُّ بْنُ خَشْرَمٍ كُلُّهُمْ", "bengali": "", "english": "This hadith is narrated on the authority of A'mash with the same chain of transmitters with a slight variation of words", "french": "", "indonesian": "", "russian": "", "urdu": "عیسیٰ بن یونس نے اعمش سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی ،  البتہ وہ کہتے ہیں :   \" وہ خوا", "grades": "", "reference": "Book 29, Hadith 12", "international_number": "4409", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4410", "arabic": "حَدَّثَنَا  قُتَيْبَةُ بْنُ سَعِيدٍ ، حَدَّثَنَا  لَيْثٌ . ح وحَدَّثَنَا  مُحَمَّدُ بْنُ رُمْحٍ ، أَ", "bengali": "", "english": "A'isha reported that the Quraish had been anxious about the Makhzumi woman who had committed theft, and said:Who will speak to Allah's Messenger (ﷺ) about her? They said: Who dare it, but Usama, the loved one of Allah's Messenger (ﷺ)? So Usama spoke to him. Thereupon Allah's Messenger (ﷺ) said: Do you intercede regarding one of the punishments prescribed by Allah? He then stood up and addressed (people) saying: O people, those who have gone before you were destroyed, because if any one of high rank committed theft amongst them, they spared him; and it anyone of low rank committed theft, they inflicted the prescribed punishment upon him. By Allah, if Fatima, daughter of Muhammad, were to steal, I would have her hand cut off. In the hadith transmitted on the authority of Ibn Rumh (the words are):\" Verily those before you perished", "french": "", "indonesian": "", "russian": "", "urdu": "قتیبہ بن سعید اور محمد بن رمح نے کہا :  ہمیں لیث نے ابن شہاب سے خبر دی ،  انہوں نے عروہ سے اور انہوں", "grades": "", "reference": "Book 29, Hadith 13", "international_number": "4410", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4411", "arabic": "وحَدَّثَنِي  أَبُو الطَّاهِرِ ،  وَحَرْمَلَةُ بْنُ يَحْيَى وَاللَّفْظُ لِحَرْمَلَةَ، قَالَا: أَخْبَر", "bengali": "", "english": "A'isha, the wife of Allah's Apostle (ﷺ), reported that the Quraish were concerned about the woman who had committed theft during the lifetime of Allah's Apostle (ﷺ), in the expedition of Victory (of Mecca). They said:Who would speak to Allah's Messenger (ﷺ) about her? They (again) said: Who can dare do this but Usama b. Zaid, the loved one of Allah's Messenger (ﷺ)? She was brought to Allah's Messenger (ﷺ) and Usama b. Zaid spoke about her to him (interceded on her behalf). The color of the face of Allah's Messenger (ﷺ) changed, and he said: Do you intercede in one of the prescribed punishments of Allah? He (Usama) said: 'Messenger of Allah, seek forgiveness for me.' When it was dusk. Allah's Messenger (ﷺ) stood up and gave an address. He (first) glorified Allah as He deserves, and then said: Now to our topic. This (injustice) destroyed those before you that when any one of (high) rank committed theft among them, they spared him, and when any weak one among them committed theft, they inflicted the prescribed punishment upon him. By Him in Whose Hand is my life, even if Fatima daughter of Muhammad were to commit theft, I would have cut off her hand. He (the Holy Prophet) then commanded about that woman who had committed theft, and her hand was cut off. `A'isha (further) said: Hers was a good repentance, and she later on married and used to come to me after that, and I conveyed her needs (and problems) to Allah's Messenger (ﷺ)", "french": "", "indonesian": "", "russian": "", "urdu": "یونس بن یزید نے مجھے ابن شہاب سے خبر دی ،  انہوں نے کہا :  مجھے عروہ بن زبیر نے نبی صلی اللہ علیہ وس", "grades": "", "reference": "Book 29, Hadith 14", "international_number": "4411", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4412", "arabic": "وحَدَّثَنَا  عَبْدُ بْنُ حُمَيْدٍ ، أَخْبَرَنَا  عَبْدُ الرَّزَّاقِ ، أَخْبَرَنَا  مَعْمَرٌ ، عَنْ", "bengali": "", "english": "A'isha reported that a woman from the tribe of Makhzum used to borrow things (from people) and then denied (having taken them). Allah's Apostle (ﷺ) commanded her hand to be cut off. Her relatives came to Usama b. Zaid and spoke to him (requesting him to intercede on her behalf). He spoke to Allah's Messenger (ﷺ) about her. The rest of the hadith is the same", "french": "", "indonesian": "", "russian": "", "urdu": "معمر نے زہری سے ،  انہوں نے عروہ سے اور انہوں نے حضرت عائشہ رضی اللہ عنہا سے روایت کی ،  انہوں نے کہ", "grades": "", "reference": "Book 29, Hadith 15", "international_number": "4412", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4413", "arabic": "وحَدَّثَنِي  سَلَمَةُ بْنُ شَبِيبٍ ، حَدَّثَنَا  الْحَسَنُ بْنُ أَعْيَنَ ، حَدَّثَنَا  مَعْقِلٌ ، عَ", "bengali": "", "english": "Jaibir reported that a woman from the tribe of Makhzum committed theft. She was brought to Allah's Apostle (ﷺ) and she sought refuge (intercession) from Umm Salama, the wife of Allah's Apostle (ﷺ). Thereupon Allah's Apostle (ﷺ) said:By Allah, even if she were Fatima, I would have her hand cut off. And thus her hand was cut off", "french": "", "indonesian": "", "russian": "", "urdu": "حضرت جابر رضی اللہ عنہ سے روایت ہے کہ بنو مخزوم کی ایک عورت نے چوری کی ،  اسے نبی صلی اللہ علیہ وسلم", "grades": "", "reference": "Book 29, Hadith 16", "international_number": "4413", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4414", "arabic": "وحَدَّثَنَا  يَحْيَى بْنُ يَحْيَى التَّمِيمِيُّ ، أَخْبَرَنَا  هُشَيْمٌ ، عَنْ  مَنْصُورٍ ، عَنْ  ال", "bengali": "", "english": "Ubada b. as-Samit reported:Allah's Messenger (ﷺ) as saying: Receive (teaching) from me, receive (teaching) from me. Allah has ordained a way for those (women). When an unmarried male commits adultery with an unmarried female (they should receive) one hundred lashes and banishment for one year. And in case of married male committing adultery with a married female, they shall receive one hundred lashes and be stoned to death", "french": "", "indonesian": "", "russian": "", "urdu": "یحییٰ بن یحییٰ تمیمی نے کہا :  ہشیم نے ہمیں منصور سے خبر دی ،  انہوں نے حسن سے ،  انہوں نے حطان بن ع", "grades": "", "reference": "Book 29, Hadith 17", "international_number": "4414", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4415", "arabic": "وحَدَّثَنَا  عَمْرٌو النَّاقِدُ ، حَدَّثَنَا  هُشَيْمٌ ، أَخْبَرَنَا  مَنْصُورٌ بِهَذَا الْإِسْنَادِ", "bengali": "", "english": "The above hadith is likewise narrated through another chain of transmitters", "french": "", "indonesian": "", "russian": "", "urdu": "عمرو الناقد نے کہا :  ہمیں ہشیم نے حدیث بیان کی ،  کہا :  ہمیں منصور نے اسی سند کے ساتھ اسی کے مانند", "grades": "", "reference": "Book 29, Hadith 18", "international_number": "4415", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4416", "arabic": "حَدَّثَنَا  مُحَمَّدُ بْنُ الْمُثَنَّى ،  وَابْنُ بَشَّارٍ جَمِيعًا، عَنْ عَبْدِ الْأَعْلَى، قَالَ ا", "bengali": "", "english": "Ubada b. as-Samit reported that whenever Allah's Apostle (ﷺ) received revelation, he felt its rigour and the complexion of his face changed. One day revelation descended upon him, he felt the same rigour. When it was over and he felt relief, he said:Take from me. Verily Allah has ordained a way for them (the women who commit fornication),: (When) a married man (commits adultery) with a married woman, and an unmarried male with an unmarried woman, then in case of married (persons) there is (a punishment) of one hundred lashes and then stoning (to death). And in case of unmarried persons, (the punishment) is one hundred lashes and exile for one year", "french": "", "indonesian": "", "russian": "", "urdu": "سعید نے قتادہ سے ،  انہوں نے حسن سے ،  انہوں نے حِطان بن عبداللہ رقاشی سے اور انہوں نے حضرت عبادہ بن", "grades": "", "reference": "Book 29, Hadith 19", "international_number": "4416", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4417", "arabic": "وحَدَّثَنَا  مُحَمَّدُ بْنُ الْمُثَنَّى ، وَابْنُ بَشَّارٍ ، قَالَا: حَدَّثَنَا  مُحَمَّدُ بْنُ جَعْ", "bengali": "", "english": "This hadith has been reported on the authority of Qatada with the same chain of transmitters except with this variation that the unmarried is to be lashed and exiled, and the married one is to be lashed and stoned. There is neither any mention of one year nor that of one hundred", "french": "", "indonesian": "", "russian": "", "urdu": "شعبہ اور ہشام نے قتادہ سے اسی سند کے ساتھ حدیث بیان کی ،  البتہ ان دونوں کی حدیث میں ہے :   \" کنوارے", "grades": "", "reference": "Book 29, Hadith 20", "international_number": "4417", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4418", "arabic": "حَدَّثَنِي  أَبُو الطَّاهِرِ ،  وَحَرْمَلَةُ بْنُ يَحْيَى ، قَالَا: حَدَّثَنَا  ابْنُ وَهْبٍ ، أَخْب", "bengali": "", "english": "Abdullah b. 'Abbas reported that 'Umar b. Khattab sat on the pulpit of Allah's Messenger (ﷺ) and said:Verily Allah sent Muhammad (ﷺ) with truth and He sent down the Book upon him, and the verse of stoning was included in what was sent down to him. We recited it, retained it in our memory and understood it. Allah's Messenger (ﷺ) awarded the punishment of stoning to death (to the married adulterer and adulteress) and, after him, we also awarded the punishment of stoning, I am afraid that with the lapse of time, the people (may forget it) and may say: We do not find the punishment of stoning in the Book of Allah, and thus go astray by abandoning this duty prescribed by Allah. Stoning is a duty laid down in Allah's Book for married men and women who commit adultery when proof is established, or it there is pregnancy, or a confession", "french": "", "indonesian": "", "russian": "", "urdu": "یونس نے مجھے ابن شہاب سے خبر دی ،  انہوں نے کہا :  مجھے عبیداللہ بن عبداللہ بن عتبہ نے خبر دی کہ انہ", "grades": "", "reference": "Book 29, Hadith 21", "international_number": "4418", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4419", "arabic": "وحَدَّثَنَاه  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ،  وَزُهَيْرُ بْنُ حَرْبٍ ،  وَابْنُ أَبِي عُمَرَ ، ق", "bengali": "", "english": "This hadith has been narrated on the authority of Zuhri with the same chain of transmitters", "french": "", "indonesian": "", "russian": "", "urdu": "سفیان نے زہری سے اسی سند کے ساتھ حدیث بیان کی", "grades": "", "reference": "Book 29, Hadith 22", "international_number": "4419", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4420", "arabic": "وحَدَّثَنِي  عَبْدُ الْمَلِكِ بْنُ شُعَيْبِ بْنِ اللَّيْثِ بْنِ سَعْدٍ ، حَدَّثَنِي  أَبِي ، عَنْ  ج", "bengali": "", "english": "Abu Huraira reported that a person from amongst the Muslims came to Allah's Messenger (ﷺ) while he was in the mosque. He called him saying:Allah's Messenger. I have committed adultery. He (the Holy Prophet) turned away from him, He (again) came round facing him and said to him: Allah's Messenger, I have committed adultery. He (the Holy Prophet) turned away until he did that four times, and as he testified four times against his own self, Allah's Messenger (ﷺ) called him and said: Are you mad? He said: No. He (again) said: Are you married? He said: Yes. Thereupon Allah's Messenger (ﷺ) said: Take him and stone him", "french": "", "indonesian": "", "russian": "", "urdu": "عقیل  ( بن خالد اموی )  نے ابن شہاب سے ،  انہوں نے ابوسلمہ بن عبدالرحمان بن عوف اور سعید بن مسیب سے", "grades": "", "reference": "Book 29, Hadith 23", "international_number": "4420", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4421", "arabic": "وَرَوَاهُ اللَّيْثُ أَيْضًا، عَنْ عَبْدِ الرَّحْمَنِ بْنِ خَالِدِ بْنِ مُسَافِرٍ، عَنْ ابْنِ شِهَابٍ", "bengali": "", "english": "Ibn Shihab (one of the narrators) said:One who had heard Jabir b. 'Abdullah saying this informed me thus: I was one of those who stoned him. We stoned him at the place of prayer (either that of 'Id or a funeral). When the stones hurt him, he ran away. We caught him in the Harra and stoned him (to death)", "french": "", "indonesian": "", "russian": "", "urdu": "عبدالرحمان بن خالد بن مسافر نے ابن شہاب سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی", "grades": "", "reference": "Book 29, Hadith 24", "international_number": "4421", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4422", "arabic": "وحَدَّثَنِيهِ  عَبْدُ اللَّهِ بْنُ عَبْدِ الرَّحْمَنِ الدَّارِمِيُّ ، حَدَّثَنَا  أَبُو الْيَمَانِ ،", "bengali": "", "english": "This hadith has been narrated through another chain of transmitters", "french": "", "indonesian": "", "russian": "", "urdu": "شعیب نے بھی شہری سے اسی سند کے ساتھ خبر دی اور ان دونوں  ( عبدالرحمان بن خالد بن مسافر اور شعیب )  ک", "grades": "", "reference": "Book 29, Hadith 25", "international_number": "4422", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4423", "arabic": "وحَدَّثَنِي  أَبُو الطَّاهِرِ ،  وَحَرْمَلَةُ بْنُ يَحْيَى ، قَالَا: أَخْبَرَنَا  ابْنُ وَهْبٍ ، أَخ", "bengali": "", "english": "This hadith has been narrated on the authority of Abu Huraira through other chains of transmitters", "french": "", "indonesian": "", "russian": "", "urdu": "یونس ،  معمر اور ابن جریج سب نے زہری سے ،  انہوں نے ابوسلمہ سے ،  انہوں نے حضرت جابر بن عبداللہ رضی", "grades": "", "reference": "Book 29, Hadith 26", "international_number": "4423", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4424", "arabic": "وحَدَّثَنِي  أَبُو كَامِلٍ فُضَيْلُ بْنُ حُسَيْنٍ الْجَحْدَرِيُّ ، حَدَّثَنَا  أَبُو عَوَانَةَ ، عَن", "bengali": "", "english": "Jabir b. Samura reported:As he was being brought to Allah's Apostle (ﷺ) I saw Ma'iz b. Malik-a short-statured person with strong sinews, having no cloak around him. He bore witness against his own self four times that he had committed adultery, whereupon Allah's Messenger (ﷺ) said: Perhaps (you kissed her or embraced her). He said: No. by God, one deviating (from the path of virtue) has committed adultery. He then got him stoned (to death), and then delivered the address: Behold, as we set out for Jihad in the cause of Allah, one of you lagged behind and shrieked like the bleating of a male goat, and gave a small quantity of milk. By Allah, in case I get hold of him, I shall certainly punish him", "french": "", "indonesian": "", "russian": "", "urdu": "ابو عوانہ نے سماک بن حرب سے ،  انہوں نے حضرت جابر بن سمرہ رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :", "grades": "", "reference": "Book 29, Hadith 27", "international_number": "4424", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4425", "arabic": "وحَدَّثَنَا  مُحَمَّدُ بْنُ الْمُثَنَّى ،  وَابْنُ بَشَّارٍ وَاللَّفْظُ لِابْنِ الْمُثَنَّى، قَالَا:", "bengali": "", "english": "Jabir b. Samura reported that there was brought to Allah's Messenger (ﷺ) a short-statured person with thick uncombed hair, muscular body, having a mantle around him and he had committed adultery. He turned him away twice and then made pronouncement about him and he was stoned. Then Allah's Messenger (ﷺ) said:We set out for Jihad in the cause of Allah and one of you lagged behind and shrieked like the bleating of a male goat and one of then (goats' gave a small quantity of milk. In case Allah gives me power over one of them, I will punish him (in such a way that it may have a deterrent effect upon others). In another narration transmitted on the authority of Sa'id b Jubair (the words are), that He (the Holy Prophet) turned him away four times", "french": "", "indonesian": "", "russian": "", "urdu": "محمد بن جعفر نے کہا :  ہمیں شعبہ نے سماک بن حرب سے حدیث بیان کی ،  انہوں نے کہا :  میں نے حضرت جابر", "grades": "", "reference": "Book 29, Hadith 28", "international_number": "4425", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4426", "arabic": "حَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، حَدَّثَنَا  شَبَابَةُ . ح وحَدَّثَنَا  إِسْحَاقُ بْنُ", "bengali": "", "english": "This hadith has been narrated on the authority of Jabir b. Samura through another chain of transmitters with the difference that along with the mentioning (of the fact) that he (the Holy Prophet) turned him away twice, or thrice", "french": "", "indonesian": "", "russian": "", "urdu": "شبابہ اور ابوعامر عقدی دونوں نے شعبہ سے حدیث بیان کی ،  انہوں نے سماک سے ،  انہوں نے حضرت جابر بن سم", "grades": "", "reference": "Book 29, Hadith 29", "international_number": "4426", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4427", "arabic": "حَدَّثَنَا  قُتَيْبَةُ بْنُ سَعِيدٍ ،  وَأَبُو كَامِلٍ الْجَحْدَرِيُّ وَاللَّفْظُ لِقُتَيْبَةَ، قَال", "bengali": "", "english": "Ibn Abbas reported that Allah's Apostle (ﷺ) said to Ma'iz b. Malik:Is it true what has reached me about you? He said: What has reached you about me? He said: It has reached me that you have committed (adultery) with the slave-girl of so and so? He said: Yes. He (the narrator) said: He testified four times. He (the Holy Prophet) then made pronouncement about him and he was stoned (to death)", "french": "", "indonesian": "", "russian": "", "urdu": "حضرت ابن عباس رضی اللہ عنہ سے روایت ہے کہ نبی صلی اللہ علیہ وسلم نے  ( چار بار واپس کرنے اور اس کے ا", "grades": "", "reference": "Book 29, Hadith 30", "international_number": "4427", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4428", "arabic": "حَدَّثَنِي  مُحَمَّدُ بْنُ الْمُثَنَّى ، حَدَّثَنِي  عَبْدُ الْأَعْلَى ، حَدَّثَنَا  دَاوُدُ ، عَنْ", "bengali": "", "english": "Abu Sa'id reported that a person belonging to the clan of Aslam, who was called Ma, iz b. Malik, came to Allah's Messenger (ﷺ) and said:I have committed immorality (adultery), so inflict punishment upon me. Allah's Apostle (ﷺ) turned him away again and again. He then asked his people (about the state of his mind). They said: We do not know of any ailment of his except that he has committed something about which he thinks that he would not be able to relieve himself of its burden but with the Hadd being imposed upon him. He (Ma'iz) came back to Allah's Apostle (ﷺ) and he commanded us to stone him. We took him to the Baqi' al-Gharqad (the graveyard of Medina). We neither tied him nor dug any ditch for him. We attacked him with bones, with clods and pebbles. He ran away and we ran after him until he came upon the ston ground (al-Harra) and stopped there and we stoned him with heavy stones of the Harra until he became motionless (lie died). He (the Holy Prophet) then addressed (us) in the evening saying Whenever we set forth on an expedition in the cause of Allah, some one of those connected with us shrieked (under the pressure of sexual lust) as the bleating of a male goat. It is essential that if a person having committed such a deed is brought to me, I should punish him. He neither begged forgiveness for him nor cursed him", "french": "", "indonesian": "", "russian": "", "urdu": "عبدالاعلیٰ نے کہا :  ہمیں داود نے ابونضرہ سے حدیث بیان کی ،  انہوں نے حضرت ابوسعید رضی اللہ عنہ سے ر", "grades": "", "reference": "Book 29, Hadith 31", "international_number": "4428", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4429", "arabic": "حَدَّثَنِي  مُحَمَّدُ بْنُ حَاتِمٍ ، حَدَّثَنَا  بَهْزٌ ، حَدَّثَنَا  يَزِيدُ بْنُ زُرَيْعٍ ، حَدَّث", "bengali": "", "english": "Dawud narrated the hadith with the same chain of transmitters (and the words are):Allah's Apostle (ﷺ) stood tip (to address the audience) in the evening and praised Allah, glorified Him and then said: What about the people, that as we set out on an expedition, one of you remained behind us and he shrieked like the bleating of a male goat? But he did not mention (these words): People connected with us", "french": "", "indonesian": "", "russian": "", "urdu": "یزید بن زریع نے کہا :  ہمیں داود نے اسی سند کے ساتھ اسی کے ہم معنی حدیث بیان کی اور انہوں نے حدیث می", "grades": "", "reference": "Book 29, Hadith 32", "international_number": "4429", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4430", "arabic": "وحَدَّثَنَا  سُرَيْجُ بْنُ يُونُسَ ، حَدَّثَنَا  يَحْيَى بْنُ زَكَرِيَّاءَ بْنِ أَبِي زَائِدَةَ . ح", "bengali": "", "english": "This hadith has been narrated on the authority of Dawud with the same chain of transmitters but with this variation that in the hadith narrated by Sufyan (the words are):\" He made a confession of having committed adultery, thrice", "french": "", "indonesian": "", "russian": "", "urdu": "یحییٰ بن زکریا بن ابی زائدہ اور سفیان دونوں نے داود سے اسی سند کے ساتھ اس حدیث کا کچھ حصہ بیان کیا ،", "grades": "", "reference": "Book 29, Hadith 33", "international_number": "4430", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4431", "arabic": "وحَدَّثَنِي  مُحَمَّدُ بْنُ الْعَلَاءِ الْهَمْدَانِيُّ ، حَدَّثَنَا  يَحْيَى بْنُ يَعْلَى وَهُوَ ابْ", "bengali": "", "english": "Sulaiman b. Buraida reported on the authority of his father that Ma, iz b. Malik came to Allah's Apostle (ﷺ) and said to him:Messenger of Allah, purify me, whereupon he said: Woe be upon you, go back, ask forgiveness of Allah and turn to Him in repentance. He (the narrator) said that he went back not far, then came and said: Allah's Messenger, purify me. whereupon Allah's Messenger (ﷺ) said: Woe be upon you, go back and ask forgiveness of Allah and turn to Him in repentance. He (the narrator) said that he went back not far, when he came and said: Allah's Messenger, purify me. Allah's Apostle (ﷺ) said as he had said before. When it was the fourth time, Allah's Messenger (may, peace be upon him) said: From what am I to purify you? He said: From adultery, Allah's Messenger (ﷺ) asked if he had been mad. He was informed that he was not mad. He said: Has he drunk wine? A person stood up and smelt his breath but noticed no smell of wine. Thereupon Allah's Messenger (ﷺ) said: Have you committed adultery? He said: Yes. He made pronouncement about him and he was stoned to death. The people had been (divided) into two groups about him (Ma'iz). One of them said: He has been undone for his sins had encompassed him, whereas another said: There is no repentance more excellent than the repentance of Ma'iz, for he came to Allah's Apostle (ﷺ) and placing his hand in his (in the Holy Prophet's) hand said: Kill me with stones. (This controversy about Ma'iz) remained for two or three days. Then came Allah's Messenger (ﷺ) to them (his Companions) as they were sitting. He greeted them with salutation and then sat down and said: Ask forgiveness for Ma'iz b. Malik. They said: May Allah forgive Ma'iz b. Malik. Thereupon Allah's Messenger (ﷺ) said: He (Ma'iz) has made such a repentance that if that were to be divided among a people, it would have been enough for all of them. He (the narrator) said: Then a woman of Ghamid, a branch of Azd, came to him and said: Messenger of of Allah, purify me, whereupon he said: Woe be upon you; go back and beg forgiveness from Allah and turn to Him in repentance. She said: I find that you intend to send me back as you sent back Ma'iz. b. Malik. He (the Holy, Prophet) said: What has happened to you? She said that she had become pregnant as a result of fornication. He (the Holy Prophet) said: Is it you (who has done that)? She said: Yes. He (the Holy Prophet) said to her: (You will not be punished) until you deliver what is there in your womb. One of the Ansar became responsible for her until she was delivered (of the child). He (that Ansari) came to Allah's Apostle (ﷺ) and said the woman of Ghamid has given birth to a child. He (the Holy Prophet) said: In that case we shall not stone her and so leave her infant with none to suckle him. One of the Ansar got up and said: Allah's Apostle, let the responsibility of his suckling be upon me. She was then stoned to death", "french": "", "indonesian": "", "russian": "", "urdu": "سلیمان بن بریدہ نے اپنے والد  ( بریدہ بن حصیب اسلمی رضی اللہ عنہ )  سے روایت کی ،  انہوں نے کہا :  م", "grades": "", "reference": "Book 29, Hadith 34", "international_number": "4431", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4432", "arabic": "وحَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، حَدَّثَنَا  عَبْدُ اللَّهِ بْنُ نُمَيْرٍ . ح وحَدَّث", "bengali": "", "english": "Abdullah b. Buraida reported on the authority of his father that Ma'iz b. Malik al-Aslami came to Allah's Messenger (ﷺ) and said:Allah's Messenger, I have wronged myself; I have committed adultery and I earnestly desire that you should purify me. He turned him away. On the following day, he (Ma'iz) again came to him and said: Allah's Messenger, I have committed adultery. Allah's Messenger (ﷺ) turned him away for the second time, and sent him to his people saying: Do you know if there is anything wrong with his mind. They denied of any such thing in him and said: We do not know him but as a wise good man among us, so far as we can judge. He (Ma'iz) came for the third time, and he (the Holy Prophet) sent him as he had done before. He asked about him and they informed him that there was nothing wrong with him or with his mind. When it was the fourth time, a ditch was dug for him and he (the Holy Prophet) pronounced judg- ment about him and he wis stoned. He (the narrator) said: There came to him (the Holy Prophet) a woman from Ghamid and said: Allah's Messenger, I have committed adultery, so purify me. He (the Holy Prophet) turned her away. On the following day she said: Allah's Messenger, Why do you turn me away? Perhaps, you turn me away as you turned away Ma'iz. By Allah, I have become pregnant. He said: Well, if you insist upon it, then go away until you give birth to (the child). When she was delivered she came with the child (wrapped) in a rag and said: Here is the child whom I have given birth to. He said: Go away and suckle him until you wean him. When she had weaned him, she came to him (the Holy Prophet) with the child who was holding a piece of bread in his hand. She said: Allah's Apostle, here is he as I have weaned him and he eats food. He (the Holy Prophet) entrusted the child to one of the Muslims and then pronounced punishment. And she was put in a ditch up to her chest and he commanded people and they stoned her. Khalid b Walid came forward with a stone which he flung at her head and there spurted blood on the face of Khalid and so he abused her. Allah's Apostle (ﷺ) heard his (Khalid's) curse that he had huried upon her. Thereupon he (the Holy Prophet) said: Khalid, be gentle. By Him in Whose Hand is my life, she has made such a repentance that even if a wrongful tax-collector were to repent, he would have been forgiven. Then giving command regarding her, he prayed over her and she was buried", "french": "", "indonesian": "", "russian": "", "urdu": "بُشیر بن مہاجر نے حدیث بیان کی ،  کہا :  عبداللہ بن بریدہ نے ہمیں اپنے والد سے حدیث بیان کی کہ ماعز", "grades": "", "reference": "Book 29, Hadith 35", "international_number": "4432", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4433", "arabic": "حَدَّثَنِي  أَبُو غَسَّانَ مَالِكُ بْنُ عَبْدِ الْوَاحِدِ الْمِسْمَعِيُّ ، حَدَّثَنَا  مُعَاذٌ يَعْن", "bengali": "", "english": "Imran b. Husain reported that a woman from Juhaina came to Allah's Apostle (ﷺ) and she had become pregnant because of adultery. She said:Allah's Apostle, I have done something for which (prescribed punishment) must be imposed upon me, so impose that. Allah's Apostle (ﷺ) called her master and said: Treat her well, and when she delivers bring her to me. He did accordingly. Then Allah's Apostle (ﷺ) pronounced judgment about her and her clothes were tied around her and then he commanded and she was stoned to death. He then prayed over her (dead body). Thereupon Umar said to him: Allah's Apostle, you offer prayer for her, whereas she had committed adultery! Thereupon he said: She has made such a repentance that if it were to be divided among seventy men of Medina, it would be enough. Have you found any repentance better than this that she sacr ficed her life for Allah, the Majestic?", "french": "", "indonesian": "", "russian": "", "urdu": "ہشام نے مجھے یحییٰ بن ابی کثیر سے حدیث بیان کی ،  کہا :  مجھے ابوقلابہ نے حدیث بیان کی کہ انہیں ابوم", "grades": "", "reference": "Book 29, Hadith 36", "international_number": "4433", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4434", "arabic": "وحَدَّثَنَاه  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، حَدَّثَنَا  عَفَّانُ بْنُ مُسْلِمٍ ، حَدَّثَنَا  أَ", "bengali": "", "english": "This hadith has been transmitted on the authority of Yahya b. Abu Kathir", "french": "", "indonesian": "", "russian": "", "urdu": "ابان عطار نے یحییٰ بن ابی کثیر سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی", "grades": "", "reference": "Book 29, Hadith 37", "international_number": "4434", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4437", "arabic": "حَدَّثَنِي  الْحَكَمُ بْنُ مُوسَى أَبُو صَالِحٍ ، حَدَّثَنَا  شُعَيْبُ بْنُ إِسْحَاقَ ، أَخْبَرَنَا", "bengali": "", "english": "Abdullah b. 'Umar reported that a Jew and a Jewess were brought to Allah's Messenger (ﷺ) who had committed adultery. Allah's Messenger (ﷺ) came to the Jews and said:What do you find in Torah for one who commits adultery? They said: We darken their faces and make them ride on the donkey with their faces turned to the opposite direction (and their backs touching each other), and then they are taken round (the city). He said: Bring Torah if you are truthful. They brought it and recited it until when they came to the verse pertaining to stoning, the person who was reading placed his hand on the verse pertaining to stoning, and read (only that which was) between his hands and what was subsequent to that. Abdullah b. Salim who was at that time with the Messenger of Allah (ﷺ) said: Command him (the reciter) to lift his hand. He lifted it and there was, underneath that, the verse pertaining to stoning. Allah's Messenger (ﷺ) pronounced judgment about both of them and they were stoned. Abdullah b. 'Umar said: I was one of those who stoned them, and I saw him (the Jew) protecting her (the Jewess) with his body", "french": "", "indonesian": "", "russian": "", "urdu": "عبیداللہ نے ہمیں نافع سے خبر دی ،  کہا :  حضرت عبداللہ بن عمر رضی اللہ عنہ نے انہیں بتایا کہ رسول ال", "grades": "", "reference": "Book 29, Hadith 40", "international_number": "4437", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4438", "arabic": "وحَدَّثَنَا  زُهَيْرُ بْنُ حَرْبٍ ، حَدَّثَنَا  إِسْمَاعِيلُ يَعْنِي ابْنَ عُلَيَّةَ ، عَنْ  أَيُّوب", "bengali": "", "english": "Ibn Umar reported that Allah's Messenger (ﷺ) stoned to death the Jews, both male and female, who had committed adultery. The Jews brought them to Allah's Messenger (may peace he upon him). The rest of the hadith is the same", "french": "", "indonesian": "", "russian": "", "urdu": "ابن علیہ نے ہمیں ایوب سے خبر دی ،  نیز عبداللہ بن وہب نے کہا :  مجھے اہل علم میں سے بہت سے آدمیوں نے", "grades": "", "reference": "Book 29, Hadith 41", "international_number": "4438", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4439", "arabic": "وحَدَّثَنَا  أَحْمَدُ بْنُ يُونُسَ ، حَدَّثَنَا  زُهَيْرٌ ، حَدَّثَنَا  مُوسَى بْنُ عُقْبَةَ ، عَنْ", "bengali": "", "english": "Ibn 'Umar reported that the Jews brought to Allah's Messenger (ﷺ) a man and a woman who had committed adultery. The rest of the hadith is the same", "french": "", "indonesian": "", "russian": "", "urdu": "موسیٰ بن عقبہ نے ہمیں نافع سے حدیث بیان کی ،  انہوں نے حضرت ابن عمر رضی اللہ عنہ سے روایت کی کہ یہود", "grades": "", "reference": "Book 29, Hadith 42", "international_number": "4439", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4440", "arabic": "حَدَّثَنَا  يَحْيَى بْنُ يَحْيَى ،  وَأَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ كِلَاهُمَا، عَنْ أَبِي مُعَاو", "bengali": "", "english": "Al-Bara' b. 'Azib reported:There happened to pass by Allah's Apostle (ﷺ) a Jew blackened and lashed. Allah's Apostle (ﷺ) called them (the Jews) and said: Is this the punishment that you find in your Book (Torah) as a prescribed punishment for adultery? They said: Yes. He (the Holy Prophet) called one of the scholars amongst them and said: I ask you in the name of Allah Who sent down the Torah on Moses if that is the prescribed punishment for adultery that you find in your Book. He said: No. Had you not asked me in the name of Allah, I would not have given you this information. We find stoning to death (as punishment prescribed in the Torah). But this (crime) became quite common amongst our aristocratic class. So when we caught hold of any rich person (indulging in this offence) we spared him, but when we caught hold of a helpless person we imposed the prescribed punishment upon him. We then said: Let us argree (on a punishment) which we can inflict both upon the rich and the poor. So We decided to blacken the face with coal and flog as a substitute punishment for stoning. Thereupon Allah's Messenger (ﷺ) said: O Allah, I am the first to revive Thy command when they had made it dead. He then commanded and he (the offender) was stoned to death. Allah, the Majestic and Glorious, sent down (this verse):\" O Messenger, (the behaviour of) those who vie with one another in denying the truth should not grieve you...\" up to\" is vouchsafed unto you, accept it\" (v. 41) 2176 It was said (by the Jews): Go to Muhammad; it he commands you to blacken the face and award flogging (as punishment for adultery), then accept it, but it he gives verdict for stoning, then avoid it. It was (then) that Allah, the Majestic and Great, sent down (these verses):\" And they who do not judge in accordance with what Allah has revealed are, indeed, deniers of the truth\" (v. 44) ;\" And they who do not judge in accordance with what Allah has revealed-they, they indeed are the wrongdoers\" (v. 45) ;\" And they who do not judge in accordance with what God has revealed-they are the iniquitous (v. 47). (All these verses) were revealed in connection with the non-believers", "french": "", "indonesian": "", "russian": "", "urdu": "ابومعاویہ نے اعمش سے ،  انہوں نے عبداللہ بن مرہ سے اور انہوں نے حضرت براء بن عازب رضی اللہ عنہ سے رو", "grades": "", "reference": "Book 29, Hadith 43", "international_number": "4440", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4441", "arabic": "حَدَّثَنَا  ابْنُ نُمَيْرٍ ،  وَأَبُو سَعِيدٍ الْأَشَجّ ، قَالَا: حَدَّثَنَا  وَكِيعٌ ، حَدَّثَنَا", "bengali": "", "english": "This hadith has been narrated on the authority of A'mash up to the words:\" Allah's Apostle (ﷺ) pronounced judgment and he was stoned (to death)\" And he mentioned nothing subsequent to that pertaining to the revelation of verses", "french": "", "indonesian": "", "russian": "", "urdu": "وکیع نے ہمیں حدیث بیان کی ،  کہا :  ہمیں اعمش نے اسی سند کے ساتھ اس قول تک ،  اسی طرح حدیث بیان کی :", "grades": "", "reference": "Book 29, Hadith 44", "international_number": "4441", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4442", "arabic": "وحَدَّثَنِي  هَارُونُ بْنُ عَبْدِ اللَّهِ ، حَدَّثَنَا  حَجَّاجُ بْنُ مُحَمَّدٍ ، قَالَ: قَالَ  ابْن", "bengali": "", "english": "Jabir b. 'Abdullah reported that Allah's Apostle (ﷺ) stoned (to death) a person from Banu Aslam, and a Jew and his wife", "french": "", "indonesian": "", "russian": "", "urdu": "حجاج بن محمد نے ہمیں حدیث بیان کی ،  کہا :  ابن جریج نے کہا :  مجھے ابوزبیر نے خبر دی کہ انہون نے حض", "grades": "", "reference": "Book 29, Hadith 45", "international_number": "4442", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4443", "arabic": "حَدَّثَنَا  إِسْحَاقُ بْنُ إِبْرَاهِيمَ ، أَخْبَرَنَا  رَوْحُ بْنُ عُبَادَةَ ، حَدَّثَنَا  ابْنُ جُر", "bengali": "", "english": "This hadith has been transmitted on the authority of Juraij with a slight variation of words", "french": "", "indonesian": "", "russian": "", "urdu": "رَوح بن عبادہ نے ابن جریج سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی ،  البتہ انہوں نے  ( اور اس ک", "grades": "", "reference": "Book 29, Hadith 46", "international_number": "4443", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4444", "arabic": "وحَدَّثَنَا  أَبُو كَامِلٍ الْجَحْدَرِيُّ ، حَدَّثَنَا  عَبْدُ الْوَاحِدِ ، حَدَّثَنَا  سُلَيْمَانُ", "bengali": "", "english": "Abu Ishaq Shaibani said:I asked 'Abdullah b. Abu Aufi if Allah's Messenger (ﷺ) awarded (the punishment) of stoning (to death). He said: Yes. I said: After Sura al-Nur was revealed or before that? He said: I do not know", "french": "", "indonesian": "", "russian": "", "urdu": "ابواسحاق شیبانی سے روایت ہے ،  انہوں نے کہا :  میں نے عبداللہ بن ابی اوفیٰ رضی اللہ عنہ سے پوچھا :", "grades": "", "reference": "Book 29, Hadith 47", "international_number": "4444", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4445", "arabic": "وحَدَّثَنِي  عِيسَى بْنُ حَمَّادٍ الْمِصْرِيُّ ، أَخْبَرَنَا  اللَّيْثُ ، عَنْ  سَعِيدِ بْنِ أَبِي س", "bengali": "", "english": "Abu Huraira reported that he heard Allah's Messenger (ﷺ) as saying:When the slave-woman of any of you commits adultery and this (offence of hers) becomes clear, she should be flogged (as the prescribed) punishment, but hurl no reproach at her. If she commits adultery again, she should (again be punished) by flogging, but hurl no reproach upon her. If she commits fornication for the third time and it becomes clear, then he should sell her, even if only for a rope of hair", "french": "", "indonesian": "", "russian": "", "urdu": "لیث نے سعید بن ابی سعید سے ،  انہوں نے اپنے والد سے خبر دی ،  انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے", "grades": "", "reference": "Book 29, Hadith 48", "international_number": "4445", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4446", "arabic": "حَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ،  وَإِسْحَاقُ بْنُ إِبْرَاهِيمَ جَمِيعًا، عَنْ  ابْنِ", "bengali": "", "english": "This hadith his been narrated on the authority of Abu Huraira through another chain of transmitters with a slight variation of words", "french": "", "indonesian": "", "russian": "", "urdu": "ایوب بن موسیٰ ،  عبیداللہ بن عمر ،  اسامہ بن زید اور محمد بن اسحاق سب نے سعید مقبری سے ،  انہوں نے ح", "grades": "", "reference": "Book 29, Hadith 49", "international_number": "4446", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4447", "arabic": "حَدَّثَنَا  عَبْدُ اللَّهِ بْنُ مَسْلَمَةَ الْقَعْنَبِيُّ ، حَدَّثَنَا  مَالِكٌ . ح وحَدَّثَنَا  يَح", "bengali": "", "english": "Abu Huraira reported that Allah's Messenger (ﷺ) was asked about the slave-woman who committed adultery and was not protected (married). He said:If she commits adultery, then flog her and if she commits adultery again, then flog her and then sell her even for a rope. Ibn Shihab said: I do not know whether he said this (his statement pertaining to the sale of slave-woman) at the third or the fourth time. Ibn Shihab said that the word dafir (used in the text) means rope", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن مسلمہ قعنبی نے کہا :  ہمیں مالک نے حدیث سنائی ،  اور یحییٰ بن یحییٰ نے  ۔  ۔  حدیث کے الف", "grades": "", "reference": "Book 29, Hadith 50", "international_number": "4447", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4448", "arabic": "وحَدَّثَنَا  أَبُو الطَّاهِرِ ، أَخْبَرَنَا  ابْنُ وَهْبٍ ، قَالَ: سَمِعْتُ  مَالِكًا ، يَقُولُ: حَد", "bengali": "", "english": "This hadith has been narrated on the authority of Abu Huraira and Zaid b. Khalid al-Jubani, but in this no merition is made of the words of Ibn Shihab that dafir means rope", "french": "", "indonesian": "", "russian": "", "urdu": "ابن وہب نے کہا :  میں نے امام مالک سے سنا ،  وہ کہہ رہے تھے :  مجھے ابن شہاب نے عبیداللہ بن عبداللہ", "grades": "", "reference": "Book 29, Hadith 51", "international_number": "4448", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4449", "arabic": "حَدَّثَنِي  عَمْرٌو النَّاقِدُ ، حَدَّثَنَا  يَعْقُوبُ بْنُ إِبْرَاهِيمَ بْنِ سَعْدٍ ، حَدَّثَنِي  أ", "bengali": "", "english": "This hadith has been transmitted on the authority of Abu Huraira and Zaid b. Khalid al-Juhani in the same way as transmitted by Malik with this (difference) tnat there is a doubt whether her sale (that of the slave-girl committing adultery) was mentioned after the third or the fourth time", "french": "", "indonesian": "", "russian": "", "urdu": "صالح اور معمر دونوں ن زہری سے ،  انہوں نے عبیداللہ سے ،  انہوں نے حضرت ابوہریرہ اور حضرت خالد بن جہن", "grades": "", "reference": "Book 29, Hadith 52", "international_number": "4449", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4450", "arabic": "حَدَّثَنَا  مُحَمَّدُ بْنُ أَبِي بَكْرٍ الْمُقَدَّمِيُّ ، حَدَّثَنَا  سُلَيْمَانُ أَبُو دَاوُدَ ، حَ", "bengali": "", "english": "Abd al-Rahman reported that 'Ali, while delivering the address said:O people, impose the prescribed punishment upon your slaves, those who are married and those not married, for a slave-woman belonging to Allah's Messenger (ﷺ) had committed adultery, and he committed me to flog her. But she had recently given birth to a child and I was afraid that if I flogged her I might kill her. So I mentioned that to Allah's Apostle (ﷺ) and he said: You have done well", "french": "", "indonesian": "", "russian": "", "urdu": "زائدہ نے سُدی سے ،  انہوں نے سعد بن عبیدہ سے اور انہوں نے ابوعبدالرحمان سے روایت کی ،  انہوں نے کہا", "grades": "", "reference": "Book 29, Hadith 53", "international_number": "4450", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4451", "arabic": "وحَدَّثَنَاه  إِسْحَاقُ بْنُ إِبْرَاهِيمَ ، أَخْبَرَنَا  يَحْيَى بْنُ آدَمَ ، حَدَّثَنَا  إِسْرَائِي", "bengali": "", "english": "This hadith has been narrated on the authority of as-Suddi with the same chain of trznsmitters, but he did not mention:\" Those who are married and those who are not married.\" There is also an addition in it:\" I spare her until she is all right", "french": "", "indonesian": "", "russian": "", "urdu": "اسرائیل نے سُدی سے اسی سند کے ساتھ حدیث بیان کی اور انہوں نے یہ بیان کیا :   \" جو ان میں سے شادی شدہ", "grades": "", "reference": "Book 29, Hadith 54", "international_number": "4451", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4452", "arabic": "حَدَّثَنَا  مُحَمَّدُ بْنُ الْمُثَنَّى ،  وَمُحَمَّدُ بْنُ بَشَّارٍ ، قَالَا: حَدَّثَنَا  مُحَمَّدُ", "bengali": "", "english": "Anas b. Malik reported that a person who had drink wine was brought to Allah's Apostle (ﷺ). He gave him forty stripes with two lashes. Abu Bakr also did that, but when Umar (assumed the responsibilities) of the Caliphate, he consulted people and Abd al-Rahman said:The mildest punishment (for drinking) is eighty (stripes) and 'Umar their prescribed this punishment", "french": "", "indonesian": "", "russian": "", "urdu": "محمد بن جعفر نے ہمیں حدیث سنائی ،  کہا :  ہمیں شعبہ نے حدیث بیان کی ،  انہوں نے کہا :  میں نے قتادہ", "grades": "", "reference": "Book 29, Hadith 55", "international_number": "4452", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4453", "arabic": "وحَدَّثَنَا  يَحْيَى بْنُ حَبِيبٍ الْحَارِثِيُّ ، حَدَّثَنَا  خَالِدٌ يَعْنِي ابْنَ الْحَارِثِ ، حَد", "bengali": "", "english": "This hadith has been narrated on the authority of Anas through another chain of transmitters", "french": "", "indonesian": "", "russian": "", "urdu": "خالد بن حارث نے کہا :  ہمیں شعبہ نے حدیث بیان کی ،  انہوں نے کہا :  ہمیں قتادہ نے حدیث بیان کی ،  ان", "grades": "", "reference": "Book 29, Hadith 56", "international_number": "4453", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4454", "arabic": "حَدَّثَنَا  مُحَمَّدُ بْنُ الْمُثَنَّى ، حَدَّثَنَا  مُعَاذُ بْنُ هِشَامٍ ، حَدَّثَنِي  أَبِي ، عَنْ", "bengali": "", "english": "Anas b. Malik reported that Allah's Apostle (ﷺ) gave a beating with palm branches and shoes, and that Abu Bakr gave forty lashes. When Umar (became the Commander of the Faithful) and the people went near to pastures and towns, he said (to the Companions of the Holy Prophet). What is your opinion about lashing for drinking? Thereupon Abd al-Rahman b. Auf said:My opinion is that you fix it as the mildest punishment. Then 'Umar inflicted eighty stripes", "french": "", "indonesian": "", "russian": "", "urdu": "معاذ بن ہشام نے کہا :  مجھے میرے والد نے قتادہ سے حدیث بیان کی ،  انہوں نے حضرت انس بن مالک رضی اللہ", "grades": "", "reference": "Book 29, Hadith 57", "international_number": "4454", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4455", "arabic": "وحَدَّثَنَا  مُحَمَّدُ بْنُ الْمُثَنَّى ، حَدَّثَنَا  يَحْيَى بْنُ سَعِيدٍ ، حَدَّثَنَا  هِشَامٌ بِه", "bengali": "", "english": "This hadith has been narrated on the authority of Hisham with the same chain of transmitters", "french": "", "indonesian": "", "russian": "", "urdu": "یحییٰ بن سعید نے ہشام سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی", "grades": "", "reference": "Book 29, Hadith 58", "international_number": "4455", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4456", "arabic": "وحَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ، حَدَّثَنَا  وَكِيعٌ ، عَنْ  هِشَامٍ ، عَنْ  قَتَادَة", "bengali": "", "english": "Anas reported that Allah's Apostle (ﷺ) used to strike forty times with shoes and palm branches (in case of drinking of) wine. The rest of the hadith is the same and there is no mention of pastures and towns", "french": "", "indonesian": "", "russian": "", "urdu": "انس ‌رضی ‌اللہ ‌عنہ ‌سے ‌روایت ‌ہے ‌جناب ‌رسول ‌اللہ ‌صلی ‌اللہ ‌علیہ ‌وسلم ‌شراب ‌میں ‌چالیس ‌مار ‌", "grades": "", "reference": "Book 29, Hadith 59", "international_number": "4456", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4457", "arabic": "وحَدَّثَنَا  أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ،  وَزُهَيْرُ بْنُ حَرْبٍ ،  وَعَلِيُّ بْنُ حُجْرٍ ، ق", "bengali": "", "english": "Hudain b. al-Mundhir Abu Sasan reported:I saw that Walid was brought to Uthmin b. 'Affan as he had prayed two rak'ahs of the dawn prayer, and then he said: I make an increase for you. And two men bore witness against him. One of them was Humran who said that he had drunk wine. The second one gave witness that he had seen him vomiting. Uthman said: He would not have vomited (wine) unless he had drunk it. He said: 'Ali, stand up and lash him. 'Ali said: Hasan, stand up and lash him. Thereupon Hasan said: Let him suffer the heat (of Caliphate) who has enjoyed its coolness. ('Ali felt annoyed at this remark) and he said: 'Abdullah b. Ja'far, stand up and flog him, and he began to flog him and 'Ali counted the stripes until these were forty. He (Hadrat 'Ali) said: Stop now, and then said: Allah's Apostle (ﷺ) gave forty stripes, and Abu Bakr also gave forty stripes, and Umar gave eighty stripes, and all these fall under the category of the Sunnab, but this one (forty stripes) is dearer to me", "french": "", "indonesian": "", "russian": "", "urdu": "ابوبکر بن ابی شیبہ ،  زہیر بن حرب اور علی بن حجر سب نے کہا :  ہمیں اسماعیل بن علیہ نے ابن ابی عروبہ", "grades": "", "reference": "Book 29, Hadith 60", "international_number": "4457", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4458", "arabic": "حَدَّثَنِي  مُحَمَّدُ بْنُ مِنْهَالٍ الضَّرِيرُ ، حَدَّثَنَا  يَزِيدُ بْنُ زُرَيْعٍ ، حَدَّثَنَا  سُ", "bengali": "", "english": "Ali reported:If I impose Hadd on anyone, and he (in course of punish ment) dies, I would not mind except in case of a drunkard. If he dies. I would pay indemnity for him because the Messenger of Allah (ﷺ) has laid down no rule for it", "french": "", "indonesian": "", "russian": "", "urdu": "یزید بن زریع نے کہا :  ہمیں سفیان ثوری نے ابوحصین سے حدیث بیان کی ،  انہوں نے عمیر بن سعد سے اور انہ", "grades": "", "reference": "Book 29, Hadith 61", "international_number": "4458", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4459", "arabic": "حَدَّثَنَا  مُحَمَّدُ بْنُ الْمُثَنَّى ، حَدَّثَنَا  عَبْدُ الرَّحْمَنِ ، حَدَّثَنَا  سُفْيَانُ بِهَ", "bengali": "", "english": "This hadith is narrated on the authority of Sufyan", "french": "", "indonesian": "", "russian": "", "urdu": "عبدالرحمان نے سفیان سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی", "grades": "", "reference": "Book 29, Hadith 62", "international_number": "4459", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4460", "arabic": "حَدَّثَنَا  أَحْمَدُ بْنُ عِيسَى ، حَدَّثَنَا  ابْنُ وَهْبٍ ، أَخْبَرَنِي  عَمْرٌو ، عَنْ  بُكَيْرِ", "bengali": "", "english": "Abu Barda Ansari reported Allah's Messenger (ﷺ) as saying:None should be given more than ten lashes, but in case of any Hadd out of the Huded of Allah", "french": "", "indonesian": "", "russian": "", "urdu": "حضرت ابوبردہ انصاری رضی اللہ عنہ سے روایت ہے کہ انہوں نے رسول اللہ صلی اللہ علیہ وسلم کو یہ فرماتے ہ", "grades": "", "reference": "Book 29, Hadith 63", "international_number": "4460", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4461", "arabic": "حَدَّثَنَا  يَحْيَي بْنُ يَحْيَي التَّمِيمِيُّ ،  وَأَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ،  وَعَمْرٌو ال", "bengali": "", "english": "Ubida b. as-Samit reported:While we were in the company of Allah's Messenger (may peace be upoi him) he said: Swear allegiance to me that you will not associate anything with Allah, that you will not commit adultery, that you will not steal, that you will not take any life which it is forbidden by Allah to take but with (legal) justification; and whoever among you fulfils it, his reward is with Allah and he who commits any such thing and is punished for it, that will be all atonement for it And if anyone commits anything and Allah conceals (his faultfls), his matter rests with Allah. He may forgive if He likes, and He may punish him if He likes", "french": "", "indonesian": "", "russian": "", "urdu": "عبادہ بن صامتؓ سے روایت ہے رسول اﷲ ﷺ کے ساتھ بیٹھے تھے آپ نے فرمایا بیعت کرو مجھ سے اس اقرار پر کہ ا", "grades": "", "reference": "Book 29, Hadith 64", "international_number": "4461", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4462", "arabic": "حَدَّثَنَا  عَبْدُ بْنُ حُمَيْدٍ ، أَخْبَرَنَا  عَبْدُ الرَّزَّاقِ ، أَخْبَرَنَا  مَعْمَرٌ ، عَنْ  ا", "bengali": "", "english": "This hadith has been narrated on the authority of Zuhri with the same chain of transmitters with this addition:\" He recited to us the verse pertaining to women, viz, that they will not associate anything with Allah", "french": "", "indonesian": "", "russian": "", "urdu": "معمر نے زہری سے اسی سند کے ساتھ حدیث بیان کی اور حدیث میں یہ اضافہ کیا :  اس کے بعد آپ نے ہمارے سامن", "grades": "", "reference": "Book 29, Hadith 65", "international_number": "4462", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4463", "arabic": "وحَدَّثَنِي  إِسْمَاعِيلُ بْنُ سَالِمٍ ، أَخْبَرَنَا  هُشَيْمٌ ، أَخْبَرَنَا  خَالِدٌ ، عَنْ  أَبِي", "bengali": "", "english": "Ubida b. as-Samit reported:Allah's Messenger (ﷺ) took (a pledge) from us as he took from the women that we will not associate anything with Allah and we will not steal, and we will not commit adultery, and we will not kill our children, and we will not bring calumny upon one another. And he who amongst you fulfils (this pledge), his reward rests with Allah, and he upon whom amongst you is imposed the prescribed punishment and that is carried out, that is his expiation (for that sin), and he whose (sins) were covered by Allah, his matter rests with Allah. He may punish him if He likes or may forgive him if He so likes", "french": "", "indonesian": "", "russian": "", "urdu": "ابو اشعث صنعانی نے حضرت عبادہ بن صامت رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  رسول اللہ صلی اللہ", "grades": "", "reference": "Book 29, Hadith 66", "international_number": "4463", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4464", "arabic": "حَدَّثَنَا  قُتَيْبَةُ بْنُ سَعِيدٍ ، حَدَّثَنَا  لَيْثٌ . ح وحَدَّثَنَا  مُحَمَّدُ بْنُ رُمْحٍ ، أَ", "bengali": "", "english": "Ubida b. as-Samit repnrted:I was one of those headmen who swore allegiance to Allah's Messenger (ﷺ) that we will not associate anything with Allah, and will not commit adultery, and will not steal, and will not kill any soul which Allah has forbidden, but with justice nor plunder, nor disobey (Allah and His Apostle), then Paradise (will be the reward) in case we do these (acts) ; and if we commit any outrage (and that goes unpunished in the world), it is Allah Who would decide about it. Ibn Rumh said: Its judgment lies with Allah", "french": "", "indonesian": "", "russian": "", "urdu": "قتیبہ بن سعید اور محمد بن رمح نے لیث سے ،  انہوں نے یزید بن ابی حبیب سے ،  انہوں نے ابوالخیر سے ،  ا", "grades": "", "reference": "Book 29, Hadith 67", "international_number": "4464", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4465", "arabic": "حَدَّثَنَا  يَحْيَي بْنُ يَحْيَي ،  وَمُحَمَّدُ بْنُ رُمْحٍ ، قَالَا: أَخْبَرَنَا  اللَّيْثُ . ح وحَ", "bengali": "", "english": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:No requital is payable for a wound caused by an animal, for (falling into) a well and a mine, and one-fifth (is the share of the government) in the buried treasure (treasure-trove)", "french": "", "indonesian": "", "russian": "", "urdu": "ابو ‌ہریرہ ‌رضی ‌اللہ ‌عنہ ‌سے ‌روایت ‌ہے ‌جناب ‌رسول ‌اللہ ‌صلی ‌اللہ ‌علیہ ‌وسلم ‌نے ‌فرمایا ‌جانو", "grades": "", "reference": "Book 29, Hadith 68", "international_number": "4465", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4466", "arabic": "وحَدَّثَنَا  يَحْيَي بْنُ يَحْيَي ،  وَأَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ ،  وَزُهَيْرُ بْنُ حَرْبٍ ،", "bengali": "", "english": "A hadith like this has been transmitted on the authority of Zuhri", "french": "", "indonesian": "", "russian": "", "urdu": "ابن عیینہ اور امام مالک دونوں نے زہری سے لیث کی سند کے ساتھ اسی کے مانند حدیث بیان کی", "grades": "", "reference": "Book 29, Hadith 69", "international_number": "4466", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4467", "arabic": "وحَدَّثَنِي  أَبُو الطَّاهِرِ ،  وَحَرْمَلَةُ ، قَالَا: أَخْبَرَنَا  ابْنُ وَهْبٍ ، أَخْبَرَنِي  يُو", "bengali": "", "english": "A hadith like this has been transmitted on the authority of Abu Huraira", "french": "", "indonesian": "", "russian": "", "urdu": "یونس نے ابن شہاب سے ،  انہوں نے ابن مسیب اور عبیداللہ بن عبداللہ سے ،  انہوں نے ابوہریرہ رضی اللہ عن", "grades": "", "reference": "Book 29, Hadith 70", "international_number": "4467", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4468", "arabic": "حَدَّثَنَا  مُحَمَّدُ بْنُ رُمْحِ بْنِ الْمُهَاجِرِ ، أَخْبَرَنَا  اللَّيْثُ ، عَنْ  أَيُّوبَ بْنِ م", "bengali": "", "english": "Abu Huraira reported Allah's Messenger (ﷺ) as saying:The wound caused (by falling) in the well, in the mine, and caused bv the animal has no requital for it; and there is one-fifth (for the government) in the buried treasure", "french": "", "indonesian": "", "russian": "", "urdu": "اسود بن علاء نے ابوسلمہ بن عبدالرحمان سے ،  انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے اور انہوں نے رسول", "grades": "", "reference": "Book 29, Hadith 71", "international_number": "4468", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
{"hadithnumber": "4469", "arabic": "وحَدَّثَنَا  عَبْدُ الرَّحْمَنِ بْنُ سَلَّامٍ الْجُمَحِيُّ ، حَدَّثَنَا  الرَّبِيعُ يَعْنِي ابْنَ مُ", "bengali": "", "english": "A hadith like this has been transmitted on the authority of Abu Huraira", "french": "", "indonesian": "", "russian": "", "urdu": "محمد بن زیاد نے حضرت ابوہریرہ رضی اللہ عنہ سے اور انہوں نے نبی صلی اللہ علیہ وسلم سے اسی کے مانند رو", "grades": "", "reference": "Book 29, Hadith 72", "international_number": "4469", "narrator_chain": "", "chapter_intro": "The Book of Legal Punishments"}
