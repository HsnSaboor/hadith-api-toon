{"hadithnumber": "1", "text": "ابن شہاب ( محمد بن مسلم بن عبید اللہ بن عبداللہ بن شہاب ، المعروف امام زہری رحمہ اللہ ) سے روایت ہے"}
{"hadithnumber": "2", "text": "عطاء بن یسار سے روایت ہے کہ ایک شخص رسول اللہ ﷺ کے پاس آیا ، اس نے آپ ﷺ سے نمازِ فجر کے وقت کے متعلق"}
{"hadithnumber": "3", "text": "سیدہ عائشہ رضی اللہ عنہا زوجۂ پیغمبر ﷺ روایت کرتی ہیں کہ بلاشبہ رسول اللہ ﷺ صبح کی نماز پڑھتے ، پھر"}
{"hadithnumber": "4", "text": "حضرت ابوہریرہ رضی اللہ عنہ روایت کرتے ہیں کہ رسول اللہ ﷺ نے فرمایا :’’ جس نے سورج طلوع ہونے سے پہلے"}
{"hadithnumber": "5", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہما کے آزاد کردہ غلام نافع رحمہ اللہ سے روایت ہے کہ حضرت عمر بن خطاب"}
{"hadithnumber": "6", "text": "ابو سہیل ( نافع ) بن مالک اپنے والد ( مالک بن ابی عامر اصبحی ) سے روایت کرتے ہیں کہ حضرت عمر بن خطاب"}
{"hadithnumber": "7", "text": "ہشام بن عروہ رحمہ اللہ اپنے باب عروہ بن زبیر رحمہ اللہ سے روایت کرتے ہیں کہ حضرت عمر بن خطاب رضی الل"}
{"hadithnumber": "8", "text": "عبداللہ بن رافع رحمہ اللہ جو زوجۂ پیغمبر ﷺ سیدہ اُم سلمہ رضی اللہ عنہا کے آزاد کردہ غلام ہیں ، نے ح"}
{"hadithnumber": "9", "text": "حضرت انس بن مالک رضی اللہ عنہ سے روایت ہے ، انھوں نے فرمایا کہ ہم ( مدینہ منورہ میں نبی مکرم ﷺ کے ہم"}
{"hadithnumber": "10", "text": "حضرت انس بن مالک رضی اللہ عنہ روایت کرتے ہیں کہ ہم ( معیتِ رسول ﷺ میں ) نمازِ عصر ادا کرتے ، پھر کوئ"}
{"hadithnumber": "11", "text": "قاسم بن محمد رحمہ اللہ کہتے ہیں کہ میں نے لوگوں ( صحابہ رضی اللہ عنہم و تابعین رحمہم اللہ ) کو صرف ا"}
{"hadithnumber": "12", "text": "ابو سہیل بن مالک رحمہ اللہ اپنے والد مالک بن ابی عامر اصبحی رحمہ اللہ سے روایت کرتے ہیں ، انھوں نے ک"}
{"hadithnumber": "13", "text": "ابن ابی سلیط ( عبداللہ بن اُسید بن عمرو بن قیس رحمہ اللہ ) سے روایت ہے کہ سیدنا عثمان بن عفان رضی ال"}
{"hadithnumber": "14", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا :’’ جس شخص نے نماز میں سے ایک رکعت پ"}
{"hadithnumber": "15", "text": "نافع رحمہ اللہ سے روایت ہے کہ حضرت عبداللہ بن عمر رضی اللہ عنہما فرمایا کرتے تھے کہ جب تجھ سے رکوع ر"}
{"hadithnumber": "16", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ حضرت عبداللہ بن عمر اور حضرت زید بن ثابت رضی اللہ عنہم دونوں"}
{"hadithnumber": "17", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ حضرت ابوہریرہ رضی اللہ عنہ فرمایا کرتے تھے کہ جس نے رکوع پا ل"}
{"hadithnumber": "18", "text": "نافع رحمہ اللہ سے روایت ہے کہ حضرت عبداللہ بن عمر رضی اللہ عنہما فرمایا کرتے تھے کہ ( قرآنی الفاظ )"}
{"hadithnumber": "19", "text": "داؤد بن حصین رحمہ اللہ سے روایت ہے ، کہتے ہیں کہ کسی خبر دینے والے نے مجھے یہ خبر دی کہ یقیناً حضرت"}
{"hadithnumber": "20", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ بے شک رسول اللہ ﷺ نے فرمایا :’’ جس شخص کی نمازِ عص"}
{"hadithnumber": "21", "text": "حضرت یحیی بن سعید رحمہ اللہ سے روایت ہے کہ حضرت عمر بن خطاب رضی اللہ عنہ نمازِ عصر پڑھ کر واپس لوٹے"}
{"hadithnumber": "22", "text": "یحیی بن سعید رحمہ اللہ فرمایا کرتے تھے : بے شک نمازی کوئی نماز ادا کرتا ہے ، اس حال میں کہ ( ابھی )"}
{"hadithnumber": "23", "text": "نافع رحمہ اللہ سے روایت ہے کہ حضرت عبداللہ بن عمر رضی اللہ عنہما پر غشی طاری ہو گئی جس سے ان کی عقل"}
{"hadithnumber": "24", "text": "سعید بن مسیب رحمہ اللہ سے روایت ہے ( جسے وہ دیگر کتب احادیث میں حضرت ابوہریرہ رضی اللہ عنہ سے بیان ک"}
{"hadithnumber": "25", "text": "زید بن اسلم رحمہ اللہ سے روایت ہے ( اور وہ دیگر کتب حدیث کے مطابق حضرت عبداللہ بن مسعود رضی اللہ عنہ"}
{"hadithnumber": "26", "text": "عطاء بن یسار رحمہ اللہ سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا :’’ بے شک گرمی کی شدت جہنم کے جوش سے ہے"}
{"hadithnumber": "27", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا :’’ جب گرمی سخت ہو جائے تو نماز کو ٹ"}
{"hadithnumber": "28", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا :’’ جب گرمی سخت ہو جائے تو نمازکو ٹھ"}
{"hadithnumber": "29", "text": "سعید بن مسیب رحمہ اللہ سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا :’’ جس شخص نے اس درخت ( یعنی لہسن ) میں"}
{"hadithnumber": "30", "text": "عبدالرحمن بن مجبر رحمہ اللہ سے روایت ہے کہ سالم بن عبداللہ رحمہ اللہ جب کسی شخص کو دیکھتے کہ وہ اپنے"}
{"hadithnumber": "31", "text": "عمرو بن یحیی مازنی رحمہ اللہ اپنے والد ( یحیی ) سے روایت کرتے ہیں کہ انھوں نے ( چند ساتھیوں کے ساتھ"}
