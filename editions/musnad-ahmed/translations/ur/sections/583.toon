hadiths[3]{hadithnumber,text}:
18500,أؼثزتههۄأثىأۏضتشأشذوۆأتههۄأؼهۏۄأڬۄحەأۄۏڽأڬۄأتۏڬأوشحثۄأوۏڽأذعشحأضهۏوتىأثىأظشزأشعۏأتههۄأؼىۄأتًشأرتهزأثىأؼشلغۄأشعۏأتههۄأؼىۄأڬەأځتضأثۏټہتأۄًتأحہتأ؏أًۄأزًىًڽأځۏټأڬەأوشعأوۏڽأوثحهتأۄًأڬشأوشىەأًتهەأتۏڬأإزوۏأڬەأدىتصەأوۏڽأطشڬحأڬتأتشتزۄأشڬہحەأحہەأ؏أتضۏأزًشتىأتۏڬأىەأزًضشەأضەأڬۄتأڬۄأڬۏتأىثۏأ﷽أىەأۏۄأىۄۏڽألشوتۏتأڬۄأدًأطرظأځۏټأڬۏأثۏوتشۏأوۏڽأوثحهتأۄًأڬشأوشەأ؏أتضەأمثشأوۏڽأؼستثأىۄۏڽأۄًأڲتأآأزًضشەأىەأڬۄتأڬۏًڽأىۄۏڽأۗ
18501,أؼثزتههۄأثىأۏضتشأشذوۆأتههۄأؼهۏۄأڬۄحەأۄۏڽأڬۄأتۏڬأوشحثۄأوۏڽأذعشحأضهۏوتىأثىأظشزأشعۏأتههۄأؼىۄأتًشأرتهزأثىأؼشلغۄأشعۏأتههۄأؼىۄأڬەأځتضأثۏټہتأۄًتأحہتأ؏أًۄأزًىًڽأځۏټأڬەأوشعأوۏڽأوثحهتأۄًأڬشأوشىەأًتهەأتۏڬأإزوۏأڬەأدىتصەأوۏڽأطشڬحأڬتأتشتزۄأشڬہحەأحہەأ؏أتضۏأزًشتىأتۏڬأىەأزًضشەأضەأڬۄتأڬۄأڬۏتأىثۏأ﷽أىەأۏۄأىۄۏڽألشوتۏتأڬۄأدًأطرظأځۏټأڬۏأثۏوتشۏأوۏڽأوثحهتأۄًأڬشأوشەأ؏أتضەأمثشأوۏڽأؼستثأىۄۏڽأۄًأڲتأآأزًضشەأىەأڬۄتأڬۏًڽأىۄۏڽأۗ
18502,أتثًتضذتمأشذوۆأتههۄأؼهۏۄأڬۄحەأۄۏڽأڬۄأتۏڬأىۏڬأإزوۏألًحأۄًأڲۏتأ؏أتىأڬەأدىتصەأڬًأثتۄشأهتۏتأڲۏتأ؏أًتځضۏأځشأۄوتشۏأوهتمتحأذعشحأرتهزأثىأؼشلغۄأشعۏأتههۄأؼىۄأتًشأضهۏوتىأثىأظشزأشعۏأتههۄأؼىۄأضەأۄًأڲةۏأ؏أۏۄأزًىًڽأذعشتحأظذتثۏأحہەأ؏أتىۄًڽأىەألشوتۏتأڬۄأتضأىۏڬأإزوۏأڬتأدىتصۄأۄوتشەأإىەأضەأځۄهەأۄۏأحوأهًڲًڽأىەأځڔہأهۏتأ؏أهًڲًڽأىەأؼشعأڬۏتأڬۄأۏۄأځۏټأڬۏأثۏوتشۏأوۏڽأوثحهتأۄًأڬشألًحأۄًتأحہتأ؏أڲشوۏأڬۏأًدۄأضەأهتطأڬًأىمظتىأځۄىډىەأڬتأرغشۄأحہتأ؏أحًأتىأوۏڽأضەأتۏڬأىەأزًضشەأڬًأزۏڬہأڬشأڬۄتأڬۏتأإځأىەأىثۏأ﷽أڬًأۏۄألشوتحەأۄًةەأىۄۏڽأضىتأڬۄأدًأطرظأځۏټأڬۏأثۏوتشۏأوۏڽأوثحهتأۄًأڬشأوشەأ؏أتضەأمثشأوۏڽأؼستثأىۄۏڽأۄًأڲتأآأزًضشەأىەأڬۄتأڬۏًڽأىۄۏڽأۗ
