metadata:

hadiths[2]{hadithnumber,text,reference_book,reference_hadith,urdu,international_number,chapter_title_arabic}:
1388,,33,1,امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ بے شک حضرت عمر بن خطاب رضی اللہ عنہ نے اس شخص کے متعلق فرمایا,1388,
1389,,33,2,امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ ایک آدمی حضرت عبداللہ بن عمر رضی اللہ عنہما کے پاس آیا ، وہ ک,1389,
