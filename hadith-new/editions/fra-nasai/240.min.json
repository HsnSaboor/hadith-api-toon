{"metadata":{"name":"Sunan an Nasai","section":{"1":"The Book of Purification"},"section_detail":{"1":{"hadithnumber_first":1,"hadithnumber_last":324,"arabicnumber_first":1,"arabicnumber_last":324}}},"hadiths":[{"hadithnumber":240,"arabicnumber":240,"text":"Rapporté par Umm Hani' : Le Messager d'Allah (ﷺ) a fait le Ghusl, lui et Maymouna, à partir d'un seul récipient, un bol dans lequel il restait des traces de pâte","grades":[{"name":"Abu Ghuddah","grade":"Sahih"},{"name":"Al-Albani","grade":"Sahih"},{"name":"Zubair Ali Zai","grade":"Daif"}],"reference":{"book":1,"hadith":241}}]}