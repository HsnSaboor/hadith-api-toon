{"hadithnumber": "2928", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  خبردار سن لو! تم"}
{"hadithnumber": "2929", "text": "عبدالرحمٰن بن سمرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے مجھ سے فرمایا:  اے عبدال"}
{"hadithnumber": "2930", "text": "ابوموسیٰ رضی اللہ عنہ کہتے ہیں کہ  میں دو آدمیوں کو لے کر نبی اکرم صلی اللہ علیہ وسلم کے پاس گیا، ان"}
{"hadithnumber": "2931", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے عبداللہ بن ام مکتوم رضی اللہ عنہ کو مدی"}
{"hadithnumber": "2932", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ جب کسی حا"}
{"hadithnumber": "2933", "text": "مقدام بن معد یکرب رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ان کے کندھے پر مارا پھر"}
{"hadithnumber": "2934", "text": "غالب قطان ایک شخص سے روایت کرتے ہیں وہ اپنے والد سے اور وہ ان کے دادا سے روایت کرتے ہیں کہ  کچھ لوگ"}
{"hadithnumber": "2935", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  سجل رسول اللہ صلی اللہ علیہ وسلم کے کاتب  ( منشی یا محرر"}
{"hadithnumber": "2936", "text": "رافع بن خدیج رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا ہے کہ:  ایم"}
{"hadithnumber": "2937", "text": "عقبہ بن عامر رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا:  صاحب"}
{"hadithnumber": "2938", "text": "ابن اسحاق کہتے ہیں کہ  صاحب مکس وہ ہے جو لوگوں سے عشر لیتا ہے  ( بشرطیکہ وہ ظلم و تعدی سے کام لے رہا"}
{"hadithnumber": "2939", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  عمر رضی اللہ عنہ نے کہا: اگر میں کسی کو خلیفہ نامزد نہ کر"}
{"hadithnumber": "2940", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  ہم رسول اللہ صلی اللہ علیہ وسلم سے سننے اور اطاعت کرنے کی"}
{"hadithnumber": "2941", "text": "عروہ کہتے ہیں کہ ام المؤمنین عائشہ رضی اللہ عنہا نے انہیں بتایا کہ  رسول اللہ صلی اللہ علیہ وسلم عور"}
{"hadithnumber": "2942", "text": "عبداللہ بن ہشام (انہوں نے نبی اکرم صلی اللہ علیہ وسلم کا عہد پایا تھا) فرماتے ہیں کہ  ان کی والدہ زی"}
{"hadithnumber": "2943", "text": "بریدہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  ہم جس کو کسی کام کا عامل بنا"}
{"hadithnumber": "2944", "text": "ابن الساعدی (عبداللہ بن عمرو السعدی القرشی العامری) رضی اللہ عنہ کہتے ہیں کہ  عمر رضی اللہ عنہ نے مج"}
{"hadithnumber": "2945", "text": "مستورد بن شداد رضی اللہ عنہ کہتے ہیں  میں نے نبی اکرم صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا ہے آپ کہ"}
{"hadithnumber": "2946", "text": "ابو حمید ساعدی رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے قبیلہ ازد کے ایک شخص کو جسے"}
{"hadithnumber": "2947", "text": "ابومسعود انصاری رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے مجھے عامل بنا کر بھیجا اور"}
{"hadithnumber": "2948", "text": "ابومریم ازدی (اسدی) رضی اللہ عنہ کہتے ہیں کہ  میں معاویہ بن ابی سفیان رضی اللہ عنہما کے پاس گیا، انہ"}
{"hadithnumber": "2949", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  میں تم کو کوئی چیز نہ اپ"}
{"hadithnumber": "2950", "text": "مالک بن اوس بن حدثان کہتے ہیں کہ  عمر بن خطاب رضی اللہ عنہ نے ایک دن فیٔ  ( بغیر جنگ کے ملا ہوا مال"}
{"hadithnumber": "2951", "text": "زید بن اسلم کہتے ہیں کہ  عبداللہ بن عمر رضی اللہ عنہما معاویہ رضی اللہ عنہ کے پاس آئے، معاویہ رضی ال"}
{"hadithnumber": "2952", "text": "ام المؤمنین عائشہ رضی اللہ عنہا فرماتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کے پاس ایک تھیلا لایا گیا"}
{"hadithnumber": "2953", "text": "عوف بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے پاس جس دن مال فیٔ آتا آپ اسی د"}
{"hadithnumber": "2954", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم فرماتے تھے:  میں مسلمانوں س"}
{"hadithnumber": "2955", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو مال چھوڑ کر جائے تو و"}
{"hadithnumber": "2956", "text": "جابر بن عبداللہ رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم فرماتے تھے:  میں ہر مسلما"}
{"hadithnumber": "2957", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  وہ غزوہ احد کے دن نبی اکرم صلی اللہ علیہ وسلم کے سامنے پی"}
{"hadithnumber": "2958", "text": "سلیم بن مطیر کہتے ہیں کہ  مجھ سے میرے والد نے بیان کیا کہ وہ حج کرنے کے ارادے سے نکلے، جب مقام سویدا"}
{"hadithnumber": "2959", "text": "وادی القری کے باشندہ سلیم بن مطیر اپنے والد سے روایت کرتے ہیں کہ  انہوں نے ان سے بیان کیا کہ میں نے"}
{"hadithnumber": "2960", "text": "عبداللہ بن کعب بن مالک انصاری کہتے ہیں کہ  انصار کا ایک لشکر اپنے امیر کے ساتھ سر زمین فارس میں تھا"}
{"hadithnumber": "2961", "text": "عدی بن عدی کندی کے ایک لڑکے کا بیان ہے کہ  عمر بن عبدالعزیز نے لکھا کہ جو کوئی شخص پوچھے کہ مال فیٔ"}
{"hadithnumber": "2962", "text": "ابوذر رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  اللہ نے عمر کی ز"}
{"hadithnumber": "2963", "text": "مالک بن اوس بن حدثان کہتے ہیں کہ  عمر رضی اللہ عنہ نے مجھے دن چڑھے بلوا بھیجا، چنانچہ میں آیا تو انہ"}
{"hadithnumber": "2964", "text": "اس سند سے بھی مالک بن اوس سے یہی قصہ مروی ہے  اس میں ہے: اور وہ دونوں  ( یعنی علی اور عباس رضی اللہ"}
{"hadithnumber": "2965", "text": "عمر رضی اللہ عنہ کہتے ہیں  بنو نضیر کا مال اس قسم کا تھا جسے اللہ تعالیٰ نے اپنے نبی کو عطا کیا تھا"}
{"hadithnumber": "2966", "text": "ابن شہاب زہری کہتے ہیں (عمر رضی اللہ عنہ) نے کہا  اللہ نے فرمایا: «وما أفاء الله على رسوله منهم فما"}
{"hadithnumber": "2967", "text": "مالک بن اوس بن حدثان کہتے ہیں کہ  عمر رضی اللہ عنہ نے جس بات سے دلیل قائم کی وہ یہ تھی کہ رسول اللہ"}
{"hadithnumber": "2968", "text": "ام المؤمنین عائشہ رضی اللہ عنہا فرماتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کی صاحبزادی فاطمہ رضی ال"}
{"hadithnumber": "2969", "text": "ابن شہاب زہری کہتے ہیں کہ مجھ سے عروہ بن زبیر نے بیان کیا کہ ام المؤمنین عائشہ رضی اللہ عنہا نے ان س"}
{"hadithnumber": "2970", "text": "اس سند سے بھی ام المؤمنین عائشہ رضی اللہ عنہا سے یہی حدیث مروی ہے اس میں یہ ہے کہ  ابوبکر رضی اللہ ع"}
{"hadithnumber": "2971", "text": "ابن شہاب زہری سے روایت ہے کہ  اللہ نے جو فرمایا ہے: «فما أوجفتم عليه من خيل ولا ركاب» یعنی  تم نے ان"}
{"hadithnumber": "2972", "text": "مغیرہ کہتے ہیں  عمر بن عبدالعزیز جب خلیفہ ہوئے تو انہوں نے مروان بن حکم کے بیٹوں کو اکٹھا کیا پھر ار"}
{"hadithnumber": "2973", "text": "ابوطفیل کہتے ہیں کہ  فاطمہ رضی اللہ عنہا ابوبکر رضی اللہ عنہ کے پاس نبی اکرم صلی اللہ علیہ وسلم کے ت"}
{"hadithnumber": "2974", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  میرے ورثاء میری میراث سے"}
{"hadithnumber": "2975", "text": "ابوالبختری کہتے ہیں  میں نے ایک شخص سے ایک حدیث سنی وہ مجھے انوکھی سی لگی، میں نے اس سے کہا: ذرا اسے"}
{"hadithnumber": "2976", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں  جب رسول اللہ صلی اللہ علیہ وسلم نے وفات پائی تو امہات المؤ"}
{"hadithnumber": "2977", "text": "اس سند سے بھی ابن شہاب زہری سے یہی حدیث اسی طریق سے مروی ہے، اس میں ہے کہ  ام المؤمنین عائشہ رضی الل"}
{"hadithnumber": "2978", "text": "سعید بن مسیب کہتے ہیں کہ مجھے جبیر بن مطعم رضی اللہ عنہ نے خبر دی کہ  وہ اور عثمان بن عفان دونوں اس"}
{"hadithnumber": "2979", "text": "جبیر بن مطعم رضی اللہ عنہ کا بیان ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے بنو عبد شمس اور بنو نوفل کو"}
{"hadithnumber": "2980", "text": "جبیر بن مطعم رضی اللہ عنہ کہتے ہیں کہ  جب خیبر کی جنگ ہوئی تو رسول اللہ صلی اللہ علیہ وسلم نے مال غن"}
{"hadithnumber": "2981", "text": "سدی کہتے ہیں کہ  کلام اللہ میں «ذي القربى» کا جو لفظ آیا ہے اس سے مراد عبدالمطلب کی اولاد ہے۔"}
{"hadithnumber": "2982", "text": "ابن شہاب زہری کہتے ہیں کہ  مجھے یزید بن ہرمز نے خبر دی کہ نجدہ حروری  ( خارجیوں کے رئیس )  نے ابن زب"}
{"hadithnumber": "2983", "text": "عبدالرحمٰن بن ابی لیلیٰ کہتے ہیں کہ  میں نے علی رضی اللہ عنہ کو کہتے ہوئے سنا کہ رسول اللہ صلی اللہ"}
{"hadithnumber": "2984", "text": "عبدالرحمٰن بن ابی لیلیٰ کہتے ہیں: میں نے علی رضی اللہ عنہ کو یہ کہتے ہوئے سنا ہے کہ  میں، عباس، فاطم"}
{"hadithnumber": "2985", "text": "عبدالمطلب بن ربیعہ بن حارث بن عبدالمطلب نے خبر دی کہ  ان کے والد ربیعہ بن حارث اور عباس بن عبدالمطلب"}
{"hadithnumber": "2986", "text": "علی بن ابی طالب رضی اللہ عنہ کہتے ہیں کہ  میرے پاس ایک زیادہ عمر والی اونٹنی تھی جو مجھے بدر کے دن م"}
{"hadithnumber": "2987", "text": "فضل بن حسن ضمری کہتے ہیں کہ  ام الحکم یا ضباعہ رضی اللہ عنہما  ( زبیر بن عبدالمطلب کی دونوں بیٹیوں )"}
{"hadithnumber": "2988", "text": "ابن اعبد کہتے ہیں کہ  علی رضی اللہ عنہ نے مجھ سے کہا: کیا میں تمہیں اپنے اور رسول اللہ صلی اللہ علیہ"}
{"hadithnumber": "2989", "text": "علی بن حسین سے بھی یہی واقعہ مروی ہے اس میں یہ ہے کہ  اس میں یہ ہے کہ  آپ صلی اللہ علیہ وسلم نے انہی"}
{"hadithnumber": "2990", "text": "مجاعہ رضی اللہ عنہ کہتے ہیں کہ  وہ نبی اکرم صلی اللہ علیہ وسلم کے پاس اپنے بھائی کی دیت مانگنے آئے ج"}
{"hadithnumber": "2991", "text": "عامر شعبی کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کا ایک حصہ تھا، جس کو «صفي» کہا جاتا تھا آپ اگر ک"}
{"hadithnumber": "2992", "text": "ابن عون کہتے ہیں  میں نے محمد  ( محمد ابن سیرین )  سے نبی اکرم صلی اللہ علیہ وسلم کے حصے اور «صفي» ک"}
{"hadithnumber": "2993", "text": "قتادہ کہتے ہیں  رسول اللہ صلی اللہ علیہ وسلم جب خود لڑائی میں شریک ہوتے تو ایک حصہ چھانٹ کر جہاں سے"}
{"hadithnumber": "2994", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں  صفیہ رضی اللہ عنہا «صفي» میں سے تھیں۔"}
{"hadithnumber": "2995", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں  ہم خیبر آئے  ( یعنی غزوہ کے موقع پر )  تو جب اللہ تعالیٰ نے قلعہ"}
{"hadithnumber": "2996", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  ام المؤمنین صفیہ رضی اللہ عنہا پہلے دحیہ کلبی رضی اللہ عنہ کے"}
{"hadithnumber": "2997", "text": "انس رضی اللہ عنہ کہتے ہیں  دحیہ کلبی رضی اللہ عنہ کے حصے میں ایک خوبصورت لونڈی آئی تو رسول اللہ صلی"}
{"hadithnumber": "2998", "text": "انس رضی اللہ عنہ کہتے ہیں  خیبر میں سب قیدی جمع کئے گئے تو دحیہ کلبی رضی اللہ عنہ آئے اور انہوں نے ع"}
{"hadithnumber": "2999", "text": "یزید بن عبداللہ کہتے ہیں  ہم مربد  ( ایک گاؤں کا نام ہے )  میں تھے اتنے میں ایک شخص آیا جس کے سر کے"}
{"hadithnumber": "3000", "text": "کعب بن مالک رضی اللہ عنہ سے روایت ہے (اور آپ ان تین لوگوں میں سے ایک ہیں جن کی غزوہ تبوک کے موقع پر"}
{"hadithnumber": "3001", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں  جب رسول اللہ صلی اللہ علیہ وسلم نے جنگ بدر میں قریش پر فتح"}
{"hadithnumber": "3002", "text": "محیصہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  یہودیوں میں سے جس کسی مرد پ"}
{"hadithnumber": "3003", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں  ہم مسجد میں تھے کہ اچانک رسول اللہ صلی اللہ علیہ وسلم ہماری طرف تشری"}
{"hadithnumber": "3004", "text": "عبدالرحمٰن بن کعب بن مالک ایک صحابی رسول صلی اللہ علیہ وسلم سے روایت کرتے ہیں کہ  کفار قریش نے اس وق"}
