{"hadithnumber": "754", "text": "ہشام نے عروہ کے  ( شاگرد وکیع کے بجائے )  دوسرے شاگرد وں ابو معاویہ  ،  جریر  ،  نمیر اور حماد بن زی"}
{"hadithnumber": "755", "text": "قتیبہ بن سعید اور محمد بن رمح نے لیث سے  ،  انہوں نے ابن شہاب سے  ،  انہوں نے عروہ سے اورانہوں نے حض"}
{"hadithnumber": "756", "text": "( لیث کے بجائے )  عمرو بن حارث نے ابن  شہاب سے  ،  انہوں نے عروہ بن زبیر اورعمرہ بنت عبدالرحمن سے  ،"}
{"hadithnumber": "757", "text": "ابراہیم  ، یعنی ابن سعد نے ابن شہاب کے حوالے سے خبر دی ،  انہوں نے عمرہ بنت عبد الرحمن سے اور انہوں"}
{"hadithnumber": "758", "text": "سفیان بن عیینہ نے زہری سے  ،  انہوں نے عمرہ سے  ،  انہوں نے حضرت عائشہ ؓ سےروایت کی کہ بنت جحش سات س"}
{"hadithnumber": "759", "text": "یزید بن ابی حبیب نے جعفر سے  ،  انہوں نے عراک سے  ،  انہوں نے عروہ سے اور انہوں نے حضرت عائشہ ؓ سےرو"}
{"hadithnumber": "760", "text": "اسحاق کے والد بکر بن مضر نے جعفر بن ربیعہ سے باقی ماندہ سابقہ سند سے حضرت عائشہ ؓ سے روایت کی  ،  ان"}
{"hadithnumber": "761", "text": "نے یزید رشک سے  ،  انہوں نے معاذہ سے روایت کی کہ ایک عورت نےحضرت عائشہ ؓ سے پوچھا :  کیا ایک عورت ای"}
{"hadithnumber": "762", "text": "محمد بن جعفر نے کہا :  ہمیں شعبہ نے یزید سے حدیث بیان کی  ،  انہوں نے کہا :  میں نے معاذہ سے سنا کہ"}
{"hadithnumber": "763", "text": "عاصم نے معاذہ سے روایت کی ،  انہوں نے کہا :  میں نے عائشہ ؓ سے سوال کیا  ،  میں نے کہا :  حائضہ عورت"}
{"hadithnumber": "764", "text": "ابونضر سے روایت ہے کہ حضرت ام ہانی بنت ابی طالب ؓ کے آزاد کردہ غلام ابو مرہ نے خبر دی کہ انہوں نے ام"}
{"hadithnumber": "765", "text": "یزید بن ابی حبیب نے سعید بن ابی ہند سے روایت کی کہ عقیل بن ابی طالب کے آزاد کردہ غلام ابو مرہ نے ان"}
{"hadithnumber": "766", "text": "سعید بن ابی ہند کے ایک اور شاگرد ولید بن کثیر نے اسی سند سےحدیث بیان کی اور یہ الفاظ کہے :  تو آپ کی"}
{"hadithnumber": "767", "text": "ابن عباس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے حضرت میمونہ ؓ سے روایت کی  ،  انۂں نے کہا :  میں نے نبی اکرمﷺ  ("}
{"hadithnumber": "768", "text": "زید نےحباب نے ضحاک بن عثمان سے روایت کی  ،  کہا :  مجھے زید بن اسلم نے خبر دی ،  انہوں نے عبد الرحمن"}
{"hadithnumber": "769", "text": "مذکورہ روایت کو امام مسلم کو دور اور اساتذہ ہارون بن عبداللہ اور محمد بن رافع دونوں نے ابن ابی فدیک"}
{"hadithnumber": "770", "text": "ہمام بن منبہ سے روایت ہے  : کہا :  یہ احادیث ہیں جو حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے ہمیں رسو"}
{"hadithnumber": "771", "text": "اسحاق بن ابراہیم حنظلی اور محمد بن حاتم نے محمد بن بکر سے روایت کی  ،  دونوں نےکہا :  ہمیں ابن جریج"}
{"hadithnumber": "772", "text": "زکریا بن اسحاق نے حدیث بیان کی  ،   ( کہا :  ) ہم سے عمرو بن دینار نے حدیث بیان کی  ،  کہا :  میں نے"}
{"hadithnumber": "773", "text": "حضرت مسور بن مخرمہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے  ،  کہا :  میں ایک بھاری پتھر اٹھانے ہوئے آیا ا"}
{"hadithnumber": "774", "text": "شیبان بن فروخ اور عبداللہ بن محمد بن اسماء ضبعی نے کہا :  ہمیں مہدی بن میمون نے حدیث سنائی  ،  کہا :"}
{"hadithnumber": "775", "text": "عبد الرحمن بن ابی سعید خدری نے اپنے والد سے روایت کی  ،  انہوں نےکہا کہ میں سوموار کے دن رسول اللہ ﷺ"}
{"hadithnumber": "776", "text": "ابو سلمہ بن عبد الرحمان نے حضرت ابو سعید خدری ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے حدیث بیان کی  ،  انہوں نے نبی"}
{"hadithnumber": "777", "text": "ابو علاء بن شخیر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے  ، کہا کہ رسول اللہ ﷺ کی ایک حدیث دوسری کو منسوخ"}
{"hadithnumber": "778", "text": "ابوبکر بن ابی شیبہ  ،  محمد بن مثنی اور ابن بشار نےمحمد بن جعفر غندر سے  ،  انہوں نے شعبہ سے ،  انہو"}
{"hadithnumber": "779", "text": "حماد اور ابو معاویہ نےہشام بن عروہ سے  ،  انہوں نے اپنےوالد سے  ،  انہوں نے ابو ایوب سے   ،  انہوں ن"}
{"hadithnumber": "780", "text": "شعبہ نے ہشام بن عروہ سے باقی ماندہ سابقہ سند کےساتھ حضرت ابی بن کعب ‌رضی ‌اللہ ‌عنہ ‌ ‌  سےروایت کی"}
{"hadithnumber": "781", "text": "ابو سلمہ نے عطاء بن یسار سے خبر دی کہ انہیں حضرت زید بن خالد جہنی  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نےبیان کیا ک"}
{"hadithnumber": "782", "text": "ابوسلمہ نے عطاء بن یسار کےبجائے عروہ بن زبیر سے اور انہوں نےابو ایوب  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے خبر دی"}
{"hadithnumber": "783", "text": "زہیر بن حرب ،  ابو غسان مسمعی ،  محمد بن مثنیٰ اور ابن بشار نے کہا :  ہم سے معاذ بن ہشام نے حدیث بیا"}
{"hadithnumber": "784", "text": "شعبہ نے قتادہ سے باقی ماندہ اسی سند سے روایت کی ۔  فرق یہ ہے کہ شعبہ کی اس روایت میں ثم جهدها کی جگہ"}
{"hadithnumber": "785", "text": "دو مختلف سندوں کے ساتھ  ابو بردہ کے حوالے سے  ( ان کے والد )  حضرت ابو موسیٰ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے"}
{"hadithnumber": "786", "text": "ام کلثوم نے نبیﷺ کی زوجہ حضرت عائشہؓ سے روایت کی ،  انہوں نے کہا کہ ایک آدمی رسول اللہﷺ سے ایسے مرد"}
{"hadithnumber": "787", "text": "حضرت زید بن ثابت ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے کہا کہ میں نے رسول اللہﷺ کو فرماتے ہوئے سنا :  ایسی  چیز  ("}
{"hadithnumber": "788", "text": "۔  عبد اللہ بن ابراہیم بن قارظ نے بتایا کہ انہوں نے حضرت ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  کو مسجد میں"}
{"hadithnumber": "789", "text": "۔  ابن شہاب نے کہا :  مجھے سعید بن خالد بن عمرو  بن عثمان نے ،  جب میں اسے  ( سابقہ سند سے )  یہ حدی"}
{"hadithnumber": "790", "text": "عطاء بن یسار نے  حضرت ابن عباس ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ رسول اللہﷺ نے بکری کا شانہ تناول"}
{"hadithnumber": "791", "text": "۔  محمد بن عمرو بن عطاء اور علی بن عبد اللہ بن عباس نے حضرت ابن عباس ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ک"}
{"hadithnumber": "792", "text": "ابراہیم بن سعد نے کہا :  ہمیں زہری نے جعفر بن عمرو بن امیہ   ضمیری سے حدیث بیان کی ،  انہوں نے اپنے"}
{"hadithnumber": "793", "text": "ابن شہاب زہری کے دوسر شاگرد عمرو  بن  حارث نے باقی ماندہ سابقہ سند کے ساتھ عمرو بن امیہ سے روایت کی"}
{"hadithnumber": "795", "text": "بکیر بن اشج نے ابن عباس ‌رضی ‌اللہ ‌عنہ ‌ ‌  کے مولیٰ کریب سے ،  انہوں نے نبیﷺ کی زوجہ حضرت میمونہؓ"}
{"hadithnumber": "796", "text": "یعقوب بن اشج نے ابن عباس ‌رضی ‌اللہ ‌عنہ ‌ ‌  کے آزاد کردہ غلام کریب سے ،  انہوں نے نبیﷺ کی زوجہ حضر"}
{"hadithnumber": "797", "text": "حضرت ابو رافع  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے ،  انہوں نے کہا کہ میں گواہی دیتا ہوں کہ میں رسول ال"}
{"hadithnumber": "798", "text": "۔  عقیل نے زہری سے ،  انہوں نے عبید اللہ بن عبد اللہ سے اور انہوں نے حضرت ابن عباس ‌رضی ‌اللہ ‌عنہ ‌"}
{"hadithnumber": "799", "text": "عمرو ،  اوزاعی اور یونس سب نے عقیل والی سندکے ساتھ زہری سے اسی طرح روایت بیان کی ۔"}
{"hadithnumber": "800", "text": "محمد بن عمرو بن حلحلہ نے محمد بن عمرو بن عطاء سے ،  انہوں نے حضرت ابن عباس ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے ر"}
{"hadithnumber": "801", "text": "امام مسلم نے ایک دوسری سند سے ولید بن کثیر کے واسطے سے محمد بن عمرو بن عطاء سے روایت کی ،  کہا :  می"}
{"hadithnumber": "802", "text": "ابو کامل فضیل بن حسین جحدری نے کہا :  ہمیں ابو عوانہ نے عثمان بن عبد اللہ بن موہب سے حدیث سنائی ،  ا"}
{"hadithnumber": "803", "text": "سماک ،  عثمان بن عبد اللہ بن موہب اور اشعث بن ابی شعثاء سب نے جعفر بن ابی ثور سے ،  انہوں نے جابر بن"}
{"hadithnumber": "804", "text": "عمرو ناقد ،  زہیر بن حرب اور ابو بکر بن ابی شیبہ نے سفیان بن عیینہ سے ،  انہوں نے زہری سے ،  انہوں ن"}
{"hadithnumber": "805", "text": "حضرت ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے ،  کہا :  رسول اللہﷺ نے فرمایا :  ’’جب تم میں سے کسی"}
{"hadithnumber": "806", "text": "یحییٰ بن یحییٰ ،  ابوبکر بن ابی شیبہ ،  عمرو ناقد او رابن ابی عمر سب نے سفیان بن عیینہ سے ،  انہوں ن"}
{"hadithnumber": "807", "text": "یحییٰ بن یحییٰ ،  ابوبکر بن ابی شیبہ ،  عمرو ناقد او رابن ابی عمر سب نے سفیان بن عیینہ سے ،  انہوں ن"}
{"hadithnumber": "808", "text": "۔  ابن شہاب کے ایک اور شاگرد صالح نے بھی اسی سند سے یونس کی حدیث  کے ہم معنیٰ حدیث بیان کی ۔ \\n\\n809 ۔"}
{"hadithnumber": "809", "text": "سفیان نے عمرو سے ،  انہوں نے  عطاء سے ،  انہوں نے  حضرت ابن عباس ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ"}
{"hadithnumber": "810", "text": "ابن جریج نے عمرو بن دینار سے باقی ماندہ سابقہ سند کے ساتھ ابن عباس ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی"}
{"hadithnumber": "811", "text": "عبد الملک بن ابی سلیمان نے عطاء کے حوالے سے حضرت ابن عباس ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ نبی اک"}
{"hadithnumber": "812", "text": "سلیمان بن بلال نے زید بن اسلم سے ،  انہوں نے عبد الرحمن بن وعلہ سے ،  انہوں نے حضرت عبد اللہ بن  عبا"}
{"hadithnumber": "813", "text": "سفیان بن عیینہ ،  عبد العزیز بن محمد اور سفیان ثوری نے مختلف سندوں کے ساتھ زید بن اسلم کی سابقہ سند"}
{"hadithnumber": "814", "text": "۔  یزید بن ابی حبیب نے ابو خیر سے روایت کی کہ میں نے علی بن وعلہ سبائی کو ایک پوستین  ( چمڑے کا کوٹ"}
{"hadithnumber": "815", "text": "۔  جعفر بن ربیعہ نے ابو خیر سے روایت کی ،  کہا :  مجھ سے ابن وعلہ سبائی نے بیان کیا کہ میں نے عبد ال"}
{"hadithnumber": "816", "text": "۔  عبد الرحمان بن قاسم  ( بن محمد )  نے اپنے والد سے ،  انہوں نے حضرت عائشہؓ سے روایت کی ،  کہا :  ہ"}
{"hadithnumber": "817", "text": "ہشام کے والد عروہ بن زبیر نے حضرت عائشہؓ سے روایت کی کہ انہوں نے حضرت اسماء ؓ سے عاریتاً ہار لیا ،"}
{"hadithnumber": "818", "text": "ابو معاویہ نے اعمش سے ،  انہوں نے شقیق سے روایت کی ،  کہا :  میں حضرت عبد اللہ  ( بن مسعود )  اور اب"}
{"hadithnumber": "819", "text": "عبد الواحد نے کہا :  ہمیں اعمش نے شقیق سے حدیث بیان کی ،  کہا :  ابو موسیٰ اشعری ‌رضی ‌اللہ ‌عنہ ‌ ‌"}
{"hadithnumber": "820", "text": "۔  یحییٰ بن سعید قطان نے شعبہ سے حدیث بیان کی ،  کہا :  مجھ سے حکم نے ذر  ( بن عبد اللہ بن زرارہ )"}
{"hadithnumber": "821", "text": "نضر بن شمیل نے شعبہ سے باقی ماندہ سابقہ سند کے ساتھ روایت کی کہ ایک آدمی حضرت عمر ‌رضی ‌اللہ ‌عنہ ‌"}
{"hadithnumber": "822", "text": "حضرت ابن عباس ‌رضی ‌اللہ ‌عنہ ‌ ‌  کے آزاد کردہ غلام عمیر بیان کرتے ہیں کہ میں اور عبد الرحمن بن یسا"}
{"hadithnumber": "823", "text": "حضرت ابن عمر ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے ،  ایک آدمی گزرا جبکہ رسول اللہﷺ پیشاب کر رہے تھے ،  ت"}
{"hadithnumber": "824", "text": "حضرت ابوہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ وہ جنابت کی حالت میں تھے کہ رسول اللہﷺ مدینہ کے را"}
{"hadithnumber": "825", "text": "حضرت حذیفہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ رسول اللہﷺ انہیں ملے جبکہ وہ جنبی تھے تو وہ آپﷺ سے دو"}
{"hadithnumber": "826", "text": "حضرت عائشہؓ سے روایت ہے ،   انہوں نے کہا   کہ  رسول اللہﷺ اپنے تمام اوقات میں اللہ تعالیٰ کا ذکر کرت"}
{"hadithnumber": "827", "text": "۔  حماد نے عمرو بن  سے ،  انہوں نے سعید بن حویرث سے ،  انہوں نے حضرت ابن عباس ‌رضی ‌اللہ ‌عنہ ‌ ‌  س"}
{"hadithnumber": "828", "text": "سفیان بن عیینہ نے عمرو سے باقی ماندہ سابقہ سند سے حضرت ابن عباس ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی ،"}
{"hadithnumber": "829", "text": "محمد بن مسلم طائفی نے عمرو بن دینار سے ،  انہوں نے آل سائب کے آزاد کردہ غلام سعید بن حویرث سے روایت"}
{"hadithnumber": "830", "text": "اس نے سعید بن حویرث سے سنا ہے ۔"}
