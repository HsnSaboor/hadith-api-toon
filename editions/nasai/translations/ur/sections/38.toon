{"hadithnumber": "4133", "text": "مسروق کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”میں تمہیں اس طرح نہ پاؤں کہ تم میرے بعد"}
{"hadithnumber": "4134", "text": "مسروق کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”میرے بعد کافر نہ ہو جانا“۔  ( یہ حدیث )"}
{"hadithnumber": "4135", "text": "ابوبکرہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”تم میرے بعد کافر نہ ہو"}
{"hadithnumber": "4136", "text": "جریر رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے حجۃالوداع میں لوگوں کو خاموش کیا ا"}
{"hadithnumber": "4137", "text": "جریر بن عبداللہ رضی اللہ عنہ کہتے ہیں کہ  مجھ سے رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”لوگوں سے خ"}
{"hadithnumber": "4138", "text": "یزید بن ہرمز سے روایت ہے کہ  نجدہ حروری جب عبداللہ بن زبیر کے عہد میں شورش و ہنگامہ کے ایام میں  ( ح"}
{"hadithnumber": "4139", "text": "یزید بن ہرمز کہتے ہیں کہ  نجدہ نے ابن عباس رضی اللہ عنہما کو یہ سوال لکھا کہ  ( نبی اکرم صلی اللہ عل"}
{"hadithnumber": "4140", "text": "اوزاعی کہتے ہیں کہ  عمر بن عبدالعزیز نے عمر بن ولید کو ایک خط لکھا: تمہارے باپ نے تقسیم کر کے پورا خ"}
{"hadithnumber": "4141", "text": "جبیر بن مطعم رضی اللہ عنہ بیان کرتے ہیں کہ  وہ اور عثمان بن عفان رضی اللہ عنہ رسول اللہ صلی اللہ علی"}
{"hadithnumber": "4142", "text": "جبیر بن مطعم رضی اللہ عنہ کہتے ہیں کہ  جب رسول اللہ صلی اللہ علیہ وسلم نے ذی القربی کا حصہ بنی ہاشم"}
{"hadithnumber": "4143", "text": "عبادہ بن صامت رضی اللہ عنہ کہتے ہیں کہ  غزوہ حنین کے دن رسول اللہ صلی اللہ علیہ وسلم نے اونٹ کی دم ک"}
{"hadithnumber": "4144", "text": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ایک اونٹ کے پاس آئے اور اس"}
{"hadithnumber": "4145", "text": "عمر رضی اللہ عنہ کہتے ہیں کہ  بنی نضیر کا مال غنیمت مال فی میں سے تھا جو اللہ تعالیٰ نے اپنے رسول کو"}
{"hadithnumber": "4146", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  فاطمہ رضی اللہ عنہا نے ابوبکر رضی اللہ عنہ کے پاس ای"}
{"hadithnumber": "4147", "text": "عطاء  آیت کریمہ: «واعلموا أنما غنمتم من شىء فأن لله خمسه وللرسول ولذي القربى» ”جان لو کہ تمہیں جو ما"}
{"hadithnumber": "4148", "text": "قیس بن مسلم کہتے ہیں کہ  میں نے حسن بن محمد سے آیت کریمہ: «واعلموا أنما غنمتم من شىء فأن لله خمسه‏»"}
