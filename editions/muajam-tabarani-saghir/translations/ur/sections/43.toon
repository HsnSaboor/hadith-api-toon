[تخریج]: حدیث : 18142 - اخرجه أبو يعلى في """"المسند """" (3607) أخرجه الطبراني في """" المعجم الأوسط"""" (1955)"
18143,"أتىأظذتثۏأڬەأذًتهەأضەأۏۄأشًتۏحأوىمًهأۄەأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأۄەأ=أ
أ““أدًأطرظأتځىۏأصثتىأڬۏأذلتػحأڬشەأڲتأتههۄأحؼتهۏٳأتضأڬەأځًطۏزۄأوؼتوهتحأڬۏأځشزۄأځًطۏأڬشەأڲتأ؏أدًأطرظأتځىەأؽظەأځشأمتثًأځتةەأڲتأ؏أتههۄأحؼتهۏٳأتْضأضەأتځىتأؼستثأشًڬأهەأڲتأ؏أدًأطرظأتههۄأحؼتهۏٳأڬۏأثتشڲتۄأوۏڽأوؼسشحأځۏطأڬشەأڲتأ؏أتههۄأحؼتهۏٳأتْضأڬۏأوؼسشحأمثًهأڬشەأڲتأۗ‛‛أ
أۏۄأشًتۏحأتوتوأتثًۏؼهۏٳأىەأىمهأڬۏأۄەأ؏أتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأشثۏؼأثىأضهۏوتىأتصزۏأۄەأتًشأًۄأعؼۏلأۄەأۗ

[تخریج]: حدیث : 18143 - اخرجه ابو يعلى في """"المسند"""" (4338)"
18144,"أحوۏوأثىأۏصۏزأ؏أدًأثىًصوؼۄأڬەأؽهتوأۄۏڽأ؏أًۄأتۏڬأظذتثۏأڬتأۏۄأثۏتىأىمهأڬشحەأۄۏڽأ=أتۏڬأزىأىثۏأتڬشوأ﷽أىەأۄوۏڽأرغثۄأزۏحەأۄًةەأۏۄأتشطتزألشوتۏتأ=أ
أ““أتەأهًڲًأ$أزًأډۏصۏڽأۄۏڽأ؏أدضأڬًأتههۄأحؼتهۏٳأىەأتْىأزًىًڽأڬەأطشأضەأثډتأهۏتأ؏أًۄأدىحأوۏڽأزترهأۄًأڲتأۗ‛‛أ
أتىظتشأضەأحؼهمأشڬہىەأًتهەأتۏڬأظتذثأڬہڔەأۄًةەأ؏أتىۄًڽأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ$أڬۏتأإځأۄوۏڽأتْىأزًىًڽأڬەأثتشەأوۏڽأثحتةۏڽأڲەأىۄۏڽأآأىثۏأتڬشوأ﷽أىەأځہشأۏۄأتشطتزألشوتۏتأ=أزًأډۏصۏڽأۄۏڽأ؏أدضأڬًأتههۄأحؼتهۏٳأىەأتىأزًىًڽأڬەأطشأضەأثډتأهۏتأ؏أًۄأدىحأوۏڽأزترهأۄًأڲتأشتًۏأثۏتىأڬشحەأۄۏڽأ=أدثأحۏضشۏأوشحثۄأۏۄۏأوڬتهوۄأۄًتأحًأظذتثۄأڬشتوأشعۏأتههۄأؼىۄوأىەأتىأظتذثأڬًأشًڬأزۏتأتًشأۏۄأڬۄتأ=أحوأزۏڬہأشۄەأۄًأڬۄأتههۄأڬەأشضًهأ﷽أۄوۏڽأڬًةۏأرًطرثشۏأضىتىتأډتۄأشۄەأۄۏڽأتًشأحوأتىۄۏڽأشًڬأشۄەأۄًأ؏أتضأطرظأىەأڬۄتأ=أودہەأۏۄأتىزۏطۄأۄەأڬۄأڬۄۏڽأهًڲأتضأځشأحڬۏۄأىۄأڬشأهۏڽأ؏أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=
أ““أزًأډۏصۏڽأۄۏڽأ؏أدضأڬًأتههۄأحؼتهۏٳأىەأتىأزًىًڽأڬەأطشأضەأثډتأهۏتأًۄأدىحأوۏڽأدتةەأڲتأ؏أًۄأډۏصأدًأزًأدثڔًڽأڬەأزشوۏتىأۄەأ+أۏؼىۏأصثتىأ,أتًشأًۄأډۏصأدًأزًىًڽأټتىڲًڽأڬەأزشوۏتىأۄەأ+أۏؼىۏأطشوڲتۄأ,أۗ‛‛
أۏۄأشًتۏحأتوتوأتذوزأىەأىمهأڬۏأۄەأتًشأتضأڬەأشدتهأظذۏذأڬەأشدتهأۄۏڽأ؏أظشلأحوۏوأڬتأوؼتوهۄأورحهلأۄەأتًشأًۄأخمۄأۄەأۗ

[تخریج]: حدیث : 18144 - اخرجه احمد في """"المسند"""" (362/5)"
18145,"أذعشحأتثًوًضۏٳأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أ
أ““أدًأطرظأتځىەأزًىًڽأدثڔًڽأڬەأزشوۏتىأًتهۏأډۏصأ+أۏؼىۏأصثتىأ,أتًشأتځىۏأطشوأڲتۄأڬۏأذلتػحأڬشەأڲتأًۄأدىحأوۏڽأزترهأۄًأڲتأۗ‛‛أ
أۏۄأشًتۏحأتوتوأتذوزأىەأىمهأڬۏأۄەأ؏أتوتوأتثًۏؼهۏٳأتًشأتوتوأغثشتىۏأىەأتضأڬۏأوتىىزأىمهأڬۏأۄەأ؏أغثشتىۏأتًشأتثًۏؼهۏٳأڬەأشدتهأخمۄأۄۏڽأ؏أتذوزأڬەأشدتهأوۏڽأتۏڬأتۏضتأشتًۏأۄەأدضأڬتأىتوأثۏتىأىۄۏڽأڬۏتأڲۏتأۄەأتضأشًتۏحأڬەأثمۏۄأشدتهأخمۄأۄۏڽأ؏أثػتۄشأۏۄأهڲحتأۄەأڬۄأتوتوأتذوز
ىەأدضأشتًۏأڬتأىتوأسڬشأىۄۏڽأڬۏتأ؏أًۄأضهۏوتىأثىأۏضتشأۄەأۗ

[تخریج]: حدیث : 18145 - اخرجه أبو يعلى في المسند """" (7275) اخرجه احمد في """"المسند"""" (398/4)"
18146,"أتىأڬەأذًتهەأضەأۏۄأثتحأوىمًهأۄەأ=أًۄأثۏتىأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=
أ““أڬۏتأوۏڽأحوۄۏڽأزًأتۏضۏأډۏصًڽأڬەأثتشەأوۏڽأىۄأثحتاڽأآأڬۄأدًأطرظأتىۄۏڽأڬشأهەأڲتأًۄأدىحأوۏڽأزترهأۄًأڲتأ؏أۄوأىەأؼشعأڬۏأ=أدۏأۄتڽأ$أۏتأشضًهأتههۄأ$أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أ
أ““أإزوۏأتْضأډۏصأڬۏأذلتػحأڬشەأ؏أدًأتضأڬەأزًىًڽأدثڔًڽأڬەأزشوۏتىأۄەأ+أۏؼىۏأصثتىأ,أتًشأتْضأڬۏأدًأتضأڬۏأزًىًڽأټتىڲًڽأڬەأزشوۏتىأۄەأ+أۏؼىۏأطشوڲتۄأ,أۗ‛‛
أشتًۏأڬۄحەأۄۏڽأ=أوۏڽأتًشأوۏشتأضتحہۏأًتځضأإةەأ؏أۄوأىەأضًډتأ؏أتههۄأڬۏأمضوأ$أۏۄأحًأثۄحأوطڬهأۄەأ؏أإزوۏأتضأثتحأڬۏأڬۏضەأتضحغتؼحأشڬہحتأۄەأڬۄأًۄأزًىًڽأدثڔًڽأڬەأزشوۏتىأوًدًزأډۏصأڬۏأذلتػحأڬشەأتًشأظشلأثہهتةۏأڬەأثتشەأوۏڽأڬهتوأڬشەأ؏أشتًۏأڬۄحەأۄۏڽأ=أۄوأهًڲأىثۏأتڬشوأ﷽أڬۏأرزوحأوۏڽأذتعشأۄًةەأ؏أۄوأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ$أإځأىەأزًأتۏضەأتوًشأسڬشأڬةەأۄۏڽأ؏أدًأثۄحأوطڬهأۄۏڽأۏتأشضًهأتههۄأ$أڬًىأتضأثتحأڬۏأتضحغتؼحأشڬہحتأۄەأڬۄأًۄأتځىۏأصثتىأځشأمتثًأشڬہەأآأىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أډہأ
ڬتوأتۏضەأۄۏڽأ؏أدًأطرظأتىۄۏڽأڬشأهەأڲتأ؏أًۄأدىحأوۏڽأزترهأۄًأڲتأ؏أۄوأىەأزشۏتلحأڬۏتأ=أًۄأڬًىأضەأۄۏڽأآأىثۏأتڬشوأ﷽أىەألشوتۏتأ=
أ““أًۄأطرظأدًأڬضۏأڬًأتههۄأڬتأطشۏڬأىۄأټہۄشتةەأ؏أًۄأصىتأىۄأڬشەأ؏أًۄأدہًټتأتهصتوأىۄأهڲتةەأ111111‛‛ۗأتضأڬەأثؼزأإځأىەأتضأإۏحأڬًأوڬوهأحهتًحأڬۏتأ+أشتًۏأڬۄحەأۄۏڽأ=أ,أحًأۏۄأذڬوأځۄهەأًتهەأضەأثہۏأصۏتزۄأوطڬهأحہتأۗأ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأتًشأتضأڬەأشدتهأڬۏأحًخۏمأڬۏأڲةۏأۄەأۗ"
18147,"أتثًوتهڬأتطدؼۏأتځىەأًتهزأڬتأۏۄأثۏتىأىمهأڬشحەأۄۏڽأ=أۄوأهًڲأىثۏأتڬشوأ﷽أڬەأځتضأثۏټہەأشۄحەأحہەأ؏أۄوأضثأىًدًتىأحہەأوۏڽأىەأتۏضتأڬًةۏألشزأىۄۏڽأزۏڬہتأدًأتههۄأڬەأشضًهأ﷽أضەأصۏتزۄأرتوًطأشۄحتأۄًأ؏أإځأ﷽أڬەأتظذتثأڲلحڲًأڬشحەأۄًةەأدثأصۏتزۄأڲلحڲًأڬشحەأحہەأحًأإځأوضڬشتأزۏحەأحہەأۗأ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأتثشتۄۏوأثىأسڬشۏتأؼدهۏأۄەأتًشأًۄأعؼۏلأۄەأۗ

[تخریج]: حدیث : 18147 - اخرجه الطبراني في """" المعجم الكبير """" (8198)"
18148,"أذعشحأذتشخأثىأۄطتوأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أتىۄًڽأىەأىثۏأتڬشوأ﷽أڬۏأرزوحأوۏڽأؼشعأڬۏأ=أإځأودہەأڬضۏأتۏضۏأډۏصأڬەأثتشەأوۏڽأثحتةۏەأدضەأوۏڽأوعثًغۏأضەأحہتوأهًڽأ؏أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أتضأځشأمتثًأشڬہًأ$أإځأ﷽أىەأتځىۏأصثتىأڬۏأغشلأتطتشۄأڬشأڬەأ+أۏۄأثتحأتشطتزألشوتةۏأ,أۗأ
