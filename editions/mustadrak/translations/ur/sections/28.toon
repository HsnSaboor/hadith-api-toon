أ““أڬۏتأورهًمأوۏڽأوشزًڽأضەأثزلؼهۏأڬشحەأۄًأ؏أتًشأډہًڔحەأۄًأًۄأدًأحوۄتشەأهۏەأحوۄتشەأشثأىەأدًشًأ+أثۏًۏتڽأ,أثىتةۏڽأ‛‛ۗأ+أحشدوۄأڬىصتهتۏوتىأ؏أتوتوأتذوزأشعتأشذوۆأتههۄأؼهۏۄأ
أذعشحأًۄثأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأ=أذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأىەأتىأڬەأؼًشحًڽأڬًأډہًڔأڬشأوشزًڽأضەأثزلؼهۏأڬشىەأڬۏأًدۄأۏۄأثۏتىألشوتةۏأڬۄأ=أتىأڬەأڬډہأثتؽتحأتًشأڬہۏحأًؽۏشۄأحًأتىأڬۏأشۄتةطأڬەأومتوأځشأحہەأتًشأڬډہأثتؽتحأتًشأڬہۏحأًؽۏشۄأؼۏىأشتضحەأځشأحہەأۗأتىأڬًأتۏڬأزلؼۄأطزۏزأمذغأتًشأثہًڬأڬتأضتوىتأڬشىتأځڔتأۗأتىأهًڲًڽأىەأإځضأوۏڽأوطًشۄأڬۏتأڬۄتأتڲشأۄوأوضتلشًڽأضەأتځىەأځہهًڽأڬًأثډتأهۏڽأحًأۏۄأۄوتشەأڬہتىەأڬەأڬتوأإةەأڲتأۗأځہشأۏۄأضًډىەأهڲەأ=أڬۄأوضتلشًڽأڬًأڬضأغشذأوىؼأڬۏتأدتةەأآأإرشأۏۄأغەأۄًتأڬۄأۏۄأمتىًىأثىتأهۏتأدتةەأڬۄأۄوتشەأؼهتمەأوۏڽأدًأثہۏأتدىثۏأطرظأإةەأ؏أدضأڬًأۏۄأځۄډتىحەأىۄأۄًڽأ؏أتضأڬًأځڬڔأڬشأتضأضەأثزلؼهۏأڬشًأتًشأتضەأرًثأوتشًأځۏټًأ؏أصوۏىأځشأڲہضۏټًأدثأتۏضتأشًۏۄأتځىتۏتأدتةەأڲتأحًأڬًةۏأطرظأثہۏأحوۄتشەأطۄشأڬۏأدتىثأىۄۏڽأإةەأڲتأ+أدثأتىأهًڲًڽأىەأۏۄأغەأڬشأهۏتأحًأ,أطۏغتىأتۏڬأتىحۄتةۏأذضۏىأًأدوۏهأرًثشًأهڔڬەأڬۏأطڬهأوۏڽأتضأځۄتڔأځشأتىأڬەأځتضأإۏتأهًڲًڽأىەأتضأڬًأزۏڬہأهۏتأتًشأتضەأځڬڔأڬشأتضأڬەأضتحہأثزلؼهۏأثہۏأڬۏأتًشأثۄحأوتشتأځۏټتأځہشأًۄأډهتأڲۏتأۗأتضأڬەأثؼزأدًأثہۏأتضأغشلأإحتأ؏أۏۄأهًڲأتضأڬەأضتحہأۏۄۏأضهًڬأڬشحەأۗأۏۄأتىأڬتأغشۏمۄأڬتشأثىأډڬتأحہتأۗأذحۏٳأڬۄأتههۄأحؼتهۏٳأىەأذعشحأهًغأؼهۏۄأتهضهتوأڬًأتىأڬۏأدتىثأثہۏدتأۗأذعشحأهًغأؼهۏۄأتهضهتوأىەأتىأڬًأتضأؼوهأضەأشًڬتأتًشأتىأڬًأؼستثأتهٳۄۏأضەأڋشتۏتأتًشأڬۄتأ=أڬۏتأًۄأثەأذۏتةۏأڬشحەأۄًأدًأحوأضەأځۄهەأدۄتىأوۏڽأڬضۏأىەأىۄأڬۏأۗأځہشأتضأڬەأثؼزأذعشحأًۄثأىەأذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأڬەأذًتهەأضەأثتمۏأذزۏخأثۏتىأڬۏأۗ%أ"
4059,"%أثؼعأظذتثۄأڬشتوأشعًتىأتههۄأؼهۏۄوأتدوؼۏىأضەأوشلًؼتَأشًتۏحأڬشحەأۄۏڽأڬۄأدثألشطحەأذعشحأتثشتۄۏوأؼهۏۄأتهضهتوأڬەأځتضأضەأ؏أذعشحأهًغأؼهۏۄأتهضهتوأڬەأطۄشأڬۏأدتىثأشًتىۄأۄًةەأحًأزًځۄشأڬەأًمحأًۄتڽأإأځۄىډەأ؏أدثأًۄأىۄشأضزًوأځشأځۄىډەأحًأتىأڬۏأوهتمتحأذعشحأهًغأؼهۏۄأتهضهتوأڬۏأظتذثصتزۏأڬەأضتحہأۄًةۏأ؏أدًأتځىەأڲہشأًتهًڽأڬەأهةەأځتىۏأثہشأشۄۏأحہۏأۗأذعشحأهًغأؼهۏۄأتهضهتوأڬۏأزًأثۏټۏتڽأحہۏڽأ؏ألشطحًڽأىەأتىأضەأڬۄتأ=أڬًةۏأشۄىەأڬۏأدڲۄأۄەأآأتىۄًڽأىەأڬۄتأ=أدۏأۄتڽأۗأهۏڬىأدثأحڬأوۏڽأًتځضأىۄأإاڽأحوأتځىۏأدڲۄأځشأټہۄشەأشۄىتأۗأًۄأتځىەأًتهزأڬەأځتضأإةۏڽأتًشأثًهۏأ=أتثتأدتىأطۄشأڬەأزشًتصەأځشأډىزأىًدًتىًڽأڬًأوۏڽأىەأزۏڬہتأۄەأ؏أًۄأتضأمزشأذضۏىأۄۏڽأڬۄأوۏڽأىەأإدأحڬأتىأدۏضتأذضۏىأىۄۏڽأزۏڬہتأ؏أڬۄۏڽأًۄأإځأڬۏأمًوأڬەأۄتحہأىۄأډڔہأدتةۏڽأتًشأًۄأتىأڬًأشضًتأىۄأڬشأزۏڽأۗأإځأڬۏأمًوأىەأإځأڬًأوشزأوۄوتىأټہۄشتىەأضەأوىؼأڬۏتأۄًتأحہتأذحۏٳأڬۄأتىۄًڽأىەأڬۄۄأشڬہتأحہتأڬۄأوشزًڽأڬۏأوۄوتىأىًتصۏأۄوأځشأًتدثأۄەأۗأډىتىډۄألشطحەأذعشحأهًغأؼهۏۄأتهضهتوأڬەأۄتڽأإأڲةەأتًشأتىأڬەأڲہشأًتهًڽأڬەأؼهتًۄأتًشأڬضۏأڬًأتىأڬتأځحۄأىۄأډهتأۗأحًأذعشحأهًغأؼهۏۄأتهضهتوأڬۏأثۏًۏأڲہشأضەأىڬهۏأتًشأتىأڬۏأمًوأڬًأضثأڬډہأثحتأزۏتأڬۄأهًغأؼهۏۄأتهضهتوأڬەأڲہشأوۏڽأڬډہأوشزأۄۏڽأ؏أوۏڽأىەأتىأدۏضتأذضۏىأډۄشۄأڬثہۏأىۄۏڽأزۏڬہتأ؏أحًأتىأڬۏأمًوأزًڔحۏأۄًةۏأتىأڬەأځتضأإةۏأ؏أدثأإځأڬەأځتضأإةەأحًأذعشحأهًغأؼهۏۄأتهضهتوأىەأتىأضەأڬۄتأ=أۏۄأوۏشۏأ+أمًوأڬۏأ,أثۏټۏتڽأۄۏڽأ؏أۏۄأحوۄتشەأتشتزًڽأڬەأوغتثمأحوۄتشەأهةەأضحہشۏأۄۏڽأۗأتىۄًڽأىەأڬۄتأ=أڬۏتأۄوأىەأحوۄۏڽأوشزًڽأڬًأوۄوتىأټہۄشتىەأضەأوىؼأىۄۏڽأڬۏتأحہتأآأإځأدتىحەأۄۏڽأڬۄأحوۄتشۏأ+أمًوأڬۏأ,أثۏټۏًڽأوۏڽأۄوتشتأڬًةۏأذمأىۄۏڽأۄەأتًشأۄوتشەأدسثتحأڬًأحوأرًثأتډہۏأغشذأدتىحەأۄًأۗأدثأتىۄًڽأىەأذعشحأهًغأؼهۏۄأتهضهتوأڬۏأۄشأثتحأوتىىەأضەأتىڬتشأڬشأزۏتأحًأذعشحأهًغأؼهۏۄأتهضهتوأثًهەأ=أتەأڬتطأ$أودہەأحوۄتشەأومتثهأصًشأۄًحتأۏتأڬضۏأوعثًغأځتةەأڬۏأځىتۄأهۏحتأۗأإځأڬۄۄأشۄەأحہەأ=أڬتطأوۏشتأڬًةۏأوززڲتشأۄًحتأدًأحوۄتشەأرهتلأوۏشۏأوززأڬشەأۏتأوۏشتأرتىزتىأۄًحتأدًأحوأضەأوۏشتأزلتؼأڬشحتأحًأًۄأحوۄۏڽأتضأتشتزەأوۏڽأڬتوۏتثأۄًىەأضەأشًڬأهۏحتأدًأحوأىەأوۏشەأوۄوتىًڽأڬەأثتشەأوۏڽأڬشأشڬہتأۄەأتًشأدثأذعشحأهًغأؼهۏۄأتهضهتوأىەأڬۄتأ=أڬتطأودہەأحوۄتشەأومتثهأصًشأۄًحتأۏتأڬضۏأوعثًغأځتةەأڬۏأځىتۄأهۏحتأحًأذعشحأدثشۏهأؼهۏۄأتهضهتوأىەأتځىەأثتصًأځہۏهتةەأتًشأتىأهًڲًڽأڬۏأإىڬہًڽأڬًأځہًڔأڋتهتأحًأًۄأتىزہەأۄًأڬشأتۏڬأزًضشەأڬًأځتاڽأضەأشًىزحەأۄًةەأ؏أثډتاأثډتاأڬتأطًشأوډتحەأۄًةەأًۄتڽأضەأثہتڲەأڬۄأهًغأؼهۏۄأتهضهتوأڬەأڲہشأوۏڽأزىۏتأڬەأضثأضەأثڔەأدتزًڲشأوًدًزأۄۏڽأۗأۏۄۏأوغهثأۄەأتههۄأحؼتهۏٳأڬەأتشطتزأ=
أ®ًّأهّمّزٕأشّتًّزًْٕۄْأؼّىٕأعّۏٕلٓۄٙألّغّوّضٕىّإأتّؼٕۏْىّہْوٕأ+أتهموشأ=أ6:أ,¾ أ““أتىۄًڽأىەأتضەأتضأڬەأوۄوتىًڽأضەأځہضهتىتأډتۄتأحًأۄوأىەأتىأڬۏأإىڬہۏڽأوۏټأزۏڽأۗ‛‛أ+أحشدوۄأڬىصتهتۏوتىأ؏أتوتوأتذوزأشعتأشذوۆأتههۄأؼهۏۄأ ألشطحەأثًهەأ=أۄوأحوۄتشەأشثأڬەأثہۏدەأۄًةەأۄۏڽأ؏أًۄأحوأحڬأىۄۏڽأځۄىډأضڬحەأحًأتځىەأڲہشأًتهًڽأڬًأشتحًڽأشتحأهەأدتاأتًشأحوأوۏڽأڬًةۏأځۏټہأځہۏشأڬشأىۄأزۏڬہەأضًتةەأحوۄتشۏأؼًشحأڬەأ؏أتضەأثہۏأًۄۏأځۄىډىتأۄەأ؏أدًأتىۄۏڽأځۄىډەأڲتأۗأإځأتځىەأتۄهأڬەأځۏډہەأځۏډہەأډهۏڽأۗأتههۄأحؼتهۏٳألشوتحتأۄەأ=أدۄتڽأڬتأذڬوأۄەأضۏزہەأډهەأدتةۏەأۗأحًأتههۄأحؼتهۏٳأىەأتىأڬًأطتوأڬۏأغشلأىڬتهتأتًشأهًغأؼهۏۄأتهضهتوأىەأڬۄتأ=أتىأڬًأتضۏأًمحأۄهتڬأڬشأزۏڽأۗألشطحًڽأىەأدًتثأزۏتأ=أۄوۏڽأحًأظثذأڬەأًمحأڬتأذڬوأزۏتأڲۏتأۄەأ؏أڬۏتأظثذأمشۏثأىۄۏڽأۄەأۗأدثأضذشۏأڬتأًمحأۄًتأحًأذعشحأهًغأؼهۏۄأتهضهتوأ؏أتځىەأثۏًۏأثډًڽأڬًأهەأڬشأىڬهأځڔەأۗأۏۄأۄەأوغهثأتههۄأحؼتهۏٳأڬەأتضأتشطتزأڬتأ=
أ®تٓهّٔإأٳتهّأهًْٕغِأىّدّٔۏٕىٳہْوٕأثٓضّذّشِأ+أتهموشأ=أ67أ,¾ أ““أضًتةەأهًغأڬەأڲہشأًتهًڽأڬەأۄوأىەأتىۄۏڽأځډہهەأځۄشأثډتأهۏتأ‛‛ۗ أٰٰأۏۄأذزۏخأتوتوأثرتشۏأشذوۆأتههۄأؼهۏۄأتًشأتوتوأوضهوأشذوۆأتههۄأؼهۏۄأڬەأوؼۏتشأڬەأوغتثمأظذۏذأۄەأهۏڬىأطۏرۏىأشذوۆأتههۄأؼهۏۄوتأىەأتضەأىمهأىۄۏڽأڬۏتأۗ%أ"
4060,"%أذعشحأؼثزتههۄأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أ+أتههۄأڬەأ,أىثۏأذعشحأۄًزأؼهۏۄأتهضهتوأ؏أوعثًغأتًشأمًۏأوشزأحہەأۗ أٰٰأۏۄأذزۏخأتوتوأثرتشۏأشذوۆأتههۄأؼهۏۄأتًشأتوتوأوضهوأشذوۆأتههۄأؼهۏۄأڬەأوؼۏتشأڬەأوغتثمأظذۏذأۄەأهۏڬىأطۏرۏىأشذوۆأتههۄأؼهۏۄوتأىەأتضەأىمهأىۄۏڽأڬۏتأۗ%أ"
4061,أذعشحأؼثزتهشذوىأثىأضتثغألشوتحەأۄۏڽأ=أدًأتوحأثہۏأۄهتڬأۄًةۏأتىأڬتأىثۏأوڬۆأتهوڬشوۄأوۏڽأإأڬشأًلتحأحڬأؼثتزحأتهٳۄۏأوۏڽأوطؽًهأشۄتأتًشأذعشحأہًزأؼهۏۄأتهضهتوأڬۏأمثشأذدشأتضًزأتًشأصوأصوأڬەأزشوۏتىأۄەأۗأ
4062,أتثًتهغلۏهأؼتوشأثىأًتخهۄأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأ=أذعشحأؼهۏأتثىأتثۏأغتهثأؼهۏۄأتهضهتوأىەأذعشوًحأڬەأتۏڬأإزوۏأضەأڬۄتأ=أڬۏتأحًأىەأضشرأشىڲأڬتأشۏحأڬتأټۏهۄأزۏڬہتأۄەأ؏أدضأوۏڽأضشرأشىڲأڬۏأوټۏأوهۏأۄًةۏأتًشأدضأڬەأتشزڲشزأۏًڽأۏًڽأثۄحأضتشۏأثۏشۏتڽأۄۏڽأۗأتضأىەأڬۄتأ=أرزتأڬۏأمضوأ$أتەأتوۏشتهوًوىۏىأشعۏأتههۄأؼىۄأ$أإځأىەأحًأتضأطرظأڬۏأغشذأحوتوأتًظتلأثۏتىأڬشأزةۏەأۄۏڽأدضأىەأتضأڬًأزۏڬہتأۄًأۗأإځأىەألشوتۏتأ=أىۄۏڽأ؏أثهڬۄأودہەأحًأتضأڬەأوحؼهمأثحتۏتأڲۏتأۄەأۗأذعشوۏأڬۄحەأۄۏڽأ=أتەأتوۏشتهوًوىۏىأشعۏأتههۄأؼىۄأ$أتضأڬۏأطتىأڬۏتأۄەأآأإځأىەألشوتۏتأ=أتضأوۏڽأذعشحأہًزأؼهۏۄأتهضهتوأڬۏأمثشأۄەأۗأ
4063,"%أذعشحأًۄثأثىأوىثۄأشعۏأتههۄأؼىۄأضەأځًډہتأڲۏتأڬۄأذعشحأہًزأؼهۏۄأتهضهتوأۏوىأڬەأًتهزأحہەأآأحًأذعشحأًۄثأشعۏأتههۄأؼىۄأىەأڬۄتأ=أىۄۏڽأۗأثهڬۄأًۄأۏوىأڬەأثہتةۏأحہەأتًشأحًشتحأوۏڽأتىأڬتأىضثأذعشحأىًذأؼهۏۄأتهضهتوأڬۏأغشلأڬۏتأڲۏتأۄەأتًشأډًىڬۄأتۄهأؼشثأوۏڽأحؼظثأځتۏتأدتحتأحہتأتًشأوعشأتځىەأثتځأذعشحأتضوتؼۏهأؼهۏۄأتهضهتوأځشألرشأڬۏتأڬشحەأحہەأحًأتىۄًڽأىەأۏوىأڬەأذعشحأہًزأؼهۏۄأتهضهتوأڬەأثتځأۄًىەأڬتأزؼًۏٳأڬشأزۏتأحتڬۄأًۄأتىثۏتؤأڬۏأتًهتزأوۏڽأختثحأۄًڽأتًشأتىأڬۏأتًهتزأتىأوۏڽأختثحأۄًأۗأذتهتىڬۄأذعشحأہًزأؼهۏۄأتهضهتوأۏوىأڬەأًتهزأىۄۏڽأۄۏڽأثهڬۄأتىأڬەأثہتةۏأۄۏڽأتًشأذعشحأہًزأؼهۏۄأتهضهتوأڬًأؼتزأڬۏأغشلأوثؼًخألشوتۏتأۗأذعشحأًۄثأشعۏأتههۄأؼىۄأ؏أؼتزأڬتأىتوأىۄۏڽأثۏتىأڬشحەأحہەأتًشأىۄأتىأڬەأمثتةهأڬتأىضثأثۏتىأڬشحەأحہەأتًشأىۄأتىأڬەأتطؼتشأڬتأذڬوأزۏحەأحہەأذتهتىڬۄأصوۏىأځشأتىأضەأصۏتزۄأڬخشحأًتهۏأتىأڬەأضًتأڬًةۏأتوحأىۄۏڽأۗأتًشأىۄأۄۏأتىأضەأصۏتزۄأوعثًغأدضوأًتهۏأڬًةۏأتوحأحہۏأۗأتًشأىۄأتىأضەأصۏتزۄأوعثًغأځڬڔأًتهۏأڬًةۏأتوحأۄەأۗأدثأتىۄًڽأىەأزۏڬہتأڬۄأإىزہۏأتىأڬۏأدتىثأإأشۄۏأۄەأحًأتىۄًڽأىەأذعشحأہًزأؼهۏۄأتهضهتوأضەأڬۄتأ=أحًأۄوۏڽأإىزہۏأضەأڋشتحتأۄەأآأحًأتىۄًڽأىەأتځىەأثډًڽأ؏أدتىًشًڽأتًشأتځىەأوتهًڽأڬًأتۏڬأؽتشأوۏڽأدوؼأڬشأهۏتأتًشأتضأؽتشأڬەأوىۄأځشأڬہڔەأۄًأڬشأإىزہۏأڬًأتځىەأوتهًڽأتًشأثډًڽأضەأشًڬىەأهڲەأحًأإىزہۏأتىأڬەأمزوًڽأڬۏأدتىثأضەأتىزشأزترهأۄًةۏأتًشأتىأڬًأحثتۄأڬشأزۏتأۗ أذعشحأًۄثأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأ=أدثأتههۄأحؼتهۏٳأىەأتىأڬۏأدتىثأہًزأثىأؼثزتههۄأثىأشثتذأثىأتهذتشخأثىأؼتزأثىأؼًظأثىأتشوأثىأضتوأثىأىًذأؼهۏۄأتهضهتوأڬًأوثؼًخألشوتۏتأحًأحوتوأطۄشًڽأڬەأټۏهًڽأوۏڽأمًوأؼتزأڬۏأشۄتةطۏڽأحہۏڽأتًشأؼتزأڬەأؼهتمەأحوتوأثهتزأؼشثأوۏڽأضەأضثأضەأصۏتزۄأضشضثصأًأطتزتثأحہەأتًشأًۄتڽأځشأضثصۄأ؏أىۄشۏڽأتًشأثتؽتحأثڬخشحأحہەأۗأدثأتههۄأحؼتهۏٳأتىأځشأىتشتعأۄًتأتًشأتىۄًڽأىەأتههۄأحؼتهۏٳأڬۏأىتلشوتىۏأڬۏأتًشأًۄأتههۄأحؼتهۏٳأڬۏأثدتةەأثحًڽأڬۏأؼثتزحأڬشحەأحہەأحًأتههۄأحؼتهۏٳأىەأتىأځشأرطڬأإىزہۏأثہۏدۏأۗ%أ"
4064,أذعشحأڬؼثأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أتههۄأحؼتهۏٳأڬەأىثۏأذعشحأہًزأؼهۏۄأتهضهتوأ؏أذعشحأإزوأؼهۏۄأتهضهتوأڬەأضتحہأضثأهًڲًڽأضەأصۏتزۄأوطتثۄحأشڬہحەأحہەأۗأ
4065,"أذعشحأىًلأطتوۏأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأڬۄأتههۄأحؼتهۏٳأڬەأىثۏأذعشحأظتهذأؼهۏۄأتهضهتوأؼشثأضەأۄۏڽأۗأدثأتههۄأحؼتهۏٳأىەأمًوأؼتزأڬًأۄهتڬأڬشأزۏتأتًشأتىأڬتأمظۄأحوتوأۄًأڲۏتأحًأتىأڬەأثؼزأمًوأخوًزأڬًأإثتزأڬۏتأڲۏتأ؏أۏۄأهًڲأصوۏىأوۏڽأثضىەأهڲەأتًشأ+أزًشأزًشأحڬأ,أځہۏهأڲةەأۗأځہشأتىۄًڽأىەأثہۏأضشڬطۏأڬۏأۗأدثأتىأڬتألضتزأثڔہأڲۏتأتًشأۏۄأهًڲأؽۏشأرزتأڬۏأؼثتزحأڬشىەأهڲأڲةەأحًأتههۄأحؼتهۏٳأىەأتىأڬۏأغشلأذعشحأظتهذأؼهۏۄأتهضهتوأڬًأوثؼًخألشوتۏتأۗأۏۄأمًوأؼشثأحہۏأدثڬۄأذعشحأظتهذأؼهۏۄأتهضهتوأتىأوۏڽأوحًضغأرتىزتىأضەأحؼهمأشڬہحەأحہەأدثڬۄأضثأضەأتؼهۏٳأومتوأځشأشۄحەأحہەأ؏أتىأڬۏأإثتزۏأذدشأضەأمشؼأڬۏأغشلأحہۏأتًشأمشؼأًۄأًتزۏأتهمشۏٳأۄەأدًأذدشأضەأذدتصأحڬأتټہتشۄأوۏهأحڬأځہۏهۏأۄًةۏأحہۏأۗأتههۄأحؼتهۏٳأىەأتىأڬۏأدتىثأتۏڬأىًدًتىأهڔڬەأڬًأوثؼًخألشوتۏتأۗأًۄأتځىەأثتهأضلۏزأۄًىەأحڬأتىأڬًأتههۄأحؼتهۏٳأڬۏأغشلأزؼًحأزۏحتأشۄتأهۏڬىأضًتةەأتۏڬأډہًټۏأضۏأعؼۏلأدوتؼحأڬەأتًشأڬًةۏأثہۏأتضأځشأتۏوتىأىۄأهتۏتأۗأحًأمًوأخوًزأتًشأؼتزأتًشأزۏڲشأتوحۏڽأدًأتىۄۏڽأضەأحؼهمأشڬہحۏأحہۏڽأضثأڬًأۄهتڬأڬشأزۏتأڲۏتأتًشأۏۄأهًڲأهتًسأثىأضتوأثىأىًذأڬۏأتًهتزأوۏڽأضەأحہەأتًشأىًذأؼهۏۄأتهضهتوأڬەأثؼزأذعشحأتثشتۄۏوأؼهۏۄأتهضهتوأضەأځۄهەأظشلأہًزأؼهۏۄأتهضهتوأتًشأظتهذأؼهۏۄأتهضهتوأۄۏأىثۏأۄًةەأۄۏڽأۗأ"
4066,"أذعشحأڬؼثأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أځہشأتههۄأحؼتهۏٳأڬەأىثۏأذعشحأظتهذأؼهۏۄأتهضهتوأحہەأۗأإځأذعشحأؼۏضۏٳأتثىأوشۏوأؼهۏۄأتهضهتوأڬەأضتحہأثۄحأصۏتزۄأوطتثۄحأشڬہحەأحہەأ+أإځأڬتأشىڲأ,أضشرۏأوتةهأضلۏزأحہتأتًشأإځأهټڬحەأۄًةەأثتهًڽأًتهەأحہەأۗأ"
4067,"%أذعشحأًۄثأثىأوىثۄأشعۏأتههۄأؼىۄأىەأذعشحأظتهذأؼهۏۄأتهضهتوأڬتأىضثأۏًڽأثۏتىألشوتۏتأۄەأ= أ““أظتهذأثىأؼثۏزأثىأدتثشأثىأخوًزأثىأدتثشأثىأضتوأثىأىًذأۗ‛‛ أذعشحأًۄثأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأۗأتههۄأحؼتهۏٳأىەأذعشحأظتهذأؼهۏۄأتهضهتوأڬًأثتهؽأۄًحەأۄۏأتىأڬۏأمًوأڬۏأغشلأوثؼًخألشوتأزۏتأحہتأإځأڬتأشىڲأضشرۏأوتةهأضلۏزأحہتأ؏أإځأڬەأضشأڬەأثتهأضۏزہەأحہەأ؏أإځأذعشحأؼۏضۏٳأؼهۏۄأتهضهتوأڬۏأغشذأىىڲەأځتاڽأشۄتأڬشحەأحہەأ؏أإځأىۄأدًحەأځۄىحەأحہەأ؏أىۄأحۏهأهڲتحەأحہەأ؏أىۄأتىۄًڽأىەأتځىتأڬًةۏأوڬتىأثىتۏتأىۄأڬًةۏأرتظأټہڬتىۄأثىتۏتأۗأإځأۄوۏطۄأتځىەأشثأڬۏأتًىټىۏأڬەأۄوشتۄأشۄحەأحہەأ؏أًۄأدزہشأڬتأشرأڬشحۏأ؏أإځأثہۏأتضأڬەأضتحہأدتحەأتًشأدۄتڽأًۄأټہۄشحۏأ؏أإځأثہۏأًۄۏڽأمۏتوأڬشحەأۗأتًىټىۏأڬەأمحهأڬةەأدتىەأضەأځۄهەأډتهۏضأزىأحڬأإځأشًصەأضەأشۄەأتًشأإځأڬەأزتةۏڽأۄتحہأځشأحهأڬتأىطتىأحہتأۗأإځأتځىۏأثهًؽحأضەأثتهًڽأوۏڽأډتىزۏأإىەأحڬأډتهۏضأضتهأڬتأؼشظۄأتىأوۏڽأشۄەأتًشأتىأڬًأتههۄأحؼتهۏٳأڬۏأغشلأثهتحەأشۄەأهۏڬىأتىأهًڲًڽأڬۏأوضهضهأضشڬطۏأثڔہحۏأشۄۏأۗ%أ"
4068,"%أذعشحأضثشۄأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأ=أؽصًۄأحثًڬأڬەأوًمؼأځشأۄوأىەأومتوأذدشأوۏڽأځڔتاأڋتهتأحًأىثۏأتڬشوأ﷽أىەألشوتۏتأ=أدضأدضأىەأتضأځتىۏأضەأڬہتىتأحۏتشأڬۏتأۄًأ؏أًۄأځہۏىڬأزەأۗأحًأتىأوۏڽأضەأڬډہأهًڲًڽأىەأإټتأڲًىزہتأحہتأتًشأڬډہأىەأذۏضأ+أڬہدًشأ؏أڲہۏأتًشأضحًأڬتأڬہتىتأ,أحۏتشأڬشأهۏتأحہتأ؏أحًأضثأىەأځہۏىڬأزۏتأۗ أٰٰأۏۄأذزۏخأظذۏذأتهتضىتزأۄەأهۏڬىأتوتوأثرتشۏأشذوۆأتههۄأؼهۏۄأتًشأتوتوأوضهوأشذوۆأتههۄأؼهۏۄأىەأتضەأىمهأىۄۏڽأڬۏتأۗأحتۄوأتوتوأثرتشۏأشذوۆأتههۄأؼهۏۄأتًشأتوتوأوضهوأشذوۆأتههۄأؼهۏۄأىەأدًۏشۏۄأثىأتضوتؤأڬۏأذزۏخأذعشحأىتلؼأڬەأًتضغەأضەأذعشحأتثىأؼوشأشعۏأتههۄأؼىۄوتأڬتأۏۄأثۏتىأىمهأڬۏتأۄەأڬۄأهًڲأشضًهأتههۄأ﷽أڬەأۄوشتۄأخوًزأڬەأومتوأذدشأوۏڽأټہۄشەأحتۄوأتضأڬەأتهلتػأڬډہأورحهلأۄۏڽأۗ%أ"
4069,"%طۄشأثىأذًطثأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أۄوأىەأذعشحأؼوشًأثىأرتشدۄأشعۏأتههۄأؼىۄأضەأڬۄتأڬۄأۄوۏڽأمًوأخوًزأڬتأًتمؼۄأضىتةۏڽأۗأتىۄًڽأىەأڬۄتأ=أوۏڽأحوۄۏڽأشضًهأتههۄأ﷽أڬتأثحتۏتأۄًتأمًوأخوًزأڬتأمظۄأضىتحتأۄًڽأۗأخوًزأ؏أذعشحأظتهذأؼهۏۄأتهضهتوأڬۏأمًوأحہۏأۗأتههۄأحؼتهۏٳأىەأتىأڬًأزىۏتأوۏڽأثۄحأهوثۏأهوثۏأؼوشۏڽأؼغتألشوتةۏأحہۏڽأذحۏٳأڬۄأڬًةۏأوټۏأڬتأوڬتىأثىتأهۏحتأحًأًۄأ+أتځىۏأؼوشأځًشۏأڬشأڬەأ,أوؽوًوأۄًأدتحتأهۏڬىأتىأثىتىەأًتهًڽأوۏڽأضەأتثہۏأثہۏأڬًةۏأىۄأڬًةۏأصىزۄأۄًحتأحہتأۗأتضۏأًدۄأضەأًۄأځۄتڔًڽأوۏڽأوڬتىتحأثىتأڬشأرًطأۄًحەأحہەأۗأتىۄًڽأىەأځۄتڔًڽأڬًأۄوًتشأڬۏتأتًشأتىأڬًأحشتطأحشتطأڬشأڲۄشتأڬشأهۏتأۗأۏۄأهًڲأثۄحأرًطأؼۏطأحہەأۗأتىۄًڽأىەأڬۄتأ=أتەأظتهذأؼهۏۄأتهضهتوأ$أإځأۄوتشەأهةەأتځىەأشثأضەأزؼتأڬشۏڽأڬۄأًۄأۄوتشەأهةەأڬًةۏأتۏضۏأىطتىۏأػتۄشأڬشأزەأدضأضەأۄوأدتىأدتةۏڽأڬۄأإځأًتمؼۏأتههۄأحؼتهۏٳأڬەأشضًهأۄۏڽأۗأډىتىډۄأذعشحأظتهذأؼهۏۄأتهضهتوأىەأزؼتأوتىڲۏأحًأتههۄأحؼتهۏٳأىەأتىأڬەأهةەأتۏڬأتًىټىۏأىڬتهأزۏأۗأڲہتټأضەأځتىۏأځۏىەأڬەأهةەأتۏڬأزىأتًىټىۏأڬتأتًشأتۏڬأزىأتىأهًڲًڽأڬتأومششأحہتأۗأدًأزىأتًىټىۏأڬتأۄًحتأتضأزىأهًڲأتًىټىۏأتًشأځتىۏأضەأۄټأدتحەأتًشأتضأڬتأزًزہأزًۄحەأ+أتًشأتضأڬتأزًزہأتحىتأۄًحتأڬۄأ,أڬۄأًۄأهًڲأتځىەأحوتوأثشحىأوطڬۏصەأتًشأڋًهأًؽۏشۄأثہشأهۏحەأحًأتههۄأحؼتهۏٳأىەأذعشحأظتهذأؼهۏۄأتهضهتوأڬۏأغشلأًذۏألشوتةۏأڬۄأحوۄتشۏأمًوأؼىمشۏثأتضأڬۏأڬًىډۏڽأڬتټأڋتهەأڲۏأ+أۏؼىۏأتضأڬًأمحهأڬشأزەأڲۏأ,أۗأذعشحأظتهذأؼهۏۄأتهضهتوأىەأتىأڬًأتضأثتحأضەأرثشزتشأڬۏتأحًأًۄأهًڲأثًهەأ=أۄوأتۏضتأىۄۏڽأڬشۏڽأڲەأۗأإځأىەألشوتۏتأ=أحوأىەأىۄأڬۏتأحًأۄًأضڬحتأۄەأڬۄأحوۄتشۏأتًهتزًڽأوۏڽأضەأڬًةۏأۏۄأڬتوأڬشأزەأۗأتىۄًڽأىەأڬۄتأ=أإځأۄوۏڽأتضأوًهًزأڬۏأىطتىۏأثحتةۏڽأ؏أۄوأتضأڬًأځۏزتأۄًحەأۄۏأوتشأڋتهۏڽأڲەأۗأإځأىەألشوتۏتأ=أًۄأهڔڬتأضشرأًأصشزأىۏهڲًڽأۄًأڲتأ؏أدضأڬەأشىڲأوۏڽأضشرۏأوتةهأضلۏزۏأۄًأڲۏأۗأإځألشوتحەأۄۏڽأ=أطۄشأوۏڽأزًأؼوشأشضۏزۄأغتمحًشأإزوۏأشۄحەأحہەأ؏أتىأوۏڽأضەأتۏڬأڬتأثۏټتأحہتأدًأڬۄأطتزۏأضەأڲشۏصتڽأحہتأتًشأزًضشەأڬۏأتۏڬأثۏټۏأحہۏأدضأڬتأڬًةۏأڬلًأىۄأحہتأ+أۏؼىۏأتضأڬەأضټۏټضأڬتأڬًةۏأشطحۄأىۄأحہتأ,أتۏڬأزلؼۄأزًىًڽأتۏڬأودهضأوۏڽأتڬټہەأۄًةەأحًأتىأوۏڽأضەأتۏڬأىەأزًضشەأضەأڬۄتأ=أإځأتځىەأثۏټەأڬۏأطتزۏأڬۏًڽأىۄۏڽأڬشأشۄەأآأتضأىەأڬۄتأ=أودہەأتضأڬتأڬًةۏأڬلًأ+أضټۏټضأڬتأشطحۄأ,أىۄۏڽأوهأشۄتأۗأتضأىەأڬۄتأ=أوۏشۏأثۏټۏأتضأڬتأڬلًأۄەأۗأوۏڽأتضأڬتأىڬتذأحۏشەأثۏټەأضەأڬشىەأڬًأحۏتشأۄًڽأۗأډىتىډۄأتىۄًڽأىەأزًىًڽأڬۏأطتزۏأڬشأزۏأحًأتىأڬەأۄتڽأًۄأثډۄأځۏزتأۄًتأ؏أتضأطۄشأوۏڽأإټہأتلشتزألضتزۏأحہەأدًأڬضۏأغشذأتظهتذأڬۏأغشلأىۄأإحەأحہەأۗأذعشحأظتهذأؼهۏۄأتهضهتوأىەأتىأضەأڬۄتأ=أدًأتضأتًىټىۏأڬًأوتشەأڲتأًۄأحوأوۏڽأځۏزتأۄًأډڬتأۄەأحًأتىۄًڽأىەأتضأثضحۏأوۏڽأضەأإټہأزتةۏتڽأوىحرثأڬۏڽأتًشأتىأڬەأۄوشتۄأضځتۄۏأثہۏأومششأڬشأزةۏەأ؏أۏۄأثضحۏأوۏڽأڲطحأڬشحەأشۄحەأحہەأتًشأدضأڬضۏأؼًشحأڬًأزشزصۄأوۏڽأوثحهتأځتحەأحًأىػشأشڬہحەأڬۄأتضأڬەأۄتڽأهڔڬتأځۏزتأۄًتأۄەأۏتأهڔڬۏأۗأتڲشأهڔڬتأۄًحتأحًأتضأڬًأصۏشأىػشأشڬہحەأتًشأتڲشأهڔڬۏأۄًحۏأحًأتضأڬًأډہًڔأزۏحەأۗأدثأتىأڬًأًۄأوًهًزأوهأڲۏتأحًأؼًشحۏڽأډۏرأډۏرأڬشأثًهىەأهڲۏڽأ=أۏۄۏأۄەأًۄأوًهًزأدًأشضًهأتههۄأؼهۏۄأتهضهتوأڬًأوغهًثأۄەأۗأضځتۄۏًڽأىەأتضأثډەأڬًأتځىەأضتحہأهەأدتىتأډتۄتأحًأتضأثډەأڬەأزتزتأزتزۏأثۏډأوۏڽأإأڲةەأ؏أًۄأڬۄىەأهڲەأ=أتڲشأظتهذأؼهۏۄأتهضهتوأڬتأوغهًثأۏۄۏأثډۄأۄەأحًأۄوأرًزأتضأڬًأمحهأڬشأزۏڽأڲەأڬۏًىڬۄأتضأظًشحأوۏڽأۏۄأثډۄأىمظتىأزۄأۄًأڲتأ؏أًۄأهڔڬتأتۏڬأزىأوۏڽأتحىتأثڔہحتأدحىتأزًضشەأثډەأځًشەأتۏڬأۄلحەأوۏڽأثڔہحەأۄۏڽأتًشأۏۄأتۏڬأۄلحۄأوۏڽأتحىتأثڔہحتأ؏أدحىتأزًضشەأثډەأځًشەأوۄۏىەأوۏڽأثڔہحەأۄۏڽأتًشأۏۄأتۏڬأوۄۏىۄأوۏڽأتحىتأثڔہحتأدحىتأزًضشەأثډەأځًشەأتۏڬأضتهأوۏڽأثڔہحەأۄۏڽأۗأحًأًۄأإټہًڽأتلشتزأدوؼأۄًأڲةەأ؏أدًألضتزۏأحہەأتًشأتظهتذأىۄأڬشحەأحہەأتًشأزًىًڽأثًڔہەأدوؼأۄًأڲةەأۗأتًشأڬۄىەأهڲەأ=أۄوأتضأثډەأڬًأتضأڬەأومتوأتًشأتضأڬەأثتځأزتزتأڬەأوشحثۄأڬۏأًدۄأضەأڬتوأځشأشڬہحەأۄۏڽأحًأۏۄأهًڲأ<أحہەأتًشأذعشحأظتهذأؼهۏۄأتهضهتوأتىأڬەأۄوشتۄأثضحۏأوۏڽأإشتوأىۄۏڽأڬشحەأحہەأثهڬۄأزًشأځۄتڔأځشأوضدزأوۏڽأ+أدضأڬتأىتوأوضدزأظتهذأؼهۏۄأتهضهتوأۄەأ,أشتحأڲصتشتأڬشحەأحہەأۗأظثذأۄًحۏأحًأإځأتىأڬەأځتضأإحەأتًشأتىأڬًأًؼػأًأىظۏذحأڬشحەأتًشأدثأطتوأۄًأدتحۏأحًأإځأًتځضأتضۏأوضدزأوۏڽأډهەأدتحەأتًشأتضۏأوۏڽأشتحأڲصتشحەأۗ أشضًهأتههۄأ﷽أىەألشوتۏتأ=أدثأتىأهًڲًڽأىەأذعشحأظتهذأؼهۏۄأتهضهتوأڬەأرهتلأضتصطأڬتأتشتزۄأڬۏتأحًأًۄأإټہأإزوۏأذعشحأظتهذأؼهۏۄأتهضهتوأڬۏأڲصشڲتۄأوۏڽأڲہتحأهڲتأڬشأثۏټہأڲةەأتًشأتىۄًڽأىەأۏۄأغەأڬشأهۏتأڬۄأدثأإځأۏۄتڽأضەأڲصشۏڽأڲەأحًأۄوأتىۄۏڽأمحهأڬشأزۏڽأڲەأتًشأځہشأتىأڬەأڲہشأًتهًڽأځشأطثأرًىأوتشۏڽأڲەأۗأتههۄأحؼتهۏٳأىەأصوۏىأڬًأذڬوأزۏتأحًأًۄأضوټأڲةۏأۗأۏۄأضثأهًڲأدوؼأۄًةەأتًشأتًىټىۏأڬۏأدتىثأډهأځڔەأۗأۏۄأتًىټىۏأتضأًمحأذًعأځشأحہۏأۗأتىأوۏڽأضەأتۏڬأثزثرحأىەأڬۄتأ=أتضأڬەأځتضأدتاأتًشأتضأڬۏأڬًىډۏڽأڬتټأڋتهًأۗأًۄأتضأڬەأځتضأإۏتأهۏڬىأتضأڬًأمحهأڬشىەأڬۏأدضتشحأىۄأڬشأضڬتأتًشأًتځضأډهتأڲۏتأۗأځہشأزًضشەأڬًأثہۏدتأهۏڬىأًۄأثہۏأڲہثشتأڲۏتأۗأًۄأدضأڬًأثہۏأثہۏدحتأًۄأڲہثشتأدتحتأذحۏٳأڬۄأًۄأثزثرحأرًزأډهأځڔتأتًشأزًشأضەأڲشزىأتټہتأڬشأتضەأزۏڬہتأتًشأتضأڬۏأڬًىډۏڽأڬتټأڋتهۏڽأۗأًۄأڲشأڬشأحڔځىەأهڲۏأ؏أتىأوۏڽأضەأتۏڬأإزوۏأذعشحأظتهذأؼهۏۄأتهضهتوأڬەأځتضأإۏتأتًشأثًهتأ=أتًىټىۏأڬەأځتىډأځۄىډةەأڬۏًىڬۄأتضأڬۏأڬًىډۏڽأڬتټأزۏأڲةۏأۄۏڽأۗأإځألًشتَأىڬهەأتًشأۏۄأهًڲأإځأضەأوهأڬشأڬۄىەأهڲەأ=أتەأتههۄأحؼتهۏٳأڬەأىثۏأ$أتضأڬًألهتڽأطرظأىەأمحهأڬۏتأۄەأ؏أتضأوۏڽأۄوتشتأڬًةۏأمظًشأىۄۏڽأۄەأۗأإځأىەألشوتۏتأ=أڬًططأڬشأڬەأتضأڬەأثډەأڬًأذتظهأڬشأهًأتڲشأحوأتضأڬًأذتظهأڬشىەأوۏڽأڬتوۏتثأۄًأڲةەأحًأۄًأضڬحتأۄەأڬۄأؼستثأتهٳۄۏأضەأثډتاأڬۏأڬًةۏأظًشحأىڬهأإةەأۗأۏۄأهًڲأتضأتًىټىۏأڬەأثډەأڬۏأحهتطأوۏڽأىڬهأځڔەأ؏أتزہشأدثأثډەأىەأتځىۏأوتڽأڬًأحڔځحەأزۏڬہتأحًأًۄأځۄتڔأځشأزًڔأڲۏتأتضأڬًأ““أؽتشۄأمۏظشأ‛‛أڬۄحەأۄۏڽأۗأۏۄأهًڲأتضأڬًأځڬڔىەأڬەأهةەأځۄتڔأځشأإةەأحًأتههۄأحؼتهۏٳأىەأځۄتڔأڬًأذڬوأزۏتأحًأًۄأإضوتىأڬۏأغشلأتټہأڲۏتأتًشأځشىزًڽأڬۏأشضتةۏأضەأثہۏأتًىډتأۄًأڲۏتأۗ
أذعشحأظتهذأؼهۏۄأتهضهتوأثضحۏأوۏڽأزترهأۄًةەأۗأدثأإځأڬًأتًىټىۏأڬەأثډەأىەأزۏڬہتأحًأشًىەأهڲأڲۏتأذحۏٳأڬۄأتضأڬەأإىضًأثۄۄأىڬهەأۗأځہشأًۄأذعشحأظتهذأؼهۏۄأتهضهتوأڬۏأغشلأوحًدۄأۄًتأتًشأثهثهتۏتأ؏أځہشأزًثتشۄأثهثهتۏتأځہشأحۏضشۏأوشحثۄأثهثهتۏتأۗأذعشحأظتهذأؼهۏۄأتهضهتوأىەألشوتۏتأ=أتضأڬۏأۄشأثهثهتۄټأتۏڬأزىأڬۏأوۄهحأۄەأډىتىډۄأحوأهًڲأحۏىأزىأحڬأتځىەأڲہشًڽأوۏڽألتةزۄأتټہتأهًأۏۄأًؼزۄأۄەأدًأدہًټتأىۄۏڽأۄًأڲتأتًشأؼستثأڬۏأىطتىۏأۏۄأۄەأڬۄأځۄهەأزىأحوۄتشەأډۄشەأصشزأۄًأدتةۏڽأڲەأ؏أزًضشەأزىأضشرأتًشأحۏضشەأزىأڬتهەأۗأدثأتڲهتأزىأۄًتأحًأًتمؼۏأتىأڬەأډۄشەأتۏضەأ+أصشزأ,أۄًأڲةەأۏًڽأهڲحتأحہتأڲًۏتأڬۄأتىأځشأصؼلشتىأڬتأشىڲأډڔہتأزۏتأڲۏتأۄەأۗأتىأڬەأثڔەأ؏أډہًټەأ؏أوشزأًأؼًشحأ+أضثأڬتأۏۄۏأذتهأحہتأ,أدثأطتوأۄًةۏأحًأضثأتڬټہەأډهتىەأهڲەأڬۄأرثشزتشأ$أوۄهحأڬتأتۏڬأزىأڲصشأډڬتأۄەأتًشأؼىمشۏثأحوأځشأؼستثأإىەأًتهتأۄەأۗأدثأتڲهتأزىأۄًتأحًأتىأڬەأډۄشەأضشرأۄًأډڬەأحہەأڲًۏتأڬۄأرًىأوهأزۏتأڲۏتأۄًأۏۄأځہشأإۄأًأثڬتأتًشأډۏرأًأځڬتشأڬشىەأهڲەأتًشأۏۄأضودہأڲةەأڬۄأۏۄأًتمؼۏأؼستثأۄۏأۄەأۗأدثأطتوأۄًةۏأحًأضثأډهتىەأهڲەأ=أرثشزتشأ$أوۄهحأڬەأزًأزىأڲصشأڲةەأتًشأتثأؼستثأثتهڬهأإىەأۄۏأًتهتأۄەأۗأدثأحۏضشتأزىأإۏتأحًأتىأڬەأډۄشەأضۏتۄأۄًأډڬەأحہەأڲًۏتأڬۄأتىأځشأحتشڬًهأوهأزۏتأڲۏتأۄًأۏۄأځہشأضثأډهتةەأ=أرثشزتشأ$أحوأځشأؼستثأإأشۄتأۄەأۗأتىۄًڽأىەأرًزأۄۏأتځىەأڬلىأځۄىەأتًشأرًزأۄۏأتځىەأإځأڬًأوشزًڽأًتهۏأرًطثًأهڲتةۏأتىأڬۏأوشزًڽأًتهۏأرًطثًأتۏهًتأتًشأڬڔًتۄټأحہۏأتًشأتىأڬەأڬلىأ““أتىغتؼأ‛‛أ+أًۄأډوڔەأڬتألشطأدضأځشأودشوأڬًأمحهأڬۏتأدتحتأۄەأ,أڬتأحہتأۗأځہشأۏۄأصوۏىأڬەأتًځشأهۏټأڲةەأڬۏًىڬۄأتىأڬًأڬډہأتىزتصۄأىۄأحہتأڬۄأؼستثأإضوتىأڬۏأغشلأضەأإةەأڲتأۏتأصوۏىأڬۏأغشلأضەأ؏أتضأهةەأڲہثشتۄټأتًشأرًلأڬۏأًدۄأضەأًۄأڬثہۏأإضوتىأڬۏأغشلأزۏڬہحەأتًشأڬثہۏأصوۏىأڬۏأغشلأۗأدثأډًحہتأزىأإۏتأحًأإضوتىأضەأتۏڬأډۏرأڬۏأإًتصأإةۏأ؏أتضأوۏڽأۄشأڬڔڬأڬۏأإًتصأوًدًزأحہۏأتًشأۄشأتضأطەأڬۏأإًتصأثہۏأوًدًزأحہۏأدضأڬۏأشًةەأصوۏىأوۏڽأإًتصأۄًحۏأۄەأۗأتضأڬۏأًدۄأضەأتىأڬەأضۏىًڽأوۏڽأتىأڬەأزهأځہټأڲةەأ؏أحًأًۄأظثذأتځىەأڲہشًڽأوۏڽأڲہټىًڽأڬەأثهأځڔەأشۄأڲةەأۗ أٰٰأۏۄأذزۏخأمًوأخوًزأڬۏأۄهتڬحأڬەأًتمؼتحأڬۏأدتوؼأۄەأتًشأتضأڬۏأشًتۏحأڬشىەأوۏڽأطہشأثىأذًطثأشعۏأتههۄأؼىۄأوحلشزأۄۏڽأتًشأتضأضىزأڬەأؼهتًۄأتضأڬۏأڬًةۏأزًضشۏأضىزأىۄۏڽأۄەأتًشأتضأڬًأىمهأڬشىتأعشًشۏأحہتأتًشأضىزأظذۏذأڬەأۄوشتۄأتۏڬأورحظشأذز