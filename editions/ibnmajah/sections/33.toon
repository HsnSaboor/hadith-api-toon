3770,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا أَبُو أُسَامَةَ،‏‏‏‏ عَنْ بُرَيْدِ بْنِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الاستئذان ۴۹ (۶۲۹۴)، صحیح مسلم/الأشربة ۱۲ (۲۰۱۶)،(تحفة الأشراف:۹۰۴۸)، وقد أخرجہ: مسند احمد (۴/۳۹۹),3770,,Etiquette
3771,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ،‏‏‏‏ عَنْ ع,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۷۹۴)، وقد أخرجہ: صحیح البخاری/الاستئذان ۴۹ (۶۲۹۵)، صحیح مسلم/الأشربة ۱۲ (۲۰۱۳)، سنن ابی داود/الأشربة ۲۲ (۳۷۳۱),3771,,Etiquette
3772,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ،‏‏‏‏ أَنْبَأَنَا ه,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الجہاد ۶۳ (۲۵۷۰)،(تحفة الأشراف:۲۲۱۹)، وقد أخرجہ: مسند احمد (۱/۲۰۳),3772,,Etiquette
3773,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ سُلَيْمَانَ،‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/فضائل الصحابة ۱۱ (۲۴۲۸)، سنن ابی داود/الجہاد ۶۰ (۲۵۶۶)،(تحفة الأشراف:۵۲۳۰)، وقد أخرجہ: مسند احمد (۱/۲۰۳)، سنن الدارمی/الاسئذان ۳۶ (۲۷۰۷),3773,,Etiquette
3774,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ،‏‏‏‏ أَنْبَأَنَا ب,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۰۰۱، ومصباح الزجاجة:۱۳۱۹)، وقد أخرجہ: سنن الترمذی/الاستئذان ۲۰ (۲۷۱۳),3774,,Etiquette
3775,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ،‏‏‏‏ حَدَّثَنَا أَبُو مُعَاوِيَةَ،‏‏‏‏ وَوَكِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/السلام ۱۵ (۲۱۸۴)، سنن ابی داود/الأدب ۲۹ (۴۸۵۱)، سنن الترمذی/الأدب ۵۹ (۲۸۲۵)،(تحفة الأشراف:۹۲۵۳)، وقد أخرجہ: صحیح البخاری/الاستئذان ۴۷ (۶۲۹۰،۶۲۹۱)، مسند احمد (۱/۳۷۵،۴۲۵،۴۳۰،۴۴۰،۴۶۲،۴۶۴،۴۶۵، سنن الدارمی/الاستئذان ۲۸ (۲۶۹۹),3775,,Etiquette
3776,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ،‏‏‏‏ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ،‏‏‏‏ عَنْ عَبْدِ اللَّهِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۱۷۷)، وقد أخرجہ: صحیح البخاری/الاستئذان ۴۵ (۶۲۸۸)، صحیح مسلم/السلام ۱۵ (۲۱۸۴)، سنن ابی داود/الأدب ۲۹ (۴۸۵۱)، موطا امام مالک/الکلام ۶ (۱۴)، مسند احمد (۱/۴۲۵،۴۶۲،۴۶۴),3776,,Etiquette
3777,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ،‏‏‏‏ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ،‏‏‏‏ قَالَ:‏‏‏‏ قُلْتُ لِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الصلاة ۶۶ (۴۵۱)، الفتن ۷ (۷۰۷۳)، صحیح مسلم/البر والصلة ۳۴ (۲۶۱۴)، سنن ابی داود/الجہاد ۷۲ (۲۵۸۶)، سنن النسائی/المساجد ۲۶ (۷۱۹)،(تحفة الأشراف:۲۵۲۷)، وقد أخرجہ: مسند احمد (۳/۳۰۸،۳۵۰)، سنن الدارمی/المقدمة ۵۳ (۶۵۷,3777,,Etiquette
3778,حَدَّثَنَا مَحْمُودُ بْنُ غَيْلَانَ،‏‏‏‏ حَدَّثَنَا أَبُو أُسَامَةَ،‏‏‏‏ عَنْ بُرَيْدٍ،‏‏‏‏ عَنْ جَد,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الصلاة ۶۷ (۴۵۲)، الفتن ۷ (۷۰۷۵)، صحیح مسلم/البر والصلة ۳۴ (۲۶۱۵)، سنن ابی داود/الجہاد ۷۲ (۲۵۸۷)،(تحفة الأشراف:۹۰۳۹)، وقد أخرجہ: مسند احمد (۴/۳۹۱،۳۹۲،۳۹۷،۴۱۰،۴۱۳),3778,,Etiquette
3779,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ،‏‏‏‏ حَدَّثَنَا عِيسَى بْنُ يُونُسَ،‏‏‏‏ حَدَّثَنَا سَعِيدُ بْنُ أَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/تفسیر القرآن ۷۹ (۴۹۳۷)، صحیح مسلم/المسافرین ۳۸ (۷۹۸)، سنن ابی داود/الصلاة ۳۴۹ (۱۴۵۴)، سنن الترمذی/فضائل القرآن ۱۳ (۲۹۰۴)،(تحفة الأشراف:۱۶۱۰۲)، وقد أخرجہ: مسند احمد (۶/۴۸،۹۴،۹۸،۱۱۰،۱۷۰،۱۹۲،۲۳۹،۲۶۶)، سنن الدارمی/فضائل القرآن ۱۱ (۳۴۱۱),3779,,Etiquette
3780,حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ مُوسَى،‏‏‏‏ أَنْبَأَنَا شَيْبَانُ،‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۲۲۶، ومصباح الزجاجة:۱۳۲۰)، وقد أخرجہ: مسند احمد (۳/۴۰),3780,,Etiquette
3781,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ بَشِيرِ بْنِ مُهَاجِرٍ،‏‏‏‏ عَنْ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۹۵۳، ومصباح الزجاجة:۱۳۲۱)، وقد أخرجہ: حم (۵/۳۴۸،۳۵۲،۳۶۱)، سنن الدارمی/فضائل القران ۱۵ (۳۴۳۴),3781,,Etiquette
3782,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ قَالَا:‏‏‏‏ حَدَّثَنَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/المسافرین ۴۱ (۸۰۲)،(تحفة الأشراف:۱۲۴۷۱)، وقد أخرجہ: مسند احمد (۲/۳۹۶،۴۶۶،۴۹۶)سنن الدارمی/فضائل القرآن ۱ (۳۳۵۷),3782,,Etiquette
3783,حَدَّثَنَا أَحْمَدُ بْنُ الْأَزْهَرِ،‏‏‏‏ حَدَّثَنَا عَبْدُ الرَّزَّاقِ،‏‏‏‏ أَنْبَأَنَا مَعْمَرٌ،‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/المسافرین ۳۲ (۷۸۹)، سنن الترمذی/القراء ات ۱۰۰ (۲۹۴۲)،(تحفة الأشراف:۷۵۴۶)، وقد أخرجہ: صحیح البخاری/فضائل القرآن ۲۳ (۵۰۳۱)، سنن النسائی/الافتتاح ۳۷ (۹۴۳)، موطا امام مالک/القرآن ۴ (۶)، مسند احمد (۲/۱۷،۲۳،۳۰،۶۴،۱۱۲),3783,,Etiquette
3784,حَدَّثَنَا أَبُو مَرْوَانَ مُحَمَّدُ بْنُ عُثْمَانَ الْعُثْمَانِيُّ،‏‏‏‏ حَدَّثَنَا عَبْدُ الْعَزِيز,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۴۰۴۵)، وقد أخرجہ: صحیح مسلم/الصلاة ۱۱ (۳۹۵)، سنن ابی داود/الصلاة ۱۳۶ (۸۲۱)، سنن الترمذی/تفسیر الفاتحة ۲ (۱)(۲۹۵۳)، سنن النسائی/الافتتاح ۲۳ (۹۱۰)، موطا امام مالک/الصلاة ۹ (۳۹)مسند احمد (۲/۲۴۱،۲۵۰،۲۸۵،۲۹۰،۴۵۷،۴۷۸),3784,,Etiquette
3785,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا غُنْدَرٌ،‏‏‏‏ عَنْ شُعْبَةَ،‏‏‏‏ عَنْ خُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/تفسیر الفاتحة ۱ (۴۴۷۴)، تفسیرالأنفال ۳ (۴۶۴۷)، وتفسیر الحجر ۳ (۴۷۰۳)، فضائل القرآن ۹ (۵۰۰۶)، سنن ابی داود/الصلاة ۳۵۰ (۱۴۵۸)، سنن النسائی/الافتتاح ۳۶ (۹۱۴)،(تحفة الأشراف:۱۲۰۴۷)، وقد أخرجہ: موطا امام مالک/الصلاة ۷ (۳۷)، مسند احمد (۳/۴۵۰،۴/۲۱۱)، سنن الدارمی/الصلاة ۱۷۲ (۱۵۳۳)، فضائل القرآن ۱۲ (۳۴۱۶),3785,,Etiquette
3786,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا أَبُو أُسَامَةَ،‏‏‏‏ عَنْ شُعْبَةَ،‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Lighairihi; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الصلاة ۳۲۷ (۱۴۰۰)، سنن الترمذی/فضائل القرآن ۹ (۲۸۹۱)،(تحفة الأشراف:۱۳۵۵۰)، وقد أخرجہ: سنن الدارمی/فضائل القرآن ۲۳ (۳۴۵۳),3786,,Etiquette
3787,حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ،‏‏‏‏ حَدَّثَنَا سُلَيْمَانُ بْنُ بِلَا,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن الترمذی/فضائل القرآن ۱۱ (۲۸۹۹)،(تحفة الأشراف:۱۲۶۷۱)، وقد أخرجہ: صحیح مسلم/ المسافرین ۴۵ (۸۱۲),3787,,Etiquette
3788,حَدَّثَنَا الْحَسَنُ بْنُ عَلِيٍّ الْخَلَّالُ،‏‏‏‏ حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ،‏‏‏‏ عَنْ جَرِير,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۵۰)، وقد أخرجہ: سنن الترمذی/فضائل القرآن ۱۱ (۲۸۹۹)، سنن الدارمی/فضائل القرآن ۲۴ (۳۴۷۵),3788,,Etiquette
3789,حدثنا علي بن محمد حدثنا وكيع عن سفيان عن أبي قيس الأودي عن عمرو بن ميمون عن أبي مسعود الأنصاري قال:,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۰۰۱، ومصباح الزجاجة:۱۳۲۲)، وقد أخرجہ: مسند احمد (۴/۱۲۲),3789,,Etiquette
3790,حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ،‏‏‏‏ حَدَّثَنَا الْمُغِيرَةُ بْنُ عَبْدِ الرَّحْمَنِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/الدعوات ۶ (۳۳۷۷)،(تحفة الأشراف:۱۰۹۵۰)، وقد أخرجہ: موطا امام مالک/القرآن ۷ (۲۴)، مسند احمد (۵/۱۹۵،۶/۴۴۷),3790,,Etiquette
3791,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا يَحْيَى بْنُ آدَمَ،‏‏‏‏ عَنْ عَمَّارِ بْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الذکروالدعاء ۱۱ (۲۷۰۰)، سنن الترمذی/الدعوات ۷ (۳۳۷۸)،(تحفة الأشراف:۳۹۶۴،۱۲۱۹۴)، وقد أخرجہ: مسند احمد۳/۳۳،۴۹،۹۲،۹۴),3791,,Etiquette
3792,حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا مُحَمَّدُ بْنُ مُصْعَبٍ،‏‏‏‏ عَنْ الْأَوْزَاعِيِّ،‏‏‏‏ عَنْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۵۵۱۲، ومصباح الزجاجة:۱۳۲۳)، وقد أخرجہ: صحیح البخاری/التوحید ۴۳ تعلیقا، مسند احمد (۲/۵۴۰),3792,,Etiquette
3793,حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا زَيْدُ بْنُ الْحُبَابِ،‏‏‏‏ أَخْبَرَنِي مُعَاوِيَةُ بْنُ صَا,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن الترمذی/الدعوات ۴ (۳۳۷۵)،(تحفة الأشراف:۵۱۹۶)، وقد أخرجہ: مسند احمد (۴/۱۸۸،۱۹۰),3793,,Etiquette
3794,حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا الْحُسَيْنُ بْنُ عَلِيٍّ،‏‏‏‏ عَنْ حَمْزَةَ الزَّيَّاتِ،‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/الدعوات ۳۷ (۳۴۳۰)،(تحفة الأشراف:۳۹۶۶،۱۲۱۹۶),3794,,Etiquette
3795,حَدَّثَنَا هَارُونُ بْنُ إِسْحَاق الْهَمْدَانِيُّ،‏‏‏‏ حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الْوَهَّابِ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۰۲۱،۱۰۶۷۶، ومصباح الزجاجة:۱۳۲۴)، وقد أخرجہ: مسند احمد (۱/۱۶۱),3795,,Etiquette
3796,حَدَّثَنَا عَبْدُ الْحَمِيدِ بْنُ بَيَانٍ الْوَاسِطِيُّ،‏‏‏‏ حَدَّثَنَا خَالِدُ بْنُ عَبْدِ اللَّهِ،,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۳۳۱، ومصباح الزجاجة:۱۳۲۵)، وقد أخرجہ: مسند احمد (۵/۲۲۹),3796,,Etiquette
3797,حَدَّثَنَا إِبْرَاهِيمُ بْنُ الْمُنْذِرِ الْحِزَامِيُّ،‏‏‏‏ حَدَّثَنَا زَكَرِيَّا بْنُ مَنْظُورٍ،‏‏‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۸۰۱۳، ومصباح الزجاجة:۱۳۲۶),3797,,Etiquette
3798,حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا زَيْدُ بْنُ الْحُبَابِ،‏‏‏‏ عَنْ مَالِكِ بْنِ أَنَسٍ،‏‏‏‏ أَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/بدء الخلق ۱۱ (۳۲۹۳)، الدعوات ۶۵ (۶۴۰۳)، صحیح مسلم/الذکر والدعاء ۱۰ (۲۶۹۱)، سنن الترمذی/الدعوات ۶۰ (۳۴۶۴)،(تحفة الأشراف:۱۲۵۷۱)، وقد أخرجہ: موطا امام مالک/القرآن ۷ (۲۰)، مسند احمد (۲/۳۰۲،۳۷۵),3798,,Etiquette
3799,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا بَكْرُ بْنُ عَبْدِ الرَّحْمَنِ،‏‏‏‏ حَدّ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۲۳۸),3799,,Etiquette
3800,حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ الدِّمَشْقِيُّ،‏‏‏‏ حَدَّثَنَا مُوسَى بْنُ إِبْرَاهِ,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Hasan,takhreej: «سنن الترمذی/الدعوات ۹ (۳۳۸۳)،(تحفة الأشراف:۲۲۸۶),3800,,Etiquette
3801,حَدَّثَنَا إِبْرَاهِيمُ بْنُ الْمُنْذِرِ الْحِزَامِيُّ،‏‏‏‏ حَدَّثَنَا صَدَقَةُ بْنُ بَشِيرٍ مَوْلَى,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۳۷۷، ومصباح الزجاجة:۱۳۲۷),3801,,Etiquette
3802,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا يَحْيَى بْنُ آدَمَ،‏‏‏‏ حَدَّثَنَا إِسْرَائِيلُ،‏‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۷۶۵، ومصباح الزجاجة:۱۳۲۸)، وقد أخرجہ: مسند احمد (۴/۳۱۶،۳۱۸،۳۱۹),3802,,Etiquette
3803,حَدَّثَنَا هِشَامُ بْنُ خَالِدٍ الْأَزْرَقُ أَبُو مَرْوَانَ،‏‏‏‏ حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan Lighairihi; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۷۸۶۴، ومصباح الزجاجة:۱۳۲۹),3803,,Etiquette
3804,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ مُوسَى بْنِ عُبَيْدَةَ،‏‏‏‏ عَنْ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۴۳۵۷، ومصباح الزجاجة:۱۳۳۰),3804,,Etiquette
3805,حَدَّثَنَا الْحَسَنُ بْنُ عَلِيٍّ الْخَلَّالُ،‏‏‏‏ حَدَّثَنَا أَبُو عَاصِمٍ،‏‏‏‏ عَنْ شَبِيبِ بْنِ ب,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۰۴، ومصباح الزجاجة:۱۳۳۱),3805,,Etiquette
3806,حَدَّثَنَا أَبُو بَكْرٍ،‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ قَالَا:‏‏‏‏ حَدَّثَنَا مُحَمَّدُ بْنُ فُض,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الدعوات ۶۵ (۶۴۰۶)، التوحید ۵۷ (۷۵۶۳)، صحیح مسلم/الذکر والدعاء ۱۰ (۲۶۹۴)، سنن الترمذی/الدعوات ۶۰ (۳۴۶۷)،(تحفة الأشراف:۱۴۸۹۹)، وقد أخرجہ: مسند احمد (۲/۲۳۲),3806,,Etiquette
3807,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَفَّانُ،‏‏‏‏ حَدَّثَنَا حَمَّادُ بْنُ س,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۴۱۳۴، ومصباح الزجاجة:۱۳۳۲),3807,,Etiquette
3808,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ،‏‏‏‏ حَدَّثَنَا مِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الذکروالدعاء ۱۹ (۲۷۲۶)،(تحفة الأشراف:۱۵۷۸۸)، وقد أخرجہ: سنن ابی داود/الصلاة ۳۵۹ (۱۵۰۳)، سنن الترمذی/الدعوات ۱۰۴ (۳۵۵۵)، سنن النسائی/االسہو ۹۴ (۱۳۵۳)، مسند احمد (۶/۳۲۵،۴۲۹),3808,,Etiquette
3809,حَدَّثَنَا أَبُو بِشْرٍ بَكْرُ بْنُ خَلَفٍ،‏‏‏‏ حَدَّثَنِي يَحْيَى بْنُ سَعِيدٍ،‏‏‏‏ عَنْ مُوسَى بْن,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۶۳۲، ومصباح الزجاجة:۱۳۳۳)، وقد أخرجہ: مسند احمد (۴/۲۶۸،۲۷۱),3809,,Etiquette
3810,حَدَّثَنَا إِبْرَاهِيمُ بْنُ الْمُنْذِرِ الْحِزَامِيُّ،‏‏‏‏ حَدَّثَنَا أَبُو يَحْيَى زَكَرِيَّا بْنُ,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۸۰۱۳،۱۸۰۱۴، ومصباح الزجاجة:۱۳۳۴)، وقد أخرجہ: مسند احمد (۶/۳۴۴),3810,,Etiquette
3811,حَدَّثَنَا أَبُو عُمَرَ حَفْصُ بْنُ عَمْرٍو،‏‏‏‏ حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ،‏‏‏‏ ح,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «صحیح مسلم/الآداب ۲ (۲۱۳۷)،(تحفة الأشراف:۴۶۳۶)، وقد أخرجہ: مسند احمد (۵/۱۱،۲۰),3811,,Etiquette
3812,حَدَّثَنَا نَصْرُ بْنُ عَبْدِ الرَّحْمَنِ الْوَشَّاءُ،‏‏‏‏ حَدَّثَنَا عَبْدُ الرَّحْمَنِ الْمُحَارِب,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن الترمذی/الدعوات ۶۰ (۳۴۶۶،۳۴۶۸)،(تحفة الأشراف:۱۲۵۷۸)، وقد أخرجہ: صحیح البخاری/الدعوات ۶۵ (۶۴۰۵)، مسند احمد (۲/۳۰۲،۳۷۵،۵۱۵),3812,,Etiquette
3813,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا أَبُو مُعَاوِيَةَ،‏‏‏‏ عَنْ عُمَرَ بْنِ رَاشِدٍ،‏‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۹۷۲، ومصباح الزجاجة:۱۳۳۵)، وقد أخرجہ: مسند احمد (۶/۴۴۰),3813,,Etiquette
3814,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا أَبُو أُسَامَةَ،‏‏‏‏ وَالْمُحَارِبِيُّ،‏‏‏‏ عَنْ م,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الصلاة ۳۶۱ (۱۵۱۶)، سنن الترمذی/الدعوات ۳۹ (۳۴۳۴)،(تحفة الأشراف:۸۴۲۲)، وقد أخرجہ: مسند احمد (۲/۲۱),3814,,Etiquette
3815,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ،‏‏‏‏ عَنْ مُحَمَّد,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۵۱۰۰، ومصباح الزجاجة:۱۳۳۶)، وقد أخرجہ: مسند احمد (۳/۲۸۲),3815,,Etiquette
3816,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ مُغِيرَةَ بْنِ أَبِي الْحُرِّ،‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۰۸۹، ومصباح الزجاجة:۱۳۳۷)، وقد أخرجہ: مسند احمد (۴/۴۱۰،۵/۳۹۷),3816,,Etiquette
3817,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا أَبُو بَكْرِ بْنُ عَيَّاشٍ،‏‏‏‏ عَنْ أَبِي إِسْحَا,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۳۷۶، ومصباح الزجاجة:۱۳۳۸)، وقد أخرجہ: مسند احمد (۵/۳۹۴،۳۹۶،۳۹۷،۴۰۲)، سنن الدارمی/الرقاق ۱۵ (۲۷۶۵),3817,,Etiquette
3818,حَدَّثَنَا عَمْرُو بْنُ عُثْمَانَ بْنِ سَعِيدِ بْنِ كَثِيرِ بْنِ دِينَارٍ الْحِمْصِيُّ،‏‏‏‏ حَدَّثَن,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۲۰۰، ومصباح الزجاجة:۱۳۳۹)، وقد أخرجہ: مسند احمد (۶/۱۲۹،۱۴۵،۱۸۸،۲۳۹),3818,,Etiquette
3819,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ،‏‏‏‏ حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ،‏‏‏‏ حَدَّثَنَا الْحَكَمُ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الصلاة ۳۶۱ (۱۵۱۸)،(تحفة الأشراف:۶۲۸۸)، وقد أخرجہ: مسند احمد (۱/۲۴۸),3819,,Etiquette
3820,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ،‏‏‏‏ عَنْ حَمَّادِ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۶۳۰۵، ومصباح الزجاجة:۱۳۴۰)، وقد أخرجہ: مسند احمد (۶/۱۲۹،۱۴۵،۱۸۸،۲۳۹),3820,,Etiquette
3821,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ الْأَعْمَشِ،‏‏‏‏ عَنْ الْمَعْرُو,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الذکر والدعاء ۶ (۲۶۸۷)،(تحفة الأشراف:۱۱۹۸۴)، وقد أخرجہ: مسند احمد (۵/۱۴۷،۱۴۸،۱۵۳،۱۵۵،۱۶۹،۱۸۰، سنن الدارمی/الرقاق ۷۲ (۲۸۳۰),3821,,Etiquette
3822,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ قَالَا:‏‏‏‏ حَدَّثَنَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الذکر والدعاء ۱ (۲۶۷۵)، سنن الترمذی/الدعوات ۱۳۲ (۳۶۰۳)،(تحفة الأشراف:۱۲۵۰۵)، وقد أخرجہ: صحیح البخاری/التوحید ۱۵ (۷۴۰۵)، مسند احمد (۲/۲۵۱),3822,,Etiquette
3823,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا أَبُو مُعَاوِيَةَ،‏‏‏‏ وَوَكِيعٌ،‏‏‏‏ عَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الصوم ۲۵ (۱۱۵۱)، سنن الترمذی/الصوم ۵۵ (۷۶۴)، سنن النسائی/الصیام ۲۳ (۲۲۱۶)،(تحفة الأشراف:۱۲۴۷۰،۱۲۵۲۰)، وقد أخرجہ: صحیح البخاری/الصوم ۲ (۱۸۹۴)،۹ (۱۹۰۴)، اللباس ۷۸ (۵۹۲۷)، التوحید ۳۵ (۷۵۰۱)،۵۰ (۷۵۳۷)، صحیح مسلم/الصوم ۳۰ (۱۱۵۱)، موطا امام مالک/الصیام ۲۲ (۵۷)، مسند احمد (۲/۲۳۲،۲۵۲،۲۵۷،۲۶۶،۲۷۳،۲۹۳،۳۵۲،۳۱۳،۴۴۳،۴۴۵،۴۷۵،۴۷۷،۴۸۰،۵۰۱،۵۱۰)، سنن الدارمی/الصوم ۵۰ (۱۸۱۲),3823,,Etiquette
3824,حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ،‏‏‏‏ أَنْبَأَنَا جَرِيرٌ،‏‏‏‏ عَنْ عَاصِمٍ الْأَحْوَلِ،‏‏‏‏ عَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/المغازي ۳۸ (۴۲۰۵)، صحیح مسلم/الذکر والدعاء، والتوبة، و الاستغفار ۱۳ (۲۷۰۴)، سنن ابی داود/الصلاة ۳۶۱ (۱۵۲۶،۱۵۲۷،۱۵۲۸)، سنن الترمذی/الدعوات ۳ (۳۳۷۴)،(تحفة الأشراف:۹۰۱۷)، وقد أخرجہ: مسند احمد (۴/۳۹۴،۳۹۹،۴۰۰،۴۰۲،۴۰۷،۴۱۷،۴۱۸),3824,,Etiquette
3825,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ الْأَعْمَشِ،‏‏‏‏ عَنْ مُجَاهِدٍ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۹۶۵، ومصباح الزجاجة:۱۳۴۱)، وقد أخرجہ: مسند احمد (۵/۱۴۵،۱۵۰،۱۵۲،۱۵۲،۱۵۷،۱۷۹),3825,,Etiquette
3826,حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدٍ الْمَدَنِيُّ،‏‏‏‏ حَدَّثَنَا مُحَمَّدُ بْنُ مَعْنٍ،‏‏‏‏ حَدَّثَنَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih Lighairihi; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۲۸۹، ومصباح الزجاجة:۱۳۴۲)، وقد أخرجہ: مسند احمد (۵/۱۴۵،۱۵۰،۱۵۲),3826,,Etiquette
