{"hadithnumber": "3946", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  قبیلہ بنی فزارہ کے ایک شخص نے نبی اکرم صلی اللہ علیہ وسلم کو اپنے"}
{"hadithnumber": "3947", "text": "ابوعامر اشعری رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”کیا ہی اچھے ہیں قبی"}
{"hadithnumber": "3948", "text": "عبداللہ بن عمر رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”اللہ قبیلہ اسل"}
{"hadithnumber": "3949", "text": "عبداللہ بن عمر رضی الله عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اللہ قبیلہ اس"}
{"hadithnumber": "3950", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”قسم ہے اس ذات کی جس کے ہ"}
{"hadithnumber": "3951", "text": "عمران بن حصین رضی الله عنہ کہتے ہیں کہ  قبیلہ بنی تمیم کے لوگ رسول اللہ صلی اللہ علیہ وسلم کی خدمت م"}
{"hadithnumber": "3952", "text": "ابوبکرہ رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”قبائل اسلم، غفار اور م"}
{"hadithnumber": "3953", "text": "عبداللہ بن عمر رضی الله عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اے اللہ! ہمار"}
{"hadithnumber": "3954", "text": "زید بن ثابت رضی الله عنہ کہتے ہیں کہ  ہم لوگ رسول اللہ صلی اللہ علیہ وسلم کے پاس کاغذ کے پرزوں سے قر"}
{"hadithnumber": "3955", "text": "ابوہریرہ رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”باز آ جائیں وہ قومیں"}
{"hadithnumber": "3956", "text": "ابوہریرہ رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اللہ نے تم سے جاہلیت"}
