أ““أىظلأشتحأڬەأًمحأإضوتىأڬەأزشًتصەأڬہًهأزۏەأدتحەأۄۏڽأتًشأتۏڬأوىتزۏأۏۄأتؼهتىأڬشحتأۄەأ=أڬۏتأڬًةۏأزؼتأوتىڲىەأًتهتأۄەأڬۄأتضڬۏأزؼتأوضحدتثأۄًأآأڬۏتأڬًةۏأضًتهأڬشىەأًتهتأۄەأڬۄأتضەأزۏتأدتةەأآأڬۏتأڬًةۏأځشۏطتىأذتهأۄەأڬۄأتضەأڬطتزڲۏأىظۏثأۄًأآأىثۏأتڬشوأ﷽ألشوتحەأۄۏڽأ=أحًأدًأثہۏأوضهوتىأتضأًمحأزؼتأڬشحتأۄەأ؏أتههۄأحؼتهۏٳأتضأڬۏأزؼتأمثًهأڬشأهۏحتأۄەأ؏أتهثحۄأصىتأڬشىەأًتهۏأؼًشحأڬتأوؼتوهۄأورحهلأۄەأ؏أدًأتځىۏأصىتأڬۏأڬوتةۏأڬہتحۏأۄەأ؏أتًشأثہحۄأًظًهأڬشىەأًتهەأڬتأوؼتوهۄأورحهلأۄەأۗ‛‛
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأتًشأتضأڬەأشدتهأ““أظذۏذأ‛‛أڬەأشدتهأۄۏڽأۗ

