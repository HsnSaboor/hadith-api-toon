{"hadithnumber": "5646", "text": "عبد الرحمٰن بن زید کے آزاد کردہ غلام ثابت نے بتا یا کہ انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "5647", "text": "اسحاق بن عبد اللہ بن ابی طلحہ نے اپنے والد سے روایت کی ،  انھوں نے کہا کہ حضرت ابو طلحہ  رضی اللہ تع"}
{"hadithnumber": "5648", "text": "حفص بن میسرہ نے زید بن اسلم سے ،  انھوں نے عطاء بن یسار سے ،  انھوں نے حضرت ابو سعید خدری رضی اللہ ت"}
{"hadithnumber": "5649", "text": "عبد العزیزبن محمد مدنی اور ہشام بن سعد دونوں نے زید بن اسلم سے اسی سند کے ساتھ روایت کی ۔"}
{"hadithnumber": "5650", "text": "یو نس نے ابن شہاب  ( زہری  )  سے انھوں نے ابن مسیب سے روایت کی کہ حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "5651", "text": "اسماعیل بن جعفر نے اپنے والد سے ، انھوں نے حضرت ابوہریرہ رضی اللہ تعالیٰ عنہ  سے ،  روایت کی ،  کہ ر"}
{"hadithnumber": "5652", "text": "عبید اللہ بن ابی بکر نے اپنے داداحضرت انس بن مالک  رضی اللہ تعالیٰ عنہ  سے روایت کرتے ہو ئے خبر دی ک"}
{"hadithnumber": "5653", "text": "شعبہ نے کہا کہ میں نے قتادہ سے سنا ،  وہ حضرت انس رضی اللہ تعالیٰ عنہ  سے روایت کرتےہو ئے حدیث بیان"}
{"hadithnumber": "5654", "text": "اسماعیل بن جعفر نے عبد اللہ بن دینار سے روایت کی ،  انھوں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے سن"}
{"hadithnumber": "5655", "text": "سفیان نے عبد اللہ بن دینار سے ، انھوں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے ، انھوں نے رسول اللہ"}
{"hadithnumber": "5656", "text": "سفیان بن عیینہ نے ہمیں زہری سے حدیث بیان کی انھوں نے عروہ سے ،  انھوں نے حضرت عائشہ  رضی اللہ تعالیٰ"}
{"hadithnumber": "5657", "text": "صالح اور معمر دونوں نے زہری سے اسی سند کے ساتھ حدیث بیان کی  ، دونوں کی حدیث میں ہے کہ رسول اللہ  صل"}
{"hadithnumber": "5658", "text": "ابو معاویہ نے اعمش سے  ، انھوں نے مسلم سے انھوں نے مسروق سے ، انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عن"}
{"hadithnumber": "5659", "text": "یعلیٰ بن عبید نے ہمیں خبر دی کہا :  ہمیں اعمش نے اسی سند کے ساتھ حدیث بیان کی ،  مگر انھوں نے کہا  :"}
{"hadithnumber": "5660", "text": "ابوزبیر نے کہا :  انھوں نے حضرت جابر بن عبد اللہ رضی اللہ تعالیٰ عنہ  کو کہتے ہوئے سنا  :  یہود میں"}
{"hadithnumber": "5661", "text": "عبد العزیز دراوردی نے سہیل سے ، انھوں نے اپنے والد سے ، انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "5662", "text": "محمد بن مثنیٰ نے کہا  :  ہمیں محمد بن جعفر نے حدیث بیان کی ،  کہا :  ہمیں شعبہ نے حدیث بیان کی  ۔ اب"}
{"hadithnumber": "5663", "text": "۔  یحییٰ بن یحییٰ نے کہا  : ہمیں ہشیم نے سیارے سے  خبر دی  ، انھوں نے ثابت بنا نی سے  ، انھوں نے حضر"}
{"hadithnumber": "5664", "text": "اسماعیل بن سالم نے کہا  : ہمیں ہشیم نے خبر دی کہا  :  ہمیں سیار نے اسی سند کے ساتھ خبر دی ۔"}
{"hadithnumber": "5665", "text": "شعبہ نے سیار سے روایت کی ،  کہا  :  میں ثابت بنانی کے ساتھ جا رہا تھا وہ کچھ بچوں کے پاس سے گزرے تو"}
{"hadithnumber": "5666", "text": "عبد الوحد بن زیاد نے کہا  :  ہمیں حسن بن عبید اللہ نے حدیث بیان کی ۔ کہا  :  ہمیں ابرا ہیم بن سوید ن"}
{"hadithnumber": "5667", "text": "عبد اللہ بن ادریس نے حسن بن عبد اللہ سے اسی سند کے ساتھ اسی کے مانند روایت کی ۔"}
{"hadithnumber": "5668", "text": "ابو بکر بن ابی شیبہ اور ابو کریب نے کہا  :  ہمیں ابو اسامہ نے ہشام سے حدیث بیان کی  ، انھوں نے اپنے"}
{"hadithnumber": "5671", "text": "عقیل بن خالد نے ابن شہاب سے  ، انھوں نے عروہ بن زبیر سے ، انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عنہا"}
{"hadithnumber": "5672", "text": "صالح نے ابن شہاب سے اسی سند کے ساتھ اسی کے مانند روایت کی ۔"}
{"hadithnumber": "5673", "text": "ابو زبیر نے حضرت جابر رضی اللہ تعالیٰ عنہ  سے خبر دی ، کہا : رسول اللہ  صلی اللہ علیہ وسلم  نے فرمای"}
{"hadithnumber": "5674", "text": "قتیبہ بن سعید اور محمد بن رمح نے کہا : ہمیں لیث نے یزید بن ابی حبیب سے خبر دی ، انھوں نے ابو الخیر س"}
{"hadithnumber": "5675", "text": "عبداللہ بن وہب نے عمرو بن حارث ، لیث بن سعد اور حیوہ بن شریح وغیرہ سے روایت کی کہ یزید بن ابی حبیب ن"}
{"hadithnumber": "5676", "text": "ابن وہب نے کہا : میں نے لیث بن سعد سے سنا ، کہہ رہے تھے  : حمو ( دیور/جیٹھ )  خاوند کابھائی ہے یا خا"}
{"hadithnumber": "5677", "text": "عبدالرحمان بن جبیر نے کہا کہ حضرت عبداللہ بن عمرو بن عاص  رضی اللہ تعالیٰ عنہ  نے انھیں حدیث سنائی ک"}
{"hadithnumber": "5678", "text": "ثابت بنانی نے حضرت انس رضی اللہ تعالیٰ عنہ  سے روایت کی کہ نبی کریم صلی اللہ علیہ وسلم   ( گھرسے باہ"}
{"hadithnumber": "5679", "text": "معمر نے زہری سے  ، انھوں نے علی بن حسین رضی اللہ تعالیٰ عنہ  سے ، انھوں نے حضرت صفیہ بنت حی ( ام الو"}
{"hadithnumber": "5680", "text": "شعیب نے زہری سے روایت کی  ، کہا : مجھے علی بن حسین نے بتایا کہ انھیں نبی کریم  صلی اللہ علیہ وسلم کی"}
{"hadithnumber": "5681", "text": "امام مالک بن انس نے اسحاق بن عبداللہ بن ابی طلحہ سےروایت کی کہ عقیل بن ابی طالب کے آذاد کردہ غلام اب"}
{"hadithnumber": "5682", "text": "یحییٰ بن ابی کثیر نے کہا کہ اسحٰق بن عبد اللہ بن ابی طلحہ نے انھیں اسی سند سے اسی کے ہم معنی حدیث بی"}
{"hadithnumber": "5683", "text": "لیث نے نا فع سے انھوں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے اور انھوں نے نبی  صلی اللہ علیہ وسلم"}
{"hadithnumber": "5684", "text": "عبید اللہ نے نا فع سے حدیث بیان کی انھوں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے انھوں نے نبی  صلی ا"}
{"hadithnumber": "5685", "text": "ابو ربیع اور الکامل نے کہا  :  ہمیں حماد نے حدیث بیان کی کہا  :  ہمیں ایوب نے حدیث سنائی  ۔  یحییٰ ب"}
{"hadithnumber": "5686", "text": "عبد الا علیٰ نے معمر سے ، انھوں نے زہری سے ، انھوں نے سالم سے ، انھوں نے حضرت ابن عمر رضی اللہ تعالی"}
{"hadithnumber": "5687", "text": "عبد الرزاق نے کہا  : معمر نے ہمیں اسی سند کے ساتھ اسی کے مانند خبر دی ۔"}
{"hadithnumber": "5688", "text": "ابو زبیر نے حضرت جا بر  رضی اللہ تعالیٰ عنہ سے اور انھوں نے نبی  صلی اللہ علیہ وسلم  سے روایت کی کہ"}
{"hadithnumber": "5689", "text": "ابو عوانہ اور عبد العزیز بن محمد دونوں نے سہیل سے ، انھوں نے اپنے والد سے ، انھوں نے حضرت ابو ہریرہ"}
{"hadithnumber": "5690", "text": "زینب بنت ام سلمہ رضی اللہ تعالیٰ عنہا   نے ام المومنین ام سلمہ  رضی اللہ تعالیٰ عنہا   سے روایت کی ک"}
{"hadithnumber": "5691", "text": "عروہ نے حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے روایت کی ،  کہا  :  رسول اللہ  صلی اللہ علیہ وسلم  کی"}
{"hadithnumber": "5692", "text": "ہشام کے والد  ( عروہ  )  نے حضرت اسماء بنت ابی بکر رضی اللہ تعالیٰ عنہا   سے روایت کی ،  انھوں نے  ("}
{"hadithnumber": "5693", "text": "ابن ابی ملیکہ نے کہا کہ حضرت اسماء رضی اللہ تعالیٰ عنہا   نے بیان کیا کہ میں گھر کی خدمات سر انجام د"}
{"hadithnumber": "5694", "text": "مالک نےنافع سے ، انھوں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے  روایت کی کہ رسول اللہ  صلی اللہ علیہ"}
{"hadithnumber": "5695", "text": "عبیداللہ ، لیث بن اسعد ، ایوب ( سختیانی )  اور ایوب بن موسیٰ ان سب نے نافع سے ، انھوں نے حضرت ابن عم"}
{"hadithnumber": "5696", "text": "منصور نے ابو وائل  ( شقیق )  سے  ، انھوں نے عبداللہ (  بن مسعود رضی اللہ تعالیٰ عنہ  )  سے  روایت کی"}
{"hadithnumber": "5697", "text": "ابو معاویہ نے اعمش سے ، انھوں نے شقیق سے  ، انھوں نے حضرت عبداللہ ( بن مسعود رضی اللہ تعالیٰ عنہ  )"}
{"hadithnumber": "5698", "text": "عیسیٰ بن یونس اورسفیان دونوں نے اعمش سے اسی سند کے ساتھ ( حدیث بیان کی ۔  )"}
{"hadithnumber": "5699", "text": "نبی اکرم صلی اللہ علیہ وسلم  کی اہلیہ حضرت  عائشہ صدیقہ رضی اللہ تعالیٰ عنہا   سے روایت ہے ، انھوں ن"}
{"hadithnumber": "5700", "text": "ابونضرہ نے حضرت ابوسعید رضی اللہ تعالیٰ عنہ  سے روایت کی کہ جبرائیل علیہ السلام  نبی کریم صلی اللہ ع"}
{"hadithnumber": "5701", "text": "ہمام بن منبہ نے کہا : یہ احادیث جو ہمیں حضرت ابوہریرہ رضی اللہ تعالیٰ عنہ  نے نبی کریم صلی اللہ علیہ"}
{"hadithnumber": "5702", "text": "حضرت ابن عباس رضی اللہ تعالیٰ عنہ  نے نبی کریم صلی اللہ علیہ وسلم  سے روایت کی کہ آ پ نے فرمایا :  "}
{"hadithnumber": "5703", "text": "ابن نمیر نے ہشام سے  ، انھوں نے اپنے والد سے ، انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے روایت ک"}
{"hadithnumber": "5704", "text": "ابو کریب نے کہا : ہمیں ابو اسامہ نے حدیث بیان کی ، کہا ، ہمیں ہشام نے اپنے والد سے حدیث بیا ن کی ، ا"}
{"hadithnumber": "5705", "text": "خالد بن حارث نے کہا : ہمیں شعبہ نے ہشام بن زید سے حدیث بیان کی ، انھوں نے حضرت انس رضی اللہ تعالیٰ ع"}
{"hadithnumber": "5706", "text": "روح بن عبادہ نےکہا : ہمیں شعبہ نے حدیث بیان کی ، کہا : میں نے ہشام بن زید سے سنا ، انھوں نےکہا : میں"}
{"hadithnumber": "5707", "text": "جریر نے اعمش سے  ، انھوں نے ابوضحیٰ سے ، انھوں نے مسروق سے ، انھوں نے حضرت عائشہ  رضی اللہ تعالیٰ عن"}
{"hadithnumber": "5708", "text": "یحییٰ بن یحییٰ نے کہا : ہمیں ہشیم نے خبر دی ، ابو بکر بن خلاد اور بو کریب نے کہا : ہمیں ابو معاویہ ن"}
{"hadithnumber": "5709", "text": "ابوعوانہ نے منصور سے ، انھوں نےابراہیم سے ، انھوں نے مسروق سے ، انھوں نے حضرت عائشہ  رضی اللہ تعالیٰ"}
{"hadithnumber": "5710", "text": "ابو بکر بن ابی شیبہ اور زہیر بن حرب نے کہا : ہمیں جریر نے منصور سے حدیث بیان کی ، انھوں نے ابو ضحیٰ"}
{"hadithnumber": "5711", "text": "اسرائیل نےمنصور سے ، انھوں نے ابراہیم اور مسلم بن صبیح سے ، انھوں نے مسروق سے ، انھوں نے حضرت عائشہ"}
{"hadithnumber": "5712", "text": "ابن نمیر نے کہا : ہمیں ہشام نے اپنے والد سے حدیث بیان کی ، انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عنہا"}
{"hadithnumber": "5713", "text": "ابواسامہ اور عیسیٰ بن یونس دونوں نے ہشام سے اسی سند کےساتھ اسی کے مانند روایت کی ۔"}
{"hadithnumber": "5714", "text": "سریج بن یونس اور یحییٰ بن ایوب نے کہا : ہمیں عباد بن عبادنے ہشام بن عروہ سے حدیث بیان کی ، انھوں نے"}
{"hadithnumber": "5715", "text": "مالک نے ابن شہاب سے ،  انھوں نے عروہ سے ، انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے روایت کی ،"}
{"hadithnumber": "5716", "text": "یو نس معمر اور زیاد سب نے ابن شہاب سے ،  امام مالک کی سند کے ساتھ ان کی حدیث کی طرح حدیث بیان کی ،"}
{"hadithnumber": "5717", "text": "عبد الرحمٰن بن اسود نے اپنے والد سے روایت کی ،  انھوں نے کہا  :  میں نے حضرت عائشہ رضی اللہ تعالیٰ ع"}
{"hadithnumber": "5718", "text": "ابرا ہیم نے سود سے  ، انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے روایت کی ، کہا :  نبی  صلی اللہ"}
{"hadithnumber": "5719", "text": "ابو بکر بن ابی شیبہ زہیر بن حرب اور ابن ابی عمرنے  ۔ الفاظ ابن ابی عمر کے ہیں  ۔ کہا :  ہمیں سفیان ن"}
{"hadithnumber": "5720", "text": "محمد بن بشر نے مسعر سے روایت کی ،  کہا  :  ہمیں معبد بن خالد نے ابن شداد سے حدیث بیان کی  ، انھوں نے"}
{"hadithnumber": "5721", "text": "عبید اللہ بن نمیر نے کہا  :  ہمیں مسعر نے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی ۔"}
{"hadithnumber": "5722", "text": "سفیان نے معبد بن خالد سے  ، انھوں نے  عبد اللہ  بن شداد سے ، انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "5723", "text": "ابو خیثمہ نے عاصم احول سے ،  انھوں نے یو سف بن عبد اللہ سے ، انھوں نے حضرت انس بن مالک  رضی اللہ تعا"}
{"hadithnumber": "5724", "text": "سفیان اور حسن بن صالح دونوں نے عاصم انھوں نے یوسف بن عبد اللہ سے ، انھوں نے حضرت انس  رضی اللہ تعالی"}
{"hadithnumber": "5725", "text": "زینب  بنت ام سلمہ رضی اللہ تعالیٰ عنہا   نے ام المومنین حضرت ام سلمہ رضی اللہ تعالیٰ عنہا   سے روایت"}
{"hadithnumber": "5726", "text": "ابوعاصم نے ابن جریج سے روایت کی ، کہا  : مجھے ابو زبیر نے بتا یا کہ انھوں نے حضرت جا بر بن عبد اللہ"}
{"hadithnumber": "5727", "text": "روح بن عبادہ نے کہا  :  ہمیں ابن جریج  نے حدیث بیان کی ،  کہا  :  مجھے ابو زبیر نے بتا یا کہ انھوں ن"}
{"hadithnumber": "5728", "text": "سعید بن یحییٰ اموی کے والد نے کہا  :  ہمیں ابن جریج نے اسی سند کے ساتھ اسی کی مثل روایت بیان کی مگر"}
{"hadithnumber": "5729", "text": "وکیع نے اعمش سے ،  انھوں نے ابو سفیان سے ، انھوں نے حضرت جا بر  رضی اللہ تعالیٰ عنہ سے روایت کی ،  ک"}
{"hadithnumber": "5730", "text": "جریر نے اعمش سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی ۔"}
{"hadithnumber": "5731", "text": "ابو معاویہ نے اعمش سے ، انھوں نے سفیان سے ،  انھوں نے حضرت جا بر رضی اللہ تعالیٰ عنہ  سے روایت کی کہ"}
{"hadithnumber": "5732", "text": "حضرت عوف بن مالک اشجعی  رضی اللہ تعالیٰ عنہ  سے روایت ہے ، کہا  :  ہم زمانہ جاہلیت میں دم کیا کرتے ت"}
{"hadithnumber": "5733", "text": "ہشیم نے ابو بشر سے ، انھوں نے ابو متوکل  سے ،  انھوں نے حضرت ابو سعید خدری رضی اللہ تعالیٰ عنہ  سے ر"}
{"hadithnumber": "5734", "text": "شعبہ نے ابو بشر سے اسی سند کے ساتھ روایت کی ،  اور حدیث  میں یہ کہا :  اس نے ام القرآن ( سورۃفاتحہ )"}
{"hadithnumber": "5735", "text": "یزید بن ہارون نے کہا : ہمیں ہشام بن حسان نے محمد بن سیرین سےخبر دی ، انھوں نے ا پنے بھائی معبد بن سی"}
{"hadithnumber": "5736", "text": "ہمیں ہشام نے اسی سند کے ساتھ ، اسی طرح حدیث بیان کی ، مگر اس نے کہا : ہم میں سے ایک آدمی اس کے ساتھ"}
{"hadithnumber": "5737", "text": "سیدنا عثمان بن ابی العاص ثقفی رضی اللہ عنہ سے روایت ہے کہ انہوں نے رسول اللہ صلی اللہ علیہ وسلم سے ا"}
{"hadithnumber": "5738", "text": "عبدالاعلیٰ نے سعید جریری سے  ، انھوں نے ابو علاء سے روایت کی کہ سیدنا عثمان بن ابوالعاص رضی اللہ عنہ"}
{"hadithnumber": "5739", "text": "سالم بن نوح اور ابو اسامہ  ، دونوں نےجریری سے  ، انھوں  نے ابو علااء سے  ، انھوں نے عثمان بن ابی الع"}
{"hadithnumber": "5740", "text": "سفیان نے سعید جریری سے روایت کی ، کہا : ہمیں یزید بن عبداللہ بن شخیر نے حدیث بیان کی ، انھوں نے حضرت"}
{"hadithnumber": "5741", "text": "حضرت جابر رضی اللہ تعالیٰ عنہ  نے رسول اللہ  صلی اللہ علیہ وسلم  سے  روایت کی کہ آپ  صلی اللہ علیہ و"}
{"hadithnumber": "5742", "text": "بکیر نے کہا کہ عاصم بن عمر بن قتادہ نے انھیں حدیث  سنائی کہ حضرت جابر بن عبداللہ  رضی اللہ تعالیٰ عن"}
{"hadithnumber": "5743", "text": "عبدالرحمان بن سلیمان نے حضرت عاصم بن عمر بن قتادہ سے  روایت کی  ، کہا :  کہ سیدنا جابر بن عبداللہ رض"}
{"hadithnumber": "5744", "text": "حضرت جابر رضی اللہ تعالیٰ عنہ  سے  روایت کی کہ حضرت ام سلمہ رضی اللہ تعالیٰ عنہ  نے رسول اللہ  صلی ا"}
{"hadithnumber": "5745", "text": "ابومعاویہ نے اعمش سے ، انھوں نے ابو سفیان سے  ، انھوں نے حضرت جابر رضی اللہ تعالیٰ عنہ  سے روایت کی"}
{"hadithnumber": "5746", "text": "جریر اور سفیان دونوں نے اعمش سے اسی سند کے ساتھ بیان کیا اور \" تو ان کی رگ کاٹی \" کے الفاظ بیان نہیں"}
{"hadithnumber": "5747", "text": "سلیمان نے کہا : میں نے ابو سفیان کو سنا ، انھوں نے کہا : میں نے حضرت جابر بن عبداللہ رضی اللہ تعالیٰ"}
{"hadithnumber": "5748", "text": "ابو زبیر نے حضرت جابر رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا : حضرت سعد بن معاذ  رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "5749", "text": "حضرت ابن عباس  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ رسول اللہ  صلی اللہ علیہ وسلم  نے پچھنے لگوانے او"}
{"hadithnumber": "5750", "text": "عمر و بن عامر انصاری نے کہا : میں نے حضرت انس بن مالک رضی اللہ تعالیٰ عنہ  سے سنا ، آپ کہہ رہے تھے ۔"}
{"hadithnumber": "5751", "text": "یحییٰ بن سعید نے عبیداللہ سے روایت کی ، کہا : مجھے نافع نے حضرت  ابن عمر رضی اللہ تعالیٰ عنہ  سے خبر"}
{"hadithnumber": "5752", "text": "عبداللہ بن نمیر اور محمد بن بشر نے کہا : ہمیں عبیداللہ نے نافع سے حدیث بیان کی ، انھوں نے حضرت ابن ع"}
{"hadithnumber": "5753", "text": "امام مالک اورضحاک بن عثمان  ، دونوں نے نافع سے ، انھوں نے حضرت ابن عمر  رضی اللہ تعالیٰ عنہ  سے روای"}
{"hadithnumber": "5754", "text": "محمد بن زید نے  حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے روایت کی کہ رسول اللہ  صلی اللہ علیہ وسلم  نے ف"}
{"hadithnumber": "5755", "text": "ابن نمیر نے ہشام سے ، انھوں نے اپنے والد سے ، انھوں نے حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے روایت ک"}
{"hadithnumber": "5756", "text": "خالد بن حارث اور عبدہ بن سلیمان نے ہشام سے اسی سند کے ساتھ اسی کے مانند روایت کی ۔"}
{"hadithnumber": "5757", "text": "عبدہ بن سلیمان نے ہشام سے ، انھوں نے فاطمہ سے ، انھوں نے حضرت اسماء رضی اللہ تعالیٰ عنہا   سے روایت"}
{"hadithnumber": "5758", "text": "ابن نمیر اور ابو  اسامہ نے ہشام سے اسی سند کے ساتھ حدیث بیان کی اور ابن نمیر کی حدیث  میں ہے :  وہ ا"}
{"hadithnumber": "5759", "text": "سعید بن مسروق نے عبایہ بن رفاعہ سے ، انھوں نے اپنے دادا سے  ، انھوں نےحضرت رافع بن خدیج رضی اللہ تعا"}
{"hadithnumber": "5760", "text": "ابو بکر بن ابی شیبہ  ، محمد بن مثنیٰ  ، محمد بن حاتم اور ابو بکر بن نافع نے کہا : ہمیں عبدالرحمان بن"}
{"hadithnumber": "5761", "text": "حضرت عائشہ رضی اللہ تعالیٰ عنہ سے روایت ہے  ، انھوں نے کہا : نبی کریم صلی اللہ علیہ وسلم  کےمرض میں"}
{"hadithnumber": "5763", "text": "انھوں نے  ( ام قیس رضی اللہ تعالیٰ عنہا   )  نے کہا  :  میں اپنے ایک بچے کو لے کر آپ  صلی اللہ علیہ"}
{"hadithnumber": "5765", "text": "عبید اللہ نے کہا  :  انھوں  ( ام قیس  رضی اللہ تعالیٰ عنہا    )  نے مجھ سے بیان کیا کہ ان کے اسی بچے"}
{"hadithnumber": "5766", "text": "عقیل نے ابن شہاب سے روایت کی ،  کہا  : مجھے ابو سلمہ بن عبد الرحمٰن اور سعید بن مسیب نے بتا یا کہ حض"}
{"hadithnumber": "5767", "text": "یو نس نے ابن شہاب سے ، انھوں نے سعید بن مسیب سے ، انھوں نے ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے اور انھ"}
{"hadithnumber": "5768", "text": "اعلاء  ( بن الرحمٰن  )  کے والد نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی ،  رسول اللہ  صلی"}
{"hadithnumber": "5769", "text": "عروہ رسول اللہ  صلی اللہ علیہ وسلم  کی اہلیہ حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے روایت کی کہ جب ان"}
{"hadithnumber": "5770", "text": "شعبہ نے قتادہ سے ،  انھوں نے ابو متوکل سے ، انھوں نے حضرت ابو سعید خدری رضی اللہ تعالیٰ عنہ  سے روای"}
{"hadithnumber": "5771", "text": "سعید نے قتادہ سے انھوں نے ابو متوکل ناجی سے ،  انھوں نے حضرت ابو سعید خدری رضی اللہ تعالیٰ عنہ سے رو"}
{"hadithnumber": "5772", "text": "امام مالک نے محمد بن منکدر اور عمربن عبید اللہ کے آزاد کردہ غلام ابو نضر سے ، انھوں نے عامر بن  ( سع"}
{"hadithnumber": "5773", "text": "عبداللہ بن مسلمہ بن قعنب اورقتیبہ بن سعید نے کہا : ہمیں مغیرہ بن عبدالرحمان قرشی نے ابو نضرسے حدیث ب"}
{"hadithnumber": "5774", "text": "سفیان نے محمد بن منکدرسے ، انھوں نے عامر بن سعد سے ، انھوں نے اسامہ  رضی اللہ تعالیٰ عنہ  سے روایت ک"}
{"hadithnumber": "5775", "text": "ابن جریج نے کہا :  مجھے عمرو بن دینار نے بتایا کہ عامر بن سعد نے انھیں خبر دی کہ کسی شخص نے حضرت سعد"}
{"hadithnumber": "5776", "text": "حماد بن زید اور سفیان بن عینیہ دونوں نے عمرو بن دینار سے ابن جریج کی سند کے ساتھ اسی کی حدیث کےمانند"}
{"hadithnumber": "5777", "text": "یونس نے ابن شہاب سے  ، انھوں نے عامر بن سعد سے خبر دی ، انھوں نے حضرت اسامہ بن زید رضی اللہ تعالیٰ ع"}
{"hadithnumber": "5778", "text": "معمر نے زہری سے یونس کی سند کے ساتھ اسی  ( یونس )  کی حدیث کے مانند حدیث بیان کی ۔"}
{"hadithnumber": "5779", "text": "ابن ابی عدی نے شعبہ سے انھوں نے حبیب  ( بن ابی ثابت اسدی )  سے روایت کی ،  کہا  :  ہم مدینہ میں تھے"}
{"hadithnumber": "5780", "text": "عبید اللہ بن معاذ کے والد نے کہا  :  ہمیں شعبہ نے اسی سند کے ساتھ یہ حدیث سنا ئی مگر انھوں نے حدیث ک"}
{"hadithnumber": "5781", "text": "سفیان نے حبیب سے ،  انھوں نے ابرا ہیم بن سعد سے ، انھوں نے حضرت سعد بن مالک  ، حضرت حزیمہ بن ثابت او"}
{"hadithnumber": "5782", "text": "اعمش  نے حبیب سے ، انھوں نے ابرا ہیم بن سعد بن ابی وقاص سے روایت کی ،  کہا  :  حضرت اسامہ بن زید رضی"}
{"hadithnumber": "5783", "text": "شیبانی نے حبیب بن ابی  ثابت سے ، انھوں نے ابرا ہیم بن سعد بن مالک سے ، انھوں نے اپنے والد سے ، انھوں"}
{"hadithnumber": "5784", "text": "امام مالک نے ابن شہاب سے  ، انھوں نے عبدالحمید بن عبدالرحمان بن زید بن خطاب سے  ، انھوں نے عبداللہ ب"}
{"hadithnumber": "5785", "text": "معمر نے ہمیں اسی سند کے ساتھ مالک کی حدیث کی طرح حدیث بیان کی اور معمر کی حدیث میں یہ الفاظ زائد بیا"}
{"hadithnumber": "5786", "text": "یونس نے اسی سند کے ساتھ ابن شہاب سے خبر دی ، مگر انھوں نے کہا : بلاشبہ عبداللہ بن حارث نے انھیں حدیث"}
{"hadithnumber": "5787", "text": "امام مالک نے ابن شہاب سے ، انھوں  نے عبد اللہ بن عامر  بن ربیعہ سے  ، روایت کی کہ حضرت عمر رضی اللہ"}
{"hadithnumber": "5788", "text": "یونس نے کہا  :  ابن شہاب نے کہا  :  مجھے ابو سلمہ بن عبد الرحمٰن نے حضرت ابو ہریرہ رضی اللہ تعالیٰ ع"}
{"hadithnumber": "5789", "text": "صالح نے ابن شہاب سے روایت کی  ، کہا  : مجھے ابو سلمہ بن عبدالرحمٰن وغیرہ نے بتا یا کہ حضرت ابو ہریرہ"}
{"hadithnumber": "5790", "text": "شعیب نے زہری سے روایت کی  ، کہا  :  مجھے سنان بن ابی سنان دؤلی نے بتایا کہ حضرت ابو ہریرہ رضی اللہ ت"}
{"hadithnumber": "5791", "text": "یو نس نے ابن شہاب سے روایت کی  ، کہ  ابوسلمہ بن عبد الرحمٰن بن عوف  رضی اللہ تعالیٰ عنہ  نے انھیں حد"}
{"hadithnumber": "5792", "text": "صالح نے ابن شہاب سے روایت کی  ، کہا  : مجھے ابو سلمہ بن عبدالرحمٰن نے بتایا :  انھوں نے حضرت ابو ہری"}
{"hadithnumber": "5793", "text": "شعیب نے زہری سے اسی سند کے ساتھ اسی کے مانند روایت کی ۔"}
{"hadithnumber": "5794", "text": "علاء کے والد  ( عبد الرحمٰن  ) نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ سے روایت کی کہ رسول اللہ  صلی ا"}
{"hadithnumber": "5795", "text": "ابو خیثمہ  ( زہیر )  نے ابو زبیر سے ، انھوں نے حضرت جابر رضی اللہ تعالیٰ عنہ  سے روایت کی کہا :  رسو"}
{"hadithnumber": "5796", "text": "یزید تستری نے کہا  :  ہمیں ابو زبیر نے حضرت جا بر  رضی اللہ تعالیٰ عنہ سے روایت کی کہا  :  رسول اللہ"}
{"hadithnumber": "5797", "text": "ابن جریج نے کہا  :  مجھے ابو زبیر نے بتا یا کہ انھوں نے جابر بن عبد اللہ  رضی اللہ تعالیٰ عنہ  کو کہ"}
{"hadithnumber": "5798", "text": "معمر نے زہری سے ، انھوں نے عبید اللہ بن عبد اللہ بن عتبہ سے روایت کی کہ حضرت ابو ہریرہ رضی اللہ تعال"}
{"hadithnumber": "5799", "text": "عقیل بن خالد اور شعیب دونوں نے زہری سے اسی سند کے ساتھ اسی کے مانند روایت کی ۔ عقیل کی حدیث میں ہے ک"}
{"hadithnumber": "5800", "text": "ہمام بن یحییٰ نے کہا  :  ہمیں قتادہ نے حضرت انس رضی اللہ تعالیٰ عنہ سے  حدیث بیان کی کہ نبی  صلی الل"}
{"hadithnumber": "5801", "text": "شعبہ نے کہا  : میں قتادہ سے سنا ، وہ حضرت انس بن مالک  رضی اللہ تعالیٰ عنہ  سے حدیث روایت کر رہے تھے"}
{"hadithnumber": "5802", "text": "یحییٰ بن عتیق نے کہا  : ہمیں محمد بن سیرین  نے حضرت ابوہریرہ رضی اللہ تعالیٰ عنہ  سے حدیث بیان کی ،"}
{"hadithnumber": "5803", "text": "ہشام بن حسان نے محمد بن سیرین سے انھوں نے ابوہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہا :  رسول ا"}
{"hadithnumber": "5804", "text": "امام مالک نے ابن شہاب سے ، انھوں نے عبد اللہ بن عمر رضی اللہ تعالیٰ عنہ کے دو بیٹوں حمزہ اور سالم سے"}
{"hadithnumber": "5805", "text": "یو نس نے ابن شہاب سے ، انھوں نے بن عمر رضی اللہ تعالیٰ عنہ  کے دوبیٹوں حمزہ اور سالم سے ، انھوں نے ح"}
{"hadithnumber": "5806", "text": "سفیان ،  صالح ،  عقیل ،  بن خا لد  ، عبد الرحمٰن بن اسحٰق اور شعیب  ، ان سب نے زہری سے ،  انھوں نے س"}
{"hadithnumber": "5807", "text": "محمد بن جعفر نے کہا  :  ہمیں شعبہ نے عمر بن محمد بن یزید سے حدیث بیان کی انھوں نے اپنے والد سے سنا ،"}
{"hadithnumber": "5808", "text": "روح بن عبادہ نے کہا  :  شعبہ نے ہمیں اسی سند کے ساتھ اسی کے مانند حدیث سنائی لیکن انوھں نے  \" برحق "}
{"hadithnumber": "5809", "text": "حمزہ بن عبد اللہ بن عمر نے اپنے والد  ( حضرت عبد اللہ بن عمر رضی اللہ تعالیٰ عنہ   ) سے روایت کی کہ"}
{"hadithnumber": "5810", "text": "امام مالک نے ابو حازم سے ،  انھوں نے حضرت سہل بن سعد  رضی اللہ تعالیٰ عنہ  سے روایت کی  ، کہا  :  نب"}
{"hadithnumber": "5811", "text": "ہشام بن سعد نے ابو حازم سے ، انھوں نے حضرت سہل بن سعد  رضی اللہ تعالیٰ عنہ  سے ،  انھوں نے  نبی  صلی"}
{"hadithnumber": "5812", "text": "ابن جریج نے کہا  :  مجھے ابو زبیر نے بتا یا کہ انھوں نے حضرت جابر رضی اللہ تعالیٰ عنہ  سے سنا ، وہ ر"}
{"hadithnumber": "5813", "text": "یو نس نے ابن شہاب سے  ، انھوں نے ابو سلمہ بن عبد الرحمٰن بن عوف سے ،  انھوں نے حضرت معاویہ بن حکم سل"}
{"hadithnumber": "5814", "text": "عقیل معمر  ، ابن ابی ذئب اور مالک ،  ان سب نے زہری سے اسی سند کے ساتھ یو نس کی حدیث کے ہم معنی روایت"}
{"hadithnumber": "5815", "text": "حجاج صواف اور اوزاعی  ، دونوں نے یحییٰ بن ابی کثیر سے ، انھوں نے ہلال بن ابی میمونہ سے ،  انھوں نے ع"}
{"hadithnumber": "5816", "text": "معمر نے زہر ی سے ،  انھوں نے یحییٰ بن عروہ بن زبیر سے ،  انھوں نے اپنے والد سے ،  انھوں نے حضرت عائش"}
{"hadithnumber": "5817", "text": "معقل بن عبید اللہ نے زہری سے روایت کی ، کہا  :  مجھے یحییٰ بن عروہ نے بتا یا کہ انھوں نے عروہ سے سنا"}
{"hadithnumber": "5818", "text": "ابن جریج نے ابن شہاب سے اسی سند کے ساتھ معقل کی زہری سے روایت کردہ حدیث کے مانند روایت کی ۔"}
{"hadithnumber": "5819", "text": "صالح نے ابن شہا ب سے ،  روایت کی :  کہا مجھے علی بن حسین  ( زین العابدین  )  نے حدیث سنا ئی کہ حضرت"}
{"hadithnumber": "5820", "text": "اوزاعی  ، یونس اور معقل بن عبید اللہ سب نے زہری سے ،  اسی سند کے ساتھ حدیث بیان کی  ، مگر یونس نے کہ"}
{"hadithnumber": "5821", "text": "۔  ( حضرت عبد اللہ بن عمر رضی اللہ تعالیٰ عنہ  کی اہلیہ )  صفیہ نے نبی  صلی اللہ علیہ وسلم  کی ایک ا"}
{"hadithnumber": "5822", "text": "عمرو بن شرید نے اپنے والد سے روایت کی  ، کہا  :  ثقیف کے وفد میں کو ڑھ کا یک مریض بھی تھا رسول اللہ"}
{"hadithnumber": "5823", "text": "عبد ہ بن سلیمان اور ابن نمیر نے ہشام سے ، انھوں نے اپنے والد سے ، انھوں نے حضرت عائشہ رضی اللہ تعالی"}
{"hadithnumber": "5824", "text": "ابو معاویہ نے کہا  :  ہمیں ہشام نے اس سند کے ساتھ حدیث سنا ئی اور کہا  :  بے دم کا سانپ اور پشت پر د"}
{"hadithnumber": "5825", "text": "سفیان بن عیینہ نے زہری سے ،  انھوں نے سالم سے ، انھوں نے اپنے والد  ( حضرت ابن عمر رضی اللہ تعالیٰ ع"}
{"hadithnumber": "5828", "text": "لیث  ( بن سعد )  نے نافع سے روایت کی کہ حضرت ابو لبابہ  رضی اللہ تعالیٰ عنہ  نے حضرت ابن عمر رضی الل"}
{"hadithnumber": "5829", "text": "جریر بن حازم نے کہا  :  ہمیں نافع نے حدیث سنا ئی کہا  :  حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سانپوں کو"}
{"hadithnumber": "5830", "text": "عبید اللہ نے کہا  :  مجھے نافع نے بتا یا کہ انھوں نے حضرت ابولبابہ رضی اللہ تعالیٰ عنہ  سے سنا  ، وہ"}
{"hadithnumber": "5831", "text": "نافع سے روایت ہے کہ انھوں نے حضرت عبد اللہ بن عمر رضی اللہ تعالیٰ عنہ  سے بیان کیا کہ حضرت ابو لبابہ"}
{"hadithnumber": "5832", "text": "یحییٰ بن سعید کہہ رہے تھے  :  مجھے نافع نے خبر دی کہ حضرت ابولبابہ بن عبدا لمنذرانصاری رضی اللہ تعال"}
{"hadithnumber": "5833", "text": "عمر بن نافع نے اپنے والد سے روایت کی ،  کہا : ایک دن حضرت عبد اللہ بن عمر رضی اللہ تعالیٰ عنہ  اپنے"}
{"hadithnumber": "5834", "text": "اسامہ کو نافع نے حدیث سنا ئی کہ حضرت ابو لبابہ رضی اللہ تعالیٰ عنہ حضرت ابن عمر رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "5835", "text": "ابو معاویہ نے اعمش سے ،  انھوں نے ابرا ہیم سے  ، انھوں نے اسود سے ،  انھوں نے حضرت عبد اللہ بن مسعود"}
{"hadithnumber": "5836", "text": "جریر اعمش سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی ۔"}
{"hadithnumber": "5837", "text": "ابو کریب نے کہا  :  ہمیں حفص نے حدیث بیان کی ،  انھوں نے کہا  :  ہمیں اعمش نے ابرا ہم سے حدیث بیان ک"}
{"hadithnumber": "5838", "text": "عمر بن حفص بن غیاث نے کہا  :  ہمیں میرے والد نے حدیث بیان کی ، کہا  :  ہمیں اعمش نے حدیث سنائی  ، کہ"}
{"hadithnumber": "5839", "text": "امام مالک بن انس نے ، ابن افلح کے آزاد کردہ غلام صیفی سے روایت کی ، کہا : مجھے ہشام بن زہرہ کے آزاد"}
{"hadithnumber": "5840", "text": "جریر بن حا زم نے کہا  :  میں نے اسماء بن عبید کو ایک آدمی سے حدیث بیان کرتے ہو ئے سنا ،  جسے سائب کہ"}
{"hadithnumber": "5841", "text": "ابن عجلا ن نے کہا  :  مجھے صیفی نے ابو سائب سے حدیث بیان کی ،  انھوں نے حضرت خدری رضی اللہ تعالیٰ عن"}
{"hadithnumber": "5842", "text": "ابو بکر بن ابی شیبہ عمر وناقد اسحٰق بن ابرا ہیم اور ابن ابی عمر نے ہمیں حدیث بیان کی ،  اسحٰق نے کہا"}
{"hadithnumber": "5843", "text": "ابوطاہر نے کہا  :  ہمیں ابن وہب نے بتا یا کہا  ، مجھے ابن جریج نے خبرد  ۔ اور محمد بن احمد بن ابی خل"}
{"hadithnumber": "5844", "text": "عامر بن سعد نے اپنے والد  ( حضرت سعد بن ابی وقاص رضی اللہ تعالیٰ عنہ   )  سے روایت کی کہ نبی  صلی ال"}
{"hadithnumber": "5845", "text": "ابو طا ہر اور حرملہ نے کہا  :  ہمیں ابن وہب نے خبر دی  ، کہا  :  مجھے یو نس نے زہری سے ،  انھوں نے ع"}
{"hadithnumber": "5846", "text": "خالد بن عبد اللہ نے سہیل سے ،  انھوں نے اپنے والد سے ،  انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "5847", "text": "ابو عوانہ جریر ،  اسماعیل بن زکریا اور سفیان سب نے سہیل سے ،  انھوں نے اپنے والد سے ،  انھوں نے حضرت"}
{"hadithnumber": "5848", "text": "محمد بن صباح  نے کہا  :  ہمیں اسماعیل بن زکریا نے سہیل سے حدیث بیان کی انھوں نے کہا  :  مجھے میری بہ"}
{"hadithnumber": "5849", "text": "سعید بن مسیب اور ابو سلمہ بن عبد الرحمٰن نے حضرت ابوہریرہ رضی اللہ تعالیٰ عنہ  سے اور انھوں نے نبی"}
{"hadithnumber": "5850", "text": "اعرج نے حضرت  ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی کہ نبی  صلی اللہ علیہ وسلم  نے فر ما یا  :"}
{"hadithnumber": "5851", "text": "ہمام بن منبہ نے کہا  :  یہ احادیث ہیں جو ہمیں حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  نے نبی  صلی اللہ ع"}
{"hadithnumber": "5852", "text": "جویریہ بن اسماءنے نافع سے ،  انھوں نے حضرت عبد اللہ  ( بن عمر رضی اللہ تعالیٰ عنہ  )  سے روایت کی ،"}
{"hadithnumber": "5853", "text": "عبید اللہ بن عمر نے نافع سے اور انھوں نے حضرت ابن عمر  رضی اللہ تعالیٰ عنہ  سے روایت کی ،  اسی طرح"}
{"hadithnumber": "5854", "text": "مالک نے نافع سے ،  انھوں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے ، انھوں نے نبی  صلی اللہ علیہ وسلم"}
{"hadithnumber": "5855", "text": "عبد ہ نے ہشام  ( بن عروہ )  سے ،  انھوں  نے اپنےوالد سے ،  انھوں نےحضرت ابو ہریرہ رضی اللہ تعالیٰ عن"}
{"hadithnumber": "5856", "text": "ابو معاویہ اور خالد بن حارث نے ہمیں حدیث سنا ئی کہا :  ہمیں ہشام نے اسی سند کے ساتھ حدیث بیان کی  ،"}
{"hadithnumber": "5857", "text": "حمید بن عبد الرحمٰن نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے ، انھوں نے رسول اللہ  صلی اللہ علیہ وس"}
{"hadithnumber": "5858", "text": "ہمام بن منبہ نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے ،  انھوں نے نبی  صلی اللہ علیہ وسلم  سے ،  ان"}
{"hadithnumber": "5859", "text": "ابو صالح سمان نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ سے روایت کی کہ رسول اللہ  صلی اللہ علیہ وسلم نے"}
{"hadithnumber": "5860", "text": "ہشام نے محمد  ( بن سیرین  )  سے ، انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے ،  انھوں نےنبی  صل"}
{"hadithnumber": "5861", "text": "ایوب سختیانی نے محمد بن سیرین سے ، انھوں نے حضرت ابوہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی  ، کہا  :"}
