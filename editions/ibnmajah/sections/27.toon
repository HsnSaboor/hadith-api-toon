{"hadithnumber": "3185", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَعَبْدُ اللَّهِ بْنُ سَعِيدٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏", "grades": "{'name': 'Al-Albani', 'grade': 'Very Daif Isnaad'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Very Daif Isnaad'},{'name': 'Shuaib Al Arnaut', 'grade': 'Very Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 27, Hadith 24", "international_number": "3185", "narrator_chain": ""}
{"hadithnumber": "3186", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏عَنْ شُعْبَةَ، ‏‏‏‏‏‏عَنْ هِشَامِ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 27, Hadith 25", "international_number": "3186", "narrator_chain": ""}
