metadata:
  section_id: 18
  section_name: رسول اللہ صلی اللہ علیہ وسلم کی پگڑی مبارک کا بیان
  hadith_first: 110
  hadith_last: 114

hadiths[5]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
110,’’سیدنا جابر رضی اللہ عنہ سے مروی ہے وہ فرماتے ہیں کہ نبی اکرم صلی اللہ علیہ وسلم فتح مکہ کے دن مکہ معظمہ میں داخل ہوئے تو آپ صلی اللہ علیہ وسلم کے سرِ اقدس پر ایک سیاہ پگڑی تھی۔ ‘‘,,,110,,رسول اللہ صلی اللہ علیہ وسلم کی پگڑی مبارک کا بیان
111,’’سیدنا عمر وبن حریث رضی اللہ عنہ سے مروی ہے کہ میں نے دیکھا کہ نبی اکرم صلی اللہ علیہ وسلم کے سرِ اقدس پر سیاہ عمامہ تھا۔‘‘,,,111,,رسول اللہ صلی اللہ علیہ وسلم کی پگڑی مبارک کا بیان
112,’’سیدنا عمر وبن حریث رضی اللہ عنہ سے مروی ہے کہ نبی اکرم صلی اللہ علیہ وسلم نے لوگوں کو خطبہ ارشاد فرمایا جب کہ آپ صلی اللہ علیہ وسلم کے سرِ اقدس پر سیاہ پکڑی تھی۔ ‘‘,,,112,,رسول اللہ صلی اللہ علیہ وسلم کی پگڑی مبارک کا بیان
113,"’’سیدنا عبداللہ بن عمر رضی اللہ عنہ سے مروی ہے وہ فرماتے ہیں کہ نبی اکرم صلی اللہ علیہ وسلم جب پگڑی مبارک باندھتے تھے تو اس کے شملہ کو اپنے دونوں کندھوں کے درمیان لٹکا دیتے تھے ( ابن عمر رضی اللہ عنہما کے شاگرد، امام) نافع فرماتے ہیں : ابن عمر رضی اللہ عنہما بھی اسی طرح کرتے تھے۔ اور عبید اللہ فرماتے ہیں : قاسم بن محمد اور سالم کو میں نے د یکھا کہ وہ دونوں بھی اسی طرح کیا کرتے تھے۔ ‘‘",,,113,,رسول اللہ صلی اللہ علیہ وسلم کی پگڑی مبارک کا بیان
114,’’سیدنا ابن عباس رضی اللہ عنہما سے مروی ہے کہ نبی اکرم صلی اللہ علیہ وسلم نے لوگوں کو خطبہ ارشاد فرمایا جب کہ آپ صلی اللہ علیہ وسلم کے سرِاقدس پر سیاہ پگڑی تھی۔ ‘‘,,,114,,رسول اللہ صلی اللہ علیہ وسلم کی پگڑی مبارک کا بیان
