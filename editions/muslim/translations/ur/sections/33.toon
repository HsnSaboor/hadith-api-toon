{"hadithnumber": "4701", "text": "عبداللہ بن مسلمہ بن قعنب اور قتیبہ بن سعید نے مغیرہ حزامی سے اور زہیر بن حرب اور عمرو ناقد نے سفیان"}
{"hadithnumber": "4702", "text": "ہمام بن منبہ سے روایت ہے ،  کہا :  یہ ہے جو حضرت ابوہریرہ رضی اللہ عنہ نے رسول اللہ صلی اللہ علیہ وس"}
{"hadithnumber": "4703", "text": "حضرت جابر بن عبداللہ رضی اللہ عنہ نے کہا :  نبی صلی اللہ علیہ وسلم نے فرمایا :   \" اچھائی اور برائی"}
{"hadithnumber": "4704", "text": "حضرت عبداللہ  ( بن عمر رضی اللہ عنہ )  نے کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   \" جب تک"}
{"hadithnumber": "4705", "text": "حصین  ( بن عبدالرحمٰن )  نے حضرت جابر بن سمرہ رضی اللہ عنہ سے روایت کی کہ میں اپنے والد  ( حضرت سمرہ"}
{"hadithnumber": "4706", "text": "عبدالملک بن عمیر نے حضرت جابر بن سمرہ رضی اللہ عنہ سے روایت کی کہ میں نے رسول اللہ صلی اللہ علیہ وسل"}
{"hadithnumber": "4707", "text": "ابو عوانہ نے سماک سے ،  انہوں نے حضرت جابر بن سمرہ رضی اللہ عنہ سے ،  انہوں نے نبی صلی اللہ علیہ وسل"}
{"hadithnumber": "4708", "text": "حماد بن سلمہ نے سماک سے حدیث بیان کی ،  انہوں نے کہا :  میں نے حضرت جابر بن سمرہ رضی اللہ عنہ کو یہ"}
{"hadithnumber": "4709", "text": "داود نے شعبی سے ،  انہوں نے جابر بن سمرہ رضی اللہ عنہ سے روایت کی ،  کہا :  نبی صلی اللہ علیہ وسلم ن"}
{"hadithnumber": "4710", "text": "عبداللہ )  بن عون نے شعبی سے ،  انہوں نے حضرت جابر بن سمرہ رضی اللہ عنہ سے روایت کی ،  کہا :  میں رس"}
{"hadithnumber": "4711", "text": "حاتم بن اسماعیل نے مہاجر بن مسمار سے حدیث بیان کی ،  انہوں نے عامر بن سعد بن ابی وقاص سے روایت کی ،"}
{"hadithnumber": "4712", "text": "ابن ابی ذئب نے مہاجر بن مسمار سے حدیث بیان کی ،  انہوں نے عامر بن سعد سے روایت کی کہ انہوں نے ابن سم"}
{"hadithnumber": "4713", "text": "ہشام کے والد  ( عروہ )  نے حضرت عبداللہ بن عمر رضی اللہ عنہ سے روایت کی کہ جب میرے والد  ( حضرت عمر"}
{"hadithnumber": "4714", "text": "سالم نے ابن عمر رضی اللہ عنہ سے بیان کیا ،  کہا :  میں حضرت حفصہ رضی اللہ عنہ کے پاس گیا ،  انہوں نے"}
{"hadithnumber": "4715", "text": "جریر بن حازم نے کہا :  ہمیں حسن بصری نے اور انہیں عبدالرحمٰن بن سمرہ رضی اللہ عنہ نے حدیث بیان کی ،"}
{"hadithnumber": "4716", "text": "یونس بن عبید ،  منصور ،  حمید اور ہشام بن حسان سب نے حسن بصری سے ،  انہوں نے حضرت عبدالرحمان بن سمرہ"}
{"hadithnumber": "4717", "text": "برید بن عبداللہ سے روایت ہے ،  انہوں نے ابوبردہ سے ،  انہوں نے حضرت ابو موسیٰ  ( اشعری )  رضی اللہ ع"}
{"hadithnumber": "4718", "text": "حمید بن ہلال نے کہا :  مجھے ابوبردہ نے حدیث بیان کی ،  انہوں نے کہا :  حضرت ابو موسیٰ اشعری رضی اللہ"}
{"hadithnumber": "4719", "text": "ابن حجیرہ اکبر نے حضرت ابوذر رضی اللہ عنہ سے روایت کی ،  کہا :  میں نے عرض کی :  اللہ کے رسول! کیا آ"}
{"hadithnumber": "4720", "text": "ابو سالم جیشانی نے حضرت ابوذر رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :"}
{"hadithnumber": "4721", "text": "ابوبکر بن ابی شیبہ ،  زہیر بن حرب اور ابن نمیر تینوں نے کہا :  ہمیں سفیان بن عیینہ نے عمرو بن دینار"}
{"hadithnumber": "4722", "text": "ابن وہب نے کہا :  مجھے حرملہ نے عبدالرحمان بن شماسہ سے حدیث بیان کی ،  انہوں نے کہا :  میں حضرت عائش"}
{"hadithnumber": "4723", "text": "جریر بن حازم نے حرملہ مصری سے ،  انہوں نے عبدالرحمان بن ابی شماسہ سے ،  انہوں نے حضرت عائشہ رضی اللہ"}
{"hadithnumber": "4724", "text": "عبیداللہ بن عمر ،  ایوب ،  ضحاک بن عثمان اور اسامہ  ( بن زید لیثی )  سب نے نافع سے ،  انہوں نے ابن ع"}
{"hadithnumber": "4727", "text": "اسماعیل بن جعفر نے حضرت عبداللہ بن دینار سے ،  انہوں نے ابن عمر رضی اللہ عنہ سے روایت کی ،  کہا :  ر"}
{"hadithnumber": "4728", "text": "بسر بن سعید نے عبداللہ بن عمر رضی اللہ عنہ سے ،  انہوں نے نبی صلی اللہ علیہ وسلم سے اس کے ہم معنی حد"}
{"hadithnumber": "4729", "text": "ابو اشہب نے حضرت حسب بصری سے روایت کی کہ عبیداللہ بن زیاد حضرت معقل بن یسار رضی اللہ عنہ کے پاس اس م"}
{"hadithnumber": "4730", "text": "یونس نے حضرت حسن بصری سے روایت کی ،  کہا :  ابن زیاد حضرت معقل رضی اللہ عنہ کے پاس گیا وہ اس وقت  ("}
{"hadithnumber": "4731", "text": "ابو ملیح سے روایت ہے کہ عبیداللہ بن زیاد ،  حضرت معقل بن یسار رضی اللہ عنہ کی بیماری میں ان کے پاس گ"}
{"hadithnumber": "4732", "text": "سوادہ بن ابواسود نے خبر دی کہ میرے والد نے مجھے حدیث بیان کی کہ حضرت معقل بن یسار رضی اللہ عنہ بیمار"}
{"hadithnumber": "4733", "text": "حسن بصری رحمۃ اللہ علیہ نے بتایا کہ عائذ بن عمرو رضی اللہ عنہ اور وہ رسول اللہ صلی اللہ علیہ وسلم کے"}
{"hadithnumber": "4734", "text": "اسماعیل بن ابراہیم نے ابوحیان سے ،  انہوں نے ابو زرعہ سے ،  انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے ر"}
{"hadithnumber": "4735", "text": "عبدالرحیم بن سلیمان نے ابوحیان سے ،  جریر نے ان سے اور عمارہ بن قعقاع سے ،  ان سب نے ابوزرعہ سے ،  ا"}
{"hadithnumber": "4736", "text": "حماد بن زید نے ایوب سے ،  انہوں نے یحییٰ بن سعید سے ،  انہوں نے ابوزرعہ سے ،  انہوں نے حضرت ابوہریرہ"}
{"hadithnumber": "4737", "text": "ہمیں عبدالوارث نے بیان کیا ،  کہا :  ہمیں ایوب نے یحییٰ بن سعید بن حیان سے حدیث بیان کی ،  انہوں نے"}
{"hadithnumber": "4738", "text": "ابوبکر بن ابی شیبہ ،  عمرو ناقد اور ابن ابی عمر نے حدیث بیان کی ،   ۔  ۔  الفاظ ابوبکر بن ابی شیبہ ک"}
{"hadithnumber": "4739", "text": "معمر نے زہری سے ،  انہوں نے عروہ سے ،  انہوں نے ابوحمید ساعدی رضی اللہ عنہ سے روایت کی ،  انہوں نے ک"}
{"hadithnumber": "4740", "text": "ہشام نے اپنے والد سے ،  انہوں نے ابوحمید ساعدی رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  رسول اللہ"}
{"hadithnumber": "4741", "text": "عبدہ ،  ابن نمیر اور ابومعاویہ ،  اسی طرح عبدالرحیم بن سلیمان اور سفیان سب نے اسی سند کے ساتھ ہشام س"}
{"hadithnumber": "4742", "text": "عبداللہ بن ذکوان یعنی ابوزناد سے روایت ہے انہوں نے عروہ بن زبیر سے ،  انہوں نے ابوحمید ساعدی رضی الل"}
{"hadithnumber": "4743", "text": "وکیع بن جراح نے کہا :  ہمیں اسماعیل بن ابی خالد نے قیس بن ابی حازم سے حدیث سنائی ،  انہوں نے حضرت عد"}
{"hadithnumber": "4744", "text": "عبداللہ بن نمیر ،  محمد بن بشر اور ابواسامہ سبنے کہا :  ہمیں اسماعیل نے اسی سند کے ساتھ اسی کے مطابق"}
{"hadithnumber": "4745", "text": "فضل بن موسیٰ نے کہا :  ہمیں اسماعیل بن ابی خالد نے حدیث سنائی ،  کہا :  ہمیں قیس بن ابی حازم نے خبر"}
{"hadithnumber": "4746", "text": "ابن جریج نے بیان کیا کہ قرآن مجید کی آیت :   \" اے ایمان والو! اللہ کی اطاعت کرو اور رسول کی اطاعت کر"}
{"hadithnumber": "4749", "text": "یونس نے خبر دی کہ انہیں ابن شہاب نے خبر دی ،  کہا :  ہمیں ابوسلمہ بن عبدالرحمان نے ابوہریرہ رضی اللہ"}
{"hadithnumber": "4750", "text": "زیاد  ( بن سعد )  سے روایت ہے ،  انہوں نے ابن شہاب سے اسی سند کے ساتھ روایت کی ،  انہوں نے ابوہریرہ"}
{"hadithnumber": "4751", "text": "ابو عوانہ اور شعبہ نے یعلیٰ بن عطاء سے روایت کی ،  انہوں نے علقمہ سے  ( حدیث )  سنی ،  انہوں نے ابوہ"}
{"hadithnumber": "4752", "text": "معمر نے ہمام بن منبہ سے ،  انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے ،  انہوں نے نبی اکرم صلی اللہ علیہ"}
{"hadithnumber": "4753", "text": "حضرت ابوہریرہ رضی اللہ عنہ کے مولیٰ  ( ازاد کردہ غلام )  ابو یونس نے حدیث بیان کی ،  کہا :  میں نے ح"}
{"hadithnumber": "4754", "text": "ابو صالح السمان سے روایت ہے ،  انہوں نے ابوہریرہ رضی اللہ عنہ سے روایت ہے ،  انہوں نے کہا :  رسول ال"}
{"hadithnumber": "4755", "text": "ابن ادریس نے ہمیں شعبہ سے حدیث بیان کی ،  انہوں نے ابو عمران سے ،  انہوں نے عبداللہ بن صامت سے اور ا"}
{"hadithnumber": "4756", "text": "محمد بن جعفر اور نضر بن شمیل نے ہمیں شعبہ سے ،  انہوں نے ابوعمران سے اسی سند کے ساتھ حدیث بیان کی او"}
{"hadithnumber": "4757", "text": "عبیداللہ کے والد معاذ نے ہمیں شعبہ سے اور انہوں نے ابوعمران سے اسی سند کے ساتھ حدیث بیان کی ،  جس طر"}
{"hadithnumber": "4758", "text": "محمد بن مثنیٰ نے کہا :  محمد بن جعفر نے ہمیں شعبہ سے حدیث بیان کی ،  انہوں نے یحییٰ بن حصین سے ،  ان"}
{"hadithnumber": "4759", "text": "ابن بشار نے ہمیں یہی حدیث بیان کی ،  کہا :  ہمیں محمد بن جعفر اور عبدالرحمٰن بن مہدی نے شعبہ سے اسی"}
{"hadithnumber": "4760", "text": "وکیع بن جراح نے ہمیں شعبہ سے اسی سند کے ساتھ حدیث بیان کی اور کہا :   \" کٹے ہوئے اعضاء والا حبشی غلا"}
{"hadithnumber": "4761", "text": "بہز نے ہمیں شعبہ سے اسی سند کے ساتھ حدیث بیان کی :  انہوں نے  \" کٹے ہوئے اعضاء والا حبشی غلام \"  نہی"}
{"hadithnumber": "4762", "text": "زید بن ابی انیسہ نے یحییٰ بن حصین سے ،  انہوں نے اپنی دادی حضرت ام حصین رضی اللہ عنہا سے روایت کی کہ"}
{"hadithnumber": "4763", "text": "لیث نے عبیداللہ سے ،  انہوں نے نافع سے ،  انہوں نے حضرت عبداللہ بن عمر رضی اللہ عنہ سے ،  انہوں نے ر"}
{"hadithnumber": "4764", "text": "ٰ قطان اور عبداللہ بن نمیر دونوں نے عبیداللہ سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی"}
{"hadithnumber": "4765", "text": "زبید نے سعد بن عبیدہ سے ،  انہوں نے ابوعبدالرحمٰن سے ،  انہوں نے حضرت علی رضی اللہ عنہ سے روایت کی ک"}
{"hadithnumber": "4766", "text": "ہمیں محمد بن عبداللہ بن نمیر ،  زہیر بن حرب اور ابوسعید اشج نے حدیث بیان کی ،  الفاظ سب کے ملتے جلتے"}
{"hadithnumber": "4767", "text": "ابوبکر بن ابی شیبہ نے ہمیں حدیث بیان کی ،  کہا :  ہمیں وکیع اور ابومعاویہ نے اعمش سے اسی سند سے اسی"}
{"hadithnumber": "4768", "text": "ہمیں ابوبکر بن ابی شیبہ نے حدیث بیان کی ،  کہا :  ہمیں عبداللہ بن ادریس نے یحییٰ بن سعید اور عبیدالل"}
{"hadithnumber": "4769", "text": "یہی حدیث نے ہمیں ابن نمیر نے بیان کی ،  کہا :  ہمیں عبداللہ بن ادریس نے حدیث بیان کی ،  کہا :  ہمیں"}
{"hadithnumber": "4770", "text": "یزید بن ہاد نے عبادہ بن ولید بن عبادہ بن صامت ،  انہوں نے اپنے والد سے روایت کی ،  انہوں نے کہا :  م"}
{"hadithnumber": "4771", "text": "جنادہ بن ابی امیہ سے روایت ہے ،  کہا :  ہم حضرت عبادہ بن صامت رضی اللہ عنہ کے پاس حاضر ہوئے ،  وہ  ("}
{"hadithnumber": "4772", "text": "حضرت ‌ابوہریرہ ‌رضی ‌اللہ ‌عنہ ‌سے ‌روایت ‌ہے ‌رسول ‌اللہ ‌صلی ‌اللہ ‌علیہ ‌وسلم ‌نے ‌فرمایا ‌امام ‌"}
{"hadithnumber": "4773", "text": "شعبہ نے ہمیں فرات قزاز سے حدیث بیان کی ،  انہوں نے ابوحازم سے روایت کی کہ میں پانچ سال حضرت ابوہریرہ"}
{"hadithnumber": "4774", "text": "حسن بن فرات نے اپنے والد سے اسی سند کے ساتھ اسی کے مانند روایت کی ۔"}
{"hadithnumber": "4775", "text": "حضرت عبداللہ  ( بن مسعود رضی اللہ عنہ )  سے روایت ہے کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   "}
{"hadithnumber": "4776", "text": "عبدالرحمن بن عبد رب الکعبہ سے روایت ہے میں مسجد میں گیا وہاں عبداﷲ بن عمرو بن العاصؓ کعبہ کے سایہ می"}
{"hadithnumber": "4777", "text": "وکیع اور ابومعاویہ دونوں نے اعمش سے اسی سند سے اسی کے مانند روایت کی"}
{"hadithnumber": "4778", "text": "عامر نے عبدالرحمان بن عبد رب الکعبہ صائدی سے روایت کی ،  کہا :  میں نے کعبہ کے پاس ایک مجمع دیکھا ،"}
{"hadithnumber": "4779", "text": "محمد بن جعفر نے ہمیں شعبہ سے حدیث بیان کی ،  انہوں نے کہا :  میں نے قتادہ سے سنا ،  وہ حضرت انس بن م"}
{"hadithnumber": "4782", "text": "محمد بن جعفر نے ہمیں حدیث بیان کی ،  کہا :  ہمیں شعبہ نے سماک بن حرب سے حدیث بیان کی ،  انہوں نے علق"}
{"hadithnumber": "4783", "text": "شبابہ نے کہا :  ہمیں شعبہ نے سماک سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی اور کہا :  اشعث بن قی"}
{"hadithnumber": "4784", "text": "حذیفہ بن الیمان رضی ‌اللہ ‌عنہ  سے روایت ہے لوگ رسول اﷲ  صلی ‌اللہ ‌علیہ ‌وسلم  سے بھلی باتوں کو پوچ"}
{"hadithnumber": "4785", "text": "حذیفہ بن الیمان رضی ‌اللہ ‌عنہ  سے روایت ہے میں نے عرض کیا یارسول اﷲؐ! ہم برائی میں تھے پھر اﷲ تعالی"}
{"hadithnumber": "4786", "text": "۴۷۸۶۔ ابوہریرہ رضی ‌اللہ ‌عنہ  سے روایت ہے رسول اﷲؐ نے فرمایا جو شخص حاکم کی اطاعت سے باہر ہوجاوے او"}
{"hadithnumber": "4787", "text": "۴۷۸۷۔ ترجمہ وہی ہے جو اوپر گزرا۔"}
{"hadithnumber": "4788", "text": "۴۷۸۸۔ ابوہریرہ رضی اﷲ عنہ سے روایت ہے رسول اﷲ  صلی ‌اللہ ‌علیہ ‌وسلم  نے فرمایا جو شخص اطاعت سے نکل"}
{"hadithnumber": "4789", "text": "ترجمہ وہی ہے جو اوپر گزرا۔"}
{"hadithnumber": "4790", "text": "ابن عباس رضی اﷲ عنہ سے روایت ہے رسول اﷲ  صلی ‌اللہ ‌علیہ ‌وسلم  نے فرمایا جو شخص اپنے حاکم سے بری با"}
{"hadithnumber": "4791", "text": "ابن عباس رضی ‌اللہ ‌عنہ  سے روایت ہے رسول اﷲ صلی ‌اللہ ‌علیہ ‌وسلم نے فرمایا جو شخص اپنے حاکم سے بری"}
{"hadithnumber": "4792", "text": "جندب بن عبداﷲ بجلی رضی اﷲ عنہ سے روایت ہے رسول اﷲ  صلی ‌اللہ ‌علیہ ‌وسلم  نے فرمایا جو شخص اندھے جھن"}
{"hadithnumber": "4793", "text": "نافع رضی ‌اللہ ‌عنہ  سے روایت ہے عبداﷲ بن عمر رضی ‌اللہ ‌عنہ  عبداﷲ بن مطیع رضی ‌اللہ ‌عنہ  کے پاس آ"}
{"hadithnumber": "4794", "text": "ترجمہ وہی جو اوپر گزرا۔"}
{"hadithnumber": "4795", "text": "ترجمہ وہی جو اوپر گزرا۔"}
{"hadithnumber": "4796", "text": "شعبہ نے زیاد بن علاقہ سے حدیث بیان کی ،  انہوں نے کہا :  میں نے عَرفجہ رضی اللہ عنہ سے سنا ،  کہا :"}
{"hadithnumber": "4797", "text": "ابو عوانہ ،  شیبان ،  اسرائیل ،  عبداللہ بن مختار اور ایک آدمی جس کا حماد نے نام لیا تھا ،  ان سب نے"}
{"hadithnumber": "4798", "text": "ابو یعفور نے حضرت عرفجہ رضی اللہ عنہ سے روایت کی ،  کہا :  میں نے نبی صلی اللہ علیہ وسلم کو یہ فرمات"}
{"hadithnumber": "4799", "text": "حضرت ابو سعید خدری رضی اللہ عنہ سے روایت ہے ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   \" ج"}
{"hadithnumber": "4800", "text": "ہمام بن یحییٰ نے کہا :  ہمیں قتادہ نے حسن سے حدیث بیان کی ،  انہوں نے ضبہ بن محصن سے ،  انہوں نے ام"}
{"hadithnumber": "4801", "text": "ہشام دستوائی نے قتادہ سے روایت کی ،  کہا :  ہمیں حسن نے ضبہ بن محصب عنزی سے حدیث بیان کی ،  انہوں نے"}
{"hadithnumber": "4802", "text": "ماد بن زید نے کہا :  ہمیں معلیٰ بن زیاد اور ہشام نے حسن سے حدیث بیان کی ،  انہوں نے ضبہ بن محصن سے ،"}
{"hadithnumber": "4803", "text": "ابن مبارک نے ہشام سے ،  انہوں نے حسن سے ،  انہوں نے ضبہ بن محصن سے ،  انہوں نے حضرت ام سلمہ رضی اللہ"}
{"hadithnumber": "4804", "text": "یزید بن یزید بن جابر نے رُزیق بن حیان سے ،  انہوں نے مسلم بن قرظہ سے ،  انہوں نے حضرت عوف بن مالک رض"}
{"hadithnumber": "4805", "text": "داود بن رُشید نے کہا :  ہمیں ولید بن مسلم نے حدیث سنائی ،  کہا :  ہمیں عبدالرحمٰن بن یزید بن جابر نے"}
{"hadithnumber": "4806", "text": "اسحٰق بن موسیٰ انصاری نے کہا :  ہمیں ولید بن مسلم نے حدیث بیان کی ،  کہا :  ہمیں ابن جابر نے اسی سند"}
{"hadithnumber": "4807", "text": "لیث نے ابوزبیر سے ،  انہوں نے جابر رضی اللہ عنہ سے روایت کی ،  کہا :  حدیبیہ کے دن ہم ایک ہزار چار س"}
{"hadithnumber": "4808", "text": "سفیان نے ابوزبیر سے ،  انہوں نے حضرت جابر رضی اللہ عنہ سے روایت کی ،  کہا :  ہم نے رسول اللہ صلی الل"}
{"hadithnumber": "4809", "text": "محمد بن حاتم نے ہمیں حدیث بیان کی ،  کہا :  ہمیں حجاج نے ابن جریج سے حدیث سنائی ،  کہا :  مجھے ابوزب"}
{"hadithnumber": "4810", "text": "مجھے ابراہیم بن دینار نے حدیث بیان کی ،  کہا :  ہمیں سلیمان بن مجالد کے آزاد کردہ غلام حجاج بن محمد"}
{"hadithnumber": "4811", "text": "عمرو نے حضرت جابر رضی اللہ عنہ سے روایت کی ،  کہا :  حدیبیہ کے دن ہم ایک ہزار چار سو تھے ،  نبی صلی"}
{"hadithnumber": "4812", "text": "عمرو بن مرہ نے سالم بن ابی جعد سے روایت کی ،  کہا :  میں نے حضرت جابر بن عبداللہ رضی اللہ عنہ سے اصح"}
{"hadithnumber": "4813", "text": "حصین نے سالم بن ابی جعد سے ،  انہوں نے حضرت جابر رضی اللہ عنہ سے روایت کی کہ اگر ہم ایک لاکھ بھی ہوت"}
{"hadithnumber": "4814", "text": "اعمش نے کہا :  مجھے سالم بن ابی جعد نے حدیث بیان کی ،  انہوں نے کہا :  میں نے حضرت جابر رضی اللہ عنہ"}
{"hadithnumber": "4815", "text": "عبیداللہ کے والد معاذ نے ہمیں حدیث بیان کی ،  کہا :  ہمیں شعبہ نے عمرہ بن مرہ سے حدیث سنائی ،  کہا :"}
{"hadithnumber": "4816", "text": "ابوداود اور نضر بن شمیل نے شعبہ سے اسی سند کے ساتھ اسی کے مانند روایت کی"}
{"hadithnumber": "4817", "text": "خالد  ( حذاء )  نے حکم بن عبداللہ بن اعرج سے ،  انہوں نے حضرت معقل بن یسار رضی اللہ عنہ سے روایت کی"}
{"hadithnumber": "4818", "text": "یونس نے اسی سند سے ،  یعنی حکم بن عبداللہ سے روایت کی"}
{"hadithnumber": "4821", "text": "قتادہ نے سعید بن مسیب سے ،  انہوں نے اپنے والد سے روایت کی ،  کہا :  میں نے وہ درخت دیکھا تھا ،  پھر"}
{"hadithnumber": "4822", "text": "حاتم بن اسماعیل نے حضرت سلمہ بن اکوع رضی اللہ عنہ کے مولیٰ یزید بن عبید سے حدیث بیان کی ،  انہوں نے"}
{"hadithnumber": "4823", "text": "حماد بن مسعدہ نے کہا  ہمیں یزید نے سلمہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سےاسی کی مانند حدیث بیان کی ہے"}
{"hadithnumber": "4824", "text": "عباد بن تمیم نے حضرت عبداللہ بن زید رضی اللہ عنہ سے روایت کی ،  کہا :  ان کے پاس کوئی شخص آیا اور کہ"}
{"hadithnumber": "4825", "text": "یزید بن ابی عبید نے حضرت سلمہ بن اکوع رضی اللہ عنہ سے روایت کی کہ وہ حجاج کے پاس گئے ،  اس نے کہا :"}
{"hadithnumber": "4826", "text": "اسماعیل بن زکریا نے عاصم احول سے ،  انہوں نے ابوعثمان نہدی سے روایت کی ،  کہا :  مجھے حضرت مجاشع بن"}
{"hadithnumber": "4827", "text": "علی بن مسہر نے عاصم سے ،  انہوں نے ابوعثمان سے روایت کی ،  کہا :  مجھے مجاشع بن مسعود سلمی رضی اللہ"}
{"hadithnumber": "4828", "text": "محمد بن فضیل نے عاصم سے اسی سند کے ساتھ حدیث بیان کی ،  کہا :  میں حضرت مجاشع رضی اللہ عنہ کے بھائی"}
{"hadithnumber": "4829", "text": "جریر نے منصور سے ،  انہوں نے مجاہد سے ،  انہوں نے طاوس سے ،  انہوں نے حضرت ابن عباس رضی اللہ عنہ سے"}
{"hadithnumber": "4830", "text": "سفیان ،  مفضل بن مُہلہل اور اسرائیل ،  سب نے منصور سے اسی سند کے ساتھ اسی کے مانند روایت کی"}
{"hadithnumber": "4831", "text": "حضرت عائشہ رضی اللہ عنہا نے کہا کہ رسول اللہ صلی اللہ علیہ وسلم سے ہجرت کے متعلق سوال کیا گیا ،  آپ"}
{"hadithnumber": "4832", "text": "ولید بن مسلم نے کہا :  ہمیں عبدلرحمٰن بن عمرو اوزاعی نے حدیث بیان کی ،  کہا :  مجھے ابن شہاب زہری نے"}
{"hadithnumber": "4833", "text": "محمد بن یوسف نے اوزاعی سے اسی سند کے ساتھ اسی کے مانند روایت کی مگر انہوں نے کہا :   \" بلاشبہ اللہ ت"}
{"hadithnumber": "4834", "text": "یونس بن یزید نے کہا :  ابن شہاب نے کہا :  مجھے عروہ بن زبیر نے بتایا کہ نبی صلی اللہ علیہ وسلم کی اہ"}
{"hadithnumber": "4835", "text": "امام مالک نے ابن شہاب سے ،  انہوں نے عروہ بن زبیر سے روایت کی کہ حضرت عائشہ رضی اللہ عنہا نے انہیں ع"}
{"hadithnumber": "4836", "text": "عبداللہ بن دینار نے بتایا کہ انہوں نے حضرت عبداللہ بن عمر رضی اللہ عنہ سے سنا ،  کہہ رہے تھے :  ہم س"}
{"hadithnumber": "4837", "text": "عبداللہ بن نمیر نے کہا :  ہمیں عبیداللہ نے نافع سے حدیث بیان کی ،  انہوں نے حضرت عبداللہ بن عمر رضی"}
{"hadithnumber": "4838", "text": "عبداللہ بن ادریس ،  عبدالرحیم بن سلیمان اور عبدالوہاب ثقفی سن نے عبیداللہ سے اسی سند کے ساتھ حدیث بی"}
{"hadithnumber": "4839", "text": "امام مالک نے نافع سے ،  انہوں نے حضرت عبداللہ بن عمر رضی اللہ عنہ سے روایت کی ،  کہا :  رسول اللہ صل"}
{"hadithnumber": "4840", "text": "لیث نے نافع سے ،  انہوں نے حضرت عبداللہ بن عمر رضی اللہ عنہ سے ،  انہوں نے رسول اللہ صلی اللہ علیہ و"}
{"hadithnumber": "4841", "text": "حماد نے ایوب سے ،  انہوں نے نافع سے ،  انہوں نے حضرت ابن عمر رضی اللہ عنہ سے روایت کی ،  کہا :  رسول"}
{"hadithnumber": "4842", "text": "اسماعیل بن علیہ ،  سفیان اور ثقفی سب نے ایوب سے حدیث بیان کی ،  ایوب اور ضحاک بن عثمان نے نافع سے ،"}
{"hadithnumber": "4843", "text": "امام مالک نے نافع سے ،  انہوں نے حضرت عبداللہ بن عمر رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ"}
{"hadithnumber": "4844", "text": "یحییٰ بن یحییٰ ،  محمد بن رمح اور قتیبہ بن سعید نے لیث بن سعد سے حدیث بیان کی ۔  خلف بن ہشام ،  ابو"}
{"hadithnumber": "4845", "text": "حضرت عبداﷲ بن عمر رضی اﷲ عنہما سے روایت ہے رسول اﷲ  صلی ‌اللہ ‌علیہ ‌وسلم  نے فرمایا گھوڑوں کی پیشان"}
{"hadithnumber": "4846", "text": "ترجمہ وہی جو اوپر گزرا۔"}
{"hadithnumber": "4847", "text": "جریر بن عبداﷲ رضی ‌اللہ ‌عنہ  سے روایت ہے میں نے رسول اﷲؐ کو دیکھا آپ ایک گھوڑے کی پیشانی کے بال انگ"}
{"hadithnumber": "4848", "text": "ترجمہ وہی جو اوپر گزرا۔"}
{"hadithnumber": "4849", "text": "عروہ بارقی سے روایت ہے رسول اﷲ  صلی ‌اللہ ‌علیہ ‌وسلم  نے فرمایا برکت بندھی ہوئی ہے گھوڑوں کی پیشانی"}
{"hadithnumber": "4850", "text": "عروہ بارقی سے روایت ہے رسول اﷲ صلی ‌اللہ ‌علیہ ‌وسلم نے فرمایا برکت بندھی ہوئی ہے گھوڑوں کی پیشانیوں"}
{"hadithnumber": "4851", "text": "ترجمہ وہی جو اوپر گزرا۔"}
{"hadithnumber": "4852", "text": "ترجمہ وہی جو اوپر گزرا۔"}
{"hadithnumber": "4853", "text": "ترجمہ وہی جو اوپر گزرا اس روایت میں ثواب اور غنیمت کا ذکر نہیں ہے۔"}
{"hadithnumber": "4854", "text": "انس رضی ‌اللہ ‌عنہ  سے روایت ہے رسول اﷲ  صلی ‌اللہ ‌علیہ ‌وسلم  نے فرمایا برکت گھوڑوں کی پیشانیوں می"}
{"hadithnumber": "4855", "text": "ترجمہ وہی جو اوپر گزرا۔"}
{"hadithnumber": "4856", "text": "وکیع نے سفیان سے ،  انہوں نے سلم بن عبدالرحمٰن سے ،  انہوں نے ابوزرعہ سے ،  انہوں نے حضرت ابوہریرہ ر"}
{"hadithnumber": "4857", "text": "عبداللہ بن نمیر اور عبدالرزاق نے سفیان سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی ۔  اور عبدالرزاق"}
{"hadithnumber": "4858", "text": "محمد بن جعفر اور وہب بن جریر نے ہمیں شعبہ سے حدیث بیان کی ،  انہوں نے عبداللہ بن یزید نخعی سے ،  انہ"}
{"hadithnumber": "4859", "text": "جریر نے عمارہ بن قعقاع سے ،  انہوں نے ابوزرعہ سے ،  انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی"}
{"hadithnumber": "4860", "text": "ابن فضیل نے عمارہ سے اسی سند کے ساتھ  ( یہی )  حدیث بیان کی ۔"}
{"hadithnumber": "4861", "text": "مغیرہ بن عبدالرحمٰن حزامی نے ابوزناد سے خبر دی ،  انہوں نے اعرج سے ،  انہوں نے ابوہریرہ رضی اللہ عنہ"}
{"hadithnumber": "4862", "text": "عمرو ناقد اور زہیر بن حرب نے کہا :  ہمیں سفیان بن عیینہ نے ابوزناد سے حدیث بیان کی ،  انہوں نے اعرج"}
{"hadithnumber": "4863", "text": "ہمام بن منبہ سے روایت ہے ،  کہا :  یہ احادیث ہیں جو حضرت ابوہریرہ رضی اللہ عنہ نے رسول اللہ صلی اللہ"}
{"hadithnumber": "4864", "text": "ابن ابی عمر نے کہا :  ہمیں سفیان نے ابوزناد سے ،  انہوں نے اعرج سے ،  انہوں نے ابوہریرہ رضی اللہ عنہ"}
{"hadithnumber": "4865", "text": "یحییٰ بن سعید نے ابوصالح سے ،  انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  کہا :  رسول اللہ ص"}
{"hadithnumber": "4866", "text": "سہیل منے اپنے والد  ( ابو صالح )  سے ،  انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  کہا :  رس"}
{"hadithnumber": "4867", "text": "ابو خالد احمر نے ہمیں شعبہ سے حدیث بیان کی ،  انہوں نے قتادہ اور حُمید سے ،  انہوں نے حضرت انس بن ما"}
{"hadithnumber": "4868", "text": "محمد بن جعفر نے کہا :  ہمیں شعبہ نے قتادہ سے حدیث بیان کی ،  انہوں نے کہا :  میں نے حضرت انس بن مالک"}
{"hadithnumber": "4869", "text": "خالد بن عبداللہ واسطی نے سہیل بن ابی صالح سے حدیث بیان کی ،  انہوں نے اپنے والد سے ،  انہوں نے حضرت"}
{"hadithnumber": "4870", "text": "ابو عوانہ ،  جریر اور ابو معاویہ سب نے اسی سند کے ساتھ سہیل سے اسی کے مانند روایت کی ۔"}
{"hadithnumber": "4871", "text": "ابوتوبہ نے ہمیں حدیث بیان کی ،  کہا :  ہمیں معاویہ بن سلام نے زید بن سلام سے حدیث بیان کی ،  انہوں ن"}
{"hadithnumber": "4872", "text": "یحییٰ بن حسان نے کہا :  ہمیں معاویہ نے حدیث بیان کی ،  کہا :  مجھے زید نے خبر دی کہ انہوں نے ابوسلام"}
{"hadithnumber": "4873", "text": "حضرت انس بن مالک رضی اللہ عنہ سے روایت ہے کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   \" صبح کو یا"}
{"hadithnumber": "4874", "text": "عبدالعزیز بن ابی حازم نے اپنے والد سے ،  انہوں نے حضرت سہل بن سعد ساعدی رضی اللہ عنہ سے اور انہوں نے"}
{"hadithnumber": "4875", "text": "سفیان نے ابوحازم سے ،  انہوں نے حضرت سہل بن سعد ساعدی رضی اللہ عنہ سے ،  انہوں نے رسول اللہ صلی اللہ"}
{"hadithnumber": "4876", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   \" اگر میری حالت"}
{"hadithnumber": "4877", "text": "عبداللہ بن یزید مقری نے سعید بن ابی ایوب سے روایت کی ،  انہوں نے کہا :  مجھے شرجیل بن شریک معافری نے"}
{"hadithnumber": "4878", "text": "عبداللہ بن مبارک نے روایت کی ،  کہا :  ہمیں سعید بن ابی ایوب اور حیوہ بن شریح نے بتایا ،  دونوں میں"}
{"hadithnumber": "4879", "text": "حضرت ابو سعید خدری رضی اللہ عنہ سے روایت ہے کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   \" ابوسعید!"}
{"hadithnumber": "4880", "text": "لیث نے سعید بن ابی سعید  ( مقبری )  سے ،  انہوں نے عبداللہ بن ابی قتادہ سے ،  انہوں نے ابوقتادہ رضی"}
{"hadithnumber": "4881", "text": "یحییٰ بن سعید نے سعید بن ابی سعید مقبری سے ،  انہوں نے عبداللہ بن ابی قتادہ سے ،  انہوں نے اپنے والد"}
{"hadithnumber": "4882", "text": "عمرو بن دینار اور محمد بن عجلان نے محمد بن قیس سے روایت کی ،  انہوں نے عبداللہ بن ابی قتادہ سے ،  ان"}
{"hadithnumber": "4883", "text": "مفضل بن فضالہ نے عباس قِتبانی کے بیٹے عیاس سے حدیث بیان کی ،  انہوں نے عبداللہ بن یزید ابو عبدالرحمٰ"}
{"hadithnumber": "4884", "text": "سعید بن ابی ایوب نے کہا :  مجھے عیاش بن عباس قتبانی نے ابو عبدالرحمٰن حبلی سے حدیث بیان کی ،  انہوں"}
{"hadithnumber": "4885", "text": "مسروق بیان کرتے ہیں کہ ہم نے حضرت عبداللہ بن مسعود رضی اللہ عنہ سے اس آیت کی تفسیر دریافت کی :   \" ج"}
{"hadithnumber": "4886", "text": "محمد بن ولید زبیدی نے زہری سے ،  انہوں نے عطاء بن یزید لیثی سے ،  انہوں نے حضرت ابو سعید خدری رضی ال"}
{"hadithnumber": "4887", "text": "معمر نے زہری سے ،  انہوں نے عطاء بن یزید لیثی سے ،  انہوں نے حضرت ابوسعید خدری رضی اللہ عنہ سے روایت"}
{"hadithnumber": "4888", "text": "اوزاعی نے ابن شہاب سے اسی سند کے ساتھ روایت کی اورآدمی جو کسی گھاٹی میں ہے کہا ۔  پھر وہ آدمی نہیں ک"}
{"hadithnumber": "4889", "text": "یحییٰ بن یحییٰ تمیمی نے کہا :  ہمیں عبدالعزیز بن ابی حازم نے اپنے والد سے حدیث بیان کی ،  انہوں نے ب"}
{"hadithnumber": "4890", "text": "قتیبہ بن سعید نے عبدالعزیز بن ابی حازم سے ،  انہوں نے اور یعقوب بن عبدالرحمٰن دونوں نے اسی سند کے سا"}
{"hadithnumber": "4891", "text": "اسامہ بن زید نے بعجہ بن عبداللہ جہنی سے ،  انہوں نے ابوہریرہ رضی اللہ عنہ سے ،  انہوں نے نبی صلی الل"}
{"hadithnumber": "4892", "text": "محمد بن ابی عمر مکی نے ہمیں حدیث بیان کی ،  کہا :  ہمیں سفیان نے ابوزناد سے ،  انہوں نے اعرج سے ،  ا"}
{"hadithnumber": "4893", "text": "وکیع نے سفیان سے ،  انہوں نے ابوزناد سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی ۔"}
{"hadithnumber": "4894", "text": "ہمام بن منبہ سے روایت ہے ،  کہا :  یہ احادیث ہیں جو ابوہریرہ رضی اللہ عنہ نے ہمیں رسول اللہ صلی اللہ"}
{"hadithnumber": "4895", "text": "علاء کے والد نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :"}
{"hadithnumber": "4896", "text": "سہیل کے والد ابوصالح نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  کہا :  رسول اللہ صلی اللہ علیہ وسل"}
{"hadithnumber": "4897", "text": "جریر نے اعمش سے ،  انہوں نے ابوعمرو شیبانی سے ،  انہوں نے ابو مسعود انصاری رضی اللہ عنہ سے روایت کی"}
{"hadithnumber": "4898", "text": "زائدہ اور شعبہ دونوں نے اعمش سے اسی سند کے ساتھ روایت کی"}
{"hadithnumber": "4899", "text": "ابومعاویہ نے ہمیں اعمش سے حدیث بیان کی ،  انہوں نے ابوعمرو شیبانی سے ،  انہوں نے حضرت ابومسعود انصار"}
{"hadithnumber": "4900", "text": "عیسیٰ بن یونس ،  شعبہ اور سفیان سب نے اعمش سے اسی سند کے ساتھ روایت کی ۔"}
{"hadithnumber": "4901", "text": "ثابت نے حضرت انس بن مالک رضی اللہ عنہ سے حدیث سنائی کہ قبیلہ اسلم کے ایک نوجوان نے آ کر عرض کی :  ال"}
{"hadithnumber": "4902", "text": "بکیر بن اشج نے بسر بن سعید سے ،  انہوں نے حضرت زید بن خالد جہنی رضی اللہ عنہ سے اور انہوں نے رسول ال"}
{"hadithnumber": "4903", "text": "ابوسلمہ بن عبدالرحمٰن نے بسر بن سعید سے ،  انہوں نے حضرت زید بن خالد جہنی رضی اللہ عنہ سے روایت کی ،"}
{"hadithnumber": "4904", "text": "علی بن مبارک نے کہا :  ہمیں یحییٰ بن ابی کثیر نے حدیث بیان کی ،  کہا :  مجھے مہری کے مولیٰ ابوسعید ن"}
{"hadithnumber": "4907", "text": "مہری کے آزاد کردہ غلام یزید بن ابی سعید نے اپنے والد سے ،  انہوں نے حضرت ابوسعید خدری رضی اللہ عنہ س"}
{"hadithnumber": "4908", "text": "سفیان  ( ثوری )  نے علقمہ بن مرثد سے ،  انہوں نے سلیمان بن بریدہ سے ،  انہوں نے اپنے والد حضرت بریدہ"}
{"hadithnumber": "4909", "text": "مسعر نے ہمیں علقمہ بن مرثد سے حدیث بیان کی ،  انہوں نے ابن بریدہ سے ،  انہوں نے اپنے والد حضرت بریدہ"}
{"hadithnumber": "4910", "text": "قعنب نے علقمہ بن مرثد سے اسی سند کے ساتھ روایت کی :   \" اور فرمایا :   ( اسے کہا جائے گا کہ )  تم اس"}
{"hadithnumber": "4911", "text": "محمد بن مثنیٰ اور محمد بن بشار نے ہمیں حدیث بیان کی  ۔  ۔  الفاظ ابن مثنیٰ کے ہیں  ۔  ۔  دونوں نے کہ"}
{"hadithnumber": "4912", "text": "مسعر نے ابواسحاق سے ،  انہوں نے حضرت براء رضی اللہ عنہ سے روایت کی ،  کہا :  جب آیت :   \" مومنوں میں"}
{"hadithnumber": "4913", "text": "سعید بن عمرو اشعثی اور سعید بن سعید نے ہمیں حدیث بیان کی :   ۔  ۔  الفاظ سعید کے ہیں  ۔  ۔  کہا :  ہ"}
{"hadithnumber": "4914", "text": "حضرت براء رضی اللہ عنہ سے روایت ہے ،  کہا :  انصار کے ایک قبیلے ،  بنو نبیت میں سے ایک شخص  ( نبی صل"}
{"hadithnumber": "4915", "text": "ثابت نے حضرت انس بن مالک رضی اللہ عنہ سے روایت کی ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم نے ابوسفیان"}
{"hadithnumber": "4916", "text": "ابوبکر بن عبداللہ بن قیس سے روایت ہے ،  انہوں نے اپنے والد  ( حضرت ابوموسیٰ اشعری رضی اللہ عنہ )  سے"}
{"hadithnumber": "4917", "text": "ثابت نے حضرت انس بن مالک رضی اللہ عنہ سے روایت کی ،  کہا :  کچھ لوگ رسول اللہ صلی اللہ علیہ وسلم کی"}
{"hadithnumber": "4918", "text": "حضرت انس رضی اللہ عنہ نے کہا :  میرے چچا جن کے نام پر میرا نام رکھا گیا ہے ،  وہ رسول اللہ صلی اللہ"}
{"hadithnumber": "4919", "text": "عمرو بن مرہ نے کہا :  میں نے ابووائل  ( شقیق )  سے سنا ،  انہوں نے کہا :  ہمیں ابو موسیٰ اشعری رضی ا"}
{"hadithnumber": "4920", "text": "ابومعاویہ نے اعمش سے ،  انہوں نے شقیق سے ،  انہوں نے ابوموسیٰ اشعری رضی اللہ عنہ سے حدیث بیان کی کہ"}
{"hadithnumber": "4921", "text": "عیسیٰ بن یونس نے کہا :  ہمیں اعمش نے شقیق سے حدیث بیان کی ،  انہوں نے حضرت ابوموسیٰ اشعری رضی اللہ ع"}
{"hadithnumber": "4922", "text": "منصور نے ابووائل سے ،  انہوں نے حضرت ابوموسیٰ اشعری رضی اللہ عنہ سے روایت کی کہ ایک آدمی نے رسول الل"}
{"hadithnumber": "4923", "text": "خالد بن حارث نے کہا :  ہمیں ابن جریج نے حدیث بیان کی ،  کہا :  مجھے یونس بن یوسف نے سلیمان بن یسار س"}
{"hadithnumber": "4924", "text": "حجاج بن محمد نے ہمیں ابن جریج سے خبر دی ،  کہا :  مجھے یونس بن یوسف نے سلیمان بن یسار سے حدیث سنائی"}
{"hadithnumber": "4925", "text": "حیوہ بن شریح نے ابوہانی سے روایت کی ،  انہوں نے ابوعبدالرحمٰن حبلی سے ،  انہوں نے عبداللہ بن عمرو رض"}
{"hadithnumber": "4926", "text": "نافع بن یزید نے کہا :  مجھے ابوہانی نے حدیث بیان کی ،  کہا :  مجھے ابوعبدالرحمٰن حبلی نے حضرت عبدالل"}
{"hadithnumber": "4927", "text": "امام مالک نے یحییٰ بن سعید سے ،  انہوں نے محمد بن ابراہیم سے ،  انہوں نے علقمہ بن وقاص سے ،  انہوں ن"}
{"hadithnumber": "4928", "text": "لیث ،  حماد بن زید ،  عبدالوہاب ثقفی ،  سلیمان بن حیان ،  حفص بن غیاث ،  یزید بن ہارون ،  ابن مبارک"}
{"hadithnumber": "4929", "text": "حضرت انس رضی اللہ عنہ سے روایت ہے کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   \" جس شخص نے سچے دل س"}
{"hadithnumber": "4930", "text": "ابوطاہر اور حرملہ بن یحییٰ نے مجھے حدیث بیان کی  ۔  ۔  الفاظ حرملہ کے ہیں  ۔  ۔  ابوطاہر نے کہا :  ہ"}
{"hadithnumber": "4931", "text": "محمد بن عبدالرحمٰن بن سہم انطاکی نے کہا :  ہمیں عبداللہ بن مبارک نے وہیب مکی سے خبر دی ،  انہوں نے ع"}
{"hadithnumber": "4932", "text": "جریر نے اعمش سے ،  انہوں نے ابوسفیان سے ،  انہوں نے حضرت جابر رضی اللہ عنہ سے روایت کی ،  کہا :  ہم"}
{"hadithnumber": "4933", "text": "ابومعاویہ ،  وکیع اور عیسیٰ بن یونس سب نے اعمش سے اسی سند کے ساتھ روایت کی ،  مگر وکیع کی حدیث میں"}
{"hadithnumber": "4934", "text": "اسحٰق بن عبداللہ بن ابی طلحہ نے انس بن مالک رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ علیہ وسلم"}
{"hadithnumber": "4935", "text": "لیث نے یحییٰ بن سعید سے ،  انہوں نے ابن حبان سے ،  انہوں نے حضرت انس بن مالک رضی اللہ عنہ سے ،  انہو"}
{"hadithnumber": "4936", "text": "لیث نے یحییٰ بن سعید سے ،  انہوں نے ابن حبان سے ،  انہوں نے حضرت انس بن مالک رضی اللہ عنہ سے ،  انہو"}
{"hadithnumber": "4937", "text": "عبداللہ بن عبدالرحمٰن نے کہا کہ انہوں نے انس بن مالک رضی اللہ عنہ کو کہتے ہوئے سنا کہ رسول اللہ صلی"}
{"hadithnumber": "4938", "text": "لیث بن سعد نے ہمیں ایوب بن موسیٰ سے حدیث بیان کی ،  انہوں نے مکحول سے ،  انہوں نے شرجیل بن سمط سے ،"}
{"hadithnumber": "4939", "text": "ابوعبیدہ بن عقبہ نے شرجیل بن سمط سے ،  انہوں نے سلمان خیر رضی اللہ عنہ سے ،  انہوں نے رسول اللہ صلی"}
{"hadithnumber": "4940", "text": "سُمی نے ابوصالح سے ،  انہوں نے ابوہریرہ رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ علیہ وسلم نے"}
{"hadithnumber": "4941", "text": "جریر نے سہیل سے ،  انہوں نے اپنے والد  ( ابوصالح )  سے ،  انہوں نے ابوہریرہ رضی اللہ عنہ سے روایت کی"}
{"hadithnumber": "4942", "text": "خالد نے ہمیں سہیل سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی ،  البتہ ان کی حدیث میں ہے :  سہیل نے"}
{"hadithnumber": "4943", "text": "وہیب نے کہا :  ہمیں سہیل نے اسی سند کے ساتھ حدیث بیان کی ،  ان کی حدیث میں ہے ،  کہا :  مجھے عبیدالل"}
{"hadithnumber": "4944", "text": "عبدالواحد بن زیاد نے کہا :  ہمیں عاصم نے حفصہ بنت سیرین سے حدیث بیان کی ،  انہوں نے کہا :  حضرت انس"}
{"hadithnumber": "4945", "text": "علی بن مسہر نےعاصم سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی ۔"}
{"hadithnumber": "4946", "text": "ثمامہ بن شُفی سے روایت ہے ،  انہوں نے حضرت عقبہ بن عامر رضی اللہ عنہ کو یہ کہتے ہوئے سنا :  میں نے ر"}
{"hadithnumber": "4947", "text": "ابن وہب نے کہا :  مجھے عمرو بن حارث نے ابوعلی  ( ثمامہ بن شفی )  سے خبر دی ،  انہوں نے حضرت عقبہ بن"}
{"hadithnumber": "4948", "text": "حارث بن یعقوب نے عبدالرحمٰن بن شماسہ سے روایت کی کہ فُقَیم لخمی نے حضرت عقبہ بن عامر رضی اللہ عنہ سے"}
{"hadithnumber": "4949", "text": "حارث بن یعقوب نے عبدالرحمٰن بن شماسہ سے روایت کی کہ فُقَیم لخمی نے حضرت عقبہ بن عامر رضی اللہ عنہ سے"}
{"hadithnumber": "4950", "text": "حضرت ثوبان رضی ‌اللہ ‌عنہ  سے روایت ہے رسول اﷲ  صلی ‌اللہ ‌علیہ ‌وسلم  نے فرمایا ہمیشہ میری امت کا ا"}
{"hadithnumber": "4951", "text": "ترجمہ وہی جو اوپر گزرا۔  ( اس حدیث کا بیان کتاب الایمان میں گزرا ) ۔"}
{"hadithnumber": "4952", "text": "ترجمہ وہی جو اوپر گزرا۔"}
{"hadithnumber": "4953", "text": "جابر بن سمرہ رضی اﷲ عنہ سے روایت ہے رسول اﷲ  صلی ‌اللہ ‌علیہ ‌وسلم  نے فرمایا یہ دین برابر قائم رہے"}
{"hadithnumber": "4954", "text": "جابر بن عبداﷲ سے روایت ہے میں نے سنا رسول اﷲ  صلی ‌اللہ ‌علیہ ‌وسلم  سے آپ فرماتے تھے ہمیشہ ایک گروہ"}
{"hadithnumber": "4955", "text": "عمیر بن ہانی سے روایت ہے میں نے معاویہ رضی ‌اللہ ‌عنہ  سے سنا منبر پر، وہ کہتے تھے میں نے سنا رسول ا"}
{"hadithnumber": "4956", "text": "معاویہ رضی ‌اللہ ‌عنہ  سے روایت ہے رسول اﷲ  صلی ‌اللہ ‌علیہ ‌وسلم  نے فرمایا جس شخص کی اﷲ تعالیٰ بھل"}
{"hadithnumber": "4957", "text": "عبدالرحمن بن شماسہ مہری سے روایت ہے میں مسلمہ بن مخلدون کے پاس بیٹھا تھا ان کے پاس عبداﷲ بن عمرو بن"}
{"hadithnumber": "4958", "text": "سعد بن ابی وقاص رضی ‌اللہ ‌عنہ  سے روایت ہے رسول اﷲؐ نے فرمایا ہمیشہ مغرب والے  ( عینی عرب یا شام وا"}
{"hadithnumber": "4959", "text": "جریر نے سہیل سے ،  انہوں نے اپنے والد سے ،  انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  کہا :"}
{"hadithnumber": "4960", "text": "عبدالعزیز بن محمد نے سہیل سے ،  انہوں نے اپنے والد سے ،  انہوں نے ابوہریرہ رضی اللہ عنہ سے روایت کی"}
{"hadithnumber": "4961", "text": "یحییٰ بن یحییٰ تمیمی نے کہا :  میں نے امام مالک سے پوچھا :  سمی نے آپ کو ابوصالح کے واسطے سے ابوہریر"}
{"hadithnumber": "4962", "text": "یزید بن ہارون نے ہمام سے حدیث بیان کی ،  انہوں نے اسحٰق بن عبداللہ بن ابی طلحہ سے ،  انہوں نے حضرت ا"}
{"hadithnumber": "4963", "text": "عبدالصمد بن عبدالوارث نے کہا :  ہمیں حمام نے حدیث بیان کی ،  کہا :  ہمیں اسحٰق بن عبداللہ بن ابی طلح"}
{"hadithnumber": "4964", "text": "ہشیم نے سیار سے ،  انہوں نے  ( عامر )  شعبی سے ،  انہوں نے حضرت جابر بن عبداللہ رضی اللہ عنہ سے روای"}
{"hadithnumber": "4965", "text": "عبدالصمد نے کہا :  ہمیں شعبہ نے سیار سے حدیث بیان کی ،  انہوں نے عامر  ( شعبی )  سے ،  انہوں نے حضرت"}
{"hadithnumber": "4966", "text": "رَوح بن عبادہ نے کہا :  ہمیں شعبہ نے حدیث بیان کی ،  کہا :  ہمیں سیار نے اسی سند کے ساتھ اسی کے مانن"}
{"hadithnumber": "4967", "text": "محمد بن جعفر نے کہا :  ہمیں شعبہ نے عاصم سے حدیث بیان کی ،  انہوں نے شعبی سے ،  انہوں نے حضرت جابر ب"}
