{"hadithnumber": "2719", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ابوہریرہ! علم فرائض سیکھ"}
{"hadithnumber": "2720", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  سعد بن ربیع رضی اللہ عنہ کی بیوی ان کی دونوں بیٹیوں کو ل"}
{"hadithnumber": "2721", "text": "ہذیل بن شرحبیل رضی اللہ عنہ کہتے ہیں کہ  ایک آدمی ابوموسیٰ اشعری اور سلمان بن ربیعہ باہلی رضی اللہ"}
{"hadithnumber": "2722", "text": "معقل بن یسار مزنی رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم سے سنا، آپ کے پاس تر"}
{"hadithnumber": "2723", "text": "معقل بن یسار مزنی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ہمارے خاندان کے ایک دادا"}
{"hadithnumber": "2724", "text": "قبیصہ بن ذویب رضی اللہ عنہ کہتے ہیں کہ  ایک نانی ابوبکر رضی اللہ عنہ کے پاس اپنا حصہ مانگنے آئی، تو"}
{"hadithnumber": "2725", "text": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے دادی و نانی کو چھٹے ح"}
{"hadithnumber": "2726", "text": "معدان بن ابی طلحہ یعمری سے روایت ہے کہ  عمر بن خطاب رضی اللہ عنہ جمعہ کے دن خطبہ دینے کے لیے کھڑے ہو"}
{"hadithnumber": "2727", "text": "مرہ بن شراحیل کہتے ہیں کہ  عمر رضی اللہ عنہ نے کہا: تین باتیں ایسی ہیں کہ اگر رسول اللہ صلی اللہ علی"}
{"hadithnumber": "2728", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  میں بیمار ہوا تو میرے پاس رسول اللہ صلی اللہ علیہ وسلم ع"}
{"hadithnumber": "2729", "text": "اسامہ بن زید رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  مسلمان کافر کا وارث"}
{"hadithnumber": "2730", "text": "اسامہ بن زید رضی اللہ عنہما سے روایت ہے کہ  انہوں نے عرض کیا: اللہ کے رسول! کیا آپ مکہ میں اپنے گھر"}
{"hadithnumber": "2731", "text": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  دو مذہ"}
{"hadithnumber": "2732", "text": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  رباب بن حذیفہ بن سعید بن سہم نے ام وائل بنت معم"}
{"hadithnumber": "2733", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم کا ایک غلام کھجور کے درخ"}
{"hadithnumber": "2734", "text": "عبداللہ بن شداد کی اخیافی بہن بنت حمزہ کہتی ہیں کہ  میرا ایک غلام فوت ہو گیا، اس نے ایک بیٹی چھوڑی،"}
{"hadithnumber": "2735", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  قاتل وارث نہ ہو گا ۔"}
{"hadithnumber": "2736", "text": "عبداللہ بن عمرو رضی اللہ عنہا سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم فتح مکہ کے دن خطبہ کے لیے"}
{"hadithnumber": "2737", "text": "ابوامامہ بن سہل بن حنیف رضی اللہ عنہ سے روایت ہے کہ  ایک شخص نے دوسرے شخص کو تیر مارا، جس سے وہ مر گ"}
{"hadithnumber": "2738", "text": "مقدام ابوکریمہ رضی اللہ عنہ (جو اہل شام میں سے تھے اور رسول اللہ صلی اللہ علیہ وسلم کے اصحاب میں سے"}
{"hadithnumber": "2739", "text": "علی بن ابی طالب رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  سگے بھائی ایک دوس"}
{"hadithnumber": "2740", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مال کو اللہ کی"}
{"hadithnumber": "2741", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے زمانے میں ایک شخص مر گیا"}
{"hadithnumber": "2742", "text": "واثلہ بن اسقع رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  عورت تین میراث حاصل"}
{"hadithnumber": "2743", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  جب لعان کی آیت نازل ہوئی تو رسول اللہ صلی اللہ علیہ وسلم نے فرما"}
{"hadithnumber": "2744", "text": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہعلیہ وسلم  نے فرمایا:  کسی شخص"}
{"hadithnumber": "2745", "text": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس شخص"}
{"hadithnumber": "2746", "text": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس بچے"}
{"hadithnumber": "2747", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے حق ولاء  ( میراث )  کو بی"}
{"hadithnumber": "2748", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے حق ولاء  ( میراث )  کو بی"}
{"hadithnumber": "2749", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو میراث زمانہ ج"}
{"hadithnumber": "2750", "text": "جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  بچہ پیدائش کے وقت رو دے تو ا"}
{"hadithnumber": "2751", "text": "جابر بن عبداللہ اور مسور بن مخرمہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا"}
{"hadithnumber": "2752", "text": "عبداللہ بن موہب کہتے ہیں کہ  میں نے تمیم داری رضی اللہ عنہ کو کہتے سنا کہ میں نے عرض کیا: اللہ کے رس"}
