{"hadithnumber": "1009", "text": "حضرت عبداللہ بن عباس رضی اللہ عنہ سے روایت ہے کہ بے شک حضرت سعد بن عبادہ رضی اللہ عنہ نے رسول اللہ ﷺ"}
{"hadithnumber": "1010", "text": "عبداللہ بن ابی بکر رحمہ اللہ ( بن محمد بن عمرو بن حزم ) اپنی پھوپھی سے روایت کرتے ہیں ، انھوں نے عبد"}
{"hadithnumber": "1011", "text": "عبداللہ بن ابی حبیبہ رحمہ اللہ سے روایت ہے ، کہتے ہیں کہ میں نے ایک شخص سے کہا ، اس حال میں کہ میں ا"}
{"hadithnumber": "1012", "text": "عروہ بن اُذَیْنہ لَیثی رحمہ اللہ سے روایت ہے ، کہتے ہیں کہ میں اپنی دادی کے ساتھ نکلا ، ان پر بیت ال"}
{"hadithnumber": "1014", "text": "یحیی بن سعید رحمہ اللہ سے روایت ہے ، کہتے ہیں کہ مجھ پر ( ایک نذر کے سلسلے میں ) پیدل چلنا لازم تھا"}
{"hadithnumber": "1015", "text": "حمید بن قیس رحمہ اللہ اور ثور بن زید دیلی رحمہ اللہ رسول اللہ ﷺ سے روایت کرتے ہیں اور ان دونوں میں س"}
{"hadithnumber": "1016", "text": "قاسم بن محمد رحمہ اللہ سے روایت ہے کہ ایک عورت حضرت عبداللہ بن عباس رضی اللہ عنہ کے پاس آ کر کہنے لگ"}
{"hadithnumber": "1017", "text": "سیدہ عائشہ رضی اللہ عنہا سے روایت ہے کہ بے شک رسول اللہ ﷺ نے فرمایا :’’ جس شخص نے یہ نذر مانی کہ وہ"}
{"hadithnumber": "1018", "text": "سیدہ عائشہ ام المؤمنین رضی اللہ عنہا سے روایت ہے ، وہ کہا کرتی تھیں کہ لغو قسم سے مراد آدمی کا ( با"}
{"hadithnumber": "1019", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہ سے روایت ہے ، وہ فرمایا کرتے تھے کہ جس شخص نے کہا : اللہ کی قسم ! پ"}
{"hadithnumber": "1020", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ بے شک رسول اللہ ﷺ نے فرمایا :’’ جس شخص نے ( کسی کام پر ) ک"}
{"hadithnumber": "1021", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہ سے روایت ہے ، وہ کہا کرتے تھے کہ جس شخص نے کوئی قسم کھائی اور اس می"}
{"hadithnumber": "1022", "text": "سلیمان بن یسار رحمہ اللہ سے روایت ہے ، کہتے ہیں کہ میں نے لوگوں کو اس حال میں پایا کہ جب وہ قسم کا ک"}
{"hadithnumber": "1023", "text": "نافع رحمہ اللہ حضرت عبداللہ بن عمر رضی اللہ عنہ سے روایت کرتے ہیں کہ بے شک وہ اپنی قسم ( کو پختہ اور"}
{"hadithnumber": "1024", "text": "حضرت ابن عمر رضی اللہ عنہ سے روایت ہے کہ بے شک رسول اللہ ﷺ نے حضرت عمر بن خطاب رضی اللہ عنہ کو اس حا"}
{"hadithnumber": "1025", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ بلاشبہ رسول اللہ ﷺ یہ قسم کھایا کرتے تھے : ( لَا وَمُقَلِّبِ"}
{"hadithnumber": "1026", "text": "ابن شہاب رحمہ اللہ سے مروی ہے ، انھیں یہ خبر پہنچی کہ حضرت ابولبابہ بن عبدالمنذر رضی اللہ عنہ پر جب"}
{"hadithnumber": "1027", "text": "سیدہ عائشہ اُمّ المؤمنین رضی اللہ عنہ سے روایت ہے ، ان سے اس شخص کے متعلق سوال کیا گیا جو یہ کہتا ہ"}
