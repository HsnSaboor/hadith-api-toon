{"hadithnumber": "2343", "text": "یعقوب بن عبد الرحمٰن القاری نے سہیل سے انھوں نے  اپنے والد  (  ابو صالح  )  سے اور انھوں نے حضرت ابو"}
{"hadithnumber": "2344", "text": "روح بن قاسم اور سلیما ن بن بلال دو نوں نے سہیل سے اسی سند کے ساتھ  ( مذکور ہ با لا  )  حدیث بیان کی"}
{"hadithnumber": "2345", "text": "ہشا م بن سعد نے زید بن اسلم سے انھوں نے ابو صالح سے انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے"}
{"hadithnumber": "2346", "text": "حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روا یت ہے انھوں نے کہا رسول اللہ  صلی اللہ علیہ وسلم  نے فر م"}
{"hadithnumber": "2347", "text": "عبد اللہ بن معقل نے حضرت عدیبن حاتم رضی اللہ تعالیٰ عنہ  سے روا یت کی ،  انھوں نے کہا :  رسول اللہ"}
{"hadithnumber": "2348", "text": "علی بن حجر سعدی اسحاق بن ابرا ہیم اور علی بن خشرم میں سے علی بن حجر نے کہا :  ہمیں عیسیٰ بن یو نس نے"}
{"hadithnumber": "2349", "text": "ابو بکر بن ابی شیبہ اور ابو کریب دو نوں نے کہا  :  ہمیں ابو معاویہ نے اعمش سے حدیث بیان کی انھوں نے"}
{"hadithnumber": "2350", "text": "شعبہ نے عمرو بن مرہ سے با قی ماندہ سابقہ سند کے ساتھ روایت کی کہ آپ  صلی اللہ علیہ وسلم  نے آگ کا ذک"}
{"hadithnumber": "2351", "text": "محمد بن جعفر نے کہا  :  ہمیں شعبہ نے عون بن ابی جحیفہ سے حدیث بیان کی  ، ا نھوں نے منذر بن جریر سے ا"}
{"hadithnumber": "2352", "text": "ابو اسامہ اور معاذ عنبری دو نوں نے کہا  :  ہمیں شعبہ نے حدیث بیا ن کی  ، ا نھوں نے کہا مجھے عون بن ا"}
{"hadithnumber": "2353", "text": "عبدالملک بن عمیر نے منذر بن جریر سے اور انھوں نےاپنے والد سے روایت کی ، انھوں نے کہا : میں نبی اکرم"}
{"hadithnumber": "2354", "text": "عبدالرحمان بن ہلال عبسی نے حضرت جریر بن عبداللہ  رضی اللہ تعالیٰ عنہ  سے روایت کی ، انھوں نے کہا : ب"}
{"hadithnumber": "2355", "text": "یحییٰ بن معین اور بشر بن خالد نے ۔ لفظ بشر کے ہیں ۔ حدیث بیان کی ، کہا : ہمیں محمد بن جعفر ( غندر )"}
{"hadithnumber": "2356", "text": "سعید بن ربیع اورابو داود دونوں نے شبعہ سے باقی ماندہ اسی سند کے ساتھ حدیث بیا ن کی اور سعید بن ربیع"}
{"hadithnumber": "2357", "text": "حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت ہے ، وہ اسے  ( آپ صلی اللہ علیہ وسلم  تک )  پہنچاتے تھے"}
{"hadithnumber": "2358", "text": "حضرت ابو ہریرہ  رضی اللہ تعالیٰ عنہ  نے نبی اکرم  صلی اللہ علیہ وسلم  سے روایت کی کہ آپ نے ( کچھ اشی"}
{"hadithnumber": "2359", "text": "ابو زناد نے اعرج سے ، انھوں نے حضرت ابو  ہریرہ رضی اللہ تعالیٰ عنہ  سے اور انھوں نے نبی کریم  صلی ال"}
{"hadithnumber": "2360", "text": "ابراہیم بن نافع نے حسن بن مسلم سے ، انھوں نے طاوس سے اور انھوں نے حضرت ابو ہریرہ  رضی اللہ تعالیٰ عن"}
{"hadithnumber": "2361", "text": "عبداللہ بن طاوس نے اپنے والد سے اور انھوں نے حضرت ابو ہریرہ  رضی اللہ تعالیٰ عنہ  سے روایت کی ، انھو"}
{"hadithnumber": "2362", "text": "حضرت ابو ہریرہ  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ نبی اکرم  صلی اللہ علیہ وسلم  نے فرمایا :  \" ایک"}
{"hadithnumber": "2363", "text": "حضرت ابو موسیٰ  رضی اللہ تعالیٰ عنہ  نے نبی اکرم  صلی اللہ علیہ وسلم  سے روایت کی ، آپ صلی اللہ علیہ"}
{"hadithnumber": "2364", "text": "جریر نے منصور سے ، انھوں نے شقیق سے ، انھوں نے مسروق سے اور انھوں نے حضرت عائشہ  رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "2365", "text": "فضیل بن عیاض نے منصور سے اسی سند کے ساتھ ( سابقہ حدیث کے مانند )  روایت کی اور انھوں نے  (  \" اپنے گ"}
{"hadithnumber": "2366", "text": "ابو بکر بن ابی شیبہ نے کہا : ابو معاویہ نے ہمیں اعمش سے حدیث بیان کی ، انھوں نے شقیق سے ، انھوں نے م"}
{"hadithnumber": "2367", "text": "ابن نمیر نے کہا : ہمیں میرے والد اور با معاویہ نے اعمش سے اسی ( مذکورہ بالا )  سند کے ساتھ اسی طرح ح"}
{"hadithnumber": "2368", "text": "محمد بن زید نے آبی اللحم ( غفاری  )   رضی اللہ تعالیٰ عنہ  کے آزاد کردہ غلام عمیر  رضی اللہ تعالیٰ ع"}
{"hadithnumber": "2369", "text": "یزید بن ابی عبید نے کہا :  میں نے آبی اللحم  رضی اللہ تعالیٰ عنہ  کے آزاد کردہ غلام عمیر رضی اللہ تع"}
{"hadithnumber": "2370", "text": "ہمام بن منبہ سے ر وایت ہے  ، کہا : یہ وہ احادیث ہیں جو ابو ہریرہ رضی اللہ تعالیٰ عنہ  نے ہمیں محمد ر"}
{"hadithnumber": "2371", "text": "یونس نے ابن شہاب سے ، انھوں نے حمید بن عبدالرحمان سے اور انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "2372", "text": "صالح اور معمر دونوں نے زہری سے یونس کی مذکورہ بالا سند کے ساتھ اسی کی حدیث کے ہم معنی حدیث بیا ن کی"}
{"hadithnumber": "2373", "text": "ابو سلمہ بن عبدالرحمان سے روایت ہےکہ انھوں نے حضرت ابو ہریرہ  رضی اللہ تعالیٰ عنہ  سے سنا ،  وہ کہہ"}
{"hadithnumber": "2374", "text": "حضرت ابو ہریرہ   رضی اللہ تعالیٰ عنہ  سے روایت ہے  ، انھوں نے کہا :  رسول اللہ  صلی اللہ علیہ وسلم"}
{"hadithnumber": "2375", "text": "حفص بن غیا ث نے ہشام سے انھوں نے فا طمہ بنت منذر سے اور انھوں نے حضرت اسماء بنت ابی بکر رضی اللہ تعا"}
{"hadithnumber": "2376", "text": "محمد بن خازم نے حدیث بیان کی کہا  :  ہمیں ہشام بن عروہ نے عبادبن حمزہ اور فا طمہ بنت منذر حدیث بیان"}
{"hadithnumber": "2377", "text": "محمد بن بشر نے کہا  : ہمیں ہشا م نے عبا د بن حمزہ سے حدیث بیان کی  ،  انھوں نے حضرت اسما رضی اللہ تع"}
{"hadithnumber": "2378", "text": "عباد بن عبد اللہ بن زبیر نے خبر دی کہ انھوں نے حضرت اسماء بنت ابی بکر  رضی اللہ تعالیٰ عنہ  سے روایت"}
{"hadithnumber": "2379", "text": "حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ رسول اللہ  صلی اللہ علیہ وسلم  فر ما یا کرتے تھے"}
{"hadithnumber": "2380", "text": "عبید اللہ سے روایت ہے کہا  :  مجھے خبیب بن عبد الرحمٰن نے حفص بن عاصم سے خبردی انھوں نے حضرت ابو ہری"}
{"hadithnumber": "2382", "text": "جریر نے عمارہ بن قعقاع سے انھوں نے ابو زرعہ سے اور انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے ر"}
{"hadithnumber": "2383", "text": "ابن فضیل نے عمارہ سے انھوں نے ابو زرعہ سے انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی ،"}
{"hadithnumber": "2384", "text": "عبد الو حد نے کہا  :  ہم سے عمارہ بن قعقاع نے  (  باقی ماند ہ )  اسی سند کے ساتھ جریر کی حدیث کی طرح"}
{"hadithnumber": "2385", "text": "حضرت عبد اللہ بن عمر رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ رسول اللہ  صلی اللہ علیہ وسلم  نے فر ما یا"}
{"hadithnumber": "2386", "text": "حضرت حکیم بن حزام رضی اللہ تعالیٰ عنہ  نے بیان کیا کہ رسول اللہ  صلی اللہ علیہ وسلم  نے فر ما یا  :"}
{"hadithnumber": "2387", "text": "حضرت حکیم بن حزام  رضی اللہ تعالیٰ عنہ  سے روا یت ہے انھوں نے کہا میں نے رسول اللہ  صلی اللہ علیہ وس"}
{"hadithnumber": "2388", "text": "حضرت ابو امامہ  رضی اللہ تعالیٰ عنہ  نے کہا  :  رسول اللہ  صلی اللہ علیہ وسلم  نے فر ما یا  :  \"  آد"}
{"hadithnumber": "2389", "text": "عبد اللہ بن عامر یحصبی نے کہا میں نے حضرت معاویہ  رضی اللہ تعالیٰ عنہ  کو کہتے ہو ئے سنا  : تم اس حد"}
{"hadithnumber": "2390", "text": "محمد بن عبد اللہ بن نمیر نے کہا  :  ہمیں سفیان نے عمرو  (  بن دینار  )  سے حدیث بیا ن کی انھوں نے وہ"}
{"hadithnumber": "2391", "text": "ابن ابی عمر مکی نے کہا  :  ہمیں سفیان نے عمرو بن دینار سے حدیث سنا ئی کہا  :  مجھے وہب بن منبہ نے  ۔"}
{"hadithnumber": "2392", "text": "حمید بن عبد الرحمٰن بن عوف نے کہا  :  میں نے حضرت معاویہ بن ابی سفیان رضی اللہ تعالیٰ عنہ  سے سنا وہ"}
{"hadithnumber": "2393", "text": "اعرج نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی کہ رسول اللہ  صلی اللہ علیہ وسلم  نے فر ما ی"}
{"hadithnumber": "2394", "text": "اسماعیل نے جو ابن جعفر ( بن ابی کثیر )  ہیں ، کہا : مجھے شریک نے حضرت میمونہ  رضی اللہ تعالیٰ عنہا"}
{"hadithnumber": "2395", "text": "محمد بن جعفر ( بن ابی کثیر )  نے کہا :  مجھے شریک نے خبر دی ، کہا :   مجھے عطاء بن یسار اور عبدالرحم"}
{"hadithnumber": "2396", "text": "عبدالاعلیٰ بن عبدالاعلیٰ نے معمر سے ، انھوں نے ( امام زہری کے بھائی )  عبداللہ بن مسلم سے ، انھوں نے"}
{"hadithnumber": "2397", "text": "اسماعیل بن ابراہیم نے معمر سے اسی سند کے ساتھ یہی روایت بیان کی اور اس میں  ( گوشت کے )  ٹکڑے کے الف"}
{"hadithnumber": "2398", "text": "عبیداللہ بن ابی جعفر نے حمزہ بن عبداللہ بن عمر سے روایت کی کہ انھوں نے اپنے والد کو یہ کہتے ہوئے سنا"}
{"hadithnumber": "2399", "text": "حضرت ابو ہریرہ  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ رسول اللہ  صلی اللہ علیہ وسلم  نے فرمایا :  \" جو"}
{"hadithnumber": "2400", "text": "بیان بن ابی بشر نے قیس بن ابی حازم سے اور انھوں نے حضرت ابو ہریرۃ  رضی اللہ تعالیٰ عنہ  سے روایت کی"}
{"hadithnumber": "2401", "text": "اسماعیل نے کہا : مجھے قیس بن ابی حازم نے حدیث سنائی ، انھوں نے کہا : ہم حضر ت ابو ہریرہ رضی اللہ تعا"}
{"hadithnumber": "2402", "text": "حضرت عبدالرحمان بن عوف  رضی اللہ تعالیٰ عنہ  کے آزادکردہ غلام ابو عبید سے  روایت کی کہ انھوں نے حضرت"}
{"hadithnumber": "2403", "text": "ابو مسلم خولانی سے روایت ہے  ، انھوں نے کہا : مجھ سے ایک پیارے امانت دار ( شخص )  نے حدیث بیان کی وہ"}
{"hadithnumber": "2404", "text": "حضرت قبیصہ بن مخارق ہلالی  رضی اللہ تعالیٰ عنہ  سے روایت ہے ، انھوں نے کہا : میں نے ( لوگوں کے معامل"}
{"hadithnumber": "2405", "text": "یونس نے ابن شہاب سے ،  انہوں نے سالم بن عبداللہ بن عمر رضی اللہ تعالیٰ عنہ  سے اور انھوں نے اپنے وال"}
{"hadithnumber": "2406", "text": "عمرو بن حارث نے ابن شہاب سے ، انھوں نے سالم سے اور انھوں نے اپنے والد حضرت عبداللہ  رضی اللہ تعالیٰ"}
{"hadithnumber": "2407", "text": "سائب بن یزید نے عبداللہ بن سعدی سے ، انھوں نے حضرت عمر بن خطاب  رضی اللہ تعالیٰ عنہ  سے اور انھوں نے"}
{"hadithnumber": "2408", "text": "لیث نے بکیر سے ، انھوں نے بسر بن سعید سے اور انھوں نے ابن ساعدی مالکی سے روایت کی کہ انھوں نے کہا :"}
{"hadithnumber": "2409", "text": "عمرو بن حارث نے بکیر بن اشج سے ،  انھوں نے بسر بن سعید سے اور انھوں نے ابن سعدی سے روایت کی کہ انھوں"}
{"hadithnumber": "2410", "text": "اعرج نےحضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی ، انھوں نے اسے نبی اکرم  صلی اللہ علیہ وسلم"}
{"hadithnumber": "2411", "text": "سعید بن مسیب نے حضرت ابو ہریرہ  رضی اللہ تعالیٰ عنہ  سے روایت کی کہ  رسول اللہ  صلی اللہ علیہ وسلم"}
{"hadithnumber": "2412", "text": "ابوعوانہ نے قتادہ سے اور انھوں نے حضرت انس رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا : رسول اللہ  صلی ا"}
{"hadithnumber": "2413", "text": "معاذ بن ہشام کے والد ہشام نے قتادہ سے اور انھوں نے حضرت انس رضی اللہ تعالیٰ عنہ  سے روایت کی کہ رسول"}
{"hadithnumber": "2414", "text": "شعبہ نے کہا :  میں نے قتادہ سے سنا ، وہ حضرت انس بن مالک  رضی اللہ تعالیٰ عنہ  سے حدیث بیان کررہے تھ"}
{"hadithnumber": "2415", "text": "ابو عوانہ نے قتادہ سے انھوں نے حضرت انس  رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہا :  رسول اللہ  صلی ا"}
{"hadithnumber": "2416", "text": "شعبہ نے کہا  :  قتادہ سے سنا وہ حضرت انس  رضی اللہ تعالیٰ عنہ  سے روایت کر رہے تھے کہا  :  میں نے رس"}
{"hadithnumber": "2417", "text": "ابن شہاب نے حضرت انس بن مالک  رضی اللہ تعالیٰ عنہ  سے اور انھوں نے رسول اللہ  صلی اللہ علیہ وسلم  سے"}
{"hadithnumber": "2418", "text": "مجھے زہیر بن حرب اور ہا رون بن عبد اللہ نے حدیث سنا ئی دو نوں نے کہا  : ہمیں حجا ج بن محمد نے ابن جر"}
{"hadithnumber": "2419", "text": "ابو حرب بن ابی اسود  کے والد سے روایت ہے انھوں نے کہا :  حضرت ابو موسیٰ اشعری رضی اللہ تعالیٰ عنہ  ن"}
{"hadithnumber": "2420", "text": "حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت ہے انھوں نے کہا :  رسول اللہ  صلی اللہ علیہ وسلم  نے فر"}
{"hadithnumber": "2421", "text": "عیاض بن عبد اللہ بن سعد سے روایت ہے کہ انھوں نے حضرت ابو سعید خدری رضی اللہ تعالیٰ عنہ  سے سنا وہ کہ"}
{"hadithnumber": "2422", "text": "زید بن اسلم نے عطا ء بن یسار سے اور انھوں نے حضرت خدری رضی اللہ تعالیٰ عنہ  سے روا یت کی کہ رسول الل"}
{"hadithnumber": "2423", "text": "ہلال بن ابی میمونہ نے عطا ء بن یسار سے اور انھوں نے حضرت ابو سعید خدری رضی اللہ تعالیٰ عنہ  سے روایت"}
{"hadithnumber": "2424", "text": "امام مالک بن انس نے ابن شہاب زہری سے انھوں نے عطا ء بن یزید لیثی سے اور انھوں نے حضرت ابو سعید خدری"}
{"hadithnumber": "2425", "text": "معمر نے زہری سے اسی سند کے ساتھ اسی طرح روایت کی  ۔"}
{"hadithnumber": "2426", "text": "حضرت عبد اللہ بن عمرو بن عاص رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ رسول اللہ   صلی اللہ علیہ وسلم  نے"}
{"hadithnumber": "2427", "text": "حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ رسول اللہ   صلی اللہ علیہ وسلم  نے فر ما یا  ( دع"}
{"hadithnumber": "2428", "text": "حضرت عمر بن خطا ب رضی اللہ تعالیٰ عنہ  نے کہا کہ رسول اللہ   صلی اللہ علیہ وسلم  نے کچھ مال تقسیم کی"}
{"hadithnumber": "2429", "text": "امام مالک بن انس نے اسحاق بن عبد اللہ بن ابی طلحہ سے اور انھوں نے حضرت انس بن مالک  رضی اللہ تعالیٰ"}
{"hadithnumber": "2430", "text": "ہمام عکرمہ بن عماراور اوزاعی سب نے اسحاق بن عبد اللہ بن ابی طلحہ سے انھوں نے حضرت انس بن مالک  رضی ا"}
{"hadithnumber": "2431", "text": "لیث نے  (  عبد اللہ  )  بن ابی ملیکہ سے اور انھوں نے حضرت مسور بن مخرمہ  رضی اللہ تعالیٰ عنہ  سے روا"}
{"hadithnumber": "2432", "text": "ایو ب سختیا نی نے عبد اللہ بن ابی ملیکہ سے اور انھوں نے حضڑت مسور بن مخرمہ رضی اللہ تعالیٰ عنہ  سے ر"}
{"hadithnumber": "2433", "text": "حسن بن علی حلوانی اور عبدبن حمید نے کہا  :  ہمیں یعقوب بن ابرا ہیم بن سعد  نے حدیث سنا ئی کہا میرے و"}
{"hadithnumber": "2434", "text": "سفیان ثوری ابن شہاب  ( زہری )  کے بھتیجے  ( محمد بن عبد اللہ بن شہاب )  اور معمر سب نے  ( زہری )  سے"}
{"hadithnumber": "2435", "text": "محمد بن سعد یہ حدیث بیان کرتے ہیں یعنی زہری مذکورہ با لا حدیث انھوں نے اپنی حدیث میں کہا :  تو رسول"}
{"hadithnumber": "2436", "text": "یونس نے ابن شہاب ( زہری )  سے خبر دی  ، کہا : مجھے حضرت انس بن مالک  رضی اللہ تعالیٰ عنہ  نے بتایا ک"}
{"hadithnumber": "2437", "text": "صالح نے ابن شہاب  ( زہری  )  سے روایت کی ، کہا : مجھ حضرت انس بن مالک رضی اللہ تعالیٰ عنہ  نے حدیث ب"}
{"hadithnumber": "2438", "text": "ابن شہاب کے بھتیجے ( محمد بن عبداللہ )  نے اپنے چچا سے خبر دی ، کہا : مجھے حضرت انس  بن مالک رضی الل"}
{"hadithnumber": "2439", "text": "قتادہ حضرت  انس بن مالک رضی اللہ تعالیٰ عنہ  سے حدیث بیان کرتے ہیں ، انھوں نے کہا : رسول اللہ   صلی"}
{"hadithnumber": "2440", "text": "ابوتیاح سے روایت ہے ، انھوں نے کہا : میں نے حضرت انس بن مالک  رضی اللہ تعالیٰ عنہ  سے سنا ، انھوں نے"}
{"hadithnumber": "2441", "text": "ہشام بن زید بن انس نےحضرت انس بن مالک رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا : جب حنین کی جنگ ہوئی ت"}
{"hadithnumber": "2442", "text": "سمیط نےحضرت انس بن مالک  رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا : ہم نے مکہ فتح کرلیا ، پھر ہم نے حن"}
{"hadithnumber": "2443", "text": "محمد بن ابی عمر مکی نے کہا : سفیان ( بن عینیہ )  نے ہمیں عمر بن سعید بن مسروق سےحدیث بیان کی ، انہوں"}
{"hadithnumber": "2444", "text": "احمد بن عبدہ ضبی نے کہا : ہمیں  ) سفیان ( بن عینیہ  نے عمر بن سعید بن مسروق سے اسی سند کے ساتھ خبر د"}
{"hadithnumber": "2445", "text": "مخلد بن خالد شعیری نے کہا : ہمیں سفیان ( بن عینیہ )  نے  حدیث سنائی ، کہا : مجھے عمر بن سعید نے اسی"}
{"hadithnumber": "2446", "text": "عمرو بن یحییٰ بن عمارہ نے عباد بن تمیم سے ، انھوں نے حضرت عبداللہ بن زید رضی اللہ تعالیٰ عنہ  سے روا"}
{"hadithnumber": "2447", "text": "منصور نے ابو وائل ( شقیق )  سے اور انھوں نے حضرت عبداللہ ( بن مسعود )  رضی اللہ تعالیٰ عنہ  سے روایت"}
{"hadithnumber": "2448", "text": "اعمش نے ( ابو وائل )  شقیق سے اور ا نھوں نے حضرت عبداللہ  رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا : ر"}
{"hadithnumber": "2449", "text": "لیث نے یحییٰ بن سعید سے حدیث بیا ن کی ، انھوں نے ابو زبیر سے اور انھوں نے حضرت جابر بن عبداللہ  رضی"}
{"hadithnumber": "2450", "text": "عبدالوہاب ثقفی نے کہا : میں نے یحییٰ بن سعید سے سنا ،  کہہ رہے تھے : مجھے ابو زبیر نے بتایا کہ انھوں"}
{"hadithnumber": "2451", "text": "سعید بن مسروق نے عبدالرحمان بن ابی نعم سے اور انھوں نے حضرت ابو سعید خدری  رضی اللہ تعالیٰ عنہ  سے"}
{"hadithnumber": "2452", "text": "عبدالواحد نے عمارہ بن قعقاع سے ر وایت کی ، انھوں نے کہا : ہمیں عبدالرحمان بن نعیم نے حدیث بیان کی ،"}
{"hadithnumber": "2453", "text": "جریر نے عمارہ بن قعقاع سے اسی سند کے ساتھ حدیث بیان کی ، انھوں نے علقمہ بن علاثہ کاذکر کیا اور عامر"}
{"hadithnumber": "2454", "text": "عمارہ بن قعقاع کے ایک دوسرے شاگرد ابن فضیل نے اسی سند کے ساتھ یہ حدیث بیان کی اور کہا :  ( رسول اللہ"}
{"hadithnumber": "2455", "text": "محمد بن ابراہیم نے ابو سلمہ اورعطاء بن یسار سے روایت کی کہ وہ دونوں حضرت ابو سعید خدری  رضی اللہ تعا"}
{"hadithnumber": "2456", "text": "ابن شہاب سے روایت ہے ، کہا : مجھے ابو سلمہ بن عبدالرحمان اورضحاک ہمدانی نے خبر دی کہ حضرت ابوسعید خد"}
{"hadithnumber": "2457", "text": "سلیمان بن ابو نضرہ سے اور انھوں نے حضرت ابو سعید خدری  رضی اللہ تعالیٰ عنہ   سے روایت کی کہ نبی اکرم"}
{"hadithnumber": "2458", "text": "قاسم بن فضل حدانی نے حدیث بیان کی  ، کہا : ہم سے ابو نضرہ نے حضرت ابو سعید خدری رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "2459", "text": "قتادہ نے ابو نضر ہ سے اور انھوں نے حضرت ابوسعید خدری  رضی اللہ تعالیٰ عنہ  سے روایت کی ، انھوں نے کہ"}
{"hadithnumber": "2460", "text": "داود نے ابونضرہ سے اور انھوں نے حضرت ابو سعید خدری  رضی اللہ تعالیٰ عنہ  سے روایت کی کہ رسول اللہ  ص"}
{"hadithnumber": "2461", "text": "ضحاک مشرقی نے  حضرت ابوسعید خدری  رضی اللہ تعالیٰ عنہ  سے اور انھوں نے نبی کریم  صلی اللہ علیہ وسلم"}
{"hadithnumber": "2462", "text": "وکیع نے حدیث بیان کی کہا اعمش نے ہمیں خیثمہ سے حدیث بیان کی  ،  انھوں نے سوید بن غفلہ سے روا یت کی ا"}
{"hadithnumber": "2463", "text": "عیسیٰ بن یو نس اور سفیان دو نوں نے اعمش سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی  ۔"}
{"hadithnumber": "2464", "text": "اعمش سے جریر اور ابو معاویہ نے اسی سند کے ساتھ روایت کی اور ان دو نوں کی حدیث میں  \" دین میں سے تیز"}
{"hadithnumber": "2465", "text": "ایو ب نے محمد سے انھوں نے عبیدہ سے اور انھوں نے حضرت علی رضی اللہ تعالیٰ عنہ  سے روایت کی انھوں نے خ"}
{"hadithnumber": "2466", "text": "ابن عون نے محمد سے اور انھوں نے عبیدہ سے روایت کی  ،  انھوں نے کہا میں تمھیں صرف وہی بیان کروں گا جو"}
{"hadithnumber": "2467", "text": "سلمہ بن کہیل نے کہا  : مجھے زید بن وہب جہنی ؒ نے حدیث سنا ئی کہ وہ اس لشکر میں شامل تھے جو حضرت علی"}
{"hadithnumber": "2468", "text": "ابو طا ہر اور یو نس بن عبد الاعلی دو نوں نے کہا ہمیں عبد اللہ بن وہب نے خبر دی انھوں نے کہا مجھے عمر"}
