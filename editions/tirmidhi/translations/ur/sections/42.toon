{"hadithnumber": "2688", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”قسم ہے اس ذات کی جس کے ہ"}
{"hadithnumber": "2689", "text": "عمران بن حصین رضی الله عنہ سے روایت ہے کہ  ایک شخص نے نبی اکرم صلی اللہ علیہ وسلم کے پاس آ کر کہا:"}
{"hadithnumber": "2690", "text": "ابو سعید خدری رضی الله عنہ کہتے ہیں کہ  ابوموسیٰ اشعری رضی الله عنہ نے عمر رضی الله عنہ سے ان کے پاس"}
{"hadithnumber": "2691", "text": "عمر بن خطاب رضی الله عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم سے آپ کے پاس آنے کی تین ب"}
{"hadithnumber": "2692", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  ایک شخص مسجد میں آیا  ( اس وقت )  رسول اللہ صلی اللہ علیہ وسلم م"}
{"hadithnumber": "2693", "text": "ام المؤمنین عائشہ رضی الله عنہا کا بیان ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے ان سے فرمایا: ”جبرائی"}
{"hadithnumber": "2694", "text": "ابوامامہ رضی الله عنہ کہتے ہیں کہ  پوچھا گیا: اللہ کے رسول! جب دو آدمی آپس میں ملیں تو سلام کرنے م"}
{"hadithnumber": "2695", "text": "عبداللہ بن عمرو بن عاص رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”وہ شخص"}
{"hadithnumber": "2696", "text": "سیار کہتے ہیں کہ  میں ثابت بنانی کے ساتھ جا رہا تھا، وہ بچوں کے پاس سے گزرے تو انہیں سلام کیا، ثابت"}
{"hadithnumber": "2697", "text": "اسماء بنت یزید رضی الله عنہا بیان کرتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ایک دن مسجد میں گزرے وہا"}
{"hadithnumber": "2698", "text": "انس بن مالک رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مجھ سے فرمایا: ”بیٹے! جب تم اپ"}
{"hadithnumber": "2699", "text": "جابر بن عبداللہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”بات چیت شروع کرنے"}
