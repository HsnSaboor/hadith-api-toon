{"hadithnumber": "1161", "text": "ابو کامل جحدری نے کہا :  ہمیں عبد الواحد نے اعمش سے حدیث  بیان کی ،  نیز ابو بکر بن ابی شیبہ  اور اب"}
{"hadithnumber": "1162", "text": "علی بن مسہر نے کہا :  ہمیں اعمش نے ابراہیم بن یزید تیمی سے حدیث سنائی ،  کہا :  میں مسجد کے باہر کھل"}
{"hadithnumber": "1163", "text": "یحییٰ بن یحییٰ نے بیان کیا کہ ہمیں ہشیم نے سیا ر سے خبر دی  ،  انہوں نے یزید الفقیر سے اور انہوں نے"}
{"hadithnumber": "1164", "text": "۔  ابو بکر بن ابی شیبہ نے ہشیم سے اسی سابقہ سند سے روایت کی کہ رسول اللہﷺ نے فمرایا :  ..... پھر اسی"}
{"hadithnumber": "1165", "text": "حذیفہ ‌رضی ‌اللہ ‌عنہ ‌سے ‌روایت ‌ہے ‌كہ ‌رسول ‌اللہ ‌صلی ‌اللہ ‌علیہ ‌وسلم ‌نے ‌فرمایا ‌ہم ‌لوگوں ‌"}
{"hadithnumber": "1166", "text": "۔   ابن ابی زائد نے  ( ابو مالک )  سعد بن طارق  ( اشجعی )  سے روایت کی ،  کہا :  مجھے ربعی بن حراش ن"}
{"hadithnumber": "1167", "text": "عبد الرحمان بن یعقوب نے حضرت ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ رسول اللہﷺ نے فرمایا :  ’"}
{"hadithnumber": "1168", "text": "۔  یونس نے ابن شہاب سے ،  انہوں نے سعید بن مسیب سے اور انہوں نے حضرت ابوہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  س"}
{"hadithnumber": "1169", "text": "۔  زبیدی نے  ( ابن شہاب )   زہری سے روایت کی  ،  انہوں نے  کہا :  مجھے سعید بن مسیب اور ابو سلمہ بن"}
{"hadithnumber": "1170", "text": "معمر نے زہری سے ،  انہوں نے ابن مسیب اور ابو سلمہ  ( بن عبد الرحمن )  سے ،  انہوں نے حضرت ابو ہریرہ"}
{"hadithnumber": "1171", "text": "۔   ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  کے آزاد کردہ غلام ابو یونس سے روایت ہے ۔  انہوں نے حضرت ابو ہریرہ"}
{"hadithnumber": "1172", "text": "ہمام بن منبہ  سے روایت ہے ،  کہا :  یہ احادیث ہیں جو حضرت ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے رسول الل"}
{"hadithnumber": "1173", "text": "۔  عبد الوارث  بن سعید نے ہمیں ابو تیاح صبعی سے خبر دی ،  انہوں نے کہا :  ہمیں حضرت انس بن مالک ‌رضی"}
{"hadithnumber": "1174", "text": "معاذ عنبری نے کہا :  ہمیں شعبہ نے حدیث سنائی ،  انہوں نے کہا :  مجھے ابوتیاح نے حضرت انس  ‌رضی ‌اللہ"}
{"hadithnumber": "1175", "text": "۔   ( معاذ کے بجائے )  خالد ،  یعنی ابن حارث نے روایت کی ،  کہا :  ہمیں  شعبہ نے ابو تیاح سے حدیث سن"}
{"hadithnumber": "1176", "text": "ابو احوص نے ابو اسحاق سے اور انہوں نے حضرت براء بن عازب  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی ،  کہا :"}
{"hadithnumber": "1177", "text": "سفیان  ( ثوری )  سے روایت ہے ،  کہا :  مجھے ابو اسحاق نے حدیث سنائی ،  کہا :  میں نے حضرت براء  ‌رضی"}
{"hadithnumber": "1178", "text": "۔   عبد العزیز  بن مسلم  اورمالک بن انس نے اپنی اپنی سندوں سے عبد اللہ بن دینار سے روایت کی ،  انہوں"}
{"hadithnumber": "1179", "text": "حضرت انس ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ رسول اللہ ﷺ بیت المقدس کی طرف منہ کر کے نماز پڑھا  کرتے"}
{"hadithnumber": "1180", "text": "حضرت انس ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ رسول اللہ ﷺ بیت المقدس کی طرف منہ کر کے نماز پڑھا  کرتے"}
{"hadithnumber": "1181", "text": "۔  یحییٰ بن سعید قطان نے حدیث بیان کی ،  کہا :  ہمیں ہشام نے حدیث سنائی ،  کہا :  مجھے میرے والد  ("}
{"hadithnumber": "1182", "text": "۔  وکیع نے کہا :  ہمیں ہشام بن عروہ نے اپنے والد  عروہ کے حوالے سے حضرت عائشہ رضی اللہ عنہا سے حدیث"}
{"hadithnumber": "1183", "text": "۔   ( یحییٰ  اور وکیع کے بجائے )  ابو معاویہ نے کہا :  ہمیں ہشام نے اپنے والد سے ،  انہوں نے حضرت عا"}
{"hadithnumber": "1184", "text": "۔  ابوبکر ابی شیبہ  او رعمرو ناقد نے کہا :  ہم سے ہاشم بن قاسم نے حدیث بیان کی ،  انہوں نے کہا :  ہم"}
{"hadithnumber": "1185", "text": "سعید بن مسیب نے حدیث بیان کی کہ حضرت ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے کہا :  رسول اللہﷺ نے فرمایا :"}
{"hadithnumber": "1186", "text": "( سعید کے بجائے )  یزید بن اصم نے حضرت ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت بیان کی کہ رسول اللہ"}
{"hadithnumber": "1187", "text": "۔  عبید اللہ بن عبد اللہ  ( بن مسعود )  نے خبر دی کہ حضرت عائشہ  اور حضرت عبد اللہ بن عباس  ‌رضی ‌ال"}
{"hadithnumber": "1188", "text": "۔   حضرت جندب  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے کہا :  میں نے نبیﷺ کو آپ کی وفات سے پانچ دن پہلے یہ کہتے ہوئے"}
{"hadithnumber": "1189", "text": "۔  ہارون بن سعید ایلی اور احمد بن عیسیٰ دونوں  نے ہمیں حدیث بیان کی ۔   ( کہا  :   )  ہم سے ابن وہب"}
{"hadithnumber": "1190", "text": "حضرت محمود بن لبید  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ حضرت عثمان بن عفان  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے"}
{"hadithnumber": "1191", "text": "ابو معاویہ نے ہمیں اعمش سے حدیث بیان کی ،  انہوں نے ابراہیم سے اور انہوں نے اسود اور علقمہ سے روایت"}
{"hadithnumber": "1192", "text": "یہ ‌روایت ‌بھی ‌ایك ‌دوسری ‌سند ‌سے ‌اسی ‌طرح ‌مروی ‌ہے ‌سوا‎ئے ‌ان ‌الفاظ ‌كے ‌وَهُوَ رَاكِعٌ ‏.‏"}
{"hadithnumber": "1193", "text": "۔  ( اعمش ےکے بجائے  ) منصور ابراھیم سے اور انھوں نے  علقمہ اور اسود سے روایت کی کہ وہ دونوں حضرت عب"}
{"hadithnumber": "1194", "text": "1193میں غالباً ابراھیم نخعی سے نیچے کسی راوی کو وہم ہوا ہے ۔ اسی لیے امام مسلم  ‌رضی ‌اللہ ‌عنہ ‌ ‌"}
{"hadithnumber": "1195", "text": "ابو عوانہ نے ابو یعفور سے اور انھوں نے مصعب بن سعد سے روایت کی  ‘ انھوں نے کہا  : میں نےاپنے والد  ("}
{"hadithnumber": "1196", "text": "ابو احوص اورسفیان نے ابو یعفور سے مذکورہ بالاسند کے ساتھ’’ہمیں روک دیا گیا  ‘  ‘ تک حدیث بیان کی ہے"}
{"hadithnumber": "1197", "text": "وکیع نے اسماعیل بن ابی خالد سے  ‘ انھوں نے زبیر بن عدی سے اور انھوں  نے مصعب  بن سعد سے روایت  کی  ‘"}
{"hadithnumber": "1198", "text": "حضرت طاوس بیان کرتے ہیں کہ ہم نے ابن عباس رضی اللہ عنھماسےدونوں پیروں پربیٹھنے کے بارے میں پو چھا تو"}
{"hadithnumber": "1199", "text": "ہم سے ابو جعفرمحمد بن صباح اور ابو بکر بن ابی شیبہ نے حدیث بیان کی ۔ حدیث کے لفظوں میں بھی دونوں ایک"}
{"hadithnumber": "1200", "text": "اوزاعی نے یحییٰ بن ابی کثیر سے اسی سند  کے ساتھ اسی کے ہم معنی حدیث بیان کی ہے  ۔"}
{"hadithnumber": "1201", "text": "ابن فضیل نے ہمیں حدیث بیان کی  ، کہا  :  ہمیں اعمش نے ابراہیم سے حدیث سنائی  ،  انھوں نے علقمہ سے او"}
{"hadithnumber": "1202", "text": "اعمش سے  ( ابن فضیل کے بجائے  ) ہریم بن سفیان نے مذکورہ بالا سند کے ساتھ اسی کے مثل حدیث بیان کی"}
{"hadithnumber": "1203", "text": "ہشیم نے اسماعیل بن ابی خالد سے  ، انھوں نے حارث بن شبیل سے  ، انھوں نے ابوعمر و شیبانی سے اور انھوں"}
{"hadithnumber": "1204", "text": "ہشیم کے بجائے )  عبداللہ بن نمیر  ، وکیع اور عیسیٰ بن یونس نے اسماعیل بن ابی خالد سے اسی سند کے ساتھ"}
{"hadithnumber": "1205", "text": "قتیبہ بن سیعد اور محمد بن رمح نے اپنی اپنی سند کے ساتھ لیث ( بن سعد ) سے حدیث بیان کی  ، انھوں نے اب"}
{"hadithnumber": "1206", "text": "زہیر نے کہا  : مجھے ابو زبیر نے حضرت جابر رضی اللہ تعالیٰ عنہ سے حدیث سنائی  ، انھوں نے کہا  : رسول"}
{"hadithnumber": "1207", "text": "حماد بن زید نے کثیر  ( بن شنظیر  ) سے  ،  انھوں نے عطاء سے اور انھوں حضرت جابر رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "1208", "text": "عبدالوارث بن سعید نے کہا  :  ہمیں کثر بن شنظیر نے  حدیث سنائی  ،  انھوں نے عطاء سے اور انھوں نے حضرت"}
{"hadithnumber": "1209", "text": "اسحاق بن ابراہیم اور اسحاق بن منصور نے کہا  :   ہمیں نضر بن  شمیل نے خبر دی  ،  انھوں نے کہا  :  ہمی"}
{"hadithnumber": "1210", "text": "محمد بن بشار نے کہا  :  ہمیں محمد بن جعفر نے  حدیث سنائی  ۔  اور ابو بکر بن ابی شیبہ نے کہا  :  ہمیں"}
{"hadithnumber": "1211", "text": "حضرت ابو درداء رضی اللہ تعالیٰ عنہ سے روایت ہے  ،  انھوں نے کہا  : رسول اللہ ﷺ قیام  ( کی حالت )  می"}
{"hadithnumber": "1212", "text": "عبداللہ بن مسلمہ بن مسلمہ بن قعنب اور قتیبہ  بن سعید نے کہا  :  ہمیں امام مالک نے حدیث سنائی  ۔  دوس"}
{"hadithnumber": "1213", "text": "عثمان بن ابی سلیمان اور ابن عجلان دونوں نے عامر بن عبداللہ بن زبیر کو عمرو سلیم زرقی سے حدیث بیان کر"}
{"hadithnumber": "1214", "text": ")  بکیر  ( بن عبداللہ  ) نے عمرو بن سلیم زرقی سے روایت کی  ،  انھوں نے کہا  :  میں نے حضرت ابو قتادہ"}
{"hadithnumber": "1215", "text": "سعید مقبری نے عمر و بن سلیم زرقی سے روایت  کی  ،  انھوں نے حضرت ابو قتادہ رضی اللہ تعالیٰ عنہ  کو کہ"}
{"hadithnumber": "1216", "text": "عبدالعزیز بن ابی حازم نے اپنے والد سے خبر  دی کہ کچھ لوگ حضرت سہل بن سعد رضی اللہ تعالیٰ عنہ کی خدمت"}
{"hadithnumber": "1217", "text": "یعقوب بن عبدالرحمن بن محمد بن عبداللہ بن عبد ،  قار ی قرشی نے کہا  :  مجھے ابو حازم نے حدیث سنائی کہ"}
{"hadithnumber": "1218", "text": "حکم بن موسیٰ قنطری  نے کہا  :  ہمیں عبداللہ بن مبارک نے حدیث سنائی  ،  نیز ابو بکر ابن ابی شیبہ نے ک"}
{"hadithnumber": "1219", "text": "ہمیں وکیع نے حدیث سنائی  ،  کہا  :  ہمیں ہشام دستوائی نے حدیث سنائی  ،  انھوں نے یحییٰ بن ابی کثیر س"}
{"hadithnumber": "1223", "text": "امام مالک نے نافع سے اور انھوں حضرت عبداللہ بن عمر رضی اللہ تعالیٰ عنہ سے روایت کی کہ رسول اللہ ﷺ نے"}
{"hadithnumber": "1224", "text": ")   عبید اللہ  ،  لیث بن سعد  ،  ایوب  ،  ضحاک بن عثمان اور موسیٰ  بن عقبہ  سب نے نافع سے  ،  انھوں"}
{"hadithnumber": "1225", "text": ")  سفیان بن عیینہ نے زہری سے  ،  انھوں نے حمید بن عبدالرحمن سے اور انھوں نے حضرت ابو سعید خدری رضی ا"}
{"hadithnumber": "1226", "text": "( سفیان کے بجائے  ) یونس  اور ابراہیم نے ابن شہاب سے  ،  انھوں نے حمید بن عبدالرحمن سے روایت کی کہ ح"}
{"hadithnumber": "1227", "text": "حضرت عائشہ رضی اللہ تعالی عنہا  سے روایت ہے کہ نبی اکرم ﷺ نے قبلے کی دیوار"}
{"hadithnumber": "1228", "text": "ابن علیہ نے ہمیں حدیث بیان کی ،  انھوں قاسم بن مہران سے  ، انھوں نے ابو رافع سے اور انھوں نے حضرت اب"}
{"hadithnumber": "1229", "text": "ابن علیہ کے بجائے  ) عبدالوارث  ، ہشیم اورشعبہ نے قاسم بن مہران سے حدیث بیان کی  ۔  انھوں نے ابو راف"}
{"hadithnumber": "1230", "text": ")  حضرت انس بن مالک  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے  ،  کہا  :  رسول اللہ ﷺ نے فرمایا  :  ’’جب تم"}
{"hadithnumber": "1231", "text": "ابو عوانہ نے قتادہ سے اور انھوں نے حضرت انس بن مالک  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ رسول اللہ ﷺ"}
{"hadithnumber": "1232", "text": ")  ( ابو عوانہ کے بجائے  ) شعبہ نے کہا  :  میں نے قتادہ سے مسجد میں تھوکنے کے بارے میں پوچھا  تو انھ"}
{"hadithnumber": "1233", "text": "حضرت ابو ذر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے نبی اکرم ﷺ سے روایت کی  ،  آپ نے فرمایا  : ’’ میرے سامنے میری ا"}
{"hadithnumber": "1234", "text": "کہمس  نے یزید بن عبداللہ بن شخیر سے  ،  انھوں نے اپنے والد سےروایت کی  ،  انھوں نےکہا  :  میں نے رسو"}
{"hadithnumber": "1235", "text": ")  جریری نے ابو علاء یزید بن عبداللہ بن شخیر سے اور انھوں نے اپنے والد سے روایت کی کہ انھوں نے  رسول"}
{"hadithnumber": "1236", "text": "بشر بن مفضل نے ہمیں ابو  مسلمہ سعید بن یزید سے خبر دی  ،  انھوں نے کہا  :  میں نے انس بن مالک   ‌رضی"}
{"hadithnumber": "1237", "text": "بشر کے بجائے  ) عباد بن  عوام نے کہا  :  ہمیں ابو مسلمہ سعید بن یزید نے حدیث سنائی  ،  انھوں نے کہا"}
{"hadithnumber": "1238", "text": ")  سفیان بن عیینہ نے ہمیں حدیث بیان کی  ،  انھوں نے زہری سے  ،  انھوں نعروہ سے اور انھوں نے حضرت عائ"}
{"hadithnumber": "1239", "text": "یونس نے ابن شہاب  ( زہری  ) سے خبر دی  ،  انھوں نے کہا  :  مجھے عروہ بن زبیر نے حضرت عائشہ رضی اللہ"}
{"hadithnumber": "1240", "text": "ابن شہاب زہری کے بجائے  ) ہشام نے اپنے والد عروہ سے اور انھوں نے حضرت عائشہ رضی اللہ تعالی عنہا سے ر"}
{"hadithnumber": "1241", "text": "سفیان بن عیینہ  نے زہری سے  ،  انھوں نے حضرت انس بن مالک  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے اور انھوں نے نبی ا"}
{"hadithnumber": "1242", "text": "عمرو  ( بن حارث  ) نے ابن شہاب  ( زہری  ) سے خبر دی  ،  انھوں نے کہا  :  مجھے حضرت انس بن مالک  ‌رضی"}
{"hadithnumber": "1243", "text": "ابن نمیر  ،  حفص اور وکیع  نے ہشام سے  ،  انھوں نے اپنے والد سے اور انھوں نے حضرت عائشہ رضی اللہ تعا"}
{"hadithnumber": "1244", "text": "سیدنا عبداللہ بن عمر ؓ سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا : ” جب تم میں سے کسی کے سامنے شام کا کھا"}
{"hadithnumber": "1245", "text": "موسیٰ بن عقبہ  ،  ابن جریج  اور ایوب سب نے نافع سے  ،  انھوں نے حضرت  ابن عمر  ‌رضی ‌اللہ ‌عنہ ‌ ‌"}
{"hadithnumber": "1246", "text": "حاتم بن اسماعیل نے  ( ابو حزرہ  )  یعقوب بن مجاہد سے  ،  انھوں ابن ابی عتیق   ( عبداللہ بن محمد بن ع"}
{"hadithnumber": "1247", "text": "اسماعیل بن جعفر نے کہا  :  مجھے ابو حزرہ القاص  ( یققوب بن مجاہد  ) نے عبداللہ بن ابی عتیق سے خبر دی"}
{"hadithnumber": "1248", "text": "محمد بن مثنیٰ اور زہیر بن حرب دونوں نے کہا  :  یحییٰ قطان نے ہمیں عبیداللہ سے حدیث بیان کی  ،  انھوں"}
{"hadithnumber": "1249", "text": "عبداللہ بن نمیر نے کہا  :  ہم سے عبید اللہ نے   حدیث بیان کی  ،  انھوں نے نافع سے اور انھوں نے حضرت"}
{"hadithnumber": "1250", "text": ")  عبدالعزیز سے  ،  جو صہیب کے بیٹے  ہیں  ،  روایت ہے کہ حضرت انس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے لہسن کے ب"}
{"hadithnumber": "1252", "text": "ابو زبیر نے حضرت جابر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ رسول اللہ ﷺ نے پیاز اور گندنا کھا نے سے م"}
{"hadithnumber": "1253", "text": "ابو طاہر اور حرملہ نے کہا  :  ہمیں ابن وہب نے خبر دی  ،  کہا  :  مجھے یونس نے ابن شہاب سے خبر دی  ،"}
{"hadithnumber": "1254", "text": "یحییٰ بن سعید نے ابن جریج سے حدیث بیان کی  ،  انھوں کہا  :  مجھے عطاء نے حضرت جابر بن عبداللہ  ‌رضی"}
{"hadithnumber": "1255", "text": "محمد بن بکر اور عبدالرزاق نے  ( دو مختلف سندوں سے روایت کرتے ہوئے ) کہا  :  ہمیں ابن جریج نے اسی  ("}
{"hadithnumber": "1256", "text": "حضرت ابو سعید  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے  ،  انھون نے کہا  :  ہم خیبر کی فتح سے فارغ نہیں ہوئ"}
{"hadithnumber": "1257", "text": "حضرت ابو سعید خدری  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ رسول اللہ ﷺ اور آپ کے صحابہ   ( ایک دفعہ  )"}
{"hadithnumber": "1258", "text": "ہشام نےکہا  :  ہم سے قتادہ نے حدیث بیان کی  ،  انھوں نے سالم بن ابی جعد سے اور انھوں نے حضرت معد ان"}
{"hadithnumber": "1259", "text": "سعید بن ابی عروبہ اور شعبہ نے قتادہ سے اسی سند کے ساتھی اسی کے مانند روایت کی"}
{"hadithnumber": "1260", "text": "ابن وہب نےہمیں حدیث سنائی  ،  انھوں نے حیوہ سے  ،  انھوں نے محمد بن عبدالرحمن سے  ،  انھوں نے شدادبن"}
{"hadithnumber": "1261", "text": ")  ( ابن وہب کے بجائے  ) مقری نے حیوہ سے باقی ماندہ اسی سند کےساتھ اسی کے مانند حدیث بیان کی"}
{"hadithnumber": "1262", "text": "سفیان ثوری نے ہمیں خبر دی  ،  انھوں نے علقمہ بن مرثد سے  ،  انھوں نے سلیمان بن بریدہ سے اور انھوں نے"}
{"hadithnumber": "1263", "text": "ابو سنان نے علقمہ بن مرثد سے  ،  انھوں نے سلیمان بن بریدہ سے اور انھوں نےاپنے والد سے روایت کی کہ  ("}
{"hadithnumber": "1264", "text": "محمد بن شیبہ نے علقمہ بن مرثد سے  ،  انھوں نے  ( سلیمان  ) بن بریدہ سے اور انھوں نے اپنے والد سے روا"}
{"hadithnumber": "1265", "text": "امام مالک نے ابن شہاب  ( زہری  ) سے  ،  انھوں نے ابوسلمہ  بن عبدالرحمن سے اور انھوں نے حضرت ابو ہریر"}
{"hadithnumber": "1266", "text": "سفیان بن عیینہ  اور لیث بن سعد نے زہری سے اسی سند کے ساتھ اسی طرح حدیث بیان کی ہے  ۔"}
{"hadithnumber": "1267", "text": ")  یحییٰ بن ابی کثیر سے روایت ہے  ،  کہا  :  ہمیں ابو سلمہ بن عبدالرحمن نے حدیث سنائی کہ حضرت ابو ہر"}
{"hadithnumber": "1268", "text": "عبدالرحمن اعرج نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ رسول اللہ ﷺ نےفرمایا  :  ’’جب"}
{"hadithnumber": "1269", "text": "مالک نے ابن شہاب سے  ،  انھوں نے عبدالرحمن اعرج سے اور انھوں نے حضرت عبداللہ بن بحسینہ  ‌رضی ‌اللہ ‌"}
{"hadithnumber": "1270", "text": "لیث نے ابن شہاب سے  ،  انھوں نےاعرج سے اور انھوں نے حضرت عبداللہ بن بحسینہ اسدی  ‌رضی ‌اللہ ‌عنہ ‌ ‌"}
{"hadithnumber": "1271", "text": "ابن شہاب کے بجائے  ) یحییٰ بن سعید نے عبدالرحمن اعرج سے اور انھوں نے حضرت عبداللہ بن مالک ابن بحسینہ"}
{"hadithnumber": "1272", "text": "سلیمان بن بلال نے زید بن اسلم سے  ،  انھوں نے عطاء بن یسار سے اور انھوں نے حضرت ابو سعید خدری  ‌رضی"}
{"hadithnumber": "1273", "text": "داؤد بن قیس  نے زید بن اسلم سے اسی سند کے ساتھ روایت کی اور اس کے معنی کے مطابق یہ کہا  :  وہ ’’ ( ن"}
{"hadithnumber": "1274", "text": "جریر نے ہمیں حدیث بیان کی  ،  انھوں نے منصور سے  ،  انھوں نے ابراہیم سے اور انھوں نے علقمہ سے روایت"}
{"hadithnumber": "1275", "text": "ابن بشر اور وکیع دونوں نے مسعر سے  اور انھوں نے منصور سے اسی سند کے ساتھ حدیث بیان کی  ابن بشر کی رو"}
{"hadithnumber": "1276", "text": "وہیب بن خالد نے کہا  : ہمیں منصور نے اسی سند کےس اتھ حدیث بیان کی  ۔  منصور نے کہا  :  ’’وہ غور کرے"}
{"hadithnumber": "1277", "text": "سفیان نے منصور سے مذکورہ سند کے ساتھ یہی حدیث بیان کی اور کہا  :  ’’وہ صحیح  کی جستجو کرے"}
{"hadithnumber": "1278", "text": "شعبہ نے منصور سے اسی سند کے ساتھ یہی  حدیث بیان کی اور کہا  : ’’ اس میں جو صحیح  کے قریب تر ہے اس کی"}
{"hadithnumber": "1279", "text": "فضیل بن عیاض نے منصور سے اسی سند کے ساتھ خبر دی اور کہا  :  ’’وہ اس کی جستجو کرے جسے وہ صحیح  سمجھتا"}
{"hadithnumber": "1280", "text": "عبدالعزیز بن عبد الصمد نے منصور سے ان سب راویوں کی سند کے ساتھ یہی حدیث بیان کی اور کہا  : ’’وہ صحیح"}
{"hadithnumber": "1281", "text": "حکم نے ابراہیم سے  ،  انھوں نے علقمہ سے اور  انھوں نے حضرت عبداللہ  ( بن مسعود  ‌رضی ‌اللہ ‌عنہ ‌ ‌"}
{"hadithnumber": "1282", "text": "ابن نمیر نے ہمیں حدیث بیان کی  ،  کہا  :  ہمیں ابن ادریس نے حسن بن عبید اللہ سے حدیث بیان کی  ،  انھ"}
{"hadithnumber": "1283", "text": "عثمان بن ابی شیبہ  نے ہمیں حدیث بیان کی  ۔  لفظ انھی کے ہیں  ۔  انھوں نے کہا  :  ہمیں جریر نے حسن بن"}
{"hadithnumber": "1284", "text": "عبدالرحمن بن اسود نے اپنے والد سے  ،  انھوں نےحضرت عبداللہ  ( بن مسعود  )  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے ر"}
{"hadithnumber": "1285", "text": "علی  ) بن مسہر نے اعمش سے  ،  انھوں نے ابراہیم سے  ،  انھوں نے علقمہ سے اور انھوں نے حضر عبداللہ  ‌ر"}
{"hadithnumber": "1286", "text": "حفص اور ابو معاویہ نے اعمش سے باقی ماندہ  اس سند کے ساتھ حضرت  عبداللہ  ( بن مسعود  )  ‌رضی ‌اللہ ‌ع"}
{"hadithnumber": "1287", "text": "زائدہ نے سلیمان  ( اعمش  ) سے باقی ماندہ اسی سند کے ساتھ حضرت عبداللہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت"}
{"hadithnumber": "1288", "text": "سفیان بن عیینہ نے کہا  :  ہم سے  ایوب نے  حدیث بیان کی  ،  انھوں نے کہا  :  میں نے محمد بن سیرین سے"}
{"hadithnumber": "1289", "text": ")  ( سفیان کے بجائے  ) حماد نے ہمیں حدیث بیان کی  ( کہا  :  ) ہمیں ایوب نے محمد بن سیرین سے حدیث سنا"}
{"hadithnumber": "1290", "text": ")  ابن ابی احمد کے آزاد کردہ غلام ابو سفیان سے روایت ہے کہ اس نے کہا  :  میں نے حضرت ابو ہریرہ  ‌رضی"}
{"hadithnumber": "1291", "text": "علی بن مبارک نے ہمیں حدیث بیان کی  ،  کہا  :  ہمیں یحییٰ نے حدیث بیان کی  ،  انھوں نے کہا  :  ہمیں ا"}
{"hadithnumber": "1292", "text": "شیبان نےیحییٰ سے  ،  انھوں نے ابو سلمہ سے اور انھوں نے حضرت ابو ہریرہ   ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روای"}
{"hadithnumber": "1293", "text": ")  اسماعیل بن ابراہیم نے خالد  ( حذاء  ) سے  ،  انھوں نے ابو قلابہ سے  ،  انھوں نے ابو مہلب سے اور ا"}
{"hadithnumber": "1294", "text": "عبدالوہاب تقفی نے خالد حذاء  سے باقی ماندہ اسی سند کے ساتھ حضرت عمران بن حصین  ‌رضی ‌اللہ ‌عنہ ‌ ‌"}
{"hadithnumber": "1295", "text": "یحییٰ بن سعید قطان نے عبیداللہ سے حدیث بیان کی  ،  انھوں نے کہا  :  مجھے نافع نے حضرت ابن عمر  ‌رضی"}
{"hadithnumber": "1296", "text": "محمد بن بشر نے حدیث بیان کی  ،  کہا  :  ہمیں عبیداللہ نےنافع سے حدیث بیان کی اور انھوں نے حضرت  ابن"}
{"hadithnumber": "1297", "text": "حضرت عبداللہ  ( بن مسعود  ‌رضی ‌اللہ ‌عنہ ‌ ‌  ) نے نبی اکرم ﷺ سے روایت کی کہ آپ  آپ ﷺ نے سورۃ نجم ک"}
{"hadithnumber": "1298", "text": "عطاء بن یسار نے  ( اپنے شاگرد ابن قسیط  کو  )  بتایا کہ انھوں نے امام کے ساتھ  ( قرآن کی کسی سورت کی"}
{"hadithnumber": "1299", "text": "اسود بن سفیان کے آزاد کردہ غلام عبداللہ بن یزید نے ابو سلمہ بن عبدالرحمن سے روایت کی کہ حضرت ابو ہری"}
{"hadithnumber": "1300", "text": ")  یحییٰ بن ابی کثیر نے ابو سلمہ سے  ،  انھوں نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے اور انھوں ن"}
{"hadithnumber": "1301", "text": "عطاء بن میناء نے حضرت ابو ھریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌ سے روایت کی  ‘ انھوں نے کہا : ہم نے نبی ﷺکے سات"}
{"hadithnumber": "1302", "text": "صفوان بن سلیم نے بنو مخزوم کے آزاد کردہ غلام عبد الرحمٰن اعرج سے روایت کی  ‘ انھوں نے حصرت ابو ھریرہ"}
{"hadithnumber": "1303", "text": "۔ عبید اللہ بن ابی جعفر نے عبد الرحمٰن اعرج سے  ‘ انھوں نے حصرت ابوھریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌ سے اور"}
{"hadithnumber": "1304", "text": "عبید اللہ بن معاذ غنبری ارو محمد بن عبد الاعلیٰ نے کہا  : ہمیں معتمر نے اپنے والد  ( سلیمان تیمی  )"}
{"hadithnumber": "1305", "text": "عیسیٰ بن یونس  ‘ یزید بن زریع اور سلیم بن اخضر سب نے  ( سلیمان  ) تیمی سے سابقہ سند کے ساتھ روایت کی"}
{"hadithnumber": "1306", "text": "شعبہ نے  عطاء بن ابی میمونہ سے انھوں نے ابو رافع سے روایت کی  ‘ کہا  : میں نے حضرت ابو ہریرہ ‌رضی ‌ا"}
{"hadithnumber": "1307", "text": "عثمان  بن حکم نے کہا  : عامر بن عبد اللہ بن زبیر ‌رضی ‌اللہ ‌عنہ ‌ ‌ نے اپنے والد سے روایت کرتے ہوئے"}
{"hadithnumber": "1308", "text": "۔  ابن عجلان نے عامر بن عبد اللہ بن زبیرسے اور انھوں نے اپنے والد سے روایت کی  ‘ انھوں نے کہا  : رسو"}
{"hadithnumber": "1309", "text": "عبید اللہ بن عمر نے نافع سے اور انھوں نے حضرت ابن عمر ‌رضی ‌اللہ ‌عنہ ‌ ‌ سے روایت کی کہ نبیﷺجب نماز"}
{"hadithnumber": "1310", "text": "ایوب نے نافع سے اور انھوں نے حضرت ابن عمر  ‌رضی ‌اللہ ‌عنہ ‌ ‌ سے روایت کی کہ رسول اللہﷺجب تشہد میں"}
{"hadithnumber": "1311", "text": "امام مالک نے مسلم بن ابی مریم سے اور انھوں نے علی بن عبد الرحمان معادی سے روایت کی کہ انھوں نے کہا :"}
{"hadithnumber": "1312", "text": "ابن ابی عمر نے کہا  : ہمیں سفیان نے مسلم بن ابی مریم سے حدیث سنائی  ‘ انھوں نے علی بن عبد الرحمان مع"}
{"hadithnumber": "1313", "text": "زہیر بن حرب نے کہا  : ہمیں یحییٰ بن سعید نے  شعبہ سے حدیث بیان کی  ‘ انھوں نے حکم اور منصور سے ‘ انھ"}
{"hadithnumber": "1314", "text": "احمد بن حنبل نے کہا  : ہمیں یحییٰ بن سعید نے شعبہ سے حدیث سنائی  ‘ انھوں نے مجاہد سے  ‘ انھوں نے ابو"}
{"hadithnumber": "1315", "text": "عامر بن سعد نے اپنے وال ( سعد بن  ابی وقاص ‌رضی ‌اللہ ‌عنہ ‌ ‌  ) سے روایت کی  ‘ انھوں نے کہا : میں"}
{"hadithnumber": "1316", "text": "زہیر بن حرب نے کہا  : ہمیں سفیان بن عیینہ نے عمرو  ( بن دینار  ) سے حدیث سنائی  ‘ انھوں نے کہا  : مج"}
{"hadithnumber": "1317", "text": "ابن  ابی عمر نے کہا  : ہمیں سفیان بن عیینہ نے عمروبن دینار سے حدیث سنائی  ‘  انھوں نے حضرت ابن عباس"}
{"hadithnumber": "1318", "text": "ابن جریج نے کہا  :  مجھے عمرو بن دینار نے بتایا کہ ابن عباس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  کے آزاد کردہ ےغلام"}
{"hadithnumber": "1319", "text": "عروہ بن زبیر نے حدیث بیان کی کہ حضرت عائشہ رضی اللہ عنہانے کہا  : رسول اللہ ﷺ میرے ہاں تشریف لائے جب"}
{"hadithnumber": "1320", "text": "حضرت ابو ھریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ میں نے  ( یہودی عورت والے  ) اس  ( واقعے  ) کے ب"}
{"hadithnumber": "1321", "text": "ابو وائل  ( شقیق بن سلمہ  ) نے مسروق سے اور انھوں نے حضرت عائشہ ؓ سے روایت کی  ، انھوں نے کہا  : مدی"}
{"hadithnumber": "1322", "text": "ابو وائل کے بجائے  ) اشعث کے والد  ( ابو شعثاء  سلیم محاربی  ) نے مسروق سے اور انھوں نے حضرت عائشہ ؓ"}
{"hadithnumber": "1323", "text": "حضرت عائشہ ؓ نے کہا کہ میں نے  رسول اللہ ﷺ کو اپنی نماز میں  ، دجال کے فتنے  سے پناہ مانگتے  سنا"}
{"hadithnumber": "1324", "text": "وکیع نے کہا  :  ہمیں اوزاعی نے حسان بن عطیہ سے حدیث سنائی  ،  انھوں نے محمد بن ابی عائشہ سے اور انھو"}
{"hadithnumber": "1325", "text": "نبی کریم ﷺ کی زوجہ حضرت عائشہ ؓ نے خبر دی کہ نبی اکرم ﷺ نماز میں  ( یہ  ) دعا مانگتے تھے  :  اے اللہ"}
{"hadithnumber": "1326", "text": "ولید بن مسلم نےکہا  : مجھے اوزاعی نے حدیث سنائی  ، انہوں نے کہا  : ہمیں حسان بن عطیہ نےحدیث سنائی  ،"}
{"hadithnumber": "1327", "text": "ہقل بن زیاد اور عیسیٰ  بن یونس دونوں نے اوزاعی کی مذکورہ سند سے یہی حدیث روایت کی  ، ا س میں ہے  ،"}
{"hadithnumber": "1328", "text": "ہشام نے یحییٰ سے اور انھوں نے ابو سلمہ سے  روایت کی کہ انھوں نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌"}
{"hadithnumber": "1329", "text": "عمرو  ( بن دینار  ) نے طاؤس سے روایت کی  ،  انھوں نے کہا  :  میں نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ"}
{"hadithnumber": "1330", "text": "طاوس کے بیٹے  ( عبداللہ  ) نے اپنے والد طاوس سے  ،  انھوں نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے"}
{"hadithnumber": "1331", "text": "اعرج نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے اور انھوں نے نبی ﷺ سے اسی کی مانند روایت کی"}
{"hadithnumber": "1333", "text": "طاوس نے حضرت ابن عباس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت  کی کہ رسول اللہ ﷺ ان  ( سب صحابہ  ) کو اس دعا"}
{"hadithnumber": "1334", "text": "ولید نے اوزاعی سے  ،  انہوں نے ابو عمار  ۔  ان کا نام شداد بن عبداللہ ہے  ۔  سے  ،  انھوں نے ابو اسم"}
{"hadithnumber": "1335", "text": "ابو بکر بن ابی شبیہ اور ابن نمیر نے حدیث بیان کی  ، کہا ہمیں ابو معاویہ نے عاصم سے حدیث سنائی  ، انھ"}
{"hadithnumber": "1336", "text": "ابو خالد احمر نے عاصم سے اسی سند کے ساتھ  یہی حدیث بیان کی اور یا ذالجلال والاکرام  ( یا کے اضافے کے"}
{"hadithnumber": "1337", "text": "شعبہ نے عاصم اور خالد سے روایت کرتے ہوئے عبداللہ بن حارث سے حدیث بیان کی  ،  انھوں نے حضرت عائشہ رضی"}
{"hadithnumber": "1338", "text": "منصور نے مسیّب بن رافع سے  ،  انھوں نے مغیرہ بن شعبہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  کے مولیٰ وراد سے روایت کی"}
{"hadithnumber": "1339", "text": "ابوبکر بن ابی شیبہ  ، ابو کریب اور احمد بن سنان نے ہمیں حدیث بیان کی  ،  ان سب نے کہا  :  ہمیں ابو م"}
{"hadithnumber": "1340", "text": "ابن عون نے ابو سعید سے  ،  انھوں نے ورّاد  سے  ۔  جو مغیرہ بن شعبہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  کےکاتب تھے"}
{"hadithnumber": "1341", "text": "سفیان نے کہا  :  ہمیں عبدہ بن ابی لبابہ اور عبدالملک بن عمیر  نے حدیث سنائی  ،  انھوں نے مغیرہ بن شع"}
{"hadithnumber": "1342", "text": "سفیان نے کہا  :  ہمیں عبدہ بن ابی لبابہ اور عبدالملک بن عمیر  نے حدیث سنائی  ،  انھوں نے مغیرہ بن شع"}
{"hadithnumber": "1343", "text": "محمد کے والد عبداللہ بن نمیر نے کہا  :  ہمیں ہشام  نے ابو زبیر سے حدیث سنائی   ،  کہا  :   ( عبداللہ"}
{"hadithnumber": "1344", "text": "عبدہ بن سلیمان نے ہشام بن عروہ سے اور   انھوں نے اپنے خاندان کے مولیٰ ابو زبیر  سے روایت کی کہ حضرت"}
{"hadithnumber": "1345", "text": "ہشام کے بجائے  ) حجاج بن ابی عثمان نے مجھے حدیث بیان کی  ،  کہا  : مجھ سے ابو زبیر نے حدیث بیان کی"}
{"hadithnumber": "1346", "text": "موسیٰ بن عقبہ  سے روایت ہے کہ ابو زبیر مکی نے  انھیں حدیث سنائی کہ انھوں نے عبداللہ بن زبیر  ‌رضی ‌ا"}
