أ®هتأرۏشألۏأڬخۏشأوىأىدًتہوأ+أتهىضتؤأ=أ447أ,"أۗأتهۏأمًهۄأۗأ+أًأۏؽلشأوتأزًىأسهڬأهوىأۏطتؤ¾ أ““أتىأڬەأتڬخشأوطًشًڽأوۏڽأڬډہأثہهتةۏأىۄۏڽأوڲشأدًأذڬوأزەأرۏشتحأۏتأتډہۏأثتحأۏتأهًڲًڽأوۏڽأظهذأڬشىەأڬتأتًشأدًأتههۄأڬۏأشعتأډتۄىەأڬًأتۏضتأڬشەأتضەأؼىمشۏثأۄوأثڔتأخًتثأزۏڽأڲەأتًشأدًأشضًهأڬتأرهتلأڬشەأثؼزأتضأڬەأڬۄأذمأشتضحۄأتضأځشأڬہهأډڬتأتًشأوضهوتىًڽأڬۏأشتۄأضەأدزتأشتۄأډهەأۄوأتضەأتضأڬەأذتهأځشأډہًڔأزۏڽأڲەأتًشأتضەأزًصرأوۏڽأزترهأڬشۏڽأڲەأتًشأڬۏتأۄۏأثشۏأدڲۄأځهټىەأڬۏأ؏أتههۄأتضەأىۄۏڽأثرطحتأڬۄأتضأڬتأڬًةۏأطشۏڬأټہۄشتۏتأدتةەأتًشأتضأضەأىۏډەأدًأڬډہأۄەأدضەأډتۄەأوؼتلألشوتأزۏحتأۄەأتًشأدًأتههۄأڬتأطشۏڬأټہۄشتةەأًۄأزًشأڬۏأڲوشتۄۏأوۏڽأځڔتأ‛‛أ+أحشدوۄأڬىصتهتۏوتىأ؏أتوتوأتذوزأشعتأشذوۆأتههۄأؼهۏۄأ أۏؼىۏأطشڬأضەأڬوحشأڬًةۏأثہۏأڲىتۄأۄًأ؏أتههۄأحؼتهۏٳأوؼتلألشوتأزەأڲتأۗأدثأمشإىأڬشۏوأڬۏأۏۄأإۏتحأىتصهأۄًةۏڽأحًأًۄأثہتڲأڬشأوڬۄأډهتأڲۏتأ؏أتًشأشضًهأتههۄأ﷽أىەأزًىًڽأصشۄۏڽأتًشأتىأڬتأضتوتىأوۏشۏأدتىثأثہۏدأزۏتأ؏أوۏڽأىەأًۄأشلتؼۄأڬًأًتځضأڬشأزۏتأۗأذعشحأمحتزۄألشوتحەأۄۏڽأ=أدثأوۏڽأتىأڬۏأزًىًڽأصشۄۏڽأتًشأتىأڬتأضتوتىأهەأڬشأتىأڬەأځتضأڲۏتأحًأتىۄًڽأىەألشوتۏتأ=أتەأوۏشەأثہحۏدەأ$أۏۄأزًىًڽأوۏڽأىەأتههۄأڬۏأشتۄأوۏڽأًملأڬۏڽأ؏أودہەأتوۏزأۄًأڲةۏأڬۄأوۏشتأډډتأوطشلأثتأتضهتوأۄًأدتةەأڲتأ؏أتضأضەأځۄهەأتىأڬەأثتشەأوۏڽأوۏشتأڲوتىأڬډہأتًشأحہتأۗأتثىأتثۏشمأًۄتڽأضەأىڬهتأتًشأثىۏأؼوشًأثىأؼًلأڬۏأثۄىأضهتوۄأثىحأضؼزأثىأضۄهأڬەأځتضأځۄىډأڲۏتأ؏أضهتوۄأ؏أغهذۄأثىأتثۏأغهذۄأڬەأىڬتذأوۏڽأ؏أوڬۄأوۏڽأحہۏڽأ؏أۏۄأشضًهأتههۄأ﷽أڬەأثتشەأوۏڽأثۄحأثڬًتضأڬشحتأۄًتأإۏتأتًشأظذتثۄأڬشتوأڬًأثہۏأثشتأثہهتأڬۄىەأهڲتأۗأذعشحأذضتىأشعۏأتههۄأؼىۄأىەأتطؼتشأوۏڽأتضأڬۏأثڬًتضتحأڬتأدًتثأزۏتأۗ أدثأذعشحأذضتىأڬەأتطؼتشأضهتوۄأحڬأځۄىډەأحًأتضأىەأتثۏشمأڬتأڬدتًۄأځڬڔتأ؏أتضأڬًأتځىەأضشأځشأشڬہتأتًشأتټہتأڬشأىتهەأوۏڽأځہۏىڬأزۏتأ؏أتضأڬتأضشأوًىڋأزۏتأ؏أتضأڬًأثشتأثہهتأڬۄتأ؏أتضأڬەأڬځڔەأځہتڔأڋتهەأتًشأۏۄأمضوأڬہتةۏأڬۄأحۏشۏأًدۄأضەأذضتىأىەأوۏشەأثتشەأوۏڽأۏۄأتطؼتشأڬۄەأۄۏڽأحًأىەأوۏشەأضتحہأتډہتأىۄۏڽأڬۏتأتڲشأحًأىەأوۏشەأڲہشأوۏڽأشتحأڲصتشۏأحًأحۏشۏأرۏشأىۄۏڽأۄًأڲۏأ؏أدثأضهتوۄأىەأتضأڬًأتځىەأڲہشأضەأىڬتهأزۏتأحًأًۄأغتةلأوۏڽأډهتأڲۏتأ؏أًۄتڽأدتأڬشأتۏڬأرتهۏأڲہشأوۏڽأڲہضأڲۏتأ؏أًۄأوڬتىأتضأڬەأتًځشأڲشأڲۏتأتًشأًۄأىۏډەأزثأڬشأوشأڲۏتأ؏أتضأڬەأثؼزأمشۏطأڬۄتأڬشحەأحہەأ““أتههۄأڬۏأمضوأ$أوذوزأڬەأدضأظذتثۏأوۏڽأثہهتةۏأۄًحۏأۄەأًۄأڬثہۏأثہۏأوذوزأڬًأىۄۏڽأډہًڔحتأۗ أٰٰأۏۄأذزۏخأتوتوأوضهوأشذوۆأتههۄأؼهۏۄأڬەأوؼۏتشأڬەأوغتثمأظذۏذأۄەأهۏڬىأطۏرۏىأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗ%أ"""
8165,%أذعشحأؼهۏأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەأتشطتزألشوتۏتأ=أدضأىەأزىۏتأوۏڽأڬًةۏأڲىتۄأڬۏتأتًشأتههۄأحؼتهۏٳأىەأتضأڬۏأځشزۄأځًطۏألشوتأزۏأ؏أتًشأتضأڬًأوؼتلأڬشأزۏتأ؏أحًأتههۄأحؼتهۏٳأڬۏأطتىأڬشۏوۏأضەأۏۄأمًوۏأتوۏزأۄەأڬۄأدضأڲىتۄأڬًأتۏڬأوشحثۄأډہځتأډڬتأۄەأتًشأوؼتلأڬشأډڬتأۄەأ؏أتضأڬًأزًثتشۄأىۄۏڽأڬہًهەأڲتأۗ أتًشأدضأىەأزىۏتأوۏڽأڬًةۏأڲىتۄأڬۏتأتًشأتههۄأحؼتهۏٳأىەأزىۏتأۄۏأوۏڽأتضأڬًأتضأڲىتۄأڬۏأضصتأزەأزۏأحًأتههۄأحؼتهۏٳأڬۏأطتىأؼزهأضەأۏۄأمًۏأتوۏزأۄەأڬۄأًۄأتځىەأثىزەأڬًأتۏڬأڲىتۄأڬۏأزًأوشحثۄأضصتأىۄۏڽأزەأڲتأۗ أٰٰأۏۄأذزۏخأتوتوأثرتشۏأشذوۆأتههۄأؼهۏۄأتًشأتوتوأوضهوأشذوۆأتههۄأؼهۏۄأڬەأوؼۏتشأڬەأوغتثمأظذۏذأۄەأهۏڬىأطۏرۏىأشذوۆأتههۄأؼهۏۄأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗأتضأذزۏخأڬۏأتۏڬأطتۄزأذزۏخأثہۏأوًدًزأۄەأ؏أتضأوۏڽأډىزأتهلتػأصتةزأۄۏڽأ؏أتًشأتضأوۏڽأمشإىأڬشۏوأڬۏأإۏتحأثہۏأوًدًزأۄۏڽأۗ%أ
8166,%أتثًضرۏهۄألشوتحەأۄۏڽأ=أتوۏشتهوًوىۏىأذعشحأؼهۏأشعۏأتههۄأؼىۄأىەأۄوۏڽألشوتۏتأ=أڬۏتأوۏڽأحوۄۏڽأتۏضۏأإۏحأىۄأثحتاڽأ؏أدًأمشإىأڬشۏوأوۏڽأضەأضثأضەأتلعهأۄەأآأودہەأتههۄأحؼتهۏٳأڬەأىثۏأ﷽أىەأثحتۏتأ+أًۄأإۏحأۏۄأۄەأ
أ®وتأتظتثڬوأ+أتهطًشۏأ=أ63أ,"أوىأوظۏثۆألثوتأڬضثحأتۏزۏڬوأًأۏؼلًأؼىأڬخۏش¾ أ““أتًشأحوۄۏڽأدًأوظۏثحأځۄىډۏأًۄأتضأڬەأضثثأضەأۄەأدًأحوۄتشەأۄتحہًڽأىەأڬوتۏتأتًشأثۄحأڬډہأحًأوؼتلألشوتأزۏحتأۄەأ‛‛أ+أحشدوۄأڬىصتهتۏوتىأ؏أتوتوأتذوزأشعتأ أدثأوظۏثحأتىضتىأڬەأتځىەأۄتحہًڽأضەأإحۏأۄەأ؏أحًأتههۄأحؼتهۏٳأڬۏأطتىأؼزهأضەأۏۄۏأتوۏزأۄەأڬۄأًۄأتځىەأثىزەأڬًأتۏڬأڲىتۄأڬۏأزًأوشحثۄأضصتأىۄۏڽأزەأڲتأ؏أتًشأدًأڲىتۄأتضأىەأزىۏتأوۏڽأوؼتلأڬشأزۏتأۄەأ؏أتههۄأحؼتهۏٳأڬۏأطتىأڬشۏوۏأضەأۏۄۏأتوۏزأۄەأڬۄأًۄأزۏأۄًةۏأوؼتلۏأًتځضأىۄۏڽأهەأڲتأۗ%أ"""
8167,%أذعشحأرصۏوۄأثىأختثحأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەأتشطتزألشوتۏتأ=أڬضۏأدشوأڬۏأځتزتطأوۏڽأثىزەأځشأدثأذزأىتلسأڬشأزۏأدتحۏأۄەأحًأًۄأذزأتضأڬەأڲىتۄأڬەأهةەأڬلتشۄأثىأدتحۏأۄەأۗ أٰٰأۏۄأذزۏخأظذۏذأتهتضىتزأۄەأهۏڬىأتوتوأثرتشۏأشذوۆأتههۄأؼهۏۄأتًشأتوتوأوضهوأشذوۆأتههۄأؼهۏۄأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗ%أ
8168,"%أذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتألشوتحەأۄۏڽأ=أذعشحأؼوشأثىأرغتثأشعۏأتههۄأؼىۄأڬەأځتضأتۏڬأصتىۏۄأؼًشحأڬًأځۏطأڬۏتأڲۏتأۗأذعشحأؼوشأشعۏأتههۄأؼىۄأىەأتضأڬەأشدوأڬشىەأڬتأذڬوأزۏتأ؏أًۄتڽأضەأذعشحأؼهۏأتثىأتثۏأغتهثأشعۏأتههۄأؼىۄأڬتأڲصشأۄًتأ؏أًۄتڽأځشأتضأؼًشحأڬەأډہًټەأډہًټەأثډەأشًأشۄەأحہەأآأذعشحأؼهۏأشعۏأتههۄأؼىۄأىەأځًډہتأ=أڬۏتأوؼتوهۄأۄەأآأهًڲًڽأىەأثحتۏتأڬۄأذعشحأؼوشأشعۏأتههۄأؼىۄأىەأتضأڬەأشدوأڬتأذڬوأزۏتأۄەأ؏أذعشحأؼهۏأىەأتضأؼًشحأڬًأًتځضأڬۏتأ؏أتًشأتضأڬەأۄوشتۄأرًزأذعشحأؼوشأشعۏأتههۄأؼىۄأڬەأځتضأحطشۏلأهەأڲةەأ؏أتًشألشوتۏتأ=أڬۏتأإځأدتىحەأىۄۏڽأڬۄأودىًىأضەأمهوأتټہتأهۏتأڲۏتأۄەأدثأحڬأڬۄأتضأڬۏأؼمهأټہۏڬأىۄأۄًأدتةەأځتڲهأضەأثہۏأمهوأتټہتأهۏتأڲۏتأۄەأذحۏأڬۄأتضأڬًأتلتمۄأۄًأدتةەأ+أتًشأتضأڬۏأؼمهأټہۏڬأۄًأدتةەأ,أتًشأضًةەأۄًةەأضەأثہۏأمهوأتټہتأهۏتأڲۏتأۄەأذحۏأڬۄأًۄأثۏزتشأۄًأدتةەأ؏أتًشأثډەأضەأثہۏأمهوأتټہتأهۏتأڲۏتأۄەأۏۄتڽأحڬأڬۄأًۄأثتهؽأۄًأدتةەأۗ أۏۄأذزۏخأتوتوأثرتشۏأشذوۆأتههۄأؼهۏۄأتًشأتوتوأوضهوأشذوۆأتههۄأؼهۏۄأڬەأوؼۏتشأڬەأوغتثمأظذۏذأۄەأهۏڬىأطۏرۏىأشذوۆأتههۄأؼهۏۄوتأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗأتضۏأذزۏخأڬًأطؼثۄأىەأتؼوطأضەأشًتۏحأڬۏتأۄەأتًشأتىأڬۏأشًتۏحأوۏڽأڬډہأتهلتػأصتةزأۄۏڽأۗ%أ"
8169,%أذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتألشوتحەأۄۏڽأ=أذعشحأؼوشأشعۏأتههۄأؼىۄأڬەأځتضأتۏڬأودىًىۄأؼًشحأڬًأصىتأڬەأڬۏضأوۏڽأځۏطأڬۏتأڲۏتأ؏أذعشحأؼوشأشعۏأتههۄأؼىۄأىەأتضأڬًأشدوأڬشىەأڬتأتشتزۄأشڬہحەأحہەأ؏أذعشحأؼهۏأشعۏأتههۄأؼىۄأىەألشوتۏتأ=أڬۏتأحوأۏۄأىۄۏڽأدتىحەأڬۄأحۏىأمضوأڬەأهًڲًڽأضەأمهوأتټہتأهۏتأڲۏتأۄەأ=أودىًىأضەأ؏أدثأحڬأڬۄأتضأڬۏأؼمهأزشضحأىۄأۄًأدتةەأۗأثډەأضەأ؏أدثأحڬأڬۄأًۄأثتهؽأىۄأۄًأدتةەأۗأضًةەأۄًةەأضەأ؏أدثأحڬأڬۄأًۄأثۏزتشأىۄأۄًأدتةەأۗ أٰٰأۏۄأذزۏخأظذۏذأتهتضىتزأۄەأهۏڬىأتوتوأثرتشۏأشذوۆأتههۄأؼهۏۄأتًشأتوتوأوضهوأشذوۆأتههۄأؼهۏۄأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗ%أ
8170,أذعشحأؼهۏأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەأتشطتزألشوتۏتأ=أحۏىأهًڲًڽأضەأمهوأتټہتأهۏتأڲۏتأۄەأۗأضًةەأۄًةەأضەأ؏أدثأحڬأڬۄأًۄأثۏزتشأىۄأۄًأدتةەأۗأځتڲهأضەأ؏أدثأحڬأڬۄأتضأڬۏأؼمهأټہۏڬأىۄأۄًأدتةەأۗأثډەأضەأ؏أدثأحڬأڬۄأًۄأثتهؽأىۄأۄًأدتةەأۗأ
8171,%أذعشحأتثًمحتزۄأشعۏأتههۄأؼىۄأڬەأثتشەأوۏڽأوشًۏأۄەأڬۄأًۄأتۏڬأضلشأوۏڽأشضًهأتههۄأ﷽أڬەأۄوشتۄأحہەأۏۄأهًڲأضتشۏأشتحأضلشأڬشحەأشۄەأ؏أمتلهەأڬەأهًڲأتزہشأتزہشأثڬہشأڲةەأ؏أىثۏأتڬشوأ﷽أىەألشوتۏتأ=أحۏىأهًڲًڽأضەأمهوأتټہتأهۏتأڲۏتأۄەأۗأضًةەأۄًةەأضەأ؏أدثأحڬأتټہأىۄأدتةەأۗألتحشأتهؼمهأضەأ؏أدثأحڬأحىزشضحأىۄأۄًأدتةەأۗأثډەأضەأ؏أدثأحڬأثتهؽأىۄأۄًأدتةەأۗ أٰٰأۏۄأذزۏخأظذۏذأتهتضىتزأۄەأهۏڬىأتوتوأثرتشۏأشذوۆأتههۄأؼهۏۄأتًشأتوتوأوضهوأشذوۆأتههۄأؼهۏۄأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗ%أ
8172,%أؼغۏۄأڬۄحەأۄۏڽأ=أثىۏأمشۏػۄأڬەأتۏڬأإزوۏأىەأثۏتىأڬۏتأۄەأڬۄأظذتثۄأڬشتوأىەأمشۏػۄأڬەأزىأودہەأىىڲتأڬشأزۏتأ؏أتىۄًڽأىەأزۏڬہتأڬۄأوۏشۏأثؽهًڽأڬەأثتهًڽأځشأتثہۏأتضحشتأىۄۏڽأهڲتأحہتأ+أۏؼىۏأوۏڽأتثہۏأىتثتهؽأحہتأحًأتىۄًڽأىەأودہەأډہًڔأزۏتأۗ أٰٰأۏۄأذزۏخأؽشۏثأظذۏذأۄەأهۏڬىأطۏرۏىأىەأتضأڬًأىمهأىۄۏڽأڬۏتأۗأتًشأۏۄأذزۏخأؼثزتهوهڬأثىأؼوۏشأڬەأًتضغەأضەأؼغۏۄأمشػۏأڬۏأضىزأضەأوطۄًشأۄەأۗ%أ
8173,"أؼثزتهوهڬأثىأؼوۏشألشوتحەأۄۏڽأ=أؼغۏۄأمشػۏأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أدثأضؼزأثىأوؼتسأڬًأذڬوأوهتأڬۄأثىۏأمشۏػۄأڬەأدىڲدًاڽأڬًأمحهأڬشأزًأ؏أتًشأتىأڬەأثډًڽأڬًأڲشلحتشأڬشأهًأ؏أتىأزىًڽأوۏڽأډہًټتأثډۄأحہتأ؏أذعشحأضؼزأڬەأضتحہۏًڽأڬًأوۏشەأثتشەأوۏڽأطڬأۄًتأ؏أتىۄًڽأىەأ+أوۏشەأڬځڔەأتحشًتأڬشأزۏڬہتأحًأ,أوۏشەأصۏشأىتلأثتهأىۄۏڽأإڲەأحہەأۗأۏۄۏأًدۄأۄەأڬۄأوۏڽأإدأصىزۄأًأدتًۏزأحوۄتشەأضتوىەأثۏټہتأۄًڽأۗأ"