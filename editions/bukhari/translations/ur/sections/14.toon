{"hadithnumber": "990", "text": "ہم سے عبداللہ بن یوسف نے بیان کیا، انہوں نے کہا کہ ہمیں امام مالک رحمہ اللہ نے نافع اور عبداللہ ابن"}
{"hadithnumber": "991", "text": "اور اسی سند کے ساتھ نافع سے روایت ہے کہ  عبداللہ بن عمر رضی اللہ عنہما وتر کی جب تین رکعتیں پڑھتے تو"}
{"hadithnumber": "992", "text": "ہم سے عبداللہ بن مسلمہ نے بیان کیا، ان سے امام مالک نے بیان کیا، ان سے مخرمہ بن سلیمان نے بیان کیا،"}
{"hadithnumber": "993", "text": "ہم سے یحییٰ بن سلیمان نے بیان کیا، انہوں نے کہا کہ ہم سے عبداللہ بن وہب نے بیان کیا، انہوں نے کہا کہ"}
{"hadithnumber": "994", "text": "ہم سے ابوالیمان نے بیان کیا، انہوں نے کہا کہ ہمیں شعیب نے زہری سے خبر دی، انہوں نے کہا کہ مجھ سے عرو"}
{"hadithnumber": "995", "text": "ہم سے ابو نعمان نے بیان کیا، کہا کہ ہم سے حماد بن زید نے بیان کیا، کہا کہ ہم سے انس بن سیرین نے بیان"}
{"hadithnumber": "996", "text": "ہم سے عمر بن حفص بن غیاث نے بیان کیا، کہا کہ مجھ سے میرے باپ نے بیان کیا، انہوں نے کہا کہ ہم سے اعمش"}
{"hadithnumber": "997", "text": "ہم سے مسدد بن مسرہد نے بیان کیا، کہا کہ ہم سے ہشام بن عروہ نے بیان کیا، کہا کہ مجھ سے میرے باپ نے عا"}
{"hadithnumber": "998", "text": "ہم سے مسدد بن مسرہد نے بیان کیا، کہا کہ ہم سے یحییٰ بن سعید نے بیان کیا، ان سے عبیداللہ عمری نے ان س"}
{"hadithnumber": "999", "text": "ہم سے اسماعیل نے بیان کیا، انہوں نے کہا کہ ہم سے امام مالک نے بیان کیا، انہوں نے ابوبکر بن عمر بن عب"}
{"hadithnumber": "1000", "text": "ہم سے موسیٰ بن اسماعیل نے بیان کیا، کہا کہ ہم سے جویریہ بن اسماء نے بیان کیا، ان سے نافع نے اور ان س"}
{"hadithnumber": "1001", "text": "ہم سے مسدد نے بیان کیا، کہا کہ ہم سے حماد بن زید نے بیان کیا، ان سے ایوب سختیانی نے ان سے محمد بن سی"}
{"hadithnumber": "1002", "text": "ہم سے مسدد بن مسرہد نے بیان کیا، کہا کہ ہم سے عبدالواحد بن زیاد نے بیان کیا، کہا کہ ہم سے عاصم بن سل"}
{"hadithnumber": "1003", "text": "ہم سے احمد بن یونس نے بیان کیا، کہا کہ ہم سے زائدہ نے بیان کیا، ان سے تیمی نے، ان سے ابومجلز نے، ان"}
{"hadithnumber": "1004", "text": "ہم سے مسدد بن مسرہد نے بیان کیا، کہا کہ ہمیں اسماعیل بن علیہ نے خبر دی، کہا کہ ہمیں خالد حذاء نے خبر"}
