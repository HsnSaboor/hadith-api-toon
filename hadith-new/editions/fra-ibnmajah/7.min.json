{"metadata":{"name":"Sunan Ibn Majah","section":{"0":"The Book of the Sunnah"},"section_detail":{"0":{"hadithnumber_first":1,"hadithnumber_last":266,"arabicnumber_first":1,"arabicnumber_last":266}}},"hadiths":[{"hadithnumber":7,"arabicnumber":7,"text":"Rapporté par Abu Hurairah : Le Messager d’Allah (ﷺ) a dit : \"Un groupe de ma communauté restera toujours attaché au commandement d’Allah et ceux qui s’opposent à eux ne pourront pas leur nuire","grades":[{"name":"Al-Albani","grade":"Hasan Sahih"},{"name":"Muhammad Fouad Abd al-Baqi","grade":"Hasan Sahih"},{"name":"Shuaib Al Arnaut","grade":"Sahih"},{"name":"Zubair Ali Zai","grade":"Isnaad Hasan"}],"reference":{"book":0,"hadith":7}}]}