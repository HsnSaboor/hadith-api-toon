metadata:
  section_id: 17
  section_name: رسول اللہ صلی اللہ علیہ وسلم کے خودمبارک کابیان
  hadith_first: 109
  hadith_last: 109

hadiths[1]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
109,"""The Prophet (Allah bless him and give him peace) wore two coats of mail on the Day of \nUhud, so he tried to climb the boulder but was not able. He therefore made Talha sit\nbeneath him, and the Prophet (Allah bless him and give him peace), climbed up until he stood upright on the rock."" He said: ""I heard the Prophet say (Allah bless him and give\nhim peace): 'Talha performed a deed worthy of reward'!”",,,109,"Az-Zubair ibn al-'Awwam said:",رسول اللہ صلی اللہ علیہ وسلم کے خودمبارک کابیان
