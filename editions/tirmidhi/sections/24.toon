{"hadithnumber": "1720", "arabic": "حَدَّثَنَا إِسْحَاق بْنُ مَنْصُورٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، حَدَّثَنَا عُبَيْدُ الل", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 24, Hadith 1", "international_number": "1720", "narrator_chain": ""}
{"hadithnumber": "1721", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُعَاذُ بْنُ هِشَامٍ، حَدَّثَنَا أَبِي، عَنْ قَتَادَة", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 24, Hadith 2", "international_number": "1721", "narrator_chain": ""}
{"hadithnumber": "1722", "arabic": "حَدَّثَنَا مَحْمُودُ بْنُ غَيْلَانَ، حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ، حَدَّثَنَا", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 24, Hadith 3", "international_number": "1722", "narrator_chain": ""}
{"hadithnumber": "1723", "arabic": "حَدَّثَنَا أَبُو عَمَّارٍ، حَدَّثَنَا الْفَضْلُ بْنُ مُوسَى، عَنْ مُحَمَّدِ بْنِ عَمْرٍو، حَدَّثَنَا", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 24, Hadith 4", "international_number": "1723", "narrator_chain": ""}
{"hadithnumber": "1724", "arabic": "حَدَّثَنَا مَحْمُودُ بْنُ غَيْلَانَ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا سُفْيَانُ، عَنْ أَبِي إِسْحَاق،", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 24, Hadith 5", "international_number": "1724", "narrator_chain": ""}
{"hadithnumber": "1725", "arabic": "حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، عَنْ نَافِعٍ، عَنْ إِبْرَاهِيمَ بْنِ عَبْدِ ا", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 24, Hadith 6", "international_number": "1725", "narrator_chain": ""}
{"hadithnumber": "1726", "arabic": "حَدَّثَنَا إِسْمَاعِيل بْنُ مُوسَى الْفَزَارِيُّ، حَدَّثَنَا سَيْفُ بْنُ هَارُونَ الْبُرْجُمِيُّ، عَ", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Hasan'},{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 24, Hadith 7", "international_number": "1726", "narrator_chain": ""}
{"hadithnumber": "1727", "arabic": "حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا اللَّيْثُ، عَنْ يَزِيدَ بْنِ أَبِي حَبِيبٍ، عَنْ عَطَاءِ بْنِ أَبِ", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 24, Hadith 8", "international_number": "1727", "narrator_chain": ""}
{"hadithnumber": "1728", "arabic": "حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، وَعَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ، عَن", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 24, Hadith 9", "international_number": "1728", "narrator_chain": ""}
{"hadithnumber": "1729", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ طَرِيفٍ الْكُوفِيُّ، حَدَّثَنَا مُحَمَّدُ بْنُ فُضَيْلٍ، عَنْ الْأَعْمَشِ،", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 24, Hadith 10", "international_number": "1729", "narrator_chain": ""}
{"hadithnumber": "1730", "arabic": "حَدَّثَنَا الْأَنْصَارِيُّ، حَدَّثَنَا مَعْنٌ، حَدَّثَنَا مَالِكٌ، ح وحَدَّثَنَا قُتَيْبَةُ، عَنْ مَ", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 24, Hadith 11", "international_number": "1730", "narrator_chain": ""}
{"hadithnumber": "1731", "arabic": "حَدَّثَنَا الْحَسَنُ بْنُ عَلِيٍّ الْخَلَّالُ، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَخْبَرَنَا مَعْمَرٌ،", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 24, Hadith 12", "international_number": "1731", "narrator_chain": ""}
{"hadithnumber": "1732", "arabic": "حَدَّثَنَا إِسْحَاق بْنُ مَنْصُورٍ، أَخْبَرَنَا عَفَّانُ، حَدَّثَنَا حَمَّادُ بْنُ سَلَمَةَ، عَنْ عَ", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 24, Hadith 13", "international_number": "1732", "narrator_chain": ""}
{"hadithnumber": "1733", "arabic": "حَدَّثَنَا حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا إِسْمَاعِيل بْنُ إِبْرَاهِيمَ، حَدَّثَنَا أَ", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 24, Hadith 14", "international_number": "1733", "narrator_chain": ""}
{"hadithnumber": "1734", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ حُجْرٍ، حَدَّثَنَا خَلَفُ بْنُ خَلِيفَةَ، عَنْ حُمَيْدٍ الْأَعْرَجِ، عَنْ عَ", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Very Daif'},{'name': 'Al-Albani', 'grade': 'Very Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 24, Hadith 15", "international_number": "1734", "narrator_chain": ""}
{"hadithnumber": "1735", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، عَنْ حَمَّادِ بْنِ", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 24, Hadith 16", "international_number": "1735", "narrator_chain": ""}
{"hadithnumber": "1736", "arabic": "حَدَّثَنَا هَارُونُ بْنُ إِسْحَاق الْهَمْدَانِيُّ، حَدَّثَنَا يَحْيَى بْنُ مُحَمَّدٍ الْمَدَنِيُّ، ع", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 24, Hadith 17", "international_number": "1736", "narrator_chain": ""}
{"hadithnumber": "1737", "arabic": "حَدَّثَنَا سَلَمَةُ بْنُ شَبِيبٍ، وَالْحَسَنُ بْنُ عَلِيٍّ الْخَلَّالُ، وغير واحد، ‏‏‏‏‏‏قَالُوا:‏‏‏", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 24, Hadith 18", "international_number": "1737", "narrator_chain": ""}
{"hadithnumber": "1738", "arabic": "حَدَّثَنَا يُوسُفُ بْنُ حَمَّادٍ الْمَعْنِيُّ الْبَصْرِيُّ، حَدَّثَنَا عَبْدُ الْوَارِثِ بْنُ سَعِيد", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 24, Hadith 19", "international_number": "1738", "narrator_chain": ""}
{"hadithnumber": "1739", "arabic": "حَدَّثَنَا قُتَيْبَةُ، وَغَيْرُ وَاحِدٍ، ‏‏‏‏‏‏عَنْ عَبْدِ اللَّهِ بْنِ وَهْبٍ، عَنْ يُونُسَ، عَنْ ا", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 24, Hadith 20", "international_number": "1739", "narrator_chain": ""}
{"hadithnumber": "1740", "arabic": "حَدَّثَنَا مَحْمُودُ بْنُ غَيْلَانَ، حَدَّثَنَا حَفْصُ بْنُ عُمَرَ بْنِ عُبَيْدِ اللَّهِ الطَّنَافِس", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 24, Hadith 21", "international_number": "1740", "narrator_chain": ""}
{"hadithnumber": "1741", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عُبَيْدٍ الْمُحَارِبِيُّ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ أَبِي حَازِمٍ،", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 24, Hadith 22", "international_number": "1741", "narrator_chain": ""}
{"hadithnumber": "1742", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ حُمَيْدٍ الرَّازِيُّ، حَدَّثَنَا جَرِيرٌ، عَنْ مُحَمَّدِ بْنِ إِسْحَاق، عَ", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Hasan Sahih'},{'name': 'Al-Albani', 'grade': 'Hasan Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 24, Hadith 23", "international_number": "1742", "narrator_chain": ""}
{"hadithnumber": "1743", "arabic": "حَدَّثَنَا حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِيل، عَنْ جَعْفَرِ بْنِ مُحَمَّدٍ،", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih Muquf'},{'name': 'Al-Albani', 'grade': 'Sahih Muquf'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 24, Hadith 24", "international_number": "1743", "narrator_chain": ""}
{"hadithnumber": "1744", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، عَنْ حَمَّادِ بْنِ سَلَمَةَ، قَا", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 24, Hadith 25", "international_number": "1744", "narrator_chain": ""}
{"hadithnumber": "1745", "arabic": "حَدَّثَنَا الْحَسَنُ بْنُ عَلِيٍّ الْخَلَّالُ، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَخْبَرَنَا مَعْمَرٌ،", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 24, Hadith 26", "international_number": "1745", "narrator_chain": ""}
{"hadithnumber": "1746", "arabic": "حَدَّثَنَا إِسْحَاق بْنُ مَنْصُورٍ، أَخْبَرَنَا سَعِيدُ بْنُ عَامِرٍ، وَالْحَجَّاجُ بْنُ مِنْهَالٍ،", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Daif'},{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 24, Hadith 27", "international_number": "1746", "narrator_chain": ""}
{"hadithnumber": "1747", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ الْأَنْصَارِيُّ، حَدَّثَ", "grades": "{'name': 'Zubair Ali Zai', 'grade': 'Sahih Bukhari'}", "reference": "Book 24, Hadith 28", "international_number": "1747", "narrator_chain": ""}
{"hadithnumber": "1748", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، وَمُحَمَّدُ بْنُ يَحْيَى،‏‏‏‏ وَغَيْرُ وَاحِدٍ، ‏‏‏‏‏‏قَالُوا:‏‏", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 24, Hadith 29", "international_number": "1748", "narrator_chain": ""}
{"hadithnumber": "1749", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا رَوْحُ بْنُ عُبَادَةَ، حَدَّثَنَا ابْنُ جُرَيْجٍ، أَخْب", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 24, Hadith 30", "international_number": "1749", "narrator_chain": ""}
{"hadithnumber": "1750", "arabic": "حَدَّثَنَا إِسْحَاق بْنُ مُوسَى الْأَنْصَارِيُّ، حَدَّثَنَا مَعْنٌ، حَدَّثَنَا مَالِكٌ، عَنْ أَبِي ا", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 24, Hadith 31", "international_number": "1750", "narrator_chain": ""}
{"hadithnumber": "1751", "arabic": "حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ، عَنْ أَيُّوبَ، عَنْ عِكْرِمَةَ، عَنْ ابْنِ ع", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Bukhari And Muslim'}", "reference": "Book 24, Hadith 32", "international_number": "1751", "narrator_chain": ""}
{"hadithnumber": "1752", "arabic": "حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا أَبُو عَوَانَةَ، عَنْ عُمَرَ بْنِ أَبِي سَلَمَةَ، عَنْ أَبِيهِ، عَ", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 24, Hadith 33", "international_number": "1752", "narrator_chain": ""}
{"hadithnumber": "1753", "arabic": "حَدَّثَنَا سُوَيْدُ بْنُ نَصْرٍ، أَخْبَرَنَا ابْنُ الْمُبَارَكِ، عَنْ الْأَجْلَحِ، عَنْ عَبْدِ اللَّ", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 24, Hadith 34", "international_number": "1753", "narrator_chain": ""}
{"hadithnumber": "1754", "arabic": "حَدَّثَنَا حُمَيْدُ بْنُ مَسْعَدَةَ، حَدَّثَنَا عَبْدُ الْوَهَّابِ الثَّقَفِيُّ، عَنْ حُمَيْدٍ، عَنْ", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Bukhari And Muslim'}", "reference": "Book 24, Hadith 35", "international_number": "1754", "narrator_chain": ""}
{"hadithnumber": "1755", "arabic": "حَدَّثَنَا هَنَّادٌ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ أَبِي الزِّنَادِ، عَنْ هِشَامِ بْنِ عُرْوَةَ", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Hasan Sahih'},{'name': 'Al-Albani', 'grade': 'Hasan Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 24, Hadith 36", "international_number": "1755", "narrator_chain": ""}
{"hadithnumber": "1756", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ خَشْرَمٍ، أَخْبَرَنَا عِيسَى بْنُ يُونُسَ، عَنْ هِشَامٍ، عَنْ الْحَسَنِ، عَن", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'}", "reference": "Book 24, Hadith 37", "international_number": "1756", "narrator_chain": ""}
{"hadithnumber": "1757", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ حُمَيْدٍ، حَدَّثَنَا أَبُو دَاوُدَ هُوَ الطَّيَالِسِيُّ، عَنْ عَبَّادِ بْن", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'}", "reference": "Book 24, Hadith 39", "international_number": "1757", "narrator_chain": ""}
{"hadithnumber": "1758", "arabic": "حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا يَعْقُوبُ بْنُ عَبْدِ الرَّحْمَنِ الْإِسْكَنْدَرَانِيُّ، عَنْ سُهَ", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 24, Hadith 41", "international_number": "1758", "narrator_chain": ""}
{"hadithnumber": "1759", "arabic": "حَدَّثَنَا سُوَيْدُ بْنُ نَصْرٍ، أَخْبَرَنَا عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ، عَنْ عُبَيْدِ اللَّهِ", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 24, Hadith 42", "international_number": "1759", "narrator_chain": ""}
{"hadithnumber": "1760", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ حُجْرٍ، أَخْبَرَنَا عَلِيُّ بْنُ مُسْهِرٍ، حَدَّثَنَا أَبُو إِسْحَاق الشَّيْ", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 24, Hadith 43", "international_number": "1760", "narrator_chain": ""}
{"hadithnumber": "1761", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ حُجْرٍ، أَخْبَرَنَا عَلِيُّ بْنُ مُسْهِرٍ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 24, Hadith 44", "international_number": "1761", "narrator_chain": ""}
{"hadithnumber": "1762", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ حُمَيْدٍ الرَّازِيُّ، حَدَّثَنَا أَبُو تُمَيْلَةَ، وَالْفَضْلُ بْنُ مُوسَى", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 24, Hadith 45", "international_number": "1762", "narrator_chain": ""}
{"hadithnumber": "1763", "arabic": "حَدَّثَنَا زِيَادُ بْنُ أَيُّوبَ الْبَغْدَادِيُّ، حَدَّثَنَا أَبُو تُمَيْلَةَ، عَنْ عَبْدِ الْمُؤْمِ", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 24, Hadith 46", "international_number": "1763", "narrator_chain": ""}
{"hadithnumber": "1764", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ حُجْرٍ، أَخْبَرَنَا الْفَضْلُ بْنُ مُوسَى، عَنْ عَبْدِ الْمُؤْمِنِ بْنِ خَال", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 24, Hadith 47", "international_number": "1764", "narrator_chain": ""}
{"hadithnumber": "1765", "arabic": "حَدَّثَنَا عَبْدُ اللَّهِ بْنُ مُحَمَّدِ بْنِ الْحَجَّاجِ الصَّوَّافُ الْبَصْرِيُّ، حَدَّثَنَا مُعَا", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Daif'},{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 24, Hadith 48", "international_number": "1765", "narrator_chain": ""}
{"hadithnumber": "1766", "arabic": "حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ، حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ، ح", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 24, Hadith 49", "international_number": "1766", "narrator_chain": ""}
{"hadithnumber": "1767", "arabic": "حَدَّثَنَا سُوَيْدُ بْنُ نَصْرٍ، أَخْبَرَنَا عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ، عَنْ سَعِيدٍ الْجُرَي", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan'}", "reference": "Book 24, Hadith 50", "international_number": "1767", "narrator_chain": ""}
{"hadithnumber": "1768", "arabic": "حَدَّثَنَا يُوسُفُ بْنُ عِيسَى، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا يُونُسُ بْنُ أَبِي إِسْحَاق، عَنْ الش", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 24, Hadith 52", "international_number": "1768", "narrator_chain": ""}
{"hadithnumber": "1769", "arabic": "حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا ابْنُ أَبِي زَائِدَةَ، عَنْ الْحَسَنِ بْنِ عَيَّاشٍ، عَنْ أَبِي إِ", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Sahih'},{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 24, Hadith 53", "international_number": "1769", "narrator_chain": ""}
{"hadithnumber": "1770", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا عَلِيُّ بْنُ هَاشِمِ بْنِ الْبَرِيدِ، وَأَبُو سَعْدٍ ال", "grades": "{'name': 'Ahmad Muhammad Shakir', 'grade': 'Hasan'},{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Bashar Awad Maarouf', 'grade': 'Hasan'}", "reference": "Book 24, Hadith 54", "international_number": "1770", "narrator_chain": ""}
{"hadithnumber": "1771", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، حَدَّثَنَا شُعْبَةُ، عَنْ يَ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 24, Hadith 59", "international_number": "1771", "narrator_chain": ""}
{"hadithnumber": "1772", "arabic": "حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ عُمَرَ، عَنْ نَافِعٍ، عَنْ سَعِيدِ بْنِ أَبِي هِنْدٍ، عَنْ أَبِي مُوسَى الأَشْعَرِيِّ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ حُرِّمَ لِبَاسُ الْحَرِيرِ وَالذَّهَبِ عَلَى ذُكُورِ أُمَّتِي وَأُحِلَّ لإِنَاثِهِمْ ‏\"\"‏ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ عُمَرَ وَعَلِيٍّ وَعُقْبَةَ بْنِ عَامِرٍ وَأَنَسٍ وَحُذَيْفَةَ وَأُمِّ هَانِئٍ وَعَبْدِ اللَّهِ بْنِ عَمْرٍو وَعِمْرَانَ بْنِ حُصَيْنٍ وَعَبْدِ اللَّهِ بْنِ الزُّبَيْرِ وَجَابِرٍ وَأَبِي رَيْحَانَةَ وَابْنِ عُمَرَ وَوَاثِلَةَ بْنِ الأَسْقَعِ ‏.‏ وَحَدِيثُ أَبِي مُوسَى حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Narrated Abu Musa Al-Ash'ari:"}
{"hadithnumber": "1773", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُعَاذُ بْنُ هِشَامٍ، حَدَّثَنَا أَبِي، عَنْ قَتَادَةَ، عَنِ الشَّعْبِيِّ، عَنْ سُوَيْدِ بْنِ غَفَلَةَ، عَنْ عُمَرَ، أَنَّهُ خَطَبَ بِالْجَابِيَةِ فَقَالَ نَهَى نَبِيُّ اللَّهِ صلى الله عليه وسلم عَنِ الْحَرِيرِ إِلاَّ مَوْضِعَ أُصْبُعَيْنِ أَوْ ثَلاَثٍ أَوْ أَرْبَعٍ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏", "grades": "", "reference": "", "international_number": "1773", "narrator_chain": "Narrated Suwaid bin Ghafalah:"}
{"hadithnumber": "1774", "arabic": "حَدَّثَنَا مَحْمُودُ بْنُ غَيْلاَنَ، حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ، حَدَّثَنَا هَمَّامٌ، حَدَّثَنَا قَتَادَةُ، عَنْ أَنَسِ بْنِ مَالِكٍ، أَنَّ عَبْدَ الرَّحْمَنِ بْنَ عَوْفٍ، وَالزُّبَيْرَ بْنَ الْعَوَّامِ، شَكَيَا الْقَمْلَ إِلَى النَّبِيِّ صلى الله عليه وسلم فِي غَزَاةٍ لَهُمَا فَرَخَّصَ لَهُمَا فِي قُمُصِ الْحَرِيرِ قَالَ وَرَأَيْتُهُ عَلَيْهِمَا ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏", "grades": "", "reference": "", "international_number": "1774", "narrator_chain": "Narrated Anas bin Malik:"}
{"hadithnumber": "1775", "arabic": "حَدَّثَنَا أَبُو عَمَّارٍ، حَدَّثَنَا الْفَضْلُ بْنُ مُوسَى، عَنْ مُحَمَّدِ بْنِ عَمْرٍو، حَدَّثَنَا وَاقِدُ بْنُ عَمْرِو بْنِ سَعْدِ بْنِ مُعَاذٍ، قَالَ قَدِمَ أَنَسُ بْنُ مَالِكٍ فَأَتَيْتُهُ فَقَالَ مَنْ أَنْتَ فَقُلْتُ أَنَا وَاقِدُ بْنُ عَمْرِو بْنِ سَعْدِ بْنِ مُعَاذٍ، ‏.‏ قَالَ فَبَكَى وَقَالَ إِنَّكَ لَشَبِيهٌ بِسَعْدٍ وَإِنَّ سَعْدًا كَانَ مِنْ أَعْظَمِ النَّاسِ وَأَطْوَلِهِمْ وَإِنَّهُ بَعَثَ إِلَى النَّبِيِّ صلى الله عليه وسلم جُبَّةً مِنْ دِيبَاجٍ مَنْسُوجٌ فِيهَا الذَّهَبُ فَلَبِسَهَا رَسُولُ اللَّهِ صلى الله عليه وسلم فَصَعِدَ الْمِنْبَرَ فَقَامَ أَوْ قَعَدَ فَجَعَلَ النَّاسُ يَلْمُسُونَهَا فَقَالُوا مَا رَأَيْنَا كَالْيَوْمِ ثَوْبًا قَطُّ ‏.‏ فَقَالَ ‏ ‏ أَتَعْجَبُونَ مِنْ هَذِهِ لَمَنَادِيلُ سَعْدٍ فِي الْجَنَّةِ خَيْرٌ مِمَّا تَرَوْنَ ‏\"\"‏ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ أَسْمَاءَ بِنْتِ أَبِي بَكْرٍ ‏.‏ وَهَذَا حَدِيثٌ صَحِيحٌ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Narrated Waqid bin 'Amr bin Sa'd bin Mu'adh:"}
{"hadithnumber": "1776", "arabic": "حَدَّثَنَا مَحْمُودُ بْنُ غَيْلاَنَ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا سُفْيَانُ، عَنْ أَبِي إِسْحَاقَ، عَنِ الْبَرَاءِ، قَالَ مَا رَأَيْتُ مِنْ ذِي لِمَّةٍ فِي حُلَّةٍ حَمْرَاءَ أَحْسَنَ مِنْ رَسُولِ اللَّهِ صلى الله عليه وسلم لَهُ شَعْرٌ يَضْرِبُ مَنْكِبَيْهِ بَعِيدُ مَا بَيْنَ الْمَنْكِبَيْنِ لَمْ يَكُنْ بِالْقَصِيرِ وَلاَ بِالطَّوِيلِ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ جَابِرِ بْنِ سَمُرَةَ وَأَبِي رِمْثَةَ وَأَبِي جُحَيْفَةَ ‏.‏ وَهَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏", "grades": "", "reference": "", "international_number": "1776", "narrator_chain": "Narrated Al-Bara' :"}
{"hadithnumber": "1777", "arabic": "حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، عَنْ نَافِعٍ، عَنْ إِبْرَاهِيمَ بْنِ عَبْدِ اللَّهِ بْنِ حُنَيْنٍ، عَنْ أَبِيهِ، عَنْ عَلِيٍّ، قَالَ نَهَانِي النَّبِيُّ صلى الله عليه وسلم عَنْ لُبْسِ الْقَسِّيِّ وَالْمُعَصْفَرِ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ أَنَسٍ وَعَبْدِ اللَّهِ بْنِ عَمْرٍو وَحَدِيثُ عَلِيٍّ حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏", "grades": "", "reference": "", "international_number": "1777", "narrator_chain": "Narrated 'Ali:"}
{"hadithnumber": "1778", "arabic": "حَدَّثَنَا إِسْمَاعِيلُ بْنُ مُوسَى الْفَزَارِيُّ، حَدَّثَنَا سَيْفُ بْنُ هَارُونَ الْبُرْجُمِيُّ، عَنْ سُلَيْمَانَ التَّيْمِيِّ، عَنْ أَبِي عُثْمَانَ، عَنْ سَلْمَانَ، قَالَ سُئِلَ رَسُولُ اللَّهِ صلى الله عليه وسلم عَنِ السَّمْنِ وَالْجُبْنِ وَالْفِرَاءِ ‏.‏ فَقَالَ ‏ ‏ الْحَلاَلُ مَا أَحَلَّ اللَّهُ فِي كِتَابِهِ وَالْحَرَامُ مَا حَرَّمَ اللَّهُ فِي كِتَابِهِ وَمَا سَكَتَ عَنْهُ فَهُوَ مِمَّا عَفَا عَنْهُ ‏\"\"‏ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنِ الْمُغِيرَةِ ‏.‏ وَهَذَا حَدِيثٌ غَرِيبٌ لاَ نَعْرِفُهُ مَرْفُوعًا إِلاَّ مِنْ هَذَا الْوَجْهِ ‏.‏ وَرَوَى سُفْيَانُ وَغَيْرُهُ عَنْ سُلَيْمَانَ التَّيْمِيِّ عَنْ أَبِي عُثْمَانَ عَنْ سَلْمَانَ قَوْلَهُ وَكَأَنَّ الْحَدِيثَ الْمَوْقُوفَ أَصَحُّ ‏.‏ وَسَأَلْتُ الْبُخَارِيَّ عَنْ هَذَا الْحَدِيثِ فَقَالَ مَا أُرَاهُ مَحْفُوظًا رَوَى سُفْيَانُ عَنْ سُلَيْمَانَ التَّيْمِيِّ عَنْ أَبِي عُثْمَانَ عَنْ سَلْمَانَ مَوْقُوفًا ‏.‏ قَالَ الْبُخَارِيُّ وَسَيْفُ بْنُ هَارُونَ مُقَارِبُ الْحَدِيثِ وَسَيْفُ بْنُ مُحَمَّدٍ عَنْ عَاصِمٍ ذَاهِبُ الْحَدِيثِ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Narrated Salman:"}
{"hadithnumber": "1779", "arabic": "حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا اللَّيْثُ، عَنْ يَزِيدَ بْنِ أَبِي حَبِيبٍ، عَنْ عَطَاءِ بْنِ أَبِي رَبَاحٍ، قَالَ سَمِعْتُ ابْنَ عَبَّاسٍ، يَقُولُ مَاتَتْ شَاةٌ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم لأَهْلِهَا ‏ ‏ أَلاَ نَزَعْتُمْ جِلْدَهَا ثُمَّ دَبَغْتُمُوهُ فَاسْتَمْتَعْتُمْ بِهِ ‏\"\"‏ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ سَلَمَةَ بْنِ الْمُحَبِّقِ وَمَيْمُونَةَ وَعَائِشَةَ ‏.‏ وَحَدِيثُ ابْنِ عَبَّاسٍ حَسَنٌ صَحِيحٌ وَقَدْ رُوِيَ مِنْ غَيْرِ وَجْهٍ عَنِ ابْنِ عَبَّاسٍ عَنِ النَّبِيِّ صلى الله عليه وسلم نَحْوُ هَذَا ‏.‏ وَرُوِيَ عَنِ ابْنِ عَبَّاسٍ عَنْ مَيْمُونَةَ عَنِ النَّبِيِّ صلى الله عليه وسلم ‏.‏ وَرُوِيَ عَنْهُ عَنْ سَوْدَةَ وَسَمِعْتُ مُحَمَّدًا يُصَحِّحُ حَدِيثَ ابْنِ عَبَّاسٍ عَنِ النَّبِيِّ صلى الله عليه وسلم وَحَدِيثَ ابْنِ عَبَّاسٍ عَنْ مَيْمُونَةَ وَقَالَ احْتَمَلَ أَنْ يَكُونَ رَوَى ابْنُ عَبَّاسٍ عَنْ مَيْمُونَةَ عَنِ النَّبِيِّ صلى الله عليه وسلم وَرَوَى ابْنُ عَبَّاسٍ عَنِ النَّبِيِّ صلى الله عليه وسلم وَلَمْ يَذْكُرْ فِيهِ عَنْ مَيْمُونَةَ ‏.‏ قَالَ أَبُو عِيسَى وَالْعَمَلُ عَلَى هَذَا عِنْدَ أَكْثَرِ أَهْلِ الْعِلْمِ وَهُوَ قَوْلُ سُفْيَانَ الثَّوْرِيِّ وَابْنِ الْمُبَارَكِ وَالشَّافِعِيِّ وَأَحْمَدَ وَإِسْحَاقَ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Narrated Ibn 'Abbas:"}
{"hadithnumber": "1780", "arabic": "حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، وَعَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ، عَنْ زَيْدِ بْنِ أَسْلَمَ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ وَعْلَةَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ أَيُّمَا إِهَابٍ دُبِغَ فَقَدْ طَهُرَ ‏\"‏ ‏.‏ هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَالْعَمَلُ عَلَى هَذَا عِنْدَ أَكْثَرِ أَهْلِ الْعِلْمِ قَالُوا فِي جُلُودِ الْمَيْتَةِ إِذَا دُبِغَتْ فَقَدْ طَهُرَتْ ‏.‏ قَالَ أَبُو عِيسَى قَالَ الشَّافِعِيُّ أَيُّمَا إِهَابِ مَيْتَةٍ دُبِغَ فَقَدْ طَهُرَ إِلاَّ الْكَلْبَ وَالْخِنْزِيرَ ‏.‏ وَاحْتَجَّ بِهَذَا الْحَدِيثِ ‏.‏ وَقَالَ بَعْضُ أَهْلِ الْعِلْمِ مِنْ أَصْحَابِ النَّبِيِّ صلى الله عليه وسلم وَغَيْرِهِمْ إِنَّهُمْ كَرِهُوا جُلُودَ السِّبَاعِ وَإِنْ دُبِغَ وَهُوَ قَوْلُ عَبْدِ اللَّهِ بْنِ الْمُبَارَكِ وَأَحْمَدَ وَإِسْحَاقَ وَشَدَّدُوا فِي لُبْسِهَا وَالصَّلاَةِ فِيهَا ‏.‏ قَالَ إِسْحَاقُ بْنُ إِبْرَاهِيمَ إِنَّمَا مَعْنَى قَوْلِ رَسُولِ اللَّهِ صلى الله عليه وسلم ‏\"‏ أَيُّمَا إِهَابٍ دُبِغَ فَقَدْ طَهُرَ ‏\"‏ ‏.‏ جِلْدُ مَا يُؤْكَلُ لَحْمُهُ هَكَذَا فَسَّرَهُ النَّضْرُ بْنُ شُمَيْلٍ ‏.‏ وَقَالَ إِسْحَاقُ قَالَ النَّضْرُ بْنُ شُمَيْلٍ إِنَّمَا يُقَالُ الإِهَابُ لِجِلْدِ مَا يُؤْكَلُ لَحْمُهُ ‏.‏", "grades": "", "reference": "", "international_number": "1780", "narrator_chain": "Narrated Ibn 'Abbas:"}
{"hadithnumber": "1781", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ طَرِيفٍ الْكُوفِيُّ، حَدَّثَنَا مُحَمَّدُ بْنُ فُضَيْلٍ، عَنِ الأَعْمَشِ، وَالشَّيْبَانِيِّ، عَنِ الْحَكَمِ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِي لَيْلَى، عَنْ عَبْدِ اللَّهِ بْنِ عُكَيْمٍ، قَالَ أَتَانَا كِتَابُ رَسُولِ اللَّهِ صلى الله عليه وسلم ‏ ‏ أَنْ لاَ تَنْتَفِعُوا مِنَ الْمَيْتَةِ بِإِهَابٍ وَلاَ عَصَبٍ ‏\"\"‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ ‏.‏ وَيُرْوَى عَنْ عَبْدِ اللَّهِ بْنِ عُكَيْمٍ عَنْ أَشْيَاخٍ لَهُمْ هَذَا الْحَدِيثُ ‏.‏ وَلَيْسَ الْعَمَلُ عَلَى هَذَا عِنْدَ أَكْثَرِ أَهْلِ الْعِلْمِ ‏.‏ وَقَدْ رُوِيَ هَذَا الْحَدِيثُ عَنْ عَبْدِ اللَّهِ بْنِ عُكَيْمٍ أَنَّهُ قَالَ أَتَانَا كِتَابُ النَّبِيِّ صلى الله عليه وسلم قَبْلَ وَفَاتِهِ بِشَهْرَيْنِ ‏.‏ قَالَ وَسَمِعْتُ أَحْمَدَ بْنَ الْحَسَنِ يَقُولُ كَانَ أَحْمَدُ بْنُ حَنْبَلٍ يَذْهَبُ إِلَى هَذَا الْحَدِيثِ لِمَا ذُكِرَ فِيهِ قَبْلَ وَفَاتِهِ بِشَهْرَيْنِ وَكَانَ يَقُولُ كَانَ هَذَا آخِرَ أَمْرِ النَّبِيِّ صلى الله عليه وسلم ‏.‏ ثُمَّ تَرَكَ أَحْمَدُ بْنُ حَنْبَلٍ هَذَا الْحَدِيثَ لَمَّا اضْطَرَبُوا فِي إِسْنَادِهِ حَيْثُ رَوَى بَعْضُهُمْ فَقَالَ عَنْ عَبْدِ اللَّهِ بْنِ عُكَيْمٍ عَنْ أَشْيَاخٍ لَهُمْ مِنْ جُهَيْنَةَ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Narrated 'Abdullah bin 'Ukaim:"}
{"hadithnumber": "1782", "arabic": "حَدَّثَنَا الأَنْصَارِيُّ، حَدَّثَنَا مَعْنٌ، حَدَّثَنَا مَالِكٌ، ح وَحَدَّثَنَا قُتَيْبَةُ، عَنْ مَالِكٍ، عَنْ نَافِعٍ، وَعَبْدِ اللَّهِ بْنِ دِينَارٍ، وَزَيْدِ بْنِ أَسْلَمَ، كُلُّهُمْ يُخْبِرُ عَنْ عَبْدِ اللَّهِ بْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ لاَ يَنْظُرُ اللَّهُ يَوْمَ الْقِيَامَةِ إِلَى مَنْ جَرَّ ثَوْبَهُ خُيَلاَءَ ‏\"\"‏ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ حُذَيْفَةَ وَأَبِي سَعِيدٍ وَأَبِي هُرَيْرَةَ وَسَمُرَةَ وَأَبِي ذَرٍّ وَعَائِشَةَ وَهُبَيْبِ بْنِ مُغْفِلٍ ‏.‏ وَحَدِيثُ ابْنِ عُمَرَ حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Narrated 'Abdullah bin 'Umar:"}
{"hadithnumber": "1783", "arabic": "حَدَّثَنَا الْحَسَنُ بْنُ عَلِيٍّ الْخَلاَّلُ، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَخْبَرَنَا مَعْمَرٌ، عَنْ أَيُّوبَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ مَنْ جَرَّ ثَوْبَهُ خُيَلاَءَ لَمْ يَنْظُرِ اللَّهُ إِلَيْهِ يَوْمَ الْقِيَامَةِ ‏\"‏ ‏.‏ فَقَالَتْ أُمُّ سَلَمَةَ فَكَيْفَ يَصْنَعْنَ النِّسَاءُ بِذُيُولِهِنَّ قَالَ ‏\"‏ يُرْخِينَ شِبْرًا ‏\"‏ ‏.‏ فَقَالَتْ إِذًا تَنْكَشِفَ أَقْدَامُهُنَّ ‏.‏ قَالَ ‏\"‏ فَيُرْخِينَهُ ذِرَاعًا لاَ يَزِدْنَ عَلَيْهِ ‏\"‏ ‏.‏ قَالَ هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏", "grades": "", "reference": "", "international_number": "1783", "narrator_chain": "Narrated Ibn 'Umar:"}
{"hadithnumber": "1784", "arabic": "حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ، أَخْبَرَنَا عَفَّانُ، حَدَّثَنَا حَمَّادُ بْنُ سَلَمَةَ، عَنْ عَلِيِّ بْنِ زَيْدٍ، عَنْ أُمِّ الْحَسَنِ الْبَصْرِيِّ، أَنَّ أُمَّ سَلَمَةَ، حَدَّثَتْهُمْ أَنَّ النَّبِيَّ صلى الله عليه وسلم شَبَّرَ لِفَاطِمَةَ شِبْرًا مِنْ نِطَاقِهَا ‏.‏ قَالَ أَبُو عِيسَى وَرَوَى بَعْضُهُمْ عَنْ حَمَّادِ بْنِ سَلَمَةَ عَنْ عَلِيِّ بْنِ زَيْدٍ عَنِ الْحَسَنِ عَنْ أُمِّهِ عَنْ أُمِّ سَلَمَةَ ‏.‏ وَفِي هَذَا الْحَدِيثِ رُخْصَةٌ لِلنِّسَاءِ فِي جَرِّ الإِزَارِ لأَنَّهُ يَكُونُ أَسْتَرَ لَهُنَّ ‏.‏", "grades": "", "reference": "", "international_number": "1784", "narrator_chain": "Narrated Umm Salamah:"}
{"hadithnumber": "1785", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ إِبْرَاهِيمَ، حَدَّثَنَا أَيُّوبُ، عَنْ حُمَيْدِ بْنِ هِلاَلٍ، عَنْ أَبِي بُرْدَةَ، قَالَ أَخْرَجَتْ إِلَيْنَا عَائِشَةُ كِسَاءً مُلَبَّدًا وَإِزَارًا غَلِيظًا فَقَالَتْ قُبِضَ رُوحُ رَسُولِ اللَّهِ صلى الله عليه وسلم فِي هَذَيْنِ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ عَلِيٍّ وَابْنِ مَسْعُودٍ ‏.‏ وَحَدِيثُ عَائِشَةَ حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏", "grades": "", "reference": "", "international_number": "1785", "narrator_chain": "Narrated Abu Burdah:"}
{"hadithnumber": "1786", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ حُجْرٍ، حَدَّثَنَا خَلَفُ بْنُ خَلِيفَةَ، عَنْ حُمَيْدٍ الأَعْرَجِ، عَنْ عَبْدِ اللَّهِ بْنِ الْحَارِثِ، عَنِ ابْنِ مَسْعُودٍ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ كَانَ عَلَى مُوسَى يَوْمَ كَلَّمَهُ رَبُّهُ كِسَاءُ صُوفٍ وَجُبَّةُ صُوفٍ وَكُمَّةُ صُوفٍ وَسَرَاوِيلُ صُوفٍ وَكَانَتْ نَعْلاَهُ مِنْ جِلْدِ حِمَارٍ مَيِّتٍ ‏\"\"‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ غَرِيبٌ لاَ نَعْرِفُهُ إِلاَّ مِنْ حَدِيثِ حُمَيْدٍ الأَعْرَجِ ‏.‏ وَحُمَيْدٌ هُوَ ابْنُ عَلِيٍّ الْكُوفِيُّ ‏.‏ قَالَ سَمِعْتُ مُحَمَّدًا يَقُولُ حُمَيْدُ بْنُ عَلِيٍّ الأَعْرَجُ مُنْكَرُ الْحَدِيثِ وَحُمَيْدُ بْنُ قَيْسٍ الأَعْرَجُ الْمَكِّيُّ صَاحِبُ مُجَاهِدٍ ثِقَةٌ ‏.‏ وَالْكُمَّةُ الْقَلَنْسُوَةُ الصَّغِيرَةُ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Narrated Ibn Mas'ud:"}
{"hadithnumber": "1787", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، عَنْ حَمَّادِ بْنِ سَلَمَةَ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، قَالَ دَخَلَ النَّبِيُّ صلى الله عليه وسلم مَكَّةَ يَوْمَ الْفَتْحِ وَعَلَيْهِ عِمَامَةٌ سَوْدَاءُ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ عَلِيٍّ وَعَمْرِو بْنِ حُرَيْثٍ وَابْنِ عَبَّاسٍ وَرُكَانَةَ ‏.‏ قَالَ أَبُو عِيسَى حَدِيثُ جَابِرٍ حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏", "grades": "", "reference": "", "international_number": "1787", "narrator_chain": "Narrated Jabir:"}
{"hadithnumber": "1788", "arabic": "حَدَّثَنَا هَارُونُ بْنُ إِسْحَاقَ الْهَمْدَانِيُّ، حَدَّثَنَا يَحْيَى بْنُ مُحَمَّدٍ الْمَدَنِيُّ، عَنْ عَبْدِ الْعَزِيزِ بْنِ مُحَمَّدٍ، عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ كَانَ النَّبِيُّ صلى الله عليه وسلم إِذَا اعْتَمَّ سَدَلَ عِمَامَتَهُ بَيْنَ كَتِفَيْهِ ‏.‏ قَالَ نَافِعٌ وَكَانَ ابْنُ عُمَرَ يَسْدِلُ عِمَامَتَهُ بَيْنَ كَتِفَيْهِ ‏.‏ قَالَ عُبَيْدُ اللَّهِ وَرَأَيْتُ الْقَاسِمَ وَسَالِمًا يَفْعَلاَنِ ذَلِكَ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ غَرِيبٌ ‏.‏ وَفِي الْبَابِ عَنْ عَلِيٍّ وَلاَ يَصِحُّ حَدِيثُ عَلِيٍّ فِي هَذَا مِنْ قِبَلِ إِسْنَادِهِ ‏.", "grades": "", "reference": "", "international_number": "1788", "narrator_chain": "Narrated Nafi':"}
{"hadithnumber": "1789", "arabic": "حَدَّثَنَا سَلَمَةُ بْنُ شَبِيبٍ، وَالْحَسَنُ بْنُ عَلِيٍّ الْخَلاَّلُ، وَغَيْرُ، وَاحِدٍ، قَالُوا حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَخْبَرَنَا مَعْمَرٌ، عَنِ الزُّهْرِيِّ، عَنْ إِبْرَاهِيمَ بْنِ عَبْدِ اللَّهِ بْنِ حُنَيْنٍ، عَنْ أَبِيهِ، عَنْ عَلِيِّ بْنِ أَبِي طَالِبٍ، قَالَ نَهَانِي النَّبِيُّ صلى الله عليه وسلم عَنِ التَّخَتُّمِ بِالذَّهَبِ وَعَنْ لِبَاسِ الْقَسِّيِّ وَعَنِ الْقِرَاءَةِ فِي الرُّكُوعِ وَالسُّجُودِ وَعَنْ لِبَاسِ الْمُعَصْفَرِ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏", "grades": "", "reference": "", "international_number": "1789", "narrator_chain": "Narrated 'Ali bin Abi Talib:"}
{"hadithnumber": "1790", "arabic": "حَدَّثَنَا يُوسُفُ بْنُ حَمَّادٍ الْمَعْنِيُّ الْبَصْرِيُّ، حَدَّثَنَا عَبْدُ الْوَارِثِ بْنُ سَعِيدٍ، عَنْ أَبِي التَّيَّاحِ، حَدَّثَنَا حَفْصٌ اللَّيْثِيُّ، قَالَ أَشْهَدُ عَلَى عِمْرَانَ بْنِ حُصَيْنٍ أَنَّهُ حَدَّثَنَا أَنَّهُ، قَالَ نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم عَنِ التَّخَتُّمِ بِالذَّهَبِ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ عَلِيٍّ وَابْنِ عُمَرَ وَأَبِي هُرَيْرَةَ وَمُعَاوِيَةَ ‏.‏ قَالَ أَبُو عِيسَى حَدِيثُ عِمْرَانَ حَدِيثٌ حَسَنٌ ‏.‏ وَأَبُو التَّيَّاحِ اسْمُهُ يَزِيدُ بْنُ حُمَيْدٍ ‏.‏", "grades": "", "reference": "", "international_number": "1790", "narrator_chain": "Narrated 'Imran bin Husain:"}
{"hadithnumber": "1791", "arabic": "حَدَّثَنَا قُتَيْبَةُ، وَغَيْرُ، وَاحِدٍ، عَنْ عَبْدِ اللَّهِ بْنِ وَهْبٍ، عَنْ يُونُسَ، عَنِ ابْنِ شِهَابٍ، عَنْ أَنَسٍ، قَالَ كَانَ خَاتَمُ النَّبِيِّ صلى الله عليه وسلم مِنْ وَرِقٍ وَكَانَ فَصُّهُ حَبَشِيًّا ‏.‏ قَالَ وَفِي الْبَابِ عَنِ ابْنِ عُمَرَ وَبُرَيْدَةَ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ غَرِيبٌ مِنْ هَذَا الْوَجْهِ ‏.‏", "grades": "", "reference": "", "international_number": "1791", "narrator_chain": "Narrated Anas:"}
{"hadithnumber": "1792", "arabic": "حَدَّثَنَا مَحْمُودُ بْنُ غَيْلاَنَ، حَدَّثَنَا حَفْصُ بْنُ عُمَرَ بْنِ عُبَيْدٍ الطَّنَافِسِيُّ، حَدَّثَنَا زُهَيْرُ بْنُ مُعَاوِيَةَ أَبُو خَيْثَمَةَ، عَنْ حُمَيْدٍ، عَنْ أَنَسٍ، قَالَ كَانَ خَاتَمُ رَسُولِ اللَّهِ صلى الله عليه وسلم مِنْ فِضَّةٍ فَصُّهُ مِنْهُ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ غَرِيبٌ مِنْ هَذَا الْوَجْهِ ‏.‏", "grades": "", "reference": "", "international_number": "1792", "narrator_chain": "Narrated Anas:"}
{"hadithnumber": "1793", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عُبَيْدٍ الْمُحَارِبِيُّ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ أَبِي حَازِمٍ، عَنْ مُوسَى بْنِ عُقْبَةَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ النَّبِيَّ صلى الله عليه وسلم صَنَعَ خَاتَمًا مِنْ ذَهَبٍ فَتَخَتَّمَ بِهِ فِي يَمِينِهِ ثُمَّ جَلَسَ عَلَى الْمِنْبَرِ فَقَالَ ‏ ‏ إِنِّي كُنْتُ اتَّخَذْتُ هَذَا الْخَاتَمَ فِي يَمِينِي ‏\"\"‏ ‏.‏ ثُمَّ نَبَذَهُ وَنَبَذَ النَّاسُ خَوَاتِيمَهُمْ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ عَلِيٍّ وَجَابِرٍ وَعَبْدِ اللَّهِ بْنِ جَعْفَرٍ وَابْنِ عَبَّاسٍ وَعَائِشَةَ وَأَنَسٍ ‏.‏ قَالَ أَبُو عِيسَى حَدِيثُ ابْنِ عُمَرَ حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَقَدْ رُوِيَ هَذَا الْحَدِيثُ عَنْ نَافِعٍ عَنِ ابْنِ عُمَرَ نَحْوَ هَذَا مِنْ غَيْرِ هَذَا الْوَجْهِ وَلَمْ يَذْكُرْ فِيهِ أَنَّهُ تَخَتَّمَ فِي يَمِينِهِ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Narrated Ibn 'Umar:"}
{"hadithnumber": "1794", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ حُمَيْدٍ الرَّازِيُّ، حَدَّثَنَا جَرِيرٌ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ، عَنِ الصَّلْتِ بْنِ عَبْدِ اللَّهِ بْنِ نَوْفَلٍ، قَالَ رَأَيْتُ ابْنَ عَبَّاسٍ يَتَخَتَّمُ فِي يَمِينِهِ وَلاَ إِخَالُهُ إِلاَّ قَالَ رَأَيْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم يَتَخَتَّمُ فِي يَمِينِهِ ‏.‏ قَالَ أَبُو عِيسَى قَالَ مُحَمَّدُ بْنُ إِسْمَاعِيلَ حَدِيثُ مُحَمَّدِ بْنِ إِسْحَاقَ عَنِ الصَّلْتِ بْنِ عَبْدِ اللَّهِ بْنِ نَوْفَلٍ حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏", "grades": "", "reference": "", "international_number": "1794", "narrator_chain": "Narrated As-Salt bin 'Abdullah bin Nawfal:"}
{"hadithnumber": "1795", "arabic": "حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِيلَ، عَنْ جَعْفَرِ بْنِ مُحَمَّدٍ، عَنْ أَبِيهِ، قَالَ كَانَ الْحَسَنُ وَالْحُسَيْنُ يَتَخَتَّمَانِ فِي يَسَارِهِمَا ‏.‏ وَهَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏", "grades": "", "reference": "", "international_number": "1795", "narrator_chain": "Narrated Ja'far bin Muhammad :"}
{"hadithnumber": "1796", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، عَنْ حَمَّادِ بْنِ سَلَمَةَ، قَالَ رَأَيْتُ ابْنَ أَبِي رَافِعٍ يَتَخَتَّمُ فِي يَمِينِهِ فَسَأَلْتُهُ عَنْ ذَلِكَ، فَقَالَ رَأَيْتُ عَبْدَ اللَّهِ بْنَ جَعْفَرٍ يَتَخَتَّمُ فِي يَمِينِهِ ‏.‏ وَقَالَ عَبْدُ اللَّهِ بْنُ جَعْفَرٍ كَانَ النَّبِيُّ صلى الله عليه وسلم يَتَخَتَّمُ فِي يَمِينِهِ ‏.‏ قَالَ وَقَالَ مُحَمَّدُ بْنُ إِسْمَاعِيلَ هَذَا أَصَحُّ شَيْءٍ رُوِيَ فِي هَذَا الْبَابِ ‏.‏", "grades": "", "reference": "", "international_number": "1796", "narrator_chain": "Narrated Hammad bin Salamah:"}
{"hadithnumber": "1797", "arabic": "حَدَّثَنَا الْحَسَنُ بْنُ عَلِيٍّ الْخَلاَّلُ، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَخْبَرَنَا مَعْمَرٌ، عَنْ ثَابِتٍ، عَنْ أَنَسِ بْنِ مَالِكٍ، أَنَّ النَّبِيَّ صلى الله عليه وسلم صَنَعَ خَاتَمًا مِنْ وَرِقٍ فَنَقَشَ فِيهِ مُحَمَّدٌ رَسُولُ اللَّهِ ثُمَّ قَالَ ‏\"‏ لاَ تَنْقُشُوا عَلَيْهِ ‏\"‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ صَحِيحٌ حَسَنٌ ‏.‏ وَمَعْنَى قَوْلِهِ ‏\"‏ لاَ تَنْقُشُوا عَلَيْهِ ‏\"‏ ‏.‏ نَهَى أَنْ يَنْقُشَ أَحَدٌ عَلَى خَاتَمِهِ مُحَمَّدٌ رَسُولُ اللَّهِ ‏.‏", "grades": "", "reference": "", "international_number": "1797", "narrator_chain": "Narrated Anas bin Malik:"}
{"hadithnumber": "1798", "arabic": "حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ، أَخْبَرَنَا سَعِيدُ بْنُ عَامِرٍ، وَالْحَجَّاجُ بْنُ مِنْهَالٍ، قَالاَ حَدَّثَنَا هَمَّامٌ، عَنِ ابْنِ جُرَيْجٍ، عَنِ الزُّهْرِيِّ، عَنْ أَنَسٍ، قَالَ كَانَ رَسُولُ اللَّهِ صلى الله عليه وسلم إِذَا دَخَلَ الْخَلاَءَ نَزَعَ خَاتَمَهُ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ غَرِيبٌ ‏.‏", "grades": "", "reference": "", "international_number": "1798", "narrator_chain": "Narrated Anas:"}
{"hadithnumber": "1799", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ الأَنْصَارِيُّ، حَدَّثَنَا أَبِي، عَنْ ثُمَامَةَ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ كَانَ نَقْشُ خَاتَمِ النَّبِيِّ صلى الله عليه وسلم مُحَمَّدٌ سَطْرٌ وَرَسُولُ سَطْرٌ وَاللَّهِ سَطْرٌ ‏.‏ قَالَ أَبُو عِيسَى حَدِيثُ أَنَسٍ حَدِيثٌ حَسَنٌ صَحِيحٌ غَرِيبٌ ‏.‏", "grades": "", "reference": "", "international_number": "1799", "narrator_chain": "Narrated Anas bin Malik:"}
{"hadithnumber": "1800", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، وَمُحَمَّدُ بْنُ يَحْيَى، وَغَيْرُ، وَاحِدٍ، قَالُوا حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ الأَنْصَارِيُّ، حَدَّثَنِي أَبِي، عَنْ ثُمَامَةَ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ كَانَ نَقْشُ خَاتَمِ النَّبِيِّ صلى الله عليه وسلم ثَلاَثَةَ أَسْطُرٍ مُحَمَّدٌ سَطْرٌ وَرَسُولُ سَطْرٌ وَاللَّهِ سَطْرٌ ‏.‏ وَلَمْ يَذْكُرْ مُحَمَّدُ بْنُ يَحْيَى فِي حَدِيثِهِ ثَلاَثَةَ أَسْطُرٍ ‏.‏ وَفِي الْبَابِ عَنِ ابْنِ عُمَرَ ‏.‏", "grades": "", "reference": "", "international_number": "1800", "narrator_chain": "Narrated Anas bin Malik:"}
{"hadithnumber": "1801", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا رَوْحُ بْنُ عُبَادَةَ، حَدَّثَنَا ابْنُ جُرَيْجٍ، أَخْبَرَنِي أَبُو الزُّبَيْرِ، عَنْ جَابِرٍ، قَالَ نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم عَنِ الصُّورَةِ فِي الْبَيْتِ وَنَهَى أَنْ يُصْنَعَ ذَلِكَ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ عَلِيٍّ وَأَبِي طَلْحَةَ وَعَائِشَةَ وَأَبِي هُرَيْرَةَ وَأَبِي أَيُّوبَ ‏.‏ قَالَ أَبُو عِيسَى حَدِيثُ جَابِرٍ حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏", "grades": "", "reference": "", "international_number": "1801", "narrator_chain": "Narrated Jabir:"}
{"hadithnumber": "1802", "arabic": "حَدَّثَنَا إِسْحَاقُ بْنُ مُوسَى الأَنْصَارِيُّ، حَدَّثَنَا مَعْنٌ، حَدَّثَنَا مَالِكٌ، عَنْ أَبِي النَّضْرِ، عَنْ عُبَيْدِ اللَّهِ بْنِ عُتْبَةَ، أَنَّهُ دَخَلَ عَلَى أَبِي طَلْحَةَ الأَنْصَارِيِّ يَعُودُهُ ‏.‏ قَالَ فَوَجَدْتُ عِنْدَهُ سَهْلَ بْنَ حُنَيْفٍ ‏.‏ قَالَ فَدَعَا أَبُو طَلْحَةَ إِنْسَانًا يَنْزِعُ نَمَطًا تَحْتَهُ فَقَالَ لَهُ سَهْلٌ لِمَ تَنْزِعُهُ فَقَالَ لأَنَّ فِيهِ تَصَاوِيرَ وَقَدْ قَالَ النَّبِيُّ صلى الله عليه وسلم مَا قَدْ عَلِمْتَ ‏.‏ قَالَ سَهْلٌ أَوَلَمْ يَقُلْ ‏ ‏ إِلاَّ مَا كَانَ رَقْمًا فِي ثَوْبٍ ‏\"\"‏ فَقَالَ بَلَى وَلَكِنَّهُ أَطْيَبُ لِنَفْسِي ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Narrated Abu An-Nadr:"}
{"hadithnumber": "1803", "arabic": "حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ، عَنْ أَيُّوبَ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنْ صَوَّرَ صُورَةً عَذَّبَهُ اللَّهُ حَتَّى يَنْفُخَ فِيهَا يَعْنِي الرُّوحَ وَلَيْسَ بِنَافِخٍ فِيهَا وَمَنِ اسْتَمَعَ إِلَى حَدِيثِ قَوْمٍ وَهُمْ يَفِرُّونَ بِهِ مِنْهُ صُبَّ فِي أُذُنِهِ الآنُكُ يَوْمَ الْقِيَامَةِ ‏\"\"‏ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ عَبْدِ اللَّهِ بْنِ مَسْعُودٍ وَأَبِي هُرَيْرَةَ وَأَبِي جُحَيْفَةَ وَعَائِشَةَ وَابْنِ عُمَرَ ‏.‏ قَالَ أَبُو عِيسَى حَدِيثُ ابْنِ عَبَّاسٍ حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Narrated Ibn 'Abbas:"}
{"hadithnumber": "1804", "arabic": "حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا أَبُو عَوَانَةَ، عَنْ عُمَرَ بْنِ أَبِي سَلَمَةَ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ غَيِّرُوا الشَّيْبَ وَلاَ تَشَبَّهُوا بِالْيَهُودِ ‏\"\"‏ ‏.‏ قَالَ وَفِي الْبَابِ عَنِ الزُّبَيْرِ وَابْنِ عَبَّاسٍ وَجَابِرٍ وَأَبِي ذَرٍّ وَأَنَسٍ وَأَبِي رِمْثَةَ وَالْجَهْدَمَةِ وَأَبِي الطُّفَيْلِ وَجَابِرِ بْنِ سَمُرَةَ وَأَبِي جُحَيْفَةَ وَابْنِ عُمَرَ ‏.‏ قَالَ أَبُو عِيسَى حَدِيثُ أَبِي هُرَيْرَةَ حَدِيثٌ حَسَنٌ صَحِيحٌ وَقَدْ رُوِيَ مِنْ غَيْرِ وَجْهٍ عَنْ أَبِي هُرَيْرَةَ عَنِ النَّبِيِّ صلى الله عليه وسلم ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Narrated Abu Hurairah:"}
{"hadithnumber": "1805", "arabic": "حَدَّثَنَا سُوَيْدُ بْنُ نَصْرٍ، أَخْبَرَنَا ابْنُ الْمُبَارَكِ، عَنِ الأَجْلَحِ، عَنْ عَبْدِ اللَّهِ بْنِ بُرَيْدَةَ، عَنْ أَبِي الأَسْوَدِ، عَنْ أَبِي ذَرٍّ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ إِنَّ أَحْسَنَ مَا غُيِّرَ بِهِ الشَّيْبُ الْحِنَّاءُ وَالْكَتَمُ ‏\"\"‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَأَبُو الأَسْوَدِ الدِّيلِيُّ اسْمُهُ ظَالِمُ بْنُ عَمْرِو بْنِ سُفْيَانَ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Narrated Abu Dharr:"}
{"hadithnumber": "1806", "arabic": "حَدَّثَنَا حُمَيْدُ بْنُ مَسْعَدَةَ، حَدَّثَنَا عَبْدُ الْوَهَّابِ الثَّقَفِيُّ، عَنْ حُمَيْدٍ، عَنْ أَنَسٍ، قَالَ كَانَ رَسُولُ اللَّهِ صلى الله عليه وسلم رَبْعَةً لَيْسَ بِالطَّوِيلِ وَلاَ بِالْقَصِيرِ حَسَنَ الْجِسْمِ أَسْمَرَ اللَّوْنِ وَكَانَ شَعْرُهُ لَيْسَ بِجَعْدٍ وَلاَ سَبْطٍ إِذَا مَشَى يَتَكَفَّأُ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ عَائِشَةَ وَالْبَرَاءِ وَأَبِي هُرَيْرَةَ وَابْنِ عَبَّاسٍ وَأَبِي سَعِيدٍ وَجَابِرٍ وَوَائِلِ بْنِ حُجْرٍ وَأُمِّ هَانِئٍ ‏.‏ قَالَ أَبُو عِيسَى حَدِيثُ أَنَسٍ حَدِيثٌ حَسَنٌ صَحِيحٌ غَرِيبٌ مِنْ هَذَا الْوَجْهِ مِنْ حَدِيثِ حُمَيْدٍ ‏.‏", "grades": "", "reference": "", "international_number": "1806", "narrator_chain": "Narrated Anas:"}
{"hadithnumber": "1807", "arabic": "حَدَّثَنَا هَنَّادٌ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ أَبِي الزِّنَادِ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، قَالَتْ كُنْتُ أَغْتَسِلُ أَنَا وَرَسُولُ اللَّهِ، صلى الله عليه وسلم مِنْ إِنَاءٍ وَاحِدٍ وَكَانَ لَهُ شَعْرٌ فَوْقَ الْجُمَّةِ وَدُونَ الْوَفْرَةِ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ غَرِيبٌ مِنْ هَذَا الْوَجْهِ ‏.‏ وَقَدْ رُوِيَ مِنْ غَيْرِ وَجْهٍ عَنْ عَائِشَةَ أَنَّهَا قَالَتْ كُنْتُ أَغْتَسِلُ أَنَا وَرَسُولُ اللَّهِ صلى الله عليه وسلم مِنْ إِنَاءٍ وَاحِدٍ ‏.‏ وَلَمْ يَذْكُرُوا فِيهِ هَذَا الْحَرْفَ وَكَانَ لَهُ شَعْرٌ فَوْقَ الْجُمَّةِ وَدُونَ الْوَفْرَةِ ‏.‏ وَعَبْدُ الرَّحْمَنِ بْنُ أَبِي الزِّنَادِ ثِقَةٌ كَانَ مَالِكُ بْنُ أَنَسٍ يُوَثِّقُهُ وَيَأْمُرُ بِالْكِتَابَةِ عَنْهُ ‏.‏", "grades": "", "reference": "", "international_number": "1807", "narrator_chain": "Narrated 'Aishah:"}
{"hadithnumber": "1808", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ خَشْرَمٍ، أَخْبَرَنَا عِيسَى بْنُ يُونُسَ، عَنْ هِشَامٍ، عَنِ الْحَسَنِ، عَنْ عَبْدِ اللَّهِ بْنِ مُغَفَّلٍ، قَالَ نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم عَنِ التَّرَجُّلِ إِلاَّ غِبًّا ‏.‏", "grades": "", "reference": "", "international_number": "1808", "narrator_chain": "Narrated 'Abdullah bin Mughaffal:"}
{"hadithnumber": "1809", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، عَنْ هِشَامٍ، عَنِ الْحَسَنِ، بِهَذَا الإِسْنَادِ نَحْوَهُ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ أَنَسٍ ‏.‏", "grades": "", "reference": "", "international_number": "1809", "narrator_chain": "Another chain with similar meaning.\\n\\n\\n[Abu 'Eisa said:"}
{"hadithnumber": "1810", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ حُمَيْدٍ، حَدَّثَنَا أَبُو دَاوُدَ، - هُوَ الطَّيَالِسِيُّ عَنْ عَبَّادِ بْنِ مَنْصُورٍ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ النَّبِيَّ صلى الله عليه وسلم قَالَ ‏\"‏ اكْتَحِلُوا بِالإِثْمِدِ فَإِنَّهُ يَجْلُو الْبَصَرَ وَيُنْبِتُ الشَّعْرَ ‏\"‏ ‏.‏ وَزَعَمَ أَنَّ النَّبِيَّ صلى الله عليه وسلم كَانَتْ لَهُ مُكْحُلَةٌ يَكْتَحِلُ بِهَا كُلَّ لَيْلَةٍ ثَلاَثَةً فِي هَذِهِ وَثَلاَثَةً فِي هَذِهِ ‏.‏ وَقَدْ رُوِيَ مِنْ غَيْرِ وَجْهٍ عَنِ النَّبِيِّ صلى الله عليه وسلم أَنَّهُ قَالَ ‏\"‏ عَلَيْكُمْ بِالإِثْمِدِ فَإِنَّهُ يَجْلُو الْبَصَرَ وَيُنْبِتُ الشَّعْرَ ‏\"‏ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ جَابِرٍ وَابْنِ عُمَرَ ‏.‏ قَالَ أَبُو عِيسَى حَدِيثُ ابْنِ عَبَّاسٍ حَدِيثٌ حَسَنٌ لاَ نَعْرِفُهُ عَلَى هَذَا اللَّفْظِ إِلاَّ مِنْ حَدِيثِ عَبَّادِ بْنِ مَنْصُورٍ ‏.‏", "grades": "", "reference": "", "international_number": "1810", "narrator_chain": "Narrated Ibn 'Abbas:"}
{"hadithnumber": "1811", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ حُجْرٍ، وَمُحَمَّدُ بْنُ يَحْيَى، قَالاَ حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، عَنْ عَبَّادِ بْنِ مَنْصُورٍ، نَحْوَهُ ‏.‏ وَقَدْ رُوِيَ مِنْ غَيْرِ وَجْهٍ عَنْ النَّبِيِّ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ قَالَ عَلَيْكُمْ بِالْإِثْمِدِ فَإِنَّهُ يَجْلُو الْبَصَرَ وَيُنْبِتُ الشَّعْرَ", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It has been reported through other routed that the Prophet (ﷺ) said:"}
{"hadithnumber": "1812", "arabic": "حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا يَعْقُوبُ بْنُ عَبْدِ الرَّحْمَنِ الإِسْكَنْدَرَانِيُّ، عَنْ سُهَيْلِ بْنِ أَبِي صَالِحٍ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ النَّبِيَّ صلى الله عليه وسلم نَهَى عَنْ لُبْسَتَيْنِ الصَّمَّاءِ وَأَنْ يَحْتَبِيَ الرَّجُلُ بِثَوْبِهِ لَيْسَ عَلَى فَرْجِهِ مِنْهُ شَيْءٌ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ عَلِيٍّ وَابْنِ عُمَرَ وَعَائِشَةَ وَأَبِي سَعِيدٍ وَجَابِرٍ وَأَبِي أُمَامَةَ ‏.‏ وَحَدِيثُ أَبِي هُرَيْرَةَ حَسَنٌ صَحِيحٌ غَرِيبٌ مِنْ هَذَا الْوَجْهِ وَقَدْ رُوِيَ هَذَا مِنْ غَيْرِ وَجْهٍ عَنْ أَبِي هُرَيْرَةَ عَنِ النَّبِيِّ صلى الله عليه وسلم ‏.‏", "grades": "", "reference": "", "international_number": "1812", "narrator_chain": "Narrated Abu Hurairah:"}
{"hadithnumber": "1813", "arabic": "حَدَّثَنَا سُوَيْدُ بْنُ نَصْرٍ، أَخْبَرَنَا عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ، عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ النَّبِيَّ صلى الله عليه وسلم قَالَ ‏ ‏ لَعَنَ اللَّهُ الْوَاصِلَةَ وَالْمُسْتَوْصِلَةَ وَالْوَاشِمَةَ وَالْمُسْتَوْشِمَةَ ‏\"\"‏ ‏.‏ قَالَ نَافِعٌ الْوَشْمُ فِي اللَّثَةِ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ عَائِشَةَ وَابْنِ مَسْعُودٍ وَأَسْمَاءَ بِنْتِ أَبِي بَكْرٍ وَابْنِ عَبَّاسٍ وَمَعْقِلِ بْنِ يَسَارٍ وَمُعَاوِيَةَ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Narrated Ibn 'Umar:"}
{"hadithnumber": "1814", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ حُجْرٍ، أَخْبَرَنَا عَلِيُّ بْنُ مُسْهِرٍ، حَدَّثَنَا أَبُو إِسْحَاقَ الشَّيْبَانِيُّ، عَنْ أَشْعَثَ بْنِ أَبِي الشَّعْثَاءِ، عَنْ مُعَاوِيَةَ بْنِ سُوَيْدِ بْنِ مُقَرِّنٍ، عَنِ الْبَرَاءِ بْنِ عَازِبٍ، قَالَ نَهَانَا رَسُولُ اللَّهِ صلى الله عليه وسلم عَنْ رُكُوبِ الْمَيَاثِرِ ‏.‏ قَالَ وَفِي الْحَدِيثِ قِصَّةٌ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ عَلِيٍّ وَمُعَاوِيَةَ ‏.‏ وَحَدِيثُ الْبَرَاءِ حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَقَدْ رَوَى شُعْبَةُ عَنْ أَشْعَثَ بْنِ أَبِي الشَّعْثَاءِ نَحْوَهُ وَفِي الْحَدِيثِ قِصَّةٌ ‏.‏", "grades": "", "reference": "", "international_number": "1814", "narrator_chain": "Narrated Al-Bara' bin 'Azib:"}
{"hadithnumber": "1815", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ حُجْرٍ، أَخْبَرَنَا عَلِيُّ بْنُ مُسْهِرٍ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، قَالَتْ إِنَّمَا كَانَ فِرَاشُ النَّبِيِّ صلى الله عليه وسلم الَّذِي يَنَامُ عَلَيْهِ أَدَمٌ حَشْوُهُ لِيفٌ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ حَفْصَةَ وَجَابِرٍ ‏.‏", "grades": "", "reference": "", "international_number": "1815", "narrator_chain": "Narrated 'Aishah:"}
{"hadithnumber": "1816", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ حُمَيْدٍ الرَّازِيُّ، حَدَّثَنَا أَبُو تُمَيْلَةَ، وَالْفَضْلُ بْنُ مُوسَى، وَزَيْدُ بْنُ حُبَابٍ، عَنْ عَبْدِ الْمُؤْمِنِ بْنِ خَالِدٍ، عَنْ عَبْدِ اللَّهِ بْنِ بُرَيْدَةَ، عَنْ أُمِّ سَلَمَةَ، قَالَتْ كَانَ أَحَبَّ الثِّيَابِ إِلَى النَّبِيِّ صلى الله عليه وسلم الْقَمِيصُ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ غَرِيبٌ إِنَّمَا نَعْرِفُهُ مِنْ حَدِيثِ عَبْدِ الْمُؤْمِنِ بْنِ خَالِدٍ تَفَرَّدَ بِهِ وَهُوَ مَرْوَزِيٌّ ‏.‏ وَرَوَى بَعْضُهُمْ هَذَا الْحَدِيثَ عَنْ أَبِي تُمَيْلَةَ عَنْ عَبْدِ الْمُؤْمِنِ بْنِ خَالِدٍ عَنْ عَبْدِ اللَّهِ بْنِ بُرَيْدَةَ عَنْ أُمِّهِ عَنْ أُمِّ سَلَمَةَ ‏.‏", "grades": "", "reference": "", "international_number": "1816", "narrator_chain": "Narrated Umm Salamah:"}
{"hadithnumber": "1817", "arabic": "حَدَّثَنَا زِيَادُ بْنُ أَيُّوبَ الْبَغْدَادِيُّ، حَدَّثَنَا أَبُو تُمَيْلَةَ، عَنْ عَبْدِ الْمُؤْمِنِ بْنِ خَالِدٍ، عَنْ عَبْدِ اللَّهِ بْنِ بُرَيْدَةَ، عَنْ أُمِّهِ، عَنْ أُمِّ سَلَمَةَ، قَالَتْ كَانَ أَحَبَّ الثِّيَابِ إِلَى النَّبِيِّ صلى الله عليه وسلم الْقَمِيصُ ‏.‏ قَالَ وَسَمِعْت مُحَمَّدَ بْنَ إِسْمَعِيلَ يَقُولُ حَدِيثُ عَبْدِ اللَّهِ بْنِ بُرَيْدَةَ عَنْ أُمِّهِ عَنْ أُمِّ سَلَمَةَ أَصَحُّ وَإِنَّمَا يُذْكَرُ فِيهِ أَبُو تُمَيْلَةَ عَنْ أُمِّهِ", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Narrated Umm Salamah:"}
{"hadithnumber": "1818", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ حُجْرٍ، أَخْبَرَنَا الْفَضْلُ بْنُ مُوسَى، عَنْ عَبْدِ الْمُؤْمِنِ بْنِ خَالِدٍ، عَنْ عَبْدِ اللَّهِ بْنِ بُرَيْدَةَ، عَنْ أُمِّ سَلَمَةَ، قَالَتْ كَانَ أَحَبَّ الثِّيَابِ إِلَى رَسُولِ اللَّهِ صلى الله عليه وسلم الْقَمِيصُ ‏.‏", "grades": "", "reference": "", "international_number": "1818", "narrator_chain": "Narrated Umm Salamah:"}
{"hadithnumber": "1819", "arabic": "حَدَّثَنَا عَبْدُ اللَّهِ بْنُ مُحَمَّدِ بْنِ الْحَجَّاجِ الصَّوَّافُ الْبَصْرِيُّ، حَدَّثَنَا مُعَاذُ بْنُ هِشَامٍ الدَّسْتَوَائِيُّ، حَدَّثَنِي أَبِي، عَنْ بُدَيْلِ بْنِ مَيْسَرَةَ الْعُقَيْلِيِّ، عَنْ شَهْرِ بْنِ حَوْشَبٍ، عَنْ أَسْمَاءَ بِنْتِ يَزِيدَ بْنِ السَّكَنِ الأَنْصَارِيَّةِ، قَالَتْ كَانَ كُمُّ يَدِ رَسُولِ اللَّهِ صلى الله عليه وسلم إِلَى الرُّسْغِ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ غَرِيبٌ ‏.‏", "grades": "", "reference": "", "international_number": "1819", "narrator_chain": "Narrated Asma' bint Yazid bin As-Sakan Al-Ansariyyah:"}
{"hadithnumber": "1820", "arabic": "حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ، حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ، حَدَّثَنَا شُعْبَةُ، عَنِ الأَعْمَشِ، عَنْ أَبِي صَالِحٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ كَانَ رَسُولُ اللَّهِ صلى الله عليه وسلم إِذَا لَبِسَ قَمِيصًا بَدَأَ بِمَيَامِنِهِ ‏.‏ قَالَ أَبُو عِيسَى وَرَوَى غَيْرُ وَاحِدٍ هَذَا الْحَدِيثَ عَنْ شُعْبَةَ بِهَذَا الإِسْنَادِ عَنْ أَبِي هُرَيْرَةَ مَوْقُوفًا وَلاَ نَعْلَمُ أَحَدًا رَفَعَهُ غَيْرَ عَبْدِ الصَّمَدِ بْنِ عَبْدِ الْوَارِثِ عَنْ شُعْبَةَ ‏.‏", "grades": "", "reference": "", "international_number": "1820", "narrator_chain": "Narrated Abu Hurairah:"}
{"hadithnumber": "1821", "arabic": "حَدَّثَنَا سُوَيْدُ بْنُ نَصْرٍ، أَخْبَرَنَا عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ، عَنْ سَعِيدٍ الْجُرَيْرِيِّ، عَنْ أَبِي نَضْرَةَ، عَنْ أَبِي سَعِيدٍ، قَالَ كَانَ رَسُولُ اللَّهِ صلى الله عليه وسلم إِذَا اسْتَجَدَّ ثَوْبًا سَمَّاهُ بِاسْمِهِ عِمَامَةً أَوْ قَمِيصًا أَوْ رِدَاءً ثُمَّ يَقُولُ ‏ ‏ اللَّهُمَّ لَكَ الْحَمْدُ أَنْتَ كَسَوْتَنِيهِ أَسْأَلُكَ خَيْرَهُ وَخَيْرَ مَا صُنِعَ لَهُ وَأَعُوذُ بِكَ مِنْ شَرِّهِ وَشَرِّ مَا صُنِعَ لَهُ ‏\"\"‏ ‏.‏ قَالَ أَبُو عِيسَى وَفِي الْبَابِ عَنْ عُمَرَ وَابْنِ عُمَرَ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Narrated Abu Sa'eed:"}
{"hadithnumber": "1822", "arabic": "حَدَّثَنَا هِشَامُ بْنُ يُونُسَ الْكُوفِيُّ، حَدَّثَنَا الْقَاسِمُ بْنُ مَالِكٍ الْمُزَنِيُّ، عَنِ الْجُرَيْرِيِّ، نَحْوَهُ ‏.‏ وَهَذَا حَدِيثٌ حَسَنٌ ‏.‏", "grades": "", "reference": "", "international_number": "1822", "narrator_chain": ""}
{"hadithnumber": "1823", "arabic": "حَدَّثَنَا يُوسُفُ بْنُ عِيسَى، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا يُونُسُ بْنُ أَبِي إِسْحَاقَ، عَنِ الشَّعْبِيِّ، عَنْ عُرْوَةَ بْنِ الْمُغِيرَةِ بْنِ شُعْبَةَ، عَنْ أَبِيهِ، أَنَّ النَّبِيَّ صلى الله عليه وسلم لَبِسَ جُبَّةً رُومِيَّةً ضَيِّقَةَ الْكُمَّيْنِ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏", "grades": "", "reference": "", "international_number": "1823", "narrator_chain": "Narrated 'Urwah bin Al-Mugirah bin Shu'bah:"}
{"hadithnumber": "1824", "arabic": "حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا ابْنُ أَبِي زَائِدَةَ، عَنِ الْحَسَنِ بْنِ عَيَّاشٍ، عَنْ أَبِي إِسْحَاقَ، هُوَ الشَّيْبَانِيُّ عَنِ الشَّعْبِيِّ، قَالَ قَالَ الْمُغِيرَةُ بْنُ شُعْبَةَ أَهْدَى دِحْيَةُ الْكَلْبِيُّ لِرَسُولِ اللَّهِ صلى الله عليه وسلم خُفَّيْنِ فَلَبِسَهُمَا ‏.‏ قَالَ أَبُو عِيسَى وَقَالَ إِسْرَائِيلُ عَنْ جَابِرٍ عَنْ عَامِرٍ وَجُبَّةً فَلَبِسَهُمَا حَتَّى تَخَرَّقَا لاَ يَدْرِي النَّبِيُّ صلى الله عليه وسلم أَذَكِيٌّ هُمَا أَمْ لاَ ‏.‏ وَهَذَا حَدِيثٌ حَسَنٌ غَرِيبٌ ‏.‏ أَبُو إِسْحَاقَ الَّذِي رَوَى هَذَا عَنِ الشَّعْبِيِّ هُوَ أَبُو إِسْحَاقَ الشَّيْبَانِيُّ وَاسْمُهُ سُلَيْمَانُ وَالْحَسَنُ بْنُ عَيَّاشٍ هُوَ أَخُو أَبِي بَكْرِ بْنِ عَيَّاشٍ ‏.‏", "grades": "", "reference": "", "international_number": "1824", "narrator_chain": "Narrated Ash-Sha'bi:"}
{"hadithnumber": "1825", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا عَلِيُّ بْنُ هَاشِمِ بْنِ الْبَرِيدِ، وَأَبُو سَعْدٍ الصَّغَانِيُّ عَنْ أَبِي الأَشْهَبِ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ طَرَفَةَ، عَنْ عَرْفَجَةَ بْنِ أَسْعَدَ، قَالَ أُصِيبَ أَنْفِي يَوْمَ الْكُلاَبِ فِي الْجَاهِلِيَّةِ فَاتَّخَذْتُ أَنْفًا مِنْ وَرِقٍ فَأَنْتَنَ عَلَىَّ فَأَمَرَنِي رَسُولُ اللَّهِ صلى الله عليه وسلم أَنْ أَتَّخِذَ أَنْفًا مِنْ ذَهَبٍ ‏.‏", "grades": "", "reference": "", "international_number": "1825", "narrator_chain": "Narrated 'Urfajah bin As'ad:"}
{"hadithnumber": "1826", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ حُجْرٍ، حَدَّثَنَا الرَّبِيعُ بْنُ بَدْرٍ، وَمُحَمَّدُ بْنُ يَزِيدَ الْوَاسِطِيُّ، عَنْ أَبِي الأَشْهَبِ، نَحْوَهُ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ غَرِيبٌ إِنَّمَا نَعْرِفُهُ مِنْ حَدِيثِ عَبْدِ الرَّحْمَنِ بْنِ طَرَفَةَ ‏.‏ وَقَدْ رَوَى سَلْمُ بْنُ زَرِيرٍ عَنْ عَبْدِ الرَّحْمَنِ بْنِ طَرَفَةَ نَحْوَ حَدِيثِ أَبِي الأَشْهَبِ ‏.‏ وَقَدْ رُوِيَ عَنْ غَيْرِ وَاحِدٍ مِنْ أَهْلِ الْعِلْمِ أَنَّهُمْ شَدُّوا أَسْنَانَهُمْ بِالذَّهَبِ وَفِي هَذَا الْحَدِيثِ حُجَّةٌ لَهُمْ ‏.‏ وَقَالَ عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ سَلْمُ بْنُ رَزِينٍ وَهُوَ وَهَمٌ وَأَبُو سَعْدٍ الصَّغَانِيُّ اسْمُهُ مُحَمَّدُ بْنُ مُيَسَّرٍ ‏.‏", "grades": "", "reference": "", "international_number": "1826", "narrator_chain": "Another chain with similar meaning.\\n\\n\\n[Abu 'Eisa said:"}
{"hadithnumber": "1827", "arabic": "حَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا ابْنُ الْمُبَارَكِ، وَمُحَمَّدُ بْنُ بِشْرٍ، وَعَبْدُ اللَّهِ بْنُ إِسْمَاعِيلَ بْنِ أَبِي خَالِدٍ، عَنْ سَعِيدِ بْنِ أَبِي عَرُوبَةَ، عَنْ قَتَادَةَ، عَنْ أَبِي الْمَلِيحِ، عَنْ أَبِيهِ، أَنَّ النَّبِيَّ صلى الله عليه وسلم نَهَى عَنْ جُلُودِ السِّبَاعِ أَنْ تُفْتَرَشَ ‏.‏", "grades": "", "reference": "", "international_number": "1827", "narrator_chain": "Narrated Abu Al-Malih:"}
{"hadithnumber": "1828", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، حَدَّثَنَا سَعِيدٌ، عَنْ قَتَادَةَ، عَنْ أَبِي الْمَلِيحِ، عَنْ أَبِيهِ، أَنَّ النَّبِيَّ صلى الله عليه وسلم نَهَى عَنْ جُلُودِ السِّبَاعِ ‏.‏", "grades": "", "reference": "", "international_number": "1828", "narrator_chain": "Another chain from Abu Al-Malih from his father:"}
{"hadithnumber": "1829", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُعَاذُ بْنُ هِشَامٍ، حَدَّثَنِي أَبِي، عَنْ قَتَادَةَ، عَنْ أَبِي الْمَلِيحِ، أَنَّهُ كَرِهَ جُلُودَ السِّبَاعِ ‏.‏ قَالَ أَبُو عِيسَى وَلاَ نَعْلَمُ أَحَدًا قَالَ عَنْ أَبِي الْمَلِيحِ، عَنْ أَبِيهِ، غَيْرَ سَعِيدِ بْنِ أَبِي عَرُوبَةَ ‏.‏", "grades": "", "reference": "", "international_number": "1829", "narrator_chain": "Another chain from Abu Al-Malik, that he (ﷺ) disliked predator skins. Abu 'Eisa said:"}
{"hadithnumber": "1830", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، حَدَّثَنَا شُعْبَةُ، عَنْ يَزِيدَ الرِّشْكِ، عَنْ أَبِي الْمَلِيحِ، عَنِ النَّبِيِّ صلى الله عليه وسلم أَنَّهُ نَهَى عَنْ جُلُودِ السِّبَاعِ ‏.‏ وَهَذَا أَصَحُّ ‏.‏", "grades": "", "reference": "", "international_number": "1830", "narrator_chain": "Narrated Abu Al-Malih:"}
{"hadithnumber": "1831", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا أَبُو دَاوُدَ، حَدَّثَنَا هَمَّامٌ، عَنْ قَتَادَةَ، قَالَ قُلْتُ لأَنَسِ بْنِ مَالِكٍ كَيْفَ كَانَ نَعْلُ رَسُولِ اللَّهِ صلى الله عليه وسلم قَالَ لَهُمَا قِبَالاَنِ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏", "grades": "", "reference": "", "international_number": "1831", "narrator_chain": "Narrated Qatadah:"}
{"hadithnumber": "1832", "arabic": "حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ، أَخْبَرَنَا حِبَّانُ بْنُ هِلاَلٍ، حَدَّثَنَا هَمَّامٌ، حَدَّثَنَا قَتَادَةُ، عَنْ أَنَسٍ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم كَانَ نَعْلاَهُ لَهُمَا قِبَالاَنِ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ قَالَ وَفِي الْبَابِ عَنِ ابْنِ عَبَّاسٍ وَأَبِي هُرَيْرَةَ ‏.‏", "grades": "", "reference": "", "international_number": "1832", "narrator_chain": "Narrated Qatadah:"}
{"hadithnumber": "1833", "arabic": "حَدَّثَنَا قُتَيْبَةُ، عَنْ مَالِكٍ، ح وَحَدَّثَنَا الأَنْصَارِيُّ، حَدَّثَنَا مَعْنٌ، حَدَّثَنَا مَالِكٌ، عَنْ أَبِي الزِّنَادِ، عَنِ الأَعْرَجِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ لاَ يَمْشِي أَحَدُكُمْ فِي نَعْلٍ وَاحِدَةٍ لِيُنْعِلْهُمَا جَمِيعًا أَوْ لِيُحْفِهِمَا جَمِيعًا ‏\"\"‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ جَابِرٍ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Narrated Abu Hurairah:"}
{"hadithnumber": "1834", "arabic": "حَدَّثَنَا أَزْهَرُ بْنُ مَرْوَانَ الْبَصْرِيُّ، حَدَّثَنَا الْحَارِثُ بْنُ نَبْهَانَ، عَنْ مَعْمَرٍ، عَنْ عَمَّارِ بْنِ أَبِي عَمَّارٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم أَنْ يَنْتَعِلَ الرَّجُلُ وَهُوَ قَائِمٌ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ غَرِيبٌ ‏.‏ وَرَوَى عُبَيْدُ اللَّهِ بْنُ عَمْرٍو الرَّقِّيُّ هَذَا الْحَدِيثَ عَنْ مَعْمَرٍ عَنْ قَتَادَةَ عَنْ أَنَسٍ وَكِلاَ الْحَدِيثَيْنِ لاَ يَصِحُّ عِنْدَ أَهْلِ الْحَدِيثِ ‏.‏ وَالْحَارِثُ بْنُ نَبْهَانَ لَيْسَ عِنْدَهُمْ بِالْحَافِظِ وَلاَ نَعْرِفُ لِحَدِيثِ قَتَادَةَ عَنْ أَنَسٍ أَصْلاً ‏.‏", "grades": "", "reference": "", "international_number": "1834", "narrator_chain": "Narrated Abu Hurairah:"}
{"hadithnumber": "1835", "arabic": "حَدَّثَنَا أَبُو جَعْفَرٍ السِّمْنَانِيُّ، حَدَّثَنَا سُلَيْمَانُ بْنُ عُبَيْدِ اللَّهِ الرَّقِّيُّ، حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ عَمْرٍو الرَّقِّيُّ، عَنْ مَعْمَرٍ، عَنْ قَتَادَةَ، عَنْ أَنَسٍ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم نَهَى أَنْ يَنْتَعِلَ الرَّجُلُ وَهُوَ قَائِمٌ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ غَرِيبٌ ‏.‏ وَقَالَ مُحَمَّدُ بْنُ إِسْمَاعِيلَ وَلاَ يَصِحُّ هَذَا الْحَدِيثُ وَلاَ حَدِيثُ مَعْمَرٍ عَنْ عَمَّارِ بْنِ أَبِي عَمَّارٍ عَنْ أَبِي هُرَيْرَةَ ‏.‏", "grades": "", "reference": "", "international_number": "1835", "narrator_chain": "Narrated Anas:"}
{"hadithnumber": "1836", "arabic": "حَدَّثَنَا الْقَاسِمُ بْنُ دِينَارٍ، حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ السَّلُولِيُّ، كُوفِيٌّ حَدَّثَنَا هُرَيْمُ بْنُ سُفْيَانَ الْبَجَلِيُّ الْكُوفِيُّ، عَنْ لَيْثٍ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، قَالَتْ رُبَّمَا مَشَى النَّبِيُّ صلى الله عليه وسلم فِي نَعْلٍ وَاحِدَةٍ ‏.‏", "grades": "", "reference": "", "international_number": "1836", "narrator_chain": "Narrated 'Aishah:"}
{"hadithnumber": "1837", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، أَنَّهَا مَشَتْ بِنَعْلٍ وَاحِدَةٍ ‏.‏ وَهَذَا أَصَحُّ ‏.‏ قَالَ أَبُو عِيسَى وَهَكَذَا رَوَاهُ سُفْيَانُ الثَّوْرِيُّ وَغَيْرُ وَاحِدٍ عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ مَوْقُوفًا وَهَذَا أَصَحُّ ‏.‏", "grades": "", "reference": "", "international_number": "1837", "narrator_chain": "Narrated 'Abdur-Rahman bin Al-Qasim:"}
{"hadithnumber": "1838", "arabic": "حَدَّثَنَا الأَنْصَارِيُّ، حَدَّثَنَا مَعْنٌ، حَدَّثَنَا مَالِكٌ، ح وَحَدَّثَنَا قُتَيْبَةُ، عَنْ مَالِكٍ، عَنْ أَبِي الزِّنَادِ، عَنِ الأَعْرَجِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ إِذَا انْتَعَلَ أَحَدُكُمْ فَلْيَبْدَأْ بِالْيَمِينِ وَإِذَا نَزَعَ فَلْيَبْدَأْ بِالشِّمَالِ فَلْتَكُنِ الْيُمْنَى أَوَّلَهُمَا تُنْعَلُ وَآخِرَهُمَا تُنْزَعُ ‏\"\"‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Narrated Abu Hurairah:"}
{"hadithnumber": "1839", "arabic": "حَدَّثَنَا يَحْيَى بْنُ مُوسَى، حَدَّثَنَا سَعِيدُ بْنُ مُحَمَّدٍ الْوَرَّاقُ، وَأَبُو يَحْيَى الْحِمَّانِيُّ قَالاَ حَدَّثَنَا صَالِحُ بْنُ حَسَّانَ، عَنْ عُرْوَةَ، عَنْ عَائِشَةَ، قَالَتْ قَالَ لِي رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ إِذَا أَرَدْتِ اللُّحُوقَ بِي فَلْيَكْفِيكِ مِنَ الدُّنْيَا كَزَادِ الرَّاكِبِ وَإِيَّاكِ وَمُجَالَسَةَ الأَغْنِيَاءِ وَلاَ تَسْتَخْلِقِي ثَوْبًا حَتَّى تُرَقِّعِيهِ ‏\"‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ غَرِيبٌ لاَ نَعْرِفُهُ إِلاَّ مِنْ حَدِيثِ صَالِحِ بْنِ حَسَّانَ ‏.‏ قَالَ وَسَمِعْتُ مُحَمَّدًا يَقُولُ صَالِحُ بْنُ حَسَّانَ مُنْكَرُ الْحَدِيثِ وَصَالِحُ بْنُ أَبِي حَسَّانَ الَّذِي رَوَى عَنْهُ ابْنُ أَبِي ذِئْبٍ ثِقَةٌ ‏.‏ قَالَ أَبُو عِيسَى وَمَعْنَى قَوْلِهِ ‏\"‏ وَإِيَّاكِ وَمُجَالَسَةَ الأَغْنِيَاءِ ‏\"‏ ‏.‏ هُوَ نَحْوُ مَا رُوِيَ عَنْ أَبِي هُرَيْرَةَ عَنِ النَّبِيِّ صلى الله عليه وسلم أَنَّهُ قَالَ ‏\"‏ مَنْ رَأَى مَنْ فُضِّلَ عَلَيْهِ فِي الْخَلْقِ وَالرِّزْقِ فَلْيَنْظُرْ إِلَى مَنْ هُوَ أَسْفَلُ مِنْهُ مِمَّنْ فُضِّلَ هُوَ عَلَيْهِ فَإِنَّهُ أَجْدَرُ أَنْ لاَ يَزْدَرِيَ نِعْمَةَ اللَّهِ عَلَيْهِ ‏\"‏ ‏.‏ وَيُرْوَى عَنْ عَوْنِ بْنِ عَبْدِ اللَّهِ بْنِ عُتْبَةَ قَالَ صَحِبْتُ الأَغْنِيَاءَ فَلَمْ أَرَ أَحَدًا أَكْثَرَ هَمًّا مِنِّي أَرَى دَابَّةً خَيْرًا مِنْ دَابَّتِي وَثَوْبًا خَيْرًا مِنْ ثَوْبِي وَصَحِبْتُ الْفُقَرَاءَ فَاسْتَرَحْتُ ‏.‏", "grades": "", "reference": "", "international_number": "1839", "narrator_chain": "Narrated 'Aishah:"}
{"hadithnumber": "1840", "arabic": "حَدَّثَنِي ابْنُ أَبِي عُمَرَ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ ابْنِ أَبِي نَجِيحٍ، عَنْ مُجَاهِدٍ، عَنْ أُمِّ هَانِئٍ، قَالَتْ قَدِمَ رَسُولُ اللَّهِ صلى الله عليه وسلم مَكَّةَ وَلَهُ أَرْبَعُ غَدَائِرَ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ غَرِيبٌ ‏.‏ قَالَ مُحَمَّدٌ لاَ أَعْرِفُ لِمُجَاهِدٍ سَمَاعًا مِنْ أُمِّ هَانِئٍ ‏.‏", "grades": "", "reference": "", "international_number": "1840", "narrator_chain": "Narrated Umm Hani:"}
{"hadithnumber": "1841", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، حَدَّثَنَا إِبْرَاهِيمُ بْنُ نَافِعٍ الْمَكِّيُّ، عَنِ ابْنِ أَبِي نَجِيحٍ، عَنْ مُجَاهِدٍ، عَنْ أُمِّ هَانِئٍ، قَالَتْ قَدِمَ رَسُولُ اللَّهِ صلى الله عليه وسلم مَكَّةَ وَلَهُ أَرْبَعُ ضَفَائِرَ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ غَرِيبٌ ‏.‏ وَعَبْدُ اللَّهِ بْنُ أَبِي نَجِيحٍ مَكِّيٌّ أَبُو نَجِيحٍ اسْمُهُ يَسَارٌ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ غَرِيبٌ وَعَبْدُ اللَّهِ بْنُ أَبِي نَجِيحٍ مَكِّيٌّ", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Another chain from Umm Hani' who said:"}
{"hadithnumber": "1842", "arabic": "حَدَّثَنَا حُمَيْدُ بْنُ مَسْعَدَةَ، حَدَّثَنَا مُحَمَّدُ بْنُ حُمْرَانَ، عَنْ أَبِي سَعِيدٍ، وَهُوَ عَبْدُ اللَّهِ بْنُ بُسْرٍ قَالَ سَمِعْتُ أَبَا كَبْشَةَ الأَنْمَارِيَّ، يَقُولُ كَانَتْ كِمَامُ أَصْحَابِ رَسُولِ اللَّهِ صلى الله عليه وسلم بُطْحًا ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ مُنْكَرٌ ‏.‏ وَعَبْدُ اللَّهِ بْنُ بُسْرٍ بَصْرِيٌّ هُوَ ضَعِيفٌ عِنْدَ أَهْلِ الْحَدِيثِ ضَعَّفَهُ يَحْيَى بْنُ سَعِيدٍ وَغَيْرُهُ ‏.‏ وَبُطْحٌ يَعْنِي وَاسِعَةٌ ‏.‏", "grades": "", "reference": "", "international_number": "1842", "narrator_chain": "Narrated Abu Sa'eed - who is 'Abdullah bin Busr:"}
{"hadithnumber": "1843", "arabic": "حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا أَبُو الأَحْوَصِ، عَنْ أَبِي إِسْحَاقَ، عَنْ مُسْلِمِ بْنِ نَذِيرٍ، عَنْ حُذَيْفَةَ، قَالَ أَخَذَ رَسُولُ اللَّهِ صلى الله عليه وسلم بِعَضَلَةِ سَاقِي أَوْ سَاقِهِ فَقَالَ ‏ ‏ هَذَا مَوْضِعُ الإِزَارِ فَإِنْ أَبَيْتَ فَأَسْفَلُ فَإِنْ أَبَيْتَ فَلاَ حَقَّ لِلإِزَارِ فِي الْكَعْبَيْنِ ‏\"\"‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ رَوَاهُ الثَّوْرِيُّ وَشُعْبَةُ عَنْ أَبِي إِسْحَاقَ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Narrated Hudhaifa:"}
{"hadithnumber": "1844", "arabic": "حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا مُحَمَّدُ بْنُ رَبِيعَةَ، عَنْ أَبِي الْحَسَنِ الْعَسْقَلاَنِيِّ، عَنْ أَبِي جَعْفَرِ بْنِ مُحَمَّدِ بْنِ رُكَانَةَ، عَنْ أَبِيهِ، أَنَّ رُكَانَةَ، صَارَعَ النَّبِيَّ صلى الله عليه وسلم فَصَرَعَهُ النَّبِيُّ صلى الله عليه وسلم قَالَ رُكَانَةُ سَمِعْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم يَقُولُ ‏ ‏ إِنَّ فَرْقَ مَا بَيْنَنَا وَبَيْنَ الْمُشْرِكِينَ الْعَمَائِمُ عَلَى الْقَلاَنِسِ ‏\"\"‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ غَرِيبٌ وَإِسْنَادُهُ لَيْسَ بِالْقَائِمِ ‏.‏ وَلاَ نَعْرِفُ أَبَا الْحَسَنِ الْعَسْقَلاَنِيَّ وَلاَ ابْنَ رُكَانَةَ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Narrated Abu Ja'far bin Muhammad bin Rukanah:"}
{"hadithnumber": "1845", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ حُمَيْدٍ، حَدَّثَنَا زَيْدُ بْنُ حُبَابٍ، وَأَبُو تُمَيْلَةَ يَحْيَى بْنُ وَاضِحٍ عَنْ عَبْدِ اللَّهِ بْنِ مُسْلِمٍ، عَنْ عَبْدِ اللَّهِ بْنِ بُرَيْدَةَ، عَنْ أَبِيهِ، قَالَ جَاءَ رَجُلٌ إِلَى النَّبِيِّ صلى الله عليه وسلم وَعَلَيْهِ خَاتَمٌ مِنْ حَدِيدٍ فَقَالَ ‏\"‏ مَا لِي أَرَى عَلَيْكَ حِلْيَةَ أَهْلِ النَّارِ ‏\"‏ ‏.‏ ثُمَّ جَاءَهُ وَعَلَيْهِ خَاتَمٌ مِنْ صُفْرٍ فَقَالَ ‏\"‏ مَا لِي أَجِدُ مِنْكَ رِيحَ الأَصْنَامِ ‏\"‏ ‏.‏ ثُمَّ أَتَاهُ وَعَلَيْهِ خَاتَمٌ مِنْ ذَهَبٍ فَقَالَ ‏\"‏ مَا لِي أَرَى عَلَيْكَ حِلْيَةَ أَهْلِ الْجَنَّةِ ‏\"‏ ‏.‏ قَالَ مِنْ أَىِّ شَيْءٍ أَتَّخِذُهُ قَالَ ‏\"‏ مِنْ وَرِقٍ وَلاَ تُتِمَّهُ مِثْقَالاً ‏\"‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ غَرِيبٌ ‏.‏ وَفِي الْبَابِ عَنْ عَبْدِ اللَّهِ بْنِ عَمْرٍو ‏.‏ وَعَبْدُ اللَّهِ بْنُ مُسْلِمٍ يُكْنَى أَبَا طَيْبَةَ وَهُوَ مَرْوَزِيٌّ ‏.‏", "grades": "", "reference": "", "international_number": "1845", "narrator_chain": "Narrated 'Abdullah bin Buraidah:"}
{"hadithnumber": "1846", "arabic": "حَدَّثَنَا ابْنُ أَبِي عُمَرَ، حَدَّثَنَا سُفْيَانُ، عَنْ عَاصِمِ بْنِ كُلَيْبٍ، عَنِ ابْنِ أَبِي مُوسَى، قَالَ سَمِعْتُ عَلِيًّا، يَقُولُ نَهَانِي رَسُولُ اللَّهِ صلى الله عليه وسلم عَنِ الْقَسِّيِّ وَالْمِيثَرَةِ الْحَمْرَاءِ وَأَنْ أَلْبَسَ خَاتَمِي فِي هَذِهِ وَفِي هَذِهِ ‏.‏ وَأَشَارَ إِلَى السَّبَّابَةِ وَالْوُسْطَى ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَابْنُ أَبِي مُوسَى هُوَ أَبُو بُرْدَةَ بْنُ أَبِي مُوسَى وَاسْمُهُ عَامِرُ بْنُ عَبْدِ اللَّهِ بْنِ قَيْسٍ ‏.‏", "grades": "", "reference": "", "international_number": "1846", "narrator_chain": "Narrated Ibn Abi Musa:"}
{"hadithnumber": "1847", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُعَاذُ بْنُ هِشَامٍ، حَدَّثَنِي أَبِي، عَنْ قَتَادَةَ، عَنْ أَنَسٍ، قَالَ كَانَ أَحَبَّ الثِّيَابِ إِلَى رَسُولِ اللَّهِ صلى الله عليه وسلم يَلْبَسُهَا الْحِبَرَةُ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ غَرِيبٌ ‏.‏", "grades": "", "reference": "", "international_number": "1847", "narrator_chain": "Narrated Anas:"}
