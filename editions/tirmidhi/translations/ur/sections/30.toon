{"hadithnumber": "2116", "text": "سعد بن ابی وقاص رضی الله عنہ کہتے ہیں کہ  فتح مکہ کے سال میں ایسا بیمار پڑا کہ موت کے قریب پہنچ گیا،"}
{"hadithnumber": "2117", "text": "ابوہریرہ رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”مرد اور عورت ساٹھ سال"}
{"hadithnumber": "2118", "text": "عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”کسی مسلمان کو یہ"}
{"hadithnumber": "2119", "text": "طلحہ بن مصرف کہتے ہیں کہ  میں نے عبداللہ بن ابی اوفی رضی الله عنہ سے پوچھا: کیا رسول اللہ صلی اللہ ع"}
{"hadithnumber": "2120", "text": "ابوامامہ باہلی رضی الله عنہ کہتے ہیں کہ  میں نے حجۃ الوداع کے سال خطبہ میں رسول اللہ صلی اللہ علیہ و"}
{"hadithnumber": "2121", "text": "عمرو بن خارجہ رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم اپنی اونٹنی پر خطبہ دے رہے تھ"}
{"hadithnumber": "2122", "text": "علی رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے وصیت  ( کے نفاذ )  سے پہلے قرض کی اد"}
{"hadithnumber": "2123", "text": "ابوحبیبہ طائی کہتے ہیں کہ  میرے بھائی نے اپنے مال کے ایک حصہ کی میرے لیے وصیت کی، میں نے ابو الدرداء"}
{"hadithnumber": "2124", "text": "ام المؤمنین عائشہ رضی الله عنہا سے روایت ہے کہ  بریرہ اپنے زر کتابت کے بارے میں ان سے تعاون مانگنے ا"}
