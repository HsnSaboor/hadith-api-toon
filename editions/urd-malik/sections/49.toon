hadiths[40]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
1671,"حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ نے فرمایا :’’ ( اصل ) مسکین یہ چکر لگان",,,1671,,
1672,ابن بجید انصاری حارثی رحمہ اللہ اپنی دادی جان ( حضرت اُم بجید رضی اللہ عنہا ) سے روایت کرتے ہیں کہ ب,,,1672,,
1673,"حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ، کہتے ہیں کہ رسول اللہ ﷺ نے فرمایا :’’ مسلمان ایک آنت میں کھ",,,1673,,
1674,حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ بے شک رسول اللہ ﷺ کے پاس ایک کافر شخص مہمان بنا تو رسول ال,,,1674,,
1675,"سیدہ اُم سلمہ رضی اللہ عنہا زوجہ پیغمبر ﷺ سے روایت ہے کہ بے شک رسول اللہ ﷺ نے فرمایا :’’ وہ شخص جو چ",,,1675,,
1676,ابومثنی جہنی رحمہ اللہ سے روایت ہے ، کہتے ہیں کہ میں مروان بن حکم کے پاس تھا ، ان کے پاس حضرت ابوسعی,,,1676,,
1677,امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ بلاشبہ حضرت عمر بن خطاب رضی اللہ عنہ ، حضرت علی بن ابی طالب ا,,,1677,,
1678,ابن شہاب رحمہ اللہ سے روایت ہے کہ بلاشبہ سیدہ عائشہ اُم المؤمنین اور حضرت سعد بن ابی وقاص رضی اللہ ,,,1678,,
1679,ابو جعفر قاری رحمہ اللہ سے روایت ہے ، کہتے ہیں کہ میں نے حضرت عبداللہ بن عمر رضی اللہ عنہ کو دیکھا ،,,,1679,,
1680,عامر بن عبداللہ بن زبیر رحمہ اللہ اپنے والد ( حضرت عبداللہ بن زبیر رضی اللہ عنہ ) سے روایت کرتے ہیں ,,,1680,,
1681,حضرت انس بن مالک رضی اللہ عنہ سے روایت ہے کہ بے شک رسول اللہ ﷺ کے پاس کچھ دودھ لایا گیا جس میں کنویں,,,1681,,
1682,حضرت سہل بن سعد انصاری رضی اللہ عنہ سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ کے پاس پینے کی چیز لائی گئی ( ,,,1682,,
1683,"حضرت انس بن مالک رضی اللہ عنہ سے روایت ہے ، کہتے ہیں کہ : ( میرے سوتیلے والد ) حضرت ابوطلحہ رضی اللہ",,,1683,,
1684,"حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ بے شک رسول اللہ ﷺ نے فرمایا :’’ دو آدمیوں کا کھانا تین کو ",,,1684,,
1685,"حضرت جابر بن عبداللہ رضی اللہ عنہ سے روایت ہے کہ بے شک رسول اللہ ﷺ نے فرمایا :’’ دروازے بند رکھو ، م",,,1685,,
1686,"حضرت ابوشُریح کعبی رضی اللہ عنہ سے روایت ہے کہ بے شک رسول اللہ ﷺ نے فرمایا :’’ جو شخص اللہ اور آخرت ",,,1686,,
1687,"حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ نے فرمایا :’’ ایک دفعہ ایک آدمی کسی راس",,,1687,,
1688,"حضرت جابر بن عبداللہ رضی اللہ عنہ سے روایت ہے ، کہتے ہیں : رسول اللہ ﷺ نے ایک لشکر ساحلِ سمندر کی طر",,,1688,,
1689,عمرو بن سعد بن معاذ رضی اللہ عنہ اپنی دادی ( اُمّ سعد حواء بنت یزید بن سکن رضی اللہ عنہا ) سے روایت ,,,1689,,
1690,"عبداللہ بن ابی بکر رضی اللہ عنہ سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا :’’ اللہ تعالیٰ یہودیوں پر لعنت",,,1690,,
1691,"امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ بے شک حضرت عیسیٰ علیہ السلام فرمایا کرتے تھے :’’ اے بنی اسرائ",,,1691,,
1692,امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ بے شک رسول اللہ ﷺ مسجد میں داخل ہوئے تو اس میں حضرت ابوبکر صد,,,1692,,
1693,یحیی بن سعید رضی اللہ عنہ سے روایت ہے کہ بلاشبہ حضرت عمر بن خطاب رضی اللہ عنہ گھی کے ساتھ روٹی کھا ر,,,1693,,
1694,"حضرت انس بن مالک رضی اللہ عنہ سے روایت ہے ، کہتے ہیں : میں نے حضرت عمر بن خطاب رضی اللہ عنہ کو دیکھا",,,1694,,
1695,"حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے ، کہتے ہیں : حضرت عمر بن خطاب رضی اللہ عنہ سے ٹڈی دل ",,,1695,,
1696,"حُمَید بن مالک بن خُثَیم رحمہ اللہ سے روایت ہے ، کہتے ہیں : میں حضرت ابوہریرہ رضی اللہ عنہ کے ہمراہ ",,,1696,,
1697,"ابونعیم وہب بن کیسان رضی اللہ عنہ سے روایت ہے ، کہتے ہیں : رسول اللہ ﷺ کے پاس کھانا لایا گیا ، اس حا",,,1697,,
1698,قاسم بن محمد رحمہ اللہ سے روایت ہے ، کہتے ہیں کہ ایک آدمی حضرت عبداللہ بن عباس رضی اللہ عنہما کے پاس,,,1698,,
1699,ہشام بن عروہ رحمہ اللہ اپنے والد ( عروہ بن زبیر رضی اللہ عنہ ) سے روایت کرتے ہیں کہ ان کے پاس کبھی ب,,,1699,,
1700,"یحیی بن سعید رحمہ اللہ سے روایت ہے کہ بے شک حضرت عمر بن خطاب رضی اللہ عنہ نے فرمایا : اپنے آپ کو گوش",,,1700,,
1701,یحیی بن سعید رحمہ اللہ سے روایت ہے کہ بے شک حضرت عمر بن خطاب رضی اللہ عنہ نے حضرت جابر بن عبداللہ رض,,,1701,,
1702,حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ سونے کی انگوٹھی پہنا کرتے تھے ۔,,,1702,,
1703,"صدقہ بن یسار رحمہ اللہ سے روایت ہے ، کہتے ہیں : میں نے سعید بن مسیب سے انگوٹھی پہننے کے متعلق سوال ک",,,1703,,
1704,عباد بن تمیم رحمہ اللہ سے روایت ہے کہ حضرت ابو بشیر انصاری رضی اللہ عنہ نے انھیں خبر دی کہ وہ رسول ا,,,1704,,
1705,محمد بن ابی امامہ بن سہل بن حُنَیف رحمہ اللہ سے روایت ہے ، انھوں نے اپنے والد ابوامامہ رحمہ اللہ ( ا,,,1705,,
1706,ابوامامہ بن سہل بن حنیف رحمہ اللہ سے روایت ہے ، کہتے ہیں کہ حضرت عامر بن ربیعہ رضی اللہ عنہ نے ( میر,,,1706,,
1707,"حمید بن قیس مکی رحمہ اللہ سے روایت ہے ، کہتے ہیں : رسول اللہ ﷺ کے پاس حضرت جعفر بن ابی طالب رضی اللہ",,,1707,,
1708,عروہ بن زبیر رضی اللہ عنہ سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ سیدہ ام سلمہ رضی اللہ عنہا زوجہ پیغمبر ﷺ,,,1708,,
1709,"عطاء بن یسار رحمہ اللہ سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ نے فرمایا :’’ جب آدمی بیمار ہوتا ہے تو اللہ",,,1709,,
1710,یزید بن خُصَیفہ رحمہ اللہ عروہ بن زبیر رحمہ اللہ سے روایت کرتے ہیں کہ انھوں نے سیدہ عائشہ رضی اللہ ع,,,1710,,
