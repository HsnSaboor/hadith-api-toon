metadata:
  section_id: 14
  section_name: رسول اللہ صلی اللہ علیہ وسلم کا دائیں ہاتھ میں انگوٹھی پہننا
  hadith_first: 93
  hadith_last: 101

hadiths[8]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
93,"“Allah’s Messenger (Allah bless him and give him peace) chose a signet ring of silver, so it was in his possession. Then it was in the possession of Abu Bakr and the possession of 'Umar. Then it was in the possession of 'Uthman, until it fell into the well of Aris. Its engraved inscription was: ‘Muhammad is the Messenger of Allah.”",,,93,"Ibn 'Umar said:",رسول اللہ صلی اللہ علیہ وسلم کا دائیں ہاتھ میں انگوٹھی پہننا
94,“The Prophet (Allah bless him and give him peace) used to wear his signet ring on his right hand.”,,,94,"'Ali ibn Abi Talib said (may Allah be well pleased with him):",رسول اللہ صلی اللہ علیہ وسلم کا دائیں ہاتھ میں انگوٹھی پہننا
96,"""I saw Ibn Abi Rafi' wearing a signet ring on his right hand, so I asked him about that and he said: 'I saw 'Abdu llah ibn Ja'far wearing a signet ring on his right hand', and 'Abdullah ibn Ja'far said:\n'Allah’s Messenger (Allah bless him and give him peace) used to wear a signet ring on his right hand'.”",,,96,"Hammad ibn Salama said:",رسول اللہ صلی اللہ علیہ وسلم کا دائیں ہاتھ میں انگوٹھی پہننا
97,“He (Allah bless him and give him peace) used to wear a signet ring on his right hand.”,,,97,"Abdullah ibn Ja'far said:",رسول اللہ صلی اللہ علیہ وسلم کا دائیں ہاتھ میں انگوٹھی پہننا
98,"""The Prophet (Allah bless him and give him peace) used to wear a signet ring on his right hand.”",,,98,"Jabir ibn ‘Abdi’llah said:",رسول اللہ صلی اللہ علیہ وسلم کا دائیں ہاتھ میں انگوٹھی پہننا
99,"“Ibn 'Abbas used to wear a signet ring on his right hand, without adornment, and he said: 'Allah’s Messenger (Allah bless him and give him peace) used to wear a signet ring on his right hand'.”",,,99,"‘As-Salt ibn 'Abdi’llah said:",رسول اللہ صلی اللہ علیہ وسلم کا دائیں ہاتھ میں انگوٹھی پہننا
100,"""The Prophet (Allah bless him and give him peace) chose a signet ring of silver, and put its stone in the part close to the\npalm of his hand. On it he engraved: “Muhammad is the Messenger of Allah,” and he forbade anyone [else] to engrave on it. It is the one that fell from Mu'aiqib into the well of Aris.”",,,100,"Ibn 'Umar said:",رسول اللہ صلی اللہ علیہ وسلم کا دائیں ہاتھ میں انگوٹھی پہننا
101,"""Al-Hasan and al-Husain used to wear signet rings on their left hands.""",,,101,"Ja'far ibn Muhammad reports that his father said:",رسول اللہ صلی اللہ علیہ وسلم کا دائیں ہاتھ میں انگوٹھی پہننا
