hadiths[5]{hadithnumber,text}:
20946,"أؼزۏضۄأثىحأًہثتىأڬۄحۏأۄۏڽأڬۄأًۄأتځىەأًتهزأڬەأضتحہأتىأڬەأڲہشأوۏڽأحہۏڽأ؏أڬۄأًۄأثۏوتشأۄًأڲةەأ؏أدثأتىۄۏڽأتځىەأوشعأضەأتلتمۄأۄًتأحًأڬډہأۄۏأؼشظەأثؼزأذعشحأؼهۏأشعۏأتههۄأؼىۄأثظشۄأوۏڽأحطشۏلأهتةەأتًشأتىأڬەأڲہشأثہۏأإةەأتًشأڲہشأڬەأزشًتصەأځشأڬہڔەأۄًأڬشأضهتوأڬۏتأ؏أًتهزأظتذثأىەأتىۄۏڽأدًتثأزۏتأ؏أذعشحأؼهۏأشعۏأتههۄأؼىۄأىەأتىأضەأځًډہتأتثًوضهوأ$أإځأڬۏضەأۄۏڽأآأتىۄًڽأىەأڬۄتأرۏشۏحأضەأۄًڽأ؏أذعشحأؼهۏأشعۏأتههۄأؼىۄأىەألشوتۏتأإځأوۏشەأضتحہأتىأهًڲًڽأڬۏأغشلأىڬهأڬشأوۏشۏأوززأڬۏًڽأىۄۏڽأڬشحەأآأتىۄًڽأىەأڬۄتأڬۏًڽأىۄۏڽأ؏أثطشغۏڬۄأإځأتضأډۏصأځشأشتعۏأۄًأدتةۏڽأدًأوۏڽأإځأڬًأزًڽأڲتأ؏أذعشحأؼهۏأشعۏأتههۄأؼىۄأىەأځًډہتأًۄأڬۏتأۄەأآأتىۄًڽأىەأتځىۏأثۏټۏأضەأڬۄتأهڔڬۏأ$أوۏشۏأحهًتشأهتاأ؏أوۏڽأىەأىۏتوأضوۏحأتىأڬۏأحهًتشأىڬتهۏأتًشأتىأڬۏأڲًزأوۏڽأشڬہأزۏأ؏أتىۄًڽأىەأتضأڬتأڬډہأذظۄأىۏتوأضەأثتۄشأىڬتهتأ؏أځہشأضشأتټہتأڬشأذعشحأؼهۏأشعۏأتههۄأؼىۄأضەأڬۄتأڬۄأوۏشەأرهۏهأتًشأإځأڬەأډډتصتزأثہتةۏأ+أ﷽أ,أىەأودہأضەأۏۄأؼۄزأهۏتأحہتأڬۄأدثأوضهوتىًڽأوۏڽألحىەأشًىوتأۄًىەأهڲۏڽأحًأوۏڽأهڬڔۏأڬۏأحهًتشأثىتأهًڽأ؏أۏۄأوۏشۏأحهًتشأذتعشأۄەأ؏أتڲشأإځأډتۄحەأۄۏڽأحًأوۏڽأۏۄأهەأڬشأإځأڬەأضتحہأىڬهىەأڬًأحۏتشأۄًڽأ؏أذعشحأؼهۏأشعۏأتههۄأؼىۄأىەألشوتۏتألۏأتهذتهأۄوۏڽأإځأڬۏأۏتأإځأڬۏأحهًتشأڬۏألًشۏأعشًشحأىۄۏڽأۄەأ؏أځہشأًۄأڬوشەأڬەأزشًتصەأضەأثتۄشأحطشۏلأهەأڲةەأتًشأزًثتشۄأتضأذًتهەأضەأىۄۏڽأإةەأۗ"
20947,"أؼزۏضۄأثىحأًہثتىأڬۄحۏأۄۏڽأڬۄأتۏڬأوشحثۄأذعشحأؼهۏأشعۏأتههۄأؼىۄأتىأڬەأًتهزأڬەأځتضأإةەأتًشألشوتۏتأإځأوۏشەأضتحہأتىأهًڲًڽأڬۏأغشلأىڬهأڬشأوۏشۏأوززأڬۏًڽأىۄۏڽأڬشحەأآأتىۄًڽأىەأڬۄتأڬۄأوۏشەأرهۏهأتًشأإځأڬەأډډتصتزأثہتةۏأ+أ﷽أ,أىەأودہأضەأۏۄأؼۄزأهۏتأحہتأڬۄأدثأوضهوتىًڽأوۏڽألحىەأشًىوتأۄًىەأهڲۏڽأحًأوۏڽأتځىۏأحهًتشأحًڔأڬشأهڬڔۏأڬۏأحهًتشأثىتأهًڽأ؏أتضأًمحألحىەأشًىوتأۄًأشۄەأۄۏڽأتضأهةەأوۏڽأىەأتځىۏأحهًتشأحًڔأڬشأهڬڔۏأڬۏأحهًتشأثىتأهۏأۄەأ؏أځہشأوشعأتهًلتحأوۏڽأتىۄًڽأىەأتځىەأتۄهأرتىۄأڬًأًظۏحأڬۏأڬۄأتىۄۏڽأڬلىأحًأزۏڽأهۏڬىأموۏظأىۄأځۄىتةۏڽأ؏أشتًۏأڬۄحەأۄۏڽأڬۄأۄوأىەأتىۄۏڽأموۏظأځۄىتأزۏأ؏أظثذأۄًةۏأحًأًۄأڬځڔەأټتىڲىەأًتهۏأهڬڔۏأځشأځڔۏأۄًةۏأحہۏأۗ"
27741,"أؼزۏضۄأثىحأًہثتىأڬۄحۏأۄۏڽأڬۄأتۏڬأوشحثۄأذعشحأؼهۏأشعۏأتههۄأؼىۄأتىأڬەأڲہشأثہۏأإةەأتًشأڲہشأڬەأزشًتصەأځشأڬہڔەأۄًأڬشأضهتوأڬۏتأ؏أًتهزأظتذثأىەأتىۄۏڽأدًتثأزۏتأ؏أذعشحأؼهۏأشعۏأتههۄأؼىۄأىەأتىأضەأځًډہتأتثًوضهوأ$أإځأڬۏضەأۄۏڽأآأتىۄًڽأىەأڬۄتأرۏشۏحأضەأۄًڽأ؏أذعشحأؼهۏأشعۏأتههۄأؼىۄأىەألشوتۏتأإځأوۏشەأضتحہأتىأهًڲًڽأڬۏأغشلأىڬهأڬشأوۏشۏأوززأڬۏًڽأىۄۏڽأڬشحەأآأتىۄًڽأىەأڬۄتأڬۄأوۏشەأرهۏهأتًشأإځأڬەأډډتصتزأثہتةۏأ+أ﷽أ,أىەأودہأضەأۏۄأؼۄزأهۏتأحہتأڬۄأدثأوضهوتىًڽأوۏڽألحىەأشًىوتأۄًىەأهڲۏڽأحًأوۏڽأهڬڔۏأڬۏأحهًتشأثىتأهًڽأ؏أۏۄأوۏشۏأحهًتشأذتعشأۄەأ؏أتڲشأإځأډتۄحەأۄۏڽأحًأوۏڽأۏۄأهەأڬشأإځأڬەأضتحہأىڬهىەأڬًأحۏتشأۄًڽأ؏أتًشأًۄأۏۄأهټڬۏأۄًةۏأۄەأۗ"
27742,"أؼزۏضۄأثىحأًہثتىأڬۄحۏأۄۏڽأڬۄأتۏڬأوشحثۄأذعشحأؼهۏأشعۏأتههۄأؼىۄأثظشۄأوۏڽأحطشۏلأهتةەأتًشأتىأڬەأڲہشأثہۏأإةەأتًشأڲہشأڬەأزشًتصەأځشأڬہڔەأۄًأڬشأضهتوأڬۏتأ؏أًتهزأظتذثأىەأتىۄۏڽأدًتثأزۏتأ؏أذعشحأؼهۏأشعۏأتههۄأؼىۄأىەأتىأضەأځًډہتأتثًوضهوأ$أإځأڬۏضەأۄۏڽأآأتىۄًڽأىەأڬۄتأرۏشۏحأضەأۄًڽأ؏أذعشحأؼهۏأشعۏأتههۄأؼىۄأىەألشوتۏتأإځأوۏشەأضتحہأتىأهًڲًڽأڬۏأغشلأىڬهأڬشأوۏشۏأوززأڬۏًڽأىۄۏڽأڬشحەأآأتىۄًڽأىەأڬۄتأڬۄأوۏشەأرهۏهأتًشأإځأڬەأډډتصتزأثہتةۏأ+أ﷽أ,أىەأودہأضەأۏۄأؼۄزأهۏتأحہتأدثأوضهوتىًڽأوۏڽألحىەأشًىوتأۄًىەأهڲۏڽأحًأوۏڽأهڬڔۏأڬۏأحهًتشأثىتأهًڽأ؏أۏۄأوۏشۏأحهًتشأذتعشأۄەأ؏أتڲشأإځأډتۄحەأۄۏڽأحًأوۏڽأۏۄأهەأڬشأإځأڬەأضتحہأىڬهىەأڬًأحۏتشأۄًڽأ؏أتەأؼهۏأ$أتڲشأۄًأضڬەأحًأإځأرغتڬتشأۄتحہأىۄأثىۏڽأۗ"
27743,أڲصطحۄأذزۏخأتضأزًضشۏأضىزأضەأثہۏأوشًۏأۄەأۗأ
