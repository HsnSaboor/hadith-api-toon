metadata:

hadiths[770]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
391,طلحہ بن عبیداللہ رضی اللہ عنہ کہتے ہیں کہ  اہل نجد کا ایک شخص رسول اللہ صلی اللہ علیہ وسلم کے پاس آی,Sahih (Al-Albani),"Book 2, Hadith 391",,,391
392,اس سند سے بھی ابوسہیل نافع بن مالک بن ابی عامر سے یہی حدیث مروی ہے، اس میں ہے کہ  نبی اکرم صلی اللہ ,Sahih (Al-Albani),"Book 2, Hadith 392",,,392
393,"عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جبرائیل علیہ ال",Sahih (Al-Albani),"Book 2, Hadith 393",,,393
394,ابن شہاب زہری کہتے ہیں کہ  عمر بن عبدالعزیز منبر پر بیٹھے ہوئے تھے، آپ نے عصر میں کچھ تاخیر کر دی، ا,Hasan (Al-Albani),"Book 2, Hadith 394",,,394
395,ابوموسیٰ رضی اللہ عنہ کہتے ہیں کہ  ایک سائل نے نبی اکرم صلی اللہ علیہ وسلم سے  ( اوقات نماز کے بارے ,Da'if (Al-Albani),"Book 2, Hadith 395",,,395
396,"عبداللہ بن عمرو رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  ظہر کا وقت اس",Da'if (Al-Albani),"Book 2, Hadith 396",,,396
397,محمد بن عمرو سے روایت ہے (اور وہ حسن بن علی بن ابی طالب رضی اللہ عنہما کے لڑکے ہیں) وہ کہتے ہیں کہ  ,Da'if (Al-Albani),"Book 2, Hadith 397",,,397
398,ابوبرزہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ظہر سورج ڈھل جانے پر پڑھتے اور عصر اس,Sahih (Al-Albani),"Book 2, Hadith 398",,,398
399,جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  میں رسول اللہ صلی اللہ علیہ وسلم کے ساتھ ظہر پڑھتا تو ای,Sahih (Al-Albani),"Book 2, Hadith 399",,,399
400,"اسود کہتے ہیں کہ  عبداللہ بن مسعود رضی اللہ عنہ نے فرمایا: رسول اللہ صلی اللہ علیہ وسلم کی  ( نماز ظ",Sahih (Al-Albani),"Book 2, Hadith 400",,,400
401,ابوذر رضی اللہ عنہ کہتے ہیں کہ  ہم نبی اکرم صلی اللہ علیہ وسلم کے ساتھ تھے، مؤذن نے ظہر کی اذان کہنے,,"Book 2, Hadith 401",,,401
402,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب گرمی کی شدت ہو تو نما",Sahih (Al-Albani),"Book 2, Hadith 402",,,402
403,جابر بن سمرہ رضی اللہ عنہ کہتے ہیں کہ  بلال رضی اللہ عنہ ظہر کی اذان اس وقت دیتے تھے جب سورج ڈھل جات,Sahih (Al-Albani),"Book 2, Hadith 403",,,403
404,انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم عصر ایسے وقت میں پڑھتے تھے کہ سور,Sahih (Al-Albani),"Book 2, Hadith 404",,,404
405,زہری کا بیان ہے کہ  عوالی مدینہ سے دو یا تین میل کے فاصلہ پر واقع ہے۔ راوی کا کہنا ہے کہ میرا خیال ہ,Sahih (Al-Albani),"Book 2, Hadith 405",,,405
406,خیثمہ کہتے ہیں کہ  سورج کے زندہ ہونے کا مطلب یہ ہے کہ تم اس کی تپش اور گرمی محسوس کرو۔,Hasan (Al-Albani),"Book 2, Hadith 406",,,406
407,ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم عصر ایسے وقت میں ادا فرمات,Sahih (Al-Albani),"Book 2, Hadith 407",,,407
408,علی بن شیبان رضی اللہ عنہ کہتے ہیں کہ  ہم رسول اللہ صلی اللہ علیہ وسلم کے پاس مدینہ آئے تو دیکھا کہ ,Sahih (Al-Albani),"Book 2, Hadith 408",,,408
409,"علی رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے غزوہ خندق کے روز فرمایا:  ہم کو انہ",Sahih (Al-Albani),"Book 2, Hadith 409",,,409
410,قعقاع بن حکیم ام المؤمنین عائشہ رضی اللہ عنہا کے آزاد کردہ غلام ابویونس سے روایت کرتے ہیں کہ  انہوں ,Sahih (Al-Albani),"Book 2, Hadith 410",,,410
411,زید بن ثابت رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ظہر دوپہر کو پڑھا کرتے تھے، اور ک,Sahih (Al-Albani),"Book 2, Hadith 411",,,411
412,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس شخص نے سورج ڈوبنے سے ",Da'if (Al-Albani),"Book 2, Hadith 412",,,412
413,علاء بن عبدالرحمٰن کہتے ہیں کہ  ہم ظہر کے بعد انس بن مالک رضی اللہ عنہ کے پاس آئے تو دیکھا کہ وہ عصر,Sahih (Al-Albani),"Book 2, Hadith 413",,,413
414,"عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس شخص کی عصر چھ",Sahih (Al-Albani),"Book 2, Hadith 414",,,414
415,ابوعمرو یعنی اوزاعی کا بیان ہے کہ  عصر فوت ہونے کا مطلب یہ ہے کہ زمین پر جو دھوپ ہے وہ تمہیں زرد نظر,Hasan Sahih (Al-Albani),"Book 2, Hadith 415",,,415
416,انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  ہم نبی اکرم صلی اللہ علیہ وسلم کے ساتھ مغرب پڑھتے تھے، پھر تیر,Sahih (Al-Albani),"Book 2, Hadith 416",,,416
417,سلمہ بن الاکوع رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم مغرب سورج ڈوبتے ہی پڑھتے تھے جب,Da'if (Al-Albani),"Book 2, Hadith 417",,,417
418,مرثد بن عبداللہ کہتے ہیں کہ  جب ابوایوب رضی اللہ عنہ ہمارے پاس جہاد کے ارادے سے آئے، ان دنوں عقبہ بن,Sahih (Al-Albani),"Book 2, Hadith 418",,,418
419,نعمان بن بشیر رضی اللہ عنہما کہتے ہیں کہ  میں لوگوں میں سب سے زیادہ اس نماز یعنی عشاء کے وقت کو جانت,Sahih (Al-Albani),"Book 2, Hadith 419",,,419
420,عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  ایک رات ہم عشاء کے لیے رسول اللہ صلی اللہ علیہ وسلم کی آم,Sahih (Al-Albani),"Book 2, Hadith 420",,,420
421,معاذ بن جبل رضی اللہ عنہ کہتے ہیں کہ  ہم نے عشاء میں نبی اکرم صلی اللہ علیہ وسلم کا انتظار کیا لیکن ,Sahih (Al-Albani),"Book 2, Hadith 421",,,421
422,ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  ہم نے رسول اللہ صلی اللہ علیہ وسلم کے ساتھ عشاء پڑھنی چاہی ت,Sahih (Al-Albani),"Book 2, Hadith 422",,,422
423,ام المؤمنین عائشہ رضی اللہ عنہا فرماتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نماز صبح  ( فجر )  ادا ف,Sahih Maqtu' (Al-Albani),"Book 2, Hadith 423",,,423
424,"رافع بن خدیج رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  فجر  ( نماز صبح )  ا",Da'if (Al-Albani),"Book 2, Hadith 424",,,424
425,عبداللہ بن صنابحی نے کہا کہ ابومحمد کا کہنا ہے کہ  وتر واجب ہے تو اس پر عبادہ بن صامت رضی اللہ عنہ ن,Da'if (Al-Albani),"Book 2, Hadith 425",,,425
426,"ام فروہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم سے پوچھا گیا: کون سا عمل افضل ہے؟ آپ",Hasan (Al-Albani),"Book 2, Hadith 426",,,426
427,"عمارہ بن رویبہ کہتے ہیں کہ  اہل بصرہ میں سے ایک آدمی نے ان سے پوچھا اور کہا: آپ مجھے ایسی بات بتائیے",Sahih (Al-Albani),"Book 2, Hadith 427",,,427
428,فضالہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مجھے جو باتیں سکھائیں ان میں یہ بات ,Sahih (Al-Albani),"Book 2, Hadith 428",,,428
429,"ابوالدرداء رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  پانچ چیزیں ہیں، جو انہ",Munkar (Al-Albani),"Book 2, Hadith 429",,,429
430,سعید بن مسیب کہتے ہیں کہ  ابوقتادہ بن ربعی رضی اللہ عنہ نے انہیں خبر دی کہ رسول اللہ صلی اللہ علیہ و,Sahih (Al-Albani),"Book 2, Hadith 430",,,430
431,"ابوذر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مجھ سے فرمایا:  ابوذر! تم اس وقت کیا",Sahih (Al-Albani),"Book 2, Hadith 431",,,431
432,عمرو بن میمون اودی کہتے ہیں کہ  معاذ بن جبل رضی اللہ عنہ رسول اللہ صلی اللہ علیہ وسلم کے قاصد بن کر ,,"Book 2, Hadith 432",,,432
433,"عبادہ بن صامت رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  میرے بعد تمہارے اوپ",Da'if (Al-Albani),"Book 2, Hadith 433",,,433
434,"قبیصہ بن وقاص رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  میرے بعد تم پر ایسے",Da'if (Al-Albani),"Book 2, Hadith 434",,,434
435,ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ ´ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ` رسول اللہ صلی اللہ علیہ وسلم ج,Da'if (Al-Albani),"Book 2, Hadith 435",,,435
436,"ابوہریرہ رضی اللہ عنہ سے اس حدیث میں یہ بھی روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اپ",Sahih (Al-Albani),"Book 2, Hadith 436",,,436
437,ابوقتادہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم اپنے ایک سفر میں تھے، تو آپ ایک طرف م,Sahih (Al-Albani),"Book 2, Hadith 437",,,437
438,خالد بن سمیر کہتے ہیں کہ  مدینہ سے عبداللہ بن رباح انصاری جنہیں انصار مدینہ فقیہ کہتے تھے ہمارے پاس ,Sahih (Al-Albani),"Book 2, Hadith 438",,,438
439,"ابوقتادہ رضی اللہ عنہ سے اس حدیث میں یوں مروی ہے کہ  آپ صلی اللہ علیہ وسلم نے فرمایا:  اللہ تعالیٰ ن",Sahih (Al-Albani),"Book 2, Hadith 439",,,439
440,"ابوقتادہ رضی اللہ عنہ نبی اکرم صلی اللہ علیہ وسلم سے اسی مفہوم کی حدیث روایت کرتے ہیں،  اس میں ہے:  ",Sahih (Al-Albani),"Book 2, Hadith 440",,,440
441,"ابوقتادہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  سو جانے میں کوتاہی نہیں ",Hasan Sahih (Al-Albani),"Book 2, Hadith 441",,,441
442,"انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جو شخص کوئی نماز بھول ",Hasan (Al-Albani),"Book 2, Hadith 442",,,442
443,عمران بن حصین رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ایک سفر میں تھے کہ لوگ نماز ف,Da'if Mauquf (Al-Albani),"Book 2, Hadith 443",,,443
444,عمرو بن امیہ ضمری رضی اللہ عنہ کہتے ہیں کہ  ہم رسول اللہ صلی اللہ علیہ وسلم کے ساتھ ایک سفر میں تھے،,Sahih Maqtu' (Al-Albani),"Book 2, Hadith 444",,,444
445,ذی مخبر حبشی رضی اللہ عنہ (خادم رسول اللہ صلی اللہ علیہ وسلم) سے اس واقعے میں روایت ہے کہ  نبی اکرم ,Sahih (Al-Albani),"Book 2, Hadith 445",,,445
446,اس سند سے بھی ذی مخبر سے یہی حدیث مروی ہے اس میں ہے  انہوں نے بغیر جلد بازی کے ٹھہر ٹھہر کر اذان دی۔,Sahih (Al-Albani),"Book 2, Hadith 446",,,446
447,عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں  ہم صلح حدیبیہ کے زمانے میں رسول اللہ صلی اللہ علیہ وسلم کے س,Da'if (Al-Albani),"Book 2, Hadith 447",,,447
448,"عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مجھے مسجدوں کے ",Da'if (Al-Albani),"Book 2, Hadith 448",,,448
449,"انس رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  قیامت اس وقت تک قائم نہیں ہ",Da'if (Al-Albani),"Book 2, Hadith 449",,,449
450,عثمان بن ابی العاص رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے انہیں طائف کی مسجد ای,Sahih (Al-Albani),"Book 2, Hadith 450",,,450
451,عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے زمانے میں مسجد نبوی کچی ا,Sahih (Al-Albani),"Book 2, Hadith 451",,,451
452,عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم کے زمانے میں مسجد نبوی کے,Sahih (Al-Albani),"Book 2, Hadith 452",,,452
453,انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم مدینہ تشریف لائے تو آپ شہر کے بال,Sahih (Al-Albani),"Book 2, Hadith 453",,,453
454,انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  مسجد نبوی کی جگہ پر قبیلہ بنو نجار کا ایک باغ تھا، اس میں کچھ ,Sahih (Al-Albani),"Book 2, Hadith 454",,,454
455,ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے گھر اور محلہ میں مسجدیں,Sahih (Al-Albani),"Book 2, Hadith 455",,,455
456,"سمرہ رضی اللہ عنہ سے روایت کرتے ہیں کہ  انہوں نے اپنے بیٹے  ( سلیمان )  کو لکھا: حمد و صلاۃ کے بعد م",Sahih (Al-Albani),"Book 2, Hadith 456",,,456
457,"نبی اکرم صلی اللہ علیہ وسلم کی آزاد کردہ لونڈی میمونہ رضی اللہ عنہا سے روایت ہے کہ  انہوں نے کہا: ال",Sahih (Al-Albani),"Book 2, Hadith 457",,,457
458,ابوالولید سے روایت ہے کہ  میں نے ابن عمر رضی اللہ عنہما سے مسجد کی کنکریوں کے متعلق پوچھا تو انہوں ن,Sahih (Al-Albani),"Book 2, Hadith 458",,,458
459,"ابوصالح کہتے ہیں کہ  کہا جاتا تھا: جب آدمی کنکریوں کو مسجد سے نکالتا ہے تو وہ اسے قسم دلاتی ہیں  ( ک",Hasan Maqtu' (Al-Albani),"Book 2, Hadith 459",,,459
460,"ابوبدر کہتے ہیں: میرا خیال ہے کہ  ابوہریرہ رضی اللہ عنہ نے یہ حدیث نبی اکرم صلی اللہ علیہ وسلم سے مر",Hasan (Al-Albani),"Book 2, Hadith 460",,,460
461,"انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مجھ پر میری امت کے ثو",Sahih (Al-Albani),"Book 2, Hadith 461",,,461
462,"عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اگر ہم اس دروازے",Sahih (Al-Albani),"Book 2, Hadith 462",,,462
463,نافع سے روایت ہے کہ  عمر بن خطاب رضی اللہ عنہ نے یہ بات کہی اور یہی زیادہ صحیح ہے ۱؎۔,Sahih (Al-Albani),"Book 2, Hadith 463",,,463
464,نافع سے روایت ہے کہ  عمر بن خطاب رضی اللہ عنہ  ( مردوں کو )  عورتوں کے دروازہ سے داخل ہونے سے منع کر,Sahih (Al-Albani),"Book 2, Hadith 464",,,464
465,"ابوحمید یا ابواسید انصاری کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں سے کوئی شخ",Sahih (Al-Albani),"Book 2, Hadith 465",,,465
466,"حیوہ بن شریح کہتے ہیں کہ  میں عقبہ بن مسلم سے ملا تو میں نے ان سے کہا: مجھے یہ خبر پہنچی ہے کہ آپ نے",Sahih (Al-Albani),"Book 2, Hadith 466",,,466
467,"ابوقتادہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں سے کوئی شخص",Sahih (Al-Albani),"Book 2, Hadith 467",,,467
468,اس سند سے بھی ابوقتادہ رضی اللہ عنہ سے اسی طرح  مرفوعاً مروی ہے، اس میں اتنا زیادہ ہے کہ پھر اس کے ب,Sahih (Al-Albani),"Book 2, Hadith 468",,,468
469,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  فرشتے تم میں سے ہر ایک ش",Hasan (Al-Albani),"Book 2, Hadith 469",,,469
470,"اسی سند سے ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم میں سے ہر ",Hasan (Al-Albani),"Book 2, Hadith 470",,,470
471,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  بندہ برابر نماز ہی میں ر",Sahih (Al-Albani),"Book 2, Hadith 471",,,471
472,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مسجد میں جو جس کام کے لی",Hasan (Al-Albani),"Book 2, Hadith 472",,,472
473,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  جو شخص کسی کو",Sahih (Al-Albani),"Book 2, Hadith 473",,,473
474,"انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مسجد میں تھوکنا گناہ ",Sahih (Al-Albani),"Book 2, Hadith 474",,,474
475,"انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مسجد میں تھوکنا گناہ ",,"Book 2, Hadith 475",,,475
476,"انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مسجد میں حلق سے بلغم ",Sahih (Al-Albani),"Book 2, Hadith 476",,,476
477,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص اس مسجد میں داخل ",Sahih (Al-Albani),"Book 2, Hadith 477",,,477
478,"طارق بن عبداللہ محاربی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب آدمی نم",Sahih (Al-Albani),"Book 2, Hadith 478",,,478
479,عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ایک دن خطبہ دے رہے تھے کہ اس,Da'if (Al-Albani),"Book 2, Hadith 479",,,479
480,ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کھجور کی شاخوں کو پسند کرتے تھے ,Da'if (Al-Albani),"Book 2, Hadith 480",,,480
481,ابو سہلہ سائب بن خلاد رضی اللہ عنہ کہتے ہیں (احمد کہتے ہیں کہ وہ نبی اکرم صلی اللہ علیہ وسلم کے اصحا,Sahih (Al-Albani),"Book 2, Hadith 481",,,481
482,عبداللہ بن شخیر بن عوف رضی اللہ عنہ کہتے ہیں  میں رسول اللہ صلی اللہ علیہ وسلم کے پاس آیا اور آپ نما,Sahih (Al-Albani),"Book 2, Hadith 482",,,482
483,اس سند سے ابوالعلاء یزید بن عبداللہ بن الشخیر نے  اپنے والد عبداللہ بن الشخیر رضی اللہ عنہ سے اسی مع,Sahih (Al-Albani),"Book 2, Hadith 483",,,483
484,ابوسعید حمیری کہتے ہیں کہ  میں نے دمشق کی مسجد میں واثلہ بن اسقع رضی اللہ عنہ کو دیکھا کہ انہوں نے ب,Sahih (Al-Albani),"Book 2, Hadith 484",,,484
485,عبادہ بن ولید بن عبادہ بن صامت سے روایت ہے کہ  ہم جابر بن عبداللہ رضی اللہ عنہما کے پاس آئے، وہ اپنی,Sahih (Al-Albani),"Book 2, Hadith 485",,,485
486,انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  ایک شخص اونٹ پر سوار ہو کر آیا، اس نے اسے مسجد میں بٹھایا پھر ,Sahih (Al-Albani),"Book 2, Hadith 486",,,486
487,عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  بنی سعد بن بکر نے ضمام بن ثعلبہ کو رسول اللہ صلی اللہ عل,Sahih (Al-Albani),"Book 2, Hadith 487",,,487
488,ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  یہود نبی اکرم صلی اللہ علیہ وسلم کے پاس آئے اور آپ مسجد میں اپنے ,Sahih (Al-Albani),"Book 2, Hadith 488",,,488
489,"ابوذر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  میرے لیے ساری زمین ذریعہ طہ",Sahih (Al-Albani),"Book 2, Hadith 489",,,489
490,ابوصالح غفاری کہتے ہیں کہ  علی رضی اللہ عنہ بابل سے گزر رہے تھے کہ ان کے پاس مؤذن انہیں نماز عصر کی ,Sahih (Al-Albani),"Book 2, Hadith 490",,,490
491,"اس سند سے بھی علی رضی اللہ عنہ سے  سلیمان بن داود کی حدیث کے ہم معنی حدیث مروی ہے، مگر اس میں: «فلما",Da'if (Al-Albani),"Book 2, Hadith 491",,,491
492,ابوسعید رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا  ( اور موسیٰ بن اسماعیل نے ,Sahih (Al-Albani),"Book 2, Hadith 492",,,492
493,براء بن عازب رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم سے اونٹ کے باڑوں  ( بیٹھنے کی ,Sahih (Al-Albani),"Book 2, Hadith 493",,,493
494,"سبرہ بن معبد جہنی رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  بچے سات سال کے ہ",Sahih (Al-Albani),"Book 2, Hadith 494",,,494
495,"عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تمہ",Sahih (Al-Albani),"Book 2, Hadith 495",,,495
496,داود بن سوار مزنی سے اس سند سے اسی مفہوم کی حدیث مروی ہے، اس میں انہوں نے یہ اضافہ کیا ہے کہ  جب کوئ,,"Book 2, Hadith 496",,,496
497,"ہشام بن سعد کا بیان ہے کہ  مجھ سے معاذ بن عبداللہ بن خبیب جہنی نے بیان کیا، ہشام کہتے ہیں: ہم معاذ ک",Da'if (Al-Albani),"Book 2, Hadith 497",,,497
498,ابو عمیر بن انس اپنے ایک انصاری چچا سے روایت کرتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم فکرمند ہوئے کہ,Da'if (Al-Albani),"Book 2, Hadith 498",,,498
499,عبداللہ بن زید رضی اللہ عنہ کہتے ہیں کہ  جب رسول اللہ صلی اللہ علیہ وسلم نے ناقوس کی تیاری کا حکم دی,Sahih (Al-Albani),"Book 2, Hadith 499",,,499
500,"ابومحذورہ رضی اللہ عنہ کہتے ہیں کہ  میں نے عرض کیا: اللہ کے رسول صلی اللہ علیہ وسلم! آپ مجھے اذان کا",Sahih (Al-Albani),"Book 2, Hadith 500",,,500
501,اس سند سے بھی ابو محذورہ رضی اللہ عنہ سے اسی طرح مروی ہے  اس میں فجر کی پہلی  ( اذان )  میں «الصلاة ,Sahih (Al-Albani),"Book 2, Hadith 501",,,501
502,ابن محیریز کا بیان ہے کہ ابو محذورہ رضی اللہ عنہ نے ان سے بیان کیا کہ  رسول اللہ صلی اللہ علیہ وسلم ,Sahih (Al-Albani),"Book 2, Hadith 502",,,502
503,ابو محذورہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے بذات خود مجھے اذان کے کلمات سکھ,Hasan (Al-Albani),"Book 2, Hadith 503",,,503
504,عبدالملک کا بیان کہ انہوں نے ابو محذورہ رضی اللہ عنہ کو کہتے سنا کہ  رسول اللہ صلی اللہ علیہ وسلم نے,Sahih (Al-Albani),"Book 2, Hadith 504",,,504
505,"ابو محذورہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے انہیں اذان سکھائی، آپ کہتے تھے:",,"Book 2, Hadith 505",,,505
506,ابن ابی لیلیٰ کہتے ہیں کہ  نماز تین حالتوں سے گزری، ہمارے صحابہ کرام نے ہم سے بیان کیا کہ رسول اللہ ,Da'if (Al-Albani),"Book 2, Hadith 506",,,506
507,معاذ بن جبل رضی اللہ عنہ کہتے ہیں کہ  نماز میں تین تبدیلیاں ہوئیں، اسی طرح روزوں میں بھی تین تبدیلیا,Sahih (Al-Albani),"Book 2, Hadith 507",,,507
508,انس رضی اللہ عنہ کہتے ہیں کہ  بلال رضی اللہ عنہ کو حکم دیا گیا کہ وہ اذان دہری اور اقامت اکہری کہیں۔,Sahih (Al-Albani),"Book 2, Hadith 508",,,508
509,"اس طریق سے بھی انس رضی اللہ عنہ سے وہیب کی حدیث کے مثل حدیث مروی ہے  اسماعیل کہتے ہیں: میں نے اسے ای",Sahih (Al-Albani),"Book 2, Hadith 509",,,509
510,عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے زمانے میں اذان کے کلمات د,Hasan Sahih (Al-Albani),"Book 2, Hadith 510",,,510
511,مسجد عریان ۱؎ کے مؤذن ابو جعفر کہتے ہیں کہ  میں نے بڑی مسجد کے مؤذن ابو مثنیٰ کو کہتے سنا کہ میں نے ,Da'if (Al-Albani),"Book 2, Hadith 511",,,511
512,عبداللہ بن زید رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے اذان کے سلسلہ میں کئی کام کر,Da'if (Al-Albani),"Book 2, Hadith 512",,,512
513,"عبداللہ بن محمد کہتے ہیں  میرے دادا عبداللہ بن زید رضی اللہ عنہ یہ حدیث بیان کرتے تھے، اس میں ہے:  ت",Sahih (Al-Albani),"Book 2, Hadith 513",,,513
514,زیاد بن حارث صدائی رضی اللہ عنہ کہتے ہیں کہ  جب صبح کی پہلی اذان کا وقت ہوا تو نبی اکرم صلی اللہ علی,Sahih (Al-Albani),"Book 2, Hadith 514",,,514
515,"ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  مؤذن کی بخشش کر دی جات",Hasan (Al-Albani),"Book 2, Hadith 515",,,515
516,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب نماز کے لیے اذان دی ج",Sahih (Al-Albani),"Book 2, Hadith 516",,,516
517,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  امام  ( مقتدیوں کی نماز ",Hasan (Al-Albani),"Book 2, Hadith 517",,,517
518,اس سند سے بھی ابوہریرہ رضی اللہ عنہ سے  گذشتہ حدیث کے مثل مرفوع روایت آئی ہے۔,Sahih (Al-Albani),"Book 2, Hadith 518",,,518
519,قبیلہ بنی نجار کی ایک عورت کہتی ہے  مسجد کے اردگرد گھروں میں سب سے اونچا میرا گھر تھا، بلال رضی اللہ,Da'if (Al-Albani),"Book 2, Hadith 519",,,519
520,ابوجحیفہ رضی اللہ عنہ کہتے ہیں کہ  میں مکہ میں نبی اکرم صلی اللہ علیہ وسلم کے پاس آیا، آپ چمڑے کے ای,Da'if (Al-Albani),"Book 2, Hadith 520",,,520
521,"انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اذان اور اقامت کے درم",Sahih (Al-Albani),"Book 2, Hadith 521",,,521
522,"ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کا ارشاد ہے:  جب تم اذان سنو تو",Sahih (Al-Albani),"Book 2, Hadith 522",,,522
523,عبداللہ بن عمرو بن العاص رضی اللہ عنہما سے روایت ہے کہ  انہوں نے نبی اکرم صلی اللہ علیہ وسلم کو فرما,Sahih (Al-Albani),"Book 2, Hadith 523",,,523
524,"عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  ایک شخص نے عرض کیا: اے اللہ کے رسول! مؤذنوں کو ہم پر فضی",Sahih (Al-Albani),"Book 2, Hadith 524",,,524
525,"سعد بن ابی وقاص رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس شخص نے مؤذن",Sahih (Al-Albani),"Book 2, Hadith 525",,,525
526,"ام المؤمنین عائشہ رضی اللہ عنہا فرماتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم جب مؤذن کو: «أشهد أن لا ",Hasan (Al-Albani),"Book 2, Hadith 526",,,526
527,"عمر بن خطاب رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب مؤذن: «الله أكبر ا",Sahih (Al-Albani),"Book 2, Hadith 527",,,527
528,ابوامامہ رضی اللہ عنہ سے یا بعض صحابہ کرام سے روایت ہے کہ  بلال رضی اللہ عنہ نے اقامت شروع کی، جب ان,Sahih (Al-Albani),"Book 2, Hadith 528",,,528
529,"جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس شخص نے اذان ",Sahih (Al-Albani),"Book 2, Hadith 529",,,529
530,ام المؤمنین ام سلمہ رضی اللہ عنہا کہتی ہیں کہ  مجھے رسول اللہ صلی اللہ علیہ وسلم نے سکھایا کہ میں مغ,Sahih (Al-Albani),"Book 2, Hadith 530",,,530
531,"عثمان بن ابی العاص رضی اللہ عنہ کہتے ہیں کہ  میں نے عرض کیا: اے اللہ کے رسول! آپ مجھے میری قوم کا ام",Da'if (Al-Albani),"Book 2, Hadith 531",,,531
532,عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  بلال رضی اللہ عنہ نے فجر کا وقت ہونے سے پہلے اذان دے دی ت,Sahih (Al-Albani),"Book 2, Hadith 532",,,532
533,عمر رضی اللہ عنہ کے مسروح نامی مؤذن سے روایت ہے کہ  انہوں نے صبح صادق سے پہلے اذان دے دی تو عمر رضی ,Hasan (Al-Albani),"Book 2, Hadith 533",,,533
534,"بلال رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے ان سے فرمایا:  تم اذان نہ دیا کرو ",Sahih (Al-Albani),"Book 2, Hadith 534",,,534
535,ام المؤمنین عائشہ رضی اللہ عنہا فرماتی ہیں کہ  ابن ام مکتوم رضی اللہ عنہ رسول اللہ صلی اللہ علیہ وسل,Hasan Sahih (Al-Albani),"Book 2, Hadith 535",,,535
536,ام المؤمنین عائشہ رضی اللہ عنہا فرماتی ہیں کہ  ابن ام مکتوم رضی اللہ عنہ رسول اللہ صلی اللہ علیہ وسل,Sahih (Al-Albani),"Book 2, Hadith 536",,,536
537,ابوالشعثاء کہتے ہیں کہ  ہم ابوہریرہ رضی اللہ عنہ کے ساتھ مسجد میں تھے کہ ایک شخص مؤذن کے عصر کی اذان,Sahih (Al-Albani),"Book 2, Hadith 537",,,537
538,جابر بن سمرہ رضی اللہ عنہ کہتے ہیں کہ  بلال رضی اللہ عنہ اذان دیتے تھے پھر رکے رہتے تھے، پھر جب نبی ,Hasan Sahih (Al-Albani),"Book 2, Hadith 538",,,538
539,مجاہد کہتے ہیں کہ  کہ میں ابن عمر رضی اللہ عنہما کے ساتھ تھا کہ ایک شخص نے ظہر یا عصر میں تثویب ۱؎ ک,Sahih (Al-Albani),"Book 2, Hadith 539",,,539
540,"ابوقتادہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جب نماز کے لیے تکبیر ک",Sahih (Al-Albani),"Book 2, Hadith 540",,,540
541,یحییٰ سے اسی سند سے گذشتہ حدیث کے ہم مثل حدیث مروی ہے، اس میں ہے  یہاں تک کہ تم مجھے دیکھ لو کہ میں ,Sahih (Al-Albani),"Book 2, Hadith 541",,,541
542,ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے لیے جب نماز کی تکبیر کہی جاتی تھی,Da'if (Al-Albani),"Book 2, Hadith 542",,,542
543,حمید کہتے ہیں  میں نے ثابت بنانی سے اس شخص کے بارے میں پوچھا جو نماز کی تکبیر ہو جانے کے بعد بات کرت,Sahih (Al-Albani),"Book 2, Hadith 543",,,543
544,کہمس کہتے ہیں کہ  ہم منیٰ میں نماز کے لیے کھڑے ہوئے، امام ابھی نماز کے لیے نہیں نکلا تھا کہ ہم میں س,Hasan Sahih (Al-Albani),"Book 2, Hadith 544",,,544
545,انس رضی اللہ عنہ کہتے ہیں کہ  نماز  ( عشاء )  کی تکبیر کہی گئی اور رسول اللہ صلی اللہ علیہ وسلم مسجد,Da'if (Al-Albani),"Book 2, Hadith 545",,,545
546,سالم ابوالنضر کہتے ہیں  جب نماز کی تکبیر کہہ دی جاتی اور رسول اللہ صلی اللہ علیہ وسلم دیکھتے کہ  ( م,Sahih (Al-Albani),"Book 2, Hadith 546",,,546
547,اس سند سے ابومسعود زرقی بھی  علی بن ابی طالب رضی اللہ عنہ سے گذشتہ روایت کے ہم مثل روایت کرتے ہیں۔,Sahih (Al-Albani),"Book 2, Hadith 547",,,547
548,"ابو الدرداء رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  تین آدمی ک",Da'if (Al-Albani),"Book 2, Hadith 548",,,548
549,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  میں نے سوچا کہ نماز کھڑی",Da'if (Al-Albani),"Book 2, Hadith 549",,,549
550,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  میں نے ارادہ کیا کہ اپنے",Sahih (Al-Albani),"Book 2, Hadith 550",,,550
551,عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں  تم لوگ ان پانچوں نمازوں کی پابندی کرو جہاں ان کی اذان دی جائ,Sahih (Al-Albani),"Book 2, Hadith 551",,,551
552,"عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص اذان کی ",Sahih (Al-Albani),"Book 2, Hadith 552",,,552
553,"عبداللہ بن ام مکتوم رضی اللہ عنہ نے  نبی اکرم صلی اللہ علیہ وسلم سے پوچھا: اے اللہ کے رسول صلی اللہ ",Sahih Maqtu' (Al-Albani),"Book 2, Hadith 553",,,553
554,ابن ام مکتوم رضی اللہ عنہ کہتے ہیں  اللہ کے رسول! مدینے میں کیڑے مکوڑے اور درندے بہت ہیں، تو آپ صلی ,Sahih (Al-Albani),"Book 2, Hadith 554",,,554
555,ابی بن کعب رضی اللہ عنہ کہتے ہیں کہ  ایک دن رسول اللہ صلی اللہ علیہ وسلم نے ہمیں فجر پڑھائی پھر فرما,Da'if (Al-Albani),"Book 2, Hadith 555",,,555
556,"عثمان بن عفان رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے عشاء جماعت سے",Da'if (Al-Albani),"Book 2, Hadith 556",,,556
557,"ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جو مسجد سے جتنا دور ہو",Sahih (Al-Albani),"Book 2, Hadith 557",,,557
558,ابی بن کعب رضی اللہ عنہ کہتے ہیں  اہل مدینہ میں نمازیوں میں ایک صاحب تھے، میری نظر میں کسی کا مکان م,Sahih (Al-Albani),"Book 2, Hadith 558",,,558
559,"ابوامامہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو اپنے گھر سے وضو کر کے",Sahih (Al-Albani),"Book 2, Hadith 559",,,559
560,"ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  باجماعت نماز  ( کا ",Sahih (Al-Albani),"Book 2, Hadith 560",,,560
561,"بریدہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  اندھیری راتوں میں مسجدوں ",Sahih (Al-Albani),"Book 2, Hadith 561",,,561
562,سعد بن اسحاق کہتے ہیں کہ  مجھ سے ابو ثمامہ حناط نے بیان کیا ہے کہ وہ مسجد جا رہے تھے کہ کعب بن عجرہ ,Sahih (Al-Albani),"Book 2, Hadith 562",,,562
563,"سعید بن مسیب کہتے ہیں  ایک انصاری کی وفات کا وقت قریب ہوا تو انہوں نے کہا: میں تم لوگوں کو ایک حدیث ",Sahih (Al-Albani),"Book 2, Hadith 563",,,563
564,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے وضو کیا اور اچھی ط",Sahih (Al-Albani),"Book 2, Hadith 564",,,564
565,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ کی باندیوں کو اللہ ",Sahih (Al-Albani),"Book 2, Hadith 565",,,565
566,"عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم اللہ کی باندی",Sahih (Al-Albani),"Book 2, Hadith 566",,,566
567,"عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم اپنی عورتوں ک",,"Book 2, Hadith 567",,,567
568,"مجاہد کہتے ہیں: عبداللہ بن عمر رضی اللہ عنہما نے کہا کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا ہے:  ",Sahih (Al-Albani),"Book 2, Hadith 568",,,568
569,ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں  رسول اللہ صلی اللہ علیہ وسلم اگر وہ چیزیں دیکھتے جو عورتیں,Sahih (Al-Albani),"Book 2, Hadith 569",,,569
570,"عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  عورت کی اپنے گھر ",Sahih (Al-Albani),"Book 2, Hadith 570",,,570
571,"عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اگر ہم اس دروازے",,"Book 2, Hadith 571",,,571
572,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  جب نماز کی تک",Sahih (Al-Albani),"Book 2, Hadith 572",,,572
573,"ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  تم نماز کے لیے اس حال ",Da'if (Al-Albani),"Book 2, Hadith 573",,,573
574,ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک شخص کو اکیلے نماز پڑھتے ,Sahih (Al-Albani),"Book 2, Hadith 574",,,574
575,یزید بن الاسودخزاعی رضی اللہ عنہ کہتے ہیں کہ  کہ انہوں نے رسول اللہ صلی اللہ علیہ وسلم کے ساتھ نماز ,Sahih (Al-Albani),"Book 2, Hadith 575",,,575
576,یزید بن اسود خزاعی رضی اللہ عنہ کہتے ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم کے ساتھ صبح کی نماز ,Sahih (Al-Albani),"Book 2, Hadith 576",,,576
577,یزید بن عامر رضی اللہ عنہ کہتے ہیں  میں  ( مسجد )  آیا، نبی اکرم صلی اللہ علیہ وسلم نماز میں تھے، تو,Da'if (Al-Albani),"Book 2, Hadith 577",,,577
578,عفیف بن عمرو بن مسیب کہتے ہیں کہ  مجھ سے قبیلہ بنی اسد بن خزیمہ کے ایک شخص نے بیان کیا کہ انہوں نے ا,Sahih (Al-Albani),"Book 2, Hadith 578",,,578
579,"ام المؤمنین میمونہ رضی اللہ عنہا کے آزاد کردہ غلام سلیمان بن یسار کہتے ہیں  : میں بلاط میں عبداللہ ب",Sahih (Al-Albani),"Book 2, Hadith 579",,,579
580,"عقبہ بن عامر رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  جس نے لوگ",,"Book 2, Hadith 580",,,580
581,خرشہ بن حر فزاری کی بہن سلامہ بنت حر رضی اللہ عنہا کہتی ہیں  میں نے رسول اللہ صلی اللہ علیہ وسلم کو ,,"Book 2, Hadith 581",,,581
582,"ابومسعود بدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  لوگوں کی امامت وہ ش",Sahih (Al-Albani),"Book 2, Hadith 582",,,582
583,"اس سند سے بھی شعبہ سے یہی حدیث مروی ہے  اس میں ہے: «ولا يؤم الرجل الرجل في سلطانه» کوئی شخص کسی کی س",Sahih (Al-Albani),"Book 2, Hadith 583",,,583
584,"ابومسعود رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  اگر لوگ قرأت میں برابر",Sahih (Al-Albani),"Book 2, Hadith 584",,,584
585,عمرو بن سلمہ رضی اللہ عنہ کہتے ہیں  ہم ایسے مقام پر  ( آباد )  تھے جہاں سے لوگ نبی اکرم صلی اللہ علی,Sahih (Al-Albani),"Book 2, Hadith 585",,,585
586,اس سند سے بھی عمرو بن سلمہ رضی اللہ عنہ سے یہ حدیث مروی ہے، اس میں ہے  میں ایک پیوند لگی ہوئی پھٹی چ,Da'if (Al-Albani),"Book 2, Hadith 586",,,586
587,عمرو بن سلمہ رضی اللہ عنہ کے والد سلمہ بن قیس اشجعی رضی اللہ عنہ کہتے ہیں کہ  وہ لوگ ایک وفد میں رسو,Sahih (Al-Albani),"Book 2, Hadith 587",,,587
588,عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کی آمد سے پہلے جب مہاجرین او,Sahih (Al-Albani),"Book 2, Hadith 588",,,588
589,مالک بن حویرث رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے ان سے یا ان کے ایک ساتھی سے ف,Sahih (Al-Albani),"Book 2, Hadith 589",,,589
590,"عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم میں سے وہ لوگ ا",Sahih (Al-Albani),"Book 2, Hadith 590",,,590
591,ام ورقہ بنت عبداللہ بن نوفل انصاریہ رضی اللہ عنہا فرماتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم جب غزوہ,Sahih (Al-Albani),"Book 2, Hadith 591",,,591
592,اس سند سے بھی ام ورقہ بنت عبداللہ بن حارث رضی اللہ عنہا سے یہی حدیث مروی ہے، لیکن پہلی حدیث زیادہ کا,Hasan (Al-Albani),"Book 2, Hadith 592",,,592
593,"عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم فرماتے تھے:  تین آدمیوں کی ",Da'if (Al-Albani),"Book 2, Hadith 593",,,593
594,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  فرض نماز ہر مسلمان کے پی",Sahih (Al-Albani),"Book 2, Hadith 594",,,594
595,انس رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے ابن ام مکتوم رضی اللہ عنہ کو اپنا جانشی,Hasan Sahih (Al-Albani),"Book 2, Hadith 595",,,595
596,بدیل کہتے ہیں کہ ہمارے ایک غلام ابوعطیہ نے ہم سے بیان کیا کہ  مالک بن حویرث رضی اللہ عنہ ہماری اس مس,Sahih (Al-Albani),"Book 2, Hadith 596",,,596
597,ہمام کہتے ہیں کہ  حذیفہ رضی اللہ عنہ نے مدائن  ( کوفہ کے پاس ایک شہر ہے )  میں ایک چبوترہ  ( اونچی ج,Sahih (Al-Albani),"Book 2, Hadith 597",,,597
598,عدی بن ثابت انصاری کہتے ہیں کہ  مجھ سے ایک شخص نے بیان کیا کہ وہ عمار بن یاسر رضی اللہ عنہما کے ساتھ,Sahih (Al-Albani),"Book 2, Hadith 598",,,598
599,جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  معاذ بن جبل رضی اللہ عنہ عشاء کی نماز رسول اللہ صلی اللہ,Sahih (Al-Albani),"Book 2, Hadith 599",,,599
600,جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  معاذ بن جبل رضی اللہ عنہ نبی اکرم صلی اللہ علیہ وسلم کے ,,"Book 2, Hadith 600",,,600
601,انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم گھوڑے پر سوار ہوئے پھر اس سے گر گ,Hasan Sahih (Al-Albani),"Book 2, Hadith 601",,,601
602,جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم مدینہ میں گھوڑے پر سوار ہوئے تو اس نے آپ,Da'if (Al-Albani),"Book 2, Hadith 602",,,602
603,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  امام بنایا ہی اس لیے گیا",,"Book 2, Hadith 603",,,603
604,اس طریق سے بھی  ابوہریرہ رضی اللہ عنہ سے «إنما جعل الإمام ليؤتم به» والی یہی حدیث نبی اکرم صلی اللہ ,Sahih (Al-Albani),"Book 2, Hadith 604",,,604
605,ام المؤمنین عائشہ رضی اللہ عنہا فرماتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے اپنے گھر میں بیٹھ کر ,Hasan (Al-Albani),"Book 2, Hadith 605",,,605
606,جابر رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم بیمار ہوئے تو ہم نے آپ کے پیچھے نماز پڑھی,Da'if (Al-Albani),"Book 2, Hadith 606",,,606
607,اسید بن حضیر رضی اللہ عنہ کہتے ہیں کہ  وہ اپنی قوم کی امامت کرتے تھے، وہ کہتے ہیں کہ ایک بار رسول ال,Sahih (Al-Albani),"Book 2, Hadith 607",,,607
608,انس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ام حرام رضی اللہ عنہا کے پاس آئے تو ان کے,Sahih (Al-Albani),"Book 2, Hadith 608",,,608
609,انس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ان کی اور ان کے گھر کی ایک عورت کی اما,Sahih (Al-Albani),"Book 2, Hadith 609",,,609
610,عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  میں نے اپنی خالہ میمونہ رضی اللہ عنہا کے گھر رات بسر کی ,Sahih (Al-Albani),"Book 2, Hadith 610",,,610
611,اس سند سے ابن عباس رضی اللہ عنہما سے اس واقعہ میں مروی ہے کہ  آپ صلی اللہ علیہ وسلم نے میرا سر یا می,Sahih (Al-Albani),"Book 2, Hadith 611",,,611
612,انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  ان کی دادی ملیکہ رضی اللہ عنہا نے رسول اللہ صلی اللہ علیہ وسلم,Da'if (Al-Albani),"Book 2, Hadith 612",,,612
613,اسود بن یزید نخعی سے روایت ہے کہ  میں نے اور علقمہ بن قیس نخعی نے عبداللہ بن مسعود رضی اللہ عنہ کے پ,Sahih (Al-Albani),"Book 2, Hadith 613",,,613
614,یزید بن اسود رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کے پیچھے نماز پڑھی، جب آپ,Sahih (Al-Albani),"Book 2, Hadith 614",,,614
615,براء بن عازب رضی اللہ عنہما کہتے ہیں کہ  ہم جب رسول اللہ صلی اللہ علیہ وسلم کے پیچھے نماز پڑھتے تو ہ,Da'if (Al-Albani),"Book 2, Hadith 615",,,615
616,"مغیرہ بن شعبہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  امام اس جگہ پر  ( ن",Da'if (Al-Albani),"Book 2, Hadith 616",,,616
617,"عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب امام نماز پو",Sahih (Al-Albani),"Book 2, Hadith 617",,,617
618,"علی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  نماز کی کلید  ( کنجی )  پاکی ",Da'if (Al-Albani),"Book 2, Hadith 618",,,618
619,"معاویہ بن ابی سفیان رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مجھ سے پہلے",Sahih (Al-Albani),"Book 2, Hadith 619",,,619
620,براء رضی اللہ عنہ کا بیان ہے (اور وہ جھوٹے نہ تھے) کہ  لوگ جب رسول اللہ صلی اللہ علیہ وسلم کے ساتھ ا,Sahih (Al-Albani),"Book 2, Hadith 620",,,620
621,براء رضی اللہ عنہ بیان کرتے ہیں کہ  ہم لوگ نبی اکرم صلی اللہ علیہ وسلم کے ساتھ نماز پڑھتے تھے تو ہم ,Sahih (Al-Albani),"Book 2, Hadith 621",,,621
622,براء بن عازب رضی اللہ عنہما کا بیان ہے کہ  لوگ رسول اللہ صلی اللہ علیہ وسلم کے ساتھ نماز پڑھتے تھے ت,Shadh (Al-Albani),"Book 2, Hadith 622",,,622
623,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم میں سے وہ شخص جو اپنا",Da'if (Al-Albani),"Book 2, Hadith 623",,,623
624,انس رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے انہیں  ( یعنی مسلمانوں کو )  نماز کی تر,Sahih (Al-Albani),"Book 2, Hadith 624",,,624
625,ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم سے ایک کپڑے میں نماز پڑھنے کے بارے م,Sahih (Al-Albani),"Book 2, Hadith 625",,,625
626,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم میں سے کوئی شخص ایک ک",,"Book 2, Hadith 626",,,626
627,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں سے کوئی شخص ای",Hasan Sahih (Al-Albani),"Book 2, Hadith 627",,,627
628,عمر بن ابی سلمہ رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو ایک کپڑے میں نماز پ,Sahih (Al-Albani),"Book 2, Hadith 628",,,628
629,طلق رضی اللہ عنہ کہتے ہیں کہ  ہم نبی اکرم صلی اللہ علیہ وسلم کے پاس آئے تو ایک شخص آیا اور اس نے عرض,Sahih (Al-Albani),"Book 2, Hadith 629",,,629
630,سہل بن سعد رضی اللہ عنہ کہتے ہیں کہ  میں نے لوگوں کو دیکھا کہ وہ نماز میں رسول اللہ صلی اللہ علیہ وس,Sahih (Al-Albani),"Book 2, Hadith 630",,,630
631,ام المؤمنین عائشہ رضی اللہ عنہا فرماتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے ایک ایسے کپڑے میں نماز,Sahih (Al-Albani),"Book 2, Hadith 631",,,631
632,"سلمہ بن الاکوع رضی اللہ عنہ کہتے ہیں کہ  میں نے عرض کیا: اللہ کے رسول! میں شکاری ہوں، کیا میں ایک کر",Sahih (Al-Albani),"Book 2, Hadith 632",,,632
633,عبدالرحمٰن بن ابی بکر کہتے ہیں  جابر بن عبداللہ رضی اللہ عنہما نے ایک کرتے میں ہماری امامت کی، ان کے,Sahih (Al-Albani),"Book 2, Hadith 633",,,633
634,عبادہ بن ولید بن عبادہ بن صامت کہتے ہیں کہ  ہم جابر بن عبداللہ رضی اللہ عنہما کے پاس آئے تو انہوں نے,Sahih (Al-Albani),"Book 2, Hadith 634",,,634
635,عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے یا عمر رضی اللہ عنہ نے,Hasan Sahih (Al-Albani),"Book 2, Hadith 635",,,635
636,بریدہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایسے لحاف میں نماز پڑھنے سے منع فرما,Sahih (Al-Albani),"Book 2, Hadith 636",,,636
637,"عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  جو شخ",Sahih (Al-Albani),"Book 2, Hadith 637",,,637
638,ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  ایک آدمی اپنا تہبند ٹخنوں سے نیچے لٹکائے ہوئے نماز پڑھ رہا تھا، ت,Sahih (Al-Albani),"Book 2, Hadith 638",,,638
639,"ام حرام والدہ محمد بن زید سے روایت ہے کہ  انہوں نے ام المؤمنین ام سلمہ رضی اللہ عنہا سے پوچھا: عورت ",Da'if (Al-Albani),"Book 2, Hadith 639",,,639
640,"ام المؤمنین ام سلمہ رضی اللہ عنہا فرماتی ہیں کہ  انہوں نے نبی اکرم صلی اللہ علیہ وسلم سے پوچھا: کیا ",Da'if (Al-Albani),"Book 2, Hadith 640",,,640
641,"ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  بالغہ عورت ک",Sahih (Al-Albani),"Book 2, Hadith 641",,,641
642,محمد بن سیرین کہتے ہیں کہ  ام المؤمنین عائشہ رضی اللہ عنہا طلحہ رضی اللہ عنہ کی والدہ صفیہ رضی اللہ ,Hasan Sahih (Al-Albani),"Book 2, Hadith 642",,,642
643,ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے نماز میں سدل ۱؎ کرنے اور آدمی کو ,Hasan Sahih (Al-Albani),"Book 2, Hadith 643",,,643
644,"ابن جریج کہتے ہیں کہ  میں نے عطاء کو نماز میں اکثر سدل کرتے ہوئے دیکھا ہے۔ ابوداؤد کہتے ہیں: عطاء کا",Da'if (Al-Albani),"Book 2, Hadith 644",,,644
645,ام المؤمنین عائشہ رضی اللہ عنہا فرماتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ہمارے شعار یا لحاف ۱؎ می,Sahih (Al-Albani),"Book 2, Hadith 645",,,645
646,ابوسعید مقبری سے روایت ہے کہ  انہوں نے نبی اکرم صلی اللہ علیہ وسلم کے غلام ابورافع رضی اللہ عنہ کو د,Sahih (Al-Albani),"Book 2, Hadith 646",,,646
647,عبداللہ بن عباس رضی اللہ عنہما کے آزاد کردہ غلام کریب کا بیان ہے کہ  عبداللہ بن عباس نے عبداللہ بن ح,Sahih (Al-Albani),"Book 2, Hadith 647",,,647
648,عبداللہ بن سائب رضی اللہ عنہ کہتے ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم کو فتح مکہ کے دن نماز پ,Sahih (Al-Albani),"Book 2, Hadith 648",,,648
649,عبداللہ بن سائب رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ہمیں مکہ میں صبح کی نماز پ,Hasan (Al-Albani),"Book 2, Hadith 649",,,649
650,ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم صحابہ کرام کے ساتھ نماز پڑھ رہے,Shadh (Al-Albani),"Book 2, Hadith 650",,,650
651,"بکر بن عبداللہ نے  نبی اکرم صلی اللہ علیہ وسلم سے یہی حدیث  ( مرسلاً )  روایت کی ہے، اس میں لفظ: «في",,"Book 2, Hadith 651",,,651
652,"شداد بن اوس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  یہود کی مخالفت کرو، ک",Hasan Sahih (Al-Albani),"Book 2, Hadith 652",,,652
653,عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو دیکھا ہے,,"Book 2, Hadith 653",,,653
654,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں سے کوئی نماز پ",Sahih (Al-Albani),"Book 2, Hadith 654",,,654
655,"ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں سے کوئی نما",Sahih (Al-Albani),"Book 2, Hadith 655",,,655
656,عبداللہ بن شداد رضی اللہ عنہ کہتے ہیں کہ مجھ سے ام المؤمنین میمونہ بنت حارث رضی اللہ عنہا نے بیان کی,Sahih (Al-Albani),"Book 2, Hadith 656",,,656
657,"انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  ایک انصاری نے عرض کیا: اللہ کے رسول! میں بھاری بھر کم آدمی ہوں",Sahih (Al-Albani),"Book 2, Hadith 657",,,657
658,انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم ام سلیم رضی اللہ عنہا کی زیارت کے ,Sahih (Al-Albani),"Book 2, Hadith 658",,,658
659,مغیرہ بن شعبہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم چٹائی اور دباغت دیئے ہوئے چمڑوں,Sahih (Al-Albani),"Book 2, Hadith 659",,,659
660,انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  ہم رسول اللہ صلی اللہ علیہ وسلم کے ساتھ سخت گرمی میں نماز پڑھت,,"Book 2, Hadith 660",,,660
661,"جابر بن سمرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم لوگ اس طرح صف بند",Sahih (Al-Albani),"Book 2, Hadith 661",,,661
662,ابوالقاسم جدلی کہتے ہیں کہ میں نے نعمان بن بشیر رضی اللہ عنہما کو کہتے سنا کہ  رسول اللہ صلی اللہ عل,Da'if (Al-Albani),"Book 2, Hadith 662",,,662
663,نعمان بن بشیر رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم ہماری صفیں درست کیا کرتے تھے، ,Hasan Sahih (Al-Albani),"Book 2, Hadith 663",,,663
664,براء بن عازب رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم صفوں کے اندر ایک طرف سے دوسری ,Da'if (Al-Albani),"Book 2, Hadith 664",,,664
665,نعمان بن بشیر رضی اللہ عنہما کہتے ہیں کہ  جب ہم نماز کے لیے کھڑے ہوتے تو رسول اللہ صلی اللہ علیہ وسل,Da'if (Al-Albani),"Book 2, Hadith 665",,,665
666,عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ   ( قتیبہ کی روایت میں جسے انہوں نے ابوزاہریہ سے، اور ابوز,Sahih (Al-Albani),"Book 2, Hadith 666",,,666
667,"انس بن مالک رضی اللہ عنہ سے روایت ہے کہ  کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم لوگ صفوں میں",,"Book 2, Hadith 667",,,667
668,"انس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم لوگ اپنی صفیں درست رکھو کی",Sahih (Al-Albani),"Book 2, Hadith 668",,,668
669,صاحب مقصورہ محمد بن مسلم بن سائب کہتے ہیں کہ  میں نے ایک روز انس بن مالک رضی اللہ عنہ کے بغل میں نما,Sahih (Al-Albani),"Book 2, Hadith 669",,,669
670,اس سند سے بھی انس رضی اللہ عنہ سے یہی حدیث مروی ہے کہ  رسول اللہ صلی اللہ علیہ وسلم جب نماز کے لیے ک,Sahih (Al-Albani),"Book 2, Hadith 670",,,670
671,"انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  پہلے اگلی صف پوری کرو",Sahih (Al-Albani),"Book 2, Hadith 671",,,671
672,"عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم میں بہترین ل",Sahih (Al-Albani),"Book 2, Hadith 672",,,672
673,عبدالحمید بن محمود کہتے ہیں کہ  میں نے انس بن مالک رضی اللہ عنہ کے ساتھ جمعہ کے دن نماز پڑھی  ( جگہ ,Sahih (Al-Albani),"Book 2, Hadith 673",,,673
674,"ابومسعود رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم میں سے عقلمند اور باش",Sahih (Al-Albani),"Book 2, Hadith 674",,,674
675,عبداللہ بن مسعود رضی اللہ عنہ بھی نبی اکرم صلی اللہ علیہ وسلم سے اسی کے مثل روایت کرتے ہیں  اس میں ا,Munkar (Al-Albani),"Book 2, Hadith 675",,,675
676,"ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  بیشک اللہ تعال",Sahih (Al-Albani),"Book 2, Hadith 676",,,676
677,"عبدالرحمٰن بن غنم کہتے ہیں کہ  ابو مالک اشعری رضی اللہ عنہ نے کہا: کیا میں تم کو رسول اللہ صلی اللہ ",Sahih (Al-Albani),"Book 2, Hadith 677",,,677
678,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مردوں کی سب سے بہتر پہلی",Sahih (Al-Albani),"Book 2, Hadith 678",,,678
679,"ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  لوگ پہلی صف سے",Sahih (Al-Albani),"Book 2, Hadith 679",,,679
680,ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے بعض صحابہ کرام رضی اللہ عنہم,Hasan (Al-Albani),"Book 2, Hadith 680",,,680
681,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  امام کو  ( صف کے )  بیچ ",Sahih (Al-Albani),"Book 2, Hadith 681",,,681
682,وابصہ بن معبد رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک شخص کو صف کے پیچھے اکیلے,Sahih (Al-Albani),"Book 2, Hadith 682",,,682
683,ابوبکرہ رضی اللہ عنہ کا بیان ہے کہ  وہ مسجد میں آئے اور اللہ کے نبی کریم صلی اللہ علیہ وسلم رکوع میں,Sahih (Al-Albani),"Book 2, Hadith 683",,,683
684,ابوبکرہ رضی اللہ عنہ سے روایت ہے کہ  وہ  ( مسجد میں )  آئے اس حال میں کہ رسول اللہ صلی اللہ علیہ وسل,Sahih (Al-Albani),"Book 2, Hadith 684",,,684
685,"طلحہ بن عبیداللہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم نے  ( اونٹ",Sahih (Al-Albani),"Book 2, Hadith 685",,,685
686,عطاء (عطاء بن ابی رباح) کہتے ہیں  کجاوہ کی پچھلی لکڑی ایک ہاتھ کی یا اس سے کچھ بڑی ہوتی ہے۔,Sahih (Al-Albani),"Book 2, Hadith 686",,,686
687,عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم جب عید کے دن نکلتے تو برچھی ,Sahih (Al-Albani),"Book 2, Hadith 687",,,687
688,ابوجحیفہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے انہیں بطحاء میں ظہر اور عصر کی دو ,Sahih (Al-Albani),"Book 2, Hadith 688",,,688
689,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں کوئی شخص نماز ",Sahih (Al-Albani),"Book 2, Hadith 689",,,689
690,ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  ابوالقاسم صلی اللہ علیہ وسلم نے فرمایا، پھر سفیان نے لکیر کھین,Hasan (Al-Albani),"Book 2, Hadith 690",,,690
691,سفیان بن عیینہ کا بیان ہے کہ  میں نے شریک کو دیکھا، انہوں نے ہمارے ساتھ ایک جنازے کے موقع پر عصر پڑھ,Sahih (Al-Albani),"Book 2, Hadith 691",,,691
692,عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم اپنے اونٹ کو قبلہ کی طرف کر ک,Sahih (Al-Albani),"Book 2, Hadith 692",,,692
693,مقداد بن اسود رضی اللہ عنہ کہتے ہیں  میں نے جب بھی رسول اللہ صلی اللہ علیہ وسلم کو کسی لکڑی یا ستون ,Sahih (Al-Albani),"Book 2, Hadith 693",,,693
694,"عبداللہ بن عباس رضی اللہ عنہما کا بیان ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  تم لوگ سوئے ہو",Da'if (Al-Albani),"Book 2, Hadith 694",,,694
695,"سہل بن ابی حثمہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں سے کو",Sahih (Al-Albani),"Book 2, Hadith 695",,,695
696,سہل رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کے کھڑے ہونے کی جگہ اور قبلہ  ( کی دیوار ),Sahih (Al-Albani),"Book 2, Hadith 696",,,696
697,"ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں سے کوئی ش",Sahih (Al-Albani),"Book 2, Hadith 697",,,697
698,"ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں سے کوئی ش",Sahih (Al-Albani),"Book 2, Hadith 698",,,698
699,سلیمان بن عبدالملک کے دربان ابو عبید بیان کرتے ہیں کہ  میں نے عطاء بن زید لیثی کو کھڑے ہو کر نماز پڑ,Munkar (Al-Albani),"Book 2, Hadith 699",,,699
700,ابوصالح کہتے ہیں  میں نے ابو سعید خدری رضی اللہ عنہ کو جو کچھ کرتے ہوئے دیکھا اور سنا، وہ تم سے بیان,Sahih (Al-Albani),"Book 2, Hadith 700",,,700
701,بسر بن سعید کہتے ہیں کہ  زید بن خالد جہنی رضی اللہ عنہ نے انہیں ابوجہیم رضی اللہ عنہ کے پاس یہ پوچھن,Sahih (Al-Albani),"Book 2, Hadith 701",,,701
702,ابوذر رضی اللہ عنہ کہتے ہیں کہ (حفص کی روایت میں ہے)   )  کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا ,Sahih (Al-Albani),"Book 2, Hadith 702",,,702
703,"عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں (شعبہ نے اسے مرفوعاً روایت کیا ہے)  :  نماز حائضہ عورت اور ک",Sahih (Al-Albani),"Book 2, Hadith 703",,,703
704,عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں، عکرمہ کہتے ہیں کہ  میرا گمان ہے کہ وہ اسے رسول اللہ صلی الل,Hasan (Al-Albani),"Book 2, Hadith 704",,,704
705,"یزید بن نمران کہتے ہیں کہ  میں نے تبوک میں ایک اپاہج کو دیکھا، اس نے کہا: میں نبی اکرم صلی اللہ علیہ",Hasan (Al-Albani),"Book 2, Hadith 705",,,705
706,سعید سے اسی سند سے اسی مفہوم کی حدیث مروی ہے، اس میں انہوں نے یہ اضافہ کیا ہے کہ  آپ صلی اللہ علیہ و,Hasan (Al-Albani),"Book 2, Hadith 706",,,706
707,غزوان کہتے ہیں کہ  وہ حج کو جاتے ہوئے تبوک میں اترے، انہیں ایک اپاہج آدمی نظر آیا، انہوں نے اس سے اس,Hasan (Al-Albani),"Book 2, Hadith 707",,,707
708,عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  ہم رسول اللہ صلی اللہ علیہ وسلم کے ساتھ اذاخر ۱,Da'if (Al-Albani),"Book 2, Hadith 708",,,708
709,عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نماز پڑھ رہے تھے کہ ایک بکری,Da'if (Al-Albani),"Book 2, Hadith 709",,,709
710,ام المؤمنین عائشہ رضی اللہ عنہا فرماتی ہیں کہ  میں نبی اکرم صلی اللہ علیہ وسلم کے اور قبلہ کے بیچ می,Sahih (Al-Albani),"Book 2, Hadith 710",,,710
711,ام المؤمنین عائشہ رضی اللہ عنہا فرماتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم اپنی رات کی نماز پڑھتے ا,Sahih (Al-Albani),"Book 2, Hadith 711",,,711
712,ام المؤمنین عائشہ رضی اللہ عنہا فرماتی ہیں کہ  تم لوگوں نے بہت برا کیا کہ ہم عورتوں کو گدھے اور کتے ,Hasan (Al-Albani),"Book 2, Hadith 712",,,712
713,ام المؤمنین عائشہ رضی اللہ عنہا فرماتی ہیں کہ  میں سوئی رہتی تھی، میرے دونوں پاؤں رسول اللہ صلی اللہ,Sahih (Al-Albani),"Book 2, Hadith 713",,,713
714,ام المؤمنین عائشہ رضی اللہ عنہا فرماتی ہیں کہ  میں رسول اللہ صلی اللہ علیہ وسلم کی سمت میں لیٹی رہتی,Sahih (Al-Albani),"Book 2, Hadith 714",,,714
715,عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  میں ایک گدھی پر سوار ہو کر آیا، ان دنوں میں بالغ ہونے کے,Sahih (Al-Albani),"Book 2, Hadith 715",,,715
716,ابوصہباء کہتے ہیں کہ  ہم نے ابن عباس رضی اللہ عنہما کے پاس ان چیزوں کا تذکرہ کیا جو نماز کو توڑ دیتی,Da'if (Al-Albani),"Book 2, Hadith 716",,,716
717,"منصور سے یہی حدیث اس سند سے بھی مروی ہے، اس میں یہ ہے کہ  ابن عباس رضی اللہ عنہما نے کہا: بنی عبدالم",Sahih (Al-Albani),"Book 2, Hadith 717",,,717
718,فضل بن عباس رضی اللہ عنہما کہتے ہیں کہ  ہم ایک صحرا میں تھے کہ رسول اللہ صلی اللہ علیہ وسلم ہمارے پا,Hasan (Al-Albani),"Book 2, Hadith 718",,,718
719,"ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  نماز کو کوئی چیز نہ",Hasan (Al-Albani),"Book 2, Hadith 719",,,719
720,ابوالوداک کہتے ہیں کہ  ابو سعید خدری رضی اللہ عنہ نماز پڑھ رہے تھے کہ قریش کا ایک نوجوان ان کے سامنے,Sahih (Al-Albani),"Book 2, Hadith 720",,,720
721,عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں  میں نے رسول اللہ صلی اللہ علیہ وسلم کو دیکھا، جب آپ نماز شرو,Hasan (Al-Albani),"Book 2, Hadith 721",,,721
722,عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم جب نماز کے لیے کھڑے ہوتے تو ,Da'if (Al-Albani),"Book 2, Hadith 722",,,722
723,وائل بن حجر رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کے ساتھ نماز پڑھی، جب آپ ن,Sahih (Al-Albani),"Book 2, Hadith 723",,,723
724,وائل بن حجر رضی اللہ عنہ کہتے ہیں کہ  انہوں نے نبی اکرم صلی اللہ علیہ وسلم کو دیکھا، جب آپ نماز کے ل,Hasan (Al-Albani),"Book 2, Hadith 724",,,724
725,"عبدالجبار بن وائل کہتے ہیں: مجھ سے میرے گھر والوں نے بیان کیا کہ میرے والد نے ان سے بیان کیا کہ  انہ",Sahih (Al-Albani),"Book 2, Hadith 725",,,725
726,"وائل بن حجر رضی اللہ عنہ کہتے ہیں کہ  میں نے کہا: میں ضرور رسول اللہ صلی اللہ علیہ وسلم کی نماز دیکھ",Sahih (Al-Albani),"Book 2, Hadith 726",,,726
727,عاصم بن کلیب نے اس سند سے بھی اسی مفہوم کی حدیث روایت کی ہے، اس میں یہ ہے کہ  پھر آپ صلی اللہ علیہ و,Sahih (Al-Albani),"Book 2, Hadith 727",,,727
728,میں نے نبی اکرم صلی اللہ علیہ وسلم کو دیکھا جس وقت آپ نے نماز شروع کی اپنے دونوں ہاتھوں کو کانوں کے ,Sahih (Al-Albani),"Book 2, Hadith 728",,,728
729,وائل بن حجر رضی اللہ عنہ کہتے ہیں  میں سردی کے موسم میں نبی اکرم صلی اللہ علیہ وسلم کے پاس آیا تو می,Sahih (Al-Albani),"Book 2, Hadith 729",,,729
730,عبدالحمید بن جعفر کہتے ہیں کہ مجھے محمد بن عمرو بن عطاء نے خبر دی ہے کہ  میں نے ابو حمید ساعدی رضی ا,Sahih (Al-Albani),"Book 2, Hadith 730",,,730
731,صحابہ کرام رضی اللہ عنہم کی ایک مجلس میں تھا، ان لوگوں نے آپس میں رسول اللہ صلی اللہ علیہ وسلم کی نم,Da'if (Al-Albani),"Book 2, Hadith 731",,,731
732,اس سند سے بھی محمد بن عمرو بن عطاء سے اسی طرح مروی ہے، اس میں ہے  جب آپ سجدہ کرتے تو اپنے دونوں ہاتھ,Sahih (Al-Albani),"Book 2, Hadith 732",,,732
733,عباس بن سہل ساعدی یا عیاش بن سہل ساعدی کہتے ہیں کہ  وہ ایک مجلس میں تھے، جس میں ان کے والد بھی تھے ا,Sahih (Al-Albani),"Book 2, Hadith 733",,,733
734,عباس بن سہل بیان کرتے ہیں کہ  ابوحمید، ابواسید، سہل بن سعد اور محمد بن مسلمہ رضی اللہ عنہم اکٹھے ہوئ,Sahih (Al-Albani),"Book 2, Hadith 734",,,734
735,اس طریق سے بھی ابوحمید رضی اللہ عنہ سے یہی حدیث مروی ہے، اس میں ہے  جب آپ صلی اللہ علیہ وسلم نے سجدہ,Sahih (Al-Albani),"Book 2, Hadith 735",,,735
736,اس طریق سے بھی ابوحمید رضی اللہ عنہ سے یہی حدیث مروی ہے، اس میں ہے  جب آپ صلی اللہ علیہ وسلم نے سجدہ,Sahih (Al-Albani),"Book 2, Hadith 736",,,736
737,وائل بن حجر رضی اللہ عنہ نے نبی اکرم صلی اللہ علیہ وسلم سے یہی حدیث روایت کی ہے اس میں ہے  جب آپ صلی,Sahih (Al-Albani),"Book 2, Hadith 737",,,737
738,میں نے رسول اللہ صلی اللہ علیہ وسلم کو دیکھا کہ آپ نماز میں اپنے دونوں انگوٹھے اپنے دونوں کانوں کی ل,,"Book 2, Hadith 738",,,738
739,ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم جب نماز کے لیے تکبیر تحریمہ کہتے تو ,,"Book 2, Hadith 739",,,739
740,نضر بن کثیر بیان کرتے ہیں کہ  عبداللہ بن طاؤس نے مسجد خیف میں میرے بغل میں نماز پڑھی، جب آپ نے پہلا ,Sahih (Al-Albani),"Book 2, Hadith 740",,,740
741,عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  وہ جب نماز میں داخل ہوتے تو «الله اكبر» کہتے، اور جب ر,Sahih (Al-Albani),"Book 2, Hadith 741",,,741
742,نافع کہتے ہیں کہ  عبداللہ بن عمر رضی اللہ عنہما جب نماز شروع کرتے تو اپنے دونوں ہاتھ دونوں کندھوں کے,Sahih (Al-Albani),"Book 2, Hadith 742",,,742
743,عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم جب دو رکعتیں پڑھ کر  ( تیسری,Sahih (Al-Albani),"Book 2, Hadith 743",,,743
744,علی بن ابی طالب رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم جب فرض نماز کے لیے کھڑے ہو,Sahih (Al-Albani),"Book 2, Hadith 744",,,744
745,مالک بن حویرث رضی اللہ عنہ کہتے ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم کو دیکھا آپ اپنے دونوں ہا,Sahih (Al-Albani),"Book 2, Hadith 745",,,745
746,"بشیر بن نہیک کہتے ہیں کہ  ابوہریرہ رضی اللہ عنہ نے کہا: اگر میں نبی اکرم صلی اللہ علیہ وسلم کے آگے ہ",Sahih (Al-Albani),"Book 2, Hadith 746",,,746
747,عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ہمیں نماز سکھائی تو آپ نے,Sahih (Al-Albani),"Book 2, Hadith 747",,,747
748,"علقمہ سے روایت ہے کہ  عبداللہ بن مسعود رضی اللہ عنہ نے کہا: کیا میں تمہیں رسول اللہ صلی اللہ علیہ وس",Sahih (Al-Albani),"Book 2, Hadith 748",,,748
749,براء رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم جب نماز شروع کرتے تو اپنے دونوں ہاتھ ,Sahih (Al-Albani),"Book 2, Hadith 749",,,749
750,اس طریق سے بھی یزید سے شریک ہی کی حدیث کی طرح حدیث مروی ہے  اس میں انہوں نے «ثم لا يعود»  ( پھر ایسا,Da'if (Al-Albani),"Book 2, Hadith 750",,,750
751,اس طریق سے بھی سفیان سے یہی حدیث گذشتہ سند سے مروی ہے، اس میں ہے کہ  آپ نے اپنے دونوں ہاتھوں کو پہلی,Sahih (Al-Albani),"Book 2, Hadith 751",,,751
