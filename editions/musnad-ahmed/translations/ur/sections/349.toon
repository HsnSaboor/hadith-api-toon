hadiths[2]{hadithnumber,text}:
16756,أتۏڬأرتحًىأظذتثۏۄأشعۏأتههۄأؼىۄتأضەأوشًۏأۄەأڬۄأتۏڬأوشحثۄأىثۏأوۏشەأۏۄتڽأحطشۏلأهتةەأحًأوۏڽأثتةۏڽأۄتحہأضەأڬہتىتأڬہتأشۄۏأحہۏأ؏أوۏڽأتۏڬأحىڲزضحأؼًشحأحہۏأ؏أىثۏأ﷽أىەأوۏشەأۄتحہأځشأوتشتأدضأضەأهموۄأڲشأڲۏتأتًشألشوتۏتأدثأتههۄأىەأحوۄتشتأزتۄىتأۄتحہأثىتۏتأۄەأحًأثتةۏڽأۄتحہأضەأوحأڬہتاأ؏أډىتىډۄأوۏڽأىەأزتةۏڽأۄتحہأضەأڬہتىتأطشًؼأڬشأزۏتأ؏أتًشأتضأڬەأثؼزأڬثہۏأثہۏأثتةۏڽأۄتحہأضەأىۄۏڽأڬہتۏتأۗ
16767,"أتۏڬأرتحًىأ+أدىۄۏڽأزًىًڽأمثهًڽأڬۏأغشلأىوتصأځڔہىەأڬتأطشلأذتظهأۄەأ,أڬۄحۏأۄۏڽأڬۄأتۏڬأوشحثۄأىثۏأ﷽أوۏشەأۏۄتڽأحطشۏلأهتةەأتًشأودہأضەألشوتۏتأوۄىزۏأهڲتۏتأڬشًأ؏أحوأهًڲأوۄىزۏأهڲتىتأډہًڔأزۏحۏأۄًأتًشأحوۄتشەأۄتحہأوشزًڽأڬەأۄتحہأڬۏأغشذأۄًأدتحەأۄۏڽأ؏أوۏڽأىەأتضأڬەأثؼزأضەأوۄىزۏأهڲتىتأڬثہۏأىۄۏڽأډہًڔۏأ؏أتًشأوۏڽأتۏضتأۄۏأڬشًڽأڲۏأحتإىڬۄأتههۄأضەأدتأوهًڽأ؏أشتًۏأڬۄحەأۄۏڽأڬۄأًۄأتضۏأضتهأڬۏأؼوشأوۏڽأثہۏأوۄىزۏأهڲتۏتأڬشحۏأحہۏڽأۗ"
