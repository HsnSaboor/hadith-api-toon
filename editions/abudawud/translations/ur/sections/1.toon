{"hadithnumber": "106", "text": "عثمان بن عفان رضی اللہ عنہ کے غلام حمران بن ابان کہتے ہیں کہ  میں نے عثمان بن عفان رضی اللہ عنہ کو د"}
{"hadithnumber": "107", "text": "حمران کہتے ہیں کہ  میں نے عثمان بن عفان رضی اللہ عنہ کو وضو کرتے دیکھا، پھر اس حدیث کے ہم معنی حدیث"}
{"hadithnumber": "108", "text": "عثمان بن عبدالرحمٰن تیمی کہتے ہیں کہ  ابن ابی ملیکہ سے وضو کے متعلق پوچھا گیا، تو انہوں نے کہا: میں"}
{"hadithnumber": "109", "text": "ابوعلقمہ کہتے ہیں کہ  عثمان رضی اللہ عنہ نے پانی منگوایا اور وضو کیا، پہلے داہنے ہاتھ سے بائیں ہاتھ"}
{"hadithnumber": "110", "text": "ابووائل شقیق بن سلمہ کہتے ہیں کہ  میں نے عثمان بن عفان رضی اللہ عنہ کو دیکھا کہ انہوں نے وضو میں اپن"}
{"hadithnumber": "111", "text": "عبد خیر کہتے ہیں کہ  علی رضی اللہ عنہ ہمارے پاس آئے آپ نماز پڑھ چکے تھے، پانی منگوایا، ہم لوگوں نے"}
{"hadithnumber": "112", "text": "عبد خیر کہتے ہیں کہ  علی رضی اللہ عنہ نے صبح کی نماز پڑھی پھر رحبہ  ( کوفہ میں ایک جگہ کا نام ہے )"}
{"hadithnumber": "113", "text": "عبد خیر کہتے ہیں کہ  میں نے علی رضی اللہ عنہ کو دیکھا  ( ان کے پاس )  ایک کرسی لائی گئی، وہ اس پر بی"}
{"hadithnumber": "114", "text": "زر بن حبیش کہتے ہیں کہ  انہوں نے علی رضی اللہ عنہ سے سنا جب ان سے رسول اللہ صلی اللہ علیہ وسلم کے وض"}
{"hadithnumber": "115", "text": "عبدالرحمٰن بن ابی لیلیٰ کہتے ہیں کہ  میں نے علی رضی اللہ عنہ کو دیکھا کہ آپ نے وضو کیا تو اپنا چہرہ"}
{"hadithnumber": "116", "text": "ابوحیہ (ابن قیس) کہتے ہیں کہ  میں نے علی رضی اللہ عنہ کو دیکھا کہ آپ نے وضو کیا، پھر ابوحیہ نے آپ کے"}
{"hadithnumber": "117", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  علی بن ابی طالب رضی اللہ عنہ استنجاء کر کے میرے پاس آئے،"}
{"hadithnumber": "118", "text": "یحییٰ مازنی کہتے ہیں کہ  انہوں نے عبداللہ بن زید بن عاصم  ( جو عمرو بن یحییٰ مازنی کے نانا ہیں )  سے"}
