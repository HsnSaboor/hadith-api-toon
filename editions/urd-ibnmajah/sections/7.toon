hadiths[145]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
1638,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  انسان کی ہر نیکی دس گنا ",,,,,1638
1639,قبیلہ عامر بن صعصعہ کے مطرف نامی ایک فرد بیان کرتے ہیں کہ  عثمان بن ابی العاص ثقفی رضی اللہ عنہ نے ا,,,,,1639
1640,"سہل بن سعد رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جنت میں ایک دروازہ ہے ج",,,,,1640
1641,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے ایمان کے ساتھ اور ",,,,,1641
1642,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب رمضان کی پہلی رات ہوت",,,,,1642
1643,"جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ تعالیٰ ہر افطار کے وقت ",,,,,1643
1644,"انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رمضان آیا تو رسول کرام صلی اللہ علیہ وسلم نے فرمایا:  یہ مہین",,,,,1644
1645,صلہ بن زفر کہتے ہیں کہ  ہم شک والے دن میں عمار بن یاسر رضی اللہ عنہما کے پاس تھے ان کے پاس ایک بھنی ,,,,,1645
1646,ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے چاند دیکھنے سے ایک روز پہلے روزہ ,,,,,1646
1647,معاویہ بن ابی سفیان رضی اللہ عنہما منبر پر کہہ رہے تھے کہ  رسول اللہ صلی اللہ علیہ وسلم رمضان سے پہل,,,,,1647
