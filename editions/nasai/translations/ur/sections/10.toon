{"hadithnumber": "852", "text": "عبداللہ بن ام مکتوم رضی اللہ عنہ سے روایت ہے کہ  انہوں نے عرض کیا: اللہ کے رسول! مدینہ میں کیڑے مکوڑ"}
{"hadithnumber": "853", "text": "عروہ روایت کرتے ہیں کہ  عبداللہ بن ارقم رضی اللہ عنہ اپنے لوگوں کی امامت کرتے تھے، ایک دن نماز کا وق"}
{"hadithnumber": "854", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب شام کا کھانا حاضر ہو، اور"}
{"hadithnumber": "855", "text": "اسامہ بن عمیر رضی اللہ عنہ کہتے ہیں کہ  ہم رسول اللہ صلی اللہ علیہ وسلم کے ساتھ حنین میں تھے کہ ہم پ"}
{"hadithnumber": "856", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے اچھی طرح وضو کیا،"}
{"hadithnumber": "857", "text": "عثمان بن عفان رضی اللہ عنہم کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  جس نے ن"}
{"hadithnumber": "858", "text": "محجن رضی اللہ عنہ سے روایت ہے کہ  وہ ایک مجلس میں رسول اللہ صلی اللہ علیہ وسلم کے ساتھ تھے کہ مؤذن ن"}
{"hadithnumber": "859", "text": "یزید بن اسود عامری رضی اللہ عنہ کہتے ہیں کہ  میں مسجد خیف میں رسول اللہ صلی اللہ علیہ وسلم کے ساتھ ف"}
{"hadithnumber": "860", "text": "ابوذر رضی اللہ عنہ کہتے ہیں کہ  رسول اکرم صلی اللہ علیہ وسلم نے میری ران پہ ہاتھ مار کر مجھ سے فرمای"}
{"hadithnumber": "861", "text": "ام المؤمنین میمونہ رضی اللہ عنہا کے آزاد کردہ غلام سلیمان کہتے ہیں کہ  میں نے ابن عمر رضی اللہ عنہم"}
{"hadithnumber": "862", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم نماز کے لیے آؤ تو"}
{"hadithnumber": "863", "text": "ابورافع رضی اللہ عنہ کہتے ہیں کہ  جب رسول اللہ صلی اللہ علیہ وسلم عصر کی نماز پڑھ چکتے تو بنی عبدالا"}
{"hadithnumber": "864", "text": "اس سند سے بھی  ابورافع رضی اللہ عنہ سے اسی جیسی حدیث مروی ہے۔"}
{"hadithnumber": "865", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اول وقت میں نماز کے لیے"}
{"hadithnumber": "866", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب نماز کے لیے اقامت کہہ"}
{"hadithnumber": "867", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جب نماز کے لیے اقامت کہہ"}
{"hadithnumber": "868", "text": "ابن بحینہ (عبداللہ بن مالک ازدی) رضی اللہ عنہ کہتے ہیں کہ  نماز فجر کے لیے اقامت کہی گئی تو رسول الل"}
{"hadithnumber": "869", "text": "عبداللہ بن سرجس رضی اللہ عنہ کہتے ہیں کہ  ایک شخص آیا، اور رسول اللہ صلی اللہ علیہ وسلم فجر کی نماز"}
{"hadithnumber": "870", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ہمارے گھر آئے تو میں نے اور ایک یتیم نے آ"}
{"hadithnumber": "871", "text": "عبداللہ بن عباس رضی اللہ عنہم کہتے ہیں کہ  ایک عورت رسول اللہ صلی اللہ علیہ وسلم کے پیچھے نماز پڑھتی"}
{"hadithnumber": "872", "text": "ابوبکرہ رضی اللہ عنہ کہتے ہیں کہ  وہ مسجد میں داخل ہوئے، نبی اکرم صلی اللہ علیہ وسلم رکوع میں تھے، ت"}
{"hadithnumber": "873", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  ایک دن رسول اللہ صلی اللہ علیہ وسلم نے نماز پڑھائی، پھر سلام پھیر"}
{"hadithnumber": "874", "text": "عبداللہ بن عمر رضی اللہ عنہم سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم ظہر سے پہلے دو رکعت سنت پڑ"}
{"hadithnumber": "875", "text": "عاصم بن ضمرہ کہتے ہیں کہ  ہم نے علی رضی اللہ عنہ سے رسول اللہ صلی اللہ علیہ وسلم کی نماز کے متعلق سو"}
