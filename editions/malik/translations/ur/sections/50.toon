{"hadithnumber": "1711", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ، کہتے ہیں کہ رسول اللہ ﷺ نے فرمایا :’’ جس کے ساتھ اللہ تعالی"}
{"hadithnumber": "1712", "text": "یحیی بن سعید رحمہ اللہ سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ کے زمانے میں ایک آدمی کو موت آ گئی تو ایک آ"}
{"hadithnumber": "1713", "text": "حضرت عثمان بن ابی العاص رضی اللہ عنہ سے روایت ہے کہ بلاشبہ وہ رسول اللہ ﷺ کے پاس آئے ، حضرت عثمان رض"}
{"hadithnumber": "1714", "text": "سیدہ عائشہ رضی اللہ عنہا سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ جب بیمار ہوتے تو اپنے آپ پر معوذات سورتیں"}
{"hadithnumber": "1715", "text": "عمرہ بنت عبدالرحمن رحمۃ اللہ علیہ سے روایت ہے کہ بیشک حضرت ابوبکر صدیق رضی اللہ عنہ سیدہ عائشہ رضی ا"}
{"hadithnumber": "1716", "text": "زید بن اسلم رضی اللہ عنہ سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ کے زمانے میں ایک آدمی کو کوئی زخم پہنچا ا"}
{"hadithnumber": "1717", "text": "یحیی بن سعید رحمہ اللہ سے روایت ہے ، کہتے ہیں : مجھے یہ خبر پہنچی کہ بلاشبہ حضرت اسعد بن زرارہ رضی ا"}
{"hadithnumber": "1718", "text": "نافع رحمہ اللہ سے روایت ہے کہ بے شک حضرت عبداللہ بن عمر رضی اللہ عنہما نے لقوے کی وجہ سے داغ لگوایا"}
{"hadithnumber": "1719", "text": "فاطمہ بنت منذر سے روایت ہے کہ بے شک ( ان کی دادی جان ) حضرت اسماء بنت ابی بکر صدیق رضی اللہ عنہما کے"}
{"hadithnumber": "1720", "text": "ہشام بن عروہ رحمہ اللہ اپنے والد ( عروہ بن زبیر رضی اللہ عنہ ) سے روایت کرتے ہیں کہ بلاشبہ رسول اللہ"}
{"hadithnumber": "1721", "text": "حضرت ابن عمر رضی اللہ عنہما سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ نے فرمایا :’’ بخار جہنم کے جوش ( بھاپ"}
{"hadithnumber": "1722", "text": "حضرت جابر بن عبداللہ رضی اللہ عنہما سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ نے فرمایا :’’ جب آدمی مریض کی"}
{"hadithnumber": "1723", "text": "( عبداللہ ) ابن عطیہ رضی اللہ عنہ سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ نے فرمایا :’’ نہ عَدْویٰ ( کوئی"}
{"hadithnumber": "1724", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ نے مونچھوں کے مونڈنے اور داڑھیو"}
{"hadithnumber": "1725", "text": "حمید بن عبدالرحمن بن عوف رحمہ اللہ سے روایت ہے ، انھوں نے ( امیرالمومنین ) حضرت معاویہ بن ابی سفیان"}
{"hadithnumber": "1726", "text": "زیاد بن سعد رحمہ اللہ سے روایت ہے ، انھوں نے ابن شہاب رحمہ اللہ کو سنا ، وہ ایک آدمی سے کہہ رہے تھے"}
{"hadithnumber": "1727", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ وہ خصّی کرنے کو ناپسند کرتے تھے اور کہتے تھے : اس"}
{"hadithnumber": "1728", "text": "صفوان بن سلیم رحمہ اللہ کو یہ خبر پہنچی کہ بے شک نبی کریم ﷺ نے فرمایا :’’ میں اور یتیم کی کفالت کرنے"}
{"hadithnumber": "1729", "text": "یحیی بن سعید رحمہ اللہ سے روایت ہے کہ بے شک حضرت ابوقتادہ رضی اللہ عنہ نے رسول اللہ ﷺ سے عرض کیا : ب"}
