{"hadithnumber": "4581", "text": "ابومنہال کہتے ہیں کہ  میں نے بیع صرف کے بارے میں براء بن عازب رضی اللہ عنہما سے پوچھا، تو انہوں نے ک"}
{"hadithnumber": "4582", "text": "ابوبکرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے چاندی کے بدلے چاندی اور سونے کے بد"}
{"hadithnumber": "4583", "text": "ابوبکرہ رضی اللہ عنہ کہتے ہیں کہ  ہمیں رسول اللہ صلی اللہ علیہ وسلم نے منع فرمایا کہ ہم چاندی کے بدل"}
{"hadithnumber": "4584", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  مجھ سے اسامہ بن زید رضی اللہ عنہما نے بیان کیا کہ رسول ا"}
{"hadithnumber": "4585", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  میں نے ابن عباس رضی اللہ عنہما سے کہا: آپ جو یہ باتیں کہتے ہ"}
{"hadithnumber": "4586", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  میں بقیع میں اونٹ بیچتا، چنانچہ میں دینار سے بیچتا تھا او"}
{"hadithnumber": "4587", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  میں چاندی کے بدلے سونا یا سونے کے بدلے چاندی بیچتا تھا۔ م"}
{"hadithnumber": "4588", "text": "سعید بن جبیر سے روایت ہے کہ  وہ اس چیز کو ناپسند کرتے تھے کہ وہ درہم ٹھیرا کر دینار اور دینار ٹھیرا"}
{"hadithnumber": "4589", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  وہ اس میں کوئی حرج نہیں سمجھتے تھے یعنی دینار طے کر کے"}
{"hadithnumber": "4590", "text": "ابراہیم نخعی سے روایت ہے کہ  درہم طے کر کے کر دینار لینے کو وہ ناپسند کرتے تھے جب وہ قرض کے طور پر ہ"}
{"hadithnumber": "4591", "text": "سعید بن جبیر سے روایت ہے کہ  وہ اس میں کوئی حرج نہیں سمجھتے تھے خواہ قرض کے طور پر ہو۔"}
{"hadithnumber": "4592", "text": "اس سند سے بھی  سعید بن جبیر سے اسی طرح مروی ہے۔ ابوعبدالرحمٰن نسائی کہتے ہیں: میں نے اس مقام میں اسے"}
{"hadithnumber": "4593", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم کے پاس آ کر عرض کیا: ٹ"}
{"hadithnumber": "4594", "text": "جابر رضی اللہ عنہ کہتے ہیں کہ  جب نبی اکرم صلی اللہ علیہ وسلم مدینہ آئے تو آپ نے ترازو منگا کر اس سے"}
{"hadithnumber": "4595", "text": "جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے میرا قرض دیا اور مجھے مزید دیا۔"}
{"hadithnumber": "4596", "text": "سوید بن قیس رضی اللہ عنہ کہتے ہیں کہ  میں اور مخرفہ عبدی رضی اللہ عنہ مقام ہجر سے کپڑا لائے، ہم منیٰ"}
{"hadithnumber": "4597", "text": "ابوصفوان رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم سے ہجرت سے قبل پاجامے بیچے تو"}
{"hadithnumber": "4598", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ” «مکیال»  ( ناپن"}
{"hadithnumber": "4599", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے غلہ خریدا"}
