hadiths[23]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
2862,"عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  کسی مسلمان کے",,,,,2862
2863,ام المؤمنین عائشہ رضی اللہ عنہا فرماتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے  ( اپنی وفات کے وقت ),,,,,2863
2864,"سعد بن ابی وقاص رضی اللہ عنہ کہتے ہیں کہ  وہ بیمار ہوئے  ( ابن ابی خلف کی روایت میں ہے: مکہ میں، آگے",,,,,2864
2865,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  ایک شخص نے نبی اکرم صلی اللہ علیہ وسلم سے عرض کیا: کون سا صدقہ اف",,,,,2865
2866,"ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  آدمی کا اپنی زندگی ",,,,,2866
2867,"ابوہریرہ رضی اللہ عنہ کا بیان ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مرد اور عورت دونوں ساٹ",,,,,2867
2868,"ابوذر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مجھ سے فرمایا:  اے ابوذر! میں تمہیں ",,,,,2868
2869,"عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  آیت کریمہ: «إن ترك خيرا الوصية للوالدين والأقربين»  اگر ",,,,,2869
2870,"ابوامامہ رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا ہے:  کہ ال",,,,,2870
2871,"عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں  جب اللہ عزوجل نے آیت کریمہ: «ولا تقربوا مال اليتيم إلا بالت",,,,,2871
2872,عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  ایک شخص نبی اکرم صلی اللہ علیہ وسلم کے پاس آیا ,,,,,2872
2873,علی بن ابی طالب رضی اللہ عنہ کہتے ہیں  میں نے رسول اللہ صلی اللہ علیہ وسلم سے یہ بات سن کر یاد رکھی ,,,,,2873
2874,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  سات تباہ و برباد کر دینے",,,,,2874
2875,عمیر بن قتادۃ لیثی رضی اللہ عنہ (جنہیں شرف صحبت حاصل ہے) کہ  ایک شخص نے رسول اللہ صلی اللہ علیہ وسلم,,,,,2875
2876,خباب رضی اللہ عنہ کہتے ہیں کہ  مصعب بن عمیر رضی اللہ عنہ احد کے دن قتل کر دیے گئے، اور ان کے پاس ایک,,,,,2876
2877,"بریدہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے پاس ایک عورت نے آ کر کہا: میں نے اپن",,,,,2877
2878,عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  عمر رضی اللہ عنہ کو خیبر میں ایک زمین ملی، وہ نبی اکرم صل,,,,,2878
2879,یحییٰ بن سعید سے عمر بن خطاب رضی اللہ عنہ کے صدقہ کے متعلق روایت ہے، وہ کہتے ہیں کہ  عبدالحمید بن عب,,,,,2879
2880,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب انسان مر جاتا ہے تو ا",,,,,2880
2881,"ام المؤمنین عائشہ رضی اللہ عنہا فرماتی ہیں کہ  ایک عورت نے رسول اللہ صلی اللہ علیہ وسلم سے عرض کیا: ",,,,,2881
2882,عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  ایک شخص  ( سعد بن عبادہ رضی اللہ عنہ )  نے رسول اللہ صلی,,,,,2882
2883,عبداللہ بن عمرو بن العاص رضی اللہ عنہما سے روایت ہے کہ  عبداللہ بن عمرو بن العاص رضی اللہ عنہما سے ر,,,,,2883
2884,جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  ان کے والد انتقال کر گئے اور اپنے ذمہ ایک یہودی کا تیس و,,,,,2884
