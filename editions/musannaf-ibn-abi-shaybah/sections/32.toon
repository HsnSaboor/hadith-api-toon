hadiths[537]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}: 34549,حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أُنْزِلَ عَلَیْہِ الْقُرْآنُ وَہُوَ ابْنُ ثَلاثٍ وَأَرْبَعِینَ سَنَۃً ، وَأَقَامَ بِمَکَّۃَ عَشْرَ سِنِینَ وَبِالْمَدِینَۃِ عَشْرَ سِنِینَ ، وَتُوفِّیَ وَہُوَ ابْنُ ثَلاثٍ وَسِتِّینَ سَنَۃً۔ (ابن سعد 191),,,34549 34550,"حدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَامِرِ بْنِ سَعْدٍ ، عَنْ جَرِیرٍ ؛ أَنَّہُ سَمِعَ مُعَاوِیَۃَ یَخْطُبُ ، قَالَ : مَاتَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ ابْنُ ثَلاَثٍ وَسِتِّینَ سَنَۃً ، وَأَبُو بَکْرٍ وَعُمَرُ وَأَنَا ابْنُ ثَلاَثٍ وَسِتِّینَ۔ (مسلم 1827۔ احمد 96)",,,34550 34551,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ ہِشَامٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : أُنْزِلَ عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ ابْنُ أَرْبَعِینَ سَنَۃً ، ثُمَّ مَکَثَ بِمَکَّۃَ ثَلاَثَ عَشْرَۃَ سَنَۃً ، وَکَانَ بِالْمَدِینَۃِ عَشْراً ، فَقُبِضَ وَہُوَ ابْنُ ثَلاَثٍ وَسِتِّینَ۔ (بخاری 3851۔ ترمذی 3621)",,,34551 34552,"حَدَّثَنَا إِسْمَاعِیلَ ، عَنِ خَالِدٍ ، عَنِ عَمَّارٍ مَوْلَی بَنِی ہَاشِمٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : تُوُفِّیَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ ابْنُ خَمْسٍ وَسِتِّینَ۔ (مسلم 1827۔ ترمذی 3650)",,,34552 34553,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ خَالِدٍ ، عَنِ عَمَّارٍ مَوْلَی بَنِی ہَاشِمٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بُعِثَ وَہو ابْنُ أَرْبَعِینَ سَنَۃً ، وَأَقَامَا بِمَکَّۃَ خَمْسَ عَشْرَۃَ سَنَۃً ، وَبِالْمَدِینَۃِ عَشْرَاً ، فَقُبِضَ وَہُوَ ابْنُ خَمْسٍ وَسِتِّینَ۔,,,34553 34554,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : أُنْزِلَ عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ ابْنُ أَرْبَعِینَ ، فَمَکَثَ بِمَکَّۃَ عَشَرِ سِنِینَ ، وَبِالْمَدِینَۃِ عَشَرِ سِنِینَ۔",,,34554 34555,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، قَالَ : أَسْلَمَ الزُّبَیْرُ ، وَہُوَ ابْنُ سِتَّۃَ عَشْرَ سَنَۃً ، وَلَمْ یَتَخَلَّفْ عَنْ غَزْوَۃٍ غَزَاہَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَقُتِلَ وَہُوَ ابْنُ بِضْعٍ وَسِتِّینَ۔",,,34555 34556,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، قَالَ : حَدَّثَنَا شَرِیکٍ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : مَاتَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَأَبُو بَکْرٍ وَعُمَرُ وَعَلی أَبْنَائَ ثَلاَثٍ وَسِتِّینَ سَنَۃً ، وَعُثْمَانُ وَہُوَ ابْنُ نَیِّفٍ وَسَبْعِینَ۔\n\n(ابن ابی عاصم 166)",,,34556 34557,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی بِشْرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : جَمَعْتُ الْمُحْکَمَ عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : قُلْتُ لَہُ : وَمَا الْمُحْکَمَ ؟ قَالَ : الْمُفَصَّلَ۔ وزاد غَیْرُ ہُشْیَمٍ : وَقُبِضَ وَأَنَا ابْنُ عَشْرٍ۔",,,34557 34558,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ أَنَسٍ قَالَ : قدِمَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْمَدِینَۃَ وَأَنَا ابْنُ عَشْرٍ ، وَتُوُفِّیَ وَأَنَا ابْنُ عِشْرِینَ۔ (بخاری 5166۔ مسلم 1603)",,,34558 34559,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُوسَی بْنِ عُلَیٍّ ، عَنْ أَبِیہِ ، قَالَ : سَمِعْتُ مَسْلَمَۃَ بْنَ مُخَلَّدٍ ، قَالَ : وُلِدْتُ حِینَ قَدِمَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْمَدِینَۃَ ، وَقُبِضَ وَأَنَا ابْنُ عَشْرٍ۔ (طبرانی 1060)",,,34559 34560,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سِنَانُ بْنُ سَلَمَۃَ الْہُذَلِیُّ ، عَنْ أَبِیہِ ؛ أَنْ جَدَّہ سِنَانِ بْنِ سَلَمَۃَ وُلِدَ یَوْمَ حُنَیْنٍ، قَالَ : فَدَعَا بِہِ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَتَفَلَ فِی فِیہِ ، وَمَسَحَ عَلَی وَجْہِہِ ، وَدَعَا لَہُ بِالْبَرَکَۃِ۔",,,34560 34561,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہُشَیْمٍ ، عَنْ عَلِیِّ بْنِ زَیْدٍ ، عَنْ سَالِمٍ ؛ أَنَّ عُمَرَ تُوُفِّیَ وَہُوَ ابْنُ خَمْسٍ وَخَمْسِینَ۔,,,34561 34562,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ سَعِیدٍ، عَنْ قَتَادَۃَ، عَنْ سَالِمِ بْنِ أَبِی الْجَعْدِ، عَنْ مَعْدَانَ بْنِ أَبِی طَلْحَۃَ الْیَعْمُرِیِّ، قَالَ : أُصِیبَ عُمَرُ رَحِمَہُ اللَّہُ یَوْمَ الأَرْبِعَائِ ، لأَرْبَعٍ بَقِینَ مِنْ ذِی الْحِجَّۃ۔",,,34562 34563,"حَدَّثَنَا أَبُو أُسَامَۃَ، حَدَّثَنَا ہِشَامٌ، قَالَ: أَخْبَرَنِی أَبِی، قَالَ: أَسْلَمَ أَبُو بَکْرٍ یَوْمَ أَسْلَمَ وَلَہُ أَرْبَعُونَ أَلْفَ دِرْہَمٍ۔",,,34563 34564,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عَنْ عَائِشَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ تَزَوَّجَہَا وَہِیَ بِنْتُ تِسْعٍ ، وَمَاتَ عَنْہَا وَہِیَ بِنْتُ ثَمَانَ عَشْرَۃَ۔,,,34564 34565,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا شَرِیکٌ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : سَمِعْتُ عَمْرَو بْنَ حُرَیْثٍ یَقُولُ : کُنْتُ فِی بَطْنِ الْمَرْأَۃِ یَوْمَ بَدْرٍ۔",,,34565 34566,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إِدْرِیسَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : عُرِضْتُ عَلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَوْمَ أُحُدٍ وَأَنَا ابْنُ أَرْبَعَ عَشْرَۃَ فَاسْتَصْغَرَنِی ، وَعُرِضْتُ عَلَیْہِ یَوْمَ الْخَنْدَقِ وَأَنَا ابْنُ خَمْسَ عَشْرَۃَ فَأَجَازَنِی۔",,,34566 34567,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إِدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنْ ہِلاَلِ بْنِ یَِسَافٍ ، قَالَ : أَسْلَمَ عُمَرُ بْنُ الْخَطَّابِ بَعْدَ أَرْبَعِینَ رَجُلاً وَإِحْدَی عَشْرَۃَ امْرَأَۃً۔",,,34567 34568,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ أَبِی حَمْزَۃَ الأَنْصَارِیِّ ، عَنْ زَیْدِ بْنِ أَرْقَمَ ، قَالَ : أَوَّلُ مَنْ أَسْلَمَ مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَلِیٌّ ، قَالَ : فَذُکِرَ ذَلکَ لإِبْرَاہِیم فَأَنْکَرَ ذَلِکَ ، وَقَالَ : أَبُو بَکْرٍ۔",,,34568 34569,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ أَبِی مَالِکٍ الأَشْجَعِیِّ ، عَنْ سَالِمٍ ، قَالَ : قُلْتُ لاِبْنِ الْحَنَفِیَّۃِ : أَبُو بَکْرٍ کَانَ أَوَّلُ الْقَوْمِ إِسْلاَمًا ؟ قَالَ : لاَ۔",,,34569 34570,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، قَالَ : أَوَّلُ مَنْ أَظْہَرَ الإِسْلاَمَ سَبْعَۃٌ : رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَأَبُو بَکْرٍ ، وَبِلاَلٌ ، وَخَبَّابٌ ، وَصُہَیْبٌ ، وَعَمَّارٌ ، وَسُمَیَّۃُ أُمُّ عَمَّارٍ ، فَأَمَّا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَمَنَعَہُ عَمُّہُ ، وَأَمَّا أَبُو بَکْرٍ فَمَنَعَہُ قَوْمُہُ ، وَأُخِذَ الآخَرُونَ فَأُلْبِسُوا أَدْرَاعَ الْحَدِیدِ ، وَصَہَرُوہُمْ فِی الشَّمْسِ حَتَّی بَلَغَ الْجَہْدُ مِنْہُمْ کُلَّ مَبْلَغٍ ، فَأَعْطَوْہُمْ مَا سَأَلُوا ، فَجَائَ إِلَی کُلِّ رَجُلٍ مِنْہُمْ قَوْمَہُ بِأَنْطَاعِ الأَدَمِ فِیہَا الْمَائُ ، فَأَلْقَوْہُمْ فِیہَا ، ثُمَّ حَمَلُوہُ بِجَوَانِبِہِ ، إِلاَّ بِلاَلاً ، فَلَمَّا کَانَ الْعَشِیُّ جَائَ أَبُو جَہْلٍ ، فَجَعَلَ یَشْتُمُ سُمَیَّۃَ وَیَرْفُثُ ، ثُمَّ طَعَنَہَا فِی قُبُلِہَا ، فَہِیَ أَوَّلُ شَہِیدٍ اُسْتُشْہِدَ فِی الإِسْلاَمِ ، إِلاَّ بِلاَلا، فَإِنَّہُ ہَانَتْ عَلَیْہِ نَفْسُہُ فِی اللہِ حَتَّی مَلُّوا فَجَعَلُوا فِی عُنُقِہِ حَبْلاً ، ثُمَّ أَمَرُوا صِبْیَانَہُمْ ، فَاشْتَدُّوا بِہِ بَیْنَ أَخْشَبَیْ مَکَّۃَ ، وَجَعَلَ یَقُولُ : أَحَدٌ أَحَدٌ۔",,,34570 34571,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنِ الشَّعْبِیِّ ، قَالَ : أَعْطَوْہُمْ مَا سَأَلُوا ، إِلاَّ خَبَّابًا ، فَجَعَلُوا یُلَزِّقُونَ ظَہْرَہُ بِالرَّضْفِ حَتَّی ذَہَبَ مَائَ مَتْنَیہِ۔",,,34571 34572,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ مِسْعَرٍ ، عَنْ قَیْسِ بْنِ مُسْلِمٍ ، عَنْ طَارِقِ بْنِ شِہَابٍ ، قَالَ : کَانَ خَبَّابٌ مِنَ الْمُہَاجِرِینَ ، وَکَانَ مِمَنْ یُعَذَّبُ فِی اللہِ۔",,,34572 34573,"حَدَّثَنَا مُحَمَّدُ بْنُ فَضَیْلٍ ، عَنْ أَبِیہِ ، قَالَ : سَمِعْتُ کُرْدُوسًا یَقُولُ ، أَلاَ إِنَّ خَبَّابَ بْنَ الأَرَتِّ أَسْلَمَ سَادِسَ سِتَّۃٍ ، کَانَ لَہُ سُدُسُ الإِسْلاَمِ۔",,,34573 34574,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ مُطَرِّفٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْبَرَائِ ، قَالَ : عُرِضْتُ أَنَا ، وَابْنُ عُمَرَ عَلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَوْمَ بَدْرٍ فَاسْتَصْغَرَنَا ، وَشَہِدْنَا یَوْمَ أُحُدٍ۔",,,34574 34575,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ عَاصِمٍ ، قَالَ : سَأَلَ صُبَیْحٌ أَبَا عُثْمَانَ : رَأَیْتَ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ؟ فَقَالَ: أَسْلَمْتُ عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَأَدَّیْت إِلَیْہِ ثَلاَثَ صَدَقَاتٍ، وَلَمْ أَلْقَہُ۔ (ابن سعد 97)",,,34575 34576,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ ہِلاَلِ بْنِ خَبَّابٍ ، عَنْ مَیْسَرَۃَ أَبِی صَالِحٍ ، عَنْ سُوَیْد بْنِ غَفَلَۃَ ، قَالَ : أَتَانَا مُصَدِّقُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,34576 34577,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ قَیْسِ بْنِ مُسْلِمٍ ، عَنْ طَارِقِ بْنِ شِہَابٍ ، قَالَ : رَأَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَغَزَوْت فِی خِلاَفَۃِ أَبِی بَکْرٍ وَعُمَرَ ثَلاَثًا وَثَلاَثِینَ ، أَوْ ثَلاَثًا وَأَرْبَعِینَ ، مَا بَیْنَ غَزْوَۃٍ إِلَی سَرِیَّۃٍ۔ (احمد 314۔ طبرانی 8205)",,,34577 34578,"حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنْ حَبَّۃَ الْعُرَنِیِّ ، قَالَ سَمِعْتُ عَلِیًّا ، یَقُولُ : أَنَا أَوَّلُ مَنْ صَلَّی مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,34578 34579,"أَخْبَرَنَا حُسَیْنُ بْنُ مُحَمَّدٍ التَّمِیمِیُّ ، حَدَّثَنَا جَرِیرُ بْنُ حَازِمٍ ، عَنْ مُجَالِدٍ ، عَنْ عَامِرٍ ، قَالَ : قَالَ أَبُو بَکْرٍ لِعَلِیٍّ : أَکَرِہْتَ إِمَارَتِی ؟ قَالَ : لاَ ، قَالَ أَبُو بَکْرٍ : إِنِّی کُنْتُ فِی ہَذَا الأَمْرِ قَبْلَک۔",,,34579 34580,"حَدَّثَنَا غُنْدَرٌ، عَنْ شُعْبَۃَ، عَنْ عَمْرِو بْنِ مُرَّۃَ، قَالَ: سَمِعْتُ ابْنَ أَبِی أَوْفَی، وَکَانَ مِنْ أَصْحَابِ الشَّجَرَۃِ۔",,,34580 34581,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عُبَیْدَۃَ ، حَدَّثَنَا أَبِی ، عَنِ الأَعْمَشِ ، عَنِ الْقَاسِمِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِیہِ ، قَالَ: قَالَ عَبْدُ اللہِ : لَقَدْ رَأَیْتُنِی سَادِسَ سِتَّۃٍ ، مَا عَلَی الأَرْضِ مُسْلِمٌ غَیْرُنَا۔",,,34581 34582,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنِ ابْنِ لَہِیعَۃَ ، قَالَ : حدَّثَنِی یَزِیدُ بْنُ عَمْرٍو الْمَعَافِرِیُّ ، قَالَ : سَمِعْتُ أَبَا ثَوْرٍ الْفَہْمِیَّ ، یَقُولُ : قَدِمَ عَلَیْنَا عَبْدُ الرَّحْمَنِ بْنُ عُدَیْسٍ الْبَلَوِیُّ ، وَکَانَ مِمَّنْ بَایَعَ تَحْتَ الشَّجَرَۃِ ، فَصَعِدَ الْمِنْبَرَ فَحَمِدَ اللَّہَ ، وَأَثْنَی عَلَیْہِ ، ثُمَّ ذَکَرَ عُثْمَانَ ۔ قَالَ أَبُو ثَوْرٍ : فَدَخَلْنَا عَلَی عُثْمَانَ وَہُوَ مَحْصُورٌ ، فَقَالَ : إِنِّی لَرَابِعُ الإِسْلاَمِ۔",,,34582 34583,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، حَدَّثَنَا زُہَیْرٌ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی جُحَیْفَۃَ ، قَالَ : رَأَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہَذِہِ مِنْہُ بَیْضَائُ ، وَوَضَعَ زُہَیْرٌ یَدَہُ عَلَی عُنْفَقَتِہِ ، قِیلَ لأَبِی جُحَیْفَۃَ : مِثْلُ مَنْ أَنْتَ یَوْمَئِذٍ ؟ قَالَ : أُبْرِی النَّبْلَ وَأَرِیشُہَا۔",,,34583 34584,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، حَدَّثَنَا زُہَیْرٌ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : تَمَارَی عَبْدُ اللہِ بْنُ عُتْبَۃَ وَرَجُلٌ مِنْ ہَمْدَانَ ، فَقَالَ الْہَمْدَانِیُّ : أَبُو بَکْرٍ أَکْبَرُ مِنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَقَالَ عَبْدُ اللہِ : لاَ ، بَلْ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَکْبَرُ مِنْ أَبِی بَکْرٍ ، تُوُفِّیَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ ابْنُ ثَلاَثٍ وَسِتِّینَ ، وَتُوُفِّیَ أَبُو بَکْرٍ وَہُوَ ابْنُ ثَلاَثٍ وسِتِّینَ ، فَقَالَ عَامِرُ بْنُ سَعْدٍ الْبَجَلِیُّ : أَنَا أَقْضِی بَیْنَکُمَا ، حَدَّثَنِی جَریرُ بْنُ عَبْدِ اللہِ ؛ أَنَّہُ کَانَ عِنْدَ مُعَاوِیَۃَ ، فَقَالَ : تُوُفِّیَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ ابْنُ ثَلاَثٍ وَسِتِّینَ ، وَتُوُفِّیَ أَبُو بَکْرٍ وَہُوَ ابْنُ ثَلاَثٍ وسِتِّینَ ، وَقُتِلَ عُمَرُ وَہُوَ ابْنُ ثَلاَثٍ وَسِتِّینَ ، وَأَنَا ابْنُ سَبْعٍ وَخَمْسِینَ۔ (مسلم 1827)",,,34584 34585,"حَدَّثَنَا شَیْخٌ لَنَا ، قَالَ : سَمِعْتُ جَعْفَرًا ، یُحَدِّثُ عَنْ أَبِیہِ ، قَالَ : أَسْلَمَ عَلِیٌّ وَہُوَ ابْنُ سَبْعٍ ، وَقُبِضَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ ابْنُ سَبْعٍ وَعِشْرِینَ ، وَقُتِلَ عَلِیٌّ وَہُوَ ابْنُ سَبْعٍ وَخَمْسِینَ۔",,,34585 34586,"حَدَّثَنَا شَیْخٌ لَنَا ، قَالَ : حدَّثَنَا مُجَالِدٌ ، عَنْ عَامِرٍ ، قَالَ : سَأَلْتُ ابْنَ عَبَّاسٍ ، أَوْ سُئِلَ ابْنُ عَبَّاسٍ : أَیُّ النَّاسِ کَانَ أَوَّلَ إسْلاَمًا ؟ فَقَالَ : أَمَا سَمِعْتَ قَوْلَ حَسَّانِ بْنِ ثَابِتٍ :\n\nإِذَا تَذَکَّرْت شَجْوًا مِنْ أَخِی ثِقَۃٍ\n\nخَیْرَ الْبَرِّیَّۃِ أَتْقَاہَا وَأَعْدَلَہَا\n\nوَالثَّانِیَ التَّالِیَ الْمَحْمُودَ مَشْہَدُہُ\n\n\n\nفَاذْکُرْ أَخَاک أَبَا بَکْرٍ بِمَا فَعَلاَ\n\nإِلا النَّبِیُّ وَأَوْفَاہَا بِمَا حَمَلاَ\n\nوَأَوَّلَ النَّاسِ مِنْہُمْ صَدَّقَ الرُّسُلاَ\n\n(حاکم 64۔ ابن عساکر 39)",,,34586 34587,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، قَالَ سَمِعْتُ ابْنَ أَبِی لَیْلَی یُحَدِّثُ ، عَنْ عَبْدِ اللہِ بْنِ عُکَیْمٍ ، قَالَ : قُرِئَ عَلَیْنَا کِتَابُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَأَنَا غُلاَمٌ شَابٌّ : لاَ تَنْتَفِعُوا مِنَ الْمَیْتَۃِ بِإِہَابٍ ، وَلاَ عَصَبٍ۔",,,34587 34588,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ أَشْعَثَ ، عَنْ عَوْنِ بْنِ أَبِی جُحَیْفَۃَ ، عَنْ أَبِیہِ ، قَالَ : بَعَثَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِینَا مُصَدِّقًا ، فَأَخَذَ الصَّدَقَۃَ مِنْ أَغْنِیَائِنَا ، فَرَدَّہَا فِی فُقَرَائِنَا ، فَکُنْتُ غُلاَمًا یَتِیمًا لاَ مَالَ لِی ، فَأَعْطَانِی قَلُوصًا۔",,,34588 34589,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا ہِشَامٌ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أُنْزِلَ عَلَیْہِ وَہُوَ ابْنُ أَرْبَعِینَ سَنَۃً ، فَأَقَامَ بِمَکَّۃَ ثَلاَثَ عَشْرَۃَ سَنَۃً ، وَأَقَامَ بِالْمَدِینَۃِ عَشْرَ سِنِینَ ، فَتُوُفِّیَ وَہُوَ ابْنُ ثَلاَثٍ وَسِتِّینَ۔",,,34589 34590,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی نَعَامَۃَ ، سَمِعَہُ مِنْ خَالِدِ بْنِ عُمَیْرٍ ، قَالَ : خَطَبَنَا عُتْبَۃُ بْنُ غَزْوَانَ ، فَقَالَ : لَقَدْ رَأَیْتُنِی سَابِعَ سَبْعَۃٍ مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔ (مسلم 2278۔ ابن ماجہ 4156)",,,34590 34591,"حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ ، حَدَّثَنَا سُلَیْمَانُ بْنُ بِلاَلٍ ، قَالَ : حدَّثَنِی رَبِیعَۃُ بْنُ أَبِی عَبْدِ الرَّحْمَنِ ، قَالَ : سَمِعْتُ أَنَسَ بْنِ مَالِکٍ ، یَقُولُ : بُعِثَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَلَی رَأْسِ أَرْبَعِینَ ، فَأَقَامَ بِمَکَّۃَ عَشْرًا ، وَبِالْمَدِینَۃِ عَشْرًا ، وَتُوُفِّیَ عَلَی رَأْسِ سِتِّینَ سَنَۃً۔ (مسلم 1825۔ احمد 240)",,,34591 34592,"حَدَّثَنَا مُحَمَّدُ بْنُ عُبَیْدٍ ، حَدَّثَنَا إِسْمَاعِیلُ بْنُ أَبِی خَالِدٍ ، قَالَ : رَأَیْتُ زِرَّ بْنَ حُبَیْشٍ وَقَدْ أَتَی عَلَیْہِ عِشْرُونَ وَمِئَۃُ سَنَۃٍ ، وَإِنَّ لِحْیَیْہِ لَیَضْطَرِبَانِ مِنَ الْکِبَرِ ، وَرَأَیْتُ أَبَا عَمْرٍو الشَّیْبَانِیَّ ، وَقَدْ أَتَی عَلَیْہِ تِسْعَ عَشْرَۃَ وَمِئَۃُ سَنَۃٍ۔",,,34592 34593,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ إِسْمَاعِیلَ ، قَالَ : رَأَیْتُ زِرَّ بْنَ حُبَیْشٍ فِی الْمَسْجِدِ ، تَخْتَلِجُ لَحْیَاہُ مِنَ الْکِبَرِ، وَہُوَ یَقُولُ : أَنَا ابْنُ عِشْرِینَ وَمِئَۃِ سَنَۃٍ۔",,,34593 34594,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، قَالَ : قَالَ لِی شَقِیقُ بْنُ سَلَمَۃَ : یَا سُلَیْمَانُ ، لَوْ رَأَیْتُنِی وَنَحْنُ ہُرَّابٌ مِنْ خَالِدِ بْنِ الْوَلِیدِ یَوْمَ بُزَاخَۃَ ، فَوَقَعْتُ عَنِ الْبَعِیرِ ، فَکَادَتْ تَنْدَقُّ عُنُقِی ، فَلَوْ مِتَّ یَوْمَئِذٍ کَانَتِ النَّارُ۔",,,34594 34595,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، قَالَ : سَمِعْتُ شَقِیقًا یَقُولُ : کُنْتُ یَوْمَئِذٍ ابْنَ إِحْدَی عَشْرَۃَ سَنَۃً۔",,,34595 34596,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ أَبِی خَلْدَۃَ ، عَنْ أَبِی الْعَالِیَۃِ ، سَمِعَ عُمَرَ یَقُولُ : اللَّہُمَّ عَافِنَا وَاعْفُ عَنَّا۔",,,34596 34597,"حَدَّثَنَا حَفْصٌ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، قَالَ : لَمْ یَکُنْ بَیْنَ الْحَسَنِ وَالْحُسَیْنِ إِلاَّ طُہْرٌ۔",,,34597 34598,"حَدَّثَنَا الْحَسَنُ بْنُ مُوسَی الأَشْیَبُ ، عَنْ أَبِی ہِلاَلٍ ، عَنْ قَتَادَۃَ ، قَالَ : آخِرُہُمْ مَوْتًا بِالْمَدِینَۃِ جَابِرُ بْنُ عَبْدِ اللہِ ، وَآخِرُہُمْ مَوْتًا بِالْبَصْرَۃِ أَنَسُ بْنُ مَالِکَ ، وَآخِرُہُمْ مَوْتًا بِالْکُوفَۃِ عَبْدُ اللہِ بْنُ أَبِی أَوْفَی۔",,,34598 34599,حَدَّثَنَا الْحَسَنُ بْنُ مُوسَی ، عَنْ أَبِی ہِلاَلٍ ، عَنْ قَتَادَۃَ ، أَنَّ أَبَا بَکْرٍ تُوُفِّیَ وَہُوَ ابْنُ خَمْسٍ وَسِتِّینَ سَنَۃً ، وَأَنَّ عُمَرَ قُتِلَ وَہُوَ ابْنُ إِحْدَی وَخَمْسِینَ ، وَأَنَّ عُثْمَانَ قُتِلَ وَہُوَ ابْنُ تِسْعٍ ، أَوْ ثَمَانٍ وَثَمَانِینَ۔,,,34599 34600,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ الْقَطَّانُ ، عَنْ سُفْیَانَ ، عَنِ الأَعْمَشِ ، عَنْ عُمَارَۃَ بْنِ عُمَیْرٍ ، عَنْ حُرَیْثِ بْنِ ظُہَیْرٍ ، قَالَ : لَمَّا نُعِیَ عَبْدُ اللہِ إِلی أَبِی الدَّرْدَائِ ، قَالَ : مَا خَلَّفَ بَعْدَہُ مِثْلُہُ۔",,,34600 34601,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی حَمْزَۃَ ، قَالَ : تُوُفِّیَ ابْنُ عَبَّاسٍ فَوَلِیَہُ ابْنُ الْحَنَفِیَّۃِ۔",,,34601 34602,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سَالِمِ بْنِ أَبِی حَفْصَۃَ ، عَنْ رَجُلٍ یُقَالَ لَہُ : أَبُو کُلْثُومٍ ، قَالَ : سَمِعْتُ ابْنَ الْحَنَفِیَّۃِ یَقُولُ فِی جِنَازَۃِ ابْنِ عَبَّاسٍ : الْیَوْمُ مَاتَ رَبَّانِیُّ الْعِلْمِ۔",,,34602 34603,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عَمَّارٍ مَوْلَی بَنِی ہَاشِمٍ ، قَالَ : جَلَسْنَا مَعَ ابْنِ عَبَّاسٍ فِی ظِلِّ الْقَصْرِ ، فِی جِنَازَۃِ زَیْدِ بْنِ ثَابِتٍ ، قَالَ : لَقَدْ دُفِنَ الْیَوْمَ عِلْمٌ کَثِیرٌ۔",,,34603 34604,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ شُعْبَۃَ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، قَالَ : مَرُّوا بِجِنَازَۃِ أَبِی عَبْدِ الرَّحْمَنِ عَلَی أَبِی جُحَیْفَۃَ ، فَقَالَ : اسْتَرَاحَ وَاسْتُرِیحَ مِنْہُ۔",,,34604 34605,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ ابْنِ أَبْجَرَ ، قَالَ : أَخْبَرْتُ الشَّعْبِیَّ بِمَوْتِ إِبْرَاہِیمَ ، فَقَالَ : رَحِمَہُ اللَّہُ ، أَمَا إِنَّہُ لَمْ یُخُلَّفْ خَلْفَہُ مِثْلُہُ ، أَمَا إِنَّہُ مَیِّتًا أَفْقَہُ مِنْہُ حَیًّا۔",,,34605 34606,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَاصِمٍ ، قَالَ : أَخْبَرْتُ الْحَسَنَ بِمَوْتِ الشَّعْبِیِّ ، فَقَالَ : رَحِمَہُ اللَّہُ ، وَاللہِ إِنْ کَانَ مِنَ الإِسْلاَمِ لَبِمَکَانٍ۔",,,34606 34607,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ نَافِعٍ ، قَالَ : کَانَ ابْنُ عُمَرَ فِی السُّوقِ ، فَنُعِیَ إِلَیْہِ حُجْر ، فَأَطْلَقَ حُبْوَتَہُ وَقَامَ ، وَغَلَبَہُ النَّحِیبُ۔",,,34607 34608,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ شُعْبَۃَ ، عَنْ عَلِیِّ بْنِ زَیْدٍ ، عَنْ أَبِی عُثْمَانَ ، قَالَ : أَتَیْتُ عُمَرَ بِنَعْیِ النُّعْمَانِ بْنِ مُقَرِّنٍ ، فَوَضَعَ یَدَہُ عَلَی رَأْسِہِ ، وَجَعَلَ یَبْکِی۔",,,34608 34609,"حَدَّثَنَا شَیْخٌ لَنَا ، قَالَ : أَخْبَرَنَا الأَعْمَشُ ، قَالَ : ہَلَکَ إِبْرَاہِیمُ وَہُوَ ابْنُ ، ثَمَانٍ وَأَرْبَعِینَ ، قَالَ الأَعْمَشُ: وَہَلَکَ سَعِیدُ بْنُ جُبَیْرٍ وَہُوَ ابْنُ سِتٍّ وَأَرْبَعِینَ۔",,,34609 34610,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ إِیَاسِ بْنِ مُعَاوِیَۃَ ، قَالَ : جَلَسْتُ إِلَی سَعِیدِ بْنِ الْمُسَیَّبِ ، فَقَالَ لِی : مِمَّنْ أَنْتَ ؟ قُلْتُ : مِنْ مُزَیْنَۃَ ، قَالَ : إِنِّی لأَذْکُرُ یَوْمَ نَعْیِ عُمَرَ بْنِ الْخَطَّابِ النُّعْمَانَ عَلَی الْمِنْبَرِ۔",,,34610 34611,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا مَالِکُ بْنُ أَنَسٍ ، عَنْ سَالِمٍ أَبِی النَّضْرِ ، قَالَ : لَمَّا تُوُفِّیَ سَعْدٌ ، أَمَرْت عَائِشَۃَ أَنْ یَمُرَّ بِہِ عَلَیْہَا ، فَتَسْتَغْفِرُ لَہُ۔",,,34611 34612,"حَدَّثَنَا یَزِیدُ بْنَ ہَارُونَ ، عَنْ ہَمَّامٍ ، عَنْ قَتَادَۃَ ، عَنْ أَبِی الْعَالِیَۃِ ، قَالَ : قرَأْتُ الْقُرْآنَ بَعْدَ وَفَاۃِ نَبِیِّکُمْ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِعِشْرِینَ سَنَۃً۔",,,34612 34613,"حَدَّثَنَا أَسْوَدُ بْنُ عَامِرٍ ، حَدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ عَلِیِّ بْنِ زَیْدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : لَقَدْ بَلَغْتُ ثَمَانِینَ سَنَۃً وَأَنَا أَخْوَفُ مَا أَخَافُ عَلَیَّ النِّسَائُ۔",,,34613 34614,"حَدَّثَنَا عَفَّانُ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ، عَنْ حُمَیْدٍ، قَالَ: قَالَ أَبُو عُثْمَانَ: أَتَتْ عَلَیَّ نَحْوٌ مِنْ ثَلاَثِینَ وَمِئَۃِ سَنَۃٍ۔",,,34614 34615,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا الْحَجَّاجُ بْنُ أَبِی زَیْنَبَ ، قَالَ : سَمِعْتُ أَبَا عُثْمَانَ النَّہْدِیَّ ، یَقُولُ : کُنَّا فِی الْجَاہِلِیَّۃِ نَعْبُدُ حَجَرًا ، فَسَمِعْنَا مُنَادِیًا یُنَادِی : یَا أَہْلَ الرِّحَالِ ، إِنَّ رَبَّکُمْ قَدْ ہَلَکَ فَالْتَمِسُوا رَبًّا ، قَالَ : فَخَرَجْنَا عَلَی کُلِّ صَعْبٍ وَذَلُولٍ ، فَبَیْنَا نَحْنُ کَذَلِکَ نَطْلُبُ إِذَا نَحْنُ بِمُنَادٍ یُنَادِی : إِنَّا قَدْ وَجَدْنَا رَبَّکُمْ ، أَوْ شَبَہَہُ ، قَالَ : فَجِئْنَا ، فَإِذَا حَجَرٌ ، فَنَحَرْنَا عَلَیْہِ الْحُمُرَ۔",,,34615 34616,حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ إِسْمَاعِیلَ ، عَنْ شُبَیْلِ بْنِ عَوْفٍ ، وَکَانَ أَدْرَکَ الْجَاہِلِیَّۃَ۔,,,34616 34617,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی رَجَائٍ ، قَالَ : قُلْتُ لِلْحَسَنِ الْبَصْرِیِّ : مَتَی عَہْدُک بِالْمَدِینَۃِ ؟ قَالَ : مَا لِی بِہَا عَہْدٌ بَعْدَ صِفِّینَ ، قَالَ : قُلْتُ : فَمَتَی احْتَلَمْتَ ؟ قَالَ : بَعْدَ صِفِّینَ بِعَامٍ۔",,,34617 34618,"حَدَّثَنَا الْحَسَنُ بْنُ مُوسَی ، حَدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ عَلِیِّ بْنِ زَیْدٍ ، عَنْ یُوسُفَ بْنِ مِہْرَانَ ، عَنِ ابْنِ عَبَّاسٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : کَانَ عُمْرُ آدَمَ أَلْفَ سَنَۃٍ ، وَکَانَ عُمْرُ دَاوُد سِتِّینَ سَنَۃً ، فَقَالَ آدَم : أَیْ رَبِّ ، زِدْہُ مِنْ عُمْرِی أَرْبَعِینَ سَنَۃً ، فَأَکْمَلَ لآدَمَ أَلْفَ سَنَۃٍ ، وَأَکْمَلَ لِدَاوُدَ مِئَۃَ سَنَۃٍ۔\n\n(احمد 251۔ ابن سعد 28)",,,34618 34619,"حَدَّثَنَا الْحَسَنُ بْنُ مُوسَی ، حَدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ عَلِیِّ بْنِ زَیْدٍ ، عَنْ یُوسُفَ بْنِ مِہْرَانَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : بُعِثَ نُوحٌ لأَرْبَعِینَ سَنَۃً ، وَلَبِثَ فِی قَوْمِہِ أَلْفَ سَنَۃٍ إِلاَّ خَمْسِینَ عَامًا یَدْعُوہُمْ ، وَعَاشَ بَعْدَ الطُّوفَانِ سِتِّینَ سَنَۃً ، حَتَّی کَثُرَ النَّاسُ وَفَشَوْا۔ (حاکم 545)",,,34619 34620,حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ أَبِی ہُرَیْرَۃَ ؛ أَنَّ إِبْرَاہِیمَ اخْتَتَنَ بِالْقَدُّومِ ، وَہُوَ ابْنُ عِشْرِینَ وَمِئَۃِ سَنَۃٍ ، وَعَاشَ بَعْدَ ذَلِکَ ثَمَانِینَ سَنَۃٍ۔,,,34620 34621,"حدَّثَنَا إِسْمَاعِیلُ بْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : أُلْقِیَ یُوسُفُ فِی الْجُبِّ وَہُوَ ابْنُ سَبْعَ عَشْرَۃَ سَنَۃً ، وَکَانَ فِی الْعُبُودِیَّۃِ وَالْمِلْکِ وَالسِّجْنِ ، ثَمَانِینَ سَنَۃً ، ثُمَّ جُمِعَ لَہُ شَمْلُہُ ، فَعَاشَ بَعْدَ ذَلِکَ ثَلاَثًا وَعِشْرِینَ سَنَۃً۔",,,34621 34622,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ أَبِی رَزِینٍ ، قَالَ : قِیلَ لِلْعَبَّاسِ : أَنْتَ أَکْبَرُ ، أَمَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ فَقَالَ : ہُوَ أَکْبَرُ مِنِّی ، وَأَنَا وُلِدْتُ قَبْلَہُ۔",,,34622 34623,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ أَبِیہِ ، قَالَ : قِیلَ لأَبِی وَائِلٍ : أَنْتَ أَکْبَرُ ، أَوْ رَبِیعُ بْنُ خُثَیْمٍ ؟ قَالَ : أَنَا أَکْبَرُ مِنْہُ سِنًّا ، وَہُوَ أَکْبَرُ مِنِّی عَقْلاً۔",,,34623 34624,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ یَحْیَی بْن سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : اسْتَکْمَلَ أَبُو بَکْرٍ بِخِلاَفَتِہِ سِنَّ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَتُوُفِّیَ وَہُوَ ابْنُ ثَلاَثٍ وَسِتِّینَ۔",,,34624 34625,"حَدَّثَنَا غُنْدَرٌ ، حَدَّثَنَا شُعْبَۃُ ، عَنْ عَمْرِو بْنِ مُرَّۃ ، قَالَ : سَأَلْتُ أَبَا عُبَیْدَۃَ : ہَلْ تَذْکُرُ مِنْ عَبْدِ اللہِ شَیْئًا؟ قَالَ : لاَ أَذْکُرُ مِنْہُ شَیْئًا۔",,,34625 34626,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ شُعَیْبِ بْنِ الْحَبْحَابِ ، عَنِ الْحَسَنِ ، قَالَ : رَأَیْتُ عُثْمَانَ یُصَبُّ عَلَیْہِ مِنْ إِبْرِیقٍ۔",,,34626 34627,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ أَبِیہِ ، وَمَالِکِ بْنِ مِغْوَلٍ ، عَنِ الْحَکَمِ ، قَالَ : کَانَ أَوَّلُ مَنْ قَضَی بِالْکُوفَۃِ ہَاہُنَا سَلْمَانُ بْنُ رَبِیعَۃَ الْبَاہِلِی ، جَلَسَ أَرْبَعِینَ یَوْمًا لاَ یَأْتِیہ خَصْمٌ۔",,,34627 34628,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، قَالَتْ : تَزَوَّجَنِی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَأَنَا بِنْتُ سِتِّ سِنِینَ ، وَبَنَی بِی وَأَنَا بِنْتُ تِسْعِ سِنِینَ۔ (بخاری 3894۔ مسلم 1039)",,,34628 34629,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سُفْیَانَ ، عَنْ أَبِیہِ ، عَنْ عِکْرِمَۃَ ، قَالَ : کَانَ بَیْنَ آدَمَ وَنُوحٍ عَشَرَۃُ أَقْرُنَ ، کُلُّہَا عَلَی الإِسْلاَمِ۔",,,34629 34630,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ سُفْیَانَ ، قَالَ : سَمِعْتُ الْہُذَلِیَّ یسَأَلُ جَعْفَرًا : کَمْ کَانَ لِعَلِیٍّ حِینَ ہَلَکَ ؟ قَالَ : قتُِلَ وَہُوَ ابْنُ ، ثَمَانٍ وَخَمْسِینَ ، وَمَاتَ لَہَا الْحَسَنُ ، وَقُتِلَ لَہَا الْحُسَیْنُ۔",,,34630 34631,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، قَالَ : سَمِعْتُ أَبِی ، قَالَ : حَدَّثَنَا أَبُو عُثْمَانَ ؛ أَنَّ عُثْمَانَ قُتِلَ فِی أَوْسَطِ أَیَّامِ التَّشْرِیقِ۔",,,34631 34632,"حَدَّثَنَا أَبُو نُعَیْمٍ الْفَضْلُ بْنُ دُکَیْنٍ ، قَالَ : حدَّثَنَا ابْنُ الْغَسِیلِ ، عَنْ عَاصِمِ بْنِ عُمَرَ بْنِ قَتَادَۃَ ، عَنْ مَحْمُودِ بْنِ لَبِیدٍ ، قَالَ : تُوُفِّیَ إِبْرَاہِیمُ بْنُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ ابْنُ ثَمَانیَۃَ عَشَرَ شَہْرًا ، وَقَالَ : إِنَّ لَہُ مُرْضِعًا فِی الْجَنَّۃِ۔",,,34632 34633,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، أَخْبَرَنَا یُونُسُ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : کُنْتُ أَنَا وَالأَسْوَدُ بْنُ یَزِیدَ فِی الشُّرْطَۃِ مَعَ عَمْرِو بْنِ حُرَیْثٍ ، لَیَالِی مُصْعَبٍ۔",,,34633 34634,حَدَّثَنَا شَبَابَۃُ ، عَنْ شُعْبَۃَ ، عَنْ مُعَاوِیَۃَ بْنِ قُرَّۃَ ، عَنْ أَبِیہِ ؛ أَنَّہُ أَتَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَقَدْ حَلَبَ وَصَرَّ۔ (ابوداؤد 1077۔ احمد 19),,,34634 34635,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، حَدَّثَنَا حَنَشُ بْنُ الْحَارِثِ ، قَالَ : رَأَیْتُ سُوَیْد بْنَ غَفَلَۃَ یَمُرُّ إِلَی امْرَأَۃٍ لَہُ مِنْ بَنِی أَسَدٍ ، وَہُوَ ابْنُ سَبْعٍ وَعِشْرِینَ وَمِئَۃِ سَنَۃٍ۔",,,34635 34636,وذَکَرُوا أَنَّ أَبَا مُوسَی الأَشْعَری تُوفِی وَہُو ابْن ثَلاث وستین ، وَمَاتَ سَنَۃَ أَرْبَعٍ وَأَرْبَعِینَ ، فِی إِمْرَۃِ مُعَاوِیَۃَ رَحِمَہُ اللہُ۔,,,34636 34637,وَمَاتَ الْعَبَّاسُ فِی إِمْرَۃِ عُثْمَانَ۔,,,34637 34638,وَمَاتَ ابْنُ مَسْعُودٍ فِی آخِرِ إِمْرَۃِ عُثْمَانَ۔,,,34638 34639,وَمَاتَ حُذَیْفَۃُ حِینَ جَائَ قَتْلُ عُثْمَانَ۔,,,34639 34640,وَمَاتَ جَابِرُ بْنُ زَیْدٍ ،,,,34640 34641,وَأَنَسُ بْنُ مَالِکٍ فِی جُمُعَۃِ ، سَنَۃِ ثَلاَثٍ وَتِسْعِینَ۔,,,34641 34642,وَمَاتَ ابْنُ عُمَرَ سَنَۃَ ثَلاَثٍ وَسَبْعِینَ۔,,,34642 34643,وَمَاتَتْ عَائِشَۃُ ،,,,34643 34644,وَالْحَسَنُ بْنُ عَلِیٍّ ، سَنَۃَ ثَمَانٍ وَخَمْسِینَ۔,,,34644 34645,وَمَاتَ عَمْرُو بْنُ حُرَیْثٍ فِی سَنَۃِ خَمْسٍ وَثَمَانِینَ۔,,,34645 34646,وَقُتِلَ الْحُسَیْنُ بْنُ عَلِیٍّ سَنَۃَ إِحْدَی وَسِتِّینَ ، فِی یَوْمِ عَاشُورَائَ ، قَتَلَہُ سِنَانُ بْنُ أَنَسٍ النَّخَعِیُّ الْوَہْبِیلِیُّ، لَعَنَہُ اللَّہُ ، وَجَائَ بِرَأْسِہِ خَوِلِیُّ بْنُ یَزِیدَ الأَصْبُحِیُّ إِلَی عُبَیْدِ اللہِ بْنِ زِیَادٍ۔,,,34646 34647,وَقُتِلَ ابْنُ الزُّبَیْرِ سَنَۃَ ثَلاَثٍ وَسَبْعِینَ۔,,,34647 34648,وَمَاتَ ابْنُ الْحَنَفِیَّۃِ فِی سَنَۃِ ، ثَمَانِینَ۔,,,34648 34649,وَتُوُفِّیَ ابْنُ عَبَّاسٍ فِی سَنَۃِ ثَمَانٍ وَسِتِّینَ۔,,,34649 34650,وَمَاتَ شُرَیْحٌ فِی سَنَۃِ ثَلاَث وَسَبْعِینَ۔,,,34650 34651,وَمَاتَ عَلِیُّ بْنُ الْحُسَیْنِ فِی سَنَۃِ ثِنْتَیْنِ وَتِسْعِینَ۔,,,34651 34652,وَمَاتَ أَبُو جَعْفَرٍ فِی سَنَۃِ أَرْبَعَ عَشْرَۃَ وَمِئَۃٍ۔,,,34652 34653,وَمَاتَ سَعِیدُ بْنُ الْمُسَیَّبِ فِی سَنَۃِ ثَلاَثٍ وَتِسْعِینَ۔,,,34653 34654,وَمَاتَ مُوسَی بْنُ طَلْحَۃَ فِی سَنَۃِ سِتٍّ وَمِئَۃٍ۔,,,34654 34655,وَمَاتَ أَبُو بُرْدَۃَ ،,,,34655 34656,وَالشَّعْبِیُّ فِی سَنَۃِ أَرْبَعٍ وَمِئَۃٍ۔,,,34656 34657,وَمَاتَ أَبُو بُرْدَۃَ وَہُوَ ابْنُ نَیِّفٍ وَثَمَانِینَ سَنۃ۔,,,34657 34658,وَقُتِلَ سَعِیدُ بْنُ جُبَیْرٍ فِی سَنَۃِ خَمْسٍ وَتِسْعِینَ۔,,,34658 34659,وَمَاتَ إِبْرَاہِیمُ فِی سَنَۃِ سِتٍّ وَتِسْعِینَ۔,,,34659 34660,وَمَاتَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ فِی سَنَۃِ إِحْدَی وَمِئَۃٍ۔,,,34660 34661,وَمَاتَ الْحَسَنُ ،,,,34661 34662,وَابْنُ سِیرِینَ فِی سَنَۃِ عَشْرٍ وَمِئَۃٍ۔,,,34662 34663,وَمَاتَ سَالِمُ بْنُ أَبِی الْجَعْدِ فِی زَمَنِ سُلَیْمَانَ بْنِ عَبْدِ الْمَلِکِ۔,,,34663 34664,وَمَاتَ مُجَاہِدٌ فِی سَنَۃِ ثِنْتَیْنِ وَمِئَۃٍ۔,,,34664 34665,وَمَاتَ الضَّحَّاکُ فِی سَنَۃِ خَمْسٍ وَمِئَۃٍ۔,,,34665 34666,وَمَاتَ مُحَمَّدُ بْنُ کَعْبٍ الْقُرَظِیّ سَنَۃَ ثَمَانٍ وَمِئَۃٍ۔,,,34666 34667,وَمَاتَ طَلْحَۃُ الْیَامِیُّ فِی سَنَۃِ ثِنْتَیْ عَشْرَۃَ وَمِئَۃٍ۔,,,34667 34668,وَمَاتَ زُبَیْدٌ فِی سَنَۃِ ثِنْتَیْنِ وَعِشْرِینَ وَمِئَۃٍ۔,,,34668 34669,وَمَاتَ سَلَمَۃُ فِی سَنَۃِ إِحْدَی وَعِشْرِینَ وَمِئَۃٍ۔,,,34669 34670,وَمَاتَ مَنْصُورٌ فِی سَنَۃِ ثِنْتَیْنِ وَثَلاَثِینَ وَمِئَۃٍ۔,,,34670 34671,وَمَاتَ قَتَادَۃُ ،,,,34671 34672,وَنَافِعٌ ، فِی سَنَۃِ سَبْعَ عَشْرَۃَ وَمِئَۃٍ۔,,,34672 34673,وَمَاتَ الْحَکَمُ فِی سَنَۃِ خَمْسَ عَشْرَۃَ وَمِئَۃٍ۔,,,34673 34674,وَمَاتَ أَبُو قَیْسٍ ،,,,34674 34675,وَوَاصِلٌ ،,,,34675 34676,وَحَمَّادٌ ، فِی سَنَۃِ عِشْرِینَ وَمِئَۃٍ۔,,,34676 34677,وَمَاتَ أَبُو صَخْرَۃَ فِی سَنَۃِ ، ثَمَانَ عَشْرَۃَ وَمِئَۃٍ۔,,,34677 34678,وَمَاتَ حَبِیبٌ فِی سَنَۃِ تِسْعَ عَشْرَۃَ وَمِئَۃٍ۔,,,34678 34679,وَمَاتَ عَمْرُو بْنُ مُرَّۃَ فِی سَنَۃِ سَبْعَ عَشْرَۃَ وَمِئَۃٍ۔,,,34679 34680,وَتُوُفِّیَ عَطَاء ٌ فِی سَنَۃِ خَمْسَ عَشْرَۃَ وَمِئَۃٍ۔,,,34680 34681,وَمَاتَ مُغِیرَۃُ فِی سَنَۃِ سِتٍّ وَثَلاَثِینَ وَمِئَۃٍ۔,,,34681 34682,وَمَاتَ عَبْدُ الْمَلِکِ بْنُ أَبِی سُلَیْمَانَ ،,,,34682 34683,وَہِشَامُ بْنُ عُرْوَۃَ ، فِی سَنَۃِ خَمْسٍ وَأَرْبَعِینَ وَمِئَۃٍ۔,,,34683 34684,وَمَاتَ أَبُو إِسْحَاقَ ،,,,34684 34685,وَجَابِرٌ الْجُعْفِیُّ فِی سَنَۃِ ثَمَانَ وَعِشْرِینَ وَمِئَۃٍ۔,,,34685 34686,وَمَاتَ مِسْعَرٌ فِی سَنَۃِ خَمْسٍ وَخَمْسِینَ وَمِئَۃٍ۔,,,34686 34687,وَمَاتَ عَلِیُّ بْنُ صَالِحٍ فِی سَنَۃِ أَرْبَعٍ وَخَمْسِینَ وَمِئَۃٍ۔,,,34687 34688,وَمَاتَ الثَّوْرِیُّ فِی سَنَۃِ إِحْدَی وَسِتِّینَ وَمِئَۃٍ۔,,,34688 34689,وَمَاتَ شُعْبَۃُ فِی سَنَۃِ سِتِّینَ وَمِئَۃٍ۔,,,34689 34690,وَوَلِیَ أَبُو بَکْرٍ الصِّدِّیقُ سَنَتَیْنِ وَنِصْفاً ، وَتُوُفِّیَ مِنْ مُہَاجِرِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی سَنَۃِ ثِنْتَیْ عَشْرَۃَ۔,,,34690 34691,وَوَلِیَ عُمَرُ بْنُ الْخَطَّابِ عَشْرَ سِنِینَ وَنِصْفاً ، وَقُتِلَ سَنَۃَ ثَلاَثٍ وَعِشْرِینَ مِنْ مُہَاجِرِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فِی ذِی الْحِجَّۃِ ۔,,,34691 34692,وَوَلِیَ عُثْمَان بْنُ عَفَّانَ ثِنْتَیْ عَشْرَۃَ سَنَۃٍ ، وَقُتِلَ سَنَۃَ خَمْسٍ وَثَلاَثِینَ فِی ذِی الْحِجَّۃِ۔,,,34692 34693,وَوَلِیَ عَلِیٌّ خَمْسَ سِنِینَ ، وَقُتِلَ فِی سَنَۃِ أَرْبَعِینَ مِنْ مُہَاجِرِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی شَہْرِ رَمَضَانَ ، فِی لَیْلَۃِ إِحْدَی وَعِشْرِینَ یَوْمَ جُمُعَۃٍ ، وَمَاتَ لَیْلَۃَ الأَحَدِ۔,,,34693 34694,وَوَلِیَ مُعَاوِیَۃُ عِشْرِینَ إِلاَّ شَیْئًا ، وَمَاتَ سَنَۃَ سِتِّینَ مِنَ الْمُہَاجِرِ۔,,,34694 34695,وَوَلِیَ یَزِیدُ بْنُ مُعَاوِیَۃَ ثَلاَثَ سِنِینَ وَنِصْفًا۔,,,34695 34696,وَکَانَتْ فِتْنَۃُ ابْنِ الزُّبَیْرِ تِسْعَ سِنِینَ۔,,,34696 34697,وَوَلِیَ مَرْوَانُ بْنُ الْحَکَمِ نَحْوًا مِنْ تِسْعَۃِ أَشْہُرٍ ، أَوْ عَشْرَۃٍ۔,,,34697 34698,وَوَلِیَ عَبْدُ الْمَلِکِ بْنُ مَرْوَانَ أَرْبَعَ عَشْرَۃَ سَنَۃً۔,,,34698 34699,وَوَلِیَ الْوَلِیدُ تِسْعَ سِنِینَ۔,,,34699 34700,وَوَلِیَ سُلَیْمَانُ ،,,,34700 34701,وَعُمَرُ بْنُ عَبْدِ الْعَزِیزِ کُلُّ وَاحِدٍ مِنْہُمَا سَنَتَیْنِ وَنِصْفاً۔,,,34701 34702,وَوَلِیَ ہِشَامُ بْنُ عَبْدِ الْمَلِکِ عِشْرِینَ سَنَۃً إِلاَّ أَشْہُرًا۔,,,34702 34703,وَوَلِیَ الْوَلِیدُ بْنُ یَزِیدَ نَحْوًا مِنْ سَنَتَیْنِ۔,,,34703 34704,وَوَلِیَ یَزِیدُ بْنُ الْوَلِیدِ بْنِ عَبْدِ الْمَلِکِ سِتَّۃَ أَشْہُرٍ۔,,,34704 34705,وَوَلِیَ إِبْرَاہِیمُ أَرْبَعِینَ لَیْلَۃً۔,,,34705 34706,وَوَلِیَ مَرْوَانُ بْنُ مُحَمَّدِ بْنِ مَرْوَانَ خَمْسَ سِنِینَ ، وَہُوَ الَّذِی أُخِذَتِ الْخِلاَفَۃُ مِنْہُ۔,,,34706 34707,وَوَلِیَ أَبُو الْعَبَّاسِ عَبْدُ اللہِ بْنُ مُحَمَّدِ بْنِ عَلِیِّ بْنِ عَبْدِ اللہِ بْنِ عَبَّاسٍ أَرْبَعَ سِنِینَ وَنِصْفًا۔,,,34707 34708,وَوَلِیَ أَبُو جَعْفَرٍ ، وَاسْمُہُ عَبْدُ اللہِ بْنُ مُحَمَّدِ بْنِ عَلِیٍّ ثِنْتَیْنِ وَعِشْرِینَ سَنَۃً۔,,,34708 34709,وَوَلِیَ الْمَہْدِیُّ عَشْرَ سِنِینَ۔,,,34709 34710,وَوَلِیَ مُوسَی بْنُ الْمَہْدِیِّ سَنَۃً وَشَہْراً۔,,,34710 34711,وَوَلِیَ ہَارُونُ ثَلاَثًا وَعِشْرِینَ سَنَۃً۔,,,34711 34712,وَوَلِیَ الْمَأْمُونُ ثِنْتَیْنِ وَعِشْرِینَ سَنَۃً إِلاَّ شَہْرًا۔,,,34712 34713,"وَذَکَرَ ابْنُ إِدْرِیسَ : قَالَ سَأَلْتُ إِسْرَائِیلَ : أَبُو إِسْحَاقَ ابْنُ کَمْ مَاتَ ؟ قَالَ : مَاتَ ابْنُ سِتٍّ وَتِسْعِینَ۔",,,34713 34714,وَکَانَ الشَّعْبِیُّ أَکْبَرَ مِنْہُ بِسَنَتَیْنِ۔,,,34714 34715,وَقُتِلَ طَلْحَۃُ,,,34715 34716,وَالزُّبَیْرُ فِی رَجَبٍ سَنَۃُ سِتٍّ وَثَلاَثِینَ۔,,,34716 34717,وَمَاتَ مَسْرُوقٌ فِی سَنَۃِ ثَلاَثٍ وَسِتِّینَ۔,,,34717 34718,وَمَاتَ الأَسْوَدُ فِی سَنَۃِ أَرْبَعٍ وَسَبْعِینَ۔,,,34718 34719,وَمَاتَ عَبِیْدَۃُ فِی سَنَۃِ أَرْبَعٍ وَسِتِّینَ۔,,,34719 34720,وَمَاتَ عَلْقَمَۃُ بْنُ قَیْسٍ فِی سَنَۃِ ثِنْتَیْنِ وَسِتِّینَ۔,,,34720 34721,وَمَاتَ عَمْرُو بْنُ مَیْمُونٍ فِی سَنَۃِ خَمْسٍ وَسَبْعِینَ۔,,,34721 34722,وَمَاتَ أَبُوعَوْنٍ الثَّقَفِیُّ فِی سَنَۃِ إِحْدَی وَخَمْسِینَ وَمِئَۃٍ۔,,,34722 34723,وَمَاتَ مَالِکُ بْنُ مِغْوَلٍ فِی سَنَۃِ إِحْدَی وَخَمْسِینَ وَمِئَۃٍ ، أَوَّلُہَا۔,,,34723 34724,وَمَاتَ إِسْرَائِیلُ فِی سَنَۃِ سِتِّینَ وَمِئَۃٍ۔,,,34724 34725,وَمَاتَ قَیْسُ بْنُ الرَّبِیعِ,,,34725 34726,وَجَعْفَرُ الأَحْمَرُ ، فِی سَنَۃِ سَبْعٍ وَسِتِّینَ وَمِئَۃٍ۔,,,34726 34727,وَمَاتَ شَرِیکُ بْنُ عَبْدِ اللہِ فِی سَنَۃِ سَبْعٍ وَسَبْعِینَ وَمِئَۃٍ۔,,,34727 34728,وَمَاتَ مُجَاہِدُ بْنُ جَبْرٍ فِی سَنَۃِ ثِنْتَیْنِ وَمِئَۃٍ۔,,,34728 34729,وَمَاتَ رِبْعِیُّ بْنُ حِرَاشٍ فِی زَمَنِ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ۔,,,34729 34730,"- بَلَغَنَا : أَنَّ اسْمَ أَبِی بَکْرٍ الصِّدِّیقِ : عَبْدُ اللہِ بْنُ عُثْمَانَ۔",,,34730 34731,"وَاسْمَ أَبِی عُبَیْدَۃَ بْنِ الْجَرَّاحِ : عَامِرُ بْنُ عَبْدِ اللہِ بْنِ الْجَرَّاحِ۔",,,34731 34732,"وَاسْمَ أَبِی ذَرٍّ الْغِفَارِیِّ : جُنْدُبُ بْنُ جُنَادَۃَ۔",,,34732 34733,"وَاسْمَ أَبِی الدَّرْدَائِ : عُوَیْمِرٌ۔",,,34733 34734,"وَاسْمَ أَبِی قَتَادَۃَ : الْحَارِثُ بْنُ رِبْعِیٍّ۔",,,34734 34735,"وَاسْمَ أَبِی مَحْذُورَۃَ : سَمُرَۃُ بْنُ مِعْیَرٍ۔",,,34735 34736,"وَاسْمَ أَبِی الْیَسَرِ : کَعْبُ بْنُ عَمْرٍو۔",,,34736 34737,"وَاسْمَ أَبِی أُسَیْدَ : مَالِکُ بْنُ رَبِیعَۃَ بْنِ سَعْدِ بْنِ رَبِیعَۃَ۔",,,34737 34738,"وَاسْمَ أَبِی بُرْزَۃَ : نَضْلَۃُ بْنُ عُبَیْدٍ۔",,,34738 34739,"وَاسْمَ أَبِی سَعِیدٍ الْخُدْرِیِّ : سَعْدُ بْنُ مَالِکٍ۔",,,34739 34740,"وَاسْمَ أَبِی الْہَیْثُمِ بْنِ التَّیْہَانِ : مَالِکُ بْنُ التَّیْہَانِ۔",,,34740 34741,"وَاسْمَ أَبِی أَیُّوبَ : خَالِدُ بْنُ زَیْدٍ۔",,,34741 34742,"وَاسْمَ أَبِی مَسْعُودٍ : عُقْبَۃُ بْنُ عَمْرٍو۔",,,34742 34743,"وَأَبُو الْمَلِیحِ : عَامِرُ بْنُ أُسَامَۃَ۔",,,34743 34744,"وَأَبُو مُوسَی الأَشْعَرِیُّ : عَبْدُ اللہِ بْنُ قَیْسٍ۔",,,34744 34745,"وَاسْمَ أَبِی أُمَامَۃَ الْبَاہِلِیِّ : الصُّدَیُّ بْنُ عَجْلاَنَ۔",,,34745 34746,"وَاسْمَ أَبِی أُمَامَۃَ الأَنْصَارِیِّ : أَسْعَدُ بْنُ زُرَارَۃَ۔",,,34746 34747,"وَاسْمَ أَبِی دُجَانَۃَ : سِمَاکُ بْنُ خَرَشَۃَ۔",,,34747 34748,"وَاسْمَ أَبِی بَکْرَۃَ : نُفَیْعُ بْنُ الْحَارِثِ۔",,,34748 34749,"وَاسْمَ أَبِی ہُرَیْرَۃَ : عَبْدُ شَمْسٍ۔",,,34749 34750,"وَأَبُو طَلْحَۃَ الأَنْصَارِیُّ : زَیْدُ بْنُ سَہْلٍ۔",,,34750 34751,"وَأَبُو بُرْدَۃَ بْنُ نِیَارٍ : ہَانِئُ بْنُ نِیَارٍ۔",,,34751 34752,"وَأَبُو أُحَیْحَۃَ : سَعِیدُ بْنُ الْعَاصِ۔",,,34752 34753,"عبْدُ الْمُطَّلِبُ اسْمُہُ : شَیْبَۃُ۔",,,34753 34754,"وَہَاشِمٌ اسْمُہُ : عَمْرٌو۔",,,34754 34755,"وَعَبْدُ مَنَافٍ الْکَبِیرُ : الْمُغِیرَۃُ۔",,,34755 34756,"وَاسْمَ أَبِی لَہَبٍ : عَبْدُ الْعُزَّی بْنُ عَبْدِ الْمُطَّلِبِ۔",,,34756 34757,"أَبُو جُحَیْفَۃَ : وَہْبٌ السُّوَائِیُّ۔",,,34757 34758,"أَبُو حُذَیْفَۃَ بْنُ الْیَمَانِ : حُسَیْلُ بْنُ جَابِرٍ۔",,,34758 34759,"وَاسْمَ أَبِی وَائِلٍ : شَقِیقُ بْنُ سَلَمَۃَ۔",,,34759 34760,"وَأَبُو الأَحْوَصِ : عَوْفُ بْنُ مَالِکٍ الْجُشَمِیُّ۔",,,34760 34761,"وَأَبُو عَبْدِ الرَّحْمَنِ السُّلَمِیُّ : عَبْدُ اللہِ بْنُ حَبِیبٍ۔",,,34761 34762,"أَبُو الْبَخْتَرِیِّ الطَّائِیُّ : سَعِیدُ بْنُ فَیْرُوز۔",,,34762 34763,"وَاسْمَ أَبِی رَزِینٍ : مَسْعُودٌ۔",,,34763 34764,"وَأَبُو ظَبْیَانِ : حُصَیْنُ بْنُ جُنْدُبٍ۔",,,34764 34765,"وَأَبُو الزَّعْرَائِ : عَبْدُ اللہِ بْنُ ہَانِئٍ۔",,,34765 34766,"وَأَبُو الزَّعْرَائِ الْجُشَمِیُّ : عَمْرُو بْنُ عَمْرٍو۔",,,34766 34767,"أَبُو سُفْیَانَ : طَلْحَۃُ بْنُ نَافِعٍ۔",,,34767 34768,"وَأَبُو صَالِحٍ صَاحِبُ الأَعْمَشِ : ذَکْوَانُ۔",,,34768 34769,"وَأَبُو صَالِحٍ مَوْلَی أُمِّ ہَانِیئٍ صَاحِبُ الْکَلْبِیِّ : بَاذَانُ۔",,,34769 34770,"أَبُو صَالِحٍ الْحَنَفِیُّ : مَاہَانُ۔",,,34770 34771,"أَبُو عَمْرٍو الشَّیْبَانِیُّ : سَعْدُ بْنُ إِیَاسٍ۔",,,34771 34772,"أَبُو عُثْمَانَ النَّہْدِی : عَبْدُ الرَّحْمَنِ بن مُلّ۔",,,34772 34773,"أَبُو قِلاَبَۃَ : عَبْدُ اللہِ بْنُ زَیْدٍ۔",,,34773 34774,"أَبو الوَدَّاک : جَبْرُ بْنُ نَوْف۔",,,34774 34775,"أَبُو کَاہِلٍ : قَیْسُ بْنُ عَائِذٍ ، وَقَدْ رَأَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,34775 34776,"أَبُو السَّفَرِ : سَعِیدُ بْنُ یُحْمِدَ۔",,,34776 34777,"أَبُو الأَسْوَدِ الدُّؤَلِیُّ : ظَالِمُ بْنُ عَمْرِو بْنِ سُفْیَانَ۔",,,34777 34778,"أَبُو حَکِیمِ الْمُزَنِیُّ : عَقِیلُ بْنُ مُقَرِّنٍ۔",,,34778 34779,"أَبُو سَرِیْحَۃَ : حُذَیْفَۃُ بْنُ أَسِیدٍ الْغِفَارِیُّ۔",,,34779 34780,"أَبُو عَمْرَۃَ : مَعْقِلٌ۔",,,34780 34781,"أَبُو الْمُتَوَکِّلِ النَّاجِی : عَلِیُّ بْنُ دَاوُد۔",,,34781 34782,"أَبُو الْکَنُودِ الأَزْدِیُّ : عَبْدُ اللہِ بْنُ عُوَیْمِرٍ۔",,,34782 34783,"أَبُو عَطِیَّۃَ الْہَمْدَانِیُّ : مَالِکُ بْنُ عَامِرٍ۔",,,34783 34784,"أَبُو بُرْدَۃَ الأَشْعَرِیُّ : عَامِرُ بْنُ عَبْدِ اللہِ۔",,,34784 34785,"أَبُو خَالِدٍ الْوَالِبِیُّ : ہُرْمُزُ۔",,,34785 34786,"أَبُو مَعْمَرٍ : عَبْدُ اللہِ بْنُ سَخْبَرَۃَ۔",,,34786 34787,"أَبُو صُفْرَۃَ : سَارِقُ بْنُ ظَالِمٍ۔",,,34787 34788,"أَبُو الطُّفَیْلِ : عَامِرُ بْنُ وَاثِلَۃَ۔",,,34788 34789,"أَبُو الْقَعْقَاعِ الْجَرْمِیُّ : عَبْدُ اللہِ بْنُ خَالِدٍ۔",,,34789 34790,"أَبُو الْعَالِیَۃِ الرِّیَاحِیُّ : رُفَیْعٌ۔",,,34790 34791,"وَأَبُو الْعَالِیَۃِ : زِیَادُ بْنُ فَیْرُوز۔",,,34791 34792,"وَأَبُو الضُّحَی : مُسْلِمُ بْنُ صُبَیْحٍ۔",,,34792 34793,"أَبُو عِیسَی : یَحْیَی بْنُ رَافِعٍ۔",,,34793 34794,"أَبُو الْحَلاَلُ الْعَتَکِیُّ : رَبِیعَۃُ بْنُ زُرَارَۃَ۔",,,34794 34795,"أََبُو الْجَلْدِ : جَیْلانُ بْنُ فَرْوَۃ۔",,,34795 34796,"أَبُو جَمْرَۃَ : نَصْرُ بْنُ عِمْرَانَ۔",,,34796 34797,"أَبُو حَمْزَۃَ الأَسَدِیُّ : عَمَّارَ بْنُ أَبِی عَطَائٍ۔",,,34797 34798,"وَأَبُو حَمْزَۃَ الأَعْوَرُ : مَیْمُونٌ۔",,,34798 34799,"وَأَبُو حَمْزَۃَ الثَّمَالِیُّ : ثَابِتٌ۔",,,34799 34800,"وَأَبُو التَّیَّاحِ الضُّبَعِیُّ : یَزِیدُ بْنُ حُمَیْدٍ۔",,,34800 34801,"أَبُو عِمْرَانَ الْجَوْنِیُّ : عَبْدُ الْمَلِکِ بْنُ حَبِیبٍ۔",,,34801 34802,"أَبُو تَمِیمَۃَ الْہُجَیْمِیُّ : طَرِیفُ بْنُ مُجَالِدٍ۔",,,34802 34803,"أَبُو لَبِیدٍ : لِمَازَۃُ بْنُ زَبَّارِ۔",,,34803 34804,"أَبُو الْعَجْفَائِ السُّلَمِیُّ : ہَرِمٌ۔",,,34804 34805,"أَبُو الزَّاہِرِیَّۃِ : حُدَیْرُ بْنُ کُرَیْبٍ۔",,,34805 34806,"أَبُو مُسْلِمٍ الْخَوْلاَنِیُّ : عَبْدُ اللہِ بْنُ عَبْدِ اللہِ۔",,,34806 34807,"أَبُو حَازِمٍ الْمَدِینِیُّ : سَلَمَۃُ بْنُ دِینَارٍ۔",,,34807 34808,"أَبُو الزِّنَادُ : عَبْدُ اللہِ بْنُ ذَکْوَانَ۔",,,34808 34809,"أَبُو جَعْفَرٍ الْقَارِء : یَزِیدُ بْنُ الْقَعْقَاعِ۔",,,34809 34810,"أَبُو الْحُوَیْرِثِ : عَبْدُ الرَّحْمَنِ بْنُ مُعَاوِیَۃَ۔",,,34810 34811,"أَبُو الْخَلِیلِ : صَالِحٌ بْنُ مَرْیَمٍ۔",,,34811 34812,"أََبُو نَعَامَۃَ العَدَویُّ : عَمْرٌو۔",,,34812 34813,"أَبُو السَّلِیلِ : ضُرَیبُ بْنُ نُفَیْرٍ۔",,,34813 34814,"أَبُو مُرَایَۃَ الْعِجْلِیُّ : عَبْدُ اللہِ بْنُ عَمْرٍو۔",,,34814 34815,"أَبُو السَّوارِ العَدَویُّ : حَسَّانُ بْنُ حُرَیْثٍ۔",,,34815 34816,"وَیُقَالَ : أَبُو قَتَادَۃَ الْعَدَوِیُّ : تَمِیمُ بْنُ نُذَیْرٍ۔",,,34816 34817,"أَبُو عَاصِمٍ الْغَطَفَانِیُّ : عَلِیُّ بْنُ عُبَیْدِ اللہِ۔",,,34817 34818,"وَأَبُو رَجَائٍ الْعُطَارِدِیُّ : عِمْرَانُ بْنُ عَبْدِ اللہِ ، وَقَالَ بَعْضُہُمْ : عِمْرَانُ بْنُ مِلْحَانَ۔",,,34818 34819,"أَبُو نَضْرَۃَ : مُنْذَرُ بْنُ مَالِکٍ۔",,,34819 34820,"أَبُو الصِّدِّیقِ النَّاجِی : بَکْرٌ۔",,,34820 34821,"أَبُو ہُنَیْدَۃَ : حُرَیْثُ بْنُ مَالِکٍ۔",,,34821 34822,"أَبُو أَیُّوبَ الأَزْدِیُّ : یَحْیَی بْنُ مَالِکٍ۔",,,34822 34823,"أَبُو حَسَّانَ الأَعْرَجُ : مُسْلِمٌ۔",,,34823 34824,"أَبُو مِجْلَزٍ : لاَحِقُ بْنُ حُمَیْدٍ۔",,,34824 34825,"أَبُو الزُّبَیْرِ : مُحَمَّدُ بْنُ مُسْلِمٍ۔",,,34825 34826,"والزُّہْرِی : مُحَمَّد بْنُ مُسْلِمِ بْنِ عُبَیْدِ اللہِ بْنِ شِہَابٍ۔",,,34826 34827,"أَبُو مَعْشَرٍ : زِیَادُ بْنُ کُلَیْبٍ۔",,,34827 34828,"وَأَبُو عَبْدِ اللہِ الشَّقَرِیُّ : سَلَمَۃُ بْنُ تَمَّامٍ۔",,,34828 34829,"أَبُو الْجَحَّافِ : دَاوُدُ بْنُ أَبِی عَوْفٍ۔",,,34829 34830,"وَأَبُو حُصَیْنٍ : عُثْمَانُ بْنُ عَاصِمٍ۔",,,34830 34831,"أَبُو إِسْحَاقَ السَّبِیعِیُّ : عَمْرُو بْنُ عَبْدِ اللہِ۔",,,34831 34832,"وَأَبُو إِسْحَاقَ الشَّیْبَانِیُّ : سُلَیْمَانُ بْنُ فَیْرُوزٍ۔",,,34832 34833,"أَبُو حِبَرۃَ : شِیْحَۃُ بْنُ عَبْدِ اللہِ۔",,,34833 34834,"أَبُو الْوَازِعِ الرَّاسِبِیُّ : جَابِرُ بْنُ عَمْرٍو۔",,,34834 34835,"أَبُو الْعَلاَئِ بْنِ الشِّخِّیرِ : یَزِیدُ بْنُ عَبْدِ اللہِ بْنِ الشِّخِّیرِ۔",,,34835 34836,"أَبُو فَرْوَۃَ الْہَمْدَانِیُّ : عُرْوَۃُ بْنُ الْحَارِثِ۔",,,34836 34837,"أَبُو فَرْوَۃَ الْجُہَنِیُّ : مُسْلِمُ بْنُ سَالِمٍ۔",,,34837 34838,"أَبُو الْجُوَیْرِیَۃِ الْجَرْمِیُّ : حِطَّانُ بْنُ خُفَافٍ۔",,,34838 34839,"أَبُو رَیْحَانَۃَ : عَبْدُ اللہِ بْنُ مَطَرٍ۔",,,34839 34840,"أَبُو حَازِمٍ الأَشْجَعِیُّ : سَلْمَانُ۔",,,34840 34841,"أَبُو رَزِینٍ الْعُقَیْلِیُّ : لَقِیطُ بْنُ عَامِرٍ۔",,,34841 34842,"أَبُو الْغَرِیفِ : عُبَیْدُ اللہِ بْنُ خَلِیفَۃَ۔",,,34842 34843,"أَبُو رَوْقٍ : عَطِیَّۃُ بْنُ الْحَارِثِ۔",,,34843 34844,"أَبُو الْیَقْظَانِ : عُثْمَانُ بْنُ عُمَیْرٍ۔",,,34844 34845,"أَبُو عَمْرٍو الشَّعْبِیُّ : عَامِرُ بْنُ شَرَاحِیلَ۔",,,34845 34846,"أَبُو مَالِکٍ الأَشْجَعِیُّ : سَعْدُ بْنُ طَارِقٍ۔",,,34846 34847,"أَبُو حَیَّانَ التَّیْمِیُّ : یَحْیَی بْنُ سَعِیدٍ۔",,,34847 34848,"أَبُو قَیْسٍ الأَوْدِیُّ : عَبْدُ الرَّحْمَنِ بْنُ ثَرْوَانَ۔",,,34848 34849,"أَبُو مَیْسَرَۃَ : عَمْرُو بْنُ شُرَحْبِیلَ۔",,,34849 34850,"أَبُو جَعْفَرٍ الْفَرَّائُ : کَیْسَانُ۔",,,34850 34851,"الأَوْزَاعِیُّ : عَبْدُ الرَّحْمَنِ بْنُ عَمْرٍو ، وَیُکَنَّی أَبَا عَمْرٍو۔",,,34851 34852,"الإِفْرِیقِیُّ : عَبْدُ الرَّحْمَان بْنُ زِیَادٍ۔",,,34852 34853,"أَبُو جَعْفَرٍ : مُحَمَّدُ بْنُ عَلِیِّ بْنِ حُسَیْنٍ ، الَّذِی رَوَی عَنْہُ الزُّہْرِیُّ۔",,,34853 34854,"أَبُو جَمِیلَۃَ : سُنَیِّنُ السُّلَمِیُّ۔",,,34854 34855,"أَبُو بِشْرٍ : جَعْفَرُ بْنُ إِیَاسٍ۔",,,34855 34856,"أَبُو عَوْنٍ الثَّقَفِیُّ : مُحَمَّدُ بْنِ عُبَیْدِ اللہِ۔",,,34856 34857,"أَبُو عَاصِمٍ الثَّقَفِیُّ : مُحَمَّدُ بْنُ أَبِی أَیْوبِ۔",,,34857 34858,"أَبُو الْعَنْبَسِ : سَعِیدُ بْنُ کَثِیرٍ۔",,,34858 34859,"أَبُو سِنَانٍ : ضِرَارُ بْنُ مُرَّۃَ۔",,,34859 34860,"أَبُو سِیْدان الْغَطَفَانِیُّ : عُبَیْدُ بْنُ طُفَیْلٍ۔",,,34860 34861,"أَبُو کِبْرَانَ الْجَرْمِیُّ : الْحَسَنُ بْنُ عُقْبَۃَ۔",,,34861 34862,"أَبُو جَعْفَرٍ الرَّازِیُّ : عِیسَی بْنُ مَاہَانَ۔",,,34862 34863,"أَبُو یَعْلَی الثَّوْرِیُّ : مُنْذِرٌ۔",,,34863 34864,"أَبُو نُوحٍ ، الَّذِی رَوَی عَنْہُ فِطَرٌ : الْقَاسِمُ الأَنْصَارِیُّ۔",,,34864 34865,"أَبُو الْمُغِیرَۃِ ، الَّذِی رَوَی عَنْہُ أَبُو إِسْحَاقَ : عُبَیْدٌ۔",,,34865 34866,"السُّدِّیُّ : إِسْمَاعِیلُ۔",,,34866 34867,"أَبُو الْمِقْدَامِ : ثَابِتُ بْنُ الْمِقْدَامُ۔",,,34867 34868,"الْجَرِیرِیُّ : سَعِیدُ بْنُ إِیَاسٍ۔",,,34868 34869,"وَأَبُو مَسْلَمَۃَ : سَعِیدُ بْنُ یَزِیدَ۔",,,34869 34870,"أَبُو الْمِنْہَالِ : سَیَّارُ بْنُ سَلاَمَۃَ۔",,,34870 34871,"أَبُو نَصْرٍ : حُمَیْدُ بْنُ ہِلاَلٍ۔",,,34871 34872,"أَبُو الْعَلاَئِ : ہِلاَلُ بْنُ خَبَّابٍ۔",,,34872 34873,"أَبُو الْمُخَارِقِ الْعَبْدِیُّ اسْمُہُ : مَغْرَائُ۔",,,34873 34874,"أَبُو إِیَاسٍ : مُعَاوِیَۃُ بْنُ قُرَّۃَ۔",,,34874 34875,"أَبُو خِفَافٍ صَاحِبُ أَبِی إِسْحَاقَ : نَاجِیَۃُ الْعَدَوِیُّ۔",,,34875 34876,"ابْنُ أَبِی مُلَیْکَۃَ : عَبْدُ اللہِ بْنُ أَبِی مُلَیْکَۃَ۔",,,34876 34877,"أَبُو أُسَامَۃَ اسْمُہُ : زَیْدٌ۔",,,34877 34878,"ابْنُ بُحَیْنَۃَ ، اسْمُہُ : عَبْدُ اللہِ۔",,,34878 34879,"أَبُو الشَّعْثَائِ الْمُحَارِبِیُّ : سُلَیْمُ بْنُ أَسْوَدَ۔",,,34879 34880,"أَبُو الْحَسَنِ ، الَّذِی رَوَی عَنْہُ عَمْرُو بْنُ مُرَّۃَ ، ہُوَ : ہِلاَلُ بْنُ یَسَافٍ۔",,,34880 34881,"أَبُو یَعْفُورٍ الْعَبْدِیُّ : وَقْدَانُ الأَکْبَرُ۔",,,34881 34882,"أَبُو یَعْفُورٍ الْعَامِرِیُّ : عَبْدُ الرَّحْمَنِ بْنُ عُبَیْدٍ۔",,,34882 34883,"أَبُو ثَابِتٍ ، الَّذِی رَوَی عَنْہُ أَبُو یَعْفُورٍ : أَیْمَنُ۔",,,34883 34884,"أَبُو الشَّعْثَائِ : جَابِرُ بْنُ زَیْدٍ۔",,,34884 34885,"أَبُو حَازِمٍ ، الَّذِی رَوَی عَنْہُ إِسْمَاعِیلُ : نَبْتل۔",,,34885 34886,"وَقَالَ بَعْضُہُمْ : أَبُو سَلَمَۃَ بْنُ عَبْدِ الرَّحْمَنِ : عَبْدُ اللہِ بْنُ عَبْدِ الرَّحْمَنِ۔",,,34886 34887,"أَبُو الْمُہَلَّبِ ، صَاحِبُ عَوْفٍ : عُمَر بْنُ مُعَاوِیَۃَ ، وَقَالَ بَعْضُہُمْ : عَبْدُ الرَّحْمَنِ بْنُ مُعَاوِیَۃَ۔",,,34887 34888,"أَبُو مُحَارِبٍ : مُسْلِمُ بْنُ عَمْرٍو۔",,,34888 34889,"أَبُو الْخَلِیلِ : صَالِحٌ۔",,,34889 34890,"أَبُو الْعَالِیَۃِ الْکُوفِیُّ ، الَّذِی رَوَی عَنْہُ أَبُو إِسْحَاقَ : عَبْدُ اللہِ بْنُ سَلَمَۃَ الْہَمْدَانِیُّ۔",,,34890 34891,"أَبُوالأَشْہَبِ : جَعْفَرُ بْنُ حِیَّانَ۔",,,34891 34892,"أَبُو ہِلاَلٍ الرَّاسِبِیُّ : مُحَمَّدُ بْنُ سُلَیْمٍ۔",,,34892 34893,"أَبُو الْمُعْتَمِرِ : یَزِیدُ بْنُ طَہْمَانَ۔",,,34893 34894,"وَالْمَسْعُودِیُّ : عَبْدُ الرَّحْمَنِ بْنُ عَبْدِ اللہِ بْنِ عُتْبَۃَ۔",,,34894 34895,"وَأَبُو الْعُمَیْسِ : عُتْبَۃُ بْنُ عَبْدِ اللہِ۔",,,34895 34896,"اسْمُ أَبِی سَہْلٍ : عَوْفُ بْنُ أَبِی جَمِیلَۃَ۔",,,34896 34897,"أَبُو جَعْفَرٍ الْخِطْمِیُّ : عُمَیْرُ بْنُ یَزِیدَ۔",,,34897 34898,"أَبُو تَمِیمٍ الْجَیَشَانِیُّ : عَبْدُ اللہِ بْنُ مَالِکٍ۔",,,34898 34899,"أَبُو وَہْبٍ الْجَیَشَانِیُّ ، اسْمُہُ : دَیْلَمٌ۔",,,34899 34900,"أَبُو حَرِیزٍ ، اسْمُہُ : عَبْدُ اللہِ بْنُ حُسَیْنٍ۔",,,34900 34901,"أَبُو فَاخِتَۃَ ، مَوْلَی ابْنِ ہُبَیْرَۃَ : سَعِیدُ بْنُ عِلاَقَۃَ۔",,,34901 34902,"أَبُو رَجَائٍ ، الَّذِی رَوَی عَنْہُ شُعْبَۃُ ، وَابْنُ عُلَیَّۃَ : مُحَمَّدُ بْنُ سَیْفٍ۔",,,34902 34903,"أَبُو الْمُعْتَمِرِ صَاحِبُ إِسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، اسْمُہُ : حَنَشٌ۔",,,34903 34904,"وَسَمِعْتُ مَنْ یَذْکُرُ : أَنَّ أَبَا حَمْزَۃَ ، الَّذِی رَوَی عَنْہُ إِسْمَاعِیلُ بْنُ أَبِی خَالِدٍ : سَعْدُ بْنُ عُبَیْدَۃَ۔",,,34904 34905,"الْبَہِیُّ ، الَّذِی رَوَی عَنْہُ السُّدِّیُّ وَإِسْمَاعِیلُ بْنُ أَبِی خَالِدٍ ، اسْمُہُ : عبْدُ اللہِ۔",,,34905 34906,"ابْنُ أَبِی نَجِیحٍ ، اسْمُہُ : عَبْدُ اللہِ۔",,,34906 34907,"وَالَّذِی رَوَی عَنْہُ عَطَائُ بْنُ السَّائِبِ أَبُو مُسْلِمٍ ، اسْمُہُ : الأَغَرُّ۔",,,34907 34908,"أَبُو عَبْدِ اللہِ الْبَرَّادُ ، اسْمُہُ : سَالِمٌ۔",,,34908 34909,"أَبُو مُوسَی الَّذِی رَوَی عَنْہُ رَاشِدُ بْنُ سَعْدٍ ، اسْمُہُ : یُحَنَّسُ۔",,,34909 34910,"الأَعْمَشُ : سُلَیْمَانُ بْنُ مِہْرَانَ۔",,,34910 34911,"أَبُو کَثِیرٍ الَّذِی رَوَی عَنْ أَبِی ہُرَیْرَۃَ ، اسْمُہُ : یَزِیدُ بْنُ عَبْدِ الرَّحْمَنِ بْنِ أُذَیْنَۃَ السُّحَیْمِیُّ۔",,,34911 34912,"أَبُو زُمَیْلٍ : سِمَاکٌ الْحَنَفِیُّ۔",,,34912 34913,"أَبُو النَّجَاشِیِّ ، مَوْلَی رَافِعِ بْنِ خَدِیجٍ ، اسْمُہُ : عَطَاء ٌ۔",,,34913 34914,"أَبُو کُدَیْنَۃَ : یَحْیَی بْنُ الْمُہَلَّبِ۔",,,34914 34915,"اسْمُ أَبِی تِحْیَی : حُکِیْم بْنُ سَعْدٍ۔",,,34915 34916,"أَبُو یَزِیدَ الَّذِی رَوَی عَنْہُ سُفْیَانُ : وَقَائُ بْنُ إِیَاسٍ۔",,,34916 34917,"أَبُو خَالِدٍ الدَّالاَنِیُّ : یَزِیدُ بْنُ عَبْدِ الرَّحْمَنِ۔",,,34917 34918,"أَبُو الْفُرَاتِ ، الَّذِی رَوَی عَنْہُ أَبُو حَیَّانَ : شَدَّادُ بْنُ أَبِی الْعَالِیَۃِ۔",,,34918 34919,"أَبُو طَلْقٍ : عَدیُّ بْنُ حَنْظَلَۃَ۔",,,34919 34920,"أَبُو سَلْمَانَ صَاحِبُ مِسْعَرٍ ، اسْمُہُ : یَزِیدُ۔",,,34920 34921,"الْہِزْہَازِ الَّذِی رَوَی عَنْہُ عَبْدُ اللہِ ، اسْمُہُ : ہَانِیء ٌ۔",,,34921 34922,"وَاسْمُ أَبِی عُمَرَ ، صَاحِبِ ابْنِ الْحَنَفِیَّۃِ : دِینَارٌ ، مَوْلَی بِشْرِ بْنِ غَالِبٍ۔",,,34922 34923,"اسْمُ أَبِی سِنَانٍ الأَسَدِیِّ : وَہْب بْنُ عَبْد اللہِ۔",,,34923 34924,"أَبُو عَیَّاش الزُّرَقِیُّ ، اسْمُہُ : زَیْدٌ۔",,,34924 34925,"أَمُّ سُلَیْمَانَ بْنِ عَمْرِو بْنِ الأَحْوَصِ ، اسْمُہَا : أُمُّ جُنْدُبٍ۔",,,34925 34926,"أَبُو سَعِیدٍ الأَحْمُسِیُّ : الْمُخَارِقُ بْنُ عَبْدِ اللہِ۔",,,34926 34927,"أَبُو ہَارُونَ الْعَبْدِیُّ : عُمَارَۃُ بْنُ جُوَیْنٍ۔",,,34927 34928,"أَبُو الْعُبَیْدِیْنُ : مُعَاوِیَۃَ بْنِ سَبْرَۃَ بْنِ حُصَیْنٍ۔",,,34928 34929,"وَاسْمُ أَبِی عِیَاضٍ : عَمْرُو بْنُ الأَسْوَدِ الَعَنْسِیُّ۔",,,34929 34930,وَاسْمُ أَبِی إِدْرِیسَ الْمَرْہَبِیِّ سَوَّارٌ۔,,,34930 34931,"أَبُو قَتَادَۃَ الْعَدَوِیُّ : تَمِیمُ بْنُ نَذِیرٍ۔",,,34931 34932,"أَبُو ہُبَیْرَۃَ : حُرَیْثُ بْنُ مَالِکٍ۔",,,34932 34933,"أَبُو ہُبَیْرَۃَ : یَحْیَی بْنُ عَبَّادٍ الأَنْصَارِیُّ۔",,,34933 34934,"أَبُو الْجَوْزَائِ ، اسْمُہُ : أَوْسُ بْنُ عَبْدِ اللہِ الرَّبَعِیِّ۔",,,34934 34935,"أَبُو الدَّہْمَائِ : قِرْفَۃُ بْنُ بُہَیْسٍ۔",,,34935 34936,"أَبُو ہَمَّامٍ : الْوَلِیدُ بْنُ قَیْسٍ السَّکُونِیُّ۔",,,34936 34937,"أَبُو إِبْرَاہِیمَ الأَنْصَارِیُّ ، یَقُولُونَ : ہُوَ عَبْدُ اللہِ بْنُ أَبِی قَتَادَۃَ۔",,,34937 34938,"اسْمُ أَبِی ہَارُونَ الْغَنَوِیُّ : إِبْرَاہِیمُ بْنُ الْعَلاَئِ۔",,,34938 34939,"اسْمُ أَبِی مَرْثَدٍ الْغَنَوِیُّ : کَنَّازُ بْنُ حُصَیْنٍ۔",,,34939 34940,"أَبُو إِدْرِیسَ الْخَوْلاَنِیُّ : عَائِذُ اللہِ۔",,,34940 34941,"اسْمُ أَبِی غَلاَّبٍ : یُونُسُ بْنُ جُبَیْرٍ۔",,,34941 34942,"اسْمُ أَبِی الْعَالِیَۃِ الْبَرَّائُ : کُلْثُومُ مَوْلًی لِقُرَیْشٍ۔",,,34942 34943,"وَاسْمُ أَبِی الْجَہْمِ : صُبَیْحٌ ، الَّذِی رَوَی عَنْہُ أَصْحَابُنَا۔",,,34943 34944,"أَبُو قُدَامَۃَ الَّذِی رَوَی عَنْہُ سِمَاکٌ ، اسْمُہُ : النُّعْمَانُ بْنُ حُمَیْدٍ۔",,,34944 34945,"أَبُو إِسْرَائِیلَ الْعَبْسِیُّ ، اسْمُہُ : إِسْمَاعِیلُ بْنُ إِسْحَاقَ۔",,,34945 34946,"أَبُو مَالِکٍ الأَشْعَرِیُّ ، اسْمُہُ : عَمْرٌو۔",,,34946 34947,"ابْنُ حَوَالَۃَ ، اسْمُہُ : عَبْدُ اللہِ۔",,,34947 34948,"أُمُّ الرَّائِحِ بِنْتُ صُلَیْعٍ ، اسْمُہَا : الرَّبَابُ۔",,,34948 34949,"أَبُو زَیْدٍ الأَنْصَارِیُّ ، اسْمُہُ : عَمْرُو بْنُ أَخْطَبَ۔",,,34949 34950,"اسْمُ أَبِی عُمَرَ الْبَہْرَانِیِّ : یَحْیَی بْنُ عُبَیْدٍ۔",,,34950 34951,"اسْمُ أَبِی بَلْجٍ الْفَزَارِیِّ : یَحْیَی بْنُ أَبِی سُلَیْمٍ۔",,,34951 34952,"اسْمُ أَبِی الْجُلاَسِ : عُقْبَۃُ بْنُ سَیَّارٍ۔",,,34952 34953,"اسْمُ أَبِی ہَمَّامٍ ، الَّذِی رَوَی عَنْہُ یَعْلَی بْنُ عَطَائٍ : عَبْدُ اللہِ بْنُ یَسَارٍ۔",,,34953 34954,"اسْمُ أَبِی قَزَعَۃَ ، الَّذِی رَوَی عَنْہُ حَمَّادُ بْنُ سَلَمَۃَ : سُوَیْدُ بْنُ حُجَیْرٍ البَاہْلِیُّ۔",,,34954 34955,"اسْمُ ابْنِ مُنَبِّہٍ : وَہْبٌ۔",,,34955 34956,"اسْمُ أُمِّ الْفَضْلِ : لُبَابَۃُ بِنْتُ الْحَارِثِ۔",,,34956 34957,"اسْمُ أَبِی نَعَامَۃَ الْحَنَفِیُّ : قَیْسُ بْنُ عَبَایَۃَ۔",,,34957 34958,"أَبُو نَعَامَۃَ الشَّقَرِیُّ : عَبْدُ رَبِّہِ۔",,,34958 34959,"أَبُو عَقِیلٍ : بَشیِرُ بْنُ عُقْبَۃَ۔",,,34959 34960,"أَبُو طِوَالَۃَ : عَبْدُ اللہِ بْنُ عَبْدِ الرَّحْمَنِ بْنِ مَعْمَرٍ۔",,,34960 34961,"أَبُو مَوْدُودٍ : عَبْدُ الْعَزِیزِ بْنُ أَبِی سُلَیْمَانَ۔",,,34961 34962,"اسْمُ أَبِی فِرَاسٍ ، مَوْلَی عَمْرِو بْنِ الْعَاصِ : یَزِیدُ بْنُ رَبَاحٍ۔",,,34962 34963,"أَبُو الزِّنْبَاعِ ، الَّذِی رَوَی عَنْہُ أَبُو حَیَّانَ : صَدَقَۃُ بْنُ صَالِحٍ۔",,,34963 34964,"اسْمُ أَبِی مُعَاوِیَۃَ : مُحَمَّدُ بْنُ خَازِمٍ۔",,,34964 34965,"اسْمُ أَبِی الأَحْوَصِ : سَلاَّمُ بْنُ سُلَیْمٍ۔",,,34965 34966,"اسْمُ أَبِی الْمُہَزِّمِ : یَزِیدُ بْنُ سُفْیَانَ۔",,,34966 34967,"اسْمُ أَبِی عَبْدِ اللہِ الْجَدَلِیِّ : عَبْدُ بْنُ عَبْدٍ۔",,,34967 34968,"مَاتَ أَبُو خَالِدٍ الْوَالِبِیُّ فِی سَنَۃِ مِئَۃٍ ، وَاسْمُہُ : ہُرْمُزُ۔",,,34968 34969,"وَیَذْکُرُونَ أَنَّ سَعِیدَ بْنَ الْمُسَیَّبِ ، قَالَ : وُلِدْتُ فِی سَنَتَیْنِ مَضَتَا مِنْ خِلاَفَۃِ عُمَرَ ، رَضِیَ اللَّہُ عَنْہُ۔",,,34969 34970,"وَیَذْکُرُونَ : أَنَّ أَبَا أَیُّوبَ الأَزْدِیَّ ، صَاحِبُ قَتَادَۃَ : یَحْیَی بْنُ مَالِکٍ۔",,,34970 34971,"وَاسْمُ أُمِّ ہَانِئٍ بِنْتِ أَبِی طَالِبٍ : ہِنْدٌ۔",,,34971 34972,"وَأُمِّ حَکِیمٍ بِنْتِ الزُّبَیْرِ ، اسْمُہَا : ضُبَاعَۃُ۔",,,34972 34973,"وَأَبُو حُمَیْدٍ السَّاعِدِیُّ : عَبْدُ الرَّحْمَنِ بْنُ سَعْدِ بْنِ الْمِقْدَامِ۔",,,34973 34974,"أُمُّ خَالِدِ بِنْتُ خَالِدٍ ، اسْمُہَا : أَمَۃُ بِنْتُ خَالِدٍ۔",,,34974 34975,"وَیَذْکُرُونَ : أَنَّ اسْمَ أَبِی مَعْبَدٍ ، مَوْلَی ابْنَ عَبَّاسٍ : نَافِذٌ۔",,,34975 34976,"وَیَذْکُرُونَ : أَنَّ اسْمَ أَبِی یَحْیَی الأَعْرَجِ : مِصْدَعٌ ، مَوْلَی مُعَاذِ ابْنِ عَفْرَائَ۔",,,34976 34977,"وَیَذْکُرُونَ : أَنَّ اسْمَ أُمِّ عَطِیَّۃَ الأَنْصَارِیَّۃِ : نُسَیْبَۃٌ۔",,,34977 34978,"أَبُو عَمَّارٍ الْہَمْدَانِیُّ : عَرِیبُ بْنُ حُمَیْدٍ۔",,,34978 34979,"أَبُو نَوْفَلِ بْنُ أَبِی عَقْرَبٍ ، اسْمُہُ : مُعَاوِیَۃُ بْنُ مُسْلِمِ بْنِ أَبِی عَقْرَبٍ۔",,,34979 34980,"أَبُو صِرْمَۃَ : مَالِکُ بْنُ قَیْسٍ الْقَارِیئُ۔",,,34980 34981,"أَبُو السَّوَداء : عَمْرُو بْنُ عِمْرَانَ۔",,,34981 34982,"وَبَلَغَنِی : أَنَّ اسْمَ أَبِی قَیْسِ بْنِ أَبِی حَازِمٍ : عَوْفُ بْنُ الْحَارِثِ۔",,,34982 34983,"وَبَلَغَنِی : أَنَّ اسْمَ ابْنِ مِرْبَعٍ : زَیْدُ بْنُ مِرْبَعٍ۔",,,34983 34984,"وَاسْمُ أَبِی ثَعْلَبَۃَ الْخُشَنِیِّ : لاَشِرُ بْنُ حُمَیْد۔",,,34984 34985,"وَاسْمُ أَبِی مُسْلِمٍ الْخَوْلاَنِیِّ : عَبْدُ اللہِ بْنُ ثَوْبٍ۔",,,34985 34986,"الْہَیْثَمُ بْنُ الأَسْوَدِ یُکَنَّی : أَبَا العُرْیان۔",,,34986 34987,"وَطَاوُوسٌ یُکَنَّی : أَبَا عَبْدِ الرَّحْمَنِ۔",,,34987 34988,"عَقِیلُ بْنُ أَبِی طَالِبٍ یُکَنَّی : أَبَا یَزِیدَ۔",,,34988 34989,"سَلْمَانُ الْفَارِسِیُّ : أَبُو عَبْدِ اللہِ۔",,,34989 34990,"صُہَیْبٌ : أَبُو یَحْیَی۔",,,34990 34991,"عطَائُ بْنُ أَبِی مَیْمُونَۃَ یُکَنَّی : بِأَبِی مُعَاذٍ۔",,,34991 34992,"نُعَیْمُ بْنُ زِیَادٍ ، الَّذِی رَوَی عَنْہُ عَامِرٌ ، یُکَنَّی : بِأَبِی یَحْیَی۔",,,34992 34993,"مُوسَی بْنُ یَزِیدَ بْنِ مُوہَبٍ یُکَنَّی : بِأَبِی عَبْدِ الرَّحْمَنِ۔",,,34993 34994,"مُوسَی بْنُ طَلْحَۃَ : أَبُو عِیسَی۔",,,34994 34995,"مُسْلِمُ بْنُ صُبَیْحٍ کُنْیَتُہُ : أَبُو الضُّحَی۔",,,34995 34996,"اسْمُ أَبِی عَطِیَّۃَ ، صَاحِبِ عَلِّیِّ بْنِ الأَقْمَرِ : عَمْرُو بْنُ أَبِی جُنْدُبٍ۔",,,34996 34997,"یَزِیدُ ، الَّذِی رَوَی عَنْہُ عِمْرَانُ ، یُکَنَّی : بِأَبِی البَزَریِّ۔",,,34997 34998,"زَیْدُ بْنُ صُوحَانَ : أَبُو عَائِشَۃَ۔",,,34998 34999,"کُنْیَۃُ مُوَرِّقٍ الْعِجْلِیِّ : أَبُو الْمُعْتَمِرِ۔",,,34999 35000,"عمْرُو بْنُ عَبَسَۃَ : أَبُو نَجِیحٍ۔",,,35000 35001,"ذُکِرَ : أَنَّ أَبا الْجَوْزَائِ قُتِلَ فی سَنَۃَ ثَلاَثٍ وَثَمَانِینَ فِی الْجَمَاجِمِ ،",,,35001 35002,وَعُقْبَۃُ بْنُ عَبْدِ الْغَافِرِ ،,,,35002 35003,وَعَبْدُ اللہِ بْنُ غَالِبٍ۔,,,35003 35004,"وَذُکِرَ : أَنَّ مُطَرِّفاً أَکْبَرُ مِنَ الْحَسَنِ بِعِشْرِینَ سَنَۃً",,,35004 35005,وَکَانَ أَخُوہُ أَبُو الْعَلاَئِ أَکْبَرَ مِنَ الْحَسَنِ بِعَشْرِ سِنِینَ,,,35005 35006,وَمَاتَ مُطَرِّفٌ بَعْدَ طَاعُونِ الْجَارِفِ۔,,,35006 35007,وَمَاتَ أَبُو نَضْرَۃَ ، وَأَبُو مِجْلَزٍ ، وَبَکْرٌ قَبْلَ الْحَسَنِ بِقَلِیلٍ۔,,,35007 35008,"وَذُکِرَ : أَنَّ الْحَسَنَ کَانَ أَکْبَرَ مِنْ مُحَمَّدٍ بِعَشْرِ سِنِینَ۔",,,35008 35009,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إِدْرِیسَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنِ الزُّہْرِیِّ ، قَالَ : کُنْتُ إِذَا لَقِیتُ عُبَیْدَ اللہِ ، فَکَأَنَّمَا أُفَجِّرُ بِہِ بَحْرًا۔",,,35009 35010,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ شُعْبَۃَ ، عَنْ عَبْدِ الْمَلِکِ بْنِ مَیْسَرَۃَ ، قَالَ : لَمْ یَلْقَ الضَّحَّاکُ ابْنَ عَبَّاسٍ ، إِنَّمَا لَقِیَ سَعِیدَ بْنَ جُبَیْرٍ بِالرَّیِّ ، فَأَخَذَ عَنْہُ التَّفْسِیرَ۔",,,35010 35011,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ بْنِ مُحَمَّدٍ ؛ أَنَّ فَاطِمَۃَ دُفِنَتْ لَیْلاً۔,,,35011 35012,"حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ ، حَدَّثَنَا سُلَیْمَانُ بْنُ الْمُغِیرَۃَ ، عَنْ حُمَیْدِ بْنِ ہِلاَلٍ ، عَنْ عَبْدِ اللہِ بْنِ مُغَفَّلٍ ، قَالَ: مَرَّ عَبْدُ اللہِ بْنُ سَلاَمٍ فِی أَرْضٍ إِلَی جَنْبِہِ ، فَقَالَ : إِنَّ ہَذِہِ رَأْسَ أَرْبَعِینَ سَنَۃً ، یَکُونُ عِنْدَہَا صُلْحٌ ، قَالَ : فَکَانَتْ جَمَاعَۃُ مُعَاوِیَۃَ عِنْدَ رَأْسِ الأَرْبَعِینَ۔",,,35012 35013,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ شُعْبَۃَ ، قَالَ: أَخْبَرَنِی مُشَاشٌ، قَالَ: سَأَلْتُ الضَّحَّاکَ: رَأَیْتَ ابْنَ عَبَّاسٍ؟ فَقَالَ: لاَ۔",,,35013 35014,"حَدَّثَنَا إِسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ مَنْصُورِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنِ الشَّعْبِیِّ ، قَالَ : مَاتَ أَبُو بَکْرٍ ، وَعُمَرُ ، وَعَلِیٌّ وَلَمْ یَجْمَعُوا الْقُرْآنَ۔",,,35014 35015,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، قَالَ : لَمَّا تُوُفِّیَ سَعِیدُ بْنُ أَبِی الْحَسَنِ وَجَدَ عَلَیْہِ الْحَسَنُ وَجْدًا شَدِیدًا ، فَکُلِّمَ فِی ذَلِکَ ، فَقَالَ : مَا سَمِعْتُ اللَّہَ عَابَ عَلَی یَعْقُوبَ الْحُزْنَ ، وَقَالَ الْحَسَنُ : لَمَّا تُوُفِّیَ عُتْبَۃُ بْنُ مَسْعُودٍ وَجَدَ عَلَیْہِ ابْنُ مَسْعُودٍ ، فَلَمَّا کُلِّمَ فِی ذَلِکَ ، قَالَ : أَمَا وَاللہِ إِذْ قضَی اللَّہُ مَا قَضَی ، مَا أُحِبُّ أَنِّی دَعَوْتُہُ فَأَجَابَنِی۔",,,35015 35016,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، حَدَّثَنَا إِسْرَائِیلُ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : حُدِّثْتُ ؛ أَنَّ قَیْسَ بْنَ سَعْدِ بْنِ عُبَادَۃَ خَدَمَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سَنَتَینَ۔",,,35016 35017,"حَدَّثَنَا عُبَیْدُ اللہِ ، قَالَ : أَخْبَرَنَا إِسْرَائِیلُ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ رَجُلٍ حَدَّثَہُ ؛ أَنَّ أَبَا بَکْرٍ طَافَ بِعَبْدِ اللہِ بْنِ الزُّبَیْرِ فِی خِرْقَۃٍ ، وَکَانَ أَوَّلَ مَوْلُودٍ وُلِدَ فِی الإِسْلاَمِ۔ (ابن ابی عاصم 121)",,,35017 35018,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، أَخْبَرَنَا ہَمَّامٌ ، قَالَ : دَخَلَ أَبُو دَاوُد الأَعْمَی عَلَی قَتَادَۃَ ، فَلَمَّا خَرَجَ ، قَالُوا لَہُ : ہَذَا یَرْوِی عَنْ ثَمَانیَۃَ عَشَرَ بَدْرِیًّا ، قَالَ : ہَذَا کَانَ سَائِلاً قَبْلَ الْجَارِفِ ، لاَ یَعْرِضُ لِشَیْئٍ مِنْ ہَذَا ، فَوَاللہِ مَا حَدَّثَنَا الْحَسَنُ ، وَسَعِید بْنُ الْمُسَیَّبِ عَنْ بَدْرِیٍّ مُشَافَہَۃً ، إِلاَّ سَعِیدٌ ، عَنْ سَعْدٍ۔",,,35018 35019,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، قَالَ : قُلْتُ لأَبِی عُبَیْدَۃَ : أَکَانَ عَبْدُ اللہِ مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لَیْلَۃَ الْجِنِّ ؟ قَالَ : لاَ۔",,,35019 35020,"حَدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : ذُکِرَ ذَلِکَ لِعَلْقَمَۃَ ، فَقَالَ : وَدِدْتُ أَنَّ صَاحِبَنَا کَانَ مَعَہُ۔ (مسلم 333)",,,35020 35021,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ فُضَیْلٍ ، عَنْ ہِشَامٍ ، قَالَ : قُلْتُ : کَمْ أَدْرَکَ الْحَسَنُ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ قَالَ : ثَلاَثِینَ وَمِئَۃٍ ، قَالَ : قُلْتُ : کَمْ أَدْرَکَ ابْنُ سِیرِینَ ؟ قَالَ : ثَلاَثِینَ۔",,,35021 35022,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ إِسْمَاعِیلَ ، عَنْ عَامِرٍ ، قَالَ : حدَّثَنِی عَبْدُ الرَّحْمَنِ بْنُ أَبْزَی ، قَالَ : صَلَّیْتُ مَعَ عُمَرَ عَلَی زَیْنَبَ ، وَکَانَتْ أَوَّلَ نِسَائِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَاتَتْ بَعْدَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,35022 35023,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، قَالَ : تُوُفِّیَتْ خَدِیجَۃُ قَبْلَ أَنْ یَخْرُجَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إِلَی الْمَدِینَۃِ بِسَنَتَیْنِ ، أَوْ قَرِیبًا مِنْ ذَلِکَ ، ثُمَّ نَکَحَ عَائِشَۃَ وَہِیَ بِنْتُ سِتِّ سِنِینَ ، وبَنَی بِہَا وَہِیَ بِنْتُ تِسْعٍ۔",,,35023 35024,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَنْ شَرِیکٍ ، قَالَ سَمِعْتُ أَبَا إِسْحَاقَ ، یَقُولُ : وُلِدْتُ لِسَنَتَیْنِ مِنْ إِمْرَۃِ عُثْمَانَ ، قَالَ شَرِیکٌ : وَدَفَنَّاہُ أَیَّامَ الْخَوَارِجِ۔",,,35024 35025,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللہِ الأَسَدِیِّ ، حَدَّثَنَا حِبَّانُ ، عَنْ مُجَالِدٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : کَتَبَ أَبُو مُوسَی إِلَی عُمَرَ : إِنَّہُ تَأْتِینَا کُتُبٌ مَا نَعْرِفُ تَأْرِیخَہَا ، فَأَرِّخْ ، فَاسْتَشَارَ أَصْحَابَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، فَقَالَ بَعْضُہُمْ : أَرِّخْ لِمَبْعَثِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَقَالَ بَعْضُہُمْ : أَرِّخْ لِمَوْتِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ عُمَرُ : أُؤَرِّخُ لِمُہَاجِرِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَإِنَّ مُہَاجِرَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَرْقٌ بَیْنَ الْحَقِّ وَالْبَاطِلِ ، فَأَرَّخَ۔",,,35025 35026,"أَبُوبَکْرٍ الصِّدِّیقُ : عَبْدُ اللہِ۔",,,35026 35027,"عَبْدُ اللہِ بْنُ الزُّبَیْرِ : أَبُو بَکْرٍ۔",,,35027 35028,"عمَرُ بْنُ الْخَطَّابِ : أَبُو حَفْصٍ۔",,,35028 35029,"عُثْمَانُ بْنُ عَفَّانَ : أَبُو عَبْدِ اللہِ ، وَیُکَنَّی : بِأَبِی عَمْرٍو۔",,,35029 35030,"حُذَیْفَۃُ : أَبُو عَبْدِ اللہِ۔",,,35030 35031,"الزُّبَیْرُ بْنُ الْعَوَّامِ : أَبُو عَبْدِ اللہِ۔",,,35031 35032,"جَرِیرُ بْنُ عَبْدِ اللہِ : أَبُو عَبْدِ اللہِ ، وَقَالَ بَعْضُہُمْ : أَبُو عَمْرٍو۔",,,35032 35033,"عَبْدُ اللہِ بْنُ مَسْعُودٍ : أَبُو عَبْدِ الرَّحْمَنِ۔",,,35033 35034,"ابْنُ عُمَرَ : أَبُو عَبْدِ الرَّحْمَنِ۔",,,35034 35035,"عَلِیُّ بْنُ أَبِی طَالِبٍ : أَبُو الْحَسَنِ۔",,,35035 35036,"سَعْدُ بْنُ أَبِی وَقَّاصٍ : أَبُو إِسْحَاقَ۔",,,35036 35037,"عَبَّاسُ بْنُ عَبْدِ الْمُطَّلِبِ : أَبُو الْفَضْلِ۔",,,35037 35038,"عَبْدُ اللہ بْنُ عَبَّاسٍ : أَبُو الْعَبَّاسِ۔",,,35038 35039,"أُبَیّ بْنُ کَعْبٍ : أَبُو الْمُنْذِرِ۔",,,35039 35040,"عِمْرَانُ بْنُ الْحُصَیْنِ : أَبُو نُجَیْدٍ۔",,,35040 35041,"خَالِدُ بْنُ زَیْدٍ : أَبُو أَیُّوبَ۔",,,35041 35042,"عُقْبَۃُ بْنُ عَمْرٍو : أَبُو مَسْعُودٍ۔",,,35042 35043,"أَنَسُ بْنُ مَالِکٍ : أَبُو حَمْزَۃَ۔",,,35043 35044,"الْحَسَنُ بْنُ عَلِیٍّ : أَبُو مُحَمَّدٍ۔",,,35044 35045,"الأَشْعَثُ بْنُ قَیْسٍ : أَبُو مُحَمَّدٍ۔",,,35045 35046,"الْحُسَیْنُ بْنُ عَلِیٍّ : أَبُو عَبْدِ اللہِ۔",,,35046 35047,"الْمِقْدَادُ بْنُ الأَسْوَدِ : أَبُو عَمْرٍو۔",,,35047 35048,"حَمْزَۃُ بْنُ عَبْدِ الْمُطَّلِبِ : أَبُو عُمَارَۃَ۔",,,35048 35049,"مُعَاوِیَۃُ : أَبُو عَبْدِ الرَّحْمَنِ۔",,,35049 35050,"عَبْدُ الرَّحْمَنِ بْنُ عَوْفٍ : أَبُو مُحَمَّدٍ۔",,,35050 35051,"خَالِدُ بْنُ الْوَلِیدِ : أَبُو سُلَیْمَانَ۔",,,35051 35052,"عَمَّارُ : أَبُو الْیَقْظَانِ۔",,,35052 35053,"طَلْحَۃُ بْنُ عُبَیْدِ اللہِ : أَبُو مُحَمَّدٍ۔",,,35053 35054,"المُغِیرَۃُ بْنُ شُعْبَۃَ : أَبُو عَبْدِ اللہِ۔",,,35054 35055,سَعْدُ بْنُ مَالِکَ ،,,,35055 35056,"وَعَمْرُو بْنُ حُرَیْثٍ : أَبُو سَعِیدٍ۔",,,35056 35057,"عَمْرُو بْنُ الْعَاصِ : أَبُو عَبْدِ اللہِ۔",,,35057 35058,"مَرْوَانُ بْنُ الْحَکَمِ : أَبُو عَبْدِ الْمَلِکِ۔",,,35058 35059,"شُرَیْحُ : أَبُو أُمَیَّۃَ۔",,,35059 35060,"سُوَیْد بْنُ غَفَلَۃَ : أَبُو أُمَیَّۃَ۔",,,35060 35061,"الأَسْوَدُ بْنُ یَزِیدَ : أَبُو عَمْرٍو۔",,,35061 35062,"عَلْقَمَۃُ : أَبُو شِبْلٍ۔",,,35062 35063,"مَسْرُوقٌ : أَبُو عَائِشَۃَ۔",,,35063 35064,"ابْنُ الْحَنَفِیَّۃِ : أَبُو الْقَاسِمِ۔",,,35064 35065,"سَعِیدُ بْنُ الْمُسَیَّبِ : أَبُو مُحَمَّدٍ۔",,,35065 35066,"عَبْدُ اللہِ بْنُ مَعْقِلٍ : أَبُو الْوَلِیدِ۔",,,35066 35067,"سَعِیدُ بْنُ جُبَیْرٍ : أَبُو عَبْدِ اللہِ۔",,,35067 35068,"مُجَاہِدٌ : أَبُو الْحَجَّاجِ۔",,,35068 35069,"عَطَائُ بْنُ أَبِی رَبَاحٍ : أَبُو مُحَمَّدٍ۔",,,35069 35070,"إِیَاسُ بْنُ مُعَاوِیَۃَ : أَبُو وَاثِلَۃَ۔",,,35070 35071,"ابْنُ سِیرِینَ : أَبُو بَکْرٍ۔",,,35071 35072,"الْحَسَنُ : أَبُو سَعِیدٍ۔",,,35072 35073,"الشَّعْبِیُّ : أَبُو عَمْرٍو۔",,,35073 35074,"إِبْرَاہِیمُ النَّخَعِیُّ : أَبُو عِمْرَانَ۔",,,35074 35075,"عَبْدُ الرَّحْمَنِ بْنُ أَبِی لَیْلَی : أَبُو عِیسَی۔",,,35075 35076,"عَبْدُ اللہِ بْنُ عُکَیْمٍ : أَبُو مَعْبَدٍ۔",,,35076 35077,"الْحَکَمُ بْنُ عُتَیْبَۃَ : أَبُو عَبْدِ اللہِ۔",,,35077 35078,"حَمَّادُ بْنُ أَبِی سُلَیْمَانَ : أَبُو إِسْمَاعِیلَ۔",,,35078 35079,"الْمُہَلَّبُ بْنُ أَبِی صُفْرَۃَ : أَبُو سَعِیدٍ۔",,,35079 35080,"وَاقِعُ بْنُ سَحْبَانَ : أَبُو عَقِیلٍ۔",,,35080 35081,"عَطَائُ بْنُ أَبِی مَیْمُونَۃَ : أَبُو مُعَاذٍ۔",,,35081 35082,"سَعْدُ بْنُ مُعَاذٍ : أَبُو عَمْرٍو۔",,,35082 35083,"عَمْرُو بْنُ شُعَیْبٍ : أَبُو إِبْرَاہِیمَ۔",,,35083 35084,"عَبْدُ اللہِ بْنُ عَمْرٍو : أَبُو مُحَمَّدٍ۔",,,35084 35085,"عَبْدُ اللہِ بْنُ الْحَارِثِ ، یُکْنَی : بِأَبِی الْوَلِیدِ۔",,,35085
