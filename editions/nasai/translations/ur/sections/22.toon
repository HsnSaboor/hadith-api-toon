{"hadithnumber": "2393", "text": "عبداللہ بن عمرو رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم میرے حجرے میں داخل ہوئے اور"}
{"hadithnumber": "2394", "text": "عبداللہ بن عمرو بن العاص رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم سے ذکر کیا گیا کہ"}
{"hadithnumber": "2395", "text": "ابوسلمہ بن عبدالرحمٰن بن عوف کہتے ہیں کہ  میں عبداللہ بن عمرو رضی اللہ عنہما کے پاس آیا۔ میں نے عرض"}
{"hadithnumber": "2396", "text": "عبداللہ بن عمرو رضی الله عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے ان سے فرمایا: ”ایک دن"}
{"hadithnumber": "2397", "text": "عبداللہ بن عمرو رضی الله عنہما کہتے ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم سے روزہ کا ذکر کیا تو"}
{"hadithnumber": "2398", "text": "عبداللہ بن عمرو رضی الله عنہما کہتے ہیں کہ  مجھ سے رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”ایک دن ر"}
{"hadithnumber": "2399", "text": "عبداللہ بن عمرو رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: مجھے خبر ملی ہے"}
{"hadithnumber": "2400", "text": "عبداللہ بن عمرو رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مجھ سے فرمایا، پھر راوی"}
{"hadithnumber": "2401", "text": "عبداللہ بن عمرو رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مجھ سے فرمایا: ”عبداللہ"}
{"hadithnumber": "2402", "text": "عبداللہ بن عمرو رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مجھ سے فرمایا: ”قرآن ایک"}
{"hadithnumber": "2403", "text": "عبداللہ بن عمرو بن العاص رضی الله عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کو خبر ملی کہ میں ر"}
{"hadithnumber": "2404", "text": "ابوقلابۃ ابوالملیح سے روایت کرتے ہیں کہ  انہوں نے کہا: میں تمہارے والد زید کے ساتھ عبداللہ بن عمرو ر"}
{"hadithnumber": "2405", "text": "عبداللہ بن عمرو رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مجھ سے فرمایا: ”مہینے می"}
{"hadithnumber": "2406", "text": "ابوذر رضی الله عنہ کہتے ہیں کہ  میرے حبیب صلی اللہ علیہ وسلم نے مجھے تین باتوں کی وصیت کی ہے میں انہ"}
{"hadithnumber": "2407", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مجھے تین چیزوں کا حکم دیا ہے: وتر"}
{"hadithnumber": "2408", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مجھے صلاۃ الضحیٰ  ( چاشت کی نماز"}
{"hadithnumber": "2409", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مجھے وتر پڑھ کر سونے، جمعہ کے دن"}
{"hadithnumber": "2410", "text": "ابوعثمان سے روایت ہے کہ  ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ میں نے رسول اللہ صلی اللہ علیہ وسلم کو کہ"}
{"hadithnumber": "2411", "text": "ابوذر رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے مہینے کے تین دن روزہ"}
{"hadithnumber": "2412", "text": "ابوعثمان ایک شخص سے روایت کرتے ہیں کہ  ابوذر رضی اللہ عنہ کہتے ہیں کہ میں نے رسول اللہ صلی اللہ علیہ"}
{"hadithnumber": "2413", "text": "عثمان بن ابی العاص رضی الله عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا:"}
{"hadithnumber": "2414", "text": "اس سند سے سعید بن ابی ہند نے روایت کی ہے کہ  عثمان بن ابی العاص رضی اللہ عنہ نے اسی طرح کہا ہے، اور"}
{"hadithnumber": "2415", "text": "عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم ہر مہینے میں تین دن روزہ رکھت"}
{"hadithnumber": "2416", "text": "عبداللہ بن عمر رضی الله عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم ہر مہینے تین دن روزے رکھت"}
{"hadithnumber": "2417", "text": "ہنیدہ خزاعی کہتے ہیں کہ  میں ام المؤمنین کے پاس آیا، اور میں نے انہیں کہتے ہوئے سنا کہ رسول اللہ صلی"}
{"hadithnumber": "2418", "text": "ام المؤمنین حفصہ رضی الله عنہا کہتی ہیں کہ  چار باتیں ایسی ہیں جنہیں نبی اکرم صلی اللہ علیہ وسلم نہی"}
{"hadithnumber": "2419", "text": "نبی اکرم صلی اللہ علیہ وسلم کی بعض بیویوں سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم ذی الحجہ کے ن"}
{"hadithnumber": "2420", "text": "نبی اکرم صلی اللہ علیہ وسلم کی ایک بیوی کہتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم  ( ذی الحجہ کے پہلے"}
{"hadithnumber": "2421", "text": "ام المؤمنین ام سلمہ رضی الله عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ہر مہینے میں تین دن۔ ہر"}
{"hadithnumber": "2422", "text": "جریر بن عبداللہ رضی الله عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”ہر مہینے میں تین"}
{"hadithnumber": "2423", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  ایک اعرابی رسول اللہ صلی اللہ علیہ وسلم کے پاس ایک بھنا ہوا خرگوش"}
{"hadithnumber": "2424", "text": "ابوذر رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ہمیں حکم دیا ہے کہ ہم مہینے کے تین ر"}
{"hadithnumber": "2425", "text": "ابوذر رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ہمیں حکم دیا ہے کہ ہم ہر مہینے کے ای"}
{"hadithnumber": "2426", "text": "موسیٰ بن طلحہ کہتے ہیں کہ  میں نے ابوذر رضی اللہ عنہ کو مقام ربذہ میں کہتے سنا کہ رسول اللہ صلی اللہ"}
{"hadithnumber": "2427", "text": "ابوذر رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے ایک شخص سے فرمایا: ”تم تیرہویں، چو"}
{"hadithnumber": "2428", "text": "ابوذر رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے ایک شخص کو تیرہویں، چودہویں، اور پ"}
{"hadithnumber": "2429", "text": "ابی بن کعب رضی الله عنہ کہتے ہیں کہ  ایک اعرابی  ( دیہاتی )  رسول اللہ صلی اللہ علیہ وسلم کے پاس آیا"}
{"hadithnumber": "2430", "text": "موسیٰ بن طلحہ سے روایت ہے کہ  ایک شخص نبی اکرم صلی اللہ علیہ وسلم کے پاس خرگوش لے کر آیا، آپ نے اس ک"}
{"hadithnumber": "2431", "text": "موسیٰ بن طلحہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کے پاس ایک خرگوش لایا گیا جسے ایک شخص نے بھون"}
{"hadithnumber": "2432", "text": "قتادہ بن ملحان (ابن منہال) رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم بیض کے ان تینوں"}
{"hadithnumber": "2433", "text": "ابوالمنہال قتادہ بن ملحان رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے انہیں ایام بی"}
{"hadithnumber": "2434", "text": "قدامہ (قتادہ بن ملحان) بن ملحان رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ہمیں روشن چان"}
