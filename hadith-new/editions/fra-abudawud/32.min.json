{"metadata":{"name":"Sunan Abu Dawud","section":{"1":"Purification (Kitab Al-Taharah)"},"section_detail":{"1":{"hadithnumber_first":1,"hadithnumber_last":390,"arabicnumber_first":1,"arabicnumber_last":390}}},"hadiths":[{"hadithnumber":32,"arabicnumber":32,"text":"Rapporté par Hafsah (la mère des croyants) رضي الله عنها : Le Prophète ﷺ utilisait sa main droite pour manger et boire, et sa main gauche pour d’autres usages","grades":[{"name":"Al-Albani","grade":"Sahih"},{"name":"Muhammad Muhyi Al-Din Abdul Hamid","grade":"Sahih"},{"name":"Shuaib Al Arnaut","grade":"Sahih Lighairihi"},{"name":"Zubair Ali Zai","grade":"Isnaad Hasan"}],"reference":{"book":1,"hadith":32}}]}