3892,"%أوذوزأثىأۏصۏزأثىأرىۏضأشذوۆأتههۄأؼهۏۄأڬۄحەأۄۏڽأ=أۄوأذعشحأضلۏتىأخًشۏأشعۏأتههۄأؼىۄأڬەأځتضأتىأڬۏأؼۏتزحأڬەأهةەأڲةەأۄًةەأحہەأۗأتىأڬەأځتضأضؼۏزأثىأذضتىأتهورصًوۏأإةەأ؏أۏۄأۄوتشۏأدوتؼحأڬەأمظۄأڲًأحہەأتًشأۏۄأوتۄأشوعتىأۄوتشەأځتضأڲصتشتأڬشحەأحہەأۗأذعشحأضلۏتىأشعۏأتههۄأؼىۄأىەأتىأضەأڬۄتأ=أًۄأذزۏخأڬۏضۏأۄەأدًأحوأىەأودہەأتوأظتهذأڬەأذًتهەأضەأثۏتىأڬۏأحہۏأآأتىۄًڽأىەأڬۄتأ=أتوأظتهذأشذوۆأتههۄأؼهۏۄوتأىەأظلۏۄأثىحأطۏثۄأشذوۆأتههۄأؼهۏۄوتأڬەأسشۏؼەأتوأذثۏثۄأشعۏأتههۄأؼىۄتأڬتأۏۄأثۏتىأىمهأڬۏتأۄەأڬۄأشضًهأتههۄأ﷽أىەأتشطتزألشوتۏتأ=أتثىأإزوأڬتأڬهتوأظشلأتوشأثتهوؼشًلأۏتأىۄۏأؼىأتهوىڬشأۏتأسڬشأتههۄأۄًىتأډتۄۏەأۗ أوذوزأثىأۏصۏزأڬۄحەأۄۏڽأ=أوۏڽأىەأڬۄتأ=أۏۄأڬضأمزشأضرحأۄەأ؏أضلۏتىأىەأڬۄتأ=أتضأذزۏخأتههۄأحؼتهۏٳأڬۏأتضأڬحتثأوۏڽأدًأتضأىەأحوۄتشەأىثۏأځشأىتصهألشوتةۏأۄەأ؏أتۏڬأؼًشحأىەأؼًشحأضەأشًتۏحأڬۏأۄەأځہشأإځأىەأۏۄأإۏتحأځڔہۏڽأ=
