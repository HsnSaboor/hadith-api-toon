hadiths[198]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}:
3349,3349۔ حَدَّثَنَا عَمْرُو بْنُ زُرَارَۃَ حَدَّثَنَا جَرِیرٌ عَنْ قَابُوْسَ عَنْ أَبِیْہِ عَنِ ابْنِ عَبَّاسٍ قَالَ قَالَ رَسُولُ اللّٰہِ ﷺ إِنَّ الرَّجُلَ الَّذِی لَیْسَ فِیْ جَوْفِہِ مِنَ الْقُرْآنِ شَیْئٌ کَالْبَیْتِ الْخَرِبِ ۔1,,takhreej: !حسن: اخرجہ احمد1/223والترمذی،کتاب ثواب القران،با الذی لیس فی جوقہ قرآن کالبیت الخرب (2914) والحاکم فی المستدرک1/554,3349
3350,3350۔ أَخْبَرَنَا عَبْدُ اللّٰہِ بْنُ خَالِدِ بْنِ حَازِمٍ حَدَّثَنَا مُحَمَّدُ بْنُ سَلَمَۃَ حَدَّثَنَا أَبُوْ سِنَانٍ عَنْ أَبِیْ إِسْحٰقَ عَنْ أَبِیْ الْأَحْوَصِ عَنْ عَبْدِ اللّٰہِ قَالَ إِنَّ ہٰذَا الْقُرْآنَ مَأْدُبَۃُ اللّٰہِ فَخُذُوْا مِنْہُ مَا اسْتَطَعْتُمْ فَإِنِّی لَا أَعْلَمُ شَیْئًا أَصْفَرَ مِنْ خَیْرٍ مِنْ بَیْتٍ لَیْسَ فِیہِ مِنْ کِتَابِ اللّٰہِ شَیْئٌ وَإِنَّ الْقَلْبَ الَّذِی لَیْسَ فِیہِ مِنْ کِتَابِ اللّٰہِ شَیْئٌ خَرِبٌ کَخَرَابِ الْبَیْتِ الَّذِی لَا سَاکِنَ لَہٗ ۔1,,takhreej: ! صحیح: أخرجہ ابن ابی شیبہ10/486(10081) وعبدالرزاق(5998) والطبرانی فی الکبیر9/183(8642),3350
3351,3351۔ حَدَّثَنَا أَبُوْ عَامِرٍ قَبِیصَۃُ أَخْبَرَنَا سُفْیَانُ عَنْ عَطَائِ بْنِ السَّائِبِ عَنْ أَبِیْ الْأَحْوَصِ عَنْ عَبْدِ اللّٰہِ قَالَ تَعَلَّمُوا ہٰذَا الْقُرْآنَ فَإِنَّکُمْ تُؤْجَرُونَ بِتِلَاوَتِہٖ بِکُلِّ حَرْفٍ عَشْرَ حَسَنَاتٍ أَمَا إِنِّی لَا أَقُولُ بِ{ الم }وَلَکِنْ بِأَلِفٍ وَلَامٍ وَمِیمٍ بِکُلِّ حَرْفٍ عَشْرُ حَسَنَاتٍ۔2,,takhreej: @ صحیح: أخرجہ الطبرانی فی الکبیر(8649-8648) وعبدالرزاق(5993) وابن ابی شیبہ10/361(9981),3351
3352,3352۔ حَدَّثَنَا مُعَاذُ بْنُ ہَانِئٍ حَدَّثَنَا حَرْبُ بْنُ شَدَّادٍ حَدَّثَنَا یَحْیَی ہُوَ ابْنُ أَبِیْ کَثِیْرٍ حَدَّثَنِی حَفْصُ بْنُ عِنَانٍ الْحَنَفِیُّ أَنَّ أَبَا ہُرَیْرَۃَ کَانَ یَقُولُ إِنَّ الْبَیْتَ لَیَتَّسِعُ عَلَی أَہْلِہٖ وَتَحْضُرُہُ الْمَلَائِکَۃُ وَتَہْجُرُہُ الشَّیَاطِیْنُ وَیَکْثُرُ خَیْرُہٗ أَنْ یُقْرَأَ فِیہِ الْقُرْآنُ وَإِنَّ الْبَیْتَ لَیَضِیْقُ عَلٰی أَہْلِہٖ وَتَہْجُرُہُ الْمَلَائِکَۃُ وَتَحْضُرُہُ الشَّیَاطِینُ وَیَقِلُّ خَیْرُہٗ أَنْ لَا یُقْرَأَ فِیہِ الْقُرْآنُ ۔3,,takhreej: # صحیح: أخرجہ ابن ابی شیبہ10/487(10076) وابن المبارک فی الزہد(790),3352
3353,3353۔ حَدَّثَنَا عَبْدُ اللّٰہِ بْنُ یَزِیدَ حَدَّثَنَا ابْنُ لَہِیعَۃَ عَنْ مِشْرَحِ بْنِ ہَاعَانَ قَالَ سَمِعْتُ عُقْبَۃَ ابْنَ عَامِرٍ یَقُوْلُ سَمِعْتُ رَسُولَ اللّٰہِ ﷺ یَقُولُ لَوْ جُعِلَ الْقُرْآنُ فِیْ إِہَابٍ ثُمَّ أُلْقِیَ فِیْ النَّارِ مَا احْتَرَقَ ۔1,,takhreej: !ضعیف: أخرجہ الطبرانی فی الکبیر17/308(850) والبیہقی فی شعب الإیمان(2699) وابن عدی فی الکامل 6/246,3353
3354,3354۔ حَدَّثَنَا عَبْدُ اللّٰہِ بْنُ جَعْفَرٍ الرَّقِّیُّ عَنْ عُبَیْدِ اللّٰہِ بْنِ عَمْرٍو عَنْ زَیْدِ بْنِ أَبِیْ أُنَیْسَۃَ عَنْ عَاصِمٍ عَنْ أَبِیْ صَالِحٍ قَالَ سَمِعْتُ أَبَا ہُرَیْرَۃَ یَقُولُ اقْرَئُوا الْقُرْآنَ فَإِنَّہٗ نِعْمَ الشَّفِیعُ یَوْمَ الْقِیَامَۃِ إِنَّہٗ یَقُولُ یَوْمَ الْقِیَامَۃِ یَا رَبِّ حَلِّہِ حِلْیَۃَ الْکَرَامَۃِ فَیُحَلَّی حِلْیَۃَ الْکَرَامَۃِ یَا رَبِّ اکْسُہٗ کِسْوَۃَ الْکَرَامَۃِ فَیُکْسَی کِسْوَۃَ الْکَرَامَۃِ یَا رَبِّ أَلْبِسْہُ تَاجَ الْکَرَامَۃِ یَا رَبِّ ارْضَ عَنْہُ فَلَیْسَ بَعْدَ رِضَاکَ شَیْئٌ۔2,,takhreej: @حسن: أخرجہ الترمذی،کتاب ثواب القرآن،باب الذی لیس فی جوفہ قران…(2916) والحاکم1/552والبیہقی فی شعب الإیمان(1997-1996),3354
3355,3355۔ حَدَّثَنَا مُوسَی بْنُ خَالِدٍ حَدَّثَنَا إِبْرَاہِیمُ بْنُ مُحَمَّدٍ الْفَزَارِیُّ عَنْ سُفْیَانَ عَنْ عَاصِمٍ عَنْ مُجَاہِدٍ عَنِ ابْنِ عُمَرَ قَالَ یَجِیئُ الْقُرْآنُ یَشْفَعُ لِصَاحِبِہٖ یَقُولُ یَا رَبِّ لِکُلِّ عَامِلٍ عُمَالَۃٌ مِنْ عَمَلِہٖ وَإِنِّی کُنْتُ أَمْنَعُہُ اللَّذَّۃَ وَالنَّوْمَ فَأَکْرِمْہُ فَیُقَالُ ابْسُطْ یَمِینَکَ فَتُمْلَأُ مِنْ رِضْوَانِ اللّٰہِ ثُمَّ یُقَالُ ابْسُطْ شِمَالَکَ فَتُمْلَأُ مِنْ رِضْوَانِ اللّٰہِ وَیُکْسَی کِسْوَۃَ الْکَرَامَۃِ وَیُحَلَّی بِحِلْیَۃِ الْکَرَامَۃِ وَیُلْبَسُ تَاجَ الْکَرَامَۃِ ۔1,,takhreej: !حسن: أخرجہ ابن ابی شیبہ 10/497-496(10099-10098) وابن منصور1/113(22),3355
3356,3356۔ أَخْبَرَنَا مُوسَی بْنُ خَالِدٍ حَدَّثَنَا إِبْرَاہِیْمُ بْنُ مُحَمَّدٍ الْفَزَارِیُّ عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللّٰہِ عَنِ الْمُسَیَّبِ بْنِ رَافِعٍ عَنْ أَبِیْ صَالِحٍ قَالَ الْقُرْآنُ یَشْفَعُ لِصَاحِبِہٖ فَیُکْسٰی حُلَّۃَ الْکَرَامَۃِ ثُمَّ یَقُولُ رَبِّ زِدْہُ فَیُکْسَی تَاجُ الْکَرَامَۃِ قَالَ فَیَقُولُ رَبِّ زِدْہُ فَاٰتِہٖ وَاٰتِہٖ قَالَ : یَقُولُ رِضَائِیْ قَالَ أَبُوْ مُحَمَّد قَالَ وُہَیْبُ بْنُ الْوَرْدِ اجْعَلْ قِرَائَتَکَ الْقُرْآنَ عِلْمًا وَلَا تَجْعَلْہُ عَمَلًا ۔2,,takhreej: @جید: أخرجہ ابن ابی شیبہ10/495(10097),3356
3357,3357۔ حَدَّثَنَا مُوسَی بْنُ خَالِدٍ حَدَّثَنَا إِبْرَاہِیمُ الْفَزَارِیُّ عَنِ الْأَعْمَشِ عَنْ أَبِیْ صَالِحٍ عَنْ أَبِیْ ہُرَیْرَۃَ قَالَ قَالَ رَسُولُ اللّٰہِ ﷺ أَیُحِبُّ أَحَدُکُمْ إِذَا أَتَی أَہْلَہٗ أَنْ یَجِدَ ثَـلَاثَ خَلِفَاتٍ سِمَانٍ) ) قَالُوا نَعَمْ یَا رَسُولَ اللّٰہِ قَالَ:(( فَثَـلَاثُ آیَاتٍ یَقْرَؤُہُنَّ أَحَدُکُمْ خَیْرٌ لَہٗ مِنْہُنَّ) ) ۔1,,takhreej: ! صحیح: أخرجہ مسلم،کتاب صلاۃ المسافرین،باب فضل قراۃ القران وتعلمہ(872)وابن ماجہ،کتاب الأدب،باب ثواب القران(8782 ),3357
3358,3358۔ حَدَّثَنَا جَعْفَرُ بْنُ عَوْنٍ حَدَّثَنَا إِبْرَاہِیمُ ہُوَ الْہَجَرِیُّ عَنْ أَبِیْ الْأَحْوَصِ عَنْ عَبْدِ اللّٰہِ قَالَ إِنَّ ہٰذَا الْقُرْآنَ مَأْدُبَۃُ اللّٰہِ فَتَعَلَّمُوْا مِنْ مَأْدُبَتِہٖ مَا اسْتَطَعْتُمْ إِنَّ ہٰذَا الْقُرْآنَ حَبْلُ اللّٰہِ وَالنُّورُ الْمُبِینُ وَالشِّفَائُ النَّافِعُ عِصْمَۃٌ لِمَنْ تَمَسَّکَ بِہٖ وَنَجَاۃٌ لِمَنَ اتَّبَعَہُ لَا یَزِیْغُ فَیَسْتَعْتِبُ وَلَا یَعْوَجُّ فَیُقَوَّمُ وَلَا تَنْقَضِیْ عَجَائِبُہٗ وَلَا یَخْلَقُ عَنْ کَثْرَۃِ الرَّدِّ فَاتْلُوْہُ فَإِنَّ اللّٰہَ یَأْجُرُکُمْ عَلَی تِلَاوَتِہٖ بِکُلِّ حَرْفٍ عَشْرَ حَسَنَاتٍ أَمَا إِنِّیْ لَا أَقُولُ الم وَلَکِنْ بِأَلِفٍ وَلَامٍ وَمِیمٍ ۔1,,takhreej: @ضعیف: ابراہیم ہجری ضعیف ہیں۔أخرجہ عبدالرزاق(6017)والبیہقی فی شعب الإیمان(1980) والحاکم 1/555,3358
3359,3359۔ حَدَّثَنَا جَعْفَرُ بْنُ عَوْنٍ حَدَّثَنَا أَبُوْ حَیَّانَ عَنْ یَزِیْدَ بْنِ حَیَّانَ عَنْ زَیْدِ بْنِ أَرْقَمَ قَالَ قَامَ رَسُولُ اللّٰہِ ﷺ یَوْمًا خَطِیبًا فَحَمِدَ اللّٰہَ وَأَثْنٰی عَلَیْہِ ثُمَّ قَالَ {یَا أَیُّہَا النَّاسُ إِنَّمَا أَنَا بَشَرٌ یُوْشِکُ أَنْ یَأْتِیَنِیْ رَسُولُ رَبِّیْ فَأُجِیْبَہٗ وَإِنِّیْ تَارِکٌ فِیکُمْ الثَّقَلَیْنِ أَوَّلُہُمَا کِتَابُ اللّٰہِ فِیہِ الْہُدَی وَالنُّورُ فَتَمَسَّکُوْا بِکِتَابِ اللّٰہِ وَخُذُوْا بِہٖ) ) فَحَثَّ عَلَیْہِ وَرَغَّبَ فِیہِ ثُمَّ قَالَ:(( وَأَہْلَ بَیْتِی أُذَکِّرُکُمْ اللّٰہَ فِیْ أَہْلِ بَیْتِی ثَـلَاثَ مَرَّاتٍ ) ) ۔1,,takhreej: ! صحیح: أخرجہ احمد4/367-366 ومسلم،کتاب فضائل الصحابہ،باب فضائل علی بن ابی طالب(2408),3359
3360,3360۔ حَدَّثَنَا جَعْفَرُ بْنُ عَوْنٍ أَخْبَرَنَا الْأَعْمَشُ عَنْ أَبِیْ وَائِلٍ قَالَ قَالَ عَبْدُ اللّٰہِ إِنَّ ہٰذَا الصِّرَاطَ مُحْتَضَرٌ تَحْضُرُہُ الشَّیَاطِیْنُ یُنَادُوْنَ یَا عَبْدَ اللّٰہِ ہٰذَا الطَّرِیْقُ فَاعْتَصِمُوْا بِحَبْلِ اللّٰہِ فَإِنَّ حَبْلَ اللّٰہِ الْقُرْآنُ ۔2,,takhreej: @صحیح: أخرجہ البیہقی فی شعب الإیمان(2025) والطبرانی فی الکبیر9/340(9031) وابن منصور 3/1083 (519),3360
3361,3361۔ أَخْبَرَنَا أَبُوْ الْمُغِیرَۃِ حَدَّثَنَا عَبْدَۃُ عَنْ خَالِدِ بْنِ مَعْدَانَ قَالَ إِنَّ قَارِئَ الْقُرْآنِ وَالْمُتَعَلِّمَ تُصَلِّی عَلَیْہِمْ الْمَلَائِکَۃُ حَتّٰی یَخْتِمُوا السُّوْرَۃَ فَإِذَا أَقْرَأَ أَحَدُکُمْ السُّوْرَۃَ فَلْیُؤَخِّرْ مِنْہَا آیَتَیْنِ حَتّٰی یَخْتِمَہَا مِنْ آخِرِ النَّہَارِ کَیْ مَا تُصَلِّی الْمَلَائِکَۃُ عَلَی الْقَارِئِ وَالْمُقْرِئِ مِنْ أَوَّلِ النَّہَارِ إِلٰی آخِرِہِ ۔1,,takhreej: ! جید: أخرجہ ابن ابی شیبہ10/505(10128),3361
3362,3362۔ أَخْبَرَنَا الْحَکَمُ بْنُ نَافِعٍ أَخْبَرَنَا حَرِیزٌ عَنْ شُرَحْبِیلَ بْنِ مُسْلِمٍ الْخَوْلَانِیِّ عَنْ أَبِیْ أُمَامَۃَ أَنَّہٗ کَانَ یَقُولُ اقْرَؤُوا الْقُرْآنَ وَلَا تَغُرَّنَّکُمْ ہَذِہِ الْمَصَاحِفُ الْمُعَلَّقَۃُ فَإِنَّ اللّٰہَ لَنْ یُعَذِّبَ قَلْبًا وَعَی الْقُرْآنَ ۔2,,takhreej: @صحیح: أخرجہ ابن ابی شیبہ11/505(10128),3362
3363,3363۔ حَدَّثَنَا عَبْدُ اللّٰہِ بْنُ صَالِحٍ حَدَّثَنِی مُعَاوِیَۃُ بْنُ صَالِحٍ عَنْ سُلَیْمِ بْنِ عَامِرٍ عَنْ أَبِیْ أُمَامَۃَ الْبَاہِلِیِّ قَالَ اقْرَئُوا الْقُرْآنَ وَلَا یَغُرَّنَّکُمْ ہَذِہِ الْمَصَاحِفُ الْمُعَلَّقَۃُ فَإِنَّ اللّٰہَ لَا یُعَذِّبُ قَلْبًا وَعَی الْقُرْآنَ ۔1,,takhreej: !صحیح: سابقہ حدیث ہی مکرر آئی ہے۔,3363
3364,3364۔ أَخْبَرَنَا مُحَمَّدُ بْنُ یُوسُفَ حَدَّثَنَا مِسْعَرٌ عَنْ مَعْنِ بْنِ عَبْدِ الرَّحْمَنِ عَنِ ابْنِ مَسْعُودٍ قَالَ لَیْسَ مِنْ مُؤَدِّبٍ إِلَّا وَہُوَ یُحِبُّ أَنْ یُؤْتَی أَدَبُہٗ وَإِنَّ أَدَبَ اللّٰہِ الْقُرْآنُ ۔2,,takhreej: @ صحیح: یہ (3350) حدیث کی ایک طرف ہے۔,3364
3365,3365۔ حَدَّثَنَا سَہْلُ بْنُ حَمَّادٍ حَدَّثَنَا شُعْبَۃُ عَنْ عَبْدِ الْمَلِکِ بْنِ مَیْسَرَۃَ عَنْ أَبِیْ الْأَحْوَصِ قَالَ کَانَ عَبْدُ اللّٰہِ یَقُولُ إِنَّ ہٰذَا الْقُرْآنَ مَأْدُبَۃُ اللّٰہِ فَمَنْ دَخَلَ فِیہِ فَہُوَ آمِنٌ ۔3,,takhreej: # صحیح: سابقہ (3350) کا ایک کنارہ ہے۔,3365
3366,3366۔ أَخْبَرَنَا یَحْیَی بْنُ حَمَّادٍ حَدَّثَنَا أَبُوْ عَوَانَۃَ عَنِ الْأَعْمَشِ عَنْ إِبْرَاہِیْمَ عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ عَنْ عَبْدِ اللّٰہِ قَالَ مَنْ أَحَبَّ الْقُرْآنَ فَلْیُبْشِرْ ۔4,,takhreej: $ صحیح: أخرجہ ابن ابی شیبہ10/406(10129) وابن منصور1/12(3),3366
3367,3367۔ حَدَّثَنَا یَعْلَی حَدَّثَنَا الْأَعْمَشُ عَنْ إِبْرَاہِیمَ عَنْ عَبْدِ الرَّحْمٰنِ بْنِ یَزِیْدَ عَنْ عَبْدِ اللّٰہِ قَالَ مَنْ أَحَبَّ الْقُرْآنَ فَلْیُبْشِرْ ۔5,,takhreej: %صحیح: سابقہ حدیث ہی مکرر منقول ہے۔,3367
3368,3368۔ حَدَّثَنَا یَزِیدُ بْنُ ہَارُوْنَ أَنْبَأَنَا ہَمَّامٌ عَنْ عَاصِمِ بْنِ أَبِیْ النُّجُودِ عَنِ الشَّعْبِیِّ أَنَّ ابْنَ مَسْعُوْدٍ کَانَ یَقُوْلُ یَجِیْئُ الْقُرْآنُ یَوْمَ الْقِیَامَۃِ فَیَشْفَعُ لِصَاحِبِہٖ فَیَکُونُ لَہٗ قَائِدًا إِلٰی الْجَنَّۃِ وَیَشْہَدُ عَلَیْہِ وَیَکُونُ لَہٗ سَائِقًا إِلٰی النَّارِ ۔1,,takhreej: ! حسن: أخرجہ ابن ابی شیبہ10/497(10102) وابن الضر یس فی فضائل القرآن (108),3368
3369,3369۔ حَدَّثَنَا مُسْلِمُ بْنُ إِبْرَاہِیمَ حَدَّثَنَا الْحَسَنُ بْنُ أَبِیْ جَعْفَرٍ حَدَّثَنَا بُدَیْلٌ عَنْ أَنَسٍ قَالَ قَالَ رَسُولُ اللّٰہِ ﷺ إِنَّ لِلَّہِ أَہْلِیْنَ مِنَ النَّاسِ قِیلَ یَا رَسُولَ اللّٰہِ مَنْ ہُمْ قَالَ أَہْلُ الْقُرْآنِ ۔2,,takhreej: @ صحیح: أخرجہ ابن ماجہ فی المقدمۃ،باب فضل من تعلم القران وعلمہ(215) والحاکم/وابونعیم فی الحلیۃ9/40,3369
3370,3370۔حَدَّثَنَا عَمْرُو بْنُ عَاصِمٍ حَدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ عَنْ عَاصِمِ بْنِ بَہْدَلَۃَ عَنْ مُغِیثٍ عَنْ کَعْبٍ قَالَ عَلَیْکُمْ بِالْقُرْآنِ فَإِنَّہُ فَہْمُ الْعَقْلِ وَنُورُ الْحِکْمَۃِ وَیَنَابِیْعُ الْعِلْمِ وَأَحْدَثُ الْکُتُبِ بِالرَّحْمَنِ عَہْدًا وَقَالَ فِیْ التَّوْرَاۃِ یَا مُحَمَّدُ إِنِّی مُنَزِّلٌ عَلَیْکَ تَوْرَاۃً حَدِیثَۃً تَفْتَحُ فِیہَا أَعْیُنًا عُمْیًا وَآذَانًا صُمًّا وَقُلُوبًا غُلْفًا ۔3,,takhreej: # حسن: أخرجہ ابو عبید فی فضائل القرآن(ص77)وابن ابی شیبہ11/481(11787),3370
3371,3371۔ حَدَّثَنَا سَہْلُ بْنُ حَمَّادٍ حَدَّثَنَا شُعْبَۃُ حَدَّثَنَا زِیَادُ بْنُ مِخْرَاقٍ عَنْ أَبِیْ إِیَاسٍ عَنْ أَبِیْ کِنَانَۃَ عَنْ أَبِیْ مُوسَی أَنَّہٗ قَالَ إِنَّ ہٰذَا الْقُرْآنَ کَائِنٌ لَکُمْ أَجْرًا وَکَائِنٌ لَکُمْ ذِکْرًا وَکَائِنٌ بِکُمْ نُورًا وَکَائِنٌ عَلَیْکُمْ وِزْرًا اتَّبِعُوا الْقُرْآنَ وَلَا یَتَّبِعْکُمْ الْقُرْآنُ فَإِنَّہُ مَنْ یَتَّبِعِ الْقُرْآنَ یَہْبِطْ بِہٖ فِیْ رِیَاضِ الْجَنَّۃِ وَمَنْ اتَّبَعَہُ الْقُرْآنُ یَزُخُّ فِیْ قَفَاہُ فَیَقْذِفُہٗ فِیْ جَہَنَّمَ قَالَ أَبُوْْ مُحَمَّد یَزُخُّ یَدْفَعُ۔1,,takhreej: ! صحیح: ابو کنانہ شرط ابن حبان پر ہے۔ أخرجہ ابن ابی شیبہ10/484(10063)وابن منصور 1/49 (8) والبیہقی فی شعب الإیمان(2024-2023),3371
3372,3372۔ حَدَّثَنَا عَبْدُ اللّٰہِ بْنُ یَزِیدَ حَدَّثَنَا مُوسَی بْنُ أَیُّوْبَ قَالَ سَمِعْتُ عَمِّیْ إِیَاسَ بْنَ عَامِرٍ یَقُولُ أَخَذَ عَلِیُّ بْنُ أَبِیْ طَالِبٍ بِیَدِیْ ثُمَّ قَالَ إِنَّکَ إِنْ بَقِیتَ سَیَقْرَأُ الْقُرْآنَ ثَـلَاثَۃُ أَصْنَافٍ فَصِنْفٌ لِلَّہِ وَصِنْفٌ لِلْجِدَالِ وَصِنْفٌ لِلدُّنْیَا وَمَنْ طَلَبَ بِہٖ أَدْرَکَ ۔2,,takhreej: @ صحیح: (مسند علی)(734),3372
3373,3373۔ حَدَّثَنَا سُلَیْمَانُ بْنُ حَرْبٍ عَنْ حَمَّادِ بْنِ زَیْدٍ عَنْ أَیُّوْبَ عَنْ أَبِیْ قِلَابَۃَ أَنَّ رَجُلًا قَالَ لِأَبِیْ الدَّرْدَائِ إِنَّ إِخْوَانَکَ مِنْ أَہْلِ الْکُوفَۃِ مِنْ أَہْلِ الذِّکْرِ یُقْرِئُونَکَ السَّلَامَ فَقَالَ وَعَلَیْہِمُ السَّلَامُ وَمُرْہُمْ فَلْیُعْطُوا الْقُرْآنَ بِخَزَائِمِہِمْ فَإِنَّہٗ یَحْمِلُہُمْ عَلَی الْقَصْدِ وَالسُّہُولَۃِ وَیُجَنِّبُہُمْ الْجَوْرَ وَالْحُزُونَۃَ ۔1,,takhreej: ! منقطع ضعیف: أخرجہ ابن ابی شیبہ10/527(10211)وعبدالرزاق(5996),3373
3374,3374۔ أَخْبَرَنَا مُحَمَّدُ بْنُ یَزِیدَ الرِّفَاعِیُّ حَدَّثَنَا الْحُسَیْنُ الْجُعْفِیُّ عَنْ حَمْزَۃَ الزَّیَّاتِ عَنْ أَبِیْ الْمُخْتَارِ الطَّائِیِّ عَنِ ابْنِ أَخِی الْحَارِثِ عَنِ الْحَارِثِ قَالَ دَخَلْتُ الْمَسْجِدَ فَإِذَا أُنَاسٌ یَخُوضُوْنَ فِیْ أَحَادِیْثَ فَدَخَلْتُ عَلٰی عَلِیٍّ فَقُلْتُ أَلَا تَرٰی أَنَّ أُنَاسًا یَخُوضُوْنَ فِیْ الْأَحَادِیثِ فِیْ الْمَسْجِدِ فَقَالَ قَدْ فَعَلُوْہَا قُلْتُ نَعَمْ قَالَ أَمَا إِنِّی سَمِعْتُ رَسُولَ اللّٰہِ ﷺ یَقُولُ سَتَکُونُ فِتَنٌ قُلْتُ وَمَا الْمَخْرَجُ مِنْہَا قَالَ کِتَابُ اللّٰہِ کِتَابُ اللّٰہِ فِیہِ نَبَأُ مَا قَبْلَکُمْ وَخَبَرُ مَا بَعْدَکُمْ وَحُکْمُ مَا بَیْنَکُمْ ہُوَ الْفَصْلُ لَیْسَ بِالْہَزْلِ ہُوَ الَّذِی مَنْ تَرَکَہٗ مِنْ جَبَّارٍ قَصَمَہُ اللّٰہُ وَمَنْ ابْتَغٰی الْہُدَی فِیْ غَیْرِہٖ أَضَلَّہُ اللّٰہُ فَہُوَ حَبْلُ اللّٰہِ الْمَتِیْنُ وَہُوَ الذِّکْرُ الْحَکِیْمُ وَہُوَ الصِّرَاطُالْمُسْتَقِیْمُ وَہُوَ الَّذِی لَا تَزِیغُ بِہٖ الْأَہْوَائُ وَلَا تَلْتَبِسُ بِہٖ الْأَلْسِنَۃُ وَلَا یَشْبَعُ مِنْہُ الْعُلَمَائُ وَلَا یَخْلَقُ عَنْ کَثْرَۃِ الرَّدِّ وَلَا تَنْقَضِیْ عَجَائِبُہٗ وَہُوَ الَّذِیْ لَمْ یَنْتَہِ الْجِنُّ إِذْ سَمِعَتْہُ أَنْ قَالُوا إِنَّا سَمِعْنَا قُرْآنًا عَجَبًا ہُوَ الَّذِیْ مَنْ قَالَ بِہٖ صَدَقَ وَمَنْ حَکَمَ بِہٖ عَدَلَ وَمَنْ عَمِلَ بِہٖ أُجِرَ وَمَنْ دَعَا إِلَیْہِ ہُدِیَ إِلٰی صِرَاطٍ مُسْتَقِیْمٍ خُذْہَا إِلَیْکَ یَا أَعْوَرُ ۔1,,takhreej: ! ضعیف: اس میں ابو مختار اور ابن أخی الحارث مجہول ہیں۔ أخرجہ ابن ابی شیبہ 10/482 (10056) والترمذی، کتاب ثواب القران،باب ماجاء فی فضل القران(2908)والبیہقی فی شعب(1935),3374
3375,3375۔ حَدَّثَنَا مُحَمَّدُ بْنُ الْعَلَائِ حَدَّثَنَا زَکَرِیَّا بْنُ عَدِیٍّ حَدَّثَنَا مُحَمَّدُ بْنُ سَلَمَۃَ عَنْ أَبِیْ سِنَانٍ عَنْ عَمْرِو بْنِ مُرَّۃَ عَنْ أَبِیْ الْبَخْتَرِیِّ عَنِ الْحَارِثِ عَنْ عَلِیٍّ قَالَ قِیلَ یَا رَسُولَ اللّٰہِ إِنَّ أُمَّتَکَ سَتُفْتَتَنُ مِنْ بَعْدِکَ قَالَ فَسَأَلَ رَسُولَ اللّٰہِ ﷺ أَوْ سُئِلَ مَا الْمَخْرَجُ مِنْہَا قَالَ الْکِتَابُ الْعَزِیزُ الَّذِی لَا یَأْتِیہِ الْبَاطِلُ مِنْ بَیْنِ یَدَیْہِ وَلَا مِنْ خَلْفِہٖ تَنْزِیلٌ مِنْ حَکِیْمٍ حَمِیْدٍ مَنِ ابْتَغَی الْہُدَی فِیْ غَیْرِہِ أَضَلَّہُ اللّٰہُ وَمَنْ وَلِیَ ہٰذَا الْأَمْرَ مِنْ جَبَّارٍ فَحَکَمَ بِغَیْرِہِ قَصَمَہُ اللّٰہُ ہُوَ الذِّکْرُ الْحَکِیمُ وَالنُّورُ الْمُبِینُ وَالصِّرَاطُ الْمُسْتَقِیمُ فِیہِ خَبَرُ مَنْ قَبْلَکُمْ وَنَبَأُ مَا بَعْدَکُمْ وَحُکْمُ مَا بَیْنَکُمْ وَہُوَ الْفَصْلُ لَیْسَ بِالْہَزْلِ وَہُوَ الَّذِی سَمِعَتْہُ الْجِنُّ فَلَمْ تَتَنَاہَی أَنْ قَالُوا إِنَّا سَمِعْنَا قُرْآنًا عَجَبًا یَہْدِیْ إِلٰی الرُّشْدِ وَلَا یَخْلَقُ عَنْ کَثْرَۃِ الرَّدِّ وَلَا تَنْقَضِیْ عِبَرُہٗ وَلَا تَفْنَی عَجَائِبُہٗ ثُمَّ قَالَ عَلِیٌّ لِلْحَارِثِ خُذْہَا إِلَیْکَ یَا أَعْوَرُ ۔1,,takhreej: ! حسن: أخرجہ الخطیب فی الفقیہ والمتفقہ1/55والرازی فی فضائل القران(35),3375
3376,3376۔ أَخْبَرَنَا مُحَمَّدُ بْنُ یُوسُفَ حَدَّثَنَا سُفْیَانُ عَنْ أَبِیْ حُمْرَّۃَ عَنْ إِبْرَاہِیمَ وَمَنْ یُؤْتَ الْحِکْمَۃَ فَقَدْ أُوتِیَ خَیْرًا کَثِیرًا قَالَ الْفَہْمَ بِالْقُرْآنِ ۔2,,takhreej: @ ضعیف: أخرجہ الطبری فی التفسیر3/90,3376
3377,3377۔ أَخْبَرَنَا مُحَمَّدُ بْنُ یُوسُفَ عَنْ وَرْقَائَ عَنِ ابْنِ أَبِیْ نَجِیْحٍ عَنْ مُجَاہِدٍ یُؤْتِی الْحِکْمَۃَ مَنْ یَشَائُ قَالَ الْکِتَابَ یُؤْتِی إِصَابَتَہُ مَنْ یَشَائُ ۔3,,takhreej: # صحیح: أخرجہ ابن ابی شیبہ7/231(3009)والطبری فی التفسیر3/90,3377
3378,3378۔ أَخْبَرَنَا مُحَمَّدُ بْنُ یَزِیدَ حَدَّثَنَا أَبُوْْ بَکْرٍ عَنِ الْأَعْمَشِ عَنْ خَیْثَمَۃَ قَالَ قَالَ لِامْرَأَتِہٖ إِیَّاکِ أَنْ تُدْخِلِی بَیْتِی مَنْ یَشْرَبُ الْخَمْرَ بَعْدَ أَنْ کَانَ یُقْرَأُ فِیہِ الْقُرْآنُ کُلَّ ثَـلَاثٍ ۔1,,takhreej: ! صحیح: أخرجہ الفسوی فی المعرقۃ والتاریخ3/143وابونعیم فی الحلیۃ4/115,3378
3379,3379۔ حَدَّثَنَا أَبُوْْ نُعَیْمٍ حَدَّثَنَا فِطْرٌ عَنِ الْحَکَمِ عَنْ مِقْسَمٍ عَنِ ابْنِ عَبَّاسٍ قَالَ مَا یَمْنَعُ أَحَدَکُمْ إِذَا رَجَعَ مِنْ سُوْقِہٖ أَوْ مِنْ حَاجَتِہٖ فَاتَّکَأَ عَلٰی فِرَاشِہٖ أَنْ یَقْرَأَ ثَـلَاثَ آیَاتٍ مِنَ الْقُرْآنِ ۔2,,takhreej: @ صحیح: أخرجہ ابن المبارک فی الزہد(807)وابن عدی فی الکامل1/249والطبرانی فی الکبیر 11//398 والبیہقی فی شعب (2198-2003),3379
3380,3380۔ أَخْبَرَنَا مُسْلِمُ بْنُ إِبْرَاہِیمَ حَدَّثَنَا عَبْدُ الْوَاحِدِ حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِسْحٰقَ حَدَّثَنَا النُّعْمَانُ بْنُ سَعْدٍ عَنْ عَلِیٍّ قَالَ قَالَ رَسُولُ اللّٰہِ ﷺ خَیْرُکُمْ مَنْ تَعَلَّمَ الْقُرْآنَ وَعَلَّمَہٗ۔3,,takhreej: # صحیح: أخرجہ الترمذی،کتاب ثواب القران،باب فی تعلیم القرآن وابن ابی شیبہ10/503(10121)والخطیب فی تاریخ 10/459,3380
3381,3381۔ حَدَّثَنَا الْحَجَّاجُ بْنُ مِنْہَالٍ حَدَّثَنَا شُعْبَۃُ أَخْبَرَنِی عَلْقَمَۃُ بْنُ مَرْثَدٍ قَالَ سَمِعْتُ سَعْدَ ابْنَ عُبَیْدَۃَ عَنْ أَبِیْ عَبْدِ الرَّحْمَنِ السُّلَمِیِّ عَنْ عُثْمَانَ عَنِ النَّبِیِّ ﷺ قَالَ إِنَّ خَیْرَکُمْ مَنْ عَلَّمَ الْقُرْآنَ أَوْ تَعَلَّمَہٗ قَالَ أَقْرَأَ أَبُوْ عَبْدِ الرَّحْمَنِ فِیْ إِمْرَۃِ عُثْمَانَ حَتّٰی کَانَ الْحَجَّاجُ قَالَ ذَاکَ أَقْعَدَنِی مَقْعَدِیْ ہٰذَا ۔1,,takhreej: !صحیح: أخرجہ النسائی فی فضائل القران(62-61)والبیہقی فی شعب(2206-2205),3381
3382,3382۔ حَدَّثَنَا الْمُعَلَّی بْنُ أَسَدٍ حَدَّثَنَا الْحَارِثُ بْنُ نَبْہَانَ حَدَّثَنَا عَاصِمُ بْنُ بَہْدَلَۃَ عَنْ مُصْعَبِ بْنِ سَعْدٍ عَنْ أَبِیْہِ قَالَ قَالَ رَسُولُ اللّٰہِ ﷺ خِیَارُکُمْ مَنْ تَعَلَّمَ الْقُرْآنَ وَعَلَّمَ الْقُرْآنَ قَالَ فَأَخَذَ بِیَدِیْ فَأَقْعَدَنِیْ ہٰذَا الْمَقْعَدَ أُقْرِئُ ۔2,,takhreej: @صحیح بالشاہد: أخرجہ ابن منصور1/103(20),3382
3383,3383۔ حَدَّثَنَا سَعِیْدُ بْنُ عَامِرٍ عَنْ شُعْبَۃَ عَنْ یَزِیْدَ بْنِ أَبِیْ زِیَادٍ عَنْ عِیْسَی عَنْ رَجُلٍ عَنْ سَعْدِ بْنِ عُبَادَۃَ أَنَّ رَسُولَ اللّٰہِ ﷺ قَالَ مَا مِنْ رَجُلٍ یَتَعَلَّمُ الْقُرْآنَ ثُمَّ یَنْسَاہُ إِلَّا لَقِیَ اللّٰہَ یَوْمَ الْقِیَامَۃِ وَہُوَ أَجْذَمُ قَالَ أَبُوْ مُحَمَّد عِیسَی ہُوَ ابْنُ فَائِدٍ۔3,,takhreej: #ضعیف: أخرجہ احمد5/285وابوداؤد،کتاب الصلاۃ،باب التشدید فیمن حفظ القران ثم نسیہ(1474)وابن ابی شیبہ 10/74(1044),3383
3384,3384۔ حَدَّثَنَا جَعْفَرُ بْنُ عَوْنٍ حَدَّثَنَا مُوسَی بْنُ عُبَیْدَۃَ عَنْ صَفْوَانَ بْنِ سُلَیْمٍ عَنْ نَاجِیَۃَ بْنِ عَبْدِاللّٰہِ بْنِ عُتْبَۃَ عَنْ أَبِیْہِ عَنْ عَبْدِ اللّٰہِ قَالَ أَکْثِرُوْا تِلَاوَۃَ الْقُرْآنِ قَبْلَ أَنْ یُرْفَعَ قَالُوا ہَذِہِ الْمَصَاحِفُ تُرْفَعُ فَکَیْفَ بِمَا فِیْ صُدُورِ الرِّجَالِ قَالَ یُسْرَی عَلَیْہِ لَیْلًا فَیُصْبِحُونَ مِنْہُ فُقَرَائَ وَیَنْسَوْنَ قَوْلَ لَا إِلَہَ إِلَّا اللّٰہُ وَیَقَعُونَ فِیْ قَوْلِ الْجَاہِلِیَّۃِ وَأَشْعَارِہِمْ وَذٰلِکَ حِینَ یَقَعُ عَلَیْہِمْ الْقَوْلُ ۔1,,takhreej: ! صحیح:أخرجہ ا بن منصور2/335(97)والحاکم4/504وعبدالرزاق(5981)والطبرانی فی الکبیر 9/153 (8698),3384
3385,3385۔ حَدَّثَنَا الْمُعَلَّی بْنُ أَسَدٍ حَدَّثَنَا سَلَّامٌ یَعْنِی ابْنَ أَبِیْ مُطِیْعٍ قَالَ کَانَ قَتَادَۃُ یَقُولُ اعْمُرُوا بِہٖ قُلُوبَکُمْ وَاعْمُرُوا بِہٖ بُیُوتَکُمْ قَالَ أُرَاہُ یَعْنِی الْقُرْآنَ۔2,,takhreej: @ ضعیف:سلام کی قتادہ سے روایت متکلم فیہ ہے۔,3385
3386,3386۔ حَدَّثَنَا عَمْرُو بْنُ عَاصِمٍ حَدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ عَنْ عَاصِمٍ عَنْ زِرٍّ عَنِ ابْنِ مَسْعُودٍ قَالَ لَیُسْرَیَنَّ عَلَی الْقُرْآنِ ذَاتَ لَیْلَۃٍ فَلَا یُتْرَکُ آیَۃٌ فِیْ مُصْحَفٍ وَلَا فِیْ قَلْبِ أَحَدٍ إِلَّا رُفِعَتْ ۔3,,takhreej: #حسن: أخرجہ ابن ابی شیبہ10/534(10242)وعبدالرزاق(5980)والبخاری فی خلق افعال العباد(ص86),3386
3387,3387۔ حَدَّثَنَا مُحَمَّدُ بْنُ کَثِیْرٍ عَنْ عَبْدِ اللّٰہِ بْنِ وَاقِدٍ عَنْ قَتَادَۃَ قَالَ مَا جَالَسَ الْقُرْآنَ أَحَدٌ فَقَامَ عَنْہُ إِلَّا بِزِیَادَۃٍ أَوْ نُقْصَانٍ ثُمَّ قَرَأَ وَنُنَزِّلُ مِنَ الْقُرْآنِ مَا ہُوَ شِفَائٌ وَرَحْمَۃٌ لِّلْمُؤْمِنِیْنَ وَلَا یَزِیْدُ الظَّالِمِیْنَ إِلَّا خَسَارًا ۔1,,takhreej: ! ضعیف: محمد بن کثیر ضعیف ہے، أخرجہ ابو عبید فی فضائلہ(ص57-56),3387
3388,3388۔ حَدَّثَنَا مَرْوَانُ بْنُ مُحَمَّدٍ حَدَّثَنَا رِفْدَۃُ الْغَسَّانِیُّ حَدَّثَنَا ثَابِتُ بْنُ عَجْلَانَ الْأَنْصَارِیُّ قَالَ کَانَ یُقَالُ إِنَّ اللّٰہَ لَیُرِیْدُ الْعَذَابَ بِأَہْلِ الْأَرْضِ فَإِذَا سَمِعَ تَعْلِیمَ الصِّبْیَانِ الْحِکْمَۃَ صَرَفَ ذٰلِکَ عَنْہُمْ قَالَ مَرْوَانُ یَعْنِی بِالْحِکْمَۃِ الْقُرْآنَ ۔2,,takhreej: @ضعیف: رفدہ بن قضاعۃ ضعیف ہے۔,3388
3389,3389۔ أَخْبَرَنَا مُحَمَّدُ بْنُ الْمُبَارَکِ حَدَّثَنَا صَدَقَۃُ بْنُ خَالِدٍ عَنِ ابْنِ جَابِرٍ حَدَّثَنَا شَیْخٌ یُکَنَّی أَبَا عَمْرٍو عَنْ مُعَاذِ بْنِ جَبَلٍ قَالَ سَیَبْلَی الْقُرْآنُ فِیْ صُدُورِ أَقْوَامٍ کَمَا یَبْلَی الثَّوْبُ فَیَتَہَافَتُ یَقْرَئُونَہٗ لَا یَجِدُوْنَ لَہٗ شَہْوَۃً وَلَا لَذَّۃً یَلْبَسُوْنَ جُلُودَ الضَّأْنِ عَلَی قُلُوبِ الذِّئَابِ أَعْمَالُہُمْ طَمَعٌ لَا یُخَالِطُہٗ خَوْفٌ إِنْ قَصَّرُوا قَالُوا سَنَبْلُغُ وَإِنْ أَسَائُوا قَالُوا سَیُغْفَرُ لَنَا إِنَّا لَا نُشْرِکُ بِاللّٰہِ شَیْئًا 1,,takhreej: !صحیح: یہ معاذ پر موقوف ہے۔,3389
3390,3390۔ حَدَّثَنَا عُبَیْدُ اللّٰہِ بْنُ عَبْدِ الْمَجِیدِ عَنْ شُعْبَۃَ عَنْ مَنْصُورٍ قَالَ سَمِعْتُ أَبَا وَائِلٍ عَنْ عَبْدِ اللّٰہِ عَنِ النَّبِیِّ ﷺ قَالَ بِئْسَمَا لِأَحَدِکُمْ أَنْ یَقُوْلَ نَسِیْتُ آیَۃَ کَیْتَ وَکَیْتَ بَلْ ہُوَ نُسِّیَ وَاسْتَذْکِرُوا الْقُرْآنَ فَإِنَّہٗ أَسْرَعُ تَفَصِّیًا مِنْ صُدُوْرِ الرِّجَالِ مِنَ النَّعَمِ مِنْ عُقُلِہَا ۔2,,takhreej: @متفق علیہ: أخرجہ البخاری،کتاب فضائل القران،باب استذکار القران وتعاہدہ(5032)ومسلم،کتاب صلاۃ المسافرین، باب فضائل القرآن وما یتعلق بہ (790),3390
3391,3391۔ حَدَّثَنَا وَہْبُ بْنُ جَرِیرٍ حَدَّثَنَا مُوسَی یَعْنِی ابْنَ عُلَیٍّ قَالَ سَمِعْتُ أَبِیْ قَالَ سَمِعْتُ عُقْبَۃَ بْنَ عَامِرٍ یَقُوْلُ : قَالَ رَسُوْلُ اللّٰہِ ﷺ تَعَلَّمُوا کِتَابَ اللّٰہِ وَتَعَاہَدُوْہُ وَتَغَنَّوْا بِہٖ وَاقْتَنُوْہُ فَوَالَّذِی نَفْسِی بِیَدِہِ أَوْ فَوَالَّذِی نَفْسُ مُحَمَّدٍ بِیَدِہِ لَہُوَ أَشَدُّ تَفَلُّتًا مِنَ الْمَخَاضِ فِیْ الْعُقُلِ۔3,,takhreej: #صحیح: أخرجہ احمد4/146والنسائی فی فضائل القرآن(60-59),3391
3392,3392۔ حَدَّثَنَا عَبْدُ اللّٰہِ بْنُ صَالِحٍ قَالَ حَدَّثَنِی مُوسَی عَنْ أَبِیْہِ عَنْ عُقْبَۃَ بْنِ عَامِرٍ أَنَّ رَسُولَ اللّٰہِ ﷺ قَالَ تَعَلَّمُوا کِتَابَ اللّٰہِ تَعَالَی وَتَعَاہَدُوْہُ وَاقْتَنُوْہُ وَتَغَنَّوْا بِہٖ فَوَالَّذِی نَفْسِی بِیَدِہِ لَہُوَ أَشَدُّ تَفَلُّتًا مِنَ الْمَخَاضِ فِیْ الْعُقُلِ ۔1,,takhreej: ! صحیح: أخرجہ النسائی،کتاب فضائل القران(60)والطبرانی فی الکبیر17/291-290(802-801-800),3392
3393,3393۔ أَخْبَرَنَا سُلَیْمَانُ بْنُ حَرْبٍ حَدَّثَنَا حَمَّادُ بْنُ زَیْدٍ عَنْ أَیُّوْبَ عَنِ ابْنِ أَبِیْ مُلَیْکَۃَ أَنَّ عِکْرِمَۃَ بْنَ أَبِیْ جَہْلٍ کَانَ یَضَعُ الْمُصْحَفَ عَلَی وَجْہِہٖ وَیَقُوْلُ کِتَابُ رَبِّی کِتَابُ رَبِّی ۔2,,takhreej: @منقطع ضعیف: ابن ابی ملیکہ نے عکرمہ کو نہیں پایا۔ أخرجہ الحاکم3/243والبیہقی فی الشعب(2229)والطبرانی الکبیر 17/371(1018),3393
3394,3394۔ حَدَّثَنَا مُسْلِمُ بْنُ إِبْرَاہِیْمَ حَدَّثَنَا ہَمَّامٌ حَدَّثَنَا ثَابِتٌ قَالَ کَانَ عَبْدُ الرَّحْمَنِ بْنُ أَبِیْ لَیْلٰی إِذَا صَلَّی الصُّبْحَ قَرَأَ الْمُصْحَفَ حَتّٰی تَطْلُعَ الشَّمْسُ قَالَ وَکَانَ ثَابِتٌ یَفْعَلُہُ ۔3,,takhreej: #صحیح: أخرجہ ابن سعد فی الطبقات6/75,3394
3395,3395۔ أَخْبَرَنَا مُحَمَّدُ بْنُ عَبْدِ اللّٰہِ الرَّقَاشِیُّ عَنْ یَزِیْدَ بْنِ زُرَیْعٍ عَنْ سَعِیْدٍ عَنْ قَتَادَۃَ قَالَ فَأَمَّا الَّذِینَ آمَنُوْا فَیَعْلَمُوْنَ أَنَّہٗ الْحَقُّ مِنْ رَبِّہِمْ قَالَ أَیْ یَعْلَمُونَ أَنَّہٗ کَلَامُ الرَّحْمَنِ۔1,,takhreej: !صحیح: أخرجہ الطبرانی فی التفسیر1/180,3395
3396,3396۔ حَدَّثَنَا عَبْدُ اللّٰہِ بْنُ صَالِحٍ عَنْ مُعَاوِیَۃَ بْنِ صَالِحٍ عَنْ أَبِیْ بَکْرِ بْنِ أَبِیْ مَرْیَمَ عَنْ عَطِیَّۃَ قَالَ قَالَ رَسُولُ اللّٰہِ ﷺ مَا مِنْ کَلَامٍ أَعْظَمُ عِنْدَ اللّٰہِ مِنْ کَلَامِہٖ وَمَا رَدَّ الْعِبَادُ إِلٰی اللّٰہِ کَلَامًا أَحَبَّ إِلَیْہِ مِنْ کَلَامِہٖ۔2,,takhreej: @ضعیف: أخرجہ البیہقی فی الأسماء والصفات(ص244),3396
3397,3397۔ حَدَّثَنَا مُحَمَّدُ بْنُ یُوْسُفَ عَنْ إِسْرَائِیلَ حَدَّثَنَا عُثْمَانُ بْنُ الْمُغِیْرَۃِ الثَّقَفِیُّ عَنْ سَالِمِ ابْنِ أَبِیْ الْجَعْدِ عَنْ جَابِرِ بْنِ عَبْدِ اللّٰہِ قَالَ کَانَ رَسُولُ اللّٰہِ ﷺ یَعْرِضُ نَفْسَہٗ فِیْ الْمَوْسِمِ عَلَی النَّاسِ فِیْ الْمَوْقِفِ فَیَقُولُ ہَلْ مِنْ رَجُلٍ یَحْمِلُنِی إِلٰی قَوْمِہِ فَإِنَّ قُرَیْشًا مَنَعُونِیْ أَنْ أُبَلِّغَ کَلَامَ رَبِّی ۔3,,takhreej: # صحیح: أخرجہ احمد3/390وابن ابی شیبہ10/310(18431)وابوداؤد،کتاب السنۃ،باب فی القران (4734) والترمذی ، کتاب ثواب القران،باب حرض النبی صلی اللہ علیہ وسلم علی تبلیغ القران(2926),3397
3398,3398۔ حَدَّثَنَا إِسْحَقُ حَدَّثَنَا جَرِیْرٌ عَنْ لَیْثٍ عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ عَنْ أَبِیْ الزَّعْرَائِ قَالَ قَالَ عُمَرُ بْنُ الْخَطَّابِ إِنَّ ہٰذَا الْقُرْآنَ کَلَامُ اللّٰہِ فَلَا أَعْرِفَنَّکُمْ فِیْمَا عَطَفْتُمُوہُ عَلَی أَہْوَائِکُمْ ۔1,,takhreej: ! صحیح: أخرجہ الآجری فی الشریعۃ(ص78)والبیہقی فی الاسماء والصفات(282),3398
3399,3399۔ أَخْبَرَنَا إِسْمٰعِیْلُ بْنُ إِبْرَاہِیْمَ التَّرْجُمَانِیُّ حَدَّثَنَا مُحَمَّدُ بْنُ الْحَسَنِ الْہَمْدَانِیُّ عَنْ عَمْرِو بْنِ قَیْسٍ عَنْ عَطِیَّۃَ عَنْ أَبِیْ سَعِیْدٍ الْخُدْرِیِّ قَالَ قَالَ رَسُولُ اللّٰہِ ﷺ مَنْ شَغَلَہٗ قِرَائَۃُ الْقُرْآنِ عَنْ مَسْأَلَتِی وَذِکْرِی أَعْطَیْتُہُ أَفْضَلَ ثَوَابِ السَّائِلِیْنَ وَفَضْلُ کَلَامِ اللّٰہِ عَلَی سَائِرِ الْکَلَامِ کَفَضْلِ اللّٰہِ عَلَی خَلْقِہِ ۔2,,takhreej: @اسنادہ ضعیف لکن لہ شواہد: أخرجہ الترمذی،کتاب ثواب القران،باب من شغلہ القران أعطی أفضل العطایا،أخرجہ یحیی بن عبدالحمید الحمانی،فی مسندہ،قالہ الحافط فی الفتح9/66والقضاعی فی مسند الشہاب 2/326 (1455) وأخرجہ البخاری فی(خلق افعال العباد)(ص109)وفی الکبیر2/115وأخرجہ ابو نعیم فی الحلیۃ7/313 مزید شواہد کے لیے دیکھئے مصنف ابن ابی شیبہ10/237(9320)والشعب للبیہقی(574-573) واللالی المصنوعہ2/343-342,3399
3400,3400۔ حَدَّثَنَا سُلَیْمَانُ بْنُ حَرْبٍ حَدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ عَنْ أَشْعَثَ الْحُدَّانِیِّ عَنْ شَہْرِ بْنِ حَوْشَبٍ قَالَ قَالَ رَسُوْلُ اللّٰہِ ﷺ فَضْلُ کَلَامِ اللّٰہِ عَلَی کَلَامِ خَلْقِہِ کَفَضْلِ اللّٰہِ عَلَی خَلْقِہٖ۔1,,takhreej: ! مرسل،ضعیف: أخرجہ ابوداؤد فی المراسیل(535)وابن عدی فی الکامل5/1705,3400
3401,3401۔ حَدَّثَنَا عَبْدُ اللّٰہِ بْنُ صَالِحٍ حَدَّثَنَا یَحْیَی بْنُ أَیُّوبَ عَنْ عُبَیْدِ اللّٰہِ بْنِ أَبِیْ جَعْفَرٍ عَنْ رَجُلٍ مِنْ شُیُوْخِ مِصْرَ أَنَّہٗ حَدَّثَہٗ عَنْ عَبْدِ اللّٰہِ بْنِ عَمْرٍو عَنْ رَسُوْلِ اللّٰہِ ﷺ أَنَّہٗ قَالَ الْقُرْآنُ أَحَبُّ إِلٰی اللّٰہِ مِنَ السَّمٰوَاتِ وَالْأَرْضِ وَمَنْ فِیہِنَّ ۔2,,takhreej: @ ضعیف جداً: أخرجہ الرازی،ضعیف القرآن وتلاوتہ(28),3401
3402,3402۔ حَدَّثَنَا أَبُوْ النُّعْمَانِ حَدَّثَنَا ہَارُونُ الْأَعْوَرُ عَنْ أَبِیْ عِمْرَانَ الْجَوْنِیِّ عَنْ جُنْدُبٍ أَنَّ النَّبِیَّ ﷺ قَالَ اقْرَئُوا الْقُرْآنَ مَا ائْتَلَفْتُمْ عَلَیْہِ فَإِذَا اخْتَلَفْتُمْ فِیہِ فَقُومُوْا ۔3,,takhreej: # متفق علیہ: أخرجہ البخاری،کتاب فضائل القرآن ، باب اقرئوُا القران ماائتلف علیہ قلوبکم(5060)ومسلم،کتاب العلم، باب النہی عن اتباع متشابہ القران(2667),3402
3403,3403۔ أَخْبَرَنَا یَزِیْدُ بْنُ ہَارُوْنَ حَدَّثَنَا ہَمَّامٌ حَدَّثَنَا أَبُوْ عِمْرَانَ الْجَوْنِیُّ عَنْ جُنْدُبِ بْنِ عَبْدِ اللّٰہِ قَالَ اقْرَئُوا الْقُرْآنَ مَا ائْتَلَفَتْ عَلَیْہِ قُلُوبُکُمْ فَإِذَا اخْتَلَفْتُمْ فِیہِ فَقُوْمُوْا۔1,,takhreej: ! صحیح: سابقہ ولاحق ملاحظہ فرمائیں۔,3403
3404,3404۔ حَدَّثَنَا أَبُوْ غَسَّانَ مَالِکُ بْنُ إِسْمٰعِیْلَ حَدَّثَنَا أَبُوْ قُدَامَۃَ حَدَّثَنَا أَبُوْ عِمْرَانَ الْجَوْنِیُّ عَنْ جُنْدُبٍ قَالَ قَالَ رَسُولُ اللّٰہِ ﷺ اقْرَئُوا الْقُرْآنَ مَا ائْتَلَفَتْ عَلَیْہِ قُلُوْبُکُمْ فَإِذَا اخْتَلَفْتُمْ فِیْہِ فَقُوْمُوْا ۔2,,takhreej: @ صحیح: (3402)ہی مکرر ہے۔,3404
3405,3405۔ حَدَّثَنَا أَبُوْ نُعَیْمٍ حَدَّثَنَا فِطْرٌ عَنْ أَبِیْ إِسْحٰقَ عَنِ الْحَارِثِ عَنْ عَلِیٍّ رَضِیَ اللّٰہُ عَنْہُ قَالَ مِنَ النَّاسِ مَنْ یُؤْتَی الْاِِیمَانَ وَلَا یُؤْتَی الْقُرْآنَ وَمِنْہُمْ مَنْ یُؤْتَی الْقُرْآنَ وَلَا یُؤْتَی الْاِِیمَانَ وَمِنْہُمْ مَنْ یُؤْتَی الْقُرْآنَ وَالْاِِیمَانَ وَمِنْہُمْ مَنْ لَا یُؤْتَی الْقُرْآنَ وَلَا الْاِِیمَانَ ثُمَّ ضَرَبَ لَہُمْ مَثَلًا قَالَ فَأَمَّا مَنْ أُوتِیَ الْاِِیمَانَ وَلَمْ یُؤْتَ الْقُرْآنَ فَمَثَلُہُ مَثَلُ التَّمْرَۃِ حُلْوَۃُ الطَّعْمِ لَا رِیحَ لَہَا وَأَمَّا مَثَلُ الَّذِی أُوتِیَ الْقُرْآنَ وَلَمْ یُؤْتَ الْاِِیْمَانَ فَمَثَلُ الْآسَۃِ طَیِّبَۃُ الرِّیْحِ مُرَّۃُ الطَّعْمِ وَأَمَّا الَّذِی أُوْتِیَ الْقُرْآنَ وَالْاِِیمَانَ فَمَثَلُ الْأُتْرُجَّۃِ طَیِّبَۃُ الرِّیحِ حُلْوَۃُ الطَّعْمِ وَأَمَّا الَّذِی لَمْ یُؤْتَ الْقُرْآنَ وَلَا الْاِِیمَانَ فَمَثَلُہْ مَثَلُ الْحَنْظَلَۃِ مُرَّۃُ الطَّعْمِ لَا رِیْحَ لَہَا ۔1,,takhreej: !صحیح: أخرجہ ابو عبید فی فضائل القران(ص387)وأخرجہ ابن ابی شیبہ مختصراً10/529(10220),3405
3406,3406۔ حَدَّثَنَا أَبُوْ النُّعْمَانِ حَدَّثَنَا أَبُوْ عَوَانَۃَ عَنْ قَتَادَۃَ عَنْ أَنَسِ بْنِ مَالِکٍ عَنْ أَبِیْ مُوسَی الْأَشْعَرِیِّ عَنِ النَّبِیِّ ﷺ قَالَ مَثَلُ الْمُؤْمِنِ الَّذِیْ یَقْرَأُ الْقُرْآنَ مَثَلُ الْأُتْرُجَّۃِ طَعْمُہَا طَیِّبٌ وَرِیْحُہَا طَیِّبٌ وَمَثَلُ الْمُؤْمِنِ الَّذِی لَا یَقْرَأُ الْقُرْآنَ مَثَلُ التَّمْرَۃِ طَعْمُہَا حُلْوٌ وَلَیْسَ لَہَا رِیحٌ وَمَثَلُ الْمُنَافِقِ الَّذِیْ یَقْرَأُ الْقُرْآنَ مَثَلُ الرَّیْحَانَۃِ رِیحُہَا طَیِّبٌ وَطَعْمُہَا مُرٌّ وَمَثَلُ الْمُنَافِقِ الَّذِی لَا یَقْرَأُ الْقُرْآنَ مَثَلُ الْحَنْظَلَۃِ لَیْسَ لَہَا رِیحٌ وَطَعْمُہَا مُرٌّ ۔2,,takhreej: @متفق علیہ: أخرجہ البخاری،کتاب فضائل القران،باب فضل القران علی سائر الکلام(5020)ومسلم،کتاب صلاۃ المسافرین، باب فضیلۃ حافظ القران(797),3406
3407,3407۔ أَخْبَرَنَا عُبَیْدُ اللّٰہِ عَنْ إِسْرَائِیْلَ عَنْ أَبِیْ إِسْحٰقَ عَنِ الْحَارِثِ عَنْ عَلِیٍّ قَالَ مَثَلُ الَّذِی أُوتِیَ الْاِِیمَانَ وَلَمْ یُؤْتَ الْقُرْآنَ مَثَلُ التَّمْرَۃِ طَعْمُہَا طَیِّبٌ وَلَا رِیحَ لَہَا وَمَثَلُ الَّذِی أُوتِیَ الْقُرْآنَ وَلَمْ یُؤْتَ الْاِِیمَانَ مَثَلُ الرَّیْحَانَۃِ الْآسَۃِ رِیحُہَا طَیِّبٌ وَطَعْمُہَا مُرٌّ وَمَثَلُ الَّذِی أُوتِیَ الْقُرْآنَ وَالْاِِیمَانَ مَثَلُ الْأُتْرُجَّۃِ رِیحُہَا طَیِّبٌ وَطَعْمُہَا طَیِّبٌ وَمَثَلُ الَّذِی لَمْ یُؤْتَ الْاِِیمَانَ وَلَا الْقُرْآنَ مَثَلُ الْحَنْظَلَۃِ رِیحُہَا خَبِیْثٌ وَطَعْمُہَا خَبِیْثٌ ۔1,,takhreej: !صحیح: أخرجہ ابو عبید فی فضائلہ (ص387),3407
3408,3408۔ أَخْبَرَنَا الْحَکَمُ بْنُ نَافِعٍ عَنْ شُعَیْبِ بْنِ أَبِیْ حَمْزَۃَ عَنِ الزُّہْرِیِّ حَدَّثَنِی عَامِرُ بْنُ وَاثِلَۃَ أَنَّ نَافِعَ بْنَ عَبْدِ الْحَارِثِ لَقِیَ عُمَرَ بْنَ الْخَطَّابِ بِعُسْفَانَ وَکَانَ عُمَرُ اسْتَعْمَلَہٗ عَلٰی أَہْلِ مَکَّۃَ فَسَلَّمَ عَلٰی عُمَرَ فَقَالَ لَہٗ عُمَرُ مَنِ اسْتَخْلَفْتَ عَلٰی أَہْلِ الْوَادِیْ فَقَالَ نَافِعٌ اسْتَخْلَفْتُ عَلَیْہِمْ ابْنَ أَبْزَی فَقَالَ عُمَرُ وَمَنْ ابْنُ أَبْزَی فَقَالَ مَوْلًی مِنْ مَوَالِیْنَا فَقَالَ عُمَرُ فَاسْتَخْلَفْتَ عَلَیْہِمْ مَوْلًی فَقَالَ یَا أَمِیرَ الْمُؤْمِنِینَ إِنَّہٗ قَارِئٌ لِکِتَابِ اللّٰہِ عَالِمٌ بِالْفَرَائِضِ فَقَالَ عُمَرُ أَمَا إِنَّ رَسُولَ اللّٰہِ ﷺ قَالَ إِنَّ اللّٰہَ یَرْفَعُ بِہٰذَا الْکِتَابِ أَقْوَامًا وَیَضَعُ بِہٖ آخَرِیْنَ ۔1,,takhreej: !صحیح: أخرجہ مسلم،کتاب صلاۃالمسافرین،باب فضل من یقوم بالقران ویعلمہ(817)والبیہقی فی الصلاۃ باب امامۃ المولی3/89,3408
3409,3409۔ حَدَّثَنَا أَبُوْ الْمُغِیرَۃِ حَدَّثَنَا عَبْدَۃُ عَنْ خَالِدِ بْنِ مَعْدَانَ قَالَ إِنَّ الَّذِی یَقْرَأُ الْقُرْآنَ لَہٗ أَجْرٌ وَإِنَّ الَّذِی یَسْتَمِعُ لَہٗ أَجْرَانِ۔2,,takhreej: @عبدۃ بن خالد کا ترجمہ نہیں ملا۔,3409
3410,3410۔ حَدَّثَنَا رَزِیْنُ بْنُ عَبْدِ اللّٰہِ بْنِ حُمَیْدٍ عَنْ عَبْدِ الرَّزَّاقِ عَنِ ابْنِ جُرَیْجٍ عَنْ عَطَائٍ عَنِ ابْنِ عَبَّاسٍ قَالَ مَنْ اسْتَمَعَ إِلٰی آیَۃٍ مِنْ کِتَابِ اللّٰہِ کَانَتْ لَہٗ نُورًا ۔3,,takhreej: # ضعیف: أخرجہ عبدالرزاق(6012),3410
3411,3411۔ أَخْبَرَنَا مُسْلِمُ بْنُ إِبْرَاہِیمَ حَدَّثَنَا ہِشَامٌ وَہَمَّامٌ قَالَا حَدَّثَنَا قَتَادَۃُ عَنْ زُرَارَۃَ بْنِ أَوْفٰی عَنْ سَعْدِ بْنِ ہِشَامٍ عَنْ عَائِشَۃَ عَنِ النَّبِیِّ ﷺ قَالَ الَّذِی یَقْرَأُ الْقُرْآنَ وَہُوَ مَاہِرٌ بِہٖ فَہُوَ مَعَ السَّفَرَۃِ الْکِرَامِ الْبَرَرَۃِ وَالَّذِی یَقْرَؤُہٗ وَہُوَ یَشْتَدُّ عَلَیْہِ فَلَہٗ أَجْرَانِ ۔1,,takhreej: !صحیح: أخرجہ البخاری،کتاب التفسیر،باب سورۃ عبس(4937)ومسلم،کتاب صلاۃ المسافرین،باب الماہر بالقران والذی،یتعتع فیہ (798),3411
3412,3412۔ حَدَّثَنَا مَرْوَانُ بْنُ مُحَمَّدٍ حَدَّثَنَا سَعِیْدٌ ہُوَ ابْنُ عَبْدِ الْعَزِیْزِ عَنْ إِسْمٰعِیْلَ بْنِ عُبَیْدِ اللّٰہِ عَنْ وَہْبٍ الذِّمَارِیِّ قَالَ مَنْ آتَاہُ اللّٰہُ الْقُرْآنَ فَقَامَ بِہٖ آنَائَ اللَّیْلِ وَآنَائَ النَّہَارِ وَعَمِلَ بِمَا فِیہِ وَمَاتَ عَلَی الطَّاعَۃِ بَعَثَہُ اللّٰہُ یَوْمَ الْقِیَامَۃِ مَعَ السَّفَرَۃِ وَالْأَحْکَامِ قَالَ سَعِیدٌ السَّفَرَۃُ الْمَلَائِکَۃُ وَالْأَحْکَامُ الْأَنْبِیَائُ قَالَ وَمَنْ کَانَ حَرِیصًا وَہُوَ یَتَفَلَّتُ مِنْہُ وَہُوَ لَا یَدَعُہٗ أُوتِیَ أَجْرَہٗ مَرَّتَیْنِ وَمَنْ کَانَ عَلَیْہِ حَرِیصًا وَہُوَ یَتَفَلَّتُ مِنْہُ وَمَاتَ عَلَی الطَّاعَۃِ فَہُوَ مِنْ أَشْرَافِہِمْ وَفُضِّلُوا عَلَی النَّاسِ کَمَا فُضِّلَتِ النُّسُورُ عَلَی سَائِرِ الطَّیْرِ وَکَمَا فُضِّلَتْ مَرْجَۃٌ خَضْرَائُ عَلَی مَا حَوْلَہَا مِنَ الْبِقَاعِ فَإِذَا کَانَ یَوْمُ الْقِیَامَۃِ قِیلَ أَیْنَ الَّذِینَ کَانُوْا یَتْلُوْنَ کِتَابِیْ لَمْ یُلْہِہِمُ اتِّبَاعُ الْأَنْعَامِ فَیُعْطَی الْخُلْدَ وَالنَّعِیمَ فَإِنْ کَانَ أَبَوَاہُ مَاتَا عَلَی الطَّاعَۃِ جُعِلَ عَلَی رُئُوسِہِمَا تَاجُ الْمُلْکِ فَیَقُولَانِ رَبَّنَا مَا بَلَغَتْ ہٰذَا أَعْمَالُنَا فَیَقُوْلُ بَلٰی إِنَّ ابْنَکُمَا کَانَ یَتْلُوْ کِتَابِیْ ۔1,,takhreej: !صحیح: وہب الدماری شرط ابن حبان پر ہے۔,3412
3413,3413۔ أَخْبَرَنَا قَبِیصَۃُ أَخْبَرَنَا سُفْیَانُ عَنْ عَبْدِ الْمَلِکِ بْنِ عُمَیْرٍ قَالَ قَالَ رَسُولُ اللّٰہِ ﷺ فِیْ فَاتِحَۃِ الْکِتَابِ شِفَائٌ مِنْ کُلِّ دَائٍ ۔2,,takhreej: @مرسل ضعیف: أخرجہ البیہقی فی الشعب(2370),3413
3414,3414۔ حَدَّثَنَا بِشْرُ بْنُ عُمَرَ الزَّہْرَانِیُّ حَدَّثَنَا شُعْبَۃُ عَنْ خُبَیْبِ بْنِ عَبْدِ الرَّحْمَنِ عَنْ حَفْصِ ابْنِ عَاصِمٍ عَنْ أَبِیْ سَعِیدِ بْنِ الْمُعَلَّی الْأَنْصَارِیِّ قَالَ مَرَّ بِی رَسُولُ اللّٰہِ ﷺ فَقَالَ أَلَمْ یَقُلِ اللّٰہُ عَزَّ وَجَلَّ یَا أَیُّہَا الَّذِینَ آمَنُوا اسْتَجِیبُوْا لِلَّہِ وَلِلرَّسُولِ إِذَا دَعَاکُمْ قَالَ أَلَا أُعَلِّمُکَ أَعْظَمَ سُورَۃٍ فِیْ الْقُرْآنِ قَبْلَ أَنْ أَخْرُجَ مِنَ الْمَسْجِدِ فَلَمَّا أَرَادَ أَنْ یَخْرُجَ قَالَ الْحَمْدُ لِلَّہِ رَبِّ الْعَالَمِینَ وَہِیَ السَّبْعُ الْمَثَانِی وَالْقُرْآنُ الْعَظِیمُ الَّذِی أُوتِیْتُمْ ۔1,,takhreej: !صحیح: أخرجہ البخاری،کتاب التفسیر،باب ماجاء فی فاتحۃ الکتاب(4474)والنسائی فی فضائل القرآن(35),3414
3415,3415۔ حَدَّثَنَا مُحَمَّدُ بْنُ سَعِیدٍ حَدَّثَنَا أَبُوْ أُسَامَۃَ عَنْ عَبْدِ الْحَمِیدِ بْنِ جَعْفَرٍ عَنِ الْعَلَائِ بْنِ عَبْدِ الرَّحْمَنِ عَنْ أَبِیْہِ عَنْ أَبِیْ ہُرَیْرَۃَ عَنْ أُبَیِّ بْنِ کَعْبٍ قَالَ قَالَ رَسُولُ اللّٰہِ ﷺ فَاتِحَۃُ الْکِتَابِ ہِیَ السَّبْعُ الْمَثَانِی ۔2,,takhreej: @صحیح: أخرجہ البیہقی،کتاب الصلاۃ،باب تعلیق القراء ۃ المطلقۃ فیما روینا بالفاتحہ 2/376-375 والبخاری، کتاب التفسیر،باب ماجاء فی فاتحۃ الکتاب(4474),3415
3416,3416۔ حَدَّثَنَا نُعَیْمُ بْنُ حَمَّادٍ حَدَّثَنَا عَبْدُ الْعَزِیزِ بْنُ مُحَمَّدٍ عَنِ الْعَلَائِ بْنِ عَبْدِ الرَّحْمَنِ عَنْ أَبِیْہِ عَنْ أَبِیْ ہُرَیْرَۃَ أَنَّ رَسُولَ اللّٰہِ ﷺ قَالَ مَا أُنْزِلَتْ فِیْ التَّوْرَاۃِ وَلَا فِیْ الْاِِنْجِیلِ وَالزَّبُورِ وَالْقُرْآنِ مِثْلُہَا یَعْنِی أُمَّ الْقُرْآنِ وَإِنَّہَا لَسَبْعٌ مِنَ الْمَثَانِی وَالْقُرْآنُ الْعَظِیْمُ الَّذِیْ أُعْطِیْتُ ۔1,,takhreej: ! صحیح: أخرجہ الترمذی،کتاب ثواب القران،باب ماجاء فی فضل فاتحۃ الکتاب(2878)واسخاوی فی جمال القراء 1/116-115,3416
3417,3417۔ أَخْبَرَنَا أَبُوْ عَلِیٍّ الْحَنَفِیُّ حَدَّثَنِی ابْنُ أَبِیْ ذِئْبٍ عَنِ الْمَقْبُرِیِّ عَنْ أَبِیْ ہُرَیْرَۃَ قَالَ قَالَ رَسُوْلُ اللّٰہِ ﷺ الْحَمْدُ لِلَّہِ أُمُّ الْقُرْآنِ وَأُمُّ الْکِتَابِ وَالسَّبْعُ الْمَثَانِیْ۔2,,takhreej: @صحیح: أخرجہ الترمذی،کتاب التفسیر،باب من سورۃ الحجر(3123),3417
3418,3418۔ أَخْبَرَنَا أَبُوْ نُعَیْمٍ حَدَّثَنَا فِطْرٌ عَنْ أَبِیْ إِسْحٰقَ عَنْ أَبِیْ الْأَحْوَصِ عَنْ عَبْدِ اللّٰہِ قَالَ مَا مِنْ بَیْتٍ یُقْرَأُ فِیہِ سُورَۃُ الْبَقَرَۃِ إِلَّا خَرَجَ مِنْہُ الشَّیْطَانُ وَلَہٗ ضَرِیْطٌ ۔3,,takhreej: # صحیح: ’’ولہ خریط‘‘ کے الفاظ صحیح سند سے ثابت نہیں، أخرجہ ابن الضریس فی فضائل القرآن(175)والبیہقی فی شعب الإیمان(2379),3418
3419,3419۔ حَدَّثَنَا أَبُوْ الْمُغِیرَۃِ حَدَّثَنَا عَبْدَۃُ عَنْ خَالِدِ بْنِ مَعْدَانَ قَالَ سُورَۃُ الْبَقَرَۃِ تَعْلِیمُہَا بَرَکَۃٌ وَتَرْکُہَا حَسْرَۃٌ وَلَا یَسْتَطِیعُہَا الْبَطَلَۃُ وَہِیَ فُسْطَاطُ الْقُرْآنِ ۔4,,takhreej: $عمرۃ کے خیالات نہیں ملے’’مستطاط القران‘‘ کے الفاظ کے علاوہ بقیہ الفاظ کی مسلم،کتاب صلاۃ المسافرین،باب فضل قراء ۃ القرآن وسورۃ البقرۃ (804) سے شہادت ملتی ہے۔,3419
3420,3420۔ حَدَّثَنَا عَمْرُو بْنُ عَاصِمٍ حَدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ عَنْ عَاصِمٍ عَنْ أَبِیْ الْأَحْوَصِ عَنْ عَبْدِ اللّٰہِ أَنَّہٗ قَالَ إِنَّ لِکُلِّ شَیْئٍ سَنَامًا وَإِنَّ سَنَامَ الْقُرْآنِ سُورَۃُ الْبَقَرَۃِ وَإِنَّ لِکُلِّ شَیْئٍ لُبَابًا وَإِنَّ لُبَابَ الْقُرْآنِ الْمُفَصَّلُ قَالَ أَبُوْ مُحَمَّد اللُّبَابُ الْخَالِصُ ۔1,,takhreej: !حسن: أخرجہ الطبرانی فی الکبیر9/138(8644)والحاکم(2060)جب کہ یہ الفاظ حاکم کے اسی حوالے سے مرفوعًا بھی ثابت ہیں۔,3420
3421,3421۔ حَدَّثَنَا إِسْمٰعِیْلُ بْنُ أَبَانَ عَنْ مُحَمَّدِ بْنِ طَلْحَۃَ عَنْ زُبَیْدٍ عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْأَسْوَدِ قَالَ مَنْ قَرَأَ سُورَۃَ الْبَقَرَۃِ تُوِّجَ بِہَا تَاجًا فِیْ الْجَنَّۃِ ۔2,,takhreej: @صحیح: أخرجہ ابن الضریس فی فضائل القرآن (165),3421
3422,3422۔ حَدَّثَنَا أَبُوْ نُعَیْمٍ حَدَّثَنَا شُعْبَۃُ عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ عَنْ أَبِیْ الْأَحْوَصِ قَالَ قَالَ عَبْدُ اللّٰہِ إِنَّ الشَّیْطَانَ إِذَا سَمِعَ سُورَۃَ الْبَقَرَۃِ تُقْرَأُ فِیْ بَیْتٍ خَرَجَ مِنْہُ۔3,,takhreej: # صحیح: أخرجہ الحاکم فی المستدرک (2062),3422
3423,3423۔ حَدَّثَنَا أَبُوْ الْمُغِیرَۃِ حَدَّثَنَا صَفْوَانُ حَدَّثَنِی أَیْفَعُ بْنُ عَبْدٍ الْکَلَاعِیُّ قَالَ قَالَ رَجُلٌ یَا رَسُولَ اللّٰہِ أَیُّ سُورَۃِ الْقُرْآنِ أَعْظَمُ قَالَ قُلْ ہُوَ اللّٰہُ أَحَدٌ قَالَ فَأَیُّ آیَۃٍ فِیْ الْقُرْآنِ أَعْظَمُ قَالَ آیَۃُ الْکُرْسِیِّ اللّٰہُ لَا إِلَہَ إِلَّا ہُوَ الْحَیُّ الْقَیُّوْمُ قَالَ فَأَیُّ آیَۃٍ یَا نَبِیَّ اللّٰہِ تُحِبُّ أَنْ تُصِیبَکَ وَأُمَّتَکَ قَالَ خَاتِمَۃُ سُورَۃِ الْبَقَرَۃِ فَإِنَّہَا مِنْ خَزَائِنِ رَحْمَۃِ اللّٰہِ مِنْ تَحْتِ عَرْشِہٖ أَعْطَاہَا ہَذِہِ الْأُمَّۃَ لَمْ تَتْرُکْ خَیْرًا مِنْ خَیْرِ الدُّنْیَا وَالْآخِرَۃِ إِلَّا اشْتَمَلَتْ عَلَیْہِ۔1,,takhreej: ! ضعیف: حافظ ابن حجر اصابۃ میں کہتے ہیں 1/222 یہ دارمی نے کہا ہے کہ ایفع کی آیۃ الکرسی والی حدیث مرسل یا معضل ہے۔,3423
3424,3424۔ حَدَّثَنَا أَبُوْ نُعَیْمٍ حَدَّثَنَا أَبُوْ عَاصِمٍ الثَّقَفِیُّ حَدَّثَنَا الشَّعْبِیُّ قَالَ قَالَ عَبْدُ اللّٰہِ بْنُ مَسْعُوْدٍ لَقِیَ رَجُلٌ مِنْ أَصْحَابِ مُحَمَّدٍ رَجُلًا مِنَ الْجِنِّ فَصَارَعَہٗ فَصَرَعَہُ الْاِِنْسِیُّ فَقَالَ لَہٗ الْاِِنْسِیُّ إِنِّی لَأَرَاکَ ضَئِیلًا شَخِیْتًا کَأَنَّ ذُرَیْعَتَیْکَ ذُرَیْعَتَا کَلْبٍ فَکَذٰلِکَ أَنْتُمْ مَعْشَرَ الْجِنِّ أَمْ أَنْتَ مِنْ بَیْنِہِمْ کَذٰلِکَ قَالَ لَا وَاللّٰہِ إِنِّی مِنْہُمْ لَضَلِیعٌ وَلَکِنْ عَاوِدْنِی الثَّانِیَۃَ فَإِنْ صَرَعْتَنِیْ عَلَّمْتُکَ شَیْئًا یَنْفَعُکَ فَعَاوَدَہٗ فَصَرَعَہٗ قَالَ ہَاتِ عَلِّمْنِیْ قَالَ نَعَمْ قَالَ تَقْرَأُ اللّٰہُ لَا إِلٰہَ إِلَّا ہُوَ الْحَیُّ الْقَیُّومُ قَالَ نَعَمْ قَالَ فَإِنَّکَ لَا تَقْرَؤُہَا فِیْ بَیْتٍ إِلَّا خَرَجَ مِنْہُ الشَّیْطَانُ لَہٗ خَبَجٌکَخَبَجِ الْحِمَارِ ثُمَّ لَا یَدْخُلُہُ حَتّٰی یُصْبِحَ قَالَ أَبُوْ مُحَمَّد الضَّئِیلُ الدَّقِیقُ وَالشَّخِیتُ الْمَہْزُولُ وَالضَّلِیعُ جَیِّدُ الْأَضْلَاعِ وَالْخَبَجُ الرِّیحُ ۔1,,takhreej: ! منقطع، ضعیف: شعبی کا ابن مسعود رضی اللہ عنہ سے سماع ثابت نہیں، أخرجہ الطبرانی فی الکبیر 9/183۔184 (8826),3424
3425,3425۔ حَدَّثَنَا جَعْفَرُ بْنُ عَوْنٍ أَخْبَرَنَا أَبُوْ الْعُمَیْسِ عَنِ الشَّعْبِیِّ قَالَ قَالَ عَبْدُ اللّٰہِ مَنْ قَرَأَ عَشْرَ آیَاتٍ مِنْ سُورَۃِ الْبَقَرَۃِ فِیْ لَیْلَۃٍ لَمْ یَدْخُلْ ذٰلِکَ الْبَیْتَ شَیْطَانٌ تِلْکَ اللَّیْلَۃَ حَتّٰی یُصْبِحَ أَرْبَعًا مِنْ أَوَّلِہَا وَآیَۃُ الْکُرْسِیِّ وَآیَتَانِ بَعْدَہَا وَثَلَاثٌ خَوَاتِیمُہَا أَوَّلُہَا لِلَّہِ مَا فِیْ السَّمٰوَاتِ ۔2,,takhreej: @ ضعیف: سابقہ کی طرح منقطع ہے، أخرجہ الطبرانی فی الکبیر 9/147 (8673),3425
3426,3426۔ أَخْبَرَنَا عَمْرُو بْنُ عَاصِمٍ حَدَّثَنَا حَمَّادٌ عَنْ عَاصِمٍ عَنِ الشَّعْبِیِّ عَنِ ابْنِ مَسْعُودٍ قَالَ مَنْ قَرَأَ أَرْبَعَ آیَاتٍ مِنْ أَوَّلِ سُورَۃِ الْبَقَرَۃِ وَآیَۃَ الْکُرْسِیِّ وَآیَتَانِ بَعْدَ آیَۃِ الْکُرْسِیِّ وَثَـلَاثًا مِنْ آخِرِ سُورَۃِ الْبَقَرَۃِ لَمْ یَقْرَبْہُ وَلَا أَہْلَہٗ یَوْمَئِذٍ شَیْطَانٌ وَلَا شَیْئٌ یَکْرَہُہٗ وَلَا یُقْرَأْنَ عَلَی مَجْنُونٍ إِلَّا أَفَاقَ ۔3,,takhreej: # ضعیف: سابقہ کی طرح منقطع ہے۔ أخرجہ البیہقی فی الشعب (2412),3426
3427,3427۔ حَدَّثَنَا سَعِیدُ بْنُ عَامِرٍ عَنْ شُعْبَۃَ عَنْ أَبِیْ إِسْحٰقَ عَمَّنْ سَمِعَ عَلِیًّا یَقُولُ مَا کُنْتُ أَرٰی أَنَّ أَحَدًا یَعْقِلُ یَنَامُ حَتّٰی یَقْرَأَ ہَؤُلَائِ الْآیَاتِ مِنْ آخِرِ سُورَۃِ الْبَقَرَۃِ وَإِنَّہُنَّ لَمِنْ کَنْزٍ تَحْتَ الْعَرْشِ ۔1,,takhreej: !صحیح: أخرجہ ابن الضریس فی فضائل القرآن ( 176),3427
3428,3428۔ حَدَّثَنَا إِسْحٰقُ بْنُ عِیسَی عَنْ أَبِیْ الْأَحْوَصِ عَنْ أَبِیْ سِنَانٍ عَنِ الْمُغِیرَۃِ بْنِ سُبَیْعٍ وَکَانَ مِنْ أَصْحَابِ عَبْدِ اللّٰہِ قَالَ مَنْ قَرَأَ عَشْرَ آیَاتٍ مِنَ الْبَقَرَۃِ عِنْدَ مَنَامِہِ لَمْ یَنْسَ الْقُرْآنَ أَرْبَعُ آیَاتٍ مِنْ أَوَّلِہَا وَآیَۃُ الْکُرْسِیِّ وَآیَتَانِ بَعْدَہَا وَثَلَاثٌ مِنْ آخِرِہَا قَالَ إِسْحَقُ لَمْ یَنْسَ مَا قَدْ حَفِظَ قَالَ أَبُوْ مُحَمَّد مِنْہُمْ مَنْ یَقُولُ الْمُغِیرَۃُ بْنُ سُمَیْعٍ ۔2,,takhreej: @ صحیح: أخرجہ البیہقی فی الشعب (2413) والترمذی، فی ثواب القرآن،باب،ماجاء فی سورۃ البقرۃ و آیۃ الکرسی (2881) وابونعیم فی ذکر أخبار أصبھان 1/233,3428
3429,3429۔ حَدَّثَنَا إِسْحَقُ بْنُ عِیسَی عَنْ أَبِیْ مُعَاوِیَۃَ عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِیْ بَکْرٍ الْمُلَیْکِیِّ عَنْ أَبِیْ سَلَمَۃَ عَنْ أَبِیْ ہُرَیْرَۃَ قَالَ قَالَ رَسُولُ اللّٰہِ ﷺ مَنْ قَرَأَ آیَۃَ الْکُرْسِیِّ وَفَاتِحَۃَ حم الْمُؤْمِنِ إِلٰی قَوْلِہِ إِلَیْہِ الْمَصِیرُ لَمْ یَرَ شَیْئًا یَکْرَہُہٗ حَتّٰی یُمْسِیَ وَمَنْ قَرَأَہَا حِینَ یُمْسِی لَمْ یَرَ شَیْئًا یَکْرَہُہٗ حَتّٰی یُصْبِحَ۔1,,takhreej: ! ضعیف: عبدالرحمن بن ابی بکر ضعیف ہے۔,3429
3430,3430۔ حَدَّثَنَا عَفَّانُ حَدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ أَخْبَرَنَا أَشْعَثُ بْنُ عَبْدِ الرَّحْمَنِ الْجَرْمِیُّ عَنْ أَبِیْ قِلَابَۃَ عَنْ أَبِیْ الْأَشْعَثِ الصَّنْعَانِیِّ عَنِ النُّعْمَانِ بْنِ بَشِیْرٍ أَنَّ رَسُولَ اللّٰہِ ﷺ قَالَ إِنَّ اللّٰہَ کَتَبَ کِتَابًا قَبْلَ أَنْ یَخْلُقَ السَّمَوَاتِ وَالْأَرْضَ بِأَلْفَیْ عَامٍ فَأَنْزَلَ مِنْہُ آیَتَیْنِ خَتَمَ بِہِمَا سُورَۃَ الْبَقَرَۃِ وَلَا تُقْرَأَنِ فِیْ دَارٍ ثَلَاثَ لَیَالٍ فَیَقْرَبُہَا شَیْطَانٌ ۔2,,takhreej: @ صحیح: أخرجہ ابوعبید فی فضائل القرآن (232) والحاکم 2065 والبیہقی فی الشعب (2400),3430
3431,3431۔ حَدَّثَنَا سَعِیْدُ بْنُ عَامِرٍ عَنْ شُعْبَۃَ عَنْ مَنْصُوْرٍ عَنْ إِبْرَاہِیْمَ عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیْدَ عَنْ أَبِیْ مَسْعُودٍ عَنِ النَّبِیِّ ﷺ قَالَ مَنْ قَرَأَ الْآیَتَیْنِ الْآخِرَتَیْنِ مِنْ سُورَۃِ الْبَقَرَۃِ فِیْ لَیْلَۃٍ کَفَتَاہُ ۔3,,takhreej: #متفق علیہ: أخربہ البخاری، کتاب فضائل القرآن، باب فضل سورۃ البقرۃ (5009) ومسلم،کتاب صلاۃ المسافرین باب فضل الفاتحۃ وخواتیم سورۃ البقرہ (807),3431
3432,3432۔ حَدَّثَنَا أَبُوْ عَاصِمٍ حَدَّثَنَا عُبَیْدُ اللّٰہِ بْنُ أَبِیْ زِیَادٍ عَنْ شَہْرِ بْنِ حَوْشَبٍ عَنْ أَسْمَائَ بِنْتِ یَزِیْدَ قَالَتْ قَالَ رَسُولُ اللّٰہِ ﷺ اسْمُ اللّٰہِ الْأَعْظَمُ فِیْ ہَاتَیْنِ الْآیَتَیْنِ اللّٰہُ لَا إِلٰہَ إِلَّا ہُوَ الْحَیُّ الْقَیُّومُ وَإِلٰہُکُمْ إِلٰہٌ وَاحِدٌ ۔1,,takhreej: !حسن: أخرجہ ابوداؤد، کتاب الصلاۃ، باب الدعاء (1496) والترمذی، کتاب الدعوات، باب ماجاء عن جامع الدعوات عن رسول اللّٰہ ﷺ (3472) وابن ماجہ،کتاب الدعائ،باب اسم اللّٰہ الأعظم (3855),3432
3433,3433۔ حَدَّثَنَا مُجَاہِدٌ ہُوَ ابْنُ مُوْسَی حَدَّثَنَا مَعْنٌ حَدَّثَنَا مُعَاوِیَۃُ بْنُ صَالِحٍ عَنْ أَبِیْ الزَّاہِرِیَّۃِ عَنْ جُبَیْرِ بْنِ نُفَیْرٍ أَنَّ رَسُولَ اللّٰہِ ﷺ قَالَ إِنَّ اللّٰہَ خَتَمَ سُورَۃَ الْبَقَرَۃِ بِآیَتَیْنِ أُعْطِیتُہُمَا مِنْ کَنْزِہٖ الَّذِی تَحْتَ الْعَرْشِ فَتَعَلَّمُوْہُنَّ وَعَلِّمُوْہُنَّ نِسَائَکُمْ فَإِنَّہُمَا صَلَاۃٌ وَقُرْآنٌ وَدُعَائٌ ۔2,,takhreej: @مرسل، ضعیف: أخرجہ مسلم مفاہ، نیز امام حاکم نے (2066) اور بیہقی نے الشعب (3403) میں اسے موصولاً بھی بیان کیاہے۔,3433
3434,3434۔ حَدَّثَنَا أَبُوْ نُعَیْمٍ حَدَّثَنَا بَشِیْرٌ ہُوَ ابْنُ الْمُہَاجِرِ حَدَّثَنِیْ عَبْدُ اللّٰہِ بْنُ بُرَیْدَۃَ عَنْ أَبِیْہِ قَالَ کُنْتُ جَالِسًا عِنْدَ النَّبِیِّ ﷺ فَسَمِعْتُہٗ یَقُولُ تَعَلَّمُوْا سُوْرَۃَ الْبَقَرَۃِ فَإِنَّ أَخْذَہَا بَرَکَۃٌ وَتَرْکَہَا حَسْرَۃٌ وَلَا یَسْتَطِیْعُہَا الْبَطَلَۃُ ثُمَّ سَکَتَ سَاعَۃً ثُمَّ قَالَ تَعَلَّمُوْا سُورَۃَ الْبَقَرَۃِ وَآلِ عِمْرَانَ فَإِنَّہُمَا الزَّہْرَاوَانِ وَإِنَّہُمَا تُظِلَّانِ صَاحِبَہُمَا یَوْمَ الْقِیَامَۃِ کَأَنَّہُمَا غَمَامَتَانِ أَوْ غَیَابَتَانِ أَوْ فِرْقَانِ مِنْ طَیْرٍ صَوَافَّ وَإِنَّ الْقُرْآنَ یَلْقَی صَاحِبَہُ یَوْمَ الْقِیَامَۃِ حِینَ یَنْشَقُّ عَنْہُ الْقَبْرُ کَالرَّجُلِ الشَّاحِبِ فَیَقُولُ لَہٗ ہَلْ تَعْرِفُنِیْ فَیَقُوْلُ مَا أَعْرِفُکَ فَیَقُولُ أَنَا صَاحِبُکَ الْقُرْآنُ الَّذِی أَظْمَأْتُکَ فِیْ الْہَوَاجِرِ وَأَسْہَرْتُ لَیْلَکَ وَإِنَّ کُلَّ تَاجِرٍ مِنْ وَرَائِ تِجَارَتِہٖ وَإِنَّکَ الْیَوْمَ مِنْ وَرَائِ کُلِّ تِجَارَۃٍ فَیُعْطَی الْمُلْکَ بِیَمِینِہِ وَالْخُلْدَ بِشِمَالِہِ وَیُوضَعُ عَلٰی رَأْسِہٖ تَاجُ الْوَقَارِ وَیُکْسٰی وَالِدَاہُ حُلَّتَیْنِ لَا یُقَوَّمُ لَہُمَا الدُّنْیَا فَیَقُولَانِ بِمَ کُسِیْنَا ہٰذَا وَیُقَالُ لَہُمَا بِأَخْذِ وَلَدِکُمَا الْقُرْآنَ ثُمَّ یُقَالُ لَہٗ اقْرَأْ وَاصْعَدْ فِیْ دَرَجِ الْجَنَّۃِ وَغُرَفِہَا فَہُوَ فِیْ صُعُوْدٍ مَا دَامَ یَقْرَأُ ہَذًّا کَانَ أَوْ تَرْتِیلًا ۔1,,takhreej: !حسن: أخرجہ ابن ابی شیبہ 10/492۔493 (10094) و احمد(5/348) والحاکم 2057:,3434
3435,3435۔ حَدَّثَنَا عَبْدُ اللّٰہِ بْنُ صَالِحٍ حَدَّثَنِی مُعَاوِیَۃُ عَنْ أَبِیْ یَحْیَی سُلَیْمِ بْنِ عَامِرٍ أَنَّہٗ سَمِعَ أَبَا أُمَامَۃَ یَقُوْلُ إِنَّ أَخًا لَکُمْ أُرِیَ فِیْ الْمَنَامِ أَنَّ النَّاسَ یَسْلُکُوْنَ فِیْ صَدْعِ جَبَلٍ وَعْرٍ طَوِیْلٍ وَعَلٰی رَأْسِ الْجَبَلِ شَجَرَتَانِ خَضْرَاوَانِ تَہْتِفَانِ ہَلْ فِیْکُمْ مَنْ یَقْرَأُ سُورَۃَ الْبَقَرَۃِ ہَلْ فِیکُمْ مَنْ یَقْرَأُ سُورَۃَ آلِ عِمْرَانَ فَإِذَا قَالَ الرَّجُلُ نَعَمْ دَنَتَا بِأَعْذَاقِہِمَا حَتّٰی یَتَعَلَّقَ بِہِمَا فَتَخْطِرَانِ بِہٖ الْجَبَلَ قَالَ أَبُوْ مُحَمَّد الْأَعْذَاقُ الْأَغْصَانُ ۔1,,takhreej: !ضعیف: عبداللہ بن صالح ضعیف ہے، أخرجہ ابوعبید فی فضائل القرآن (ص236:),3435
3436,3436۔ حَدَّثَنَا عَبْدُ اللّٰہِ بْنُ جَعْفَرٍ الرَّقِّیُّ عَنْ عُبَیْدِ اللّٰہِ بْنِ عَمْرٍو عَنْ زَیْدٍ عَنْ جَابِرٍ عَنْ أَبِیْ الضُّحَی عَنْ مَسْرُوقٍ عَنْ عَبْدِ اللّٰہِ قَالَ قَرَأَ رَجُلٌ عِنْدَ عَبْدِ اللّٰہِ الْبَقَرَۃَ وَآلَ عِمْرَانَ فَقَالَ قَرَأْتَ سُورَتَیْنِ فِیہِمَا اسْمُ اللّٰہِ الْأَعْظَمُ الَّذِی إِذَا دُعِیَ بِہٖ أَجَابَ وَإِذَا سُئِلَ بِہٖ أَعْطٰی ۔2,,takhreej: @صحیح بالشواھد: أخرجہ الطحاوی فی مشکل الآثار 1/63 والطبرانی فی الکبیر 8/282 (7925) والحاکم (1861),3436
3437,3437۔ حَدَّثَنَا مُحَمَّدُ بْنُ سَعِیْدٍ حَدَّثَنَا عَبْدُ السَّلَامِ بْنُ حَرْبٍ عَنِ الْجُرَیْرِیِّ عَنْ أَبِیْ عَطَّافٍ عَنْ کَعْبٍ قَالَ مَنْ قَرَأَ الْبَقَرَۃَ وَآلَ عِمْرَانَ جَائَتَا یَوْمَ الْقِیَامَۃِ تَقُوْلَانِ رَبَّنَا لَا سَبِیلَ عَلَیْہِ ۔1,,takhreej: !ضعیف: عبدالسلام نے جریری سے آخر عمر میں سماع کیا۔,3437
3438,3438۔ حَدَّثَنَا أَبُوْ نُعَیْمٍ حَدَّثَنَا إِسْرَائِیلُ عَنْ أَبِیْ إِسْحٰقَ عَنْ سُلَیْمِ بْنِ حَنْظَلَۃَ الْبَکْرِیِّ قَالَ قَالَ عَبْدُ اللّٰہِ بْنُ مَسْعُوْدٍ مَنْ قَرَأَ آلَ عِمْرَانَ فَہُوَ غَنِیٌّ وَالنِّسَائُ مُحَبِّرَۃٌ قَالَ أَبُوْ مُحَمَّد مُحَبِّرَۃٌ مُزَیِّنَۃٌ ۔2,,takhreej: @صحیح: أخرجہ ابوعبید فی فضائل القرآن ص (237۔238) والبیہقی فی الشعب (2615),3438
3439,3439۔ حَدَّثَنَا إِسْحَقُ بْنُ عِیْسَی عَنِ ابْنِ لَہِیْعَۃَ عَنْ یَزِیْدَ بْنِ أَبِیْ حَبِیْبٍ عَنْ أَبِیْ الْخَیْرِ عَنْ عُثْمَانَ بْنِ عَفَّانَ قَالَ مَنْ قَرَأَ آخِرَ آلِ عِمْرَانَ فِیْ لَیْلَۃٍ کُتِبَ لَہٗ قِیَامُ لَیْلَۃٍ ۔3,,takhreej: #ضعیف: ابن لھیعہ ضعیف ہے، دیکھئے مشکاۃ المصابیح (2171),3439
3440,3440۔ حَدَّثَنَا مُحَمَّدُ بْنُ الْمُبَارَکِ حَدَّثَنَا صَدَقَۃُ بْنُ خَالِدٍ عَنْ یَحْیَی بْنِ الْحَارِثِ عَنْ مَکْحُوْلٍ قَالَ مَنْ قَرَأَ سُوْرَۃَ آلِ عِمْرَانَ یَوْمَ الْجُمُعَۃِ صَلَّتْ عَلَیْہِ الْمَلَائِکَۃُ إِلَی اللَّیْلِ ۔4,,takhreej: $صحیح: مشکاۃ المصابیح (2172),3440
3441,3441۔ حَدَّثَنَا الْقَاسِمُ بْنُ سَلَّامٍ أَبُوْ عُبَیْدٍ قَالَ حَدَّثَنِی عُبَیْدُ اللّٰہِ الْأَشْجَعِیُّ حَدَّثَنِیْ مِسْعَرٌ حَدَّثَنِیْ جَابِرٌ قَبْلَ أَنْ یَقَعَ فِیْمَا وَقَعَ فِیہِ عَنِ الشَّعْبِیِّ قَالَ قَالَ عَبْدُ اللّٰہِ نِعْمَ کَنْزُ الصُّعْلُوْکِ سُورَۃُ آلِ عِمْرَانَ یَقُوْمُ بِہَا فِیْ آخِرِ اللَّیْلِ ۔1,,takhreej: ! صحیح: أخرجہ البیہقی فی الشعب (2616) وعبدالرزاق (6015),3441
3442,3442۔ حَدَّثَنَا مُحَمَّدُ بْنُ سَعِیْدٍ حَدَّثَنَا عَبْدُ السَّلَامِ عَنِ الْجُرَیْرِیِّ عَنْ أَبِیْ السَّلِیْلِ قَالَ أَصَابَ رَجُلٌ دَمًا قَالَ فَأَوَی إِلٰی وَادِی مَجَنَّۃٍ وَادٍ لَا یُمْسِی فِیہِ أَحَدٌ إِلَّا أَصَابَتْہُ جِنَّۃٌ وَعَلَی شَفِیرِ الْوَادِی رَاہِبَانِ فَلَمَّا أَمْسَی قَالَ أَحَدُہُمَا لِصَاحِبِہٖ ہَلَکَ وَاللّٰہِ الرَّجُلُ قَالَ فَافْتَتَحَ سُورَۃَ آلِ عِمْرَانَ قَالَا فَقَرَأَ سُورَۃً طَیِّبَۃً لَعَلَّہُ سَیَنْجُو قَالَ فَأَصْبَحَ سَلِیمًا ۔قَالَ أَبُوْ مُحَمَّد أَبُوْ السَّلِیلِ ضُرَیْبُ بْنُ نُقَیْرٍ وَیُقَالُ ابْنُ نُفَیْرٍ۔2,,takhreej: @ضعیف: عبدالسلام کا ابواسحاق سے سماع متأخر ہے۔,3442
3443,3443۔ حَدَّثَنَا مُعَاذُ بْنُ ہَانِئٍ حَدَّثَنَا إِبْرَاہِیمُ بْنُ طَہْمَانَ حَدَّثَنَا عَاصِمٌ عَنِ الْمُسَیَّبِ بْنِ رَافِعٍ قَالَ قَالَ عَبْدُ اللّٰہِ السَّبْعُ الطُّوَلُ مِثْلُ التَّوْرَاۃِ وَالْمِئِیْنَ مِثْلُ الْاِِنْجِیلِ وَالْمَثَانِیْ مِثْلُ الزَّبُوْرِ وَسَائِرُ الْقُرْآنِ بَعْدُ فَضْلٌ ۔1,,takhreej: ! منقطع، ضعیف: المسیب، ابن مسعود سے نہیں ملے، أخرجہ ابن ابی شیبہ 10/554( 10320),3443
3444,3444۔ حَدَّثَنَا أَبُوْ نُعَیْمٍ حَدَّثَنَا زُہَیْرٌ عَنْ أَبِیْ إِسْحٰقَ عَنْ عَبْدِ اللّٰہِ بْنِ خَلِیْفَۃَ عَنْ عُمَرَ قَالَ الْأَنْعَامُ مِنْ نَوَاجِبِ الْقُرْآنِ۔2,,takhreej: @جید: أخرجہ ابوعبید فی فضائل القرآن (ص240:),3444
3445,3445۔ حَدَّثَنَا مُسْلِمُ بْنُ إِبْرَاہِیمَ حَدَّثَنَا ہَمَّامٌ عَنْ أَبِیْ عِمْرَانَ الْجَوْنِیِّ عَنْ عَبْدِ اللّٰہِ بْنِ رَبَاحٍ عَنْ کَعْبٍ قَالَ فَاتِحَۃُ التَّوْرَاۃِ الْأَنْعَامُ وَخَاتِمَتُہَا ہُوْدٌ۔3,,takhreej: # صحیح: أخرجہ ابی شیبہ 10/555 (10323),3445
3446,3446۔ أَخْبَرَنَا یَزِیدُ بْنُ ہَارُوْنَ أَخْبَرَنَا ہَمَّامٌ عَنْ أَبِیْ عِمْرَانَ الْجَوْنِیِّ عَنْ عَبْدِ اللّٰہِ بْنِ رَبَاحٍ أَنَّ النَّبِیَّ ﷺ قَالَ اقْرَئُوْا سُورَۃَ ہُوْدٍ یَوْمَ الْجُمُعَۃِ ۔4,,takhreej: $ مرسل،ضعیف,3446
3447,3447۔ حَدَّثَنَا مُسْلِمُ بْنُ إِبْرَاہِیْمَ حَدَّثَنَا ہَمَّامٌ حَدَّثَنَا أَبُوْ عِمْرَانَ الْجَوْنِیُّ عَنْ عَبْدِ اللّٰہِ بْنِ رَبَاحٍ عَنْ کَعْبٍ قَالَ قَالَ رَسُولُ اللّٰہِ ﷺ اقْرَئُوْا سُورَۃَ ہُودٍ یَوْمَ الْجُمُعَۃِ ۔5,,takhreej: % مرسل ضعیف: أخرجہ ابوداؤد، فی مراسیلہ (59) والبیہقی فی الشعب (2438) دیکھئے: الدرالمنشور 1/319,3447
3448,3448۔ حَدَّثَنَا أَبُوْ الْمُغِیرَۃِ حَدَّثَتْنَا عَبْدَۃُ عَنْ خَالِدِ بْنِ مَعْدَانَ قَالَ مَنْ قَرَأَ عَشْرَ آیَاتٍ مِنَ الْکَہْفِ لَمْ یَخَفِ الدَّجَّالَ ۔1,,takhreej: ! صحیح بالشاھد: أخرجہ مسلم، کتاب صلاۃ المسافرین، باب فضل سورۃ الکھف و آیۃ الکرسی (809) وابوعبید فی فضائل القرآن (ص245:),3448
3449,3449۔ حَدَّثَنَا مُحَمَّدُ بْنُ کَثِیرٍ عَنِ الْأَوْزَاعِیِّ عَنْ عَبْدَۃَ عَنْ زِرِّ بْنِ حُبَیْشٍ قَالَ مَنْ قَرَأَ آخِرَ سُورَۃِ الْکَہْفِ لِسَاعَۃٍ یُرِیدُ یَقُومُ مِنَ اللَّیْلِ قَامَہَا قَالَ عَبْدَۃُ فَجَرَّبْنَاہُ فَوَجَدْنَاہُ کَذٰلِکَ ۔2,,takhreej: @ ضعیف: محمد بن کثیر ضعیف راوی ہے، أخرجہ ابوعبید فی فضائل القرآن (ص246:),3449
3450,3450۔ حَدَّثَنَا أَبُوْ النُّعْمَانِ حَدَّثَنَا ہُشَیْمٌ حَدَّثَنَا أَبُوْ ہَاشِمٍ عَنْ أَبِیْ مِجْلَزٍ عَنْ قَیْسِ بْنِ عُبَادٍ عَنْ أَبِیْ سَعِیْدٍ الْخُدْرِیِّ قَالَ مَنْ قَرَأَ سُورَۃَ الْکَہْفِ لَیْلَۃَ الْجُمُعَۃِ أَضَائَ لَہٗ مِنَ النُّورِ فِیمَا بَیْنَہٗ وَبَیْنَ الْبَیْتِ الْعَتِیْقِ ۔3,,takhreej: # صحیح: أخرجہ ابوعبید فی فضائل القرآن (ص244:) والبیہقی فی الشعب (2444) والنسائی فی عمل الیوم واللیلۃ (953) والحاکم (2072),3450
3451,3451۔ أَخْبَرَنَا أَبُوْ الْمُغِیْرَۃِ حَدَّثَتْنَا عَبْدَۃُ عَنْ خَالِدِ بْنِ مَعْدَانَ قَالَ اقْرَئُوا الْمُنَجِّیَۃَ وَہِیَ الم تَنْزِیلُ فَإِنَّہٗ بَلَغَنِی أَنَّ رَجُلًا کَانَ یَقْرَؤُہَا مَا یَقْرَأُ شَیْئًا غَیْرَہَا وَکَانَ کَثِیْرَ الْخَطَایَا فَنَشَرَتْ جَنَاحَہَا عَلَیْہِ وَقَالَتْ رَبِّ اغْفِرْ لَہٗ فَإِنَّہٗ کَانَ یُکْثِرُ قِرَائَتِیْ فَشَفَّعَہَا الرَّبُّ فِیہِ وَقَالَ اکْتُبُوا لَہٗ بِکُلِّ خَطِیْئَۃٍ حَسَنَۃً وَارْفَعُوْا لَہُ دَرَجَۃً۔1,,takhreej: !عبدۃ بنت خالد کا ترجمہ نہ مل سکا دیکھئے الدرالمنشور 5/170۔171,3451
3452,3452۔ حَدَّثَنَا عَفَّانُ حَدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ أَخْبَرَنَا أَبُوْ الزُّبَیْرِ عَنْ عَبْدِ اللّٰہِ بْنِ ضَمْرَۃَ عَنْ کَعْبٍ قَالَ مَنْ قَرَأَ تَنْزِیلُ السَّجْدَۃَ وَ تَبَارَکَ الَّذِی بِیَدِہِ الْمُلْکُ کُتِبَ لَہٗ سَبْعُونَ حَسَنَۃً وَحُطَّ عَنْہُ بِہَا سَبْعُونَ سَیِّئَۃً وَرُفِعَ لَہٗ بِہَا سَبْعُوْنَ دَرَجَۃً ۔2,,takhreej: @ صحیح: أخرجہ ابن الضریس فی فضائل القرآن (213) دیکھئے الدر المنشور 5/170,3452
3453,3453۔ حَدَّثَنَا عَبْدُ اللّٰہِ بْنُ صَالِحٍ حَدَّثَنِی مُعَاوِیَۃُ بْنُ صَالِحٍ أَنَّہٗ سَمِعَ أَبَا خَالِدٍ عَامِرَ بْنَ جَشِیبٍ وَبَحِیرَ بْنَ سَعْدٍ یُحَدِّثَانِ أَنَّ خَالِدَ بْنَ مَعْدَانَ قَالَ إِنَّ الم تَنْزِیلُ تُجَادِلُ عَنْ صَاحِبِہَا فِیْ الْقَبْرِ تَقُولُ اللّٰہُمَّ إِنْ کُنْتُ مِنْ کِتَابِکَ فَشَفِّعْنِیْ فِیْہِ وَإِنْ لَمْ أَکُنْ مِنْ کِتَابِکَ فَامْحُنِیْ عَنْہُ وَإِنَّہَا تَکُونُ کَالطَّیْرِ تَجْعَلُ جَنَاحَہَا عَلَیْہِ فَیُشْفَعُ لَہٗ فَتَمْنَعُہٗ مِنْ عَذَابِ الْقَبْرِ وَفِیْ تَبَارَکَ مِثْلَہٗ فَکَانَ خَالِدٌ لَا یَبِیْتُ حَتّٰی یَقْرَأَ بِہِمَا ۔1,,takhreej: ! ضعیف: عبداللہ بن صالح ضعیف ہے۔ امام ترمذی نے اسے مشکاۃ (2176) میں دارمی کے حوالے سے روایت کیا ہے۔ دیکھئے الدر المنشور 5/171,3453
3454,3454۔ أَخْبَرَنَا أَبُوْ نُعَیْمٍ حَدَّثَنَا سُفْیَانُ عَنْ لَیْثٍ عَنْ أَبِیْ الزُّبَیْرِ عَنْ جَابِرٍ قَالَ کَانَ النَّبِیُّ ﷺ لَا یَنَامُ حَتّٰی یَقْرَأَ تَنْزِیلُ السَّجْدَۃَ وَتَبَارَکَ ۔2,,takhreej: @ صحیح اخرجہ البخاری، فی الأدب المفرد (1209) والحاکم (3545) والنسائی فی الکبریٰ (10542),3454
3455,3455۔ حَدَّثَنَا مُوسَی بْنُ خَالِدٍ حَدَّثَنَا مُعْتَمِرٌ عَنْ لَیْثٍ عَنْ طَاوٗسٍ قَالَ فُضِّلَتَا عَلَی کُلِّ سُورَۃٍ فِیْ الْقُرْآنِ بِسِتِّینَ حَسَنَۃً ۔3,,takhreej: # ضعیف: أخرجہ ابن الضریس فی فضائل القرآن (233) وعبدالرزاق (6035),3455
3456,3456۔ أَخْبَرَنَا حَجَّاجُ بْنُ مِنْہَالٍ حَدَّثَنَا شُعْبَۃُ حَدَّثَنِی عَمْرُو بْنُ مُرَّۃَ قَالَ سَمِعْتُ مُرَّۃَ یَقُولُ أُتِیَ رَجُلٌ فِیْ قَبْرِہِ فَأُتِیَ جَانِبُ قَبْرِہِ فَجَعَلَتْ سُوْرَۃٌ مِنَ الْقُرْآنِ ثَـلَاثُوْنَ آیَۃً تُجَادِلُ عَنْہُ حَتّٰی قَالَ فَنَظَرْنَا أَنَا وَمَسْرُوقٌ فَلَمْ نَجِدْ فِیْ الْقُرْآنِ سُورَۃً ثَـلَاثِینَ آیَۃً إِلَّا تَبَارَک ۔1,,takhreej: !صحیح: أخرجہ ابن الضریس فی فضائل القرآن (234) وابوعبید فی فضائل القرآں (ص260:) والطبرانی فی الکبیر 9/140 (8651),3456
3457,3457۔ حَدَّثَنَا إِبْرَاہِیمُ بْنُ الْمُنْذِرِ حَدَّثَنَا إِبْرَاہِیمُ بْنُ الْمُہَاجِرِ بْنِ الْمِسْمَارِ عَنْ عُمَرَ بْنِ حَفْصِ بْنِ ذَکْوَانَ عَنْ مَوْلَی الْحُرَقَۃِ عَنْ أَبِیْ ہُرَیْرَۃَ قَالَ قَالَ رَسُولُ اللّٰہِ ﷺ إِنَّ اللّٰہَ تَبَارَکَ وَتَعَالَی قَرَأَطٰہَ وَیٰسٓ قَبْلَ أَنْ یَخْلُقَ السَّمَوَاتِ وَالْأَرْضَ بِأَلْفِ عَامٍ فَلَمَّا سَمِعَتِ الْمَلَائِکَۃُ الْقُرْآنَ قَالَتْ طُوْبٰی لِأُمَّۃٍ یَنْزِلُ ہٰذَا عَلَیْہَا وَطُوبٰی لِأَجْوَافٍ تَحْمِلُ ہٰذَا وَطُوبٰی لِأَلْسِنَۃٍ تَتَکَلَّمُ بِہٰذَا ۔2,,takhreej: @ ضعیف جدًا: ابن حبان وابن جوزی کہتے ہیں (ھذا متن موضوع) دیکھئے میزان الاعتدال 1/67، ومشکاۃ المصابیح (2148),3457
3458,3458۔ حَدَّثَنَا أَبُوْ الْوَلِیْدِ مُوسَی بْنُ خَالِدٍ حَدَّثَنَا مُعْتَمِرٌ عَنْ أَبِیْہِ قَالَ بَلَغَنِی عَنِ الْحَسَنِ قَالَ مَنْ قَرَأَ یس فِیْ لَیْلَۃٍ ابْتِغَائَ وَجْہِ اللّٰہِ أَوْ مَرْضَاۃِ اللّٰہِ غُفِرَ لَہٗ وَقَالَ بَلَغَنِی أَنَّہَا تَعْدِلُ الْقُرْآنَ کُلَّہٗ۔1,,takhreej: ! منقطع،ضعیف: دیکھئے الدر المنشور 5/256,3458
3459,3459۔ حَدَّثَنَا مُحَمَّدُ بْنُ سَعِیْدٍ حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ عَنِ الْحَسَنِ بْنِ صَالِحٍ عَنْ ہَارُوْنَ أَبِیْ مُحَمَّدٍ عَنْ مُقَاتِلِ بْنِ حَیَّانَ عَنْ قَتَادَۃَ عَنْ أَنَسٍ قَالَ قَالَ رَسُولُ اللّٰہِ ﷺ إِنَّ لِکُلِّ شَیْئٍ قَلْبًا وَإِنَّ قَلْبَ الْقُرْآنِ یٰسٓ مَنْ قَرَأَہَا فَکَأَنَّمَا قَرَأَ الْقُرْآنَ عَشْرَ مَرَّاتٍ ۔2,,takhreej: @ ضعیف: ہارون ابومحمد مجہول ہے۔ أخرجہ الترمذی، کتاب ثواب القرآن، باب ماجاء فی فضل یٰس (2889) والبیہقی فی الشعب (2460),3459
3460,3460۔ حَدَّثَنَا الْوَلِیدُ بْنُ شُجَاعٍ حَدَّثَنِی أَبِیْ حَدَّثَنِی زِیَادُ بْنُ خَیْثَمَۃَ عَنْ مُحَمَّدِ بْنِ جُحَادَۃَ عَنِ الْحَسَنِ عَنْ أَبِیْ ہُرَیْرَۃَ قَالَ قَالَ رَسُولُ اللّٰہِ ﷺ مَنْ قَرَأَ یس فِیْ لَیْلَۃٍ ابْتِغَائَ وَجْہِ اللّٰہِ غُفِرَ لَہٗ فِیْ تِلْکَ اللَّیْلَۃِ ۔1,,takhreej: !منقطع، ضعیف,3460
3461,3461۔ حَدَّثَنَا الْوَلِیدُ بْنُ شُجَاعٍ حَدَّثَنِی أَبِیْ حَدَّثَنِی زِیَادُ بْنُ خَیْثَمَۃَ عَنْ مُحَمَّدِ بْنِ جُحَادَۃَ عَنْ عَطَائِ بْنِ أَبِیْ رَبَاحٍ قَالَ بَلَغَنِی أَنَّ رَسُولَ اللّٰہِ ﷺ قَالَ مَنْ قَرَأَ یس فِیْ صَدْرِ النَّہَارِ قُضِیَتْ حَوَائِجُہٗ۔2,,takhreej: @ مرسل، ضعیف: أخرجہ البیہقی فی الشعب (2463) وابن حبان 2574,3461
3462,3462۔ حَدَّثَنَا عَمْرُو بْنُ زُرَارَۃَ حَدَّثَنَا عَبْدُ الْوَہَّابِ حَدَّثَنَا رَاشِدٌ أَبُوْ مُحَمَّدٍ الْحِمَّانِیُّ عَنْ شَہْرِ بْنِ حَوْشَبٍ قَالَ قَالَ ابْنُ عَبَّاسٍ مَنْ قَرَأَ یس حِینَ یُصْبِحُ أُعْطِیَ یُسْرَ یَوْمِہِ حَتّٰی یُمْسِیَ وَمَنْ قَرَأَہَا فِیْ صَدْرِ لَیْلِہِ أُعْطِیَ یُسْرَ لَیْلَتِہٖ حَتّٰی یُصْبِحَ ۔3,,takhreej: # حسن: امام سیوطی الدرالمنشور میں کہتے ہیں۔ 5/257، أخرجہ الدارمی عن ابن عباس ، اور پھر اس حدیث کا ذکر کرتے ہیں۔,3462
3463,3463۔ حَدَّثَنَا یَعْلَی حَدَّثَنَا إِسْمٰعِیْلُ عَنْ عَبْدِ اللّٰہِ بْنِ عِیْسٰی قَالَ أُخْبِرْتُ أَنَّہٗ مَنْ قَرَأَ حٰمٓ الدُّخَانَ لَیْلَۃَ الْجُمُعَۃِ إِیْمَانًا وَتَصْدِیْقًا بِہَا أَصْبَحَ مَغْفُورًا لَہٗ۔4,,takhreej: $ صحیح: سیوطی الدرالمنشور میں کہتے ہیں 6/24۔25 ’’أخرج الدارمی‘‘ پھر اس حدیث کا تذکرہ کرتے ہیں نیز اس کی شاہد ’’ترمذی کتاب ثواب القرآن،باب ماجاء فی فضل حمٓ الدخان (2891) میں ہے۔,3463
3464,3464۔ حَدَّثَنَا مُحَمَّدُ بْنُ الْمُبَارَکِ حَدَّثَنَا صَدَقَۃُ بْنُ خَالِدٍ عَنْ یَحْیَی بْنِ الْحَارِثِ عَنْ أَبِیْ رَافِعٍ قَالَ مَنْ قَرَأَ الدُّخَانَ فِیْ لَیْلَۃِ الْجُمُعَۃِ أَصْبَحَ مَغْفُورًا لَہٗ وَزُوِّجَ مِنَ الْحُوْرِ الْعِینِ۔ 1,,takhreej: ! صحیح: سیوطی الدرالمنشور6/24 میں دارمی کاحوالہ دیتے ہیں۔,3464
3465,3465۔ حَدَّثَنَا جَعْفَرُ بْنُ عَوْنٍ عَنْ مِسْعَرٍ عَنْ سَعْدِ بْنِ إِبْرَاہِیمَ قَالَ کُنَّ الْحَوَامِیمُ یُسَمَّیْنَ الْعَرَائِسَ ۔2,,takhreej: @ صحیح: أخرجہ ابن ابی شیبہ 10/557 (10333) والبیہقی فی الشعب (2482),3465
3466,3466۔ حَدَّثَنَا سَعِیدُ بْنُ عَامِرٍ عَنْ ہِشَامٍ عَنِ الْحَسَنِ قَالَ مَنْ قَرَأَ ثَـلَاثَ آیَاتٍ مِنْ آخِرِ سُورَۃِ الْحَشْرِ إِذَا أَصْبَحَ فَمَاتَ مِنْ یَوْمِہٖ ذٰلِکَ طُبِعَ بِطَابَعِ الشُّہَدَائِ وَإِنْ قَرَأَ إِذَا أَمْسَی فَمَاتَ مِنْ لَیْلَتِہِ طُبِعَ بِطَابَعِ الشُّہَدَائِ ۔3,,takhreej: # صحیح: أخرجہ ابن الضریس فی فضائل القرآن (227) سیوطی اسے الدر المنشور میں 1/202اسے دارمی کی طرف منسوب کرتے ہیں۔,3466
3467,3467۔ حَدَّثَنَا إِسْحٰقُ بْنُ عِیْسٰی عَنْ مَعْنٍ عَنْ مُعَاوِیَۃَ بْنِ صَالِحٍ عَنْ بَحِیْرِ بْنِ سَعْدٍ عَنْ خَالِدِ بْنِ مَعْدَانَ عَنِ النَّبِیِّ ﷺ أَنَّہٗ کَانَ یَقْرَأُ الْمُسَبِّحَاتِ عِنْدَ النَّوْمِ وَیَقُولُ إِنَّ فِیہِنَّ آیَۃً تَعْدِلُ أَلْفَ آیَۃٍ ۔1,,takhreej: ! صحیح: أخرجہ احمد 4/128 والبیہقی فی الشعب (2503) وابوداؤد، کتاب الأدب، باب مایقول عندالنوم (5057),3467
3468,3468۔ حَدَّثَنَا مُحَمَّدُ بْنُ الْفَرَجِ الْبَغْدَادِیُّ حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللّٰہِ بْنِ الزُّبَیْرِ حَدَّثَنَا خَالِدُ بْنُ طَہْمَانَ أَبُوْ الْعَلَائِ الْخَفَّافُ حَدَّثَنِیْ نَافِعُ بْنُ أَبِیْ نَافِعٍ عَنْ مَعْقِلِ بْنِ یَسَارٍ عَنِ النَّبِیِّ ﷺ قَالَ مَنْ قَالَ حِینَ یُصْبِحُ أَعُوذُ بِاللّٰہِ السَّمِیعِ الْعَلِیمِ مِنَ الشَّیْطَانِ الرَّجِیمِ وَثَـلَاثَ آیَاتٍ مِنْ آخِرِ سُورَۃِ الْحَشْرِ وَکَّلَ اللّٰہُ بِہٖ سَبْعِینَ أَلْفَ مَلَکٍ یُصَلُّونَ عَلَیْہِ حَتّٰی یُمْسِیَ وَإِنْ قَالَہَا مَسَائً فَمِثْلُ ذٰلِکَ حَتّٰی یُصْبِحَ ۔2,,takhreej: @حسن: أخرجہ احمد 5/26، والترمذی، کتاب ثواب القرآن، باب فضل آخر سورۃ الحشر (2923),3468
3469,3469۔ حَدَّثَنَا أَبُوْ زَیْدٍ سَعِیدُ بْنُ الرَّبِیعِ حَدَّثَنَا شُعْبَۃُ عَنْ أَبِیْ الْحَسَنِ مُہَاجِرٍ قَالَ جَائَ رَجُلٌ زَمَنَ زِیَادٍ إِلٰی الْکُوفَۃِ فَسَمِعْتُہُ یُحَدِّثُ أَنَّہٗ کَانَ مَعَ رَسُولِ اللّٰہِ ﷺ فِیْ مَسِیْرٍ لَہٗ قَالَ وَرُکْبَتِیْ تُصِیبُ أَوْ تَمَسُّ رُکْبَتَہٗ فَسَمِعَ رَجُلًا یَقْرَأُ قُلْ یَا أَیُّہَا الْکَافِرُوْنَ قَالَ بَرِئَ مِنَ الشِّرْکِ وَسَمِعَ رَجُلًا یَقْرَأُ قُلْ ہُوَ اللّٰہُ أَحَدٌ قَالَ غُفِرَ لَہٗ۔1,,takhreej: !صحیح: جہالت صحابی قارح نہیں، أخرجہ ابن الضریس فی فضائل القرآن (305) والنسائی فی الکبریٰ (10540) احمد 4/63، 64،65,3469
3470,3470۔ حَدَّثَنَا أَبُوْ نُعَیْمٍ حَدَّثَنَا زُہَیْرٌ عَنْ أَبِیْ إِسْحٰقَ عَنْ فَرْوَۃَ بْنِ نَوْفَلٍ عَنْ أَبِیْہِ أَنَّ رَسُولَ اللّٰہِ ﷺ قَالَ مَجِیئٌ مَا جَائَ بِکَ قَالَ جِئْتُ لِتُعَلِّمَنِی شَیْئًا أَقُولُہٗ عِنْدَ مَنَامِیْ قَالَ فَإِذَا أَخَذْتَ مَضْجَعَکَ فَاقْرَأْ قُلْ یَا أَیُّہَا الْکَافِرُونَ ثُمَّ نَمْ عَلَی خَاتِمَتِہَا فَإِنَّہَا بَرَائَۃٌ مِنَ الشِّرْکِ ۔2,,takhreej: @ صحیح: أخرجہ ابوعبید فی فضائل القرآن (ص264:),3470
3471,3471۔ حَدَّثَنَا أَبُوْ الْمُغِیْرَۃِ حَدَّثَنَا صَفْوَانُ حَدَّثَنَا إِیَاسٌ الْبِکَالِیُّ عَنْ نَوْفٍ الْبِکَالِیِّ قَالَ إِنَّ اللّٰہَ جَزَّأَ الْقُرْآنَ عَلَی ثَـلَاثَۃِ أَجْزَائٍ فَجَعَلَ قُلْ ہُوَ اللّٰہُ أَحَدٌ ثُلُثَ الْقُرْآنِ۔ 1,,takhreej: ! ضعیف: ایاس اللبکائی مجہول ہے۔,3471
3472,3472۔ حَدَّثَنَا عَبْدُ اللّٰہِ بْنُ یَزِیدَ حَدَّثَنَا حَیْوَۃُ قَالَ أَخْبَرَنِیْ أَبُوْ عَقِیلٍ أَنَّہٗ سَمِعَ سَعِیدَ بْنَ الْمُسَیَّبِ یَقُوْلُ إِنَّ نَبِیَّ اللّٰہِ ﷺ قَالَ مَنْ قَرَأَ قُلْ ہُوَ اللّٰہُ أَحَدٌ عَشْرَ مَرَّاتٍ بُنِیَ لَہٗ بِہَا قَصْرٌ فِیْ الْجَنَّۃِ وَمَنْ قَرَأَ عِشْرِینَ مَرَّۃً بُنِیَ لَہٗ بِہَا قَصْرَانِ فِیْ الْجَنَّۃِ وَمَنْ قَرَأَہَا ثَـلَاثِینَ مَرَّۃً بُنِیَ لَہٗ بِہَا ثَـلَاثَۃُ قُصُوْرٍ فِیْ الْجَنَّۃِ فَقَالَ عُمَرُ بْنُ الْخَطَّابِ وَاللّٰہِ یَا رَسُولَ اللّٰہِ إِذَنْ لَتَکْثُرَنَّ قُصُوْرُنَا فَقَالَ رَسُولُ اللّٰہِ ﷺ اللّٰہُ أَوْسَعُ مِنْ ذٰلِکَ قَالَ أَبُوْ مُحَمَّد أَبُوْ عَقِیلٍ زُہْرَۃُ بْنُ مَعْبَدٍوَزَعَمُوْا أَنَّہٗ کَانَ مِنَ الْأَبْدَالِ ۔2,,takhreej: @حسن لغیرہ: أخرجہ احمد3/437، وابن کثیر فی التفسیر 5/251 والطبرانی فی الکبیر20/185(397) و (398),3472
3473,3473۔ أَخْبَرَنَا أَبُوْ الْمُغِیرَۃِ عَنْ عُتْبَۃَ بْنِ ضَمْرَۃَ بْنِ حَبِیْبٍ عَنْ أَبِیْہِ أَنَّہٗ کَانَ إِذَا قَرَأَ سُورَۃً فَخَتَمَہَا أَتْبَعَہَا بِقُلْ ہُوَ اللّٰہُ أَحَدٌ ۔1,,takhreej: ! صحیح,3473
3474,3474۔ حَدَّثَنَا مُسْلِمُ بْنُ إِبْرَاہِیْمَ عَنْ أَبَانَ بْنِ یَزِیْدَ الْعَطَّارِ حَدَّثَنَا قَتَادَۃُ عَنْ سَالِمِ بْنِ أَبِیْ الْجَعْدِ عَنْ مَعْدَانَ بْنِ أَبِیْ طَلْحَۃَ عَنْ أَبِیْ الدَّرْدَائِ قَالَ قَالَ رَسُولُ اللّٰہِ ﷺ أَیَعْجِزُ أَحَدُکُمْ أَنْ یَقْرَأَ فِیْ لَیْلَۃٍ ثُلُثَ الْقُرْآنِ قَالُوْا نَحْنُ أَعْجَزُ وَأَضْعَفُ مِنْ ذٰلِکَ فَقَالَ إِنَّ اللّٰہَ جَزَّأَ الْقُرْآنَ ثَـلَاثَۃَ أَجْزَائٍ فَجَعَلَ قُلْ ہُوَ اللّٰہُ أَحَدٌ ثُلُثَ الْقُرْآنِ ۔2,,takhreej: @ صحیح: أخرجہ مسلم، کتاب صلاۃ المسافرین، باب فضل قراء ۃ (قل ھو اللّٰہ احد) والنسائی فی عمل الیوم واللیلۃ (701) وابوعبید فی فضائل القرآن (ص269,3474
3475,3475۔ حَدَّثَنَا أَبُوْ نُعَیْمٍ عَنْ إِبْرَاہِیمَ بْنِ إِسْمَعِیلَ بْنِ مُجَمِّعٍ قَالَ أَخْبَرَنِی ابْنُ شِہَابٍ أَنَّ حُمَیْدَ بْنَ عَبْدِ الرَّحْمَنِ حَدَّثَہٗ أَنَّ أَبَا ہُرَیْرَۃَ کَانَ یَقُولُ قُلْ ہُوَ اللّٰہُ أَحَدٌ تَعْدِلُ ثُلُثَ الْقُرْآنِ ۔3,,takhreej: # صحیح: أخرجہ الترمذی،کتاب ثواب القران،باب فی سورۃ الاخلاص(2901)وابن ماجہ،کتاب الأدب،باب ثواب القران(3787)والطحاوی فی مشکل الآثار(1222-1221),3475
3476,3476۔ أَخْبَرَنَا الْمُعَلَّی بْنُ أَسَدٍ عَنْ سَلَّامِ بْنِ أَبِیْ مُطِیْعٍ عَنْ عَاصِمٍ عَنْ زِرٍّ عَنْ عَبْدِ اللّٰہِ قَالَ قُلْ ہُوَ اللّٰہُ أَحَدٌ تَعْدِلُ ثُلُثَ الْقُرْآنِ ۔4,,takhreej: $ حسن: آئندہ حدیث ملاحظہ کریں۔,3476
3477,3477۔ حَدَّثَنَا عَمْرُو بْنُ عَاصِمٍ عَنْ حَمَّادِ بْنِ سَلَمَۃَ عَنْ عَاصِمٍ عَنْ زِرٍّ عَنْ عَبْدِ اللّٰہِ مِثْلَہٗ ۔1,,takhreej: !حسن: أخرجہ النسائی فی الکبریٰ(10509)وابو عبید فی فضائل القران(ص268)والطبرانی فی الکبیر 10 / 172 (10245),3477
3478,3478۔ حَدَّثَنَا یَزِیْدُ بْنُ ہَارُوْنَ أَخْبَرَنَا مُبَارَکُ بْنُ فَضَالَۃَ حَدَّثَنَا ثَابِتٌ عَنْ أَنَسٍ أَنَّ رَجُلًا قَالَ وَاللّٰہِ إِنِّی لَأُحِبُّ ہٰذِہِ السُّورَۃَ قُلْ ہُوَ اللّٰہُ أَحَدٌ فَقَالَ رَسُولُ اللّٰہِ ﷺ حُبُّکَ إِیَّاہَا أَدْخَلَکَ الْجَنَّۃَ ۔2,,takhreej: @صحیح: أخرجہ الرازی فی فضائل القران(108)وابن خزیمہ(537)وعبد بن حمید فی المنتخب(1306),3478
3479,3479۔ حَدَّثَنَا عَبْدُ اللّٰہِ بْنُ مَسْلَمَۃَ حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللّٰہِ بْنِ مُسْلِمٍ عَنْ مُحَمَّدِ بْنِ شِہَابٍ عَنْ حُمَیْدِ بْنِ عَبْدِ الرَّحْمٰنِ عَنْ أُمِّہِ أَنَّ رَسُولَ اللّٰہِ ﷺ سُئِلَ عَنْ قُلْ ہُوَ اللّٰہُ أَحَدٌ فَقَالَ ثُلُثُ الْقُرْآنِ أَوْ تَعْدِلُہٗ۔3,,takhreej: #حسن: أخرجہ مالک فی القران،باب ماجاء فی قراء ۃ(قل اللہ احد)(19)واحمد6/404والنسائی فی الکبریٰ (10533),3479
3480,3480۔ حَدَّثَنَا عُبَیْدُ اللّٰہِ بْنُ مُوسَی عَنْ إِسْرَائِیلَ عَنْ مَنْصُورٍ عَنْ ہِلَالٍ عَنِ الرَّبِیْعِ بْنِ خُثَیْمٍ عَنْ عَمْرِو بْنِ مَیْمُونٍ عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِیْ لَیْلٰی عَنِ امْرَأَۃٍ مِنَ الْأَنْصَارِ عَنْ أَبِیْ أَیُّوْبَ قَالَ أَتَاہَا فَقَالَ أَلَا تَرَیْنَ إِلٰی مَا جَائَ بِہٖ رَسُولُ اللّٰہِ ﷺ قَالَتْ رُبَّ خَیْرٍ قَدْ أَتَانَا بِہٖ رَسُولُ اللّٰہِ ﷺ فَمَا ہُوَ قَالَ قَالَ لَنَا أَیَعْجِزُ أَحَدُکُمْ أَنْ یَقْرَأَ ثُلُثَ الْقُرْآنِ فِیْ لَیْلَۃٍ قَالَ فَأَشْفَقْنَا أَنْ یُرِیدَنَا عَلَی أَمْرٍ نَعْجِزُ عَنْہُ فَلَمْ نَرْجِعْ إِلَیْہِ شَیْئًا حَتّٰی قَالَہَا ثَـلَاثَ مَرَّاتٍ ثُمَّ قَالَ أَمَا یَسْتَطِیْعُ أَحَدُکُمْ أَنْ یَقْرَأَ اللّٰہُ الْوَاحِدُ الصَّمَدُ۔1,,takhreej: !صحیح: أخرجہ الترمذی،کتاب ثواب القران،باب ماجاء فی سورۃ الاخلاص(2898)وابن عبدالبیر التہمید 7/256 والنسائی فی الکبریٰ(10519),3480
3481,3481۔ حَدَّثَنَا نَصْرُ بْنُ عَلِیٍّ عَنْ نُوحِ بْنِ قَیْسٍ عَنْ مُحَمَّدٍ الْعَطَّارِ عَنْ أُمِّ کَثِیرٍ الْأَنْصَارِیَّۃِ عَنْ أَنَسِ بْنِ مَالِکٍ قَالَ قَالَ رَسُولُ اللّٰہِ ﷺ مَنْ قَرَأَ قُلْ ہُوَ اللّٰہُ أَحَدٌ خَمْسِیْنَ مَرَّۃً غَفَرَ اللّٰہُ لَہٗ ذُنُوبَ خَمْسِینَ سَنَۃً ۔2,,takhreej: @ ام کثیر انصاریہ نامعلوم ، أخرجہ الترمذی،کتاب ثواب القران ، باب ماجاء فی سوۃ الاخلاص(2900)والبیہقی فی الشعب (2548) والخطیب فی تاریخ بغداد6/204,3481
3482,3482۔ حَدَّثَنَا عَبْدُ اللّٰہِ بْنُ یَزِیدَ حَدَّثَنَا حَیْوَۃُ وَابْنُ لَہِیْعَۃَ قَالَا سَمِعْنَا یَزِیدَ بْنَ أَبِیْ حَبِیْبٍ یَقُولُ حَدَّثَنِی أَبُوْ عِمْرَانَ أَنَّہٗ سَمِعَ عُقْبَۃَ بْنَ عَامِرٍ یَقُولُ تَعَلَّقْتُ بِقَدَمِ رَسُولِ اللّٰہِ ﷺ فَقُلْتُ یَا رَسُولَ اللّٰہِ أَقْرِئْنِی سُورَۃَ ہُودٍ وَسُورَۃَ یُوسُفَ فَقَالَ لِی رَسُولُ اللّٰہِ ﷺ یَا عُقْبَۃُ إِنَّکَ لَنْ تَقْرَأَ مِنَ الْقُرْآنِ سُورَۃً أَحَبَّ إِلٰی اللّٰہِ وَلَا أَبْلَغَ عِنْدَہُ مِنْ قُلْ أَعُوذُ بِرَبِّ الْفَلَقِ قَالَ یَزِیدُ فَلَمْ یَکُنْ أَبُوْ عِمْرَانَ یَدَعُہَا کَانَ لَا یَزَالُ یَقْرَؤُہَا فِیْ صَلَاۃِ الْمَغْرِبِ ۔1,,takhreej: ! صحیح: أخرجہ احمد4/155والطبرانی فی الکبیر17/313ومسلم،کتاب صلاۃ المسافرین،باب فضل قراء ۃ المعوذتین (814),3482
3483,3483۔ حَدَّثَنَا أَحْمَدُ بْنُ عَبْدِ اللّٰہِ حَدَّثَنَا لَیْثٌ عَنِ ابْنِ عَجْلَانَ عَنْ سَعِیْدِ بْنِ أَبِیْ سَعِیدٍ الْمَقْبُرِیِّ أَنَّ عُقْبَۃَ بْنَ عَامِرٍ قَالَ مَشَیْتُ مَعَ النَّبِیِّ ﷺ فَقَالَ لِی قُلْ یَا عُقْبَۃُ فَقُلْتُ أَیَّ شَیْئٍ أَقُوْلُ قَالَ فَسَکَتَ عَنِّیْ ثُمَّ قَالَ یَا عُقْبَۃُ قُلْ فَقُلْتُ أَیَّ شَیْئٍ أَقُولُ قَالَ قُلْ أَعُوذُ بِرَبِّ الْفَلَقِ فَقَرَأْتُہَا حَتّٰی جِئْتُ عَلَی آخِرِہَا فَقَالَ رَسُولُ اللّٰہِ ﷺ عِنْدَ ذٰلِکَ مَا سَأَلَ سَائِلٌ وَلَا اسْتَعَاذَ مُسْتَعِیذٌ بِمِثْلِہَا۔2,,takhreej: @ صحیح: أخرجہ النسائی،کتاب الاسعادہ8/254والبیہقی فی الشعب(2564),3483
3484,3484۔ حَدَّثَنَا یَعْلَی حَدَّثَنَا إِسْمٰعِیْلُ ہُوَ ابْنُ أَبِیْ خَالِدٍ عَنْ قَیْسٍ عَنْ عُقْبَۃَ بْنِ عَامِرٍ قَالَ قَالَ رَسُولُ اللّٰہِ ﷺ لَقَدْ أُنْزِلَ عَلَیَّ آیَاتٌ لَمْ أَرَ أَوْ لَمْ یُرَ مِثْلُہُنَّ یَعْنِی الْمُعَوِّذَتَیْنِ ۔3,,takhreej: #صحیح: أخرجہ مسلم،کتاب صلاۃالمسافرین،باب فضل قراء ۃ المعوذتین(814)(265)والنسائی فی الاستعاذۃ 8/254,3484
3485,3485۔ حَدَّثَنَا یَحْیَی بْنُ بِسْطَامَ عَنْ یَحْیَی بْنِ حَمْزَۃَ حَدَّثَنِی یَحْیَی بْنُ الْحَارِثِ عَنِ الْقَاسِمِ أَبِیْ عَبْدِ الرَّحْمَنِ عَنْ تَمِیمٍ الدَّارِیِّ ح وَحَدَّثَنِی عُثْمَانُ بْنُ مُسْلِمٍ عَنِ الْعَبَّاسِ بْنِ مَیْمُونٍ عَنْ تَمِیمٍ الدَّارِیِّ قَالَ مَنْ قَرَأَ عَشْرَ آیَاتٍ فِیْ لَیْلَۃٍ لَمْ یُکْتَبْ مِنَ الْغَافِلِینَ ۔1,,takhreej: !حسن: (3487) ملاحظہ فرمائیں۔,3485
3486,3486۔ حَدَّثَنَا یَحْیَی بْنُ بِسْطَامَ عَنْ یَحْیَی بْنِ حَمْزَۃَ حَدَّثَنِی یَحْیَی بْنُ الْحَارِثِ عَنِ الْقَاسِمِ أَبِیْ عَبْدِ الرَّحْمَنِ عَنْ تَمِیمٍ الدَّارِیِّ وَفَضَالَۃَ بْنِ عُبَیْدٍ قَالَا مَنْ قَرَأَ بِعَشْرِ آیَاتٍ فِیْ لَیْلَۃٍ کُتِبَ مِنَ الْمُصَلِّیْنَ ۔2,,takhreej: @مرسل: ضعیف القاسم نے تمیم کو نہیں پایا، أخرجہ ابن منصور1/116(23)والبیہقی فی الشعب(2196),3486
3487,3487۔ حَدَّثَنَا إِسْمَعِیلُ بْنُ أَبَانَ حَدَّثَنَا أَبُوْ أُوَیْسٍ عَنْ مُوْسَی بْنِ عُقْبَۃَ عَنْ مُحَمَّدِ بْنِ کَعْبٍ الْقُرَظِیِّ عَنِ ابْنِ عُمَرَ قَالَ مَنْ قَرَأَ فِیْ لَیْلَۃٍ بِعَشْرِ آیَاتٍ لَمْ یُکْتَبْ مِنَ الْغَافِلِینَ ۔1,,takhreej: !حسن: أخرجہ الحاکم(2042)وابن ابی شیبہ 10/508 (10137)وابن خزیمہ(1143),3487
3488,3488۔ حَدَّثَنَا مَالِکُ بْنُ إِسْمَعِیلَ حَدَّثَنَا إِسْرَائِیلُ عَنْ أَبِیْ إِسْحٰقَ عَنِ الْمُغِیرَۃِ بْنِ عَبْدِ اللّٰہِ الْجَدَلِیِّ عَنِ ابْنِ عُمَرَ قَالَ مَنْ قَرَأَ فِیْ لَیْلَۃٍ بِعَشْرِ آیَاتٍ لَمْ یُکْتَبْ مِنَ الْغَافِلِینَ ۔2,,takhreej: @حسن: أخرجہ الضریس فی فضائل القرآن (63)وابن منصور 1/29(104),3488
3489,3489۔ حَدَّثَنَا أَبُوْ نُعَیْمٍ حَدَّثَنَا فِطْرٌ عَنْ أَبِیْ إِسْحٰقَ عَنْ أَبِیْ الْأَحْوَصِ عَنْ عَبْدِ اللّٰہِ قَالَ مَنْ قَرَأَ فِیْ لَیْلَۃٍ بِخَمْسِیْنَ آیَۃً لَمْ یُکْتَبْ مِنَ الْغَافِلِینَ ۔3,,takhreej: #صحیح: أخرجہ ابن ابی شیبہ10/508(10135)والطبرانی فی الکبیر9/158(8727),3489
