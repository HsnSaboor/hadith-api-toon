{"metadata":{"name":"Sunan an Nasai","section":{"1":"The Book of Purification"},"section_detail":{"1":{"hadithnumber_first":1,"hadithnumber_last":324,"arabicnumber_first":1,"arabicnumber_last":324}}},"hadiths":[{"hadithnumber":119,"arabicnumber":119,"text":"Rapporté par Ja'far bin 'Amr bin Umayyah Ad-Damri, dont le père a vu le Messager d'Allah (ﷺ) faire les ablutions et passer ses mains mouillées sur ses Khuffs","grades":[{"name":"Abu Ghuddah","grade":"Sahih"},{"name":"Al-Albani","grade":"Sahih"},{"name":"Zubair Ali Zai","grade":"Sahih Bukhari"}],"reference":{"book":1,"hadith":119}}]}