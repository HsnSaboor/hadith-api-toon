{"hadithnumber": "7523", "text": "معمر نے ہمام بن منبہ سے حدیث بیان کی ، کہا : یہ احادیث ہیں جو حضرت ابو ہریرۃ رضی اللہ تعالیٰ عنہ   ن"}
{"hadithnumber": "7524", "text": "ابن شہاب سے  روایت ہے  ، کہا : مجھے حضرت انس بن مالک رضی اللہ تعالیٰ عنہ   نے خبر دی کہ اللہ عزوجل ن"}
{"hadithnumber": "7525", "text": "سفیان نے قیس بن مسلم سے اور انھوں نے طارق بن شہاب سے روایت کی کہ یہودیوں نے حضرت عمر رضی اللہ تعالیٰ"}
{"hadithnumber": "7526", "text": "عبداللہ بن ادریس نے اپنے والد سے ، انھوں نے قیس بن مسلم سے اور انھوں نے طارق بن شہاب سے روایت کی ، ک"}
{"hadithnumber": "7527", "text": "ابو عمیس نے قیس بن مسلم سے اور انھوں نے طارق بن شہاب سے روایت کی  ، کہا : یہودیوں میں سے ایک شخص حضر"}
{"hadithnumber": "7528", "text": "یونس نے ابن شہاب سے روایت کی ، انھوں نے کہا : مجھے عروہ بن زبیر نے خبر دی کہ انھوں نے حضرت عائشہ رضی"}
{"hadithnumber": "7529", "text": "صالح نے ابن شہاب سے روایت کی ، کہا : مجھے عروہ نے بتایاکہ انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عنہا"}
{"hadithnumber": "7530", "text": "ابو اسامہ نے کہا : ہمیں ہشام نے اپنے والد  ( عروہ  ) سے حدیث بیان کی ،  انھوں نے حضرت عائشہ رضی اللہ"}
{"hadithnumber": "7531", "text": "عبدہ بن سلیمان نے ہشام سے انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عنہا    سے اللہ عزوجل کے فرمان :  \" جو"}
{"hadithnumber": "7532", "text": "ابو اسامہ نے کہا : ہمیں ہشام نے اپنے والد سے خبر دی انھوں نے اس عزوجل کے فرمان :  \" اور یہ لوگ آپ سے"}
{"hadithnumber": "7533", "text": "عبد ہ بن سلیمان نے ہشام  ( بن عروہ ) سے انھوں نے اپنے والد سے اور انھوں نے حضرت عائشہ رضی اللہ تعالی"}
{"hadithnumber": "7534", "text": "ابو اسامہ نے کہا : ہمیں ہشام نے اپنے والد سے حدیث بیان کی ،  انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "7535", "text": "ابن نمیر نے کہا : ہمیں ہشام نے اسی سند کے ساتھ  ( یہی ) حدیث بیان کی ۔"}
{"hadithnumber": "7536", "text": "عروہ نے حضرت عائشہ رضی اللہ تعالیٰ عنہا    سے اس  ( اللہ )  عزوجل کے فرمان  :  \" جب کافرتم پر چڑھ آئ"}
{"hadithnumber": "7537", "text": "عبد ہ بن سلیمان نے کہا : ہمیں ہشام  ( ابن عروہ )  نے اپنے والدسے اور انھوں نے حضرت عائشہ رضی اللہ تع"}
{"hadithnumber": "7538", "text": "ابو اسامہ نے کہا : ہمیں ہشام بن عروہ نے اپنے والد سے بیان کیا انھوں نے حضرت عائشہ  رضی اللہ تعالیٰ ع"}
{"hadithnumber": "7539", "text": "ابو معاویہ نے ہشام بن عروہ سے اور انھوں نے اپنے والد سے روایت کی ،  انھوں نے کہا : مجھ سے حضرت عائشہ"}
{"hadithnumber": "7540", "text": "ابو اسامہ نے کہا :  ہمیں ہشام نے اسی سند کے ساتھ اسی کے مانند روایت کی ۔"}
{"hadithnumber": "7541", "text": "معاذ عنبری نے کہا : ہمیں شعبہ نے مغیرہ بن نعمان سے حدیث بیان کی انھوں نے حضرت سعید بن جبیر رضی اللہ"}
{"hadithnumber": "7542", "text": "محمد بن جعفر اور نضر بن شمیل دونوں نے کہا : ہمیں شعبہ نے اسی سند کے ساتھ حدیث بیان کی ۔ ابن جعفر کی"}
{"hadithnumber": "7543", "text": "منصور نے حضرت سعید بن جبیر رضی اللہ تعالیٰ عنہ   سے روایت کی کہا :  مجھ سے عبد الرحمٰن بن ایزدی نے ک"}
{"hadithnumber": "7544", "text": "ابو معاویہ شیبان نے منصور بن معتمر سے انھوں نے سعید بن جیبر سے اور انھوں نے حضرت ابن عباس رضی اللہ ت"}
{"hadithnumber": "7545", "text": "عبد اللہ بن ہاشم اور عبد الرحمٰن بن بشر عبدی نے مجھے حدیث بیان کی دونوں نے کہا :  ہمیں یحییٰ بن سعید"}
{"hadithnumber": "7546", "text": "ابو بکر بن ابی شیبہ ہارون بن عبد اللہ اور عبد بن حمید نے ہمیں ھدیث بیان کی ،  عبد نے کہا :   ہمیں خب"}
{"hadithnumber": "7547", "text": "ابو معاویہ نے کہا :  ہمیں ابو عمیس نے اسی سند کے ساتھ اسی کے مانند روایت کی اور کہا :   \" آخری سورت"}
{"hadithnumber": "7548", "text": "عطاء نے حضرت ابن عباس رضی اللہ تعالیٰ عنہ   سے روایت کی کہا :  مسلمانوں میں سے کچھ لوگ ایک شخص کو کو"}
{"hadithnumber": "7549", "text": "ابو اسحاق سے روایت ہے کہا :  میں نے حضرت براء بن عازب  رضی اللہ تعالیٰ عنہ   کو کہتے ہوئے سنا :  انص"}
{"hadithnumber": "7550", "text": "عون بن عبداللہ کے والد سے روایت ہے کہ حضرت ابن مسعود رضی اللہ تعالیٰ عنہ   نےکہا : ہمارے اسلام لانے"}
{"hadithnumber": "7551", "text": "حضرت ابن عباس رضی اللہ تعالیٰ عنہ   سے روایت ہے   ، کہا :  ( جاہلی دور میں )  ایک عورت برہنہ ہوکر بی"}
{"hadithnumber": "7552", "text": "ابو معاویہ نے کہا : ہمیں اعمش نے ابو سفیان سے حدیث بیان کی ، انھوں نے حضرت جابر رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "7553", "text": "ابو عوانہ نے اعمش سے  ، انھوں نے ابو سفیان سے اور انھوں نے حضرت جابر رضی اللہ تعالیٰ عنہ   سے روایت"}
{"hadithnumber": "7554", "text": "عبداللہ بن ادریس نے اعمش سے ، انھوں نے ابراہیم سے ، انھوں نے ابو معمر سے اور انھوں نے حضرت عبداللہ ب"}
{"hadithnumber": "7556", "text": "شعبہ نے سلیمان ( اعمش )  سے اسی سندکے ساتھ یہی  روایت کی ۔"}
{"hadithnumber": "7558", "text": "ابو بشر نے سعید بن  جبیر سے روایت کی ، کہا :  کہ میں نے سیدنا ابن عباس رضی اللہ عنہما سے کہا کہ سورۃ"}
{"hadithnumber": "7559", "text": "علی بن مسہر نے ابو حیان سے ، انھوں نے شعبی سے اور انھوں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ   سے روا"}
{"hadithnumber": "7560", "text": "ابن ادریس نے کہا : ہمیں ابو حیان نے شعبی سے حدیث بیان کی ۔ انھوں نے حضرت عبداللہ بن عمر رضی اللہ تعا"}
{"hadithnumber": "7561", "text": "اسماعیل بن علیہ اور عیسیٰ بن یونس دونوں نے ابوحیان سے اسی سند کے ساتھ ان دونوں کی حدیث کے مانند روای"}
{"hadithnumber": "7562", "text": "ہشیم نے ابو ہاشم سے ، انھوں نے ابو مجلز سے اور انھوں نے قیس بن عباد سے روایت کی ، کہا : میں نے حضرت"}
{"hadithnumber": "7563", "text": "سفیان نے ابو ہاشم سے  ، انھوں نے ابو مجلز سے ، انھوں نے قیس بن عباد سے روایت کی  ، کہا : میں نے حضرت"}
