hadiths[1076]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}:
28655,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ لأُِسَامَۃَ : یَا أُسَامَۃُ، لاَ تَشْفَعْ فِی حَدٍّ ، وَکَانَ إِذَا شَفَعَ شَفَّعَہُ۔ (ابن سعد 69)",,,28655
28656,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَن وَاصِلٍ ، عَنْ أَبِی وَائِلٍ ، عَن کَعْبٍ ، قَالَ : لاَ یُشَفَّعْ فِی حَدٍّ۔",,,28656
28657,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ عَبْدِ اللہِ بْنِ عُرْوَۃَ ، عَنِ الْفُرَافِصَۃِ الْحَنَفِیِّ ، قَالَ : مَرُّوا عَلَی الزُّبَیْرِ بِسَارِقٍ فَتَشَفَّعَ لَہُ ، فَقَالُوا : أَتَشْفَعُ لِسَارِقٍ ؟ فَقَالَ : نَعَمْ ، مَا لَمْ یُؤْتَ بِہِ إِلَی الإِمَامِ ، فَإِذَا أُتِیَ بِہِ إِلَی الإِمَامِ ، فَلاَ عَفَا اللَّہُ عَنْہُ إِنْ عَفَا عَنْہُ۔",,,28657
28658,حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ ہِشَامٍ ، عَنْ عَبْدِ اللہِ بْنِ عُرْوَۃَ ، عَنِ الْفُرَافِصَۃِ ، عَنِ الزُّبَیْرِ ، مِثْلَہُ۔,,,28658
28659,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ الرُّؤَاسِیُّ ، عَنْ ہِشَامٍ ، عَنْ أَبِی حَازِمٍ ؛ أَنَّ عَلِیًّا شَفَعَ لِسَارِقٍ ، فَقِیلَ لَہُ، تَشْفَعُ لِسَارِقٍ ؟ فَقَالَ : نَعَمْ ، إِنَّ ذَلِکَ یُفْعَلُ مَا لَمْ یُبَلَّغْ بِہِ الإِمَامُ ، فَإِذَا بُلِّغَ بِہِ الإِمَامُ فَلاَ أَعْفَاہُ اللَّہُ إِنْ أَعْفَاہُ۔",,,28659
28660,"حَدَّثَنَا وَکِیعٌ ، عَنْ سَعِیدِ بْنِ عُبَیْدٍ ، عَن سُلَیْمَانَ بْنِ أَبِی کَبْشَۃَ ؛ أَنَّ سَارِقًا مَرَّ بِہِ عَلَی سَعِیدِ بْنِ جُبَیْرٍ ، وَعَطَائٍ فَشَفَعَا لَہُ ، فَقِیلَ لَہُمَا : وَتَرَیَانِ ذَلِکَ ؟ فَقَالاَ : نَعَمْ ، مَا لَمْ یُؤْتَ بِہِ إِلَی الإِمَامِ۔",,,28660
28661,"حَدَّثَنَا عَبْدَۃُ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عَبْدِ الْوَہَّابِ ، عَنِ ابْنِ عُمَرَ ، قَالَ : مَنْ حَالَتْ شَفَاعَتُہُ دُونَ حَدٍّ مِنْ حُدُودِ اللہِ ، فَقَدْ ضَادَّ اللَّہَ فِی خَلْقِہِ۔ (ابوداؤد 3592۔ احمد 70)",,,28661
28662,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عُرْوَۃَ ، عَنْ عَائِشَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کُلِّمَ فِی شَیْئٍ ، فَقَالَ : لَوْ کَانَتْ فَاطِمَۃُ ابْنَۃُ مُحَمَّدٍ لأَقَمْتُ عَلَیْہَا الْحَدَّ۔ (بخاری 3475۔ مسلم 1315)",,,28662
28663,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ إِسْحَاقَ ، عَنْ مُحَمَّدِ بْنِ طَلْحَۃَ بْنِ رُکَانَۃَ ، عَنْ أُمِّہِ عَائِشَۃَ بِنْتِ مَسْعُودِ بْنِ الأَسْوَدِ ، عَنْ أَبِیہَا مَسْعُودٍ ، قَالَ : لَمَّا سَرَقَتِ الْمَرْأَۃُ تِلْکَ الْقَطِیفَۃَ مِنْ بَیْتِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَعْظَمْنَا ذَلِکَ ، وَکَانَتِ الْمَرْأَۃُ مِنْ قُرَیْشٍ ، فَجِئْنَا إِلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نُکَلِّمُہُ وَقُلْنَا : نَحْنُ نَفْدِیہَا بِأَرْبَعِینَ أُوقِیَّۃً ، قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : تَطَّہَّرُ خَیْرٌ لَہَا ، فَلَمَّا سَمِعْنَا لِینَ قَوْلِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أَتَیْنَا أُسَامَۃَ ، فَقُلْنَا : کَلِّمْ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَلَمَّا رَأَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ذَلِکَ ، قَامَ خَطِیبًا ، فَقَالَ : مَا إِکْثَارُکُمْ عَلَیَّ فِی حَدٍّ مِنْ حُدُودِ اللہِ ، وَقَعَ عَلَی أَمَۃٍ مِنْ إِمَائِ اللہِ ؟ وَالَّذِی نَفْسِی بِیَدِہِ ، لَوْ کَانَتْ فَاطِمَۃُ بِنْتُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَزَلَتْ بِالَّذِی نَزَلَتْ بِہِ ، لَقَطَعَ مُحَمَّدٌ یَدَہَا۔ (احمد 409۔ طبرانی 792)",,,28663
28664,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ حَرْبِ بْنِ شَدَّادٍ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ ثَوْبَانَ ، عَنْ زُییْدِ بْنِ الصَّلْتِ ، قَالَ : سَمِعْتُ أَبَا بَکْرٍ الصِّدِّیقَ ، یَقُولُ : لَوْ أَخَذْتُ شَارِبًا لأَحْبَبْتُ أَنْ یَسْتُرَہُ اللَّہُ ، وَلَوْ أَخَذْتُ سَارِقًا لأَحْبَبْتُ أَنْ یَسْتُرَہُ اللَّہُ۔",,,28664
28665,"حَدَّثَنَا شَرِیکٌ ، عَنْ سَعِیدِ بْنِ مَسْرُوقٍ ، عَن عِکْرِمَۃَ ، قَالَ : سُرِقَتْ عَیْبَۃٌ لِعَمَّارٍ بِالْمُزْدَلِفَۃِ ، فَوَضَعَ فِی أَثَرِہَا جَفْنًۃً، وَدَعَا الْقَافَۃَ ، فَقَالُوا: حَبَشِیٌّ، فَاتَّبَعُوا أَثَرَہُ حَتَّی انْتَہَوْا إِلَی حَائِطٍ وَہُوَ یُقَلِّبُہَا ، فَأَخَذَہَا وَتَرَکَہُ، فَقِیلَ لَہُ ؟ فَقَالَ : أَسْتُرُ عَلَیْہِ لَعَلَّ اللَّہَ أَنْ یَسْتُرَ عَلَیَّ۔",,,28665
28666,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَن عِکْرِمَۃَ ؛ أَنَّ ابْنَ عَبَّاسٍ ، وَعَمَّارًا ، وَالزُّبَیْرَ أَخَذُوا سَارِقًا فَخَلَّوْا سَبِیلَہُ ، فَقُلْتُ لابْنِ عَبَّاسٍ : بِئْسَ مَا صَنَعْتُمْ حِینَ خَلَّیْتُمْ سَبِیلَہُ ، فَقَالَ : لاَ أُمَّ لَکَ ، أَمَّا لَوْ کُنْتَ أَنْتَ لَسَرَّک أَنْ یُخَلَّی سَبِیلُک۔",,,28666
28667,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَن عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَن نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قطَعَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی مِجَنٍّ قِیمَتُہُ ثَلاَثَۃُ دَرَاہِمَ۔ (بخاری 6797۔ مسلم 1314)",,,28667
28668,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا سُلَیْمَانُ بْنُ کَثِیرٍ ، وَإِبْرَاہِیمُ بْنُ سَعْدٍ ، قَالاَ جَمِیعًا : أَخْبَرَنَا الزُّہْرِیُّ ، عَنْ عَمْرَۃَ ، عَنْ عَائِشَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : الْقَطْعُ فِی رُبْعِ دِینَارٍ فَصَاعِدًا۔ (بخاری 2790۔ مسلم 1312)",,,28668
28669,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَن عِیسَی بْنِ أَبِی عَزَّۃَ ، عَنِ الشَّعْبِیِّ ، عَنْ عَبْدِ اللہِ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَطَعَ فِی خَمْسَۃِ دَرَاہِمَ۔ (ابوداؤد 243۔ ابویعلی 5333),,,28669
28670,"حَدَّثَنَا أَحْمَدُ بْنُ إِسْحَاقَ ، عَن وُہَیْبٍ ، قَالَ : حدَّثَنَا أَبُو وَاقِدٍ ، عَنْ عَامِرِ بْنِ سَعْدٍ ، عَنْ أَبِیہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : یُقْطَعُ السَّارِقُ فِی ثَمَنِ الْمِجَنِّ۔ (ابن ماجہ 2586۔ احمد 169)",,,28670
28671,حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ عَلِیٍّ ؛ أَنَّہُ قَطَعَ یَدَ سَارِقٍ فِی بَیْضَۃٍ حَدِیدٍ ، ثَمَنُہَا رُبْعُ دِینَارٍ۔,,,28671
28672,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، قَالَ : سَمِعْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، یَقُولُ : الْقَطْعُ فِی ثَمَنِ الْمِجَنِّ۔ (احمد 180۔ بیہقی 259)",,,28672
28673,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عَمْرَۃَ ، عَنْ عَائِشَۃَ أُمِّ الْمُؤْمِنِینَ ، قَالَتْ : الْقَطْعُ فِی رُبْعِ دِینَارٍ فَصَاعِدًا۔ (مالک 832۔ ابن حبان 4462)",,,28673
28674,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَن حُمَیْدٍ ، قَالَ : سُئِلَ أَنَسٌ : فِی کَمْ یُقْطَعُ یَدُ السَّارِقِ ؟ فَقَالَ : قَدْ قَطَعَ أَبُو بَکْرٍ فِیمَا لاَ یَسُرُّنِی أَنَّہُ لِی بِخَمْسَۃِ دَرَاہِمَ ، أَوْ ثَلاَثَۃِ دَرَاہِمَ۔",,,28674
28675,حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسٍ ؛ أَنَّ رَجُلاً سَرَقَ مِجَنًّا عَلَی عَہْدِ أَبِی بَکْرٍ فَقُطِعَ۔,,,28675
28676,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَن خَالِدٍ ، عَن عِکْرِمَۃَ ، قَالَ : تُقْطَعُ الْیَدُ فِی ثَمَنِ الْمِجَنِّ ، قَالَ : قُلْتُ : ذَکَرَ لَکَ ثَمَنَہُ ؟ قَالَ : أَرْبَعَۃٌ ، أَوْ خَمْسَۃٌ۔",,,28676
28677,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَن دَاوُد بْنِ فَرَاہِیجَ ؛ أَنَّہُ سَمِعَ أَبَا ہُرَیْرَۃَ ، وَأَبَا سَعِیدٍ الْخُدْرِیَّ ، یَقُولاَنِ : لاَ تُقْطَعُ الْیَدُ إِلاَّ فِی أَرْبَعَۃِ دَرَاہِمَ فَصَاعِدًا۔",,,28677
28678,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی بَکْرٍ ، عَنْ عَمْرَۃَ ، قَالَتْ: قَدْ عَلِمْت أَنَّ عُثْمَانَ قَطَعَ فِی أُتْرُجَّۃٍ، قُوِّمَتْ ثَلاَثَۃَ دَرَاہِمَ۔ (مالک 832)",,,28678
28679,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی بَکْرٍ ، عَنْ عَمْرَۃَ ، عَنْ عَائِشَۃَ ، قَالَتْ : تُقْطَعُ فِی رُبْعِ دِینَارٍ ، وَقَالَتْ عَمْرَۃُ : قَطَعَ عُمَرُ فِی أُتْرُجَّۃٍ۔",,,28679
28680,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَن بُرْدٍ ، عَنْ مَکْحُولٍ ، قَالَ : یُقْطَعُ السَّارِقُ فِی ثَمَنِ الْمِجَنِّ۔",,,28680
28681,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ (ح) وَإِسْمَاعِیلُ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ عُمَرَ ، قَالَ : لاَ تُقْطَعُ الْخَمْسُ إِلاَّ فِی خَمْسٍ۔",,,28681
28682,"حَدَّثَنَا أَبُو دَاوُدَ، عَنْ ہِشَامٍ، عَنْ قَتَادَۃَ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ ، قَالَ: لاَ تُقْطَعُ الْخَمْسُ إِلاَّ فِی خَمْسٍ۔",,,28682
28683,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ، عَنْ سُفْیانَ، عن عَبْدِالرَّحْمَنِ بْنِ الْقَاسِمِ، عَنْ أَبِیہِ؛ أَنَّ ابْنَ الزُّبَیْرِ قَطَعَ فِی نَعْلَیْنِ۔,,,28683
28684,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَن عُبَیْدِ اللہِ ، عَن نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : کَانُوا یَتَسَارَقُونَ السِّیَاطَ فِی طَرِیقِ مَکَّۃَ ، فَقَالَ عُثْمَانُ : لَئِنْ عُدْتُمْ لأَقْطَعَن فِیہِ۔",,,28684
28685,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَعَنَ اللَّہُ السَّارِقَ ، یَسْرِقُ الْبَیْضَۃَ فَتُقْطَعُ یَدُہُ ، وَیَسْرِقُ الْحَبْلَ فَتُقْطَعُ یَدُہُ۔\n\n(مسلم 1314۔ ابن ماجہ 2583)",,,28685
28686,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ أَبِی بَکْرِ بْنِ مُحَمَّدٍ ، قَالَ : أُتِیَ عُثْمَانُ بِرَجُلٍ سَرَقَ أُتْرُجَّۃً ، فَقَوَّمَہَا رُبْعَ دِینَارٍ ، فَقَطَعَ یَدَہُ۔",,,28686
28687,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، قَالَ : حدَّثَنَی أَیُّوبُ بْنُ مُوسَی ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ : لاَ یُقْطَعُ السَّارِقُ فِی دُونِ ثَمَنِ الْمِجَنِّ ، وَثَمَنُ الْمِجَنِّ عَشَرَۃُ دَرَاہِمَ۔",,,28687
28688,"حَدَّثَنَا عَبْدُ الأَعْلَی ، وَعَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، قَالَ : کَانَ یَقُولُ : ثَمَنُ الْمِجَنِّ عَشَرَۃُ دَرَاہِمَ۔",,,28688
28689,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، وَوَکِیعٌ ، عَنِ الْمَسْعُودِیِّ ، عَنِ الْقَاسِمِ ، عَنِ ابْنِ مَسْعُودٍ ، أَنَّہُ قَالَ : لاَ یُقْطَعُ إِلاَّ فِی دِینَارٍ ، أَوْ عَشَرَۃِ دَرَاہِمَ۔",,,28689
28690,"حَدَّثَنَا وَکِیعٌ ، عَن حَمْزَۃَ الزَّیَّاتِ ، عَنِ الْحَکَمِ ، عَنْ أَبِی جَعْفَرٍ قَالَ : قیمَۃُ الْمِجَنِّ دِینَارٌ ، الَّذِی تُقْطَعُ فِیہِ الْیَدُ۔",,,28690
28691,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ عَبْدِ الْمَلِکِ بْنِ أَبِی سُلَیْمَانَ ، عَنْ عَطَائٍ ، قَالَ : أَدْنَی مَا یُقْطَعُ فِیہِ السَّارِقُ ثَمَنُ الْمِجَنِّ ، وَکَانَ یُقَوَّمُ الْمِجَنُّ فِی زَمَانِہِمْ دِینَارًا ، أَوْ عَشَرَۃَ دَرَاہِمَ۔",,,28691
28692,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَن حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : قَالَ عَبْدُ اللہِ : لاَ تُقْطَعُ الْیَدُ إِلاَّ فِی تُرْسٍ ، أَوْ حَجَفَۃٍ ، قَالَ : قُلْتُ لإِبْرَاہِیمَ : کَمْ قِیمَتُہُ ؟ قَالَ : دِینَارٌ۔",,,28692
28693,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، قَالَ : کَانَ السَّارِقُ عَلَی عَہْدِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُقْطَعُ فِی ثَمَنِ الْمِجَنِّ ، وَکَانَ الْمِجَنُّ یَوْمَئِذٍ لَہُ ثَمَنٌ ، وَلَمْ یَکُنْ یُقْطَعُ فِی الشَّیْئِ التَّافِہِ۔\n\n(عبدالرزاق 18959)",,,28693
28694,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ ، قَالَ : یُقْطَعُ فِی ثَمَنِ الْمِجَنِّ۔",,,28694
28695,"حَدَّثَنَا شَرِیکٌ ، عَنْ عَطِیَّۃَ بْنِ عَبْدِ الرَّحْمَن ، عَنِ الْقَاسِمِ ، قَالَ : أُتِیَ عُمَرُ بِسَارِقٍ فَأَمَرَ بِقَطْعِہِ ، فَقَالَ عُثْمَانُ : إِنَّ سَرِقَتَہُ لاَ تَسْوَی عَشَرَۃَ دَرَاہِمَ ، قَالَ : فَأَمَرَ بِہَا عُمَرُ فَقُوِّمَتْ ثَمَانیَۃَ دَرَاہِمَ ، فَلَمْ یَقْطَعْہُ۔",,,28695
28696,"حَدَّثَنَا الثَّقَفِیُّ ، عَنِ الْمُثَنَّی ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، قَالَ : دَخَلْتُ عَلَی سَعِیدِ بْنِ الْمُسَیَّبِ ، فَقُلْت لَہُ : إِنَّ أَصْحَابَک ؛ عُرْوَۃَ بْنَ الزُّبَیْرِ ، وَمُحَمَّدَ بْنَ مُسْلِمٍ الزُّہْرِیَّ ، وَابْنَ یَسَارٍ یَقُولُونَ : ثَمَنُ الْمِجَنِّ خَمْسَۃُ دَرَاہِمَ ، فَقَالَ : أَمَّا ہَذَا فَقَدْ مَضَتْ فِیہِ سُنَّۃٌ مِنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ عَشَرَۃُ دَرَاہِمَ۔\n\n(عبدالرزاق 18951)",,,28696
28697,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، قَالَتْ : لَمْ یَکُنْ یُقْطَعُ عَلَی عَہْدِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی الشَّیْئِ التَّافِہِ۔ (بخاری 6792۔ مسلم 1313)",,,28697
28698,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَن سُلَیْمَانَ بْنِ مُوسَی ، عَنْ عُثْمَانَ ، قَالَ : لَیْسَ عَلَیْہِ قَطْعٌ حَتَّی یَخْرُجَ بِالْمَتَاعِ مِنَ الْبَیْتِ۔",,,28698
28699,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : لَیْسَ عَلَیْہِ قَطْعٌ حَتَّی یَخْرُجَ بِالْمَتَاعِ مِنَ الْبَیْتِ۔",,,28699
28700,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَن مُوسَی بْنِ أَبِی الْفُرَاتِ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : لاَ یُقْطَعُ حَتَّی یَخْرُجَ بِالْمَتَاعِ مِنَ الْبَیْتِ۔",,,28700
28701,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ حُصَیْنٍ الْحَارِثِیِّ ، عَنِ الشَّعْبِیِّ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : أُتِیَ بِرَجُلٍ قَدْ نَقَبَ ، فَأُخِذَ عَلَی تِلْکَ الْحَالِ ، فَلَمْ یَقْطَعْہُ۔",,,28701
28702,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنِ الشَّعْبِیِّ ، أَنَّہُ سُئِلَ عَنْ رَجُلٍ سَرَقَ سَرِقَۃً ، ثُمَّ کَوَّرَہَا ، فَأُدْرِکَ قَبْلَ أَنْ یَخْرُجَ مِنَ الْبَیْتِ ؟ قَالَ : لَیْسَ عَلَیْہِ قَطْعٌ۔",,,28702
28703,"حَدَّثَنَا ابْنُ مُسْہِرٍ ، عَن زَکَرِیَّا ، عَنِ الشَّعْبِیِّ ، قَالَ : لَیْسَ عَلَیْہِ قَطْعٌ حَتَّی یُخْرِجَ الْمَتَاعَ مِنَ الْبَیْتِ۔",,,28703
28704,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : یُؤْخَذُ السَّارِقُ قَدْ أَخَذَ الْمَتَاعَ ، وَقَدْ جَمَعَہُ فِی الْبَیْتِ ؟ قَالَ : لاَ قَطْعَ عَلَیْہِ حَتَّی یَخْرُجَ بِہِ ، زَعَمُوا ، قَالَ : وَقَالَ عَمْرُو بْنُ دِینَارٍ : مَا أَرَی عَلَیْہِ قَطْعًا۔",,,28704
28705,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَن دَاوُد ، عَنْ أَبِی حَرْبِ بْنِ أَبِی الأَسْوَدِ ؛ أَنَّ لِصًّا نَقَبَ بَیْتَ قَوْمٍ ، فَأَدْرَکَہُ الْحُرَّاسُ فَأَخَذُوہُ ، فَرُفِعَ إِلَی أَبِی الأَسْوَدِ ، فَقَالَ : وَجَدْتُمْ مَعَہُ شَیْئًا ، فَقَالُوا : لاَ ، فَقَالَ : الْبَائِسُ أَرَادَ أَنْ یَسْرِقَ فَأَعْجَلْتُمُوہُ ، فَجَلَدَہُ خَمْسَۃً وَعِشْرِینَ سَوْطًا۔",,,28705
28706,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَن حُمَیْدٍ ؛ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ کَتَبَ فِی سَارِقٍ : لاَ یُقْطَعُ حَتَّی یَخْرُجَ بِالْمَتَاعِ مِنَ الدَّارِ ، لَعَلَّہُ تَعْرِضُ لَہُ تَوْبَۃٌ قَبْلَ أَنْ یَخْرُجَ مِنَ الدَّارِ۔",,,28706
28707,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، قَالَ : بَلَغَ عَائِشَۃَ أَنَّہُمْ یَقُولُونَ : إِذَا لَمْ یَخْرُجْ بِالْمَتَاعِ لَمْ یُقْطَعْ ، فَقَالَتْ : لَوْ لَمْ أَجِدْ إِلاَّ سِکِّینًا لَقَطَعْتُہُ۔",,,28707
28708,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا زَنَی ، وَسَرَقَ ، وَقَتَلَ ، وَعَمِلَ حُدُودًا ، قَالَ : یُقْتَلُ ، وَلاَ یُزَادُ عَلَی ذَلِکَ۔",,,28708
28709,"حَدَّثَنَا حَفْصٌ، عَن مُجَالِدٍ، عَنِ الشَّعْبِیِّ، عَن مَسْرُوقٍ، قَالَ: قَالَ عَبْدُ اللہِ: إِذَا اجْتَمَعَ حَدَّانِ أَحَدُہُمَا الْقَتْلُ ، أَتَی الْقَتْلُ عَلَی الآخَرِ۔",,,28709
28710,"حَدَّثَنَا حَفْصٌ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ، قَالَ : إِذَا اجْتَمَعَتْ حُدُودٌ ، أُقِیمَتْ کُلُّہَا عَلَیْہِ۔",,,28710
28711,"حَدَّثَنَا عَبْدُ الْعَزِیزِ بْنُ مُحَمَّدٍ الدَّرَاوَرْدِیُّ ، عَن حُسَیْنِ بْنِ حَازِمٍ ، قَالَ : رَأَیْتُ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ ضَرَبَ عَنقَ سَارِقٍ ، بَعْدَ أَنْ قُطِعَتْ أَرْبَعُہُ۔",,,28711
28712,حَدَّثَنَا ابْنُ الدَّرَاوَرْدِیِّ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ رَجُلٍ مِنْ أَہْلِ الشِّفَائِ ؛ أَنَّ عُثْمَانَ بْنَ عَفَّانَ ضَرَبَ عَنقَ قیناس بَعْدَ أَنْ قُطِعَتْ أَرْبَعُہُ۔,,,28712
28713,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ؛ قَالَ : کَانَ عَطَائٌ یَقُولُ : إِنْ سَرَقَ وَشَرِبَ الْخَمْرَ ، ثُمَّ قَتَلَ ، فَہُوَ الْقَتْلُ ، لاَ یُقْطَعُ ، وَلاَ یُحَدُّ۔",,,28713
28714,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ، عَنِ ابْنِ جُرَیْجٍ، قَالَ: سَمِعْتُ ابْنَ أَبِی مُلَیْکَۃَ، یَقُولُ: تُقَامُ عَلَیْہِ الْحُدُودُ، ثُمَّ یُقْتَلُ۔",,,28714
28715,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا سَعِیدُ بْنُ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، قَالَ : تُقَامُ عَلَیْہِ الْحُدُودُ ، ثُمَّ یُقْتَلُ۔",,,28715
28716,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا سَعِیدٌ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا کَانَتْ حُدُودٌ فِیہَا قَتْلٌ ، فَإِنَّ الْقَتْلَ یَأْتِی عَلَی ذَلِکَ أَجْمَعَ۔",,,28716
28717,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ؛ فِی الرَّجُلِ یَسْرِقُ فَتُقْطَعُ یَدُہُ ، قَالَ : لَیْسَ عَلَیْہِ شَیْئٌ إِلاَّ أَنْ یُوجَدَ مَعَہُ شَیْئٌ ، وَقَالَ حَمَّادٌ : یُتْبَعُ بِہَا۔",,,28717
28718,"حَدَّثَنَا حَفْصٌ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ (ح) وَأَشْعَثَ ، عَنِ ابْنِ سِیرِینَ ، قَالاَ : لَیْسَ عَلَیْہِ شَیْئٌ إِذَا قُطِعَتْ یَدُہُ ، إِلاَّ أَنْ یُوجَدَ شَیْئٌ بِعَیْنِہِ۔",,,28718
28719,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ؛ أَنَّہُ قَالَ فِی السَّارِقِ : إِنْ وُجِدَتِ السَّرِقَۃُ عَندَہُ بِعَیْنِہَا أُخِذَتْ مِنْہُ ، وَقُطِعَتْ یَدُہُ ، وَإِنْ کَانَ قَدَ اسْتَہْلَکَہَا ، قُطِعَتْ یَدُہُ وَلاَ ضَمَانَ عَلَیْہِ۔",,,28719
28720,حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ (ح) وَأَشْعَثَ ، عَنِ ابْنِ سِیرِینَ ؛ مِثْلَہُ۔,,,28720
28721,"حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ یَغْرَمُ السَّارِقُ بَعْدَ قَطْعِ یَمِینِہِ ، إِلاَّ أَنْ تُوجَدَ السَّرِقَۃُ بِعَیْنِہَا ، فَتُؤْخَذَ مِنْہُ۔",,,28721
28722,حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یُضَمِّنُ السَّارِقَ بَعْدَ مَا یُقْطَعُ۔,,,28722
28723,"حَدَّثَنَا أَبُو خَالِدٍ ، وَلَیْسَ بِالأَحْمَرِ ، عَن قُرَیْشِ بْنِ حَیَّانَ الْعِجْلِیّ ، عَن مَطَرٍ الْوَرَّاقِ ،قَالَ : سُئِلَ سَعِیدُ بْنُ جُبَیْرٍ عَنِ الرَّجُلِ یَسْرِقُ السَّرِقَۃَ فَتُقْطَعُ یَدُہُ ، أَیَغْرَمُ السَّرِقَۃَ ؟ قَالَ : کَفَی بِالْقَطْعِ غُرْمًا۔",,,28723
28724,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : دَخَلْتُ عَلَی عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، فَسَأَلَنِی عَنِ الْعَبْدِ الآبِقِ السَّارِقِ یُقْطَعُ ؟ فَقُلْتُ : مَا بَلَغَنِی فِیہِ شَیْئٌ ، فَلَمَّا قَدِمْتُ الْمَدِینَۃَ لَقِیتُ سَالِمَ بْنَ عَبْدِ اللہِ ، فَأَخْبَرَنِی أَنَّ عَبْدَ اللہِ بْنَ عُمَرَ قَطَعَ عَبْدًا لَہُ ، سَارِقًا ، آبِقًا۔",,,28724
28725,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَن نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، فِی الْعَبْدِ الآبِقِ یَسْرِقُ ، قَالَ : یُقْطَعُ۔",,,28725
28726,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : یُقْطَعُ۔",,,28726
28727,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَن حَسَنِ بْنِ صَالِحٍ ، عَنْ إِبْرَاہِیمَ بْنِ عَامِرٍ ؛ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ سَأَلَ عُرْوَۃَ عَنْہُ ؟ فَقَالَ : یُقْطَعُ۔",,,28727
28728,"حَدَّثَنَا أَسْوَدُ بْنُ عَامِرٍ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ؛ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ ، وَالْقَاسِمَ، قَالاَ : الْعَبْدُ الآبِقُ إِذَا سَرَقَ قُطِعَ۔",,,28728
28729,"حَدَّثَنَا مَحْبُوبٌ الْقَوَارِیرِیُّ ، عَنْ سُفْیَانَ ، عَن خَالِدٍ الْحَذَّائِ ، عَنِ الْحَسَنِ ؛ سُئِلَ عَنِ الْعَبْدِ الآبِقِ یَسْرِقُ ، تُقْطَعُ یَدَہُ ؟ قَالَ : نَعَمْ۔",,,28729
28730,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سُفْیَانَ ، عَنْ عَمْرٍو ، عَن مُجَاہِدٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ یُقْطَعُ الْعَبْدُ الآبِقُ إِذَا سَرَقَ فِی إِبَاقِہِ۔",,,28730
28731,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : کَانَ عُثْمَانُ ، وَمَرْوَانُ یَقُولاَنِ : لاَ یُقْطَعُ۔",,,28731
28732,حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ؛ أَنَّ عُثْمَانَ ، وَعُمَرَ بْنَ عَبْدِ الْعَزِیزِ ، وَمَرْوَانَ کَانُوا لاَ یَقْطَعُونَ الْعَبْدَ الآبِقَ إِذَا سَرَقَ۔,,,28732
28733,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَن عُبَیْدِ اللہِ ، وَیَحْیَی ، عَن نَافِعٍ ، قَالَ : سَرَقَ عَبْدٌ لاِبْنِ عُمَرَ ، فَبَعَثَ بِہِ إِلَی سَعِیدِ بْنِ الْعَاصِ ، فَقَالَ : إِنَّ ہَذَا سَرَقَ فَاقْطَعْہُ ، قَالَ : لاَ یُقْطَعُ الْعَبْدُ الآبِقُ۔",,,28733
28734,"حَدَّثَنَا عُبَیْدُ اللہِ ، عَن حَنْظَلَۃَ ، عَن سَالِمٍ ، عَنْ عَائِشَۃَ ، قَالَتْ : لَیْسَ عَلَیْہِ قَطْعٌ۔",,,28734
28735,"حَدَّثَنَا شَرِیکٌ ، عَنْ أَبِی حَصِینٍ ، عَنْ عَبْدِ اللہِ ، قَالَ : أُتِیَ عُثْمَانُ بِغُلاَمٍ قَدْ سَرَقَ ،فَقَالَ : انْظُرُوا إِلَی مُؤْتَزَرِہِ ، ہَلْ أَنْبَتَ ؟۔",,,28735
28736,حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، وَمِسْعَرٍ، عَنْ أَبِی حَصِینٍ، عَنْ عَبْدِاللہِ بْنِ عُبَیْدِ بْنِ عُمَیْرٍ، عَنْ عُثْمَانَ؛ بِمِثْلِہِ۔,,,28736
28737,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ إِسْمَاعِیلَ بْنِ أُمَیَّۃَ ، عَنْ مُحَمَّدِ بْنِ یَحْیَی بْنِ حَبَّانَ ، قَالَ : ابْتَہَرَ غُلاَمٌ مِنَّا فِی شِعْرہِ بِامْرَأَۃٍ ، فَرُفِعَ إِلَی عُمَرَ ، فَشَکَّ فِیہِ ، فَنَظَرَ إِلَیْہِ ، فَلَمْ یُوجَد أَنْبَتَ ، فَقَالَ : لَوْ وَجَدْتُک أَنْبَتَّ لَجَلَدْتُک ، أَوْ لَحَدَدْتُک۔ (ابوعبید 289)",,,28737
28738,حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَن حُمَیْدٍ ، عَنْ أَنَسٍ ؛ أَنَّ أَبَا بَکْرٍ أُتِیَ بِغُلاَمٍ قَدْ سَرَقَ ، فَلَمْ یَتَبَیَّن احْتِلاَمُہُ، فَشَبَرَہُ فَنَقَصَ أُنْمُلَۃً ، فَتَرَکَہُ فَلَمْ یَقْطَعْہُ۔,,,28738
28739,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃ ، عَنْ قَتَادَۃ ، عَنْ خِلاَسٍ ، عَنْ عَلِیٍّ ، قَالَ : إِذَا بَلَغَ الْغُلاَمُ خَمْسَۃَ أَشْبَارٍ ، اقْتُصَّ مِنہِ ، وَاقْتُصَّ لَہُ۔",,,28739
28740,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، قَالَ : أُتِیَ ابْنُ الزُّبَیْرِ بِعَبْدٍ لِعُمَرَ بْنِ أَبِی رَبِیعَۃَ سَرَقَ ، فَأَمَرَ بِہِ فَشُبِرَ وَہُوَ وَصِیفٌ ، فَبَلَغَ سِتَّۃَ أَشْبَارٍ ، فَقَطَعَہُ۔",,,28740
28741,( حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَن ہَمَّامٍ ، عَنْ قَتَادَۃَ ؛ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ ، وَالْحَسَنَ کَانَا لاَ یُقِیمَانِ عَلَی الْغُلاَمِ حَدًّا حَتَّی یَحْتَلِمَ۔,,,28741
28742,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، فِی الصَّبِیِّ یَسْرِقُ ، قَالَ : لاَ قَطْعَ عَلَیْہِ حَتَّی یَحْتَلِمَ ، وَقَالَ عَمْرُو بْنُ دِینَارٍ : مَا أَرَی عَلَیْہِ قَطْعًا۔",,,28742
28743,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ، عَن حَسَنٍ، عَن مَنْصُورٍ، عَنْ إِبْرَاہِیمَ، قَالَ: لاَ یُقْطَعُ حَتَّی یَعْقِلَ، یَعْنِی یَحْتَلِمَ۔",,,28743
28744,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَن سُلَیْمَانَ بْنِ مُوسَی ، قَالَ : لاَ حَدَّ ، وَلاَ قَوَدَ عَلَی مَنْ لَمْ یَبْلُغِ الْحُلُمَ۔",,,28744
28745,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ یَحْیَی ، عَن سُلَیْمَانَ بْنِ یَسَارٍ ، قَالَ : أُتِیَ عُمَرُ بِغُلاَمٍ قَدْ سَرَقَ ، فَأَمَرَ بِہِ فَشُبِرَ ، فَوُجِدَ سِتَّۃَ أَشْبَارٍ ، إِلاَّ أُنْمُلَۃً فَتَرَکَہُ ، فَسُمِّیَ الْغُلاَمُ ، نُمَیلَۃَ۔",,,28745
28746,"حَدَّثَنَا وَکِیعٌ ، عَن مُسْعِرٍ ، عَنِ الْقَاسِمِ ، قَالَ : أُتِیَ عَبْدُ اللہِ بِجَارِیَۃٍ سَرَقَتْ لَمْ تَحِضْ ، فَلَمْ یَقْطَعْہَا۔",,,28746
28747,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إِبْرَاہِیمَ ؛ فِی الْجَارِیَۃِ تُزَوَّجُ فَیُدْخَلُ بِہَا ، ثُمَّ تُصِیبُ فَاحِشَۃً ، قَالَ : لَیْسَ عَلَیْہَا حَدٌّ حَتَّی تَحِیضَ۔",,,28747
28748,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، قَالَ : لَیْسَ عَلَی الْجَارِیَۃِ حَدٌّ حَتَّی تَحِیضَ۔",,,28748
28749,"حَدَّثَنَا عَبْدُالأَعْلَی، عن مَعْمَرٍ، عَنِ الزُّہْرِیِّ، قَالَ: لَیْسَ عَلَی الْجَارِیَۃِ حَدٌّ حَتَّی تَحِیضَ، أَوْ تَحِیضَ لِدَاتُہَا۔",,,28749
28750,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَن جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ ، قَالَ : لَیْسَ عَلَی الْجَارِیَۃِ حَدٌّ حَتَّی تَحِیضَ ، أَوْ تَحِیضَ لِدَاتُہَا۔",,,28750
28751,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ أَبِی بَکْرٍ بْنِ عَمْرِو بْنِ حَزْمٍ ؛ أَنَّہُ أُتِیَ بِجَارِیَۃٍ لَمْ تَبْلُغِ الْحَیْضَ ، أَخَذَتْ غُلاَمًا فَقَتَلَتْہُ ، وَغَیَّبَتْ مَا عَلَیْہِ ، فَلَمَّا رَآہَا قَدِ احْتَالَتْ حِیلَۃَ الْکَبِیرِ ، أَمَرَ بِہَا فَقُتِلَتْ۔,,,28751
28752,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ أَبِی بَکْرٍ ، قَالَ : سَمِعْتُ مَکْحُولاً ، یَقُولُ : إِذَا بَلَغَ الْغُلاَمُ خَمْسَ عَشْرَۃَ سَنَۃً ، جَازَتْ شَہَادَتُہُ ، وَوَجَبَتْ عَلَیْہِ الْحُدُودُ۔",,,28752
28753,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا سَرَقَ مِرَارًا ، فَإِنَّمَا تُقْطَعُ یَدٌ وَاحِدَۃٌ ، وَإِذَا شَرِبَ الْخَمْرَ مِرَارًا ، وَإِذَا قَذَفَ مِرَارًا فَإِنَّمَا عَلَیْہِ حَدٌّ وَاحِدٌ۔",,,28753
28754,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یُؤْخَذُ ، وَقَدْ زَنَی غَیْرَ مَرَّۃٍ بِامْرَأَۃٍ وَاحِدَۃٍ ، أَوْ أَکْثَرَ مِنْ ذَلِکَ مِنَ النِّسَائِ ؟ قَالَ : حَدٌّ وَاحِدٌ ، وَالسَّارِقُ یُؤْخَذُ وَقَدْ سَرَقَ مِرَارًا ، مِثْلُ ذَلِکَ۔",,,28754
28755,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : کَانَ یَقُولُ ، أَوْ یُقَالُ : إِذَا سَرَقَ الرَّجُلُ مِنْ شَتَّی ، ثُمَّ قُطِعَ لِوَاحِدٍ ، کَانَ لَہُمْ جَمِیعًا۔",,,28755
28756,"حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَن حَمَّادٍ ، قَالَ : إِذَا سَرَقَ مِرَارًا فَلَمْ یَقْدِرُوا عَلَیْہِ إِلاَّ بَعْدُ ، فَإِنَّمَا تُقْطَعُ یَدٌ وَاحِدَۃٌ۔",,,28756
28757,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : إِذَا سَرَقَ مِنْ شَتَّی ، فَقُطِعَ لِبَعْضِہِمْ ، لَمْ یُقْطَعْ بَعْدُ ، إِلاَّ أَنْ یُحْدِثَ سَرِقَۃً۔",,,28757
28758,"حَدَّثَنَا عُمَرُ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : إِذَا سَرَقَ ، ثُمَّ سَرَقَ ، ثُمَّ أُتِیَ بِہِ فَحَدٌّ وَاحِدٌ ، وَکَذَلِکَ فِی الزِّنَی۔",,,28758
28759,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قَالَ ابْنُ شِہَابٍ فِی رَجُلٍ سَرَقَ ، ثُمَّ شُہِدَ عَلَیْہِ أَنَّہُ قَدْ سَرَقَ قَبْلَ ذَلِکَ مِرَارًا ، أَوِ اعْتَرَفَ مَعَ عُقُوبَتِہِ ؟ قَالَ : تُقْطَعُ یَدُہُ ، وَقَالَ ابْنُ شِہَابٍ فِی رَجُلٍ زَنَی فَشُہِدَ عَلَیْہِ ، أَوِ اعْتَرَفَ بِذَلِکَ ، قَالَ : یُقَامُ عَلَیْہِ حَدٌّ وَاحِدٌ۔",,,28759
28760,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی حُرَّۃَ ، عَنِ الْحَسَنِ ، قَالَ : یَجُوزُ إِقْرَارُ الْعَبْدِ فِیمَا أُقِرَّ بِہِ مِنْ حَدٍّ یُقَامُ عَلَیْہِ ، وَمَا أَقَرَّ بِہِ مِمَّا تَذْہَبُ فِیہِ رَقَبَتُہُ فَلاَ یَجُوزُ۔",,,28760
28761,حَدَّثَنَا ابْنُ عَیَّاشٍ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی إِسْحَاقَ ؛ أَنَّ عَبْدًا أَقَرَّ عِندَ شُرَیْحٍ بِالسَّرِقَۃِ ، فَلَمْ یَقْطَعْہُ۔,,,28761
28762,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، وَعَبْدِ اللہِ بْنِ عیسی ، عَنِ الشَّعْبِیِّ ؛ أَنَّہُ قَالَ : لَیْسَ عَلَی الْعَبْدِ یُقِرُّ بِالسَّرِقَۃِ قَطْعٌ۔",,,28762
28763,"حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَن سُلَیْمَانَ بْنِ مُوسَی ، قَالَ : لاَ یَجُوزُ اعْتِرَافُ الْعَبْدِ ، إِلاَّ بِبَیِّنَۃٍ۔",,,28763
28764,"حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ یَجُوزُ اعْتِرَافُ الْعَبْدِ۔",,,28764
28765,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ أَبِی الضُّحَی ، وَالشَّعْبِیِّ ، قَالاَ : لاَ یُقَامُ عَلَی عَبْدٍ حَدٌّ بِاعْتِرَافٍ ، إِلاَّ بِبَیِّنَۃٍ۔",,,28765
28766,"حَدَّثَنَا مُعَاذٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَقُولُ : لاَ یَجُوزُ إِقْرَارُ الْعَبْدِ عَلَی نَفْسِہِ إِذَا بَلَغَ النَّفْسَ فِی خَطَأٍ ، وَلاَ عَمْدٍ۔",,,28766
28767,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ أَبِی مَالِکٍ الأَشْجَعِیِّ ، قَالَ : حدَّثَنِی أَہْلُ ہُرْمُزَ وَالْحَیُّ ، عَن ہُرْمُزَ ، أَنَّہُ أَتَی عَلِیًّا ، فَقَالَ : إِنِّی أَصَبْتُ حَدًّا ، فَقَالَ : تُبْ إِلَی اللہِ وَاسْتَتَرَ ، قَالَ : یَا أَمِیرَ الْمُؤْمِنِینَ ، طَہِّرْنِی ، قَالَ : قُمْ یَا قَنْبَرُ ، فَاضْرِبْہُ الْحَدَّ ، وَلَیَکنْ ہُوَ یَعُدُّ لِنَفْسِہِ ، فَإِذَا نَہَاک فَانْتَہِ ، وَکَانَ مَمْلُوکًا۔",,,28767
28768,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی بِشْرٍ ، عَن یُوسُفَ بْنِ مَاہِکٍ ؛ أَنَّ عَبْدًا لِبَعْضِ أَہْلِ مَکَّۃَ سَرَقَ رِدَائً لِصَفْوَانَ بْنِ أُمَیَّۃَ ، فَأُتِیَ بِہِ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَأَمَرَ بِقَطْعِہِ ، فَقَالَ : یَا رَسُولَ اللہِ ، تَقْطَعُہُ مِنْ أَجْلِ ثَوْبِی ؟ قَالَ : فَہَلاَ قَبْلَ أَنْ تَأْتِیَنِی بہ۔ (ابوداؤد 4394۔ ابن ماجہ 2595)",,,28768
28769,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ عَبْدِ الْمَلِکِ بْنِ أَبِی سُلَیْمَانَ ، عَنْ عَطَائٍ ؛ فِی الْعَبْدِ یَسْرِقُ ، قَالَ: یُقْطَعُ۔",,,28769
28770,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی أَبُو بَکْرِ بْنُ عَبْدِ اللہِ ، عَنْ أَبِی الزِّنَادِ ؛ أَنَّہُ أَخْبَرَہُ أَنَّ عَبْدَ اللہِ بْنَ عَامِرٍ أَخْبَرَہُ ، أَنَّ أَبَا بَکْرٍ قَطَعَ یَدَ عَبْدٍ سَرَقَ۔",,,28770
28771,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ إِسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ ؛ فِی أَرْبَعَۃٍ شَہِدُوا عَلَی رَجُلٍ بِالزِّنَی ، فَکَانَ أَحَدُہُمْ لَیْسَ بِعَدْلٍ ؟ قَالَ : یُدْرَأُ عَنْہُمُ الْحَدُّ لأَنَّہُمْ أَرْبَعَۃٌ۔",,,28771
28772,"حَدَّثَنَا ابْنُ فُضَیْلٍ، عَنْ أَشْعَثَ، عَنِ الشَّعْبِیِّ، قَالَ: إِذَا شَہِدَ أَرْبَعَۃٌ بِالزِّنَی، ثُمَّ لَمْ یَکُونُوا عُدُولاً لَمْ أَجْلِدْہُمْ۔",,,28772
28773,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللہِ الأَنْصَارِیُّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : إِذَا شَہِدَ أَرْبَعَۃٌ بِالزِّنَی عَلَی رَجُلٍ فَلَمْ یُعَدَّلُوا ، دُرِئَ عَنہُ الْحَدُّ ، وَلَمْ یُجْلَدْ أَحَد مِنْہُمْ۔",,,28773
28774,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنِ الأَعْمَشِ ، عَنِ الْقَاسِمِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِیہِ ، قَالَ : کُنْتُ قَاعِدًا عِندَ عَلِیٍّ فَجَائَ رَجُلٌ ، فَقَالَ : یَا أَمِیرَ الْمُؤْمِنِینَ ، إِنِّی قَدْ سَرَقْتُ ، فَانْتَہَرَہُ ، ثُمَّ عَادَ الثَّانِیَۃَ ، فَقَالَ : إِنِّی قَدْ سَرَقْتُ ، فَقَالَ لَہُ عَلِیٌّ : قَدْ شَہِدْتَ عَلَی نَفْسِکَ شَہَادَتَیْنِ ، قَالَ : فَأَمَرَ بِہِ فَقُطِعَتْ یَدُہُ ، فَرَأَیْتُہَا مُعَلَّقَۃً ، یَعْنِی فِی عُنُقِہِ۔",,,28774
28775,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَن حَسَنِ بْنِ صَالِحٍ ، عَن غَالِبٍ أَبِی الْہُذَیْلِ ، قَالَ : سَمِعْتُ سُبَیْعًا أَبَا سَالِمٍ ، یَقُولُ : شَہِدْتُ الْحَسَنَ بْنَ عَلِیٍّ وَأُتِیَ بِرَجُلٍ أَقَرَّ بِسَرِقَۃٍ ، فَقَالَ لَہُ الْحَسَنُ : فَلَعَلَّک اخْتَلَسْتَہُ ، لِکَیْ یَقُولَ لاَ ، حَتَّی أَقَرَّ عَندَہُ مَرَّتَیْنِ ، أَوْ ثَلاَثًا ، فَأَمَرَ بِہِ فَقُطِعَ۔",,,28775
28776,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : رَجُلٌ شَہِدَ عَلَی نَفْسِہِ مَرَّۃً وَاحِدَۃً بِأَنَّہُ سَرَقَ ؟ قَالَ : حَسْبُہُ۔",,,28776
28777,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ (ح) وَعَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُمَا قَالاَ : إِذَا قَذَفَ قَوْمًا جَمِیعًا جُلِدَ حَدًّا وَاحِدًا ، وَإِذَا قَذَفَ شَتَّی جُلِدَ لِکُلِّ وَاحِدٍ مِنْہُمْ حَدًّا۔",,,28777
28778,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَن یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یَقْذِفُ الْقَوْمَ جَمِیعًا ، قَالَ : یُجْلَدُ لِکُلِّ إِنْسَانٍ مِنْہُمْ حَدًّا۔",,,28778
28779,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إِبْرَاہِیمَ ؛ فِی الرَّجُلِ یَقْذِفُ الْقَوْمَ مُجْتَمَعِینَ بِقَذْفٍ وَاحِدٍ ، قَالَ : عَلَیْہِ حَدٌّ وَاحِدٌ۔وَقَالَ قَتَادَۃُ ، عَنِ الْحَسَنِ : لِکُلِّ رَجُلٍ مِنْہُمْ حَدٌّ۔",,,28779
28780,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَن حَمَّادٍ ، قَالَ : یُجْلَدُ حَدًّا وَاحِدًا۔",,,28780
28781,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا قَذَفَ مِرَارًا فَحَدٌّ وَاحِدٌ۔",,,28781
28782,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ؛ أَنَّہُ کَانَ یَقُولُ : إِذَا قَذَفَ الرَّجُلُ الْقَوْمَ بِقَذْفٍ وَاحِدٍ ، فَإِنَّمَا عَلَیْہِ حَدٌّ وَاحِدٌ۔",,,28782
28783,"حَدَّثَنَا مُحَمَّدُ بْنُ یَزِیدٍ ، عَنْ أَبِی الْعَلاَئِ ، عَنْ قَتَادَۃَ ، وَأَبِی ہَاشِمٍ ؛ فِی رَجُلٍ افْتَرَی عَلَی قَوْمٍ جَمِیعًا ، قَالَ : عَلَیْہِ حَدٌّ وَاحِدٌ۔",,,28783
28784,"حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ فِی رَجُلٍ دَخَلَ عَلَی أَہْلِ بَیْتٍ ، فَقَذَفَہُمْ ، قَالَ : حدٌّ وَاحِدٌ۔",,,28784
28785,"حَدَّثَنَا الضَّحَّاکُ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَبْدِ الکریم ، عَنْ طَاوُوسٍ ، قَالَ : حَدٌّ وَاحِدٌ۔",,,28785
28786,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ أَبِیہِ ، عَن حَمَّادٍ ، قَالَ : یُجْلَدُ حَدًّا وَاحِدًا۔",,,28786
28787,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ؛ فِی الرَّجُلِ یَقْذِفُ الْقَوْمَ جَمِیعًا ، قَالَ : إِنْ کَانَ فِی کَلاَمٍ وَاحِدٍ فَحَدٌّ وَاحِدٌ : وَإِذَا فَرَّقَ ، فَعَلَیْہِ لِکُلِّ وَاحِدٍ مِنْہُمْ حَدٌّ ، وَالسَّارِقُ مِثْلُ ذَلِکَ۔",,,28787
28788,"حَدَّثَنَا ہُشَیْمُ بْنُ بَشِیرٍ، عَنْ مُغِیرَۃَ، عَنْ إِبْرَاہِیمَ؛ أَنَّہُ قَالَ: مَنْ قَذَفَ یَہُودِیًّا، أَوْ نَصْرَانِیًّا فَلاَ حَدَّ عَلَیْہِ۔",,,28788
28789,حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُطَرِّفٍ ، عَنِ الشَّعْبِیِّ ؛ أَنَّہُ قَالَ مِثْلَ ذَلِکَ۔,,,28789
28790,حَدَّثَنَا ہُشَیْمٌ ، عَن یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَقُولُ ذَلِکَ,,,28790
28791,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، وَابْنُ نُمَیْرٍ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، قَالَ : لَیْسَ عَلَی قَاذِفِ أَہْلِ الذِّمَّۃِ حَدٌّ۔",,,28791
28792,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ لَیْثٍ ، عَن طَاوُوسٍ ، وَمُجَاہِدٍ ، وَالشَّعْبِیِّ (ح) وَالْحَکَمِ ، عَنْ إِبْرَاہِیمَ ، قَالُوا : إِذَا کَانَتِ الْیَہُودِیَّۃُ وَالنَّصْرَانِیَّۃُ تَحْتَ مُسْلِمٍ ، فَلَیْسَ بَیْنَہُمَا مُلاَعَنۃٌ ، وَلَیْسَ عَلَی قَاذِفِہِمَا حَدٌّ۔",,,28792
28793,"حَدَّثَنَا یَحْیَی بْنُ عَبْدِ الْمَلِکِ بْنِ أَبِی غَنِیَّۃَ ، عَنْ أَبِیہِ ، عَنِ الْحَکَمِ ، قَالَ : إِذَا قَذَفَ الرَّجُلُ الرَّجُلَ ، وَلَہُ أُمٌّ یَہُودِیَّۃٌ ، أَوْ نَصْرَانِیَّۃٌ فَلاَ حَدَّ عَلَیْہِ۔",,,28793
28794,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : إِذَا قَذَفَ الْیَہُودِیُّ وَالنَّصْرَانِیُّ ، عُزِّرَ قَاذِفُہُ۔",,,28794
28795,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی خَلْدَۃَ ، عَن عِکْرِمَۃَ ، قَالَ : لَوْ أُوتِیَتْ بِرَجُلٍ قَذَفَ یَہُودِیًّا ، أَوْ نَصْرَانِیًّا وَأَنَا وَالٍ ، لَضَرَبْتہ۔",,,28795
28796,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَن یُونُسَ ، عَنِ الْحَسَنِ ؛ سُئِلَ عَنْ رَجُلٍ قَذَفَ نَصْرَانِیَّۃً ؟ قَالَ : یُضْرَبُ إِنْ کَانَ لَہَا زَوْجٌ مُسْلِمٌ۔",,,28796
28797,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ فِی النَّصْرَانِیَّۃِ وَالْیَہُودِیَّۃِ تُقْذَفُ وَلَہَا زَوْجٌ مُسْلِمٌ ، وَلَہَا مِنْہُ وَلَدٌ ، قَالَ : عَلَی قَاذِفِہَا الْحَدُّ۔",,,28797
28798,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا کَانَتِ الْیَہُودِیَّۃُ وَالنَّصْرَانِیَّۃ تَحْتَ رَجُلٍ مُسْلِمٍ ، فَقَذَفَہَا رَجُلٌ فَلاَ حَدَّ عَلَیْہِ۔",,,28798
28799,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الشَّیْبَانِیِّ ، عَنْ أَبِی بَکْرٍ بْنِ حَفْصٍ ؛ أَنَّ رَجُلاً قَذَفَ نَصْرَانِیَّۃً ، وَلَہَا ابْنٌ مُسْلِمٌ ، فَضَرَبَہُ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ أَرْبَعَۃً وَثَلاَثِینَ سَوْطًا۔,,,28799
28800,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ، عَنْ أَشْعَثَ، عَنِ الْحَسَنِ؛ فِی النَّصْرَانِیِّ یَقْذِفُ الْمُسْلِمَ، قَالَ: یُجْلَدُ ثَمَانِینَ۔",,,28800
28801,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَن طَارِقٍ ، قَالَ : شَہِدْتُ الشَّعْبِیَّ ضَرَبَ نَصْرَانِیًّا قَذَفَ مُسْلِمًا ثَمَانِینَ۔",,,28801
28802,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، قَالَ : إِذَا قَذَفَ النَّصْرَانِیُّ الْمُسْلِمَ جُلِدَ الْحَدَّ۔",,,28802
28803,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، قَالَ فِی أَہْلِ الذِّمَّۃِ : یُجْلَدُونَ فِی الْفِرْیَۃِ عَلَی الْمُسْلِمِینَ۔",,,28803
28804,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُطَرِّفٍ ، عَنْ عَامِرٍ ، قَالَ : أَتَانِی مُسْلِمٌ وَجُرْمُقَانِیٌّ ، قَدِ افْتَرَی کُلُّ وَاحِدٍ مِنْہُمَا عَلَی صَاحِبِہِ ، فَجَلَدْتُ الْجُرْمُقَانِیَّ ، وَتَرَکْت الْمُسْلِمَ ، فَأَتَی عُمَرَ بْنَ عَبْدِ الْعَزِیزِ فَذَکَرَ ذَلِکَ لَہُ ، فَقَالَ : أَحْسَنَ۔",,,28804
28805,"حَدَّثَنَا ابْنُ فُضَیْلٍ، عَنْ عَاصِمٍ ، قَالَ: شَہِدْتُ الشَّعْبِیَّ وَضَرَبَ نَصْرَانِیًّا قَذَفَ مُسْلِمًا ، فَقَالَ : اضْرِبْ، وَلاَ یُرَی إِبْطُک۔",,,28805
28806,"حَدَّثَنَا مَخْلَدُ بْنُ یَزِیدَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عُمَرَ بْنِ عَطَائِ بْنِ أَبِی الْخُوار ، عَنْ عِکْرِمَۃَ مَوْلَی ابْنِ عَبَّاسٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ فِی الْمَمْلُوکِ یَقْذِفُ الْحُرَّ ، قَالَ : یُجْلَدُ أَرْبَعِینَ۔",,,28806
28807,حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ إِسْحَاقَ بْنِ أَبِی فَرْوَۃَ ، عَنْ مَکْحُولٍ ، وَعَطَائٍ ؛ أَنَّ عُمَرَ ، وَعَلِیًّا کَانَا یَضْرِبَانِ الْعَبْدَ یَقْذِفُ الْحُرَّ أَرْبَعِینَ۔,,,28807
28808,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ ذَکْوَانَ ، عَنْ عَبْدِ اللہِ بْنِ عَامِرِ بْنِ رَبِیعَۃَ ، قَالَ : کَانَ أَبُو بَکْرٍ الصِّدِّیقُ ، وَعُمَرُ بْنُ الْخَطَّابِ ، وَعُثْمَانُ بْنُ عَفَّانَ لاَ یَجْلِدُونَ الْعَبْدَ فِی الْقَذْفِ إِلاَّ أَرْبَعِینَ ، ثُمَّ رَأَیْتُہمْ یَزِیدُونَ عَلَی ذَلِکَ۔",,,28808
28809,"حَدَّثَنَا عَبْدِ السَّلام ، عَنْ مُطَرِفٍ ، عَنِ الشَّعْبِّی ، قَالَ : یُضْرَبُ أَرْبَعِینَ۔",,,28809
28810,"( حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ سعید ، عن أَبِی مَعْشَرٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : یُضْرَبُ أَرْبَعِینَ۔",,,28810
28811,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ عَلِیٍّ ، قَالَ : یُضْرَبُ أَرْبَعِینَ۔",,,28811
28812,حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِید بْنِ الْمُسَیْب ، وَالْحَسَنِ ؛ مِثْلَہُ۔,,,28812
28813,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسُ ، عَنِ الْحَسَنِ ، قَالَ : یُضْرَبُ أَرْبَعِینَ۔",,,28813
28814,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَن حَنْظَلَۃَ ، عَنِ الْقَاسِمِ ، قَالَ : یُضْرَبُ أَرْبَعِینَ۔",,,28814
28815,"حَدَّثَنَا وَکِیعٌ ، عَنْ سَعِید بْنِ حَسَّانَ ، عَنْ مُجَاہِدٍ ، قَالَ : أَرْبَعِینَ۔",,,28815
28816,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ جَرِیرٍ ، عَنْ قَیْسِ بْنِ سَعْدٍ ، عَنْ طَاوُوسٍ ، قَالَ : یُضْرَبُ أَرْبَعِینَ۔",,,28816
28817,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ ، وَحَمَّادًا ؟ فَقَالاَ : یُضْرَبُ أَرْبَعِینَ۔",,,28817
28818,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ مُحَمَّدِ بْنِ رَاشِدٍ ، عَنْ مَکْحُولٍ ، قَالَ : یُضْرَبُ أَرْبَعِینَ۔",,,28818
28819,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، قَالَ : جَلَدَ أَبُو بَکْرٍ بْنُ مُحَمَّدِ بْنِ عَمْرِو بْنِ حَزْمٍ عَبْدًا قَذَفَ حُرًّا ثَمَانِینَ۔",,,28819
28820,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : یُضْرَبُ ثَمَانِینَ۔",,,28820
28821,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنِ الْمَسْعُودِیِّ ، عَنِ الْقَاسِمِ بْنِ عَبْدِ الرَّحْمَنِ ، قَالَ : یُضْرَبُ ثَمَانِینَ۔",,,28821
28822,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حدَّثَنَی جَرِیرُ بْنُ حَازِمٍ ، قَالَ : قَرَأْتُ کِتَابَ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ إِلَی عَدِیِّ بْنِ أَرْطَاۃَ : أَمَّا بَعْدُ ، کَتَبْتَ تَسْأَلُ عَنِ الْعَبْدِ یَقْفُو الْحُرَّ ، کَمْ یُجْلَدُ ، وَذَکَرْتَ أَنَّہُ بَلَغَک أَنِّی کُنْتُ أَجْلِدُہُ إِذْ أَنَا بِالْمَدِینَۃِ أَرْبَعِینَ جَلْدَۃً ، ثُمَّ جَلَدْتُہُ فِی آخِرِ عَمَلِی ثَمَانِینَ جَلْدَۃً ، وَإِنَّ جَلْدِی الأَوَّلَ کَانَ رَأْیًا رَأَیْتُہُ ، وَإِنَّ جِلْدِیَّ الأَخِیرَ وَافَقَ کِتَابَ اللہِ ، فَاجْلِدْہُ ثَمَانِینَ جَلْدَۃً۔",,,28822
28823,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی بَکْرٍ ، قَالَ : ضَرَبَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ الْعَبْدَ یَقْذِفُ ثَمَانِینَ۔",,,28823
28824,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَن رُزَیْقٍ ، قَالَ : کَتَبْتُ إِلَی عُمَرَ بْنَ عَبْدِ الْعَزِیزِ فِی رَجُلٍ قَذَفَ ابْنَہُ ، فَقَالَ ابْنُہُ : إِنْ جُلِدَ أَبِی اعْتَرَفْتُ ، فَکَتَبَ إِلَیْہِ عُمَرُ : اجْلِدْہُ ، إِلاَّ أَنْ یَعْفُوَ عَنْہُ۔",,,28824
28825,"حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ فِی الرَّجُلِ یَقْذِفُ ابْنَہُ ، فَقَالَ : لاَ یُجْلَدُ۔",,,28825
28826,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَن مُبَارَکٍ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یَقْذِفُ ابْنَہُ ، قَالَ : لَیْسَ عَلَیْہِ حَدٌّ۔",,,28826
28827,"حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنِ الْقَاسِمِ ، عَنْ أَبِیہِ ، قَالَ : قَالَ عَبْدُ اللہِ : لاَ حَدَّ إِلاَّ عَلَی رَجُلَیْنِ : رَجُلٌ قَذَفَ مُحْصَنَۃً ، أَوْ نَفَی رَجُلاً مِنْ أَبِیہِ ، وَإِنْ کَانَتْ أُمُّہُ أَمَۃً۔",,,28827
28828,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : إِذَا نَفَی الرَّجُلُ الرَّجُلَ مِنْ أَبِیہِ ، فَإِنَّ عَلَیْہِ الْحَدَّ ، وَإِنْ کَانَتْ أُمَّہُ مَمْلُوکَۃً۔",,,28828
28829,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ سَعِیدٍ الزُّبَیْدِیِّ ، عَن حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ؛ فِی الرَّجُلِ یَقُولُ لِلرَّجُلِ : لَسْتَ لأََبِیک ، وَأُمَّہُ أَمَۃٌ ، أَوْ یَہُودِیَّۃٌ ، أَوْ نَصْرَانِیَّۃٌ ، قَالَ : لاَ یُجْلَدُ۔",,,28829
28830,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَن شَیْخٍ مِنَ الأَزْدِ ؛ أَنَّ ابْنَ ہُبَیْرَۃَ سَأَلَ عَنہُ الْحَسَنَ ،وَالشَّعْبِیَّ ؟ فَقَالاَ : یُضْرَبُ الْحَدَّ ، یَقُولُ فِی الرَّجُلِ یَنْفِی الرَّجُلَ مِنْ أَبِیہِ ، وَأُمُّہُ أَمَۃٌ۔",,,28830
28831,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَن یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : أُمُّ الْوَلَدِ لاَ یُجْلَدُ قَاذِفُہَا۔",,,28831
28832,"حَدَّثَنَا حَفْصٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ (ح) وَعَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، وَابْنِ سِیرِینَ ، قَالُوا : لَیْسَ عَلَی قَاذِفِ أُمِّ الْوَلَدِ حَدٌّ۔",,,28832
28833,"حَدَّثَنَا عَبَّادٌ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ فِی رَجُلٍ قَذَفَ رَجُلاً أُمَّہُ أُمَّ وَلَدٍ ، قَالَ : لَیْسَ عَلَیْہِ حَدٌّ حَتَّی تُعْتقَ۔",,,28833
28834,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ مُغِیرَۃَ، عَنْ إِبْرَاہِیمَ ، وَالشَّعْبِیِّ ، قَالاَ: لَیْسَ عَلَی قَاذِفِ أُمِّ الْوَلَدِ شَیْئٌ۔",,,28834
28835,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : لاَ یُجْلَدُ قَاذِفُ أُمِّ الْوَلَدِ۔",,,28835
28836,"حَدَّثَنَا عَبَّادٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، وَمُحَمَّدٍ ، قَالاَ : لَیْسَ عَلَی قَاذِفِ أُمِّ الْوَلَدِ حَدٌّ۔",,,28836
28837,حَدَّثَنَا إِسْمَاعِیلُ بْنُ إِبْرَاہِیمَ ، عَن أَیُّوبَ ، عَن نَافِعٍ ؛ أَنَّ بَعْضَ أُمَرَائِ الْفِتْنَۃِ سَأَلَ ابْنَ عُمَرَ عَن أُمِّ وَلَدٍ قُذِفَتْ ؟ فَأَمَرَ بِقَاذِفِہَا أَنْ یُجْلَدَ ثَمَانِینَ۔,,,28837
28838,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَن نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : یُجْلَدُ قَاذِفُ أُمِّ الْوَلَدِ۔",,,28838
28839,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : اسْتَبَّ ابْنُ صَرِیحَۃ ، وَابْنُ أُمِّ وَلَدٍ ، فَسَبَّ ابْنُ الصَرِیحَۃِ ابْنَ أُمِّ الْوَلَدِ فَجُلِدَ۔",,,28839
28840,حَدَّثَنَا عَبْدُ الْوَہَّابِ بْنِ عَطَائٍ ، عَنْ سَعِیدٍ ، عَنْ أَبِی یَزِیدَ الْمَدَنِیِّ ؛ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ جَلَدَ رَجُلاً قَذَفَ أُمَّ وَلَدِ رَجُلٍ لَمْ تُعْتَقْ۔,,,28840
28841,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ؛ أَنَّ عَدِیَّا کَتَبَ إِلَی عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، فَکَتَبَ : أَنِ اجْلِدْہُ الْحَدَّ۔",,,28841
28842,"حَدَّثَنَا إِسْمَاعِیلُ بْنُ إِبْرَاہِیمَ ، عَن أَیُّوبَ ، قَالَ : کَتَبْتُ إِلَی أَبِی قلاَبَۃَ أَسْأَلُہُ عَنِ الْمَرْأَۃِ تُقْذَفُ ، وَقَدْ کَانَتْ مُلِکَتْ ؟ فَکَتَبَ إِلَیَّ : أَنَّ قَاذِفَہَا یُجْلَدُ ثَمَانِینَ۔",,,28842
28843,حَدَّثَنَا عَبْدَۃُ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إِبْرَاہِیمَ ؛ فِی أُمِّ الْوَلَدِ إِذَا أُعْتِقَتْ ، ثُمَّ قُذِفَتْ ، جُلِدَ قَاذِفُہَا۔,,,28843
28844,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ؛ أَنَّہُ کَانَ یَقُولُ : إِذَا مُلِکَتِ الْمَرْأَۃُ مَرَّۃً ، ثُمَّ أُعْتِقَتْ ، فَإِنَّ عَلَی قَاذِفِہَا الْحَدَّ۔",,,28844
28845,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ ہِشَامٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ؛ فِی امْرَأَۃٍ مُلِکَتْ مَرَّۃً ، ثُمَّ قُذِفَتْ ، قَالَ : لاَ یُجْلَدُ قَاذِفُہَا۔",,,28845
28846,"حَدَّثَنَا جَرِیرٌ ، عَن مَنْصُورٍ ، عَنْ أَبِی الضُّحَی (ح) وَعَن مُغِیرَۃَ ، عَنِ الشَّعْبِیِّ ، قَالاَ : کَانَ عَلِیٌّ یَقُولُ : إِذَا سَرَقَ السَّارِقُ مِرَارًا قُطِعَتْ یَدُہُ وَرِجْلُہُ ، ثُمَّ إِنْ عَادَ اسْتَوْدَعْتُہُ السِّجْنَ۔",,,28846
28847,"حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، قَالَ : کَانَ عَلِیٌّ لاَ یَزِیدُ عَلَی أَنْ یَقْطَعَ لِسارِقٍ یَدًا وَرِجْلاً ، فَإِذَا أُتِیَ بِہِ بَعْدَ ذَلِکَ ، قَالَ : إِنِّی لأَسْتَحِی أَنْ لاَ یَتَطَہَّرَ لِصَلاَتِہِ ، وَلَکِنْ أَمْسِکُوا کَلْبَہ عَنِ الْمُسْلِمِینَ ، وَأَنْفِقُوا عَلَیْہِ مِنْ بَیْتِ الْمَالِ۔",,,28847
28848,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیُّ ، عَنِ الزُّہْرِیِّ ، قَالَ : انْتَہَی أَبُو بَکْرٍ فِی قَطْعِ السَّارِقِ إِلَی الْیَدِ وَالرِّجْلِ۔",,,28848
28849,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ بْنِ جَابِرٍ ، عَنْ مَکْحُولٍ ؛ أَنَّ عُمَرَ قَالَ : إِذَا سَرَقَ فَاقْطَعُوا یَدَہُ ، ثُمَّ إِنْ عَادَ فَاقْطَعُوا رِجْلَہُ ، وَلاَ تَقْطَعُوا یَدَہُ الأُخْرَی ، وَذَرُوہُ یَأْکُلُ بِہَا الطَّعَامَ وَیَسْتَنْجِی بِہَا مِنَ الْغَائِطِ ، وَلَکِنِ احْبِسُوہُ عَنِ الْمُسْلِمِینَ۔",,,28849
28850,"حَدَّثَنَا جَرِیرٌ ، عَن مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لاَ یُتْرَک ابْنُ آدَمَ کَالْبَہِیمَۃِ ، یُتْرَکُ لَہُ یَدٌ یَأْکُلُ بِہَا۔",,,28850
28851,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، عَنْ أَبِیہِ ؛ أَنَّ أَبَا بَکْرٍ أَرَادَ أَنْ یَقْطَعَ الرِّجْلَ بَعْدَ الْیَدِ وَالرِّجْلِ ، فَقَالَ عُمَرُ لَہُ : السُّنَّۃُ الْیَدُ۔",,,28851
28852,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَن خَالِدٍ الْحَذَّائِ ، عَن عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : رَأَیْتُ عُمَرَ بْنَ الْخَطَّابِ قَطَعَ یَدَ رَجُلٍ بَعْدَ یَدِہِ وَرِجْلِہِ۔",,,28852
28853,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ سُئِلَ : أَیُقْطَعُ السَّارِقُ أَکْثَرَ مِنْ یَدِہِ وَرِجْلِہِ ؟ قَالَ : لاَ ، وَلَکِنَّہُ یُحْبَسُ۔",,,28853
28854,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، قَالَ : کَتَبَ نَجْدَۃُ إِلَی ابْنِ عُمَرَ ، یَسْأَلُہُ : ہَلْ قَطَعَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الرِّجْلَ بَعْدَ الْیَدِ ؟ فَکَتَبَ إِلَیْہِ : أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَدْ قَطَعَ الرِّجْلَ بَعْدَ الْیَدِ۔",,,28854
28855,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی عَبْدُ رَبِّہِ بْنُ أَبِی أُمَیَّۃَ بْنِ الْحَارِثِ ، عَنِ الْحَارِثِ بْنِ عَبْدِ اللہِ بْنِ أَبِی رَبِیعَۃَ ؛ أَنَّہُ حَدَّثَہُ ، وَعَبْدُ الرَّحْمَن بْنُ سَابِطٍ أَیْضًا حَدَّثَاہُ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أُتِیَ بِعَبْدٍ قَدْ سَرَقَ فَقَطَعَ یَدَہُ ، ثُمَّ الثَّانِیَۃَ فَقَطَعَ رِجْلَہُ ، ثُمَّ أُتِیَ بِہِ فَقَطَعَ یَدَہُ ، ثُمَّ أُتِیَ بِہِ فَقَطَعَ رِجْلَہُ۔\n\n(ابوداؤد 247)",,,28855
28856,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنِ الشَّعْبِیِّ (ح) وَعَنْ شُعْبَۃَ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ عَبْدِ اللہِ بْنِ سَلِمَۃَ ؛ أَنَّ عَلِیًّا أُتِیَ بِسَارِقٍ فَقَطَعَ یَدَہُ الْیُمْنَی ، ثُمَّ أُتِیَ بِہِ فَقَطَعَ رِجْلَہُ الْیُسْرَی ، ثُمَّ أُتِیَ بِہِ الثَّالِثَۃَ ، فَقَالَ : إِنِّی لأَسْتَحْیِی أَنْ أَقْطَعَ یَدَہُ یَأْکُلُ بِہَا وَیَسْتَنْجِی بِہَا۔\n\nوَفِیْ حَدِیثِ بَعْضِہِمْ : ضَرَبَہُ وَحَبَسَہُ۔",,,28856
28857,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ عَبْدِ اللہِ بْنِ سَلَمَۃِ ، قَالَ : کَانَ عَلِیٌّ یَقُولُ فِی السَّارِقِ : إِذَا سَرَقَ قَطَعْت یَدَہُ ، فَإِنْ عَادَ قَطَعْتُ رِجْلَہُ ، فَإِنْ عَادَ اسْتَوْدَعْتُہُ السِّجْنَ۔",,,28857
28858,حَدَّثَنَا أَبُو خَالِدٍ، عَنْ حَجَّاجٍ، عَنْ عَمْرِو بْنِ دِینَارٍ؛ أَنَّ نَجْدَۃَ کَتَبَ إِلَی ابْنِ عَبَّاسٍ یَسْأَلُہُ عَنِ السَّارِقِ؟ فَکَتَبَ إِلَیْہِ بِمِثْلِ قَوْلِ عَلِیٍّ۔,,,28858
28859,حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَن سِمَاکٍ ، عَنْ بَعْضِ أَصْحَابِہِ ؛ أَنَّ عُمَرَ اسْتَشَارَہُمْ فِی سَارِقٍ ، فَأَجْمَعُوا عَلَی مِثْلِ قَوْلِ عَلِیٍّ۔,,,28859
28860,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَن ثُمَامَۃَ ؛ أَنَّ أَنَسَ بْنَ مَالِکٍ کَانَ إِذَا زَنَی مَمْلُوکُہُ ضَرَبَہُ الْحَدَّ۔,,,28860
28861,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَن عُبَیْدِ اللہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، وَزَیْدِ بْنِ خَالِدٍ ، وَشِبْلٍ ، قَالُوا: کُنَّا عَندَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَسَأَلَہُ رَجُلٌ عَنِ الأَمَۃِ تَزْنِی قَبْلَ أَنْ تُحْصَنَ ؟ قَالَ : اجْلِدُوہَا ، فَإِنْ زَنَتْ فَاجْلِدُوہَا ، قَالَ فِی الثَّالِثَۃِ ، أَوْ فِی الرَّابِعَۃِ : فَبِیعُوہَا وَلَوْ بِضَفِیرٍ۔ (احمد 116۔ ابن ماجہ 2565)",,,28861
28862,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ عَبْدِ الأَعْلَی ، عَنْ أَبِی جَمِیلَۃَ ، عَنْ عَلِیٍّ ، قَالَ : أُخْبِرَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِأَمَۃٍ لَہُمْ فَجَرَتْ ، فَأَرْسَلَنِی إِلَیْہَا ، فَقَالَ : اذْہَبْ فَأَقِمْ عَلَیْہَا الْحَدَّ ، فَانْطَلَقْتُ فَوَجَدْتہَا لَمْ تَجِفَّ مِنْ دِمَائِہَا ، فَقَالَ : أَفْرَغْتَ ؟ فَقُلْتُ : وَجَدْتہَا لَمْ تَجِفَّ مِنْ دِمَائِہَا ، قَالَ : إِذَا جَفَّتْ مِنْ دِمَائِہَا فَاجْلِدْہَا ، ثُمَّ قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : وَأَقِیمُوا الْحُدُودَ عَلَی مَا مَلَکَتْ أَیْمَانُکُمْ۔\n\n(ابوداؤد 4468۔ احمد 89)",,,28862
28863,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن ہَمَّامٍ ، عَنْ عَمْرِو بْنِ شُرَحْبِیلَ ، قَالَ : جَائَ مَعْقِلُ الْمُزَنِیّ إِلَی عَبْدِ اللہِ ، فَقَالَ : جَارِیَتِی زَنَتْ فَاجْلِدُوہَا ؟ قَالَ : فَقَالَ عبْدُ اللہِ : اجْلِدْہَا خَمْسِینَ ، فَقَالَ : عَادَتْ ، فَقَالَ : اجْلِدْہَا۔",,,28863
28864,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ بْنِ مُحَمَّدِ بْنِ عَلِیٍّ ؛ أَنَّ فَاطِمَۃَ حَدَّتْ جَارِیَۃً لَہَا۔,,,28864
28865,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ أَبِی الزِّنَادِ ، عَن خَارِجَۃَ بْنِ زَیْدٍ ، عَنْ زَیْدٍ ؛ أَنَّہُ حَدَّ جَارِیَۃً لَہُ۔,,,28865
28866,حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَن خَالِدٍ، عَنْ أَبِی قِلاَبَۃَ؛ أَنَّ أَبَا الْمُہَلَّبِ کَانَ یَجْلِدُ أَمَتَہُ إِذَا فَجَرَتْ فِی مَجْلِسِ قَوْمِہِ۔,,,28866
28867,"حَدَّثَنَا جَرِیرٌ، عَنْ مُغِیرَۃَ، عَنْ فُضَیْلٍ، عَنْ إِبْرَاہِیمَ، قَالَ: کَانُوا یُرْسِلُونَ إِلَی خَدَمِہِمْ إِذَا زَنَیْنَ یَجْلِدُونَہُنَّ فِی الْمَجَالِسِ۔",,,28867
28868,حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَن نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَضْرِبُ أَمَتَہُ إِذَا فَجَرَتْ۔,,,28868
28869,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ أَشْعَثَ ، عَنْ أَبِیہِ ، قَالَ : شَہِدْت أَبَا بَرْزَۃَ ضَرَبَ أَمَۃً لَہُ فَجَرَتْ ، قَالَ : وَعَلَیْہَا مِلْحَفَۃٌ قَدْ جُلِّلَتْ بِہَا ، قَالَ : وَعَندَہُ طَائِفَۃٌ مِنَ النَّاسِ ، قَالَ : ثُمَّ قَرَأَ {وَلْیَشْہَدْ عَذَابَہُمَا طَائِفَۃٌ مِنَ الْمُؤْمِنِینَ}۔",,,28869
28870,"حَدَّثَنَا وَکِیعٌ ، وَغُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، قَالَ : أَدْرَکْتُ أَشْیَاخَ الأَنْصَارِ إِذَا زَنَتِ الأَمَۃُ یَضْرِبُونَہَا فِی مَجَالِسِہِمْ۔",,,28870
28871,حَدَّثَنَا أَبُو خَالِدٍ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، وَالأَسْوَدِ ؛ أَنَّہُمَا کَانَا یُقِیمَانِ الْحُدُودَ عَلَی جِوَارِی الْحَیِّ إِذَا زَنَیْنَ فِی الْمَجَالِسِ۔,,,28871
28872,"حَدَّثَنَا وَکِیعٌ، عَنْ إِسْرَائِیلَ، عَنْ جَابِرٍ، عَنْ أَبِی جَعْفَرٍ ، قَالَ: لاَ تُطہِّر فِی الْحَیِّ إِلاَّ مَا مَلَکَتْ یَمِینُک۔",,,28872
28873,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی مَیْسَرَۃَ ؛ أَنَّہُ کَانَ یَضْرِبُ إِمَائَ قَوْمِہِ یُطَہِّرُہُنَّ۔,,,28873
28874,"حَدَّثَنَا جَرِیرٌ ، عَن مَنْصُورٍ ، قَالَ : لَقِیتُ عَبْدَ الرَّحْمَن بْنَ مَعْقِلٍ ، فَقُلْتُ : أَرَأَیْتَ الأَمَۃَ الَّتِی سَأَلَ عَنْہَا أَبُوک عَبْدَ اللہِ أَنَّہَا فَجَرَتْ ، فَأَمَرَہُ بِجِلْدِہَا ، کَانَتْ تَزَوَّجَتْ ؟ قَالَ : لاَ۔",,,28874
28875,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنِ الأَعْمَشِ ، عَن حَبِیبٍ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِذَا زَنَتْ خَادِمُ أَحَدِکُمْ فَلْیَجْلِدْہَا ، فَإِنْ عَادَتْ فَلْیَجْلِدْہَا ، فَإِنْ عَادَتْ فَلْیَجْلِدْہَا ، فَإِنْ عَادَتْ فَلْیَبِعْہَا وَلَوْ بِحَبْلٍ مِنْ شَعْرٍ۔ (ترمذی 1440۔ نسائی 7240)",,,28875
28876,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَن حَبِیبٍ ، عَنِ ابْنِ عَبَّاسٍ (ح) وَعَنْ سُفْیَانَ ، عَن مَنْصُورٍ ، عَن مُجَاہِدٍ (ح) وَعَن شُعْبَۃَ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالُوا : لَیْسَ عَلَی الأَمَۃِ حَدٌّ حَتَّی تُزَوَّجَ۔",,,28876
28877,"حَدَّثَنَا ابْنُ یَمَانٍ ، عَنْ أَشْعَثَ ، عَنْ جَعْفَرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : لاَ تُجْلَدُ الأَمَۃُ حَتَّی تُحْصَنَ۔",,,28877
28878,"حَدَّثَنَا جَرِیرٌ ، عَن مَنْصُورٍ ، عَن مُجَاہِدٍ ، قَالَ : یَقُولُ أَہْلُ مَکَّۃَ : إِذَا فَجَرَتِ الأَمَۃُ وَلَمْ تَکُنْ تَزَوَّجَتْ قَبْلَ ذَلِکَ ، لاَ یُقَامُ عَلَیْہَا الْحَدُّ۔",,,28878
28879,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ، عَنْ عَمْرٍو، عَن مُجَاہِدٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: لَیْسَ عَلَی الأَمَۃِ حَدٌّ حَتَّی تُحْصَنَ بِزَوْجٍ۔",,,28879
28880,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ مُبَارَکٍ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَن عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : حدُّ الْمُکَاتَبِ حَدُّ الْمَمْلُوکِ۔",,,28880
28881,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیْرَۃ ، قَالَ : حَدُّ الْمُکَاتَبِ حَدُّ الْمَمْلُوکِ ، مَا بَقِیَ عَلَیْہِ شَیْئٌ مِنْ مُکَاتَبَتِہِ۔",,,28881
28882,"حَدَّثَنَا عَبْدَۃُ ، عَن صَالِحِ بْنِ حَیٍّ ، عَنِ الشَّعْبِیِّ ، قَالَ : حَدُّ الْمَمْلُوکِ مَا بَقِیَ عَلَیْہِ شَیْئٌ۔",,,28882
28883,"حَدَّثَنَا أَبُو خَالِد الأَحَمْر، عَنْ صَالِحِ بْنِ حَیِّ، عَنْ الشَّعْبِیِّ، قَالَ: یُضْرَبُ الْمُکَاتَبُ حَدَّ الْعَبْدِ حَتَّی یعْتقَ۔",,,28883
28884,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : حدَّہُ حَدُّ الْعَبْدِ۔",,,28884
28885,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَن مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَلِیٍّ ؛ فِی الْمُکَاتَبِ إِذَا أَصَابَ حَدًّا ، قَالَ : یُضْرَبُ بِحِسَابِ مَا أَدَّی۔",,,28885
28886,"حَدَّثَنَا ہُشَیْمٌ ، وَعَبْدُ الرَّحِیمِ ، عَن مُجَالِدٍ ، عَنْ عَامِرٍ ، قَالَ : لاَ امْتِحَانَ فِی حَدٍّ۔",,,28886
28887,"حَدَّثَنَا وَکِیعٌ ، عَن عِمْرَانَ بْنِ حُدَیْرٍ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ : الْمِحْنَۃُ فِی الضِّنَّۃ أَنْ تُوعِدہ ، وَتُجْلَبَ عَلَیْہِ ، وَإِنْ ضَرَبْتُہُ سَوْطًا وَاحِدًا ، فَلَیْسَ اعْتِرَافُہُ بِشَیْئٍ۔",,,28887
28888,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سَعِیدِ بْنِ زَیْدٍ ، عَن وَاصِلٍ مَوْلَی أَبِی عُیَیْنَۃَ ، عَنْ أَبِی عُیَیْنَۃَ بْنِ الْمُہَلَّبِ ، قَالَ : سَمِعْتُ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ ، یَقُولُ : مَنْ أَقَرَّ بَعْدَ مَا ضُرِبَ سَوْطًا وَاحِدًا ، فَہُوَ کَذَّابٌ۔",,,28888
28889,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، وَالْحَکَمِ ، قَالاَ : الْمِحْنَۃُ بِدْعَۃٌ۔",,,28889
28890,"حَدَّثَنَا وَکِیعٌ، عَنِ الْمَسْعُودِیِّ، عَنِ الْقَاسِمِ، عَنْ شُرَیْحٍ، قَالَ: الْقَیْدُ کُرْہٌ، وَالسِّجْنُ کَرْہٌ، وَالْوَعِیدُ کَرْہٌ۔",,,28890
28891,"حَدَّثَنَا حَفْصٌ ، عَنِ الشَّیْبَانِیِّ ، عَنْ عَلِیِّ بْنِ حَنْظَلَۃَ ، عَنْ أَبِیہِ ، قَالَ : قَالَ عُمَرُ : لَیْسَ الرَّجُلُ بِأَمِینٍ عَلَی نَفْسِہِ إِنْ أَجَعْتَہُ ، أَوْ أَخَفْتَہُ ، أَوْ حَبَسْتَہُ۔",,,28891
28892,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قَالَ ابْنُ شِہَابٍ فِی رَجُلٍ اعْتَرَفَ بَعْدَ مَا جُلِدَ ، قَالَ : لَیْسَ عَلَیْہِ حَدٌّ۔",,,28892
28893,"حَدَّثَنَا وَکِیعٌ ، عَن مُبَارَکٍ ، عَنِ الْحَسَنِ ، قَالَ : قَالَ عُمَرُ : رَوِّعَ السَّارِقَ وَلاَ تُرَاعِہِ۔",,,28893
28894,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا ابْنُ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، عَن طَارِقٍ الشَّامِیِّ ؛ أَنَّہُ أُتِیَ بِرَجُلٍ أُخِذَ فِی سَرِقَۃٍ فَضَرَبَہُ فَأَقَرَّ ، فَبَعَثَ إِلَی ابْنِ عُمَرَ یَسْأَلُہُ عَنْ ذَلِکَ ؟ فَقَالَ لَہُ ابْنُ عُمَرَ : لاَ تَقْطَعْہُ ، فَإِنَّہُ إِنَّمَا أَقَرَّ بَعْدَ ضَرْبِکَ إِیَّاہُ۔",,,28894
28895,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : سَأَلْتُہُ عَنِ الرَّجُلِ یَقُولُ لاِمْرَأَتِہِ : لَمْ أَجِدْکِ عَذْرَائَ ؟ قَالَ : لَیْسَ عَلَیْہِ شَیْئٌ ، إِنَّ الْعُذْرَۃَ تَذْہَبُ مِنَ الْوَثْبَۃِ ، وَالْمَرَضِ ، وَطُولِ التَّعَنیسِ۔",,,28895
28896,"حَدَّثَنَا عَبْدُ الرَّزَّاقِ، عَنْ مَعْمَرٍ، عَنِ الْحَکَمِ بْنِ أَبَانَ ، عَن سَالِمٍ ، قَالَ: سَأَلْتُہُ عَنِ الرَّجُلِ یَقُولُ لاِمْرَأَتِہِ لَمْ أَجِدْکِ عَذْرَائَ ؟ قَالَ : لاَ بَأْسَ ، الْعُذْرَۃُ تُذْہِبُہَا الْوَثْبَۃُ وَالشَّیْئُ۔",,,28896
28897,"حَدَّثَنَا حَفْصٌ ، عَنْ الشَّیْبَانِیُّ ، عَنِ الشَّعْبِیِّ ؛ فِی الرَّجُلِ یَتَزَوَّجُ الْبِکْرَ ، ثُمَّ یَقُولُ : لَمْ أَجِدْکِ عَذْرَائَ ، قَالَ : لَیْسَ بِشَیْئٍ۔",,,28897
28898,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَن یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : کَانَ لاَ یَرَی ذَلِکَ قَذْفًا۔",,,28898
28899,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ؛ فِی الرَّجُلِ یَتَزَوَّجُ الْمَرْأَۃَ ، فَیَقُولُ : لَمْ أَجِدْہَا عَذْرَائَ ، قَالَ : لاَ حَدَّ عَلَیْہِ۔",,,28899
28900,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لَیْسَ بِقَذْفٍ۔",,,28900
28901,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ قَتَادَۃَ ، عَن سُلَیْمَانَ بْنِ یَسَارٍ ، وَعَطَائٍ ، وَالْحَسَنِ ؛ فِی الرَّجُلِ یَقُولُ لاِمْرَأَتِہِ لَمْ أَجِدْکِ عَذْرَائَ ؟ قَالُوا : إِنَّ الْعُذْرَۃَ تُذْہِبُہَا النَّیْطَۃُ ، وَاللِّیطَۃُ۔",,,28901
28902,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ أَبِی حَنِیفَۃَ ، عَنِ الْہَیْثَمِ ، عَمَّنْ أَخْبَرَہُ ، عَنْ عَائِشَۃَ ، قَالَتْ : لَیْسَ عَلَیْہِ شَیْئٌ ، إِنَّ الْعُذْرَۃَ تَذْہَبُ مِنَ الْوَثْبَۃِ ، وَالْحَیْضَۃِ ، وَالْوُضُوئِ۔",,,28902
28903,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ فِی الرَّجُلِ یَقُولُ لامْرَأَتِہِ : لَمْ أَجِدْکِ عَذْرَائَ ، قَالَ سَعِیدٌ : حَدٌّ ، وَلاَ مُلاَعَنۃَ۔",,,28903
28904,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنِ ابْنِ لَہِیعَۃَ ، عَنْ عَبْدِ اللہِ بْنِ ہُبَیْرَۃَ ، عَنْ رَجُلٍ قَدْ سَمَّاہُ ؛أَنَّ زَیْدَ بْنَ ثَابِتٍ، وَابْنَ عُمَرَ سُئِلاَ عَنْ رَجُلٍ قَالَ لاِمْرَأَتِہِ : لَمْ أَجِدْکِ عَذْرَائَ ؟ قَالاَ : إِنْ تَبَرَّأَ جُلِدَ الْحَدَّ ، وَکَانَتِ امْرَأَتَہُ ، وَإِنْ لَمْ یَتَبَرَّأْ لاَعَنَہَا وَفُرِّقَ بَیْنَہُمَا۔",,,28904
28905,"حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : إِذَا دَخَلَ الرَّجُلُ بِالْمَرْأَۃِ ، ثُمَّ قَالَ : لَمْ أَجِدْہَا عَذْرَائَ ، قَالَ : یُضْرَبُ الْحَدُّ ، وَلاَ یُلاَعَن ، لأَنَّہُ لَمْ یَقُلْ : إِنِّی رَأَیْتُک تَزْنِینَ۔",,,28905
28906,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ ابْنِ شُبْرُمَۃَ ، قَالَ : کُنْتُ عَندَ الشَّعْبِیِّ ، فَأُتِیَ بِرَجُلٍ قَدْ أُخِذَ فِی حَدٍّ ، أَوْ قَذْفٍ، فَضَرَبَہُ الْحَدَّ وَعَلَیْہِ قَمِیصٌ ، مَا أَدْرِی مَا تَحْتَہُ۔",,,28906
28907,"حَدَّثَنَا شَرِیکٌ ، عَنْ لَیْثٍ ، عَن مُجَاہِدٍ (ح) وَعَنِ الْمُغِیرَۃِ ، عَنْ إِبْرَاہِیمَ ، قَالاَ : یُضْرَبُ الْقَاذِفُ وَعَلَیْہِ ثِیَابُہُ۔",,,28907
28908,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ إِسْمَاعِیلَ بْنِ أُمَیَّۃَ ، عَنْ سَعْدِ بْنِ إِبْرَاہِیمَ ، عَن أَبِیہِ ، قَالَ : إِنِّی لأَذْکُرُ مَسْکَ شَاۃٍ أَمَرَتْ بِہَا أمی فَذُبِحَتْ ، حِینَ ضَرَبَ عُمَرُ أَبَا بَکْرَۃَ ، فَجَعَلَ مَسْکَہَا عَلَی ظَہْرِہِ مِنْ شِدَّۃِ الضَّرْبِ۔",,,28908
28909,"حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ مُطَرِّفٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : یُضْرَبُ الْقَاذِفُ وَعَلَیْہِ ثِیَابُہُ ، إِلاَّ أَنْ یَکُونَ عَلَیْہِ فَرْوٌ ، أَوْ قَبَائٌ مَحْشُوٌّ ، حَتَّی یَجِدَ مَسَّ الضَّرْبِ۔",,,28909
28910,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الْحَجَّاجِ ، عَنِ الْوَلِیدِ بْنِ أَبِی مَالِکٍ ؛ أَنَّ أَبَا عُبَیْدَۃَ بْنَ الْجَرَّاحِ أُتِیَ بِرَجُلٍ فِی حَدٍ ، فَذَہَبَ الرَّجُلُ یَنْزِعُ قَمِیصَہُ ، وَقَالَ : مَا یَنْبَغِی لِجَسَدِی ہَذَا الْمُذْنِبِ أَنْ یُضْرَبَ وَعَلَیْہِ الْقَمِیصُ ، قَالَ : فَقَالَ أَبُو عُبَیْدَۃَ : لاَ تَدَعُوہُ یَنْزِعُ قَمِیصَہُ ، فَضَرَبَہُ عَلَیْہِ۔",,,28910
28911,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَن حَمَّادٍ ، قَالَ : یُضْرَبُ الْقَاذِفُ وَعَلَیْہِ ثِیَابُہُ۔",,,28911
28912,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ إِسْمَاعِیلَ ، عَنِ الْحَسَنِ ، قَالَ : إِذَا قَذَفَ الرَّجُلُ فِی الشِّتَائِ لَمْ یُلْبَسْ ثِیَابَ الصَّیْفِ ، وَلَکِنْ یُضْرَبُ فِی ثِیَابِہِ الَّتِی قَذَفَ فِیہَا ، وَإِذَا قَذَفَ فِی الصَّیْفِ لَمْ یُلْبَسْ ثِیَابَ الشِّتَائِ ، یُضْرَبُ فِیمَا قَذَفَ فِیہِ۔",,,28912
28913,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ سَعْدِ بْنِ إِبْرَاہِیمَ ، عَن أَبِیہِ ، عَن أُمِّہِ ، قَالَتْ : إِنِّی لأَذْکُرُ مَسْکَ شَاۃٍ ، ثُمَّ ذَکَرَ نَحْوًا مِنْ حَدِیثِ ابْنِ عُلَیَّۃَ۔",,,28913
28914,"حَدَّثَنَا شَرِیکٌ ، عَن سَلَمَۃَ بْنِ الْمَجْنُونِ ، قَالَ : قُلْتُ لِرَجُلٍ : یَا فَاعِلٌ بِأُمِّہِ ، قَالَ : فَقَدَّمُونِی إِلَی أَبِی ہُرَیْرَۃَ فَضَرَبَنِی۔ قَالَ : وَمَا أَوْجَعَنی إِلاَّ سَوْطٌ وَقَعَ عَلَی سَوْطٍ۔",,,28914
28915,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَی ؛ أَنَّ امْرَأَۃً مِنَ الصَّبیْرِیِّینَ زَنَتْ ، فَأَلْبَسَہَا أَہْلُہَا دِرْعًا مِنْ حَدِیدٍ ، فَرُفِعَتْ إِلَی عَلِیٍّ فَضَرَبَہَا وَہُوَ عَلَیْہَا۔,,,28915
28916,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ أَشْعَثَ بْنِ سُوَّارٍ ، عَنْ أَبِیہِ ، قَالَ : شَہِدْتُ أَبَا بَرْزَۃَ یَضْرِبُ أَمَۃً لَہُ فَجَرَتْ ، وَعَلَیْہَا مِلْحَفَۃٌ۔",,,28916
28917,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَن حَمَّادٍ ، قَالَ : أَمَّا الزَّانِی فَیُخْلَعُ عَنْہُ ثِیَابُہُ ، وَتَلا : {وَلاَ تَأْخُذْکُمْ بِہِمَا رَأْفَۃٌ فِی دِینِ اللہِ} ، قُلْتُ : ہَذَا فِی الْحُکْمِ ، قَالَ : ہَذَا فِی الْحُکْمِ وَالْجَلْدِ۔",,,28917
28918,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ الْحَجَّاجِ ، عَنِ الْوَلِیدِ بْنِ أَبِی مَالِکٍ ، قَالَ : أُتِیَ أَبُو عُبَیْدَۃَ بِرَجُلٍ قَدْ زَنَی ، فَقَالَ : إِنَّ ہَذَا الْجَسَدَ الْمُذْنِبَ لأَہْلٌ أَنْ یُضْرَبَ ، قَالَ : فَنَزَعَ عَنْہُ قَبَائَہُ ، فَأَبَی أَنْ یَضْرِبَہُ ، وَرَدَّ عَلَیْہِ قَبَائَہُ۔",,,28918
28919,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنِ الْقَاسِمِ ، عَنْ أَبِیہِ ، قَالَ : أُتِیَ عَبْدُ اللہِ بِرَجُلٍ وُجِدَ مَعَ امْرَأَۃٍ فِی ثَوْبٍ ، قَالَ : فَضَرَبَہُمَا أَرْبَعِینَ أَرْبَعِینَ ، قَالَ : فَخَرَجُوا إِلَی عُمَرَ ، فَاسْتَعْدَوْا عَلَیْہِ ، فَلَقِیَ عُمَرُ عَبْدَ اللہِ ، فَقَالَ : قَوْمٌ اسْتَعْدَوْا عَلَیْک فِی کَذَا وَکَذَا ، قَالَ : فَأَخْبَرَہُ بِالْقِصَّۃِ ، فَقَالَ لِعَبْدِ اللہِ : کَذَلِکَ تَرَی ؟ قَالَ : نَعَمْ، قَالُوا : جِئْنَا نَسْتَعْدِیہِ ، فَإِذَا ہُوَ یَسْتَفْتِیہِ۔",,,28919
28920,"حَدَّثَنَا حَاتِمٌ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ عَلِیٍّ ، قَالَ : إِذَا وُجِدَ الرَّجُلُ مَعَ الْمَرْأَۃِ ، جُلِدَ کُلُّ وَاحِدٍ مِنْہُمَا مِئَۃ۔",,,28920
28921,حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَن سَلَمَۃَ ، عَنِ الْحَسَنِ الْعُرَنِیِّ ، عَنْ عبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ؛ أَنَّ رَجُلاً کَانَ لَہُ عَسِیفٌ ، فَوَجَدَہُ مَعَ امْرَأَتِہِ فِی لِحَافٍ ، فَضَرَبَہُ عُمَرُ أَرْبَعِینَ۔,,,28921
28922,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَن سُوَیْد بْنِ نَجِیحٍ ، عَن ظَبْیَانَ بْنِ عُمَارَۃَ ، قَالَ : أُتِیَ عَلِیٌّ بِرَجُلٍ وَامْرَأَۃٍ ، وَقَالَ رَجُلٌ : إِنَّا وَجَدْنَاہُمَا فِی لِحَافٍ وَاحِدٍ ، وَعَندَہُمَا خَمْرٌ وَرَیْحَانٌ ، قَالَ : فَقَالَ عَلِیٌّ : مُرْیِبَّانِ خَبِیثَانِ ، فَجَلَدَہُمَا ، وَلَمْ یَذْکُرْ حَدًّا۔",,,28922
28923,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، عَنِ الْحَسَنِ ، قَالَ : تُجَزُّ رُؤُوسُہُمَا وَیُجْلَدَانِ ، فَذَکَرَ جَلْدًا لاَ أَحْفَظُہُ۔",,,28923
28924,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ أَبِی بِشْرٍ ، عَنْ أَبِی رَوْحٍ ؛ أَنَّ امْرَأَۃً تَشَبَّہَتْ بِأَمَۃٍ لِرَجُلٍ ، وَذَلِکَ لَیْلاً ، فَوَاقَعَہَا وَہُوَ یَرَی أَنَّہَا أَمَتُہُ ، قَالَ : فَرُفِعَ ذَلِکَ إِلَی عُمَرَ ، قَالَ : فَأَرْسَلَ إِلَی عَلِیٍّ ، فَقَالَ : اضْرِبِ الرَّجُلَ حَدًّا فِی السِّرِّ ، وَاضْرِبِ الْمَرْأَۃَ فِی الْعَلاَنِیَۃِ۔",,,28924
28925,"حَدَّثَنَا غَسَّانُ بْنُ مُضَرَ ، عَنْ سَعِیدِ بْنِ یَزِیدَ ، عَنْ أَبِی نَضْرَۃَ ، قَالَ : سُئِلَ ابْنُ عَبَّاسٍ : مَا حَدُّ اللُّوطِیِّ؟ قَالَ : یُنْظَرُ إلی أَعْلَی بِنَائٍ فِی الْقَرْیَۃِ فَیُرْمَی منہ مُنَکَّسًا ، ثُمَّ یُتْبَعُ الْحِجَارَۃُ۔",,,28925
28926,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی ابْنُ خُثَیْمٍ ، عَن مُجَاہِدٍ ، وَسَعِیدِ بْنِ جُبَیْرٍ ؛ أَنَّہُمَا سَمِعَا ابْنَ عَبَّاسٍ یَقُولُ فِی الرَّجُلِ یُوجَدُ ، أَوْ یُؤْخَذُ عَلَی اللُّوطِیَّۃِ : أَنَّہُ یُرْجَمُ۔",,,28926
28927,حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْقَاسِمِ بْنِ الْوَلِیدِ ، عَنْ یَزِیدَ بْنِ قَیْسٍ ؛ أَنَّ عَلِیًّا رَجَمَ لُوطِیًّا۔,,,28927
28928,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ فِی الرَّجُلِ یَأْتِی الرَّجُلَ ، قَالَ : سُنَّتُہُ سُنَّۃُ الْمَرْأَۃِ۔",,,28928
28929,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : یُرْجَمُ أُحْصِنَ ، أَوْ لَمْ یُحْصَنْ۔",,,28929
28930,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَن حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : حدُّ اللُّوطِیِّ حَدُّ الزَّانِی ، إِنْ کَانَ مُحْصَنًا فَالرَّجْمُ ، وَإِنْ کَانَ بِکْرًا فَالْجَلْدُ۔",,,28930
28931,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : اللُّوطِیُّ بِمَنْزِلَۃِ الزَّانِی۔",,,28931
28932,"حَدَّثَنَا یَزِیدُ ، قَالَ : أَخْبَرَنَی سَعِیدٌ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ (ح) وَعَنْ أبِی مَعْشَرٍ ، عَنْ إِبْرَاہِیمَ ، قَالاَ : اللُّوطِیُّ بِمَنْزِلَۃِ الزَّانِی۔",,,28932
28933,"حَدَّثَنَا یَزِیدُ ، قَالَ : أَخْبَرَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ حَمَّادِ بْنِ أَبِی سُلَیْمَانَ ، عَنْ إِبْرَاہِیمَ ؛ فِی اللُّوطِیِّ ، قَالَ : لَوْ کَانَ أَحَدٌ یُرْجَمُ مَرَّتَیْنِ رُجِمَ ہَذَا۔",,,28933
28934,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : یُرْجَمُ اللُّوطِیُّ إِذَا کَانَ مُحْصَنًا ، وَإِنْ کَانَ بِکْرًا جُلِدَ مِئَۃً۔",,,28934
28935,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَن مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ (ح) وَعَنْ سُفْیَانَ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الْحَکَمِ ؛ فِی اللُّوطِیِّ : یُضْرَبُ دُونَ الْحَدِّ۔",,,28935
28936,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَن عُبَیْدِ اللہِ بْنِ عَبْدِ اللہِ بْنِ مَعْمَرٍ ، قَالَ : عَلَیْہِ الرَّجْمُ ، قِتْلَہُ قَوْمِ لُوطٍ۔",,,28936
28937,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ جَابِرِ بْنِ زَیْدٍ ، قَالَ : حُرْمَۃُ الدُّبُرِ أَعْظَمُ مِنْ حُرْمَۃِ کَذَا۔ قَالَ قَتَادَۃُ : نَحْنُ نَحْمِلُہُ عَلَی الرَّجْمِ۔",,,28937
28938,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ قَیْسٍ ، عَنْ أَبِی حَصَیْنٍ ؛ أَنَّ عُثْمَانَ أَشْرَفَ عَلَی النَّاسِ یَوْمَ الدَّارِ ، فَقَالَ : أَمَا عَلِمْتُمْ أَنَّہُ لاَ یَحِلُّ دَمُ امْرِئٍ مُسْلِمٍ إِلاَّ بِأَرْبَعَۃٍ : رَجُلٌ عَمِلَ عَمَلَ قَوْمِ لُوطٍ۔",,,28938
28939,"حَدَّثَنَا غَسَّانُ بْنُ مُضَرَ، عَنْ سَعِیدِ بْنِ یَزِیدَ، عَن سِنَانِ بْنِ سَلَمَۃَ؛ أَنَّہُ قَالَ لَہُ: نِعْمَ الرَّجُلُ إِنْ کَانَ لُوطِیًّا۔",,,28939
28940,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَن طَاوُوسٍ ؛ أَنَّہُ کَانَ یَقُولُ : لَیْسَ عَلَیْہِ حَدٌّ ، إِلاَّ أَنْ یَقُولَ : إِنَکَ تَعْمَلُ بِعَمَلِ قَوْمِ لُوطٍ۔",,,28940
28941,حَدَّثَنَا یَحْیَی بْنُ وَاضِحٍ ، عَن عُبَیْدِ بْنِ سُلَیْمَانَ ، عَنِ الضَّحَّاکِ ؛ بِنَحْوٍ مِنْ قَوْلِ طَاوُوسٍ۔,,,28941
28942,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی خَالِدٍ الْوَاسِطِیِّ ، عَنِ الشَّعْبِیِّ ، قَالَ : لاَ أَعْلَمُ عَلَیْہِ حَدًّا۔",,,28942
28943,"حَدَّثَنَا عَبْدُ الْوَہَّابِ ، عَنْ سَعِیدِ بْنِ أَبِی عَرُوبَۃَ ، عَن فَرْقَدٍ السَّبَخِیِّ ؛ أَنَّ رَجُلاً ، قَالَ لِرَجُلٍ : یَا لُوطِیُّ ، فَسَأَلَ الْحَسَنَ، وَمُحَمَّدًا؟ فَقَالاَ: لَیْسَ عَلَیْہِ حَدٌّ، وَقَالَ الْحَسَنُ: إِلاَّ أَنْ یَقُولَ: إِنَّک تَعْمَلُ بِعَمَلِ قَوْمِ لُوطٍ۔",,,28943
28944,"حَدَّثَنَا مُحَمَّدُ بْنُ یَزِیدَ ، عَنْ أَبِی الْعَلاَئِ ، عَنْ قَتَادَۃَ ، قَالَ : لَیْسَ علَیْہِ شَیْئٌ۔\n\nوَقَالَ أَبُو ہَاشِمٍ : إِذَا قَالَ : إِنَّک تَنْکِحُ فُلاَنًا فِی دُبُرِہِ ، قَالَ : اجْلِدْہُ الْحَدَّ۔",,,28944
28945,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی ہِلاَلٍ ، عَنْ قَتَادَۃَ ، قَالَ : قَالَ رَجُلٌ لأَبِی الأَسْوَدِ : یَا لُوطِیُّ ، فَقَالَ : یَرْحَمُ اللَّہُ لُوطًا ، وَلَمْ یَرَہُ شَیْئًا۔",,,28945
28946,"حَدَّثَنَا وَکِیعٌ ، عَن حَسَنٍ ، عَن مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : یُجْلَدُ مَنْ فَعَلَہُ وَمَنْ رُمِی بِہِ۔",,,28946
28947,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : مَنْ قَذَفَ بِہِ إِنْسَانًا جُلِدَ ، وَیُبْتَغی فِیہِ مِنَ الشُّہُودِ ، کَمَا یُبْتَغی فِی شُہُودِ الزِّنَی۔",,,28947
28948,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : إِذَا قَذَفَ الرَّجُلُ الرَّجُلَ بِعَمَلِ قَوْمِ لُوطٍ ، أَوْ بِالْبَہِیمَۃِ جُلِدَ۔",,,28948
28949,"حَدَّثَنَا غُنْدَرٌ، عَنْ شُعْبَۃَ ، عَنْ عَبْدِ الْخَالِق ، عَنْ حَمَّادٍ ، قَالَ : عَلَیْہِ الْحَدّ۔",,,28949
28950,"حَدَّثَنَا وَکِیعٌ ، عَنْ سَعِیدِ بْنِ حَسَّانَ ، عَنْ عَبْدِ الْحَمِیدِ بْنِ جُبَیْرٍ ؛ أَنَّ رَجُلاً قَالَ لِرَجُلٍ : یَا لُوطِیُّ ، فَرُفِعَ إِلَی عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، فَجَعَلَ یَقُولُ : یَا لُوطِیُّ ، یَا مُحَمَّدِیُّ ، قَالَ : فَضَرَبَہُ بِضْعَۃَ عَشَرَ سَوْطًا ، ثُمَّ أَخْرَجَہُ مِنَ الْغَدِ ، فَأَکْمَلَ لَہُ الْحَدَّ۔",,,28950
28951,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی ہِلاَلٍ ، عَنِ الْحَسَنِ ، وَعِکْرِمَۃَ ؛ قَالَ الْحَسَنُ : لَیْسَ عَلَیْہِ حَدٌّ ، وَقَالَ عِکْرِمَۃُ : عَلَیْہِ الْحَدُّ۔",,,28951
28952,"حَدَّثَنَا عَبْدَۃُ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، قَالَ : إِذَا قَذَفَ الرَّجُلُ الرَّجُلَ أُقِیمَ عَلَیْہِ الْحَدُّ ، فَإِنْ أَعَادَ عَلَیْہِ الْقَذْفَ فَلاَ حَدَّ عَلَیْہِ ، إِلاَّ أَنْ یُحْدِث لَہُ قَذْفًا آخَرُ۔",,,28952
28953,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَن عُیَیْنَۃَ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِیہِ ؛ أَنَّ عُمَرَ لَمَّا أَمَرَ بِأَبِی بَکْرَۃَ وَأَصْحَابِہِ فَجُلِدُوا ، فَعَادَ أَبُو بَکْرَۃَ ، فَقَالَ : زَنَی الْمُغِیرَۃُ ، فَأَرَادَ عُمَرُ أَنْ یَجْلِدَہُ ، فَقَالَ لَہُ عَلِیٌّ : عَلَی مَا تَجْلِدُہُ ؟ وَہَلْ قَالَ إِلاَّ مَا قَدْ قَالَ ، فَتَرَکَہُ۔",,,28953
28954,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ حَجَّاجٍ ، عَنْ فُضَیْلٍ ، عَنْ إِبْرَاہِیمَ ؛فِی رَجُلٍ قَذَفَ رَجُلاً فَجُلِدَ ، ثُمَّ قَذَفَہُ أیضًا ، فَقَالَ : لاَ یُجْلَد۔",,,28954
28955,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ بَعْضِ أَصْحَابِہِ ، عَنِ الشَّعْبِیِّ ، قَالَ : لَیْسَ عَلَی قَاذِفٍ یَمِینٌ۔",,,28955
28956,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی ذِئْبٍ ؛ أَنَّ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ أَحَلَّفَ رَجُلاً قَذَفَ۔,,,28956
28957,"حَدَّثَنَا عَبْدَۃُ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، قَالَ : سُئِلَ الْقَاسِمُ عَنْ رَجُلٍ یَقُولُ لِرَجُلٍ : یَا ابْنَ الْخَیَّاطِ ، أَوْ یَا ابْنَ الْحَجَّامِ ، أَوْ یَا ابْنَ الْجَزَّارِ ، وَلَیْسَ أَبُوہُ کَذَلِکَ ؟ فَقَالَ الْقَاسِمُ : قَدْ أَدْرَکْنَاہ وَمَا تُقَامُ الْحُدُودُ إِلاَّ فِی الْقَذْفِ الْبَیِّنِ ، أَوْ فِی النَّفْیِ الْبَیِّنِ۔",,,28957
28958,"حَدَّثَنَا ابْنُ الْمُبَارَک ، وَعَبْدُ الرَّزَّاقِ ، عَنْ مَعْمَرٍ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : لاَ حَدَّ إِلاَّ عَلَی مَنْ نَصَبَ الْحَدَّ نَصْبًا۔",,,28958
28959,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ إِسْمَاعِیلَ بْنِ سَالِمٍ ؛ أَنَّ رَجُلَیْنِ کَانَ بَیْنَہُمَا لِحَائٌ ، فَقَالَ أَحَدُہُمَا للآخَرِ : مَا وُلِدَ بِالْکُوفَۃِ وَلَدُ زِنَی إِلاَّ فِی الأَخرِ شَبَہٌ مِنْہُ ، وَقَالَ الآخَرُ : لَوْ کُشِفَ مَا عَندَ الأَخرِ مَا بَقِیَتْ بِالْکُوفَۃِ فَاجِرَۃٌ إِلاَّ عَرَفَتْہُ ، فَسُئِلَ عَن ذَلِکَ الشَّعْبِیُّ ؟ فَقَالَ : لَیْسَ عَلَی وَاحِدٍ مِنْہُمَا حَدٌّ۔",,,28959
28960,حَدَّثَنَا أَبُو دَاوُدَ ، عَن زَمْعَۃَ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ لاَ یَرَی فِی التَّعْرِیضِ حَدًّا۔,,,28960
28961,"حَدَّثَنَا ہُشَیْمٌ ، عَن مَنْصُورٍ ، عَنِ الْحَسَنِ ، قَالَ : لَیْسَ عَلَیْہِ حَدٌّ حَتَّی یَقُولَ : یَا زَانٍ ، یَا زَانِیَۃ ، أَوْ یَا ابْنَ الزَّانِیَۃِ۔",,,28961
28962,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَن حَمَّادٍ ؛ فِی الرَّجُلِ یَقُولُ لِلرَّجُلِ : إِنَّ فِی ظَہْرِکَ حَدُّ الزِّنَی ، قَالَ : إِنْ شَائَ قَالَ : إِنَّمَا قُلْتُ : إِنَّ فِی ظَہْرِکَ لَمَوْضِعًا ، قَالَ : لَیْسَ عَلَیْہِ حَدٌّ۔",,,28962
28963,"حَدَّثَنَا غُنْدَرٌ ، عَنْ عَوْفٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُ قَالَ : لاَ یُجْلَد الْحَدَّ إِلاَّ فِی الْقَذْفِ الْمُصَرَّحِ۔",,,28963
28964,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ إِبْرَاہِیم بْنِ عَامِرٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّ رَجُلاً قَالَ لِرَجُلٍ : یَا ابْنَ کِرَاثَۃٍ ، قَالَ : یُضْرَبُ الْحَدَّ۔ (عبدالرزاق 13709)",,,28964
28965,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ أَبِی الرِّجَالِ ، عَن أُمِّہِ عَمْرَۃَ ، قَالَتْ : اسْتَبَّ رَجُلاَنِ ، فَقَالَ أَحَدُہُمَا : مَا أُمِّی بِزَانِیَۃٍ ، وَمَا أَبِی بِزَانٍ ، فَشَاوَرَ عُمَرُ الْقَوْمَ ، فَقَالُوا : مَدَحَ أَبَاہُ وَأُمَّہُ ، فَقَالَ : لَقَدْ کَانَ لَہُمَا مِنَ الْمَدْحِ غَیْرُ ہَذَا ، فَضَرَبَہُ۔",,,28965
28966,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنِ الْجَلْدِ بْنِ أَیُّوبَ ، عَن مُعَاوِیَۃَ بْنِ قُرَّۃَ ؛ أَنَّ رَجُلاً قَالَ لِرَجُلٍ : یَا ابْنَ شَامَّۃِ الْوَذْرِ ، فَاسْتَعْدَی عَلَیْہِ عُثْمَانَ بْنَ عَفَّانَ ، فَقَالَ : إِنَّمَا عَنیْتُ کَذَا وَکَذَا ، فَأَمَرَ بِہِ عُثْمَانُ فَجُلِدَ الْحَدَّ۔",,,28966
28967,"حدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : فِی التَّعْرِیضِ عُقُوبَۃٌ۔",,,28967
28968,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، قَالَ : فِیہِ الْحَدُّ۔",,,28968
28969,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَاصِمٍ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّ سَمُرَۃَ قَالَ : مَنْ عَرَّضَ عَرَّضْنَا لَہُ۔",,,28969
28970,حَدَّثَنَا مُعَاذٌ ، عَنْ عَوْفٍ ، عَنْ أَبِی رَجَائٍ ؛ أَنَّ عُمَرَ ، وَعُثْمَانَ کَانَا یُعَاقِبَانِ فِی الْہِجَائِ۔,,,28970
28971,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ أَنَّہُ کَانَ یَرَی الضَّرْبَ فِی التَّعْرِیضِ۔,,,28971
28972,حَدَّثَنَا أَبُو عَاصِمٍ ، عَنِ الأَوْزَاعِیِّ ، عَنِ الزُّہْرِیِّ ؛ أَنَّہُ کَانَ یَجْلِدُ الْحَدَّ فِی التَّعْرِیضِ۔,,,28972
28973,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَن سُلَیْمَانَ بْنِ یَسَارٍ ، عَنِ ابْنِ أَبِی رَبِیعَۃَ ، قَالَ : دَعَانَا عُمَرُ فِی فِتْیَانٍ مِنْ فِتْیَانِ قُرَیْشٍ ، فِی إِمَائٍ زَنَیْنَ مِنْ رَقِیقِ الإِمَارَۃِ ، فَضَرَبْنَاہُنَّ خَمْسِینَ خَمْسِینَ۔",,,28973
28974,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن ہَمَّامٍ ، عَنْ عَمْرِو بْنِ شُرَحْبِیلَ ،قَالَ : جَائَ مَعْقِلٌ الْمُزَنِیُّ إِلَی عَبْدِ اللہِ ، فَقَالَ : إِنَّ جَارِیَتِی زَنَتْ ، فَقَالَ : اجْلِدْہَا خَمْسِینَ۔",,,28974
28975,"حَدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَن یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : إِذَا اعْتَرَفَ الْعَبْدُ بِالزِّنَی ، جَلَدَہُ سَیِّدُہُ خَمْسِینَ سَوْطًا۔",,,28975
28976,"حَدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَن یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : إِذَا اعْتَرَفَ الْعَبْدُ بِشُرْبِ الْخَمْرِ ، جَلَدَہُ سَیِّدُہُ أَرْبَعِینَ سَوْطًا۔",,,28976
28977,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ الْقَطَّانُ ، عَن مَالِکِ بْنِ أَنَسٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : بَلَغَنِی عَنْ عُمَرَ ، وَعُثْمَانَ ، وَابْنِ عُمَرَ ؛ أَنَّہُمْ کَانُوا یَضْرِبُونَ الْعَبْدَ فِی الْخَمْرِ ثَمَانِینَ۔",,,28977
28978,"حَدَّثَنَا عَبْدُ اللہِ بْنُ مُبَارَکٍ ، عَنْ سَعِیدِ بْنِ أَبِی أَیُّوبَ ، عَن مَعْرُوفِ بْنِ سُوَیْد ؛ أَنَّ قَوْمًا کَانُوا یَسْرِقُونَ رَقِیقَ النَّاسِ بِأَفْرِیقِیَّۃَ ، فَقَالَ عُلِیُّ بْنُ رَبَاحٍ : لَیْسَ عَلَیْہِمْ قَطْعٌ ، قَدْ کَانَ ہَذَا عَلَی عَہْدِ عُمَرَ بْنِ الْخَطَّابِ ، فَلَمْ یَرَ عَلَیْہِمْ قَطْعًا ، وَقَالَ: ہَؤُلاَئِ خَلاَّبُونَ۔",,,28978
28979,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ، قَالَ: مَنْ سَرَقَ صغیرًا قُطِعَ۔",,,28979
28980,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی، عَنِ ابْنِ أَبِی ذِئْبٍ، عَنِ الزُّہْرِیِّ؛ فِی الَّذِی یَسْرِقُ الصِّبْیَانَ وَالأَعَاجِمَ: تُقْطَعُ یَدُہُ۔",,,28980
28981,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی مَعْنٌ ، أَوْ مَعْمَرٌ ، عَنْ ابْن شِہَابٍ ، قَالَ : سَأَلْتُہُ عَنْ رَجُلٍ سَرَقَ عَبْدًا أَعْجَمِیًا ؟ قَالَ : تُقْطَعُ یَدُہُ۔",,,28981
28982,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ، عَنِ ابْنِ جُرَیْجٍ، قَالَ: أُخْبِرْتُ أَنَّ عُمَرَ بْنَ الْخَطَّابِ قَطَعَ رَجُلاً فِی غُلاَمٍ سَرَقَہُ۔",,,28982
28983,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ الْحَجَّاجِ ، عَنْ حُصَیْنٍ ، عَنِ الشَّعْبِیِّ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : فِی قَلِیلِ الْخَمْرِ وَکَثِیرہ ثَمَانُون۔",,,28983
28984,حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ، عَنْ عَمْرٍو، عَنِ الْحَسَنِ؛ فِی الْخَمْرِ قَلِیلِہِ وَکَثِیرِہِ، وَإِنْ حُسْوَۃً ، فِیہَا الْحَدُّ۔,,,28984
28985,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ مُحَمَّدِ بْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : مَنْ شَرِبَ مِنَ الْخَمْرَ قَلِیلاً، أَوْ کَثِیرًا ضُرِبَ حَدًّا۔",,,28985
28986,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قَالَ عَطَائٌ : إِنْ شَرِبَ رَجُلٌ مِنَ الْمُسْکِر مَا بَلَغَ أَنْ یُسْکِرَ ، فَقَدْ وَجَبَ عَلَیْہِ الْحَدُّ۔",,,28986
28987,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، عَنْ سُفْیَانَ ، عَن حُصَیْنِ بْنِ عَبْدِ الرَّحْمَنِ ، یَرْفَعُہُ إِلَی عُمَرَ ، قَالَ : مَنْ شَرِبَ مِنَ الْخَمْرِ قَلِیلاً ، أَوْ کَثِیرًا ضُرِبَ الْحَدُّ۔",,,28987
28988,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : لَیْسَ فِی شَیْئٍ مِنَ الشَّرَابِ حَدٌّ حَتَّی یُسْکِرَ ، إِلاَّ فِی الْخَمْرِ۔",,,28988
28989,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ رَجُلٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : یُضْرَبُ فِی الْخَمْرِ فِی قَلِیلِہَا وَکَثِیرِہَا۔",,,28989
28990,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ حَجَّاجٍ ، عَنْ حُصَیْنٍ ، عَنِ الشَّعْبِیِّ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : حدُّ النَّبِیذِ ثَمَانُونَ۔",,,28990
28991,"حَدَّثَنَا ابْنُ مُسْہِرٍ، عَنِ الشَّیْبَانِیِّ، عَن حَسَّانَ بْنِ مُخَارِقٍ، قَالَ: بَلَغَنِی أَنَّ رَجُلاً سَایَرَ عُمَرَ بْنَ الْخَطَّابِ فِی سَفَرٍ وَکَانَ صَائِمًا ، فَلَمَّا أَفْطَرَ أَہْوَی إِلَی قِرْبَۃٍ لِعُمَرَ مُعَلَّقَۃٍ فِیہَا نَبِیذٌ قَدْ خَضْخَضَہَا الْبَعِیرُ ، فَشَرِبَ مِنْہَا فَسَکِرَ ، فَضَرَبَہُ عُمَرُ الْحَدَّ ، فَقَالَ لَہُ : إِنَّمَا شَرِبْت مِنْ قِرْبَتِکَ ؟فَقَالَ لَہُ عُمَرُ : إِنَّمَا جَلَدْنَاک لِسُکْرِک۔",,,28991
28992,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ فِی السَّکْرَانِ مِنَ النَّبِیذِ ، قَالَ : یُضْرَبُ ثَمَانِینَ۔",,,28992
28993,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَن عُبَیْدَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالُ : یُضْرَبُ الْحَدُّ فِی النَّبِیذِ۔",,,28993
28994,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَن عُبَیْدَۃَ ، عَنْ أَبِی وَائِلٍ ، قَالَ : لَیْسَ فِیہِ حَدٌّ۔",,,28994
28995,"حَدَّثَنَا ابْنُ نُمَیْرٍ، عَنْ حَجَّاجٍ ، عَنْ أَبِی عَوْنٍ ، عَنْ عَبْدِ اللہِ بْنِ شَدَّادٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: فِی السّکْرِ مِنَ النَّبِیذِ ، ثَمَانُونَ۔",,,28995
28996,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَبِیہِ ، عَن شَقِیقٍ الضَّبِیِّ ، قَالَ : فِیہِ الْحَدُّ ، یُضْرَبُ ثَمَانِینَ۔",,,28996
28997,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَن مُجَالِدٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : کَانَ عَلِیٌّ یَرْزُقُ النَّاسَ الطِّلائَ فِی دِنَانٍ صِغَارٍ ، فَسَکِرَ مِنْہُ رَجُلٌ ، فَجَلَدَہُ عَلِیٌّ ثَمَانِینَ ، قَالَ : فَشَہِدُوا عَندَہُ أَنَّہُ إِنَّمَا سَکِرَ مِنَ الَّذِی رَزَقَہُمْ ، قَالَ : وَلِمَ شَرِبَ مِنْہُ حَتَّی سَکِرَ؟۔",,,28997
28998,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ عَبْدِ اللہِ الدَّانَاجِ ، عَنْ حُضَیْنٍ أَبِی سَاسَانَ ؛ أَنَّہُ رَکِبَ أناسٌ مِنْ أَہْلِ الْکُوفَۃِ إِلَی عُثْمَانَ ، فَأَخْبَرُوہُ بِمَا کَانَ مِنْ أَمْرِ الْوَلِیدِ بْنِ عُقْبَۃَ مِنْ شُرْبِ الْخَمْرِ ، فَکُلِّمَہُ فِی ذَلِکَ عَلِیٌّ ، فَقَالَ عُثْمَانُ : دُونَک ابْنَ عَمِّکَ ، فَأَقِمْ عَلَیْہِ الْحَدَّ ، فَقَالَ عَلِیٌّ : قُمْ یَا حَسَنُ فَاجْلِدْہُ ، فَقَالَ : فِیمَ أَنْتَ مِنْ ہَذَا ؟ َولِّ ہَذَا غَیْرَک ، قَالَ : بَلْ ضَعُفْتَ ، وَوَہَنْتَ وَعَجَزْتَ ، قُمْ یَا عَبْدَ اللہِ بْنَ جَعْفَرٍ ، فَجَعَلَ یَجْلِدُہُ ، وَیَعُدُّ عَلِیٌّ حَتَّی بَلَغَ أَرْبَعِینَ ، فَقَالَ : کُفَّ ، أَوْ أَمْسِکْ ، جَلَدَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَرْبَعِینَ ، وَأَبُو بَکْرٍ أَرْبَعِینَ ، وَکَمَّلَہَا عُمَرُ ثَمَانِینَ ، وَکُلٌّ سُنَّۃٌ۔ (مسلم 1331۔ ابوداؤد 4475)",,,28998
28999,حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ أَنَّ عُمَرَ ضَرَبَ فِی الْخَمْرِ ثَمَانِینَ۔,,,28999
29000,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ، عَنْ عَلِیٍّ ، قَالَ : شَرِبَ قَوْمٌ مِنْ أَہْلِ الشَّامِ الْخَمْرَ ، وَعَلَیْہِمْ یَزِیدُ بْنُ أَبِی سُفْیَانَ ، وَقَالُوا : ہِیَ لَنَا حَلاَلٌ ، وَتَأَوَّلُوا ہَذِہِ الآیَۃَ : {لَیْسَ عَلَی الَّذِینَ آمَنُوا وَعَمِلُوا الصَّالِحَاتِ جُنَاحٌ فِیمَا طَعِمُوا} الآیَۃَ ، قَالَ : فَکَتَبَ فِیہِمْ إِلَی عُمَرَ ، فَکَتَبَ : أَنِ ابْعَثْ بِہِمْ إِلَیَّ قَبْلَ أَنْ یُفْسِدُوا مَنْ قِبَلِکَ ، فَلَمَّا قَدِمُوا عَلَی عُمَرَ ، اسْتَشَارَ فِیہِمُ النَّاسَ ، فَقَالُوا : یَا أَمِیرَ الْمُؤْمِنِینَ ، نَرَی أَنَّہُمْ قَدْ کَذَبُوا عَلَی اللہِ ، وَشَرَعُوا فِی دِینِہِمْ مَا لَمْ یَأْذَنْ بِہِ اللَّہُ ، فَاضْرِبْ رِقَابَہُمْ ، وَعَلِیٌّ سَاکِتٌ ، فَقَالَ : مَا تَقُولُ یَا أَبَا الْحَسَنِ فِیہِمْ ؟ قَالَ : أَرَی أَنْ تَسْتَتِیبَہُمْ ، فَإِنْ تَابُوا جَلَدْتَہُمْ ثَمَانِینَ لِشُرْبِہم الْخَمْرِ ، وَإِنْ لَمْ یَتُوبُوا ضَرَبْتَ أَعْنَاقَہِمْ ، فَإِنَّہُمْ قَدْ کَذَبُوا عَلَی اللہِ ، وَشَرَعُوا فِی دِینِہِمْ مَا لَمْ یَأْذَنْ بِہِ اللَّہُ، فَاسْتَتَابَہُمْ فَتَابُوا ، فَضَرَبَہُمْ ثَمَانِینَ ثَمَانِینَ۔",,,29000
29001,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ عَمْرٍو ، قَالَ : حَدَّثَنَا أَبُو سَلَمَۃَ ،وَمُحَمَّدُ بْنُ إِبْرَاہِیمَ ، وَالزُّہْرِیُّ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَزْہَرِ ، قَالَ : أُتِیَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِشَارِبٍ یَوْمَ حُنَیْنٍ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لِلنَّاسِ : قُومُوا إِلَیْہِ ، فقام إِلَیْہِ النَّاسُ فَضَرَبُوہُ بِنِعَالِہِمْ۔\n\n(نسائی 5284۔ حاکم 374)",,,29001
29002,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا الْمَسْعُودِیُّ ، عَنْ زَیْدٍ الْعَمِّیِّ ، عَنْ أَبِی نَضْرَۃَ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ضَرَبَ فِی الْخَمْرِ بِنَعْلَیْنِ أَرْبَعِینَ ، فَجَعَلَ عُمَرُ مَکَانَ کُلِّ نَعْلٍ سَوْطًا۔ (احمد 67)",,,29002
29003,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا عِمْرَانُ بْنُ حُدَیْرٍ ، عَنِ السَّمَیْطِ بْنِ عُمَیْرٍ ، قَالَ : دَخَلَ رَجُلٌ یَوْمَ الْجُمُعَۃِ الْمَسْجِدَ ، فَصَلَّی أَرْبَعًا ، فَقَالَ رَجُلٌ لِصَاحِبِہِ : رَأَیْتَ مَا رَأَیْتُ ؟ قَالَ : نَعَمْ ، فَأَخَذَاہُ فَأَتَیَا بِہِ أَبَا مُوسَی الأَشْعَرِیَّ ، فَقَالاَ : إِنَّ ہَذَا دَخَلَ الْمَسْجِدَ فَصَلَّی أَرْبَعًا ، فَقَالَ : ہَلْ غَیَّرَ ؟ فَقَالاَ : لاَ ، قَالَ : إِنَّ ہَذِہِ لَرِیبَۃٌ ، قَالَ : مَا حَمَلَک عَلَی مَا صَنَعْتَ ؟ قَالَ : مَا شَرِبْتہَا قَبْلَ الْیَوْمِ ، فَجَلَدَہُ ثَمَانِینَ۔",,,29003
29004,حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ زَیْدٍ الْعَمِّیِّ ، عَنْ أَبِی الصِّدِّیقِ النَّاجِی ، عَنْ أَبِی سَعِیدٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ أَنَّہُ ضَرَبَ فِی الْخَمْرِ أَرْبَعِینَ۔ (ترمذی 1442۔ احمد 32),,,29004
29005,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ مَعْمَرٍ ، قَالَ : حدَّثَنَی عَبْدُ الْحَکِیمِ بْنُ فلاَنِ بْنِ یَعْلَی ، عَنْ أَبِیہِ ؛ أَنَّ یَعْلَی بْنَ أُمَیَّۃَ قَالَ لِعُمَرَ بْنِ الْخَطَّابِ ، أَوْ کَتَبَ إِلَیْہِ : إِنَّا نُؤْتَی بِقَوْمٍ قَدْ شَرِبُوا الشَّرَابَ ، فَعَلَی مَنْ نُقِیمُ الْحَدَّ ؟ فَقَالَ: اسْتَقْرِئْہُ الْقُرْآنَ ، وَأَلْقِ رِدَائَہُ بَیْنَ أَرْدِیَۃٍ ، فَإِنْ لَمْ یَقْرَأَ الْقُرْآنَ وَلَمْ یَعْرِفْ رِدَائَہُ ، فَأَقِمْ عَلَیْہِ الْحَدَّ۔",,,29005
29006,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، عَنْ مِسْعَرٍ، قَالَ: حدَّثَنَا أَبُو بَکْرِ بْنُ عَمْرِو بْنِ عُتْبَۃَ ، قَالَ : أُرَاہُ ذَکَرَہُ عَنْ عُمَرَ، أَنَّہُ قَالَ : لاَ حَدَّ إِلاَّ فِیمَا خَلَسَ الْعَقْلَ۔",,,29006
29007,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ أَبِی بَکْرٍ بْنِ عَمْرِو بْنِ عُتْبَۃَ ، عَنْ عَبْدِ اللہِ بْنِ عُتْبَۃَ ، قَالَ : أُرَاہُ عَنْ عُمَرَ، قَالَ : لاَ حَدَّ إِلاَّ فِیمَا خَلَسَ الْعَقْلَ۔",,,29007
29008,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ سَعِیدِ بْنِ سَعِیدٍ ، عَنْ عَطَائٍ ، قَالَ : إِذَا سَرَقَ الْمُسْلِمُ مِنَ الذِّمِّیِّ خَمْرًا ، قُطِعَ ، وَإِذَا سَرَقَہَا مِنْ مُسْلِمٍ لَمْ یُقْطَعْ۔",,,29008
29009,حَدَّثَنَا حَفْصٌ ، عَن مُجَالِدٍ ، عَنْ عَامِرٍ ؛ أَنَّ شُرَیْحًا ضَمَّنَ مُسْلِمًا خَمْرًا أَہْرَاقَہَا لِذِمِّیٍّ۔,,,29009
29010,"حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : مَنْ سَرَقَ مِنْ یَہُودِیٍّ ، أَوْ نَصْرَانِیٍّ ، أَوْ أَخَذَ مِنْ أَہْلِ الذِّمَّۃِ ، قُطِعَ۔",,,29010
29011,"حَدَّثَنَا مُعَمَّرُ بْنُ سُلَیْمَانَ الرَّقِّی ، عَنْ حَجَّاجٍ ، عَنْ عَبْدِ الْجَبَّارِ بْنِ وَائِلٍ ، عَنْ أَبِیہِ ، قَالَ : اسْتُکْرِہَتِ امْرَأَۃٌ عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَدَرَأَ عَنہَا الْحَدَّ۔ (ترمذی 1453۔ ابن ماجہ 2598)",,,29011
29012,حَدَّثَنَا حَفْصٌ ، عَن عُبَیْدِ اللہِ ، عَن نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ عُمَرَ أُتِیَ بِإِمَائٍ مِنْ إِمَائِ الإِمَارَۃِ اسْتَکْرَہَہُنَّ غِلْمَانٌ مِنْ غِلْمَانِ الإِمَارَۃِ ، فَضَرَبَ الْغِلْمَانَ وَلَمْ یَضْرِبِ الإِمَائَ۔,,,29012
29013,حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَن عُبَیْدِ اللہِ ، عَن نَافِعٍ ؛ أَنَّ رَجُلاً أَضَافَ أَہْلَ بَیْتٍ ، فَاسْتَکْرَہَ مِنْہُمُ امْرَأَۃً ، فَرُفِعَ ذَلِکَ إِلَی أَبِی بَکْرٍ ، فَضَرَبَہُ وَنَفَاہُ ، وَلَمْ یَضْرِبِ الْمَرْأَۃَ۔,,,29013
29014,حَدَّثَنَا مُعَمَّرُ بْنُ سُلَیْمَانَ الرَّقِّی ، عَنْ حَجَّاجٍ ؛ أَنَّ حَبَشِیًّا اسْتَکْرَہَ امْرَأَۃً مِنْہُمْ ، فَأَقَامَ عَلَیْہِ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ الْحَدَّ ، وَأَمْکَنَہَا مِنْ رَقَبَتِہِ۔,,,29014
29015,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الزُّہْرِیِّ ، وَالشُّعَبِیِّ ، وَالْحَسَنِ ، قَالُوا : لَیْسَ عَلَی مُسْتَکْرَہَۃٍ حَدٌّ۔",,,29015
29016,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، وَالزُّہْرِیِّ ، قَالاَ : لَیْسَ عَلَی مُسْتَکْرَہَۃٍ حَدٌّ۔",,,29016
29017,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی حُرَّۃَ ، عَنِ الْحَسَنِ ، قَالَ : اسْتَکْرَہَ عَبْدٌ امْرَأَۃً فَوَطِئَہَا ، فَاخْتَصَمَا إِلَی الْحَسَنِ وَہُوَ قَاضٍ یَوْمَئِذٍ ، فَضَرَبَہُ الْحَدَّ ، وَقَضَی بِالْعَبْدِ لِلْمَرْأَۃِ۔",,,29017
29018,"حَدَّثَنَا شَبَابَۃُ بْنِ سَوَّارٍ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ ، وَحَمَّادًا عَنْ مَمْلُوکٍ افْتَرَعَ جَارِیَۃً ؟ فَقَالاَ : عَلَیْہِ الْحَدُّ ، وَلَیْسَ عَلَیْہِ الصَّدَاقُ۔",,,29018
29019,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَمُحَمَّدٍ ، قَالاَ : إِذَا قَتَلَ السَّکْرَانُ قُتِلَ۔",,,29019
29020,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : یُقْتَلُ۔",,,29020
29021,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ؛ أَنَّ سَکْرَانَیْنِ قَتَلَ أَحَدُہُمَا صَاحِبَہُ ، قَالَ : فَقَتَلَہُ مُعَاوِیَۃُ۔",,,29021
29022,"حَدَّثَنَا عَبْدُالْوَہَّابِ، عَن بُرْدٍ، عَنْ مَکْحُولٍ، وَالزُّہْرِیِّ، قَالاَ: یَجُوزُ طَلاَقُ السَّکْرَانِ، وَیُقْطَعُ إِنْ سَرَقَ۔",,,29022
29023,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَن حَنْظَلَۃَ بْنِ أَبِی سُفْیَانَ ، عَنِ الْقَاسِمِ ؛ سُئِلَ عَنِ السَّکْرَانِ یَسْرِقُ ؟ فَقَالَ : إِنْ کَانَ یُعْرَفُ بِالسَّرِقَۃِ قَبْلَ ذَلِکَ فَاقْطَعْہُ ، وَإِلاَّ فَلاَ۔",,,29023
29024,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ مُحَمَّدِ بْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ؛ فِی النَّشْوَانِ : یُقْطَعُ إِنْ سَرَقَ ، وَیُؤْخَذُ بِجِنَایَاتِہِ کُلِّہَا۔",,,29024
29025,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، عَنِ الزُّہْرِیِّ ؛ فِی السَّکْرَانِ : إِذَا أَعْتَقَ ، أَوْ طَلَّقَ جَازَ عَلَیْہِ وَأُقِیمَ عَلَیْہِ الْحَدُّ۔",,,29025
29026,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : إِنْ سَرَقَ قُطِعَ ، وَإِنْ قَتَلَ قُتِلَ۔",,,29026
29027,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : مَا تَکَلَّمَ بِہِ السَّکْرَانُ مِنْ شَیْئٍ أُقِیمَ عَلَیْہِ۔",,,29027
29028,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَمُحَمَّدٍ ، قَالاَ : إِنْ سَرَقَ قُطِعَ۔",,,29028
29029,"حَدَّثَنَا عَبْدَۃُ، عَنْ عَاصِمٍ، عَنِ الْحَسَنِ، قَالَ: أَرْبَعَۃٌ إِلَی السُّلْطَانِ؛ الزَّکَاۃُ، وَالصَّلاَۃُ، وَالْحُدُودُ، وَالْقَضَائُ۔",,,29029
29030,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ جَبَلَۃَ بْنِ عَطِیَّۃَ ، عَنِ ابْنِ مُحَیْرِیزٍ ، قَالَ : الْجُمُعَۃُ ، وَالْحُدُودُ ، وَالزَّکَاۃُ ، وَالْفَیْئُ إِلَی السُّلْطَانِ۔",,,29030
29031,"حَدَّثَنَا عُمَرُ بْنُ أَیُّوبَ ، عَنْ مُغِیرَۃَ بْنِ زِیَادٍ ، عَنْ عَطَائٍ الْخُرَاسَانِیِّ ، قَالَ : إِلَی السُّلْطَانِ الزَّکَاۃُ ، وَالْجُمُعَۃُ ، وَالْحُدُودُ۔",,,29031
29032,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : السُّلْطَانُ وَلِیُّ مَنْ حَارَبَ الدِّینَ ، وَإِنْ قَتَلَ أَخَا امْرِئٍ ، أَوْ أَبَاہُ۔",,,29032
29033,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ؛ فِی رَجُلٍ قَالَ لِرَجُلٍ : یَا شَارِبَ خَمْرٍ ، قَالَ : لَیْسَ عَلَیْہِ حَدٌّ۔",,,29033
29034,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یَقُولُ لِلرَّجُلِ : یَا شَارِبَ خَمْرٍ ، یَا سَکْرَانُ ، قَالَ : کَانَ لاَ یَرَی عَلَیْہِ حَدًّا۔",,,29034
29035,"حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، فِی الرَّجُلِ یَقُولُ لِلرَّجُلِ: یَا شَارِبُ، یَا سَارِقُ، قَالَ : لَیْسَ عَلَیْہِ حَدٌّ ، وَلَکِنْ سِیَاطٌ۔",,,29035
29036,"حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَن سُلَیْمَانَ بْنِ مُوسَی ، قَالَ : سَأَلْنَا عُمَرَ بْنَ عَبْدِ الْعَزِیزِ عَنْ رَجُلٍ قَالَ لِرَجُلٍ : یَا شَارِبَ خَمْرٍ ، أَوْ یَا مُشْرِکُ ، أَوْ یَا سَکْرَانُ ، قُلْنَا : یُحَدُّ ؟ قَالَ : سُبْحَانَ اللہِ ، مَا یُحَدُّ إِلاَّ مَنْ قَذَفَ مُسْلِمًا۔",,,29036
29037,"حَدَّثَنَا ابْنُ یَمَانٍ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ؛ فِی الرَّجُلِ یَقُولُ لِلرَّجُلِ : یَا شَارِبَ خَمْرٍ ، قَالَ : لاَ یُضْرَبُ۔",,,29037
29038,"حَدَّثَنَا جَرِیرٌ ، عَن مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ؛ فِی رَجُلٍ لاَعَنَ امْرَأَتَہُ ، فَفُرِّقَ بَیْنَہُمَا ، ثُمَّ أَکْذَبَ نَفْسَہُ ، قَالَ : یُجْلَدُ ، وَیُلْزَقُ بِہِ الْوَلَدُ۔",,,29038
29039,"حَدَّثَنَا حَفْصٌ، عَن دَاوُد، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ؛ فِی الْمُلاَعِن یُکَذِّبُ نَفْسَہُ، قَالَ: یُضْرَبُ وَہُوَ خَاطِبٌ۔",,,29039
29040,"حَدَّثَنَا أَبُو بَکْرٍ بْنُ عَیَّاشٍ ، عَنْ مُطَرِّفٍ ، قَالَ : إِذَا قَذَفَ الرَّجُلُ امْرَأَتَہُ لاَعَنہَا ، فَإِنْ أَکْذَبَ نَفْسَہُ بَعْدَ ذَلِکَ جُلِدَ ، وَیُلْزَقُ بِہِ الْوَلَدُ ، وَرُدَّتْ إِلَیْہِ امْرَأَتُہُ۔",,,29040
29041,"حَدَّثَنَا أَبُو بَکْرٍ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ؛ فِی الْمُلاَعِنِ یُکَذِّبُ نَفْسَہُ ، قَالَ : یُجْلَدُ الْحَدَّ۔",,,29041
29042,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، قَالَ : سَأَلْتُہُ عَنِ الرَّجُلِ یُلاَعِنُ امْرَأَتَہُ ، ثُمَّ أَقَرَّ بِالْوَلَدِ ؟ قَالَ : یُضْرَبُ الْحَدَّ ، وَیُلْزَقُ بِہِ الْوَلَدُ۔",,,29042
29043,"حَدَّثَنَا أَبُو عَاصِمٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ فِی الرَّجُلِ یَقْذِفُ امْرَأَتَہُ ، أَوْ یَنْتَفِی مِنْ وَلَدِ امْرَأَتِہِ ، ثُمَّ یُکَذِّبُ نَفْسَہُ ، قَالَ : یُحَدُّ۔",,,29043
29044,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ شُبْرُمَۃَ ، عَنِ الْحَارِثِ (ح) وَعَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ (ح) وَعَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنِ الشَّعْبِیِّ ؛ فِی الْمَلاَعِن یُکَذِّبُ نَفْسَہُ ، قَالُوا : یُضْرَبُ۔",,,29044
29045,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ مُحَمَّدِ بْنِ الزُّبَیْرِ ، عَنْ مَکْحُولٍ ، قَالَ : إِذَا لاَعَنَ الرَّجُلُ ، وَأَبَتِ الْمَرْأَۃُ أَنْ تُلاَعِن ، رُجِمَتْ۔",,,29045
29046,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : تُحْبَسُ۔",,,29046
29047,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ الْمُحَارِبِیُّ، عَن جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ؛ فِی الرَّجُلِ یَقْذِفُ امْرَأَتَہُ فَتَأْبَی أَنْ تُلاَعنہُ، قَالَ : تُجْلَدُ مِئَۃ ، وَتُرْجَمُ۔",,,29047
29048,"حَدَّثَنَا عُمَر، عَنْ عِیسَی الْخَیَّاط، عَنِ الشَّعْبِیِّ، قَالَ: مَنْ وَقَعَ عَلَیْہِ اللِّعَانُ فَأَبَی أَنْ یَحْلِفَ، أُقِیمَ عَلَیْہِ الْحَدُّ۔\n\nوَقَالَ عِیسَی : سَمِعْت غَیْرَ الشَّعْبِیِّ یَقُولُ : یُجْبَرَانِ عَلَی اللِّعَانِ ، وَیُحْبَسَانِ حَتَّی یَتَلاَعَنَا۔",,,29048
29049,"حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ سُفْیَانَ ، عَنْ مُطَرِّفٍ ، وَجَابِرٍ ، عَنِ الشَّعْبِیِّ (ح) وَعَنْ سُفْیَانَ ، عَنْ لَیْثٍ ، عَن مُجَاہِدٍ ، وَعَطَائٍ ، قَالُوا : إِذَا دُرِئَ فِی اللِّعَانِ أُلْزِقَ بِہِ الْوَلَدُ۔",,,29049
29050,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ؛ فِی الرَّجُلِ یُلاَعنِ امْرَأَتَہُ ، ثُمَّ یَقْذِفُہَا ، قَالَ : یُضْرَبُ ، وَقَالَ عَامِرٌ : لاَ یُضْرَبُ۔",,,29050
29051,"حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ ، وَحَمَّادًا عَنِ الرَّجُلِ یُلاَعنِ امْرَأَتَہُ ، ثُمَّ تَلِدُ ، فَیَقُولُ : لَیْسَ ہَذَا مِنِّی ؟ قَالاَ : یُضْرَبُ۔",,,29051
29052,"حَدَّثَنَا أَبُو عَاصِمٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : إِنْ لاَعَنَتُہُ ، ثُمَّ قَذّفَہَا لَمْ یُحَدّ ۔ قَالَ : قُلْتُ : وَکَیْفَ وَقَدْ أَکْذَبَ نَفْسَہُ ؟ قَالَ : لاَ یُحَدُّ ، قَدْ بَائَ بِلَعَنَۃِ اللہِ فِی کِتَابِ اللہِ۔",,,29052
29053,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا قَذَفَ الْمَجْلُودُ امْرَأَتَہُ جُلِدَ ، وَلاَ لِعَانَ بَیْنَہُمَا۔\n\nقَالَ : وَسَأَلْتُ الْحَسَنَ ، وَعَامِرًا ؟ فَقَالاَ : یُلاَعِن۔",,,29053
29054,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ أَشْعَثَ ، عَن مَنْصُورٍ ، وَحَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا قَذَفَ الرَّجُلُ امْرَأَتَہُ ، وَقَدْ کَانَ جُلِدَ الْحَدَّ ، جُلِدَ ، وَلاَ یُلاَعِن ، لأَََّنَّہُ لاَ تَجُوزُ شَہَادَتُہُ۔",,,29054
29055,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ عُمَرَ بْنِ عَامِرٍ ، عَن حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا أَکْذَبَ الرَّجُلُ نَفْسَہُ مَا بَقِیَ مِنْ مُلاَعَنَتِہَا شَیْئٌ ، جُلِدَ وَہِیَ امْرَأَتُہُ۔",,,29055
29056,حَدَّثَنَا عَبَّادٌ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إِبْرَاہِیمَ ، مِثْلَہُ۔,,,29056
29057,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : إِذَا أَکْذَبَ نَفْسَہُ قَبْلَ أَنْ تَنْقَضِیَ الْمُلاَعنۃُ جُلِدَ وَہِیَ امْرَأَتُہُ ، وَإِنْ أَکْذَبَ نَفْسَہُ بَعْدَ الْمُلاَعَنَۃِ فَلاَ شَیْئَ۔",,,29057
29058,"حَدَّثَنَا جَرِیرٌ ، عَن بَیَانٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : مَنْ قَذَفَ ابْنَ الْمُلاَعنۃِ ، أَوْ قَذَفَ أُمَّہُ ضُرِبَ۔",,,29058
29059,"حَدَّثَنَا شَرِیکٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ (ح) وَعَن لَیْثٍ ، عَن مُجَاہِدٍ (ح) وَعَنْ جَابِرٍ ، وَابْنِ سَالِمٍ ، عَنْ عَامِرٍ ، قَالُوا : مَنْ قَذَفَ ابْنَ الْمُلاَعنۃِ جُلِدَ۔",,,29059
29060,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ لَیْثٍ ، عَن مُجَاہِدٍ ، وَطَاوُوسٍ ؛ فِی الرَّجُلِ یَقُولُ لابْنِ الْمُلاَعنۃِ : یَا ابْنَ الزَّانِیَۃِ ، قَالَ : یُجْلَدُ ثَمَانِینَ۔",,,29060
29061,"حَدَّثَنَا أَبُو بَکْرٍ بْنُ عَیَّاشٍ ، عَن مُوسَی بْنِ عُبَیْدَۃَ ، عَن نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : مَنْ قَذَفَ ابْنَ الْمُلاَعنۃِ جُلِدَ۔",,,29061
29062,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَن عِمْرَانَ ، عَن عِکْرِمَۃَ ، قَالَ : مَنْ قَالَ لاِبْنِ الْمُلاَعنۃِ : یَا ابْنَ الْہَنَۃِ ، جُلِدَ الْحَدَّ۔",,,29062
29063,"حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ مُطَرِّفٍ ، عَنْ عَامِرٍ ، قَالَ ، إِذَا قِیلَ لاِبْنِ الْمُلاَعنۃِ : لَسْتَ بِابْنِ فُلاَنٍ الَّذِی لاَعَنَ أُمَّک ، قَالَ : یُجْلَدُ الَّذِی یَقُولُ لَہُ ذَلِکَ۔",,,29063
29064,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبَّادِ بْنِ مَنْصُورٍ ، عَن عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : مَنْ رَمَی ابْنَ الْمُلاَعنۃِ ، أَوْ أُمَّہُ ، جُلِدَ۔",,,29064
29065,"حَدَّثَنَا وَکِیعٌ ، عَنِ الْفَضْلِ بْنِ دَلْہَمٍ ، عَنِ الْحَسَنِ ، قَالَ : یُضْرَبُ قَاذِفُ ابْنِ الْمُلاَعنۃِ۔",,,29065
29066,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِنْ قَذَفَہَا إِنْسَانٌ جُلِدَ قَاذِفُہَا۔",,,29066
29067,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ، وَحَمَّادٍ، عَنْ إِبْرَاہِیمَ؛ فِی الأَمَۃِ تَکُونُ تَحْتَ الْحُرِّ فَیَقْذِفُہَا، قَالَ : لاَ یُضْرَبُ الْحَدَّ ، وَلاَ یُلاَعِن۔",,,29067
29068,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ مُطَرِّفٍ ، عَنْ عَامِرٍ ؛ فِی الأَمَۃِ تَکُونُ تَحْتَ الْحُرِّ فَیَقْذِفُہَا ، قَالَ : لاَ حَدَّ عَلَیْہِما ، وَلاَ لِعَانَ۔",,,29068
29069,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ لَیْثٍ ، عَن طَاوُوسٍ ، وَمُجَاہِدٍ (ح) وَالْحَکَمِ ، عَنْ إِبْرَاہِیمَ ، وَالشَّعْبِیِّ ؛ فِی الرَّجُلِ تَکُونُ تَحْتَہُ الأَمَۃُ فَیَقْذِفُہَا ، قَالُوا : لَیْسَ بَیْنَہُمَا تَلاَعَنٌ ، وَلَیْسَ عَلَی قَاذِفِہَا حَدٌّ۔",,,29069
29070,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، وَحَمَّادٍ ؛ فِی الْعَبْدِ تَکُونُ تَحْتَہُ الْحُرَّۃُ فَیَقْذِفُہَا ، قَالاَ : لَیْسَ بَیْنَہُمَا مُلاَعنۃٌ ، وَیُجْلَدُ۔",,,29070
29071,"حَدَّثَنَا مُحَمَّدُ بْنُ عُبَیْدٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ فِی الْیَہُودِیَّۃِ تُلاَعِنِ الْمُسْلِمَ ؟ قَالَ : لاَ ، وَلاَ الْعَبْدُ الْحُرَّۃَ ، وَلَکِنْ یُجْلَدُ الْعَبْدُ۔",,,29071
29072,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَن حَسَنٍ ، عَنْ مُطَرِّفٍ ، عَنِ الْحَکَمِ ، وَعَامِرٍ ؛ فِی الْمَمْلُوکِ تَکُونُ لَہُ امْرَأَۃٌ حُرَّۃٌ ، فَتَجِیئُ بِوَلَدٍ فَیَنْتَفِی مِنْہُ ، قَالَ : یُضْرَبُ ، وَلاَ لِعَانَ بَیْنَہُمَا ، وَیُلْزَقُ بِہِ الْوَلَدُ۔\n\nوَقَالَ عَامِرٌ ، وَالْحَکَمُ ؛ فِی الْحُرِّ تَحْتَہُ الأَمَۃُ ، فَجَائَتْ بِوَلَدٍ ، فَانْتَفَی مِنْہُ ، قَالاَ : لَیْسَ بَیْنَہُمَا لِعَانٌ ، وَیُلْزَقُ بِہِ الْوَلَدُ۔",,,29072
29073,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ؛ فِی الْعَبْدِ إِذَا کَانَ تَحْتَہُ الْحُرَّۃُ ، أَنَّہُ إِذَا قَذَفَہَا جُلِدَ ، وَلاَ یُلاَعِنُ ، وَإِذَا کَانَ حُرٌّ تَحْتَہُ أَمَۃٌ فَقَذَفَہَا ، فَإِنَّہُ لاَ یُجْلَدُ ، وَلاَ یُلاَعِنُ ، وَإِذَا کَانَ عَبْدٌ تَحْتَہُ أَمَۃٌ فَقَذَفَہَا ، فَإِنَّہُ لاَ یُجْلَدُ ، وَلاَ یُلاَعِنُ۔,,,29073
29074,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ؛ فِی أَرْبَعَۃٍ شَہِدُوا عَلَی رَجُلٍ أَنَّہُ طَلَّقَ امْرَأَتَہُ ثَلاَثًا ، فَأَنْکَرَ ، وَأَقَرَّ بِغَشَیَانِ الْمَرْأَۃِ ، فَقَالَ : لاَ حَدَّ عَلَیْہِ لأَنَّہُ مُخَاصِمٌ۔",,,29074
29075,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ جَابِرِ بْنِ زَیْدٍ ، وَہُوَ قَوْلُ قَتَادَۃَ ؛ أَنَّہُمَا قَالاَ : یُفَرَّقُ بَیْنَہُمَا بِشَہَادَۃِ اثْنَیْنِ وَثَلاَثَۃٍ ، وَیُرْجَمُ بِشَہَادَۃِ أَرْبَعَۃٍ۔",,,29075
29076,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، قَالَ : نَبَّؤُوا عَنْ حَبِیْبِ بْنِ أَبِی ذِئْبٍ ، عَنْ عُمَرَ ، قَالَ : یُفَرَّقُ بَیْنَہُمَا بِشَہَادَۃِ أَرْبَعَۃٍ فَأَکْثَرَ ، فَإِنْ عَادَ رُجِمَ۔",,,29076
29077,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، قَالَ : نَبَّؤُووا عَنْ إبْرَاہِیمَ ، قَالَ : یُفَرَّقُ بَیْنَہُمَا بِشَہَادَۃِ أَرْبَعَۃٍ ، وَأَکْثَرِ مِنْ ذَلِکَ رَجْمٌ۔",,,29077
29078,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُحَمَّدِ بْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ؛ أَنَّہُ سُئِلَ عَنْ رَجُلٍ شَہِدَ عَلَیْہِ شُہُودٌ أَنَّہُ طَلَّقَ امْرَأَتَہُ ثَلاَثًا ، فَجَحَدَ ذَلِکَ ، وَأَنَّہُ کَانَ یَغْشَاہَا ؟ قَالَ : فَقَالَ الشَّعْبِیِّ : یُدْرَأُ عَنْہُ الْحَدُّ لإِنْکَارِہِ۔",,,29078
29079,"حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ فِی رَجُلٍ طَلَّقَ امْرَأَتَہُ فَأَشْہَدَ شَاہِدَیْنِ ، ثُمَّ قَدِمَ الْقَرْیَۃَ الَّتِی بِہَا الْمَرْأَۃُ ، فَغَشِیَہَا وَأَقَرَّ بِأَنْ قَدْ أَصَابَہَا ، وَأَنْکَرَ أَنْ یَکُونَ طَلَّقَہَا ، فَقَالَ عَطَائٌ : تَجُوزُ شَہَادَتُہُمَا ، وَیُفَرَّقُ بَیْنَہُمَا ، وَلاَ یُحَدُّ۔",,,29079
29080,"حَدَّثَنَا عَبْدَۃُ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ؛ أَنَّ رَجُلاً طَلَّقَ امْرَأَتَہُ ثَلاَثًا ، ثُمَّ جَعَلَ یَغْشَاہَا بَعْدَ ذَلِکَ ، فَسُئِلَ عَن ذَلِکَ عَمَّارٌ ؟ فَقَالَ : لَئِنْ قَدَرْتُ عَلَی ہَذَا لأَرْجُمَنَّہُ۔",,,29080
29081,حَدَّثَنَا مُحَمَّدُ بْنُ سَوَائٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَن خِلاَسٍ ، عَنْ عَمَّارٍ ؛ بِنَحْوِہِ۔,,,29081
29082,"حَدَّثَنَا حُمَیْدٌ ، وَعَبْدُ الرَّحْمَنِ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، عَن عِیسَی بْنِ عَاصِمٍ ، قَالَ : خَرَجَ قَوْمٌ فِی سَفَرٍ ، فَمَرُّوا بِرَجُلٍ فَنَزَلُوا بِہِ ، فَطَلَّقَ امْرَأَتَہُ ثَلاَثًا ، فَمَضَی الْقَوْمُ فِی سَفَرِہِمْ ، ثُمَّ عَادُوا فَوَجَدُوہُ مَعَہَا ، فَقَدَّمُوہُ إِلَی شُرَیْحٍ، فَقَالُوا: إِنَّ ہَذَا طَلَّقَ امْرَأَتَہُ ثَلاَثًا وَوَجَدْنَاہُ مَعَہَا، فَأَنْکَرَ، فَقَالَ: تَشْہَدُونَ أَنَّہُ زَانٍ؟ فَأَعَادُوا عَلَیْہِ القَول کَمْا قَالُوا، فَقَالَ: تَشْہَدُونَ أَنَّہُ زَانٍ؟ فَأَعَادُوا عَلَیْہِ، فَفَرَّقَ بَیْنَہُمَا، وَلَمْ یَحُدَّہُمَا، وَأَجَازَ شَہَادَتَہُمَا۔",,,29082
29083,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللہِ الأَنْصَارِیُّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یَقُولُ لِلرَّجُلِ : أَخْبَرَنِی فُلاَنٌ أَنَّک زَنَیْتَ ، قَالَ : لَیْسَ عَلَیْہِ حَدٌّ لأَنَّہُ أَضَافَہُ إِلَی غَیْرِہِ۔",,,29083
29084,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ بَعْضِ أَصْحَابِہِ ، عَنِ الشَّعْبِیِّ ؛ أَنَّ رَجُلاً قَالَ لِرَجُلٍ : زَعَمَ فُلاَنٌ أَنَّک زَانٍ ، قَالَ : إِنْ جَائَ بِالْبَیِّنَۃِ ، وَإِلاَّ ضُرِبَ الْحَدَّ۔",,,29084
29085,"حَدَّثَنَا ہُشَیْمٌ ، عَن مَنْصُورٍ ، عَنِ الْحَارِثِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : قَالَ عُمَرُ بْنُ الْخَطَّابِ : لأَنْ أُعَطِّلُ الْحُدُودَ بِالشُّبُہَاتِ أَحَبَّ إِلَیَّ مِنْ أَنْ أُقِیمَہَا فِی الشُّبُہَاتِ۔",,,29085
29086,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ إِسْحَاقَ بْنِ أَبِی فَرْوَۃَ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ؛ أَنَّ مُعَاذًا ، وَعَبْدَ اللہِ بْنَ مَسْعُودٍ ، وَعُقْبَۃَ بْنَ عَامِرٍ ، قَالُوا : إِذَا اشْتَبَہَ عَلَیْک الْحَدُّ فَادْرَأْہُ۔",,,29086
29087,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَن قَیْسِ بْنِ مُسْلِمٍ ، عَن طَارِقِ بْنِ شِہَابٍ ؛ أَنَّ امْرَأَۃً زَنَتْ ، فَقَالَ عُمَرُ : أُرَاہَا کَانَتْ تُصَلِّی مِنَ اللَّیْلِ فَخَشَعَتْ ، فَرَکَعَتْ فَسَجَدَتْ ، فَأَتَاہَا غَاوٍ مِنَ الْغُوَاۃِ فَتَجَتَّمَہَا ، فَأَرْسَلَ عُمَرُ إِلَیْہَا ، فَقَالَتْ کَمَا قَالَ عُمَرُ ، فَخَلَّی سَبِیلَہَا۔",,,29087
29088,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانُوا یَقُولُونَ ، ادْرَؤُوا الْحُدُودَ عَنْ عِبَادِ اللہِ مَا اسْتَطَعْتُمْ۔",,,29088
29089,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَن بُرْدٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : ادْفَعُوا الْحُدُودَ لِکُلِّ شُبْہَۃٍ۔",,,29089
29090,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَاصِمٍ ، عَنْ أَبِی وَائِلٍ ، عَنْ عَبْدِ اللہِ ، قَالَ : ادْرَؤُوا الْقَتْلَ وَالْجَلْدَ عَنِ الْمُسْلِمِینَ مَا اسْتَطَعْتُمْ۔",,,29090
29091,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ إِبْرَاہِیمَ ، قَالَ : قَالَ : اطْرُدُوا الْمُعْتَرِفِینَ۔",,,29091
29092,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ عَاصِمِ بْنِ کُلَیْبٍ ، عَنْ أَبِیہِ ، قَالَ : قَالَ أَبُو مُوسَی : أُتِیَت وَأَنَا بِالْیَمَنِ بِامْرَأَۃٍ حُبْلَی ، فَسَأَلْتُہَا ؟ فَقَالَتْ : مَا تَسْأَلُ عَنِ امْرَأَۃٍ حُبْلَی ثَیِّبٍ مِنْ غَیْرِ بَعْلٍ ؟ أَمَا وَاللَّہِ مَا خَالَلْتُ خَلِیلاً ، وَلاَ خَادَنْتُ خِدْنًا مُنْذُ أَسْلَمْتُ ، وَلَکِنْ بَیْنَا أَنَا نَائِمَۃٌ بِفِنَائِ بَیْتِی ، وَاللَّہِ مَا أَیْقَظَنِی إِلاَّ رَجُلٌ رقصنی وَأَلْقَی فِی بَطْنِی مِثْلَ الشِّہَابِ ، ثُمَّ نَظَرْت إِلَیْہِ مُقَفِّیًا مَا أَدْرِی مَنْ ہُوَ مِنْ خَلْقِ اللہِ ، فَکَتَبْتُ فِیہَا إِلَی عُمَرَ ، فَکَتَبَ عُمَرُ : وَافِنِی بِہَا ، وَبِنَاسٍ مِنْ قَوْمِہَا ، قَالَ : فَوَافَیْنَاہُ بِالْمَوْسِمِ ، فَقَالَ شَبَہَ الْغَضْبَانِ : لَعَلَّک قَدْ سَبَقْتَنِی بِشَیْئٍ مِنْ أَمْرِ الْمَرْأَۃِ ؟ قَالَ : قُلْتُ : لاَ ، ہِیَ مَعِی وَنَاسٌ مِنْ قَوْمِہَا ، فَسَأَلَہَا ، فَأَخْبَرَتْہُ کَمَا أَخْبَرَتْنِی ، ثُمَّ سَأَلَ قَوْمَہَا فَأَثْنَوْا خَیْرًا ، قَالَ : فَقَالَ عُمَرُ : شَابَّۃٌ تِہَامِیَّۃٌ نُوَمۃ ، قَدْ کَانَ یُفْعَلُ ، فَمَارَّہَا ، وَکَسَاہَا ، وَأَوْصَی قَوْمَہَا بِہَا خَیْرًا۔",,,29092
29093,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ شُعْبَۃَ ، عَنْ عَبْدِ الْمَلِکِ بْنِ مَیْسَرَۃَ ، عَنِ النَّزَّالِ بْنِ سَبْرَۃَ ، قَالَ : بَیْنَمَا نَحْنُ بِمِنًی مَعَ عُمَرَ ، إِذَا امْرَأَۃٌ ضَخْمَۃٌ عَلَی حِمَارَۃٍ تَبْکِی ، قَدْ کَادَ النَّاسُ أَنْ یَقْتُلُوہَا مِنَ الزِّحَامِ ، یَقُولُونَ : زَنَیْتِ ، فَلَمَّا انْتَہَتْ إِلَی عُمَرَ ، قَالَ : مَا یُبْکِیکِ ؟ إِنَّ الْمَرأَۃ رُبَّمَا اسْتُکْرِہَتْ ، فَقَالَتْ : کُنْت امْرَأَۃً ثَقِیلَۃَ الرَّأْسِ ، وَکَانَ اللَّہُ یَرْزُقُنِی مِنْ صَلاَۃِ اللَّیْلِ ، فَصَلَّیْتُ لَیْلَۃً ثُمَّ نِمْتُ ، فَوَاللَّہِ مَا أَیْقَظَنِی إِلاَّ الرَّجُلُ قَدْ رَکِبَنِی ، فَنَظرتُ إِلَیْہِ مُقْفِیًا مَا أَدْرِی مَنْ ہُوَ مِنْ خَلْقِ اللہِ ، فَقَالَ عُمَرُ : لَوْ قَتَلْتُ ہَذِہِ خَشِیت عَلَی الأَخْشَبَیْنِ النَّارَ ، ثُمَّ کَتَبَ إِلَی الأَمْصَارِ : أَنْ لاَ تُقْتَلَ نَفْسٌ دُونَہُ۔",,,29093
29094,"حَدَّثَنَا وَکِیعٌ ، عَنْ یَزِیدَ بْنِ زِیَادٍ الْبَصْرِیِّ ، عَنِ الزُّہْرِیِّ ، عَنْ عُرْوَۃَ ، عَنْ عَائِشَۃَ ، قَالَتْ : ادْرَؤُوا الْحُدُودَ عَنِ الْمُسْلِمِینَ مَا اسْتَطَعْتُمْ ، فَإِذَا وَجَدْتُمْ لِلْمُسْلِمِ مَخْرَجًا ، فَخَلُّوا سَبِیلَہُ ، فَإِنَّ الإِمَامَ أَنْ یُخْطِیء فِی الْعَفْوِ ، خَیْرٌ مِنْ أَنْ یُخْطِئَ فِی الْعُقُوبَۃِ۔ (ترمذی 1424۔ حاکم 384)",,,29094
29095,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، وَأَبُو الأَحْوَصِ ، عَنْ عَاصِمٍ ، عَنْ أَبِی رَزِینٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : مَنْ أَتَی بَہِیمَۃً فَلاَ حَدَّ عَلَیْہِ۔ (ابوداؤد 4460)",,,29095
29096,"حَدَّثَنَا جَرِیرٌ ، عَن مَنْصُورٍ ، عَنِ الْحَکَمِ ؛ فِیمَنْ أَتَی بَہِیمَۃً ، قَالَ : یُجْلَدُ ، وَلاَ یُبْلَغُ بِہِ الْحَدَّ۔",,,29096
29097,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ؛ فِی الَّذِی یَأْتِی الْبَہِیمَۃَ ، قَالَ : یُعَزَّرُ۔",,,29097
29098,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : لَیْسَ عَلَی مَنْ أَتَی بَہِیمَۃً حَدٌّ ، وَلاَ عَلَی مَنْ رُمِی بِہَا۔",,,29098
29099,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ أَبِی حَنِیفَۃَ ، عَن حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : قَالَ عُمَرُ : لَیْسَ عَلَی مَنْ أَتَی بَہِیمَۃً حَدٌّ۔",,,29099
29100,"حَدَّثَنَا حَفْصٌ ، عَنْ عُبَیْدَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : مَنْ أَتَی بَہِیمَۃً فَلاَ حَدَّ عَلَیْہِ۔",,,29100
29101,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَن بُدَیْلٍ ، عَنْ جَابِرِ بْنِ زَیْدٍ ؛ أَنَّہُ قَالَ : إِذَا أَتَی الرَّجُلُ الْبَہِیمَۃَ ، أُقِیمَ عَلَیْہِ الْحَدُّ۔",,,29101
29102,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا سُفْیَانُ بْنُ حُسَیْنٍ ، عَنْ أَبِی عَلِیٍّ الرَّحَبِیِّ ، عَن عِکْرِمَۃَ ، قَالَ : سُئِلَ الْحَسَنُ بْنُ عَلِیٍّ عَنْ رَجُلٍ أَتَی بَہِیمَۃً ؟ قَالَ : إِنْ کَانَ مُحْصَنًا رُجِمَ۔",,,29102
29103,حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنِ ابْنِ أَبِی فَرْوَۃَ ، عَن بُکَیْرِ بْنِ عَبْدِ اللہِ بْنِ الأَشَجِّ ، عَن سُلَیْمَانَ بْنِ یَسَارٍ ؛ أَنَّہُ کَانَ یُقِیمُ عَلَیْہِ الْحَدَّ۔,,,29103
29104,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ فِیمَنْ یَأْتِی الْبَہِیمَۃَ وَالْغُلاَمَ ؟ قَالَ : عَلَیْہِ الْحَدُّ۔",,,29104
29105,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : إِذَا وَقَعَ الرَّجُلُ بِالْبَہِیمَۃِ جُلِدَ الْحَدَّ تَامًّا ، وَمَنْ رَمَی امْرَأَۃً بِالْبَہِیمَۃِ فَعَلَیْہِ الْحَدُّ۔",,,29105
29106,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ لَیْثٍ ، عَنْ یَزِیدَ ، عَن مَسْرُوقٍ ؛ فِی الَّذِی یَأْتِی الْبَہِیمَۃَ ، قَالَ : إِذَا فَعَلَ بِہَا ، قَالَ : ذُبِحَتْ۔",,,29106
29107,"حَدَّثَنَا ابْنُ أَبِی عَدِیٍّ ، عَن دَاوُد ، قَالَ : قَالَ مَسْرُوقٌ : یُرْجَمُ وَتُرْجَمُ الْحِجَارَۃ الَّتِی رُجِمَ بِہَا ، وَیُعْفَی أَثَرُہُ ، یَعْنِی فِی الَّذِی یَأْتِی الْبَہِیمَۃَ۔",,,29107
29108,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنِ الْحَکَمِ ، قَالَ : مَنْ أَتَی الْبَہِیمَۃَ أُقِیمَ عَلَیْہِ الْحَدُّ۔",,,29108
29109,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الْعَلاَئِ بْنِ الْمُسَیَّبِ ، عَنْ أَبِیہِ ، قَالَ : مَنْ أَتَی بَہِیمَۃً لَمْ تُقمْ لَہُ قِیَامَۃٌ۔",,,29109
29110,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ؛ فِی الَّذِی یَأْتِی الْبَہِیمَۃَ ، قَالَ : عَلَیْہِ أَدْنَی الْحَدَّیْنِ ، أُحْصِنَ ، أَمْ لَمْ یُحْصَنْ۔",,,29110
29111,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ إِبْرَاہِیمَ بْنِ إِسْمَاعِیلَ ، عَن دَاوُد بْنِ حُصَیْنٍ ، عَن عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : اقْتُلُوا الْفَاعِلَ بِالْبَہِیمَۃِ وَالْبَہِیمَۃَ۔ \n\n(ابوداؤد 4459۔ حاکم 355)",,,29111
29112,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنْ عُمَیْرِ بْنِ نُمَیْرٍ ، قَالَ : سُئِلَ ابْنُ عُمَرَ عَنْ جَارِیَۃٍ کَانَتْ بَیْنَ رَجُلَیْنِ ، فَوَقَعَ عَلَیْہَا أَحَدُہُمَا ؟ قَالَ : لَیْسَ عَلَیْہِ حَدٌّ ، ہُوَ خَائِنٌ یُقَوَّمُ عَلَیْہِ قِیمَۃٌ وَیَأْخُذُہَا۔",,,29112
29113,"حَدَّثَنَا حَفْصٌ ، عَن دَاوُد ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ فِی جَارِیَۃٍ کَانَتْ بَیْنَ رَجُلَیْنِ ، فَوَقَعَ عَلَیْہَا أَحَدُہُمَا ، قَالَ : یُضْرَبُ تِسْعَۃً وَتِسْعِینَ سَوْطًا۔",,,29113
29114,حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ عَبْدَۃَ ، عَنْ شُرَیْحٍ ؛ أَنَّہُ دَرَأَ عَنہُ الْحَدَّ ، وَضَمَّنَہُ۔,,,29114
29115,"حَدَّثَنَا عَبْدُ الرَّزَّاقِ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ؛ فِی الأَمَۃِ تَکُونُ بَیْنَ الشُّرَکَائِ ، فَیَقَعُ عَلَیْہَا أَحَدُہُمْ ، قَالَ : یُضْرَبُ مِئَۃً۔",,,29115
29116,"حَدَّثَنَا رَوَّادُ بْنُ الْجَرَّاحِ ، عَنِ الأَوْزَاعِیِّ ، عَنْ مَکْحُولٍ ؛ فِی جَارِیَۃٍ بَیْنَ ثَلاَثَۃٍ ، وَقَعَ عَلَیْہَا أَحَدُہُمْ ، فَقَالَ : عَلَیْہِ أَدْنَی الْحَدَّیْنِ مِئَۃً ، وَعَلَیْہِ ثُلُثَا ثَمَنِہَا ، وَثُلُثَا عُقْرُہَا ، وَیَلِی قِیمَۃَ الْوَلَدِ إِنْ کَانَ۔",,,29116
29117,"حَدَّثَنَا یَزِیدُ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : یُعَزَّرُ ، وَیُقَوَّمُ عَلَیْہِ۔",,,29117
29118,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، قَالَ : بَلَغَنَا أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ أُتِیَ بِجَارِیَۃٍ کَانَتْ بَیْنَ رَجُلَیْنِ ، فَوَطِئَہَا أَحَدُہُمَا ، فَاسْتَشَارَ فِیہَا سَعِیدَ بْنَ الْمُسَیَّبِ ، وَسَعِیدِ بْنِ جُبَیْرٍ ، وَعُرْوَۃَ بْنِ الزُّبَیْرِ ، فَقَالُوا : نَرَی أَنْ یُجْلَدَ دُونَ الْحَدِّ ، ویُقَوّموہا قِیمَۃً ، فَیَدْفَعُ إِلَی شَرِیکِہِ نِصْفَ الْقِیمَۃِ۔",,,29118
29119,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَن یُونُسَ ؛ فِی رَجُلٍ یَقَعُ عَلَی جَارِیَۃٍ بَیْنَہُ وَبَیْنَ شَرِیکِہِ ، قَالَ : تُقَوَّمُ عَلَیْہِ۔",,,29119
29120,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سَعِیدٍ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ؛ فِی جَارِیَۃٍ کَانَتْ بَیْنَ رَجُلَیْنِ ، فَوَقَعَ عَلَیْہَا أَحَدُہُمَا ، فَحَمَلَتْ ، قَالَ : تُقَوَّمُ عَلَیْہِ۔",,,29120
29121,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَن حَسَنٍ ، عَنْ لَیْثٍ ، عَن طَاوُوسٍ ؛ فِی الْجَارِیَۃِ تَکُونُ بَیْنَ الرَّجُلَیْنِ ، فَیَطَؤُہَا أَحَدُہُمَا ، قَالَ : عَلَیْہِ الْعُقْرُ بِالْحِصَّۃِ۔",,,29121
29122,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ إِسْمَاعِیلَ بْنِ سَالِمٍ ، عَنِ الْحَکَمِ ؛ أَنَّہُ قَالَ فِی رَجُلٍ وَطِئَ جَارِیَۃً مِنَ الْفَیْئِ ، قَالَ : لَیْسَ عَلَیْہِ حَدٌّ ، لَہُ فِیہَا نَصِیبٌ۔",,,29122
29123,"حَدَّثَنَا عَبْدَۃُ، عَنْ سَعِیدٍ، عَنْ قَتَادَۃَ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ، قَالَ: لَیْسَ عَلَیْہِ حَدٌّ، إِذَا کَانَ لَہُ فِیہَا نَصِیبٌ۔",,,29123
29124,حَدَّثَنَا وَکِیعٌ ، عَن مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ بُکَیْرِ بْنِ دَاوُد ؛ أَنَّ عَلِیًّا أَقَامَ عَلَی رَجُلٍ وَقَعَ عَلَی جَارِیَۃٍ مِنَ الْخُمُسِ الْحَدَّ۔,,,29124
29125,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : إِذَا کَانَ لَہُ فِی الْفَیْئِ شَیْئٌ ، عُزِّرَ وَتُقَوَّمُ عَلَیْہِ، وَکَذَلِکَ فِی جَارِیَۃٍ بَیْنَہُ وَبَیْنَ رَجُلٍ۔",,,29125
29126,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی بِشْرٍ ، عَن حَبِیبِ بْنِ سَالِمٍ ؛ أَنَّ رَجُلاً وَقَعَ بِجَارِیَۃِ امْرَأَتِہِ ، فَأَتَتِ امْرَأَتُہُ النُّعْمَانَ بْنَ بَشِیرٍ فَأَخْبَرَتْہُ ، فَقَالَ : أَمَا إِنَّ عَندِی فِی ذَلِکَ خَبَرًا شَافِیًا ، أُحَدِّثْہُ عَن رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنْ کُنْتِ أَذِنْتِ لَہُ جَلَدْتہ مِئَۃً ، وَإِنْ کُنْت لَمْ تَأْذَنِی لَہُ رَجَمْتَہُ۔ (ترمذی 1452۔ احمد 277)",,,29126
29127,"حَدَّثَنَا عَلِی ابْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَن عِکْرِمَۃَ ، قَالَ : جَائَتِ امْرَأَۃٌ إِلَی عَلِیٍّ ، فَقَالَتْ : إِنَّ زَوْجِی وَقَعَ عَلَی وَلِیدَتِی ، قَالَ : إِنْ تَکُونِی صَادِقَۃً رَجَمْنَاہُ ، وَإِنْ تَکُونِی کَاذِبَۃً جَلَدْنَاکِ ، ثُمَّ تَضَرَّبَ النَّاسُ حَتَّی اخْتَلَطُوا ، فَذَہَبَتِ الْمَرْأَۃُ۔",,,29127
29128,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَن مُبَارَکِ بْنِ عُمَارَۃَ ، قَالَ : جَائَتِ امْرَأَۃٌ إِلَی عَلِیٍّ ، فَقَالَتْ : یَا وَیْلَہَا ، إِنَّ زَوْجَہَا وَقَعَ عَلَی جَارِیَتِہَا ، فَقَالَ : إِنْ کُنْتِ صَادِقَۃً رَجَمْنَاہُ ، وَإِنْ تَکُونِی کَاذِبَۃً جَلَدْنَاکِ۔",,,29128
29129,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ مَکْحُولٍ، قَالَ: قَالَ عُمَرُ: لاَ أُوتَی بِرَجُلٍ وَقَعَ عَلَی جَارِیَۃِ امْرَأَتِہِ، إِلاَّ فَعَلْتُ وَفَعَلْتُ۔",,,29129
29130,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَابْنِ سِیرِینَ ؛ کَانَا إِذَا سُئِلاَ عَنِ الرَّجُلِ یَقَعُ عَلَی جَارِیَۃِ امْرَأَتِہِ یَتْلُوَانِ ہَذِہِ الآیَۃَ : {وَالَّذِینَ ہُمْ لِفُرُوجِہِمْ حَافِظُونَ إِلاَّ عَلَی أَزْوَاجِہِمْ ، أَوْ مَا مَلَکَتْ أَیْمَانُہُمْ فَإِنَّہُمْ غَیْرُ مَلُومِینَ}۔",,,29130
29131,"حَدَّثَنَا وَکِیعٌ ، عَنْ بَشِیرِ بْنِ سَلْمَانَ ، قَالَ : سَمِعْتُ إِبْرَاہِیمَ ، یَقُولُ : تَعْزِیرٌ وَلاَ حَدَّ۔",,,29131
29132,حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ سِمَاکٍ ، عَنْ مَعْبَدٍ ، وَعُبَیْدٍ بَنِی حُمْرَانَ ، عَنِ ابْنِ مَسْعُودٍ ؛ أَنَّہُ ضَرَبَہُ دُونَ الْحَدِّ۔,,,29132
29133,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، قَالَ : قَالَ عَلْقَمَۃُ : مَا أُبَالِی وَقَعْتُ عَلَی جَارِیَۃِ امْرَأَتِی ، أَوْ جَارِیَۃِ عَوْسَجَۃَ ، رَجُلٍ مِنَ الْحَیِّ۔",,,29133
29134,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی مَیْسَرَۃَ ؛ فِی رَجُلٍ یَأْتِی جَارِیَۃَ امْرَأَتِہِ ، أَنَّہُ قَالَ : مَا أُبَالِی أَتَیْتُہَا ، أَوْ جَارِیَۃً مِنَ الطَّرِیقِ۔",,,29134
29135,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : عَلَیْہِ الْحَدُّ۔",,,29135
29136,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَامِرٍ ، عَنْ سَالِمٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ عُمَرُ : لَوْ أُتِیتُ بِرَجُلٍ وَقَعَ عَلَی جَارِیَۃِ امْرَأَتِہِ لَرَجَمْتُہُ۔",,,29136
29137,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أخْبَرَنَا ابْنُ أَبِی عَرُوبَۃَ ، عَنْ إِیَاسِ بْنِ مُعَاوِیَۃَ ، عَن نَافِعٍ ، قَالَ : جَائَتْ جَارِیَۃٌ إِلَی عُمَرَ ، فَقَالَتْ : یَا أَمِیرَ الْمُؤْمِنِینَ ، إِنَّ الْمُغِیرَۃَ یَطَؤُنِی ، وَإِنَّ امْرَأَتَہُ تَدْعُونِی زَانِیَۃً ، فَإِنْ کُنْتُ لَہَا فَانْہَہُ عَنْ غَشَیَانِی ، وَإِنْ کُنْتُ لَہُ فَانْہَ امْرَأَتَہُ عَن قَذْفِی ، فَأَرْسَلَ إِلَی الْمُغِیرَۃِ ، فَقَالَ : تَطَأُ ہَذِہِ الْجَارِیَۃَ ؟ قَالَ : نَعَمْ ، قَالَ : مِنْ أَیْنَ ؟ قَالَ : وَہَبَتْہَا لِی امْرَأَتِی ، قَالَ : وَاللَّہِ لَئِنْ لَمْ تَکُنْ وَہَبَتْہَا لَکَ لاَ تَرْجِعُ إِلَی أَہْلِکَ إِلاَّ مَرْجُومًا ، ثُمَّ ، وَقَالَ : انْطَلِقَا إِلَی امْرَأَۃِ الْمُغِیرَۃِ فَأَعْلِمَاہَا : لَئِنْ لَمْ تَکُونِی وَہَبْتِہَا لَہُ لَنَرْجُمَنَّہُ ، قَالَ : فَأَتَیَاہَا فَأَخْبِرَاہَا ، فَقَالَتْ : یَا لَہْفَاہُ ، أَیُرِیدُ أَنْ یَرْجُمَ بَعْلِی ، لاَہَا اللہِ إِذًا ، لَقَدْ وَہَبْتُہَا لَہُ ، قَالَ : فَخَلَّی عَنْہُ۔",,,29137
29138,"( حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیم ، قَالَ : أَتَی رَجُلٌ ابْنَ مَسْعُودٍ ، فَقَالَ : إِنِّی وَقَعْت عَلَی جَارِیَۃِ امْرَأَتِی ، فَقَالَ : قَدْ سَتَرَ اللَّہُ عَلَیْک ، فَاسْتَتِرْ ، فَبَلَغَ ذَلِکَ عَلِیًّا ، فَقَالَ : لَوْ أَتَانِی الَّذِی أَتَی ابْنَ أُمِّ عَبْدٍ ، لَرَضَخْتُ رَأْسَہُ بِالْحِجَارَۃِ۔",,,29138
29139,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنِ الْہَیْثَمِ بْنِ بَدْرٍ ، عَن حُرْقُوسٍ ، عَنْ عَلِیٍّ ؛ أَنَّ رَجُلاً وَقَعَ عَلَی جَارِیَۃِ امْرَأَتِہِ ، فَدَرَأَ عَنہُ الْحَدَّ۔ (عبدالرزاق 1348),,,29139
29140,"حَدَّثَنَا وَکِیعٌ ، عَنْ زَکَرِیَا ، عَنِ الشَّعْبِیِّ ، عَنْ عَبْدِ اللہِ ؛ أَنَّہُ قَالَ : لاَ حَدَّ عَلَیْہِ۔",,,29140
29141,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ ، قَالَ : جَائَ رَجُلٌ إِلَی عَبْدِ اللہِ ، فَقَالَ : إِنِّی وَقَعْتُ عَلَی جَارِیَۃِ امْرَأَتِی ، فَقَالَ : اتَّقِ اللَّہَ ، وَلاَ تَعُدْ۔",,,29141
29142,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَن مَنْصُورٍ ، عَن رِبْعِیٍّ ، عَن عُقْبَۃَ بْنِ جَبَّار ، عَنْ عَبْدِ اللہِ ، قَالَ : لاَ حَدَّ عَلَیْہِ۔",,,29142
29143,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ الْقَطَّانُ ، عَنْ سُفْیَانَ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ، عَنْ عَامِرِ بْنِ مَطَرٍ ، عَنْ عَبْدِ اللہِ ؛ فِی الرَّجُلِ یَقَعُ عَلَی جَارِیَۃِ امْرَأَتِہِ ، قَالَ : إِنَ اسْتَکْرَہَہَا فَہِیَ حُرَّۃٌ ، وَعَلَیْہِ مِثْلُہَا لِسَیِّدَتِہَا ، وَإِنْ کَانَتْ طَاوَعَتْہُ فَہِیَ لَہُ ، وَعَلَیْہِ مِثْلُہَا لِسَیِّدَتِہَا۔",,,29143
29144,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ جَرِیرٍ ، عَنْ قَیْسٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ حَدَّ عَلَیْہِ۔",,,29144
29145,حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، عَنْ سَلَمَۃَ بْنِ مَحَبِّقٍ ؛ أَنَّ رَجُلاً وَقَعَ عَلَی جَارِیَۃِ امْرَأَتِہِ، فَدَرَأَ عَنہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْحَدَّ۔ (ابوداؤد 4456۔ احمد 467),,,29145
29146,"حَدَّثَنَا أَبُو مُحَمَّدٍ عَبْدُ اللہِ بْنُ یُونُسَ، قَالَ: حدَّثَنَا أَبُو عَبْدِالرَّحْمَنِ بَقِیُّ بْنُ مَخْلَدٍ، قَالَ: حَدَّثَنَا أَبُوبَکْرٍ، قَالَ:\n\n حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّ امْرَأَۃً تَزَوَّجَتْ فِی عِدَّتِہَا ، فَضَرَبَہَا عُمَرُ تَعْزِیرًا دُونَ الْحَدِّ۔",,,29146
29147,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، قَالَ : قُلْتُ لِسَعِیدِ بْنِ الْمُسَیَّبِ : إِنْ تَزَوَّجَہَا فِی عِدَّتِہَا عَمْدًا ؟ قَالَ : یُقَامُ عَلَیْہَا الْحَدُّ۔",,,29147
29148,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ؛ أَنَّ مَرْوَانَ جَلَدَہُمَا أَرْبَعِینَ أَرْبَعِینَ ، وَفَرَّقَ بَیْنَہُمَا ، فَقَالَ لَہُ قبیصَۃُ بْنُ ذُؤَیْبٍ : لَوْ خَفَّفْتَ فَجَلَدْتَہُمَا عِشْرِینَ عِشْرِینَ۔",,,29148
29149,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ (ح) وَعَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ؛فِی امْرَأَۃٍ نَکَحَتْ فِی عِدَّتِہَا ، قَالاَ : لَیْسَ عَلَیْہَا حَدٌّ۔",,,29149
29150,"حَدَّثَنَا شَرِیکٌ، عَن مَنْصُورٍ، عَنْ إِبْرَاہِیمَ، قَالَ: لاَ یُقَامُ عَلَی أَہْلِ الْکِتَابِ حَدٌّ فِی شُرْبِ خَمْرٍ، وَلاَ زِنًی۔",,,29150
29151,"حَدَّثَنَا وَکِیعٌ، عَنْ شُعْبَۃَ ، عَنْ عَمْرٍو ، عَن مُجَاہِدٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ: لَیْسَ عَلَی أَہْلِ الْکِتَابِ حَدٌّ۔",,,29151
29152,حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ رَجَائٍ ، عَنْ قَبِیصَۃَ بْنِ ذُؤَیْبٍ ؛ أَنَّ رَجُلاً وَقَعَ عَلَی جَارِیَتِہِ وَلَہَا زَوْجٌ ، فَضَرَبَہُ عُمَرُ بْنُ الْخَطَّابِ مِئَۃً نَکَالاً۔,,,29152
29153,"حَدَّثَنَا شَرِیکٌ ، عَنْ جَامِعٍ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، قَالَ : أُتِیَ عُمَرُ بِرَجُلٍ وَقَعَ عَلَی أَمَتِہِ وَقَدْ زَوَّجَہَا ، فَضَرَبَہُ ضَرْبًا ، وَلَمْ یَبْلُغْ بِہِ الْحَدَّ۔",,,29153
29154,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : إِذَا وَقَعَ الرَّجُلُ عَلَی أَمَتِہِ وَلَہَا زَوْجٌ ، فَإِنَّہُ یُجْلَدُ مِئَۃً ، أُحْصِنَ ، أَوْ لَمْ یُحْصَنْ ، فَإِنْ حَمَلَتْ ، فَالْوَلَدُ لِلْفِرَاشِ۔",,,29154
29155,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ حَمَّادًا عَنِ الرَّجُلِ یَسْرِقُ مِنْ بَیْتِ الْمَالِ ؟ قَالَ : یُقْطَعُ ، وَقَالَ الْحَکَمُ : لاَ یُقْطَعُ۔",,,29155
29156,"حَدَّثَنَا وَکِیعٌ ، عَنِ الْمَسْعُودِیِّ ، عَنِ الْقَاسِمِ ؛ أَنَّ رَجُلاً سَرَقَ مِنْ بَیْتِ الْمَالِ ، فَکَتَبَ فِیہِ سَعْدٌ إِلَی عُمَرَ ، فَکَتَبَ عُمَرُ إِلَی سَعْدٍ : لَیْسَ عَلَیْہِ قَطْعٌ ، لَہُ فِیہِ نَصِیبٌ۔",,,29156
29157,"حَدَّثَنَا وَکِیعٌ، عَنْ شُعْبَۃَ، قَالَ: سَأَلْتُ الْحَکَمَ عن الرجل یَسْرِقُ مِنْ بَیْتِ الْمَالِ؟ قَالَ: لَیْسَ عَلَیْہِ قَطْعٌ۔",,,29157
29158,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ فِی الرَّجُلِ یَسْرِقُ مِنَ الْمَغْنَمِ ، قَالَ : لَیْسَ عَلَیْہِ حَدٌّ ، إِذَا کَانَ لَہُ فِیہِ نَصِیبٌ۔",,,29158
29159,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : إِذَا سَرَقَ الرَّجُلُ مِنَ الْغَنِیمَۃِ ، وَلَہُ فِیہَا شَیْئٌ لَمْ یُقْطَعْ ، فَإِنْ سَرَقَ مِنْہَا وَلَیْسَ لَہُ فِیہَا نَصِیبٌ قُطِعَ۔",,,29159
29160,"حَدَّثَنَا شَرِیکٌ ، عَنْ سِمَاکٍ ، عَنِ ابن عبَیْدِ بْنِ الأَبْرَصِ ؛ أَنَّ عَلِیًّا کَانَ یَقْسِمُ سِلاَحًا فِی الرَّحْبَۃِ ، فَأَخَذَ رَجُلٌ مِغْفَرًا ، فَالْتَحَفَ عَلَیْہِ ، فَوَجَدَہُ رَجُلٌ ، فَأَتَی بِہِ عَلِیًّا ، فَلَمْ یَقْطَعْہُ ، وَقَالَ : لَہُ فِیہِ شِرْکٌ۔",,,29160
29161,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنِ السَّائِبِ بْنِ یَزِیدَ ؛ أَنَّ عَبْدَ اللہِ بْنَ عَمْرِو بْنِ الْحَضْرَمِیِّ ، قَالَ : أَتَیْتُ عُمَرَ بِغُلاَمٍ لِی ، فَقُلْتُ : اقْطَعْہُ ، قَالَ : وَمَا لَہُ ؟ قُلْتُ : سَرَقَ مِرْآۃً لاِمْرَأَتِی خَیْرٌ مِنْ سِتِّینَ دِرْہَمًا ، قَالَ عُمَرُ : غُلاَمُکُمْ یَسْرقُ مَتَاعَکُمْ۔",,,29161
29162,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَنْ ہَمَّامٍ ، عَنْ عَمْرِو بْنِ شُرَحْبِیلَ ،قَالَ : جَائَ مَعْقِلٌ الْمُزَنِیّ إِلَی عَبْدِ اللہِ ، فَقَالَ : غُلاَمِی سَرَقَ قَبَائِی ، فَاقْطَعُہُ ؟ قَالَ عَبْدُ اللہِ : لاَ ، مَالِکُ بَعْضُہُ فِی بَعْضٍ۔",,,29162
29163,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ؛ أَنَّ عَلِیًّا ، قَالَ : إِذَا سَرَقَ عَبْدِی مِنْ مَالِی لَمْ أَقْطَعْہُ۔",,,29163
29164,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : حَدَّثَنَا سَلَیْمُ بْنُ حَیَّانَ ، قَالَ : حدَّثَنَا سَعِیدُ بْنُ مِینَائَ ، قَالَ : کَانَ عَبْدُ اللہِ بْنُ الزُّبَیْرِ یَلِی صَدَقَۃَ الزُّبَیْرِ ، وَکَانَتْ فِی بَیْتٍ لاَ یَدْخُلُہُ أَحَدٌ غَیْرُہُ ، وَغَیْرُ جَارِیَۃٍ لَہُ ، فَفَقَدَ شَیْئًا مِنَ الْمَالِ، فَقَالَ لِلْجَارِیَۃِ : مَا کَانَ یَدْخُلُ ہَذَا الْبَیْتَ غَیْرِی وَغَیْرُک ، فَمَنْ أَخَذَ ہَذَا الْمَالَ ؟ فَأَقَرَّتِ الْجَارِیَۃُ ، فَقَالَ لِی : یَا سَعِیدُ ، انْطَلِقْ بِہَا فَاقْطَعْ یَدَہَا ، فَإِنَّ الْمَالَ لَوْ کَانَ لِی لَمْ یَکُنْ عَلَیْہَا قَطْعٌ۔",,,29164
29165,"حَدَّثَنَا غُنْدَرٌ، عَنْ شُعْبَۃَ، قَالَ: سَأَلْتُ حَمَّادًا، وَالْحَکَمَ عَنِ الرَّجُلِ یَقَعُ عَلَی جَارِیَۃِ أُمِّہِ؟ قَالاَ: عَلَیْہِ الْحَدُّ۔",,,29165
29166,"حَدَّثَنَا غُنْدَرٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَن ، قَالَ : لَیْسَ عَلَیْہِ حَدٌّ۔",,,29166
29167,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَلِیِّ بْنِ الأَقْمَرِ ، عَنْ یَزِیدَ بْنِ أَبِی کَبْشَۃَ ؛ أَنَّ أَبَا الدَّرْدَائِ أُتِیَ بِامْرَأَۃٍ قَدْ سَرَقَتْ ، فَقَالَ لَہَا : سَلامَۃُ ، أَسَرَقْتِ ؟ قُولِی : لاَ۔",,,29167
29168,"حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنْ مَوْلًی لأَبِی مَسْعُودٍ ، عَنْ أَبِی مَسْعُودٍ ، قَالَ : أُتِیَ بِرَجُلٍ سَرَقَ ، فَقَالَ : أَسَرَقْتَ ؟ قُلْ : وَجَدْتُہُ ، قَالَ : وَجَدْتُہُ ، فَخَلَّی سَبِیلَہُ۔",,,29168
29169,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا سَعِیدُ بْنُ أَبِی عَرُوبَۃَ ، عَنْ سُلَیْمَانِ النَّاجِی ، عَنْ أَبِی الْمُتَوَکِّلِ ؛ أَنَّ أَبَا ہُرَیْرَۃَ أُتِیَ بِسَارِقٍ ، وَہُوَ یَوْمَئِذٍ أَمِیرٌ ، فَقَالَ : أَسَرَقْتَ ؟ أَسَرَقْتَ ؟ قُلْ : لاَ ، لاَ مَرَّتَیْنِ ، أَوْ ثَلاَثًا۔",,,29169
29170,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ یَزِیدَ بْنِ خُصَیْفَۃَ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ ثَوْبَانَ؛ أَنَّ رَجُلاً سَرَقَ شَمْلَۃً، فَأُتِیَ بِہِ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالُوا : یَا رَسُولَ اللہِ ، ہَذَا سَرَقَ شَمْلَۃً ، فَقَالَ : مَا إِخَالَہُ سَرَقَ۔\n\n(عبدالرزاق 1383۔ دارقطنی 102)",,,29170
29171,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، عَنْ غَالِبٍ أَبِی الْہُذَیْلِ ، قَالَ : سَمِعْتُ سُبَیْعًا أَبَا سَالِمٍ ، یَقُولُ : شَہِدْتُ الْحَسَنَ بْنَ عَلِیٍّ ، وَأُتِیَ بِرَجُلٍ أَقَرَّ بِسَرِقَۃٍ ، فَقَالَ لَہُ الْحَسَنُ : لَعَلَّک اخْتَلَسْتَ ؟ لِکَیْ یَقُولَ : لاَ۔",,,29171
29172,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عِکْرِمَۃَ بْنِ خَالِدٍ ، قَالَ : أُتِیَ عُمَرُ بِسَارِقٍ قَدِ اعْتَرَفَ ، فَقَالَ عُمَرُ: إِنِّی لأَرَی یَدَ رَجُلٍ مَا ہِیَ بِیَدِ سَارِقٍ، قَالَ الرَّجُلُ: وَاللَّہِ مَا أَنَا بِسَارِقٍ، فَأَرْسَلَہُ عُمَرُ وَلَمْ یَقْطَعْہُ۔",,,29172
29173,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : کَانَ مَنْ مَضَی یُؤْتَی بِالسَّارِقِ ، فَیَقُولُ : أَسَرَقْتَ ؟ وَلاَ أَعْلَمہُ إِلاَّ سَمَّی أَبَا بَکْرٍ وَعُمَرَ۔",,,29173
29174,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : حدَّثَنِی مِسْکِینٌ ، رَجُلٌ مِنْ أَہْلِی ، قَالَ : شَہِدْتُ عَلِیًّا أُتِیَ بِرَجُلٍ وَامْرَأَۃٍ وُجِدَا فِی خَرِبَۃٍ ، فَقَالَ لَہُ عَلِیٌّ : أَقَرُبْتَہَا ؟ فَجَعَلَ أَصْحَابُ عَلِیٍّ یَقُولُونَ لَہُ : قُلْ : لاَ ، فَقَالَ : لاَ ، فَخَلَّی سَبِیلَہُ۔",,,29174
29175,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ مَعْمَرٍ ، عَنْ یَحْیَی ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ لِمَاعِزِ بْنِ مَالِکٍ : لَعَلَّک قَبَّلْتَ ، أَوْ لَمَسْتَ ، أَوْ بَاشَرْتَ ۔ (احمد 255۔ بخاری 6824)",,,29175
29176,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ مُحَمَّدِ بْنِ یَحْیَی بْنِ حَبَّانَ ، عَنْ رَافِعِ بْنِ خَدِیجٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ قَطْعَ فِی ثُمَّرٍ ، وَلاَ کَثَرٍ۔ (احمد 463۔ مالک 839)",,,29176
29177,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، قَالَ : لَیْسَ فِی شَیْئٍ مِنَ الْحَیَوَانِ قَطْعٌ حَتَّی یَأْوِیَ الْمُرَاحَ ، وَلَیْسَ فِی شَیْئٍ مِنَ الثِّمَارِ قَطْعٌ حَتَّی یَأْوِیَ الْجَرِینَ۔",,,29177
29178,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْحَاقَ بْنِ سَعِیدٍ ، عَنْ أَبِیہِ ، عَنِ ابْنِ عُمَرَ ، قَالَ : لَیْسَ فِی شَیْئٍ مِنَ الثِّمَارِ قَطْعٌ ، إِلاَّ مَا أَوَی الْجَرِینَ ، وَلَیْسَ فِی شَیْئٍ مِنَ الْمَاشِیَۃِ قَطْعٌ ، إِلاَّ فِیمَا آوَی الْمُرَاحَ۔",,,29178
29179,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ مَعْمَرٍ ، قَالَ : قَالَ یَحْیَی بْنُ أَبِی کَثِیرٍ ، قَالَ : قَالَ عُمَرُ : لاَ یُقْطَعُ فِی عِذْقٍ ، وَلاَ فِی عَامِ سَنَۃٍ۔",,,29179
29180,حَدَّثَنَا وَکِیعٌ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، وَالسُّرِیِّ بْنِ یَحْیَی ، عَنِ الْحَسَنِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أُتِیَ بِرَجُلٍ سَرَقَ طَعَامًا ، فَلَمْ یَقْطَعْہُ۔ (ابوداؤد 245۔ عبدالرزاق 18915),,,29180
29181,حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ بْنِ عَبْدِ الْمَلِکِ ، وَعَمْرٍو ، عَنِ الْحَسَنِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أُتِیَ بِرَجُلٍ سَرَقَ طَعَامًا ، فَلَمْ یَقْطَعْہُ۔,,,29181
29182,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ عَنِ الرَّجُلِ یَسْرِقُ الطَّعَامَ ، أَوِ الْحِمَارَ مِنَ الصَّحْرَائِ ؟ فَقَالَ : لَیْسَ عَلَیْہِ قَطْعٌ۔",,,29182
29183,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَمِعْتُ عَبْدَ الرَّحْمَن بْنَ الْقَاسِمِ ، قَالَ : قَطَعَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ فِی مُدٍّ ، أَوْ أَمْدَادٍ مِنْ طَعَامٍ۔",,,29183
29184,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ حسان بْنِ زَاہِرٍ ، عَنْ حُصَیْنِ بْنِ حُدَیرٍ ، قَالَ : سَمِعْتُ عُمَرَ وہو یَقُولُ : لاَ قَطْعَ فِی عِذْقٍ ، وَلاَ فِی عَامِ سَنَۃٍ۔",,,29184
29185,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ؛ أَنَّہُ قَالَ: لَیْسَ فِی الثَمَرَۃِ قَطْعٌ، وَلاَ فِی الْمَاشِیَۃِ الرَّاعِیَۃِ، وَلَکِنْ فِیہَا نَکَالٌ وَتَضْعِیفُ الْغُرْمِ ، فَإِذَا آوَاہا الْمُرَاحُ ، أَوِ الْجَرِینُ ، یُقْطَعُ إِذَا سَرَقَ قَدْرَ رُبْعِ دِینَارٍ۔",,,29185
29186,حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ حَکِیمِ بْنِ حَکِیمِ بْنِ عَبَّادِ بْنِ حُنَیْفٍ ، عَنِ النُّعْمَانِ بْنِ مُرَّۃَ الزُّرَقِیِّ ؛ أَنَّ عَلِیًّا قَطَعَ سَارِقًا مِنَ الْخَصْرِ ، خَصْرِ الْقَدَمِ۔,,,29186
29187,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ إِسْمَاعِیلَ الْحَنَفِیِّ ، عَنْ أُمِّ رَزِینٍ ، قَالَتْ : سَمِعْتُ ابْنَ عَبَّاسٍ یَقُولُ : أَیَعْجِزُ أُمَرَاؤُنَا ہَؤُلاَئِ أَنْ یَقْطَعُوا کَمَا قَطَعَ ہَذَا الأَعْرَابِیُّ ، یَعْنِی نَجْدَۃَ ، فَلَقَدْ قَطَعَ فَمَا أَخْطَأَ ، یَقْطَعُ الرِّجْلَ ، وَیَذَرُ عَاقِبَہَا۔",,,29187
29188,"حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، وَعَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : سُئِلَ عَنِ الْقَطْعِ ؟ فَقَالَ : أَمَّا الرِّجْلُ ، فَیُتْرَکُ لَہُ عَقِبُہُ۔",,,29188
29189,"حَدَّثَنَا عَبْدَۃُ، عَنِ الْعَلاَئِ بْنِ عَبْدِالْکَرِیمِ، عَنْ أَبِی جَعْفَرٍ، قَالَ: الرِّجْلُ تُقْطَعُ مِنْ وَسَطِ الْقَدَمِ مِنْ مَفْصِلٍ۔",,,29189
29190,حَدَّثَنَا وَکِیعٌ ، عَنِ الْعَلاَئِ ، عَنْ أَبِی جَعْفَرٍ ؛ بِنَحْوِہِ۔,,,29190
29191,حَدَّثَنَا مُحَمَّدُ بْنُ مَیْسَرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، عنْ عِکْرِمَۃَ ؛ أَنَّ عُمَرَ بْنَ الْخَطَّابِ قَطَعَ الْیَدَ مِنَ الْمَفْصِلِ ، وَقَطَعَ عَلِیٌّ الْقَدَمَ ، وَأَشَارَ عَمْرٌو إِلَی شَطْرِہَا۔,,,29191
29192,"حَدَّثَنَا وَکِیعٌ ، عَنْ مَسَرَّۃَ بْنِ مَعْبَدٍ اللَّخْمِیِّ ، قَالَ : سَمِعْتُ عَدِیَّ بْنِ عَدِیٍّ یُحَدِّثُ ، عَنْ رَجَائِ بْنِ حَیْوَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَطَعَ رَجُلاً مِنَ الْمَفْصِلِ۔ (270)",,,29192
29193,"حَدَّثَنَا وَکِیعٌ ، عَنْ سَمُرَۃَ أَبِی عَبْدِ الرَّحْمَنِ ، قَالَ : رَأَیْتُ بِالْحِیرَۃ مَقْطُوعًا مِنَ الْمَفْصِلِ ، فَقُلْتُ : مَنْ قَطَعَک ؟ قَالَ : قَطَعَنی الرَّجُلُ الصَّالِحُ عَلِیٌّ ، أَمَا إِنَّہُ لَمْ یَظْلِمْنِی۔",,,29193
29194,حَدَّثَنَا أَبُو سَعْدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، عَنْ عِکْرِمَۃَ ؛ أَنَّ عُمَرَ قَطَعَ الْیَدَ مِنَ الْمَفْصِلِ۔,,,29194
29195,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ یَزِیدَ بْنِ خُصَیْفَۃَ ، عَنْ ابْنِ ثَوْبَانٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَطَعَ یَدَ رَجُلٍ ، ثُمَّ حَسَمَہُ۔,,,29195
29196,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ یَزِیدَ بْنِ خُصَیْفَۃَ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ ، رفعہ ؛ مِثْلَہُ۔,,,29196
29197,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَمْرِو بْنِ أَبِی سُفْیَانَ ؛ أَنَّ ابْنَ الزُّبَیْرِ أُتِیَ بِسَارِقٍ ، فَقَطَعَہُ ، فَقَالَ لَہُ أَبَانُ بْنُ عُثْمَانَ : احْسِمْہُ ، فَقَالَ : إِنَّک بِہِ لَرَحِیمٌ ، قَالَ : لاَ ، وَلَکِنَّہُ مِنَ السُّنَّۃِ۔",,,29197
29198,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ، قَالَ : مِنَ السُّنَّۃِ حَسْمُ السَّارِقِ۔",,,29198
29199,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ عَبْدِ الْمَلِکِ بْنِ أَبْجَرَ ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنْ حُجِّیَّۃَ ؛ أَنَّ عَلِیًّا کَانَ یَقْطَعُ اللُّصُوصَ وَیَحْسِمُہُمْ وَیَحْبِسُہُمْ وَیُدَاوِیہِمْ ، فَإِذَا بَرَؤُوا ، قَالَ : أرْفَعُوا أَیْدِیَکُمْ ، فَیَرْفَعُونَہَا کَأَنَّہَا أُیُورُ الْحُمُرِ ، ثُمَّ یَقُولُ : مَنْ قَطَعَکُمْ ؟ فَیَقُولُونَ : عَلِیٌّ ، فَیَقُولُ : وَلِمَ ؟ فَیَقُولُونَ : إِنَّا سَرَقْنَا ، فَیَقُولُ : اللَّہُمَّ اشْہَدْ ، اللَّہُمَّ اشْہَدْ ، اذْہَبُوا۔",,,29199
29200,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ زُہَیْرِ بْنِ مُحَمَّدِ ، عَنْ یَزِیدَ بْنِ خُصَیْفَۃَ ، قَالَ : أُتِیَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ بِرَجُلٍ قد سَرَقَ طَیْرًا ، فَاسْتَفْتَی فِی ذَلِکَ السَّائِبَ بْنَ یَزِیدَ ، فَقَالَ : مَا رَأَیْتُ أَحَدًا قَطَعَ فِی الطَّیْرِ ، وَمَا عَلَیْہِ فِی ذَلِکَ قَطْعٌ ، فَتَرَکَہُ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ ، فَلَمْ یَقْطَعْہُ۔",,,29200
29201,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَبْدِ اللہِ بْن یَسَارٍ ، قَالَ : أُتِیَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ فِی رَجُلٍ سَرَقَ دَجَاجَۃً ، فَأَرَادَ أَنْ یَقْطَعَہُ ، فَقَالَ لَہُ أَبُو سَلَمَۃَ بْنُ عَبْدِ الرَّحْمَنِ : قَالَ عُثْمَانُ : لاَ قَطْعَ فِی الطَّیْرِ۔",,,29201
29202,حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ أَبِی خَالِدٍ ، عَنْ رَجُلٍ ، عَنْ عَلِیٍّ ؛ أَنَّہُ کَانَ لاَ یَقْطَعُ فِی الطَّیْرِ۔,,,29202
29203,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : سَمِعْتُ بَعْضَ مَنْ أَرْضَی ، یَقُولُ : لاَ قَطْعَ فِی بَازٍ سُرِقَ ، وَإِنْ کَانَ ثَمَنُہُ دِینَارًا ، أَوْ أَکْثَرَ مِنْ ذَلِکَ۔",,,29203
29204,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، قَالَ : کَانَ یَقُولُہُ۔",,,29204
29205,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : أُتِیَ مَرْوَانُ بْنُ الْحَکَمِ بِقَوْمٍ یَخْتَفُونَ الْقُبُورَ ، یَعْنِی یَنْبُشُونَ ، فَضَرَبَہُمْ وَنَفَاہُمْ ، وَأَصْحَابُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مُتَوَافِرُونَ۔",,,29205
29206,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الزُّہْرِیِّ ، قَالَ : أُخِذَ نَبَّاشٌ فِی زَمَانِ مُعَاوِیَۃَ ، زَمَانَ کَانَ مَرْوَانُ عَلَی الْمَدِینَۃِ ، فَسَأَلَ مَنْ کَانَ بِحَضْرَتِہِ مِنْ أَصْحَابِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِالْمَدِینَۃِ وَالْفُقَہَائِ ؟ فَلَمْ یَجِدُوا أَحَدًا قَطَعَہُ ، قَالَ : فَأَجْمَعَ رَأْیُہُمْ عَلَی أَنْ یَضْرِبَہُ ، وَیُطَافَ بِہِ۔",,,29206
29207,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ مَعْمَرٍ ، قَالَ : بَلَغَنِی أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ قَطَعَ نَبَّاشًا۔",,,29207
29208,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الْحَجَّاجِ ، عَنِ الْحَکَمِ ، عَنْ إِبْرَاہِیمَ ، وَالشَّعْبِیِّ ، قَالاَ : یُقْطَعُ سَارِقُ أَمْوَاتِنَا ، کَمَا یُقْطَعُ سَارِقُ أَحْیَائِنَا۔",,,29208
29209,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَاجٍ ، قَالَ : سَأَلْتُ عَطَائً عَنِ النَّبَّاشِ ؟ قَالَ : یُقْطَعُ۔",,,29209
29210,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ فِی النَّبَّاشِ ، قَالَ : ہُوَ بِمَنْزِلَۃِ السَّارِقِ ، یُقْطَعُ۔",,,29210
29211,"حَدَّثَنَا حَفْصٌ، عَنْ أَشْعَثَ، قَالَ: سَأَلْتُ الْحَسَنَ عَنِ النَّبَّاشِ؟ فَقَالَ: یُقْطَعُ، وَسَأَلْتُ الشَّعْبِیَّ؟ فَقَالَ: یُقْطَعُ۔",,,29211
29212,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، وَحَمَّادٍ ، عَنْ إِبْرَاہِیمَ ؛ فِی النَّبَّاشِ ، قَالَ : یُقْطَعُ۔",,,29212
29213,"حَدَّثَنَا جَرِیرٌ، عَنْ مُغِیرَۃَ، عَنْ حَمَّادٍ ، وَأَصْحَابِہِ ، قَالُوا: یُقْطَعُ النَّبَّاشُ ، لأَنَّہُ قَدْ دَخَلَ عَلَی الْمَیِّتِ بَیْتَہُ۔",,,29213
29214,"حَدَّثَنَا ابْنُ یَمَانٍ ، عَنْ شَیْخٍ ، عَنْ مَکْحُولٍ ، قَالَ : لاَ یُقْطَعُ ، إِلاَّ أَنْ یَکُونَ لِلْقَبْرِ بَابٌ۔",,,29214
29215,"حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ إِسْرَائِیلَ ، عَنْ عَبْدِ اللہِ بْنِ الْمُخْتَارِ ، عَنْ معاویۃ بْنِ قُرَّۃَ ، قَالَ : النَّبَّاشُ لِصٌّ ، فَاقْطَعْہُ۔",,,29215
29216,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حَجَّاجٍ ؛ أَنَّ مَسْرُوقًا ، وَإِبْرَاہِیمَ النَّخَعِیّ ، وَالشَّعْبِیَّ ، وَزَاذَانَ ، وَأَبَا زُرْعَۃَ بْنَ عَمْرِو بْنِ جَرِیرٍ ، کَانُوا یَقُولُونَ فِی النَّبَّاشِ : یُقْطَعُ۔",,,29216
29217,"حَدَّثَنَا شَیْخٌ لَقِیتُہُ بِمِنَی ، عَنْ رَوْحِ بْنِ الْقَاسِمِ ، عَنْ مُطَرِّفٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لَیْسَ عَلَی النَّبَّاشِ قَطْعٌ ، وَعَلَیْہِ شَبِیہٌ بِالْقَطْعِ۔",,,29217
29218,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَاجٍ ، عَنْ أَبِی مُصْعَبٍ عَطَائِ بْنِ أَبِی مَرْوَانَ ، عَنْ أَبِیہِ ؛ أَنَّ عَلِیًّا أُتِیَ بِالنَّجَاشِیَّ سَکْرَانًا مِنَ الْخَمْرِ فِی رَمَضَانَ ، فَتَرَکَہُ حَتَّی صَحَا ، ثُمَّ ضَرَبَہُ ثَمَانِینَ ، ثُمَّ أَمَرَ بِہِ إِلَی السِّجْنِ ، ثُمَّ أَخْرَجَہُ مِنَ الْغَدِ فَضَرَبَہُ عِشْرِینَ ، فَقَالَ : ثَمَانِینَ لِلْخَمْرِ ، وَعِشْرینَ لِجُرْأَتِکَ عَلَی اللہِ فِی رَمَضَانَ۔",,,29218
29219,"حَدَّثَنَا أَبُو الأَحْوصِ ، عَنْ أَبِی الْحَارِثِ التَّیْمِیِّ ، عَن أَبِی مَاجِدٍ الْحَنَفِیِّ ، قَالَ : کُنْتُ عِنْدَ عَبْدِ اللہِ بْنِ مَسْعُودٍ قَاعِدًا ، فَجَائَہُ رَجُلٌ مِنَ الْمُسْلِمیَن بِابْنِ أَخٍ لَہُ ، فَقَالَ لَہُ : یَا أَبَا عَبْدِ الرَّحْمَانَ ، ابْنُ أَخِی وَجَدْتُہُ سَکْرَانًا ، فَقَالَ عَبْدُ اللہِ : تَرْتِرُوہ ، وَمَزْمِزُوہ ، وَاستُنْکِہُوہ ، فَتُرْتِر ،وَمُزْمِز ، وَاستُنْکِہ ، فَوُجِدَ سَکْرَانًا ، فَدُفِعَ إِلَی السِّجْنِ ، فَلَمَا کَانَ الْغَدُ ، جِئْتُ وَجِیئَ بِہِ۔ (بیہقی 318)",,,29219
29220,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا سَکَرَ الإِنْسَانُ تُرِکَ حَتَّی یُفِیقَ ، ثُمَّ جُلِدَ۔",,,29220
29221,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنِ الشَّعْبِیِّ ، قَالَ : إِذَا سَکَرَ الإِمَامُ جُلِدَ وَہُوَ لاَ یَعْقِلُ ، فَإِِنَّہُ إِنْ عَقِلَ امْتَنَعَ۔",,,29221
29222,حَدَّثَنَا وَکِیعٌ، عَنِ ابْنِ أَبِی ذِئْبٍ، عَنِ الزُّہْرِیِّ، عَنِ السَّائِبِ بْنِ یَزِیدَ؛ أَنَّ عُمَرَ کَانَ یَضْرِبُ فِی الرِّیحِ۔,,,29222
29223,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَنْ عَلْقَمَۃَ ، قَالَ : قرَأَ عَبْدُ اللہِ سُورَۃَ یُوسُفَ بِحِمْصَ ، فَقَالَ رَجُلٌ : مَا ہَکَذَا أُنْزِلَتْ ، فَدَنَا مِنْہُ عَبْدُ اللہِ ، فَوَجَدَ مِنْہُ رِیحَ الْخَمْرِ ، فَقَالَ لَہُ : تُکَذِّبُ بِالْحَقِّ ، وَتَشْرَبُ الرِّجْسَ ، وَاللَّہِ ، لَہکَذَا أَقْرَأَنِیہَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، لاَ أَدَعُک حَتَّی أَحُدَّک ، فَجَلَدَہُ الْحَدَّ۔ (بخاری 5001۔ مسلم 552)",,,29223
29224,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنْ یَزِیدَ بْنِ الأَصَمِّ ؛ أَنَّ ذَا قَرَابَۃٍ لَمَیْمُونَۃَ دَخَلَ عَلَیْہَا ، فَوَجَدَتْ مِنْہُ رِیحَ شَرَابٍ ، فَقَالَتْ : لَئِنْ لَمْ تَخْرُجْ إِلَی الْمُسْلِمِینَ فَیَحُدُّونَک ، أَوْ یُطَہِّرُونَک ، لاَ تَدْخُلْ عَلَیَّ بَیْتِی أَبَدًا۔",,,29224
29225,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، قَالَ : کَتَبْتُ إِلَی ابْنِ الزُّبَیْرِ ، أَسْأَلُہُ عَنِ الرَّجُلِ یُوجَدُ مِنْہُ رِیحُ الشَّرَابِ ؟ فَقَالَ : إِنْ کَانَ مُدْمِنًا فَحُدَّہُ۔",,,29225
29226,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُحَمَّدِ بْنِ شَرِیکٍ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، قَالَ : أُتِیتُ بِرَجُلٍ وُجِدَتْ مِنْہُ رِیحُ الْخَمْرِ، وَأَنَا قَاضٍ عَلَی الطَّائِفِ ، فَأَرَدْتُ أَنْ أَضْرِبَہُ ، فَقَالَ : إِنَّمَا أَکَلْتُ فَاکِہَۃً ، فَکَتَبْتُ إِلَی ابْنِ الزُّبَیْرِ ، فَکَتَبَ إِلَیَّ : إِنْ کَانَ مِنَ الْفَاکِہَۃِ مَا یُشْبِہُ رِیحَ الْخَمْرِ ، فَادْرَأْ عَنْہُ۔",,,29226
29227,"حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، وَعَمْرِو بْنِ دِینَارٍ ، قَالاَ : لاَ حَدَّ فِی رِیحٍ۔",,,29227
29228,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ أَنَّہُ کَانَ لاَ یَرَی فِی الرِّیحِ حَدًّا۔,,,29228
29229,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ إِسْمَاعِیلَ بْنِ سُمَیْعٍ ، عَنْ مَالِکِ بْنِ عُمَیْرٍ الْحَنَفِیِّ ، قَالَ : أُتِیَ عُمَرُ بِابْنِ مَظْعُونٍ قَدْ شَرِبَ خَمْرًا ، فَقَالَ : مَنْ شُہُودُک ؟ قَالَ : فُلاَنٌ وَفُلاَنٌ ، وَعَتَّابُ بْنُ سَلَمَۃَ ، وَکَانَ یُسَمَّی عَتَّابُ الشَّیْخَ الصَّدُوقَ ، فَقَالَ : رَأَیْتُہُ یَقِیؤُہَا ، وَلَمْ أَرَہُ یَشْرَبُہَا ، فَجَلَدَہُ عُمَرُ الْحَدَّ۔",,,29229
29230,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ إِسْمَاعِیلَ بْنِ سُمَیْعٍ ، عَنْ مَالِکِ بْنِ عُمَیْرٍ ، عَنْ عَتَّابِ بْنِ سَلَمَۃَ ؛ أَنَّ عُمَرَ ضَرَبَہُ الْحَدَّ ، وَنَصَبَہُ لِلنَّاسِ ، إِلاَّ أَنَّہُ قَالَ : أُتِیَ بِحَفْصِ بْنِ عُمَرَ۔",,,29230
29231,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ سُئِلَ عَنِ الْحَلْقِ ؟ فَقَالَ : جَعَلَہُ اللَّہُ تَعَالَی نُسُکًا وَسُنَّۃً ، وَجَعَلَہُ النَّاسُ عُقُوبَۃً۔",,,29231
29232,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَوْزَاعِیِّ ، عَنْ رَوْحِ بْنِ یَزِید ، عَنْ بِشْرٍ ، عَنْ أبِیہِ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ: إِیَّایَ وَحَلْقَ الرَّأْسِ وَاللِّحْیَۃِ۔",,,29232
29233,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُحَمَّدِ بْنِ مُسْلِمٍ ، عَنْ إِبْرَاہِیمَ بْنِ مَیْسَرَۃَ ، قَالَ : حدَّثَنِی الرِّضَا ، یَعْنِی طَاوُوسًا ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ مَثَّلَ بِالشَّعْرِ فَلَیْسَ مِنَّا۔ (طبرانی 10977)",,,29233
29234,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُحَمَّدِ بْنِ مُسْلِمٍ ، عَنْ إِبْرَاہِیمَ بْنِ مَیْسَرَۃَ ، عَن طَاوُوسٍ ، قَالَ : جَعَلَہُ اللَّہُ طَہُورًا ، وَجَعَلْتُمُوہُ عُقُوبَۃً۔",,,29234
29235,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : حلْقُ الرَّأْسِ فِی الْعُقُوبَۃِ بِدْعَۃٌ۔",,,29235
29236,"حَدَّثَنَا عَائِذُ بْنُ حَبِیبٍ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ خِلاَسٍ ، قَالَ : جِیئَ بِرَجُلٍ مَعَہُ أَرْبَعَۃٌ ، فَشَہِدَ ثَلاَثَۃٌ مِنْہُمْ بِالزِّنَی ، وَلَمْ یَمْضِ الرَّابِعُ ، فَجَلَدَ عَلِیٌّ الثَّلاَثَۃَ ، وَجَزَّ رَأْسَ الْمَشْہُودِ عَلَیْہِ۔",,,29236
29237,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنْ مَکْحُولٍ ، وَالْوَلِیدِ بْنِ أَبِی مَالِکٍ ؛ أَنَّ عُمَرَ کَتَبَ فِی شَاہِدِ الزُّورِ : یُضْرَبُ أَرْبَعِینَ سَوْطًا ، وَیُسَخَّمُ وَجْہُہُ ، وَیُحْلَقُ رَأْسُہُ ، وَیُطَالُ حَبْسُہُ۔",,,29237
29238,"حَدَّثَنَا عُثْمَانُ بْنُ عُثْمَانَ ، عَنْ عُمَرَ بْنِ مُصْعَبٍ ، قَالَ : أُتِیَ عَبْدُ اللہِ بْنُ الزُّبَیْرِ بِرَجُلٍ مِنْ بَنِی تَمِیمٍ ، فَأَمَرَ بِحَلْقِہِ۔",,,29238
29239,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ أَشْعَثَ ، عَنْ فُضَیْلٍ ، عَنِ ابْنِ مُغَفَّلٍ ؛ أَنَّ رَجُلاً جَائَ إِلَی عَلِیٍّ فَسَارَّہُ ، فَقَالَ : یَا قَنْبَرُ ، أَخْرِجْہُ مِنَ الْمَسْجِدِ ، فَأَقِمْ عَلَیْہِ الْحَدَّ۔",,,29239
29240,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ قَیْسِ بْنِ مُسْلِمٍ ، عَنْ طَارِقِ بْنِ شِہَابٍ ؛ أَنَّ عُمَرَ أُتِیَ بِرَجُلٍ فِی شَیْئٍ ، فَقَالَ : أَخْرِجَاہُ مِنَ الْمَسْجِدِ ، فَأَخْرَجَاہُ۔",,,29240
29241,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ اللہِ الشَّعَیْثِیِّ ، عَنِ الْعَبَّاسِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ حَکِیمِ بْنِ حِزَامٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تُقَامُ الْحُدُودُ فِی الْمَسَاجِدِ ، وَلاَ یُسْتَقَادُ فِیہَا۔\n\n(ابن ماجہ 748)",,,29241
29242,"حَدَّثَنَا وَکِیعٌ، عَنْ مُبَارَکٍ، عَنْ ظَبْیَانَ بْنِ صَبَیْحٍ، قَالَ: قَالَ ابْنُ مَسْعُودٍ: لاَ تُقَامُ الْحُدُودُ فِی الْمَسَاجِدِ۔",,,29242
29243,"حَدَّثَنَا شَرِیکٌ ، عَنْ لَیْثٍ ، عنْ مُجَاہِدٍ (ح) وَعَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالاَ : کَانُوا یَکْرَہُونَ أَنْ یُقِیمُوا الْحُدُودَ فِی الْمَسَاجِدِ۔",,,29243
29244,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ أَنَّہُ کَرِہَ ، أَوْ کَانَ یَکْرَہُ الْجَلْدَ فِی الْمَسْجِدِ۔,,,29244
29245,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ إِسْمَاعِیلَ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، عَنْ طَاوُوسٍ ، رَفَعَہُ ، قَالَ : لاَ تُقَامُ الْحُدُودُ فِی الْمَسَاجِدِ۔ (ترمذی 1401۔ ابن ماجہ 2599)",,,29245
29246,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیل ، عَنْ عِیسَی بْنِ أَبِی عَزَّۃَ ، عَنِ الشَّعْبِیِّ ، قَالَ : شَہِدْتُہُ ،وَضَرَبَ رَجُلاً افْتَرَی عَلَی رَجُلٍ فِی قَمِیصٍ ، وَلَمْ یَضْرِبْہُ فِی الْمَسْجِدِ۔",,,29246
29247,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُحَمَّدِ بْنِ خَالِدٍ الضَّبِّیِّ ، عَنْ مَکْحُولٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : جَنِّبُوا مَسَاجِدَکُمْ إِقَامَۃَ حُدُودِکُمْ۔ (ابن ماجہ 750۔ طبرانی 136)",,,29247
29248,"حَدَّثَنَا ابْنُ یَمَانٍ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ أَبِی الضُّحَی ، عَنْ مَسْرُوقٍ ، قَالَ : لِلْمَسْجِدِ حُرْمَۃٌ۔",,,29248
29249,حَدَّثَنَا ابْنُ یَمَانٍ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ أَبِی الضُّحَی ؛ أَنَّہُ کَرِہَ الضَّرْبَ فِی الْمَسْجِدِ۔,,,29249
29250,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ، قَالَ : تُقَامُ الْحُدُودُ فِی الْمَسَاجِدِ کُلُّہَا ، إِلاَّ الْقَتْلَ۔",,,29250
29251,حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ إِسْمَاعِیلَ ، عَنِ ابْنِ سِیرِینَ ، عَنْ شُرَیْحٍ ؛ أَنَّہُ کَانَ یُقِیمُ الْحُدُودَ فِی الْمَسَاجِدِ۔,,,29251
29252,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ فِی رَجُلٍ قَالَ لِرَجُلٍ : مَا تَأْتِی امْرَأَتُک إِلاَّ حَرَامًا ، قَالَ : کَذَبَ ، لَیْسَ عَلَیْہِ حَدٌّ۔",,,29252
29253,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : لَیْسَ عَلَی الْمُخْتَلِسِ ، وَلاَ عَلَی الْمُسْتَلِبِ ، وَلاَ الْخَائِنِ قَطْعٌ۔",,,29253
29254,"حَدَّثَنَا أَبُو عَاصِمٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، رَفَعَہُ ، بِنَحْوِہِ۔\n\n(ابوداؤد 4391۔ ترمذی 1448)",,,29254
29255,حَدَّثَنَا ابْنُ مُبَارَکٍ، عَنْ مَعْمَرٍ، عَنِ الزُّہْرِیِّ؛ أَنَّ مَرْوَانَ سَأَلَ زَیْدَ بْنَ ثَابِتٍ عَنِ الْخُلْسَۃِ؟ فَلَمْ یَرَ فِیہَا قَطْعًا۔,,,29255
29256,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، قَالَ : قَالَ عَلِیٌّ : لَیْسَ عَلَی الْمُخْتَلِسِ قَطْعٌ۔",,,29256
29257,حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ خِلاَسٍ ؛ أَنَّ عَلِیًّا لَمْ یَکُنْ یَقْطَعْ فِی الْخُلْسَۃِ۔,,,29257
29258,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ؛ أَنَّ غُلاَمًا اخْتَلَسَ طَوْقًا ، فَرُفِعَ إِلَی عَدِیِّ بْنِ أَرْطَاۃَ ، فَسَأَلَ الْحَسَنَ عَن ذَلِکَ ؟ فَقَالَ : لاَ قَطْعَ عَلَیْہِ ، وَسَأَلَ عَن ذَلِکَ إِیَاسَ بْنَ مُعَاوِیَۃَ ؟ فَأَمَرَہُ بِقَطْعِہِ ، فَلَمَّا اخْتَلَفَا ، کَتَبَ فِی ذَلِکَ إِلَی عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، فَکَتَبَ إِلَیْہِ عُمَرُ : إِنَّ الْعَرَبَ کَانَتْ تَدْعُوہَا عَدْوَۃَ الظَّہِیرَۃِ ، لاَ قَطْعَ عَلَیْہِ ، وَلَکِنْ أَوْجِعْ ظَہْرَہُ ، وَأَطِلْ حَبْسَہُ۔",,,29258
29259,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ؛ أَنَّ عَدِیًّا رُفِعَ إِلَیْہِ رَجُلٌ اخْتَلَسَ خُلْسَۃً ، فَقَالَ إِیَاسٌ : عَلَیْہِ الْقَطْعُ ، وَقَالَ الْحَسَنُ : لاَ قَطْعَ عَلَیْہِ ، فَکَتَبَ عَدِیٌّ إِلَی عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، فَقَالَ : لَیْسَ عَلَیْہِ قَطْعٌ ، قَالَ : وَکَانَتِ الْعَرَبُ تُسَمِّیہَا عَدْوَۃَ الظَّہِیرَۃِ۔",,,29259
29260,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، عَنْ مُحَمَّدٍ ، قَالَ : لَیْسَ فِی الْخُلْسَۃِ قَطْعٌ۔",,,29260
29261,"حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَیْسَ عَلَی الْخَائِنِ قَطْعٌ۔",,,29261
29262,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : لَیْسَ عَلَی الْخَائِنِ قَطْعٌ۔",,,29262
29263,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، قَالَ : جَائَ رَجُلٌ إِلَی شُرَیْحٍ ، فَقَالَ : إِنَّ ہَذَا سَرَقَ مِنِّی ، فَقَالَ : وَمَنْ ہَذَا ؟ قَالَ : أَجِیرِی ، قَالَ : لَیْسَ بِسَارِقٍ مَنِ ائْتَمَنْتہ عَلَی بَیْتِک۔",,,29263
29264,"حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : لَیْسَ فِی الْخِیَانَۃِ قَطْعٌ۔",,,29264
29265,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ أَبِی حُرَّۃَ ، عَنِ الْحَسَنِ ؛ فِی غُلاَمٍ کَانَ مَعَ قَوْمٍ فِی السُّوقِ ، فَسَرَقَ بَعْضَ مَتَاعِہِمْ ، فَقَالَ : ہُوَ خَائِنٌ ، وَلاَ قَطْعَ عَلَیْہِ۔",,,29265
29266,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنْ أَبِی عُثْمَانَ ، قَالَ : أُتِیَ عُمَرُ بِرَجُلٍ فِی حَدٍّ ، فَأُتِیَ بِسَوْطٍ ، فَقَالَ : أُرِیدُ أَلْیَنَ مِنْ ہَذَا ، فَأُتِیَ بِسَوْطٍ فِیہِ لِینٌ ، فَقَالَ : أُرِیدُ أَشَدَّ مِنْ ہَذَا ، فَأُتِیَ بِسَوْطٍ بَیْنَ السَّوْطَیْنِ ، فَقَالَ : اضْرِبْ ، وَلاَ یُرَی إِبْطُک ، وَأَعْطِ کُلَّ عُضْوٍ حَقَّہُ۔",,,29266
29267,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی الْحَارِثِ التَّیْمِیِّ ، عَنْ أَبِی مَاجِدٍ ، عَنْ عَبْدِ اللہِ ؛ أَنَّہُ دَعَا جَلاَّدًا ، فَقَالَ : اجْلِدْ وَارْفَعْ یَدَک ، وَأَعْطِ کُلَّ عُضْوٍ حَقَّہُ ، قَالَ : فَضَرَبَہُ الْحَدَّ ضَرْبًا غَیْرَ مُبَرِّحٍ۔",,,29267
29268,"حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَدِیِّ بْنِ ثَابِتٍ ، عَنِ الْمُہَاجِرِ بْنِ عَمِیرَۃَ ، عَنْ عَلِیٍّ ، قَالَ : أُتِیَ بِرَجُلٍ سَکْرَانَ ، أَوْ فِی حَدٍّ ، فَقَالَ : اضْرِبْ ، وَأَعْطِ کُلَّ عُضْوٍ حَقَّہُ ، وَاتَّقِ الْوَجْہَ وَالْمَذَاکِیرَ۔",,,29268
29269,"حَدَّثَنَا إِسْمَاعِیلُ بْنُ إِبْرَاہِیمَ ، عَنْ أَشْعَثَ ، عَنْ أَبِیہِ ، قَالَ : شَہِدْتُ أَبَا بَرْزَۃَ أَقَامَ الْحَدَّ عَلَی أَمَۃٍ لَہُ فِی دِہْلِیزِہِ ، وَعَندَہُ نَفَرٌ مِنْ أَصْحَابِہِ ، فَقَالَ : اجْلِدْہَا جَلْدًا بَیْنَ الْجَلْدَیْنِ ، لَیْسَ بِالْتَّمَطی ، وَلاَ بِالتَّخْفِیفِ۔",,,29269
29270,"حَدَّثَنَا وَکِیعٌ ، عَنْ عِمْرَانَ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ : الْجَلاَدُ لاَ یَخْرُجُ إِبْطُہُ۔",,,29270
29271,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَاصِمٍ ، قَالَ : شَہِدْتُ الشَّعْبِیَّ وَضَرَبَ نَصْرَانِیًّا قَذَفَ مُسْلِمًا ، فَقَالَ : اضْرِبْ، وَأَعْطِ کُلَّ عُضْوٍ حَقَّہُ ، وَلاَ یُرَیَنَّ إِبْطَک۔",,,29271
29272,"حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : حدَّ الْفِرْیَۃِ ، وَحَدَّ الْخَمْرِ أَنْ تَجْلِدَ ، وَلاَ تَرْفَعْ یَدَک۔",,,29272
29273,"حَدَّثَنَا جَرِیرٌ، عَنْ مُغِیرَۃَ، عَنْ إِبْرَاہِیمَ، قَالَ: یُضْرَبُ الزَّانِی ضَرْبًا شَدِیدًا، وَیُقَسَّمُ الضَّرْبُ بَیْنَ أَعْضَائِہِ۔",,,29273
29274,"حَدَّثَنَا أَبُو عَاصِمٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : حدُّ الزِّنَی أَشَدُّ مِنْ حَدِّ الْخَمْرِ ، وَحَدُّ الْخَمْرِ وَالْفِرْیَۃِ وَاحِدٌ۔",,,29274
29275,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ إِسْمَاعِیلَ ، عَنِ الْحَسَنِ ، قَالَ : یُضْرَبُ الزَّانِی أَشَدَّ مِنْ ضَرْبِ الشَّارِبِ ، وَیُضْرَبُ الشَّارِبُ أَشَدَّ مِنْ ضَرْبِ الْقَاذِفِ۔",,,29275
29276,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ حَنْظَلَۃَ السَّدُوسِیِّ ، قَالَ : سَمِعْتُ أَنَسَ بْنَ مَالِکٍ ، یَقُولُ : کَانَ یُؤْمَرُ بِالسَّوْطِ ، فَتُقْطَعُ ثَمَرَتُہُ ، ثُمَّ یُدَقُّ بَیْنَ حَجَرَیْنِ ، ثُمَّ یُضْرَبَ بِہِ ، فَقُلْتُ لأَنَسٍ : فِی زَمَانِ مَنْ کَانَ ہَذَا ؟ قَالَ : فِی زَمَانِ عُمَرَ بْنِ الْخَطَّابِ۔",,,29276
29277,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی الْحَارِثِ التَّیْمِیِّ ، عَنِ أبی مَاجِدٍ ، عَنْ عَبْدِ اللہِ ؛ أَنَّہُ دَعَا بِسَوْطٍ فَدَقَّ ثَمَرَتَہُ حَتَّی آضَتْ لَہُ مِخْفَقَہُ ، وَدَعَا بِجَلاَّدٍ ، فَقَالَ : اجْلِدْ۔",,,29277
29278,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنَ ، عَن زَیْدِ بْنِ أَسْلَمَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أُتِیَ بِرَجُلٍ قَدْ أَصَابَ حَدًّا ، فَأُتِیَ بِسَوْطٍ جَدِیدٍ شَدِیدٍ ، فَقَالَ : دُونَ ہَذَا ، فَأُتِیَ بِسَوْطٍ مُنْکَسِرٍ مُنْتَشِرٍ ، فَقَالَ : فَوْقَ ہَذَا ، فَأُتِیَ بِسَوْطٍ قَدْ دِیث ، یَعْنِی قَدْ لُیِّنَ ، فَقَالَ : ہَذَا۔ (مالک 12)",,,29278
29279,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنِ الْمُثَنَّی ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، قَالَ : إِذَا وُجِدَ الْغُلُولُ عَندَ الرَّجُلِ ، أُخِذَ وَجُلِدَ مِئَۃً ، وَحُلِقَ رَأْسُہُ وَلِحْیَتُہُ ، وَأُخِذَ مَا کَانَ فِی رَحْلِہِ مِنْ شَیْئٍ إِلاَّ الْحَیَوَانَ ، وَأُحْرِقَ رَحْلُہُ ، وَلَمْ یَأْخُذْ سَہْمًا فِی الْمُسْلِمِینَ أَبَدًا ، قَالَ : وَبَلَغَنِی ؛ أَنَّ أَبَا بَکْرٍ وَعُمَرَ کَانَا یَفْعَلاَنِہِ۔",,,29279
29280,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَیْسَ فِی الْغُلُولِ قَطْعٌ۔",,,29280
29281,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ قَالَ : لَیْسَ فِی الْغُلُولِ قَطْعٌ۔",,,29281
29282,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَن یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی الْغُلُولِ إِذَا وُجِدَ عَندَ رَجُلٍ : یُحْرَقُ رَحْلُہُ۔",,,29282
29283,"حَدَّثَنَا دَاوُد بْنُ عَبْدِ اللہِ ، قَالَ : حدَّثَنَا عَبْدُ الْعَزِیزِ بْنُ مُحَمَّدٍ ، عَن صَالِحِ بْنِ مُحَمَّدِ بْنِ زَائِدَۃَ ، عَنْ سَالِمِ بْنِ عَبْدِ اللہِ ، عَنْ أَبِیہِ ، عَنْ عُمَرَ بْنِ الْخَطَّابِ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : مَنْ وَجَدْتُمُوہُ قَدْ غَلَّ فَحَرِّقُوا مَتَاعَہُ۔ (ابوداؤد 2706۔ ترمذی 1461)",,,29283
29284,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائِ بْنِ أَبِی مَرْوَانَ ، عَنْ أَبِیہِ ، قَالَ : أُوتِیَ عَلِیٌّ بِرَجُلٍ شَرِبَ خَمْرًا فِی رَمَضَانَ ، فَجَلَدَہُ ثَمَانِینَ ، وَعَزَّرَہُ عِشْرِینَ۔",,,29284
29285,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی سِنَانٍ الْبَکْرِیِّ ، قَالَ : أُتِیَ عُمَرُ بِرَجُلٍ شَرِبَ خَمْرًا فِی رَمَضَانَ ، فَضَرَبَہُ ثَمَانِینَ ، وَعَزَّرَہُ عِشْرِینَ۔",,,29285
29286,حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الأَسْوَدِ بْنِ ہِلاَلٍ ، عَنْ عَبْدِ اللہِ ، مِثْلَہُ۔,,,29286
29287,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ؛ فِی الْیَہُودِیِّ وَالنَّصْرَانِیِّ : إِنْ کَانَ أُحْصِنَ فِی شِرْکِہِ ، ثُمَّ أَسْلَمَ ، ثُمَّ أَصَابَ فَاحِشَۃً قَبْلَ أَنْ یُحْصَنَ فِی الإِسْلاَمِ ، قَالَ : یُرْجَمُ۔",,,29287
29288,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : إِحْصَانُ الْیَہُودِیِّ وَالنَّصْرَانِیِّ فِی شِرْکِہِمَا إِحْصَانٌ ، وَلَیْسَ الْمَجُوسِیُّ بِإِحْصَانٍ۔",,,29288
29289,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ جَابِرِ بْنِ زَیْدٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ فِی أَرْبَعَۃٍ شَہِدُوا عَلَی امْرَأَۃٍ بِالزِّنَی أَحَدُہُمْ زَوْجُہَا ، قَالَ : یُلاَعِنُ الزَّوْجُ ، وَیُضْرَبُ الثَّلاَثَۃُ۔",,,29289
29290,حَدَّثَنَا ابْنُ مُسْہِرٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، مِثْلَہُ۔,,,29290
29291,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، وَعَبْدَۃُ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، قَالَ : إِذَا جَاؤُوا جَمِیعًا مَعًا ، فَالزَّوْجُ أَجْوَزُہُمْ شَہَادَۃً۔",,,29291
29292,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ، قَالَ : یُقَامُ عَلَیْہا الْحَدُّ۔",,,29292
29293,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الشَّیْبَانِیِّ ، عَن حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : یُلاَعِنُ الزَّوْجُ ، وَیُضْرَبُ الثَّلاَثَۃُ۔",,,29293
29294,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، وَابْنِ عَبَّاسٍ ؛ فِی الرَّجُلِ یَبِیعُ امْرَأَتَہُ ، قَالاَ : یُعَاقَبَانِ ، وَیُنَکَّلاَنِ۔",,,29294
29295,"حَدَّثَنَا زَیْدُ بْنُ حُبَاب ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ قَتَادَۃَ ؛ فِی رَجُلٍ بَاعَ امْرَأَۃً وَہُمَا حُرَّانِ ، فَأُخِذَا عِندَ الْجِسْرِ، فِی أَوْسَاطِہِمَا الدَّنَانِیرُ، فَکُتِبَ إِلَی عُمَرَ بْنِ عَبْدِالْعَزِیزِ فِیہِمَا، فَکَتَبَ: أَنْ یُعَزَّرَا، وَیُسْتَوْدَعَا السِّجْنَ۔",,,29295
29296,"حَدَّثَنَا مُحَمَّدُ بْنُ یَزِیدَ ، عَنْ أَبِی الْعَلاَئِ ، عَنْ قَتَادَۃَ ، عَن عِکْرِمَۃَ ، عنِ ابْنِ عَبَّاسٍ ؛ فِی رَجُلَیْنِ بَاعَ أَحَدُہُمَا الآخَرَ ، قَالَ : یُرَدُّ الْبَیْعُ ، وَیُعَاقَبَانِ ، وَلاَ قَطْعَ عَلَیْہِمَا۔",,,29296
29297,"حَدَّثَنَا عَبْدُ الْوَہَّابِ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَن خِلاَسٍ ، عَنْ عَلِیٍّ ، قَالَ : تُقْطَعُ یَدَہُ۔",,,29297
29298,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ مَعْمَرٍ ، عَنِ ابْنِ شِہَابٍ ؛ فِی رَجُلٍ بَاعَ رَجُلاً حُرًّا ، قَالَ : یُعَاقَبَانِ ، الَّذِی بَاعَہُ وَالَّذِی أَقَرَّ بِالْبَیْعِ ، عُقُوبَۃً مُوجِعَۃً۔",,,29298
29299,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی مَعْمَرٌ ، عَنِ ابْنِ شِہَابٍ ؛ فِی رَجُلٍ بَاعَ ابْنَتَہُ ، فَوَقَعَ الْمُبْتَاعُ عَلَیْہَا ، فَقَالَ أَبُوہَا : حَمَلَنِی عَلَی بَیْعِہَا الْحَاجَۃُ ، قَالَ : یُجْلَدَانِ ، الأَبُ وَابْنَتُہُ ، مِئَۃٌ ، مِئَۃٌ ، إِنْ کَانَتْ قَدْ بَلَغَتْ ، وَیُرَدُّ إِلَی الْمُبْتَاعِ الثَمَنُ ، وَعَلَی الْمُبْتَاعِ صَدَاقُہَا بِمَا أَصَابَ مِنْہَا ، ثُمَّ یَغْرَمُ الأَبُ الصَّدَاقَ ، إِلاَّ أَنْ یَکُونَ الْمُبْتَاعُ قَدْ عَلِمَ أَنَّہَا حُرَّۃٌ ، فَعَلَیْہِ الصَّدَاقُ ، وَلاَ یَغْرَمُ الأَبُ لَہُ ، وَیُجْلَدُ مِئَۃً ، وَإِنْ کَانَتْ جَارِیَۃً لاَ تَعْقِلُ ، فَعَلَی الأَبِ النَّکَالُ۔",,,29299
29300,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مُغِیرَۃَ ، عَن حَمَّادٍ ؛ فِی امْرَأَۃٍ بَاعَتْ أُخْتَہَا عَنْ أَمْرِہَا ، فَاشْتَرَاہَا رَجُلٌ ، فَوَطِئَہَا ، قَالَ : یُرَدُّ عَلَی الرَّجُلِ مَالُہُ ، وَتُعَاقَبُ الْمَرْأَۃُ وَأُخْتُہَا ، وَیَرْضَخُ لَہَا شَیْئًا۔",,,29300
29301,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَن یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : شَاہِدُ الزُّورِ یُضْرَبُ شَیْئًا ، وَیُعَرَّفُ النَّاسُ ، وَیُقَالُ : إِنَّ ہَذَا شَہِدَ بِزُورٍ۔",,,29301
29302,"حَدَّثَنَا عَبَّادُ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، قَالَ : شَاہِدُ الزُّورِ یُضْرَبُ مَا دُونَ الأَرْبَعِینَ ؛ خَمْسَۃً وَثَلاَثِینَ ، سِتَّۃً وَثَلاَثِینَ ، وَسَبْعَۃً وَثَلاَثِینَ۔",,,29302
29303,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : شَاہِدُ الزُّورِ یُعَزَّرُ۔",,,29303
29304,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ الْمُحَارِبِیُّ ، عَنِ الْجَعْدِ أَبِی عُثْمَانَ ، قَالَ : کَانَ شُرَیْحٌ إِذَا أُتِیَ بِشَاہِدِ الزُّورِ خَفَقَہُ خَفَقَاتٍ۔",,,29304
29305,حَدَّثَنَا الْمُحَارِبِیُّ ، عَنْ عَبْدِ اللہِ بْنِ سَعِیدٍ ؛ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ جَلَدَ شَاہِدَ الزُّورِ سَبْعِینَ سَوْطًا۔,,,29305
29306,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنْ مَکْحُولٍ ، وَالْوَلِیدِ بْنِ أَبِی مَالِکٍ ، قَالاَ : کَتَبَ عُمَرُ بْنُ الْخَطَّابِ فِی شَاہِدِ الزُّورِ ؛ یُضْرَبُ أَرْبَعِینَ سَوْطًا ، وَیُسَخَّمُ وَجْہُہُ ، وَیُحْلَقُ رَأْسُہُ ، وَیُطَافُ بِہِ ، وَیُطَالُ حَبْسُہُ۔",,,29306
29307,"حَدَّثَنَا حَفْصٌ ، وَعَبَّادُ بْنُ الْعَوَّامِ ، عَنْ حَجَّاجٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : مَضَتِ السُّنَّۃُ مِنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَالْخَلِیفَتَیْنِ مِنْ بَعْدِہِ ، أَنْ لاَ تَجُوزَ شَہَادَۃُ النِّسَائِ فِی الْحُدُودِ۔",,,29307
29308,"حَدَّثَنَا جَرِیرٌ ، عَنْ بَیَانٌ ، عَنْ إِبْرَاہِیمَ ؛ سُئِلَ عَن ثَلاَثَۃٍ شَہِدُوا عَلَی رَجُلٍ بِالزِّنَی ، وَامْرَأَتَینِ ؟ قَالَ : لاَ یَجُوزُ حَتَّی یَکُونُوا أَرْبَعَۃً۔",,,29308
29309,"حَدَّثَنَا وَکِیعٌ، عَنْ شُعْبَۃَ، عَنِ الْحَکَمِ، عَنْ إِبْرَاہِیمَ، قَالَ: لاَ تَجُوزُ شَہَادَۃُ النِّسَائِ فِی الطَلاَقِ وَالْحُدُودِ۔",,,29309
29310,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ مُجَالِدٍ ، عَنْ عَامِرٍ ، قَالَ : لاَ تَجُوزُ شَہَادَۃُ النِّسَائِ فِی الْحُدُودِ۔",,,29310
29311,"حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، وَوَکِیعٌ ، عَنْ زَکَرِیَّا ، عَنِ الشَّعْبِیِّ ، قَالَ : لاَ تَجُوزُ شَہَادَۃُ امْرَأَۃٍ فِی حَدٍّ ، وَلاَ شَہَادَۃُ عَبْدٍ۔",,,29311
29312,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : لاَ تَجُوزُ شَہَادَۃُ النِّسَائِ فِی الْحُدُودِ۔",,,29312
29313,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ، عَنْ جُوَیْبِرٍ، عَنِ الضَّحَّاکِ، قَالَ: لاَ تَجُوزُ شَہَادَۃُ النِّسَائِ فِی دَمٍ ، وَلاَ حَدِّ دَمٍ۔",,,29313
29314,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، قَالَ : سَمِعْتُ حَمَّادًا ، یَقُولُ : لاَ تَجُوزُ شَہَادَۃُ النِّسَائِ فِی الْحُدُودِ۔",,,29314
29315,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیُّ بْنُ صَالِحٍ ، قَالَ : سَمِعْتُ عَبْد الرَّحْمن بن سَعِید بْنِ وَہْبٍ ، یَقُولُ : لاَ تَجُوزُ شَہَادَۃُ النِّسَائِ فِی الْحُدُودِ۔",,,29315
29316,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : لاَ یُجْلَدُ فِی شَیْئٍ مِنَ الْحُدُودِ ، إِلاَّ بِشَہَادَۃِ رَجُلَیْنِ۔",,,29316
29317,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ؛ {وَلْیَشْہَدْ عَذَابَہُمَا طَائِفَۃٌ مِنَ الْمُؤْمِنِینَ} ، قَالَ : أَدْنَاہ رَجُلٌ ، وَقَالَ عَطَائٌ : رَجُلاَنِ۔",,,29317
29318,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ {وَلْیَشْہَدْ عَذَابَہُمَا طَائِفَۃٌ مِنَ الْمُؤْمِنِینَ} ، قَالَ : عَشَرَۃٌ۔",,,29318
29319,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : ثَلاَثَۃٌ فَصَاعِدًا۔",,,29319
29320,"حَدَّثَنَا عَبَّادٌ ، عَنْ أَشْعَثَ ، عَنْ أَبِیہِ ، قَالَ : شَہِدْتُ أَبَا بَرْزَۃَ ضَرَبَ أمَۃً لَہُ فَجَرَتْ ، وَعَلَیْہَا مِلْحَفَۃٌ قَدْ جُلِّلَتْ بِہَا ، وَعَندَہُ طَائِفَۃٌ مِنَ النَّاسِ ، ثُمَّ قَالَ : {وَلْیَشْہَدْ عَذَابَہُمَا طَائِفَۃٌ مِنَ الْمُؤْمِنِینَ}۔",,,29320
29321,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ مُحَمَّدِ بْنِ کَعْبٍ ، قَالَ : سَمِعْتُہُ یَقُولُ : (إِنْ یُعْفَ عَنْ طَائِفَۃٍ مِنْکُمْ) ، قَالَ : کَانَ رَجُلاً۔",,,29321
29322,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ (ح) وَعَن مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّہُمَا قَالاَ : مَنْ قَذَفَ صَغِیرًا فَلاَ حَدَّ عَلَیْہِ۔",,,29322
29323,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : لاَ حَدَّ فِی غُلاَمٍ افْتُرِیَ عَلَیْہِ وَہُوَ صَغِیرٌ ، حَتَّی تَجِبَ عَلَیْہِ الْحُدُودُ۔",,,29323
29324,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : لَیْسَ عَلَی مَنَ دَعَی لِغَیْرِ أُمِّہِ حَدٌّ۔",,,29324
29325,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدِ بْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ؛ فِی رَجُلٍ قَالَ لِرَجُلٍ : لَسْتَ لِفُلاَنَۃَ ، أُمِّہِ ، قَالَ : کَانَ لاَ یُجْعَلُ عَلَیْہِ الْحَدُّ ، إِنَّمَا ہِیَ کَذْبَۃٌ۔",,,29325
29326,حَدَّثَنَا مُحَمَّدُ بْنُ سَوَائٍ ، عَنْ سَعِیدٍ ، عَنْ رَجُلٍ ، عَنْ حَمَّادٍ ؛ مِثْلَہُ۔,,,29326
29327,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : لَیْسَ عَلَیْہِ حَدٌّ۔",,,29327
29328,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : فِی الضَّرْبِ۔",,,29328
29329,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنِ الشَّعْبِیِّ ، قَالَ : فِی الضَّرْبِ۔",,,29329
29330,"حَدَّثَنَا وَکِیعٌ ، عَنْ عِمْرَانَ بْنِ حُدَیْرٍ ، عَنْ أَبِی مِجْلَزٍ ؛ فِی قَوْلِہِ تَعَالَی : {وَلاَ تَأْخُذْکُمْ بِہِمَا رَأْفَۃٌ فِی دِینِ اللہِ} ، قَالَ : إِقَامَۃُ الْحُدُودِ إِذَا رُفِعَتْ إِلَی السُّلْطَانِ۔",,,29330
29331,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ (ح) وَعَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ؛ فِی قَوْلِہِ تَعَالَی : {وَلاَ تَأْخُذْکُمْ بِہِمَا رَأْفَۃٌ فِی دِینِ اللہِ} ، قَالاَ : لَیْسَ بِالْقَتْلِ ، وَلَکِنْ فِی إِقَامَۃِ الْحَدِّ۔",,,29331
29332,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : إِقَامَۃُ الْحَدِّ ، أَمَا إِنَّہُ لَیْسَ بِشِدَّۃِ الْجَلْدِ۔",,,29332
29333,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ؛ {وَلاَ تَأْخُذْکُمْ بِہِمَا رَأْفَۃٌ فِی دِینِ اللہِ}، قَالَ : فِی إِقَامَۃِ الْحَدِّ ، یُقَامُ ، وَلاَ یُعَطَّلُ۔",,,29333
29334,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ مُبَارَکٍ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ عِکْرِمَۃَ ، وَسُلَیْمَانَ بْنِ یَسَارٍ ؛ فِی الرَّجُلِ یَتَزَوَّجُ الأَمَۃَ ، وَلَمْ یَکُنْ تَزَوَّجَ حُرَّۃً قَبْلَہَا ، ثُمَّ یَفْجُرُ ، قَالَ سُلَیْمَانُ بْنُ یَسَارٍ : یُرْجَمُ ، وَقَالَ عِکْرِمَۃُ: یُجْلَدُ۔",,,29334
29335,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : سُئِلَ عَنْ رَجُلٍ زَنَی وَلَہُ سَرَارِیُّ ؟ قَالَ : یُجْلَدُ ، وَلاَ یُرْجَمُ۔",,,29335
29336,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، وَحَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لاَ یُحْصن الْحُرَّ بِیَہُودِیَّۃٍ ، وَلاَ نَصْرَانِیَّۃٍ ، وَلاَ بِأَمَۃٍ۔",,,29336
29337,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ عُبَیْدِ اللہِ بْنِ عَبْدِ اللہِ بْنِ عُتْبَۃَ ، أَوْ عَبْدِ اللہِ بْنِ عُتْبَۃَ ؛ أَنَّ مَرْوَانَ سَأَلَہُ عَنِ الْحُرِّ تَکُونُ تَحْتَہُ الأَمَۃُ ، ثُمَّ یُصِیبُ فَاحِشَۃً ؟ قَالَ : یُرْجَمُ ، قَالَ : عَمَّنْ تَأْخُذُ ہَذَا ؟ قَالَ : أَدْرَکْنَا أَصْحَابَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُونَہُ۔ (بیہقی 216)",,,29337
29338,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَقُولُ : لاَ تُحْصِنُ الأَمَۃُ الْحُرَّ ، وَلاَ الْعَبْدُ الْحُرَّۃَ۔",,,29338
29339,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، وَہُوَ قَوْلُ قَتَادَۃَ ؛ أَنَّہُمَا کَانَا یَقُولاَنِ فِی الْحُرَّۃِ تَحْتَ الْعَبْدِ تَزْنِی ، السُّنَّۃُ أَنَّہَا تُرْجَمُ ، وَفِی الْحُرِّ تَحْتَہُ الأَمَۃُ : لاَ یُرْجَمُ۔",,,29339
29340,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنِ الْفَضْلِ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ؛ أَنَّ سُلَیْمَانَ بْنَ یَسَارٍ ، قَالَ : أَحْصَنَہَا وَأَحْصَنَتْہُ۔",,,29340
29341,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : أَحْصَنَہَا وَأَحْصَنَتْہُ ، قَالَ : الْحُرُّ الآنَ مَرْجُومٌ۔",,,29341
29342,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : قَدِمْتُ الْمَدِیِنَۃ ، وَقَدَ أَجْمَعُوا عَلَی عَبْدٍ أُحْصِنَ بِحُرَّۃ أَنْ یرْجَم ، إِلاَّ عِکْرِمَۃ ، فَإِنَّہُ قَالَ : عَلَیْہِ نِصَفُ الْحَّدِ۔",,,29342
29343,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إِبْرَاہِیمَ ؛ فِی الْعَبْدِ تَکُونُ تَحْتَہُ الْحُرَّۃُ ، وَالْحُرِّ یَکُون تَحْتَہُ الأَمَۃُ، فَیَزْنِی أَحَدُہُمَا، قَالَ: لَیْسَ عَلَی وَاحِدٍ مِنْہُمَا رَجْمٌ، حَتَّی یَکُونَا حُرَّیْنِ مُسْلِمَیْنِ۔",,,29343
29344,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : إِحْصَانُ الأَمَۃِ أَنْ تَنْکِحَ الْحُرَّ ، وَإِحْصَانُ الْعَبْدِ أَنْ یَنْکِحَ الْحُرَّۃَ۔",,,29344
29345,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، وَالشَّعْبِیِّ ؛ فِی الْحُرِّ یَتَزَوَّجُ الْیَہُودِیَّۃَ وَالنَّصْرَانِیَّۃ ثُمَّ یَفْجُرُ ، فَقَالاَ : یُجْلَدُ ، وَلاَ یُرْجَمُ۔",,,29345
29346,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ زَمْعَۃَ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ لاَ یَرَی أَنْ یُحْصِنَ الْحُرَّ ، إِلاَّ الْحُرَّۃُ الْمُسْلِمَۃُ۔,,,29346
29347,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ أَبِی بَکْرٍ بْنِ عَبْدِ اللہِ بْنِ أَبِی مَرْیَمَ ، عَنْ عَلِیِّ بْنِ أَبِی طَلْحَۃَ ، عَنْ کَعْبٍ؛ أَنَّہُ أَرَادَ أَنْ یَتَزَوَّجَ یَہُودِیَّۃً ، أَوْ نَصْرَانِیَّۃً ، فَسَأَلَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَن ذَلِکَ ؟ فَنَہَاہُ عَنْہَا، وَقَالَ : إِنَّہَا لاَ تُحْصِنُک۔ (ابوداؤد 206۔ طبرانی 205)",,,29347
29348,حَدَّثَنَا أَبُو أُسَامَۃَ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ لاَ یَرَی مُشْرِکَۃً مُحْصِنَۃً۔,,,29348
29349,"حَدَّثَنَا وَکِیعُ بْنُ الْجَرَّاحِ ، عَنْ سُفْیَانَ ، عَنْ مُوسَی بْنِ عُقْبَۃَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : مَنْ أَشْرَکَ بِاَللَّہِ فَلَیْسَ بِمُحْصِن۔",,,29349
29350,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَقُولُ : إِذَا تَزَوَّجَہَا وَہُوَ غَیْرُ مُسْلِمٍ ، لَمْ تُحْصِنْہُ حَتَّی یَطَأَہَا فِی الإِسْلاَمِ۔",,,29350
29351,"حَدَّثَنَا وَکِیعٌ ، عَنْ سَعِیدِ بْنِ بَشِیرٍ ، عَنْ قَتَادَۃَ ، عَنْ جَابِرِ بْنِ زَیْدٍ ، وَسَعِیدِ بْنِ الْمُسَیَّبِ ؛ فِی الْیَہُودِیَّۃِ وَالنَّصْرَانِیَّۃ تَکُونُ تَحْتَ الْمُسْلِمِ ، ثُمَّ یَفْجُرُ ، قَالاَ : یُرْجَمُ۔",,,29351
29352,"حَدَّثَنَا إِسْمَاعِیلُ بْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : کَانَ یَقُولُ : تُحْصِنُ الْیَہُودِیَّۃُ وَالنَّصْرَانِیَّۃُ الْمُسْلِمَ۔",,,29352
29353,حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ فِی الرَّجُلِ یَتَزَوَّجُ الْمَرْأَۃَ مِنْ أَہْلِ الْکِتَابِ ، أَنَّہَا تُحْصِنُہُ۔,,,29353
29354,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ إِسْرَائِیلَ ، عَنْ سَالِمٍ ، قَالَ : سَأَلْتُ سَعِیدَ بْنَ جُبَیْرٍ عَنِ الرَّجُلِ یَتَزَوَّجُ الْیَہُودِیَّۃَ، وَالنَّصْرَانِیَّۃَ ، وَالأَمَۃَ أَیُحْصَنُ بِہِنَّ ؟ قَالَ : نَعَمْ ، وَلَوْ مَا۔",,,29354
29355,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنْ بَکْرٍ ، قَالَ : تَزَوَّجَتِ امْرَأَۃٌ عَبْدَہَا ، فَقِیلَ لَہَا ؟ فَقَالَتْ : أَلَیْسَ اللَّہُ یَقُولُ : {وَمَا مَلَکَتْ أَیْمَانُکُمْ} فَہَذَا مْلِکُ یَمِینِی ، وَتَزَوَّجَتِ امْرَأَۃٌ مِنْ غَیْرِ بَیِّنَۃٍ ، وَلاَ وَلِیٍّ ، فَقِیلَ لَہَا ؟ فَقَالَتْ : أَنَا ثَیِّبٌ ، وَقَدْ مَلَکْتُ أَمْرِی ، فَرُفِعَتا إِلَی عُمَرَ ، فَجَمَعَ النَّاسَ فَسَأَلَہُمْ ؟ فَقَالُوا : قَدْ خَاصَمَتَاک بِکِتَابِ اللہِ جَلَّ جَلاَلُہُ ، وَقَالَ عَلِیٌّ : قَدْ خَاصَمَتَاک بِکِتَابِ اللہِ ، فَجَلَدَ کُلَّ وَاحِدٍ مِنْہُمَا مِئَۃَ جَلْدَۃٍ ، ثُمَّ کَتَبَ إِلَی الأَمْصَارِ : أَیُّمَا امْرَأَۃٍ تَزَوَّجَتْ عَبْدَہَا ، أَوْ تَزَوَّجَتْ بِغَیْرِ وَلِیٍّ ، فَہِیَ بِمَنْزِلَۃِ الزَّانِیَۃِ۔",,,29355
29356,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنِ الْحَکَمِ ؛ أَنَّ عُمَرَ کَتَبَ فِی امْرَأَۃٍ تَزَوَّجَتْ عَبْدَہَا ، أَنْ یُفَرَّقَ بَیْنَہُمَا ، وَیُقَامُ الْحَدُّ عَلَیْہَا۔,,,29356
29357,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْمَاعِیلَ بْنِ مُسْلِمٍ ، قَالَ : سَأَلْتُ عَطَائً ، وَعَبْدَ اللہِ بْنَ عُبَیْدِ بْنِ عُمَیْرٍ ، وَمُجَاہِدًا عَنِ امْرَأَۃٍ کَانَ لَہَا عَبْدٌ ، فَأَرَادَتْ أَنْ تُعْتِقَہُ عَلَی أَنْ یَتَزَوَّجَہَا ؟ فَقَالَ عَطَائٌ ، وَعَبْدُ اللہِ بْنُ عُبَیْدٍ : تُعْتِقُہُ ، وَلاَ تُشَارِطُہُ ، وَقَالَ مُجَاہِدٌ : فِی ہَذَا عُقُوبَۃٌ مِنَ اللہِ وَمِنَ السُّلْطَانِ ، تُفَارِقُہُ ، وَیُقَامُ عَلَیْہَا الْحَدُّ۔",,,29357
29358,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَسْوَدِ بْنِ شَیْبَانَ ، عَنْ أَبِی نَوْفَلِ بْنِ أَبِی عَقْرَبٍ ، قَالَ : جَائَتِ امْرَأَۃٌ إِلَی عُمَرَ بْنِ الْخَطَّابِ ، فَقَالَتْ : یَا أَمِیرَ الْمُؤْمِنِینَ ، إِنِّی امْرَأَۃٌ کَمَا تَرَی ، وَغَیْرِی مِنَ النِّسَائِ أَجْمَلُ مِنِّی ، وَلِی عَبْدٌ قَدْ رَضِیتُ دِینَہُ وَأَمَانَتَہُ ، فَأَرَدْتُ أَنْ أَتَزَوَّجَہُ ، فَدَعَا بِالْغُلاَمِ فَضَرَبَہُمَا ضَرْبًا مُبَرِّحًا ، وَأَمَرَ فِی الْعَبْدِ فَبِیعَ فِی أَرْضِ غُرْبَۃٍ۔",,,29358
29359,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ، عَنْ أَشْعَثَ، عَنِ الْحَسَنِ، قَالَ: إِذَا قَالَ: یَاابْنَ الزَّانِیَیْنِ، قَالَ: یُجْلَدُ حَدَّیْنِ۔",,,29359
29360,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ حُسَیْنٍ ، عَنْ مَکْحُولٍ ؛ فِی رَجُلٍ قَالَ لِرَجُلٍ : یَا زَانٍ ، یَاابْنَ الزَّانِیَۃِ ، قَالَ : یُضْرَبُ حَدَّیْنِ۔",,,29360
29361,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنِ الْمُجَالِدِ ، عَنِ الشَّعْبِیِّ ، عَنْ جَابِرٍ ، قَالَ : جَائَ مَاعِزُ بْنُ مَالِکٍ إِلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : إِنَّہُ قَدْ زَنَی ، فَقَالَ : أَمَا لِہَذَا أَحَدٌ ؟ فَرَدَّہُ ، ثُمَّ جَائَ ثَلاَثَ مِرَارٍ ، فَقَالَ : أَمَا لِہَذَا أَحَدٌ ، فَرَدَّہُ ، فَلَمَّا کَانَتِ الرَّابِعَۃُ ، قَالَ : ارْجُمُوہُ ، فَرَمَاہُ وَرَمَیْنَاہُ ، وَفَرَّ وَاتَّبَعَنَاہُ ، قَالَ عَامِرٌ : فَقَالَ لِی جَابِرٌ : فَہَاہُنَا قَتَلْنَاہُ۔ (بخاری 5270۔ مسلم 1318)",,,29361
29362,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ سَعْدٍ ، قَالَ : حدَّثَنَی یَزِیدُ بْنُ نُعَیْمٍ بْنِ ہَزَّالٍ ، عَنْ أَبِیہِ ، قَالَ : کَانَ مَاعِزُ بْنُ مَالِکٍ فِی حَجْرِ أَبِی ، فَأَصَابَ جَارِیَۃً مِنَ الْحَیِّ ، فَقَالَ لَہُ أَبِی : إِئْتِ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَأَخْبِرْہُ بِمَا صَنَعْتَ ، یَسْتَغْفِرْ لَکَ ، وَإِنَّمَا یُرِیدُ بِذَلِکَ لِیَجْعَلَ لَہُ مَخْرَجًا ، فَأَتَاہُ ، فَقَالَ : یَا رَسُولَ اللہِ ، إِنِّی قَدْ زَنَیْت فَأَقِمْ عَلَیَّ کِتَابَ اللہِ ، فَأَعْرَضَ عَنْہُ ، ثُمَّ أَتَاہُ ، حَتَّی ذَکَرَ أَرْبَعَ مِرَارٍ ، ثُمَّ أَتَاہُ الرَّابِعَۃَ ، فَقَالَ : یَا رَسُولَ اللہِ ، إِنِّی قَدْ زَنَیْت فَأَقِمْ عَلَیَّ کِتَابَ اللہِ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَلَیْسَ قَدْ قُلْتَہَا أَرْبَعَ مَرَّاتٍ ، فَبِمَنْ ؟ قَالَ : بِفُلاَنَۃٍ ، قَالَ : ہَلْ ضَاجَعْتہَا ؟ قَالَ : نَعَمْ ، قَالَ : ہَلْ بَاشَرْتَہَا ؟ قَالَ : نَعَمْ ، قَالَ : ہَلْ جَامَعْتہَا ؟ قَالَ : نَعَمْ ، قَالَ : فَأَمَرَ بِہِ لِیُرْجَمَ ، فَأُخْرِجَ إِلَی الْحَرَّۃِ ، فَلَمَّا وَجَدَ مَسَّ الْحِجَارَۃِ خَرَجَ یَشْتَدُّ، فَلَقِیَہُ عَبْدُ اللہِ بْنُ أُنَیْسٍ وَقَدْ أَعْجَزَ أَصْحَابَہُ ، فَانْتَزَعَ لَہُ بِوَظِیفِ بَعِیرٍ ، فَرَمَاہُ بِہِ فَقَتَلَہُ ، ثُمَّ أَتَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَذَکَرَ ذَلِکَ لَہُ ، فَقَالَ : ہَلاَّ تَرَکْتُمُوہُ ، لَعَلَّہُ یَتُوبُ ، فَیَتُوبَ اللَّہُ عَلَیْہِ ؟۔ (ابوداؤد 4418۔ احمد 217)",,,29362
29363,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : جَائَ مَاعِزُ بْنُ مَالِکٍ إِلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : إِنِّی قَدْ زَنَیْتَ ، فَأَعْرَضَ عَنْہُ حَتَّی أَتَاہُ أَرْبَعَ مِرَارٍ ، فَأَمَرَ بِہِ أَنْ یُرْجَمَ ، فَلَمَّا أَصَابَتْہُ الْحِجَارَۃُ أَدْبَرَ یَشْتَدُّ ، فَلَقِیَہُ رَجُلٌ بِیَدِہِ لَحْیُ جَمَلٍ ، فَضَرَبَہُ فَصَرَعَہُ ، فَذُکِرَ لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِرَارُہُ حِینَ مَسَّتْہُ الْحِجَارَۃُ ، قَالَ : فَہَلاَّ تَرَکْتُمُوہُ۔ (بخاری 5272۔ مسلم 16)",,,29363
29364,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، عَنِ ابْنِ أَبْزَی ، عَنْ أَبِی بَکْرٍ ، قَالَ : أَتَی مَاعِزُ بْنُ مَالِکٍ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَأَقَرَّ عَندَہُ ثَلاَثَ مَرَّاتٍ ، فَقُلْتُ : إِنْ أَقْرَرْتَ عَندَہُ الرَّابِعَۃَ ، فَأَمَرَ بِہِ فَحُبِسَ ، یَعْنِی یُرْجَمُ۔ (احمد 8۔ ابویعلی 36)",,,29364
29365,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنِ الشَّعْبِیِّ ، قَالَ : شَہِدَ مَاعِزٌ عَلَی نَفْسِہِ أَرْبَعَ مَرَّاتٍ أَنَّہُ قَدْ زَنَی ، فَأَمَرَ بِہِ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یُرْجَمَ۔",,,29365
29366,"حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ سِمَاکٍ ، عَنْ جَابِرِ بْنِ سَمُرَۃَ ، قَالَ : رَأَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حِینَ أُتِیَ بِمَاعِزِ بْنِ مَالِکٍ ، أُتِیَ بِرَجُلٍ أَشْعَرَ ذِی عَضَلاَتٍ ، فِی إِزَارِہِ ، فَرَدَّہُ مَرَّتَیْنِ، ثُمَّ أَمَرَ بِرَجْمِہِ۔ (مسلم 1320۔ ابوداؤد 4422)",,,29366
29367,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا بَشِیرُ بْنِ الْمُہَاجِرٍ ، قَالَ : حَدَّثَنَی عَبْدُ اللہِ بْنُ بُرَیْدَۃَ ، عَنْ أَبِیہِ ؛ أَنَّ مَاعِزَ بْنَ مَالِکٍ الأَسْلَمِیَّ أَتَی رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : إِنِّی قَدْ ظَلَمْتُ نَفْسِی وَزَنَیْتُ ، وَإِنِّی أُرِیدُ أَنْ تُطَہِّرَنِی ، فَرَدَّہُ ، فَلَمَّا کَانَ الْغَدُ أَتَاہُ أَیْضًا ، فَقَالَ : یَا رَسُولَ اللہِ ، إِنِّی قَدْ زَنَیْتُ ، فَرَدَّہُ الثَّانِیَۃَ ، فَأَرْسَلَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إِلَی قَوْمِہِ ، فَقَالَ : أَتَعْلَمُونَ بِعَقْلِہِ بَأْسًا ؟ تُنْکِرُونَ مِنْہُ شَیْئًا ؟ فَقَالُوا : لاَ نَعْلَمُہُ إِلاَّ وَفِی الْعَقْلِ مِنْ صَالِحِینَا فِیمَا نُرَی ، قَالَ : فَأَتَاہُ الثَّالِثَۃَ ، فَأَرْسَلَ إِلَیْہِمْ أَیْضًا ، فَسَأَلَ عَنْہُ ؟ فَأَخْبَرُوہُ أَنَّہُ لاَ بَأْسَ بِہِ ، وَلاَ بِعَقْلِہِ ، فَلَمَّا کَانَ الرَّابِعَۃُ ، حَفَرَ لَہُ حُفْرَۃً ، ثُمَّ أَمَرَ بِہِ فَرُجِمَ۔ (مسلم 1323۔ ابوداؤد 4432)",,,29367
29368,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ دَاوُد ، عَنْ أَبِی نَضْرَۃَ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ، قَالَ : جَائَ مَاعِزُ بْنُ مَالِکٍ فَاعْتَرَفَ بِالزِّنَی ثَلاَثَ مَرَّاتٍ ، فَسَأَلَ عَنْہُ ؟ ثُمَّ أَمَرَ بِہِ فَرُجِمَ ، فَرَمَیْنَاہُ بِالْخَزَفِ ، وَالْجَنْدَلِ ، وَالْعِظَامِ ، وَمَا حَفَرْنَا لَہُ ، وَلاَ أَوْثَقْنَاہُ ، فَسَبَقْنَا إِلَی الْحَرَّۃِ وَاتَّبَعَناہُ ، فَقَامَ إِلَیْنَا ، فَرَمَیْنَاہُ حَتَّی سَکَتَ ، فَمَا اسْتَغْفَرَ لَہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَلاَ سَبَّہُ۔ (مسلم 1321۔ ابوداؤد 4429)",,,29368
29369,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ حَجَّاجٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ الْمُغِیرَۃِ الطَّائِفِیِّ ، عَنِ ابْنِ شَدَّادٍ ، عَنْ أَبِی ذَرٍّ ، قَالَ : کُنَّا مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی سَفَرٍ ، فَجَائَ رَجُلٌ فَأَقَرَّ أَنَّہُ قَدْ زَنَی ، فَرَدَّہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ثَلاَثًا ، فَلَمَّا کَانَتِ الرَّابِعَۃُ وَنَزَلَ ، أَمَرَ بِہِ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَرُجِمَ ، وَشَقَّ ذَلِکَ عَلَیْہِ حَتَّی عَرَفْتُہَ فِی وَجْہِہِ ، فَلَمَّا سُرِّیَ عَنْہُ الْغَضَبُ ، قَالَ : یَا أَبَا ذَرٍّ ، إِنَّ صَاحِبَکُمْ قَدْ غُفِرَ لَہُ ، قَالَ : وَکَانَ یُقَالُ : إِنَّ تَوْبَتَہُ أَنْ یُقَامَ عَلَیْہِ الْحَدُّ۔ (احمد 119۔ طحاوی 142)",,,29369
29370,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنِ ابْنِ أَبِی أَوْفَی ، قَالَ : قُلْتُ لَہُ : رَجَمَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ قَالَ : نَعَمْ ، قُلْتُ : بَعْدَ مَا أُنْزِلَتْ سُورَۃُ النُّورِ ، أَوْ قَبْلَہَا ؟ قَالَ : لاَ أَدْرِی۔\n\n(بخاری 6813۔ مسلم 1328)",,,29370
29371,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عُبَیْدِ اللہِ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : قَالَ عُمَرُ : قَدْ خَشِیت أَنْ یَطُولَ بِالنَّاسِ زَمَانٌ حَتَّی یَقُولَ الْقَائِلُ : مَا نَجِدُ الرَّجْمَ فِی کِتَابِ اللہِ ، فَیَضِلُّوا بِتَرْکِ فَرِیضَۃٍ أَنْزَلَہَا اللَّہُ ، أَلاَ وَإِنَّ الرَّجْمَ حَقٌّ ، إِذَا أُحْصِنَ الرَّجُل ، أَوْ قَامَتِ الْبَیِّنَۃُ ، أَوْ کَانَ حَمْلٌ ، أَوِ اعْتِرَافٌ ، وَقَدْ قَرَأْتُہَا : {الشَّیْخُ وَالشَّیْخَۃُ إِذَا زَنَیَا فَارْجُمُوہُمَا الْبَتَّۃَ}۔ \n\nرَجَمَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَرَجَمْنَا بَعْدَہُ۔\n\nقِیلَ لِسُفْیَانَ : رَجَمَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ قَالَ : نَعَمْ۔ (بخاری 2829۔ مسلم 1317)",,,29371
29372,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ حَمَّادٍ ، قَالَ : سَأَلْتُہُ عَنِ الرَّجُلِ یُقِرُّ بِالزِّنَی ، کَمْ یُرَدُّ ؟ قَالَ : مَرَّۃً ، وَسَأَلْتُ الْحَکَمَ ؟ فَقَالَ : أَرْبَعَ مَرَّاتٍ۔",,,29372
29373,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّ مَاعِزَ بْنَ مَالِکٍ أَتَی أَبَا بَکْرٍ فَأَخْبَرَہُ أَنَّہُ زَنَی ، فَقَالَ لَہُ أَبُو بَکْرٍ : ذَکَرَتَ ہَذَا لأَحَدٍ غَیْرِی ؟ قَالَ : لاَ ، قَالَ لَہُ أَبُو بَکْرٍ : اسْتَتِرْ بِسِتْرِ اللہِ ، وَتُبْ إِلَی اللہِ ، فَإِنَّ النَّاسَ یُعَیِّرُونَ ، وَلاَ یُغَیِّرُونَ ، وَاللَّہُ یَقْبَلُ التَّوْبَۃَ عَن عِبَادِہِ ، فَلَمْ تَقَرَّ نَفْسُہُ، حَتَّی أَتَی عُمَرَ ، فَذَکَرَ مِثْلَ مَا ذکرَ لأَبِی بَکْرٍ ، فَقَالَ لَہُ عُمَرُ : مِثْلَ مَا قَالَ أَبُو بَکْرٍ ، فَلَمْ تَقَرَّ نَفْسُہُ حَتَّی أَتَی رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَأَخْبَرَہُ أَنَّہُ قَدْ زَنَی ، فَأَعْرَضَ عَنْہُ ، حَتَّی قَالَ لَہُ ذَلِکَ مِرَارًا ، فَلَمَّا أَکْثَرَ ، بَعَثَ إِلَی قَوْمِہِ ، فَقَالَ لَہُمْ : ہَلَ اشْتَکَی ؟ أَبِہِ جِنَّۃٌ ؟ فَقَالُوا : لاَ وَاللَّہِ یَا رَسُولَ اللہِ ، إِنَّہُ صَحِیحٌ ، قَالَ : أَبِکْرٌ ، أَمْ ثَیِّبٌ ؟ قَالُوا : بَلْ ثَیِّبٌ ، فَأَمَرَ بِہِ فَرُجِمَ۔ (عبدالرزاق 13342)",,,29373
29374,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا دَاوُد ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ عُمَرَ ، قَالَ : رَجَمَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَرَجَمَ أَبُو بَکْرٍ ، وَرَجَمْتُ۔ (ترمذی 1431۔ مالک 10)",,,29374
29375,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ أَشْعَثَ ، عَنْ عَلِیِّ بْنِ زَیْدٍ ، عَنْ یُوسُفَ بْنِ مِہْرَانَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : قَالَ عُمَرُ : الرَّجْمُ حَدٌّ مِنْ حُدُودِ اللہِ ، فَلاَ تُخْدَعُوا عَنْہُ ، وَآیۃُ ذَلِکَ : أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجَمَ ، وَرَجَمَ أَبُو بَکْرٍ ، وَرَجَمْتُ أَنَا۔ (طیالسی 25۔ عبدالرزاق 13364)",,,29375
29376,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ مُحَمَّدِ بْنِ إِبْرَاہِیمَ ، عَن أَبِی عُثْمَانَ بْنِ نَصْرٍ ، عَنْ أَبِیہِ ، قَالَ : کُنْتُ فِیمَنْ رَجَمَ مَاعِزًا ، فَلَمَّا وَجَدَ مَسَّ الْحِجَارَۃِ ، قَالَ : رُدُّونِی إِلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَأَنْکَرْتُ ذَلِکَ ، فَأَتَیْتُ عَاصِمَ بْنَ عُمَرَ ، فَقَالَ : قَالَ الْحَسَنُ بْنُ مُحَمَّدِ بْنِ الْحَنَفِیَّۃِ : لَقَدْ بَلَغَنِی، فَأَنْکَرْتہ، فَأَتَیْتُ جَابِرًا، فَقُلْت: لَقَدْ ذَکَرَ الأَسْلَمِیُّ شَیْئًا مِنْ قَوْلِ مَاعِزِ بْنِ مَالِکٍ: رُدَّونِی، فَأَنْکَرْتُہُ، فَقَالَ: أَنَا فِیمَنْ رَجَمَہُ ، فَقَالَ: إِنَّہُ وَجَدَ مَسَّ الْحِجَارَۃِ ، قَالَ: رُدّونِی إِلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، فَإِنَّ قَوْمِی آذَوْنِی ، وَقَالُوا : ائْتِ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَإِنَّہُ غَیْرُ قَاتِلِکَ ، فَمَا أَقْلَعْنَا عَنْہُ حَتَّی قَتَلْنَاہُ ، فَلَمَا ذُکِرَ شَأْنُہُ لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : أَلاَ تَرَکْتُمُوہُ حَتَّی أَنْظُرَ فِی شَأْنِہِ۔\n\n(نسائی 7206۔ احمد 431)",,,29376
29377,"حَدَّثَنَا ہَوْذَۃُ بْنُ خَلِیفَۃَ ، قَالَ : حدَّثَنَا عَوْفٌ ، عَنْ مُسَاوِرِ بْنِ عُبَیْدٍ ، عَنْ أَبِی بَرْزَۃَ ،قَالَ : رَجَمَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجُلاً مِنَّا ، یُقَالُ لَہُ : مَاعِزُ بْنُ مَالِکٍ۔ (احمد 423۔ بزار 3855)",,,29377
29378,"حَدَّثَنَا مُحَمَّدُ بْنُ الْحَسَنِ ، عَنْ مُحَمَّدِ بْنِ سُلَیْمٍ أَبِی ہِلاَلٍ ، عَنْ نَجِیحٍ أَبِی عَلِی ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : رَجَمَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَرَجَمَ أَبُو بَکْرٍ ، وَعُمَرُ وَأَمْرُہُمَا سُنَّۃٌ۔",,,29378
29379,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَنْ سُفْیَانَ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، عَنْ یَزِیدَ بْنِ نُعَیْمٍ ، عَنْ أَبِیہِ ،قَالَ : جَائَ مَاعِزُ بْنُ مَالِکٍ إِلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : یَا رَسُولَ اللہِ ، إِنِّی قَدْ زَنَیْتُ فَأَقِمْ فِیَّ کِتَابَ اللہِ ، فَأَعْرَضَ عَنْہُ ، ثُمَّ قَالَ : إِنِّی قَدْ زَنَیْتُ ، فَأَقِمْ فِیَّ کِتَابَ اللہِ ، فَأَعْرَضَ عَنْہُ حَتَّی ذَکَرَ أَرْبَعَ مَرَّاتٍ ، قَالَ : اذْہَبُوا فَارْجُمُوہُ ، فَلَمَّا مَسَّہُ مَسَّ الْحِجَارَۃُ اشْتَدَّ ، فَخَرَجَ عَبْدُ اللہِ بْنُ أُنَیْسٍ ، أَوِ ابْنُ أَنَسٍ ، مِنْ بَادِیَتِہِ ، فَرَمَاہُ بِوَظِیفِ جَمَلٍ فَصَرَعَہُ ، فَرَمَاہُ النَّاسُ حَتَّی قَتَلُوہُ ، فَذُکِرَ ذَلِکَ لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِرَارُہُ ، فَقَالَ : ہَلاَّ تَرَکْتُمُوہُ یَتُوبُ ، فَیَتُوبَ اللَّہُ عَلَیْہِ ، یَا ہَزَّالُ ، أَوْ یَا ہِزَّانُ ، لَوْ سَتَرْتَہُ بِثَوْبِکَ ؛ کَانَ خَیْرًا لَکَ مِمَّا صَنَعْتَ۔ (بیہقی 219۔ احمد 217)",,,29379
29380,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عُبَیْدِ اللہِ بْنِ عَبْدِ اللہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، وَزَیْدِ بْنِ خَالِدٍ ، وَشِبْلٍ ؛ أَنَّہُمْ قَالُوا :\n\nکُنَّا عَندَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَامَ رَجُلٌ ، فَقَالَ : أُنْشِدُک اللَّہَ إِلاَ قَضَیْتَ بَیْنَنَا بِکِتَابِ اللہِ ، فَقَالَ : خَصْمُہُ ، وَکَانَ أَفْقَہَ مِنْہُ: اقْضِ بَیْنَنَا بِکِتَابِ اللہِ ، وَائْذَنْ لِی حَتَّی أَقُولَ، قَالَ: قُلْ، قَالَ: إِنَّ ابْنِی کَانَ عَسِیفًا عَلَی ہَذَا ، وَإِنَّہُ زَنَی بِامْرَأَتِہِ ، فَافْتَدَیْتُ مِنْہُ بِمِئَۃِ شَاۃٍ وَخَادِمٍ ، فَسَأَلْتُ رِجَالاً مِنْ أَہْلِ الْعِلْمِ ؟ فَأُخْبِرْتُ أَنَّ عَلَی ابْنِی جَلْدَ مِئَۃٍ وَتَغْرِیبَ عَامٍ ، وَأَنَّ عَلَی امْرَأَۃِ ہَذَا الرَّجْمَ ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : وَالَّذِی نَفْسِی بِیَدِہِ ، لأَقْضِیَنَّ بَیْنَکُمَا بِکِتَابِ اللہِ ، الْمِئَۃُ شَاۃٍ وَالْخَادِمُ رَدٌّ عَلَیْک ، وَعَلَی ابْنِکَ جَلْدُ مِئَۃٍ وَتَغْرِیبُ عَامٍ، وَاغْدُ یَا أُنَیْسُ عَلَی امْرَأَۃِ ہَذَا، فَإِنَ اعْتَرَفْت فَارْجُمْہَا۔(بخاری 2315۔ ابن ماجہ 2549)",,,29380
29381,"حَدَّثَنَا شَبَابَۃُ بْنُ سوَّارٍ ، عَنْ شُعْبَۃَ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، عَنْ حِطَّانَ بْنِ عَبْدِ اللہِ ، عَنْ عُبَادَۃَ بْنِ الصَّامِتِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : خُذُوا عَنِی ، قَدْ جَعَلَ اللَّہُ لَہُنَّ سَبِیلاً ، الثَّیِّبُ بِالثَّیِّبِ ، وَالْبِکْرُ بِالْبِکْرِ ، الْبِکْرُ یُجْلَدُ وَیُنْفَی ، وَالثَّیِّبُ یُجْلَدُ وَیُرْجَمُ۔ (مسلم 13۔ ابوداؤد 4415)",,,29381
29382,"حَدَّثَنَا شَرِیکُ بْنُ عَبْدِ اللہِ ، عَنْ فِرَاسٍ ، عَنْ عَامِرٍ ، عَنْ مَسْرُوقٍ ، عنْ أُبَیٍّ ، قَالَ : إِذَا زَنَی الْبِکْرَانِ یُجْلَدَانِ وَیُنْفَیَانِ ، وَإِذَا زَنَی الثَّیِّبَانِ یُجْلَدَانِ وَیُرْجَمَانِ۔",,,29382
29383,حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ، عَنْ إِسْمَاعِیلَ، عَنِ الشَّعْبِیِّ، عَنْ أُبَیٍّ؛ أَنَّہُ کَانَ یَرَی فِی الثَّیِّبِ یُجْلَدُ وَیُرْجَمُ۔,,,29383
29384,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ مُسْلِمٍ ، عَنْ مَسْرُوقٍ ، قَالَ : الْبِکْرَانِ یُجْلَدَانِ وَیُنْفَیَانِ ، وَالثَّیِّبَانِ یُجْلَدَانِ وَیُرْجَمَانِ۔",,,29384
29385,حَدَّثَنَا ہُشَیْمٌ ، عَنْ حُصَیْنٍ ، وَالشَّیْبَانِیِّ ، وَأَشْعَثَ ، عَنِ الشَّعْبِیِّ ؛ أَنَّ عَلِیًا جَلَدَ وَرَجَمَ۔,,,29385
29386,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : کَانَ عُمَرُ یَرْجُمُ وَیَجْلِدُ ، وَکَانَ عَلِیٌّ یَرْجُمُ وَیَجْلِدُ۔",,,29386
29387,"حَدَّثَنَا وَکِیعٌ ، عَنِ الْمَسْعُودِیِّ ، عَنِ الْقَاسِمِ ، قَالَ : قَالَ أَبُو ذَرٍّ : الشَّیْخَانِ الثَّیِّبَانِ یُجْلَدَانِ وَیُرْجَمَانِ، وَالْبِکْرَانِ یُجْلَدَانِ وَیُنْفَیَانِ۔",,,29387
29388,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَن زَمْعَۃَ ، عَنِ ابْنِ طَاوُوسٍ، عَنْ أَبِیہِ، قَالَ: عَلَی الْمُحْصَنِ إِذَا زَنَی الرَّجْمُ، وَعَلَی الْبِکْرِ الْجَلْدُ وَالنَّفْیُ۔",,,29388
29389,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ مُحَمَّدِ بْنِ سَالِمٍ ، عَنْ عَامِرٍ ؛ فِی الْبِکْرِ إِذَا زَنَی یُنْفَی سَنَۃً۔,,,29389
29390,حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ الأَعْمَشِ ، عَنِ الْقَاسِمِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِیہِ ؛ أَنَّ عَلِیًّا جَلَدَ وَرَجَمَ، جَلَدَ یَوْمَ الْخَمِیسِ ، وَرَجَمَ یَوْمَ الْجُمُعَۃِ۔,,,29390
29391,حَدَّثَنَا شَاذَانُ ، وَعَفَّانُ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَن سِمَاکٍ ، عَنْ جَابِرِ بْنِ سَمُرَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجَمَ مَاعِزَ بْنَ مَالِکٍ ، وَلَمْ یَذْکُرْ جَلْدًا۔ (احمد 92۔ طبرانی 1967),,,29391
29392,حَدَّثَنَا شَبَابَۃُ ، عَنْ لَیْثٍ ، عَنْ نَافِعٍ ، عَنْ صَفِیَّۃَ بِنْتِ أَبِی عُبَیْدٍ ، عَنْ أَبِی بَکْرٍ ؛ أَنَّہُ جَلَدَ رَجُلاً وَقَعَ عَلَی جَارِیَۃٍ بِکْرٍ ، فَأَحْبَلَہَا ، فَاعْتَرَفَ ، وَلَمْ یَکُنْ أُحْصِنَ ، فَأَمَرَ بِہِ أَبُو بَکْرٍ فَجُلِدَ ، ثُمَّ نُفِیَ۔,,,29392
29393,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَن زَیْدِ بْنِ أَسْلَمَ ، عْن أَبِیہِ ؛ أَنَّ عُمَرَ نَفَی إِلَی فَدَکَ۔,,,29393
29394,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنِ ابْنِ یَسَارٍ مَوْلًی لِعُثْمَانَ ، قَالَ : جَلَدَ عُثْمَانُ امْرَأَۃً فِی زِنًا ، ثُمَّ أَرْسَلَ بِہَا مَوْلًی لَہُ ، یُقَالُ لَہُ : الْمُہْرِیُّ ، إِلَی خَیْبَرَ ، فَنَفَاہَا إِلَیْہَا۔",,,29394
29395,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَیِّ ؛ أَنَّ عَلِیًّا نَفَی إِلَی الْبَصْرَۃِ۔,,,29395
29396,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنِ الأَجْلَحِ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : أُتِیَ عَلِیٌّ بِجَارِیَۃٍ مِنْ ہَمْدَانَ ، فَضَرَبَہَا وَسَیَّرَہَا إِلَی الْبَصْرَۃِ سَنَۃً۔",,,29396
29397,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ إِسْمَاعِیلَ بْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : قُلْتُ لَہُ فِی زَمَنِ ابْنِ ہُبَیْرَۃَ : مِنْ أَیْنَ یُنْفَی فِی الزِّنَی ؟ قَالَ : مِنْ عَمَلِہِ إِلَی عَمِلِ غَیْرِہِ۔",,,29397
29398,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ رَجُلٍ ، عَنِ الْحَسَنِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَفَی إِلَی خَیْبَرَ۔,,,29398
29399,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا مُحَمَّدُ بْنُ إِسْحَاقَ ، عَن نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ أَبَا بَکْرٍ نَفَی رَجُلاً وَامْرَأَۃً حَوْلاً۔",,,29399
29400,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ الزُّہْرِیِّ ؛ أَنَّ عُمَرَ نَفَی إِلَی الْبَصْرَۃِ۔,,,29400
29401,"حَدَّثَنَا وَکِیعٌ ، عَن زَکَرِیَّا أَبِی عِمْرَانَ ، قَالَ : سَمِعْتُ شَیْخًا یُحَدِّثُ ، عَنِ ابْنِ أَبِی بَکْرَۃَ ، عَنْ أَبِیہِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجَمَ امْرَأَۃً فَحَفَرَ إِلَی الثَّنْدُوَۃِ۔ (ابوداؤد 4440۔ احمد 36)",,,29401
29402,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ الْقَطَّانُ ، عَن مُجَالِدٍ ، عَنْ عَامِرٍ ؛ أَنَّ عَلِیًّا رَجَمَ امْرَأَۃً ، فَحَفَرَ لَہَا إِلَی السُّرَّۃِ ، وَأَنَا شَاہِد ذَلِکَ۔,,,29402
29403,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، قَالَ : حَدَّثَنَا بَشِیرُ بْنُ الْمُہَاجِرِ ، قَالَ : حدَّثَنَی عَبْدُ اللہِ بْنُ بُرَیْدَۃَ ، عَنْ أَبِیہِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَتَتْہُ الْغَامِدِیَّۃُ ، فَأَقَرَّتْ عَندَہُ بِالزِّنَی ، فَأَمَرَ بِہَا ، فَحُفِرَ لَہَا إِلَی صَدْرِہَا ، وَأَمَرَ النَّاسَ فَرَجَمُوا ، ثُمَّ أَمَرَ بِہَا فَصُلِّیَ عَلَیْہَا ، ثُمَّ دُفِنَتْ۔ (مسلم 1323۔ ابوداؤد 4439)",,,29403
29404,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ سِمَاکٍ ، عَنِ الْحَسَنِ ، قَالَ : جَائَتِ امْرَأَۃٌ مِنْ بَارِقَ إِلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَتْ : إِنِّی قَدْ زَنَیْت فَأَقِمْ فِیَّ حَدَّ اللہِ ، قَالَ : فَرَدَّہَا النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَتَّی شَہِدَتْ عَلَی نَفْسِہَا شَہَادَاتٍ ، قَالَ : فَقَالَ لَہَا النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : ارْجِعِی ، فَلَمَّا وَضَعَتْ حَمْلَہَا أَمَرَہَا النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَتَطَہَّرَتْ ، وَلَبِسَتْ أَکْفَانَہَا ، ثُمَّ أُمِرَ بِہَا فَرُجِمَتْ ، فَأَصَابَ خَالِدَ بْنَ الْوَلِیدِ مِنْ دَمِہَا فَسَبَّہَا ، فَنَہَاہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : لَقَدْ تَابَتْ تَوْبَۃً لَوْ تَابَہَا صَاحِبُ مَکْسٍ لَقُبِلَ مِنْہُ۔ (ابوداؤد 249)",,,29404
29405,"حَدَّثَنَا ابْنُ نُمَیْرٍ، قَالَ: حدَّثَنَا بَشِیرُ بْنُ مُہَاجِرٍ ، قَالَ: حَدَّثَنَا عَبْدُ اللہِ بْنُ بُرَیْدَۃَ ، عَنْ أَبِیہِ ، قَالَ : جَائَتِ الْغَامِدِیَّۃُ ، فَقَالَتْ : یَا رَسُولَ اللہِ ، إِنِّی قَدْ زَنَیْتُ ، وَإِنِّی أُرِیدُ أَنْ تُطَہِّرَنِی ، وَإِنَّہُ رَدَّہَا ، فَلَمَّا کَانَ الْغَدُ ، قَالَتْ : یَا نَبِیَّ اللہِ ، لِمَ تَرُدَّنِی ؟ فَلَعَلَّک أَنْ تُرَدِّدَنِی کَمَا رَدَّدْتَ مَاعِزَ بْنَ مَالِکٍ ، فَوَاللَّہِ إِنِّی لِحُبْلَی ، قَالَ : إِمَّا لاَ ، فَاذْہَبِی حَتَّی تَلِدِی ، فَلَمَّا وَلَدَتْ أَتَتْہُ بِالصَّبِیِّ فِی خِرْقَۃٍ ، قَالَتْ : ہَذَا قَدْ وَلَدْتُہُ ، قَالَ : اذْہَبِی فَأَرْضِعِیہِ ، حَتَّی تَفْطِمِیہِ ، فَلَمَّا فَطَمَتْہُ أَتَتْہُ بِالصَّبِیِّ ، وَفِی یَدِہِ کِسْرَۃُ خُبْزٍ ، فَقَالَتْ : ہَذَا یَا نَبِیَّ اللہِ قَدْ فَطَمْتُہُ ، وَقَدْ أَکَلَ الطَّعَامَ ، فَدُفَعَ الصَّبِیَّ إِلَی رَجُلٍ مِنَ الْمُسْلِمِینَ ، ثُمَّ أَمَرَ بِہَا فَحُفِرَ لَہَا إِلَی صَدْرِہَا ، وَأَمَرَ النَّاسَ فَرَجَمُوا ، فَأَقْبَلَ خَالِدُ بْنُ الْوَلِیدِ بِحَجَرٍ فَرَمَی رَأْسَہَا ، فَانْتَضَخَ الدَّمُ عَلَی وَجْہِ خَالِدِ بْنِ الْوَلِیدِ ، فَسَمِعَ نَبِیُّ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سَبَّہُ إِیَّاہَا ، فَقَالَ : مَہْلاً یَا خَالِدُ بْنَ الْوَلِیدِ ، فَوَالَّذِی نَفْسِی بِیَدِہِ ، لَقَدْ تَابَتْ تَوْبَۃً لَوْ تَابَہَا صَاحِبُ مَکْسٍ لَغُفِرَ لَہُ ، ثُمَّ أَمَرَ بِہَا فَصُلَّیَ عَلَیْہَا وَدُفِنَتْ۔",,,29405
29406,"حَدَّثَنَا عَفَّانُ بْنُ مُسْلِمٍ ، قَالَ : حدَّثَنَا أَبَانُ الْعَطَّارُ ، قَالَ : حَدَّثَنَی یَحْیَی بْنُ أَبِی کَثِیرٍ ، عَنْ أَبِی قِلاَبَۃَ ، عَنْ أَبِی الْمُہَلَّبِ ، عَنْ عِمْرَانَ بْنِ حُصَیْنٍ ؛ أَنَّ امْرَأَۃً مِنْ جُہَیْنَۃَ أَتَتِ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَتْ : إِنِّی أَصَبْتُ حَدًّا فَأَقِمْہُ عَلَیَّ ، وَہِیَ حَامِلٌ ، فَأَمَرَ بِہَا أَنْ یُحْسَنَ إِلَیْہَا حَتَّی تَضَعَ ، فَلَمَّا أَنْ وَضَعَتْ ، جِیئَ بِہَا إِلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَأَمَرَ بِہَا ، فَشُکَّتْ عَلَیْہَا ثِیَابُہَا ، ثُمَّ رَجَمَہَا وَصَلَّی عَلَیْہَا ، فَقَالَ عُمَرُ : یَا نَبِیَّ اللہِ ، أَتُصَلِّی عَلَیْہَا وَقَدْ زَنَتْ ؟ فَقَالَ : لَقَدْ تَابَتْ تَوْبَۃً لَوْ قُسِمَتْ بَیْنَ سَبْعِینَ مِنْ أَہْلِ الْمَدِینَۃِ لَوَسِعَتْہُمْ ، وَہَلْ وَجَدْتَ أَفْضَلَ مِنْ أَنْ جَادَتْ بِنَفْسِہَا۔ (مسلم 1324۔ ابوداؤد 4437)",,,29406
29407,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الأَجْلَحِ ، عَنِ الشَّعْبِیِّ ، قَالَ : أُتِیَ عَلِیٌّ بِشُرَاحَۃَ ، امْرَأَۃٍ مِنْ ہَمْدَانَ ، وَہِیَ حُبْلَی مِنْ زِنًی ، فَأَمَرَ بِہَا عَلِیٌّ فَحُبِسَتْ فِی السِّجْنِ ، فَلَمَّا وَضَعَتْ مَا فِی بَطْنِہَا ، أَخْرَجَہَا یَوْمَ الْخَمِیسِ ، فَضَرَبَہَا مِئَۃ سَوْطٍ ، وَرَجَمَہَا یَوْمَ الْجُمُعَۃِ۔",,,29407
29408,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی سُفْیَانَ ، عَنْ أَشْیَاخِہِ ؛ أَنَّ امْرَأَۃً غَابَ عنہا زَوْجُہَا ، ثُمَّ جَائَ وَہِیَ حَامِلٌ ، فَرَفَعَہَا إِلَی عُمَرَ ، فَأَمَرَ بِرَجْمِہَا ، فَقَالَ مُعَاذٌ : إِنْ یَکُنْ لَکَ عَلَیْہَا سَبِیلٌ ، فَلاَ سَبِیلَ لَکَ عَلَی مَا فِی بَطْنِہَا ، فَقَالَ عُمَرُ : احْبِسُوہَا حَتَّی تَضَعَ ، فَوَضَعَتْ غُلاَمًا لَہُ ثَنِیَّتَانِ ، فَلَمَّا رَآہُ أَبُوہُ ، قَالَ : ابْنِی ، ابْنِی ، فَبَلَغَ ذَلِکَ عُمَرَ ، فَقَالَ : عَجَزَتِ النِّسَائُ أَنْ تَلِدْنَ مِثْلَ مُعَاذٍ ، لَوْلاَ مُعَاذٌ ہَلَکَ عُمَرُ۔",,,29408
29409,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ حَجَّاجٍ ، عَنِ الْحَسَن بْن سَعْدٍ ، عَنْ عَبْدِ الرَّحَمَن بْنِ عَبْدِ اللہِ ، قَالَ : أُتِیَ عَلِیٌّ بِامْرَأَۃٍ قَدْ زَنَتْ ، فَحَبَسَہَا حَتَّی وَضَعَتْ وَتَعَلَّتْ مِنْ نِفَاسہَا۔",,,29409
29410,حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ حَجَّاجٍ ، عَنِ الْقَاسِمِ ، عَنْ أَبِیہِ ، عَنْ عَلِیٍّ ؛ مِثْلَہُ۔,,,29410
29411,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنِ الْحَسَنِ بْنِ صَالِحٍ ، عَنْ سِمَاکٍ ، قَالَ : حدَّثَنِی ذُہلُ بْنُ کَعْبٍ ، قَالَ : أَرَادَ عُمَرُ أَنْ یَرْجُمَ الْمَرْأَۃَ الَّتِی فَجَرَتْ وَہِیَ حَامِلٌ ، فَقَالَ لَہُ مُعَاذٌ : إِذًا تَظْلِمُہَا ، أَرَأَیْتَ الَّذِی فِی بَطْنِہَا ، مَا ذَنْبُہُ ؟ عَلاَمَ تَقْتُلْ نَفْسَیْنِ بِنَفْسٍ وَاحِدَۃٍ ؟ فَتَرَکَہَا حَتَّی وَضَعَتْ حَمْلَہَا ، ثُمَّ رَجَمَہَا۔",,,29411
29412,حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْمِنْہَالِ ، عَنْ زَاذَانَ ؛ أَنَّ عَلِیًّا أَمَرَ بِہَا فَلُفَّتْ فِی عَبَائِۃٍ۔,,,29412
29413,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ صَالِحِ بْنِ صَالِحٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ سَعِیدِ الْہَمْدَانِیِّ ، عَنْ مَسْعُودٍ ، رَجُلٍ مِنْ آلِ أَبِی الدَّرْدَائِ ؛ أَنَّ عَلِیًّا لَمَّا رَجَمَ شُرَاحَۃَ ، جَعَلَ النَّاسُ یَلْعَنُونَہَا ، فَقَالَ : أیُّہَا النَّاسُ ، لاَ تَلْعَنُوہَا ، فَإِنَّہُ مَنْ أُقِیمَ عَلَیْہِ عَصَا حَدٍّ ، فَہُوَ کَفَّارَتُہُ ، جَزَائَ الدَّیْن بِالدَّیْنِ۔",,,29413
29414,حَدَّثَنَا عَبْدُ اللہِ بْنُ إِدْرِیسَ ، عَنْ یَزِیدَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ؛ أَنَّ عَلِیًّا کَانَ إِذَا شَہِدَ عَندَہُ الشُّہُودُ عَلَی الزِّنَی ، أَمَرَ الشُّہُودَ أَنْ یَرْجُمُوا ، ثُمَّ رَجَمَ ، ثُمَّ رَجَمَ النَّاسُ ، وَإِذَا کَانَ إِقْرَارًا ، بَدَأَ ہُوَ فَرَجَمَ، ثُمَّ رَجَمَ النَّاسُ۔,,,29414
29415,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ حَجَّاجٍ ، عَنِ الْحَسَنِ بْنِ سَعْدٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَبْدِ اللہِ بْنِ مَسْعُودٍ ، عَنْ عَلِیٍّ ، قَالَ : أَیُّہَا النَّاسُ ، إِنَّ الزِّنَی زِنَائَانِ : زِنَی سِرٍّ ، وَزِنَی عَلاَنِیَۃٍ ، فَزِنَی السِّرِّ ، أَنْ یَشْہَدَ الشُّہُودُ فَتَکُونَ الشُّہُودُ أَوَّلَ مَنْ یَرْمِی ، ثُمَّ الإِمَامُ ، ثُمَّ النَّاسُ ، وَزِنَی الْعَلاَنِیَۃِ ، أَنْ یَظْہَرَ الْحَبَلُ ، أَوِ الاِعْتِرَافُ ، فَیَکُونُ الإِمَامُ أَوَّلَ مَنْ یَرْمِی ، قَالَ : وَفِی یَدِہِ ثَلاَثَۃُ أَحْجَارٍ ، قَالَ : فَرَمَاہَا بِحَجَرٍ فَأَصَابَ صِمَاخَہَا فَاسْتَدَارَتْ ، وَرَمَی النَّاسُ۔",,,29415
29416,حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ حَجَّاجٍ ، عَنِ الْقَاسِمِ ، عَنْ أَبِیہِ ، عَنْ عَلِیٍّ ؛ مِثْلُہُ۔,,,29416
29417,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، قَالَ : سَمِعْتُ عَمْرَو بْنَ نَافِعٍ ، یُحَدِّثُ عَنْ عَلِیٍّ ، قَالَ : الرَّجْمُ رَجْمَانِ ، فَرَجْمٌ یَرْجُمُ الإِمَامُ ، ثُمَّ النَّاسُ ، وَرَجْمٌ یَرْجُمُ الشُّہُودُ ، ثُمَّ الإِمَامُ ، ثُمَّ النَّاسُ ، فَقُلْتُ لِلْحَکَمِ : مَا رَجْمُ الإِمَامِ ؟ قَالَ : إِذَا وَلَدَتْ ، أَوْ أَقَرَّتْ ، وَرَجْمُ الشُّہُودِ إِذَا شَہِدُوا۔",,,29417
29418,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، قَالَ : قُلْتُ لِلْحَکَمِ : مَا رَجْمُ الإِمَامِ ؟ قَالَ : إِذَا وَلَدَتْ ، أَوْ أَقَرَّتْ ، وَإِذَا شَہِدَ الشُّہُودُ بَدَأَ الشُّہُودُ۔",,,29418
29419,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی عُثْمَانَ ، قَالَ : لَمَّا شَہِدَ أَبُو بَکْرَۃَ وَصَاحِبَاہُ عَلَی الْمُغِیرَۃِ ، جَائَ زِیَادٌ ، فَقَالَ لَہُ عُمَرُ : رَجُلٌ لَنْ یَشْہَدَ إِنْ شَائَ اللَّہُ إِلاَّ بِحَقٍّ ، قَالَ : رَأَیْتُ انْبِہَارًا وَمَجْلِسًا سَیِّئًا ، فَقَالَ عُمَرُ : ہَلْ رَأَیْتَ الْمِرْوَدَ دَخَلَ الْمُکْحُلَۃِ ؟ قَالَ : لاَ ، فَأَمَرَ بِہِمْ فَجُلِدُوا۔",,,29419
29420,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ زَیْدٍ ، عَنْ یَحْیَی بْنِ عَتِیقٍ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّ أُنَاسًا شَہِدُوا عَلَی رَجُلٍ فِی زِنًی ، قَالَ : فَقَالَ عُثْمَانُ بِیَدِہِ ہَکَذَا : تَشْہَدُونَ أَنَّہُ ،وَجَعَلَ یُدْخِلُ إِصْبَعَہُ السَّبَّابَۃَ فِی إِصْبَعِہِ الْیُسْرَی ، وَقَدْ عَقَدَ بِہَا عَشْرًۃ۔",,,29420
29421,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَوْفٍ ، عَنْ قَسَامَۃَ بْنِ زُہَیْرٍ ، قَالَ : لَمَّا کَانَ مِنْ شَأْنِ أَبِی بَکْرَۃَ وَالْمُغِیرَۃِ بْنِ شُعْبَۃَ الَّذِی کَانَ ، قَالَ أَبُو بَکْرَۃَ : اجْتَنِبْ ، أَوْ تَنَحَّ عَن صَلاَتِنَا ، فَإِنَّا لاَ نُصَلِّی خَلْفَک ، قَالَ : فَکَتَبَ إِلَی عُمَرَ فِی شَأْنِہِ ، قَالَ : فَکَتَبَ عُمَرُ إِلَی الْمُغِیرَۃِ : أَمَّا بَعْدُ ، فَإِنَّہُ قَدْ رَقِیَ إِلَیَّ مِنْ حَدِیثِکَ حَدِیثٌ ، فَإِنْ یَکُنْ مَصْدُوقًا عَلَیْک ، فَلأَنْ تَکُونَ مِتَّ قَبْلَ الْیَوْمِ خَیْرٌ لَکَ ، قَالَ : فَکَتَبَ إِلَیْہِ وَإِلَی الشُّہُودِ ، أَنْ یُقْبِلُوا إِلَیْہِ۔\n\nفَلَمَّا انْتَہَوْا إِلَیْہِ ، دَعَا الشُّہُودَ فَشَہِدُوا ، فَشَہِدَ أَبُو بَکْرَۃَ ، وَشِبْلُ بْنُ مَعْبَدٍ ، وَأَبُو عَبْدِ اللہِ نَافِعٌ ، قَالَ : فَقَالَ عُمَرُ حِینَ شَہِدَ ہَؤُلاَئِ الثَّلاَثَۃُ : أَوْدَی الْمُغِیرَۃِ أَرْبَعَۃٌ ، وَشَقَّ عَلَی عُمَرَ شَأْنُہُ جِدًّا ، فَلَمَّا قَامَ زِیَادٌ ، قَالَ: لَنْ یَشْہَدْ إِنْ شَائَ اللَّہُ إِلاَّ بِحَقٍّ ، ثُمَّ شَہِدَ ، فَقَالَ : أَمَّا الزِّنَی فَلاَ أَشْہَدُ بِہِ ، وَلَکِنِّی قَدْ رَأَیْتُ أَمْرًا قَبِیحًا، فَقَالَ عُمَرُ : اللَّہُ أَکْبَرُ ، حُدُّوہُمْ ، فَجَلَدَہُمْ ، فَلَمَّا فَرَغَ مِنْ جَلْدِ أَبِی بَکْرَۃَ ، قَامَ أَبُو بَکْرَۃَ ، فَقَالَ : أَشْہَدُ أَنَّہُ زَانٍ ، فَذَہَب عُمَرُ یُعِیدَ عَلَیْہِ الْحَدَّ ، فَقَالَ عَلِیٌّ : إِنْ جَلَدْتَہُ فَارْجُمْ صَاحِبَک ، فَتَرَکَہُ ، فَلَمْ یُجْلَدْ فِی قَذفٍ مَرَّتَیْنِ بَعْدُ۔",,,29421
29422,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ أَبِی خَلْدَۃَ ، قَالَ : لَقِیَنِی سَعِیدُ بْنُ أَرْطَبَان ، عَمُّ ابْنِ عَوْنٍ ، فَقَالَ : أَتُرِیدُ أَنْ تَأْتِیَ أَبَا الْعَالِیَۃِ ؟ قُلْتُ : نَعَمْ ، قَالَ : فَقُلْ لَہُ : شَہِدَ الْحَسَنُ ، وَابْنُ سِیرِینَ ، وَثَابِتٌ الْبُنَانِیُّ عَلَی امْرَأَۃٍ وَرَجُلٍ أَنَّہُمَا زَنَیَا ، وَأَقَرَّتِ الْمَرْأَۃُ ، وَأَنْکَرَ الرَّجُلُ ؟ فَسَأَلْتُ أَبَا الْعَالِیَۃِ عَن ذَلِکَ ؟ فَقَالَ : لَقِیْتَ رَجُلاً مِنْ أَہْلِ الأَہْوَائِ ؛ یُجْلَدُ الْحَسَنُ ثَمَانِینَ ، وَمُحَمَّدٌ ثَمَانِینَ ، وَثَابِتٌ ثَمَانِینَ ، وَتُرْجَمُ الْمَرْأَۃُ بِاعْتِرَافِہَا ، وَیَذْہَبُ الرَّجُلُ لَیْسَ عَلَیْہِ شَیْئٌ۔",,,29422
29423,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنِ الشَّعْبِیِّ ؛ أَنَّ الْیَہُودَ قَالُوا لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَا حَدَّ ذَلِکَ ؟ یَعْنونَ الرَّجْمَ ، قَالَ : إِذَا شَہِدَ أَرْبَعَۃٌ أَنَّہُمْ رَأَوْہُ یُدْخِلُ کَمَا یُدْخِلُ الْمِیلُ فِی الْمُکْحُلَۃِ ، فَقَدْ وَجَبَ الرَّجْمُ۔",,,29423
29424,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ، قَالَ : إِذَا شَہِدَ أَرْبَعَۃٌ عَلَی شَیْئٍ ،مَنَعُوا ظُہُورَہُمْ ، وَجَازَتْ شَہَادَاتُہُمْ۔",,,29424
29425,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ، عَنْ جَعْفَرٍ، عَنْ أَبِیہِ، قَالَ: قَالَ عَلِّیٌّ: مَا أُحِبَّ أَنْ أَکُونَ أَوَّلَ الشُّہُودِ الأَرْبَعَۃِ۔",,,29425
29426,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : أُتِیَ عَلِیٌّ بِرَجُلٍ وَشَہِدَ عَلَیْہِ رَجُلاَنِ أَنَّہُ سَرَقَ ، فَأَخَذَ فِی شَیْء مِنْ أُمُورِ النَّاسِ ، وَتَہَدَّدَ شُہُودَ الزُّورِ ، فَقَالَ : لاَ أُوتَی بِشَاہِدِ زُورٍ إِلاَّ فَعَلْتُ بِہِ کَذَا وَکَذَا ، قَالَ : ثُمَّ طَلَبَ الشَّاہِدَیْنِ فَلَمْ یَجِدْہُمَا ، فَخَلَّی سَبِیلَہُ۔",,,29426
29427,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ حَجَّاجٍ ، عَنِ الْحَسَنِ بْنِ سَعْدٍ ، عَنْ عَبْدِ اللہِ بْنِ شَدَّادٍ ؛ أَنَّ امْرَأَۃً رُفِعَتْ إِلَی عُمَرَ ، أَقَرَّتْ بِالزِّنَی أَرْبَعَ مَرَّاتٍ ، فَقَالَ : إِنْ رَجَعْتِ لَمْ نُقِمْ عَلَیْکِ الْحَدَّ ، فَقَالَتْ : لاَ یَجْتَمِعُ عَلَیَّ أَمْرَانِ ؛ آتِی الْفَاحِشَۃَ ، وَلاَ یُقَامُ عَلَیَّ الْحَدُّ ، قَالَ : فَأَقَامَہُ عَلَیْہَا۔",,,29427
29428,حَدَّثَنَا حَفْصٌ، عَنْ حَجَّاجٍ، عَنْ نَافِع، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ؛ أَنَّ أَبَا وَاقِدٍ بَعَثَہُ عُمَرُ إِلَیْہَا ، فَذَکَرَ مِثْلَہُ۔,,,29428
29429,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، وَعَطَائٍ ، قَالاَ : إِذَا أَقَرَّ بِحَدِّ زِنًی ، أَوْ سَرِقَۃٍ ، ثُمَّ جَحَدَ دُرِئَ عَنْہُ۔",,,29429
29430,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ قَتَادَۃَ ، عَنْ یَحْیَی بْنِ یَعْمُرَ ، قَالَ : إِنْ کَانَ أَقَرَّ فَقَدْ أَنْکَرَ ، یَعْنِی الَّذِی یُقِرُّ بِالْحَدِّ ، ثُمَّ یَرْجِعُ۔",,,29430
29431,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حُمَیْدٍ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یُقِرُّ عِنْدَ النَّاسِ ، ثُمَّ یَجْحَدُ ، قَالَ : یُؤْخَذُ بِہِ۔",,,29431
29432,حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یُقِرُّ بِالْحَدِّ دُونَ السُّلْطَانِ ، ثُمَّ یَجْحَدُ إِذَا رُفِعَ ، لَمْ یَرَ أَنْ یَلْزَمَہُ۔,,,29432
29433,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنَی إِسْمَاعِیلُ ، عَنِ ابْنِ شِہَابٍ ،قَالَ : مَنِ اعْتَرَفَ مِرَارًا کَثِیرَۃً بِسَرِقَۃٍ ، أَوْ بِحَدٍّ ثُمَّ أَنْکَرَ ، لَمْ یَجُزْ عَلَیْہِ شَیئٌ۔",,,29433
29434,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ دَاوُد ، عَنْ زِیَادِ بْنِ عُثْمَان ؛ أَنَّ رَجُلاً مِن النَّصَارَی اسْتَکْرَہ امْرَأَۃً مُسْلِمَۃً عَلَی نَفْسِہَا ، فَرُفِعَ إِلَی أَبِی عُبَیْدَۃَ بْنِ الْجَرَّاحِ ، فَقَالَ : مَا عَلَی ہَذَا صَالَحْنَاکُم ، فَضَرَبَ عُنُقَہُ۔",,,29434
29435,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنِ الْمُجَالِدِ ، عَنِ الشَّعْبِیِّ ، عَنْ سُوَیْدِ بْنِ غَفَلَۃَ ؛ أَنَّ رَجُلاً مِنْ أَہْلِ الذِّمَّۃِ ، مِنْ نُبَیْطِ أَہْلِ الشَّامِ نَخَسَ بِامْرَأَۃٍ عَلَی دَابَّۃٍ ، فَلَمْ تَقَعْ ، فَدَفَعَہَا بِیَدِہِ فَصَرَعَہَا ، فَانْکَشَفَتْ عَنْہَا ثِیَابُہَا ، فَجَلَسَ لِیُجَامِعَہَا ، فَرُفِعَ إِلَی عُمَرَ بْنِ الْخَطَّابِ ، وَقَامَتْ عَلَیْہِ الْبَیِّنَۃُ ، فَأَمَرَ بِہِ فَصُلِبَ ، وَقَالَ : لَیْسَ عَلَی ہَذَا عَاہَدْنَاکُمْ۔",,,29435
29436,حَدَّثَنَا أَسْوَدُ بْنُ عَامِرٍ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ قَتَادَۃَ ؛ أَنَّ عَبْدَ الْمَلِکِ بْنَ مَرْوَانَ أُتِیَ بِرَجُلٍ مِنْ أَہْلِ الذِّمَّۃِ اسْتَکْرَہَ امْرَأَۃً مُسْلِمَۃً ، فَخَصَاہُ۔,,,29436
29437,"حَدَّثَنَا الْبَکْرَاوِیُّ ، عَنْ إِسْمَاعِیلَ بْنِ مُسْلِمٍ ، عَنِ الْحَسَنِ ، قَالَ : إِذَا اسْتَکْرَہَ الذِّمِّیُّ الْمُسْلِمَۃَ قُتِلَ۔",,,29437
29438,"حَدَّثَنَا إِسْمَاعِیلُ بْنُ إِبْرَاہِیمَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ مُحَمَّدِ بْنِ إِبْرَاہِیمَ ، عَنْ عَطَائِ بْنِ یَسَارٍ ؛ أَنَّ مَاعِزَ بْنَ مَالِکٍ أَتَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَأَقَرَّ عَلَی نَفْسِہِ بِالزِّنَی ، قَالَ : وَبِمَنْ ، قَالَ : بِفُلاَنَۃَ مَوْلاَۃِ ابْنِ فُلاَنٍ ، فَأَرْسَلَ إِلَیْہَا فَأَنْکَرَتْ ، فَخَلَّی سَبِیلَہَا ، وَأَخَذَہُ بِمَا أَقَرَّ عَلَی نَفْسِہِ ، وَلَمْ یُذْکَرْ أَنَّہُ جَلَدَہُ حَدَّ الْفِرْیَۃِ فِیہَا۔ (احمد 339)",,,29438
29439,"حَدَّثَنَا ابْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ قَالَ : زَنَیْت بِفُلاَنَۃٍ ، قَالَ : عَلَیْہِ لَہَا الْحَدُّ۔",,,29439
29440,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ صَالِحِ بْنِ مُسْلِمٍ ، عَنِ الشَّعْبِیِّ ؛ فِی رَجُلٍ قَالَ لاِمْرَأَۃٍ : أَشْہَدُ أَنِّی قَدْ زَنَیْتُ بِکِ ، قَالَ : أَضْرَبُہُ بِمَا افْتَرَی عَلَیْہَا ، وَلاَ أَضْرِبُہُ بِمَا افْتَرَی عَلَی نَفْسِہِ إِلاَّ بِبَیِّنَۃٍ۔",,,29440
29441,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، قَالَ : یُجْلَدُ حَدَّیْنِ ، قُلْتُ : فَإِنْ أَکْذَبَ ؟ قَالَ : یُجْلَدُ حَدًّا، وَیُدْرَأُ عَنْہُ آخَرُ۔",,,29441
29442,"حَدَّثَنَا یَحْیَی بْنُ یَعْلَی التَّیْمِیُّ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا قَالَتِ الْمَرْأَۃُ : زَنَی بِی فُلاَنٌ ، فلا تُجْلَدُ ، وَلاَ یُجْلَدُ۔",,,29442
29443,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَام ، عَنِ الْحَسَن ، قَالَ : إِذَا قَذَفَ الرَّجُلُ الرَّجُلَ بِالْمَرَأَۃِ ؛ جُلِدَ حَدَّینِ ؛ حَدّ لِلْرَجُلِ ، وَحَدّ لِلْمَرَأَۃ۔",,,29443
29444,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عُبَیْدَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إِذَا قَالَ الرَّجُلُ لِلْرَجُلِ : إِنَّ فُلاَنًا زَنَی بِفُلاَنَۃَ ، فَلَیْسَ عَلَیْہِ إِلاَّ حَدٌّ وَاحِدٌ۔",,,29444
29445,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : إِذَا قَذَفَ الرَّجُلُ امْرَأَتَہُ بِرَجُلٍ مُسَمًّی ، أُقِیمَ عَلَیْہِ الْحَدُّ۔ وَقَالَ ابْنُ سِیرِینَ : لاَ حَدَّ عَلَیْہِ ، کَانَ الَّذِی لاَعَنَ بِہِ النَّبیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَذَفَہَا بِابْنِ سَحْمَائَ۔",,,29445
29446,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ مُحَمَّدِ بْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : إِذَا قَذَفَ الرَّجُلُ امْرَأَتَہُ بِرَجُلٍ مُسَمًّی ، لَمْ یَکُنْ عَلَیْہِ لَہُمَا إِلاَّ حَدٌّ وَاحِدٌ ، قَالَ : أَیْہَُما أَخَذَہُ بِحَدِّہِ ؛ لَمْ یَکُنْ لِلآخَرِ حَدٌّ ۔ إِنْ بَدَأَتِ الْمَرْأَۃُ فَلاَعَنَتَہُ ، لَمْ یُضْرَبُ لِلْرَجُلِ ، وَإِنْ ضُرِبَ لِلْرَجُلِ لَمْ یَلاَعَنْ لِلْمَرَأَۃِ۔",,,29446
29447,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ فِی رَجُلٍ قَالَ لامْرَأَتِہِ : رَأَیْتُکِ تَزْنِینَ قَبْلَ أَنْ تَکُونِین عَندِی ، قَالَ سَعِیدٌ : حَدٌّ ، وَلاَ مُلاَعَنَۃَ۔ وَقَالَ الْحَسَنُ : لاَ حَدَّ ، وَلاَ مُلاَعَنۃَ ، لأَنَّہُ قَالَ لَہَا ذَلِکَ وَہِیَ عَندَہُ۔",,,29447
29448,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ فِی رَجُلٍ قَالَ لاِمْرَأَتِہِ : زَنَیْتِ وَأَنْتِ أَمَۃٌ ، قَالَ : یُحَدُّ۔",,,29448
29449,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ أَبِی عَوَانَۃَ ، عَنْ أَبِی بِشْرٍ ، عَنْ عَمْرِو بْنِ ہَرمٍ ، عَنْ جَابِرِ بْنِ زَیْدٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ فِی رَجُلٍ طَلَّقَ امْرَأَتَہُ وَاحِدَۃً ، ثُمَّ قَذَفَہَا ، قَالَ : یُجْلَدُ الْحَدَّ ، لَیْسَ کَمَنْ لَمْ یُطَلِّقْ\n\nوَقَالَ ابْنُ عُمَرَ : یُلاَعِنْ إِذَا کَانَ یَمْلِکُ الرَّجْعَۃَ۔",,,29449
29450,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : إِذَا طَلَّقَ الرَّجُلُ امْرَأَتَہُ ثَلاَثًا ، ثُمَّ قَذَفَہَا ، قَالَ : یُجْلَدُ الْحَدَّ ، إِلاَّ أَنْ تَکُونَ حَامِلاً ، فَإِنْ کَانَتْ حَامِلاً لاَعَنْہَا۔",,,29450
29451,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنِ الْحَکَمِ ؛ فِی رَجُلٍ طَلَّقَ امْرَأَتَہُ ثَلاَثًا وَہِیَ حُبْلَی ، ثُمَّ انْتَفَی مِمَّا فِی بَطْنِہَا ، قَالَ : یُجْلَدُ ، وَیُلْزَقُ بِہِ الْوَلَدُ۔",,,29451
29452,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا طَلَّقَ ثَلاَثًا ، ثُمَّ انْتَفَی مِنْ وَلَدِہِ وَہُوَ لاَ یَمْلِکُ الرَّجْعَۃَ، جُلِدَ ، وَأُلْزِقَ بِہِ الْوَلَدُ ، وَإِذَا انْتَفَی مِنْ وَلَدِہِ وَہُوَ یَمْلِکُ الرَّجْعَۃَ لاَعَنَ ، وَنُفِیَ عَنْہُ الْوَلَدَ ، وَإِنْ کَانَ لَمْ یُقِرَّ بِہِ قَطُّ۔",,,29452
29453,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ؛ فِی رَجُلٍ طَلَّقَ امْرَأَتَہُ طَلاَقًا بَائِنًا ،فَادَّعَتْ حَمْلاً فَانْتَفَی مِنْہُ ، قَالَ : یُلاَعِنُہَا۔",,,29453
29454,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنِ الشَّعْبِیِّ ؛ أَنَّہُ سُئِلَ عَنْ رَجُلٍ طَلَّقَ امْرَأَتَہُ ثَلاَثًا ، فَجَائَتْ بِحَمْلٍ ، فَانْتَفَی مِنْہُ ؟ قَالَ : فَقَالَ : یُلاَعِنْ ، قَالَ : فَقَالَ الْحَارِثُ : یَا أَبَا عَمْرو ، إِنَّ اللَّہَ قَالَ فِی کِتَابِہِ : (وَالَّذِینَ یَرْمُونَ أَزْوَاجَہُمْ) ، أَفَتَرَاہَا لَہُ زَوْجَۃً ؟ قَالَ : فَقَالَ الشَّعْبِیُّ : إِنِّی لأَسْتَحِی إِذَا رَأَیْتُ الْحَقَّ أَنْ لاَ أَرْجِع إِلَیْہِ۔",,,29454
29455,"حَدَّثَنَا عَبَّادٌ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الْحَکَمِ ، وَحَمَّادٍ ، عَنْ إِبْرَاہِیمَ ؛ فِی الرَّجُلِ یُطَلِّقُ امْرَأَتَہُ طَلاَقًا بَائِنًا ، ثُمَّ یَقْذِفُہَا ، قَالَ : یُضْرَبُ۔",,,29455
29456,"حَدَّثَنَا عُثْمَانُ بْنُ عُثْمَانَ الْقُرَشِیُّ ، عَنْ عُثْمَانَ البَتِّی ، قَالَ : کَانَ الْقَاسِمُ بْنُ مُحَمَّدٍ یَقُولُ فِی رَجُلٍ طَلَّقَ امْرَأَتَہُ ، ثُمَّ قَالَ لَہَا : زَنَیْتِ وَأَنْتِ امْرَأَتِی ، قَالَ : یُلاَعِنُ۔",,,29456
29457,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنِ الشَّعْبِیِّ ؛ فِی رَجُلٍ قَذَفَ ، ثُمَّ طَلَّقَ ثَلاَثًا ، قَالَ : یُلاَعِنُہَا مَا کَانَتْ فِی الْعِدَّۃِ۔",,,29457
29458,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا کَانَ یَمْلِکُ الرَّجْعَۃَ لاَعَنَ ، وَإِذَا کَانَ لاَ یَمْلِکُ الرَّجْعَۃَ جُلِدَ۔",,,29458
29459,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، قَالَ : سَمِعْتُ حَمَادًا ، یَقُولُ : لاَ حدَّ وَلاَ لِعَان۔",,,29459
29460,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ غَیْلاَنَ ، عَنِ الْحَکَمِ ، قَالَ : یُضْرَبُ۔",,,29460
29461,"حَدَّثَنَا عَبْدُ الأَعْلَی، عَنِ ابْنِ أَبِی عَرُوبَۃَ، عَنْ عَامِرٍ ، عَنْ مَکْحُولٍ؛ أَنَّہُ قَالَ : إِذَا قَذَفَ ثُمَّ طَلَّقَ ، لاَعَنَ۔",,,29461
29462,حَدَّثَنَا ابْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ فِی الرَّہْنِ ، لَمْ یَرَ عَلَیْہِ حَدًّا۔,,,29462
29463,"حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ مُطَرِّفٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : إِذَا رَہَنْتَ وَلِیدَتَکَ ، فَلاَ تَقَعْنَّ عَلَیْہَا حَتَّی تَفْتَکَّہَا۔",,,29463
29464,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ أَبِی بَکْرِ بْنِ أَبِی مَرْیَمَ ، عَنْ حَکِیمِ بْنِ عُمَیْرٍ ، قَالَ : کَتَبَ عُمَرُ بْنُ الْخَطَّابِ : أَلاَ لاَ یَجْلِدَنَّ أَمِیرُ جَیْشٍ ، وَلاَ سَرِیَّۃٍ أَحَدًا الْحَدَّ ، حَتَّی یَطْلُعَ الدَّرْبِ ، لِئَلاَّ تَحْمِلَہُ حَمِیَّۃُ الشَّیْطَانِ أَنْ یَلْحَقَ بِالْکُفَّارِ۔",,,29464
29465,حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ أَبِی بَکْرِ بْنِ عَبْدِ اللہِ بْنِ أَبِی مَرْیَمَ ، عنْ حُمَیْدِ بْنِ فُلاَنِ بْنِ رُومَانَ ؛ أَنَّ أَبَا الدَّرْدَائِ نَہَی أَنْ یُقَامَ عَلَی أَحَدٍ حَدٌّ فِی أَرْضِ الْعَدُوِّ۔,,,29465
29466,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَنْ عَلْقَمَۃَ ، قَالَ : غَزَوْنَا أَرْضَ الرُّومِ وَمَعَنا حُذَیْفَۃُ ، وَعَلَیْنَا رَجُلٌ مِنْ قُرَیْشٍ ، فَشَرِبَ الْخَمْرَ ، فَأَرَدْنَا أَنْ نَحُدَّہُ ، فَقَالَ حُذَیْفَۃُ : أَتَحُدُّونَ أَمِیرَکُمْ ، وَقَدْ دَنَوْتُمْ مِنْ عَدُوِّکُمْ ، فَیَطْمَعُونَ فِیکُمْ ؟ فَقَالَ : لأَشْرَبَنَّہَا ، وَإِنْ کَانَتْ مُحَرَّمَۃً ، وَلأَشْرَبَنَّہَا عَلَی رَغْمِ مَنْ رَغِمَ۔",,,29466
29467,"حَدَّثَنَا مُحَمَّدُ بْنُ سَوَائٍ ، عَنْ خَالِدٍ ، عَنْ جَابِرِ بْنِ زَیْدٍ ؛ فِیمَنْ أَتَی ذَاتَ مَحْرَمٍ مِنْہُ ، قَالَ : ضَرْبَۃُ عُنُقٍ۔",,,29467
29468,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ عَبَّادِ بْنِ مَنْصُورٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : اقْتُلُوا کُلَّ مَنْ أَتَی ذَاتَ مَحْرَمٍ۔",,,29468
29469,حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ أَشْعَثَ ، عَنْ عَدِیٍّ بْنِ ثَابِتٍ ، عَنِ الْبَرَائِ بْنِ عَازِبٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَعَثَ إِلَی رَجُلٍ تَزَوَّجَ امْرَأَۃَ أَبِیہِ ، فَأَمَرَہُ أَنْ یَأْتِیَہُ بِرَأْسِہِ۔ (ترمذی 1362۔ ابن ماجہ 2607),,,29469
29470,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، عَنِ السَّدِیِّ ، عَنْ عَدِیِّ بْنِ ثَابِتٍ ، عَنِ الْبَرَائِ ، قَالَ : لَقِیت خَالِی وَمَعَہُ الرَّایَۃُ ، فَقُلْتُ لَہُ ؟ فَقَالَ : بَعَثَنِی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إِلَی رَجُلٍ تَزَوَّجَ امْرَأَۃَ أَبِیہِ أَنْ أَقْتُلَہُ ، أَوْ أَضْرِبَ عُنُقَہُ۔ (ابوداؤد 4451۔ احمد 290)",,,29470
29471,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ حُمَیْدٍ ، عَنْ بَکْرٍ ، قَالَ : رُفِعَ إِلَی الْحَجَّاجِ رَجُلٌ زَنَی بِابْنَتِہِ ، فَقَالَ : مَا أَدْرِی بِأَیِّ قِتْلَۃٍ أَقْتُلُ ہَذَا ، وَہَمَّ أَنْ یَصْلُبَہُ ، فَقَالَ لَہُ عَبْدُ اللہِ بْنُ مُطَرِّفٍ ، وَأَبُو بُرْدَۃَ : سَتَرَ اللَّہُ ہَذِہِ الأُمَّۃَ ، أَحَبَّ البَلاَئِ مَا سَتَرَ الإِسْلاَمَ ، اقْتُلْہُ ، قَالَ : صَدَقْتُمَا ، فَأَمَرَ بِہِ فَقُتِلَ۔",,,29471
29472,"حَدَّثَنَا حَفْصٌ ، عَنْ عَمْرٍو ، قَالَ : سَأَلْتُہُ : مَا کَانَ الْحَسَنُ یَقُولُ فِیمَنْ تَزَوَّجَ ذَاتَ مَحْرَمٍ مِنْہُ ، وَہُوَ یَعْلَمُ ؟ قَالَ : عَلَیْہِ الْحَدُّ۔",,,29472
29473,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ حُمَیْدٍ الأَعْرَجِ ، عَنْ یَحْیَی بْنِ عَبْدِ اللہِ بْنِ صَیْفِیٍّ ؛ أَنَّ عُمَرَ کَتَبَ إِلَی أَبِی مُوسَی : أَلاَ یُبْلَغُ فِی تَعْزِیرٍ أَکْثَرُ مِنْ ثَلاَثِینَ۔",,,29473
29474,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ جَامِعٍ ، عَنْ أَبِی وَائِلٍ ؛ أَنَّ رَجُلاً کَتَبَ إِلَی أُمِّ سَلَمَۃَ فِی دَیْنٍ لَہُ قِبَلَہَا ، یحرّجُ عَلَیْہَا فِیہِ ، فَأَمَرَ عُمَرُ بْنُ الْخَطَّابِ أَنْ یُضْرَبَ ثَلاَثِینَ جَلْدَۃً۔ قَالَ بَعْضُ أَصْحَابِنَا : کُلُّہَا یُبْضِعُ وَیُحْدرُ۔",,,29474
29475,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، قَالَ : التَّعْزِیرُ مَا بَیْنَ السَّوْطِ إِلَی الأَرْبَعِینَ۔",,,29475
29476,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ صَدَقَۃَ بْنِ عَبْدِ اللہِ ، عَنِ الْحَارِثِ بْنِ عُتْبَۃَ ؛ أنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ أُتِیَ بِرَجُلٍ یَسُبُّ عُثْمَانَ ، فَقَالَ : مَا حَمَلَک عَلَی أَنْ سَبَبْتَہُ ؟ قَالَ : أُبْغِضُہُ ، قَالَ : وَإِنْ أَبْغَضْتَ رَجُلاً سَبَبْتَہُ ، قَالَ : فَأَمَرَ بِہِ فَجُلِدَ ثَلاَثِینَ جَلْدَۃً۔",,,29476
29477,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ طَلْحَۃَ بْنِ یَحْیَی ، قَالَ : کُنْتُ جَالِسًا عَندَ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، فَجَائَہُ رَجُلٌ ، فَسَأَلَہُ الْفَرِیضَۃَ ؟ فَلَمْ یَفْرِضْ لَہُ ، فَقَالَ : ہُوَ کَافِرٌ بِاللَّہِ إِنْ لَمْ یَفْرِضْ لَہُ ،قَالَ : فَضَرَبَہُ مَا بَیْنَ الْعَشَرَۃِ إِلَی الْخَمْسَۃِ عَشَرَ۔",,,29477
29478,"حَدَّثَنَا شَبَابَۃُ ، قَالَ : حدَّثَنَا لَیْثُ بْنُ سَعْدٍ ، عَنْ یَزِیدَ بْنِ أَبِی حَبِیبٍ ، عَنْ بُکَیْرِ بْنِ عَبْدِ اللہِ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ جَابِرٍ ، عَنْ أَبِی بُرْدَۃَ بْنِ نِیَارٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یُجْلَدُ فَوْقَ عَشَرَۃِ أَسْوَاطٍ ، إِلاَّ فِی حَدٍّ۔ (بخاری 6848۔ ابوداؤد 4485)",,,29478
29479,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ إِسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنْ عِمْرَانَ ، عَنِ الشَّعْبِیِّ ؛ أَنَّہُ سُئِلَ عَنْ أَرْبَعَۃٍ شَہِدُوا عَلَی رَجُلٍ أَنَّہُ لَیْسَ ابْنَ فُلاَنٍ ، وَشَہِدَ أَرْبَعَۃٌ أَنَّہُ ابْنُ فُلاَنٍ ؟ فَقَالَ : ادْرَأْ عَن ہَؤُلاَئِ لأَنَّہُمْ أَرْبَعَۃٌ ، وَأُصَدِّقَ الآخَرِینَ۔",,,29479
29480,"حَدَّثَنَا شَرِیکٌ ، عَنْ عَبْدِ الْکَرِیِمِ ، عَنْ عِکْرِمَۃَ ، قَالَ : قَالَ عُمَرُ لِعَبْدِ الرَّحْمَنِ بْنِ عَوْفٍ : أَرَأَیْتَ لَوْ کُنْتَ الْقَاضِیَ وَالْوَالِیَ ، ثُمَّ أَبْصَرْتَ إِنْسَانًا عَلَی حَدٍّ ، أَکُنْتَ مُقِیمًا عَلَیْہِ ؟ قَالَ : لاَ ، حَتَّی یَشْہَدَ مَعِی غَیْرِی ، قَالَ : أَصَبْتَ ، وَلَوْ قُلْتَ غَیْرَ ذَلِکَ لَمْ تُجِدْ۔",,,29480
29481,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، قَالَ : سَمِعْتُ حَمَّادًا ، یَقُولُ : سَمِعْنَا أَنَّ الْحَاکِمَ یُجَوِّزُ قَوْلَہُ فِیمَا اعْتُرِفَ عَندَہُ إِلاَّ الْحُدُودَ۔",,,29481
29482,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ، عَنْ أَشْعَثَ، عَنِ الْحَسَنِ؛ أَنَّہُ سُئِلَ عَنِ الْمَرْأَۃِ تَعَلَّقُ بِالرَّجُلِ فَتَقُولُ: فَعَلَ بِی؟ فَقَالَ الْحَسَنُ: قَذَفَتْ رَجُلاً مِنَ الْمُسْلِمِینَ، عَلَیْہَا الْحَدُّ۔ قَالَ: وَقَالَ إِبْرَاہِیمُ : ہِیَ طَالِبَۃُ حَقٍّ، کَیْفَ تَقُولُ؟",,,29482
29483,"حَدَّثَنَا عَبْد الرَّحیم ، عَنِ الأَشْعَثِ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ قَالَتْ لَہُ امْرَأَۃٌ : إِنَّ ہَذَا زَنَی بِی ، قَالَ : تُجْلَدُ بِقَذْفِہَا الرَّجُلَ ، وَلاَ یُجْلَدُ الرَّجُلُ۔",,,29483
29484,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ أَبِیہِ ، وَعَمِّہِ ، وَیَحْیَی بْنِ أَبِی الْہَیْثَمِ ، عَنْ جَدِّہِ ؛ أَنَّہُ شَہِدَ عَلِیًّا وَأُتِیَ بِرَجُلٍ وَامْرَأَۃٍ ، وُجِدَا فِی خَرِبِ مُرَادٍ ، فَأُتِیَ بِہِمَا عَلِیٌّ ، فَقَالَ : بِنْتُ عمِّی وَیَتِیمَتِی فِی حَجْرِی ، فَجَعَلَ أَصْحَابُہُ یَقُولُونَ : قُولِی زَوْجِی ، فَقَالَتْ : ہُوَ زَوْجِی ، فَقَالَ عَلِیٌّ : خُذْ بِیَدِ امْرَأَتِک۔",,,29484
29485,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، وَحَمَّادٍ ، قَالاَ : یُدْرَأُ عَنْہُ۔",,,29485
29486,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : یُدْرَأُ عَنْہُ۔",,,29486
29487,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ إِبْرَاہِیمَ ؛ فِی الْمَرْأَۃِ تُوجَدُ مَعَ الرَّجُلِ ، فَتَقُولُ : تَزَوَّجَنِی ، فَقَالَ إِبْرَاہِیمُ : لَوْ کَانَ ہَذَا حَقًّا مَا کَانَ عَلَی زَانٍ حَدٌّ۔",,,29487
29488,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، قَالَ : سَأَلْتُ الزُّہْرِیَّ عَنْ رَجُلٍ نَفَی رَجُلاً مِنْ أَبٍ لَہُ فِی الشِّرْکِ ؟ فَقَالَ : عَلَیْہِ الْحَدُّ ، لأَنَّہُ نَفَاہُ مِنْ نَسَبِہِ۔",,,29488
29489,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ؛ أَنَّ رَجُلاً مِنَ الْمُہَاجِرِینَ افْتُرِیَ عَلَیْہِ عَلَی عَہْدِ عُمَرَ بْنِ الْخَطَّابِ ، وَکَانَتْ أُمُّہُ مَاتَتْ فِی الْجَاہِلِیَّۃِ ، فَجَلَدَہُ عُمَرُ لِحُرْمَۃِ الْمُسْلِمِ۔,,,29489
29490,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ عَمِّہِ ، عَنِ الشَّعْبِیِّ ؛ أَنَّہُ سُئِلَ عَنْ رَجُلٍ قَذَفَ رَجُلاً ، وَأُمُّہُ مُشْرِکَۃٌ ؟ قَالَ : أَرَأَیْتَ لَوْ أَنَّ رَجُلاً قَذَفَ الأَشْعَثَ ، أَلَمْ یُضْرَبْ ؟۔",,,29490
29491,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ سَعِیدٍ الزُّبَیْدِیِّ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ؛ فِی الرَّجُلِ یَقُولُ لِلرَّجُلِ : لَسْتَ لأَبِیک ، وَأُمُّہُ أَمَۃٌ ، أَوْ یَہُودِیَّۃٌ ، أَوْ نَصْرَانِیَّۃٌ ، قَالَ : لاَ حَدَّ عَلَیْہِ۔",,,29491
29492,"حَدَّثَنَا ابْنُ أَبِی غَنِیۃَ ، عَنْ أَبِیہِ ، عَنِ الْحَکَمِ ، قَالَ : إِذَا قَذَفَ الرَّجُلُ الرَّجُلَ ، وَلَہُ أُمٌّ یَہُودِیَّۃٌ ، أَوْ نَصْرَانِیَّۃٌ ، فَلاَ حَدَّ عَلَیْہِ۔",,,29492
29493,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ حَمَّادٍ ؛ فِی الرَّجُلِ یَغِیبُ عَنِ امْرَأَتِہِ ، وَلَمْ یَدْخُلْ بِہَا ، فَتَجِیئُ بِحَمْلٍ ، أَوْ بِوَلَدٍ ، قَالَ : إِنْ کَانَتْ غَیْبَتُہُ بِأَرْضٍ بَعِیدَۃٍ لَمْ تُصَدَّقْ ، وَیُقَامُ عَلَیْہَا الْحَدُّ ، وَإِنْ کَانَ فِی أَرْضٍ قَرِیبَۃٍ یُرَوْنَ أَنَّہُ یَأْتِیہَا سِرًّا ، صُدِّقَتْ بِالْوَلَدِ أَنَّہُ مِنْ زَوْجِہَا۔",,,29493
29494,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، عَنِ الزُّہْرِیِّ ، قَالَ : لَوْ أَنَّ رَجُلاً قَذَفَ رَجُلاً ، فَعَفَا وَأَشْہَدَ ، ثُمَّ جَائَ بِہِ إِلَی الإِمَامِ بَعْدَ ذَلِکَ ، أَخَذَ لَہُ بِحَقِّہِ ، وَلَوْ مَکَثَ ثَلاَثِینَ سَنَۃً۔",,,29494
29495,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : سَأَلْتُ الْحَسَنَ ، وَابْنَ سِیرِینَ عَنِ الرَّجُلِ یَفْتَرِی عَلَی الرَّجُلِ فَیَعْفُو ؟ قَالَ الْحَسَنُ : لاَ ، وَقَالَ ابْنُ سِیرِینَ : مَا أَدْرِی۔",,,29495
29496,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ رُزَیْقٍ ، قَالَ : کَتَبْتُ إِلَی عُمَرَ بْنِ عَبْدِ الْعَزِیزِ فِی رَجُلٍ قَذَفَ ابْنَہُ : فَقَالَ ابْنَہُ : إِنْ جُلِدَ أَبِی اعْتَرَفْتُ ، فَکَتَبَ إِلَیَّ عُمَرُ : أَنِ اجْلِدْہُ ، إِلاَّ أَنْ یَعْفُوَ عَنْہُ۔",,,29496
29497,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ زَکَرِیَّا ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ؛ أَنَّہُ سُئِلَ عَنْ رَجُلٍ أَرَادُوا أَنْ یَقْطَعُوا یَدَہُ ، یَعْنِی الْیُمْنَی ، فَقَدَّمَ یَدَہُ الْیُسْرَی ، فَقُطِعَتْ ؟ قَالَ : لاَ تُقْطَعُ الْیُمْنَی۔",,,29497
29498,حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ؛ أَنَّ عَلِیًّا أَمْضَی ذَلِکَ۔,,,29498
29499,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ جَابِرٍ، عَنْ عَامِرٍ؛ فِی إِمَامٍ أُتِیَ بِسَارِقٍ، فَجَہلَ فَقُطِعَ یَسَارُہُ، قَالَ: یُتْرَکُ۔",,,29499
29500,"حَدَّثَنَا مُحَمَّدُ بْنُ مُیَسَّرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَمَّنْ حَدَّثَہُ ، عَنِ الْقَاسِمِ بْنِ مُحَمَّدٍ ، قَالَ : اجْتَمَعْتُ أَنَا وَسَعِیدُ بْنُ الْمُسَیَّبِ فِی الرَّجُلِ إِذَا أُمِرَ بِقَطْعِ یَمِینِہِ ، أَنَّہُ إِنْ دَسَّ إِلَی الْحَجَّامِ یَسَارَہُ فَقَطَعَہَا ، قَالاَ : یَدُہُ تُبطلُ ، وَالْقَوَدُ فِی مَوْضِعِہِ۔",,,29500
29501,"حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِیلَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ حَرْمَلَۃَ ، قَالَ : طَلَّقَ جَارٌ لِی سَکْرَانُ ، فَأَمَرَنِی أَنْ أَسْأَلَ سَعِیدَ بْنَ الْمُسَیَّبِ ، قَالَ : إِنْ أُصِیبَ فِیہِ الْحَقُّ جُلِدَ ثَمَانِینَ ، وَفُرِّقَ بَیْنَہُ وَبَیْنَ أَہْلِہِ۔",,,29501
29502,حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ لَیْثٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَنبَسَۃَ ؛ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ أَجَازَ طَلاَقَہُ ، وَجَلَدَہُ۔,,,29502
29503,"حَدَّثَنَا إِسْمَاعِیلُ بْنُ إِبْرَاہِیمَ ، عَن أَیُّوبَ ، عَنِ الْحَسَنِ ، وَابْنِ سِیرِینَ ؛ أَنَّہُمَا قَالاَ : طَلاَقُ السَّکْرَانِ جَائِزٌ ، وَیُجْلَدُ ظَہْرُہُ۔",,,29503
29504,"حَدَّثَنَا وَکِیعٌ ، عَنْ جَعْفَرٍ ، عَن مَیْمُونَ ، قَالَ : یَجُوزُ طَلاَقُہُ وَیُجْلَدُ۔",,,29504
29505,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیُّ ، عَنِ الزُّہْرِیِّ ، قَالَ: إِذَا أَعْتَقَ ، أَوْ طَلَّقَ السَّکْرَانُ جَازَ طَلاَقُہُ، وَأُقِیمَ عَلَیْہِ الْحَدُّ۔",,,29505
29506,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَمَّنْ سَمِعَ الشَّعْبِیَّ ، یَقُولُ : یَجُوزُ طَلاَقُہُ ، وَیُوجَعُ ظَہْرُہُ۔",,,29506
29507,"حَدَّثَنَا عُبَادَۃُ بْنُ الْعَوَّامِ ، عَنْ عُمَرَ بْنِ عَامِرٍ ، عَن حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّ عَلِیًّا وَعَبْدَ اللہِ اخْتَلَفَا فِی أُمِّ وَلَدٍ بَغَتْ ، فَقَالَ عَلِیٌّ : تُجْلَدُ ، وَلاَ نَفْیَ عَلَیْہَا ، وَقَالَ عَبْدُ اللہِ : تُجْلَدُ وَتُنْفَی۔",,,29507
29508,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ قَالَ : حدَّثَنَا إِسْرَائِیلُ ، عَن مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ؛ فِی أُمِّ الْوَلَدِ تَفْجُرُ ، قَالَ : یُقَامُ عَلَیْہَا حَدُّ الأَمَۃِ ، وَہِیَ عَلَی مَنْزِلَتِہَا۔",,,29508
29509,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، قَالَ : سَمِعْتُ حَمَّادًا ، یَقُولُ : لاَ تَجُوزُ شَہَادَۃٌ عَلَی شَہَادَۃٍ فِی حَدٍّ۔",,,29509
29510,"حَدَّثَنَا ابْنُ أَبِی زَائِدَۃَ ، عَنِ ابْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : لاَ تَجُوزُ شَہَادَۃٌ عَلَی شَہَادَۃٍ فِی قِصَاصٍ ، وَلاَ حَدٍّ۔",,,29510
29511,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ ہِشَامٍ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لاَ تَجُوزُ شَہَادَۃُ الرَّجُلِ عَلَی الرَّجُلِ فِی الْحُدُودِ۔",,,29511
29512,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَن حَسَنٍ ، عَنْ لَیْثٍ ، عَن طَاوُوسٍ ، وَعَطَائٍ ؛ قَالاَ : لاَ تَجُوزُ شَہَادَۃٌ عَلَی شَہَادَۃٍ فِی حَدٍّ۔",,,29512
29513,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، عَنْ شُرَیْحٍ ، وَمَسْرُوقٍ ؛ أَنَّہُمَا قَالاَ : لاَ تَجُوزُ شَہَادَۃٌ عَلَی شَہَادَۃٍ فِی حَدٍّ ، وَلاَ یُکْفَلاَنِ فِی حَدٍّ۔",,,29513
29514,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إِدْرِیسَ ، عَنْ مُطَرِّفٍ ، عَنْ عَامِرٍ ، قَالَ : إِذَا ہَرَبَ إِلَی الْحَرَمِ ، فَقَدْ أَمِنَ ، فَإِنْ أَصَابَہُ فِی الْحَرَمِ ، أُقِیمَ عَلَیْہِ الْحَدُّ فِی الْحَرَمِ۔",,,29514
29515,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ؛ أَنَّ الْوَلِیدَ أَرَادَ أَنْ یُقِیمَ عَلَی رَجُلٍ الْحَدَّ فِی الْحَرَمِ ، فَقَالَ لَہُ عُبَیْدُ بْنُ عُمَیْرٍ : لاَ تُقِمْہُ إِلاَّ أَنْ یَکُونَ أَصَابَہُ فِیہِ۔",,,29515
29516,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إِدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَعَطَائٍ ، قَالاَ : إِذَا أَصَابَ حَدًّا فِی غَیْرِ الْحَرَمِ ، ثُمَّ لَجَأَ إِلَی الْحَرَمِ ، أُخْرِجَ مِنَ الْحَرَمِ حَتَّی یُقَامَ عَلَیْہِ۔",,,29516
29517,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَن خُصَیْفٍ ، عَن مُجَاہِدٍ ، قَالَ : إِذَا أَصَابَ الرَّجُلُ الْحَدَّ فِی غَیْرِ الْحَرَمِ ، ثُمَّ أَتَی الْحَرَمَ ، أُخْرِجَ مِنَ الْحَرَمِ فَأُقِیمَ عَلَیْہِ الْحَدُّ ، وَإِذَا أَصَابَہُ فِی الْحَرَمِ أُقِیمَ عَلَیْہِ فِی الْحَرَمِ۔",,,29517
29518,"حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَن خُصَیْفٍ ، عَن مُجَاہِدٍ ؛ أَنَّ رَجُلاً قَتَلَ رَجُلاً ، ثُمَّ دَخَلَ الْحَرَمَ ، قَالَ : یُؤْخَذُ فَیُخْرَجُ بِہِ مِنَ الْحَرَمِ ، ثُمَّ یُقَامُ عَلَیْہِ الْحَدُّ ۔ یَقُولُ : الْقَتْلُ۔",,,29518
29519,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ عَطَائٍ ، عَنْ سَعِیدٍ (ح) وَعَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ فِی الرَّجُلِ یَقْتُلُ ، ثُمَّ یَدْخُلُ الْحَرَمَ ، قَالَ : لاَ یُبَایِعُہُ أَہْلُ مَکَّۃَ ، وَلاَ یَشْتَرُونَ مِنْہُ ، وَلاَ یَسْقُونَہُ ، وَلاَ یُطْعِمُونَہُ ، وَلاَ یُؤْوُونَہُ ، وَلاَ یُنْکِحُونَہُ حَتَّی یَخْرُجَ فَیُؤْخَذَ بِہِ۔ (ابن جریر 13)",,,29519
29520,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عُمَرَ ، وَابْنِ عَبَّاسٍ ، قَالاَ : لَوْ وَجَدْنَا قَاتِلَ آبَائِنَا فِی الْحَرَمِ لَمْ نَقْتُلْہُ۔",,,29520
29521,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ ، وَحَمَّادًا عَنِ الرَّجُلِ یَقْتُلُ ، ثُمَّ یَدْخُلُ الْحَرَمَ ؟ قَالَ حَمَّادٌ : یُخْرَجُ فَیُقَامُ عَلَیْہِ الْحَدُّ ، وَقَالَ الْحَکَمُ : لاَ یُبَایَعُ ، وَلاَ یُؤَاکَلُ۔",,,29521
29522,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنی أَبُو بَکْرِ بْنُ عَبْدِ اللہِ ، أَنَّ خَالِدَ بْنَ مَعْبَدٍ حَدَّثَہُ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، وَعُبَیْدِ اللہِ بْنِ عَبْدِ اللہِ بْنِ عُتْبَۃَ ؛ أَنَّہُمَا سُئِلاَ عَنِ السَّارِقِ یَسْرِقُ ، فَیَطْرَحُ سَرِقَتَہُ خَارِجًا مِنَ الْبَیْتِ ، وَیُوجَدُ فِی الْبَیْتِ الَّذِی سَرَقَ فِیہِ الْمَتَاعَ ، أَعَلَیْہِ الْقَطْعُ ؟ فَقَالاَ : عَلَیْہِ الْقَطْعُ۔",,,29522
29523,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنَی مَعْمَرٌ ، عَن خُصَیْفٍ ، قَالَ : فَقَدَ قَوْمٌ مَتَاعًا لَہُمْ مِنْ بَیْتِہِمْ ، فَرَأَوْا نَقْبًا فِی الْبَیْتِ ، فَخَرَجُوا یَنْظُرُونَ ، فَإِذَا رَجُلاَنِ یَسْعَیَانِ، فَأَدْرَکُوا أَحَدَہُمَا مَعَہُ مَتَاعُہُمْ، وَأَفْلَتَہُمَ الآخَرُ ، فَأَتَیَا بِہِ ، فَقَالَ : لَمْ أَسْرِقْ شَیْئًا ، وَإِنَّمَا اسْتَأْجَرَنِی ہَذَا الَّذِی أٌفْلِتَ، وَدَفَعَ إِلَیَّ ہَذَا الْمَتَاعَ لأَحْمِلَہُ لَہُ ، لاَ أَدْرِی مِنْ أَیْنَ جَائَ بِہِ ؟ قَالَ خُصَیْفٌ : فَکُتِبَ فِیہِ إِلَی عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، فَکَتَبَ : أَنْ یُنَکَّلَہُ وَیُخْلدَہُ السِّجْنَ ، وَلاَ یَقْطَعَہُ۔",,,29523
29524,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ إِسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنْ عَامِرٍ ؛ فِی رَجُلٍ أَخَذَ مِنْ رَجُلٍ ثَوْبًا ، فَقَالَ : سَرَقْتَہُ ؟ فَقَالَ : إِنَّمَا أَخَذْتُہُ بِحَقٍّ لِی عَلَیْہِ ، فَقَالَ الشَّعْبِیُّ : لاَ حَدَّ عَلَیْہِ۔",,,29524
29525,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قَالَ عَطَائٌ : إِنْ وُجِدَتْ سَرِقَۃً مَعَ رَجُلِ سَوْئٍ یُتَّہَمُ فَقَالَ : ابْتَعْتَہَا ، فَلَمْ یعیِّن مِمَّنِ ابْتَاعَہَا مِنْہُ ، أَوْ قَالَ : وَجَدْتُہَا ، لَمْ یُقْطَعْ ، وَلَمْ یُعَاقَبْ۔",,,29525
29526,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : کَتَبَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ بِکِتَابٍ قَرَأْتُہُ : إِذَا وُجِدَ الْمَتَاعُ مَعَ الرَّجُلِ الْمُتَّہم فَقَالَ : ابْتَعْتَہُ ، فَلَمْ ینفذہُ ، فَاشْدُدْہُ فِی السِّجْنِ وَثَاقًا ، وَلاَ تَحُلَّہُ بِکَلاَمِ أَحَدٍ حَتَّی یَأْتِیَ فِیہِ أَمْرُ اللہِ ، قَالَ : فَذَکَرْتُ ذَلِکَ لِعَطَائٍ ، فَأَنْکَرَہُ۔",,,29526
29527,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ ، قَالَ : سَمِعْتُ ابْنَ الزُّبَیْرِ ، یَقُولُ : مَنْ رَفَعَ السِّلاَحَ ، ثُمَّ وَضَعَہُ ، فَدَمُہُ ہَدَرٌ۔\n\nقَالَ : وَکَانَ طَاوُوسٌ یَرَی ذَلِکَ أَیْضًا۔",,,29527
29528,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی مَعْمَرٌ ، عَنِ ابْنِ شِہَابٍ ؛ أَنَّ رَجُلاً ضَرَبَ رَجُلاً بِالسَّیْفِ ، فَلَمْ یَقْطَعْ مَرْوَانُ بْنُ الْحَکَمِ یَدَہُ ، وَأَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ قَطَعَ یَدَ رَجُلٍ فِی ذَلِکَ بِکِتَابِ الْوَلِیدِ بْنِ عَبْدِ الْمَلِکِ۔ (عبدالرزاق 18686)",,,29528
29529,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنَی زِیَادٌ ؛ أَنَّ ابْنَ شِہَابٍ أَخْبَرَہُ ، قَالَ : ضَرَبَ صَفْوَانُ بْنُ الْمُعَطَّلِ حَسَّانَ بْنَ الْفُرَیْعَۃِ بِالسَّیْفِ فِی ہِجَائٍ ہَجَاہُ ، فَلَمْ یَقْطَعْ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَدَہُ۔ (عبدالرزاق 18686)",,,29529
29530,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَن عُبَیْدِ اللہِ ، عَن نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ رَفَعَ عَلَیْنَا السِّلاَحَ فَلَیْسَ مِنَّا۔ (بخاری 6874۔ مسلم 98)",,,29530
29531,"حَدَّثَنَا جَرِیرٌ ، عَنِ الْعَلاَئِ بْنِ الْمُسَیَّبِ ، عَن خَیْثَمَۃَ ، قَالَ : قَالَ عُمَرُ : لَیْسَ مِنَّا مَنْ شَہَرَ السِّلاَحَ عَلَیْنَا۔",,,29531
29532,حَدَّثَنَا جَرِیرٌ بن عَبْدِ الْحَمِیدِ ، أَوْ حُدَّثْتُ عَنْہُ ، عَن مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، بِنَحْوِہِ۔,,,29532
29533,"حَدَّثَنَا مُصْعَبُ بْنُ الْمِقْدَامِ ، عَن عِکْرِمَۃَ بْنِ عَمَّارٍ ، عَنْ إِیَاسِ بْنِ سَلَمَۃَ ، عَنْ أَبِیہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ سَلَّ عَلَیْنَا السَّیْفَ فَلَیْسَ مِنَّا۔ (مسلم 162۔ احمد 46)",,,29533
29534,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَن شَرِیکٍ ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنَ ، عَنْ أَبِیہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ رَفَعَ عَلَیْنَا السِّلاَحَ فَلَیْسَ مِنَّا۔ (بخاری 1280۔ مسلم 164)",,,29534
29535,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، سُلَیْمَانُ بْنُ حَیَّانَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی ظَبْیَانَ ، عَن أُسَامَۃَ ، قَالَ : بَعَثَنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی سَرِیَّۃٍ ، فَصَبَّحْنَا الْحُرَقَاتِ مِنْ جُہَیْنَۃَ ، فَأَدْرَکْت رَجُلاً ، فَقَالَ : لاَ إِلَہَ إِلاَّ اللَّہُ ، فَطَعَنتُہُ ، فَوَقَعَ فِی نَفْسِی مِنْ ذَلِکَ ، فَذَکَرْتُہُ لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : قَالَ لاَ إِلَہَ إِلاَّ اللَّہُ وَقَتَلْتَہُ ؟ قَالَ : قُلْتُ : یَا رَسُولَ اللہِ ، إِنَّمَا قَالَہَا فَرَقًا مِنَ السِّلاَحِ ، قَالَ : فَأَلاَّ شَقَقْتَ عَن قَلْبِہِ حَتَّی تَعْلَمَ قَالَہَا فَرَقًا ، أَمْ لاَ ؟ قَالَ : فَمَا زَالَ یُکَرِّرُہَا عَلَیَّ ، حَتَّی تَمَنَّیْت أَنِّی أَسْلَمْت یَوْمَئِذٍ۔ (بخاری 4269۔ مسلم 185)",,,29535
29536,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی ظَبْیَانَ ، عَن أُسَامَۃَ ، قَالَ : بَعَثْنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی سَرِیَّۃٍ ، فَذَکَرَ نَحْوَہُ۔ (مسلم 158۔ طبرانی 394)",,,29536
29537,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی سُفْیَانَ ، عَنْ جَابِرٍ (ح) وَعَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالا : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أُمِرْت أَنْ أُقَاتِلَ النَّاسَ حَتَّی یَقُولُوا : لاَ إِلَہَ إِلاَّ اللَّہُ ، فَإِذَا قَالُوہَا مَنَعُوا مِنِّی دِمَائَہُمْ وَأَمْوَالَہُمْ إِلاَّ بِحَقِّہَا ، وَحِسَابُہُمْ عَلَی اللہِ۔ (ابوداؤد 2633۔ ترمذی 2606)",,,29537
29538,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ أَبِی مَالِکٍ ، عَنْ أَبِیہِ ، قَالَ : سَمِعْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، یَقُولُ: مَنْ وَحَّدَ اللَّہَ ، وَکَفَرَ بِمَا یُعْبَدُ مِنْ دُونِہِ ، فَقَدْ حَرُمَ دَمُہُ ، وَحِسَابُہُ عَلَی اللہِ۔ (مسلم 37۔ احمد 772)",,,29538
29539,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أُمِرْت أَنْ أُقَاتِلَ النَّاسَ حَتَّی یَقُولُوا : لاَ إِلَہَ إِلاَّ اللَّہُ ، فَإِذَا قَالُوہَا عَصَمُوا مِنِّی دِمَائَہُمْ وَأَمْوَالَہُمْ إِلاَّ بِحَقِّہَا ، وَحِسَابُہُمْ عَلَی اللہِ ، ثُمَّ قَرَأَ : {فَذَکِّرْ إِنَّمَا أَنْتَ مُذَکِّرٌ لَسْت عَلَیْہِمْ بِمُصَیْطِرٍ}۔\n\n(مسلم 52۔ ترمذی 3341)",,,29539
29540,"حَدَّثَنَا عَبْدُ اللہِ بْنُ بَکْرٍ السَّہْمِیُّ ، عَن حَاتِمِ بْنِ أَبِی صَغِیرَۃَ ، عَنِ النُّعْمَانِ بْنِ سَالِمٍ ، أَنَّ عَمْرَو بْنَ أَوْسٍ أَخْبَرَہُ ، عَنْ أَبِیہِ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : أُمِرْت أَنْ أُقَاتِلَ النَّاسَ حَتَّی یَقُولُوا لاَ إِلَہَ إِلاَّ اللَّہُ۔",,,29540
29541,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ أَبَانَ بْنِ عَبْدِ اللہِ ، عَنْ إِبْرَاہِیمَ بْنِ جَرِیرٍ ، عَنْ جَرِیرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أُمِرْت أَنْ أُقَاتِلَ النَّاسَ حَتَّی یَقُولُوا لاَ إِلَہَ إِلاَّ اللَّہُ۔ (طبرانی 2392)",,,29541
29542,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ صَالِحٍ مَوْلَی التَّوْأَمَۃِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أُمِرْت أَنْ أُقَاتِلَ النَّاسَ حَتَّی یَقُولُوا لاَ إِلَہَ إِلاَّ اللَّہُ ، فَإِذَا قَالُوہَا حَرُمَتْ عَلَیَّ دِمَاؤُہُمْ وَأَمْوَالُہُمْ إِلاَّ بِحَقِّہَا ، وَحِسَابُہُمْ عَلَی اللہِ۔ (احمد 475)",,,29542
29543,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَن حَبِیبِ بْنِ أَبِی عَمْرَۃَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : خَرَجَ الْمِقْدَادُ بْنُ الأَسْوَدِ فِی سَرِیَّۃٍ ، فَمَرُّوا بِرَجُلٍ فِی غُنَیْمَۃٍ لَہُ ، فَأَرَادُوا قَتْلَہُ ، فَقَالَ : لاَ إِلَہَ إِلاَّ اللَّہُ ، فَقَالَ الْمِقْدَادُ : وَدَّ لَوْ فَرَّ بِأَہْلِہِ وَمَالِہِ ، قَالَ : فَلَمَّا قَدِمُوا ، ذَکَرُوا ذَلِکَ لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَنَزَلَتْ : {یَا أَیُّہَا الَّذِینَ آمَنُوا إِذَا ضَرَبْتُمْ فِی سَبِیلِ اللہِ فَتَبَیَّنُوا ، وَلاَ تَقُولُوا لِمَنْ أَلْقَی إِلَیْکُمُ السَّلاَمَ لَسْتَ مُؤْمِنًا تَبْتَغُونَ عَرَضَ الْحَیَاۃِ الدُّنْیَا} قَالَ : الْغَنِیمَۃُ ، {فَعَندَ اللہِ مَغَانِمُ کَثِیرَۃٌ کَذَلِکَ کُنْتُمْ مِنْ قَبْلُ} قَالَ: تَکْتُمُونَ إِیمَانَکُمْ مِنَ الْمُشْرِکِینَ ، {فَمَنَّ اللَّہُ عَلَیْکُمْ} فَأَظْہَرَ الإِسْلاَمَ ، {فَتَبَیَّنُوا} وَعِیدًا مِنَ اللہِ ، {إِنَّ اللَّہَ کَانَ بِمَا تَعْمَلُونَ خَبِیرًا}۔",,,29543
29544,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ إِسْرَائِیلَ ، عَن سِمَاکٍ ، عَن عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : مَرَّ رَجُلٌ مِنْ بَنِی سُلَیْمٍ عَلَی نَفَرٍ مِنْ أَصْحَابِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَمَعَہُ غَنَمٌ ، فَسَلَّمَ عَلَیْہِمْ ، فَقَالُوا : مَا سَلَّمَ عَلَیْکُمْ إِلاَّ لِیَتَعَوَّذَ مِنْکُمْ ، فَعَمَدُوا إِلَیْہِ فَقَتَلُوہُ ، وَأَخَذُوا غَنَمَہُ ، فَأَتَوْا بِہَا رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَأَنْزَلَ اللَّہُ : {یَا أَیُّہَا الَّذِینَ أَمَّنُوا إِذَا ضَرَبْتُمْ فِی سَبِیلِ اللہِ فَتَبَیَّنُوا وَلاَ تَقُولُوا لِمَنْ أَلْقَی إِلَیْکُمَ السَّلاَمَ لَسْت مُؤْمِنًا تَبْتَغُونَ عَرَضَ الْحَیَاۃِ الدُّنْیَا فَعَندَ اللہِ مَغَانِمُ کَثِیرَۃٌ} إِلَی آخِرِ الآیَۃِ۔",,,29544
29545,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إِسْرَائِیلُ ، عَن سِمَاکٍ ، عَن عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، بِمِثْلِہِ ، وَلَمْ یَذْکُرْ : فَأَتَوْا بِہَا النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,29545
29546,"حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ ، قَالَ : حدَّثَنَا لَیْثُ بْنُ سَعْدٍ ، عَنِ ابْنِ شِہَابٍ ، عَنْ عَطَائِ بْنِ یَزِیدَ اللَّیْثِیِّ ، عَن عُبَیْدِ اللہِ بْنِ عَدِیِّ بْنِ الْخِیَارِ ، عَنِ الْمِقْدَادِ ؛ أَنَّہُ أَخْبَرَہُ أَنَّہُ قَالَ : یَا رَسُولَ اللہِ ، أَرَأَیْتَ إِنْ لَقِیتُ رَجُلاً مِنَ الْکُفَّارِ ، فَقَاتَلَنِی فَضَرَبَ إِحْدَی یَدَیَّ بِالسَّیْفِ فَقَطَعَہَا ، ثُمَّ لاَذَ مَنِی بِشَجَرَۃٍ ، فَقَالَ : أَسْلَمْتُ لِلَّہِ ، أَقْتُلُہُ یَا رَسُولَ اللہِ ، بَعْدَ أَنْ قَالَہَا ؟ فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تَقْتُلْہُ ، فَقُلْتُ : یَا رَسُولَ اللہِ ، قَطَعَ یَدِی ، ثُمَّ قَالَ ذَلِکَ بَعْدَ أَنْ قَطَعَہَا ، فَأَقْتُلُہُ ؟ قَالَ : لاَ تَقْتُلْہُ ، وَإِنْ قَتَلْتَہُ فَإِنَّہُ بِمَنْزِلَتِکَ قَبْلَ أَنْ تَقْتُلَہُ ، وَأَنْتَ بِمَنْزِلَتِہِ قَبْلَ أَنْ یَقُولَ الْکَلِمَۃَ الَّتِی قَالَ۔ (مسندہ 486)",,,29546
29547,"حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ ، قَالَ : حدَّثَنَا سُلَیْمَانُ بْنُ الْمُغِیرَۃِ ، عنْ حُمَیْدِ بْنِ ہِلاَلٍ ، قَالَ : جَائَ أَبُو الْعَالِیَۃِ إِلَیَّ وَإِلَی صَاحِبٍ لِی ، فَقَالَ : ہَلُمَّا فَإِنَّکُمَا أَشَبُّ مِنِّی ، وأَوْعَی لِلْحَدِیثِ مِنِّی ، فَانْطَلَقْنَا حَتَّی أَتَیْنَا بِشْرَ بْنَ عَاصِمٍ اللَّیْثِیَّ ، فقال أَبُو الْعَالِیَۃِ : حَدِّثْ ہَذَیْنِ حَدِیثَکَ ، فَقَالَ : حَدَّثَنَا عٌُقْبَۃُ بْنُ مَالِکِ اللَّیْثِیُّ ، قَالَ : بَعَثَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سَرِیَّۃً ، فَأَغَارَتْ عَلَی الْقَوْمِ ، فَشَدَّ رَجُلٌ مِنَ الْقَوْمِ ، فَاتَّبَعَہُ رَجُلٌ مِنَ السَّرِیَّۃِ مَعَہُ سَیْفٌ شَاہِرٌ ، فَقَالَ الشَّادُّ مِنَ الْقَوْمِ : إِنِّی مُسْلِمٌ ، فَلَمْ یَنْظُرْ فِیمَا قَالَ ، فَضَرَبَہُ فَقَتَلَہُ ، فَنُمِّیَ الْحَدِیثُ إِلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَوْلاً شَدِیدًا ، فَبَلَغَ الْقَاتِلَ ، فَبَیْنَمَا النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَخْطُبُ ، إِذْ قَالَ الْقَاتِلُ : وَاللَّہِ یَا نَبِیَّ اللہِ ، مَا قَالَ الَّذِی قَالَ إِلاَّ تَعَوُّذًا مِنَ الْقَتْلِ ، فَأَعْرَضَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْہُ ، وَعَمَّنْ یَلِیہِ مِنَ النَّاسِ ، وَفَعَلَ ذَلِکَ مَرَّتَیْنِ ، کُلُّ ذَلِکَ یُعْرِضُ عَنْہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِوَجْہِہِ ، فَلَمْ یَصْبِرْ أَنْ قَالَ الثَّالِثَۃَ مِثْلَ ذَلِکَ ، وَأَقْبَلَ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِوَجْہِہِ ، تُعْرَفُ الْمَسَائَۃُ فِی وَجْہِہِ ، فَقَالَ : إِنَّ اللَّہَ أَبَی عَلَیَّ فِیمَنْ قَتَلَ مُؤْمِنًا ، ثَلاَثَ مَرَّاتٍ یَقُولُ ذَلِکَ۔ (ابوداؤد 2620۔ احمد 288)",,,29547
29548,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا سُفْیَانُ بْنُ حُسَیْنٍ ، عَنِ الزُّہْرِیِّ ، عَن عُبَیْدِ اللہِ بْنِ عَبْدِ اللہِ بْنِ عُتْبَۃَ ، قَالَ : لَمَّا ارْتَدَّ مَنِ ارْتَدَّ عَلَی عَہْدِ أَبِی بَکْرٍ ، أَرَادَ أَبُو بَکْرٍ أَنْ یُجَاہِدَہُمْ ، فَقَالَ عُمَرُ : أَتُقَاتِلُہُمْ وَقَدْ سَمِعْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، یَقُولُ : مَنْ شَہِدَ أَنْ لاَ إِلَہَ إِلاَّ اللَّہُ وَأَنَّ مُحَمَّدًا رَسُولُ اللہِ ، حَرُمَ مَالُہُ إِلاَّ بِحَقٍّ ، وَحِسَابُہُمْ عَلَی اللہِ تَعَالَی ؟ فَقَالَ أَبُو بَکْرٍ : أَنَّی لاَ أَقَاتِلُ مَنْ فَرَّقَ بَیْنَ الصَّلاَۃِ وَالزَّکَاۃِ، وَاللَّہِ لأَقَاتِلَنَّ مَنْ فَرَّقَ بَیْنَہُمَا حَتَّی أَجْمَعَہُمَا ، قَالَ عُمَرُ : فَقَاتَلْنَا مَعَہُ فَکَانَ رَشْدًا ، فَلَمَّا ظَفِرَ بِمَنْ ظَفِرَ بِہِ مِنْہُمْ ، قَالَ : اخْتَارُوا مِنِّی خَصْلَتَیْنِ ؛ إِمَّا حَرْبٌ مُجْلِیَۃٌ ، وَإِمَّا الْخِطَّۃُ الْمُخْزِیَۃُ ۔ قَالُوا : ہَذِہِ الْحَرْبُ الْمُجْلِیَۃُ قَدْ عَرَفْنَاہَا ، فَمَا الْخِطَّۃُ الْمُخْزِیَۃُ ؟ قَالَ : تَشْہَدُونَ عَلَی قَتْلاَنَا أَنَّہُمْ فِی الْجَنَّۃِ ، وَعَلَی قَتْلاَکُمْ أَنَّہُمْ فِی النَّارِ ، فَفَعَلُوا۔ (بخاری 1399۔ مسلم 32)",,,29548
29549,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، قَالَ : حدَّثَنَا أَبَانُ بْنُ عَبْدِ اللہِ الْبَجَلِیُّ ، قَالَ : حَدَّثَنِی إِبْرَاہِیمُ بْنُ جَرِیرٍ ، عَنْ جَرِیرٍ، قَالَ: إِنَّ نَبِیَّ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَعَثَنِی إِلَی الْیَمَنِ أُقَاتِلُہُمْ وَأَدْعُوہُمْ ، فَإِذَا قَالُوا لاَ إِلَہَ إِلاَّ اللَّہُ، حَرُمَتْ عَلَیْکُمْ أَمْوَالُہُمْ وَدِمَاؤُہُمْ۔",,,29549
29550,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الرَّحْمَنِ بْنُ أَبِی ذِئْبٍ ، عَن خَالِہِ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : ضُرِبَ ابْنٌ لَہُ فِی الشَّرَابِ وَطِیفَ بِہِ ، فَقَالَ : مَا أَجِدُ عَلَیْہِ فِی ضَرْبِہِ إِیَّاہُ ، وَلَکِنِّی أَجِدُ عَلَیْہِ أَنَّہُ طَافَ بِہِ ، وَہُوَ شَیْئٌ لَمْ یَفْعَلْہُ الْمُسْلِمُونَ۔",,,29550
29551,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ إِسْمَاعِیلَ بْنِ سُمَیْعٍ ، قَالَ : سَمِعْتُ مَالِکَ بْنَ عُمَیْرٍ ، یَقُولُ : سَمِعْت عَتَّابَ بْنَ سَلَمَۃَ ، یَقُولُ : سَأَلَنِی عُمَرُ بْنُ الْخَطَّابِ عَنْ رَجُلٍ قَالَ : رَأَیْتہُ یَشْرَبُہَا ؟ فَقُلْتُ : لَمْ أَرَہُ یَشْرَبُہَا ، وَلَکِنْ رَأَیْتہ یَقِیؤُہَا ، قَالَ : فَضَرَبَہُ الْحَدَّ ، وَنَصَبَہُ لِلنَّاسِ۔",,,29551
29552,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ؛ فِی الرَّجُلِ یَقُولُ لِلرَّجُلِ : زَنَیْتَ وَأَنْتَ مُشْرِکٌ ، قَالَ : لاَ یُحَدُّ۔",,,29552
29553,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ؛ أَنَّہُ قَالَ : إِذَا قَالَ : زَنَیْتَ وَأَنْتَ مُشْرِکٌ ، یُقَامُ عَلَیْہِ الْحَدُّ۔",,,29553
29554,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ؛ فِی الْکَافِرِ یَزْنِی ، فَیُقَامُ عَلَیْہِ الْحَدَّ ثُمَّ یُسْلِمْ ، فَیَقْذِفُہُ رَجُلٌ ، وَیَقُولُ : إِنَّمَا عَنیْتُ زِنَاہُ الَّذِی کَانَ فِی کُفْرِہِ ؟ قَالَ : یُقَامُ عَلَی قَاذِفِہِ الْحَدُّ۔",,,29554
29555,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنِ ابْنِ أَبِی ذِئْبٍ ، قَالَ : سَأَلْتُ الزُّہْرِیَّ عَنِ امْرَأَۃٍ زَنَتْ وَہِیَ یَہُودِیَّۃٌ ، أَوْ نَصْرَانِیَّۃٌ، أَوْ مَجُوسِیَّۃٌ، ثُمَّ أَسْلَمَتْ، فَقَذَفَہَا رَجُلٌ؟ فَقَالَ ابْنُ شِہَابٍ: لَیْسَ عَلَی مَنْ قَذَفَہَا حَدٌّ، وَلَکِنْ یُنَکَّلُ۔",,,29555
29556,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ؛ فِی الرَّجُلِ یَنْفِی الرَّجُلَ مِنْ فَخْذِہِ ، قَالَ : لاَ یُضْرَبُ ، إِلاَّ أَنْ یَنْفِیَہُ مِنْ أَبِیہِ۔",,,29556
29557,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ رَجُلٍ، عَنِ الْحَکَمِ ، قَالَ: إِذَا قَالَ : لَسْتَ مِنْ بَنِی تَمِیمٍ ، قَالَ : یُضْرَبُ۔",,,29557
29558,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَبْدِ الْمَلِکِ ، قَالَ : سَمِعْتُ الشَّعْبِیَّ ، قَالَ فِی رَجُلٍ یَقُولُ لِلرَّجُلِ : یَا زَانٍ ، وَہُوَ یَعْلَمُ أَنَّہُ قَدْ زَنَی ، أَیُحَدُّ ؟ قَالَ : نَعَمْ ، إِنَّ اللَّہَ یَقُولُ : {ثُمَّ لَمْ یَأْتُوا بِأَرْبَعَۃِ شُہَدَائَ}۔",,,29558
29559,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی حَصِینٍ ؛ أَنَّ رَجُلاً قَالَ لِرَجُلٍ : یَا روسبیہ ، فَضَرَبَہُ عُرْوَۃُ بْنُ الْمُغِیرَۃِ الْحَدَّ ، فَأَعْجَبَ ذَلِکَ الشَّعْبِیَّ۔",,,29559
29560,"حَدَّثَنَا یَحْیَی بْنُ یَعْلَی بْنُ الْحَارِثِ ، قَالَ : حدَّثَنَا أَبِی ، عَنْ غَیْلاَنَ بْنِ جَامِعٍ ، عَنْ أَشْعَثَ بْنَ سُلَیْمَانَ ، قَالَ : جِیئَ بِرَجُلٍ إِلَی الْقَاسِمِ بْنِ عَبْدِ الرَّحْمَنِ وَہُوَ قَاضٍ ، قَالَ : فَشُہِدَ عَلَیْہِ أَنَّہُ قَالَ لِرَجُلٍ : یَا روسبیہ ، فَجَلَدَہُ الْحَدَّ۔",,,29560
29561,"حَدَّثَنَا وَکِیعٌ، عَنْ صَالِحِ بْنِ مَعْبَدٍ، عَنِ الشَّعْبِیِّ؛ فِی الرَّجُلِ یَقُولُ لِلرَّجُلِ: یَا مَعْفُوج، قَالَ: عَلَیْہِ الْحَدُّ۔",,,29561
29562,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ یَحْیَی بْنِ الْوَلِیدِ ، قَالَ : شَہِدْتُ ابْنَ أَشْوَعَ أُتِیَ بِرَجُلٍ قَالَ لِرَجُلٍ : یَا مَفْعُولُ ، فَجَلَدَہُ الْحَدَّ۔",,,29562
29563,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ عُبَیْدَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : یُجْلَدُ۔",,,29563
29564,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی ہِلاَلٍ ، عَنِ الْحَسَنِ ، وَعِکْرِمَۃَ ؛ فِی الرَّجُلِ یَقُولُ لِلرَّجُلِ : یَا مُخَنَّثُ ، قَالَ عِکْرِمَۃُ : عَلَیْہِ الْحَدُّ ۔ وَقَالَ الْحَسَنُ : لَیْسَ عَلَیْہِ الْحَدُّ۔",,,29564
29565,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ أَبِی ہِلاَلٍ ، عَنِ الْحَسَنِ ، قَالَ : لَیْسَ عَلَیْہِ حَدٌّ۔",,,29565
29566,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : إِذَا قَالَ : یَا مُخَنَّثُ فَلَیْسَ عَلَیْہِ حَدٌّ۔",,,29566
29567,"حَدَّثَنَا شَرِیکٌ ، عَنْ عَبْدِ الْمَلِکِ بْنِ عُمَیْرٍ ، قَالَ : قَالَ عَلِیٌّ : قَوْلُ الرَّجُلِ لِلرَّجُلِ : یَا خَبِیثُ ، یَا فَاسِقُ ، قَالَ : ہُنَّ فَوَاحِشُ ، وَفِیہِنَّ عُقُوبَۃٌ ، وَلاَ تَقُولُہُنَّ فَتَعَوَّدَہُنَّ۔",,,29567
29568,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ أَنَّ أَبَا بَکْرٍ قَالَ فِی الرَّجُلِ یَقُولُ لِلرَّجُلِ : یَا خَبِیثُ ، یَا فَاسِقُ ، قَالَ : قَدْ قَالَ قَوْلاً سَیِّئًا ، وَلَیْسَ فِیہِ عُقُوبَۃٌ ، وَلاَ حَدٌّ۔",,,29568
29569,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ إِسْحَاقَ ، قَالَ : شَہِدْتُ سَالِمًا ، وَالْقَاسِمَ وَسَأَلَہُمَا أَمِیرُ الْمَدِینَۃِ عَنْ رَجُلٍ قَالَ لِرَجُلٍ یَا فَاسِقُ ؟ فَقَرَآ ہَذِہِ الآیَۃَ : {إِنْ جَائَکُمْ فَاسِقٌ بِنَبَأٍ فَتَبَیَّنُوا}، وَقَالاَ : الْفَاسِقُ : الْکَذَّابُ ، یُعَزَّرُ أَسْوَاطًا۔",,,29569
29570,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ أَشْعَثَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ ؛ فِی الرَّجُلِ یَقُولُ لِلرَّجُلِ : یَا خَبِیثُ ، قَالَ : ہُوَ قَوْلُ سَیْئٍ ، وَلَیْسَ فِیہِ عُقُوبَۃٌ۔",,,29570
29571,"حَدَّثَنَا حَفْصٌ ، عَنْ إِسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ ، قَالَ : لَوْ أَنَّ رَجُلاً قَالَ لِرَجُلٍ : ادَّعَاک عَشَرَۃٌ ، لَمْ یَکُنْ عَلَیْہِ حَدٌّ۔",,,29571
29572,"حَدَّثَنَا جَرِیرٌ ، عَنْ رَقبۃَ ، عَنْ حَمَّادٍ ؛ فِی الرَّجُلِ یَقُولُ لِلرَّجُلِ : أَنْتَ دَعِیٌّ ، لَیْسَ عَلَیْہِ حَدٌّ۔",,,29572
29573,"حَدَّثَنَا أَبُو عِصَامٍ ، عَنِ الأَوْزَاعِیِّ ، عَنِ الزُّہْرِیِّ ؛ فِی الرَّجُلِ یَقُولُ لِلرَّجُلِ مِنَ الْعَرَبِ : إِنَّک لَمَوْلًی ، قَالَ : یُضْرَبُ الْحَدَّ۔",,,29573
29574,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ سُفْیَانَ بْنِ حُسَیْنٍ ، عَنِ الْحَسَنِ ، قَالَ : إِذَا زَنَی الرَّجُلُ بِالصَّبِیَّۃِ جُلِدَ وَلَمْ یُرْجَمْ ، وَلَیْسَ عَلَی الصَّبِیَّۃِ شَیْئٌ ، وَإِذَا زَنَی غُلاَمٌ بِامْرَأَۃٍ جُلِدَتْ وَلَمْ تُرْجَمْ ، وَعَلَی الْغُلاَمِ تَعْزِیرٌ۔",,,29574
29575,"حَدَّثَنَا جَرِیرٌ ، عَنِ الْمُغِیرَۃِ ، عَنْ إِبْرَاہِیمَ ؛ فِی رَجُلٍ افْتَضَّ صَبِیَّۃً ، قَالَ : عَلَیْہِ عُقْرُہَا۔",,,29575
29576,"حَدَّثَنَا عَمْرُ بْنُ عَلِیِّ بْنِ عَطَائِ بْنِ مُقَدَّمٍ ، عَنْ حَجَّاجٍ ، عَنْ مَکْحُولٍ ، عَنِ ابْنِ مُحَیْرِیزٍ ، عَنْ فَضَالَۃَ بْنِ عُبَیْدٍ ، قَالَ : سَأَلْتُہُ عَن تَعْلِیقِ الْیَدِ فِی الَعُنُقِ ؟ فَقَالَ : السُّنَّۃُ ، قَطَعَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَدَ رَجُلٍ ، ثُمَّ عَلَّقَہَا فِی عُنُقِہِ۔ (ابوداؤد 4411۔ ترمذی 1447)",,,29576
29577,حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنِ الأَعْمَشِ ، عَنِ الْقَاسِمِ ، عَنْ أَبِیہِ ؛ أَنَّ عَلِیًّا قَطَعَ یَدَ سَارِقٍ فَرَأَیْتہَا مُعَلَّقَۃً ، یَعْنِی فِی عُنُقِہِ۔,,,29577
29578,حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ الأَعْمَشِ ، عَنِ الْقَاسِمِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِیہِ ؛ أَنَّ عَلِیًّا قَطَعَ یَدَ رَجُلٍ ، ثُمَّ عَلَّقَہَا فِی عُنُقِہِ۔,,,29578
29579,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، قَالَ : أَخْبَرَنَا أَشْعَثُ ، عَنِ الْحَسَنِ ؛ أَنَّہُ قَالَ : یُقْتَلُ السُّحَّارُ ، وَلاَ یُسْتَتَابُون۔",,,29579
29580,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ حَارِثَۃَ بْنِ مُضَرِّبٍ؛ أَنَّ جُنْدَبًا قَتَلَ سَاحِرًا، أَوْ أَرَادَ أَنْ یَقْتُلَہُ۔,,,29580
29581,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ سَالِمٍ ، عَنْ قَیْسِ بْنِ عُبَادٍ ؛ أنَّہُ قَتَلَ سَاحِرًا۔,,,29581
29582,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ ہَمَّامِ بْنِ یَحْیَی ؛ أَنَّ عَامِلَ عُمَانَ کَتَبَ إِلَی عُمَرَ بْنِ عَبْدِ الْعَزِیزِ فِی سَاحِرَۃٍ أَخَذَہَا ، فَکَتَبَ إِلَیْہِ عُمَرُ : إِنَ اعْتَرَفَتْ ، أَوْ قَامَتْ عَلَیْہَا الْبَیِّنَۃُ ، فَاقْتُلْہَا۔",,,29582
29583,حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ عُبَیْدِ اللہِ ، عَن نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ جَارِیَۃً لِحَفْصَۃَ سَحَرَتْہَا ، وَوَجَدُوا سِحْرَہَا ، وَاعْتَرَفَتْ ، فَأَمَرَت عَبْدَ الرَّحْمَنِ بْنُ زَیْدٍ فَقَتَلَہَا ، فَبَلَغَ ذَلِکَ عُثْمَانَ فَأَنْکَرَہُ ، وَاشْتَدَّ عَلَیْہِ ، فَأَتَاہُ ابْنُ عُمَرَ فَأَخْبَرَہُ أَنَّہَا سَحَرَتْہَا ، وَوَجَدُوا سِحْرَہَا ، وَاعْتَرَفَتْ بِہِ ، فَکَأَنَّ عُثْمَانُ إِنَّمَا أَنْکَرَ ذَلِکَ لأَنَّہَا قُتِلَتْ بِغَیْرِ إِذْنِہِ۔,,,29583
29584,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ زَیْدٍ أَبِی الْمُعَلَّی ، قَالَ : حدَّثَنِی شُرْطِیٌّ لِسِنَانِ بْنِ سَلَمَۃَ ؛ أَنَّ سِنَانًا أُتِیَ بِسَاحِرَۃٍ ، فَأَمَرَ بِہَا أَنْ تُلْقَی فِی الْبَحْرِ۔",,,29584
29585,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ؛ سَمِعَ بَجَالَۃ ، یَقُولُ : کُنْتُ کَاتِبًا لِجَزْئِ بْنِ مُعَاوِیَۃَ ، فَأَتَانَا کِتَابُ عُمَرَ بْنِ الْخَطَّابِ : أَنَ اقْتُلُوا کُلَّ سَاحِرٍ وَسَاحِرَۃٍ ، قَالَ : فَقَتَلْنَا ثَلاَثَ سَوَاحِرَ۔",,,29585
29586,حَدَّثَنَا الثَّقَفِیُّ، عَنِ الْمُثَنَّی، عَنْ عَمْرِو بْنِ شُعَیْبٍ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ؛ فِی السَّاحِرِ إِذَا اعْتَرَفَ قُتِلَ۔,,,29586
29587,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ؛ فِی السَّاحِرِ ، قَالَ : یُقْتَلُ۔",,,29587
29588,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِیہِ ، قَالَ : لَمَّا قَدِمَ عَلَی عُمَرَ فَتْحُ تَسْتُرَ ، وَتَسْتُرُ مِنْ أَرْضِ الْبَصْرَۃِ ، سَأَلَہُمْ : ہَلْ مِنْ مُغْرِبَۃٍ ؟ قَالُوا : رَجُلٌ مِنَ الْمُسْلِمِینَ لَحِقَ بِالْمُشْرِکِینَ فَأَخَذْنَاہُ، قَالَ : فَمَا صَنَعْتُمْ بِہِ ؟ قَالُوا : قَتَلْنَاہُ ، قَالَ : أَفَلاَ أَدْخَلْتُمُوہُ بَیْتًا ، وَأَغْلَقْتُمْ عَلَیْہِ بَابًا ، وَأَطْعَمْتُمُوہُ کُلَّ یَوْمٍ رَغِیفًا ، ثُمَّ اسْتَتَبْتُمُوہُ ثَلاَثًا ، فَإِنْ تَابَ ، وَإِلاَّ قَتَلْتُمُوہُ ، ثُمَّ قَالَ : اللَّہُمَّ لَمْ أَشْہَدْ ، وَلَمْ آمُرْ ، وَلَمْ أَرْضَ إِذْ بَلَغَنِی ، أَوْ قَالَ : حِینَ بَلَغَنِی۔",,,29588
29589,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ، عَنْ أَشْعَثَ، عَنِ الشَّعْبِیِّ، قَالَ: قَالَ عَلِیٌّ: یُسْتَتَابُ الْمُرْتَدُّ ثَلاَثًا، فَإِنْ عَادَ قُتِلَ۔",,,29589
29590,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ، عَنِ ابْنِ جَرِیرٍ، عَنْ سُلَیْمَانَ بْنِ مُوسَی، عَنْ عُثْمَانَ، قَالَ: یُسْتَتَابُ الْمُرْتَدُّ ثَلاَثًا۔",,,29590
29591,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَمَّنْ سَمِعَ ابْنَ عُمَرَ ، یَقُولُ : یُسْتَتَابُ الْمُرْتَدُّ ثَلاَثًا ، فَإِنْ تَابَ تُرِکَ ، وَإِنْ أَبَی قُتِلَ۔",,,29591
29592,حَدَّثَنَا ہُشَیْمٌ ، عَنِ الْمُغِیرَۃِ ، عَنْ إِبْرَاہِیمَ ؛ فِی الْمُرْتَدُّ یُسْتَتَابُ ، فَإِنْ تَابَ تُرِکَ ، وَإِنْ أَبَی قُتِلَ۔,,,29592
29593,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عنْ حُمَیْدِ بْنِ ہِلاَلٍ ؛ أَنَّ مُعَاذَ بْنَ جَبَلٍ أَتَی أَبَا مُوسَی وَعَندَہُ رَجُلٌ یَہُودِیٌّ ، فَقَالَ : مَا ہَذَا ؟ فَقَالَ : ہَذَا یَہُودِیٌّ أَسْلَمَ ، ثُمَّ ارْتَدَّ وَقَدِ اسْتَتَابَہُ أَبُو مُوسَی شَہْرَیْنِ ، قَالَ : فَقَالَ مُعَاذٌ : لاَ أَجْلِسُ حَتَّی أَضْرِبُ عُنُقَہُ ، قَضَائُ اللہِ وَقَضَائُ رَسُولِہِ۔ (بخاری 6923۔ مسلم 1456)",,,29593
29594,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ حَیَّانَ ، عَنِ ابْنِ شِہَابٍ ، قَالَ : یُدْعَی إِلَی الإِسْلاَمِ ثَلاَثَ مَرَّاتٍ ، فَإِنْ أَبَی ضُرِبَتْ عُنُقُہُ۔",,,29594
29595,"حَدَّثَنَا ابْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قَالَ عَطَائٌ فِی الإِنْسَانِ یَکْفُرُ بَعْدَ إِسْلاَمِہِ : یُدْعَی إِلَی الإِسْلاَمِ ، فَإِنْ أَبَی قُتِلَ۔",,,29595
29596,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی عَمْرُو بْنُ دِینَارٍ ؛ فِی الرَّجُلِ یَکْفُرُ بَعْدَ إِیمَانِہِ ، قَالَ : سَمِعْتُ عُبَیْدَ بْنَ عُمَیْرٍ ، یَقُولُ : یُقْتَلُ۔",,,29596
29597,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ أَیُّوبَ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ بَدَّلَ دِینَہُ فَاقْتُلُوہُ۔ (بخاری 6922۔ ابوداؤد 4351)",,,29597
29598,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ قَتَادَۃَ ، عَنْ خِلاَسٍ ، عن علی ؛ فِی الْمُرْتَدَّۃِ تُسْتَأْمَی ، وَقَالَ : تُقْتَلُ۔",,,29598
29599,"حَدَّثَنَا عَبْدُالرَّحِیمِ بْنُ سُلَیْمَانَ ، وَوَکِیعٌ ، عَنْ أَبِی حَنِیفَۃَ ، عَنْ عَاصِمٍ ، عَنْ أَبِی رَزِینٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: لاَ یُقْتَلْنَ النِّسَائُ إِذَا ہُنَّ ارْتَدَدْنَ عَنِ الإِسْلاَمِ ، وَلَکِنْ یُحْبَسْنَ وَیُدْعَیْنَ إِلَی الإِسْلاَمِ ، وَیُجْبَرْنَ عَلَیْہِ۔",,,29599
29600,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ؛ فِی الْمُرْتَدَّۃِ ، قَالَ : لاَ تُقْتَلُ۔",,,29600
29601,"حَدَّثَنَا حَفْصٌ ، عَنْ عمرو ، عَنِ الْحَسَنِ ، قَالَ : لاَ تُقْتَلُ۔",,,29601
29602,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : لاَ تَقْتُلُوا النِّسَائَ إِذَا ہُنَّ ارْتَدَدْنَ عَنِ الإِسْلاَمِ ، وَلَکِنْ یُدْعَیْنَ إِلَی الإِسْلاَمِ ، فَإِنْ ہُنَّ أَبَیْنَ سُبِینَ ، فَیُجْعَلْنَ إِمَائَ الْمُسْلِمِینَ ، وَلاَ یُقْتَلْنَ۔",,,29602
29603,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ أَبِی حَرَّۃَ ، عَنِ الْحَسَنِ ؛ فِی الْمَرْأَۃِ تَرْتَدُّ عَنِ الإِسْلاَمِ ، قَالَ : لاَ تُقْتَلُ ، تُحْبَسُ۔",,,29603
29604,"حَدَّثَنَا حَفْصٌ ، عَنْ عُبَیدۃ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ تُقْتَلُ۔",,,29604
29605,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ فِی الْمُرْتَدَّۃِ : تُسْتَتَابُ ، فَإِنْ تَابَتْ ، وَإِلاَّ قُتِلَتْ۔",,,29605
29606,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ؛ أَنَّ أُمَّ وَلَدٍ لِرَجُلٍ مِنَ الْمُسْلِمِینَ ارْتَدَّتْ ، فَبَاعَہَا بِدَوْمَۃِ الْجَنْدَلِ ، مِنْ غَیْرِ أَہْلِ دِینِہَا۔,,,29606
29607,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إِبْرَاہِیمَ ؛ فِی الْمَرْأَۃِ تَرْتَدُّ عَنِ الإِسْلاَمِ ، قَالَ : تُسْتَتَابُ ، فَإِنْ تَابَتْ ، وَإِلاَّ قُتِلَتْ۔",,,29607
29608,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ، عَنْ سَعِیدٍ، عَنْ أَبِی مَعْشَرٍ، عَنْ إِبْرَاہِیمَ، قَالَ: تُسْتَتَابُ، فَإِنْ تَابَتْ، وَإِلاَّ قُتِلَتْ۔",,,29608
29609,"حَدَّثَنَا عَبْدُ الصَّمَدِ ، عَنْ ہِشَامٍ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : تُقْتَلُ۔",,,29609
29610,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ أَبِی حَصِینٍ ، عَنْ سُوَیْدِ بْنِ غَفَلَۃَ ؛ أَنَّ عَلِیًّا حَرَقَ زَنَادِقَۃً بِالسُّوقِ ، فَلَمَّا رَمَی عَلَیْہِمْ بِالنَّارِ ، قَالَ : صَدَقَ اللَّہُ وَرَسُولُہُ ، قَالَ : ثُمَّ انْصَرَفَ ، فَاتَّبَعْتُہُ ، قَالَ : أَسُوَیْدُ ؟ قُلْتُ : نَعَمْ ، یَا أَمِیرَ الْمُؤْمِنِینَ ، سَمِعْتُک تَقُولُ شَیْئًا ، قَالَ : یَا سُوَیْد ، إِنِّی مَعَ قَوْمٍ جُہَّالٍ ، فَإِذَا سَمِعْتنِی أَقُولُ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَہُوَ حَقٌّ۔",,,29610
29611,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عُبَیْدٍ ، عَنْ أَبِیہِ ، قَالَ : کَانَ أُنَاسٌ یَأْخُذُونَ الْعَطَائَ وَالرِّزْقَ وَیُصَلُّونَ مَعَ النَّاسِ کَانُوا یَعْبُدُونَ الأَصْنَامَ فِی السِّرِّ ، فَأُتِیَ بِہِمْ عَلِیُّ بْنُ أَبِی طَالِبٍ فَوَضَعَہُمْ فِی الْمَسْجِدِ ، أَوْ قَالَ : فِی السِّجْنِ ، ثُمَّ قَالَ : یَا أَیُّہَا النَّاسُ ، مَا تَرَوْنَ فِی قَوْمٍ کَانُوا یَأْخُذُونَ مَعَکُم الْعَطَائَ وَالرِّزْقَ ، وَیَعْبُدُونَ ہَذِہِ الأَصْنَامَ ؟ قَالَ النَّاسُ : اقْتُلْہُمْ ، قَالَ : لاَ ، وَلَکِنْ أَصْنَعُ بِہِمْ کَمَا صُنِعَ بِأَبِینَا إِبْرَاہِیمَ صلوات اللہ علیہ ، فَحَرَّقَہُمْ بِالنَّارِ۔",,,29611
29612,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ أَیُّوبَ بْنِ نُعْمَانَ ، قَالَ : شَہِدْتُ عَلِیًّا فِی الرَّحْبَۃِ ، وَجَائَ رَجُلٌ ، فَقَالَ : یَا أَمِیرَ الْمُؤْمِنِینَ ، إِنَّ ہَاہُنَا أَہْلَ بَیْتٍ لَہُمْ وَثَنٌ فِی دَارِہِمْ یَعْبُدُونَہُ ، فَقَامَ عَلِیٌّ یَمْشِی حَتَّی انْتَہَی إِلَی الدَّارِ ، فَأَمَرَہُمْ فَدَخَلُوا ، فَأَخْرَجُوا إِلَیْہِ تِمْثَالَ رُخَامٍ ، فَأَلْہَبَ عَلِیٌّ الدَّارَ۔",,,29612
29613,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ سِمَاکٍ ، عَنْ قَابُوسَ بْنِ مُخَارِقٍ ، عَنْ أَبِیہِ ، قَالَ : بَعَثَ عَلِیٌّ مُحَمَّدَ بْنَ أَبِی بَکْرٍ أَمِیرًا عَلَی مِصْرَ ، فَکَتَبَ مُحَمَّدٌ إِلَی عَلِیٍّ یَسْأَلُہُ عَنْ زَنَادِقَۃٍ ؛ مِنْہُمْ مَنْ یَعْبُدُ الشَّمْسَ وَالْقَمَرَ ، وَمِنْہُمْ مَنْ یَعْبُدُ غَیْرَ ذَلِکَ ، وَمِنْہُمْ مَنْ یُدْعَی لِلإِسْلاَمِ ؟ فَکَتَبَ عَلِیٌّ وَأمَرَہُ بِالزَّنَادِقَۃِ ؛ أَنْ یَقْتُلَ مَنْ کَانَ یَدْعِی الإِسْلاَمِ ، وَیُتْرَکُ سَائِرُہُمْ یَعْبُدُونَ مَا شَاؤُوا۔",,,29613
29614,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ أَیُّوبَ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ بَلَغَہُ أَنَّ عَلِیًّا أَخَذَ زَنَادِقَۃً فَأَحْرَقَہُمْ ، قَالَ : فَقَالَ : أَمَّا أَنَا فَلَوْ کُنْتُ لَمْ أُعَذِّبْہُمْ بِعَذَابِ اللہِ ، وَلَوْ کُنْتُ أَنَا لَقَتَلْتہمْ ، لِقَوْلِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ بَدَّلَ دِینَہُ فَاقْتُلُوہُ۔",,,29614
29615,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ سِمَاکٍ ، عَنِ ابْنِ عُبَیْدِ بْنِ الأَبْرَصِ ، عَنْ عَلِیِّ بْنِ أَبِی طَالِبٍ ؛ أَنَّہُ أُتِیَ بِرَجُلٍ کَانَ نَصْرَانِیًّا فَأَسْلَمَ ، ثُمَّ تَنَصَّرَ ، قَالَ : فَسَأَلَہُ عَنْ کَلِمَۃٍ ، فَقَالَ لَہُ ، فَقَامَ إِلَیْہِ عَلِیٌّ فَرَفَسَہُ بِرِجْلِہِ ، فَقَامَ النَّاسُ إِلَیْہِ فَضَرَبُوہُ حَتَّی قَتَلُوہُ۔",,,29615
29616,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ عَبْدِ الْمَلِکِ بْنِ سَعِیدِ بْنِ حَیَّانَ ، عَنْ عَمَّارٍ الدَّہْنِیِّ ، قَالَ : حدَّثَنَی أَبُو الطُّفَیْلِ ، قَالَ : کُنْتُ فِی الْجَیْشِ الَّذِینَ بَعَثَہُ عَلِیُّ بْنُ أَبِی طَالِبٍ إِلَی بَنِی نَاجِیَۃَ ، قَالَ : فَانْتَہَیْنَا إِلَیْہِمْ ، فَوَجَدْنَاہُمْ عَلَی ثَلاَثِ فِرَقٍ ، قَالَ : فَقَالَ أَمِیرُنَا لِفِرْقَۃٍ مِنْہُمْ : مَا أَنْتُمْ ؟ قَالُوا : نَحْنُ قَوْمٌ مِنَ النَّصَارَی لَمْ نَرَ دِینًا أَفْضَلَ مِنْ دِینِنَا ، فَثَبَتْنَا عَلَیْہِ ، فَقَالَ : اعْتَزَلُوا ، ثُمَّ قَالَ لِفِرْقَۃٍ أُخْرَی : مَا أَنْتُمْ ؟ قَالُوا : نَحْنُ قَوْمٌ کُنَّا نَصَارَی فَأَسْلَمْنَا فَثَبَتْنَا عَلَی الإِسْلاَمِ ، فَقَالَ : اعْتَزَلُوا ، ثُمَّ قَالَ لِلثَّالِثَۃِ : مَا أَنْتُمْ ؟ قَالُوا : نَحْنُ قَوْمٌ کُنَّا نَصَارَی فَأَسْلَمْنَا، ثُمَّ رَجَعْنَا، فَلَمْ نَرَ دِینًا أَفْضَلَ مِنْ دِینِنَا الأَوَّلِ، فَتَنَصَّرْنَا، فَقَالَ لَہُمْ: أَسْلِمُوا ، فَأَبَوْا، فَقَالَ لأَصْحَابِہِ : إِذَا مَسَحْتُ رَأْسِی ثَلاَثَ مَرَّاتٍ ، فَشُدُّوا عَلَیْہِمْ ، فَفَعَلُوا ، فَقَتَلُوا الْمُقَاتِلَۃَ ، وَسَبَوْا الذَّرِیۃَ۔",,,29616
29617,"حَدَّثَنَا شَرِیکٌ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ تُسَاکِنُکُمُ الْیَہُودُ وَالنَّصَارَی ، إِلاَّ أَنْ یُسْلِمُوا ، فَمَنْ أَسْلَمَ مِنْہُمْ ثُمَّ ارْتَدَّ ، فَلاَ تَضْرِبُوا إِلاَّ عُنُقَہُ۔",,,29617
29618,"حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ ، قَالَ : حدَّثَنَا حَسَنٌ ، عَنِ ابْنِ أَبِی لَیْلَی ؛ فِی رَجُلٍ سَرَقَ مِنَ الْکَعْبَۃِ ؟ قَالَ : لَیْسَ عَلَیْہِ قَطْعٌ۔",,,29618
29619,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ حَجَّاجٍ ، عَنِ الْقَاسِمِ بْنِ أَبِی بَزَّۃَ ، عَن مُجَاہِدٍ (ح) وَعَن لَیْثٍ ، عَنْ عَطَائٍ ، وَمُجَاہِدٍ (ح) وَجُوَیْبِرٍ ، عَنِ الضِّحَاکِ (ح) وَأَبِی حَرَّۃَ ، عَنِ الْحَسَنِ ؛ أَنَّہُمْ قَالُوا فِی الْمُحَارِبِ : الإِمَامُ فِیہِ مُخَیَّرٌ۔",,,29619
29620,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : السُّلْطَانُ وَلِیُّ قَتْلِ مَنْ حَارَبَ الدِّینَ۔",,,29620
29621,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ أَبِی ہِلاَلٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : الإِمَامُ مُخَیَّرٌ فِی الْمُحَارِبِ۔",,,29621
29622,"حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ؛ فِی الْمَرْأَۃِ تَقَعُ عَلَی الْمَرْأَۃِ ، قَالَ : تُضْرَبُ أَدْنَی الْحَدَّیْنِ۔",,,29622
29623,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عَبْدُ اللہِ بْنُ الْحَارِثِ الْحَاطِبِیَّ ، عَنْ حَفْصَۃَ بِنْتِ زَیْدٍ ، عَنْ سَالِمِ بْنِ عَبْدِ اللہِ بْنِ عُمَرَ ؛ فِی الْمَرْأَۃِ تَرْکَبُ الْمَرْأَۃَ ، قَالَ : لَیَلْقَیْنَ اللَّہَ وَہُمَا زَانِیَتَانِ۔",,,29623
29624,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ أَبِیہِ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : {إِنَّمَا جَزَائُ الَّذِینَ یُحَارِبُونَ اللَّہَ وَرَسُولَہُ} ، قَالَ : إِذَا خَرَجَ وَأَخَافَ السَّبِیلَ ، وَأَخَذَ الْمَالَ ، قُطِعَتْ یَدُہُ وَرِجْلُہُ مِنْ خِلاَفٍ ، وَإِذَا أَخَافَ السَّبِیلَ ، وَلَمْ یَأْخُذَ الْمَالَ نُفِیَ ، وَإِذَا قَتَلَ قُتِلَ ، وَإِذَا أَخَافَ السَّبِیلَ وَأَخَذَ الْمَالَ وَقَتَلَ صُلِبَ۔",,,29624
29625,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : حُدَّثْتُ عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : مَنْ حَارَبَ فَہُوَ مُحَارِبٌ ، قَالَ سَعِیدٌ : فَإِنْ أَصَابَ دَمًا قُتِلَ ، وَإِنْ أَصَابَ دَمًا وَمَالاً صُلِبَ ، فَإِنَّ الصَّلْبَ ہُوَ أَشَدُّ ، وَإِذَا أَصَابَ مَالاً وَلَمْ یُصِبْ دَمًا قُطِعَتْ یَدُہُ وَرِجْلُہُ ، لِقَوْلِ اللہِ جَلَّ جَلاَلہ : {أَوْ تُقَطَّعَ أَیْدِیہِمْ وَأَرْجُلُہُمْ مِنْ خِلاَفٍ} ، فَإِنْ تَابَ فَتَوْبَتُہُ بَیْنَہُ وَبَیْنَ اللہِ ، وَیُقَامُ عَلَیْہِ الْحَدُّ۔",,,29625
29626,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ حَجَّاجٍ ، عَنْ عَطِیَّۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ فِی قَوْلِہِ : {إِنَّمَا جَزَائُ الَّذِینَ یُحَارِبُونَ اللَّہَ وَرَسُولَہُ وَیَسْعَوْنَ فِی الأَرْضِ فَسَادًا أَنْ یُقَتَّلُوا ، أَوْ یُصَلَّبُوا ، أَوْ تُقَطَّعَ أَیْدِیہِمْ وَأَرْجُلُہُمْ مِنْ خِلاَفٍ} حَتَّی خَتَمَ الآیَۃَ ، فَقَالَ : إِذَا حَارَبَ الرَّجُلُ فَقَتَلَ وَأَخَذَ الْمَالَ ، قُطِعَتْ یَدُہُ وَرِجْلُہُ مِنْ خِلاَفٍ وَصُلِبَ ، وَإِذَا قَتَلَ وَلَمْ یَأْخُذِ الْمَالَ قُتِلَ ، وَإِذَا أَخَذَ الْمَالَ وَلَمْ یَقْتُلْ ، قُطِعَتْ یَدُہُ وَرِجْلُہُ مِنْ خِلاَفٍ ، وَإِذَا لَمْ یَقْتُلْ وَلَمْ یَأْخُذِ الْمَالَ نُفِیَ۔",,,29626
29627,"حَدَّثَنَا وَکِیعٌ ، عَن عِمْرَانَ بْنِ حُدَیْرٍ ، عَنْ أَبِی مِجْلَزٍ ؛ فِی ہَذِہِ الآیَۃِ : {إِنَّمَا جَزَائُ الَّذِینَ یُحَارِبُونَ اللَّہَ وَرَسُولَہُ} قَالَ : إِذَا قَتَلَ وَأَخَذَ الْمَالَ قُتِلَ ، وَإِذَا أَخَذَ الْمَالَ وَأَخَافَ السَّبِیلَ صُلِبَ ، وَإِذَا قَتَلَ وَلَمْ یَعْدُ ذَلِکَ قُتِلَ ، وَإِذَا أَخَذَ الْمَالَ وَلَمْ یَعْدُ ذَلِکَ قُطِعَ ، وَإِذَا أَفْسَدَ نُفِیَ۔",,,29627
29628,"حَدَّثَنَا ہُشَیْمٌ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ: مَنْ وَطِئَ فَرْجًا بِجَہَالَۃٍ ، دُرِئَ عَنْہُ الْحَدُّ ، وَضَمِنَ الْعُقْرَ۔",,,29628
29629,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَیُّوبَ الہُجَیمیِّ ، عَنْ عَمِّہِ ، قَالَ : رَأَیْتُ سَلْمَانَ بْنَ رَبِیعَۃَ أَخَذَ رَجُلاً فِی حَدٍّ فَأَضْجَعَہُ ، ثُمَّ ضَرَبَہُ۔",,,29629
29630,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنِ الْقَاسِمِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِیہِ ؛ أَنَّ عَلِیًّا ضَرَبَ رَجُلاً وَہُوَ قَاعِدٌ ، عَلَیْہِ عَبَائَۃٌ لَہُ قَسْطَلاَن۔,,,29630
29631,حَدَّثَنَا شَرِیکٌ، عَنْ سِمَاکٍ، عَنْ جَابِرِ بْنِ سَمُرَۃَ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجَمَ یَہُودِیًّا وَیَہُودِیَّۃً۔,,,29631
29632,حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَن مُجَالِدٍ ، عَنْ عَامِرٍ ، عَنْ جَابِرٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجَمَ یَہُودِیًّا وَیَہُودِیَّۃً۔,,,29632
29633,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا عُبَیْدُ اللہِ بْنُ عُمَرَ ، عَن نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجَمَ یَہُودِیَّیْنِ ، أَنَا فِیمَنْ رَجَمَہُمَا۔",,,29633
29634,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، وَوَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ عَبْدِ اللہِ بْنِ مُرَّۃَ ، عَنْ الْبَرَائِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجَمَ یَہُودِیًّا۔,,,29634
29635,حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنِ الشَّعْبِیِّ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجَمَ یَہُودِیًّا ، أَوْ یَہُودِیَّۃً۔,,,29635
29636,"حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ رَاشِدٍ ، عَنْ مَکْحُولٍ ؛ فِی رَجُلٍ دَخَلَ حَمَّامًا ؛ فَأَخَذَ جُبَّۃً فَلَبِسَہَا بَیْنَ قَمِیصَیْنِ ، قَالَ : یُقْطَعُ۔",,,29636
29637,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ؛ قَالَ : أَخْبَرَنَی مُعَاوِیَۃُ بْنُ صَالِحٍ ؛ قَالَ : حَدَّثَنَی أَبُو الزَّاہِرِیَّۃِ ، عَن جُبَیْرِ بْنِ نُفَیْرٍ، عَنْ أَبِی الدَّرْدَائِ ؛ أَنَّہُ سُئِلَ عَن سَارِقِ الْحَمَّامِ ؟ فَقَالَ : لاَ قَطْعَ عَلَیْہِ۔",,,29637
29638,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : تُضْرَبُ النِّسَائُ ضَرْبًا دُونَ ضَرْبٍ ، وَسَوْطًا دُونَ سَوْطٍ ، وَتُتَّقَی وُجُوہُہُنَّ ، وَلاَ یُمَدَّدْنَ ، وَلاَ یُجَرَّدْنَ۔",,,29638
29639,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَشْعَثَ ، عَنْ أَبِیہِ ؛ قَالَ : شَہِدْتُ أَبَا بَرْزَۃَ ضَرَبَ أَمَۃً لَہُ قَدْ فَجَرَتْ ، وَعَلَیْہَا مِلْحَفَۃٌ ، ضَرْبًا لَیْسَ بِالتَّمَطِّی ، وَلاَ بِالتَّخْفِیفِ۔",,,29639
29640,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَامِرٍ ؛ قَالَ : النِّسَائُ لاَ یُجَرَّدْنَ ، وَلاَ یُمْدَّدْنَ ، یُضْرَبْنَ ضَرْبًا دُونَ ضَرْبٍ ، وَسَوْطًا دُونَ سَوْطٍ ، وَتُتَّقَی وُجُوہُہُنَّ۔",,,29640
29641,"حَدَّثَنَا وَکِیعٌ ، عَنِ الْمَسْعُودِیِّ ، عَنِ الْقَاسِمِ ؛ أَنَّ أَبَا بَکْرٍ أُتِیَ بِرَجُلٍ انْتَفَی مِنْ أَبِیہِ ، فَقَالَ أَبُو بَکْرٍ : اضْرِبِ الرَّأْسَ ، فَإِنَّ الشَّیْطَانَ فِی الرَّأْسِ ۔",,,29641
29642,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ عِیسَی بْنِ أَبِی عَزَّۃَ ، قَالَ : شَہِدْتُ الشَّعْبِیَّ وَنَہَی عَنْ ضَرْبَ رَأْسِ رَجُلٍ افْتَرَی عَلَی رَجُلٍ ، وَہُوَ یُجْلَدُ۔",,,29642
29643,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، قَالَ : سُئِلَ عَطَائٌ عَنِ الرَّجُلِ یَسْمَعُ الرَّجُلَ یَقْذِفُ الرَّجُلَ ، أَیُبَلِّغُہُ ؟ قَالَ : لاَ ، إِنَّمَا تُجَالِسُونَ بِالأَمَانَۃِ۔",,,29643
29644,"حَدَّثَنَا ابْنُ مُبَارَکٍ، عَن جُوَیْبِرٍ، عَنِ الضَّحَّاکِ؛ فِی رَجُلٍ قَذَفَ أمْرَأَتَہُ، ثُمَّ ادَّعَی شُہُودًا غَیْبًا، قَالَ: لاَ یُؤَجَّلُ۔",,,29644
29645,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ عُلاَثَۃَ مُحَمَّدِ بْنِ عَبْدِ اللہِ الْعُقَیْلِیِّ ، قَالَ : قَذَفَ رَجُلٌ رَجُلاً ، فَرَفَعَہُ إِلَی عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، فَادَّعَی الْقَاذِفُ الْبَیِّنَۃَ عَلَی مَا قَالَ لَہُ بِأَرْمِینِیَّۃَ ، یَعْنِی غَیْبًا ، قَالَ : فَقَالَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ: الْحَدُّ لاَ یُؤَخَّرُ ، لَکِنْ إِنْ جِئْتَ بِبَیِّنَۃٍ قَبِلْتُ شَہَادَتَہُمْ۔",,,29645
29646,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَن حُمَیْدٍ ، عَن بَکْرٍ ؛ أَنَّ رَجُلاً قَذَفَ رَجُلاً ، فَرَفَعَہُ إِلَی عُمَرَ بْنِ الْخَطَّابِ ، فَأَرَادَ أَنْ یَجْلِدَہُ ، فَقَالَ : أَنَا أُقِیمُ الْبَیِّنَۃَ ، فَتَرَکَہُ۔",,,29646
29647,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ وَمُحَمَّدٍ ، قَالاَ : إِذَا قَتَلَ السَّکْرَانُ قُتِلَ۔",,,29647
29648,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : یُقْتَلُ۔",,,29648
29649,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ؛ أَنَّ سَکْرَانَیْنِ قَتَلَ أَحَدُہُمَا صَاحِبَہُ : فَقَتَلَہُ مُعَاوِیَۃُ۔",,,29649
29650,"قالَ أَبُو بَکْرٍ : ہَذَا مَا حَفِظْت عَنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنَّہُ قَضَی بِہِ وَأَجَازَ فِیہِ الْقَضَائَ۔\n\nحَدَّثَنَا أَبُو عَبْدِ الرَّحْمَنِ بَقِیُّ بْنُ مَخْلَدٍ قَالَ : حدَّثَنَا أَبْو بَکْرٍ قَالَ :\n\n حدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَن عُبَیْدِ اللہِ بْنِ أَبِی یَزِیدَ ، عَنْ أَبِیہِ ، عَنْ عُمَرَ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَضَی بِالْوَلَدِ لِلْفِرَاشِ۔",,,29650
29651,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ قَالَ : قضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی کُلِّ شَرِکٍ لَمْ یُقْسَمْ رَبْعَۃٍ ، أَوْ حَائِطٍ ، لاَ یَحِلُّ لَہُ أَنْ یَبِیعَ حَتَّی یَسْتَأْذِنَ شَرِیکَہُ ، فَإِنْ شَائَ أَخَذَ ، وَإِنْ شَائَ تَرَکَ ، فَإِنْ بَاعَ وَلَمْ یُؤْذِنْہُ ، فَہُوَ أَحَقُّ بِہِ۔ (مسلم 1229۔ ابوداؤد 3507)",,,29651
29652,"حَدَّثَنَا جَرِیرٌ ، عَن مَنْصُورٍ ، عَنِ الْحَکَمِ ، عَنْ عَلِیٍّ ، وَعَبْدِ اللہِ قَالا : قضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِالشُّفْعَۃِ لِلْجِوَارِ۔",,,29652
29653,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ الْعَبْدِیُّ قَالَ : حدَّثَنَا نَافِعُ بْنُ عُمَرَ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، عَنِ ابْنِ عَبَّاسٍ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَضَی بِالْیَمِینِ عَلَی الْمُدَّعَی عَلَیْہِ۔",,,29653
29654,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَن فِرَاسٍ ، عَنِ الشَّعْبِیِّ ، عَن مَسْرُوقٍ ، عَنْ عَبْدِ اللہِ أَنَّہُ سُئِلَ ، عَنْ رَجُلٍ تَزَوَّجَ امْرَأَۃً فَمَاتَ عنہا وَلَمْ یَدْخُلْ بِہَا وَلَمْ یَفْرِضْ لَہَا صَدَاقًا قَالَ عَبْدُ اللہِ : لَہَا الصَّدَاقُ وَلَہَا الْمِیرَاثُ وَعَلَیْہَا الْعِدَّۃُ ، وَقَالَ مَعْقِلُ بْنُ سِنَانٍ : شَہِدْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَضَی فِی بِرْوَعَ ابنَۃ وَاشِقٍ بِمِثْلِ ذَلِکَ۔",,,29654
29655,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَن سِمَاکٍ ، عَن تَمِیمِ بْنِ طَرَفَۃَ قَالَ : اخْتَصَمَ رَجُلانِ إِلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی جَمَلٍ ، فَجَائَ کُلُّ وَاحِدٍ مِنْہُمَا إِلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِشَاہِدَیْنِ یَشْہَدَانِ أَنَّہُ جَمَلُہُ فَقَضَی بِہِ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَیْنَہُمَا۔",,,29655
29656,"حَدَّثَنَا ابْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَن سَلَمَۃَ بْنِ کُہَیْلٍ قَالَ : کُنَّا جُلُوسًا عِنْدَ شُرَیْحٍ إِذْ أَتَاہُ قَوْمٌ یَخْتَصِمُونَ إِلَیْہِ فِی عُمْرَی جُعِلَتْ لِرَجُلِ حَیَاتَہُ ، فَقَالَ لَہُ : ہِیَ لَہُ حَیَاتَہُ وَمَوْتَہُ ، فَأَقْبَلَ عَلَیْہِ الَّذِی قَضَی عَلَیْہِ یُنَاشِدُہُ فَقَالَ شُرَیْحٌ : لَقَدْ لامَنِی ہَذَا فِی أَمْرٍ قَضَی بِہِ رسول اللہ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,29656
29657,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنِ الْمِسْوَرِ أَنَّ عُمَرَ اسْتَشَارَ النَّاسَ فِی إِمْلاصِ الْمَرْأَۃِ، فَقَالَ الْمُغِیرَۃُ بْنُ شُعْبَۃَ : شَہِدْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَضَی فِیہِ بِغُرَّۃِ عَبْدٍ ، أَوْ أَمَۃٍ ، فَقَالَ عُمَرُ : لَتَأْتِیَنَّ بِمَنْ یَشْہَدُ ، فَشَہِدَ لَہُ مُحَمَّدُ بْنُ مَسْلَمَۃَ۔",,,29657
29658,"حَدَّثَنَا یَحْیَی بْنُ یَعْلَی التَّیْمِیُّ ، عَن مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَن عُبَیْدِ بْنِ نُضَیْلَۃَ ، عَنِ الْمُغِیرَۃِ بْنِ شُعْبَۃَ قَالَ : قضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَلَی عَاقِلَتِہَا االدِّیَۃِ ، وَفِی الْحَمْلِ غُرَّۃٌ۔",,,29658
29659,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی قَیْسٍ ، عَن ہُزَیْلِ بْنِ شُرَحْبِیلَ قَالَ : جَائَ رَجُلٌ إِلَی أَبِی مُوسَی وَسَلْمَانَ بْنِ رَبِیعَۃَ فَسَأَلَہُمَا عَنِ ابْنَۃٍ ، وَابْنَۃِ ابْنٍ ، وَأُخْتٍ لأَبٍ وَأُمٍّ ، فَقَالا : لِلابْنَۃِ النِّصْفُ ، وَمَا بَقِیَ فَلِلأُخْتِ ، وَائْتِ ابْنَ مَسْعُودٍ فَاسْأَلْہُ فَإِنَّہُ سَیُتَابِعُنَا ، فَأَتَی الرَّجُلُ ابْنَ مَسْعُودٍ فَسَأَلَہُ وَأَخْبَرَہُ بِمَا قَالا : فَقَالَ ابْنُ مَسْعُودٍ : {لقَدْ ضَلَلْتُ إِذًا وَمَا أَنَا مِنَ الْمُہْتَدِینَ} وَلَکِنْ سَأَقْضِی بِمَا قَضَی بِہِ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لِلابْنَۃِ النِّصْفُ ، وَلابْنَۃِ الابْنِ السُّدُسُ تَکْمِلَۃَ الثُّلُثَیْنِ ، وَمَا بَقِیَ فَلِلأُخْتِ۔\n\n(بخاری 6742۔ ابوداؤد 2882)",,,29659
29660,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَن عُبَیْدِ اللہِ ، عَن زَیْدِ بْنِ خَالِدٍ وَشَبْلٍ ، وَأَبِی ہُرَیْرَۃَ قَالُوا : کُنَّا عِنْدَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَأَتَاہُ رَجُلٌ فَقَالَ : أَنْشُدُک اللَّہَ ، إِلاَّ قَضَیْت بَیْنَنَا بِکِتَابِ اللہِ ، فَقَالَ خَصْمُہُ ، وَکَانَ أَفْقَہَ مِنْہُ : أَجَلْ یَا رَسُولَ اللہِ اقْضِ بَیْنَنَا بِکِتَابِ اللہِ وَائْذَنْ لِی حَتَّی أَقُولَ ، قَالَ : قُلْ ، قَالَ : إِنَّ ابْنِی کَانَ عَسِیفًا عَلَی ہَذَا ، وَالْعَسِیفُ : الأَجِیرُ ، وَإِنَّہُ زَنَی بِامْرَأَتِہِ فَافْتَدَیْت مِنْہُ بِمِئَۃِ شَاۃٍ وَخَادِمٍ ، فَسَأَلْت رِجَالاً مِنْ أَہْلِ الْعِلْمِ فَأُخْبِرْت أَنَّ عَلَی ابْنِی جَلْدَ مِئَۃ وَتَغْرِیبَ عَامٍ ، وَأَنَّ عَلَی امْرَأَۃِ ہَذَا الرَّجْمَ ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : وَالَّذِی نَفْسِی بِیَدِہِ ، لأَقْضِیَنَّ بَیْنَکُمَا بِکِتَابِ اللہِ : الْمِئَۃُ شَاۃٍ وَالْخَادِمُ رَدٌّ عَلَیْک ، وَعَلَی ابْنِکَ جَلْدُ مِئَۃ وَتَغْرِیبُ عَامِ ، وَاغْدُ یَا أُنَیْسُ عَلَی امْرَأَۃِ ہَذَا فَإِنَ اعْتَرَفَتْ فَارْجُمْہَا۔",,,29660
29661,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ قَالَ : حدَّثَنَا سَیْفُ بْنُ سُلَیْمَانَ الْمَکِّیُّ قَالَ : أَخْبَرَنَی قَیْسُ بْنُ سَعْدٍ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، عَنِ ابْنِ عَبَّاسٍ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَضَی بِیَمِینٍ وَشَاہِدٍ۔",,,29661
29662,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ قَالَ : قَضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِالدَّیْنِ قَبْلَ الْوَصِیَّۃِ وَأَنْتُمْ تَقْرَؤُونَ : {مِنْ بَعْدِ وَصِیَّۃٍ یُوصِی بِہَا أَوْ دَیْنٍ} وَأَنَّ أَعْیَانَ بَنِی الأُمِّ یَتَوَارَثُونَ دُونَ بَنِی الْعَلاَّتِ۔ (ابن ماجہ 2715۔ احمد 131)",,,29662
29663,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَن مَہْدِیِّ بْنِ مَیْمُونٍ ، عَنْ مُحَمَّدِ بْنِ أَبِی یَعْقُوبَ ، عَنِ الْحَسَنِ بْنِ سَعْدٍ قَالَ: حدَّثَنِی رَبَاحٌ ، عَنْ عُثْمَانَ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَضَی أَنَّ الْوَلَدَ لِلْفِرَاشِ۔",,,29663
29664,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ سُفْیَانَ بْنِ حُسَیْنٍ ، عَنْ شَیْبَۃَ بْنِ مُسَاوِرٍ قَالَ : کَتَبَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ فَقُرِئَ عَلَیْنَا کِتَابُہُ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَضَی فِی الْمُوضِحَۃِ بِخَمْسٍ مِنَ الإِبِلِ ، وَلَمْ یَقْضِ فِیمَا سِوَی ذَلِکَ۔",,,29664
29665,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ أَخْبَرَنَا مُحَمَّدُ بْنُ إِسْحَاقَ ، عَنْ أَبِی مَالِکِ بْنِ ثَعْلَبَۃَ ، عَنْ أَبِیہِ ثَعْلَبَۃَ بْنِ أَبِی مَالِکٍ قَالَ : قضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی مَہْزُورِ وَادِی بَنِی قُرَیْظَۃَ أَنْ یَحْبِسَ الْمَائَ إِلَی الْکَعْبَیْنِ ، لاَ یَحْبِسُ الأَعْلَی عَلَی الأَسْفَلِ۔ (طبرانی 1386)",,,29665
29666,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ قَالَ : قضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی السِّنِّ بِخَمْسٍ مِنَ الإِبِلِ۔",,,29666
29667,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدٍ وَحرَامِ بْنِ سَعْدٍ أَنَّ نَاقَۃً لِلْبَرَائِ دَخَلَتْ حَائِطَ قَوْمٍ فَأَفْسَدَتْ عَلَیْہِمْ ، فَقَضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنَّ حِفْظَ الأَمْوَالِ عَلَی أَہْلِہَا بِالنَّہَارِ ، وَأَنَّ عَلَی أَہْلِ الْمَاشِیَۃِ مَا أَصَابَتِ الْمَاشِیَۃُ بِاللَّیْلِ۔,,,29667
29668,حَدَّثَنَا أَبُو أُسَامَۃَ وَمُحَمَّدُ بْنُ بِشْرٍ ، عَنْ سَعِیدِ بْنِ أَبِی عَرُوبَۃَ ، عَن غَالِبٍ التَّمَّارِ، عنْ حُمَیْدِ بْنِ ہِلالٍ، عَن مَسْرُوقِ بْنِ أَوْسٍ ، عَنْ أَبِی مُوسَی الأَشْعَرِیِّ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَضَی فِی الأَصَابِعِ عَشْرًا مِنَ الإِبِلِ۔,,,29668
29669,حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، عَنْ سَعِیدٍ ، عَنْ مَطَرٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَضَی فِی الأَصَابِعِ عَشْرًا عَشْرًا۔,,,29669
29670,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عُثْمَانَ الْبَتِّیِّ ، عَنْ عَبْدِ الْحَمِیدِ بْنِ سَلَمَۃَ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ أَنَّ أَبَوَیْہِ اخْتَصَمَا فِیہِ إِلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَحَدُہُمَا کَافِرٌ وَالآخَرُ مُسْلِمٌ ، فَخَیَّرَہُ ، فَتَوَجَّہَ إِلَی الْکَافِرِ ، فَقَالَ اللَّہُمَّ اہْدِہِ فَتَوَجَّہَ إِلَی الْمُسْلِمِ فَقَضَی لَہُ بِہِ۔ (نسائی 6387۔ احمد 446),,,29670
29671,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ الْعَبْدِیُّ ، حدَّثَنَا مُحَمَّدُ بْنُ عَمْرٍو ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ قَالَ : قَضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی الْجَنِینِ غُرَّۃً : عَبْدًا ، أَوْ أَمَۃً ، فَقَالَ الَّذِی قَضَی عَلَیْہِ : أَنَعْقِلُ مَنْ لاَ شَرِبَ ، وَلا أَکَلَ ، وَلا صَاحَ ، وَلا اسْتَہَلَّ ، وَمِثْلُ ذَلِکَ یُطَل ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنَّ ہَذَا لَیَقُولُ بِقَوْلِ شَاعِرٍ ، فِیہِ غُرَّۃٌ : عَبْدٌ ، أَوْ أَمَۃٌ۔ (ابن ماجہ 2639)",,,29671
29672,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَوْفٍ قَالَ : قرِئَ عَلَیْنَا کِتَابُ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ أَیُّمَا رَجُلٍ أَفْلَسَ فَأَدْرَکَ رَجُلٌ مَتَاعَہُ بِعَیْنِہِ ، فَہُوَ أَحَقُّ بِہِ مِنْ سَائِرِ الْغُرَمَائِ إلا أن یکون اقتضی من مالہ شیئًا ، فہو أسوۃ الغرماء ، قَضَی بِذَلِکَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,29672
29673,"حَدَّثَنَا مُحَمَّدُ بْنُ سَوَائٍ ، عَنْ سَعِیدِ بْنِ أَبِی عَرُوبَۃَ ، عَنْ أَبِی الطُّفَیْلِ سَعِیدِ بْنِ حَمْلٍ ، عَن عِکْرِمَۃَ قَالَ: عِدَّۃُ الْمُخْتَلِعَۃِ حَیْضَۃٌ ، قَضَاہَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی جَمِیلَۃَ ابْنَۃِ سَلُولَ۔",,,29673
29674,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ حَجَّاجٍ ، عَنْ أَبِی سَعِیدٍ الأَعْسَمِ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَضَی فِی الْعَبْدِ وَسَیِّدِہِ قَضِیَّتَیْنِ ، قَضَی فِی الْعَبْدِ إِذَا خَرَجَ مِنْ دَارِ الْحَرْبِ قَبْلَ سَیِّدِہِ ، فَہُوَ حُرٌّ ، فَإِنْ خَرَجَ سَیِّدُہُ بَعْدَہُ لَمْ یردہ عَلَیْہِ ، وَإِنْ خَرَجَ السَّیِّدُ قَبْلَ الْعَبْدِ مِنْ دَارِ الْحَرْبِ ، ثُمَّ خَرَجَ الْعَبْدُ بَعْدَ ردّہ عَلَی سَیِّدِہِ۔ (سعید بن منصور 2806),,,29674
29675,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ حَدَّثَنَا عَبَّادُ بْنُ مَنْصُورٍ ، عَن عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : فَرَّقَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَیْنَہُمَا یَعْنِی الْمُتَلاعِنَیْنِ ، وَقَضَی أَنْ لاَ بَیْتَ لَہَا عَلَیْہِ ، وَلا قُوتَ مِنْ أَجْلِ أَنَّہُمَا یَتَفَرَّقَانِ مِنْ غَیْرِ طَلاقٍ ، وَلا مُتَوَفًّی عَنہَا ، وَقَضَی أَنْ لاَ یُدْعَی ولدہا لأبٍ وَلا تُرْمَی ہِیَ ، وَلا یُرْمَی وَلَدُہَا ، وَمَنْ رَمَاہَا ، أَوْ رَمَی وَلَدَہَا فَعَلَیْہِ الْحَدُّ۔",,,29675
29676,"حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ قَالَ : قَالَ عَلِیٌّ : مَنْ بَاعَ عَبْدًا ، وَلَہُ مَالٌ فَمَالُہُ لِلْبَائِعِ إِلاَّ أَنْ یَشْرِطَ الْمُبْتَاعُ ، قَضَی بِہِ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,29676
29677,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ أَبِی بَکْرِ بْنِ عَبْدِ اللہِ بْنِ أَبِی مَرْیَمَ ، عَن ضَمْرَۃَ بْنِ حَبِیبٍ قَالَ : قَضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَلَی ابْنَتِہِ فَاطِمَۃَ بِخِدْمَۃِ الْبَیْتِ ، وَقَضَی عَلَی عَلِیٍّ بِمَا کَانَ خَارِجًا مِنَ الْبَیْتِ مِنَ الْخِدْمَۃِ۔",,,29677
29678,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ رُفَیْعٍ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ قَالَ : قَضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِالشُّفْعَۃِ فِی کُلِّ شَیْئٍ فِی الأَرْضِ وَالدَّارِ وَالْجَارِیَۃِ وَالدَّابَّۃِ ، فَقَالَ عَطَائٌ إِنَّمَا الشُّفْعَۃُ فِی الأَرْضِ وَالدَّارِ ، فَقَالَ ابْنُ أَبِی مُلَیْکَۃَ : تَسْمَعُنی لاَ أُمَّ لَکَ أَقُولُ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَتَقُول ہَذَا ؟۔",,,29678
29679,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ، عَنْ عَمْرٍو، عَن عِکْرِمَۃَ قَالَ: قضَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لِرَجُلٍ مِنَ الأَنْصَارِ قَتَلَہُ مَوْلَی بَنِی عَدِیٍّ بِالدِّیَۃِ اثْنَیْ عَشَرَ أَلْفًا، وَفِیہِمْ نَزَلَتْ: {وَمَا نَقَمُوا إِلاَّ أَنْ أَغْنَاہُمُ اللَّہُ وَرَسُولُہُ مِنْ فَضْلِہِ}۔",,,29679
29680,"حَدَّثَنَا یَحْیَی بْنُ زَکَرِیَّا بْنِ أَبِی زَائِدَۃَ ، عن داود ، عَنِ الشَّعْبِیِّ ، عَنْ عَلْقَمَۃَ قَالَ : جَائَ رَجُلٌ إِلَی ابْنِ مَسْعُودٍ فَقَالَ : إِنَّ رَجُلاً مِنَّا تَزَوَّجَ امْرَأَۃً ولَمْ یَفْرِضْ لَہَا وَلَمْ یُجَامِعْہَا حَتَّی مَاتَ ، فَقَالَ ابْنُ مَسْعُودٍ : مَا سُئِلْتُ عَن شَیْئٍ مُنْذُ فَارَقْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَشَدَّ عَلَیَّ مِنْ ہَذَا ، قَالَ : فَتَرَدَّدَ فِیہَا شَہْرًا فَقَالَ : سَأَقُولُ فِیہَا بِرَأْیِی ، فَإِنْ کَانَ صَوَابًا فَمِنَ اللہِ ، وَإِنْ کَانَ خَطَأً فَمِنِّی وَالشَّیْطَانِ ، أَرَی أَنَّ لَہَا مَہْرَ نِسَائِہَا لاَ وَکْسَ ، وَلا شَطَطَ ، وَلَہَا الْمِیرَاثُ ، وَعَلَیْہَا عِدَّۃُ الْمُتَوَفَّی عنہا زَوْجُہَا ، فَقَامَ نَاسٌ مِنْ أَشْجَعَ فَقَالُوا : نَشْہَدُ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَضَی بِمِثْلِ الَّذِی قَضَیْت فِی امْرَأَۃٍ مِنَّا یُقَالُ لَہَا بِرْوَعُ ابْنَۃُ وَاشِقٍ ، قَالَ فَمَا رَأَیْت ابْنَ مَسْعُودٍ فَرِحَ کما فَرِحَ یَوْمَئِذٍ۔",,,29680
29681,"حَدَّثَنَا یَحْیَی بْنُ زکریا بن أَبِی زَائِدَۃَ ، عَنْ أَبِیہِ ، عَن حَبِیبِ بْنِ أَبِی ثَابِتٍ ، عَن حُمَیْدٍ ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ قَالَ : نَحَلَ رَجُلٌ مِنَّا أُمَّہُ نخلاً حَیَاتَہَا ، فَلَمَّا مَاتَتْ قَالَ : أَنَا أَحَقُّ بِنخْلِی ، فَقَضَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنَّہَا مِیرَاثٌ۔ (مسلم 1247)",,,29681
29682,"حَدَّثَنَا یَحْیَی بْنُ زکریا بن أَبِی زَائِدَۃَ ، عَنْ أَبِیہِ ، عَن خَالِدِ بْنِ سَلَمَۃَ قَالَ : حدَّثَنِی مُحَمَّدُ بْنُ أَبِی ضرَارٍ قَالَ : اخْتَصَمَ رَجُلانِ إِلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقَضَی عَلَی أَحَدِہِمَا ، قَالَ : فَأَحدَّ کَأَنَّہُ یُنْکِرُ وَیَرَی غَیْرَ ذَلِکَ ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنَّمَا أَنَا بَشَرٌ أَقْضِی بِمَا أَرَی ، فَمَنْ قَضَیْت لہ مِنْ حق أَخِیہِ شَیْئًا فَلا یَأْخُذْہُ۔",,,29682
29683,"حَدَّثَنَا وَکِیعٌ ، حدَّثَنَا ابْنُ أَبِی ذِئْبٍ ، عَن مَخْلَدِ بْنِ خُفَافِ بْنِ إِیمَاء بْنِ رَحْضَۃَ الْغِفَارِیِّ ، عَنْ عُرْوَۃَ بْنِ الزُّبَیْرِ ، عَنْ عَائِشَۃَ قَالَتْ : قَضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَنَّ خَرَاجَ الْعَبْدِ بِضَمَانِہِ۔ (ابوداؤد 3502۔ ترمذی 1285)",,,29683
29684,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَن زَیْنَبَ ابنۃ أُمِّ سَلَمَۃَ ، عَن أُمِّ سَلَمَۃَ قَالَتْ قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنَّکُمْ تَخْتَصِمُونَ إِلَیَّ ، وَإِنَّمَا أَنَا بَشَرٌ ، وَلَعَلَّ بَعْضَکُمْ أَنْ یَکُونَ أَلْحَنَ بِحُجَّتِہِ مِنْ بَعْضٍ ، وَإِنَّمَا أَقْضِی بَیْنَکُمْ عَلَی نَحْوِ مما أَسْمَعُ مِنْکُمْ ، فَمَنْ قَضَیْت لَہُ مِنْ حَقِّ أَخِیہِ شَیْئًا فَلا یَأْخُذْہُ ، فَإِنَّمَا أَقْطَعُ لَہُ قِطْعَۃً مِنَ النَّارِ ، یَأْتِی بِہَا یَوْمَ الْقِیَامَۃِ۔",,,29684
29685,حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدِ بْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ أَبِی بُرْدَۃَ ، عَنْ أَبِی مُوسَی أَنَّ رَجُلَیْنِ ادَّعَیَا دَابَّۃً لَیْسَ لِوَاحِدٍ مِنْہُمَا بَیِّنَۃٌ فَقَضَی بِہَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَیْنَہُمَا۔,,,29685
29686,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ أَشْعَثَ ، عَنِ الزُّہْرِیِّ قَالَ : قضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی الذَّکَرِ إِذَا اسْتُؤْصِلَ ، أَوْ قُطِعَتْ حَشَفَتُہُ الدِّیَۃَ مِئَۃ مِنَ الإِبِلِ۔",,,29686
29687,"حَدَّثَنَا عَبْدُ الأَعْلَی بْنُ عَبْدِالأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ قَالَ: دَعَانِی عُمَرُ بْنُ عَبْدِ الْعَزِیزِ فَسَأَلَنِی عَنِ الْقَسَامَۃِ فَقَالَ : إِنَّہُ قَدْ بَدَا لِی أَنْ أَرُدَّہَا إِنَّ الأَعْرَابِیَّ یَشْہَدُ ، وَالرَّجُلُ الْغَائِبُ یَجِیئُ فَیَشْہَدُ ، فَقُلْتُ : یَا أَمِیرَ الْمُؤْمِنِینَ ، إِنَّک لَنْ تَسْتَطِیعَ رَدَّہَا ، قَضَی بِہَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَالْخُلَفَائُ بَعْدَہُ۔",,,29687
29688,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ قَالَ: حدَّثَنَا ابْنُ أَبِی ذِئْبٍ، عَنِ ابْنِ شِہَابٍ، عَنْ أَبِی سَلَمَۃَ، عَنْ جَابِرِ بْنِ عَبْدِاللہِ قَالَ : قَضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِالْعُمْرَی لَہُ وَلِعَقِبِہِ بَتْلَۃً ، لَیْسَ لِلْمُعْطِی فِیہَا شَرْطٌ ، وَلا ثُنْیَا۔",,,29688
29689,"حَدَّثَنَا حَفْصٌ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَضَی بِابْنَۃِ حَمْزَۃَ لِجَعْفَرٍ ، وَقَالَ : إِنَّ خَالَتَہَا عَندَہُ ، وَالْخَالَۃُ وَالِدَۃٌ۔ (ابوداؤد 2274۔ احمد 98)",,,29689
29690,"حَدَّثَنَا عَبْدُ الأَعْلَی قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ إِسْحَاقَ ، عَنْ مَکْحُولٍ ، قَالَ : قَضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی الْمُوضِحَۃِ فَصَاعِدًا ؛ قَضَی فِی الْمُوضِحَۃِ : بِخَمْسٍ مِنَ الإِبِلِ ، وَفِی المنقَّلۃ : خمس عشرۃ ، وفی المأمومۃ : الثلث ، وفی الجائفۃ : الثلث۔",,,29690
29691,"حَدَّثَنَا عبد الرحیم بن سلیمان ، عن أشعث ، عن الزہری قَالَ : قَضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی الصُّلْبِ الدِّیَۃَ۔",,,29691
29692,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَن دَاوُد بْنِ أَبِی ہِنْدٍ ، عَنْ عَبْدِ اللہِ بْنِ عُبَیْدِ بْنِ عُمَیْرٍ قَالَ : کَتَبَ إِلَیَّ أَخٌ مِنْ بَنِی زُرَیْقٍ : لِمَنْ قَضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِابْنِ الْمُلاعَنَۃِ ؟ فَکَتَبْت إِلَیْہِ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَضَی بِہِ لأُِمِّہِ ، ہِیَ بِمَنْزِلَۃِ أَبِیہِ وَبِمَنْزِلَۃِ أُمِّہِ۔ (عبدالرزاق 12476)",,,29692
29693,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَن سِمَاکٍ ، عَنْ خَالِدِ بْنِ عَرْعَرَۃَ ، عَنْ عَلِیٍّ ، قَالَ : لَمَّا أَرَادُوا أَنْ یَرْفَعُوا الْحَجَرَ الأَسْوَدَ ، اخْتَصَمُوا فِیہِ فَقَالُوا : یَحْکُمُ بَیْنَنَا أَوَّلُ رَجُلٍ یَخْرُجُ مِنْ ہَذِہِ السِّکَّۃِ ، قَالَ : فَکَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَوَّلَ مَنْ خَرَجَ علیہم ، فَقَضَی بَیْنَہُمْ أَنْ یَجْعَلُوہُ فِی مِرْطٍ ، ثُمَّ یَرْفَعَہُ جَمِیعُ الْقَبَائِلِ کُلِّہَا۔ (حاکم 458)",,,29693
29694,"حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ ، قَالَ : حدَّثَنَا ابْنُ أَبِی ذِئْبٍ ، عَنْ أَبِی الْمُعْتَمِرِ عن عمر بْنِ خَلْدَۃَ الأَنْصَارِیِّ ، قَالَ : جِئنا أَبا ہُرَیْرَۃَ فِی صَاحِبٍ لَنَا أُصِیبَ بِہَذَا الدَّیْنِ ، یَعْنِی أَفْلَسَ ، فَقَالَ : قَضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی رَجُلٍ مَاتَ ، أَوْ أَفْلَسَ أَنَّ صَاحِبَ الْمَتَاعِ أَحَقُّ بِمَتَاعِہِ إِذَا وَجَدَہُ إِلاَّ أَنْ یَتْرُکَ صَاحِبُہُ وَفَائً۔\n\n(ابوداؤد 3518۔ ابن ماجہ 2360)",,,29694
29695,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عُمَرَ بْنِ رَاشِدٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : سَمِعْتُہ یَقُولُ : قَضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِالْجِوَارِ۔",,,29695
29696,حَدَّثَنَا وَکِیعٌ ، عَنِ علی بْنِ مُبَارَکٍ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ یَزِیدَ بْنِ نُعَیْمٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ أَنَّ نَضْرَۃَ بْنَ أَکْثَم تَزَوَّجَ امْرَأَۃً وَہِیَ حَامِلٌ ، فَفَرَّقَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَیْنَہُمَا ، وَقَضَی لَہَا بِالصَّدقۃ۔ (ابوداؤد 2124),,,29696
29697,"حَدَّثَنَا عَبْدُ الأَعْلَی بْنُ عَبْدِ الأَعْلَی ، عَن یُونُسَ ، عَنِ الْحَسَنِ أَنَّ عُمَرَ قَالَ : مَنْ یَعْلَمُ قَضِیَّۃَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی الْجَدِّ ، فَقَالَ : مَعْقِلُ بْنُ یَسَارٍ الْمُزَنِیّ فِینَا قَضَی بِہِ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : بمَاذَا ؟ قَالَ : السُّدُسُ ، قَالَ : مَعَ مَنْ ؟ قَالَ : لاَ أَدْرِی ، قَالَ : لاَ دَرَیْت فَمَاذَا تُغْنِی إِذًا۔\n\n(ابوداؤد 2889۔ ابن ماجہ 2723)",,,29697
29698,حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ لَیْثٍ ، عَن طَاوُوس ، أَنَّ امْرَأَتَیْنِ ضَرَّتَیْنِ رَمَتْ إِحْدَاہُمَا الأُخْرَی فَأَسْقَطَتْ جَنِینًا ، فَقَضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِیہِ عَبْدًا ، أَوْ أَمَۃً ، أَوْ فَرَسًا۔,,,29698
29699,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدِ بْنِ أَبِی عَرُوبَۃَ عَمَّنْ حَدَّثَہُ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ أَبِی الْحَسَنِ مَوْلًی لِبَنِی نَوْفَلٍ ، قَالَ : کُنْتُ أَنَا وَامْرَأَتِی مَمْلُوکَیْنِ فَطَلَّقْتُہَا ثِنْتَیْنِ ، ثُمَّ أُعْتِقْنَا بَعْدُ ، فَأَرَدْت مُرَاجَعَتَہَا ، فَانْطَلَقْت إِلَی ابْنِ عَبَّاسٍ فَسَأَلْتُہُ ، عَن مُرَاجَعَتِہَا فَقَالَ : إِنْ رَاجَعْتہَا فَہِیَ عِنْدَکَ عَلَی وَاحِدَۃٍ ، وَمَضَتِ اثْنَتَانِ ، قَضَی بِذَلِکَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,29699
29700,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ عَاصِمِ بْنِ کُلَیْبٍ ، عَنْ أَبِیہِ قَالَ : أَتَیْتُ عُمَرَ رضی اللہ ، عَنہ وَہُوَ بِالْمَوْسِمِ فنادیت مِنْ وَرَائِ الْفُسْطَاطِ : أَلا إِنِّی فُلانُ بْنُ فُلانٍ الْجَرْمِیُّ ، وَإِنَّ ابْنَ أُخْتٍ لَنَا عَانَ فِی بَنِی فُلانٍ وَقَدْ عَرَضْنَا عَلَیْہِ قَضِیَّۃَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فأبی ؟ قَالَ : فرفع عمر جانب الفسطاط ، فقال : تعرف صاحبک ؟ فقَالَ : نَعَمْ ، فقال : ہو ذاک ؛ انطلقا بہ حتی ینفذ لک قضیۃ رسول اللہ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : وَکُنَّا نَتَحَدَّثُ أَنَّ الْقَضِیَّۃَ کَانَتْ أَرْبَعًا مِنَ الإِبِلِ۔ (ابویعلی 164)",,,29700
29701,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَن مُجَالِدٍ ، عَنِ الشَّعْبِیِّ قَالَ : ضَرَبَتِ امْرَأَۃٌ امْرَأَۃً فَقَتَلَتْہَا وَأَلْقَتْ جَنِینًا مَیِّتًا، قَالَ : فَقَضَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِالدِّیَۃِ عَلَی عَاقِلَۃِ الْقَاتِلَۃِ ، وَلَمْ یَجْعَلْ عَلَی وَلَدِہَا ، وَلا عَلَی زَوْجِہَا شَیْئًا وَقَضَی بِالدِّیَۃِ لِزَوْجِ الْمَقْتُولَۃِ وَوَلَدِہَا ، وَلَمْ یَجْعَلْ لِعَصَبَتِہَا مِنْہَا شَیْئًا۔",,,29701
29702,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ أَبِی جَعْفَرٍ مُحَمَّدِ بْنِ عَلِیٍّ وَعَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، وَعَنْ أَبَانَ بْنِ صَالِحٍ ، عَن مُجَاہِدٍ قَالُوا : تَغَایَرَتِ امْرَأَتَانِ لِحَمْلِ بْنِ مَالِکِ بْنِ النَّابِغَۃِ ، فَحَمَلَتْ إِحْدَاہُمَا عَلَی الأُخْرَی بِعَمُودِ فُسْطَاطٍ فَضَرَبَتْہَا فَأَلْقَتْ مَا فِی بَطْنِہَا وَمَاتَتْ ، فَرُفِعَ ذَلِکَ إِلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقَضَی بِدِیَتِہَا عَلَی عَاقِلَۃِ الْقَاتِلَۃِ وَقَضَی فِی الْجَنِینِ بِغُرَّۃٍ عَبْدٍ ، أَوْ أَمَۃٍ فَقَالَ أَبُو الْقَاتِلَۃ ، أَوْ عَمُّہَا : أَنَدِی مَنْ لاَ أَکَلَ ، وَلا شَرِبَ ، وَلا صَاحَ ، ولا اسْتَہَلَّ ، وَمثل ذَلِکَ یُطَل ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنَّ ہَذَا یَقُولُ بِقَوْلِ شَاعِرٍ ، نَعَمْ ، فِیہِ غُرَّۃٌ : عَبْدٌ ، أَوْ أَمَۃٌ۔\n\n(بخاری 6740۔ مسلم 1309)",,,29702
29703,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَضَی بِشَاہِدٍ وَیَمِین المدعی ، فَقَالَ أَبُو جَعْفَرٍ : وَقَضَی بِہِ عَلِیٌّ فِیکُمْ۔",,,29703
29704,"حَدَّثَنَا وَکِیعٌ قَالَ: حدَّثَنَا سُفْیَانُ ، عَنْ إِسْمَاعِیلَ بْنِ أُمَیَّۃَ قَالَ : قَضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، فِی رَجُلٍ قَتَلَ رَجُلاً وَأَمْسَکَہُ آخَرَ : أَنْ یُقتل القَاتل ویُحبس الممسک۔",,,29704
29705,"حَدَّثَنَا وکیع ، قَالَ : حَدَّثَنَا ابن أبی ذئب ، عن الحکم بن مسلم السالمی ، عن عبد الرحمن بن ہرمز الأعرج قَالَ : قضی رَسُول اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أن لاَ تَجُوزُ شَہَادَۃُ الظِّنَّۃِ ، وَلا الْحِنَۃِ ولا الجِنَّۃ۔\n\n(عبدالرزاق 15366۔ حاکم 99)",,,29705
29706,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَن سِمَاکٍ ، عَن حَنَشِ بْنِ الْمُعْتَمِرِ قَالَ : حُفِرَت زُبْیَۃٌ بِالْیَمَنِ لِلأَسَدِ ، فَوَقَعَ فِیہَا الأَسَدُ ، فَأَصْبَحَ النَّاسُ یَتَدَافَعُونَ عَلَی رَأْسِ الْبِئْرِ ، فَوَقَعَ فِیہَا رَجُلٌ فَتَعَلَّقَ بِرَجُلٍ ، ثُمَّ تَعَلَّقَ الآخَرُ بِآخَرَ ، فَہَوَی فِیہَا أَرْبَعَۃٌ فَہَلَکُوا جَمِیعًا ، فَلَمْ یَدْرِ النَّاسُ کَیْفَ یَصْنَعُونَ ، فَجَائَ عَلِیٌّ رحمہ اللہ فَقَالَ : إِنْ شِئْتُمْ قَضَیْت بَیْنَکُمْ بِقَضَائٍ یَکُونُ حَاجِزًا بَیْنَکُمْ حَتَّی تَأْتُوا النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : فَإِنِّی أَجْعَلُ الدِّیَۃَ عَلَی مَنْ حَضَرَ رَأْسَ الْبِئْرِ ، فَجَعَلَ لِلأَوَّلِ الَّذِی ہُوَ فِی الْبِئْرِ رُبْعَ الدِّیَۃِ ، وَلِلثَّانِی ثُلُثَ الدِّیَۃِ ، وَلِلثَّالِثِ نِصْفَ الدِّیَۃِ ، وَلِلرَّابِعِ الدِّیَۃَ کَامِلَۃً ، قَالَ : فَتَرَاضَوْا عَلَی ذَلِکَ حَتَّی أَتَوُا النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَأَخْبَرُوہُ بِقَضَائِ عَلِیٍّ فَأَجَازَ الْقَضَائَ۔",,,29706
29707,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَن زَائِدَۃَ ، عَن سِمَاکٍ ، عَن حَنَشٍ ، عَنْ عَلِیٍّ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِذَا تَقَاضَی إِلَیْک رَجُلانِ فَلا تَقْضِ لِلأَوَّلِ حَتَّی تَسْمَعَ مَا یَقُولُ الآخَرُ ، فَإِنَّک سَوْفَ تَرَی کَیْفَ تَقْضِی ، قَالَ عَلِیٌّ : فَمَا زِلْت بَعْدَہَا قَاضِیًا۔",,,29707
29708,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ أَبِی الْبَخْتَرِیِّ ، عَنْ عَلِیٍّ قَالَ : بَعَثَنِی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إِلَی أَہْلِ الْیَمَنِ لأَقْضِیَ بَیْنَہُمْ ، قُلْتُ : یَا رَسُولَ اللہِ : إِنَّہ لاَ عِلْمَ لِی بِالْقَضَائِ ، فَضَرَبَ بِیَدِہِ عَلَی صَدْرِی ، وَقَالَ : اللَّہُمَّ اہْدِ قَلْبَہُ وَسَدِّدْ لِسَانَہُ ، قَالَ : فَمَا شَکَکْت فِی قَضَائٍ بَیْنَ اثْنَیْنِ حَتَّی جَلَسْت مَجْلِسِی ہَذَا۔ (احمد 88۔ حاکم 88)",,,29708
29709,"حَدَّثَنَا یَحْیَی بْنُ یَعْلَی التَّیْمِیُّ ، عَن مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَن عُبَیْدِ بْنِ نُضَیْلۃ ، عَنِ الْمُغِیرَۃِ بْنِ شُعْبَۃَ قَالَ : شَہِدْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَضَی فِیہِ بِغُرَّۃٍ عَبْدٍ ، أَوْ أَمَۃٍ ، فَقَالَ عمر : لِتَجِیئَ بِمَنْ یَشْہَدُ مَعَک ، فَشَہِدَ لَہُ مُحَمَّدُ بْنُ مَسْلَمَۃَ۔",,,29709
29710,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی عَوْنٍ ، عَنِ الْحَارِثِ بْنِ عَمْرٍو الْہُذَلِیِّ ، عَنْ رَجُلٍ مِنْ أَہْلِ حِمْصَ مِنْ أَصْحَابِ مُعَاذٍ ، عَن مُعَاذٍ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لَمَّا بَعَثَہُ قَالَ : کَیْفَ تَقْضِی ، قَالَ : أَقْضِی بِکِتَابِ اللہِ ، قَالَ : فَإِنْ لَمْ یَکُنْ فی کِتَابِ اللہ ؟ قَالَ : أَقْضِی بِسُنَّۃِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : فَإِنْ لَمْ تَکُنْ سُنَّۃٌ مِنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ قَالَ : أَجْتَہِدُ بِرَأْیِی ، قَالَ : فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْحَمْدُ لِلَّہِ الَّذِی وَفَّقَ رَسُولَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,29710
29711,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَن زَائِدٍ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، عَنِ الْحَکَمِ ، عَنْ عَبْدِ اللہِ بْنِ شَدَّادٍ ، عَنِ ابْنَۃِ حَمْزَۃَ ، قَالَ مُحَمَّدٌ : وَہِیَ أُخْتُ ابْنِ شَدَّادٍ لأُِمِّہِ ، قَالَتْ : مَاتَ مَوْلی لی وَتَرَکَ ابْنَتَہُ، فَقَسَمَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَالَہُ بَیْنِی وَبَیْنَ ابْنَتِہِ ، فَجَعَلَ لِی النِّصْفَ وَلَہَا النِّصْفَ۔\n\n(ابن ماجہ 2734۔ طبرانی 874)",,,29711
29712,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ إِسْرَائِیلَ ، عَن سِمَاکٍ ، عَن عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : قضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی الرِّکَازِ الْخُمُسَ۔",,,29712
29713,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ قَالَ : قضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِالْعَقْلِ عَلَی الْعَصَبَۃِ ، وَالدِّیَۃُ مِیرَاثٌ۔ (عبدالرزاق 17768)",,,29713
29714,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ رُفَیْعٍ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، قَالَ : قضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِالشُّفْعَۃِ فِی کُلِّ شَیْئٍ : الأَرْضِ ، وَالدَّارِ ، وَالْجَارِیَۃِ ، وَالدَّابَّۃِ ، فَقَالَ عَطَائٌ : إِنَّمَا الشُّفْعَۃُ فِی الأَرْضِ وَالدَّارِ ، فَقَالَ لَہُ ابْنُ أَبِی مُلَیْکَۃَ : تَسْمَعنی لاَ أُمَّ لَکَ أَقُولُ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَتَقُولُ ہَذَا ؟!!۔",,,29714
29715,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، حدَّثَنَا ابْنُ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَن سُلَیْمَانَ بْنِ یَسَارٍ ، وَقَالَ : الْقَسَامَۃُ حَقٌّ قَضَی بِہَا النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَیْنَمَا الأَنْصَارُ عِنْدَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إِذْ خَرَجَ رَجُلٌ مِنْہُمْ ، ثُمَّ خَرَجُوا مِنْ عِنْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَإِذَا ہُمْ بِصَاحِبِہِمْ یَتَشَحَّطُ فِی دَمِہِ ، فَرَجَعُوا إِلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقَالُوا : قَتَلَتْنَا یَہُود ، وَسَمُّوا رَجُلاً مِنْہُمْ ، وَلَمْ تَکُنْ لَہُمْ بَیِّنَۃٌ، فَقَالَ لَہُمْ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : شَاہِدَانِ مِنْ غَیْرِکُمْ حَتَّی أَدْفَعَہُ إِلَیْکُمْ بِرُمَّتِہِ ، فَلَمْ تَکُنْ لَہُمْ بَیِّنَۃٌ فَقَالَ : اسْتَحَقُّوا بخمسین قَسَامَۃً أَدْفَعُہُ إِلَیْکُمْ بِرُمَّتِہِ ، فقَالُوا : إِنَّا نَکْرَہُ أَنْ نَحْلِفَ عَلَی غَیْبٍ ، فَأَرَادَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یَأْخُذَ قَسَامَۃَ الْیَہُودِ بِخَمْسِینَ مِنْہُمْ ، فَقَالَتِ الأَنْصَارُ : یَا رَسُولَ اللہِ ، إِنَّ الْیَہُودَ لاَ یُبَالُونَ الْحَلِفَ ، مَتَی نَقْبَلُ ہَذَا مِنْہُمْ یَأْتُونَا عَلَی آخِرِنَا ، فَوَدَاہُ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِنْ عَندِہِ۔",,,29715
29716,"حَدَّثَنَا إِسْمَاعِیلُ بْنُ عُلَیَّۃَ ، عَن دَاوُد ، عَنِ الشَّعْبِیِّ قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقْضِی بِالْقَضَائَ ، ثُمَّ یَنْزِلُ الْقُرْآنُ بِغَیْرِ الَّذِی قَضَی بِہِ فَلا یَرُدُّہُ ، وَیَسْتَأْنِفُ۔",,,29716
29717,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ النَّجْرَانِیِّ قَالَ : قُلْتُ لِعَبْدِ اللہِ بْنِ عمَرَ : أُسْلِمُ فِی نَخْلٍ قَبْلَ أَنْ یُطْلِعَ ، قَالَ : لاَ ، قُلْتُ : لِمَ ؟ قَالَ : إِنَّ رَجُلاً أَسْلَمَ فِی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی حَدِیقَۃِ نَخْلٍ قَبْلَ أَنْ تُطْلِعَ ، فَلَمْ تُطْلِعْ شَیْئًا ذَلِکَ الْعَامَ ، فَقَالَ الْمُشْتَرِی : ہُوَ لِی حَتَّی تُطْلِعَ ، وَقَالَ الْبَائِعُ : إِنَّمَا بِعْتُک النَّخْلَ ہَذِہِ السَّنَۃَ، فَاخْتَصَمَا إِلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لِلْبَائِعِ : أَجَدَّ مِنْ نَخْلِکَ شَیْئًا ؟ قَالَ : لاَ ، قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : فَبِمَ تَسْتَحِلُّ مَالَہُ ؟ ارْدُدْ عَلَیْہِ مَا أَخَذْت مِنْہُ ، وَلا تُسْلِمُوا فِی نَخْلٍ حَتَّی یَبْدُوَ صَلاحُہُ۔ (ابوداؤد 3461۔ احمد 15)",,,29717
29718,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی قَالَ : أَخْبَرَنَا إِسْرَائِیلُ ، عَنْ عَبْدِ اللہِ بْنِ الْمُخْتَارِ ، عَنِ الْحَسَنِ قَالَ : قَضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی رَجُلٍ عَضَّ یَدَ رَجُلٍ فَنَزَعَ الرَّجُلُ یَدَہُ مِنْ فِیہِ فَانْتَزَعَتْ ثَنِیَّتَہُ ، فَانْطَلَقَ الرَّجُلُ إِلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنَّہُ لَمْ یَدَعْک تَأْکُلُ یَدَہُ ، فَلَمْ یَقْضِ لَہُ مِنَ الدِّیَۃِ شَیْئًا۔",,,29718
29719,"حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ ، حدَّثَنَا ابْنُ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، عَنِ الْمُغِیرَۃِ بْنِ شُعْبَۃَ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَضَی فِی الْمَرْأَۃِ تُقْتَلُ : یَرِثُہَا وَلَدُہَا وَالْعَقْلُ عَلَی عَصَبَتِہَا۔",,,29719
29720,"حَدَّثَنَا شَبَابَۃُ ، حدَّثَنَا ابْنُ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : قَضَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَرِثُ قَاتِلُ مَنْ قَتَلَ وَلِیَّہُ شَیْئًا مِنَ الدِّیَۃ عَمْدًا ، أَوْ خَطَأً۔ (ابوداؤد 360۔ بیہقی 219)",,,29720
29721,حَدَّثَنَا شَبَابَۃُ ، حَدَّثَنَا ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَضَی فِی الْقَسَامَۃِ أَنَّ الْیَمِینَ عَلَی الْمُدَّعَی عَلَیْہِ۔,,,29721
29722,"حَدَّثَنَا شَبَابَۃُ ، حدَّثَنَا ابْنُ أَبِی ذِئْبٍ ، عَنْ أَبِی جَابِرٍ الْبَیَاضِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ قَالَ : قَضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی الرَّجُلِ یُغَیِّرُ شَہَادَتَہُ ، قَالَ : یُؤْخَذُ بِالأُولَی۔ (عبدالرزاق 15508)",,,29722
29723,"حَدَّثَنَا عَبْدَۃُ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إِبْرَاہِیمَ ؛ فِی الرَّجُلِ یُقِرُّ بِالْوَلَدِ ، ثُمَّ یَنْتَفِی مِنْہُ ، قَالَ : یُلاعن بِکِتَابِ اللہِ ، وَیُلْزَمُ الْوَلَدَ بِقَضَائِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,29723
29724,"حَدَّثَنَا عَفَّانُ ، حدَّثَنَا ہَمَّامٌ ، َدَّثَنَا قَتَادَۃُ ، عَن عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إِنَّ زَوْجَ بَرِیرَۃَ کَانَ عَبْدًا أَسْوَدَ یُسَمَّی مُغِیثًا ، فَقَضَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِیہَا أَرْبَعَ قَضِیَّاتٍ ، قَضَی أَنَّ مَوَالِیَہَا اشْتَرَطُوا الْوَلائَ ، فَقَضَی أَنَّ الْوَلائَ لِمَنْ أَعْطَی الثَّمَنَ ، وَخَیَّرَہَا ، وَأَمَرَہَا أَنْ تَعْتَدَّ ، وَتُصُدِّقَ عَلَیْہَا بِصَدَقَۃٍ ، فَأَہْدَتْ مِنْہا إِلَی عَائِشَۃَ فَذَکَرَتْ ذَلِکَ لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقَالَ : ہُوَ لَہَا صَدَقَۃٌ وَلَنَا ہَدِیَّۃٌ۔\n\n(بخاری 5280۔ ابوداؤد 2225)",,,29724
29725,"حَدَّثَنَا شَبَابَۃُ ، حدَّثَنَا لَیْثُ بْنُ سَعْدٍ ، عَنِ ابْنِ شِہَابٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ أَبِی ہُرَیْرَۃَ قَالَ : قَضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی جَنِینِ امْرَأَۃٍ مِنْ بَنِی لَحْیَانَ سَقَطَ مَیِّتًا بِغُرَّۃٍ عَبْدٍ ، أَوْ أَمَۃٍ ، ثُمَّ إِنَّ الْمَرْأَۃَ الَّتِی قَضَی عَلَیْہَا بِالْغُرَّۃِ تُوُفِّیَتْ ، فَقَضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنَّ مِیرَاثَہَا لِزَوْجِہَا وَبَنِیہَا ، وَأَنَّ الْعَقْلَ عَلَی عَصَبَتِہَا۔ (بخاری 6740۔ مسلم 1309)",,,29725
29726,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، حَدَّثَنَا الثَّوْرِیِّ ، عَن حُمَیْدٍ الأَعْرَجِ ، عَن طَارِقٍ الْمَکِّیِّ ، عَنْ جَابِرٍ قَالَ : قضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی امْرَأَۃٍ مِنَ الأَنْصَارِ أَعْطَاہَا ابْنُہَا حَدِیقَۃً مِنْ نَخْلٍ فَمَاتَتْ ، فَقَالَ ابْنُہَا : إِنَّمَا أَعْطَیْتہَا حَیَاتَہَا ، وَلَہُ إِخْوَۃٌ ، فَقَالَ لَہُ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : ہِیَ لَہَا حَیَاتَہَا وَمَوْتَہَا ، قَالَ : فإِنی کُنْتُ تَصَدَّقْتُ بِہَا عَلَیْہَا ، قَالَ : فَذَاکَ أَبْعَدُ لَک۔ (ابوداؤد 3552۔ بیہقی 174)",,,29726
29727,"حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، أو ابْنِ أَبِی مُلَیْکَۃَ وَعَمْرِو بْنِ دِینَارٍ قَالا : مَا زِلْنَا نَسْمَعُ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَضَی فِی الْعَبْدِ الآبِقِ یُؤخَدُ خَارِجًا مِنَ الْحَرَمِ دِینَارًا وَعَشَرَۃَ دَرَاہِمَ۔",,,29727
29728,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لَمَّا قَضَی بالْوَلَدَ لابْنِ زَمْعَۃَ قَالَ : یا سَوْدَۃ : احْتَجِبِی مِنْہُ ، وَقَالَ : إِنِّی لَوْ لَمْ أَفْعَلْ ہَذَا لَمْ یَشَأْ رَجُلٌ أَنْ یَدَّعِیَ وَلَدَ رَجُلٍ إِلاَّ ادَّعَاہُ۔\n\n(بخاری 2053۔ مسلم 1080)",,,29728
29729,حَدَّثَنَا عَفَّانُ ، حدَّثَنَا ہَمَّامٌ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ أَبِی بُرْدَۃَ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ أَنَّ رَجُلَیْنِ ادَّعَیَا بَعِیرًا ، فَبَعَثَ کُلٌّ مِنْہُمَا بِشَاہِدَیْنِ ، فَقَضَی فِیہِ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَیْنَہُمَا۔,,,29729
29730,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ قَالَ : أَخْبَرَنَا جُوَیْرِیَۃُ بْنُ أَسْمَائَ ، عَنْ عَبْدِ اللہِ بْنِ یَزِیدَ مَوْلَی الْمُنْبَعِثِ ، عَنْ رَجُلٍ ، عَن سُرَّقٍ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَضَی بِشَاہِدٍ وَیَمِینٍ۔",,,29730
