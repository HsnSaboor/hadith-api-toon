{"hadithnumber": "5640", "text": "ہم سے ابوالیمان حکم بن نافع نے بیان کیا، انہوں نے کہا ہم کو شعیب نے خبر دی، ان سے زہری نے بیان کیا،"}
{"hadithnumber": "5642", "text": "ہم سے عبداللہ بن محمد نے بیان کیا، انہوں نے کہا ہم سے عبدالملک بن عمرو نے بیان کیا، انہوں نے کہا ہم"}
{"hadithnumber": "5643", "text": "ہم سے مسدد نے بیان کیا، کہا ہم سے یحییٰ نے بیان کیا، ان سے سفیان نے، ان سے سعد نے، ان سے عبداللہ بن"}
{"hadithnumber": "5644", "text": "ہم سے ابراہیم بن المنذر نے بیان کیا، کہا کہ مجھ سے محمد بن فلیح نے بیان کیا، کہا کہ مجھ سے میرے والد"}
{"hadithnumber": "5645", "text": "ہم سے عبداللہ بن یوسف نے بیان کیا، کہا ہم کو امام مالک نے خبر دی، انہیں محمد بن عبداللہ بن عبدالرحمٰ"}
{"hadithnumber": "5646", "text": "ہم سے قبیصہ نے بیان کیا، انہوں نے کہا ہم سے سفیان سے بیان کیا، ان سے اعمش نے (دوسری سند) اور امام بخ"}
{"hadithnumber": "5647", "text": "ہم سے محمد بن یوسف نے بیان کیا، کہا ہم سے سفیان ثوری نے بیان کیا، ان سے اعمش نے، ان سے ابراہیم تیمی"}
{"hadithnumber": "5648", "text": "ہم سے عبدان نے بیان کیا، ان سے ابوحمزہ نے بیان کیا، ان سے اعمش نے، ان سے ابراہیم تیمی نے، ان سے حارث"}
{"hadithnumber": "5649", "text": "ہم سے قتیبہ بن سعید نے بیان کیا، کہا ہم سے ابوعوانہ نے بیان کیا، ان سے منصور نے، ان سے ابووائل نے او"}
{"hadithnumber": "5650", "text": "ہم سے حفص بن عمر نے بیان کیا، کہا ہم سے شعبہ نے بیان کیا، کہا کہ مجھے اشعث بن سلیم نے خبر دی، کہا کہ"}
{"hadithnumber": "5651", "text": "ہم سے عبداللہ بن محمد نے بیان کیا، کہا ہم سے سفیان نے بیان کیا، ان سے ابن المنکدر نے، انہوں نے جابر"}
{"hadithnumber": "5652", "text": "ہم سے مسدد نے بیان کیا، کہا ہم سے یحییٰ بن ابی کثیر نے بیان کیا، ان سے عمران ابوبکر نے بیان کیا، ان"}
{"hadithnumber": "5653", "text": "ہم سے عبداللہ بن یوسف تینسی نے بیان کیا، کہا ہم سے لیث بن سعد نے بیان کیا، کہا کہ مجھ سے یزید بن عبد"}
{"hadithnumber": "5654", "text": "ہم سے قتیبہ نے بیان کیا، ان سے امام مالک نے، ان سے ہشام بن عروہ نے، ان سے ان کے والد نے اور ان سے عا"}
{"hadithnumber": "5655", "text": "ہم سے حجاج بن منہال نے بیان کیا، کہا ہم سے شعبہ نے بیان کیا، کہا کہ مجھے عاصم نے خبر دی، کہا کہ میں"}
{"hadithnumber": "5656", "text": "ہم سے معلی بن اسد نے بیان کیا، کہا ہم سے عبدالعزیز بن مختار نے بیان کیا، کہا ہم سے خالد نے بیان کیا،"}
{"hadithnumber": "5657", "text": "ہم سے سلیمان بن حرب نے بیان کیا، کہا ہم سے حماد بن زید نے بیان کیا، ان سے ثابت نے اور ان سے انس رضی"}
{"hadithnumber": "5658", "text": "ہم سے محمد بن مثنیٰ نے بیان کیا، کہا ہم سے یحییٰ بن ابی کثیر نے بیان کیا، کہا ہم سے ہشام بن عروہ نے"}
{"hadithnumber": "5659", "text": "ہم سے مکی بن ابراہیم نے بیان کیا، کہا ہم کو جعید بن عبدالرحمٰن نے خبر دی، انہیں عائشہ بنت سعد نے کہ"}
{"hadithnumber": "5660", "text": "ہم سے قتیبہ نے بیان کیا، انہوں نے کہا ہم سے جریر نے بیان کیا، ان سے اعمش نے بیان کیا، ان سے ابراہیم"}
{"hadithnumber": "5661", "text": "ہم سے قبیصہ نے بیان کیا، انہوں نے کہا ہم سے سفیان ثوری نے بیان کیا، ان سے اعمش نے بیان کیا، ان سے اب"}
{"hadithnumber": "5662", "text": "ہم سے اسحاق بن شاہین واسطی نے بیان کیا، کہا ہم سے خالد بن عبداللہ نے بیان کیا، ان سے خالد حذاء نے، ا"}
{"hadithnumber": "5663", "text": "ہم سے یحییٰ بن بکیر نے بیان کیا، کہا ہم سے لیث نے بیان کیا، ان سے عقیل نے، ان سے ابن شہاب نے، ان سے"}
{"hadithnumber": "5664", "text": "ہم سے عمرو بن عباس نے بیان کیا، کہا ہم سے عبدالرحمٰن نے بیان کیا، کہا ہم سے سفیان نے بیان کیا، ان سے"}
{"hadithnumber": "5665", "text": "ہم سے قبیصہ نے بیان کیا، کہا ہم سے سفیان نے بیان کیا، ان سے ابن ابی نجیح اور ایوب نے، ان سے مجاہد نے"}
{"hadithnumber": "5666", "text": "ہم سے یحییٰ بن یحییٰ ابوزکریا نے بیان کیا، کہا ہم کو سلیمان بن بلال نے خبر دی، ان سے یحییٰ بن سعید ن"}
{"hadithnumber": "5667", "text": "ہم سے موسیٰ بن اسماعیل نے بیان کیا، کہا ہم سے عبدالعزیز بن مسلم نے بیان کیا، کہا ہم سے سلیمان اعمش ن"}
{"hadithnumber": "5668", "text": "ہم سے موسیٰ بن اسماعیل نے بیان کیا، کہا ہم سے عبدالعزیز بن عبداللہ بن ابی سلمہ نے بیان کیا، کہا ہم ک"}
{"hadithnumber": "5669", "text": "ہم سے ابراہیم بن موسیٰ نے بیان کیا، کہا ہم سے ہشام بن عروہ نے بیان کیا، ان سے معمر نے (دوسری سند) او"}
{"hadithnumber": "5670", "text": "ہم سے ابراہیم بن حمزہ نے بیان کیا، کہا ہم سے حاتم بن اسماعیل نے بیان کیا، ان سے جعید بن عبدالرحمٰن ن"}
{"hadithnumber": "5671", "text": "ہم سے آدم بن ابی ایاس نے بیان کیا، کہا ہم سے شعبہ نے بیان کیا، کہا ہم سے ثابت بنانی نے بیان کیا اور"}
{"hadithnumber": "5672", "text": "ہم سے آدم بن ابی ایاس نے بیان کیا، کہا ہم سے شعبہ نے، ان سے اسماعیل بن ابی خالد نے اور ان سے قیس بن"}
{"hadithnumber": "5673", "text": "ہم سے ابوالیمان نے بیان کیا، کہا ہم کو شعیب نے خبر دی، ان سے زہری نے بیان کیا، کہا ہمیں عبدالرحمٰن ب"}
{"hadithnumber": "5674", "text": "ہم سے عبداللہ بن ابی شیبہ نے بیان کیا، کہا ہم سے ابواسامہ نے بیان کیا، ان سے ہشام نے، ان سے عباد بن"}
{"hadithnumber": "5675", "text": "ہم سے موسیٰ بن اسماعیل نے بیان کیا، کہا ہم سے ابوعوانہ نے بیان کیا، ان سے منصور نے، ان سے ابراہیم نے"}
{"hadithnumber": "5676", "text": "ہم سے محمد بن بشار نے بیان کیا، کہا ہم سے غندر (محمد بن جعفر) نے بیان کیا، کہا ہم سے شعبہ نے بیان کی"}
{"hadithnumber": "5677", "text": "ہم سے اسماعیل نے بیان کیا، کہا مجھ سے امام مالک نے، ان سے ہشام بن عروہ نے، ان سے ان کے والد نے اور ا"}
