hadiths[210]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
6500,"قتیبہ بن سعید بن جمیل بن طریف ثقفی اور زہیر بن حرب نے کہا :  ہمیں جریر نے عمارہ بن قعقاع سے حدیث بیا",,,,,6500
6501,فضیل نے عمارہ بن قعقاع سے ،  انہوں نے ابوزرعہ سے ،  انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ,,,,,6501
6502,شریک نے عمارہ اور ابن شبرمہ سے حدیث بیان کی ،  انہوں نے ابوزرعہ سے ،  انہوں نے حضرت ابوہریرہ رضی الل,,,,,6502
6503,"محمد بن طلحہ اور وہیب دونوں نے ابن شبرمہ سے اسی سند کے ساتھ حدیث بیان کی ۔ \n\nوہیب کی حدیث میں ہے :  ",,,,,6503
6504,"وکیع نے سفیان سے اور یحییٰ بن سعید قطان نے سفیان اور شعبہ دونوں سے روایت کی ،  دونوں نے کہا :  ہمیں ",,,,,6504
6507,حضرت عبداللہ بن عمرو رضی اللہ عنہ نے بیان کیا کہ ایک شخص نے نبی صلی اللہ علیہ وسلم کی خدمت میں حاضر ,,,,,6507
6508,"سلیمان بن مغیرہ نے کہا :  ہمیں حمید بن ہلال نے ابورافع سے حدیث بیان کی ،  انہوں نے حضرت ابوہریرہ رضی",,,,,6508
6509,محمد بن سیرین نے حضرت ابوہریرہ رضی اللہ عنہ سے ،  انہوں نے نبی صلی اللہ علیہ وسلم سے روایت کی ،  آپ ,,,,,6509
6510,ابو عوانہ نے سہیل سے ،  انہوں نے اپنے والد  ( ابوصالح )  سے ،  انہوں نے حضرت ابوہریرہ رضی اللہ عنہ س,,,,,6510
6511,جریر نے سہیل سے ،  انہوں نے اپنے والد  ( ابوصالح )  سے ،  انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے روا,,,,,6511
6512,"سلیمان بن بلال نے کہا :  مجھے سہیل نے اپنے والد  ( ابوصالح )  سے حدیث بیان کی ،  انہوں نے حضرت ابوہر",,,,,6512
6513,ولید بن ولید نے عبداللہ بن دینار سے ،  انہوں نے حضرت عبداللہ بن عمر رضی اللہ عنہ سے روایت کی کہ ان ک,,,,,6513
6514,حیوہ بن شریح نے ابن ہاد سے ،  انہوں نے عبداللہ بن دینار سے ،  انہوں نے حضرت عبداللہ بن عمر رضی اللہ ,,,,,6514
6515,ابراہیم بن سعد اور لیث بن سعد دونوں نے یزید بن عبداللہ بن اسامہ بن ہاد سے حدیث بیان کی ،  انہوں نے ع,,,,,6515
6516,ابن مہدی نے ہمیں معاویہ بن صالح سے حدیث بیان کی ،  انہوں نے عبدالرحمٰن بن جبیر بن نفیر سے ،  انہوں ن,,,,,6516
6517,"عبداللہ بن وہب نے کہا :  مجھے معاویہ بن صالح نے  ( باقی ماندہ سابقہ سند کے ساتھ )  حضرت نواس بن سمعا",,,,,6517
6518,"حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   """" اللہ ",,,,,6518
6519,"حضرت عائشہ رضی اللہ عنہ سے روایت ہے ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   "" رَحم  ( خ",,,,,6519
6520,"زہیر بن حرب اور ابن ابی عمر نے کہا :  ہمیں سفیان نے زہری سے حدیث بیان کی ،  انہوں نے محمد بن جبیر بن",,,,,6520
6521,امام مالک نے زہری سے روایت کی ،  محمد بن جبیر بن معطم نے خبر دی کہ ان کے والد نے انہیں بتایا کہ رسول,,,,,6521
6522,"معمر نے زہری سے اسی سند کے ساتھ اسی کے مانند روایت کی اور  ( اس میں ہے :  حضرت جبیر بن معطم رضی اللہ",,,,,6522
6523,"یونس نے ابن شہاب سے ،  انہوں نے حضرت انس بن مالک رضی اللہ عنہ سے روایت کی ،  کہا :  رسول اللہ صلی ال",,,,,6523
6524,"عقیل بن خالد نے کہا :  ابن شہاب نے کہا :  مجھے حضرت انس بن مالک رضی اللہ عنہ نے خبر دی کہ رسول اللہ ",,,,,6524
6525,"حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ ایک شخص نے عرض کی :  اللہ کے رسول! میرے  ( بعض )  رشتہ دار",,,,,6525
6526,امام مالک نے ابن شہاب سے ،  انہوں نے حضرت انس بن مالک رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ,,,,,6526
6530,"ابوداؤد نے کہا :  ہمیں شعبہ نے قتادہ سے حدیث بیان کی ،  انہوں نے حضرت انس رضی اللہ عنہ سے روایت کی ک",,,,,6530
6531,")   وہب بن جریر نے کہا :  ہمیں شعبہ نے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی اور مزید یہ کہا :  ",,,,,6531
6532,امام مالک نے ابن شہاب سے ،  انہوں نے عطاء بن یزید لیثی سے ،  انہوں نے حضرت ابو ایوب انصاری رضی اللہ ,,,,,6532
6533,سفیان ،  یونس ،   ( محمد بن ولید )  زبیدی اور معمر سب نے زہری سے مالک کی سند کے ساتھ ،  اس قول کے سو,,,,,6533
6534,"حضرت عبداللہ بن عمر رضی اللہ عنہ سے روایت ہے کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   "" مومن کے",,,,,6534
6535,"حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   "" تین دن کے بعد",,,,,6535
6536,"اعرج نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   "" بدگما",,,,,6536
6537,علاء کے والد  ( عبدالرحمٰن )  نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ علیہ و,,,,,6537
6538,"جریر نے اعمش سے ،  انہوں نے ابوصالح سے ،  انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  کہا :  ",,,,,6538
6539,"شعبہ نے ہمیں اعمش سے اسی سند کے ساتھ روایت کی :   "" ایک دوسرے سے قطع رحمی نہ کرو ،  ایک دوسرے سے روگ",,,,,6539
6540,)   سہیل نے اپنے والد  ( ابوصالح )  سے ،  انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے اور انہوں نے نبی صل,,,,,6540
6541,داؤد بن قیس نے ہمیں عامر بن کریز کے آزاد کردہ غلام ابوسعید سے ،  انہوں نے حضرت ابوہریرہ رضی اللہ عنہ,,,,,6541
6542,اسامہ بن زید سے روایت ہے کہ انہوں نے عبداللہ بن عامر بن کریز کے آزاد کردہ غلام ابوسعید کو یہ کہتے ہو,,,,,6542
6543,"یزید بن اصم نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرما",,,,,6543
6546,سفیان نے مسلم بن ابی مریم سے ،  انہوں نے ابوصالح سے روایت کی ،  انہوں نے حضرت ابوہریرہ رضی اللہ عنہ ,,,,,6546
6547,امام مالک بن انس نے مسلم بن ابی مریم سے ،  انہوں نے ابوصالح سے ،  انہوں نے حضرت ابوہریرہ رضی اللہ عن,,,,,6547
6548,"حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   "" اللہ ت",,,,,6548
6549,"عبدالاعلیٰ بن حماد نے کہا :  ہمیں حماد بن سلمہ نے ثابت سے حدیث بیان کی ،  انہوں نے ابورافع سے ،  انہ",,,,,6549
6550,"ابوبکر بن محمد بن زنجویہ قشیری نے کہا :  ہمیں عبدالاعلیٰ بن حماد نرسی نے حماد بن سلمہ سے اسی سند کے ",,,,,6550
6551,"سعید بن منصور اور ابوربیع زہرانی سے کہا :  ہمیں حماد بن زید نے ایوب سے حدیث بیان کی ،  انہوں نے ابوق",,,,,6551
6552,ہشیم نے ہمیں خالد سے خبر دی ،  انہوں نے ابوقلابہ سے ،  انہوں نے ابواسماء سے ،  انہوں نے رسول اللہ صل,,,,,6552
6553,"یزید بن زُرَیع نے کہا :  ہمیں خالد نے ابوقلابہ سے ،  انہوں نے ابو اسماء رحبی سے ،  انہوں نے حضرت ثوب",,,,,6553
6554,"یزید بن ہارون نے کہا :  ہمیں عاصم احول نے ابوقلابہ عبداللہ بن زید سے خبر سنائی ،  انہوں نے ابو اشعث ",,,,,6554
6555,مروان بن معاویہ نے عاصم احول سے اسی سند کے ساتھ حدیث بیان کی ۔,,,,,6555
6556,"حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   "" قیامت ",,,,,6556
6557,"عثمان بن ابی شیبہ اور اسحٰق بن ابراہیم نے کہا :  ہمیں جریر نے اعمش سے حدیث بیان کی ،  انہوں نے ابووا",,,,,6557
6558,شعبہ اور سفیان دونوں نے اعمش سے جریر کی سند کے ساتھ اسی کی حدیث کے مانند روایت کی ۔,,,,,6558
6559,عثمان بن ابی شیبہ ،  زہیر بن حرب اور اسحٰق بن ابراہیم نے کہا؛ ہمیں جریر نے اعمش سے حدیث بیان کی ،  ا,,,,,6559
6560,ابومعاویہ ،  سفیان ،  عیسیٰ بن یونس اور یحییٰ بن عبدالملک بن ابی غنیہ سب نے اعمش سے جریر کی سند کے س,,,,,6560
6561,"منصور نے ابراہیم سے ،  انہوں نے اسود  ( بن یزید نخعی )  سے روایت کی ،  انہوں نے کہا :  کچھ قریشی نوج",,,,,6561
6562,اعمش نے ابراہیم سے ،  انہوں نے اسود سے ،  انہوں نے حضرت عائشہ رضی اللہ عنہا سے روایت کی ،  انہوں نے ,,,,,6562
6563,"محمد بن بشر نے کہا :  ہمیں ہشام نے اپنے والد  ( عروہ )  سے حدیث بیان کی ،  انہوں نے حضرت عائشہ رضی ا",,,,,6563
6564,ابو معاویہ نے ہمیں ہشام سے اسی سند کے ساتھ حدیث بیان کی ۔,,,,,6564
6565,ابن شہاب نے عروہ بن زبیر سے ،  انہوں نے حضرت عائشہ رضی اللہ عنہا سے روایت کی کہ رسول اللہ صلی اللہ ع,,,,,6565
6566,امام مالک بن انس نے یزید بن خُصَیفہ سے ،  انہوں نے عروہ بن زبیر سے ،  انہوں نے نبی صلی اللہ علیہ وسل,,,,,6566
6567,"عمرہ نے حضرت عائشہ رضی اللہ عنہا سے روایت کی ،  انہوں نے کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرما",,,,,6567
6568,عطاء بن یسار نے حضرت ابوسعید اور حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  دونوں نے رسول اللہ صلی ال,,,,,6568
6569,سفیان نے قریش کے ایک بزرگ ابن محیصن سے روایت کی ،  انہوں نے محمد بن قیس بن مخرمہ کو حضرت ابوہریرہ رض,,,,,6569
6570,"ابوزبیر نے کہا :  ہمیں حضرت جابر بن عبداللہ رضی اللہ عنہ نے حدیث بیان کی کہ رسول اللہ صلی اللہ علیہ ",,,,,6570
6571,"عطاء بن ابی رباح نے حدیث بیان کی ،  کہا :  ایک دن حضرت ابن عباس رضی اللہ عنہ نے مجھ سے کہا :  کیا می",,,,,6571
6572,مروان بن محمد دمشقی نے کہا؛ ہمیں سعید بن عبدالعزیز نے ربیعہ بن یزید سے حدیث بیان کی ،  انہوں نے ابو ,,,,,6572
6573,"ابوبکر بن اسحٰق نے کہا :  ہمیں ابومسہر نے حدیث بیان کی ،  انہوں نے کہا :  ہمیں سعید بن عبدالعزیز نے ",,,,,6573
6574,"ابواسحٰق نے کہا :  ہمیں یہ حدیث بشر کے دو بیٹوں حسن اور حسین نے اور محمد بن یحییٰ نے بیان کی ،  انہو",,,,,6574
6575,"ابواسماء نے حضرت ابوذر رضی اللہ عنہ سے روایت کی ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :  ",,,,,6575
6576,"حضرت جابر بن عبداللہ رضی اللہ عنہ سے روایت ہے کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   "" ظلم سے",,,,,6576
6577,"عبداللہ بن دینار نے حضرت ابن عمر رضی اللہ عنہ سے روایت کی ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم نے ",,,,,6577
6578,"سالم نے اپنے والد سے روایت کی ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   "" مسلمان دوسرے مس",,,,,6578
6579,"حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   "" کیا تم جانتے ",,,,,6579
6580,"حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   "" قیامت کے دن ت",,,,,6580
6581,"حضرت ابوموسیٰ رضی اللہ عنہ سے روایت ہے ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   "" اللہ ت",,,,,6581
6582,"ابوزبیر نے حضرت جابر رضی اللہ عنہ سے حدیث بیان کی ،  کہا :  دو لڑکے آپس میں لڑ پڑے ،  ایک لڑکا مہاجر",,,,,6582
6583,"سفیان بن عیینہ نے کہا :  عمرو  ( بن دینار )  نے حضرت جابر بن عبداللہ رضی اللہ عنہ سے سنا ،  وہ کہہ ر",,,,,6583
6584,)   اسحٰق بن ابراہیم ،  اسحٰق بن منصور اور محمد بن رافع نے ہمیں حدیث بیان کی  ۔  ۔  ابن رافع نے کہا ,,,,,6584
6585,"حضرت ابوموسیٰ رضی اللہ عنہ سے روایت ہے ،  انہوں نے کہا کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :  ",,,,,6585
6586,"زکریا نے ہمیں شعبی سے حدیث بیان کی ،  انہوں نے حضرت نعمان بن بشیر رضی اللہ عنہ سے روایت کی ،  کہا : ",,,,,6586
6587,مطرف نے شعبی سے ،  انہوں نے نعمان بن بشیر رضی اللہ عنہ سے ،  انہوں نے نبی صلی اللہ علیہ وسلم سے اسی ,,,,,6587
6588,"وکیع نے اعمش سے ،  انہوں نے شعبی سے ،  انہوں نے حضرت نعمان بن بشیر رضی اللہ عنہ سے روایت کی ،  کہا :",,,,,6588
6589,"خیثمہ  ( بن عبدالرحمٰن )  نے حضرت نعمان بن بشیر رضی اللہ عنہ سے روایت کی ،  کہا :  رسول اللہ صلی الل",,,,,6589
