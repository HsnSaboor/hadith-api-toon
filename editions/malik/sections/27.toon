{"hadithnumber": "1074", "arabic": "[1074] حَدَّثَنِی یَحْیَی، عَنْ مَالِکٍ، عَنْ مُحَمَّدِ بْنِ یَحْیَی بْنِ حَبَّانَ، عَنِ الأَعْرَجِ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Mauquf Sahih'}", "reference": "Book 27, Hadith 1", "international_number": "1074", "narrator_chain": ""}
{"hadithnumber": "1075", "arabic": "[1075] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ نَافِعٍ، عَنْ عَبْدِ اللّٰہِ بْنِ عُمَرَ، أَنَّ رَسُولَ اللّ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Mauquf Sahih'}", "reference": "Book 27, Hadith 2", "international_number": "1075", "narrator_chain": ""}
{"hadithnumber": "1076", "arabic": "[1076] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ، عَنْ أَبِیہِ، أَ نَّہُ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Mauquf Daif'}", "reference": "Book 27, Hadith 3", "international_number": "1076", "narrator_chain": ""}
{"hadithnumber": "1077", "arabic": "[1077] حَدَّثَنِی مَالِکٌ، عَنْ عَبْدِ اللّٰہِ بْنِ الْفَضْلِ، عَنْ نَافِعِ بْنِ جُبَیْرِ بْنِ مُطْع", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Daif'}", "reference": "Book 27, Hadith 4", "international_number": "1077", "narrator_chain": ""}
{"hadithnumber": "1078", "arabic": "[1078] وَحَدَّثَنِی عَنْ مَالِکٍ، أَ نَّہُ بَلَغَہُ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ، أَ نَّہُ قَال", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Mauquf Daif'}", "reference": "Book 27, Hadith 5", "international_number": "1078", "narrator_chain": ""}
{"hadithnumber": "1079", "arabic": "[1079] وَحَدَّثَنِی عَنْ مَالِکٍ، أَ نَّہُ بَلَغَہُ : أَنَّ الْقَاسِمَ بْنَ مُحَمَّدٍ، وَسَالِمَ ب", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Mauquf Daif'}", "reference": "Book 27, Hadith 6", "international_number": "1079", "narrator_chain": ""}
{"hadithnumber": "1080", "arabic": "[1080] وَحَدَّثَنِی عَنْ مَالِکٍ، أَ نَّہُ بَلَغَہُ : أَنَّ  الْقَاسِمَ بْنَ مُحَمَّدٍ، وَسَالِمَ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih Lighairihi'}", "reference": "Book 27, Hadith 7", "international_number": "1080", "narrator_chain": ""}
{"hadithnumber": "1081", "arabic": "[1081] حَدَّثَنِی یَحْیَی، عَنْ مَالِکٍ، عَنْ أبِی حَازِمِ بْنِ دِینَارٍ، عَنْ سَہْلِ بْنِ سَعْدٍ ا", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Mauquf Daif'}", "reference": "Book 27, Hadith 8", "international_number": "1081", "narrator_chain": ""}
{"hadithnumber": "1082", "arabic": "[1082] وَحَدَّثَنِی عَنْ مَالِکٍ : عَنْ یَحْیَی بْنِ سَعِیدٍ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ، أَ نّ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Mauquf Daif'}", "reference": "Book 27, Hadith 9", "international_number": "1082", "narrator_chain": ""}
{"hadithnumber": "1083", "arabic": "[1083] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ نَافِعٍ : أَنَّ ابْنَۃَ عُبَیْدِ اللّٰہِ بْنِ عُمَرَ، وَأُم", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 27, Hadith 10", "international_number": "1083", "narrator_chain": ""}
{"hadithnumber": "1084", "arabic": "[1084] وَحَدَّثَنِی عَنْ مَالِکٍ، أَنَّہُ بَلَغَہُ، أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ کَتَبَ فِی", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Maqtu Sahih'}", "reference": "Book 27, Hadith 11", "international_number": "1084", "narrator_chain": ""}
