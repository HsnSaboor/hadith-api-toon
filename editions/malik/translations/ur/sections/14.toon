{"hadithnumber": "455", "text": "ایک انصاری صحابی رضی اللہ عنہ سے روایت ہے کہ انھوں نے رسول اللہ ﷺ کو سنا کہ آپ ہمیں پیشاب یا پاخانے"}
{"hadithnumber": "456", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے ، وہ کہتے تھے کہ کچھ لوگ کہتے ہیں کہ جب تو اپنی حاجت"}
{"hadithnumber": "457", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ ( ایک دفعہ ) رسول اللہ ﷺ نے قبلہ کی جانب والی دیوا"}
{"hadithnumber": "458", "text": "سیدہ عائشہ رضی اللہ عنہا زوجہ رسول اللہ ﷺ سے روایت ہے کہ رسول اللہ ﷺ نے قبلہ کی جانب دیوار میں تھوک"}
{"hadithnumber": "459", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے ، کہتے ہیں ، اسی دوران کہ لوگ ( مسجد ) قبا میں نمازِ"}
{"hadithnumber": "460", "text": "سعید بن مسیب رحمہ اللہ سے روایت ہے کہ رسول اللہ ﷺ مدینہ منورہ میں تشریف لانے کے بعد سولہ ماہ تک بیت"}
{"hadithnumber": "461", "text": "نافع رحمہ اللہ سے روایت ہے کہ حضرت عمر بن خطاب رضی اللہ عنہ نے فرمایا : جب بیت اللہ کی طرف منہ کر لی"}
{"hadithnumber": "462", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا :’’ میری اس مسجد میں ( پڑھی جانے وال"}
{"hadithnumber": "463", "text": "حضرت ابوہریرہ رضی اللہ عنہ یا حضرت ابوسعید خدری رضی اللہ عنہ سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا :’"}
{"hadithnumber": "464", "text": "حضرت عبداللہ بن زید مازنی رضی اللہ عنہ سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا :’’ وہ جگہ جو میرے گھر ا"}
{"hadithnumber": "465", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا :’’ اللہ کی بندیوں کو اللہ ک"}
{"hadithnumber": "466", "text": "بُسر بن سعید رحمہ اللہ سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا :’’ جب تم میں سے کوئی عورت نماز عشاء کو"}
{"hadithnumber": "467", "text": "حضرت عمر بن خطاب رضی اللہ عنہ کی اہلیہ حضرت عاتکہ بنت زید بن عمرو بن نفیل رضی اللہ عنہا سے روایت ہے"}
{"hadithnumber": "468", "text": "سیدہ عائشہ رضی اللہ عنہا زوجہ پیغمبر ﷺ سے روایت ہے ، انھوں نے کہا کہ اگر رسول اللہ ﷺ اس صورت حال کو"}
{"hadithnumber": "469", "text": "عبداللہ بن ابی بکر ( بن محمد بن عمرو ) بن حزم رحمہ اللہ سے روایت ہے کہ وہ کتاب جو رسول اللہ ﷺ نے ( ا"}
