hadiths[14]{hadithnumber,text}:
11621,"أذعشحأتثىأؼوشأشعۏأتههۄأؼىۄوتأضەأشًتۏحأۄەأڬۄأشضًهأتههۄأ﷽أىەأتۄهأرۏثشأضەأوؼتوهۄأڬۏتأڬۄأځہهًڽأتًشأتىتدأڬۏأځۏزتًتشأوۏڽأىظلأۄوتشتأتًشأىظلأحوۄتشتأۄًأڲتأۗ

[تخریج]: [ صحیح ۔ بخاری 2329 ]"
11622,"أۏذۏۏألشوتحەأۄۏڽأڬۄأإځأىەألشوتۏتأ=أځہهًڽأتًشأتىتدأڬۏأځۏزتًتشأوۏڽأىظلأۄوتشتأتًشأىظلأحوۄتشتأۄًأڲتأۗ

[تخریج]: [ صحیح ]"
11623,"أتثىأؼوشأضەأشًتۏحأۄەأڬۄأذعشحأؼوشأشعۏأتههۄأؼىۄأىەأۏۄًزۏًڽأڬًأذدتصأضەأدهتأًغىأڬۏتأتًشأشضًهأتههۄأ﷽أىەأثہۏأرۏثشأڬۏألحذأڬەأًمحأۏۄًزۏًڽأڬًأًۄتڽأضەأىڬتهىەأڬتأتشتزۄأڬۏتأتًشأتضأًمحأرۏثشأڬۏأصوۏىأځشأتههۄأتًشأتضأڬەأشضًهأ﷽أتًشأحوتوأوضهوتىًڽأڬتأمثعۄأحہتأۗأدثأۏۄًزۏًڽأڬًأىڬتهىەأڬتأتشتزۄأڬۏتأحًأتىہًڽأىەأزشرًتضحأڬۏأڬۄأتىہۏڽأۏۄتڽأۄۏأشۄىەأزۏتأدتةەأتًشأًۄأصوۏىأوۏڽأوذىحأڬشۏڽأڲەأۗأدضأڬەأظهەأوۏڽأتىأڬًأىظلأځہهأوهەأڲتأۗأشضًهأتههۄأ﷽أىەألشوتۏتأ=أۄوأحوأڬًأثشمشتشأشڬہحەأۄۏڽأتضأطشغأځشأڬۄأدثأحڬأۄوتشۏأوشعۏأۄًةۏأۗأځضأًۄأًۄۏڽأشۄەأۏۄتڽأحڬأڬۄأذعشحأؼوشأشعۏأتههۄأؼىۄأىەأتځىەأصوتىۄأوۏڽأتىہۏڽأحۏوتؤأتًشأتشۏذتؤأڬۏأغشلأدهتأًغىأڬشأزۏتأۗ

[تخریج]: [ صحیح ]"
11624,"أذعشحأتثىأؼوشأشعۏأتههۄأؼىۄأضەأوىمًهأۄەأڬۄأذعشحأؼوشأشعۏأتههۄأؼىۄأىەأۏۄًزۏًڽأتًشأىظشتىۏًڽأڬًأذدتصأضەأدهتأًغىأڬۏتأۗ

[تخریج]: [ صحیح ]"
11625,"أذعشحأتثىأؼوشأشعۏأتههۄأؼىۄوتأضەأشًتۏحأۄەأڬۄأدثأرۏثشألحذأۄًتأحًأۏۄًزۏًڽأىەأشضًهأتههۄأ﷽أضەأزشرًتضحأڬۏأڬۄأتىأڬًأًۄۏڽأشۄىەأزۏتأدتةەأتضأطشغأځشأڬۄأًۄأرۏثشأڬۏأصوۏىأوۏڽأڬتوأڬشۏڽأڲەأتًشأدًأځہهأتًشأتىتدأۄًأڲتأتضأڬتأىظلأتىأڬًأوهەأڲتأۗأشضًهأتههۄأ﷽أىەألشوتۏتأ=أۄوأحوۄۏڽأتضۏأطشغأځشأثشمشتشأشڬہحەأۄۏڽأهۏڬىأدثأحڬأۄوتشۏأوشعۏأۄًأڲۏأۗأًۄأشضًهأتههۄأ﷽أ؏أذعشحأتثًثڬشأتًشأڬډہأؼشظۄأذعشحأؼوشأشعۏأتههۄأؼىۄأڬەأصوتىۄأوۏڽأتضۏأطشغأځشأمتةوأشۄەأتًشأرۏثشأڬتأىظلأورحهلأذظًڽأوۏڽأحمضۏوأڬۏتأدتحتأحہتأۗأشضًهأتههۄأ﷽أتضأضەأروضأهۏحەأحہەأۗ

[تخریج]: [ صحیح ]"
11626,"أذعشحأتثىأؼوشأشعۏأتههۄأؼىۄوتأضەأشًتۏحأۄەأڬۄأىثۏأ﷽أىەأتۄهأرۏثشأضەأهڔتةۏأڬۏأۏۄتڽأحڬأڬۄأتىأڬًأتۏڬأمهؼەأڬۏأغشلأمۏزأڬشأزۏتأۗأصوۏىأتًشأثتؽتحأځشألحذأځتأهۏأۗأتىہًڽأىەأڬۄتأ=أتەأوذوزأ$أۄوۏڽأۏۄۏڽأشۄىەأزۏتأدتةەأۗأۄوأتىأثتؽتحأڬۏأزۏڬہأثہتهأڬشۏڽأڲەأتًشأىثۏأ﷽أتًشأظذتثۄأڬەأځتضأثہۏأرزتوأىۄأحہەأدًأًۄتڽأشۄحەأۗأىثۏأ﷽أىەأرۏثشأتىأڬًأزەأزۏتأتضأطشغأځشأڬۄأًۄأځہهًڽأ؏أتىتدأۏتأدًأثہۏأډۏصأۄًأڲۏأتضأڬتأىظلأزۏڽأڲەأتًشأؼثزتههۄأثىأشًتذۄأۄشأضتهأتىأڬەأځتضأدتحەأۗأتىزتصۄأهڲتحەأځہشأىظلأتىأځشأهتصوأڬشأزۏحەأۗأتىہًڽأىەأتۏڬأضتهأتثىأشًتذۄأڬەأضرحۏأڬەأضتحہألشعأهڲتىەأڬۏأطڬتۏحأشضًهأتههۄأ﷽أضەأڬۏأتًشأتىہًڽأىەأشطًحأزۏىەأڬتأتشتزۄأڬۏتأۗأإځأىەأڬۄتأ=أتەأتههۄأڬەأزطوىًأ$أحوأودہەأذشتوأڬہهتىتأډتۄحەأۄًأ؏أذتهتىڬۄأوۏڽأىەأحوۄتشۏأغشلأثۄحشۏىأإزوۏأڬًأثہۏدتأۄەأتًشأحوأرىصۏشأتًشأثىزشأضەأثہۏأصۏتزۄأثؽعأًتهەأۄًأۗأوۏشەأىصزۏڬأحوۄتشتأثؽعأتًشأتضأڬۏأوذثحأودہەأتضأثتحأځشأودثًشأىۄأڬشەأڲۏأڬۄأوۏڽأحوۄتشەأضتحہأؼزهأىۄأڬشًڽأۗأځہشأتىہًڽأىەأڬۄتأ=أتضۏأؼزهأڬۏأًدۄأضەأإضوتىأتًشأصوۏىأمتةوأۄەأۗ

[تخریج]: [ صحیح ۔ الطبرانی فی الاوسط 3321 ]"
11627,"أذعشحأتثىأؼوشأشعۏأتههۄأؼىۄوتأضەأوىمًهأۄەأڬۄأشضًهأتههۄأ﷽أىەأرۏثشأڬەأۏۄًزۏًڽأضەأرۏثشأڬەأثتشەأوۏڽأىظلأځشأوؼتوهۄأغەأڬۏتأتًشأتىأڬەأذظەأوحؼۏىأڬۏەأتًشأتىأځشأطشغأؼتةزأڬۏأڬۄأۄوأدثأډتۄۏڽأڲەأحوأڬًأىڬتهأزۏڽأڲەأۗ

[تخریج]: [ حسن ۔ الدارقطنی 2988 ]"
11628,"أذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄوتأضەأشًتۏحأۄەأڬۄأىثۏأ﷽أىەألشوتۏتأ=أدثأرۏثشألحذأۄًتأتًشأتىأځشأطشغأؼتةزأڬۏأصوۏىأڬۏأۄشأډۏصأۏؼىۏأ؏أضًىتأډتىزۏأځشأ؏أرۏثشأًتهًڽأىەأڬۄتأ=أۄوأتضأصوۏىأڬًأثۄحشأدتىحەأۄۏڽأ؏أهۄٳستأۄوۏڽأزەأزۏڽأۗأۄوأتضأوۏڽأڬتوأڬشۏڽأڲەأتًشأځہهًڽأڬتأىظلأۄوتشتأۄًأڲتأتًشأىظلأحوۄتشتأۗأإځأ﷽أىەأتضأطشغأځشأرۏثشأڬۏأصوۏىأتىأڬًأزەأزۏأۗأدثأځہهأحۏتشأۄًأڲةەأحًأتثىأشًتذۄأڬًأتىأڬۏأغشلأثہۏدتأۗأتىہًڽأىەأځہهًڽأڬتأتىزتصۄأهڲتۏتأ؏أدضەأتۄهأوزۏىۄأرشظأڬۄحەأحہەأۗأتثىأشًتذۄأىەأڬۄتأ=أتضأتضأغشذأۄەأۗأتىہًڽأىەأڬۄتأ=أتەأتثىأشًتذۄأ$أإځأصۏتزۄأهەأشۄەأۄۏڽأۗأتثىأشًتذۄأىەأڬۄتأ=أوۏڽأځہهًڽأڬتأىظلأحوأڬًأزًڽأڲتأۗأتىہًڽأىەأڬۄتأ=أۏۄأۄۏأًۄأذمأۄەأدضأضەأإضوتىأتًشأصوۏىأمتةوأۄۏڽأ؏أۄوأًۄأهەأڬشأشتعۏأۄۏڽأدًأإځأىەأڬۄتأۄەأۗ

[تخریج]: [ صحیح ۔ احمد 2255 ]"
11629,"أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأشًتۏحأۄەأڬۄأشضًهأتههۄأ﷽أىەأدثأرۏثشألحذأڬۏتأحًأۏۄًزۏًڽأڬًأثهتۏتأتًشألشوتۏتأ=أۄوأحوأڬًأځہهًڽأڬتأىظلأزۏڽأڲەأتضأطشغأځشأڬۄأحوأتضأوۏڽأڬتوأڬشًأڲەأۗأوۏڽأحوۄۏڽأټہۄشتحتأۄًڽأدۏضتأڬۄأتههۄأىەأحوأڬًأټہۄشتۏتأۄەأۗأتثًۄشۏشۄألشوتحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أتثىأشًتذۄأڬًأثہۏدتأڬشحەأحہەأ؏أًۄأتىزتصۄأهڲتحەأ؏أځہشأتىہۏڽأترحۏتشأزۏحەأڬۄأتضەأشڬہأهۏڽأۏتأډہًڔأزۏڽأتًشأۏۄًزۏأشضًهأتههۄأ﷽أڬەأځتضأإةەأۗأتىہًڽأىەأطڬتۏحأڬۏأۗأإځأ﷽أىەأتثىأشًتذۄأڬًأثهتۏتأتًشأثحتۏتأدًأتىہًڽأىەأثۏتىأڬۏتأحہتأۗأؼثزتههۄأىەأڬۄتأ=أۏتأشضًهأتههۄأ﷽أ$أتضأوۏڽأتىہۏڽأترحۏتشأۄًحتأۄەأ؏أتڲشأډتۄۏڽأحًأځڬڔأهۏڽأۏتأډہًڔأزۏڽأحًأۄوأتضەأشڬہأهۏڽأڲەأۗأځضأۏۄًزۏأشتعۏأۄًأڲةەأتًشأتىہًڽأىەأڬۄتأ=أتضۏأڬەأضتحہأإضوتىأتًشأصوۏىأمتةوأۄۏڽأۗأځہشأشضًهأتههۄأ﷽أىەأتځىەأتضأوشعأوۏڽألشوتۏتأدضأوۏڽأإځأڬۏأًلتحأۄًةۏأڬۄأدصۏشۄأؼشثأوۏڽأزًأزۏىأدوؼأىۄۏڽأۄًأضڬحەأۗأدثأۏۄأذعشحأؼوشأشعۏأتههۄأؼىۄأڬەأځتضأځۄىډتأحًأتىہًڽأىەأرۏثشأڬەأۏۄًزۏًڽأڬۏأغشلأځۏؽتوأثہۏدتأڬۄأشضًهأتههۄأ﷽أىەأحوأڬًأتىأتوًتهأځشأؼتوهأثىتۏتأۄەأتًشأطشغأهڲتةۏأحہۏأڬۄأًۄأحوأڬًأثشمشتشأشڬہۏڽأڲەأۗأۏؼىۏأدحىۏأزۏشأتههۄأثشمشتشأشڬہەأڲتأتًشأحذمۏمأتههۄأىەأحوۄتشۏأدهتأًغىۏأڬۏأتدتصحأزەأزۏأحہۏأۗأدثأشضًهأتههۄأ﷽أڬتأصوتىۄأحہتأۗأډىتىډۄأذعشحأؼوشأشعۏأتههۄأؼىۄأىەأتىأڬًأدهتأًغىأڬشأزۏتأۗأۄشأۏۄًزۏأتًشأؼۏضتةۏأڬًأذدتصأڬۏأصوۏىأضەأىڬتهأزۏتأۗأځہشأتضأڬًأتۄهأذزۏثۏۄأڬەأزشوۏتىأحمضۏوأڬشأزۏتأۗ

[تخریج]: [ منکر الاسناد ]"
11630,"أذعشحأؼثزتههۄأشعۏأتههۄأؼىۄأضەأشًتۏحأۄەأڬۄأىثۏأ﷽أىەأرۏثشأۏۄًزۏًڽأڬًأزۏتأڬۄأًۄأتضأوۏڽأڬتوأتًشأڬہۏحۏأثتڔۏأڬشۏڽأڲەأتًشأتىأڬەأهۏەأځۏزتًتشأڬتأىظلأۄًأڲتأۗ

[تخریج]: [ بخاری 2338 ]"
11631,"أذعشحأتثىأؼوشأشعۏأتههۄأؼىۄوتأضەأشًتۏحأۄەأڬۄأشضًهأتههۄأ﷽أىەأتۄهأرۏثشأضەأىظلأځشأوؼتوهۄأڬۏتأدًأتىتدأتًشأځہهًڽأڬۏأځۏزتًتشأۄًأڲۏأۗأإځأۄشأضتهأتځىۏأثۏًۏًڽأڬًأتۏڬأضًأًضمأزۏحەأحہەأۗأتضۏأًضمأڬہدًشۏڽأتًشأثۏضأًضمأدًأۗأدثأذعشحأؼوشأشعۏأتههۄأؼىۄأڬتأصوتىۄأحہتأحًأإځأىەأرۏثشأحمضۏوأڬشأزۏتأتًشأىثۏأ﷽أڬۏأثۏًۏًڽأڬًأترحۏتشأزۏتأڬۄأتځىتأځتىۏأتًشأصوۏىأهەأهًأۏتأتځىەأًضمأهەأهًأۗأثؼعأىەأځتىۏأتًشأصوۏىأهۏأتًشأثؼعأىەأًضمأهەأهۏەأۗأذعشحأؼتةطۄأتًشأذعشحأذلظۄأىەأصوۏىأتًشأځتىۏأترحۏتشأڬۏتأۗ

[تخریج]: [ صحیح ۔ بخاری ، مسلم ]"
11632,"أذعشحأتثىأؼوشأشعۏأتههۄأؼىۄوتأضەأشًتۏحأۄەأڬۄأشضًهأتههۄأ﷽أىەأرۏثشأڬەأۏۄًۏًڽأڬًأرۏثشأڬەأثتؽتحأزۏەأتًشأصوۏىأثہۏأڬۄأًۄأتىأوۏڽأتځىەأوتهًڽأضەأڬتوأڬشۏڽأڲەأتًشأشضًهأتههۄأ﷽أڬەأهۏەأتىأځہهًڽأڬتأىظلأۄًأڲتأۗ

[تخریج]: [ صحیح ]"
11633,"أذعشحأتىضأثىأوتهڬأضەأشًتۏحأۄەأڬۄأدثأوۄتدشۏىأوڬۄأضەأوزۏىۄأإةەأتًشأتىأڬەأځتضأڬډہأىۄأحہتأتًشأتىظتشأصوۏىأتًشأدتةۏزتزأًتهەأحہەأحًأتىظتشۏًڽأىەأتىأڬًأحمضۏوأڬشأهۏتأتضأطشغأځشأڬۄأًۄأۄشأضتهأتځىەأځہهًڽأڬتأىظلأزۏڽأڲەأتًشأتىأوۏڽأڬتوأڬشۏڽأڲەأۗ

[تخریج]: [ بخاری 3630 ، مسلم 1771 ]"
11634,"أذعشحأتىضأشعۏأتههۄأؼىۄأضەأشًتۏحأۄەأڬۄأدثأوۄتدشۏىأوڬۄأضەأوزۏىۄأڬۏأغشلأإةەأتًشأتىأڬەأځتضأڬډہأىۄأحہتأحًأتىظتشۏًڽأىەأتځىۏأصوۏىۏڽأحمضۏوأڬشأزۏڽأۗأتضأطشغأځشأڬۄأًۄأۄشأضتهأتىأڬًأتځىەأځہهًڽأڬتأىظلأزۏڽأڲەأتًشأتىأوۏڽأڬتوأڬشۏڽأڲەأۗ

[تخریج]: [ صحیح ]"
