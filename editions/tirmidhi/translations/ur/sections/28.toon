{"hadithnumber": "2048", "text": "عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس چیز سے تم عل"}
{"hadithnumber": "2049", "text": "عمران بن حصین رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے بدن داغنے سے منع فرمایا ۱"}
{"hadithnumber": "2050", "text": "انس رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے اسعد بن زرارہ کے بدن کو سرخ پھنسی کی"}
{"hadithnumber": "2051", "text": "انس رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم گردن کی دونوں جانب موجود دو پوشیدہ رگوں ا"}
{"hadithnumber": "2052", "text": "عبداللہ بن مسعود رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے معراج کی رات کا حال بیان"}
{"hadithnumber": "2053", "text": "عکرمہ کہتے ہیں کہ  ابن عباس رضی الله عنہما کے پاس پچھنا لگانے والے تین غلام تھے، ان میں سے دو ابن عب"}
{"hadithnumber": "2054", "text": "سلمی رضی الله عنہا سے (جو نبی اکرم صلی اللہ علیہ وسلم کی خدمت کرتی تھیں) کہتی ہیں کہ  رسول اللہ صلی"}
{"hadithnumber": "2055", "text": "مغیرہ بن شعبہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے بدن داغا یا ج"}
{"hadithnumber": "2056", "text": "انس رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے بچھو کے ڈنک، نظر بد اور پسلی میں نکلنے"}
{"hadithnumber": "2057", "text": "عمران بن حصین رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جھاڑ پھونک صرف ن"}
{"hadithnumber": "2058", "text": "ابو سعید خدری رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم جنوں اور انسان کی نظر بد سے پنا"}
{"hadithnumber": "2059", "text": "عبید بن رفاعہ زرقی رضی الله عنہ سے روایت ہے کہ  اسماء بنت عمیس رضی الله عنہا نے عرض کیا: اللہ کے رسو"}
{"hadithnumber": "2060", "text": "عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  اللہ کے رسول حسن اور حسین رضی الله عنہما پر یہ کلمات پڑھ"}
{"hadithnumber": "2061", "text": "حابس تمیمی رضی الله عنہ کہتے ہیں کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا: الو"}
{"hadithnumber": "2062", "text": "عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اگر کوئی چیز تق"}
{"hadithnumber": "2063", "text": "ابو سعید خدری رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ہمیں ایک سریہ میں بھیجا، ہم"}
{"hadithnumber": "2064", "text": "ابو سعید خدری رضی الله عنہ کہتے ہیں کہ  کچھ صحابہ  ( جن میں شامل میں بھی تھا )  عرب کے ایک قبیلہ کے"}
{"hadithnumber": "2065", "text": "ابوخزامہ اپنے والد سے روایت کرتے ہیں، وہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم سے پوچھا:"}
{"hadithnumber": "2066", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”عجوہ  ( کھجور )  جنت کا"}
{"hadithnumber": "2067", "text": "سعید بن زید رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”صحرائے عرب کا فقعہ"}
{"hadithnumber": "2068", "text": "ابوہریرہ رضی الله عنہ سے روایت ہے کہ  میں سے کچھ لوگوں نے کہا: کھنبی زمین کی چیچک ہے،  ( یہ سن کر )"}
{"hadithnumber": "2069", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  میں نے تین، پانچ یا سات کھنبی لی، ان کو نچوڑا، پھر اس کا عرق ایک"}
{"hadithnumber": "2070", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  کلونجی موت کے علاوہ ہر بیماری کی دوا ہے۔ قتادہ ہر روز کلونجی کے ا"}
{"hadithnumber": "2071", "text": "ابومسعود انصاری رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے کتے کی قیمت، زانیہ عورت کی"}
{"hadithnumber": "2072", "text": "عیسیٰ بن عبدالرحمٰن کہتے ہیں کہ  میں عبداللہ بن عکیم ابومعبد جہنی کے ہاں ان کی عیادت کرنے گیا، ان کو"}
{"hadithnumber": "2073", "text": "رافع بن خدیج رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”بخار جہنم کی گرمی"}
