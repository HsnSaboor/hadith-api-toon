{"hadithnumber": "1651", "text": "علقمہ بن ابی علقمہ رحمہ اللہ اپنی والدہ ( مرجانہ اُمِّ علقمہ جو سیدہ عائشہ رضی اللہ عنہا کی آزاد کرد"}
{"hadithnumber": "1652", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ انھوں نے فرمایا : ایسی عورتیں جو کپڑے پہننے والی ہوں ( لیک"}
{"hadithnumber": "1653", "text": "ابن شہاب رحمہ اللہ سے روایت ہے کہ بے شک رسول اللہ ﷺ رات کے وقت اٹھے ( بیدار ہوئے ) ، پھر آپ ﷺ نے آسم"}
{"hadithnumber": "1654", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہ سے روایت ہے کہ بے شک رسول اللہ ﷺ نے فرمایا :’’ وہ شخص جو اپنا کپڑا"}
{"hadithnumber": "1655", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ یقیناً رسول اللہ ﷺ نے فرمایا :’’ اللہ تعالیٰ قیامت کے دن ا"}
{"hadithnumber": "1656", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہ سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ نے فرمایا :’’ اللہ تعالیٰ قیامت ک"}
{"hadithnumber": "1657", "text": "علاء بن عبدالرحمن رحمہ اللہ اپنے والد ( عبدالرحمن بن یعقوب رحمہ اللہ ) سے روایت کرتے ہیں ، کہتے ہیں"}
{"hadithnumber": "1658", "text": "سیدہ ام سلمہ رضی اللہ عنہا زوجہ پیغمبر ﷺ سے روایت ہے ، انھوں نے جس وقت کہ ازار کا ذکر کیا گیا ( نبی"}
{"hadithnumber": "1659", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ نے فرمایا :’’ تم میں سے کوئی بھی ایک جو"}
{"hadithnumber": "1660", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ بے شک رسول اللہ ﷺ نے فرمایا :’’ جب تم میں سے کوئی جوتا پہن"}
{"hadithnumber": "1661", "text": "کعب احبار رحمہ اللہ سے روایت ہے کہ بے شک ایک آدمی نے اپنے دونوں جوتے اتار دیے تو انھوں نے اس سے کہا"}
{"hadithnumber": "1662", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ، کہتے ہیں : رسول اللہ ﷺ نے دو قسم کے پہننے کے انداز اور دو ق"}
{"hadithnumber": "1663", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہ سے روایت ہے کہ بے شک حضرت عمر بن خطاب رضی اللہ عنہ نے ایک حلہ یعنی"}
{"hadithnumber": "1664", "text": "حضرت انس بن مالک رضی اللہ عنہ سے روایت ہے ، کہتے ہیں : میں نے حضرت عمر بن خطاب رضی اللہ عنہ کو دیکھا"}
{"hadithnumber": "1665", "text": "حضرت انس بن مالک رضی اللہ عنہ سے روایت ہے ، فرماتے ہیں کہ رسول اللہ ﷺ نہ تو بہت زیادہ لمبے تھے ، نہ"}
{"hadithnumber": "1666", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہ سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ نے فرمایا :’’ میں نے آج رات ( خوا"}
{"hadithnumber": "1667", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ، کہتے ہیں : پانچ چیزیں فطرت میں سے ہیں : ناخن تراشنا ، مونچھ"}
{"hadithnumber": "1668", "text": "سعید بن مسیب رحمہ اللہ سے روایت ہے ، کہتے ہیں : بے شک حضرت ابراہیم علیہ السلام نے لوگوں میں سب سے پہ"}
{"hadithnumber": "1669", "text": "حضرت جابر بن عبداللہ رضی اللہ عنہ سے روایت ہے کہ بے شک رسول اللہ ﷺ نے اس سے منع فرمایا کہ آدمی اپنے"}
{"hadithnumber": "1670", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہ سے روایت ہے کہ بے شک رسول اللہ ﷺ نے فرمایا :’’ جب تم میں سے کوئی شخ"}
