{"hadithnumber": "534", "text": "حضرت ابو مالک اشعری  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا :  ’’پاکیزگی نصف ایما"}
{"hadithnumber": "535", "text": "ابو عوانہ نے سماک بن حرب سےانہوں نے مصعب بن سعد سے روایت کی کہ عبد اللہ بن عمر  ‌رضی ‌اللہ ‌عنہ ‌ ‌"}
{"hadithnumber": "536", "text": "شعبہ  ، زائدہ اور اسرائیل سب نے سماک بن حرب سے اسی اسناد کے ساتھ رسول اللہ ﷺ سے یہی حدیث روایت کی ہے"}
{"hadithnumber": "537", "text": "وہب بن منبہ کے بھائی ہمام بن منبہ سے روایت ہے ،  کہا :  یہ وہ احادیث ہیں جو حضرت ابو ہریرہ  ‌رضی ‌ال"}
{"hadithnumber": "538", "text": "یونس نے ابن شہاب سے روایت کی کہ عطاء بن یزید نے انہیں خبر دی کہ حمران نے  ،  جوحضرت عثمان  ‌رضی ‌الل"}
{"hadithnumber": "539", "text": "یعقوب کے والد ابراہیم  (  بن سعد )  نے ابن شہاب سے باقی ماندہ سند کے ساتھ حمران سے روایت کی کہ انہوں"}
{"hadithnumber": "540", "text": "جریر نے ہشام بن عروہ سے  ،  انہوں نے اپنے والد ( عروہ بن زبیر ) سے  ،  انہوں نے حضرت عثمان  ‌رضی ‌ال"}
{"hadithnumber": "541", "text": "ہشام سے  ( جریر کے بجائے )  ابو اسامہ  ،  وکیع اور سفیان کی سندوں سے بھی یہ روایت بیان کی گئی ۔  ان"}
{"hadithnumber": "542", "text": "ابن شہاب نے کہا :  لیکن عروہ ،  حمران کی جانب سے حدیث بیان کرتے ہیں کہ انہوں نے کہا : پھر جب عثمان ‌"}
{"hadithnumber": "543", "text": "اسحاق بن سعيد نے عمرو بن سعید بن عاص نے اپنے والد ( سعید بن عمرو ) سے اور انہوں نے اپنے والد  ( عمرو"}
{"hadithnumber": "544", "text": "ابن عبدہ کی روایت میں ہے  : میں عثمان  ‌رضی ‌اللہ ‌عنہ ‌ ‌  کے پاس آیا تو انہوں نے وضو کیا  ۔  قتیبہ"}
{"hadithnumber": "545", "text": "قتیبہ بن سعید ،  ابوبکر بن ابی شیبہ اور زہیر بن حرب نے کہا :   (  اس حدیث کے الفاظ قتیبہ اور ابوبکر"}
{"hadithnumber": "546", "text": "مسعر نےابو صخرہ جامع بن شداد سے روایت کی  ،  انہو ں نے کہا : میں نےحمران بن ابان سے سنا ،  انہوں نےک"}
{"hadithnumber": "547", "text": "عبید اللہ بن معاذ نے اپنےوالد سے اور محمد بن مثنیٰ اورابن بشار نے محمد بن جعفر  ( غندر )  سےروایت کی"}
{"hadithnumber": "548", "text": "مخرمہ کےوالد بکیر  (  بن عبد اللہ  )  نے حمران  ( مولیٰ عثمان  )  سے روایت کی کہ ایک دن حضرت عثمان ب"}
{"hadithnumber": "549", "text": "معاذ بن عبد الرحمن نے عثمان بن عفان ‌رضی ‌اللہ ‌عنہ ‌ ‌  کے مولیٰ حمران سے اور انہوں نے حضرت عثمان ب"}
{"hadithnumber": "550", "text": "علاء نے اپنے والد عبد الرحمن بن یعقوب سے اور انہوں نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت"}
{"hadithnumber": "551", "text": "محمد (  بن سیرین )  نےحضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  انہو ں نے نبی ﷺ سے روایت"}
{"hadithnumber": "552", "text": "عمر بن اسحاق کےوالد اسحاق  ( بن عبد اللہ  )  نے حضرت ابوہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ رس"}
{"hadithnumber": "553", "text": "عبدالرحمان بن مہدی نے کہا :  ہمیں معاویہ بن صالح نے ربیعہ بن یزید کے حوالے سے ابو ادریس خولانی سےحدی"}
{"hadithnumber": "554", "text": "زید بن حباب نے معاویہ بن صالح سے باقی ماندہ سابقہ سند کے ساتھ حضرت عقبہ بن عامر جہنی  ‌رضی ‌اللہ ‌عن"}
{"hadithnumber": "555", "text": "خالد  بن عبد اللہ نےعمرو بن یحییٰ بن عمارہ سے ،  انہوں نے اپنےوالد  ( یحییٰ بن عمارہ )  سے  ،  انہوں"}
{"hadithnumber": "556", "text": "( خالدبن عبداللہ کے بجائے )  سلیمان بن بلا ل نےعمرو بن یحییٰ سے باقی ماندہ پچھلی سند کے ساتھ یہی روا"}
{"hadithnumber": "557", "text": "مالک بن انس نے عمرو بن یحییٰ کی سند سے یہی روایت بیان کی اور کہا : انہوں نےتین بار کلی کی اور ناک می"}
{"hadithnumber": "558", "text": "بہز نے وہیب سے اور اس نے عمرو بن یحییٰ سے سابقہ راویوں کی اسناد کی طرح حدیث بیان کی اور اس میں کہا :"}
{"hadithnumber": "559", "text": "ہارون بن سعید ایلی اور ابو طاہر نےحدیث بیان کی ،  انہوں نےکہا :  ہمیں ابن وہب نےحدیث سنائی ،  انہوں"}
{"hadithnumber": "560", "text": "اعرج نےحضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے نبی ﷺ کی طرف منسوب کرتے ہوئے روایت کی کہ آپ نے فرمایا"}
{"hadithnumber": "561", "text": "ہمام بن منبہ سےمنقول ہے  ،  انہوں نے کہا :  یہ احادیث ہیں جو حضرت ابوہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے"}
{"hadithnumber": "562", "text": "مالک نے ابن شہاب سے  ،  انہوں نے ابو ادریس خولانی سے  ،  انہو ں نے حضرت ابوہریرہ  ‌رضی ‌اللہ ‌عنہ ‌"}
{"hadithnumber": "563", "text": "یونس نے ابن شہاب سے روایت کی ، کہا :  مجھے ابو ادریس خولانی نے بیان کیا کہ انہوں نے حضرت ابو ہریرہ"}
{"hadithnumber": "564", "text": "عیسیٰ بن طلحہ نےحضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ نبی ﷺ نے فرمایا : ’’جب تم میں سے"}
{"hadithnumber": "565", "text": "ابو زبیر نے حضرت جابر بن عبد اللہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  کو سنا ،  کہہ رہے تھے ،  رسول اللہ ﷺ نے فرما"}
{"hadithnumber": "566", "text": "مخرمہ بن بکیر نے اپنےوالد سے  ،  انہوں نے شداد کے آزاد کردہ غلام سالم سے روایت کی  ،  انہوں نے کہا :"}
{"hadithnumber": "567", "text": "ایک اور سند سے محمد بن عبدالرحمان نے شداد بن ہاد کے آزادکردہ غلام ابو عبد اللہ  ( سالم  )  سے روایت"}
{"hadithnumber": "568", "text": "ابوسلمہ بن عبد الرحمن نے بیان کیا کہ مہری کے آزاد کردہ غلام سالم نے مجھے بتایا کہ میں اور عبدالرحمن"}
{"hadithnumber": "569", "text": "نعیم بن عبد اللہ نے شداد بن بن ہاد کے آزاد کردہ غلام سالم سے روایت کی  ،  انہوں نے کہا :  میں حضرت ع"}
{"hadithnumber": "570", "text": "جریر نے منصور سے  ،  انہوں نے ہلال بن یساف سے  ،  انہوں نے ابو یحییٰ  (  مصدع ،  الاعرج )  سے اور ان"}
{"hadithnumber": "571", "text": "منصور کے دوسرے شاگرد سفیان اور شعبہ کے حوالے سے بھی باقی ماندہ اسی سند کے ساتھ یہی روایت بیان کی گئی"}
{"hadithnumber": "572", "text": "یوسف بن ماہک نے حضرت عبد اللہ بن عمرو ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  کہا :  ایک سفر کے دوران م"}
{"hadithnumber": "573", "text": "ربیع بن مسلم نے محمد بن زیاد سے  ،  انہوں نے حضرت ابوہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ نبی ﷺ"}
{"hadithnumber": "574", "text": "شعبہ نےمحمد بن زیاد سے  ،  انہوں نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سےروایت کی کہ انہوں نے کچھ"}
{"hadithnumber": "575", "text": "سہیل کے والد ابو صالح نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  انہوں نے کہا :  رسول ا"}
{"hadithnumber": "576", "text": "حضرت جابر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سےروایت ہے  ، انہوں نے کہا :  مجھے حضرت عمر بن خطاب  ‌رضی ‌اللہ ‌عنہ"}
{"hadithnumber": "577", "text": "حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا : ’’جب ایک مسلم  (  یامومن"}
{"hadithnumber": "578", "text": "حضرت عثمان بن عفان ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے  ،  انہوں نے کہا :  رسول اللہ ﷺ نے فرمایا : ’’جس"}
{"hadithnumber": "579", "text": "عمارہ بن غزیہ انصاری نےنعیم بن عبداللہ مجمر سے روایت کی  ،  انہوں نے کہا : میں نے ابوہریرہ ﷺ کو وضو"}
{"hadithnumber": "580", "text": "سعید بن ابی ہلال نے نعیم بن عبداللہ سےروایت کی  کہ انہوں نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  کو"}
{"hadithnumber": "581", "text": "مروان نے ابو مالک اشجعی سعد بن طارق سے ،  انہوں نے ابو حازم سے اور انہوں نے حضرت ابو ہریرہ  ‌رضی ‌ال"}
{"hadithnumber": "582", "text": "( مروان کے بجائے  )  ابن فضیل نے ابو مالک اشجعی سے  ، انہوں نے ابو حازم سے اور انہوں نے حضرت ابو ہری"}
{"hadithnumber": "583", "text": "حضرت حذیفہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے  ،  انہوں نے کہا :  رسول اللہ ﷺ نے فرمایا  :  ’’بلاشبہ"}
{"hadithnumber": "584", "text": "اسماعیل  (  بن جعفر )  نے علاء سے  ،  انہوں نے اپنے والد سےاور انہوں نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌"}
{"hadithnumber": "585", "text": "اسماعیل کے بجائے )  عبدالعزیز دراوردی اور مالک نے علاء سے  ،  انہوں نے اپنےوالد عبد الرحمن سے اور ان"}
{"hadithnumber": "586", "text": "ابو حازم سے روایت ہے  ،  انہوں نےکہا :  میں ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  کے پیچھے کھڑا تھا اور وہ"}
{"hadithnumber": "587", "text": "اسماعیل نے بیان کیا کہ انہیں علاء نے خبر دی  ،  انہوں نے اپنے والد سے روایت کی  ،  انہوں نے حضرت ابو"}
{"hadithnumber": "588", "text": "( بجائے اسماعیل کے  )  مالک اور شعبہ نے اسی سند کے ساتھ علاء بن عبدالرحمن سے روایت کی  ،  شعبہ کی حد"}
{"hadithnumber": "589", "text": "حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ نبی ﷺ نےفرمایا : ’’اگر مجھے یہ ڈر نہ ہوتا کہ میں"}
{"hadithnumber": "590", "text": "مسعر نے مقدام بن شریح سے اور انہوں نے اپنے والد سے روایت کی  ،  انہوں نے کہا : میں نے حضرت عائشہ ؓ س"}
{"hadithnumber": "591", "text": "سفیان نے مقدام بن شریح سے باقی ماندہ سابقہ سند سے حضرت عائشہ ‎ؓؓؓؓؓؓؓؓؓؓؓؓؓؓسے روایت کی کہ نبی ﷺجب ا"}
{"hadithnumber": "592", "text": "حضرت ابو موسیٰ اشعری  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت  ہے  ،  انہوں نے کہا :  میں رسول اللہﷺ کی خدمت م"}
{"hadithnumber": "593", "text": "ہشیم نے حصین سے  ،  انہوں نے ابو وائل سے  ،  انہوں نے حضرت حذیفہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی"}
{"hadithnumber": "594", "text": "منصور اور اعمش دونوں نے ابو وائل سے  ،  انہوں نے حضرت حذیفہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  ان"}
{"hadithnumber": "595", "text": "سفیان نے منصور کےحوالے سے اور حصین اور اعمش نے  ( بھی منصور کی طرح  )  ابو وائل سے اور انہوں  نے حضر"}
{"hadithnumber": "596", "text": "حضرت ابن عباس ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے ابو متوکل کو بتایا کہ انہوں نے ایک رات اللہ کے نبی ﷺ کے ہاں گز"}
{"hadithnumber": "597", "text": "ابن عیینہ نے زہری سے حدیث بیان کی  ،  انہوں نے سعید بن مسیب سے  ،  انہوں نے حضرت ابو ہریرہ ‌رضی ‌الل"}
{"hadithnumber": "598", "text": "مجھے یونس نے ابن شہاب زہری سے خبر دی ،  انہوں نے سعید بن مسیب سے  ،  انہوں نے حضرت ابو ہریرہ  ‌رضی ‌"}
{"hadithnumber": "599", "text": "حضرت انس بن مالک ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے ،  انہوں نے کہا :  ہمارے لیے مونچھیں کترنے  ،  ناخ"}
{"hadithnumber": "600", "text": "عبید اللہ نےنافع سے  ،  انہوں نے حضرت ابن عمر ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے اور انہوں نے نبیﷺ سے روایت کی"}
{"hadithnumber": "601", "text": "ابو بکر بن نافع نے اپنے والد سے  ، انہوں نے حضرت ابن عمر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے اور انہوں نے نبی ﷺ"}
{"hadithnumber": "602", "text": "عمر بن محمد نے نافع کے حوالے سے حضرت ابن عمر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سےروایت کی  ،  انہوں نے کہا کہ رس"}
{"hadithnumber": "603", "text": "حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سےروایت ہے  ،  انہوں نے کہا :  رسول ا للہ ﷺ نے فرمایا : ’’ مونچ"}
{"hadithnumber": "604", "text": "قتیبہ بن سعید  ،  ابو بکر بن ابی شیبہ او رزہیر بن حرب نے کہا :  ہمیں وکیع نے زکریا بن ابی زائدہ سےحد"}
{"hadithnumber": "605", "text": "ابو کریب نے بیان کیا  ،  ہمیں ابو زائدہ کے بیٹے نے اپنے والد  (  ابو زائدہ )  سے خبر دی ،  انہوں نے"}
{"hadithnumber": "606", "text": "اعمش کے دوشاگرد وکیع اور ابو معاویہ كی سندوں سے حضرت سلمان  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے  (  اور"}
{"hadithnumber": "607", "text": "اعمش کے ایک اور شاگرد سفیان نے ان سے اور منصور سے  ،  ان دونوں نے ابراہیم سے  ،  انہوں نے عبد الرحمن"}
{"hadithnumber": "608", "text": "ابوزبیر نے بیان کیا کہ انہوں نے حضرت جابر ‌رضی ‌اللہ ‌عنہ ‌ ‌  کو یہ کہتے ہوئے سنا  :  رسول اللہ ﷺ ن"}
{"hadithnumber": "609", "text": "زہیر بن حرب اور ابن نمیر دونوں نے کہا ،  ہمیں سفیان بن عیینہ نے حدیث سنائی  ،  نیز یحییٰ بن یحییٰ نے"}
{"hadithnumber": "610", "text": "حضرت ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے  ،  انہوں نے رسول اللہ ﷺ سے روایت کی  ،  آپ نے فرمای"}
{"hadithnumber": "611", "text": "محمد بن یحییٰ بن حبان اپنے چچا واسع بن حبان سے اور وہ حضرت ابن عمر   سے روایت کرتے ہیں کہ انہوں نےکہ"}
{"hadithnumber": "612", "text": "یحییٰ بن سعید نے محمد بن یحییٰ سے  ،  انہوں نے اپنے چچا واسع بن حبان سے روایت کی  ،  انہوں نے کہا :"}
{"hadithnumber": "613", "text": "ہمام نے یحییٰ بن ابی کثیر سے  ، انہوں نے عبد اللہ بن ابی قتادہ سے  ،  انہوں نے اپنے والد حضرت ابو قت"}
{"hadithnumber": "614", "text": "ہشام دستوائی نے یحییٰ بن ابی کثیر سے  ،  انہو ں نے عبد اللہ بن ابی قتادہ سے  ،  انہوں نے اپنے باپ  ("}
{"hadithnumber": "615", "text": "ایوب نے یحییٰ بن ابی کثیر سے  ،  انہوں نے عبد اللہ بن ابی قتادہ سے  ،  انہو ننے  (  اپنے والد )  حضر"}
{"hadithnumber": "616", "text": "ابو احوص نے اشعث سے  ،  انہوں نے اپنے والد سے  ،  انہوں نے مسروق سے اور انہوں نے حضرت عائشہ ؓ سے روا"}
{"hadithnumber": "617", "text": "اشعث کے ایک دوسرے شاگرد شعبہ نے باقی ماندہ سابقہ سند کے ساتھ حضرت عائشہ ؓ سے روایت کی کہ رسول اللہ ﷺ"}
{"hadithnumber": "618", "text": "حضرت ابوہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ رسول اللہﷺ نے فرمایا : ’’تم دو سخت لعنت والے کاموں"}
{"hadithnumber": "619", "text": "خالد  (  ھذاء )  نے عطاء بن ابی میمونہ سے  ،  انہوں نے حضرت انس بن مالک  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روا"}
{"hadithnumber": "620", "text": "دو مختلف سندوں سے شعبہ سے روایت ہے  ،  انہوں نے عطاء بن ابی میمونہ سے اور انہوں نے حضرت انس  ‌رضی ‌ا"}
{"hadithnumber": "621", "text": "( شعبہ کے بجائے )  روح بن قاسم کی سند سے حضرت انس بن مالک ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ رسول ا"}
{"hadithnumber": "622", "text": "ابو معاویہ نے اعمش سے  ،  انہوں نے ابراہیم نخعی سے  ،  انہون نے ہمام سے روایت کی  ،  انہوں نے کہا :"}
{"hadithnumber": "623", "text": "( ابو معاویہ کے بجائے )  اعمش کے دیگر متعدد شاگردوں عیسیٰ بن یونس  ،  سفیان اور ابن مسہر نے بھی ابو"}
{"hadithnumber": "624", "text": "اعمش نے شقیق سےاور انہوں نے حضرت حذیفہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  انہوں نےکہا  :  میں نبی"}
{"hadithnumber": "625", "text": "منصور نے ابو وائل ( شقیق )  سے روایت کی  ،  انہوں نےکہاکہ حضرت ابو موسیٰ اشعری  ‌رضی ‌اللہ ‌عنہ ‌ ‌"}
{"hadithnumber": "626", "text": "مغیرہ ‌بن ‌شعبہ ‌سے ‌روایت ‌ہے ‌كہ ‌رسول ‌اللہ ‌صلی ‌اللہ ‌علیہ ‌وسلم ‌اپنے ‌كام ‌كو ‌نكلے ‌ان ‌كی ‌"}
{"hadithnumber": "627", "text": "یحییٰ بن سعید کےایک دوسرے شاگرد عبدالوہاب نے اسی سند کے ساتھ مذکورہ بالا روایت بیان کی اور کہا : آپﷺ"}
{"hadithnumber": "628", "text": "اسود بن ھلال نے حضرت مغیرہ بن شعبہ سے روایت کی ‘ انھو ں نے کہا ایک رات میں رسول اللہ ﷺ کے ساتھ تھا ج"}
{"hadithnumber": "629", "text": "ابو معاویہ نے اعمش سے  ،  انہوں نے مسلم  (  بن صبیح ہمدانی )  سے  ،  انہوں نے مسروق سے اور انہوں نے"}
{"hadithnumber": "630", "text": "اعمش سے  (  ابو معاویہ کےبجائے )  عیسیٰ بن یونس )  نےباقی ماندہ سابقہ سند کے ساتھ حضرت مغیرہ بن شعبہ"}
{"hadithnumber": "631", "text": "زکریا نےعامر  ( شعبی )  سے روایت کی  ، کہا  :  مجھے عروہ بن مغیرہ نے اپنے والد حضرت مغیرہ  ‌رضی ‌الل"}
{"hadithnumber": "632", "text": "عامر شعبی کے ایک دوسرے شاگرد عمر بن ابی زائدہ نےعروہ بن مغیرہ کے حوالے سے ان کے والد سے روایت کی کہ"}
{"hadithnumber": "633", "text": "حمید الطویل نے کہا :  ہمیں بکر بن عبد اللہ مزنی نے حدیث بیان کی  ،  انہوں نے عروہ بن مغیرہ بن شعبہ س"}
{"hadithnumber": "634", "text": "امیہ بن بسطام اور محمد بن عبد الاعلیٰ نے کہا :  ہمیں معتمر نے اپنے والد سے حدیث سنائی  ،  کہا : مجھے"}
{"hadithnumber": "635", "text": "محمد بن عبدالاعلیٰ نے کہا :  ہمیں معتمر نے اپنے والد سے حدیث سنائی ،  انہوں نے بکر سے  ،  انہوں نے ح"}
{"hadithnumber": "636", "text": "یحییٰ بن سعید نے  ( سلیمان  )  تیمی سے  ،  انہوں نے بکر بن عبد اللہ سے  ،  انہوں نے حسن سے  ،  انہوں"}
{"hadithnumber": "639", "text": "عبد الرزاق نے کہا :  ہمیں سفیان ثوری نے عمرو بن قیس ملائی سے حدیث سنای ،  انہوں نےحکم بن عتیبہ سے ،"}
{"hadithnumber": "640", "text": "زید بن ابی انیسہ نے حکم سے مذکورہ سند کے ساتھ اس  ( سابقہ حدیث  )  کے مانند حدیث بیان کی  ۔"}
{"hadithnumber": "641", "text": "اعمش نے حکم کے حوالے سے قاسم بن مغیرہ سے اور انہوں نے شریح بن ہانی سے روایت کی  ،  انہوں نے کہا : می"}
{"hadithnumber": "642", "text": "سلیمان بن بریدہ  ( اسلمی  )  نے اپنے والد سے روایت کی نبی اکرم ﷺ نے فتح مکہ کے دن کئی نمازیں ایک وضو"}
{"hadithnumber": "643", "text": "عبد اللہ بن شقیق نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌ سے روایت کی کہ نبی اکرمﷺ نے فرمایا  : ’’جب ت"}
{"hadithnumber": "644", "text": "وکیع اور ابو معاویہ کی سندوں سے اعمش سے روایت ہے  ،  انہوں نے ابو رزین اور ابو صالح سے اور ان دونوں"}
{"hadithnumber": "645", "text": "ابوسلمہ نے ابن مسیب دونوں نے ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  انہوں نے نبی ﷺ سے اسی"}
{"hadithnumber": "646", "text": "جابر  (  بن عبد اللہ )  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ انہوں"}
{"hadithnumber": "647", "text": "اعرج  ،  محمد ،  علاء کے والد عبد الرحمان بن یعقوب  ،  ہمام بن منبہ اور ثابت بن عیاض  ( سب  ) نےکہا"}
{"hadithnumber": "648", "text": "علی بن مسہر نے حدیث بیان کی کہ ہمیں اعمش نے ابو زرین اور ابو صالح سے خبر دی  ،  ان دونوں نے حضرت ابو"}
{"hadithnumber": "649", "text": "اسماعیل بن زکریا نے اعمش کےحوالے سے  ،  باقی ماندہ مذکورہ سند کے ساتھ  ،  یہی روایت بیان کی لیکن ’’ا"}
{"hadithnumber": "650", "text": "اعرج نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سےروایت بیان کی کہ رسول اللہ ﷺ نے فرمایا  : ’’جب کتا تم"}
{"hadithnumber": "651", "text": "محمد بن سیرین نے حضرت ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ رسول اللہ ﷺ نے فرمایا  : ’’جب تم"}
{"hadithnumber": "652", "text": "ہمام بن منبہ نے کہا :  یہ احادیث ہیں جو ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے ہمیں محمد رسو ل اللہ ﷺ سے"}
{"hadithnumber": "653", "text": "عبید اللہ بن معاذ نے ہمیں اپنےوالد سے حدیث بیان کی  ( کہا :  ) ہمیں میرے والد نے  ،  انہیں شعبہ نے ا"}
{"hadithnumber": "654", "text": "( خالد  )  بن حارث  ،  یحییٰ بن سعید اور محمد بن جعفر  ،  سب نے شعبہ سے اسی سند سے اس  (  سابقہ حدیث"}
{"hadithnumber": "655", "text": "حضرت جابر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے رسول اللہ ﷺ سے حدیث بیان کی کہ آپﷺ نےکھڑے ہوئے پانی میں پیشاب کرن"}
{"hadithnumber": "656", "text": "ابن سیرین نے ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے اور انہوں نے نبی ﷺ سے روایت کی  ،  آپ نے فرمایا : ’’"}
{"hadithnumber": "657", "text": "ہمام بن منبہ نے کہا :  یہ احادیث ہیں جو حضرت ابوہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے ہمیں محمد ﷺ سے بیان ک"}
{"hadithnumber": "658", "text": "بکیر بن اشج سے روایت ہے کہ ہشام بن زہرہ کے آزادکردہ غلام ابو سائب نے انہیں حدیث سنائی  کہ انہو ں نےح"}
{"hadithnumber": "659", "text": "ثابت نے حضرت انس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سےروایت کی کہ ایک بدوی نے مسجد میں پیشاب  ( کرنا شروع  )  کر"}
{"hadithnumber": "660", "text": "یحییٰ بن سعید نے حضرت انس بن مالک  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے سنا ،  وہ بیان کر رہے تھے کہ ایک بدوی مسج"}
{"hadithnumber": "661", "text": "اسحاق بن ابی طلحہ نے روایت کی  ، کہا  :  مجھ سے حضرت انس بن مالک  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نےبیان کیا ،"}
{"hadithnumber": "662", "text": "عبداللہ بن نمیر نےہشام سے  ،  انہوں نے اپنے والد (  عروج بن زبیر )  سے اور انہوں نے نبی ﷺ کی زوجہ  ("}
{"hadithnumber": "663", "text": "جریر نے ہشام سے روایت کی  ، انہو نے اپنے والد سے اور انہو ں نے حضرت عائشہ ؓ سے روایت کی  ،  انہوں نے"}
{"hadithnumber": "664", "text": "ہشام کے ایک او رشاگرد عیسیٰ نے ہشام کی اسی سند سے ابن نمیر کی روایت  (  : 662 )  کے مطابق روایت بیان"}
{"hadithnumber": "665", "text": "لیث نے ابن شہاب سے خبر دی ،  انہوں عبید اللہ بن عبد اللہ سے  ،  انہوں نے حضرت ام قیس بنت محصن  ‌رضی"}
{"hadithnumber": "666", "text": "سفیان بن عیینہ نے زہری سے اسی سند کے ساتھ  (  مذکورہ بالا )  روایت کی اور کہا :  آپ نے پانی منگوایا"}
{"hadithnumber": "667", "text": "یونس بن یزید نے کہا :  مجھے ابن شہاب نے خبر دی ،  کہا :  مجھے عبید اللہ بن عبد اللہ بن عتبہ بن مسعود"}
{"hadithnumber": "668", "text": "خالد نے ابومعشر سے  ،  انہوں نے ابراہیم نخعی سے  ،  انہوں نے علقمہ اور اسود سے روایت کی کہ ایک آدمی"}
{"hadithnumber": "669", "text": "اعمش نے ابراہیم سے  ،  انہوں نے اسود اور ہمام سے  ،  انہوں نے حضرت عائشہ ؓ سے مادہ منویہ کے بارے میں"}
{"hadithnumber": "670", "text": "( خالد کی بجائے )  ابومعشر کے دوسرے شاگرد ہشام بن حسان اور ابن ابی عروبہ نے خالد کے ہم معنی روایت کی"}
{"hadithnumber": "671", "text": "ابن عیینہ نے منصور سے  ،  انہوں نے ابراہیم سے  ،  انہوں نے ہمام سے  ،  انہوں نے حضرت عائشہ سے مذکورہ"}
{"hadithnumber": "672", "text": "محمد بن بشر نے عمرو بن میمون سے روایت کی  ،  انہوں نے کہا کہ میں نے سلیمان بن یسار سے آدمی کے کپڑے ک"}
{"hadithnumber": "673", "text": "عبدالواحد بن زیاد ،  ابن مبارک اور ابن ابی زائدہ نے عمرو بن میمون سے سابقہ سندکے ساتھ یہی حدیث بیان"}
{"hadithnumber": "674", "text": "عبد اللہ بن شہاب خولانی سےر وایت ہے  ،  کہا :  میں حضرت عائشہ ؓ کا مہمان تھا ،  مجھے اپنے دونوں کپڑو"}
{"hadithnumber": "675", "text": "وکیع نے بیان کیا  ،  ہمیں ہشام نے حدیث سنائی :  اور یحییٰ بن سعید نے ہشام بن عروہ سے روایت کی  ،  کہ"}
{"hadithnumber": "676", "text": "یحییٰ بن عبد اللہ بن سالم  ،  مالک بن انس اور عمرو بن حارث تینوں نے ہشام بن عروہ کی مذکورہ بالا سند"}
{"hadithnumber": "677", "text": "وکیع نے بیان کیا  ،  ( کہا :  )  ہمیں اعمش نے حدیث سنائی  ،  انہوں نے کہا  :  میں نے مجاہد کو طاؤس س"}
{"hadithnumber": "678", "text": "عبدالواحدنے اسی سند سے سلیمان اعمش سے مذکورہ بالا حدیث روایت کی  ،  سوائے اس کے کہ کہا :  اور دوسرا"}
