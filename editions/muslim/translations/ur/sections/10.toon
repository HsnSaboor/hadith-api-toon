{"hadithnumber": "2089", "text": "امام مالک بن انس اور عبد اللہ بن نمیر نے کہا :  ہمیں ہشام نے اپنے والد عروہ سے حدیث سنا ئی انھوں نے"}
{"hadithnumber": "2090", "text": "ابو معاویہ نے ہشام بن عروہ سے اسی سند کے ساتھ  ( سابقہ حدیث کے مانند  )  روایت کی اور اس میں یہ اضاف"}
{"hadithnumber": "2091", "text": "حرملہ بن یحییٰ نے مجھے حدیث بیان کی  ،  ( کہا  )  مجھے ابن وہب نے یونس سے خبر دی نیز ابو طاہر اور مح"}
{"hadithnumber": "2092", "text": "ابو عمرو اوزاعی اور ان کے علاوہ د وسرے ( راوی ، دونوں میں سے ہرایک ) نے کہا : میں نے ابن شہاب زہری س"}
{"hadithnumber": "2094", "text": "۔  ( عبدالرحمان بن نمر نے ہی کہا :  ) زہری نے کہا : کثیر بن عباس  رضی اللہ تعالیٰ عنہ  نے ( اپنے بھا"}
{"hadithnumber": "2095", "text": "محمد بن ولید زبیدی نے زہری سے روایت کی ، انھوں نے کہا : کثیر بن عباس  رضی اللہ تعالیٰ عنہ  حدیث بیان"}
{"hadithnumber": "2096", "text": "ابن جریج نے کہا : میں نے عطاء ( بن ابی رباح )  کو کہتے ہوئے سنا : میں نے عبید بن عمیر سے سنا ، کہہ ر"}
{"hadithnumber": "2097", "text": "قتادہ نے عطاء بن ابی رباح سے ، انھوں نے عبید بن عمیر سے اور انھوں نے حضر ت عائشہ  رضی اللہ تعالیٰ عن"}
{"hadithnumber": "2098", "text": "سلیمان بن بلال نے یحییٰ ( بن سعید )  سے اور انھوں نے عمرہ سے روایت کی کہ ایک یہودی عورت حضرت عائشہ"}
{"hadithnumber": "2099", "text": "عبدالوہاب اور سفیان نے یحییٰ بن سعید سے اسی سند کے ساتھ سلیمان بن بلال کی حدیث کے ہم معنی روایت بیان"}
{"hadithnumber": "2102", "text": "ابو بکر بن ابی شیبہ نے کہا : ہم سے عبداللہ بن نمیر نے حدیث بیان کی ، نیز محمد بن عبداللہ نمیر نے حدی"}
{"hadithnumber": "2103", "text": "ہمیں  ( عبداللہ )  ابن نمیر نے حدیث بیان کی ، کہا : ہم سے ہشام نے ، انھوں نے  ( اپنی بیوی ) فاطمہ ("}
{"hadithnumber": "2106", "text": "خالد بن حارث نے کہا :  ہم سے ابن جریج  نے حدیث بیان کی  ،  ( انھوں نے کہا :  )  مجھ سے منصور بن عبدا"}
{"hadithnumber": "2107", "text": "یحیٰ اموی نے کہا :  ہم سے ا بن جریج نے اسی سند کے ساتھ اسی  ( سابقہ  حدیث  )  کے مانند حدیث بیان کی"}
{"hadithnumber": "2108", "text": "وہیب نے کہا : ہمیں منصور نے اپنی والدہ ( صفیہ )  سے حدیث بیان کی ، انھوں نے اسماء بنت ابی بکر  رضی ا"}
{"hadithnumber": "2109", "text": "حفص بن میسرہ نے کہا : زید بن اسلم نے مجھے عطاء بن یسار سے حدیث بیان کی ، انھوں نے حضرت ابن عباس  رضی"}
{"hadithnumber": "2110", "text": "امام مالک نے زید بن اسلم سے اسی سند کے ساتھ اس  ( مذکورہ حدیث )  کے مانند روایت کی ، البتہ انھوں نے"}
{"hadithnumber": "2111", "text": "اسماعیل ابن علیہ نے سفیان سے ، انھوں نے حبیب  بن ابی ثابت سے ، انھوں نے طاوس سے اور انھوں نے حضرت اب"}
{"hadithnumber": "2112", "text": "یحییٰ نے سفیان سے حدیث بیان کی ، انھوں نے کہا : ہمیں حبیب نے  طاوس سے حدیث سنائی ، انھوں نے حضرت ابن"}
{"hadithnumber": "2113", "text": "حضرت عبداللہ بن عمرو بن عاص  رضی اللہ تعالیٰ عنہ  نے کہا : کہ جب رسول اللہ  صلی اللہ علیہ وسلم  کے ز"}
{"hadithnumber": "2114", "text": "ہشیم نے اسماعیل سے ، انھوں نے قیس بن ابی حازم سے ، اور انھوں نے ابو مسعود انصاری رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "2115", "text": "معتمر نے اسماعیل سے ، انھوں نے قیس سے اور انھوں نے حضرت ابو مسعود  رضی اللہ تعالیٰ عنہ  سے  روایت کی"}
{"hadithnumber": "2116", "text": "وکیع ، ابواسامہ ، ابن نمیر ، جریر ، سفیان ، اورمروان سب نے اسماعیل سے اسی سند کے ساتھ روایت کی ، سفی"}
{"hadithnumber": "2117", "text": "ابو عامر اشعری عبداللہ بن براد اور محمد بن علاء نے کہا : ہمیں ابو اسامہ نے برید سے حدیث سنائی ، انھو"}
{"hadithnumber": "2118", "text": "بشر بن مفضل نے کہا : جریری نے ہمیں ابو علاء حیان بن عمیر سے حدیث بیان کی ، انھوں نے حضرت عبدالرحمان"}
{"hadithnumber": "2119", "text": "عبدالاعلیٰ بن عبدالاعلیٰ نے جریری سے ، انھوں نے حیان بن نمیر سے اور انھوں نے حضرت عبدالرحمان بن سمرہ"}
{"hadithnumber": "2120", "text": "سالم بن نوح نے کہا : ہمیں جریری نے حیان بن عمیر سے خبر دی اور انھوں نے عبدالرحمان بن سمرہ  رضی اللہ"}
{"hadithnumber": "2121", "text": "حضرت عبداللہ بن عمر  رضی اللہ تعالیٰ عنہ  سے روایت ہے  ، وہ رسول اللہ  صلی اللہ علیہ وسلم  سے یہ خبر"}
{"hadithnumber": "2122", "text": "حضرت مغیرہ بن شعبہ  رضی اللہ تعالیٰ عنہ   فرماتے ہیں کہ رسول اللہ  صلی اللہ علیہ وسلم کے عہد مبارک م"}
