{"hadithnumber": "2290", "text": "اور ابوالزناد نے بیان کیا، ان سے محمد بن حمزہ بن عمرو الاسلمی نے اور ان سے ان کے والد (حمزہ) نے کہ ع"}
{"hadithnumber": "2291", "text": "ابوعبداللہ (امام بخاری رحمہ اللہ) نے کہا کہ لیث نے بیان کیا، ان سے جعفر بن ربیعہ نے، ان سے عبدالرحمٰ"}
{"hadithnumber": "2292", "text": "ہم سے صلت بن محمد نے بیان کیا، کہا کہ ہم سے ابواسامہ نے بیان کیا، ان سے ادریس نے، ان سے طلحہ بن مصرف"}
{"hadithnumber": "2293", "text": "ہم سے قتیبہ نے بیان کیا، کہا کہ ہم سے اسماعیل بن جعفر نے بیان کیا، ان سے حمید نے اور ان سے انس رضی ا"}
{"hadithnumber": "2294", "text": "ہم سے محمد بن صباح نے بیان کیا، کہا ہم سے اسماعیل بن زکریا نے بیان کیا، ان سے عاصم بن سلیمان نے بیان"}
{"hadithnumber": "2295", "text": "ہم سے ابوعاصم نے بیان کیا، ان سے یزید بن ابی عبید نے، ان سے سلمہ بن اکوع رضی اللہ عنہ نے کہ  نبی کری"}
{"hadithnumber": "2296", "text": "ہم سے علی بن عبداللہ مدینی نے بیان کیا، ان سے سفیان بن عیینہ نے بیان کیا، ان سے عمرو بن دینار نے بیا"}
{"hadithnumber": "2297", "text": "ہم سے یحییٰ بن بکیر نے بیان کیا، کہا کہ ہم سے لیث بن سعد نے بیان کیا، ان سے عقیل نے کہ ابن شہاب نے ب"}
{"hadithnumber": "2298", "text": "ہم سے یحییٰ بن بکیر نے بیان کیا، کہا کہ ہم سے لیث نے بیان کیا، ان سے عقیل نے، ان سے ابن شہاب نے، ان"}
