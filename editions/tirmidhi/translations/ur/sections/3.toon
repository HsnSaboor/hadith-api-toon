{"hadithnumber": "452", "text": "خارجہ بن حذافہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم  ( حجرے سے نکل کر )  ہمارے پاس"}
{"hadithnumber": "453", "text": "علی رضی الله عنہ کہتے ہیں  وتر تمہاری فرض نماز کی طرح لازمی نہیں ہے ۱؎، بلکہ رسول اللہ صلی اللہ علیہ"}
{"hadithnumber": "454", "text": "علی رضی الله عنہ کہتے ہیں:  وتر لازم نہیں ہے جیسا کہ فرض صلاۃ کا معاملہ ہے، بلکہ یہ رسول اللہ صلی ال"}
{"hadithnumber": "455", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  مجھے رسول اللہ صلی اللہ علیہ وسلم نے حکم دیا کہ میں وتر سونے سے پ"}
{"hadithnumber": "456", "text": "جابر رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”تم میں سے جسے اندیشہ ہو کہ"}
{"hadithnumber": "457", "text": "مسروق سے روایت ہے کہ  انہوں نے ام المؤمنین عائشہ رضی الله عنہا سے رسول اللہ صلی اللہ علیہ وسلم کے وت"}
{"hadithnumber": "458", "text": "ام المؤمنین ام سلمہ رضی الله عنہا کہتی ہیں  نبی اکرم صلی اللہ علیہ وسلم وتر تیرہ رکعت پڑھتے تھے لیکن"}
{"hadithnumber": "459", "text": "ام المؤمنین عائشہ رضی الله عنہا کہتی ہیں:  نبی اکرم صلی اللہ علیہ وسلم کی قیام اللیل  ( تہجد )  تیرہ"}
{"hadithnumber": "460", "text": "علی رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم تین رکعت وتر پڑھتے تھے، ان میں مفصل میں سے"}
{"hadithnumber": "461", "text": "انس بن سیرین کہتے ہیں کہ  میں نے ابن عمر رضی الله عنہما سے پوچھا: کیا میں فجر کی دو رکعت سنت لمبی پڑ"}
{"hadithnumber": "462", "text": "عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم وتر میں «‏سبح اسم ربك الأعلى"}
{"hadithnumber": "463", "text": "عبدالعزیز بن جریج کہتے ہیں کہ  ہم نے عائشہ رضی الله عنہا سے پوچھا: رسول اللہ صلی اللہ علیہ وسلم وتر"}
{"hadithnumber": "464", "text": "حسن بن علی رضی الله عنہما کہتے ہیں کہ  مجھے رسول اللہ صلی اللہ علیہ وسلم نے یہ کلمات سکھائے جنہیں می"}
{"hadithnumber": "465", "text": "ابو سعید خدری رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جو وتر پڑھے بغیر سو"}
{"hadithnumber": "466", "text": "زید بن اسلم (مرسلاً) کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جو وتر پڑھے بغیر سو جائے،"}
{"hadithnumber": "467", "text": "عبداللہ بن عمر رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”صبح ہونے سے پہ"}
{"hadithnumber": "468", "text": "ابو سعید خدری رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”صبح ہونے سے پہلے وت"}
{"hadithnumber": "469", "text": "عبداللہ بن عمر رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جب فجر طلوع ہو"}
{"hadithnumber": "470", "text": "طلق بن علی رضی الله عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا: ”ایک رات میں"}
{"hadithnumber": "471", "text": "ام المؤمنین ام سلمہ رضی الله عنہا کہتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم وتر کے بعد دو رکعتیں پڑھت"}
{"hadithnumber": "472", "text": "سعید بن یسار کہتے ہیں کہ  میں ایک سفر میں ابن عمر رضی الله عنہما کے ساتھ چل رہا تھا، میں ان سے پیچھے"}
{"hadithnumber": "473", "text": "انس بن مالک رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے چاشت کی بارہ رک"}
{"hadithnumber": "474", "text": "عبدالرحمٰن بن ابی لیلیٰ کہتے ہیں کہ  مجھے صرف ام ہانی رضی الله عنہا نے خبر دی کہ انہوں نے رسول اللہ"}
{"hadithnumber": "475", "text": "ابو الدرداء رضی الله عنہ یا ابوذر رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمای"}
{"hadithnumber": "476", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے چاشت کی دو رکعتوں"}
{"hadithnumber": "477", "text": "ابو سعید خدری رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم چاشت کی نماز پڑھتے تھے۔ یہاں تک"}
{"hadithnumber": "478", "text": "عبداللہ بن سائب رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم سورج ڈھل جانے کے بعد ظہر سے پ"}
{"hadithnumber": "479", "text": "عبداللہ بن ابی اوفی رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جسے اللہ تع"}
{"hadithnumber": "480", "text": "جابر بن عبداللہ رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ہمیں ہر معاملے میں استخارہ"}
{"hadithnumber": "481", "text": "انس بن مالک رضی الله عنہ کہتے ہیں کہ  ام سلیم رضی الله عنہا نے نبی اکرم صلی اللہ علیہ وسلم کے پاس آ"}
{"hadithnumber": "482", "text": "ابورافع رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے  ( اپنے چچا )  عباس رضی الله عنہ س"}
{"hadithnumber": "483", "text": "کعب بن عجرہ رضی الله عنہ کہتے ہیں کہ  ہم نے عرض کیا، اللہ کے رسول! آپ پر سلام بھیجنا تو ہم نے جان لی"}
{"hadithnumber": "484", "text": "عبداللہ بن مسعود رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”قیامت کے دن مجھ"}
{"hadithnumber": "485", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جو مجھ پر ایک بار صلاۃ"}
{"hadithnumber": "486", "text": "عمر بن خطاب رضی الله عنہ کہتے ہیں کہ  دعا آسمان اور زمین کے درمیان رکی رہتی ہے، اس میں سے ذرا سی بھ"}
{"hadithnumber": "487", "text": "عمر بن خطاب رضی الله عنہ کہتے ہیں  ہمارے بازار میں کوئی خرید و فروخت نہ کرے جب تک کہ وہ دین میں خوب"}
