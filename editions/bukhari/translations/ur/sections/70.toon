{"hadithnumber": "5450", "text": "سے صلت بن محمد نے بیان کیا، کہا ہم سے حماد بن زید نے، ان سے جعد ابوعثمان نے ان سے انس رضی اللہ عنہ ن"}
{"hadithnumber": "5451", "text": "ہم سے مسدد نے بیان کیا، کہا ہم سے عبدالوارث نے بیان کیا، ان سے عبدالعزیز نے بیان کیا کہ  انس رضی الل"}
{"hadithnumber": "5452", "text": "ہم سے علی بن عبداللہ نے بیان کیا، کہا ہم سے ابوصفوان عبداللہ بن سعید نے بیان کیا، کہا ہم کو یونس نے"}
{"hadithnumber": "5453", "text": "ہم سے سعید بن عفیر نے بیان کیا، کہا ہم سے ابن وہب نے بیان کیا، ان سے یونس نے، ان سے ابن شہاب نے بیان"}
{"hadithnumber": "5454", "text": "ہم سے علی بن عبداللہ مدینی نے بیان کیا، کہا ہم سے سفیان ثوری نے بیان کیا، انہوں نے یحییٰ بن سعید سے"}
{"hadithnumber": "5455", "text": "یحییٰ نے بیان کیا کہ میں نے بشیر سے سنا، انہوں نے بیان کیا ہم سے سوید رضی اللہ عنہ نے بیان کیا  ہم ر"}
{"hadithnumber": "5456", "text": "ہم سے علی بن عبداللہ نے بیان کیا، انہوں نے کہا ہم سے سفیان نے بیان کیا، ان سے عمرو بن دینار نے، ان س"}
{"hadithnumber": "5457", "text": "ہم سے ابراہیم بن المنذر نے بیان کیا، کہا کہ مجھ سے محمد بن فلیح نے بیان کیا، کہا کہ مجھ سے میرے والد"}
{"hadithnumber": "5458", "text": "ہم سے ابونعیم نے بیان کیا، کہا ہم سے سفیان نے بیان کیا، ان سے ثور نے، ان سے خالد بن معدان نے اور ان"}
{"hadithnumber": "5459", "text": "ہم سے ابوعاصم نے بیان کیا، ان سے ثور بن یزید نے بیان کیا، ان سے خالد بن معدان نے اور ان سے ابوامامہ"}
{"hadithnumber": "5460", "text": "ہم سے حفص بن عمر نے بیان کیا، کہا ہم سے شعبہ نے بیان کیا، ان سے محمد نے، وہ زیاد کے صاحبزادے ہیں، کہ"}
{"hadithnumber": "5461", "text": "ہم سے عبداللہ بن ابی اسود نے بیان کیا، کہا ہم سے ابواسامہ نے، ان سے اعمش نے، ان سے شقیق نے، اور ان س"}
{"hadithnumber": "5462", "text": "ہم سے ابوالیمان نے بیان کیا، کہا ہم کو شعیب نے خبر دی، انہیں زہری نے اور لیث نے بیان کیا، کہا انہوں"}
{"hadithnumber": "5463", "text": "ہم سے معلی بن اسد نے بیان کیا، انہوں نے کہا ہم سے وہیب نے بیان کیا، ان سے ایوب نے، ان سے ابوقلابہ نے"}
{"hadithnumber": "5464", "text": "اور ایوب سے روایت ہے، ان سے نافع نے کہ  ابن عمر رضی اللہ عنہما نے ایک مرتبہ رات کا کھانا کھایا اور ا"}
{"hadithnumber": "5465", "text": "ہم سے محمد بن یوسف نے بیان کیا، کہا ہم سے سفیان نے بیان کیا، ان سے ہشام بن عروہ نے، ان سے ان کے والد"}
{"hadithnumber": "5466", "text": "مجھ سے عبداللہ بن محمد نے بیان کیا، کہا ہم سے یعقوب بن ابراہیم نے بیان کیا، کہا کہ مجھ سے میرے والد"}
