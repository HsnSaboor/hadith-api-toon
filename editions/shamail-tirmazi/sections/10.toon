metadata:

hadiths[11]{hadithnumber,arabic,bengali,english,french,indonesian,russian,urdu,grades,reference,international_number,narrator_chain,chapter_intro}:
{"hadithnumber": "74", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، قَالَ‏:‏ حَدَّثَنَا أَبُو دَاوُدَ الطَّيَالِسِيُّ، قَالَ‏:‏ حَدَّثَنَا هَمَّامٌ، عَنْ، قَالَ‏:‏ قُلْتُ لأَنَسِ بْنِ مَالِكٍ‏:‏ كَيْفَ كَانَ نَعْلُ رَسُولِ اللهِ صلى الله عليه وسلم‏؟‏ قَالَ‏:‏ لَهُمَا قِبَالانِ‏.‏", "bengali": "", "english": "‘How were the sandals of Allah’s Messenger (Allah bless him and give him peace)?’ He said: ‘They had two thongs'.”", "french": "", "indonesian": "", "russian": "", "urdu": "’’ قتادۃ فرماتے ہیں : میں نے سیدنا انس بن مالک رضی اللہ عنہ سے پوچھا کہ نبی اکرم صلی اللہ علیہ وسلم کے پاپوش مبارک کیسے تھے؟ تو انہوں نے فرمایا: آپ صلی اللہ علیہ وسلم کے پاپوش مبارک کے ہر کفش میں دوتسمے تھے۔ ‘‘", "grades": "", "reference": "", "international_number": "74", "narrator_chain": "", "chapter_intro": "The Khuff (Leather Socks) Of Rasoolullah"}
{"hadithnumber": "75", "arabic": "حَدَّثَنَا أَبُو كُرَيْبٍ مُحَمَّدُ بْنُ الْعَلاءِ، قَالَ‏:‏ حَدَّثَنَا وَكِيعٌ، عَنْ سُفْيَانَ، عَنْ خَالِدٍ الْحَذَّاءِ، عَنْ عَبْدِ اللهِ بْنِ الْحَارِثِ، عَنِ ابْنِ عَبَّاسٍ، قَالَ‏:‏ كَانَ لِنَعْلِ رَسُولِ اللهِ صلى الله عليه وسلم قِبَالانِ، مَثْنِيٌّ شِرَاكَهُمَا‏.‏", "bengali": "", "english": "\"The sandals of Allah’s Messenger (Allah bless him and give him peace) had two thongs with double laces.”", "french": "", "indonesian": "", "russian": "", "urdu": "’’ سیدنا ابن عباس رضی اللہ عنہما سے مروی ہے، وہ فرماتے ہیں کہ رسول اللہ صلی اللہ علیہ وسلم کے پاپوش مبارک کے دونوں تسمے دوہرے تھے۔ ‘‘", "grades": "", "reference": "", "international_number": "75", "narrator_chain": "", "chapter_intro": "The Khuff (Leather Socks) Of Rasoolullah"}
{"hadithnumber": "76", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، قَالَ‏:‏ حَدَّثَنَا أَبُو أَحْمَدَ الزُّبَيْرِيُّ، قَالَ‏:‏ حَدَّثَنَا عِيسَى بْنُ طَهْمَانَ، قَالَ‏:‏ أَخْرَجَ إِلَيْنَا أَنَسُ بْنُ مَالِكٍ نَعْلَيْنِ جَرْدَاوَيْنِ، لَهُمَا قِبَالانِ‏.‏ قَالَ : فَحَدَّثَنِي ثَابِتٌ بَعْدُ عَنْ أَنَسُ ، أَنَّهُمَا كَانَتَا نَعْلَيِ النَّبِيِّ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ .", "bengali": "", "english": "\"Anas ibn Malik brought out to us a pair of hairless sandals with two thongs. Then Thabit told me afterwards, on the authority of Anas, that they were the sandals of the Prophet (Allah bless him and give him peace).”", "french": "", "indonesian": "", "russian": "", "urdu": "’’ عیسی بن طہمان فرماتے ہیں : سیدنا انس بن مالک رضی اللہ عنہ نے ہمیں دو جوتے نکال کر دکھائے، جن پر بال نہیں تھے اور ان دونوں کے دو تسمے تھے۔ اس کے بعد مجھے ثابت نے سیدنا انس رضی اللہ عنہ سے بیان کیا کہ یہ دونوں جوتے نبی اکرم صلی اللہ علیہ وسلم کے تھے۔ ‘‘", "grades": "", "reference": "", "international_number": "76", "narrator_chain": "", "chapter_intro": "The Khuff (Leather Socks) Of Rasoolullah"}
{"hadithnumber": "77", "arabic": "حَدَّثَنَا إِسْحَاقُ بْنُ مُوسَى الأَنْصَارِيُّ، قَالَ‏:‏ حَدَّثَنَا مَعْنٌ، قَالَ‏:‏ حَدَّثَنَا مَالِكٌ، قَالَ‏:‏ حَدَّثَنَا سَعِيدُ بْنُ أَبِي سَعِيدٍ الْمَقْبُرِيُّ، عَنْ عُبَيْدِ بْنِ جُرَيْجٍ، أَنَّهُ قَالَ لابْنِ عُمَرَ‏:‏ رَأَيْتُكَ تَلْبَسُ النِّعَالَ السِّبْتِيَّةَ، قَالَ‏:‏ إِنِّي رَأَيْتُ رَسُولَ اللهِ صلى الله عليه وسلم يَلْبَسُ النِّعَالَ الَّتِي لَيْسَ فِيهَا شَعَرٌ، وَيَتَوَضَّأُ فِيهَا، فَأَنَا أُحِبُّ أَنْ أَلْبَسَهَا‏.‏", "bengali": "", "english": "\"I saw you wearing the tanned ox-hide sandals with no hair on them .\" He replied: I saw Allah’s Messenger (Allah bless him and give him peace) wearing the sandals on which there is no hair", "french": " and he performed the minor ritual ablution in them", "indonesian": " so I love to wear them!”\"", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "", "chapter_intro": ""}
{"hadithnumber": "78", "arabic": "حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ، قَالَ‏:‏ حَدَّثَنَا عَبْدُ الرَّزَّاقِ، عَنْ مَعْمَرٍ، عَنِ ابْنِ أَبِي ذِئْبٍ، عَنْ صَالِحٍ مَوْلَى التَّوْءَمَةِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ‏:‏ كَانَ لِنَعْلِ رَسُولِ اللهِ صلى الله عليه وسلم قِبَالانِ‏.‏", "bengali": "", "english": "\"The sandals of Allah’s Messenger (Allah bless him and give him peace) had two thongs.\"", "french": "", "indonesian": "", "russian": "", "urdu": "’’ سیّدنا ابوہریرہ رضی اللہ عنہ فرماتے ہیں : رسول اللہ صلی اللہ علیہ وسلم کے جوتے کے دو تسمے تھے۔ ‘‘", "grades": "", "reference": "", "international_number": "78", "narrator_chain": "", "chapter_intro": "The Khuff (Leather Socks) Of Rasoolullah"}
{"hadithnumber": "79", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، قَالَ‏:‏ حَدَّثَنَا أَبُو أَحْمَدَ، قَالَ‏:‏ حَدَّثَنَا سُفْيَانُ، عَنِ السُّدِّيِّ، قَالَ‏:‏ حَدَّثَنِي مَنْ، سَمِعَ عَمْرَو بْنَ حُرَيْثٍ، يَقُولُ‏:‏ رَأَيْتُ رَسُولَ اللهِ صلى الله عليه وسلم، يُصَلِّي فِي نَعْلَيْنِ مَخْصُوفَتَيْنِ‏.‏", "bengali": "", "english": "\"I saw Allah's Messenger (Allah bless him and give him peace) performing the ritual prayer in sewn sandals.”", "french": "", "indonesian": "", "russian": "", "urdu": "’’ سیدنا عمر وبن حریث رضی اللہ عنہ فرماتے ہیں : میں نے رسول اللہ صلی اللہ علیہ وسلم کو دیکھا کہ وہ دو ایسے جوتوں میں نماز پڑھ رہے ہیں جن میں پیوند لگے ہوئے تھے۔ ‘‘", "grades": "", "reference": "", "international_number": "79", "narrator_chain": "", "chapter_intro": "The Khuff (Leather Socks) Of Rasoolullah"}
{"hadithnumber": "80", "arabic": "حَدَّثَنَا إِسْحَاقُ بْنُ مُوسَى الأَنْصَارِيُّ، قَالَ‏:‏ حَدَّثَنَا مَعْنٌ، قَالَ‏:‏ حَدَّثَنَا مَالِكٌ، عَنْ أَبِي الزِّنَادِ، عَنِ الأَعْرَجِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللهِ صلى الله عليه وسلم، قَالَ‏:‏ لا يَمْشِيَنَّ أَحَدُكُمْ فِي نَعْلٍ وَاحِدَةٍ، لِيُنْعِلْهُمَا جَمِيعًا، أَوْ لِيُحْفِهِمَا جَمِيعًا‏.‏ حَدَّثَنَا قُتَيْبَةُ، عَنْ مَالِكِ بْنِ أَنَسٍ، عَنْ أَبِي الزِّنَادِ نَحْوَهُ‏.‏\"", "bengali": "", "english": "“Let none of you walk in a single sandal. Let him wear them both or take them both off!”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "", "chapter_intro": "The Khuff (Leather Socks) Of Rasoolullah"}
{"hadithnumber": "81", "arabic": "حَدَّثَنَا إِسْحَاقُ بْنُ مُوسَى، قَالَ‏:‏ حَدَّثَنَا مَعْنٌ، قَالَ‏:‏ حَدَّثَنَا مَالِكٌ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، أَنَّ النَّبِيَّ صلى الله عليه وسلم نَهَى أَنْ يَأْكُلَ، يَعْنِي الرَّجُلَ، بِشِمَالِهِ، أَوْ يَمْشِيَ فِي نَعْلٍ وَاحِدَةٍ‏.‏", "bengali": "", "english": "“The Prophet (Allah bless him and give him peace) forbade one (referring to the man) to eat with his left hand, or to walk in a single sandal.”", "french": "", "indonesian": "", "russian": "", "urdu": "’’ سیدنا جابر رضی اللہ عنہ فرماتے ہیں : نبی اکرم صلی اللہ علیہ وسلم نے منع فرمایا کہ کوئی آدمی بائیں ہاتھ سے کھانا کھائے یا ایک جوتے میں چلے۔ ‘‘", "grades": "", "reference": "", "international_number": "81", "narrator_chain": "", "chapter_intro": "The Khuff (Leather Socks) Of Rasoolullah"}
{"hadithnumber": "82", "arabic": "حَدَّثَنَا قُتَيْبَةُ، حوَحَدَّثَنَا إِسْحَاقُ بْنُ مُوسَى، قَالَ‏:‏ حَدَّثَنَا مَعْنٌ، قَالَ‏:‏ حَدَّثَنَا مَالِكٌ، عَنْ أَبِي الزِّنَادِ، عَنِ الأَعْرَجِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ النَّبِيَّ صلى الله عليه وسلم، قَالَ‏:‏ إِذَا انْتَعَلَ أَحَدُكُمْ فَلْيَبْدَأْ بِالْيَمِينِ، وَإِذَا نَزَعَ فَلْيَبْدَأْ بِالشِّمَالِ، فَلْتَكُنِ الْيَمِينُ أَوَّلَهُمَا تُنْعَلُ، وَآخِرَهُمَا تُنْزَعُ‏.‏", "bengali": "", "english": "“The Prophet said (Allah bless him and give him peace): \"When one of you puts on sandals, let him begin with the right, and when he takes them off, let him begin with the left, for the right must be the first of them to be put on, and the last of them to be taken off.”", "french": "", "indonesian": "", "russian": "", "urdu": "’’ سیدنا ابوہریرہ رضی اللہ عنہ سے مروی ہے، وہ فرماتے ہیں کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: تم میں سے جب کوئی جوتا پہنے تو دائیں جانب سے شروع کر ے اور جب اتارے تو بائیں جانب سے شروع کرے، پہننے کے لحاظ سے دایاں پاؤں پہلے، اور اتارنے کے لحاظ سے دایاں پاؤں آخر میں ہونا چاہیے۔ ‘‘", "grades": "", "reference": "", "international_number": "82", "narrator_chain": "", "chapter_intro": "The Khuff (Leather Socks) Of Rasoolullah"}
{"hadithnumber": "83", "arabic": "حَدَّثَنَا أَبُو مُوسَى مُحَمَّدُ بْنُ الْمُثَنَّى، قَالَ‏:‏ حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، قَالَ‏:‏ حَدَّثَنَا شُعْبَةُ، قَالَ‏:‏ حَدَّثَنَا أَشْعَثُ هُوَ ابْنُ أَبِي الشَّعْثَاءِ، عَنْ أَبِيهِ، عَنْ مَسْرُوقٍ، عَنْ عَائِشَةَ، قَالَتْ‏:‏ كَانَ رَسُولُ اللهِ صلى الله عليه وسلم يُحِبُّ التَّيَمُّنَ مَا اسْتَطَاعَ فِي تَرَجُّلِهِ، وَتَنَعُّلِهِ وَطُهُورِهِ‏.‏", "bengali": "", "english": "\"Allah’s Messenger (Allah bless him and give him peace) would love to start whatever he could on the right side, in his combing, his footwear and his purification.”", "french": "", "indonesian": "", "russian": "", "urdu": "’’ ام المؤمنین سیدہ عائشہ صدیقہ رضی اللہ عنہا سے مروی ہے، وہ فرماتی ہیں : رسول اللہ صلی اللہ علیہ وسلم کنگھی فرمانے میں، جوتا پہننے میں، وضو ء کرنے میں حتی المقدور داہنی طرف سے شروع کرنے کو بہت پسند رکھتے تھے۔ ‘‘", "grades": "", "reference": "", "international_number": "83", "narrator_chain": "", "chapter_intro": "The Khuff (Leather Socks) Of Rasoolullah"}
{"hadithnumber": "84", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ مَرْزُوقٍ أَبُو عَبْدِ اللهِ، قَالَ‏:‏ حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ قَيْسٍ أَبُو مُعَاوِيَةَ، قَالَ‏:‏ حَدَّثَنَا هِشَامٌ، عَنْ مُحَمَّدٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ‏:‏ كَانَ لِنَعْلِ رَسُولِ اللهِ صلى الله عليه وسلم قِبَالانِ وَأَبِي بَكْرٍ وَعُمَرَ، وَأَوَّلُ مَنْ عَقَدَ عَقْدًا وَاحِدًا عُثْمَانُ رضي الله عنه‏.‏‏.‏", "bengali": "", "english": "“The sandals of Allah’s Messenger (Allah bless him and give him peace) had two thongs, as did those of Abu Bakr and 'Umar (may Allah the Exalted be well pleased with them), and the first to tie a single knot was 'Uthman (may Allah be well pleased with him).”", "french": "", "indonesian": "", "russian": "", "urdu": "’’ سیدنا ابوہریرہ رضی اللہ عنہ سے مروی ہے، وہ فرماتے ہیں : رسول اللہ صلی اللہ علیہ وسلم کے ہر ایک کفش مبارک کے دوتسمے تھے، اور سیدنا ابوبکر صدیق، سیدنا عمر فاروق رضی اللہ عنہا کے بھی۔ اور حضرت عثمان رضی اللہ عنہ پہلے صاحب ہیں جنہوں نے ایک تسمے کی گرہ باندھی۔ ‘‘", "grades": "", "reference": "", "international_number": "84", "narrator_chain": "", "chapter_intro": "The Khuff (Leather Socks) Of Rasoolullah"}
