metadata:
  section_id: 19
  section_name: رسول اللہ صلی اللہ علیہ وسلم کی لنگی مبارک کا بیان
  hadith_first: 115
  hadith_last: 118

hadiths[4]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
115,"""The Prophet (Allah bless him and give him peace) addressed the people while wearing a black turban.”",,,115,"'Amr ibn Huraith reported that his father said:",رسول اللہ صلی اللہ علیہ وسلم کی لنگی مبارک کا بیان
116,"""When the Prophet (Allah bless him and give him peace) donned a turban, he let his turban hang down between his shoulders.”",,,116,"Ibn 'Umar said:",رسول اللہ صلی اللہ علیہ وسلم کی لنگی مبارک کا بیان
117,“The Prophet (Allah bless him and give him peace) addressed the people while wearing a turban that was dasma’ [marked with traces of oil from his hair].,,,117,"Ibn 'Abbas said:",رسول اللہ صلی اللہ علیہ وسلم کی لنگی مبارک کا بیان
118,"“'A'isha (may Allah be well pleased with her) brought out to us a tangled garment and a coarse loincloth, then she said: ‘The spirit of Allah’s Messenger (Allah bless him and give him peace) was taken in these two'.”",,,118,"Abu Burda reported that his father said:",رسول اللہ صلی اللہ علیہ وسلم کی لنگی مبارک کا بیان
