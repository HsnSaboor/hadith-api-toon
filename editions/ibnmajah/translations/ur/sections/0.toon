{"hadithnumber": "228", "text": "ابوامامہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم اس علم دین کو اس کے ق"}
{"hadithnumber": "229", "text": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ایک دن اپنے کسی کمرے سے نکل"}
{"hadithnumber": "230", "text": "زید بن ثابت رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ اس شخص کو تروتاز"}
{"hadithnumber": "231", "text": "جبیر بن مطعم رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم منیٰ کی مسجد خیف میں خطبہ دینے"}
{"hadithnumber": "232", "text": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  اللہ تعالیٰ اس شخ"}
{"hadithnumber": "233", "text": "ابوبکرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے یوم النحر  ( دسویں ذی الحجہ )  کو"}
{"hadithnumber": "234", "text": "معاویہ قشیری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  سنو! حاضرین یہ باتیں"}
{"hadithnumber": "235", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم میں سے جو"}
{"hadithnumber": "236", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ تعالیٰ اس شخص کو"}
{"hadithnumber": "237", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  بعض لوگ خیر کی کنجی ا"}
{"hadithnumber": "238", "text": "سہل بن سعد رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  یہ خیر خزانے ہیں، اور"}
{"hadithnumber": "239", "text": "ابوالدرداء رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  عالم کے لیے"}
{"hadithnumber": "240", "text": "انس بن مالک رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جس نے کسی کو علم دی"}
{"hadithnumber": "241", "text": "ابوقتادہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  آدمی اپنی موت کے بعد جو"}
{"hadithnumber": "242", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول صلی اللہ علیہ وسلم نے فرمایا:  مومن کو اس کے اعمال اور نیکیو"}
{"hadithnumber": "243", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  سب سے بہتر اور افضل صد"}
{"hadithnumber": "244", "text": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کو کبھی بھی ٹیک لگا کر کھات"}
{"hadithnumber": "245", "text": "ابوامامہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم سخت گرمی کے دن میں بقیع غرقد نامی مقب"}
{"hadithnumber": "246", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم جب چلتے تو صحابہ رضی اللہ عن"}
{"hadithnumber": "247", "text": "ابو سعید خدری رضی اللہ عنہ فرماتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  عنقریب تمہارے پاس"}
{"hadithnumber": "248", "text": "اسماعیل (اسماعیل بن مسلم) کہتے ہیں کہ  ہم حسن بصری کے پاس ان کی عیادت کے لیے گئے یہاں تک کہ ہم سے گھ"}
{"hadithnumber": "249", "text": "ہارون عبدی کہتے ہیں کہ  جب ہم ابو سعید خدری رضی اللہ عنہ کے پاس آتے تو وہ فرماتے: رسول اللہ صلی الل"}
{"hadithnumber": "250", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کی دعاؤں میں یہ دعا بھی تھی: «اللهم"}
{"hadithnumber": "251", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم فرماتے تھے:  اے اللہ! میرے لیے اس چی"}
{"hadithnumber": "252", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس شخص نے علم دین کو جس"}
