{"metadata":{"name":"Sunan Abu Dawud","section":{"16":"Sacrifice (Kitab Al-Dahaya)"},"section_detail":{"16":{"hadithnumber_first":2788,"hadithnumber_last":2843,"arabicnumber_first":2788,"arabicnumber_last":2843}}},"hadiths":[{"hadithnumber":2841,"arabicnumber":2841,"text":"Rapporté par Abdullah ibn Abbas رضي الله عنه : Le Messager d’Allah ﷺ a sacrifié un bélier pour chacun, al-Hasan et al-Husayn (qu’Allah les agrée)","grades":[{"name":"Al-Albani","grade":"Sahih"},{"name":"Muhammad Muhyi Al-Din Abdul Hamid","grade":"Sahih"},{"name":"Shuaib Al Arnaut","grade":"Hasan Sahih"},{"name":"Zubair Ali Zai","grade":"Isnaad Sahih"}],"reference":{"book":16,"hadith":54}}]}