3514,3514۔ حَدَّثَنَا سُلَیْمَانُ بْنُ حَرْبٍ حَدَّثَنَا صَالِحٌ الْمُرِّیُّ عَنْ أَیُّوْبَ عَنْ أَبِیْ قِلَابَۃَ رَفَعَہٗ قَالَ مَنْ شَہِدَ الْقُرْآنَ حِینَ یُفْتَحُ فَکَأَنَّمَا شَہِدَ فَتْحًا فِیْ سَبِیلِ اللّٰہِ وَمَنْ شَہِدَ خَتْمَہٗ حِینَ یُخْتَمُ فَکَأَنَّمَا شَہِدَ الْغَنَائِمَ تُقْسَمُ ۔1,,takhreej: ! ضعیف: أخرجہ ابو عبید فی فضائل القران (ص108-107) نیزدیکھئے جمال القراء سخاوی کی1/113,3514
3515,3515۔ حَدَّثَنَا سُلَیْمَانُ بْنُ حَرْبٍ حَدَّثَنَا صَالِحٌ الْمُرِّیُّ عَنْ قَتَادَۃَ قَالَ کَانَ رَجُلٌ یَقْرَأُ فِیْ مَسْجِدِ الْمَدِیْنَۃِ وَکَانَ ابْنُ عَبَّاسٍ قَدْ وَضَعَ عَلَیْہِ الرَّصَدَ فَإِذَا کَانَ یَوْمُ خَتْمِہِ قَامَ فَتَحَوَّلَ إِلَیْہِ ۔2,,takhreej: @ضعیف: أخرجہ بن الضریس فی فضائل القران(79),3515
3516,3516۔ حَدَّثَنَا سُلَیْمَانُ بْنُ حَرْبٍ حَدَّثَنَا صَالِحٌ عَنْ ثَابِتٍ الْبُنَانِیِّ قَالَ کَانَ أَنَسُ بْنُ مَالِکٍ إِذَا أَشْفٰی عَلٰی خَتْمِ الْقُرْآنِ بِاللَّیْلِ بَقَّی مِنْہُ شَیْئًا حَتّٰی یُصْبِحَ فَیَجْمَعَ أَہْلَہٗ فَیَخْتِمَہٗ مَعَہُمْ ۔3,,takhreej: # ضعیف: أخرجہ الضریس فی فضائل القران(78),3516
3517,3517۔ حَدَّثَنَا عَفَّانُ حَدَّثَنَا جَعْفَرُ بْنُ سُلَیْمَانَ حَدَّثَنَا ثَابِتٌ قَالَ کَانَ أَنَسٌ إِذَا خَتَمَ الْقُرْآنَ جَمَعَ وَلَدَہُ وَأَہْلَ بَیْتِہِ فَدَعَا لَہُمْ ۔4,,takhreej: $صحیح: أخرجہ الطبرانی فی الکبیر1/242(674)والبیہقی فی الشعب(6070),3517
3518,3518۔ حَدَّثَنَا أَبُوْ الْمُغِیرَۃِ حَدَّثَنَا الْأَوْزَاعِیُّ عَنْ عَبْدَۃَ قَالَ إِذَا خَتَمَ الرَّجُلُ الْقُرْآنَ بِنَہَارٍ صَلَّتْ عَلَیْہِ الْمَلَائِکَۃُ حَتّٰی یُمْسِیَ وَإِنْ فَرَغَ مِنْہُ لَیْلًا صَلَّتْ عَلَیْہِ الْمَلَائِکَۃُ حَتّٰی یُصْبِحَ ۔1,,takhreej: ! صحیح: أخرجہ ابو نعیم فی الحلیۃ6/113,3518
3519,3519۔ حَدَّثَنَا إِسْحٰقُ بْنُ عِیسٰی عَنْ صَالِحٍ الْمُرِّیِّ عَنْ قَتَادَۃَ عَنْ زُرَارَۃَ بْنِ أَوْفٰی أَنَّ النَّبِیَّ ﷺ سُئِلَ أَیُّ الْعَمَلِ أَفْضَلُ قَالَ الْحَالُّ الْمُرْتَحِلُ قِیلَ وَمَا الْحَالُّ الْمُرْتَحِلُ قَالَ صَاحِبُ الْقُرْآنِ یَضْرِبُ مِنْ أَوَّلِ الْقُرْآنِ إِلٰی آخِرِہِ وَمِنْ آخِرِہٖ إِلٰی أَوَّلِہٖ کُلَّمَا حَلَّ ارْتَحَلَ ۔2,,takhreej: @ ضعیف: أخرجہ الحاکم (2089-2088) وابو نعیم فی الحلیۃ6/174والطبرانی فی الکبیر12/168(16783),3519
3520,3520۔ حَدَّثَنَا إِبْرَاہِیمُ بْنُ مُوسَی عَنْ جَرِیرٍ عَنِ الْأَعْمَشِ عَنْ إِبْرَاہِیْمَ قَالَ إِذَا قَرَأَ الرَّجُلُ الْقُرْآنَ نَہَارًا صَلَّتْ عَلَیْہِ الْمَلَائِکَۃُ حَتّٰی یُمْسِیَ وَإِنْ قَرَأَہٗ لَیْلًا صَلَّتْ عَلَیْہِ الْمَلَائِکَۃُ حَتّٰی یُصْبِحَ قَالَ سُلَیْمَانُ فَرَأَیْتُ أَصْحَابَنَا یُعْجِبُہُمْ أَنْ یَخْتِمُوْہُ أَوَّلَ النَّہَارِ وَأَوَّلَ اللَّیْلِ ۔3,,takhreej: #صحیح: أخرجہ ابن الفریس فی فضائل القرآن(50)وابو عبید فی فضائل القرآن (ص109),3520
3521,3521۔ حَدَّثَنَا مُحَمَّدُ بْنُ یُوسُفَ الْفِرْیَابِیُّ عَنْ سُفْیَانَ عَنِ الْأَعْمَشِ عَنْ إِبْرَاہِیمَ مِثْلَہٗ إِلَّا أَنَّہٗ لَیْسَ فِیہِ قَوْلُ سُلَیْمَانَ ۔1,,takhreej: $صحیح: اس کی مسند شرط بخاری پر ہے۔,3521
3522,3522۔ حَدَّثَنَا فَرْوَۃُ بْنُ أَبِیْ الْمَغْرَائِ عَنِ الْقَاسِمِ بْنِ مَالِکٍ الْمُزَنِیِّ عَنْ عَبْدِ الرَّحْمٰنِ بْنِ إِسْحٰقَ عَنْ مُحَارِبِ بْنِ دِثَارٍ قَالَ مَنْ قَرَأَ الْقُرْآنَ عَنْ ظَہْرِ قَلْبِہٖ کَانَتْ لَہٗ دَعْوَۃٌ فِیْ الدُّنْیَا أَوْ فِیْ الْآخِرَۃِ ۔1,,takhreej: ! ضعیف: عبدالرحمن بن اسحاق حدیث ضعیف ہے۔,3522
3523,3523۔ حَدَّثَنَا مُحَمَّدُ بْنُ سَعِیْدٍ حَدَّثَنَا عَبْدُ السَّلَامِ عَنْ یَزِیدَ بْنِ عَبْدِ الرَّحْمٰنِ عَنْ طَلْحَۃَ وَعَبْدِ الرَّحْمَنِ بْنِ الْأَسْوَدِ قَالَا مَنْ قَرَأَ الْقُرْآنَ لَیْلًا أَوْ نَہَارًا صَلَّتْ عَلَیْہِ الْمَلَائِکَۃُ إِلَی اللَّیْلِ وَقَالَ الْآخَرُ غُفِرَ لَہٗ ۔2,,takhreej: @طلحہ تک یہ سند حسن ہے جب کہ عبدالرحمن بن الأسود سے یزید بن عبدالرحمن کا سماع ثابت نہیں لہٰذا یہ منقطع ہے۔أخرج أثر طلحۃ ابن الضریس فی فضائل القران (54) اس کی سند صحیح ہے اگر یہ الفاظ محفوظ ہوں تو کیوں کہ نوری نے (حلیۃ الأبرابر) (ص183) میں ’’من ختم القران‘‘ کے الفاظ ذکر کیے ہیں۔,3523
3524,3524۔ حَدَّثَنَا عَمْرُو بْنُ حَمَّادٍ حَدَّثَنَا قَزَعَۃُ بْنُ سُوَیْدٍ عَنْ حُمَیْدٍ الْأَعْرَجِ قَالَ مَنْ قَرَأَ الْقُرْآنَ ثُمَّ دَعَا أَمَّنَ عَلَی دُعَائِہِ أَرْبَعَۃُ آلَافِ مَلَکٍ ۔3,,takhreej: # ضعیف: قزعۃ بن سوید ضعیف ہے۔,3524
3525,3525۔ حَدَّثَنَا سَعِیدُ بْنُ الرَّبِیعِ حَدَّثَنَا شُعْبَۃُ عَنِ الْحَکَمِ عَنْ مُجَاہِدٍ قَالَ بَعَثَ إِلَیَّ قَالَ إِنَّمَا دَعَوْنَاکَ أَنَّا أَرَدْنَا أَنْ نَخْتِمَ الْقُرْآنَ وَإِنَّہُ بَلَغَنَا أَنَّ الدُّعَائَ یُسْتَجَابُ عِنْدَ خَتْمِ الْقُرْآنِ قَالَ فَدَعَوْا بِدَعَوَاتٍ ۔4,,takhreej: $ صحیح: أخرجہ ابن الضریس فی فضائل القران(49) والبیہقی فی الشعب(2072)وابو عبید فی فضائل القران (ص107),3525
3526,3526۔ حَدَّثَنَا مُحَمَّدُ بْنُ حُمَیْدٍ حَدَّثَنَا ہَارُوْنُ عَنْ عَنْبَسَۃَ عَنْ لَیْثٍ عَنْ طَلْحَۃَ بْنِ مُصَرِّفٍ عَنْ مُصْعَبِ بْنِ سَعْدٍ عَنْ سَعْدٍ قَالَ إِذَا وَافَقَ خَتْمُ الْقُرْآنِ أَوَّلَ اللَّیْلِ صَلَّتْ عَلَیْہِ الْمَلَائِکَۃُ حَتّٰی یُصْبِحَ وَإِنْ وَافَقَ خَتْمُہُ آخِرَ اللّٰیْلِ صَلَّتْ عَلَیْہِ الْمَلَائِکَۃُ حَتّٰی یُمْسِیَ فَرُبَّمَا بَقِیَ عَلَی أَحَدِنَا الشَّیْئُ فَیُؤَخِّرَہٗ حَتّٰی یُمْسِیَ أَوْ یُصْبِحَ قَالَ أَبُوْ مُحَمَّد ہٰذَا حَسَنٌ عَنْ سَعْدٍ ۔1,,takhreej: ! ضعیف: لیث ضغیف ہے۔,3526
3527,3527۔ حَدَّثَنَا مُجَاہِدُ بْنُ مُوسَی حَدَّثَنَا مَعْنٌ حَدَّثَنَا إِبْرَاہِیمُ بْنُ مُہَاجِرِ بْنِ مِسْمَارٍ ابْنِ أَخِی بُکَیْرِ بْنِ مِسْمَارٍ حَدَّثَنِی صَفْوَانُ بْنُ سُلَیْمٍ عَنْ عَطَائِ بْنِ یَسَارٍ قَالَ حَمَلَۃُ الْقُرْآنِ عُرَفَائُ أَہْلِ الْجَنَّۃِ ۔2,,takhreej: @ ضعیف: ابراہیم بن مہاجر ضعیف ہے۔,3527
3528,3528۔ حَدَّثَنَا یَزِیدُ بْنُ ہَارُوْنَ أَخْبَرَنَا عَبْدُ الْمَلِکِ عَنْ سَعِیدِ بْنِ جُبَیْرٍ أَنَّہٗ کَانَ یَخْتِمُ الْقُرْآنَ کُلَّ لَیْلَتَیْنِ ۔3,,takhreej: # صحیح: أخرجہ ابو نعیم فی الحلیۃ4/273وابو عبید فی فضائل القران(ص182)وابن کثیر فی فضائل القران ص (258),3528
3529,3529۔ حَدَّثَنَا عُثْمَانُ بْنُ مُحَمَّدٍ حَدَّثَنَا جَرِیرٌ عَنْ مُطَرِّفٍ عَنْ أَبِیْ إِسْحٰقَ عَنْ أَبِیْ بُرْدَۃَ عَنْ عَبْدِ اللّٰہِ بْنِ عَمْرٍو قَالَ قُلْتُ یَا رَسُوْلَ اللّٰہِ فِیْ کَمْ أَخْتِمُ الْقُرْآنَ قَالَ اخْتِمْہُ فِیْ شَہْرٍ قُلْتُ یَا رَسُولَ اللّٰہِ إِنِّی أُطِیْقُ قَالَ اخْتِمْہُ فِیْ خَمْسٍ وَعِشْرِیْنَ قُلْتُ إِنِّی أُطِیْقُ قَالَ اخْتِمْہُ فِیْ عِشْرِینَ قُلْتُ إِنِّی أُطِیْقُ قَالَ اخْتِمْہُ فِیْ خَمْسَ عَشْرَۃَ قُلْتُ إِنِّی أُطِیْقُ قَالَ اخْتِمْہُ فِیْ عَشْرٍ قُلْتُ إِنِّی أُطِیْقُ قَالَ اخْتِمْہُ فِیْ خَمْسٍ قُلْتُ إِنِّی أُطِیْقُ قَالَ لَا ۔1,,takhreej: !متفق علیہ: أخرجہ البخاری،کتاب الصوم،باب حق الضیف فی الصوم(1974)ومسلم،کتاب الصوم،باب النہی عن صوم الدہر لمن تضرر بہ أوفو ت بہ …(2722),3529
3530,3530۔ حَدَّثَنَا عَبْدُ اللّٰہِ بْنُ سَعِیدٍ حَدَّثَنَا عُقْبَۃُ بْنُ خَالِدٍ عَنْ عَبْدِ الرَّحْمَنِ بْنِ زِیَادٍ حَدَّثَنِی عَبْدُالرَّحْمَنِ بْنُ رَافِعٍ عَنْ عَبْدِ اللّٰہِ بْنِ عَمْرٍو قَالَ أَمَرَنِی رَسُولُ اللّٰہِ ﷺ أَنْ لَا أَقْرَأَ الْقُرْآنَ فِیْ أَقَلَّ مِنْ ثَلَاثٍ ۔2,,takhreej: @صحیح: أخرجہ احمد2/158وابوداؤد،کتاب الصلاۃ،باب فی کم یقراء القران(1391),3530
3531,3531۔ حَدَّثَنَا أَبُوْ الْوَلِیْدِ الطَّیَالِسِیُّ حَدَّثَنَا لَیْثُ بْنُ سَعْدٍ حَدَّثَنَا ابْنُ أَبِیْ مُلَیْکَۃَ عَنِ ابْنِ أَبِیْ نَہِیْکٍ عَنْ سَعْدِ بْنِ أَبِیْ وَقَّاصٍ أَنَّ رَسُوْلَ اللّٰہِ ﷺ قَالَ لَیْسَ مِنَّا مَنْ لَمْ یَتَغَنَّ بِالْقُرْآنِ قَالَ ابْنُ عُیَیْنَۃَ : یَسْتَغْنِی قَالَ أَبُوْ مُحَمَّد النَّاسُ یَقُوْلُوْنَ عُبَیْدُ اللّٰہِ بْنُ أَبِیْ نَہِیْکٍ ۔1,,takhreej: ! صحیح: ابن حبان(120)وأخرجہ الرازی فی فضائل القران(90)والبیہقی فی الشعب(2613),3531
3532,3532۔ حَدَّثَنَا جَعْفَرُ بْنُ عَوْنٍ أَخْبَرَنَا مِسْعَرٌ عَنْ عَبْدِ الْکَرِیْمِ عَنْ طَاوٗسٍ قَالَ سُئِلَ النَّبِیُّ ﷺ أَیُّ النَّاسِ أَحْسَنُ صَوْتًا لِلْقُرْآنِ وَأَحْسَنُ قِرَائَۃً قَالَ مَنْ إِذَا سَمِعْتَہُ یَقْرَأُ أُرِیْتَ أَنَّہٗ یَخْشَی اللّٰہَ قَالَ طَاوٗسٌ وَکَانَ طَلْقٌ کَذٰلِکَ ۔2,,takhreej: @ ضعیف: أخرجہ ابن ابی شیبہ10/546(9694)وابوعبید فی فضائل القران ص168وأخرجہ ابو نعیم فی حلیۃ الأولیا4/19,3532
3533,3533۔ حَدَّثَنَا عَبْدُ اللّٰہِ بْنُ صَالِحٍ حَدَّثَنِی اللَّیْثُ حَدَّثَنِی عُقَیْلٌ عَنِ ابْنِ شِہَابٍ حَدَّثَنِی أَبُوْسَلَمَۃَ عَنْ أَبِیْ ہُرَیْرَۃَ أَنَّہٗ کَانَ یَقُوْلُ قَالَ رَسُولُ اللّٰہِ ﷺ لَمْ یَأْذَنِ اللّٰہُ لِشَیْئٍ مَا أَذِنَ لِنَبِیٍّ یَتَغَنَّی بِالْقُرْآنِ و قَالَ صَاحِبٌ لَہٗ زَادَ یَجْہَرُ بِہٖ۔1,,takhreej: ! متفق علیہ: أخرجہ البخاری،کتاب فضائل القران،باب من لم یتغن بالقران(5023)ومسلم،کتاب صلاۃ المسافرین، باب استحباب تحسین الصوت بالقران(792),3533
3534,3534۔ حَدَّثَنَا عَبْدُ اللّٰہِ بْنُ صَالِحٍ حَدَّثَنَا اللّٰیْثُ حَدَّثَنِی یُونُسُ عَنِ ابْنِ شِہَابٍ قَالَ أَخْبَرَنِی أَبُوْ سَلَمَۃَ أَنَّ أَبَا ہُرَیْرَۃَ قَالَ مَا أَذِنَ اللّٰہُ لِشَیْئٍ کَمَا أَذِنَ لِنَبِیٍّ یَتَغَنّٰی بِالْقُرْآنِ ۔2,,takhreej: @ صحیح: حدیث مکرر آئی ہے۔,3534
3535,3535۔ حَدَّثَنَا عَبْدُ اللّٰہِ بْنُ صَالِحٍ حَدَّثَنِی اللَّیْثُ حَدَّثَنِی یُوْنُسُ عَنِ ابْنِ شِہَابٍ قَالَ أَخْبَرَنِی أَبُوْ سَلَمَۃَ بْنُ عَبْدِ الرَّحْمَنِ أَنَّ رَسُولَ اللّٰہِ ﷺ کَانَ یَقُوْلُ لِأَبِیْ مُوسَی وَکَانَ حَسَنَ الصَّوْتِ بِالْقُرْآنِ لَقَدْ أُوتِیَ ہٰذَا مِنْ مَزَامِیْرِ آلِ دَاوٗدَ ۔3,,takhreej: # متفق علیہ: أخرجہ البخاری،کتاب فضائل القرآن،باب حسن الصوت بالقراء ۃ بالقرآن(5048)ومسلم،کتاب صلاۃ المسافرین، باب استحباب تحسین الصوت بالقران(793),3535
3536,3536۔ حَدَّثَنَا عَبْدُ اللّٰہِ بْنُ صَالِحٍ حَدَّثَنِی اللَّیْثُ حَدَّثَنِی یُونُسُ عَنِ ابْنِ شِہَابٍ قَالَ حَدَّثَنِیْ أَبُوْ سَلَمَۃَ أَیْضًا أَنَّ عُمَرَ بْنَ الْخَطَّابِ کَانَ إِذَا رَأٰی أَبَا مُوْسَی قَالَ ذَکِّرْنَا رَبَّنَا یَا أَبَا مُوسَی فَیَقْرَأُ عِنْدَہٗ۔1,,takhreej: ! ضعیف: أخرجہ ابو عبید فی فضائل القرآن(ص163) والبیہقی فی الشہادات،باب تحسین الصوت بالقران والذکر 10/231,3536
3537,3537۔ حَدَّثَنَا جَعْفَرُ بْنُ عَوْنٍ حَدَّثَنَا إِبْرَاہِیْمُ الْہَجَرِیُّ عَنْ أَبِیْ الْأَحْوَصِ عَنْ عَبْدِ اللّٰہِ قَالَ لَا أُلْفِیَنَّ أَحَدَکُمْ یَضَعُ إِحْدٰی رِجْلَیْہِ عَلَی الْأُخْرٰی یَتَغَنَّی وَیَدَعُ أَنْ یَقْرَأَ سُورَۃَ الْبَقَرَۃِ فَإِنَّ الشَّیْطَانَ یَفِرُّ مِنَ الْبَیْتِ یُقْرَأُ فِیہِ سُورَۃُ الْبَقَرَۃِ وَإِنَّ أَصْفَرَ الْبُیُوتِ الْجَوْفُ یَصْفَرُ مِنْ کِتَابِ اللّٰہِ ۔2,,takhreej: @ ضعیف: أخرجہ عبدالرزاق (5998)والطبرانی فی الاوسط(7762) جب کہ ابن ابی شیبہ10/386(10073) میں اس کا آخری جزء صحیح سندسے مروی ہے۔,3537
3538,3538۔ أَخْبَرَنَا سُلَیْمَانُ بْنُ حَرْبٍ حَدَّثَنَا حَمَّادُ بْنُ زَیْدٍ عَنْ أَیُّوبَ قَالَ حَدَّثَنِی بَعْضُ آلِ سَالِمِ بْنِ عَبْدِ اللّٰہِ قَالَ قَدِمَ سَلَمَۃُ الْبَیْذَقُ الْمَدِینَۃَ فَقَامَ یُصَلِّی بِہِمْ فَقِیلَ لِسَالِمٍ لَوْ جِئْتَ فَسَمِعْتَ قِرَائَتَہٗ فَلَمَّا کَانَ بِبَابِ الْمَسْجِدِ سَمِعَ قِرَائَتَہٗ رَجَعَ فَقَالَ غِنَائٌ غِنَائٌ ۔1,,takhreej: ! ضعیف: اس میں ابن جریج کا عنعنہ اور ایک راوی مجہول ہے۔,3538
3539,3539۔ حَدَّثَنَا أَبُوْ عَاصِمٍ عَنِ ابْنِ جُرَیْجٍ عَنِ ابْنِ شِہَابٍ عَنْ أَبِیْ سَلَمَۃَ أَنَّ أَبَا مُوسٰی کَانَ یَأْتِی عُمَرَ فَیَقُولُ لَہٗ عُمَرُ ذَکِّرْنَا رَبَّنَا فَیَقْرَأُ عِنْدَہٗ۔2,,takhreej: @ منقطع ضعیف: (3536) میں گزر چکی ہے۔,3539
3540,3540۔ حَدَّثَنَا یَزِیدُ بْنُ ہَارُوْنَ حَدَّثَنَا مُحَمَّدٌ ہُوَ ابْنُ عَمْرٍو عَنْ أَبِیْ سَلَمَۃَ عَنْ أَبِیْ ہُرَیْرَۃَ قَالَ قَالَ رَسُولُ اللّٰہِ ﷺ مَا أَذِنَ اللّٰہُ لِشَیْئٍ کَأَذَنِہِ لِنَبِیٍّ یَتَغَنَّی بِالْقُرْآنِ یَجْہَرُ بِہٖ۔3,,takhreej: # حسن: أخرجہ ابن سعد فی الطبقات4/1/79وابو عبید فی فضائل القران(ص162),3540
3541,3541۔ حَدَّثَنَا عُثْمَانُ بْنُ عُمَرَ عَنْ مَالِکِ بْنِ مِغْوَلٍ عَنِ ابْنِ بُرَیْدَۃَ عَنْ أَبِیْہِ عَنِ النَّبِیِّ ﷺ قَالَ لَقَدْ أُوتِیَ أَبُوْ مُوسَی مِزْمَارًا مِنْ مَزَامِیرِ آلِ دَاوُدَ ۔4,,takhreej: $ صحیح: أخرجہ احمد5/349ومسلم فی صلاۃ المسافرین، باب تحسین الصوت بالقران(793),3541
3542,3542۔ أَخْبَرَنَا یَزِیدُ بْنُ ہَارُوْنَ عَنْ مُحَمَّدِ بْنِ عَمْرٍو عَنْ أَبِیْ سَلَمَۃَ عَنْ أَبِیْ ہُرَیْرَۃَ قَالَ دَخَلَ رَسُولُ اللّٰہِ ﷺ فَسَمِعَ قِرَائَۃَ رَجُلٍ فَقَالَ مَنْ ہٰذَا قِیلَ عَبْدُ اللّٰہِ بْنُ قَیْسٍ قَالَ لَقَدْ أُوْتِیَ ہٰذَا مِنْ مَزَامِیْرِ آلِ دَاوٗدَ ۔5,,takhreej: % حسن: صحیح ابن حبان(7196),3542
3543,3543۔ حَدَّثَنَا عُبَیْدُ اللّٰہِ عَنْ سُفْیَانَ عَنْ مَنْصُورٍ عَنْ طَلْحَۃَ عَنْ عَبْدِ الرَّحْمٰنِ بْنِ عَوْسَجَۃَ عَنِ الْبَرَائِ عَنِ النَّبِیِّ ﷺ قَالَ زَیِّنُوا الْقُرْآنَ بِأَصْوَاتِکُمْ ۔1,,takhreej: ! صحیح : أخرجہ ابو عبید فی فضائل القران (ص160) والرازی فی فضائل القران(22)والحاکم1/575-571,3543
3544,3544۔ حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ حَدَّثَنَا صَدَقَۃُ بْنُ أَبِیْ عِمْرَانَ عَنْ عَلْقَمَۃَ بْنِ مَرْثَدٍ عَنْ زَاذَانَ أَبِیْ عُمَرَ عَنِ الْبَرَائِ بْنِ عَازِبٍ قَالَ سَمِعْتُ رَسُولَ اللّٰہِ ﷺ یَقُوْلُ حَسِّنُوا الْقُرْآنَ بِأَصْوَاتِکُمْ فَإِنَّ الصَّوْتَ الْحَسَنَ یَزِیدُ الْقُرْآنَ حُسْنًا ۔2,,takhreej: @ صحیح : أخرجہ الحاکم1/575,3544
3545,3545۔ أَخْبَرَنَا عَبْدُ اللّٰہِ بْنُ سَعِیْدٍ عَنْ عَبْدِ اللّٰہِ بْنِ إِدْرِیْسَ عَنِ الْأَعْمَشِ قَالَ قَرَأَ رَجُلٌ عِنْدَ أَنَسٍ بِلَحْنٍ مِنْ ہٰذِہِ الْأَلْحَانِ فَکَرِہَ ذٰلِکَ أَنَسٌ قَالَ أَبُوْ مُحَمَّد و قَالَ غَیْرُہُ قَرَأَ غُورَکُ بْنُ أَبِیْ الْخِضْرِمِ ۔3,,takhreej: # صحیح : أخرجہ ابن ابی شیبہ10/466(9998),3545
3546,3546۔ حَدَّثَنَا الْعَبَّاسُ بْنُ سُفْیَانَ عَنِ ابْنِ عُلَیَّۃَ عَنِ ابْنِ عَوْنٍ عَنْ مُحَمَّدٍ قَالَ کَانُوْا یَرَوْنَ ہٰذِہِ الْأَلْحَانَ فِیْ الْقُرْآنِ مُحْدَثَۃً۔4,,takhreej: $ صحیح,3546
