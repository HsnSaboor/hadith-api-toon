{"hadithnumber": "1042", "arabic": "[1042] وَحَدَّثَنِی عَنْ مَالِکٍ، عَمَّنْ سَمِعَ نَافِعاً یَقُولُ : قَالَ عَبْدُ اللّٰہِ بْنُ عُمَرَ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 24, Hadith 1", "international_number": "1042", "narrator_chain": ""}
{"hadithnumber": "1043", "arabic": "[1043] وَحَدَّثَنِی عَنْ مَالِکٍ، أَ نَّہُ بَلَغَہُ، عَنْ سَعْدِ بْنِ أبِی وَقَّاصٍ، أَ نَّہُ سُئ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Maqtu Sahih'}", "reference": "Book 24, Hadith 2", "international_number": "1043", "narrator_chain": ""}
{"hadithnumber": "1044", "arabic": "[1044] وَحَدَّثَنِی یَحْیَی عَنْ مَالِکٍ، عَنْ نَافِعٍ : أَنَّ عَبْدَ الرَّحْمَنِ بْنَ أبِی ہُرَیْ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 24, Hadith 3", "international_number": "1044", "narrator_chain": ""}
{"hadithnumber": "1045", "arabic": "[1045] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ زَیْدِ بْنِ أَسْلَمَ، عَنْ سَعْدٍ الْجَارِیِّ مَوْلَی عُمَرَ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 24, Hadith 4", "international_number": "1045", "narrator_chain": ""}
{"hadithnumber": "1046", "arabic": "[1046] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ أبِی الزِّنَادِ، عَنْ أبِی سَلَمَۃَ بْنِ عَبْدِ الرَّحْمَنِ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Mauquf Sahih'}", "reference": "Book 24, Hadith 5", "international_number": "1046", "narrator_chain": ""}
{"hadithnumber": "1047", "arabic": "[1047] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ أبِی الزِّنَادِ، عَنْ أبِی سَلَمَۃَ بْنِ عَبْدِ الرَّحْمَنِ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Mauquf Daif'}", "reference": "Book 24, Hadith 6", "international_number": "1047", "narrator_chain": ""}
{"hadithnumber": "1048", "arabic": "[1048] حَدَّثَنِی یَحْیَی، عَنْ مَالِکٍ، عَنِ ابْنِ شِہَابٍ، عَنِ أبِی إِدْرِیسَ الْخَوْلاَنِیِّ، ع", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Maqtu Sahih'}", "reference": "Book 24, Hadith 7", "international_number": "1048", "narrator_chain": ""}
{"hadithnumber": "1049", "arabic": "[1049] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ إِسْمَاعِیلَ بْنِ أبِی حَکِیمٍ، عَنْ عَبِیدَۃَ بْنِ سُفْیَان", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Mauquf Sahih'}", "reference": "Book 24, Hadith 8", "international_number": "1049", "narrator_chain": ""}
{"hadithnumber": "1050", "arabic": "[1050] حَدَّثَنِی یَحْیَی، عَنْ مَالِکٍ، عَنِ ابْنِ شِہَابٍ، عَنْ عُبَیْدِ اللّٰہِ بْنِ عَبْدِ اللّٰ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Mauquf Sahih'}", "reference": "Book 24, Hadith 9", "international_number": "1050", "narrator_chain": ""}
{"hadithnumber": "1051", "arabic": "[1051] وَحَدَّثَنِی مَالِکٌ، عَنْ زَیْدِ بْنِ أَسْلَمَ، عَنِ ابْنِ وَعْلَۃَ الْمِصْرِیِّ، عَنْ عَبْ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Mauquf Sahih'}", "reference": "Book 24, Hadith 10", "international_number": "1051", "narrator_chain": ""}
{"hadithnumber": "1088", "arabic": "حَدَّثَنِي يَحْيَى، عَنْ مَالِكٍ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ أَبِيهِ، أَنَّهُ قَالَ سُئِلَ رَسُولُ اللَّهِ صلى الله عليه وسلم فَقِيلَ لَهُ يَا رَسُولَ اللَّهِ إِنَّ نَاسًا مِنْ أَهْلِ الْبَادِيَةِ يَأْتُونَنَا بِلُحْمَانٍ وَلاَ نَدْرِي هَلْ سَمَّوُا اللَّهَ عَلَيْهَا أَمْ لاَ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ سَمُّوا اللَّهَ عَلَيْهَا ثُمَّ كُلُوهَا ‏\"\"‏ ‏.‏ قَالَ مَالِكٌ وَذَلِكَ فِي أَوَّلِ الإِسْلاَمِ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1089", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ يَحْيَى بْنِ سَعِيدٍ، أَنَّ عَبْدَ اللَّهِ بْنَ عَيَّاشِ بْنِ أَبِي رَبِيعَةَ الْمَخْزُومِيَّ، أَمَرَ غُلاَمًا لَهُ أَنْ يَذْبَحَ ذَبِيحَةً فَلَمَّا أَرَادَ أَنْ يَذْبَحَهَا قَالَ لَهُ سَمِّ اللَّهَ ‏.‏ فَقَالَ لَهُ الْغُلاَمُ قَدْ سَمَّيْتُ ‏.‏ فَقَالَ لَهُ سَمِّ اللَّهَ وَيْحَكَ ‏.‏ قَالَ لَهُ قَدْ سَمَّيْتُ اللَّهَ ‏.‏ فَقَالَ لَهُ عَبْدُ اللَّهِ بْنُ عَيَّاشٍ وَاللَّهِ لاَ أَطْعَمُهَا أَبَدًا ‏.‏", "grades": "", "reference": "", "international_number": "1089", "narrator_chain": ""}
{"hadithnumber": "1090", "arabic": "حَدَّثَنِي يَحْيَى، عَنْ مَالِكٍ، عَنْ زَيْدِ بْنِ أَسْلَمَ، عَنْ عَطَاءِ بْنِ يَسَارٍ، أَنَّ رَجُلاً، مِنَ الأَنْصَارِ مِنْ بَنِي حَارِثَةَ كَانَ يَرْعَى لِقْحَةً لَهُ بِأُحُدٍ فَأَصَابَهَا الْمَوْتُ فَذَكَّاهَا بِشِظَاظٍ فَسُئِلَ رَسُولُ اللَّهِ صلى الله عليه وسلم عَنْ ذَلِكَ فَقَالَ ‏ ‏ لَيْسَ بِهَا بَأْسٌ فَكُلُوهَا ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1091", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ نَافِعٍ، عَنْ رَجُلٍ، مِنَ الأَنْصَارِ عَنْ مُعَاذِ بْنِ سَعْدٍ، أَوْ سَعْدِ بْنِ مُعَاذٍ أَنَّ جَارِيَةً، لِكَعْبِ بْنِ مَالِكٍ كَانَتْ تَرْعَى غَنَمًا لَهَا بِسَلْعٍ فَأُصِيبَتْ شَاةٌ مِنْهَا فَأَدْرَكَتْهَا فَذَكَّتْهَا بِحَجَرٍ فَسُئِلَ رَسُولُ اللَّهِ صلى الله عليه وسلم عَنْ ذَلِكَ فَقَالَ ‏ ‏ لاَ بَأْسَ بِهَا فَكُلُوهَا ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1092", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ ثَوْرِ بْنِ زَيْدٍ الدِّيلِيِّ، عَنْ عَبْدِ اللَّهِ بْنِ عَبَّاسٍ، أَنَّهُ سُئِلَ عَنْ ذَبَائِحِ، نَصَارَى الْعَرَبِ فَقَالَ لاَ بَأْسَ بِهَا وَتَلاَ هَذِهِ الآيَةَ ‏{‏وَمَنْ يَتَوَلَّهُمْ مِنْكُمْ فَإِنَّهُ مِنْهُمْ ‏}‏‏.‏", "grades": "", "reference": "", "international_number": "1092", "narrator_chain": ""}
{"hadithnumber": "1093", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، أَنَّهُ بَلَغَهُ أَنَّ عَبْدَ اللَّهِ بْنَ عَبَّاسٍ، كَانَ يَقُولُ مَا فَرَى الأَوْدَاجَ فَكُلُوهُ ‏.‏", "grades": "", "reference": "", "international_number": "1093", "narrator_chain": ""}
{"hadithnumber": "1094", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ يَحْيَى بْنِ سَعِيدٍ، عَنْ سَعِيدِ بْنِ الْمُسَيَّبِ، أَنَّهُ كَانَ يَقُولُ مَا ذُبِحَ بِهِ إِذَا بَضَعَ فَلاَ بَأْسَ بِهِ إِذَا اضْطُرِرْتَ إِلَيْهِ ‏.‏", "grades": "", "reference": "", "international_number": "1094", "narrator_chain": ""}
{"hadithnumber": "1095", "arabic": "حَدَّثَنِي يَحْيَى، عَنْ مَالِكٍ، عَنْ يَحْيَى بْنِ سَعِيدٍ، عَنْ أَبِي مُرَّةَ، مَوْلَى عَقِيلِ بْنِ أَبِي طَالِبٍ أَنَّهُ سَأَلَ أَبَا هُرَيْرَةَ عَنْ شَاةٍ، ذُبِحَتْ فَتَحَرَّكَ بَعْضُهَا فَأَمَرَهُ أَنْ يَأْكُلَهَا ثُمَّ سَأَلَ عَنْ ذَلِكَ زَيْدَ بْنَ ثَابِتٍ فَقَالَ إِنَّ الْمَيْتَةَ لَتَتَحَرَّكُ وَنَهَاهُ عَنْ ذَلِكَ ‏.‏ وَسُئِلَ مَالِكٌ عَنْ شَاةٍ  تَرَدَّتْ فَتَكَسَّرَتْ فَأَدْرَكَهَا صَاحِبُهَا فَذَبَحَهَا فَسَالَ الدَّمُ مِنْهَا وَلَمْ تَتَحَرَّكْ فَقَالَ مَالِكٌ إِذَا كَانَ ذَبَحَهَا وَنَفَسُهَا يَجْرِي وَهِيَ تَطْرِفُ فَلْيَأْكُلْهَا ‏.‏", "grades": "", "reference": "", "international_number": "1095", "narrator_chain": ""}
{"hadithnumber": "1096", "arabic": "حَدَّثَنِي يَحْيَى، عَنْ مَالِكٍ، عَنْ نَافِعٍ، عَنْ عَبْدِ اللَّهِ بْنِ عُمَرَ، أَنَّهُ كَانَ يَقُولُ إِذَا نُحِرَتِ النَّاقَةُ فَذَكَاةُ مَا فِي بَطْنِهَا فِي ذَكَاتِهَا إِذَا كَانَ قَدْ تَمَّ خَلْقُهُ وَنَبَتَ شَعَرُهُ فَإِذَا خَرَجَ مِنْ بَطْنِ أُمِّهِ ذُبِحَ حَتَّى يَخْرُجَ الدَّمُ مِنْ جَوْفِهِ ‏.‏", "grades": "", "reference": "", "international_number": "1096", "narrator_chain": ""}
{"hadithnumber": "1097", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ يَزِيدَ بْنِ عَبْدِ اللَّهِ بْنِ قُسَيْطٍ اللَّيْثِيِّ، عَنْ سَعِيدِ بْنِ الْمُسَيَّبِ، أَنَّهُ كَانَ يَقُولُ ذَكَاةُ مَا فِي بَطْنِ الذَّبِيحَةِ فِي ذَكَاةِ أُمِّهِ إِذَا كَانَ قَدْ تَمَّ خَلْقُهُ وَنَبَتَ شَعَرُهُ ‏.‏", "grades": "", "reference": "", "international_number": "1097", "narrator_chain": ""}
