hadiths[157]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
679,"ابراہیم نے اسو د سے انہوں نے حضرت عائشہ ؓ سے روایت کی  ،  کہا :  ہم  (  ازواد نبی ﷺ )  میں سے کسی ای",,,,,679
680,"عبد الرحمان بن اسود نے اپنے والد سے  ،  انہوں نے  حضرت عائشہ ؓ سے روایت کی  ،  کہا :  ہم میں سے کسی",,,,,680
681,"حضرت میمونہؓ سے روایت ہے  ،  انہوں نے کہا :  رسول اللہ ﷺ اپنی بیویوں کے مخصوص ایام میں کپڑے کے اوپر ",,,,,681
682,"حضرت ابن عباس ‌رضی ‌اللہ ‌عنہ ‌ ‌  کے آزاد کر دہ غلام ابو کریب نے کہا :  میں نے رسول اللہ ﷺ کی زوجہ ",,,,,682
683,"ابو سلمہ بن عبد الرحمن نے بیان کیا کہ حضرت ام سلمہ ؓ نے انہیں بتایا ،  کہا :  میں رسول اللہ ﷺ کے  سا",,,,,683
684,مالک نے ابن شہاب سے  ، انہوں نے عروہ سے  ،  انہوں نے عمرہ سے اور انہوں نے حضرت عائشہ ؓ سے روایت کی  ,,,,,684
685,قتیبہ بن سعید اور محمد بن رمح نے لیث سے ،  انہوں نے ابن شہاب سے  ،  انہوں نے عروہ اور عمرہ بنت عبد ا,,,,,685
686,محمدبن عبد الرحمن بن نوفل نے عروہ بن زبیر سے  ،  انہوں نے رسول اللہﷺ کی زوجہ حضرت عائشہ ؓ سے روایت ک,,,,,686
687,"ہشام نے کہا :  عروہ بن ہمیں حضرت عائشہ ؓ سے خبر دی کہ انہوں نے کہا :  رسول اللہ ﷺ  (  اعتکاف کی حالت",,,,,687
688,"اسود نے حضرت عائشہ ؓ سے روایت کی  ،  انہوں نےکہا :  میں ایام مخصوصہ میں رسول اللہ ﷺ کاسر دھودیتی تھی",,,,,688
689,"اعمش نے ثابت بن عبید سے  ،  انہوں نے قاسم بن محمد سے اور انہوں نے حضرت عائشہ ؓ سے روایت کی ،  کہا : ",,,,,689
690,حجاج اور ابن ابی غنیہ نے ثابت سے  ،  انہوں نے قاسم بن محمد سے  ،  انہوں نے حضرت عائشہ سے روایت کی  ،,,,,,690
691,"حضرت ابو ہریرہ ﷺ سے روایت ہے  ،  انہو ں نے کہا :  ایک بار رسول اللہ ﷺ مسجد میں موجود تھے تو آپ نے فر",,,,,691
692,"ابو بکر بن ابی شیبہ اور زہیر بن حرب نے کہا :  ہمیں وکیع نے مسعر اور سفیان سے حدیث بیان کی  ،  انہوں ",,,,,692
693,"صفیہ بنت شیبہ نے حضرت عائشہ ؓ سے روایت کی کہ انہوں نے کہا :  میں حیض کی حالت میں ہوتی تو رسول اللہ ﷺ",,,,,693
694,حضرت انس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سےروایت ہے کہ یہودی ،  جب ان کی کوئی عورت حائضہ ہوتی تو نہ وہ اس کے س,,,,,694
695,وکیع  ،  ابو معاویہ اور ہشیم نے اعمش سے حدیث بیان کی  ، انہوں نے منذر بن یعلیٰ سے  (  جن کی کنیت ابو,,,,,695
696,شعبہ نے سلیمان اعمش سے باقی ماندہ سابقہ سند کے ساتھ حضرت علی  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ ان,,,,,696
697,"حضرت ابن عباس ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے  ،  کہا :  حضرت علی  ‌رضی ‌اللہ ‌عنہ ‌ ‌ نے فرمایا : ",,,,,697
698,حضرت ابن عباس ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ نبی اکرمﷺ رات کو اٹھے  ،  قضائے حاجت کی  ،  پھر اپ,,,,,698
699,ابوسلمہ بن عبد الرحمن نے حضرت عائشہ ؓ سےروایت کی کہ رسول اللہﷺ جب جنابت کی حالت میں سونا چاہتے توسون,,,,,699
700,ابن علیہ  ، وکیع اور  عندر نے شعبہ سے  ،  انہوں نے حکم سے  ،  انہوں نے ابراہیم سے  ،  انہوں نے اسود ,,,,,700
701,"محمد بن مثنیٰ اور ابن بشار دونوں نے کہا : ہمیں محمد بن جعفر نے حدیث سنائی ، اسی طرح عبیداللہ بن معاذ",,,,,701
702,عبید اللہ نے نافع سے  ،  انہوں نے حضرت ابن عمر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سےر وایت کی کہ  حضرت عمر  ‌رضی ,,,,,702
703,"ابن جریج سے روایت ہے  ( کہا :  )  مجھے نافع نے ابن عمر ‌رضی ‌اللہ ‌عنہ ‌ ‌ سے روایت کرتے ہوئے خبر دی",,,,,703
704,عبداللہ بن دینار سے حضرت ابن عمر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ عمر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے ر,,,,,704
705,"لیث نے معاویہ بن صالح سے  ،  انہوں نے عبد اللہ بن ابی قیس سے روایت کی  ،  انہوں نے کہا : میں نے حضرت",,,,,705
706,عبدالرحمن بن مہدی اور ابن وہب دونوں نے معاویہ بن صالح سے سابقہ سند کے ساتھ یہی روایت بیان کی,,,,,706
707,"ابو بکر بن ابی شیبہ نے کہا : ہمیں حفص بن غیاث نے حدیث سنائی ،  نیز ابو کریب نے کہا :  ہمیں ابن ابی ز",,,,,707
708,حضرت انس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ نبی اکرمﷺ ایک ہی غسل سے اپنی  (  ایک سے زیادہ )  بیویو,,,,,708
709,اسحاق بن ابی طلحہ نےکہاکہ مجھے حضرت انس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے یہ حدیث سنائی کہ ام سلیم  ‌رضی ‌الل,,,,,709
710,قتادہ سےروایت ہے کہ حضرت انس بن مالک  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے انہیں حدیث سنائی کہ ام سلیم ؓ نے  (  ا,,,,,710
711,"ابو مالک اشجعی نے حضرت انس بن مالک  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  انہوں نے کہا : ایک عورت نے ",,,,,711
712,ابو معاویہ نے ہشام بن عروہ سے  ،  انہوں نے اپنےوالد سے  ،  انہوں نے زینب بنت ابی سلمہ سے اور انہوں ن,,,,,712
713,ہشام کے دو شاگردوں وکیع اور سفیان نے باقی ماندہ سابقہ سند کے ساتھ اسی  ( سابقہ حدیث )  کے ہم معنی حد,,,,,713
714,"ابن شہاب نے کہا :  مجھے عروہ بن زبیر نے خبر دی کہ حضرت عائشہ ؓ نے انہیں بتایا کہ ام سلیم ؓ جو ابو طل",,,,,714
715,مسافع بن عبد اللہ نے عروہ بن زبیر سے  ،  انہوں نے حضرت عائشہ ؓ سے روایت کی کہ ایک عورت نے رسول اللہ ,,,,,715
716,"ابو توبہ نے  ،  جو ربیع بن نافع ہیں  ،  ہم سے حدیث بیان کی  ،  کہا :  معاویہ بن سلام نے ہمیں اپنےبھا",,,,,716
717,یحییٰ بن حسان نے ہمیں خبر دی کہ ہمیں معاویہ بن سلام نے اسی اسناد کے ساتھ اسی طرح حدیث سنائی ،  سوائے,,,,,717
718,ابو معاویہ نے ہشام بن عروہ سے  ،  انہوں نے اپنے والد سے اور انہوں نے حضرت عائشہ ؓ سے ر وایت کی کہ جب,,,,,718
719,جریر ،  علی بن مسہر اور ابن نمیر نے ہشام کی اسی سند کے ساتھ  (  یہ )  حدیث روایت کی لیکن ان  ( تینوں,,,,,719
720,وکیع نے ہشام کی اسی سند کے ساتھ حضرت عائشہ ؓ سے حدیث بیان کی کہ رسو ل اللہ ﷺ نے جنابت سےغسل فرمایا ،,,,,,720
721,زائدہ نے ہشام سے اسی سند کے ساتھ حضرت عائشہ ؓ سے روایت کی کہ رسول اللہ ﷺ جب غسل جنابت فرماتے  (  تو ,,,,,721
722,"عیسیٰ بن یونس نے ہم سے حدیث بیان کی  ،   ( کہا :  ) ہم سے اعمش نے حدیث بیان کی  ،  انہوں نے سالم بن ",,,,,722
723,وکیع اور ابو معاویہ نے اعمش کی سابقہ سندکے ساتھ یہ روایت بیان کی لیکن ان دونوں کی حدیث میں سر پر تین,,,,,723
724,عبد اللہ بن ادریس نے اعمش کی سابقہ سند کے ساتھ ابن عباس ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے حضرت میمونہ ؓ کی روا,,,,,724
725,"قاسم  ( بن محمدبن ابی بکر )  نے حضرت عائشہ ؓ سے روایت کی  ،  کہا : رسول اللہ ﷺ جب غسل جنابت فرماتے ت",,,,,725
726,امام مالک نے ابن شہاب  ( زہری ) سے  ،  انہوں نے عروہ سے اور انہوں نےحضرت عائشہ ؓ سے روایت کی کہ رسول,,,,,726
727,قتیبہ بن سعید اور ابن رمح نے لیث سے  ،  اسی طرح قتیبہ بن سعید  ،  ابوبکر بن ابی شیبہ  ،  عمرو ناقد ا,,,,,727
728,ابو بکر بن حفص نے ابو سلمہ بن عبد الرحمن  (  بن عوف جوحضرت عائشہ کے رضاعی بھانجے تھے )  سےر وایت کی ,,,,,728
729,"بکیر بن عبداللہ نے ابو سلمہ بن عبدالرحمن سے روایت کی  ،  کہا :  حضرت عائشہ ؓ نے فرمایا :  جب رسول ال",,,,,729
730,حفصہ بنت عبد الرحمن بن ابی بکر سے  (  جو منذر بن زبیر کی اہلیہ تھیں  )  روایت ہے کہ حضرت عائشہؓ نے ا,,,,,730
731,"قاسم بن محمد  (  بن ابی بکر  )  نے حضرت عائشہ ؓ سے روایت کی  ،  فرمایا : میں اور رسول اللہ ﷺ ایک برت",,,,,731
732,( حضرت عائشہ کی شاگرد )  معاذہ بنت عبد اللہ نے حضرت عائشہ ؓ سے روایت کی  ،  انہوں نے کہا میں اور رسو,,,,,732
733,سفیان نے عمرو سے  ،  انہوں نے ابو شعثاء سے  ،  انہوں نے ابن عباسؓ سے روایت کی  ،  کہا ،  مجھے حضرت م,,,,,733
734,"ابن جریج نے عمرو بن دینار سے روایت کی  ،  کہا :  مجھے جتنا زیادہ  (  سےزیادہ  )  علم ہے اور جو میرے ",,,,,734
735,حضرت ام سلمہ ؓ نے بیان کیا کہ وہ اور رسول اللہ ﷺ ایک برتن میں  (  سے  )  غسل جنابت کرتے تھے  ۔,,,,,735
736,عبید اللہ بن معاذ نے بیان کی کہ ان کے والد نے انہیں حدیث سنائی اور ابن مثنی نے عبد الرحمان  ، یعنی ا,,,,,736
737,"مسعر نے ابن جبر سے  ، انہوں نے حضرت انس ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  کہا :  رسول اللہ ﷺ ایک ",,,,,737
738,"بشر نے کہا :  ہمیں ابو ریحانہ نے حضرت سفینہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سےحدیث بیان کی ،  انہوں نے کہا :  ",,,,,738
739,ابو بکر بن ابی شیبہ اورعلی بن حجر نے اسماعیل بن علیہ سے ،  انہوں نے ابو ریحانہ سے  ،  انہوں نےحضرت س,,,,,739
740,ابو احوص نے ابو اسحاق سے  ،  انہو ں نے سلیمان بن صرد سے  ،  انہوں نے حضرت جبیر بن مطعم  ‌رضی ‌اللہ ‌,,,,,740
741,شعبہ نے ابو ا سحاق سے  ،  انہوں نے سلیمان بن صرد سے  ،  انہوں نے حضرت جبیر بن مطعم  ‌رضی ‌اللہ ‌عنہ ,,,,,741
742,"یحییٰ بن یحییٰ اور اسماعیل بن سالم نے کہا :  ہمیں ہشیم نے خبر دی ،  انہوں نے ابو بشر سے  ،  انہوں نے",,,,,742
743,امام جعفر کےوالد امام محمد باقر بن علی بن حسین پ ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے حضرت جابر بن عبد اللہ  ‌رضی,,,,,743
744,سفیان بن عیینہ نے ایوب بن موسیٰ سے  ،  انہوں نے سعید بن ابی سعید مقبیری سے  ،  انہوں نے حضرت ام سلمہ,,,,,744
745,"یزید بن ہارون اور عبدالرزاق نے کہا : ہمیں اسی سند کے ساتھ سفیان ثوری نے ایوب بن موسیٰ کے حوالے سے خب",,,,,745
746,ایوب بن موسیٰ سے  (  سفیان ثوری کے بجائے )  روح بن قاسم نے اسی  ( سابقہ سند )  کے ساتھ روایت کی کہ ا,,,,,746
747,"عبید اللہ بن عمیر سے روایت ہے  ،  انہوں نے کہا :  حضرت عائشہؓ کو یہ خبر پہنچی کہ عبداللہ بن عمروؓ عو",,,,,747
748,"عمرو بن محمد ناقد اور ابن ابی عمر نے سفیان بن عیینہ سے حدیث بیان کی  ،  عمرو نے کہا :  ہمیں سفیان بن",,,,,748
749,"وہیب نے کہا : ہمیں منصور نے اپنی والدہ  ( صفیہ بنت شیبہ )  سے  ،  انہوں نے حضرت عائشہؓ سے روایت کرتے",,,,,749
750,"محمد بن جعفر نے کہا : ہمیں شعبہ نے ابراہیم بن مہاجر سے حدیث سنائی ،  انہوں نےکہا :  میں نے صفیہ سے س",,,,,750
751,"شعبہ کے ایک دوسرے شاگرد عبید اللہ کے والد معاذ بن معاذ عنبری نے کہا :  ہمیں شعبہ نے اسی  ( مذکورہ ) ",,,,,751
752,( شعبہ کے استاد )  ابراہیم بن مہاجر سے  ( شعبہ کے بجائے )  ابو احوص کی سند سے صفیہ بنت شیبہ کے حوالے,,,,,752
753,وکیع نے ہشام بن عروہ سے  ،  انہوں نے اپنے والد سے اور انہوں نے حضرت عائشہؓ سے روایت کی ،  انہوں نے ک,,,,,753
754,ہشام نے عروہ کے  ( شاگرد وکیع کے بجائے )  دوسرے شاگرد وں ابو معاویہ  ،  جریر  ،  نمیر اور حماد بن زی,,,,,754
755,قتیبہ بن سعید اور محمد بن رمح نے لیث سے  ،  انہوں نے ابن شہاب سے  ،  انہوں نے عروہ سے اورانہوں نے حض,,,,,755
756,( لیث کے بجائے )  عمرو بن حارث نے ابن  شہاب سے  ،  انہوں نے عروہ بن زبیر اورعمرہ بنت عبدالرحمن سے  ،,,,,,756
757,ابراہیم  ، یعنی ابن سعد نے ابن شہاب کے حوالے سے خبر دی ،  انہوں نے عمرہ بنت عبد الرحمن سے اور انہوں ,,,,,757
758,سفیان بن عیینہ نے زہری سے  ،  انہوں نے عمرہ سے  ،  انہوں نے حضرت عائشہ ؓ سےروایت کی کہ بنت جحش سات س,,,,,758
759,یزید بن ابی حبیب نے جعفر سے  ،  انہوں نے عراک سے  ،  انہوں نے عروہ سے اور انہوں نے حضرت عائشہ ؓ سےرو,,,,,759
760,اسحاق کے والد بکر بن مضر نے جعفر بن ربیعہ سے باقی ماندہ سابقہ سند سے حضرت عائشہ ؓ سے روایت کی  ،  ان,,,,,760
761,"نے یزید رشک سے  ،  انہوں نے معاذہ سے روایت کی کہ ایک عورت نےحضرت عائشہ ؓ سے پوچھا :  کیا ایک عورت ای",,,,,761
