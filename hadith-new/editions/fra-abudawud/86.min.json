{"metadata":{"name":"Sunan Abu Dawud","section":{"1":"Purification (Kitab Al-Taharah)"},"section_detail":{"1":{"hadithnumber_first":1,"hadithnumber_last":390,"arabicnumber_first":1,"arabicnumber_last":390}}},"hadiths":[{"hadithnumber":86,"arabicnumber":86,"text":"Il est rapporté que ‘Ata n’approuvait pas de faire les ablutions avec du lait ou du nabidh et disait : « Je préfère faire le tayammum plutôt que les ablutions avec du lait ou du nabidh. »","grades":[{"name":"Al-Albani","grade":"Sahih"},{"name":"Muhammad Muhyi Al-Din Abdul Hamid","grade":"Sahih"},{"name":"Shuaib Al Arnaut","grade":"Sahih"},{"name":"Zubair Ali Zai","grade":"Isnaad Sahih"}],"reference":{"book":1,"hadith":86}}]}