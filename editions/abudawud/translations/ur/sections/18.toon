{"hadithnumber": "2862", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  کسی مسلمان کے"}
{"hadithnumber": "2863", "text": "ام المؤمنین عائشہ رضی اللہ عنہا فرماتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے  ( اپنی وفات کے وقت )"}
{"hadithnumber": "2864", "text": "سعد بن ابی وقاص رضی اللہ عنہ کہتے ہیں کہ  وہ بیمار ہوئے  ( ابن ابی خلف کی روایت میں ہے: مکہ میں، آگے"}
{"hadithnumber": "2865", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  ایک شخص نے نبی اکرم صلی اللہ علیہ وسلم سے عرض کیا: کون سا صدقہ اف"}
{"hadithnumber": "2866", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  آدمی کا اپنی زندگی"}
{"hadithnumber": "2867", "text": "ابوہریرہ رضی اللہ عنہ کا بیان ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مرد اور عورت دونوں ساٹ"}
{"hadithnumber": "2868", "text": "ابوذر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مجھ سے فرمایا:  اے ابوذر! میں تمہیں"}
{"hadithnumber": "2869", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  آیت کریمہ: «إن ترك خيرا الوصية للوالدين والأقربين»  اگر"}
{"hadithnumber": "2870", "text": "ابوامامہ رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا ہے:  کہ ال"}
{"hadithnumber": "2871", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں  جب اللہ عزوجل نے آیت کریمہ: «ولا تقربوا مال اليتيم إلا بالت"}
{"hadithnumber": "2872", "text": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  ایک شخص نبی اکرم صلی اللہ علیہ وسلم کے پاس آیا"}
{"hadithnumber": "2873", "text": "علی بن ابی طالب رضی اللہ عنہ کہتے ہیں  میں نے رسول اللہ صلی اللہ علیہ وسلم سے یہ بات سن کر یاد رکھی"}
{"hadithnumber": "2874", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  سات تباہ و برباد کر دینے"}
{"hadithnumber": "2875", "text": "عمیر بن قتادۃ لیثی رضی اللہ عنہ (جنہیں شرف صحبت حاصل ہے) کہ  ایک شخص نے رسول اللہ صلی اللہ علیہ وسلم"}
{"hadithnumber": "2876", "text": "خباب رضی اللہ عنہ کہتے ہیں کہ  مصعب بن عمیر رضی اللہ عنہ احد کے دن قتل کر دیے گئے، اور ان کے پاس ایک"}
{"hadithnumber": "2877", "text": "بریدہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے پاس ایک عورت نے آ کر کہا: میں نے اپن"}
{"hadithnumber": "2878", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  عمر رضی اللہ عنہ کو خیبر میں ایک زمین ملی، وہ نبی اکرم صل"}
{"hadithnumber": "2879", "text": "یحییٰ بن سعید سے عمر بن خطاب رضی اللہ عنہ کے صدقہ کے متعلق روایت ہے، وہ کہتے ہیں کہ  عبدالحمید بن عب"}
{"hadithnumber": "2880", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب انسان مر جاتا ہے تو ا"}
{"hadithnumber": "2881", "text": "ام المؤمنین عائشہ رضی اللہ عنہا فرماتی ہیں کہ  ایک عورت نے رسول اللہ صلی اللہ علیہ وسلم سے عرض کیا:"}
{"hadithnumber": "2882", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  ایک شخص  ( سعد بن عبادہ رضی اللہ عنہ )  نے رسول اللہ صلی"}
{"hadithnumber": "2883", "text": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما سے روایت ہے کہ  عبداللہ بن عمرو بن العاص رضی اللہ عنہما سے ر"}
{"hadithnumber": "2884", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  ان کے والد انتقال کر گئے اور اپنے ذمہ ایک یہودی کا تیس و"}
