metadata:
  section_id: 12
  section_name: Chapter 12
  hadith_first: 93
  hadith_last: 101

hadiths[9]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
93,“The Prophet (Allah bless him and give him peace) used to wear his signet ring on his right hand.”,,,48808,"'Ali ibn Abi Talib said (may Allah be well pleased with him):",Chapter 12
94,"""I saw Ibn Abi Rafi' wearing a signet ring on his right hand, so I asked him about that and he said: 'I saw 'Abdu llah ibn Ja'far wearing a signet ring on his right hand', and 'Abdullah ibn Ja'far said:\n'Allah’s Messenger (Allah bless him and give him peace) used to wear a signet ring on his right hand'.”",,,48809,"Hammad ibn Salama said:",Chapter 12
95,“He (Allah bless him and give him peace) used to wear a signet ring on his right hand.”,,,48810,"Abdullah ibn Ja'far said:",Chapter 12
96,"""The Prophet (Allah bless him and give him peace) used to wear a signet ring on his right hand.”",,,48811,"Jabir ibn ‘Abdi’llah said:",Chapter 12
97,"“Ibn 'Abbas used to wear a signet ring on his right hand, without adornment, and he said: 'Allah’s Messenger (Allah bless him and give him peace) used to wear a signet ring on his right hand'.”",,,48812,"‘As-Salt ibn 'Abdi’llah said:",Chapter 12
98,"""The Prophet (Allah bless him and give him peace) chose a signet ring of silver, and put its stone in the part close to the\npalm of his hand. On it he engraved: “Muhammad is the Messenger of Allah,” and he forbade anyone  to engrave on it. It is the one that fell from Mu'aiqib into the well of Aris.”",,,48813,"Ibn 'Umar said:",Chapter 12
99,"""Al-Hasan and al-Husain used to wear signet rings on their left hands.""",,,48814,"Ja'far ibn Muhammad reports that his father said:",Chapter 12
100,“He (Allah bless him and give him peace) used to wear a signet ring on his right hand.”,,,48815,"Anas ibn Malik said:",Chapter 12
101,"""Allah’s Messenger (Allah bless him and give him peace) chose a signet ring of gold, and he used to wear it on his right hand. The people therefore chose signet rings of gold, so he threw it away (Allah bless him and give him peace) and said: 'I shall never wear it!' The people therefore threw their signet rings away.”",,,48816,"Ibn 'Umar said:",Chapter 12
