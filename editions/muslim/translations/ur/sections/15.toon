{"hadithnumber": "3291", "text": "جریر نے منصور سے ، انھوں نے ابو حازم سے اور انھوں نے ابو ہریرہ  رضی اللہ تعالیٰ عنہ  سے روایت کی ، ک"}
{"hadithnumber": "3292", "text": "ابو عوانہ ، ابو احوص ، مسعر  ، سفیان اورشعبہ سب نے منصور سے اسی سند کے ساتھ یہ حدیث بیا ن کی اور ان"}
{"hadithnumber": "3293", "text": "سیار نے ابو حازم سے ، انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے اورانھوں نے نبی کریم صلی اللہ"}
{"hadithnumber": "3294", "text": "یو نس بن یزید نے مجھے ابن شہاب سے خبر دی کہ علی بن حسین نے انھیں خبر دی کہ عمرو بن عثمان بن عفان نے"}
{"hadithnumber": "3295", "text": "معمر نے زہری سے انھوں نے علی بن حسین سے انھوں نے عمرو بن عثمان سے اور انھوں نے اسامہ بن زید رضی اللہ"}
{"hadithnumber": "3296", "text": "محمد بن ابی حفصہ اور زمعہ بن صالح دونوں نے کہا  ابن شہاب نے ہمیں حدیث بیان کی انھوں نے علی بن حسین س"}
{"hadithnumber": "3297", "text": "سلیمان بن بلال نے ہمیں عبد الرحمٰن بن حمید  ( بن عبد الرحمٰن بن عوف  )  سے حدیث بیان کی کہ انھوں نے"}
{"hadithnumber": "3298", "text": "سفیان بن عیینہ نے ہمیں عبد الرحمٰن بن حمید سے خبر دی انھوں نے کہا  :  میں نے عمر بن عبد لعزیز سے سنا"}
{"hadithnumber": "3299", "text": "صالح نے عبد الرحمٰن بن حمید سے روایت کی کہ انھوں نے عمر بن عبد العزیز سے سنا  ،  وہ سائب بن یزید  رض"}
{"hadithnumber": "3300", "text": "اسماعیل بن محمد بن سعد نے مجھے خبر دی کہ حمید بن عبد الرحمٰن  بن عوف نے انھیں بتا یا کہ سائب بن یزید"}
{"hadithnumber": "3301", "text": "ضحا ک بن مخلد نے ہمیں حدیث بیان کی ،   ( کہا  :   ) ہمیں ابن جریج نے اسی سند کے ساتھ اسی کے مانند خب"}
{"hadithnumber": "3302", "text": "جریر نے ہمیں منصور سے خبر دی انھوں نے مجا ہد سے انھوں نے طاوس سے انھوں نے حضرت ابن عباس رضی اللہ تعا"}
{"hadithnumber": "3303", "text": "مفضل نے ہمیں منصور سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی  ،  انھوں نے  \" جس دن سے اللہ تعا لی"}
{"hadithnumber": "3304", "text": "ابو شریح عدوی رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ انھوں نے عمرو بن سعید سے جب وہ  ( ابن زبیر رضی الل"}
{"hadithnumber": "3305", "text": "ولید بن مسلم نے ہمیں حدیث بیان کی ،   ( کہا )  ہمیں اوزاعی نے حدیث سنا ئی  ۔  ( کہا  :   )  مجھے یحی"}
{"hadithnumber": "3306", "text": "شیبان نے یحییٰ سے روایت کی ،   ( کہا  :   )  مجھے ابو سلمہ نے خبر دی  ، انھوں نے حجرت ابو ہریرہ رضی"}
{"hadithnumber": "3307", "text": "حضرت جا بر رضی اللہ تعالیٰ عنہ  سے روایت ہے انھوں نے کہا  :  میں نے نبی  صلی اللہ علیہ وسلم  سے سنا"}
{"hadithnumber": "3308", "text": "عبد اللہ بن مسلمہ قعنبی یحییٰ بن یحییٰ اور قتیبہ بن سعید نے ہمیں حدیث بیان کی  ، قعنبی نے کہا  :  می"}
{"hadithnumber": "3309", "text": "یحییٰ بن یحییٰ تمیمی اور قتیبہ بن سعید چقفی نے ہمیں حدیث بیان کی  ۔  ۔  ۔ یحییٰ نے کہا  :  ہمیں معاو"}
{"hadithnumber": "3310", "text": "شریک نے ہمیں عمار دہنی سے خبر دی انھوں نے ابو زبیر سے انھوں نے جا بر بن عبد اللہ  رضی اللہ تعالیٰ عن"}
{"hadithnumber": "3311", "text": "وکیع نے ہمیں مساوروراق سے خبردی  ، انھوں نے جعفر بن عمرو بن حریث سے انھوں نے اپنے والد  ( عمرہ بن حر"}
{"hadithnumber": "3312", "text": "ابو بکر بن ابی شیبہ اور حسن حلوانی نے ہمیں حدیث بیان کی دونوں نے کہا  :  ہمیں ابو اسامہ نے مساور ورا"}
{"hadithnumber": "3313", "text": "عبد العزیز  یعنی محمد دراوردی کے بیٹے نے عمرو بن یحییٰ مازنی سے حدیث بیان کی انھوں نے عباد بن تمیم س"}
{"hadithnumber": "3314", "text": "عبدالعزیز یعنی ابن مختار سلیمان بن بلال اور وہیب  ( بن خالد باہلی  )  سب نے عمرو بن یحییٰ مازنی سے ا"}
{"hadithnumber": "3315", "text": "عبد اللہ بن عمرو بن عثمان نے رافع بن خدیج  رضی اللہ تعالیٰ عنہ  سے روایت کی ،  انھوں نے کہا  :  رسول"}
{"hadithnumber": "3316", "text": "نافع بن جبیر سے روایت ہے کہ مروان بن حکم نے لوگون کو خطا ب کیا ،  اس نے مکہ کے باشبدوں اور اس کی حرم"}
{"hadithnumber": "3317", "text": "حضرت جا بر رضی اللہ تعالیٰ عنہ  سے روایت ہے کہا  :  رسول اللہ  صلی اللہ علیہ وسلم  نے فر مایا :  "}
{"hadithnumber": "3318", "text": "عبد اللہ بن نمیر نے کہا  : ہمیں عثمان بن حکیم نے حدیث بیان کی  ( کہا )  ۔ مجھ سے عامر بن سعد نے اپنے"}
{"hadithnumber": "3319", "text": "مروان بن معاویہ نے ہمیں حدیث بیان کی  ( کہا :   )  ہمیں عثمان بن حکیم انصاری نے حدیث بیان کی ،  ( کہ"}
{"hadithnumber": "3320", "text": "اسماعیل بن محمد نے عا مر بن سعد سے روایت کی کہ حضرت سعد  ( بن ابی وقاص رضی اللہ تعالیٰ عنہ  )   ( مد"}
{"hadithnumber": "3321", "text": "اسماعیل بن جعفر نے ہمیں ھدیث بیان کی ،   ( کہا )  مجھے مطلب بن عبد اللہ بن خطا ب کے مولیٰ عمرو بن اب"}
{"hadithnumber": "3322", "text": "یعقوب بن عبد الرحمٰن القاری نے ہمیں عمرو بن ابی عمرو سے حدیث بیان کی انھوں نے انس بن مالک رضی اللہ ت"}
{"hadithnumber": "3323", "text": "عاصم نے ہمیں حدیث بیان کی کہا  :  میں نے حضرت انس بن مالک  رضی اللہ تعالیٰ عنہ  سے پو چھا  :  کیا رس"}
{"hadithnumber": "3324", "text": "ہمیں عاصم احول نے خبر دی کہا  ،  میں نے حضرت انس رضی اللہ تعالیٰ عنہ  سے پوچھا :  کیا رسول اللہ  صلی"}
{"hadithnumber": "3325", "text": "اسحاق بن عبد اللہ بن ابی طلحہ نے حجرت انس بن مالک  رضی اللہ تعالیٰ عنہ سے روایت کی کہ رسول اللہ  صلی"}
{"hadithnumber": "3326", "text": "زہری نے حضرت انس بن مالک  رضی اللہ تعالیٰ عنہ  سے روایت کی ،  انھوں نے کہا  :  رسول اللہ  صلی اللہ ع"}
{"hadithnumber": "3327", "text": "ہمیں ابو بکر بن ابی شیبہ زہیر بن حرب اور ابو کریب سب نے ابو معاویہ سے حدیث بیان کی  ( کہا )  ہمیں اع"}
{"hadithnumber": "3328", "text": "علی بن مسہر اور وکیع دونوں نے اعمش سے سی سند کے ساتھ اسی طرح حدیث بیان کی جس طرح آخر تک ابو معاویہ س"}
{"hadithnumber": "3329", "text": "سفیان نے اعمش سے اسی سند کے ساتھ ابن مسہر اور وکیع کی حدیث کی طرح بیان کی مگر اس میں  \" جس نے اپنے م"}
{"hadithnumber": "3330", "text": "زائد ہ نے سلیمان سے انھوں نے ابو صالح سے انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے اور انھوں ن"}
{"hadithnumber": "3331", "text": "سفیان نے اعمش سے اسی سند کے ساتھ اسی کے مانند روایت کی ، اور انھوں نے  \" قیامت کے دن \"  کے الفاظ نہی"}
{"hadithnumber": "3332", "text": "ہمیں یحییٰ بن یحییٰ نے حدیث سنا ئی کہا  :  میں نے امام مالک  کے سامنے قراءت کی کہ ابن شہاب سے روایت"}
{"hadithnumber": "3333", "text": "معمر نے ہمیں زہری سے حدیث بیان کی انھوں نے سعید بن مسیب سے انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ ع"}
{"hadithnumber": "3334", "text": "امام مالک بن انس کے سامنے جن احادیث کی قراءت کی گئی ان میں سے سہیل بن ابی صالح نے اپنے والد سے اور ا"}
{"hadithnumber": "3335", "text": "عبد العزیز بن محمد مدنی نے ہمیں سہیل بن ابی صالح سے خبر دی انھوں نے اپنے والد سے انھوں نے حضرت ابو ہ"}
{"hadithnumber": "3336", "text": "حماد بن اسماعیل بن علیہ نے ہمیں ہمیں  حدیث بیا ن کی ،  ( کہا :  )  ہمیں میرے والد نے وہیب سے حدیث بی"}
{"hadithnumber": "3337", "text": "علی بن مبارک سے روایت ہے ،  ( کہا :  )  ہمیں یحییٰ بن ابی کثیر نے حدیث بیان کی ،  ( کہا :  )  ہمیں م"}
{"hadithnumber": "3338", "text": "شیبان اورحرب ، یعنی ابن شداد دونوں نے یحییٰ بن ابی کثیر سے اسی سندکے ساتھ  ، اسی کے مانند حدیث بیان"}
{"hadithnumber": "3339", "text": "سعید بن ابوسعید نے مہری کے آزاد کردہ غلام ،  ابو سعید سے روایت کی وہ سیدنا ابو سعید خدری رضی اللہ عن"}
{"hadithnumber": "3340", "text": "سعید بن عبدالرحمان بن ابی سعیدخدری  رضی اللہ تعالیٰ عنہ  نے حدیث بیان کی کہ عبدالرحمان نے انھیں اپنے"}
{"hadithnumber": "3341", "text": "سہل بن حنیف  رضی اللہ تعالیٰ عنہ  سے روایت ہے  ، انھوں نے کہا : رسول اللہ  صلی اللہ علیہ وسلم  نے اپ"}
{"hadithnumber": "3342", "text": "عبدہ نے ہمیں ہشام سے حدیث بیان کی ، انھوں نے اپنے والدسے اورانھوں نے حضرت عائشہ  رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "3343", "text": "ابو اسامہ اور ابن نمیر دونوں نے ہشام بن عروہ سے اسی سند کےساتھ اسی کے ہم معنی حدیث بیان کی ۔"}
{"hadithnumber": "3344", "text": "نافع نے ہمیں حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے حدیث بیان کی ، انھوں نے کہا : میں نے رسول اللہ  صل"}
{"hadithnumber": "3345", "text": "امام مالک نے قطن بن وہب بن عویمر بن اجدع سےروایت کی ، انھوں نے حضرت زبیر کے آزاد کردہ غلام یحس سے رو"}
{"hadithnumber": "3346", "text": "ضحاک نے ہمیں قطن خزاعی سے خبر دی ، انھوں نے مصعب کے مولیٰ یحس سے ، انھوں نے حضرت عبداللہ بن عمر  رضی"}
{"hadithnumber": "3347", "text": "علاء بن عبدالرحمان  ( بن یعقوب )  نے اپنے والدسے ، انھوں نے حضرت ابو ہریرہ  رضی اللہ تعالیٰ عنہ  سے"}
{"hadithnumber": "3348", "text": "ابو عبداللہ قر اظ کہتے ہیں : میں نے حضرت ابو ہریرہ  رضی اللہ تعالیٰ عنہ  کو یہ کہتے ہوئے سنا : رسول"}
{"hadithnumber": "3349", "text": "صالح بن ابو صالح نے اپنے والد سے ، انھوں نے حضرت ابوہریرہ  رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا :"}
{"hadithnumber": "3350", "text": "نعیم بن عبداللہ نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی ، انھوں نےکہا : رسول اللہ  صلی ال"}
{"hadithnumber": "3351", "text": "اسماعیل بن جعفر سے روایت ہے ۔  ( کہا :  ) علاء نے ا پنے والد سے ، انھوں نے حضرت ابو ہریرہ  رضی اللہ"}
{"hadithnumber": "3352", "text": "۔  ہمیں عبدالعزیز   یعنی دراوردی نے حدیث بیان کی ، انھوں نےعلاء سے انھوں نے ا پنے والد سے اور انھوں"}
{"hadithnumber": "3353", "text": "امام مالک بن انس نے یحییٰ بن سعید سے روایت کی ، انھوں نے کہا ، میں نے ابو حباب سعید بن یسار سے سنا ،"}
{"hadithnumber": "3354", "text": "سفیان اورعبدالوہاب دونوں نے یحییٰ بن سعید سے اسی سند کے ساتھ روایت کی اور دونوں نے کہا :  \" جیسے بھٹ"}
{"hadithnumber": "3355", "text": "حضرت جابر بن عبداللہ سے روایت ہے کہ ایک بدو نے رسول اللہ  صلی اللہ علیہ وسلم  سے بیعت کی ۔ اس کے بعد"}
{"hadithnumber": "3356", "text": "حضرت زید بن ثابت  رضی اللہ تعالیٰ عنہ  نے نبی  صلی اللہ علیہ وسلم  سے روایت کی ، آپ صلی اللہ علیہ وس"}
{"hadithnumber": "3357", "text": "حضرت جابر بن سمرہ  رضی اللہ تعالیٰ عنہ  سے روایت ہے ، انھوں نے کہا : میں نے رسول اللہ  صلی اللہ علیہ"}
{"hadithnumber": "3358", "text": "عبداللہ بن عبدالرحمان بن یحس نےمجھے ابو عبداللہ قراظ سے خبر دی ، انھوں نے کہا : میں ابو ہریرہ رضی ال"}
{"hadithnumber": "3359", "text": "محمد بن حاتم اور ابراہیم بن دینار نے مجھے حدیث بیان کی ، دونوں نے کہا ، ہم سے حجاج نے حدیث بیا ن کی"}
{"hadithnumber": "3360", "text": "ابو ہارون موسیٰ بن ابی عیسیٰ اورمحمد بن عمرو دونوں نے ابو عبداللہ قراظ سے سنا ، انھوں نے حضرت ابو ہر"}
{"hadithnumber": "3361", "text": "حاتم ، یعنی ابن اسماعیل نے ہمیں عمر بن نبیہ سے حدیث بیان کی ، کہا : مجھے دینار قراظ نے خبر دی ، انھو"}
{"hadithnumber": "3362", "text": "اسماعیل بن جعفر نے ہمیں عمر بن نبیہ کعبی سے حدیث بیان کی ، انھوں نے ابو عبداللہ قراظ سے روایت کی کہ"}
{"hadithnumber": "3363", "text": "اسامہ بن زید نے ہمیں  ابو عبداللہ قراظ سے حدیث بیان کی ،  ( اسامہ نے  )  کہا : میں نے ان سے سنا ، کہ"}
{"hadithnumber": "3364", "text": "وکیع نے ہمیں ہشام بن  عروہ سے حدیث بیان کی ، انھوں نے اپنے والد سے ، انھوں نے عبداللہ بن زبیر  رضی ا"}
{"hadithnumber": "3365", "text": "ہمیں ابن  جریج نے خبر دی ،  ( کہا :  )  مجھے ہشام بن عروہ نے اپنے والد سے خبر دی ، انھوں نے عبداللہ"}
{"hadithnumber": "3366", "text": "ابو صفوان اور ابن وہب نے یونس بن یزید سے ، انھوں نے ابن شہاب سے  ، انھوں نے سعید بن مسیب سے روایت کی"}
{"hadithnumber": "3367", "text": "عقیل بن خالد نے مجھے ابن شہاب سے حدیث سنائی ، انھوں نے کہا : مجھے سعید بن مسیب نے خبر دی کہ حضرت ابو"}
{"hadithnumber": "3368", "text": "عبد اللہ بن ابوبکر نے عباد بن تمیم سے انھوں نے عبد اللہ بن زید  ( بن عاصم )  مازنی  رضی اللہ تعالیٰ"}
{"hadithnumber": "3369", "text": "ابو بکر نے ے عباد تمیم سے انھوں نے عبد اللہ بن زید انصاری رضی اللہ تعالیٰ عنہ  سے روایت کی کہ انھوں"}
{"hadithnumber": "3370", "text": "حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ رسول اللہ  صلی اللہ علیہ وسلم  نے فرمایا  :  "}
{"hadithnumber": "3371", "text": "حضرت ابو حمید  رضی اللہ تعالیٰ عنہ سے روایت ہے کہا  :  غزوہ تبوک کے موقع پر ہم رسول اللہ  صلی اللہ ع"}
{"hadithnumber": "3372", "text": "عبید اللہ بن معاذ نے ہم سے حدیث بیان کی  ( کہا  :  )  میرے والد نے ہمیں حدیث سنا ئی  ( کہا  :   )  ہ"}
{"hadithnumber": "3373", "text": "حرم بن عمارہ نے مجھے سابقہ سند کے ساتھ حدیث بیان کی کہ حضرت انس بن مالک رضی اللہ تعالیٰ عنہ  سے روای"}
{"hadithnumber": "3374", "text": "سفیان بن عیینہ نے ہمیں زہری سے حدیث بیان کی ،  انھوں نے سعید بن مسیب سے انھوں نے ابو ہریرہ رضی اللہ"}
{"hadithnumber": "3375", "text": "معمر نے ہمیں زہری سے خبر دی انھوں نے سعید بن مسیب سے انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے"}
{"hadithnumber": "3376", "text": "ابو سلمہ بن عبدالرحمٰن اور جہینہ والوں کے آزاد کردہ غلام ابو عبداللہ اغر سے روایت ہے ۔  ۔  ۔ اور یہ"}
{"hadithnumber": "3377", "text": "عبد الوہاب نے ہمیں حدیث بیان کی کہا  ، میں نے یحییٰ بن سعید کو کہتے ہو ئے سنا کہ میں نے ابو صا لح سے"}
{"hadithnumber": "3378", "text": "یحییٰ قطان نے یحییٰ بن سعید سے اسی سند کے ساتھ  ( یہی )  حدیث بیان کی ۔"}
{"hadithnumber": "3379", "text": "یحییٰ قطان نے ہمیں عبید اللہ ( بن عمر )  سے حدیث بیان کی ،  انھوں نے کہا  :  مجھے نافع نے حضرت ابن"}
{"hadithnumber": "3380", "text": "ابو اسامہ عبد اللہ بن نمیر اور عبد الوہاب سب نے عبید اللہ سے اسی سند کے ساتھ  ( یہ )  حدیث بیان کی ۔"}
{"hadithnumber": "3381", "text": "موسیٰ جہنی نے نافع سے انھوں نے ابن عمر رضی اللہ تعالیٰ عنہ  سے روایت کی  ، انھوں نے کہا  :  میں نے ر"}
{"hadithnumber": "3382", "text": "ایوب نے نافع سے انھوں نے ابن عمر رضی اللہ تعالیٰ عنہ  سے انھوں نے نبی  صلی اللہ علیہ وسلم  سے اسی کے"}
{"hadithnumber": "3383", "text": "لیث نے نافع سے روایت کی ،  انھوں نے ابرا ہیم  بن عبد اللہ بن معبد  ( بن عباس )  سے روایت کی ،   ( کہ"}
{"hadithnumber": "3384", "text": "سفیان نے زہری سے انھوں نے سعید  ( بن مسیب  )  سے انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ سے روای"}
{"hadithnumber": "3385", "text": "معمر نے زہری سے اسی سند کے ساتھ روایت کی  ، البتہ انھوں نے کہا  :  \"   ( عبادت کے لیے )  تین مسجدوں"}
{"hadithnumber": "3386", "text": "سلمان اغر نے حدیث بیان کی انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے سنا ،  وہ بتا رہے تھے کہ ر"}
{"hadithnumber": "3387", "text": "حمید خراط سے روایت ہے کہا  :  میں نے ابو سلمہ بن عبد الرحمٰن سے سنا انھوں نے کہا  :  عبد الرحمٰن بن"}
{"hadithnumber": "3388", "text": "حمید  ( طویل )  نے ابو سلمہ سے انھوں نے ابو سعید خدی  رضی اللہ تعالیٰ عنہ  سے اور انھوں نے نبی  صلی"}
{"hadithnumber": "3389", "text": "ایوب نے ہمیں نافع سے حدیث بیان کی ،  انھوں نے ابن عمر رضی اللہ تعالیٰ عنہ سے روایت کی کہ رسول اللہ"}
{"hadithnumber": "3390", "text": "ابو بکر ابی شیبہ نے حدیث بیان کی ،   ( کہا  )  ہمیں عبد اللہ بن نمیر اور ابو اسامہ نے عبید اللہ سے ح"}
{"hadithnumber": "3391", "text": "ہمیں یحییٰ نےحدیث بیان کی ،  ( کہا :   )  ہمیں عبید اللہ نے حدیث بیان کی  ،  ( کہا :   ) مجھے نافع ن"}
{"hadithnumber": "3392", "text": "خالد بن حارث نے ہمیں ابن عجلا ن سے حدیث بیان کی  ، انھوں نے نافع سے ،  انھوں نے حضرت ابن عمر رضی الل"}
{"hadithnumber": "3393", "text": "یحییٰ بن یحییٰ نے کہا  :  میں نے امام مالک کے سامنے قراءت کی کہ عبد اللہ بن دینار سے روایت ہے ، انھو"}
{"hadithnumber": "3394", "text": "ہمیں اسماعیل بن جعفر نے حدیث بیان کی ،   ( کہا :   )  مجھے عبد اللہ بن دینار نے خبر دی کہ انھوں نے ح"}
{"hadithnumber": "3395", "text": "مجھے زہیر بن حرب نے حدیث بیان کی کہا  :  ہمیں سفیان بن عیینہ نے حدیث سنا ئی  ۔ انھوں نے عبد اللہ بن"}
{"hadithnumber": "3396", "text": "ابن ابی عمر نے سفیان سے باقی ماندہ اسی سند کے ساتھ روایت کی کہ رسول اللہ  صلی اللہ علیہ وسلم  ہر ہفت"}
{"hadithnumber": "3397", "text": "سفیان ثوری نے ابن دینار سے اسی سند کے ساتھ روایت کی ، مگر ہر ہفتے کے روز کا ذکر نہیں کیا  ۔"}
