{"hadithnumber": "5114", "text": "ابو سنان ضرار بن مرہ نے محارب بن دثار سے ، انھوں نے عبداللہ بن بریدہ سے ، انھوں نے اپنے والد سے روای"}
{"hadithnumber": "5115", "text": "علقمہ بن مرثد نے ابن بریدہ سے ، انھوں نے اپنے والد سے روایت کی کہ رسول اللہ  صلی اللہ علیہ وسلم  نے"}
{"hadithnumber": "5127", "text": "حجاج بن محمد نے ابن جریج سے روایت کی ،  کہا :  مجھے ابن شہاب نے علی بن حسین بن علی سے حدیث بیان کی ،"}
{"hadithnumber": "5128", "text": "عبد الرزاق نے ابن جریج سے اسی سند کے ساتھ اسی کے مانند روایت کی ۔"}
{"hadithnumber": "5129", "text": "۔  عبد اللہ  بن وہب نے کہا  : مجھے یو نس بن یزید نے ابن شہاب سے حدیث بیان کی ،  کہا  :  مجھے علی بن"}
{"hadithnumber": "5130", "text": "عبد اللہ بن مبارک نے یو نس سے انھوں نے زہری سے اسی سند کے ساتھ  اسی کے مانند روایت کی ۔"}
{"hadithnumber": "5131", "text": "ثابت نے حضرت انس بن مالک  رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہا :  جس دن شرا ب حرام کی گئی  ، میں"}
{"hadithnumber": "5132", "text": "عبد العز یز بن صہیب نے کہا :  لوگوں نے حضرت انس بن مالک رضی اللہ تعالیٰ عنہ  سے فضیخ  ( ملی جلی کچی"}
{"hadithnumber": "5133", "text": "ابن علیہ نے کہا  :  ہمیں سلیمان تیمی نے بتا یا کہا  :  ہمیں حضرت انس بن ما لک  رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "5134", "text": "محمد بن عبد الاعلیٰ نے کہا  :  ہمیں معتمر  ( بن سلیمان تیمی )  نے اپنے والد سے حدیث بیان کی کہا  :"}
{"hadithnumber": "5135", "text": "سعید بن ابی عروبہ نے قتادہ سے  ، انھوں نے حضرت انس بن مالک  رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا :"}
{"hadithnumber": "5136", "text": "معاذ کے والد ہشام نے قتادہ سے ، انھوں نے حضرت انس بن مالک رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا : م"}
{"hadithnumber": "5137", "text": "عمرو بن حارث نے کہا کہ قتادہ بن دعامہ نے انھیں حدیث بیان کی ، انھوں نے حضرت انس بن مالک رضی اللہ تعا"}
{"hadithnumber": "5138", "text": "اسحاق بن عبداللہ بن ابی طلحہ نے انس بن مالک  رضی اللہ تعالیٰ عنہ  سے روایت کی کہ انھوں نے کہا : میں"}
{"hadithnumber": "5139", "text": "عبدالحمید بن جعفر نے ہمیں اپنے والد سے حدیث بیان کی  ، کہا :  مجھے میرے والد نے حدیث بیان کی ، انھوں"}
{"hadithnumber": "5140", "text": "حضرت انس رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ  نبی کریم صلی اللہ علیہ وسلم  سے شراب کو سرکہ بنانے کے"}
{"hadithnumber": "5141", "text": "حضرت  طارق بن سوید جعفی رضی اللہ تعالیٰ عنہ  نے نبی کریم صلی اللہ علیہ وسلم  سے شراب ( بنانے )  کےمت"}
{"hadithnumber": "5142", "text": "یحییٰ بن ابی کثیر نے کہا کہ ابو کثیر نے انھیں حدیث بیان کی ، انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ"}
{"hadithnumber": "5143", "text": "عبداللہ بن نمیر نےکہا : اوزاعی نے ہمیں حدیث بیان کی ، کہا : ہمیں ابو کثیر نے حدیث سنائی ، کہا : میں"}
{"hadithnumber": "5144", "text": "زہیر بن حرب اور ابوکریب نے کہا : ہمیں وکیع نےاوزاعی  ، عکرمہ بن عمار اورعقبہ بن توام سے حدیث بیان کی"}
{"hadithnumber": "5145", "text": "جریر بن حازم نے کہا : میں نے عطاء ابن ابی رباح سے سنا ، کہا : ہمیں حضرت جابر بن عبداللہ انصاری رضی ا"}
{"hadithnumber": "5146", "text": "لیث نے عطاء ابن ابی رباح سے ، انھوں نے حضرت جابر بن عبداللہ انصاری رضی اللہ تعالیٰ عنہ  سے روایت کی"}
{"hadithnumber": "5147", "text": "ابن جریج نے کہا : عطاء نے مجھ سے کہا کہ میں نے حضرت جابر بن عبداللہ رضی اللہ تعالیٰ عنہ  سے سنا ، کہ"}
{"hadithnumber": "5148", "text": "حکیم بن حزام  رضی اللہ تعالیٰ عنہ  کے آزاد کردہ غلام ابوزبیر نے حضرت جابر بن عبداللہ انصاری رضی اللہ"}
{"hadithnumber": "5149", "text": "تیمی نے ابو نضرہ سے ، انھوں نے حضرت ابوسعید خدری رضی اللہ تعالیٰ عنہ  سے روایت کی کہ نبی کریم  صلی ا"}
{"hadithnumber": "5150", "text": "سعید بن یزید ابو مسلمہ نے ابونضرہ سے ، انھوں نے حضرت ابوسعید خدری رضی اللہ تعالیٰ عنہ  سے روایت کی"}
{"hadithnumber": "5151", "text": "بشر بن مفضل نے ابومسلمہ سے اسی سند کے ساتھ اسی کے مانندروایت کی ۔"}
{"hadithnumber": "5152", "text": "وکیع نے اسماعیل بن مسلم عبدی سے ، انھوں نے ابو متوکل ناجی سے ، انھوں نے حضرت ابوسعید خدری رضی اللہ ت"}
{"hadithnumber": "5153", "text": "روح بن عبادہ نے کہا : ہمیں اسماعیل بن مسلم عبدی نے اسی سند کے ساتھ حدیث بیان کی ، کہا : رسول اللہ  ص"}
{"hadithnumber": "5154", "text": "ہشام دستوائی نے یحییٰ بن ابی کثیر سے ، انھوں نے عبداللہ بن ابی قتادہ سے ، انھوں نے اپنے والد سے روای"}
{"hadithnumber": "5155", "text": "حجاج بن ابی عثمان نے یحییٰ بن ابی کثیر سے اسی سند کے ساتھ اسی کے مانند روایت کی ۔"}
{"hadithnumber": "5156", "text": "علی بن مبار ک نے یحییٰ  ( بن ابی کثیر  ) سے انھوں نے ابو سلمہ سے انھوں نے حضرت ابو قتادہ  رضی اللہ ت"}
{"hadithnumber": "5157", "text": "حسین معلم نے کہا  :  یحییٰ بن ابی کثیر نے ہمیں انھی دونوں سندوں سے حدیث بیان کی ،  مگر انھوں نے کہا"}
{"hadithnumber": "5158", "text": "۔  ابان عطار نے کہا  :  ہمیں یحییٰ بن ابی کثیر نے حدیث بیان کی کہا :  مجھے عبد اللہ بن ابی قتادہ رضی"}
{"hadithnumber": "5159", "text": "ابو سلمہ بن عبد الرحمٰن نے ابو قتادہ رضی اللہ تعالیٰ عنہ  سے انھوں نے نبی  صلی اللہ علیہ وسلم  سے اس"}
{"hadithnumber": "5160", "text": "وکیع نے عکرمہ بن عمار سے انھوں نے ابو کثیر حنفی سے انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے ر"}
{"hadithnumber": "5161", "text": "ہا شم بن قاسم نے کہا  :  ہمیں عکرمہ بن عمار نے حدیث بیان کی  ، کہا :  ہمیں یزید بن عبد الرحمٰن بن اذ"}
{"hadithnumber": "5162", "text": "علی بن مسہر نے ہمیں شیبانی سے حدیث بیان کی  ، انھوں نے حبیب سے انھوں نے سعید بن جبیر سے انھوں نے حضر"}
{"hadithnumber": "5163", "text": "خالد طلحان نے شیبانی سے اسی سند کے ساتھ خشک کھجوروں اور کشمش کے متعلق روایت بیان کی اور انھوں نے کچی"}
{"hadithnumber": "5164", "text": "عبد الرزاق نے کہا  :  ہمیں ابن جریج نے خبردی کہا  :  مجھے موسیٰ بن عقبہ نے بتا یا انھوں نے نافع سے ا"}
{"hadithnumber": "5165", "text": "روح نے کہا  :  ہمیں ابن جریج نے حدیث بیان کی ،  کہا :  مجھے موسیٰ بن عقبہ نے نا فع سے خبر دی انھوں ن"}
{"hadithnumber": "5166", "text": "لیث نے ابن شہاب سے ، انھوں نے حضرت انس بن مالک رضی اللہ تعالیٰ عنہ  سے روایت کی ، انھوں نے ان کو بتا"}
{"hadithnumber": "5167", "text": "سفیان بن عینیہ نے زہری سے ، انھوں نے حضرت انس بن مالک رضی اللہ تعالیٰ عنہ  سے روایت کی کہ رسول اللہ"}
{"hadithnumber": "5168", "text": "۔  ( گزشتہ سند سے روایت کرتے ہوئے سفیان بن عینیہ نے )  کہا : انھیں ابو سلمہ نے بتایا کہ انھوں نے حضر"}
{"hadithnumber": "5169", "text": "سہیل کے والد ( ابوصالح )  نے حضرت ابوہریرہ رضی اللہ تعالیٰ عنہ  سے  ، انھوں نے نبی کریم  صلی اللہ عل"}
{"hadithnumber": "5170", "text": "محمد نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی کہ نبی کریم صلی اللہ علیہ وسلم  نے عبدالقیس"}
{"hadithnumber": "5171", "text": "عبشر ، جریر اور شعبہ سب نے اعمش سے ، انھوں نے ابراہیم تیمی سے ، انھوں نے حارث بن  سوید سے اور انھوں"}
{"hadithnumber": "5172", "text": "منصور نے ابراہیم سے روایت کی ، کہا :  میں نے اسود سے کہا : کیا تم نے ام المومنین ( عائشہ صدیقہ  رضی"}
{"hadithnumber": "5173", "text": "اعمش نے ابراہیم سے انھوں نے اسود سے ، انھوں نے حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے روایت کی کہ رسو"}
{"hadithnumber": "5174", "text": "منصور ، سلیمان اور حماد نے ابراہیم سے  ، انھوں نے اسود سے ، انھوں نے حضرت عائشہ  رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "5175", "text": "ثمامہ بن حزن قشیری نے حدیث بیان کی ، کہا : میں نے حضرت عائشہ  رضی اللہ تعالیٰ عنہا   کی خدمت میں حاض"}
{"hadithnumber": "5176", "text": "ابن علیہ نے کہا : ہمیں اسحاق بن سوید نے معاذہ سےحدیث بیان کی ، انھوں نےحضرت عائشہ رضی اللہ تعالیٰ عن"}
{"hadithnumber": "5177", "text": "عبدالوہاب ثقفی نے کہا : ہمیں اسحاق بن سوید نے اسی سند کے ساتھ حدیث بیان کی مگر انھوں نے روغن زفت ملے"}
{"hadithnumber": "5178", "text": "عباد بن عباد اورحماد بن زید نے ابو حمزہ سے روایت کی ، انھوں نے کہا : میں نے حضرت ابن عباس  رضی اللہ"}
{"hadithnumber": "5179", "text": "حبیب بن ابی ثابت نے سعید بن جبیر سے ، انھوں نے حضرت ابن عباس رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا"}
{"hadithnumber": "5180", "text": "حبیب بن ابی عمرہ نے سعید بن جبیر سے ، انھوں نے حضرت ابن عباس رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا"}
{"hadithnumber": "5181", "text": "یحییٰ بن ابی عمر نے حضرت ابن عباس  رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا : رسول اللہ  صلی اللہ علیہ"}
{"hadithnumber": "5182", "text": "حضرت ابو سعید خدری رضی اللہ تعالیٰ عنہ   سے روایت ہے کہ رسول اللہ صلی اللہ علیہ وسلم  نے گھڑوں میں ن"}
{"hadithnumber": "5183", "text": "سعید بن ابی عروبہ نے قتادہ سے ، انھوں نے ابو نضرہ سے ، انھوں نے حضرت ابو سعید خدری رضی اللہ تعالیٰ ع"}
{"hadithnumber": "5184", "text": "ہشام نے قتادہ سے اسی سند کے ساتھ روایت کی کہ نبی کریم  صلی اللہ علیہ وسلم  نے  ( ان برتنوں میں  )  ن"}
{"hadithnumber": "5185", "text": "ابو متوکل نے حضرت ابو سعید  رضی اللہ تعالیٰ عنہ  سے روایت کی  ، کہا : رسول اللہ  صلی اللہ علیہ وسلم"}
{"hadithnumber": "5186", "text": "منصور بن حیان نے سعید بن جبیر سے روایت کی  ، کہا : میں حضرت ابن عمر  رضی اللہ تعالیٰ عنہ  اور حضرت ا"}
{"hadithnumber": "5187", "text": "یعلیٰ بن حکیم نے سعید بن جبیر سے روایت کی ، کہا :  میں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے گھڑوں"}
{"hadithnumber": "5188", "text": "امام مالک  رحمۃ اللہ علیہ  نے نافع سے ، انھوں نے حضرت ابن عمر  رضی اللہ تعالیٰ عنہ  سے روایت کی کہ ر"}
{"hadithnumber": "5189", "text": "لیث بن سعد ، ایوب ، عبیداللہ ، یحییٰ بن سعید ، ضحاک بن عثمان اور اسامہ ان سب نے حضرت ابن عمر رضی الل"}
{"hadithnumber": "5190", "text": "ثابت سے روایت ہے  ، کہا : میں نےحضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے پوچھا : رسول اللہ  صلی اللہ علی"}
{"hadithnumber": "5191", "text": "سلیمان تیمی نے طاوس سے روایت کی ، کہا : ایک شخص نے ابن عمر  رضی اللہ تعالیٰ عنہ  سے پوچھا کہ نبی کری"}
{"hadithnumber": "5192", "text": "ابن جریج نے کہا : مجھے ابن طاوس نے اپنے والد سے خبر دی ، انھوں نے حضرت ابن عمر  رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "5193", "text": "وہیب نے عبداللہ بن طاوس سے  ، انھوں نے اپنے والد سے  ، انھوں نے حضرت ابن عمر  رضی اللہ تعالیٰ عنہ  س"}
{"hadithnumber": "5194", "text": "ابراہیم بن میسرہ سے روایت ہے کہ انھوں نے طاوس کو یہ کہتے ہوئے سنا : میں حضرت ابن عمر رضی اللہ تعالیٰ"}
{"hadithnumber": "5195", "text": "شعبہ نے محارب بن دثار سے روایت کی ، انھوں نے کہا : میں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  کو یہ کہ"}
{"hadithnumber": "5196", "text": "شیبانی نے محارب بن دثار سے  ، انھوں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے اور انھوں نے نبی کریم صل"}
{"hadithnumber": "5197", "text": "عقبہ بن حریث نے کہا : میں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  کو یہ کہتے ہوئے سنا : رسول اللہ  صلی"}
{"hadithnumber": "5198", "text": "جبلہ نے کہا  :  میں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  کو حدیث بیان کرتے ہوئے سنا  ، کہا :  رسول ا"}
{"hadithnumber": "5199", "text": "عبید اللہ کے والد معاذ نے کہا  :  ہمیں شعبہ نے عمرو بن مرہ سے حدیث کی ،  کہا  :  مجھے زاذان نے حدیث"}
{"hadithnumber": "5200", "text": "ابو داؤد نے کہا  :  ہمیں شعبہ نے اسی سند کے ساتھ حدیث بیان کی ۔"}
{"hadithnumber": "5201", "text": "عبد الخالق  بن سلمہ نے کہا  :  میں نے سعید بن مسیب کو کہتے ہو ئے سنا کہ میں نے عبد اللہ بن عمر رضی ا"}
{"hadithnumber": "5202", "text": "ابو خیثمہ   ( زہیر  )  نے ابو زبیر سے انھوں نے حضرت جا بر اور حضرت عبد اللہ بن عمر رضی اللہ تعالیٰ ع"}
{"hadithnumber": "5203", "text": "ابن جریج نے کہا  :  مجھے ابو زبیر نے بتا یا کہ انھوں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  کو کہتے ہو"}
{"hadithnumber": "5205", "text": "ابو عوانہ نے ابو زبیر سے ،  انھوں نے حضرت جا بر رضی اللہ تعالیٰ عنہ  سے روایت کی کہ نبی  صلی اللہ عل"}
{"hadithnumber": "5206", "text": "ہمیں ابو خیثمہ  ( زہیر  )  نے ابو زبیر سے خبر دی انھوں نے حضرت جا بر رضی اللہ تعالیٰ عنہ  سے روایت ک"}
{"hadithnumber": "5209", "text": "معرف بن واصل نے محارب بن دثار سے انھوں نے ابن بریدہ سے انھوں نے اپنے والد سے روایت کی ،  کہا :  رسول"}
{"hadithnumber": "5210", "text": "حضرت عبد اللہ بن عمرو رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ جب رسول اللہ صلی اللہ علیہ وسلم  نے  ( بعض"}
{"hadithnumber": "5211", "text": "امام مالک نے ابن شہاب  ( زہری )  سے انھوں نے ابو سلمہ بن عبد الرحمٰن سے انھوں نے حضرت عائشہ رضی اللہ"}
{"hadithnumber": "5212", "text": "یو نس نے ابن شہا ب سے انھوں نے ابو سلمہ بن عبد الرحمٰن سے روایت کی ،  انھوں نے حضرت عائشہ رضی اللہ ت"}
{"hadithnumber": "5213", "text": "۔  ( سفیان  )  ابن عیینہ صالح اور معمر سب نے زہری سے اسی سند کے ساتھ روایت کی سفیان اور صالح کی حدیث"}
{"hadithnumber": "5215", "text": "عمرو نے سعد بن ابی بردہ سے سنا انھوں نے اپنے والد  ( ابو بردہ عامر بن ابی موسیٰ )  کے واسطے سے اپنے"}
{"hadithnumber": "5216", "text": "زید بن ابی انیسہ نے سعید بن ابی بردہ سے روایت کی ،  کہا  :  ہمیں حضرت ابو بردہ نے اپنے والد سے روایت"}
{"hadithnumber": "5217", "text": "ابو زبیر نے حضرت جا بر رضی اللہ تعالیٰ عنہ  سے روایت کی کہ ایک شخص جیشان سے آیا جیشان یمن میں ہے اس"}
{"hadithnumber": "5218", "text": "ایوب نے نافع سے اور انھوں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے روایت کی :  کہا :  رسول اللہ  صلی"}
{"hadithnumber": "5219", "text": "ابن جریج نے کہا  :  مجھے مو سیٰ بن عقبہ نے نافع سے خبردی انھوں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "5220", "text": "۔  عبد العزیز بن مطلب نے مو سیٰ بن عقبہ سے اسی سند کے ساتھ اسی کے مانند روایت کی ۔"}
{"hadithnumber": "5221", "text": "عبید اللہ نے کہا  :  ہمیں نافع نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ سے خبر دی کہا :  اس بات کا علم مج"}
{"hadithnumber": "5222", "text": "۔  یحییٰ بن یحییٰ نے کہا  :  میں نے امام مالک کے سامنے قراءت کی کہ نافع سے روایت ہے انھوں نے حضرت اب"}
{"hadithnumber": "5223", "text": "عبد اللہ بن مسلمہ بن قعنب نے کہا  :  ہمیں مالک نے نافع سے حدیث بیان کی  ،  ( انھوں نے  )  حضرت ابن ع"}
{"hadithnumber": "5224", "text": "عبید اللہ نے نافع سے ،  انھوں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہ رسول اللہ  صلی"}
{"hadithnumber": "5225", "text": "موسیٰ بن عقبہ نے نافع سے ،  انھوں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے ،  انھوں نے رسول اللہ  صلی"}
{"hadithnumber": "5226", "text": "معاذ عنبری نے کہا :  ہمیں شعبہ نے یحییٰ  بن عبید ابو عمر بہرا نی سے روایت بیان کی کہا :  میں نے حضرت"}
{"hadithnumber": "5227", "text": "محمد بن جعفر نے کہا  :  ہمیں شعبہ نے یحییٰ بہرا نی  سے حدیث بیان کی ،  کہا  :  لوگوں نے حضرت ابن عبا"}
{"hadithnumber": "5228", "text": "ابو معاویہ نے اعمش سے انھوں نے ابو عمر سے ،  انھوں نے حضرت عباس رضی اللہ تعالیٰ عنہ  سے روایت کی ،"}
{"hadithnumber": "5229", "text": "۔  جریر نے اعمش سے انھوں نے  یحییٰ ابو عمر سے ،  انھوں نے حضرت عباس رضی اللہ تعالیٰ عنہ  سے روایت کی"}
{"hadithnumber": "5230", "text": "زید نے ابو عمر یحییٰ نخعی سے روایت کی کہا  :  کچھ لوگوں نے حضرت ابن عباس رضی اللہ تعالیٰ عنہ  سے شرا"}
{"hadithnumber": "5231", "text": "ہمیں ثمامہ یعنی ابن حزن قشیری نے حدیث بیان کی  ، کہا :  میں حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے ملن"}
{"hadithnumber": "5232", "text": "حسن کی والدہ نے حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے روایت کی  ، کہا :  ہم رسول اللہ  صلی اللہ علیہ"}
{"hadithnumber": "5233", "text": "عبد العزیز بن ابی حازم نے ابو حازم سے انھوں نے حضرت سہل بن سعد  رضی اللہ تعالیٰ عنہ  سے روایت کی ،"}
{"hadithnumber": "5234", "text": "یعقوب بن عبد الرحمٰن نے ابو حازم سے روایت کی ،  کہا :  میں نےحضرت سہل بن سعد  رضی اللہ تعالیٰ عنہ  س"}
{"hadithnumber": "5235", "text": "محمد ابو غسان نے کہا  :  مجھے ابو حازم نے حجرت سہل بن سعد  رضی اللہ تعالیٰ عنہ  سے یہی حدیث روایت کی"}
{"hadithnumber": "5236", "text": "محمد بن سہل تیمی اور ابو بکر بن اسحٰق نے کہا  :  ہمیں ابن ابی مریم نے حدیث بیان کی  ، کہا  :  ہمیں ا"}
{"hadithnumber": "5237", "text": "حضرت انس رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ میں نے اپنے اس پیالے سے رسول اللہ  صلی اللہ علیہ وسلم"}
{"hadithnumber": "5238", "text": "معاذ عنبری نے کہا :  ہمیں شعبہ نے ابو اسحاق  ( ہمدانی )  سے حدیث بیان کی ، انھوں نے حضرت براء رضی ال"}
{"hadithnumber": "5239", "text": "محمد بن جعفر نے کہا : ہمیں شعبہ نے حدیث بیان کی ، کہا :  میں نے ابو اسحاق ہمدانی سے سنا  ، کہہ رہے ت"}
{"hadithnumber": "5240", "text": "یونس نے زہری سے روایت کی ، کہا : ابن مسیب نے کہا : حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  نے کہا :  کہ"}
{"hadithnumber": "5241", "text": "معقل نے زہری سے ، انھوں نے سعید بن مسیب سے روایت کی کہ انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "5242", "text": "ابو عاصم ضحاک نے کہا : ہمیں ابن جریج نے خبر دی ، کہا : مجھے ابو زبیر نے بتایا کہ انھوں نے حضرت جابر"}
{"hadithnumber": "5243", "text": "روح بن عبادہ نے کہا : ہمیں ابن جریج اور زکریا بن اسحاق نے حدیث بیان کی ، دونوں نے کہا : ہمیں ابو زبی"}
{"hadithnumber": "5244", "text": "ابو معاویہ نے اعمش سے ، انھوں نے ابو صالح سے  ، انھوں نے حضرت جابر بن عبداللہ رضی اللہ تعالیٰ عنہ  س"}
{"hadithnumber": "5245", "text": "جریر نے اعمش سے ، انھوں نے سفیان ابو صالح سے  ، انھوں نے حضرت جابر  رضی اللہ تعالیٰ عنہ  سے روایت کی"}
{"hadithnumber": "5246", "text": "قتیبہ بن سعید اور محمد بن رمح نے لیث سے حدیث بیان کی ، انھوں نے ابو زبیرسے ، انھوں نے حضرت جابر  رضی"}
{"hadithnumber": "5247", "text": "امام مالک  رحمۃ اللہ علیہ  نے ابو زبیر سے ،  انھوں نے حضرت جابر  رضی اللہ تعالیٰ عنہ  سے  ، انھوں نے"}
{"hadithnumber": "5248", "text": "زہیر نے ابو زبیر سے ، انھوں نے حضرت جابر رضی اللہ تعالیٰ عنہ  سے رویت کی ، کہا : رسول اللہ  صلی اللہ"}
{"hadithnumber": "5249", "text": "سفیان نے ابو زبیر سے  ، انھوں نے حضرت جابر  رضی اللہ تعالیٰ عنہ  سے اور انھوں نے نبی کریم صلی اللہ ع"}
{"hadithnumber": "5250", "text": "اسحاق بن منصور نے کہا : ہمیں روح بن عبادہ نے خبر دی کہا : ہمیں ابن جریج نے حدیث بیان کی ، کہا : مجھے"}
{"hadithnumber": "5251", "text": "اسحاق بن منصور نے کہا : ہمیں  روح بن عبادہ نے خبر دی ، کہا :  ہمیں ابن جریج نے حدیث بیان کی  ، کہا م"}
{"hadithnumber": "5252", "text": "ابو عاصم نے کہا : ہمیں ابن جریج نے یہی حدیث عطاء اور عمرو بن دینار دے روح کی روایت کے مانند بیا ن کی"}
{"hadithnumber": "5253", "text": "ابو خثیمہ  ( زہیر )  نے ابو زبیر سے حدیث بیان کی ، انھوں نے جابر رضی اللہ تعالیٰ عنہ  سے روایت کی ،"}
{"hadithnumber": "5254", "text": "سفیان بن ابو زبیر سے ، انھوں نے جابر  رضی اللہ تعالیٰ عنہ  سے  ، انھوں نے نبی کریم صلی اللہ علیہ وسل"}
{"hadithnumber": "5255", "text": "ہاشم بن قاسم نے کہا :  \" ہمیں لیث بن سعد نے حدیث بیان کی ، کہا : مجھے یزید بن عبداللہ بن اسامہ بن ہا"}
{"hadithnumber": "5256", "text": "علی جہضمی نے کہا : ہمیں لیث بن سعد نے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی مگر انھوں نے اس  ( ح"}
{"hadithnumber": "5257", "text": "سالم نے اپنے والد ( حضرت عبداللہ بن عمر رضی اللہ تعالیٰ عنہ  )  سے روایت کی ، کہا :  \" جب تم سونے لگ"}
{"hadithnumber": "5258", "text": "حضرت ابو موسیٰ رضی اللہ تعالیٰ عنہ  سے ر وایت ہے  ، کہا : مدینہ میں ایک گھر اپنے رہنے والوں کے اوپر"}
{"hadithnumber": "5259", "text": "ابو معاویہ نے اعمش سے ، انھوں نے خیثمہ سے  ، انھوں ن ابوحذیفہ سے  ، انھوں نے حضرت حذیفہ رضی اللہ تعا"}
{"hadithnumber": "5260", "text": "عیسیٰ بن یونس نے کہا : ہمیں اعمش نے خیثمہ بن عبدالرحمان سے خبر دی ، انھوں نے ابو حذیفہ ارحبی سے ، ان"}
{"hadithnumber": "5261", "text": "سفیان نے اعمش سے اسی سند کے ساتھ حدیث بیان کی اور لڑکی کا آنا ، اعرابی کے آنے سے پہلے بیان کیا ۔"}
{"hadithnumber": "5262", "text": "ابو عاصم نے ابن جریج سے  روایت کی  ، کہا : مجھے ابو زبیر نے حضرت جابر بن عبداللہ  رضی اللہ تعالیٰ عن"}
{"hadithnumber": "5263", "text": "روح بن عبادہ نے کہا : ہمیں ابن جریج نے حدیث بیان کی ، کہا : مجھے ابو زبیر نے بتایا کہ انھوں نے حضرت"}
{"hadithnumber": "5264", "text": "حضرت جابر رضی اللہ تعالیٰ عنہ  نے  رسول اللہ  صلی اللہ علیہ وسلم  سے روایت کی کہ آپ صلی اللہ علیہ وس"}
{"hadithnumber": "5265", "text": "سفیان نے زہری سے ، انھوں نے ابو بکر بن عبیداللہ بن عبداللہ بن عمر سے ، انھوں نے اپنے دادا حضرت ابن ع"}
{"hadithnumber": "5266", "text": "عبیداللہ نے زہری سے سفیان کی سند کے ساتھ ( حدیث بیان کی ۔  )"}
{"hadithnumber": "5267", "text": "ابوطاہر اورحرملہ نے کہا : ہمیں عبداللہ بن وہب نے حدیث بیان کی ، کہا  : مجھے عمر بن  محمد نے حدیث بیا"}
{"hadithnumber": "5268", "text": "۔  سیدنا ایاس بن سلمہ بن اکوع رضی اللہ عنہ اپنے والد رضی اللہ عنہ سے روایت کرتے ہیں کہ انہوں نے کہا"}
{"hadithnumber": "5269", "text": "ولید بن کثیر نے وہب بن کیسان سے روایت کی  ، انھوں نے  حضرت عمر بن ابی سلمہ رضی اللہ تعالیٰ عنہ  سے س"}
{"hadithnumber": "5270", "text": "محمد بن عمرو بن حلحلہ نے وہب بن کیسان سے  ، انھوں نے حضرت عمر بن ابی سلمہ  رضی اللہ تعالیٰ عنہ  سےرو"}
{"hadithnumber": "5271", "text": "سفیان بن عینیہ نے زہری سے ، انھوں نے عبیداللہ سے ، انھوں نے حضرت ابوسعید رضی اللہ تعالیٰ عنہ  سے  رو"}
{"hadithnumber": "5272", "text": "یونس نے ابن شہاب سے ، انھوں نے عبیداللہ بن عبداللہ بن عتبہ سے ، انھوں نے حضرت ابو سعید خدری  رضی الل"}
{"hadithnumber": "5273", "text": "معمر نے زہری سے اسی سند کے ساتھ اسی کے مانند  روایت کی ، البتہ انھوں نے کہا : ان ( مشکوں )  کا اختنا"}
{"hadithnumber": "5274", "text": "ہمام نے کہا : ہمیں قتادہ نے حدیث بیان کی ، انھوں نے حضرت انس  رضی اللہ تعالیٰ عنہ  سے  روایت کی کہ ن"}
{"hadithnumber": "5275", "text": "سعید نے قتادہ سے ، انھوں نے حضرت انس رضی اللہ تعالیٰ عنہ  سے  ، انھوں نے نبی کریم صلی اللہ علیہ وسلم"}
{"hadithnumber": "5276", "text": "ہشام نے قتادہ سے  ، انھوں  نے حضرت انس  رضی اللہ تعالیٰ عنہ  سے ، انھوں نے نبی کریم صلی اللہ علیہ وس"}
{"hadithnumber": "5277", "text": "ہمام نے کہا : قتادہ نے ہمیں ابو عیسیٰ اُسواری سے حدیث بیان کی ، انھوں نے حضرت ابوسعید خدری رضی اللہ"}
{"hadithnumber": "5278", "text": "شعبہ نے کہا : ہمیں قتادہ نے ابو عیسیٰ اسواری سے حدیث بیان کی ، انھوں نے حضرت ابوسعید خدری رضی اللہ ت"}
{"hadithnumber": "5279", "text": "ابوغطفان مری سے روایت ہے کہ انھوں نے حضرت  ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے سنا ، کہہ رہے تھے  ، رس"}
{"hadithnumber": "5280", "text": "ابوعوانہ نے عاصم سے  ، انھوں نے شعبی سے ، انھوں نے حضرت ابن عباس رضی اللہ تعالیٰ عنہ  سے  روایت کی ،"}
{"hadithnumber": "5281", "text": "سفیان نے عاصم سے ، انھوں نے شعبہ سے ، انھوں نے حضرت ابن عباس  رضی اللہ تعالیٰ عنہ  سے روایت کی کہ نب"}
{"hadithnumber": "5282", "text": "ہشیم نےکہا : ہمیں عاصم احول اور مغیرہ نے شعبی سے حدیث بیان کی  ، انھوں نے حضرت ابن عباس رضی اللہ تعا"}
{"hadithnumber": "5283", "text": "معاذ نے کہا : ہمیں شعبہ نے عاصم سے حدیث بیان کی ، انھوں نے شعبی کو سنا ، انھوں نے حضرت ابن عباس  رضی"}
{"hadithnumber": "5284", "text": "محمد بن جعفر اور وہب بن جریر دونوں نے شعبہ سے اسی سند کے ساتھ روایت کی ۔ دونوں کی حدیث میں ہے : میں"}
{"hadithnumber": "5285", "text": "عبداللہ بن ابی قتادہ نے  اپنے والد سے روایت کی کہ نبی کریم  صلی اللہ علیہ وسلم  سے اس بات سے منع فرم"}
{"hadithnumber": "5286", "text": "ثمامہ بن عبداللہ بن انس نے حضرت انس رضی اللہ تعالیٰ عنہ  سے روایت کی کہ رسول اللہ  صلی اللہ علیہ وسل"}
{"hadithnumber": "5287", "text": "عبدالوارث نے ابو عصام سے  ، انھوں نے حضرت انس رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا : نبی کریم صلی"}
{"hadithnumber": "5288", "text": "ہشام دستوائی نے ابو عصام سے ، انھوں نے حضرت انس رضی اللہ تعالیٰ عنہ  سے اسی کے مانند روایت کی اور کہ"}
{"hadithnumber": "5289", "text": "امام مالک نے ابن شہاب سے  ، انھوں نے حضرت انس بن مالک رضی اللہ تعالیٰ عنہ  سے روایت کی کہ رسول اللہ"}
{"hadithnumber": "5290", "text": "سفیان بن عینیہ نے زہری سے ، انھوں نے حضرت انس رضی اللہ تعالیٰ عنہ  سے روایت کی  ، کہا : نبی کریم صلی"}
{"hadithnumber": "5291", "text": "ابو طوالہ عبداللہ بن عبدالرحمان انصاری سے روایت ہے  ، انھوں نےحضرت انس رضی اللہ تعالیٰ عنہ  کو حدیث"}
{"hadithnumber": "5292", "text": "امام مالک بن انس نے ابو حازم سے ، انھوں نے حضرت سہل بن ساعدی  رضی اللہ تعالیٰ عنہ  سے  روایت کی کہ ر"}
{"hadithnumber": "5293", "text": "عبدالعزیز بن ابی حازم اور یعقوب بن عبدالرحمان القاری ، دونوں نے ابو حازم سے  ، انھوں نے حضرت سہل بن"}
{"hadithnumber": "5294", "text": "عمرو نے عطاء سے ، انھوں نے حضرت ابن عباس رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا : رسول اللہ  صلی الل"}
{"hadithnumber": "5295", "text": "ابن جریج نے ہمیں حدیث سنائی ، کہا : میں نے عطاء سے سنا  ، وہ کہہ رہے تھے  : میں نے حضرت ابن عباس رضی"}
{"hadithnumber": "5296", "text": "ابو بکر بن ابی شیبہ ، زہیر بن حرب اور محمد بن حاتم نے کہا : ہمیں ابن مہدی نے سفیان سے حدیث بیان کی ،"}
{"hadithnumber": "5297", "text": "ابو معاویہ نے ہشام بن عروہ سے ، انھوں نے عبدالرحمان بن سعد سے ، انھوں نے حضرت کعب بن مالک رضی اللہ ت"}
{"hadithnumber": "5298", "text": "عبداللہ بن نمیر نے کہا : ہمیں ہشام نے عبدالرحمان بن سعد سے حدیث بیا ن کی کہ عبدالرحمان بن کعب ۔ یا ع"}
{"hadithnumber": "5299", "text": "۔  ( عبداللہ )  ابن نمیر نے کہا : ہمیں ہشام نے عبدالرحمان بن سعد سے حدیث بیان کی کہ عبدالرحمان بن کع"}
{"hadithnumber": "5300", "text": "سفیان بن عینیہ نے ابو زبیر سے ، انھوں نے حضرت جابر رضی اللہ تعالیٰ عنہ  سے روایت کی کہ نبی کریم صلی"}
{"hadithnumber": "5301", "text": "عبداللہ بن نمیر نے کہا : ہمیں سفیان ( ثوری )  نے ابو زبیر سے حدیث بیان کی ، انھو ں نے حضرت جابر  رضی"}
{"hadithnumber": "5302", "text": "ابو داود حفری اورعبدالرزاق دونوں نےسفیان  ( ثوری )  سے اسی سند کے ساتھ اسی کے مانند روایت کی ۔ \\n\\nان"}
{"hadithnumber": "5303", "text": "جریر نے اعمش سے  ، انھوں نے ابو سفیان سے ، انھوں نے حضرت جابر رضی اللہ تعالیٰ عنہ  سے روایت کی  ، کہ"}
{"hadithnumber": "5304", "text": "ابو معاویہ نے اعمش سے اسی سندکے ساتھ روایت کی :  \"  جب تم میں سے کسی کا لقمہ گر جائے \" آخرتک اور حدی"}
{"hadithnumber": "5305", "text": "محمد بن فضیل نے اعمش سے ، انھوں نے ابو صالح اور ابوسفیان سے  ، انھوں نے حضرت جابر رضی اللہ تعالیٰ عن"}
{"hadithnumber": "5306", "text": "بہز نے کہا : ہمیں حماد بن سلمہ نے حدیث بیان کی ، کہا : ہمیں ثابت نے حضرت انس رضی اللہ تعالیٰ عنہ  سے"}
{"hadithnumber": "5307", "text": "حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  نے نبی کریم  صلی اللہ علیہ وسلم  سے ر وایت کی کہ آپ صلی اللہ علی"}
{"hadithnumber": "5308", "text": "عبدالرحمان بن مہدی نے کہا  : ہمیں حماد نے اسی سند کے ساتھ حدیث سنائی ، مگرانھوں نےکہا :  \" تم میں سے"}
{"hadithnumber": "5309", "text": "جریر نے اعمش سے ، انھوں نے ابو وائل سے ، انھوں نے حضرت ابو مسعود انصاری رضی اللہ تعالیٰ عنہ  سے روای"}
{"hadithnumber": "5310", "text": "ابو بکر بن ابی شیبہ اور اسحاق بن ابراہیم نے ہمیں یہی حدیث ابو معاویہ سے بیان کی ، نیز یہ حدیث ہمیں ن"}
{"hadithnumber": "5311", "text": "عمار بن رزیق نے اعمش سے ، انھوں نے ابو سفیان سے  ، انھوں نے جابر رضی اللہ تعالیٰ عنہ  سے روایت کی ،"}
{"hadithnumber": "5312", "text": "ثابت نے حضرت انس رضی اللہ تعالیٰ عنہ  سے ر وایت کی کہ نبی کریم صلی اللہ علیہ وسلم  کا ایک فارس سے تع"}
{"hadithnumber": "5313", "text": "خلف بن خلیفہ نے یزید بن کیسان سے  ، انھوں نے ابوحازم سے ، انھوں نے حضرت ابوہریرہ رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "5314", "text": "عبدالواحد بن زیاد نے کہا : ہمیں یزید نے حدیث بیان کی ، کہا : ہمیں ابوحازم نے حدیث سنائی ، کہا :  میں"}
{"hadithnumber": "5315", "text": "حجاج بن شاعر نے کہا : ضحاک بن مخلد نے مجھے ایک رقعے سے حدیث بیان کی ، اسے میرے سامنے رکھا پھر اسے پڑ"}
{"hadithnumber": "5316", "text": "اسحاق بن عبداللہ بن ابی طلحہ نے کہا کہ انھوں نے حضرت انس بن مالک رضی اللہ تعالیٰ عنہ  سے سنا  ، وہ ک"}
{"hadithnumber": "5317", "text": "عبداللہ بن نمیر نے کہا : ہمیں سعد بن سعید نے حدیث بیان کی ، کہا : مجھے حضرت انس بن مالک رضی اللہ تعا"}
{"hadithnumber": "5318", "text": "یحییٰ بن سعید اموی نے ہمیں حدیث بیان کی  ،  کہا  :  ہمیں میرے والد نے حدیث سنا ئی کہا  :  ہمیں سعد ب"}
{"hadithnumber": "5319", "text": "عبد الرحمٰن بن ابی لیلیٰ نے حضرت انس بن مالک  رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہا  :  حضرت ابو ط"}
{"hadithnumber": "5320", "text": "یحییٰ  ( مازنی  )  نے حضرت انس بن ما لک رضی اللہ تعالیٰ عنہ  سے حضرت ابو طلحہ  رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "5321", "text": "عبد اللہ بن عبد اللہ بن ابی طلحہ نے حضرت انس بن مالک رضی اللہ تعالیٰ عنہ  سے ،  انھوں نے نبی  صلی ال"}
{"hadithnumber": "5322", "text": "عمرو بن عبد اللہ بن ابی طلحہ نے حضرت انس بن ما لک رضی اللہ تعالیٰ عنہ  سے روایت کی کہا  :  حضرت ابو"}
{"hadithnumber": "5323", "text": "اسامہ نے بتا یا کہ یعقوب بن عبد اللہ بن ابی طلحہ نے انھیں حدیث بیان کی کہ انھوں نے حضرت انس بن ما لک"}
{"hadithnumber": "5324", "text": "نضر بن انس نے حضرت انس بن مالک  رضی اللہ تعالیٰ عنہ  سے ،  انھوں نے نبی  صلی اللہ علیہ وسلم  کے حوال"}
{"hadithnumber": "5325", "text": "اسحٰق بن عبد اللہ بن ابی طلحہ سے روایت ہے کہ انھوں نے حضرت انس رضی اللہ تعالیٰ عنہ  سے سنا کہہ رہے ت"}
{"hadithnumber": "5326", "text": "سلیمان بن مغیرہ نے ثابت سے ،  انھوں نے حضرت انس رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہا  :  ایک شخص"}
{"hadithnumber": "5327", "text": "معمر نے ثابت بنا نی اور عاصم احول سے ،  انھوں نے حضرت انس بن مالک رضی اللہ تعالیٰ عنہ  سے روایت کی ک"}
{"hadithnumber": "5328", "text": "محمد بن جعفر نے کہا  :  ہمیں شعبہ نے یزید بن خمیر سے ،  انھوں نے حضرت عبد اللہ بن بسر  رضی اللہ تعال"}
{"hadithnumber": "5329", "text": "ابن ابی عدی اور یحییٰ بن حماد دونوں نے شعبہ سے اسی سند کے ساتھ حدیث بیان کی  ۔ گٹھلیوں کو دو انگلیوں"}
{"hadithnumber": "5330", "text": "حضرت عبد اللہ بن جعفر  رضی اللہ تعالیٰ عنہ سے روایت ہے ،  کہا  :  میں رسول اللہ  صلی اللہ علیہ وسلم"}
{"hadithnumber": "5331", "text": "حفص بن غیاث نے مصعب بن سلیم سے روایت کی ، کہا :  ہمیں حضرت انس بن ما لک رضی اللہ تعالیٰ عنہ  نے حدیث"}
{"hadithnumber": "5332", "text": "زہیر بن حرب اور ابن ابی عمر نے سفیان بن عیینہ سے حدیث بیان کی  ، انھوں نے مصعب بن سلیم سے انھوں نے ح"}
{"hadithnumber": "5333", "text": "محمد بن جعفر نے کہا  :  ہمیں شعبہ نے حدیث بیان کی کہا  :  میں نے جبلہ بن سحیم سے سنا کہ عبد اللہ بن"}
{"hadithnumber": "5334", "text": "عبید اللہ کے والد معاذ اور عبدالرحمٰن بن مہدی  دونوں نے شعبہ سے اسی سند کے ساتھ حدیث بیان کی  ۔ ان د"}
{"hadithnumber": "5335", "text": "سفیان نے جبلہ بن سحیم سے روایت کی کہا :  میں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے سنا  ، کہہ رہے"}
{"hadithnumber": "5336", "text": "عروہ نے حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے روایت کی کہ نبی  صلی اللہ علیہ وسلم  نے فرمایا :  \"  ای"}
{"hadithnumber": "5337", "text": "ابوالرجال محمد بن عبد الرحمٰن نے اپنی والدہ  ( عمرہ منت عبد الرحمان انصاریہ )  سے انھوں نے کہا  :  ر"}
{"hadithnumber": "5338", "text": "عبد اللہ بن عبد الرحمٰن نے عامر سعد بن ابی وقاص سے ،  انھوں نے اپنے والد سے روایت کی کہ رسول اللہ  ص"}
{"hadithnumber": "5339", "text": "ابو اسامہ نے ہا شم بن ہاشم سے روایت کی ، کہا  :  میں نے عامر بن سعد بن ابی وقاص سے سنا  ، کہہ رہے تھ"}
{"hadithnumber": "5340", "text": "مروان بن معاویہ فرازی اور ابو بدر شجاع بن ولید دونوں نے ہاشم بن ہاشم سے ،  اسی سند کے ساتھ رسول اللہ"}
{"hadithnumber": "5341", "text": "عبد اللہ بن ابی عتیق نے حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے روایت کی کہ رسول اللہ  صلی اللہ علیہ وس"}
{"hadithnumber": "5342", "text": "جریر اور عمر بن عبید  نے عبدالملک بن عمیر سے انھوں نے عمرو بن حریث سے ،  انھوں نے سعید بن زید بن عمر"}
{"hadithnumber": "5343", "text": "شعبہ نے عبدالملک بن عمیر سے روایت کی کہا  :   عمرو بن حریث سےسنا ،  انھوں نے کہا  : میں نے حضرت سعید"}
{"hadithnumber": "5344", "text": "شعبہ نے کہا  :  مجھے بن عتیبہ نے حسن عرنی سے خبر دی انھوں نے عمرو بن حریث سے ،  انھوں نے حضرت سعید ب"}
{"hadithnumber": "5345", "text": "عبثر نے مطرف سے ،  انھوں نے حسن سے ،  انھوں نے عمرو بن حریث سے انھوں نے سعید بن زید بن عمرو بن نفیل"}
{"hadithnumber": "5346", "text": "جریر نے مطرف سے انھوں نے حکم  بن عتیبہ سے انھوں  نے حسن عرنی سے انھوں نے عمرو بن حریث سے ،  انھوں نے"}
{"hadithnumber": "5347", "text": "سفیا ن نے عبد الملک بن عمیر سے روایت کی ،  کہا :  میں نے عمرو بن حریث سے سنا ،  انھوں نے کہا :  میں"}
{"hadithnumber": "5348", "text": "شہر بن حوشب نے کہا  :  میں نے عبد الملک بن عمیر سےسنا  ، انھوں نے کہا  : میں عبد الملک سے ملا تو انھ"}
{"hadithnumber": "5349", "text": "ابو سلمہ عبد الرحمٰن نے حضرت جا بر بن عبد اللہ  رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہا  :  ہم مرالظ"}
{"hadithnumber": "5350", "text": "یحییٰ بن حسان نے کہا کہ ہمیں سلیمان بن بلال نے ہشام بن عروہ سے حدیث بیان کی  ، انھوں نے اپنے والد سے"}
{"hadithnumber": "5351", "text": "یحییٰ بن صالح وحاظی نے کہا کہ ہمیں سلیمان بن بلال نے اسی سند کے ساتھ حدیث سنا ئی اور کہا  :  \" سالنو"}
{"hadithnumber": "5352", "text": "ابو بشر نے ابو سفیان  ( طلحہ بن نافع  )  سے انھوں نے حضرت جابر بن عبد اللہ  رضی اللہ تعالیٰ عنہ  سے"}
{"hadithnumber": "5353", "text": "اسماعیل بن علیہ نے مثنیٰ بن سعید سے حدیث بیان کی کہا  :  مجھے طلحہ بن نافع نے حدیث بیان کی کہ انھوں"}
{"hadithnumber": "5354", "text": "نصر کے والد علی جہضمی نے کہا  :  ہمیں مثنیٰ بن سعید نے طلحہ بن نافع سے حدیث بیان کی  ، کہا  :  ہمیں"}
{"hadithnumber": "5355", "text": "حجاج بن ابی زینب نے کہا  :  مجھے ابو سفیان طلحہ بن نافع نے حدیث بیان کی  ، انھوں نے کہا  :  میں نے ح"}
{"hadithnumber": "5356", "text": "محمد بن جعفر نے کہا  :  ہمیں شعبہ نے سماک بن حرب سے حدیث بیان کی  ، انھوں نے جا بر بن سمرہ  رضی اللہ"}
{"hadithnumber": "5357", "text": "یحییٰ بن سعید نے شعبہ سے اسی سند کے ساتھ حدیث بیان کی ۔"}
{"hadithnumber": "5358", "text": "حضرت ایوب انصاری رضی اللہ تعالیٰ عنہ  کے آزاد کردہ غلام افلح نے حضرت ایوب انصاری  رضی اللہ تعالیٰ عن"}
{"hadithnumber": "5359", "text": "جریر بن عبدالحمید نےفضیل بن غزوان سے ، انھوں نے ابو حازم اشجعی سے ، انھوں نے حضرت ابو ہریرہ  رضی الل"}
{"hadithnumber": "5360", "text": "وکیع نے  فضیل بن غزوان سے  ، انھوں نے ابوحازم سے ، انھوں نےابوہریرہ رضی اللہ تعالیٰ عنہ  سےروایت کی"}
{"hadithnumber": "5361", "text": "ابن فضیل نے اپنے والد سے ، انھوں نے ابو حازم سے انھوں نے ابوہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی ،"}
{"hadithnumber": "5362", "text": "شبانہ بن سوار نے کہا : ہمیں سلیمان بن مغیرہ نے ثابت سے حدیث بیان کی ، انھوں نے عبدالرحمان بن ابی لیل"}
{"hadithnumber": "5363", "text": "۔  نضر بن شمیل نے سلیمان بن مغیرہ سے اسی سند کےساتھ روایت کی ۔"}
{"hadithnumber": "5364", "text": "ابو عثمان نے حضرت عبدالرحمان بن ابی بکر رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا :  سیدنا عبدالرحمن بن"}
{"hadithnumber": "5365", "text": "معمبر بن سلیمان کے والد نے کہا : ہمیں ابو عثمان نے حدیث بیان کی کہ انھیں حضرت عبدالرحمان بن ابی بکر"}
{"hadithnumber": "5366", "text": "جریری نے ابو عثمان سے ، انھوں نے حضرت عبدالرحمان بن ابی بکر رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا :"}
{"hadithnumber": "5367", "text": "اعرج نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے  روایت کی ، انھوں نے کہا  : رسول اللہ  صلی اللہ علیہ"}
{"hadithnumber": "5368", "text": "اسحاق بن ابراہیم اور یحییٰ بن حبیب نے روح  بن عبادہ سے حدیث بیان کی  ، کہا : ہمیں ابن جریج نےبتایا ،"}
{"hadithnumber": "5369", "text": "ابو زبیر نے حضرت جابر رضی اللہ تعالیٰ عنہ  سے  ، انھوں نے نبی کریم  صلی اللہ علیہ وسلم  سے ابن جریج"}
{"hadithnumber": "5370", "text": "ابو معاویہ نے ہمیں اعمش سے خبر دی ، انھوں نے ابو سفیان سے اور انھوں نے حضرت جابر رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "5371", "text": "جریر نے اعمش سے ، انھوں نے ابو سفیان سے ، انھوں نے حضرت جابر  رضی اللہ تعالیٰ عنہ  سے  ، انھوں نے نب"}
{"hadithnumber": "5372", "text": "یحییٰ قطان نے عبید اللہ سے روایت کی ،  کہا  :  مجھے نافع نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے خبر"}
{"hadithnumber": "5373", "text": "ابو اسامہ اور ابن نمیر نے عبید اللہ سے معمر نے ایوب سے (  عبید اللہ اور ایوب )  دونوں نے نافع سے انھ"}
{"hadithnumber": "5374", "text": "واقد بن محمد بن زید سے روایت ہے کہ انھوں نے نافع سے سنا  ، انھوں نے کہا  :  حضرت ابن عمر رضی اللہ تع"}
{"hadithnumber": "5375", "text": "عبد الرحمٰن نے سفیان سے ،  انھوں نے ابو زبیر سے انھوں نے حضرت جا بر اور ابن عمر رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "5376", "text": "ابن نمیر نے ہمیں حدیث بیان کی کہا  :  ہمیں میرے والد نے حدیث بیان کی  ، کہا  : ہمیں سفیان نے ابو زبی"}
{"hadithnumber": "5377", "text": "حضرت ابو موسیٰ رضی اللہ تعالیٰ عنہ  نے نبی اکرم  صلی اللہ علیہ وسلم  سے روایت کی کہ آپ نے فرما یا  :"}
{"hadithnumber": "5378", "text": "عبد العز یز بن محمد نے ابو علاء سے انھوں نے اپنے والد سےانھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "5379", "text": "سہیل بن ابو صالح نے اپنے والد سے انھوں نے حضرت ابوہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہ نبی"}
{"hadithnumber": "5380", "text": "جریر نے اعمش سےانھوں نے ابو حازم سے انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہا"}
{"hadithnumber": "5381", "text": "زہیر نے ہمیں سلیمان اعمش سے اسی سند کے ساتھ اسی کے مانند روایت کی ۔"}
{"hadithnumber": "5382", "text": "سفیان نے اعمش سے اسی سند کے ساتھ اسی کے مانند روایت کی  ۔"}
{"hadithnumber": "5383", "text": "آل جعدہ کے آزاد کردہ غلام ابو یحییٰ نے حضرت ابوہریرہ رضی اللہ تعالیٰ عنہ سے روایت کی ، کہا  :  میں ن"}
