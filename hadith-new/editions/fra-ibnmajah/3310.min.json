{"metadata":{"name":"Sunan Ibn Majah","section":{"29":" Chapters on Food"},"section_detail":{"29":{"hadithnumber_first":3251,"hadithnumber_last":3370,"arabicnumber_first":3251,"arabicnumber_last":3370}}},"hadiths":[{"hadithnumber":3310,"arabicnumber":3310,"text":"Rapporté par Anas bin Malik : On n'a jamais débarrassé des restes de viande rôtie devant le Messager d'Allah ﷺ, et aucun tapis n'a jamais été transporté avec lui","grades":[{"name":"Al-Albani","grade":"Daif Isnaad"},{"name":"Muhammad Fouad Abd al-Baqi","grade":"Daif Isnaad"},{"name":"Shuaib Al Arnaut","grade":"Daif"},{"name":"Zubair Ali Zai","grade":"Daif"}],"reference":{"book":29,"hadith":60}}]}