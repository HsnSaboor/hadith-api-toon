{"hadithnumber": "2070", "text": "امام مالکؒ نے عبداللہ بن ابی بکر سے روایت کی ، انھوں نے عباد بن تمیم سے سنا ، وہ کہہ رہے تھے : میں ن"}
{"hadithnumber": "2071", "text": "سفیان بن عینیہ نے عبداللہ بن ابی بکر سے ، انھوں نے عباد بن تمیم سے اور انھوں نے اپنے چچا ( عبداللہ ب"}
{"hadithnumber": "2072", "text": "ابو بکربن محمد بن عمرو نے بتایا کہ ان کو عبادبن تمیم نے خبر دی ، ان کوحضرت عبداللہ بن زیدانصاری رضی"}
{"hadithnumber": "2073", "text": "ابن شہاب نے کہا : مجھےعباد بن تمیم مازنی نے خبر دی ، انھوں نے اپنے چچاسے سنا اور وہ نبی کریم صلی الل"}
{"hadithnumber": "2074", "text": "شعبہ نے ثابت سے اورانھوں نے حضرت انس  رضی اللہ تعالیٰ عنہ  سے روایت کی کہا :  میں نے رسول اللہ صلی ا"}
{"hadithnumber": "2075", "text": "حمادبن سلمہ نے ثابت سے اور انھوں نے حضرت انس بن مالک  رضی اللہ تعالیٰ عنہ  سے ر وایت کی کہ نبی اکرم"}
{"hadithnumber": "2076", "text": "ابن ابی عدی اور عبدالاعلیٰ نے سعید ( بن ابی عروبہ )  سے  ، انھوں نے قتادہ سے اور انھوں نے حضرت انس ر"}
{"hadithnumber": "2077", "text": "یحییٰ بن سعید نے ( سعید )  بن ابی عروبہ سے اور انھوں نے قتادہ سے روایت کی کہ ان کو حضرت انس بن مالک"}
{"hadithnumber": "2078", "text": "شریک بن ابی نمر نے حضرت انس بن مالک  رضی اللہ تعالیٰ عنہ  سے روایت کی کہ جمعے کے روز ایک آدمی اس درو"}
{"hadithnumber": "2079", "text": "اسحاق بن عبداللہ بن ابی طلحہ نے حضرت انس بن مالک رضی اللہ تعالیٰ عنہ  سے روایت کی ، انھوں نےکہا : رس"}
{"hadithnumber": "2080", "text": "عبدالاعلیٰ بن حماد اور محمد بن ابی بکر مقدمی نے کہا : ہمیں معتمر نے حدیث بیا ن کی ، انھوں نے کہا : ہ"}
{"hadithnumber": "2081", "text": "سلمان بن مغیرۃ نے ثابت اور انھوں نے حضرت انس  رضی اللہ تعالیٰ عنہ  سے اسی کے ہم معنی روایت کی اور یہ"}
{"hadithnumber": "2082", "text": "حفص بن عبیداللہ بن انس بن مالک نے بیان کیاکہ انھوں نے حضرت انس بن مالک  رضی اللہ تعالیٰ عنہ  سے سنا"}
{"hadithnumber": "2083", "text": "حضرت انس  رضی اللہ تعالیٰ عنہ  نے کہا : ہم رسول اللہ  صلی اللہ علیہ وسلم کے ساتھ تھے کہ ہم پر بارش ب"}
{"hadithnumber": "2084", "text": "جعفر بن محمد نے عطاء بن ابی ر باح سے روایت کی انھوں نے نبی کریم  صلی اللہ علیہ وسلم  کی ذوجہ محترمہ"}
{"hadithnumber": "2085", "text": "ابن جریج عطاء بن ابی رباح سے حدیث بیان کرتے ہیں ، انھوں نے نبی اکرم  صلی اللہ علیہ وسلم  کی زوجہ محت"}
{"hadithnumber": "2086", "text": "سلمان بن یسار نے نبی اکرم صلی اللہ علیہ وسلم  کی اہلیہ محترمہ حضرت عائشہ  رضی اللہ تعالیٰ عنہا  سے ر"}
{"hadithnumber": "2087", "text": "مجاہد نے حضرت ابن عباس  رضی اللہ تعالیٰ عنہ  سے  ، انھوں نے نبی کریم صلی اللہ علیہ وسلم  سے روایت کی"}
