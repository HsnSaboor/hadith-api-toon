{"hadithnumber": "1479", "text": "ہم سے اسماعیل بن عبداللہ نے بیان کیا ‘ کہا کہ مجھ سے امام مالک رحمہ اللہ نے ابوالزناد سے بیان کیا ‘"}
{"hadithnumber": "1480", "text": "ہم سے عمر بن حفص بن غیاث نے بیان کیا ‘ کہا کہ مجھ سے میرے باپ نے بیان کیا ‘ کہا کہ ہم سے اعمش نے بیا"}
{"hadithnumber": "1482", "text": "اور سلیمان بن بلال نے کہا کہ مجھ سے عمرو نے اس طرح بیان کیا کہ پھر بنی حارث بن خزرج کا خاندان اور پھ"}
{"hadithnumber": "1483", "text": "ہم سے سعید بن ابی مریم نے بیان کیا ‘ کہا کہ ہم سے عبداللہ بن وہب نے بیان کیا ‘ کہا کہ مجھے یونس بن ی"}
{"hadithnumber": "1484", "text": "ہم سے مسدد نے بیان کیا ‘ انہوں نے کہا کہ ہم سے یحییٰ بن سعید قطان نے بیان کیا ‘ انہوں نے کہا کہ ہم س"}
{"hadithnumber": "1485", "text": "ہم سے عمر بن محمد بن حسن اسدی نے بیان کیا ‘ انہوں نے کہا کہ ہم سے میرے باپ نے بیان کیا ‘ انہوں نے کہ"}
{"hadithnumber": "1486", "text": "ہم سے حجاج بن منہال نے بیان کیا ‘ کہا کہ ہم سے شعبہ نے بیان کیا ‘ کہا کہ مجھے عبداللہ بن دینار نے خب"}
{"hadithnumber": "1487", "text": "ہم سے عبداللہ بن یوسف نے بیان کیا ‘ انہوں نے کہا کہ مجھ سے لیث نے بیان کیا ‘ انہوں نے کہا کہ مجھ سے"}
{"hadithnumber": "1488", "text": "ہم سے قتیبہ نے امام مالک سے بیان کیا ‘ ان سے حمید نے اور ان سے انس بن مالک رضی اللہ عنہ نے کہ  رسول"}
{"hadithnumber": "1489", "text": "ہم سے یحییٰ بن بکیر نے بیان کیا ‘ کہا کہ ہم سے لیث نے بیان کیا ‘ ان سے عقیل نے ‘ ان سے ابن شہاب نے ‘"}
{"hadithnumber": "1490", "text": "ہم سے عبداللہ بن یوسف نے بیان کیا ‘ کہا کہ ہمیں امام مالک بن انس نے خبر دی ‘ انہیں زید بن اسلم نے او"}
{"hadithnumber": "1491", "text": "ہم سے آدم بن ابی ایاس نے بیان کیا ‘ انہوں نے کہا کہ ہم سے شعبہ نے بیان کیا ‘ انہوں نے کہا کہ ہم سے م"}
{"hadithnumber": "1492", "text": "ہم سے سعید بن عفیر نے بیان کیا ‘ کہا کہ ہم سے عبداللہ بن وہب نے بیان کیا ‘ ان سے یونس نے ‘ ان سے ابن"}
{"hadithnumber": "1493", "text": "ہم سے آدم بن ابی ایاس نے بیان کیا ‘ کہا کہ ہم سے شعبہ نے بیان کیا ‘ کہا کہ ہم سے حکم بن عتبہ نے بیان"}
{"hadithnumber": "1494", "text": "ہم سے علی بن عبداللہ نے بیان کیا ‘ انہوں نے کہا کہ ہم سے یزید بن زریع نے بیان کیا ‘ انہوں نے کہا کہ"}
{"hadithnumber": "1495", "text": "ہم سے یحییٰ بن موسیٰ نے بیان کیا ‘ انہوں نے کہا کہ ہم سے وکیع نے بیان کیا ‘ کہا کہ ہم سے شعبہ نے بیا"}
{"hadithnumber": "1496", "text": "ہم سے محمد بن مقاتل نے بیان کیا ‘ انہوں نے کہا کہ ہمیں عبداللہ نے خبر دی ‘ انہوں نے کہا کہ ہمیں زکری"}
{"hadithnumber": "1497", "text": "ہم سے حفص بن عمر نے بیان کیا، کہا کہ ہم سے شعبہ نے عمرو بن مرہ سے بیان کیا ‘ ان سے عبداللہ بن ابی او"}
{"hadithnumber": "1498", "text": "اور لیث نے کہا کہ مجھ سے جعفر بن ربیعہ نے بیان کیا ‘ انہوں نے عبدالرحمٰن بن ہرمز سے ‘ انہوں نے ابوہر"}
{"hadithnumber": "1499", "text": "ہم سے عبداللہ بن یوسف نے بیان کیا ‘ انہوں نے کہا کہ ہمیں امام مالک نے خبر دی ‘ انہیں ابن شہاب نے ‘ ا"}
{"hadithnumber": "1500", "text": "ہم سے یوسف بن موسیٰ نے بیان کیا ‘ انہوں نے کہا کہ ہم سے ابواسامہ نے بیان کیا ‘ انہوں نے کہا کہ ہم سے"}
