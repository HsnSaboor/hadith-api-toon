{"hadithnumber": "1755", "arabic": "حَدَّثَنَا جُبَارَةُ بْنُ الْمُغَلِّسِ، ‏‏‏‏‏‏حَدَّثَنَا مَنْدَلُ بْنُ عَلِيٍّ، ‏‏‏‏‏‏حَدَّثَنَا عُم", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 7, Hadith 118", "international_number": "1755", "narrator_chain": ""}
{"hadithnumber": "1756", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا أَبُو عَاصِمٍ، ‏‏‏‏‏‏حَدَّثَنَا ثَوَابُ بْنُ عُت", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 7, Hadith 119", "international_number": "1756", "narrator_chain": ""}
{"hadithnumber": "1757", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا قُتَيْبَةُ، ‏‏‏‏‏‏حَدَّثَنَا عَبْثَرُ، ‏‏‏‏‏‏عَن", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 7, Hadith 120", "international_number": "1757", "narrator_chain": ""}
{"hadithnumber": "1758", "arabic": "حَدَّثَنَا عَبْدُ اللَّهِ بْنُ سَعِيدٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو خَالِدٍ الْأَحْمَرُ، ‏‏‏‏‏‏عَنِ الْأَ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Bukhari And Muslim'}", "reference": "Book 7, Hadith 121", "international_number": "1758", "narrator_chain": ""}
{"hadithnumber": "1759", "arabic": "حَدَّثَنَا زُهَيْرُ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الرَّزَّاقِ، ‏‏‏‏‏‏عَنْ سُفْيَانَ، ‏‏‏‏‏", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 7, Hadith 122", "international_number": "1759", "narrator_chain": ""}
{"hadithnumber": "1760", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا أَحْمَدُ بْنُ خَالِدٍ الْوَهْبِيُّ، ‏‏‏‏‏‏حَدَّث", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 7, Hadith 123", "international_number": "1760", "narrator_chain": ""}
{"hadithnumber": "1761", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏عَنْ أَبِي الزِّ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 7, Hadith 124", "international_number": "1761", "narrator_chain": ""}
{"hadithnumber": "1762", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا يَحْيَى بْنُ حَمَّادٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو عَ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 7, Hadith 125", "international_number": "1762", "narrator_chain": ""}
{"hadithnumber": "1763", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى الْأَزْدِيُّ، ‏‏‏‏‏‏حَدَّثَنَا مُوسَى بْنُ دَاوُدَ، ‏‏‏‏‏‏ وَخَالِ", "grades": "{'name': 'Al-Albani', 'grade': 'Very Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Very Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 7, Hadith 126", "international_number": "1763", "narrator_chain": ""}
