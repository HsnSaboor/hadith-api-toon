metadata:

hadiths[15]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
334,ہم سے عبداللہ بن یوسف نے بیان کیا، انہوں نے کہا ہمیں مالک نے عبدالرحمٰن بن قاسم سے خبر دی، انہوں نے ,,,,,334
335,ہم سے محمد بن سنان عوفی نے بیان کیا، انہوں نے کہا ہم سے ہشیم نے بیان کیا (دوسری سند) کہا اور مجھ سے ,,,,,335
336,ہم سے سے زکریا بن یحییٰ نے بیان کیا، کہا ہم سے عبداللہ بن نمیر نے، کہا ہم سے ہشام بن عروہ نے، وہ اپن,,,,,336
337,ہم سے یحییٰ بن بکیر نے بیان کیا، انہوں نے کہا ہم سے لیث بن سعد نے بیان کیا، انہوں نے جعفر بن ربیعہ س,,,,,337
338,ہم سے آدم بن ابی ایاس نے بیان کیا، انہوں نے کہا ہم سے شعبہ نے بیان کیا، انہوں نے کہا ہم سے حکم بن عی,,,,,338
339,ہم سے حجاج بن منہال نے بیان کیا، کہا ہم سے شعبہ نے کہا کہ مجھے حکم بن عیینہ نے خبر دی ذر بن عبداللہ ,,,,,339
340,ہم سے سلیمان بن حرب نے بیان کیا، کہا ہم سے شعبہ نے حکم کے واسطہ سے حدیث بیان کی، وہ ذر بن عبداللہ سے,,,,,340
341,ہم سے محمد بن کثیر نے بیان کیا، کہا ہم سے شعبہ نے حکم سے، وہ ذر بن عبداللہ سے، وہ سعید بن عبدالرحمٰن,,,,,341
342,ہم سے مسلم بن ابراہیم نے بیان کیا، کہا ہم سے شعبہ نے حکم سے، انہوں نے ذر بن عبداللہ سے، انہوں نے سعی,,,,,342
343,ہم سے محمد بن بشار نے بیان کیا، کہا ہم سے غندر نے، کہا کہ ہم سے شعبہ نے حکم کے واسطے سے، انہوں نے ذر,,,,,343
344,ہم سے مسدد نے بیان کیا کہ ہم سے یحییٰ بن سعید نے، کہا کہ ہم سے عوف نے، کہا کہ ہم سے ابورجاء نے عمران,,,,,344
345,ہم سے بشر بن خالد نے بیان کیا، کہا مجھ کو محمد نے خبر دی جو غندر کے نام سے مشہور ہیں، شعبہ کے واسطہ ,,,,,345
346,ہم سے عمر بن حفص نے بیان کیا کہ کہا ہم سے میرے والد حفص بن غیاث نے، کہا کہ ہم سے اعمش نے بیان کیا، ک,,,,,346
347,ہم سے محمد بن سلام نے بیان کیا، کہا ہمیں ابومعاویہ نے خبر دی اعمش سے، انہوں نے شقیق سے، انہوں نے بیا,,,,,347
348,ہم سے عبدان نے حدیث بیان کی، کہا ہمیں عبداللہ نے خبر دی، کہا ہمیں عوف نے ابورجاء سے خبر دی، کہا کہ ہ,,,,,348
