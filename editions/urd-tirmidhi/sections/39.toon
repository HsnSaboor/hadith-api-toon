hadiths[34]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
2573,"عبداللہ بن مسعود رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”قیامت کے دن جہنم",,,,,2573
2574,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”قیامت کے دن جہنم سے ایک ",,,,,2574
2575,حسن بصری کہتے ہیں کہ  عتبہ بن غزوان رضی الله عنہ نے ہمارے اس بصرہ کے منبر پر بیان کیا کہ نبی اکرم صل,,,,,2575
2576,"ابو سعید خدری رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ” «صعود» جہنم کا ا",,,,,2576
2577,"ابوہریرہ رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”کافر کے چمڑے کی موٹائی",,,,,2577
2578,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”قیامت کے دن کافر کی ڈاڑھ",,,,,2578
2579,"ابوہریرہ رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”کافر کی ڈاڑھ احد جیسی ",,,,,2579
2580,"عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”کافر اپنی زبان ک",,,,,2580
2581,ابو سعید خدری رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم سے اللہ تعالیٰ کے قول «كالمهل,,,,,2581
2582,"ابوہریرہ رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جہنمیوں کے سر پر «ماء ",,,,,2582
2583,ابوامامہ رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے اللہ تعالیٰ کے اس قول «ويسقى من,,,,,2583
2584,"ابو سعید خدری رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ” «كالمهل» یعنی تل",,,,,2584
2585,عبداللہ بن عباس رضی الله عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے یہ آیت پڑھی «اتقوا ا,,,,,2585
2586,"ابو الدرداء رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جہنمیوں پر بھوک مسلط ",,,,,2586
2587,ابو سعید خدری رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے اس آیت کریمہ «وهم فيها كا,,,,,2587
2588,"عبداللہ بن عمرو بن عاص رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اگر اس ک",,,,,2588
2589,"ابوہریرہ رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”تمہاری  ( دنیا کی )  ا",,,,,2589
2590,"ابو سعید خدری رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”تمہاری یہ آگ جہن",,,,,2590
2591,"ابوہریرہ رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جہنم کی آگ ایک ہزار س",,,,,2591
2592,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جہنم نے اپنے رب سے شکایت",,,,,2592
2593,"انس رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جہنم سے نکلے گا  ( شعبہ نے اپ",,,,,2593
2594,"انس رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”اللہ تعالیٰ کہے گا: اسے جہن",,,,,2594
2595,"عبداللہ بن مسعود رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جہنم سے سب سے آ",,,,,2595
2596,"ابوذر رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جہنم سے سب سے آخر میں نکلن",,,,,2596
2597,"جابر رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”موحدین میں سے کچھ لوگ جہنم م",,,,,2597
2598,"ابو سعید خدری رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جہنم سے وہ آدمی نکل",,,,,2598
2599,"ابوہریرہ رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جہنم میں داخل ہونے وا",,,,,2599
2600,"عمران بن حصین رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”میری امت کی ایک ج",,,,,2600
2601,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”میں نے جہنم جیسی کوئی چی",,,,,2601
2602,"عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”میں نے جنت میں ",,,,,2602
2603,"عمران بن حصین رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”میں نے جہنم میں جھا",,,,,2603
2604,"نعمان بن بشیر رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”قیامت کے دن سب سے",,,,,2604
2605,"حارثہ بن وہب خزاعی رضی الله عنہ کہتے ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا: ",,,,,2605
2795,جرہد رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم مسجد میں جرہد کے پاس  ( یعنی میرے پاس سے ,,,,,2795
