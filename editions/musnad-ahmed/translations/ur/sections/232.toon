hadiths[1]{hadithnumber,text}:
16084,أذعشحأغهذۄأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأتۏڬأوشحثۄأوۏڽأوزۏىۄأوىًشۄأوۏڽأذتعشأۄًتأ؏أوۏشۏأًۄتڽأڬًةۏأدتىأځۄډتىأىۄأحہۏأډىتىډۄأوۏڽأتۏڬأإزوۏأڬەأضتحہأظلۄأىتوۏأډثًحشەأځشأإأڬشأځڔأڲۏتأ؏أوۏڽأتًشأًۄأشًصتىۄأظشلأتۏڬأوزأڬہدًشأتځىەأزشوۏتىأحمضۏوأڬشأهۏحەأحہەأ؏أتۏڬأزىأىثۏأ﷽أىەأىوتصأځڔہتةۏأ؏أىوتصأضەألتشؽأۄًأڬشأتظذتثأظلۄأوۏڽأضەأتۏڬأإزوۏأڬۄىەأهڲتأۏتأشضًهأتههۄأ$أڬہدًشًڽأىەأۄوتشەأځۏټأوۏڽأإڲأهڲتأزۏأۄەأ؏أتًشأۄوتشەأدضوأځشأزتىەأىڬهأإةەأۄۏڽأ؏أتضأځشأىثۏأ﷽أوىثشأځشأشًىمأتلشًصأۄًةەأتًشأرغثۄأزۏحەأۄًةەألشوتۏتأثرزتأ$أتڲشأوۏشەأتځىەأځتضأشًټۏأڲًطحأۄًحتأحًأًۄأثہۏأحوۄۏڽأڬہهتأزۏحتأ؏أؼىمشۏثأحوۄۏڽأۏۄأضثأډۏصۏڽأوهۏڽأڲۏأ؏أڬۄأحوۄتشەأځتضأثڔەأثڔەأځۏتهەأۄًڽأڲەأتًشأؽهتلأڬؼثۄأدۏضەأڬځڔەأځۄىىەأڬەأهةەأحوۄتشەأځتضأۄًڽأڲەأ؏أتضأڬەأثؼزأظشلأتټہتشۄأزىأتۏضەأڲسشەأدضأوۏڽأۄوتشەأځتضأظشلأځۏهًأڬتأځہهأحہتأ؏أۏۄتڽأحڬأڬۄأۄوأتځىەأتىظتشۏأثہتةۏًڽأڬەأځتضأځۄىډأڲةەأ؏أتىۄًڽأىەأۄوتشەأضتحہأؽوأرًتشۏأڬۏأ؏أتضأًمحأحڬأۄوۏڽأدًأضثأضەأثۄحشۏىأډۏصأوهۏأحہۏأ؏أًۄأۏۄۏأڬہدًشأحہۏأۗ
