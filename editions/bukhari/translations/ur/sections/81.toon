{"hadithnumber": "6566", "text": "ہم سے مسدد نے بیان کیا، انہوں نے کہا ہم سے یحییٰ نے بیان کیا، ان سے حسن بن ذکوان نے بیان کیا، انہوں"}
{"hadithnumber": "6568", "text": "اور نبی کریم صلی اللہ علیہ وسلم نے فرمایا کہ  اللہ کے راستے میں جہاد کے لیے ایک صبح یا ایک شام سفر ک"}
{"hadithnumber": "6569", "text": "ہم سے ابوالیمان نے بیان کیا، کہا ہم کو شعیب نے خبر دی، کہا ہم سے ابوالزناد نے، ان سے اعرج نے اور ان"}
{"hadithnumber": "6570", "text": "ہم سے قتیبہ بن سعید نے بیان کیا، انہوں نے کہا ہم سے اسماعیل بن جعفر نے بیان کیا، ان سے عمرو نے بیان"}
{"hadithnumber": "6571", "text": "ہم سے عثمان بن ابی شیبہ نے بیان کیا، کہا ہم سے جریر بن عبدالحمید نے بیان کیا، ان سے منصور نے، ان سے"}
{"hadithnumber": "6572", "text": "ہم سے مسدد نے بیان کیا، انہوں نے کہا ہم سے ابوعوانہ نے بیان کیا، ان سے عبدالملک نے بیان کیا، ان سے ع"}
{"hadithnumber": "6573", "text": "ہم سے ابوالیمان نے بیان کیا، کہا ہم کو شعیب نے خبر دی، انہیں زہری نے، کہا مجھ کو سعید اور عطا بن یزی"}
{"hadithnumber": "6574", "text": "عطاء نے بیان کیا کہ  ابو سعید خدری رضی اللہ عنہ بھی اس وقت ابوہریرہ رضی اللہ عنہ کے ساتھ بیٹھے ہوئے"}
{"hadithnumber": "6575", "text": "مجھ سے یحییٰ بن حماد نے بیان کیا، کہا ہم سے ابوعوانہ نے بیان کیا، ان سے سلیمان نے، ان سے شقیق نے اور"}
{"hadithnumber": "6576", "text": "(دوسری سند) اور مجھ سے عمرو بن علی نے بیان کیا، کہا ہم سے محمد بن جعفر نے، کہا ہم سے شعبہ نے، ان سے"}
{"hadithnumber": "6577", "text": "ہم سے مسدد نے بیان کیا، کہا ہم سے یحییٰ نے بیان کیا، ان سے عبیداللہ نے، ان سے نافع نے بیان کیا اور ا"}
{"hadithnumber": "6578", "text": "مجھ سے عمرو بن محمد نے بیان کیا، انہوں نے کہا ہم سے ہشیم نے بیان کیا، انہوں نے کہا ہم کو ابوبشر اور"}
{"hadithnumber": "6579", "text": "ہم سے سعید بن مریم نے بیان کیا، کہا ہم کو نافع بن عمر نے خبر دی، ان سے ابن ابی ملیکہ نے بیان کیا، ان"}
{"hadithnumber": "6580", "text": "ہم سے سعید بن عفیر نے بیان کیا، انہوں نے کہا کہ مجھ سے ابن وہب نے بیان کیا، ان سے یونس نے بیان کیا،"}
{"hadithnumber": "6581", "text": "ہم سے ابوالولید نے بیان کیا، کہا ہم سے ہمام نے بیان کیا، ان سے قتادہ نے، ان سے انس رضی اللہ عنہ نے ا"}
{"hadithnumber": "6582", "text": "ہم سے مسلم بن ابراہیم نے بیان کیا، کہا ہم سے وہیب بن خالد نے بیان کیا، کہا ہم سے عبدالعزیز نے بیان ک"}
{"hadithnumber": "6583", "text": "ہم سے سعید بن ابومریم نے بیان کیا، کہا ہم سے محمد بن مطرف نے بیان کیا، کہا کہ مجھ سے ابوحازم نے، ان"}
{"hadithnumber": "6584", "text": "ابوحازم نے بیان کیا کہ یہ حدیث مجھ سے نعمان بن ابی عیاش نے سنی اور کہا کہ  میں گواہی دیتا ہوں کہ میں"}
{"hadithnumber": "6585", "text": "احمد بن شبیب بن سعید حبطی نے بیان کیا، ان سے ان کے والد نے بیان کیا، ان سے یونس نے، ان سے ابن شہاب ن"}
{"hadithnumber": "6586", "text": "ہم سے احمد بن صالح نے بیان کیا، انہوں نے کہا ہم سے ابن وہب نے بیان کیا، انہوں نے کہا کہ مجھ سے یونس"}
{"hadithnumber": "6587", "text": "ہم سے ابراہیم بن المنذر حزامی نے بیان کیا، کہا ہم سے محمد بن فلیح نے بیان کیا، کہا ہم سے ہمارے والد"}
{"hadithnumber": "6588", "text": "مجھ سے ابراہیم بن المنذر نے بیان کیا، انہوں نے کہا کہ ہم سے انس بن عیاض نے بیان کیا، ان سے عبیداللہ"}
{"hadithnumber": "6589", "text": "ہم سے عبدان نے بیان کیا، کہا مجھ کو میرے والد نے خبر دی، انہیں شعبہ نے، ان سے عبدالملک نے بیان کیا،"}
{"hadithnumber": "6590", "text": "ہم سے عمرو بن خالد نے بیان کیا، کہا ہم سے لیث نے بیان کیا، ان سے یزید نے، ان سے ابوالخیر مرثد بن عبد"}
{"hadithnumber": "6591", "text": "ہم سے علی بن عبداللہ مدینی نے بیان کیا، کہا ہم سے حرمی بن عمارہ نے بیان کیا، کہا ہم سے شعبہ نے بیان"}
{"hadithnumber": "6592", "text": "اور ابن ابوعدی محمد بن ابراہیم نے بھی شعبہ سے روایت کیا، ان سے معبد بن خالد نے اور ان سے حارثہ رضی ا"}
{"hadithnumber": "6593", "text": "ہم سے سعید بن ابی مریم نے بیان کیا، ان سے نافع بن عمر نے، کہا کہ مجھ سے ابن ابی ملیکہ نے بیان کیا، ا"}
