{"hadithnumber": "2385", "text": "ہم سے محمد بن یوسف بیکندی نے بیان کیا، کہا کہ ہم کو جریر نے خبر دی، انہیں مغیرہ نے، انہیں شعبی نے او"}
{"hadithnumber": "2386", "text": "ہم سے معلی بن اسد نے بیان کیا، ان سے عبدالواحد نے بیان کیا، ان سے اعمش نے بیان کیا، انہوں نے بیان کی"}
{"hadithnumber": "2387", "text": "ہم سے عبدالعزیز بن عبداللہ اویسی نے بیان کیا، ان سے سلیمان بن بلال نے بیان کیا، ان سے ثور بن زید نے،"}
{"hadithnumber": "2388", "text": "ہم سے احمد بن یونس نے بیان کیا، کہا کہ ہم سے ابوشہاب نے بیان کیا، ان سے اعمش نے، ان سے زید بن وہب نے"}
{"hadithnumber": "2389", "text": "ہم سے احمد بن شبیب بن سعید نے بیان کیا، کہا کہ ہم سے ہمارے والد نے بیان کیا، ان سے یونس نے کہ ابن شہ"}
{"hadithnumber": "2390", "text": "ہم سے ابوالولید نے بیان کیا، کہا کہ ہم سے شعبہ نے بیان کیا، انہیں سلمہ بن کہیل نے خبر دی، کہا کہ میں"}
{"hadithnumber": "2391", "text": "ہم سے مسلم نے بیان کیا، کہا کہ ہم سے شعبہ نے بیان کیا، ان سے عبدالملک نے، ان سے ربعی بن حراش نے اور"}
{"hadithnumber": "2392", "text": "ہم سے مسدد نے بیان کیا، ان سے یحییٰ قطان نے، ان سے سفیان ثوری نے کہ مجھ سے سلمہ بن کہیل نے بیان کیا،"}
{"hadithnumber": "2393", "text": "ہم سے ابونعیم نے بیان کیا، ان سے سفیان بن عیینہ نے بیان کیا، ان سے ابوسلمہ نے اور ان سے ابوہریرہ رضی"}
{"hadithnumber": "2394", "text": "ہم سے خلاد نے بیان کیا، ان سے مسعر نے بیان کیا، ان سے محارب بن دثار نے بیان کیا، اور ان سے جابر بن ع"}
{"hadithnumber": "2395", "text": "ہم سے عبدان نے بیان کیا، کہا کہ ہم کو عبداللہ بن مبارک نے خبر دی، انہیں یونس نے خبر دی، انہیں زہری ن"}
{"hadithnumber": "2396", "text": "ہم سے ابراہیم بن المنذر نے کہا کہ ہم سے انس نے بیان کیا، ان سے ہشام نے، ان سے وہب بن کیسان نے اور ان"}
{"hadithnumber": "2397", "text": "ہم سے ابوالیمان نے بیان کیا، انہوں نے کہا کہ ہمیں شعیب نے خبر دی، وہ زہری سے روایت کرتے ہیں (دوسری س"}
{"hadithnumber": "2398", "text": "ہم سے ابوالولید نے بیان کیا، ان سے شعبہ نے بیان کیا، ان سے عدی بن ثابت نے، ان سے ابوحازم نے اور ان س"}
{"hadithnumber": "2399", "text": "ہم سے عبداللہ بن محمد نے بیان کیا، انہوں نے کہا کہ ہم سے ابوعامر نے بیان کیا، ان سے فلیح نے بیان کیا"}
{"hadithnumber": "2400", "text": "ہم سے مسدد نے بیان کیا، کہا کہ ہم سے عبدالاعلیٰ نے بیان کیا، ان سے معمر نے، ان سے ہمام بن منبہ، وہب"}
{"hadithnumber": "2401", "text": "ہم سے مسدد نے بیان کیا، ان سے یحییٰ نے بیان کیا، ان سے شعبہ نے، ان سے سلمہ نے، ان سے ابوسلمہ نے اور"}
{"hadithnumber": "2402", "text": "ہم سے احمد بن یونس نے بیان کیا، ان سے زہیر نے بیان کیا، انہوں نے کہا ان سے یحییٰ بن سعید نے بیان کیا"}
{"hadithnumber": "2403", "text": "ہم سے مسدد نے بیان کیا، کہا کہ ہم سے یزید بن زریع نے بیان کیا، ان سے حسین معلم نے بیان کیا، ان سے عط"}
{"hadithnumber": "2404", "text": "لیث نے بیان کیا کہ مجھ سے جعفر بن ربیعہ نے بیان کیا، ان سے عبدالرحمٰن بن ہرمز نے اور ان سے ابوہریرہ"}
{"hadithnumber": "2406", "text": "اور ایک مرتبہ میں نبی کریم صلی اللہ علیہ وسلم کے ساتھ ایک جہاد میں ایک اونٹ پر سوار ہو کر گیا۔ اونٹ"}
{"hadithnumber": "2407", "text": "ہم سے ابونعیم نے بیان کیا، کہا کہ ہم سے سفیان بن عیینہ نے بیان کیا، ان سے عبداللہ بن دینار نے بیان ک"}
{"hadithnumber": "2408", "text": "ہم سے عثمان بن ابی شبیہ نے بیان کیا، ان سے جریر نے بیان کیا، ان سے منصور نے، ان سے شعبی نے، ان سے مغ"}
{"hadithnumber": "2409", "text": "ہم سے ابوالیمان حکم بن نافع نے بیان کیا، کہا کہ ہم کو شعیب نے خبر دی، ان سے زہری نے بیان کیا انہیں س"}
