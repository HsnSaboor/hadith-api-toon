{"hadithnumber": "248", "text": "ہم سے عبداللہ بن یوسف نے بیان کیا، انہوں نے کہا ہمیں مالک نے ہشام سے خبر دی، وہ اپنے والد سے، وہ نبی"}
{"hadithnumber": "249", "text": "ہم سے محمد بن یوسف نے حدیث بیان کی، انہوں نے کہا کہ ہم سے سفیان نے بیان کیا اعمش سے روایت کر کے، وہ"}
{"hadithnumber": "250", "text": "ہم سے آدم بن ابی ایاس نے حدیث بیان کی، انہوں نے کہا کہ ہم سے ابن ابی ذئب نے حدیث بیان کی۔ انہوں نے ز"}
{"hadithnumber": "251", "text": "ہم سے عبداللہ بن محمد نے حدیث بیان کی، انہوں نے کہا کہ ہم سے عبدالصمد نے، انہوں نے کہا ہم سے شعبہ نے"}
{"hadithnumber": "252", "text": "ہم سے عبداللہ بن محمد نے حدیث بیان کی، انہوں نے کہا کہ ہم سے یحییٰ بن آدم نے حدیث بیان کی، انہوں نے"}
{"hadithnumber": "253", "text": "ہم سے ابونعیم نے روایت کی، انہوں نے کہا کہ ہم سے سفیان بن عیینہ نے عمرو کے واسطہ سے بیان کیا، وہ جاب"}
{"hadithnumber": "254", "text": "ابونعیم نے ہم سے بیان کیا، انہوں نے کہا کہ ہم سے زہیر نے روایت کی ابواسحاق سے، انہوں نے کہا کہ ہم سے"}
{"hadithnumber": "255", "text": "محمد بن بشار نے ہم سے حدیث بیان کی، انہوں نے کہا ہم سے غندر نے بیان کیا، انہوں نے کہا کہ ہم سے شعبہ"}
{"hadithnumber": "256", "text": "ہم سے ابونعیم (فضل بن دکین) نے بیان کیا، کہا کہ ہم سے معمر بن یحییٰ بن سام نے روایت کیا، کہا کہ ہم س"}
{"hadithnumber": "257", "text": "ہم سے موسیٰ بن اسماعیل نے بیان کیا، انہوں نے کہا ہم سے عبدالواحد نے اعمش کے واسطے سے بیان کیا، انہوں"}
{"hadithnumber": "258", "text": "محمد بن مثنیٰ نے ہم سے بیان کیا، کہا کہ ہم سے ابوعاصم (ضحاک بن مخلد) نے بیان کیا، وہ حنظلہ بن ابی سف"}
{"hadithnumber": "259", "text": "ہم سے عمر بن حفص بن غیاث نے بیان کیا، کہا کہ ہم سے میرے والد نے بیان کیا، کہا کہ ہم سے اعمش نے، کہا"}
{"hadithnumber": "260", "text": "ہم سے عبداللہ بن زبیر حمیدی نے بیان کیا، انہوں نے کہا ہم سے سفیان نے بیان کیا، انہوں نے کہا کہ ہم سے"}
{"hadithnumber": "261", "text": "ہم سے عبداللہ بن مسلمہ نے بیان کیا، کہا ہم سے افلح بن حمید نے بیان کیا قاسم سے، وہ عائشہ رضی اللہ عن"}
{"hadithnumber": "262", "text": "ہم سے مسدد نے بیان کیا، انہوں نے کہا ہم سے حماد نے ہشام کے واسطے سے بیان کیا، وہ اپنے والد سے، وہ عا"}
{"hadithnumber": "263", "text": "ہم سے ابوالولید نے بیان کیا۔ کہا ہم سے شعبہ نے ابوبکر بن حفص کے واسطے سے بیان کیا، وہ عروہ سے، وہ عا"}
{"hadithnumber": "264", "text": "ہم سے ابوالولید نے بیان کیا، انہوں نے کہا ہم سے شعبہ نے عبداللہ بن عبداللہ بن جبیر سے انہوں نے کہا ک"}
{"hadithnumber": "265", "text": "ہم سے محمد بن محبوب نے بیان کیا، انہوں نے کہا ہم سے عبدالواحد بن زیاد نے بیان کیا، انہوں نے کہا ہم س"}
{"hadithnumber": "266", "text": "ہم سے موسیٰ بن اسماعیل نے بیان کیا، انہوں نے کہا ہم سے ابوعوانہ نے بیان کیا، انہوں نے کہا ہم سے اعمش"}
{"hadithnumber": "267", "text": "ہم سے محمد بن بشار نے حدیث بیان کی، کہا ہم سے ابن ابی عدی اور یحییٰ بن سعید نے شعبہ سے، وہ ابراہیم ب"}
{"hadithnumber": "268", "text": "ہم سے محمد بن بشار نے بیان کیا۔ انہوں نے کہا ہم سے معاذ بن ہشام نے بیان کیا، انہوں نے کہا مجھ سے میر"}
{"hadithnumber": "269", "text": "ہم سے ابوالولید نے بیان کیا، کہا ہم سے زائدہ نے ابوحصین کے واسطہ سے، انہوں نے ابوعبدالرحمٰن سے، انہو"}
{"hadithnumber": "270", "text": "ہم سے ابوالنعمان نے بیان کیا، کہا ہم سے ابوعوانہ نے ابراہیم بن محمد بن منتشر سے، وہ اپنے والد سے، کہ"}
{"hadithnumber": "271", "text": "ہم سے آدم بن ابی ایاس نے بیان کیا، کہا ہم سے شعبہ نے حدیث بیان کی، کہا ہم سے حکم نے ابراہیم کے واسطہ"}
{"hadithnumber": "272", "text": "ہم سے عبدان نے بیان کیا، انہوں نے کہا ہم سے عبداللہ نے بیان کیا، انہوں نے کہا ہم سے ہشام بن عروہ نے"}
{"hadithnumber": "273", "text": "اور عائشہ رضی اللہ عنہا نے فرمایا کہ میں اور رسول اللہ صلی اللہ علیہ وسلم ایک برتن میں غسل کرتے تھے۔"}
