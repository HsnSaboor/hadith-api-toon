{"hadithnumber": "1371", "text": "قاسم بن محمد سے روایت ہے ، انھوں نے کہا کہ میں نے حضرت عبداللہ بن عباس رضی اللہ عنہما کو سنا ، اس حا"}
{"hadithnumber": "1372", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ بے شک رسول اللہ ﷺ نے ایک بیع میں دو بیع کرنے سے منع فرمایا ہے"}
{"hadithnumber": "1373", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ ایک آدمی نے دوسرے شخص سے کہا کہ تم میرے لیے اس اونٹ کو نقد خر"}
{"hadithnumber": "1374", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ قاسم بن محمد رحمہ اللہ سے اس شخص کے متعلق سوال کیا گیا جس نے"}
{"hadithnumber": "1375", "text": "سعید بن مسیب رحمہ اللہ سے روایت ہے کہ بے شک رسول اللہ ﷺ نے دھوکے کی بیع سے منع فرمایا ہے ۔"}
{"hadithnumber": "1376", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ بے شک رسول اللہ ﷺ نے ملامسہ اور منابذہ سے منع فرمایا ہے ۔"}
{"hadithnumber": "1377", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ بے شک رسول اللہ ﷺ نے فرمایا :’’ دو بیع کرنے والے ("}
{"hadithnumber": "1378", "text": "حضرت عبداللہ بن مسعود رضی اللہ عنہ سے روایت ہے ، وہ بیان کیا کرتے تھے کہ رسول اللہ ﷺ نے فرمایا :’’ ج"}
{"hadithnumber": "1379", "text": "عبید ابو صالح جو کہ سفاح کے آزاد کردہ غلام تھے ، سے روایت ہے انھوں نے کہا کہ میں نے ( مکہ و طائف کے"}
{"hadithnumber": "1380", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے ، ان سے اس شخص کے متعلق سوال کیا گیا جس کا دوسرے شخص"}
{"hadithnumber": "1381", "text": "زید بن اسلم رحمہ اللہ سے روایت ہے ، انھوں نے کہا کہ دورِ جاہلیت کا سود اس طرح تھا کہ ایک آدمی کا دوس"}
{"hadithnumber": "1382", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ بے شک رسول اللہ ﷺ نے فرمایا :’’ مالدار آدمی کا ٹال مٹول کر"}
{"hadithnumber": "1383", "text": "موسیٰ بن میسرہ رحمہ اللہ سے روایت ہے ، انھوں نے ایک شخص کو سنا ، وہ سعید بن مسیب رحمہ اللہ سے سوال ک"}
{"hadithnumber": "1384", "text": "ابوبکر بن عبدالرحمن بن حارث بن ہشام سے روایت ہے کہ بے شک رسول اللہ ﷺ نے فرمایا :’’ جس آدمی نے کوئی س"}
{"hadithnumber": "1385", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ بے شک رسول اللہ ﷺ نے فرمایا :’’ جو کوئی شخص مفلس ہو جائے ،"}
