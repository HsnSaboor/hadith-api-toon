hadiths[46]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
2390,"عمر بن خطاب رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اپنے صدقہ کو دے کر",,,,,2390
2391,"عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو صدقہ دے کر و",,,,,2391
2392,عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم کے عہد میں ایک گھو,,,,,2392
2393,زبیر بن عوام رضی اللہ عنہ سے روایت ہے کہ  انہوں نے اللہ تعالیٰ کی راہ میں ایک گھوڑی صدقہ میں دی جس ک,,,,,2393
2394,"بریدہ رضی اللہ عنہ کہتے ہیں کہ  ایک عورت نے رسول اللہ صلی اللہ علیہ وسلم کے پاس آ کر عرض کیا: اللہ ",,,,,2394
2395,عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  ایک شخص نبی اکرم صلی اللہ علیہ وسلم کی خدمت میں,,,,,2395
2396,عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  عمر بن خطاب رضی اللہ عنہ کو خیبر میں کچھ زمین ملی، تو وہ ,,,,,2396
2397,"عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  عمر بن خطاب رضی اللہ عنہ نے کہا: اللہ کے رسول! خیبر کے جو",,,,,2397
2398,"ابوامامہ رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  عاریت  ( مانگ",,,,,2398
2399,"انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  عاریت  ( م",,,,,2399
2400,"سمرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ہاتھ پر واجب ہے کہ جو وہ لے ",,,,,2400
2401,"عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس کے ",,,,,2401
2402,عروہ بارقی رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے ان کو ایک بکری خریدنے کے لیے ,,,,,2402
2403,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مالدار کا  ( قرض کی ادائ",,,,,2403
2404,"عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مالدار کا ٹال مٹ",,,,,2404
2405,"ابوامامہ باہلی رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  ( قرض ک",,,,,2405
2406,عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے عہد میں ایک شخص ایک قرض ,,,,,2406
2407,ابوقتادہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم کے پاس ایک جنازہ لایا گیا، تاکہ آپ,,,,,2407
2408,ام المؤمنین میمونہ رضی اللہ عنہا کہتی ہیں کہ  وہ قرض لیا کرتی تھیں تو ان کے گھر والوں میں سے کسی نے ,,,,,2408
2409,"عبداللہ بن جعفر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ تعالیٰ قرض",,,,,2409
2410,"صہیب الخیر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو قرض لے اور اس کو اد",,,,,2410
2411,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جو لوگوں کا مال لے اور اس",,,,,2411
2412,"ثوبان رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس کی روح بدن سے جدا ہوئی ا",,,,,2412
2413,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  آدمی کی جان اس کے قرض ک",,,,,2413
2414,"عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو مر جائے اور ا",,,,,2414
2415,ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  جب کوئی مومن رسول اللہ صلی اللہ علیہ وسلم کے عہد میں وفات پا ج,,,,,2415
2416,"جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو مال چھوڑ جائے تو وہ اس کے",,,,,2416
2417,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو کسی تنگ دست پر آسانی",,,,,2417
2418,"بریدہ اسلمی رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جو کسی تنگ دست کو مہلت",,,,,2418
2419,"صحابی رسول ابوالیسر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو کوئی یہ چا",,,,,2419
2420,حذیفہ رضی اللہ عنہ نبی اکرم صلی اللہ علیہ وسلم سے روایت کرتے ہیں کہ  ایک شخص مر گیا تو اس سے پوچھا گ,,,,,2420
2421,"ابن عمر اور عائشہ رضی اللہ عنہم سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو کسی حق ک",,,,,2421
2422,"ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے صاحب حق سے فرمایا:  شریفانہ ان",,,,,2422
2423,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم میں بہتر وہ ہے یا بہت",,,,,2423
2424,عبداللہ بن ابی ربیعہ مخزومی رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے غزوہ حنین کے,,,,,2424
2425,عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  ایک شخص نبی اکرم صلی اللہ علیہ وسلم سے اپنا قرض یا حق ما,,,,,2425
2426,ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  ایک اعرابی نبی اکرم صلی اللہ علیہ وسلم سے اپنے قرض کا مطالبہ,,,,,2426
2427,"شرید رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو قرض ادا کر سکتا ہو اس کا ",,,,,2427
2428,ہرماس بن حبیب اپنے والد کے واسطے سے اپنے دادا سے روایت کرتے ہیں کہ  میں رسول اللہ صلی اللہ علیہ وسلم,,,,,2428
2429,کعب بن مالک رضی اللہ عنہ سے روایت ہے کہ  انہوں نے مسجد نبوی میں ابن ابی حدرد سے اپنے قرض کا مطالبہ ک,,,,,2429
2430,قیس بن رومی کہتے ہیں کہ  سلیمان بن اذنان نے علقمہ کو ان کی تنخواہ ملنے تک کے لیے ایک ہزار درہم قرض د,,,,,2430
2431,"انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  معراج کی رات میں نے ج",,,,,2431
2432,"یحییٰ بن ابی اسحاق ہنائی کہتے ہیں کہ  میں نے انس بن مالک رضی اللہ عنہ سے پوچھا: ہم میں سے ایک شخص اپ",,,,,2432
2433,سعد بن اطول رضی اللہ عنہ کہتے ہیں کہ  ان کے بھائی وفات پا گئے، اور  ( ترکہ میں )  تین سو درہم اور با,,,,,2433
2434,جابر بن عبداللہ رضی اللہ عنہما سے روایت ہے کہ  ان کے والد وفات پا گئے، اور اپنے اوپر ایک یہودی کے تی,,,,,2434
2528,"عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص کسی غلام ",,,,,2528
