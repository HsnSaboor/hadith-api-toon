{"hadithnumber": "6805", "text": "جریر نے اعمش سے ،  انہوں نے ابوصالح سے اور انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  کہا :"}
{"hadithnumber": "6806", "text": "ابومعاویہ نے اعمش سے اسی سند کے ساتھ حدیث بیان کی ،  اور انہوں نے یہ بیان نہیں کیا کہ  \" اگر وہ ایک"}
{"hadithnumber": "6807", "text": ")   ہمیں معمر نے ہمام بن منبہ سے حدیث بیان کی ،  کہا :  یہ احادیث ابوہریرہ رضی اللہ عنہ نے ہمیں رسول"}
{"hadithnumber": "6808", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم مکہ کے ایک راستے پر چل"}
{"hadithnumber": "6809", "text": "عمرو ناقد ،  زُہیر بن حرب اور ابن ابی عمر نے ہمیں سفیان سے حدیث بیان کی  ۔  ۔  الفاظ عمرو کے ہیں  ۔"}
{"hadithnumber": "6810", "text": "معمر نے ہمیں ایوب سے خبر دی ،  انہوں نے ابن سیرین سے ،  انہوں نے ابوہریرہ رضی اللہ عنہ سے ،  نیز  ("}
{"hadithnumber": "6811", "text": ")   عبدالعزیز بن صُہیب نے حضرت انس رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا کہ رسول اللہ صلی اللہ عل"}
{"hadithnumber": "6812", "text": "علاء کے والد  ( عبدالرحمٰن )  نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ علیہ و"}
{"hadithnumber": "6813", "text": "عطاء بن میناء نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فر"}
{"hadithnumber": "6814", "text": "عبدالعزیز نے حضرت انس رضی اللہ عنہ سے روایت کی ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :"}
{"hadithnumber": "6815", "text": "ثابت نے حضرت انس رضی اللہ عنہ سے اور انہوں نے نبی صلی اللہ علیہ وسلم سے اسی کے مانند روایت کی ،  مگر"}
{"hadithnumber": "6816", "text": "عاصم نے ہمیں نضر بن انس سے حدیث بیان کی کہ حضرت انس رضی اللہ عنہ ان دنوں زندہ تھے ۔   ( نضر نے )  کہ"}
{"hadithnumber": "6817", "text": "عبداللہ بن ادریس نے اسماعیل بن ابی خالد سے ،  انہوں نے قیس بن ابی حازم سے روایت کی کہ انہوں نے کہا :"}
{"hadithnumber": "6818", "text": "سفیان بن عیینہ ،  جریر بن عبدالحمید ،  وکیع ،  عبداللہ بن نمیر ،  معتمر بن سلیمان اور ابواسامہ سب نے"}
{"hadithnumber": "6819", "text": "معمر نے ہمیں ہمام بن منبہ سے حدیث بیان کی ،  کہا :  یہ احادیث ہمیں ابوہریرہ رضی اللہ عنہ نے رسول الل"}
{"hadithnumber": "6820", "text": "ہمام نے کہا :  ہمیں قتادہ نے انس بن مالک رضی اللہ عنہ سے حدیث بیان کی ،  انہوں نے حضرت عبادہ بن صامت"}
{"hadithnumber": "6821", "text": "شعبہ نے قتادہ سے روایت کی ،  انہوں نے کہا :  میں نے حضرت انس بن مالک رضی اللہ عنہ کو حضرت عبادہ بن ص"}
{"hadithnumber": "6822", "text": "خالد بن حارث بجیمی نے کہا :  ہمیں سعید نے قتادہ سے حدیث بیان کی ،  انہوں نے زُرارہ سے ،  انہوں نے سع"}
{"hadithnumber": "6823", "text": "محمد بن بکر نے کہا :  ہمیں سعید نے قتادہ سے اسی سند کے ساتھ حدیث بیان کی ۔"}
{"hadithnumber": "6824", "text": "علی بن مسہر نے زکریا سے ،  انہوں نے شعبی سے ،  انہوں نے شریح بن بانی سے اور انہوں نے حضرت عائشہ رضی"}
{"hadithnumber": "6825", "text": "عیسیٰ بن یونس نے کہا :  ہمیں زکریا نے عامر  ( شعبی )  سے حدیث بیان کی ،  انہوں نے کہا :  مجھے شُریح"}
{"hadithnumber": "6826", "text": "عبثر نے مطرف سے ،  انہوں نے عامر سے ،  انہوں نے شریح بن ہانی سے اور انہوں نے حضرت ابوہریرہ رضی اللہ"}
{"hadithnumber": "6827", "text": "جریر نے مطرف سے اسی سند کے ساتھ عبثر کی حدیث کے مانند خبر دی ۔"}
{"hadithnumber": "6828", "text": "حضرت ابوموسیٰ اشعری رضی اللہ عنہ نے نبی صلی اللہ علیہ وسلم سے روایت کی کہ آپ نے فرمایا :   \" جو شخص"}
{"hadithnumber": "6829", "text": "یزید بن اصم نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرما"}
{"hadithnumber": "6830", "text": "یحییٰ بن سعید اور ابن ابی عدی نے سلیمان تیمی سے ،  انہوں نے حضرت انس بن مالک رضی اللہ عنہ سے ،  انہو"}
{"hadithnumber": "6831", "text": "معتمر نے اپنے والد  ( سلیمان تیمی )  سے اسی سند کے ساتھ حدیث بیان کی اور  \" جب وہ چل کر میرے پاس آتا"}
{"hadithnumber": "6832", "text": "ابوصالح نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :"}
{"hadithnumber": "6833", "text": "وکیع نے کہا :  ہمیں اعمش نے معرور بن سوید سے حدیث بیان کی ،  انہوں نے حضرت ابوزر رضی اللہ عنہ سے روا"}
{"hadithnumber": "6834", "text": "ابومعاویہ نے اعمش سے اسی سند کے ساتھ اسی کے مانند روایت بیان کی ،  مگر انہوں نے کہا :   \" اس کے لیے"}
{"hadithnumber": "6835", "text": "محمد بن ابوعدی نے حمید سے ،  انہوں نے ثابت سے اور انہوں نے حضرت انس بن مالک رضی اللہ عنہ سے روایت کی"}
{"hadithnumber": "6836", "text": "خالد بن حارث نے کہا :  ہمیں حمید نے اسی سند کے ساتھ دعا کے ان الفاظ تک حدیث بیان کی :   \" ہمیں دوزخ"}
{"hadithnumber": "6837", "text": "حماد نے کہا :  ثابت نے ہمیں حضرت انس رضی اللہ عنہ سے خبر دی کہ رسول اللہ صلی اللہ علیہ وسلم اپنے صحا"}
{"hadithnumber": "6838", "text": ")  قتادہ نے انس رضی اللہ عنہ سے اور انہوں نے نبی صلی اللہ علیہ وسلم سے یہی حدیث بیان کی ۔"}
{"hadithnumber": "6839", "text": "حضرت ابوہریرہ رضی اللہ عنہ نے نبی صلی اللہ علیہ وسلم سے روایت کی کہ آپ نے فرمایا :   \" اللہ تبارک و"}
{"hadithnumber": "6840", "text": ")   عبدالعزیز بن صہیب نے کہا :  قتادہ نے حضرت انس رضی اللہ عنہ سے پوچھا کہ رسول اللہ صلی اللہ علیہ و"}
{"hadithnumber": "6841", "text": "ثابت نے حضرت انس رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ علیہ وسلم  ( دعا فرماتے ہوئے یہ )  ک"}
{"hadithnumber": "6842", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   \" جو شخص دن میں"}
{"hadithnumber": "6843", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ے ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :  کوئی شخص ج"}
{"hadithnumber": "6846", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   \" دو کلم"}
{"hadithnumber": "6847", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   \" یہ بات"}
{"hadithnumber": "6848", "text": "ابوبکر بن ابی شیبہ نے ہمیں حدیث بیان کی ،  کہا :  ہمیں علی بن مسہر اور ابن نمیر نے موسیٰ جہنی سے حدی"}
{"hadithnumber": "6849", "text": "عبدالواحد بن زیاد نے کہا :  ہمیں ابو مالک اشجعی نے اپنے والد  ( طارق بن اشیم اشجعی رضی اللہ عنہ )  س"}
{"hadithnumber": "6850", "text": "ابومعاویہ نے کہا؛ ہمیں ابومالک اشجعی نے اپنے والد سے حدیث بیان کی ،  کہا :  جب کوئی شخص مسلمان ہوتا"}
{"hadithnumber": "6851", "text": "یزید بن ہارون نے کہا :  ابومالک نے ہمیں اپنے والد سے خبر دی کہ انہوں نے نبی صلی اللہ علیہ وسلم سے سن"}
{"hadithnumber": "6852", "text": ")   معصب بن سعد سے روایت ہے ،  انہوں نے کہا :  مجھے میرے والد  ( سعد بن ابی وقاص رضی اللہ عنہ )  نے"}
{"hadithnumber": "6853", "text": "ابومعاویہ نے اعمش سے ،  انہوں نے ابوصالح سے اور انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  ک"}
{"hadithnumber": "6854", "text": "عبداللہ بن نمیر اور ابواسامہ نے کہا :  ہمیں اعمش نے حدیث بیان کی ،  انہوں نے ابوصالح سے اور انہوں نے"}
{"hadithnumber": "6857", "text": "حضرت ابوسعید خدری رضی اللہ عنہ سے روایت ہے ،  کہا :  حضرت معاویہ رضی اللہ عنہ نکل کر مسجد میں ایک حل"}
{"hadithnumber": "6858", "text": "ثابت نے ابو بُردہ سے اور انہوں نے حضرت اغرمزنی رضی اللہ عنہ سے ،  جنہیں شرفِ صحبت حاصل تھا ،  روایت"}
{"hadithnumber": "6859", "text": "غندر نے شعبہ سے ،  انہوں نے عمرہ بن مُرہ سے اور انہوں نے ابوبُردہ سے روایت کی ،  انہوں نے کہا :  میں"}
{"hadithnumber": "6860", "text": "عبیداللہ کے والد معاذ ،  ابوداؤد اور عبدالرحمٰن بن مہدی نے شعبہ سے اسی سند سے  ( یہی )  روایت کی ۔"}
{"hadithnumber": "6861", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   \" جس شخص"}
{"hadithnumber": "6862", "text": "محمد بن فضیل اور ابومعاویہ نے عاصم سے ،  انہوں نے ابوعثمان سے اور انہوں نے حضرت ابوموسیٰ رضی اللہ عن"}
{"hadithnumber": "6863", "text": ")   حفص بن غیاث نے عاصم سے اسی سند کے ساتھ اسی کے مانند روایت کی ۔"}
{"hadithnumber": "6864", "text": "یزید بن زُریع نے کہا :  ہمیں  ( سلیمان )  تیمی نے ابوعثمان سے حدیث بیان کی ،  انہوں نے حضرت ابوموسیٰ"}
{"hadithnumber": "6865", "text": "معتمر نے اپنے والد  ( سلیمان تیمی )  سے روایت کی ،  انہوں نے کہا :  ہمیں ابوعثمان نے حضرت ابوموسیٰ ر"}
{"hadithnumber": "6866", "text": "ایوب نے ابوعثمان سے اور انہوں نے حضرت ابوموسیٰ رضی اللہ عنہ سے روایت کی ،  کہا :  ہم رسول اللہ صلی ا"}
{"hadithnumber": "6867", "text": "خالد حذاء نے ابوعثمان سے اور انہوں نے حضرت ابوموسیٰ رضی اللہ عنہ سے روایت کی ،   کہا :  ہم ایک غزوے"}
{"hadithnumber": "6868", "text": "عثمان بن غیاث نے کہا :  ہمیں ابوعثمان نے حضرت ابوموسی اشعری رضی اللہ عنہ سے روایت کی ،  کہا :  رسول"}
{"hadithnumber": "6869", "text": "ابو بکر رضی اﷲ عنہ سے روایت ہے انہوں نے رسول اﷲ ﷺ سے عرض کیا یارسول اﷲ ﷺ مجھے ایک دعا سکھلائیے جس کو"}
{"hadithnumber": "6870", "text": "عبداللہ بن وہب نے ہمیں خبر دی ،  کہا :  ہمیں ایک آدمی نے جس کا انہوں نے نام لیا اور عمرو بن حارث نے"}
{"hadithnumber": "6871", "text": "ابن نمیر نے کہا :  ہمیں ہشام نے اپنے والد  ( عروہ )  سے اور انہوں نے حضرت عائشہ رضی اللہ عنہا سے روا"}
{"hadithnumber": "6872", "text": "ابومعاویہ اور وکیع نے ہمیں ہشام سے اسی سند کے ساتھ حدیث بیان کی ۔"}
{"hadithnumber": "6873", "text": "ابن علیہ نے کہا :  ہمیں سلیمان تیمی نے خبر دی ،  انہوں نے کہا :  ہمیں حضرت انس بن مالک رضی اللہ عنہ"}
{"hadithnumber": "6874", "text": "یزید بن زریع اور معتمر دونوں نے تیمی سے ،  انہوں نے حضرت انس رضی اللہ عنہ سے اور انہوں نے نبی صلی ال"}
{"hadithnumber": "6875", "text": "ابن مبارک نے سلیمان تیمی سے ،  انہوں نے حضرت انس بن مالک رضی اللہ عنہ سے ،  انہوں نے نبی صلی اللہ عل"}
{"hadithnumber": "6876", "text": "شعیب بن حبحاب نے حضرت انس رضی اللہ عنہ سے روایت کی کہ نبی صلی اللہ علیہ وسلم یہ دعائیں مانگا کرتے تھ"}
{"hadithnumber": "6877", "text": ")   عمرو ناقد اور زُہیر بن حرب نے مجھے حدیث بیان کی ،  انہوں نے کہا :  ہمیں سفیان بن عیینہ نے حدیث ب"}
{"hadithnumber": "6878", "text": "لیث نے یزید بن ابی حبیب سے اور انہون نے حارث بن یعقوب سے روایت کی کہ یعقوب بن عبداللہ نے انہیں حدیث"}
{"hadithnumber": "6880", "text": "یعقوب نے کہا :  قعقاع بن حکیم نے ذوان سے ،  انہوں نے ابوصالح سے اور انہوں نے حضرت ابوہریرہ رضی اللہ"}
{"hadithnumber": "6881", "text": "لیث نے یزید بن ابی حبیب سے ،  انہوں نے جعفر سے ،  انہوں نے یعقوب سے روایت کی ،  انہوں نے ان کو بتایا"}
{"hadithnumber": "6882", "text": "منصور نے سعد بن عبیدہ سے روایت کی ،  انہوں نے کہا :  مجھے حضرت براء بن عازب رضی اللہ عنہ نے حدیث بیا"}
{"hadithnumber": "6883", "text": "حُصین بن سعد بن عبیدہ سے ،  انہوں نے حضرت براء بن عازب رضی اللہ عنہ سے اور انہوں نے نبی صلی اللہ علی"}
{"hadithnumber": "6884", "text": "محمد بن مثنیٰ نے ابوداود سے اور ابن بشار نے عبدالرحمٰن اور ابوداود دونوں سے روایت کی ،  دونوں نے کہا"}
{"hadithnumber": "6885", "text": "ابو احوص نے ابواسحٰق سے اور انہوں نے حضرت براء بن عازب رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی الل"}
{"hadithnumber": "6886", "text": "شعبہ نے ابواسحٰق سے روایت کی کہ انہوں نے حضرت براء بن عازب رضی اللہ عنہ کو کہتے ہوئے سنا :  رسول الل"}
{"hadithnumber": "6887", "text": "حضرت براء بن عازب رضی اللہ عنہ سے روایت ہے کہ نبی صلی اللہ علیہ وسلم جب بستر پر تشریف لے جاتے تو یہ"}
{"hadithnumber": "6888", "text": "عقبہ بن مُکرم اور ابوبکر بن نافع نے کہا :  ہمیں غندر نے حدیث بیان کی ،  انہوں نے کہا :  ہمیں شعبہ نے"}
{"hadithnumber": "6889", "text": "جریر نے سہیل سے روایت کی ،  انہوں نے کہا :   ( میرے والد )  ابوصالح ہمیں حکم دیا کرتے تھے کہ جب ہم م"}
{"hadithnumber": "6890", "text": "خالد طحان نے سہیل سے ،  انہوں نے اپنے والد سے اور انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،"}
{"hadithnumber": "6891", "text": "اعمش نے ابوصالح سے اور انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  کہا :  حضرت فاطمہ رضی اللہ"}
{"hadithnumber": "6892", "text": "انس بن عیاض نے کہا :  ہمیں عبیداللہ نے حدیث بیان کی ،  انہوں نے کہا :  مجھے سعید بن ابی سعید مقبری ن"}
{"hadithnumber": "6893", "text": "عبدہ نے عبیداللہ بن عمر سے اسی سند کے ساتھ یہی حدیث روایت کی اور کہا :   \" پھر وہ یہ ہے :  تیرے نام"}
{"hadithnumber": "6894", "text": "حضرت انس رضی اللہ عنہ سے روایت ہے کہ رسول اللہ صلی اللہ علیہ وسلم جب بستر پر جاتے تو فرماتے :   \" ال"}
{"hadithnumber": "6895", "text": "منصور نے ہلال سے اور انہوں نے فروہ بن نوفل اشجعی سے روایت کی ،  کہا :  میں نے ام المومنین حضرت عائشہ"}
{"hadithnumber": "6896", "text": "عبداللہ بن ادریس نے حصین سے ،  انہوں نے ہلال سے اور انہوں نے فروہ بن نوفل سے روایت کی ،  کہا :  میں"}
{"hadithnumber": "6897", "text": "ابن ابی عدی اور محمد بن جعفر دونوں نے شعبہ سے اور انہوں نے حصین سے اسی سند کے ساتھ اسی کے مانند روای"}
{"hadithnumber": "6898", "text": "عبدہ بن ابولبابہ نے ہلال بن سیاف سے ،  انہوں نے فروہ بن نوفل سے اور انہوں نے حضرت عائشہ رضی اللہ عنہ"}
{"hadithnumber": "6899", "text": "حضرت ابن عباس رضی اللہ عنہ سے روایت ہے کہ رسول اللہ صلی اللہ علیہ وسلم  ( دعا کرتے ہوئے )  فرمایا کر"}
{"hadithnumber": "6900", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ نبی صلی اللہ علیہ وسلم جب کسی سفر میں ہوتے اور سحر کے وقت"}
{"hadithnumber": "6901", "text": "معاذ عنبری نے کہا :  ہمیں شعبہ نے ابواسحٰق سے حدیث بیان کی ،  انہوں نے ابوبردہ بن ابوموسیٰ اشعری سے"}
{"hadithnumber": "6902", "text": ")   عبدالملک بن صباح مسمعی نے کہا :  ہمیں شعبہ نے اسی سند سے  ( یہی )  حدیث بیان کی ۔"}
{"hadithnumber": "6903", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ،  کہا :  رسول اللہ صلی اللہ علیہ وسلم فرمایا کرتے تھے :   "}
{"hadithnumber": "6904", "text": "محمد بن مثنیٰ اور محمد بن بشار نے کہا :  ہمیں محمد بن جعفر نے حدیث بیان کی ،  انہوں نے کہا :  ہمیں ش"}
{"hadithnumber": "6905", "text": "محمد بن مثنیٰ اور ابن بشار نے کہا :  ہمیں عبدالرحمٰن نے سفیان سے حدیث بیان کی ،  انہوں نے ابواسحاق س"}
{"hadithnumber": "6906", "text": "عبداللہ بن حارث اور ابو عثمان نہدی نے حضرت زید بن ارقم رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  م"}
{"hadithnumber": "6907", "text": "عبدالواحد بن زیاد نے حسن بن عبداللہ سے روایت کی ،  انہوں نے کہا :  ہمیں ابراہیم بن سعد نخعی نے حدیث"}
{"hadithnumber": "6908", "text": "جریر نے حسن بن عبیداللہ سے ،  انہوں نے ابراہیم بن سوید سے ،  انہوں نے عبدالرحمٰن بن یزید سے اور انہو"}
{"hadithnumber": "6909", "text": ")   زائدہ نے حسن بن عبیداللہ سے ،  انہوں نے ابراہیم بن سُوید سے ،  انہوں نے عبدالرحمٰن بن یزید سے او"}
{"hadithnumber": "6910", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ رسول اللہ صلی اللہ علیہ وسلم  ( دعا کرتے ہوئے یہ )  فرمایا"}
{"hadithnumber": "6911", "text": "ابوکریب محمد بن علاء نے ہمیں حدیث بیان کی ،  انہوں نے کہا :  ہمیں  ( عبداللہ )  بن ادریس نے حدیث بیا"}
{"hadithnumber": "6912", "text": "ابن نمیر نے کہا :  ہمیں عبداللہ بن ادریس نے حدیث بیان کی ،  انہوں نے کہا :  ہمیں عاصم بن کلیب نے اسی"}
{"hadithnumber": "6913", "text": ")   کُریب نے حضرت ابن عباس رضی اللہ عنہ سے اور انہوں نے حضرت جویریہ رضی اللہ عنہا سے روایت کی کہ نبی"}
{"hadithnumber": "6914", "text": "ابورشدین نے حضرت ابن عباس رضی اللہ عنہ سے اور انہوں نے حضرت جویریہ رضی اللہ عنہا سے روایت کی ،  انہو"}
{"hadithnumber": "6915", "text": "محمد بن جعفر نے کہا :  ہمیں شعبہ نے حکم سے حدیث بیان کی ،  انہوں نے کہا :  میں نے ابن ابی لیلی سے سن"}
{"hadithnumber": "6916", "text": "وکیع ،  معاذ اور ابن ابی عدی سب نے شعبہ سے اسی سند کے ساتھ روایت کی اور معاذ کی حدیث میں ہے :   \" جب"}
{"hadithnumber": "6917", "text": "عبیداللہ بن ابی یزید اور عطاء بن ابی رباح نے مجاہد سے ،  انہوں نے ابن ابی لیلیٰ سے ،  انہوں نے حضرت"}
{"hadithnumber": "6920", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ نبی صلی اللہ علیہ وسلم نے فرمایا :   \" جب تم مرغ کی بانگ س"}
{"hadithnumber": "6921", "text": "معاذ بن ہشام نے کہا :  مجھے میرے والد نے قتادہ سے حدیث بیان کی ،  انہوں نے ابوعالیہ سے اور انہوں نے"}
{"hadithnumber": "6922", "text": "وکیع نے ہشام سے اسی سند کے ساتھ حدیث بیان کی ،  لیکن معاذ بن ہشام کی حدیث زیادہ مکمل ہے ۔"}
{"hadithnumber": "6923", "text": "ہمیں سعید بن ابی عروبہ نے قتادہ سے روایت کی ،  ابوعالیہ ریاحی نے انہیں حضرت ابن عباس رضی اللہ عنہ سے"}
{"hadithnumber": "6924", "text": "حماد بن سلمہ نے کہا :  مجھے یوسف بن عبداللہ بن حارث نے ابوعالیہ سے خبر دی ،  انہوں نے حضرت ابن عباس"}
{"hadithnumber": "6925", "text": "وہیب نے کہا :  ہمیں سعید جریری نے ابو عبداللہ جسری سے حدیث بیان کی ،  انہوں نے ابن صامت سے اور انہوں"}
{"hadithnumber": "6926", "text": "شعبہ نے جریر سے ،  انہوں نے ابوعبداللہ جسری سے جو عنزہ قبیلے سے تھے ،  انہوں نے عبداللہ بن صامت سے ا"}
{"hadithnumber": "6927", "text": ")   فضیل نے طلحہ بن عبیداللہ بن کریز سے ،  انہوں نے ام درداء سے اور انہوں نے حضرت ام درداء رضی اللہ"}
{"hadithnumber": "6928", "text": ")   موسیٰ بن سروان معلم نے ہمیں حدیث بیان کی ،  کہا :  مجھے طلحہ بن عبیداللہ بن کریز نے حدیث بیان کی"}
{"hadithnumber": "6930", "text": "( صفوان نے )  کہا :  میں بازار کی طرف نکلا تو حضرت ابودرداء رضی اللہ عنہ سے بھی میری ملاقات ہوئی ،"}
{"hadithnumber": "6931", "text": "یزید بن ہارون نے عبدالملک بن ابی سلیمان سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی ،  اور کہا :  ص"}
{"hadithnumber": "6932", "text": "ابواسامہ اور محمد بن بشر نے زکریا بن ابی زائدہ سے ،  انہوں نے سعید بن ابی بُردہ سے اور انہوں نے حضرت"}
{"hadithnumber": "6933", "text": "اسحٰق بن یوسف ازرق نے کہا :  ہمیں زکریا بن ابی زائدہ نے سعید بن ابی بُردہ سے حدیث بیان کی ،  انہوں ن"}
{"hadithnumber": "6934", "text": "امام مالک نے ابن شہاب سے ،  انہوں نے ابن ازہر کے آزاد کردہ غلام ابوعبید سے اور انہوں نے حضرت ابوہریر"}
{"hadithnumber": "6935", "text": "عقیل بن خالد نے ابن شہاب سے روایت کی ،  انہوں نے کہا :  مجھے عبدالرحمٰن بن عوف رضی اللہ عنہ کے آزاد"}
{"hadithnumber": "6936", "text": "ابوادریس خولانی نے حضرت ابوہریرہ رضی اللہ عنہ سے ،  انہوں نے نبی صلی اللہ علیہ وسلم سے روایت کی کہ آ"}
